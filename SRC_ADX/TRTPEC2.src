#<AdxTL>@(#)12.0.0.0 $Revision$
##########################################################################################################
# Exécution des escalades via serveur batch                  Module CRM     31 Décembre 2003
##########################################################################################################
##########################################################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
  #--- Actions liées au traitement standard 
  Case ACTION
    When "INIT"        : Gosub INIT
    When "OUVRE_BATCH" : Gosub INIT
    When "INIT_DIA"    : Gosub INIT_DIA
    When "CONTROLE"    : Gosub CONTROLE_DIA
    When "EXEC"        : Gosub EXEC
    When "TERMINE"     : Gosub TERMINE_DIA
    When Default
  Endcase
Return

##########################################################################################################
# Détail des actions liées au traitement standard                       #
#########################################################################
##########################################################################################################
$INIT
Return

##########################################################################################################
$INIT_DIA
  Raz [M:DIA]
Return

##########################################################################################################
$CONTROLE_DIA
Return

##########################################################################################################
$TERMINE_DIA
Return

##########################################################################################################
$EXEC
Local Char SZCLE
Local Integer ICUT
Local Integer ICLECOUNT
Local Char SZMESS(250)
Local Integer IERRINF
Local Integer IESCFLG
Local Char SZMESSAGE(250)
Local Integer IBRETOUR

  SZMESS = ""
  IERRINF = 0
  IESCFLG = 0
  Raz SZMESSAGE
  IBRETOUR = 1
  If !GSERVEUR Then
    Call OUVRE_TRACE("Escalation process") From LECFIC
  Endif
  #Lancement de l'exécution des escalades.
  SZMESS = mess(942,182,1)
  Call ECR_TRACE("--------------------------------------------",0) From GESECRAN
  Call ECR_TIME(".") From DOSSUB
  Call ECR_TRACE(SZMESS,0) From GESECRAN
  Call ECR_TRACE("--------------------------------------------",0) From GESECRAN
  If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
  If !clalev([F:SREA]) : Local File SERREQUEST [SREA] : Endif
  Gosub OUVRE From WOSRE
  Gosub OUVRE_TABLES From SUBSREA
  #---------------------------------------------------#
  #Demandes de service
  SZCLE = ""
  ICUT = 2500
  ICLECOUNT = ICUT
  While ICLECOUNT >= ICUT
    ICLECOUNT = 0
    Filter [SREA] Where [F:SREA]SREASS <> 5 and [F:SREA]SRENUM > SZCLE Order By [F:SREA]SRENUM Asc
    For [SREA]
      SZCLE = [F:SREA]SRENUM
      IERRINF = 0
      IESCFLG = 0
      Call DOESC([F:SREA]SRENUM, [M]CAT, IESCFLG, SZMESSAGE, IBRETOUR) From SUBSREB3
      If IBRETOUR = 0 Then
        #Erreur concernant la demande de service n° :
        SZMESS = mess(943,182,1) - ":" - [F:SREA]SRENUM
        Call ECR_TRACE(SZMESS, 1) From GESECRAN
        Call ECR_TRACE(SZMESSAGE, 1) From GESECRAN
      Else
        If IESCFLG Then
          #La demande service n° XXXX a été escaladée.
          SZMESS = mess(506,196,1) - ":" - [F:SREA]SRENUM - mess(944,182,1)
          Call ECR_TRACE(SZMESS, 0) From GESECRAN
        Endif
      Endif
      ICLECOUNT += 1
      If ICLECOUNT >= ICUT Then
        Break
      Endif
    Next
    Filter [SREA]
  Wend
  #Exécution des escalades terminée.
  SZMESS = mess(950,182,1)
  Call ECR_TRACE("--------------------------------------------",0) From GESECRAN
  Call ECR_TIME(".") From DOSSUB
  Call ECR_TRACE(SZMESS,0) From GESECRAN
  Call ECR_TRACE("--------------------------------------------",0) From GESECRAN
  If !GSERVEUR Then
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
Return
