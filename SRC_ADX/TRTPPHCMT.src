#<AdxTL>@(#)9.0.0.0 $Revision$
#----------------------------------------------------------------------------------
# TRTPPHCMT : Saisie fenêtre du commentaire sur variable prépaie en saisie croisée
#----------------------------------------------------------------------------------
# (C) PROSPER 08/10
# LOT P03 - 66096
#----------------------------------------------------------------------------------

End

$ACTION
Case [L]ACTION
    When "DEBUT"
        Gosub DEBUT
    When "OK"
        Gosub OK
    When "FIN"
Endcase
Return

$DEBUT
# Récupération du contenu de la variable VRACMT passée par l'appelant
Raz [M:DIA], [L]VALEUR
[M:DIA]VRACMT = [L]PARAM(1)

# PARAM
# 1 : Commentaire
# 2 : Refnum
# 3 : Ctrnum
# 4 : Vracod
# 5 : Demamt

# Dbgaff

Return

$OK
# Et si OK, information de l'appelant et renvoie de la saisie
[L]VALEUR = "OK"
[L]PARAM(1) = [M:DIA]VRACMT
Return
