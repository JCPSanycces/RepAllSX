#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################################
$AREAD_AFTER

  #--CPO 21.10.2013 SQUOTED devient persistante
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class - no use of APARENT in the line script...
  #If this.APARENT<>null
  #  this.LEG    = this.APARENT.LEG
  #  this.CURVCR = this.APARENT.CUR
  #Endif

  If this.LEG="" | this.CURVCR=""
    #--sinon il faut initialiser à partir de SALFCY
    #--Chargement de la LEG et de la devise société du document
    If this.SALFCY<>""
      Local File FACILITY [FCY]
      Local File COMPANY  [CPY]

      Read [F:FCY]FCY0=this.SALFCY
      If fstat Raz [F:FCY] Endif
      Read [F:CPY]CPY0=[F:FCY]LEGCPY
      If fstat Raz [F:CPY] : Endif

      this.LEG    = [F:CPY]LEG
      this.CURVCR = [F:CPY]ACCCUR
    Endif
  Endif

Return
#######################################################################################
$AREAD_AFTER_C_VACITM

  # -----------------------------------
  #--Chargement des propriétés _LEG liées aux propriété déclinées par législation
  #--VACITM, VAT
  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  If this.APARENT.LEG = AVOID.ACHAR
    [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this.APARENT, this.APARENT.CPY, this.APARENT.SALFCY, this.APARENT.LEG)
    If [L]ASTATUS >= [V]CST_AERROR : Return : Endif
  Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VACITM_LEG(this.APARENT, this.VACITM, this.APARENT.CPY, this.APARENT.SALFCY, this.APARENT.LEG, this.VACITM_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VAT_LEG(this.APARENT, this.VAT, this.APARENT.CPY, this.APARENT.SALFCY, this.APARENT.LEG, this.VAT_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return
#######################################################################################
#---------------------------------------------------------------------------- #
# Alimentation des paramètres pour la recherche des codes taxes               #
#                                                                             #
# Method that loads properties of FINDVAT (MYPARAM) with SQUOTED (this)       #
#                                                                             #
#------------------------------------------------------------------------------
$LOADVATPARAMFROMDOC
Local Date    WDAT
Local Char    WCUR(GLONCUR)
Local Integer WCHGTYP
Local Decimal WCOEFDEVISE
Local Integer WSTAT:#--CPO 71937 19.04.2013
Local Integer WRET, WLINE, WI
#-----
Local File COMPANY    [CPY]
Local File FACILITY   [FCY]
Local File TAXLINK    [TLK] : # Table Calcul base calcul taxe (link)
Local File AGRPCPY    [AGC] : # Table Groupes de sociétés

Local File BPARTNER   [BPR]
Local File BPCUSTOMER [BPC]
Local File ITMMASTER  [ITM]
Local File TABVACITM  [TVI]

WCOEFDEVISE=1

#If GACTX.USER="LD" : Dbgaff : Endif

If this.APARENT=null Return Endif
#Dbgaff #--was present into integration

# -----
# Alimentation des propriétés de la classe de données paramètres FINDVAT : MYPARAM
# -----

# A voir comment tester d'autres cas : TRAIT=11,12,13,2,3
If MYPARAM.TRAIT= 0
  MYPARAM.TRAIT   = 1  : # Code traitement 1=Taxes classiques (TVA+parafiscales+spéciales)
Endif
MYPARAM.BPCBPS    = 1  : # Type de tiers   1=Client
MYPARAM.TIERS     = this.APARENT.BPCORD
MYPARAM.ITMREF    = this.ITMREF

MYPARAM.GSOCIETE  = this.APARENT.CPY
Read [CPY] CPY0=this.APARENT.CPY        : If fstat  Raz [F:CPY] : Endif
MYPARAM.GLOCALDEV = [F:CPY]ACCCUR

Read [FCY] FCY0=this.APARENT.SALFCY     : If fstat  Raz [F:FCY] : Endif

MYPARAM.GFINRSP   = [F:FCY]FINRSPFCY
MYPARAM.GSYSCUR   = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"SYSCUR")

Read [BPR] BPR0=MYPARAM.TIERS   : If fstat  Raz [F:BPR] : Endif
Read [BPC] BPC0=MYPARAM.TIERS   : If fstat  Raz [F:BPC] : Endif
Read [ITM] ITM0=MYPARAM.ITMREF  : If fstat  Raz [F:ITM] : Endif

## A ne pas mettre içi puisque cela concerne la recheche des codes taxes pour un elt fac
##----- Lecture de l'élément de facturation -----#
#If dim(MYPARAM.DTANUM)>0 & MYPARAM.DTANUM<>0
##  If MYPARAM.BPCBPS=1
##    If dim(GMIGRATION)>0 & dim(WNBSFI)>0        : # Dde 81811: Optimisation
##       Local Integer WJ                         : # Dde 81811: Optimisation
##       WJ=find(DTANUM,WSFINUM (0..WNBSFI))      : # Dde 81811: Optimisation
##    Else                                        : # Dde 81811: Optimisation
#
#        If [F:SFI]SFINUM<>MYPARAM.DTANUM
#          Read [SFI] SFI0=MYPARAM.DTANUM : If fstat  Raz [F:SFI] : Endif
#        Endif
#
##    Endif                                       : # Dde 81811: Optimisation
##  Elsif MYPARAM.BPCBPS=2
##    If !clalev([F:PFI])  Local File PFOOTINV [PFI] : Endif
##    If [F:PFI]PFINUM<>MYPARAM.DTANUM
##      Read [PFI] PFI0=MYPARAM.DTANUM : If fstat  Raz [F:PFI] : Endif
##    Endif
##  Endif
#Endif

# -----
# Alimentation des propriétés de la classe de données paramètre TAXLINK
# C'est une propriété de la classe de données paramètre FINDVAT faisant partie de la collection C_TLK
# -----
If MYPARAM.C_TLK(1) = null
  WRET = fmet MYPARAM.ADDLINE("C_TLK",1)
  If WRET = [V]CST_ANOTDEFINED
    #--The insertion was not possible
    [L]ASTATUS = fmet this.ASETERROR ("", "Data Class SPRICESEARCH : Method call LOADVATPARAMFROMDOC result error for MYPARAM.ADDLINE 'C_TLK':", [V]CST_AERROR)
    Return
  Endif
Endif

SetInstance MYPARAM.C_TLK(1) With [F:CPY]
SetInstance MYPARAM.C_TLK(1) With [F:BPR]

MYPARAM.C_TLK(1).MODULE=5     : # Bug 74842
#[F:TLK]=[F:BPC]
SetInstance MYPARAM.C_TLK(1) With [F:BPC]

If dim([F:BPC]AGTPCP)>0
  MYPARAM.C_TLK(1).AGTPCPBPR=[F:BPC]AGTPCP
Else
  MYPARAM.C_TLK(1).AGTPCPBPR=2
Endif

# Alimentations à partir de l'article
If MYPARAM.ITMREF<>""
  #[F:TLK]=[F:ITM]
  SetInstance MYPARAM.C_TLK(1) With [F:ITM]   : # Equivalent du transclasse

  # Alimentation de TSICOD depuis l'article car non présent dans SQUOTED
  For WLINE = 1 To dim([F:ITM]TSICOD)
     If MYPARAM.C_TLK(1).C_TSICOD(WLINE) = null
       WRET = fmet MYPARAM.C_TLK(1).ADDLINE("C_TSICOD",WLINE)
       If WRET = [V]CST_ANOTDEFINED
         #--The insertion was not possible
         [L]ASTATUS = fmet MYPARAM.ASETERROR ("", "Result error for MYPARAM.C_TLK(1) 'C_TSICOD':", [V]CST_AERROR)
         Break
       Endif
      Endif
      MYPARAM.C_TLK(1).C_TSICOD(WLINE).TSICOD =  [F:ITM]TSICOD(WLINE-1)
  Next WLINE

Endif

# Inutile içi
#If dim(MYPARAM.DTANUM)>0 & MYPARAM.DTANUM<>0
#  Raz [L]WVACITM
##  If MYPARAM.BPCBPS=1
##    If dim(GMIGRATION)>0 & dim(WNBSFI)>0          : # Dde 81811 : Optimisation
##       If WJ                                      : # Dde 81811 : Optimisation
##            [L]WVACITM(0)=WSFIVACITM(WJ-1)        : # Dde 81811 : Optimisation
##            [L]WVACITM(1)=WSFICLCVACITM(WJ-1)     : # Bug 82733 : Recherche code taxe lié au niveau de taxe sélection
##       Else                                       : # Dde 81811 : Optimisation
##            [L]WVACITM(0)=""                      : # Dde 81811 : Optimisation
##            [L]WVACITM(1)=""                      : # Bug 82733 : Recherche code taxe lié au niveau de taxe sélection
##       Endif                                      : # Dde 81811 : Optimisation
##    Else
#        [L]WVACITM(0)=[F:SFI]VACITM
#        # Bug 82733 : Recherche code taxe lié au niveau de taxe sélection
#        [L]WVACITM(1)=[F:SFI]CLCVACITM
##    Endif                                         : # Dde 81811 : Optimisation
##  Elsif MYPARAM.BPCBPS=2
##    [L]WVACITM(0)=[F:PFI]VACITM
##  Endif
#Endif
#-----

MYPARAM.C_TLK(1).FCY      = MYPARAM.GFINRSP
MYPARAM.C_TLK(1).AGTPCPCPY= [F:CPY]AGTPCP
#-----
MYPARAM.C_TLK(1).NBGRP=0
#  If dim(GMIGRATION)>0 & dim(NBAGC)>0             : # Dde 81811 : Optimisation
#   Local Integer WJ                             : # Dde 81811 : Optimisation
#   For WJ=0 To NBAGC-1                          : # Dde 81811 : Optimisation
#      If WAGCCPY(WJ)=[F:TLK]CPY                 : # Dde 81811 : Optimisation
#          [F:TLK]GRP([F:TLK]NBGRP)=WAGCGRP(WJ)  : # Dde 81811 : Optimisation
#          [F:TLK]NBGRP+=1                       : # Dde 81811 : Optimisation
#          If [F:TLK]NBGRP>98  Break : Endif     : # Dde 81811 : Optimisation
#      Elsif WAGCCPY(WJ)>[F:TLK]CPY              : # Dde 81811 : Optimisation
#           Break                                : # Dde 81811 : Optimisation
#      Endif                                     : # Dde 81811 : Optimisation
#   Next WJ                                      : # Dde 81811 : Optimisation
#  Else                                            : # Dde 81811 : Optimisation


WI=1
For [AGC] AGC1 Where CPY=MYPARAM.GSOCIETE

  If MYPARAM.C_TLK(1).C_GRP(WI) = null
    WRET = fmet MYPARAM.C_TLK(1).ADDLINE("C_GRP",WI)
    If WRET = [V]CST_ANOTDEFINED
      #--The insertion was not possible
      [L]ASTATUS = fmet MYPARAM.ASETERROR ("", "Result error for MYPARAM.C_TLK(1) 'C_GRP':", [V]CST_AERROR)
      Return
    Endif
  Endif

  MYPARAM.C_TLK(1).C_GRP(WI).GRP =[F:AGC]GRP
  WI+=1
  If WI>99  Break : Endif
Next
MYPARAM.C_TLK(1).NBGRP=WI-1

#Endif                                           : # Dde 81811 : Optimisation

# -----
# Alimentation à partir du contexte : içi alimentation à partir de la classe Recherche tarif
# -----
#Gosub ALITLK
# Se situe dans ALITLK pour ce qui concerne les commandes
MYPARAM.C_TLK(1).SALFCY     = this.APARENT.SALFCY

MYPARAM.C_TLK(1).CUR        = this.APARENT.CUR
MYPARAM.C_TLK(1).VACBPR     = this.APARENT.VACBPR
MYPARAM.C_TLK(1).VACBPR_LEG = this.APARENT.VACBPR_LEG

#If GACTX.USER="LD" : Dbgaff : Endif

# Alimentation des familles statistiques article depuis SPRICESEARCH --> SFINDPRICE --> SFINDPRICED --> SPRICLINKD
For WLINE = 1 To maxtab(this.C_VACITM)
  If this.C_VACITM(WLINE)<>null
    If MYPARAM.C_VAT(WLINE) = null
      WRET = fmet MYPARAM.ADDLINE("C_VAT",WLINE)
      If WRET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        [L]ASTATUS = fmet MYPARAM.ASETERROR ("", "Result error for MYPARAM 'C_VAT':", [V]CST_AERROR)
        Return
      Endif
    Endif
    MYPARAM.C_VAT(WLINE).VACITM     = this.C_VACITM(WLINE).VACITM
    MYPARAM.C_VAT(WLINE).VACITM_LEG = this.C_VACITM(WLINE).VACITM_LEG
    MYPARAM.C_VAT(WLINE).VAT        = "" : #AVOID.ACHAR
    MYPARAM.C_VAT(WLINE).VAT_LEG    = "" : #AVOID.ACHAR
  Endif
Next WLINE

# Dans TAXLINK VACITM n'est pas dimensionné, on initialise avec le 1er niveau
If MYPARAM.C_VAT(1) <> null
  MYPARAM.C_TLK(1).VACITM     = MYPARAM.C_VAT(1).VACITM
  MYPARAM.C_TLK(1).VACITM_LEG = MYPARAM.C_VAT(1).VACITM_LEG
Endif

MYPARAM.C_TLK(1).QTY    = this.QTY

WDAT = this.APARENT.QUODAT : WCUR = this.APARENT.CUR : WCHGTYP = this.APARENT.CHGTYP
Gosub CHARG_RATRPT

# A charger pour les taxes provinciales non utile içi
#----- Chargement des provinces -----#
# Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
# If find(TRAIT, 2,3) & func AFNC.ACTIV("PTX")
#     Gosub DECLARE_SAT
#     WBPCORD=this.BPCORD
#     WSTOFCY=this.STOFCY : WBPAADD=this.PRICEPARAM(1).BPAADD
#     If dim([M:ADB2]CTY)>0 WCTY=[M:ADB2]CTY : WCRY=[M:ADB2]CRY : WSAT=[M:ADB2]SAT Endif
#     Gosub CHARG_SAT
#Endif

Return

$CHARG_RATRPT
If WCUR <> MYPARAM.GSYSCUR
    Call CONVERT(MYPARAM.ACTX, MYPARAM.GSYSCUR,WCUR,MYPARAM.GLOCALDEV,WCHGTYP,WDAT,1000000.00,WCOEFDEVISE,WSTAT) From TRTDEV_SYRA
    If WSTAT=0 & WCOEFDEVISE<>0 WCOEFDEVISE=WCOEFDEVISE/1000000.00 Else WCOEFDEVISE=1 Endif
Endif
MYPARAM.C_TLK(1).RATRPT = WCOEFDEVISE
Return

#------------------------------------------------------------------------- #
# Récupération des codes taxes après la recherche                          #
#                                                                          #
# Method that loads results from FINDVAT (MYPARAM) to SQUOTED (this)       #
#                                                                          #
# ------------------------------------------------------------------------ #
$LOADVATRESULTFROMFINDVAT
#If GACTX.USER="LD" : Dbgaff : Endif

Local Integer WLINE, WRET

If this.APARENT=null Return Endif

For WLINE=1 To maxtab(MYPARAM.C_VAT)

  If MYPARAM.C_VAT(WLINE)<>null
    If this.C_VACITM(WLINE)=null
      WRET = fmet this.ADDLINE("C_VACITM",WLINE)
      If WRET = [V]CST_ANOTDEFINED
        #--The insertion was not possible
        [L]ASTATUS = fmet this.ASETERROR ("", "Data Class SQUOTE : Method call LOADVATRESULTFROMFINDVAT result error for this.ADDLINE 'C_VACITM':", [V]CST_AERROR)
        Return
      Endif
    Endif

    this.C_VACITM(WLINE).VAT     = MYPARAM.C_VAT(WLINE).VAT
    this.C_VACITM(WLINE).VAT_LEG = MYPARAM.C_VAT(WLINE).VAT_LEG
  Endif

Next WLINE

Return

