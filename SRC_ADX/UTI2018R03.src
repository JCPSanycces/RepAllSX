#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTI2018R03 UTI process for 2018Rn of X3
# ---------------------------------------------------------------------- #
#      moulinettes à passer en fin du patch de la 2018Rn - passage de Rn-1 vers Rn
#
#      correction utility to be done at the end of the patch - move from Rn-1 to Rn
#
##########################################################################
  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("UTI2018R03 Processing") From LECFIC
  Call PATCH(nomap)
  Call TEMPOFF From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
# -----------------------------------------------------------------    #
# To  execute during integration of list of patches                    #
# call in integration if UTIXXXNN is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

#-------------------------------------------------------------#
# le test du dossier mère doit etre fait dans chaque uti.. pas ici
# Test of the mother folder must be done in each utixxx.. not HERE
#-------------------------------------------------------------#
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif

Call EXE_UTI2018R03 (APPLI)

End

###################################################
Subprog EXE_UTI2018R03(LDOSSIER)
Value Char LDOSSIER

Call ECR_TRACE("START : UTI2018R03-Phase for folder "+LDOSSIER,0) From GESECRAN

#-------------------------------------------------------------#
# implementer ici l'appel de chaque uti necessaire
# le test du dossier mère doit etre fait dans chaque uti..
#
# implement here the call of each necessary uti
# Test of the mother folder must be done in each utixxx..
#-------------------------------------------------------------#

#  Call PATCH  (LDOSSIER) From UTIXXX

## Issue X3-67176 - 2018-02-21 by CCC : Remove Russian texts
Call PATCH(LDOSSIER) From UTILANRUS

# Issue X3-58749 - 2018-02-08 by CCC
Call PATCH(LDOSSIER) From SUBALH1     # Requests validation
Call PATCH(LDOSSIER) From SUBALT1     # Graphical requests validation

# Issue X3-52049 - 2018-01-22 by FHA : ORI ORIC records initiated in GDD if necessary
If [F:ADS]MODULE(1) = 2 Then
  Call PATCH(LDOSSIER) From UTICPT95
  Call PATCH(LDOSSIER) From SUBGDE    # Journal Entry Transaction validation
Endif
# Issue X3-52049 - 24/01/2018 By BEFOU : For MAJ ORIGIN ORICOD ON MIGRATION With FLGGEN
If [F:ADS]MODULE(1) = 2 Then
  Call PATCH(LDOSSIER) From UTICPT96
Endif

  If [F:ADS]MODULE(8) = 2 Then
    Call PATCH(LDOSSIER) From UTIPJM201802001    # Issue X3-65941 - 2018-01-12 by FGR
    Call PATCH(LDOSSIER) From UTIPJM201802002    # Issue X3-66468 - 2018-01-11 by SINGC
    Call PATCH(LDOSSIER) From UTIPJM201803001    # Issue X3-66474 - 2018-02-22 by SINGC
    Call PATCH(LDOSSIER) From UTIPJM201803002    # Issue X3-15630 - 2018-03-08 by FGR
  Endif

#MAPAD - 2018-02-28 - X3-64399 - START
#MIPEA - 2018-03-01- US X3-80852- START
If [F:ADS]MODULE(14)=2 | [F:ADS]MODULE(19)=2 #& func AFNC.ACTIV("FZAPH")>0
#If [F:ADS]MODULE(14)<>2
#MIPEA - 2018-03-01- US X3-80852- END
  Call PATCH(LDOSSIER) From UTIHRM005
Endif
#MAPAD - 2018-02-28 - X3-64399 - END

#MIPEA - 2018-03-03- US X3-75027- START
  Call PATCH(LDOSSIER) From UTIHRM006
#MIPEA - 2018-03-03- US X3-75027- END

#MIPEA - 2018-03-26 - X3-84179 - START
If [F:ADS]MODULE(14)=2 | [F:ADS]MODULE(19)=2 #& func AFNC.ACTIV("FZAPH")>0
  Call PATCH(LDOSSIER) From UTIHRM008
Endif
#MIPEA - 2018-03-26 - X3-84179 - END

# Issue X3-42285 - 2018-01-31 by VAVIL update STRDATWD on DKSKEY
    Call PATCH(LDOSSIER) From UTITC73
# Issue end

# Issue X3-78009 - 2018-03-06 by VAVIL PT consignment invoices
Call PATCH(LDOSSIER) From UTITC74
# Issue end

# Issue X3-76171 - Limit of specific activity codes.
Call PATCH(LDOSSIER) From UTIINIMAXSPEACV
# Issue end

# Issue X3-77639 - 2018-03-13 by ERMIL : Add column to point in time tables to identify primary or secondary valuation
If [F:ADS]MODULE(6) = 2 Then
  Call PATCH(LDOSSIER) From UTIPIT
Endif

Call ECR_TRACE("END : UTI2018R03-Phase for folder "+LDOSSIER,0) From GESECRAN
#----- Fin du traitement -----#
$FIN_UTI2018R03
End
