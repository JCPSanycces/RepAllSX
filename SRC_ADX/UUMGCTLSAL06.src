#<AdxTL>@(#)2.0.0.0 $Revision$
############################################################################
# UUMGCTLSAL06   Contrôle Pre-migration Livraisons           Module Ventes #
#                                                                          #
# Toutes versions :                                                        #
# ---------------                                                          #
# SDELIVERY  without SDELIVERYD                                            #
# SDELIVERYD without SDELIVERY                                             #
# SDELIVERYD with STOFCY different from SDELIVERY                          #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGCTLSAL06") From LECFIC
  Endif

  Call MAJ_UUMGCTLSAL06(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End


###################################################################################
Subprog MAJ_UUMGCTLSAL06(DOSSIER)
Value Char DOSSIER

If [F:ADS]MODULE(4)<>2 : End : Endif                                  : # N= no module

Call ECR_TIME("UUMGCTLSAL06 Sales Delivery Process : SDELIVERY-D") From DOSSUB
Call ECR_TRACE("UUMGCTLSAL06 : Process Start on : "+DOSSIER,0) From GESECRAN

Local Integer ERR,COMPTEUR

Gosub CTL1 : # SDELIVERY  without SDELIVERYD
Gosub CTL2 : # SDELIVERYD without SDELIVERY
Gosub CTL3 : # SDELIVERYD with STOFCY different from SDELIVERY

$FIN
Call ECR_TIME("UUMGCTLSAL06 : Sales Delivery Process END.") From DOSSUB
End


###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Call ECR_TRACE(REQSQL,1) From GESECRAN
ERR=1
Resume

###################################################################################
# SDELIVERY without SDELIVERYD
###################################################################################
$CTL1
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSVUE.ISVIEW(DOSSIER,"SDELIVERY")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"SDELIVERYD") : Return : Endif
# Issue 106947 - 20150811 by LD

REQSQL(0)="SELECT SDH.SDHNUM_0 FROM "-DOSSIER+".SDELIVERY SDH "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".SDELIVERYD SDD WHERE SDH.SDHNUM_0=SDD.SDHNUM_0) "
REQSQL(2)="ORDER BY SDH.SDHNUM_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("SDELIVERY without SDELIVERYD",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VSDHNUM(50)) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"SDHNUM="-[BXX]VSDHNUM,0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################


###################################################################################
# SDELIVERYD without SDELIVERY
###################################################################################
$CTL2
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSVUE.ISVIEW(DOSSIER,"SDELIVERY")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"SDELIVERYD") : Return : Endif
# Issue 106947 - 20150811 by LD

REQSQL(0)="SELECT SDD.SDHNUM_0,SDD.SDDLIN_0 FROM "-DOSSIER+".SDELIVERYD SDD "
REQSQL(1)="WHERE NOT EXISTS (SELECT 'X' FROM "-DOSSIER+".SDELIVERY SDH WHERE SDH.SDHNUM_0=SDD.SDHNUM_0) "
REQSQL(2)="ORDER BY SDD.SDHNUM_0,SDD.SDDLIN_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("SDELIVERYD without SDELIVERY",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VSDHNUM(50),Integer VSDDLIN) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"SDHNUM/SDDLIN="-[BXX]VSDHNUM+'/'+num$([BXX]VSDDLIN),0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################
# SDELIVERYD with STOFCY different from SDELIVERY
###################################################################################
$CTL3
Local Char REQSQL (250) (3)
Raz COMPTEUR,ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSVUE.ISVIEW(DOSSIER,"SDELIVERY")  : Return : Endif
If func DOSVUE.ISVIEW(DOSSIER,"SDELIVERYD") : Return : Endif
# Issue 106947 - 20150811 by LD

REQSQL(0)="SELECT SDD.SDHNUM_0,SDD.SDDLIN_0 FROM "-DOSSIER+".SDELIVERYD SDD "
REQSQL(1)="WHERE SDD.STOFCY_0<>(SELECT SDH.STOFCY_0 FROM"-DOSSIER+".SDELIVERY SDH WHERE SDH.SDHNUM_0=SDD.SDHNUM_0) "
REQSQL(2)="ORDER BY SDD.SDHNUM_0,SDD.SDDLIN_0 "

Call ECR_TIME(string$(50,"*"))  From DOSSUB
Call ECR_TRACE("SDELIVERYD with STOFCY different from SDELIVERY",0) From GESECRAN

Onerrgo ERR_SQL
For (Char VSDHNUM(50),Integer VSDDLIN) From num$(GTYPDBA*2+1) Sql REQSQL As [BXX]
  COMPTEUR+=1
  Call ECR_TRACE(string$(20," ")+"SDHNUM/SDDLIN="-[BXX]VSDHNUM+'/'+num$([BXX]VSDDLIN),0) From GESECRAN
Next

If COMPTEUR>0
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",1) From GESECRAN
Else
Call ECR_TRACE(string$(10,"-")+'>'-num$(COMPTEUR)+" records found.",0) From GESECRAN
Endif
Return
###################################################################################

