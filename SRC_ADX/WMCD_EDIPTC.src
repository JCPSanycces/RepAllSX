#<AdxTL>@(#)0.0.0.0 $Revision$Class Protocol
# Supervisor
## CRUD-CLASSE ## EDIPTC
# 2018-11-06 07:04:56 584


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(EDIPTC,ASTATUS)
Variable Instance EDIPTC Using C_EDIPTC
Variable Integer ASTATUS

If EDIPTC = null : End : Endif

Gosub _AVARIABLES From WMC00EDIPTC

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_EDIPTC

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(EDIPTC,ASTATUS)
Variable Instance EDIPTC Using C_EDIPTC
Variable Integer ASTATUS

If EDIPTC = null : End : Endif

Gosub AVARIABLES From WMC00EDIPTC
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_EDIPTC
Else
 Gosub ADELETE_EDIPTC
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(EDIPTC,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If EDIPTC.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EDIPTC.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIPTC.EPTD) : # EDIPTCD -- 2
 If EDIPTC.EPTD(A_N2) <> null
& and EDIPTC.EPTD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDIPTC.EPTD(A_N2).ASTALIN<>[V]CST_ANEW
   EDIPTC.EPTD(A_N2).ASTALIN = [V]CST_ADEL
   [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTD(A_N2).ACTION("ADELETE_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIPTC.EPTM) : # EDIPTCM -- 3
 If EDIPTC.EPTM(A_N2) <> null
& and EDIPTC.EPTM(A_N2).ASTALIN<>[V]CST_ANEWDEL
  If EDIPTC.EPTM(A_N2).ASTALIN<>[V]CST_ANEW
   EDIPTC.EPTM(A_N2).ASTALIN = [V]CST_ADEL
   [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTM(A_N2).ACTION("ADELETE_CONTROL_BEFORE"))
   If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER
For A_N2=1 To maxtab(EDIPTC.EPTD) : # EDIPTCD -- 2
 If EDIPTC.EPTD(A_N2) <> null
& and EDIPTC.EPTD(A_N2).ASTALIN<>[V]CST_ANEWDEL
  [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTD(A_N2).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
For A_N2=1 To maxtab(EDIPTC.EPTM) : # EDIPTCM -- 3
 If EDIPTC.EPTM(A_N2) <> null
& and EDIPTC.EPTM(A_N2).ASTALIN<>[V]CST_ANEWDEL
  [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTM(A_N2).ACTION("ADELETE_CONTROL_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_EDIPTC
Trbegin [F:EPT]
 Gosub ADELETE_EDIPTC
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_EDIPTC
[L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

#-----------------------------------------------------#
For A_N2=1 To maxtab(EDIPTC.EPTD)
 If EDIPTC.EPTD(A_N2) <> null
  [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTD(A_N2).ACTION("ADELETE_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  EDIPTC.EPTD(A_N2).ASTALIN=[V]CST_ADEL
  [L]ASTATUS = func WMC00EDIPTC._MAJSQL_EDIPTCD(EDIPTC.EPTD(A_N2))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTD(A_N2).ACTION("ADELETE_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

#-----------------------------------------------------#
For A_N2=1 To maxtab(EDIPTC.EPTM)
 If EDIPTC.EPTM(A_N2) <> null
  [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTM(A_N2).ACTION("ADELETE_BEFORE"))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  EDIPTC.EPTM(A_N2).ASTALIN=[V]CST_ADEL
  [L]ASTATUS = func WMC00EDIPTC._MAJSQL_EDIPTCM(EDIPTC.EPTM(A_N2))
  If [L]ASTATUS>=[V]CST_AERROR : Break  : Endif
  [L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.EPTM(A_N2).ACTION("ADELETE_AFTER"))
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Endif
Next A_N2
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#-----------------------------------------------------#

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(EDIPTC,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EDIPTC._MAJSQL_EDIPTC(EDIPTC))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EDIPTC.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If EDIPTC.snapshotEnabled=1
 [L]A_RETIK = EDIPTC.revertUpdTick
Endif
[L]ASTATUS = max(fmet EDIPTC.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



