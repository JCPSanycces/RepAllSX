#<AdxTL>@(#)7.0.0.0 $Revision$
###########################################################
# nouvelle visu capacités (llc 08.00 v130)
Subprog VIS_CAP(LFCY,LTWD,LDAT,LDAY,LWEE,LMON)
Variable Char    LFCY
Variable Char    LTWD
Variable Date    LDAT
Variable Integer LDAY
Variable Integer LWEE
Variable Integer LMON
#
Local Integer CHOIX
Local Integer WBOU(1..GNBBOU)  
Local Integer WNOLIGN : WNOLIGN = nolign
Local Integer WFSTAT  : WFSTAT  = fstat
#
Local Integer WNBR    
Local Char    WTWD(3) 
Local Date    WDATD   
Local Date    WDATF   
Local Integer WCOR   
Local Decimal WTOT
Local Integer WRET
Local Char    WMON0(15) 
Local Char    WMON1(15)
Local Char    WMON2(15)
Local Char    WDAY(10)(7)
Local Integer WQUA
Local Integer I
#
If clalev([F:FCY]) = 0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:TUV]) = 0  : Local File TABUNAVAIL [TUV]  : Endif
If clalev([F:TWD]) = 0  : Local File TABWEEDIA  [TWD]  : Endif

# lecture site
Call LECTURE ("FCY", LFCY, "") From CONTOBJ   

# lecture indisponibilités
Read [F:TUV]UVY0=[F:FCY]UVYCOD  
If fstat : Raz [F:TUV] : Endif

Call SAVBOUT From GESECRAN
#  
For I = 1 To GNBBOU  
  WBOU(I) = 0 
Next I  
WBOU(GVALI) = 1
Call SETBOUT(WBOU) From GESECRAN  
#
Local Mask CBN3[CBN3]
Local Dlgbox Mask [CBN3]
&    Button mess(64,123,1)
&    With left$(mess(64,123,1),1)
&    Coded GSTAOK
&    Titled mess(206,198,1)
&    As [CBN3]
Boxact [CBN3]
#
Raz [M:CBN3]
[M:CBN3]FCY  = LFCY
[M:CBN3]TWD  = LTWD
WNBR  =  LDAY
WNBR += (LWEE*7)
WNBR += (LMON*31)
Local Decimal WCAP(WNBR)
WTWD  = LTWD
WDATD = LDAT
WDATF = (WDATD + WNBR -1)

Call LOACAPPLN(WTWD,WDATD,WDATF,WCAP,WRET) From MFGLIB

I      = 0
WQUA   = dayn(WDATD)-1
WIND   = 0
Raz WMON0, WMON1, WMON2, WDAY
While WDATD < WDATF
  WMON1      = month$(WDATD)-num$(year(WDATD))
  If WCAP(WIND) = 0
    WDAY(WQUA) = format$("N0:2",num$(day(WDATD)))+"    ****"
  Else  
      WDAY(WQUA) = format$("N0:2",num$(day(WDATD)))+"  "+format$("N:3.2",WCAP(WIND))
  Endif
  WDATD += 1
  WMON2      = month$(WDATD)-num$(year(WDATD)) 
  WIND  += 1
  WQUA  += 1
  If WQUA = 7 
    WQUA = 0 
  Endif
  If WMON1 <> WMON2 | WQUA = 0
    If I < dim([M:CBN3]MON)
      If WMON0 <> WMON1
        [M:CBN3]MON(I)  = WMON1
      Endif
      [M:CBN3]DAY1(I) = WDAY(0)
      [M:CBN3]DAY2(I) = WDAY(1)
      [M:CBN3]DAY3(I) = WDAY(2)
      [M:CBN3]DAY4(I) = WDAY(3)
      [M:CBN3]DAY5(I) = WDAY(4)
      [M:CBN3]DAY6(I) = WDAY(5)
      [M:CBN3]DAY7(I) = WDAY(6)
      WMON0 = WMON1
      Raz WMON1, WMON2, WDAY
      I += 1
    Else
      Break
    Endif
  Endif
Wend
[M:CBN3]BASPAG = I
Affzo [M:CBN3]5-10
Grizo [M:CBN3]5
Enable GSTAEDI
$VIS_CAP1
Boxinp [CBN3] Using CHOIX
  Case CHOIX
    When GSTAEDI :
      Call PRTSCR("CBN3","",mess(206,198,1),0,0) From ATRTX3
      Disable GSTAEDI
      Goto VIS_CAP1
  Endcase 
#
Call RESTBOUT From GESECRAN
fstat  = WFSTAT
nolign = WNOLIGN
End
############################################################
# Actions écran STOCKCBN
############################################################
$SET_NOL
Local Integer NOL : NOL = nolign-1
Return
############################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
Gosub SET_NOL
Call UNICITE(VALEUR,[M]STOFCY(0..[M]BASPAG-1)) From OBJDIV
If mkstat = 0
  Read [FCY]FCY0=VALEUR
    If fstat
      mkstat = 2
      GMESSAGE = VALEUR-mess(15,104,1)
      End
    Endif
    If [F:FCY]WRHFLG <> 2
      mkstat = 2
      GMESSAGE = WFCY-mess(58,199,1)
      End
    Endif
  Read [PCB]PCB0=VALEUR
    If fstat
      mkstat = 2
      GMESSAGE = mess(12,187,1)
      End
    Endif
    [M]FCYNAM(NOL) =  [F:FCY]FCYNAM
Endif
End
############################################################
Subprog AS_REFDAT(VALEUR)
Variable Date    VALEUR
If GBATCH = 0 & VALEUR = [0/0/0] : [M:DIA]REFDAT = datesyst : Endif        # 07.05 31058
End
############################################################
Subprog C_REFDAT(VALEUR)
Variable Date    VALEUR
If GBATCH = 0 & VALEUR = [0/0/0] : mkstat = 2 : Endif                      # 07.05 31058
End

