#    Modification le : 13/03/2003
#-------------------------------------------------------------------------------
################################################################################
# Mon petit bazar jusqu'à ce que je le connaisse par coeur
#     Infbox "nolign="-num$(nolign)
################################################################################
Call OBJET("LOF",GBIDC1,GBIDC2) From GOBJET
End

################################################################################
$ACTION
  Case ACTION
    When "SEL_TABLE"     : Gosub SEL_TABLE     
    #When "SEL_LISTE"     : Gosub SEL_LISTE 
    When Default
  Endcase
Return

#-------------------------------------------------------------------------------
$SEL_TABLE
  Case TABLE
    When "SELLOFLIK"    : Gosub SET_LOFLIK
  Endcase
Return

#-------------------------------------------------------------------------------
$SET_LOFLIK
  Local Char CODFIC    : CODFIC = "LAYOUTFAS"
  Local Char LCPY, LFCY, LAASREF

  If clalev([F:LOFB])=0 : Local File LAYOUTFAS    [LOFB] : Endif

  Default File [LOFB]
  LCPY = PARAM(1)
  LFCY = PARAM(2)
  LAASREF = PARAM(3)
  CRITERE = "CPY=LCPY and FCY=LFCY and AASREF=LAASREF"
  ORDRE = "CODLOF; LINLOF"

  START   = "CODLOF" : # clé composée avec LINLOF aussi

  TIT(0) = mess(21,7772,1)
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "CPY"       : Gosub TEXTE From GLOBIENS
  NBCOL += 1 : COL(NBCOL) = "FCY"       : Gosub TEXTE From GLOBIENS
  NBCOL += 1 : COL(NBCOL) = "CODLOF"    : Gosub TEXTE From GLOBIENS
  NBCOL += 1 : COL(NBCOL) = "LINLOF"    : Gosub TEXTE From GLOBIENS
  NBCOL += 1 : COL(NBCOL) = "ACCGLE"    : Gosub TEXTE From GLOBIENS
  # bidouille pour que le titre de la colonne soit le titre AMTNOTCPY
  # et que la valeur soit correctement formatée en fonction de la devise société.
  # (GFMT3 format des nombres les plus grands. Il existe aussi GFMT1 et GFMT2.)
  NBCOL += 1 : COL(NBCOL) = "AMTNOTCPY" : Gosub TEXTE From GLOBIENS : COL(NBCOL) = "format$('N:'+GFMT3, AMTNOTCPY)"
  # bidouille pour que le titre de la colonne soit le titre TYPVCR
  # et que la valeur soit décodée
  NBCOL += 1 : COL(NBCOL) = "TYPVCR"    : Gosub TEXTE From GLOBIENS : COL(NBCOL) = "mess(TYPVCR, 3117, 1)"
  NBCOL += 1 : COL(NBCOL) = "DES"       : Gosub TEXTE From GLOBIENS
Return

