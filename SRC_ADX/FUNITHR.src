#<AdxTL>@(#)7.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","FUNITHR","IITHR",3,"XYFUNITHR") From GTRAITE
End
######################################################################################
## Resynchronisation de l'historique cumul article-site                              #
######################################################################################
$ACTION
Case ACTION
  When "INIT"           : Gosub INIT
  When "EXEC"           : Gosub EXEC
  When "TERMINE"        : Gosub TERMINE
Endcase 
Return

######################################################################################
$INIT
If !clalev([F:ITH])  : Local File ITMMVTHIS [ITH]  : Endif
If !clalev([F:ITH1]) : Local File ITMMVTHIS [ITH1] : Endif
If !clalev([F:ITV])  : Local File ITMMVT    [ITV]  : Endif
If !clalev([F:PER])  : Local File PERIOD    [PER]  : Endif
If !clalev([F:STJ])  : Local File STOJOU    [STJ]  : Endif
Return

$EXEC
Local Char    WFILTRE(240)
Local Integer WSENS
Local Integer WFLUX

Call OUVRE_TRACE(mess(105,196,1)) From LECFIC

WMSG = mess(105,196,1)-[M]STOFCY
Call ECR_TRACE(WMSG,0) From GESECRAN 
Call ECR_TRACE(mess(174,100,1),-1) From GESECRAN 
Call PRTSCR("ITHR","","",0,1) From ATRTX3
Call ECR_TRACE(mess(51,9010,1),-1) From GESECRAN

If [M]ITMREFSTR=[M]ITMREFEND
   If [M]ITMREFSTR=""
      WFILTRE="STOFCY=[M]STOFCY"
   Else   
      WFILTRE="STOFCY=[M]STOFCY & ITMREF=[M]ITMREFSTR"
   Endif
Else
   WFILTRE="STOFCY=[M]STOFCY & ITMREF>=[M]ITMREFSTR & ITMREF<=[M]ITMREFEND"
Endif

Local Decimal LEXE, LPER
Call GETSOC([M]STOFCY) From DEVSUB
Call GETPERSOC(GSOCIETE,GTYPGEN,[M]PERSTR,LEXE,LPER) From CPTSUB
[M]PERSTR=[F:PER]PERSTR

# Boucle de traitement par article
For [ITV]ITV1 Where evalue(WFILTRE)
   #---      
   # Dégestion du cumul article-site pour la période       
   #---      
   Trbegin [ITH]
   # Lecture du cumul article-site à traiter
   Readlock [ITH]ITH0=[F:ITV]ITMREF;[M]STOFCY;[M]PERSTR
   # Il existe
   If fstat=0
      # Décrémentation des cumuls annuels de l'article-site pour les périodes suivantes
      For [ITH1]ITH0 Where ITMREF=[F:ITH]ITMREF & STOFCY=[F:ITH]STOFCY 
&                        & PERSTR>[F:ITH]PERSTR & FIYNUM=[F:ITH]FIYNUM
         [F:ITH1]YEARCPQTY -= [F:ITH]MONRCPQTY
         [F:ITH1]YEARCPAMT -= [F:ITH]MONRCPAMT
         [F:ITH1]YEARCPMVT -= [F:ITH]MONRCPMVT   
         [F:ITH1]YEAISSQTY -= [F:ITH]MONISSQTY
         [F:ITH1]YEAISSAMT -= [F:ITH]MONISSAMT
         [F:ITH1]YEAISSMVT -= [F:ITH]MONISSMVT
         Rewrite [ITH1]
      Next
      # Décrémentation des cumuls annuels de l'article-site pour la période à traiter
      [F:ITH]YEARCPQTY -= [F:ITH]MONRCPQTY
      [F:ITH]YEARCPAMT -= [F:ITH]MONRCPAMT
      [F:ITH]YEARCPMVT -= [F:ITH]MONRCPMVT   
      [F:ITH]YEAISSQTY -= [F:ITH]MONISSQTY
      [F:ITH]YEAISSAMT -= [F:ITH]MONISSAMT
      [F:ITH]YEAISSMVT -= [F:ITH]MONISSMVT
      # Raz des cumuls mensuels de l'article-site pour la période à traiter
      Raz [F:ITH]MONRCPQTY, [F:ITH]MONRCPAMT, [F:ITH]MONRCPMVT
      Raz [F:ITH]MONISSQTY, [F:ITH]MONISSAMT, [F:ITH]MONISSMVT
      Raz [F:ITH]AMTDEV
      # Réécriture du cumul article-site à traiter
      Rewrite [ITH]
      # FGR 15/01/2010 : X3SUIVI60986
      #Call ECR_TRACE("Article :"-[F:ITH]ITMREF-"Début période :"-[F:ITH]PERSTR-"calculée",0) From GESECRAN
      Call ECR_TRACE("Article :"-[F:ITH]ITMREF-"Début période :"-num$([F:ITH]PERSTR)-"calculée",0) From GESECRAN
   # Enregistrement locké   
   Elsif fstat=1
      # Article suivant
      Goto LOOP_ITV
   # Il n'existe pas   
   Else
      # Création du cumul article-site à traiter
      Raz [F:ITH]
      [F:ITH]ITMREF = [F:ITV]ITMREF   
      [F:ITH]STOFCY = [F:ITV]STOFCY
      [F:ITH]PERSTR = [M]PERSTR
      [F:ITH]PEREND = [F:PER]PEREND
      [F:ITH]FIYNUM = [F:PER]FIYNUM
      [F:ITH]PERNUM = [F:PER]PERNUM
      [F:ITH]CREDAT = date$   
      [F:ITH]CREUSR = GUSER
      [F:ITH]EXPNUM = [C]EXPORT
      # Lecture période précédente pour initialisation cumuls annuels
      # et dates, prix, pièce dernier mouvement
      Filter [ITH1] Where ITMREF=[F:ITV]ITMREF & STOFCY=[F:ITV]STOFCY 
&                       & FIYNUM=[F:PER]FIYNUM & PERSTR<[M]PERSTR 
      Read [ITH1]ITH0 Last
      Filter [ITH1]
      If !fstat
         [F:ITH]YEARCPQTY = [F:ITH1]YEARCPQTY
         [F:ITH]YEARCPAMT = [F:ITH1]YEARCPAMT
         [F:ITH]YEARCPMVT = [F:ITH1]YEARCPMVT   
         [F:ITH]YEAISSQTY = [F:ITH1]YEAISSQTY
         [F:ITH]YEAISSAMT = [F:ITH1]YEAISSAMT
         [F:ITH]YEAISSMVT = [F:ITH1]YEAISSMVT
         [F:ITH]LASRCPDAT = [F:ITH1]LASRCPDAT
         [F:ITH]LASRCPPRI = [F:ITH1]LASRCPPRI
         [F:ITH]VCRTYP    = [F:ITH1]VCRTYP
         [F:ITH]VCRNUM    = [F:ITH1]VCRNUM
         [F:ITH]VCRLIN    = [F:ITH1]VCRLIN
         [F:ITH]LASPURDAT = [F:ITH1]LASPURDAT 
         [F:ITH]LASPURPRI = [F:ITH1]LASPURPRI
      Endif
      Write [ITH]
      # FGR 15/01/2010 : X3SUIVI60986
      #Call ECR_TRACE("Article :"-[F:ITH]ITMREF-"Début période :"-[F:ITH]PERSTR-"créée",0) From GESECRAN
      Call ECR_TRACE("Article :"-[F:ITH]ITMREF-"Début période :"-num$([F:ITH]PERSTR)-"créée",0) From GESECRAN
   Endif   
   Commit
   #---      
   # Maj du cumul article-site pour la période       
   #---      
   Readlock [ITH]ITH0=[F:ITV]ITMREF;[F:ITV]STOFCY;[M]PERSTR
   
   Trbegin [ITH]
   For [STJ]STJ0 Where STOFCY=[F:ITH]STOFCY & ITMREF=[F:ITH]ITMREF
&                    & IPTDAT>=[F:ITH]PERSTR & IPTDAT<[F:ITH]PEREND
&                    & UPDCOD=2
      # Valeur WFLUX : 1=entrée / 2=sortie / 3=inventaire, autres 
      Case [F:STJ]TRSTYP
       When 1,3,5,16      : WFLUX=1 : WSENS=+1
       When 11,32         : WFLUX=1 : WSENS=-1
       When 2,4,6,24,29   : WFLUX=2 : WSENS=+1
       When 12,19         : WFLUX=2 : WSENS=-1
       When 14            : If [F:STJ]ACTQTY>0
                               WFLUX=1 : WSENS=+1
                            Else
                               WFLUX=2 : WSENS=+1
                            Endif                     
       When Default       : WFLUX=3
      Endcase                                               

      # Rien à faire si modification lot
      If [F:STJ]VCRTYP=35 Goto LOOP_STJ Endif  
      
      # Uniquement mouvements non régularisés
      If [F:STJ]REGFLG=1
         # Entrées
         If WFLUX=1
            [F:ITH]MONRCPQTY += [F:STJ]ACTQTY
            [F:ITH]YEARCPQTY += [F:STJ]ACTQTY
            If WSENS=1
               [F:ITH]MONRCPMVT +=1
               [F:ITH]YEARCPMVT +=1
               If [F:STJ]IPTDAT>[F:ITH]LASRCPDAT
                  [F:ITH]LASRCPDAT = [F:STJ]IPTDAT
                  [F:ITH]LASRCPPRI = [F:STJ]PRIORD
                  [F:ITH]VCRTYP    = [F:STJ]VCRTYP
                  [F:ITH]VCRNUM    = [F:STJ]VCRNUM
                  [F:ITH]VCRLIN    = [F:STJ]VCRLIN
               Endif
            Endif
            # Réception non nulle
            If [F:STJ]TRSTYP=3 & [F:STJ]PRIORD<>0
               If [F:STJ]IPTDAT>[F:ITH]LASPURDAT 
                  [F:ITH]LASPURDAT = [F:STJ]IPTDAT 
                  [F:ITH]LASPURPRI = [F:STJ]PRIORD
               Endif
            Endif
            # Calcul montant entrée sur tous les mouvements
            [F:ITH]MONRCPAMT += [F:STJ]AMTVAL
            [F:ITH]YEARCPAMT += [F:STJ]AMTVAL
         # Sorties 
         Elsif WFLUX=2
            [F:ITH]MONISSQTY += [F:STJ]ACTQTY*(-1)
            [F:ITH]YEAISSQTY += [F:STJ]ACTQTY*(-1)
            If WSENS=1
               [F:ITH]MONISSMVT +=1
               [F:ITH]YEAISSMVT +=1
               If [F:STJ]IPTDAT>[F:ITH]LASISSDAT
                  [F:ITH]LASISSDAT = [F:STJ]IPTDAT
               Endif
            Endif 
            # Calcul montant sortie sur tous les mouvements
            [F:ITH]MONISSAMT += [F:STJ]AMTVAL
            [F:ITH]YEAISSAMT += [F:STJ]AMTVAL
         Endif
      Endif
      # Ecart non absorbé
      [F:ITH]AMTDEV += [F:STJ]AMTDEV

      $LOOP_STJ
   Next      

   Rewrite [ITH]
   Commit

   Read [ITH]ITH0=[F:ITV]ITMREF;[F:ITV]STOFCY;[M]PERSTR
   
   Trbegin [ITH1]
   # Incrémentation des cumuls annuels de l'article-site pour les périodes suivantes
   For [ITH1]ITH0 Where ITMREF=[F:ITH]ITMREF & STOFCY=[F:ITH]STOFCY
&                     & PERSTR>[F:ITH]PERSTR & FIYNUM=[F:ITH]FIYNUM
      [F:ITH1]YEARCPQTY += [F:ITH]MONRCPQTY
      [F:ITH1]YEARCPAMT += [F:ITH]MONRCPAMT
      [F:ITH1]YEARCPMVT += [F:ITH]MONRCPMVT   
      [F:ITH1]YEAISSQTY += [F:ITH]MONISSQTY
      [F:ITH1]YEAISSAMT += [F:ITH]MONISSAMT
      [F:ITH1]YEAISSMVT += [F:ITH]MONISSMVT
      # Maj date, prix, pièce dernière entrée
      If [F:ITH]LASPURDAT  > [F:ITH1]LASPURDAT
         [F:ITH1]LASPURDAT = [F:ITH]LASPURDAT 
         [F:ITH1]LASPURPRI = [F:ITH]LASPURPRI
      Else   
         [F:ITH]LASPURDAT  = [F:ITH1]LASPURDAT
      Endif
      If [F:ITH]LASRCPDAT  > [F:ITH1]LASRCPDAT
         [F:ITH1]LASRCPDAT = [F:ITH]LASRCPDAT
         [F:ITH1]LASRCPPRI = [F:ITH]LASRCPPRI
         [F:ITH1]VCRTYP    = [F:ITH]VCRTYP
         [F:ITH1]VCRNUM    = [F:ITH]VCRNUM
         [F:ITH1]VCRLIN    = [F:ITH]VCRLIN
      Else
         [F:ITH]LASRCPDAT  = [F:ITH1]LASRCPDAT                  
      Endif
      # Maj date dernière sortie
      If [F:ITH]LASISSDAT  > [F:ITH1]LASISSDAT
         [F:ITH1]LASISSDAT = [F:ITH]LASISSDAT
      Else
         [F:ITH]LASISSDAT  = [F:ITH1]LASISSDAT                  
      Endif
      Rewrite [ITH1]
   Next

   $LOOP_ITV
   Commit
Next

Return

$TERMINE
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
Call IMPSCR      From ATRTX3
Return

######################################################################################
# Actions champs
######################################################################################
Subprog C_PERSTR(VALEUR)
Variable Date    VALEUR
Local Decimal LEXE, LPER
Call GETSOC([M]STOFCY) From DEVSUB
Call GETPERSOC(GSOCIETE,GTYPGEN,VALEUR,LEXE,LPER) From CPTSUB
VALEUR=[F:PER]PERSTR
End

Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M:ITHR]ITMREFEND=[M:ITHR]ITMREFSTR | [M:ITHR]ITMREFEND<VALEUR
   [M:ITHR]ITMREFEND = VALEUR
   Affzo [M:ITHR]ITMREFEND
Endif
End

######################################################################################


