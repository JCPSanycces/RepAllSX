#<AdxTL>@(#)4.0.0.0 $Revision$
#CHECK UNUSED_SOURCE
Call OBJET("ARQ",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "DEFBOUT" : Gosub DEFBOUT
 When "SETBOUT" : Gosub SETBOUT
 When "EXEBOUT" : Gosub EXEBOUT
Endcase
Return

$DEFBOUT
NBTEX += 1 : CBOUT(NBTEX) = "2" :  TEX(NBTEX) = mess(91,123,1) : # Copie
Return

$SETBOUT
If CLECUR=0 | REP="M" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
Return

$EXEBOUT
Case REP
 When "2"
  Call COPIE(CLECUR1)
Endcase
Return

#########################################################
Subprog COPIE(TABLE)
Value Char TABLE
Local Integer OK , NUMERO
If clalev([M:DIA2])=0
 Local Mask ACOPIE [DIA2]
 Raz [M:DIA2]
 [M]OBJET = "Requête"-TABLE
 OK = 2 : Call DIALO(OK,"Requête") From GOBJTXT
 # Copie d'une requête
 If OK<>2 : End : Endif
Endif
Call TEMPON("T") From GESECRAN
Local File =[M]DOSORG+".ADAPIRQT"  [ARQ1]
Local File =[M]DOSDES+".ADAPIRQT"  [ARQ2]
Call DEBTRANS From GLOCK
Gosub TR_COP
Call TEMPOFF From GESECRAN
End

$TR_COP
GOK = 1
Trbegin [ARQ2]
 Delete [ARQ2] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ADAPIRQT" : Goto ROLL_TR_COP
 Endif
 Read [ARQ1]ARQ0 = TABLE
 [F:ARQ2] = [F:ARQ1]
 If dim([F:ARQ2]UPDUSR)>0 : [F:ARQ2]UPDUSR = GUSER : Endif
 If dim([F:ARQ2]UPDDAT)>0 : [F:ARQ2]UPDDAT = date$ : Endif
 Write [ARQ2]
 If fstat
  GOK = 0 : Call FSTA("ARQ2") From GLOCK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
