Subprog AVLEGAL(TEXTE)
Variable Char TEXTE

#  Avertissement licence
#  Si le fichier warning existe on envoie sa localisation
#  Il est posssible de filtrer en fonction des variables
#  GPRODUIT, PRODUIT, GLANGUE, lûˋgislation

# Diffûˋrentes valeurs de GPRODUIT
# -1   Superviseur
#  0   X3 ou Diapason
#  1   Gûˋode
#  2   Paye
#  3   Biens
# Call NOMBRA(11,PRODUIT) From GLOCK  : # PRODUIT=5   "DIA"

If GSERVEUR or GWEBSERV=1 : End : Endif


Local Char LOCALIS(200),NOMFIC(250),DIRSEP
Case GOS(1)
 When "dos"   : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase
LOCALIS = "X3_ROOT"+DIRSEP+"RESPER"
NOMFIC=filpath(LOCALIS,"include","js","X3_PUB")
If filinfo(NOMFIC,7)<0
  Openo NOMFIC,0 Using [CEX_]
  Iomode adxifs ""  Using [CEX_]
  Iomode adxirs chr$(10)  Using [CEX_]
  Iomode adxium GUTF8  Using [CEX_]
  Wrseq "{"  Using [CEX_]
  Wrseq ""  Using [CEX_]
  Wrseq "}"  Using [CEX_]
  Openo Using [CEX_]
Endif

Local Char NAMF          : NAMF="ADX_warning"
Local Char TYPF          : TYPF="txt"
LOCALIS="X3_ROOT/GEN/"+GLANGUE+"/LIB"
NOMFIC=filpath(LOCALIS,NAMF,TYPF,"X3_PUB")
If filinfo(NOMFIC,7)>0
 TEXTE = LOCALIS+','+NAMF+','+TYPF+',X3_PUB'
Endif

End

