Subprog GENUSERP(FORCE,URL1)
Value Integer FORCE
Variable Char URL1

#    Gûˋnûˋration de la page utilisateur en tenant compte du produit/sociûˋtûˋ/langue
#    si FORCE=1 on la gûˋnû´re dans tous les cas
#            =0 que si elle n'existe pas

#If GSERVEUR : End : Endif

Local Char DIRSEP
Local Char VALL1(200),VALL2(200)
Local Char FILEIN(200),FILEOUT(200),REP(200)
Local Integer IP,IP1,IP2,DEB,I,J

Call GLOBWEB(nomap) From INTRUTILA

Case GOS(1)
 When "dos"  : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase
REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+"LIB"
FILIN=filpath(REP,"ADX_user_param","htm","X3_PUB")
REP = "ADX_PORTAL"+DIRSEP+"DESIGN"+DIRSEP+"ACCWEB"+DIRSEP+"_DF"
FILOUT=filpath(REP,"user_param_"+GLANGUE,"htm","X3_PUB")

#FILIN="#@E:\"+"user_param.htm"
#FILOUT="#@E:\"+"user_param1.htm"
If FORCE=0 and filinfo(FILOUT,7)>0 : Goto ENVCUI : Endif

If filinfo(FILIN,7)<0 : End : Endif

# Transformation des fichiers modû´les
Openi FILIN Using [I_ED]
Iomode adxifs "" Using [I_ED]
Iomode adxirs chr$(10) Using [I_ED]
Iomode adxium GUTF8 Using [I_ED]

Openo FILOUT,0 Using [O_ED]
Iomode adxifs "" Using [O_ED]
Iomode adxirs chr$(10) Using [O_ED]
Iomode adxium GUTF8 Using [O_ED]
While fstat=0
  Rdseq VALL1 Using [I_ED]
  If fstat=0
    If instr(1,VALL1,"xsagesiteurlx")<>0    : Gosub MODURLX : Endif
    If instr(1,VALL1,"xsagesloganx")<>0     : Gosub MODLOGX : Endif
    If instr(1,VALL1,"xsageprodnamex")<>0   : Gosub MODPROX : Endif
    If instr(1,VALL1,"xsagesitelabelx")<>0  : Gosub MODLABX : Endif
    Wrseq VALL1 Using [O_ED]
  Endif
Wend

Openo Using [O_ED]
Openi Using [I_ED]

$ENVCUI
URL1="http://"+GVIRTDIR+"/"+"ADX_PORTAL/DESIGN/ACCWEB/_DF/user_param_"+GLANGUE+".htm"

End

$MODURLX
Local Char WEBSITE(100)
Call CREWEBSIT(WEBSITE) From INTRUTILA
IP=instr(1,WEBSITE,"//")
If IP<>0 : WEBSITE=right$(WEBSITE,IP+2) : Endif
IP=instr(1,VALL1,"xsagesiteurlx")
VALL1=left$(VALL1,IP-1)+WEBSITE+right$(VALL1,IP+13)
Return

$MODLOGX
Local Char SLOG(150) : SLOG=mess(244,123,1)
If SLOG="" and GLANGUE<>"FRA" : SLOG="Accelerate/your business/performance" : Endif
Local Char SLOGD(100)(1..5),SAVV(100)
IP=instr(1,VALL1,"xsagesloganx")
SAVV=right$(VALL1,IP+12)
DEB=1
For I=1 To 5
 IP1=instr(DEB,SLOG,"/")
 If IP1>0
   SLOGD(I)=mid$(SLOG,DEB,IP1-DEB) : DEB=IP1+1
 Else
   SLOGD(I)=right$(SLOG,DEB)
   Break 1
 Endif
Next I
VALL1=left$(VALL1,IP-1)+"<p>"+SLOGD(1)+"</p>"
For J=2 To I
  VALL1+="<p>"+SLOGD(J)+"</p>"
Next J
VALL1+=SAVV
Return

$MODPROX
Local Char    TIT(80) , TITABR(80)

#87108
#Local Integer PRODUIT
#Call NOMBRA(11,PRODUIT) From GLOCK
TIT = func APRODUCT._AGETPRODUCTNAME()
Case GPRODUIT
 When -1 : TIT = "Superviseur"   : TITABR = "ADX"  : # Superviseur
 When  0 : TITABR = "ADX"  : # X3
 When  1 : TITABR = "GEO"  : # Gûˋode
 When  2 : TITABR = "INN"  : # Paye
 When  3 : TITABR = "ABE"  : # Biens
Endcase

IP=instr(1,VALL1,"xsageprodnamex")
VALL1=left$(VALL1,IP-1)+TIT+right$(VALL1,IP+14)
Return

$MODLABX
Local Char WEBSITE(100)
Call CREWEBSIT(WEBSITE) From INTRUTILA
IP=instr(1,WEBSITE,"//")
If IP<>0 : WEBSITE=right$(WEBSITE,IP+2) : Endif
IP=instr(1,VALL1,"xsagesitelabelx")
VALL1=left$(VALL1,IP-1)+WEBSITE+right$(VALL1,IP+15)
Return

