Subprog BOLINK(FONCTION,VARIA,CLE)
Value Char FONCTION
Value Char VARIA
Value Char CLE

#  Tunnel û  partir de la Business Intelligence

Local Char CLE1(30),CLE2(30)
Local Integer I

If CLE<>""
  I=instr(1,CLE,"~")
  If I <> 0
    CLE1=left$(CLE,I-1)
    CLE2=right$(CLE,I+1)
  Else
    CLE1=CLE : CLE2=""
  Endif
Endif

#    # Appel objet
#    # - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#If left$(FONCTION,3)="GES"
#  Call OBJET(right$(FONCTION,4),CLE1,CLE2) From GOBJET
#Endif
# 114378 CCL
If left$(FONCTION,3)="GES"
 Local Char WFCT(250)
 WFCT = FONCTION + "/1/" + right$(FONCTION,4)+" /M/" + CLE
 Nap =WFCT
Endif
End

# -------------------------------------------------------------------------------

Subprog CREURLBO(BONAME,BOREP,BOTYP,BOINV,BOVAL)
Value Char BONAME
Value Char BOREP()(1..)
Value Char BOTYP()(1..)
Value Char BOINV()(1..)
Value Char BOVAL()(1..)

# BONAME : Nom du rapport   :
# BOREP  : Tableau des Rûˋpertoires
# Tableau des invites :
# BOTYP  : Type                :  (S)imple, (M)ultiple, (R)ange
# BOINV  : Invite              :  Bien respecter les majuscules, minuscules
# BOVAL  : Valeurs(s)          :  A ou A,B ou [V1..V2] selon le cas


Local Integer I

Global Clbfile GURLBO(2)
If BONAME="" : End : Endif
Local Char SERV(100)
GURLBO=GBOPROXY

Local Char BOVERSION(80)
Call GETBOVERSION(BOVERSION) From INTRUTILA
If toupper(BOVERSION)='R2'
  GURLBO+="enterprise115/desktoplaunch/opendoc/openDocument.jsp?"
Elsif toupper(BOVERSION)='R3'
  GURLBO="/businessobjects/OpenDocument/opendoc/openDocument.jsp?"
Elsif toupper(BOVERSION)='R4'
  GURLBO="/BOE/OpenDocument/opendoc/openDocument.jsp?"
Else
  GURLBO+="openDocument.jsp?"
Endif

If toupper(BOVERSION)='R4'
 GURLBO+="sIDType=CUID"
 GURLBO+="&iDocID="+BONAME
Else
 GURLBO+="sType=wid"
 GURLBO+="&sDocName="+BONAME
 For I=1 To dim(BOREP)
  If vireblc(BOREP(I),2)="" : Break 1 : Endif
  If I=1 : GURLBO+="&sPath=" : Else : GURLBO+="," : Endif
  GURLBO+="["+BOREP(I)+"]"
 Next I
Endif
For I=1 To dim(BOTYP)
  If BOTYP(I)="" : Break 1 : Endif
  GURLBO+="&ls"+BOTYP(I)+BOINV(I)+"="+BOVAL(I)
Next I

End

