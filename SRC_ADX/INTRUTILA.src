Subprog GETPORTEXA(PORT)
    Variable Char PORT
    Local Char PORTPROP(80)
    Local Integer CODERET
    PORTPROP="exalead.tools.baseport"
    PORT=""
    CODERET=-1
    Call RECHPROP(PORTPROP,PORT,CODERET) From INTRUTILA
End
