#<AdxTL>@(#)11.0.0.0 $Revision$
#-----------------------------------------------------------------------
Subprog GLOBWEB(ADOSS)

#         GI_DOSS   : dossier traitûˋ
#         GI_VGEN   : version des gûˋnûˋrateurs
#         GI_LLAN   : langues û  utiliser pour la gûˋnûˋration
#         GI_NBLAN  : nombre de langues du dossier

Value Char ADOSS

Global Char GI_VGEN,GI_DOSS,GI_LANDEF(3)
Global Integer GI_NBLAN
Local Integer I

GI_DOSS=ADOSS
If GI_DOSS="" : GI_DOSS=nomap : Endif

GI_VGEN="7,2012090"

If clalev([F:ADS])<>0 and [F:ADS]DOSSIER=GI_DOSS
  Global Char GI_LLAN(3)(1..dim([F:ADS]LAN))
  Global Char ISOLAN(6)(1..dim([F:ADS]LAN))
  Global Integer GI_VLAN(1..dim([F:ADS]LAN))
  Raz GI_LLAN,GI_NBLAN
  For I=0 To [F:ADS]NBRLAN-1
    GI_LLAN(I+1)=[F:ADS]LAN(I)
  Next I
  GI_NBLAN=[F:ADS]NBRLAN
  GI_LANDEF=[F:ADS]LANDEF
Else
  If clalev([F:ADSW])=0 : Local File ADOSSIER [ADSW] : Endif

  Global Char GI_LLAN(3)(1..dim([F:ADSW]LAN))
  Global Char ISOLAN(6)(1..dim([F:ADSW]LAN))
  Global Integer GI_VLAN(1..dim([F:ADSW]LAN))
  Raz GI_LLAN,GI_NBLAN

  Read [ADSW]DOSSIER=GI_DOSS
  If fstat
   If filinfo(filpath("","histo","",nomap),0)<=0
    # On est en train de crûˋer le dossier historique
    Read [ADSW]DOSSIER=nomap
   Else
    # Le dossier historique est crûˋûˋ (la fiche dossier historique n'existe pas)
    Read [ADSW]DOSSIER=adxmother(0)
   Endif
  Endif
  If fstat<>0 : Call ECR_TRACE(mess(52,150,1)-GI_DOSS,1) From GESECRAN : End : Endif
  For I=0 To [F:ADSW]NBRLAN-1
    GI_LLAN(I+1)=[F:ADSW]LAN(I)
  Next I
  GI_NBLAN=[F:ADSW]NBRLAN
  GI_LANDEF=[F:ADSW]LANDEF
Endif

For I=1 To GI_NBLAN
  Case GI_LLAN(I)
    When "FRA" : ISOLAN(I)="FR-FR"
    When "ENG" : ISOLAN(I)="EN-US"
    When "BRI" : ISOLAN(I)="EN-GB"
    When "GER" : ISOLAN(I)="DE-DE"
    When "ITA" : ISOLAN(I)="IT-IT"
    When "POL" : ISOLAN(I)="PL-PL"
    When "POR" : ISOLAN(I)="PT-PT"
    When "RUS" : ISOLAN(I)="RU-RU"
    When "SPA" : ISOLAN(I)="ES-ES"
    When Default
                If clalev([F:TLA])=0  : Local File TABLAN [TLA]  : Endif
                Read [TLA]TLA0=GI_LLAN(I)
                If fstat=0 and [F:TLA]LANISO<>"" and len([F:TLA]LANISO)>=3
                  ISOLAN(I)=toupper(ctrans([F:TLA]LANISO,"_","-"))
                Else
                  ISOLAN(I)=GI_LLAN(I)
                Endif
  Endcase
Next I


End

#-----------------------------------------------------------------------

Subprog GLOBLANG(TLAN,NBLAN)
Variable Char TLAN()(1..)
Variable Integer NBLAN

If clalev([F:ADSW])=0 : Local File ADOSSIER [ADSW] : Endif

Local Integer LANCUR

Raz TLAN,NBLAN
For [ADSW]
# Est ce un vrai dossier ?
 If filinfo(filpath("FIL","AMSK","fde",[F:ADSW]DOSSIER),7)>0
  For LANCUR=0 To [F:ADSW]NBRLAN-1
    If !find([F:ADSW]LAN(LANCUR),TLAN(1..NBLAN))
      NBLAN+=1 : TLAN(NBLAN)=[F:ADSW]LAN(LANCUR)
    Endif
  Next LANCUR
 Endif
Next
End

#-----------------------------------------------------------------------

Subprog GLOBLANGREF(TDOS,TLAN,NBLAN)
Variable Char TDOS()(1..)
Variable Char TLAN()(1..)
Variable Integer NBLAN

#   On recherche le dossier de rûˋfûˋrence traduction pour chaque langue
#   Si il n'est pas dûˋfini on prend le dossier mû´re ou le premier dossier
#   qui porte cette langue

Local Integer I,LANCUR,ILA
Local Char DOSREF,DOSFIRST(10)(1..50)
If clalev([F:ADSW])=0 : Local File ADOSSIER [ADSW] : Endif
Raz TDOS,TLAN,NBLAN

For I=7 To 0 Step -1
  If adxmother(I)<>""
    DOSREF=adxmother(I)
    Break 1
  Endif
Next I

For [ADSW]
# Est ce un vrai dossier ?
 If filinfo(filpath("FIL","AMSK","fde",[F:ADSW]DOSSIER),7)>0
  For LANCUR=0 To [F:ADSW]NBRLAN-1
    ILA=find([F:ADSW]LAN(LANCUR),TLAN(1..NBLAN))
    If ILA=0
      NBLAN+=1 : TLAN(NBLAN)=[F:ADSW]LAN(LANCUR) : DOSFIRST(NBLAN)=[F:ADSW]DOSSIER
      If [F:ADSW]LANREF(LANCUR)=2 : TDOS(NBLAN)=[F:ADSW]DOSSIER : Endif
    Else
      If [F:ADSW]LANREF(LANCUR)=2 : TDOS(ILA)=[F:ADSW]DOSSIER : Endif
    Endif
  Next LANCUR
 Endif
Next

Read [ADSW]DOSSIER=DOSREF

# Positionne les dossiers pour les langues non affectûˋes
For I=1 To NBLAN
  If TDOS(I)=""
    If find(TLAN(I),[F:ADSW]LAN(0..[F:ADSW]NBRLAN-1))
      TDOS(I)=DOSREF
    Else
      TDOS(I)=DOSFIRST(I)
    Endif
  Endif
Next I

End

#-----------------------------------------------------------------------

Subprog NAMEFIC(DOSS,TYP,LANG,NAME,NAMEFIC)

Value Char DOSS,TYP,LANG,NAME
Variable Char NAMEFIC()


Local Char DOSREF(10),REP(200),DIRSEP,APPLI(10)
Local Integer I
APPLI="X3_PUB"

Case GOS(1)
 When "dos"   : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

###################################
# point d'entrûˋe pour ne pas utiliser le fichier solution.xml
If dim(GPOINT)>0
 [V]GPOINT="SOLNOBO" : [V]GPE=0 : Gosub ENTREE From EXEFNC
 If [V]GPE=1 Then : End  :  Endif
Endif
###################################


Case TYP
  When "SRVL"
#              REP = "X3_ROOT"+DIRSEP+"GEN"+DIRSEP+LANG+DIRSEP+TYP
              REP = DOSS+DIRSEP+"GEN"+DIRSEP+LANG+DIRSEP+TYP
              NAMEFIC=filpath(REP,"","",APPLI)
              If NAME<>"" : NAMEFIC+=DIRSEP+NAME+".xml" : Endif
  When "M151"
              REP="X3_CLIENT"+DIRSEP+"WEBF"+DIRSEP+LANG+DIRSEP+"SRVL"
              NAMEFIC=filpath(REP,"","",APPLI)
              If NAME<>"" : NAMEFIC+=DIRSEP+NAME+".xml" : Endif
  When "RES","IMP","EXP"
              REP="X3_ROOT"+DIRSEP+TYP
              NAMEFIC=filpath(REP,"","",APPLI)
              If NAME<>"" : NAMEFIC+=DIRSEP+NAME : Endif
              If NAME<>"" & right$(NAME,max(len(NAME)-3,1))<>".xml" : NAMEFIC+=".xml" : Endif
  When "PHO"
              REP="X3_ROOT"+DIRSEP+TYP
              NAMEFIC=filpath(REP,"","",APPLI)
              If NAME<>"" : NAMEFIC+=DIRSEP+NAME : Endif
  When "WIND","SCRN","WEBS","STY","PAR"
              REP = DOSS+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+TYP
              NAMEFIC = filpath(REP,"","",APPLI)
              If NAME<>"" : NAMEFIC+=DIRSEP+NAME : Endif
              If NAME<>"" & right$(NAME,max(len(NAME)-3,1))<>".inf" : NAMEFIC+=".xml" : Endif
  When "FENJ"
              I=find(LANG,GI_LLAN(1..GI_NBLAN))
              Local Char SYRLAN
              If I>0 : SYRLAN=ISOLAN(I) : Endif
              REP = DOSS+DIRSEP+"GEN"+DIRSEP+"SYR"+DIRSEP+SYRLAN+DIRSEP+"FENJ"
              If(func INTRUTILB.JSONONLYPARAM(DOSS) & GUSER="LVXX")
                Local Integer ERREUR
                REP = DOSS+DIRSEP+"GEN"+DIRSEP+"SYR"+DIRSEP+SYRLAN+DIRSEP+"FENJ-N"
                Call CREREP(filpath(REP,"","",APPLI),ERREUR) From DOSAPL
              Endif
              NAMEFIC = filpath(REP,"","",APPLI)
              If NAME<>"" : NAMEFIC+=DIRSEP+NAME+".json" : Endif
  When "WINDJ","SCRNJ"
              REP = DOSS+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+TYP
              NAMEFIC = filpath(REP,"","",APPLI)
              If NAME<>"" : NAMEFIC+=DIRSEP+NAME+".json"  : Endif
  When "XSD"
              REP = DOSS+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+"WEBS"
              NAMEFIC = filpath(REP,"","",APPLI)
              If NAME<>"" : NAMEFIC+=DIRSEP+NAME : Endif
              NAMEFIC+=".xsd"
  When "OBJT"
              REP = DOSS+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+TYP
              NAMEFIC = filpath(REP,"","",APPLI)
              If NAME<>"" : NAMEFIC+=DIRSEP+"OBJ_"+NAME+".xml" : Endif
  When "OBJTJ"
              REP = DOSS+DIRSEP+"GEN"+DIRSEP+"ALL"+DIRSEP+TYP
              NAMEFIC = filpath(REP,"","",APPLI)
              If NAME<>"" : NAMEFIC+=DIRSEP+"OBJ_"+NAME+".json" : Endif
  When "PRF","PROF"
              REP = DOSS+DIRSEP+"GEN"+DIRSEP+LANG+DIRSEP+"PROF"
              NAMEFIC = filpath(REP,"","",APPLI)
              If NAME<>"" : NAMEFIC+=DIRSEP+NAME+".xml" : Endif
  When "GEN"
              REP = DOSS+DIRSEP+"GEN"
              NAMEFIC = filpath(REP,"","",APPLI)
  When "ECR"
              NAMEFIC = filpath("ECR","","",DOSS)
  When "TMP"
              REP = DOSS+DIRSEP+"TMP"
              NAMEFIC = filpath(REP,"","",APPLI)
              If NAME<>"" : NAMEFIC+=DIRSEP+NAME : Endif
  When "LANG"
              REP = DOSS+DIRSEP+"GEN"+DIRSEP+LANG
              NAMEFIC = filpath(REP,"","",APPLI)
  When "DOSS"
              REP = DOSS
              NAMEFIC = filpath(REP,"","",APPLI)
  When "FENX","FENW","FENS","WINA","FENT"
              REP = DOSS+DIRSEP+"GEN"+DIRSEP+LANG+DIRSEP+TYP
              NAMEFIC = filpath(REP,"","",APPLI)
              If NAME<>"" : NAMEFIC+=DIRSEP+NAME+".xml" : Endif
  When "HTML"
              REP = DOSS+DIRSEP+"GEN"+DIRSEP+LANG+DIRSEP+TYP
              NAMEFIC = filpath(REP,"","",APPLI)
              If NAME<>"" : NAMEFIC+=DIRSEP+NAME+".htm" : Endif
  When "MENL"
              REP = DOSS+DIRSEP+"GEN"+DIRSEP+LANG+DIRSEP+TYP
              NAMEFIC = filpath(REP,"","",APPLI)+DIRSEP
              If NAME<>"" : NAMEFIC+=NAME+".xml" : Endif
  When "MENLJ"
              REP = DOSS+DIRSEP+"GEN"+DIRSEP+LANG+DIRSEP+"MENL"
              NAMEFIC = filpath(REP,"menloc","js",APPLI)
              If NAME<>"" : NAMEFIC+=NAME+".xml" : Endif
  When "SOL"
              For I=7 To 0 Step -1
                If adxmother(I)<>""
                  DOSREF=adxmother(I)
                  Break 1
                Endif
              Next I
              NAMEFIC=filpath("","","",DOSREF)
              NAMEFIC=left$(NAMEFIC,len(NAMEFIC)-len(DOSREF))
              NAMEFIC+="solution.xml"
  When  Default
Endcase


End
#-----------------------------------------------------------------------

Subprog NFICTEMP(DOSS,NAME,EXT,NAMEFIC)

Value Char DOSS
Value Char NAME,EXT
Variable Char NAMEFIC()

Local Char DIRSEP,NAME1(100)

NAME1=NAME

Case GOS(1)
 When "dos"   : DIRSEP="\"
 When Default : DIRSEP="/"
Endcase

If NAME1="" : Call ENVVAR(NAME1) : Endif
NAME1="F"+num$(adxuid(1))+"_"+NAME
NAMEFIC = filpath(DOSS+DIRSEP+"TMP",NAME1,EXT,"X3_PUB")

End
#-----------------------------------------------------------------------

Subprog ENVVAR(HORDAT)

#  Positionne la variable :
#         HORDAT : horodatage ex: 19990809143225
#

Variable Char HORDAT()

HORDAT=date$+left$(time$,2)+mid$(time$,4,2)+right$(time$,7)

End

#-----------------------------------------------------------------------

Subprog INCRYPT(ZCLAIR,ZCODE)
Value Char ZCLAIR
Variable Char ZCODE

Local Char KEYC(50),KEYINT(50),KEYDIV(50),KEYENT(50)
Local Integer NDIV,NREST,NINTER,I,C1

Raz ZCODE
KEYC="x3 vient du froid"
KEYINT="cromanwqxfzpgedkvstjhyilu"
KEYDIV="zxWyZxzvwYzxZXxxZWWyWxYXz"
KEYENT="cf2tln3yuVkDr7oPaQ8bsSd4x"

For I=1 To len(ZCLAIR)
  NDIV = ascii(mid$(ZCLAIR,I,1))/len(KEYC)
  NREST= ascii(mid$(ZCLAIR,I,1))-NDIV*len(KEYC)
  C1=ascii(mid$(KEYDIV,I,1))-NDIV
  ZCODE+=chr$(C1)
  ZCODE+=mid$(KEYINT,NREST+1,1)
  NINTER=mod(NREST,2)
  If NINTER=0
   ZCODE+=mid$(KEYENT,NREST+1,1)
  Endif
Next I

End

