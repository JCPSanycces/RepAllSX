Subprog INITYPPORT(OKENV)
Variable Integer OKENV

If GSERVEUR or GHISTO or GWEBSERV=1
 OKENV = 0 : End
Endif

# Est-on en portail interactif ou pas ?
# Oui si
#    - on est en X2 ou en X3 avec droit au portail
#    - la table APORTUSER est prûˋsente

Local Integer ERRPORT,VLICENSE,ERF

#87108
#Local Integer PRODUIT
#Call NOMBRA(11,PRODUIT) From GLOCK  : # Si PRODUIT=6   X2
##  Controle licence
#If PRODUIT<>6
# Call NOMBRA(12,VLICENSE) From GLOCK
# VLICENSE=mod(VLICENSE,2)
#Endif
#Infbox("Produit"-num$(PRODUIT)-"  license"-num$(VLICENSE))
#If PRODUIT<>6 and VLICENSE<>1
# OKENV = 0 : End
#Endif
If dim(GACTX._ASYRLIC)>0 & GACTX._ASYRLIC<>null
 VLICENSE=fmet GACTX.AGETLICACV("APL")
Else
 VLICENSE=1
Endif
If VLICENSE<>1
 OKENV = 0 : End
Endif


Local Char PREFPUS
#87108
#If PRODUIT<>6
 #Call PARAM("","NEWPORT",PREFPUS) From ADOVAL
 Onerrgo ERF
 Local File AUTILIS [AU_]
 If ERF
  Call PARAM("","NEWPORT",PREFPUS) From ADOVAL
 Elsif dim([F:AU_]LOGIN)>0
  If toupper(adxusr)<>"ASK_"
    Read [AU_]LOGIN = toupper(adxusr)
  Else
   Read [AU_]LOGIN = toupper(GLOGIN)
  Endif
  If fstat or ERF
   Call PARAM("","NEWPORT",PREFPUS) From ADOVAL
  Else
   Call PARAMUTIL("NEWPORT",PREFPUS,[F:AU_]USR,"") From SUBAUS
  Endif

 Endif
 Close Local File [AU_]
 Onerrgo
#Endif
Onerrgo INIPORTERR
Local File APORTUSER [APU]
Onerrgo
#87108
#If ERRPORT=0 and (PRODUIT=6 or PREFPUS="2")
# OKENV = 1
#Endif
If ERRPORT=0 and PREFPUS="2"
 OKENV = 1
Endif
End

$ERF
ERF = errn
Resume

$INIPORTERR
ERRPORT=1
Resume

