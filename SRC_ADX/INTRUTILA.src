Subprog CREWEBSIT(WEBSITE)
Variable Char WEBSITE()

If GSERVEUR : End : Endif
If dim(GADXWEBSITE)>0 and GADXWEBSITE<>""
  WEBSITE=GADXWEBSITE
Else
  If GPRODUIT<=0
#87108
#    Local Integer PRODUIT
#    Call NOMBRA(11,PRODUIT) From GLOCK
#    Case PRODUIT
#      When 5             : WEBSITE="http://www.formula.it"
#      When Default       : WEBSITE="http://www.sageerpx3.com"
#    Endcase
    WEBSITE="http://www.sageerpx3.com"
  Else
    Case GLANGUE
      When "FRA"         : WEBSITE="http://www.sage.fr"
      When "SPA"         : WEBSITE="http://www.sage.es"
      When "ENG","BRI"   : WEBSITE="http://www.sageerpx3.com"
      When "POR"         : WEBSITE="http://www.sage.pt"
      When "ITA"         : WEBSITE="http://www.formula.it"
      When "CHI","CHN"   : WEBSITE="http://www.sagesoft.cn"
      When Default       : WEBSITE="http://www.sageerpx3.com"
    Endcase
  Endif
Endif

End

