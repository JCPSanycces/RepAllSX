Subprog MODVALCLB(VALLM)
#
# --- Remplace les caractû´res spûˋciaux non interprûˋtables par xml
#
Variable Clbfile VALLM

Gosub MVALC
End

#-----------------------------------------------------------------------

Subprog MODVAL(VALLM)
#
# --- Remplace les caractû´res spûˋciaux non interprûˋtables par xml
#
Variable Char VALLM

Gosub MVALC
End

#------------------------------

$MVALC:
Local Clbfile WN_VAL(2)
Local Char WN_CAR,WN_REP,WN_REP1
Local Integer WN_RG,WN_DEB
WN_VAL=VALLM

WN_CAR="<" : WN_REP="&lt;"     : WN_REP1="&#60;"  : Gosub MODVALCCA
WN_CAR=">" : WN_REP="&gt;"     : WN_REP1="&#62;"  : Gosub MODVALCCA
WN_CAR='"' : WN_REP="&quot;"   : WN_REP1="&#34;"  : Gosub MODVALCCA
WN_CAR='&' : WN_REP="&amp;"    : WN_REP1="&#38;"  : Gosub MODVALCCA
Return

#  Point d'entrûˋe spûˋcifique pour les menus locaux (enlû´ve les \)
$MVALC1
Gosub MVALC
WN_CAR='\' : WN_REP=" "    : WN_REP1=" "  : Gosub MODVALC
Return

$MODVALC
  WN_DEB=1
  Repeat
   WN_RG=instr(WN_DEB,VALLM,WN_CAR)
   If WN_RG & !find(mid$(VALLM,WN_RG,5),"&#60;","&#62;","&#34;","&#38;")
     WN_VAL=left$(VALLM,WN_RG-1)+WN_REP1+right$(VALLM,WN_RG+1)
     VALLM=WN_VAL
     WN_DEB=WN_RG+1
   Else
     WN_DEB=WN_RG+1
   Endif
  Until WN_RG=0
Return

$MODVALCCA
  WN_DEB=1
  Repeat
   WN_RG=instr(WN_DEB,VALLM,WN_CAR)
   If WN_RG & !find(mid$(VALLM,WN_RG,4),"&lt;","&gt;") & mid$(VALLM,WN_RG,5)<>"&amp;" & mid$(VALLM,WN_RG,6)<>"&quot;"
     WN_VAL=left$(VALLM,WN_RG-1)+WN_REP+right$(VALLM,WN_RG+1)
     VALLM=WN_VAL
     WN_DEB=WN_RG+1
   Else
     WN_DEB=WN_RG+1
   Endif
  Until WN_RG=0
Return

#-----------------------------------------------------------------------

Subprog VIDEREP(DOSS,TYP,LANG,SUP)

#  Efface le contenu du rûˋpertoire REP
#  Si SUP=0  dûˋtruit le rûˋpertoire
#        =1  recrûˋe le rûˋpertoire vide

Value Char DOSS,TYP,LANG
Value Integer SUP

Local Char NAMEREP(GDIMFIC),MACHINE(GDIMFIC)
Local Char OPT(200),ORDRE(200)
Local Integer STAT

Call NAMEFIC(DOSS,TYP,LANG,"",NAMEREP)

ORDRE="ae_rmdir "+NAMEREP
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
If SUP=1
  ORDRE="ae_mkdir "+NAMEREP
  Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS
Endif

End

#-----------------------------------------------------------------------

Subprog VIDEALLREP(DOSS,LANG,SUP)

Value Char DOSS,LANG
Value Integer SUP

#  Efface le contenu des rûˋpertoires publiûˋs du dossier DOSS pour la langue LANG
#  Si LANG="ALL" dûˋtruit les rûˋpertoires pour toutes les langues
#  Si SUP=0  dûˋtruit les rûˋpertoires
#        =1  recrûˋe les rûˋpertoires vide

Local Char SREP
Local Integer LANCUR

Call GLOBWEB(DOSS)

If LANG="ALL"
    Call VIDEREP(DOSS,"GEN","",0)
    Call VIDEREP(DOSS,"LANG","ALL",SUP)
    Call CREREPPUB(DOSS) From INTRUTILC
Else
    For SREP="WINA","MENL","FENX","FENW","HTML","SRVL","PROF"
      Call VIDEREP(DOSS,SREP,LANG,SUP)
    Next SREP
    If SUP=0 : Call VIDEREP(DOSS,"LANG",LANG,SUP) : Endif
Endif

End

#-----------------------------------------------------------------------

Subprog INITAEL(DOSS)

# Efface le contenu des tables AELT et AELTLINK du dossier DOSS

Value Char DOSS

Local Char OPT(200),ORDRE(200),MACHINE(GDIMFIC)
Local Integer STAT

ORDRE="valfil -z "+DOSS-"AELT"
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS

ORDRE="valfil -z "+DOSS-"AELTLINK"
Call SYSTEME(MACHINE,ORDRE,OPT,STAT) From ORDSYS

End

#-------------------------------------------------------------------------------------------
# Recherche le nom de solution et le nom de la virtual directory de publication
# Recherche les informations SGBD û  envoyer au client
# Recherche les paramû´tres BO
#-------------------------------------------------------------------------------------------

Subprog INIVWEB(SOLUTION,VIRDIR,ACCESS,BASE)

Variable Char SOLUTION,VIRDIR,ACCESS,BASE

Local Char NOMFIC(200),VALL1(200),ACCESSPATH(200),CHM(50),CLIENTUSE(10)
Local Integer I1,I2,TYPD
Local Char TYPSGBD,NOMBAS(30),SERVEUR(100),SQLINST(50),ORAPORT
Local Integer TBAS
Local Char RETOUR(250)

Global Char GBOPROXY(200),GBOSYST(100),GAPPSERV(100)

Call NAMEFIC(nomap,"SOL","","",NOMFIC) From INTRUTILA
If filinfo(NOMFIC,7)<0 : Goto ERRLEC : Endif
fstat=0
Openi NOMFIC,0 Using [CST_]
If fstat<>0 : Goto ERRLEC : Endif
Iomode adxifs ""  Using [CST_]
Iomode adxirs chr$(10)  Using [CST_]
Iomode adxium GUTF8  Using [CST_]
fstat=0
While fstat=0
  Rdseq VALL1 Using [CST_]
  If instr(1,VALL1,"<solution")<>0
    I1=instr(1,VALL1,"name")
    I2=instr(I1+6,VALL1,'"')
    If I2-I1-6>0
      SOLUTION=vireblc(mid$(VALL1,I1+6,I2-I1-6),2)
    Endif
  Elsif instr(1,VALL1,"application.web.virtdir")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      VIRDIR=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
      VIRDIR=ctrans(VIRDIR,"\","/")
    Endif
  Elsif instr(1,VALL1,"application.bo.proxypass")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      GBOPROXY=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif instr(1,VALL1,"component.application.servername")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      GAPPSERV=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif instr(1,VALL1,"application.bo.systeme")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      GBOSYST=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif instr(1,VALL1,"application.http.url")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      VIRDIR=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif instr(1,VALL1,"doc.files.accesspath")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      ACCESSPATH=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif instr(1,VALL1,"doc.files.chm")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      CHM=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif instr(1,VALL1,"doc.files.clientuse")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      CLIENTUSE=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif instr(1,VALL1,'family="DATABASE"')<>0
    I1=instr(1,VALL1,"type")
    I2=instr(I1+6,VALL1,'"')
    If I2-I1-6>0
      TYPSGBD=vireblc(mid$(VALL1,I1+6,I2-I1-6),2)
    Endif
    Case TYPSGBD
      When "ORACLE"    : TBAS=1
      When "SQLSERVER" : TBAS=2
    Endcase
  Elsif TBAS=1 and instr(1,VALL1,"database.adonix.orasid")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      NOMBAS=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif TBAS=2 and instr(1,VALL1,"database.adonix.sqlbase")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      NOMBAS=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif instr(1,VALL1,"component.database.servername")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      SERVEUR=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif TBAS=2 and instr(1,VALL1,"database.adonix.sqlinstance")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      SQLINST=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif TBAS=1 and instr(1,VALL1,"database.software.oraport")<>0
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      ORAPORT=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Endif
Wend

If ORAPORT="" and TBAS=1 : ORAPORT="1521" : Endif
If TBAS=2 : SERVEUR+="\"+SQLINST : Endif
Openi Using [CST_]

If ACCESSPATH<>"" and GBROWS=0 & !GSERVEUR and GWEBSERV=0
   TYPD=1
   If toupper(CLIENTUSE)="CHM" : TYPD=2 : Endif
   If CHM=""
     If TYPD=1 : CHM="index.htm" : Else : CHM="index.chm" : Endif
   Endif
   ACCESS = ACCESSPATH+"~"+num$(TYPD)+"~"+CHM
Endif

If (GBROWS=0 | GFUSION=1) & !GSERVEUR
   BASE = num$(TBAS)+"~"+NOMBAS+"~"+SERVEUR+"~"+ORAPORT
Endif

End

$ERRLEC:
Raz SOLUTION,VIRDIR
If dim(OKENV)>0 : Raz OKENV : Endif
End

#-----------------------------------------------------------------------

Subprog SETBO(USERX3)
Value Char USERX3
Local Char USRBI(80),PWDBI(80),MODESECBI(80),MESSA(80)
Local Integer OK,MODE
Local Char RETOUR(250)
Call VARPSEBO(USERX3,USRBI,PWDBI,MESSA,MODE,OK) From GESUSER
Global Integer GUSRBOOK
If OK<>1 & GFUSION=0 : End : Endif
If USRBI<>"" : GUSRBOOK=1 : Endif
Case MODE
  When 1 : MODESECBI="SecEnterprise"
  When 2 : MODESECBI="LDAP"
  When 3 : MODESECBI="Windows AD"
  When 4 : MODESECBI="Windows NT"
  When Default : MODESECBI="SecEnterprise"
Endcase
# Provisoire ------------------------------------------------
If GBOSYST="" and nomap="SUPERV" and GADONIX=2  : GBOSYST="SODSQL01" : Endif
# -----------------------------------------------------------
#  Codage des valeurs
Call INCRYPT(USRBI,RETOUR) From INTRUTILA
USRBI="CRYPT:"+RETOUR
Call INCRYPT(PWDBI,RETOUR) From INTRUTILA
PWDBI="CRYPT:"+RETOUR

If OK=1 and !GSERVEUR
 Callui RETOUR=""    With "UIAction=" + chr$(1) + "SessionSettings",
& "BOUSR="  + chr$(1) + USRBI,
& "BOPWD="  + chr$(1) + PWDBI,
& "BOSERV=" + chr$(1) + GBOSYST,
& "BOSEC="  + chr$(1) + MODESECBI
Endif

End
#----------------Info pour Exalead UI -----------------------------------------------

Subprog GETINFOFOREXALEAD(VAL1,VAL2,XINFO,XLOCATION,XPARAMS,WITHFNC)
    Value Integer VAL1
    Value Integer VAL2
    Variable Clbfile XINFO
    Variable Clbfile XLOCATION
    Variable Clbfile XPARAMS
    Value Integer WITHFNC #1 : avec liste fct 0, sans list fct


    Local Char VERSION(20)
    Local Char NOPATCH(20)
    Local Integer PRODUCT
    Local Char VERSOL(20)
    Local Char TOKEN(250)


    Call GETINFOVER(VERSION,NOPATCH,PRODUCT,VERSOL) From INTRUTILA
    Call GETTOKEN(VAL1,(VAL2+1),TOKEN) From INTRUTILA


#{
#xinfos: [
#        {name: 'version',value: '16.23','type': 'info'},
#        {name: 'patch',value: '12','type': 'info'}
#        {name: 'token',value: 'qsdqdqseazdczfds','type': 'token'}
#         ],
#xparams: ['val1','val2',....,'valn']
#}
    Local Char HOSTNAME(250)
    Local Char PORTNUM(10)
    Local Char PATH(250)
    Local Char PROXY(250)
    Call GETHOSTEXA(HOSTNAME) From INTRUTILA      #hostname serveur de la servlet
    Call GETPORTEXA(PORTNUM) From INTRUTILA       # No port serveur servlet
# pour test :
    #HOSTNAME="exalid01.sagefr.adinternal.com""
    #PORTNUM="15000"

# pour test :
#    If(GUSER='LV')
#        HOSTNAME="eclvarciat.sagefr.adinternal.com"
#        PORTNUM="8080"
#    Endif
# fin pour test

    PATH="/search-ui/"                       # nom de la srrvlet (constante)
    SUBPATH="search/"                                  # subPath de la page jsp û  atteindre (constant
    Raz XLOCATION
    XLOCATION="xlocation:{"
    XLOCATION+="'hostname':'http://"+HOSTNAME+"',"
    XLOCATION+="'port':'"+PORTNUM+"',"
    XLOCATION+="'path':'"+PATH+"',"
    XLOCATION+="'subpath':'"+SUBPATH+"'"
    XLOCATION+="}"

    Raz XINFO
    XINFO="xinfos:["
    XINFO+="{'name':'token','value':'"+TOKEN+"','type':'token'},"
    XINFO+="{'name':'version','value':'"+VERSION+"','type':'info'},"
    XINFO+="{'name':'patch','value':'"+NOPATCH+"','type':'info'},"
    XINFO+="{'name':'product','value':'"+num$(PRODUCT)+"','type':'info'},"
    XINFO+="{'name':'versol','value':'"+VERSOL+"','type':'info'},"
    XINFO+="{'name':'solution','value':'"+GINSTID+"','type':'info'},"
    XINFO+="{'name':'folder','value':'"+nomap+"','type':'info'},"
    XINFO+="{'name':'theme','value':'"+GTHEME+"','type':'info'}" #theme du portail
    XINFO+="]"

    Raz XPARAMS
    If (WITHFNC=1)
        Call GETXPARAMS(XPARAMS) From INTRUTILA
    Endif
End

#----------------xparams -----------------------------------------------
Subprog GETXPARAMS(XPARAMS)
    Variable Clbfile XPARAMS
     Local Char TABRES(GLONAFC)(1..3000)
     Local Char UTILIS
     Local Integer NBFONC


    XPARAMS="xparams:["
    UTILIS=GUSER
    #CHECK UNUSED_BEGIN
    Call LISTFONCUS(UTILIS,NBFONC,TABRES) From ATRTASRSUB
    #CHECK UNUSED_END
    For I=1 To NBFONC
        If TABRES(I)="" : Break 1 : Endif
        XPARAMS+="'"+TABRES(I)+"'"
        If I<NBFONC : XPARAMS+=",": Endif
    Next I
     XPARAMS+="]"
End
#----------------Info Version/produit -----------------------------------------------
Subprog GETINFOVER(VERSION,NOPATCH,PRODUCT,VERSOL)
    Variable Char VERSION
    Variable Char NOPATCH
    Variable Integer PRODUCT
    Variable Char VERSOL

    Call VERSIONX3(VERSION,NOPATCH) From INTRUTILA
    #87108
    #Call NOMBRA(11,PRODUCT) From GLOCK
    Case GPRODUIT
     When 0 : PRODUCT=1 : # X3
     When 1 : PRODUCT=4 : # Gûˋode
     When 2 : PRODUCT=2 : # Paye
     When 3 : PRODUCT=8 : # Biens
     When Default : PRODUCT=GPRODUIT
    Endcase

    VERSOL=func APRODUCT.AGETRELEASESUP()
End
#----------------TOKEN X3 -----------------------------------------------

Subprog GETTOKEN(VAL1,VAL2,R)
    Value Integer VAL1
    Value Integer VAL2
    Variable Char R
    Local Integer VAL3
    Char RETOUR(250)
    Local Char RETOUR1(250)
    VAL3=VAL1+VAL2
    Call INCRYPT(GUSER+"_"+num$(VAL3),RETOUR) From INTRUTILA
    Call INCRYPT(GINSTID+"_"+GDOSX3,RETOUR1) From INTRUTILA
    #GUSER
    #GINSTID
    #GDOSX3
    R=RETOUR+"_"+RETOUR1
End
