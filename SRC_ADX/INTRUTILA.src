Subprog INIPORTAL

If GSERVEUR or GWEBSERV=1 : End : Endif

Local Char URLPTLPAGE(250),HOMEPAGEURL(250)
Local Char RETOUR(250)(1..10)
Local Char PTLPAGE(60)
Local Integer VLICENSE

If dim(GPTLPAGE)>0 : PTLPAGE=GPTLPAGE : Endif
Call PARAMUTIL("HOMEPAGE",HOMEPAGEURL,GUSER,"") From SUBAUS : # Page utilisateur
If HOMEPAGEURL=""
 #  Rûˋcupûˋration des paramû´tres HOMEPAGE1,2 et 3
 Local Char HOMEPAGE1(60),HOMEPAGE2(60),HOMEPAGE3(60)
 Call PARAMUTIL("HOMEPAGE1",HOMEPAGE1,GUSER,"") From SUBAUS : # Page utilisateur 1
 Call PARAMUTIL("HOMEPAGE2",HOMEPAGE2,GUSER,"") From SUBAUS : # Page utilisateur 2
 Call PARAMUTIL("HOMEPAGE3",HOMEPAGE3,GUSER,"") From SUBAUS : # Page utilisateur 3
 HOMEPAGEURL=vireblc(HOMEPAGE1,2)+vireblc(HOMEPAGE2,2)+vireblc(HOMEPAGE3,2)
Endif

Local Char SEP
Case GOS(1)
 When "dos"   : SEP="\"
 When Default : SEP="/"
Endcase

If toupper(left$(HOMEPAGEURL,6))="LOCAL:" and GVIRTDIR<>""
  HOMEPAGEURL=ctrans("http://"+GVIRTDIR+SEP+right$(HOMEPAGEURL,7),"\","/")
Endif
If left$(HOMEPAGEURL,8)="$X3_PTL:"
  URLPTLPAGE=right$(HOMEPAGEURL,9)
  HOMEPAGEURL=""
Endif

#  Controle licence
#87108
#Call NOMBRA(12,VLICENSE) From GLOCK
#VLICENSE=mod(VLICENSE,2)
If dim(GACTX._ASYRLIC)>0 & GACTX._ASYRLIC<>null
 VLICENSE=fmet GACTX.AGETLICACV("APL")
Else
 VLICENSE=1
Endif
If VLICENSE<>1 & GHISTO : PTLPAGE="" : Endif

If PTLPAGE<>""
  Local Integer TYPAG
  Call CNXTPTLURL(URLPTLPAGE, TYPAG) From SUBAPSPAGE
  If TYPAG=1  :# Adresse relative
    If GVIRTDIR<>"" and GBROWS<>0
       URLPTLPAGE=ctrans("http://"+GVIRTDIR+SEP+"ADX_PORTAL"+SEP+URLPTLPAGE,"\","/")
    Else
       URLPTLPAGE=ctrans("LocalPortal:ADX_PORTAL"+SEP+URLPTLPAGE,"\","/")
    Endif
  Elsif  TYPAG=0 and GBROWS=1 and instr(1,URLPTLPAGE,"http:")<>0
    If HOMEPAGEURL="" : HOMEPAGEURL=URLPTLPAGE : Endif
    Raz URLPTLPAGE, PTLPAGE
  Endif
Endif


Local Char REP(250),NOMFIC(250),PAGDEF(100),URLPTLPAGE1(250)
Local Integer TROUV
REP = "ADX_PORTAL"+SEP+"DESIGN"+SEP+"ACCWEB"+SEP
Case GPRODUIT
    When  -1,0 : REP+="_DF"  : # Superviseur ou X3
    When  1    : REP+="_DF"  : # Gûˋode
    When  2    : REP+="INN"  : # Paye
    When  3    : REP+="ABE"  : # Biens
Endcase


#    On construit le nom complet, on vûˋrifie l'existance et on applique les rû´gles de substitution
 PAGDEF="user_"+tolower(GLANGUE)
 NOMFIC=filpath(REP,PAGDEF,"HTM","X3_PUB")
 If filinfo(NOMFIC,7)>0 : Goto ENVOICALLUI : Endif

 PAGDEF="user_df"
 PAGDEF="user__df"     : # CC 17/04/2006  : Bug 40976
 NOMFIC=filpath(REP,PAGDEF,"htm","X3_PUB")
 If filinfo(NOMFIC,7)>0 : Goto ENVOICALLUI : Endif

 REP = "ADX_PORTAL"+SEP+"DESIGN"+SEP+"ACCWEB"+SEP+"_DF"
 PAGDEF="user_"+tolower(GLANGUE)
 NOMFIC=filpath(REP,PAGDEF,"htm","X3_PUB")
 If filinfo(NOMFIC,7)>0 : Goto ENVOICALLUI : Endif

 PAGDEF="user__df"     : # CC 17/04/2006  : Bug 40976
 NOMFIC=filpath(REP,PAGDEF,"htm","X3_PUB")
 If filinfo(NOMFIC,7)>0 : Goto ENVOICALLUI : Endif
 TROUV=-1

$ENVOICALLUI
If TROUV<>-1
 Gosub ENVURL
Else
 Call GENUSERP(0,URLPTLPAGE1) From INTRUTILA
 If URLPTLPAGE1<>"" : Gosub ENVURL1 : Endif
Endif

 If URLPTLPAGE="" and HOMEPAGEURL="" and URLPTLPAGE1<>""
  If GBROWS<>0  :  # Provisoire
    Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings" ,
&   "PortalUrl="+chr$(1)+ URLPTLPAGE1
  Endif
  End
 Endif

If URLPTLPAGE<>""
  If HOMEPAGEURL=""
    Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings" ,
&   "PortalUrl="+chr$(1)+ URLPTLPAGE
  Else
    Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings" ,
&   "PortalUrl="+chr$(1)+ URLPTLPAGE ,
&   "HomeUrl="+chr$(1)+HOMEPAGEURL
  Endif
Endif

If URLPTLPAGE="" and HOMEPAGEURL<>""
    Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings" ,
&   "HomeUrl="+chr$(1)+HOMEPAGEURL
Endif

End

$ENVURL
   URLPTLPAGE1=ctrans("http://"+GVIRTDIR+SEP+REP+SEP+PAGDEF+".htm","\","/")
$ENVURL1
   Callui RETOUR="" With "UIAction="+chr$(1)+"SessionSettings",
&  "DefaultHomeUrl="+chr$(1)+ URLPTLPAGE1
Return

# ------------------------------------------------------------------------------

Subprog VERSIONX3(VERSION,NOPATCH)
Variable Char VERSION
Variable Char NOPATCH

NOPATCH=""
Local File APATCH [APT]
Filter [APT] Where TYP="P"
Read [APT]APT0 Last
If fstat=0
  NOPATCH=num$([F:APT]PATNUM)
Endif
Filter [APT]
Close Local File [APT]
VERSION=GVERSION

End

# ------------------------------------------------------------------------------

Subprog VERSX3(DOSSIER,VERSION,RELEASE,NOPATCH)
Value Char DOSSIER
Variable Char VERSION,RELEASE,NOPATCH

Raz VERSION,RELEASE,NOPATCH

If DOSSIER=nomap
 Local File ADOVAL [A_DW]
Else
 Local File =DOSSIER+".ADOVAL" [A_DW]
Endif
Read [A_DW]ADW0 = "";"";"RELEASE"
If fstat=0
  RELEASE=num$([F:A_DW]VALEUR)
Else
  RELEASE="0"
Endif
Close Local File [A_DW]

If DOSSIER=nomap
 Local File APATCH [APT]
Else
 Local File =DOSSIER+".APATCH" [APT]
Endif
Filter [APT] Where TYP="P"
Read [APT]APT0 Last
If fstat=0
  #106969 If [F:APT]VER<>0 : VERSION=num$([F:APT]VER) : Endif
  NOPATCH=num$([F:APT]PATNUM)
  #If [F:APT]RELEASE<>""
  #  VERSION=ctrans([F:APT]RELEASE,".","")
  #Endif
Endif
Filter [APT]
Close Local File [APT]
#106969
#If VERSION="" : VERSION=ctrans(GVERSION,".","") : Endif
VERSION=func APRODUCT.AGETVERSION()
End
# ------------------------------------------------------------------------------

Subprog PARAMLINK(DOSSIER,TYPLIEN,MAC,SERV,DOSS,SOL,RET)
Value Char DOSSIER
Value Integer TYPLIEN
Variable Char MAC,DOSS,SOL
Variable Integer SERV,RET

# Rend les paramû´tres de dûˋfinition du lien pour le dossier DOSSIER
# TYPLIEN=1    Divers
#        =2    Lien comptable
#        =3    Lien Immo
#        =4    Lien Paye
#        =5    Lien logistique

# Code retour
# RET = 0     OK
# RET = 1     Dossier inexistant
# RET = 2     Lien non trouvûˋ
# RET = 3     Lien non actif

Raz MAC,SERV,DOSS,RET

If clalev([F:ADSW])=0 : Local File ADOSSIER [ADSW] : Endif
If clalev([F:ADDW])=0 : Local File ADOSSOL  [ADDW] : Endif
Read [ADSW]DOSSIER=DOSSIER
If fstat<>0 : RET=1 : End : Endif

For [ADDW] Where DOSSIER=[F:ADSW]DOSSIER
 If [F:ADDW]LTYPLIEN=TYPLIEN
  MAC=[F:ADDW]LMAC
  SERV=[F:ADDW]LSERV
  DOSS=[F:ADDW]LDOSTARG
  SOL=[F:ADDW]LSOL
  If [F:ADDW]LLIENACT<>2 : RET=3 : Endif
  Break 1
 Endif
Next ADDW
If MAC="" : RET=2 : Endif
End

# -------------------------------------------------------------------------------

Subprog INITBO(CLOB)
Variable Clbfile CLOB

Local Char TURL(150)(1..10),BOVERSION(80),TURL1(250)
Call GETBOVERSION(BOVERSION) From INTRUTILA

#  Initialisation des blocs BO (charge l'URL)
Raz CLOB
#If dim(GURLBO)<0 or GURLBO="" or GUSRBOOK<>1: CLOB="  " : End : Endif
#If GURLBO="" : End : Endif
If toupper(BOVERSION)='R4'
 Setlob CLOB With GURLBO
Else
 CLOB="<DESC><URL><TIT></TIT>"
 CLOB+="<TIM>"+num$(time$)+"</TIM>"
 CLOB+="<TAD>"+toupper(BOVERSION)+"</TAD><ADR>"
 Setlob TURL With GURLBO
 For I=1 To 30
   If TURL(I)="" : Break 1 : Endif
   TURL1=TURL(I)
   Call MODVAL(TURL1)
   CLOB+=TURL1
 Next I
 CLOB+="</ADR></URL></DESC>"
Endif
End

# -----------------------------------------------
Subprog INITURL1(CLOB,LIEN1,LIEN2,LIEN3)
Variable Clbfile CLOB
Value Char LIEN1,LIEN2,LIEN3
Local Char TABRES(250)(1..3000),LIENCOU
Local Integer IND,I,J,LENG

Local File AURL [AUR]
Raz CLOB
IND+=1 : TABRES(IND)="<DESC>"
If LIEN1<>"" : LIENCOU=LIEN1 : Gosub ADDLIEN : Endif
If LIEN2<>"" : LIENCOU=LIEN2 : Gosub ADDLIEN : Endif
If LIEN3<>"" : LIENCOU=LIEN3 : Gosub ADDLIEN : Endif
IND+=1 : TABRES(IND)="</DESC>"
Setlob CLOB With TABRES
End

$ADDLIEN
Read [AUR]AUR0=LIENCOU
If fstat<>0 or ([F:AUR]TYPURL<>1 and [F:AUR]TYPURL<>3) : Return : Endif
IND+=1 : TABRES(IND)="<URL>"
IND+=1 : TABRES(IND)="<TIT>"
IND+=1
If left$([F:AUR]INTEVAL,1)="="
 TABRES(IND)=evalue(right$([F:AUR]INTEVAL,2))
 Call MODVAL(TABRES(IND))
Else
 Call TEXTE([F:AUR]INTIT,TABRES(IND)) From OBJDIV
 Call MODVAL(TABRES(IND))
Endif
IND+=1 : TABRES(IND)="</TIT>"
If [F:AUR]TYPURL=1
  IND+=1
  If (dim([F:AUR]PLEURL)<>-1)
    TABRES(IND)="<TAD>"+func STRINGLOCATION([F:AUR]PLEURL)+"</TAD>"
  Else
    TABRES(IND)="<TAD>ABS</TAD>"
  Endif
  IND+=1 : TABRES(IND)="<ADR>"
  IND+=1
  If left$([F:AUR]URL,1)="="
    TABRES(IND)=evalue(right$([F:AUR]URL,2))
    Call MODVAL(TABRES(IND))
  Else
    TABRES(IND)=[F:AUR]URL
    Call MODVAL(TABRES(IND))
  Endif
  IND+=1 : TABRES(IND)="</ADR>"
Else
  IND+=1 : TABRES(IND)="<TAD>LOC</TAD>"+"<PAG><![CDATA["
  Local Char TABLOB(250)(1..1000)
  If left$([F:AUR]URL,1)="="
    [F:AUR]XSLCLOB=evalue(right$([F:AUR]URL,2))
  Endif
  Setlob TABLOB With [F:AUR]XSLCLOB
  For I=1 To 1000
    If TABLOB(I)="" : Break 1 : Endif
    IND+=1 : TABRES(IND)=TABLOB(I)
  Next I
  IND+=1 : TABRES(IND)="]]></PAG>"
Endif

IND+=1 : TABRES(IND)="</URL>"
Return

Funprog STRINGLOCATION(INTLOCATION)
   Value Integer INTLOCATION #  1:word wide web, 2:public folder, 3:current folder
   Variable Char RESVAL
   RESVAL="ABS"
    Case INTLOCATION
       When 1  : RESVAL="ABS"
       When 2  : RESVAL="PUB"
       When 3  : RESVAL="DOS"
    Endcase
End RESVAL
# -------------------------------------------------------------------------------

Subprog INITURL(CLOB,LIEN1,LIEN2,LIEN3)
Variable Clbfile CLOB
Value Char LIEN1,LIEN2,LIEN3
Local Char LIENCOU(250),TABRES(250)
Local Clbfile TABRESCLB(2)
Local Integer I
Local File AURL [AUR]
Raz CLOB
CLOB="<DESC>"
If LIEN1<>"" : LIENCOU=LIEN1 : Gosub ADDLIENC : Endif
If LIEN2<>"" : LIENCOU=LIEN2 : Gosub ADDLIENC : Endif
If LIEN3<>"" : LIENCOU=LIEN3 : Gosub ADDLIENC : Endif
CLOB+="</DESC>"
End

$ADDLIENC
Read [AUR]AUR0=LIENCOU
If fstat<>0 or ([F:AUR]TYPURL<>1 and [F:AUR]TYPURL<>3) : Return : Endif
CLOB+="<URL>"
CLOB+="<TIT>"
If left$([F:AUR]INTEVAL,1)="="
 TABRESCLB=evalue(right$([F:AUR]INTEVAL,2))
 Call MODVALCLB(TABRESCLB)
 CLOB+=TABRESCLB
Else
 Call TEXTE([F:AUR]INTIT,TABRES) From OBJDIV
 Call MODVAL(TABRES)
 CLOB+=TABRES
Endif
CLOB+="</TIT>"
If [F:AUR]TYPURL=1
  If (dim([F:AUR]PLEURL)<>-1)
    CLOB+="<TAD>"+func STRINGLOCATION([F:AUR]PLEURL)+"</TAD>"
  Else
    CLOB+="<TAD>ABS</TAD>"
  Endif
  CLOB+="<ADR>"
  If left$([F:AUR]URL,1)="="
    TABRESCLB=evalue(right$([F:AUR]URL,2))
    Call MODVALCLB(TABRESCLB)
    CLOB+=TABRESCLB
  Else
    TABRES=[F:AUR]URL
    Call MODVAL(TABRES)
    CLOB+=TABRES
  Endif
  CLOB+="</ADR>"
Else
  CLOB+="<TAD>LOC</TAD>"+"<PAG><![CDATA["
  If left$([F:AUR]URL,1)="="
    [F:AUR]XSLCLOB=evalue(right$([F:AUR]URL,2))
  Endif
  CLOB+=[F:AUR]XSLCLOB
  CLOB+="]]></PAG>"
Endif

CLOB+="</URL>"
Return

# -------------------------------------------------------------------------------
Subprog INIXSL(CLOB,XSLNAME)
Variable Clbfile CLOB
Value Char XSLNAME
Local File AURL [AUR]
Read[AUR]AUR0=XSLNAME
If fstat=0
  CLOB=[F:AUR]XSLCLOB
Endif
End
# -------------------------------------------------------------------------------
Subprog MAJURL(MASQUE,CHAMP,CLOB)
Value Char MASQUE,CHAMP
Variable Clbfile CLOB

Local Integer BL

Local File AMSK [AMK]
Local File AMSKZON [AMZ]
Read [AMK]CODMSK=MASQUE
If fstat=0
  Read [AMZ]CODE=MASQUE;CHAMP
  If fstat=0
    BL=[F:AMZ]NUMBLOC-1
    Call INITURL(CLOB,[F:AMK]BLOCLIEN1(BL),[F:AMK]BLOCLIEN2(BL),[F:AMK]BLOCLIEN3(BL))
    Affzo =CHAMP
  Endif
Endif
End
# -------------------------------------------------------------------------------

Subprog GETIMSP(XPROF,LANG,TIMESP)
Value Char XPROF
Value Char LANG
Variable Char TIMESP

Local Char WE_VALL1(200),WE_NOMFIC(200)
Local Integer AA,BB,ERF

Call NAMEFIC(nomap,"PROF",LANG,XPROF,WE_NOMFIC) From INTRUTILA
Onerrgo ERF
Openi WE_NOMFIC Using [HTI_]
Iomode adxifs "" Using [HTI_]
Iomode adxirs chr$(10) Using [HTI_]
Iomode adxium GUTF8 Using [HTI_]
Rdseq WE_VALL1 Using [HTI_]
Rdseq WE_VALL1 Using [HTI_]
AA=instr(1,WE_VALL1,"TIM=")
If AA<>0
 BB=instr(AA+6,WE_VALL1,'"')
 TIMESP=mid$(WE_VALL1,AA+5,BB-AA-5)
Endif
Openi Using [HTI_]
Onerrgo
If ERF : TIMESP = "no profil" : Endif
End
# -------------------------------------------------------------------------------

Subprog GETIMSTY(STYL,TIMESP)
Value Char STYL
Variable Char TIMESP

Local Char WE_VALL1(200),WE_NOMFIC(200)
Local Integer AA,BB

Call NAMEFIC(nomap,"STY","",STYL,WE_NOMFIC) From INTRUTILA
Openi WE_NOMFIC Using [HTI_]
Iomode adxifs "" Using [HTI_]
Iomode adxirs chr$(10) Using [HTI_]
Iomode adxium GUTF8 Using [HTI_]

Rdseq WE_VALL1 Using [HTI_]
Rdseq WE_VALL1 Using [HTI_]
AA=instr(1,WE_VALL1,"TIM=")
If AA<>0
  BB=instr(AA+6,WE_VALL1,'"')
  TIMESP=mid$(WE_VALL1,AA+5,BB-AA-5)
Endif
Openi Using [HTI_]

End

# -------------------------------------------------------------------------------

Subprog RECHPROP(PROPERTY,VPROP,OK)
# Recherche la valeur de la property dans Solution.xml
# OK=0 si valeur trouvûˋe
#   =1 propriûˋtûˋ non trouvûˋe
#   =2 fichier solution non trouvûˋ
#   =3 pb de lecture sur le fichier

Value Char PROPERTY
Variable Char VPROP
Variable Integer OK

Local Char NOMFIC(200),VALL1(200),ACCESSPATH(200),CHM(50),CLIENTUSE(10)
Local Integer I1,I2,I3
Local Char TYPSGBD,NOMBAS(30),SERVEUR(100),SQLINST(50),ORAPORT
Local Integer TBAS

Raz VPROP
OK=1

Call NAMEFIC(nomap,"SOL","","",NOMFIC) From INTRUTILA
If filinfo(NOMFIC,7)<0 : OK=2 : End : Endif
fstat=0
Openi NOMFIC,0 Using [CST_]
If fstat<>0 : OK=3 : End : Endif
Iomode adxifs ""  Using [CST_]
Iomode adxirs chr$(10)  Using [CST_]
Iomode adxium GUTF8  Using [CST_]
fstat=0
While fstat=0
  Rdseq VALL1 Using [CST_]
  I1=instr(1,toupper(VALL1),toupper(PROPERTY))
  If I1<>0
    OK=0
    I2=instr(I1+len(PROPERTY),toupper(VALL1),toupper(PROPERTY))
    If I2<>0     : # Pour traiter les propriûˋtûˋs sous forme <pppp/>
      I1=instr(I1+1,toupper(VALL1),">")
      I2=instr(I1+1,toupper(VALL1),"<")
      VPROP=mid$(VALL1,I1+1,I2-I1-1)
    Endif
    Break 1
  Endif
Wend
Openi Using [CST_]
End

# -------------------------------------------------------------------------------

Subprog RECHPROP2(MODULE,FAMILY,PROPERTY,VPROP,OK)
# Recherche la valeur de la property dans Solution.xml
# OK=0 si valeur trouvûˋe
#   =1 propriûˋtûˋ non trouvûˋe
#   =2 fichier solution non trouvûˋ
#   =3 pb de lecture sur le fichier
Value Char MODULE  # optional
Value Char FAMILY  # optional
Value Char PROPERTY
Variable Char VPROP
Variable Integer OK

Local Char NOMFIC(200),VALL1(200),ACCESSPATH(200),CHM(50),CLIENTUSE(10)
Local Integer I1,I2,I3
Local Char TYPSGBD,NOMBAS(30),SERVEUR(100),SQLINST(50),ORAPORT
Local Integer TBAS

Raz VPROP
OK=1

Call NAMEFIC(nomap,"SOL","","",NOMFIC) From INTRUTILA
If filinfo(NOMFIC,7)<0 : OK=2 : End : Endif
fstat=0
Openi NOMFIC,0 Using [CST_]
If fstat<>0 : OK=3 : End : Endif
Iomode adxifs ""  Using [CST_]
Iomode adxirs chr$(10)  Using [CST_]
Iomode adxium GUTF8  Using [CST_]
fstat=0
While fstat=0
  Rdseq VALL1 Using [CST_]
  If instr(1,VALL1,"module")
    Local Integer II1,II2
    II1=-1 : II2=-1
    If MODULE<>""
      II1=instr(1,toupper(VALL1),toupper(MODULE))
    Endif
    If FAMILY<>""
      II2=instr(1,toupper(VALL1),toupper(FAMILY))
    Endif
  Endif

  I1=instr(1,toupper(VALL1),toupper(PROPERTY))
  If I1<>0 & II1<>0 & II2<>0
    OK=0
    I2=instr(I1+len(PROPERTY),toupper(VALL1),toupper(PROPERTY))
    If I2<>0     : # Pour traiter les propriûˋtûˋs sous forme <pppp/>
      I1=instr(I1+1,toupper(VALL1),">")
      I2=instr(I1+1,toupper(VALL1),"<")
      VPROP=mid$(VALL1,I1+1,I2-I1-1)
    Endif
    Break 1
  Endif
Wend
Openi Using [CST_]
End


# -------------------------------------------------------------------------------

Subprog RECHPROPOCC(PROPERTY,VPROP,OCC,OK)
# Retrieve the OCC occurence of PROPERTY in Solution.xml and gives its value in VPROP
# OK=0 if value found with the right occurence
#   =1 property not found (or not with the required occurence)
#   =2 file solution.xml not found
#   =3 read error in solution.xml

Value Char PROPERTY
Variable Char VPROP
Value Integer OCC
Variable Integer OK

Local Char NOMFIC(200),VALL1(200),ACCESSPATH(200),CHM(50),CLIENTUSE(10)
Local Integer I1,I2,I3
Local Char TYPSGBD,NOMBAS(30),SERVEUR(100),SQLINST(50),ORAPORT
Local Integer TBAS,TOCC

Raz VPROP
OK=1

Call NAMEFIC(nomap,"SOL","","",NOMFIC) From INTRUTILA
If filinfo(NOMFIC,7)<0 : OK=2 : End : Endif
fstat=0
Openi NOMFIC,0 Using [CST_]
If fstat<>0 : OK=3 : End : Endif
Iomode adxifs ""  Using [CST_]
Iomode adxirs chr$(10)  Using [CST_]
Iomode adxium GUTF8  Using [CST_]
fstat=0
While fstat=0
  Rdseq VALL1 Using [CST_]
  I1=instr(1,toupper(VALL1),toupper(PROPERTY))
  If I1<>0
    TOCC+=1
    If TOCC=OCC or OCC=0
      OK=0
      I2=instr(I1+len(PROPERTY),toupper(VALL1),toupper(PROPERTY))
      If I2<>0     : # Pour traiter les propriûˋtûˋs sous forme <pppp/>
        I1=instr(I1+1,toupper(VALL1),">")
        I2=instr(I1+1,toupper(VALL1),"<")
        VPROP=mid$(VALL1,I1+1,I2-I1-1)
      Endif
      Break 1
    Endif
  Endif
Wend
Openi Using [CST_]
End

