Subprog LISTBRIDGEJ(LSERV,LPORT,LVERS)

# Renvoie le nombre et le nom des bridge Java dûˋfinis pour la solution
Variable Char LSERV()(1..)
Variable Integer LPORT(1..)
Variable Char LVERS()(1..)

Local Integer NBBRIDGE
Raz LSERV,LPORT,LVERS

$SUITBRIDG
Local Char NOMFIC(200),VALL1(200)
Local Integer I1,I2

Raz NBBRIDGE,LSERV,LPORT,LVERS

Call NAMEFIC(nomap,"SOL","","",NOMFIC) From INTRUTILA
If filinfo(NOMFIC,7)<0 :
  If dim(RETACT)>0 : Return : Endif
  End
Endif
fstat=0
Openi NOMFIC,0 Using [CST_]
If fstat<>0 : Goto ERRLEC : Endif
Iomode adxifs ""  Using [CST_]
Iomode adxirs chr$(10)  Using [CST_]
Iomode adxium GUTF8  Using [CST_]
fstat=0
While fstat=0
  Rdseq VALL1 Using [CST_]
  If instr(1,VALL1,'family="SERVERJAVA"')<>0
    NBBRIDGE+=1
    Gosub ADDBRIDGE
  Endif
Wend

Openi Using [CST_]
If dim(RETACT)>0 : Return : Endif
End

$ADDBRIDGE
#  A rechercher
Local Integer NBI
While fstat=0 and NBI<3
  Rdseq VALL1 Using [CST_]
  If instr(1,VALL1,'component.serverjava.servername')<>0
    NBI+=1
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      LSERV(NBBRIDGE)=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif instr(1,VALL1,'component.serverjava.version')<>0
    NBI+=1
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      LPORT(NBBRIDGE)=val(vireblc(mid$(VALL1,I1+1,I2-I1-1),2))
    Endif
  Elsif instr(1,VALL1,'all.host.port')<>0
    NBI+=1
    I1=instr(1,VALL1,">")
    I2=instr(I1+1,VALL1,'<')
    If I2-I1-1>0
      LVERS(NBBRIDGE)=vireblc(mid$(VALL1,I1+1,I2-I1-1),2)
    Endif
  Elsif instr(1,VALL1,'/module>')<>0
    NBI+=3
  Endif
Wend
Return

