Subprog GETHOSTEXA(HOST)
    Variable Char HOST
    Local Char HOSTPROP(80)
    Local Integer CODERET
    HOSTPROP="component.exalead.servername"

    HOST=""
    CODERET=-1
    Call RECHPROP(HOSTPROP,HOST,CODERET) From INTRUTILA
End
