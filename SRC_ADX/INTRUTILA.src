Subprog TRSFDATP(DATE1,TECDAT)
Value Date DATE1
Variable Char TECDAT

ANN=year(DATE1)
MOIS=month(DATE1)
JMOIS=day(DATE1)
NSEM=week(DATE1)
JSEM=dayn(DATE1)
TECDAT=num$(ANN)+"-"+format$("N0:##",MOIS)+"-"+format$("N0:##",JMOIS)+"-"+format$("N0:##",NSEM)+"-"+num$(JSEM)
End

# -------------------------------------------------------------------------------

Subprog CONTDRFEN(DOSS,WIND,AMESS,OK)
Value Char DOSS
Value Char WIND
Variable Char AMESS
Variable Integer OK

#  ContrûÇle si les fichiers FENS,FENW,FENX pour la fenûˆtre WIND
#  du dossier DOSS sont crûˋes avec des droits >= 666 pour chaque langue du dossier
#  OK=1   si tout est correct, 0 sinon

Local Char NAMEF(200)
Local Integer VNUM,BASE,DRWORLD,DRGROUP,DRUSER,I
BASE=32768

Call GLOBWEB(DOSS) From INTRUTILA
For I=1 To GI_NBLAN
  For TYP="FENS","FENW","FENX"
    Call NAMEFIC(DOSS,TYP,GI_LLAN(I),WIND,NAMEF) From INTRUTILA
    VNUM=filinfo(NAMEF,0)
    VNUM-=BASE
    DRWORLD=mod(VNUM,8)
    DRUSER=VNUM/64
    DRGROUP=(VNUM-DRUSER*64)/8
    If DRGROUP<6 or DRUSER<6 or DRWORLD<6
      AMESS=TYP-GI_LLAN(I)-WIND
      OK=0
      End
    Endif
  Next TYP
Next I
OK=1
End

# -------------------------------------------------------------------------------
Subprog CONVDATI(DATEX,HEURX,DATI)
Value Date DATEX
Value Integer HEURX
Variable Char DATI
Local Integer AN,MOIS,JMOIS,HEU,MIN1
AN=year(DATEX)
MOIS=month(DATEX)
JMOIS=day(DATEX)
HEU=HEURX/100
MIN1=HEURX-HEU*100
DATI=num$(AN)+format$("N0:##",MOIS)+format$("N0:##",JMOIS)+format$("N0:##",HEU)+format$("N0:##",MIN1)
End

# -------------------------------------------------------------------------------
Subprog CONVDI(DATEX,DATI)
Value Date DATEX
Variable Char DATI
Local Integer AN,MOIS,JMOIS
AN=year(DATEX)
MOIS=month(DATEX)
JMOIS=day(DATEX)
DATI=num$(AN)+format$("N0:##",MOIS)+format$("N0:##",JMOIS)
End


