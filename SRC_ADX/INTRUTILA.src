Funprog ISBRIDGEJ

# Si il existe au moins un bridge Java dûˋfini dans solution.xml  EXIST=1 sinon EXIST=0
Local Integer NBBRIDGE
Local Char LSERV(100)(1..20)
Local Integer LPORT(1..20)
Local Char LVERS(50)(1..20)
Local Integer EXIST,RETACT

Gosub SUITBRIDG
If NBBRIDGE>=1 : EXIST=1 : Endif
End EXIST

# ---------------------------------------------------------------------------------------

Funprog NBBRIDGEJ
# Nombre de bridges Java dûˋfinis dans solution.xml

Local Integer NBBRIDGE
Local Char LSERV(100)(1..20)
Local Integer LPORT(1..20)
Local Char LVERS(50)(1..20)
Local Integer RETACT
Gosub SUITBRIDG
End NBBRIDGE

# ---------------------------------------------------------------------------------------

Funprog ISSOLB
# Si il existe au moins une solution dûˋfinis dans la table ADOSSOL  EXIST=1 sinon EXIST=0

Local Integer NBSOL
Local Char LSOL(20)(1..100)
Local Char LSERV(100)(1..100)
Local Integer LPORT(1..100)
Local Char LUSER(50)(1..100)
Local Char LPASWD(50)(1..100)
Local Integer EXIST,RETACT
Gosub LISTSOLE
If NBSOL>=1 : EXIST=1 : Endif
End EXIST

# ---------------------------------------------------------------------------------------

Funprog NBSOLB
# Nombre de solutions dûˋfinies dans la table ADOSSOL

Local Integer NBSOL
Local Char LSOL(20)(1..100)
Local Char LSERV(100)(1..100)
Local Integer LPORT(1..100)
Local Char LUSER(50)(1..100)
Local Char LPASWD(50)(1..100)
Local Integer RETACT
Gosub LISTSOLE
End NBSOL

# ---------------------------------------------------------------------------------------

Subprog LISTSOLB(LSOL,LSERV,LPORT,LUSER,LPASWD)

#  Renvoie la liste des solutions liûˋes accessibles via le bridge Java
#  Lorsqu'une solution est dûˋfinie via plusieurs dossiers, ce sont les paramû´tres du premier qui sont utilisûˋs


Variable Char LSOL()(1..)            : # Solution
Variable Char LSERV()(1..)           : # Serveur X3
Variable Integer LPORT(1..)          : # Service
Variable Char LUSER()(1..)           : # User plateforme
Variable Char LPASWD()(1..)          : # Mot de passe plateforme

Local Integer NBSOL              : # Nombre de solutions
Raz LSOL,LSERV,LPORT,LUSER,LPASWD
$LISTSOLE
Local File ADOSSOL [ADD]
For [ADD]
  If !find([F:ADD]LSOL,LSOL(1..NBSOL))
    NBSOL+=1
    LSOL(NBSOL)=[F:ADD]LSOL
    LSERV(NBSOL)=[F:ADD]LMAC
    LPORT(NBSOL)=[F:ADD]LSERV
    LUSER(NBSOL)=[F:ADD]LUSRJAV
    LPASWD(NBSOL)="CRYX3:"+[F:ADD]LPWDJAV
    If NBSOL>=dim(LSERV) : Break 1 : Endif
  Endif
Next
If dim(RETACT)>0 : Return : Endif
End

# ----------------------------------------------------------------------------

Funprog GETBRIDGEJ(IDXBRIDGE,LSERV1,LPORT1,LVERS1)

# Renvoie les paramû´tres du idxiû´me bridge Java dûˋfini dans solution.xml
# Si non trouvûˋ EXIST=0 , sinon EXIST=1

Value Integer IDXBRIDGE        : # Index du bridge (base 1)
Variable Char LSERV1()          : # Hostname du serveur Bridge
Variable Integer LPORT1         : # Servive
Variable Char LVERS1()          : # version du bridge

Raz LSERV1,LPORT1,LVERS1
Local Integer NBBRIDGE
Local Char LSERV(100)(1..20)
Local Integer LPORT(1..20)
Local Char LVERS(50)(1..20)
Local Integer RETACT,EXIST
Gosub SUITBRIDG
 If IDXBRIDGE>0 and IDXBRIDGE<=NBBRIDGE
   EXIST=1
  LSERV1=LSERV(IDXBRIDGE)
  LPORT1=LPORT(IDXBRIDGE)
  LVERS1=LVERS(IDXBRIDGE)
 Else
   EXIST=0
 Endif
End EXIST

# ----------------------------------------------------------------------------

Funprog GETTSOLB(IDXSOL,LSOL1,LSERV1,LPORT1,LUSER1,LPASWD1)

# Renvoie les paramû´tres de la idxiû´me solution dûˋfinie dans ADOSSOL
# Si non trouvûˋ EXIST=0 , sinon EXIST=1


Value Integer IDXSOL            : # Index de la solution (base 1)
Variable Char LSOL1()            : # Solution
Variable Char LSERV1()           : # Hostname du serveur X3
Variable Integer LPORT1          : # Service
Variable Char LUSER1()           : # User plateforme
Variable Char LPASWD1()          : # Mot de passe plateforme

 Raz LSOL1,LSERV1,LPORT1,LUSER1,LPASWD1
Local Integer NBSOL
Local Char LSOL(20)(1..100)
Local Char LSERV(100)(1..100)
Local Integer LPORT(1..100)
Local Char LUSER(50)(1..100)
Local Char LPASWD(50)(1..100)
Local Integer RETACT,EXIST
Gosub LISTSOLE
 If IDXSOL>0 and IDXSOL<=NBSOL
   EXIST=1
  LSOL1=LSOL(IDXSOL)
  LSERV1=LSERV(IDXSOL)
  LPORT1=LPORT(IDXSOL)
  LUSER1=LUSER(IDXSOL)
  LPASWD1=LPASWD(IDXSOL)
 Else
   EXIST=0
 Endif
End EXIST

# --------------------------------------------------------------------------
Subprog GETBOVERSION(BOVALPROP)
Variable Char BOVALPROP
Local Char BOPROP(80)
Local Integer CODERET
BOPROP="busobj.cms.version"

BOVALPROP=""
CODERET=-1
Call RECHPROP(BOPROP,BOVALPROP,CODERET) From INTRUTILA
If(CODERET > 0)
  BOVALPROP="R2"
Endif
End

# --------------------------------------------------------------------------
Subprog GETWSVERSION(WSVERSION)
Variable Char WSVERSION

# Donne la version du serveur Web
# La version est rendue sous la forme SAFE X3 WebServer v1.126
# Pour faciliter les tests on ne conserve que v1.126 qui est renvoyûˋ dans le paramû´tre WSVERSION

WSVERSION=""
If GBROWS=0 : End : Endif
Local Char VALCLI(100)
Getui VALCLI="" With "X3FileVersion"
Local Integer K
K = instr(1,VALCLI,"=")
If K and len(VALCLI)>=K+7
  WSVERSION= right$(VALCLI,len(VALCLI)-5)
Endif

End

