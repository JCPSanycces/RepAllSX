Subprog MENFONOBJ(MENFON,OBJ)
Variable Char MENFON
Value Char OBJ

#   On vûˋrifie si la fonction de nom MENFON est bien affectûˋe û  l'objet OBJ
Local Char OBJ1

If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
Read [AFC]CODINT=MENFON
If fstat<>0 : MENFON="" : End : Endif
If clalev([F:ACT])=0 : Local File ACTION [ACT] : Endif
Read [ACT]ACTION=[F:AFC]ACTION
If fstat<>0 or [F:ACT]TYP<>1: MENFON="" : End : Endif
OBJ1=[F:AFC]VALPAR(0)
#116664,117869
#If len(vireblc(OBJ1,2))=5
# OBJ1=mid$(vireblc(OBJ1,2),2,3)
#Endif
If len(vireblc(OBJ1,2))>2
 OBJ1=mid$(vireblc(OBJ1,2),2,len(OBJ1)-2)
Endif
If OBJ<>OBJ1 : MENFON="" : Endif

End

# -------------------------------------------------------------------------------
Subprog MENFONCNS(MENFON,CNS)
Variable Char MENFON
Value Char CNS

#   On vûˋrifie si la fonction de nom MENFON est bien affectûˋe û  la consultation CNS
Local Char CNS1

If clalev([F:AFC])=0 : Local File AFONCTION [AFC] : Endif
Read [AFC]CODINT=MENFON
If fstat<>0 : MENFON="" : End : Endif
If clalev([F:ACT])=0 : Local File ACTION [ACT] : Endif
Read [ACT]ACTION=[F:AFC]ACTION
If fstat<>0 or [F:ACT]TYP<>2: MENFON="" : End : Endif
CNS1=[F:ACT]PARAM1
If CNS1<>"" and CNS1<>CNS : MENFON="" : Endif

End

