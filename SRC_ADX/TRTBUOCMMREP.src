#<AdxTL>@(#)1.0.0.0 $Revision$
#------------------------------------------------------------------------------------------
#                       Clôture Budgétaire des budgets opérationnels
#------------------------------------------------------------------------------------------
#  Fonction : BUOCMMREP - Report de pré-engagements et engagements non soldés
#  Action   : BUOCMMREP
#  Fenêtre/Window  : BUOCMMREP
#  Ecran concerné/Mask : BUOCMMREP [M:BCR]
#  Description :
#  *1-Report -> Aprés cloture des DA et Commande, report des pré-engagement et engagements
#------------------------------------------------------------------------------------------

Call TRAITE_CHAR(VALEUR,PARAM,"","BUOCMMREP","TRTBUOCMMREP",4,"") From GTRAITE
End

$ACTION
Case ACTION
 When "AVANT_PAR"   : Gosub AVANT_PAR
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1 : GOK = 0
Endcase
Return

$AVANT_PAR
Raz [M:BCR]
Return

$INIT
# Tables utiles
If !clalev([BUA])  : Local File BUDPURAUD  [BUA]  : Endif
If !clalev([BUP])  : Local File BUDPAR     [BUP]  : Endif
If !clalev([BUT])  : Local File BUDTYP     [BUT]  : Endif
If !clalev([ENV])  : Local File ENVELOPPE  [ENV]  : Endif
If !clalev([ENV2]) : Local File ENVELOPPE  [ENV2] : Endif
If !clalev([ENV3]) : Local File ENVELOPPE  [ENV3] : Endif
If !clalev([ENF])  : Local File ENVFIY     [ENF]  : Endif
If !clalev([ENF2]) : Local File ENVFIY     [ENF2] : Endif
If !clalev([ENF3]) : Local File ENVFIY     [ENF3] : Endif
If !clalev([BUD])  : Local File BUD        [BUD]  : Endif
If !clalev([BUD2]) : Local File BUD        [BUD2] : Endif
If !clalev([BUD3]) : Local File BUD        [BUD3] : Endif
If !clalev([CCE])  : Local File CACCE      [CCE]  : Endif
If !clalev([CMM])  : Local File GCOMMIT    [CMM]  : Endif
If !clalev([CMD])  : Local File GCOMMITD   [CMD]  : Endif
If !clalev([GCM])  : Local File GACM       [GCM]  : Endif
If !clalev([LED])  : Local File GLED       [LED]  : Endif
If !clalev([CPY])  : Local File COMPANY    [CPY]  : Endif
If !clalev([FCY])  : Local File FACILITY   [FCY]  : Endif
If !clalev([FIY])  : Local File FISCALYEAR [FIY]  : Endif
If !clalev([FIY2]) : Local File FISCALYEAR [FIY2] : Endif

# Achats
If !clalev([PIH]) : Local File PINVOICE   [PIH] : Endif
If !clalev([PID]) : Local File PINVOICED  [PID] : Endif
If !clalev([PSH]) : Local File PREQUIS    [PSH] : Endif
If !clalev([PSD]) : Local File PREQUISD   [PSD] : Endif
If !clalev([POH]) : Local File PORDER     [POH] : Endif
If !clalev([POP]) : Local File PORDERP    [POP] : Endif
If !clalev([POQ]) : Local File PORDERQ    [POQ] : Endif
If !clalev([CAL]) : Local File CPTANALIN  [CAL] : Endif

# Masque
Local Mask BUOCMMREP [BCR]

# Variables Locales
Local Char CRITBUA(250), CRITLIG(250), MESSA(250)
Local Char SITE(GLONFCY), NUMENV(GLONENV), ENV_RECEP(GLONENV), TABLE(GLONABR)
Local Decimal EXERCICE,PERIODE
Local Integer I, J, STAT, INDAXENT, INDAXENV, INDAX3, OK
I=0

# Pour le Call MAJENG()
Local Char CODLED, DEVLED
Local Char DOCUMENT(GLONVCR)(1..4)  #18 (1)n° de la pièce d'origine (2)n° de ligne de la pièce d'origine (3)n° de séquence pour les commandes
Local Libelle MOTIF(1..2)       #19 (1)Motif Action AML-2683  (2) Motif Pièce AML-2684
Local Char PIECE
Local Char IDENT(GLONVCR)(1..3)
Local Integer SENS, SIGN
Local Char    COMPTE
Local Char    TIERS
Local Char    TYPPCE
Local Integer TYPORG
Local Char    NUMPCE
Local Integer TYPCUR
Local Char TBACC(GLONGAC)(1..10)
Local Char TBLED(GLONLED)(1..10)
Local Decimal RATDIV(1..10) : RATDIV(1)=0
Local Decimal RATMLT(1..10) : RATMLT(1)=0
Local Char TBDIE(GLONDIE)(1..func AFNC.ACTIV("ANA"))
Local Char TBCCE(GLONCCE)(1..func AFNC.ACTIV("ANA"))
Local Integer NBTB : NBTB=0
Local Integer CONTBUD : CONTBUD=0
Local Char    SAVTEX(50)
Local Integer INDENV, INDENT, INDCCE3
Return


$CONTROLE
TMP=1
Return

$EXEC
# Trace/Tracking
If [M]TRC=2
 Local Integer TRCREP
 TRCREP=0
 # Report des pré-engagements et engagements non soldés
 Call OUVRE_TRACE(mess(210,107,1)) From LECFIC
 Call ECR_TRACE(string$(len(mess(210,107,1)),"-"),0) From  GESECRAN
 Call ECR_TRACE(mess(210,107,1),0) From  GESECRAN
 Call ECR_TRACE(string$(len(mess(210,107,1)),"-"),0) From  GESECRAN
Endif

Gosub LOAD_FILTRE
Gosub DECLARE_GLOBAL From SUBCMM

# Report des budgets
For I=0 To [M]NBLIG-1
 If [M]REPOR(I)=2
  Call DEBTRANS From GLOCK
  Gosub REPORTCMM
 Endif
Next

If [M]TRC=2
 If !TRCREP
  # Rien n'a été reporté
  Call ECR_TRACE(mess(205,108,1),1) From GESECRAN
 Endif
 Call ECR_TRACE("---------------------------------------------",0) From GESECRAN
Endif
Return

$LOAD_FILTRE
#--------- Critère sur table d'audit ---------#
CRITBUA ='CPY="'+[M]CPY+'" & FIY='+num$([M]EFIY)
CRITBUA -= '& (CMMPRP>0 | CMM>0) & BUD<>""'
#
If [M]FCYSTR<>""
CRITBUA -='& FCY>="'+[M]FCYSTR+'" & FCY<="'+[M]FCYEND+'"'
Endif
#
Case [M]TYPDOC
 When 2 : CRITBUA -= '& TYP=1'
 When 3 : CRITBUA -= '& TYP=2'
Endcase
Return

$REPORTCMM
GOK=1
Trbegin [ENV],[ENV2],[ENV3],[ENF],[ENF2],[ENF3],[BUD],[BUD2],[BUD3],[CCE],[CAL],[BUA]

If [M]TRC=2
 Call ECR_TRACE("",0) From  GESECRAN
 Call ECR_TRACE(mess([M]TYP(I),2684,1)-":"-[M]NUM(I),0) From GESECRAN
 Call ECR_TRACE(mess(50,104,1)-"=>"-num$([M]AMTREPLED(I)),0) From GESECRAN
 Call ECR_TRACE(string$(40,"-"),0) From  GESECRAN
Endif

# --- Affectation des variable pour les Call MAJENG(...) From CPTENG --- #
Call LECLED([M]CPY,[M]LEDTYP(I),CODLED,DEVLED) From CPTDIV
DOCUMENT(1)=[M]NUM(I)
DOCUMENT(2)=num$([M]LIN(I))
DOCUMENT(3)=num$([M]SEQ(I))
DOCUMENT(4)=num$([M]ANALIN(I))
COMPTE = [M]ACC(I)
#PIECE = [M]CODGAU(I)
For J=1 To 3
 IDENT(J) = DOCUMENT(J)
Next
Call LECTURE("CMM",[M]CMM(I),"") From CONTOBJ
SENS   = [F:CMM]SNS
TIERS  = [F:CMM]BPR
TYPPCE = [F:CMM]TYPREF
TYPORG = [F:CMM]TYPORG
NUMPCE = [F:CMM]NUMREF
TYPCUR = [F:CMM]TYPCUR


Read [BUA]BUA1 = [M]BUANUM(I)
If !fstat
 For J=1 To min(dim([F:BUA]CCE),GOPTCANA)
  [L]TBDIE(J)=[F:BUA]DIE(J-1)
  [L]TBCCE(J)=[F:BUA]CCE(J-1)
 Next
 For J=1 To dim([F:BUA]ACC)
  [L]TBLED(J)=[F:BUA]LED(J-1)
  [L]TBACC(J)=[F:BUA]ACC(J-1)
 Next
Endif

Call LECTURE("ENV",[M]ENV(I),"") From CONTOBJ
Call LECTURE("BUP",[F:ENV]BUD,"") From CONTOBJ
If [F:BUP]LEV=1
 SITE=""
Else
 SITE=[M]FCY(I)
Endif
Call LECTURE("BUT",[F:ENV]BUDTYP,"") From CONTOBJ

###-----------------------------------------------------------
###---DANS L’EXERCICE ÉMETTEUR :
###-----------------------------------------------------------

##--DÉDUCTION DU MONTANT REPORTÉ :
#-* DU MONTANT ENGAGÉ DE LA LB (AMTCMM0) OU DU MONTANT PRÉ-ENGAGÉ DE LA LB (AMTCMMPRP0)

##--DANS L’ENGAGEMENT OU LE PRÉ-ENGAGEMENT :
#-* CRÉATION D’UNE LIGNE DE SOLDE SUR L’EXERCICE EN COURS DE CLÔTURE
#-* MAJ DE LA TABLE D'AUDIT

## ! NB:  Tout cela est fait par le Call MAJENG() From CPTENG !


MOTIF(2)=6 : # Report
MOTIF(1)=4  : #Solde (/Report)
SIGN=-1
Call MAJENG([M]DAT(I),[M]FCY(I),[M]CUR(I),[M]AMTREP(I),RATDIV,RATMLT,[M]QTY(I),TBACC,TBLED,TIERS
&                 ,TBDIE,TBCCE,SENS,SIGN,[M]CMMTYP(I),CONTBUD,[M]CMM(I),DOCUMENT,MOTIF,OK,MESSA
&                 ,PIECE,IDENT,TYPPCE,NUMPCE,TYPORG,TYPCUR) From CPTENG
If !OK
 Call MESSAGE(MESSA) From GESECRAN
 GOK=0
Endif

###-----------------------------------------------------------
###---DANS L’EXERCICE ÉMETTEUR :
###-----------------------------------------------------------

##--DÉDUCTION DU MONTANT REPORTÉ :
#-* DU MONTANT BUDGÉTÉ DANS LA LIGNE BUDGÉTAIRE (AMT0) DANS LE BUDGET DE L’EXERCICE (AMTBUDFIY) DANS L’ENVELOPPE (AMTENV).

#--- Enveloppe
Readlock [ENV]ENV0 = [M]ENV(I)
If !fstat
 If [F:BUT]YEAFLG=1 :#Dans l'enveloppe, que si enveloppe Annuelle
  [F:ENV]AMTENV -= [M]AMTREPLED(I)
  Rewrite [ENV]
  If fstat : GOK=0 : Call FSTA("ENV") From GLOCK : Goto AB_TR : Endif
  If [M]TRC=2
   TRCREP+=1
   # Mise à jour de l'enveloppe
   Call ECR_TRACE(mess(200,108,1)-":"-[F:ENV]ENV,0) From GESECRAN
  Endif
 Endif
Elsif fstat=1
 GOK=-1 : GLOCK="$ENV"-[F:ENV]ENV : Goto ROLL_TR
Else
 GOK=0 : Call FSTA("ENV") From GLOCK : Goto AB_TR
Endif

#--- Budget exercice
Readlock [ENF]ENF0=[M]ENV(I);[M]FIY(I)
If !fstat
 [F:ENF]AMTBUDFIY -= [M]AMTREPLED(I)
 Rewrite [ENF]
 If fstat: GOK=0 : Call FSTA("ENF") From GLOCK : Goto AB_TR : Endif
 If [M]TRC=2
  TRCREP+=1
  # Mise à jour du budget exercice
  Call ECR_TRACE(mess(197,108,1)-":"-[F:ENF]ENV-"/"-num$([F:ENF]FIYNUM),0) From GESECRAN
 Endif
Elsif fstat=1
 GOK=-1 : GLOCK="$ENF"-[F:ENF]ENV-num$([F:ENF]FIYNUM) : Goto ROLL_TR
Else
 GOK=0 : Call FSTA("ENF") From GLOCK : Goto AB_TR
Endif

#--- Ligne budgétaire
#Si paramétrage budget niveau société le champ site doit être vide
If [F:BUP]LEV=1
 SITE=""
Else
 SITE=[M]FCY(I)
Endif
Raz SAVTEX

#LEDTYP+BUD+CPY+FCY+FIY+VER+ACC+CCE1+CCE2+CCE3
Call LEC_BUP([F:ENV]BUD) From CPTLEC
Call GETGDDINDDIE([F:ENV]SOCIETE,[F:BUP]DIE(2),INDENV,INDENT,INDCCE3) From TRTGDD
If INDCCE3>0
 Filter [BUD] Where LEDTYP=[M]LEDTYP(I) & BUD=[M]BUD(I) & CPY=[M]CPY & FCY=SITE & FIY=[M]FIY(I) & VER="1" & ACC=[M]ACC(I)
&& evalue('CCE'+num$(INDENV))=[M]ENV(I) & evalue('CCE'+num$(INDENT))=[M]ENT(I) & evalue('CCE'+num$(INDCCE3))=[M]CCE3(I)
Else
 Filter [BUD] Where LEDTYP=[M]LEDTYP(I) & BUD=[M]BUD(I) & CPY=[M]CPY & FCY=SITE & FIY=[M]FIY(I) & VER="1" & ACC=[M]ACC(I)
&& evalue('CCE'+num$(INDENV))=[M]ENV(I) & evalue('CCE'+num$(INDENT))=[M]ENT(I)
Endif
Readlock [BUD] First

If !fstat
 [F:BUD]AMT(0) -= [M]AMTREPLED(I)
 If [F:BUD]AMTCMM=0 & [F:BUD]AMTCMMPRP=0
  [F:BUD]STA = 5
 Endif
 Rewrite [BUD]
 If fstat: GOK=0 : Call FSTA("BUD") From GLOCK : Goto AB_TR : Endif
 If [M]TRC=2
  TRCREP+=1
  # Mise à jour de la ligne
  Call ECR_TRACE(mess(195,108,1)-":"-evalue('[F:BUD]CCE'+num$(INDENV))-"/"-evalue('[F:BUD]CCE'+num$(INDENT))
&                -"/"-num$([F:BUD]FIY)-"/"-[F:BUD]ACC,0) From GESECRAN
 Endif
 SAVTEX = [F:BUD]TEX
Elsif fstat=1
 GOK=-1 : GLOCK="$BUD"-num$([F:BUD]ACCNUM) : Goto ROLL_TR
Else
 GOK=0 : Call FSTA("BUD") From GLOCK : Goto AB_TR
Endif

Filter [BUD]


###-----------------------------------------------------------
###--- DANS L’EXERCICE RÉCEPTEUR :
###-----------------------------------------------------------

 ##--SI LA LIGNE BUDGÉTAIRE, LE BUDGET OU L’ENVELOPPE N’EXISTENT PAS :
 #-* CRÉATION DE LA LB DU BUDGET PAR EXERCICE OU DE L’ENVELOPPE

 ##--SI LES ÉLÉMENTS BUDGÉTAIRES EXISTENT OU VIENNENT D’ÊTRE CRÉÉS, AJOUT DU MONTANT REPORTÉ :
 #-* AU MONTANT BUDGÉTÉ DE LA LIGNE BUDGÉTAIRE (AMT0) DANS LE BUDGET DE L’EXERCICE (AMTBUDFIY) DANS L’ENVELOPPE (AMTENV).

# Check the validity date of the budget account/  Recipient entity /dimension
Call CTL_DAT([M]ACC(I),[M]COA,[M]AXEENT(I),[M]ENT(I),[M]DIE3(I),[M]CCE3(I),
&            [M]TRC,[M]ENV(I),[M]DRFIY,[M]FRFIY,OK) From TRTBUOREC
If OK=0 : GOK=0 : Goto AB_TR : Endif
# Check the validity dates of entity/budget/project
Call CTL_DAT2([F:ENV]ENTMNA,[F:ENV]ENTAPP,[F:ENV]ENTRAT,[F:ENV]BUD,[F:ENV]PRJ,
&             [M]TRC,[F:ENV]ENV,[M]DRFIY,[M]FRFIY,OK) From TRTBUOREC
If OK=0 : GOK = 0 : Goto AB_TR : Endif

If [F:BUT]YEAFLG=1 :#Annuelle
 Filter [ENV2] Where ENVORG=[M]ENV(I)
 Readlock [ENV2]ENV0 First
 If !fstat
  #L'enveloppe existe
  ENV_RECEP=[F:ENV2]ENV

  [F:ENV2]AMTENV += [M]AMTREPLED(I)
  [F:ENV2]UPDDAT = date$
  [F:ENV2]UPDUSR = GUSER
  Rewrite [ENV2]
  If fstat: GOK=0 : Call FSTA("ENV2") From GLOCK : Goto AB_TR : Endif
  If [M]TRC=2 : TRCREP+=1
   # Mise à jour de l'enveloppe
   Call ECR_TRACE(mess(200,108,1)-":"-[F:ENV2]ENV,0) From GESECRAN
  Endif
  #Donc le budget exercice aussi à priori
  Read [ENF2]ENF0 = [F:ENV2]ENV;[M]FIY(I)+1
  [F:ENF2]AMTBUDFIY += [M]AMTREPLED(I)
  Rewrite [ENF2]
  If fstat: GOK=0 : Call FSTA("ENF2") From GLOCK : Goto AB_TR : Endif
  If [M]TRC=2 : TRCREP+=1
   # Mise à jour du budget exercice
   Call ECR_TRACE(mess(197,108,1)-":"-[F:ENF2]ENV-"/"-num$([F:ENF2]FIYNUM),0) From GESECRAN
  Endif

  Call LEC_BUP([F:ENV2]BUD) From CPTLEC
  Call GETGDDINDDIE([F:ENV2]SOCIETE,[F:BUP]DIE(2),INDENV,INDENT,INDCCE3) From TRTGDD

  #La ligne
  CRITLIG  = 'BUD="'+[M]BUD(I)+'" & LEDTYP='+num$([M]LEDTYP(I))+' & CPY="'+[M]CPY+'"'
  CRITLIG -= '& ACC="'+[M]ACC(I)+'" & CCE'+num$(INDENT)+'="'+[M]ENT(I)+'" & CCE'+num$(INDENV)+'="'+[F:ENV2]ENV+'"'
  CRITLIG -= '& FIY='+num$([M]FIY(I)+1)-'& FCY="'+SITE+'"'
  Filter [BUD2] Where evalue(CRITLIG)
  Readlock [BUD2] First
  If !fstat
   # La ligne existe
   # Si la ligne est de statut saisie ou à approuver, on refuse le report
   If [F:BUD2]STA<3
    If [M]TRC=2 : TRCREP+=1
     # Report impossible : Ligne budgétaire non approuvée
     Call ECR_TRACE(string$(50,"!"),0) From GESECRAN
     Call ECR_TRACE(mess(254,108,1)-"["-evalue('[F:BUD2]CCE'+num$(INDENV))-"/"-evalue('[F:BUD2]CCE'+num$(INDENT))
&                   -"/"-num$([F:BUD2]FIY)-"/"-[F:BUD2]ACC-"]",0) From GESECRAN
     Call ECR_TRACE(string$(50,"!"),0) From GESECRAN
    Endif
    GOK=0 : Goto AB_TR
   Endif
   [F:BUD2]AMT(0) += [M]AMTREPLED(I)
   [F:BUD2]AMTAPP += [M]AMTREPLED(I)
   Rewrite [BUD2]
   If fstat: GOK=0 : Call FSTA("BUD2") From GLOCK : Goto AB_TR : Endif
   If [M]TRC=2 : TRCREP+=1
    # Mise à jour de la ligne
    Call ECR_TRACE(mess(195,108,1)-":"-evalue('[F:BUD2]CCE'+num$(INDENV))-"/"-evalue('[F:BUD2]CCE'+num$(INDENT))
&                  -"/"-num$([F:BUD2]FIY)-"/"-[F:BUD2]ACC,0) From GESECRAN
   Endif
  Elsif fstat=1
   GOK=-1 : GLOCK="$BUD"-num$([F:BUD2]ACCNUM) : Goto ROLL_TR
  Else
   # Si la ligne n'existe pas
   Raz [BUD3]
   [F:BUD3]BUD    = [M]BUD(I)
   [F:BUD3]LEDTYP = [M]LEDTYP(I)
   [F:BUD3]FIY    = [M]FIY(I)+1
   [F:BUD3]CPY    = [M]CPY
   [F:BUD3]FCY    = SITE
   [F:BUD3]VER    = "1"
   [F:BUD3]COA    = [M]COA
   [F:BUD3]ACC    = [M]ACC(I)
   Assign '[F:BUD3]DIE'+num$(INDENT) With [M]AXEENT(I)
   Assign '[F:BUD3]DIE'+num$(INDENV) With [M]AXEENV(I)
   Assign '[F:BUD3]CCE'+num$(INDENT) With [M]ENT(I)
   Assign '[F:BUD3]CCE'+num$(INDENV) With [F:ENV2]ENV
   If INDCCE3>0
    Assign '[F:BUD3]DIE'+num$(INDCCE3) With [M]DIE3(I)
    Assign '[F:BUD3]CCE'+num$(INDCCE3) With [M]CCE3(I)
   Endif
   [F:BUD3]CUR    = [M]CURLED(I)
   [F:BUD3]AMT(0) = [M]AMTREPLED(I)
   [F:BUD3]STA    = 3
   [F:BUD3]AMTAPP = [M]AMTREPLED(I)
   [F:BUD3]APPDAT = date$
   [F:BUD3]ACCNUM = uniqid([F:BUD3])
   [F:BUD3]TEX    = SAVTEX
   Write [BUD3]
   If fstat: GOK=0 : Call FSTA("BUD3") From GLOCK : Goto AB_TR : Endif
   If [M]TRC=2 : TRCREP+=1
    ##Création de la ligne
    Call ECR_TRACE(mess(196,108,1)-":"-evalue('[F:BUD3]CCE'+num$(INDENV))-"/"-evalue('[F:BUD3]CCE'+num$(INDENT))
&                  -"/"-num$([F:BUD3]FIY)-"/"-[F:BUD3]ACC,0) From GESECRAN
   Endif
  Endif:#Readlock [BUD2] First
  Filter [BUD2]

 Elsif fstat=1 :#Readlock [ENV2]

  GOK=-1 : GLOCK="$ENV2"-[F:ENV2]ENV : Goto ROLL_TR

 Else :#Readlock [ENV2]
  #L'enveloppe n'existe pas il faut la créer

  #--- Nouveau numéro d'enveloppe
  If NUMENV=""
   If [F:BUT]MANCOU<>2
    Call NUMERO([F:BUT]COU,[F:BUD]FCY,[M]DRFIY,"",[L]NUMENV,STAT) From SUBANM
   Else
    If len([F:ENV]ENV+"_R"+num$([M]RFIY))>GLONENV
     Local Integer DIFLEN
     DIFLEN=len([F:ENV]ENV+"_R"+num$([M]RFIY))-GLONENV
     NUMENV=left$([F:ENV]ENV,len([F:ENV]ENV)-DIFLEN)+"_R"+num$([M]RFIY)
    Else
     NUMENV=[F:ENV]ENV+"_R"+num$([M]RFIY)
    Endif
   Endif
  Endif

  #Numéro de l'enveloppe de reception
  ENV_RECEP=NUMENV

  Raz [F:ENV3]
  # Creation de l'enveloppe
  [F:ENV3] = [F:ENV]
  Raz [F:ENV3]AMTAPP
  Raz [F:ENV3]REVDAT
  Raz [F:ENV3]APPDAT
  Raz [F:ENV3]DRECOND
  Raz [F:ENV3]UPDUSR
  Raz [F:ENV3]UPDDAT
  Raz [F:ENV3]UPDTIM
  Raz [F:ENV3]ENVRCD
  Raz [F:ENV3]CRETIM
  [F:ENV3]ENVORG = [M]ENV(I)
  [F:ENV3]ENV    = NUMENV
  [F:ENV3]REASTR = [M]DRFIY
  [F:ENV3]REAEND = [M]FRFIY
  [F:ENV3]AMTENV = [M]AMTREPLED(I)
  [F:ENV3]AMTRES = 0
  [F:ENV3]STA    = 1
  [F:ENV3]CREUSR = GUSER
  [F:ENV3]CREDAT = date$
  Write [ENV3]
  If fstat: GOK=0 : Call FSTA("ENV3") From GLOCK : Goto AB_TR : Endif
  Call DUPTEXTRA("ENVELOPPE","DESTRA",[F:ENV]ENV,"","ENVELOPPE","DESTRA",[F:ENV3]ENV,"")  From ATEXTRA
  Call DUPTEXTRA("ENVELOPPE","SHOTRA",[F:ENV]ENV,"","ENVELOPPE","SHOTRA",[F:ENV3]ENV,"")  From ATEXTRA

  If [M]TRC=2 : TRCREP+=1
   #--- Création de l'enveloppe
   Call ECR_TRACE(mess(201,108,1)-":"-[F:ENV3]ENV,0) From  GESECRAN
  Endif

  #--- ,  de la section
  If [F:BUP]DIE(1)<>""
   GOK = 1
   Raz [F:CCE]
   [F:CCE]DIE    = [F:BUP]DIE(1)
   [F:CCE]CCE    = NUMENV
   [F:CCE]ENAFLG = 2
   [F:CCE]ACS    = [F:ENV]ACS
   [F:CCE]VLYSTR = [M]DRFIY
   [F:CCE]VLYEND = [M]FRFIY
   [F:CCE]FCY    = [F:ENV]FCY
   [F:CCE]BUDTRK = 2
   [F:CCE]IPT    = 2
   Write [CCE]
   If fstat : GOK = 0 : Call FSTA("CCE") From GLOCK : Goto AB_TR : Endif
   Call DUPTEXTRA("ENVELOPPE","DESTRA",[F:ENV]ENV,"","CACCE","DESTRA",[F:BUP]DIE(1),NUMENV)  From ATEXTRA
   Call DUPTEXTRA("ENVELOPPE","SHOTRA",[F:ENV]ENV,"","CACCE","SHOTRA",[F:BUP]DIE(1),NUMENV)  From ATEXTRA
  Endif

  #--- ainsi que du Budget exercice
  Raz [F:ENF3]
  [F:ENF3]ENV = NUMENV
  [F:ENF3]AMTBUDFIY = [M]AMTREPLED(I)
  [F:ENF3]AMTRESFIY = 0
  [F:ENF3]FIYNUM = [M]RFIY
  [F:ENF3]FIYSTR = [M]DRFIY
  [F:ENF3]FIYEND = [M]FRFIY
  [F:ENF3]STAFIY = 1
  Write [ENF3]
  If fstat: GOK=0 : Call FSTA("ENF3") From GLOCK : Goto AB_TR : Endif
  If [M]TRC=2 : TRCREP+=1
   #Création du budget exercice
   Call ECR_TRACE(mess(198,108,1)-":"-[F:ENF3]ENV-"/"-num$([F:ENF3]FIYNUM),0) From GESECRAN
  Endif

  #--- et enfin  de la ligne
  Raz [F:BUD3]
  [F:BUD3]BUD    = [M]BUD(I)
  [F:BUD3]LEDTYP = [M]LEDTYP(I)
  [F:BUD3]FIY    = [M]RFIY
  [F:BUD3]CPY    = [M]CPY
  [F:BUD3]FCY    = SITE
  [F:BUD3]VER    = "1"
  [F:BUD3]COA    = [M]COA
  [F:BUD3]ACC    = [M]ACC(I)
  Assign '[F:BUD3]DIE'+num$(INDENT) With [M]AXEENT(I)
  Assign '[F:BUD3]DIE'+num$(INDENV) With [M]AXEENV(I)
  Assign '[F:BUD3]CCE'+num$(INDENT) With [M]ENT(I)
  Assign '[F:BUD3]CCE'+num$(INDENV) With NUMENV
  If INDCCE3>0
   Assign '[F:BUD3]DIE'+num$(INDCCE3) With [M]DIE3(I)
   Assign '[F:BUD3]CCE'+num$(INDCCE3) With [M]CCE3(I)
  Endif
  [F:BUD3]CUR    = [M]CURLED(I)
  [F:BUD3]AMT(0) = [M]AMTREPLED(I)
  [F:BUD3]STA    = 3
  [F:BUD3]AMTAPP = [M]AMTREPLED(I)
  [F:BUD3]APPDAT = date$
  [F:BUD3]ACCNUM = uniqid([F:BUD3])
  [F:BUD3]TEX    = SAVTEX
  Write [BUD3]
  If fstat: GOK=0 : Call FSTA("BUD3") From GLOCK : Goto AB_TR : Endif
  If [M]TRC=2 : TRCREP+=1
   ##Création de la ligne
   Call ECR_TRACE(mess(196,108,1)-":"-evalue('[F:BUD3]CCE'+num$(INDENV))-"/"-evalue('[F:BUD3]CCE'+num$(INDENT))
&                 -"/"-num$([F:BUD3]FIY)-"/"-[F:BUD3]ACC,0) From GESECRAN
  Endif

  #Mise à jour de l'enveloppe d'origine avec la date de reconduction
  Readlock [ENV]ENV0 = [M]ENV(I)
  If !fstat
   [F:ENV]TYPREC = 2
   [F:ENV]ENVRCD = NUMENV
   [F:ENV]DRECOND = date$
   Rewrite [ENV]
   If fstat : GOK=0 : Call FSTA("ENV") From GLOCK : Goto AB_TR : Endif
   If [M]TRC=2
    TRCREP+=1
    # Mise à jour de l'enveloppe
    Call ECR_TRACE(mess(200,108,1)-":"-[F:ENV]ENV,0) From GESECRAN
   Endif
  Elsif fstat=1
   GOK=-1 : GLOCK="$ENV"-[F:ENV]ENV : Goto ROLL_TR
  Else
   GOK=0 : Call FSTA("ENV") From GLOCK : Goto AB_TR
  Endif

 Endif :#Read [ENV2]
 Filter [ENV2]

Else :# pluri-annuelle

 #Numéro de l'enveloppe de reception
 ENV_RECEP=[F:ENV]ENV

 If [F:ENV]REAEND<=[M]DRFIY
  #Si l'enveloppe n'est pas définie jusqu'à la fin de l'exercice suivant
  # il faut la prolonger...

  [F:ENV]REAEND = [M]FRFIY
  #81779 : une enveloppe pluri annu ne doit pas voir son montant augmenter!  [F:ENV]AMTENV += [M]AMTREPLED(I)
  Rewrite [ENV]
  If fstat: GOK=0 : Call FSTA("ENV") From GLOCK : Goto AB_TR : Endif
  If [M]TRC=2
   TRCREP+=1
   # Mise à jour de l'enveloppe
   Call ECR_TRACE(mess(200,108,1)-":"-[F:ENV]ENV,0) From GESECRAN
  Endif
  #...et créer le budget exercice correspondant
  Raz [ENF3]
  [F:ENF3]ENV = [F:ENV]ENV
  [F:ENF3]AMTBUDFIY = [M]AMTREPLED(I)
  [F:ENF3]AMTRESFIY = 0
  [F:ENF3]FIYNUM = [M]RFIY
  [F:ENF3]FIYSTR = [M]DRFIY
  [F:ENF3]FIYEND = [M]FRFIY
  [F:ENF3]STAFIY = 1
  Write [ENF3]
  If fstat: GOK=0 : Call FSTA("ENF3") From GLOCK : Goto AB_TR : Endif
  If [M]TRC=2 : TRCREP+=1
   # Création du budget exercice
   Call ECR_TRACE(mess(198,108,1)-":"-[F:ENF3]ENV-"/"-num$([F:ENF3]FIYNUM),0) From GESECRAN
  Endif
 Else
  # L'enveloppe est bien définie sur l'exercice recepteur & donc le budget exercice existe
  Read [ENF]ENF0 = [F:ENV]ENV;[M]RFIY
  If !fstat
   [F:ENF]AMTBUDFIY += [M]AMTREPLED(I)
   Rewrite [ENF]
   If fstat: GOK=0 : Call FSTA("ENF") From GLOCK : Goto AB_TR : Endif
   If [M]TRC=2 : TRCREP+=1
    # Mise à jour du budget exercice
    Call ECR_TRACE(mess(197,108,1)-":"-[F:ENF]ENV-"/"-num$([F:ENF]FIYNUM),0) From GESECRAN
   Endif
  Endif
 Endif

 # La ligne
 CRITLIG  = 'BUD="'+[M]BUD(I)+'" & LEDTYP='+num$([M]LEDTYP(I))+' & CPY="'+[M]CPY+'"'
 CRITLIG -= '& ACC="'+[M]ACC(I)+'" & CCE'+num$(INDENT)+'="'+[M]ENT(I)+'" & CCE'+num$(INDENV)+'="'+[F:ENV]ENV+'"'
 CRITLIG -= '& FIY='+num$([M]RFIY)-'& FCY="'+SITE+'"'
 Filter [BUD2] Where evalue(CRITLIG)
 Readlock [BUD2] First
 If !fstat
  # La ligne existe
  # Si la ligne est de statut saisie ou à approuver, on refuse le report
  If [F:BUD2]STA<3
   If [M]TRC=2 : TRCREP+=1
    # Ligne budgétaire non approuvée
    Call ECR_TRACE(string$(50,"!"),0) From GESECRAN
    Call ECR_TRACE(mess(254,108,1)-"["-evalue('[F:BUD2]CCE'+num$(INDENV))-"/"-evalue('[F:BUD2]CCE'+num$(INDENT))
&                  -"/"-num$([F:BUD2]FIY)-"/"-[F:BUD2]ACC-"]",0) From GESECRAN
    Call ECR_TRACE(string$(50,"!"),0) From GESECRAN
   Endif
   GOK=0 : Goto AB_TR
  Endif
  [F:BUD2]AMT(0) += [M]AMTREPLED(I)
  [F:BUD2]AMTAPP += [M]AMTREPLED(I)
  Rewrite [BUD2]
  If fstat: GOK=0 : Call FSTA("BUD2") From GLOCK : Goto AB_TR : Endif
  If [M]TRC=2 : TRCREP+=1
   # Mise à jour de la ligne
   Call ECR_TRACE(mess(195,108,1)-":"-evalue('[F:BUD2]CCE'+num$(INDENV))-"/"-evalue('[F:BUD2]CCE'+num$(INDENT))
&                 -"/"-num$([F:BUD2]FIY)-"/"-[F:BUD2]ACC,0) From GESECRAN
  Endif
 Elsif fstat=1
  GOK=-1 : GLOCK="$BUD2"-num$([F:BUD2]ACCNUM) : Goto ROLL_TR
 Else
  # Si la ligne n'existe pas
  Raz [BUD3]
  [F:BUD3]BUD    = [M]BUD(I)
  [F:BUD3]LEDTYP = [M]LEDTYP(I)
  [F:BUD3]FIY    = [M]FIY(I)+1
  [F:BUD3]CPY    = [M]CPY
  [F:BUD3]FCY    = SITE
  [F:BUD3]VER    = "1"
  [F:BUD3]COA    = [M]COA
  [F:BUD3]ACC    = [M]ACC(I)
  Assign '[F:BUD3]DIE'+num$(INDENT) With [M]AXEENT(I)
  Assign '[F:BUD3]DIE'+num$(INDENV) With [M]AXEENV(I)
  Assign '[F:BUD3]CCE'+num$(INDENT) With [M]ENT(I)
  Assign '[F:BUD3]CCE'+num$(INDENV) With [F:ENV]ENV
  If INDCCE3>0
   Assign '[F:BUD3]DIE'+num$(INDCCE3) With [M]DIE3(I)
   Assign '[F:BUD3]CCE'+num$(INDCCE3) With [M]CCE3(I)
  Endif
  [F:BUD3]CUR    = [M]CURLED(I)
  [F:BUD3]AMT(0) = [M]AMTREPLED(I)
  [F:BUD3]STA    = 3
  [F:BUD3]AMTAPP = [M]AMTREPLED(I)
  [F:BUD3]APPDAT = date$
  [F:BUD3]ACCNUM = uniqid([F:BUD3])
  [F:BUD3]TEX    = SAVTEX
  Write [BUD3]
  If fstat: GOK=0 : Call FSTA("BUD3") From GLOCK : Goto AB_TR : Endif
  If [M]TRC=2 : TRCREP+=1
   ##Création de la ligne
   Call ECR_TRACE(mess(196,108,1)-":"-evalue('[F:BUD3]CCE'+num$(INDENV))-"/"-num$([F:BUD3]FIY)-"/"-[F:BUD3]ACC,0) From GESECRAN
  Endif
 Endif
 Filter [BUD2]
Endif :#Annuelle/Pluri-annuelle

##--DANS LES DA, LES COMMANDES ET LES RÉCEPTIONS NON FACTURÉES :
##--+DANS LA TABLE D'AUDIT
#-* MISE À JOUR DU NOUVEAU NUMÉRO D’ENVELOPPE

#Ceci est valable pour les enveloppe annuelles uniquement
If [F:BUT]YEAFLG=1
  Case [M]TYP(I)
   When 1 :#Demande d'achat
    TABLE = "PSD"
    Gosub RW_PUR
   When 2 :#Commande
    TABLE = "POP"
    Read [POH]POH0 = [M]NUM(I)
    If !fstat
     If [F:POH]POHTYP=1 :#Commande standard
      Gosub RW_PUR
    Else :#=2->Commande ouverte
      # Dans le cas des cmd ouv il peut y avoir plusieurs demandes de livraison (DL) donc
      # on ne doit changer l'enveloppe sur la ligne de cmd que si il n'y a plus de DL sur N
      Local Shortint DORW : DORW=1
      Filter [BUA] Where NUM=[M]NUM(I) & FIY=[M]FIY(I)
      For [BUA]BUA0
       If [F:BUA]CMM<>0 : DORW=0 : Break : Endif
      Next
      Filter [BUA]
      If DORW
       Gosub RW_PUR
      Endif
    Endif
    Endif
  Endcase

Endif :#Env annuelle

###-----------------------------------------------------------
###---DANS L’EXERCICE RÉCEPTEUR :
###-----------------------------------------------------------

##--SI LES ÉLÉMENTS BUDGÉTAIRES EXISTENT OU VIENNENT D’ÊTRE CRÉÉS, AJOUT DU MONTANT REPORTÉ :
#-* AU MONTANT ENGAGÉ DE LA LB (AMTCMM0) OU AU MONTANT PRÉ-ENGAGÉ DE LA LB (AMTCMMPRP0)

##--DANS L’ENGAGEMENT OU LE PRÉ-ENGAGEMENT :
#-* CRÉATION D’UNE LIGNE DE PRÉ-ENGAGEMENT OU D’ENGAGEMENT SUR
#   LE NOUVEL EXERCICE AVEC LE NUMÉRO DE LA NOUVELLE ENVELOPPE

MOTIF(1)=1 : #Création (/Report)
SIGN=1

INDAXENV=find([M]AXEENV(I),TBDIE(1..NBTB))
If INDAXENV
 TBCCE(INDAXENV)=ENV_RECEP
Endif
Call MAJENG([M]DRFIY,[M]FCY(I),[M]CUR(I),[M]AMTREP(I),RATDIV,RATMLT,[M]QTY(I),TBACC,TBLED,TIERS
&                 ,TBDIE,TBCCE,SENS,SIGN,[M]CMMTYP(I),CONTBUD,[M]CMM(I),DOCUMENT,MOTIF,OK,MESSA
&                 ,PIECE,IDENT,TYPPCE,NUMPCE,TYPORG,TYPCUR) From CPTENG
If !OK
 Call MESSAGE(MESSA) From GESECRAN
 GOK=0
Endif

If [M]TRC=2
 Call ECR_TRACE("",0) From GESECRAN
Endif

If GOK<0   : Goto ROLL_TR
Elsif !GOK : Goto AB_TR
Endif
Commit :#[ENV],[ENV2],[ENV3],[ENF],[ENF2],[ENF3],[BUD],[BUD2],[BUD3],[CCE],[CAL]
Return


$RW_PUR
  # MAJ CPTANALIN
  #ABRFIC+VCRTYP+VCRNUM+VCRLIN+VCRSEQ+CPLCLE+ANALIG
  Readlock [CAL]CAL0=TABLE;0;NUM(I);LIN(I);SEQ(I);""
  If !fstat
   INDAXENV = find([M]AXEENV(I),[F:CAL]DIE(0..dim([F:CAL]DIE)-1))
   If INDAXENV & [F:CAL]CCE(INDAXENV-1)<>ENV_RECEP
    [F:CAL]CCE(INDAXENV-1)=ENV_RECEP
    Rewrite [CAL]
    If fstat: GOK=0 : Call FSTA("CAL") From GLOCK : Goto AB_TR : Endif
    If [M]TRC=2 : TRCREP+=1
     # Mise à jour de la pièce d'achat avec le numéro d'enveloppe
     Call ECR_TRACE(mess([M]TYP(I),2684,1)-[M]NUM(I)-":"-mess(252,108,1)-"->"-ENV_RECEP,0) From GESECRAN
    Endif
   Endif
  Elsif fstat=1
   GOK=-1 : GLOCK="$CAL"-[F:CAL]ABRFIC-[F:CAL]VCRNUM : Goto ROLL_TR
  Endif

  # Dans le cas des commandes il faut aussi mettre à jour :
  # -la table Historique de commande
  # -les réceptions
  # -les retours
  If [M]TYP(I)=2
   #Table historique
   Local File UPORDERP
   Filter [UOP] Where POHNUM=NUM(I) & POPLIN=LIN(I) & POPSEQ=SEQ(I)
   For [UOP]POP0
    Readlock [CAL]CAL0="UOP";0;NUM(I);LIN(I);0;num$([F:UOP]LINREVNUM);1
    If !fstat
     INDAXENV = find([M]AXEENV(I),[F:CAL]DIE(0..dim([F:CAL]DIE)-1))
     If INDAXENV
      [F:CAL]CCE(INDAXENV-1)=ENV_RECEP
      Rewrite [CAL]
      If fstat: GOK=0 : Call FSTA("CAL") From GLOCK : Goto AB_TR : Endif
      If [M]TRC=2 : TRCREP+=1
       # Mise à jour de la pièce d'achat avec le numéro d'enveloppe
       Call ECR_TRACE([F:PTD]PTHNUM-mess(252,108,1)-"->"-ENV_RECEP,0) From GESECRAN
      Endif
     Endif
    Elsif fstat=1
     GOK=-1 : GLOCK="$CAL"-[F:CAL]ABRFIC-[F:CAL]VCRNUM : Goto ROLL_TR
    Endif
   Next
   Filter [UOP]
   #Ré-écriture des receptions sur la commande
   Local File PRECEIPTD [PTD]
   Filter [PTD] Where POHNUM=NUM(I) & POPLIN=LIN(I)
   For [PTD]PTD0
    Readlock [CAL]CAL0="PTD";0;[F:PTD]PTHNUM;[F:PTD]PTDLIN;0;"";1
    If !fstat
     INDAXENV = find([M]AXEENV(I),[F:CAL]DIE(0..dim([F:CAL]DIE)-1))
     If INDAXENV
      [F:CAL]CCE(INDAXENV-1)=ENV_RECEP
      Rewrite [CAL]
      If fstat: GOK=0 : Call FSTA("CAL") From GLOCK : Goto AB_TR : Endif
      If [M]TRC=2 : TRCREP+=1
       # Reception XXXX Mise à jour de la pièce d'achat avec le numéro d'enveloppe
       Call ECR_TRACE(mess(2,511,1)-[F:PTD]PTHNUM-mess(252,108,1)-"->"-ENV_RECEP,0) From GESECRAN
      Endif
     Endif
    Elsif fstat=1
     GOK=-1 : GLOCK="$CAL"-[F:CAL]ABRFIC-[F:CAL]VCRNUM : Goto ROLL_TR
    Endif
   Next
   Filter [PTD]
   #Ré-écriture des retours sur les receptions de la commande
   Local File PRETURND [PND]
   Filter [PND] Where POHNUM=NUM(I) & POPLIN=LIN(I)
   For [PND]PND0
    Readlock [CAL]CAL0="PND";0;[F:PND]PNHNUM;[F:PND]PNDLIN;0;"";1
    If !fstat
     INDAXENV = find([M]AXEENV(I),[F:CAL]DIE(0..dim([F:CAL]DIE)-1))
     If INDAXENV
      [F:CAL]CCE(INDAXENV-1)=ENV_RECEP
      Rewrite [CAL]
      If fstat: GOK=0 : Call FSTA("CAL") From GLOCK : Goto AB_TR : Endif
      If [M]TRC=2 : TRCREP+=1
       # Retours XXXX Mise à jour de la pièce d'achat avec le numéro d'enveloppe
       Call ECR_TRACE(mess(3,511,1)-[F:PTD]PTHNUM-mess(252,108,1)-"->"-ENV_RECEP,0) From GESECRAN
      Endif
     Endif
    Elsif fstat=1
     GOK=-1 : GLOCK="$CAL"-[F:CAL]ABRFIC-[F:CAL]VCRNUM : Goto ROLL_TR
    Endif
   Next
   Filter [PND]
  Endif

Return
#--


$AB_TR
If [M]TRC=2
 Call ECR_TRACE("",0) From GESECRAN
 If MESSA<>""
  Call ECR_TRACE("**"-MESSA-"**",1) From GESECRAN
 Endif
 Call ECR_TRACE("",0) From GESECRAN
Endif
Rollback
Return

$ROLL_TR
Rollback
Call ROLL From GLOCK
If GROLL
 Return
Else
 Goto REPORTCMM
Endif


$TERMINE
Local Integer INDREP : INDREP=0
For I=0 To [M]NBLIG-1
 If [M]REPOR(I)=2 : INDREP=1 : Break : Endif
Next
If !INDREP
 # Vous n'avez rien coché. Souhaitez vous quitter sans rien faire?
 Call OUINON(mess(105,108,1),OK) From GESECRAN
 If OK=1
  FOK=0
  FIN=0
 Endif
Else
 # Trace
 If [M]TRC=2
  Call ECR_TRACE(string$(40,"#"),0) From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
 Endif
Endif
Return

$COLORIZE
Local Integer J,K : K=1
Local Char SRTCUR
Case [M]SRT
  When 0
   SRTCUR = ""
  When 1 :#Pièce
   SRTCUR =[M]NUM(0)
  When 2 :#Enveloppe
   SRTCUR =[M]ENV(0)
  When 3 :#Entité
   SRTCUR =[M]ENT(0)
  When 4 :#Compte
   SRTCUR =[M]ACC(0)
 Endcase
For J=0 To [M]NBLIG-1
 Case [M]SRT
  When 0
   If K<>3 : K+=1 : Else : K=1 : Endif
   Chgstl [M]NBLIG(J)  With "GDD"+num$(K)
  When 1 :#Pièce
   If SRTCUR<>[M]NUM(J)
    If K<>3 : K+=1 : Else : K=1 : Endif
    Chgstl [M]NBLIG(J)  With "GDD"+num$(K)
   Else
    Chgstl [M]NBLIG(J)  With "GDD"+num$(K)
   Endif
   SRTCUR =[M]NUM(J)
  When 2 :#Enveloppe
   If SRTCUR<>[M]ENV(J)
    If K<>3 : K+=1 : Else : K=1 : Endif
    Chgstl [M]NBLIG(J)  With "GDD"+num$(K)
   Else
    Chgstl [M]NBLIG(J)  With "GDD"+num$(K)
   Endif
   SRTCUR =[M]ENV(J)
  When 3 :#Entité
   If SRTCUR<>[M]ENT(J)
    If K<>3 : K+=1 : Else : K=1 : Endif
    Chgstl [M]NBLIG(J)  With "GDD"+num$(K)
   Else
    Chgstl [M]NBLIG(J)  With "GDD"+num$(K)
   Endif
   SRTCUR =[M]ENT(J)
  When 4 :#Compte
   If SRTCUR<>[M]ACC(J)
    If K<>3 : K+=1 : Else : K=1 : Endif
    Chgstl [M]NBLIG(J)  With "GDD"+num$(K)
   Else
    Chgstl [M]NBLIG(J)  With "GDD"+num$(K)
   Endif
   SRTCUR =[M]ACC(J)
 Endcase
Next
Affzo [M]
Return


####################################
## Etiquette de l'écran REPRECBUD ##
####################################


Subprog CL_SEARCH(VALEUR)
Variable Char    VALEUR()
If [M]CPY=""
 End
Endif
Gosub INIT
#
Local Libelle LEDTYPGEN,LEDTYPANA
Call SETMAINREF([M]CPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
#
Gosub LOAD_FILTRE
#
Filter [BUA] Where evalue(CRITBUA)
For [BUA]BUA0
 Call LECTURE("BUP",[F:BUA]BUD,"") From CONTOBJ
 If [F:BUP]GDDFLG = 2
  Call LECTURE("CMM",[F:BUA]CMMNUM,"") From CONTOBJ
  [M]BUANUM(I) = [F:BUA]BUANUM
  [M]TYPPCE(I) = [F:BUA]TYPPCE
  [M]TYP(I)    = [F:BUA]TYP
  [M]NUM(I)    = [F:BUA]NUM
  [M]LIN(I)    = [F:BUA]LIN
  [M]SEQ(I)    = [F:BUA]SEQ
  [M]ANALIN(I) = [F:BUA]ANALIN
  [M]LEDTYP(I) = [F:BUA]LEDTYP(LEDTYPANA-1)
  [M]ACC(I)    = [F:BUA]ACC(LEDTYPANA-1)
  [M]DAT(I)    = [F:BUA]DAT
  [M]FCY(I)    = [F:BUA]FCY
  [M]FIY(I)    = [F:BUA]FIY
  [M]CODGAU(I) = [F:BUA]CODGAU
  [M]CMM(I)    = [F:BUA]CMMNUM
  [M]CMMTYP(I) = [F:CMM]TYP
  Case [F:BUA]TYP
   When 1 : [M]OBJ(I)="PSH"
   When 2 : [M]OBJ(I)="POH"
   When 3 :#Facture
    Read [PIH]PIH0=[F:BUA]NUM
    If !fstat
     Case [F:PIH]ORIMOD
      When 2,3 : #Comptabilité/tiers
       [M]OBJ(I)="BIS"
      When 6 : #Achats
       [M]OBJ(I)="PIH"
     Endcase
    Else
     [M]OBJ(I)="GAS"
    Endif
  Endcase
  [M]BUD(I)    = [F:BUA]BUD
  Call LECTURE("BUP",[F:BUA]BUD,"") From CONTOBJ
  INDAXENT  = find([F:BUP]DIE(0),[F:BUA]DIE(0..8))
  If INDAXENT
   [M]AXEENT(I) = [F:BUA]DIE(INDAXENT-1)
   [M]ENT(I)    = [F:BUA]CCE(INDAXENT-1)
  Endif
  INDAXENV  = find([F:BUP]DIE(1),[F:BUA]DIE(0..8))
  If INDAXENV
   [M]AXEENV(I) = [F:BUA]DIE(INDAXENV-1)
   [M]ENV(I)    = [F:BUA]CCE(INDAXENV-1)
  Endif
  INDAX3 = find([F:BUP]DIE(2),[F:BUA]DIE(0..8))
  If INDAX3 & [F:BUP]DIE(2)<>""
   [M]DIE3(I)   = [F:BUA]DIE(INDAX3-1)
   [M]CCE3(I)   = [F:BUA]CCE(INDAX3-1)
  Endif
  [M]CUR(I)    = [F:BUA]CUR
  [M]CURLED(I) = [F:BUA]CURLED(LEDTYPANA-1)
  Case [F:CMM]TYP
   When 1
    [M]AMTREP(I) = [F:BUA]CMMPRP
    [M]AMTREPLED(I) = [F:BUA]CMMPRPLED(LEDTYPANA-1)
   When 2
    [M]AMTREP(I) = [F:BUA]CMM
    [M]AMTREPLED(I) = [F:BUA]CMMLED(LEDTYPANA-1)
  Endcase
  [M]QTY(I)    = [F:BUA]QTY
  [M]REPOR(I)  = 1
  I+=1
  #----TB protection----
  If I>dim([M]REPOR)-1
   #Tableau Plein
   Call MESSAGE(mess(26,100,1)) From GESECRAN : I-=1 : Break
  Endif
  #--------------------
 Endif
Next
Filter [BUA]
[M]NBLIG=I
If [M]NBLIG=0
 # Aucun enregistrement pour ces sélections
 Call MESSAGE(mess(104,199,1)) From GESECRAN
Else
 Affzo [M]
 Raz [M]SRT
 Gosub COLORIZE
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Local Char SOCIETE(GLONCPY)
 SOCIETE=VALEUR
 Local Integer SOC
 SOC = find(SOCIETE,GSOC(1..GNBSOC))
 If !SOC
  # Société inexistante
  GMESSAGE=mess(16,104,1)
  mkstat=2 : End
 Endif
 #06/10/09-Dmd54223:Autorisation site
 Call CONTCPY(VALEUR) From CPTSUB
 # Variables locales
 Local Libelle LEDTYPGEN, LEDTYPANA
 Local Char    CODLED(GLONLED), DEVLED(GLONCUR)
 Local Decimal EXERCICE
 # Plan de compte
 Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
 Call SETMAINREF(SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV
 Call LECLED(SOCIETE,LEDTYPANA,CODLED,DEVLED) From CPTDIV
 Call LECTURE("LED",CODLED,"") From CONTOBJ
 [M]COA=[F:LED]COA
 # Exercice
 Call GETEXE(VALEUR,LEDTYPANA,date$,EXERCICE) From CPTSUB
 Read [FIY]FIY0 = SOCIETE;LEDTYPANA;EXERCICE
 If !fstat & [F:FIY]FIYSTA=2
  [M]EFIY=EXERCICE
  [M]INTEFIY=[F:FIY]DES
  [M]DFIY=[F:FIY]FIYSTR
  [M]FFIY=[F:FIY]FIYEND
  Read [FIY2]FIY0 = SOCIETE;LEDTYPANA;EXERCICE+1
  If !fstat & [F:FIY2]FIYSTA<>3
   [M]RFIY=EXERCICE+1
   [M]INTRFIY=[F:FIY2]DES
   [M]DRFIY=[F:FIY2]FIYSTR
   [M]FRFIY=[F:FIY2]FIYEND
  Endif
 Endif
Endif
Affzo [M]
End

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
Raz [M]NBLIG
Affzo [M]
End

Subprog C_EFIY(VALEUR)
Variable Decimal VALEUR
If [M]CPY<>""
 # Variables locales
 Local Libelle LEDTYPGEN, LEDTYPANA
 # Plan de compte
 Call LECTURE("CPY",[M]CPY,"") From CONTOBJ
 Call SETMAINREF([M]CPY,LEDTYPGEN,LEDTYPANA) From CPTDIV
 Read [FIY]FIY0 = [M]CPY;LEDTYPANA;VALEUR
 If !fstat
  If [F:FIY]FIYSTA=2
   [M]INTEFIY=[F:FIY]DES
   [M]DFIY=[F:FIY]FIYSTR
   [M]FFIY=[F:FIY]FIYEND
   Read [FIY2]FIY0 = [M]CPY;LEDTYPANA;VALEUR+1
   If !fstat
    If [F:FIY2]FIYSTA=3
     # Exercice budgétaire récepteur fermé
     GMESSAGE=mess(204,108,1)
     mkstat=2
    Else
     [M]RFIY=VALEUR+1
     [M]INTRFIY=[F:FIY2]DES
     [M]DRFIY=[F:FIY2]FIYSTR
     [M]FRFIY=[F:FIY2]FIYEND
    Endif
   Else
    # Il n'existe pas d'exercice recepteur pour cet exercice sur cette société et son référentiel analytique principal
    GMESSAGE=mess(202,108,1)
    mkstat=2 : End
   Endif
  Else
  # Exercice non ouvert
   GMESSAGE=mess(20,101,1)
   mkstat=2 : End
  Endif
 Else
  # Exercice inexistant pour cette société sur le référentiel analytique principal
  GMESSAGE=mess(203,108,1)
  mkstat=2 : End
 Endif
Endif
End

Subprog AM_EFIY(VALEUR)
Variable Decimal VALEUR
Raz [M]NBLIG
Affzo [M]
End

Subprog AS_DET(VALEUR)
Variable Char    VALEUR()
GNAVEXEFNC=1 :#Necessaire pour eviter le choix de transaction cf $DEBUT dans GOBJET.src
Local Char BUOPURTRS
#Transaction de saisie des achats.
  Call PARAM([M]CPY,"GDDPURTRS",BUOPURTRS) From ADOVAL
If BUOPURTRS<>""
 GFLAG=BUOPURTRS
Endif
End

Subprog IB_NBLIG
If [M]CMM(nolign-1)=""
 Raz GBOUT2
Endif
GBOUT3 = mess([M]TYP(nolign-1),2684,1)-[M]NUM(nolign-1)
End

Subprog B4_NBLIG
#Tri par numéro de pièce
Sorta [M:BCR]NBLIG [M:BCR]NBLIG Order By [M:BCR]NUM(indice)
[M]SRT=1
Gosub COLORIZE
Affzo [BCR]1-99
End

Subprog B5_NBLIG
#Tri par enveloppe
Sorta [M:BCR]NBLIG [M:BCR]NBLIG Order By [M:BCR]ENV(indice),
&                                          [M:BCR]TYP(indice),
&                                          [M:BCR]FIY(indice),
&                                          [M:BCR]ENT(indice)
[M]SRT=2
Gosub COLORIZE
Affzo [BCR]1-99
End

Subprog B6_NBLIG
#Tri par entité
Sorta [M:BCR]NBLIG [M:BCR]NBLIG Order By [M:BCR]ENT(indice),
&                                          [M:BCR]FIY(indice),
&                                          [M:BCR]ACC(indice),
&                                          [M:BCR]ENV(indice)
[M]SRT=3
Gosub COLORIZE
Affzo [BCR]1-99
End

Subprog B7_NBLIG
#Tri par compte budgétaire
Sorta [M:BCR]NBLIG [M:BCR]NBLIG Order By [M:BCR]ACC(indice),
&                                          [M:BCR]NUM(indice),
&                                          [M:BCR]FIY(indice),
&                                          [M:BCR]TYP(indice)
[M]SRT=4
Gosub COLORIZE
Affzo [BCR]1-99
End

Subprog CL_COCHER(VALEUR)
Variable Char    VALEUR()
If [M]NBLIG>0
 Local Integer COCHE
 If [M]REPOR(0)=1
  COCHE=2
 Else
  COCHE=1
 Endif
 For I=0 To [M]NBLIG-1
  [M]REPOR(I)=COCHE
 Next
 Affzo [M]
Endif
End

######################################################################################

Subprog C_FCYSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 If [F:FCY]LEGCPY<>[M]CPY
  # Ce site est dans la société
  GMESSAGE = mess(43,133,1)-[F:FCY]LEGCPY
  mkstat = 2 : End
 Endif
Endif
End

Subprog AS_FCYEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]FCYSTR<>""
 VALEUR = [M]FCYSTR
 Affzo [M]FCYEND
Endif
End

Subprog C_FCYEND(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]FCYSTR<>""
  # Zone Obligatoire
  GMESSAGE=mess(10,123,1)
  mkstat=2 : End
Endif
If VALEUR<>""
 Call LECTURE("FCY",VALEUR,"") From CONTOBJ
 If [F:FCY]LEGCPY<>[M]CPY
  # Ce site est dans la société
  GMESSAGE = mess(43,133,1)-[F:FCY]LEGCPY
  mkstat = 2 : End
 Endif
 If VALEUR<[M]FCYSTR
  #La borne fin est inférieure à la borne début
  GMESSAGE = mess(257,139,1)
  mkstat = 2 : End
 Endif
Endif
End

