##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
Case [L]AMETHOD
 When "LS"                           : Gosub LS
 When "READCLOB"                     : Gosub READCLOB
 When "WRITECLOB"                    : Gosub WRITECLOB
 When "READCLOB_"                    : Gosub READCLOB_
 When "READBLOB"                     : Gosub READBLOB
 When "WRITEBLOB"                    : Gosub WRITEBLOB
 When "GETFILEINFO"                  : Gosub GETFILEINFO
 When "GETFILEDATETIME"              : Gosub GETFILEDATETIME
 When "GETFILECOM"                   : Gosub GETFILECOM
 When "DELETEFILE"                   : Gosub DELETEFILE
 When "GETFILECONTENTTYPE"           : Gosub GETFILECONTENTTYPE
 Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
Case [L]AOPERATION
Endcase
Return

##########################################################################################################

#**
#* LS
#*!
$LS
Local Integer  MAXFILES:MAXFILES=32767
Local Integer  NAMELENGTH : NAMELENGTH=250
If NBFILES
 MAXFILES = min(MAXFILES,NBFILES)
 Raz NBFILES
Endif
Gosub LS_1 :# File
Return

#**
#* LS_1
#*!
$LS_1
Local Char     MACHINE(250),ORDSYS(250)
Local Char     FICHIER(250) : FICHIER=nomap
Local Integer  ASTATUS: ASTATUS=0
Local Integer  ISWITCH
Local Char     NAMELIKE(50) : NAMELIKE="NAME like '"
Local Char     PATTERN(250)
Local Integer  ILIKE1,ILIKE2
Local Char     FULLNAME(250)
Local Char     FULLPATH(250)
Local Char     OS(20)
Local Char     SEP(1)
Local Integer  EXIST,I

Local Char    WFILES(250)(1..)
Local Integer WNBFILES

If func AFNC.PARTSEP(ver$(0),2," ")>="17r.301"
 Gosub LS_LSADX_NEW
Else
 Gosub LS_LSADX
Endif
Return

$LS_LSADX_NEW
#ver$(0) Version 17r.301 18/11/2014
ILIKE1 = instr(1,[L]QWHERE,NAMELIKE)
If ILIKE1
 ILIKE1 += len(NAMELIKE)
 ILIKE2 = instr(ILIKE1,[L]QWHERE,"'")
 PATTERN = mid$([L]QWHERE,ILIKE1,ILIKE2-ILIKE1)
 While 1
  ILIKE1 = instr(1,PATTERN,"%")
  If !ILIKE1: Break: Endif
  PATTERN  = left$(PATTERN,ILIKE1-1) + "*" + right$(PATTERN,ILIKE1+1)
 Wend
Endif

Call MACHINE(this.ACTX.AFOLDER, MACHINE, FICHIER) From ASYRSYS
Call GET_OS(this.ACTX,MACHINE,OS) From ASYRSYS

FULLPATH = filpath(this.ROOT,"","","")

If len([L]PATH)
 FULLPATH += "\" + [L]PATH
Endif
If OS="unix"
 FULLPATH = ctrans(FULLPATH,"\","/")
Else
 FULLPATH  = ctrans(FULLPATH,"/","\")
Endif

Raz NBFILES,FILES

Raz [L]WNBFILES,[L]WFILES
If instr(1,[L]FULLPATH,"@")>0
 [L]MACHINE = left$([L]FULLPATH,instr(1,[L]FULLPATH,"@")-1)
 [L]FULLPATH = right$([L]FULLPATH,instr(1,[L]FULLPATH,"@")+1)
Endif

#116405
ORDSYS  = 'lsadx -d'
If func ASYRSYS._AVERSRUN(MACHINE)>="19r.111"
 ORDSYS += "x"
Endif
ORDSYS += ' "'+[L]FULLPATH+'"'

Call SYSTEME2(this.ACTX,MACHINE,ORDSYS,'',[L]WNBFILES,[L]WFILES) From ASYRSYS
Gosub ADD_FILES

#116405
ORDSYS  = 'lsadx -f'
If func ASYRSYS._AVERSRUN(MACHINE)>="19r.111"
 ORDSYS += "x"
Endif
ORDSYS += ' "'+[L]FULLPATH+'"'

If PATTERN<>""
 If EXTENSION<>""
  ORDSYS -= PATTERN+'.'+EXTENSION
 Else
  ORDSYS -= PATTERN+'.*'
 Endif
Elsif EXTENSION<>""
 ORDSYS -= '*.'+EXTENSION
Endif
Raz [L]WNBFILES,[L]WFILES
Call SYSTEME2(this.ACTX,MACHINE,ORDSYS,'',[L]WNBFILES,[L]WFILES) From ASYRSYS
Gosub ADD_FILES
Return

$ADD_FILES
I = 1
While I<=[L]WNBFILES
 FULLNAME = [L]WFILES(I)
 If (len(FULLNAME) > 0) & !(find(FULLNAME,".","..")) & !(FULLPATH = FULLNAME) : #& !(len(FULLNAME) = len([L]PATH))
  If len(FULLNAME) > len([L]FULLPATH ) & left$(FULLNAME,len([L]FULLPATH )) = [L]FULLPATH
   FULLNAME = right$(FULLNAME,len([L]FULLPATH)+2)
   FULLNAME = ctrans(FULLNAME,"/","\")
  Elsif len([L]PATH)>0
   FULLNAME  = [L]PATH + "/" + FULLNAME
  Endif
  [L]NBFILES += 1
  [L]FILES([L]NBFILES)   = FULLNAME
 Endif
 I += 1
Wend
Return

$LS_LSADX
# ver$(0) Version 17r.217 23/07/2014
ILIKE1 = instr(1,[L]QWHERE,NAMELIKE)
If ILIKE1
 ILIKE1 += len(NAMELIKE)
 ILIKE2 = instr(ILIKE1,[L]QWHERE,"'")
 PATTERN = mid$([L]QWHERE,ILIKE1,ILIKE2-ILIKE1)
 While 1
  ILIKE1 = instr(1,PATTERN,"%")
  If !ILIKE1: Break: Endif
  PATTERN  = left$(PATTERN,ILIKE1-1) + "*" + right$(PATTERN,ILIKE1+1)
 Wend
Endif

Call MACHINE(nomap, MACHINE, FICHIER) From ASYRSYS
Call GET_OS(this.ACTX,MACHINE,OS) From ASYRSYS

#MAXFILES+2 : MAXFILES + "." and ".." !
#ORDSYS  = MACHINE + "@" + 'lsadx -a"' - nomap + '" ' + "-n " + num$(MAXFILES+2) + " "
#Case ASCDESC
# When "desc"          : ORDSYS += "-r "
# When "TIMESTAMP"     : ORDSYS += "-t"
# When "TIMESTAMP desc": ORDSYS += "-t -r "
#Endcase

FULLPATH = filpath(this.ROOT,"","","")
If len([L]PATH)
 FULLPATH += "\" + [L]PATH
Endif
If OS="unix"
 FULLPATH = ctrans(FULLPATH,"\","/")
Else
 FULLPATH  = ctrans(FULLPATH,"/","\")
Endif

#ORDSYS  += FULLPATH
#ORDSYS  += " " - EXTENSION
#If len(PATTERN)
# ORDSYS  += '"' + PATTERN + '"'
#Endif

#If find(int(mod(filinfo(FULLPATH,0)/2^12,16)),0,8)<>0
# Return : # It's not a directory
#Endif

Case OS
 When "unix"
  # ls -p pour que les répertoires apparaissent avec un / à la fin
  ORDSYS = 'ls'
  Case ASCDESC
   When "desc"          : ORDSYS -= '-r'
   When "TIMESTAMP"     : ORDSYS -= '-t -r'
   When "TIMESTAMP desc": ORDSYS -= '-t'
  Endcase
  SEP = '/'
 When Default
  # dir /a:-d pour lister tous les fichiers sauf les répertoires
  # dir /b    pour n'afficher que le nom des fichiers sur une seule colonne
  ORDSYS = 'dir /a: /b'
  Case ASCDESC
   When "desc"          : ORDSYS -= '/o:-n'
   When "TIMESTAMP"     : ORDSYS -= '/o:d'
   When "TIMESTAMP desc": ORDSYS -= '/o:-d'
  Endcase
  SEP = '\'
Endcase
ORDSYS -= '"'+vireblc(FULLPATH,2)
If PATTERN<>""
 If EXTENSION<>""
  ORDSYS += SEP+PATTERN+'.'+EXTENSION
 Else
  ORDSYS += SEP+PATTERN+'.*'
 Endif
Elsif EXTENSION<>""
 ORDSYS += SEP+'*.'+EXTENSION
Endif
ORDSYS += '"'

# mb 12.8.14 Why Local file doesn't work ?
#Local File (NAME(NAMELENGTH)) From System MACHINE+'@'+ORDSYS As [ORDSYS_]
#For [ORDSYS_]
# FULLNAME = [ORDSYS_]NAME
# If (len(FULLNAME) > 0) & !(len(FULLNAME) = len([L]PATH)) & !(find(FULLNAME,".","..")) & !(FULLPATH = FULLNAME)
#  [L]NBFILES = NBFILES+1
#  If len(FULLNAME) > len(this.ROOT) & left$(FULLNAME,len(this.ROOT)) = this.ROOT
#   FULLNAME = right$(FULLNAME,len(this.ROOT)+2)
#   FULLNAME = ctrans(FULLNAME,"/","\")
#  Elsif len([L]PATH)>0
#   FULLNAME  = [L]PATH + "\" + FULLNAME
#  Endif
#  If len(EXTENSION) : FULLNAME += "." + EXTENSION : Endif
#  FILES([L]NBFILES)   = FULLNAME
# Endif
#Next ORDSYS_
#Close Local File [ORDSYS_]

Call SYSTEME2(this.ACTX,MACHINE,ORDSYS,'',[L]NBFILES,[L]FILES) From ASYRSYS
[L]NBFILES = min([L]NBFILES,dim([L]FILES))

# if the path is not a directory : bug 102603 CCL
# 108902 CCL
If OS="dos" & [L]NBFILES=1 & filinfo([L]FULLPATH+"/"+[L]FILES,7)<0
 [L]NBFILES = 0
 Return
Endif

I = 1
While I<=[L]NBFILES
 FULLNAME = [L]FILES(I)
 If (len(FULLNAME) > 0)  & !(find(FULLNAME,".","..")) & !(FULLPATH = FULLNAME) : # & !(len(FULLNAME) = len([L]PATH))
  If len(FULLNAME) > len(this.ROOT) & left$(FULLNAME,len(this.ROOT)) = this.ROOT
   FULLNAME = right$(FULLNAME,len(this.ROOT)+2)
   FULLNAME = ctrans(FULLNAME,"/","\")
  Elsif len([L]PATH)>0
   FULLNAME  = [L]PATH + SEP + FULLNAME
  Endif
  [L]FILES(I)   = FULLNAME
  I += 1
 Else
  Dela I,1 [L]FILES
  [L]NBFILES -= 1
 Endif
Wend
Return

#**
#* _GETFILEKEYS
#*!
$_GETFILEKEYS
Local Char     AFILEKEYS(100)(1..)
Local Integer  MAXKEYS,NBKEYS,P1,P2
Local Char     FIELDS(30)(1..)

MAXKEYS  = 1 :FIELDS(MAXKEYS) = "CODBLB"
MAXKEYS += 1 :FIELDS(MAXKEYS) = "IDENT1"
MAXKEYS += 1 :FIELDS(MAXKEYS) = "IDENT2"
MAXKEYS += 1 :FIELDS(MAXKEYS) = "IDENT3"
#MAXKEYS += 1 :FIELDS(MAXKEYS) = "NAMBLB"

Raz NBKEYS
P1=1
If len(FILEKEYS)
 While NBKEYS < MAXKEYS
  P2 = instr(P1,FILEKEYS,"\")
  If P2
   NBKEYS+=1 : AFILEKEYS(NBKEYS) = ctrans(mid$( FILEKEYS, P1, P2-P1),'$','~')
   P1=P2+1
  Else
   NBKEYS+=1 : AFILEKEYS(NBKEYS) = ctrans(right$(FILEKEYS, P1),'$','~')
   Break
  Endif
 Wend
Endif
Return

#**
#*
#* !
$LS_LOB
Local Char     TBPRO(10)(1..)            : # Properties' names
Local Char     TBFIL(10)(1..)            : # Columns' names
Local Char     NAMELIKE(50) : NAMELIKE="(NAME like '"
Local Char     PATTERN(250)
Local Integer  J
Local Char     FILEKEYS(250)
Local Integer  F: F=0
Local Integer  ILIKE1,ILIKE2
Local Char     SEP(1)


Local Integer I: I=0
Local Char    TFULLNAME(NAMELENGTH)(1..)
Local File    (Char FULLNAME(NAMELENGTH)) From Variable TFULLNAME As [LNK_]

FILEKEYS = [L]PATH
Gosub _GETFILEKEYS
For F=1 To NBKEYS
 If len(QWHERE1) : QWHERE1 +=  ' and ' : Endif
 QWHERE1 += "(" + FIELDS(F) + " eq '" + AFILEKEYS(F) + "')"
Next F

If len(QWHERE1)
 Filter [ALB_] Where evalueSData(QWHERE1,TBPRO,TBFIL) Order By Key LNKORDER=CODBLB;IDENT1;IDENT2;IDENT3;NAMBLB Asc
Endif

For [ALB_]LNKORDER(min(MAXKEYS,NBKEYS+1))
 I+=1 : TFULLNAME(I) = ""
 SEP=''
 For J=0 To min(MAXKEYS,NBKEYS)
  TFULLNAME(I) += SEP
  Case J+1
   When 1: TFULLNAME(I) +=ctrans([F:ALB_]CODBLB,'~','$')
   When 2: TFULLNAME(I) +=ctrans([F:ALB_]IDENT1,'~','$')
   When 3: TFULLNAME(I) +=ctrans([F:ALB_]IDENT2,'~','$')
   When 4: TFULLNAME(I) +=ctrans([F:ALB_]IDENT3,'~','$')
   #When 5: TFULLNAME(I) +=ctrans([F:ALB_]NAMBLB,'~','$')
  Endcase
  SEP = '\'
 Next J
Next ALB_
Close Local File [ALB_]

ILIKE1 = instr(1,[L]QWHERE,NAMELIKE)
If ILIKE1
 ILIKE1 += len(NAMELIKE)
 ILIKE2  = instr(ILIKE1,[L]QWHERE,"'")
 PATTERN = mid$([L]QWHERE,ILIKE1,ILIKE2-ILIKE1)

 QWHERE1 = "(FULLNAME like '" + PATTERN + "')"
 Filter [LNK_] Where evalueSData(QWHERE1,TBPRO,TBFIL)
Else
 Filter [LNK_] Where len(FULLNAME) > 0
Endif

For [LNK_]
 If !(len([F:LNK_]FULLNAME) = len([L]PATH))
  [L]NBFILES = [L]NBFILES+1
  FILES([L]NBFILES)  =  [F:LNK_]FULLNAME
  If NBFILES=MAXFILES: Break:Endif
 Endif
Next LNK_
Return

#**
#* OPEN_ABLOB
#*!
$OPEN_ABLOB
Local Char          QWHERE1(250)
Local Char          QWHERE2(250)
Local File ABLOB    [ALB_]
QWHERE1 = "TYPBLB eq 3"
QWHERE2 = "(TYPBLB = 3)"

Return

#**
#* LS_2
#*!
$LS_2
Gosub OPEN_ABLOB
Gosub $LS_LOB
Return

#**
#* OPEN_ACLOB
#*!
$OPEN_ACLOB
Local Char          QWHERE1(250)
Local Char          QWHERE2(250)
Local File ACLOB    [ALB_]
If len(vireblc(this.ROOT,4))
 QWHERE1 = "TYPDOC eq '" + vireblc(this.ROOT,4) + "'"
 QWHERE2 = "TYPDOC =  '" + vireblc(this.ROOT,4) + "'"
Endif
Return

#**
#* LS_3
#*!
$LS_3
Gosub OPEN_ACLOB
Gosub $LS_LOB
Return

#**
#* READCLOB
#* Param : Char    NAME ()
#* Return: Clbfile CLOB
#*!
$READCLOB
Gosub READCLOB_1 :# File
Return

#**
#* READCLOB_1
#* Param : Char    NAME ()
#* Return: Clbfile CLOB
#*!
$READCLOB_1
Local Char    LINE(255)
Local Char    FILEPATH(255)
Local Char    FILEPATH(255)
FILEPATH = func _GETFULLPATH(this.ROOT,[L]FULLNAME)

If filinfo(FILEPATH,0) > 0
 Openi FILEPATH
 #adxifs="" : adxirs=chr$(13)+chr$(10)
 adxium=[L]IUM
 While 1
  Rdseq LINE
  Append CLOB,LINE
  Break (fstat<>0)
 Wend
 Openi
Endif
Return

#**
#* READCLOB_
#* Param : Char     PATH ()
#* Param : Char     CALLBACK
#* Value Char       IFS
#* Value Char       IRS
#* Value Integer    IUM
#* Value Char       CALLBACK
#* Variable Clbfile CLOB
$READCLOB_
Gosub READCLOB__1 :# File
Return

#**
#* READCLOB__1
#* Param : Char     PATH ()
#* Param : Char     CALLBACK
#* Value Char       IFS
#* Value Char       IRS
#* Value Integer    IUM
#* Value Char       CALLBACK
#* Variable Clbfile CLOB

#*!
$READCLOB__1
Local Char      LINE(250)
Local Char      FILEPATH(250)
Local Integer   RES
Local Integer   I,J,K

FILEPATH = func _GETFULLPATH(this.ROOT,[L]NAME)
If filinfo(FILEPATH,0) > 0
 Openi FILEPATH,FSEEK
 adxifs=IFS
 adxirs=IRS
 adxium=IUM
 While 1
  Rdseq LINE
  RES = func =CALLBACK With (LINE,CLOB)
  Break (RES<>0 or fstat<>0)
 Wend
 Openi
Endif
Return

#**
#* WRITECLOB
#* Param : Char    NAME ()
#* Return: Clbfile CLOB
#*!
$WRITECLOB
Gosub WRITECLOB_1 :# File
Return

#**
#* WRITECLOB_1
#*!
$WRITECLOB_1
Local Char    FILEPATH(255)
[L]FILEPATH = func _GETFULLPATH(this.ROOT,[L]FULLNAME)

Openo [L]FILEPATH
adxium=IUM
Wrseq CLOB
Openo
Return

#**
#* READBLOB
#* Param : Char    NAME ()
#* Return: Nlbfile BLOB
#*!
$READBLOB
Gosub READBLOB_1 :# File
Return


#**
#* READBLOB_1
#* Param : Char    NAME ()
#* Return: Blbfile BLOB
#*!
$READBLOB_1
Local Char    LINE(255)
Local Char    FILEPATH(255)
Local Integer SIZE
[L]FILEPATH = func _GETFULLPATH(this.ROOT,[L]FULLNAME)

SIZE = filinfo(FILEPATH,7)
If  SIZE > 0
 Openi FILEPATH Using [VFB]
 Getseq 1,BLOB Sized SIZE Using [VFB]
 Openi
Endif
Return

#**
#* _BUILD_QWHERE
#*!
$_BUILD_QWHERE
Local Integer F
For F=1 To NBKEYS
 QWHERE2 += " and (" + FIELDS(F) + "='" + AFILEKEYS(F) + "')"
Next F
Return

#**
#* READBLOB_2
#* Param : Char    NAME ()
#* Return: Blbfile BLOB
#*!
$READBLOB_2
Gosub OPEN_ABLOB
FILEKEYS = [L]FULLNAME
Gosub _GETFILEKEYS
If NBKEYS
 Gosub _BUILD_QWHERE
 Filter [ALB_] Where evalue(QWHERE2)
 Read [ALB_]ABB0 First
 BLOB = [ALB_]BLOB
Endif
Return

#**
#* READBLOB_3
#* Param : Char    NAME ()
#* Return: Blbfile BLOB
#*!
$READBLOB_3
Local Integer COUNT
Gosub OPEN_ACLOB
FILEKEYS = [L]FULLNAME
Gosub _GETFILEKEYS
If NBKEYS = MAXKEYS
 Gosub _BUILD_QWHERE
 Filter [ALB_] Where evalue(QWHERE2)
 Read [ALB_]ACB0 First
 COUNT = strEncode( [ALB_]CLOB, BLOB, GUTF8 )
Endif
Return

#**
#* WRITEBLOB
#* Param : Char    NAME ()
#* Return: Clbfile BLOB
#*!
$WRITEBLOB
Gosub WRITEBLOB_1 :# File
Return

#**
#* WRITEBLOB_1
#*!
$WRITEBLOB_1
Local Char    FILEPATH(255)
FILEPATH = func _GETFULLPATH(this.ROOT,[L]FULLNAME)

[L]ARET_VALUE  = [V]CST_AOK

Onerrgo WRITEBLOB_1_ERROR
Openo [L]FILEPATH,0 Using [VOL]
Onerrgo
If [L]ARET_VALUE  = [V]CST_AOK
 Putseq 1, BLOB Using [VOL]
 Openo Using [VOL]
Endif
Return

$WRITEBLOB_1_ERROR
[L]ARET_VALUE = func ASYRSUB._ASETSTATUS(this,"",0, [V]CST_AERROR,[V]CST_AHTTP_FORBIDDEN,mess(43,149,1))
Resume

#**
#* WRITEBLOB_2
#*!
$WRITEBLOB_2
Local Char FILEKEYS(250)
Local Char WCNT(100),WATYP(GLONATYP)
FILEKEYS = [L]FULLNAME
Gosub _GETFILEKEYS
If NBKEYS
 Gosub OPEN_ABLOB

 Local Integer LADXLOG
 [L]LADXLOG=adxlog
 If !adxlog : Trbegin [ALB_] : Endif
 [ALB_]CODBLB = AFILEKEYS(1)
 [ALB_]IDENT1   = AFILEKEYS(2)
 [ALB_]IDENT2   = AFILEKEYS(3)
 [ALB_]IDENT3   = AFILEKEYS(4)
 [ALB_]BLOB      = [L]BLOB
 [ALB_]CREDAT=date$
 [ALB_]CREDATTIM=datetime$
 [ALB_]CREUSR=this.ACTX.USER
 [ALB_]UPDUSR=this.ACTX.USER

 [L]WATYP = 'ATYPE9-1'
 [ALB_]CNTTYP = [L]WATYP
 [L]WCNT = 'image'
 [ALB_]TYPBLB = func ASYRLOB.F_CNTTYP_TO_AML7806([L]WCNT)
 Write [ALB_]
 If fstat
  [L]ASTATUS = [V]CST_AERROR
 Endif

 If LADXLOG=0 and adxlog
  If [L]ASTATUS=0
   Commit
  Else
   Rollback
  Endif
 Endif

 Close Local File [ALB_]
Endif

Return

#**
#* WRITEBLOB_3
#*!
$WRITEBLOB_3
Local Char FILEKEYS(250)
Local Char WCNT(100),WATYP(GLONATYP)
FILEKEYS = [L]FULLNAME
Gosub _GETFILEKEYS
If NBKEYS
 Gosub OPEN_ACLOB

 Local Integer LADXLOG
 Local Clbfile CLOB
 Local Integer NBC
 Local Char EXTENSION(3)

 [L]NBC = strDecode( BLOB, [L]CLOB, GUTF8 )
 [L]LADXLOG=adxlog
 If !adxlog : Trbegin [ALB_] : Endif
 [ALB_]CODBLB = AFILEKEYS(1)
 [ALB_]IDENT1   = AFILEKEYS(2)
 [ALB_]IDENT2   = AFILEKEYS(3)
 [ALB_]IDENT3   = AFILEKEYS(4)
 [ALB_]CLOB      = [L]CLOB
 [ALB_]CREDAT=date$
 [ALB_]CREDATTIM=datetime$
 [ALB_]CREUSR=this.ACTX.USER
 [ALB_]UPDUSR=this.ACTX.USER

 [ALB_]CNTTYP = 'ATYPE10'
 [ALB_]TYPDOC = vireblc(this.ROOT)

 Write [ALB_]
 If fstat
  [L]ASTATUS = [V]CST_AERROR
 Endif

 If LADXLOG=0 and adxlog
  If [L]ASTATUS=0
   Commit
  Else
   Rollback
  Endif
 Endif

 Close Local File [ALB_]
Endif

Return


