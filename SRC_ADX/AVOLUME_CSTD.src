Return

#**
#* GETFILEDATETIME
#*!
$GETFILEDATETIME
Gosub GETFILEDATETIME_1 :# File
Return

#**
#* GETFILEDATETIME_1
#*!
$GETFILEDATETIME_1
Local Char     FILEPATH(255)
Local Integer  FTIMES
Local Integer  S , H , M
Local Date     D
Local Char     TIMESTAMP(20)
Local Integer  FTIMES

[L]FILEPATH = func _GETFULLPATH(this.ROOT,[L]FULLNAME)

[L]FTIMES= max(0,filinfo(FILEPATH,9))
S = int(mod(FTIMES,60))
M = int(mod(FTIMES,3600)/60)
H = int(mod(FTIMES,86400)/3600)
D = [01/01/1970]+int(FTIMES/86400)
TIMESTAMP = right$(num$(100+H),2)+":"+right$(num$(100+M),2)+":"+right$(num$(100+S),2)+"Z"
TIMESTAMP = num$(year(D))+"-"+right$(num$(100+month(D)),2)+"-"+right$(num$(100+day(D)),2)+"T"+TIMESTAMP
FDATETIME = gdatetime$(TIMESTAMP)
Return


#**
#* GETFILECOM
#*!
$GETFILECOM
Gosub GETFILECOM_1 :# File
Return

#**
#* GETFILECONTENTTYPE
#*!
$GETFILECONTENTTYPE
Gosub GETFILECONTENTTYPE_1 :# File
Return

#**
#* GETFILECONTENTTYPE_1
#*!
$GETFILECONTENTTYPE_1
APOS = instr(1,FULLNAME,".")
If APOS
 EXTENSION = right$(FULLNAME,APOS+1)
 CONTENTTYPE = "application/"
 Case tolower(EXTENSION)
  When "xls","xlsx"   : CONTENTTYPE += "excel"
  When "doc","docx" : CONTENTTYPE += "msword"
  When "ppt"            : CONTENTTYPE += "powerpoint"
  When "js","json"    : CONTENTTYPE += "json"
  When "bmp","jpg","jpeg","gif","png","tiff"  : CONTENTTYPE = "image/"+EXTENSION
  When Default       : CONTENTTYPE += EXTENSION
 Endcase
Endif
Return

#**
#* GETFILECONTENTTYPE_2
#*!
$GETFILECONTENTTYPE_2
Local Char FILEKEYS(250)
FILEKEYS = [L]FULLNAME
Gosub _GETFILEKEYS
If NBKEYS
 Gosub OPEN_ABLOB
 Gosub _BUILD_QWHERE
 Filter [ALB_] Where evalue(QWHERE2)
 Read [ALB_]ABB0 First
 [L]CONTENTTYPE = mess([ALB_]TYPBLB,7806,1)
 Close Local File [ALB_]
Endif
Return

#**
#* GETFILECONTENTTYPE_3
#*!
$GETFILECONTENTTYPE_3
Local Char FILEKEYS(250)
FILEKEYS = [L]FULLNAME
Gosub _GETFILEKEYS
If NBKEYS
 Gosub OPEN_ACLOB
 Gosub _BUILD_QWHERE
 Filter [ALB_] Where evalue(QWHERE2)
 Read [ALB_]ACB0 First
 [L]CONTENTTYPE = this.ROOT
 Close Local File [ALB_]
Endif
Return


#**
#* GETFILECOM_1
#*!
$GETFILECOM_1
Local Char     FILEPATH(255)
[L]FILEPATH   = func _GETFULLPATH(this.ROOT,[L]FULLNAME)
[L]COMMENT = filcom([L]FILEPATH,"", "", -1)
Return

#**
#* DELETEFILE
#*!
$DELETEFILE
Gosub DELETEFILE_1 :# File
Return

#**
#* DELETEFILE_1
#*!
$DELETEFILE_1
Local Char     FILEPATH(255)
Local Integer  ASTATUS
[L]FILEPATH = func _GETFULLPATH(this.ROOT,[L]FULLNAME)

[L]ASTATUS = Delfile(FILEPATH)
If [L]ASTATUS < 0
 [L]ASTATUS = fmet this.ACTX.ASETERROR(ctrans([L]FULLNAME,"\","/"),errmes$(abs([L]ASTATUS)),[V]CST_AERROR )
Endif
Return



#**
#* DELETE_LOB
#*!
$DELETE_LOB
FILEKEYS = [L]FULLNAME
Gosub _GETFILEKEYS
If NBKEYS
 Gosub _BUILD_QWHERE
 Delete [ALB_] Where evalue(QWHERE2)
Endif
Return

#**
#* DELETEFILE_2
#*!
$DELETEFILE_2
Gosub OPEN_ABLOB
Gosub DELETE_LOB
Return

#**
#* DELETEFILE_3
#*!
$DELETEFILE_3
Gosub OPEN_ACLOB
Gosub DELETE_LOB
Return

#**
#* _GETFULLPATH
#*
#* @param VOLUME
#* @param FILENAM
#*!
Funprog _GETFULLPATH(ROOT,FULLNAME)
Value Char ROOT
Value Char FULLNAME

Local Char    FILEPATH(255)
[L]FILEPATH  = filpath([L]ROOT,"","","")
# Remove the last / character
[L]FILEPATH = left$([L]FILEPATH,len([L]FILEPATH)-(instr(len([L]FILEPATH),[L]FILEPATH,"/")/len([L]FILEPATH)))
[L]FILEPATH += "/" + ctrans([L]FULLNAME,"\","/")
End FILEPATH

