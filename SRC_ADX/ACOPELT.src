#<AdxTL>@(#)12.0.0.0 $Revision$
# Gestion du masque ACOPELT

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","ACOPELT","ACOPELT",3,"") From GTRAITE
End

#---------------------------------------------------------#
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "EXEC"        : Gosub EXEC
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "FIN_TABLE"   : Gosub FIN_TABLE
Endcase
Return

$INIT
TMP = 1
Return

$EXEC
Local Char    FICORG(GDIMFIC) , FICDES(GDIMFIC)
Local Char    COD(250) , REP(250) , TRT(30) , ETA(30) , MESSA(250)
Local Integer I , J , K , STAT , OK , CRE , STA
Local Char    FICSRF(250) , FICTRA(250) , ORDSYS(250)(1..2) , TEXTE(80)
Local Char    MACHINE(250) , MACORG(250) , APPLI(30)
Local Char    EXT(30) , PRO(30) , OBJ(30)
Call MACHINE([M:ACOP]DOSORG,MACORG,APPLI) From ORDSYS
Call MACHINE([M:ACOP]DOSDES,MACHINE,PRO) From ORDSYS
OBJ = "ELT"
COD = [M:ACOP]ELT    
Gosub COPIEELT
zonsui = "ELT"
SAI = 1
Return

#------------#
$COPIEELT
If MACHINE=adxmac(0) : Return : Endif : # Il n'y a qu'un seul répertoire X3_PUB
K = 0
For I=len(COD) To 1 Step -1
 If mid$(COD,I,1)="."
  K = I : Break
 Endif
Next I
If K
 EXT = right$(COD,K+1)
 REP = left$(COD,K-1)
Else
 REP = COD
Endif
For I=len(REP) To 1 Step -1
 If find(mid$(REP,I,1),"\","/")<>0
  K = I : Break
 Endif
Next I
If K
 TRT = right$(REP,K+1)
 REP = left$(REP,K-1)
Else
 TRT = REP
 REP = ""
Endif
FICORG = filpath(REP,TRT,EXT,"X3_PUB","",MACORG)
FICDES = filpath(REP,TRT,EXT,"X3_PUB","",MACHINE)
If filinfo(FICORG,0)<0
 Call ECR_TRACE("|"+FICORG-": Fichier inexistant",1) From GESECRAN
 STA = 0 : Return
Endif
If instr(1,toupper(FICORG),"X3_CLIENT")<>0 & filinfo(filpath(REP,"","","X3_PUB","",MACHINE),0)<0
 Call ECR_TRACE("Création du répertoire"-filpath(REP,"","","X3_PUB","",MACHINE),-1) From GESECRAN
 K = instr(1,FICDES,"@")
 If K
  ORDSYS = right$(FICDES,K+1)
 Else
  ORDSYS = FICDES
 Endif
 K = 0
 For I=len(ORDSYS) To 1 Step -1
  If find(mid$(ORDSYS,I,1),"\","/")<>0
   K = I : Break
  Endif
 Next I
 If K
  ORDSYS = 'ae_mkdir'-'"'+left$(ORDSYS,K-1)+'"'
  Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
 Endif
Endif
Call COPIE(FICORG,FICDES,STAT) From ORDSYS
If EXT="tar"
 If instr(1,toupper(FICORG),"ADX_PORTAL")<>0 and instr(1,toupper(FICORG),"ARCHIVES")<>0
  Call DETARPORTAL(MACHINE) From VALCSTWEB 
 Elsif instr(1,toupper(FICORG),"X3_ROOT")<>0 and instr(1,toupper(FICORG),"X3CLI")<>0
  Call DETARX3CLI(MACHINE) From VALCSTWEB
 Elsif instr(1,toupper(FICORG),"X3_ROOT")<>0 and instr(1,toupper(FICORG),"RESSTD")<>0
  Call DETARRES(MACHINE,"STD") From VALCSTWEB
 Elsif instr(1,toupper(FICORG),"X3_ROOT")<>0 and instr(1,toupper(FICORG),"RESVER")<>0
  Call DETARRES(MACHINE,"VER") From VALCSTWEB
 Elsif instr(1,toupper(FICORG),"X3_ROOT")<>0 and instr(1,toupper(FICORG),"RESPER")<>0
  Call DETARRES(MACHINE,"PER") From VALCSTWEB
 Elsif instr(1,toupper(FICORG),"X3_CLIENT")<>0
  Call DETARX3CLIENT(MACHINE) From VALCSTWEB
 Endif
Endif
Return

#---------------------------------------------------------#
$SEL_TABLE
Case TABLE
 When "ELT" : Gosub SEL_ELT From APATCH
Endcase
Return

$FIN_TABLE
Case TABLE
 When "ELT" : Gosub FIN_ELT From APATCH
Endcase
Return

#---------------------------------------------------------#
Subprog AV_DOSORG(VALEUR)
Variable Char    VALEUR()
Call AV_DOSORG(VALEUR) From ACOPIE
End

Subprog AS_DOSORG(VALEUR)
Variable Char    VALEUR()
Call AS_DOSORG(VALEUR) From ACOPIE
End

Subprog AM_DOSORG(VALEUR)
Variable Char    VALEUR()
Call AM_DOSORG(VALEUR) From ACOPIE
End

Subprog AS_DOSDES(VALEUR)
Variable Char    VALEUR()
Call AS_DOSDES(VALEUR) From ACOPIE
End

Subprog C_DOSDES(VALEUR)
Variable Char    VALEUR()
Call C_DOSDES(VALEUR) From ACOPIE
End

Subprog C_ELT(VALEUR)
Variable Char    VALEUR()
End

Subprog S_ELT(VALEUR)
Variable Char    VALEUR()
Local Char PARAM(20)(1..1)
Call S_TAB_CHAR(VALEUR,PARAM,"ELT","ACOPELT","") From GACTION
End
