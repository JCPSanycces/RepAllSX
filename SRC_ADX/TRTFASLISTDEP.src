#<AdxTL>@(#)0.0.0.0 $Revision$
#** ####################################################################################################################
#*
#* Label      : action
#* Purpose    : standard entry point
#*
#*! ####################################################################################################################
$ACTION
  Case ACTION
    When "DEBUT"  : Gosub DEBUT
    When "BOUTON" : Gosub BOUTON
    When Default  :
  Endcase
Return

#** ####################################################################################################################
#*
#* Label      : debut
#* Purpose    : after the window is displayed
#*
#*! ####################################################################################################################
$DEBUT
  Effzo [M:FLIS]1-99
Return

#** ####################################################################################################################
#*
#* Label      : bouton
#* Purpose    : a button at the bottom of the screen was activated
#*
#*! ####################################################################################################################
$BOUTON
  If BOUT = "S" Then
    # search button
    Call SEARCH()
  Endif
Return

#** ####################################################################################################################
#*
#* SubProg    : search
#* Purpose    : checks the selected criteria and afterwards the actual search will be performed
#*
#* Parameters :
#*
#*! ####################################################################################################################
Subprog SEARCH()
  Local Integer I

  If [M:FLIS]CPY = "" Then
    End
  Endif

  GOK = 0

  # open tables
  If clalev([F:CNX]) = 0 Then : Local File CONTEXT  [CNX] : Endif
  If clalev([F:FIS]) = 0 Then : Local File FISCYEAR [FIS] : Endif

  Link [CNX] With [FIS]FIY0 = [F:CNX]CPY;[F:CNX]CNX
&   As [LNK]
&   Where [F:CNX]CPY = [M:FLIS]CPY
&   Order By [F:FIS]DATSTRFIY
  For [LNK]
    If [M:FLIS]TYPPER = 1 Then
      # fiscal year
      If [M:FLIS]DATSTR = [F:FIS]DATSTRFIY and [M:FLIS]DATEND = [F:FIS]DATENDFIY Then
        GOK = 1
      Endif
    Else
      # periods
      For I = 0 To [F:FIS]NBRPER
        If [M:FLIS]DATSTR = [F:FIS]DATSTRPER(I) and [M:FLIS]DATEND = [F:FIS]DATENDPER(I) Then
          GOK = 1
        Endif
      Next I
    Endif
  Next

  # close tables
  If clalev([F:CNX]) <> 0 Then : Close Local File [CNX] : Endif
  If clalev([F:FIS]) <> 0 Then : Close Local File [FIS] : Endif

  If GOK = 1 Then
    Call COLLECT_DATA()
  Else
    Call ECR_TRACE(mess(1010,2299,1), 1) From GESECRAN
  Endif
End

#** ####################################################################################################################
#*
#* SubProg    : collect_data
#* Purpose    : performs the actual data mapping
#*
#* Parameters :
#*
#*! ####################################################################################################################
Subprog COLLECT_DATA()
  Local Integer I : I = 0

  Call TEMPON("L") From GESECRAN

  # open tables
  If clalev([F:FLU]) = 0 Then : Local File FXDLIFL   [FLU] : Endif
  If clalev([F:FAS]) = 0 Then : Local File FXDASSETS [FAS] : Endif
  If clalev([F:DEP]) = 0 Then : Local File DEPREC    [DEP] : Endif
  If clalev([F:GAC]) = 0 Then : Local File GACCOUNT  [GAC] : Endif
  If clalev([F:CNX]) = 0 Then : Local File CONTEXT   [CNX] : Endif

  Effzo [M:FLIS]10

  If [M:FLIS]TYPPER = 1 Then
    # fiscal year
    Link [FLU] With [FAS]FAS1 = [F:FLU]CPY;[F:FLU]AASREF,
&                   [DEP]DEP0 = [F:FLU]AASREF;[F:FLU]DPRPLN;[F:FLU]FIYENDDAT;[F:FLU]FIYENDDAT,
&                   [GAC]GAC0 = [F:FLU]COA;[F:FLU]GAC,
&                   [CNX]CNX0 = [F:FLU]CPY;[F:FLU]CNX
&     As [LNK]
&     Where [F:FLU]CPY       = [M:FLIS]CPY
&       and [F:FLU]DPRPLN    = [M:FLIS]DPRPLN
&       and [F:FLU]CODTXS    = ""
&       and [F:FLU]FIYSTRDAT = [M:FLIS]DATSTR
&       and [F:FLU]FIYENDDAT = [M:FLIS]DATEND
&       and [F:FLU]PERSTRDAT = [0/0/0]
&       and [F:FLU]PERENDDAT = [0/0/0]
&     Order By [F:FAS]AASREF
  Else
    # periods
    Link [FLU] With [FAS]FAS1 = [F:FLU]CPY;[F:FLU]AASREF,
&                   [DEP]DEP0 = [F:FLU]AASREF;[F:FLU]DPRPLN;[F:FLU]FIYENDDAT;[F:FLU]FIYENDDAT,
&                   [GAC]GAC0 = [F:FLU]COA;[F:FLU]GAC,
&                   [CNX]CNX0 = [F:FLU]CPY;[F:FLU]CNX
&     As [LNK]
&     Where [F:FLU]CPY       = [M:FLIS]CPY
&       and [F:FLU]DPRPLN    = [M:FLIS]DPRPLN
&       and [F:FLU]CODTXS    = ""
&       and [F:FLU]PERSTRDAT = [M:FLIS]DATSTR
&       and [F:FLU]PERENDDAT = [M:FLIS]DATEND
&     Order By [F:FAS]AASREF
  Endif

  # main loop
  For [LNK]
    [M:FLIS]AASREF(I)    = [F:FLU]AASREF
    [M:FLIS]AASDES(I)    = [F:FAS]AASDES1
    [M:FLIS]PURDAT(I)    = [F:FAS]PURDAT
    [M:FLIS]ISSDAT(I)    = [F:FAS]ISSDAT
    [M:FLIS]DPRDUR(I)    = [F:DEP]DPRDUR
    [M:FLIS]DPM(I)       = [F:DEP]DPM
    [M:FLIS]GAC(I)       = [F:FLU]GAC
    [M:FLIS]DPRBASSTR(I) = [F:FLU]DPRBASEND
    [M:FLIS]NBV(I)       = [F:FLU]DPRBASEND - [F:FLU]DPRCUMEND
    [M:FLIS]DPE(I)       = [F:FLU]DPE
    I += 1
  Next
  [M:FLIS]CUR = [F:CNX]CUR

  # close tables
  If clalev([F:FLU]) <> 0 Then : Close Local File [FLU] : Endif
  If clalev([F:FAS]) <> 0 Then : Close Local File [FAS] : Endif
  If clalev([F:DEP]) <> 0 Then : Close Local File [DEP] : Endif
  If clalev([F:GAC]) <> 0 Then : Close Local File [GAC] : Endif
  If clalev([F:CNX]) <> 0 Then : Close Local File [CNX] : Endif

  # count
  [M:FLIS]BASPAG = I
  nolign = I
  # reset the table
  Affzo [M:FLIS]10

  Call TEMPOFF() From GESECRAN
End
