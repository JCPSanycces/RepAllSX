#<AdxTL>@(#)0.0.0.0 $Revision$ Object management PICF

$ACTION
Case ACTION
  When "OUVRE"          : Gosub OUVRE
  When "LIENS"          : Gosub LIENS
  When "CREATION"       : Gosub CREATION
  When "MODIF"          : Gosub MODIF
  When "VERIF_CRE"      : Gosub VERIF_CRE
  When "VERIF_MOD"      : Gosub VERIF_MOD
 When Default
Endcase
Return

$OUVRE
  If clalev([F:PIES])=0       : Local File PIHRMEMPSET    [PIES]      : Endif
  If clalev([F:PIFS])=0       : Local File PIHRMFAIRSET   [PIFS]      : Endif
  If clalev([F:PICF])=0       : Local File PIHRMFAIRCFG   [PICF]      : Endif
Return

$LIENS
Local Integer I,K

#Updating setup
Read [PIFS]PIFS0 = [F:PICF]COD
If !fstat
  [M:PICF1] = [F:PIFS]
Endif

#Updating service type selection
nolign = 0
For I = 1 To len(mess(0,11817,1))
  nolign += 1
  K=nolign
  [M:PICF1]SRVTYP(nolign-1) = K
  [M:PICF1]SRVINC(nolign-1) = [F:PIFS]SRVINC(nolign-1)
Next
Assign "[M:PICF1]NBRSRV" With nolign

#Updating service ID's
Filter [PIES] Where COD = [F:PICF]COD
nolign = 0
For [PIES]PIES0
  nolign += 1
  [M:PICF2] = [F:PIES]
Next
Assign "[M:PICF2]NBREMP" With nolign
Filter [PIES]




Affzo [M:PICF1]
Affzo [M:PICF2]
Return

$VERIF_MOD
$VERIF_CRE
Local Char PAYSTRDAT(10)
Local Char PAYENDDAT(10)
Local Integer I
Local Integer FOUND_SRV

#Check that at least one service type has been defined
If [M:PICF1]NBRSRV = 0
  mkstat = 2
  GERR = 1
  GMESSAGE = mess(00012,11820,1)
Else
  For I = 1 To [M:PICF1]NBRSRV
    If [M:PICF1]SRVINC(I-1) = 2 #Included
      FOUND_SRV = 2
    Endif
  Next
  If FOUND_SRV <> 2
    mkstat = 2
    GERR = 1
    GMESSAGE = mess(00012,11820,1)
  Endif
Endif

PAYSTRDAT = num$(year([M:PICF1]BATCFGSTR))+"-"+num$(month([M:PICF1]BATCFGSTR))+"-"+num$(day([M:PICF1]BATCFGSTR))
PAYENDDAT = num$(year([M:PICF1]BATCFGEND))+"-"+num$(month([M:PICF1]BATCFGEND))+"-"+num$(day([M:PICF1]BATCFGEND))

#Set payroll batch config
[M:PICF1]PAYBATCFG = '{"config":{"startDate":"'+PAYSTRDAT+'","endDate":"'+PAYENDDAT+'","pageSize":'+num$([M:PICF1]PAGSIZ)+'}}'
Return

$CREATION
$MODIF
Local Integer I
Filter [F:PIFS]
Delete [F:PIFS] Where [F:PIFS]COD=[M:PICF0]COD or [F:PIFS]COD = ""
If fstat=1 | fstat>5
  GOK=0 : Call RSTA("PIFS",[M:PICF0]COD) From GLOCK : Return
Endif

Filter [F:PIES]
Delete [F:PIES] Where [F:PIES]COD=[M:PICF0]COD or [F:PIES]COD = ""
If fstat=1 | fstat>5
  GOK=0 : Call RSTA("PIES",[M:PICF0]COD) From GLOCK : Return
Endif


[F:PIFS]COD = [M:PICF0]COD
[F:PIFS]    = [M:PICF1]
#Service Selection
For I = 1 To [M:PICF1]NBRSRV
  [F:PIFS]SRVTYP(I-1) = [M:PICF1]SRVTYP(I-1)
  [F:PIFS]SRVINC(I-1) = [M:PICF1]SRVINC(I-1)
Next
Write [F:PIFS]
If fstat
  GOK=0 : Call FSTA("PIFS") From GLOCK
  Return
Endif

For nolign = 1 To [M:PICF2]NBREMP
  Raz [F:PIES]
  [F:PIES]COD = [M:PICF0]COD
  [F:PIES]    = [M:PICF2]
  Write [F:PIES]
  If fstat
    GOK=0 : Call FSTA("PIES") From GLOCK
    Return
  Endif
Next
Return


Subprog C_PAGSIZ(VALEUR)
Variable Decimal VALEUR
Local Integer MAX_PAGE
[L]MAX_PAGE = 6500
#The page size will be hard coded, at this stage (2017-07-05), we don't want to be configured by the user
If VALEUR > 6500
  mkstat = 2
  GMESSAGE = mess(00013,11820,1)-num$(MAX_PAGE)
Endif

#Negative value check
If VALEUR < 0
  mkstat = 2
  GMESSAGE = mess(00001,00175,1)
Endif
End


Subprog C_BPCID(VALEUR)
Variable Char    VALEUR()
#Manual check of length not to display actual value on screen 245
If len(VALEUR) > 245
  mkstat = 2
  GMESSAGE = mess(00014,11820,1)-num$(VALEUR)
Endif
End

Subprog C_BPCSCT(VALEUR)
Variable Char    VALEUR()
End

Subprog C_USR(VALEUR)
Variable Char    VALEUR()
End

Subprog C_PWD(VALEUR)
Variable Char    VALEUR()
End

Subprog C_TIMSEC(VALEUR)
Variable Decimal VALEUR
#Negative value check
If VALEUR < 0
  mkstat = 2
  GMESSAGE = mess(00001,00175,1)
Endif
End


Subprog C_BATCFGSTR(VALEUR)
Variable Date    VALEUR
If [M:PICF1]BATCFGEND <> [00/00/00]
  If VALEUR > [M:PICF1]BATCFGEND
    GMESSAGE = mess(00216,10702,1) #Start date later than end date
    mkstat = 2
  Endif
Endif
End

Subprog C_BATCFGEND(VALEUR)
Variable Date    VALEUR
If [M:PICF1]BATCFGSTR <> [00/00/00]
  If VALEUR < [M:PICF1]BATCFGSTR
    GMESSAGE = mess(00217,10702,1)  #End date earlier than start date
    mkstat = 2
  Endif
Endif
End

