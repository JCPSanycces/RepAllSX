#<AdxTL>@(#)0.0.0.0 $Revision$
$TRANOTE
Gosub OPEN_LNK_TNH From SAFTGENPORMG
For [MGT5]
    Read [F:PTDK2]DKD0="SAFT-PT";[F:PTTNH]TNHTYP;[F:PTTNH]TNHNUM
    Call LEC_TTN_LEG([F:PTFCY]LEG, [F:PTTNH]TNHTYP, STAT) From TRTLECLEG
    If [L]SAFTTYPE = 8
      If [F:PTTNH]BPCBPS=1 & [F:PTBPR]LEGETT=2 : Goto NEXTTNH2 : Endif
      If !find([F:PTDK2]RECTYP,1)      : Goto NEXTTNH2 : Endif
      If !STAT & [F:TSD]SAFTTRNTYP = 3 : Goto NEXTTNH2 : Endif
      If func PORLEGLIB1.CTRL_COMDAT([F:PTTNH]FCY,[F:PTTNH]DPEDAT,[F:PTTNH]ETD)<>1 : Goto NEXTTNH2 : Endif
    Endif
    Gosub RAZVAR_MG From SAFTGENPORMG
    Gosub FEED_VARS
    $NEXTTNH2
Next
Gosub CLOSE_LNK_TNH From SAFTGENPORMG
Return

$FEED_VARS
#DocumentNumber
Call PTNUMDOC([F:PTTNH]TNHTYP,[F:PTTNH]TNHNUM,[L]MGDOCNUMB) From SAFTGENPORMG

#ATCUD
[L]MGATCUD = "0"

#MovementStatuts
[L]MGMOVSTAT = 'N'

#SystemEntryDate, Reason, SourceID(Modification), Hash, HashControl, SourceID(Creation), ATDocCodeID, SourceBilling
If [F:TSD]RECTYP=4 #External document
  Call DOCSTAT([F:PTTNH]TNHTYP,[F:PTTNH]TNHNUM,[F:PTTNH]TRNDAT,2,[L]MGHASHCOD,[L]MGHSHCONT,[L]MGSYSENTD,[L]MGCREUSER,
&              [L]MGATCODID,[L]MGSOURCEB,[L]MGMOVTYPE) From SAFTGENPORMG
Else #Other
  Call DOCSTAT([F:PTTNH]TNHTYP,[F:PTTNH]TNHNUM,[F:PTTNH]TRNDAT,1,[L]MGHASHCOD,[L]MGHSHCONT,[L]MGSYSENTD,[L]MGCREUSER,
&              [L]MGATCODID,[L]MGSOURCEB,[L]MGMOVTYPE) From SAFTGENPORMG
Endif

#MovementType
# RMA * Do not change, this is for previous cases when we didn't have SAFTTRNTYP on DKSDATA
If [L]MGMOVTYPE=''
  Call MANDOC_TEXT_GT([F:TTN]RECTYP,[F:TTN]SAFTTRNTYP,[L]MGMOVTYPE) From PORLEGLIB
Endif

#SourceID(Creation) - When there isn't any record on DKSDATA
If [L]MGCREUSER = ''
  [L]MGCREUSER = [F:PTTNH]CREUSR
Endif

#MovementStatusDate
[L]MGMOVSTDT = [L]MGSYSENTD

#SourceID -> DocumentStatus
[L]MGUPDUSER = [L]MGCREUSER

#Period
[L]MGPERIODE  = func SAFTGENPOR.GET_PERIOD_NUMBER([F:PTTNH]CPY, [F:PTTNH]TRNDAT)

#MovementDate
[L]MGMOVEDAT  = format$("D:YYYY[-]MM[-]DD",[F:PTTNH]TRNDAT)

#TransactionID
If [L]SAFTTYPE=2
  Filter [F:PTSTJ] Where VCRNUM=[F:PTTNH]TNHNUM & STOFCY= [F:PTTNH]FCY
  Read [F:PTSTJ] First
  If !fstat
    [L]MGTRANSID = [F:PTSTJ]NUMVCR
  Endif
  Filter [F:PTSTJ]
Endif

#CustomerID
If [F:PTTNH]BPCBPS=1
  [L]MGCUSTOID = [F:PTTNH]BPRNUM
  [L]MGSUPPLID = ""
Elsif [F:PTTNH]BPCBPS=2
  [L]MGCUSTOID = ""
  [L]MGSUPPLID = [F:PTTNH]BPRNUM
Endif
#SupplierID

#MovementComments
[L]MGCOMMENT = ""
#DeliveryID
#Issue X3-90614 – 2018-05-29 2018.R5 - Insert the tag <DeliveryID> with value vehicle...
[L]MGDELIVID = vireblc([F:PTTNH]LICPLATE-[F:PTTNH]TRLLICPLATE, 2)
If [L]MGDELIVID = ""
  [L]MGDELIVID = "Desconhecido"
Endif
#DeliveryDate
[L]MGDELIVDT = [F:PTTNH]DPEDAT
#Issue end
#LocationID
[L]MGLOCATID = ""
#BuildingNumber
[L]MGBUIDNBR = "Desconhecido"
#ShipTo
#WarehouseID
[L]MGWAREHID_ST = ""

#StreetName,AddressDetail,City,PostalCode,Region
If ctrans([F:PTTNH]BPDADDLIG(0)+[F:PTTNH]BPDADDLIG(1)+[F:PTTNH]BPDADDLIG(2)," ","")<>''
  [L]MGSTREETN_ST = ''
  [L]MGADDDETA_ST = vireblc([F:PTTNH]BPDADDLIG(0)-[F:PTTNH]BPDADDLIG(1)-[F:PTTNH]BPDADDLIG(2),2)
  [L]MGCITY_ST    = vireblc([F:PTTNH]BPDCTY,2)
  [L]MGPOSTCOD_ST = vireblc([F:PTTNH]BPDPOSCOD,2)
  [L]MGCOUNTRY_ST = vireblc([F:PTTNH]BPDCRY,2)
  [L]MGREGION_ST  = vireblc([F:PTTNH]BPDSAT,2)
Else
  Call ADDRESS(1,[F:PTTNH]BPRNUM,[F:PTTNH]BPAADD,[L]MGSTREETN_ST,[L]MGADDDETA_ST,[L]MGCITY_ST,[L]MGPOSTCOD_ST,[L]MGCOUNTRY_ST,[L]MGREGION_ST) From SAFTGENPORMG
Endif

If [L]MGADDDETA_ST  = '' : [L]MGADDDETA_ST  = 'Desconhecido' : Endif
If [L]MGCITY_ST     = '' : [L]MGCITY_ST     = 'Desconhecido' : Endif
If [L]MGPOSTCOD_ST  = '' : [L]MGPOSTCOD_ST  = '0000000'      : Endif
If [L]MGREGION_ST   = '' : [L]MGREGION_ST   = 'Desconhecido' : Endif
If [L]MGCOUNTRY_ST  = '' : [L]MGCOUNTRY_ST  = 'PT'           : Endif

If [L]MGCOUNTRY_ST <> "PT" & [L]SAFTTYPE = 8 : Return : Endif

If len([L]MGPOSTCOD_ST) = 7 & [L]MGCOUNTRY_ST = 'PT'
  [L]MGPOSTCOD_ST = format$("K:4#[-]3#", [L]MGPOSTCOD_ST)
Endif

#ShipFrom
#WarehouseID
[L]MGWAREHID_SF = [F:PTTNH]FCY
#StreetName,AddressDetail,City,PostalCode,Region
# Issue X3-3575 - 2016-09-22 by RICAR : Allow to change the ship from address on transportation notes
# Issue X3-3575
If ctrans([F:PTTNH]SHIFRMADDLIG(0)+[F:PTTNH]SHIFRMADDLIG(1)+[F:PTTNH]SHIFRMADDLIG(2)," ","")<>''
  [L]MGSTREETN_SF = ''
  [L]MGADDDETA_SF = vireblc([F:PTTNH]SHIFRMADDLIG(0)-[F:PTTNH]SHIFRMADDLIG(1)-[F:PTTNH]SHIFRMADDLIG(2),2)
  [L]MGCITY_SF    = vireblc([F:PTTNH]SHIFRMCTY,2)
  [L]MGPOSTCOD_SF = vireblc([F:PTTNH]SHIFRMPOSCOD,2)
  [L]MGCOUNTRY_SF = vireblc([F:PTTNH]SHIFRMCRY,2)
  [L]MGREGION_SF  = vireblc([F:PTTNH]SHIFRMSAT,2)

  If [L]MGADDDETA_SF  = '' : [L]MGADDDETA_SF  = 'Desconhecido' : Endif
  If [L]MGCITY_SF     = '' : [L]MGCITY_SF     = 'Desconhecido' : Endif
  If [L]MGPOSTCOD_SF  = '' : [L]MGPOSTCOD_SF  = '0000000'      : Endif
  If [L]MGREGION_SF   = '' : [L]MGREGION_SF   = 'Desconhecido' : Endif
  If [L]MGCOUNTRY_SF  = '' : [L]MGCOUNTRY_SF  = 'PT'           : Endif

  If len([L]MGPOSTCOD_SF) = 7 & [L]MGCOUNTRY_SF = 'PT'
    [L]MGPOSTCOD_SF = format$("K:4#[-]3#", [L]MGPOSTCOD_SF)
  Endif
Else
  Call ADDRESS(3,[F:PTTNH]FCY,[F:PTFCY]BPAADD,[L]MGSTREETN_SF,[L]MGADDDETA_SF,[L]MGCITY_SF,[L]MGPOSTCOD_SF,[L]MGCOUNTRY_SF,[L]MGREGION_SF) From SAFTGENPORMG
Endif

If [L]MGCOUNTRY_SF <> "PT" & [L]SAFTTYPE = 8 : Return : Endif
# End issue X3-3575

#MovementEndTime
If [F:PTTNH]ARVDAT<>[0/0/0] & [F:PTTNH]ETA<>"0000"
  [L]MGMOVENDT = format$("D:YYYY[-]MM[-]DD",[F:PTTNH]ARVDAT)+"T"+format$("hh[:]mm[:]ss",ctrans([F:PTTNH]ETA,":","")+"00")
Endif
#MovementStartTime
If [F:PTTNH]DPEDAT<>[0/0/0] & [F:PTTNH]ETD<>"0000"
  [L]MGMOVSTRT = format$("D:YYYY[-]MM[-]DD",[F:PTTNH]DPEDAT)+"T"+format$("hh[:]mm[:]ss",ctrans([F:PTTNH]ETD,":","")+"00")
Else
  Call ECR_TRACE (mess(237,7711,1)-[F:PTTNH]TNHNUM-mess(236,7711,1), 1) From GESECRAN
Endif

#Gosub SET_TZ From PORLEGLIB1

#VEHICLEID
[L]VEHICLEID = [F:PTTNH]LICPLATE+[F:PTTNH]TRLLICPLATE

If [L]SAFTWAY=1
 Gosub WRITE_MOVEG_H From SAFTGENPORMG
Endif

For [F:PTTND] Where [F:PTTND]TNHNUM=[F:PTTNH]TNHNUM
  #LineNumber
  #[L]MGDLINNBR = [F:PTTND]TNDLIN
  [L]MGDLINNBR += 1
  #OriginatingON,OrderDate
  [L]MGDORIGIN  = ""

  If [F:PTTNH]GLBDOCNUM<>''
    [L]MGDORIGIN=[F:PTTNH]GLBDOCNUM
    If !instr(1,[L]MGDORIGIN," ")
        Call SET_ORIGON([L]MGDORIGIN) From SAFTGENPORMG
    Endif
    [L]MGDORDDAT=[F:PTTNH]GLBDOCDAT
  Endif
#  #-

  #ProductCode
  [L]MGDPRODUC = [F:PTTND]ITMREF
  #ProductDescription
  [L]MGDPRODES = [F:PTTND]ITMDES
  #Quantity
  [L]MGDQUANTI  = [F:PTTND]QTY
  #UnitOfMeasure
  [L]MGDUOM    = [F:PTTND]UOM
  #UnitPrice
  [L]MGDNETPRI = 0
  #Description
  [L]MGDLINDES = [F:PTTND]ITMDES

  #DebitAmount/CreditAmount
#  If [F:PTTND]NETPRINOT<0
#    [L]MGDDEBAMT = abs([F:PTTND]QTY * ([F:PTTND]NETPRINOT*[F:PTTNH]CHGRAT))
#  Else
#    [L]MGDCREAMT = abs([F:PTTND]QTY * ([F:PTTND]NETPRINOT*[F:PTTNH]CHGRAT))
#  Endif
#  If abs([F:PTTND]NETPRINOT)<>0
#    #TaxType,TaxCountryRegion,TaxCode,TaxPercentage,TaxExemptionReason
#    For YC = 0 To 0  #Alterar?
#     If [F:PTTND]VAT(YC)<>""
#        Call GETTAX([L]SOC,[F:PTTND]VAT(YC),[F:PTTNH]TRNDAT,[L]MGDTAXTYP,[L]MGDTAXCOU,[L]MGDTAXCOD,[L]MGDTAXPER,[L]MGDTAXEXA) From SAFTGENPORVAT
#     Endif
#    Next
#  Endif
  #SettlementAmount
  #[L]MGDSETAMT  =   (([F:PTTND]GROPRI-[F:PTTND]NETPRINOT)*[F:PTTNH]CHGRAT)*[F:PTTND]QTY

  If [L]SAFTWAY=1
    Gosub WRITE_MOVEG_D From SAFTGENPORMG
  Else
    Gosub FEED_VAR_WS From PORLEGLIB1
  Endif
Next

##TaxPayable
#[L]MGTTAXPAY = [F:PTTNH]DLVINVATIL-[F:PTTNH]DLVINVNOTL
##NetTotal
#[L]MGTNETTOT = [F:PTTNH]DLVINVNOTL
##GrossTotal
#[L]MGTGROTOT = [F:PTTNH]DLVINVATIL
##CurrencyAmount
#[L]MGTCURAMT = [F:PTTNH]DLVINVATI

[L]MGTCURCOD = ''

If [L]SAFTWAY=1
 Gosub WRITE_MOVEG_T From SAFTGENPORMG
Endif

Return

