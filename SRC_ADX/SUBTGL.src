#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion du fichier TGRLIS
Call OBJET ("TGL", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "RAZCRE"       : Gosub RAZCRE
    When "RAZDUP"       : Gosub RAZDUP
    When "SETBOUT"      : Gosub SETBOUT
    When "LIENS"        : Gosub LIENS
    When "FERME"        : Gosub FERME
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "CREATION"     : Gosub CREATION
    When "MODIF"        : Gosub MODIF
    When "ANNULE"       : Gosub ANNULE
    When "APRES_CRE"    : Gosub APRES_CRE
    When "APRES_MOD"    : Gosub APRES_MOD
    When "AV_ANNULE"    : Gosub AV_ANNULE
    When "ABANDON"      : Gosub ABANDON
    When default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Integer GITGLFGVCTL
Global Char GSZTGLBID

  GITGLFGVCTL = 0
  GSZTGLBID = ""
Return

##########################################################################################################
$FERME
  Kill GITGLFGVCTL
  Kill GSZTGLBID
Return

##########################################################################################################
$SETBOUT
  Case REP
    When ""
      If [M:TGL0]TGRTAB <> "" Then
        CHMEN += "IN"
      Endif
      If [M:TGL2]NBFIE = 0 Then
        Call VIREBOUT(CHAINE,"B") From GOBJET    
      Endif
    When "M", "C", "D"
      Call VIREBOUT(CHAINE,"B") From GOBJET    
    When Default
  Endcase
  If GPILNAV <> 1 Then
    Call VIREBOUT(CHAINE,"B") From GOBJET
  Endif
  Call VIREBOUT(CHAINE,"H") From GOBJET    
Return

##########################################################################################################
$RAZCRE
  [M:TGL2]FIESRTTYP = 1
  Affzo [M:TGL2]FIESRTTYP
Return

##########################################################################################################
$RAZDUP
  Raz [M:TGL0]TGRNAMAXX
  Raz [M:TGL1]
  Raz [M:TGL2]
  Raz [M:TGL3]
  Call AM_TGRTAB([M:TGL0]TGRTAB)
Return

##########################################################################################################
$LIENS
  #Charge une description standard ou personnalisée des champs
  Call LOADFIE([M:TGL0]TGRTAB, [M:TGL2]TGRSSPDEF) From SUBTGLB
  Call LOADSRT([M:TGL0]TGRTAB, [M:TGL2]TGRSSPDEF) From SUBTGLB
  #Charge une description des tables liées
  Call LOADLNK([M:TGL0]TGRTAB) From SUBTGLB
  Call SETTABSRT([M:TGL2]FIESRT) From SUBTGLB
  Affzo [M:TGL1]1-99
  Affzo [M:TGL2]1-99
  Affzo [M:TGL3]1-99
Return

##########################################################################################################
$VERIF_CRE_MOD
  If [M:TGL2]TABSRT = "" Then
    #La table de tri n'est pas indiquée.
    GMESSAGE = mess(602,196,1)
    GERR = 3
    OK = 0
    Return
  Endif
  # Vérifie la présence du champ de tri dans les quinzes premières lignes du tableau des champs affichés
  Gosub CHKFIESRT From SUBTGLB
Return

##########################################################################################################
$VERIF_CRE
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return
##########################################################################################################
$VERIF_MOD
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$CREATION_MODIF
  # FGR 03/03/2009 : X3SUIVI52963 Texte traduisible
  Call MAJTEXTRA([M:TGL0]TGRNAMAXX, "TGRLIS", "TGRNAMAXX", [M:TGL0]TGRTAB, "") From ATEXTRA
  #Enregistre une description standard ou personnalisée des champs
  Gosub SAVEFIE From SUBTGLB
  #Enregistre une description des tables liées
  Gosub SAVELNK From SUBTGLB
Return

##########################################################################################################
$CREATION
  Gosub CREATION_MODIF
Return

##########################################################################################################
$MODIF
  Gosub CREATION_MODIF
Return

##########################################################################################################
$ANNULE
  # FGR 03/03/2009 : X3SUIVI52963 Texte traduisible
  Call SUPTEXTRA("TGRLIS", "TGRNAMAXX", [M:TGL0]TGRTAB, "") From ATEXTRA
Return

##########################################################################################################
$APRES_CRE
  #Charge une description standard ou personnalisée des champs
  Call LOADFIE([M:TGL0]TGRTAB, [M:TGL2]TGRSSPDEF) From SUBTGLB
  Call LOADSRT([M:TGL0]TGRTAB, [M:TGL2]TGRSSPDEF) From SUBTGLB
  #Charge une description des tables liées
  Call LOADLNK([M:TGL0]TGRTAB) From SUBTGLB
  #Crée un support de sélection de type Tous, s'il n'en existe pas pour la cible.
  Gosub CRESSP3 From SUBTGLB
  #Crée un support de sélection de type Premier niveau, s'il n'en existe pas pour la cible.
  Gosub CRESSP4 From SUBTGLB
  Affzo [M:TGL2]1-99
  Affzo [M:TGL3]1-99
  GITGLFGVCTL = 0
Return

##########################################################################################################
$APRES_MOD
  #Charge une description standard ou personnalisée des champs
  Call LOADFIE([M:TGL0]TGRTAB, [M:TGL2]TGRSSPDEF) From SUBTGLB
  Call LOADSRT([M:TGL0]TGRTAB, [M:TGL2]TGRSSPDEF) From SUBTGLB
  #Charge une description des tables liées
  Call LOADLNK([M:TGL0]TGRTAB) From SUBTGLB
  Affzo [M:TGL2]1-99
  Affzo [M:TGL3]1-99
  GITGLFGVCTL = 0
Return

##########################################################################################################
$AV_ANNULE
  Filter [TLF]
  Delete [TLF] Where [F:TLF]TGRTAB = [M:TGL0]TGRTAB
  If fstat Then
    GOK = 0
    Call FSTA("TLF") From GLOCK
  Endif
  Filter [TLL]
  Delete [TLL] Where [F:TLL]TGRTAB = [M:TGL0]TGRTAB
  If fstat Then
    GOK = 0
    Call FSTA("TLL") From GLOCK
  Endif
  Filter [SSP] Where [F:SSP]SPTTGR = [M:TGL0]TGRTAB
  For [SSP] SSP1
    Delete [SSC] Where [F:SSC]SPTNUM = [F:SSP]SPTNUM
    If fstat Then
      GOK = 0
      #Erreur lors de la suppression des composants des supports de sélection associés à la cible.
      Call FSTA("SSC") From GLOCK
      Break
    Endif
  Next
  Filter [SSP]
Return

##########################################################################################################
$ABANDON
  If GITGLFGVCTL Then
    #Supprime le support de présentation créé lors de la saisie de la cible
    If [M:TGL2]TGRSSPDEF <> "" Then
      Call DEBTRANS From GLOCK
      Trbegin [TGP]
      Delete [TGP] Where [F:TGP]TGRSSPNUM = [M:TGL2]TGRSSPDEF and [F:TGP]SPTDEF = 1
      If fstat Then
        Rollback
      Else
        Commit
      Endif
    Endif
    GITGLFGVCTL = 0
  Endif
Return

##########################################################################################################
Subprog AM_TGRTAB(VALEUR)
Variable Char    VALEUR()

Local Char SZABRTGR
Local Integer IERR
Local Char SZTEXTE(GLONDCO)

  SZABRTGR = ""
  IERR = 0
  [M:TGL0]TGRTAB = VALEUR
  If VALEUR = "" Then
    [M:TGL0]TGRNAMAXX = ""
  Else
    Read [FID]FID0=[M:TGL0]TGRTAB;GAUSCRMI
    If fstat Then
      Read [FID]FID0=[M:TGL0]TGRTAB;""
      If fstat Then
        Read [ATB]CODFIC=[M:TGL0]TGRTAB
        If fstat Then
          [M:TGL0]TGRNAMAXX = [M:TGL0]TGRTAB
        Else    
          SZABRTGR = [F:ATB]ABRFIC
          Call TEXTE([F:ATB]INTITFIC, [M:TGL0]TGRNAMAXX) From OBJDIV
        Endif
      Else
        Call LECTEXTRA(SZTEXTE, "FIEDIC", "CRITABAXX", [F:FID]CRITAB, [F:FID]CAT) From ATEXTRA
        If SZTEXTE = "" Then
          Read [ATB]CODFIC=[M:TGL0]TGRTAB
          If fstat Then
            [M:TGL0]TGRNAMAXX = [M:TGL0]TGRTAB
          Else    
            SZABRTGR = [F:ATB]ABRFIC
            Call TEXTE([F:ATB]INTITFIC, [M:TGL0]TGRNAMAXX) From OBJDIV
          Endif
        Else
          [M:TGL0]TGRNAMAXX = SZTEXTE
        Endif
      Endif
    Else
      Call LECTEXTRA(SZTEXTE, "FIEDIC", "CRITABAXX", [F:FID]CRITAB, [F:FID]CAT) From ATEXTRA
      If SZTEXTE = "" Then
        Read [ATB]CODFIC=[M:TGL0]TGRTAB
        If fstat Then
          [M:TGL0]TGRNAMAXX = [M:TGL0]TGRTAB
        Else    
          SZABRTGR = [F:ATB]ABRFIC
          Call TEXTE([F:ATB]INTITFIC, [M:TGL0]TGRNAMAXX) From OBJDIV
        Endif
      Else
        [M:TGL0]TGRNAMAXX = SZTEXTE
      Endif
    Endif
  Endif
  #Défini une clé primaire par défaut et le champ de tri
  Filter [ATI] Where [F:ATI]CODFIC = [M:TGL0]TGRTAB
  For [ATI]
    If !instr(1, [F:ATI]DESCRIPT, "+") Then
      If [F:ATI]HOMONYM = 1 Then
        [M:TGL3]TGRMAIKEY = [F:ATI]DESCRIPT
        [M:TGL2]FIESRT = [F:ATI]DESCRIPT
        [M:TGL2]TABSRT = [M:TGL0]TGRTAB
        [M:TGL2]FIESRTTYP = 1
        Break
      Endif
    Endif
  Next
  Filter [ATI]
  #Défini un objet associé par défaut
  [M:TGL3]TGRAOB = ""
  Filter [ATY] Where [F:ATY]FICLIEN = [M:TGL0]TGRTAB
  For [ATY]
    If [M:TGL3]TGRAOB = "" Then
      [M:TGL3]TGRAOB = [F:ATY]OBJLIEN
    Else
      If [F:ATY]OBJLIEN = SZABRTGR Then
        [M:TGL3]TGRAOB = [F:ATY]OBJLIEN
      Endif
    Endif
  Next
  Filter [ATY]
  If [M:TGL3]TGRAOB = "" Then
    Filter [AOB] Where [F:AOB]NOMFIC = [M:TGL0]TGRTAB
    For [AOB]NOMFIC
      If [M:TGL3]TGRAOB = "" Then
        [M:TGL3]TGRAOB = [F:AOB]ABREV
      Else
        If [F:AOB]ABREV = SZABRTGR Then
          [M:TGL3]TGRAOB = [F:AOB]ABREV
        Endif
      Endif
    Next
    Filter [AOB]
  Endif
  #Créé le support de présentation par défaut, s'il n'existe pas.
  Call CRETGPDEF([M:TGL0]TGRTAB, IERR) From SUBTGLB
  If IERR Then
    #Erreur lors de la création du support de présentation par défaut associé à la cible.
    GMESSAGE = mess(762,196,1)
    GERR = 1
  Endif
  #Charge la description des champs affichés
  If !IERR Then
    If [M:TGL2]TGRSSPDEF <> "" Then
      Call LOADFIE([M:TGL0]TGRTAB, [M:TGL2]TGRSSPDEF) From SUBTGLB
    Endif
  Endif
  #Défini un champ de tri si une clé primaire n'a pas été trouvée
  If [M:TGL3]TGRMAIKEY = "" Then
    If [M:TGL2]NBFIE > 0 Then
      [M:TGL2]FIESRT = [M:TGL2]TGRFIE(0)
      [M:TGL2]TABSRT = [M:TGL2]TGRTABLNK(0)
      [M:TGL2]FIESRTTYP = 1
    Endif
  Endif
  Affzo [M:TGL0]1-99
  Affzo [M:TGL1]1-99
  Affzo [M:TGL2]1-99
  Affzo [M:TGL3]1-99
End

##########################################################################################################
Subprog C_TGRFIE(VALEUR)
Variable Char    VALEUR()

Local Integer IZ
Local Integer INOL
Local Integer INBOCC
Local Integer IBRETOUR
Local Char SZMESSAGE(250)
Local Char SZLEFTCRIFIE(GLONAVA)

  INOL = nolign-1
  INBOCC = [M:TGL2]NBFIE-1
  # FGR 12/01/2009 : X3SUIVI51579
  Call CTRL_CHAMP_TABLE ([M:TGL2]TGRTABLNK(INOL), VALEUR, SZLEFTCRIFIE, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If IBRETOUR = 0 Then
    GMESSAGE = SZMESSAGE
    mkstat = 2
    GERR = 1
    End
  Else
    #Vérifie si le champ n'a pas déjà été préalablement saisi dans le tableau
    For IZ = 0 To INBOCC
      If IZ <> INOL Then
        If [M:TGL2]TGRFIE(IZ) = VALEUR and [M:TGL2]TGRFIE(IZ) <> "" Then
          If [M:TGL2]TGRTABLNK(IZ) = [M:TGL2]TGRTABLNK(nolign-1) Then
            VALEUR = ""
            mkstat = 2
            GMESSAGE = mess(24,123,1) - num$(IZ+1) : # Code déjà existant en ligne
            GERR = 2
          Endif
        Endif
      Endif
      If GERR > 0 Then
        Break
      Endif
    Next
    If GERR Then
      End
    Endif
    If VALEUR <> "" Then
      Read [ATZ]CODZONE=[M:TGL2]TGRTABLNK(nolign-1);SZLEFTCRIFIE
      If fstat Then
        # XX n'est pas un champ de la table : YY
        GMESSAGE = VALEUR - mess(574,196,1) - [M:TGL2]TGRTABLNK(nolign-1)
        GERR = 1
        mkstat = 2
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AM_TGRFIE(VALEUR)
Variable Char    VALEUR()

Local Integer IFIEITER
Local Integer INOLCTL
Local Integer IMAXSRT
Local Char SZTEXTE(100)
Local Char SZLEFTCRIFIE(GLONAVA)

  INOLCTL = nolign-1
  IMAXSRT = 0
  SZTEXTE = ""
  [M:TGL2]TGRFIE(nolign-1) = VALEUR
  # FGR 12/01/2009 : X3SUIVI51579
  SZLEFTCRIFIE = func CRMUTIL150.GET_CHAMP_SSIND([M:TGL2]TGRFIE(nolign-1))
  Read [ATZ]CODZONE=[M:TGL2]TGRTABLNK(nolign-1);SZLEFTCRIFIE
  If fstat Then
    [M:TGL2]TGRFIENAM(nolign-1) = ""
  Else
    Call TEXTE([F:ATZ]NOLONG, SZTEXTE) From OBJDIV
    [M:TGL2]TGRFIENAM(nolign-1) = left$(SZTEXTE, 40)
  Endif
  If [M:TGL2]TGRFIEORD(nolign-1) = 0 Then
    #Calcule une numéro maxi pour le nouveau champs
    For IFIEITER = 0 To dim([M:TGL2]TGRFIE)-1
      If IFIEITER <> INOLCTL Then
        If [M:TGL2]TGRFIE(IFIEITER) <> "" Then
          If [M:TGL2]TGRFIEORD(IFIEITER) > IMAXSRT Then
            IMAXSRT = [M:TGL2]TGRFIEORD(IFIEITER)
          Endif
        Endif
      Endif
    Next
    [M:TGL2]TGRFIEORD(nolign-1) = IMAXSRT + 1
  Endif
  Affzo [M:TGL2]TGRFIE(nolign-1)
  Affzo [M:TGL2]TGRFIENAM(nolign-1)
  Affzo [M:TGL2]TGRFIEORD(nolign-1)
End

##########################################################################################################
Subprog C_FIESRT(VALEUR)
Variable Char    VALEUR()

Local Integer Z2
Local Integer IFIEFOUND
Local Integer IBRETOUR
Local Char SZMESSAGE(250)
Local Char SZLEFTCRIFIE(GLONAVA)

  # FGR 12/01/2009 : X3SUIVI51579
  Call CTRL_CHAMP_TABLE ([M:TGL2]TABSRT, VALEUR, SZLEFTCRIFIE, SZMESSAGE, IBRETOUR) From CRMUTIL150
  If IBRETOUR = 0 Then
    GMESSAGE = SZMESSAGE
    mkstat = 2
    GERR = 1
    End
  Else
    IFIEFOUND = 0
    #Contrôle si le champs fait partie de la liste des champs affichés
    For Z2 = 0 To [M:TGL2]NBFIE-1
      If [M:TGL2]TGRFIE(Z2) = VALEUR Then
        IFIEFOUND = 1
        Break
      Endif
    Next
    If !IFIEFOUND Then
      #Ce champs ne fait pas partie de la liste ci-dessus. Saisie refusée.
      GMESSAGE = mess(750,196,1) - mess(627,196,1)
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

##########################################################################################################
Subprog C_TGRTABLNK(VALEUR)
Variable Char    VALEUR()
Local Integer IFOUND

  IFOUND = 0
  If VALEUR = [M:TGL0]TGRTAB Then
    IFOUND = 1
  Else
    Filter [TLL] Where [F:TLL]TGRTAB = [M:TGL0]TGRTAB
    For [TLL]
      If VALEUR <> "" Then
        If [F:TLL]TGRLNK <> "" Then
          If [F:TLL]TGRLNK = VALEUR Then
            IFOUND = 1
            Break
          Endif
        Endif
      Endif
    Next
    Filter [TLL]
  Endif
  If IFOUND = 0 Then
    #La table indiquée n'a pas été liée avec la cible
    GMESSAGE = mess(600,196,1)
    GERR = 1
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AM_TGRTABLNK(VALEUR)
Variable Char    VALEUR()

  [M:TGL2]TGRFIE(nolign-1) = ""
  [M:TGL2]TGRFIENAM(nolign-1) = ""
  Affzo [M:TGL2]TGRFIE(nolign-1)
  Affzo [M:TGL2]TGRFIENAM(nolign-1)
End

##########################################################################################################
Subprog C_TABSRT(VALEUR)
Variable Char    VALEUR()

Local Integer Z2
Local Integer IFOUND

  IFOUND = 0
  For Z2 = 0 To [M:TGL2]NBFIE-1 
    If [M:TGL2]TGRFIE(Z2) = [M:TGL2]FIESRT Then
      If [M:TGL2]TGRTABLNK(Z2) = VALEUR Then
        IFOUND = 1
        Break
      Endif
    Endif
  Next
  If !IFOUND Then
    #La table indiquée est incorrecte. Saisie refusée.
    GMESSAGE = mess(601,196,1)
    GERR = 1
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AM_FIESRT(VALEUR)
Variable Char    VALEUR()

Local Integer ITER

  [M:TGL2]FIESRT = VALEUR
  If [M:TGL2]FIESRT <> "" Then
    For ITER = 0 To [M:TGL2]NBFIE-1 
      If [M:TGL2]TGRFIE(ITER) = [M:TGL2]FIESRT Then
        [M:TGL2]TABSRT = [M:TGL2]TGRTABLNK(ITER)
        Break
      Endif
    Next
  Endif
  Call SETTABSRT([M:TGL2]FIESRT) From SUBTGLB
  Affzo [M:TGL2]FIESRT
End

##########################################################################################################
Subprog C_TGRLNKIDX(VALEUR)
Variable Char    VALEUR()

Local Char SZCHAR
Local Integer IFOUND

  IFOUND = 0
  #Vérifie si l'index indiqué est défini dans la table
  Filter [ATI] Where [F:ATI]CODFIC = [M:TGL3]TGRLNK(nolign-1)
  For [ATI]
    If VALEUR <> "" Then
      If [F:ATI]CODIND <> "" Then
        If [F:ATI]CODIND = VALEUR Then
          IFOUND = 1
          Break
        Endif
      Endif
    Endif
  Next
  Filter [ATI]
  If !IFOUND Then
    #Cet index n'est pas défini pour la table : 
    GMESSAGE = mess(699,196,1) - [M:TGL3]TGRLNK(nolign-1)
    GERR = 1
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AM_TGRLNKIDX(VALEUR)
Variable Char    VALEUR()

  [M:TGL3]TGRLNKIDX(nolign -1) = VALEUR
  [M:TGL3]TGREXPLNK(nolign -1) = ""
  #Affiche la clé de lien unique par défaut
  Read [ATI]CODIND=[M:TGL3]TGRLNK(nolign-1);[M:TGL3]TGRLNKIDX(nolign-1)
  If !fstat Then
    If !instr(1, [F:ATI]DESCRIPT, "+") Then
      Read [ATB]CODFIC=[M:TGL0]TGRTAB
      If !fstat Then
        If [M:TGL3]TGRMAIKEY <> "" Then
          [M:TGL3]TGREXPLNK(nolign -1) = "[F:" + [F:ATB]ABRFIC + ']' + [M:TGL3]TGRMAIKEY
        Endif
      Endif
    Endif
  Endif
  Affzo [M:TGL3]TGREXPLNK(nolign -1)
End

##########################################################################################################
Subprog C_TGREXPLNK(VALEUR)
Variable Char    VALEUR()

Local Char MSG(250)
Local Char SZVALEUR(250)
Local Integer INBCOMPKEY
Local Integer INBTGL3KEY
Local Integer ISTARTCTL

  INBCOMPKEY = 0
  INBTGL3KEY = 0
  ISTARTCTL = 1
  MSG = ""
  #Vérifie si le nombre de composante de clé est conforme à la clé indiquée.
  #Compte le nombre de composantes de la clé
  Read [ATI]CODIND=[M:TGL3]TGRLNK(nolign-1);[M:TGL3]TGRLNKIDX(nolign-1)
  If !fstat Then
    ISTARTCTL = 1
    While instr(ISTARTCTL, [F:ATI]DESCRIPT, "+")
      INBCOMPKEY += 1
      ISTARTCTL = instr(ISTARTCTL, [F:ATI]DESCRIPT, "+") + 1
    Wend
  Endif
  #Compte le nombre de composantes dans TGL3
  ISTARTCTL = 1
  While instr(ISTARTCTL, VALEUR, ";")
    INBTGL3KEY += 1
    ISTARTCTL = instr(ISTARTCTL, VALEUR, ";") + 1
  Wend
  If INBCOMPKEY <> INBTGL3KEY Then
    #Le nombre de composantes de clé saisies ne correspond pas à l'index précisé. Saisie refusée
    GMESSAGE = mess(715,196,1) - mess(627,196,1)
    GERR = 1
    mkstat = 2
  Endif
  If GERR Then
    End 
  Endif
  SZVALEUR = VALEUR
  Call ANALYSE(SZVALEUR,[M:TGL0]TGRTAB,MSG) From SUBTGLB
  If MSG <> "" Then
    GMESSAGE = MSG
    GERR = 1
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog C_TGRMAIKEY(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    Read [ATZ]CODZONE=[M:TGL0]TGRTAB;VALEUR
    If fstat Then
      # XX n'est pas un champ de la table : YY
      GMESSAGE = VALEUR - mess(574,196,1) - [M:TGL0]TGRTAB
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

##########################################################################################################
Subprog C_TGRAOB(VALEUR)
Variable Char    VALEUR()

  Read [AOB]ABREV=VALEUR
  If fstat Then
    #XXX n'est pas un objet. Saisie refusée.
    GMESSAGE = VALEUR - mess(716,196,1) - mess(627,196,1)
    GERR = 1
    mkstat = 2
  Else
    If [F:AOB]NOMFIC <> [M:TGL0]TGRTAB Then
      #XXX n'est pas associé à la table : NNNNN
      GMESSAGE = VALEUR - mess(717,196,1) - [M:TGL0]TGRTAB
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

##########################################################################################################
Subprog AM_TGRLNK(VALEUR)
Variable Char    VALEUR()

Local Integer IQUIT

  IQUIT = 0
  [M:TGL3]TGRLNK(nolign-1) = VALEUR
  #Propose une clé et une expression de lien par défaut pour la table sélectionnnée
  [M:TGL3]TGRLNKIDX(nolign-1) = ""
  [M:TGL3]TGREXPLNK(nolign-1) = ""
  Filter [SSP] Where [F:SSP]SPTTGR = [M:TGL0]TGRTAB and [F:SSP]SPTTYP = 4 Order By [F:SSP]SPTNUM Asc
  For [SSP] Hint Key SSP1
    Filter [SSC] Where [F:SSC]SPTNUM = [F:SSP]SPTNUM and [F:SSC]SPTTAB = [M:TGL3]TGRLNK(nolign-1)
    For [SSC] SSC1
      If [F:SSC]SPTIDX <> "" Then
        If [F:SSC]SPTFLT <> "" Then
          [M:TGL3]TGRLNKIDX(nolign-1) = [F:SSC]SPTIDX
          [M:TGL3]TGREXPLNK(nolign-1) = [F:SSC]SPTFLT
          IQUIT = 1
        Endif
      Endif
      If IQUIT Then
        Break
      Endif
    Next
    Filter [SSC]
    If IQUIT Then
      Break
    Endif
  Next
  Filter [SSP]
  Affzo TGRLNKIDX(nolign-1), TGREXPLNK(nolign-1)
End

##########################################################################################################
Subprog C_TGRLNK(VALEUR)
Variable Char    VALEUR()

#Vérifie que l'on n'a pas saisie deux fois la même table dans le taleau
Local Integer INOL
Local Integer Z
Local Integer IFOUND

  INOL = nolign-1
  IFOUND = 0
  For Z = 0 To dim([M:TGL3]TGRLNK)-1
    If Z <> INOL Then
      If [M:TGL3]TGRLNK(Z) <> "" Then
        If VALEUR <> "" Then
          If [M:TGL3]TGRLNK(Z) = VALEUR Then
            IFOUND = 1
            Break
          Endif
        Endif
      Endif
    Endif
  Next
  If IFOUND  Then
    mkstat = 2
    #Cette table a déjà été mentionnée dans le tableau. Saisie refusée.
    GMESSAGE = mess(690,196,1) - mess(627,196,1)
    GERR = 1 
  Endif
End

##########################################################################################################
Subprog C_TGRTAB(VALEUR)
Variable Char    VALEUR()

Local Char SZDESCRIPT(100)
Local Integer IFOUND
Local Integer IKEYTYPE

  IKEYTYPE = 0
  SZDESCRIPT = ""
  IFOUND = 0
  If VALEUR = "" Then
    #Zone obligatoire
    GMESSAGE = mess(10,123,1)
    GERR = 1
    mkstat = 2
  Endif
  If GERR Then
    End
  Endif
  #Contrôle tout d'abord si la cible souhaitée comporte une clé par défaut à composante unique.
  Filter [ATI] Where [F:ATI]CODFIC = VALEUR
  For [ATI]
    SZDESCRIPT = [F:ATI]DESCRIPT
    Break
  Next
  Filter [ATI]
  If SZDESCRIPT = "" Then
    #Cette table comporte une structure de clé inadaptée. Saisie refusée.
    GMESSAGE = mess(740,196,1) - mess(627,196,1)
    GERR = 1
    mkstat = 2
  Endif
  If GERR Then
    End
  Endif
  If instr(1, SZDESCRIPT, "+") Then
    #Cette table ne comporte pas une clé primaire à composante unique. Saisie refusée.
    GMESSAGE = mess(741,196,1) - mess(627,196,1)
    GERR = 1
    mkstat = 2
  Endif
  If GERR Then
    End
  Endif
  #Vérifie si le champ indiqué fait partie de la table saisie
  Read [ATZ]CODZONE=VALEUR;SZDESCRIPT
  If fstat Then
    #Le champ indiqué comme clé primaire n'est pas défini dans la table. Saisie refusée.
    GMESSAGE = mess(742,196,1) - mess(627,196,1)
    GERR = 1
    mkstat = 2
  Endif
  If GERR Then
    End
  Endif
  #Véfifie si la longueur de la clé n'excède pas la capacité de stockage de QURTMP
  If [F:ATZ]LONG > 30 Then
    #Le champ de clé primaire de la cible à une longueur supérieure à trente caractères. Saisie refusée.
    GMESSAGE = mess(743,196,1) - mess(627,196,1)
    GERR = 1
    mkstat = 2
  Endif
  If GERR Then
    End
  Endif
  #Contrôle si la clé primaire est bien de type alphanumérique.
  Local File =VALEUR [TYPY]
  IKEYTYPE = evalue("Type([F:TYPY]" + SZDESCRIPT + ")")
  Close Local File [TYPY]
  If IKEYTYPE < 10 Then
    #Cette table ne comporte pas une clé primaire de type alphanumérique. Saisie refusée.
    GMESSAGE = mess(744,196,1) - mess(627,196,1)
    GERR = 1
    mkstat = 2
  Endif
End

##########################################################################################################
Subprog AM_TGRSSPDEF(VALEUR)
Variable Char    VALEUR()

  [M:TGL2]TGRSSPDEF = VALEUR
  #Charge une description standard ou personnalisée des champs
  Call LOADFIE([M:TGL0]TGRTAB, [M:TGL2]TGRSSPDEF) From SUBTGLB
  Call LOADSRT([M:TGL0]TGRTAB, [M:TGL2]TGRSSPDEF) From SUBTGLB
  Affzo [M:TGL2]1-99
End

##########################################################################################################
Subprog IB_NBFIE

  Gosub ACTIVEPSS From SUBTGLB
End

##########################################################################################################
Subprog B1_NBFIE

  Gosub SETPSS From SUBTGLB
End

##########################################################################################################
Subprog AM_TGRFIEORD(VALEUR)
Variable Decimal VALEUR

  #Vérifie si le calcul des positions est activé
  Read [DVA]DVA0="PSS";GUSER
  If fstat Then
    [M:TGL2]TGRFIEORD(nolign-1) = VALEUR
    Affzo [M:TGL2]TGRFIEORD(nolign-1)
    End
  Else
    If [F:DVA]INTX(0) = 0 Then
      [M:TGL2]TGRFIEORD(nolign-1) = VALEUR
      Affzo [M:TGL2]TGRFIEORD(nolign-1)
      End
    Endif
  Endif

  #Maintien une suite logique de numéros d'ordres
Local Integer INOL
Local Integer ITERTAB
Local Integer ITERWHOLE
Local Integer ITERMORE
Local Integer ITERLACK
Local Integer INUMFOUND
Local Integer IMINI
Local Integer ITESTMINI
Local Integer IVALEXIST
Local Integer IHOMONYME
Local Integer IPHOTO(250)
Local Integer ITERPHOTO
Local Integer IMAXPHOTO
Local Integer IGOODINDEX
Local Integer ICOMPUTE(250)
Local Integer ICOUNT
Local Integer IVALPASSED
Local Integer ITEROCC

  INOL = nolign-1
  INUMFOUND = 0
  ITESTMINI = 0
  IMINI = 0
  Call TEMPON(mess(44, 182, 2)) From GESECRAN
  If VALEUR >= dim([M:TGL2]TGRFIEORD) Then
    VALEUR = dim([M:TGL2]TGRFIEORD) - 1
  Endif
  [M:TGL2]TGRFIEORD(nolign-1) = VALEUR
  #Charge IPHOTO
  Raz IPHOTO
  For ITERWHOLE = 0 To dim([M:TGL2]TGRFIEORD)-1
    IPHOTO(ITERWHOLE) = [M:TGL2]TGRFIEORD(ITERWHOLE)
  Next
  For ITERWHOLE = 1 To dim([M:TGL2]TGRFIEORD)-1
    #Compte les occurences de chaque chiffre
    Raz ICOMPUTE
    For ITEROCC = 1 To dim([M:TGL2]TGRFIEORD)-1
      ICOUNT = 0
      For ITERTAB = 0 To [M:TGL2]NBFIE-1
        If [M:TGL2]TGRFIEORD(ITERTAB) = ITEROCC Then
          ICOUNT += 1
        Endif
      Next
      ICOMPUTE(ITEROCC) = ICOUNT
    Next
    #Cherche si VALEUR est égale à ITERWHOLE
    IVALEXIST = 0
    For ITERTAB = 0 To [M:TGL2]NBFIE-1
      If [M:TGL2]TGRFIEORD(ITERTAB) = ITERWHOLE Then
        If ITERTAB = INOL Then
          IVALEXIST = 1
          Break
        Endif
      Endif
    Next
    #Réalise les contrôles nécessaires à la priorité des incrémentations
    If ICOMPUTE(ITERWHOLE) > 1 Then
      If ITERWHOLE <> [M:TGL2]TGRFIEORD(INOL) Then
        #On recherche le chiffre avec le poids initiale le plus fort
        IMAXPHOTO = 0
        For ITERPHOTO = 0 To dim(IPHOTO)-1
          If [M:TGL2]TGRFIEORD(ITERPHOTO) = ITERWHOLE Then
            If IPHOTO(ITERPHOTO) > IMAXPHOTO Then
              IMAXPHOTO = IPHOTO(ITERPHOTO)
              IGOODINDEX = ITERPHOTO
            Endif
          Endif
        Next
      Endif
    Endif
    #Cherche ITERWHOLE dans le tableau
    ITERMORE = ITERWHOLE
    IVALPASSED = 0
    INUMFOUND = 0
    For ITERTAB = 0 To [M:TGL2]NBFIE-1
      If [M:TGL2]TGRFIEORD(ITERTAB) > 0 Then
        If [M:TGL2]TGRFIEORD(ITERTAB) = ITERWHOLE Then
          If ITERTAB = INOL Then
            VALEUR = ITERWHOLE
            [M:TGL2]TGRFIEORD(ITERTAB) = VALEUR
          Else
            If ICOMPUTE(ITERWHOLE) > 1 Then
              If ITERWHOLE = [M:TGL2]TGRFIEORD(INOL) Then
                [M:TGL2]TGRFIEORD(ITERTAB) = ITERWHOLE + 1
              Else
                If ITERTAB = IGOODINDEX Then
                  [M:TGL2]TGRFIEORD(ITERTAB) = ITERWHOLE + 1
                Else
                  [M:TGL2]TGRFIEORD(ITERTAB) = ITERWHOLE
                Endif
              Endif
            Else
              [M:TGL2]TGRFIEORD(ITERTAB) = ITERWHOLE
            Endif
          Endif
          ITERMORE += 1
          INUMFOUND = 1
        Endif
      Endif
    Next
    If !INUMFOUND Then
      #On recherche le chiffre immédiatement supérieur à ITERWHOLE
      IMINI = 250
      INUMFOUND = 0
      For ITERTAB = 0 To [M:TGL2]NBFIE-1
        If [M:TGL2]TGRFIEORD(ITERTAB) > 0 Then
          ITESTMINI = [M:TGL2]TGRFIEORD(ITERTAB) - ITERWHOLE
          If ITESTMINI > 0 Then
            If ITESTMINI < IMINI Then
              IMINI = ITESTMINI
              ITERMORE = [M:TGL2]TGRFIEORD(ITERTAB)
            Endif
          Endif
        Endif
      Next
      #Cherche si VALEUR est égale à ITERMORE
      #Cherche également si un homonyme de valeur est présent
      IVALEXIST = 0
      IHOMONYME = 0
      For ITERTAB = 0 To [M:TGL2]NBFIE-1
        If [M:TGL2]TGRFIEORD(ITERTAB) = ITERMORE Then
          If ITERTAB = INOL Then
            IVALEXIST = 1
          Else
            IHOMONYME = 1
          Endif
        Endif
      Next
      ITERLACK = ITERMORE - IMINI
      For ITERTAB = 0 To [M:TGL2]NBFIE-1
        If [M:TGL2]TGRFIEORD(ITERTAB) = ITERMORE Then
          If ITERTAB = INOL Then
            If IHOMONYME Then
              VALEUR = (ITERMORE - IMINI) + 1
            Else
              VALEUR = ITERMORE - IMINI
            Endif
            [M:TGL2]TGRFIEORD(ITERTAB) = VALEUR
          Else
            If IVALEXIST Then
              If ITERLACK = [M:TGL2]TGRFIEORD(INOL) Then
                ITERLACK += 1
                [M:TGL2]TGRFIEORD(ITERTAB) = ITERLACK
              Else
                [M:TGL2]TGRFIEORD(ITERTAB) = ITERLACK
              Endif
            Else
              [M:TGL2]TGRFIEORD(ITERTAB) = ITERLACK
            Endif
          Endif
          ITERLACK += 1
        Endif
      Next
    Endif
  Next
  Call TEMPOFF From GESECRAN
  Affzo [M:TGL2]1-99
End

##########################################################################################################
Subprog C_TGRSSPDEF(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> "" Then
    Read [TGP]TGP0=VALEUR
    If !fstat Then
      If [F:TGP]TGR <> [M:TGL0]TGRTAB Then
        #Le support de présentation sélectionné est incompatible avec la cible.
        GMESSAGE = mess(65,177,1)
        GERR = 2
        mkstat = 2
        End
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog C_NBLNK
Local Integer INOL
Local Integer INOL2
Local Integer ITERFIE
Local Integer ITERDEL
Local Integer ICANDEL

  ITERDEL = 0
  ITERFIE = 0
  ICANDEL = 1
  If status = 65 Then
    #Effacement d'une seule ligne
    INOL = nolign-1
    INOL2 = nolign-1
  Elsif status = 68 or status = 83 Then
    #Effacement d'un groupe de lignes
    INOL = nolign-1
    INOL2 = nolign1-1
  Endif
  #
  If status = 68 or status = 83 or status = 65 Then
    For ITERDEL = INOL To INOL2
      SZDELTABLE = [M:TGL3]TGRLNK(ITERDEL)
      For ITERFIE = 0 To [M:TGL2]NBFIE-1
        If [M:TGL2]TGRTABLNK(ITERFIE) = SZDELTABLE Then
          ICANDEL = 0
          Break
        Endif
      Next
      If ICANDEL = 0 Then
        Break
      Endif
    Next
    If ICANDEL = 0 Then
      #Cette table est utilisée dans le support de présentation par défaut de la cible. Suppression refusée.
      GMESSAGE = mess(112,177,1)
      GERR = 1
      mkstat = 2
      End
    Endif
    #On recherche l'utilisation de la table dans tous les supports de présentation de la cible
    For ITERDEL = INOL To INOL2
      SZDELTABLE = [M:TGL3]TGRLNK(ITERDEL)
      Filter [TLF] Where [F:TLF]TGRTAB = [M:TGL0]TGRTAB and [F:TLF]TGRTABLNK = SZDELTABLE
      For [TLF]
        ICANDEL = 0
        Break
      Next
      #LSE 12/09/2006 FQ37667
      Filter [TLF]
      If ICANDEL = 0 Then
        Break
      Endif
    Next
    If ICANDEL = 0 Then
      #Cette table est utilisée dans un support de présentation associé à la cible. Suppression refusée.
      GMESSAGE = mess(113,177,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End

##########################################################################################################
$TRTCOP
  #-----------------------------------------------------------#
  # Etiquette appelée depuis le traitement superviseur ACOPIE #
  # --------------------------------------------------------- #
  # Traitement de la copie d'une cible                        #
  #-----------------------------------------------------------#
  If [M]DOSORG = nomap Then
    Local File TGRLIS [TGL1]
    Local File TGRLISFIE [TLF1]
    Local File TGRSSP [TGP1]
    Local File TGRLISLNK [TLL1]
    Local File ATEXTRA [AXX1]
  Else
    Local File =[M]DOSORG+".TGRLIS" [TGL1]
    Local File =[M]DOSORG+".TGRLISFIE" [TLF1]
    Local File =[M]DOSORG+".TGRSSP" [TGP1]
    Local File =[M]DOSORG+".TGRLISLNK" [TLL1]
    Local File =[M]DOSORG+".ATEXTRA" [AXX1]
  Endif
  If [M]DOSDES = nomap Then
    Local File TGRLIS [TGL2]
    Local File TGRLISFIE [TLF2]
    Local File TGRSSP [TGP2]
    Local File TGRLISLNK [TLL2]
    Local File ATEXTRA [AXX2]
  Else
    Local File =[M]DOSDES+".TGRLIS" [TGL2]
    Local File =[M]DOSDES+".TGRLISFIE" [TLF2]
    Local File =[M]DOSDES+".TGRSSP" [TGP2]
    Local File =[M]DOSDES+".TGRLISLNK" [TLL2]
    Local File =[M]DOSORG+".ATEXTRA" [AXX2]
  Endif
  OK = 1
  Look [TGL2]TGL0=TABLE
  If !fstat Then
    OK = 2
    Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
    If OK <> 2 Then
      OK = 0
    Endif
  Endif
  If OK Then
    Call DEBTRANS From GLOCK
    Gosub TRT_COPIE
  Endif
  Close Local File [TGL1], [TLF1], [TGP1], [TLL1],[TGL2], [TLF2], [TGP2], [TLL2], [AXX1], [AXX2]
Return

##########################################################################################################
$TRT_COPIE
  #--------------------------------------------------#
  # Transaction de copie d'une cible                 #
  #--------------------------------------------------#
  GOK = 1
  Trbegin [TGL2]
  Delete [TGL2] Where TGRTAB=TABLE
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$" + [M]DOSDES+".TGRLIS"-TABLE  
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK = 0
    Call RSTA("TGL2",TABLE) From GLOCK   
    Goto AB_COPIE
  Endif
  #
  Delete [TLF2] Where TGRTAB=TABLE
  If fstat = 1 Then
    GOK = -1  
    GLOCK = "$" + [M]DOSDES+".TGRLISFIE"-TABLE  
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK = 0 
    Call RSTA("TLF2",TABLE) From GLOCK   
    Goto AB_COPIE
  Endif
  #
  Delete [TLL2] Where TGRTAB=TABLE
  If fstat = 1 Then
    GOK = -1  
    GLOCK = "$" + [M]DOSDES+".TGRLISLNK"-TABLE  
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK = 0 
    Call RSTA("TLL2",TABLE) From GLOCK   
    Goto AB_COPIE
  Endif
  #
  Read [TGL1]TGL0=TABLE
  If !fstat Then
    [F:TGL2] = [F:TGL1]
    Write [TGL2]
    If fstat Then
      GOK = 0
      Call FSTA("TGL2") From GLOCK  
      Goto AB_COPIE  
    Endif
    # FGR 03/03/2009 : X3SUIVI52963 Texte traduisible
    Call COPTEXTRA("TGRLIS", "TGRNAMAXX", [M:TGL0]TGRTAB, "") From ATEXTRA
    If GOK = 0 Then
      Goto AB_COPIE  
    Endif
  Endif
  #
  Filter [TLF1] Where [F:TLF1]TGRTAB = TABLE
  For [TLF1]
    [F:TLF2] = [F:TLF1]
    Write [TLF2]
    If fstat Then
      GOK = 0  
      Call FSTA("TLF2") From GLOCK  
      Goto AB_COPIE  
    Endif
  Next
  Filter [TLF1]
  #
  Filter [TLL1] Where [F:TLL1]TGRTAB = TABLE
  For [TLL1]
    [F:TLL2] = [F:TLL1]
    Write [TLL2]
    If fstat Then
      GOK = 0  
      Call FSTA("TLL2") From GLOCK  
      Goto AB_COPIE  
    Endif
  Next
  Filter [TLL1]
  #
  Look [TGP2]TGP0=[F:TGL1]TGRSSPDEF
  If fstat Then
    Read [TGP1]TGP0=[F:TGL1]TGRSSPDEF
    [F:TGP2] = [F:TGP1]
    Write [TGP2]
    If fstat Then
      GOK = 0  
      Call FSTA("TGP2") From GLOCK  
      Goto AB_COPIE  
    Endif
  Endif
  #
  Commit
Return

##########################################################################################################
#----- Abandon de la copie -----#
$AB_COPIE
  Rollback 
Return

##########################################################################################################
#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
  Rollback 
  Call ROLL From GLOCK  
  If !GROLL Then
    Goto TRT_COPIE 
  Endif 
Return
