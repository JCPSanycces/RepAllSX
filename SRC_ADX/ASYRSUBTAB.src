End


#****************************************************************************************************************
#* ADELINSTANCE
#*!
Funprog ADELINSTANCE(AINS,WCLA)
Value Char AINS
Variable Instance WCLA Using OBJECT

If [L]AINS="" : End [V]CST_ANOTDEFINED : Endif

Local Integer ASTATUS

[L]ASTATUS = fmet WCLA._ACTION("ADELINSTANCE_BEFORE")
If ([L]ASTATUS>=[V]CST_AERROR) : End [V]CST_ANOTDEFINED : Endif

If evalue( "WCLA."+[L]AINS+".ASTALIN")= [V]CST_ANEW
 Assign  "WCLA."+[L]AINS+".ASTALIN" With [V]CST_ANEWDEL
Else
 Assign "WCLA."+[L]AINS+".ASTALIN" With [V]CST_ADEL
Endif

[L]ASTATUS = evalue("fmet"-'WCLA.'+[L]AINS+'.ACTION("ADELINSTANCE_AFTER")')
If ([L]ASTATUS>=[V]CST_AERROR) : End [V]CST_ANOTDEFINED : Endif

Call _ASTATUSPARENT(WCLA) From ASYRSUB

End 0

#****************************************************************************************************************
#* _ADELINSTANCE
#*!
Funprog _ADELINSTANCE(WCLA)

Variable Instance WCLA Using OBJECT

Local Integer ASTATUS

[L]ASTATUS = fmet WCLA.ADELETEERROR([V]CST_ALLERRORS)

[L]ASTATUS = fmet WCLA.ACTION("ADELINSTANCE_BEFORE")
If ([L]ASTATUS>=[V]CST_AERROR) : End [V]CST_ANOTDEFINED : Endif

If WCLA.ASTALIN=[V]CST_ANEW
 WCLA.ASTALIN= [V]CST_ANEWDEL
Else
 WCLA.ASTALIN= [V]CST_ADEL
Endif

[L]ASTATUS = fmet WCLA.ACTION("ADELINSTANCE_AFTER")
If ([L]ASTATUS>=[V]CST_AERROR) : End [V]CST_ANOTDEFINED : Endif

Call _ASTATUSPARENT(WCLA) From ASYRSUB

End 0

#****************************************************************************************************************
#* ADDLINE
#*!
Funprog ADDLINE(ALINE,AINS,ACHILD,WCLA)
Value Integer ALINE
Value Char AINS
Value Char ACHILD
Variable Instance WCLA Using OBJECT

If [L]ACHILD="" or [L]AINS="" : End [V]CST_ANOTDEFINED : Endif

If evalue("dim(WCLA."+AINS+")")<0 : End [V]CST_ANOTDEFINED : Endif : # exitence du pointeur

Local Integer  ACRE,APOS,I,ASTATUS,NBINS,ADIMMAX,ADIMMIN

[L]ASTATUS = fmet WCLA._ACTION_LINE_BEFORE("ADDLINE_BEFORE",[L]ALINE,[L]AINS)
If ([L]ASTATUS>=[V]CST_AERROR) : End [V]CST_ANOTDEFINED : Endif

If evalue("type(WCLA."+AINS+")")=524 : # c'est  un pointeur

 [L]ADIMMAX = fmet WCLA.AGETDIM(AINS)
 [L]ADIMMIN = fmet WCLA.AGETMIN(AINS)

 If [L]ADIMMAX=1 & [L]ADIMMIN=2
  Raz [L]APOS
 Else
  [L]APOS   = evalue("maxtab(WCLA."+[L]AINS+")")
 Endif

 If [L]ADIMMAX>0
  For I=1 To APOS
   If evalue("WCLA."+[L]AINS+"("+num$(I)+")")<>null & !find(evalue("WCLA."+[L]AINS+"("+num$(I)+").ASTALIN"),CST_ADEL,CST_ANEWDEL)
    NBINS += 1
   Endif
  Next
  If NBINS>= [L]ADIMMAX
   [L]ASTATUS = fmet WCLA.ASETERROR("",func ASYRFNC.MES2(mess(266,133,1),AINS,ACHILD),[V]CST_AERROR) : # insertion impossible
   End [V]CST_ANOTDEFINED
  Endif
 Endif

 Case [L]ALINE
  When [V]CST_AFIRSTPOS : # first position
   For I=1 To APOS
    If evalue("WCLA."+[L]AINS+"("+num$(I)+")")<>null & !find(evalue("WCLA."+[L]AINS+"("+num$(I)+").ASTALIN"),CST_ADEL,CST_ANEWDEL)
     Assign "WCLA."+[L]AINS+"("+num$(I)+").AORDER" With evalue("WCLA."+[L]AINS+"("+num$(I)+").AORDER + 1")
    Endif
   Next
   [L]ACRE = 1
  When [V]CST_ALASTPOS : # last position
   For I=1 To APOS
    If evalue("WCLA."+[L]AINS+"("+num$(I)+")")<>null & !find(evalue("WCLA."+[L]AINS+"("+num$(I)+").ASTALIN"),CST_ADEL,CST_ANEWDEL)
     If [L]ACRE<evalue("WCLA."+[L]AINS+"("+num$(I)+").AORDER")
      Assign "[L]ACRE" With evalue("WCLA."+[L]AINS+"("+num$(I)+").AORDER")
     Endif
    Endif
   Next
   [L]ACRE += 1
  When Default : # position n
   For I=1 To APOS
    If evalue("WCLA."+[L]AINS+"("+num$(I)+")")<>null & !find(evalue("WCLA."+[L]AINS+"("+num$(I)+").ASTALIN"),CST_ADEL,CST_ANEWDEL)
     If evalue("WCLA."+[L]AINS+"("+num$(I)+").AORDER")>=[L]ALINE
      Assign "WCLA."+[L]AINS+"("+num$(I)+").AORDER" With evalue("WCLA."+[L]AINS+"("+num$(I)+").AORDER + 1")
     Endif
    Endif
   Next
   [L]ACRE = [L]ALINE
 Endcase
 [L]APOS += 1
 Assign "WCLA."+[L]AINS+"("+num$([L]APOS)+")" With evalue("NewInstance  =WCLA.ALLOCGRP, "+[L]ACHILD+"(WCLA.ACTX,NullUuid,"+num$([L]ACRE)+',WCLA,"'+[L]AINS+'")')
 If evalue("dim(WCLA."+[L]AINS+"("+num$([L]APOS)+").ASTALIN)")>0
  Assign "WCLA."+[L]AINS+"("+num$([L]APOS)+").ASTALIN" With [V]CST_ANEW
  [L]ASTATUS = evalue("fmet"-"WCLA."+[L]AINS+"("+num$([L]APOS)+").ADDINSTANCE_BOUND")
  If [L]ASTATUS>=[V]CST_AERROR : End [V]CST_ANOTDEFINED : Endif
  If evalue("fmet"-"WCLA."+[L]AINS+"("+num$([L]APOS)+").AGETTYPCLA")<3 # persitant or basic
   [L]ASTATUS = evalue("fmet"-"WCLA."+[L]AINS+"("+num$([L]APOS)+").AINIT")
   If [L]ASTATUS>=[V]CST_AERROR : End [V]CST_ANOTDEFINED : Endif
  Endif
  [L]ASTATUS = evalue("fmet"-'WCLA.'+[L]AINS+"("+num$([L]APOS)+').ACTION("ADDLINE_AFTER")')
  If ([L]ASTATUS>=[V]CST_AERROR) : End [V]CST_ANOTDEFINED : Endif
  Call _ASTATUSPARENT(WCLA) From ASYRSUB
 Endif
Endif

End [L]APOS : # [L]ACRE

#****************************************************************************************************************
#* DELLINE
#*!
Funprog ADELLINE(AINDICE,AINS,WCLA)
Value Integer AINDICE
Value Char AINS
Variable Instance WCLA Using OBJECT

If [L]AINS="" : End [V]CST_ANOTDEFINED : Endif

If evalue("dim(WCLA."+AINS+")")<0 : End [V]CST_ANOTDEFINED : Endif : # exitence du pointeur

If evalue("type(WCLA."+AINS+")")<>524 : End [V]CST_ANOTDEFINED : Endif : # c'est bien un pointeur

Local Integer I,K,ASTATUS,APOS,TBPOS

[L]ASTATUS = fmet WCLA._ACTION_LINE_BEFORE("ADELLINE_BEFORE",AINDICE,AINS)
If ([L]ASTATUS>=[V]CST_AERROR) : End [V]CST_ANOTDEFINED : Endif

[L]TBPOS   = evalue("maxtab(WCLA."+[L]AINS+")")

Raz APOS
Case [L]AINDICE
 When [V]CST_AFIRSTPOS : # first position
  For I=1 To [L]TBPOS
   If evalue("WCLA."+[L]AINS+"("+num$(I)+")")<>null & !find(evalue("WCLA."+[L]AINS+"("+num$(I)+").ASTALIN"),CST_ADEL,CST_ANEWDEL)
    If [L]APOS>evalue("WCLA."+[L]AINS+"("+num$(I)+").AORDER") or [L]APOS=0
     [L]APOS = evalue("WCLA."+[L]AINS+"("+num$(I)+").AORDER")
    Endif
   Endif
  Next

 When [V]CST_ALASTPOS : # last position
  For I=1 To [L]TBPOS
   If evalue("WCLA."+[L]AINS+"("+num$(I)+")")<>null & !find(evalue("WCLA."+[L]AINS+"("+num$(I)+").ASTALIN"),CST_ADEL,CST_ANEWDEL)
    If [L]APOS<evalue("WCLA."+[L]AINS+"("+num$(I)+").AORDER") or [L]APOS=0
     [L]APOS = evalue("WCLA."+[L]AINS+"("+num$(I)+").AORDER")
    Endif
   Endif
  Next

 When Default : # position n
  For I=1 To [L]TBPOS
   If evalue("WCLA."+[L]AINS+"("+num$(I)+")")<>null & !find(evalue("WCLA."+[L]AINS+"("+num$(I)+").ASTALIN"),CST_ADEL,CST_ANEWDEL)
    If evalue("WCLA."+[L]AINS+"("+num$(I)+").AORDER")=AINDICE
     [L]APOS = I
     Break
    Endif
   Endif
  Next I

Endcase

If [L]APOS>0
 If evalue("WCLA."+[L]AINS+"("+num$([L]APOS)+").ASTALIN")= [V]CST_ANEW
  Assign "WCLA."+[L]AINS+"("+num$([L]APOS)+").ASTALIN" With [V]CST_ANEWDEL
 Else
  Assign "WCLA."+[L]AINS+"("+num$([L]APOS)+").ASTALIN" With [V]CST_ADEL
 Endif
 [L]ASTATUS = evalue("fmet"-'WCLA.'+[L]AINS+"("+num$([L]APOS)+').ACTION("ADELLINE_AFTER")')
 If ([L]ASTATUS>=[V]CST_AERROR) :  [L]APOS=0 : Endif
 Call _ASTATUSPARENT(WCLA) From ASYRSUB
Endif

If [L]APOS<=0
  End [V]CST_ANOTDEFINED
Endif

For I=1 To evalue("maxtab(WCLA."+[L]AINS+")")
 If evalue("WCLA."+[L]AINS+"("+num$(I)+")")<>null & !find(evalue("WCLA."+[L]AINS+"("+num$(I)+").ASTALIN"),CST_ADEL,CST_ANEWDEL)
  If evalue("WCLA."+[L]AINS+"("+num$(I)+").AORDER")>AINDICE
   Assign "WCLA."+[L]AINS+"("+num$(I)+").AORDER" With evalue("WCLA."+[L]AINS+"("+num$(I)+").AORDER")-1
  Endif
 Endif
Next I

End 0


#****************************************************************************************************************
#* GETINDBYLINE
#*!
Funprog GETINDBYLINE(ALINE,AINS,WCLA)
Value Integer ALINE
Value Char AINS
Variable Instance WCLA Using OBJECT

If [L]AINS="" : End [V]CST_ANOTDEFINED : Endif

If evalue("dim(WCLA."+AINS+")")<0 : End [V]CST_ANOTDEFINED : Endif : # exitence du pointeur

If evalue("type(WCLA."+AINS+")")<>524 : End [V]CST_ANOTDEFINED : Endif : # c'est bien un pointeur

Local Integer APOS,I,AINDICE
[L]APOS   = evalue("maxtab(WCLA."+[L]AINS+")")

For I=1 To APOS
 If evalue("WCLA."+[L]AINS+"("+num$(I)+").AORDER")=[L]ALINE & !find(evalue("WCLA."+[L]AINS+"("+num$(I)+").ASTALIN"),CST_ADEL,CST_ANEWDEL)
  [L]AINDICE = I : Break
 Endif
Next

End [L]AINDICE

#****************************************************************************************************************
#* Sort of array with 3 parameters
#*!
Subprog SORT3(WCLASSE,STA,WAINS,PRO1,PRO2,PRO3)
Variable Instance WCLASSE Using OBJECT
Variable Integer STA
Value Char WAINS
Value Char PRO1
Value Char PRO2
Value Char PRO3
Call  SORTN(WCLASSE,STA,WAINS,PRO1,PRO2,PRO3,"","","","","")
End

#****************************************************************************************************************
#* Sort of array with X parameters
#*!
Subprog SORT(WCLASSE,STA,WAINS,PRO)
Variable Instance WCLASSE Using OBJECT
Variable Integer STA
Value Char WAINS
Value Char PRO()(0..)
If dim(PRO)<8 : End : Endif
Call  SORTN(WCLASSE,STA,WAINS,PRO(1),PRO(2),PRO(3),PRO(4),PRO(5),PRO(6),PRO(7),PRO(8))
End

#****************************************************************************************************************
#* Sort of array
#*!
Subprog SORTN(WCLASSE,STA,WAINS,PRO1,PRO2,PRO3,PRO4,PRO5,PRO6,PRO7,PRO8)
Variable Instance WCLASSE Using OBJECT
Variable Integer STA
Value Char WAINS,PRO1,PRO2,PRO3,PRO4,PRO5,PRO6,PRO7,PRO8

If WCLASSE=null : STA=[V]CST_ANOTDEFINED : End : Endif

Local Integer WLINE(1..),WNBR,WNBRPRO,I,J
Local Char ORDERBY(250)

WNBR = (evalue("maxtab(WCLASSE."+WAINS+")"))

If WNBR<2 : STA=[V]CST_ANOTDEFINED : End : Endif
If WCLASSE=null : STA=[V]CST_ANOTDEFINED : End : Endif

# Calcul nombre de propriété en critére
If PRO1<>""
 WNBRPRO += 1
 If PRO2<>""
  WNBRPRO += 1
  If PRO3<>"" :
   WNBRPRO += 1
   If PRO4<>""
    WNBRPRO += 1
    If PRO5<>"" :
     WNBRPRO += 1
     If PRO6<>""
      WNBRPRO += 1
      If PRO7<>""
       WNBRPRO += 1
       If PRO8<>""
        WNBRPRO += 1
       Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

# Creation des variables de travail

For J=1 To WNBRPRO
 Case evalue("type(WCLASSE."+WAINS+"("+num$(WNBR)+")."+evalue("PRO"+num$(J))+")")
  When 1,2,4,5,6
   Case J
    When 1 : Local Decimal WFLD1(1..)
    When 2 : Local Decimal WFLD2(1..)
    When 3 : Local Decimal WFLD3(1..)
    When 4 : Local Decimal WFLD4(1..)
    When 5 : Local Decimal WFLD5(1..)
    When 6 : Local Decimal WFLD6(1..)
    When 7 : Local Decimal WFLD7(1..)
    When 8 : Local Decimal WFLD8(1..)
   Endcase
  When 3
   Case J
    When 1 : Local Date WFLD1(1..)
    When 2 : Local Date WFLD2(1..)
    When 3 : Local Date WFLD3(1..)
    When 4 : Local Date WFLD4(1..)
    When 5 : Local Date WFLD5(1..)
    When 6 : Local Date WFLD6(1..)
    When 7 : Local Date WFLD7(1..)
    When 8 : Local Date WFLD8(1..)
   Endcase
  When 526
   Case J
    When 1 : Local Datetime WFLD1(1..)
    When 2 : Local Datetime WFLD2(1..)
    When 3 : Local Datetime WFLD3(1..)
    When 4 : Local Datetime WFLD4(1..)
    When 5 : Local Datetime WFLD5(1..)
    When 6 : Local Datetime WFLD6(1..)
    When 7 : Local Datetime WFLD7(1..)
    When 8 : Local Datetime WFLD8(1..)
   Endcase
  When Default
   Case J
    When 1 : Local Char WFLD1(250)(1..)
    When 2 : Local Char WFLD2(250)(1..)
    When 3 : Local Char WFLD3(250)(1..)
    When 4 : Local Char WFLD4(250)(1..)
    When 5 : Local Char WFLD5(250)(1..)
    When 6 : Local Char WFLD6(250)(1..)
    When 7 : Local Char WFLD7(250)(1..)
    When 8 : Local Char WFLD8(250)(1..)
   Endcase
 Endcase
Next

# Chargement des variables de travail
For I=1 To WNBR
 For J=1 To WNBRPRO
  Assign "WFLD"+num$(J)+'('+num$(I)+")" With evalue("WCLASSE."+WAINS+"(I)."+evalue("PRO"+num$(J)))
  WLINE(I) = I
 Next
Next

# sorta des variables
Case WNBRPRO
 When 1 : Sorta WNBR WFLD1,WLINE
 When 2 : Sorta WNBR WFLD1,WFLD2,WLINE
 When 3 : Sorta WNBR WFLD1,WFLD2,WFLD3,WLINE
 When 4 : Sorta WNBR WFLD1,WFLD2,WFLD3,WFLD4,WLINE
 When 5 : Sorta WNBR WFLD1,WFLD2,WFLD3,WFLD4,WFLD5,WLINE
 When 6 : Sorta WNBR WFLD1,WFLD2,WFLD3,WFLD4,WFLD5,WFLD6,WLINE
 When 7 : Sorta WNBR WFLD1,WFLD2,WFLD3,WFLD4,WFLD5,WFLD6,WFLD7,WLINE
 When 8 : Sorta WNBR WFLD1,WFLD2,WFLD3,WFLD4,WFLD5,WFLD6,WFLD7,WFLD8,WLINE
Endcase

# Modification AORDER en conséquence
For I=1 To WNBR
 J = find(I,WLINE)
 If J
  Assign "WCLASSE."+WAINS+"("+num$(I)+").AORDER" With J
 Endif
Next

STA = 0

End

