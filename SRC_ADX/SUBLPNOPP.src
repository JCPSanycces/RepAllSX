#<AdxTL>@(#)0.0.0.0 $Revision$
# TRAITEMENTS LIES AU PICKING DES AFFECTATIONS DE LPN                  #
#########################################################################

#########################################################################
# Actions de l'objet                                                    #
#########################################################################

#########################################################################
$TIROIR
ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
WPICK=2
Gosub RAFFRAICHI

Return

#########################################################################
$FILGAUCHE
Local Integer W_I, W_J
Local Char    W_STA(GLONSTA)


If currbox<>GBOXLPN
  # Issue 106909 - 2018-09-20 by MAE : on ne selectionne que les opérations
  FILGAUCHE='find([F:SGH]MODOPELPN,1,2,3) '
  Return
Endif

If WMOD = 1
  # Rien dans la liste de picking
   FILGAUSUP(0)='[F:LPN]LPNNUM=""'
   Return
Endif

Raz FILGAUSUP(1)
Raz FILGAUSUP(2)
Raz FILGAUSUP(3)
FILGAUSUP(0) = '[F:LPN]STOFCY = [M:LPNO]STOFCY & [F:LPN]LPNSTAT = 2'
# Filtre emplacement début/fin
If [M:LPNO]LOCSTR<>AVOID.ACHAR
      FILGAUSUP(0) += '&[F:LPN]LOC>=[M:LPNO]LOCSTR'
Endif
If [M:LPNO]LOCEND<>AVOID.ACHAR
      FILGAUSUP(0) += '& [F:LPN]LOC<=[M:LPNO]LOCEND'
Endif
#filtre type emplacement
If [M:LPNO]LOCTYPSTR <> AVOID.ACHAR
    FILGAUSUP(0) += '&[F:LPN]LOCTYP>=[M:LPNO]LOCTYPSTR'
Endif
If [M:LPNO]LOCTYPEND<>AVOID.ACHAR
      FILGAUSUP(0) += '& [F:LPN]LOCTYP<=[M:LPNO]LOCTYPEND'
Endif

#filtre LPN
If [M:LPNO]LPNNUMSEL <> AVOID.ACHAR
    FILGAUSUP(0) += '&[F:LPN]LPNNUM=[M:LPNO]LPNNUMSEL'
Endif

# Filtre formule
If [M:LPNO]SELFOR <> ""
  Read [TFO]TFO0=11;[M:LPNO]SELFOR
  If fstat = 0
      FILGAUSUP(0) += "&" + [F:TFO]FORFOR
  Endif
Endif
#


Return

#########################################################################
$AP_FILGAUCHE
Case currbox
 When GBOXLPN    : WPICK=2 : Gosub RAFFRAICHI
 When Default
Endcase
Return

#########################################################################
$DEB_PICK

Return

#########################################################################
$PICKE
Local Decimal WPCUDIS, WSTUDIS, WSTUACTDIS, WTOTACTDIS, WDISPO, WQTYSTU
Local Integer LTYPLOC, LSTA, LRET, LSEQ
#--- Issue 89625
#Local Char    LOWNER
#--- Issue 96990
Local Integer I
Local Decimal LQTY
Local Char    PABR(GLONABR)
PABR = "LPNO"

If GREP = "M" | GREP = ""
   If dim(GCTRDATSCS) <= 0
      If [M:LPNO]IPTDAT < date$
         Global Integer GCTRDATSCS
         # Attention ! la date d imputation est antérieure à la date du jour
         Call MESSAGE(mess(162,184,1)) From GESECRAN
      Endif
   Endif
Endif

If dim(LSAVNOL)<=0
    Local Integer LSAVNOL
    LSAVNOL=-1
Endif

If REP=""
   If !CLECUR | !VERROU | !ACTMOD
      OK=0 : Return
   Endif
Endif

If currbox<>GBOXLPN
    Return
Endif
#controle avant picking : contenant et emplacement entête obligatoire uniquement en regroupement
If [M:LPNO]MODOPELPN = 1
  If [M:LPNO]LPNDESH = AVOID.ACHAR
    GMESSAGE=mess(525,184,1)   # contenant obligatoire
    OK=0 : GERR=1 : Return
  Endif
  If [M:LPNO]LOCDESH = AVOID.ACHAR
    GMESSAGE=mess(536,184,1)   # emplacement obligatoire
    OK=0 : GERR=1 : Return
  Endif
Endif



If !clalev([F:STA]) : Local File STOALL [STA] : Endif
If !clalev([F:STO2]): Local File STOCK  [STO2]  Endif
# premiere passe sur les lignes de stocks du LPN pour le regroupement pour controler que les lignes de stock :
#          ne soit pas en controle qualité
#          ne soit pas en inventaire
#          ne soit pas en cours de pesée
If [M:LPNO]MODOPELPN = 1
  Filter [STO2] Where LPNNUM=[F:LPN]LPNNUM Order By Key STO6
  For [STO2]
      # numéro contenant destination <> origine
      If [M:LPNO]LPNDESH = [F:STO2]LPNNUM
        GMESSAGE=mess(541,184,1)
        OK=0 : GERR=1 : Break
       Endif
      # Ligne(s) de stock en controle qualité
      If [F:STO2]QLYCTLDEM<>""
         GMESSAGE=mess(532,184,1)
         OK=0:  GERR=1 : Break
      Endif
      If [F:STO2]CUNLOKFLG = 2
         GMESSAGE=mess(233,184,1)   # Ligne(s) de stock en inventaire
         OK=0 : GERR=1 : Break
      Endif
      # La ligne de stock est-elle en cours de pesée
      Look [F:STA]STA0(3)=[F:STO2]STOFCY;[F:STO2]ITMREF;[F:STO2]STOCOU
      [G:STA]currlen=0
      If !fstat
        Call ALL_WEIGHING([F:STO2]STOFCY,[F:STO2]ITMREF,[F:STO2]STOCOU,LRET) From STKALL
        If LRET<>0
          GMESSAGE=mess(533,184,1) # Ligne(s) de stock en cours de pesée
          OK=0 : GERR=1 : Break
        Endif
      Endif
  Next
  Filter [STO2]
  If GERR = 1
   Return
  Endif
Endif
# deuxieme passe pour charger les lignes de stocks du LPN
Filter [STO2] Where LPNNUM=[F:LPN]LPNNUM
& Order By Key STO6
  For [STO2]
      If [M:LPNO]NBLIG >= dim([M:LPNO]ITMREF)
         Call ECR_TRACE(mess(203,184,1),1) From GESECRAN                 # Ecran SCS1 plein
         OK=0
         GERR=1
         Break
      Endif
      If [F:STO2]ITMREF <> [F:ITM]ITMREF
         Call LECITM2([M:LPNO]STOFCY,[F:STO2]ITMREF,[F:STO2]WRH,LRET) From STKLIB
         If LRET<>0
            If GMESSAGE<>"" Call ERREUR(GMESSAGE) From GESECRAN
               GERR=1
               Break
            Endif
         Endif
      Endif
      Read [STO]STO0=[M:LPNO]STOFCY;[F:STO2]STOCOU
      If [F:STO]QTYSTU-[F:STO]CUMWIPQTY >0
        Gosub ALI_DOC From SUBLPNOPB
        Call STKWSTOSEQ ("LPNO", nolign-1, [M:LPNO]NBLIG, 2, LSEQ, LRET) From STKECR
        #Call FILLCHGW("LPNO", nolign-1, 1, [M:LPNO]WSTOSEQ(nolign-1), [M:LPNO]STOFCY, LRET, LQTY) From SUBSCSB
        If [F:ITM]SERMGTCOD = 4
          PNOL = nolign - 1
          Gosub CTR_SERIES_GLOBALE From SUBSCSB
        Else
          Call FILLCHGW("LPNO", nolign-1, 1, [M:LPNO]WSTOSEQ(nolign-1), [M:LPNO]STOFCY, LRET, LQTY) From SUBSCSB
        Endif
        If LRET<>0
          Call ERREUR(GMESSAGE) From GESECRAN
          OK = 0 : GERR=1 : WPICK = 1
          Gosub RAFFRAICHI
          Gosub DEPICK
          Break
        Endif
     Else
      GMESSAGE=mess(57,184,1)
      OK = 0 : GERR = 1
     Endif
  Next
Filter [STO2]


Return

#########################################################################
$DEPICK
Local Integer DP_LRET
Case currbox
 When GBOXLPN :
        Look [LPN]LPN0=[F:LPN]LPNNUM
        If fstat
            Call RSTA ("LPN",[F:LPN]LPNNUM) From GLOCK
            FOK=0 : Return
        Endif
        Raz I,J
        Raz OK
        If [M:LPNO]NBLIG <> 0
# Le depick d'un contenant peut entrainer la suppression de plusieurs lignes de [LPNO] (meme contenant)
           While OK <> 1
              I = find([F:LPN]LPNNUM,[M:LPNO]LPNNUM(J..[M:LPNO]NBLIG-1))
              If I<>0
                 Look [STO]STO0=[M:LPNO]STOFCY;[M:LPNO]WSTOCOU(I-1)
                 If fstat
                    Call RSTA ("STO",[M:LPNO]STOFCY-num$([M:LPNO]WSTOCOU(I-1))) From GLOCK
                    FOK=0
                    Return
                 Endif
                 Call DEPICK([M:LPNO]STOFCY,[M:LPNO]WSTOCOU(I-1),"LPNO", DP_LRET) From SUBLPNOPB
                 OK = DP_LRET
              Else
                OK=1
              Endif
           Wend
        Endif
        If [M:LPNO]NBLIG >0
          Grizo [M:LPNO]MODOPELPN
        Else
          Actzo [M:LPNO]MODOPELPN
        Endif
        Affzo [M:LPNO]
 When Default
Endcase
Return
#########################################################################
$FIN_PICK
If REP=""
   If !VERROU
      GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return
   Elsif !CLECUR | !ACTMOD | GCONSULT
      GMESSAGE=mess(9,123,1)  : GERR=1 : OK=0 : Return
   Endif
Endif

#Local Integer LRET
#Local Decimal LQTY
#    If dim(GSCSPIC)>0
#        Kill GSCSPIC
#        Call FILLCHGW("LPNO", nolign-1, 1, [M:LPNO]WSTOSEQ(nolign-1), [M:LPNO]STOFCY, LRET, LQTY) From SUBSCSB
#        Affzo [M:LPNO]10
#    Endif

Case currbox
 When GBOXLPN : Affzo [M:LPNO]1-99
 When Default
Endcase


If [M:LPNO]NBLIG>0 & dim(LSAVNOL)>0 & LSAVNOL>=0
    zonsui="NBLIG("+num$(LSAVNOL)+")"
    Kill LSAVNOL
Endif

Return

#########################################################################
# Etiquettes de traitement                                              #
#########################################################################

$REMPBOX
#-----------------------------------------------------------------------#
# Remplissage des boites de picking                                     #
#-----------------------------------------------------------------------#
ILIS=val(right$(currbox,8))

Gosub REMP_LISGAU From GOBJSUB
WPICK=2
Gosub RAFFRAICHI


Return

#########################################################################
$RAFFRAICHI
#-----------------------------------------------------------------------#
# Raffraichissement des listes de picking pour les lignes déjà saisies  #
#-----------------------------------------------------------------------#
If currbox  = GBOXLPN
  For I=0 To [M:LPNO]NBLIG-1
    Read [LPN]LPN0=[M:LPNO]LPNNUM(I)
    If fstat : Raz [F:LPN] : Endif
    If    WPICK=1 Gosub DEPICK From GOBJSUB
    Elsif WPICK=2 Gosub REPICK From GOBJSUB
    Endif
   Next I
Endif
Return

