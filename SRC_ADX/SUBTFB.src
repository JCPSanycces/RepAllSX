#<AdxTL>@(#)4.0.0.0 $Revision$
Call OBJET("TFB",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "AFFMASK"     : Gosub AFFMASK
 When "SETBOUT"     : Gosub SETBOUT
 When "APRES_CHOI"  : Gosub APRES_CHOI
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
 When "LIENS0"      : Gosub LIENS0
 When "LIENS2"      : Gosub LIENS2
 When "RAZDUP"      : Gosub RAZDUP
 When "RAZCRE"      : Gosub RAZCRE
 When "CREATION"    : Gosub CREATION
 When "MODIF"       : Gosub MODIF
 When "ABANDON"     : Gosub ABANDON
 When "SEL_TABLE"   : Case COUZON
                        When "COD","BAN","RECTYP","ORDNUM","LEG" : Gosub S_TFB
                      Endcase
 When "VERF_TABLE"  : Case OBJET
                        When "TFB" : Gosub V_TFB
                      Endcase
Endcase
Return

$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Local Char WCLECUR1(30)
Return

$AFFMASK
Call FMTLEG From TRTX3
Gosub GRILEG
Return


$GRILEG
If func AFNC.ACTIV("LEG")=0
  Diszo [M:TFB1]LEG
  [M:TFB1]LEG=GDOSLEG(1)
  Affzo [M:TFB1]LEG
Endif
Return

$LIENS
Call LECTEXTRA([M:TFB1]DESTRA,"TABFILBAN","DESTRA",[M:TFB1]COD,[M:TFB1]BAN+"~"+[M:TFB1]LEG) From ATEXTRA
Call LECTEXTRA([M:TFB1]SHOTRA,"TABFILBAN","SHOTRA",[M:TFB1]COD,[M:TFB1]BAN+"~"+[M:TFB1]LEG) From ATEXTRA
Return

$LIENS0
Call AM_FMT([F:TFB]FMT)
Call C_FMT([F:TFB]FMT)

Gosub CHARGE_CUR
Return

$LIENS2
If dim([M]LEG)>0 : Affzo [M]LEG : GCURLEG=[M]LEG Endif
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
If [M]RECTYP>1 # Si le type d'enregistrement n'est pas en-tête
 Call SET_CURMULT([M]COD,[M]BAN,[M]LEG) #X3-29247
 Grizo CURMULT, FILREF, NATPAY, FILEXO , NBCUR, CUR, CURCTL
Else #Si entete
 Actzo CURMULT, FILREF, NATPAY , NBCUR, CUR, CURCTL
 If [M]FMT=2 : Actzo FILEXO : Endif
Endif
If [M:TFB1]CURCTL=1 #  désactivé ou non renseigné #X3-29247
  Grizo [M:TFB1]NBCUR
  Grizo [M:TFB1]CUR
Endif
Return

$RAZCRE
Gosub GRILEG
$RAZDUP
If COUZON="RECTYP"
 If zc>1
  Grizo CURMULT, FILREF, NATPAY, FILEXO ,CUR, CURCTL
 Else
  Actzo CURMULT, FILREF, NATPAY , CUR, CURCTL
  If [M]FMT=2 : Actzo FILEXO : Endif
 Endif
Endif
If [M:TFB1]CURCTL=1
  Grizo [M:TFB1]NBCUR
  Grizo [M:TFB1]CUR
Endif
Return

$INICRE
$INIMOD
  If func AFNC.ACTIV("LEG")=0 : [F:TFB]LEG = GDOSLEG(1) : Endif
  If dim([F:TFB]DES)>0
   [F:TFB]DES = [M:TFB1]DESTRA
  Endif
  [F:TFB]BANLEG = [TFB]BAN+"~"+[TFB]LEG

Return

$CREATION
#Gosub TEXTRA
#If GOK<1 : Return : Endif
  Gosub CONTROLEBEFORE #X3-29247
Return

$MODIF
Gosub CONTROLEBEFORE #X3-29247
Gosub TEXTRA
If GOK<1 : Return : Endif

Local File TABFILBAN [TFB4]
If GREP="M" #X3-29247
   Update [TFB4]
&     Where COD=[M]COD & BAN=[M]BAN & LEG=[M]LEG
&     With FILREF=[M]FILREF, FILEXO=[M]FILEXO, CURMULT=[M]CURMULT, NATPAY=[M]NATPAY , CURCTL = [M]CURCTL
   If fstat = 1
    GOK = -1 : Call RSTA("TFB",[M]COD) From GLOCK
   Endif
   For I=0 To dim(CUR)-1 #Sauvegarde du champ dimensionné #X3-29247
    Update [TFB4] Where COD=[M]COD & BAN=[M]BAN & LEG=[M]LEG With  CUR(I)=[M]CUR(I)
   Next
Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 WCLECUR1 = CLECUR1+"~"+CLECUR2(3)
 Call DUPTEXTRA("TABFILBAN","DESTRA",CLECUR2,WCLECUR1,"TABFILBAN","DESTRA",[F:TFB]COD,[F:TFB]BAN+"~"+[F:TFB]LEG) From ATEXTRA
 Call DUPTEXTRA("TABFILBAN","SHOTRA",CLECUR2,WCLECUR1,"TABFILBAN","SHOTRA",[F:TFB]COD,[F:TFB]BAN+"~"+[F:TFB]LEG) From ATEXTRA
Endif
Call MAJTEXTRA([M:TFB1]DESTRA,"TABFILBAN","DESTRA",[F:TFB]COD,[F:TFB]BAN+"~"+[F:TFB]LEG) From ATEXTRA
Call MAJTEXTRA([M:TFB1]SHOTRA,"TABFILBAN","SHOTRA",[F:TFB]COD,[F:TFB]BAN+"~"+[F:TFB]LEG) From ATEXTRA
Return

$ABANDON
Actzo CURMULT, FILREF, NATPAY
If [M]FMT=2 : Actzo FILEXO : Endif
Return

Subprog SET_CURMULT(PCOD, PBAN, PLEG ) #X3-29247
Variable Char PCOD , PBAN , PLEG
Local File TABFILBAN [TFB]
Read [TFB]TFB0(5) = PCOD;PBAN;1;0;PLEG
If fstat
 Read [TFB]TFB0(5) = PCOD;PBAN;1;0;""
 If fstat
  Read [TFB]TFB0(5) = PCOD;"";1;0;PLEG
  If fstat
  Read [TFB]TFB0(5) = PCOD;"";1;0;""
   If fstat
     Raz [F:TFB]
     End
   Endif
  Endif
 Endif
Endif
If [F:TFB]CURMULT=2 : [M]CURMULT=2 : Else [M]CURMULT=1 : Endif
If [F:TFB]CURCTL=0 : [M]CURCTL=1 Else [M]CURCTL=[F:TFB]CURCTL : Endif
Gosub CHARGE_CUR
[M]FILREF=[F:TFB]FILREF
[M]NATPAY=[F:TFB]NATPAY
#[M]ORDNUM=[F:TFB]ORDNUM
#[M]RECTYP=[F:TFB]RECTYP
End

$SETBOUT
If CLECUR & SUPPR : CHAINE+="A" : Endif
If !CLECUR | REP<>"" | !VERROU
 Call VIREBOUT(CHAINE,"U") From GOBJET : # Copie
Endif
Return


$APRES_CHOI
Case REPONSE
 When GSTAANU : Gosub ANNULER : REPONSE=0
Endcase
Return


$ANNULER
If !VERROU
 Gosub VERROU From GOBJET
 If !VERROU
  Call ERREUR(mess(10,100,1)) From GESECRAN : Return
 Else
  AFFICHE = 1 : Gosub RELIT From GOBJSUB
 Endif
Endif
OK = 2
If dim([V]GCONF)<=0 or [V]GCONF(1)=2 : # Suppression
 Call OUINON(mess(53,123,1)-[M]COD-[M]BAN-[M]LEG-mess([M]RECTYP,656,1)-num$(ORDNUM),OK) From GESECRAN : # Suppression
Endif
If OK<>2 : Return : Endif
OK=1
Gosub VERF_ANU
If OK=0 : Return : Endif
Call DEBTRANS From GLOCK
Gosub TR3
CLECUR = 0
Gosub RELIT From GOBJSUB
Return


$VERF_ANU
# Suppression bloquante
If !clalev([F:TPY])  : Local File TABPAYTYP [TPY]  : Endif
If !clalev([F:TFB1]) : Local File TABFILBAN [TFB1] : Endif
Local Integer NBRLEG                         # Number of recording with the same "CODE"
Local Char    TABLEG(GLONADI)(1..GNBLEG+1)   # List of legislation

Filter [TFB1] Where COD=[M]COD & (BAN<>[M]BAN | RECTYP<>[M]RECTYP | ORDNUM<>[M]ORDNUM | LEG<>[M]LEG)
For [TFB1]TFB0(5)
 If !find([F:TFB1]LEG,TABLEG(1..NBRLEG))
  NBRLEG +=1
  TABLEG(NBRLEG) = [F:TFB1]LEG
 Endif
Next
Filter [TFB1]

# Deletion is available if the [TFB] recording exists with the same code and the empty legislation
If find("",TABLEG(1..NBRLEG))  : Return : Endif

# OK=0 : Deletion forbidden
If [M]LEG=""
For [TPY] Where FILREF8=[M]COD | FILREF6=[M]COD
  If !find ([F:TPY]LEG,TABLEG(1..NBRLEG)) : OK = 0 : Break : Endif
 Next
Else
 For [TPY] Where LEG=[M]LEG & (FILREF8=[M]COD | FILREF6=[M]COD)
  OK = 0 : Break
 Next
Endif
# La fiche est utilisée par xxx dans yyy
# Il faut d'abord supprimer ce lien
If OK=0
 Local Char NOM (GLONAX3)
 Call LECTEXTRA(NOM,"TABPAYTYP","DESTRA",[F:TPY]PAYTYP,[F:TPY]LEG) From ATEXTRA
 Call ERREUR(mess(101,126,1)-[F:TPY]PAYTYP-"("+NOM+")"-mess(198,133,1)-"TABPAYTYP"+"\"+mess(176,115,1)) From GESECRAN
Endif
Return


$TR3
GOK=1
Trbegin [TFB]
 Delete [TFB] Where COD=[M]COD & BAN=[M]BAN & RECTYP=[M]RECTYP & ORDNUM=[M]ORDNUM & LEG=[M]LEG
Commit

# suppression des textes traduisibles seulement si inutilisés
Filter [TFB] Where COD=[M]COD & BAN=[M]BAN & LEG=[M]LEG
If rowcount([TFB])=0
 Call SUPTEXTRA("TABFILBAN","DESTRA",[M]COD,[M]BAN+"~"+[M]LEG) From ATEXTRA
 Call SUPTEXTRA("TABFILBAN","SHOTRA",[M]COD,[M]BAN+"~"+[M]LEG) From ATEXTRA
Endif
Filter [TFB]
Return


$S_TFB
OBJET = "TFB"
Local Char ZONE(20)

# Critère de sélection
For ZONE="COD","BAN","RECTYP","ORDNUM","LEG"
 If ZONE=COUZON : Break : Endif
 CRITERE += " & "+ZONE+"=[M]"+ZONE
Next
If CRITERE<>""
 CRITERE=right$(CRITERE,4)
 Filter [TFB] Where evalue(CRITERE)
Endif

# Positionnement par défaut dans la fenêtre de sélection
If !GINTRA
 # EXPSTART n'est pas gérée en intradon
 For ZONE="COD","BAN","RECTYP","ORDNUM","LEG"
  If ZONE=COUZON : Assign "[F:TFB]"+ZONE With VALEUR
  Else           : Assign "[F:TFB]"+ZONE With evalue("[M]"+ZONE)
  Endif
 Next
 Read [TFB]TFB0(5) =
 If !fstat
  For ZONE="COD","BAN","RECTYP","ORDNUM","LEG"
   If ZONE=COUZON : EXPSTART += " & "+ZONE+"=[L]VALEUR"
   Else           : EXPSTART += " & "+ZONE+"=[M]"+ZONE
   Endif
  Next
  EXPSTART=right$(EXPSTART,4)
 Endif
Endif
If EXPSTART=""
 START = COUZON
Endif

If CRITERE<>"" : Filter [TFB] : Endif
Return


$V_TFB
For ZONE="COD","BAN","RECTYP","ORDNUM","LEG"
 If ZONE<>COUZON
  Assign "[M]"+ZONE With evalue("[F:TFB]"+ZONE)
 Endif
Next
mkstat=4
Return


$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

########################################
## Copie par couple (Fichier+Banque)  ##
########################################
$TRTCOP
Local Char LEGDEST(250)

If [M]DOSORG=nomap
 Local File TABFILBAN  [TFB1]
 Local File ATEXTRA    [AXX1]
Else
 Local File =[M]DOSORG+".TABFILBAN"  [TFB1]
 Local File =[M]DOSORG+".ATEXTRA"    [AXX1]
Endif
If [M]DOSDES=nomap
 Local File TABFILBAN [TFB2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".TABFILBAN"  [TFB2]
 Local File =[M]DOSDES+".ATEXTRA"    [AXX2]
Endif

Gosub OUVDOS From ATEXTRA

# Multi-Lég... Vérifier que la législation existe dans le dossier destination
# Sous OUVDOS, le fichier ADOSSIER ADS2 du dossier destination est déjà en ligne
If TABLE3<>"" & clalev([F:ADS2])>0 & !find(TABLE3,[F:ADS2]DOSLEG(0..dim([F:ADS2]DOSLEG)-1))
 Call MESSAGE(TABLE3-":"-mess(249,133,1) ) From GESECRAN  # Législation non gérée par le dossier
 Return
Endif

# We can't copy an empty legislation to a single-legislation folder. We have to move the empty legislation
# to the legislation of the destination folder before the copy
LEGDEST = TABLE3
If LEGDEST="" & [F:ADS2]NBLEG=1
 LEGDEST = [F:ADS2]DOSLEG(0)
Endif

Call DEBTRANS From GLOCK

Gosub TR_COP
Close Local File [TFB1], [TFB2], [AXX1], [AXX2]
Return


$TR_COP
GOK = 1
Trbegin [TFB2]
 Delete [TFB2] Where COD=TABLE & BAN=TABLE2 & LEG=LEGDEST
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".TABFILBAN" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("TFB2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [TFB1] Where COD=TABLE & BAN=TABLE2 & LEG=TABLE3
  [F:TFB2] = [F:TFB1]
  [F:TFB2]LEG = LEGDEST
  Call COPTEXTRALEG("TABFILBAN","DESTRA",TABLE,TABLE2+"~"+TABLE3,TABLE2+"~"+LEGDEST) From CPTDIV
  Call COPTEXTRALEG("TABFILBAN","SHOTRA",TABLE,TABLE2+"~"+TABLE3,TABLE2+"~"+LEGDEST) From CPTDIV
  If dim([F:TFB2]UPDUSR)>0 : [F:TFB2]UPDUSR = GUSER : Endif
  If dim([F:TFB2]UPDDAT)>0 : [F:TFB2]UPDDAT = date$ : Endif
  Write [TFB2]
  If fstat
   GOK = 0 : Call FSTA("TFB2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return


$AB_TR_COP
Rollback
Return


$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return


########################################
## Ecran TFB1                         ##
########################################

Subprog IB_BAN
GBOUT1 = mess(22,123,1)-mess(1,653,1) : # Sélection Banque
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If [M]BAN<>"" & VALEUR<>""
 Call LEC_BAN(VALEUR) From CPTLEC
 Call LEC_CPY([F:BAN]CPY) From CPTLEC
 If [F:CPY]LEG<>"" & [F:CPY]LEG<>VALEUR
  # Banque incompatible avec la législation
  GMESSAGE = mess(261,117,1)
  mkstat = 2 : End
 Endif
Endif
GCURLEG = VALEUR
End

Subprog AP_RECTYP(VALEUR) #X3-29247
Variable Integer VALEUR
If VALEUR<>2 : [M]ORDNUM=0 : Endif
If VALEUR>1 # Si le type d'enregistrement n'est pas en-tête
 Grizo CURMULT, FILREF, NATPAY, FILEXO , NBCUR, CUR, CURCTL
Else
  Actzo CURMULT, FILREF, NATPAY, FILEXO , NBCUR, CUR, CURCTL
  Call AM_CURCTL([M]CURCTL)
Endif
End

Subprog AS_ORDNUM(VALEUR)
Variable Decimal VALEUR
If [M]RECTYP<>2 : mkstat=2 : Endif
End

Subprog C_ORDNUM(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : VALEUR = 1 : Endif
End

Subprog AV_POS(VALEUR)
Variable Decimal  VALEUR
If nolign=1
 VALEUR = 1
Else
 VALEUR = [M]POS(nolign-2) + [M]LNG(nolign-2)
Endif
End

Subprog AS_LNG(VALEUR)
Variable Decimal VALEUR
Case [M]FLDTYP(nolign-1)
 When 3,4 : VALEUR = 6 : mkstat = 2 : # Date (JJMMAA), Date (AAMMJJ)
 When 6,7 : VALEUR = 2 : mkstat = 2 : # Mois, Jour
Endcase
End

Subprog C_LNG(VALEUR)
Variable Decimal VALEUR
If [M]FMT=2
 End
Elsif VALEUR=0
 mkstat=1
 GMESSAGE = mess(10,123,1)
 End
Endif
Case [M]FLDTYP(nolign-1)
 When 5 : # Année
  If !find(VALEUR,1,2,4) : mkstat = 1 : End : Endif
Endcase
End

Subprog APRES_NBLIG
If !GIMPORT : Affzo TOTLNG, POS : Endif
End

Subprog AM_FMT(VALEUR)
Value Integer VALEUR
If VALEUR=1
 # le format est ‘Fixe’ => affichage des colonnes qui existent aujourd’hui : type champ, position, longueur, formule titre
 Chgfmt [M]STRSEP With "-K:250"
 Chgfmt [M]ENDSEP With "-K:250"
 Chgfmt [M]OBY With "-K:5"
 Chgfmt [M]CND With "-K:250"

 Chgfmt [M]POS With "N:4"
 Chgfmt [M]TOTLNG With "N:4"
Else
 # le format est ‘Variable’ => affichage des colonnes suivantes : type champ, longueur (long max, non obligatoire),
 # séparateur début (dans lequel sera définie la balise dans le cas de fichier XML. Ex : ''), Formule, séparateur fin.
 Chgfmt [M]POS With "-N:4"
 Chgfmt [M]TOTLNG With "-N:4"

 Chgfmt [M]STRSEP With "K:250"
 Chgfmt [M]ENDSEP With "K:250"
 Chgfmt [M]OBY With "K:5"
 Chgfmt [M]CND With "K:250"
Endif
End

Subprog C_FRM(VALEUR)
Variable Char VALEUR
If VALEUR=""
 [M]OBY(nolign-1) = 0
 Grizo [M]OBY(nolign-1)
Else
 Actzo [M]OBY(nolign-1)
Endif
End

Subprog AV_OBY(VALEUR)
Variable Integer VALEUR
Call C_FRM([M]FRM(nolign-1))
End

Subprog AS_ENDSEP(VALEUR)
Variable Char    VALEUR()
If [M]STRSEP(nolign-1)<>"" and [M]FRM(nolign-1)<>"" and VALEUR=""
 VALEUR = "</"+mid$([M]STRSEP(nolign-1), 2, len([M]STRSEP(nolign-1)))
Endif
End

Subprog C_ENDSEP(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Local Char ENDSEP(250)
ENDSEP = "</"+mid$([M]STRSEP(nolign-1), 2, len([M]STRSEP(nolign-1)))
If [M]STRSEP(nolign-1)<>"" and [M]FRM(nolign-1)<>"" and VALEUR<>[L]ENDSEP
 Call OUINON(func AFNC.MES1(mess(263,117,1), ENDSEP), OK) From GESECRAN
 If OK=2 : VALEUR = [L]ENDSEP : Endif
Endif
End

Subprog C_FMT(VALEUR)
Value Integer VALEUR
If VALEUR=2 : Actzo [M]FILEXO : Else Grizo [M]FILEXO : Endif
End

######################################################################################
## Multi Currencies Gestion - X3-29247 - BEFOU 13/06/2017
######################################################################################
$CONTROLEBEFORE
### Contrôle tableau devises ###
#Mono Currencies & More than one currencies
If [M:TFB1]CURMULT  = [V]CST_ANO and [M:TFB1]NBCUR>1
  GMESSAGE=func ASYRFNC.MES1(mess(26,173,1),[M:TFB1]COD)
  GOK=0
Endif
#Pas de code devise Control Currencies Approved or Prohibited
If [M:TFB1]CURCTL>1 and [M:TFB1]NBCUR=0
  If GREP="M"
    GMESSAGE=mess(385,196,1) # Modification
  Else
    GMESSAGE=mess(384,196,1) #Création
  Endif
  GOK=0
Endif
Return

$CHARGE_CUR
Gosub RAZ_GRID_CUR
For I=0 To dim([F:TFB]CUR)-1
  If [F:TFB]CUR(I)<>""
    [M:TFB1]CUR(I) = [F:TFB]CUR(I)
    [M:TFB1]NBCUR +=1
  Else
    [M:TFB1]CUR(I)=""
  Endif
Next
Return

$RAZ_GRID_CUR
   If [M:TFB1]NBCUR <> 0 # RAZ Grid
    Dela 0,[M:TFB1]NBCUR [M:TFB1]NBCUR
    [M:TFB1]NBCUR=0
   Endif
   Affzo [M:TFB1]NBCUR
Return

Subprog GES_CURCTL(VALEUR)
Value Integer VALEUR
  If [M:TFB1]CURCTL = 3 # Prohibited
    [M:TFB1]CURCTL=1
    Affzo [M:TFB1]CURCTL
    Gosub RAZ_GRID_CUR
    Grizo [M:TFB1]NBCUR
    Grizo [M:TFB1]CUR
  Endif
  If VALEUR=[V]CST_AYES
    Discombo 0 From [M:TFB1]CURCTL
  Else
    Discombo 3 From [M:TFB1]CURCTL
  Endif
End

Subprog AS_CURCTL(VALEUR)
Variable Integer VALEUR
   If [M:TFB1]CURMULT =  [V]CST_ANO
    GMENLOC(3)=1
  Endif
End

Subprog AM_CURCTL(VALEUR)
Variable Integer VALEUR
# MENU LOCAL 3684 1-ALL 2-Autorised 3-Prohibited
  Actzo [M:TFB1]NBCUR
  Actzo [M:TFB1]CUR
  Case VALEUR
    When 1: #1-ALL
      Gosub RAZ_GRID_CUR
      Grizo [M:TFB1]NBCUR
      Grizo [M:TFB1]CUR
    When 2: #2-Autorised

    When 3: #3-Prohibited
       If [M:TFB1]CURMULT =  [V]CST_ANO
        fstat=2
      Endif
  Endcase

End

Subprog AM_CURMULT(VALEUR)
Variable Integer VALEUR
#Todo : Desactiver ML 3 Prohibited
  Call GES_CURCTL(VALEUR)
  If VALEUR  = [V]CST_ANO and [M]NBCUR>1
    GMESSAGE=func ASYRFNC.MES1(mess(26,173,1),[M:TFB1]COD)
  Endif
End

Subprog C_CUR(VALEUR)
Variable Char    VALEUR()
   If [M:TFB1]CURMULT  = [V]CST_ANO and nolign>1
    VALEUR=""
    GMESSAGE=func ASYRFNC.MES1(mess(26,173,1),[M:TFB1]COD)
    mkstat=2
  Endif
  If [M:TFB1]CURCTL=1 # Théoriquement désactivé
    VALEUR=""
    mkstat=2
    Grizo [M:TFB1]NBCUR
    Grizo [M:TFB1]CUR
  Endif
 For I=0 To [M:TFB1]NBCUR-1
 If VALEUR = [M:TFB1]CUR(I) and I<>nolign-1# No doublons & pas la ligne en cours
    VALEUR=""
    mkstat=2
 Endif
Next
End

######################################################################################

Subprog IB_COD
End

######################################################################################
## Après Modif - Clée Chargement données du header #X3-29247
######################################################################################
Subprog AM_COD(VALEUR)
Variable Char    VALEUR()
  Call SET_CURMULT(VALEUR,[M]BAN,[M]LEG)
  Affzo CURMULT, FILREF, NATPAY , NBCUR, CUR, CURCTL
  Call AM_CURCTL([M]CURCTL)
End

Subprog AM_BAN(VALEUR)
Variable Char    VALEUR()
  Call SET_CURMULT([M]COD,VALEUR,[M]LEG)
  Affzo CURMULT, FILREF, NATPAY , NBCUR, CUR, CURCTL
   Call AM_CURCTL([M]CURCTL)
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
  Call SET_CURMULT([M]COD,[M]BAN,VALEUR)
  Affzo CURMULT, FILREF, NATPAY , NBCUR, CUR, CURCTL
   Call AM_CURCTL([M]CURCTL)
End


