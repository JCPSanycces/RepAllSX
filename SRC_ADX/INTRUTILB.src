Subprog SUPWINDIC(APPLI,ECRAN)
Value Char APPLI,ECRAN

Call TR_DELWIN("_"+ECRAN,APPLI) From MSKDIV

End

# ------------------------------------------------------------------------------

Subprog CREWIND(APPLI,ECRAN)
Value Char APPLI,ECRAN

If clalev([F:AW_I])=0  : Local File =APPLI+".AWINDOW"  [AW_I]  : Endif
If clalev([F:AMK])=0  : Local File =APPLI+".AMSK"  [AMK]  : Endif
Read [AMK]CODMSK=ECRAN
If fstat<>0 : End : Endif

Local Integer I
Raz [F:AW_I]
[F:AW_I]WIN="_"+ECRAN
[F:AW_I]DES=[F:AMK]INTMSK
[F:AW_I]MDL=1
[F:AW_I]ENAFLG=2
[F:AW_I]TYP=2    : # Boite de dialogue
[F:AW_I]NBMSK=1
[F:AW_I]NOMMSK(0)=ECRAN
#[F:AW_I]INTMSK(0)=
[F:AW_I]FLGMSK(0)=2
[F:AW_I]ROWMSK(0)=10
[F:AW_I]WINTYP=1
For I=0 To 16
  [F:AW_I]BSTD(I)=1
Next I
If GPRODUIT<>1
  [F:AW_I]BSTD(17)=2
Else
  [F:AW_I]BSTD(18)=2
Endif
[F:AW_I]MODULE=[F:AMK]MODULE :#X3-48726

Trbegin [AW_I]
Write [F:AW_I]
Commit
End

# ------------------------------------------------------------------------------

Subprog MAJCLB(CODE,IDENT1,IDENT2,IDENT3,CLB)
Value Char CODE
Value Char IDENT1
Value Char IDENT2
Value Char IDENT3
Value Clbfile CLB

# Sur les dossiers historisés on n'écrit pas dans ACLOB pour les préférences
Local Char ID3(50) : ID3=toupper(IDENT3)
Local Char USERLOC(100) : USERLOC=toupper(IDENT1)

# Sur les dossiers historisés on ne lit pas dans ACLOB pour les préférences
#If GHISTO : Raz CLB : End : Endif
If GHISTO=1
  ID3="HIS"+ID3
  If clalev([F:AC_B])=0  : Local File =adxmother(0)+".ACLOB"  [AC_B]  : Endif
Else
  If clalev([F:AC_B])=0  : Local File ACLOB  [AC_B]  : Endif
Endif

[F:AC_B]CLOB=CLB    : # CC  - 11/02/2013  (pour tronquer la valeur si trop grande à la taille de la table)
CLB=[F:AC_B]CLOB

If CODE="USERPREF" and IDENT2="FAVORIS" and len(CLB)>0
  Local Integer I1
  I1=instr(1,CLB,"/MAIN>")
  If I1<>0 and len(CLB)>I1+5    : # Bug du traitement des clob serveur Web
    CLB=left$(CLB,I1+5)
  Endif
  If I1=0
    If  instr(2,CLB,"<")=0 and instr(1,CLB,"/>")<>0
#    Cas du message <MAIN ... />  0 favoris   : # Bug 95080    CC : 10/02/2014
    Else
# Vos favoris n'ont pas été mis à jour, vous dépassez la capacité de stockage autorisée
      Call MESSAGE(mess(230,124,1)) From GESECRAN
      End
    Endif
  Endif
Endif


Trbegin [AC_B]
Read [AC_B]ACB0=toupper(CODE);USERLOC;toupper(IDENT2);ID3
If fstat=0
  [F:AC_B]CLOB=CLB
  [F:AC_B]CREUSR=GUSER
  [F:AC_B]CREDAT=date$
  If dim([F:AC_B]CRETIM)>0 : [F:AC_B]CRETIM=time : Endif
  Rewrite [AC_B]
Else
  [F:AC_B]CODBLB=toupper(CODE)
  [F:AC_B]IDENT1=USERLOC
  [F:AC_B]IDENT2=toupper(IDENT2)
  [F:AC_B]IDENT3=ID3
  [F:AC_B]NAMBLB=""
  [F:AC_B]CLOB=CLB
  [F:AC_B]TYPDOC=""
  [F:AC_B]CREUSR=GUSER
  [F:AC_B]CREDAT=date$
  If dim([F:AC_B]CRETIM)>0 : [F:AC_B]CRETIM=time : Endif
  Write [F:AC_B]
Endif
Commit
End

# ------------------------------------------------------------------------------
Subprog DUPFAV(USRORIGIN,USRDEST)
Value Char USRORIGIN
Value Char USRDEST

# Duplicate "favoris" from USERORIGIN to USRDEST

# Sur les dossiers historisés on ne lit pas dans ACLOB pour les préférences
#If GHISTO : Raz CLB : End : Endif
If GHISTO=1
  ID3="HIS"+ID3
  If clalev([F:AC_B])=0  : Local File =adxmother(0)+".ACLOB"  [AC_B]  : Endif
Else
  If clalev([F:AC_B])=0  : Local File ACLOB  [AC_B]  : Endif
Endif

# Les favoris sont stockés avec le login et pas avec le CODUSR

If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
Local Char LOGINORIGIN,LOGINDEST

Read [AUS]CODUSR=USRORIGIN
If fstat=0
  LOGINORIGIN=[F:AUS]LOGIN
Else
  End
Endif

Read [AUS]CODUSR=USRDEST
If fstat=0
  LOGINDEST=[F:AUS]LOGIN
Else
  End
Endif


Local Clbfile CLBPREF(10)
Read [AC_B]ACB0="USERPREF";toupper(LOGINORIGIN);"FAVORIS";""
If fstat=0
  CLBPREF=[F:AC_B]CLOB
Endif



Trbegin [AC_B]
Read [AC_B]ACB0="USERPREF";toupper(LOGINDEST);"FAVORIS";""
If fstat=0
  [F:AC_B]CLOB=CLBPREF
#  [F:AC_B]CREUSR=GUSER
  [F:AC_B]CREDAT=date$
  If dim([F:AC_B]CRETIM)>0 : [F:AC_B]CRETIM=time : Endif
  If dim([F:AC_B]UPDUSR)>0 : [F:AC_B]UPDUSR=GUSER : Endif

  Rewrite [AC_B]
Else
  [F:AC_B]CODBLB="USERPREF"
  [F:AC_B]IDENT1=toupper(LOGINDEST)
  [F:AC_B]IDENT2="FAVORIS"
  [F:AC_B]IDENT3=""
  [F:AC_B]NAMBLB=""
  [F:AC_B]CLOB=CLBPREF
  [F:AC_B]TYPDOC=""
  [F:AC_B]CREUSR=GUSER
  [F:AC_B]CREDAT=date$
  If dim([F:AC_B]CRETIM)>0 : [F:AC_B]CRETIM=time : Endif
  Write [F:AC_B]
Endif
Commit
End

# ------------------------------------------------------------------------------

Subprog READCLB(CODE,IDENT1,IDENT2,IDENT3,CLB)
Value Char CODE
Value Char IDENT1
Value Char IDENT2
Value Char IDENT3
Variable Clbfile CLB

Local Char ID3(50) : ID3=toupper(IDENT3)
# Sur les dossiers historisés on ne lit pas dans ACLOB pour les préférences
#If GHISTO : Raz CLB : End : Endif
If GHISTO=1
  ID3="HIS"+ID3
  If clalev([F:AC_B])=0  : Local File =adxmother(0)+".ACLOB"  [AC_B]  : Endif
Else
  If clalev([F:AC_B])=0  : Local File ACLOB  [AC_B]  : Endif
Endif
Read [AC_B]ACB0=toupper(CODE);toupper(IDENT1);toupper(IDENT2);ID3
If fstat=0
  CLB=[F:AC_B]CLOB
#   Pb sur les favoris  CC 07/12/2012
  If CODE="USERPREF" and IDENT2="FAVORIS" and len(CLB)>0
    Local Integer I1
    I1=instr(1,CLB,"/MAIN>")
    If I1<>0 and len(CLB)>I1+5
      CLB=left$(CLB,I1+5)
    Elsif I1=0
      Raz CLB
    Endif
  Endif
Else
  Raz CLB
Endif
End

# ------------------------------------------------------------------------------

Subprog ISSCREENTOGENER(APPLI1,FENETRE1,SILENCE)
Value Char APPLI1,FENETRE1
Value Integer SILENCE
Local Integer ISSCREENTOGEN,SIL
SIL=SILENCE
Goto EXECWINCONT

Subprog ISWINTOGENER(APPLI1,FENETRE1)
Value Char APPLI1,FENETRE1

#  On vérifie si la fenêtre est marquée comme devant être générée
#  auquel cas on valide tous les masques et la fenêtres
Local Integer SIL
SIL=1

$EXECWINCONT
Local Integer NODISP
If FENETRE1="TEMPON" : NODISP=1 : Endif

$EXECWINOK
Local Char APPLI,FENETRE(20)
Local Integer GENER,NBTRY
APPLI=APPLI1
FENETRE=FENETRE1
If FENETRE="AASELECT"  : FENETRE="_SELBOX"  : Endif
If FENETRE="AACHOOSE"  : FENETRE="_CHOOSE"  : Endif
If FENETRE="AAFORMULA" : FENETRE="_FORMULA" : Endif

If GHISTO : APPLI=adxmother(0) : Endif
$RETRYWIN
If clalev([F:AEL])=0  : Local File =APPLI+".AELT"  [AEL]  : Endif
Read [AEL]ELT0="FENX";FENETRE;GLANGUE
#If fstat<>0 or (fstat=0 and [F:AEL]ELTINV="G")
If fstat=0
  If [F:AEL]ELTINV="G"
    Gosub GENSCREENWIN
  Elsif [F:AEL]ELTINV="X"
    NBTRY+=1
    If NBTRY=1 and NODISP=0
      Call TEMPON("*"-mess(291,123,1)-FENETRE1) From GESECRAN  : # "SYNCHRONISATION"
    Endif
    If NBTRY<=30
      Sleep 1
      Goto RETRYWIN
    #111892 after 30 try with "X", pass to "G" to have global validation next time
    Else
      If adxlog=0
         Trbegin [AEL]
         [F:AEL]ELTINV="G"
         Rewrite [AEL]
         Commit
      Endif
    Endif
  Endif
Endif
If NBTRY>0 and NODISP=0
  Call TEMPOFF From GESECRAN
Endif
If dim(EXECWINOK1)>0 : Return : Endif
End


#  On valide les écrans et la fenêtre
$GENSCREENWIN
Local Char TSTPWIN(14)
If adxlog=0
  Read [AEL]ELT0="FENX";FENETRE;GLANGUE
  If fstat=0
    Trbegin [AEL]
    [F:AEL]ELTINV="X"
    Rewrite [AEL]
    Commit
    TSTPWIN=[F:AEL]ELTSTP
  Endif
Endif
Local Char AAKEY(100)
#  On valide les écrans et la fenêtre
If clalev([F:AWI])=0  : Local File =APPLI+".AWINDOW"  [AWI]  : Endif
Read [AWI]AWI0=FENETRE1
If fstat<>0 : Return : Endif
Local Integer I,K,MOK
If NODISP=0 : Call TEMPON(mess(291,123,1)-FENETRE1) From GESECRAN : Endif  : # "Synchronisation"
If dim(GI_LLAN)<0 : Call GLOBWEB(APPLI) From INTRUTILA : Endif
If [F:AWI]MSKENT<>""
  Read [AEL]ELT0="SCRN";[F:AWI]MSKENT;"ALL"
  If fstat<>0 or [F:AEL]ELTSTP<TSTPWIN
    Call VALID([F:AWI]MSKENT,APPLI,GI_NBLAN,GI_LLAN,SIL,MOK) From VALMSK
  Endif
Endif
#101312
Local Integer WOUVACV
If clalev([F:ACV])<=0
 WOUVACV=1
 Local File =APPLI+".ACTIV"  [ACV]
Endif

For I=0 To [F:AWI]NBMSK-1
 # -- mb 3.9.2012 bug 84117 ---#
 K = 1
 If [F:AWI]ACTMSK(I)<>"" & clalev([F:ACV])>0
  Read [ACV]CODACT = [F:AWI]ACTMSK(I)
  If fstat or [F:ACV]FLACT<>2
   K = 0
  Endif
 Endif
 If K
 # -- mb 3.9.2012 bug 84117 ---#
  Read [AEL]ELT0="SCRN";[F:AWI]NOMMSK(I);"ALL"
  If fstat<>0 or [F:AEL]ELTSTP<TSTPWIN
    Call VALID([F:AWI]NOMMSK(I),APPLI,GI_NBLAN,GI_LLAN,SIL,MOK) From VALMSK
  Endif
 Endif
Next I

#101312
If WOUVACV=1 & clalev([F:ACV])>0
 Close Local File [ACV]
Endif

If dim(ISSCREENTOGEN)<=0
  Global Integer COMFROMSCRTOGEN
  Call VALID(FENETRE1,APPLI,SIL,MOK) From VALWIN
  Kill COMFROMSCRTOGEN
Endif

If NODISP=0 : Call TEMPOFF From GESECRAN : Endif

Return


# ---------------------------------------------------------------------------------------------------------

Subprog GENERDIFFWIN(APPLI,FENETRE1)
Value Char APPLI
Value Char FENETRE1

#  Invalide la fenêtre pour forcer une génération complète

Local Char FENETRE
FENETRE=FENETRE1
If FENETRE="AASELECT"  : FENETRE="_SELBOX"  : Endif
If FENETRE="AACHOOSE"  : FENETRE="_CHOOSE"  : Endif
If FENETRE="AAFORMULA" : FENETRE="_FORMULA" : Endif

If FENETRE="TEMPON"
  Local Integer MOK
  Call VALID(FENETRE1,APPLI,1,MOK) From VALWIN
  End
Endif
If dim(GI_DOSS)<0 or dim(GI_LLAN)<0 or GI_DOSS<>APPLI
  Call GLOBWEB(APPLI) From INTRUTILA
Endif


If clalev([F:AEL])=0  : Local File =APPLI+".AELT"  [AEL]  : Endif
#If clalev([F:AEK])=0  : Local File =APPLI+".AELTLINK"  [AEK]  : Endif


Local Integer WI_I,WI_J,WE_TREC
Local Char HORDAT(14)
HORDAT=date$+left$(time$,2)+mid$(time$,4,2)+right$(time$,7)

#  Mise à jour des liens
If adxlog=0
  Trbegin [AEL]
  WE_TREC=1
Endif

#Gosub WI_SUPWIND From INTRUTILB
For WI_J=1 To GI_NBLAN
  If GI_VLAN(WI_J)=0
      Readlock [AEL]ELT0="FENX";FENETRE;GI_LLAN(WI_J)
      If fstat=0
        [F:AEL]ELTINV="G"
        Rewrite [AEL]
      Else
        [F:AEL]ELTTYP="FENX"
        [F:AEL]ELT=FENETRE
        [F:AEL]ELTLAN=GI_LLAN(WI_J)
        [F:AEL]ELTSTP=HORDAT
        [F:AEL]ELTINV="G"
        Write [AEL]
      Endif
      Readlock [AEL]ELT0="FENW";FENETRE;GI_LLAN(WI_J)
      If fstat=0
        [F:AEL]ELTINV="G"
        Rewrite [AEL]
      Else
        [F:AEL]ELTTYP="FENW"
        [F:AEL]ELT=FENETRE
        [F:AEL]ELTLAN=GI_LLAN(WI_J)
        [F:AEL]ELTSTP=HORDAT
        [F:AEL]ELTINV="G"
        Write [AEL]
      Endif
  Endif
Next WI_J

If  WE_TREC=1 : Commit : Endif
End


# ------------------------------------------------------------------------------

Subprog GENERDIFFSCREEN(APPLI,SCREEN)

#  Génération différée de l'écran SCREEN
#  Positionne le flag sur toutes les fenêtres qui l'utilise

Value Char APPLI                   : # Nom du dossier
Value Char SCREEN                  : # Nom du masque
                                   : # Si 1 on invalide les écrans utilisant MENL en bouton

Local Integer WI_J,WE_TREC

If dim(GI_DOSS)<0 or dim(GI_LLAN)<0 or GI_DOSS<>APPLI
  Call GLOBWEB(APPLI) From INTRUTILA
Endif
If clalev([F:AEL])=0  : Local File =APPLI+".AELT"      [AEL]  : Endif
If clalev([F:AEK])=0  : Local File =APPLI+".AELTLINK"  [AEK]  : Endif
Local Char HORDAT(14)
HORDAT=date$+left$(time$,2)+mid$(time$,4,2)+right$(time$,7)

#  Mise à jour des liens
If adxlog=0
  Trbegin [AEL]
  WE_TREC=1
Endif


Filter [AEK] Where ELTTYPLK="SCRN" and ELTLK=SCREEN and ELTTYP="FENX"
For [AEK]
    For WI_J=1 To GI_NBLAN
      If GI_VLAN(WI_J)=0
        Readlock [AEL]ELT0="FENW";[F:AEK]ELT;GI_LLAN(WI_J)
        If fstat=0
          [F:AEL]ELTINV="G"
          [F:AEL]ELTSTP=HORDAT
          Rewrite [AEL]
        Endif
        Readlock [AEL]ELT0="FENX";[F:AEK]ELT;GI_LLAN(WI_J)
        If fstat=0
          [F:AEL]ELTINV="G"
          [F:AEL]ELTSTP=HORDAT
          Rewrite [AEL]
        Endif
      Endif
    Next WI_J
Next
Filter [AEK]

If  WE_TREC=1 : Commit : Endif

If func AFNC.PARTSEP(ver$(0),2," ")>"16r.217"
  Local Char NAMF(250)
  NAMF=filpath("ECR",SCREEN,"msk",APPLI)
  Openo NAMF,0 Using [DIFM]
  Openo Using [DIFM]
Endif
End

#----------------------------------------------------------------------------------

Subprog ISWGPRESENT(APPLI1,WINDOW)
Value Char APPLI1
Value Char WINDOW
If WINDOW="" : End : Endif

Local Char APPLI
APPLI=APPLI1
If APPLI="" : APPLI=nomap : Endif

Local Integer OKTRT
Call EXISTE_ADX("",APPLI,"WG"+WINDOW,OKTRT) From ORDSYS
If OKTRT<=0
  Local Integer SAVGVALID : SAVGVALID=GVALIDDIFF
  GVALIDDIFF=1
  Call VALID(WINDOW,APPLI,1,OKTRT) From VALWIN
  GVALIDDIFF=SAVGVALID
Endif
End

#----------------------------------------------------------------------------------

Subprog ISW1PRESENT(APPLI1,SCREEN)
Value Char APPLI1
Value Char SCREEN
If SCREEN="" : End : Endif

Local Char APPLI
APPLI=APPLI1
If APPLI="" : APPLI=nomap : Endif

Local Integer OKTRT
Call EXISTE_ADX("",APPLI,"W1"+SCREEN,OKTRT) From ORDSYS
If OKTRT<=0
  If dim(GI_LLAN)<0 : Call GLOBWEB(APPLI) From INTRUTILA : Endif
  Local Integer SAVGVALID : SAVGVALID=GVALIDDIFF
  GVALIDDIFF=1
  Call VALID(SCREEN,APPLI,GI_NBLAN,GI_LLAN,1,OKTRT) From VALMSK
  GVALIDDIFF=SAVGVALID
Endif
End

#----------------------------------------------------------------------------------

Subprog ISWINDOWOK(APPLI1,FENETRE1)
Value Char APPLI1
Value Char FENETRE1
If FENETRE1="" : End : Endif
Local Integer SIL : SIL=1
Local Integer NODISP : NODISP=1
Local Integer EXECWINOK1
Local Integer SAVGVALID : SAVGVALID=GVALIDDIFF
GVALIDDIFF=1
Gosub EXECWINOK
GVALIDDIFF=SAVGVALID
End

#----------------------------------------------------------------------------------

Subprog ISSCREENOK(APPLI1,SCREEN)
Value Char APPLI1
Value Char SCREEN
If SCREEN="" : End : Endif

Local Char APPLI
APPLI=APPLI1
If APPLI="" : APPLI=nomap : Endif

If filinfo(filpath("ECR",SCREEN,"msk",APPLI),7)<=0
  # Issue X3-103790 - 2018-09-28 by ALSHE : screen valitation for historical folders
  # check if it is an historical folder
  If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER = adxmother
  If (!fstat & [ADS]DOSHIS = APPLI) # historical folder
    # check if screen exists in original folder
    If filinfo(filpath("ECR",SCREEN,"msk",adxmother),7)<=0
      GMESSAGE = mess(1767,10033,1)+":"-SCREEN-"-"-mess(278,133,1)-adxmother-"!"
      OK = 0
    Endif
  # End issue X3-103790
  Else # standard folder
    If dim(GI_LLAN)<0 : Call GLOBWEB(APPLI) From INTRUTILA : Endif
    Local Integer OKTRT
    Local Integer SAVGVALID : SAVGVALID=GVALIDDIFF
    GVALIDDIFF=1
    Call VALID(SCREEN,APPLI,GI_NBLAN,GI_LLAN,1,OKTRT) From VALMSK
    GVALIDDIFF=SAVGVALID
  Endif
Endif
End
#----------------------------------------------------------------------------------
Funprog JSONONLYPARAM(DOS)
    Value Char DOS
    Variable Integer JSONLY : JSONLY=0
    If DOS=nomap
      If(dim(GJSONONLY) >0 and  GJSONONLY = 2) : JSONLY=1 :Endif
    Else
      If clalev([F:ADW])=0  : Local File = DOS+".ADOVAL"    [ADW]  : Endif
      Read [ADW]ADW0 = "";"";"JSONONLY"
      If(fstat<2)
        If([F:ADW]VALEUR = "2") : JSONLY=1 : Endif
      Endif
    Endif
End JSONLY

