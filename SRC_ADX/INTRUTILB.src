#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char LISTSCR(20)(1..10)
Local Integer NBSCR
Call LWINDAT(nomap,"20050101000000",LISTSCR,NBSCR,2,1)
End
Call SYNCHROFEN(nomap,2,1)
End
#
#  INTRUTILB : Exploitation des liens dans les tables AELT et AELTLINK
#
#    Version initiale :   CC - 20/02/2003
#
# Status : ELTINV
#       ""  : Ok (no generation)
#       "G" : Full generation
#       "I" : Assembly only
#       "X" : Transition situation, avoid deadlocks
# --------------------------------------------------------------------

#  Crée l'enreg écran et ses liens
$WI_CRESCRN
Local Integer WI_I,WI_J
Local Integer WI_NBB,WI_MBOUT(1..30)
Gosub WI_SUPSCRN
  [F:AEL]ELTTYP="SCRN"
  [F:AEL]ELT=MASQUE
  [F:AEL]ELTLAN="ALL"
  [F:AEL]ELTSTP=WE_HORDAT
  [F:AEL]ELTINV=""
  Write [AEL]
For WI_J=1 To BLC_NBR
  If BLC_TYP(WI_J)<=2 & BLC_TYP(WI_J)>0 :#115994 ne pas generer ligne pour les blocs non actifs
    For WI_I=1 To LIG_NBR(WI_J)
      If LIG_LIB(WI_J,WI_I)<>0 and (LIG_SAI(WI_J,WI_I)=1 or LIG_SAI(WI_J,WI_I)=2)
        [F:AEK]ELTTYP="SCRN"
        [F:AEK]ELT=MASQUE
        [F:AEK]ELTTYPLK="MENL"
        [F:AEK]ELTLK="M"+format$("N0:"+func GENMENULOC.FMTMNL(LIG_LIB(WI_J,WI_I)),LIG_LIB(WI_J,WI_I))
        If LIG_GRA(WI_J,WI_I)>=3 and LIG_GRA(WI_J,WI_I)<=6
          [F:AEK]ELTUSAGE="B"
          WI_NBB+=1
          WI_MBOUT(WI_NBB)=LIG_LIB(WI_J,WI_I)
          Write [AEK]
        Else
# Pour garder l'écriture en type B si le menu local est utilisé plusieurs fois dans l'écran
          [F:AEK]ELTUSAGE="M"
          If !find(LIG_LIB(WI_J,WI_I),WI_MBOUT(1..WI_NBB))
            Write [AEK]
          Endif
       Endif
      Endif
    Next WI_I
  Endif
Next WI_J
# Invalide les fenêtres qui utilisent l'écran
Call INVALID(APPLI,"SCRN",MASQUE,"ALL",0) From INTRUTILB

Return


#  Supprime l'enreg screen et ses liens
$WI_SUPSCRN:
  Readlock [AEL]ELT0="SCRN";MASQUE;"ALL"
  If fstat=0 :  Delete [AEL] Curr : Endif
  Delete [AEK] Where ELTTYP="SCRN" and ELT=MASQUE
Return



#  Crée l'enreg Objet et ses liens
$WI_CREOBJT
Local Integer WI_I
Gosub WI_SUPOBJT
  [F:AEL]ELTTYP="OBJT"
  [F:AEL]ELT=OBJET
  [F:AEL]ELTLAN="ALL"
  [F:AEL]ELTSTP=WE_HORDAT
  [F:AEL]ELTINV=""
  Write [AEL]
  For WI_I=1 To AOB_NBSEL
    If AOB_SELNOLIB(WI_I)<>0
      [F:AEK]ELTTYP="OBJT"
      [F:AEK]ELT=OBJET
      [F:AEK]ELTTYPLK="MENL"
      [F:AEK]ELTLK="M"+format$("N0:"+func GENMENULOC.FMTMNL(AOB_SELNOLIB(WI_I)),AOB_SELNOLIB(WI_I))
      [F:AEK]ELTUSAGE="M"
      Write [AEK]
    Endif
  Next WI_I
# Invalide les fenêtres qui utilisent l'objet
Call INVALID(APPLI,"OBJT",OBJET,"ALL",0) From INTRUTILB
Return

#  Supprime l'enreg objet et ses liens
$WI_SUPOBJT:
  Readlock [AEL]ELT0="OBJT";OBJET;"ALL"
  If fstat=0 :  Delete [AEL] Curr : Endif
  Delete [AEK] Where ELTTYP="OBJT" and ELT=OBJET
Return


#  Crée l'enreg fenêtre (1 par langue) et ses liens
$WI_CREWIND:
  Local Integer WI_I,WI_J
  Gosub WI_SUPWIND
  For WI_J=1 To GI_NBLAN
    If GI_VLAN(WI_J)=0
      [F:AEL]ELTTYP="FENX"
      [F:AEL]ELT=FENETRE
      [F:AEL]ELTLAN=GI_LLAN(WI_J)
      [F:AEL]ELTSTP=WE_HORDAT
      [F:AEL]ELTINV=""
      Write [AEL]
      [F:AEL]ELTTYP="FENW"
      Write [AEL]
    Endif
  Next WI_J

# Liens fenêtre - écran
  For WI_J=1 To AWI_NBRMSK
    If AWI_FLGMSK(WI_J)=2 and AWI_NOMMSK(WI_J)<>""
      [F:AEK]ELTTYP="FENX"
      [F:AEK]ELT=FENETRE
      [F:AEK]ELTTYPLK="SCRN"
      [F:AEK]ELTLK=AWI_NOMMSK(WI_J)
      [F:AEK]ELTUSAGE=" "
      Write [AEK]
    Endif
  Next WI_J

# Liens fenêtre - objet
  For WI_J=1 To AWB_NBR
      If AWB_OBJ(WI_J)=AWI_OBJ : WI_I+=1 : Endif
      [F:AEK]ELTTYP="FENX"
      [F:AEK]ELT=FENETRE
      [F:AEK]ELTTYPLK="OBJT"
      [F:AEK]ELTLK=AWB_OBJ(WI_J)
      [F:AEK]ELTUSAGE=" "
      If AWB_OBJ(WI_J)<>AWI_OBJ or WI_I=1
        Write [AEK]
      Endif
  Next WI_J
Return

#  Supprime l'enreg fenêtre et ses liens
$WI_SUPWIND:
  Local Integer WI_K
  For WI_K=1 To GI_NBLAN
    If GI_VLAN(WI_K)=0
      Readlock [AEL]ELT0="FENX";FENETRE;GI_LLAN(WI_K)
      If fstat=0 : Delete [AEL] Curr : Endif
      Readlock [AEL]ELT0="FENW";FENETRE;GI_LLAN(WI_K)
      If fstat=0 : Delete [AEL] Curr : Endif
    Endif
  Next WI_K
  Delete [AEK] Where ELTTYP="FENX" and ELT=FENETRE
Return


#  Crée l'enreg menu local MCOU dans la langue LANGUE
$WI_CREMENL:
  Local Char WI_CMENL
  WI_CMENL="M"+format$("N0:"+func GENMENULOC.FMTMNL(MCOU),MCOU)
  Readlock [AEL]ELT0="MENL";WI_CMENL;LANGUE
  [F:AEL]ELTTYP="MENL"
  [F:AEL]ELT=WI_CMENL
  [F:AEL]ELTLAN=LANGUE
  [F:AEL]ELTSTP=WE_HORDAT
  [F:AEL]ELTINV=""
  If fstat=0
    Rewrite [AEL]
  Else
    Write [AEL]
  Endif
# Invalide les fenêtres Web qui utilisent le menu local modifié
# Invalide les écrans (et les fenêtres Web et C/S) qui utilisent le menu local en bouton
  Call INVALID(APPLI,"MENL",WI_CMENL,LANGUE,1) From INTRUTILB
Return

#  Supprime l'enreg menu local MCOU dans toutes les langues
$WI_SUPMENL:
  Local Char WI_CMENL
  WI_CMENL="M"+format$("N0:"+func GENMENULOC.FMTMNL(MCOU),MCOU)
  Delete [AEL] Where ELTTYP="MENL" and ELT=WI_CMENL
Return


#  Crée l'enreg de type SRVL
$WI_CRESRVL:
  Readlock [AEL]ELT0="SRVL";KEYS;LANCOU
  [F:AEL]ELTTYP="SRVL"
  [F:AEL]ELT=KEYS
  [F:AEL]ELTLAN=LANCOU
  [F:AEL]ELTSTP=WE_HORDAT
  [F:AEL]ELTINV=""
  If fstat=0
    Rewrite [AEL]
  Else
    Write [AEL]
  Endif
Return



#  Crée l'enreg Profil
$WI_CREPROF
  Gosub WI_SUPPROF
  [F:AEL]ELTTYP="PROF"
  [F:AEL]ELT=PROF
  [F:AEL]ELTLAN="ALL"
  [F:AEL]ELTSTP=WE_HORDAT
  [F:AEL]ELTINV=""
  Write [AEL]
Return

#  Supprime l'enreg profil
$WI_SUPPROF:
  Readlock [AEL]ELT0="PROF";PROF;"ALL"
  If fstat=0 :  Delete [AEL] Curr : Endif
Return



# ------------------------------------------------------------------------------

Subprog INVALID(APPLI,MTY1,MELT,MLAN,USAGE)
#  Invalide les éléments suite à la modification de l'élément MELT de type MTY1
#     MTY1=MENL (menu local)                       --> Invalide FENW + SCRN langue MLAN
#     MTY1=SCRN, OBJT (écran, objet)               --> Invalide FENX et FENW toutes langues
#     MTY1=SCR1 (écran suite à modif menu radio bouton)  --> Invalide FENX, FENW (toutes langues) et SCRN

Value Char APPLI                   : # Nom du dossier
Value Char MTY1                    : # Type d'élément (MENL,SCRN, SCR1)
Value Char MELT                    : # Nom de l'élément (ex: AMK1 ou M0012)
Value Char MLAN                    : # Langue de l'élément (ex: FRA ou ALL si toutes langues)
Value Integer USAGE                : # Type d'utilisation
                                   : # Si 1 on invalide les écrans utilisant MENL en radio bouton

Local Char MTYP,ADAPP
Local Integer WI_H,WI_J,TYPINV

Call GLOBWEB(APPLI) From INTRUTILA
If clalev([F:AEL])=0  : Local File =APPLI+".AELT"      [AEL]  : Endif
If clalev([F:AEK])=0  : Local File =APPLI+".AELTLINK"  [AEK]  : Endif
If clalev([F:AEK1])=0 : Local File =APPLI+".AELTLINK"  [AEK1] : Endif

MTYP=MTY1
If MTYP="SCR1"
  Readlock [AEL]="SCRN";MELT;"ALL"
  [F:AEL]ELTINV="I"
  Rewrite [AEL]
  MTYP="SCRN"
Endif

Filter [AEK] Where ELTTYPLK=MTYP and ELTLK=MELT
For [AEK]
  Case [F:AEK]ELTTYP
    When "FENX"
       Case MTYP
         When "SCRN","OBJT"
           For WI_H=1 To GI_NBLAN
             Readlock [AEL]ELT0="FENW";[F:AEK]ELT;GI_LLAN(WI_H)
             If fstat=0 and [F:AEL]ELTINV<>"G" and [F:AEL]ELTINV<>"X"
               [F:AEL]ELTINV="I"
               Rewrite [AEL]
             Endif
             Readlock [AEL]ELT0="FENX";[F:AEK]ELT;GI_LLAN(WI_H)
             If fstat=0 and [F:AEL]ELTINV<>"G" and [F:AEL]ELTINV<>"X"
               [F:AEL]ELTINV="I"
               Rewrite [AEL]
             Endif
           Next WI_H
         When "MENL"
           Readlock [AEL]ELT0="FENW";[F:AEK]ELT;MLAN
           If fstat=0 and [F:AEL]ELTINV<>"G" and [F:AEL]ELTINV<>"X"
             [F:AEL]ELTINV="I"
             Rewrite [AEL]
           Endif
       Endcase
    When "SCRN"
#      Si menu utilisé sous forme de bouton  --> Invalide les écrans qui l'utilise
       TYPINV=0
       If USAGE=1 and [F:AEK]ELTUSAGE="B" and not(func JSONONLYPARAM(APPLI))
         Readlock [AEL]="SCRN";[F:AEK]ELT;"ALL"
         [F:AEL]ELTINV="I"
         Rewrite [AEL]
         TYPINV=1
       Endif
       Filter [AEK1] Where ELTTYPLK="SCRN" and ELTLK=[F:AEK]ELT
         Gosub WI_INVALLFEN
       Filter [AEK1]
    When "OBJT"
       TYPINV=0
       Filter [AEK1] Where ELTTYPLK="OBJT" and ELTLK=[F:AEK]ELT
         Gosub WI_INVALLFEN
       Filter [AEK1]
    When Default
  Endcase
Next
Filter [AEK]



End


$WI_INVALLFEN
  For [AEK1]
    For WI_J=1 To GI_NBLAN
      Readlock [AEL]ELT0="FENW";[F:AEK1]ELT;GI_LLAN(WI_J)
      If fstat=0 and [F:AEL]ELTINV<>"G" and [F:AEL]ELTINV<>"X"
        [F:AEL]ELTINV="I"
        Rewrite [AEL]
      Endif
      If TYPINV=1
        Readlock [AEL]ELT0="FENX";[F:AEK1]ELT;GI_LLAN(WI_J)
        If fstat=0 and [F:AEL]ELTINV<>"G" and [F:AEL]ELTINV<>"X"
          [F:AEL]ELTINV="I"
          Rewrite [AEL]
        Endif
      Endif
    Next WI_J
  Next

Return

# ---------------------------------------------------------------------------

Subprog LSCRBOUT(APPLI,NOMEN,LISTSCR,NBSCR,USAGE,GEN)
#
#  Donne la liste des écrans utilisant le menu local NOMEN sous forme de bouton
#  Si USAGE=0   on rend la liste complète en fonction de la taille de LISTSCR
#          =1   idem + on affiche la liste complète dans une trace
#  Si GEN  =1   on invalide les écrans concernés

Value Char APPLI                       : # Nom du dossier
Value Integer NOMEN                    : # Numéro du menu local
Variable Char LISTSCR()(1..)           : # Table réceptacle de la liste des écrans invalides
Variable Integer NBSCR                 : # Nombre d'écrans invalides
Value Integer USAGE                    : # Type d'utilisation
Value Integer GEN                      : # Invalidation écran (1) ou Non

Local Integer WI_I

Raz NBSCR,LISTSCR
Local File =APPLI+".AELTLINK"  [AEK]

If USAGE=1 : Call OUVRE_TRACE(" ") From LECFIC : Endif

Filter [AEK] Where ELTTYPLK="MENL" and ELTLK="M"+format$("N0:"+func GENMENULOC.FMTMNL(NOMEN),NOMEN)
For [AEK]
  NBSCR+=1
  If USAGE=1 : Call ECR_TRACE([F:AEK]ELT,0) From GESECRAN : Endif
  If NBSCR<=dim(LISTSCR) : LISTSCR(NBSCR)=[F:AEK]ELT : Endif
  If GEN=1
    Call INVALID(APPLI,"SCR1",[F:AEK]ELT,"ALL",0)
  Endif
Next
Filter [AEK]

If USAGE=1
  Call ECR_TRACE(mess(136,150,1)-":"-num$(NBSCR),0) From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

End

# ---------------------------------------------------------------------------

Subprog LSCRINV(APPLI,LISTSCR,NBSCR,USAGE,GEN)
#
#  Recherche les écrans invalides
#  Si USAGE=0   on rend le nombre (NBSCR) et la liste dans LISTSCR (selon la dimension de LISTSCR)
#          =1   idem + on affiche la liste complete dans une trace (trace gérée à l'extérieur)
#          =2   idem + on affiche la liste complete dans une trace et on ouvre et lit la trace
#  Si GEN  =1   on valide les écrans concernes

Value Char APPLI                       : # Nom du dossier
Variable Char LISTSCR()(1..)           : # Table réceptacle de la liste des écrans invalides
Variable Integer NBSCR                 : # Nombre d'écrans invalides
Value Integer USAGE                    : # Type d'utilisation
Value Integer GEN                      : # Génération Oui/Non

Local Integer MOK

Raz NBSCR,LISTSCR
Local File =APPLI+".AELT"     [AEW]

If USAGE=2 : Call OUVRE_TRACE(" ") From LECFIC : Endif


Filter [AEW] Where ELTTYP="SCRN" and ELTINV="I"
For [AEW]
  NBSCR+=1
  If USAGE>=1 : Call ECR_TRACE([F:AEW]ELT,0) From GESECRAN : Endif
  If NBSCR<=dim(LISTSCR) : LISTSCR(NBSCR)=[F:AEW]ELT : Endif
  If GEN=1
    Call VALID([F:AEW]ELT,APPLI,1,GLANGUE,0,MOK) From VALMSK
  Endif
Next
Filter [AEW]

If USAGE>=1
  If NBSCR=0
    Call ECR_TRACE(mess(127,150,1),0) From GESECRAN
  Else
    Call ECR_TRACE(mess(128,150,1)-num$(NBSCR),0) From GESECRAN
  Endif
  If USAGE=2
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif
End

# ---------------------------------------------------------------------------

Subprog LWINDAT(APPLI,TSTAMP,LISTSCR,NBSCR,USAGE,GEN)
#
#  Recherche les fenêtres générées avant le timestamp TSTAMP
#  Si USAGE=0   on rend le nombre (NBSCR) et la liste dans LISTSCR (selon la dimension de LISTSCR)
#          =1   idem + on affiche la liste complete dans une trace (trace gérée à l'extérieur)
#          =2   idem + on affiche la liste complete dans une trace et on ouvre et lit la trace
#  Si GEN  =1   on valide les fenêtres concernées et supprime les inexistantes

Value Char APPLI,TSTAMP
Value Integer USAGE,GEN
Variable Integer NBSCR
Variable Char LISTSCR()(1..)

Local Integer AA,NBFEN,NBSUP,MOK,L

Local File =APPLI+".AELT"     [AEL]
Local File =APPLI+".AWINDOW"  [AWI]
L = type([F:AEL]ELT)-10
Local Char FENETRE(L),LISTFEN(L)(1..8000)


If USAGE=2 : Call OUVRE_TRACE(" ") From LECFIC : Endif

Filter [AEL] Where (ELTTYP="FENX" or ELTTYP="FENW") and ELTSTP<TSTAMP
For [AEL]
  FENETRE=[F:AEL]ELT
  If find(FENETRE,LISTFEN(1..NBFEN)) : Goto SUITWDAT : Endif
  NBFEN+=1
  LISTFEN(NBFEN)=FENETRE
  NBSCR+=1
  If USAGE>=1 : Call ECR_TRACE([F:AEL]ELT-[F:AEL]ELTSTP,0) From GESECRAN : Endif
  If NBSCR<=dim(LISTSCR) : LISTSCR(NBSCR)=[F:AEL]ELT : Endif
  If GEN=1
    Read [AWI]AWI0=[F:AEL]ELT
    If fstat=0
      Call VALID([F:AEL]ELT,APPLI,1,MOK) From VALWIN
    Else  : # Fenêtre inexistante
      If USAGE>=1 : Call ECR_TRACE(mess(19,150,1)-":"-[F:AEL]ELT,0) From GESECRAN : Endif
      Call SUPWIND(APPLI,[F:AEL]ELT) From INTRUTILB
      NBSUP+=1
    Endif
  Endif
$SUITWDAT:
Next
Filter [AEL]

If USAGE>=1
  If NBSCR=0
    Call ECR_TRACE(mess(135,150,1),0) From GESECRAN
  Else
    Call ECR_TRACE(mess(69,150,1)-":"-num$(NBSCR),0) From GESECRAN
  Endif
  If NBSUP<>0
    Call ECR_TRACE(mess(133,150,1)-num$(NBSUP),0) From GESECRAN
  Endif
  If USAGE=2
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif


End


# ---------------------------------------------------------------------------

Subprog ISSCRINV(APPLI,SCREEN,RESULT,USAGE)
#
#  Vérifie si l'écran SCREEN est valide ou non
#  Si il est valide RESULT=0 si invalide RESULT=1 si non généré RESULT=2
#  Si USAGE=0   on rend RESULT
#          =1   on lance la validation de l'écran

Value Char APPLI                       : # Nom du dossier
Value Char SCREEN()                    : # Nom de l'écran
Variable Integer RESULT                : # Résultat
Value Integer USAGE                    : # Type d'utilisation

Raz RESULT

If clalev([F:AEL])=0  : Local File =APPLI+".AELT"  [AEL]  : Endif
Read [AEL]ELT0="SCRN";SCREEN;"ALL"
If fstat<>0
    RESULT=2
Elsif [F:AEL]ELTINV="I"
    RESULT=1
Endif
If USAGE=1 and RESULT<>0
  Local Integer OK
  Call VALID(SCREEN,APPLI,1,GLANGUE,0,OK) From VALMSK
Endif
End


# ---------------------------------------------------------------------------

Subprog ISOBJINV(APPLI,OBJET,RESULT,USAGE)
#
#  Vérifie si l'objet OBJET est généré ou non
#  Si il est généré RESULT=0 si non généré RESULT=2
#  Si USAGE=0   on rend RESULT
#          =1   on lance la validation de l'objet

Value Char APPLI                       : # Nom du dossier
Value Char OBJET()                     : # Nom de l'objet
Variable Integer RESULT                : # Résultat
Value Integer USAGE                    : # Type d'utilisation

Raz RESULT
#Local Char WE_NOMF(200)
#Call NAMEFIC(APPLI,"OBJT","",OBJET,WE_NOMF) From INTRUTILA
#If filinfo(WE_NOMF,7)<=0
#  RESULT=2
#Endif

If clalev([F:AEL])=0  : Local File =APPLI+".AELT"  [AEL]  : Endif
Read [AEL]ELT0="OBJT";OBJET;"ALL"
If fstat<>0 : RESULT=2 : Endif

If USAGE=1 and RESULT<>0
  Local Integer OK
  Call VALID(OBJET,APPLI,1,OK) From VALOBJ
Endif
End


# ---------------------------------------------------------------------------

Subprog SUPSCRN(APPLI,MASQUE)
Value Char APPLI,MASQUE
Local Char NAMEFIC(200)
Local Integer ERR,LOCTR

If clalev([F:AEL])=0  : Local File =APPLI+".AELT"  [AEL]  : Endif
If clalev([F:AEK])=0  : Local File =APPLI+".AELTLINK"  [AEK]  : Endif

Call GLOBWEB(APPLI) From INTRUTILA

#  Supprime l'enreg screen et ses liens de AELT et AELTLINK
If adxlog=0 : LOCTR=1 : Trbegin [AEL],[AEK] : Endif
Gosub WI_SUPSCRN
If LOCTR=1 : Commit : Endif

#  Supprime le fichier SCRN
Call NAMEFIC(APPLI,"SCRN","",MASQUE,NAMEFIC) From INTRUTILA
Call EFFACE(NAMEFIC,ERR) From ORDSYS
End
# ---------------------------------------------------------------------------

Subprog SUPWIND(APPLI,FENETRE)
Value Char APPLI,FENETRE
Local Integer I,ERR,LOCTR
Local Char NAMEFIC(200)

If clalev([F:AEL])=0  : Local File =APPLI+".AELT"  [AEL]  : Endif
If clalev([F:AEK])=0  : Local File =APPLI+".AELTLINK"  [AEK]  : Endif

Call GLOBWEB(APPLI) From INTRUTILA

#  Supprime l'enreg window et ses liens de AELT et AELTLINK
If adxlog=0 : LOCTR=1 : Trbegin [AEL],[AEK] : Endif
Gosub WI_SUPWIND
If LOCTR=1 : Commit : Endif

#  Supprime les fichiers WIND  + WINA, FENX, FENW, FENT et FENS dans toutes les langues
Call NAMEFIC(APPLI,"WIND","",FENETRE,NAMEFIC) From INTRUTILA
Call EFFACE(NAMEFIC,ERR) From ORDSYS

Call GLOBWEB(APPLI) From INTRUTILA
For I=1 To GI_NBLAN
  Call NAMEFIC(APPLI,"FENX",GI_LLAN(I),FENETRE,NAMEFIC) From INTRUTILA
    Call EFFACE(NAMEFIC,ERR) From ORDSYS
  Call NAMEFIC(APPLI,"FENW",GI_LLAN(I),FENETRE,NAMEFIC) From INTRUTILA
    Call EFFACE(NAMEFIC,ERR) From ORDSYS
  Call NAMEFIC(APPLI,"WINA",GI_LLAN(I),FENETRE,NAMEFIC) From INTRUTILA
    Call EFFACE(NAMEFIC,ERR) From ORDSYS
  Call NAMEFIC(APPLI,"HTML",GI_LLAN(I),FENETRE,NAMEFIC) From INTRUTILA
    Call EFFACE(NAMEFIC,ERR) From ORDSYS
  Call NAMEFIC(APPLI,"FENT",GI_LLAN(I),FENETRE,NAMEFIC) From INTRUTILA
    Call EFFACE(NAMEFIC,ERR) From ORDSYS
  Call NAMEFIC(APPLI,"FENS",GI_LLAN(I),FENETRE,NAMEFIC) From INTRUTILA
    Call EFFACE(NAMEFIC,ERR) From ORDSYS
Next I


End
# ---------------------------------------------------------------------------

Subprog SUPOBJT(APPLI,OBJET)
Value Char APPLI,OBJET
Local Integer ERR,LOCTR
Local Char NAMEFIC(200)

If clalev([F:AEL])=0  : Local File =APPLI+".AELT"  [AEL]  : Endif
If clalev([F:AEK])=0  : Local File =APPLI+".AELTLINK"  [AEK]  : Endif

Call GLOBWEB(APPLI) From INTRUTILA

#  Supprime l'enreg objet et ses liens de AELT et AELTLINK
If adxlog=0 : LOCTR=1 : Trbegin [AEL],[AEK] : Endif
Gosub WI_SUPOBJT
If LOCTR=1 : Commit : Endif

#  Supprime le fichier OBJT
Call NAMEFIC(APPLI,"OBJT","",OBJET,NAMEFIC) From INTRUTILA
Call EFFACE(NAMEFIC,ERR) From ORDSYS


End
# ---------------------------------------------------------------------------

Subprog SUPMENL(APPLI,MCOU)
Value Char APPLI
Value Integer MCOU
Local Integer I,ERR,LOCTR
Local Char NAMEFIC(200)

If clalev([F:AEL])=0  : Local File =APPLI+".AELT"  [AEL]  : Endif

Call GLOBWEB(APPLI) From INTRUTILA

#  Supprime l'enreg menu de AELT
If adxlog=0 : LOCTR=1 : Trbegin [AEL] : Endif
Gosub WI_SUPMENL
If LOCTR=1 : Commit : Endif

#  Supprime le fichier correspondant dans toutes les langues
For I=1 To GI_NBLAN
  Call NAMEFIC(APPLI,"MENL",GI_LLAN(I),"M"+format$("N0:"+func GENMENULOC.FMTMNL(MCOU),MCOU),NAMEFIC) From INTRUTILA
  Call EFFACE(NAMEFIC,ERR) From ORDSYS
Next I
End
# ---------------------------------------------------------------------------

Subprog SUPPROF(APPLI,PROF)
Value Char APPLI,PROF
Local Integer ERR,LOCTR,I
Local Char NAMEFIC(200)

If clalev([F:AEL])=0  : Local File =APPLI+".AELT"  [AEL]  : Endif


#  Supprime l'enreg profil de AELT
If adxlog=0 : LOCTR=1 : Trbegin [AEL] : Endif
Gosub WI_SUPPROF
If LOCTR=1 : Commit : Endif

Call GLOBWEB(APPLI) From INTRUTILA

#  Supprime les fichiers PROF et PRF
For I=1 To GI_NBLAN
  Call NAMEFIC(APPLI,"PRF",GI_LLAN(I),PROF,NAMEFIC) From INTRUTILA
    Call EFFACE(NAMEFIC,ERR) From ORDSYS
  Call NAMEFIC(APPLI,"PROF",GI_LLAN(I),PROF,NAMEFIC) From INTRUTILA
    Call EFFACE(NAMEFIC,ERR) From ORDSYS

# Supprime tous les fichiers PROFIL-*
  NAMEFIC=left$(NAMEFIC,len(NAMEFIC)-4)+"-*"
  Call EFFACE(NAMEFIC,ERR) From ORDSYS
Next I
End

# ---------------------------------------------------------------------------

Subprog ISWINVALID(APPLI1,LANG,FENETRE1,TYPCLI,WSTAMP,RESULT,USAGE)
Value Char APPLI1,FENETRE1,LANG
Value Integer TYPCLI,USAGE
Variable Char WSTAMP()
Variable Integer RESULT
#   Vérifie si la fenetre FENETRE est valide dans la langue LANG pour le type de client TYPCLI
#   TYPCLI                = 0 à déterminer par le pg
#                         = 1 C/S (type FENX)
#                         = 2 Client Web (type FENW)
#   Si USAGE=0   on rend RESULT  =0 si OK
#                                =1 si invalide (on assemble à la volée si demandé)
#                                =2 si non générée (il faut alors la générer complètement)
#           =1   on lance en plus la validation de la fenêtre

Local Char TYP,APPLI,WSTAMP1(14),FENETRE(20)
Local Integer MAJLOC
#  Pour traiter les dossiers historisés
WSTAMP1=WSTAMP
APPLI=APPLI1
FENETRE=FENETRE1
If FENETRE="AASELECT"  : FENETRE="_SELBOX"  : Endif
If FENETRE="AACHOOSE"  : FENETRE="_CHOOSE"  : Endif
If FENETRE="AAFORMULA" : FENETRE="_FORMULA" : Endif

If GHISTO : APPLI=adxmother(0) : Endif


RESULT=0
TYP="FENX"
If TYPCLI=2
  TYP="FENW"
Endif
If TYPCLI=0 and (GBROWS<>0 or GFUSION=1) : TYP="FENW" : Endif

If clalev([F:AEL])=0  : Local File =APPLI+".AELT"  [AEL]  : Endif
Read [AEL]ELT0=TYP;FENETRE;LANG
If fstat<>0
  RESULT=2
Elsif [F:AEL]ELTINV="I"
  RESULT=1
Endif

WSTAMP=[F:AEL]ELTSTP
If USAGE=1 and (RESULT=1 or (RESULT=0 and WSTAMP1<>"" and WSTAMP<>WSTAMP1))
  Local Char WK_LAN,WK_SEP
  Case GOS(1)
    When "dos"   : WK_SEP="\"
    When Default : WK_SEP="/"
  Endcase
  WK_LAN=LANG
  Call ENVVAR(WSTAMP) From INTRUTILA
  Gosub MSTAMPWIND
  If TYP="FENW"
    Gosub ISFENVT
    If(not(func JSONONLYPARAM(APPLI)))
     Gosub WE_GENFENW  From VALWINWEB
    Endif
    Gosub ASSJSON From VALWINJSON
  Endif
  If TYP="FENX" : Gosub WE_GENFENCS From VALWINWEB : Endif
  If adxlog=0 : Trbegin [AEL] : MAJLOC=1 : Endif
  Readlock [AEL]ELT0=TYP;FENETRE;LANG
  [F:AEL]ELTINV=""
  [F:AEL]ELTSTP=WSTAMP
  Rewrite [AEL]
  If MAJLOC=1 : Commit : Endif
Endif
End

$ISFENVT
  If clalev([F:AWI])=0  : Local File =APPLI+".AWINDOW"  [AWI]  : Endif
  Read [AWI]AWI0=FENETRE
  If fstat=0
    Local Integer ISFENGVT
    ISFENGVT=[F:AWI]FVT
  Endif
Return

$MSTAMPWIND

Local Char WE_NOMFIC(200),WE_VALL1(200)
Local Char FENMEN(200)(1..500)
Local Integer IFENMEN,AA,TOKENLEN
Local Char TYPFEN(5)
Local Char TIMESTAMPTOKEN(20)

#SAVIFS = adxifs
#SAVIRS = adxirs
#SAVIUM = adxium
#adxifs = ""
#adxirs = chr$(10)
#adxium = GUTF8
TYPFEN="WIND"
TIMESTAMPTOKEN="TIM="
TOKENLEN=4
If(func JSONONLYPARAM(APPLI))
  TYPFEN="WINDJ"
  TIMESTAMPTOKEN='"$generationDate": '
  TOKENLEN=19
Endif
Call NAMEFIC(APPLI,TYPFEN,"",FENETRE,WE_NOMFIC) From INTRUTILA
Openi WE_NOMFIC Using [HTI_]
Iomode adxifs "" Using [HTI_]
Iomode adxirs chr$(10) Using [HTI_]
Iomode adxium GUTF8 Using [HTI_]

Rdseq WE_VALL1 Using [HTI_]
IFENMEN+=1 : FENMEN(IFENMEN)=WE_VALL1
Rdseq WE_VALL1 Using [HTI_]
AA=instr(1,WE_VALL1,TIMESTAMPTOKEN)
#AA=instr(1,WE_VALL1,"TIM=")
If AA<>0
   WE_VALL1=left$(WE_VALL1,AA-1)+TIMESTAMPTOKEN+'"'+WSTAMP+right$(WE_VALL1,AA+14+TOKENLEN+1)
    #WE_VALL1=left$(WE_VALL1,AA-1)+'TIM="'+WSTAMP+right$(WE_VALL1,AA+19)
Endif
IFENMEN+=1 : FENMEN(IFENMEN)=WE_VALL1
While fstat=0
  Rdseq WE_VALL1 Using [HTI_]
  If fstat=0 : IFENMEN+=1 : FENMEN(IFENMEN)=WE_VALL1 : Endif
Wend
Openi Using [HTI_]

Openo WE_NOMFIC,0 Using [HTO_]
Iomode adxifs "" Using [HTO_]
Iomode adxirs chr$(10) Using [HTO_]
Iomode adxium GUTF8 Using [HTO_]
For AA=1 To IFENMEN
  Wrseq FENMEN(AA) Using [HTO_]
Next AA

Openo Using [HTO_]
#adxifs = SAVIFS
#adxirs = SAVIRS
#adxium = SAVIUM
Return

# --------------------------------------------------------------------

Subprog ISMENGEN(APPLI,SCREEN,RESULT,USAGE,WE_HORDAT)
#
#  Vérifie si les menus locaux de l'écran SCREEN sont générés dans les langues du dossier
#  Si OK RESULT=0 sinon RESULT=1
#  Si USAGE=0   on rend RESULT
#          =1   on invalide les langues absentes et on envoie un message (annulé)
#          =1   on génère un menu vide

Value Char APPLI                       : # Nom du dossier
Value Char SCREEN()                    : # Nom de l'écran
Variable Integer RESULT                : # Résultat
Value Integer USAGE                    : # Type d'utilisation
Value Char WE_HORDAT()                 : # Horodatage de génération

Local Char WE_NOMF(200),SEP,TMEN(8),LANGUE
Local Integer I

Raz RESULT

If clalev([F:AEK])=0  : Local File =APPLI+".AELTLINK"  [AEK]  : Endif

Filter [AEK] Where ELT=SCREEN and ELTTYP="SCRN" and ELTTYPLK="MENL"
For [AEK]
  TMEN=[F:AEK]ELTLK
  Gosub VERIFMEN
Next
Filter [AEK]


End


Subprog ISMENOBJGEN(APPLI,OBJET,RESULT,USAGE,WE_HORDAT)
#
#  Vérifie si les menus locaux de l'objet OBJET sont générés dans les langues du dossier
#  Si OK RESULT=0 sinon RESULT=1
#  Si USAGE=0   on rend RESULT
#          =1   on invalide les langues absentes et on envoie un message (annulé)
#          =1   on génère un menu vide

Value Char APPLI                       : # Nom du dossier
Value Char OBJET()                     : # Nom de l'objet
Variable Integer RESULT                : # Résultat
Value Integer USAGE                    : # Type d'utilisation
Value Char WE_HORDAT()                 : # Horodatage de génération

Local Char WE_NOMF(200),SEP,TMEN(8),LANGUE
Local Integer I

Raz RESULT

If clalev([F:AEK])=0  : Local File =APPLI+".AELTLINK"  [AEK]  : Endif

Filter [AEK] Where ELT=OBJET and ELTTYP="OBJT" and ELTTYPLK="MENL"
For [AEK]
  TMEN=[F:AEK]ELTLK
  Gosub VERIFMEN
Next
Filter [AEK]


End



$VERIFMEN:
Local Integer MCOU,ILANC
For ILANC=1 To GI_NBLAN
  LANGUE=GI_LLAN(ILANC)
  Call NAMEFIC(APPLI,"MENL",LANGUE,TMEN,WE_NOMF) From INTRUTILA
  If filinfo(WE_NOMF,7)<=0
#    RESULT=1
    If USAGE=1
       MCOU=val(right$(TMEN,2))
#      Call ECR_TRACE(mess(98,123,1)-":"-num$(MCOU)-LANGUE,1) From GESECRAN
#      GI_VLAN(ILANC)=1
      Call GENONEMENU(APPLI,MCOU,LANGUE) From GENMENULOC
    Endif
  Endif
Next ILANC
Return



# ---------------------------------------------------------------------------

Subprog VALIDALLWIN(APPLI1,TYP,INV,NIVTRA) #no usage found !
Value Char APPLI1,TYP
Value Integer INV,NIVTRA

#   Réassemble les fenêtres du dossier selon les critères suivants
#   TYP    :  FENX -> Uniquement en mode C/S    FENW -> Uniquement en mode Web   "" -> les 2
#   INV    :  1 : Réassemble les seules fenêtres invalides (ELTINV="I")
#   NIVTRA :  0 on ne trace pas   1 on trace     2 1+on ouvre et lit la trace

Local Char APPLI,WSTAMP(14),FILTRE(100)
Local Char WK_LAN(50),WK_SEP,FENETRE
Local Char LISTWIN(20)(1..8000)
Local Integer MAJLOC,I,HIST,NBWIN,NBASS

If NIVTRA=2 : Call OUVRE_TRACE(" ") From LECFIC : Endif


#  Pour traiter les dossiers historisés
APPLI=APPLI1
Local File =APPLI+".AELT"  [AEL]
Local File =APPLI+".AELT"  [AEL1]
Local File =APPLI+".AWINDOW"  [AWI]
If adxlog=0 : Trbegin [AEL1] : MAJLOC=1 : Endif

Call GLOBWEB(APPLI) From INTRUTILA
WK_LAN=GI_LLAN(1)
For I=2 To GI_NBLAN
  WK_LAN-=GI_LLAN(I)
Next I

Call ENVVAR(WSTAMP) From INTRUTILA
Case GOS(1)
  When "dos"   :  WK_SEP="\"
  When Default :  WK_SEP="/"
Endcase

If TYP="FENW" or TYP="FENX"
  FILTRE='ELTTYP="'+TYP+'"'
Else
  FILTRE='(ELTTYP="FENW" or ELTTYP="FENX")'
Endif
If INV=1
  FILTRE-=' and ELTINV="I"'
Endif

Filter [AEL] Where evalue(FILTRE)
For [AEL]
  If !find([F:AEL]ELT,LISTWIN(1..NBWIN))
    NBWIN+=1
    LISTWIN(NBWIN)=[F:AEL]ELT
    FENETRE=[F:AEL]ELT
    Read [AWI]AWI0=FENETRE
    If fstat=0
      If NIVTRA>0 : Call ECR_TRACE(mess(140,150,1)-":"-FENETRE,0) From GESECRAN : Endif
      NBASS+=1
      Gosub MSTAMPWIND
      Gosub WE_GENFENW  From VALWINWEB
      For I=1 To GI_NBLAN
        If TYP="FENX" or TYP="FENW"
          Readlock [AEL1]ELT0=TYP;FENETRE;GI_LLAN(I)
          [F:AEL1]ELTINV=""
          [F:AEL1]ELTSTP=WSTAMP
          Rewrite [AEL1]
        Else
          Readlock [AEL1]ELT0="FENW";FENETRE;GI_LLAN(I)
          [F:AEL1]ELTINV=""
          [F:AEL1]ELTSTP=WSTAMP
          Rewrite [AEL1]
          Readlock [AEL1]ELT0="FENX";FENETRE;GI_LLAN(I)
          [F:AEL1]ELTINV=""
          [F:AEL1]ELTSTP=WSTAMP
          Rewrite [AEL1]
        Endif
      Next I
    Endif
  Endif
Next

Filter [AEL]
If MAJLOC=1 : Commit : Endif
If NIVTRA>0 : Call ECR_TRACE(mess(139,150,1)-":"-num$(NBASS),0) From GESECRAN : Endif

If NIVTRA=2
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif


End

# ----------------------------------------------------------------------------------------

Subprog SYNCHROFEN(APPLI,NIVTRA,GEN)
Value Char APPLI
Value Integer NIVTRA,GEN

#     - Vérification des timestamp des fenêtres
#     - Suppression des fenêtres modèles ou inactives des répertoires de publication
#       et des fichiers de liens (AELT et AELTLINK)
#
#     NIVTRA : Niveau de trace
#            0 . on ne trace pas
#            1 . on écrit dans la trace sans l'ouvrir et la fermer
#            2 . on trace et on ouvre la trace en fin de traitement
#     GEN    0 . rien
#            1 . on valide les fenêtres déphasées

Local Char    LANG(GLONLAN)
Local Char    STAMPWIND,STAMPFENX,STAMPFENW,STAMPELW,STAMPELX
Local Char    WE_NOMFIC(200),WE_VALL1(200)
Local Integer NBWIN,NBOK,NBERW,NBERX,NBSUPF,NBFEN,NBVAL
Local Integer AA,BB,MOK,L

Local File =APPLI+".AELT"     [AEL]
Local File =APPLI+".AELT"     [AEL1]
Local File =APPLI+".AWINDOW"  [AWI]
Local File =APPLI+".ACTIV"    [ACV]

L = type([F:AEL]ELT)-10
Local Char LISTFEN(L)(1..8000) , FENETRE(L)

Call GLOBWEB(APPLI) From INTRUTILA
If find(GLANGUE,GI_LLAN(1..GI_NBLAN))
  LANG=GLANGUE
Else

Endif
If NIVTRA=2 : Call OUVRE_TRACE(mess(129,150,1)) From LECFIC : Endif

Filter [AEL] Where (ELTTYP="FENW" or ELTTYP="FENX") and ELTLAN=LANG
For [AEL]
  FENETRE=[F:AEL]ELT
  If find(FENETRE,LISTFEN(1..NBFEN)) : Goto SUITFEN : Endif
  NBWIN+=1
  NBFEN+=1
  LISTFEN(NBFEN)=FENETRE
  STAMPELX=[F:AEL]ELTSTP
  If left$(FENETRE,1)<>"_"
    Read [AWI]AWI0=FENETRE
    If fstat<>0   : # Fenêtre inexistante
      If NIVTRA>0 : Call ECR_TRACE(mess(19,150,1)-":"-FENETRE,0) From GESECRAN : Endif
      Call SUPWIND(APPLI,FENETRE) From INTRUTILB
      NBSUPF+=1
      Goto SUITFEN
    Endif
    If [F:AWI]MDL=2 : # Fenêtre modèle
      If NIVTRA>0 : Call ECR_TRACE(mess(130,150,1)-":"-FENETRE,0) From GESECRAN : Endif
      Call SUPWIND(APPLI,FENETRE) From INTRUTILB
      NBSUPF+=1
      Goto SUITFEN
    Endif
    If [F:AWI]CODACT<>""  : # Fenêtre inactive
      Read [ACV]CODACT = [F:AWI]CODACT
      If fstat<>0 or [F:ACV]FLACT<>2
        If NIVTRA>0
          Call ECR_TRACE(mess(131,150,1)-":"-FENETRE-"   "+mess(14,115,1)-':'-[F:AWI]CODACT,0) From GESECRAN
        Endif
        Call SUPWIND(APPLI,FENETRE) From INTRUTILB
        NBSUPF+=1
        Goto SUITFEN
      Endif
    Endif
  Endif
  If NIVTRA=0 : Goto SUITFEN : Endif
  Read [AEL1]ELT0="FENW";FENETRE;LANG
  STAMPELW=[F:AEL1]ELTSTP
  Gosub MSTAMP
  If STAMPFENX<>STAMPELX
    WE_VALL1="C/S"-FENETRE-"AELT:"+STAMPELX-"FENX:"+STAMPFENX-"WIND:"+STAMPWIND
    Call ECR_TRACE(WE_VALL1,0) From GESECRAN
    NBERX+=1
  Endif
  If STAMPFENW<>STAMPELW
    WE_VALL1="Web"-FENETRE-"AELT:"+STAMPELW-"FENW:"+STAMPFENW-"WIND:"+STAMPWIND
    Call ECR_TRACE(WE_VALL1,0) From GESECRAN
    NBERW+=1
  Endif
  If STAMPFENX=STAMPELX and STAMPFENW=STAMPELW
    NBOK+=1
  Else
    If GEN=1
      NBVAL+=1
      Call VALID(LISTFEN(AA),APPLI,1,MOK) From VALWIN
    Endif
  Endif
 $SUITFEN:
Next
Filter [AEL]


If NIVTRA>0
  Call ECR_TRACE("  ",0) From GESECRAN
  Call ECR_TRACE(mess(69,150,1)-":"-num$(NBWIN),0) From GESECRAN
  Call ECR_TRACE(mess(69,150,1)-"OK :"-num$(NBOK),0) From GESECRAN
  Call ECR_TRACE(mess(132,150,1)-"C/S :"-num$(NBERX),0) From GESECRAN
  Call ECR_TRACE(mess(132,150,1)-"Web :"-num$(NBERW),0) From GESECRAN
  Call ECR_TRACE(mess(133,150,1)-":"-num$(NBSUPF),0) From GESECRAN
  If GEN=1
    Call ECR_TRACE(mess(134,150,1)-":"-num$(NBVAL),0) From GESECRAN
  Endif
  If NIVTRA=2
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Endif

End


$MSTAMP
Gosub MSTAMP_WIND
Gosub MSTAMP_FENX
Gosub MSTAMP_FENW
Return


$MSTAMP_WIND
Local Char TYPFEN(5)
Local Char TIMESTAMPTOKEN(20)
Local Integer TOKENLEN
TYPFEN="WIND"
TIMESTAMPTOKEN="TIM="
TOKENLEN=4
If(func JSONONLYPARAM(APPLI))
  TYPFEN="WINDJ"
  TIMESTAMPTOKEN='"$generationDate": '
  TOKENLEN=19
Endif
 Call NAMEFIC(APPLI,TYPFEN,"",FENETRE,WE_NOMFIC) From INTRUTILA
 If filinfo(WE_NOMFIC,7)<=0
   STAMPWIND=mess(87,100,1)
   Return
 Endif
 Openi WE_NOMFIC Using [HTI_]
 Iomode adxifs "" Using [HTI_]
 Iomode adxirs chr$(10) Using [HTI_]
 Iomode adxium GUTF8 Using [HTI_]

 Rdseq WE_VALL1 Using [HTI_]
 Rdseq WE_VALL1 Using [HTI_]
  AA=instr(1,WE_VALL1,TIMESTAMPTOKEN)
  BB=instr(AA+TOKENLEN+2,WE_VALL1,'"')
  #AA=instr(1,WE_VALL1,"TIM=")
  #BB=instr(AA+6,WE_VALL1,'"')

 If AA<>0 and BB<>0
   STAMPWIND=mid$(WE_VALL1,AA+TOKENLEN+1,BB-AA-(TOKENLEN+1))
   #STAMPWIND=mid$(WE_VALL1,AA+5,BB-AA-5)
 Endif
 Openi Using [HTI_]
Return


$MSTAMP_FENX
 Call NAMEFIC(APPLI,"FENX",LANG,FENETRE,WE_NOMFIC) From INTRUTILA
 If filinfo(WE_NOMFIC,7)<=0
   STAMPFENX=mess(87,100,1)
   Return
 Endif
 Openi WE_NOMFIC Using [HTI_]
 Iomode adxifs "" Using [HTI_]
 Iomode adxirs chr$(10) Using [HTI_]
 Iomode adxium GUTF8 Using [HTI_]

 Rdseq WE_VALL1 Using [HTI_]
 Rdseq WE_VALL1 Using [HTI_]
 AA=instr(1,WE_VALL1,"TIM=")
 BB=instr(AA+6,WE_VALL1,'"')
 If AA<>0 and BB<>0
   STAMPFENX=mid$(WE_VALL1,AA+5,BB-AA-5)
 Endif
 Openi Using [HTI_]
Return


$MSTAMP_FENW
 Call NAMEFIC(APPLI,"FENW",LANG,FENETRE,WE_NOMFIC) From INTRUTILA
 If filinfo(WE_NOMFIC,7)<=0
   STAMPFENW=mess(87,100,1)
   Return
 Endif
 Openi WE_NOMFIC Using [HTI_]
 Iomode adxifs "" Using [HTI_]
 Iomode adxirs chr$(10) Using [HTI_]
 Iomode adxium GUTF8 Using [HTI_]
 Rdseq WE_VALL1 Using [HTI_]
 Rdseq WE_VALL1 Using [HTI_]
 Rdseq WE_VALL1 Using [HTI_]
 AA=instr(1,WE_VALL1,"TIM=")
 BB=instr(AA+6,WE_VALL1,'"')
 If AA<>0 and BB<>0
   STAMPFENW=mid$(WE_VALL1,AA+5,BB-AA-5)
 Endif
 Openi Using [HTI_]
Return

