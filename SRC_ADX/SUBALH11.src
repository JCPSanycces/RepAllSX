#<AdxTL>@(#)0.0.0.0 $Revision$ Génération JSON requête
# Modifications done in requester:# Now, a file <UUID>.lck, where <UUID> is the request ID, is created during the request execution in order to verify if request is still running

Raz GPILOBJ,GNBMASKOUV
GCONSULT = 0
#GBIDC1 = "ZZERB"
GBIDC1 = "AQCQRY01"
Call VALIDE(GBIDC1,nomap,0,0)
#Call OBJET("ALH",GBIDC1,GBIDC2) From GOBJET
End

#######################################################
## Validation of a list for Syracuse
#######################################################
Subprog VALIDE(LISTE,APPLI,DEBUG,SILENCE)
Value Char    LISTE
Value Char    APPLI
Value Integer DEBUG
Value Integer SILENCE

Gosub VARIABLES

  If clalev([F:AMP])  : LogicClose File [AMP]  : Endif : Local File =APPLI+".AMSKPAR"  [AMP]

  If clalev([F:ALD2]) : LogicClose File [ALD2] : Endif : Local File =APPLI+".ALISTED"  [ALD2]
  If clalev([F:ALH])  : LogicClose File [ALH]  : Endif : Local File =APPLI+".ALISTEH"  [ALH]
  If clalev([F:ALD])  : LogicClose File [ALD]  : Endif : Local File =APPLI+".ALISTED"  [ALD]
  If clalev([F:ALR])  : LogicClose File [ALR]  : Endif : Local File =APPLI+".ALISTER"  [ALR]
  If dim([F:ALH]TYPENV)>0 & filinfo(filpath("FIL","ALISTENV","fde",APPLI),0)>0
    If clalev([F:ALV]): LogicClose File [ALV]  : Endif : Local File =APPLI+".ALISTENV" [ALV]
  Endif
  If clalev([F:ATY])  : LogicClose File [ATY]  : Endif : Local File =APPLI+".ATYPE"    [ATY]
  If clalev([F:ATY2]) : LogicClose File [ATY2] : Endif : Local File =APPLI+".ATYPE"    [ATY2]
  If clalev([F:ACC])  : LogicClose File [ACC]  : Endif : Local File =APPLI+".ACCES"    [ACC]
  If clalev([F:ATX])  : LogicClose File [ATX]  : Endif : Local File =APPLI+".ATEXTE"   [ATX]
  If clalev([F:ACV])  : LogicClose File [ACV]  : Endif : Local File =APPLI+".ACTIV"    [ACV]
  If clalev([F:AOB])  : LogicClose File [AOB]  : Endif : Local File =APPLI+".AOBJET"   [AOB]
# Added  March 18, 2014 For generating links on fields that don't have a data type associated to a table
  If clalev([F:ATZ])  : LogicClose File [ATZ]  : Endif : Local File =APPLI+".ATABZON"  [ATZ]
  If clalev([F:ATB])  : LogicClose File [ATB]  : Endif : Local File =APPLI+".ATABLE"   [ATB]
  If clalev([F:ACLA]) : LogicClose File [ACLA] : Endif : Local File =APPLI+".ACLASSE"  [ACLA]
  If clalev([F:AFC])  : LogicClose File [AFC]  : Endif : Local File =APPLI+".AFONCTION" [AFC]
# Addition End of January 2014 (security filters)
  If clalev([F:AFC])  : LogicClose File [AFC]  : Endif : Local File =APPLI+".AFONCTION"   [AFC]

  If filinfo(filpath("FIL","AVIEWTAB","fde",APPLI),0)<0
& or filinfo(filpath("FIL","AVIEWFLD","fde",APPLI),0)<0
& or filinfo(filpath("FIL","AVIEWIND","fde",APPLI),0)<0
    If clalev([F:AVWT]) : LogicClose File [AVWT] : Endif : Local File =APPLI+".ATABLE"  [AVWT]
    If clalev([F:AVWF]) : LogicClose File [AVWF] : Endif : Local File =APPLI+".ATABZON" [AVWF]
    If clalev([F:AVWI]) : LogicClose File [AVWI] : Endif : Local File =APPLI+".ATABIND" [AVWI]
  Else
    If clalev([F:AVWT]) : LogicClose File [AVWT] : Endif : Local File =APPLI+".AVIEWTAB" [AVWT]
    If clalev([F:AVWF]) : LogicClose File [AVWF] : Endif : Local File =APPLI+".AVIEWFLD" [AVWF]
    If clalev([F:AVWI]) : LogicClose File [AVWI] : Endif : Local File =APPLI+".AVIEWIND" [AVWI]
  Endif

  OK = 1
  INTRQT = mess(277,139,1)-LISTE : # Requête standard

  Read [ALH]ALH0 = LISTE
  If fstat
    OK = 0 : Call ECR_TRACE(INTRQT-":"-mess(23,100,1),1) From GESECRAN : # Fiche inexistante
    Goto FIN
  Endif
  Gosub LIENS
  Gosub FIELDS
  If !OK
#   Gosub DESACTIVE
    Goto FIN
  Endif

# Debug
  If DEBUG
    Call OUVRE_TRACE("") From LECFIC
    Call ECR_TRACE(TBFIC(F),0) From GESECRAN
    For I=1 To NBFIC2
      If I<>F
        If LORG(I)<>0
          Call ECR_TRACE(TBFIC(I)-"<="-TBFIC(LORG(I))-LZON(I),0) From GESECRAN
        Else
          Call ECR_TRACE(TBFIC(I)-[F:ALH]LNK(LIND(I)),0) From GESECRAN
        Endif
      Endif
    Next I
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif


  Gosub SYRA_TRT
  If !OK : Goto FIN : Endif

  $FIN
  If !OK
    GERR = 1
  Endif
  End

$VARIABLES
Local Char     LAN(GLONLAN)(1..10)
Local Integer  I , J , K , F , L , OK , DIME , STAT, NBFORMFUNC, NOCOM, I0
Local Integer  II , JJ , KK
Local Shortint MAXFIC, MAXCOL, DIMBEG, MAXLIEN, MAXLNK, MAXLEV
MAXFIC = 80
MAXLIEN = 30
MAXCOL  = 250 : # Dom June 10, 2017
MAXLNK  = 12   : # Nombre de liens maxi sur un link
MAXLEV  = 20   : # Maximum number of breaking level
Local Integer  NBFIC , NBFIC2 , NBLAN , PASSE , OKL , OKLIEN , NBFIC3
# NB_LINK added end of January 2014 (security filters)
Local Integer NB_LINK

Local Integer  P , OKFLD , ERFLD
Local Schar    TBFIC(GLONATB)(1..MAXFIC) , ABFIC(GLONABR+2)(1..MAXFIC) , LZON(12)(1..MAXFIC)
# Size changed for TBCHP/CLE End of January
Local Schar    TLIEN(250) , FLDVCR(20) , FLDLIG(250) , TTYPE(GLONATY) , TBCHP(30)(1..200) , CLE(20)(1..16)
Local Integer  NBLIEN , TBLNK(1..MAXLIEN)
Local Schar    TBFIC3(GLONATB)(1..MAXFIC)
Local Integer  LIEN(1..MAXFIC) , LORG(1..MAXFIC) , LNUM(1..MAXFIC) , LORD(1..MAXFIC)
Local Schar    LCLE(GLONANX)(1..MAXFIC)
Local Integer  LIMP(1..MAXFIC) , LIND(1..MAXFIC) , LIMO(1..MAXFIC,1..40)
Local Char     CHAINE(250), CHAINE1(250), ZONE(80)
Local Char     LNKFIC(GLONABR+2) , DESAX(80), LNKTBL(GLONATB)
Local Char     TRAITE(GLONADC) , FICTRT(GDIMFIC) , MAGIC(80)
Local Char     SAVIFS(5) , SAVIRS(5) , IDENT(20)
Local Char     ABREV(GLONABR+2)
Local Integer  SAVIUM
Local Integer  NBCHP , NBGRP , GROUPE , SPA , NBCLE , LONG , NBCOL , NBLNK
Local Integer  TRI(20) , CUM , NIVEAU
Local Integer  NBTXT , LIGTXT(1..20) , TYPTXT(1..20)
Local Schar    CHTXT(GLONAVA)(1..20) , ABTXT(GLONABR+2)(1..20) , TBTXT(GLONATB)(1..20)
Local Char     AOBSIT(GLONAVA) , AOBACC(GLONAVA) , AOBFIC(GLONAVA), AOBFNC(GLONAFC)
# AOBAOB added end of January 2014 security filters, AOBTUN added March 31, 2014
Local Char     AOBAOB(GLONAOB), AOBTUN(GLONAOB)
Local Integer  FLCLOB
Local Char     CH2(250) , CH3(250) , CH4(250) , WVALPAR(250) , INTRQT(40) , WOBJPAR(GLONAOB)
Local Schar    TBORG(GLONATB)(1..MAXLIEN) , TBDES(GLONATB)(1..MAXLIEN)
Local Schar    ZNORG(20)(1..MAXLIEN) , ZNDES(20)(1..MAXLIEN)
Local Integer  TBRANG(1..MAXCOL)
Local Integer  LIENCOMPO,ERVAL
Local Integer AI, AJ, AK
Local Schar    ESC(5)
Local Schar    FIELDS(20)(1..MAXCOL),FTYPE(30)(1..MAXCOL),FTYPA(8)(1..MAXCOL),FTUN(20)(1..MAXCOL),FTUN1(20)(1..MAXCOL),COMPFORM(250)(1..MAXCOL)
Local Schar    FNCKEY(50)(1..MAXCOL) :#SAM 116052
# Modification done SAM 111929 October 21,2015 to handle special formats (email, phones)
Local Integer    FFIELDS(1..MAXCOL)
Local Decimal  FLEN(1..MAXCOL)
Local Char FFORTYP(50)(1..MAXCOL) :#SAM 109290
Local Libelle  FRANGE(1..MAXCOL), FNIV(1..MAXCOL), FCUM(1..MAXCOL)
Local Integer  FNUMF(1..MAXCOL), FTEX(1..MAXCOL)
Local Integer  NBFIELDS,NBFORMS
Local Integer  CONVONLY
Local Shortint MENL(1..MAXCOL)
Local Integer  NBLEV, NBSRT, NBCUM, SHIFT_IF, BRKLEV(1..MAXLEV)
Local Integer  NBHEAD : NBHEAD=1000
Local Char AFILOPE(255)
Local Char FACET(20)
Local Char     MODLEC(2)
Local Char     INDEX(GLONANX)
Local Char     TEMPCH(100)
Local Char CHL(200)
Local Integer SCALE, PRECISION
Local Char FORM(30)

#{ SAM 116052
Local Char DESCRIPTKEY(30)(1..)
Local Integer DESCRIPTLEN
#SAM 116052 }


# Additional variables for filters added end of January 2014
Local Char LINK_CLAUSE(250)(1..),LINK_SITE(250),LINK_ACCES(250), LINK_ROLES(250)(1..)
Local Integer IF_ACCESS

# Additional variable to give the type of folder (hrm/x3) added Sept 3,2014
Local Char LNK_FOLDTYP(30), FLG_FOLDTYP(10)

  FLG_FOLDTYP=func AFNC.PARAMDOS("","TYPDOS")
  Case FLG_FOLDTYP
    When "0","1" : LNK_FOLDTYP="x3/erp"
    When "3" : LNK_FOLDTYP="x3/hrm"
  Endcase
Return

########################################################
## Link computation
########################################################

$LIENS

## Fill the file array
  Raz TBFIC , NBFIC
  For [ALD]ALD0 Where COD=LISTE
    If !find([F:ALD]TBL,TBFIC(1..NBFIC))
      Read [AVWT]CODFIC = [F:ALD]TBL
      If fstat
        OK = 0 : Call ECR_TRACE(INTRQT-":"-func AFNC.MES(mess(85,133,1),[F:ALD]TBL),-1) From GESECRAN : # Table # inexistante
      Else
        NBFIC += 1
        TBFIC(NBFIC) = [F:ALD]TBL
        ABFIC(NBFIC) = [F:AVWT]ABRFIC
      Endif
    Endif
  Next ALD
  If NBFIC=0
    Call ECR_TRACE(INTRQT-":"-mess(116,141,1),0) From GESECRAN : # Aucune table déclarée
    OK = 0 : Return
  Endif
  If !OK : Return : Endif

## Decode the forced links
  Raz LIMP, LIMO
  For I=0 To dim([F:ALH]LNK)-1
    If [F:ALH]LNK(I)<>""
      CHAINE = vireblc([F:ALH]LNK(I),4)
      J = instr(1,CHAINE,"=")
      If J
        ZONE   = left$(CHAINE,J-1)
        CHAINE = right$(CHAINE,J+1)
        J = instr(1,ZONE,"]")
        If J
          ZONE   = seg$(ZONE,2,J-1)
        Endif
        If left$(ZONE,2)="F:" : ZONE = right$(ZONE,3) : Endif
        K = find(ZONE,ABFIC(1..NBFIC))
        If K
          LIMP(K) = 1
          LIND(K) = I
          While CHAINE<>""
            J = instr(1,CHAINE,";")
            If J
              ZONE   = left$(CHAINE,J-1)
              CHAINE = right$(CHAINE,J+1)
            Else
              ZONE   = CHAINE
              CHAINE = ""
            Endif
            If left$(ZONE,1)="["
              J = instr(1,ZONE,"]")
              If J
                ZONE = seg$(ZONE,2,J-1)
                If left$(ZONE,2)="F:" : ZONE = right$(ZONE,3) : Endif
                J = find(ZONE,ABFIC(1..NBFIC))
                If J
                  LIMO(K,LIMP(K)) = J
                  LIMP(K) += 1
                Endif
              Endif
            Endif
          Wend
        Endif
      Endif
    Endif
  Next I

## Search loop

  F = 0
  PASSE = 0

$LIENS0
  F += 1
  If F>NBFIC
    If PASSE=0
      PASSE = 1 : F = 1
    Else
      OK = 0 : Call ECR_TRACE(INTRQT-":"-mess(7,124,1),0) From GESECRAN : # Links impossible
      Return
    Endif
  Endif

  If LIMP(F) : Goto LIENS0 : Endif

  Raz LIEN, LORG, LZON, LCLE
  LIEN(F) = 1

## Add tables in a second pass

  NBFIC2 = NBFIC
  If PASSE=1
    For [AVWF]CODZONE Where CODFIC=TBFIC(F) & LIEN<>""
      If !find([F:AVWF]LIEN,TBFIC(1..NBFIC2))
        Read [AVWT]CODFIC = [F:AVWF]LIEN
        #98895 If fstat
        #If fstat or K=0
        #118953
        If fstat
          # Link impossible\Table doesn't exist
          OK = 0 : Call ECR_TRACE(INTRQT-"->"-mess(45,105,1)-'"'-[F:AVWF]LIEN-'":'-TBFIC(F),-1) From GESECRAN
        Else
          NBFIC2 += 1
          TBFIC(NBFIC2) = [F:AVWF]LIEN
          LIEN(NBFIC2)  = 1
          LORG(NBFIC2)  = F
          LZON(NBFIC2)  = [F:AVWF]CODZONE
          #118953
          If [F:ALH]TYP=3 & K
           Gosub INDEX
           LCLE(NBFIC2)  = INDEX
          Endif
        Endif
     Endif
   Next FLD
  Endif

## Links computation

$LIENS1
  OKL = 0
  For I=1 To NBFIC2
    If LIMP(I)
      LIEN(I) = 1
    Elsif !LIEN(I)
      For J=1 To NBFIC2
        If LIEN(J)
          For [AVWF]LIEN Where LIEN=TBFIC(I) & CODFIC=TBFIC(J)
            LIEN(I) = 1
            LORG(I) = J
            LZON(I) = [F:AVWF]CODZONE
            OKL = 1
            Break
          Next
        Endif
        If LIEN(I) : Break : Endif
      Next J
    Endif
  Next I

  If sum(LIEN(1..NBFIC))<>NBFIC
    If OKL : Goto LIENS1 : Else : Goto LIENS0 : Endif
  Endif

## Suppress the useless tables

  I = NBFIC+1
  While I<=NBFIC2
    If !find(I,LORG(1..NBFIC))
      Dela I  TBFIC, ABFIC, LIEN, LORG, LZON
      NBFIC2 -= 1
      For J=1 To NBFIC
        If LORG(J)>I : LORG(J) -= 1 : Endif
      Next J
    Else
      I += 1
    Endif
  Wend

## Sort in the right order and renumbering
  For I=1 To NBFIC2
    LNUM(I) = I
  Next I

  Raz LORD
  LORD(F) = 1

  For K=1 To NBFIC2
    For I=1 To NBFIC2
      If LIMP(I)
        If LORD(I)=0
          OKL = 1
          For J=1 To LIMP(I)-1
            If LORD(LIMO(I,J))=0 or LORD(LIMO(I,J))>K : OKL = 0 : Endif
          Next J
        Else
          OKL = 0
        Endif
      Else
        If LORG(I)>0 & LORD(LORG(I))=K
          OKL = 1
        Else
          OKL = 0
        Endif
      Endif
      If OKL : LORD(I) = K+1 : Endif
    Next I
  Next K

  If find(0,LORD(1..NBFIC2))
    Goto LIENS0
  Endif

  Sorta NBFIC2 LORD, TBFIC, ABFIC, LIEN, LORG, LZON, LNUM, LIMP, LIND
  F = 1

  For I=1 To NBFIC2
    K = find(LORG(I),LNUM(1..NBFIC2))
    If K
      LORG(I) = K
    Endif
  Next I
Return

# Fields computation
$FIELDS
  NBFIELDS=0
  NBFORMS=0
  NBCUM=0
  CONVONLY=fmet GACTX.APARAM.AGETUSERVALNUM("ACONVONLY")
  For [ALD] Where COD=LISTE and (STREND<=2 or CLC<>"")
    NBFIELDS+=1
    FNUMF(NBFIELDS)=[ALD]LIG
    FRANGE(NBFIELDS)=([ALD]STREND>=2)
    FNIV(NBFIELDS)=[ALD]NIV
    FTEX(NBFIELDS)=[ALD]NUMTEX
    FTYPA(NBFIELDS)=[ALD]CODTYP
    Read [ATY]CODTYP=[ALD]CODTYP

    # Manage the tunnel in a more sophisticated way
    # The test TUN=2 was replaced by TUN<>1 because TUN is 0 for graphical requests
    FTUN(NBFIELDS)="" : AOBTUN="" : FTUN1(NBFIELDS)=""
    If pat([ATY]CODTYP,"AX*")=0 & [ATY]CODTYP<>"ATX" & [ALD]TUN<>1
      If [ATY]CODTYP="VCR" : # Added March 31,2014
        Read [AMP]CODPAR=2;[ALD]TBL;[ALD]FLD;"VCROBJ"
        If fstat=0
          Read [AOB]ABREV=mid$([AMP]VALPAR,2,len([AMP]VALPAR)-2)
          If fstat=0 : AOBTUN=[AOB]ABREV : Endif
        Endif
        If AOBTUN<>""
          Read [AMP]CODPAR=2;[ALD]TBL;[ALD]FLD;"OBJZON"
          If fstat=0 and [AMP]VALPAR<>""
            J=find([AMP]VALPAR,FIELDS(1..NBFIELDS-1))
            #If J<>0 : FTUN1(NBFIELDS)=[AMP]VALPAR : Else AOBTUN="" : Endif : # Modified April 10,2014 : no tunnel if field not found
            If J<>0 : FTUN1(NBFIELDS)=[AMP]VALPAR  : Endif : # Modified SAM 118916
          Endif
        Endif
      Else
        If [ATY]CODCLA<>"" and CONVONLY<>2
          FTUN(NBFIELDS)=[ATY]CODCLA
        Elsif [ATY]OBJLIEN<>""
          AOBTUN=[ATY]OBJLIEN
        Elsif [ALD]FLD<>"" and [ALD]TBL<>""
          Read [ATZ]CODZONE=[ALD]TBL;[ALD]FLD
          If fstat=0
            If [ATZ]LIEN<>""
              AOBTUN=[ATZ]LIEN
            Endif
          Endif
        Endif
      Endif

      If FTUN(NBFIELDS)="" and AOBTUN<>"" and CONVONLY<>2
      # Search if a suitable class exists (persistent and associated to the right class)
        For [ACLA] Where TYPCLA=2 and TABREF=[ATZ]LIEN
          FTUN(NBFIELDS)=[ACLA]CODCLA
          Break
        Next
      Endif

      # If not found, is there a "classic link" possible?
      If FTUN(NBFIELDS)="" and AOBTUN<>""
        FNCKEY(NBFIELDS)=""
        Read [ATZ]CODZONE=[F:ALD]TBL;[F:ALD]FLD
        If fstat=[V]CST_AOK & [F:ATZ]EXPLIEN<>""
            Call SETCLE(DESCRIPTLEN,DESCRIPTKEY,ctrans([F:ATZ]EXPLIEN,";","+")) From LNKSUB
            Call SETTUNKEY(DESCRIPTKEY, DESCRIPTLEN, FNCKEY(NBFIELDS)) From SUBALH11A
        Endif
        If FNCKEY(NBFIELDS)=""
            Read [AOB]ABREV=AOBTUN
            Read [AVWT]CODFIC=[AOB]NOMFIC
            If fstat=0
              #{ SAM 116052
              For [AVWI]CODIND Where CODFIC=[AVWT]CODFIC
               Call SETCLE(DESCRIPTLEN,DESCRIPTKEY,[F:AVWI]DESCRIPT) From LNKSUB
               # set current field as 1st key element
               # Issue X3-102025 - 2018-10-16 by CCC : If the key is composed of several elements, it's not possible to know which element corresponds to the current field
               If DESCRIPTLEN=1
                    DESCRIPTKEY(1) = [F:ALD]FLD
               Else
                    # As there are several elements in the key, it's not possible to know wich corresponds to the current field
                    # => If fields' names don't correspond to the one in the key, a link descriptor must be added in the definition of the table
               Endif
               Call SETTUNKEY(DESCRIPTKEY, DESCRIPTLEN, FNCKEY(NBFIELDS)) From SUBALH11A
               Break
              Next
              #SAM 116052 }
            Endif
        Endif
        Read [AFC]CODINT="GES"+AOBTUN
        If fstat=0 and [AFC]CODPAR(0)="OBJET" and [AFC]TYP=2 and [AFC]VALPAR(0)='"'+AOBTUN+'"'
          FTUN(NBFIELDS)="~"+[AFC]CODINT
        Endif
      Endif
    Endif

    # Hack for the dictionary texts
    FFORTYP(NBFIELDS) = [ATY]FORTYP:#SAM 109290
    If find([ATY]CODTYP,"ATX")
      FTYPE(NBFIELDS)=func AJSONLIB.TYPZON(7,0)
    Else
      FTYPE(NBFIELDS)=func AJSONLIB.TYPZON([ATY]TYPTYP,[ALD]NOLIB)
    Endif
    FLEN(NBFIELDS)=[ALD]LNG
    If FLEN(NBFIELDS)=0 and [ATY]LNGTYP<>0 : FLEN(NBFIELDS)=[ATY]LNGTYP : Endif

    # Modification done SAM 111929 October 21,2015 to handle special formats (email, phones)
    FFIELDS(NBFIELDS)=[ATY]FMTPROSYR

    MENL(NBFIELDS)=[ALD]NOLIB
    If [ALD]CLC<>""
      NBFORMS+=1
      FIELDS(NBFIELDS)="FORMULA_"+num$(NBFORMS)
      COMPFORM(NBFIELDS)=[ALD]CLC
    Else
      J=0
      I=find([ALD]FLD,FIELDS(1..NBFIELDS-1))
      If I
        Repeat
          J+=1
          K=find([ALD]FLD,FIELDS(I+1..NBFIELDS-1))
          I+=K
        Until K=0
      Endif
      FIELDS(NBFIELDS)=[ALD]FLD+string$(J>0,"_"+num$(J))
      If [F:ALD]CODTYP="ATX"
        COMPFORM(NBFIELDS)="[F:AX"+num$([F:ALD]LIG+10)+"]TEXTE"
      Elsif find([F:ALD]CODTYP,"AXX","AX1","AX2","AX3")
        COMPFORM(NBFIELDS)="[F:AY"+num$([F:ALD]LIG+10)+"]TEXTE"
      Else
        K = find([F:ALD]TBL,TBFIC(1..NBFIC2))
        COMPFORM(NBFIELDS) = "[F:"+string$(K>0,ABFIC(K+(K=0)))+"]"+[F:ALD]FLD
      Endif
    Endif
    If [ALD]CUM=2
      NBCUM+=1
      FCUM(NBFIELDS)=NBCUM
    Endif
  Next
Return

# Search index in a destination table

$INDEX
INDEX = ""
For [AVWI] Where CODFIC=TBDES(K)
 CHAINE = [F:AVWI]DESCRIPT
 Gosub SETCLE
 N = 0
 For L=1 To NBLIEN
  If TBDES(L)=TBDES(K)
   For M=1 To NBCLE
    If ZNDES(L)=CLE(M)
     N += 1 : Break
    Endif
   Next M
  Endif
 Next L
 If N=NBCLE
  INDEX = [F:AVWI]CODIND
  Break
 Endif
Next AVWI
If INDEX=""
 # On essaye de prendre le premier qui correspond
 For [AVWI] Where CODFIC=TBDES(K)
  CHAINE = [F:AVWI]DESCRIPT
  Gosub SETCLE
  N = 0
  For L=1 To NBLIEN
   If TBDES(L)=TBDES(K)
    For M=1 To NBCLE
     If ZNDES(L)=CLE(M)
      N += 1 : Break
     Endif
    Next M
   Endif
  Next L
  If N
   INDEX = [F:AVWI]CODIND
   Break
  Endif
 Next AVWI
 If INDEX=""
  # Table x\Lien inexistant
  Call ECR_TRACE(INTRQT-"->"-mess(56,123,1)-TBDES(K)+"\"+mess(253,139,1),1) From GESECRAN
 Else
  # Table x\Lien incorrect
  Call ECR_TRACE(INTRQT-"->"-mess(56,123,1)-TBDES(K)+"\"+INDEX-":"-mess(162,115,1),1) From GESECRAN
 Endif
 OK = 0
Endif
Return

#---------------------------------#
$SETCLE
Local Integer NBCLE , AI, AJ
Local Char    CLE(20)(1..16)
Raz CLE, NBCLE
While CHAINE<>""
 AI = instr(1,CHAINE,"+")
 AJ = instr(1,CHAINE,"-")
 If AI & AJ
  AI = min(AI,AJ)
 Elsif AJ & !AI
  AI = AJ
 Endif
 NBCLE += 1
 If AI
  CLE(NBCLE) = left$(CHAINE,AI-1)
  CHAINE = right$(CHAINE,AI+1)
 Else
  CLE(NBCLE) = CHAINE
  CHAINE = ""
 Endif
Wend
Return

########################################################
## Program generation
########################################################

$SYRA_TRT
Local Char    FILE_TO_DELETE(GDIMFIC)
Local Integer ERROR

Gosub VERIF_ALD
Gosub DECL_GEN From AJSONLIB
If APPLI="" : APPLI=nomap : Endif

Call MACHINE(APPLI,MACHINE,APPLI) From ORDSYS

#First delete the 'old' script
NOMTRT=func PREFIX_TRT_OLD+LISTE
FILE_TO_DELETE= filpath("TRT",NOMTRT ,"src",APPLI,"",MACHINE)
Call _EFFACE(FILE_TO_DELETE,ERROR) From ASYRSYS

#1 script for managing data
NOMTRT=func PREFIX_TRT_DATA+LISTE
Gosub TRT_DEB
Gosub CORPS_DATA From SUBALH11B
Gosub TRT_FIN

#1 script for managing the prototype
NOMTRT=func PREFIX_TRT_PROTO+LISTE
Gosub TRT_DEB
Gosub CORPS_PROTO From SUBALH11B
Gosub TRT_FIN

If !SILENCE
 Call TEMPOFF From GESECRAN
Endif

adxifs = SAVIFS
adxirs = SAVIRS
adxium = SAVIUM
Return

#-------------------------------------------------------#
$TRT_DEB
  If !SILENCE
   Call TEMPON(mess(159,133,1)-NOMTRT) From GESECRAN : # Validation du traitement
  Endif

  If GTRACE<>""
   Call ECR_TRACE(INTRQT-"->"-mess(159,133,1)-NOMTRT,0) From GESECRAN
  Endif
  Call LECTEXTRA(DESAX,"ALISTEH","INTIT",[F:ALH]COD,"") From ATEXTRA
  COMMENT="Request"-LISTE-"("+DESAX+")"-format$("D:YYYY[-]MM[-]DD[T]hh[:]mm[:]ss",date$)
  #{SAM 119672 Gosub DEB_GEN From AJSONLIB
  FICTRT = filpath("TRT",NOMTRT,"src",APPLI,"",MACHINE)

  SAVIFS = adxifs
  SAVIRS = adxirs
  SAVIUM = adxium

  adxifs = ""
  adxirs = chr$(10)
  adxium = GUTF8
  MAGIC  = mess(77,133,1) : # Superviseur Adonix

# Program header generation
  APWCB=" Append WCLOB,'"
  Openo FICTRT , 0 Using [SSS_]
  Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$" Using [SSS_]
  Wrseq "#"-MAGIC Using [SSS_]
  Wrseq "#"-COMMENT Using [SSS_]
  Wrseq Using [SSS_]
  #SAM 119672}

Return

#-------------------------------------------------------#
$TRT_FIN
  Wrseq Using [SSS_]
  Openo Using [SSS_]
  Call VALID("TRT",NOMTRT,APPLI,STAT) From VALMSKSUB
Return

#-------------------------------------------------------#
$VERIF_ALD
  NBTXT = 0
  For [ALD]ALD0 Where COD=LISTE & STREND<=2
    Read [AVWT]CODFIC = [F:ALD]TBL
    If !fstat
      Case [ALD]CODTYP
        When "ATX"
          NBTXT += 1
          TBTXT(NBTXT)  = [F:ALD]TBL
          CHTXT(NBTXT)  = [F:ALD]FLD
          LIGTXT(NBTXT) = [F:ALD]LIG
          ABTXT(NBTXT)  = [F:AVWT]ABRFIC
          TYPTXT(NBTXT) = 1
        When "AXX","AX1","AX2","AX3"
          NBTXT += 1
          TBTXT(NBTXT)  = [F:ALD]TBL
          CHTXT(NBTXT)  = [F:ALD]FLD
          LIGTXT(NBTXT) = [F:ALD]LIG
          ABTXT(NBTXT)  = [F:AVWT]ABRFIC
          TYPTXT(NBTXT) = 2
          For GBIDC1="CLECUR1","CLECUR2"
            Read [AMP]CODPAR=2;TBTXT(NBTXT);CHTXT(NBTXT);GBIDC1
            If !fstat & instr(1,[AMP]VALPAR,"+")
              # Issue X3-53628 - 2017-09-20 by CCC
              #If GTRACE<>""
              #  Call ECR_TRACE([F:ALD]TBL-":"-[F:ALD]FLD-"("+[ALD]CODTYP+")"-mess(214,133,1),-1) From GESECRAN
              #Endif
              TYPTXT(NBTXT) = 3 : Break
            Endif
          Next GBIDC1
      Endcase
    Endif
  Next ALD
Return

#-------------------------------------------------------#
# Write the link URL end (go to page J on level LEVEL and tramsmit the parameters)
$WR_URL_LINK
  Wrseq "    Append ASND.DATA,'?representation=QUERY~"+LISTE+"~'+num$(LEVEL)+'."+FACET+"&startRecord='+num$(J)" Using [SSS_]
  Wrseq "    Append ASND.DATA,'&count='+num$(NBLINES)+'&requestID='+"+'"'+"'"+'"+'+"REQUID+"+'"'+"'"+'"' Using [SSS_]
  Wrseq "    Append ASND.DATA,'&displayLineNum='+string$(IFLINE<>0,'true')+string$(IFLINE=0,'false')" Using [SSS_]
  Wrseq "    Append ASND.DATA,'&cube='+string$(IFCUBE<>0,'true')+string$(IFCUBE=0,'false')" Using [SSS_]
  Wrseq "    Append ASND.DATA,'&level='+num$(LEVEL)" Using [SSS_]
  Wrseq "    Append ASND.DATA,'&frequency='+num$(FRQ)" Using [SSS_] :#SAM 114121
  Wrseq "    Append ASND.DATA,'"+'","$type":"application/json;vnd.sage=syracuse"}'+"'" Using [SSS_]
Return

# Modified End of January 2014 security filters multiple modifications
# Bug found (typo : TBFIC(F) remained instead of TBFIC(1)) Dec 2015, Dom
$LINK0
  LINK_CLAUSE(1)='  Link ['+ABFIC(1)+'] With '
  LNKFIC = ABFIC(1): LNKTBL=TBFIC(1)
  NB_LINK=1
Return

# Link generation for classical requester
$LINK1
  LINK_CLAUSE(1)="  Link ["+ABFIC(F)+"] With"
  LNKFIC = ABFIC(F) : LNKTBL=TBFIC(F)
  NB_LINK = 1
  For I=1 To NBFIC2
    If I<>F
      NB_LINK+=1
      #LINK_CLAUSE(NB_LINK)=string$(NB_LINK>2,"& ,    ")+string$(NB_LINK=2,"&      ")
      If LIMP(I)
        LINK_CLAUSE(NB_LINK)+=[F:ALH]LNK(LIND(I))
      Else
        Read [AVWI]NUMLIG(2) = TBFIC(I);1
        LINK_CLAUSE(NB_LINK)+="["+ABFIC(I)+"]"+[F:AVWI]CODIND+" = "
        Read [AVWF]CODZONE = TBFIC(LORG(I));LZON(I)
        If [F:AVWF]EXPLIEN=""
          LINK_CLAUSE(NB_LINK)+="[F:"+ABFIC(LORG(I))+"]"+[F:AVWF]CODZONE
        Else
          CHAINE = vireblc(format$("KT:120X",[F:AVWF]EXPLIEN),2)
          While CHAINE<>""
            K = instr(1,CHAINE,";")
            If K
              ZONE   = left$(CHAINE,K-1)
              CHAINE = right$(CHAINE,K+1)
            Else
              ZONE   = CHAINE
              CHAINE = ""
            Endif
            K = instr(1,ZONE,"indice")
            If K
              ZONE = left$(ZONE,K-1)+"0"+right$(ZONE,K+6)
            Endif
            If left$(ZONE,1)>="A" & left$(ZONE,1)<="Z"
              LINK_CLAUSE(NB_LINK)+="[F:"+ABFIC(LORG(I))+"]"+ZONE
            Else
              LINK_CLAUSE(NB_LINK)+=ZONE
            Endif
            If CHAINE<>"" : LINK_CLAUSE(NB_LINK)+=";" : Endif
          Wend
        Endif
      Endif
    Endif
  Next I

  For I=1 To NBTXT
    If find(TYPTXT(I),1,2)
      NB_LINK+=1
      #LINK_CLAUSE(NB_LINK)=string$(NB_LINK>2,"& ,    ")+string$(NB_LINK=2,"&      ")
    Endif
    Case TYPTXT(I)
      When 1
        LINK_CLAUSE(NB_LINK)+="[AX"+num$(LIGTXT(I)+10)+"]NUMERO = LANGUE;"
        If CHTXT(I)<>""
          LINK_CLAUSE(NB_LINK)+="[F:"+ABTXT(I)+"]"+CHTXT(I)
        Else
          Read [ALD]ALD0 = LISTE;LIGTXT(I)
          LINK_CLAUSE(NB_LINK)+=vireblc(format$("KT:250X",[F:ALD]CLC),2)
        Endif
      When 2
        LINK_CLAUSE(NB_LINK)+='[AY'+num$(LIGTXT(I)+10)+']AXX0 = "'+TBTXT(I)+'";"'+CHTXT(I)+'";LANGUE'
        For GBIDC1="CLECUR1","CLECUR2"
          Read [AMP]CODPAR=2;TBTXT(I);CHTXT(I);GBIDC1
          If !fstat
            Read [AVWF]CODZONE = TBTXT(I);[AMP]VALPAR
            If !fstat
              CHAINE = "[F:"+ABTXT(I)+"]"+[AMP]VALPAR
            Else
              CHAINE = [AMP]VALPAR
            Endif
          Else
            CHAINE = '""'
          Endif
          LINK_CLAUSE(NB_LINK)+=";"+CHAINE
        Next GBIDC1
    Endcase
  Next I
Return

# Link generation for graphical requester
$LINK3
 LINK_CLAUSE(1)="  Link ["+ABFIC(F)+"] With"
 LNKFIC = ABFIC(F)
 LNKTBL = TBFIC(F)        # Issue X3-75518 - 2018-08-09 by CCC : main table is not known without this
 NB_LINK = 1
 For I=1 To NBFIC2
  If I<>F
   NB_LINK+=1
   #LINK_CLAUSE(NB_LINK)=string$(NB_LINK>2,"& ,    ")+string$(NB_LINK=2,"&      ")
   If LIMP(I)
    LINK_CLAUSE(NB_LINK)+=[F:ALH]LNK(LIND(I))
   Else
    LINK_CLAUSE(NB_LINK)+="["+ABFIC(I)+"]"+LCLE(I)
    Read [AVWT]CODFIC=func SUBALH11A.TABLE(LISTE,ABFIC(I))
    Read [AVWI]CODIND=[F:AVWT]CODFIC;LCLE(I)
    CHAINE = [F:AVWI]DESCRIPT
    Gosub SETCLE
    Raz CHAINE, ZONE
    MODLEC = "="
    For J=1 To NBCLE
     For L=1 To NBLIEN
      If TBDES(L)=TBFIC(I) & ZNDES(L)=CLE(J)
       If TBLNK(L)=1 : # Jointure interne
        MODLEC = "~="
       Endif
       If ZONE<>"" & ZONE<>TBORG(L)
        MODLEC = "~="
       Endif
       ZONE = TBORG(L)
       K = find(TBORG(L),TBFIC)
       If K
        If CHAINE<>"" : CHAINE += ";" : Endif
        CHAINE += "["+ABFIC(K)+"]"+ZNORG(L)
       Endif
      Endif
     Next L
    Next J
    LINK_CLAUSE(NB_LINK)+=" "+MODLEC+" "+CHAINE
   Endif
  Endif
 Next I

 For I=1 To NBTXT
  If find(TYPTXT(I),1,2)
   NB_LINK+=1
   #LINK_CLAUSE(NB_LINK)=string$(NB_LINK>2,"& ,    ")+string$(NB_LINK=2,"&      ")
  Endif
  Case TYPTXT(I)
   When 1
    LINK_CLAUSE(NB_LINK)+="[AX"+num$(LIGTXT(I)+10)+"]NUMERO = LANGUE;"
    If CHTXT(I)<>""
     LINK_CLAUSE(NB_LINK)+="[F:"+ABTXT(I)+"]"+CHTXT(I)
    Else
     Read [ALD]ALD0 = LISTE;LIGTXT(I)
     LINK_CLAUSE(NB_LINK)+=vireblc(format$("KT:255X",[F:ALD]CLC),2)
    Endif
   When 2
    LINK_CLAUSE(NB_LINK)+='[AY'+num$(LIGTXT(I)+10)+']AXX0   = "'+TBTXT(I)+'";"'+CHTXT(I)+'";LANGUE'
    For GBIDC1="CLECUR1","CLECUR2"
     Read [AMP]CODPAR=2;TBTXT(I);CHTXT(I);GBIDC1
     If !fstat
      Read [AVWF]CODZONE = TBTXT(I);vireblc(format$("KT:250X",[AMP]VALPAR),2)
      If !fstat
       CHAINE = "[F:"+ABTXT(I)+"]"+[AVWF]CODZONE
      Else
       CHAINE = [AMP]VALPAR
      Endif
     Else
      CHAINE = '""'
     Endif
     LINK_CLAUSE(NB_LINK)+=";"+CHAINE
    Next GBIDC1
  Endcase
 Next I
Return

$GENELINK
  Call LNK_SORT(LINK_CLAUSE,OKL) From SUBALT1
  OKL=0
  Wrseq LINK_CLAUSE(1) Using [SSS_]
  For I=2 To NB_LINK
   If I>2
    Wrseq "& , "; Using [SSS_]
   Else
    Wrseq "&   "; Using [SSS_]
   Endif
   Wrseq LINK_CLAUSE(I) Using [SSS_]
  Next I
  #For I=1 To NB_LINK
  #  Wrseq LINK_CLAUSE(I) Using [SSS_]
  #Next I
  If LINK_ACCES<>"" & IF_ACCESS
    Wrseq "& "+string$(NB_LINK>1,",    ")+string$(NB_LINK=1,"     ")+LINK_ACCES Using [SSS_]
    OKL+=1
  Endif
  If LINK_SITE<>""
    Wrseq "& "+string$(NB_LINK+OKL>1, ",    ")+string$(NB_LINK+OKL=1,"     ")+LINK_SITE Using [SSS_]
    OKL+=1
  Endif
  If NB_LINK+OKL=1
    Wrseq "& "+'      [ALH]ALH0="'+LISTE+'"' Using [SSS_]
  Endif
  Wrseq "& As [LNK]" Using [SSS_]
  Wrseq "& Where evalue(CRITERE)" Using [SSS_]
  If KK
    Wrseq "&     "+"& evalue(CRITSUP)" Using [SSS_]
  Endif
  If AOBACC<>"" & IF_ACCESS
    Wrseq "&     "+"& [Z_ACC]CONSUL=2" Using [SSS_]
  Endif

  # Added Sept 22, 2014 by Dom Bug if no role
  If AOBAOB<>""
    Wrseq "&     "+"& evalue(CRITROL)" Using [SSS_]
  Endif

  OKL = 0
  NBGRP = 0
  Filter [ALD] Where COD=LISTE & STREND<=2 & SRT>1 & GRP=2 Order By Key CLE=COD;NIV;LIG
  For [ALD]CLE
    NBGRP += 1
    If OKL<>0
      Wrseq ";"; Using [SSS_]
    Else
      OKL = 1
      Wrseq "& Order By Key CLE = "; Using [SSS_]  : # 101900
    Endif
    If [F:ALD]CODTYP="ATX"
      Wrseq "[F:AX"+num$([F:ALD]LIG+10)+"]TEXTE"; Using [SSS_]
    Elsif find([F:ALD]CODTYP,"AXX","AX1","AX2","AX3")
      Wrseq "[F:AY"+num$([F:ALD]LIG+10)+"]TEXTE"; Using [SSS_]
    Else
      K = find([F:ALD]TBL,TBFIC(1..NBFIC2))
      Wrseq "[F:"+ABFIC(K)+"]"+[F:ALD]FLD; Using [SSS_]
    Endif
    If [F:ALD]SRT=3 : Wrseq " Desc"; Using [SSS_] : Endif
  Next
  Filter [ALD] Where COD=LISTE & STREND<=2 & SRT>1 & GRP<>2 Order By Key CLE=COD;NIV;LIG
  For [ALD]CLE
    If OKL<>0
      Wrseq ";"; Using [SSS_]
    Else
      OKL = 1
      Wrseq "& Order by Key CLE = "; Using [SSS_]  : # 101900
    Endif
    If [F:ALD]CODTYP="ATX"
      Wrseq "[F:AX"+num$([F:ALD]LIG+10)+"]TEXTE"; Using [SSS_]
    Elsif find([F:ALD]CODTYP,"AXX","AX1","AX2","AX3")
      Wrseq "[F:AY"+num$([F:ALD]LIG+10)+"]TEXTE"; Using [SSS_]
    Else
      K = find([F:ALD]TBL,TBFIC(1..NBFIC2))
      Wrseq "[F:"+ABFIC(K)+"]"+[F:ALD]FLD; Using [SSS_]
    Endif
    If [F:ALD]SRT=3 : Wrseq " Desc"; Using [SSS_] : Endif
  Next
  Filter [ALD]
  If OKL=0
    For [ALD]ALD0 Where COD=LISTE & STREND<=2 & FLD<>""
      K = find([F:ALD]TBL,TBFIC(1..NBFIC2))
      Wrseq "& Order by Key CLE = "; Using [SSS_] : # 101900
      Wrseq "[F:"+ABFIC(K)+"]"+[F:ALD]FLD; Using [SSS_]
      OKL=1
      Break
    Next
  Endif
  If OKL=0
    # Bug found on a HRM report : no sorting order is defined if only formula are present
    Read [AVWI]NUMLIG(2) = TBFIC(F);1
    If !fstat   # Issue X3-44426 - 2017-06-14 by CCC : add the Order by only if a key has been defined in the view
        CHAINE = [F:AVWI]DESCRIPT
        Wrseq "& Order by Key CLE = ["+ABFIC(F)+"]"+vireblc(ctrans([F:AVWI]DESCRIPT,"+-","  "),3)+" : # Default order"; Using [SSS_]
    Else
        Wrseq "& Order by Key CLE = 1 : # No order can be specified"; Using [SSS_]
    Endif
  Endif
  Wrseq Using [SSS_]

Return
# End of modifications End of January 2014

##############################
$REC_CLOB
FLCLOB = 0
CHAINE = vireblc(format$("KT:255X",CHAINE),2)
J = 0
Repeat
 J = instr(J+1,CHAINE,"[")
 If J
  K = instr(J+1,CHAINE,"]")
  If K & !instr(1,seg$(CHAINE,J+1,K-1),"/")
   Repeat
    K += 1
   Until K>len(CHAINE) or !instr(1,sigma(0,25,chr$(65+indcum))+sigma(0,9,chr$(48+indcum))+"_",mid$(CHAINE,K,1))
   CH2 = seg$(CHAINE,J,K-1)
   K = instr(1,CH2,"]")
   CH3 = seg$(CH2,2,K-1)
   CH4 = right$(CH2,K+1)
   If left$(CH3,2)="F:" : CH3 = right$(CH3,3) : Endif
   Read [AVWT]CODFIC = func SUBALH11A.TABLE(LISTE,CH3)
   If !fstat
    Read [AVWF]CODZONE = [F:AVWT]CODFIC;CH4
    If !fstat
     Read [ATY]CODTYP=[F:AVWF]CODTYP
     If !fstat & find([F:ATY]TYPTYP,9,10)
      FLCLOB = 1 : Break
     Endif
    Endif
   Endif
  Endif
 Endif
Until J=0
Return

Funprog PREFIX_TRT_OLD : End "WF"
Funprog PREFIX_TRT_PROTO : End "WFP"
Funprog PREFIX_TRT_DATA    : End "WFD"

