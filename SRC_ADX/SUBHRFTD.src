#<AdxTL>@(#)0.0.0.0 $Revision$
Call OBJET("FTD",GBIDC1,"") From GOBJET
End

$ACTION
Case ACTION
 When "SETBOUT" : Gosub SETBOUT
 When "RAZDUP" : Gosub RAZDUP
Endcase
Return

########################################
#39925
$SETBOUT
If !CLECUR | GREP<>"" | !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET
Endif
Return

$RAZDUP
Raz [M]VER
Return

$TRTCOP
If [M]DOSORG=nomap
 Local File HRFILTDS [FTD1]
Else
 Local File =[M]DOSORG+".HRFILTDS" [FTD1]
Endif
If [M]DOSDES=nomap
 Local File HRFILTDS [FTD2]
Else
 Local File =[M]DOSDES+".HRFILTDS" [FTD2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [FTD1], [FTD2]
Return

$TR_COP
GOK = 1
Trbegin [FTD2]
 Delete [FTD2] Where NUMREC=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".HRFILTDS" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("FTD2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [FTD1] Where NUMREC=TABLE
  [F:FTD2] = [F:FTD1]
  If dim([F:FTD2]UPDUSR)>0 : [F:FTD2]UPDUSR = GUSER : Endif
  If dim([F:FTD2]UPDDAT)>0 : [F:FTD2]UPDDAT = date$ : Endif
  If dim([F:FTD2]UPDTIM)>0 : [F:FTD2]UPDTIM = time : Endif
  Write [FTD2]
  If fstat
   GOK = 0 : Call FSTA("FTD2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
Return

######################################################################################
## Etiquette ajoutée par le superviseur (écran HRFILTDS) 04/07/2005 09:54:06 (DBA)
######################################################################################
Subprog C_NUMREC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call UNICITE(VALEUR,[M]NUMREC(0..[M]BPAG-1)) From OBJDIV
 If mkstat=2 : End : Endif
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran HRFILTDS) 05/03/2010 16:42:51 (DBA)
######################################################################################
Subprog AS_VER(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : mkstat=2 : End : Endif
End
