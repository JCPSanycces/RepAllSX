#<AdxTL>@(#)214.0.0.0 $Revision$
Call CONSNAT("","","","",[0/0/0],[0/0/0],"","","")
End

####################################################################
## GH 05/08/99 Nouvelle consultation de nature gérée par GCONSULT ##
####################################################################
Subprog CONSNAT(CECRAN,CNAT,CSOC,CSITE,CDEB,CFIN,CDEV,CFILTRE,COPT) 
Value Char CECRAN
Value Char CNAT
Value Char CSOC
Value Char CSITE
Value Date CDEB
Value Date CFIN
Value Char CDEV
Value Char CFILTRE
Value Char COPT
Local Char PARAM(250)(1..8)

PARAM(1) = CNAT
PARAM(2) = CSITE
PARAM(3) = CSOC
PARAM(4) = CDEB
PARAM(5) = CFIN
PARAM(6) = CDEV
PARAM(7) = CFILTRE
PARAM(8) = COPT
Call GCONSULT("NAT",CECRAN,PARAM) From GCONSULT
End
