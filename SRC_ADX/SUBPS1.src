#<AdxTL>@(#)9.0.0.0 $Revision$
Close Mask
Raz GPILOBJ
Call OBJET("PS1",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "SETBOUT"         : Gosub SETBOUT
 When "INIMOD","INICRE" : Gosub SET_TBL
 When "APRES_MOD"       : Gosub APRES_MOD
 When "SEL_LISTE"       : Gosub SEL_LISTE
 When "MODIF"           : Gosub MAJ_TEXTE
 When "CREATION"        : Gosub MAJ_TEXTE
 When "ANNULE"          : Gosub ANNULE
 When "CHANGE"          : Gosub CHANGE
 When "LIENS"           : Gosub LIENS
Endcase
Return

$LIENS
For I=0 To [PS1]NBRVAR-1
 [M:PS12]VARNUM(I) = I+1
Next
Return

$SETBOUT
If !CLECUR or REP<>"" or !VERROU
 Call VIREBOUT(CHAINE,"2") From GOBJET : # Copie
Endif
Return

$SET_TBL
Local Char ZONE(GLONAVA)
For ZONE=[F:PS1]DATFLD,[F:PS1]CPYFLD,[F:PS1]FCYFLD
 Read [ATZ]CODZONE = [F:PS1]RLGTBL;ZONE
 If fstat
  For I=0 To [F:PS1]NBRTBL-1
   Read [ATZ]CODZONE = [F:PS1]TBL(I);ZONE
   If !fstat : Break : Endif
  Next I
 Endif
 Read [ATB]CODFIC = [F:ATZ]CODFIC
 Case ZONE
  When [F:PS1]DATFLD : [F:PS1]DATTBL = [F:ATB]ABRFIC
  When [F:PS1]CPYFLD : [F:PS1]CPYTBL = [F:ATB]ABRFIC
  When [F:PS1]FCYFLD : [F:PS1]FCYTBL = [F:ATB]ABRFIC
 Endcase
Next ZONE
Return

$APRES_MOD
If clalev([F:PS2])=0 : Local File PARSTA2 [PS2] : Endif
Local Char LISTEVT(250)
For [PS2] Where RLG=CLECUR1
 LISTEVT -= [F:PS2]COD
Next
If LISTEVT<>""
 GERR = 2 : GMESSAGE = mess(197,124,1)+"\"+LISTEVT : # Vous devez revalider les codes stats
Endif
Return
 
$SEL_LISTE
Case LISTE
 When "SELCLE"
  Gosub SELCLE
Endcase
Return

$SELCLE
If clalev([F:ATI])=0 : Local File ATABIND [ATI] : Endif
If clalev([F:ANX])=0 : Local File AINDEX  [ANX] : Endif
NBTEX = 0 
For [ATI] Where CODFIC=PARAM(1) 
 NBTEX += 1 
 TEXTE(NBTEX) = [F:ATI]CODIND-[F:ATI]DESCRIPT 
 TEX(NBTEX)   = [F:ATI]CODIND 
Next 
For [ANX]ANX0 Where TABLE=PARAM(1) & FLACT=2
 NBTEX += 1
 TEXTE(NBTEX) = [F:ANX]CODIND-[F:ANX]DESCRIPT 
 TEX(NBTEX)   = [F:ANX]CODIND
Next
Return

$MAJ_TEXTE
Call MAJTEXTRA([M:PS10]INTIT,"PARSTA1","INTIT",[M:PS10]COD,"") From ATEXTRA
Call MAJTEXTRA([M:PS11]INTSHO,"PARSTA1","INTSHO",[M:PS10]COD,"") From ATEXTRA
##### Pour la duplication ######
If GREP = "D"
 For I=0 To [M:PS12]NBRVAR-1
  If [M]VARNUM(I) <> 0
   Call DUPTEXTRA("PARSTA1","VARINTIT",CLECUR1,num$([M]VARNUM(I)),"PARSTA1","VARINTIT",[M:PS10]COD,num$(I+1)) From ATEXTRA
  Endif
 Next
 Return
Endif
##############################
For I=0 To [M:PS12]NBRVAR-1
 If [M]VARNUM(I) <> 0
  Call DUPTEXTRA("PARSTA1","VARINTIT",[M:PS10]COD,num$([M]VARNUM(I)),"PARSTA1","VARINTIT",[M:PS10]COD,chr$(255)+num$(I+1)) From ATEXTRA
 Endif
Next
Delete [AXX] Where CODFIC = "PARSTA1" & ZONE = "VARINTIT" & IDENT1 = [M:PS10]COD & left$(IDENT2,1) <> chr$(255)
If fstat=1
 GOK=-1 : Call RSTA("AXX","PARSTA1"-[M:PS10]COD) From GLOCK : Return
Endif
Update [AXX] Where CODFIC = "PARSTA1" & ZONE = "VARINTIT" & IDENT1 = [M:PS10]COD & left$(IDENT2,1) = chr$(255)
&            With [AXX]IDENT2 = right$([AXX]IDENT2,2)
If fstat=1
 GOK=-1 : Call RSTA("AXX","PARSTA1"-[M:PS10]COD) From GLOCK : Return
Endif
For I=0 To [M:PS12]NBRVAR-1
 Call MAJTEXTRA([M:PS12]VARINTIT(I),"PARSTA1","VARINTIT",[M:PS10]COD,num$(I+1)) From ATEXTRA
 [M]VARNUM(I) = I
Next I
Return

$ANNULE
Delete [AXX] Where CODFIC="PARSTA1" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

$CHANGE
Update [AXX] Where CODFIC="PARSTA1" & IDENT1=[L]OCODE With IDENT1=[L]NCODE
If fstat=1
 GOK=-1 : GLOCK="$ATEXTRA PARSTA1"-[L]OCODE : Return
Elsif fstat
 GOK=0 : Call RSTA("AXX",[L]OCODE) From GLOCK : Return
Endif
Return

#########################################################
$TRTCOP
If [M]DOSORG=nomap 
 Local File PARSTA1  [PS11] 
 Local File ATEXTRA  [AXX1] 
Else 
 Local File =[M]DOSORG+".PARSTA1"  [PS11]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif 
If [M]DOSDES=nomap 
 Local File PARSTA1  [PS12]
 Local File ATEXTRA   [AXX2] 
Else 
 Local File =[M]DOSDES+".PARSTA1"  [PS12]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif 
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [PS11], [PS12], [AXX1] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [PS12]
 Delete [PS12] Where COD=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".PARSTA1" : Goto ROLL_TR_COP
 Endif
 Delete [AXX2] Where CODFIC="PARSTA1" & IDENT1=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".ATEXTRA" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("AXX2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [PS11]PS10 Where COD=TABLE
  [F:PS12] = [F:PS11]
  Call COPTEXTRA("PARSTA1","INTIT",[F:PS12]COD,"") From ATEXTRA
  Call COPTEXTRA("PARSTA1","INTSHO",[F:PS12]COD,"") From ATEXTRA
  For I=1 To [F:PS12]NBRVAR
   Call COPTEXTRA("PARSTA1","VARINTIT",[F:PS12]COD,num$(I)) From ATEXTRA
  Next I
  If dim([F:PS12]UPDUSR)>0 : [F:PS12]UPDUSR = GUSER : Endif
  If dim([F:PS12]UPDDAT)>0 : [F:PS12]UPDDAT = date$ : Endif
  Write [PS12]
  If fstat
   GOK=0 : Call FSTA("PS12") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif


###################################################################################
Subprog C_DATFLD(VALEUR)
Variable Char    VALEUR()
Local Integer TYPZ
TYPZ = 8 : # Date
Gosub VERFZONE
End

Subprog C_CPYFLD(VALEUR)
Variable Char    VALEUR()
Local Integer TYPZ
If VALEUR="" : End : Endif
TYPZ = 7 : # Alpha
Gosub VERFZONE
End

Subprog C_FCYFLD(VALEUR)
Variable Char    VALEUR()
Local Integer TYPZ
If VALEUR="" : End : Endif
TYPZ = 7 : # Alpha
Gosub VERFZONE
End

$VERFZONE
Read [ATZ]CODZONE = [M]RLGTBL;VALEUR
If fstat
 GMESSAGE = mess(8,124,1) : mkstat = 2 : Return
# Zone inexistante
Else
 Read [ATY]CODTYP = [F:ATZ]CODTYP
 If [F:ATY]TYPTYP<>TYPZ
  GMESSAGE = mess(10,124,1) : mkstat = 2 : Return
# Zone de type incorrect
 Endif
Endif
Return

Subprog C_TBL(VALEUR)
Variable Char    VALEUR()
Local Integer OK , NOL , I
NOL = nolign-1
If VALEUR=[M]RLGTBL : mkstat = 1 : End : Endif
Read [ATZ]LIEN(2) = VALEUR;[M]RLGTBL
If !fstat
 OK = 1
Else
 OK = 0
 For I=0 To NOL-1 : # L'ordre est important
  Read [ATZ]LIEN(2) = VALEUR;[M]TBL(I)
  If !fstat
    OK = 1 : Break
  Endif
 Next I
Endif
If OK & [M]EXPLNK(NOL)=""
 Gosub SET_LIEN
 [M]EXPLNK(NOL) = CHAINE2
Endif
End

$SET_LIEN
Local Char    CHAINE1(80) , CHAINE2(80) , CHAMP(80)
Local Integer K
Read [ATB]CODFIC = [F:ATZ]CODFIC
If [F:ATZ]EXPLIEN=""
 CHAINE1 = "[F:"+[F:ATB]ABRFIC+"]"+[F:ATZ]CODZONE
Else
 CHAINE1 = vireblc(format$("KT:120X",[F:ATZ]EXPLIEN),2)
Endif
CHAINE2 = ""
Repeat
 K = instr(1,CHAINE1,";")
 If K
  CHAMP   = left$(CHAINE1,K-1)
  CHAINE1 = right$(CHAINE1,K+1)
 Else
  CHAMP   = CHAINE1
  CHAINE1 = ""
 Endif
 If left$(CHAMP,1)>="A" & left$(CHAMP,1)<="Z"
  CHAMP = "[F:"+[F:ATB]ABRFIC+"]"+CHAMP
 Endif
 If CHAINE2<>"" : CHAINE2 += ";" : Endif
 CHAINE2 += CHAMP
Until CHAINE1=""
Return

Subprog AM_TBL(VALEUR)
Variable Char    VALEUR()
If VALEUR="" : End : Endif
If [M]ABRLNK(nolign-1)<>""
 Read [ATB]CODFIC = VALEUR
 If !fstat
  [M]ABRLNK(nolign-1) = [F:ATB]ABRFIC
  Affzo [M]ABRLNK(nolign-1)
 Endif
Endif
If CLELNK(nolign-1)<>""
 Read [ATI]NUMLIG(2) = VALEUR ; 1
 If !fstat
  [M]CLELNK(nolign-1) = [F:ATI]CODIND
  Affzo [M]CLELNK(nolign-1)
 Endif
Endif
End

Subprog B1_ABRLNK(VALEUR)
Variable Char    VALEUR()
If [M]TBL(nolign-1)<>""
 Read [ATB]CODFIC = [M]TBL(nolign-1)
 VALEUR = [F:ATB]ABRFIC
Endif
End

Subprog C_CLELNK(VALEUR)
Variable Char    VALEUR()
Local Integer OK
If VALEUR="" : End : Endif 
OK = 0 
For [ATI] Where CODFIC=[M]TBL(nolign-1)
 If VALEUR=[F:ATI]CODIND 
  OK = 1 : Break 
 Endif 
Next 
If !OK
 For [ANX]ANX0 Where TABLE=[M]TBL(nolign-1) & FLACT=2
  If VALEUR=[F:ANX]CODIND
   OK = 1 : Break
  Endif
 Next
Endif
If !OK 
 GMESSAGE = VALEUR-":"-mess(6,114,1) : # Clé inexistante 
 mkstat = 2 
Endif
End 

Subprog AS_EXPLNK(VALEUR)
Variable Char    VALEUR()
Local Integer NB , I
Raz [M]TABFIL, NB
[M]TABFIL(0) = [M]RLGTBL
Read [ATB]CODFIC = [M]RLGTBL
[M]ABRFIL(0) = [F:ATB]ABRFIC
For I=0 To nolign-2
 NB += 1
 [M]TABFIL(NB) = [M]TBL(I)
 If [M]ABRLNK(I)<>""
  [M]ABRFIL(NB) = [M]ABRLNK(I)
 Else
  Read [ATB]CODFIC = [M]TBL(I)
  [M]ABRFIL(NB) = [F:ATB]ABRFIC
 Endif
Next I
End

Subprog C_EXPLNK(VALEUR)
Variable Char    VALEUR()
Local Integer OK , NOL, STD
NOL = nolign-1
VALEUR = vireblc(toupper(VALEUR),2)
If [M]CLELNK(NOL)=""
 STD = 1
Else
 Read [ATI]NUMLIG(2) = [M]TBL(NOL) ; 1
 STD = ([M]CLELNK(NOL)=[F:ATI]CODIND)
Endif
If STD
 If VALEUR=""
  Read [ATZ]LIEN(2) = [M]TBL(NOL);[M]RLGTBL
  If !fstat
   OK = 1
  Else
   OK = 0
   For I=0 To NOL-1 : # L'ordre est important
    Read [ATZ]LIEN(2) = [M]TBL(NOL);[M]TBL(I)
    If !fstat
     OK = 1 : Break
    Endif
   Next I
  Endif
  If OK 
   Gosub SET_LIEN
   VALEUR = CHAINE2
  Else
   GMESSAGE = mess(10,123,1) : # Zone obligatoire
   mkstat = 2 : End
  Endif
 Else
  Call CONTROLE(VALEUR)
 Endif
Elsif VALEUR=""
 GMESSAGE = mess(10,123,1) : # Zone obligatoire
 mkstat = 2 : End
Else
 Call CONTROLE(VALEUR)
Endif
End

###########################################
Subprog CONTROLE(EXPR)
Variable Char EXPR()
EXPR = toupper(EXPR)
Local Char    CHAINE(250) , CHAMP(30) , ABREV(10)
Local Char    TBABR(GLONABR)(10), TBFIC(GLONATB)(10)
Local Integer NBCLE , NBCMP
Local Integer I , J , OK
OK = 1
NBCLE = 0
CHAINE = ""
Read [ATB]CODFIC = [M]RLGTBL
TBFIC(0) = [M]RLGTBL
TBABR(0) = [F:ATB]ABRFIC
For I=0 To nolign-2
 TBFIC(I+1) = [M]TBL(I)
 If [M]ABRLNK(I)<>""
  TBABR(I+1) = [M]ABRLNK(I)
 Else
  Read [ATB]CODFIC = [M]TBL(I)
  TBABR(I+1) = [F:ATB]ABRFIC
 Endif
Next I
If [M]CLELNK(nolign-1)<>""
 For [ATI] Where CODFIC=[M]TBL(nolign-1)
  If [M]CLELNK(nolign-1)=[F:ATI]CODIND 
   CHAINE = [F:ATI]DESCRIPT
   Break
  Endif 
 Next 
 If CHAINE=""
  For [ANX]ANX0 Where TABLE=[M]TBL(nolign-1) & FLACT=2
   If [M]CLELNK(nolign-1)=[F:ANX]CODIND
    CHAINE = [F:ANX]DESCRIPT
    Break
   Endif
  Next
 Endif
Endif
If CHAINE=""
 Read [ATI]NUMLIG(2) = [M]TBL(nolign-1);1
 CHAINE = [F:ATI]DESCRIPT
Endif
Repeat
 NBCLE += 1
 I = instr(1,CHAINE,"+")
 J = instr(1,CHAINE,"-")
 If    I & J  : I = min(I,J)
 Elsif J & !I : I = J
 Endif
 If I : CHAINE = right$(CHAINE,I+1) : Else : CHAINE = "" : Endif
Until CHAINE = ""
NBCMP = 0
CHAINE = EXPR
Repeat
 NBCMP += 1
 I = instr(1,CHAINE,";")
 If I
  CHAMP  = left$(CHAINE,I-1)
  CHAINE = right$(CHAINE,I+1)
 Else
  CHAMP  = CHAINE
  CHAINE = ""
 Endif
 If left$(CHAMP,1)="[" & !instr(1,CHAMP,"/")
  I = instr(1,CHAMP,"]")
  If I=0 : OK = 0 : Break : Endif
  ABREV = seg$(CHAMP,2,I-1)
  CHAMP = right$(CHAMP,I+1)
  If left$(ABREV,2) = "F:" : ABREV = right$(ABREV,3) : Endif
  K = find(ABREV,TBABR)
  If !K
   GMESSAGE = ABREV-":"-mess(124,124,1) : # Table inexistante
   OK = 0 : Break
  Endif
  I = instr(1,CHAMP,"(")
  If I : CHAMP = left$(CHAMP,I-1) : Endif
  Read [ATZ]CODZONE = TBFIC(K-1);CHAMP
  If fstat
   GMESSAGE = "[F:"+ABREV+"]"+CHAMP-":"-mess(41,100,1) : # Champ inexistant
   OK = 0 : Break
  Endif
 Endif
Until CHAINE=""
If !OK
 If GMESSAGE = "" : GMESSAGE = mess(101,123,1) : Endif
 mkstat = 2 : End
Endif
If NBCMP<>NBCLE
 GMESSAGE = mess(101,123,1) : # Expression de lien incorrecte
 mkstat = 2 : End
Endif  
End

Subprog C_VARNAM(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]VARNAM(0..[M]NBRVAR-1)) From OBJDIV
End

Subprog AS_EXPNLK(VALEUR)
Variable Char    VALEUR()
End

Subprog C_EXPNLK(VALEUR)
Variable Char    VALEUR()
End
