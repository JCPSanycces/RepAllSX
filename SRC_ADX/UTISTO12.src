#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTISTO12   Mise à jour des cumuls de STOLOTFCY suite au bug 62927      #
##########################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
#--- Issue 108760 by TS
#Call SAIDOS(DOSSIER,"") From SAIDOS
Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
#---
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  #--- Issue 108760 By TS
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  #---

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Init CREMVTSEQ") From LECFIC

  Call MAJ_UTISTO12(DOSSIER)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif
End

Subprog MAJ_UTISTO12(DOSSIER)
Value Char     DOSSIER

If clalev([F:ADS])=0 : Local File ADOSSIER [ADS] : Endif
If [F:ADS]DOSSIER<>[L]DOSSIER
  Read [ADS]DOSSIER=[L]DOSSIER
  If fstat : Raz [F:ADS] : Endif
Endif

# Uniquement si module stock
If [F:ADS]MODULE(6)<>2 : End : Endif

Local Decimal LQTYSTO, LQTYSTJ, LAMTSTJ
Local Decimal LQTYSTJTOT, LAMTSTJTOT, LQTYSTJLOT
Local Char LTCM
Local Integer LRET, LVLTLOT, LNB

Call ECR_TRACE("UTISTO12: Process Start on : "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:SLF])  =0  Local File =DOSSIER+".STOLOTFCY"  [SLF]  : Endif
If clalev([F:STO])  =0  Local File =DOSSIER+".STOCK"      [STO]  : Endif
If clalev([F:STJ])  =0  Local File =DOSSIER+".STOJOU"     [STJ]  : Endif
If clalev([F:ITF])  =0  Local File =DOSSIER+".ITMFACILIT" [ITF]  : Endif
If clalev([F:ITM])  =0  Local File =DOSSIER+".ITMMASTER"  [ITM]  : Endif
If clalev([F:ITG])  =0  Local File =DOSSIER+".ITMCATEG"   [ITG]  : Endif
If clalev([F:TCM])  =0  Local File =DOSSIER+".TABCOSTMET" [TCM]  : Endif

For [ITF] Where STOMGTCOD>1
    Call GETTCM([F:ITF]ITMREF, [F:ITF]STOFCY, LTCM, LRET) From STKVAL
    If [F:TCM]ISSVLTCOD=6
        LVLTLOT = 1
    Else
        LVLTLOT = 0
    Endif
    For [SLF] Where ITMREF=[F:ITF]ITMREF
&                 & STOFCY=[F:ITF]STOFCY
&                 & UPDDAT>[01/06/2009]
        Raz LQTYSTO, LQTYSTJTOT, LAMTSTJTOT, LQTYSTJLOT, LNB
        Filter [STO] Where [F:STO]ITMREF = [F:SLF]ITMREF
&                    & [F:STO]STOFCY = [F:SLF]STOFCY
&                    & [F:STO]LOT    = [F:SLF]LOT
&                    & [F:STO]SLO    = [F:SLF]SLO
        For [STO]reckey
            LQTYSTO += [F:STO]QTYSTUACT
        Next
        Filter [STO]

        # Différence entre AVCBASQTY et quantité en stock ?
        If LQTYSTO<>[F:SLF]AVCBASQTY
            Filter [STJ] Where ITMREF = [F:SLF]ITMREF
&                        & STOFCY = [F:SLF]STOFCY
&                        & UPDCOD = 2
&                        & LOT    = [F:SLF]LOT
&                        & SLO    = [F:SLF]SLO
            For [STJ]STJ1(4)
                Raz LQTYSTJ, LAMTSTJ
                For [STJ]STJ1
                    LQTYSTJ += [F:STJ]ACTQTY
                    LAMTSTJ += [F:STJ]VARORD
                    LNB+=1
                Next
                LQTYSTJLOT += LQTYSTJ
                # On prend uniquement les entrées sauf si l'article est géré au PM lot
                If LVLTLOT | LQTYSTJ>0
                    LQTYSTJTOT += LQTYSTJ
                    LAMTSTJTOT += LAMTSTJ
                Endif
            Next
            Filter [STJ]
            If LQTYSTO<>LQTYSTJLOT
                Call ECR_TRACE([F:SLF]ITMREF+";"+[F:SLF]LOT+";"+[F:SLF]SLO+";"+[F:SLF]STOFCY-": qty STO ("+num$(LQTYSTO)+") "+mid$("<>",(LQTYSTO>LQTYSTJLOT)+1,1)+" qty STJ ("+num$(LQTYSTJLOT)+")",1)
& From GESECRAN
            Else
                Trbegin [SLF]
                Call ECR_TRACE("Update "+[F:SLF]ITMREF+";"+[F:SLF]LOT+";"+[F:SLF]SLO+";"+[F:SLF]STOFCY-":",0) From GESECRAN
                Call ECR_TRACE("----> avcbasqty="+num$([F:SLF]AVCBASQTY)-"-->"-num$(LQTYSTO),0) From GESECRAN
                [F:SLF]AVCBASQTY = LQTYSTO
                If LQTYSTJTOT=0
                    Call ECR_TRACE("----> avcbasamt="+num$([F:SLF]AVCBASAMT)-"--> 0",0) From GESECRAN
                    [F:SLF]AVCBASAMT = 0
                Else
                    Call ECR_TRACE("----> avcbasamt="+num$([F:SLF]AVCBASAMT)-"-->"-num$(arr(LAMTSTJTOT * LQTYSTO / LQTYSTJTOT, 10^-6)),0) From GESECRAN
                    [F:SLF]AVCBASAMT = arr(LAMTSTJTOT * LQTYSTO / LQTYSTJTOT, 10^-6)
                Endif
                If [F:SLF]AVCBASQTY>0
                    Call ECR_TRACE("----> avc="+num$([F:SLF]AVC)-"-->"-num$([F:SLF]AVCBASAMT / [F:SLF]AVCBASQTY),0) From GESECRAN
                    [F:SLF]AVC = arr([F:SLF]AVCBASAMT / [F:SLF]AVCBASQTY,10^-6)
                Endif
                Rewrite [SLF]
                Commit
            Endif
        Endif
    Next
Next
Call ECR_TRACE("UTISTO12: Process end",0) From GESECRAN

End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
#--- Issue 108760 by TS
#If APPLI="X3" : End : Endif
If APPLI=GDOSX3 : End : Endif
#---
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
#--- Issue 108760 by TS
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
#---
#--- Issue 108760 by TS
If filinfo(filpath("FIL","STOLOTFCY","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
If func DOSVUE.ISVIEW(APPLI,"STOLOTFCY") : End : Endif                  : # For Archive folder
#---
Call MAJ_UTISTO12(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
#--- Issue 108760 by TS
#If APPLI="X3" : End : Endif
If APPLI=GDOSX3 : End : Endif
#---
#--- Issue 108760 by TS
If filinfo(filpath("FIL","STOLOTFCY","fde",APPLI),0)<=0 : End : Endif   : # XXXXXX= name of table
If func DOSVUE.ISVIEW(APPLI,"STOLOTFCY") : End : Endif                  : # For Archive folder
#---
Call MAJ_UTISTO12(APPLI)
End

