#<AdxTL>@(#)9.0.0.0 $Revision$ Gestion objet MXL
Call OBJET ("MXL", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "RAZCRE"       : Gosub RAZCRE
    When "SETBOUT"      : Gosub SETBOUT
    When "LIENS"        : Gosub LIENS
    When "FERME"        : Gosub FERME
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "CREATION"     : Gosub CREATION
    When "MODIF"        : Gosub MODIF
    When "APRES_CRE"    : Gosub APRES_CRE
    When "APRES_MOD"    : Gosub APRES_MOD
    When "ANNULE"       : Gosub ANNULE
    When "AVANTBOUT"    : Gosub AVANTBOUT
    When Default
  Endcase
Return

##########################################################################################################
$FERME
  If GPILNAV>1 Then
    If GNAVIG(GPILNAV-1) = "GESCMG" Then
      [M:MAY5]MAGTPL = [M:MXL0]NUM
      Affzo [M:MAY5]MAGTPL
    Endif
  Endif
Return

##########################################################################################################
$SETBOUT
  If REP = "" Then
    #Générer paramétrage standard.
    CHMEN += "7"
  Endif
  #----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
  Gosub SET_BOUT_SPE From GSAISIE
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$AVANTBOUT
Local Integer IERRINF
Local Integer IMESSREP

  IERRINF = 0
  IMESSREP = 0
  #Bouton Générer paramétrage standard
  If BOUT = "7" Then
    #Confirmez-vous la génération des publipostages XML (MAILBPR et MAILCCN) dans leur version standard.
    Call OUINON(mess(668,182,1), IMESSREP) From GESECRAN
    If IMESSREP = 2 Then
      Call CREMAILCCN(IERRINF) From SUBMXLB
      If IERRINF Then
        #La création du publipostage XML standard : MAILCCN a échoué.
        GMESSAGE = mess(667,182,1)
        GERR = 1
      Endif
      If IERRINF = 0 Then
        Call CREMAILBPR(IERRINF) From SUBMXLB
        If IERRINF Then
          #La création du publipostage XML standard : MAILBPR a échoué.
          GMESSAGE = mess(666,182,1)
          GERR = 1
        Endif
      Endif
      If IERRINF = 0 Then
        Gosub RAFFRAICHIR From GOBJSUB
      Endif
    Endif
  Endif
Return

##########################################################################################################
$RAZCRE
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESCMG" Then
      If GSZTYPSEA = "CCN" Then
        [M:MXL0]TYP = 2
        [M:MXL0]ROT = "CONTACTCRM"
        [M:MXL0]SRT = "SRT"
        [M:MXL0]TTR = ""
        [M:MXL0]REPFNCFLG = 2
        Grizo [M:MXL0]TTR
      Else
        [M:MXL0]TYP = 1
        [M:MXL0]ROT = "BPARTNER"
        [M:MXL0]SRT = "SRT"
        [M:MXL0]TTR = "TTR"
        [M:MXL0]REPFNCFLG = 2
        Actzo [M:MXL0]TTR
      Endif
    Elsif GNAVIG(GPILNAV-1) = "GESOMM" Then
      If [M:MAZ4]TYPSEA = "CCN" Then
        [M:MXL0]TYP = 2
        [M:MXL0]ROT = "CONTACTCRM"
        [M:MXL0]SRT = "SRT"
        [M:MXL0]TTR = ""
        [M:MXL0]REPFNCFLG = 2
        Grizo [M:MXL0]TTR
      Else
        [M:MXL0]TYP = 1
        [M:MXL0]ROT = "BPARTNER"
        [M:MXL0]SRT = "SRT"
        [M:MXL0]TTR = "TTR"
        [M:MXL0]REPFNCFLG = 2
        Actzo [M:MXL0]TTR
      Endif
    Elsif GNAVIG(GPILNAV-1) = "GESOMP" Then
      If [M:MAZ4]TYPSEA = "CCN" Then
        [M:MXL0]TYP = 2
        [M:MXL0]ROT = "CONTACTCRM"
        [M:MXL0]SRT = "SRT"
        [M:MXL0]TTR = ""
        [M:MXL0]REPFNCFLG = 2
        Grizo [M:MXL0]TTR
      Else
        [M:MXL0]TYP = 1
        [M:MXL0]ROT = "BPARTNER"
        [M:MXL0]SRT = "SRT"
        [M:MXL0]TTR = "TTR"
        [M:MXL0]REPFNCFLG = 2
        Actzo [M:MXL0]TTR
      Endif
    Else
      [M:MXL0]TYP = 1
      [M:MXL0]ROT = "BPARTNER"
      [M:MXL0]SRT = "SRT"
      [M:MXL0]TTR = "TTR"
      [M:MXL0]REPFNCFLG = 2
      Actzo [M:MXL0]TTR
    Endif
  Else
    [M:MXL0]TYP = 1
    [M:MXL0]ROT = "BPARTNER"
    [M:MXL0]SRT = "SRT"
    [M:MXL0]TTR = "TTR"
    [M:MXL0]REPFNCFLG = 2
    Actzo [M:MXL0]TTR
  Endif
  Gosub LOADPARAM From SUBMXLB
  Affzo [M:MXL0]1-99
  Affzo [M:MXL1]1-99
Return

##########################################################################################################
$LIENS
  If [M:MXL0]TYP = 1 Then
    Actzo [M:MXL0]TTR
  Else
    [M:MXL0]TTR = ""
    Grizo [M:MXL0]TTR
  Endif
  #Chargement du paramétrage
  Gosub LOADMXL1 From SUBMXLB
Return

##########################################################################################################
$VERIF_CRE_MOD
  If [M:MXL0]NUM = "" Then
    #Aucun identifiant du publipostage XML n'a été saisi. Création refusée.
    If ACTION = "VERIF_CRE" Then
      GMESSAGE = mess(647,182,1)
    Else
      GMESSAGE = mess(648,182,1)
    Endif
    GERR = 2
    OK = 0
    Return
  Endif
  Gosub CLEANSTAR From SUBMXLB
  Gosub CHKEMPTY From SUBMXLB
  If OK = 0 Then
    Return
  Endif
  Gosub CHECKDUP From SUBMXLB
  If OK = 0 Then
    Affzo [M:MXL1]1-99
  Endif
Return

##########################################################################################################
$VERIF_CRE
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$VERIF_MOD
  Gosub VERIF_CRE_MOD
  If OK = 0 Then
    Return
  Endif
Return

##########################################################################################################
$CREATION
  # FGR 11/02/2014 : X3SUIVI92373
  Call MAJTEXTRA([M:MXL0]MXLDESAX3, "MAILXML", "MXLDESAX3", [M:MXL0]NUM, "") From ATEXTRA
  Call MAJTEXTRA([M:MXL0]MXLSHOAX1, "MAILXML", "MXLSHOAX1", [M:MXL0]NUM, "") From ATEXTRA
  # --------------------------------
  Gosub SAVEMXL1 From SUBMXLB
Return

##########################################################################################################
$MODIF
  # FGR 11/02/2014 : X3SUIVI92373
  Call MAJTEXTRA([M:MXL0]MXLDESAX3, "MAILXML", "MXLDESAX3", [M:MXL0]NUM, "") From ATEXTRA
  Call MAJTEXTRA([M:MXL0]MXLSHOAX1, "MAILXML", "MXLSHOAX1", [M:MXL0]NUM, "") From ATEXTRA
  # --------------------------------
  Gosub SAVEMXL1 From SUBMXLB
Return

##########################################################################################################
$APRES_CRE
  #Chargement du paramétrage
  Gosub LOADMXL1 From SUBMXLB
  Affzo [M:MXL0]1-99
  Affzo [M:MXL1]1-99
Return

##########################################################################################################
$APRES_MOD
  #Chargement du paramétrage
  Gosub LOADMXL1 From SUBMXLB
  Affzo [M:MXL0]1-99
  Affzo [M:MXL1]1-99
Return

##########################################################################################################
$ANNULE
  # FGR 11/02/2014 : X3SUIVI92373
  Call SUPTEXTRA("MAILXML", "MXLDESAX3", [M:MXL0]NUM, "") From ATEXTRA
  Call SUPTEXTRA("MAILXML", "MXLSHOAX1", [M:MXL0]NUM, "") From ATEXTRA
  # --------------------------------
  Delete [MXD] Where [F:MXD]NUM = [M:MXL0]NUM
  If fstat Then
    #Erreur lors de la suppression du paramétrage du publipostage XML. Transaction abandonnée.
    GMESSAGE = mess(650,182,1)
    GERR = 1
    GOK = 0
  Endif
Return

##########################################################################################################
Subprog AM_TYP(VALEUR)
Variable Integer VALEUR

  [M:MXL0]TYP = VALEUR
  If [M:MXL0]TYP = 1 Then
    [M:MXL0]TTR = "TTR"
    [M:MXL0]ROT = "BPARTNER"
    Actzo [M:MXL0]TTR
  Else
    [M:MXL0]TTR = ""
    [M:MXL0]ROT = "CONTACTCRM"
    Grizo [M:MXL0]TTR
  Endif
  Gosub LOADPARAM From SUBMXLB
  Affzo [M:MXL0]1-99
  Affzo [M:MXL1]1-99
End

##########################################################################################################
Subprog IB_NBLIG

  Raz GBOUT1
  Raz GBOUT2
  If GREP <> "" Then
    #Nom par défaut.
    GBOUT1 = mess(646,182,1)
    #Extraite tous les champs.
    GBOUT2 = mess(651,182,1)
  Endif
End

##########################################################################################################
Subprog B1_NBLIG
Local Integer ISTR
Local Integer ILOOPSECURE
Local Char SZ1(250)
Local Char SZ2(250)
Local Char SZ3(250)
Local Char SZ4(250)

  ILOOPSECURE = 0
  ISTR = 0
  SZ1 = ""
  SZ2 = ""
  SZ3 = ""
  SZ4 = ""
  [M:MXL1]LBEXML(nolign-1) = [M:MXL1]FIE(nolign-1)
  #On enlève les parenthèses
  While instr(1, [M:MXL1]LBEXML(nolign-1), "(")
    ISTR = instr(1, [M:MXL1]LBEXML(nolign-1), "(")
    SZ1 = left$([M:MXL1]LBEXML(nolign-1), ISTR - len("("))
    SZ2 = right$([M:MXL1]LBEXML(nolign-1), ISTR + 1)
    SZ3 = SZ1 + SZ2
    [M:MXL1]LBEXML(nolign-1) = SZ3
    ILOOPSECURE += 1
    If ILOOPSECURE > 10000 Then
      Break
    Endif
  Wend
  ISTR = 0
  SZ1 = ""
  SZ2 = ""
  SZ3 = ""
  While instr(1, [M:MXL1]LBEXML(nolign-1), ")")
    ISTR = instr(1, [M:MXL1]LBEXML(nolign-1), ")")
    SZ1 = left$([M:MXL1]LBEXML(nolign-1), ISTR - len(")"))
    SZ2 = right$([M:MXL1]LBEXML(nolign-1), ISTR + 1)
    SZ3 = SZ1 + ' ' + SZ2
    [M:MXL1]LBEXML(nolign-1) = SZ3
    ILOOPSECURE += 1
    If ILOOPSECURE > 20000 Then
      Break
    Endif
  Wend
  SZ4 = [M:MXL1]LBEXML(nolign-1)
  [M:MXL1]LBEXML(nolign-1) = vireblc(SZ4, 4)
  Affzo [M:MXL1]LBEXML(nolign-1)
End

##########################################################################################################
Subprog B2_NBLIG
Local Integer ISTR
Local Integer ILOOPSECURE
Local Char SZ1(250)
Local Char SZ2(250)
Local Char SZ3(250)
Local Char SZ4(250)
Local Integer ITER

  ILOOPSECURE = 0
  ISTR = 0
  SZ1 = ""
  SZ2 = ""
  SZ3 = ""
  SZ4 = ""
  For ITER = 0 To [M:MXL1]NBLIG-1
    If [M:MXL1]LBEXML(ITER) = "" Then
      [M:MXL1]LBEXML(ITER) = [M:MXL1]FIE(ITER)
      #On enlève les parenthèses
      While instr(1, [M:MXL1]LBEXML(ITER), "(")
        ISTR = instr(1, [M:MXL1]LBEXML(ITER), "(")
        SZ1 = left$([M:MXL1]LBEXML(ITER), ISTR - len("("))
        SZ2 = right$([M:MXL1]LBEXML(ITER), ISTR + 1)
        SZ3 = SZ1 + SZ2
        [M:MXL1]LBEXML(ITER) = SZ3
        ILOOPSECURE += 1
        If ILOOPSECURE > 10000 Then
          Break
        Endif
      Wend
      ISTR = 0
      SZ1 = ""
      SZ2 = ""
      SZ3 = ""
      While instr(1, [M:MXL1]LBEXML(ITER), ")")
        ISTR = instr(1, [M:MXL1]LBEXML(ITER), ")")
        SZ1 = left$([M:MXL1]LBEXML(ITER), ISTR - len(")"))
        SZ2 = right$([M:MXL1]LBEXML(ITER), ISTR + 1)
        SZ3 = SZ1 + ' ' + SZ2
        [M:MXL1]LBEXML(ITER) = SZ3
        ILOOPSECURE += 1
        If ILOOPSECURE > 20000 Then
          Break
        Endif
      Wend
      SZ4 = [M:MXL1]LBEXML(ITER)
      [M:MXL1]LBEXML(ITER) = vireblc(SZ4, 4)
    Endif
  Next
  Affzo [M:MXL1]1-99
End

##########################################################################################################
$TRTCOP
  #-----------------------------------------------------------#
  # Etiquette appelée depuis le traitement superviseur ACOPIE #
  # --------------------------------------------------------- #
  # Traitement de la copie d'un publipostage XML              #
  #-----------------------------------------------------------#
  If [M]DOSORG = nomap Then
    Local File MAILXML [MXL1]
    Local File MAILXMLD  [MXD1]
  Else
    Local File =[M]DOSORG+".MAILXML" [MXL1]
    Local File =[M]DOSORG+".MAILXMLD"  [MXD1]
  Endif
  If [M]DOSDES = nomap Then
    Local File MAILXML [MXL2]
    Local File MAILXMLD [MXD2]
  Else
    Local File =[M]DOSDES+".MAILXML" [MXL2]
    Local File =[M]DOSDES+".MAILXMLD"  [MXD2]
  Endif
  OK = 1
  Look [MXL2]MXL0=TABLE
  If !fstat Then
    OK= 2
    Call AVERTIR([M]DOSDES-TABLE-mess(148,196,1),OK) From GESECRAN
    If OK <> 2 Then
      OK = 0
    Endif
  Endif
  If OK Then
    Call DEBTRANS From GLOCK
    Gosub TRT_COPIE
  Endif
  Close Local File [MXL1], [MXD1], [MXL2], [MXD2]
Return

##########################################################################################################
$TRT_COPIE
  #--------------------------------------------------#
  # Transaction de copie d'un publipostage XML       #
  #--------------------------------------------------#
  GOK = 1
  Trbegin [MXL2]
  Delete [MXD2] Where NUM=TABLE
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$" + [M]DOSDES + ".MAILXMLD" - TABLE
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK = 0
    Call RSTA("MXD2",TABLE) From GLOCK
    Goto AB_COPIE
  Endif
  Delete [MXL2] Where NUM=TABLE
  If fstat = 1 Then
    GOK = -1
    GLOCK = "$" + [M]DOSDES + ".MAILXML" - TABLE
    Goto ROLL_COPIE
  Elsif fstat Then
    GOK = 0
    Call RSTA("MXL2",TABLE) From GLOCK
    Goto AB_COPIE
  Endif
  If GOK = 1 Then
    Read [MXL1]MXL0=TABLE
    If !fstat Then
      [F:MXL2] = [F:MXL1]
      Write [MXL2]
      If fstat Then
        GOK = 0
        Call FSTA("MXL2") From GLOCK
        Goto AB_COPIE
      Endif
    Endif
  Endif
  If GOK = 1 Then
    Filter [MXD1] Where [F:MXD1]NUM = TABLE
    For [MXD1]
      [F:MXD2] = [F:MXD1]
      Write [MXD2]
      If fstat Then
        GOK = 0
        Call FSTA("MXD2") From GLOCK
        Goto AB_COPIE
      Endif
    Next
    Filter [MXD1]
  Endif
  Commit
Return

##########################################################################################################
#----- Abandon de la copie -----#
$AB_COPIE
  Rollback
Return

##########################################################################################################
#----- Nouvel essai si nécessaire -----#
$ROLL_COPIE
  Rollback
  Call ROLL From GLOCK
  If !GROLL Then
    Goto TRT_COPIE
  Endif
Return
