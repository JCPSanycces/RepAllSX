#<AdxTL>@(#)230.0.0.0 $Revision$
Call SAITRT("SUBZZM")
End

##########################################################################################################
##  Saisie traitement
##########################################################################################################
Subprog SAITRT(VALEUR)
Value Char    VALEUR  : # Nom du traitement
Local Char    PARAM(30)(1..1)
PARAM(1) = VALEUR
Call SAISIE_CHAR(VALEUR,PARAM,"FSAITRT","TRTTRT","") From GSAISIE
End

##########################################################################################################
##  Saisie étiquette
##########################################################################################################
Subprog ETIQUETTE(VALEUR,TRAIT,NBPAR,CODPAR,TYPPAR,ADRPAR)
Value Char    VALEUR  : # Nom de l'étiquette sous-programme
Value Char    TRAIT   : # Nom du traitement
Value Integer NBPAR   : # Nombre d'arguments du 'Subprog'
Value Char    CODPAR  : # Nom de la variable qui contient le nom des arguments
Value Char    TYPPAR  : # Nom de la variable qui contient le type de donnée (char, integer, etc...)
Value Char    ADRPAR  : # Nom de la variable qui contient le type d'adresse (valeur, adresse)
Local Char    PARAM(30)(1..6)
PARAM(1) = TRAIT
PARAM(2) = VALEUR
PARAM(3) = num$(NBPAR)
PARAM(4) = CODPAR
PARAM(5) = TYPPAR
PARAM(6) = ADRPAR
Call SAISIE_CHAR(VALEUR,PARAM,"FSAIETQ","TRTTRT","") From GSAISIE
End

##########################################################################################################
$ACTION
Case ACTION
 When "OUVRE"
  Case BOITE
   When "FSAITRT"    : If PARAM(1)="" : FIN = 1 : Endif
   When "FSAIETQ"    : If PARAM(1)="" | PARAM(2)="" : FIN = 1 : Endif
  Endcase
 When "DEBUT"
  Case BOITE
   When "FSAITRT"    : Gosub DEBUT
   When "FSAIETQ"    : Gosub DEBUT_ETQ
  Endcase
 When "TITRE"        : TIT = mess(19,123,1)-PARAM(1)  : # Traitement
 When "SETBOUT"      : Gosub SETBOUT
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "ENR"          : Gosub ENREG
 When "END"          : Gosub FERME
 When Default
Endcase
Return

###################################################################
$DEBUT
Local Integer LIG , COLL , STAT 
Local Char    FICSRC(GDIMFIC) , FICLCK(GDIMFIC) , LIGNE(255)
Local Char    OLDIFS(5) , OLDIRS(5)
Local Integer OLDIUM
Local Char    CHAINE(80) , PROGOBJ(GLONADC) , APPLI(GLONADS)
Local Char    FICTRA(GDIMFIC)
Local Char    MESSAGE(80)(1..5)
Local Char    ORDSYS(GDIMFIC)(1..2)
Local Char    TRAIT(GLONADC)
Local Char    FICAPL(GDIMFIC)
Local Integer NBMERE
Local Char    TBMERE(10)(1..10)
Local Char    LCKERR(50)(1..3)
TRAIT  = PARAM(1)
APPLI  = nomap
OLDIFS = adxifs
OLDIRS = adxirs
OLDIUM = adxium
Gosub CHARGE_TRT
If !OK
 FIN = 1 : Return
Endif
Affzo
Gosub VERROU
Return

$TETADO
Local Char TETADO(30), REVISION(20)
TETADO   = "#<AdxT"+GADOVERS+">@(#)%I%"
REVISION = "$Revision$"
Return

####################
$CHARGE_TRT
Raz [M:TTT]
Gosub TETADO
FICSRC = filpath("TRT",TRAIT,"src",APPLI)
FICLCK = filpath("TRT",TRAIT,"LCKsrc",APPLI)
If filinfo(FICSRC,0)<0
 Gosub LEC_MERE
 For J=1 To NBMERE
  FICSRC = filpath("TRT",TRAIT,"src",TBMERE(J))
  FICLCK = filpath("TRT",TRAIT,"LCKsrc",TBMERE(J))
  If filinfo(FICSRC,0)>=0 : Break : Endif
 Next J
Endif
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
OK = 1
If filinfo(FICSRC,0)>=0
 Openi FICSRC Using [TRT]
 Rdseq LIGNE Using [TRT]
 I = instr(1,LIGNE,REVISION)
 If I=0
  [M:TTT]ENTADX  = TETADO
  [M:TTT]COMMENT = right$(LIGNE,len(TETADO)+1)
 Else
  [M:TTT]ENTADX  = left$(LIGNE,I+len(REVISION))
  [M:TTT]COMMENT = right$(LIGNE,I+len(REVISION)+1)
 Endif
 Rdseq LIGNE Using [TRT]
 While fstat=0
  If len(LIGNE)>250
   # Traitement/Longueur de ligne trop grande
   Call ERREUR(mess(19,123,1)-":"-TRAIT+"\"+mess(50,123,1)) From GESECRAN
   OK = 0 : Break
  Endif 
  [M:TTT]LIGNE([M:TTT]NBLIG) = LIGNE
  [M:TTT]NBLIG += 1
  Rdseq LIGNE Using [TRT]
 Wend
 Openi Using [TRT]
Else
 [M:TTT]ENTADX  = TETADO
 [M:TTT]COMMENT = mess(19,123,1)-TRAIT : # Traitement
Endif
Return

#############################
$LEC_MERE
If NBMERE = 0
 FICAPL = filpath("","APL","ini",APPLI)
 If filinfo(FICAPL,0)>=0
  Openi FICAPL
  Rdseq LIGNE
  While fstat=0
   LIGNE = vireblc(LIGNE,2)
   If left$(LIGNE,10)="adxmother("
    J = instr(1,LIGNE,"=")
    If J
     LIGNE = vireblc(right$(LIGNE,J+1),2)
     LIGNE = seg$(LIGNE,2,len(LIGNE)-1)
     If LIGNE<>APPLI & !find(LIGNE,TBMERE(1..NBMERE)) & filinfo(filpath("","","",LIGNE),0)>=0
      NBMERE += 1
      TBMERE(NBMERE) = LIGNE
     Endif
    Endif
   Endif
   Rdseq LIGNE
  Wend
  Openi
 Endif
Endif
Return

###################################################################
$SETBOUT
If !VERROU
 IMGFLG(3) = 1 : # Cadenas
Else
 IMGFLG(3) = 0
Endif
Return

###################################################################
$APRES_MODIF
If VERROU
 REP = "M"
Else
 Gosub QUILOCKE
Endif
Return

###################################################################
$QUILOCKE
Openi FICLCK Using [LOK]
Rdseq LCKERR(1) Using [LOK]
Rdseq LCKERR(2) Using [LOK]
Rdseq LCKERR(3) Using [LOK]
Openi Using [LOK]
GMESSAGE  = "\|"+FICLCK+"|\|"+mess(200,124,1) : # Le fichier est verrouillé par
GMESSAGE += "|\|"+LCKERR(1)+"|\|"+LCKERR(2)+"|\|"+LCKERR(3)+"|\|"
GERR = 1
Return

###################################################################
$VERROU
If filinfo(FICLCK,0)>=0
 VERROU = 0
Else
 Openo FICLCK Using [LOK]
 Wrseq adxmac(-2) Using [LOK]
 Wrseq adxusr Using [LOK]
 Wrseq format$(GFMD,date$)-"-"-time$ Using [LOK]
 Openo Using [LOK]
 VERROU = 1
Endif
Return

###################################################################
$DEVERROU
If VERROU
 If filinfo(FICLCK,0)>=0
  Call EFFACE(FICLCK,STAT) From ORDSYS
 Endif 
 VERROU = 0
Endif
Return

###################################################################
$AP_CHOIX
Case REPONSE
 When GSTACLK+3
  Gosub VERROU
  If VERROU
   Case BOITE
    When "FSAITRT"    : Gosub CHARGE_TRT
    When "FSAIETQ"    : Gosub CHARGE_ETQ
   Endcase
   If !OK
    Gosub DEVERROU
   Else 
    Affzo
   Endif
  Else
   Gosub QUILOCKE
  Endif
  REPONSE = 0
Endcase
Return

###################################################################
$ENREG
If VERROU
 Case BOITE
  When "FSAITRT"    : Gosub VAL_TRT
  When "FSAIETQ"    : Gosub VAL_ETQ
 Endcase
 If GOK<1 : Return : Endif
Endif
Gosub FERME
Return

###################################################################
$FERME
Gosub DEVERROU
adxifs = OLDIFS
adxirs = OLDIRS
adxium = OLDIUM
FIN = 1
Return

###################################################################
$DEBUT_ETQ
Local Integer K , OKLIG , OKETQ , LIG , COLL , STAT
Local Char    FICSRC(GDIMFIC) , FICLCK(GDIMFIC) , FICOLD(GDIMFIC) , LIGNE(255)
Local Char    OLDIFS(5) , OLDIRS(5) , PROGOBJ(GLONADC) , APPLI(GLONADS)
Local Integer OLDIUM
Local Char    CHAINE(80) , ETIQ(20) , APPDES(GLONADS)
Local Char    FICTRA(GDIMFIC)
Local Char    MESSAGE(80)(1..5)
Local Char    ORDSYS(GDIMFIC)(1..2)
Local Char    TRAIT(GLONADC), ETIQUETTE(20)
Local Integer NBPAR
Local Char    LCKERR(50)(1..3)
TRAIT     = PARAM(1)
ETIQUETTE = PARAM(2)
NBPAR     = val(PARAM(3))
If NBPAR>0
 Local Char    CODPAR(10)(1..NBPAR)
 Local Integer TYPPAR(1..NBPAR)
 Local Integer ADRPAR(1..NBPAR)
 For I=1 To NBPAR
  CODPAR(I) = evalue(PARAM(4)+"("+num$(I-1)+")")
  TYPPAR(I) = evalue(PARAM(5)+"("+num$(I-1)+")")
  ADRPAR(I) = evalue(PARAM(6)+"("+num$(I-1)+")")
 Next I
Endif
APPDES = nomap
OLDIFS = adxifs
OLDIRS = adxirs
OLDIUM = adxium
Gosub CHARGE_ETQ
If !OK
 FIN = 1 : Return
Endif
Affzo
Gosub VERROU
Return

####################
$CHARGE_ETQ
Raz [M:TTT]
Gosub TETADO
FICSRC = filpath("TRT",TRAIT,"src",APPDES)
FICLCK = filpath("TRT",TRAIT,"LCKsrc",APPDES)
adxifs = ""
adxirs = chr$(10)
adxium = GUTF8
OK = 1
If filinfo(FICSRC,0)>=0
 Openi FICSRC Using [TRT]
 Rdseq LIGNE Using [TRT]
 I = instr(1,LIGNE,REVISION)
 If I=0
  [M:TTT]ENTADX  = TETADO
  [M:TTT]COMMENT = right$(LIGNE,len(TETADO))
 Else
  [M:TTT]ENTADX  = left$(LIGNE,I+len(REVISION))
  [M:TTT]COMMENT = right$(LIGNE,I+len(REVISION)+1)
 Endif
 Rdseq LIGNE Using [TRT]
 OKLIG = 0
 While fstat=0
  If len(LIGNE)>250
   # Traitement/Longueur de ligne trop grande
   Call ERREUR(mess(19,123,1)-":"-TRAIT+"\"+mess(50,123,1)) From GESECRAN
   OK = 0 : Break
  Elsif left$(LIGNE,7)="Subprog"
   If OKLIG
    Break
   Else
    K = instr(1,LIGNE,"(")
    If K=0 : K = len(LIGNE)+1 : Endif
    ETIQ = vireblc(seg$(LIGNE,8,K-1),2)
    If ETIQ=ETIQUETTE : OKLIG = 1 : Endif
   Endif
  Endif
  If OKLIG
   [M:TTT]LIGNE([M]NBLIG) = LIGNE
   [M:TTT]NBLIG += 1
  Endif
  Rdseq LIGNE Using [TRT]
 Wend
 Openi Using [TRT]
 If !OK : Return : Endif
Else
 [M:TTT]ENTADX  = TETADO
 [M:TTT]COMMENT = mess(19,123,1)-TRAIT : # Traitement
Endif
If [M:TTT]NBLIG=0
 [M:TTT]LIGNE(0) = "Subprog"-ETIQUETTE
 If left$(ETIQUETTE,3)="IB_"
  [M:TTT]NBLIG = 1
 Else
  For I=1 To NBPAR
   If I=1 : [M:TTT]LIGNE(0) += "(" : Endif
   [M:TTT]LIGNE(0) += CODPAR(I)
   If I<NBPAR : [M:TTT]LIGNE(0) += "," : Endif
   If I=NBPAR : [M:TTT]LIGNE(0) += ")" : Endif
  Next I
  [M:TTT]NBLIG = 1
  For I=1 To NBPAR
   Case ADRPAR(I)
    When 1 : [M:TTT]LIGNE([M:TTT]NBLIG) = "Variable "
    When 2 : [M:TTT]LIGNE([M:TTT]NBLIG) = "Value    "
   Endcase
   Case TYPPAR(I)
    When 1 : [M:TTT]LIGNE([M:TTT]NBLIG) += "Char     "
    When 2 : [M:TTT]LIGNE([M:TTT]NBLIG) += "Integer  "
    When 3 : [M:TTT]LIGNE([M:TTT]NBLIG) += "Decimal  "
    When 4 : [M:TTT]LIGNE([M:TTT]NBLIG) += "Date     "
    When 5 : [M:TTT]LIGNE([M:TTT]NBLIG) += "Libelle  "
    When 6 : [M:TTT]LIGNE([M:TTT]NBLIG) += "Clbfile  "
    When 7 : [M:TTT]LIGNE([M:TTT]NBLIG) += "Blbfile  "
   Endcase
   [M:TTT]LIGNE([M:TTT]NBLIG) += CODPAR(I)
   [M:TTT]NBLIG += 1
  Next I
 Endif
 [M:TTT]LIGNE([M:TTT]NBLIG) = "End"
 [M:TTT]NBLIG += 1
Endif
Return

###################################################################
##  Sous-programmes
###################################################################
$VAL_TRT
FICSRC = filpath("TRT",TRAIT,"src",APPLI)
Openo FICSRC,0 Using [TRT]
Wrseq [M:TTT]ENTADX-[M:TTT]COMMENT Using [TRT]
For I=0 To [M:TTT]NBLIG-1
 Wrseq vireblc(format$("KT:255X",[M:TTT]LIGNE(I)),1) Using [TRT]
Next I
Openo Using [TRT]
PROGOBJ = TRAIT
GOK = 1
Gosub VALID
If GOK<1
 SUIZON = "[M:TTT]LIGNE("+num$(LIG-1)+")"
Endif
Return

###################################################################
$VAL_ETQ
FICOLD = filpath("TRT",TRAIT,"old",APPDES)
FICSRC = filpath("TRT",TRAIT,"src",APPDES)
If filinfo(FICSRC,0)>=0
 Call COPIE(FICSRC,FICOLD,STAT) From ORDSYS
 Openi FICOLD Using [ETQ]
 FICSRC = filpath("TRT",TRAIT,"src",APPDES)
 Openo FICSRC,0 Using [TRT]
 Rdseq LIGNE Using [ETQ]
 Wrseq LIGNE Using [TRT]
 Rdseq LIGNE Using [ETQ]
 OKLIG = 0
 OKETQ = 0
 While fstat=0
  If left$(LIGNE,7)="Subprog"
   If OKLIG
    OKLIG = 0
   Else
    K = instr(1,LIGNE,"(")
    If K=0 : K = len(LIGNE)+1 : Endif
    ETIQ = vireblc(seg$(LIGNE,8,K-1),2)
    If ETIQ=ETIQUETTE
     Gosub ECR_ETQ
     OKLIG = 1 : OKETQ = 1
    Endif
   Endif
  Endif
  If !OKLIG : Wrseq LIGNE Using [TRT] : Endif
  Rdseq LIGNE Using [ETQ]
 Wend
 If !OKETQ
  Gosub ECR_ETQ
 Endif
 Openi Using [ETQ]
Else
 Openo FICSRC,0 Using [TRT]
 Wrseq [M:TTT]ENTADX-[M:TTT]COMMENT Using [TRT]
 If find(left$(TRAIT,3),"SPE","SPV") & len(TRAIT)<=6 : # Ca va servir pour un Objet
  Wrseq "$ACTION" Using [TRT]
  Wrseq "Case ACTION" Using [TRT]
  Wrseq " When default" Using [TRT]
  Wrseq "Endcase" Using [TRT]
  Wrseq "Return" Using [TRT]
  Wrseq Using [TRT]
 Endif
 Gosub ECR_ETQ
Endif
Openo Using [TRT]

Call MAJDICTRT(TRAIT,APPDES,"",0,"") From SUBADC

PROGOBJ = TRAIT
APPLI = APPDES
GOK = 1
Gosub VALID
If GOK<1
 SUIZON = "[M:TTT]LIGNE("+num$(LIG-1)+")"
Endif
Return

####################
$ECR_ETQ
For I=0 To [M:TTT]NBLIG-1
 Wrseq vireblc(format$("KT:255X",[M:TTT]LIGNE(I)),1) Using [TRT]
Next I
Return

###################################################################
$VALID
Call TEMPON("V") From GESECRAN
Call VALID("TRT",PROGOBJ,APPLI,STAT) From VALMSKSUB
Call TEMPOFF From GESECRAN
If GOK<1
 CHAINE = MESSAGE(2)
 LIG = 0 : COLL = 0
 I = 1 : J = 0
 While I<=len(CHAINE)
  If instr(1,"0123456789",mid$(CHAINE,I,1))
   LIG = 10*LIG+val(mid$(CHAINE,I,1))
   J = 1
  Elsif J=1
   Break
  Endif
  I += 1
 Wend
 J = 0
 While I<=len(CHAINE)
  If instr(1,"0123456789",mid$(CHAINE,I,1))
   COLL = 10*COLL+val(mid$(CHAINE,I,1))
   J = 1
  Elsif J=1
   Break
  Endif
  I += 1
 Wend
Endif
Return

###################################################################
## Etiquette masque OBJTRT
###################################################################
Subprog C_NBLIG
End
