#<AdxTL>@(#)%I%
# Supervisor
# Inquiry CNG

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "08:11:01"
A_USER  = "ADMIN"
A_STAMP = "20181109081101"
Return

$DEFAUT
Default File [ID]
Return

$OUVFIC
Local File EMPLOID [ID]
Return

$NOMFIC
Local Char    TIT(GLONDES) , TITT(GLONDES)
Local Char    PROGSTD(GLONADC) , PROGSPE(GLONADC)
Local Char    ABMSK(GLONABR)(16) , NOMMSK(GLONAMK)(16) , CABMSK(GLONABR) , CNOMMSK(GLONAMK)
Local Char    BOITE(GLONFEN) , CBOITE(GLONFEN)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , OBJDERLU(GLONAOB)
Local Char    CODMSKDEF(GLONAMK) , CMEMO(GLONAMM)
Local Libelle MAGNETO
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA)
Call TEXTE(1000786,TITT) From OBJDIV
TIT        = mess(15,126,1)
If dim(CNSCOD)>0 : TIT -= CNSCOD : Endif
PROGSTD    = "CNSCNGSTD"
PROGSPE    = "CNSCNGSPE"
CBOITE     = "DCNSCNG"
BOITE      = "FCNSCNG"
NOMMSK(0)  = "CONSCNG1"
ABMSK(0)   = "CNG1"
NOMMSK(1)  = "CONSCNG2"
ABMSK(1)   = "CNG2"
NOMMSK(2)  = "CONSCNG3"
ABMSK(2)   = "CNG3"
NOMMSK(3)  = "CONSCNG4"
ABMSK(3)   = "CNG4"
NOMMSK(4)  = "CONSCNG5"
ABMSK(4)   = "CNG5"
CMEMO      = "ctp"
CNOMMSK    = "CRITCNG"
CABMSK     = "CCNG"
NOMFIC     = "EMPLOID"
ABFIC      = "ID"
OBJDERLU   = "EML"
MAGNETO    = 2
ZSITE      = "FCY"
ZACC       = "CODACS"
Return

$SETCLE
Local Char    CLE(10), CLECMP(10)(0..0), CLEMSK(10)(0..0)
Local Integer NBCMP
Local Char    FILTRE(250)
CLE = "ID0"
NBCMP = 1
CLECMP(0) = "REFNUM"
CLEMSK(0) = "REFNUM"
Return

$OUVRE
If clalev([F:ID])=0 : Local File EMPLOID      [ID] : Endif
If clalev([F:HRCTR])=0 : Local File EMPLOCTR     [HRCTR] : Endif
If clalev([F:ID])=0 : Local File EMPLOID      [ID] : Endif
If clalev([F:CNG])=0 : Local File CNGCPY       [CNG] : Endif
If clalev([F:HRPEOD])=0 : Local File HRPEODET     [HRPEOD] : Endif
If clalev([F:FCY])=0 : Local File FACILITY     [FCY] : Endif
Return

$OUVRE_MSK
Case MA
 When -1 : Local Mask =CNOMMSK   [CCNG]
 When  0 : Local Mask =NOMMSK(0) [CNG1]
 When  1 : Local Mask =NOMMSK(1) [CNG2]
 When  2 : Local Mask =NOMMSK(2) [CNG3]
 When  3 : Local Mask =NOMMSK(3) [CNG4]
 When  4 : Local Mask =NOMMSK(4) [CNG5]
Endcase
Return

$GRISE_MSK
Case MA
 When -1 : Grizo [CCNG]
 When  0 : Grizo [CNG1]
 When  1 : Grizo [CNG2]
 When  2 : Grizo [CNG3]
 When  3 : Grizo [CNG4]
 When  4 : Grizo [CNG5]
Endcase
Return

$GRISE_CLE
Case MA
 When -1 : If dim([M:CCNG]REFNUM)>0 : Grizo [CCNG]REFNUM : Endif
 When  0 : If dim([M:CNG1]REFNUM)>0 : Grizo [CNG1]REFNUM : Endif
Endcase
Return

$GRISE_CRIT
If dim([M:CCNG]CTRNUM)>0
 Grizo [CCNG]CTRNUM
Endif
If dim([M:CCNG]REFNUM)>0
 Grizo [CCNG]REFNUM
Endif
If dim([M:CCNG]DATPYR)>0
 Grizo [CCNG]DATPYR
Endif
Return

$FERME_MSK
Case MA
 When -1 : If clalev([M:CCNG])>0 : Close Local Mask [CCNG] : Endif
 When  0 : If clalev([M:CNG1])>0 : Close Local Mask [CNG1] : Endif
 When  1 : If clalev([M:CNG2])>0 : Close Local Mask [CNG2] : Endif
 When  2 : If clalev([M:CNG3])>0 : Close Local Mask [CNG3] : Endif
 When  3 : If clalev([M:CNG4])>0 : Close Local Mask [CNG4] : Endif
 When  4 : If clalev([M:CNG5])>0 : Close Local Mask [CNG5] : Endif
Endcase
Return

$SETMASK
Case MA
 When -1 : Default Mask [CCNG]
 When  0 : Default Mask [CNG1]
 When  1 : Default Mask [CNG2]
 When  2 : Default Mask [CNG3]
 When  3 : Default Mask [CNG4]
 When  4 : Default Mask [CNG5]
Endcase
Return

$RAZMASK
Case MA
 When -1 : Raz [M:CCNG]
 When  0 : Raz [M:CNG1]
 When  1 : Raz [M:CNG2]
 When  2 : Raz [M:CNG3]
 When  3 : Raz [M:CNG4]
 When  4 : Raz [M:CNG5]
Endcase
Return

$CRITENT
If dim([M:CCNG]CTRNUM)>0 & dim([M:CNG1]CTRNUM)>0
 [M:CCNG]CTRNUM = [M:CNG1]CTRNUM
Endif
If dim([M:CCNG]REFNUM)>0 & dim([M:CNG1]REFNUM)>0
 [M:CCNG]REFNUM = [M:CNG1]REFNUM
Endif
If dim([M:CCNG]DATPYR)>0 & dim([M:CNG1]DATPYR)>0
 [M:CCNG]DATPYR = [M:CNG1]DATPYR
Endif
Return

$ENTCRIT
If dim([M:CCNG]CTRNUM)>0 & dim([M:CNG1]CTRNUM)>0
[M:CNG1]CTRNUM = [M:CCNG]CTRNUM
Endif
If dim([M:CCNG]REFNUM)>0 & dim([M:CNG1]REFNUM)>0
[M:CNG1]REFNUM = [M:CCNG]REFNUM
Endif
If dim([M:CCNG]DATPYR)>0 & dim([M:CNG1]DATPYR)>0
[M:CNG1]DATPYR = [M:CCNG]DATPYR
Endif
Return

$CRITAFF
Local Integer NBCA
Local Char    CRITAFF(10)(1..1) , CRITAFF2(10)(1..1)
NBCA = 0
Return

$STYLEPLAG
Return

Subprog GETACT(NOL,TITBOUT,VALBOUT)
Value Integer NOL
Variable Char TITBOUT()(1..) , VALBOUT()(1..)
Local Integer ONOL , NBBOUT
ONOL   = nolign
nolign = NOL
indice = max(0,nolign-1)
Call AS_NBLIG From ="W1CONSCNG2"
NBBOUT = 0
nolign = ONOL
indice = max(0,nolign-1)
End

Subprog ACTRUN(INFO)
Value Char INFO
Local Char    BOUT(3)
Local Integer ONOL
ONOL    = nolign
BOUT    = func AFNC.PART(INFO,1)
nolign  = val(func AFNC.PART(INFO,2))
indice  = max(0,nolign-1)
Gosub NOMFIC
For MA=0 to dim(NOMMSK)-1
 Gosub OUVRE_MSK
Next MA
For MA=0 to dim(NOMMSK)-1
 Gosub SETMASK
Next MA
Case BOUT
Endcase
nolign = ONOL
indice = max(0,nolign-1)
End

$RIEN
Resume


