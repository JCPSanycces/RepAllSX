#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion du masque MAUTSUS
#########################################################################
# Contient les traitements utilisée pour la modélisation                #
# Etiquettes                                                            #
#########################################################################
#    ACTION MODELISATION E-COMMERCE                                     #
#                                                                       #
# GACTION  : TRTAUTSUS   : Suspension automatique des OF                #
#                                                                       #
#########################################################################
$ACTION
Case ACTION
 When "INIT"          : Gosub INIT
 When "INIT_DIA"      : Gosub INIT_DIA
 When "CONTROLE"      : Gosub CONTROLE
 When "EXEC"          : Gosub EXEC
 When "TERMINE"       : Gosub TERMINE
 When Default
Endcase
Return

#########################################################################
$INIT
# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub OUVRE
Return

#########################################################################
$INIT_DIA

# titre de la boîte 
TIT = mess(240,195,1)

Raz [M:DIA] 
Return

#########################################################################
$CONTROLE

If !GSERVEUR             &
&  [M:DIA]MFGNUMDEB = "" & 
&  [M:DIA]MFGNUMFIN = "" &   
&  [M:DIA]ITMREFDEB = "" &
&  [M:DIA]ITMREFFIN = "" &
&  [M:DIA]STRDATDEB = [0/0/0] &
&  [M:DIA]STRDATFIN = [0/0/0] 
   GERR = 3
   GMESSAGE = mess(64,190,1)
   FOK = 0  
   Return 
Endif
TIT=" "
TMP=1
Return

##########################################################################
$EXEC
If !GSERVEUR
    TRA = 1
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
    Call PRTSCR("MAUTSUS","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
    Call ECR_TRACE(" ",0) From GESECRAN 
    # lecture en cours
    Call TEMPON("") From GESECRAN
Endif

# préparation des critères de filtre
Gosub SEL_OF

# traitement des OF
Gosub TRT_OF
Return

##########################################################################
$TERMINE
If !GSERVEUR
    Call TEMPOFF From GESECRAN
    # fermeture trace 
    Call FERME_TRACE From LECFIC
    # aucune suppression effectuee ou lecture trace
    If !NBOF 
         GERR = 2 : GMESSAGE = mess(88,193,1)
    Endif
    # lecture trace
Endif
Return

########################################################################
$OUVRE
Local Integer  OK
Local Integer  NBOF
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
Local Char     FORMULE1(255)
Local Char     WMESS(85)
Local Char     WMFGNUM(GLONVCR)
Local Integer  WSTA
Local Integer  WLNK


Gosub CHARG_PARAM
#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFI])  = 0 : Local File MFGITM      [MFI]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE      [MFO]  : Endif
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
If clalev ([F:TFO]) = 0 : Local File TABFOR      [TFO] : Endif 

# --- Déclaration classes ecran --- #
Local Mask MFGK    [MFGK]

Return

########################################################################
# Préparation du filtre sur la table article lancé                     #
########################################################################
$SEL_OF

Raz CRITERE
Raz CRITERE1
Raz CRITERE2

If [M:DIA]WOPFLG = 2
    CRITERE  = "MFGSTA=2&SUSFLG<>2&MFGTRKFLG<3&OPTFLG<>2"
    Gosub LOAD_CRITERE
Endif

If [M:DIA]WOFFLG = 2
    CRITERE  = "MFGSTA=1&SUSFLG<>2&MFGTRKFLG<3&OPTFLG<>2"
    Gosub LOAD_CRITERE
Endif

# fin de la première partie
CRITERE1 += ")"


CRITERE  = "MFGFCY = [M:DIA]MFGFCY"     # site de production
Gosub LOAD_CRITERE2

If [M:DIA]MFGNUMDEB <> ""               # borne début OF
    CRITERE = "MFGNUM >= [M:DIA]MFGNUMDEB"
    Gosub LOAD_CRITERE2   
Endif

If [M:DIA]MFGNUMFIN <> ""               # borne fin   OF       
    CRITERE = "MFGNUM <= [M:DIA]MFGNUMFIN"
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]ITMREFDEB <> ""               # borne début article lancé
    CRITERE = "[F:MFI]ITMREF >= [M:DIA]ITMREFDEB"               
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]ITMREFFIN <> ""               # borne fin   article lancé
    CRITERE = "[F:MFI]ITMREF <= [M:DIA]ITMREFFIN"               
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]STRDATDEB <> [0/0/0]          # borne début date 
    CRITERE = "STRDAT >= [M:DIA]STRDATDEB"                        
    Gosub LOAD_CRITERE2
Endif

If [M:DIA]STRDATFIN <> [0/0/0]          # borne fin   date
    CRITERE = "STRDAT <= [M:DIA]STRDATFIN"               
    Gosub LOAD_CRITERE2
Endif
#
Return

############################################################
$LOAD_CRITERE
If len(CRITERE1)=0 
    CRITERE1 += "("
Else 
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE  
Return

############################################################
$LOAD_CRITERE2
If len(CRITERE)+len(CRITERE1)+1 < 225
  CRITERE1 += "&"
  CRITERE1 += CRITERE  
Else
  If CRITERE2 <> ""
     CRITERE2 += "&"
  Endif
  CRITERE2 += CRITERE
Endif
Return

#---------------------------------------------------------------------#
# Traitement des ordres                                               #
#---------------------------------------------------------------------#
$TRT_OF

# FQ 67806 GA 11/2010 PE CUSSELFLT idem FUNMAUTO
Local Char     CUSFLT(255) : Raz CUSFLT
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif

Raz FORMULE1,WLNK
# analyse présence formule de sélection
If [M:DIA]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif     
Else
    Read [F:TFO]TFO0=10;[M:DIA]FORMULE
    If fstat 
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif 
    Else  
        If FORMULE1 = "" 
            FORMULE1  = [F:TFO]FORFOR                
        Else
            FORMULE1 += "&" 
            FORMULE1 += [F:TFO]FORFOR                
        Endif
    Endif
Endif

If FORMULE1 = "" : FORMULE1 = "1=1" : Endif

If CRITERE2 = "" : CRITERE2 = "1=1" : Endif


# si MFI, MFO et MFM ne sont pas utilisés dans la formule
# il n'est pas nécessaire de faire le Link mais plutôt un Filter sur MFG
# le Link se fait aussi si des bornes sur l'article ont été saisies
WLNK = instr(0,FORMULE1,"[F:MFI]") + instr(0,FORMULE1,"[F:MFO]") + instr(0,FORMULE1,"[F:MFM]") +
&      instr(0,FORMULE1,"[MFI]")   + instr(0,FORMULE1,"[MFO]")   + instr(0,FORMULE1,"[MFM]")   +
&      instr(0,CRITERE1,"[F:MFI]") + instr(0,CRITERE2,"[F:MFI]")

If WLNK
     # FQ 67806 GA 11/2010 PE CUSSELFLT idem FUNMAUTO
       Link [MFG] With [MFI]MFI2=[F:MFG]MFGNUM,[MFO]MFO0=[F:MFG]MFGNUM,[MFM]MFM0=[F:MFG]MFGNUM As [MFGX]
&                 Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(FORMULE1) & evalue(CUSFLT)
&                 Order By Key MFG0
       # boucle de lecture 
       For  [MFGX]
           If [F:MFG]MFGNUM = WMFGNUM : Goto NXT1 : Endif # ne pas traiter 2 fois le même enregistrement
           Gosub TRTSUS
       $NXT1
       Next
  Else
     # FQ 67806 GA 11/2010 PE CUSSELFLT idem FUNMAUTO
       Filter [MFG] Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(FORMULE1) & evalue(CUSFLT)
&                   Order By Key MFG0
       # boucle de lecture 
       For  [MFG]
           Gosub TRTSUS
       Next
#
       Filter [MFG]
Endif
#
Return

#-----------------------------------------------------------------------#
# Traitement suspension                                                 #
#-----------------------------------------------------------------------#
$TRTSUS
# FQ 67806 GA 11/2010 PE BEFTRTLIG idem FUNMAUTO
Local Integer GPE : GPE=1
GPOINT = "BEFTRTLIG" : Gosub ENTREE From EXEFNC
If !GPE Return Endif

Gosub VERROU
If !OK : Return : Endif
Call DEBTRANS From GLOCK
GOK = 1

Gosub MAJSUS
Gosub DEVERROU
Return

#-----------------------------------------------------------------------#
# Suspension                                                            #
#-----------------------------------------------------------------------#
$MAJSUS
#
Trbegin [MFG]

    WSTA    = [F:MFG]MFGSTA
    WMFGNUM = [F:MFG]MFGNUM
    [F:MFG]SUSFLG = 2
    [F:MFG]UPDDAT = date$
    [F:MFG]UPDUSR = GUSER
    [F:MFG]EXPNUM = [C]EXPORT
    Rewrite [MFG]
    WMESS   = mess(156,197,1)-mess(WSTA,317,1)-WMFGNUM-mess(179,190,1)+"."
    Call ECR_TRACE(WMESS,0)  From GESECRAN
    NBOF += 1

Commit
Return


#-----------------------------------------------------------------------#
# Positionnement d'un verrou sur l'entête OF                            #
#-----------------------------------------------------------------------#
$VERROU
SYMBOLE = "MFG"+[F:MFG]MFGNUM
Lock = SYMBOLE With lockwait = 0
OK = 1
If fstat 
    Call ECR_TRACE([F:MFG]MFGNUM - mess(10,100,1),1) From GESECRAN 
    OK = 0
Endif 
Return

#-----------------------------------------------------------------------#
# Suppression du verrou sur l'entête OF                                 #
#-----------------------------------------------------------------------#
$DEVERROU
Unlock=SYMBOLE
Return

######################################################################## 
$CHARG_PARAM 
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return 

###########################################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

#######################################################################
#                     ETIQUETTES                                      #
#######################################################################

########################################
Subprog AM_MFGNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]MFGNUMFIN = VALEUR : Endif
End

########################################
Subprog C_WOFFLG(VALEUR)
Variable Integer VALEUR
If [M:DIA]WOPFLG = 1 & VALEUR = 1
    GERR = 1 : GMESSAGE = mess(359,199,1)
    mkstat = 2  : # une case au moins doit être cochée !
Endif
End

########################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]ITMREFFIN = VALEUR : Endif
End


