#<AdxTL>@(#)0.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Initialisation of short description
#----------------------------------------------------------------------------------------#

# execute this treatement in all the files
Subprog GENE
Call OUVRE_TRACE("init ACTLREF") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
#Gosub MAJTAB
End

#----------------------------------------------------------------------------------------#

#----------------------------------------------------------------------------------------#
$MAJTAB
If DOSSIER=nomap
 Local File ACLASSE [ACLA]
 Local File ACLAFLD [ACLAF]
 Local File ATABZON [ATZ]
 Local File ACLALNK [ACLAK]
 Local File ASHWEXPPRO [ASWR]
 Local File ASHWFLD [ASWF]
 Local File ACONTEXT [ACTX]
 Local File ASHW [ASW]
 Local File ACLACOL [ACLAC]
 Local File ASHWCOL [ASWC]
 Local File ACONTEXT [ACTX2]
 Local File ATYPE [ATY]
 Local File ATYPERUL   [ATYR]
 Local File ATYPERPAR  [ATYRP]
 Local File ATABIND  [ATI]
 Local File ACLAPARFLD [ACLFP]
 Local File ASHWPAR [ASWP]
Else
 Local File =DOSSIER+".ACLAFLD" [ACLAF]
 Local File =DOSSIER+".ATABZON" [ATZ]
 Local File =DOSSIER+".ACLASSE" [ACLA]
 Local File =DOSSIER+".ACLALNK" [ACLAK]
 Local File =DOSSIER+".ASHWEXPPRO" [ASWR]
 Local File =DOSSIER+".ASHWFLD" [ASWF]
 Local File =DOSSIER+".ACONTEXT" [ACTX]
 Local File =DOSSIER+".ASHW" [ASW]
 Local File =DOSSIER+".ACLACOL" [ACLAC]
 Local File =DOSSIER+".ASHWCOL" [ASWC]
 Local File =DOSSIER+".ACONTEXT" [ACTX2]
 Local File =DOSSIER+".ATYPE" [ATY]
 Local File =DOSSIER+".ATYPERUL" [ATYR]
 Local File =DOSSIER+".ATYPERPAR" [ATYRP]
 Local File =DOSSIER+".ATABIND" [ATI]
 Local File =DOSSIER+".ACLAPARFLD" [ACLFP]
 Local File =DOSSIER+".ASHWPAR" [ASWP]
Endif

If  dim([ATYRP]PARCLE)>0
 Trbegin [ATY]
 For [ATY] Where [F:ATY]TYPSELSYR=2
  Read [ATYR]ATYR0 = [ATY]CODTYP;2;func APREFIXTRT.GET_PREFIX_TYP_ACTRLREF+[ATY]CODTYP;[V]CST_ANAMCTLREF
  If fstat & [F:ATY]CODCLA<>""
   Read [ACLA]ACLA0 = [F:ATY]CODCLA
   If !fstat & [F:ACLA]TYPCLA=2
    Call ECR_TRACE("--"-[ATY]CODTYP,0) From GESECRAN
    Gosub CRE_RUL_ACTLREF : # Creation de la regle
    Gosub MAJ_ACLAF : # modification propriété/parametres
    Gosub MAJ_ASWF : # modification propriété/parametres
   Endif
  Endif
 Next

 Commit
Endif

Close Local File [ACLA],[ACLAF],[ATZ],[ACLAK],[ASWR],[ASWF],[ACTX],[ASW],[ACTX2]

Return


$MAJ_ASWF
For [ASWF] Where CODTYP = [ATY]CODTYP
 Call ECR_TRACE( [ASWF]CODREP- [ASWF]CODFLD,0) From GESECRAN
 For I=1 To NBCLE
  Read [F:ASWP]ASWP0 = [ASWF]CODREP;1;2;[ASWF]CODFLD;"";1;[L]CLE(I)
  If !fstat
   Read [F:ASWP]ASWP0 = [ASWF]CODREP;1;1;[ASWF]CODFLD;"";1;[L]CLE(I)
   If fstat
    [F:ASWP]TYPKEY = 1
    Write [F:ASWP]
    If fstat
     Call ERREUR("ASHWPAR"-[ASWF]CODREP-"1 1"-[ASWF]CODFLD-[L]CLE(I),1) From DOSDIC
   Endif
  Endif
  Endif
 Next
 If HASAFILTER
  Read [F:ASWP]ASWP0 = [ASWF]CODREP;1;1;[ASWF]CODFLD;"";1; "AFILTER"
  If fstat
   [F:ASWP]ADRVAL = 2
   [F:ASWP]NUMPAR = 1
   [F:ASWP]TYPINT = [V]CST_ATYPCHAR
   [F:ASWP]TYPPAR = 1
   [F:ASWP]VALEUR = '""'
   [F:ASWP]CODREP = [ASWF]CODREP
   [F:ASWP]TYPKEY = 1
   [F:ASWP]CODFLD = [ASWF]CODFLD
   [F:ASWP]CODPAR = "AFILTER"
   [F:ASWP]TYPPAR = 1
   [F:ASWP]CODLNK = ""
   [F:ASWP]AFFLNK = 1
   Write [F:ASWP]
    If fstat
     Call ERREUR("ASHWPAR"-[ASWF]CODREP-"1 1"-[ASWF]CODFLD-"AFILTER",1) From DOSDIC
   Endif
  Endif
 Endif
Next
Return

$MAJ_ACLAF
For [ACLAF] Where CODTYP = [ATY]CODTYP
 Call ECR_TRACE( [ACLAF]CODCLA- [ACLAF]FLDCLA,0) From GESECRAN
 For I=1 To NBCLE
  Read [F:ACLFP]ACLFP0 = [F:ACLAF]CODCLA;1;2;[F:ACLAF]FLDCLA;[L]CLE(I)
  If !fstat
   Read [F:ACLFP]ACLFP0 = [F:ACLAF]CODCLA;1;1;[F:ACLAF]FLDCLA;[L]CLE(I)
   If fstat
    [F:ACLFP]TYPKEY = 1
    Write [F:ACLFP]
    If fstat
     Call ERREUR("ACLAPARFLD"-[F:ACLAF]CODCLA-"1"-[F:ACLAF]FLDCLA-[L]CLE(I),1) From DOSDIC
   Endif
  Endif
  Endif
 Next
 If HASAFILTER
  Read [F:ACLFP]ACLFP0 = [F:ACLAF]CODCLA;1;1;[F:ACLAF]FLDCLA; "AFILTER"
  If fstat
   [F:ACLFP]ADRVAL = 2
   [F:ACLFP]NUMPAR = 1
   [F:ACLFP]TYPINT = [V]CST_ATYPCHAR
   [F:ACLFP]TYPPAR = 1
   [F:ACLFP]VALEUR = '""'
   [F:ACLFP]CODCLA =[F:ACLAF]CODCLA
   [F:ACLFP]TYPKEY = 1
   [F:ACLFP]FLDCLA = [F:ACLAF]FLDCLA
   [F:ACLFP]CODPAR = "AFILTER"
   Write [F:ACLFP]
    If fstat
     Call ERREUR("ACLAPARFLD"-[F:ACLAF]CODCLA-"1"-[F:ACLAF]FLDCLA-"AFILTER",1) From DOSDIC
   Endif
  Endif
 Endif
 If HASAENABLE
  Read [F:ACLFP]ACLFP0 = [F:ACLAF]CODCLA;1;1;[F:ACLAF]FLDCLA;"AENABLE"
  If fstat
   [F:ACLFP]ADRVAL = 2
   [F:ACLFP]NUMPAR = 1
   [F:ACLFP]TYPINT = 2
   [F:ACLFP]TYPPAR = 1
   [F:ACLFP]VALEUR = '2'
   [F:ACLFP]CODCLA =[F:ACLAF]CODCLA
   [F:ACLFP]TYPKEY = 1
   [F:ACLFP]FLDCLA = [F:ACLAF]FLDCLA
   [F:ACLFP]CODPAR = "AENABLE"
   Write [F:ACLFP]
    If fstat
     Call ERREUR("ACLAPARFLD"-[F:ACLAF]CODCLA-"1"-[F:ACLAF]FLDCLA-"AENABLE",1) From DOSDIC
   Endif
  Endif
 Endif
Next
Return


$CRE_RUL_ACTLREF
Local Integer ORD
Local Char CHAINE(250)
Local Integer HASAENABLE,HASAFILTER
Local Integer NBCLE , K , L
Local Char    CLE(GLONAVA)(1..16)

Read [ACLA]ACLA0 = [F:ATY]CODCLA
If !fstat &  find([F:ACLA]TYPCLA,2)>0
 If [F:ACLA]TYPCLA=2
  Read [ATI]CODIND = [F:ACLA]TABREF;[F:ACLA]INDREF
  If !fstat
   CHAINE = [F:ATI]DESCRIPT
  Endif
 Elsif [F:ACLA]TYPCLA=5
  CHAINE = [F:ACLA]KEYINT
 Endif
 If CHAINE <>""
  Gosub L_DEFCLE From SUBACLA
 Endif
Endif

[L]ORD += 1
Raz [F:ATYR]
[F:ATYR]CODTYP = [F:ATY]CODTYP
[F:ATYR]TYPRUL = 2
[F:ATYR]TRTRUL = func APREFIXTRT.GET_PREFIX_TYP_ACTRLREF+[F:ATY]CODTYP
[F:ATYR]PRGRUL = [V]CST_ANAMCTLREF
[F:ATYR]ORDRUL= 0
Write [F:ATYR]
If fstat
 Call ERREUR("ATYPRUL"-[F:ATY]CODTYP-"~"+[V]CST_ANAMCTLREF,1) From DOSDIC
Endif
Gosub INIT_ATYRP
[ATYRP]PARCOD = "AINSTANCE"
Call NUMEROFRA("Instance",[ATYRP]PARTIT) From OBJDIV
[ATYRP]PARTYP = [V]CST_ATYPINSTANCE
[ATYRP]PARCLA = "OBJECT"
[ATYRP]PARDIM = 1
[ATYRP]PARMOD = 1
[ATYRP]PARCLE = 1
Write [ATYRP]
If fstat
 Call ERREUR("ATYPRULPAR"-[F:ATY]CODTYP-"~"+[V]CST_ANAMCTLREF+"~"+[ATYRP]PARCOD,1) From DOSDIC
Endif
Gosub INIT_ATYRP
[ATYRP]PARCOD = "APRONAME"
Call NUMEROFRA("Propriété",[ATYRP]PARTIT) From OBJDIV
[ATYRP]PARTYP = [V]CST_ATYPCHAR
[ATYRP]PARCLA = ""
[ATYRP]PARDIM = 1
[ATYRP]PARMOD = 2
[ATYRP]PARCLE = 1
Write [ATYRP]
If fstat
 Call ERREUR("ATYPRULPAR"-[F:ATY]CODTYP-"~"+[V]CST_ANAMCTLREF+"~"+[ATYRP]PARCOD,1) From DOSDIC
Endif
Gosub INIT_ATYRP
[ATYRP]PARCOD = "AVALUE"
Call NUMEROFRA("Valeur",[ATYRP]PARTIT) From OBJDIV
[ATYRP]PARTYP = [F:ATY]TYPTYP
[ATYRP]PARCLA = ""
[ATYRP]PARDIM = 1
[ATYRP]PARMOD = 1
[ATYRP]PARCLE = 1
Write [ATYRP]
If fstat
 Call ERREUR("ATYPRULPAR"-[F:ATY]CODTYP-"~"+[V]CST_ANAMCTLREF+"~"+[ATYRP]PARCOD,1) From DOSDIC
Endif

If NBCLE>0
 For I=1 To NBCLE
  Read [ACLAF]ACLAF0 = [ACLA]CODCLA;[L]CLE(I)
  If !fstat
   Gosub INIT_ATYRP
   [F:ATYRP]PARCOD = [L]CLE(I)
   [F:ATYRP]PARTIT =  [ACLAF]INTFLD
   [F:ATYRP]PARTYP = func ATY_TOOL.GET_INTERNAL_TYP_LM30([ACLAF]CODTYP)
   [F:ATYRP]PARCLA = ""
   [F:ATYRP]PARDIM  = 1
   [F:ATYRP]PARMOD = 2
   [F:ATYRP]PARCLE  =  2
   Write [ATYRP]
   If fstat
    Call ERREUR("ATYPRULPAR"-[F:ATY]CODTYP-"~"+[V]CST_ANAMCTLREF+"~"+[ATYRP]PARCOD,1) From DOSDIC
   Endif
  Endif
 Next

 Read [ACLAF]ACLAF0 = [ACLA]CODCLA;"ENAFLG"
 If !fstat
  Gosub INIT_ATYRP
  [F:ATYRP]PARCOD =  "AENABLE"
  [F:ATYRP]PARTIT =  [ACLAF]INTFLD
  [F:ATYRP]PARTYP = func ATY_TOOL.GET_INTERNAL_TYP_LM30([ACLAF]CODTYP)
  [F:ATYRP]PARCLA = ""
  [F:ATYRP]PARDIM = 1
  [F:ATYRP]PARMOD = 2
  [F:ATYRP]PARCLE =  1
  HASAENABLE = 1
  Write [ATYRP]
  If fstat
   Call ERREUR("ATYPRULPAR"-[F:ATY]CODTYP-"~"+[V]CST_ANAMCTLREF+"~"+[ATYRP]PARCOD,1) From DOSDIC
  Endif
 Endif
 Gosub INIT_ATYRP
 [F:ATYRP]PARCOD =  "AFILTER"
 Call NUMEROFRA("Filtre",[F:ATYRP]PARTIT) From OBJDIV
 [F:ATYRP]PARTYP = [V]CST_ATYPCHAR
 [F:ATYRP]PARCLA = ""
 [F:ATYRP]PARDIM = 1
 [F:ATYRP]PARMOD = 2
 [F:ATYRP]PARCLE =  1
 HASAFILTER = 1
 Write [ATYRP]
 If fstat
  Call ERREUR("ATYPRULPAR"-[F:ATY]CODTYP-"~"+[V]CST_ANAMCTLREF+"~"+[ATYRP]PARCOD,1) From DOSDIC
 Endif
Endif
Return

$INIT_ATYRP
Raz [ATYRP]
[ATYRP]CODTYP = [F:ATYR]CODTYP
[ATYRP]TYPRUL = [F:ATYR]TYPRUL
[ATYRP]TRTRUL = [F:ATYR]TRTRUL
[ATYRP]PRGRUL = [F:ATYR]PRGRUL
[ATYRP]PARORD = [L]ORD
[L]ORD += 1
Return
