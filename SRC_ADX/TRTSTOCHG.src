#<AdxTL>@(#)4.0.0.0 $Revision$

$ACTION

Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "TITRE"       : Gosub TIT_TRT
    When "OUVRE_BOITE" : Gosub OUVRE_BOITE
    When "DEBUT"       : Gosub DEBUT
    When "SETBOUT"     : Gosub SETBOUT
    When "AVANT_BOUTON":
        Case BOUT
            When "E"   : Gosub AVANT_ENR
        Endcase
    When "BOUTON" :
        Case BOUT
            When "E"   : Gosub ENR
            When "A"   : Gosub ABANDON
        Endcase
    When "END"         : Gosub ACTEND
    When "FIN"         : GCONSULT=WSVGCONSULT
    When Default :
Endcase

Return


$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return

#########################################################################
$TIT_TRT
    Call LECTEXTRA(TIT,"STKTRS","DESAXX","3",GSCSNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-GSCSNUM-":"-TIT
Return


##################################################
$OUVRE

Local Integer WSVGCONSULT
WSVGCONSULT=GCONSULT

    If !GOUVENT
        FIN = 1
        Return
    Endif
    Raz GOUVENT

    Global Integer LLIGDOC   : LLIGDOC = val(PARAM(1))             # hcb 110327
    Global Char    LABR(5)   : LABR    = PARAM(2)                  # hcb 110327

    Local Integer LLIGDOC   : LLIGDOC = val(PARAM(1))
    Local Char    LABR(5)   : LABR    = PARAM(2)
    Local Char    LMABR(10) : LMABR   = "[M:"+LABR+"]"

If evalue(LMABR+"CREFLG(LLIGDOC)")<>0
   GCONSULT=2
Endif

Return

##################################################
$OUVRE_BOITE
If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
# ouverture et lecture du dictionnaire des fenetres pour recuperer l ecran generé
If clalev([F:AWI])=0 Local File AWINDOW [AWI] : Endif
Local Char WNOMMSK(GLONAMK)
BOITE = "WQSCS"+GSCSNUM+"S"                 # hcb 50197
GBOITE = BOITE
Call NOMTRTWIN(BOITE,WINPROG) From MSKDIV


#                                                                                         # hcb X3-67989 deb
If [F:SRT]BETFCYCOD = 2
    If !clalev([F:ITFW]) : Local File ITMFACILIT [ITFW] : Endif
    [F:ITFW] = [F:ITF]
    [F:ITF]  = [F:ITFD]
Endif
#                                                                                         # hcb X3-67989 fin
Gosub FORMAT_INV From STKLIB
Gosub FORMAT_INV_CHG From STKLIB                               # hcb 110327
If [F:SRT]BETFCYCOD = 2                                                                   # hcb X3-67989
    [F:ITF]  = [F:ITFW]                                                                   # hcb X3-67989
Endif                                                                                     # hcb X3-67989
Local Integer LBETCPY
    If PARAM(3)<>PARAM(4)
        Read [FCY]FCY0 = PARAM(4)
        Read [FCY]FCY1 = [F:FCY]LEGCPY;PARAM(3)
        If fstat
            LBETCPY = 2
        Else
            LBETCPY = 1
        Endif
    Else
        LBETCPY = 1
    Endif

If [F:ITM]SERMGTCOD=2 & LBETCPY<>2
    GWSINVSER = "-"+GSINVSER
    GWSINVSERF= "-"+GSINVSERF
    GWSINTSER = ""
    GWSINTSERF= ""
Endif

Return

##################################################
$DEBUT
Local Integer I
Local Integer LRET
Local Char    W_LOT(GLONLOT)
Local Char    W_SLO(GLONSLO)

Raz [M:SCD]

    [M:SCD]STOFCY     = PARAM(3)
    [M:SCD]FCYDES     = PARAM(4)
    If [M:SCD]STOFCY<>[M:SCD]FCYDES
        Read [FCY]FCY0 = [M:SCD]FCYDES
        Read [FCY]FCY1 = [F:FCY]LEGCPY;[M:SCD]STOFCY
        If fstat
            [M:SCD]BETCPY = 2
        Else
            [M:SCD]BETCPY = 1
        Endif
    Else
        [M:SCD]BETCPY = 1
    Endif

[M:SCD]ITMREF     = evalue(LMABR+"ITMREF(LLIGDOC)")

[M:SCD]TRSTYP     = val(PARAM(5))
[M:SCD]TRSCOD     = PARAM(6)
[M:SCD]VCRTYP     = val(PARAM(7))
[M:SCD]VCRNUM     = PARAM(8)
[M:SCD]VCRLIN     = val(PARAM(9))

[M:SCD]STOFCY     = PARAM(3)
[M:SCD]FCYDES     = PARAM(4)
If [M:SCD]STOFCY<>[M:SCD]FCYDES
    Read [FCY]FCY0 = [M:SCD]FCYDES
    Read [FCY]FCY1 = [F:FCY]LEGCPY;[M:SCD]STOFCY
    If fstat
        [M:SCD]BETCPY = 2
    Else
        [M:SCD]BETCPY = 1
    Endif
Else
    [M:SCD]BETCPY = 1
Endif

[M:SCD]STA        = evalue(LMABR+"STA(LLIGDOC)")
If evalue("dim("+LMABR+"LOT)>0") & dim([M:SCD]LOT)>0
    [M:SCD]LOT        = evalue(LMABR+"LOT(LLIGDOC)")
Endif
If evalue("dim("+LMABR+"SLO)>0") & dim([M:SCD]SLO)>0
    [M:SCD]SLO        = evalue(LMABR+"SLO(LLIGDOC)")
Endif
#--- TS 106217
If evalue("dim("+LMABR+"ECCVALMAJ)>0") & dim([M:SCD]ECCVALMAJ)>0
    [M:SCD]ECCVALMAJ  = evalue(LMABR+"ECCVALMAJ(LLIGDOC)")
Endif
#---
If evalue("dim("+LMABR+"POT)>0") & dim([M:SCD]POT)>0
    [M:SCD]POT        = evalue(LMABR+"POT(LLIGDOC)")
Endif
If evalue("dim("+LMABR+"LOCTYP)>0") & dim([M:SCD]LOCTYP)>0
    [M:SCD]LOCTYP     = evalue(LMABR+"LOCTYP(LLIGDOC)")
Endif
If evalue("dim("+LMABR+"LOC)>0") & dim([M:SCD]LOC)>0
    [M:SCD]LOC        = evalue(LMABR+"LOC(LLIGDOC)")
Endif
If evalue("dim("+LMABR+"QLYCTLDEM)>0")
    [M:SCD]QLYCTLDEM  = evalue(LMABR+"QLYCTLDEM(LLIGDOC)")
Endif
If evalue("dim("+LMABR+"MVTDES)>0")
    [M:SCD]MVTDES     = evalue(LMABR+"MVTDES(LLIGDOC)")
Endif

If [F:ITM]SERMGTCOD=3 & dim([M:SCD]SERNUMDEP)>0
    [M:SCD]SERNUMDEP  = evalue(LMABR+"SERNUM(LLIGDOC)")
    [M:SCD]SERNUMFDEP = evalue(LMABR+"SERNUMF(LLIGDOC)")
Endif

If dim([M:SCD]PALNUM)>0                                  # hcb 120505 38601
   [M:SCD]PALNUM     = evalue(LMABR+"PALNUM(LLIGDOC)")
Endif                                                    # hcb 120505 38601
If dim([M:SCD]CTRNUM)>0                                  # hcb 120505 38601
   [M:SCD]CTRNUM     = evalue(LMABR+"CTRNUM(LLIGDOC)")
Endif
#                                                                                         # hcb x3-67989 deb
If evalue("dim("+LMABR+"LPNNUM)>0") & dim([M:SCD]LPNNUM)>0
    [M:SCD]LPNNUM     = evalue(LMABR+"LPNNUM(LLIGDOC)")
Endif

# si la transaction ne permet pas la modification de l'emplacement la selection sur LPNNUMDES
# affiche les Contenants ayant le meme emplacement ou ceux n ayant pas d'emplacement
Raz [M:SCD]LOCSELLPN
If dim([M:SCD]LPNNUM)>0 & [M:SCD]LPNNUM <> "" & [F:SRT]CHGEMPCOD <> 2
   [M:SCD]LOCSELLPN = [M:SCD]LOC
Endif
[M:SCD]LOTACT = [M:SCS1]LOTACT
#                                                                                         # hcb x3-67989 fin

                                                 # hcb 120505 38601
[M:SCD]OWNER      = evalue(LMABR+"OWNER(LLIGDOC)")
[M:SCD]QTYPCU     = evalue(LMABR+"QTYPCU(LLIGDOC)")
[M:SCD]PCU        = evalue(LMABR+"PCU(LLIGDOC)")
[M:SCD]PCUSTUCOE  = evalue(LMABR+"PCUSTUCOE(LLIGDOC)")
[M:SCD]QTYSTU     = evalue(LMABR+"QTYSTUDES(LLIGDOC)")
[M:SCD]STU        = evalue(LMABR+"STU(LLIGDOC)")

[M:SCD]WSTOCOU1   = evalue(LMABR+"WSTOCOU(LLIGDOC)")                 # hcb 110327

[M:SCD]CCECODS        = [F:DTR]STOCCECOD
If [M:SCD]CCECODS=0
    [M:SCD]CCECODS        = 3
Endif

[M:SCD]COEUCUS = "1"-[M:SCD]PCU-"="-num$([M:SCD]PCUSTUCOE)-[M:SCD]STU
If dim([M:SCD]LOT)>0
  W_LOT=[M:SCD]LOT
Endif
If dim([M:SCD]SLO)>0
  W_SLO=[M:SCD]SLO
Endif
Call POSTABLE([M:SCD]FCYDES, [M:SCD]ITMREF, W_LOT, W_SLO, LRET) From SUBSCSB
If LRET
    FIN = 1
    Return
Endif

If evalue(LMABR+"CREFLG(LLIGDOC)")=0
    Gosub LOAD_FROM_SGW From TRTSTOCHGB
Else
    Gosub LOAD_FROM_STJ From TRTSTOCHGB
Endif

#---- Si demande d'analyse alors on interdit le changement de statut ----#
If [M:SCD]QLYCTLDEM<>""
    Diszo [M:SCD]STADES
Endif

#---- Si dépôt saisi sur la ligne de changement de stock
If evalue("dim("+LMABR+"WRHDES)>0") & evalue(LMABR+"WRHDES(LLIGDOC)")<>""
    Diszo [M:SCD]WRHDES
Endif
If [F:SRT]CHGPCUCOD = 2 & [F:ITM]SERMGTCOD = 4                  # hcb X3-90572
   Diszo [M:SCD]PCUDES                                          # hcb X3-90572
Endif                                                           # hcb X3-90572

Gosub MAJ_PECQTY From TRTSTOCHGB
Affzo [M:SCD]

# Chargement sous-statuts autorisés
Case evalue(LMABR+"BETFCYCOD")
 When 1 : GSCSAUZSST = [F:SRU]AUZSST
 When 2 : GSCSAUZSST = [F:SRU]AUZSST : # Trf inter-sites
 When 3 : GSCSAUZSST = "A*,Q*,R*"    : # Inactif
 When 4 : GSCSAUZSST = "A*,Q*,R*"    : # Trf sous-traitant --> pas de restriction
#MAE, RET_SSTRT
 When 5 : GSCSAUZSST = "A*,Q*,R*"    : # Retour sous-traitant --> pas de restriction

Endcase

Return

#############################################################
$SETBOUT
If [M:SCD]CCECODS=3
    Call VIREBOUT(CHMEN,"ab") From GOBJET
Endif
If evalue(LMABR+"CREFLG(LLIGDOC)")<>0
    Call VIREBOUT(CHMEN,"EA") From GOBJET
    Gosub SET_BOUT_SPE From GSAISIE
    GSTADEF = GSTAESC
Endif
Return

#############################################################
$AVANT_ENR
FOK = 1
# Contrôle que l'enregistrement peut se faire
Call AVANT_ENRCHG  From TRTSTOCHGB
If mkstat
    FOK = 0
    Return
Endif
#                                                                       # hcb 110327 deb
Raz GERR
If [M:SCD]NBLIG>1 & [F:ITM]SERMGTCOD = 4
   # Vérification que les plages de no série sont bien croissantes
   Sorta [M:SCD]NBLIG [M:SCD]NBLIG Order By [M:SCD]SERNUM([S]indice)
   For J=1 To [M:SCD]NBLIG-1
      If [M:SCD]SERNUM(J) <= [M:SCD]SERNUMF(J-1)
         GMESSAGE = mess(464,199,1)                # numeros de série incorrectes des numeros sont présents plusieurs fois
         GERR=1
         FOK=0
         Break
      Endif
   Next J
Endif
If GERR = 1
   Return
Endif
#                                                                       # hcb 110327 fin
Return

##################################################
$ENR

Call ENR_CHG(LABR,LLIGDOC)  From TRTSTOCHGB

FIN=1

Return


##################################################
$ABANDON
    Gosub ANNULE
    Raz [M:SCD]
    Gosub DEBUT
Return

##########################################################################
$ANNULE
Local Integer  I
Local Integer  LRET
Local Shortint WRET
If dim([M:SCD]LOCDES)>0
    For I=0 To [M:SCD]NBLIG-1
        Call STKDELRES([M:SCD]WLOCSEQ(I), [M:SCD]FCYDES, [M:SCD]LOCDES(I), LRET) From STKLOC
    Next

    I=find([M:SCD]WSTOSEQ,[M:SGW]WSTOSEQ(0..[M:SGW]NBLIG-1))-1
    While I>0 & I<dim([M:SGW]WSTOSEQ) & [M:SGW]WSTOSEQ(I)=[M:SCD]WSTOSEQ
        If [M:SGW]WLOCDES(I) = [M:SCD]LOC
            Call STKVALEMP([M:SGW]WLOCSEQ(I),
&                      [M:SCD]TRSTYP,[M:SCD]TRSCOD,
&                      [M:SCD]FCYDES,[M:SCD]ITMREF,
&                      [M:SGW]WPCUDES(I),
&                      [M:SCD]QTYPCU,[M:SGW]WQTYPCUDES(I),
&                      [M:SGW]WSTADES(I),[M:SGW]WLOCTYPDES(I),
&                      [M:SGW]WLOCDES(I),"",WRET,GBIDD1,"","") From STKLOC
        Else
            Call STKCTREMP([M:SGW]WLOCSEQ(I),
&                      [M:SCD]TRSTYP,[M:SCD]TRSCOD,
&                      [M:SCD]FCYDES,[M:SCD]ITMREF,
&                      [M:SGW]WPCUDES(I),
&                      [M:SGW]WQTYPCUDES(I),
&                      [M:SGW]WSTADES(I),[M:SGW]WLOCTYPDES(I),
&                      [M:SGW]WLOCDES(I),"",1,WRET,GBIDD1,"","",[M:SGW]WWRHDES(I)) From STKLOC
        Endif

        I += 1
    Wend
Endif
Return

##########################################################################
$ACTEND
    Gosub ANNULE
    # Fait perdre le focus au tableau
    # => Oblige à repasser en IB_NBLIG dans le document => GOUVENT initialiser
    mkstat=99
Return

##########################################################################
Subprog AVANT_NBLIG
Local Integer LRET
# si l article est géré en Contenant l'emplacement ne px pas etre modifié ds le détail
#                                                                                         # hcb X3-67989 deb
If dim([M:SCD]LPNNUM)>0 & [M:SCD]LPNNUM <> "" & dim([M:SCD]LOCTYPDES)>0
   Diszo [M:SCD]LOCTYPDES(nolign-1)
   Diszo [M:SCD]LOCDES(nolign-1)
Endif
#                                                                                         # hcb X3-67989 fin

    If [M:SCD]QTYSTUDES(nolign-1)=0
        # Ce n'est pas censé arriver puisqu'on interdit l'insertion
        # et la suppression sur la première ligne
        If nolign-1=0
            [M:SCD]PCUDES(nolign-1) = [M:SCD]PCU
            [M:SCD]COEDES(nolign-1) = [M:SCD]PCUSTUCOE
            [M:SCD]STADES(nolign-1) = [M:SCD]STA
            If dim([M:SCD]PALNUMDES)>0
                [M:SCD]PALNUMDES(nolign-1) = [M:SCD]PALNUM
            Endif
            If dim([M:SCD]CTRNUMDES)>0
                [M:SCD]CTRNUMDES(nolign-1) = [M:SCD]CTRNUM
            Endif
        Elsif !find([M:SCD]PCUDES(nolign-2),[M:SCD]PCU,[M:SCD]STU)
            [M:SCD]PCUDES(nolign-1) = [M:SCD]STU
            [M:SCD]COEDES(nolign-1) = 1
            [M:SCD]STADES(nolign-1) = [M:SCD]STADES(nolign-2)
            If dim([M:SCD]PALNUMDES)>0
                [M:SCD]PALNUMDES(nolign-1) = [M:SCD]PALNUMDES(nolign-2)
            Endif
            If dim([M:SCD]CTRNUMDES)>0
                [M:SCD]CTRNUMDES(nolign-1) = [M:SCD]CTRNUMDES(nolign-2)
            Endif
        Else
            [M:SCD]PCUDES(nolign-1) = [M:SCD]PCUDES(nolign-2)
            [M:SCD]COEDES(nolign-1) = [M:SCD]COEDES(nolign-2)
            [M:SCD]STADES(nolign-1) = [M:SCD]STADES(nolign-2)
            If dim([M:SCD]PALNUMDES)>0
                [M:SCD]PALNUMDES(nolign-1) = [M:SCD]PALNUMDES(nolign-2)
            Endif
            If dim([M:SCD]CTRNUMDES)>0
                [M:SCD]CTRNUMDES(nolign-1) = [M:SCD]CTRNUMDES(nolign-2)
            Endif
        Endif
        [M:SCD]QTYPCUDES(nolign-1) = 0

        If nolign>1 & dim([M:SCD]SERNUMF)>0 & [M:SCD]SERNUMF(nolign-2)<>""
            If [M:SCD]SERNUMFDEP <> [M:SCD]SERNUMF(nolign-2)
                Call PLUS_UN([M:SCD]SERNUMF(nolign-2),[M:SCD]SERNUM(nolign-1),LRET) From STKLIB
            Endif
        Endif
        If [F:ITFD]LOCMGTCOD=2
            Call STKWLOCSEQ("SCD", nolign-1, LRET) From STKECR
            If [M:SCD]FCYDES=[M:SCD]STOFCY & nolign>1
                [M:SCD]LOCTYPDES(nolign-1) = [M:SCD]LOCTYPDES(nolign-2)
                [M:SCD]LOCDES(nolign-1)    = [M:SCD]LOCDES(nolign-2)
                If dim([M:SCD]WRHDES)>0
                  [M:SCD]WRHDES(nolign-1)  = [M:SCD]WRHDES(nolign-2)
                Endif
            Endif
        Endif
        If left$([M:SCD]STADES(nolign-1),1)="Q"
            [M:SCD]QLYCTLFLG(nolign-1) = [F:SRU]QLYCTLFLG
        Endif
    Endif
#                                                                   # hcb X3-67989 fin

    If dim([M:SCD]LPNNUM)>0
       If [M:SCD]LPNNUM<>""
          If dim([M:SCD]WRHDES)> 0
             Diszo [M:SCD]WRHDES(nolign-1)
          Endif
          Diszo [M:SCD]LOCDES   (nolign-1)
          Diszo [M:SCD]LOCTYPDES(nolign-1)
       Endif
    Endif
#                                                                   # hcb X3-67989 fin

End

##########################################################################
Subprog C_NBLIG

Local Integer I
Local Integer LRET

If dim([M:SCD]SERNUMDEP)>0 & [M:SCD]SERNUMDEP<>"" & nolign=1 & find(status,65,68,83,73)
    mkstat=2
    GMESSAGE=mess(33,184,1)+":\"+[M:SCD]SERNUMDEP    # Ce n° de série doit être présent
    End
Endif

Case status
    When 73, 82:
        If [M:SCD]PECQTYSTU=[M:SCD]QTYSTU
            mkstat=2
            GMESSAGE=mess(34,184,1)    # Plus de quantité à traiter
        Elsif [M:SGW]NBLIG+[M:SCD]NBLIG+1>=dim([M:SGW]WSTOSEQ)
            mkstat=2
            GMESSAGE=mess(36,184,1)
        Endif

    # annulation d une ligne
    When 65 :
        If dim([M:SCD]LOCDES(nolign-1))>0
            Call STKDELRES([M:SCD]WLOCSEQ(nolign-1), [M:SCD]FCYDES, [M:SCD]LOCDES(nolign-1), LRET) From STKLOC
        Endif
        [M:SCD]QTYSTUDES(nolign-1) = 0
        Gosub MAJ_PECQTY From TRTSTOCHGB


    # annulation d'un groupe de lignes
    When 68,83 :
        If dim([M:SCD]LOCDES)>0
            For I=nolign-1 To nolign1-1                     # hcb 62165
                Call STKDELRES([M:SCD]WLOCSEQ(I), [M:SCD]FCYDES, [M:SCD]LOCDES(I), LRET) From STKLOC
                [M:SCD]QTYSTUDES(I) = 0
            Next
        Endif
        Gosub MAJ_PECQTY From TRTSTOCHGB
Endcase

End

##########################################################################
Subprog APRES_NBLIG

Local Integer     LRET
Local Shortint    WRET
Local Char        LSLO(GLONSLO)
Local Decimal     WOVF
Local Libelle LNOTPCU
Local Libelle LNOTCOE
Local Libelle LNOTSTA
Local Libelle LNOTLOC
Local Libelle LNOTLOF
Local Libelle LNOTLOT
Local Libelle LNOTSLO
Local Libelle LNOTSER
Local Libelle LNOTPAL
Local Libelle LNOTCTR
Local Integer LDUP
Local Integer I
Local Char    WWRH(GLONWRH)

GOUVENT = 0

Gosub SET_NOL

If [M:SCD]WLOCSEQ(NOL)=0 | [M:SCD]WLOCSEQ(NOL)=100000
    Call STKDELRES(100000,"","",LRET) From STKLOC
    [M:SCD]WLOCSEQ(NOL)=0
Endif

#                                                                 # hcb 110327 deb
If [F:ITM]SERMGTCOD = 4
   Local Integer LSEQIND
   Call WSTOSEQIND ("SCD",NOL+1, LSEQIND, LRET) From SUBSCSB
   If LRET
      End
   Endif
   [M:SCD]WSTOSEQIND(NOL) = LSEQIND
Endif
#                                                                 # hcb 110327 end

If dim([M:SCD]WRHDES) > 0
    WWRH=[M:SCD]WRHDES(NOL)
Else
    WWRH=""
Endif

If adxgtb=1 | find(status,65,68,83)
    If [F:ITF]LOCMGTCOD=2 & dim([M:SCD]LOC) & [M:SCD]WLOCSEQ(NOL)<>100000
        # Supprimer les réservations d'emplacements afin de montrer qu'on veut une réservation définitive
        If [M:SGW]WLOCSEQCUR>100000 & [M:SGW]WLOCSEQCUR<>99999999
          [M:SGW]WLOCSEQCUR -= 100000
        Endif
        If [M:SGW]WLOCSEQCUR<>0
            Call STKDELRES([M:SGW]WLOCSEQCUR, [M:SCD]FCYDES, "", LRET) From STKLOC
            [M:SGW]WLOCSEQCUR = 99999999
        Endif
        If [M:SCD]WLOCSEQ(NOL)>0
            # Recréer les réservations
            Call STKCTREMP([M:SCD]WLOCSEQ(NOL),
&                          [M:SCD]TRSTYP,
&                          [M:SCD]TRSCOD,
&                          [M:SCD]FCYDES,
&                          [M:SCD]ITMREF,
&                          [M:SCD]PCUDES(NOL),
&                          [M:SCD]QTYPCUDES(NOL),
&                          [M:SCD]STADES(NOL),
&                          [M:SCD]LOCTYPDES(NOL),
&                          [M:SCD]LOCDES(NOL),
&                          "",0,WRET,WOVF,"","",WWRH) From STKLOC
        Endif
    Endif
    Gosub MAJ_PECQTY From TRTSTOCHGB
    End
Endif

# Supprimer les réservations d'emplacements afin de montrer qu'on veut une réservation définitive
If [M:SCD]WLOCSEQ(NOL)>100000
    [M:SCD]WLOCSEQ(NOL) -= 100000
Endif
If dim([M:SCD]LOCDES(NOL))>0 & [F:ITFD]LOCMGTCOD > 1    # hcb 36313
    Call STKDELRES([M:SCD]WLOCSEQ(NOL), [M:SCD]FCYDES, [M:SCD]LOCDES(NOL), LRET) From STKLOC
    If !LRET
        Call STKCTREMP([M:SCD]WLOCSEQ(NOL),  [M:SCD]TRSTYP, [M:SCD]TRSCOD, [M:SCD]FCYDES,
&                      [M:SCD]ITMREF, [M:SCD]PCUDES(NOL), [M:SCD]QTYPCUDES(NOL), [M:SCD]STADES(NOL),
&                      [M:SCD]LOCTYPDES(NOL), [M:SCD]LOCDES(NOL), "", 1, mkstat, WOVF, "", "",WWRH) From STKLOC
        [M:SGW]WLOCSEQCUR = 99999999
    Endif
Endif

End

##########################################################################
Subprog C_PCUDES(VALEUR)
Variable Char    VALEUR()
End

##########################################################################
Subprog AM_PCUDES(VALEUR)
Variable Char    VALEUR()
    Local Char LUSCAV
    Local Char LFMT
    Local Integer LMODIF
    Local Decimal LCOE

    Gosub SET_NOL
    Call CTLUOM ([M:SCD]ITMREF,3,"", VALEUR,LCOE, LUSCAV, LFMT, LMODIF) From STKACT
    If LUSCAV <> "S"
       If LUSCAV <> "C"
          mkstat = 2
          End
       Endif
    Endif

    If LMODIF=2
        Actzo [M:SCD]COEDES(NOL)
    Else
        Diszo [M:SCD]COEDES(NOL)
    Endif
    If VALEUR<>[M:SCD]PCUDES(NOL)
        [M:SCD]COEDES(NOL) = LCOE
        [M:SCD]QTYPCUDES(NOL) =  [M:SCD]QTYSTUDES(NOL)/[M:SCD]COEDES(NOL)
        Call QTEARR([M:SCD]QTYPCUDES(NOL),VALEUR) From TRTDIV
    Else
        [M:SCD]QTYSTUDES(NOL) = [M:SCD]QTYPCUDES(NOL) * [M:SCD]COEDES(NOL)
    Endif
    Affzo [M:SCD]COEDES(NOL),QTYSTUDES(NOL),QTYPCUDES(NOL)
    Gosub MAJ_PECQTY From TRTSTOCHGB

End

##########################################################################
Subprog AS_QTYPCUDES(VALEUR)
Variable Decimal VALEUR

Gosub SET_NOL

If VALEUR = 0
   If [M:SCD]PECQTYSTU < [M:SCD]QTYSTU
      If [M:SCD]PCUDES(NOL) = [M:SCD]STU
         VALEUR =  ([M:SCD]QTYSTU-[M:SCD]PECQTYSTU)
      Else
         VALEUR =  ([M:SCD]QTYSTU-[M:SCD]PECQTYSTU)/[M:SCD]COEDES(NOL)
         Call QTEARR(VALEUR,[M:SCD]PCUDES(NOL)) From TRTDIV
      Endif
   Endif
Else
    Call QTEARR(VALEUR,[M:SCD]PCUDES(NOL)) From TRTDIV
Endif
#--- Alimentation de la quantité en US : QTYstu
[M:SCD]QTYSTUDES(NOL) = (VALEUR * [M:SCD]COEDES(NOL))
Call QTEARR([M:SCD]QTYSTUDES(NOL),[M:SCD]STU) From TRTDIV

End


##########################################################################
Subprog C_QTYPCUDES(VALEUR)
Variable Decimal VALEUR
    Local Char LUSCAV
    Local Char LFMT
    Local Integer LMODIF

    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif             # hcb 50197
    If [F:SRT]SRTTYP<>3 | [F:SRT]SRTNUM<>GSCSNUM                    # hcb 50197
       Read [SRT]SRT0=3;GSCSNUM : If fstat  Raz [F:SRT] : Endif
    Endif

    Gosub SET_NOL

    If VALEUR = 0
        mkstat = 2
        End
    Endif

    If [F:SRT]UOMSAIFLG=2
        Call CTLUOM([M:SCD]ITMREF,3,"", [M:SCD]PCUDES(NOL),[M:SCD]COEDES(NOL), LUSCAV, LFMT, LMODIF) From STKACT
        If LMODIF<>2
            Call CTRNEWQTY( NOL, VALEUR, [M:SCD]COEDES(NOL) )  From TRTSTOCHGB
            If mkstat=2
                End
            Endif
            Diszo [M:SCD]COEDES(NOL)
        Else
            Actzo [M:SCD]COEDES(NOL)
        Endif
    Else
        Call CTRNEWQTY( NOL, VALEUR, [M:SCD]COEDES(NOL) )  From TRTSTOCHGB
        If mkstat=2
            End
        Endif
    Endif
    [M:SCD]QTYSTUDES(NOL) = VALEUR * [M:SCD]COEDES(NOL)
    Affzo [M:SCD]QTYSTUDES(NOL)

    Gosub MAJ_PECQTY From TRTSTOCHGB

End

##########################################################################
Subprog AM_COEDES(VALEUR)
Variable Decimal VALEUR
    Gosub SET_NOL

    If VALEUR = 0
        mkstat=2
    Endif

    Call CTRNEWQTY( NOL, [M:SCD]QTYPCUDES, VALEUR ) From TRTSTOCHGB
    If mkstat=2
        End
    Endif
    [M:SCD]QTYSTUDES(NOL) = [M:SCD]QTYPCUDES(NOL) * VALEUR
    Affzo QTYSTUDES(NOL)
    Gosub MAJ_PECQTY From TRTSTOCHGB
End

##########################################################################
Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()
If [F:ITM]SERMGTCOD=1
   End
Endif

Local Char LSERF(GLONSER)

    If [F:ITM]SERMGTCOD=3
        Call CTRSERNUM( nolign-1, VALEUR, LSERF ) From TRTSTOCHGB
        If GMESSAGE<>""
            mkstat = 2
        Else
            If LSERF>[M:SCD]SERNUMFDEP
                mkstat=2
            Else
                [M:SCD]SERNUMF(nolign-1) = LSERF
                Affzo [M:SCD]SERNUMF(nolign-1)
            Endif
        Endif
    Else
        If [F:ITM]SERMGTCOD=2 & VALEUR<>""    # hcb 92476
           Call STKCTRSER( VALEUR, [M:SCD]ITMREF, nolign-1, [M:SCD]NBLIG, [M:SCD]WSTOSEQ,
&                          [M:SCD]TRSTYP, [M:SCD]VCRTYP, [M:SCD]VCRNUM, [M:SCD]VCRLIN, 0, "", 0, 0, 1, "" ) From STKACT
        Endif                                 # hcb 92476
    Endif
End

##########################################################################
Subprog C_STADES(VALEUR)
Variable Char    VALEUR()
If VALEUR=""                        # hcb 28638
   GMESSAGE = mess(10,123,1)        # hcb 28638
   mkstat = 2                       # hcb 28638
   End                              # hcb 28638
Endif                               # hcb 28638
If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif             # hcb 50197
If [F:SRT]SRTTYP<>3 | [F:SRT]SRTNUM<>GSCSNUM                    # hcb 50197
   Read [SRT]SRT0=3;GSCSNUM : If fstat  Raz [F:SRT] : Endif
Endif


If dim([M:SCS1]BETFCYCOD)>0 &[M:SCS1]BETFCYCOD=1
   # Si changement de stock sans chgt d'emplacement, on contrôle
   # les statuts autorisés par l'emplacement
   #--- Bug 71116
   #If [F:SRT]CHGEMPCOD<>2 & [F:ITF]LOCMGTCOD=2
   If [F:SRT]CHGEMPCOD<>2 & [F:ITF]LOCMGTCOD=2 & VALEUR<>[M:SCS1]STADES(nolign-1)
   #---
      If [F:STC]LOC<>[M:SCD]LOCDES(nolign-1)
         Read [STC]STC0=[M:SCS1]STOFCY;[M:SCD]LOCDES(nolign-1)
         If fstat End Endif
      Endif
      Call STKCTRSTA(VALEUR,[F:STC]AUZSST,1,3,0,mkstat) From STKACT
   Endif
Endif

End

##########################################################################
Subprog AM_STADES(VALEUR)
Variable Char    VALEUR()
If left$(VALEUR,1)="Q"
    [M:SCD]QLYCTLFLG(nolign-1) = [F:SRU]QLYCTLFLG
Endif
End

#--- Bug 60553
Subprog AM_WRHDES(VALEUR)
Variable Char    VALEUR()
If [M:SCD]WRHDES(nolign-1)<>""
   Raz [M:SCD]LOCDES(nolign-1)
Endif
End

#                                                                   # hcb 110327 deb
Subprog IB_NBLIG
# No séries concernés
GBOUT1 = mess(655,199,1)
# pas de saisie des series concernés si :
# saisie détail impossible
# l article ne gère pas les series globales
# pas de STOCOU
# pas de quantité qualifiée
If [F:ITM]SERMGTCOD <> 4 | [M:SCD]WSTOCOU1 = 0 | [M:SCD]QTYSTUDES (nolign-1)= 0
   Raz GBOUT1
Endif
End

Subprog B1_NBLIG
Local Integer LRET
Local Integer LSEQ
Local Decimal LQTYSTU
Local Integer I
Raz I
GOUVCHGS = 2
Call DELSTOCHGW(LABR, [M:SCD]STOFCY, LLIGDOC, LLIGDOC, 0, LRET) From SUBSCSB
LSEQ = [M:SCD]WSTOSEQ
Call FILLCHGW("SCD", I, [M:SCD]NBLIG-I, LSEQ, [M:SCD]STOFCY, LRET, LQTYSTU) From SUBSCSB
End

Subprog AM_QTYPCUDES(VALEUR)
Variable Decimal VALEUR
If [F:ITM]SERMGTCOD = 4 & [M:SCD]QTYPCUDES(nolign-1) <> VALEUR
   Raz   [M:SCD]SERNUM (nolign-1)
   Raz   [M:SCD]SERNUMF(nolign-1)
   Affzo [M:SCD]SERNUM (nolign-1)
   Affzo [M:SCD]SERNUMF(nolign-1)
Endif
End
#                                                                   # hcb 110327 end

