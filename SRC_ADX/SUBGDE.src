#<AdxTL>@(#)5.0.0.0 $Revision$
###################################################################################
# Gestion des Transactions de saisie
###################################################################################
Call OBJET("GDE",GBIDC1,"") From GOBJET
End

# Issue X3-70924 - 2018-01-15 - MDJ : Replace the call to VALID from VALMSK by a call to VALIDFULL from VALMSK

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "SETBOUT"      : Gosub SETBOUT
 When "LIENS"        : Gosub LIENS
 When "RAZCRE"       : Gosub RAZCRE
 When "INICRE"       : Gosub INICRE
 When "INIMOD"       : Gosub INIMOD
 When "CREATION"     : Gosub CREATION
 When "MODIF"        : Gosub MODIF
 When "EXEBOUT"      : Gosub EXEBOUT
 When "AP_CHANGE"    : Gosub AP_CHANGE
 When "ANNULE"       : Gosub ANNULE
 When "BS_DEFVAL"    : Gosub BS_DEFVAL
 When "FERME"        : Gosub FERME
Endcase
Return

###################################################################################
$OUVRE
Local Integer NLED, NLEDSUI, NBDIE
Local Integer AUT, NBLED, TYPREF
If !clalev([F:AMK])  : Local File AMSK       [AMK]  : Endif
If !clalev([F:AMZ])  : Local File AMSKZON    [AMZ]  : Endif
If !clalev([F:GDD])  : Local File GDIAENTRYD [GDD]  : Endif
If !clalev([F:DIE])  : Local File GDIE       [DIE]  : Endif

##############################################################################
# permet de vérifier que l'abréviation HAE correspond bien à la table GACCENTRY
# si ce n'est pas le cas, on ferme la table HAE, et on ouvre la table GACCENTRY avec l'abréviation HAE
##############################################################################
Local Integer N
N = find("HAE", [S]fileabre)
If !clalev([F:HAE])
 Local File GACCENTRY  [HAE]
Else
 If right$([S]filename(N+1), 1+len([S]filename(N+1))-len("GACCENTRY")) <> "GACCENTRY"
  Close Local File [HAE]
  Local File GACCENTRY  [HAE]
 Endif
Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

###################################################################################
$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET #DdM52888
Return

###################################################################################
$LIENS
GCURLEG = [F:GDE]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Gosub DEGRISE
Gosub CHARGE_CHAMP
Gosub CHARGE_TYPLED
Gosub LECTURE
Gosub GRISE
Call LECTEXTRA([M:GDE0]DESTRA,"GDIAENTRY","DESTRA",[M:GDE0]DIA,"") From ATEXTRA
Call LECTEXTRA([M:GDE0]SHOTRA,"GDIAENTRY","SHOTRA",[M:GDE0]DIA,"") From ATEXTRA
Return

###################################################################################
$INICRE
If func AFNC.ACTIV("LEG")=0 : [F:GDE]LEG = GDOSLEG(1) : Endif
If dim([F:GDE]DES)>0
 [F:GDE]DES = [M:GDE0]DESTRA
Endif
Return

$INIMOD
Gosub INICRE
Return

###################################################################################
$RAZCRE
Gosub DEGRISE
Gosub CHARGE_CHAMP
Gosub AFF
Return
###################################################################################


##############
$CHARGE_CHAMP
Gosub EFF

### Onglet en tête
I = -1

## Bloc A
I += 1 : [M:GDE2]MSK(I)="A" : [M:GDE2]FLD(I) = "FCY"    : [M:GDE2]FLDDES(I) = mess(12,105,1) : # Site
I += 1 : [M:GDE2]MSK(I)="A" : [M:GDE2]FLD(I) = "TYP"    : [M:GDE2]FLDDES(I) = mess(10,105,1) : # Type de pièce
I += 1 : [M:GDE2]MSK(I)="A" : [M:GDE2]FLD(I) = "NUM"    : [M:GDE2]FLDDES(I) = mess(11,105,1) : # Numéro de pièce
I += 1 : [M:GDE2]MSK(I)="A" : [M:GDE2]FLD(I) = "ACCDAT" : [M:GDE2]FLDDES(I) = mess(14,105,1) : # Date comptable
If [M:GDE0]FLGLOT=2
 I += 1 : [M:GDE2]MSK(I)="A" : [M:GDE2]FLD(I) = "DIG" : [M:GDE2]FLDDES(I) = mess(33,142,1) : # Transaction de saisie
Endif

## Bloc B
I += 1 : [M:GDE2]MSK(I)="B" : [M:GDE2]FLD(I) = "JOU" : [M:GDE2]FLDDES(I) = mess(13,105,1) : # Journal
I += 1 : [M:GDE2]MSK(I)="B" : [M:GDE2]FLD(I) = "CAT" : [M:GDE2]FLDDES(I) = mess(8,105,1)  : # Catégorie
I += 1 : [M:GDE2]MSK(I)="B" : [M:GDE2]FLD(I) = "STA" : [M:GDE2]FLDDES(I) = mess(9,105,1)  : # Etat
I += 1 : [M:GDE2]MSK(I)="B" : [M:GDE2]FLD(I) = "DIA" : [M:GDE2]FLDDES(I) = mess(102,105,1): # Code Transaction

# Bloc C
I += 1 : [M:GDE2]MSK(I)="C" : [M:GDE2]FLD(I) = "LIB" : [M:GDE2]FLDDES(I) = mess(16,105,1) : # Libellé par défaut
I += 1 : [M:GDE2]MSK(I)="C" : [M:GDE2]FLD(I) = "BOL" : [M:GDE2]FLDDES(I) = mess(98,105,1) : # Chrono Bollato

# Bloc D
I += 1 : [M:GDE2]MSK(I)="D" : [M:GDE2]FLD(I) = "DENT" : [M:GDE2]FLDDES(I) = mess(53,105,1) : # Date de saisie
I += 1 : [M:GDE2]MSK(I)="D" : [M:GDE2]FLD(I) = "DDUD" : [M:GDE2]FLDDES(I) = mess(15,105,1) : # Date d'échéance
I += 1 : [M:GDE2]MSK(I)="D" : [M:GDE2]FLD(I) = "DVAL" : [M:GDE2]FLDDES(I) = mess(54,105,1) : # Date de valeur
If func AFNC.ACTIV("KIT")
 I += 1 : [M:GDE2]MSK(I)="D" : [M:GDE2]FLD(I) = "DBAN"  : [M:GDE2]FLDDES(I) = mess(99,105,1) : # Date de banque
Endif

# Bloc E
I += 1 : [M:GDE2]MSK(I)="E" : [M:GDE2]FLD(I) = "TRAT"  : [M:GDE2]FLDDES(I) = mess(21,105,1)  : # Type de cours
I += 1 : [M:GDE2]MSK(I)="E" : [M:GDE2]FLD(I) = "DRAT"  : [M:GDE2]FLDDES(I) = mess(164,105,1) : # Date cours
I += 1 : [M:GDE2]MSK(I)="E" : [M:GDE2]FLD(I) = "CUR"   : [M:GDE2]FLDDES(I) = mess(18,105,1)  : # Devise
If [M:GDE1]NBRRAT>0
 For J=1 To [M:GDE1]NBRRAT
  I += 1 : [M:GDE2]MSK(I)="E" : [M:GDE2]FLD(I) = "MLT"+num$(J) : [M:GDE2]FLDDES(I) = mess(168,105,1)-num$(J) : # Cours multiplicateur
  I += 1 : [M:GDE2]MSK(I)="E" : [M:GDE2]FLD(I) = "DIV"+num$(J) : [M:GDE2]FLDDES(I) = mess(169,105,1)-num$(J) : # Cours diviseur
 Next
Endif

# Bloc F
# Issue X3-52045 - 2017-08-07 by FHA : field ORIGIN & ORICOD added
I += 1 : [M:GDE2]MSK(I)="F" : [M:GDE2]FLD(I) = "ORI"   : [M:GDE2]FLDDES(I) = mess(128,124,1)                           :# Origine
I += 1 : [M:GDE2]MSK(I)="F" : [M:GDE2]FLD(I) = "ORIC"  : [M:GDE2]FLDDES(I) = mess(128,124,1)-tolower(mess(193,124,1))  :# Origine Transaction
# End issue X3-52045
I += 1 : [M:GDE2]MSK(I)="F" : [M:GDE2]FLD(I) = "DOC"   : [M:GDE2]FLDDES(I) = mess(22,105,1) : # Document d'origine
I += 1 : [M:GDE2]MSK(I)="F" : [M:GDE2]FLD(I) = "DDOC"  : [M:GDE2]FLDDES(I) = mess(23,105,1) : # Date d'origine
I += 1 : [M:GDE2]MSK(I)="F" : [M:GDE2]FLD(I) = "MOD"   : [M:GDE2]FLDDES(I) = mess(58,105,1) : # Module
If func AFNC.ACTIV("PJM") & [M:GDE0]FLGLOT<>2
 I += 1 : [M:GDE2]MSK(I)="F" : [M:GDE2]FLD(I) = "PJT"  : [M:GDE2]FLDDES(I) = mess(00274,00197,1)  : # Affaire
Endif
I += 1 : [M:GDE2]MSK(I)="F" : [M:GDE2]FLD(I) = "CIB"   : [M:GDE2]FLDDES(I) = mess(60,105,1) : # Code interbancaire

# Bloc G
If func AFNC.ACTIV("FEE2")
 I += 1 : [M:GDE2]MSK(I)="G" : [M:GDE2]FLD(I) = "DAS"  : [M:GDE2]FLDDES(I) = mess(215,105,1): # Déclaration honoraire
Endif
I += 1 : [M:GDE2]MSK(I)="G" : [M:GDE2]FLD(I) = "FUP"   : [M:GDE2]FLDDES(I) = mess(56,105,1) : # Relance
I += 1 : [M:GDE2]MSK(I)="G" : [M:GDE2]FLD(I) = "PAZ"   : [M:GDE2]FLDDES(I) = mess(57,105,1) : # Bon à payer

# Bloc H
I += 1 : [M:GDE2]MSK(I)="H" : [M:GDE2]FLD(I) = "REF"   : [M:GDE2]FLDDES(I) = mess(17,105,1) : # Référence pièce
I += 1 : [M:GDE2]MSK(I)="H" : [M:GDE2]FLD(I) = "SIM"   : [M:GDE2]FLDDES(I) = mess(25,105,1) : # Référence simulation

# Bloc I
I += 1 : [M:GDE2]MSK(I)="I" : [M:GDE2]FLD(I) = "RVS"   : [M:GDE2]FLDDES(I) = mess(55,105,1) : # Extourne
I += 1 : [M:GDE2]MSK(I)="I" : [M:GDE2]FLD(I) = "DRVS"  : [M:GDE2]FLDDES(I) = mess(165,105,1): # Date d'extourne
I += 1 : [M:GDE2]MSK(I)="I" : [M:GDE2]FLD(I) = "TYPO"  : [M:GDE2]FLDDES(I) = mess(10,105,1)-"("+mess(22,105,1)+")" : # Type de pièce (Document d'origine
I += 1 : [M:GDE2]MSK(I)="I" : [M:GDE2]FLD(I) = "NUMO"  : [M:GDE2]FLDDES(I) = mess(11,105,1)-"("+mess(22,105,1)+")" : # Numéro de pièce (Document d'origine)

# Zones spécifiques du masque GACCENTR1
For [AMZ]CODE Where CODMSK="GACCENTR1" & NUMBLOC<>6 & CODZON>="X" & CODACT<>""
 I += 1 : [M:GDE2]FLD(I) = [F:AMZ]CODZON
 Call TEXTE([F:AMZ]INTIT,[M:GDE2]FLDDES(I)) From OBJDIV
Next
[M:GDE2]NBRFLD = I+1

### Onglet ligne
I = -1
# Saisie en ligne/onglet
If [M:GDE1]TYPENT>1
  I += 1 : [M:GDE3]FLD(I) = "IDT"      :   [M:GDE3]FLDDES(I) = mess(173,105,1)      : # Identifiant ligne
Endif
I += 1 : [M:GDE3]FLD(I) = "FCYL"  : [M:GDE3]FLDDES(I) = mess(93,105,1)  : # Site ligne

# Saisie en colonne
If [M:GDE1]TYPENT=1
 For J=1 To [M:GDE1]NBRLED
  I += 1 : [M:GDE3]FLD(I) = "SAC"+num$(J) : [M:GDE3]FLDDES(I) = mess(27,102,1)-"-"-mess([M:GDE1]LEDTYP(J-1),2644,1)  : # Collectif
  I += 1 : [M:GDE3]FLD(I) = "ACC"+num$(J) : [M:GDE3]FLDDES(I) = mess(30,105,1)-"-"-mess([M:GDE1]LEDTYP(J-1),2644,1)  : # Compte
 Next
Elsif [M:GDE1]TYPENT=2
 # Saisie en ligne
 I += 1 : [M:GDE3]FLD(I) = "LEDT"     :   [M:GDE3]FLDDES(I) = mess(166,105,1)     : # Type de référentiel
 I += 1 : [M:GDE3]FLD(I) = "SAC1"     :   [M:GDE3]FLDDES(I) = mess(27,102,1)      : # Collectif
 I += 1 : [M:GDE3]FLD(I) = "ACC1"     :   [M:GDE3]FLDDES(I) = mess(30,105,1)      : # Compte
 I += 1 : [M:GDE3]FLD(I) = "DACC"     :   [M:GDE3]FLDDES(I) = mess(117,105,1)     : # Intitulé compte ligne
Else
 # Saisie en onglet
 For J=1 To [M:GDE1]NBRLED
  I += 1 : [M:GDE3]FLD(I) = "SAC"+num$(J) : [M:GDE3]FLDDES(I) = mess(27,102,1)-"-"-mess([M:GDE1]LEDTYP(J-1),2644,1)  : # Collectif
  I += 1 : [M:GDE3]FLD(I) = "ACC"+num$(J) : [M:GDE3]FLDDES(I) = mess(30,105,1)-"-"-mess([M:GDE1]LEDTYP(J-1),2644,1)  : # Compte
 Next
Endif

I += 1 : [M:GDE3]FLD(I) = "BPR"     :    [M:GDE3]FLDDES(I) = mess(31,105,1)        : # Tiers
I += 1 : [M:GDE3]FLD(I) = "DEB"     :    [M:GDE3]FLDDES(I) = mess(1,610,1)         : # Débit
I += 1 : [M:GDE3]FLD(I) = "CDT"     :    [M:GDE3]FLDDES(I) = mess(2,610,1)         : # Crédit
If func AFNC.ACTIV("KRU")
 I += 1 : [M:GDE3]FLD(I) = "DOE"     :    [M:GDE3]FLDDES(I) = mess(205,105,1)      : # Pointeur Double-partie
Endif
I += 1 : [M:GDE3]FLD(I) = "DES"     :    [M:GDE3]FLDDES(I) = mess(36,105,1)        : # Libellé
If func AFNC.ACTIV("VAT")
 I += 1 : [M:GDE3]FLD(I) = "TAX"    :    [M:GDE3]FLDDES(I) = mess(39,105,1)        : # Taxe
Endif

# Saisie en colonne/onglet
If [M:GDE0]FLGLOT<>2 # Fields offset :  only if not Batch entry transaction
 If [M:GDE1]TYPENT=1 or [M:GDE1]TYPENT=3
  For J=1 To [M:GDE1]NBRLED
   I += 1 : [M:GDE3]FLD(I) = "CPA"+num$(J) : [M:GDE3]FLDDES(I) = mess(61,105,1)-"-"-mess([M:GDE1]LEDTYP(J-1),2644,1) : # Contrepartie
  Next
 Else
 # Saisie en ligne
  I += 1 : [M:GDE3]FLD(I) = "CPA1"  : [M:GDE3]FLDDES(I) = mess(61,105,1) : # Contrepartie
 Endif
Endif


If [M:GDE0]FLGLOT<>2
 If func AFNC.ACTIV("CSL")
  I += 1 : [M:GDE3]FLD(I) = "CSLC"  : [M:GDE3]FLDDES(I) = mess(177,105,1) : # Partenaire
 Elsif func AFNC.ACTIV("PRCSL")
  I += 1 : [M:GDE3]FLD(I) = "CSLBPR"  : [M:GDE3]FLDDES(I) = mess(177,105,1) : # Partenaire
 Endif
 If func AFNC.ACTIV("CSL1")
  I += 1 : [M:GDE3]FLD(I) = "CSLFLO"  : [M:GDE3]FLDDES(I) = mess(178,105,1) : # Flux
 Endif
Endif

I += 1 : [M:GDE3]FLD(I) = "QTY"   : [M:GDE3]FLDDES(I) = mess(33,105,1) : # Quantité
I += 1 : [M:GDE3]FLD(I) = "UOM"   : [M:GDE3]FLDDES(I) = mess(34,105,1) : # Unité
If func AFNC.ACTIV("PJM") & [M:GDE0]FLGLOT<>2
 I += 1 : [M:GDE3]FLD(I) = "PJTLIN"  : [M:GDE3]FLDDES(I) = mess(00274,00197,1) : # Affaire
Endif
I += 1 : [M:GDE3]FLD(I) = "DSP"   : [M:GDE3]FLDDES(I) = mess(38,105,1) : # Répartition
# Issue X3-59287 - 2017-11-08 by FHA : STT* default value issue
#I += 1 : [M:GDE3]FLD(I) = "ST1"   : [M:GDE3]FLDDES(I) = mess(42,105,1) : # Code stat 1
#I += 1 : [M:GDE3]FLD(I) = "ST2"   : [M:GDE3]FLDDES(I) = mess(43,105,1) : # Code stat 2
#I += 1 : [M:GDE3]FLD(I) = "ST3"   : [M:GDE3]FLDDES(I) = mess(44,105,1) : # Code stat 3
I += 1 : [M:GDE3]FLD(I) = "STT1"   : [M:GDE3]FLDDES(I) = mess(42,105,1) : # Code stat 1
I += 1 : [M:GDE3]FLD(I) = "STT2"   : [M:GDE3]FLDDES(I) = mess(43,105,1) : # Code stat 2
I += 1 : [M:GDE3]FLD(I) = "STT3"   : [M:GDE3]FLDDES(I) = mess(44,105,1) : # Code stat 3
# End issue X3-59287

#RMA * Req. 75183
Gosub FIELD_GDE From CAPFLOLIB

I += 1 : [M:GDE3]FLD(I) = "FRER"  : [M:GDE3]FLDDES(I) = mess(152,105,1): # Référence libre
I += 1 : [M:GDE3]FLD(I) = "MTC"   : [M:GDE3]FLDDES(I) = mess(70,105,1) : # Lettre
I += 1 : [M:GDE3]FLD(I) = "MDA"   : [M:GDE3]FLDDES(I) = mess(71,105,1) : # Date lettrage
I += 1 : [M:GDE3]FLD(I) = "MDX"   : [M:GDE3]FLDDES(I) = mess(72,105,1) : # Date maxi lettrage
I += 1 : [M:GDE3]FLD(I) = "MDY"   : [M:GDE3]FLDDES(I) = mess(95,105,1) : # Date mini lettrage
I += 1 : [M:GDE3]FLD(I) = "CHK"   : [M:GDE3]FLDDES(I) = mess(73,105,1) : # Pointage
I += 1 : [M:GDE3]FLD(I) = "CHD"   : [M:GDE3]FLDDES(I) = mess(74,105,1) : # Date pointage
If func AFNC.ACTIV("VAT")
 I += 1 : [M:GDE3]FLD(I) = "VAT"  : [M:GDE3]FLDDES(I) = mess(75,105,1) : # Tva déclarée
Endif
I += 1 : [M:GDE3]FLD(I) = "LIN"   : [M:GDE3]FLDDES(I) = mess(76,105,1) : # No écriture
I += 1 : [M:GDE3]FLD(I) = "CHR"   : [M:GDE3]FLDDES(I) = mess(77,105,1) : # No chrono

# Zones spécifiques du masque GACCENTR1
For [AMZ]CODE Where CODMSK="GACCENTR1" & NUMBLOC=6 & CODZON>="X" & CODACT<>""
 I += 1 : [M:GDE3]FLD(I) = [F:AMZ]CODZON
 Call TEXTE([F:AMZ]INTIT,[M:GDE3]FLDDES(I)) From OBJDIV
Next
[M:GDE3]NBRFLD = I+1

Return

##############
$LECTURE
Raz NBDIE
For [F:GDD] Where DIA=[F:GDE]DIA
 K = find([F:GDD]FLD,[M:GDE2]FLD(0..[M:GDE2]NBRFLD))
 If K
  [M:GDE2]DAC(K-1)    = [F:GDD]DAC
  [M:GDE2]DEFVAL(K-1) = [F:GDD]DEFVAL
  [M:GDE2]CTL(K-1)    = [F:GDD]CTL
 Else
  K = find([F:GDD]FLD,[M:GDE3]FLD(0..[M:GDE3]NBRFLD))
  If K
   [M:GDE3]DAC(K-1)    = [F:GDD]DAC
   [M:GDE3]CRD(K-1)    = [F:GDD]CRD
   [M:GDE3]DEFVAL(K-1) = [F:GDD]DEFVAL
   [M:GDE3]CTL(K-1)    = [F:GDD]CTL
  Else
   If left$([F:GDD]FLD,3)="CCE"
     If NBDIE<dim([M:GDE4]DIE)
      [M:GDE4]DIE(NBDIE)    = right$([F:GDD]FLD,5)
      [M:GDE4]FLD(NBDIE)    = "CCE."+right$([F:GDD]FLD,5)
      [M:GDE4]DAC(NBDIE)    = [F:GDD]DAC
      [M:GDE4]CRD(NBDIE)    = [F:GDD]CRD
      [M:GDE4]DEFVAL(NBDIE) = [F:GDD]DEFVAL
      [M:GDE4]CTL(NBDIE)    = [F:GDD]CTL
       NBDIE+=1
     Endif
   Endif
  Endif
 Endif
Next
[M:GDE4]NBRFLD = NBDIE
Gosub AFF
Return

$CREATION
For I=1 To [M:GDE2]NBRFLD
 nolign = I
 Raz [F:GDD]
 [F:GDD]DIA = [M:GDE0]DIA
 [F:GDD]    = [M:GDE2]
 Write [F:GDD]
 If fstat
  GOK=0 : Call FSTA("GDD") From GLOCK
  Return
 Endif
Next
For I=1 To [M:GDE3]NBRFLD
 nolign = I
 Raz [F:GDD]
 [F:GDD]DIA = [M:GDE0]DIA
 [F:GDD]    = [M:GDE3]
 Write [F:GDD]
 If fstat
  GOK=0 : Call FSTA("GDD") From GLOCK
  Return
 Endif
Next
For I=1 To [M:GDE4]NBRFLD
 nolign = I
 Raz [F:GDD]
 [F:GDD]DIA = [M:GDE0]DIA
 [F:GDD]    = [M:GDE4]
 Write [F:GDD]
 If fstat
  GOK=0 : Call FSTA("GDD") From GLOCK
  Return
 Endif
Next
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Delete [F:GDD] Where DIA=[M]DIA
If fstat=1 | fstat>5
 GOK=-1 : GLOCK="$GDIAENTRYD"
 Return
Endif
If GOK<1 : Return : Endif
Gosub CREATION
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GDIAENTRY","DESTRA",CLECUR1,"","GDIAENTRY","DESTRA",[M:GDE0]DIA,"")  From ATEXTRA
 Call DUPTEXTRA("GDIAENTRY","SHOTRA",CLECUR1,"","GDIAENTRY","SHOTRA",[M:GDE0]DIA,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M:GDE0]DESTRA,"GDIAENTRY","DESTRA",[M:GDE0]DIA,"") From ATEXTRA
Call MAJTEXTRA([M:GDE0]SHOTRA,"GDIAENTRY","SHOTRA",[M:GDE0]DIA,"") From ATEXTRA
Return


$AP_CHANGE
Call CHGTEXTRA("GDIAENTRY","DESTRA",[M:GDE0]DIA,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("GDIAENTRY","SHOTRA",[M:GDE0]DIA,"",NCODE,"") From ATEXTRA
Return

$ANNULE
# Annulation des écrans
Local Char MSK(GLONAMK)
MSK = "WMAC1"+[F:GDE]DIA
Call DELMSK(MSK,nomap) From MSKDIV
If GOK<1 : Return : Endif
MSK = "WMAC2"+[F:GDE]DIA
Call DELMSK(MSK,nomap) From MSKDIV
If GOK<1 : Return : Endif
For I=1 To len(mess(0,2644,1))-1
 MSK = "WMAC"+num$(I+2)+[F:GDE]DIA
 Call DELMSK(MSK,nomap) From MSKDIV
 If GOK<1 : Break : Endif
Next
If GOK<1 : Return : Endif

# Annulation de la fenêtre
Local Char WIN(GLONFEN)
WIN = "WOGG"+[F:GDE]DIA
Call DELWIN(WIN,nomap) From MSKDIV
If GOK<1 : Return : Endif

# Annulation des lignes Transaction
Delete [F:GDD] Where DIA=[F:GDE]DIA
If fstat=1 | fstat>5
 GOK=-1 : GLOCK="$GDIAENTRYD"
 Return
Endif

# Annulation des Textes Traduisibles
Call SUPTEXTRA("GDIAENTRY","DESTRA",[M:GDE0]DIA,"") From ATEXTRA
Call SUPTEXTRA("GDIAENTRY","SHOTRA",[M:GDE0]DIA,"") From ATEXTRA
Return


$EXEBOUT
Case REP
 When "1" :
  Gosub VALID
 When "3" :
  #-- Visu de l'entête
  If [M]FLGPAG<>2
   Call VISUM("WMAC0"+CLECUR1) From SUBAMK
  Endif
  #-- Visu de l'onglet 1 ou de la Page unique
  Call VISUM("WMAC1"+CLECUR1) From SUBAMK
  #-- Visu des autres onglets
  If [M]FLGPAG<>2
   If [F:GDE]TYPENT<3
     Call VISUM("WMAC2"+CLECUR1) From SUBAMK
   Else
    For NBONG=2 To [F:GDE]NBRLED+1
     Call VISUM("WMAC"+num$(NBONG)+CLECUR1) From SUBAMK
    Next
   Endif
  Endif
Endcase
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

########################################
## Création d'une fenêtre
########################################
Subprog PATCH(APPLI)
Value Char APPLI()

If APPLI="X3" : End : Endif
Onerrgo CHUT From CONTROLE
Local File =APPLI+".ADOVAL" [ADW]
Onerrgo
If GERREUR : GERREUR=0 : End : Endif

Read [ADW]ADW0 = "";"";"MODULE1"
If !fstat & ([F:ADW]VALEUR="" | mid$([F:ADW]VALEUR,2,1)="2") : # Si module Compta
  Call GENDOS(APPLI)
Endif
End

Subprog GENDOS(APPLI)
Value Char APPLI()

Local File =APPLI+".ATYPE"     [ATY]

Local File =APPLI+".AMSK"      [AMK]
Local File =APPLI+".AMSKZON"   [AMZ]
Local File =APPLI+".AMSKACT"   [AMA]
Local File =APPLI+".AMSKPAR"   [AMP]

Local File =APPLI+".AMSK"      [AMK2]
Local File =APPLI+".AMSKZON"   [AMZ2]
Local File =APPLI+".AMSKACT"   [AMA2]
Local File =APPLI+".AMSKPAR"   [AMP2]

Local File =APPLI+".AWINDOW"   [AWI]
Local File =APPLI+".AWINPAR"   [AWP]
Local File =APPLI+".AWINBRO"   [AWB]
Local File =APPLI+".AWINBOUT"  [AWT]

Local File =APPLI+".GDIAENTRY"  [GDE]
Local File =APPLI+".GDIAENTRYD" [GDD]

Local File =APPLI+".AOBJET"    [AOB]
Local File =APPLI+".AOBJTAB"   [AOT]
Local File =APPLI+".AOBJLST"   [AOL]
Local File =APPLI+".ATABLE"    [ATB]
Local File =APPLI+".ATABIND"   [ATI]
Local File =APPLI+".ATABZON"   [ATZ]
Local File =APPLI+".ATEXTE"    [ATX]

Local File =APPLI+".ATABLE"    [AT2]
Local File =APPLI+".ACTIV"     [ACV]
Local File =APPLI+".ACTION"    [ACT]
Local File =APPLI+".ACTPAR"    [ATR]
Local File =APPLI+".ACTCODPAR" [AAR]
Local Integer OK
Local Char    MERE(20), MACHINE(20)

Call MOTHER(APPLI,APPLI,MERE,MACHINE) From ATEXTRA
Local File =MERE+".ADOSSIER"  [ADS]
Read [ADS]DOSSIER = APPLI

# En validation de dossier, il y a un problème avec GSCHSTD
GSCHSTD(1) = "STD"
GSCHSTD(2) = "STDA"
GSCHSTD(3) = "STDL"

For [GDE]DIA
 If GTRACE<>"" : Call ECR_TRACE([F:GDE]DIA,0) From GESECRAN : Endif
 Call VALIDATION([F:GDE]DIA,APPLI,1)
Next
Call VALID("GAS",APPLI,1,OK) From VALOBJ
Call VALID("LOT",APPLI,1,OK) From VALOBJ
End

$VALID
Call VALIDATION([F:GDE]DIA,nomap,1)
If [F:GDE]FLGLOT=2
 Call VALID("LOT",nomap,1,OK) From VALOBJ
Else
 Call VALID("GAS",nomap,1,OK) From VALOBJ
Endif
Return



######################################################################################
######################################################################################
Subprog VALIDATION(COD,APPLI,SILENCE)
Value Char COD()
Value Char APPLI()
Value Integer SILENCE

If !clalev([F:ADS])  : Local File ADOSSIER   [ADS]  : Endif
If !clalev([F:ATY])  : Local File ATYPE      [ATY]  : Endif

If !clalev([F:AMK])  : Local File AMSK       [AMK]  : Endif
If !clalev([F:AMZ])  : Local File AMSKZON    [AMZ]  : Endif
If !clalev([F:AMA])  : Local File AMSKACT    [AMA]  : Endif
If !clalev([F:AMP])  : Local File AMSKPAR    [AMP]  : Endif

If !clalev([F:AMK2]) : Local File AMSK       [AMK2] : Endif
If !clalev([F:AMZ2]) : Local File AMSKZON    [AMZ2] : Endif
If !clalev([F:AMA2]) : Local File AMSKACT    [AMA2] : Endif
If !clalev([F:AMP2]) : Local File AMSKPAR    [AMP2] : Endif

If !clalev([F:AWI])  : Local File AWINDOW    [AWI]  : Endif
If !clalev([F:AWP])  : Local File AWINPAR    [AWP]  : Endif
If !clalev([F:AWB])  : Local File AWINBRO    [AWB]  : Endif
If !clalev([F:AWT])  : Local File AWINBOUT   [AWT]  : Endif

If !clalev([F:GDE])  : Local File GDIAENTRY  [GDE]  : Endif
If !clalev([F:GDD])  : Local File GDIAENTRYD [GDD]  : Endif


If !clalev([F:AOB])  : Local File AOBJET     [AOB]  : Endif
If !clalev([F:AOT])  : Local File AOBJTAB    [AOT]  : Endif
If !clalev([F:AOL])  : Local File AOBJLST    [AOL]  : Endif
If !clalev([F:ATB])  : Local File ATABLE     [ATB]  : Endif
If !clalev([F:ATI])  : Local File ATABIND    [ATI]  : Endif
If !clalev([F:ATZ])  : Local File ATABZON    [ATZ]  : Endif
If !clalev([F:ATX])  : Local File ATEXTE     [ATX]  : Endif

If !clalev([F:AT2])  : Local File ATABLE     [AT2]  : Endif
If !clalev([F:ACV])  : Local File ACTIV      [ACV]  : Endif
If !clalev([F:ACT])  : Local File ACTION     [ACT]  : Endif
If !clalev([F:ATR])  : Local File ACTPAR     [ATR]  : Endif
If !clalev([F:AAR])  : Local File ACTCODPAR  [AAR]  : Endif

Local Char    MASKREF0(GLONAMK) , MASKREF1(GLONAMK) , MASKREF2(GLONAMK)
Local Char    MASKDES0(GLONAMK) , MASKDES1(GLONAMK) , MASKDES2(GLONAMK)
Local Char    NOMWIN(GLONFEN)   , WINREF(GLONFEN)

Local Integer NBZONE , MAXBLOC , P3 , P4 , NBACT
Local Char    CHAMP(GLONAVA)
Local Integer NCOL , LANCUR
Local Integer RGSAC
Local Integer OK

If !SILENCE : Call TEMPON("V") From GESECRAN :  Endif
Call DEBTRANS From GLOCK

Local Integer NBONG

# Création des masques
Gosub TRTMASK
If !GOK
 If !SILENCE :  Call TEMPOFF From GESECRAN : Endif
 End
Endif

# Validation des masques
If GOK=1
  If [F:GDE]ENAFLG=2
    Read [ADS]DOSSIER = APPLI
    #*X3-70924 Call VALID(MASKDES1,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,SILENCE,OK) From VALMSK
    Call VALIDFULL(MASKDES1,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,SILENCE,OK) From VALMSK
    If [F:GDE]FLGPAG<>2
      #*X3-70924 Call VALID(MASKDES0,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,SILENCE,OK) From VALMSK
      Call VALIDFULL(MASKDES0,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,SILENCE,OK) From VALMSK
      If [F:GDE]TYPENT<3
        #*X3-70924 Call VALID(MASKDES2,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,SILENCE,OK) From VALMSK
        Call VALIDFULL(MASKDES2,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,SILENCE,OK) From VALMSK
      Else
        For NBONG=2 To [F:GDE]NBRLED+1
          MASKDES2="WMAC"+num$(NBONG)+[F:GDE]DIA
          #*X3-70924 Call VALID(MASKDES2,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,SILENCE,OK) From VALMSK
          Call VALIDFULL(MASKDES2,APPLI,[F:ADS]NBRLAN,[F:ADS]LAN,SILENCE,OK) From VALMSK
        Next
      Endif
    Endif
  Endif
Endif

# Création de la fenêtre
Read [GDE]DIA = COD
If GSCHSTD(1)="" : End : Endif
NOMWIN = "WOGG"+COD
If [F:GDE]FLGLOT=2
 WINREF = "OGG"+GSCHSTD(3)
Else
 WINREF = "OGG"+GSCHSTD(1)
Endif
Call DEBTRANS From GLOCK
Gosub TRTWIN

# Validation de la fenêtre
If GOK>0
 If [F:GDE]ENAFLG=2
  Call VALID(NOMWIN,APPLI,1,OK) From VALWIN
 Else
  Local Char TRTWIN(12)
  If NOMWIN<>"" : TRTWIN="WG"+NOMWIN : Endif
  Call EFFACE_ADX("",APPLI,TRTWIN,OK) From ORDSYS
  Call EFFACE(filpath("TRT",TRTWIN,"src",APPLI),OK) From ORDSYS
 Endif
Endif

If !SILENCE :  Call TEMPOFF From GESECRAN : Endif
End

$TRTMASK
MASKDES0 = "WMAC0"+[F:GDE]DIA
MASKDES1 = "WMAC1"+[F:GDE]DIA
MASKDES2 = "WMAC2"+[F:GDE]DIA
GOK = 1

Trbegin [AMK2] , [AMZ2] , [AMA2] , [AMP2]

# Effacement masque précédent
Call DELMSK(MASKDES1,APPLI) From MSKDIV
If GOK>0
 If [F:GDE]FLGPAG<>2
  Call DELMSK(MASKDES0,APPLI) From MSKDIV
  If [F:GDE]TYPENT<3
   Call DELMSK(MASKDES2,APPLI) From MSKDIV
  Else
   For NBONG=2 To [F:GDE]NBRLED+1
    MASKDES2="WMAC"+num$(NBONG)+[F:GDE]DIA
    Call DELMSK(MASKDES2,APPLI) From MSKDIV
    If GOK<=0 : Break : Endif
   Next
  Endif
 Endif
Endif
If   GOK<0 : Goto ROLL_TRM
Elsif !GOK : Goto AB_TRM
Endif

If [F:GDE]ENAFLG=2
 Gosub WRIMSK
 If   GOK<0 : Goto ROLL_TRM
 Elsif !GOK : Goto AB_TRM
 Endif
Endif
Commit
Return

$WRIMSK
Gosub NBZONE
If [F:GDE]FLGLOT<>2 & [F:GDE]FLGPAG=2 & NBZONE>18
 Call ECR_TRACE(COD-":"-mess(78,105,1)-"("+num$(NBZONE)+"/18)",1) From GESECRAN : # Trop de zones
 GOK = 0 : Return
Endif
If [F:GDE]FLGLOT<>2 & [F:GDE]FLGPAG=2
 Gosub NBACTION
 If NBACT>200
  Call ECR_TRACE(COD-":"-mess(86,105,1)-":"-mess(41,9013,1),1) From GESECRAN
  GOK = 0 : Return
 Endif
Endif
If [F:GDE]FLGLOT<>2
 If [F:GDE]FLGPAG=2
  MASKREF1 = "GACCENTR1"
  MAXBLOC = int((NBZONE+3)/2)
  P3 = 3
  P4 = 1
 Else
  MASKREF0 = "GACCENT0"
  MASKREF1 = "GACCENTR2"
  MASKREF2 = "GACCENTR3"
  MAXBLOC = 4
  P3 = 1
  P4 = 1
 Endif
Else
  MASKREF1 = "GENTLOT"
Endif

# Construction du masque 1
Read [AMK]CODMSK = MASKREF1
[F:AMK2] = [F:AMK]
[F:AMK2]CODMSK  = MASKDES1
[F:AMK2]INTMSK  = 0
[F:AMK2]MDL     = 1
[F:AMK2]ABRMSK  = "HAE1"

#-- Visu liste gauche
If [F:GDE]FLGBRO<>2
 [F:AMK2]NBRCOL=112
Endif

#-- Nombre de colonne fixes
NCOL = find(1,[F:AMK2]TYPBLOC(0..dim(TYPBLOC)-1))
If NCOL & [F:GDE]NBRCOL>0
 For J=1 To 9
  K = instr(1,[F:AMK2]OPTION(NCOL-1),num$(J))
  If K
   [F:AMK2]OPTION(NCOL-1) = left$([F:AMK2]OPTION(NCOL-1),K-1)+right$([F:AMK2]OPTION(NCOL-1),K+1)
  Endif
 Next J
 [F:AMK2]OPTION(NCOL-1) += num$([F:GDE]NBRCOL)
Endif

For [AMZ]CODZON Where CODMSK=MASKREF1
 [F:AMZ2] = [F:AMZ]
 [F:AMZ2]CODMSK = MASKDES1
 If [F:GDE]FLGPAG=2 or [F:GDE]FLGLOT=2
  Gosub TRT1
 Else
  Gosub TRT2
 Endif
 Write [AMZ2]
 If fstat
   GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
 Endif
 Call COPIE_ACTION(MASKREF1,MASKDES1,[F:AMZ]CODZON,OK)
 If GOK<1 : Break : Endif
Next
If   GOK<1 : Return : Endif

# Dans le cas d'une transaction sur 2 onglets, vérification de blocs vide dans l'onglet 1.
If [F:GDE]FLGPAG<>2
 Gosub TRT3
Endif
Write [AMK2]
If fstat
 GOK = 0 : Call FSTA("AMK2") From GLOCK : Return
Endif

# Construction du masque 2..X
If [F:GDE]FLGPAG<>2
 If [F:GDE]TYPENT<3
  NBONG = 2 : Gosub ONGLETX
 Else
  For NBONG=2 To [F:GDE]NBRLED+1
   MASKDES2="WMAC"+num$(NBONG)+[F:GDE]DIA
   Gosub ONGLETX
  Next
 Endif
Endif

# Construction du masque d'entête si Transaction sur plusieurs pages
If [F:GDE]FLGPAG<>2
 Read [AMK]CODMSK = MASKREF0
 [F:AMK2] = [F:AMK]
 [F:AMK2]CODMSK  = MASKDES0
 [F:AMK2]INTMSK  = 0
 [F:AMK2]MDL     = 1
 [F:AMK2]ABRMSK  = "HAE0"
 #-- Visu liste gauche
 If [F:GDE]FLGBRO<>2
   [F:AMK2]NBRCOL=112
 Endif
 For [AMZ]CODZON Where CODMSK=MASKREF0
  [F:AMZ2] = [F:AMZ]
  [F:AMZ2]CODMSK = MASKDES0
  Gosub TRT2
  Write [AMZ2]
  If fstat
   GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
  Endif
  Call COPIE_ACTION(MASKREF0,MASKDES0,[F:AMZ]CODZON,OK)
  If GOK<1 : Break : Endif
 Next
 If   GOK<1 : Return : Endif
 Write [AMK2]
 If fstat
  GOK = 0 : Call FSTA("AMK2") From GLOCK : Goto AB_TRM
 Endif
Endif
Return

$ONGLETX
Read [AMK]CODMSK = MASKREF2
[F:AMK2] = [F:AMK]
[F:AMK2]CODMSK  = MASKDES2
[F:AMK2]INTMSK  = 0
[F:AMK2]MDL     = 1
[F:AMK2]ABRMSK  = "HAE"+num$(NBONG)

#-- Visu liste gauche
If [F:GDE]FLGBRO<>2
 [F:AMK2]NBRCOL=112
Endif

#-- Nombre de colonne fixes
NCOL = find(1,[F:AMK2]TYPBLOC(0..dim(TYPBLOC)-1))
If NCOL & [F:GDE]NBRCOL>0
 For J=1 To 9
  K = instr(1,[F:AMK2]OPTION(NCOL-1),num$(J))
  If K
   [F:AMK2]OPTION(NCOL-1) = left$([F:AMK2]OPTION(NCOL-1),K-1)+right$([F:AMK2]OPTION(NCOL-1),K+1)
  Endif
 Next J
 [F:AMK2]OPTION(NCOL-1) += num$([F:GDE]NBRCOL)
Endif
For [AMZ]CODZON Where CODMSK=MASKREF2
 [F:AMZ2] = [F:AMZ]
 [F:AMZ2]CODMSK = MASKDES2
 Gosub SET_OK
 Gosub TAB_CHP
 Write [AMZ2]
 If fstat
  GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
 Endif
 Call COPIE_ACTION(MASKREF2,MASKDES2,[F:AMZ]CODZON,OK)
 If GOK<1 : Break : Endif
Next
If   GOK<0 : Goto ROLL_TRM
Elsif !GOK : Goto AB_TRM
Endif
Write [AMK2]
If fstat
 GOK = 0 : Call FSTA("AMK2") From GLOCK : Goto AB_TRM
Endif
Return

$AB_TRM
Rollback
Return

$ROLL_TRM
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TRTMASK : Endif

$NBZONE
NBZONE=1
NBACT=1
CHAMP = "LIB"    : Gosub TEST : If OK : NBZONE += 1 : NBACT+=4 : Endif
CHAMP = "BOL"    : Gosub TEST : If OK : NBZONE += 1 : NBACT+=0 : Endif
CHAMP = "DENT"   : Gosub TEST : If OK : NBZONE += 1 : NBACT+=5 : Endif
CHAMP = "DDUD"   : Gosub TEST : If OK : NBZONE += 1 : NBACT+=5 : Endif
CHAMP = "DVAL"   : Gosub TEST : If OK : NBZONE += 1 : NBACT+=4 : Endif
CHAMP = "DBAN"   : Gosub TEST : If OK : NBZONE += 1 : NBACT+=4 : Endif
CHAMP = "CUR"    : Gosub TEST : If OK : NBZONE += 1 : NBACT+=9 : Endif
CHAMP = "TRAT"   : Gosub TEST : If OK : NBZONE += 1 : NBACT+=5 : Endif
CHAMP = "DRAT"   : Gosub TEST : If OK : NBZONE += 1 : NBACT+=6 : Endif

# Cours (1 à 5)
NBZONE += 1 * [F:GDE]NBRRAT : NBACT+= 12 * [F:GDE]NBRRAT

CHAMP = "ORI"    : Gosub TEST : If OK : NBZONE += 1 : NBACT+=0 : Endif  # Issue X3-52045 - 2017-08-07 by FHA : field ORIGIN & ORICOD added
CHAMP = "ORIC"   : Gosub TEST : If OK : NBZONE += 1 : NBACT+=0 : Endif  # Issue X3-52045 - 2017-08-07 by FHA : field ORIGIN & ORICOD added
CHAMP = "DOC"    : Gosub TEST : If OK : NBZONE += 1 : NBACT+=4 : Endif
CHAMP = "DDOC"   : Gosub TEST : If OK : NBZONE += 1 : NBACT+=5 : Endif
CHAMP = "MOD"    : Gosub TEST : If OK : NBZONE += 1 : NBACT+=0 : Endif
CHAMP = "PJT"    : Gosub TEST : If OK : NBZONE += 1 : NBACT+=3 : Endif
CHAMP = "CIB"    : Gosub TEST : If OK : NBZONE += 1 : NBACT+=3 : Endif

CHAMP = "DAS"    : Gosub TEST : If OK : NBZONE += 1 : NBACT+=5 : Endif
CHAMP = "FUP"    : Gosub TEST : If OK : NBZONE += 1 : NBACT+=5 : Endif
CHAMP = "PAZ"    : Gosub TEST : If OK : NBZONE += 1 : NBACT+=6 : Endif

CHAMP = "REF"    : Gosub TEST : If OK : NBZONE += 1 : NBACT+=4 : Endif
CHAMP = "SIM"    : Gosub TEST : If OK : NBZONE += 1 : NBACT+=0 : Endif

CHAMP = "RVS"    : Gosub TEST : If OK : NBZONE += 1 : NBACT+=6 : Endif
CHAMP = "DRVS"   : Gosub TEST : If OK : NBZONE += 1 : NBACT+=5 : Endif

CHAMP = "TYPO"   : Gosub TEST : If OK : NBZONE += 1 : NBACT+=0 : Endif
CHAMP = "NUMO"   : Gosub TEST : If OK : NBZONE += 1 : NBACT+=0 : Endif


For [F:GDD] Where DIA=[F:GDE]DIA
 If [F:GDD]FLD>="X" & [F:GDD]DAC<3
  Read [AMZ]CODE = "GACCENTR1";[F:GDD]FLD
  If !fstat & [F:AMZ]NUMBLOC<>6
   NBZONE += 1
  Endif
 Endif
Next
Return

$NBACTION
# Contrepartie (1 à 10)
NBACT + = 18 * [F:GDE]NBRLED
CHAMP = "DES"       : Gosub TEST : If OK : NBACT +=6  :  Endif
CHAMP = "TAX"       : Gosub TEST : If OK : NBACT +=6  :  Endif
CHAMP = "CSLC"      : Gosub TEST : If OK : NBACT +=4  :  Endif
CHAMP = "CSLBPR"    : Gosub TEST : If OK : NBACT +=6  :  Endif
CHAMP = "CSLFLO"    : Gosub TEST : If OK : NBACT +=6  :  Endif
CHAMP = "QTY"       : Gosub TEST : If OK : NBACT +=5  :  Endif
CHAMP = "UOM"       : Gosub TEST : If OK : NBACT +=4  :  Endif
CHAMP = "DSP"       : Gosub TEST : If OK : NBACT +=10 :  Endif
# Issue X3-59287 - 2017-11-08 by FHA : STT* default value issue
#CHAMP = "ST1"       : Gosub TEST : If OK : NBACT +=3  :  Endif
#CHAMP = "ST2"       : Gosub TEST : If OK : NBACT +=3  :  Endif
#CHAMP = "ST3"       : Gosub TEST : If OK : NBACT +=3  :  Endif
CHAMP = "STT1"       : Gosub TEST : If OK : NBACT +=3  :  Endif
CHAMP = "STT2"       : Gosub TEST : If OK : NBACT +=3  :  Endif
CHAMP = "STT3"       : Gosub TEST : If OK : NBACT +=3  :  Endif
# End issue X3-59287
CHAMP = "CAPFLOTYP" : Gosub TEST : If OK : NBACT +=5  :  Endif
Return

$TEST
OK = 0
Read [GDD]=[F:GDE]DIA;CHAMP
If !fstat & [F:GDD]DAC<3 : OK = 1 : Endif
Return

$TRT1
Gosub SET_OK
Case [F:AMZ]NUMBLOC
 When 3,4
  Case [F:AMZ]CODZON
   When "CAT"             : # On met toujours CAT en 3,1
    [F:AMZ2]NUMBLOC = 3
    [F:AMZ2]NOZONE  = 1
   When "STA"
    If NBZONE=0           : # Si y'a pas de zone supp on met STA en 4,1
     [F:AMZ2]NUMBLOC = 4
     [F:AMZ2]NOZONE  = 1
    Else                  : # sinon on le met en 3,2  c'est plus joli
     [F:AMZ2]NUMBLOC = 3
     [F:AMZ2]NOZONE  = 2
    Endif
   When "IDTLED"
    If [F:GDE]NBRRAT=0
     [F:AMZ2]SAIAFF = 3
    Elsif P3-1<=MAXBLOC
     [F:AMZ2]NUMBLOC = 3
     [F:AMZ2]NOZONE  = (P3)+.1
     [F:AMZ2]DIME    = [F:GDE]NBRRAT
    Else
     [F:AMZ2]NUMBLOC = 4
     [F:AMZ2]NOZONE  = (P4)+.1
     [F:AMZ2]DIME    = [F:GDE]NBRRAT
    Endif
   When "RAT1"
    If [F:GDE]NBRRAT=0
     [F:AMZ2]SAIAFF = 3
    Elsif P3-1<=MAXBLOC
     [F:AMZ2]NUMBLOC = 3
     [F:AMZ2]NOZONE  = (P3)+.2
     [F:AMZ2]DIME    = [F:GDE]NBRRAT
    Else
     [F:AMZ2]NUMBLOC = 4
     [F:AMZ2]NOZONE  = (P4)+.2
     [F:AMZ2]DIME    = [F:GDE]NBRRAT
    Endif
   When "CURDIV"
    If [F:GDE]NBRRAT=0
     [F:AMZ2]SAIAFF = 3
    Elsif P3-1<=MAXBLOC
     [F:AMZ2]NUMBLOC = 3
     [F:AMZ2]NOZONE  = (P3)+.3
     [F:AMZ2]DIME    = [F:GDE]NBRRAT
    Else
     [F:AMZ2]NUMBLOC = 4
     [F:AMZ2]NOZONE  = (P4)+.3
     [F:AMZ2]DIME    = [F:GDE]NBRRAT
    Endif
   When "RAT2"
    If [F:GDE]NBRRAT=0
     [F:AMZ2]SAIAFF = 3
    Elsif P3-1<=MAXBLOC
     [F:AMZ2]NUMBLOC = 3
     [F:AMZ2]NOZONE  = (P3)+.4
     [F:AMZ2]DIME    = [F:GDE]NBRRAT
    Else
     [F:AMZ2]NUMBLOC = 4
     [F:AMZ2]NOZONE  = (P4)+.4
     [F:AMZ2]DIME    = [F:GDE]NBRRAT
    Endif
   When "CURMLT"
    If [F:GDE]NBRRAT=0
     [F:AMZ2]SAIAFF = 3
    Elsif P3-1<=MAXBLOC
     [F:AMZ2]NUMBLOC = 3
     [F:AMZ2]NOZONE  = (P3)+.5
     [F:AMZ2]DIME    = [F:GDE]NBRRAT
     P3=P3+[F:GDE]NBRRAT
    Else
     [F:AMZ2]NUMBLOC = 4
     [F:AMZ2]NOZONE  = (P4)+.5
     [F:AMZ2]DIME    = [F:GDE]NBRRAT
     P4 = P4+[F:GDE]NBRRAT
    Endif

   When Default
    If SAIAFF<3
     If P3<=MAXBLOC
      [F:AMZ2]NUMBLOC = 3
      [F:AMZ2]NOZONE  = P3
      P3 += 1
     Else
      P3 = 99
      [F:AMZ2]NUMBLOC = 4
      [F:AMZ2]NOZONE  = P4
      P4 += 1
     Endif
    Else
     [F:AMZ2]NUMBLOC = 5
     [F:AMZ2]NOZONE = 99
    Endif
  Endcase
 When 6
    Gosub TAB_CHP
Endcase
Return

$TRT2
Gosub SET_OK
If [F:AMZ2]SAIAFF<3
  Case [F:AMZ]CODZON
   When "IDTLED"
     [F:AMZ2]NOZONE  += .1
     [F:AMZ2]DIME    = [F:GDE]NBRRAT
   When "RAT1"
     [F:AMZ2]NOZONE  += .1
     [F:AMZ2]DIME    = [F:GDE]NBRRAT
   When "CURDIV"
     [F:AMZ2]NOZONE  += .1
     [F:AMZ2]DIME    = [F:GDE]NBRRAT
   When "RAT2"
     [F:AMZ2]NOZONE  += .1
     [F:AMZ2]DIME    = [F:GDE]NBRRAT
   When "CURMLT"
     [F:AMZ2]NOZONE  += .1
     [F:AMZ2]DIME    = [F:GDE]NBRRAT
  Endcase
Else
 [F:AMZ2]NOZONE  = 99
 # Toute les zones invisibles doivent se retrouver dans le bloc invisible (problème évoqué sous 41580)
 I= find(5,[F:AMK]TYPBLOC(0..dim([F:AMK]TYPBLOC)-1))
 If I :  [F:AMZ2]NUMBLOC = I : Endif
Endif
Return

$TAB_CHP
If [F:AMZ]CODZON<>"ACCDAT"
 If [F:GDE]TYPENT=1

    #------------ Saisie en colonne

    If left$([F:AMZ]CODZON,3)="SAC" |
&      left$([F:AMZ]CODZON,3)="ACC" |
&      left$([F:AMZ]CODZON,3)="CPA"
        If val(right$([F:AMZ]CODZON,4))>[F:GDE]NBRLED
            [F:AMZ2]SAIAFF = 3
        Endif
    Endif
 Elsif [F:GDE]TYPENT=2

    #------------ Saisie en ligne

    If left$([F:AMZ]CODZON,3)="SAC" |
&      left$([F:AMZ]CODZON,3)="ACC" |
&      left$([F:AMZ]CODZON,3)="CPA"

       # Suppression des SACx,ACCx,CPAx dont x>1
        If val(right$([F:AMZ]CODZON,4))>1
            [F:AMZ2]SAIAFF = 3
        Else
            # Application du format Standard  (Initulé Général pour le compte et contrepartie)
            Raz [F:AMZ2]OPTFOR
            If left$([F:AMZ]CODZON,3)="ACC" & len([F:AMZ]CODZON)=4
                [F:AMZ2]INTEVAL="mess(30,105,1)"    # Compte
            Elsif left$([F:AMZ]CODZON,3)="CPA"
                [F:AMZ2]INTEVAL="mess(61,105,1)"    # Contrepartie
            Endif
        Endif
    Endif
 Else
    #------------ Saisie en onglet

    If left$([F:AMZ]CODZON,3)="SAC" |
&      left$([F:AMZ]CODZON,3)="ACC" |
&      left$([F:AMZ]CODZON,3)="CPA"

       # Suppression des SACx,ACCx,CPAx dans chaque onglet dont x ne correspond pas à l'onglet.
       #   (1er onglet 'ligne' : SAC0,ACC0,CPT0, 2ème onglet 'ligne' : SAC1,SAC1,CPT1  etc)

       If val(right$([F:AMZ]CODZON,4))<>val(mid$(MASKDES2,5,1))-1
         [F:AMZ2]SAIAFF = 3
       Endif
    Endif
 Endif
Endif

# Type de référentiel : uniquement en Ligne
If [F:AMZ]CODZON="LEDTYP" & [F:GDE]TYPENT<>2
  [F:AMZ2]SAIAFF = 3
Endif

# Identifiant ligne : uniquement en Ligne/Onglet
If [F:AMZ]CODZON="IDTLIN" & [F:GDE]TYPENT=1
  [F:AMZ2]SAIAFF = 3
Endif

# Intitulé & Format de Sections : Uniquement en Onglet (max 9)
If left$([F:AMZ]CODZON,3)="CCE" &  [F:GDE]TYPENT=3
 OK = val(right$([F:AMZ]CODZON,4))
 If OK<10
# 60 caractères
#  [F:AMZ2]INTEVAL= "evalue('+[M:HAEF]INTDIE('+num$(find(evalue('[M:HAEF]DIE'+mid$('"+[F:AMZ]CODZON+"',4,2)+'('+ num$(val(mid$('"+MASKDES2+"',5,1))-2)+')'),[M:HAEF]DIE(0..dim([M:HAEF]DIE)-1))-1)+')')"
   [F:AMZ2]INTEVAL= '[M:HAEF]INTDIE(find([M:HAE'+num$(mid$(MASKDES2,5,1))+']DIE('+num$(OK-1)+'),[M:HAEF]DIE(0..19))-1)'
 Endif
 [F:AMZ2]OPTFOR = "=GCCEFMT"
Endif

Return

$SET_OK
 # Zones saisies/affichées dans l'écran de référence qui peuvent devenir invisibles

 Case [F:AMZ]CODZON

  When "FCY"         : CHAMP = "FCY"
  When "JOU"         : CHAMP = "JOU"
  When "ACCDAT"      : CHAMP = "ACCDAT"

  When "CAT"         : CHAMP = "CAT"
  When "STA" :       : CHAMP = "STA"
  When "DACDIA"      : CHAMP = "DIA"

  When "DESVCR"      : CHAMP = "LIB"
  When "BOLLATO"     : CHAMP = "BOL"
  When "ENTDAT"      : CHAMP = "DENT"
  When "DUDDAT"      : CHAMP = "DDUD"
  When "VALDAT"      : CHAMP = "DVAL"
  When "BANDAT"      : CHAMP = "DBAN"
  When "ORIGIN"      : CHAMP = "ORI"  # Issue X3-52045 - 2017-08-07 by FHA : field ORIGIN & ORICOD added
  When "ORICOD"      : CHAMP = "ORIC" # Issue X3-52045 - 2017-08-07 by FHA : field ORIGIN & ORICOD added
  When "BPRVCR"      : CHAMP = "DOC"
  When "BPRDATVCR"   : CHAMP = "DDOC"
  When "ORIMOD"      : CHAMP = "MOD"
  When "PJT"         : CHAMP = "PJT"
  When "BANCIB"      : CHAMP = "CIB"
  When "REF"         : CHAMP = "REF"
  When "REFSIM"      : CHAMP = "SIM"
  When "CUR"         : CHAMP = "CUR"
  When "TYPRAT"      : CHAMP = "TRAT"
  When "RATDAT"      : CHAMP = "DRAT"
  When "IDTLED"      : CHAMP = "MLT1"
  When "RAT1"        : CHAMP = "MLT1"
  When "CURMLT"      : CHAMP = "MLT1"
  When "RAT2"        : CHAMP = "MLT1"
  When "CURDIV"      : CHAMP = "MLT1"
  When "FLGDAS"      : CHAMP = "DAS"
  When "FLGFUP"      : CHAMP = "FUP"
  When "FLGPAZ"      : CHAMP = "PAZ"
  When "RVS"         : CHAMP = "RVS"
  When "RVSDAT"      : CHAMP = "DRVS"
  When "RVSORITYP"   : CHAMP = "TYPO"
  When "RVSORINUM"   : CHAMP = "NUMO"

  When "FCYLIN"      : CHAMP = "FCYL"
  When "ACCDES"      : CHAMP = "DACC"
  When "ACC1"        : CHAMP = "ACC1"
  When "ACC2"        : CHAMP = "ACC2"
  When "ACC3"        : CHAMP = "ACC3"
  When "ACC4"        : CHAMP = "ACC4"
  When "ACC5"        : CHAMP = "ACC5"
  When "ACC6"        : CHAMP = "ACC6"
  When "ACC7"        : CHAMP = "ACC7"
  When "ACC8"        : CHAMP = "ACC8"
  When "ACC9"        : CHAMP = "ACC9"
  When "ACC10"       : CHAMP = "ACC10"

  When "SAC1"        : CHAMP = "SAC1"
  When "SAC2"        : CHAMP = "SAC2"
  When "SAC3"        : CHAMP = "SAC3"
  When "SAC4"        : CHAMP = "SAC4"
  When "SAC5"        : CHAMP = "SAC5"
  When "SAC6"        : CHAMP = "SAC6"
  When "SAC7"        : CHAMP = "SAC7"
  When "SAC8"        : CHAMP = "SAC8"
  When "SAC9"        : CHAMP = "SAC9"
  When "SAC10"       : CHAMP = "SAC10"

  When "BPR"         : CHAMP = "BPR"
  When "FREREF"      : CHAMP = "FRER"
  When "TAX"         : CHAMP = "TAX"
  When "DOE"         : CHAMP = "DOE"

  When "CPA1"        : CHAMP = "CPA1"
  When "CPA2"        : CHAMP = "CPA2"
  When "CPA3"        : CHAMP = "CPA3"
  When "CPA4"        : CHAMP = "CPA4"
  When "CPA5"        : CHAMP = "CPA5"
  When "CPA6"        : CHAMP = "CPA6"
  When "CPA7"        : CHAMP = "CPA7"
  When "CPA8"        : CHAMP = "CPA8"
  When "CPA9"        : CHAMP = "CPA9"
  When "CPA10"       : CHAMP = "CPA10"

  When "CSLCOD"      : CHAMP = "CSLC"
  When "CSLBPR"      : CHAMP = "CSLBPR"
  When "CSLFLO"      : CHAMP = "CSLFLO"

  When "UOM"         : CHAMP = "UOM"
  When "QTY"         : CHAMP = "QTY"
  When "PJTLIN"      : CHAMP = "PJTLIN"
  When "STT1"        : CHAMP = "STT1" :# X3-59287 ST1 changed to STT1
  When "STT2"        : CHAMP = "STT2" :# X3-59287 ST2 changed to STT2
  When "STT3"        : CHAMP = "STT3" :# X3-59287 ST3 changed to STT3
  When "MTC"         : CHAMP = "MTC"
  When "MTCDAT"      : CHAMP = "MDA"
  When "MTCDATMAX"   : CHAMP = "MDX"
  When "MTCDATMIN"   : CHAMP = "MDY"
  When "CHK"         : CHAMP = "CHK"
  When "CHKDAT"      : CHAMP = "CHD"
  When "AMTVAT"      : CHAMP = "VAT"
  When "ACCNUM"      : CHAMP = "LIN"
  When "CHRNUM"      : CHAMP = "CHR"
  When Default
   If [F:AMZ]CODZON>="X" & [F:AMZ]CODACT<>""
    CHAMP = [F:AMZ]CODZON : # Zones spécifiques
   Else
    CHAMP=""
   Endif
 Endcase
 If CHAMP<>""
  Gosub TEST
  If !OK : [F:AMZ2]SAIAFF  = 3 : Endif
  [F:AMZ2]CODCTL = [F:GDD]CTL
 Endif
OK=1
If [F:AMZ]SAIAFF=1 & [F:AMZ2]SAIAFF=3 : # Zones saisies devenues invisibles
 Case [F:AMZ]CODZON
  When "ENTDAT"      : [F:AMZ2]VALDEF = "*[M]ACCDAT" : OK=0
  When "VALDAT"      : [F:AMZ2]VALDEF = "*[M]DUDDAT" : OK=0
  When "FCYLIN"      : [F:AMZ2]VALDEF = "*[M]FCY" : # On garde D_FCYLIN (init à [M]FCY)
  When "QTY"         : [F:AMZ2]VALDEF="" : OK=0 : # Pas d'init
 Endcase
Endif
If [F:AMZ]SAIAFF<>3 & [F:AMZ2]SAIAFF=3
 [F:AMZ2]TYPGRAPH = 1
 Raz [F:AMZ2]OBLIG, [F:AMZ2]LIEN, [F:AMZ2]TUNNEL
 Raz [F:AMZ2]CODACC, [F:AMZ2]CONSAI, [F:AMZ2]CODCTL
Endif
Return

$TRT3
Local Integer NBZ1,NBZ2,NBZ3,NBZ4,NBZ5,NBZ6,NBZ7,DEVINV
Raz NBZ1,NBZ2,NBZ3,NBZ4,NBZ5,NBZ6,NBZ7,DEVINV

For [AMZ2]CODZON Where CODMSK=MASKDES1 & SAIAFF<3 & NUMBLOC<8
    If !find([F:AMZ2]CODZON,"IDTLED","RAT1","CURMLT","RAT2","CURDIV")
       Assign "NBZ"+num$([F:AMZ2]NUMBLOC) With evalue("NBZ"+num$([F:AMZ2]NUMBLOC))+1
    Else
       # cours minimum à 1 (NBRAT>=1) mais celui peut petre paramétré "invisible".
       If !DEVINV : NBZ5 += [F:GDE]NBRRAT : DEVINV=1 : Endif
    Endif
Next
#Infbox num$(NBZ1),num$(NBZ2),num$(NBZ3),num$(NBZ4),num$(NBZ5),num$(NBZ6),num$(NBZ7)

# Gestion du bloc 2,3,4
For I=2 To 4
  If evalue("NBZ"+num$(I))=0

    # Zone rendue invisible
    Assign "[F:AMK2]POSBLOC("+num$(I-1)+")" With 0
    [F:AMK2]TYPBLOC(I-1) = 5

    # Agrandissement de la colonne
    Assign "[F:AMK2]POSBLOC("+num$(I+2)+")" With val(num$(I)+".1")
    Assign "[F:AMK2]COLBLOC("+num$(I+2)+")" With 2

  Endif
Next

# Gestion du bloc 5,6,7
For I=5 To 7
  If evalue("NBZ"+num$(I))=0 & evalue("NBZ"+num$(I-3))=0

    # Zone rendue invisible
    Assign "[F:AMK2]POSBLOC("+num$(I-1)+")" With 0
    [F:AMK2]TYPBLOC(I-1) = 5

 Endif
Next

# Gestion du bloc 1
If NBZ1=0
 [F:AMK2]POSBLOC(0) = 0
 [F:AMK2]TYPBLOC(0) = 5
Endif


Return


$TRTWIN
GOK = 1
Trbegin [AWI] , [AWP]

 If NOMWIN<>WINREF
  Delete [AWI] Where WIN=NOMWIN
  If fstat=1
   GOK = -1 : GLOCK = "$AWINDOW"-NOMWIN : Goto ROLL_TRW
  Endif
  Delete [AWP] Where WIN=NOMWIN
  If fstat=1
   GOK = -1 : GLOCK = "$AWINPAR"-NOMWIN : Goto ROLL_TRW
  Endif
  Delete [AWB] Where WIN=NOMWIN
  If fstat=1
   GOK = -1 : GLOCK = "$AWINBRO"-NOMWIN : Goto ROLL_TRW
  Endif
  Delete [AWT] Where WIN=NOMWIN
  If fstat=1
   GOK = -1 : GLOCK = "$AWINBOUT"-NOMWIN : Goto ROLL_TRW
  Endif
 Endif

 If [F:GDE]ENAFLG=2
  Read [F:AWI]AWI0 = WINREF
  If !fstat
   [F:AWI]WIN = NOMWIN
   If [F:GDE]FLGPAG=2
    [F:AWI]MSKENT    = ""
    [F:AWI]NOMMSK(0) = MASKDES1
    [F:AWI]FLGMSK(0) = 2
    [F:AWI]NBMSK     = 1
   Else
    [F:AWI]MSKENT    = MASKDES0
    [F:AWI]NOMMSK(0) = MASKDES1
    [F:AWI]FLGMSK(0) = 2
    If [F:GDE]TYPENT<3
     [F:AWI]NOMMSK(1) = MASKDES2
     [F:AWI]FLGMSK(1) = 2
     [F:AWI]NBMSK     = 2
     [F:AWI]INTFOLD(1) = "mess(7,105,1)"    # Lignes
    Else
     For NBONG=1 To [F:GDE]NBRLED
      MASKDES2="WMAC"+num$(NBONG+1)+[F:GDE]DIA
      [F:AWI]NOMMSK(NBONG) = MASKDES2
      [F:AWI]FLGMSK(NBONG) = 2
      [F:AWI]ROWMSK(NBONG) = 5*(NBONG+1)
#      [F:AWI]INTFOLD(NBONG) = "mess("+num$(NBONG)+",2644,1)"
      [F:AWI]INTFOLD(NBONG) = "mess("+num$([F:GDE]LEDTYP(NBONG-1))+",2644,1)"

     Next
      [F:AWI]NBMSK  = [F:GDE]NBRLED+1
    Endif
   Endif

   [F:AWI]ACS    = [F:GDE]ACS
   Call LECTEXTRA([F:AWI]LIBEL,"GDIAENTRY","DESTRA",[F:GDE]DIA,"") From ATEXTRA
   [F:AWI]MDL    = 1
   [F:AWI]ENAFLG = 2
   [F:AWI]TRN    = [F:GDE]DIA
   If NOMWIN<>WINREF
    Write [AWI]
    For [AWP] Where WIN=WINREF
     [F:AWP]WIN = NOMWIN
     Write [AWP]
     If fstat
      GOK = 0 : Call FSTA("AWP") From GLOCK : Break
     Endif
    Next
    If [F:GDE]FLGBRO=2
     For [AWB] Where WIN=WINREF
      [F:AWB]WIN = NOMWIN
      Write [AWB]
      If fstat
       GOK = 0 : Call FSTA("AWB") From GLOCK : Break
      Endif
     Next
    Elsif [F:GDE]FLGBRO<>2
     For [AWB] Where WIN=WINREF
      Raz [F:AWB]
      [F:AWB]WIN = NOMWIN
      [F:AWB]DERLU=1
      Write [AWB]
      If fstat
       GOK = 0 : Call FSTA("AWB") From GLOCK : Break
      Endif
     Next
    Endif
    For [AWT] Where WIN=WINREF
     [F:AWT]WIN = NOMWIN
     Write [AWT]
     If fstat
      GOK = 0 : Call FSTA("AWT") From GLOCK : Break
     Endif
    Next
   Else
    Rewrite [AWI]
   Endif
   If fstat
    GOK = 0 : Call FSTA("AWI") From GLOCK : Goto AB_TRW
   Endif
  Endif
 Endif
Commit
Return

$AB_TRW
Rollback
Return

$ROLL_TRW
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TRTWIN : Endif
Return

# Transfert actions et paramètres
Subprog COPIE_ACTION(MASKORG,MASKDES,ZONE,STD)
Value Char MASKORG()
Value Char MASKDES()
Value Char ZONE()
Value Integer STD
Local Integer OK, NOL
For [AMA]TYPAFF Where TYPAFF=1 & CODAFF=MASKORG & CODZON=ZONE
 If [F:AMZ2]SAIAFF<>1 & find(left$([F:AMA]ACTION,6),"FLDDEF","FLDAVT","FLDCTL") : OK=0
 Elsif !STD & [F:AMA]ACTION="STD" : OK=0
 Else OK=1
 Endif
 If OK
  NOL+=1
  [F:AMA2] = [F:AMA]
  [F:AMA2]CODAFF = MASKDES
  [F:AMA2]NOACT  = NOL
  Write [AMA2]
  If fstat
   GOK=0 : Call FSTA("AMA2") From GLOCK : Break
  Endif
 Endif
Next
If GOK<1 : End : Endif
For [AMP]CODPAR Where TYPAFF=1 & CODAFF=MASKORG & CODZON=ZONE
 [F:AMP2] = [F:AMP]
 [F:AMP2]CODAFF = MASKDES
 Write [AMP2]
 If fstat
  GOK=0 : Call FSTA("AMP2") From GLOCK : Break
 Endif
Next
If GOK<1 : End : Endif
If ZONE>="X" & [F:AMZ2]SAIAFF<3 & [F:AMZ2]CODACT<>""
 Local Char    TYPZON(10) , TYPACT(10)
 Local Integer ACT
 Read [ATY]CODTYP = [F:AMZ2]CODTYP
 Case [F:ATY]TYPTYP
  When 1         : TYPZON = "INT"
  When 2,3,4,5,6 : TYPZON = "DCB"
  When 7         : TYPZON = "CAR"
  When 8         : TYPZON = "DAT"
 Endcase
 For ACT=3,4,5
  Case ACT
   When 3 : TYPACT = "FLDDEF"
   When 4 : TYPACT = "FLDAVT"
   When 5 : TYPACT = "FLDCTL"
  Endcase
  Read [AMA2]TYPAFF(4) = 1;MASKDES;ZONE;ACT
  If fstat
   Raz [F:AMA2]
   [F:AMA2]TYPAFF = 1
   [F:AMA2]CODAFF = MASKDES
   [F:AMA2]CODZON = ZONE
   [F:AMA2]TYPACT = ACT
   [F:AMA2]NOACT  = 1
   [F:AMA2]ACTION = TYPACT+TYPZON
   [F:AMA2]EXEACT = 1
   [F:AMA2]DISACT = 2
   Write [AMA2]
   If fstat
    GOK=0 : Call FSTA("AMA2") From GLOCK : Break
   Endif
  Endif
  Read [AMP2]CODPAR = 1;MASKDES;ZONE;"FLDNAM"
  If fstat
   Raz [F:AMP2]
   [F:AMP2]TYPAFF = 1
   [F:AMP2]CODAFF = MASKDES
   [F:AMP2]CODZON = ZONE
   [F:AMP2]CODPAR = "FLDNAM"
   [F:AMP2]VALPAR = '"'+ZONE+'"'
   Write [AMP2]
   If fstat
    GOK=0 : Call FSTA("AMP2") From GLOCK : Break
   Endif
  Endif
 Next ACT
Endif
End

###############################################################################
##  Copie
###############################################################################
$TRTCOP
If [M]DOSORG=nomap
 Local File GDIAENTRY  [GDE1]
 Local File GDIAENTRYD [GDD1]
 Local File ATEXTRA  [AXX1]
Else
 Local File =[M]DOSORG+".GDIAENTRY"  [GDE1]
 Local File =[M]DOSORG+".GDIAENTRYD" [GDD1]
 Local File =[M]DOSORG+".ATEXTRA"  [AXX1]
Endif
If [M]DOSDES=nomap
 Local File GDIAENTRY  [GDE2]
 Local File GDIAENTRYD [GDD2]
 Local File ATEXTRA  [AXX2]
Else
 Local File =[M]DOSDES+".GDIAENTRY"  [GDE2]
 Local File =[M]DOSDES+".GDIAENTRYD" [GDD2]
 Local File =[M]DOSDES+".ATEXTRA"  [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [GDE1] , [GDD1] , [GDE2] , [GDD2]
Close Local File [AXX1], [AXX2]
If clalev([F:ADS1])>0 : Close Local File [ADS1] : Endif
If clalev([F:ADS2])>0 : Close Local File [ADS2] : Endif
Return

$TR_COP
GOK = 1
Trbegin [GDE2] , [GDD2]
 Delete [GDD2] Where DIA=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".GDIAENTRYD" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("GDD2","") From GLOCK : Goto AB_TR_COP
 Endif
 Delete [GDE2] Where DIA=TABLE
 If fstat=1
  GOK=-1 : GLOCK = "$"+[M]DOSDES+".GDIAENTRY" : Goto ROLL_TR_COP
 Elsif fstat>5
  GOK = 0 : Call RSTA("GDD2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [GDD1] Where DIA=TABLE
  [F:GDD2] = [F:GDD1]
  Write [GDD2]
  If fstat
   GOK = 0 : Call FSTA("GDD2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
 For [GDE1] Where DIA=TABLE
  [F:GDE2] = [F:GDE1]
  Call COPTEXTRA("GDIAENTRY","DESTRA",TABLE,"") From ATEXTRA
  Call COPTEXTRA("GDIAENTRY","SHOTRA",TABLE,"") From ATEXTRA
  If dim([F:GDE2]UPDUSR)>0 : [F:GDE2]UPDUSR = GUSER : Endif
  If dim([F:GDE2]UPDDAT)>0 : [F:GDE2]UPDDAT = date$ : Endif
  Write [GDE2]
  If fstat
   GOK = 0 : Call FSTA("GDE2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

######################################################################################
$GRISE
# pour les transactions dits "Standard", on interdit
#     - la modification des référentiels (=> tous non automatique)
#     - Le type de saisie
#     - ...
If [F:GDE]DIA=GSCHSTDC or [F:GDE]DIA=GSCHSTDL
 Gosub GRISE_ALL : Return
Else
 # pour les autres transactions, on interdit la modification de type de saisie si transaction est déjà utilisée.
 Filter [HAE] Where DACDIA=[F:GDE]DIA
 Read [HAE]HAE3 First
 If !fstat
  Grizo [M:GDE1]TYPENT
 Endif
 Filter [HAE]
Endif

If [F:GDE]FLGLOT=2
 [M:GDE1]TYPENT=1 : Affzo [M:GDE1]TYPENT : Grizo [M:GDE1]TYPENT
 [M:GDE1]FLGPAG=2 : Affzo [M:GDE1]FLGPAG : Grizo [M:GDE1]FLGPAG
Else
 If [F:GDE]TYPENT=3
  [M:GDE1]FLGPAG=1 : Affzo [M:GDE1]FLGPAG : Grizo [M:GDE1]FLGPAG
 Endif
Endif
If [F:GDE]NBRLED=1 : Actzo [M:GDE1]FLGEQL Else : Grizo [M:GDE1]FLGEQL : Endif
Return

$GRISE_ALL
[M:GDE0]FLGLOT=1 : Affzo [M:GDE0]FLGLOT : Grizo [M:GDE0]FLGLOT
If [F:GDE]DIA=GSCHSTDC
 [M:GDE1]TYPENT=1 : Affzo [M:GDE1]TYPENT : Grizo [M:GDE1]TYPENT
Else
 [M:GDE1]TYPENT=2 : Affzo [M:GDE1]TYPENT : Grizo [M:GDE1]TYPENT
Endif

Raz [M:GDE1]NBRLED
For I=1 To len(mess(0,2644,1))
 Raz AUT
 For NBLED=1 To len(GLEDTYPAUT)
  TYPREF = val(mid$(GLEDTYPAUT,NBLED,1))
  # Gestion de la valeur 10
  If TYPREF=1 &  mid$(GLEDTYPAUT,NBLED+1,1)="0"
   If I=10 : AUT=1 : Break : Endif
  Else
   If TYPREF = I : AUT=1 : Break : Endif
  Endif
 Next
 If !AUT
  [M:GDE1]LEDTYP([M]NBRLED) = I
  [M:GDE1]NBRLED +=1
 Endif
Next

Affzo [M:GDE1]15   : Grizo [M:GDE1]15
Return

$DEGRISE
Actzo [M:GDE0]FLGLOT
Actzo [M:GDE1]TYPENT,FLGPAG,NBRRAT
Actzo [M:GDE1]15
Return

$AFF
Affzo [GDE2]20
Affzo [GDE3]20
Affzo [GDE4]20
Return

$EFF
Effzo [GDE2]20
Effzo [GDE3]20
Effzo [GDE4]20
Return



###############################################################################
##  Contrôle en saisie du paramètre SCHSAISIE,SCHSTDC,SCHSTDL
###############################################################################
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK
If VALEUR="" : End : Endif
If !clalev([F:GDE])  : Local File GDIAENTRY [GDE]  : Endif
Local Integer I
Read [GDE]DIA = VALEUR
Case PARAM
 When "SCHSTDC" :
  # La transaction "Standard" de type colonne ne peut pas être flagué "Par lot"
  If [F:GDE]FLGLOT=2
   # Schéma de saisie incorrect - Ecran de sais par lot
   GMESSAGE = mess(130,104,1)-"("+mess(81,105,1)+")" : mkstat = 2 : End
  Endif
  # La transaction "Standard" de type colonne doit être flagué "Colonne"
  If [F:GDE]TYPENT<>1
   # Schéma de saisie incorrect
   GMESSAGE = mess(130,104,1)-"("+mess([F:GDE]TYPENT,2646,1)+")" : mkstat = 2 : End
  Endif
  # La transaction "Standard" de type colonne doit avoit tous les référentiels saisis
  If [F:GDE]NBRLED<>11-len(GLEDTYPAUT)
   # Schéma de saisie incorrect - Type de référentiel
   GMESSAGE = mess(130,104,1)-"("+mess(166,105,1)+")" : mkstat = 2 : End
  Endif
 When "SCHSTDL" :
  # La transaction "Standard" de type ligne ne peut pas être flagué "Par lot"
  If [F:GDE]FLGLOT=2
   # Schéma de saisie incorrect - Ecran de sais par lot
   GMESSAGE = mess(130,104,1)-"("+mess(81,105,1)+")" : mkstat = 2 : End
  Endif
  # La transaction "Standard" de type ligne doit être flagué "Ligne"
  If [F:GDE]TYPENT<>2
   # Schéma de saisie incorrect
   GMESSAGE = mess(130,104,1)-"("+mess([F:GDE]TYPENT,2646,1)+")" : mkstat = 2 : End
  Endif
  # La transaction "Standard" de type ligne doit avoit tous les référentiels saisis
  If [F:GDE]NBRLED<>11-len(GLEDTYPAUT)
   # Schéma de saisie incorrect - Type de référentiel
   GMESSAGE = mess(130,104,1)-"("+mess(166,105,1)+")" : mkstat = 2 : End
  Endif
 When "SCHSAILOT" :
  # La transaction "Standard" de type "Saisie par lot" doit être flagué "Par lot"
  If [F:GDE]FLGLOT<>2
   # Schéma de saisie incorrect
   GMESSAGE = mess(130,104,1) : mkstat = 2 : End
  Endif
 When "SCHSAISIE" :
  # La transaction "Standard" ne doit pas être flagué "Par lot"
  If [F:GDE]FLGLOT=2
   # Schéma de saisie incorrect
   GMESSAGE = mess(130,104,1) : mkstat = 2 : End
  Endif
Endcase
If dim([M:ADWP]CMP)>0 & [M:ADWP]CMP<>"" & [F:GDE]GFY<>"" & [M:ADWP]CMP<>[F:GDE]GFY
 Call VERSOC([F:GDE]GFY,[M:ADWP]CMP,[M:ADWP]FCY,VALEUR) From CFYSUB
 If GMESSAGE<>""
  Gosub TIT From WOGDE
  I = instr(1,GMESSAGE,":")
  GMESSAGE = TIT-":"-LEG-left$(GMESSAGE,I-1)+"\"+right$(GMESSAGE,I+1)
 Endif
 If mkstat : OK = 0 : End : Endif
Endif
End


######################################################################################
# Si la transaction est flaguée : Saisie par lot
#    => Saisi des référentiels en colonne (TYPENT=1)
#    => Forcément une saisie sur 1 page  (FLGPAG=2)
######################################################################################
Subprog C_FLGLOT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 [M:GDE1]TYPENT=1 : Affzo [M:GDE1]TYPENT : Grizo [M:GDE1]TYPENT
 [M:GDE1]FLGPAG=2 : Affzo [M:GDE1]FLGPAG : Grizo [M:GDE1]FLGPAG
Else
 Actzo [M:GDE1]TYPENT,FLGPAG
 If [F:GDE]TYPENT=3
  [M:GDE1]FLGPAG=1 : Affzo [M:GDE1]FLGPAG : Grizo [M:GDE1]FLGPAG
 Endif
Endif
If VALEUR<>[M:GDE0]FLGLOT
 [M:GDE0]FLGLOT=VALEUR
 Gosub CHARGE_CHAMP
 Gosub AFF
Endif
End

######################################################################################
Subprog AS_NBRLED
  # Dans le cas d'une transaction onglet, le nombre de référentiel ne doit dépasser 8 référentiels.
  # Désactiver l'insertion Correction 2 X3-38638 (  NBRLED > ==> Disable 73  )
  If [M:GDE1]TYPENT = 3
    If NBRLED >= 8
      Disable 73
    Else
      Enable 73
    Endif
    If nolign-1>=8 # nolign remplacé par NBRLED
      mkstat = 1 : End
   Endif
  Endif
  If [M:GDE1]TYPENT <> 3
    If NBRLED > ( len(mess(0,2644,1)) -len(GLEDTYPAUT) )
      Disable 73
    Else
      Enable 73
    Endif
    If nolign -1 >=(len(mess(0,2644,1)) -len(GLEDTYPAUT) +1 )
      mkstat = 1 : End
    Endif
  Endif

End


######################################################################################
Subprog C_NBRLED
If !clalev([F:HAE])  : Local File GACCENTRY  [HAE]  : Endif
Local Integer I,J,K,NBDIE,OK
Raz K
If adxgtb=2  :# Sortie du tableau
 # Au moins un réféntiel doit être renseigné
 If [M:GDE1]NBRLED<1 | [M:GDE1]LEDTYP(0)<1
  GMESSAGE=mess(10,123,1)        # Zone obligatoire
  mkstat=2  : End
 Endif
 # Si les référentiels évoluent, l'onglet "Ligne" évolue également
 If [F:GDE]NBRLED<>[M:GDE1]NBRLED & [M:GDE1]TYPENT<>3
  K=1
  If [F:GDE]NBRLED>[M:GDE1]NBRLED
   Filter [HAE] Where DACDIA=[M:GDE0]DIA
   Read [HAE]HAE3 First
   If !fstat
    # Attention, diminution du nbre de référentiels affichés : risque d’écritures incohérentes
    Call AVERTIR(mess(201,105,1),OK) From GESECRAN
   Endif
   Filter [HAE]
  Endif
 Else
  For I=1 To [M:GDE1]NBRLED
   If [M:GDE1]OLDLEDTYP(I-1)<>[M:GDE1]LEDTYP(I-1)
    K = 1 : Break
   Endif
  Next
 Endif
 If K
  Gosub CHARGE_CHAMP
  Gosub LECTURE
  Gosub AFF
 Endif
 If [M:GDE1]NBRLED=1
  Actzo [M:GDE1]FLGEQL
 Else
  Effzo [M:GDE1]FLGEQL
  Grizo [M:GDE1]FLGEQL
 Endif
Endif
End

$CHARGE_TYPLED
For I=1 To [M:GDE1]NBRLED
 [M:GDE1]OLDLEDTYP(I-1)=[M:GDE1]LEDTYP(I-1)
Next
Return


######################################################################################
Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer I,NBLED, TYPREF
#-- Filtre des référentiels dits "Saisissable" pour les transactions Colonnes (2) & Lignes (1)
If [M]TYPENT<>3 #Onglet (3)
 For I=1 To len(mess(0,2644,1))
  For NBLED=1 To len(GLEDTYPAUT)
   TYPREF = val(mid$(GLEDTYPAUT,NBLED,1))
   # Gestion de la valeur 10
   If TYPREF=1 &  mid$(GLEDTYPAUT,NBLED+1,1)="0"
    If I=10 : GMENLOC(I) = 1 : Break : Endif
   Else
    If TYPREF = I : GMENLOC(I) = 1 : Break  : Endif
   Endif
  Next
 Next
Endif

#-- Filtre des référentiels : retire les référentiels déjà sélectionnés
For I=0 To [M:GDE1]NBRLED-1
 If I<>indice & [M:GDE1]LEDTYP(I)>0 # X3-38638 [M:GDE1]LEDTYP(I)<>0 to [M:GDE1]LEDTYP(I)>0 - BEFOU (1)
  GMENLOC([M]LEDTYP(I)) = 1 # Désactive le menu Local
 Endif
Next

End

######################################################################################
# Si le nombre de cours évolue, l'onglet "En tête" évolue également
######################################################################################
Subprog AM_NBRRAT(VALEUR)
Variable Decimal VALEUR
Local Integer NBDIE
[M:GDE1]NBRRAT=VALEUR
Gosub CHARGE_CHAMP
Gosub LECTURE
End

Subprog C_NBRRAT(VALEUR)
Variable Decimal VALEUR
If VALEUR>5 :
 # Nombre de cours devise saisissable limité à 5
 GMESSAGE= mess(171,107,1) : mkstat=2 : End
Endif
End

######################################################################################
# Si le Type de saisie évolue (colonne/ligne), l'onglet "Ligne" évolue également
######################################################################################
Subprog AM_TYPENT(VALEUR)
Variable Integer VALEUR
Local Integer NBDIE
[M:GDE1]TYPENT=VALEUR
Gosub CHARGE_CHAMP
Gosub LECTURE

If VALEUR=3
 [M:GDE1]FLGPAG=1 : Affzo [M:GDE1]FLGPAG : Grizo [M:GDE1]FLGPAG
Else
 Actzo [M:GDE1]FLGPAG
Endif

End

######################################################################################
####                                                                           #######
####    Ecrans Tableau Onglet 2, 3  et 4                                       #######
####                                                                           #######
######################################################################################
Subprog AM_DIE(VALEUR)
Variable Char    VALEUR()
[M:GDE4]FLD(nolign-1) = "CCE."+VALEUR
End

Subprog C_DIE(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:GDE4]DIE(0..[M:GDE4]NBRFLD-1)) From OBJDIV
End

######################################################################################
#
# Mode de saisie    DAC
#    1 - Saisi                            Le champ FLG permet de rendre non accessible
#    2 - Affiché                          les colonnes DEFVAL & CTL.
#    3 - Invisible                        Le champ FLG est initialisé en D & AS_DAC.
#
# Mode Fiche        CRD
#    1 - Non
#    2 - Oui
#
# Valeur par défaut DEFVAL & Contrôle CTL
#
######################################################################################
######################################################################################
Subprog D_DAC(VALEUR)
Variable Integer VALEUR
VALEUR=3
Local Integer NOL : NOL = nolign-1
If [M:GDE1]TYPENT=2 & [M]FLD(NOL)="IDT"                 # Champs uniquement saisi
 VALEUR = 1
Elsif find([M]FLD(NOL),"LEDT","DEB","CDT")              # Champs uniquement saisi
 VALEUR = 1
Elsif find(left$([M]FLD(NOL),3),"ACC","CCE")            # Champs saisi
 VALEUR = 1
# Issue X3-52045 - 2017-08-07 by FHA : field ORIGIN & ORICOD added
Elsif find([M]FLD(NOL),"DIA","BOL","DBAN","MOD","SIM","TYPO","NUMO","DACC","ORI","ORIC",
&                      "MTC","MDA","MDX","MDY","CHK","CHD",
&                      "VAT","LIN","CHR","UOM")            # Champs non saisi
 VALEUR = 2
 FLG(NOL)=2
Elsif GREP="C" & [M]FLD(NOL)="CSLC"
 VALEUR = 3
Endif
End

######################################################################################
Subprog AS_DAC(VALEUR)
Variable Integer VALEUR
Local Integer I,J,K
Local Integer NOL : # NOL = nolign-1
# MHB 25/09/08 - Si on ne calcule par NOL, on ne fait pas la vérification sur la bonne zone dans le cadre d'un import
If !GIMPORT Then
  NOL = nolign-1
Else
  K = find([F:GDD]FLD,[M]FLD)
  NOL = max(0,K-1)
Endif
If [M:GDE1]TYPENT=2 & [M]FLD(NOL)="IDT"                 # Champs uniquement saisi
 VALEUR = 1 : mkstat = 2 : End
Elsif find([M]FLD(NOL),"LEDT","DEB","CDT")              # Champs uniquement saisi
 VALEUR = 1 : mkstat = 2 : End
Elsif find([M]FLD(NOL),"ACCDAT")                        # Champs  saisi/affiché
  GMENLOC(3) = 1
Elsif find(left$([M]FLD(NOL),3),"ACC")                  # Champs uniquement saisi
 VALEUR = 1 : mkstat = 2 : End
Elsif find(left$([M]FLD(NOL),3),"CCE","MLT","DIV",
&                               "JOU","CAT","STA")      # Champs  saisi/affiché
  GMENLOC(3) = 1
Elsif find([M]FLD(NOL),"TYP","NUM","FCY")               # Champs  saisi/affiché
  GMENLOC(3) = 1
# Issue X3-52045 - 2017-08-07 by FHA : field ORIGIN & ORICOD added
Elsif find([M]FLD(NOL),"DIA","BOL","DBAN","MOD","SIM","TYPO","NUMO","DACC","ORI","ORIC",
&                      "MTC","MDA","MDX","MDY","CHK","CHD",
&                      "VAT","LIN","CHR","UOM")            # Champs non saisi
  GMENLOC(1) = 1
  FLG(NOL)=2
Elsif [M]FLD(NOL)="BPR"            # Champ saisi si au moins un collectif saisi
  I = find("SAC1",[M]FLD(1..dim([M]FLD)-1))
  If I & evalue("[M]DAC("+num$(I)+")")=1
       VALEUR=1 :  mkstat=2
  Elsif [M]TYPENT=1 & [M]NBRLED>1  # Autant de collectifs que de référentiel en Saisie en colonne
   For J=2 To [M]NBRLED            # Même contrôle...
    I = find("SAC"+num$(J),[M]FLD(1..dim([M]FLD)-1))
    If I & evalue("[M]DAC("+num$(I)+")")=1
       VALEUR=1 :  mkstat=2 : Break
    Endif
   Next
  Endif
Endif
End

######################################################################################
Subprog C_DAC(VALEUR)
Variable Integer VALEUR
Local Integer I,J,K
Local Integer NOL : # NOL = nolign-1
# MHB 25/09/08 - Si on ne calcule par NOL, on ne fait pas la vérification sur la bonne zone dans le cadre d'un import
If !GIMPORT Then
  NOL = nolign-1
Else
  K = find([F:GDD]FLD,[M]FLD)
  NOL = max(0,K-1)
Endif
If find(left$([M]FLD(NOL),3),"SAC") & VALEUR=1  # Tiers est saisi si au moins un collectif saisi
  I = find("BPR",[M]FLD(1..dim([M]FLD)-1))
  If I
    [M]DAC(I)=1  : Affzo [M]DAC(I)
  Endif
Endif
End

######################################################################################
Subprog D_CRD(VALEUR)
Variable Integer VALEUR
Local Integer NOL : NOL = nolign-1
If find([M]FLD(NOL),"FCYL","IDT","LEDT","BPR","DEB","CDT","DSP")
 VALEUR = 1
Elsif find(left$([M]FLD(NOL),3),"ACC","CCE","SAC")
 VALEUR = 1
Endif
End

Subprog AS_CRD(VALEUR)
Variable Integer VALEUR
Local Integer NOL : NOL = nolign-1
If find([M]FLD(NOL),"FCYL","IDT","LEDT","BPR","DEB","CDT","DSP")
 VALEUR = 1 : mkstat = 2
Elsif find(left$([M]FLD(NOL),3),"ACC","CCE","SAC")
 VALEUR = 1 : mkstat = 2
Endif
End

######################################################################################
Subprog AS_DEFVAL(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : NOL = nolign-1
If [M]FLG(NOL)=2
 mkstat = 1 : End
Endif
End

######################################################################################
Subprog C_DEFVAL(VALEUR)
Variable Char    VALEUR()
# A priori, uniquement pour l'écran GDIANTRY4, Onglet Sections
If !clalev([F:CCE]) : Local File "CACCE"  [CCE] : Endif
Call LECTURE("CCE",VALEUR,[M:GDE4]DIE(nolign-1)) From CONTOBJ
If !fstat
 If [M]GFY<>"" & [F:CCE]FCY<>"" & [M]GFY<>[F:CCE]FCY
  Call COMPAT([M]GFY,[F:CCE]FCY,VALEUR) From CFYSUB
  If mkstat=2 : End : Endif
 Endif
 VALEUR='"'+VALEUR+'"'
Endif
End

$BS_DEFVAL
VALEUR='"'+VALEUR+'"'
Return

######################################################################################
Subprog AS_CTL(VALEUR)
Variable Char     VALEUR
Local Integer NOL : NOL = nolign-1
If [M]DAC(NOL)=3 or [M]FLG(NOL)=2
 mkstat = 1 : End
Endif
End

Subprog C_GFY(VALEUR)
Variable Char    VALEUR()
Local Shortint STAT
Local Char MESSA(250)
Call CNTCOHGRPLEG(VALEUR,GCURLEG,STAT,MESSA) From CPTCNT
If !STAT
 GMESSAGE=MESSA
 mkstat=2 : End
Endif
End

######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
End

######################################################################################

Subprog C_DIAACC(VALEUR)
Variable Char    VALEUR()
If [M]GFY<>"" & [F:GDA]GFY<>"" & [M]GFY<>[F:GDA]GFY
 Call COMPAT([M]GFY,[F:GDA]GFY,VALEUR) From CFYSUB
 If mkstat=2 : End : Endif
Endif
End


######################################################################################

