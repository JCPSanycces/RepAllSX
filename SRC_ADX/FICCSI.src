#<AdxTL>@(#)0.0.0.0 $Revision$
#** V7 : Waiting Time Management **#

#########################################################################
# FICCSI : Fiche parcours individualisé                                          #
# --------------------------------------------------------------------- #
#########################################################################

Call IMPRIME("FICCSI","") From ETAT
End


####################################################
## Parcours individualisé par salarié
####################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)

#-----
Call EXEC(NBPAR,PARAMETRE)
#-----
End

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()(1..)

Call TEMPON("O") From GESECRAN


#-----
Gosub OUVRE   : # Ouverture des tables
If GERREUR  GERREUR=0 : End : Endif
#-----

#-----
Gosub DECLARE : # Déclaration des variables globales
# On rajoute le paramètre COUPED en critère
Call PARAM("","COUPED",[L]WCOUPED) From ADOVAL
For I=1 To NBPAR
  J=instr(1,[L]PARAMETRE(I),"=")
  If J
    [L]PARAM  = left$([L]PARAMETRE(I),J-1)
    Call GETPARAM([L]PARAM,NBPAR,PARAMETRE,[L]VALEUR) From ETAT
    Case [L]PARAM
      When "couped"          : [L]PARAMETRE(I)   = "couped="+[L]WCOUPED
    Endcase
  Endif
Next
#-----
Call GETPARAM("X3ETA",NBPAR,PARAMETRE,ETAT)
Call GETPARAM("csideb",NBPAR,PARAMETRE,CSIDEB)
Call GETPARAM("csifin",NBPAR,PARAMETRE,CSIFIN)
Call GETPARAM("cpydeb",NBPAR,PARAMETRE,CPYDEB)
Call GETPARAM("cpyfin",NBPAR,PARAMETRE,CPYFIN)
Call GETPARAM("fcydeb",NBPAR,PARAMETRE,FCYDEB)
Call GETPARAM("fcyfin",NBPAR,PARAMETRE,FCYFIN)
Call GETPARAM("matdeb",NBPAR,PARAMETRE,MATDEB)
Call GETPARAM("matfin",NBPAR,PARAMETRE,MATFIN)
Call GETPARAM("population",NBPAR,PARAMETRE,POPULATION)
Call GETPARAM("datdeb",NBPAR,PARAMETRE,PARAM) : DATDEB=PARAM
Call GETPARAM("datfin",NBPAR,PARAMETRE,PARAM) : DATFIN=PARAM
Call GETPARAM("potdeb",NBPAR,PARAMETRE,POTDEB)
Call GETPARAM("potfin",NBPAR,PARAMETRE,POTFIN)
Call GETPARAM("jotdeb",NBPAR,PARAMETRE,JOTDEB)
Call GETPARAM("jotfin",NBPAR,PARAMETRE,JOTFIN)
Call GETPARAM("tcsdeb",NBPAR,PARAMETRE,TCSDEB)
Call GETPARAM("tcsfin",NBPAR,PARAMETRE,TCSFIN)
Call GETPARAM("flgpro",NBPAR,PARAMETRE,PARAM) : PROFLG=val(PARAM)


Call GETPARAM("__REQUETE",NBPAR,PARAMETRE,PARAM) : [L]NUMREQ = val(PARAM)

PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

CRITERE1 = "[F:ID]ENAFLG=2"
CRITERE2 = "([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=date$)"
# Comme dans l'état FICINS lien entre EMPCTR et FACGROUP pour tester les bornes de société
If CPYDEB<>"" : CRITERE1 -= "& [F:FGR]CPY>='"+CPYDEB+"'"    : Endif
If CPYFIN<>"" : CRITERE1 -= "& [F:FGR]CPY<='"+CPYFIN+"'"    : Endif
If FCYDEB<>"" : CRITERE1 -= "& [F:ECT]FCY>='"+FCYDEB+"'"    : Endif
If FCYFIN<>"" : CRITERE1 -= "& [F:ECT]FCY<='"+FCYFIN+"'"    : Endif
If MATDEB<>"" : CRITERE2 -= "& [F:ECT]REFNUM>='"+MATDEB+"'" : Endif
If MATFIN<>"" : CRITERE2 -= "& [F:ECT]REFNUM<='"+MATFIN+"'" : Endif

[L]CRITCSI1 = "1=1"
[L]CRITCSI2 = "1=1"
If CSIDEB<>"" : CRITCSI1 -= "& [F:CSI2]COD>='"+CSIDEB+"'" : Endif
If CSIFIN<>"" : CRITCSI1 -= "& [F:CSI2]COD<='"+CSIFIN+"'" : Endif
If POTDEB<>"" : CRITCSI1 -= "& [F:CSI2]POT>='"+POTDEB+"'" : Endif
If POTFIN<>"" : CRITCSI1 -= "& [F:CSI2]POT<='"+POTFIN+"'" : Endif
If JOTDEB<>"" : CRITCSI1 -= "& [F:CSI2]JOBPOT>='"+JOTDEB+"'" : Endif
If JOTFIN<>"" : CRITCSI1 -= "& [F:CSI2]JOBPOT<='"+JOTFIN+"'" : Endif
If TCSDEB<>"" : CRITCSI1 -= "& [F:CSI2]TCS>='"+TCSDEB+"'" : Endif
If TCSFIN<>"" : CRITCSI1 -= "& [F:CSI2]TCS<='"+TCSFIN+"'" : Endif

# Si la date de la table STRDAT n'est pas obligatoire
#    Si paramètre DATDEB n'est pas renseigné on laisse passé [L]DATDEB > gdat$(01,01,1900)
#    Si la date de la table STRDAT n'est pas renseignée on laisse passé [F:CSI2]STRDAT < [01/01/1900])
# Sinon il suffit de faire le test [F:CSI2]STRDAT >=["+format$(GFMD,[L]DATDEB)+']'
If [L]DATDEB > gdat$(01,01,1900)
#   [L]CRITCSI2 -= "& (([F:CSI2]STRDAT >=["+format$(GFMD,[L]DATDEB)+']'
#&                  +" & [F:CSI2]STRDAT > [01/01/1900]) | [F:CSI2]STRDAT < [01/01/1900])"
   [L]CRITCSI2 -= "& (([F:CSI2]STRDAT <=["+format$(GFMD,[L]DATFIN)+']'
&                  +" & [F:CSI2]STRDAT > [01/01/1900]) | [F:CSI2]STRDAT < [01/01/1900])"

Endif
If [L]DATFIN > gdat$(01,01,1900)
#   [L]CRITCSI2 -= "& (([F:CSI2]ENDDAT <=["+format$(GFMD,[L]DATFIN)+']'
#&                  +" & [F:CSI2]ENDDAT > [01/01/1900]) | [F:CSI2]ENDDAT < [01/01/1900])"
   [L]CRITCSI2 -= "& (([F:CSI2]ENDDAT >=["+format$(GFMD,[L]DATDEB)+']'
&                  +" & [F:CSI2]ENDDAT > [01/01/1900]) | [F:CSI2]ENDDAT < [01/01/1900])"
Endif
If [L]PROFLG = 1
  [L]CRITCSI2 -= "& [F:CSI2]FLGPRO<>2"
Endif
If [L]PROFLG = 2
  [L]CRITCSI2 -= "& [F:CSI2]FLGPRO=2"
Endif

# Comme dans l'état FICINS lien entre EMPCTR et FACGROUP pour tester les bornes de société
If [L]POPULATION<>""
 Link [ECT] With
&   [ID]ID0=[F:ECT]REFNUM
& , [HRCTR]CTR2=[F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR
& , [FGR]FGR1(1)=[F:ECT]FCY
& , [HRPOA]POA0=[L]POPULATION;[F:ECT]REFNUM
& As [LID]
& Where evalue(CRITERE1) & evalue(CRITERE2) & [F:HRPOA]REFNUM<>""
Else
 Link [ECT] With
&   [ID]ID0=[F:ECT]REFNUM
& , [HRCTR]CTR2=[F:ECT]REFNUM;[F:ECT]CTRNUM;[F:ECT]NBRCTR
& , [FGR]FGR1(1)=[F:ECT]FCY
& As [LID]
& Where evalue(CRITERE1) & evalue(CRITERE2)
Endif


Call DEBTRANS From GLOCK
Gosub TR1
Call DEBTRANS From GLOCK
Gosub TR2
Call TEMPOFF From GESECRAN
End

$TR1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER
Commit
Return

$TR2
Trbegin [ARM]
 I=1
 For [LID]ECT0(2)
  Filter [F:CSI2] Where REFNUM=[F:ECT]REFNUM & CTR=[F:ECT]CTRNUM & evalue(CRITCSI1) & evalue(CRITCSI2)
  For [CSI2]CSI3
    Raz [F:ARM]
    [F:ARM]USR    = GUSER
    [F:ARM]RPTCOD = [L]ETAT
    [F:ARM]NUMREQ = [L]NUMREQ
    [F:ARM]NUMLIG = I
    [F:ARM]CLEA1  = [F:CSI2]COD
    [F:ARM]CLEA2  = [F:ECT]REFNUM
    [F:ARM]CLEA3  = [F:ECT]CTRNUM
    #ADNGO - 2017-02-15 - START
#** V7 : Waiting Time Management **#
#    If GPAYE
#      Call SOLDE_DIF([F:ECT]REFNUM,[F:ECT]CTRNUM,[F:CSI2]STRDAT,SOLDE) From DIVPAYE
#      [F:ARM]CLEMD1 = SOLDE
#    Else
#      [F:ARM]CLEMD1 = [F:CSI2]NBRHOUDIF
#    Endif
     If GPAYE
      Call SOLDE_DIF([F:ECT]REFNUM,[F:ECT]CTRNUM,[F:CSI2]STRDAT,SOLDE) From DIVPAYE
      [F:ARM]CLEMD1 = SOLDE
    Else
      [F:ARM]CLEMD1 = [F:CSI2]NBRHOUDIF
    Endif
    #ADNGO - 2017-02-15 - END
    [F:ARM]CLEMD1 = [F:CSI2]NBRHOUDIF
    Write [ARM]
    If fstat
     GOK = 0 : Call FSTA("ARM") From GLOCK : Break 2
    Endif
   I+=1
  Next
 Next
 Filter [F:CSI2]
 If GOK=0
  Goto AB_TR2
 Elsif GOK=-1
  Goto ROLL_TR2
 Endif
Commit
Return


$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif
Return

$AB_TR2
Rollback
Return

$OUVRE
If clalev([F:ARM])=0    : Local File AREPORTM  [ARM]  : Endif
If clalev([F:ECT])=0    : Local File EMPCTR    [ECT]  : Endif
If clalev([F:CSI2])=0   : Local File COURSEI   [CSI2] : Endif
If clalev([F:FGR])=0    : Local File FACGROUP  [FGR]  : Endif
If clalev([F:HRPOA])=0    : Local File POPULA    [HRPOA]  : Endif
If clalev([F:HRCTR])=0  : Local File EMPLOCTR  [HRCTR]: Endif
If clalev([F:ID])=0     : Local File EMPLOID   [ID]   : Endif
Return

$DECLARE
Local Char    VALEUR(30)
Local Integer  I, J
Local Char WCOUPED(20)
Local Char    PARAM(20), ETAT(GLONARP), CRITERE1(250), CRITERE2(250), CRITCSI1(250), CRITCSI2(250)
Local Char    CSIDEB(GLONCSI),CSIFIN(GLONCSI)
Local Char    CPYDEB(GLONCPY), CPYFIN(GLONCPY), FCYDEB(GLONFCY), FCYFIN(GLONFCY)
Local Char    MATDEB(GLONEML), MATFIN(GLONEML),POPULATION(GLONPOP)
Local Char    POTDEB(GLONPOT),POTFIN(GLONPOT)
Local Char    JOTDEB(GLONJOT),JOTFIN(GLONJOT)
Local Char    TCSDEB(GLONTCS),TCSFIN(GLONTCS)
Local Integer PROFLG

Local Decimal NUMREQ
Local Date    DATDEB, DATFIN
Local Decimal SOLDE


Return


Subprog GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR)
Value    Char    PARAM
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Variable Char    VALEUR
Local Integer L
Call GETPARAM(PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
L = len(PARAM)
If right$(PARAM,L-2)="deb"
 If VALEUR=string$(len(VALEUR)," ") : VALEUR = "" : Endif
Elsif right$(PARAM,L-2)="fin"
 If VALEUR=string$(len(VALEUR),"z") : VALEUR = "" : Endif
Endif
End

