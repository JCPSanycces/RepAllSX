#<AdxTL>@(#)5.0.0.0 $Revision$
If 1
  Local Char PARAM(20)(1..3) , VALEUR(20)
  PARAM(1) = "PF-VERSMIN_CCZ_5" : # Product
  PARAM(2) = "2"                : # Alternative type (menu 224)
  Call TRAITE_CHAR(VALEUR,PARAM,"","CREEVL","DCREEVL",3,"") From GTRAITE
  Infbox "PARAM(3)="+PARAM(3)   : # returns 0 if KO, ECCSEQ>0 if OK
Else
  Call TR_EXEC2("PF-VERSMIN_CCZ_5",2,[18/08/2015],"","","CREEVL","")
  If GERR
     If GMESSAGE<>""
        Call ERREUR(GMESSAGE) From GESECRAN
        GMESSAGE=""
     Endif
     GERR=0
  Else
     # if GOK<1, a log displays errors
     Infbox "GOK="+num$(GOK)
  Endif
Endif
End

$ACTION
Case ACTION
  When "INIT"        : Gosub INIT
  When "AVANT_PAR"   : Gosub AVANT_PAR
  When "INIT_DIA"    : Gosub INIT_DIA
  When "CONTROLE"    : Gosub CONTROLE
  When "EXEC"        : Gosub EXEC
  When "SORTIE"      : Gosub SORTIE

  When "BOITE"       : Gosub BOITE
  When "IMPZON"      : Gosub IMPZON
  When "CREATION"    : Gosub CREATION
  When "APRES_REV"   : Gosub GNRUBM
Endcase
Return

############################################################################################
## Generate of a new BOM version in development from the last one available to use
## GH 03/15
############################################################################################

$INIT
Local Char    ITM([V]GLONITM)
Local Integer TYPALT
Local Integer TRC, TYPREV

ITM    = [L]PARAM(1)
TYPALT = val([L]PARAM(2))
[L]PARAM(3)="0"

Gosub VERIF
If GERR=-1
   GMESSAGE=mess(14,195,1)-[L]ITM+"\"+GMESSAGE : # Item
   GERR=1
Endif
If GERR : FIN=1 : Endif
Return

$VERIF
If !clalev([F:EVL])  : Local File ECCVAL    [EVL]  : Endif
If !clalev([F:ITM])  : Local File ITMMASTER [ITM]  : Endif
If !clalev([F:TBO])  : Local File TABBOMALT [TBO]  : Endif

Local Integer SEQ, ALT1, ALT2, NIV
Local Char    FCY1(GLONFCY)
Local Char    SAVFONCION([V]GLONAFC)

SAVFONCTION = GFONCTION

Read [ITM]ITM0 = [L]ITM
If !fstat
   NIV = func ECCLIB.NBRCPN([L]ITM)
Endif
If NIV<1
   GERR=1 : GMESSAGE = mess(153,187,1)-[L]ITM : # Versions not managed on this product
   Return
Endif
ALT1 =  evalue("[F:ITM]ECCBOMALT"+num$([L]TYPALT)+"(0)")
If ALT1=0
   GERR=-1 : GMESSAGE = mess(309,193,1)-"("+mess(1,240,1)+")" : # BOM code not defined
   Return
Endif

Filter [EVL] Where ITMREF=[L]ITM & ECCTYP=[L]TYPALT
Read [EVL]EVL0 Last
Filter [EVL]
If fstat>2
   GERR=-1 : GMESSAGE = mess(308,193,1) : # Non existing version
   Return
Elsif [F:EVL]USESTA=1
   # Last version ... In development
   GERR=-1 : GMESSAGE = mess(311,193,1)-[F:EVL]ECCVALMAJ-[F:EVL]ECCVALMIN-":"-mess(1,240,1)
   Return
Elsif [F:EVL]ENDDAT<>[0/0/0]
   Call TEXTFIC("ECCVAL","ENDDAT",1,GMESSAGE) From OBJDIV
   # Last version ... Ending date
   GERR=-1 : GMESSAGE = mess(311,193,1)-[F:EVL]ECCVALMAJ-[F:EVL]ECCVALMIN-":"-GMESSAGE-"="-format$("D:"+GFMDAT4,[F:EVL]ENDDAT)+")"
   Return
Endif
[L]SEQ  = [F:EVL]ECCSEQ
[L]ALT2 = [F:EVL]BOMALT

If [L]ALT1=[L]ALT2
   GERR=-1 : GMESSAGE = mess(314,193,1)-"("+num$([L]ALT1)+")"-":"-mess(1,240,1)-","-mess(2,240,1) :  # Same BOM codes
   Return
Endif

Read [TBO]TBO0 = [L]TYPALT;[L]ALT1
If fstat
   GERR=1 : GMESSAGE = num$([L]ALT1)-":"-mess(154,193,1) : # Non existing BOM code
   Return
Endif
[L]FCY1 =[F:TBO]FCY

Read [TBO]TBO0 = [L]TYPALT;[L]ALT2
If fstat
   GERR=1 : GMESSAGE = num$([L]ALT2)-":"-mess(154,193,1) : # Non existing BOM code
   Return
Endif
If [L]FCY1<>[F:TBO]FCY
   GERR=-1 : GMESSAGE = mess(310,193,1) : # Incompatible sites between BOM codes for versioning
   Return
Endif

#GPROFIL="GL"
GFONCTION="CREEVL"
Call AUTORIS From EXEFNC
If GNBAUZ=0
  GERR=1
Elsif GUSRFCY(1)<>"\"
  If [L]FCY1<>""
     If !find([L]FCY1,GUSRFCY(1..GNBAUZ)) : GERR=1 : Endif
  Else
     # At least one authorized site (for sales, production, stock) according to the BOM type (commercial, production, SST)
     Case [L]TYPALT
       When 1 : CRITFCY = "SALFLG=2"
       When 2 : CRITFCY = "MFGFLG=2"
       When 3 : CRITFCY = "WRHFLG=2"
     Endcase
     GERR=1
     Local File FACILITY [FCY]
     For [FCY]FCY0 Where evalue(CRITFCY)
         If find([F:FCY]FCY,GUSRFCY(1..GNBAUZ)) : GERR=0 : Break : Endif
     Next
  Endif
Endif
If GERR
   GMESSAGE=mess(1,123,1) : # Unauthorized function
   Return
Endif

# Lock management
If !func ECCLIB.LCKBOH([L]ITM,[L]ALT2,[L]TYPALT)
   GERR=1 : GMESSAGE=mess([L]TYPALT,2059,1)-[L]ITM-num$([L]ALT2)+"\"+mess(10,100,1) : Return
Endif
Return

#############################################################

$SORTIE
#GPROFIL="ADMIN"
GFONCTION=SAVFONCTION
Call AUTORIS From EXEFNC

Call DELOCK("BOH") From GLOCK : # Call DELOCK("BOH\") From GLOCK # Issue 118592 GH 20/09/2016
Return

#############################################################

$AVANT_PAR
If SAI : Raz [M:EVLB]INV : Endif : # to redo diszo instructions
Return

#############################################################

$INIT_DIA
Raz [M:EVLB]
[M:EVLB]TYPALT = [L]TYPALT
[M:EVLB]ITMREF = [L]ITM
[M:EVLB]NIV    = [L]NIV

Read [EVL]EVL0 = [L]ITM;[L]SEQ;[L]TYPALT
If fstat : Raz [F:EVL] : Endif
[M:EVLB]ECCVALMAJ = [F:EVL]ECCVALMAJ
[M:EVLB]ECCVALMIN = [F:EVL]ECCVALMIN
[M:EVLB]STRDAT    = [F:EVL]STRDAT
[M:EVLB]ENDDAT    = [F:EVL]ENDDAT
[M:EVLB]BOMALT    = [F:EVL]BOMALT
[M:EVLB]DATCRE=max(date$,[M:EVLB]STRDAT)+1
[M:EVLB]TYPCRE    = [L]NIV
Call AM_TYPCRE([M:EVLB]TYPCRE)
Return

#############################################################

$CONTROLE
If [M:EVLB]NEWVALMAJ="" | ([M:EVLB]TYPCRE=2 & [M:EVLB]NEWVALMIN="")
   Call LIENS("AMK","AMSK","CREEVL","","num$([F:AMK]TITBLOC(1))",GMESSAGE) From CONTOBJ
   Call TEXTE(val(GMESSAGE),GMESSAGE) From OBJDIV
   GERR=1 : GMESSAGE+="\"+mess(141,143,1)
   SAI=1
Else
   Look [EVL]EVL1 = [L]ITM;[M:EVLB]NEWVALMAJ;[M:EVLB]NEWVALMIN;[L]TYPALT
   If !fstat
      Call LIENS("AMK","AMSK","CREEVL","","num$([F:AMK]TITBLOC(1))",GMESSAGE) From CONTOBJ
      Call TEXTE(val(GMESSAGE),GMESSAGE) From OBJDIV
      GERR=1 : GMESSAGE+="\"+mess(61,127,1)
      SAI=1
   Endif
Endif
Return

#############################################################

$EXEC
GOK=1
[L]TYPREV = 2-([M:EVLB]ECCVALMAJ<>[M:EVLB]NEWVALMAJ) : # 1 = major / 2=minor

If ![V]GSERVEUR & GTRACE=""
   Call OUVRE_TRACE(TITCRIT) From LECFIC
   TRC=1
Endif

Call TR_EXEC1([L]ITM,[L]TYPALT,[M:EVLB]DATCRE,[M:EVLB]NEWVALMAJ,[M:EVLB]NEWVALMIN,[L]ALT1,[L]ALT2,[L]SEQ,[L]TYPREV,"CREEVL")
If GOK<1 or GERR=1 : SAI=1 : Endif
If TRC
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE From LECFIC
Endif
If SAI=1 : Return : Endif

[L]PARAM(3) = num$([L]SEQ+1)
Return

#############################################################
## Duplication (header + lines + text) of the last BOM available to use into a new one in development
## + Setting of a new version associated with this BOM in development

Subprog TR_EXEC1(ITM,TYPALT,DATCRE,VMAJ,VMIN,ALT1,ALT2,SEQ,TYPREV,TRTSUI)
Value Char    ITM()
Value Integer TYPALT
Value Date    DATCRE
Value Char    VMAJ(), VMIN()
Value Integer ALT1, ALT2
Value Integer SEQ, TYPREV
Value Char    TRTSUI()

Local Char ABREV(GLONAOB), TRTGBM(GLONADC)

[L]TRTGBM="CREEVL"
[L]ABREV="BOD"
Case [L]TYPALT
 When 1 : GFONBOD="BOMC"
 When 2 : GFONBOD="BOMP"
 When 3 : GFONBOD="BOMS" : [L]ABREV="BOS"
Endcase

If dim([V]GDATEREF)=1
   Local Date SAVDATEREF
   [L]SAVDATEREF = [V]GDATEREF
Endif

Gosub DEFVAR From OBJSIM

Gosub TR

Gosub RESTGLO From OBJSIM

If dim([V]GDATEREF)=1 & dim([L]SAVDATEREF)=1
   [V]GDATEREF=[L]SAVDATEREF
Endif
End

$TR
Read [BOH]BOH0 = [L]ITM;[L]ALT2;[L]TYPALT
If fstat
   GOK=0 : Call RSTA("BOH",[L]ITM-num$([L]ALT2)-num$([L]TYPALT)) From GLOCK : Return
Endif

GDATEREF=[0/0/0]
Gosub CHARGE From OBJSIM
#
[V]GREP="D" : [M:BOH0]NEWALT = [L]ALT1
Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
[L]ACTION="RAZDUP" : Gosub ACTION From GOBJSUB
For [L]MA=0 To [L]NBMASK
  Gosub SETMASK From =[L]WINPROG
  Call SAIMSK("","IMPZON","CREEVL") From ="W0"+[L]NOMMSK([L]MA)
  If mkstat : [V]GOK=0 : Break : Endif
Next

If [V]GOK>0
   If !adxlog
     Gosub CREATION From GOBJET1
   Else
     Gosub CREATION From OBJSIM
   Endif
Endif
Setmode

If GOK>0 & [L]TRTSUI<>""
   ACTION = "APRES_REV" : Gosub ACTION From =[L]TRTSUI
Endif
Return

$BOITE
Case [L]TYPALT
 When 1 : GBOITE="OBOD"
 When 2 : GBOITE="OBODP"
 When 3 : GBOITE="OBODS"
Endcase
Return

$IMPZON
Case IMPZON
   When "BOMALT" : [M]BOMALT = [M:BOH0]NEWALT
Endcase
Return

$CREATION
Call DUPTEXTRA("BOM","BOMDESAXX",[M:BOH0]ITMREF+"~"+num$([L]ALT2),num$([L]TYPALT)
&             ,"BOM","BOMDESAXX",[M:BOH0]ITMREF+"~"+num$([M:BOH0]BOMALT),num$([L]TYPALT)) From ATEXTRA

Raz [F:EVL]
[F:EVL] = [F:BOH]
[F:EVL]ECCSEQ    = [L]SEQ+1
[F:EVL]ECCTYP    = [L]TYPALT
[F:EVL]STRDAT    = [L]DATCRE
[F:EVL]ECCVALMAJ = [L]VMAJ
[F:EVL]ECCVALMIN = [L]VMIN
[F:EVL]EXNFLG    = 1
If dim([F:EVL]UPDBOMNUM)=1
   [F:EVL]UPDBOMNUM = ""
   [F:EVL]UPDBOMFLG = 1 : # [F:EVL]UPDBOMFLG = 1 + ([L]TYPREV=1) : # to desactivate till propagation is not delivered
Endif

Write [EVL]
If fstat
   GOK=0 : Call FSTA("EVL") From GLOCK : Return
Endif
Return

$GNRUBM
If adxlog | dim([F:EVL]UPDBOMNUM)<0 : Return : Endif

Read [EVL]EVL0 = [L]ITM;[L]SEQ+1;[L]TYPALT
If !fstat & [F:EVL]UPDBOMFLG  = 2 & [F:EVL]UPDBOMNUM=""
   Local Char NUMUPD([V]GLONUBH)
   Call GENERE([L]ITM,[L]SEQ+1,[L]TYPALT,[L]NUMUPD) From CREUBM
Endif
Return

#**----------------------------------------------------------------<br/>
#* Generate of a new BOM version in development from the last one available to use
#**<br/>----------------------------------------------------------------<br/>
#* @param ITM    = Product
#* @param TYPALT = Alternative type (menu 224)
#* @param DATCRE = Start date of new version in development
#* @param VMAJ   = New major version number
#* @param VMIN   = New minor version number
#* @param OPT    = Option : "D" then don't block if DATDRE is in the past
#**<br/>----------------------------------------------------------------
#*!

Subprog TR_EXEC2(ITM,TYPALT,DATCRE,VMAJ,VMIN,TRTSUI,OPT)
Value Char    ITM()
Value Integer TYPALT
Value Date    DATCRE
Value Char    VMAJ(), VMIN()
Value Char    TRTSUI()
Value Char    OPT()     # Issue 115658 - 2016-11-18 by CCC : allow to create old versions during import

Local Integer TRC, TYPREV

# INIT
GERR=0 : GMESSAGE="" : GOK=1
Gosub VERIF
If GERR=-1
   GMESSAGE=mess(14,195,1)-[L]ITM+"\"+GMESSAGE : # Item
   GERR=1
Endif
If GERR : Goto FIN2 : Endif

# C_DATCRE
Read [EVL]EVL0 = [L]ITM;[L]SEQ;[L]TYPALT
If fstat
   GERR=1 : GMESSAGE = mess(308,193,1) : # Non existing version
Elsif [L]DATCRE <= [F:EVL]STRDAT
   GERR=1 : GMESSAGE = mess(312,193,1) : # Date <= starting validity of the last  version
Elsif [L]DATCRE <= date$
&   & instr(1,OPT,"D")=0    # Issue 115658 - 2016-10-12 by CCC
   GERR=1 : GMESSAGE = mess(72,199,1) : # Date must be after current date
Endif
If GERR : Goto FIN2 : Endif

# CONTROLE
If [L]VMAJ="" | ([L]NIV=2 & [L]VMIN="")
   Call LIENS("AMK","AMSK","CREEVL","","num$([F:AMK]TITBLOC(1))",GMESSAGE) From CONTOBJ
   Call TEXTE(val(GMESSAGE),GMESSAGE) From OBJDIV
   GERR=1 : GMESSAGE-=":"-mess(141,143,1)
Else
   Look [EVL]EVL1 = [L]ITM;[L]VMAJ;[L]VMIN;[L]TYPALT
   If !fstat
      Call LIENS("AMK","AMSK","CREEVL","","num$([F:AMK]TITBLOC(1))",GMESSAGE) From CONTOBJ
      Call TEXTE(val(GMESSAGE),GMESSAGE) From OBJDIV
      GERR=1 : GMESSAGE-=[L]VMAJ-[L]VMIN-":"-mess(61,127,1)
   Endif
Endif
If GERR : Goto FIN2 : Endif

[L]TYPREV = 2-([F:EVL]ECCVALMAJ<>[L]VMAJ) : # 1 = major / 2=minor

If clalev([F:ATX])=0 : Local File ATEXTE   [ATX] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX] : Endif

If ![V]GSERVEUR & GTRACE=""
   Local Char TIT([V]GLONDES)
   Call TITAWI("DCREEVL",TIT) From OBJDIV
   Call OUVRE_TRACE(TIT) From LECFIC
   TRC=1
Endif
Call TR_EXEC1([L]ITM,[L]TYPALT,[L]DATCRE,[L]VMAJ,[L]VMIN,[L]ALT1,[L]ALT2,[L]SEQ,[L]TYPREV,[L]TRTSUI)
If TRC
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE From LECFIC
Endif

$FIN2
Gosub SORTIE
End

######################################################################################
## Labels for screen CREEVL  16/02/2015 15:18:25 (GH)
######################################################################################

Subprog D_INV(VALEUR)
Variable Char    VALEUR

If [M:EVLB]NIV=1
   [M:EVLB]TYPCRE=1 : Affzo [EVLB]TYPCRE : Diszo [EVLB]TYPCRE
Else
   Actzo [EVLB]TYPCRE
Endif
End

######################################################################################

Subprog C_DATCRE(VALEUR)
Variable Date    VALEUR

If [M:EVLB]ECCVALMAJ=""
   GMESSAGE = mess(311,193,1)+"\"+mess(10,123,1) : mkstat=2 : # Last version\Mandatory field
Elsif VALEUR <= [M:EVLB]STRDAT
   GMESSAGE = mess(312,193,1) : mkstat=2 : # Date <= starting validity of the last  version
Elsif VALEUR <= date$
   GMESSAGE = mess(72,199,1) : mkstat=2 : # Date must be after current date
Endif
End

######################################################################################

Subprog AM_TYPCRE(VALEUR)
Variable Integer VALEUR

If !clalev([F:ITM])  : Local File ITMMASTER [ITM]  : Endif
Local Integer STAT
Local Char    MSG(250)

If [F:ITM]ITMREF<>[M:EVLB]ITMREF
   Read [ITM]ITM0 = [M:EVLB]ITMREF
   If fstat : Raz [F:ITM] : Endif
Endif

Raz [M:EVLB] NEWVALMAJ, NEWVALMIN
Case VALEUR
  When 1 : # major revision
    Call CALCUL([F:ITM]ECCMAJ,[M:EVLB]ECCVALMAJ,[M:EVLB]NEWVALMAJ,MSG,STAT) From SUBICV
    If [M:EVLB]ECCVALMIN<>"" & [L]STAT=0
       Call CALCUL([F:ITM]ECCMIN,"",[M:EVLB]NEWVALMIN,MSG,STAT) From SUBICV
    Endif
  When 2 : # minor revision
    [M:EVLB]NEWVALMAJ = [M:EVLB]ECCVALMAJ
    Call CALCUL([F:ITM]ECCMIN,[M:EVLB]ECCVALMIN,[M:EVLB]NEWVALMIN,MSG,STAT) From SUBICV
Endcase
If STAT
   Raz [M:EVLB] NEWVALMAJ, NEWVALMIN
Endif
Affzo [EVLB] NEWVALMAJ, NEWVALMIN
End

