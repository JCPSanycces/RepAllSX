#<AdxTL>@(#)34.0.0.0 $Revision$
#CHECK IGNORE_SOURCE
#LS Utilitaire de suppression d'un fichier sur le disque
#8 juin 1998

Subprog SAIANUFIC
Gosub OUVRE
OK = 2
Call DIALO(OK,mess(101,116,1)) From GESECRAN  :#Effacement fichier disque
If OK <> 2 : Close Mask [DIA] : End : Endif
OK = 1
Call OUINON(mess(28,100,1),OK) From GESECRAN :#Confirmation d'annulation
If OK = 2
 Call EFFACE([M]FILNAM,STAT) From ORDSYS
 Call ERREUR(mess(165,100,1)+ " "+[M]FILNAM) From GESECRAN : #Effacement fichier
Endif
Close Mask [DIA]
End

$OUVRE
Local Integer OK, STAT
Local Mask UTIANUFIC [DIA]
Return

##############################
Subprog C_FILNAM(VALEUR)
Variable Char    VALEUR()
Local Integer OKFIL
Call EXISTE(VALEUR,OKFIL) From ORDSYS
Case OKFIL
 When 0
  GMESSAGE = mess(101,100,1) : #Fichier inexistant
  mkstat = 2
  End
 When 2
  GMESSAGE = mess(55,141,1)  : #Ce fichier est un répertoire
  mkstat = 2
  End
 Endcase
End
