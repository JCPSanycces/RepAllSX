#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# SUBPIHB : Gestion des factures d'achat                   MBT 30/08/98 #
# --------------------------------------------------------------------- #
# Traitements complémentaires de l'objet "PIH"                          #
# Les traitements sur champ "Call"     se trouvent dans le SUBPIH       #
# Les actions "Gosub" de l'objet "PIH" se trouvent dans le SUBPIHA      #
#########################################################################

$LECT_FICLIG
#--------------------------------------------------------------------#
# Lecture des fichiers associés à la ligne pour utilisation dans MàJ #
#   - ITMMASTER  [ITM] : Articles                                    #
#   - ITMBPS     [ITP] : Articles-Fournisseurs                       #
#--------------------------------------------------------------------#
If [F:ITM]ITMREF<>[F:PID]ITMREF
   Read [ITM] ITM0=[F:PID]ITMREF
   If fstat Raz [F:ITM] : Endif
Endif
If [F:ITP]ITMREF<>[F:PID]ITMREF | [F:ITP]BPSNUM<>[F:PIH]BPR
   Read [ITP] ITP0=[F:PID]ITMREF;[F:PID]BPSNUM
   If fstat Raz [F:ITP] : Endif
Endif
Return

$CHARG_ADR_BPSINV
#-----------------------------------------------#
# Chargement de l'adresse fournisseur facturant #
#-----------------------------------------------#
#----- Lecture BPARTNER si nécessaire -----#
If [F:BPR]BPRNUM<>[M:PIH0]BPR
   Read [BPR] BPR0=[M:PIH0]BPR : If fstat Raz [F:BPR] : Endif
Endif
#----- Lecture BPSUPPLIER si nécessaire -----#
If [F:BPS]BPSNUM<>[M:PIH0]BPR
   Read [BPS] BPS0=[M:PIH0]BPR : If fstat Raz [F:BPS] : Endif
Endif
#-----
If [F:BPS]BPSINV=[M:PIH0]BPR
  [M:AD66]BPAADD=[F:BPS]BPAINV
Else
  [M:AD66]BPAADD=[F:BPS]BPAADD
Endif
[M:AD66]BPRNAM(0) = [F:BPR]BPRNAM(0)
[M:AD66]BPRNAM(1) = [F:BPR]BPRNAM(1)
Gosub RECUP_ADR_FACTURANT
Return

$RECUP_ADR_FACTURANT
#----- Chargement adresse fournisseur facturant -----#
If [F:BPA]BPANUM<>[M:PIH0]BPR | [F:BPA]BPAADD<>[M:AD66]BPAADD
   Read [BPA] BPA0=1;[M:PIH0]BPR;[M:AD66]BPAADD : If fstat Raz [F:BPA] : Endif
Endif
#-----
[M:AD66] = [F:BPA]
[M:AD66]BPAADD    = [F:BPA]BPAADD
[M:AD66]ADBBPR    = [F:BPA]BPANUM
[M:AD66]ADBFLG    = 1
Return

$CHARG_ADR_BPRPAY
#------------------------------------------#
# Chargement de l'adresse fournisseur payé #
#------------------------------------------#
#----- Lecture BPARTNER payé si nécessaire -----#
If [F:BPR]BPRNUM<>[M:PIH1]BPRPAY
  Read [BPR] BPR0=[M:PIH1]BPRPAY : If fstat Raz [F:BPR] : Endif
Endif
#----- Lecture BPSUPPLIER facturant si nécessaire -----#
If [F:BPS]BPSNUM<>[M:PIH0]BPR
  Read [BPS] BPS0=[M:PIH0]BPR : If fstat Raz [F:BPS] : Endif
Endif
#-----
If [F:BPS]BPRPAY=[M:PIH1]BPRPAY
  [M:AD67]BPAADD=[F:BPS]BPAPAY
Else
  #----- Lecture BPSUPPLIER payé si nécessaire -----#
  If [F:BPS]BPSNUM<>[M:PIH1]BPRPAY
    Read [BPS] BPS0=[M:PIH1]BPRPAY : If fstat Raz [F:BPS] : Endif
  Endif
  If [F:BPS]BPRPAY=[M:PIH1]BPRPAY
    [M:AD67]BPAADD=[F:BPS]BPAPAY
  Elsif [F:BPS]BPAADD<>""
    [M:AD67]BPAADD=[F:BPS]BPAADD
  Else
    [M:AD67]BPAADD=[F:BPR]BPAADD
  Endif
Endif
#----- Chargement adresse fournisseur payé -----#
If [F:BPA]BPANUM<>[M:PIH1]BPRPAY | [F:BPA]BPAADD<>[M:AD67]BPAADD
  Read [BPA] BPA0=1;[M:PIH1]BPRPAY;[M:AD67]BPAADD : If fstat Raz [F:BPA] : Endif
Endif
#-----
[M:AD67] = [F:BPA]
[M:AD67]BPRNAM(0) = [F:BPR]BPRNAM(0)
[M:AD67]BPRNAM(1) = [F:BPR]BPRNAM(1)
[M:AD67]BPAADD    = [F:BPA]BPAADD
[M:AD67]ADBBPR    = [F:BPA]BPANUM
[M:AD67]ADBFLG    = 1
#----- Relecture BPARTNER facturant si nécessaire -----#
If [F:BPR]BPRNUM<>[M:PIH0]BPR
   Read [BPR] BPR0=[M:PIH0]BPR : If fstat Raz [F:BPR] : Endif
Endif
#----- Relecture BPSUPPLIER facturant si nécessaire -----#
If [F:BPS]BPSNUM<>[M:PIH0]BPR
   Read [BPS] BPS0=[M:PIH0]BPR : If fstat Raz [F:BPS] : Endif
Endif
#-----
Return

########################################################################
# CONVERT_MONTANT : S/P de conversion des éléments de facturation      #
#                   et des montants HT, TVA                            #
#                   après un changement de devise facture ou de        #
#                   type de cours facture                              #
# -------------------------------------------------------------------- #
# Subprog CONVERT_MONTANT (DEV,TYP)                                    #
#    DEV  : Nouveau code devise                                        #
#    TYP  : Nouveau type de cours                                      #
########################################################################
Subprog CONVERT_MONTANT (DEV,TYP)
Value Char     DEV
Value Integer  TYP
Local Integer  I, STAT
If [M:PIH1]NBFAC1>0
   For I=0 To [M:PIH1]NBFAC1-1
       Call MAJ_ELEMENT (I,0,-1) From SUBPIHB
       Call CONVERT([M:PIH1]CUR,DEV,GLOCALDEV,TYP,[M:PIH0]ACCDAT,
&                   [M:PIH1]INVDTAAMT1(I),GBIDD2,STAT) From TRTDEV
       If STAT  Raz GBIDD2 : Endif
       [M:PIH1]INVDTAAMT1(I)=GBIDD2 : [M:PIH4]INVDTAAMT(I)=GBIDD2
       Call CONVERT([M:PIH1]CUR,DEV,GLOCALDEV,TYP,[M:PIH0]ACCDAT,
&                   [M:PIH4]INVORDAMT(I),GBIDD2,STAT) From TRTDEV
       If STAT  Raz GBIDD2 : Endif
       [M:PIH4]INVORDAMT(I)=GBIDD2
       # Issue 85145 - 2012-10-16 by MUARN : Tunuel sur éléments de facturation et devise
       [M:PIH4]AMTCODLIB(I)=DEV
       Call MAJ_ELEMENT (I,0,+1) From SUBPIHB
   Next I
Endif
Call CONVERT([M:PIH1]CUR,DEV,GLOCALDEV,TYP,[M:PIH0]ACCDAT,
&            [M:PIH1]TOTLINAMT1,GBIDD2,STAT) From TRTDEV
If STAT  Raz GBIDD2 : Endif
[M:PIH1]TOTLINAMT1=GBIDD2 : [M:PIH4]TOTLINAMT=GBIDD2
Call CONVERT([M:PIH1]CUR,DEV,GLOCALDEV,TYP,[M:PIH0]ACCDAT,
&            [M:PIH1]TOTTAXAMT1,GBIDD2,STAT) From TRTDEV
If STAT  Raz GBIDD2 : Endif
[M:PIH1]TOTTAXAMT1=GBIDD2 : [M:PIH4]TOTTAXAMT=GBIDD2
End

########################################################################
# MAJ_ELEMENT : S/P de mise à jour des bases et calcul des taxes       #
#                   et répartition si besoin des montants sur          #
#                   les lignes au prorata des qtés ou montant          #
# -------------------------------------------------------------------- #
# Subprog MAJ_ELEMENT (NOL,AFF,SENS)                                   #
#    NOL  : Numéro de ligne de l'élément de facturation (nolign-1)     #
#    AFF  : Indicateur d'affichage (0=Non, 1-2=Oui)                    #
#    SENS : Sens de la mise à jour (+1=Cumul, -1=Soustraction)         #
########################################################################
Subprog MAJ_ELEMENT (NOL,AFF,SENS)
Value Shortint NOL
Value Integer  AFF
Value Integer  SENS
Local Shortint I, J, K, L, M
Local Integer  TYPREG,  STAT
Local Decimal  MONTANT, MONTDED, MTLIG, CUMLIG
Local Decimal  CUMORIMT,  CUMORIQTE, CUMORIWEU, CUMORIVOU
Local Decimal  CUMQTYPUU, CUMQTYWEU, CUMQTYVOU, CUMAMTNOTLIN, WMT
Local Char     TAXE(GLONVAT)
# Issue 71937 - 2012-03-27 by SR report CPO
Local Integer  WRET
Raz GPIH_INDTAX
#---- Si les calculs de taxe non pas commencés alors c'est fini ----#
If [M:PIH4]NBFAC=0 & AFF<>2 End : Endif
#---- Si élément fait partie de la ligne tarif et taxe produit alors c'est fini ----#
If [M:PIH4]INVLINFLG(NOL)=6 & [M:PIH4]INVDTAVAT(NOL)="" Goto AFF_TAXES : Endif
#----- Si l'élément est une remise sur taxe (settlement discount), c'est fini -----#
If dim([M:PIH4]DISVATFLG)>0 & [M:PIH4]DISVATFLG(NOL)=2  Goto AFF_TAXES : Endif
#------ Si montant de l'élément égal à zéro ni calcul, ni màj ------#
If [M:PIH4]INVDTAAMT(NOL)=0 Goto AFF_TAXES : Endif
#----- Calcul suivant le type de répartition -----#
Case [M:PIH4]INVLINFLG(NOL)
  When 1  : Gosub CAL_TAXE_PIED : # Pas de répartition sur les lignes
  When 2  : Gosub CAL_PRORATA   : # Prorata des quantités
  When 3  : Gosub CAL_PRORATA   : # Prorata des montants
  When 4  : Gosub CAL_PRORATA   : # Prorata des poids
  When 5  : Gosub CAL_PRORATA   : # Prorata des volumes
  When 6  : Gosub CAL_TAXE_PIED : # Provient des lignes (tarif)
Endcase
#----- Affichage du tableau des taxes -----#
$AFF_TAXES
# Issue 83026 - 2012-07-04 by MUARN : early discount
[M:PIH4]BASDEP = max(sum([M:PIH4]BASDEPNOT(0..[M:PIH4]NBTAX-1)), sum([M:PIH4]BASDEPATI(0..[M:PIH4]NBTAX-1)))

#Issue 107878 - 2018-10-03 by RBA change due to sequence display
#If AFF>0 & !GIMPORT Affzo [PIH4]10,20,30 : Endif
If AFF>0 & !GIMPORT Affzo [PIH4]10,25,30 : Endif
End
#------------------------------------------------------------#
# Répartition sur les lignes au prorata des qtés ou montants #
#------------------------------------------------------------#
$CAL_PRORATA
#----- Taxe à taux fixe -----#
If [M:PIH4]INVDTAVAT(NOL)<>"" Gosub CAL_TAXE_PIED : Endif
#----- Recherche si élément nouveau et màj soustraction alors c'est fini -----#
If !find([M:PIH4]INVDTA(NOL),[M:PIH3]INVDTALIN2(0..8)) & SENS=-1 Return : Endif
#---- C'est un élément nouveau : Stockage du no d'élément et du code taxe ----#
If !find([M:PIH4]INVDTA(NOL),[M:PIH3]INVDTALIN2(0..8))
   I=find(0,[M:PIH3]INVDTALIN2(0..8))
   If I<>0
     [M:PIH3]INVDTALIN2(I-1)=[M:PIH4]INVDTA(NOL)
     [M:PIH3]INVDTAVAT2(I-1)=[M:PIH4]INVDTAVAT(NOL)
   Else
     Return : # Une 10ème répartition est impossible !
   Endif
Endif
#----- Si avoir avec qtés ou mts nuls répartition avec qtés ou mts d'origine -----#
# Cumul des qtés     : Tout sauf Service
# Cumul des poids    : Normal et composé
# Cumul des volumes  : Normal et composé
# Cumul des montants : Tout sauf composé
If [M:PIH0]PIHTYP=3
  # Issue 119994 - 2016-11-15 by MUARN : SST ne pas prendre en compte toutes les lignes
  CUMQTYPUU   =sigma(I=0,[M:PIH3]NBLIG-1,abs([M:PIH3]QTYPUU(I)*([M:PIH3]LINTYP(I)<>3)))
  CUMQTYWEU   =sigma(I=0,[M:PIH3]NBLIG-1,abs([M:PIH3]QTYWEU(I)*([M:PIH3]LINTYP(I)<3)))
  CUMQTYVOU   =sigma(I=0,[M:PIH3]NBLIG-1,abs([M:PIH3]QTYVOU(I)*([M:PIH3]LINTYP(I)<3)))
  CUMAMTNOTLIN=sigma(I=0,[M:PIH3]NBLIG-1,abs([M:PIH3]AMTNOTLIN(I)*([M:PIH3]LINTYP(I)<>2)))
  If ([M:PIH4]INVLINFLG(NOL)=2 & CUMQTYPUU=0)    |
&    ([M:PIH4]INVLINFLG(NOL)=3 & CUMAMTNOTLIN=0) |
&    ([M:PIH4]INVLINFLG(NOL)=4 & CUMQTYWEU=0)    |
&    ([M:PIH4]INVLINFLG(NOL)=5 & CUMQTYVOU=0)
    # Issue 119994 - 2016-11-15 by MUARN : SST ne pas prendre en compte toutes les lignes
    #CUMORIQTE=sum([M:PIH3]ORIQTYPUU(0..[M:PIH3]NBLIG-1))
    #CUMORIWEU=sum([M:PIH3]ORIQTYWEU(0..[M:PIH3]NBLIG-1))
    #CUMORIVOU=sum([M:PIH3]ORIQTYVOU(0..[M:PIH3]NBLIG-1))
    CUMORIQTE=sigma(I=0,[M:PIH3]NBLIG-1,[M:PIH3]ORIQTYPUU(I)*([M:PIH3]LINTYP(I)<>3))
    CUMORIWEU=sigma(I=0,[M:PIH3]NBLIG-1,[M:PIH3]ORIQTYWEU(I)*([M:PIH3]LINTYP(I)<3))
    CUMORIVOU=sigma(I=0,[M:PIH3]NBLIG-1,[M:PIH3]ORIQTYVOU(I)*([M:PIH3]LINTYP(I)<3))
    Raz CUMORIMT
    For I=0 To [M:PIH3]NBLIG-1
      If [M:PIH3]UOMPUUCOE(I)=0 [M:PIH3]UOMPUUCOE(I)=1 : Endif
      CUMORIMT+=([M:PIH3]ORIQTYPUU(I)*[M:PIH3]ORINETPRI(I)/[M:PIH3]UOMPUUCOE(I))
    Next I
  Endif
Endif
#---- Si fac complément avec qtés ou mts nuls répartition avec qtés ou mts d'origine ----#
If [M:PIH0]PIHTYP=2
  # Issue 119994 - 2016-11-15 by MUARN : SST ne pas prendre en compte toutes les lignes
  CUMQTYPUU   =sigma(I=0,[M:PIH3]NBLIG-1,abs([M:PIH3]QTYPUU(I)*([M:PIH3]LINTYP(I)<>3)))
  CUMQTYWEU   =sigma(I=0,[M:PIH3]NBLIG-1,abs([M:PIH3]QTYWEU(I)*([M:PIH3]LINTYP(I)<3)))
  CUMQTYVOU   =sigma(I=0,[M:PIH3]NBLIG-1,abs([M:PIH3]QTYVOU(I)*([M:PIH3]LINTYP(I)<3)))
  CUMAMTNOTLIN=sigma(I=0,[M:PIH3]NBLIG-1,abs([M:PIH3]AMTNOTLIN(I)*([M:PIH3]LINTYP(I)<>2)))
  If ([M:PIH4]INVLINFLG(NOL)=2 & CUMQTYPUU=0)    |
&    ([M:PIH4]INVLINFLG(NOL)=3 & CUMAMTNOTLIN=0) |
&    ([M:PIH4]INVLINFLG(NOL)=4 & CUMQTYWEU=0)    |
&    ([M:PIH4]INVLINFLG(NOL)=5 & CUMQTYVOU=0)
    # Issue 119994 - 2016-11-15 by MUARN : SST ne pas prendre en compte toutes les lignes
    #CUMORIQTE=sum([M:PIH3]ORIQTYPUU(0..[M:PIH3]NBLIG-1))
    #CUMORIWEU=sum([M:PIH3]ORIQTYWEU(0..[M:PIH3]NBLIG-1))
    #CUMORIVOU=sum([M:PIH3]ORIQTYVOU(0..[M:PIH3]NBLIG-1))
    #CUMORIMT =sum([M:PIH3]ORINETPRI(0..[M:PIH3]NBLIG-1))
    CUMORIQTE=sigma(I=0,[M:PIH3]NBLIG-1,[M:PIH3]ORIQTYPUU(I)*([M:PIH3]LINTYP(I)<>3))
    CUMORIWEU=sigma(I=0,[M:PIH3]NBLIG-1,[M:PIH3]ORIQTYWEU(I)*([M:PIH3]LINTYP(I)<3))
    CUMORIVOU=sigma(I=0,[M:PIH3]NBLIG-1,[M:PIH3]ORIQTYVOU(I)*([M:PIH3]LINTYP(I)<3))
    CUMORIMT =sigma(I=0,[M:PIH3]NBLIG-1,[M:PIH3]ORINETPRI(I)*([M:PIH3]LINTYP(I)<>2))
  Endif
Endif
#----- Répartition sur les lignes -----#
# INVLINFLG (DSPLIN de PFI) : 1=non,2=qté,3=Mnts,4=Poids,5=volume
# LINTYP    : 1=normal,2=composé,3=service,4=Matière
J=find([M:PIH4]INVDTA(NOL),[M:PIH3]INVDTALIN2(0..8)) : Raz CUMLIG
If [M:PIH3]NBLIG>0
  For I=0 To [M:PIH3]NBLIG-1
    # Issue X3-74383 - 2018-04-05 by MUARN : facture généré à partir des ventes, et élément en taux produit, ne pas faire
    # NBLIG est renseigné mais pas la ligne article
    If [M:PIH3]TYPORI(I)>0
      # Si Normal
      # ou composé et répartition qté ou poids ou volume
      # ou service et répartition = montant
      # ou Matière et répartition qté ou montant
      If [M:PIH3]LINTYP(I)<2
&   | ([M:PIH3]LINTYP(I)=2 & [M:PIH4]INVLINFLG(NOL)<>3)
&   | ([M:PIH3]LINTYP(I)=3 & [M:PIH4]INVLINFLG(NOL)=3)
&   | ([M:PIH3]LINTYP(I)=4 & [M:PIH4]INVLINFLG(NOL)<4)
        #----- Le prorata du produit fini s'affecte au service -----#
        If [M:PIH3]LINTYP(I)=2
          M=I+1
        #----- Le prorata des autres s'affecte sur eux-mêmes -----#
        Else
          M=I
        Endif
        #-----
        If SENS=1
          If I<[M:PIH3]NBLIG-1
            Raz MTLIG
            #----- Si fact.complémentaire ou avoir sur facture et quantités nulles -----#
            If find([M:PIH0]PIHTYP,2,3) &
&           (([M:PIH4]INVLINFLG(NOL)=2 & CUMQTYPUU=0)    |
&            ([M:PIH4]INVLINFLG(NOL)=3 & CUMAMTNOTLIN=0) |
&            ([M:PIH4]INVLINFLG(NOL)=4 & CUMQTYWEU=0)    |
&            ([M:PIH4]INVLINFLG(NOL)=5 & CUMQTYVOU=0))
              Case [M:PIH4]INVLINFLG(NOL)
                When 2 : #----- Prorata par quantités -----#
                  If CUMORIQTE<>0 & [M:PIH3]LINTYP(I)<>3
                    MTLIG=[M:PIH4]INVDTAAMT(NOL)*[M:PIH3]ORIQTYPUU(I)/CUMORIQTE
                  Endif
                When 3 : #----- Prorata par montants -----#
                  If CUMORIMT<>0 & [M:PIH3]LINTYP(I)<>2
                    If [M:PIH0]PIHTYP=2
                      #----- Facture complémentaire -----#
                      MTLIG=[M:PIH4]INVDTAAMT(NOL)*[M:PIH3]ORINETPRI(I)/CUMORIMT
                    Else
                      #----- Avoir sur facture -----#
                      WMT=[M:PIH3]ORIQTYPUU(I)*[M:PIH3]ORINETPRI(I)/[M:PIH3]UOMPUUCOE(I)
                      MTLIG=[M:PIH4]INVDTAAMT(NOL)*WMT/CUMORIMT
                    Endif
                  Endif
                When 4 : #----- Prorata par poids -----#
                  If CUMORIWEU<>0 & [M:PIH3]LINTYP(I)<3
                    MTLIG=[M:PIH4]INVDTAAMT(NOL)*[M:PIH3]ORIQTYWEU(I)/CUMORIWEU
                  Endif
                When 5 : #----- Prorata par volumes -----#
                  If CUMORIVOU<>0 & [M:PIH3]LINTYP(I)<3
                    MTLIG=[M:PIH4]INVDTAAMT(NOL)*[M:PIH3]ORIQTYVOU(I)/CUMORIVOU
                  Endif
              Endcase
            Else
              #----- Autres cas (facture, avoir sur retour ...etc) -----#
              Case [M:PIH4]INVLINFLG(NOL)
                When 2 : #----- Prorata par quantités -----#
                  If [M:PIH4]TOTLINQTY<>0 & [M:PIH3]LINTYP(I)<>3
                    MTLIG=[M:PIH4]INVDTAAMT(NOL)*[M:PIH3]QTYPUU(I)/[M:PIH4]TOTLINQTY
                  Endif
                When 3 : #----- Prorata par montants -----#
                  If [M:PIH3]CUMLINAMT1<>0 & [M:PIH3]LINTYP(I)<>2
                    MTLIG=[M:PIH4]INVDTAAMT(NOL)*[M:PIH3]AMTNOTLIN(I)/[M:PIH3]CUMLINAMT1
                  Endif
                When 4 : #----- Prorata par poids -----#
                  If [M:PIH4]TOTLINWEU<>0 & [M:PIH3]LINTYP(I)<3
                    MTLIG=[M:PIH4]INVDTAAMT(NOL)*[M:PIH3]QTYWEU(I)/[M:PIH4]TOTLINWEU
                  Endif
                When 5 : #----- Prorata par volumes -----#
                  If [M:PIH4]TOTLINVOU<>0 & [M:PIH3]LINTYP(I)<3
                    MTLIG=[M:PIH4]INVDTAAMT(NOL)*[M:PIH3]QTYVOU(I)/[M:PIH4]TOTLINVOU
                  Endif
              Endcase
            Endif
            Call ARRDEV(MTLIG,GCUR) From TRTDIV
          Else
            MTLIG=[M:PIH4]INVDTAAMT(NOL)-CUMLIG
          Endif
          Assign "[M:PIH3]DISCRGAMT"+num$(J)+"(M)" With MTLIG
          CUMLIG+=MTLIG
        Else
          MTLIG=evalue("[M:PIH3]DISCRGAMT"+num$(J)+"(M)")
          Assign "[M:PIH3]DISCRGAMT"+num$(J)+"(M)" With 0
        Endif
        # Issue 102698 - 2014-11-19 by MUARN : escomptes belges
        If GDEPMGTMOD=5 & [M:PIH1]DEPRAT<>0 & ( ([M:PIH4]DEPFLG(NOL)=2 & [M:PIH4]INCDCR(NOL)=1) | [M:PIH4]INCDCR(NOL)=2)
          Assign "[M:PIH3]DDTADEP"+num$(J)+"(M)" With evalue("[M:PIH3]DISCRGAMT"+num$(J)+"(M)")*[M:PIH1]DEPRAT/100
        Else
          Assign "[M:PIH3]DDTADEP"+num$(J)+"(M)" With 0
        Endif

        If [M:PIH3]INVDTAVAT2(J-1)="" & [M:PIH3]VAT1(M)<>"" Gosub CAL_TAXE_LIGNE : Endif
        [M:PIH3]UPDFLG(M)=1
      Endif
    Endif
  Next I
Endif
If SENS=-1 [M:PIH3]INVDTALIN2(J-1)=0 : [M:PIH3]INVDTAVAT2(J-1)="" : Endif
Return
#-----------------------------------------------------------#
# Màj bases taxables et calcul des taxes en pied de facture #
#-----------------------------------------------------------#
$CAL_TAXE_PIED
#----- Recherche si taxe déja existante -----#
I=find([M:PIH4]INVDTAVAT(NOL),[M:PIH4]TAX(0..[M:PIH4]NBTAX-1))
If I<>0 & [M:PIH4]PURTYP(I-1)<>1
  J=find([M:PIH4]INVDTAVAT(NOL),[M:PIH4]TAX(I..[M:PIH4]NBTAX-1))
  If J<>0
    I+=J
    If [M:PIH4]PURTYP(I-1)<>1
      J=find([M:PIH4]INVDTAVAT(NOL),[M:PIH4]TAX(I..[M:PIH4]NBTAX-1))
      If J<>0 I+=J Else I=0 : Endif
    Endif
  Else
    I=0
  Endif
Endif
#----- Nouvelle taxe -----#
If I=0
  #----- Le nombre maximum de taxe est dépassé ! ------#
  If [M:PIH4]NBTAX>=dim([M:PIH4]TAX)
    Call ERREUR ([M:PIH4]INVDTAVAT(NOL)-mess(300,194,1)) From GESECRAN
    GPIH_INDTAX=I+1
    Return
  Endif
  #-----
  I=[M:PIH4]NBTAX
  [M:PIH4]NBTAX+=1
  [M:PIH4]TAX(I)=[M:PIH4]INVDTAVAT(NOL)
  # Issue 71937 - 2012-03-27 by SR report CPO : comment
  Call LEC_TVT_LEG(GCURLEG,[M:PIH4]INVDTAVAT(NOL),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  #  Read [TVT] TVT0=[M:PIH4]INVDTAVAT(NOL) : If fstat Raz [F:TVT] : Endif
  Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:PIH4]LIBTAX(I)) From TRTX3TEX
  [M:PIH4]PURTYP(I)=1
Else
  I-=1
Endif
#----- Mise à jour base taxable et montants de taxe-----#
If SENS=-1
  [M:PIH4]BASTAX(I)-=[M:PIH4]INVDTAAMT(NOL)
  If dim([M:PIH4]DTADISBAS)>0
    [M:PIH4]BASTAX(I)-=[M:PIH4]DTADISBAS(NOL)
    [M:PIH4]DISBAS(I)-=[M:PIH4]DTADISBAS(NOL)
  Endif
  [M:PIH4]AMTTAX(I)-=[M:PIH4]DTAAMTTAX(NOL)
  [M:PIH4]DEDTAX(I)-=[M:PIH4]DTADEDTAX(NOL)

  # Issue 83026 - 2012-07-02 by MUARN : early escompte
  # calcul base escomptable uniquement sur facture et facture complémentaire
  If [M:PIH0]PIHTYP<3
    If [M:PIH1]DEP<>""
      #element facturation soumis escompte ou minoration ou GDEPMGTMOD = 1 ou 4
      If ([M:PIH4]INCDCR(NOL)=1 & [M:PIH4]DEPFLG(NOL)=2) | [M:PIH4]INCDCR(NOL)=2 | GDEPMGTMOD = 1 | GDEPMGTMOD = 4
        If [M:PIH1]DEPTYP = 1 #escompte HT
          [M:PIH4]BASDEPNOT(I)-=[M:PIH4]INVDTAAMT(NOL)
        Elsif [M:PIH1]DEPTYP = 2 #escompte TTC
          If [M:PIH1]VACTYP<>4
            [M:PIH4]BASDEPATI(I)-=[M:PIH4]INVDTAAMT(NOL)+[M:PIH4]DTAAMTTAX(NOL)
          Else
            [M:PIH4]BASDEPATI(I)-=[M:PIH4]INVDTAAMT(NOL)
          Endif
        Endif
        # Issue 102698 - 2014-11-24 by MUARN : escomptes belges
        If GDEPMGTMOD=5
          # Issue 102698 by TS : escomptes belges
          #[M:PIH4]DTADEP(NOL) = [M:PIH4]INVDTAAMT(NOL)
          [M:PIH4]DTADEP(NOL) = [M:PIH4]INVDTAAMT(NOL)*[M:PIH1]DEPRAT/100
        Endif
      Endif
    Endif
  Endif

  #----- Suppression ligne taxe si aucun montant et affichage -----#
  If [M:PIH4]BASTAX(I)=0 & [M:PIH4]AMTTAX(I)=0 & [M:PIH4]DEDTAX(I)=0 : # & AFF>0
    If !GIMPORT
      Dela I,1,[M:PIH4]NBTAX-1 [M:PIH4]NBTAX : [M:PIH4]NBTAX-=1
    Endif
  Endif
Else
  [M:PIH4]BASTAX(I)+=[M:PIH4]INVDTAAMT(NOL)
  If dim([M:PIH4]DTADISBAS)>0
    Raz [M:PIH4]DTADISBAS(NOL)
  Endif
  #----- Calcul du montant de taxe avec sa partie déductible -----#
  #If [M:PIH4]DTAAMTTAX(NOL)=0 & [M:PIH4]DTADEDTAX(NOL)=0
    TAXE=[M:PIH4]INVDTAVAT(NOL)
    Gosub RECH_DATE_TAXE
    Call CALTAXE(GSOCIETE,GBIDA1,[M:PIH1]VAC,GCUR,1,TAXE,1,
&                [M:PIH4]INVDTAAMT(NOL),MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
    [M:PIH4]DTAAMTTAX(NOL)=MONTANT
    [M:PIH4]DTADEDTAX(NOL)=MONTDED
  #Endif
  [M:PIH4]AMTTAX(I)+=[M:PIH4]DTAAMTTAX(NOL)
  [M:PIH4]DEDTAX(I)+=[M:PIH4]DTADEDTAX(NOL)

  # Issue 83026 - 2012-07-02 by MUARN : early escompte
  # calcul base escomptable uniquement sur facture et facture complémentaire
  If [M:PIH0]PIHTYP<3
    If [M:PIH1]DEP<>""
      #element facturation soumis escompte ou minoration ou GDEPMGTMOD = 1 ou 4
      If ([M:PIH4]INCDCR(NOL)=1 & [M:PIH4]DEPFLG(NOL)=2) | [M:PIH4]INCDCR(NOL)=2 | GDEPMGTMOD = 1| GDEPMGTMOD = 4
        If [M:PIH1]DEPTYP = 1 #escompte HT
          [M:PIH4]BASDEPNOT(I)+=[M:PIH4]INVDTAAMT(NOL)
        Elsif [M:PIH1]DEPTYP = 2 #escompte TTC
          If [M:PIH1]VACTYP<>4
            [M:PIH4]BASDEPATI(I)+=[M:PIH4]INVDTAAMT(NOL)+[M:PIH4]DTAAMTTAX(NOL)
          Else
            [M:PIH4]BASDEPATI(I)+=[M:PIH4]INVDTAAMT(NOL)
          Endif
        Endif
        # Issue 102698 - 2014-11-24 by MUARN : escomptes belges
        If GDEPMGTMOD=5
          # Issue 102698 by TS : escomptes belges
          #[M:PIH4]DTADEP(NOL) = [M:PIH4]INVDTAAMT(NOL)
          [M:PIH4]DTADEP(NOL) = [M:PIH4]INVDTAAMT(NOL)*[M:PIH1]DEPRAT/100
        Endif
      Endif
    Endif
  Endif

Endif
GPIH_INDTAX=I+1
Return
#--------------------------------------------------------------#
# Màj bases taxables et calcul des taxes à la ligne de facture #
#--------------------------------------------------------------#
$CAL_TAXE_LIGNE

#----- Recherche si taxe déja existante -----#
K=find([M:PIH3]VAT1(M),[M:PIH4]TAX(0..[M:PIH4]NBTAX-1))
If K<>0 & [M:PIH4]PURTYP(K-1)<>[M:PIH3]LINPURTYP(M)
   L=find([M:PIH3]VAT1(M),[M:PIH4]TAX(K..[M:PIH4]NBTAX-1))
   If L<>0
     K+=L
     If [M:PIH4]PURTYP(K-1)<>[M:PIH3]LINPURTYP(M)
       L=find([M:PIH3]VAT1(M),[M:PIH4]TAX(K..[M:PIH4]NBTAX-1))
       If L<>0 K+=L Else K=0 : Endif
     Endif
   Else
     K=0
   Endif
Endif
#----- Nouvelle taxe -----#
If K=0
  #----- Le nombre maximum de taxe est dépassé ! ------#
  If [M:PIH4]NBTAX>=dim([M:PIH4]TAX)
    Call ERREUR ([M:PIH3]VAT1(M)-mess(300,194,1)) From GESECRAN
    GPIH_INDTAX=K+1
    Return
  Endif
  #-----
  K=[M:PIH4]NBTAX
  [M:PIH4]NBTAX+=1
  [M:PIH4]TAX(K)=[M:PIH3]VAT1(M)
  # Issue 71937 - 2012-03-27 by SR report CPO : comment
  Call LEC_TVT_LEG(GCURLEG,[M:PIH3]VAT1(M),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
#  Read [TVT] TVT0=[M:PIH3]VAT1(M) : If fstat Raz [F:TVT] : Endif
  Call GET_ATEXTRA("TABVAT","SHOAXX",GLANGUE,[M:PIH4]LIBTAX(K)) From TRTX3TEX
  [M:PIH4]PURTYP(K)=[M:PIH3]LINPURTYP(M)
Else
  K-=1
Endif
#----- Calcul du montant de taxe avec sa partie déductible -----#
TAXE=[M:PIH3]VAT1(M)
Gosub RECH_DATE_TAXE
Call CALTAXE(GSOCIETE,GBIDA1,[M:PIH1]VAC,GCUR,1,TAXE,1,
&            MTLIG,MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
#----- Mise à jour base taxable et montants de taxe-----#
If SENS=-1 [M:PIH3]BASTAXLIN1(M)-=MTLIG
           [M:PIH3]AMTTAXLIN1(M)-=MONTANT
           [M:PIH3]DEDTAXLIN1(M)-=MONTDED
#          [M:PIH3]AMTATILIN(M) -=MTLIG
           If [M:PIH1]VACTYP<>4 [M:PIH3]AMTATILIN(M) -=MONTANT : Endif
           [M:PIH4]BASTAX(K)-=MTLIG
           [M:PIH4]AMTTAX(K)-=MONTANT
           [M:PIH4]DEDTAX(K)-=MONTDED
           # Issue 83026 - 2012-07-02 by MUARN : early discount
           # calcul base escomptable uniquement sur facture et facture complémentaire
           If [M:PIH0]PIHTYP<3
             If [M:PIH1]DEP<>""
               #element facturation soumis escompte ou minoration ou GDEPMGTMOD = 1 ou4
               If ([M:PIH4]INCDCR(NOL)=1 & [M:PIH4]DEPFLG(NOL)=2) | [M:PIH4]INCDCR(NOL)=2 | GDEPMGTMOD = 1 | GDEPMGTMOD = 4
                 If [M:PIH1]DEPTYP = 1 #escompte HT
                   [M:PIH4]BASDEPNOT(K)-=MTLIG
                 Elsif [M:PIH1]DEPTYP = 2 #escompte TTC
                    If [M:PIH1]VACTYP<>4
                      [M:PIH4]BASDEPATI(K)-=MTLIG+MONTANT
                    Else
                      [M:PIH4]BASDEPATI(K)-=MTLIG
                    Endif
                 Endif
                 # Issue 102698 - 2014-11-24 by MUARN : escomptes belges
                 If GDEPMGTMOD=5
                   # Issue 102698 by TS : escomptes belges
                   #[M:PIH4]DTADEP(NOL) = [M:PIH4]INVDTAAMT(NOL)
                   [M:PIH4]DTADEP(NOL) = [M:PIH4]INVDTAAMT(NOL)*[M:PIH1]DEPRAT/100
                 Endif
               Endif
             Endif
           Endif

#          #----- Suppression ligne taxe si aucun montant -----#
           If [M:PIH4]BASTAX(K)=0 & [M:PIH4]AMTTAX(K)=0 & [M:PIH4]DEDTAX(K)=0
              If !GIMPORT
                 Dela K,1,[M:PIH4]NBTAX-1 [M:PIH4]NBTAX : [M:PIH4]NBTAX-=1
              Endif
           Endif
      Else [M:PIH3]BASTAXLIN1(M)+=MTLIG
           [M:PIH3]AMTTAXLIN1(M)+=MONTANT
           [M:PIH3]DEDTAXLIN1(M)+=MONTDED
#          [M:PIH3]AMTATILIN(M) +=MTLIG
           If [M:PIH1]VACTYP<>4 [M:PIH3]AMTATILIN(M) +=MONTANT : Endif
           [M:PIH4]BASTAX(K)+=MTLIG
           [M:PIH4]AMTTAX(K)+=MONTANT
           [M:PIH4]DEDTAX(K)+=MONTDED
           # Issue 83026 - 2012-07-02 by MUARN : early discount
           # calcul base escomptable uniquement sur facture et facture complémentaire
           If [M:PIH0]PIHTYP<3
             If [M:PIH1]DEP<>""
               #element facturation soumis escompte ou minoration ou GDEPMGTMOD = 1 ou 4
               If ([M:PIH4]INCDCR(NOL)=1 & [M:PIH4]DEPFLG(NOL)=2) | [M:PIH4]INCDCR(NOL)=2 | GDEPMGTMOD = 1 | GDEPMGTMOD = 4
                 If [M:PIH1]DEPTYP = 1 #escompte HT
                   [M:PIH4]BASDEPNOT(K)+=MTLIG
                 Elsif [M:PIH1]DEPTYP = 2 #escompte TTC
                   If [M:PIH1]VACTYP<>4
                     [M:PIH4]BASDEPATI(K)+=MTLIG+MONTANT
                   Else
                     [M:PIH4]BASDEPATI(K)+=MTLIG
                   Endif
                 Endif
                 # Issue 102698 - 2014-11-24 by MUARN : escomptes belges
                 If GDEPMGTMOD=5
                   # Issue 102698 by TS : escomptes belges
                   #[M:PIH4]DTADEP(NOL) = [M:PIH4]INVDTAAMT(NOL)
                   [M:PIH4]DTADEP(NOL) = [M:PIH4]INVDTAAMT(NOL)*[M:PIH1]DEPRAT/100
                 Endif
               Endif
             Endif
           Endif
Endif
GPIH_INDTAX=K+1
Return

########################################################################
# MAJ_TAXE : S/P de mise à jour des montants de taxe au prorata        #
#                des bases sur les éléments de facturation et          #
#                          sur les lignes de facture                   #
# -------------------------------------------------------------------- #
# Subprog MAJ_TAXE (NOL)                                               #
#    NOL  : Numéro de ligne de la taxe (nolign-1)                      #
########################################################################
Subprog MAJ_TAXE (NOL)
Value Shortint NOL
Local Shortint I, J, K, L, CLCAMTFLG
Local Decimal  CUMTAX, CUMDED, DIFTAX, DIFDED, MAXBAS, DIFBAS1
Local Decimal WBASE : # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
# Issue 71937 - 2012-03-27 by SR report CPO : comment
Local Integer WRET
If [M:PIH4]BASTAX(NOL)=0 End : Endif : # Si le diviseur est zéro on ne fait rien !
#----- Màj des montants de taxe sur les éléments de facturation -----#
For I=0 To [M:PIH4]NBFAC-1
  If [M:PIH4]INVDTAVAT(I)=[M:PIH4]TAX(NOL) & [M:PIH4]PURTYP(NOL)=1

    # Issue 102698 - 2014-12-17 by MUARN : escomptes belges
    If [M:PIH0]PIHTYP<3
      If [M:PIH1]DEP<>""
        #element facturation soumis escompte ou minoration ou GDEPMGTMOD = 1 ou 4
        If ([M:PIH4]INCDCR(I)=1 & [M:PIH4]DEPFLG(I)=2) | [M:PIH4]INCDCR(I)=2 | GDEPMGTMOD = 1 | GDEPMGTMOD = 4
          If GDEPMGTMOD=5
            [M:PIH4]DTADEP(I) = [M:PIH4]INVDTAAMT(I)*[M:PIH1]DEPRAT/100
          Endif
        Endif
      Endif
    Endif

    # Issue 102698 by TS : escomptes belges
    #[M:PIH4]DTAAMTTAX(I)=[M:PIH4]AMTTAX(NOL)*[M:PIH4]INVDTAAMT(I)/[M:PIH4]BASTAX(NOL)
    [M:PIH4]DTAAMTTAX(I)=[M:PIH4]AMTTAX(NOL)*([M:PIH4]INVDTAAMT(I)-[M:PIH4]DTADEP(I))/[M:PIH4]BASTAX(NOL)

    Call ARRDEV([M:PIH4]DTAAMTTAX(I),GCUR) From TRTDIV
    CUMTAX+=[M:PIH4]DTAAMTTAX(I)

    # Issue 102698 by TS : escomptes belges
    #[M:PIH4]DTADEDTAX(I)=[M:PIH4]DEDTAX(NOL)*[M:PIH4]INVDTAAMT(I)/[M:PIH4]BASTAX(NOL)
    [M:PIH4]DTADEDTAX(I)=[M:PIH4]DEDTAX(NOL)*([M:PIH4]INVDTAAMT(I)-[M:PIH4]DTADEP(I))/[M:PIH4]BASTAX(NOL)

    Call ARRDEV([M:PIH4]DTADEDTAX(I),GCUR) From TRTDIV
    CUMDED+=[M:PIH4]DTADEDTAX(I)
    If abs([M:PIH4]INVDTAAMT(I))>MAXBAS MAXBAS=abs([M:PIH4]INVDTAAMT(I)) : J=1 : K=I : Endif
  Endif
Next I
#----- Màj des montants de taxe sur les lignes de facture -----#
For I=0 To [M:PIH3]NBLIG-1
  If [M:PIH3]LINPURTYP(I)=[M:PIH4]PURTYP(NOL)
    If [M:PIH3]VAT1(I)=[M:PIH4]TAX(NOL)
      #----- Positionnement indicateur de réajustement des bases spéciales 2 à 7 -----#
      Raz CLCAMTFLG
      For L=2 To 3+4*(func AFNC.ACTIV("PTX") & dim([M:PIH3]CLCAMT4)>0)
        GBIDD2=evalue("[M:PIH3]CLCAMT"+num$(L)+"(I)")
        If GBIDD2<>0 & (GBIDD2=[M:PIH3]AMTNOTLIN(I)+[M:PIH3]AMTTAXLIN1(I) |
&                       GBIDD2=[M:PIH3]AMTTAXLIN1(I))
          CLCAMTFLG+=2^L-1
        Endif
      Next L
      If CLCAMTFLG>0  DIFBAS1=-[M:PIH3]AMTTAXLIN1(I) : Endif
      #-----
      [M:PIH3]AMTTAXLIN1(I)=[M:PIH4]AMTTAX(NOL)*[M:PIH3]BASTAXLIN1(I)/[M:PIH4]BASTAX(NOL)
      Call ARRDEV([M:PIH3]AMTTAXLIN1(I),GCUR) From TRTDIV
      CUMTAX+=[M:PIH3]AMTTAXLIN1(I)
      #----- Réajustement bases spéciales 1 et 2 si TVA incluse dans ces bases (Canada) -----#
      If CLCAMTFLG>0
        DIFBAS1+=[M:PIH3]AMTTAXLIN1(I)
        Call REAJUST_CLCAMT(I,DIFBAS1,CLCAMTFLG) From SUBPIHC
      Endif
      #-----
      [M:PIH3]DEDTAXLIN1(I)=[M:PIH4]DEDTAX(NOL)*[M:PIH3]BASTAXLIN1(I)/[M:PIH4]BASTAX(NOL)
      Call ARRDEV([M:PIH3]DEDTAXLIN1(I),GCUR) From TRTDIV : [M:PIH3]UPDFLG(I)=1
      CUMDED+=[M:PIH3]DEDTAXLIN1(I)
      If abs([M:PIH3]BASTAXLIN1(I))>MAXBAS MAXBAS=abs([M:PIH3]BASTAXLIN1(I)) : J=2 : K=I : Endif
    Elsif [M:PIH3]VAT2(I)=[M:PIH4]TAX(NOL)
      #----- Réajustement base taxe 1 (TVA) si taxe parafiscale soumise -----#
      # Issue 71937 - 2012-03-27 by SR report CPO : comment
      Call LEC_TVT_LEG(GCURLEG,[M:PIH3]VAT2(I),WRET) From TRTLECLEG
      If WRET : Raz [F:TVT] : Endif
      #Read [TVT] TVT0=[M:PIH3]VAT2(I) : If fstat Raz [F:TVT] : Endif
      If [F:TVT]VATCHA=2 DIFBAS1=-[M:PIH3]AMTTAXLIN2(I) : Endif
      #-----
      # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
      WBASE=[M:PIH3]AMTNOTLIN(I)
      If [F:TVT]VATBAS>1
        WBASE=[M:PIH3]CLCAMT2(I) : # Bases spéciales 2-7
      Endif
      #-----
      # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
      #[M:PIH3]AMTTAXLIN2(I)=[M:PIH4]AMTTAX(NOL)*[M:PIH3]AMTNOTLIN(I)/[M:PIH4]BASTAX(NOL)
      [M:PIH3]AMTTAXLIN2(I)=[M:PIH4]AMTTAX(NOL)*WBASE/[M:PIH4]BASTAX(NOL)
      Call ARRDEV([M:PIH3]AMTTAXLIN2(I),GCUR) From TRTDIV
      CUMTAX+=[M:PIH3]AMTTAXLIN2(I)
      #----- Réajustement base taxe 1 (TVA) si taxe parafiscale soumise -----#
      If [F:TVT]VATCHA=2
        DIFBAS1+=[M:PIH3]AMTTAXLIN2(I)
        Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPIHC
      Endif
      #-----
      # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
      #[M:PIH3]DEDTAXLIN2(I)=[M:PIH4]DEDTAX(NOL)*[M:PIH3]AMTNOTLIN(I)/[M:PIH4]BASTAX(NOL)
      [M:PIH3]DEDTAXLIN2(I)=[M:PIH4]DEDTAX(NOL)*WBASE/[M:PIH4]BASTAX(NOL)
      Call ARRDEV([M:PIH3]DEDTAXLIN2(I),GCUR) From TRTDIV : [M:PIH3]UPDFLG(I)=1
      CUMDED+=[M:PIH3]DEDTAXLIN2(I)
      If abs([M:PIH3]AMTNOTLIN(I))>MAXBAS MAXBAS=abs([M:PIH3]AMTNOTLIN(I)) : J=3 : K=I : Endif
    Elsif [M:PIH3]VAT3(I)=[M:PIH4]TAX(NOL)
      #----- Réajustement base taxe 1 (TVA) si taxe spéciale soumise -----#
      # Issue 71937 - 2012-03-27 by SR report CPO : comment
      Call LEC_TVT_LEG(GCURLEG,[M:PIH3]VAT3(I),WRET) From TRTLECLEG
      If WRET : Raz [F:TVT] : Endif
      #Read [TVT] TVT0=[M:PIH3]VAT3(I) : If fstat Raz [F:TVT] : Endif
      If [F:TVT]VATCHA=2 DIFBAS1=-[M:PIH3]AMTTAXLIN3(I) : Endif
      #-----
      # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
      WBASE=[M:PIH3]AMTNOTLIN(I)
      If [F:TVT]VATBAS>1
        WBASE=[M:PIH3]CLCAMT3(I) : # Bases spéciales 2-7
      Endif
      #-----
      # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
      #[M:PIH3]AMTTAXLIN3(I)=[M:PIH4]AMTTAX(NOL)*[M:PIH3]AMTNOTLIN(I)/[M:PIH4]BASTAX(NOL)
      [M:PIH3]AMTTAXLIN3(I)=[M:PIH4]AMTTAX(NOL)*WBASE/[M:PIH4]BASTAX(NOL)
      Call ARRDEV([M:PIH3]AMTTAXLIN3(I),GCUR) From TRTDIV
      CUMTAX+=[M:PIH3]AMTTAXLIN3(I)
      #----- Réajustement base taxe 1 (TVA) si taxe spéciale soumise -----#
      If [F:TVT]VATCHA=2
        DIFBAS1+=[M:PIH3]AMTTAXLIN3(I)
        Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPIHC
      Endif
      #-----
      # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
      #[M:PIH3]DEDTAXLIN3(I)=[M:PIH4]DEDTAX(NOL)*[M:PIH3]AMTNOTLIN(I)/[M:PIH4]BASTAX(NOL)
      [M:PIH3]DEDTAXLIN3(I)=[M:PIH4]DEDTAX(NOL)*WBASE/[M:PIH4]BASTAX(NOL)
      Call ARRDEV([M:PIH3]DEDTAXLIN3(I),GCUR) From TRTDIV : [M:PIH3]UPDFLG(I)=1
      CUMDED+=[M:PIH3]DEDTAXLIN3(I)
      If abs([M:PIH3]AMTNOTLIN(I))>MAXBAS MAXBAS=abs([M:PIH3]AMTNOTLIN(I)) : J=4 : K=I : Endif
    Elsif func AFNC.ACTIV("PTX") & dim([M:PIH3]TAXRCP)>0
      If [M:PIH3]TAXRCP(I)=[M:PIH4]TAX(NOL)
        #----- Réajustement base taxe 1 (TVA) si taxe entrée soumise -----#
        # Issue 71937 - 2012-03-27 by SR report CPO : comment
        Call LEC_TVT_LEG(GCURLEG,[M:PIH3]TAXRCP(I),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:PIH3]TAXRCP(I) : If fstat Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 DIFBAS1=-[M:PIH3]AMTTAXRCP(I) : Endif
        #-----
        # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
        WBASE=[M:PIH3]AMTNOTLIN(I)
        If [F:TVT]VATBAS>1
          WBASE=[M:PIH3]CLCAMT4(I) : # Bases spéciales 2-7
        Endif
        #-----
        # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
        #[M:PIH3]AMTTAXRCP(I)=[M:PIH4]AMTTAX(NOL)*[M:PIH3]AMTNOTLIN(I)/[M:PIH4]BASTAX(NOL)
        [M:PIH3]AMTTAXRCP(I)=[M:PIH4]AMTTAX(NOL)*WBASE/[M:PIH4]BASTAX(NOL)
        Call ARRDEV([M:PIH3]AMTTAXRCP(I),GCUR) From TRTDIV
        CUMTAX+=[M:PIH3]AMTTAXRCP(I)
        #----- Réajustement base taxe 1 (TVA) si taxe entrée soumise -----#
        If [F:TVT]VATCHA=2
          DIFBAS1+=[M:PIH3]AMTTAXRCP(I)
          Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPIHC
        Endif
        #-----
        # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
        #[M:PIH3]DEDTAXRCP(I)=[M:PIH4]DEDTAX(NOL)*[M:PIH3]AMTNOTLIN(I)/[M:PIH4]BASTAX(NOL)
        [M:PIH3]DEDTAXRCP(I)=[M:PIH4]DEDTAX(NOL)*WBASE/[M:PIH4]BASTAX(NOL)
        Call ARRDEV([M:PIH3]DEDTAXRCP(I),GCUR) From TRTDIV : [M:PIH3]UPDFLG(I)=1
        CUMDED+=[M:PIH3]DEDTAXRCP(I)
        If abs([M:PIH3]AMTNOTLIN(I))>MAXBAS MAXBAS=abs([M:PIH3]AMTNOTLIN(I)) : J=5 : K=I : Endif
      Elsif [M:PIH3]TAXISS(I)=[M:PIH4]TAX(NOL)
        #----- Réajustement base taxe 1 (TVA) si taxe sortie soumise -----#
        # Issue 71937 - 2012-03-27 by SR report CPO : comment
        Call LEC_TVT_LEG(GCURLEG,[M:PIH3]TAXISS(I),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:PIH3]TAXISS(I) : If fstat Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 DIFBAS1=-[M:PIH3]AMTTAXISS(I) : Endif
        #-----
        # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
        WBASE=[M:PIH3]AMTNOTLIN(I)
        If [F:TVT]VATBAS>1
          WBASE=[M:PIH3]CLCAMT5(I) : # Bases spéciales 2-7
        Endif
        #-----
        # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
        #[M:PIH3]AMTTAXISS(I)=[M:PIH4]AMTTAX(NOL)*[M:PIH3]AMTNOTLIN(I)/[M:PIH4]BASTAX(NOL)
        [M:PIH3]AMTTAXISS(I)=[M:PIH4]AMTTAX(NOL)*WBASE/[M:PIH4]BASTAX(NOL)
        Call ARRDEV([M:PIH3]AMTTAXISS(I),GCUR) From TRTDIV
        CUMTAX+=[M:PIH3]AMTTAXISS(I)
        #----- Réajustement base taxe 1 (TVA) si taxe entrée soumise -----#
        If [F:TVT]VATCHA=2
          DIFBAS1+=[M:PIH3]AMTTAXISS(I)
          Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPIHC
        Endif
        #-----
        # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
        #[M:PIH3]DEDTAXISS(I)=[M:PIH4]DEDTAX(NOL)*[M:PIH3]AMTNOTLIN(I)/[M:PIH4]BASTAX(NOL)
        [M:PIH3]DEDTAXISS(I)=[M:PIH4]DEDTAX(NOL)*WBASE/[M:PIH4]BASTAX(NOL)
        Call ARRDEV([M:PIH3]DEDTAXISS(I),GCUR) From TRTDIV : [M:PIH3]UPDFLG(I)=1
        CUMDED+=[M:PIH3]DEDTAXISS(I)
        If abs([M:PIH3]AMTNOTLIN(I))>MAXBAS MAXBAS=abs([M:PIH3]AMTNOTLIN(I)) : J=6 : K=I : Endif
      Elsif [M:PIH3]TAXOTH1(I)=[M:PIH4]TAX(NOL)
        #----- Réajustement base taxe 1 (TVA) si autre taxe 1 soumise -----#
        # Issue 71937 - 2012-03-27 by SR report CPO : comment
        Call LEC_TVT_LEG(GCURLEG,[M:PIH3]TAXOTH1(I),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:PIH3]TAXOTH1(I) : If fstat Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 DIFBAS1=-[M:PIH3]AMTTAXOTH1(I) : Endif
        #-----
        # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
        WBASE=[M:PIH3]AMTNOTLIN(I)
        If [F:TVT]VATBAS>1
          WBASE=[M:PIH3]CLCAMT6(I) : # Bases spéciales 2-7
        Endif
        #-----
        # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
        #[M:PIH3]AMTTAXOTH1(I)=[M:PIH4]AMTTAX(NOL)*[M:PIH3]AMTNOTLIN(I)/[M:PIH4]BASTAX(NOL)
        [M:PIH3]AMTTAXOTH1(I)=[M:PIH4]AMTTAX(NOL)*WBASE/[M:PIH4]BASTAX(NOL)
        Call ARRDEV([M:PIH3]AMTTAXOTH1(I),GCUR) From TRTDIV
        CUMTAX+=[M:PIH3]AMTTAXOTH1(I)
        #----- Réajustement base taxe 1 (TVA) si autre taxe 1 soumise -----#
        If [F:TVT]VATCHA=2
          DIFBAS1+=[M:PIH3]AMTTAXOTH1(I)
          Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPIHC
        Endif
        #-----
        # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
        #[M:PIH3]DEDTAXOTH1(I)=[M:PIH4]DEDTAX(NOL)*[M:PIH3]AMTNOTLIN(I)/[M:PIH4]BASTAX(NOL)
        [M:PIH3]DEDTAXOTH1(I)=[M:PIH4]DEDTAX(NOL)*WBASE/[M:PIH4]BASTAX(NOL)
        Call ARRDEV([M:PIH3]DEDTAXOTH1(I),GCUR) From TRTDIV : [M:PIH3]UPDFLG(I)=1
        CUMDED+=[M:PIH3]DEDTAXOTH1(I)
        If abs([M:PIH3]AMTNOTLIN(I))>MAXBAS MAXBAS=abs([M:PIH3]AMTNOTLIN(I)) : J=7 : K=I : Endif
      Elsif [M:PIH3]TAXOTH2(I)=[M:PIH4]TAX(NOL)
        #----- Réajustement base taxe 1 (TVA) si autre taxe 2 soumise -----#
        # Issue 71937 - 2012-03-27 by SR report CPO : comment
        Call LEC_TVT_LEG(GCURLEG,[M:PIH3]TAXOTH2(I),WRET) From TRTLECLEG
        If WRET : Raz [F:TVT] : Endif
        #Read [TVT] TVT0=[M:PIH3]TAXOTH2(I) : If fstat Raz [F:TVT] : Endif
        If [F:TVT]VATCHA=2 DIFBAS1=-[M:PIH3]AMTTAXOTH2(I) : Endif
        #-----
        # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
        WBASE=[M:PIH3]AMTNOTLIN(I)
        If [F:TVT]VATBAS>1
          WBASE=[M:PIH3]CLCAMT7(I) : # Bases spéciales 2-7
        Endif
        #-----
        # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
        #[M:PIH3]AMTTAXOTH2(I)=[M:PIH4]AMTTAX(NOL)*[M:PIH3]AMTNOTLIN(I)/[M:PIH4]BASTAX(NOL)
        [M:PIH3]AMTTAXOTH2(I)=[M:PIH4]AMTTAX(NOL)*WBASE/[M:PIH4]BASTAX(NOL)
        Call ARRDEV([M:PIH3]AMTTAXOTH2(I),GCUR) From TRTDIV
        CUMTAX+=[M:PIH3]AMTTAXOTH2(I)
        #----- Réajustement base taxe 1 (TVA) si autre taxe 1 soumise -----#
        If [F:TVT]VATCHA=2
          DIFBAS1+=[M:PIH3]AMTTAXOTH2(I)
          Call REAJUST_BASTAXLIN1(I,DIFBAS1) From SUBPIHC
        Endif
        #-----
        # Issue 79434 - 2012-01-31 by VPO : pb calcul taxe speciale (erreur sur base pour prorata)
        #[M:PIH3]DEDTAXOTH2(I)=[M:PIH4]DEDTAX(NOL)*[M:PIH3]AMTNOTLIN(I)/[M:PIH4]BASTAX(NOL)
        [M:PIH3]DEDTAXOTH2(I)=[M:PIH4]DEDTAX(NOL)*WBASE/[M:PIH4]BASTAX(NOL)
        Call ARRDEV([M:PIH3]DEDTAXOTH2(I),GCUR) From TRTDIV : [M:PIH3]UPDFLG(I)=1
        CUMDED+=[M:PIH3]DEDTAXOTH2(I)
        If abs([M:PIH3]AMTNOTLIN(I))>MAXBAS MAXBAS=abs([M:PIH3]AMTNOTLIN(I)) : J=8 : K=I : Endif
      Endif
    Endif
    #----- Mise à jour du TTC ligne si facture non CEE -----#
    If [M:PIH1]VACTYP<>4
      [M:PIH3]AMTATILIN(I)=[M:PIH3]AMTNOTLIN(I)+[M:PIH3]AMTTAXLIN1(I)
&                           +[M:PIH3]AMTTAXLIN2(I)+[M:PIH3]AMTTAXLIN3(I)
      If func AFNC.ACTIV("PTX") & dim([M:PIH3]TAXRCP)>0
        [M:PIH3]AMTATILIN(I)+=[M:PIH3]AMTTAXRCP(I)
        [M:PIH3]AMTATILIN(I)+=[M:PIH3]AMTTAXISS(I)
        [M:PIH3]AMTATILIN(I)+=[M:PIH3]AMTTAXOTH1(I)
        [M:PIH3]AMTATILIN(I)+=[M:PIH3]AMTTAXOTH2(I)
      Endif
    Endif
  Endif
Next I
#----- Imputation des écarts éventuels sur les montants les plus gros -----#
DIFTAX=[M:PIH4]AMTTAX(NOL)-CUMTAX
DIFDED=[M:PIH4]DEDTAX(NOL)-CUMDED
If DIFTAX<>0 | DIFDED<>0
  Case J
    When 1 : [M:PIH4]DTAAMTTAX (K)+=DIFTAX : [M:PIH4]DTADEDTAX (K)+=DIFDED
    When 2 : [M:PIH3]AMTTAXLIN1(K)+=DIFTAX : [M:PIH3]DEDTAXLIN1(K)+=DIFDED
    When 2 : Raz CLCAMTFLG
             #----- Positionnement indicateur de réajustement des bases spéciales 2 à 7 -----#
             For L=2 To 3+4*(func AFNC.ACTIV("PTX") & dim([M:PIH3]CLCAMT4)>0)
               GBIDD2=evalue("[M:PIH3]CLCAMT"+num$(L)+"(I)")
               If GBIDD2<>0 & (GBIDD2=[M:PIH3]AMTNOTLIN(I)+[M:PIH3]AMTTAXLIN1(I) |
&                              GBIDD2=[M:PIH3]AMTTAXLIN1(I))
                 CLCAMTFLG+=2^L-1
               Endif
             Next L
             #-----
             [M:PIH3]AMTTAXLIN1(K)+=DIFTAX : [M:PIH3]DEDTAXLIN1(K)+=DIFDED
             If CLCAMTFLG>0  Call REAJUST_CLCAMT(K,DIFTAX,CLCAMTFLG) From SUBPIHC : Endif
    When 3 : [M:PIH3]AMTTAXLIN2(K)+=DIFTAX : [M:PIH3]DEDTAXLIN2(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR report CPO : comment
             Call LEC_TVT_LEG(GCURLEG,[M:PIH3]VAT2(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:PIH3]VAT2(K) : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPIHC : Endif
    When 4 : [M:PIH3]AMTTAXLIN3(K)+=DIFTAX : [M:PIH3]DEDTAXLIN3(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR report CPO : comment
             Call LEC_TVT_LEG(GCURLEG,[M:PIH3]VAT3(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:PIH3]VAT3(K) : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPIHC : Endif
    When 5 : [M:PIH3]AMTTAXRCP(K)+=DIFTAX  : [M:PIH3]DEDTAXRCP(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR report CPO : comment
             Call LEC_TVT_LEG(GCURLEG,[M:PIH3]TAXRCP(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:PIH3]TAXRCP(K)  : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPIHC : Endif
    When 6 : [M:PIH3]AMTTAXISS(K)+=DIFTAX  : [M:PIH3]DEDTAXISS(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR report CPO : comment
             Call LEC_TVT_LEG(GCURLEG,[M:PIH3]TAXISS(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:PIH3]TAXISS(K)  : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPIHC : Endif
    When 7 : [M:PIH3]AMTTAXOTH1(K)+=DIFTAX : [M:PIH3]DEDTAXOTH1(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR report CPO : comment
             Call LEC_TVT_LEG(GCURLEG,[M:PIH3]TAXOTH1(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:PIH3]TAXOTH1(K) : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPIHC : Endif
    When 8 : [M:PIH3]AMTTAXOTH2(K)+=DIFTAX : [M:PIH3]DEDTAXOTH2(K)+=DIFDED
             # Issue 71937 - 2012-03-27 by SR report CPO : comment
             Call LEC_TVT_LEG(GCURLEG,[M:PIH3]TAXOTH2(K),WRET) From TRTLECLEG
             If WRET : Raz [F:TVT] : Endif
             #Read [TVT] TVT0=[M:PIH3]TAXOTH2(K) : If fstat Raz [F:TVT] : Endif
             If [F:TVT]VATCHA=2 Call REAJUST_BASTAXLIN1(K,DIFTAX) From SUBPIHC : Endif
  Endcase
Endif
End

##################################################################
# CHARG_LIG : S/P chargement d'une ligne de facture              #
#             calcul de la quantité à facturer                   #
# -------------------------------------------------------------- #
# Subprog CHARG_LIG (NOL,NBMAX)                                  #
#    NOL    : Numéro de la ligne en cours (nolign-1)             #
#    NBMAX  : Nombre de lignes déja présentes dans le tableau    #
#                                                                #
# Attention : Les champs TYPORI(NOL), NUMORI(NOL), LINORI(NOL),  #
# SEQORI(NOL) et ITMREF(NOL) doivent être préalablement chargés  #
##################################################################
Subprog CHARG_LIG (NOL,NBMAX)
Value Shortint NOL
Value Shortint NBMAX
Local Shortint I, J
Local Decimal  QTE, QTEMAX
Local Char     VAT(GLONVAT)(3), VACBPR(GLONTVB)
Local Char     SAV_NUMORI(GLONVCR) : SAV_NUMORI=[M:PIH3]NUMORI(NOL)
Local Integer  SAV_LINORI          : SAV_LINORI=[M:PIH3]LINORI(NOL)
# Issue 82703 - 2012-10-05 by SR Si pas facture complémentaire
Local Integer  SAV_SEQORI          : SAV_SEQORI=[M:PIH3]SEQORI(NOL)
Local Char     SAV_ITMREF(GLONITM) : SAV_ITMREF=[M:PIH3]ITMREF(NOL)
Local Char     WITMREF_ORI(GLONITM)
Local Libelle  ORIPRIRCP
Local Decimal  SAV_QTYUOM, SAV_QTYPUU, SAV_NETPRIN, SAV_AMTNOTLIN
# Issue 81115 - 2012-04-12 by SR
Local Integer AXE
Local Char    WCCE(GLONCCE)
# Issue 94288 - 2013-11-14 by SR
Local Integer WSTATUS

# Issue 84130 - 2013-03-18 by MUARN : landed cost - poids et volume
If dim([L]WOLDQTYSTU)<0 Local Decimal  WOLDQTYSTU       : Endif

[M:PIH3]LINPURTYP(NOL)=1
[M:PIH3]LINFLG(NOL)=0
If dim([M:PIH3]LINDSP)>0
  [M:PIH3]LINDSP(NOL)="" : # Evite l'initialisation en attendant gestion sur autres documents
Endif
If GMODU(5)=2  & [M:PIH0]SIHNUM=""  Raz [F:SID] : Endif : # à cause de l'INISEC "PID"
#---------------------------------------#
# Préchargement à partir des commandes  #
#---------------------------------------#
# Issue 82703 - 2012-10-05 by SR Si pas facture complémentaire
If ([M:PIH3]TYPORI(NOL)=1 | [M:PIH3]TYPORI(NOL)=9) & [M:PIH0]PIHTYP <> 2
   If [F:POH]POHNUM<>[M:PIH3]NUMORI(NOL)
      Read [POH] POH0=[M:PIH3]NUMORI(NOL) : If fstat Raz [F:POH] : Endif
   Endif
   #----- Si 1ère ligne commande facturée, reprise infos tiers payé ...etc -----#
   If [M:PIH3]NBLIG=0
     Gosub REPRISE_INFOS
   Endif
   #----- Si 1ère ligne commande facturée reprise adresse fournisseur divers -----#
   If (NOL=0 | !find(1,[M:PIH3]TYPORI(0..NOL-1))) & [M:PIH0]BPR=[F:POH]BPSNUM & [M:AD66]ADBFLG<>2
     If [F:BPS]BPSNUM<>[M:PIH0]BPR
       Read [BPS] BPS0=[M:PIH0]BPR
     Endif
     If [F:BPS]BPSTYP=3
       [M:AD66] = [F:POH]
       [M:AD66]ADBFLG = 2
       If !GIMPORT
         [M:PIH0]BPRNAM1=[M:AD66]BPRNAM(0)
         Affzo [PIH0]BPRNAM1
       Endif
       #----- Recopie adresse fournisseur facturant divers pour fournisseur payé -----#
       If [M:PIH1]BPRPAY=[M:PIH0]BPR & [M:AD67]ADBFLG<>2
         [M:AD67]=[M:AD66]
       Endif
     Endif
   Endif
   #-----
   # Issue 84130 - 2013-03-14 by MUARN : Landed cost-reprise unité poids volume de la commande si 1ère ligne
   If NOL=0 & ([M:PIH4]DSPVOU <> [F:POH]DSPVOU | [M:PIH4]DSPWEU <> [F:POH]DSPWEU)
     [M:PIH4]DSPVOU = [F:POH]DSPVOU
     [M:PIH4]DSPWEU = [F:POH]DSPWEU
   Endif
   Read [POQ] POQ0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL);[M:PIH3]SEQORI(NOL)
   If fstat Raz [F:POQ] : Endif
   If [F:POH]POHTYP=1
      Read [POP] POP0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL);1
      If fstat : Raz [F:POP] : Endif
   Else
      Filter [POP] Where POHNUM=[M:PIH3]NUMORI(NOL) & POPLIN=[M:PIH3]LINORI(NOL) &
&                        POPDAT>=[F:POQ]DEMRCPDAT
      Read [POP] POP1 First
      If fstat : Raz [F:POP] : Endif
      Filter [POP]
   Endif
   Call CAL_QTEMAX(NOL,NBMAX,QTE) From SUBPIHB : # Calcul quantité maxi facturable
   If [F:POQ]UOMPUUCOE=0 [F:POQ]UOMPUUCOE=1 : Endif
   # Issue 76951/2 - 2011-10-10 by VPO : controler ITMREF même si document origine
   If GIMPORT & [M:PIH3]ITMREF(NOL)<>"" & [M:PIH3]ITMREF(NOL)<>[F:POP]ITMREF
    Call ERREUR ([M:PIH3]ITMREF(NOL)-mess(424,194,1)-[F:POP]ITMREF) From GESECRAN
    GERR=1
    mkstat=2
    End
   Endif
   nolign=NOL+1 : [M:PIH3]=[F:POP] : [M:PIH3]=[F:POQ]
   # Issue 71069 - 2016-06-10 by MUARN : PJT entête
   # Issue 71069-54 - 2016-08-25 by MUARN : import PJT
   If ([M:PIH3]NBLIG = 0 & GPJTSNGDOC = 1) | ([M:PIH3]NBLIG = 1 & GPJTSNGDOC = 1 & [M:PIH0]BETCPY = 2)
&     | (GIMPORT & [M:PIH3]NBLIG=1  & GPJTSNGDOC = 1)
      [M:PIH1]PJTH = [F:POH]PJTH
      If !GIMPORT : Affzo [M:PIH1]PJTH : Endif
   Endif
   Gosub RAZ_CHAMPS_LIGNE
   #----- Si chargement des lignes service et matières fournies -----#
   #If [M:PIH3]LINTYP(NOL)>2
   #  If [M:PIH3]LIKQTYCOE(NOL)<>0
   #    QTE=GPIH_QTE*[M:PIH3]LIKQTYCOE(NOL) : # Calcul qté à partir du produit fini !
   #    Call QTEARR(QTE,[F:POQ]PUU) From TRTDIV
   #  Else
   #    QTE=[F:POQ]QTYPUU
   #  Endif
   #Endif
   #-----
   [M:PIH3]BPSNUM(NOL)    =[F:POH]BPSNUM
   [M:PIH3]FCYLIN(NOL)    =[F:POH]POHFCY
   [M:PIH3]QTYUOM(NOL)    =QTE
   [M:PIH3]UOM(NOL)       =[F:POQ]PUU
   [M:PIH3]UOMPUUCOE(NOL) =1
   [M:PIH3]PUU(NOL)       =[F:POQ]PUU
   [M:PIH3]QTYPUU(NOL)    =QTE
   [M:PIH3]ORIQTYPUU(NOL) =QTE
   If [F:POQ]QTYPUU<>0
     [M:PIH3]ORIQTYWEU(NOL)=[F:POQ]QTYWEU*QTE/[F:POQ]QTYPUU
     Call QTEARR([M:PIH3]ORIQTYWEU(NOL),[M:PIH4]DSPWEU) From TRTDIV
     [M:PIH3]ORIQTYVOU(NOL)=[F:POQ]QTYVOU*QTE/[F:POQ]QTYPUU
     Call QTEARR([M:PIH3]ORIQTYVOU(NOL),[M:PIH4]DSPVOU) From TRTDIV
   Endif
   [M:PIH3]GROPRI(NOL)    =arr([F:POP]GROPRI/[F:POQ]UOMPUUCOE,10^-GDECPRI)
   [M:PIH3]NETPRI(NOL)    =[F:POP]NETPRI/[F:POQ]UOMPUUCOE
   # Issue 70985 - 2012-06-08 by MUARN : landed cost
   If [M:PIH0]PIHTYP =  1
     # Issue 98218 - 2014-03-21 by MUARN : non pris en compte de GPIHCPR pour STCNUM
     If GPIHCPR = 1
       [M:PIH3]CPRCOE(NOL) = 1
       [M:PIH3]CPRAMT(NOL) = 0
       #[M:PIH3]STCNUM(NOL) = ""
     Else
       [M:PIH3]CPRCOE(NOL)  =[F:POQ]CPRCOE
       [M:PIH3]CPRAMT(NOL)  =[F:POQ]CPRAMT
       #[M:PIH3]STCNUM(NOL)  =[F:POQ]STCNUM
     Endif
     [M:PIH3]STCNUM(NOL)  =[F:POQ]STCNUM
   Else
      [M:PIH3]CPRCOE(NOL) = 1
      [M:PIH3]CPRAMT(NOL) = 0
      [M:PIH3]STCNUM(NOL) = ""
      # Issue 121952 - 2017-03-13 by MUARN : raz zones charges
      Raz  [M:PIH3]FCSCPR(NOL), [M:PIH3]FCSCSTPUR(NOL)
   Endif
   # Issue 84130 - 2013-03-14 by MUARN : conversion poids volume si besoin
   WOLDQTYSTU = [M:PIH3]QTYSTU(NOL)
   #----- Chargement unité et quantité en unité de stock ----#
   If [M:PIH3]UOM(NOL)=[M:PIH3]STU(NOL)
     [M:PIH3]QTYSTU(NOL)=[M:PIH3]QTYUOM(NOL)
   Else
     Call PCAL_QTY([M:PIH3]QTYPUU(NOL),[M:PIH3]PUU(NOL),[M:PIH3]QTYSTU(NOL),[M:PIH3]STU(NOL),
&               [M:PIH3]ITMREF(NOL),[M:PIH3]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
   Endif
   If WOLDQTYSTU <> [M:PIH3]QTYSTU(NOL)
      If !clalev([F:TUN])  Local File TABUNIT [TUN] : Endif
      If [F:TUN]UOM<>[M:PIH3]LINWEU(NOL)
        Read [TUN] TUN0=[M:PIH3]LINWEU(NOL) : If fstat Raz [F:TUN] : Endif
      Endif
      [M:PIH3]QTYWEU(NOL) = arr([M:PIH3]QTYWEU(NOL)*[M:PIH3]QTYSTU(NOL)/WOLDQTYSTU,10^-[F:TUN]UOMDEC)
      If [F:TUN]UOM<>[M:PIH3]LINVOU(NOL)
        Read [TUN] TUN0=[M:PIH3]LINVOU(NOL) : If fstat Raz [F:TUN] : Endif
      Endif
      [M:PIH3]QTYVOU(NOL) = arr([M:PIH3]QTYVOU(NOL)*[M:PIH3]QTYSTU(NOL)/WOLDQTYSTU,10^-[F:TUN]UOMDEC)
   Endif
   If [M:PIH4]DSPWEU <> [F:POQ]LINWEU
      Local Char ORI_WEU : ORI_WEU = [F:POQ]LINWEU
      Call PCAL_QTY([M:PIH3]QTYWEU(NOL), ORI_WEU, [M:PIH3]QTYWEU(NOL), [M:PIH4]DSPWEU,
&                   [M:PIH3]ITMREF(NOL), [M:PIH0]BPR, 1,GBIDD2) From TRTACHQTE1
      Call PCAL_QTY([M:PIH3]ORIQTYWEU(NOL), ORI_WEU, [M:PIH3]ORIQTYWEU(NOL), [M:PIH4]DSPWEU,
&                   [M:PIH3]ITMREF(NOL), [M:PIH0]BPR, 1,GBIDD2) From TRTACHQTE1
   Endif
   If [M:PIH4]DSPVOU <> [F:POQ]LINVOU
      Local Char ORI_VOU : ORI_VOU = [F:POQ]LINVOU
      Call PCAL_QTY([M:PIH3]QTYVOU(NOL), ORI_VOU, [M:PIH3]QTYVOU(NOL), [M:PIH4]DSPVOU,
&                   [M:PIH3]ITMREF(NOL), [M:PIH0]BPR, 1,GBIDD2) From TRTACHQTE1
      Call PCAL_QTY([M:PIH3]ORIQTYVOU(NOL), ORI_VOU, [M:PIH3]ORIQTYVOU(NOL), [M:PIH4]DSPVOU,
&                   [M:PIH3]ITMREF(NOL), [M:PIH0]BPR, 1,GBIDD2) From TRTACHQTE1
   Endif

   # Issue 96912 - 2014-02-17 by MUARN : gestion des tarifs en commande ouverte
   If [F:POQ]POHTYP=2
     Local  Decimal  DISCRGVAL(0..8), NETPRI
     For I=1 To 9
       If evalue("DIM([M:PIH3]DISCRGVAL"+num$(I)+"(NOL))")>0
         DISCRGVAL(I-1)=evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(NOL)")
       Endif
     Next I
     Call CALNET(2,[F:BPS]PLISTC,[M:PIH3]GROPRI(NOL),DISCRGVAL,[M:PIH3]QTYUOM(NOL),[M:PIH3]NETPRI(NOL),[M:PIH1]CUR) From TRTPRICE
   Endif

   # Issue 100616 - 2014-11-04 by MUARN : alimentation devise en fonction entête facture
   [M:PIH3]NETCUR(NOL)=[M:PIH1]CUR

   If [M:PIH1]CUR<>[F:POH]CUR Call CONVERSION([F:POH]CUR,NOL) : Endif
   [M:PIH3]AMTNOTLIN(NOL) =[M:PIH3]NETPRI(NOL)*[M:PIH3]QTYUOM(NOL)
   Call ARRDEV([M:PIH3]AMTNOTLIN(NOL),[M:PIH1]CUR) From TRTDIV
   # Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
   [M:PIH3]AMTNOTLINCAL(NOL) =[M:PIH3]AMTNOTLIN(NOL)
   [M:PIH3]NETPRI(NOL)    =arr([M:PIH3]NETPRI(NOL),10^-GDECPRI)
   [M:PIH3]ORINETPRI(NOL) =[M:PIH3]NETPRI(NOL)
   If dim([M:PIH3]TSICOD1(NOL))>0 [M:PIH3]TSICOD1(NOL)=[F:POP]TSICOD(0) : Endif
   If dim([M:PIH3]TSICOD2(NOL))>0 [M:PIH3]TSICOD2(NOL)=[F:POP]TSICOD(1) : Endif
   If dim([M:PIH3]TSICOD3(NOL))>0 [M:PIH3]TSICOD3(NOL)=[F:POP]TSICOD(2) : Endif
   If dim([M:PIH3]TSICOD4(NOL))>0 [M:PIH3]TSICOD4(NOL)=[F:POP]TSICOD(3) : Endif
   If dim([M:PIH3]TSICOD5(NOL))>0 [M:PIH3]TSICOD5(NOL)=[F:POP]TSICOD(4) : Endif
   #----- Chargement comptes et sections analytiques -----#
   Call CHARG_ACCCCE(NOL,"[M:PIH3]LINACC","[M:PIH3]LINDSP","[M:PIH3]CCE",
&                    "POP",0,[F:POP]POHNUM,[F:POP]POPLIN,[F:POP]POPSEQ,"") From TRTX3CPT
   #----- Alimentation des provinces -----#
   If func AFNC.ACTIV("PTX")
     #----- Chargement province de sortie -----#
     If dim([M:PIH3]SATISS)>0
       If [F:POH]BPOCRY<>"" | [F:POH]BPOCTY<>""
         [M:PIH3]SATISS(NOL)=[F:POH]BPOSAT
       Else
         #----- Lecture de l'adresse d'expédition si nécessaire -----#
         If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:POH]BPSNUM | [F:BPA]BPAADD<>[F:POH]BPOADD
           Read [BPA] BPA0=1;[F:POH]BPSNUM;[F:POH]BPOADD
           If fstat  Raz [F:BPA] : Endif
         Endif
         #-----
         [M:PIH3]SATISS(NOL)=[F:BPA]SAT
       Endif
     Endif
     #----- Chargement province d'entrée -----#
     If dim([M:PIH3]SATRCP)>0
       If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[F:POQ]PRHFCY | [F:BPA]BPAADD<>[F:POQ]FCYADD
         Read [BPA] BPA0=3;[F:POQ]PRHFCY;[F:POQ]FCYADD
         If fstat  Raz [F:BPA] : Endif
       Endif
       [M:PIH3]SATRCP=[F:BPA]SAT
     Endif
   Endif
   #-----
   If [F:POH]VACBPR<>[M:PIH1]VAC & [M:PIH3]LINTYP(NOL)<>2
     If [F:ITM]ITMREF<>[M:PIH3]ITMREF(NOL)
       Read [ITM] ITM0=[M:PIH3]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
     Endif
     Call ALIVATCOD(2,[M:PIH0]BPR,[M:PIH3]ITMREF(NOL),"PIH3",NOL) From TRTX3
   Else
     [M:PIH3]VAT1(NOL)=[F:POP]VAT(0)
     [M:PIH3]VAT2(NOL)=[F:POP]VAT(1)
     [M:PIH3]VAT3(NOL)=[F:POP]VAT(2)
   Endif
   [M:PIH3]PRTFLG(NOL)=1 : Gosub SIGN_DISCRGVAL
#---------------------------------------#
# Préchargement à partir des réceptions #
#---------------------------------------#
Elsif [M:PIH3]TYPORI(NOL)=2 & [M:PIH0]PIHTYP<>2
   If !clalev([F:PIDB])  Local File PINVOICED [PIDB] : Endif
   If !clalev([F:PIDC])  Local File PINVOICED [PIDC] : Endif
   If [F:PTH]PTHNUM<>[M:PIH3]NUMORI(NOL)
      Read [PTH] PTH0=[M:PIH3]NUMORI(NOL) : If fstat Raz [F:PTH] : Endif
   Endif
   Read [PTD] PTD0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
   If fstat Raz [F:PTD] : Endif
   #VPO 03/02/11 71185 ajout lecture POHNUMORI ssi TYPORI=2
   [M:PIH3]POHNUMORI(NOL)=[F:PTD]POHNUM
   #----- Lecture entête et ligne commande se rapportant à la réception -----#
   If [F:PTD]POHNUM<>""
     If [F:POH]POHNUM<>[F:PTD]POHNUM | [F:POH]POHTYP=0
        Read [POH] POH0=[F:PTD]POHNUM : If fstat Raz [F:POH] : Endif
     Endif
     Read [POQ] POQ0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
     If fstat Raz [F:POQ] : Endif
     If [F:POH]POHTYP=1
        Read [POP] POP0=[F:PTD]POHNUM;[F:PTD]POPLIN;1
        If fstat : Raz [F:POP] : Endif
     Else
        Filter [POP] Where POHNUM=[F:PTD]POHNUM & POPLIN=[F:PTD]POPLIN &
&                          POPDAT>=[F:POQ]DEMRCPDAT
        Read [POP] POP1 First
        If fstat : Raz [F:POP] : Endif
        Filter [POP]
     Endif
     # Issue 107480 - 2015-04-16 by SR : Perf
     [M:PIH3]POHNUMPTD(NOL)     = [F:PTD]POHNUM
     [M:PIH3]POPLINPTD(NOL)     = [F:PTD]POPLIN
     [M:PIH3]POQSEQPTD(NOL)     = [F:PTD]POQSEQ
     [M:PIH3]QTYPUUPTD(NOL)     = [F:PTD]QTYPUU
     [M:PIH3]INVQTYPUUPTD(NOL)  = [F:PTD]INVQTYPUU
    # End issue 107480
   Else Raz [F:POH], [F:POQ], [F:POP]
   Endif
   #----- Si 1ère ligne réception facturée, reprise infos tiers payé ...etc -----#
   If [M:PIH3]NBLIG=0
     Gosub REPRISE_INFOS
   Endif
   #----- Si 1ère ligne récept/cde facturée reprise adresse fournisseur divers -----#
   If (NOL=0 | !find(1,[M:PIH3]TYPORI(0..NOL-1))) & [M:PIH0]BPR=[F:POH]BPSNUM & [M:AD66]ADBFLG<>2
     If [F:BPS]BPSNUM<>[M:PIH0]BPR
       Read [BPS] BPS0=[M:PIH0]BPR
     Endif
     If [F:BPS]BPSTYP=3
       [M:AD66] = [F:POH]
       [M:AD66]ADBFLG = 2
       If !GIMPORT
         [M:PIH0]BPRNAM1=[M:AD66]BPRNAM(0)
         Affzo [PIH0]BPRNAM1
       Endif
       #----- Recopie adresse fournisseur facturant divers pour fournisseur payé -----#
       If [M:PIH1]BPRPAY=[M:PIH0]BPR & [M:AD67]ADBFLG<>2
         [M:AD67]=[M:AD66]
       Endif
     Endif
   Endif
   #-----
   # Issue 84130 - 2013-03-14 by MUARN : Landed cost-reprise unité poids volume de la commande si 1ère ligne
   If NOL=0 & ([M:PIH4]DSPVOU <> [F:PTH]DSPVOU | [M:PIH4]DSPWEU <> [F:PTH]DSPWEU)
     [M:PIH4]DSPVOU = [F:PTH]DSPVOU
     [M:PIH4]DSPWEU = [F:PTH]DSPWEU
   Endif
   Call CAL_QTEMAX(NOL,NBMAX,QTE) From SUBPIHB : # Calcul quantité maxi facturable
   QTEMAX=GPIH_QTEMAX
   #-----
   If [F:POQ]UOMPUUCOE=0 [F:POQ]UOMPUUCOE=1 : Endif
   # Issue 76951/2 - 2011-10-10 by VPO : controler ITMREF même si document origine
    If GIMPORT & [M:PIH3]ITMREF(NOL)<>"" & [M:PIH3]ITMREF(NOL)<>[F:PTD]ITMREF
    Call ERREUR ([M:PIH3]ITMREF(NOL)-mess(424,194,1)-[F:PTD]ITMREF) From GESECRAN
    GERR=1
    mkstat=2
    End
   Endif
   nolign=NOL+1
   If [F:PTD]POHNUM<>""
     If [F:POP]POHNUM<>""  [M:PIH3]=[F:POP] : Endif
     If [F:POQ]POHNUM<>""  [M:PIH3]=[F:POQ] : Endif
   Endif
   [M:PIH3]=[F:PTD]
   # Issue 71069 - 2016-06-10 by MUARN : PJT entête
   # Issue 71069-54 - 2016-08-25 by MUARN : import PJT
   If ([M:PIH3]NBLIG = 0 & GPJTSNGDOC = 1) | ([M:PIH3]NBLIG = 1 & GPJTSNGDOC = 1 & [M:PIH0]BETCPY = 2)
&     | (GIMPORT & [M:PIH3]NBLIG=1  & GPJTSNGDOC = 1)
      [M:PIH1]PJTH = [F:PTH]PJTH
      If !GIMPORT : Affzo [M:PIH1]PJTH : Endif
   Endif
   Gosub RAZ_CHAMPS_LIGNE
   #----- Si chargement des lignes service et matières fournies -----#
   #If [M:PIH3]LINTYP(NOL)>2
   #  If [M:PIH3]LIKQTYCOE(NOL)<>0
   #    QTE=GPIH_QTE*[M:PIH3]LIKQTYCOE(NOL) : # Calcul qté à partir du produit fini !
   #    Call QTEARR(QTE,[F:PTD]PUU) From TRTDIV
   #  Else
   #    QTE=[F:PTD]QTYPUU
   #  Endif
   #Endif
   #-----
   [M:PIH3]BPSNUM(NOL)    =[F:PTH]BPSNUM
   [M:PIH3]FCYLIN(NOL)    =[F:PTH]PRHFCY
   [M:PIH3]QTYUOM(NOL)    =QTE
   [M:PIH3]UOM(NOL)       =[F:PTD]PUU
   [M:PIH3]UOMPUUCOE(NOL) =1
   [M:PIH3]PUU(NOL)       =[F:PTD]PUU
   [M:PIH3]QTYPUU(NOL)    =QTE
   [M:PIH3]ORIQTYPUU(NOL) =QTE
   #--- Déduire les qtés sur-facturées pour éviter de détecter une différence de qté ---#
   If [F:PTD]INVQTYPUU<>0
     GBIDD3=[F:PTD]INVQTYPUU
     For [PIDB] PID1 Where TYPORI=2
&                        & NUMORI=[F:PTD]PTHNUM
&                        & LINORI=[F:PTD]PTDLIN
       GBIDD3-=[F:PIDB]QTYPUU
       #----- Tenir compte d'éventuels avoirs sur facture -----#
       For [PIDC] PID1 Where TYPORI=4
&                          & NUMORI=[F:PIDB]NUM
&                          & LINORI=[F:PIDB]PIDLIN
         If [F:PIDB]NETPRI=[F:PIDC]NETPRI  GBIDD3+=[F:PIDC]QTYPUU : Endif
       Next
       #-----
     Next
     [M:PIH3]ORIQTYPUU(NOL)+=GBIDD3
   Endif
   #-----
   If [F:PTD]QTYPUU<>0
     [M:PIH3]ORIQTYWEU(NOL)=[F:PTD]QTYWEU*[M:PIH3]ORIQTYPUU(NOL)/[F:PTD]QTYPUU
     Call QTEARR([M:PIH3]ORIQTYWEU(NOL),[M:PIH4]DSPWEU) From TRTDIV
     [M:PIH3]ORIQTYVOU(NOL)=[F:PTD]QTYVOU*[M:PIH3]ORIQTYPUU(NOL)/[F:PTD]QTYPUU
     Call QTEARR([M:PIH3]ORIQTYVOU(NOL),[M:PIH4]DSPVOU) From TRTDIV
   Endif
   [M:PIH3]GROPRI(NOL)    =arr([F:POP]GROPRI/[F:POQ]UOMPUUCOE,10^-GDECPRI)
   #------------------------------------------------------------------#
   # Point d'entrée ORIPRIFAC pour chargement du prix d'origine       #
   # ---------------------------------------------------------------- #
   # Ce point d'entrée n'est appelé que pour les lignes de facture    #
   #      issues des réceptions                                       #
   # ---------------------------------------------------------------- #
   # Variable modifiable par le point d'entrée :                      #
   #    ORIPRIRCP : Indicateur chargement prix d'origine              #
   #                1 = à partir du prix commande (valeur par défaut) #
   #                2 = à partir du prix réception                    #
   #------------------------------------------------------------------#
   ORIPRIRCP=1
   GPOINT="ORIPRIFAC" : Gosub ENTREE From EXEFNC
   # Issue 70985 - 2012-06-08 by MUARN : landed cost
   If [M:PIH0]PIHTYP =  1
     # Issue 98218 - 2014-03-21 by MUARN : non pris en compte de GPIHCPR pour STCNUM
     If GPIHCPR = 1
       [M:PIH3]CPRCOE(NOL) = 1
       [M:PIH3]CPRAMT(NOL) = 0
       #[M:PIH3]STCNUM(NOL) = ""
     Else
       [M:PIH3]CPRCOE(NOL)  =[F:PTD]CPRCOE
       [M:PIH3]CPRAMT(NOL)  =[F:PTD]CPRAMT
       #[M:PIH3]STCNUM(NOL)  =[F:PTD]STCNUM
     Endif
     [M:PIH3]STCNUM(NOL)  =[F:PTD]STCNUM
   Else
      [M:PIH3]CPRCOE(NOL) = 1
      [M:PIH3]CPRAMT(NOL) = 0
      [M:PIH3]STCNUM(NOL) = ""
      # Issue 121952 - 2017-03-13 by MUARN : raz zones charges
      Raz  [M:PIH3]FCSCPR(NOL), [M:PIH3]FCSCSTPUR(NOL)
   Endif
   # Issue 84130 - 2013-03-14 by MUARN : conversion poids volume si besoin
   WOLDQTYSTU = [M:PIH3]QTYSTU(NOL)
   #----- Chargement unité et quantité en unité de stock ----#
   If [M:PIH3]UOM(NOL)=[M:PIH3]STU(NOL)
     [M:PIH3]QTYSTU(NOL)=[M:PIH3]QTYUOM(NOL)
   Else
     Call PCAL_QTY([M:PIH3]QTYPUU(NOL),[M:PIH3]PUU(NOL),[M:PIH3]QTYSTU(NOL),[M:PIH3]STU(NOL),
&               [M:PIH3]ITMREF(NOL),[M:PIH3]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
   Endif
   If WOLDQTYSTU <> [M:PIH3]QTYSTU(NOL)
      If !clalev([F:TUN])  Local File TABUNIT [TUN] : Endif
      If [F:TUN]UOM<>[M:PIH3]LINWEU(NOL)
        Read [TUN] TUN0=[M:PIH3]LINWEU(NOL) : If fstat Raz [F:TUN] : Endif
      Endif
      [M:PIH3]QTYWEU(NOL) = arr([M:PIH3]QTYWEU(NOL)*[M:PIH3]QTYSTU(NOL)/WOLDQTYSTU,10^-[F:TUN]UOMDEC)
      If [F:TUN]UOM<>[M:PIH3]LINVOU(NOL)
        Read [TUN] TUN0=[M:PIH3]LINVOU(NOL) : If fstat Raz [F:TUN] : Endif
      Endif
      [M:PIH3]QTYVOU(NOL) = arr([M:PIH3]QTYVOU(NOL)*[M:PIH3]QTYSTU(NOL)/WOLDQTYSTU,10^-[F:TUN]UOMDEC)
   Endif
   If [M:PIH4]DSPWEU <> [F:PTD]LINWEU
      Local Char ORI_WEU : ORI_WEU = [F:PTD]LINWEU
      Call PCAL_QTY([M:PIH3]QTYWEU(NOL), ORI_WEU, [M:PIH3]QTYWEU(NOL), [M:PIH4]DSPWEU,
&                   [M:PIH3]ITMREF(NOL), [M:PIH0]BPR, 1,GBIDD2) From TRTACHQTE1
      Call PCAL_QTY([M:PIH3]ORIQTYWEU(NOL), ORI_WEU, [M:PIH3]ORIQTYWEU(NOL), [M:PIH4]DSPWEU,
&                   [M:PIH3]ITMREF(NOL), [M:PIH0]BPR, 1,GBIDD2) From TRTACHQTE1
   Endif
   If [M:PIH4]DSPVOU <> [F:PTD]LINVOU
      Local Char ORI_VOU : ORI_VOU = [F:PTD]LINVOU
      Call PCAL_QTY([M:PIH3]QTYVOU(NOL), ORI_VOU, [M:PIH3]QTYVOU(NOL), [M:PIH4]DSPVOU,
&                   [M:PIH3]ITMREF(NOL), [M:PIH0]BPR, 1,GBIDD2) From TRTACHQTE1
      Call PCAL_QTY([M:PIH3]ORIQTYVOU(NOL), ORI_VOU, [M:PIH3]ORIQTYVOU(NOL), [M:PIH4]DSPVOU,
&                   [M:PIH3]ITMREF(NOL), [M:PIH0]BPR, 1,GBIDD2) From TRTACHQTE1
   Endif

   If [F:PTD]POHNUM<>"" & ORIPRIRCP<>2
     [M:PIH3]NETPRI(NOL)  =[F:POP]NETPRI/[F:POQ]UOMPUUCOE
     # Issue 100616 - 2014-11-04 by MUARN : alimentation devise en fonction entête facture
     [M:PIH3]NETCUR(NOL)=[M:PIH1]CUR

     If [M:PIH1]CUR<>[F:POH]CUR Call CONVERSION([F:POH]CUR,NOL) : Endif
   Else
     [M:PIH3]NETPRI(NOL)  =[F:PTD]NETPRIPUU
     # Issue 100616 - 2014-11-04 by MUARN : alimentation devise en fonction entête facture
     [M:PIH3]NETCUR(NOL)=[M:PIH1]CUR

     If [M:PIH1]CUR<>[F:PTD]NETCUR Call CONVERSION([F:PTD]NETCUR,NOL) : Endif
     [M:PIH3]GROPRI(NOL)  =[M:PIH3]NETPRI(NOL)
   Endif
   [M:PIH3]AMTNOTLIN(NOL) =[M:PIH3]NETPRI(NOL)*[M:PIH3]QTYUOM(NOL)
   Call ARRDEV([M:PIH3]AMTNOTLIN(NOL),[M:PIH1]CUR) From TRTDIV
   # Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
   [M:PIH3]AMTNOTLINCAL(NOL) =[M:PIH3]AMTNOTLIN(NOL)
   [M:PIH3]NETPRI(NOL)    =arr([M:PIH3]NETPRI(NOL),10^-GDECPRI)
   [M:PIH3]ORINETPRI(NOL) =[M:PIH3]NETPRI(NOL)
   If dim([M:PIH3]TSICOD1(NOL))>0 [M:PIH3]TSICOD1(NOL)=[F:PTD]TSICOD(0) : Endif
   If dim([M:PIH3]TSICOD2(NOL))>0 [M:PIH3]TSICOD2(NOL)=[F:PTD]TSICOD(1) : Endif
   If dim([M:PIH3]TSICOD3(NOL))>0 [M:PIH3]TSICOD3(NOL)=[F:PTD]TSICOD(2) : Endif
   If dim([M:PIH3]TSICOD4(NOL))>0 [M:PIH3]TSICOD4(NOL)=[F:PTD]TSICOD(3) : Endif
   If dim([M:PIH3]TSICOD5(NOL))>0 [M:PIH3]TSICOD5(NOL)=[F:PTD]TSICOD(4) : Endif
   #----- Chargement comptes et sections analytiques -----#
   Call CHARG_ACCCCE(NOL,"[M:PIH3]LINACC","[M:PIH3]LINDSP","[M:PIH3]CCE",
&                    "PTD",0,[F:PTD]PTHNUM,[F:PTD]PTDLIN,0,"") From TRTX3CPT
   #----- Alimentation des provinces (sortie alimentée par transclasse) -----#
   If func AFNC.ACTIV("PTX")
     #----- Chargement province d'entrée -----#
     If dim([M:PIH3]SATRCP)>0
       If [F:FCY]FCY<>[F:PTH]PRHFCY
         Read [FCY] FCY0=[F:PTH]PRHFCY : If fstat  Raz [F:FCY] : Endif
       Endif
       If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[F:PTH]PRHFCY | [F:BPA]BPAADD<>[F:FCY]BPAADD
         Read [BPA] BPA0=3;[F:PTH]PRHFCY;[F:FCY]BPAADD
         If fstat  Raz [F:BPA] : Endif
       Endif
       [M:PIH3]SATRCP(NOL)=[F:BPA]SAT
     Endif
   Endif
   #-----
   If [F:POH]VACBPR=""
     Call INIT_REGIME([F:PTH]BPSNUM,[F:PTH]PRHFCY,"F",[L]VACBPR) From CPTSUB
   Else
     [L]VACBPR=[F:POH]VACBPR
   Endif
   If [L]VACBPR<>[M:PIH1]VAC & [M:PIH3]LINTYP(NOL)<>2
     If [F:ITM]ITMREF<>[M:PIH3]ITMREF(NOL)
       Read [ITM] ITM0=[M:PIH3]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
     Endif
     Call ALIVATCOD(2,[M:PIH0]BPR,[M:PIH3]ITMREF(NOL),"PIH3",NOL) From TRTX3
   Else
     [M:PIH3]VAT1(NOL)=[F:PTD]VAT(0)
     [M:PIH3]VAT2(NOL)=[F:PTD]VAT(1)
     [M:PIH3]VAT3(NOL)=[F:PTD]VAT(2)
   Endif
   If QTE<QTEMAX [M:PIH3]PRTFLG(NOL)=2 Else [M:PIH3]PRTFLG(NOL)=1 : Endif
   Gosub SIGN_DISCRGVAL
#---------------------------------------#
#  Préchargement à partir des retours   #
#---------------------------------------#
Elsif [M:PIH3]TYPORI(NOL)=3
   If [F:PNH]PNHNUM<>[M:PIH3]NUMORI(NOL)
      Read [PNH] PNH0=[M:PIH3]NUMORI(NOL) : If fstat Raz [F:PNH] : Endif
   Endif
   Read [PND] PND0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
   If fstat Raz [F:PND] : Endif
   #----- Lecture entête et ligne réception se rapportant au retour -----#
   If [F:PND]PTHNUM<>""
     If [F:PTH]PTHNUM<>[F:PND]PTHNUM
       Read [PTH] PTH0=[F:PND]PTHNUM : If fstat Raz [F:PTH] : Endif
     Endif
     Read [PTD] PTD0=[F:PND]PTHNUM;[F:PND]PTDLIN
     If fstat Raz [F:PTD] : Endif
     #----- Lecture entête et ligne commande se rapportant à la réception -----#
     If [F:PND]POHNUM<>""
       If [F:POH]POHNUM<>[F:PND]POHNUM
          Read [POH] POH0=[F:PND]POHNUM : If fstat Raz [F:POH] : Endif
       Endif
       Read [POQ] POQ0=[F:PND]POHNUM;[F:PND]POPLIN;[F:PND]POQSEQ
       If fstat Raz [F:POQ] : Endif
       If [F:POH]POHTYP=1
          Read [POP] POP0=[F:PND]POHNUM;[F:PND]POPLIN;1
          If fstat : Raz [F:POP] : Endif
       Else
          Filter [POP] Where POHNUM=[F:PND]POHNUM & POPLIN=[F:PND]POPLIN &
&                            POPDAT>=[F:POQ]DEMRCPDAT
          Read [POP] POP1 First
          If fstat : Raz [F:POP] : Endif
          Filter [POP]
       Endif
     Else
       Raz [F:POH], [F:POQ], [F:POP]
     Endif
   Else
     Raz [F:PTH], [F:PTD], [F:POH], [F:POQ], [F:POP]
   Endif
   #----- Si 1ère ligne retour facturé, reprise infos tiers payé ...etc -----#
   If [M:PIH3]NBLIG=0
     Gosub REPRISE_INFOS
   Endif
   #-----
   Call CAL_QTEMAX(NOL,NBMAX,QTE) From SUBPIHB : # Calcul quantité maxi facturable
   If [F:PND]UOMPUUCOE=0 [F:PND]UOMPUUCOE=1 : Endif
   # Issue 76951/2 - 2011-10-10 by VPO : controler ITMREF même si document origine
   If GIMPORT & [M:PIH3]ITMREF(NOL)<>"" & [M:PIH3]ITMREF(NOL)<>[F:PND]ITMREF
    Call ERREUR ([M:PIH3]ITMREF(NOL)-mess(424,194,1)-[F:PND]ITMREF) From GESECRAN
    GERR=1
    mkstat=2
    End
   Endif
   nolign=NOL+1
   [M:PIH3]=[F:PND]
   # Issue 71069 - 2016-06-10 by MUARN : PJT entête
   # Issue 71069-54 - 2016-08-25 by MUARN : import PJT
   If ([M:PIH3]NBLIG = 0 & GPJTSNGDOC = 1) | (GIMPORT & [M:PIH3]NBLIG=1  & GPJTSNGDOC = 1)
      [M:PIH1]PJTH = [F:PNH]PJTH
      If !GIMPORT : Affzo [M:PIH1]PJTH : Endif
   Endif
   If [F:PND]PTHNUM<>""
     If [F:POP]POHNUM<>""  [M:PIH3]=[F:POP] : Endif
     If [F:POQ]POHNUM<>""  [M:PIH3]=[F:POQ] : Endif
   Endif
   Gosub RAZ_CHAMPS_LIGNE
   #----- Si chargement des lignes service et matières fournies -----#
   #If [M:PIH3]LINTYP(NOL)>2
   #  If [M:PIH3]LIKQTYCOE(NOL)<>0
   #    QTE=GPIH_QTE*[M:PIH3]LIKQTYCOE(NOL) : # Calcul qté à partir du produit fini !
   #    Call QTEARR(QTE,[F:PND]PUU) From TRTDIV
   #  Else
   #    QTE=[F:PND]QTYPUU
   #  Endif
   #Endif
   #-----
   # Issue 71069 - 2016-09-19 by SR : PJT écrasé par celui de la ligne commande
   [M:PIH3]PJT(NOL)       =[F:PND]PJT
   [M:PIH3]BPSNUM(NOL)    =[F:PNH]BPSNUM
   [M:PIH3]FCYLIN(NOL)    =[F:PNH]PNHFCY
   [M:PIH3]QTYUOM(NOL)    =QTE
   [M:PIH3]UOM(NOL)       =[F:PND]PUU
   [M:PIH3]UOMPUUCOE(NOL) =1
   [M:PIH3]PUU(NOL)       =[F:PND]PUU
   [M:PIH3]QTYPUU(NOL)    =QTE
   [M:PIH3]ORIQTYPUU(NOL) =QTE
   If [F:ITM]ITMREF<>[F:PND]ITMREF
     Read [ITM] ITM0=[F:PND]ITMREF : If fstat  Raz [F:ITM] : Endif
   Endif
   Call PCAL_QTY(QTE,[F:PND]PUU,GBIDD1,[F:PND]STU,
&                    [F:PND]ITMREF,[F:PND]BPSNUM,1,GBIDD2) From TRTACHQTE1
   [M:PIH3]ORIQTYWEU(NOL)=[F:ITM]ITMWEI*GBIDD1
   [M:PIH3]ORIQTYVOU(NOL)=[F:ITM]ITMVOU*GBIDD1
   Call CONVERT_QTY([F:ITM]WEU,[M:PIH4]DSPWEU,[M:PIH3]ORIQTYWEU(NOL)) From TRTX3
   Call CONVERT_QTY([F:ITM]VOU,[M:PIH4]DSPVOU,[M:PIH3]ORIQTYVOU(NOL)) From TRTX3
   If [F:PND]POHNUM<>""
     If [F:POQ]UOMPUUCOE=0 [F:POQ]UOMPUUCOE=1 : Endif
     [M:PIH3]GROPRI(NOL)  =arr([F:POP]GROPRI/[F:POQ]UOMPUUCOE,10^-GDECPRI)
     [M:PIH3]NETPRI(NOL)  =arr([F:POP]NETPRI/[F:POQ]UOMPUUCOE,10^-GDECPRI)
     # Issue 100616 - 2014-11-04 by MUARN : alimentation devise en fonction entête facture
     [M:PIH3]NETCUR(NOL)=[M:PIH1]CUR

     If [M:PIH1]CUR<>[F:POH]CUR Call CONVERSION([F:POH]CUR,NOL) : Endif
   Else
     [M:PIH3]NETPRI(NOL)  =[F:PND]NETPRIPUU
     # Issue 84557 - 2012-09-26 by MUARN : alimentation devise en fonction entête facture
     [M:PIH3]NETCUR(NOL)=[M:PIH1]CUR

     If [M:PIH1]CUR<>[F:PND]NETCUR Call CONVERSION([F:PND]NETCUR,NOL) : Endif
     [M:PIH3]GROPRI(NOL)  =[M:PIH3]NETPRI(NOL)
   Endif
   #-------------------------------------------------------------------#
   # Point d'entrée ORIPRIAVR pour chargement d'un prix net spécifique #
   # ----------------------------------------------------------------- #
   # Ce point d'entrée n'est appelé que pour les lignes d'avoir        #
   #      issues des retours                                           #
   # ----------------------------------------------------------------- #
   # Variables modifiables par le point d'entrée :                     #
   #   [M:PIH3]GROPRI (NOL)       Prix unitaire brut                   #
   #   [M:PIH3]DISCRGVALx (NOL)   Remises/Frais 1 à 9                  #
   #   [M:PIH3]NETPRI (NOL)       Prix unitaire net                    #
   #   [M:PIH3]PRIREN (NOL)       Motif prix brut                      #
   #   [M:PIH3]DISCRGRENx (NOL)   Motifs Remises/Frais 1 à 9           #
   #-------------------------------------------------------------------#
   GPOINT="ORIPRIAVR" : Gosub ENTREE From EXEFNC
   # Issue 70985 - 2012-06-08 by MUARN : landed cost
   [M:PIH3]CPRCOE(NOL)    =1
   [M:PIH3]CPRAMT(NOL)    =0
   [M:PIH3]STCNUM(NOL)    = ""
   # Issue 121952 - 2017-03-13 by MUARN : raz zones charges
   Raz  [M:PIH3]FCSCPR(NOL), [M:PIH3]FCSCSTPUR(NOL)

   #-----
   [M:PIH3]ORINETPRI(NOL) =[M:PIH3]NETPRI(NOL)
   [M:PIH3]AMTNOTLIN(NOL) =[M:PIH3]NETPRI(NOL)*[M:PIH3]QTYUOM(NOL)
   Call ARRDEV([M:PIH3]AMTNOTLIN(NOL),[M:PIH1]CUR) From TRTDIV
   # Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
   [M:PIH3]AMTNOTLINCAL(NOL) =[M:PIH3]AMTNOTLIN(NOL)
   If dim([M:PIH3]TSICOD1(NOL))>0 [M:PIH3]TSICOD1(NOL)=[F:PND]TSICOD(0) : Endif
   If dim([M:PIH3]TSICOD2(NOL))>0 [M:PIH3]TSICOD2(NOL)=[F:PND]TSICOD(1) : Endif
   If dim([M:PIH3]TSICOD3(NOL))>0 [M:PIH3]TSICOD3(NOL)=[F:PND]TSICOD(2) : Endif
   If dim([M:PIH3]TSICOD4(NOL))>0 [M:PIH3]TSICOD4(NOL)=[F:PND]TSICOD(3) : Endif
   If dim([M:PIH3]TSICOD5(NOL))>0 [M:PIH3]TSICOD5(NOL)=[F:PND]TSICOD(4) : Endif
   #----- Chargement comptes et sections analytiques -----#
   Call CHARG_ACCCCE(NOL,"[M:PIH3]LINACC","[M:PIH3]LINDSP","[M:PIH3]CCE",
&                    "PND",0,[F:PND]PNHNUM,[F:PND]PNDLIN,0,"") From TRTX3CPT
   #----- Alimentation des provinces (sortie alimentée par transclasse) -----#
   If func AFNC.ACTIV("PTX")
     #----- Chargement province d'entrée -----#
     If dim([M:PIH3]SATRCP)>0
       If [F:FCY]FCY<>[F:PNH]PNHFCY
         Read [FCY] FCY0=[F:PNH]PNHFCY : If fstat  Raz [F:FCY] : Endif
       Endif
       If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[F:PNH]PNHFCY | [F:BPA]BPAADD<>[F:FCY]BPAADD
         Read [BPA] BPA0=3;[F:PNH]PNHFCY;[F:FCY]BPAADD
         If fstat  Raz [F:BPA] : Endif
       Endif
       [M:PIH3]SATRCP(NOL)=[F:BPA]SAT
     Endif
   Endif
   #-----
   If [F:PNH]VACBPR<>[M:PIH1]VAC & [M:PIH3]LINTYP(NOL)<>2
     If [F:ITM]ITMREF<>[M:PIH3]ITMREF(NOL)
       Read [ITM] ITM0=[M:PIH3]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
     Endif
     Call ALIVATCOD(2,[M:PIH0]BPR,[M:PIH3]ITMREF(NOL),"PIH3",NOL) From TRTX3
   Else
     [M:PIH3]VAT1(NOL)=[F:PND]VAT(0)
     [M:PIH3]VAT2(NOL)=[F:PND]VAT(1)
     [M:PIH3]VAT3(NOL)=[F:PND]VAT(2)
   Endif
   [M:PIH3]PRTFLG(NOL)=1 : Gosub SIGN_DISCRGVAL
#-------------------------------------------------#
# Préchargement de l'avoir à partir de la facture #
#-------------------------------------------------#
Elsif [M:PIH3]TYPORI(NOL)=4 & [M:PIH0]PIHTYP=3
   If clalev([F:PIHB])<=0 Local File PINVOICE  [PIHB] : Endif
   If clalev([F:PIDB])<=0 Local File PINVOICED [PIDB] : Endif
   # Issue 84130 - 2013-03-15 by MUARN : landed cost - pour unité poids et volume  facture d'origine
   If clalev([F:PIVB])<=0 Local File PINVOICEV [PIVB] : Endif
   If [F:PIVB]NUM<>[M:PIH3]NUMORI(NOL)
     Read [PIVB] PIV0=[M:PIH3]NUMORI(NOL) : If fstat Raz [F:PIVB] : Endif
   Endif

   If [F:PIHB]NUM<>[M:PIH3]NUMORI(NOL)
      Read [PIHB] PIH0=[M:PIH3]NUMORI(NOL) : If fstat Raz [F:PIHB] : Endif
   Endif
   Read [PIDB] PID0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
   If fstat Raz [F:PIDB] : Endif
   Call CAL_QTEMAX(NOL,NBMAX,QTE) From SUBPIHB : # Calcul quantité maxi facturable
   # Issue 76951/2 - 2011-10-10 by VPO : controler ITMREF même si document origine
   If GIMPORT & [M:PIH3]ITMREF(NOL)<>"" & [M:PIH3]ITMREF(NOL)<>[F:PIDB]ITMREF
    Call ERREUR ([M:PIH3]ITMREF(NOL)-mess(424,194,1)-[F:PIDB]ITMREF) From GESECRAN
    GERR=1
    mkstat=2
    End
   Endif
   # Issue 84130 - 2013-03-14 by MUARN : Landed cost-reprise unité poids volume de la commande si 1ère ligne
   If NOL=0 & ([M:PIH4]DSPVOU <> [F:PIVB]DSPVOU | [M:PIH4]DSPWEU <> [F:PIVB]DSPWEU)
     [M:PIH4]DSPVOU = [F:PIVB]DSPVOU
     [M:PIH4]DSPWEU = [F:PIVB]DSPWEU
   Endif
   nolign=NOL+1 : [M:PIH3]=[F:PIDB]
   # Issue 71069 - 2016-06-10 by MUARN : PJT entête
   # Issue 71069-54 - 2016-08-25 by MUARN : import PJT
   If ([M:PIH3]NBLIG = 0 & GPJTSNGDOC = 1) | (GIMPORT & [M:PIH3]NBLIG=1  & GPJTSNGDOC = 1)
      [M:PIH1]PJTH = [F:PIHB]PJTH
      If !GIMPORT : Affzo [M:PIH1]PJTH : Endif
   Endif
   Raz [M:PIH3]LINTEX(NOL),     [M:PIH3]PIDLIN(NOL),
&      [M:PIH3]DISCRGAMT1(NOL), [M:PIH3]DISCRGAMT2(NOL),
&      [M:PIH3]DISCRGAMT3(NOL), [M:PIH3]DISCRGAMT4(NOL),
&      [M:PIH3]DISCRGAMT5(NOL), [M:PIH3]DISCRGAMT6(NOL),
&      [M:PIH3]DISCRGAMT7(NOL), [M:PIH3]DISCRGAMT8(NOL),
&      [M:PIH3]DISCRGAMT9(NOL)
   [M:PIH3]TYPORI(NOL)    =4              : # A cause du transclasse
   [M:PIH3]NUMORI(NOL)    =SAV_NUMORI     : # A cause du transclasse
   [M:PIH3]LINORI(NOL)    =SAV_LINORI     : # A cause du transclasse
   [M:PIH3]SEQORI(NOL)    =0              : # A cause du transclasse
   [M:PIH3]QTYUOM(NOL)    =QTE/[F:PIDB]UOMPUUCOE
   [M:PIH3]QTYPUU(NOL)    =QTE
   Call QTEARR([M:PIH3]QTYPUU(NOL),[M:PIH3]PUU(NOL)) From TRTDIV
   [M:PIH3]ORIQTYPUU(NOL) =[M:PIH3]QTYPUU(NOL)
   If [F:PIDB]QTYPUU<>0
     [M:PIH3]ORIQTYWEU(NOL) =[F:PIDB]QTYWEU*QTE/[F:PIDB]QTYPUU
     Call QTEARR([M:PIH3]ORIQTYWEU(NOL),[M:PIH4]DSPWEU) From TRTDIV
     [M:PIH3]ORIQTYVOU(NOL) =[F:PIDB]QTYVOU*QTE/[F:PIDB]QTYPUU
     Call QTEARR([M:PIH3]ORIQTYVOU(NOL),[M:PIH4]DSPVOU) From TRTDIV
   Endif
   # Issue 84557 - 2012-09-26 by MUARN : alimentation devise en fonction entête facture
   [M:PIH3]NETCUR(NOL)=[M:PIH1]CUR

   If [M:PIH1]CUR<>[F:PIHB]CUR Call CONVERSION([F:PIHB]CUR,NOL) : Endif

   # Issue 70985 - 2012-06-08 by MUARN : landed cost
   [M:PIH3]CPRCOE(NOL)    =1
   [M:PIH3]CPRAMT(NOL)    =0
   [M:PIH3]STCNUM(NOL)    = ""
   # Issue 121952 - 2017-03-13 by MUARN : raz zones charges
   Raz  [M:PIH3]FCSCPR(NOL), [M:PIH3]FCSCSTPUR(NOL)

   If [F:PIHB]PIHTYP=2 & [F:PIDB]NETPRI=0
     [M:PIH3]ORIQTYPUU(NOL)=[F:PIDB]ORIQTYPUU
     [M:PIH3]ORIQTYWEU(NOL)=[F:PIDB]ORIQTYWEU
     [M:PIH3]ORIQTYVOU(NOL)=[F:PIDB]ORIQTYVOU
     Raz [M:PIH3]NETPRI(NOL), [M:PIH3]ORINETPRI(NOL)
   Else
     If [PIHB]PIHTYP=1
       [M:PIH3]ORINETPRI(NOL)=[M:PIH3]NETPRI(NOL)
     Endif
     If [F:PIDB]NETPRI<>0 & [M:PIH3]QTYUOM(NOL)<>0
       [M:PIH3]AMTNOTLIN(NOL)=[M:PIH3]NETPRI(NOL)*[M:PIH3]QTYUOM(NOL)
     Endif
   Endif

   # Issue 84130 - 2013-03-14 by MUARN : conversion poids volume si besoin
   WOLDQTYSTU = [M:PIH3]QTYSTU(NOL)
   #----- Chargement unité et quantité en unité de stock ----#
   If [M:PIH3]UOM(NOL)=[M:PIH3]STU(NOL)
     [M:PIH3]QTYSTU(NOL)=[M:PIH3]QTYUOM(NOL)
   Else
     Call PCAL_QTY([M:PIH3]QTYPUU(NOL),[M:PIH3]PUU(NOL),[M:PIH3]QTYSTU(NOL),[M:PIH3]STU(NOL),
&               [M:PIH3]ITMREF(NOL),[M:PIH3]BPSNUM(NOL),1,GBIDD1) From TRTACHQTE1
   Endif
   If WOLDQTYSTU <> [M:PIH3]QTYSTU(NOL)
      If !clalev([F:TUN])  Local File TABUNIT [TUN] : Endif
      If [F:TUN]UOM<>[M:PIH3]LINWEU(NOL)
        Read [TUN] TUN0=[M:PIH3]LINWEU(NOL) : If fstat Raz [F:TUN] : Endif
      Endif
      [M:PIH3]QTYWEU(NOL) = arr([M:PIH3]QTYWEU(NOL)*[M:PIH3]QTYSTU(NOL)/WOLDQTYSTU,10^-[F:TUN]UOMDEC)
      If [F:TUN]UOM<>[M:PIH3]LINVOU(NOL)
        Read [TUN] TUN0=[M:PIH3]LINVOU(NOL) : If fstat Raz [F:TUN] : Endif
      Endif
      [M:PIH3]QTYVOU(NOL) = arr([M:PIH3]QTYVOU(NOL)*[M:PIH3]QTYSTU(NOL)/WOLDQTYSTU,10^-[F:TUN]UOMDEC)
   Endif
   If [M:PIH4]DSPWEU <> [F:PIVB]DSPWEU
      Local Char ORI_WEU : ORI_WEU = [F:PIVB]DSPWEU
      Call PCAL_QTY([M:PIH3]QTYWEU(NOL), ORI_WEU, [M:PIH3]QTYWEU(NOL), [M:PIH4]DSPWEU,
&                   [M:PIH3]ITMREF(NOL), [M:PIH0]BPR, 1,GBIDD2) From TRTACHQTE1
      Call PCAL_QTY([M:PIH3]ORIQTYWEU(NOL), ORI_WEU, [M:PIH3]ORIQTYWEU(NOL), [M:PIH4]DSPWEU,
&                   [M:PIH3]ITMREF(NOL), [M:PIH0]BPR, 1,GBIDD2) From TRTACHQTE1
   Endif
   If [M:PIH4]DSPVOU <> [F:PIVB]DSPVOU
      Local Char ORI_VOU : ORI_VOU = [F:PIVB]DSPVOU
      Call PCAL_QTY([M:PIH3]QTYVOU(NOL), ORI_VOU, [M:PIH3]QTYVOU(NOL), [M:PIH4]DSPVOU,
&                   [M:PIH3]ITMREF(NOL), [M:PIH0]BPR, 1,GBIDD2) From TRTACHQTE1
      Call PCAL_QTY([M:PIH3]ORIQTYVOU(NOL), ORI_VOU, [M:PIH3]ORIQTYVOU(NOL), [M:PIH4]DSPVOU,
&                   [M:PIH3]ITMREF(NOL), [M:PIH0]BPR, 1,GBIDD2) From TRTACHQTE1
   Endif

   Call ARRDEV([M:PIH3]AMTNOTLIN(NOL),[M:PIH1]CUR) From TRTDIV
   # Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
   [M:PIH3]AMTNOTLINCAL(NOL)=[M:PIH3]AMTNOTLIN(NOL)
   If dim([M:PIH3]TSICOD1(NOL))>0 [M:PIH3]TSICOD1(NOL)=[F:PIDB]TSICOD(0) : Endif
   If dim([M:PIH3]TSICOD2(NOL))>0 [M:PIH3]TSICOD2(NOL)=[F:PIDB]TSICOD(1) : Endif
   If dim([M:PIH3]TSICOD3(NOL))>0 [M:PIH3]TSICOD3(NOL)=[F:PIDB]TSICOD(2) : Endif
   If dim([M:PIH3]TSICOD4(NOL))>0 [M:PIH3]TSICOD4(NOL)=[F:PIDB]TSICOD(3) : Endif
   If dim([M:PIH3]TSICOD5(NOL))>0 [M:PIH3]TSICOD5(NOL)=[F:PIDB]TSICOD(4) : Endif
   #----- Chargement comptes et sections analytiques -----#
   Call CHARG_ACCCCE(NOL,"[M:PIH3]LINACC","[M:PIH3]LINDSP","[M:PIH3]CCE",
&                    "PID",0,[F:PIDB]NUM,[F:PIDB]PIDLIN,0,"") From TRTX3CPT
   #-----
   [M:PIH3]VAT1(NOL)=[F:PIDB]VAT(0)
   [M:PIH3]VAT2(NOL)=[F:PIDB]VAT(1)
   [M:PIH3]VAT3(NOL)=[F:PIDB]VAT(2)
   [M:PIH3]PRTFLG(NOL)=1
#--------------------------------------------------#
# Préchargement de la ligne facture complémentaire #
#--------------------------------------------------#
# Issue 82703 - 2012-10-05 by SR
# Issue 110325 - 2016-01-08 by SR : FCC sur expé
Elsif [M:PIH0]PIHTYP=2 & find([M:PIH3]TYPORI(NOL),1,2,4,6)
   #----- Origine commande ou expé -----#
   # Issue 110325 - 2016-01-08 by SR : FCC sur expé
#   If [M:PIH3]TYPORI(NOL)=1
   If find([M:PIH3]TYPORI(NOL),1,6)
     If clalev([F:POQB])<=0 Local File PORDERQ [POQB] : Endif
     If clalev([F:POPB])<=0 Local File PORDERP [POPB] : Endif
     If [M:PIH3]TYPORI(NOL)=1
       Read [POQB] POQ0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL);[M:PIH3]SEQORI(NOL)
       If fstat Raz [F:POQB] : Endif
       Read [POPB] POP0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL);[M:PIH3]SEQORI(NOL)
       If fstat Raz [F:POPB] : Endif
       # Issue 90503 - 2013-06-14 by SR : autorisé si facture complémentaire
  #     If GIMPORT & [M:PIH3]ITMREF(NOL)<>"" & [M:PIH3]ITMREF(NOL)<>[F:POQB]ITMREF
  #      Call ERREUR ([M:PIH3]ITMREF(NOL)-mess(424,194,1)-[F:POQB]ITMREF) From GESECRAN
  #      GERR=1
  #      mkstat=2
  #      End
  #     Endif
       nolign=NOL+1
       [M:PIH3]=[F:POPB]
       [M:PIH3]=[F:POQB]
       # Issue 110325 - 2016-01-11 by SR : FCC sur expé ligne déplacée
       [M:PIH3]TYPORI(NOL) = 1 : # A cause du transclasse
     Else
       If clalev([F:SHDB])<=0 Local File SHIPMENTD [SHDB] : Endif
       Read [SHDB] SHD0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
       If fstat Raz [F:SHDB] : Endif
       Read [POQB] POQ0=[F:SHDB]POHNUM;[F:SHDB]POPLIN;[F:SHDB]POQSEQ
       If fstat Raz [F:POQB] : Endif
       Read [POPB] POP0=[F:SHDB]POHNUM;[F:SHDB]POPLIN;[F:SHDB]POQSEQ
       If fstat Raz [F:POPB] : Endif
       nolign=NOL+1
       [M:PIH3]=[F:POPB]
       [M:PIH3]=[F:POQB]
       [M:PIH3]=[F:SHDB]
       [M:PIH3]TYPORI(NOL) = 6 : # A cause du transclasse
     Endif
     # End issue 110325
     # Issue 71069 - 2016-06-10 by MUARN : PJT entête
     # Issue 71069-54 - 2016-08-25 by MUARN : import PJT
     If ([M:PIH3]NBLIG = 0 & GPJTSNGDOC = 1) | (GIMPORT & [M:PIH3]NBLIG=1  & GPJTSNGDOC = 1)
       If [M:PIH3]TYPORI(NOL)=1
         If [F:POH]POHNUM<>[M:PIH3]NUMORI(NOL)
           Read [POH] POH0=[M:PIH3]NUMORI(NOL) : If fstat Raz [F:POH] : Endif
         Endif
       Else
         If [F:POH]POHNUM<>[F:SHDB]POHNUM
           Read [POH] POH0=[F:SHDB]POHNUM : If fstat Raz [F:POH] : Endif
         Endif
       Endif
       [M:PIH1]PJTH = [F:POH]PJTH
       If !GIMPORT : Affzo [M:PIH1]PJTH : Endif
     Endif
     # End issue 71069
     [M:PIH3]NETCUR(NOL)=[M:PIH1]CUR
     #-----
     [M:PIH3]VAT1(NOL)=[F:POPB]VAT(0)
     [M:PIH3]VAT2(NOL)=[F:POPB]VAT(1)
     [M:PIH3]VAT3(NOL)=[F:POPB]VAT(2)
     If dim([M:PIH3]TSICOD1(NOL))>0 [M:PIH3]TSICOD1(NOL)=[F:POPB]TSICOD(0) : Endif
     If dim([M:PIH3]TSICOD2(NOL))>0 [M:PIH3]TSICOD2(NOL)=[F:POPB]TSICOD(1) : Endif
     If dim([M:PIH3]TSICOD3(NOL))>0 [M:PIH3]TSICOD3(NOL)=[F:POPB]TSICOD(2) : Endif
     If dim([M:PIH3]TSICOD4(NOL))>0 [M:PIH3]TSICOD4(NOL)=[F:POPB]TSICOD(3) : Endif
     If dim([M:PIH3]TSICOD5(NOL))>0 [M:PIH3]TSICOD5(NOL)=[F:POPB]TSICOD(4) : Endif
     #-----
     # Issue 110325 - 2016-01-11 by SR : FCC sur expé déplacé
#     [M:PIH3]TYPORI(NOL) = 1 : # A cause du transclasse
     [M:PIH3]POHNUMORI(NOL)=[F:POQB]POHNUM
     #---
     WITMREF_ORI=[F:POQB]ITMREF
     #----- Alimentation de la province d'entrée -----#
     If func AFNC.ACTIV("PTX") & dim([M:PIH3]SATRCP)>0 & [F:PTDB]ITMREF=SAV_ITMREF
       #----- Lecture du site de réception si nécessaire -----#
       If [F:FCY]FCY<>GFCY
         Read [FCY] FCY0=GFCY : If fstat  Raz [F:FCY] : Endif
       Endif
       #----- Lecture de l'adresse du site de réception si nécessaire -----#
       If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>GFCY | [F:BPA]BPAADD<>[F:FCY]BPAADD
         Read [BPA] BPA0=3;GFCY;[F:FCY]BPAADD
         If fstat  Raz [F:BPA] : Endif
       Endif
       #-----
       [M:PIH3]SATRCP(NOL)=[F:BPA]SAT
     Endif
   #----- Origine réception -----#
   Elsif [M:PIH3]TYPORI(NOL)=2
     If clalev([F:PTDB])<=0 Local File PRECEIPTD [PTDB] : Endif
     Read [PTDB] PTD0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
     If fstat Raz [F:PTDB] : Endif
     # Issue 76951/2 - 2011-10-10 by VPO : controler ITMREF même si document origine
     # Issue 90503 - 2013-06-14 by SR : autorisé si facture complémentaire
#     If GIMPORT & [M:PIH3]ITMREF(NOL)<>"" & [M:PIH3]ITMREF(NOL)<>[F:PTDB]ITMREF
#      Call ERREUR ([M:PIH3]ITMREF(NOL)-mess(424,194,1)-[F:PTDB]ITMREF) From GESECRAN
#      GERR=1
#      mkstat=2
#      End
#     Endif
     nolign=NOL+1 : [M:PIH3]=[F:PTDB]
     # Issue 100616 - 2014-11-04 by MUARN : alimentation devise en fonction entête facture
     [M:PIH3]NETCUR(NOL)=[M:PIH1]CUR
     #-----
     [M:PIH3]VAT1(NOL)=[F:PTDB]VAT(0)
     [M:PIH3]VAT2(NOL)=[F:PTDB]VAT(1)
     [M:PIH3]VAT3(NOL)=[F:PTDB]VAT(2)
     If dim([M:PIH3]TSICOD1(NOL))>0 [M:PIH3]TSICOD1(NOL)=[F:PTDB]TSICOD(0) : Endif
     If dim([M:PIH3]TSICOD2(NOL))>0 [M:PIH3]TSICOD2(NOL)=[F:PTDB]TSICOD(1) : Endif
     If dim([M:PIH3]TSICOD3(NOL))>0 [M:PIH3]TSICOD3(NOL)=[F:PTDB]TSICOD(2) : Endif
     If dim([M:PIH3]TSICOD4(NOL))>0 [M:PIH3]TSICOD4(NOL)=[F:PTDB]TSICOD(3) : Endif
     If dim([M:PIH3]TSICOD5(NOL))>0 [M:PIH3]TSICOD5(NOL)=[F:PTDB]TSICOD(4) : Endif
     #-----
     [M:PIH3]TYPORI(NOL)=2 : # A cause du transclasse
     #VPO 03/02/11 71185 ajout lecture POHNUMORI ssi TYPORI=2
     [M:PIH3]POHNUMORI(NOL)=[F:PTDB]POHNUM
     #---
     WITMREF_ORI=[F:PTDB]ITMREF
     #----- Alimentation de la province d'entrée -----#
     If func AFNC.ACTIV("PTX") & dim([M:PIH3]SATRCP)>0 & [F:PTDB]ITMREF=SAV_ITMREF
       #----- Lecture du site de réception si nécessaire -----#
       If [F:FCY]FCY<>GFCY
         Read [FCY] FCY0=GFCY : If fstat  Raz [F:FCY] : Endif
       Endif
       #----- Lecture de l'adresse du site de réception si nécessaire -----#
       If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>GFCY | [F:BPA]BPAADD<>[F:FCY]BPAADD
         Read [BPA] BPA0=3;GFCY;[F:FCY]BPAADD
         If fstat  Raz [F:BPA] : Endif
       Endif
       #-----
       [M:PIH3]SATRCP(NOL)=[F:BPA]SAT
     Endif
     # Issue 71069 - 2016-06-10 by MUARN : PJT entête
     If [F:PTH]PTHNUM<>[M:PIH3]NUMORI(NOL)
       Read [PTH] PTH0=[M:PIH3]NUMORI(NOL) : If fstat Raz [F:PTH] : Endif
     Endif
     # Issue 71069-54 - 2016-08-25 by MUARN : import PJT
     If ([M:PIH3]NBLIG = 0 & GPJTSNGDOC = 1) | (GIMPORT & [M:PIH3]NBLIG=1  & GPJTSNGDOC = 1)
       [M:PIH1]PJTH = [F:PTH]PJTH
       If !GIMPORT : Affzo [M:PIH1]PJTH : Endif
     Endif
     # End issue 71069
   #----- Origine facture -----#
   Else
     If clalev([F:PIDB])<=0 Local File PINVOICED [PIDB] : Endif
     Read [PIDB] PID0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
     If fstat Raz [F:PIDB] : Endif
     # Issue 76951/2 - 2011-10-10 by VPO : controler ITMREF même si document origine
     # Issue 90503 - 2013-06-14 by SR : autorisé si facture complémentaire
#     If GIMPORT & [M:PIH3]ITMREF(NOL)<>"" & [M:PIH3]ITMREF(NOL)<>[F:PIDB]ITMREF
#      Call ERREUR ([M:PIH3]ITMREF(NOL)-mess(424,194,1)-[F:PIDB]ITMREF) From GESECRAN
#      GERR=1
#      mkstat=2
#      End
#     Endif
     nolign=NOL+1 : [M:PIH3]=[F:PIDB]
     # Issue 100616 - 2014-11-04 by MUARN : alimentation devise en fonction entête facture
     [M:PIH3]NETCUR(NOL)=[M:PIH1]CUR
     #-----
     [M:PIH3]VAT1(NOL)=[F:PIDB]VAT(0)
     [M:PIH3]VAT2(NOL)=[F:PIDB]VAT(1)
     [M:PIH3]VAT3(NOL)=[F:PIDB]VAT(2)
     If dim([M:PIH3]TSICOD1(NOL))>0 [M:PIH3]TSICOD1(NOL)=[F:PIDB]TSICOD(0) : Endif
     If dim([M:PIH3]TSICOD2(NOL))>0 [M:PIH3]TSICOD2(NOL)=[F:PIDB]TSICOD(1) : Endif
     If dim([M:PIH3]TSICOD3(NOL))>0 [M:PIH3]TSICOD3(NOL)=[F:PIDB]TSICOD(2) : Endif
     If dim([M:PIH3]TSICOD4(NOL))>0 [M:PIH3]TSICOD4(NOL)=[F:PIDB]TSICOD(3) : Endif
     If dim([M:PIH3]TSICOD5(NOL))>0 [M:PIH3]TSICOD5(NOL)=[F:PIDB]TSICOD(4) : Endif
     #-----
     [M:PIH3]TYPORI(NOL)=4 : # A cause du transclasse
     WITMREF_ORI=[F:PIDB]ITMREF
     # Issue 71253 - 2012-05-24 by SR : Localisation Portugaise
     # Issue 98403 - 2014-03-27 by SR : Localisation Portugaise
     If dim([M:PIH3]DCLEECNUM) > 0
       If [F:BPR]BPRNUM<>[M:PIH0]BPR
          Read [BPR] BPR0=[M:PIH0]BPR
          If fstat Raz [F:BPR] : Endif
       Endif
       If NOL = 0
          [M:PIH3]DCLEECNUM(NOL) = [F:BPR]EECNUM
       Else
          [M:PIH3]DCLEECNUM(NOL) = [M:PIH3]DCLEECNUM(NOL-1)
          If [M:PIH3]DCLEECNUM(NOL) = ""
             [M:PIH3]DCLEECNUM(NOL) = [F:BPR]EECNUM
          Endif
       Endif
     Endif
     # Issue 71069 - 2016-06-10 by MUARN : PJT entête
     If clalev([F:PIHB])<=0 Local File PINVOICE  [PIHB] : Endif
     If [F:PIHB]NUM<>SAV_NUMORI
       Read [PIHB] PIH0=SAV_NUMORI : If fstat Raz [F:PIHB] : Endif
     Endif
     # Issue 71069-54 - 2016-08-25 by MUARN : import PJT
     If ([M:PIH3]NBLIG = 0 & GPJTSNGDOC = 1) | (GIMPORT & [M:PIH3]NBLIG=1  & GPJTSNGDOC = 1)
       [M:PIH1]PJTH = [F:PIHB]PJTH
       If !GIMPORT : Affzo [M:PIH1]PJTH : Endif
     Endif
     # End issue 71069
   Endif
   #-----
   [M:PIH3]NUMORI(NOL)    =SAV_NUMORI     : # A cause du transclasse
   [M:PIH3]LINORI(NOL)    =SAV_LINORI     : # A cause du transclasse
   # Issue 82703 - 2012-10-05 by SR
   [M:PIH3]SEQORI(NOL)    =SAV_SEQORI     : # A cause du transclasse
   # Issue 112754 - 2016-12-02 by SR : Services : Si article pré chargement <> article pièce d'origine
   If [M:PIH3]ITMREF(NOL) <> SAV_ITMREF
      If [F:ITM]ITMREF <> SAV_ITMREF
      Read [F:ITM]ITM0 = SAV_ITMREF
      If fstat : Raz [F:ITM] : Endif
     Endif
     [M:PIH3]ITMKND(NOL) = 1
     If [F:ITM]SCSFLG = 2 : [M:PIH3]ITMKND(NOL) = 3 : Endif
   Endif
   # End issue 112754
   [M:PIH3]ITMREF(NOL)    =SAV_ITMREF     : # A cause du transclasse
   #-----
   Gosub RAZ_CHAMPS_LIGNE
   Raz [M:PIH3]PIDLIN(NOL),     [M:PIH3]NETPRI(NOL),     [M:PIH3]ORINETPRI(NOL),
&      [M:PIH3]LINACC1(NOL),    [M:PIH3]LINACC2(NOL),    [M:PIH3]LINACC3(NOL),
&      [M:PIH3]LINACC4(NOL),    [M:PIH3]LINACC5(NOL),    [M:PIH3]LINACC6(NOL),
&      [M:PIH3]LINACC7(NOL),    [M:PIH3]LINACC8(NOL),    [M:PIH3]LINACC9(NOL),
&      [M:PIH3]LINACC10(NOL),   [M:PIH3]CREFLG(NOL),     [M:PIH3]UPDFLG(NOL),
&      [M:PIH3]AMTATILIN(NOL),  [M:PIH3]QTYBUDLIN(NOL),  [M:PIH3]PRIREN(NOL),
&      [M:PIH3]CPR(NOL),        [M:PIH3]LINFLG(NOL),     [M:PIH3]RCPDAT(NOL),
&      [M:PIH3]DIFQTY(NOL),     [M:PIH3]DIFPRI(NOL),     [M:PIH3]STRDAT(NOL),
&      [M:PIH3]ENDDAT(NOL),     [M:PIH3]PERNBR(NOL),     [M:PIH3]PERTYP(NOL)
   # Issue 84129 - 2012-11-08 by MUARN : landed cost
   # Issue 89349 - 2014-01-31 by SR : Rapprochements
   Raz [M:PIH3]LINAMTCPR(NOL), [M:PIH3]CSTPUR(NOL), [M:PIH3]LINCSTPUR(NOL),
&      [M:PIH3]FCSCSTPUR(NOL), [M:PIH3]FCSCPR(NOL)

   #----- Raz codes taxe et provinces si article différent de la facture d'origine -----#
   If [M:PIH3]ITMREF(NOL)<>WITMREF_ORI & func AFNC.ACTIV("PTX") & dim([M:PIH3]TAXRCP)>0
     Raz [M:PIH3]TAXRCP(NOL),     [M:PIH3]TAXISS(NOL),     [M:PIH3]TAXOTH1(NOL),
&        [M:PIH3]TAXOTH2(NOL),    [M:PIH3]SATRCP(NOL),     [M:PIH3]SATISS(NOL)
   Endif
   #-----
   If dim([M:PIH3]DISCRGVAL1(NOL))>0 Raz [M:PIH3]DISCRGVAL1(NOL) : Endif
   If dim([M:PIH3]DISCRGVAL2(NOL))>0 Raz [M:PIH3]DISCRGVAL2(NOL) : Endif
   If dim([M:PIH3]DISCRGVAL3(NOL))>0 Raz [M:PIH3]DISCRGVAL3(NOL) : Endif
   If dim([M:PIH3]DISCRGVAL4(NOL))>0 Raz [M:PIH3]DISCRGVAL4(NOL) : Endif
   If dim([M:PIH3]DISCRGVAL5(NOL))>0 Raz [M:PIH3]DISCRGVAL5(NOL) : Endif
   If dim([M:PIH3]DISCRGVAL6(NOL))>0 Raz [M:PIH3]DISCRGVAL6(NOL) : Endif
   If dim([M:PIH3]DISCRGVAL7(NOL))>0 Raz [M:PIH3]DISCRGVAL7(NOL) : Endif
   If dim([M:PIH3]DISCRGVAL8(NOL))>0 Raz [M:PIH3]DISCRGVAL8(NOL) : Endif
   If dim([M:PIH3]DISCRGVAL9(NOL))>0 Raz [M:PIH3]DISCRGVAL9(NOL) : Endif
   If dim([M:PIH3]DISCRGREN1(NOL))>0 Raz [M:PIH3]DISCRGREN1(NOL) : Endif
   If dim([M:PIH3]DISCRGREN2(NOL))>0 Raz [M:PIH3]DISCRGREN2(NOL) : Endif
   If dim([M:PIH3]DISCRGREN3(NOL))>0 Raz [M:PIH3]DISCRGREN3(NOL) : Endif
   If dim([M:PIH3]DISCRGREN4(NOL))>0 Raz [M:PIH3]DISCRGREN4(NOL) : Endif
   If dim([M:PIH3]DISCRGREN5(NOL))>0 Raz [M:PIH3]DISCRGREN5(NOL) : Endif
   If dim([M:PIH3]DISCRGREN6(NOL))>0 Raz [M:PIH3]DISCRGREN6(NOL) : Endif
   If dim([M:PIH3]DISCRGREN7(NOL))>0 Raz [M:PIH3]DISCRGREN7(NOL) : Endif
   If dim([M:PIH3]DISCRGREN8(NOL))>0 Raz [M:PIH3]DISCRGREN8(NOL) : Endif
   If dim([M:PIH3]DISCRGREN9(NOL))>0 Raz [M:PIH3]DISCRGREN9(NOL) : Endif
   If dim([M:PIH3]LINDSP)>0 Raz [M:PIH3]LINDSP(NOL) : Endif
   If dim([M:PIH3]CCE1)>0   Raz [M:PIH3]CCE1(NOL)   : Endif
   If dim([M:PIH3]CCE2)>0   Raz [M:PIH3]CCE2(NOL)   : Endif
   If dim([M:PIH3]CCE3)>0   Raz [M:PIH3]CCE3(NOL)   : Endif
   If dim([M:PIH3]CCE4)>0   Raz [M:PIH3]CCE4(NOL)   : Endif
   If dim([M:PIH3]CCE5)>0   Raz [M:PIH3]CCE5(NOL)   : Endif
   If dim([M:PIH3]CCE6)>0   Raz [M:PIH3]CCE6(NOL)   : Endif
   If dim([M:PIH3]CCE7)>0   Raz [M:PIH3]CCE7(NOL)   : Endif
   If dim([M:PIH3]CCE8)>0   Raz [M:PIH3]CCE8(NOL)   : Endif
   If dim([M:PIH3]CCE9)>0   Raz [M:PIH3]CCE9(NOL)   : Endif
   If dim([M:PIH3]CCE10)>0  Raz [M:PIH3]CCE10(NOL)  : Endif
   If dim([M:PIH3]CCE11)>0  Raz [M:PIH3]CCE11(NOL)  : Endif
   If dim([M:PIH3]CCE12)>0  Raz [M:PIH3]CCE12(NOL)  : Endif
   If dim([M:PIH3]CCE13)>0  Raz [M:PIH3]CCE13(NOL)  : Endif
   If dim([M:PIH3]CCE14)>0  Raz [M:PIH3]CCE14(NOL)  : Endif
   If dim([M:PIH3]CCE15)>0  Raz [M:PIH3]CCE15(NOL)  : Endif
   If dim([M:PIH3]CCE16)>0  Raz [M:PIH3]CCE16(NOL)  : Endif
   If dim([M:PIH3]CCE17)>0  Raz [M:PIH3]CCE17(NOL)  : Endif
   If dim([M:PIH3]CCE18)>0  Raz [M:PIH3]CCE18(NOL)  : Endif
   If dim([M:PIH3]CCE19)>0  Raz [M:PIH3]CCE19(NOL)  : Endif
   If dim([M:PIH3]CCE20)>0  Raz [M:PIH3]CCE20(NOL)  : Endif
   #----- Lecture de l'ITMMASTER -----#
   If [F:ITM]ITMREF<>[M:PIH3]ITMREF(NOL)
      Read [ITM] ITM0=[M:PIH3]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
   Endif
   #------ Lecture de l'ITMBPS -------#
   If [F:ITP]ITMREF<>[M:PIH3]ITMREF(NOL) | [F:ITP]BPSNUM<>[M:PIH0]BPR
      Read [ITP] ITP0=[M:PIH3]ITMREF(NOL);[M:PIH0]BPR : If fstat Raz [F:ITP] : Endif
   Endif
   #-----
   # Issue 84130 - 2013-03-19 by MUARN : ajout facture complémentaire sur commande
   If [M:PIH3]TYPORI(NOL)=1
     [M:PIH3]ORIQTYPUU(NOL)=[F:POQB]QTYPUU
     [M:PIH3]ORIQTYWEU(NOL)=[F:POQB]QTYWEU
     [M:PIH3]ORIQTYVOU(NOL)=[F:POQB]QTYVOU
     [M:PIH3]ORINETPRI(NOL)=[F:POQB]LINAMT
     [M:PIH3]BPSNUM(NOL)   =[F:POQB]BPSNUM
     [M:PIH3]FCYLIN(NOL)   =[F:POQB]PRHFCY
   Elsif [M:PIH3]TYPORI(NOL)=2
     [M:PIH3]ORIQTYPUU(NOL)=[F:PTDB]QTYPUU
     [M:PIH3]ORIQTYWEU(NOL)=[F:PTDB]QTYWEU
     [M:PIH3]ORIQTYVOU(NOL)=[F:PTDB]QTYVOU
     [M:PIH3]ORINETPRI(NOL)=[F:PTDB]LINAMT
     [M:PIH3]BPSNUM(NOL)   =[F:PTDB]BPSNUM
     [M:PIH3]FCYLIN(NOL)   =[F:PTDB]PRHFCY
  # Issue 110325 - 2016-01-08 by SR
   Elsif [M:PIH3]TYPORI(NOL) = 4
     [M:PIH3]ORIQTYPUU(NOL)=[F:PIDB]QTYPUU
     [M:PIH3]ORIQTYWEU(NOL)=[F:PIDB]QTYWEU
     [M:PIH3]ORIQTYVOU(NOL)=[F:PIDB]QTYVOU
     [M:PIH3]ORINETPRI(NOL)=[F:PIDB]AMTNOTLIN
     [M:PIH3]BPSNUM(NOL)   =[F:PIDB]BPSNUM
     [M:PIH3]FCYLIN(NOL)   =[F:PIDB]FCYLIN
 # Issue 110325 - 2016-01-08 by SR : FCC sur expé
   Elsif [M:PIH3]TYPORI(NOL) = 6
     [M:PIH3]ORIQTYPUU(NOL)=[F:SHDB]SHIQTYPUU
     [M:PIH3]ORIQTYWEU(NOL)=[F:SHDB]QTYWEU
     [M:PIH3]ORIQTYVOU(NOL)=[F:SHDB]QTYVOU
     [M:PIH3]ORINETPRI(NOL)=[F:SHDB]LINAMT
     [M:PIH3]BPSNUM(NOL)   =[F:POQB]BPSNUM
     [M:PIH3]FCYLIN(NOL)   =[F:POQB]PRHFCY
   Endif
   [M:PIH3]QTYUOM(NOL)   =0
   [M:PIH3]QTYPUU(NOL)   =0
   [M:PIH3]UOMPUUCOE(NOL)=1
   [M:PIH3]UOM(NOL)      =""
   [M:PIH3]PUU(NOL)      =[F:ITM]PUU
   If [F:ITP]PUU<>"" [M:PIH3]PUU(NOL)=[F:ITP]PUU : Endif
   [M:PIH3]AMTNOTLIN(NOL)=0
   # Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
   [M:PIH3]AMTNOTLINCAL(NOL)=0
   #----- Rechargement désignations, codes statistique si article différent -----#
   If [M:PIH3]ITMREF(NOL)<>WITMREF_ORI
     #----- Chargement des désignations article -----#
     #Call CHARGE_ITMDES("DES1AXX",[M:PIH0]LAN,[F:ITM]ITMREF,[M:PIH3]ITMDES(NOL)) From TRTX3
     #If [M:PIH3]ITMDES(NOL)="" [M:PIH3]ITMDES(NOL)=[F:ITM]ITMDES1 : Endif
     Call CHARGE_DEFITMDES("DES1AXX",[M:PIH0]LAN,[F:ITM]ITMREF,[M:PIH3]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
     #[M:PIH3]ITMDES1(NOL)=[F:ITM]ITMDES1
     Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PIH3]ITMDES1(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
     #-----
     Raz [M:PIH3]LINPURTYP(NOL)
     #-----
     If dim([M:PIH3]TSICOD1(NOL))>0 [M:PIH3]TSICOD1(NOL)=[F:ITM]TSICOD(0) : Endif
     If dim([M:PIH3]TSICOD2(NOL))>0 [M:PIH3]TSICOD2(NOL)=[F:ITM]TSICOD(1) : Endif
     If dim([M:PIH3]TSICOD3(NOL))>0 [M:PIH3]TSICOD3(NOL)=[F:ITM]TSICOD(2) : Endif
     If dim([M:PIH3]TSICOD4(NOL))>0 [M:PIH3]TSICOD4(NOL)=[F:ITM]TSICOD(3) : Endif
     If dim([M:PIH3]TSICOD5(NOL))>0 [M:PIH3]TSICOD5(NOL)=[F:ITM]TSICOD(4) : Endif
     # Issue 81115 - 2012-04-12 by SR
     If [M:PIH3]TYPORI(NOL)=2
        If clalev([F:PTI])> 0 :  Close Local File [F:PTI] : Endif
        Local File PRECEIPTD [PTI]
        [F:PTI] = [F:PTDB]
    # Issue 110325 - 2016-01-08 by SR : FCC sur expé (et sur commande)
    Elsif find([M:PIH3]TYPORI(NOL),1,6)
        If clalev([F:PTI])> 0 :  Close Local File [F:PTI] : Endif
        Local File PORDERP [PTI]
        [F:PTI] = [F:POPB]
     Else
        If clalev([F:PTI])> 0 :  Close Local File [F:PTI] : Endif
        Local File PINVOICED [PTI]
        [F:PTI] = [F:PIDB]
     Endif
     # Issue X3-58146 - 2017-10-05 by MUARN : init comptes avants axes
     If [M:PIH3]LINACC1(NOL)="" & [M:PIH3]LINACC2(NOL)="" & [M:PIH3]LINACC3(NOL)=""
       Call INIT_COMPTES_LIGNE(NOL) From SUBPIHC
     Endif
     For AXE = 1 To GNBDIE
        # Issue X3-58146- 2017-10-05 by MUARN
        #WCCE = evalue("[M:PIH3]CCE"+num$(AXE))
        Call INIT_CCE(WCCE,AXE,"PIC","[M:PIH3]LINACC",NOL) From TRTX3CPT
        Assign ("[M:PIH3]CCE"+num$(AXE)+"(NOL)") With WCCE
     Next
   #----- Si article identique à la facture d'origine -----#
   Else
   # Issue 82703 - 2012-11-08 by SR
   # Issue 110325 - 2016-01-08 by SR : FCC sur expé
 #    If [M:PIH3]TYPORI(NOL)=1
     If find([M:PIH3]TYPORI(NOL),1,6)
       #----- Chargement comptes et sections analytiques -----#
       Call CHARG_ACCCCE(NOL,"[M:PIH3]LINACC","[M:PIH3]LINDSP","[M:PIH3]CCE",
&                    "POP",0,[F:POPB]POHNUM,[F:POPB]POPLIN,[F:POPB]POPSEQ,"") From TRTX3CPT
     Elsif [M:PIH3]TYPORI(NOL)=2
       #----- Chargement comptes et sections analytiques -----#
       Call CHARG_ACCCCE(NOL,"[M:PIH3]LINACC","[M:PIH3]LINDSP","[M:PIH3]CCE",
&                        "PTD",0,[F:PTDB]PTHNUM,[F:PTDB]PTDLIN,0,"") From TRTX3CPT
     Else
       #----- Chargement comptes et sections analytiques -----#
       Call CHARG_ACCCCE(NOL,"[M:PIH3]LINACC","[M:PIH3]LINDSP","[M:PIH3]CCE",
&                        "PID",0,[F:PIDB]NUM,[F:PIDB]PIDLIN,0,"") From TRTX3CPT
     Endif
   Endif
   #----- Chargement des provinces -----#
   If func AFNC.ACTIV("PTX")
     #----- Chargement province de sortie -----#
     If dim([M:PIH3]SATISS)>0
       If [M:AD66]CRY<>"" | [M:AD66]CTY<>""
         [M:PIH3]SATISS(NOL)=[M:AD66]SAT
       Else
         If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[M:PIH0]BPR | [F:BPA]BPAADD<>[M:AD66]BPAADD
           Read [BPA] BPA0=1;[M:PIH0]BPR;[M:AD66]BPAADD : If fstat  Raz [F:BPA] : Endif
         Endif
         [M:PIH3]SATISS(NOL)=[F:BPA]SAT
       Endif
     Endif
     #----- Chargement province d'entrée -----#
     If dim([M:PIH3]SATRCP)>0
       If [F:FCY]FCY<>[M:PIH0]FCY
         Read  [FCY] FCY0=[M:PIH0]FCY : If fstat  Raz [F:FCY] : Endif
       Endif
       If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[M:PIH0]FCY | [F:BPA]BPAADD<>[F:FCY]BPAADD
         Read [BPA] BPA0=3;[M:PIH0]FCY;[F:FCY]BPAADD : If fstat  Raz [F:BPA] : Endif
       Endif
       [M:PIH3]SATRCP(NOL)=[F:BPA]SAT
     Endif
   Endif
   #----- Alimentation des codes taxes -----#
   Call ALIVATCOD(2,[M:PIH0]BPR,[M:PIH3]ITMREF(NOL),"PIH3",NOL) From TRTX3
   #-----
   [M:PIH3]PRTFLG(NOL)=1

   # Issue 70985 - 2012-06-08 by MUARN : landed cost
   [M:PIH3]CPRCOE(NOL) = 1
   [M:PIH3]CPRAMT(NOL) = 0
   [M:PIH3]STCNUM(NOL) = ""
   # Issue 121952 - 2017-03-13 by MUARN : raz zones charges
   Raz  [M:PIH3]FCSCPR(NOL), [M:PIH3]FCSCSTPUR(NOL)

#-----------------------------------#
# Préchargement de la ligne diverse #
#-----------------------------------#
Elsif [M:PIH3]TYPORI(NOL)=5
   Raz [M:PIH3]LINPURTYP(NOL), [M:PIH3]LINACC1(NOL), [M:PIH3]LINACC2(NOL),
&      [M:PIH3]LINACC3(NOL),   [M:PIH3]LINACC4(NOL), [M:PIH3]LINACC5(NOL),
&      [M:PIH3]LINACC6(NOL),   [M:PIH3]LINACC7(NOL), [M:PIH3]LINACC8(NOL),
&      [M:PIH3]LINACC9(NOL),   [M:PIH3]LINACC10(NOL)
   #----- Lecture de l'ITMMASTER -----#
   If [F:ITM]ITMREF<>[M:PIH3]ITMREF(NOL)
      Read [ITM] ITM0=[M:PIH3]ITMREF(NOL) : If fstat Raz [F:ITM] : Endif
   Endif
   #------ Lecture de l'ITMBPS -------#
   If [F:ITP]ITMREF<>[M:PIH3]ITMREF(NOL) | [F:ITP]BPSNUM<>[M:PIH0]BPR
      Read [ITP] ITP0=[M:PIH3]ITMREF(NOL);[M:PIH0]BPR : If fstat Raz [F:ITP] : Endif
   Endif
   [M:PIH3]BPSNUM(NOL)   =[M:PIH0]BPR
   [M:PIH3]FCYLIN(NOL)   =[M:PIH0]FCY
   #----- Chargement des désignations article -----#
   #Call CHARGE_ITMDES("DES1AXX",[M:PIH0]LAN,[F:ITM]ITMREF,[M:PIH3]ITMDES(NOL)) From TRTX3
   #If [M:PIH3]ITMDES(NOL)="" [M:PIH3]ITMDES(NOL)=[F:ITM]ITMDES1 : Endif
   Call CHARGE_DEFITMDES("DES1AXX",[M:PIH0]LAN,[F:ITM]ITMREF,[M:PIH3]ITMDES(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
   #[M:PIH3]ITMDES1(NOL)=[F:ITM]ITMDES1
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PIH3]ITMDES1(NOL), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
   # Issue 112754 - 2016-12-01 by SR : Init de ITMKND selon le type d'article
   [M:PIH3]ITMKND(NOL) = 1
   If [F:ITM]SCSFLG = 2 : [M:PIH3]ITMKND(NOL) = 3 : Endif
   #-----------------------------------------------#
   [M:PIH3]UOMPUUCOE(NOL)=1
   [M:PIH3]UOM(NOL)      =[F:ITM]PUU
   [M:PIH3]PUU(NOL)      =[F:ITM]PUU
   If [F:ITP]PUU<>"" [M:PIH3]UOM(NOL)=[F:ITP]PUU
                     [M:PIH3]PUU(NOL)=[F:ITP]PUU : Endif
   If dim([M:PIH3]TSICOD1(NOL))>0 [M:PIH3]TSICOD1(NOL)=[F:ITM]TSICOD(0) : Endif
   If dim([M:PIH3]TSICOD2(NOL))>0 [M:PIH3]TSICOD2(NOL)=[F:ITM]TSICOD(1) : Endif
   If dim([M:PIH3]TSICOD3(NOL))>0 [M:PIH3]TSICOD3(NOL)=[F:ITM]TSICOD(2) : Endif
   If dim([M:PIH3]TSICOD4(NOL))>0 [M:PIH3]TSICOD4(NOL)=[F:ITM]TSICOD(3) : Endif
   If dim([M:PIH3]TSICOD5(NOL))>0 [M:PIH3]TSICOD5(NOL)=[F:ITM]TSICOD(4) : Endif
   #----- Chargement des provinces -----#
   If func AFNC.ACTIV("PTX")
     #----- Chargement province de sortie -----#
     If dim([M:PIH3]SATISS)>0
       If [M:AD66]CRY<>"" | [M:AD66]CTY<>""
         [M:PIH3]SATISS(NOL)=[M:AD66]SAT
       Else
         If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[M:PIH0]BPR | [F:BPA]BPAADD<>[M:AD66]BPAADD
           Read [BPA] BPA0=1;[M:PIH0]BPR;[M:AD66]BPAADD : If fstat  Raz [F:BPA] : Endif
         Endif
         [M:PIH3]SATISS(NOL)=[F:BPA]SAT
       Endif
     Endif
     #----- Chargement province d'entrée -----#
     If dim([M:PIH3]SATRCP)>0
       If [F:FCY]FCY<>[M:PIH0]FCY
         Read  [FCY] FCY0=[M:PIH0]FCY : If fstat  Raz [F:FCY] : Endif
       Endif
       If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[M:PIH0]FCY | [F:BPA]BPAADD<>[F:FCY]BPAADD
         Read [BPA] BPA0=3;[M:PIH0]FCY;[F:FCY]BPAADD : If fstat  Raz [F:BPA] : Endif
       Endif
       [M:PIH3]SATRCP(NOL)=[F:BPA]SAT
     Endif
   Endif
   #-----
   #VPO 15/10/10 66790
   If [M:PIH3]ITMREF(NOL)<>""
       Call ALIVATCOD(2,[M:PIH0]BPR,[M:PIH3]ITMREF(NOL),"PIH3",NOL) From TRTX3
   Endif
   [M:PIH3]PRTFLG(NOL)=1
   [M:PIH3]LINTYP(NOL)=1

   #----- Initialisation des landed cost -----#
   # Issue 70985 - 2012-06-08 by MUARN : alimentation coefficient frais d'approche et coût achat forfaitaire
   # MUARN 07/02/2013 finalement toujours coef=1 cout=0 SDC="" dans tous les cas de PIHTYP pour lignes divers
   [M:PIH3]CPRCOE(NOL)=1
   [M:PIH3]CPRAMT(NOL)=0
   [M:PIH3]STCNUM(NOL)= ""
   # Issue 121952 - 2017-03-13 by MUARN : raz zones charges
   Raz  [M:PIH3]FCSCPR(NOL), [M:PIH3]FCSCSTPUR(NOL)
   # Issue 84130 - 2012-12-12 by MUARN : landed cost - poids et volume
   [M:PIH3]LINWEU(NOL)=[M:PIH4]DSPWEU
   [M:PIH3]LINVOU(NOL)=[M:PIH4]DSPVOU
   If [M:PIH3]LINTYP(NOL)<3
     If [F:ITM]ITMREF<>[M:PIH3]ITMREF(NOL)
       Read [ITM] ITM0=[M:PIH3]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
     Endif
     Call CONVERT_VOUWEU("PIH3",NOL,[M:PIH3]LINWEU(NOL),[M:PIH3]LINVOU(NOL),[M:PIH3]QTYSTU(NOL),0) From STCLIB
   Endif

Endif
#-----
[M:PIH3]PREQTYPUU(NOL)=[M:PIH3]QTYPUU(NOL)
#----- Chargement comptes et type d'achat si nécessaire -----#
If [M:PIH3]LINACC1(NOL)="" & [M:PIH3]LINACC2(NOL)="" & [M:PIH3]LINACC3(NOL)=""
  Call INIT_COMPTES_LIGNE(NOL) From SUBPIHC
Endif
If [M:PIH3]LINPURTYP(NOL)=0
  Call D_LINPURTYP ([M:PIH3]LINPURTYP(NOL))  From SUBPIH  : # Chargement type d'achat
Endif
#VPO 15/10/10 66790 alimentation des codes taxe
If [M:PIH3]ITMREF(NOL)=""
    #chargement des codes taxe du compte du fournisseur
    If [F:GAC]COA<>GCOA(1) | [F:GAC]ACC<>[M:PIH3]LINACC1(NOL)
       Read [GAC] GAC0=GCOA(1);[M:PIH3]LINACC1(NOL) : If fstat Raz [F:GAC] : Endif
    Endif
    [M:PIH3]VAT1(NOL)=[F:GAC]VAT(0)
    [M:PIH3]VAT2(NOL)=[F:GAC]VAT(1)
    [M:PIH3]VAT3(NOL)=[F:GAC]VAT(2)
Endif
#----- Si pas de nature ou clé de répartition, effacement des axes analytiques -----#
GBIDI2=0 : Gosub PREP_INIT_CCE From SUBPIHB
#----------------------------------------------------------------------#
# Point d'entrée ALILIGFAC pour charger les champs de la ligne facture #
# -------------------------------------------------------------------- #
# Ce point d'entrée est appelé pour toutes les lignes de facture       #
#    quelles que soit leur origine et permet de changer les            #
#    valeurs de la ligne ou de charger des zones spécifiques           #
# -------------------------------------------------------------------- #
# Variables modifiables par le point d'entrée :                        #
#    Tous les champs ligne facture du masque [M:PIH3]                  #
#    NOL contient l'indice de la ligne en cours de chargement          #
#----------------------------------------------------------------------#
SAV_QTYUOM   =[M:PIH3]QTYUOM   (NOL)
SAV_QTYPUU   =[M:PIH3]QTYPUU   (NOL)
SAV_NETPRI   =[M:PIH3]NETPRI   (NOL)
SAV_AMTNOTLIN=[M:PIH3]AMTNOTLIN(NOL)
GPOINT="ALILIGFAC" : Gosub ENTREE From EXEFNC
If [M:PIH3]QTYPUU(NOL)<>SAV_QTYPUU
  [M:PIH3]QTYUOM(NOL)=[M:PIH3]QTYPUU(NOL)/[M:PIH3]UOMPUUCOE(NOL)
  Call QTEARR([M:PIH3]QTYUOM(NOL),[M:PIH3]UOM(NOL)) From TRTDIV
Endif
If [M:PIH3]QTYUOM(NOL)<>SAV_QTYUOM
  [M:PIH3]QTYPUU(NOL)=[M:PIH3]QTYUOM(NOL)*[M:PIH3]UOMPUUCOE(NOL)
  Call QTEARR([M:PIH3]QTYPUU(NOL),[M:PIH3]PUU(NOL)) From TRTDIV
Endif
If [M:PIH3]QTYUOM(NOL)<>SAV_QTYUOM | [M:PIH3]NETPRI(NOL)<>SAV_NETPRI
  [M:PIH3]AMTNOTLIN(NOL) =[M:PIH3]NETPRI(NOL)*[M:PIH3]QTYUOM(NOL)
  Call ARRDEV([M:PIH3]AMTNOTLIN(NOL),[M:PIH1]CUR) From TRTDIV
  # Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
  [M:PIH3]AMTNOTLINCAL(NOL) =[M:PIH3]AMTNOTLIN(NOL)
Elsif [M:PIH3]AMTNOTLIN(NOL)<>SAV_AMTNOTLIN
  [M:PIH3]NETPRI(NOL)=arr([M:PIH3]AMTNOTLIN(NOL)/[M:PIH3]QTYUOM(NOL),10^-GDECPRI)
Endif
# Issue 87864 - 2013-02-11 by SR : Pour SST, si besoin, initialiser les axes sur lignes non saisissables
If [M:PIH3]LINTYP(NOL) > 2
  For AXE = 1 To GNBDIE
      If evalue("[M:PIH3]CCE"+num$(AXE)+"(NOL)") = ""  # Issue 92250 - 2013-09-03 by MUARN
          Raz WCCE
          Call INIT_CCE(WCCE,AXE,"PID","[M:PIH3]LINACC",NOL) From TRTX3CPT
          Assign ("[M:PIH3]CCE"+num$(AXE)+"(NOL)") With WCCE
      Endif
  Next
Endif
# Issue 89349 - 2013-10-25 by SR : Rapprochement
Grizo [M:PIH3]FCSCOD(NOL)
# Issue 82703 - 2013-02-12 by SR
If [M:PIH0]PIHTYP = 2 & [M:PIH3]TYPORI(NOL) <> 5
   [M:PIH3]CSTMAJLIN(NOL) = 2
   Actzo [M:PIH3]CSTMAJLIN(NOL)
# Issue 95710 - 2014-01-09 by SR : si avoir sur FCC récupérer CSTMAJLIN et FCSCOD de la FCC
Elsif [M:PIH3]TYPORI(NOL)=4 & [M:PIH0]PIHTYP=3 & [F:PIHB]PIHTYP = 2
       # Issue 100930 - 2014-06-20 by SR : PIDB et non PID qui n'est pas forcément en ligne
       [M:PIH3]CSTMAJLIN(NOL) = [F:PIDB]CSTMAJLIN
       # Issue 89349 - 2014-02-10 by SR
       [M:PIH3]FCSCOD(NOL)    = [F:PIDB]FCSCOD
Else
   [M:PIH3]CSTMAJLIN(NOL) = 1
   Grizo [M:PIH3]CSTMAJLIN(NOL)
Endif
# Issue 84130 - 2013-02-27 by MUARN : landed cost
If [M:PIH3]STCNUM(NOL)<>"" : [M:PIH3]WSTCUPD(NOL)=2 : Endif

#----- Si pas picking et article sous-traité, chargement du service et matières fournies -----#
If !GIMPORT & !GPIH_PICK & [M:PIH3]LINTYP(NOL)=2  Gosub CHARG_LIG_SUPPLEMENT From SUBPIHD : Endif
End

#-----------------------------------------------------------------#
# Effacement des champs ligne récupérés à tort par le transclasse #
#-----------------------------------------------------------------#
$RAZ_CHAMPS_LIGNE
#-----
Raz [M:PIH3]DISCRGAMT1(NOL), [M:PIH3]DISCRGAMT2(NOL), [M:PIH3]DISCRGAMT3(NOL),
&   [M:PIH3]DISCRGAMT4(NOL), [M:PIH3]DISCRGAMT5(NOL), [M:PIH3]DISCRGAMT6(NOL),
&   [M:PIH3]DISCRGAMT7(NOL), [M:PIH3]DISCRGAMT8(NOL), [M:PIH3]DISCRGAMT9(NOL)
#-----
Raz [M:PIH3]CLCAMT1   (NOL), [M:PIH3]CLCAMT2   (NOL), [M:PIH3]CLCAMT3   (NOL),
&   [M:PIH3]BASTAXLIN1(NOL)
If dim([M:PIH3]CLCAMT4)>0     Raz [M:PIH3]CLCAMT4(NOL)    : Endif
If dim([M:PIH3]CLCAMT5)>0     Raz [M:PIH3]CLCAMT5(NOL)    : Endif
If dim([M:PIH3]CLCAMT6)>0     Raz [M:PIH3]CLCAMT6(NOL)    : Endif
If dim([M:PIH3]CLCAMT7)>0     Raz [M:PIH3]CLCAMT7(NOL)    : Endif
#-----
Raz [M:PIH3]AMTTAXLIN1(NOL), [M:PIH3]DEDTAXLIN1(NOL), [M:PIH3]AMTTAXLIN2(NOL),
&   [M:PIH3]DEDTAXLIN2(NOL), [M:PIH3]AMTTAXLIN3(NOL), [M:PIH3]DEDTAXLIN3(NOL)
#-----
If dim([M:PIH3]DISBASLIN1)>0  Raz [M:PIH3]DISBASLIN1(NOL) : Endif
If dim([M:PIH3]AMTTAXRCP) >0  Raz [M:PIH3]AMTTAXRCP (NOL) : Endif
If dim([M:PIH3]DEDTAXRCP) >0  Raz [M:PIH3]DEDTAXRCP (NOL) : Endif
If dim([M:PIH3]AMTTAXISS) >0  Raz [M:PIH3]AMTTAXISS (NOL) : Endif
If dim([M:PIH3]DEDTAXISS) >0  Raz [M:PIH3]DEDTAXISS (NOL) : Endif
If dim([M:PIH3]AMTTAXOTH1)>0  Raz [M:PIH3]AMTTAXOTH1(NOL) : Endif
If dim([M:PIH3]DEDTAXOTH1)>0  Raz [M:PIH3]DEDTAXOTH1(NOL) : Endif
If dim([M:PIH3]AMTTAXOTH2)>0  Raz [M:PIH3]AMTTAXOTH2(NOL) : Endif
If dim([M:PIH3]DEDTAXOTH2)>0  Raz [M:PIH3]DEDTAXOTH2(NOL) : Endif
#-----
Raz [M:PIH3]LINTEX(NOL), [M:PIH3]STRDAT(NOL), [M:PIH3]ENDDAT(NOL)
#-----

Return

#---------------------------------------------------------------------------#
# Passage des montants de minoration en négatif et de majoration en positif #
#---------------------------------------------------------------------------#
$SIGN_DISCRGVAL
For I=1 To 9
  If GINVDTALIN(I-1)<>0 & GNPRNOTFLG(I-1)=1
    J=find(GINVDTALIN(I-1),[M:PIH1]INVDTA1(0..[M:PIH1]NBFAC1-1))
    If J<>0
      GBIDD1=evalue("[M:PIH3]DISCRGVAL"+num$(I)+"(NOL)")
      If ([M:PIH0]PIHTYP<3 & [M:PIH1]DEBCDT1(J-1)=2) |
&        ([M:PIH0]PIHTYP>2 & [M:PIH1]DEBCDT1(J-1)=1)
         If GBIDD1>0 GBIDD1=-GBIDD1 : Endif
      Elsif GBIDD1<0 GBIDD1=-GBIDD1
      Endif
      If GDISCRGTYP(I-1)=1 & GCLCRUL(I-1)=1
        Case [M:PIH3]TYPORI(NOL)
          When 1
            If [F:POQ]UOMPUUCOE=0  [F:POQ]UOMPUUCOE=1 : Endif
            GBIDD1=arr(GBIDD1/[F:POQ]UOMPUUCOE,10^-GDECPRI)
          When 2
            If [F:PTD]UOMPUUCOE=0  [F:PTD]UOMPUUCOE=1 : Endif
            GBIDD1=arr(GBIDD1/[F:PTD]UOMPUUCOE,10^-GDECPRI)
          When 3
            If [F:PND]UOMPUUCOE=0  [F:PND]UOMPUUCOE=1 : Endif
            GBIDD1=arr(GBIDD1/[F:PND]UOMPUUCOE,10^-GDECPRI)
        Endcase
      Endif
      Assign "[M:PIH3]DISCRGVAL"+num$(I)+"(NOL)" With GBIDD1
    Endif
  Endif
Next I
Return

#------------------------------------------------#
# Reprise des informations du document d'origine #
# ---------------------------+-----+-----+-----+ #
# Documents origine          ! Cde ! Rcp ! Ret ! #
#                            +-----+-----+-----+ #
#  - Code adr. fou facturant ! Oui ! Oui ! Oui ! #
#  - Tiers payé              ! Oui ! Oui ! Oui ! #
#  - Code adresse tiers payé ! Oui ! Oui ! Oui ! #
#  - Condition de paiement   ! Oui !     !     ! #
#  - Escompte                ! Oui ! Oui !     ! #
#  - Régime de taxe          ! Oui ! Oui ! Oui ! #
#  - Devise                  ! Oui ! Oui !     ! #
#  - Type de cours           ! Oui ! Oui !     ! #
#  - Informations douanières ! Oui ! Oui ! Oui ! #
#  - Section analyt. entête  ! Oui ! Oui ! Oui ! #
#----------------------------+-----+-----+-----+-#
$REPRISE_INFOS
Local Integer OK: OK=2 # Issue 84569 - 2012-09-25 by MUARN : reprise info doc origine après demande utilisateur
# Issue 94288 - 2013-11-14 by SR : Sauvegarder status
WSTATUS = status
Case [M:PIH3]TYPORI(NOL)
  When 1 : #----- Commande -----#
    # Issue 84569 - 2012-09-24 by MUARN : reprise info commande après demande utilisateur
    # Issue 92238 - 2013-09-03 by MUARN : ajout condition de paiement
    If [M:PIH1]BPRPAY<>[F:POH]BPRPAY | [M:AD67]BPAADD<>[F:POH]BPAPAY | [M:PIH1]VAC<>[F:POH]VACBPR |
&     [M:PIH1]CURTYP<>[F:POH]CHGTYP | [M:PIH1]CUR<>[F:POH]CUR | [M:PIH1]DEP<>[F:POH]DEP |
&     [M:PIH1]PTE<>[F:POH]PTE
      # Issue 89459 - 2013-04-18 by MUARN : contrôle webservice
      If !GIMPORT & !GWEBSERV
        Call OUINON(mess(430,194,1), OK) From GESECRAN # "remplacer les données gestion par document origine"
      Endif
      If OK = 2
        [M:AD66]BPAADD=[F:POH]BPAINV   : Gosub RECUP_ADR_FACTURANT
        If [M:PIH1]BPRPAY<>[F:POH]BPRPAY
          Call AM_BPRPAY([F:POH]BPRPAY) From SUBPIH : [M:PIH1]BPRPAY=[F:POH]BPRPAY
        Endif
        If [M:AD67]BPAADD<>[F:POH]BPAPAY
          [M:AD67]BPAADD=[F:POH]BPAPAY : Gosub REINIT_ADR_BPRPAY
        Endif
        If [M:PIH1]VAC<>[F:POH]VACBPR
          Call AM_VAC([F:POH]VACBPR) From SUBPIH    : [M:PIH1]VAC   =[F:POH]VACBPR
        Endif
        [M:PIH1]PTE   =[F:POH]PTE
        # Issue 89620 - 2013-04-24 by MUARN : devise en premier avant type cours et taux
        If [M:PIH1]CUR<>[F:POH]CUR
          Call AM_CUR([F:POH]CUR) From SUBPIH : [M:PIH1]CUR=[F:POH]CUR
        Endif
        # Issue  80571 - 2012-03-08 by SR : on doit récuperer le cours sur la commande
        #    [M:PIH1]CURTYP=[F:POH]CHGTYP
        If [M:PIH1]CURTYP<>[F:POH]CHGTYP
           [M:PIH1]CURTYP =[F:POH]CHGTYP
           Call AM_CURTYP([M:PIH1]CURTYP)       From SUBPIH
           # Issue 85529 - 2012-10-29 by MUARN : types de cours différents mais euros
           If [M:PIH1]RAT2 <> [F:POH]CHGCOE
             [M:PIH1]RAT2   =[F:POH]CHGCOE
             Call AM_RAT2([M:PIH1]RAT2)           From SUBPIH
           Endif
        Endif
        If [F:POH]DEP<>""
          GBIDC2=[F:POH]DEP
        Else
          Call INIT_ESCOMPTE([M:PIH0]BPR,GSOCIETE,"F",GBIDC2)  From CPTSUB
        Endif
        If [M:PIH1]DEP<>GBIDC2 & GBIDC2<>""
          [M:PIH1]DEP=GBIDC2 : Call AM_DEP([M:PIH1]DEP) From SUBPIH
        Endif
      Endif
    Endif
    # Issue 92238 - 2013-09-17 by MUARN : info douanières, sections ana toujours récupérées
    #----- Chargement des informations douanières -----#
    If [F:POH]POHTYP<>2 : # Commande classique
      [M:PCEZ]=[F:POH]
    Else                : # Commande ouverte
      Read [POC] POC0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
      If !fstat
        [M:PCEZ]EECICT=[F:POC]EECICT2
        [M:PCEZ]ICTCTY=[F:POC]ICTCTY2
        [M:PCEZ]FFWNUM=[F:POC]FFWNUM2
        [M:PCEZ]FFWADD=[F:POC]FFWADD2
        #--- CPO 72237 Le champ EECNUM est soumis à code activité (par le bloc dans le [M:PCEx])
        If GACTDEB=2
          [M:PCEZ]EECLOC=[F:POC]EECLOC2
          [M:PCEZ]EECNUM=[F:POC]EECNUM2
        Endif
      Endif
    Endif
    [M:PIH1]=[M:PCEZ] :
    [M:PIH1]EECICT2=[M:PCEZ]EECICT : [M:PIH1]ICTCTY2=[M:PCEZ]ICTCTY
    Affzo [PIH1]5
    #----- Chargement des sections analytiques entête -----#
    # Issue 74936 - 2011-06-20 by VPO : pb code activité ANA désactivé
    If dim([M:PIH1]DIE)>0
      For I=1 To max(GNBDIE,GOPTCANA)
        J=find([F:POH]DIE(I-1),[M:PIH1]DIE)
        If J & [F:POH]CCE(I-1)<>""  [M:PIH1]CCE(J-1)=[F:POH]CCE(I-1) : Endif
      Next I
    Endif
    Affzo [PIH1]25 : Setmok [PIH1] With 0
    #-----

  When 2 : #----- Réception -----#
    # Issue 84569 - 2012-09-24 by MUARN : reprise info réception après demande utilisateur
    # Issue 92238 - 2013-09-17 by MUARN : ajout condition de paiement
    If [M:PIH1]BPRPAY<>[F:PTH]BPRPAY | [M:AD67]BPAADD<>[F:PTH]BPAPAY | [M:PIH1]VAC<>[F:PTH]VACBPR |
&    [M:PIH1]CURTYP<>[F:PTH]CHGTYP | [M:PIH1]CUR<>[F:PTH]CUR | [M:PIH1]DEP<>[F:PTH]DEP |
&    ([F:POH]POHNUM<>"" & [M:PIH1]PTE<>[F:POH]PTE)
      # Issue 89459 - 2013-04-18 by MUARN : contrôle webservice
      If !GIMPORT & !GWEBSERV
        Call OUINON(mess(430,194,1), OK) From GESECRAN # "remplacer les données gestion par document origine"
      Endif
      If OK = 2
        [M:AD66]BPAADD=[F:PTH]BPAINV   : Gosub RECUP_ADR_FACTURANT
        If [M:PIH1]BPRPAY<>[F:PTH]BPRPAY
          Call AM_BPRPAY([F:PTH]BPRPAY) From SUBPIH : [M:PIH1]BPRPAY=[F:PTH]BPRPAY
        Endif
        If [M:AD67]BPAADD<>[F:PTH]BPAPAY
          [M:AD67]BPAADD=[F:PTH]BPAPAY : Gosub REINIT_ADR_BPRPAY
        Endif
        If [M:PIH1]VAC<>[F:PTH]VACBPR
          Call AM_VAC([F:PTH]VACBPR) From SUBPIH    : [M:PIH1]VAC   =[F:PTH]VACBPR
        Endif
        If [F:POH]POHNUM<>""
          [M:PIH1]PTE=[F:POH]PTE
        Endif
        # Issue 89620 - 2013-04-24 by MUARN : devise en premier avant type cours et taux
        If [M:PIH1]CUR<>[F:PTH]CUR
          Call AM_CUR([F:PTH]CUR) From SUBPIH : [M:PIH1]CUR=[F:PTH]CUR
        Endif
        # Issue  80571 - 2012-03-08 by SR : on doit récuperer le cours sur la réception
        #    [M:PIH1]CURTYP=[F:PTH]CHGTYP
        If [M:PIH1]CURTYP<>[F:PTH]CHGTYP
           [M:PIH1]CURTYP =[F:PTH]CHGTYP
           Call AM_CURTYP([M:PIH1]CURTYP)       From SUBPIH
           # Issue 85529 - 2012-10-29 by MUARN : types de cours différents mais euros
           If [M:PIH1]RAT2 <> [F:PTH]CHGCOE
             [M:PIH1]RAT2   =[F:PTH]CHGCOE
             Call AM_RAT2([M:PIH1]RAT2)           From SUBPIH
           Endif
        Endif
        If [F:PTH]DEP<>""
          GBIDC2=[F:PTH]DEP
        Else
          Call INIT_ESCOMPTE([M:PIH0]BPR,GSOCIETE,"F",GBIDC2)  From CPTSUB
        Endif
        If [M:PIH1]DEP<>GBIDC2 & GBIDC2<>""
          [M:PIH1]DEP=GBIDC2 : Call AM_DEP([M:PIH1]DEP) From SUBPIH
        Endif
      Endif
    Endif
    # Issue 92238 - 2013-09-17 by MUARN : info douanières, sections ana toujours récupérées
    #----- Chargement des informations douanières -----#
    [M:PCEZ]=[F:PTH]
    [M:PIH1]=[M:PCEZ]
    [M:PIH1]EECICT2=[M:PCEZ]EECICT : [M:PIH1]ICTCTY2=[M:PCEZ]ICTCTY
    Affzo [PIH1]5
    #----- Chargement des sections analytiques entête -----#
    # Issue 74936 - 2011-06-20 by VPO : pb code activité ANA désactivé
    If dim([M:PIH1]DIE)>0
      For I=1 To max(GNBDIE,GOPTCANA)
        J=find([F:PTH]DIE(I-1),[M:PIH1]DIE)
        If J & [F:PTH]CCE(I-1)<>""  [M:PIH1]CCE(J-1)=[F:PTH]CCE(I-1) : Endif
      Next I
    Endif
    Affzo [PIH1]25 : Setmok [PIH1] With 0
    #----

  When 3 : #----- Retour -----#
    # Issue 84569 - 2012-09-24 by MUARN : reprise info retour après demande utilisateur
    # Issue 92238 - 2013-09-17 by MUARN : ajout condition de paiement
    If [M:PIH1]BPRPAY<>[F:PNH]BPRPAY | [M:AD67]BPAADD<>[F:PNH]BPAPAY| [M:PIH1]VAC<>[F:PNH]VACBPR |
&   [M:PIH1]CURTYP<>[F:PTH]CHGTYP | [M:PIH1]CUR<>[F:PTH]CUR |
&   ( [F:POH]POHNUM<>"" & [M:PIH1]PTE<>[F:POH]PTE)
      # Issue 89459 - 2013-04-18 by MUARN : contrôle webservice
      If !GIMPORT & !GWEBSERV
        Call OUINON(mess(430,194,1), OK) From GESECRAN # "remplacer les données gestion par document origine"
      Endif
      If OK = 2
        [M:AD66]BPAADD=[F:PNH]BPAINV   : Gosub RECUP_ADR_FACTURANT
        If [M:PIH1]BPRPAY<>[F:PNH]BPRPAY
          Call AM_BPRPAY([F:PNH]BPRPAY) From SUBPIH : [M:PIH1]BPRPAY=[F:PNH]BPRPAY
        Endif
        If [M:AD67]BPAADD<>[F:PNH]BPAPAY
          [M:AD67]BPAADD=[F:PNH]BPAPAY : Gosub REINIT_ADR_BPRPAY
        Endif
        If [M:PIH1]VAC<>[F:PNH]VACBPR
          Call AM_VAC([F:PNH]VACBPR) From SUBPIH    : [M:PIH1]VAC   =[F:PNH]VACBPR
        Endif
        If [F:POH]POHNUM<>""
          [M:PIH1]PTE=[F:POH]PTE
        Endif
        If [F:PTH]PTHNUM<>""
          # Issue 89620 - 2013-04-24 by MUARN : devise en premier avant type cours et taux
          If [M:PIH1]CUR<>[F:PTH]CUR
            Call AM_CUR([F:PTH]CUR) From SUBPIH : [M:PIH1]CUR=[F:PTH]CUR
          Endif
          # Issue  80571 - 2012-03-08 by SR : on doit récuperer le cours sur la réception
          #    [M:PIH1]CURTYP=[F:PTH]CHGTYP
          If [M:PIH1]CURTYP<>[F:PTH]CHGTYP
            [M:PIH1]CURTYP =[F:PTH]CHGTYP
            Call AM_CURTYP([M:PIH1]CURTYP)       From SUBPIH
            # Issue 85529 - 2012-10-29 by MUARN : types de cours différents mais euros
            If [M:PIH1]RAT2 <> [F:PTH]CHGCOE
              [M:PIH1]RAT2   =[F:PTH]CHGCOE
              Call AM_RAT2([M:PIH1]RAT2)           From SUBPIH
            Endif
          Endif
        Endif
      Endif
    Endif
    # Issue 92238 - 2013-09-17 by MUARN : info douanière et section ana toujours récupérées
    #----- Chargement des informations douanières -----#
    [M:PCEZ]=[F:PNH]
    [M:PIH1]=[M:PCEZ]
    [M:PIH1]EECICT2=[M:PCEZ]EECICT : [M:PIH1]ICTCTY2=[M:PCEZ]ICTCTY
    Affzo [PIH1]5
    #----- Chargement des sections analytiques entête -----#
    # Issue 74936 - 2011-06-20 by VPO : pb code activité ANA désactivé
    If dim([M:PIH1]DIE)>0
      For I=1 To max(GNBDIE,GOPTCANA)
        J=find([F:PNH]DIE(I-1),[M:PIH1]DIE)
        If J & [F:PNH]CCE(I-1)<>""  [M:PIH1]CCE(J-1)=[F:PNH]CCE(I-1) : Endif
      Next I
    Endif
    Affzo [PIH1]25 : Setmok [PIH1] With 0
    #-----
Endcase
#-----
If !GIMPORT  Affzo [PIH1]BPRPAY, CUR, CURTYP, PTE, DEP, VAC : Endif
# Issue 94288 - 2013-11-14 by SR : Restaurer status
status = WSTATUS
Return

#---------------------------------------#
# Rechargement adresse fournisseur payé #
#---------------------------------------#
$REINIT_ADR_BPRPAY
#----- Lecture BPARTNER payé si nécessaire -----#
If [F:BPR]BPRNUM<>[M:PIH1]BPRPAY
  Read [BPR] BPR0=[M:PIH1]BPRPAY : If fstat Raz [F:BPR] : Endif
Endif
#-----
If [F:BPA]BPANUM<>[M:PIH1]BPRPAY | [F:BPA]BPAADD<>[M:AD67]BPAADD
  Read [BPA] BPA0=1;[M:PIH1]BPRPAY;[M:AD67]BPAADD : If fstat Raz [F:BPA] : Endif
Endif
#-----
[M:AD67] = [F:BPA]
[M:AD67]BPRNAM(0) = [F:BPR]BPRNAM(0)
[M:AD67]BPRNAM(1) = [F:BPR]BPRNAM(1)
[M:AD67]BPAADD    = [F:BPA]BPAADD
[M:AD67]ADBBPR    = [F:BPA]BPANUM
[M:AD67]ADBFLG    = 1
#----- Relecture BPARTNER facturant si nécessaire -----#
If [F:BPR]BPRNUM<>[M:PIH0]BPR
   Read [BPR] BPR0=[M:PIH0]BPR : If fstat Raz [F:BPR] : Endif
Endif
#-----
Return

#########################################################################
# CAL_QTEPOHMAX : S/P de calcul quantité maxi facturable de la commande #
#-----------------------------------------------------------------------#
# Subprog CAL_QTEPOHMAX (NOL,NBMAX,QTEMAX)                              #
#   NOL      : indice de la ligne à traiter (nolign-1)                  #
#   NBMAX    : Nombre de ligne déja présentes dans le tableau           #
#   QTEMAX   : Quantité maxi facturable en UA                           #
#########################################################################
Subprog CAL_QTEPOHMAX (NOL,NBMAX,QTEMAX)
Value    Shortint NOL
Value    Shortint NBMAX
Variable Decimal  QTEMAX
#----- Variables locales -----#
Local    Shortint J, K
Local    Char     WNUMORI(GLONVCR)
Local    Integer  WLINORI, WSEQORI
Local    Decimal  WQTE, WRTNQTYPUU
#----- Valeur par défaut de la quantité maxi -----#
QTEMAX =[M:PIH3]ORIQTYPUU(NOL)
#----- Pas de calcul pour les factures complémentaires -----#
If [M:PIH0]PIHTYP=2 End : Endif
#-----
Case [M:PIH3]TYPORI(NOL)
  When 2
    If [F:PTD]PTHNUM<>[M:PIH3]NUMORI(NOL) | [F:PTD]PTDLIN<>[M:PIH3]LINORI(NOL)
      Read [PTD] PTD0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
      If fstat  Raz [F:PTD] : Endif
    Endif
    WNUMORI=[F:PTD]POHNUM
    WLINORI=[F:PTD]POPLIN
    WSEQORI=[F:PTD]POQSEQ
  When 3
    If [F:PND]PNHNUM<>[M:PIH3]NUMORI(NOL) | [F:PND]PNDLIN<>[M:PIH3]LINORI(NOL)
      Read [PND] PND0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
      If fstat  Raz [F:PND] : Endif
    Endif
    WNUMORI=[F:PND]POHNUM
    WLINORI=[F:PND]POPLIN
    WSEQORI=[F:PND]POQSEQ
  When 4
    If !clalev([F:PIDB])  Local File PINVOICED [PIDB] : Endif
    If [F:PIDB]NUM<>[M:PIH3]NUMORI(NOL) | [F:PIDB]PIDLIN<>[M:PIH3]LINORI(NOL)
      Read [PIDB] PID0=[M:PIH3]NUMORI(NOL);[M:PIH3]LINORI(NOL)
      If fstat  Raz [F:PIDB] : Endif
    Endif
    If [F:PIDB]TYPORI=1
      WNUMORI=[F:PIDB]NUMORI
      WLINORI=[F:PIDB]LINORI
      WSEQORI=[F:PIDB]SEQORI
    Elsif [F:PIDB]TYPORI=2
      If [F:PTD]PTHNUM<>[F:PIDB]NUMORI | [F:PTD]PTDLIN<>[F:PIDB]LINORI
        Read [PTD] PTD0=[F:PIDB]NUMORI;[F:PIDB]LINORI : If fstat Raz [F:PTD] : Endif
      Endif
      WNUMORI=[F:PTD]POHNUM
      WLINORI=[F:PTD]POPLIN
      WSEQORI=[F:PTD]POQSEQ
    Elsif [F:PIDB]TYPORI=3
      If [F:PND]PNHNUM<>[F:PIDB]NUMORI | [F:PND]PNDLIN<>[F:PIDB]LINORI
        Read [PND] PND0=[F:PIDB]NUMORI;[F:PIDB]LINORI : If fstat Raz [F:PND] : Endif
      Endif
      WNUMORI=[F:PND]POHNUM
      WLINORI=[F:PND]POPLIN
      WSEQORI=[F:PND]POQSEQ
    Endif
Endcase
#----- Si pas de numéro de commande, c'est fini ! -----#
If WNUMORI=""  End : Endif
#--- Issue 107856
Raz WQTE_NONFAC
#-----
Gosub CAL_QTEMAX_CDE
#----- Ajout de la quantité de la ligne en cours -----#
If [M:PIH3]CREFLG(NOL)<>0
  If !clalev([F:PIDB])  Local File PINVOICED [PIDB] : Endif
  Read [PIDB] PID0=[M:PIH0]NUM;[M:PIH3]PIDLIN(NOL) : If fstat Raz [F:PIDB] : Endif
  QTEMAX+=[F:PIDB]QTYPUU
  If [M:PIH3]TYPORI(NOL)=1  QTEMAX=[M:PIH3]ORIQTYPUU(NOL) : Endif
Endif
If QTEMAX<0  QTEMAX=0 : Endif
End

#########################################################################
# CAL_QTEMAX : S/P de calcul quantité maxi facturable      MBT 14/10/98 #
#-----------------------------------------------------------------------#
# Subprog CAL_QTEMAX (NOL,NBMAX,QTEMAX)                                 #
#   NOL      : indice de la ligne à traiter (nolign-1)                  #
#   NBMAX    : Nombre de ligne déja présentes dans le tableau           #
#   QTEMAX   : Quantité maxi facturable en UA                           #
#   -----------------------------------------------------------------   #
#   Nota : Particularité lors de la facturation d'une ligne réception   #
#          QTEMAX = Qté maxi facturable suivant paramètre PIHQTYAQR     #
#                   (statuts A ou A+Q ou A+Q+R)                         #
#                   Sert pour la màj de l'indicateur différence de qté  #
#          GPIH_QTEMAX = Qté maxi facturable incluant tous les statuts  #
#                   (A+Q+R)                                             #
#                   Sert pour la màj de l'indicateur facture partielle  #
#   Les qtés retournées sans attentes d'avoir sont déduites dans tous   #
#          les cas.                                                     #
#########################################################################
Subprog CAL_QTEMAX (NOL,NBMAX,QTEMAX)
Value    Shortint NOL
Value    Shortint NBMAX
Variable Decimal  QTEMAX
#----- Variables locales -----#
Local    Shortint J, K
Local    Char     WNUMORI(GLONVCR)
Local    Integer  WLINORI, WSEQORI
Local    Decimal  WQTE, WRTNQTYPUU, WQQQQTYPUU, WQQQQTYSTU, WRRRQTYPUU, WRRRQTYSTU
#----- Chargement variables locales -----#
WNUMORI=[M:PIH3]NUMORI(NOL)
WLINORI=[M:PIH3]LINORI(NOL)
WSEQORI=[M:PIH3]SEQORI(NOL)
#----- Valeur par défaut de la quantité maxi -----#
QTEMAX =[M:PIH3]ORIQTYPUU(NOL)
If dim(GPIH_QTEMAX)<0  Global Decimal GPIH_QTEMAX : Endif
#--- Issue 107856
# Issue 98750 - 2014-04-01 by MUARN : quantité réceptionnée non facturable
#If dim(WQTE_NONFAC)<0 Global Decimal WQTE_NONFAC
#Else
Raz WQTE_NONFAC
#Endif
#---
GPIH_QTEMAX=QTEMAX
#----- Pas de calcul pour les factures complémentaires -----#
If [M:PIH0]PIHTYP=2 End : Endif
#----------------------------------------#
Case [M:PIH3]TYPORI(NOL)
  When 1 : Gosub CAL_QTEMAX_CDE
  When 2 : Gosub CAL_QTEMAX_RCP
  When 3 : Gosub CAL_QTEMAX_RET
  When 4 : Gosub CAL_QTEMAX_FAC
Endcase
#----- Ajout de la quantité de la ligne en cours -----#
If [M:PIH3]CREFLG(NOL)<>0
   If clalev([F:PIDB])<=0 Local File PINVOICED [PIDB] : Endif
   Read [PIDB] PID0=[M:PIH0]NUM;[M:PIH3]PIDLIN(NOL) : If fstat Raz [F:PIDB] : Endif
   QTEMAX+=[F:PIDB]QTYPUU
   If [M:PIH3]TYPORI(NOL)=1  QTEMAX=[M:PIH3]ORIQTYPUU(NOL) : Endif
   If [M:PIH3]TYPORI(NOL)=2  GPIH_QTEMAX+=[F:PIDB]QTYPUU   : Endif
Endif
If QTEMAX<0 QTEMAX=0 : Endif
If GPIH_QTEMAX<0  GPIH_QTEMAX=0 : Endif
If [M:PIH3]TYPORI(NOL)<>2 GPIH_QTEMAX=QTEMAX : Endif
End
#-----------------------------------------------------------------#
# Calcul quantité maxi facturable pour ligne issue d'une commande #
#-----------------------------------------------------------------#
$CAL_QTEMAX_CDE
If [F:POQ]POHNUM<>WNUMORI | [F:POQ]POPLIN<>WLINORI | [F:POQ]POQSEQ<>WSEQORI
   Read [POQ] POQ0=WNUMORI;WLINORI;WSEQORI : If fstat Raz [F:POQ] : Endif
Endif
QTEMAX=[F:POQ]QTYPUU-[F:POQ]INVQTYPUU
#----- Recherche si des retours validés sans avoir, existent -----#
Raz WRTNQTYPUU
Columns [PNH] (PNHNUM, CFMFLG)
Columns [PND] (PNHNUM, PNDLIN, POHNUM, POPLIN, POQSEQ, LININVFLG, QTYPUU, INVQTYPUU)
For [PND] PND3 Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POQSEQ=[F:POQ]POQSEQ
&                  & LININVFLG=2 & INVQTYPUU=0
  Read [PNH] PNH0=[F:PND]PNHNUM : If fstat Raz [F:PNH] : Endif
  If [F:PNH]CFMFLG=2  WRTNQTYPUU+=[F:PND]QTYPUU : Endif
Next
Columns [PNH]
Columns [PND]
QTEMAX-=WRTNQTYPUU
#-----
If NBMAX>0
#  #----- Recherche si commande déja présente dans une ligne de la facture -----#
   Raz J
   While J<NBMAX
     K=find([F:POQ]POHNUM,[M:PIH3]NUMORI(J..NBMAX-1))
     If K=0 J=NBMAX
     Elsif [M:PIH3]TYPORI(J+(K-1))=1 & [M:PIH3]LINORI(J+(K-1))=[F:POQ]POPLIN
&                                    & [M:PIH3]SEQORI(J+(K-1))=[F:POQ]POQSEQ
&                                    & [M:PIH3]CREFLG(J+(K-1))=0
&                                    & J+(K-1)<>NOL
       Call PCAL_QTY([M:PIH3]QTYUOM(J+(K-1)),[M:PIH3]UOM(J+(K-1)),WQTE,[F:POQ]PUU,
&                    [F:POQ]ITMREF,[F:POQ]BPSNUM,1,GBIDD1) From TRTACHQTE1
       QTEMAX-=WQTE : J+=K : K=0
     Else J+=K : K=0
     Endif
   Wend
#  #----- Recherche si réceptions sur cette commande déja présente dans la facture -----#
   Filter [PTD] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POQSEQ=[F:POQ]POQSEQ
&               Order By Key PTD2
   For [PTD]
     Raz J
     While J<NBMAX
       K=find([F:PTD]PTHNUM,[M:PIH3]NUMORI(J..NBMAX-1))
       If K=0 J=NBMAX
       Elsif [M:PIH3]TYPORI(J+(K-1))=2 & [M:PIH3]LINORI(J+(K-1))=[F:PTD]PTDLIN
&                                      & [M:PIH3]CREFLG(J+(K-1))=0
&                                      & J+(K-1)<>NOL
         Call PCAL_QTY([M:PIH3]QTYUOM(J+(K-1)),[M:PIH3]UOM(J+(K-1)),WQTE,[F:POQ]PUU,
&                    [F:POQ]ITMREF,[F:POQ]BPSNUM,1,GBIDD1) From TRTACHQTE1
         QTEMAX-=WQTE : J+=K : K=0
       Else J+=K : K=0
       Endif
     Wend
     #----- Déduire la partie de qté réceptionnée qui est soldée (non facturable) -----#
     If [F:PTD]LININVFLG=2 & [F:PTD]QTYPUU>[F:PTD]INVQTYPUU
       QTEMAX-=([F:PTD]QTYPUU-[F:PTD]INVQTYPUU)
       # Issue 98750 - 2014-04-01 by MUARN : quantité réceptionnée non facturable
       WQTE_NONFAC+=([F:PTD]QTYPUU-[F:PTD]INVQTYPUU)
     Endif
     #-----
   Next
   Filter [PTD]
Else
   Filter [PTD] Where POHNUM=[F:POQ]POHNUM
&                   & POPLIN=[F:POQ]POPLIN
&                   & POQSEQ=[F:POQ]POQSEQ
&                   & LININVFLG=2
&               Order By Key PTD2
   For [PTD]
     #----- Déduire la partie de qté réceptionnée qui est soldée (non facturable) -----#
     If [F:PTD]QTYPUU>[F:PTD]INVQTYPUU
       QTEMAX-=([F:PTD]QTYPUU-[F:PTD]INVQTYPUU)
       # Issue 98750 - 2014-04-01 by MUARN : quantité réceptionnée non facturable
       WQTE_NONFAC+=([F:PTD]QTYPUU-[F:PTD]INVQTYPUU)
     Endif
     #-----
   Next
   Filter [PTD]
Endif
Return
#------------------------------------------------------------------#
# Calcul quantité maxi facturable pour ligne issue d'une réception #
#------------------------------------------------------------------#
$CAL_QTEMAX_RCP
If [F:PTH]PTHNUM<>WNUMORI
   Read [PTH] PTH0=WNUMORI         : If fstat Raz [F:PTH] : Endif
Endif
If [F:PTD]PTHNUM<>WNUMORI | [F:PTD]PTDLIN<>WLINORI
   Read [PTD] PTD0=WNUMORI;WLINORI : If fstat Raz [F:PTD] : Endif
Endif
QTEMAX=[F:PTD]QTYPUU-[F:PTD]INVQTYPUU
#----- Recherche si des retours validés sans avoir, existent -----#
Raz WRTNQTYPUU
If [F:PTD]RTNQTYPUU<>0
  Columns [PNH] (PNHNUM, CFMFLG)
  Columns [PND] (PNHNUM, PNDLIN, PTHNUM, PTDLIN, LININVFLG, QTYPUU, INVQTYPUU)
  For [PND] PND1 Where PTHNUM=[F:PTD]PTHNUM & PTDLIN=[F:PTD]PTDLIN
&                    & LININVFLG=2 & INVQTYPUU=0
    Read [PNH] PNH0=[F:PND]PNHNUM : If fstat Raz [F:PNH] : Endif
    If [F:PNH]CFMFLG=2  WRTNQTYPUU+=[F:PND]QTYPUU : Endif
  Next
  Columns [PNH]
  Columns [PND]
Endif
#-----
If NBMAX>0
   If [F:PTD]POHNUM<>""
#    #----- Recherche si commande déja présente dans une ligne de la facture -----#
     Raz J
     While J<NBMAX
       K=find([F:PTD]POHNUM,[M:PIH3]NUMORI(J..NBMAX-1))
       If K=0 J=NBMAX
       Elsif [M:PIH3]TYPORI(J+(K-1))=1 & [M:PIH3]LINORI(J+(K-1))=[F:PTD]POPLIN
&                                      & [M:PIH3]SEQORI(J+(K-1))=[F:PTD]POQSEQ
&                                      & [M:PIH3]CREFLG(J+(K-1))=0
&                                      & J+(K-1)<>NOL
         Call PCAL_QTY([M:PIH3]QTYUOM(J+(K-1)),[M:PIH3]UOM(J+(K-1)),WQTE,[F:PTD]PUU,
&                      [F:PTD]ITMREF,[F:PTH]BPSNUM,1,GBIDD1) From TRTACHQTE1
         QTEMAX-=WQTE : J+=K : K=0
       Else J+=K : K=0
       Endif
     Wend
#    #----- Recherche si réception déja présente dans une ligne de la facture -----#
     Raz J
     While J<NBMAX
       K=find([F:PTD]PTHNUM,[M:PIH3]NUMORI(J..NBMAX-1))
       If K=0 J=NBMAX
       Elsif [M:PIH3]TYPORI(J+(K-1))=2 & [M:PIH3]LINORI(J+(K-1))=[F:PTD]PTDLIN
&                                      & [M:PIH3]CREFLG(J+(K-1))=0
&                                      & J+(K-1)<>NOL
         Call PCAL_QTY([M:PIH3]QTYUOM(J+(K-1)),[M:PIH3]UOM(J+(K-1)),WQTE,[F:PTD]PUU,
&                      [F:PTD]ITMREF,[F:PTH]BPSNUM,1,GBIDD1) From TRTACHQTE1
         QTEMAX-=WQTE : J+=K : K=0
       Else J+=K : K=0
       Endif
     Wend
     #----- Recherche sur-facturation d'une réception portant sur la même commande -----#
     # Issue 107480 - 2015-04-16 by SR : comment
     #If clalev([F:PTDB])<=0  Local File PRECEIPTD [PTDB] : Endif
     For J=0 To NBMAX-1
       If [M:PIH3]TYPORI(J)=2 & [M:PIH3]CREFLG(J)=0 & J<>NOL
 #         Read [PTDB] PTD0=[M:PIH3]NUMORI(J);[M:PIH3]LINORI(J)
#         If !fstat
#           If [F:PTDB]POHNUM=[F:PTD]POHNUM &
#&             [F:PTDB]POPLIN=[F:PTD]POPLIN &
#&             [F:PTDB]POQSEQ=[F:PTD]POQSEQ
           If [M:PIH3]POHNUMPTD(J)=[F:PTD]POHNUM &
&             [M:PIH3]POPLINPTD(J)=[F:PTD]POPLIN &
&             [M:PIH3]POQSEQPTD(J)=[F:PTD]POQSEQ
              Call PCAL_QTY([M:PIH3]QTYUOM(J),[M:PIH3]UOM(J),WQTE,[F:PTD]PUU,
&                         [F:PTD]ITMREF,[F:PTH]BPSNUM,1,GBIDD1) From TRTACHQTE1
#             WQTE-=([F:PTDB]QTYPUU-[F:PTDB]INVQTYPUU)
             WQTE-=([M:PIH3]QTYPUUPTD(J)-[M:PIH3]INVQTYPUUPTD(J))
             If WQTE>0
               QTEMAX-=WQTE
             Endif
           Endif
      #   Endif
      # End issue 107480
       Endif
     Next J
   Else
#    #----- Recherche si réception sans commande déja présente dans la facture -----#
     Raz J
     While J<NBMAX
       K=find([F:PTD]PTHNUM,[M:PIH3]NUMORI(J..NBMAX-1))
       If K=0 J=NBMAX
       Elsif [M:PIH3]TYPORI(J+(K-1))=2 & [M:PIH3]LINORI(J+(K-1))=[F:PTD]PTDLIN
&                                      & [M:PIH3]CREFLG(J+(K-1))=0
&                                      & J+(K-1)<>NOL
         Call PCAL_QTY([M:PIH3]QTYUOM(J+(K-1)),[M:PIH3]UOM(J+(K-1)),WQTE,[F:PTD]PUU,
&                      [F:PTD]ITMREF,[F:PTH]BPSNUM,1,GBIDD1) From TRTACHQTE1
         QTEMAX-=WQTE : J+=K : K=0
       Else J+=K : K=0
       Endif
     Wend
   Endif
Endif
#----- Calcul des qtés en Q ou en R de la réception -----#
Raz WQQQQTYPUU, WQQQQTYSTU, WRRRQTYPUU, WRRRQTYSTU
If [F:ITM]ITMREF<>[M:PIH3]ITMREF(NOL)
  Read [ITM] ITM0=[M:PIH3]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
Endif
If [F:PTD]STOMGTCOD<2
  WRRRQTYPUU=[F:PTD]RRRQTYPUU : # Non géré en stock
Else
  Gosub RECHQTE_QR           : # Géré en stock
Endif
#-----
GPIH_QTEMAX=QTEMAX
If GPIHQTYAQR<3
  If WRTNQTYPUU>WRRRQTYPUU
    GPIH_QTEMAX-=WRTNQTYPUU
    QTEMAX     -=WRTNQTYPUU
  Else
    GPIH_QTEMAX-=WRTNQTYPUU
    QTEMAX     -=WRRRQTYPUU
  Endif
Else
  GPIH_QTEMAX-=WRTNQTYPUU
  QTEMAX     -=WRTNQTYPUU
Endif
If GPIHQTYAQR<2
  QTEMAX     -=WQQQQTYPUU
Endif
#-----
Return
#----------------------------------------------------------------------#
# Recherche aussi bien que possible des qtés en Q et R de la réception #
#----------------------------------------------------------------------#
$RECHQTE_QR
Local Char WQLYCTLDEM(GLONVCR)
#----- Recherche des qtés Q et R à partir des mouvements -----#
Raz WQLYCTLDEM
#VPO 09/12/10 69709 ajout itmref et updcod sur req STJ
For [STJ] STJ1 Where STOFCY=[F:PTD]PRHFCY
&                  & VCRTYP=6
&                  & VCRNUM=[F:PTD]PTHNUM
&                  & VCRLIN=[F:PTD]PTDLIN
&                  & ITMREF=[F:PTD]ITMREF
&                  & UPDCOD = 2
&                  & REGFLG<>2
&                  & TRSTYP<>29                : #--- Issue 115206
   Case left$([F:STJ]STA,1)
     When "Q" : WQQQQTYSTU+=[F:STJ]QTYSTU
                If [F:STJ]QLYCTLDEM<>""  WQLYCTLDEM=[F:STJ]QLYCTLDEM : Endif
     When "R" : WRRRQTYSTU+=[F:STJ]QTYSTU
   Endcase
Next
If WQLYCTLDEM<>""
#VPO 09/12/10 69709 ajout itmref et updcod sur req STJ
  For [STJ] STJ1 Where STOFCY=[F:PTD]PRHFCY
&                    & VCRNUM=WQLYCTLDEM
&                    & VCRTYPORI=6
&                    & VCRNUMORI=[F:PTD]PTHNUM
&                    & VCRLINORI=[F:PTD]PTDLIN
&                    & ITMREF = [F:PTD]ITMREF
&                    & UPDCOD = 2
&                    & REGFLG<>2
&                    & TRSTYP<>29                : #--- Issue 115206
     Case left$([F:STJ]STA,1)
       When "Q" : WQQQQTYSTU+=[F:STJ]QTYSTU
       When "R" : WRRRQTYSTU+=[F:STJ]QTYSTU
     Endcase
  Next
Endif
#----- Conversion qtés US en qtés UA -----#
If WQQQQTYSTU<>0
  Call PCAL_QTY(WQQQQTYSTU,[F:PTD]STU,WQQQQTYPUU,[F:PTD]PUU,
&               [F:PTD]ITMREF,[F:PTD]BPSNUM,1,GBIDD1) From TRTACHQTE1
Endif
If WRRRQTYSTU<>0
  Call PCAL_QTY(WRRRQTYSTU,[F:PTD]STU,WRRRQTYPUU,[F:PTD]PUU,
&               [F:PTD]ITMREF,[F:PTD]BPSNUM,1,GBIDD1) From TRTACHQTE1
Endif
Close Local File [STJ], [STO]
Return
#--------------------------------------------------------------#
# Calcul quantité maxi facturable pour ligne issue d'un retour #
#--------------------------------------------------------------#
$CAL_QTEMAX_RET
If [F:PNH]PNHNUM<>WNUMORI
   Read [PNH] PNH0=WNUMORI         : If fstat Raz [F:PNH] : Endif
Endif
If [F:PND]PNHNUM<>WNUMORI | [F:PND]PNDLIN<>WLINORI
   Read [PND] PND0=WNUMORI;WLINORI : If fstat Raz [F:PND] : Endif
Endif
QTEMAX=[F:PND]QTYPUU-[F:PND]INVQTYPUU
If NBMAX>0
#  #----- Recherche si retour déja présent dans une ligne de la facture -----#
   Raz J
   While J<NBMAX
     K=find([F:PND]PNHNUM,[M:PIH3]NUMORI(J..NBMAX-1))
     If K=0 J=NBMAX
     Elsif [M:PIH3]TYPORI(J+(K-1))=3 & [M:PIH3]LINORI(J+(K-1))=[F:PND]PNDLIN
&                                    & [M:PIH3]CREFLG(J+(K-1))=0
&                                    & J+(K-1)<>NOL
       Call PCAL_QTY([M:PIH3]QTYUOM(J+(K-1)),[M:PIH3]UOM(J+(K-1)),WQTE,[F:PND]PUU,
&                    [F:PND]ITMREF,[F:PNH]BPSNUM,1,GBIDD1) From TRTACHQTE1
       QTEMAX-=WQTE : J+=K : K=0
     Else J+=K : K=0
     Endif
   Wend
Endif
Return
#----------------------------------------------------------------#
# Calcul quantité maxi facturable pour ligne issue d'une facture #
#----------------------------------------------------------------#
$CAL_QTEMAX_FAC
If clalev([F:PIHB])<=0 Local File PINVOICE  [PIHB]  : Endif
If clalev([F:PIDB])<=0 Local File PINVOICED [PIDB]  : Endif
If [F:PIHB]NUM<>[M:PIH3]NUMORI(NOL)
   Read [PIHB] PIH0=WNUMORI : If fstat Raz [F:PIHB] : Endif
Endif
If [F:PIDB]NUM<>WNUMORI | [F:PIDB]PIDLIN<>WLINORI
   Read [PIDB] PID0=WNUMORI;WLINORI : If fstat Raz [F:PIDB] : Endif
Endif
QTEMAX=[F:PIDB]QTYPUU
If NBMAX>0
#  #----- Recherche si facture déja présente dans une ligne de l'avoir -----#
   Raz J
   While J<NBMAX
     K=find([F:PIHB]NUM,[M:PIH3]NUMORI(J..NBMAX-1))
     If K=0 J=NBMAX
     Elsif [M:PIH3]TYPORI(J+(K-1))=4 & [M:PIH3]LINORI(J+(K-1))=[F:PIDB]PIDLIN
&                                    & J+(K-1)<>NOL
       Call PCAL_QTY([M:PIH3]QTYUOM(J+(K-1)),[M:PIH3]UOM(J+(K-1)),WQTE,[F:PIDB]PUU,
&                    [F:PIDB]ITMREF,[F:PIDB]BPSNUM,1,GBIDD1) From TRTACHQTE1
       QTEMAX-=WQTE : J+=K : K=0
     Else J+=K : K=0
     Endif
   Wend
Endif
Return

##################################################################
# CONVERSION : S/P de conversion des montants ligne dans la      #
#              devise de la facture                              #
# -------------------------------------------------------------- #
# Subprog CONVERSION (OLDCUR,NOL)                                #
#    OLDCUR : Ancienne devise                                    #
#    NOL    : Numéro de la ligne en cours (nolign-1)             #
##################################################################
Subprog CONVERSION (OLDCUR,NOL)
Value Char     OLDCUR
Value Shortint NOL
Local Shortint I
Local Integer  STAT
Local Decimal  MT1, MT2
Call CONVERT2(OLDCUR,[M:PIH1]CUR,GLOCALDEV,[M:PIH1]CURTYP,[M:PIH0]ACCDAT,
&             [M:PIH3]GROPRI(NOL),MT2,STAT) From TRTDEV
[M:PIH3]GROPRI(NOL)=arr(MT2,10^-GDECPRI)
Call CONVERT2(OLDCUR,[M:PIH1]CUR,GLOCALDEV,[M:PIH1]CURTYP,[M:PIH0]ACCDAT,
&             [M:PIH3]NETPRI(NOL),MT2,STAT) From TRTDEV
[M:PIH3]NETPRI(NOL)=arr(MT2,10^-GDECPRI)
Call CONVERT2(OLDCUR,[M:PIH1]CUR,GLOCALDEV,[M:PIH1]CURTYP,[M:PIH0]ACCDAT,
&             [M:PIH3]ORINETPRI(NOL),MT2,STAT) From TRTDEV
[M:PIH3]ORINETPRI(NOL)=arr(MT2,10^-GDECPRI)
If [M:PIH3]QTYUOM(NOL)=0 | [M:PIH3]NETPRI(NOL)=0
  Call CONVERT(OLDCUR,[M:PIH1]CUR,GLOCALDEV,[M:PIH1]CURTYP,[M:PIH0]ACCDAT,
&              [M:PIH3]AMTNOTLIN(NOL),MT2,STAT) From TRTDEV
  [M:PIH3]AMTNOTLIN(NOL)=MT2
  # Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
  [M:PIH3]AMTNOTLINCAL(NOL)=[M:PIH3]AMTNOTLIN(NOL)
Endif
For I=1 To 9
    If evalue ("dim([M:PIH3]DISCRGVAL"+num$(I)+"(NOL))")>0
       If GFMTREM(I-1)="M"
          MT1=evalue ("[M:PIH3]DISCRGVAL"+num$(I)+"(NOL)")
          Call CONVERT(OLDCUR,[M:PIH1]CUR,GLOCALDEV,[M:PIH1]CURTYP,
&                      [M:PIH0]ACCDAT,MT1,MT2,STAT) From TRTDEV
          Assign "[M:PIH3]DISCRGVAL"+num$(I)+"(NOL)" With MT2
       Endif
    Endif
Next
End

####################################################################
# Recalcul de la taxe globalement à partir de la base taxe cumulée #
# ---------------------------------------------------------------- #
#      GPIH_INDTAX  = Numéro de la ligne de taxe à traiter         #
#                I  = Indice de la ligne de taxe à traiter         #
# [M:PIH4]TAXE  (I) = Code taxe à traiter                          #
# [M:PIH4]BASTAX(I) = Base taxe cumulée à traiter                  #
####################################################################
$CAL_TAXE_GLOB

If GPIH_INDTAX=0 | GPIH_INDTAX>[M:PIH4]NBTAX  Return : Endif
If dim(I)<0 Local Shortint I : Endif
I=GPIH_INDTAX-1
Local Integer  TYPREG,  STAT, NUMLIG_DISVAT
Local Decimal  MONTANT, MONTDED, SEUIL
Local Char     TAXE(GLONVAT)
#----- Si taxe classique, recherche présence remise sur taxe (Settlement discount) -----#
If [M:PIH4]VATTYP(I)=1
  If dim([M:PIH4]DISVATFLG)>0
    J=0
    NUMLIG_DISVAT=find(2,[M:PIH4]DISVATFLG(J..[M:PIH4]NBFAC-1))
    If NUMLIG_DISVAT
      If [M:PIH4]INVORDAMT(NUMLIG_DISVAT-1)=0
        J=NUMLIG_DISVAT
        NUMLIG_DISVAT=find(2,[M:PIH4]DISVATFLG(J..[M:PIH4]NBFAC-1))
        If NUMLIG_DISVAT & [M:PIH4]INVORDAMT(NUMLIG_DISVAT-1)=0
          Raz NUMLIG_DISVAT
        Endif
      Endif
    Endif
  Endif
  If NUMLIG_DISVAT | (dim([M:PIH4]DISBAS)>0 & [M:PIH4]DISBAS(I)<>0)
    Gosub SETTLEMENT_DISCOUNT
  Endif
Endif
#-----
TAXE=[M:PIH4]TAX(I)
Gosub RECH_DATE_TAXE
Call CALTAXE(GSOCIETE,GBIDA1,[M:PIH1]VAC,GCUR,1,TAXE,1,
&         [M:PIH4]BASTAX(I),MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
If func AFNC.ACTIV("PTX") & dim([F:TRA]AMTTSD)>0 & [F:TRA]AMTTSD<>0
  Call CONVERT(GCURSHR,[M:PIH1]CUR,GLOCALDEV,[M:PIH1]CURTYP,
&               [M:PIH0]ACCDAT,[F:TRA]AMTTSD,SEUIL,STAT) From TRTDEV
  If MONTANT<SEUIL  Raz MONTANT, MONTDED : Endif
Endif
#### PUNTO DE ENTRADA ARGENTINA
GPOINT="CALTAXEGLOB" : Gosub ENTREE From EXEFNC
####
If MONTANT<>[M:PIH4]AMTTAX(I)
  [M:PIH4]AMTTAX(I)=MONTANT
  [M:PIH4]DEDTAX(I)=MONTDED
  [M:PIH4]TOTTAXCLC=sum([M:PIH4]AMTTAX)
  #----- Réajustement mts taxe sur éléments et lignes facture -----#
  Raz GPIH_INDBASTAX
  Call MAJ_TAXE(I) From SUBPIHB
  #----- Si les bases ont été réajustées, il faut recalculer la taxe -----#
  If sum(GPIH_INDBASTAX)>0
    For I=0 To [M:PIH4]NBTAX-1
      If GPIH_INDBASTAX(I)=1
        #----- Si taxe classique, recherche présence remise sur taxe (Settlement discount) -----#
        If [M:PIH4]VATTYP(I)=1
          If dim([M:PIH4]DISVATFLG)>0
            J=0
            NUMLIG_DISVAT=find(2,[M:PIH4]DISVATFLG(J..[M:PIH4]NBFAC-1))
            If NUMLIG_DISVAT
              If [M:PIH4]INVORDAMT(NUMLIG_DISVAT-1)=0
                J=NUMLIG_DISVAT
                NUMLIG_DISVAT=find(2,[M:PIH4]DISVATFLG(J..[M:PIH4]NBFAC-1))
                If NUMLIG_DISVAT & [M:PIH4]INVORDAMT(NUMLIG_DISVAT-1)=0
                  Raz NUMLIG_DISVAT
                Endif
              Endif
            Endif
          Endif
          If NUMLIG_DISVAT | (dim([M:PIH4]DISBAS)>0 & [M:PIH4]DISBAS(I)<>0)
            Gosub SETTLEMENT_DISCOUNT
          Endif
        Endif
        #-----
        TAXE=[M:PIH4]TAX(I)
        Call CALTAXE(GSOCIETE,GBIDA1,[M:PIH1]VAC,GCUR,1,TAXE,1,
&                 [M:PIH4]BASTAX(I),MONTANT,MONTDED,TYPREG,STAT) From SUBTVT
        If func AFNC.ACTIV("PTX") & dim([F:TRA]AMTTSD)>0 & [F:TRA]AMTTSD<>0
          Call CONVERT(GCURSHR,[M:PIH1]CUR,GLOCALDEV,[M:PIH1]CURTYP,
&                       [M:PIH0]ACCDAT,[F:TRA]AMTTSD,SEUIL,STAT) From TRTDEV
          If MONTANT<SEUIL  Raz MONTANT, MONTDED : Endif
        Endif
        #### PUNTO DE ENTRADA ARGENTINA
        GPOINT="CALTAXEGLOB" : Gosub ENTREE From EXEFNC
        ####
        If MONTANT<>[M:PIH4]AMTTAX(I)
          [M:PIH4]AMTTAX(I)=MONTANT
          [M:PIH4]DEDTAX(I)=MONTDED
          [M:PIH4]TOTTAXCLC=sum([M:PIH4]AMTTAX)
          #----- Réajustement mts taxe sur éléments et lignes facture -----#
          Call MAJ_TAXE(I) From SUBPIHB
        Endif
      Endif
    Next I
  Endif
  #-----
Endif
Return

###################################################################
# Traitement de la remise sur taxe (code activité KGB)            #
# --------------------------------------------------------------- #
#                   I  = Indice de la ligne de taxe à traiter     #
#    [M:PIH4]TAX   (I) = Code taxe                                #
#    [M:PIH4]BASTAX(I) = Base taxe net (remise déduite            #
#    [M:PIH4]DISBAS(I) = Montant de la remise base (en négatif)   #
#        NUMLIG_DISVAT = Numéro ligne élément settlement discount #
#                   K  = Indice de la plus grosse base TVA        #
#             WBASFLG  = 0  Base sur ligne commande               #
#                        1  Base sur ligne élément de facturation #
#             WDIFBAS  = Calcul du delta bases Mises mis à jour   #
#             WMAXBAS  = Montant de la plus grosse bases TVA      #
#          WMT_DISVAT  = Montant de la remise sur taxe            #
#          WTX_DISVAT  = Pourcentage de la remise sur taxe        #
###################################################################
$SETTLEMENT_DISCOUNT
If dim(K)<0  Local Integer K : Endif
Local Libelle WBASFLG
Local Decimal WDIFBAS, WMAXBAS
Local Decimal WMT_DISVAT, WTX_DISVAT, WRND
Local Integer WSIGN
#----- Chargement arrondi devise facture -----#
If [F:TCU]CUR<>[M:PIH1]CUR
  Read [TCU] TCU0=[M:PIH1]CUR
  If !fstat WRND=[F:TCU]CURRND Else WRND=0.01 : Endif
Else
  WRND=[F:TCU]CURRND
Endif
#-----
If NUMLIG_DISVAT
  If [M:PIH0]PIHTYP<3
    WSIGN=1-2*([M:PIH4]DEBCDT(NUMLIG_DISVAT-1)-1)
  Else
    WSIGN=-(1-2*([M:PIH4]DEBCDT(NUMLIG_DISVAT-1)-1))
  Endif
  WTX_DISVAT=[M:PIH4]INVORDAMT(NUMLIG_DISVAT-1)
Else
  WSIGN=0
  WTX_DISVAT=0
Endif
#-----
WMT_DISVAT=arr(([M:PIH4]BASTAX(I)-[M:PIH4]DISBAS(I))*WTX_DISVAT/100,WRND)*WSIGN
[M:PIH4]BASTAX(I)=[M:PIH4]BASTAX(I)-[M:PIH4]DISBAS(I)+WMT_DISVAT
[M:PIH4]DISBAS(I)=WMT_DISVAT
#-----
Raz WMAXBAS, WBASFLG, K
WDIFBAS=WMT_DISVAT
#----- Boucle sur les lignes de commande -----#
For J=0 To [M:PIH3]NBLIG-1
  If [M:PIH3]VAT1(J)=[M:PIH4]TAX(I)
    WMT_DISVAT=arr(([M:PIH3]BASTAXLIN1(J)-[M:PIH3]DISBASLIN1(J))*WTX_DISVAT/100,WRND)*WSIGN
    [M:PIH3]BASTAXLIN1(J)=[M:PIH3]BASTAXLIN1(J)-[M:PIH3]DISBASLIN1(J)+WMT_DISVAT
    [M:PIH3]DISBASLIN1(J)=WMT_DISVAT
    [M:PIH3]UPDFLG(J)=1
    # Issue 102698 - 2014-11-19 by MUARN : escomptes belges
    If GDEPMGTMOD=5 & [M:PIH1]DEPRAT<>0
      #[M:PIH3]AMTDEPLIN(J)= arr([M:PIH3]AMTNOTLIN(LIG)*[M:PIH1]DEPRAT/100,[F:TCU]CURRND)
      [M:PIH3]AMTDEPLIN(J)= [M:PIH3]AMTNOTLIN(J)*[M:PIH1]DEPRAT/100
    Else
      Raz [M:PIH3]AMTDEPLIN(J)
    Endif

    If abs([M:PIH3]BASTAXLIN1(J))>WMAXBAS
      WMAXBAS=abs([M:PIH3]BASTAXLIN1(J)) : K=J : WBASFLG=0
    Endif
    WDIFBAS-=WMT_DISVAT
  Endif
Next J
#----- Boucle sur les éléments de facturation -----#
For J=0 To [M:PIH4]NBFAC-1
  If [M:PIH4]INVDTAVAT(J)=[M:PIH4]TAX(I) & [M:PIH4]INVDTAAMT(J)<>0
    WMT_DISVAT=arr([M:PIH4]INVDTAAMT(J)*WTX_DISVAT/100,WRND)*WSIGN
    [M:PIH4]DTADISBAS(J)=WMT_DISVAT
    If abs([M:PIH4]INVDTAAMT(J)+WMT_DISVAT)>WMAXBAS
      WMAXBAS=abs([M:PIH4]INVDTAAMT(J)+WMT_DISVAT) : K=J : WBASFLG=1
    Endif
    WDIFBAS-=WMT_DISVAT
  Endif
Next J

# Issue 102698 - 2014-12-18 by MUARN : escompte belge élément de facturation en majaration non soumis à escompte
If GDEPMGTMOD = 5 & [M:PIH1]DEPRAT<>0
  For J=0 To [M:PIH4]NBFAC-1
    If [M:PIH4]DISVATFLG(J)=1 & [M:PIH4]DEPFLG(J)=1 & [M:PIH4]INCDCR(J)=1
      # pas de remise sur taxe sur l'élément de facturation
      [M:PIH4]DTADISBAS(J)=0
      # élément en taux fixe
      If  [M:PIH4]INVDTAVAT(J)<> ""
        # recherche code taxe de l'élément
        L=find([M:PIH4]INVDTAVAT(J),[M:PIH4]TAX(0..[M:PIH4]NBTAX-1))
        L-=1
        If L >= I
          WMT_DISVAT=arr([M:PIH4]INVDTAAMT(J)*WTX_DISVAT/100,WRND)*WSIGN
          [M:PIH4]BASTAX(L)=[M:PIH4]BASTAX(L)-WMT_DISVAT
          [M:PIH4]DISBAS(L)=[M:PIH4]DISBAS(L)-WMT_DISVAT
        Endif
      # élément en taux produit
      Else
        K=find([M:PIH4]INVDTA(J),[M:PIH3]INVDTALIN2(0..8))
        # Issue 105931 - 2015-02-03 by MUARN : escomptes belges-correctif
        If K>0
          For M=0 To [M:PIH3]NBLIG-1
            WMT_DISVAT = evalue("[M:PIH3]DISCRGAMT"+num$(K)+"(M)")*WTX_DISVAT/100*WSIGN
            [M:PIH3]BASTAXLIN1(M)-=WMT_DISVAT
            [M:PIH3]DISBASLIN1(M)-=WMT_DISVAT
            # recherche code taxe de la ligne
            L=find([M:PIH3]VAT1(M),[M:PIH4]TAX(0..[M:PIH4]NBTAX-1))
            L-=1
            If L >= I
              [M:PIH4]BASTAX(L)=[M:PIH4]BASTAX(L)-WMT_DISVAT
              [M:PIH4]DISBAS(L)=[M:PIH4]DISBAS(L)-WMT_DISVAT
            Endif
          Next M
        Endif
      Endif
    Endif
  Next J
Endif

#----- Imputation de l'écart éventuel sur la base la plus importante -----#
If WDIFBAS<>0
  Case WBASFLG
    When 1       : [M:PIH4]DTADISBAS (K)+=WDIFBAS
    When Default : [M:PIH3]DISBASLIN1(K)+=WDIFBAS
                   [M:PIH3]BASTAXLIN1(K)+=WDIFBAS
  Endcase
Endif
#-----
Return

####################################################################
# Recherche date pour calcul des taxes                             #
# ---------------------------------------------------------------- #
# Si facture d'une réception ou avoir sur retour/facture :         #
#   GBIDA1 = Date du document d'origine                            #
#            Si plusieurs documents c'est celle du 1er document    #
#            prise en compte (picking ou saisie manuelle)          #
# Si champ VATDAT saisi manuellement (ex pour les anglais)         #
#   GBIDA1 = Date saisie                                           #
# Autrement :                                                      #
#   GBIDA1 = Date comptable de la pièce elle-même (facture/avoir)  #
####################################################################
$RECH_DATE_TAXE
If dim([M:PIH1]VATDAT)>0 & [M:PIH1]VATDAT<>[0/0/0]
  GBIDA1=[M:PIH1]VATDAT
Else
  GBIDA1=[M:PIH0]ACCDAT
Endif
Return

####################################################################
# Contrôle date pour calcul des taxes                              #
# ---------------------------------------------------------------- #
# Il faut que les dates comptables des factures d'origine          #
#    pointent sur la même période de determination du taux         #
# GBIDA1 = Date comptable de la facture d'origine                  #
# GBIDC3 = Code taxe à verifier                                    #
####################################################################
$CTRL_DATE_TAXE
Raz mkstat
If dim([M:PIH1]VATDAT)<1  Return : Endif : # Test présence du champ
If [M:PIH0]PIHTYP<>3      Return : Endif : # si <> avoir  pas contrôle
If [M:PIH1]VATDAT=[0/0/0] Return : Endif : # 1ère fois pas de contrôle
If clalev([F:TRA])=0  Local File TABRATVAT [TRA]  : Endif
If clalev([F:TVT])=0  Local File TABVAT  [TVT]  : Endif :#--CPO 71937 TVT et multi-lèg

If dim(WRET)<0  Local Integer WRET : Endif
#--CPO 71937 TVT et multi-lèg
Call LEC_TVT_LEG(GCURLEG,GBIDC3,WRET) From TRTLECLEG
If WRET : Raz [F:TVT] : Endif
#Filter [TRA] Where CPY=GSOCIETE & VAT=GBIDC3 & STRDAT<=[M:PIH1]VATDAT
Filter [TRA] Where CPY=GSOCIETE & VAT=GBIDC3 & STRDAT<=[M:PIH1]VATDAT & LEG=[F:TVT]LEG
Read [TRA] TRA0 Last
If fstat>2
  #Filter [TRA] Where CPY="" & VAT=GBIDC3 & STRDAT<=[M:PIH1]VATDAT
  Filter [TRA] Where CPY="" & VAT=GBIDC3 & STRDAT<=[M:PIH1]VATDAT & LEG=[F:TVT]LEG
  Read [TRA] TRA0 Last
  If fstat  Raz [F:TRA] : Endif
Elsif fstat
  Raz [F:TRA]
Endif
GBIDA2=[F:TRA]STRDAT
#Filter [TRA] Where CPY=GSOCIETE & VAT=GBIDC3 & STRDAT<=GBIDA1
Filter [TRA] Where CPY=GSOCIETE & VAT=GBIDC3 & STRDAT<=GBIDA1 & LEG=[F:TVT]LEG
Read [TRA] TRA0 Last
If fstat>2
  #Filter [TRA] Where CPY="" & VAT=GBIDC3 & STRDAT<=GBIDA1
  Filter [TRA] Where CPY="" & VAT=GBIDC3 & STRDAT<=GBIDA1 & LEG=[F:TVT]LEG
  Read [TRA] TRA0 Last
  If fstat  Raz [F:TRA] : Endif
Elsif fstat
  Raz [F:TRA]
Endif
Filter [TRA]
#----- Erreur la facture d'origine ne pointe pas sur le même taux de taxe -----#
If [F:TRA]STRDAT<>GBIDA2
  WRET=1 : Call AVERTIR(mess(364,199,1),WRET) From GESECRAN
  If WRET<>2  mkstat=1 : Endif
Endif
Return

###############################################################################
# Préparation des sections analytiques d'une ligne de facture                 #
# --------------------------------------------------------------------------- #
# Si la clé de répartion est renseignée                                       #
#    il faut "mettre à blanc" toutes les sections                             #
# Si l'axe est suivi en analytique et que la section correspondante est vide  #
#    il faut forcer l'initialisation grâce au Raz                             #
# Si l'axe n'est pas suivi en analytique                                      #
#    il faut "mettre  à blanc" la section correspondante                      #
# --------------------------------------------------------------------------- #
# NOL contient l'indice de la ligne en cours                                  #
# [M:PIH3]LINACC1-10(NOL) contient les comptes                                #
# GBIDI2 : 0 = Pas d'affichage des sections analytiques                       #
#          1 = Affichage des sections analytiques                             #
###############################################################################
$PREP_INIT_CCE
#-----
If dim(I)<1    Local Integer I             : Endif
If dim(WCCE)<1 Local Char    WCCE(GLONCCE) : Endif
#----- Initialisation de la clé de répartition (lignes diverses) -----#
If !varinit([M:PIH3]LINDSP,NOL) | [M:PIH3]TYPORI(NOL)=5
  If dim(WACC)<1  Local Char WACC(GLONGAC) : Endif
  Call RECH_ACC(2,"[M:PIH3]LINACC",NOL,WACC) From TRTX3CPT
  # Issue 101893 - 2014-09-04 by MUARN : sur les lignes divers ne pas initialiser LINDSP si on est sur LINDSP
  If !varinit([M:PIH3]LINDSP,NOL) | ([M:PIH3]TYPORI(NOL)=5 & zoncou <> "LINDSP")
    [M:PIH3]LINDSP(NOL)=[F:GAC]DSP
  Endif
Endif
#----- Si clé de répartition renseignée, pas de sections analytiques -----#
If [M:PIH3]LINDSP(NOL)<>""
  For I=1 To GNBDIE
    If evalue("dim([M:PIH3]CCE"+num$(I)+")")>0
      Assign"[M:PIH3]CCE"+num$(I)+"(NOL)" With ""
    Endif
  Next I
#----- Pas de section si pas de suivi analytique sur l'axe concerné -----#
Else
  For I=1 To GNBDIE
    WCCE=evalue("[M:PIH3]CCE"+num$(I)+"(NOL)")
    Raz mkstat
    Call SAIS_CCE(WCCE,I,"[M:PIH3]LINACC","[M:PIH3]LINDSP") From TRTX3CPT
    If mkstat
      Assign "[M:PIH3]CCE"+num$(I)+"(NOL)" With ""
      Raz mkstat
    Elsif evalue("[M:PIH3]CCE"+num$(I)+"(NOL)")=""
      #----- Raz pour forcer l'initialisation -----#
      Case I
        When  1 : Raz [M:PIH3]CCE1 (NOL)
        When  2 : Raz [M:PIH3]CCE2 (NOL)
        When  3 : Raz [M:PIH3]CCE3 (NOL)
        When  4 : Raz [M:PIH3]CCE4 (NOL)
        When  5 : Raz [M:PIH3]CCE5 (NOL)
        When  6 : Raz [M:PIH3]CCE6 (NOL)
        When  7 : Raz [M:PIH3]CCE7 (NOL)
        When  8 : Raz [M:PIH3]CCE8 (NOL)
        When  9 : Raz [M:PIH3]CCE9 (NOL)
        When 10 : Raz [M:PIH3]CCE10(NOL)
        When 11 : Raz [M:PIH3]CCE11(NOL)
        When 12 : Raz [M:PIH3]CCE12(NOL)
        When 13 : Raz [M:PIH3]CCE13(NOL)
        When 14 : Raz [M:PIH3]CCE14(NOL)
        When 15 : Raz [M:PIH3]CCE15(NOL)
        When 16 : Raz [M:PIH3]CCE16(NOL)
        When 17 : Raz [M:PIH3]CCE17(NOL)
        When 18 : Raz [M:PIH3]CCE18(NOL)
        When 19 : Raz [M:PIH3]CCE19(NOL)
        When 20 : Raz [M:PIH3]CCE20(NOL)
      Endcase
    Endif
  Next I
Endif
#----- Affichage des sections analytiques -----#
If GBIDI2=1
  Affzo [PIH3]LINDSP(NOL)
  Gosub AFFICH_CCE From SUBPIH
Endif
Return


###############################################################################
# Préparation des sections analytiques d'une ligne d'élément de facturation   #
# --------------------------------------------------------------------------- #
# Si la clé de répartion est renseignée                                       #
#    il faut "mettre à blanc" toutes les sections                             #
# Si l'axe est suivi en analytique et que la section correspondante est vide  #
#    il faut forcer l'initialisation grâce au Raz                             #
# Si l'axe n'est pas suivi en analytique                                      #
#    il faut "mettre  à blanc" la section correspondante                      #
# --------------------------------------------------------------------------- #
# NOL contient l'indice de la ligne en cours                                  #
# [M:PIH4]ACC1-10(NOL) contient les comptes                                   #
# GBIDI2 : 0 = Pas d'affichage des sections analytiques                       #
#          1 = Affichage des sections analytiques                             #
###############################################################################
$PREP_INIT_PFICCE
#-----
If dim(I)<1    Local Integer I             : Endif
If dim(WCCE)<1 Local Char    WCCE(GLONCCE) : Endif
#----- Si clé de répartition renseignée, pas de sections analytiques -----#
If !varinit([M:PIH4]DSP,NOL)  [M:PIH4]DSP(NOL)=[F:GAC]DSP : Endif
If [M:PIH4]DSP(NOL)<>""
  For I=1 To GNBDIE
    If evalue("dim([M:PIH4]PFICCE"+num$(I)+")")>0
      Assign"[M:PIH4]PFICCE"+num$(I)+"(NOL)" With ""
    Endif
  Next I
#----- Pas de section si pas de suivi analytique sur l'axe concerné -----#
Else
  For I=1 To GNBDIE
    WCCE=evalue("[M:PIH4]PFICCE"+num$(I)+"(NOL)")
    Raz mkstat
    Call SAIS_CCE(WCCE,I,"[M:PIH4]ACC","[M:PIH4]DSP") From TRTX3CPT
    If mkstat
      Assign "[M:PIH4]PFICCE"+num$(I)+"(NOL)" With ""
      Raz mkstat
    Elsif evalue("[M:PIH4]PFICCE"+num$(I)+"(NOL)")=""
      #----- Raz pour forcer l'initialisation -----#
      Case I
        When  1 : Raz [M:PIH4]PFICCE1 (NOL)
        When  2 : Raz [M:PIH4]PFICCE2 (NOL)
        When  3 : Raz [M:PIH4]PFICCE3 (NOL)
        When  4 : Raz [M:PIH4]PFICCE4 (NOL)
        When  5 : Raz [M:PIH4]PFICCE5 (NOL)
        When  6 : Raz [M:PIH4]PFICCE6 (NOL)
        When  7 : Raz [M:PIH4]PFICCE7 (NOL)
        When  8 : Raz [M:PIH4]PFICCE8 (NOL)
        When  9 : Raz [M:PIH4]PFICCE9 (NOL)
        When 10 : Raz [M:PIH4]PFICCE10(NOL)
        When 11 : Raz [M:PIH4]PFICCE11(NOL)
        When 12 : Raz [M:PIH4]PFICCE12(NOL)
        When 13 : Raz [M:PIH4]PFICCE13(NOL)
        When 14 : Raz [M:PIH4]PFICCE14(NOL)
        When 15 : Raz [M:PIH4]PFICCE15(NOL)
        When 16 : Raz [M:PIH4]PFICCE16(NOL)
        When 17 : Raz [M:PIH4]PFICCE17(NOL)
        When 18 : Raz [M:PIH4]PFICCE18(NOL)
        When 19 : Raz [M:PIH4]PFICCE19(NOL)
        When 20 : Raz [M:PIH4]PFICCE20(NOL)
      Endcase
    Endif
  Next I
Endif
#----- Affichage des sections analytiques -----#
If GBIDI2=1
  Affzo [PIH4]DSP(NOL)
  Gosub AFFICH_PFICCE From SUBPIH
Endif
Return


##########################################################################
# Appel du point d'entrée CLCVALFAC depuis le traitement SUBPIHD         #
# ---------------------------------------------------------------------- #
# Mettre [L]WCONTROLE à zéro pour ne pas effectuer le contrôle sur le    #
# statut validé d'une facture ou avoir portant sur le document d'origine #
##########################################################################
$POINT_CTLVALFAC
GPOINT="CTLVALFAC" : Gosub ENTREE From EXEFNC
Return

