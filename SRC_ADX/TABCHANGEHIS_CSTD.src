#<AdxTL>@(#)0.0.0.0 $Revision$
# Structure TABCHANGE

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD"                  : Gosub AREAD
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "SELCHGTYPDAT"                   : Gosub SELCHGTYPDAT
  When "COLTCH.CHGTYP"                  : Gosub COLTCH_CHGTYP
  When "COLTCH.CURDEN"                  : Gosub COLTCH_CURDEN
  When "COLTCH.CHGSTRDAT"               : Gosub COLTCH_CHGSTRDAT
  When "COLTCH.EQUAL"                   : Gosub COLTCH_EQUAL
  When "COLTCH.CUR"                     : Gosub COLTCH_CUR
  When "COLTCH.CHGDIV"                  : Gosub COLTCH_CHGDIV
  When "COLTCH.CHGRAT"                  : Gosub COLTCH_CHGRAT
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return


############################################################################################################
$AREAD
# Set currency symbol

this.CURSYM = fmet this.ACTX.ACACHE.ACUR.AGETVALCHAR(this.CURDEN, "CURSYM")

Gosub COLTCH_LOAD                     # Load collection with rates

Return

$COLTCH_LOAD
Local Integer ILINE,HLINE
Local Integer EURFLG
Local Date EURDAT
Local File TABCHANGE [TCH]
Local File TABCUR [TCU]

EURO = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"EURO")

Link [F:TCH] With [F:TCU]TCU0=[F:TCH]CUR As [LNK] Where [F:TCH]CURDEN = this.CURDEN
&    & [F:TCH]CHGTYP=this.CHGTYP & [F:TCH]CUR = this.CUR
&    Order By Key KEY1=[F:TCH]CUR Asc;[F:TCH]CHGTYP Asc;[F:TCH]CHGSTRDAT Desc
# Retrieve current exchange Rates

For [LNK]KEY1(2)
  If [F:TCU]CUR=[L]EURO | [F:TCU]EURFLG<>[V]CST_AYES
&  | [F:TCU]EURFLG=[V]CST_AYES                        # Euro countries
      # Current rates
      ILINE=fmet this.ADDLINE("COLTCH",[V]CST_ALASTPOS)
      SetInstance this.COLTCH(ILINE) With [F:TCH]
      this.COLTCH(ILINE).CURSYMDEN = this.CURSYM
      this.COLTCH(ILINE).ASTALIN = [V]CST_ALL                 # [V]CST_ALL = Line has not been modified
      this.COLTCH(ILINE).EQUAL = "="
      this.COLTCH(ILINE).CURSYM = fmet this.ACTX.ACACHE.ACUR.AGETVALCHAR(this.COLTCH(ILINE).CUR, "CURSYM")
      If this.COLTCH(ILINE).CURSYM = AVOID.ACHAR
        this.COLTCH(ILINE).CURSYM = this.COLTCH(ILINE).CUR
      Endif
    Endif
  Break
 Next
 Filter [LNK]
 Link [F:TCH] With [F:TCU]TCU0=[F:TCH]CUR As [LNK] Where [F:TCH]CURDEN = this.CURDEN
&    & [F:TCH]CHGTYP=this.CHGTYP & [F:TCH]CUR = this.CUR
&    Order By Key KEY1=[F:TCH]CUR Asc;[F:TCH]CHGTYP Asc;[F:TCH]CHGSTRDAT Desc

# Retrieve all exchange rates for a given currency and exchange rate type
 For [LNK]
     If [F:TCU]CUR=[L]EURO | [F:TCU]EURFLG<>[V]CST_AYES
&  | ([F:TCU]EURFLG=[V]CST_AYES & [F:TCU]EURDAT>this.SELCHGSTRDAT)       # Euro countries
      # History rates
      HLINE=fmet this.ADDLINE("COLTCHHIS",[V]CST_ALASTPOS)
      SetInstance this.COLTCHHIS(HLINE) With [F:TCH]
      this.COLTCHHIS(HLINE).CURSYMDEN = this.CURSYM
      this.COLTCHHIS(HLINE).CURSYM = fmet this.ACTX.ACACHE.ACUR.AGETVALCHAR(this.COLTCHHIS(HLINE).CUR, "CURSYM")
      this.COLTCHHIS(HLINE).EQUAL = "="
      If this.COLTCHHIS(HLINE).CURSYM = AVOID.ACHAR
        this.COLTCHHIS(HLINE).CURSYM = this.COLTCHHIS(HLINE).CUR
      Endif
  Endif
Next

Filter [TCH]
Return

############################################################################################################
$AINSERT_CONTROL_BEFORE
  Gosub CONTROL_CONSISTENCY
Return


############################################################################################################
$AINSERT
Local Integer ILINE

  For ILINE=1 To maxtab(this.COLTCH)
    If this.COLTCH(ILINE)<>null
      If this.COLTCH(ILINE).ASTALIN = CST_ANEW
        this.COLTCH(ILINE).CURDEN = this.CURDEN
        [L]ASTATUS = fmet this.COLTCH(ILINE).AINSERT()
        Break ([L]ASTATUS>=[V]CST_AERROR)
      Endif
    Endif
  Next
Return

############################################################################################################
$AUPDATE_CONTROL_BEFORE
  Gosub CONTROL_CONSISTENCY
Return

############################################################################################################
$AUPDATE
Local Integer ILINE

# Delete the lines
  For ILINE= 1 To maxtab(this.COLTCH)
    If this.COLTCH(ILINE).ASTALIN = [V]CST_ADEL
      [L]ASTATUS = fmet this.COLTCH(ILINE).ADELETE()
      If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
    Endif
  Next

# Update the lines
  For ILINE= 1 To maxtab(this.COLTCH)
    If this.COLTCH(ILINE).ASTALIN = [V]CST_AUPD
      this.COLTCH(ILINE).CURDEN    = this.CURDEN
      [L]ASTATUS = fmet this.COLTCH(ILINE).AUPDATE()
      If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
    Endif
  Next

# Insert the lines
  For ILINE= 1 To maxtab(this.COLTCH)
    If this.COLTCH(ILINE).ASTALIN = [V]CST_ANEW
      this.COLTCH(ILINE).CURDEN    = this.CURDEN
      [L]ASTATUS = fmet this.COLTCH(ILINE).AINSERT()
      If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
    Endif
  Next
Return

############################################################################################################
$ADELETE
Local File TABCHANGE [TCH]
Local Integer ILINE

For ILINE= 1 To maxtab(this.COLTCH)
 If !find(this.COLTCH(ILINE).ASTALIN,[V]CST_ANEW,[V]CST_ANEWDEL)
   [L]ASTATUS = fmet this.COLTCH(ILINE).ADELETE()
   If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
 Endif
Next
Return

############################################################################################################
# Tests if at least one line exists and that new or updated lines are unique.
$CONTROL_CONSISTENCY
Local Integer ILINE, ILINE1, MY_STATUS
Local Shortint LINE_FOUND : LINE_FOUND = [V]CST_AFALSE
Local Shortint LINE_ERROR : LINE_ERROR = [V]CST_AFALSE
Local Instance MY_TABCHANGED Using C_TABCHANGED

  For ILINE = 1 To maxtab(this.COLTCH)
    If this.COLTCH(ILINE)<>null
      If !find(this.COLTCH(ILINE).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
        [L]LINE_FOUND=[V]CST_ATRUE
        For ILINE1 = 1 To maxtab(this.COLTCH)
          If ILINE1 <> ILINE
            If !find(this.COLTCH(ILINE).ASTALIN,[V]CST_AUPD,[V]CST_ANEW)
              If this.COLTCH(ILINE).CHGTYP = this.COLTCH(ILINE1).CHGTYP
&              &   this.COLTCH(ILINE).CURDEN = this.COLTCH(ILINE1).CURDEN
&              &   this.COLTCH(ILINE).CUR    = this.COLTCH(ILINE1).CUR
&              &   this.COLTCH(ILINE).CURSTRDAT = this.COLTCH(ILINE1).CURSTRDAT
                [L]LINE_ERROR = [V]CST_ATRUE
              Else
                # Check if a rate change entry exists on the rate change table. The representation and class contain only the current
                # used rates for each currency and rate type.
                MY_TABCHANGED = NewInstance C_TABCHANGED AllocGroup null
                If fmet MY_TABCHANGED.AREAD( this.COLTCH(ILINE1).CHGTYP, this.COLTCH(ILINE1).CURDEN, this.COLTCH(ILINE1).CUR, this.COLTCH(ILINE1).CHGSTRDAT) = [V]CST_AOK
                  [L]LINE_ERROR = [V]CST_ATRUE
                Endif
                FreeGroup MY_TABCHANGED
              Endif
            Endif
          Endif
        Next
      Endif
    Endif
  Next

  If [L]LINE_ERROR=[V]CST_ATRUE
    # Exchange rate already exists for this date
    [L]ASTATUS = fmet this.ASETERROR("COLTCH",mess(53,133,1),[V]CST_AERROR)
  Endif

  If [L]ASTATUS = [V]CST_AOK & [L]LINE_FOUND = [V]CST_AFALSE
    # There must be at least one line
    [L]ASTATUS = fmet this.ASETERROR("COLTCH",mess(178,123,1),[V]CST_AERROR)
  Endif

  # Mandatory fields
  For ILINE = 1 To maxtab(this.COLTCH)
    #Set Mandatory Attributes
    [L]MY_STATUS = fmet this.COLTCH(ILINE).ASETATTRIBUTE("CHGSTRDAT","$isMandatory","true")
    [L]MY_STATUS = fmet this.COLTCH(ILINE).ASETATTRIBUTE("CHGDIV","$isMandatory","true")
    [L]MY_STATUS = fmet this.COLTCH(ILINE).ASETATTRIBUTE("CUR","$isMandatory","false")
    [L]MY_STATUS = fmet this.COLTCH(ILINE).ASETATTRIBUTE("CHGRAT","$isMandatory","false")
  Next
Return




$SELCHGTYPDAT
  Case [L]ARULE
    When "PROPAGATE"                      : Gosub SELCHGTYPDAT_PROPAGATE
    When Default:
  Endcase
Return

$SELCHGTYPDAT_PROPAGATE
Gosub COLTCH_LOAD
Return

$COLTCH_CHGTYP
  Case [L]ARULE
    When "PROPAGATE"                      : Gosub GET_COLTCH
    When Default:
  Endcase
Return

$COLTCH_CURDEN
  Case [L]ARULE
    When "INIT"                           : this.CURDEN = this.APARENT.CURDEN
    When "PROPAGATE"                      : Gosub GET_COLTCH
    When Default:
  Endcase
Return

$COLTCH_CHGSTRDAT
Case [L]ARULE
  When "INIT"                             : this.CHGSTRDAT = date$
  When "PROPAGATE"                        : Gosub GET_COLTCH
  When Default:
Endcase
Return

$COLTCH_EQUAL
Case [L]ARULE
  When "INIT"                             : this.EQUAL = "="
  When Default:
Endcase
Return

$COLTCH_CUR
  Case [L]ARULE
    When "PROPAGATE"                      : this.CURSYM = fmet this.ACTX.ACACHE.ACUR.AGETVALCHAR(this.CUR, "CURSYM")
                                          : Gosub GET_COLTCH
    When Default:
  Endcase
Return

$COLTCH_CHGDIV
  Case [L]ARULE
    When "INIT"                           : this.CHGDIV = 1
    When "CONTROL"                        : Gosub COLTCH_CHGDIV_CONTROL
    When "PROPAGATE"                      : Gosub CHGDIV_CHGRAT
    When Default:
  Endcase
Return

$COLTCH_CHGRAT
  Case [L]ARULE
    When "INIT"                           : this.CHGRAT = 1
    When "CONTROL"                        : Gosub COLTCH_CHGRAT_CONTROL
    When "PROPAGATE"                      : Gosub CHGDIV_CHGRAT
    When Default:
  Endcase
Return

$COLTCH_CHGDIV_CONTROL
If this.CHGDIV <=0
  [L]ASTATUS = fmet this.ASETERROR("CHGDIV","Value must be greater than 0", [V]CST_AERROR)
Endif
Return

$COLTCH_CHGRAT_CONTROL
If this.CHGRAT <=0
  [L]ASTATUS = fmet this.ASETERROR("CHGRAT","Value must be greater than 0", [V]CST_AERROR)
Endif
Return

$GET_COLTCH
Local Instance MY_TCH Using C_TABCHANGED
If this.CHGTYP>0 & this.CURDEN<>"" & this.CUR<>"" & this.CHGSTRDAT <> AVOID.ADATE
  MY_TCH = NewInstance C_TABCHANGED AllocGroup null
  [L]ASTATUS = fmet MY_TCH.AREAD(this.CHGTYP,this.CURDEN,this.CUR,this.CHGSTRDAT)
  If [L]ASTATUS <> [V]CST_AERROR
    [L]ASTATUS = fmet this.ASETERROR("COLTCH",mess(33,137,1),[V]CST_AERROR)
  Endif
  FreeGroup MY_TCH
Endif
Return

$CHGDIV_CHGRAT
Case [L]ARULE
  When "PROPAGATE"                  : Gosub RATE_PROPAGATE
  When  Default:
Endcase
Return

$RATE_PROPAGATE
If this.CHGRAT<>0
  this.REVCOURS = this.CHGDIV/this.CHGRAT
Else
  this.REVCOURS = 0
Endif
Return

