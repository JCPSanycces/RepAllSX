#<AdxTL>@(#)2.0.0.0 $Revision$ Campagnes de relances
#**##############################################################################################
# Process       : RPTFUP
# Creation date : ????-??-??
# Version       : ?.?
# Authors       : ???
# ---------------------------------------------------------------------------------------------
# Description   : Reminder report
# ---------------------------------------------------------------------------------------------
# Last Modified : 2015-10-07 | DNE   | SAM #104530 Reminder reports (FUP) per company
# Issue X3-58883 - 2018-01-11 by BEFOU : Adding Key on filter for FUP2 (FCY, FUPMOD)
#!###############################################################################################

###########################################################################################################################
## Subprog IMPRIME => Printing from X3 Printing menu
## Subprog EDITION => Printing following a campaign validation
###########################################################################################################################

$ACTION
Case ACTION
 When "FICHIER"     : Gosub FICHIER
 When "MESSAGERIE"  : Gosub MESSAGERIE
Endcase
Return

######################################################################

$MESSAGERIE
# here we choose the name of the attachment
# Do NOT include the file extension, it will be automatically appended
# Add the "#" symbol for the supervisor to automatically number the attached files
JOBID = "FUP-"+[F:FUP2]BPRFUP+"-"+format$("D:DDMMYY",date$)+"-"+num$(time)+"#"
Return

######################################################################

$FICHIER
If GFONCTION="AIMP"
 # Call to function "Reports > Reports"
 # in this case, we do not modify the manually chosen destination or filename
 Return
Endif

Local Integer N, N2
Local Char CHEMINCLI(250), SEQUENCE(6), LFCY(GLONFCY)
Local Char RPTDST(GLONAIM)(1..2), RPTEXT(4)

If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif

NBPAR = find("", PARAMETRE)
N = find("fcy", TBPAR)
LFCY = TBVAL(N)

# destinations to be used for printing FUP report
For N=1 To dim(RPTDST)
 If GSERVEUR
  # in batch mode we use only destinations set with a print server
  Call PARAML(LFCY,"RPTBATCH"+num$(N),RPTDST(N)) From ADOVAL
 Else
  Call PARAML(LFCY,"RPTDST"+num$(N),RPTDST(N)) From ADOVAL
 Endif
Next

N = find("sequence", TBPAR)
SEQUENCE=TBVAL(N)

N = find("bpc", TBPAR)
If [F:BPC]BPCNUM<>TBVAL(N) : Read [BPC]BPC0=TBVAL(N) : Endif

If [F:AIM]COD<>RPTDST([F:FUP2]FUPMOD) : Read [AIM]AIM0=RPTDST([F:FUP2]FUPMOD) : Endif

# extension to be used for files generated by Crystal Reports
RPTEXT = func GETEXT([F:AIM]PRTFMT)

PARAMETRE(NBPAR) = "_FormatExport="+chr$(1)+num$([F:AIM]PRTFMT)

Call PARAMUTIL("FUPRPTDIR",CHEMINCLI,GUSER,"") From SUBAUS
NBPAR += 1
PARAMETRE(NBPAR) = "_ExportFile="+chr$(1)+CHEMINCLI+toupper(left$(mess([F:FUP2]FUPMOD,2629,1), 3))+"-"+[FUP2]BPRFUP+"-"+[F:TFP1]NUMREQ+"-"+SEQUENCE+[L]RPTEXT

# MANDATORY - DO NOT DELETE
# Avoids asking the name of the file to be generated
OK = 0
Return

######################################################################
## Printing from X3 Print menu
######################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Call EXEC(NBPAR,PARAMETRE,0)
End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE,SIMUL)
Value Integer NBPAR, SIMUL
Variable Char    PARAMETRE()(1..)

Local Integer N
Local Char NUMREQ(GLONFUP), FLDVAL(250), BPC(GLONBPC)
Local File TMPFUP0 [TFP0]

Call GETPARAM("numedt",NBPAR,PARAMETRE,NUMREQ) From ETAT
Call GETPARAM("bpc",NBPAR,PARAMETRE,BPC) From ETAT

If [F:TFP0]QURNUM<>[L]NUMREQ : Read [TFP0]TFP0 = [L]NUMREQ : Endif
If fstat
 # Nothing to print
 Call ECR_TRACE(mess(21,135,1),0) From GESECRAN
 GOK=0 : End
Endif

If clalev([F:FUP])=0 : Local File FUP [FUP] : Endif
# There is no criterion on facility
# the client parameter is now optional
If [L]BPC=""
 Filter [FUP] Where NUMEDT=[L]NUMREQ
Else
 Filter [FUP] Where NUMEDT=[L]NUMREQ & BPRFUP=[L]BPC
Endif
If rowcount([FUP])=0
 # Nothing to print
 Filter [FUP]
 Call ECR_TRACE(mess(21,135,1),0) From GESECRAN
 GOK=0 : End
Endif
Filter [FUP]

For N=0 To 9
 If N<dim([F:TFP0]TSCCOD)
  Call SETPARAM("tsccod_"+num$(N),NBPAR,PARAMETRE,[F:TFP0]TSCCOD(N)) From ETAT
 Else
  FLDVAL = ""
  Call SETPARAM("tsccod_"+num$(N),NBPAR,PARAMETRE,FLDVAL) From ETAT
 Endif
Next
End

###########################################################################################################################
## Printing following the reminder campaign validation (process TRTFUPVAL)
###########################################################################################################################
Subprog EDITION(NUMREQ)
Value Char NUMREQ()

Local Char TBPAR(50)(1..100)
Local Char TBVAL(50)(1..100)
Local Char FLDVAL(250)
Local Char RPTDST(GLONAIM)(1..2)
Local Char DST(GLONAIM)
Local Char CHEMINCLI(250), PARNAM(250), FUPRPTDIR(250), MSG(250)
Local Integer FUPMOD, INTE, INC, NBENR, NBPAR, N, FICDST, PREVIEW
# 2015-10-07 DNE INSERT BEGIN (SAM #104530 )
Local Char RPTCODFUP(GLONARP)    : [L]RPTCODFUP = "FUP"
Local Char RPTCODFUPOLD(GLONARP) : Raz [L]RPTCODFUPOLD
# 2015-10-07 DNE INSERT END

If clalev([F:TFP0])=0 : Local File TMPFUP0    [TFP0] : Endif
If clalev([F:FUP2])=0 : Local File FUP        [FUP2] : Endif
If clalev([F:FUP3])=0 : Local File FUP        [FUP3] : Endif
If clalev([F:AIM])=0  : Local File APRINTER   [AIM]  : Endif
If clalev([F:DUD])=0  : Local File GACCDUDATE [DUD]  : Endif

Onerrgo
# Campaign validation
Call OUVRE_BOITE(mess(45,114,1), 100) From GESECRAN

# Issue X3-58883 Adding Key FUPMOD
Filter [FUP2] Where NUMEDT=[L]NUMREQ Order By Key CLE=FCY ; FUPMOD
NBENR = rowcount([FUP2])
# Campaign validation
Call SET_BOITE(mess(45,114,1), 2*NBENR) From GESECRAN

# the values of [F:FUP]PREVIEW and [F:FUP]DST must be updated before each printing
Trbegin [FUP2]
# Issue X3-58883 With the 2 keys
For [FUP2]CLE(2) Where NUMEDT=[L]NUMREQ and find(FUPMOD, 1, 2)<>0
 If GSERVEUR
  # in batch mode all destinations must use a print server
  Call PARAML([F:DUD]FCY, "RPTBATCH"+num$([F:FUP2]FUPMOD), DST) From ADOVAL
 Else
  Call PARAML([F:DUD]FCY, "RPTDST"+num$([F:FUP2]FUPMOD), DST) From ADOVAL
 Endif

 If [F:AIM]COD<>DST : Read [AIM]AIM0=DST : Endif
 If [F:AIM]PRT=1
  [L]PREVIEW = 2
 Else
  [L]PREVIEW = 1
 Endif
 # Issue X3-58883
 #Update [FUP3] Where NUMEDT=[L]NUMREQ and FCY=[F:FUP2]FCY and find(FUPMOD, 1, 2)<>0
  Update [FUP3] Where NUMEDT=[L]NUMREQ and FCY=[F:FUP2]FCY and FUPMOD=[F:FUP2]FUPMOD
& With PREVIEW=[L]PREVIEW, DST=[F:AIM]COD
Next
Commit
Filter [FUP2]

# reminders by letter or email only
# reminders by fax or by phone can't be processed here
# boucle sur chaque client
Local Integer SEQUENCE

INC = 0
# loop on reminder modes : 1/Letter, 2/E-mail
Filter [FUP2] Order By Key K1=BPRFUP;FCY
For [L]FUPMOD=1 To 2
 SEQUENCE = 1
 # loop on each group "customer/site" of the campaign
 # Use "PREVIEW<>2" instead of "PREVIEW=1" to allow reprinting campaigns created and validated
 # before the field [F:FUP]PREVIEW was added
 For [FUP2]K1(2) Where NUMEDT=[L]NUMREQ and FUPMOD=[L]FUPMOD and PREVIEW<>2
  NBPAR=0
  Raz TBPAR, TBVAL

  NBPAR+=1  : TBPAR(NBPAR) = "numedt"    : TBVAL(NBPAR)=[L]NUMREQ

  If [F:TFP0]QURNUM<>[L]NUMREQ : Read [TFP0]TFP0 = [L]NUMREQ : Endif

  NBPAR+=1  : TBPAR(NBPAR) = "sequence"  : TBVAL(NBPAR)=num$(SEQUENCE) : SEQUENCE += 1

  # retrieval of reminder texts to be used by the workflow rule for reminders by email
  Read [BPC]BPC0=[F:FUP2]BPRFUP
  Read [BPR]BPR0=[F:BPC]BPCNUM
  # Type 3 = by email
  If [F:FPT]LAN<>[F:BPR]LAN or [F:FPT]GRP<>[F:BPC]GRP or [F:FPT]TYPTXT<>3 or [F:FPT]LEVFUP<>[F:FUP2]LEVFUP
   Read [FPT]FPT0=[F:BPR]LAN;[F:BPC]GRP;3;[F:FUP2]LEVFUP
  Endif
  If fstat
   # we retrieve the text "By email" of highest level available in this reminder group for this language
   Filter [FPT] Where LAN=[F:BPR]LAN and GRP=[F:BPC]GRP and TYPTXT=3 and LEVFUP<=[F:FUP2]LEVFUP Order By LEVFUP Asc
   Read [FPT] Last
   Filter [FPT]

   If fstat
    # we retrieve the text "By email" of highest level available in group "All groups" (GRP = "")
    Filter [FPT] Where LAN=[F:BPR]LAN and GRP="" and TYPTXT=3 and LEVFUP<=[F:FUP2]LEVFUP Order By LEVFUP Asc
    Read [FPT] Last
    Filter [FPT]
   Endif
  Endif

  If [F:DUD]ACCNUM<>[F:FUP2]ACCNUM or [F:DUD]DUDLIG<>[F:FUP2]DUDLIG : Read [F:DUD]DUD1 = [F:FUP2]ACCNUM;[F:FUP2]DUDLIG : Endif
  NBPAR+=1  : TBPAR(NBPAR) = "fcy" : TBVAL(NBPAR) = [F:DUD]FCY
  # destination to be used for printing reports
  For N=1 To dim(RPTDST)
   If GSERVEUR
    # in batch mode all destinations must use a print server
    Call PARAML([F:DUD]FCY,"RPTBATCH"+num$(N),RPTDST(N)) From ADOVAL
   Else
    Call PARAML([F:DUD]FCY,"RPTDST"+num$(N),RPTDST(N)) From ADOVAL
   Endif
  Next

  NBPAR+=1  : TBPAR(NBPAR) = "bpc"
  If [M:CFP1]BPRFUP=1
   TBVAL(NBPAR) = [F:DUD]BPRPAY
  Else
   TBVAL(NBPAR) = [F:DUD]BPR
  Endif

####################################################################

  # we use CPY2 instead of CPY to avoid overwritting the value
  If clalev([F:CPY2])=0 : Local File COMPANY  [CPY2] : Endif
  If clalev([F:FCY2])=0 : Local File FACILITY [FCY2] : Endif
  If [F:CPY2]CPY<>[F:DUD]CPY : Read [F:CPY2]CPY0=[F:DUD]CPY : Endif
  If [F:FCY2]FCY<>[F:DUD]FCY : Read [F:FCY2]FCY0=[F:DUD]FCY : Endif

  # retrieval of the address associated with the address code stored in [FUP] (copied from [TFP2]ADD)
  If [F:BPA]BPATYP<>1 or [F:BPA]BPANUM<>[F:BPC]BPCNUM or [F:BPA]BPAADD<>[FUP2]ADD : Read [BPA]BPA0=1;[F:BPC]BPCNUM;[FUP2]ADD : Endif

  If GSERVEUR : PARNAM="RPTBATCH"+num$([F:FUP2]FUPMOD) Else PARNAM="RPTDST"+num$([F:FUP2]FUPMOD) : Endif
  If RPTDST([F:FUP2]FUPMOD)=""
   # Parameter not set
   Call ECR_TRACE(PARNAM-mess(136,199,1), 1) From GESECRAN
  Else
   If [F:AIM]COD<>RPTDST([F:FUP2]FUPMOD) : Read [AIM]AIM0=RPTDST([F:FUP2]FUPMOD) : Endif
   If [AIM]PRT=4
    # File
    FICDST = 1
   Endif

   If GSERVEUR
    If [AIM]PRT=1
     # The destination entered in parameter '$1' must not be of type 'Preview'.
     MSG = mess(253,117,1)
     Call DYNAMIC(MSG,"$1", PARNAM) From TEXTE
     Call ECR_TRACE(MSG, 1) From GESECRAN
    Endif

    # in batch mode the destination must use a print server
    If [AIM]PRTSRV=""
     # The destination entered in parameter '$1' must be associated with a print server.
     MSG = mess(254,117,1)
     Call DYNAMIC(MSG,"$1", PARNAM) From TEXTE
     Call ECR_TRACE(MSG, 1) From GESECRAN
    Endif
   Endif
  Endif

  Call PARAMUTIL("FUPRPTDIR",FUPRPTDIR,GUSER,"") From SUBAUS
  If FICDST and FUPRPTDIR=""
   # User parameter '$1' not set
   MSG = mess(559,199,1)
   Call DYNAMIC(MSG,"$1", "FUPRPTDIR") From TEXTE
   Call ECR_TRACE(MSG, 1) From GESECRAN
  Endif

# 2015-10-07 DNE INSERT BEGIN (SAM #104530)
   #
   # Note: If RPTCODFUP parameter is configured the report in GESARP must exist AND
   #       you cannot remove the report in GESARP unless you remove the report from
   #       RPTCODFUP parameter! So further checking is not necessary.
   #
   Call PARAML( [F:DUD]FCY, "RPTCODFUP", [L]RPTCODFUP ) From ADOVAL
   If [L]RPTCODFUP = ""
     [L]RPTCODFUP = "FUP"
   Endif
# 2015-10-07 DNE INSERT END

  # Using "_nolispar=1" prevents the Supervisor from listing Crystal parameters in the execution trace
  NBPAR+=1  : TBPAR(NBPAR) = "_nolispar" : TBVAL(NBPAR)="1"
  NBPAR+=1  : TBPAR(NBPAR) = "preview"   : TBVAL(NBPAR)="1"

# 2015-10-07 MODIF BEGIN (SAM #104530)
  Call ETAT( [L]RPTCODFUP, RPTDST([F:FUP2]FUPMOD), "", 0, "", TBPAR, TBVAL ) From AIMP3
# 2015-10-07 DNE MODIF ORIG
#  Call ETAT("FUP", RPTDST([F:FUP2]FUPMOD), "", 0, "", TBPAR, TBVAL) From AIMP3
# 2015-10-07 DNE MODIF END

  Filter [FUP] Where NUMEDT=[L]NUMREQ and FUPMOD=[F:FUP2]FUPMOD and BPRFUP=[F:FUP2]BPRFUP and ADD=[F:FUP2]ADD
  INC += rowcount([FUP])
  Call AFF_BOITE([F:FUP2]BPRFUP, INC, INTE) From GESECRAN
  Filter [FUP]
 Next # [F:FUP2]
Next # FUPMOD
Filter [FUP2]

# printing in preview mode (PREVIEW=2)
# the destination code must be retrieved to know the export format and the print server

For [FUP]FUP7(1) Where NUMEDT=[L]NUMREQ and PREVIEW=2
 Raz TBPAR, TBVAL, NBPAR
 NBPAR+=1  : TBPAR(NBPAR) = "numedt"    : TBVAL(NBPAR)=[L]NUMREQ

 If [F:TFP0]QURNUM<>[L]NUMREQ : Read [TFP0]TFP0 = [L]NUMREQ : Endif
 NBPAR+=1  : TBPAR(NBPAR) = "sequence"  : TBVAL(NBPAR)=num$(SEQUENCE) : SEQUENCE += 1

 If [M:CFP1]BPRFUP=1
  TBVAL(NBPAR) = [F:DUD]BPRPAY
 Else
  TBVAL(NBPAR) = [F:DUD]BPR
 Endif

 NBPAR+=1  : TBPAR(NBPAR) = "_nolispar" : TBVAL(NBPAR)="1"

 NBPAR+=1  : TBPAR(NBPAR) = "preview"    : TBVAL(NBPAR)="2"
# 2016-01-18 DNE INSERT BEGIN (SAM #104530)
 [L]RPTCODFUP = "FUP" : Raz [L]RPTCODFUPOLD
 For [F:FUP2]FUP8(1) Where NUMEDT=[L]NUMREQ and PREVIEW=2 and DST=[F:FUP]DST
   Call PARAML( [F:FUP2]FCY, "RPTCODFUP", [L]RPTCODFUP ) From ADOVAL
   If [L]RPTCODFUP = ""
     [L]RPTCODFUP = "FUP"
   Endif
   If [L]RPTCODFUPOLD = ""
      [L]RPTCODFUPOLD = [L]RPTCODFUP
   Elsif [L]RPTCODFUPOLD <> [L]RPTCODFUP
      [L]RPTCODFUP = "FUP"
      Break
   Endif
 Next
# 2016-01-18 DNE INSERT END
# 2015-10-07 DNE MODIF BEGIN (SAM #104530)
 Call ETAT( [L]RPTCODFUP, [F:FUP]DST, "", 0, "", TBPAR, TBVAL ) From AIMP3
# 2015-10-07 DNE MODIF ORIG
# Call ETAT("FUP", [F:FUP]DST, "", 0, "", TBPAR, TBVAL) From AIMP3
# 2015-10-07 DNE MODIF END
Next

Call FERME_BOITE From GESECRAN
End

##############################################################################################################
# The APRINTER table used by GESAIM function stores export format codes but not directly file extensions.
# This function automatically converts these numbers into file extensions.
#
# Returns the file extension associated with a Crystal destination format code
##############################################################################################################
Funprog GETEXT(CODE)
Value Integer CODE
Local Char EXT(4)

Case CODE
 When 1: EXT=".rpt"
 When 3: EXT=".doc"
 When 5: EXT=".rtf"
 When 9, 10: EXT=".txt"
 When 27, 28: EXT=".xls"
 When 29: EXT=".pdf"
 When Default : EXT=""
Endcase
End EXT

Funprog FICJOINT
Local Char RPTEXT(250), RPTDST2(GLONAIM)
Local Char CHEMINLOC(250)
Onerrgo

Call PARAML("","RPTDST2",RPTDST2) From ADOVAL
If [F:AIM]COD<>RPTDST2 : Read [AIM]AIM0=RPTDST2 : Endif
# extension to be used for files generated and sent by email by Crystal
RPTEXT = func GETEXT([F:AIM]PRTFMT)

Call PARAMUTIL("FUPRPTDIR",CHEMINLOC,GUSER,"") From SUBAUS
End CHEMINLOC+"FUP-"+[F:TFP2]BPC+RPTEXT

