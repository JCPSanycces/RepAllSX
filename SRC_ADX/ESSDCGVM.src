#<AdxTL>@(#)0.0.0.0 $Revision$ 

$ACTION

Case ACTION
   When "OUVRE"       : Gosub OUVRE
   When "DEBUT"       : Gosub DEBUT
   When "SETBOUT"     : Gosub SETBOUT
Endcase
Return


$SETBOUT
If REPONSE = 1102 or REPONSE = 1101
  #Disable sign buttons
  Call VIREBOUT(CHMEN,"a") From GOBJET
  Call VIREBOUT(CHMEN,"b") From GOBJET
Endif
Return



$OUVRE
Call MANAGE_LOCALISATION("ESSDCGVM") From DIVPAYE

$OUVRE_OUT
If clalev([F:DCG])    = 0 : Local File DEMCONGE     [DCG]     : Endif
Return

$DEBUT

#-------------------------------Hybrid----------------------------------#
Local Char VPARAM1(100)
Local Char VPARAM2(100)
Local Char ATT_ID1(GLONID1)
Local Char ATT_ID2(GLONID2)
Local Integer USERTRCK_STAT

VPARAM1 = PARAM(1)
VPARAM2 = PARAM(2)

If PARAM(5)="ESSWRKDCG"
  Gosub SET_DCGPARAM From ESSDCGV
  Gosub UPDATE_FROM_DEMCONGE From ESSDCGV
Else
  Gosub UPDATE_FROM_DEMCONGEESS From ESSDCGV
Endif
#-------------------------------Hybrid----------------------------------#

#Save paramaters for other actions
[M:ESDCGV]DEST      = PARAM(3)
[M:ESDCGV]CHRONO    = PARAM(4)

#Setting GCURLEG
[V]GCURLEG = [M:ESDCGV]LEG

#GLM Leave sub type display
If func AFNC.ACTIV("GLM")>0
  Gosub REFRESHLVESUBNNR From ESSDCGV
Endif

#Manage localisations
Call HIDE_ACTIVITYFIELDS From WESSDCGVMHIDE
Call SHOW_LEGACTCALLS From WESSDCGVMSHOW

#Update User tracking - used for attachment handling in classes
[L]ATT_ID1 = "DCG"+"~"+[M:ESDCGV]REFNUM+"~"+num$([M:ESDCGV]DEM)
[L]ATT_ID2 = num$([M:ESDCGV]UID)
[L]USERTRCK_STAT = func ESS_FUNCTIONS.UPDATE_ESSURSTRK(GUSER, "EML",[L]ATT_ID1, [L]ATT_ID2, "","ESSDCG",1,[M:ESDCGV]REFNUM,[M:ESDCGV]UID,[M:ESDCGV]CTRNUM)


#Update attachment icon
Gosub DISPLAY_ATT_ICON From ESSDCGV

Affzo [M:ESDCGV]1-99
Return

