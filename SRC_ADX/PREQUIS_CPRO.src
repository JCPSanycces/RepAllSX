Return

#####################################################
$INIT_PRQDAT
#  this.PRQDAT = date$
Return

#####################################################
$INIT_PSHFCY
  Local Char WSITE(GLONFCY)
  #récupération du site par defaut
  #GFCY = GFCYDEF(6) VPO va faire une methode pour récupérer le site par defaut (SAM 103295)
  [L]ASTATUS = fmet this.ACTX.AGETPRFFCYDEF(this,6,WSITE)
  #si le site par défaut est autorisé et qu'il s'agit d'un site d'achat=>initialisation
  If fmet this.ACTX.AGETAFCRIGHTFCY (this,"GESPSH",WSITE,CST_AFALSE)<=CST_AWARNING &
& fmet this.ACTX.ACACHE.AFCY.AGETVALNUM(WSITE,"PURFLG") = 2
    this.PSHFCY = WSITE
  Endif
Return

#####################################################
$PROPAGATE_PSHFCY
  Local Integer IND, IJ
  IND = fmet this.ACTX.ACACHE.AFCY.AGETINDEX(this.PSHFCY)
  If IND=[V]CST_ANOTDEFINED
    [L]ASTATUS=fmet this.ASETERROR("",mess(15,104,1),[V]CST_AERROR)
  Endif
  #---
  this.CPY = this.ACTX.ACACHE.AFCY.ACOL(IND).LEGCPY
  this.LEG = this.ACTX.ACACHE.AFCY.ACOL(IND).LEG
  # Autre possibilité
  #Local Instance FCY Using C_AFCY
  #FCY = this.ACTX.ACACHE.AFCY.ACOL(IND)
  #this.CPY = FCY.LEGCPY
  #this.LEG = FCY.LEG
  # Initialize line site and line receipt site if null
  If maxtab(this.PSD) <> 0
    For IJ=1 To maxtab(this.PSD)
       If this.PSD(IJ)<>null and find(this.PSD(IJ).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)<1
        this.PSD(IJ).PSHFCY = this.PSHFCY
        If this.PSD(IJ).PRHFCY = AVOID.ACHAR
           Call DEFRCPFCY(this.PSHFCY,this.PSD(IJ).PRHFCY) From TRTACHDEF1_SYRA
        Endif
       Endif
    Next IJ
  Endif
  #---
Return

