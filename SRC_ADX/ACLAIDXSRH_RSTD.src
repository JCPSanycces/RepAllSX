#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe ACLAIDX

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AQUERY_TRANS_AFTER" : Gosub AQUERY_TRANS_AFTER
      When "AQUERY_CRITERIA_AFTER" : Gosub AQUERY_CRITERIA_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

ACLAIDXSRH_RSTD


$AQUERY_CRITERIA_AFTER
If len(PQRY.QWHERE)
 PQRY.QWHERE += " and "
Endif
PQRY.QWHERE += "(FLGSEARCH eq true)"
Return

$AQUERY_TRANS_AFTER
[L]ASTATUS = [V]CST_AERROR
If this.CLA.TYPCLA <> 2 :
 this.CLA.FLGSEARCH = 1
Elsif !func ASYRFNC.ACTIVDOS(this.ACTX.AFOLDER,this.CLA.CODACT)
 this.CLA.FLGSEARCH = 1
Else
 If this.CLA.FLGSEARCH = 2
  this.CLA.FLGSEARCH = 1
  Local File ASHW    [ASW]
  For [ASW] Where CODCLA=this.CLA.CODCLA and DEFREP=2
   If  [ASW]ENAFAC(0) = 2
     this.CLA.FLGSEARCH = 2
     [L]ASTATUS = [V]CST_AOK
     Break
    Endif
  Next ASW
  #Close Local File [ASW]
 Endif
Endif
Return

