# add method AGETAFCRIGHT into class WMCONTEXT
$ADD_AGETAFCRIGHT_FCYCPY
For MET="","FCY","CPY"
 ACLAM_NBR = maxtab(ACLA.ACLAM)
 ACLAM_NBR += 1
 ACLA.ACLAM(ACLAM_NBR) = NewInstance C_ACLAMET AllocGroup ACLA
 ACLA.ACLAM(ACLAM_NBR).CODMET = "AGETAFCRIGHT"+MET
 ACLA.ACLAM(ACLAM_NBR).DONMET = 3

 # add param AINSTANCE
 ACLAMP_NBR = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR)  = NewInstance C_ACLAPARDEF AllocGroup ACLA
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODPAR    = "AINSTANCE"
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).NOPAR     = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).DIMPAR    = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).MODPAR    = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPINTPAR = 13
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CLAPAR    = "OBJECT"
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPKEY    = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODE      = ACLA.ACLAM(ACLAM_NBR).CODMET

 # add param AFONCTION
 ACLAMP_NBR = 2
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR)  = NewInstance C_ACLAPARDEF AllocGroup ACLA
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODPAR    = "AFONCTION"
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).NOPAR     = 2
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).DIMPAR    = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).MODPAR    = 2
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPINTPAR = 7
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPKEY    = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODE      = ACLA.ACLAM(ACLAM_NBR).CODMET
 If MET="FCY"
  # add param ACODFCY
  ACLAMP_NBR = 3
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR)  = NewInstance C_ACLAPARDEF AllocGroup ACLA
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODPAR    = "ACODFCY"
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).NOPAR     = 3
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).DIMPAR    = 1
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).MODPAR    = 2
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPINTPAR = 7
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPKEY    = 1
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODE      = ACLA.ACLAM(ACLAM_NBR).CODMET
  ACLAMP_NBR = 4
 Elsif MET="CPY"
  # add param ACODCPY
  ACLAMP_NBR = 3
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR)  = NewInstance C_ACLAPARDEF AllocGroup ACLA
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODPAR    = "ACODCPY"
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).NOPAR     = 3
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).DIMPAR    = 1
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).MODPAR    = 2
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPINTPAR = 7
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPKEY    = 1
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODE      = ACLA.ACLAM(ACLAM_NBR).CODMET
  ACLAMP_NBR = 4
 Else
  ACLAMP_NBR = 3
 Endif
 # add param AFLGERR
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR)  = NewInstance C_ACLAPARDEF AllocGroup ACLA
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODPAR    = "AFLGERR"
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).NOPAR     = 4
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).DIMPAR    = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).MODPAR    = 2
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPINTPAR = 2
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPKEY    = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODE      = ACLA.ACLAM(ACLAM_NBR).CODMET
Next
Return
