#--------------------------------------------------------------------------------------------------#
# add method AGETLICxxx into class WMCONTEXT
$ADD_ASYRLIC
Local Char WCODE(5),WINFO(30)
For WCODE="ACV","FCT","KIT","LAN","LEG","MOD","PAR","LIC"
 ACLAM_NBR = maxtab(ACLA.ACLAM)
 ACLAM_NBR += 1
 ACLA.ACLAM(ACLAM_NBR) = NewInstance C_ACLAMET AllocGroup ACLA
 ACLA.ACLAM(ACLAM_NBR).CODMET = "AGETLIC"+[L]WCODE
 ACLA.ACLAM(ACLAM_NBR).DONMET = 3

 # add param CODE
 ACLAMP_NBR = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR)  = NewInstance C_ACLAPARDEF AllocGroup ACLA
 If WCODE="LIC"
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODPAR    = "PRODUCTCODE"
 Else
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODPAR    = "COD"+[L]WCODE
 Endif
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).NOPAR     = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).DIMPAR    = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).MODPAR    = 2
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPINTPAR = 7
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPKEY    = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODE      = ACLA.ACLAM(ACLAM_NBR).CODMET

 If WCODE="PAR"
  # add param Value
  ACLAMP_NBR = 2
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR)  = NewInstance C_ACLAPARDEF AllocGroup ACLA
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODPAR    = "VAL"+[L]WCODE
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).NOPAR     = 1
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).DIMPAR    = 1
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).MODPAR    = 1
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPINTPAR = 7
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPKEY    = 1
  ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODE      = ACLA.ACLAM(ACLAM_NBR).CODMET
 Endif
Next
For WINFO="PARTNERID","PRODUCTVER","POLICYCODE","POLICYVER","EXPIRED","PRODUCTNAME","SERIAL"
 ACLAM_NBR = maxtab(ACLA.ACLAM)
 ACLAM_NBR += 1
 ACLA.ACLAM(ACLAM_NBR) = NewInstance C_ACLAMET AllocGroup ACLA
 ACLA.ACLAM(ACLAM_NBR).CODMET = "AGETLIC_"+[L]WINFO
 If WINFO="EXPIRED"
 ACLA.ACLAM(ACLAM_NBR).DONMET = 3
 Else
 ACLA.ACLAM(ACLAM_NBR).DONMET = 2
 Endif

 # add param CODE
 ACLAMP_NBR = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR)  = NewInstance C_ACLAPARDEF AllocGroup ACLA
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODPAR    = "PRODUCTCODE"
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).NOPAR     = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).DIMPAR    = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).MODPAR    = 2
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPINTPAR = 7
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).TYPKEY    = 1
 ACLA.ACLAM(ACLAM_NBR).ACLMP(ACLAMP_NBR).CODE      = ACLA.ACLAM(ACLAM_NBR).CODMET
Next
Return

