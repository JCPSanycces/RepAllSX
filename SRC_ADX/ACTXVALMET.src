$ADDACTXMET
Local Char MET(30)
Gosub ADD_ACTX_INIT_LAN
Gosub ADD_ACTX_INIT_LANISO
Gosub ADD_ACTX_SET_LANISO
Gosub ADD_ACLEAN
Gosub ADD_ACLEANRIGHT
