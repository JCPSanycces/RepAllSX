#<AdxTL>@(#)0.0.0.0 $Revision$ Modification caract. lot
# Gestion du masque SMX1
#---------------------------------------------------------------------------#
# Modification des caractéristiques d'un lot                                #
#---------------------------------------------------------------------------#
$ACTION
Case ACTION
    When "DEFTRANS"     : Gosub DEFTRANS     From SUBSMXA
    When "VARIANTE"     : Gosub VARIANTE     From SUBSMXA
    When "SETTRANS"     : Gosub SETTRANS     From SUBSMXA
    When "OUVRE"        : Gosub OUVRE        From SUBSMXA
    When "FILTRE"       : Gosub FILTRE       From SUBSMXA
    When "LIENS"        : Gosub LIENS        From SUBSMXA
    When "SETBOUT"      : Gosub SETBOUT      From SUBSMXA
    When "EXEBOUT"      : Gosub EXEBOUT      From SUBSMXA
    When "RAZCRE"       : Gosub RAZCRE       From SUBSMXA
    When "VERIF_CRE"    : Gosub VERIF_CRE    From SUBSMXA
    When "VERIF_MOD"    : Gosub VERIF_MOD    From SUBSMXA
    When "INICRE"       : Gosub INICRE       From SUBSMXA
    When "CREATION"     : Gosub CREATION     From SUBSMXA
    When "VALLIG"       : Gosub VALLIG       From SUBSMXA
    When "APRES_CRE"    : Gosub APRES_CRE    From SUBSMXA
    When "MODIF"        : Gosub MODIF        From SUBSMXA
    When "APRES_MOD"    : Gosub APRES_MOD    From SUBSMXA
    When "ANNULE"       : Gosub ANNULE       From SUBSMXA
    When "ABANDON"      : Gosub ABANDON      From SUBSMXA
    When "FIN"          : Gosub ABANDON      From SUBSMXA
    When "FERME"        : Gosub FERME        From SUBSMXA
    When "APRES_MODIF"  : Gosub APRES_MODIF  From SUBSMXA
Endcase
Return

$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return



##########################################################################
## Etiquette ajoutée par le superviseur 13/01/2004 15:21:28 (LLC)
##########################################################################
Subprog D_VCRNUM(VALEUR)
Variable Char    VALEUR()
[M:SMX0]VCRTYP = 35
End

##########################################################################
Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()
#-- Il faut une valeur saisie ou retournée par un compteur sinon erreur
If VALEUR = "" &  GSTKCPT(5) = "" : mkstat = 2 : End : Endif

#-- Si on est en création , n° saisi vide et un compteur est présent on sort
If GREP = "C" & VALEUR = "" &  GSTKCPT(5) <> "" : End : Endif

#-- Si dernier lu non chargé, on vérifie l'existence du n° saisi
If [M:SMX0]VCRNUM = "" & GREP <> "C"
    Look [F:SLH]SLH0=VALEUR
    If fstat
        GMESSAGE = mess(178,199,1) : mkstat = 2 : End
    Endif
Endif

If VALEUR <> "" & GSTKCPTMAN(5) <> 2
    Look [F:SLH]SLH0=VALEUR
    If fstat : Raz VALEUR : End : Endif
Endif
End

##########################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
    If fstat : Raz [ITM] : Endif
Endif
# article doit être géré avec lot
If !find([F:ITM]LOTMGTCOD,2,3,4) : mkstat = 2 : GMESSAGE = mess(480,199,1) : Endif
End

##########################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Integer LRET

Call LECITM([M:SMX0]STOFCY,VALEUR,"",3,"",LRET) From STKLIB
If LRET : mkstat = 2 : End : Endif

# si pas de titre
If dim([M:SMX1]POT) > 0              # hcb 31769
   If [F:ITF]STOMGTCOD < 3
      Grizo [M:SMX1]POT
   Else
      Actzo [M:SMX1]POT
   Endif
Endif                                # hcb 31769

# si pas de péremption
If !find([F:ITM]EXYMGTCOD,2,3,4,5,6)    # hcb 71352
    Grizo [M:SMX1]REFPER
    Grizo [M:SMX1]SHL
    Grizo [M:SMX1]SHLDAT
    Grizo [M:SMX1]SHLUOM     #v6per
    Grizo [M:SMX1]DLU        #v6per
    Grizo [M:SMX1]DLUDAT     #v6per
    Grizo [M:SMX1]SHLLTI     #v6per
    Grizo [M:SMX1]SHLLTIUOM  #v6per
    Grizo [M:SMX1]NEWLTIDAT  #v6per
Else
    Actzo [M:SMX1]REFPER
    Actzo [M:SMX1]SHL
    Actzo [M:SMX1]SHLDAT
    Actzo [M:SMX1]SHLUOM     #v6per
    Actzo [M:SMX1]DLU        #v6per
    Actzo [M:SMX1]DLUDAT     #v6per
    Actzo [M:SMX1]SHLLTI     #v6per
    Actzo [M:SMX1]SHLLTIUOM  #v6per
    Actzo [M:SMX1]NEWLTIDAT  #v6per

Endif
#                                                                                      # hcb dlu deb
If [F:ITM]EXYMGTCOD = 1 | [F:ITM]EXYMGTCOD= 3 | [F:ITM]EXYMGTCOD= 4
    Grizo [M:SMX1]DLU
    Grizo [M:SMX1]DLUDAT
Else
    Actzo [M:SMX1]DLU
    Actzo [M:SMX1]DLUDAT
Endif
#                                                                                      # hcb dlu fin
If [F:ITM]LOTCOU <> "" : [M:SMX0]GESLOTD = "C" : Endif

Raz [M:SMX0]LOT
If dim([M:SMX0]SLO) > 0 : Raz [M:SMX0]SLO : Endif
Effzo [M:SMX1]15-20
GFEALOTLEV = GWFEALOTLEV                          # hcb 71276
If dim([F:ITM]ECCSTO) > 0 & [F:ITM]ECCSTO >1      # hcb 71276
   GFEALOTLEV = 2                                 # hcb 71276
Endif                                             # hcb 71276

[M:SMX0]SLOMOD = 1
If dim([M:SMX0]SLO) > 0
    If [F:ITM]LOTMGTCOD <> 4 | GFEALOTLEV = 2                            # hcb unicite
        Grizo [M:SMX0]SLO
    Else
        Actzo [M:SMX0]SLO
        [M:SMX0]SLOMOD = 2
    Endif
Endif
If GFEALOTLEV = 2 | [F:ITM]LOTMGTCOD <> 4                                # hcb unicite
   Local Char WINVSLO                                                    # hcb unicite
   WINVSLO="-K:"+num$(GLONSLO)+"X"                                       # hcb unicite
   Chgfmt [M:SMX0]SLO  With WINVSLO                                      # hcb unicite
Else
   If [F:ITM]LOTMGTCOD =  4                                              # hcb unicite
      Local Char WINVSLO                                                 # hcb unicite
      WINVSLO="K:"+num$(GLONSLO)+"X"                                     # hcb unicite
      Chgfmt [M:SMX0]SLO  With WINVSLO                                   # hcb unicite
   Endif
Endif                                                                    # hcb unicite

Raz [M:SMX0]WFEALOTLEV                                                   # hcb unicite
If [F:ITM]LOTMGTCOD=4                                                    # hcb unicite
   [M:SMX0]WFEALOTLEV = mess(90,187,1) + " : " + mess(GFEALOTLEV,2773,1) # hcb unicite
Endif                                                                    # hcb unicite
If dim([M:SMX0]SLO) > 0 : Affzo [M:SMX0]SLO : Endif

#                                                           # Hcb 71276 deb
If dim([M:SMX1]ECCVALMAJ)>0
   Case [F:ITM]ECCSTO
      When 0,1
          Grizo [M:SMX1]ECCVALMAJ
          Grizo [M:SMX1]ECCVALMIN
      When  2
          Grizo [M:SMX1]ECCVALMIN
          Actzo [M:SMX1]ECCVALMAJ
      When  3
          Actzo [M:SMX1]ECCVALMIN
          Actzo [M:SMX1]ECCVALMAJ
      When Default
   Endcase
Endif
#                                                           # Hcb 71276 fin
Affzo [M:SMX1]15-20
End

##########################################################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
Local    Integer WIND : WIND = 0
If VALEUR = [M:SMX0]LOT : End : Endif
If [F:ITM]LOTMGTCOD <> 4 | GFEALOTLEV = 2  | (dim([F:ITM]ECCSTO) > 0 & [F:ITM]ECCSTO >1)     # hcb 71276

    Look [STL]STL0(2)=[M:SMX0]ITMREF;VALEUR
    If fstat : mkstat = 2 : GMESSAGE = mess(123,199,1) : End : Endif

    # déverrouillage lot
    If [M:SMX0]LOT <> "" : Gosub DEVERROU From SUBSMXA : Endif

    # vérification stock
    For [F:STO]STO3 Where ITMREF = [M:SMX0]ITMREF &
&                         STOFCY = [M:SMX0]STOFCY &
&                         LOT    = VALEUR
        If [F:STO]CUMALLQTY <> 0  : WIND = 1 : Break : Endif
        If [F:STO]QLYCTLDEM <> "" : WIND = 2 : Break : Endif
        If [F:STO]CUMWIPQTY <> 0  : WIND = 3 : Break : Endif
        #                                                 # hcb 110327 deb
        If [F:ITM]SERMGTCOD = 4
           Call VERIF_DESYNCHRO_SERIE([F:STO]ITMREF,[F:STO]STOCOU,[F:STO]QTYSTU,WIND) From STKLIB
           If WIND = 2
              WIND = 5
              Break
           Endif
        Endif
 #                                                 # hcb 110327 fin
    Next
    If WIND=0
        # Ce lot a t-il du stock sur d'autres sites ?
        For [F:STO]STO3 Where ITMREF = [M:SMX0]ITMREF &
&                             STOFCY <>[M:SMX0]STOFCY &
&                             LOT    = VALEUR
            WIND = 4 : Break
        Next
    Endif

    #--- Dem 77583
    #--- Pour modifier la valeur de WIND
    GPOINT="CTL_LOT" : Gosub ENTREE From EXEFNC

    If WIND
        mkstat = 2
        GMESSAGE =mess(399,198,1)-":"-[F:STO]STA
        GMESSAGE-=mess(43,197,1)-":"-[F:STO]LOT
        If [F:ITF]LOCMGTCOD=2
           GMESSAGE-=mess(44,197,1)-":"-[F:STO]LOC
        Endif
        Case WIND
            When 1:    GMESSAGE+="\"+mess(482,199,1)
            When 2:    GMESSAGE+="\"+mess(460,199,1)
            When 3:    GMESSAGE+="\"+mess(488,199,1)
            When 4:    GMESSAGE+="\"+mess(206,184,1)-[F:STO]STOFCY
        Endcase
        End
    Endif

    # verrouillage lot
    [M:SMX0]LOT = VALEUR
    Gosub VERROU From SUBSMXA
    If mkstat : End : Endif
Else
    If dim([M:SMX0]SLO) > 0
        If [M:SMX0]SLO <> "" : Gosub DEVERROU From SUBSMXA : Endif
    Endif
Endif
End

##########################################################################
Subprog AM_LOT(VALEUR)
Variable Char    VALEUR()
If [F:ITM]LOTMGTCOD = 4 & GFEALOTLEV = 1 : End : Endif                   # hcb unicite
[M:SMX0]LOT = VALEUR
If [F:ITM]LOTMGTCOD = 4 & GFEALOTLEV = 2                                 # hcb unicite deb
    Filter [F:STL] Where ITMREF = [M:SMX0]ITMREF & LOT = [M:SMX0]LOT
&                    Order By Key STL0
    Read [STL] First
    If fstat
       Raz [F:STL]
    Endif
    Filter [F:STL]
Else                                                                     # hcb unicite fin
   Read [STL]STL0(2)=[M:SMX0]ITMREF;[M:SMX0]LOT
Endif                                                                    # hcb unicite
Gosub FILL_PAGE From SUBSMXA
End

##########################################################################
Subprog C_SLO(VALEUR)
Variable Char    VALEUR()
Local    Integer WIND : WIND = 0

# déverrouillage
If [F:ITM]LOTMGTCOD = 4 & [M:SMX0]SLO <> "" : Gosub DEVERROU From SUBSMXA : Endif

Look [STL]STL0=[M:SMX0]ITMREF;[M:SMX0]LOT;VALEUR
If fstat : mkstat = 2 : GMESSAGE = mess(123,199,1) : End : Endif

# vérification stock
For [F:STO]STO3 Where ITMREF = [M:SMX0]ITMREF &
&                     STOFCY = [M:SMX0]STOFCY &
&                     LOT    = [M:SMX0]LOT    &
&                     SLO    = VALEUR
    If [F:STO]CUMALLQTY <> 0  : WIND = 1 : Break : Endif
    If [F:STO]QLYCTLDEM <> "" : WIND = 2 : Break : Endif
    If [F:STO]CUMWIPQTY <> 0  : WIND = 3 : Break : Endif
Next
If WIND=0
    # Ce lot a t-il du stock sur d'autres sites ?
    For [F:STO]STO3 Where ITMREF = [M:SMX0]ITMREF &
&                         STOFCY <>[M:SMX0]STOFCY &
&                         LOT    = [M:SMX0]LOT    &
&                         SLO    = VALEUR
         WIND = 4 : Break
    Next
Endif
If WIND
    mkstat = 2
    GMESSAGE =mess(399,198,1)-":"-[F:STO]STA
    GMESSAGE-=mess(43,197,1)-":"-[F:STO]LOT
    GMESSAGE-=mess(456,197,1)-":"-[F:STO]SLO
    If [F:ITF]LOCMGTCOD=2
        GMESSAGE-=mess(44,197,1)-":"-[F:STO]LOC
    Endif
    Case WIND
        When 1:    GMESSAGE+="\"+mess(482,199,1)
        When 2:    GMESSAGE+="\"+mess(460,199,1)
        When 3:    GMESSAGE+="\"+mess(488,199,1)
        When 4:    GMESSAGE+="\"+mess(206,184,1)-[F:STO]STOFCY
    Endcase
    End
Else
    # verrouillage lot
    [M:SMX0]SLO = VALEUR
    Gosub VERROU From SUBSMXA
    If mkstat : End : Endif

    Read [STL]STL0=[M:SMX0]ITMREF;[M:SMX0]LOT;[M:SMX0]SLO
    Gosub FILL_PAGE From SUBSMXA
Endif
End

##########################################################################
Subprog AM_SLO(VALEUR)
Variable Char    VALEUR()
End


Subprog C_POT(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : mkstat = 2 : Endif
End


Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
Raz [M:SMX0]ITMREF
Raz [M:SMX0]LOT
If dim([M:SMX0]SLO) > 0 : Raz [M:SMX0]SLO : Endif
Effzo [M:SMX1]15-20
Affzo [M:SMX0]ITMREF
Affzo [M:SMX0]LOT
If dim([M:SMX0]SLO) > 0 : Affzo [M:SMX0]SLO : Endif
Actzo [M:SMX0]10
GFCY=VALEUR
Gosub CHARG_PARAM From SUBSMXA       # ana

End


Subprog C_SHLDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > [31/12/2999]
  mkstat = 2
Endif

End


Subprog C_REFPER(VALEUR)
Variable Date    VALEUR
If VALEUR > [31/12/2999]
  mkstat = 2
Endif

End

Subprog AM_REFPER(VALEUR)
Variable Date    VALEUR
Local    Integer  WCOD : WCOD = [F:ITM]EXYMGTCOD
Local    Date     WREF : WREF = VALEUR
Local    Integer  WSHL : WSHL = [M:SMX1]SHL
Local    Integer  WUOM : WUOM = [M:SMX1]SHLUOM
Local    Decimal  WDLU : WDLU = [M:SMX1]DLU
Local    Date     WPER
Local    Date     WEXY
Local    Integer  WLTI


Call CALPER(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SMX1]SHLDAT = WPER
Affzo [M:SMX1]SHLDAT
WEXY = WPER
Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
[M:SMX1]DLUDAT = WPER
Affzo [M:SMX1]DLUDAT
[M:SMX1]DLULTI = WLTI
Affzo [M:SMX1]DLULTI

WSHL = [M:SMX1]SHLLTI
WUOM = [M:SMX1]SHLLTIUOM
Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SMX1]NEWLTIDAT = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
If [M:SMX1]NEWLTIDAT <> [31/12/2999]
   If [M:SMX1]NEWLTIDAT  > [M:SMX1]DLUDAT
      [M:SMX1]NEWLTIDAT  = [M:SMX1]DLUDAT
   Endif
Endif
Affzo [M:SMX1]NEWLTIDAT


End

Subprog AM_SHL(VALEUR)
Variable Decimal VALEUR
Local    Integer  WCOD : WCOD = [F:ITM]EXYMGTCOD
Local    Date     WREF : WREF = [M:SMX1]REFPER
Local    Integer  WSHL : WSHL = VALEUR
Local    Integer  WUOM : WUOM = [M:SMX1]SHLUOM
Local    Decimal  WDLU : WDLU = [M:SMX1]DLU
Local    Date     WPER
Local    Date     WEXY
Local    Integer  WLTI
Call CALPER(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SMX1]SHLDAT = WPER
Affzo [M:SMX1]SHLDAT

WEXY = WPER
Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
[M:SMX1]DLUDAT = WPER
Affzo [M:SMX1]DLUDAT
[M:SMX1]DLULTI = WLTI
Affzo [M:SMX1]DLULTI


WSHL = [M:SMX1]SHLLTI
WUOM = [M:SMX1]SHLLTIUOM
Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SMX1]NEWLTIDAT = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
If [M:SMX1]NEWLTIDAT  > [M:SMX1]DLUDAT
   [M:SMX1]NEWLTIDAT  = [M:SMX1]DLUDAT
Endif

Affzo [M:SMX1]NEWLTIDAT


End

Subprog AM_SHLUOM(VALEUR)
Variable Integer VALEUR
Local    Integer  WCOD : WCOD = [F:ITM]EXYMGTCOD
Local    Date     WREF : WREF = [M:SMX1]REFPER
Local    Integer  WSHL : WSHL = [M:SMX1]SHL
Local    Decimal  WDLU : WDLU = [M:SMX1]DLU
Local    Integer  WUOM : WUOM = VALEUR
Local    Date     WPER
