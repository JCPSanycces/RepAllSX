Local    Integer  WLTI

Call CALPER(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SMX1]SHLDAT = WPER
Affzo [M:SMX1]SHLDAT

WEXY = WPER
Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
[M:SMX1]DLUDAT = WPER
Affzo [M:SMX1]DLUDAT
[M:SMX1]DLULTI = WLTI
Affzo [M:SMX1]DLULTI

WSHL = [M:SMX1]SHLLTI
WUOM = [M:SMX1]SHLLTIUOM
Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SMX1]NEWLTIDAT = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
If [M:SMX1]NEWLTIDAT  > [M:SMX1]DLUDAT
   [M:SMX1]NEWLTIDAT  = [M:SMX1]DLUDAT
Endif

Affzo [M:SMX1]NEWLTIDAT


End

Subprog AM_DLU(VALEUR)
Variable Decimal VALEUR
Local    Integer  WCOD : WCOD = [F:ITM]EXYMGTCOD
Local    Date     WREF : WREF = [M:SMX1]REFPER
Local    Integer  WSHL : WSHL = [M:SMX1]SHL
Local    Integer  WUOM : WUOM = [M:SMX1]SHLUOM
Local    Decimal  WDLU : WDLU = VALEUR
Local    Date     WPER
Local    Date     WEXY : WEXY = [M:SMX1]SHLDAT
Local    Integer  WLTI

Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB
[M:SMX1]DLUDAT = WPER
Affzo [M:SMX1]DLUDAT
[M:SMX1]DLULTI = WLTI
Affzo [M:SMX1]DLULTI

#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
If [M:SMX1]NEWLTIDAT  > [M:SMX1]DLUDAT
   [M:SMX1]NEWLTIDAT  = [M:SMX1]DLUDAT
   Affzo [M:SMX1]NEWLTIDAT
Endif

End

Subprog AM_DLUDAT(VALEUR)
Variable Date    VALEUR
If [M:SMX1]NEWLTIDAT  > VALEUR
   [M:SMX1]NEWLTIDAT  = VALEUR
   Affzo [M:SMX1]NEWLTIDAT
Endif
[M:SMX1]DLULTI     =  nday(VALEUR) -nday([M:SMX1]REFPER)
Affzo [M:SMX1]DLULTI
End

Subprog AM_SHLLTI(VALEUR)
Variable Decimal VALEUR
Local    Integer  WCOD : WCOD = [F:ITM]EXYMGTCOD
Local    Date     WREF : WREF = [M:SMX1]REFPER
Local    Integer  WSHL : WSHL = VALEUR
Local    Date     WPER
Local    Integer  WUOM : WUOM = [M:SMX1]SHLLTIUOM

Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SMX1]NEWLTIDAT = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
If [M:SMX1]NEWLTIDAT  > [M:SMX1]DLUDAT
   [M:SMX1]NEWLTIDAT  = [M:SMX1]DLUDAT
Endif

Affzo [M:SMX1]NEWLTIDAT

End

Subprog AM_SHLLTIUOM(VALEUR)
Variable Integer VALEUR
Local    Integer  WCOD : WCOD = [F:ITM]EXYMGTCOD
Local    Date     WREF : WREF = [M:SMX1]REFPER
Local    Integer  WSHL : WSHL = [M:SMX1]SHLLTI
Local    Date     WPER
Local    Integer  WUOM : WUOM = VALEUR


Call CALLTI(WCOD,WREF,WSHL,WUOM,"",WPER) From STKLIB
[M:SMX1]NEWLTIDAT = WPER
#       si date recontrole > date limite utilisation : date recontrole = date limite utilisation
If [M:SMX1]NEWLTIDAT  > [M:SMX1]DLUDAT
   [M:SMX1]NEWLTIDAT  = [M:SMX1]DLUDAT
Endif

Affzo [M:SMX1]NEWLTIDAT
End

Subprog C_NEWLTIDAT(VALEUR)
Variable Date    VALEUR
If [M:SMX1]SHLLTI <> 0 & VALEUR > [M:SMX1]DLUDAT                # hcb 119447
   GMESSAGE=mess(309,184,1)  # Date re-contrôle  > date limite utilisation !
   mkstat = 2
Endif
End

Subprog C_DLU(VALEUR)
Variable Decimal VALEUR
If VALEUR > 1 | VALEUR < 0 | VALEUR = 0
   GMESSAGE = mess(83,123,1) #"valeur incorrecte"
   mkstat = 2
Endif
End

Subprog C_DLUDAT(VALEUR)
Variable Date    VALEUR
If VALEUR > [M:SMX1]SHLDAT
   GMESSAGE=mess(313,184,1)
   mkstat = 2
Endif



End

Subprog AM_SHLDAT(VALEUR)
Variable Date    VALEUR
Local    Integer  WCOD : WCOD = [F:ITM]EXYMGTCOD
Local    Decimal  WDLU : WDLU = [M:SMX1]DLU
Local    Date     WREF : WREF = [M:SMX1]REFPER
Local    Date     WPER
Local    Date     WEXY : WEXY = VALEUR
Local    Integer  WLTI


Call CALDLU(WCOD,WREF,WEXY,WDLU,"",WPER,WLTI) From STKLIB

[M:SMX1]DLUDAT = WPER
Affzo [M:SMX1]DLUDAT
[M:SMX1]DLULTI = WLTI
Affzo [M:SMX1]DLULTI

End


