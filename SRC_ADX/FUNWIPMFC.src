Subprog D_STOFCY(VALEUR)
Variable Char    VALEUR()
Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218
VALEUR = GFCY
Call GETCPY(VALEUR,"",0,"") From TRTX3CPT   # Issue 75315 - 2011-07-25 by CCC : Alimentation de GNBDIE
End

##########################################################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
# charger les éventuels paramètres de niveau site
Call GLOBVAR(VALEUR)    From WWGLOBGPA
Call GETCPY(VALEUR,"",0,"") From TRTX3CPT   # Issue 75315 - 2011-07-25 by CCC : Alimentation de GNBDIE
End

##########################################################################
Subprog C_VCRNUM(VALEUR)
Variable Char    VALEUR()

Local Char LWAICTL(2)

If VALEUR <> ""
    If !func CTRMFG([M]VCRTYP,VALEUR)  : # se positionne sur MFG
        mkstat = 2
    Elsif [M]PRF1=1 & [F:MFG]MFGTRKFLG<6
        GMESSAGE = mess(225,193,1) #"Le prix de revient n'a pas encore été calculé pour cet ordre"
        mkstat=2
    Elsif [M]PRF2=1 & [F:MFG]MFGTRKFLG=6
        GMESSAGE = mess(85,193,1) : #"Le prix de revient a déjà été calculé pour cet ordre"
        mkstat=2
    Elsif [F:MFG]MFGSTA < 4 & [M]SIMFLG<>2 : # contrôler que l'OF est clos
        [M]SIMFLG = 2 : [M]MFGTYP=1
        [M]PRF1=2
        [M]PRF2=1
        Diszo PRF1,PRF2
        Affzo SIMFLG,PRF1,PRF2
        GERR = 2 : GMESSAGE = mess(115,193,1) : #"Cet ordre de fabrication n'est pas clos"
    Endif
    If mkstat : End : Endif

    # Issue 99496 - 2014-11-03 by CCC : pending transaction control
    Raz LWAICTL
    Call PARAM([F:MFG]MFGFCY, "WOMMVTWAI", LWAICTL) From ADOVAL
    If LWAICTL="3"
        If func FUNMFGS.CTRL_WAITRS_WO([F:MFG]MFGFCY,VALEUR)>0
            mkstat=2
            GMESSAGE = mess(289,193,1)
            End
        Endif
    Endif

Endif

If VALEUR<>""
    [M]MFGTYP = ([F:MFG]MFGSTA=4)+1
    [M]FILMFG = ""
    [M]FILFLG = 1
Else
    [M]MFGTYP = ([M]SIMFLG<>2)+1
Endif
Call UPDMSG(VALEUR)

If GERR=2 : zonsui="SIMFLG" : Endif
If VALEUR="" & [M]FILMFG = "" : mkstat = 2 : Endif
End

######################################################################################
# Affiche un message à coté du n° d'ordre
# /s-pro utilisé dans FUNWIPMFC et FUNWIPSCO
######################################################################################
Subprog UPDMSG(VCRNUM)
Value Char VCRNUM
Local Char LTXT(80)

Raz [M]MSG
If [M]FILFLG=2
    If [M]MSG<>"" : [M]MSG+=" / " : Endif
    If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif
    Read [AMZ]CODE = maskcou;"FILFLG"
    If fstat : Raz [F:AMZ] : Endif

    Call TEXTE([F:AMZ]INTIT,LTXT) From OBJDIV  # Filtre activé
    ## Call TEXTE(8695,LTXT) From OBJDIV       ## GH 10/01/13 dm 77455
    [M]MSG += LTXT
Endif
If [M]MFGTYP=2
    If [M]MSG<>"" : [M]MSG+=" / " : Endif
    If !clalev([F:AMZ]) : Local File AMSKZON [AMZ] : Endif
    Read [AMZ]CODE = maskcou;"MFGTYP"
    If fstat : Raz [F:AMZ] : Endif
    Call TEXTE([F:AMZ]INTIT,LTXT) From OBJDIV  # Ordre clos
    ## Call TEXTE(27360,LTXT) From OBJDIV      ## GH 10/01/13 dm 77455
    [M]MSG += LTXT
Endif
Affzo MSG
End

######################################################################################
Subprog C_PRNCOD(VALEUR)
Variable Integer VALEUR
    If VALEUR>1
        Actzo PRVCSTPRT,EDIPRV
        Actzo FLXBUD
        If [M]FLXBUD<>2
            Actzo ORIDEVCLC
        Else
            Grizo ORIDEVCLC
        Endif
    Else
        [M]PRVCSTPRT = 1
        [M]EDIPRV = 1
        Diszo PRVCSTPRT,EDIPRV
        Grizo FLXBUD
        Grizo ORIDEVCLC
    Endif
    Affzo PRVCSTPRT,EDIPRV
End

