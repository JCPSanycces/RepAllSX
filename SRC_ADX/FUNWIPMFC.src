Subprog C_FLXBUD(VALEUR)
Variable Integer VALEUR
# Issue 85341 - 2013-08-20 by CCC
#    If VALEUR=2
#        Grizo ORIDEVCLC
#    Else
#        Actzo ORIDEVCLC
#    Endif
End

######################################################################################
Subprog C_PRF2(VALEUR)
Variable Integer VALEUR
If VALEUR<>2 & [M]PRF1<>2
    GMESSAGE = mess(266,199,1)
    mkstat=2
Endif
End

######################################################################
Subprog DELADJMWI(PVCRTYP, PVCRNUM, PDATPER, PERR)
Value    Integer PVCRTYP
Value    Char    PVCRNUM
Value    Date    PDATPER
Variable Integer PERR

Local Integer LFIND, LAST_SEQ, LRET
# Issue 95486 - 2014-01-06 by CCC : TXNTYP=17 records have to be canceled and not deleted because of CSTELM(9) & (10)
Local Decimal LCUMCST(dim([F:MWI]CSTELM)), LCUMAMT, LCUMLEV0

If dim(GDIMCST)<=0 : Global Integer GDIMCST : Endif
GDIMCST = GACTMAT+GACTMAC+GACTLAB+2+4     # = dim mat + dim mac + dim lab + sco + invdta + fg mat + fg mac + fg lab + fg sco
Local Decimal LCSTDET(GDIMCST+1)

Raz PERR

Columns [MWI] (GLPSTA)
Raz LFIND
# Issue 95486 - 2014-01-06 by CCC : TXNTYP=17 records have to be canceled and not deleted because of CSTELM(9) & (10)
For [MWI] Where VCRTYP = PVCRTYP
&             & VCRNUM = PVCRNUM
&             & ( TXNTYP=17
&               | find(TXNTYP,9,10,11,12,13,16,15,20) & (GLPSTA=2 | TXNDAT<PDATPER) )
    LFIND = 1
    Break
Next
Columns [MWI]

# Suppression des wipcost de solde non comptabilisés
Delete [MWI] Where VCRTYP = PVCRTYP
&                & VCRNUM = PVCRNUM
&                & find(TXNTYP,9,10,11,12,13,16,15,20)
&                & GLPSTA<>2
&                & TXNDAT>=PDATPER

If LFIND
    # Annulation des wipcost déjà comptabilisés
    Call GET_LAST_SEQ(PVCRTYP, PVCRNUM,LAST_SEQ) From MWIPLIB
    Filter [MWI2] Where VCRTYP = PVCRTYP
&                     & VCRNUM = PVCRNUM
&                     & ( TXNTYP=17
&                       | find(TXNTYP,9,10,11,12,13,16,15,20) & (GLPSTA=2 | TXNDAT<PDATPER) )
&                     & WIPSEQ<=LAST_SEQ
&                 Order By Key XMWI=VCRTYP;VCRNUM;TXNTYP;OPENUM;OPESPLNUM;OVENAT;WIPSEQ Desc
    # Issue 75407 - 2011-07-27 by CCC : (2) --> (3)
    # Issue 89378 - 2013-07-04 by CCC : il faut distinguer les txntyp=17 avec ou sans FG (3) --> (4)
    # Issue 92823 - 2015-03-18 by CCC : take into account OPENUM & OPESPLNUM
    For [MWI2]XMWI(6)
        [F:MWI]=[F:MWI2]
        Raz [F:MWI]QTY,[F:MWI]QTYACT,[F:MWI]AMOUNT,[F:MWI]CSTELM, LCUMAMT, LCUMCST, LCSTDET, LCUMLEV0
        For [MWI2]XMWI
            [F:MWI]QTY-=[F:MWI2]QTY
            [F:MWI]QTYACT-=[F:MWI2]QTYACT
            LCUMAMT-=[F:MWI2]AMOUNT
            For I=0 To dim([F:MWI]CSTELM)-1
                # On ne fait pas d'extourne des montants déjà absorbés et non absorbés
                # Cela ne concerne que le type 17, les autres n'ayant pas cette info
                If [F:MWI]TXNTYP=17 & find(I,9,10)
                    Raz [F:MWI]CSTELM(I)
                Else
                    LCUMCST(I)-=[F:MWI2]CSTELM(I)
                Endif
            Next
            # Issue 92823 - 2015-03-18 by CCC
            ## Issue 91525 - 2013-07-31 by CCC : signe des valeurs [MWI]xxxCST de l'annulation
            #Call LOADVAR(LCSTDET,"[F:MWI]", 0, "", -1, 0, 0) From STKVALECR
            #Call LOADFIC("[F:MWI]",LCSTDET, "", "CST", 1, 0) From STKVALECR
            Call LOADVAR(LCSTDET,"[F:MWI2]", 0, "", -1, 1, 0) From STKVALECR

            # Issue 110939 - 2015-10-12 by CCC : cancel material level cost
            LCUMLEV0 -=[F:MWI2]MATLEV0
        Next
        [F:MWI]AMOUNT = LCUMAMT
        For I=0 To dim([F:MWI]CSTELM)-1
            # On ne fait pas d'extourne des montants déjà absorbés et non absorbés
            # Cela ne concerne que le type 17, les autres n'ayant pas cette info
            If [F:MWI]TXNTYP=17 & find(I,9,10)
                Raz [F:MWI]CSTELM(I)
            Else
                [F:MWI]CSTELM(I)=LCUMCST(I)
            Endif
        Next
        # Issue 92823 - 2015-03-18 by CCC
        Call LOADFIC("[F:MWI]",LCSTDET, "", "CST", 1, 0) From STKVALECR

        # Issue 110939 - 2015-10-12 by CCC : cancel material level cost
        [F:MWI]MATLEV0 = LCUMLEV0

        If [F:MWI]QTY<>0 | [F:MWI]AMOUNT<>0
            If [F:MWI]TXNDAT<PDATPER
                [F:MWI]TXNDAT=date$
            Endif
            LAST_SEQ+=1
            [F:MWI]GLPSTA=1
            Raz [F:MWI]GLPDAT
            [F:MWI]WIPSEQ = LAST_SEQ
            [F:MWI]TXNACT=3
            Call ECR_MWI From MWIPLIB
            If fstat
                Call FSTA("MWI") From GLOCK
                LRET = 1
                Break    # FQ 69909 Ctrl des sources avant End
            Endif
            LAST_SEQ = [F:MWI]WIPSEQ :  # GH 02/2016 bug 108954 incrementation for WIPCOST
        Endif
    Next
    Filter [MWI2]
    [G:MWI2]currlen=0
    If LRET End Endif    # FQ 69909 Ctrl des sources Ligne ajoutée
Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran MWF0) 10/05/2010 16:37:44 (CCC)
######################################################################################

Subprog D_SIMFLG(VALEUR)
Variable Integer VALEUR
[M]MFGTYP=1+(VALEUR<>2)
Call UPDMSG([M]VCRNUM)
End

Subprog AM_SIMFLG(VALEUR)
Variable Integer VALEUR
If VALEUR=2
    [M]PRF1=2
    [M]PRF2=1
    Diszo PRF1,PRF2
Else
    Actzo PRF1,PRF2
Endif

[M]MFGTYP=1+(VALEUR<>2)

Call UPDMSG([M]VCRNUM)
End

#############################################################
Subprog CALMFC(PFCY,PVCRTYP,PVCRNUM)
Value Char    PFCY
Value Integer PVCRTYP
Value Char    PVCRNUM

Local Integer LTRA
If GTRACE=""
    LTRA=1
    Call OUVRE_TRACE(mess(80,195,1)) From LECFIC
Endif

#If !clalev([M:MWF0]) : Local Mask MWF0 : Endif
#Raz [M:MWF0]    # Issue 74041 - 2011-05-25 by CCC
#Gosub INIT     From FUNWIPMFC
#
#Default Mask [MWF0]
#[M:MWF0]STOFCY = PFCY
#[M:MWF0]VCRTYP = PVCRTYP
#[M:MWF0]VCRNUM = PVCRNUM
#[M:MWF0]PRNCOD = 1    # Pas d'impression
#[M:MWF0]FLXBUD = 1    # --> utile uniquement pour l'impression => valeur 1 car on n'a pas d'impression
#[M:MWF0]ORIDEVCLC = 1 # Origine écart utile uniquement pour l'impression

Case PVCRTYP
    When 10 :
        If !clalev([M:MWF0]) : Local Mask MWF0 [MWF0] : Endif
        Raz [M:MWF0], GERR, GMESSAGE  # Il faut s'assurer que l'écran est bien vide
        Gosub INIT     From FUNWIPMFC

        Default Mask [MWF0]

    When 36 :
        If !clalev([M:SWF0]) : Local Mask SWF0 [SWF0] : Endif
        Raz [M:SWF0], GERR, GMESSAGE  # Il faut s'assurer que l'écran est bien vide
        Gosub INIT     From FUNWIPMFC

        Default Mask [SWF0]
Endcase
[M]STOFCY = PFCY
[M]VCRTYP = PVCRTYP
[M]VCRNUM = PVCRNUM
[M]PRNCOD = 1    # Pas d'impression
[M]FLXBUD = 1    # --> utile uniquement pour l'impression => valeur 1 car on n'a pas d'impression
[M]ORIDEVCLC = 1 # Origine écart utile uniquement pour l'impression

Call GETCPY(PFCY,"",0,"") From TRTX3CPT   # Issue 75315 - 2011-07-25 by CCC : Alimentation de GNBDIE

Raz GERR
Gosub CONTROLE From FUNWIPMFC
If !GOK | GERR
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Else
    Gosub EXEC     From FUNWIPMFC
    If GOK & !GERR
        Gosub TERMINE  From FUNWIPMFC
    Endif
Endif

If LTRA
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Endif

End

######################################################################################
## GH 10/01/2013 Dm 77455
######################################################################################

Subprog S_VCRNUM(VALEUR)
Variable Char    VALEUR()

[M]FILSELMFG=""
# [M]FILSELMFG-="[MFG]SUSFLG<>2" : # ordre non suspendu
If [M]SIMFLG<>2
   [M]FILSELMFG-= "& [MFG]MFGSTA=4" : # ordre clos
Endif
If [M]PRF1=2
  [M]FILSELMFG-= "& "
  If [M]PRF2=2 : [M]FILSELMFG+= "(" : Endif
  [M]FILSELMFG+= "find([MFG]MFGTRKFLG,4,5)<>0" : # En cours ou soldé
Endif
If [M]PRF2=2
   If [M]PRF1=2 : [M]FILSELMFG-= "| (" : Else  [M]FILSELMFG-= "& " : Endif
   [M]FILSELMFG+= "[MFG]MFGTRKFLG=6 & [MWH]MFGTRKFLG=5" : # Prix de revient calculé
   If [M]PRF1=2 : [M]FILSELMFG+= "))" : Endif
Endif
If left$([M]FILSELMFG,3)=" & " : [M]FILSELMFG = right$([M]FILSELMFG,4) : Endif
End

######################################################################################

Subprog IB_VCRNUM
If [M]PRF2<>2
    Raz GBOUT3
Elsif [M]PRF1<>2
    GBOUT3=mess(293,193,1) : # Sélection OF avec prix revient calculé
Else
    GBOUT3=mess(294,193,1) : # Sélection OF clos
Endif
End

######################################################################################

Subprog B2_VCRNUM(VALEUR)
Variable Char    VALEUR()

[M]FILFLG = ([M]FILMFG<>"")+1
If [M]FILMFG<>"" : VALEUR="" : Endif

Call UPDMSG(VALEUR)
End

######################################################################################

Subprog B3_VCRNUM(VALEUR)
Variable Char    VALEUR()

# ici , on a forcément [M]SIMFLG=1 & [M]PRF2=2
[M]FILSELMFG = "[MFG]MFGSTA=4" : # ordre clos
#[M]FILSELMFG-=" & [MFG]SUSFLG<>2" : # ordre non suspendu
If [M]PRF1<>2
   [M]FILSELMFG-= "& [MFG]MFGTRKFLG=6" : # Prix de revient calculé
Else
   [M]FILSELMFG-= "& find([MFG]MFGTRKFLG,4,5)<>0"  : # En cours ou soldé
Endif
End

