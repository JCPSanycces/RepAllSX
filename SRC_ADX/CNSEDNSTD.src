#<AdxTL>@(#)0.0.0.0 $Revision$ Consultation EDN
$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
 When Default
Endcase
Return


$OUVRE
#  If PARAM(1) = "" and PARAM(2) = ""
#    PARAM(1) = "CDE-2015-5015"
#    PARAM(2) = "4"
#  Endif

  If PARAM(1) <> ""
    [M:EDN1]SDHNUM    = PARAM(1)
  Endif

  Local Char DEBNUM(100), FINNUM(100)
  Local Char DEBLIN(10), FINLIN(10)
  Local Char WFIL(250) : WFIL = "1=1"
Return

$LECTURE
  #-- critères obligatoires (section facultative)
  Local Char WSDHNUM(100) : WSDHNUM = [M:EDN1]SDHNUM
  If WSDHNUM = ""
    NBLU = 0
    Return
  Endif

  Gosub CHANGE_MSK From GCONSULT
  If CHGPAG<0 : NOL = MAXLIG : Endif

  #-- Positionnement des Filtres
  Gosub LOAD_FILTER

  #-- Application des Filtres et tri des enregistrements
  If CHGPAG > 0
    SUITE=1
    If CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Link [SDND] With [SDN]SDN0 = [SDND]SDNNUM As [LIEN] Where [SDND]SDHNUM = WSDHNUM
&   Order By [SDN]SDNNUM Desc; [SDND]SDNLIN Desc
  Else
    RETOUR=1
    If CHGPAG = -1 : SUITE = 1 : Else SUITE = 2 : Endif
    Link [SDND] With [SDN]SDN0 = [SDND]SDNNUM As [LIEN] Where [SDND]SDHNUM = WSDHNUM
&   Order By [SDN]SDNNUM Asc; [SDND]SDNLIN Asc
  Endif

  #-- raz du masque si 1ere ou dernière page
  If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:EDN2] : Endif

  Gosub BOUCLE

Return

$BOUCLE
  If WSDHNUM <> ""
    For [LIEN]
      If evalue(WFIL) #filtre sur LIEN car utilisation d'une cle [LIEN]SDNNUM+num$([LIEN]SDNLIN)
                      #qui ne peut être placée dans WHERE de FILTER
        If NBLU = 1
          If CHGPAG=2 | CHGPAG=-2 : Raz [M:EDN2] : Endif
          NBLU = 2
        Endif

        #-- stockage des bornes début et fin d'enregistrement pour l'écran
        If CHGPAG > 0
          If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
          NOL += 1
          If NOL=0
            DEBNUM = [F:SDN]SDNNUM
            DEBLIN = num$([F:SDND]SDNLIN)
          Endif
          FINNUM = [F:SDN]SDNNUM
          FINLIN = num$([F:SDND]SDNLIN)
        Else
          If NOL <= 0 : RETOUR=2 : Break : Endif
          NOL -= 1
          If NOL=MAXLIG-1
            FINNUM = [F:SDN]SDNNUM
            FINLIN = num$([F:SDND]SDNLIN)
          Endif
          DEBNUM = [F:SDN]SDNNUM
          DEBLIN = num$([F:SDND]SDNLIN)
        Endif

        nolign = NOL+1
        [M:EDN2]SDNNUM(nolign-1)    = [SDN]SDNNUM
        [M:EDN2]SDNNUMREF(nolign-1) = [SDN]SDNNUMREF
        [M:EDN2]NOTDAT(nolign-1)    = [SDN]NOTDAT
        [M:EDN2]SDDLIN(nolign-1)    = [SDND]SDDLIN
        [M:EDN2]SOHNUM(nolign-1)    = [SDN]SOHNUM
#        [M:EDN2]SOPLIN(nolign-1)    = [SDN]SOPLIN
        [M:EDN2]ITMREF(nolign-1)    = [SDND]ITMREF
        [M:EDN2]RCPQTY(nolign-1)    = [SDND]RCPQTY
        [M:EDN2]RCPSAU(nolign-1)    = [SDND]RCPSAU
        [M:EDN2]RCPDAT(nolign-1)    = [SDND]RCPDAT

      Endif
    Next
    Filter [SDND] ##??
  Endif
Return


#--- Préparation du filtre #
$LOAD_FILTER
  WFIL = "1=1"
  Case CHGPAG
    When 3 : # rafraichissement
      WFIL += "&[LIEN]SDNNUM+num$([LIEN]SDNLIN)<=DEBNUM+DEBLIN"
    When 2 : # suite
      WFIL += "&[LIEN]SDNNUM+num$([LIEN]SDNLIN)<FINNUM+FINLIN"
    When -2 : # retour
      WFIL += "&[LIEN]SDNNUM+num$([LIEN]SDNLIN)>DEBNUM+DEBLIN"
  Endcase
Return


#---------------------------------------------------------------------------#
#        Enable or not the link in the window                               #
#---------------------------------------------------------------------------#
Funprog GET_SDELIVERYNO_FLAG(WSDHNUM)
Value Char    WSDHNUM

  Local Integer WFOUND_FLG : WFOUND_FLG = [V]CST_AFALSE

  Local File SDELIVERYNO [SDN]
  Filter [SDN] Where [SDN]SDHNUM = WSDHNUM
  For [SDN]
    WFOUND_FLG    = [V]CST_ATRUE
    Break
  Next
  Filter [SDN]
  Close File [SDN]

End WFOUND_FLG

# EDI_X3_50816_Process_to_save_all_EDI_Setup_in_MongoDB
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat End Endif

Call VALGTC(APPLI,"EDN") From SUBGTC

End

