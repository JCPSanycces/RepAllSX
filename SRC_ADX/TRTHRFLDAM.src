#<AdxTL>@(#)%I% KMA
## DEHEN VM Code - 2016-04-07
#
Subprog HRFLDAM(VALEUR,XNUM)
Variable Char    VALEUR()
Value    Char    XNUM
If !clalev([F:ABRV1]) Local File HRSTADCLSET [F:ABRV1]  : Endif
Local Integer I
Local Char XCODTYP (8)
Local Char XDAT (30)
Local Date XDATNEW
Read[F:ABRV1]HRSDS0=[M]MDLDCL
If !fstat Then
    For I=0 To dim([F:ABRV1]POS)-1
        If [F:ABRV1]POS(I)=val(XNUM) Then
           XCODTYP=[F:ABRV1]CODTYP(I) : Break
        Endif
    Next
    If XCODTYP="D" and VALEUR<>"" Then
        If format$("DD2",VALEUR)="  /  /  " Then
           Errbox "Format incorrecte" : mkstat=2
        Else
           XDAT=format$("DD2",VALEUR)
           XDAY  = val(mid$(XDAT,1,2))
           XMOIS = val(mid$(XDAT,4,2))
           XANNEE= val(mid$(XDAT,7,2))
           XDATNEW=gdat$(XDAY,XMOIS, XANNEE)
           VALEUR=num$(XDATNEW)

        Endif
    Endif
Endif
End
#

