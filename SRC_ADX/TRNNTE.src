#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#########################################################################
# BRBAN 25/11/2014 - 97101 - Printing requirements for POR legislation
#########################################################################
#########################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

# Table declaration
Gosub OUVRE
# Variable declaration
Gosub DECLARE

[L]CRITERE(0) = "1=1"
[L]CRITERE(1) = "1=1"

For I=1 To [L]NBPAR
  J=instr(1,[L]PARAMETRE(I),"=")
  If J
    [L]PARAM  = left$([L]PARAMETRE(I),J-1)
    Call GETPARAM ([L]PARAM,[L]NBPAR,[L]PARAMETRE,VALEUR) From ETAT
    Case [L]PARAM
      When "X3ETA"          : [L]ETAT     = [L]VALEUR
      When "__REQUETE"      : [L]NUMREQ   = val([L]VALEUR)
      When "sitedeb"        : [L]CRITERE(0) -= "& FCY>='"+[L]VALEUR+"'"
      When "sitefin"        : [L]CRITERE(0) -= "& FCY<='"+[L]VALEUR+"'"
      When "bprdeb"         : [L]CRITERE(0) -= "& BPRNUM>='"+[L]VALEUR+"'"
      When "bprfin"         : [L]CRITERE(0) -= "& BPRNUM<='"+[L]VALEUR+"'"
      When "tnhnumdeb"      : [L]CRITERE(0) -= "& TNHNUM>='"+[L]VALEUR+"'"
      When "tnhnumfin"      : [L]CRITERE(0) -= "& TNHNUM<='"+[L]VALEUR+"'"
      When "datedeb"        : [L]DATREF   = gdat$(val(right$([L]VALEUR,7)),
&                                        val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                              [L]CRITERE(0) -= "& TRNDAT >=["+format$(GFMD,[L]DATREF)+']'
      When "datefin"        : [L]DATREF   = gdat$(val(right$([L]VALEUR,7)),
&                                        val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                              [L]CRITERE(0) -= "& TRNDAT <=["+format$(GFMD,[L]DATREF)+']'
      When "numedt"         : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
      When "seqedt"         : [L]PARAMETRE(I) = "seqedt=0"
      When "usr"            : [L]PARAMETRE(I) = "usr="+GUSER
      When "etat"           : [L]PARAMETRE(I) = "etat="+[L]ETAT
    Endcase
  Endif
Next

Call DEBTRANS From GLOCK
Trbegin [ARM], [TCRPT]

Raz [F:ARM] #Do not move this to ALIM_ARM

For [F:TNH]TNH0 Where evalue([L]CRITERE(0))
  Gosub ALIM_ARM
  If GOK < 1 : Break : Endif
Next

If GOK<1  Rollback  Else  Commit : Endif

End
#########################################################################
#########################################################################
$OUVRE

Local File AREPORTM   [ARM]
Local File TMPCRPT    [TCRPT]
Local File TRANNOTEH  [TNH]

Return
#########################################################################
#########################################################################
$DECLARE

Local Integer I, J , NBRCOPIE, LNBCOP    # Issue 18041 - 2017-02-03 by VAVIL : Original\Duplicate\Triplicate transport docs
Local Char    PARAM(30), VALEUR(30)
Local Char    CRITERE(255)(0..1), ETAT(15)
Local Integer NUMREQ , KPOACT, GLBDOCFLG # Issue 18041 - 2017-02-03 by VAVIL : Original\Duplicate\Triplicate transport docs
Local Date    DATREF

Return
#########################################################################
#########################################################################
$ALIM_ARM

[F:ARM]CLEA1   = [F:TNH]TNHNUM
[F:ARM]CREDAT  = date$
[F:ARM]NUMREQ  = [L]NUMREQ
[F:ARM]RPTCOD  = [F:ARP]RPTCOD
[F:ARM]USR     = GUSER
[F:ARM]NUMCOP  = 0

# Issue 18041 - 2017-02-03 by VAVIL : Original\Duplicate\Triplicate transport docs
# Issue 18041
[L]KPOACT = func AFNC.ACTIV("KPO")
[L]GLBDOCFLG = 1
If [L]KPOACT
  [L]GLBDOCFLG = [F:TNH]GLBDOC
Endif

# Issue 24522 - 2017-03-14 by MRDAB : GESTPM modification to include transport notes and move AP/AR to a new block
If [L]GLBDOCFLG = 2
  [L]LNBCOP = 3
Else
  [L]LNBCOP = max(1,[F:TNH]COPNBR)
Endif

For [L]NBRCOPIE = 1 To [L]LNBCOP
    [F:ARM]NUMLIG += 1
    [F:ARM]NUMCOP = [L]NBRCOPIE
    Write [F:ARM]
    If fstat : GOK=0 : Call FSTA("ARM") From GLOCK : Endif
Next
# End issue 24522

If [L]KPOACT :  Gosub ALIM_TMPCRPT :  Endif
# End issue 18041

Return
#########################################################################
#########################################################################
$ALIM_TMPCRPT

Raz [F:TCRPT]

[F:TCRPT] = [F:ARM]
[F:TCRPT]VCRNUM = [F:TNH]TNHNUM

Write [F:TCRPT]
If fstat : GOK=0 : Call FSTA("TCRPT") From GLOCK : Endif

Return
#########################################################################
#########################################################################

