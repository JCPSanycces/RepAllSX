If VALEUR = ""
  VALEUR = [M:TLO2]STRLOCCRE
Endif
End
############################################################
Subprog C_ENDLOCCRE(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
Local Char    WMAJ(1)       : WMAJ = "C"
Local Char    WDEB(GLONLOC) : WDEB = [M:TLO2]STRLOCCRE
Local Char    WFIN(GLONLOC) : WFIN = VALEUR
Local Char    WFOR(GLONLOC) : WFOR = [M:TLO2]LOCNUMFMT
Gosub CTR_ENDLOC
End

############################################################
$CTR_STRLOC
Local Integer WI
#
VALEUR = toupper(VALEUR)
If len([M]LOCNUMFMT) <> len(VALEUR)
  mkstat = 2
  GMESSAGE = mess(6,199,1)
Else
  For WI = 0 To len(VALEUR)-1
    If !(pat(mid$(VALEUR,WI+1,1),"#") | pat(mid$(VALEUR,WI+1,1),"!"))
      Break
    Endif
  Next WI
  If WI <> len(VALEUR)
    mkstat = 2
    GMESSAGE = mess(6,199,1)
  Endif
Endif
Return
############################################################
$CTR_ENDLOC
Local Char    WWRK(GLONLOC)
Local Char    WCAR(7)  : WCAR = "ABCDEFG"
Local Char    WLET(27) : WLET = "ABCDEFGHIJKLMNOPQRSTUVWXYZA"
Local Char    WCHI(11) : WCHI = "01234567890"
Local Char    WALL(36) : WALL = "0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ"
Local Integer IFIN     : IFIN = 0
Local Char    W1(1)
Local Char    W2(1)
Local Integer WPOS
Local Decimal WBASE(1..len(WDEB))
Local Decimal WCRE     : WCRE = 0
Local Integer I,J,K,L,M,N,O,P,Q

Local Integer WLON
WLON = find(0,[M:TLO1]LOCFMTLON)-1
   WLON= GLONLOC    # hcb 76005
Local Decimal WVALDEB(WLON)
Local Decimal WVALFIN(WLON)

# contrôle debut et fin de même longueur
If len(WDEB) <> len(WFIN)
  GMESSAGE = mess(6,196,1)
  mkstat = 2
Else
# Contrôle caractères  début et fin de même nature
  For I = 1 To len(WDEB)
    If (pat(mid$(WDEB,I,1),"#") & pat(mid$(WFIN,I,1),"!"))
      mkstat = 2
      Break
    Endif
    If (pat(mid$(WDEB,I,1),"!") & pat(mid$(WFIN,I,1),"#"))
      mkstat = 2
      Break
    Endif
  Next I
  If mkstat = 2
    GMESSAGE = mess(6,196,1)
   Return
  Endif

# Controle composantes fin >= composantes début
  For I = 0 To find(0,[M:TLO1]LOCFMTLON)-2
    WPOS = [M:TLO1]LOCFMTPOS(I)
    WLON = [M:TLO1]LOCFMTLON(I)
    If mid$(WFIN,WPOS,WLON)< mid$(WDEB,WPOS,WLON)
      mkstat = 2
      WCRE   = 0
      Break
    Endif
    For J=WPOS To WPOS+WLON-1
        WBASE(J)=1
        For K=J+1 To WPOS+WLON-1
            WBASE(J) *= (instr(1,WLET,mid$(WDEB,K,1))>0)*26 + (instr(1,WCHI,mid$(WDEB,K,1))>0)*10
        Next
    Next
    WVALDEB(I)=sigma(WPOS,WPOS+WLON-1,instr(1,WLET,mid$(WDEB,indcum,1))*WBASE(indcum)
&                                    +instr(1,WCHI,mid$(WDEB,indcum,1))*WBASE(indcum))
    WVALFIN(I)=sigma(WPOS,WPOS+WLON-1,instr(1,WLET,mid$(WFIN,indcum,1))*WBASE(indcum)
&                                    +instr(1,WCHI,mid$(WFIN,indcum,1))*WBASE(indcum))
  Next I
#
  If mkstat = 2
    GMESSAGE = mess(6,196,1)
    WCRE = 0
  Else
    WCRE=1
    For I=0 To find(0,[M:TLO1]LOCFMTLON)-2
        WCRE *= WVALFIN(I)-WVALDEB(I)+1
    Next
# Traitement pouvant être long si erreur de saisi
#    WWRK = WDEB
#    Call TEMPON(WMAJ) From GESECRAN
#    Repeat
#      WCRE += 1
#      Gosub ADD_EMP
#    Until IFIN <> 0
#    Call TEMPOFF From GESECRAN
  Endif
  [M]UPDLOCEXT = WCRE
  Affzo [M]UPDLOCEXT
  If GMESSAGE<>""
    mkstat = 2
    GERR = 1
  Endif
Endif
Return


