###########################################################
Subprog AV_PCU(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
  Read [TUN]TUN0=VALEUR
    If fstat = 0
        Call GET_ATEXTRA("TABUNIT","DESSHO",GLANGUE,[M:TLO1]UOMSHO(nolign-1)) From TRTX3TEX
    Endif
Endif
End
############################################################
Subprog C_PCU(VALEUR)
Variable Char     VALEUR
Local Char WUN(GLONUOM)
WUN = vireblc(VALEUR,1)
Call CONTROLE("TUN","",WUN,"",mkstat) From CONTOBJ
If mkstat = 0 Goto C_PCU0
Endif
WUN = toupper(WUN)
Call CONTROLE("TUN","",WUN,"",mkstat) From CONTOBJ
If mkstat = 0 Goto C_PCU0
Endif
WUN = tolower(WUN)
Call CONTROLE("TUN","",WUN,"",mkstat) From CONTOBJ
If mkstat = 0 Goto C_PCU0
Endif
WUN = toupper(mid$(WUN,1,1))+mid$(WUN,2,2)
Call CONTROLE("TUN","",WUN,"",mkstat) From CONTOBJ
If mkstat = 0 Goto C_PCU0
Endif
End
$C_PCU0
VALEUR = WUN
Call UNICITE(WUN,[M:TLO1]PCU(0..[M:TLO1]PCUNBR-1)) From OBJDIV
Call GET_ATEXTRA("TABUNIT","DESSHO",GLANGUE,[M:TLO1]UOMSHO(nolign-1)) From TRTX3TEX
End
############################################################
Subprog C_MAXQTYPCU(VALEUR)
Variable Decimal VALEUR
If [M:TLO1]FILMGTFLG = 2
  If VALEUR <= 0 | mod(VALEUR,1) <> 0
    mkstat = 2
  Endif
Else
  If VALEUR <  0 | mod(VALEUR,1) <> 0
    mkstat = 2
  Endif
Endif
End
