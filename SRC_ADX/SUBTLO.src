#<AdxTL>@(#)2.0.0.0 $Revision$
Local Char GWSINVREA(20)
#GWSINVREA="string$(2,'A')"
GWSINVREA='sigma(1,3,"a")+gr'
Infbox GWSINVREA
GWSINVREA= evalue(GWSINVREA)
Infbox GWSINVREA
End

$ACTION
If left$(GACTION,6) = "GOBJET"
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "FERME"        : Gosub FERME
    When "LIENS"        : Gosub LIENS
    When "FILTRE"       : Gosub FILTRE
    When "FILGAUCHE"    : Gosub FILGAUCHE
    When "VERF_ANU"     : Gosub VERF_ANU
    When "ANNULE"       : Gosub ANNULE
    When "SETBOUT"      : Gosub SETBOUT
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "AVANT_MODFIC" : Gosub AVANT_MODFIC
    When "APRES_MOD"    : Gosub APRES_MOD
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "APRES_CRE"    : Gosub LIENS
    When "CREATION"     : Gosub CREATION
    When "AV_IMPRIME"   : Gosub COP_ECRAN
                          OK = 0
    When "RAZCRE"       : Gosub RAZCRE
    When "RAZDUP"       : Gosub RAZDUP
    When "FIN_ACTION"   : Gosub FIN_ACTION
    When "MODIF"        : Gosub MODIF
    When Default :
  Endcase
  Return
Endif
Case GACTION
  When "SAICREEMP" :
    Case ACTION
      When "OUVRE"        : Gosub OUVRE_CREEMP
      When "DEBUT"        : Gosub DEBUT_CREEMP
      When "SETBOUT"      : Gosub SETBOUT_CREEMP
      When "ABA"          : Gosub ABA_CREEMP
      When "ENR"          : Gosub ENR_CREEMP
    Endcase
  When "SAISUPEMP" :
    Case ACTION
      When "OUVRE"        : Gosub OUVRE_SUPEMP
      When "DEBUT"        : Gosub DEBUT_SUPEMP
      When "SETBOUT"      : Gosub SETBOUT_SUPEMP
      When "ABA"          : Gosub ABA_SUPEMP
      When "ENR"          : Gosub ENR_SUPEMP
    Endcase
  When "SAIAFFEMP" :
    Case ACTION
      When "OUVRE"        : Gosub OUVRE_AFFEMP
      When "OUVRE_BOITE"  : Gosub OUVRE_BOITE_AFFEMP
      When "DEBUT"        : Gosub DEBUT_AFFEMP
      When "SETBOUT"      : Gosub SETBOUT_AFFEMP
      When "BOUTON"       : Gosub BOUTON_AFFEMP
      When "ENR"          : Gosub ENR_AFFEMP
    Endcase
Endcase
Return
###########################################################
$OUVRE
Local Integer W_I
#
If clalev([F:STC1]) = 0 : Local File STOLOC     [STC1] : Endif
If clalev([F:STO0]) = 0 : Local File STOCK      [STO0] : Endif
If clalev([F:TLO0]) = 0 : Local File TABLOCTYP  [TLO0] : Endif
If dim(GSYNSTC)<=0 : Global Integer GSYNSTC : Endif
Return
###########################################################
$FERME
Call IMPSCR        From ATRTX3
Kill GSYNSTC
Return
############################################################
$RAZCRE
Actzo [M:TLO1]
Affzo [M:TLO1]1-99
If [M:TLO1]FILMGTFLG=2
    Actzo [M:TLO1]20
Else
    Grizo [M:TLO1]20
Endif
Return
###########################################################
$RAZDUP
[M:TLO0]STOEXI = 0
[M:TLO0]LOCEXI = 0
Actzo [M:TLO1]
Affzo [M:TLO1]1-99

Raz [M:TLO5]
Return
############################################################

$COP_ECRAN
Local Char WMSK(10)(3)
Local Char WABR(06)(3)
WMSK(0) = "TLO0"
WMSK(1) = "TLO1"
WMSK(2) = "TLO5"
Call PRTSCR(WMSK,WABR,"",0,0) From ATRTX3
Return
###########################################################
$SETBOUT
Call VIREBOUT(CHAINE,"H") From GOBJET
If GREP <> "" | [M:TLO0]LOCTYP = ""
  Call VIREBOUT(CHAINE,"abcd") From GOBJET
Else
  If !([M:TLO1]DEDFLG = 2 | [M:TLO1]REAFLG = 2)
    Call VIREBOUT(CHAINE,"c") From GOBJET
  Endif
  If [M:TLO0]LOCEXI <> 2
    Call VIREBOUT(CHAINE,"d") From GOBJET
  Endif
Endif
Return
###########################################################
$LIENS
#
[M:TLO0]STOEXI = 0
[M:TLO0]LOCEXI = 0
Gosub CAL_FORMAT
#
Filter [STO] Where STOFCY = [M:TLO0]STOFCY &
&                  LOCTYP = [M:TLO0]LOCTYP
&            Order By Key STO4
For [STO]
  [M:TLO0]STOEXI = 2
  Break
Next
Filter [STO]
#
[M:TLO5]PERLOA *= 100
#
Filter [STC1] Where STOFCY = [M:TLO0]STOFCY &
&                   LOCTYP = [M:TLO0]LOCTYP
&             Order By Key STC3
Read [STC1] First
If fstat = 0
  [M:TLO0]LOCEXI = 2
  [M:TLO5]FIRLOC = [F:STC1]LOC
Endif
Read [STC1] Last
If fstat = 0
  [M:TLO5]LASLOC = [F:STC1]LOC
Endif
Filter [STC1]
#
If [M:TLO1]FILMGTFLG=2
    Actzo [M:TLO1]20
Else
    Grizo [M:TLO1]20
Endif
If [M:TLO0]STOEXI <> 0
  Grizo [M:TLO1]LOCCAT
  Grizo [M:TLO1]FILMGTFLG
  #CCC 03/10/03 S'il existe du stock sans gestion de maxi, on ne peut plus passer à une gestion avec maxi
  If [M:TLO1]PCUNBR=0
    Grizo [M:TLO1]20
  Endif
Else
  Actzo [M:TLO1]LOCCAT
  Actzo [M:TLO1]FILMGTFLG
Endif

#If [M:TLO0]LOCEXI <> 0
#  Grizo [M:TLO1]LOCNUMFMT
#Else
Actzo [M:TLO1]LOCNUMFMT
#Endif
If [M:TLO1]LOCCAT = 2
  [M:TLO1]MONITMFLG = 1
  [M:TLO1]DEDFLG    = 1
  [M:TLO1]REAFLG    = 1
  [M:TLO1]FILMGTFLG = 1
  Actzo [M:TLO1]LOCNUMFMT
  Actzo [M:TLO1]PPSSEQ
  Grizo [M:TLO1]MONITMFLG
  Grizo [M:TLO1]DEDFLG
  Grizo [M:TLO1]REAFLG
  Grizo [M:TLO1]FILMGTFLG
Elsif find([M:TLO1]LOCCAT,3,4)
  [M:TLO1]LOCNUMFMT = "AAAAAAAAAA"
  [M:TLO1]PPSSEQ    = "AAAAAAAAAA"
  Grizo [M:TLO1]LOCNUMFMT
  Grizo [M:TLO1]PPSSEQ
  Actzo [M:TLO1]MONITMFLG
  Actzo [M:TLO1]DEDFLG
  Actzo [M:TLO1]REAFLG
  Actzo [M:TLO1]FILMGTFLG
Else
  Actzo [M:TLO1]LOCNUMFMT
  Actzo [M:TLO1]PPSSEQ
  Actzo [M:TLO1]MONITMFLG
  Actzo [M:TLO1]DEDFLG
  Actzo [M:TLO1]REAFLG
  Actzo [M:TLO1]FILMGTFLG
Endif

If [M:TLO0]LOCEXI <> 0
  Grizo [M:TLO1]LOCNUMFMT
Endif
Return
###########################################################
$FILGAUCHE
# 18/07/03: enlevé sur demande de Patricia du 20/06/03
#If dim([M]STOFCY) < 0 | [M]STOFCY = ""
#  FILTSUP = "STOFCY=GFCYDEF(0)"
#Else
#  FILTSUP = "STOFCY=[M]STOFCY"
#Endif
Return
###########################################################
$FILTRE
# 18/07/03: enlevé sur demande de Patricia du 20/06/03
#If dim([M]STOFCY) < 0 | [M]STOFCY = ""
#  FILTSUP = "STOFCY=GFCYDEF(0)"
#Else
#  FILTSUP = "STOFCY=[M]STOFCY"
#Endif
Return
###########################################################
$VERIF_CRE
#-- On veut pouvoir gérer des emplacements
#If [M:TLO1]FILMGTFLG = 2 & [M:TLO1]PCUNBR = 0
#  Call ERREUR(mess(403,199,1)) From GESECRAN
#  OK = 0
#Endif
Return
###########################################################
$VERIF_MOD
#
#If [M:TLO1]FILMGTFLG = 2 & [M:TLO1]PCUNBR = 0
#  Call ERREUR(mess(403,199,1)) From GESECRAN
#  OK = 0
#Else
  If [M:TLO1]FILMGTFLG <> [F:TLO]FILMGTFLG
&  | [M:TLO1]PCUNBR    <> [F:TLO]PCUNBR
    Filter [STC1] Where STOFCY = [M:TLO0]STOFCY &
&                       LOCTYP = [M:TLO0]LOCTYP
&                 Order By Key STC3
    For [STC1]
      Look [STO0]STO4=[M:TLO0]STOFCY;[F:STC1]LOC
      If fstat = 0
        W_I = 1
        Call AVERTIR(mess(70,187,1),W_I) From GESECRAN
        If W_I = 1
          OK = 0
        Endif
        Break
      Endif
    Next
    Filter [STC1]
  Endif
  If OK <> 0
    If ([M:TLO1]DEDFLG <> [F:TLO]DEDFLG & [M:TLO1]DEDFLG = 1 & [M:TLO1]REAFLG = 1) |
&      ([M:TLO1]REAFLG <> [F:TLO]REAFLG & [M:TLO1]DEDFLG = 1 & [M:TLO1]REAFLG = 1)
      W_I = 1
      Call AVERTIR(mess(370,199,1),W_I) From GESECRAN
      If W_I = 1
        OK = 0
      Endif
    Endif
  Endif
#Endif
Return
###########################################################
#Modification éventuelle des clés de proposition des emplacements
#Mise à jour informations redondantes
$AVANT_MODFIC
If GREP="M"
& &([F:TLO]PPSSEQ    <> [M:TLO1]PPSSEQ    |
&   [F:TLO]AUZSST    <> [M:TLO1]AUZSST    |
&   [F:TLO]TEMLTI    <> [M:TLO1]TEMLTI    |
&   [F:TLO]MONITMFLG <> [M:TLO1]MONITMFLG |
&   [F:TLO]DEDFLG    <> [M:TLO1]DEDFLG    |
&   [F:TLO]REAFLG    <> [M:TLO1]REAFLG    |
&   [F:TLO]FILMGTFLG <> [M:TLO1]FILMGTFLG |
&   [F:TLO]MAXAUZWEI <> [M:TLO1]MAXAUZWEI |
&   [F:TLO]WID       <> [M:TLO1]WID       |
&   [F:TLO]HEI       <> [M:TLO1]HEI       |
&   [F:TLO]DTH       <> [M:TLO1]DTH)
  Call TEMPON("V") From GESECRAN
# MAJ emplacements libres et occupés
  Filter [STC] Where STOFCY=[M:TLO0]STOFCY & LOCTYP=[M:TLO0]LOCTYP
&              Order By Key STC3
  Look [STC] First
  If !fstat
    GSYNSTC  = ([F:TLO]FILMGTFLG <> [M:TLO1]FILMGTFLG)
    GSYNSTC += ([F:TLO]MONITMFLG <> [M:TLO1]MONITMFLG & [M:TLO1]MONITMFLG=2)*2
    GSYNSTC += ([F:TLO]DEDFLG    <> [M:TLO1]DEDFLG & [M:TLO1]DEDFLG=2)*4
    GSYNSTC += ([F:TLO]AUZSST    <> [M:TLO1]AUZSST)*8
  Endif
  For [STC]
    Readlock [STC] Curr
    Case fstat
      When 0 :
        Call MAJ_SEQ([F:STC]LOC,[M:TLO1]PPSSEQ,[M:TLO1]LOCNUMFMT,[F:STC]PPSSEQ)
        Gosub MAJ_MOD
        Rewrite [STC]
        # If fstat : #MAE : bug 111012 + 114524, on enléve l'erreur si clé déjà existante
        If fstat<>0 & fstat <> 3
          GOK = 0
          #--- Bug 75710
          #Call FSTA("LOC") From GLOCK
          Call FSTA("STC") From GLOCK
          #---
          Break
        Endif
      When 1 :
        GOK = -1
        Break
      When Default :
        GOK = 0
        #--- Bug 75710
        #Call FSTA("LOC") From GLOCK
        Call FSTA("STC") From GLOCK
        #---
        Break
    Endcase
  Next
  Filter [STC]
  If [M:TLO1]DEDFLG = 1 & [M:TLO1]REAFLG = 1
    Gosub PUR_STF
  Endif
Endif
Call TEMPOFF From GESECRAN
Return
###########################################################
$PUR_STF
Filter [STC1] Where STOFCY = [M:TLO0]STOFCY &
&                   LOCTYP = [M:TLO0]LOCTYP &
&                   DEDFLG = 1              &
&                   REAFLG = 1
&             Order By Key STC3
For [STC1]
  Filter [STF] Where STOFCY = [F:STC1]STOFCY &
&                    LOC    = [F:STC1]LOC
&              Order By Key STF0
  For [STF]
    Readlock [STF] Curr
    Case fstat
      When 0 :
        Delete [STF]
        If fstat
          GOK = 0
          Call FSTA("STF") From GLOCK
          Break 2
        Endif
      When 1 :
        GOK = -1
        Break 2
      When Default :
        GOK = 0
        Call FSTA("STF") From GLOCK
        Break 2
    Endcase
  Next
  Filter [STF]
Next
Filter [STC1]
Return
#############################################
$APRES_MOD
Local Integer LAPMOD_RET
    Call OUVRE_TRACE(mess(133,196,1)-[M:TLO0]STOFCY) From LECFIC
    Call ECR_TRACE(mess(133,196,1)-[M:TLO0]STOFCY,0) From GESECRAN
    Call TRAITEMENT("STOFCY='"+[M:TLO0]STOFCY+"'&LOCTYP='"+[M:TLO0]LOCTYP+"'",
&                 (mod(GSYNSTC,2)=1)+1,
&                 (mod(GSYNSTC,4)>=2)+1,
&                 (mod(GSYNSTC,8)>=4)+1,
&                 (mod(GSYNSTC,16)>=8)+1,
&                 2,
&                 LAPMOD_RET) From FUNLOCS
    Call FERME_TRACE From LECFIC
    If LAPMOD_RET
        Call LEC_TRACE   From LECFIC
    Else
        Call EFFACE(filpath("TRA",GTRACE,"TRA",nomap),LAPMOD_RET) From ORDSYS
    Endif
Return
###########################################################
$CREATION
#--- maj de la table ATEXTRA
Call MAJTEXTRA([M:TLO0]TYPDESAXX,"TABLOCTYP","TYPDESAXX",[M:TLO0]STOFCY,[M:TLO0]LOCTYP) From ATEXTRA
Call MAJTEXTRA([M:TLO0]TYPSHOAXX,"TABLOCTYP","TYPSHOAXX",[M:TLO0]STOFCY,[M:TLO0]LOCTYP) From ATEXTRA

Return
###########################################################
$MODIF
#--- maj de la table ATEXTRA
Call MAJTEXTRA([M:TLO0]TYPDESAXX,"TABLOCTYP","TYPDESAXX",[M:TLO0]STOFCY,[M:TLO0]LOCTYP) From ATEXTRA
Call MAJTEXTRA([M:TLO0]TYPSHOAXX,"TABLOCTYP","TYPSHOAXX",[M:TLO0]STOFCY,[M:TLO0]LOCTYP) From ATEXTRA

Return
###########################################################
#Mise à jour des champs redondants
$MAJ_MOD
If [F:TLO]LOCCAT = [F:STC]LOCCAT
  [F:STC]LOCCAT    = [M:TLO1]LOCCAT
Endif
If [F:TLO]MONITMFLG = [F:STC]MONITMFLG
  [F:STC]MONITMFLG = [M:TLO1]MONITMFLG
Endif
If [F:TLO]DEDFLG = [F:STC]DEDFLG
  [F:STC]DEDFLG    = [M:TLO1]DEDFLG
Endif
If [F:TLO]REAFLG = [F:STC]REAFLG
  [F:STC]REAFLG    = [M:TLO1]REAFLG
Endif
If [F:TLO]FILMGTFLG = [F:STC]FILMGTFLG
  [F:STC]FILMGTFLG = [M:TLO1]FILMGTFLG
Endif
If [F:TLO]FRGMGTMOD = [F:STC]FRGMGTMOD
  [F:STC]FRGMGTMOD = [M:TLO1]FRGMGTMOD
Endif
If [F:TLO]LOCNUMFMT = [F:STC]LOCNUMFMT
  [F:STC]LOCNUMFMT = [M:TLO1]LOCNUMFMT
Endif
If [F:TLO]TEMLTI = [F:STC]TEMLTI
  [F:STC]TEMLTI    = [M:TLO1]TEMLTI
Endif
If [F:TLO]AUZSST = [F:STC]AUZSST
  [F:STC]AUZSST    = [M:TLO1]AUZSST
Endif
If [F:TLO]MAXAUZWEI = [F:STC]MAXAUZWEI
  [F:STC]MAXAUZWEI = [M:TLO1]MAXAUZWEI
Endif
If [F:TLO]WID = [F:STC]WID
  [F:STC]WID       = [M:TLO1]WID
Endif
If [F:TLO]HEI = [F:STC]HEI
  [F:STC]HEI       = [M:TLO1]HEI
Endif
If [F:TLO]DTH = [F:STC]DTH
  [F:STC]DTH       = [M:TLO1]DTH
Endif
[F:STC]UPDUSR    = GUSER
[F:STC]EXPNUM    = [C]EXPORT
[F:STC]UPDDAT    = date$
Return
###########################################################
$CAL_FORMAT
Local Char    W1(1)
Local Char    W2(1)
Local Integer I, J, K, L
# Mise à état initial zones écran de positions et longueurs
For I = 0 To dim([M:TLO1]LOCFMTPOS)-1
  [M:TLO1]LOCFMTPOS(I) = 0
  [M:TLO1]LOCFMTLON(I) = 0
Next I
# Calcul des positions et longueurs des composantes du format
W1 = ""
J  = 0
K  = 1

For I = 1 To len([M:TLO1]LOCNUMFMT)
  W2 = mid$([M:TLO1]LOCNUMFMT,I,1)
  If I <> 1 & W1 <> W2
    [M:TLO1]LOCFMTPOS(J) = K
    [M:TLO1]LOCFMTLON(J) = L
    K = I
    J += 1
    L =  0
  Endif
  W1 = W2
  L += 1
Next I
[M:TLO1]LOCFMTPOS(J) = K
[M:TLO1]LOCFMTLON(J) = L
[M:TLO1]LOCFMTDIM    = J
Return
###########################################################
Subprog MAJ_SEQ(LLOC,LSEQ,LFOR,LRES)
Value    Char LLOC
Value    Char LSEQ
Value    Char LFOR
Variable Char LRES
#
Local Char WLOC(GLONLOC) : WLOC = LLOC
Local Char WSEQ(GLONLOC) : WSEQ = LSEQ
Local Char WFOR(GLONLOC) : WFOR = LFOR
Local Char WRES(GLONLOC) : WRES = ""
Local Integer I,J
#
For I = 1 To len(WSEQ)
  For J = 1 To len(WFOR)
    If mid$(WSEQ,I,1) = mid$(WFOR,J,1) Break
    Endif
  Next J
  WFOR = left$(WFOR,J-1)+"Z"+right$(WFOR,J+1)
  WRES = left$(WRES,I-1)+mid$(WLOC,J,1)+right$(WRES,I+1)
Next I
LRES = WRES
End
###########################################################
$VERF_ANU
# Ce Test ne sert à rien car il y a un lien de défini dans la table STOCK
Filter [STO0] Where STOFCY=[M:TLO0]STOFCY & LOCTYP=[M:TLO0]LOCTYP
Look [STO0]STO0 First
Filter [STO0]
If fstat = 0
   GMESSAGE = mess(8,196,1) : OK = 0
Endif
#MAE, bg 78520
For I=0 To 9
  Filter [TLO0] Where STOFCY=[M:TLO0]STOFCY & RPLLOCTYP(I)=[M:TLO0]LOCTYP
  For [TLO0]TLO0
    If fstat = 0
      GMESSAGE = mess(1,115,1)+'\'+mess(1046,196,1)+' '+[F:TLO0]LOCTYP
      OK = 0
      Break 2
    Endif
  Next
Next I
Filter [TLO0]
Return
###########################################################
#Effacement des enregistrements emplacement du type
$ANNULE
Delete [STC] Where STOFCY=[M:TLO0]STOFCY & LOCTYP=[M:TLO0]LOCTYP
If fstat = 1 GOK = -1
             Call RSTA("STC",[F:STC]LOC) From GLOCK
             Return
Endif
#--- maj de la table ATEXTRA
Delete [AXX] Where CODFIC="TABLOCTYP" & IDENT1=[L]SUPP(0) & IDENT2=[L]CODE
If fstat=1 | fstat>5
 # FGR 12/01/2010 : X3SUIVI60986
 #GOK=0 : Call RSTA([AXX],[L]SUPP(0)-[L]CODE) From GLOCK : Return
 GOK=0 : Call RSTA("AXX",[L]SUPP(0)-[L]CODE) From GLOCK : Return
Endif

Return

$FIN_ACTION
If BOUT = "b" | BOUT="d"
  Gosub RELIT From GOBJSUB
Endif
Return

###########################################################
# Action SAICREEMP : création d'emplacements
###########################################################
$OUVRE_CREEMP
If clalev([F:FCY])  = 0 : Local File FACILITY   [FCY]  : Endif
If clalev([F:TLO1]) = 0 : Local File TABLOCTYP  [TLO1] : Endif
If clalev([F:STC1]) = 0 : Local File STOLOC     [STC1] : Endif
If GWRHACT=2
   If !clalev([F:WRH])  : Local File WAREHOUSE  [WRH]  : Endif
Endif

Read [FCY]FCY0=PARAM(1)
If fstat
  FIN = 1
Else
  Read [TLO1]TLO0=[F:FCY]FCY;PARAM(2)
  If fstat
    FIN = 1
  Endif
Endif
Return
###########################################################
$DEBUT_CREEMP
Raz [M:TLO2]
[M:TLO2] = [F:FCY]
[M:TLO2] = [F:TLO1]
Filter [STC1] Where STOFCY = [M:TLO2]STOFCY &
&                   LOCTYP = [M:TLO2]LOCTYP
&             Order By Key STC3
Read [STC1] First
If fstat = 0
  [M:TLO2]FIRLOC = [F:STC1]LOC
Endif
Read [STC1] Last
If fstat = 0
  [M:TLO2]LASLOC = [F:STC1]LOC
Endif
Filter [STC1]

If GWRHACT=2
   If [F:FCY]WRHGES=2 & find([M:TLO2]LOCCAT,1,2)
      Actzo [M:TLO2]WRH
   Else
      Raz [M:TLO2]WRH
      Grizo [M:TLO2]WRH
   Endif
Endif

# Si emplacement client ou sous-traitant, un seul emplacement
If find([M:TLO2]LOCCAT,3,4)
   Diszo [M:TLO2]ENDLOCCRE
Else

Actzo [M:TLO2]ENDLOCCRE

Endif

Affzo [M:TLO2]
Return
###########################################################
$SETBOUT_CREEMP
STADEF = GSTAENR
If [M:TLO2]STRLOCCRE <> "" &
&  [M:TLO2]ENDLOCCRE <> "" &
&  [M:TLO2]ENDLOCCRE >= [M:TLO2]STRLOCCRE
    If !find("E",CHBOU)
        CHBOU+="E"
    Endif
    If !find("A",CHBOU)
        CHBOU+="A"
    Endif
#  ETABOU(GENRE) = 1
Else
        Call VIREBOUT(CHBOU,"E") From GOBJET
        Call VIREBOUT(CHBOU,"A") From GOBJET
#  ETABOU(GENRE) = 0
Endif
Return
###########################################################
$ABA_CREEMP
Effzo [M:TLO2]STRLOCCRE,ENDLOCCRE,UPDLOCEXT
Return
###########################################################
$ENR_CREEMP

# Dépôt obligatoire si gestion dépôt et emplacement interne ou quai
If GWRHACT=2 & [F:FCY]WRHGES=2 & find([M:TLO2]LOCCAT,1,2)
   If [M:TLO2]WRH="" GERR=1 : Return Endif
Endif

If [M:TLO2]UPDLOCEXT <> 0
  Local Decimal LOCEXT
  Local Char    WDEB(GLONLOC)  : WDEB   = [M:TLO2]STRLOCCRE
  Local Char    WWRK(GLONLOC)  : WWRK   = [M:TLO2]STRLOCCRE
  Local Char    WFIN(GLONLOC)  : WFIN   = [M:TLO2]ENDLOCCRE
  Local Char    WMAJ(1)        : WMAJ = "C"
  Local Decimal WCRE
  Local Char    WLET(27) : WLET = "ABCDEFGHIJKLMNOPQRSTUVWXYZA"
  Local Char    WCHI(11) : WCHI = "01234567890"
  Local Integer IFIN     : IFIN = 0
  Local Decimal WPRO     : WPRO = 0
  Local Integer VS  : VS = 2
  Local Integer K, L, M, N, O, P, Q, R
#
  If [M:TLO2]UPDLOCEXT>1000
    VS = 1
  Else
    VS=2
  Endif
  Call AVERTIR(num$([M:TLO2]UPDLOCEXT)-mess(11,196,1),VS) From GESECRAN
  If VS = 2
$ENR_CREEMP1
    Trbegin [STC1]
    GOK = 1
    Call DEBTRANS From GLOCK
# Création des emplacements
    WPRO = 0
    Repeat
      WPRO +=1
      Gosub CRE_EMP
      If GOK <> 1
        Break
      Endif
      Gosub ADD_EMP
    Until IFIN <> 0
    [M:TLO2]UPDLOCCPL = WCRE
    Affzo [M:TLO2]UPDLOCCPL
    Case GOK
      When 1 :
        Commit
        [M:TLO2]UPDLOCCPL = WCRE
        Filter [STC1] Where STOFCY = [M:TLO2]STOFCY &
&                           LOCTYP = [M:TLO2]LOCTYP
&                     Order By Key STC3
        Read [STC1] First
        If fstat = 0
          [M:TLO2]FIRLOC = [F:STC1]LOC
        Endif
        Read [STC1] Last
        If fstat = 0
          [M:TLO2]LASLOC = [F:STC1]LOC
        Endif
        Filter [STC1]
        Affzo [M:TLO2]
        GMESSAGE = num$([M:TLO2]UPDLOCCPL)-mess(12,196,1)
        GERR = 2
        FIN  = 0
        Effzo [M:TLO2]STRLOCCRE,ENDLOCCRE,UPDLOCEXT
      When -1 :
        Rollback
        Call ROLL From GLOCK
        If !GROLL
          Goto ENR_CREEMP1
        Else
          GMESSAGE = mess(20,100,1)-"STOLOC"
          GERR = 1
          FIN  = 1
        Endif
      When Default :
        Rollback
        GMESSAGE = mess(12,100,1)-"STOLOC"
        GERR = 1
        FIN  = 1
    Endcase
  Endif
#--- Bug 68958
#Endif
  #--- mise à jour du nombre d'emplacements libres -----#
  Trbegin [TLO]
  Readlock [F:TLO]TLO0=[M:TLO2]STOFCY;[M:TLO2]LOCTYP
  [F:TLO]FRGLOC += WCRE
  If [F:TLO]FRGLOC+[F:TLO]OCPLOC+[F:TLO]FULLOC <> 0
    [F:TLO]PERLOA = ([F:TLO]OCPLOC+[F:TLO]FULLOC)/([F:TLO]FRGLOC+[F:TLO]OCPLOC+[F:TLO]FULLOC)
  Endif
  Rewrite [TLO]
  Commit
#--- Bug 68958
Endif

Return

############################################################
$ADD_EMP
K = [M:TLO1]LOCFMTDIM
R = [M:TLO1]LOCFMTDIM
$ADD_EMP0
L = [M:TLO1]LOCFMTPOS(K)
M = [M:TLO1]LOCFMTLON(K)
If mid$(WWRK,L,M) <> mid$(WFIN,L,M)
  Gosub ADD_UN
  IFIN = 0
  Return
Endif
For N = K To R
  WWRK = left$(WWRK,[M:TLO1]LOCFMTPOS(N)-1)+right$(WDEB,[M:TLO1]LOCFMTPOS(N))
Next N
If K = 0
  IFIN = 1
Else
  K -= 1
  Goto ADD_EMP0
Endif
Return

###########################################################
$ADD_UN
O = L+M-1
P = M
$ADD_UN0
If P <> 0
  If pat(mid$(WWRK,O,1),"#")
    Q=instr(1,WCHI,mid$(WWRK,O,1))
#    For Q = 1 To len(WCHI)
#      If mid$(WWRK,O,1) = mid$(WCHI,Q,1)
#        Break
#      Endif
#    Next Q
    WWRK = left$(WWRK,O-1)+mid$(WCHI,Q+1,1)+right$(WWRK,O+1)
    If mid$(WCHI,Q,1) = "9"
      P -= 1
      O -= 1
      Goto ADD_UN0
    Endif
  Else
    Q=instr(1,WLET,mid$(WWRK,O,1))
#    For Q = 1 To len(WLET)
#      If mid$(WWRK,O,1) = mid$(WLET,Q,1)
#        Break
#      Endif
#    Next Q
    WWRK = left$(WWRK,O-1)+mid$(WLET,Q+1,1)+right$(WWRK,O+1)
    If mid$(WLET,Q,1) = "Z"
      P -= 1
      O -= 1
      Goto ADD_UN0
    Endif
  Endif
Endif
Return

###########################################################
# Ecriture d'un emplacement (pas d'erreur si existe déja)
$CRE_EMP
Raz [F:STC1]
[F:STC1]          = [M:TLO0]
[F:STC1]          = [M:TLO1]
If dim([M:TLO2]WRH)>0 [F:STC1]WRH=[M:TLO2]WRH Endif
[F:STC1]LOC       = WWRK
[F:STC1]OCPCOD    = 1
[F:STC1]LOKSTA    = 1
[F:STC1]CREUSR    = GUSER
[F:STC1]PCU       = ""
[F:STC1]QTYPCU    = 0
[F:STC1]MAXQTYPCU = 0
[F:STC1]CUNLOKFLG = 1
[F:STC1]AVADAT    = date$
[F:STC1]AVAHOU    = mid$(time$,1,2)+mid$(time$,4,2)
[F:STC1]ALLDAT    = date$
[F:STC1]ALLHOU    = mid$(time$,1,2)+mid$(time$,4,2)
[F:STC1]CREDAT    = date$
[F:STC1]EXPNUM    = [C]EXPORT
Call MAJ_SEQ([F:STC1]LOC,[F:STC1]PPSSEQ,[F:STC1]LOCNUMFMT,[F:STC1]PPSSEQ)

GPOINT = "BEFWRISTC"                 # hcb 43829
Gosub ENTREE From EXEFNC             # hcb 43829

Write [STC1]
Case fstat
  When 0 :
    WCRE += 1
  When 3 :
  When Default :
    GOK = 0
    Call FSTA("STC1") From GLOCK
Endcase
Return
###########################################################
# Action SAIAFFEMP : affectation d'emplacements
###########################################################
$OUVRE_AFFEMP
Local Char    WFILSTC(250)
Local Char    WFILSTF(250)
Local Char    WFILITF(250)
Local Integer WI, WJ
#
If clalev([F:FCY])  = 0 : Local File FACILITY   [FCY]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER  [ITM]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT [ITF]  : Endif
If clalev([F:STF])  = 0 : Local File STOLOCAFF  [STF]  : Endif
If clalev([F:TLO1]) = 0 : Local File TABLOCTYP  [TLO1] : Endif
If clalev([F:STC1]) = 0 : Local File STOLOC     [STC1] : Endif
If GWRHACT=2
   If !clalev([F:WRH])  : Local File WAREHOUSE  [WRH]  : Endif
   If !clalev([F:ITW])  : Local File ITMWRH     [ITW]  : Endif
Endif

Read [FCY]FCY0=PARAM(1)
If fstat
  FIN = 1
Else
  Read [TLO1]TLO0=[F:FCY]FCY;PARAM(2)
  If fstat
    FIN = 1
  Endif
Endif
Return
###########################################################
$OUVRE_BOITE_AFFEMP
If dim(GWSINVREA)<=0 : Global Char GWSINVREA(100) : Endif
If [F:TLO1]REAFLG<>2
    GWSINVREA = '"-Nz:15F"'
Else
    GWSINVREA = '"Nz:"+GUNTFMT'
Endif
Return

###########################################################
$DEBUT_AFFEMP
Raz [M:TLO3]
[M:TLO3] = [F:FCY]
[M:TLO3] = [F:TLO1]

# A réactiver si on remet les zones WRHSTR et WRHEND à Saisie
#If GWRHACT=2
#   If [F:FCY]WRHGES=2 & find([M:TLO3]LOCCAT,1,2)
#      Actzo [M:TLO3]WRHSTR, WRHEND
#   Else
#      Raz [M:TLO3]WRHSTR, [M:TLO3]WRHEND
#      Grizo [M:TLO3]WRHSTR, WRHEND
#   Endif
#Endif

Filter [STC1] Where STOFCY = [M:TLO3]STOFCY &
&                   LOCTYP = [M:TLO3]LOCTYP
&             Order By Key STC3
Read [STC1] First
If fstat = 0
  [M:TLO3]FIRLOC = [F:STC1]LOC
Endif
Read [STC1] Last
If fstat = 0
  [M:TLO3]LASLOC = [F:STC1]LOC
Endif
Filter [STC1]
[M:TLO3]FILITF  = "[F:ITF]LOCMGTCOD>1"
[M:TLO3]NBLIG = 1
Affzo [M:TLO3]
[M:TLO3]NBLIG = 0
Affzo [M:TLO3]
Return
###########################################################
$SETBOUT_AFFEMP
If [M:TLO3]NBLIG > 0 | [M:TLO3]NBLIGS > 0
  ETABOU(GENRE) = 1
  STADEF = GSTAENR
Else
  ETABOU(GENRE) = 0
  STADEF = GSTABOU2+1
Endif
ETABOU(GSPE1) = 1
ETABOU(GSPE2) = 1
Return
###########################################################
$BOUTON_AFFEMP
Case BOUT
  When "E" : Gosub AJO_AFF
  When "F" : Effzo [M:TLO3]30 : Gosub MOD_AFF
  When "G" : Gosub EFF_AFF
Endcase
Return
###########################################################
$AJO_AFF
#
WFILSTC = "STOFCY=[M:TLO3]STOFCY&LOCTYP=[M:TLO3]LOCTYP&(DEDFLG=2|REAFLG=2)&LOC>=[M:TLO3]ALLSTRLOC"
If [M:TLO3]ALLENDLOC<>""
  WFILSTC += "&LOC<=[M:TLO3]ALLENDLOC"
Endif
# A réactiver si on remet les zones WRHSTR et WRHEND à Saisie
# Si gestion dépôt, site avec dépôt et type emp interne ou quai
# on filtre les emplacements sur le dépôt
#If GWRHACT=2 & [F:FCY]WRHGES=2 & find([M:TLO3]LOCCAT,1,2)
#  WFILSTC += "&WRH>=[M:TLO3]WRHSTR"
#  If [M:TLO3]WRHEND<>""
#    WFILSTC += "&WRH<=[M:TLO3]WRHEND"
#  Endif
#Endif
#
WFILITF = "STOFCY=[M:TLO3]STOFCY&LOCMGTCOD=2&ITMREF >=[M:TLO3]ITMREFSTR"
If [M:TLO3]ITMREFEND <> ""
  WFILITF += "&ITMREF <=[M:TLO3]ITMREFEND"
Endif
#
Call TEMPON("O") From GESECRAN
Filter [STC1] Where evalue(WFILSTC)
&             Order By Key STC3
For [STC1]
  Filter [ITF] Where evalue(WFILITF)
&              Order By Key ITF1
  For [ITF]
    # Si gestion dépôt, site avec dépôt et type emp interne ou quai
    # vérification existence article-dépôt, sinon passage article-site suivant
    If GWRHACT=2 & [F:FCY]WRHGES=2 & [F:STC1]WRH<>""
      Read [ITW]ITW0=[F:ITF]ITMREF;[F:STC1]WRH
      If fstat Goto NEXT_ITF Endif
    Endif

    WJ = 0
    For WI = 0 To [M:TLO3]NBLIG-1
      If [M:TLO3]LOC(WI) = [F:STC1]LOC & [M:TLO3]ITMREF(WI) = [F:ITF]ITMREF
        WJ = 1
        Break
      Endif
    Next WI
    If WJ = 0
      Read [ITM]ITM0=[F:ITF]ITMREF
      If fstat = 0
        Read [STF]STF1=[F:ITF]STOFCY;[F:STC1]LOC;[F:ITF]ITMREF
        If fstat = 0
          If [M:TLO3]NBLIG < dim([M:TLO3]ITMREF)-1
            [M:TLO3]NBLIG += 1
            nolign = [M:TLO3]NBLIG
            [M:TLO3] = [F:STF]
            [M:TLO3]STU    (nolign-1) = [F:ITM]STU
            #[M:TLO3]ITMDES1(nolign-1) = [F:ITM]ITMDES1
            Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:TLO3]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
            [M:TLO3]FLG(nolign-1) = 1
          Else
            Call MESSAGE(mess(26,100,1)) From GESECRAN
            Break
          Endif
        Else
          If [F:ITF]STOMGTCOD > 1
            If [M:TLO3]NBLIG < dim([M:TLO3]ITMREF)-1
              [M:TLO3]NBLIG += 1
              nolign = [M:TLO3]NBLIG
              [M:TLO3]LOC    (nolign-1) = [F:STC1]LOC
              [M:TLO3]ITMREF (nolign-1) = [F:ITM]ITMREF
              [M:TLO3]STU    (nolign-1) = [F:ITM]STU
              #[M:TLO3]ITMDES1(nolign-1) = [F:ITM]ITMDES1
              Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:TLO3]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
              If [M:TLO3]REAFLG = 2
                [M:TLO3]REOTSD(nolign-1)= [M:TLO3]REOTSDDEF
                [M:TLO3]MAXSTO(nolign-1)= [M:TLO3]MAXSTODEF
              Else
                [M:TLO3]REOTSD(nolign-1)= 0
                [M:TLO3]MAXSTO(nolign-1)= 0
              Endif
              [M:TLO3]FLG(nolign-1)     = 2
            Else
              Call MESSAGE(mess(26,100,1)) From GESECRAN
              Break 2
            Endif
          Endif
        Endif
      Endif
    Endif
  $NEXT_ITF
  Next
  Filter [ITF]
Next
Filter [STC1]
Call TEMPOFF From GESECRAN
Sorta [M:TLO3]NBLIG [M:TLO3]NBLIG Order By [M:TLO3]LOC(indice),[M:TLO3]ITMREF(indice)
Affzo [M:TLO3]25
Return
###########################################################
$MOD_AFF
Effzo [M:TLO3]25
WFILSTF = "STOFCY=[M:TLO0]STOFCY&LOC >=[M:TLO3]ALLSTRLOC&ITMREF>=[M:TLO3]ITMREFSTR"
If [M:TLO3]ALLENDLOC <> ""
  WFILSTF += "&LOC <=[M:TLO3]ALLENDLOC"
Endif
If [M:TLO3]ITMREFEND <> ""
  WFILSTF += "&ITMREF <=[M:TLO3]ITMREFEND"
Endif
Link [STF] With [STC]STC0=[STF]STOFCY;[STF]LOC
&          As [LNK]
&          Where evalue(WFILSTF)
&              & [STC]LOCTYP = [M:TLO3]LOCTYP
&          Order By Key STF0
For [LNK]
  WJ = 0
  For WI = 0 To [M:TLO3]NBLIG-1
    If [M:TLO3]LOC(WI) = [F:STF]LOC & [M:TLO3]ITMREF(WI) = [F:STF]ITMREF
      WJ = 1
      Break
    Endif
  Next WI
  For WI = 0 To [M:TLO3]NBLIGS-1
    If [M:TLO3]LOCS(WI) = [F:STF]LOC & [M:TLO3]ITMREFS(WI) = [F:STF]ITMREF
      WJ = 1
    Endif
  Next WI
  If WJ = 0
    If [M:TLO3]NBLIG < dim([M:TLO3]ITMREF)-1
      [M:TLO3]NBLIG += 1
      nolign = [M:TLO3]NBLIG
      [M:TLO3] = [F:STF]
      Read [ITM]ITM0=[F:STF]ITMREF
      If fstat = 0
        [M:TLO3]STU    (nolign-1) = [F:ITM]STU
        #[M:TLO3]ITMDES1(nolign-1) = [F:ITM]ITMDES1
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:TLO3]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
      Endif
      [M:TLO3]FLG(nolign-1) = 1
    Else
      Call MESSAGE(mess(26,100,1)) From GESECRAN
      Break
    Endif
  Endif
Next
Filter [STF]
Affzo [M:TLO3]25
Return
###########################################################
$EFF_AFF
Effzo [M:TLO3]25-30
Return
###########################################################
$ENR_AFFEMP
# Contrôle mono article
GMESSAGE = ""
# Suite à la demande de PARB le 23/09/03
# Un emplacement mono-article peut très bien recevoir des articles différents mais pas en même temps
#If [M:TLO3]MONITMFLG = 2
#  For WI = 0 To [M:TLO3]NBLIG -1
#    If WI > 0
#      If [M:TLO3]LOC(WI) = [M:TLO3]LOC(WI-1)
#        GMESSAGE = mess(368,199,1)
#        GERR     = 1
#        FIN      = 0
#        Break
#      Endif
#    Endif
#  Next WI
#Endif
Local Integer WERR
Raz WERR
# Contrôle seuils saisis
If GMESSAGE = ""
  If [M:TLO3]REAFLG = 2
    For WI = 0 To [M:TLO3]NBLIG -1
      If [M:TLO3]REOTSD(WI) = 0
#        GMESSAGE = mess(369,199,1)
#        GERR     = 1
#        FIN      = 0
         WERR     = 1
        Break
      Endif
    Next WI
  Endif
Endif

If WERR = 1
   Call MESSAGE(mess(369,199,1)) From GESECRAN
Endif

# validation de la saisie
If GMESSAGE = ""
  WI = 2
  Call OUINON(mess(20,196,1),WI) From GESECRAN
  If WI = 2
    Gosub MAJ_AFF
  Endif
Endif
Return
##########################################################
$MAJ_AFF
Trbegin [STC1]
GOK = 1
Call DEBTRANS From GLOCK
For WI = 0 To [M:TLO3]NBLIG-1
  Readlock [STF]STF0=[M:TLO3]STOFCY;[M:TLO3]LOC(WI);[M:TLO3]ITMREF(WI)
  Case fstat
    When 0 :
      If [F:STF]REOTSD <> [M:TLO3]REOTSD(WI) | [F:STF]MAXSTO <> [M:TLO3]MAXSTO(WI)
        [F:STF]REOTSD = [M:TLO3]REOTSD(WI)
        [F:STF]MAXSTO = [M:TLO3]MAXSTO(WI)
        [F:STF]EXPNUM = [C]EXPORT
        [F:STF]UPDUSR = GUSER
        [F:STF]UPDDAT = date$
        Rewrite [STF]
        If fstat
          GOK = 0
          Call FSTA("STF") From GLOCK
          Break
        Endif
      Endif
    When 1 :
      GOK = -1
      Break
    When 4, 5 :
      nolign = WI +1
      Raz [F:STF]
      [F:STF] = [M:TLO3]
      [F:STF]CREUSR = GUSER
      [F:STF]CREDAT = date$
      Write [STF]
      If fstat
        GOK = 0
        Call FSTA("STF") From GLOCK
        Break
      Endif
    When Default :
      GOK = 0
      Call FSTA("STF") From GLOCK
      Break
  Endcase
Next WI
For WI = 0 To [M:TLO3]NBLIGS-1
  Readlock [STF]STF0=[M:TLO3]STOFCY;[M:TLO3]LOCS(WI);[M:TLO3]ITMREFS(WI)
  Case fstat
    When 0 :
        Delete [STF]STF0=[M:TLO3]STOFCY;[M:TLO3]LOCS(WI);[M:TLO3]ITMREFS(WI)
        If fstat
          GOK = 0
          Call FSTA("STF") From GLOCK
          Break
        Endif
    When 1 :
      GOK = -1
      Break
    When Default :
      GOK = 0
      Call FSTA("STF") From GLOCK
      Break
  Endcase
Next WI
#
Case GOK
  When 1 :
    Commit
    Effzo [M:TLO3]25
    FIN  = 1
  When -1 :
    Rollback
    Call ROLL From GLOCK
    If !GROLL
      Goto MAJ_AFF
    Else
      GMESSAGE = mess(20,100,1)-"STOLOCAFF"
      GERR = 1
      FIN  = 1
    Endif
  When Default :
    Rollback
    GMESSAGE = mess(12,100,1)-"STOLOCAFF"
    GERR = 1
    FIN  = 1
Endcase
Return
###########################################################
# Action SAISUPEMP : suppression d'emplacements
###########################################################
$OUVRE_SUPEMP
If clalev([F:FCY])  = 0 : Local File FACILITY   [FCY]  : Endif
If clalev([F:TLO1]) = 0 : Local File TABLOCTYP  [TLO1] : Endif
If clalev([F:STO0]) = 0 : Local File STOCK      [STO0] : Endif
If clalev([F:STC1]) = 0 : Local File STOLOC     [STC1] : Endif
If GWRHACT=2
   If !clalev([F:WRH])  : Local File WAREHOUSE  [WRH]  : Endif
Endif

Read [FCY]FCY0=PARAM(1)
If fstat
  FIN = 1
Else
  Read [TLO1]TLO0=[F:FCY]FCY;PARAM(2)
  If fstat
    FIN = 1
  Endif
Endif
Return
###########################################################
$DEBUT_SUPEMP
Raz [M:TLO4]
[M:TLO4] = [F:FCY]
[M:TLO4] = [F:TLO1]
Filter [STC1] Where STOFCY = [M:TLO4]STOFCY &
&                   LOCTYP = [M:TLO4]LOCTYP
&             Order By Key STC3
Read [STC1] First
If fstat = 0
  [M:TLO4]FIRLOC = [F:STC1]LOC
Endif
Read [STC1] Last
If fstat = 0
  [M:TLO4]LASLOC = [F:STC1]LOC
Endif
Filter [STC1]

# Si emplacement client ou sous-traitant, un seul emplacement
If find([M:TLO4]LOCCAT,3,4)
   Diszo [M:TLO4]ENDLOCSUP
Else
   Actzo [M:TLO4]ENDLOCSUP
Endif

Affzo [M:TLO4]
Return
###########################################################
$SETBOUT_SUPEMP
STADEF = GSTAENR
If [M:TLO4]STRLOCSUP <> "" &
&  [M:TLO4]ENDLOCSUP <> "" &
&  [M:TLO4]ENDLOCSUP >= [M:TLO4]STRLOCSUP
    If !find("E",CHBOU)
        CHBOU+="E"
    Endif
    If !find("A",CHBOU)
        CHBOU+="A"
    Endif
#  ETABOU(GENRE) = 1
Else
        Call VIREBOUT(CHBOU,"E") From GOBJET
        Call VIREBOUT(CHBOU,"A") From GOBJET
#  ETABOU(GENRE) = 0
Endif
Return
###########################################################
$ABA_SUPEMP
Effzo [M:TLO4]STRLOCSUP,ENDLOCSUP,UPDLOCEXT
Return
###########################################################
$ENR_SUPEMP
If [M:TLO4]UPDLOCEXT <> 0
  Local Decimal LOCEXT
  Local Char    WDEB(GLONLOC)  : WDEB   = [M:TLO4]STRLOCSUP
  Local Char    WFIN(GLONLOC)  : WFIN   = [M:TLO4]ENDLOCSUP
  Local Decimal WCRE
  Local Char    WLET(27) : WLET = "ABCDEFGHIJKLMNOPQRSTUVWXYZA"
  Local Char    WCHI(11) : WCHI = "01234567890"
  Local Integer IFIN     : IFIN = 0
  Local Decimal WPRO     : WPRO = 0
  Local Integer VS  : VS = 2
  Local Integer K, L, M, N, O, P, Q, R
#
  Call AVERTIR(num$([M:TLO4]UPDLOCEXT)-mess(47,196,1),VS) From GESECRAN
  If VS = 2
$ENR_SUPEMP1
    Trbegin [STC1]
    GOK = 1
    Call DEBTRANS From GLOCK
# suppression des emplacements
    WPRO = 0
    Filter [STC1] Where STOFCY = [M:TLO0]STOFCY &
&                       LOCTYP = [M:TLO0]LOCTYP &
&                       LOC   >= WDEB           &
&                       LOC   <= WFIN
&                 Order By Key STC3
    For [STC1]
      WPRO +=1
      Readlock Curr
      Case fstat
        When 0 :
          Look [STO0]STO4=[M:TLO0]STOFCY;[F:STC1]LOC
          If fstat
            Delete [STC1]
            If fstat
              Call FSTA("STC1") From GLOCK
              GOK = 0
              Break
            Endif
#MAE, LE 28/07/08, bg 48411
         Filter [STF] Where STOFCY = [F:STC1]STOFCY &
&                                LOC    = [F:STC1]LOC
&                                 Order By Key STF0

          For [STF]
            Readlock [STF] Curr
            Case fstat
              When 0 :
                Delete [STF]
                If fstat
                  GOK = 0
                  Call FSTA("STF") From GLOCK
                  Break 2
                Endif
              When 1 :
                GOK = -1
                Break 2
              When Default :
                GOK = 0
                Call FSTA("STF") From GLOCK
                Break 2
            Endcase
            Next
#Fin MAE, bg 48411
            WCRE += 1
          Endif
        When 1 :
          GOK = -1
          Break
        When Default :
          Call FSTA("STC1") From GLOCK
          GOK = 0
          Break
      Endcase
    Next
    Filter [STC1]
    Case GOK
      When 1 :
        Commit
        [M:TLO4]UPDLOCCPL = WCRE
        Filter [STC1] Where STOFCY = [M:TLO4]STOFCY &
&                           LOCTYP = [M:TLO4]LOCTYP
&                     Order By Key STC3
        Read [STC1] First
        If fstat = 0
          [M:TLO4]FIRLOC = [F:STC1]LOC
        Endif
        Read [STC1] Last
        If fstat = 0
          [M:TLO4]LASLOC = [F:STC1]LOC
        Endif
        Filter [STC1]
        [M:TLO4]UPDLOCCPL = WCRE
        Affzo [M:TLO4]
        GMESSAGE = num$([M:TLO4]UPDLOCCPL)-mess(48,196,1)
        GERR = 2
        FIN  = 0
        Effzo [M:TLO4]STRLOCSUP,ENDLOCSUP,UPDLOCEXT
      When -1 :
        Rollback
        Call ROLL From GLOCK
        If !GROLL
          Goto ENR_SUPEMP1
        Else
          GMESSAGE = mess(20,100,1)-"STOLOC"
          GERR = 1
          FIN  = 1
        Endif
      When Default :
        Rollback
        GMESSAGE = mess(12,100,1)-"STOLOC"
        GERR = 1
        FIN  = 1
    Endcase
  Endif
#--- Bug 68958
#Endif
  #--- mise à jour du nombre d'emplacements libres -----#
  Trbegin [TLO]
  Readlock [F:TLO]TLO0=[M:TLO4]STOFCY;[M:TLO4]LOCTYP
  [F:TLO]FRGLOC = max(0, [F:TLO]FRGLOC -WCRE)
  If [F:TLO]FRGLOC+[F:TLO]OCPLOC+[F:TLO]FULLOC <> 0
    [F:TLO]PERLOA = ([F:TLO]OCPLOC+[F:TLO]FULLOC)/([F:TLO]FRGLOC+[F:TLO]OCPLOC+[F:TLO]FULLOC)
  Else
    [F:TLO]PERLOA = 0
  Endif
  Rewrite [TLO]
  Commit
#--- Bug 68958
Endif

Return

