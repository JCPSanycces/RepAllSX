###########################################################
# Actions écran TLO1
###########################################################

###########################################################
Subprog C_LOCCAT(VALEUR)
Variable Integer VALEUR
If VALEUR<>[M:TLO1]LOCCAT
   If VALEUR=2
      [M:TLO1]MONITMFLG = 1
      [M:TLO1]DEDFLG    = 1
      [M:TLO1]REAFLG    = 1
      [M:TLO1]FILMGTFLG = 1
      Actzo [M:TLO1]LOCNUMFMT
      Actzo [M:TLO1]PPSSEQ
      Grizo [M:TLO1]MONITMFLG
      Grizo [M:TLO1]DEDFLG
      Grizo [M:TLO1]REAFLG
      Grizo [M:TLO1]FILMGTFLG
      Affzo [M:TLO1]MONITMFLG
      Affzo [M:TLO1]DEDFLG
      Affzo [M:TLO1]REAFLG
      Affzo [M:TLO1]FILMGTFLG
    Elsif find(VALEUR,3,4)
      [M:TLO1]LOCNUMFMT = "AAAAAAAAAA"
      [M:TLO1]PPSSEQ    = "AAAAAAAAAA"
      Grizo [M:TLO1]LOCNUMFMT
      Grizo [M:TLO1]PPSSEQ
      Actzo [M:TLO1]MONITMFLG
      Actzo [M:TLO1]DEDFLG
      Actzo [M:TLO1]REAFLG
      Actzo [M:TLO1]FILMGTFLG
      Affzo [M:TLO1]LOCNUMFMT
      Affzo [M:TLO1]PPSSEQ
   Else
      Actzo [M:TLO1]LOCNUMFMT
      Actzo [M:TLO1]PPSSEQ
      Actzo [M:TLO1]MONITMFLG
      Actzo [M:TLO1]DEDFLG
      Actzo [M:TLO1]REAFLG
      Actzo [M:TLO1]FILMGTFLG
   Endif
Endif
End
