    Read [STC1]STC0=[M:TLO3]STOFCY;VALEUR
    If fstat
      mkstat = 2
    Else
      If [F:STC1]LOCTYP <> [M:TLO0]LOCTYP
        mkstat = 2
      Endif
    Endif
  Endif
Endif
End
