############################################################
Subprog C_NBLIG
Local Integer I
    Case status
        When 65     :                                # Suppression d'une ligne
            Look [STF]STF0=[M:TLO3]STOFCY;[M:TLO3]LOC(nolign-1);[M:TLO3]ITMREF(nolign-1)
            If !fstat
                [M:TLO3]LOCS([M:TLO3]NBLIGS) = [M:TLO3]LOC(nolign-1)
                [M:TLO3]ITMREFS([M:TLO3]NBLIGS) = [M:TLO3]ITMREF(nolign-1)
                [M:TLO3]NBLIGS += 1
                Affzo [M:TLO3]30
            Endif
        When 68, 83 :                                # Suppression d'un groupe de lignes
            For I=nolign-1 To nolign1-1
                Look [STF]STF0=[M:TLO3]STOFCY;[M:TLO3]LOC(I);[M:TLO3]ITMREF(I)
                [M:TLO3]LOCS([M:TLO3]NBLIGS) = [M:TLO3]LOC(I)
                [M:TLO3]ITMREFS([M:TLO3]NBLIGS) = [M:TLO3]ITMREF(I)
                [M:TLO3]NBLIGS += 1
            Next
            Affzo [M:TLO3]30
    Endcase
End
############################################################
Subprog AV_LOC(VALEUR)
Variable Char    VALEUR()
Case [M:TLO3]FLG(nolign-1)
  When 1       : pcolor = GCOUL(1)
  When 2       : pcolor = GCOUL(3)
  When Default : pcolor = GCOUL(2)
Endcase
End
############################################################
Subprog AS_LOC(VALEUR)
Variable Char    VALEUR()
If [M:TLO3]FLG(nolign-1) <> 0
  mkstat = 2
Endif
End
############################################################
Subprog C_LOC(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
Read [STC1]STC0=[M:TLO3]STOFCY;VALEUR
If fstat = 0
  If [F:STC1]LOCTYP <> [M:TLO3]LOCTYP
    mkstat = 2
  Endif
Else
  mkstat = 2
Endif
End
############################################################
Subprog AS_ITMREF(VALEUR)
Variable Char    VALEUR()
If [M:TLO3]FLG(nolign-1) <> 0
  mkstat = 2
Endif
End
############################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Local Integer WI
Read [ITM]ITM0=VALEUR
If fstat
  mkstat = 2
  GMESSAGE = mess(212,199,1)
Else
  If [F:ITM]STOMGTCOD = 1
     mkstat = 2
     GMESSAGE = mess(147,199,1)
  Else
    Read [ITF]ITF0=VALEUR;[M:TLO0]STOFCY
    If fstat
       mkstat = 2
       GMESSAGE = mess(2,196,1)
    Else
      If [F:ITF]STOMGTCOD = 1
         mkstat = 2
         GMESSAGE = mess(147,199,1)
      Else
         If [F:ITF]LOCMGTCOD <> 2
            mkstat = 2
            GMESSAGE = mess(149,199,1)
         Endif
      Endif
    Endif
  Endif
Endif
# Contrôle unicité
WI = sigma(0,[M:TLO3]NBLIG-1,(indcum+1) * (
&                             indcum <> nolign-1
&                           & [M:TLO3]ITMREF(indcum)=VALEUR
&                           & [M:TLO3]LOC(indcum)=[M:TLO3]LOC(nolign-1)
&                           & sigma([M:TLO3]NBLIG,[M:TLO3]NBLIG,1) ) )
If WI
      mkstat = 2
      GMESSAGE = mess(176,193,1)-num$(WI)
Endif
WI = sigma(0,[M:TLO3]NBLIGS-1,(indcum+1) * (
&                             [M:TLO3]ITMREFS(indcum)=VALEUR
&                           & [M:TLO3]LOCS(indcum)=[M:TLO3]LOC(nolign-1)
&                           & sigma([M:TLO3]NBLIGS,[M:TLO3]NBLIGS,1) ) )
If WI
    mkstat = 2
    GMESSAGE = mess(794,196,1)+chr$(13)+mess(3,40,1)-num$(WI)
Endif
If !mkstat
  #[M:TLO3]ITMDES1(nolign-1) = [F:ITM]ITMDES1
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:TLO3]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
  [M:TLO3]STU    (nolign-1) = [F:ITM]STU
  Affzo [M:TLO3]ITMDES1(nolign-1)
  Affzo [M:TLO3]STU    (nolign-1)
Endif
End
############################################################
Subprog AS_REOTSD(VALEUR)
Variable Decimal VALEUR
If [M:TLO3]REAFLG <> 2
  VALEUR = 0
  mkstat = 2
Endif
End
############################################################
Subprog AS_MAXSTO(VALEUR)
Variable Decimal VALEUR
If [M:TLO3]REAFLG <> 2
  VALEUR = 0
  mkstat = 2
Endif
End
############################################################
Subprog C_MAXSTO(VALEUR)
Variable Decimal VALEUR
If VALEUR <> 0 & VALEUR < [M:TLO3]REOTSD(nolign-1)
  mkstat = 2
Endif
End
##########################################################################
Subprog C_NBLIGS
Local Integer I
    Case status
        When 65     :                                # Suppression d'une ligne
            [M:TLO3]LOCS(nolign-1) = ""
            [M:TLO3]ITMREFS(nolign-1) = ""
            Gosub MOD_AFF
        When 68, 83 :                                # Suppression d'un groupe de lignes
            For I=nolign-1 To nolign1-1
                [M:TLO3]LOCS(I) = ""
                [M:TLO3]ITMREFS(I) = ""
            Next
            Gosub MOD_AFF
    Endcase
End

############################################################
# Actions Ecran TLO4
############################################################

############################################################
Subprog AS_STRLOCSUP(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog C_STRLOCSUP(VALEUR)
Variable Char    VALEUR()
Local Char    WMAJ(1)  : WMAJ = "A"
# hcb
# Si emplacement interne, contrôle de format
If [M:TLO4]LOCCAT<3
   Gosub CTR_STRLOC
Else
   VALEUR = toupper(VALEUR)
   [M]STRLOCSUP = VALEUR
   [M]ENDLOCSUP = VALEUR
   [M]UPDLOCEXT = 1
   Affzo [M]ENDLOCSUP
   Affzo [M]UPDLOCEXT
Endif
End
############################################################
Subprog AS_ENDLOCSUP(VALEUR)
Variable Char    VALEUR()
If VALEUR = ""
  VALEUR = [M]STRLOCSUP
Endif
End
############################################################
Subprog C_ENDLOCSUP(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
Local Char    WDEB(GLONLOC) : WDEB = [M:TLO4]STRLOCSUP
Local Char    WFIN(GLONLOC) : WFIN = VALEUR
[M]UPDLOCEXT = 0
Filter [STC1] Where STOFCY = [M:TLO0]STOFCY &
&                   LOCTYP = [M:TLO0]LOCTYP &
&                   LOC   >= WDEB           &
&                   LOC   <= WFIN
&             Order By Key STC3
For [STC1]
  [M]UPDLOCEXT += 1
Next
Filter [STC1]
Affzo [M]UPDLOCEXT
End

############################################################
# Actions Ecran TLO5
############################################################

############################################################
Subprog AV_TOTLOC(VALEUR)
Variable Decimal VALEUR
VALEUR = [M:TLO5]FULLOC+[M:TLO5]OCPLOC+[M:TLO5]FRGLOC
End

