End
############################################################
Subprog C_STRLOCCRE(VALEUR)
Variable Char    VALEUR()
Local Char    WMAJ(1)  : WMAJ = "C"
# hcb
# Si emplacement interne, contrôle de format
#If [M:TLO2]LOCCAT<3    # hcb 95512
Gosub CTR_STRLOC
#Else                   # hcb 95512
If [M:TLO2]LOCCAT>2     # hcb 95512
   VALEUR = toupper(VALEUR)
   [M]STRLOCCRE = VALEUR
   [M]ENDLOCCRE = VALEUR
   [M]UPDLOCEXT = 1
   Affzo [M]ENDLOCCRE
   Affzo [M]UPDLOCEXT
Endif
