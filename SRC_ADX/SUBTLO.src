###########################################################
Subprog AS_LOCNUMFMT(VALEUR)
Variable Char     VALEUR
End
###########################################################
Subprog C_LOCNUMFMT(VALEUR)
Variable Char     VALEUR
Local Char W1(1)
Local Char W2(1)
Local Integer I
VALEUR = toupper(VALEUR)
#
W1 = mid$(VALEUR,1,1)
For I = 1 To len(VALEUR)
  W2 = mid$(VALEUR,I,1)
  If W2 < W1 | W2 < "A" | W2 > "G"
    GMESSAGE = mess(9,196,1)
    mkstat = 2
    Break
  Endif
  W1 = W2
Next I
If mkstat = 0
  # Il faut l'affecter car CAL_FORMAT l'utilise
  [M:TLO1]LOCNUMFMT = VALEUR
  Gosub CAL_FORMAT
Endif
End
###########################################################
Subprog AS_PPSSEQ(VALEUR)
Variable Char     VALEUR
If VALEUR = ""
  VALEUR = [M:TLO1]LOCNUMFMT
Endif
End
############################################################
Subprog C_PPSSEQ(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
Local Char WLOC(GLONLOC) : WLOC = ""
Local Char WCAR(GLONLOC) : WCAR = [M:TLO1]LOCNUMFMT
Local Integer I,J
#
For I = 1 To len(VALEUR)
  For J = 1 To len(WCAR)
    If mid$(VALEUR,I,1) = mid$(WCAR,J,1)
         WLOC = left$(WLOC,I-1)+mid$(WCAR,J,1)+right$(WLOC,I+1)
         WCAR = left$(WCAR,J-1)+" "+right$(WCAR,J+1)
         Break
    Endif
  Next J
Next I
WCAR = vireblc(WCAR,4)
If len(WCAR) <> 0 | WLOC <> VALEUR mkstat = 2
Endif
End
