#<AdxTL>@(#)3.0.0.0 $Revision$
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE 
 When "LIENS"      : Gosub LIENS
 When "FILTRE"     : Gosub FILTRE
 When "EXEACT"     : Gosub EXEACT
 When "SETBOUT"    : Gosub SETBOUT 
 When "APRES_CHOI" : Gosub APRES_CHOI
 When "ANNULE"     : Gosub ANNULE    # FGR 16/09/2009 : X3SUIVI57824
 When "CREATION"   : Gosub CREATION  # FGR 16/09/2009 : X3SUIVI57824
 When "MODIF"      : Gosub MODIF     # FGR 16/09/2009 : X3SUIVI57824
 When Default
Endcase
Return

######################################################################################
$OUVRE
# Demande 24415 11.04 MM 
If clalev([F:BOH]) = 0  : Local File BOM   [BOH] : Endif
Return

######################################################################################
$FILTRE
If dim(GFLTTBO)>0
  Default File [TBO]
  FILTSUP="BOMALTTYP="+GFLTTBO
Endif
Return

######################################################################################
$LIENS
# GA 21/06/2005 BOMALTTYP = 3 Alt de sous-traitance
If [M:TBO1]BOMALTTYP = 1
   Grizo [M:TBO1]MRPUSE, MPSUSE, MFGUSE, CSTUSE, FCY
Elsif [M:TBO1]BOMALTTYP = 3
   Grizo [M:TBO1]MFGUSE
   Actzo [M:TBO1]MPSUSE, MRPUSE, CSTUSE, FCY
Else
   Actzo [M:TBO1]MRPUSE, MPSUSE, MFGUSE, CSTUSE, FCY
Endif
[M:TBO1]FCYOLD = [M:TBO1]FCY
## Diszo [M:TBO1]BOMALTTYP #Radio btn !!
Return

######################################################################################
$EXEACT 
# Demande 24415 11.04 MM + 30228

Case BOUT
    When "E" :
            If find([M:TBO1]ANSWER,1,2) Call CHARGE_ACS([M:TBO1]ACSCOD) Endif
Endcase
Return
 
######################################################################################
# Demande 24415 11.04 MM + 30228
Subprog CHARGE_ACS(ACSCOD)
Value Char ACSCOD
# [M:TBO1]ANSWER=1 , on RAZ le code d'acces de toutes les nomenclatures qui utilise l'alternative 
# de façon à éviter des incohérences dans les tables
# [M:TBO1]ANSWER=2 , on répercute le code d'accès dans ttes les nomenclatures qui utilisent l'alt.

Trbegin [BOH] 
Filter [BOH] Where BOMALT= [M:TBO1]BOMALT & BOMALTTYP = [M:TBO1]BOMALTTYP
    For [BOH]
        If [M:TBO1]ANSWER=1  Raz [F:BOH]ACSCOD 
        Elsif [M:TBO1]ANSWER=2 [F:BOH]ACSCOD = ACSCOD
        Endif
        Rewrite [BOH]
        If fstat : Goto ABANDON : Endif
    Next 
Filter [BOH]
Commit 
End

######################################################################################
$ABANDON
Rollback
GERR=1 : Call ERREUR(mess(17,107,1)) From GESECRAN : GMESSAGE=""
End

######################################################################################
$SETBOUT 
Call VIREBOUT(CHAINE,"H") From GOBJET 
#  Autorisation de modif selon profil gestionnaire 
If CLECUR=1
 Read [ACC]CODACC=GUSER;[M:TBO1]ACSCOD  
 If !fstat & [F:ACC]MODIF = 1 
   Call VIREBOUT(CHAINE,"MAH") From GOBJET 
 Endif   
Endif
Return 
 
######################################################################################
$APRES_CHOI
# Demande 24415 11.04 MM 
# Pour récupérer la main quand on appuie sur Entrée après l'affichage de la boite de dialogue
If REPONSE=GSTARET REPONSE=0 Endif
Return

#############################################################
$ANNULE
  # FGR 16/09/2009 : X3SUIVI57824
  #--- maj de la table des libéllés traduisibles
  Call SUPTEXTRA("TABBOMALT","TBODESAXX",num$([M:TBO1]BOMALTTYP),num$([M:TBO1]BOMALT)) From ATEXTRA
  Call SUPTEXTRA("TABBOMALT","TBOSHOAXX",num$([M:TBO1]BOMALTTYP),num$([M:TBO1]BOMALT)) From ATEXTRA
Return

#############################################################
$CREATION
  # FGR 16/09/2009 : X3SUIVI57824
  #--- maj de la table des libéllés traduisibles
  Call MAJTEXTRA([M:TBO1]TBODESAXX,"TABBOMALT","TBODESAXX",num$([M:TBO1]BOMALTTYP),num$([M:TBO1]BOMALT)) From ATEXTRA
  Call MAJTEXTRA([M:TBO1]TBOSHOAXX,"TABBOMALT","TBOSHOAXX",num$([M:TBO1]BOMALTTYP),num$([M:TBO1]BOMALT)) From ATEXTRA
Return

#############################################################
$MODIF
  # FGR 16/09/2009 : X3SUIVI57824
  #--- maj de la table des libéllés traduisibles
  Call MAJTEXTRA([M:TBO1]TBODESAXX,"TABBOMALT","TBODESAXX",num$([M:TBO1]BOMALTTYP),num$([M:TBO1]BOMALT)) From ATEXTRA
  Call MAJTEXTRA([M:TBO1]TBOSHOAXX,"TABBOMALT","TBOSHOAXX",num$([M:TBO1]BOMALTTYP),num$([M:TBO1]BOMALT)) From ATEXTRA
Return

######################################################################################
Subprog AS_BOMALTTYP(VALEUR)
Variable Integer VALEUR
# 01/2008 ne fonctionne pas avec clé multiple TBO: on doit pouvoir consulter les autres types ...
#If GREP = "M"  | GREP = ""   :# "MODIFICATION impossible"
#   mkstat = 2
#Endif
End

######################################################################################
Subprog AM_BOMALTTYP(VALEUR)
Variable Integer VALEUR
# GA 01/2008
# si on est en modif: (re)lecture de l'alternative
If !find(GREP,"C","D") & [M:TBO1]BOMALTTYP<>0 & [M:TBO1]BOMALT<>0
   Read [TBO]TBO0=VALEUR;[M:TBO1]BOMALT
Endif
Case VALEUR
    When 1: [M:TBO1]MRPUSE = 1 : [M:TBO1]MPSUSE = 1 : [M:TBO1]CSTUSE = 1 : [M:TBO1]MFGUSE = 1 : [M:TBO1]FCY = ""  
            Affzo [M:TBO1]15          
            Grizo [M:TBO1]MRPUSE, MPSUSE, MFGUSE, CSTUSE, FCY
    When 2: [M:TBO1]MRPUSE = 2 : [M:TBO1]MPSUSE = 2 : [M:TBO1]CSTUSE = 2 : [M:TBO1]MFGUSE = 2
            Affzo [M:TBO1]15          
            Actzo [M:TBO1]MRPUSE, MPSUSE, MFGUSE, CSTUSE, FCY
    When 3: [M:TBO1]MFGUSE = 1 : [M:TBO1]CSTUSE = 2 : Grizo [M:TBO1]MFGUSE
            Affzo [M:TBO1]15          
            Actzo [M:TBO1]MRPUSE, MPSUSE, CSTUSE
Endcase
End

#######################################################################################
# 01/2008 remplacement de l'action Selection SELOBJ qui ne fonctionne pas avec clé multiple TBO
Subprog AM_BOMALT(VALEUR)
Variable Decimal VALEUR
# GA 01/2008
# si on est en modif: (re)lecture de l'alternative
If !find(GREP,"C","D") & [M:TBO1]BOMALTTYP<>0 & [M:TBO1]BOMALT<>0
   Read [TBO]TBO0=[M:TBO1]BOMALTTYP;VALEUR
Endif
End

#######################################################################################
Subprog AS_FCY(VALEUR)
Variable Char     VALEUR
If [M]BOMALTTYP=1 : VALEUR = "" : mkstat=1: Endif
End
 
######################################################################################
# Demande 24415 11.04 MM + 30228
######################################################################################
Subprog AM_ACSCOD(VALEUR)
Variable Char    VALEUR()
Raz [M:TBO1]ANSWER

#"Voulez-vous appliquer la modification du code d'accès à l'ensemble\ des nomenclatures
# utilisant cette alternative?"
If [M:TBO1]ACSCOD <> VALEUR
    Call OUINON(mess(76,187,1),[M:TBO1]ANSWER)From GESECRAN
    If !find([M:TBO1]ANSWER,1,2) Raz [M:TBO1]ANSWER Endif
Endif
End

######################################################################################
# GH 04/03/2013 dm 85838
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

If [M:TBO1]FCYOLD<>VALEUR & !find(GREP,"C","D")
   If !clalev([F:BOD]) : Local File BOMD [BOD] : Endif
   Filter [BOD] Where BOMALTTYP=[M:TBO1]BOMALTTYP & BOMALT=[M:TBO1]BOMALT
   Read [BOD] First
   If fstat<=2
      Local Integer OK
      OK=2 : # "Cette modification impactera les nomenclatures utilisant cette alternative
      Call AVERTIR(mess(179,187,1),OK) From GESECRAN
      If OK<>2 : VALEUR=[M:TBO1]FCYOLD : Endif
   Endif
   Filter [BOD]
Endif
End
