#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################################
#   Traitement de gestion des associations clients/donneurs d'ordre        Module CRM         16 aout 2000
##########################################################################################################

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "DEFBOUT"      : Gosub DEFBOUT
 When "SETBOUT"      : Gosub SETBOUT
 When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
 When "DEBUT"        : Gosub DEBUT
 When "AV_CHOIX"     : Gosub AV_CHOIX
 When "AP_CHOIX"     : Gosub AP_CHOIX
 When "AVANT_BOUTON" : Gosub AVANT_BOUTON
 When "FINSAI"       : Gosub FINSAI
 When "FIN"          : Gosub FIN
 When "ABANDON"      : Gosub ABANDON
 When "APRES_MODIF"  : Gosub APRES_MODIF
 When "BOUTON"       : Gosub BOUTON
 When "MEN"          : Gosub ONMENU
 When "OK"           : Gosub ONOK
 When Default
Endcase
Return

##########################################################################################################
$OUVRE
#PARAM(1) = Code client.
Global Integer ISDIRTY
ISDIRTY = 0

If !clalev([F:DBL]) : Local File DOOBPCLNK [DBL] : Endif
If !clalev([F:DBI]) : Local File DOOBPCINT [DBI] : Endif
If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif


Return

##########################################################################################################
$DEFBOUT
Return

##########################################################################################################
$SETBOUT
If ISDIRTY
    ETABOU(GVALI) = 1
Else
    ETABOU(GVALI) = 0
Endif
Return

##########################################################################################################
$OUVRE_BOITE
Return

##########################################################################################################
$DEBUT

#LSE 20/06/2006 FQ36654
Global Char GSZDOONUMSAVE (30) (dim([M:DOO2]DOONUM))
Global Integer GINBDOONUMSAVE
Raz GSZDOONUMSAVE
GINBDOONUMSAVE=0



#Affiche le nom du client concerné en clair.
Read [BPR] BPR0 = PARAM(1)
If !fstat
    [M:DOO2]BPC = [F:BPR]BPRNAM
Endif


#Renseigne la mention Client interne
Read [DBI] DBI0 = PARAM(1)
If fstat
    [M:DOO2]INTBPC = 2
Else
    [M:DOO2]INTBPC = [F:DBI]INTBPC
Endif

#LSE 20/06/2006 FQ36654
Gosub LOAD
#Remplit le tableau des associations Client/Donneur d'ordre.
#Local Integer I
#I = 0
#Filter [DBL] Where [F:DBL]BPCNUM = PARAM(1)
#For [DBL] DBL2
#    [M:DOO2]DOONUM(I) = [F:DBL]DOONUM#
#
#    #LSE 20/06/2006 FQ36654
#    GSZDOONUMSAVE(GINBDOONUMSAVE)=[F:DBL]DOONUM
#    GINBDOONUMSAVE=GINBDOONUMSAVE+1#
#
#    Read [BPR] BPR0 = [F:DBL]DOONUM
#    If !fstat
#        [M:DOO2]DOONUMX(I) = [F:BPR]BPRNAM
#        Read [BPA] BPA0 = 1;[M:DOO2]DOONUM(I);[F:BPR]BPAADD
#        If !fstat
#            [M:DOO2]DOOZIP(I) = [F:BPA]POSCOD
#            [M:DOO2]DOOCTY(I) = [F:BPA]CTY
#        Endif
#    Endif
#    I += 1
#Next
#Filter [DBL]
#
#[M:DOO2]NBDOO = I
#Affzo [M:DOO2]1-99
Return

##########################################################################################################
$AV_CHOIX
Return

##########################################################################################################
$AP_CHOIX
Return

##########################################################################################################
$AVANT_BOUTON
Return

##########################################################################################################
$FINSAI
#Nettoie l'écran avant de partir.
Raz [M:DOO2]
Close Local File [DBL]
Close Local File [DBI]
Close Local File [BPA]
Kill ISDIRTY

Kill GSZDOONUMSAVE
Kill GINBDOONUMSAVE

Return

##########################################################################################################
$FIN
Return

##########################################################################################################
$ABANDON
Return

##########################################################################################################
$APRES_MODIF
ISDIRTY = 1
Return

##########################################################################################################
$BOUTON
Return

##########################################################################################################
$ONMENU
Return

##########################################################################################################
$ONOK
Gosub ONSAVE
FIN = 0
Return

#########################################################
# Sous-programmes
#########################################################
##########################################################################################################
$ONSAVE
Local Integer Z
Z = 0

Local Integer IINDICE
Local Integer IINDICEMASK
Local Integer IBERROR
Local Integer IBTROUVE

If GINBDOONUMSAVE>0
    Local Char SZDOONUM_SUP (30)(GINBDOONUMSAVE)
Else
    Local Char SZDOONUM_SUP (30)(50)
Endif
Raz SZDOONUM_SUP
Local Integer INBDOONUM_SUP
INBDOONUM_SUP=0

IINDICE=0
IINDICEMASK=0
IBERROR=0
IBTROUVE=0

Call DEBTRANS From GLOCK

#Création de la mention Client interne
Readlock [DBI] DBI0 = PARAM(1)
If fstat = 5
    #Enregistrement non trouvé, il faut le créer
    [F:DBI]BPCNUM = PARAM(1)
    [F:DBI]BPCNAM = [M:DOO2]BPC
    Read [BPR] BPR0 = PARAM(1)
    If fstat
        [F:DBI]BPCSHO = PARAM(1)
    Else
        [F:DBI]BPCSHO = [F:BPR]BPRSHO
    Endif
    [F:DBI]INTBPC = [M:DOO2]INTBPC
    Trbegin [DBI]
    Write [DBI]
    If fstat
        Rollback
        Return
    Else
        Commit
    Endif
Elsif fstat = 0
    #Enregistrement trouvé, il faut le réécrire pour préserver les éventuelles modifs.
    [F:DBI]BPCNUM = PARAM(1)
    [F:DBI]BPCNAM = [M:DOO2]BPC
    Read [BPR] BPR0 = PARAM(1)
    If fstat
        [F:DBI]BPCSHO = PARAM(1)
    Else
        [F:DBI]BPCSHO = [F:BPR]BPRSHO
    Endif
    [F:DBI]INTBPC = [M:DOO2]INTBPC
    Trbegin [DBI]
    Rewrite [DBI]
    If fstat
        Rollback
        Return
    Else
        Commit
    Endif
Endif

#Création des associations
For Z = 0 To ([M:DOO2]NBDOO - 1)
    If [M:DOO2]DOONUM(Z) <> ""
        Readlock [DBL] DBL0 = [M:DOO2]DOONUM(Z);PARAM(1)
        If fstat = 5
            #Enregistrement non trouvé, il faut le créer
            [F:DBL]DOONUM = [M:DOO2]DOONUM(Z)
            [F:DBL]DOONAM = [M:DOO2]DOONUMX(Z)
            [F:DBL]BPCNUM = PARAM(1)
            Read [BPR] BPR0 = PARAM(1)
            If fstat
                [F:DBL]BPCNAM = PARAM(1)
                [F:DBL]BPCSHO = PARAM(1)
            Else
                [F:DBL]BPCNAM = [F:BPR]BPRNAM
                [F:DBL]BPCSHO = [F:BPR]BPRSHO
            Endif
            Trbegin [DBL]
            Write [DBL]
            If fstat
                Rollback
                Return
            Endif
        Elsif fstat = 0
            #Enregistrement trouvé, il faut le réécrire pour préserver les éventuelles modifs.
            [F:DBL]DOONUM = [M:DOO2]DOONUM(Z)
            [F:DBL]DOONAM = [M:DOO2]DOONUMX(Z)
            [F:DBL]BPCNUM = PARAM(1)
            Read [BPR] BPR0 = PARAM(1)
            If fstat
                [F:DBL]BPCNAM = PARAM(1)
                [F:DBL]BPCSHO = PARAM(1)
            Else
                [F:DBL]BPCNAM = [F:BPR]BPRNAM
                [F:DBL]BPCSHO = [F:BPR]BPRSHO
            Endif
            Trbegin [DBL]
            Rewrite [DBL]
            If fstat
                Rollback
                Return
            Endif
        Endif
        Commit
    Endif
Next


#traitements des enregistrements supprimés
If GINBDOONUMSAVE>0 and IBERROR=0
    #On avait des enregistrments au début
    IINDICE=0
    While IINDICE < GINBDOONUMSAVE
        IBTROUVE=0
        If GSZDOONUMSAVE(IINDICE)<>""
            IINDICEMASK=0
            
            While IINDICEMASK<[M:DOO2]NBDOO
                If [M:DOO2]DOONUM(IINDICEMASK)=GSZDOONUMSAVE(IINDICE)
                    IBTROUVE=1
                    Break
                Endif
                IINDICEMASK=IINDICEMASK+1
            Wend
        Endif
        If IBTROUVE=0
            SZDOONUM_SUP ( INBDOONUM_SUP)=GSZDOONUMSAVE(IINDICE)
            INBDOONUM_SUP=INBDOONUM_SUP+1
        Endif
        IINDICE=IINDICE+1
    Wend
Endif 

If INBDOONUM_SUP>0 and IBERROR=0
    Call DEBTRANS From GLOCK
    Trbegin [DBL]
    
    IINDICE=0
    While IINDICE <INBDOONUM_SUP
        Delete [DBL] Where [F:DBL]DOONUM=SZDOONUM_SUP(IINDICE ) and [F:DBL]BPCNUM= PARAM(1)
        If fstat <>0
            IBERROR=1
        Endif
        If IBERROR=1
            Break
        Endif
        IINDICE=IINDICE+1
    Wend
    If IBERROR=0
        Commit
    Else
        Rollback
    Endif
Endif   
    


ISDIRTY = 0
ETABOU(GSPE1) = 0

Gosub LOAD

Return

##########################################################################################################
$LOAD

Raz GSZDOONUMSAVE
GINBDOONUMSAVE=0

#Remplit le tableau des associations Client/Donneur d'ordre.
Local Integer I
I = 0
Filter [DBL] Where [F:DBL]BPCNUM = PARAM(1)
For [DBL] DBL2
    [M:DOO2]DOONUM(I) = [F:DBL]DOONUM

    #LSE 20/06/2006 FQ36654
    GSZDOONUMSAVE(GINBDOONUMSAVE)=[F:DBL]DOONUM
    GINBDOONUMSAVE=GINBDOONUMSAVE+1

    Read [BPR] BPR0 = [F:DBL]DOONUM
    If !fstat
        [M:DOO2]DOONUMX(I) = [F:BPR]BPRNAM
        Read [BPA] BPA0 = 1;[M:DOO2]DOONUM(I);[F:BPR]BPAADD
        If !fstat
            [M:DOO2]DOOZIP(I) = [F:BPA]POSCOD
            [M:DOO2]DOOCTY(I) = [F:BPA]CTY
        Endif
    Endif
    I += 1
Next
Filter [DBL]

[M:DOO2]NBDOO = I
Affzo [M:DOO2]1-99

Return
