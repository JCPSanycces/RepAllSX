#<AdxTL>@(#)2.0.0.0 $Revision$
#############################################################################
# Traitement SDHBPCM_CSTD : Liste livraison --> 2 onglets sur mobile        #
#   Classe représentation SDHBPCM : Liste des livr (2 onglets sur mobile)   #
#   Classe données        SDHBPCM : Liste des livr (2 onglets sur mobile)   #
#############################################################################


##################################
## $METHODS                     ##
##################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
     When ""
        Case [L]AEVENT
          When "AREAD_AFTER"     : Gosub AREAD_AFTER
          When "AINIT"           : Gosub AINIT
        Endcase
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "INIT_TSCCODADI"  : Gosub INIT_TSCCODADI
  Endcase
Return
#--------------------------------------
$PROPERTIES
#Case [L]CURPRO
#Endcase
Return

#######################################################################################
$AINIT
Local Integer IRET

  IRET = fmet this.INIT_TSCCODADI()
Return

##################################
## $AREAD_AFTER                 ##
##################################
$AREAD_AFTER
Local Char VCURRLEG(GLONADI)

  [L]ASTATUS = fmet this.INIT_TSCCODADI()

  # Issue X3-44511 - 2017-06-19 by CPO : Legislation property in Sales class
  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_CURRLEG_FROM_CPY_FCY(this, this.CPY, this.SALFCY, VCURRLEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_SDHTYP_LEG(this, this.SDHTYP, this.CPY, this.SALFCY, VCURRLEG, this.SDHTYP_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_VACBPR_LEG(this, this.VACBPR, this.CPY, this.SALFCY, VCURRLEG, this.VACBPR_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_PTE_LEG(this, this.PTE, this.CPY, this.SALFCY, VCURRLEG, this.PTE_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

  [L]ASTATUS = func TRTLOADPROPLEG_SYRA.INIT_DEP_LEG(this, this.DEP, this.CPY, this.SALFCY, VCURRLEG, this.DEP_LEG)
  If [L]ASTATUS >= [V]CST_AERROR : Return : Endif

Return

#######################################################################################
$INIT_TSCCODADI
Local Integer DIM_STC
Local Integer NI

  DIM_STC = func ASYRFNC.ACTIV("STC")
  # -------------------
  For NI = 1 To DIM_STC
    this.C_TSCCOD(NI).TSCCODADI = NI + 30
  Next NI
  # -------------------
  [L]ARET_VALUE = [V]CST_AOK
Return

