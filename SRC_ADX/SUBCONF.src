#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion du masque CONF
##########################################################################################################
Subprog C_PBLGRPCOV(VALEUR)
Variable Char    VALEUR()
Local Integer I

  If VALEUR = "" Then
    mkstat = 2
    End
  Endif
  Gosub CTLSHORTCUT From SUBPBLB
  #Vérifie si ce code compétence n'a pas déjà été préalablement saisi dans ce tableau
  For I = 0 To dim ([M:CONF]PBLGRPCOV) - 1
    If I <> nolign-1 Then
      If [M:CONF]PBLGRPCOV(I) = VALEUR and [M:CONF]PBLGRPCOV(I) <> "" Then
        VALEUR = ""
        mkstat = 2
        GMESSAGE = mess(431,196,1) #Cette famille de compétence a déjà été saisie.
        GERR = 2
      Endif
    Endif
  Next
End

##########################################################################################################
Subprog IB_NBPBL
  Raz GBOUT1
  Raz GBOUT2
  Raz GBOUT3
  Raz GBOUT4
  If ![M:CONF]DIRTYFLG Then
    If [M:CONF]PBLGRPCOV(nolign-1) <> "" Then
      GBOUT1 = mess(31,124,1)  #Détail
      GBOUT2 = mess(287,182,1)  #Couverture financière
      If [M:CONF]EVRMACFLG <> 2 Then
        If [M:CONF]TPL = 2 Then
          GBOUT4 = mess(294,182,1)  #Croisement avec le parc
        Else
          GBOUT3 = mess(294,182,1)  #Croisement avec le parc
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
Subprog AM_PBLGRPCOV(VALEUR)
Variable Char    VALEUR()

  #Pièces
  [M:CONF]PBLITMICD(nolign-1) = GITMICD
  If [M:CONF]PBLITMICD(nolign-1) = 0 Then
    [M:CONF]PBLITMICD(nolign-1) = 1
  Endif
  #Main d'oeuvre
  [M:CONF]PBLLABICD(nolign-1) = GLABICD
  If [M:CONF]PBLLABICD(nolign-1) = 0 Then
    [M:CONF]PBLLABICD(nolign-1) = 1
  Endif
  #Frais de mission
  [M:CONF]PBLEXSICD(nolign-1) = GEXSICD
  If [M:CONF]PBLEXSICD(nolign-1) = 0 Then
    [M:CONF]PBLEXSICD(nolign-1) = 1
  Endif
  [M:CONF]PBLGRPCOV(nolign-1) = VALEUR
  If [M:CONF]PBLGRPCOV(nolign-1) = "" Then
    [M:CONF]PBLCLA(nolign-1) = ""
  Else
    Read [PBL]PBL0=[M:CONF]PBLGRPCOV(nolign-1)
    If fstat Then
      [M:CONF]PBLCLA(nolign-1) = ""
    Else
      # FGR 23/09/2009 : X3SUIVI58024
      #[M:CONF]PBLCLA(nolign-1) = [F:PBL]GRPPBLDES
      Call LECTEXTRA([M:CONF]PBLCLA(nolign-1),"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
    Endif
  Endif
  Affzo [M:CONF]PBLCLA(nolign-1)
End
