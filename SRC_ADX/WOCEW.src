$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(10)(0..GNBDERNIER)
Local Char     A_BUF2(5)(0..GNBDERNIER)
Local Char     A_BUF3(5)(0..GNBDERNIER)
Local Char     A_BUF4(5)(0..GNBDERNIER)
Local Char     A_BUF5(15)(0..GNBDERNIER)
Local Char     A_BUF6(40)(0..GNBDERNIER)
Local Char     A_BUF7(40)(0..GNBDERNIER)
Local Char     A_BUF8(20)(0..GNBDERNIER)
If clalev([F:CEW9])>0 : Close Local File [CEW9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(10),
& Char     A_TAB2(5),
& Char     A_TAB3(5),
& Char     A_TAB4(5),
& Char     A_TAB5(15),
& Char     A_TAB6(40),
& Char     A_TAB7(40),
& Char     A_TAB8(20)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5,A_BUF6,A_BUF7,A_BUF8
& As [CEW9]
Return

$LEC_DERLU
Read [ID]ID0=[F:CEW]REFNUM
If fstat : Raz [F:ID] : Endif
Return

$CHARGE_DERLU
If clalev([F:CEW9])>0
 Read [CEW9] = [F:CEW9]A_TABI
 [L]CLE = [F:CEW9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:CEW9])>0
 Filter [CEW9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [CEW1] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:CEW9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = [F:CEW]CTRNUM+"~"
 A_CLEDERLU += [F:CEW]CODWRK+"~"
 A_CLEDERLU += [F:CEW]REFNUM+"~"
 A_CLEDERLU += [F:CEW]SRV+"~"
 A_CLEDERLU += [F:CEW]FCY+"~"
 A_CLEDERLU += [F:CEW]CPY+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:CEW9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:CEW9]
 Endif
Endif
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 1
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:CEW]CODWRK"
Call TEXTE(11485,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:10X"
SELFOR(NBSEL) = "K:10c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:CEW]CODWRK"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:CEW]CPY"
Call TEXTE(1343,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:CEW]CPY"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:CEW]FCY"
Call TEXTE(1344,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:CEW]FCY"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:CEW]SRV"
Call TEXTE(18735,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:CEW]SRV"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:CEW]REFNUM"
Call TEXTE(10793,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:15X"
SELFOR(NBSEL) = "K:15c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:CEW]REFNUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:ID]NAM"
Call TEXTE(55,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:40X"
SELFOR(NBSEL) = "K:40X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]NAM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:ID]SRN"
Call TEXTE(1825,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:40X"
SELFOR(NBSEL) = "K:40X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:ID]SRN"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:CEW]CTRNUM"
Call TEXTE(5481,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:20X"
SELFOR(NBSEL) = "K:20X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:CEW]CTRNUM"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:CEW_])=0
 Gosub OUVFIC_LISTE
Endif
Return

