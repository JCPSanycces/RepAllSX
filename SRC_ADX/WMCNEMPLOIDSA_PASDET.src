#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional RSA fields
# Supervisor
## ACLA-CLASSE ## EMPLOIDSA_PASDET
# 2018-11-06 07:05:51 785

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0EMPLOIDSA_PASDET
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_PASCRY From WMC1EMPLOIDSA_PASDET : Gosub TESTALLSTAT
Gosub INIT_PASNUM From WMC1EMPLOIDSA_PASDET : Gosub TESTALLSTAT
Gosub INIT_PASDTE From WMC1EMPLOIDSA_PASDET : Gosub TESTALLSTAT
Gosub INIT_ESSUIDPAS From WMC1EMPLOIDSA_PASDET : Gosub TESTALLSTAT
Gosub AINIT From WMC0EMPLOIDSA_PASDET : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0EMPLOIDSA_PASDET
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0EMPLOIDSA_PASDET
Gosub LNKPRO_PASCRY From WMC1EMPLOIDSA_PASDET : Gosub TESTALLSTAT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



