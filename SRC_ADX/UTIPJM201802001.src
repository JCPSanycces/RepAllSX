#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################################
# UTIPJM201802001
# Issue X3-65941 - 2018-01-12 by FGR
###################################################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM201802001(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM201802001(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer IUPDATE
Local Char SVIEW(30)

  Call ECR_TRACE("UTIPJM201802001: Process Start on : "+DOSSIER,0) From GESECRAN
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".PJMTSKITM"   [JTT]
  Local File =DOSSIER + ".ITMMASTER"   [ITM]
  # --------------------------
  Raz COMPTEUR
  Trbegin [JTT]
  Raz [F:ITM]
  # --------------------------
  Filter [JTT]
&        Where [F:JTT]STOFCY = "" or [F:JTT]CSMTYP = 0 or [F:JTT]ALLSTA = 0 or [F:JTT]ALLTYP = 0 or [F:JTT]DLVSTA = 0 or [F:JTT]ITMDLVFLG = 0
&        Order By [F:JTT]ITMREF
  For [JTT]
    COMPTEUR += 1
    If [F:JTT]STOFCY = "" Then
      [F:JTT]STOFCY = [F:JTT]TASFCY
    Endif
    If [F:JTT]CSMTYP = 0 Then
      [F:JTT]CSMTYP = 1
    Endif
    If [F:JTT]ALLSTA = 0 Then
      [F:JTT]ALLSTA = 1
    Endif
    If [F:JTT]ALLTYP = 0 Then
      [F:JTT]ALLTYP = 2
    Endif
    If [F:JTT]DLVSTA = 0 Then
      [F:JTT]DLVSTA = 1
    Endif
    If [F:JTT]ITMDLVFLG = 0 Then
      If [F:ITM]ITMREF <> [F:JTT]ITMREF Then
        Read [ITM]ITM0=[F:JTT]ITMREF
      Endif
      If [F:ITM]DLVFLG <> 1 and [F:ITM]DLVFLG <> 2 Then
        [F:JTT]ITMDLVFLG = 1
      Else
        [F:JTT]ITMDLVFLG = [F:ITM]DLVFLG
      Endif
    Endif
    #
    Rewrite [JTT]
    If fstat Then
      Call ECR_TRACE("File PJMTSKITM" - [F:JTT]OPPNUM - [F:JTT]TASCOD - num$([F:JTT]ITTSEQ) + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
  Next
  Filter [JTT]
  # --------------------------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM201802001 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM201802001 : records processed with error(s).", 0) From GESECRAN
  Endif
  Close Local File [JTT]
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  Read [ADS]DOSSIER=APPLI
  If fstat Then
    Raz [F:ADS]
  Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMTSKITM","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTSKITM") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201802001(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char APPLI

  If APPLI = GDOSX3 and GADONIX <> 2 Then
    End
  Endif
  # -------------------------
  If filinfo(filpath("FIL","PJMTSKITM","fde",APPLI),0)<=0 : End : Endif
  If func DOSVUE.ISVIEW(APPLI, "PJMTSKITM") : End : Endif
  # -------------------------
  Call MAJ_UTIPJM201802001(APPLI)
End

