######################################################################################################
# Module        : Purchasing / AP/AR Accounting
# Description   : - QR-Code handling in purchase invoices (GESBIS / GESPIH)
######################################################################################################
 # Updates :
 # Date       |Author   |Version|Description
 # 2018-05-24 |Bader    |2018.R5| Remove APRES_CRE_MOD_PIH_QRC and APRES_CRE_MOD_BIS_QRC
 #                                Add CREATION_BIS_QRC and CREATION_PIH_QRC > ACTION CREATION instead of APRES_CRE
 #                                Add MODIF_BIS_QRC and MODIF_PIH_QRC > ACTION MODIF instead of APRES_MOD
 #                                Add LIENS_QRC > called from ACTION LIENS in SUBBIS/SUBPIHA
 #                                Add FIN_ACTION_BIS/PIH > called from ACTION FIN_ACTION in SUBBIS/SUBPIHA
 # 2018-05-29 |Bader    |2018.R5| Use [F:SWIQTMP] record for indication that something changed ([F:SWIQTMP]QRCODTYP = "CHG")
 #                                Use [F:SWIQTMP] record instead of QROK variable ([F:SWIQTMP]VER = "OK")
 #                                to indicate that the QR code structure is correct
 # 2018-06-06 |Bader    |2018.R5| X3-90417 add C_PTE, C_PAM, VERIF_BIS, VERIF_PIH, CONT_AMT_PIH, CONT_AMT_BIS, CONTROL_AMOUNT
 # 2018-06-13 |Bader    |2018.R5| rename SWIQRCLIB to SWIQRCLIB2 > SWIQRCLIB now interface to bank file definition for ISO3 bank file
 # 2018-06-21 |DNE      |2018.R5| Add key component ORIMOD to table SWIQRC
######################################################################################################


#********************************************************************************************
# OUVRE_QRC: create local variables called from OUVRE in SUBPIHA and SUBBIS
#********************************************************************************************
$OUVRE_QRC
  Local Integer QROK : QROK = 2
  If !clalev([F:SWIQRC]) :Local File SWIQRC  [SWIQRC]:Endif #Swiss QR code table angre X3-90379
  If !clalev([F:SWIQTMP]):Local File SWIQRC  [SWIQTMP]:Endif #temporary file handle to check if something changed and if QR code structure is OK
Return


#******************************************************************************************************
# SETBOUT_PIH: disable button “QR code line” (5) when SWIPURQRC = No -> called from SETBOUT in SUBPIHA
#******************************************************************************************************
$SETBOUT_PIH
Call VIREBOUT(CHAINE,"6") From GOBJET     # remove QR code line button from CHAINE -> disabled
If int(val(func AFNC.PARAM("SWIPURQRC", [M:PIH0]FCY))) = 2 and [M:PIH0]PIHTYP < 3  # parameter "Swiss QRC usage purchasing" = yes and type "Invoice"?
   CHAINE += "6"                          # Enable QRC code line button
Endif
Return


#*****************************************************************************************************
# SETBOUT_BIS: disable button “QR code line” (5) when SWIPURQRC = No -> called from SETBOUT in SUBBIS
#*****************************************************************************************************
$SETBOUT_BIS
Call VIREBOUT(CHAINE,"U") From GOBJET     # remove ISR code line button from CHAINE -> disabled
If int(val(func AFNC.PARAM("SWIPURQRC", [M:BIS0]FCY))) = 2 and [M:BIS0]INVTYP = 1  # parameter "Swiss ISR usage purchasing" = yes and type "Invoice"?
   CHAINE += "U"                          # Enable ISR code line button
Endif
Return



#*********************************************************************************
# RAZDUP_PIH: clear fields of Record [F:SWIQRC] in case of duplication of invoice
#*********************************************************************************
$RAZDUP_PIH
Raz [F:SWIQRC]            # clear QR-code record
Return

#*********************************************************************************
# RAZDUP_BIS: clear fields of Record [F:SWIQRC] in case of duplication of invoice
#*********************************************************************************
$RAZDUP_BIS
Raz [F:SWIQRC]            # clear QR-code record
Return


#*********************************************************************************
# RAZCRE_PIH: clear fields of Record [F:SWIQRC]
#*********************************************************************************
$RAZCRE_PIH
Raz [F:SWIQRC]            # clear QR-code record
Return

#*********************************************************************************
# RAZCRE_BIS: clear fields of Record [F:SWIQRC] in case of duplication of invoice
#*********************************************************************************
$RAZCRE_BIS
Raz [F:SWIQRC]            # clear QR-code record
Return

#**********************************************************************************************************************************
# APRES_MODIF_PIH: enable/disable button “QR code line” (6) depending on parameter SWIPURQRC -> called from APRES_MODIF in SUBPIHA
#**********************************************************************************************************************************
$APRES_MODIF_PIH
If COUZON = "FCY"
    Call VIREBOUT(CHAINE,"6") From GOBJET              # remove ISR code line button from CHAINE -> disabled
    If int(val(func AFNC.PARAM("SWIPURQRC", CZ))) = 2  # parameter "Swiss ISR usage purchasing" = yes?
       CHAINE += "6"                                   # Enable ISR code line button
    Endif
    Gosub SETBOUT From GOBJSUB
Elsif COUZON = "PIVTYP"                                # button ISR code line only active for type "Invoice"
    Call VIREBOUT(CHAINE,"6") From GOBJET              # remove ISR code line button from CHAINE -> disabled
    If int(val(func AFNC.PARAM("SWIPURQRC", GFCY))) = 2 and [M:PIH0]PIHTYP < 3 # parameter "Swiss ISR usage purchasing" = yes and "Invoice"?
       CHAINE += "6"                                   # Enable ISR code line button
    Endif
    Gosub SETBOUT From GOBJSUB
Endif
Return


#*********************************************************************************************************************************
# APRES_MODIF_BIS: enable/disable button “QR code line” (U) depending on parameter SWIPURQRC -> called from APRES_MODIF in SUBBIS
#*********************************************************************************************************************************
$APRES_MODIF_BIS
If COUZON = "FCY"
    Call VIREBOUT(CHAINE,"U") From GOBJET              # remove QR code line button from CHAINE -> disabled
    If int(val(func AFNC.PARAM("SWIPURQRC", CZ))) = 2  # parameter "Swiss QR usage purchasing" = yes?
       CHAINE += "U"                                   # Enable QR code line button
    Endif
    Gosub SETBOUT From GOBJSUB
Elsif COUZON = "PIVTYP"                                # button QR code line only active for type "Invoice"
    Call VIREBOUT(CHAINE,"U") From GOBJET              # remove QR code line button from CHAINE -> disabled
    If int(val(func AFNC.PARAM("SWIPURQRC", [M:BIS0]FCY))) = 2 and [M:BIS0]INVTYP = 1 # parameter "Swiss QR usage purchasing" = yes and "Invoice"?
       CHAINE += "U"                                   # Enable QR code line button
    Endif
    Gosub SETBOUT From GOBJSUB
Endif
Return


#****************************************************************************************************************************************
# VERIF_QRC: do additional controls on QR-Code data
#****************************************************************************************************************************************
$VERIF_QRC
  [F:SWIQTMP]VER = "OK"
  If QRLIN(0) <> "SPC" or left$(QRLIN(1),2) <> "01"
    [F:SWIQTMP]VER = "NOK"
    Errbox(mess(101,3648,1))#'No Swiss QR-bill code or QR-bill version not supported'
  Elsif left$(QRLIN(3),2) <> "CH" and left$(QRLIN(3),2) <> "LI"
    [F:SWIQTMP]VER = "NOK"
    Errbox(mess(102,3648,1))#'IBAN country code not supported'
  Elsif QRLIN(17) <> "CHF" and QRLIN(17) <> "EUR"
    [F:SWIQTMP]VER = "NOK"
    Errbox(mess(103,3648,1))#'QR-bill supports only CHF or EUR currency'
  Endif
Return


#****************************************************************************************************************************************
# CREATION_BIS_QRC: Store QR-Code data in DB
# -> called from CREATION in SUBBIS
#****************************************************************************************************************************************
$CREATION_BIS_QRC
  If int(val(func AFNC.PARAM("SWIPURQRC", [M:BIS0]FCY))) = 2 # parameter "Swiss QRC usage purchasing" = yes?
    If [F:SWIQTMP]VER = "OK" and [F:SWIQRC]QRCODTYP = "SPC" Then          # valid QR code and QR code record filled?
      [F:SWIQRC]NUM = [F:PIH]NUM
# 2018-06-21 DNE X3-97615 BEGIN
      [F:SWIQRC]ORIMOD = 6
# 2018-06-21 DNE X3-97615 END
      Write [F:SWIQRC]
    Endif
  Endif
  Raz [F:SWIQTMP]
Return

#****************************************************************************************************************************************
# CREATION_PIH_QRC: Store QR-Code data in DB
# -> called from CREATION in SUBPIHA
#****************************************************************************************************************************************
$CREATION_PIH_QRC
  If int(val(func AFNC.PARAM("SWIPURQRC", [M:PIH0]FCY))) = 2 # parameter "Swiss QRC usage purchasing" = yes?
    If [F:SWIQTMP]VER = "OK" and [F:SWIQRC]QRCODTYP = "SPC" Then          # valid QR code and QR code record filled?
      [F:SWIQRC]NUM = [F:PIH]NUM
# 2018-06-21 DNE X3-97615 BEGIN
      [F:SWIQRC]ORIMOD = 6
# 2018-06-21 DNE X3-97615 END
      Write [F:SWIQRC]
    Endif
  Endif
  Raz [F:SWIQTMP]
Return


#****************************************************************************************************************************************
# MODIF_BIS_QRC: Store QR-Code data in DB
# -> called from MODIF in SUBBIS
#****************************************************************************************************************************************
$MODIF_BIS_QRC
  If int(val(func AFNC.PARAM("SWIPURQRC", [M:BIS0]FCY))) = 2 # parameter "Swiss QRC usage purchasing" = yes?
    If [F:SWIQTMP]VER = "OK" and ([F:SWIQRC]QRCODTYP = "SPC" or [F:SWIQTMP]QRCODTYP = "CHG") Then # valid QR code and QR code record filled or existed before?
      [F:SWIQRC]NUM = [M:BIS0]NUM
#      Filter [F:SWIQRC] Where NUM = [M:BIS0]NUM              # record already exists?
# 2018-06-21 DNE X3-97615 BEGIN
      [F:SWIQRC]ORIMOD = 6
      Filter [F:SWIQRC] Where NUM = [M:BIS0]NUM and ORIMOD = 6 # record already exists?
# 2018-06-21 DNE X3-97615 END
      If rowcount([F:SWIQRC]) > 0                            # found?
        If [F:SWIQRC]QRCODTYP = "SPC"                        # found and still correct QR code
          Rewrite [F:SWIQRC]                                 # update
        Else                                                 # found but QR code removed
#          Delete [F:SWIQRC] Where NUM = [M:BIS0]NUM          # delete
# 2018-06-21 DNE X3-97615 BEGIN
          Delete [F:SWIQRC] Where NUM = [M:BIS0]NUM and ORIMOD = 6 # delete
# 2018-06-21 DNE X3-97615 END
        Endif
      Else
        Write [F:SWIQRC]                                     # no > insert
      Endif
      Filter [F:SWIQRC]
    Endif
  Endif
  Raz [F:SWIQTMP]
Return


#****************************************************************************************************************************************
# MODIF_PIH_QRC: Store QR-Code data in DB
# -> called from MODIF in SUBPIHA
#****************************************************************************************************************************************
$MODIF_PIH_QRC
  If int(val(func AFNC.PARAM("SWIPURQRC", [M:PIH0]FCY))) = 2 # parameter "Swiss QRC usage purchasing" = yes?
    If [F:SWIQTMP]VER = "OK" and ([F:SWIQRC]QRCODTYP = "SPC" or [F:SWIQTMP]QRCODTYP = "CHG") Then # valid QR code and QR code record filled or existed before?
      [F:SWIQRC]NUM = [M:PIH0]NUM
#      Filter [F:SWIQRC] Where NUM = [M:PIH0]NUM              # record already exists?
# 2018-06-21 DNE X3-97615 BEGIN
      [F:SWIQRC]ORIMOD = 6
      Filter [F:SWIQRC] Where NUM = [M:PIH0]NUM and ORIMOD = 6 # record already exists?
# 2018-06-21 DNE X3-97615 END
      If rowcount([F:SWIQRC]) > 0                            # found?
        If [F:SWIQRC]QRCODTYP = "SPC"                        # found and still correct QR code
          Rewrite [F:SWIQRC]                                 # update
        Else                                                 # found but QR code removed
#          Delete [F:SWIQRC] Where NUM = [M:BIS0]NUM          # delete
# 2018-06-21 DNE X3-97615 BEGIN
          Delete [F:SWIQRC] Where NUM = [M:BIS0]NUM and ORIMOD = 6 # delete
# 2018-06-21 DNE X3-97615 END
        Endif
      Else
        Write [F:SWIQRC]                                     # no > insert
      Endif
      Filter [F:SWIQRC]
    Endif
  Endif
  Raz [F:SWIQTMP]
Return


#****************************************************************************************************************************************
# LIENS_QRC: Read QR-Code data from DB
# -> called from LIENS in SUBBIS and SUBPIHA
#****************************************************************************************************************************************
$LIENS_QRC
  If int(val(func AFNC.PARAM("SWIPURQRC", [F:PIH]FCY))) = 2 # parameter "Swiss QRC usage purchasing" = yes?
#    Read [F:SWIQRC]SWIQRC0 = [F:PIH]NUM
# 2018-06-21 DNE X3-97615 BEGIN
    Read [F:SWIQRC]SWIQRC0 = [F:PIH]NUM; 6
# 2018-06-21 DNE X3-97615 END
  Endif
Return


#**************************************************************************************
# FIN_ACTION_BIS: check if something changed -> called from FIN_ACTION in SUBBIS
#**************************************************************************************
$FIN_ACTION_BIS
If int(val(func AFNC.PARAM("SWIPURQRC", [M:BIS0]FCY))) = 2 # parameter "Swiss QRC usage purchasing" = yes?
    # if value changed -> set Save button
    If [F:SWIQTMP]QRCODTYP = "CHG"       # set in SUBQRC.WRITETOREC if something has changed
    # If already IN "Creation" MODE -> SAVE button needs not to be set
       If !find(GREP,"C","D")
          GREP="M" : REP="M"
          If [M:BIS0]NUM<>"" : Gosub GRISE_CLE From =WINPROG : Endif
       Endif
    Endif
Endif
Return


#**************************************************************************************
# FIN_ACTION_PIH: check if something changed -> called from FIN_ACTION in SUBPIHA
#**************************************************************************************
$FIN_ACTION_PIH
If int(val(func AFNC.PARAM("SWIPURQRC", [M:PIH0]FCY))) = 2 # parameter "Swiss QRC usage purchasing" = yes?
    # if value changed -> set Save button
    If [F:SWIQTMP]QRCODTYP = "CHG"       # set in SUBQRC.WRITETOREC if something has changed
    # If already IN "Creation" MODE -> SAVE button needs not to be set
       If !find(GREP,"C","D")
          GREP="M" : REP="M"
          If [M:PIH0]NUM<>"" : Gosub GRISE_CLE From =WINPROG : Endif
       Endif
    Endif
Endif
Return


#****************************************************************************************************************************************
# Annule_BIS_QRC: Delete QR-Code data in DB
# -> called from ANNULE in SUBBIS
#****************************************************************************************************************************************
$ANNULE_BIS_QRC
  If int(val(func AFNC.PARAM("SWIPURQRC", [M:BIS0]FCY))) = 2 # parameter "Swiss QRC usage purchasing" = yes?
    Filter [F:SWIQRC] Where NUM = [M:BIS0]NUM              # record already exists?
    If rowcount([F:SWIQRC]) > 0                            # found?
#      Delete [F:SWIQRC] Where NUM = [M:BIS0]NUM            # delete
# 2018-06-21 DNE X3-97615 BEGIN
      Delete [F:SWIQRC] Where NUM = [M:BIS0]NUM and ORIMOD = 6 # delete
# 2018-06-21 DNE X3-97615 END
    Endif
    Filter [F:SWIQRC]
  Endif
Return


