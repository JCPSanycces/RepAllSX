$ANNULE_PIH_QRC
  If int(val(func AFNC.PARAM("SWIPURQRC", [M:PIH0]FCY))) = 2 # parameter "Swiss QRC usage purchasing" = yes?
#    Filter [F:SWIQRC] Where NUM = [M:PIH0]NUM              # record already exists?
# 2018-06-21 DNE X3-97615 BEGIN
    Filter [F:SWIQRC] Where NUM = [M:PIH0]NUM and ORIMOD = 6 # record already exists?
# 2018-06-21 DNE X3-97615 END
    If rowcount([F:SWIQRC]) > 0                            # found?
#      Delete [F:SWIQRC] Where NUM = [M:PIH0]NUM            # delete
# 2018-06-21 DNE X3-97615 BEGIN
      Delete [F:SWIQRC] Where NUM = [M:PIH0]NUM and ORIMOD = 6 # delete
# 2018-06-21 DNE X3-97615 END
    Endif
    Filter [F:SWIQRC]
  Endif
Return


#****************************************************************************************************************************************
# C_PTE: Check if amount in QR code equals amount in invoice. If no, ask whether QR code data should be deleted
# -> called from C_PTE in SUBBIS2/SUBPIH
#****************************************************************************************************************************************
Subprog C_PTE(VALEUR)
Variable Char    VALEUR()
Local Integer LINVTYP
Local Char LFCY(GLONFCY)
Local Char TEMPPTE(GLONPTE)
Local Char CPY(GLONCPY)

If [F:SWIQRC]QRCODTYP = "" : End : Endif             # no QR code data > nothing to check

If GFONCTION = "GESBIS"
    LINVTYP = [M:BIS0]INVTYP
    LFCY    = [M:BIS0]FCY
Else
    If [M:PIH0]PIHTYP < 3
        LINVTYP = 1
    Else
        LINVTYP = [M:PIH0]PIHTYP
    Endif
    LFCY    = [M:PIH0]FCY
Endif
If LINVTYP = 1                                          # QR code only for type "Invoice"
    If int(val(func AFNC.PARAM("SWIPURQRC", LFCY))) = 2 # parameter "Swiss QRC usage purchasing" = yes?
        Local Integer OK
        Local Integer TYPE_PAM
        Local Char TEMPPTE(GLONPTE)
        Local Char CPY(GLONCPY)
        Local Char XSLEG(GLONADI)

        If GFONCTION = "GESBIS"
            TEMPPTE= [M:BIS1]PTE
            CPY = [M:BIS0]CPY
        Else
            TEMPPTE = [M:PIH1]PTE
            If !clalev([F:XFCY]) : Local File FACILITY [XFCY] : Endif
            Read [F:XFCY]FCY0=[M:PIH0]FCY
            If fstat = 0  # reading ok
              CPY = [F:XFCY]LEGCPY
            Endif
        Endif

        # Get ISR type from payment method
        Raz [L]XSLEG
        Call GET_LEG(CPY,[L]XSLEG) From SWIBVRLIB4
        If !clalev([F:XTPT]) : Local File TABPAYTERM [XTPT] : Endif
        Read [F:XTPT]TPT0 = VALEUR;[L]XSLEG;1
        If fstat
            # Let's give it a 2nd try for "All legislations".
            #
            # Note: For TABPAM table we need "All legislation", too, for a payment term
            #       with "All legislations" can only contain a payment method for
            #       "All legislations" (empty value), too.
            Raz [L]XSLEG
            Read [F:XTPT]TPT0 = VALEUR;[L]XSLEG;1
        Endif
        If !fstat
            If !clalev([F:XTAM]) : Local File TABPAM [XTAM] : Endif
            Read [XTAM]TAM0 = [F:XTPT]PAM;[L]XSLEG
            If fstat
                # Let's give a 2nd try for "All legislations".
                Read [F:XTAM]TAM0 = VALEUR;""
            Endif
            If fstat = 0
               TYPE_PAM = [F:XTAM]TYP
            Endif

            # Check if payment type <> ISO 3 > ask for clearing QR code data
            If [F:XTAM]SWIPAMBVR <> 5 or TYPE_PAM <> 3
                Local Integer LDSPMES : LDSPMES = 0
                LDSPMES = 1
                Call OUINON(mess(96,3648,1),OK) From GESECRAN # The invoice includes QR code data but the payment method type does not support QR codes. Delete?
                If LDSPMES
                    If OK=1 # No
                        mkstat = 2
                        If TEMPPTE<>""
                            VALEUR=TEMPPTE
                        Endif
                    Else
                        Raz [F:SWIQRC]
                    Endif
                Endif
            Endif
        Endif
    Endif
Endif
End


#****************************************************************************************************************************************
# C_PAM: Check if payment term is of type ISO 3. If no, ask whether QR code data should be deleted
# -> called from C_PAM in SUBBIH
#****************************************************************************************************************************************
Subprog C_PAM(VALEUR)
Variable Char VALEUR

Local Integer TYPE_PAM
Local Integer OK
Local Char CPY(GLONCPY)
Local Char FCY(GLONFCY)
Local Char XSLEG(GLONADI)
Raz [L]XSLEG

If [F:SWIQRC]QRCODTYP = "" : End : Endif             # no QR code data > nothing to check

# Initialisations
If GFONCTION = "GESBIS"
    CPY = [M:BIS0]CPY
    FCY = [M:BIS0]FCY
Elsif GFONCTION = "GESPIH"
    If !clalev([F:XFCY]) : Local File FACILITY [XFCY] : Endif
    Read [F:XFCY]FCY0=[M:PIH0]FCY
    If fstat = 0  #lecture ok
      CPY = [F:XFCY]LEGCPY
    Endif
    FCY = [M:PIH0]FCY
Endif

If int(val(func AFNC.PARAM("SWIPURQRC", FCY))) = 2 # parameter "Swiss QRC usage purchasing" = yes?
    Call GET_LEG(CPY,[L]XSLEG) From SWIBVRLIB4
    # Read PAM type from TABPAM
    If !clalev([F:XTAM]) : Local File TABPAM [XTAM] : Endif
    Read [F:XTAM]TAM0 = VALEUR;[L]XSLEG
    If fstat
        # Let's give a 2nd try for "All legislations".
        Read [F:XTAM]TAM0 = VALEUR;""
    Endif
    If fstat = 0
        TYPE_PAM = [F:XTAM]TYP
    Endif

    # Check if payment type <> ISO 3 > ask for clearing QR code data
    If [F:XTAM]SWIPAMBVR <> 5 or TYPE_PAM <> 3
        Local Integer LDSPMES : LDSPMES = 0
        LDSPMES = 1
        Call OUINON(mess(96,3648,1),OK) From GESECRAN # The invoice includes QR code data but the payment method type does not support QR codes. Delete?
        If LDSPMES
            If OK=2 # Yes
                Raz [F:SWIQRC]
            Endif
        Endif
    Endif
Endif
End
#*****************************************************************************************************



#****************************************************************************************************************************************
# VERIF_BIS: Check the correctness of the amount (QR code <-> invoice) in supplier BP invoices
# -> called from VERIF_CRE and VERIF_MOD in SUBPIH
#****************************************************************************************************************************************
$VERIF_BIS
If [M:BIS0]INVTYP = 1                              # QR code only for type "Invoice"
    If int(val(func AFNC.PARAM("SWIPURQRC", [M:BIS0]FCY))) = 2 # parameter "Swiss QRC usage purchasing" = yes?
        # verify consistency of amount
        Call CONT_AMT_BIS()
    Endif
Endif
Return


#****************************************************************************************************************************************
# VERIF_PIH: Check the correctness of the amount (QR code <-> invoice) in invoice control
# -> called from VERIF_CRE and VERIF_MOD in SUBPIH
#****************************************************************************************************************************************
$VERIF_PIH
If [M:PIH0]PIHTYP < 3                               # QR code only for type "Invoice"
    If int(val(func AFNC.PARAM("SWIPURQRC", [M:PIH0]FCY))) = 2 # parameter "Swiss QRC usage purchasing" = yes?
        # verify consistency of amount
        Call CONT_AMT_PIH()
    Endif
Endif
Return


#*****************************************************************************************************
# CONT_AMT_PIH: Check the correctness of the amount (QR code <-> invoice) in invoice control
#*****************************************************************************************************
Subprog CONT_AMT_PIH()
Local Decimal TOTAL

TOTAL = [M:PIH4]AMTATI
Gosub CONTROL_AMOUNT
End
#*****************************************************************************************************

#*****************************************************************************************************
# CONT_AMT_BIS: Check the correctness of the amount (QR code <-> invoice) in supplier BP invoices
#*****************************************************************************************************
Subprog CONT_AMT_BIS()
Local Decimal TOTAL

TOTAL = [M:BIS3]TOTATI
Gosub CONTROL_AMOUNT
End
#*****************************************************************************************************



#*****************************************************************************************************
# CONTROL_AMOUNT: Check the correctness of the amount (QR code <-> invoice). Called from CONT_AMT_BIS and CONT_AMT_PIH
#*****************************************************************************************************
$CONTROL_AMOUNT
Local Decimal AMOUNT

If [F:SWIQRC]AMT <> ""                    # amount given in QR code data
    AMOUNT = val([F:SWIQRC]AMT)
    If AMOUNT>0 & TOTAL>0
        # Test if the amounts are equal
        If AMOUNT<>TOTAL
            If !GIMPORT
                GERR=2 : GMESSAGE=mess(97,3648,1)  # Total inconsistent with the total amount of the QR code data on the invoice.
            Endif
        Endif
    Endif
Endif
Return
#*****************************************************************************************************

