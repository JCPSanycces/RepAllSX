#<AdxTL>@(#)2.0.0.0 $Revision$
##**
## Delta POST management
##*!

#**
#* PARSEDELTA(ACTX,JSON,UPD)
#*
#* @param ACTX
#* @param JSON
#* @param UPD
#*!
Funprog PARSEDELTA(ACTX,JSON,DELTAS)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Clbfile JSON
Variable Instance  DELTAS(1..)       Using C_ADELTA

Local Integer ASTATUS
Local Instance  NODES(1..)  Using C_ASYRJSO
Local Instance  NODE  Using C_ASYRJSO
Local Instance  PNODE  Using C_ASYRJSO
Local Uuident   UID   : UID = NullUuid

ASTATUS = func ASYRJSONPARSE.PARSEJSON(ACTX,JSON,NODES,NODE)
If ASTATUS = 0
 Call WALKPROPERTIES(DELTAS,NODE,UID,UID,"","")
Endif
FREEGROUP NODES(1)
End ASTATUS

#**
#* WALKPROPERTIES
#*!
Subprog WALKPROPERTIES(DELTAS,NODE,UIDFF,UIDFC,FATHER,COL)
Variable Instance  DELTAS Using C_ADELTA
Variable Instance  NODE  Using C_ASYRJSO
Value    Uuident   UIDFF
Value    Uuident   UIDFC
Value    Char      FATHER
Value    Char      COL

Local Char      PRO(250)
Local Instance  PNODE          Using C_ASYRJSO
Local Instance  PATTRIBUTES    Using C_ASYRJSO
Local Instance  PATTRIBUTE     Using C_ASYRJSO
Local Instance  PACTIONS       Using C_ASYRJSO
Local Instance  PACTION        Using C_ASYRJSO
Local Instance  PVALUE         Using C_ASYRJSO
Local Instance  PITEM          Using C_ASYRJSO
Local Instance  PDELTA         Using C_ADELTA
Local Uuident   UIDCF : UIDCF = UIDFF
Local Uuident   UIDCC : UIDCC = UIDFC
Local Integer   INDEX
Local Char      ISDELETED(250) : ISDELETED=""
Local Integer   IND



#1°) Loop on attributes:
PNODE=NODE
While PNODE <> null
 Case PNODE.PRO
  When "$uuid"     :
    UIDCF = UIDCC
    UIDCC = toUuid(mid$(NODE.CNT,2 ,len(NODE.CNT)-2))
  When "$value"    : PVALUE      = PNODE
  When "$index"    : INDEX       = val(PNODE.CNT)
  When "$isDeleted": ISDELETED   = PNODE.CNT
  When "$actions"  : PACTIONS    = PNODE
  When "$"         : PATTRIBUTES = PNODE
 Endcase
 PNODE = PNODE.NEX
Wend

#2°) "$value"
If PVALUE <> null
  Call ADDDELTA(PDELTA,DELTAS,PVALUE,"",FATHER,UIDCF,UIDCC,ISDELETED,0)
Endif

#3°) common attributes = $
If PATTRIBUTES <> null
 PNODE = PATTRIBUTES.SUB
 While PNODE <> null
  Call ADDDELTA(PDELTA,DELTAS,PNODE,COL,PNODE.PRO,UIDCF,UIDCC,ISDELETED,0)
  PATTRIBUTE = PNODE.SUB
  While PATTRIBUTE <> null
   PDELTA.ATT(maxtab(PDELTA.ATT)+1)   = NewInstance [UPD],C_ADELTAATT
   PDELTA.ATT(maxtab(PDELTA.ATT)).COD = PATTRIBUTE.PRO
   PDELTA.ATT(maxtab(PDELTA.ATT)).ATT = PATTRIBUTE.CNT
   PATTRIBUTE        = PATTRIBUTE.NEX
  Wend
  PNODE = PNODE.NEX
 Wend
Endif

#4°) Loop on actions:
If PACTIONS <> null
 PACTION = PACTIONS.SUB
 While PACTION <> null
  PATTRIBUTE = PACTION.SUB
  While PATTRIBUTE <> null
   Call ADDDELTA(PDELTA,DELTAS,PATTRIBUTE,COL,PACTION.PRO,UIDCF,UIDCC,ISDELETED,INDEX)
   PDELTA.ATT(1)     = NewInstance [UPD],C_ADELTAATT
   PDELTA.ATT(1).COD = PATTRIBUTE.PRO
   PDELTA.ATT(1).ATT = PATTRIBUTE.CNT
   PATTRIBUTE = PATTRIBUTE.NEX
  Wend
  PACTION = PACTION.NEX
 Wend
Endif

#5°) Loop on properties:
PNODE=NODE
While PNODE <> null
 If  "$" <> left$(PNODE.PRO,1)
  If len(FATHER) > 0
   PRO = FATHER
   If INDEX > 0
    PRO += "(" + num$(INDEX) + ")"
   Endif
   If len(PNODE.PRO)> 0
    PRO += "." + PNODE.PRO
   Endif
  Else
   PRO = PNODE.PRO
  Endif
  If PNODE.TYP = 1
   #it's an object
   Call WALKPROPERTIES(DELTAS,PNODE.SUB,UIDCF,UIDCC,PRO,"")
  Elsif PNODE.TYP = 2
   #it's an array:
   IND   = 0
   PITEM = PNODE.SUB
   While PITEM <> null
    If PITEM.TYP = 1
     #it's an object
     Call WALKPROPERTIES(DELTAS,PITEM.SUB,UIDCF,UIDCC,PRO,PNODE.PRO)
    Else
     Call ADDDELTA(PDELTA,DELTAS,PITEM,PNODE.PRO,PRO,UIDCF,UIDCC,ISDELETED,IND)
    Endif
    IND  += 1
    PITEM = PITEM.NEX
   Wend
  Else
   Call ADDDELTA(PDELTA,DELTAS,PNODE,COL,PRO,UIDCF,UIDCC,ISDELETED,0)
  Endif
 Endif
 PNODE = PNODE.NEX
Wend

End

#**
#* ADDDELTA
#*!
Subprog ADDDELTA(PDELTA,DELTAS,NODE,COL,PRO,UIDPAR,UID,ISDELETED,IND)
Variable Instance  PDELTA Using C_ADELTA
Variable Instance  DELTAS(1..) Using C_ADELTA
Variable Instance  NODE  Using C_ASYRJSO
Value    Char      COL
Value    Char      PRO
Value    Uuident   UIDPAR
Value    Uuident   UID
Value    Char      ISDELETED
Value    Integer   IND

Local Integer K

PDELTA = NewInstance [UPD] With C_ADELTA
PDELTA.COL     = COL
PDELTA.PRO     = PRO
PDELTA.UIDPAR  = UIDPAR
PDELTA.UID     = UID
PDELTA.IND     = IND

If NODE.CLB = null
 #PDELTA.CAR     = NewInstance [UPD],C_ADELTACAR
 #PDELTA.CAR.CAR = NODE.CNT
 K = func ASYRSUB.ASETCHR(PDELTA.CHR,NODE.CNT)
Else
 #PDELTA.CLB     = NewInstance [UPD],C_ADELTACLB
 #PDELTA.CLB.CLB = NODE.CLB.CLB
 K = func ASYRSUB.ASETCHR(PDELTA.CHR,NODE.CLB.CLB)
Endif

If len(ISDELETED) > 0
 PDELTA.ATT(1)     = NewInstance [UPD],C_ADELTAATT
 PDELTA.ATT(1).COD = "$isDeleted"
 PDELTA.ATT(1).ATT = "true"
Endif


DELTAS(maxtab(DELTAS)+1) = PDELTA

End
