#<AdxTL>@(#)0.0.0.0 $Revision$
$ENUM_WHAT
Local Integer E_WHAT_NONE       : E_WHAT_NONE=0
Local Integer E_WHAT_V6WORD  : E_WHAT_V6WORD = E_WHAT_NONE+1
Local Integer E_WHAT_V6EXCEL : E_WHAT_V6EXCEL= E_WHAT_V6WORD+1
Local Integer E_WHAT_V7WORD  : E_WHAT_V7WORD = E_WHAT_V6EXCEL+1
Return

#**
#* OFFICE_INT_DOCS_V6
#* This function has to lookup the X3 blob table for the given object and keys.
#* If there are matching documents, the function must generate a link
#* for each document. This link will be visible on the convergence page.
#*
#* @param FNNAME :fnName - Name of the X3 function (e.g. GESSQH)
#* @param IDENT1 : first key field of the current record (e.g. SQHNUM)
#* @param IDENT2 : second key field of the current record (e.g. SQHNUM)
#* @param IDENT3 : third key field of the current record (e.g. SQHNUM)
#*!
Funprog OFFICE_INT_DOCS_V6(FNNAME,CLASSNAME,REPRNAME,KEYS,WHAT,URL)
Value Char FNNAME
Value Char CLASSNAME
Value Char REPRNAME
Value Char KEYS()(1..)
Variable Integer WHAT
Variable Clbfile URL

Gosub ENUM_WHAT
WHAT = E_WHAT_NONE

Local Integer ASTATUS : ASTATUS=0
Local Char IDENT1(250),IDENT2(250),IDENT3(250)

Local Integer I,J
Local Char FILNAME(250)
Local Char SEP(1)
Local Char AURLSEPLOB(3): AURLSEPLOB='~'

Local Clbfile DOCURL
Local Integer POS
Local Schar SEP1(1)
Local Schar SEP2(1)

Local Char CLE1(GLONID2),CLE2(GLONID2)(1..),CLE3(GLONID2),CLEBIS(GLONID2)

If !len(FNNAME) : End CST_AERROR : Endif
#If adxusr='eboyard' : Dbgaff : Endif
Gosub SETCLE From ="WO"+FNNAME

Local Integer ETAT
For I=1 To dim(KEYS)
 Case ETAT
  When 0 :
   CLE1 = KEYS(1)
   ETAT = 1
   FILNAME = CLE1+[V]CST_TILDE
  When 1 :
   CLEBIS += SEP1 + KEYS(I)
   FILNAME += SEP2 + KEYS(I)
   SEP1 = [V]CST_TILDE
   SEP2 = [V]CST_ESCTILDE
   J += 1 :
   If J > dim(CLESEC) or (len(CLELIG)  and CLESEC(J) = CLELIG)
    ETAT = 2
   Endif
  When 2 :
   CLE3 = KEYS(I)
   FILNAME = [V]CST_TILDE+CLE3
   ETAT = 3
 Endcase
Next I

POS = instr(8+1,baseUrl,"/")

If POS
 Raz URL

 Local File AOBJBUR [AOA] Where ABREV=FNNAME & IDENT1=[L]CLE1 & IDENT2=[L]CLEBIS & IDENT3=[L]CLE3
 Read [AOA] First
 If !fstat
  DOCURL= 'http://'
  Append DOCURL,left$(right$(baseUrl,8),POS-8)+"/sdata"+right$(baseUrl,POS+6)
#  Append DOCURL,"/"+[V]CST_AURLBLOB
#  Append DOCURL,"('C_AOBJBUR"+[L]AURLSEPLOB+"BLOB"+[L]AURLSEPLOB
  Append DOCURL,"/AOBJBUR"
  Append DOCURL,"('"
  Append DOCURL,FNNAME
  Append DOCURL,[L]AURLSEPLOB
  Append DOCURL,ctrans([AOA]IDENT1,[V]CST_TILDE,[V]CST_ESCTILDE)
  Append DOCURL,[L]AURLSEPLOB
  If len([AOA]IDENT2)
   Append DOCURL,ctrans([AOA]IDENT2,[V]CST_TILDE,[V]CST_ESCTILDE)
  Endif
  Append DOCURL,[L]AURLSEPLOB
  If len([AOA]IDENT3)
   Append DOCURL,[AOA]IDENT3
  Endif  #Append DOCURL,"')"
  Append DOCURL,"')?representation=AOBJBUR.$details"

  Case [AOA]TYP
   When 5 : WHAT = E_WHAT_V6WORD
   When 6 : WHAT = E_WHAT_V6EXCEL
   When Default : WHAT = E_WHAT_NONE : ASTATUS = CST_AERROR
  Endcase

  #Call BUILD_URL(FNNAME, CLASSNAME, REPRNAME , KEYS,  DOCURL,WHAT, URL)
  URL = DOCURL
  Else
  ASTATUS = CST_AERROR
 Endif
 Close File [AOA]
Endif
End ASTATUS

#**
#* OFFICE_INT_DOCS
#*
#* @param CLASSNAME : Name of the X3 class
#* @param KEYS : Values of the key fields of the current record (e.g. SQHNUM)
#* @param REPRNAME : Name of the X3 classname
#*!
Funprog OFFICE_INT_DOCS(CLASSNAME , REPRNAME ,KEYS,WHAT, URL)
Value Char CLASSNAME
Value Char KEYS()(1..)
Value Char REPRNAME
Variable Integer WHAT
Variable Clbfile URL

Local Clbfile URL
Local Clbfile RESHEAD
Local Clbfile FILTERS
Local Char FILTERS_COD(60)(1..)
Local Char FILTERS_VAL(60)(1..)
Local Integer POS
Local Char VOLUME(50)
Local Integer AI,AJ
Local Char SEP(1)
Local Char   TAG_BR(10)
Local Char FILNAME(250)
Local Integer ASTATUS : ASTATUS=0
Local Clbfile DOCURL


Gosub ENUM_WHAT

Raz URL

POS = instr(8+1,baseUrl,"/")
 If  POS>0

 #className
Append FILTERS, "(className eq '"+ CLASSNAME + "')"

 #x3Keys
SEP=""
Append FILTERS, " and (x3Keys eq '"
For AJ=1 To dim(KEYS)
 Break  (KEYS(AJ) = "")
 #FILTERS_VAL(AI) +=  SEP + KEYS(AJ)
 Append FILTERS,SEP + KEYS(AJ)
 SEP = "~"
Next AJ
Append FILTERS, "')"

 #REPRNAME
Append FILTERS," and (representationName eq '" + REPRNAME+".$details')"

 Local Char EXPECTED_PROPS(50)(1..)
 Local Integer AN : AN=0
 AN+=1 : EXPECTED_PROPS(AN) = "$uuid"
 AN+=1 : EXPECTED_PROPS(AN) = "fileName"
 AN+=1 : EXPECTED_PROPS(AN) = "documentType"
 Local Char VALUES(250)(1..,1..AN) :#SAM strings extanded to 250 characters

 STATUSCODE = func ASYRSAREA.LIST(FILTERS, EXPECTED_PROPS, 0, RESHEAD, VALUES)
 If STATUSCODE = 200
  For AI=1 To dim(VALUES)
   Break  (VALUES(AI,1) = "")

   #DOCURL= 'http://' :# CCL 116507
   [L]DOCURL  = left$(baseUrl,instr(1,baseUrl,"/")-1)+"//"
   Append DOCURL,left$(right$(baseUrl,8),POS-8)+"/sdata/syracuse/collaboration/syracuse/documents(%27"
   Append DOCURL,VALUES(AI,1)
   Append DOCURL, '%27)/content?mime='
   Append DOCURL, VALUES(AI,3)
   Append DOCURL, '&filename='
   Append DOCURL, VALUES(AI,2)
   WHAT = E_WHAT_V7WORD

   Call BUILD_URL("", CLASSNAME , REPRNAME , KEYS,  DOCURL, WHAT, URL)
   Break :#we just take the first element !
  Next AI
 Endif
Endif
End ASTATUS

#**
#* OFFICE_INT_NEW_DOC
#*
#* @param CLASSNAME :Name of the X3 class. Required to create the sdata URL from
#* which the data will be fetched
#* @param KEYS :Values of the key fields of the current record
#* @param REPRNAME :REPRNAME - Name of the syrapedia
#* representation that is used to select a template matching this representation.
#* Also required to create the sdata URL from which the data will be fetched.
#* @param TPL : Tags to be used when filtering templates.
#*
#* className -
#*!
Funprog OFFICE_INT_NEW_DOC(CLASSNAME, KEYS, REPRNAME)
Value Char CLASSNAME
Value Char KEYS()(1..)
Value Char REPRNAME

Local Integer AI
Local Char AKEY(250),SEP(1)
SEP=''
 For AI=1 To dim(KEYS)
  Break  (KEYS(AI) = "")
  AKEY +=  SEP + KEYS(AI)
  SEP = '~'
 Next AI

Local Char TPL(20)(1..1,1..2)
 T += 1 : TPL(T,1)="$msoRepr" : TPL(T,2)=REPRNAME+".$details"
#T += 1 : TPL(T,1)="$msoLocale" : TPL(T,2)="es-US"
#T += 1 : TPL(T,1)="$msoCpy" : TPL(T,2)="AAA"
#T += 1 : TPL(T,1)="$msoLeg" : TPL(T,2)="BRI"
#T += 1 : TPL(T,1)="$msoActiv" : TPL(T,2)="XGER"
#T += 1 : TPL(T,1)="$msoEndpoint" : TPL(T,2)="x3.erp.SYDEV"


Local Clbfile JSON
Append JSON,'"$wordreport":{'
Append JSON,'"$title":"{@23634}",'
Append JSON,'"$target":"",'
Append JSON,'"$type":"application/syracuse-word-report",'
Append JSON,'"$url":"{$baseUrl}/'
Append JSON,CLASSNAME
Append JSON,'(%27'
Append JSON,AKEY
Append JSON,'%27)?representation='
Append JSON,REPRNAME
Append JSON,'.$details&role={$role}&reportMode={reportMode}&doc_uuid={document}",'
Append JSON,'"$parameters":{'
Append JSON,'"$url":"/sdata/syracuse/collaboration/syracuse/msoReportModes/$template/$workingCopies?representation=msoReportMode.$edit'
Append JSON,'&role={$role}'

 For AI=1 To dim(TPL)
  Break  (TPL(AI,1) = "")
  Append JSON,'&'
  Append JSON,TPL(AI,1)
  Append JSON,'='
  Append JSON,TPL(AI,2)
 Next AI

Append JSON,'","$method":"POST",'
Append JSON,'"$properties":{'
Append JSON,'"dummy":{'
Append JSON,'"$title":"dummy",'
Append JSON,'"$type":"application/x-string"'
Append JSON,'}':#dummy
Append JSON,'}':#$properties
Append JSON,'}'#$parameters
Append JSON,'}':#$wordreport

End JSON


#**
#* BUILD_URL
#*
#* @param FNNAME
#* @param CLASSNAME
#* @param REPRNAME
#* @param KEYS
#* @param TPL
#* @param WHAT
#* @param URL
#*!
Subprog  BUILD_URL(FNNAME, CLASSNAME, REPRNAME, KEYS,  DOCURL,WHAT, URL)
Value Char FNNAME
Value Char CLASSNAME
Value Char REPRNAME
Value Char KEYS()(1..)
Value Clbfile DOCURL
Variable Integer WHAT
Variable Clbfile URL

Local Char SEP(1)

Gosub ENUM_WHAT

URL= collaborationBaseUrl
Append URL,"/v6DocumentProxies('"
For I=1 To dim(KEYS)
  Break  (KEYS(I) = "")
  Append URL,SEP
  Append URL, KEYS(I)
  SEP='~'
Next I
Append URL,"')?representation=v6DocumentProxy.$details"
If len(FNNAME) >0          : Append URL,'&fnName='        : Append URL, FNNAME :Endif
If len(CLASSNAME)>0     : Append URL,'&className='  : Append URL, CLASSNAME :Endif
If len(REPRNAME)>0       : Append URL,'&reprName='    : Append URL, REPRNAME :Endif

Append URL,'&what='
Case WHAT
 When E_WHAT_NONE       : Append URL,"NONE"
 When E_WHAT_V6WORD  : Append URL,"V6WORD"
 When E_WHAT_V6EXCEL : Append URL,"V6EXCEL"
 When E_WHAT_V7WORD  : Append URL,"V7WORD"
Endcase
If len(DOCURL )>0       : Append URL,'&documentUrl='     : Append URL, DOCURL :Endif
End

#**
#* OFFICE_DOC
#*
#* @param FNNAME
#* @param CLASSNAME
#* @param REPRNAME
#* @param KEYS
#* @param LANISO
#* @param COMPANY
#* @param LEGISLATION
#* @param ACTIVITY_CODE
#*!
Funprog OFFICE_DOC(FNNAME, CLASSNAME, REPRNAME, KEYS,LANISO,COMPANY,LEGISLATION,ACTIVITY_CODE)
Value Char FNNAME
Value Char CLASSNAME
Value Char REPRNAME
Value Char KEYS()(1..)
Value Char LANISO
Value Char COMPANY
Value Char LEGISLATION
Value Char ACTIVITY_CODE

Local Integer WHAT
Local Clbfile URL

#return code
Local Integer ASTATUS : ASTATUS=0

Gosub ENUM_WHAT

#What default value :
WHAT = E_WHAT_NONE

# 1°) Try to open a V6 document
ASTATUS = func OFFICE_INT_DOCS_V6(FNNAME,CLASSNAME, REPRNAME,KEYS,WHAT,URL)
If ASTATUS and ( len(CLASSNAME) and len(REPRNAME))
 #no world or excel document was found in the X3 database :
 ASTATUS = func OFFICE_INT_DOCS(CLASSNAME ,REPRNAME,KEYS, WHAT, URL)
Endif

Local Clbfile DEF
Local Clbfile STA
Local Char ID(20)
Local Char SEP(1)
Local Char ENDPOINT(50)
Local Integer AK,POS

ID = "office_link"
STA = '{"$isDisabled": false}'

If len(URL)
 DEF = '{"$type": "application/json","$target":"blank","$url": "'
 Append DEF, URL
 Append DEF , '"'
 Append DEF, ',"$parameters":null'
Else
 DEF = '{"$type": "application/syracuse-word-report","$target":"blank","$url": "'
 #Compute the endpoint's code:
 ENDPOINT = baseUrl
 While 1
  POS = instr(1,ENDPOINT,"/")
  Break (POS=0)
  ENDPOINT = right$(ENDPOINT,POS+1)
 Wend
 POS = instr(8+1,baseUrl,"/")

#Compute the user's locale:
 Local Char ISOLAN(10)
 Local Char LAN(10)

 #Create a 'new document' URL
 Append DEF, left$(baseUrl,POS)+"sdata"+right$(baseUrl,POS+6)
 Append DEF, '/'
 Append DEF, CLASSNAME
 Append DEF, '(%27'
 SEP=''
 For AK=1 To dim(KEYS)
   Append DEF, SEP
   Append DEF, KEYS(AK)
   SEP='~'
 Next I
 Append DEF,'%27)'
 Append DEF,'?representation='
 Append DEF,REPRNAME
 Append DEF,'.$details&role={$role}&reportMode={reportMode}&doc_uuid={document}'

 Append DEF , '"' :#End of the URL
 Append DEF, ',"$parameters":{'
 Append DEF, '"$url":"/sdata/syracuse/collaboration/syracuse/msoReportModes/$template/$workingCopies?representation=msoReportMode.$edit'
 Append DEF, '&role={$role}'
 Append DEF, '&$msoRepr='
 Append DEF, REPRNAME
 Append DEF, '.$details'
 Append DEF, '&$msoLocale='
 If len(LANISO)
  Append DEF, LANISO
 Else
  Append DEF, isomess
 Endif
 If len(COMPANY)
  Append DEF, '&$msoCpy='
  Append DEF, COMPANY
 Endif
 If len(LEGISLATION)
  Append DEF, '&$msoLeg='
  Append DEF, LEGISLATION
 Endif
 If len(ACTIVITY_CODE)
  Append DEF, '&$msoActiv='
  Append DEF, ACTIVITY_CODE
 Endif
 Append DEF, '&$msoEndpoint=x3.erp.'
 Append DEF, ENDPOINT
 Append DEF, '"'
 Append DEF, ',"$method":"POST"'
 Append DEF, ',"$properties":{'
 Append DEF, '"dummy":{'
 Append DEF, '"$title":"dummy"'
 Append DEF, ',"$type":"application/x-string"'
 Append DEF, '}'
 Append DEF, '}'
 Append DEF, '}'

Endif
Append DEF , ', "$title": "'
Case WHAT
 When E_WHAT_NONE       : Append DEF,mess(312,123,1)
 When E_WHAT_V6WORD  : Append DEF,mess(313,123,1)
 When E_WHAT_V6EXCEL : Append DEF,mess(314,123,1)
 When E_WHAT_V7WORD  : Append DEF,mess(315,123,1)
Endcase
Append DEF , '"}'
Calliu "XDT_OFFICE:SETLINK" With ID, DEF, STA, "main"

End ASTATUS
End

#**
#* WORD_MAILMERGE
#*
#* @param CLASSNAME
#* @param REPRNAME
#* @param KEYS
#* @param LANISO
#* @param COMPANY
#* @param LEGISLATION
#* @param ACTIVITY_CODE
#*
Funprog WORD_MAILMERGE( CLASSNAME, REPRNAME, KEYS,QWHERE,CREATE,LANISO,COMPANY,LEGISLATION,ACTIVITY_CODE)
Value Char CLASSNAME
Value Char REPRNAME
Value Char KEYS()(1..)
Value Char QWHERE
Value Integer CREATE
Value Char LANISO
Value Char COMPANY
Value Char LEGISLATION
Value Char ACTIVITY_CODE

Local Integer WHAT
Local Clbfile URL
Local Clbfile DEF
Local Clbfile STA
Local Char ID(20)
Local Char SEP(1)
Local Char ENDPOINT(50)
Local Integer AK,POS

#return code
Local Integer ASTATUS : ASTATUS=0

Gosub ENUM_WHAT From AOFFDOC

#What default value :
WHAT = E_WHAT_NONE

ASTATUS = func AOFFDOC.OFFICE_INT_DOCS(CLASSNAME ,REPRNAME,KEYS, WHAT, URL)

If !ASTATUS & len(URL)
 ID = "word_mailmerge"
 STA = '{"$isDisabled": false}'

 DEF = '{"$type": "application/json","$target":"blank","$url": "'
 Append DEF, URL
 Append DEF , '"'
Elsif CREATE :# Add the link if required by the calling program
 DEF = '{"$type": "application/syracuse-word-mailmerge","$target":"blank","$url": "'
 #Compute the endpoint's code:
 ENDPOINT = baseUrl
 While 1
   POS = instr(1,ENDPOINT,"/")
   Break (POS=0)
   ENDPOINT = right$(ENDPOINT,POS+1)
 Wend
 POS = instr(8+1,baseUrl,"/")

 #Compute the user's locale:
 Local Char ISOLAN(10)
 Local Char LAN(10)

 #Create a 'new document' URL
 Append DEF, left$(baseUrl,POS)+"sdata"+right$(baseUrl,POS+6)
 Append DEF, '/'
 Append DEF, CLASSNAME
 Append DEF,'?representation='
 Append DEF,REPRNAME
 Append DEF,'.$query'
 If len(QWHERE)
  Append DEF,'&where='
  Append DEF,func ASYRJSO.ENCODE_URL(QWHERE)
 Endif
 Append DEF,'&role={$role}&createMode={creationMode}&doc_uuid={document}'

 Append DEF , '"' :#End of the URL
 Append DEF, ',"$parameters":{'
 Append DEF, '"$url":"/sdata/syracuse/collaboration/syracuse/msoMailMergeDocSels/$template/$workingCopies?representation=msoMailMergeDocSel.$edit'
 Append DEF, '&role={$role}'
 Append DEF, '&createMode={creationMode}'
 Append DEF, '&$msoRepr='
 Append DEF, REPRNAME
 Append DEF, '.$query'
 Append DEF, '&$msoLocale='
 If len(LANISO)
   Append DEF, LANISO
 Else
   Append DEF, isomess
 Endif
 If len(COMPANY)
   Append DEF, '&$msoCpy='
   Append DEF, COMPANY
 Endif
 If len(LEGISLATION)
   Append DEF, '&$msoLeg='
   Append DEF, LEGISLATION
 Endif
 If len(ACTIVITY_CODE)
   Append DEF, '&$msoActiv='
   Append DEF, ACTIVITY_CODE
 Endif
 Append DEF, '&$msoEndpoint=x3.erp.'
 Append DEF, ENDPOINT
 Append DEF, '"'
 Append DEF, ',"$method":"POST"'
 Append DEF, ',"$properties":{'
 Append DEF, '"dummy":{'
 Append DEF, '"$title":"dummy"'
 Append DEF, ',"$type":"application/x-string"'
 Append DEF, '}'
 Append DEF, '}'
 Append DEF, '}'

Endif
If len(DEF)
 Append DEF , ', "$title": "'
 Append DEF , mess(315,123,1)
 Append DEF , '"}'
 Calliu "XDT_OFFICE:SETLINK" With ID, DEF, STA, "main"
Endif
End ASTATUS
End
