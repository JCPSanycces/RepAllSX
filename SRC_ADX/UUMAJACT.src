#<AdxTL>@(#)2.0.0.0 $Revision$
##############################################################################
## Init champ TYPUTI de la table ACTION
##############################################################################
Call OUVRE_TRACE("Init champ TYPUTI de la table ACTION") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Else
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub ACTION_TYPUTI
End

Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub ACTION_TYPUTI
End

$ACTION_TYPUTI
Local File =DOSSIER+".ACTION" [ACT] 

If dim([F:ACT]TYPUTI)>0
 # Mise à jour de la table ACTION
 Call ECR_TRACE(mess(81,125,1)-"ACTION:"-time$,0) From GESECRAN
 Trbegin [ACT]
  For [ACT]
   OK = 0
   If [F:ACT]TYPUTI=0
    [F:ACT]TYPUTI = 1
    Rewrite [ACT]
    If fstat
     Call ERREUR("ACTION"-[F:ACT]ACTION,2) From DOSDIC
    Else
     Call ECR_TRACE("Update action"-[F:ACT]ACTION,0) From GESECRAN
    Endif
   Endif
  Next
 Commit
Endif

Close Local File [ACT]
Return
