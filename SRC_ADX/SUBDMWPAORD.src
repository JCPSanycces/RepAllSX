######################################################################################
## Section automatically added (Object DMWPAORD) 01/11/2017 07:04:36 (ANGRE)
######################################################################################
$ACTION
Case ACTION
 When "CREATION" : Gosub CREATION
 When "SETBOUT" :  Gosub SETBOUT
 When Default
Endcase
Return


######################################################################################


$CREATION
  Call MAJTEXTRA([M:DMWPAOR]DES(nolign-1),"DMWPAORD","DES",[M:DMWPAOR]COD,num$([M:DMWPAOR]TYP) +"~"+ [M:DMWPAOR]TYPID(nolign-1)) From ATEXTRA
Return

$SETBOUT
  CHAINE += "A"
Return

######################################################################################
## Section automatically added (screen DMWPAORD) 02/02/2017 08:51:07 (UBA)
######################################################################################
Subprog AS_TYP(VALEUR)
Variable Integer VALEUR
If !clalev ([F:DMWSC])     : Local File DMWSCHEME [DMWSC]      : Endif
Read [F:DMWSC]DMWSC0 = [M:DMWPAOR]COD   # read scheme
If !fstat
    If [F:DMWSC]CRY = 1                 # if Germany
        GMENLOC(1)=1                    # disable product group
        GMENLOC(3)=1                    # disable package size
        GMENLOC(4)=1                    # disable tariff type
        GMENLOC(5)=1                    # disable tariff category
    Endif
Endif
End


######################################################################################

######################################################################################
## Section automatically added (screen DMWPAORD) 02/07/2017 09:38:09 (ANGRE)
######################################################################################
Subprog AM_COD(VALEUR)
Variable Char    VALEUR()
Raz [M:DMWPAOR]TYPID
Raz [M:DMWPAOR]DES
[M:DMWPAOR]NBLIG = 0
Affzo [M:DMWPAOR]NBLIG
Affzo [M:DMWPAOR]TYPID
Affzo [M:DMWPAOR]DES

End


