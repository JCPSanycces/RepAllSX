#<AdxTL>@(#)3.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour onglet sélection objet GTC
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Mise à jour onglet sélection objet GTC") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If !mkstat
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJGTC
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJGTC
End

$MAJGTC

Local Integer I , VALMOD(20)

If DOSSIER<>GDOSX3
 For I=0 To dim(VALMOD)-1
  VALMOD(I) = 2
 Next I
Else
 VALMOD(0) = 2
 For I=1 To dim(VALMOD)-1
  VALMOD(I) = 1
 Next I
Endif

# Mise à jour de gtc

Call ECR_TRACE(mess(33,141,1)-"GTC:"-time$,0) From GESECRAN

# Onglet Sélection

Call MAJ_SEL(DOSSIER,"GTC") From PATCHAOB

# Validation de l'objet gtc

Call VALID_TRT(DOSSIER,0,"","","","","","","","","GTC","GTC","","","","","","","","","","",VALMOD) From VALDICO
Call VALFEN(DOSSIER,"GTC") From SUBAOB

Return
