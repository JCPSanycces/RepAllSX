#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque USASUPSEA 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone BPRSHO
mkstat = 0
zoncou = "BPRSHO"
indice = 0
If varmode([M]BPRSHO,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BPRSHO" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone BPSNAM
mkstat = 0
zoncou = "BPSNAM"
indice = 0
If varmode([M]BPSNAM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "BPSNAM" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone BPSTYP
mkstat = 0
zoncou = "BPSTYP"
indice = 0
IMPENT = [M]BPSTYP
If varinit([M]BPSTYP,indice)=0
 IMPENT = 1
Endif
If varmode([M]BPSTYP,indice)=0
 [M]BPSTYP(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "BPSTYP" : Gosub ACTION From =IMPTRT
  IMPENT = [M]BPSTYP(indice)
 Endif
Endif
[M]BPSTYP = IMPENT

## Zone NAF
mkstat = 0
zoncou = "NAF"
indice = 0
If varmode([M]NAF,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NAF" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone DEFADD
mkstat = 0
zoncou = "DEFADD"
indice = 0
IMPENT = [M]DEFADD
If varinit([M]DEFADD,indice)=0
 IMPENT = 1
Endif
If varmode([M]DEFADD,indice)=0
 [M]DEFADD(indice) = IMPENT
 If !mkstat
  IMPMOD = 0 : IMPZON = "DEFADD" : Gosub ACTION From =IMPTRT
  IMPENT = [M]DEFADD(indice)
 Endif
Endif
[M]DEFADD = IMPENT

####################################
## Bloc liste 2
####################################
IMPTBL = 0

## Zone TEL
mkstat = 0
zoncou = "TEL"
indice = 0
If varmode([M]TEL,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TEL" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone POSCOD
mkstat = 0
zoncou = "POSCOD"
indice = 0
If varmode([M]POSCOD,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "POSCOD" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone CTY
mkstat = 0
zoncou = "CTY"
indice = 0
If varmode([M]CTY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CTY" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone SAT
mkstat = 0
zoncou = "SAT"
indice = 0
If varmode([M]SAT,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "SAT" : Gosub ACTION From =IMPTRT
 Endif
Endif

## Zone CRY
mkstat = 0
zoncou = "CRY"
indice = 0
If varinit([M]CRY,indice)=0
 [M]CRY = GPAYS
Endif
If varmode([M]CRY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CRY" : Gosub ACTION From =IMPTRT
 Endif
 Call CONTROLE("TCY","!",[M]CRY,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 263 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
Endif

mkstat = 0

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "USASUPSEA"
Return

