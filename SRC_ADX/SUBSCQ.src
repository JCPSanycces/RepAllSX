#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion objet SCQ
######################################################################################
## Etiquette ajoutée par le superviseur (Objet SCQ) 19/04/2007 15:18:44 (LSE)
######################################################################################
$ACTION

Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "FERME"        : Gosub FERME
 When "SETBOUT"      : Gosub SETBOUT
 When "AVANTBOUT"    : Gosub AVANTBOUT
 When "LIENS"        : Gosub LIENS
 When "RAZCRE"       : Gosub RAZCRE
 When "RAZDUP"       : Gosub RAZDUP
 When "VERIF_CRE"    : Gosub VERIF_CRE
 When "INICRE"       : Gosub INICRE
 When "CREATION"     : Gosub CREATION
 When "APRES_CRE"    : Gosub APRES_CRE

 When "VERIF_MOD"    : Gosub VERIF_MOD
 When "INIMOD"       : Gosub INIMOD
 When "MODIF"        : Gosub MODIF

 When "AV_ANNULE"    : Gosub AV_ANNULE
 When "ANNULE"       : Gosub ANNULE
 When "AVANT_CHOI"   : Gosub AVANT_CHOI


 When default
Endcase
Return

##########################################################################################################
$AVANT_CHOI

If GBCRMFLGNEW=1
    REPONSE=GSTANEW
    Gosub NOUVEAU From GOBJSUB
    Gosub SETBOUT From GOBJSUB
    GBCRMFLGNEW=0
Endif

Return


$OUVRE
Grizo [M:SCQ0]SCPNUM

return
$FERME
return
$SETBOUT
return
$AVANTBOUT
return
$LIENS
return
$RAZCRE
return
$RAZDUP
return
$VERIF_CRE
return
$INICRE
return
$CREATION
return
$APRES_CRE
return

$VERIF_MOD
return
$INIMOD
return
$MODIF
return

$AV_ANNULE
return

$ANNULE
return

######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran SCQ0) 19/04/2007 15:21:54 (LSE)
######################################################################################
Subprog IB_QST
End


