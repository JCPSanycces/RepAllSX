#<AdxTL>@(#)0.0.0.0 $Revision$
Raz GPILBOITE
GUSRAUZ(1) = "123546"
GFONCTION  = "TPSSUP"
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TPSSUP","TPSSUP",4,"") From GTRAITE
End

#########################################
## Traitement des actions : TRTGENSUP
#########################################
$ACTION
Case ACTION
 When "INIT"        : Gosub OUVRE
 When "CONTROLE"    : Gosub CONTROLE
 When "OUVRE_BATCH" : Gosub OUVFIC From TRTTPS
 When "EXEC"        : Gosub EXEC
 When "OK"          : FIN = 1 : GOK = 1
 When "END"         : FIN = 1
 When "DEBUT"       : Gosub DEBUT
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

#######################################################
$OUVRE
#LIPET - 09-11-2016 - X3PEOP-1248 - START
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
#LIPET - 09-11-2016 - X3PEOP-1248 - END
Gosub OUVFIC From TRTTPS
If clalev([F:TIP2])=0  : Local File TIMEMP    [TIP2]  : Endif
If clalev([F:DCG])=0   : Local File DEMCONGE  [DCG]   : Endif

Local Char    CRITERE(250)
Local Char    CRITERE1(250)
Local Char    TIT(50)
Local Char    SYMBOLE(50)
Local Integer OK , OKC
Local Date    DATPAY
Local Decimal JOUR(1..2) , HEURE(1..2)
Local Integer JNUIT
#LIPET - 2017-06-07 - X3-43916 - START
#Local Char    MATRI (GLONMAT), CTR(GLONCTR)
Local Char    MATRI (GLONEML), CTR(GLONHRCTR)
#LIPET - 2017-06-07 - X3-43916 - END
Local Integer PREMIER
Local Integer NBPCE
Local Decimal OLDNBRDAY, NEWNBRDAY

#LIPET - 2017-06-07 - X3-43916 - START
#TIT = mess(111,709,1) #"Suppression des temps saisis"
TIT = mess(111,10709,1)
#LIPET - 2017-06-07 - X3-43916 - END
Local Mask TPSSUP [DIA]
Raz [M:DIA]
Call LECMEMO("STD","[M:DIA]","ges") From GMEMO

#62324
If !instr(1,GUSRAUZ(1),"1") : # Tous utilisateurs
 Call PARAMUTIL("REFNUM",[M]MATDEB,GUSER,"") From SUBAUS
 If [M]MATDEB=""
  GERR = 2 : FIN = 1
  # Pas d'accès
  GMESSAGE = mess(1,85,1)
  Return
 Endif
 [M]MATFIN = [M]MATDEB
Endif
# fin 62324
Return

$SORTIE
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

#######################################################
## Saisie fenêtre
#######################################################

$DEBUT
#62324
If !instr(1,GUSRAUZ(1),"1") : # Tous utilisateurs
 Diszo MATDEB, MATFIN
Else
 Actzo MATDEB, MATFIN
Endif
# fin 62324
Affzo [DIA]
Setmok [DIA] With 0

If [M:DIA]LEG<>""
  GCURLEG = [M:DIA]LEG
Endif

Return

#######################################################
$CONTROLE
If GSTATUT<>GSTAOK
 FIN = 1
Else
 TMP = 1
 TRA = 1
Endif
Return

#######################################################
$EXEC
#ouverture de la trace et écriture de l'en-tête
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif
Call ECR_TRACE(TIT,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

# mise en place du filtre
CRITERE = "[F:ID]FLGTPS=2"
If [M:DIA]ALLCPY<>2  #société
 CRITERE -= '& [F:FCY]LEGCPY = "'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2  #site
 CRITERE -= '& [F:HRCTR]ETRFCY = "'+[M:DIA]FCY+'"'
Endif
If [M:DIA]MATDEB<>"" #borne début matricule
 CRITERE -= '& [F:ID]REFNUM>="'+[M:DIA]MATDEB+'"'
Endif
If [M:DIA]MATFIN<>"" #borne fin du matricule
 CRITERE -= '& [F:ID]REFNUM<="'+[M:DIA]MATFIN+'"'
Endif
#filtre sur critere contrat
CRITERE1 = '[F:HRCTR]CTRDAT<=['+format$(GFMD,[M:DIA]DATFIN)+'] & ([F:HRCTR]XITDAT=[0/0/0] | [F:HRCTR]XITDAT>=['+format$(GFMD,[M:DIA]DATDEB)+'])'
If [M:DIA]ALLSRV<>2  #service
 CRITERE1 -= '& [F:HRCTR]ETRSRV = "'+[M:DIA]SRV+'"'
Endif
If [M:DIA]ALLPRF<>2  #profil
 CRITERE1 -= '& [F:HRCTR]PROPRF = "'+[M:DIA]PRF+'"'
Endif

If [M:DIA]POP<>""
 Link [HRCTR] With
&   [ID]ID0   = [F:HRCTR]REFNUM
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
& , [POA]POA0 = [M:DIA]POP;[F:ID]REFNUM
&   As [LNK]
&   Where evalue(CRITERE1) & evalue(CRITERE) & [F:POA]REFNUM<>"" & [F:FCY]LEG=GCURLEG
Else
 Link [HRCTR] With
&   [ID]ID0   = [F:HRCTR]REFNUM
& , [FCY]FCY0 = [F:HRCTR]ETRFCY
&   As [LNK]
&   Where evalue(CRITERE1) & evalue(CRITERE) & [F:FCY]LEG=GCURLEG
Endif

Call DEBTRANS From GLOCK
# Traitement
NBPCE=0
For [LNK]
 MATRI = [F:HRCTR]REFNUM
 CTR   = [F:HRCTR]CTRNUM
 Gosub TRTCONT From TRTGEN
 If OK
  Gosub TR1
  Unlock =SYMBOLE
 Endif
Next

If !NBPCE
 Call ECR_TRACE(mess(2,10703,1),0) From GESECRAN : # Aucun matricule à traiter
Else
 Call ECR_TRACE(mess(117,10703,1)-":"-num$(NBPCE),0) From GESECRAN : # Nombre de salariés concernés
Endif

If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return

$TR1
GOK = 1
Trbegin [TIP], [TIP2],[CNE]
 Gosub TR_DCG
 If GOK>=1
  PREMIER=1
  For [TIP]TIP1 Where TIM=[M:DIA]TIM & REFNUM=[F:ID]REFNUM & CTRNUM=CTR
&     & ENDDAT>=[M:DIA]DATDEB & STRDAT<=[M:DIA]DATFIN
   If PREMIER
    Call ECR_TRACE(string$(70," "),0) From GESECRAN
    Call ECR_TRACE([F:TIP]REFNUM-[F:ID]NAM-[F:ID]SRN-[F:TIP]CTRNUM,0) From GESECRAN
    PREMIER = 0
    NBPCE +=1
   Endif
   Call ECR_TRACE([F:TIP]TIM-format$("D:"+GFMDAT,[F:TIP]STRDAT)
&      -"-"-format$("D:"+GFMDAT,[F:TIP]ENDDAT),0) From GESECRAN
   If GTPS=1 & GVISA=2 & [F:TIP]STAFLG<>"" & !instr(1,GUSRAUZ(1),"4")
    # Ligne visée, modification impossible
    Call ECR_TRACE(mess(102,10709,1),1) From GESECRAN
   Else
    If [F:TIP]STRDAT>=[M:DIA]DATDEB & [F:TIP]ENDDAT<=[M:DIA]DATFIN
     #Maj cp pris
     #ADNGO - 22-02-2017 - X3PEOP-1248 - START
     #Call LECTURE("TIM",[M:DIA]TIM,"") From CONTOBJ
     Call LECTURE("HRTIM",[M:DIA]TIM,GCURLEG) From CONTOBJ
     #ADNGO - 22-02-2017 - X3PEOP-1248 - END
     If [F:TIM]CATTIM=3
      Call SUPP_CPPRIS From TPSSTD1
      If GOK<1 : Break : Endif
     Endif
     Delete [TIP]
     If fstat=1 | fstat>5
      # Suppression impossible
      Call ECR_TRACE(mess(1,115,1),1) From GESECRAN
      GOK = -1 : GLOCK = "$TIMEMP" : Break
     Endif
     # Suppression effectuée
     Call ECR_TRACE(mess(60,126,1),0) From GESECRAN
    Elsif [F:TIP]STRDAT<[M:DIA]DATDEB
     If [F:TIP]ENDDAT>[M:DIA]DATFIN
      DDEBUT=[M:DIA]DATFIN+1
      DFIN=[F:TIP]ENDDAT
      Gosub CRELIG
      If !GOK : Break : Endif
     Endif
     DDEBUT=[F:TIP]STRDAT
     DFIN=[M:DIA]DATDEB-1
     Gosub MAJLIG
     If !GOK : Break : Endif
    Elsif [F:TIP]ENDDAT>[M:DIA]DATFIN
     DDEBUT=[M:DIA]DATFIN+1
     DFIN=[F:TIP]ENDDAT
     Gosub MAJLIG
     If !GOK : Break : Endif
    Endif
   Endif
   DATPAY=[F:TIP]DATPYR
   Gosub FLGVEP From TRTGEN
  Next
 Endif
 If   GOK<1 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
Commit
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$TR_DCG
For [DCG]DCG1 Where REFNUM=[F:ID]REFNUM & TIM=[M:DIA]TIM & (CTRNUM=CTR | CTRNUM="")
&    & ENDDAT>=[M:DIA]DATDEB & STRDAT<=[M:DIA]DATFIN
 If [F:DCG]STRDAT>=[M:DIA]DATDEB & [F:DCG]ENDDAT<=[M:DIA]DATFIN
  Delete [DCG] Curr
  If fstat=1 | fstat>5
   # Suppression impossible
   Call ECR_TRACE(mess(1,115,1),1) From GESECRAN
   GOK = -1 : GLOCK = "$DEMCONGE" : Break
  Endif
 Elsif [F:DCG]STRDAT<[M:DIA]DATDEB
  If [F:DCG]ENDDAT>[M:DIA]DATFIN
   DDEBUT=[M:DIA]DATFIN+1
   DFIN=[F:DCG]ENDDAT
   Gosub CREDCG
   If !GOK : Break : Endif
  Endif
  DDEBUT=[F:DCG]STRDAT
  DFIN=[M:DIA]DATDEB-1
  Gosub MAJDCG
  If !GOK : Break : Endif
 Elsif [F:DCG]ENDDAT>[M:DIA]DATFIN
  DDEBUT=[M:DIA]DATFIN+1
  DFIN=[F:DCG]ENDDAT
  Gosub MAJDCG
  If !GOK : Break : Endif
 Endif
Next
Return

$CREDCG
## Mise à jour de la demande de congé
Raz [F:DCG2]
[F:DCG2]REFNUM = [F:DCG]REFNUM
[F:DCG2]CTRNUM = [F:DCG]CTRNUM
[F:DCG2]TIM    = [F:DCG]TIM
[F:DCG2]DEM    = uniqid([DCG])
[F:DCG2]STRDAT = DDEBUT
[F:DCG2]ENDDAT = DFIN
[F:DCG2]STRDAY = 1
[F:DCG2]ENDDAY = 1
[F:DCG2]STA    = 3
[F:DCG2]UID    = uniqid([TIP])
If dim([F:DCG2]CREDAT)>0 : [F:DCG2]CREDAT = date$ : Endif
If dim([F:DCG2]CREUSR)>0 : [F:DCG2]CREUSR = GUSER : Endif
If dim([F:DCG2]CRETIM)>0 : [F:DCG2]CRETIM = time  : Endif
Call VALORIS([F:DCG2]STRDAT,[F:DCG2]ENDDAT,[F:DCG2]REFNUM,[F:DCG2]TIM,JOUR,HEURE,[F:HRCTR]ETRFCY,[F:DCG2]CTRNUM) From SUBPLN
[F:DCG2]NBRDAY = JOUR(1)
Write [DCG2]
If fstat
 GOK = 0 : Call FSTA("DCG") From GLOCK : Return
Endif
Return

$MAJDCG
[F:DCG]STRDAT = DDEBUT
[F:DCG]ENDDAT = DFIN
If dim([F:DCG]UPDDAT)>0 : [F:DCG]UPDDAT = date$ : Endif
If dim([F:DCG]UPDUSR)>0 : [F:DCG]UPDUSR = GUSER : Endif
If dim([F:DCG]UPDTIM)>0 : [F:DCG]UPDTIM = time  : Endif
#DBA le 25/11/04
Call VALORIS([F:DCG]STRDAT,[F:DCG]ENDDAT,[F:DCG]REFNUM,[F:DCG]TIM,JOUR,HEURE,[F:HRCTR]ETRFCY,[F:DCG]CTRNUM) From SUBPLN
[F:DCG]NBRDAY = JOUR(1)
Rewrite [DCG]
If fstat
 GOK = 0 : Call FSTA("DCG") From GLOCK : Return
Endif
Return

$CRELIG
Raz [F:TIP2]
[F:TIP2]=[F:TIP]
[F:TIP2]STRDAT = DDEBUT
[F:TIP2]ENDDAT = DFIN
[F:TIP2]LIG    = uniqid([F:TIP])
If dim([F:TIP2]CREUSR)>0 : [F:TIP2]CREUSR = GUSER : Endif
If dim([F:TIP2]CREDAT)>0 : [F:TIP2]CREDAT = date$ : Endif
If dim([F:TIP2]CRETIM)>0 : [F:TIP2]CRETIM = time  : Endif
#DBA le 25/11/04
Call VALORIS([F:TIP2]STRDAT,[F:TIP2]ENDDAT,[F:TIP2]REFNUM,[F:TIP2]TIM,JOUR,HEURE,[F:TIP2]FCY,[F:TIP2]CTRNUM) From SUBPLN
[F:TIP2]NBRDAY = JOUR(1)
[F:TIP2]NBRHOU = HEURE(1)
Write [TIP2]
If fstat
 GOK = 0 : Call FSTA("TIP2") From GLOCK : Return
Endif
# Création enregistrement :
Call ECR_TRACE(mess(7,9021,1)-":"-[F:TIP2]TIM-format$("D:"+GFMDAT,[F:TIP2]STRDAT)
&    -"-"-format$("D:"+GFMDAT,[F:TIP2]ENDDAT),0) From GESECRAN
Return

$MAJLIG
[F:TIP]STRDAT = DDEBUT
[F:TIP]ENDDAT = DFIN
If dim([F:TIP]UPDDAT)>0 : [F:TIP]UPDDAT = date$ : Endif
If dim([F:TIP]UPDUSR)>0 : [F:TIP]UPDUSR = GUSER : Endif
If dim([F:TIP]UPDTIM)>0 : [F:TIP]UPDTIM = time  : Endif
#DBA le 25/11/04
Call VALORIS([F:TIP]STRDAT,[F:TIP]ENDDAT,[F:TIP]REFNUM,[F:TIP]TIM,JOUR,HEURE,[F:TIP]FCY,[F:TIP]CTRNUM) From SUBPLN
OLDNBRDAY= [F:TIP]NBRDAY
NEWNBRDAY=JOUR(1)
[F:TIP]NBRDAY = JOUR(1)
[F:TIP]NBRHOU = HEURE(1)
Rewrite [TIP]
If fstat
 GOK = 0 : Call FSTA("TIP") From GLOCK : Return
Endif
# Modification enregistrement
Call ECR_TRACE(mess(8,9021,1)-":"-[F:TIP]TIM-format$("D:"+GFMDAT,[F:TIP]STRDAT)
&    -"-"-format$("D:"+GFMDAT,[F:TIP]ENDDAT),0) From GESECRAN
#Maj cp pris
#ADNGO - 22-02-2017 - X3PEOP-1248 - START
#Call LECTURE("HRTIM",[M:DIA]TIM,"") From CONTOBJ
Call LECTURE("HRTIM",[M:DIA]TIM,GCURLEG) From CONTOBJ
#ADNGO - 22-02-2017 - X3PEOP-1248 - END
If [F:TIM]CATTIM=3
 Call SUPP_CPPRIS From TPSSTD1
 If GOK<1 : Return : Endif
Endif
Return


################################################################################
## Etiquettes écran
################################################################################

Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLCPY(VALEUR) From DIVPAYE
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
Call C_ALLCPY(VALEUR) From DIVPAYE
End

Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
Call AS_CPY(VALEUR) From DIVPAYE
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLFCY(VALEUR) From DIVPAYE
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From DIVPAYE
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR
Call AS_FCY(VALEUR) From DIVPAYE
End

Subprog C_ALLSRV(VALEUR)
Variable Integer VALEUR
Call C_ALLSRV(VALEUR) From DIVPAYE
End

Subprog AS_SRV(VALEUR)
Variable Char     VALEUR
Call AS_SRV(VALEUR) From DIVPAYE
End

Subprog C_ALLPRF(VALEUR)
Variable Integer VALEUR
Call C_ALLPRF(VALEUR) From DIVPAYE
End

Subprog AS_PRF(VALEUR)
Variable Char  VALEUR
Call AS_PRF(VALEUR) From DIVPAYE
End

Subprog C_TIM(VALEUR)
Variable Char    VALEUR()
Call C_TIM(VALEUR) From TRTGEN
End

Subprog C_MATFIN(VALEUR)
Variable Char    VALEUR()
Call C_MATFIN(VALEUR) From DIVPAYE
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
Call C_DATFIN(VALEUR) From TRTGEN
End

Subprog D_INI(VALEUR)
Variable Char    VALEUR()
Gosub GRISE From DIVPAYE
End

######################################################################################
## Section automatically added (screen TPSSUP) 11/09/2016 14:03:38 (LIPET)
######################################################################################
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
#ADNGO - 2016-12-01 - START
If VALEUR=""
    [M]ALLPRF=2
    Diszo [M]ALLPRF
Else
    Actzo [M]ALLPRF
Endif
#ADNGO - 2016-12-01 - END
End

