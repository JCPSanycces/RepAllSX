#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque MATCLC 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone DOCCLA
mkstat = 0
zoncou = "DOCCLA"
For indice=0 To 9
 IMPENT = [M]DOCCLA(indice)
 If varinit([M]DOCCLA,indice)=0
  IMPENT = 1
 Endif
 [M]DOCCLA(indice) = IMPENT
 mkstat = 0
Next indice
If mkstat : End : Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBCLC
mkstat = 0
zoncou = "NBCLC"
indice = 0
status = 1
zoncou = "NBCLC"
If varmode([M]NBCLC,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBCLC" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBCLC
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBCLC = nolign
   status = 75
   Call SAI_NBCLC(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBCLC(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBCLC
mkstat = 0
zoncou = "NBCLC"

## Zone CLASPE
mkstat = 0
zoncou = "CLASPE"
WCHAR = [M]CLASPE(indice)
If varmode([M]CLASPE,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_CLASPE([M]CLASPE(indice)) From MATCLC
 GACTION = SAVACT
 If mkstat=1 : Raz [M]CLASPE(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "CLASPE" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If vireblc([M]CLASPE(indice),2)=""
   mkstat = 1 : GMESSAGE = mess(10,123,1)
  Endif
  If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTHRCLC"
   Call CONTHRCLC([M]CLASPE(indice),[M]LEG(nolign-1),GSOCIETE) From SUBHRCLC
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_CLASPE([M]CLASPE(indice)) From MATCLC
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     SAVACT = GACTION : GACTION = "CONTOBJW"
     PARAM(1) = "HRCLC"
     Local Char    VALEUR(250)
     VALEUR = [M]CLASPE(indice)
     Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJW","CONTOBJ","") From GACTION
     [M]CLASPE(indice) = VALEUR
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
     If !mkstat
      If WCHAR<>[M]CLASPE(indice) or IMPMOD
       SAVACT = GACTION : GACTION = "STD"
       Call AM_CLASPE([M]CLASPE(indice)) From MATCLC
       GACTION = SAVACT
       If mkstat : GERR = 1 : GZONE = "CLASPE" : GZNUM = 47694 : Endif
       Gosub AFF From GSAISIE
       If mkstat : End : Endif
      Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone DESCLA
mkstat = 0
zoncou = "DESCLA"
If varinit([M]DESCLA,indice)=0
 SAVACT = GACTION : GACTION = "LECTEXTRA"
 Call LECTEXTRA([M]DESCLA(indice),"CLACTR","DESCLA",[M]CLASPE(nolign-1),[M]LEG(nolign-1)) From ATEXTRA
 GACTION = SAVACT
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG(indice),"909","") From SUBADI
 GACTION = SAVACT
Endif

## Zone ACTSELECT
mkstat = 0
zoncou = "ACTSELECT"
IMPENT = [M]ACTSELECT(indice)
If varinit([M]ACTSELECT,indice)=0
 IMPENT = 1
Endif
[M]ACTSELECT(indice) = IMPENT

## Zone NBCLC
mkstat = 0
zoncou = "NBCLC"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "MATCLC"
Return

