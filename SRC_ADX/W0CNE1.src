#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CNE1 

Subprog SAIMSK(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

####################################
## Bloc liste 1
####################################
IMPTBL = 0

## Zone YEA
mkstat = 0
zoncou = "YEA"
indice = 0
If varmode([M]YEA,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "YEA" : Gosub ACTION From =IMPTRT
 Endif
 If [M]YEA<0
  mkstat = 1 : GMESSAGE = mess(180,141,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "YEA" : GZNUM = 1879 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "STD"
  Call C_YEA([M]YEA) From SUBCNE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "YEA" : GZNUM = 1879 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
 Endif
Endif

## Zone REFNUM
mkstat = 0
zoncou = "REFNUM"
indice = 0
WCHAR = [M]REFNUM
If varmode([M]REFNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "REFNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]REFNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "DROITEMP"
  Call DROIT([M]REFNUM,"","","") From DIVPAYE
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("EML","T",[M]REFNUM,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    If WCHAR<>[M]REFNUM or IMPMOD
     SAVACT = GACTION : GACTION = "STD"
     Call AM_REFNUM([M]REFNUM) From SUBCNE
     GACTION = SAVACT
     If mkstat : GERR = 1 : GZONE = "REFNUM" : GZNUM = 10793 : Endif
     Gosub AFF From GSAISIE
     If mkstat : End : Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone CTRNUM
mkstat = 0
zoncou = "CTRNUM"
indice = 0
If varmode([M]CTRNUM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "CTRNUM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]CTRNUM,2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTVCR"
  Call CONTVCR([M]CTRNUM) From TRTDIV
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   Call CONTROLE("CTR","",[M]CTRNUM,"",mkstat) From CONTOBJ
   If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_CTRNUM([M]CTRNUM) From SUBCNE
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "CTRNUM" : GZNUM = 5481 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
   Endif
  Endif
 Endif
Endif

## Zone LEG
mkstat = 0
zoncou = "LEG"
indice = 0
If varinit([M]LEG,indice)=0
 SAVACT = GACTION : GACTION = "INILEG"
 Call INILEG([M]LEG,"","") From SUBADI
 GACTION = SAVACT
Endif

####################################
## Bloc tableau 2
####################################
IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"
indice = 0
status = 1
zoncou = "NBLIG"
If varmode([M]NBLIG,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBLIG From SUBCNE
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBLIG : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBLIG" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  NBLIG = [M]NBLIG
  For nolign=1 To NBLIG
   indice = nolign-1
   [M]NBLIG = nolign
   status = 75
   Call SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
   If mkstat : Break : Endif
  Next nolign
  If mkstat : End : Endif
  indice = 0
 Endif
Endif

mkstat = 0

End

####################################
## Bloc tableau 2
####################################
Subprog SAI_NBLIG(IMPFIC,ACTION,IMPTRT)
Value Char IMPFIC
Value Char ACTION
Value Char IMPTRT

Gosub DEFVAR

IMPTBL = 1

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

## Zone TIM
mkstat = 0
zoncou = "TIM"
WCHAR = [M]TIM(indice)
If varmode([M]TIM,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "TIM" : Gosub ACTION From =IMPTRT
 Endif
 If vireblc([M]TIM(indice),2)=""
  mkstat = 1 : GMESSAGE = mess(10,123,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 5296 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  SAVACT = GACTION : GACTION = "CONTHRTIM"
  Call CONTHRTIM([M]TIM(indice)) From SUBHRTIM
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 5296 : Endif
  Gosub AFF From GSAISIE
  If mkstat : End : Endif
  If !mkstat
   SAVACT = GACTION : GACTION = "CONTOBJN"
   Local Char    VALEUR(250)
   VALEUR = [M]TIM(indice)
   Call S_AFF_CHAR(VALEUR,PARAM,"CONTOBJN","CONTOBJ","") From GACTION
   [M]TIM(indice) = VALEUR
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 5296 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
   If !mkstat
    SAVACT = GACTION : GACTION = "STD"
    Call C_TIM([M]TIM(indice)) From SUBCNE
    GACTION = SAVACT
    If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 5296 : Endif
    Gosub AFF From GSAISIE
    If mkstat : End : Endif
    If !mkstat
     If WCHAR<>[M]TIM(indice) or IMPMOD
      SAVACT = GACTION : GACTION = "STD"
      Call AM_TIM([M]TIM(indice)) From SUBCNE
      GACTION = SAVACT
      If mkstat : GERR = 1 : GZONE = "TIM" : GZNUM = 5296 : Endif
      Gosub AFF From GSAISIE
      If mkstat : End : Endif
     Endif
    Endif
   Endif
  Endif
 Endif
Endif

## Zone NBRDAY
mkstat = 0
zoncou = "NBRDAY"
WNUM = [M]NBRDAY(indice)
If varmode([M]NBRDAY,indice)=0
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRDAY" : Gosub ACTION From =IMPTRT
 Endif
 If [M]NBRDAY(indice)<0
  mkstat = 1 : GMESSAGE = mess(180,141,1)
 Endif
 If mkstat : GERR = 1 : GZONE = "NBRDAY" : GZNUM = 47292 : Endif
 Gosub AFF From GSAISIE
 If mkstat : End : Endif
 If !mkstat
  If WNUM<>[M]NBRDAY(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_NBRDAY([M]NBRDAY(indice)) From SUBCNE
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NBRDAY" : GZNUM = 47292 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NBRPRI
mkstat = 0
zoncou = "NBRPRI"
WNUM = [M]NBRPRI(indice)
If varmode([M]NBRPRI,indice)=0
 SAVACT = GACTION : GACTION = "STD"
 Call AS_NBRPRI([M]NBRPRI(indice)) From SUBCNE
 GACTION = SAVACT
 If mkstat=1 : Raz [M]NBRPRI(indice) : Endif
 If !mkstat
  IMPMOD = 0 : IMPZON = "NBRPRI" : Gosub ACTION From =IMPTRT
 Endif
 If !mkstat
  If WNUM<>[M]NBRPRI(indice) or IMPMOD
   SAVACT = GACTION : GACTION = "STD"
   Call AM_NBRPRI([M]NBRPRI(indice)) From SUBCNE
   GACTION = SAVACT
   If mkstat : GERR = 1 : GZONE = "NBRPRI" : GZNUM = 35162 : Endif
   Gosub AFF From GSAISIE
   If mkstat : End : Endif
  Endif
 Endif
Endif

## Zone NBLIG
mkstat = 0
zoncou = "NBLIG"

End

$DEFVAR
Local Integer I , J , K , XOK , NOL , IMPENT , IMPMOD , IMPTBL , NBLIG
Local Char    IMPMSK(GLONAMK) , IMPZON(GLONAVA) , NOMZONE(40)
Local Char    PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
Local Char    PARAM(250)(1..20) , SAVACT(20)
Local Char    WCHAR(255)
Local Decimal WNUM
Local Date    WDATE
Local Clbfile WCLOB(9)

IMPMSK = "CNE1"
Return

