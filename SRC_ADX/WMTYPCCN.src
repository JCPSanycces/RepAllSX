#<AdxTL>@(#)0.0.0.0 $Revision$Class Concession contract
# Supervisor
## ATY-ATYPE ## CCN
# 2018-11-09 07:13:58 788

Funprog ACTRLREF(AINSTANCE,APRONAME,AVALUE,CCNREF,AFILTER)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Char AVALUE
Value Char CCNREF
Value Char AFILTER

Local Integer ASTATUS

If find(AINSTANCE.ACTX.AFOLDER,nomap,"")>0
 Local File CONCESSION [CCN]
Else
 Local File =AINSTANCE.ACTX.AFOLDER+".CONCESSION" [CCN]
Endif

Default File [F:CCN]
Read [F:CCN]CCN0 = [L]CCNREF
If fstat : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]CCNREF)-":"-mess(23,100,1),[V]CST_AERROR): End [L]ASTATUS
Endif

Local Integer ATSTFILTER
Local Char     AMESFILTER(250)
Case [L]AFILTER
 When Default
  [L]ATSTFILTER = 1 : [L]AMESFILTER=mess(23,100,1)
Endcase
If [L]ATSTFILTER=0 : # Record does not exist
 [L]ASTATUS = fmet AINSTANCE.ASETERROR(APRONAME,num$([L]CCNREF)-":"-[L]AMESFILTER,[V]CST_AERROR): End [L]ASTATUS
Endif

End [V]CST_AOK


