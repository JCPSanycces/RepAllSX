#<AdxTL>@(#)9.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise a jour champ BIDNUMFLG dnas les modeles de données
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update BIDNUMFLG field on BID file") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Else
   Call ECR_TRACE("*** Validation du dossier"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJFLG
End

#----------------------------------------------#
Subprog PATCH_X3(DOSSIER)
Value Char DOSSIER
Gosub MAJFLG
End

#-------------------#
$MAJFLG
Local File =DOSSIER+".BID"   [BID]

If dim([F:BID]BIDNUMFLG)<0 : End : Endif

# Mise à jour de la table BID
Call ECR_TRACE(mess(81,125,1)-"BID:"-time$,0) From GESECRAN
Trbegin [BID]
 For [BID]BID0
  If [F:BID]BIDNUMFLG=0
   [F:BID]BIDNUMFLG=1 
   Rewrite [BID]
   If fstat
    Call ERREUR("BID"-num$([F:BID]BPATYP)-num$([F:BID]BPANUM)-num$([F:BID]BIDNUM)-num$([F:BID]BPAADD),2) From DOSDIC
   Endif
  Endif
 Next BID
Commit

Close Local File [BID]

Return

