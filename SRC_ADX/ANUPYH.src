#<AdxTL>@(#)1.0.0.0 $Revision$ Annulation comptable d'un règlement 
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
GACTION = "ANUPYH"
PARBOUT(1) = "TTES-0911APN0000001" : # Numéro de règlement à annuler
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","ANUPYH","DANUPYH",3,"") From GTRAITE
End
#X3-39795  MDJ   Manage ORIGIN and ORICOD fields in GL Entry
#FQ68023 : GER - Reduction of acquisition and production costs
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "SORTIE"      : Gosub SORTIE
Endcase
Return

#####
$INIT
#####
Local Libelle TEST, LCK, MTC1, MTC2, MTC3, KIBOK : TEST=GTEST
Local Integer STAT, NOL, K, I, J, NUMESPION, MAXLIG, MAXECH, DEBTRA, PANCUR, PANNOL, PANSTA
Local Integer LETTRE, TPYH
Local Integer VU, IREF, IREFMAIN, X, INDREF
Local Integer NOLI, AXE, INDAXE
Local Integer OLIN,OLEDTYP
Local Integer WOK, WSAI
Local Integer LIGNE
Local Integer LU
Local Integer AUT

Local Char    TYPPCE(GLONGTE), NUMPCE(GLONVCR), ID(5)
Local Char    SYMBOLE(50), SYMBOLE2(50), MESSA(200), FICTRA(GDIMFIC), OPT2(1), SVG_GTRACE(GLONTRA)
Local Char    NUM(GLONVCR), TYP(GLONGTE), NUMCUR(GLONVCR), TYPCUR(GLONGTE), NPYH(GLONVCR)
Local Char    CODLED(GLONLED), DEVLED(GLONCUR)
Local Decimal MONTANT, MONTINT
Local Integer NBTB, MAXTB, ACCNUM_H, ACCNUM_G, ACCFCY
Local Integer PRORO
Local Integer FLGAUT
Local Libelle BORTYP, TYPEFF
Local Char    CPTGEN(GLONGAC), PLGEN(GLONCOA)
Local Char    COMPTE(GLONGAC), PLAN(GLONCOA), TIERS(GLONBPR), SITE(GLONFCY), SOC(GLONCPY), MTCLET(5), DEVISE(GLONCUR), AUZFCY(15)
Local Char    BORNUM(GLONVCR), PARAM2(10), BANCUR(GLONCUR)
Local Char    FILTDAA(250)
Local Decimal COEFF
Local Decimal ARD1

Onerrgo ERREUR From CONTROLE
If !clalev([F:PYH])  : Local File PAYMENTH   [PYH]  : Endif
If !clalev([F:BES])  : Local File BILSTA     [BES]  : Endif
If !clalev([F:PAN])  : Local File PAYACCNUM  [PAN]  : Endif
If !clalev([F:PMD])  : Local File PAYACCNUMD [PMD]  : Endif
If !clalev([F:TCU])  : Local File TABCUR     [TCU]  : Endif
If !clalev([F:GCM])  : Local File GACM       [GCM]  : Endif
If !clalev([F:HAE])  : Local File GACCENTRY  [HAE]  : Endif
If !clalev([F:DAE])  : Local File GACCENTRYD [DAE]  : Endif
Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Return  : Endif

TPYH=3 : NPYH=PARAM(1) : SYMBOLE=GFONCTION


LCK=1
Readlock [PYH]PYH0 = NPYH
If fstat=1
 # Règlement NPYH - Modification en cours sur un autre poste
 LCK=0 : GERR=1 : GMESSAGE=mess(27,117,1)-NPYH+"\"+mess(10,100,1)
Elsif fstat : # Règlement inexistant
 If NPYH="" : GMESSAGE = mess(137,117,1)
 Else       : GMESSAGE = NPYH-":"-mess(137,117,1)
 Endif
 LCK=0 : GERR=1
Elsif [F:PYH]STAFLG(2)<>2 & [F:PYH]STAFLG(7)<>2 & [F:PYH]STAFLG(8)<>2
 GERR=1 : GMESSAGE=mess(127,117,1) : # Règlement non comptabilisé
Elsif [F:PYH]STA>=11
 GERR=1 : GMESSAGE=mess(125,117,1) : # Règlement impayé
Else
 GFONCTION="GESPAY" : Call AUTORIS From EXEFNC
 Call DROITSITE([F:PYH]FCY,[L]AUZFCY,[L]ACCFCY) From CPTSUB
 If !instr(1,[L]AUZFCY,"A")
  GERR=1 : GMESSAGE=mess(74,100,1) : # Fonction non autorisée
 Elsif [F:PYH]FRMNUM<>""
  SYMBOLE2 = "FRM"+[F:PYH]FRMNUM+"\"+num$([F:PYH]FRMFLG)
  Lock =SYMBOLE2 With lockwait=0
  If fstat
   If [F:PYH]FRMFLG=1
    # Bordereau de remise FRMNUM - Modification en cours sur un autre poste
    GMESSAGE=mess(126,117,1)-[F:PYH]FRMNUM+"\"+mess(10,100,1)
   Else
    # Avis de domiciliation FRMNUM - Modification en cours sur un autre poste
    GMESSAGE=mess(123,117,1)-[F:PYH]FRMNUM+"\"+mess(10,100,1)
   Endif
   GERR=1
  Endif
  If [F:PYH]FRMFLG=2
   Read [BES]BES0 = [F:PYH]FRMNUM;0
   If !fstat
    # Réglement rapproché - Relevé
    GERR=1 : GMESSAGE=mess(14,121,1)+"\"+mess(199,117,1)-[F:PYH]FRMNUM
   Endif
  Endif
 Endif
 # Type de gestion d'effets
 Call PARAM([F:PYH]CPY,"TYPEFF",PARAM2) From ADOVAL
 TYPEFF = val(PARAM2)
Endif

If !GERR
 For I = 3, 8, 9
  Filter [PAN] Where TYPNUM=TPYH & NUM=NPYH & RVSACCNUM=0 & ACCSTA=[L]I
  Read [PAN]PAN0 First
  If fstat<=2
   Case I
    When 3  : GFONCTION="PAYMEP"
    When 8  : GFONCTION="REMCPT"
    When 9  : GFONCTION="REMBAN"
    When 10 : GFONCTION="VALPORT"
   Endcase
   Call AUTORIS From EXEFNC
   If I=3 | (I=9 & [F:PYH]FRMNUM="") | I=10
    Call DROITSITE([F:PYH]FCY,[L]AUZFCY,[L]ACCFCY) From CPTSUB
   Else
    Call DROITSITE([F:PYH]FRMFCY,[L]AUZFCY,[L]ACCFCY) From CPTSUB
   Endif
   If I<>10 & !instr(1,[L]AUZFCY,"G") : # Fonction non autorisée
    GERR=1 : GMESSAGE=mess(74,100,1) : Break
   Endif
  Endif
 Next I
 Filter [PAN]
 # Avertir l'utilisateur si une des pièces de règlement a été extournée manuellement via les fonctions comptables.
 I = 0
 Filter [PAN] Where TYPNUM=TPYH & NUM=NPYH & RVSACCNUM=0
 For [PAN]
  Read [F:DAE]DAE2 = [F:PAN]ACCNUM
  If !fstat
   Read [F:HAE]HAE0 = [F:DAE]TYP;[F:DAE]NUM
   If !fstat & [F:HAE]RVS>1 : I=1 : Break : Endif
  Endif
 Next
 If I
  # Attention, une des pièces du règlement a déjà été extournée, Poursuivre/Annuler"
  OK = 2 : Call AVERTIR(NPYH-"\"-mess(152,121,1)-"\"-mess(49,100,1)+"/"+mess(50,100,1),OK) From GESECRAN
  If OK<>2 :  GERR= 1 : Endif
 Endif
 Filter [PAN]
Endif

If !GERR
 Gosub CHECK_RECONCILED From BANRECLIB
 GMESSAGE = mess(54,120,1)
Endif

If GFONCTION<>SYMBOLE
 GFONCTION=SYMBOLE
 Call AUTORIS From EXEFNC
Endif
If GERR
 FIN=1
Endif
Return

#########
$INIT_DIA
#########
[M:DIA]FCY   =[F:PYH]FCY
[M:DIA]DESVCR=mess(33,121,1)-NPYH : # Rglt annulé NPYH
Return

#######
$SORTIE
#######
If SYMBOLE2<>""
 Unlock =SYMBOLE2 : SYMBOLE2=""
Endif
If LCK
 Unlock [PYH] : LCK=0
Endif
Return

#########
$CONTROLE
#########
#Issue 75458 – 2018-02-07  by MADOR - FIFO Payments Flow
If func AFNC.ACTIV("FIFRC") & [F:PYH]BAN<>""
    If func FIFOCONVAR_CSTD.FLDFIFCP_CTL([F:PYH]BAN, [F:PYH]ACCDAT)
      If func FIFOCONVAR_CSTD.IS_FIFO_EXIST([F:PYH]BAN, [F:PYH]ACCDAT) = 1
        GMESSAGE=mess(28,7708,1) : GERR=1 : FIN=1 : Return
      Endif
    Endif
Endif
#Issue end
TMP=1 : TIT="A"
Return

#####
$EXEC
#####
Onerrgo ERREUR From CONTROLE
If !clalev([F:PYD])  : Local File PAYMENTD   [PYD]   : Endif
If !clalev([F:FRM])  : Local File PAYFRM     [FRM]   : Endif
If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]   : Endif
If !clalev([F:PAN2]) : Local File PAYACCNUM  [PAN2]  : Endif
If !clalev([F:HAE])  : Local File GACCENTRY  [HAE]   : Endif
If !clalev([F:DAE])  : Local File GACCENTRYD [DAE]   : Endif
If !clalev([F:DAA])  : Local File GACCENTRYA [DAA]   : Endif
If !clalev([F:DAE4]) : Local File GACCTMPD   [DAE4]  : Endif
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]   : Endif
If !clalev([F:DUD])  : Local File GACCDUDATE [DUD]   : Endif
If !clalev([F:MTB])  : Local File MTCBATCH   [MTB]   : Endif
If !clalev([F:PYO])  : Local File PAYORDER   [PYO]   : Endif
If !clalev([F:MVS])  : Local File BPSUPPMVT  [MVS]   : Endif
If !clalev([F:MVC])  : Local File BPCUSTMVT  [MVC]   : Endif
If !clalev([F:BAN])  : Local File BANK       [BAN]   : Endif
If !clalev([F:DAE3]) : Local File GACCENTRYD [DAE3]  : Endif
If !clalev([F:DAE5]) : Local File GACCENTRYD [DAE5]  : Endif
If !clalev([F:DAE6]) : Local File GACCENTRYD [DAE6]  : Endif
If !clalev([F:PAN3]) : Local File PAYACCNUM  [PAN3]  : Endif
If !clalev([F:PYD3]) : Local File PAYMENTD   [PYD3]  : Endif
If !clalev([F:PYL])  : Local File PAYLOT     [PYL]   : Endif

# Fichiers ouverts par $LIENS de SUBGAS et CONTROLE de CPTBATCH
If !clalev([F:GTE])  : Local File GTYPACCENT [GTE]   : Endif
If !clalev([F:JOU])  : Local File GJOURNAL   [JOU]   : Endif
If !clalev([F:FCY])  : Local File FACILITY   [FCY]   : Endif
If !clalev([F:CPY])  : Local File COMPANY    [CPY]   : Endif
If !clalev([F:TCU])  : Local File TABCUR     [TCU]   : Endif

# Fichiers ouverts par VALPIECE de CPTBATCH
If !clalev([F:ANM])  : Local File ACODNUM    [ANM]   : Endif
If !clalev([F:AVN])  : Local File AVALNUM    [AVN]   : Endif
If !clalev([F:TUN])  : Local File TABUNIT    [TUN]   : Endif
If !clalev([F:DSP])  : Local File CADSP      [DSP]   : Endif

# Fichiers ouverts par CONTROLE de CPTBATCH
If !clalev([F:JST])  : Local File GAJOUSTA   [JST]   : Endif
If !clalev([F:CCE])  : Local File CACCE      [CCE]   : Endif
If !clalev([F:FIY])  : Local File FISCALYEAR [FIY]   : Endif
If !clalev([F:PER])  : Local File PERIOD     [PER]   : Endif
If !clalev([F:BPR])  : Local File BPARTNER   [BPR]   : Endif
If !clalev([F:TCH])  : Local File TABCHANGE  [TCH]   : Endif
If !clalev([F:TUN])  : Local File TABUNIT    [TUN]   : Endif
If !clalev([F:DSP])  : Local File CADSP      [DSP]   : Endif
If !clalev([F:AUZ])  : Local File CAAUZ      [AUZ]   : Endif
If !clalev([F:TCK])  : Local File TABACCLIK  [TCK]   : Endif
If !clalev([F:GDE])  : Local File GDIAENTRY  [GDE]   : Endif
If !clalev([F:GDD])  : Local File GDIAENTRYD [GDD]   : Endif
If !clalev([F:CCE2]) : Local File CACCE      [CCE2]  : Endif
If !clalev([F:HAE1]) : Local File GACCENTRY  [HAE1]  : Endif
If !clalev([F:HAE2]) : Local File GACCTMP    [HAE2]  : Endif
If !clalev([M:PAYL])  : Local Mask PAY3 [PAYL] : K=1 : Else : K=0 : Endif
If dim([M:PAYL]RITAMT)>0
 KIBOK=1
 If !clalev([F:PIH]) : Local File PINVOICE [PIH] : Endif
 If !clalev([F:RTH]) : Local File RITHIS   [RTH] : Endif
Endif
MAXECH=max(1,dim([M:PAYL]DENCOD))*2+2
MAXTB=dim([M:PAYL]DENCOD)
If K : Close Local Mask [PAYL] : Endif

Local Mask GACCENTFMT  [HAEF]
Local Mask GACCENTW    [HAEW]
Local Mask SAICURLED [SCL]
Local Mask GACCENT0 [HAE0],  GACCENT1 [HAE1], GACCENT2 [HAE2],  VENTILE  [VTL] , VENTILE2 [VT2] , LETTRECH [LTE]

If func AFNC.ACTIV("CASIN")
 If clalev([F:PCH])=0 : Local File PYHCAS     [PCH] : Endif
 If clalev([F:PC2])=0 : Local File PYHCAS     [PC2] : Endif
 If clalev([F:TFC])=0 : Local File TABFILCASH [TFC] : Endif
Endif

If  func AFNC.ACTIV("CHQMG")
 Gosub SUBPAY_OUVRE From CHKLIB
Endif

If func AFNC.ACTIV("HDU")
 Global Char GHDUFLG(1)
Endif

Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Return : Endif

Local Libelle ECH_LOC(MAXECH)
Local Integer ECH_NUM(1..len(mess(0,2644,1)),MAXECH), ECH_LIG(1..len(mess(0,2644,1)),MAXECH), ECH_NB(1..len(mess(0,2644,1)))
Local Integer ECH_DUDLIG(1..len(mess(0,2644,1)),MAXECH)
Local Char    CODLET(10)(MAXECH)
Local Integer CODREF(MAXECH)
Local Char    CODACC(GLONGAC)(MAXECH)
Local Char    CODBPR(GLONBPR)(MAXECH)
Local Char    CODCPY(GLONCPY)
Local Char    CODFCY(GLONFCY)(MAXECH)
Local Integer NBCOD

Local Decimal ECH_MT(MAXECH), ECH_MTLOC(MAXECH)
Local Char    ECH_GRP(5)(1..len(mess(0,2644,1)),MAXECH), ECH_ECT(20)(MAXECH)
Local Char    ECH_FCY(GLONFCY)(1..len(mess(0,2644,1)),MAXECH), ECH_SAC(4)(MAXECH)
Local Char    ECH_CPT(GLONGAC)(1..len(mess(0,2644,1)),MAXECH), ECH_COA(GLONCOA)(1..len(mess(0,2644,1)),MAXECH), ECH_BPR(GLONBPR)(1..len(mess(0,2644,1)),MAXECH)
Local Decimal ECH_IPT(1..len(mess(0,2644,1)),MAXECH)
Local Decimal ECH_IPTLOC(1..len(mess(0,2644,1)),MAXECH)
#
MAXLIG = 2
Local Integer NBLET , TBLET(1..MAXLIG) , DUDLIG(1..MAXLIG)
Local Decimal AMTIPT(1..MAXLIG)
#
MAXLIG = dim([M:HAE2]BPR)
Local Integer TBACCNUM(MAXLIG)
#
Local Integer TBNUM(MAXTB)
Local Libelle TBSTA(MAXTB)
Gosub ESPION From WOGAS : # Affectation de NUMESPION
#

# Sauvegarde de valeurs (essentielle lors d'extourne d'une pièce de lettrage automatique)
Local Char SVG_TYP(GLONGTE), SVG_NUM(GLONVCR)
Local Integer  SVG_NUM2

Local Integer SVG_NBLIG
Local Char    SVG_FCY(GLONGAC)(MAXLIG), SVG_COA(GLONGAC)(MAXLIG), SVG_ACC(GLONGAC)(MAXLIG), SVG_BPR(GLONBPR)(MAXLIG)
Local Decimal SVG_DEB(MAXLIG),    SVG_CDT(MAXLIG)
Local Integer SVG_LEDTYP(MAXLIG), SVG_LIN(MAXLIG), SVG_NUM1(MAXLIG)

Local Char    SVG_DES(GLONDES)(MAXLIG)
Local Char    CRITSPE(250)

Local Integer NBRECRLET
Local Integer LETFLG

Local Integer NBRACCNUM
Local Integer LSTACCNUM(0..MAXLIG)

Call SETMAINREF([F:PYH]CPY,GTYPGEN,GTYPANA) From CPTDIV

If  func AFNC.ACTIV("CHQMG") & [PYH]SNS=1 # Expense only 88598.n
 Gosub VERIF_ACCCAN From CHKLIB
Endif
If  !GOK : Return : Endif

DEBTRA=adxseek(0)
FICTRA=filpath("TRA",GTRACE,"tra",0)
Call DEBTRANS From GLOCK

$TR1
# Annulation comptable Règlement NPYH
Call TITAWI(BCRIT,GMESSAGE) From OBJDIV
Call OUVRE_TRACE(GMESSAGE-mess(TPYH,685,1)-NPYH) From LECFIC

GOK=1 : GMESSAGE="" : NBTB=0 : GTRANS=1

Trbegin [PAN], [DUD], [MTB], [MVC], [MVS], [BAN], [PYH], [PAN2], [PYO], [FRM]

Case TPYH
 When 3 : # Règlement
  For [PAN]PAN0 Where TYPNUM=TPYH & NUM=NPYH & STA>0 & RVSACCNUM=0
#   If (find([F:PAN]ACETYP,1,3)) | ([F:PAN]ACETYP=0 & find([F:PAN]STA,3,10)) #DdM65952
   If [F:PAN]ACETYP=1 | ([F:PAN]ACETYP=0 & find([F:PAN]STA,3,10))
    Gosub EXTOURNE
   Elsif [F:PAN]ACETYP = 2 | [F:PAN]ACETYP = 3
    Gosub EXTOURNE_PARTIEL
   Endif
   If GOK<1 : Break : Endif
  Next : # [PAN]
  If GOK>0 & ACCNUM_H
   GOK=0 : Call RSTA("PAN",num$(TPYH)-NPYH-"10") From GLOCK
  Endif

  If GOK>0
   Delete [PAN] Where TYPNUM=TPYH & NUM=NPYH & STA<0
   If fstat=1
    GOK=-1 : GLOCK="$PAYACCNUM"-num$(TPYH)-NPYH
   Elsif fstat>5
    GOK=0 : Call RSTA("PAN",num$(TPYH)-NPYH) From GLOCK
   Endif
  Endif
  If GOK>0
   For [PAN]PAN0 Where TYPNUM=TPYH & NUM=NPYH & RVSACCNUM<0
    [F:PAN]RVSACCNUM=-[F:PAN]RVSACCNUM
    Rewrite [PAN]
    If fstat=1
     GOK=-1 : GLOCK="$PAYACCNUM"-num$([F:PAN]TYPNUM)-[F:PAN]NUM-num$([F:PAN]STA) : Break
    Elsif fstat
     GOK=0 : Call FSTA("PAN") From GLOCK : Break
    Endif
   Next : # [PAN]
  Endif
  If GOK>0 & [F:PYH]STAFLG(2)=2 & [F:PYH]STAFLG(9)<>2 & [F:PYH]AMTNYTBIL<>0
   Call LEC_TPY_LEG([F:CPY]LEG,[F:PYH]PAYTYP) From CPTLEC
   # Dévalorisation portefeuille
   If [F:TPY]UPDBIL>1 : Gosub PORTEF From VALPORT : Endif
  Endif
  If GOK>0
   # [DUD]Montant règlé définitif repasse en provisoire + Delettrage
   For IREF=1 To len(mess(0,2644,1))
    ECH_NB(IREF) = 0
   Next

   #FQ68023
   If GMODU(14)=2 : # Presence of the fixed assets module
    Local Char    DEPMOD(10)
    Call PARAML([F:CPY]CPY,"DEPMGTMOD",DEPMOD) From ADOVAL
    GDEPMGTMOD=val(DEPMOD)
    If clalev([F:LOFC])=0 : Local File LAYOUTFAS   [LOFC] : Endif
   Endif  #FQ68023 END

   For [PYD]PYD0 Where NUM=NPYH & DUDNUM<>0
    Read [DUD]DUD1 = [F:PYD]DUDNUM;[F:PYD]DUDLIG
    If fstat=0 & !find([F:DUD]TYP,"*SO","*PO")
     J = find([F:DUD]ACCNUM,ECH_NUM(GTYPGEN,0..ECH_NB(GTYPGEN)-1))
     If !J
      Readlock [DAE]DAE2 = [F:PYD]DUDNUM
      If fstat=1
       GOK=-1 : GLOCK="$GACCENTRYD"-num$([F:PYD]DUDNUM) : Break
      Elsif fstat=0
       If ECH_NB(GTYPGEN)>=MAXECH : # Trop d'échéances à lettrer (MAXECH>MAXECH)
        GMESSAGE=mess(81,117,1)-"(MAXECH>"+num$(MAXECH)+")" : GOK=0 : Break
       Endif
      Endif
      For IREF=1 To len(mess(0,2644,1))
       If IREF = GTYPGEN
        ECH_NUM(IREF,ECH_NB(IREF))    = [F:DAE]ACCNUM
        ECH_DUDLIG(IREF,ECH_NB(IREF)) = [F:DUD]DUDLIG
        ECH_COA(IREF,ECH_NB(IREF))    = [F:DAE]COA
        ECH_CPT(IREF,ECH_NB(IREF))    = [F:DAE]ACC
        ECH_BPR(IREF,ECH_NB(IREF))    = [F:DAE]BPR
        ECH_FCY(IREF,ECH_NB(IREF))    = [F:DAE]FCYLIN
        ECH_GRP(IREF,ECH_NB(IREF))    = [F:DAE]MTC
        ECH_IPT(IREF,ECH_NB(IREF))    = [F:DUD]PAYCUR-[F:PYD]PAYCURLIN
        ECH_IPTLOC(IREF,ECH_NB(IREF)) = [F:DUD]PAYLOC-[F:PYD]PAYLOCLIN

        ECH_NB(IREF) += 1
        SYMBOLE = "MTC"-[F:DAE]FCYLIN-[F:DAE]ACC-[F:DAE]BPR
        Lock =SYMBOLE
        If fstat=1
         GOK=-1 : GLOCK="%"+SYMBOLE : Break
        Endif
       Else
        For [DAE3] Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & LEDTYP=IREF & IDTLIN=[F:DAE]IDTLIN
         If [F:DAE3]MTC<>""
          ECH_NUM(IREF,ECH_NB(IREF))    = [F:DAE3]ACCNUM
          ECH_DUDLIG(IREF,ECH_NB(IREF)) = 1
          ECH_COA(IREF,ECH_NB(IREF))    = [F:DAE3]COA
          ECH_CPT(IREF,ECH_NB(IREF))    = [F:DAE3]ACC
          ECH_BPR(IREF,ECH_NB(IREF))    = [F:DAE3]BPR
          ECH_FCY(IREF,ECH_NB(IREF))    = [F:DAE3]FCYLIN
          ECH_GRP(IREF,ECH_NB(IREF))    = [F:DAE3]MTC
#          ECH_IPT(IREF,ECH_NB(IREF))    = [F:DUD]PAYLOC-[F:PYD]PAYLOCLIN
          ECH_NB(IREF) += 1
         Endif
        Next
       Endif
      Next
     Else
      ECH_IPT(GTYPGEN,J-1)    -= [F:PYD]PAYCURLIN
      ECH_IPTLOC(GTYPGEN,J-1) -= [F:PYD]PAYLOCLIN
     Endif
    Endif
    Readlock [DUD]DUD1 = [F:PYD]DUDNUM ; [F:PYD]DUDLIG
    If fstat=1
     GOK=-1 : GLOCK="$GACCDUDATE"-num$([F:PYD]DUDNUM)-num$([F:PYD]DUDLIG) : Break
    Elsif fstat
     GOK=0 : Call RSTA("DUD",num$([F:PYD]DUDNUM)-num$([F:PYD]DUDLIG)) From GLOCK : Break
    Endif

    [F:DUD]TMPCUR+=[F:PYD]PAYCURLIN
    [F:DUD]TMPLOC+=[F:PYD]PAYLOCLIN
    If find([F:DUD]TYP,"*SO","*PO")
     [F:DUD]PAYCUR-=[F:PYD]PAYCURLIN
     [F:DUD]PAYLOC-=[F:PYD]PAYLOCLIN
    Endif

    Readlock [DAE]DAE2 = [F:DUD]ACCNUM
    If fstat=1
     GOK=-1 : GLOCK="$GACCENTRYD"-num$([F:PYD]DUDNUM) : Break
    Elsif [F:DAE]MTC<>""
     [F:DUD]PAYCUR = 0
     [F:DUD]PAYLOC = 0
    Endif

    If [F:PYD]PAYLOCLIN = [F:DUD]PAYLOC
     [F:DUD]PAYDAT = [0/0/0]
    Else
     [F:DUD]PAYDAT = [0/0/0]
     For [PYD3]PYD1 Where DUDNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG & NUM<>[F:PYD]NUM
      Filter [PAN3] Where TYPNUM=3 & NUM=[F:PYD3]NUM & STA=3
      Read [PAN3]PAN0 First
      Filter [PAN3]
      If !fstat
       Read [DAE3]DAE2 = [F:PAN3]ACCNUM
       If !fstat
        If [F:DUD]PAYDAT =  [0/0/0]
         [F:DUD]PAYDAT = [F:DAE3]ACCDAT
        Else
         [F:DUD]PAYDAT = min([F:DUD]PAYDAT,[F:DAE3]ACCDAT)
        Endif
       Else
        Read [DAE4]DAT1 = [F:PAN3]ACCNUM
        If [F:DUD]PAYDAT =  [0/0/0]
         [F:DUD]PAYDAT = [F:DAE4]ACCDAT
        Else
         [F:DUD]PAYDAT = min([F:DUD]PAYDAT,[F:DAE4]ACCDAT)
        Endif
       Endif
      Else
       [F:DUD]PAYDAT = [0/0/0]
      Endif
     Next
    Endif
    Call SLDECH("DUD")From MODECHE
    Rewrite [DUD]
    If fstat
     GOK=0 : Call FSTA("DUD") From GLOCK : Break
    Endif
    If dim(GHDUFLG)>0
     GHDUFLG = "A"
     Call HISTOECH("DUD",1,[M:HAE0]ACCDAT)From MODECHE
     Raz GHDUFLG
    Endif

    #FQ68023-Reduction of acquisition and production costs when paying with discount
    # --> P28 - if  [PYH]SNS = "Expense"
    # --> P8 - Accounts flagged "subject to discount" (param DEPMGTMOD=4 from TC/INV)
    If  [PYH]SNS = 1 and  GDEPMGTMOD = 4
    If !clalev([F:WTVT]) : Local File TABVAT[WTVT]     : Endif
    If !clalev([F:WCAC]) : Local File GACCCODE [WCAC]  : Endif
    If !clalev([F:WGAC]) : Local File GACCOUNT [WGAC]  : Endif
      # P9 - the flag “Expense creation”  must be checked
      # On Payment attibute
      Call LEC_CDA_LEG(GCURLEG,[F:PYD]DENCOD) From CPTLEC
      If fstat= 0  and [F:CDA]FLGEXPCRE = 2
        #FQ68023_b
        # Research of  Accounting code in the Tax code table
        Read [F:WTVT]TVT0=[F:PYD]VATLIN;GCURLEG
        If (fstat) :  Break  : Endif
        Read[WCAC]CAC0=10;[F:WTVT]ACCCOD;[F:PYD]COA(0)
        If (fstat) : Break : Endif
        Read [WGAC]GAC0 = [F:PYD]COA(0);[F:WCAC]ACC(12)
        If fstat= 0 and  [F:WGAC]FLGEXPCRE = 2
          Look [LOFC]LOF0(1) = [F:PYD]VCRNUM
          If !fstat
            Gosub MAJ_ANU_PYD From SUBLOF2
            If !GOK : GMESSAGE = MESSA :  Break :  Endif
          Endif
        Endif
      Endif
    Endif  #FQ68023 END

   Next : # [PYD]

   Local Integer LETSOC
   LETSOC = 0

   If GOK>0
    For IREF=1 To len(mess(0,2644,1))
     For I=0 To ECH_NB(IREF)-1
      If ECH_GRP(IREF,I)<>"" & (!find(ECH_GRP(IREF,I),ECH_GRP(IREF,0..I-1)) or !find(ECH_BPR(IREF,I),ECH_BPR(IREF,0..I-1)))
       MTCLET = ECH_GRP(IREF,I)
       SOC    = [F:PYH]CPY
       SITE   = ECH_FCY(IREF,I)
       PLAN   = ECH_COA(IREF,I)
       COMPTE = ECH_CPT(IREF,I)
       TIERS  = ECH_BPR(IREF,I)
       K=0 : Raz [M:LTE] : LETTRE = 0
       If dim([F:GAC]DIFFLG)>0
        Call LECTURE("GAC",COMPTE,PLAN) From CONTOBJ
        If [F:GAC]DIFFLG=2 : LETTRE = 1 : Endif
       Endif
       For [DAE]DAE1 Where CPY=SOC & FCYLIN=SITE & LEDTYP=IREF & ACC=COMPTE & BPR=TIERS & MTC=MTCLET
        If !LETSOC
         If !K : DEVISE=[F:DAE]CUR : Elsif [F:DAE]CUR<>DEVISE : LETSOC=1 : Endif
        Endif
        If IREF=GTYPGEN
         For [DUD]DUD1 Where ACCNUM=[F:DAE]ACCNUM
          Readlock [DUD]DUD1 Curr
          If fstat=1
           GOK=-1 : GLOCK="$GACCDUDATE"-num$([F:DAE]ACCNUM)-num$([F:DUD]DUDLIG) : Break 3
          Elsif fstat
           GOK=0 : Call RSTA("DUD",num$([F:DAE]ACCNUM)-num$([F:DUD]DUDLIG)) From GLOCK : Break 3
          Endif
          # Demande 28247
          J = find([F:DAE]ACCNUM,ECH_NUM(GTYPGEN,0..ECH_NB(GTYPGEN)-1))
          If !J or  ECH_GRP(GTYPGEN,I)<>ECH_GRP(GTYPGEN,J-1)
           J=I
          Else
           J-=1
          Endif
          # Demande 28247 (remplacement du I en J)
          If ([F:DAE]ACCNUM<>ECH_NUM(GTYPGEN,J)) | ([F:DAE]ACCNUM=ECH_NUM(GTYPGEN,J) & [F:DUD]DUDLIG<>ECH_DUDLIG(GTYPGEN,J))
           K += 1
           [M:LTE]ACCNUM([M:LTE]NBLIG) = [F:DUD]ACCNUM
           [M:LTE]DUDLIG([M:LTE]NBLIG) = [F:DUD]DUDLIG
           [M:LTE]NIPT([M:LTE]NBLIG)   = [F:DUD]PAYCUR
           [M:LTE]OIPT([M:LTE]NBLIG)   = [F:DUD]PAYLOC
           [M:LTE]NBLIG+=1
           [F:DUD]PAYCUR = 0
           [F:DUD]PAYLOC = 0
           Rewrite [DUD]
           If fstat
            GOK=0 : Call FSTA("DUD") From GLOCK : Break 3
           Endif
           If dim(GHDUFLG)>0
            GHDUFLG = "A"
            Call HISTOECH("DUD",1,[M:HAE0]ACCDAT)From MODECHE
            Raz GHDUFLG
           Endif
          Elsif ([F:DAE]ACCNUM=ECH_NUM(GTYPGEN,J) & [F:DUD]DUDLIG=ECH_DUDLIG(GTYPGEN,J) & ECH_IPT(GTYPGEN,J)<>0)
           K += 1
           [M:LTE]ACCNUM([M:LTE]NBLIG) = [F:DUD]ACCNUM
           [M:LTE]DUDLIG([M:LTE]NBLIG) = [F:DUD]DUDLIG
           [M:LTE]NIPT([M:LTE]NBLIG)   = ECH_IPT(GTYPGEN,J)
           [M:LTE]OIPT([M:LTE]NBLIG)   = ECH_IPTLOC(GTYPGEN,J)
           [M:LTE]NBLIG+=1
          Endif
         Next : # [DUD]
        Else
         #If !find([F:DAE]ACCNUM,ECH_NUM(IREF,0..ECH_NB(IREF)))
          K += 1
          [M:LTE]ACCNUM([M:LTE]NBLIG) = [F:DAE]ACCNUM
          [M:LTE]DUDLIG([M:LTE]NBLIG) = 1
          [M:LTE]NBLIG+=1
         #Endif
        Endif
       Next : # [DAE]
       If K>1 : K=0
        If !LETSOC
         Call LETTRAGE([M:LTE]NBLIG,[M:LTE]ACCNUM,[M:LTE]DUDLIG,[M:LTE]NIPT,-2,0,STAT,
&                       MESSA,TYP,NUM) From CPTLET
        Else
         Call LETTRAGE([M:LTE]NBLIG,[M:LTE]ACCNUM,[M:LTE]DUDLIG,[M:LTE]OIPT,-1,0,STAT,
&                       MESSA,TYP,NUM) From CPTLET
        Endif
        If STAT & MESSA<>"" : GMESSAGE=MESSA : Endif
        If GOK<1 : Break : Endif
        Read [DAE]DAE2 = ECH_NUM(IREF,I)
        If fstat=0 : MTCLET=[F:DAE]MTC : Else MTCLET="" : Endif
        If MTCLET<>""
         If IREF=GTYPGEN
          For [DAE]DAE1 Where LEDTYP=GTYPGEN & CPY=SOC & FCYLIN=SITE & COA=PLAN & ACC=COMPTE & BPR=TIERS & MTC=MTCLET
           Raz LETFLG
           For [DUD]DUD1 Where ACCNUM=[F:DAE]ACCNUM & (PAYCUR<>0 or PAYLOC<>0)
            LETFLG=1 : Break
           Next : # [DUD]
           If !LETFLG
            Call DELETECR([F:DAE]ACCNUM) From DELETTRAGE
            If !GOK  : GMESSAGE=mess(12,110,1) : Endif
            If GOK<1 : Break : Endif
           Else
            K+=1
           Endif
          Next : # [DAE]
         Endif
        Endif
       Endif
       If K<2
        SVG_GTRACE = GTRACE : Raz GTRACE
        Call DELETTRE(SOC,SITE,IREF,COMPTE,TIERS,MTCLET) From DELETTRAGE
        GTRACE = SVG_GTRACE
        If GOK<1 : Break : Endif
       Endif
      Endif : # ECH_GRP
     Next I
    Next IREF
   Endif : # GOK
  Endif : # GOK
  If GOK>0
   For I=0 To NBCOD-1
    For IREF=1 To len(mess(0,2644,1))
     If CODREF(I)=IREF & !find(CODLET(I),ECH_GRP(CODREF(I),0..ECH_NB(IREF)-1))
      NBRECRLET = 0
      For [DAE6]DAE6 Where [F:DAE6]CPY=CODCPY & [F:DAE6]LEDTYP=CODREF(I) & [F:DAE6]ACC=CODACC(I) & [F:DAE6]BPR=CODBPR(I) & [F:DAE6]MTC=CODLET(I)
       NBRECRLET += 1 : Break
      Next
      If NBRECRLET>0
       Call DELETTRE(CODCPY,CODFCY(I),CODREF(I),CODACC(I),CODBPR(I),CODLET(I)) From DELETTRAGE
      Endif
     Endif
    Next
   Next
  Endif
  If GOK>0
   Delete [PYO] Where PAYVCR=[F:PYH]NUM
   If fstat=1
    GOK=-1 : GLOCK="$PAYORDER"-[F:PYH]NUM
   Elsif fstat>5
    GOK=0 : Call RSTA("PYO",[F:PYH]NUM) From GLOCK
   Endif
  Endif

  If GOK>0 & [F:PYH]STAFLG(8)=2 & [F:PYH]BANPAYTPY<>0
   # Maj du montant provisoire de banque
   Readlock [BAN]BAN0 = [F:PYH]BAN
   If fstat=1
    GOK=-1 : GLOCK="$BANK"-[F:PYH]BAN
   Elsif fstat=0
    [F:BAN]PAYTPY+=[F:PYH]BANPAYTPY
    Rewrite [BAN]
    If fstat
     GOK=0 : Call FSTA("BAN") From GLOCK
    Endif
   Endif
  Endif

  If  GOK>0 & func AFNC.ACTIV("CHQMG")
   Gosub EXEC_ACCCAN From CHKLIB
  Endif

  If GOK>0 and func AFNC.ACTIV("SDD") and [F:PYH]UMRNUM<>""
   If clalev([F:HMDT])=0 : Local File HISTOMDT [HMDT] : Endif
   Local Integer DPT
   If [F:PYH]STAFLG(5)<>2 : [L]DPT=1 Else [L]DPT=2 : Endif
   Update [HMDT] Where PAYNUM=[L]NPYH With DPT=[L]DPT
   If fstat=1
    GOK = -1 : GLOCK = "$HISTOMDT"-[L]NPYH
   Elsif fstat
    GOK = 0 : Call RSTA("HMDT", [L]NPYH) From GLOCK
   Endif
  Endif

  If GOK>0
   BORTYP=[F:PYH]FRMFLG : BORNUM=[F:PYH]FRMNUM
   Raz [F:PYH]STAFLG
   Raz [F:PYH]FRMFLG, [F:PYH]FRMNUM, [F:PYH]FRMLIN, [F:PYH]FRMDAT, [F:PYH]FRMUSR
   Raz [F:PYH]ACCNUMTRE
   [F:PYH]AMTNYTBIL=0
#  [F:PYH]BPRTYP=0 : # GH 30/12/99
   [F:PYH]STAFLG(0)=2
   [F:PYH]STA=1
   [F:PYH]PST=1 : # Non comptabilisé
   Rewrite [PYH]
   If fstat=1
    GOK=-1 : GLOCK="$PAYMENTH"-NPYH
   Elsif fstat
    GOK=0 : Call FSTA("PYH") From GLOCK
   Endif
  Endif

  If GOK>0
   If dim([F:PYL]STA)>0 & [F:PYH]PAYLOT<>""
    Update [PYL] Where [F:PYL]COD=[F:PYH]PAYLOT & [F:PYL]STA=5 With [F:PYL]STA=0
    If fstat=1
     GOK = -1 : GLOCK = "$PAYLOT"-[F:PYH]PAYLOT
    Elsif fstat
     GOK = 0 : Call RSTA("PYL", [F:PYH]PAYLOT) From GLOCK
    Endif
   Endif
  Endif

  If GOK>0 & BORNUM<>""
   Read [PYH]PYH1(2) = BORTYP;BORNUM
   If fstat>2
    Delete [FRM]FRM0 = BORTYP;BORNUM
    If fstat=1
     GOK=-1 : GLOCK="$PAYFRM"-num$(BORTYP)-BORNUM
    Elsif fstat>5
     GOK=0 : Call RSTA("FRM",num$(BORTYP)-BORNUM) From GLOCK
    Endif
   Endif
  Endif

  # E viva Italia
  If GOK>0 & KIBOK
   For [RTH]RTH0 Where PAYNUM=NPYH
    Readlock [PIH]PIH0 = [F:RTH]PIHNUM
    If fstat=1
     GOK=-1 : GLOCK = "$PINVOICE"-[F:RTH]PIHNUM : Break
    Elsif fstat=0
     K=find([F:RTH]RITCOD,[F:PIH]RITCOD(0..[F:PIH]RITNBR-1))-1
     If K<0
      If dim([F:PIH]RITCOD)=[F:PIH]RITNBR
       GOK=0 : Call RSTA("PIH","#dim([F:PIH]RITNBR)<"+num$([F:PIH]RITNBR+1)) From GLOCK : Break
      Else
       K=[F:PIH]RITNBR : [F:PIH]RITNBR+=1
       [F:PIH]RITCOD(K)=[F:RTH]RITCOD : [F:PIH]RITAMTDED(K)=0 : [F:PIH]RITBASDED(K)=0
      Endif
     Endif
     [F:PIH]RITAMTDED(K) -= [F:RTH]AMT
     [F:PIH]RITBASDED(K) -= [F:RTH]BAS
     Rewrite [PIH]
     If fstat
      GOK=0 : Call FSTA("PIH") From GLOCK : Break
     Endif
    Endif
   Next : # [F:RTH]
   If GOK>0
    Delete [RTH] Where PAYNUM=[L]NPYH
    If fstat=1
     GOK=-1 : GLOCK="$RITHIS"-[L]NPYH
    Elsif fstat>5
     GOK=0 : Call RSTA("RTH",[L]NPYH) From GLOCK
    Endif
   Endif
  Endif

  If GOK>0
   # Demande 17218 : annulation d'enregistrements d'autres tables
   GPOINT = "ANNUL" : Gosub ENTREE From EXEFNC
  Endif

  If GOK>0 & TEST : GOK=0 : Endif
  If    GOK<0 : Goto ROL_TR1
  Elsif GOK=0 : Goto AB_TR1
  Endif
Endcase


Commit
GTRANS=0

Call FERME_TRACE From LECFIC
TRA=1

If dim(GHDUFLG)>0
 Kill GHDUFLG
Endif
Return

$AB_TR1
Rollback : GTRANS=0
Gosub EFF_TRACE
If GMESSAGE<>"" : GERR=1 : Endif
FIN=1 : Return

$ROL_TR1
Rollback  : GTRANS=0
Gosub EFF_TRACE
Call ROLL From GLOCK
If GROLL : FIN=1 : Return : Else Goto TR1 : Endif

$EFF_TRACE
Openo FICTRA , DEBTRA
Return

###############################################################
## Extourne totale de la pièce correspondant à ACCNUM=PANCUR ##
###############################################################
$EXTOURNE
If [F:PAN]STA=10
 If ACCNUM_H=0
  Filter [PAN2] Where TYPNUM=TPYH & NUM=NPYH & STA=10 & ACCNUM<>[F:PAN]ACCNUM & RVSACCNUM=0
  Read [PAN2]PAN0 Last
  Filter [PAN2]
  If fstat<=2 : PANCUR=[F:PAN2]ACCNUM : Else PANCUR=0 : Endif
 Else
  PANCUR=ACCNUM_H
 Endif
 If PANCUR : # Spécifique Portugal
  Gosub LECDAE : If GOK<1 : Return : Endif
  TYPCUR=[F:DAE]TYP : NUMCUR=[F:DAE]NUM
  Filter [DAE] Where TYP=[L]TYPCUR & NUM=[L]NUMCUR & ACCNUM<>[L]PANCUR
  Read [DAE]DAE0 First
  Filter [DAE]
  If fstat<=2
   [F:PAN]RVSACCNUM=[F:DAE]ACCNUM
   Rewrite [PAN]
   If fstat=1
    GOK=-1 : GLOCK="$PAYACCNUM"-num$([F:PAN]TYPNUM)-[F:PAN]NUM-num$([F:PAN]STA)
   Elsif fstat
    GOK=0 : Call FSTA("PAN") From GLOCK
   Endif
   PANCUR=[F:PAN]ACCNUM : Gosub LECDAE : If GOK<1 : Return : Endif
   Gosub LECHAE : If GOK<1 : Return : Endif
   [F:HAE]RVS = 3 : # Extournée
   Rewrite [HAE]
   If fstat
    GOK=0 : Call FSTA("HAE") From GLOCK : Return
   Endif
   If ACCNUM_H=0 : ACCNUM_H=[F:PAN]ACCNUM : Else ACCNUM_H=0 : Endif
   Return
  Endif
 Endif
Endif

PANCUR=[F:PAN]ACCNUM : Gosub LECDAE : If GOK<1 : Return : Endif
Gosub LECHAE : If GOK<1 : Return : Endif
TYPCUR=[F:HAE]TYP : NUMCUR=[F:HAE]NUM
If [F:DAE]MTC<>"" & [F:PAN]CPTBAN=2 & !find([F:DAE]ACCNUM,TBNUM(0..NBTB-1))
 SOC=[F:DAE]CPY : SITE=[F:DAE]FCYLIN : PLGEN=[F:DAE]COA : CPTGEN=[F:DAE]ACC : TIERS=[F:DAE]BPR
 MTCLET=[F:DAE]MTC
Else MTCLET=""
Endif

# Mise à jour pièce d'origine
[F:HAE]RVS = 3 : # Extournée
Rewrite [HAE]
If fstat
 GOK=0 : Call FSTA("HAE") From GLOCK : Return
Endif

# Chargement écrans
Raz [M:HAE0], [M:HAE1], [M:HAE2]
[M:HAE0] = [F:HAE]
[M:HAE1] = [F:HAE]
If [M:DIA]ACCDAT<>[0/0/0] : [M:HAE0]ACCDAT=[M:DIA]ACCDAT : Endif
If [M:DIA]DESVCR<>""      : [M:HAE1]DESVCR=[M:DIA]DESVCR : Endif
Gosub LIENS From SUBGAS
If GERR=1
 GOK = 0 : Return
Endif
[M:HAE0]NUM = ""
[M:HAE1]RVS = 1
[M:HAE1]RVSDAT = [0/0/0]
PANNOL=-1

OLIN = 0
Read [DAE]DAE2 =[F:PAN]ACCNUM
If !fstat
 OLIN = [F:DAE]LIN : OLEDTYP = [F:DAE]LEDTYP
Endif

If [F:PAN]CPTBAN=2
 PRORO = 0
 Filter [PAN2] Where TYPNUM=TPYH & NUM=NPYH & STA=4 & GRP="N"+num$([F:PAN]ACCNUM)
 Read [PAN2]PAN0 Last
 Filter [PAN2]
 If !fstat
  PANCUR = [F:PAN2]ACCNUM : PRORO = 1
 Endif
Endif

For NOL=0 To [M:HAE2]NBLIG-1
 If NOL=OLIN-1
  PANNOL=NOL
  # Pour les prorogations...
  If PRORO
   Gosub LECDAE
   If GOK<1 : Break : Endif
   Case [M:HAEF]TYPENT
    When 1
     For IREF=1 To len(mess(0,2644,1))
      INDREF = find(IREF,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
      If IREF=GTYPGEN
       Assign "[M:HAE2]ACC"+num$(INDREF)+"("+num$(NOL)+")" With [F:DAE]ACC
       Assign "[M:HAE2]SAC"+num$(INDREF)+"("+num$(NOL)+")" With [F:DAE]SAC
      Else
       Read [DAE3]DAE7 = [F:DAE]TYP;[F:DAE]NUM;[F:DAE]IDTLIN;IREF;[F:DAE]LIN
       If !fstat
        Assign "[M:HAE2]ACC"+num$(INDREF)+"("+num$(NOL)+")" With [F:DAE3]ACC
        Assign "[M:HAE2]SAC"+num$(INDREF)+"("+num$(NOL)+")" With [F:DAE3]SAC
       Endif
      Endif
     Next
    If GOK<1 : Break : Endif
    When 2
     nolign=NOL+1 : [M:HAE2]=[F:DAE]
   Endcase
  Endif
 Endif
 Case [M:DIA]EXTSNS
  When 1 : # Débit <=> crédit
   If [M]DEB(NOL)<>0
    [M]CDT(NOL) = [M]DEB(NOL)
    [M]DEB(NOL) = 0
   Else
    [M]DEB(NOL) = [M]CDT(NOL)
    [M]CDT(NOL) = 0
   Endif
  When 2 : # Montant <=> montant <0
   [M]DEB(NOL) = -[M]DEB(NOL)
   [M]CDT(NOL) = -[M]CDT(NOL)
   If dim([M]QTY)>0 : [M]QTY(NOL) = -[M]QTY(NOL) : Endif
   If [M]DSP(NOL)="$"
    For I=[M]PTV(NOL) To [M]PTF(NOL)
     [M:VT2]TBAMT(I) = -[M:VT2]TBAMT(I)
     [M:VT2]TBQTY(I) = -[M:VT2]TBQTY(I)
    Next I
   Endif
 Endcase
 If ([M]DEB(NOL)=0 & [M]CDT(NOL)=0) or [M:DIA]EXTSNS=2
  For X=1 To len(mess(0,2644,1))
   Assign "[M]AMT"+num$(X)+"("+num$(NOL)+")" With evalue("[M]AMT"+num$(X)+"("+num$(NOL)+")")*-1
   Assign "[M]AMTFRC"+num$(X)+"("+num$(NOL)+")" With evalue("[M]AMTFRC"+num$(X)+"("+num$(NOL)+")")*-1
  Next
 Endif
 [M:HAE2]CHRNUM(NOL)   = ""
 [M:HAE2]ACCNUM(NOL)   = 0
 [M:HAE2]MTC(NOL)      =""
 [M:HAE2]MTCDAT(NOL)   =[0/0/0]
 [M:HAE2]MTCDATMAX(NOL)=[0/0/0]
 [M:HAE2]MTCDATMIN(NOL)=[0/0/0]
 # Demande 30118
 GPOINT= "BEFWRIDAE"  : Gosub ENTREE From EXEFNC
Next NOL
For NOL=0 To [M:HAEW]NB-1
 TBACCNUM(NOL)  = [M:HAEW]ACCNUM(NOL)
Next

# Contrôles écran
STAT=0
Call CONTROLE(STAT,MESSA) From CPTBATCH
If !STAT & MESSA=""
 Call LECTURE("CPY",[M:HAE0]CPY,"") From CONTOBJ
 For NOL=0 To [M:HAE2]NBLIG-1
  Case [M:HAEF]TYPENT
   When 1
    IREFMAIN = find(GTYPGEN,[M:HAEF]LEDTYP(0..dim([M:HAEF]LEDTYP)-1))
    PLAN = evalue("[M:HAEF]COA"+"("+num$(IREFMAIN-1)+")")
    COMPTE = evalue("[M:HAE2]ACC"+num$(IREFMAIN)+"("+num$(NOL)+")")
    Gosub CTLBANDEV
    If STAT : Break : Endif
   When 2
    If [M:HAE2]LEDTYP(NOL)=GTYPGEN
     Call LECPLAN([M]CPY,GTYPGEN,PLAN) From CPTDIV
     COMPTE = [M:HAE2]ACC1(NOL)
     Gosub CTLBANDEV
     If STAT : Break : Endif
    Endif
  Endcase
 Next NOL
Endif
If STAT | MESSA<>""
 Gosub MESSAGE From CPTAUTO
 GMESSAGE=MESSA : GOK=0 : Return
Endif

# Ecriture de la pièce
Call VALID
If GOK<1 : Return : Endif

# F17028 : Sauvegarde de valeurs (essentielle lors d'extourne d'une pièce de lettrage automatique)
SVG_TYP  = [M:HAE0]TYP
SVG_NUM  = [M:HAE0]NUM

If MTCLET<>""
 Gosub TBLET_IN : If GOK<1 : Return : Endif
Elsif [F:PAN]CPTBAN=2
 For NOL=0 To [M:HAE2]NBLIG-1
  Gosub TBLET_OUT
 Next NOL
Endif

SVG_NBLIG = [M:HAEW]NB-1
For NOL=0 To SVG_NBLIG
 SVG_LEDTYP(NOL) = [M:HAEW]LEDTYP(NOL)
 SVG_LIN(NOL)    = [M:HAEW]LIN(NOL)
 SVG_FCY(NOL)    = [M:HAEW]FCYLIN(NOL)
 SVG_COA(NOL)    = [M:HAEW]COA(NOL)
 SVG_ACC(NOL)    = [M:HAEW]ACC(NOL)
 SVG_BPR(NOL)    = [M:HAEW]BPR(NOL)
 SVG_DEB(NOL)    = [M:HAEW]DEB(NOL)
 SVG_CDT(NOL)    = [M:HAEW]CDT(NOL)
 SVG_NUM1(NOL)   = [M:HAEW]ACCNUM(NOL)
Next

# Lettrage de l'extourne avec écriture d'origine
For NOL=0 To SVG_NBLIG
 If SVG_LIN(NOL)=[L]OLIN & SVG_LEDTYP(NOL)=[L]OLEDTYP
  SVG_NUM2 = SVG_NUM1(NOL)
 Endif
 Call LEDTYPAUT([M:HAE0]CPY,SVG_LEDTYP(NOL),[L]FLGAUT) From CPTDIV
 If FLGAUT <> 2 & SVG_ACC(NOL)<>""
  Call LECTURE("GAC",SVG_ACC(NOL),SVG_COA(NOL)) From CONTOBJ
  If [F:GAC]MTC=2 : # Compte lettrable
   SYMBOLE = "MTC"-SVG_FCY(NOL)-SVG_ACC(NOL)-SVG_BPR(NOL)
   Lock =SYMBOLE :  If fstat=1 : GOK=-1 : GLOCK="%"+SYMBOLE : Break : Endif
   SVG_GTRACE = GTRACE : Raz GTRACE
   Read [DAE]DAE0 = [L]TYPCUR;[L]NUMCUR;SVG_LIN(NOL);SVG_LEDTYP(NOL) : # Lecture écriture origine
   If !fstat
    Call DELETECR([F:DAE]ACCNUM) From DELETTRAGE
    GTRACE = SVG_GTRACE
    If GOK<1 : Break : Endif

    If SVG_BPR(NOL)<>"" & SVG_COA(NOL)=[L]PLGEN : # On est sur le référentiel général principal....
     NBLET = 0
     For [DUD]DUD1 Where ACCNUM=[F:DAE]ACCNUM
      NBLET += 1
      TBLET(NBLET)  = [F:DUD]ACCNUM
      DUDLIG(NBLET) = [F:DUD]DUDLIG
      AMTIPT(NBLET) = [F:DUD]AMTCUR
     Next : # [DUD]
    Else
     NBLET     = 1
     TBLET(NBLET)  = [F:DAE]ACCNUM
     DUDLIG(NBLET) = 1
     AMTIPT(NBLET) = SVG_DEB(NOL)+SVG_CDT(NOL)
    Endif
    NBLET += 1
    TBLET(NBLET)  = SVG_NUM1(NOL)
    DUDLIG(NBLET) = 1
    AMTIPT(NBLET) = SVG_DEB(NOL)+SVG_CDT(NOL)
    Call LETDIF(NBLET,TBLET,DUDLIG,AMTIPT,2) From CPTLET
    If GOK<1 : Break : Endif
    If [F:DAE]MTC<>""
     If NBCOD>=MAXECH : # Trop d'échéances à lettrer (MAXECH>MAXECH)
      GMESSAGE=mess(81,117,1)-"(MAXECH>"+num$(MAXECH)+")" : GOK=0 : Break
     Endif
     CODLET(NBCOD) = [F:DAE]MTC
     CODREF(NBCOD) = [F:DAE]LEDTYP
     CODACC(NBCOD) = [F:DAE]ACC
     CODBPR(NBCOD) = [F:DAE]BPR
     CODFCY(NBCOD) = [F:DAE]FCYLIN
     CODCPY = [F:DAE]CPY
     NBCOD+=1
    Endif
   Endif
  Endif
 Endif
Next NOL
If GOK<1 : Return : Endif

If PANNOL<>-1
 [F:PAN]RVSACCNUM=-SVG_NUM2
 Rewrite [PAN]
 If fstat=1
  GOK=-1 : GLOCK="$PAYACCNUM"-num$([F:PAN]TYPNUM)-[F:PAN]NUM-num$([F:PAN]STA) : Return
 Elsif fstat
  GOK=0 : Call FSTA("PAN") From GLOCK : Return
 Endif

 # Pour les prorogations
 If [F:PAN]CPTBAN=2
  For [PAN2]PAN0 Where TYPNUM=TPYH & NUM=NPYH & STA=4 & GRP="N"+num$([F:PAN]ACCNUM)
   [F:PAN2]RVSACCNUM=SVG_NUM2
   Rewrite [PAN2]
   If fstat=1
    GOK=-1 : GLOCK="$PAYACCNUM2"-num$([F:PAN2]TYPNUM)-[F:PAN2]NUM-num$([F:PAN2]STA) : Break
   Elsif fstat
    GOK=0 : Call FSTA("PAN2") From GLOCK : Break
   Endif
  Next
  If GOK<1 : Return : Endif
 Endif

 If [F:PYH]FRMNUM<>"" & find([F:PAN]ACCSTA,8,9)
  Read [PAN2]PAN0 = [F:PYH]FRMFLG;[F:PYH]FRMNUM;3;[F:PAN]ACCNUM
  If fstat=0
   [F:PAN2]RVSACCNUM=SVG_NUM2
   [F:PAN2]RENCOD="A"+[F:PYH]NUM : # Annulation
   Rewrite [PAN2]
   If fstat=1
    GOK=-1 : GLOCK="$PAYACCNUM"-num$([F:PAN2]TYPNUM)-[F:PAN2]NUM-num$([F:PAN2]STA) : Return
   Elsif fstat
    GOK=0 : Call FSTA("PAN2") From GLOCK : Return
   Endif
  Endif
 Endif
Endif

If NUMESPION
 Call ESPION("GACCENTRY",1,SVG_TYP,SVG_NUM) From ESPION
 If GOK<1 : Return : Endif
Endif

Call ECR_TRACE(SVG_TYP-SVG_NUM-mess(10,107,1)-TYPCUR-NUMCUR,0) From GESECRAN
# Pièce extournée

If [F:PAN]STA=3
 Filter [PAN2] Where TYPNUM=TPYH & NUM=NPYH & STA=-10 & ACCSTA=9
 Read [PAN2]PAN0 Last
 Filter [PAN2]
 If fstat<=2 : # Spécifique Espagnol
  ACCNUM_G=[F:PAN2]ACCNUM
  # on delettre la dévalorisation espagnole immédiatement
  Filter [PAN2] Where TYPNUM=TPYH & NUM=NPYH & STA=10 & ACCSTA=10
  Read [PAN2]PAN0 Last
  Filter [PAN2]
  If fstat<=2
   PANCUR=[F:PAN2]ACCNUM : Gosub LECDAE : If GOK<1 : Return : Endif
   Gosub LECHAE : If GOK<1 : Return : Endif
   TYPCUR=[F:HAE]TYP : NUMCUR=[F:HAE]NUM
   For [DAE]DAE0 Where TYP=[L]TYPCUR & NUM=[L]NUMCUR
    SYMBOLE = "MTC"-[F:DAE]FCYLIN-[F:DAE]ACC-[F:DAE]BPR
    Lock =SYMBOLE
    If fstat=1 : GOK=-1 : GLOCK="%"+SYMBOLE : Break : Endif
    SVG_GTRACE = GTRACE : Raz GTRACE
    Call DELETTRE([F:DAE]CPY,[F:DAE]FCYLIN,[F:DAE]LEDTYP,[F:DAE]ACC,[F:DAE]BPR,[F:DAE]MTC) From DELETTRAGE
    Call DELETECR([F:DAE]ACCNUM) From DELETTRAGE
    GTRACE = SVG_GTRACE
    If GOK<1 : Break : Endif
   Next : #[DAE]
   ACCNUM_G=-ACCNUM_G
  Endif
  # on remplit TBNUM pour TBSTA=10
  PANCUR=abs(ACCNUM_G) : Gosub LECDAE : If GOK<1 : Return : Endif
  [F:PAN]STA=10
  If [F:DAE]MTC<>""
   SOC=[F:DAE]CPY : SITE=[F:DAE]FCYLIN : COMPTE=[F:DAE]ACC : TIERS=[F:DAE]BPR
   MTCLET=[F:DAE]MTC : [M:HAE2]NBLIG=0
   Gosub TBLET_IN
  Else
   Gosub TBLET_IN2
  Endif
  [F:PAN]STA=3
  If GOK<1 : Return : Endif
 Endif
Endif
# Interface trésorerie
If func AFNC.ACTIV("CASIN") : Gosub EXTOURNE From EXPCASPAY : Endif
If GOK<1 : Return : Endif
Return


$CTLBANDEV
Call LECTURE("GAC",COMPTE,[L]PLAN) From CONTOBJ
If !fstat & [F:GAC]CUR<>""
 BANCUR = [F:GAC]CUR
 Filter [BAN] Where BANACC=[F:GAC]ACC
 Read [BAN]BAN0 First
 Filter [BAN]
 If !fstat & [F:BAN]CHGDAT<>[0/0/0] & [M:HAE0]ACCDAT < [F:BAN]CHGDAT
  BANCUR = [F:BAN]OLDCUR
 Endif
 Call LECLED([F:PYH]CPY,GTYPGEN,CODLED,DEVLED) From CPTDIV
 If BANCUR<>[M]CUR & [M]CUR<>DEVLED
  GMESSAGE = [L]PLAN-[L]COMPTE-mess(13,106,1)-BANCUR  :# Devise du compte:
  STAT=99 : Return
 Endif
Endif
Return


##############################################
## Extourne partielle d'une pièce comptable ##
##############################################
$EXTOURNE_PARTIEL
Filter [PMD] Where NUM=NPYH & ACCSTA = [F:PAN]ACCSTA & ACCNUM=[F:PAN]ACCNUM & RVSACCNUM=0
Read [PMD]PMD0 First
Filter [PMD]
If fstat : Return : Endif
PANCUR = [F:PMD]ACCNUM : Gosub LECDAE
If GOK<1 : Return : Endif
Gosub LECHAE
If GOK<1 : Return : Endif
Call LECTURE("TCU",[F:HAE]CUR,"") From CONTOBJ
ARD1 = [F:TCU]CURRND
TYPCUR=[F:DAE]TYP : NUMCUR=[F:DAE]NUM
[F:HAE]RVS = 3 : # Extournée
Rewrite [HAE]
If fstat
 GOK=0 : Call FSTA("HAE") From GLOCK : Return
Endif

Raz [M:HAE0], [M:HAE1], [M:HAE2], [M:VTL], [M:VT2]
[M:HAE0] = [F:HAE]
[M:HAE1] = [F:HAE]

GFLAG = [F:HAE]DACDIA
If !clalev([F:GDE2]) : Local File =GTABCPT+"GDIAENTRY" [GDE2] : Endif
Read [F:GDE2]DIA = [F:HAE]DACDIA
If !fstat : WSAI = [F:GDE2]TYPENT : Endif

#-- Initialisation (les messages d'erreur liée au STAT sont traités sous $DROIT)
Call INIMSKFMT([F:HAE]FCY,GFLAG,[F:HAE]TYP,[F:HAE]ACCDAT,STAT)  From SUBGASA
Call GETSOC([F:HAE]FCY) From DEVSUB

If [M:DIA]ACCDAT<>[0/0/0] : [M:HAE0]ACCDAT=[M:DIA]ACCDAT : Endif
If [M:DIA]DESVCR<>""      : [M:HAE1]DESVCR=[M:DIA]DESVCR : Endif
Gosub LIENS
[M:HAE0]NUM = ""
[M:HAE1]RVS = 1
[M:HAE1]RVSDAT = [0/0/0]
nolign = 0 : NOL = 0
## Dans PAYACCNUMD, on stocke les lignes d'écritures générées pour un règlement
## sur le référentiel général principal
For [PMD]PMD0 Where NUM=NPYH & ACCSTA = [F:PAN]ACCSTA & RVSACCNUM=0 & TYP=[F:HAE]TYP & VCRNUM=[F:HAE]NUM
 PANCUR = [F:PMD]ACCNUM
 Gosub LECDAE
 If GOK<1 : Break : Endif
 nolign += 1 : NOL=nolign-1
 [M:HAE2] = [F:DAE]
 If [F:DAE]AMTCUR<>[F:PMD]AMTCUR
  COEFF = [F:PMD]AMTCUR/[F:DAE]AMTCUR
 Else
  COEFF = 1
 Endif
 Gosub LIENS2
 Case [M:DIA]EXTSNS
  When 1 : # Débit <=> crédit
   If [M:HAE2]DEB(NOL)<>0
    [M:HAE2]CDT(NOL) = [M:HAE2]DEB(NOL)
    [M:HAE2]DEB(NOL) = 0
   Else
    [M:HAE2]DEB(NOL) = [M:HAE2]CDT(NOL)
    [M:HAE2]CDT(NOL) = 0
   Endif
  When 2 : # Montant <=> montant <0
   [M:HAE2]DEB(NOL) = -[M:HAE2]DEB(NOL)
   [M:HAE2]CDT(NOL) = -[M:HAE2]CDT(NOL)
   If dim([M:HAE2]QTY)>0 : [M:HAE2]QTY(NOL) = -[M:HAE2]QTY(NOL) : Endif
   If [M:HAE2]DSP(NOL)="$"
    For I=[M:HAE2]PTV(NOL) To [M:HAE2]PTF(NOL)
     [M:VT2]TBAMT(I) = -[M:VT2]TBAMT(I)
     [M:VT2]TBQTY(I) = -[M:VT2]TBQTY(I)
    Next I
   Endif
 Endcase
 TBACCNUM(NOL)  = [M:HAE2]ACCNUM(NOL)
 [M:HAE2]CHRNUM(NOL)   = ""
 [M:HAE2]ACCNUM(NOL)   = 0
 [M:HAE2]MTC(NOL)      =""
 [M:HAE2]MTCDAT(NOL)   =[0/0/0]
 [M:HAE2]MTCDATMAX(NOL)=[0/0/0]
 [M:HAE2]MTCDATMIN(NOL)=[0/0/0]
 # Demande 30118
 GPOINT= "BEFWRIDAE"  : Gosub ENTREE From EXEFNC
 ## On extourne les lignes d'écritures des autres référentiels.
 ## On exploite pour cela l'identifiant ligne et le montant sera calculé en exploitant le variable COEFF
 ## (idem V140). Cela suppose que la manière de regrouper les écritures
 ## est la même pour tous les types de référentiel
 Case [M:HAEF]TYPENT
  When 1
   For IREF=1 To len(mess(0,2644,1))
    INDREF = find(IREF,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
    If INDREF & IREF=GTYPGEN
     Assign "[M:HAE2]ACC"+num$(INDREF)+"("+num$(NOL)+")" With [F:DAE]ACC
     Assign "[M:HAE2]SAC"+num$(INDREF)+"("+num$(NOL)+")" With [F:DAE]SAC
    Endif
    TYPPCE = [F:DAE]TYP : NUMPCE = [F:DAE]NUM : ID = [F:DAE]IDTLIN : LIGNE = [F:DAE]LIN
    Read [DAE]DAE7 = TYPPCE;NUMPCE;ID;IREF;LIGNE
    If !fstat
     If INDREF
      Assign "[M:HAE2]ACC"+num$(INDREF)+"("+num$(NOL)+")" With [F:DAE]ACC
      Assign "[M:HAE2]SAC"+num$(INDREF)+"("+num$(NOL)+")" With [F:DAE]SAC
     Endif
     Assign "[M]AMT"+num$([F:DAE]LEDTYP)+"("+num$(NOL)+")" With arr([F:DAE]AMTLED*[F:DAE]SNS*COEFF,ARD1)
     If COEFF<>1 & [M:HAEF]BAL([F:DAE]LEDTYP-1)=2 & [M:HAEF]RNDOPT([F:DAE]LEDTYP-1)<>2
      Assign "[M]AMTFLG"+num$([F:DAE]LEDTYP)+"("+num$(NOL)+")" With 0
      Assign "[M]AMTFRC"+num$([F:DAE]LEDTYP)+"("+num$(NOL)+")" With 0
     Else
      Assign "[M]AMTFLG"+num$([F:DAE]LEDTYP)+"("+num$(NOL)+")" With [F:DAE]AMTFLG
      Assign "[M]AMTFRC"+num$([F:DAE]LEDTYP)+"("+num$(NOL)+")" With arr([F:DAE]AMTLED1*COEFF,ARD1)
     Endif
     Gosub LIEN_DAA
    Endif
   Next
  When 2
   TYPPCE = [F:DAE]TYP : NUMPCE = [F:DAE]NUM : ID = [F:DAE]IDTLIN : LIGNE = [F:DAE]LIN
   Read [DAE]DAE7 = [F:DAE]TYP;[F:DAE]NUM;[F:DAE]IDTLIN;IREF;[F:DAE]LIN
   If !fstat
    NOL+=1
    nolign=NOL+1 : [M:HAE2]=[F:DAE]
    Gosub LIENS2
    Case [M:DIA]EXTSNS
     When 1 : # Débit <=> crédit
      If [M:HAE2]DEB(NOL)<>0
       [M:HAE2]CDT(NOL) = [M:HAE2]DEB(NOL)
       [M:HAE2]DEB(NOL) = 0
      Else
       [M:HAE2]DEB(NOL) = [M:HAE2]CDT(NOL)
       [M:HAE2]CDT(NOL) = 0
      Endif
     When 2 : # Montant <=> montant <0
      [M:HAE2]DEB(NOL) = -[M:HAE2]DEB(NOL)
      [M:HAE2]CDT(NOL) = -[M:HAE2]CDT(NOL)
      If dim([M:HAE2]QTY)>0 : [M:HAE2]QTY(NOL) = -[M:HAE2]QTY(NOL) : Endif
      If [M:HAE2]DSP(NOL)="$"
       For I=[M:HAE2]PTV(NOL) To [M:HAE2]PTF(NOL)
        [M:VT2]TBAMT(I) = -[M:VT2]TBAMT(I)
        [M:VT2]TBQTY(I) = -[M:VT2]TBQTY(I)
       Next I
      Endif
    Endcase
    Assign "[M]AMT"+num$([F:DAE]LEDTYP)+"("+num$(NOL)+")" With arr([F:DAE]AMTLED*[F:DAE]SNS*COEFF,ARD1)
    If COEFF<>1 & [M:HAEF]BAL([F:DAE]LEDTYP-1)=2 & [M:HAEF]RNDOPT([F:DAE]LEDTYP-1)<>2
     Assign "[M]AMTFLG"+num$([F:DAE]LEDTYP)+"("+num$(NOL)+")" With 0
     Assign "[M]AMTFRC"+num$([F:DAE]LEDTYP)+"("+num$(NOL)+")" With 0
    Else
     Assign "[M]AMTFLG"+num$([F:DAE]LEDTYP)+"("+num$(NOL)+")" With [F:DAE]AMTFLG
     Assign "[M]AMTFRC"+num$([F:DAE]LEDTYP)+"("+num$(NOL)+")" With arr([F:DAE]AMTLED1*COEFF,ARD1)
    Endif
    [M:HAE2]CHRNUM(NOL)   = ""
    [M:HAE2]ACCNUM(NOL)   = 0
    [M:HAE2]MTC(NOL)      =""
    [M:HAE2]MTCDAT(NOL)   =[0/0/0]
    [M:HAE2]MTCDATMAX(NOL)=[0/0/0]
    [M:HAE2]MTCDATMIN(NOL)=[0/0/0]
   Endif
 Endcase
 If ([M]DEB(NOL)=0 & [M]CDT(NOL)=0) or [M:DIA]EXTSNS=2
  For X=1 To len(mess(0,2644,1))
   Assign "[M]AMT"+num$(X)+"("+num$(NOL)+")" With evalue("[M]AMT"+num$(X)+"("+num$(NOL)+")")*-1
   Assign "[M]AMTFRC"+num$(X)+"("+num$(NOL)+")" With evalue("[M]AMTFRC"+num$(X)+"("+num$(NOL)+")")*-1
  Next
 Endif
Next
If GOK<1 : Return : Endif
[M:VT2]PTVENT = K+1
[M:HAE2]NBLIG = nolign

STAT=0
Call CONTROLE(STAT,MESSA) From CPTBATCH
If !STAT & MESSA=""
 Call LECTURE("CPY",[M:HAE0]CPY,"") From CONTOBJ
 For NOL=0 To [M:HAE2]NBLIG-1
  Case [M:HAEF]TYPENT
   When 1
    IREFMAIN = find(GTYPGEN,[M:HAEF]LEDTYP(0..dim([M:HAEF]LEDTYP)-1))
    PLAN = evalue("[M:HAE2]COA"+"("+num$(IREFMAIN-1)+")")
    COMPTE = evalue("[M:HAE2]ACC"+num$(IREFMAIN)+"("+num$(NOL)+")")
    Gosub CTLBANDEV
    If STAT : Break : Endif
   When 2
    If [M:HAE2]LEDTYP(NOL)=GTYPGEN
     Call LECPLAN([M]CPY,GTYPGEN,PLAN) From CPTDIV
     COMPTE = [M:HAE2]ACC1(NOL)
     Gosub CTLBANDEV
     If STAT : Break : Endif
    Endif
  Endcase
 Next NOL
Endif
If STAT | MESSA<>""
 Gosub MESSAGE From CPTAUTO
 GMESSAGE=MESSA : GOK=0 : Return
Endif

# Ecriture de la pièce
Call VALID
If GOK<1 : Return : Endif

# Lettrage de l'extourne avec écriture d'origine
SVG_NBLIG = [M:HAEW]NB-1
For NOL=0 To SVG_NBLIG
 SVG_LEDTYP(NOL) = [M:HAEW]LEDTYP(NOL)
 SVG_FCY(NOL)    = [M:HAEW]FCYLIN(NOL)
 SVG_COA(NOL)    = [M:HAEW]COA(NOL)
 SVG_ACC(NOL)    = [M:HAEW]ACC(NOL)
 SVG_BPR(NOL)    = [M:HAEW]BPR(NOL)
 SVG_DEB(NOL)    = [M:HAEW]DEB(NOL)
 SVG_CDT(NOL)    = [M:HAEW]CDT(NOL)
 SVG_NUM1(NOL)   = [M:HAEW]ACCNUM(NOL)
 SVG_DES(NOL)    = [M:HAEW]DES(NOL)
Next

Raz [L]CRITSPE
GPOINT = "FILTER_DAE" : Gosub ENTREE From EXEFNC
If [L]CRITSPE="" : [L]CRITSPE = "1=1" : Endif

Raz NBRACCNUM, LSTACCNUM

For NOL=0 To SVG_NBLIG
 LU = 0
 Call LEDTYPAUT([M:HAE0]CPY,SVG_LEDTYP(NOL),[L]FLGAUT) From CPTDIV
 If [L]FLGAUT<>2 & SVG_ACC(NOL)<>""
  Call LECTURE("GAC",SVG_ACC(NOL),SVG_COA(NOL)) From CONTOBJ
  If [F:GAC]MTC=2 : # Compte lettrable
   SYMBOLE = "MTC"-SVG_FCY(NOL)-SVG_ACC(NOL)-SVG_BPR(NOL)
   Lock =SYMBOLE :  If fstat=1 : GOK=-1 : GLOCK="%"+SYMBOLE : Break : Endif
   SVG_GTRACE = GTRACE : Raz GTRACE
   For [DAE]DAE0 Where TYP=[L]TYPCUR & NUM=[L]NUMCUR & LEDTYP=SVG_LEDTYP(NOL)
&                    & vireblc(right$([F:DAE]REFINTLIN,4),2)=[F:PYH]NUM & ACC=SVG_ACC(NOL) & BPR=SVG_BPR(NOL)
&                    & !find([F:DAE]ACCNUM,LSTACCNUM(0..NBRACCNUM))
    LSTACCNUM(NBRACCNUM) = [F:DAE]ACCNUM
    NBRACCNUM +=1
    Call DELETECR([F:DAE]ACCNUM) From DELETTRAGE
    LU = 1 : Break
   Next

   If LU
    GTRACE = SVG_GTRACE
    If GOK<1 : Break : Endif

    If SVG_BPR(NOL)<>"" & SVG_COA(NOL)=[L]PLGEN
     NBLET = 0
     For [DUD]DUD1 Where ACCNUM=[F:DAE]ACCNUM
      NBLET += 1
      TBLET(NBLET)  = [F:DUD]ACCNUM
      DUDLIG(NBLET) = [F:DUD]DUDLIG
      AMTIPT(NBLET) = [F:DUD]AMTCUR
     Next : # [DUD]
    Else
     NBLET     = 1
     TBLET(NBLET)  = [F:DAE]ACCNUM
     DUDLIG(NBLET) = 1
     AMTIPT(NBLET) = SVG_DEB(NOL)+SVG_CDT(NOL)
    Endif
    NBLET += 1
    TBLET(NBLET)  = SVG_NUM1(NOL)
    DUDLIG(NBLET) = 1
    AMTIPT(NBLET) = SVG_DEB(NOL)+SVG_CDT(NOL)
    Call LETDIF(NBLET,TBLET,DUDLIG,AMTIPT,2) From CPTLET
    If GOK<1 : Break : Endif
    If [F:DAE]MTC<>""
     If NBCOD>=MAXECH : # Trop d'échéances à lettrer (MAXECH>MAXECH)
      GMESSAGE=mess(81,117,1)-"(MAXECH>"+num$(MAXECH)+")" : GOK=0 : Break
     Endif
     CODLET(NBCOD) = [F:DAE]MTC
     CODREF(NBCOD) = [F:DAE]LEDTYP
     CODACC(NBCOD) = [F:DAE]ACC
     CODBPR(NBCOD) = [F:DAE]BPR
     CODFCY(NBCOD) = [F:DAE]FCYLIN
     CODCPY = [F:DAE]CPY
     NBCOD+=1
    Endif
   Endif
  Endif

  # MAJ champs RVSACCNUM

  If SVG_LEDTYP(NOL)=GTYPGEN
   If !LU
    Call LEC_GAC(SVG_ACC(NOL),SVG_COA(NOL)) From CPTLEC
    For [DAE]DAE0 Where TYP=[L]TYPCUR & NUM=[L]NUMCUR & LEDTYP=SVG_LEDTYP(NOL)  & FCYLIN=SVG_FCY(NOL)
&                     & ACC=SVG_ACC(NOL) & BPR=SVG_BPR(NOL) & !find([F:DAE]ACCNUM,LSTACCNUM(0..NBRACCNUM))
&                     & evalue(CRITSPE)
     LSTACCNUM(NBRACCNUM) = [F:DAE]ACCNUM
     NBRACCNUM +=1
     If [F:GAC]MTC=2
      Call DELETECR([F:DAE]ACCNUM) From DELETTRAGE
     Endif
     LU = 1 : Break
    Next
   Endif
   ## MAJ RVSACCNUM de PAYACCNUM
   If LU
    If [F:DAE]ACCNUM = [F:PAN]ACCNUM
     [F:PAN]RVSACCNUM = SVG_NUM1(NOL)
     Rewrite [PAN]
     If fstat=1
      GOK=-1 : GLOCK="$PAYACCNUM"-num$([F:PAN]TYPNUM)-[F:PAN]NUM-num$([F:PAN]STA) : Break
     Elsif fstat
      GOK=0 : Call FSTA("PAN") From GLOCK : Break
     Endif
    Endif

    # MAJ RVSACCNUM de PAYACCNUMD
    Read [PMD]PMD0 = NPYH ; [F:PAN]ACCSTA ; [F:DAE]ACCNUM
    If !fstat
     [F:PMD]RVSACCNUM = SVG_NUM1(NOL)
     Rewrite [PMD]
     If fstat=1
      GOK=-1 : GLOCK="$PAYACCNUMD"-num$([F:PMD]NUM)-num$([M:DIA]ACCSTA) : Break
     Elsif fstat
      GOK=0 : Call FSTA("PMD") From GLOCK : Break
     Endif
    Endif
   Endif
  Endif

 Endif
Next NOL
If GOK<1 : Return : Endif

If NUMESPION
 Call ESPION("GACCENTRY",1,[M:HAE0]TYP,[M:HAE0]NUM) From ESPION
 If GOK<1 : Return : Endif
Endif

Call ECR_TRACE([M:HAE0]TYP-[M:HAE0]NUM-mess(10,107,1)-TYPCUR-NUMCUR,0) From GESECRAN
# Pièce extournée:

# Interface trésorerie
SVG_NUM2 = [M:HAEW]ACCNUM(0)
If func AFNC.ACTIV("CASIN") : Gosub EXTOURNE From EXPCASPAY : Endif
If GOK<1 : Return : Endif
Return


$LIENS
OFLGPAZ = [F:HAE]FLGPAZ
OFLGFUP = [F:HAE]FLGFUP
ODUDDAT = [F:HAE]DUDDAT
Gosub SETMSK From SUBGAS
Raz nolign, [M:VTL], [M:VT2], K
Raz [M:HAEW], NOL, NOLI
LETTRE = 0
POINTE = 0
AVERTI = 0
Local Char PARAMETRE(10)
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
# Issue 114426 - 2016-03-18 by RICAR : SIVSUP parameter to split in PIVSUP and GASSUP
# Issue 114426
#--- Paramètre de suppression des factures : affecte le bouton Suppression
Call PARAM([M]FCY,"GASSUP",PARAMETRE) From ADOVAL
GGASSUP = val(PARAMETRE)
# End issue 114426
#--- Paramètre de création de lignes à zéro
Call PARAM([M]FCY,"SIVNULL",PARAMETRE) From ADOVAL
GSIVNULL = val(PARAMETRE)

Call LEC_FCY([F:HAE]FCY) From CPTLEC
Call LEC_CPY([F:HAE]CPY) From CPTLEC
Call LEC_JOU_LEG([F:CPY]LEG,[F:HAE]JOU) From CPTLEC
Call LEC_GTE_LEG([F:CPY]LEG,[F:HAE]TYP) From CPTLEC
Call LEC_TCU([F:HAE]CUR) From CPTLEC

Call CONTEXE([F:GTE]ACS) From CPTSUB
If mkstat
 DROIT_MOD = 0
Else
 Call CONTEXE([F:JOU]ACS) From CPTSUB
 If mkstat
  DROIT_MOD = 0
 Else
  DROIT_MOD = 1
 Endif
Endif

Default Mask [HAE1]
[M]CURAFF = [M]CUR
If dim([M]CURAFF2)>0 : [M]CURAFF2 = [M]CUR : Endif
If GFONCTION="GESGAS"
 CONSCUR=0
 Gosub TBCUR From SUBGAS
Endif
If !GIMPORT
 Gosub CHARG_ZONES_DEV From SUBGA0
 Gosub GRISE_COURS From SUBGA0
Endif

Return

$LIENS2
If [F:DAE]SNS=1
 [M:HAE2]DEB(NOL) = [F:PMD]AMTCUR
 [M:HAE2]TOTDEB  += [F:PMD]AMTCUR
Else
 [M:HAE2]CDT(NOL) = [F:PMD]AMTCUR
 [M:HAE2]TOTCDT += [F:PMD]AMTCUR
Endif
If dim([M:HAE2]ACCDES)>0
 Read [GAC]GAC0 = [F:DAE]COA;[F:DAE]ACC
 Call LECTEXTRA([M:HAE2]ACCDES(NOL),"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
Endif
If [F:DAE]MTC<>"" : LETTRE = 1 : Endif
If [F:DAE]CHK<>"" : POINTE = 1 : Endif
Gosub LIEN_DAA
Return


$LIEN_DAA
If WSAI=0
 FILTDAA = "LIN="+num$(NOL+1)+"& find([F:DAA]LEDTYP,[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))"
Else
 FILTDAA = "LIN="+num$([F:DAE]LIN)+"& [F:DAA]LEDTYP="+num$([F:DAE]LEDTYP)
Endif

If [F:DAE]DSP=""
 Raz INDAXE, AXE
 For [DAA]DAA2(3) Where TYP=[F:DAE]TYP & NUM=[F:DAE]NUM & evalue(FILTDAA)
  For [DAA]DAA2(4)
   K+=1
   If !INDAXE : INDAXE = K : Endif              # Flag de présence d'analytique sur la ligne de pièce comptable
   For [DAA]DAA2
    If COEFF=1
     [M:VT2]TBAMT(K) = [F:DAA]AMTCUR
    Else
     [M:VT2]TBAMT(K) = arr([F:DAA]AMTCUR*COEFF,ARD1)
    Endif
    [M:VT2]TBQTY(K) = [F:DAA]QTY
    For I=1 To dim([F:DAA]CCE)
     AXE = find(evalue("[F:DAA]DIE"+"("+num$(I-1)+")"),[M:HAEF]DIE(0..19))
     If AXE>0
      Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$(K)+")" With [F:DAA]CCE(I-1)
     Endif
    Next I
   Next
  Next
  #-- Si INDAXE<>0, il y a une ventilation analytique.
  #-- Si INDAXE=K, il n'y a qu'une seule ligne analytique donc celle ci se précharge sur le masque HAE1/HAE2
  If INDAXE
   If INDAXE=K
    For I=1 To dim([F:DAA]CCE)
     Assign "[M]CCE"+num$(I)+"("+num$(NOL)+")" With evalue("[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")")
     Assign "[M:VT2]TBCCE"+num$(I)+"("+num$(K)+")" With ""
    Next I
    K -= 1
   Else
    If [M]PTV(NOL)=0 : [M]PTV(NOL) = INDAXE : Endif
    If [M]PTF(NOL)=0 : [M]PTF(NOL) = K : Endif
    [M]DSP(NOL) = "$"
    If [F:DAE]DSP="" : [M]DSP(NOL) = "$" : Endif
   Endif
  Endif
 Next
 If COEFF<>1 & [M]PTF(NOL)<>0
  [M:VT2]TBAMT([M]PTF(NOL)) = [M:HAE2]DEB(NOL)+[M:HAE2]CDT(NOL)-sum([M:VT2]TBAMT(max(1,[M]PTV(NOL))..[M]PTF(NOL)-1))
 Endif
Endif

[M:VT2]PTVENT = max([M:VT2]PTVENT,K+1)
Return
######################################################
## Sous - Programmes + Etiquettes de l'écran ANUPYH ##
######################################################
$LECDAE
Read [DAE]DAE2 = PANCUR
If fstat
 GOK=0
 Read [DAE4]DAT1 = PANCUR
 If fstat=0 : # En cours de validation
  GMESSAGE=[F:DAE4]TYP-[F:DAE4]NUM-":"-mess(128,117,1)
 Else
  Call RSTA("DAE",num$(PANCUR)) From GLOCK
 Endif
Endif
Return

$LECHAE
SYMBOLE = "HAE"+[F:DAE]NUM+"\"+[F:DAE]TYP
Lock =SYMBOLE
If fstat=1
 GOK=-1 : GLOCK="%"+SYMBOLE : Return
Endif
Readlock [HAE]HAE0 = [F:DAE]TYP ; [F:DAE]NUM
If fstat=1
 GOK=-1 : GLOCK="$GACCENTRY"+[F:DAE]TYP-[F:DAE]NUM
Elsif fstat
 GOK=0 : Call RSTA("HAE",[F:DAE]TYP-[F:DAE]NUM) From GLOCK
Endif
Return

$LETTRE
If !J : # Lettrage en devise d'échéance
 Call LETDIF(I-K,ECH_NUM(K..I-1),ECH_LIG(K..I-1),ECH_MT(K..I-1),2) From CPTLET
Else   : # Lettrage en devise société
 Call LETDIF(I-K,ECH_NUM(K..I-1),ECH_LIG(K..I-1),ECH_MTLOC(K..I-1),1) From CPTLET
Endif
Return

$TBLET_IN
For [DAE]DAE1 Where CPY=SOC & FCYLIN=SITE & ACC=COMPTE & BPR=TIERS & MTC=MTCLET & ACCNUM<>0
 If !find([F:DAE]ACCNUM,TBACCNUM(0..[M:HAE2]NBLIG-1),TBNUM(1..NBTB-1))

    # F17028 : On n'effectue pas le lettrage d'extourne des pièces de lettrage automatique (fait dans DELETECR de DELETTRAGE)
    Read [HAE]HAE0 = [F:DAE]TYP ; [F:DAE]NUM

    If [F:HAE]REFINT<"MTC" or [F:HAE]REFINT>"MTC9"
      Gosub TBLET_IN2 : If GOK<1 : Break : Endif
    Endif

 Endif
Next : # [DAE]
Return

$TBLET_IN2
If NBTB>=MAXTB
 For I=0 To NBTB-1
  If TBSTA(I)=0
   Dela I TBSTA,TBNUM
   NBTB-=1
  Endif
 Next I
 If NBTB>=MAXTB : # Trop d'échéances à lettrer
  GMESSAGE=mess(81,117,1)-"(NBTB>"+num$(MAXTB)+")" : GOK=0 : Return
 Endif
Endif
TBNUM(NBTB)=[F:DAE]ACCNUM
TBSTA(NBTB)=[F:PAN]STA
NBTB+=1
Return

$TBLET_OUT
If TBACCNUM(NOL)<>0
 I=find(TBACCNUM(NOL), TBNUM(0..NBTB-1))
 If I : TBSTA(I-1)=0 : Endif
Endif
Return

#############
Subprog VALID
#############
# Pour générer les pièces dans les fichiers compta "batch"
Onerrgo ERREUR From CONTROLE
Local File GACCTMP  [HAE]
Local File GACCTMPD [DAE]
Local File GACCTMPA [DAA]
Onerrgo
If GERREUR : GERREUR=0 : GOK=0 : End : Endif
Local Integer STAT
Local Char MESSA(200)
Local Char  TZONE(10)(1..10) : # Table of the zones to be forced (Ex: ORICOD)   #*X3-39795
Local Char  TVAL(30)(1..10)  : # Table of values for zones to be forced         #*X3-39795

 TZONE(5)= "ORIGIN" : TVAL(5)= "2"        :#Automatic loading  #*X3-39795
 TZONE(6)= "ORICOD" : TVAL(6)= "PAYCANCEL"                     #*X3-39795

 #*X3-39795 Call VALPIECE(STAT,MESSA) From CPTBATCH
 Call VALPIECE2(STAT,MESSA,TZONE,TVAL) From CPTBATCH
 If GOK<1   : GMESSAGE=MESSA
   Elsif STAT : GOK=0 : GMESSAGE=MESSA
   Else       : [M:HAE0]NUM=MESSA
 Endif
End

##################################
## Etiquettes de l'écran ANUPYH ##
##################################

Subprog C_ACCDAT(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0]
 If !clalev([F:FCY])  : Local File FACILITY [FCY] : Endif
 Local Char SOCIETE(GLONCPY)
 Call LECTURE("FCY",[M]FCY,"") From CONTOBJ
 [L]SOCIETE = [F:FCY]LEGCPY
 Call SETMAINREF([L]SOCIETE,GTYPGEN,GTYPANA) From CPTDIV
 Call CONTPER(VALEUR,GTYPGEN,[M]FCY) From CPTSUB
Endif
End

