#<AdxTL>@(#)1.0.0.0 $Revision$
######################################################################
# Sous-pro pour pivot de type : commmandes ou historiques de commandes
#                             cf AML 2240 : 41/42
###################################################
# FQ 64773 GA 05/2010 préfixe des noms de variables SOQWPIV devient WK
######################################################################
$OUVTAB_SOQ
If !clalev([F:TFO]) Local File TABFOR    [TFO] Endif
If !clalev([F:AXX]) Local File ATEXTRA   [AXX] Endif

If !clalev([F:SOH]) Local File SORDER   [SOH] Endif
If !clalev([F:SOQ]) Local File SORDERQ  [SOQ] Endif
If !clalev([F:SOP]) Local File SORDERP  [SOP] Endif

If !clalev([F:SOHX]) Local File SORDER   [SOHX] Endif
If !clalev([F:SOQX]) Local File SORDERQ  [SOQX] Endif
If !clalev([F:SOPX]) Local File SORDERP  [SOPX] Endif

If !clalev([F:SOH_]) Local File SORDER   [SOH_] Endif
If !clalev([F:SOQ_]) Local File SORDERQ  [SOQ_] Endif
If !clalev([F:SOP_]) Local File SORDERP  [SOP_] Endif

If !clalev([F:VSOQ]) Local File PITSOHSOQ   [VSOQ] Endif

If !clalev([F:BPR]) Local File BPARTNER  [BPR] Endif
If !clalev([F:BPC]) Local File BPCUSTOMER[BPC] Endif
If !clalev([F:ITM]) Local File ITMMASTER [ITM] Endif

Return

######################################################################
# P_CHDATSOQ date à prendre en compte
# indique quelle date de SOQ à prendre en compte (ex: DEMDLVDAT ou EXTDLVDAT)
###
# P_AGREG niveau d'agregation M(2247)
# valeurs:
# 1 : PAS DE REGROUPEMENT TRI PAR CLIENT,ARTICLE,SITE,Date DE LIV
# 2 : REGROUPEMENT PAR Date DE LIV, TRI PAR CLIENT,ARTICLE,SITE,Date DE LIV
# 3 : REGROUPEMENT PAR debut DE SEMAINE, TRI PAR CLIENT,ARTICLE,SITE,Date DE LIV
# 4 : REGROUPEMENT PAR debut DE MOIS, TRI PAR CLIENT,ARTICLE,SITE,Date DE LIV
#####################################################################
Subprog TRT_SOQ(ID,CLETRT,PITSOQ,P_FORMULE,P_CRITERE,P_CHDATSOQ,P_STRDAT,P_NBJOUR,P_ENDDAT,P_AGREG,OK)
Value Char ID()
Value Char CLETRT () 
Value Char PITSOQ () 
Value Char P_FORMULE() 
Value Char P_CRITERE() 
Value Char P_CHDATSOQ() 
Value Date P_STRDAT
Value Integer P_NBJOUR
Value Date P_ENDDAT
Value Integer P_AGREG
Variable Integer OK


If PITSOQ="" : Return : Endif

Local Char     CRITTRI(255) : Raz CRITTRI

Local Char     FORMULE1(255) : Raz FORMULE1
Local Char     FORMULE2(255) : Raz FORMULE2

Local Integer SAVADXIUM : SAVADXIUM=adxium
Local Char    SAVADXIFS : SAVADXIFS=adxifs
Local Char    SAVADXIRS : SAVADXIRS=adxirs
If ID="SCMA"
adxium = GASCII
Else
adxium = GUTF8
Endif
adxifs = ''
adxirs = chr$(13)+chr$(10)
Gosub INIT_FILE From CONNECTFCT : # ajout PE pour chgt adxium,adxifs,adxirs

Gosub OUVTAB_SOQ
Gosub OUVREPIVOT From CONNECTFCT

If PITSOQ<>""
    Local Integer WNBSOQ : Raz WNBSOQ 
    Local Integer WPRESOQ : Raz WPRESOQ
    Local Char    OPTSOQ(GDIMFIC)
    OPTSOQ = filpath("tmp",tolower(CLETRT)+"_"+tolower(ctrans(adxusr,"./*\@","_"))+"_"+num$(adxuid(2)),"pitsoq")
    Local Integer WKNBZON        : Raz WKNBZON
    Local Char    WKNORECMES (50): Raz WKNORECMES 
    Local Integer WKHEATYP       : Raz WKHEATYP 
    Local Char    WKHEADMES (250): Raz WKHEADMES 
    
    Call READPIT(PITSOQ,WKNBZON,WKNORECMES,WKHEATYP ,WKHEADMES ) From CONNECTFCT
    Local Char    WKTABZON(GLONATB+GLONAVA+2)(1..WKNBZON) : Raz WKTABZON
    Local Char    WKTABABR(GLONABR)(1..WKNBZON) : Raz WKTABABR
    Local Char    WKZON(GLONAVA)(1..WKNBZON) : Raz WKTABZON
    Local Char    WKFRM(150)(1..WKNBZON) : Raz WKFRM
    Local Integer WKWRK(1..WKNBZON) : Raz WKWRK
    Local Char    WKVAL(255)(1..WKNBZON) : Raz WKVAL
    Local Char    WKVALFIC(GLONAVA)(1..WKNBZON) : Raz WKVALFIC
    Call LOADPIVZON(PITSOQ,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK) From CONNECTFCT
    Call WRPIVOT_HEAD(PITSOQ,WKNBZON,WKTABZON,WKTABABR,WKZON,WKWRK,WKHEATYP,WKHEADMES,WPRESOQ,OPTSOQ) From CONNECTFCT
Endif
#######
Gosub TRT_FORMULE
If FORMULE1="" : FORMULE1="1=1" : Endif

Local Date WSTRDAT : WSTRDAT=[0/0/0]
Local Date WENDDAT : WENDDAT=[0/0/0]
If P_STRDAT<>[0/0/0]
    WSTRDAT=P_STRDAT
Elsif P_NBJOUR>0
    Case P_AGREG
    When 3  : WSTRDAT=aweek(week(P_ENDDAT-P_NBJOUR),year(P_ENDDAT-P_NBJOUR))
    When 4  : WSTRDAT=gdat$(1,month(P_ENDDAT-P_NBJOUR),year(P_ENDDAT-P_NBJOUR))
    When Default : WSTRDAT=P_ENDDAT-P_NBJOUR
    Endcase
Endif
If find(ID,'SCMD') # FQ 64742 GA 05/2010
    Local Date WSTRDATMIN : WSTRDATMIN=gdat$(01, 01, year(date$)-2)
    If  WSTRDAT<WSTRDATMIN WSTRDAT=WSTRDATMIN Endif  # Date mini début de sélection 01/01/n-2
Endif
If P_ENDDAT<>[0/0/0]
    WENDDAT=P_ENDDAT
Endif
If find(ID,'SCMD') # FQ 64742 GA 05/2010 
    Local Date WENDDATMAX : WENDDATMAX=gdat$(31, 12, year(date$)+1)
    If  WENDDAT<WENDDATMAX WENDDAT=WENDDATMAX Endif  # Date maxi fin de sélection 31/12/n+1
Endif

If WSTRDAT<>[0/0/0]
    ##FORMULE2="DEMDLVDAT>=WSTRDAT"
    FORMULE2=P_CHDATSOQ+">=WSTRDAT"
Endif
If WENDDAT<>[0/0/0]
    If FORMULE2<>"" FORMULE2+= "&" Endif
    ##FORMULE2+="DEMDLVDAT<=WENDDAT"
    FORMULE2+=P_CHDATSOQ+"<=WENDDAT"
Endif
# FQ 64723 GA 05/2010 interfaces SCM prévisions de ventes: sauf articles non gérés en stock
If find(ID,'SCMA','SCMD')
    If FORMULE2<>"" FORMULE2+= "&" Endif
    FORMULE2+="[F:ITM]STOMGTCOD=2"
Endif
If FORMULE2="" FORMULE2="1=1" Endif

CRITTRI = "[F:SOQ]BPCORD;[F:SOQ]ITMREF;[F:SOQ]STOFCY"
If P_CHDATSOQ="EXTDLVDAT"
    CRITTRI += ";[F:VSOQ]EXTDLVDAT"
Else
    CRITTRI += ";[F:SOQ]"+P_CHDATSOQ
Endif
# client,article,site,date de liv
Link [SOQ] With [VSOQ]VSOQ0~=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ,
& [SOH]SOH0~=[F:SOQ]SOHNUM,
& [SOP]SOP0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ,
& [ITM]ITM0~=[F:SOQ]ITMREF,
& [BPC]BPC0~=[F:SOQ]BPCORD,
& [BPR]BPR0~=[F:SOQ]BPCORD
& As [LNK]
& Order With CRITTRI

WFPERNEW=[0/0/0]
WFPER=[0/0/0]
WCLI=""
WART=""
WSIT=""
For [LNK] Where (evalue(FORMULE1)) & (evalue(FORMULE2)) & (evalue(P_CRITERE))
    #pour SCMD, on a besoin du total HT par ligne, on on multiplie par QTY
    If ID='SCMD'
        [F:SOP]NETPRINOT = [F:SOP]NETPRINOT * [F:SOQ]QTY
    Endif
    If find("SORDERP"+"/"+"SAU",WKTABZON(1..WKNBZON))=0
        # si on n'a pas l'unite de vente de la ligne de cde, il faut valoriser les QTY en unité de vente de l'article.
        COEF=1/[F:ITM]SAUSTUCOE
        Call CNVQTY([F:SOQ]QTYSTU,COEF,[F:ITM]SAU,[F:SOQ]QTY) From TRTVENQTE     : #Qté commandée
        Call CNVQTY([F:SOQ]SHTQTYSTU,COEF,[F:ITM]SAU,[F:SOQ]SHTQTY) From TRTVENQTE     : # Qté en rupture
        Call CNVQTY([F:SOQ]ALLQTYSTU,COEF,[F:ITM]SAU,[F:SOQ]ALLQTY) From TRTVENQTE     : # Qté allouée
        Call CNVQTY([F:SOQ]ODLQTYSTU,COEF,[F:ITM]SAU,[F:SOQ]ODLQTY) From TRTVENQTE     : # Qté en livraison
        Call CNVQTY([F:SOQ]DLVQTYSTU,COEF,[F:ITM]SAU,[F:SOQ]DLVQTY) From TRTVENQTE     : # Qté livrée
        Call CNVQTY([F:SOQ]INVQTYSTU,COEF,[F:ITM]SAU,[F:SOQ]INVQTY) From TRTVENQTE     : # Qté facturée
        Call CNVQTY([F:SOQ]TDLQTYSTU,COEF,[F:ITM]SAU,[F:SOQ]TDLQTY) From TRTVENQTE     : # Qté à livrer
        If !pat(GVERSION,"1.5.*")  # FQ 64773 GA 05/2010 champs inexistants en V5
            Call CNVQTY([F:SOQ]LPRQTYSTU,COEF,[F:ITM]SAU,[F:SOQ]LPRQTY) From TRTVENQTE     : # Qté sur liste prépa
            Call CNVQTY([F:SOQ]OPRQTYSTU,COEF,[F:ITM]SAU,[F:SOQ]OPRQTY) From TRTVENQTE     : # Qté en préparation
            Call CNVQTY([F:SOQ]PREQTYSTU,COEF,[F:ITM]SAU,[F:SOQ]PREQTY) From TRTVENQTE     : # Qté préparée
        Endif
    Endif

    If P_AGREG=1
        If [F:SOQ]SOHCAT=4 & P_CHDATSOQ="EXTDLVDAT"
            [F:SOQ]EXTDLVDAT = [F:SOQ]DEMDLVDAT
        Endif
        Gosub WR_SOQ
    Else
        #on calcule la fin de période de la ligne lue
        If [F:SOQ]SOHCAT=4 & P_CHDATSOQ="EXTDLVDAT"
            Case P_AGREG
            When 3  : WFPERNEW=aweek(week([F:SOQ]DEMDLVDAT),year([F:SOQ]DEMDLVDAT))
            When 4  : WFPERNEW=gdat$(1,month([F:SOQ]DEMDLVDAT),year([F:SOQ]DEMDLVDAT))
            When Default : WFPERNEW=[F:SOQ]DEMDLVDAT
            Endcase
        Else
            Case P_AGREG
            When 3  : WFPERNEW=aweek(week(evalue("[F:SOQ]"+P_CHDATSOQ)),year(evalue("[F:SOQ]"+P_CHDATSOQ)))
            When 4  : WFPERNEW=gdat$(1,month(evalue("[F:SOQ]"+P_CHDATSOQ)),year(evalue("[F:SOQ]"+P_CHDATSOQ)))
            When Default : WFPERNEW=evalue("[F:SOQ]"+P_CHDATSOQ)
            Endcase
        Endif

        If WFPER<>WFPERNEW | WCLI<>[F:SOQ]BPCORD | WART<>[F:SOQ]ITMREF | WSIT<>[F:SOQ]STOFCY
            # on arrive sur une ligne différente, il faut ecrire l'ancienne ligne si besoin
            If WFPER<>[0/0/0]
                # on sauve la ligne courante
                [F:SOH_]=[F:SOH]
                [F:SOQ_]=[F:SOQ]
                [F:SOP_]=[F:SOP]
                # on bascule la ligne de cumul
                [F:SOH]=[F:SOHX]
                [F:SOQ]=[F:SOQX]
                [F:SOP]=[F:SOPX]
                # on ecrit la ligne
                Gosub WR_SOQ
                # on recup les lignes sauvegardees
                [F:SOH]=[F:SOH_]
                [F:SOQ]=[F:SOQ_]
                [F:SOP]=[F:SOP_]
            Endif
            # on ecrase les lignes de cumul
            [F:SOHX]=[F:SOH]
            [F:SOQX]=[F:SOQ]
            Assign "[F:SOQX]"+P_CHDATSOQ With WFPERNEW 
            [F:SOPX]=[F:SOP]
        Else
            # on doit cumuler les montants SOQ et SOP
            [F:SOQX]ORIQTY +=[F:SOQ]ORIQTY   : # Qté cde initiale
            ###
            [F:SOQX]QTY    +=[F:SOQ]QTY    : #Qté commandée
            [F:SOQX]SHTQTY +=[F:SOQ]SHTQTY   : # Qté en rupture
            [F:SOQX]ALLQTY +=[F:SOQ]ALLQTY   : # Qté allouée
            [F:SOQX]ODLQTY +=[F:SOQ]ODLQTY   : # Qté en livraison
            [F:SOQX]DLVQTY +=[F:SOQ]DLVQTY   : # Qté livrée
            [F:SOQX]INVQTY +=[F:SOQ]INVQTY   : # Qté facturée
            [F:SOQX]TDLQTY +=[F:SOQ]TDLQTY   : # Qté à livrer
            ###
            [F:SOQX]QTYSTU   +=[F:SOQ]QTYSTU   : # Qté commandée US
            [F:SOQX]SHTQTYSTU+=[F:SOQ]SHTQTYSTU  : #  Qté en rupture US
            [F:SOQX]ALLQTYSTU+=[F:SOQ]ALLQTYSTU  : #  Qté allouée US
            [F:SOQX]ODLQTYSTU+=[F:SOQ]ODLQTYSTU  : #  Qté en livraison US
            [F:SOQX]DLVQTYSTU+=[F:SOQ]DLVQTYSTU  : #  Qté livrée US
            [F:SOQX]INVQTYSTU+=[F:SOQ]INVQTYSTU  : #  Qté facturée US
            [F:SOQX]TDLQTYSTU+=[F:SOQ]TDLQTYSTU  : #  Qté à livrer US
            If !pat(GVERSION,"1.5.*")  # FQ 64773 GA 05/2010 champs inexistants en V5
                   [F:SOQX]LPRQTY +=[F:SOQ]LPRQTY   : # Qté sur liste prépa
                   [F:SOQX]OPRQTY +=[F:SOQ]OPRQTY   : # Qté en préparation
                   [F:SOQX]PREQTY +=[F:SOQ]PREQTY   : # Qté préparée
                   ###
                   [F:SOQX]LPRQTYSTU+=[F:SOQ]LPRQTYSTU  : #  Qté liste prépa US
                   [F:SOQX]OPRQTYSTU+=[F:SOQ]OPRQTYSTU  : #  Qté en prépa US
                   [F:SOQX]PREQTYSTU+=[F:SOQ]PREQTYSTU  : #  Qté préparée US
            Endif

            #on convertit de la devise du SOH en devise de la 1ere commande (SOHX)
            [F:SOPX]GROPRI    +=func PITSOH.SOP_GETMTCONV([F:SOP]GROPRI,[F:SOHX]CUR)    : #  Prix brut
            [F:SOPX]NETPRI    +=func PITSOH.SOP_GETMTCONV([F:SOP]NETPRI,[F:SOHX]CUR)    : #  Prix net
            [F:SOPX]NETPRINOT +=func PITSOH.SOP_GETMTCONV([F:SOP]NETPRINOT,[F:SOHX]CUR) : #  Prix net HT
            [F:SOPX]NETPRIATI +=func PITSOH.SOP_GETMTCONV([F:SOP]NETPRIATI,[F:SOHX]CUR) : #  Prix net TTC
            [F:SOPX]PFM       +=func PITSOH.SOP_GETMTCONV([F:SOP]PFM,[F:SOHX]CUR)       : #  Marge
            [F:SOPX]CPRPRI    +=func PITSOH.SOP_GETMTCONV([F:SOP]CPRPRI,[F:SOHX]CUR)    : #  Prix revient

        Endif
        WFPER=WFPERNEW : WCLI=[F:SOQ]BPCORD : WART=[F:SOQ]ITMREF : WSIT=[F:SOQ]STOFCY
    Endif

Next
If P_AGREG<>1 & WFPER<>[0/0/0]
    # on sauve la ligne courante
    ##[F:SOH_]=[F:SOH]
    ##[F:SOQ_]=[F:SOQ]
    ##[F:SOP_]=[F:SOP]
    # on bascule la ligne de cumul
    [F:SOH]=[F:SOHX]
    [F:SOQ]=[F:SOQX]
    [F:SOP]=[F:SOPX]
    # on ecrit la ligne
    Gosub WR_SOQ
Endif

#######
If PITSOQ<>"" : Call WRPIVOT_END(PITSOQ ,WNBSOQ ,WKNORECMES ,WPRESOQ ,OPTSOQ) From CONNECTFCT : Endif
adxium = SAVADXIUM
adxifs = SAVADXIFS
adxirs = SAVADXIRS
End


######################################################################
$TRT_FORMULE
If P_FORMULE <> ""
    # FQ 65180 GA 06/2010 éviter pb de migration on garde les memes types de formule en V5 et V6
    # Menu local 213 rectifié en V5
    #If pat(GVERSION,"1.5.*")
    #Read [F:TFO]TFO0=28;P_FORMULE
    #Else
    Read [F:TFO]TFO0=45;P_FORMULE
    #Endif
    If !fstat 
        If FORMULE1 = "" 
            FORMULE1  = [F:TFO]FORFOR                 
        Else
            FORMULE1 += "&" 
            FORMULE1 += [F:TFO]FORFOR                 
        Endif
    Endif
Endif
Return

######################################################################
$WR_SOQ
If PITSOQ<>""
    ################################
    # fichiers SOH
    ################################
    #     Ouverture du fichier OPTSOQ en écriture
    If WPRESOQ = 0
      Openo OPTSOQ,0 Using [FPIV]
      WPRESOQ = 1
    Else
      Openo OPTSOQ Using [FPIV]
    Endif
    WNBSOQ += 1
    Call RAZVALPIVOT(PITSOQ,WKNBZON,WKVAL,WKVALFIC) From CONNECTFCT
    Call EVALPIVOT(PITSOQ,WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    Call WRPIVOT(WKNBZON,WKTABZON,WKTABABR,WKZON,WKFRM,WKWRK,WKVAL,WKVALFIC) From CONNECTFCT
    #     fermeture du fichier
    Openo Using [FPIV]
Endif
Return

#############################################################################
#on convertit de la devise du SOH en devise passée: celle de la 1ere commande (SOHX)
Funprog SOP_GETMTCONV(P_MT,P_ACCCUR)
Value Decimal P_MT
Value Char P_ACCCUR
Local    Integer SPSTAT
Local    Decimal MONTANT
Call CONVERT([F:SOH]CUR, P_ACCCUR, GLOCALDEV, [F:SOH]CHGTYP, date$, P_MT,MONTANT,SPSTAT) From TRTDEV
End MONTANT
End 0
#############################################################################

#############################################################################
Funprog SOH_GETSOPCAHT(P_ACCCUR)
Value Char P_ACCCUR
Local    Integer SPSTAT
Local    Decimal MONTANT
#on convertit de la devise du SOH en devise passée (devise site)
Call CONVERT([F:SOH]CUR, P_ACCCUR, GLOCALDEV, [F:SOH]CHGTYP, date$, [F:SOP]NETPRINOT,MONTANT,SPSTAT) From TRTDEV
End num$(MONTANT)
End "0"
#############################################################################

#############################################################################
# FQ 65034 Accès aux Sections de la tale SOH                                #
# P_DIE    
# - contient le numéro d'axe en V5
# - contient le code de l'axe à partir de la V6
#############################################################################
Funprog SOH_GETCCE(P_DIE)
Value    Char    P_DIE () 

Local Char WCCE(GLONCCE)

WCCE = func PITCCE.CAL_GETCCE("SOH",P_DIE,2,[F:SOH]SOHNUM,0,0,"")

End WCCE
#############################################################################

#############################################################################
# FQ 65034 Accès aux Sections de la tale SOP                                #
# P_DIE    
# - contient le numéro d'axe en V5
# - contient le code de l'axe à partir de la V6
#############################################################################
Funprog SOP_GETCCE(P_DIE)
Value    Char    P_DIE () 

Local Char WCCE(GLONCCE)

WCCE = func PITCCE.CAL_GETCCE("SOP",P_DIE,2,[F:SOP]SOHNUM,[F:SOP]SOPLIN,[F:SOP]SOPSEQ,"")

End WCCE
#############################################################################


