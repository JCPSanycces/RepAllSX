#<AdxTL>@(#)2.0.0.0 $Revision$ Gestion du masque SPACKLBE1
#########################################################################
#                                                                       #
#     ETIQUETTES DE COLISAGE                                            #
#                                                                       #
#     - Traitement        : FUNPACKLBE                                  #
#     - Action e_commerce : SAIPACKLBE  (Saisie fenêtre)                #
#                           IMPPACKLBE  (Traitement divers)             #
#                                                                       #
#########################################################################
#########################################################################
# Etiquettes ACTION                                                     #
#########################################################################
$ACTION
#--- Actions liées à la saisie fenêtre 
Case ACTION
 When "OUVRE"       : Case GACTION
                       When "SAIPACKLBE" : Gosub OUVRE_SAIPACKLBE
                      Endcase
 When "OUVRE_BOITE" : Case GACTION
                       When "SAIPACKLBE" : Gosub OUVRE_BOITE_SAIPACKLBE
                      Endcase
 When "DEBUT"       : Case GACTION
                       When "SAIPACKLBE" : Gosub DEBUT_SAIPACKLBE
                      Endcase 
 When Default
Endcase
#--- Actions liées au traitement divers 
Case ACTION
 When "TRT_DIV"     : Case TRAIT
                       When "IMPPACKLBE" : Gosub IMPRESSION 
                                           FIN=1
                                           If GFONC1="FUNPACKLBE" FIN=0 Endif 
                      Endcase
 When Default
Endcase
Return

#########################################################################
# Détail des actions liées à la saisie fenêtre                          #
#########################################################################

#########################################################################
$OUVRE_SAIPACKLBE
Local Integer  LTYP  :  LTYP=val(PARAM(1))
Local Char     LNUM  :  LNUM=PARAM(2)

If GFONC1<>"FUNPACKLBE"
   If GPACLBE<>2 FIN=1 : Return Endif
Endif

If !clalev ([F:SPH]) Local File SPACK     [SPH] Endif 
If !clalev ([F:SPD]) Local File SPACKD    [SPD] Endif 
If !clalev ([F:SDH]) Local File SDELIVERY [SDH] Endif 
If !clalev ([F:SDH]) Local File SDELIVERY [SDH] Endif 
If !clalev ([F:ARP]) Local File AREPORT   [ARP] Endif 
If !clalev ([F:ADW]) Local File ADOVAL    [ADW] Endif 
If !clalev ([F:LBP]) Local File LABELPRN  [LBP] Endif 

Return

#########################################################################
$OUVRE_BOITE_SAIPACKLBE

Return

#########################################################################
$DEBUT_SAIPACKLBE

Raz [M:PCL1]

If GFONC1<>"FUNPACKLBE"
    # on récupère le format de l'étiquette de la fonction FUNPACKLBE
    If !clalev ([F:AFC]) Local File AFONCTION [AFC] Endif     
    If [F:AFC]CODINT<>"FUNPACKLBE"
        Read [AFC]CODINT="FUNPACKLBE"
        If fstat Raz [F:AFC] Endif
    Endif
    [M:PCL1]LBLNAM=[F:AFC]RPT1
Else
    [M:PCL1]LBLNAM=GREPORT1
Endif

# Initialisation de la destination 
If [M:PCL1]LBLNAM<>"" 
    Call AIMDEF([M:PCL1]LBLDEN,[M:PCL1]LBLNAM,GBIDC1,GBIDC2) From IMPRIME 
    If [M:PCL1]LBLDEN<>"" Affzo [M:PCL1]LBLDEN Endif
Endif

# Récupération paramètres
If LTYP<>0  [M:PCL1]VCRTYP=LTYP
Else        [M:PCL1]VCRTYP=4
Endif

If LNUM<>"" [M:PCL1]VCRNUM=LNUM Endif

nolign=0
If LTYP<>0 & LNUM<>""
   For [SPH]SPH0 Where VCRTYP=LTYP & VCRNUM=LNUM
      nolign+=1
      [M:PCL1] = [F:SPH]
      [M:PCL1]LBLNBR(nolign-1) = 1
      If [M:PCL1]LBLFMT(nolign-1) = "" 
          [M:PCL1]LBLFMT(nolign-1)=[M:PCL1]LBLNAM 
          [M:PCL1]DEFDEN(nolign-1)=[M:PCL1]LBLDEN
      Elsif [M:PCL1]LBLFMT(nolign-1)=[M:PCL1]LBLNAM 
          [M:PCL1]DEFDEN(nolign-1)=[M:PCL1]LBLDEN
      Else
          # Initialisation de la destination 
          Call AIMDEF([M:PCL1]DEFDEN(nolign-1),[M:PCL1]LBLFMT(nolign-1),GBIDC1,GBIDC2) From IMPRIME 
      Endif
   Next
   [M:PCL1]NBLIG=nolign
Endif
Affzo [M:PCL1]
# Pas de saisie no document si accès depuis colisage (on traite une seule livraison)
If GFONC1 <> "FUNPACKLBE"
   DISZO [M:PCL1]VCRNUM
Else
   Actzo [M:PCL1]VCRNUM
Endif

Return
#########################################################################
# Détail des actions liées au traitement divers                         #
#########################################################################

#######################################################################
# Bouton impression des étiquettes de colis                           #
#######################################################################
$IMPRESSION
Local Char    WMSG(80), WDEFDEN(GLONAIM), WLBLFMT
Local Integer I, J, K, WNUMREQ, WNB, WNUMLIG
Global Integer GWNUMREQ     : # pour passage du no de requete 

# TRI du tableau selon imprimante,format,no colis 
Sorta [M:PCL1]NBLIG [M:PCL1]NBLIG 
&     Order By [M:PCL1]DEFDEN(indice),[M:PCL1]LBLFMT(indice),[M:PCL1]PACNUM(indice)

Raz WDEFDEN, WLBLFMT, WNB, WNUMLIG 
For I=0 To [M:PCL1]NBLIG-1
   If [M:PCL1]LBLNBR(I)<>0 & [M:PCL1]LBLFMT(I)<>"" & [M:PCL1]DEFDEN(I)<>"" 
      If [M:PCL1]DEFDEN(I)<>WDEFDEN | [M:PCL1]LBLFMT(I)<>WLBLFMT
         If WDEFDEN<>"" & WNB>0
             Local Char TBPAR(15)(1..50),TBVAL(30)(1..50) 
             [M:PCL1]LBLDEN=WDEFDEN
#             Call ETATN(WLBLFMT,"FUNPACKLBE",TBPAR,TBVAL) From ETAT
             Call ETAT(WLBLFMT,WDEFDEN,"",1,"",TBPAR,TBVAL) From AIMP3
         Endif
         WDEFDEN=[M:PCL1]DEFDEN(I)
         WLBLFMT=[M:PCL1]LBLFMT(I)
         GWNUMREQ=uniqid([LBP])
         Raz WNB, WNUMLIG 
      Endif
      Gosub REMPL_LBP
   Endif
Next I

If WNB>0
    Local Char TBPAR(15)(1..50),TBVAL(30)(1..50) 
    [M:PCL1]LBLDEN=WDEFDEN
#    Call ETATN(WLBLFMT,"FUNPACKLBE",TBPAR,TBVAL) From ETAT
    Call ETAT(WLBLFMT,WDEFDEN,"",1,"",TBPAR,TBVAL) From AIMP3
Endif

Return

############################################################################
$REMPL_LBP

#On arrive ici pour chaque ligne du tableau
Call DEBTRANS From GLOCK 
Trbegin [LBP]
Raz [F:LBP]
[F:LBP]USR    = GUSER
[F:LBP]NUMREQ = GWNUMREQ
[F:LBP]CREDAT = date$
[F:LBP]CREUSR = GUSER
[F:LBP]RPTCOD = [M:PCL1]LBLFMT(I)
[F:LBP]STOFCY = [M:PCL1]STOFCY
[F:LBP]VCRTYP = 4
[F:LBP]VCRNUM = [M:PCL1]VCRNUM
[F:LBP]PACNUM = [M:PCL1]PACNUM(I)
[F:LBP]PACSEQ = [M:PCL1]PACSEQ(I)
For J=1 To [M:PCL1]LBLNBR(I)
    [F:LBP]NUMLIG = J + WNUMLIG
    Write [F:LBP]
    If fstat : GOK = 0 : Break : Endif
Next J
If GOK = 0
   Rollback 
Else
   Commit
   WNB    += 1 
   WNUMLIG = [F:LBP]NUMLIG 
Endif
Return

###########################################################################
#   Actions sur les champs de l'écran SPACKLBE1 [PCL1]                    #
###########################################################################
Subprog AM_VCRNUM(VALEUR)
Variable Char    VALEUR()
nolign=0
If VALEUR = "" End Endif
For [SPH]SPH0 Where VCRTYP=[M:PCL1]VCRTYP & VCRNUM=VALEUR
   nolign+=1
   [M:PCL1] = [F:SPH]
   [M:PCL1]LBLNBR(nolign-1) = 1
   # Vérification du format de l'étiquette récupéré de l'emballage
   Call ARPCONT([M:PCL1]LBLFMT(nolign-1)) From IMPRIME
   If mkstat=2 Raz [M:PCL1]LBLFMT(nolign-1) : mkstat=0 : Raz GMESSAGE : Endif
   If [M:PCL1]LBLFMT(nolign-1) = "" 
       [M:PCL1]LBLFMT(nolign-1)=[M:PCL1]LBLNAM 
       [M:PCL1]DEFDEN(nolign-1)=[M:PCL1]LBLDEN
   Elsif [M:PCL1]LBLFMT(nolign-1)=[M:PCL1]LBLNAM 
       [M:PCL1]DEFDEN(nolign-1)=[M:PCL1]LBLDEN
   Else
       # Initialisation de la destination 
       Call AIMDEF([M:PCL1]DEFDEN(nolign-1),[M:PCL1]LBLFMT(nolign-1),GBIDC1,GBIDC2) From IMPRIME 
       If [M:PCL1]DEFDEN(nolign-1)<>"" Affzo [M:PCL1]DEFDEN(nolign-1) Endif
   Endif
Next
[M:PCL1]NBLIG=nolign
Affzo [M:PCL1]10
End
##########################################################################
## Etiquette ajoutée par le superviseur 17/11/2003 10:52:40 (LD)
##########################################################################
# ----------------------------- LBLNAM Format étiquette ---------------------------------
Subprog AM_LBLNAM(VALEUR)
Variable Char    VALEUR()
Local Char TBPAR(15)(1..50),TBVAL(30)(1..50) 
Local Integer OK, WOBLIG

# Recherche de l'imprimante par défaut
Call AIMDEF([M]LBLDEN,VALEUR,TBPAR,TBVAL) From IMPRIME
Affzo [M]LBLDEN 
# Demande de répercution sur les lignes détails
Call OUINON (mess(67,196,1),OK) From GESECRAN
If OK=2
    For I=0 To [M]NBLIG-1
        [M:PCL1]LBLFMT(I) = VALEUR   
        [M:PCL1]DEFDEN(I) = [M]LBLDEN
    Next
    Affzo [M:PCL1]10
Endif
End
##########################################################################
# ----------------------------- LBLDEN Destination ---------------------------------
Subprog C_LBLDEN(VALEUR)
Variable Char    VALEUR()
# Imprimante obligatoire si impression 
If [M]LBLNAM <> "" & VALEUR = ""
   GMESSAGE=mess(10,123,1) : mkstat = 2
Endif
End

##########################################################################
Subprog AP_LBLDEN(VALEUR)
Variable Char    VALEUR()
Call INIT_SRV(VALEUR, [M]LBLSRV,[M]LBLIMP) From TRTVENIMP
Affzo [M]LBLSRV, LBLIMP
End

##########################################################################
Subprog AM_LBLDEN(VALEUR)
Variable Char    VALEUR()
Local Integer OK

# Demande de répercution sur les lignes détails
Call OUINON (mess(67,196,1),OK) From GESECRAN
If OK=2
    For I=0 To [M]NBLIG-1
        [M:PCL1]LBLFMT(I) = [M]LBLNAM  
        [M:PCL1]DEFDEN(I) = VALEUR
    Next
    Affzo [M:PCL1]10
Endif
End
######################################## 
# ----------------------------- LBLFMT Format étiquette tableau ---------------------------------
Subprog C_LBLFMT(VALEUR)
Variable Char    VALEUR()
Local    Char AUTSIT(10)
Local    Integer OK
# Format étiquette obligatoire si impression nb étiquettes > 0
If [M:PCL1]LBLNBR(nolign-1) <> 0 & VALEUR = ""
   mkstat = 2
   End
Endif
End
##########################################################################
## Etiquette ajoutée par le superviseur 17/11/2003 11:50:43 (LD)
##########################################################################
Subprog AM_LBLFMT(VALEUR)
Variable Char    VALEUR()
Local Char TBPAR(15)(1..50),TBVAL(30)(1..50)
# Recherche de l'imprimante par défaut
Call AIMDEF([M]DEFDEN(nolign-1),VALEUR,TBPAR,TBVAL) From IMPRIME
Affzo [M]DEFDEN(nolign-1)
End
##########################################################################
##########################################################################
## Etiquette ajoutée par le superviseur 24/06/2004 18:07:46 (LD)
##########################################################################
# ----------------------------- DEFDEN Destination tableau ---------------------------------
Subprog C_DEFDEN(VALEUR)
Variable Char    VALEUR()
# Imprimante obligatoire si impression 
If [M]LBLFMT(nolign-1) <> "" & VALEUR = ""
   GMESSAGE=mess(10,123,1) : mkstat = 2
Endif
End
