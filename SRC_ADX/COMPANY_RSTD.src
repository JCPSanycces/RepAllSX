#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################################
# Representation COMPANY
################################################################################################

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When "CPY"
    Case [L]AEVENT
     When "AINSERT_AFTER"                : Gosub AINSERT_AFTER
     When "AUPDATE_AFTER"                : Gosub AUPDATE_AFTER
     When "AREAD_AFTER"                  : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "CPY.CPYLEGFLG"               : Gosub CPY_CPYLEGFLG
  When "CPY.CRY"                     : Gosub CPY_CRY :#60504
  When "CPY.ORICERFLG"               : Gosub CPY_ORICERFLG :#60504
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return




###############################################################################################
$AINSERT_AFTER
Gosub COMPANY_DISPLAY
Return

###############################################################################################
$AUPDATE_AFTER
Gosub COMPANY_DISPLAY
Return

###############################################################################################
$AREAD_AFTER
Gosub COMPANY_DISPLAY
Return


################################################################################################
$CPY_CPYLEGFLG
Case [L]ARULE
  When "PROPAGATE"                   : Gosub CPYLEGFLG_DISPLAY
Endcase
Return

################################################################################################
##X3-60504
$CPY_CRY
  Case [L]ARULE
    When "PROPAGATE"              : Gosub CRY_DISPLAY
  Endcase
Return

################################################################################################
#X3-60504
$CPY_ORICERFLG
  Case [L]ARULE
    When "PROPAGATE"              : Gosub ORICERFLG_DISPLAY
  Endcase
Return

####################################################################################################
$COMPANY_DISPLAY
Gosub CPYLEGFLG_DISPLAY
Gosub EECNUM_DISPLAY
Gosub BPAADD_DISPLAY
Gosub BIDNUM_DISPLAY
Gosub CRY_DISPLAY
Gosub ORICERFLG_DISPLAY
Return

####################################################################################################
$CPYLEGFLG_DISPLAY
If this.ASTALIN = [V]CST_ANEW
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CPYLEGFLG", "$isDisabled", "false")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CPYLEGFLG", "$isDisabled", "true")
Endif

# Legal Company and Legal Company EU Country
If this.CPYLEGFLG=[V]CST_AYES
  [L]ASTATUS = fmet this.ASETATTRIBUTE("MAIFCY","$isDisabled", "false")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CRY","$isDisabled", "false")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CRN","$isDisabled", "false")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("NID","$isDisabled", "false")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("LEG","$isDisabled", "false")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("RGCCUR","$isDisabled", "false")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("RGCAMT","$isDisabled", "false")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ACCCUR","$isDisabled", "false")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ACCCOD","$isDisabled", "false")
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("MAIFCY","$isDisabled", "true")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CRY","$isDisabled", "true")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CRN","$isDisabled", "true")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("NID","$isDisabled", "true")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("LEG","$isDisabled", "true")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("RGCCUR","$isDisabled", "true")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("RGCAMT","$isDisabled", "true")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ACCCUR","$isDisabled", "true")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("ACCCOD","$isDisabled", "true")
Endif
Return

################################################################################################
$EECNUM_DISPLAY
If this.CRY<>"" and this.CPYLEGFLG=[V]CST_AYES
  If fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"CRNOBL")<>[V]CST_AYES
    [L]ASTATUS = fmet this.ASETATTRIBUTE("EECNUM","$isDisabled","false")
  Else
    [L]ASTATUS = fmet this.ASETATTRIBUTE("EECNUM","$isDisabled","true")
  Endif
Else
  [L]ASTATUS = fmet this.ASETATTRIBUTE("EECNUM","$isDisabled","true")
Endif
Return

################################################################################################
$BPAADD_DISPLAY
Local Integer I
# Disable changing index fields in address
For I=1 To maxtab(this.BPA)
  If this.BPA(I)<>null
    [L]ASTATUS = fmet this.BPA(I).ASETATTRIBUTE("BPAADD","$isDisabled", "true")
  Endif
Next
Return

################################################################################################
$BIDNUM_DISPLAY
Local  Integer I
# Disable changing index fields in BID table
For I=1 To maxtab(this.BID)
  If this.BID(I)<>null
    [L]ASTATUS = fmet this.BID(I).ASETATTRIBUTE("BIDNUM","$isDisabled", "true")
    [L]ASTATUS = fmet this.BID(I).ASETATTRIBUTE("BPAADD","$isDisabled", "true")
  Endif
Next
Return

################################################################################################
##X3-60504
$CRY_DISPLAY
  If dim(this.ORICERFLG)>=0 :#X3-69093
    If fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"EECFLG")<>[V]CST_AYES & fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"GSPFLG")<>[V]CST_AYES
      [L]ASTATUS = fmet this.ASETATTRIBUTE("ORICERFLG","$isDisabled","true")
    Else
      [L]ASTATUS = fmet this.ASETATTRIBUTE("ORICERFLG","$isDisabled","false")
    Endif
  Endif
Return

################################################################################################
##X3-60504
$ORICERFLG_DISPLAY
  If dim(this.ORICERFLG)>=0 :#X3-69093
    If this.ORICERFLG=[V]CST_AYES
      [L]ASTATUS = fmet this.ASETATTRIBUTE("REXNUM","$isDisabled","false")
    Else
      [L]ASTATUS = fmet this.ASETATTRIBUTE("REXNUM","$isDisabled","true")
    Endif
  Endif
Return

