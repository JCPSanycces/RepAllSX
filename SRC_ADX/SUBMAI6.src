##########################################################################################################
# Gestion du masque MAI6
##########################################################################################################
##########################################################################################################
Subprog AM_TPLVOL(VALEUR)
Variable Char    VALEUR()

Local Char SREPFIL(250)
Local Char SFULLPATH(250)
Local Char SMESSAGE(250)

  Raz [M:MAI6]TPLDIRFIL
  SREPFIL = "[" + VALEUR + "]/" + [M:MAI6]TPLFIL
  # ----------------------------------
  Gosub ENUM_VOLFIL_TYPE From ASYRSTO
  mkstat = func ASYRSTO.CTL_VOLFIL(2, SREPFIL, SFULLPATH, E_TYPE_FILEWRITE, SMESSAGE)
  If mkstat Then
    GERR = 1
    If SMESSAGE <> "" Then
      GMESSAGE = SMESSAGE
    Endif
    If GMESSAGE = "" Then
      GMESSAGE = mess(35,126,1) - "(a)"
    Endif
    End
  Else
    [M:MAI6]TPLDIRFIL = SFULLPATH
    Affzo [M:MAI6]TPLDIRFIL
  Endif
End
