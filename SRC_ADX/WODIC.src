$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Integer  A_BUF1(0..GNBDERNIER)
Local Char     A_BUF2(12)(0..GNBDERNIER)
Local Char     A_BUF3(80)(0..GNBDERNIER)
Local Char     A_BUF4(12)(0..GNBDERNIER)
Local Char     A_BUF5(5)(0..GNBDERNIER)
Local Libelle  A_BUF6(0..GNBDERNIER)
Local Libelle  A_BUF7(0..GNBDERNIER)
Local Libelle  A_BUF8(0..GNBDERNIER)
Local Libelle  A_BUF9(0..GNBDERNIER)
If clalev([F:DIC9])>0 : Close Local File [DIC9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Integer  A_TAB1,
& Char     A_TAB2(12),
& Char     A_TAB3(80),
& Char     A_TAB4(12),
& Char     A_TAB5(5),
& Libelle  A_TAB6,
& Libelle  A_TAB7,
& Libelle  A_TAB8,
& Libelle  A_TAB9
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4,A_BUF5,A_BUF6,A_BUF7,A_BUF8,A_BUF9
& As [DIC9]
Return

$LEC_DERLU
Read [ATX]NUMERO = GLANGUE ; [F:DIC]DES
If fstat : Raz [F:ATX] : Endif
Return

$CHARGE_DERLU
If clalev([F:DIC9])>0
 Read [DIC9] = [F:DIC9]A_TABI
 [L]CLE = [F:DIC9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:DIC9])>0
 Filter [DIC9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [DIC1] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:DIC9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = [F:DIC]FLD+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:DIC9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:DIC9]
 Endif
Endif
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 1
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:DIC]ROW"
Call TEXTE(747,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 3
SELFMT(NBSEL) = "N:5F"
SELFOR(NBSEL) = "N:5#"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:DIC]ROW"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:DIC]FLD"
Call TEXTE(1261,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:12X"
SELFOR(NBSEL) = "KTD:12X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:DIC]FLD"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:ATX]TEXTE"
Call TEXTE(8,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:30X"
SELFOR(NBSEL) = ""
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:ATX]TEXTE"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:DIC]TBL"
Call TEXTE(1176,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:12X"
SELFOR(NBSEL) = "KTD:12c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:DIC]TBL"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:DIC]CODACT"
Call TEXTE(35058,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "KTD:5B"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:DIC]CODACT"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:DIC]ENAFLG"
Call TEXTE(188,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 1
SELFMT(NBSEL) = "LA00001:4X"
SELFOR(NBSEL) = ""
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:DIC]ENAFLG"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:DIC]ENASEL"
Call TEXTE(6028,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 1
SELFMT(NBSEL) = "LA00001:4X"
SELFOR(NBSEL) = ""
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:DIC]ENASEL"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:DIC]POTFLG"
Call TEXTE(29492,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 1
SELFMT(NBSEL) = "LA00001:4X"
SELFOR(NBSEL) = ""
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:DIC]POTFLG"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:DIC]FLGRET"
Call TEXTE(46403,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 1
SELFMT(NBSEL) = "LA00001:4X"
SELFOR(NBSEL) = ""
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:DIC]FLGRET"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:DIC_])=0
 Gosub OUVFIC_LISTE
Endif
Return

