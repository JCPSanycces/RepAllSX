#<AdxTL>@(#)0.0.0.0 $Revision$
#################
# Class APLCOM

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AREAD"                  : Gosub AREAD
      When "AINSERT"                : Gosub AINSERT
      When "AUPDATE"                : Gosub AUPDATE
      When "ADELETE"                : Gosub ADELETE
    Endcase
  When "COLACM"
    Case [L]AEVENT
      When "AREAD_AFTER"   : Gosub COLACM_AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
    When "COMNOM"        : Gosub COMNOM
    When "TYP"           : Gosub TYP
    When "COLACM.COMIND" : Gosub COLACM_COMIND
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return





###############################################################################################

#************************
#* CRUD for APLCOM
#*!
$AREAD
Local File APLCOM [ACM]
Local Integer ILINE
For [ACM] Where COMNOM=this.COMNOM
    ILINE = fmet this.ADDLINE("COLACM",CST_ALASTPOS)
    [L]ASTATUS = fmet this.COLACM(ILINE).AREAD([F:ACM]COMNOM,[F:ACM]COMIND)
    Break [L]ASTATUS>=[V]CST_AERROR
Next

# Assign values of properties TYP & LENGTH of class APLCOM
If maxtab(this.COLACM)>0
    this.TYP = this.COLACM(1).COMTYP-299
    this.LENGTH = this.COLACM(1).COMLEN
Endif
Return

###############################################################################################################################
$AINSERT
Local Char MESSAGE(100)
Local Integer ILINE
#** Interface Control
[L]ASTATUS = func SUPER_TOOL._REQUIRE_ROW(this.COLACM,MESSAGE)
If [L]ASTATUS<>[V]CST_ATRUE
  [L]ASTATUS = fmet this.ASETERROR("COLACM",MESSAGE,[V]CST_AERROR)
  Return
Endif

For ILINE=1 To maxtab(this.COLACM)
  If this.COLACM(ILINE)<>null
    If this.COLACM(ILINE).ASTALIN = CST_ANEW
      this.COLACM(ILINE).COMNOM = this.COMNOM
      this.COLACM(ILINE).COMTYP = this.TYP+299
      this.COLACM(ILINE).COMLEN = this.LENGTH
      [L]ASTATUS = fmet this.COLACM(ILINE).AINSERT()
      Break ([L]ASTATUS>=[V]CST_AERROR)
    Endif
  Endif
Next
Return

###############################################################################################################################
$AUPDATE
Local Char MESSAGE(100)
Local Integer ILINE
#** Interface Control
[L]ASTATUS = func SUPER_TOOL._REQUIRE_ROW(this.COLACM,MESSAGE)
If [L]ASTATUS<>[V]CST_ATRUE
  [L]ASTATUS = fmet this.ASETERROR("COLACM",MESSAGE,[V]CST_AERROR)
  Return
Endif

##** Deleted lines
#For ILINE= 1 To maxtab(this.COLACM)
#  If this.COLACM(ILINE)<>null
#    If this.COLACM(ILINE).ASTALIN = [V]CST_ADEL
#        this.COLACM(ILINE).COMNOM = this.COMNOM
#        [L]ASTATUS = fmet this.COLACM(ILINE).ADELETE()
#        If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
#    Endif
#  Endif
#Next Move down to prevent error on LINE deletion

#** Updated & Inserted lines
For ILINE= 1 To maxtab(this.COLACM)
  If this.COLACM(ILINE)<>null
    If find(this.COLACM(ILINE).ASTALIN,[V]CST_AUPD,[V]CST_ANEW)>0
        this.COLACM(ILINE).COMNOM = this.COMNOM
        this.COLACM(ILINE).COMTYP = this.TYP+299
        this.COLACM(ILINE).COMLEN = this.LENGTH
        If this.COLACM(ILINE).ASTALIN=[V]CST_AUPD
          [L]ASTATUS = fmet this.COLACM(ILINE).AUPDATE()
        Elsif this.COLACM(ILINE).ASTALIN=[V]CST_ANEW
          [L]ASTATUS = fmet this.COLACM(ILINE).AINSERT()
        Endif
        Break [L]ASTATUS>=[V]CST_AERROR
    Endif
  Endif
Next

#** Deleted lines
For ILINE= 1 To maxtab(this.COLACM)
  If this.COLACM(ILINE)<>null
    If this.COLACM(ILINE).ASTALIN = [V]CST_ADEL
        this.COLACM(ILINE).COMNOM = this.COMNOM
        [L]ASTATUS = fmet this.COLACM(ILINE).ADELETE()
        If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
    Endif
  Endif
Next

Return

###############################################################################################################################
$ADELETE
Local Integer ILINE
For ILINE= 1 To maxtab(this.COLACM)
  If this.COLACM(ILINE)<>null
    this.COLACM(ILINE).COMNOM = this.COMNOM
    [L]ASTATUS = fmet this.COLACM(ILINE).ADELETE()
    If [L]ASTATUS>=[V]CST_AERROR : Break : Endif
  Endif
Next
Return

###############################################################################################################################
$COLACM_AREAD_AFTER
#**Set status on each line
this.ASTALIN = [V]CST_ALL
Return

#######
$COMNOM
Case [L]ARULE
    When "CONTROL"   : Gosub COMNOM_CONTROL
Endcase
Return

$COMNOM_CONTROL
this.COMNOM= toupper(this.COMNOM)  #Convert to upper case
Return

#######
$TYP
Case [L]ARULE
   When "INIT"      : Gosub TYP_INIT
   When "CONTROL"   : Gosub TYP_CONTROL
   When "PROPAGATE" : Gosub TYP_PROPAGATE
Endcase
Return

$TYP_INIT
this.TYP=2                      # Default to short integer
this.LENGTH = AVOID.AINT
Return

$TYP_CONTROL
If !find(this.TYP,2,3,4,7,8)
    # Invalid value
    [L]ASTATUS = fmet this.ASETERROR("TYP",mess(83,123,1),[V]CST_AERROR)
Endif
Return

$TYP_PROPAGATE
If this.TYP<>7                   # Alphanumeric
  this.LENGTH = AVOID.AINT
Endif
Return

#######
$COLACM_COMIND
Case [L]ARULE
    When "CONTROL"   : Gosub COLACM_COMIND_CONTROL
Endcase
Return

$COLACM_COMIND_CONTROL
Local Char MESSAGE(250) : [L]MESSAGE = AVOID.ACHAR
[L]ASTATUS=func SUPER_TOOL._UNIQUE_PROPERTY(this.APARENT.COLACM,"COMIND",this.COMIND,[L]MESSAGE)
If [L]ASTATUS<>[V]CST_AOK
  [L]ASTATUS=fmet this.ASETERROR("COD",[L]MESSAGE,[L]ASTATUS)
Endif
Return

