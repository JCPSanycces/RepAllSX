#<AdxTL>@(#)0.0.0.0 $Revision$Class Bank ID statement
# Supervisor
## CRUD-CLASSE ## EMPLORIB
# 2018-11-06 07:06:26 823


############################################################################################
### Subprog _ADELETE
############################################################################################
Subprog _ADELETE(EMPLORIB,ASTATUS)
Variable Instance EMPLORIB Using C_EMPLORIB
Variable Integer ASTATUS

If EMPLORIB = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLORIB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Local Instance ALNKDELTAB Using C_ALNKDELTAB
Gosub ADELETE_EMPLORIB

End

############################################################################################
### Subprog ADELETE
############################################################################################
Subprog ADELETE(EMPLORIB,ASTATUS)
Variable Instance EMPLORIB Using C_EMPLORIB
Variable Integer ASTATUS

If EMPLORIB = null : End : Endif

Gosub AVARIABLES From WMC00EMPLORIB
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

Local Instance ALNKDELTAB Using C_ALNKDELTAB

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub ADELETE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto ADELETE_END : Endif

If !adxlog
 Gosub ADELETE_TR_EMPLORIB
Else
 Gosub ADELETE_EMPLORIB
Endif

$ADELETE_END
End


$ADELETE_CONTROL
Gosub _ADELETE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Verification delete
[L]ASTATUS = max([L]ASTATUS,func ASYRSUB.VERIFY_INSTANCE(EMPLORIB,ALNKDELTAB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _ADELETE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_BEFORE
If EMPLORIB.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLORIB.ASTALIN = [V]CST_ADEL
[L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB.ACTION("ADELETE_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_ADELETE_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB.ACTION("ADELETE_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_TR_EMPLORIB
Trbegin [F:RIB]
 Gosub ADELETE_EMPLORIB
 If [L]ASTATUS>=[V]CST_AERROR : Gosub ADELETE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$ADELETE_EMPLORIB
[L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB.ACTION("ADELETE_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = func ASYRSUB.DELETE_LINKS(EMPLORIB,ALNKDELTAB)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLORIB._MAJSQL_EMPLORIB(EMPLORIB))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet EMPLORIB.ACTION("ADELETE_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$ADELETE_ABORT
Rollback
$_ADELETE_ABORT
If EMPLORIB.snapshotEnabled=1
 [L]A_RETIK = EMPLORIB.revertUpdTick
Endif
[L]ASTATUS = max(fmet EMPLORIB.ACTION("ADELETE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#

#-----------------------------------------------------#
$_ADELETE_AFTER
Return



