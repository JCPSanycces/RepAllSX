#<AdxTL>@(#)12.0.0.0 $Revision$
$ACTION
Case ACTION
 When "FILTRE" : Gosub FILTRE
 When "AS_TYP" : Gosub AS_TYP
 #DIRAS - 2017-01-05 - JIRA X3-11758 - START
 When "FILGAUCHE" : Gosub FILGAUCHE
 #DIRAS - 2017-01-05 - JIRA X3-11758 - END
Endcase
Return

$FILTRE
If GMODU(14)<>2
 CRITERE = "find(TYP,15)=0"
Endif
Return

$AS_TYP
If GMODU(14)<>2
 Local Integer I
 Raz GMENLOC
 For I=1 To len(mess(0,602,1))
  If I=15
   GMENLOC(I) = 1
  Endif
 Next I
Endif

#DIRAS - 2017-01-05 - JIRA X3-11758 - START
Gosub AS_TYP From SUBCCLB
#DIRAS - 2017-01-05 - JIRA X3-11758 - END
Return

#DIRAS - 2017-01-05 - JIRA X3-11758 - START
$FILGAUCHE
Gosub FILGAUCHE From SUBCCLB
Return
#DIRAS - 2017-01-05 - JIRA X3-11758 - END

