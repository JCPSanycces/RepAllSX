#<AdxTL>@(#)12.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
Call SAISIE_CHAR(VALEUR,PARAM,"FCHGDAT","CHGDAT","") From GSAISIE
End

#################################################################################
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","CHGDATB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "DEBUT"        : Gosub DEBUT
 When "OUVRE"        : Gosub OUVRE
 When "OK"           : Gosub OK
 When Default
Endcase
If PSUBB
 Gosub ACTION From CHGDATB
Endif
Return

$OUVRE
If clalev([F:AUS])=0 : Local File AUTILIS [AUS] : Endif
If clalev([F:AME])=0 : Local File AMETUTI [AME] : Endif 
Return

$DEBUT
Local Integer OK
Call LECTURE("AUS",GUSER,"") From CONTOBJ
Local Char LCHGDAT(3)
Call PARAMUTIL("CHGDAT",LCHGDAT,GUSER,"") From SUBAUS
If val(LCHGDAT)<>2
 GMESSAGE = mess(31,130,1) : # Changement de date non autorisé
 GERR = 1 : FIN = 1 : Return
Endif
Raz [M]
[M]DATCUR = datesyst
Return

$OK
datesyst = [M]DATCUR
Gosub CHGUSRW From GESUSER
FIN = 1
Return

#################################################################################
Subprog C_DATCUR(VALEUR)
Variable Date VALEUR
If VALEUR<GDATDEB or VALEUR>GDATFIN
 GMESSAGE = mess(195,100,1) : # Date en dehors des périodes définies
 mkstat = 2 : End
Endif
End
