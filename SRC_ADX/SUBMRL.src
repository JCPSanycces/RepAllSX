#<AdxTL>@(#)4.0.0.0 $Revision$
# SUBMRL : Transactions Regroupements                    LLC    09/99 #
#---------------------------------------------------------------------#
# Tables mises à jour : [F:BTS]BENCHTRS Table des transactions        #
#                       [F:AMK]AMSK     Table des écrans              #
#                       [F:AMZ]AMSKZON  Table des zones d'écran       #
#                                                                     #
# Génération      écran  de saisie à partir de l'écran MFGBENCH       #
#                                                                     #
# Nom des écrans de base générés : WTxyyyz                            #
#                                  x = 51 pour plan global            #
#                                  x = 52 pour plan de travail        #
#                                  x = 53 pour regroupements          #
#                                                                     #
#                                  yyy = nom de la transaction        #
#                                                                     #
#                                  z = numéro d'ordre de l'écran      #
# Exemple:                                                            #
# - prod    : fenêtre FMFGR    générée      WFMFGRxxx                 #
#   écran de base     MFGPICK  écran généré WT53XXX1                  #
#                                                                     #
# - achats  : fenêtre FMFGRA   générée      WFMFGRAxxx                #
#   écran de base     MFGPICKA écran généré WT53XXX1                  #
#                                                                     #
# - ss-trait: fenêtre FMFGRB   générée      WFMFGRBxxx                #
#   écran de base     MFGPICK  écran généré WT53XXX1                  #
#######################################################################
# GA 08/2006: A COMPLETER pour Achats sous-traitance [M:MRL1]USRPRF = 4
#######################################################################
$ACTION
Case ACTION
 When "OUVRE"    : Gosub OUVRE
 When "FILTRE"   : Gosub FILTRE
 When "EFFMASK"  : [M]BTSTYP = 53
 When "SETBOUT"  : Gosub SETBOUT
 When "EXEBOUT"  : Gosub EXEBOUT
 When "LIENS"    : Gosub LIENS
 When "RAZCRE"   : Gosub RAZCRE
 When "INICRE"   : Gosub INICRE
 When "INIMOD"   : Gosub INICRE
 When "APRES_MODIF" : Gosub APRES_MODIF
 When "CREATION" : Gosub TRT_ECRAN
 When "MODIF"    : Gosub TRT_ECRAN
 When "ANNULE"   : Delete [AXX] Where CODFIC="BENCHTRS" & IDENT1=num$([F:BTS]BTSTYP) & IDENT2=[F:BTS]BTSNUM
                   Gosub TRT_ECRAN
 When Default
Endcase
Return


#-------------------------------------------------------#
# Définir le dossier pour la génération des écrans      #
#-------------------------------------------------------#
$OUVRE
# FQ 50870 ecrase la variable APPLI en validation des transactions sur dossier fille
If dim(APPLI)<0  Local  Char    APPLI Endif
If APPLI=""      APPLI=nomap          Endif

Local Char    LIBEL(30) , MASKREF(GLONAMK), MASKDES(GLONAMK)
Local Integer ER

If clalev ([F:AMZ]) <= 0  : Local File AMSKZON [AMZ] : Endif
If clalev ([F:AMK])  = 0  : Local File AMSK    [AMK] : Endif
If clalev ([F:AMA])  = 0  : Local File AMSKACT [AMA] : Endif
If clalev ([F:AMP])  = 0  : Local File AMSKPAR [AMP] : Endif
If clalev ([F:ADS])  = 0  : Local File ADOSSIER[ADS] : Endif


Return


#-------------------------------------------------------#
# Ne traiter que les transactions de regroupements      #
#-------------------------------------------------------#
$FILTRE
FILTSUP="BTSTYP=53"
Return

#------------------------------------------#
# Désactivation bouton validation et copie #
#------------------------------------------#
$SETBOUT
If GREP <>"" or !CLECUR Call VIREBOUT(CHAINE,"12") From GOBJET : Endif
Call VIREBOUT(CHAINE,"H") From GOBJET
Return

#------------------------------------------------#
# Après appui sur bouton "Validation" ou "copie" #
#------------------------------------------------#
$EXEBOUT
If    find([M:MRL1]USRPRF,1,4)
    MASKREF = "MFGPICK"
Elsif find([M:MRL1]USRPRF,2,3)
    MASKREF = "MFGPICKA"
Endif
Case REP
  When "1" : Gosub TRT_ECRAN
When Default
Endcase
Return

$LIENS
If [F:BTS]PLANNER = 2 & [F:BTS]BUYER<>2
    Actzo [M:MRL1]20
    [M:MRL1]USRPRF = 1
    MASKREF = "MFGPICK"
Else
    Grizo [M:MRL1]20
Endif
# GA 08/2006 Planificateur sous-traitance
If [F:BTS]PLANNER = 2 & [F:BTS]BUYER=2
    Actzo [M:MRL1]28
    [M:MRL1]USRPRF = 4
    MASKREF = "MFGPICK"        : # GA 08/2006 A REVOIR ????
Else
    Grizo [M:MRL1]28
Endif
If [F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2
    [M:MRL1]USRPRF = 2
    MASKREF = "MFGPICKA"
Endif
#If [F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2  : # GA 08/2006 sauf <Planif. ss-trait.>
If [F:BTS]PLANNER<>2 & ([F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2)
    [M:MRL1]USRPRF = 3
    MASKREF = "MFGPICKA"
Endif
If find([M:MRL1]USRPRF,2,3)
    Actzo [M:MRL1]25
    If [M:MRL1]USRPRF = 2
        If [F:BTS]APPBUY = 2 & [F:BTS]APPINT = 1 : [M:MRL1]APPPRF = 1 : Endif
        If [F:BTS]APPBUY = 1 & [F:BTS]APPINT = 2 : [M:MRL1]APPPRF = 2 : Endif
        If [F:BTS]APPBUY = 2 & [F:BTS]APPINT = 2 : [M:MRL1]APPPRF = 3 : Endif
        If !find([M:MRL1]APPPRF,1,2,3) : [M:MRL1]APPPRF = 3 : [M:MRL1]APPBUY = 2 : [M:MRL1]APPINT = 2 : Endif
    Else
        If [F:BTS]BUYER  = 2 & [F:BTS]INTBUY = 1 : [M:MRL1]APPPRF = 1 : Endif
        If [F:BTS]BUYER  = 1 & [F:BTS]INTBUY = 2 : [M:MRL1]APPPRF = 2 : Endif
        If [F:BTS]BUYER  = 2 & [F:BTS]INTBUY = 2 : [M:MRL1]APPPRF = 3 : Endif
        If !find([M:MRL1]APPPRF,1,2,3) : [M:MRL1]APPPRF = 3 : [M:MRL1]BUYER  = 2 : [M:MRL1]INTBUY = 2 : Endif
    Endif
Else
    Grizo [M:MRL1]25
Endif
# grisage si transaction consultation
If [F:BTS]TRSCNL=2
    Grizo [M:MRL1]20-25
  # GA 08/2006 Désactivation des paramétrages "Planif. ss-trait."
    Grizo [M:MRL1]28
Endif

Gosub PE_MFGTRS From SUBMFX

# chargement champs paramétrés
[M]NBRFLD = 0
Gosub CHARGE_CHAMP
Raz [M]DAC
For NOL=0 To [F:BTS]NBRFLD-1
    K = find([F:BTS]FLD(NOL),[M]FLD(0..[M]NBRFLD))
    If K
      [M]DAC(K-1) = [F:BTS]DAC(NOL)
     Endif
Next NOL
Gosub TRI

Return

$RAZCRE
Gosub PE_MFGTRS From SUBMFX
Return

#################################################
#Pour les zones n'ayant pas le même nom dans l'écran et dans le fichier
$INICRE
Gosub CHARGE_ATEXTRA From SUBMRL
[F:BTS]SRGWAIFLG = 1
Gosub PE_MFGTRS From SUBMFX
Return

#----------------------------------------#
# Création ou modif du texte traductible #
#----------------------------------------#
$CHARGE_ATEXTRA
Call MAJTEXTRA([M:MRL0]DESAXX,"BENCHTRS","DESAXX",num$([M:MRL0]BTSTYP),[M:MRL0]BTSNUM) From ATEXTRA
[F:BTS]BTSDES   =GLANGUE+"~"+[M:MRL0]DESAXX
[F:BTS]BTSTYPCAR=num$([F:BTS]BTSTYP)
Return

#################################################
$APRES_MODIF
Gosub PE_MFGTRS From SUBMFX
Return

#------------------------------------------------#
# Génération ou suppression de l'écran de saisie #
#------------------------------------------------#
$TRT_ECRAN
Local Char     WINREF1(GLONFEN)
Local Char     NOMWIN1(GLONFEN)
Case [M:MRL1]USRPRF
    When 1  :   MASKREF = "MFGPICK"             : # GA 08/2006 Planif. ss-trait
                WINREF1="FMFGR"
                NOMWIN1="WFMFGR"+[M:MRL0]BTSNUM
    When 2,3:   MASKREF = "MFGPICKA"
                WINREF1="FMFGRA"
                NOMWIN1="WFMFGRA"+[M:MRL0]BTSNUM
    When 4  :   MASKREF = "MFGPICK"             : # GA 08/2006 Planif. ss-trait
                WINREF1="FMFGRB"
                NOMWIN1="WFMFGRB"+[M:MRL0]BTSNUM
Endcase
MASKDES = "WT"+num$([M:MRL0]BTSTYP)+[M:MRL0]BTSNUM+"1"
Case ACTION
    When "ANNULE":              Call DELMSK(MASKDES, APPLI) From MSKDIV
                                Gosub TRT_SUP_FEN
    When "CREATION", "MODIF":   Call VALIDATION(MASKREF, MASKDES, APPLI, 0,ACTION)
                                Gosub TRT_GEN_FEN
    When "MASSE":               Call VALIDATION(MASKREF, MASKDES, APPLI, 0,ACTION)
                                Gosub TRT_GEN_FEN
    When Default:               Call VALIDATION(MASKREF, MASKDES, APPLI, 1,ACTION)
                                Gosub TRT_GEN_FEN
Endcase
Return

Subprog VALIDATION(LMSKREF, LMSKDES, LAPPLI, LTRS,ACTION)
Value Char LMSKREF
Value Char LMSKDES
#Value Char LCOD   # Issue 79269 code review while new EP MFGTRSWIN
Value Char LAPPLI
Value Integer LTRS
Value Char ACTION
Local Char MASKDES(GLONAMK) , MASKREF(GLONAMK) , SAVLAN(GLONLAN)
Local Integer OK , NOL , NCOL , LANCUR, J
Local Decimal RANG

If clalev([F:AMK2])=0 : Local File =LAPPLI+".AMSK"    [AMK2] : Endif
If clalev([F:AMZ2])=0 : Local File =LAPPLI+".AMSKZON" [AMZ2] : Endif
If clalev([F:AMA2])=0 : Local File =LAPPLI+".AMSKACT" [AMA2] : Endif
If clalev([F:AMP2])=0 : Local File =LAPPLI+".AMSKPAR" [AMP2] : Endif
If clalev([F:ADS])=0  : Local File  ADOSSIER [ADS] : Endif

If LTRS = 1  Call DEBTRANS From GLOCK : Endif
If LMSKREF <> ""
    Gosub TR1
    If GOK=1
        Read [ADS]DOSSIER = LAPPLI
        Call VALID(LMSKDES,LAPPLI,1,GLANGUE,1,OK) From VALMSK
    Endif
Endif
End

$TR1
GOK = 1
If LTRS = 1 : Trbegin [AMK2] , [AMZ2] , [AMA2] , [AMP2] : Endif
    Call DELMSK(LMSKDES,LAPPLI) From MSKDIV
    Read [AMK]CODMSK = LMSKREF
    [F:AMK2] = [F:AMK]
    [F:AMK2]CODMSK = LMSKDES
    [F:AMK2]MDL = 1                # !!
    NCOL = 0
    NCOL = find(1,[F:AMK2]TYPBLOC(0..dim([F:AMK]TYPBLOC)-1))
    If NCOL
        For J = 1 To 9
           K = instr(1,[F:AMK2]OPTION(NCOL-1),num$(J))
           If K
               [F:AMK2]OPTION(NCOL-1) = left$([F:AMK2]OPTION(NCOL-1),K-1) +
&                                       right$([F:AMK2]OPTION(NCOL-1),K+1)
           Endif
        Next J
        If [F:BTS]NBRCOL > 0 # Gestion des colonnes fixes
            [F:AMK2]OPTION(NCOL-1) += num$([F:BTS]NBRCOL)
        Endif
        # si approvisionneur externe, ajout possibilité d'ajouter des lignes
        If [F:BTS]PLANNER <> 2 : [F:AMK2]ACTBLOC(NCOL-1) = "" : [F:AMK2]OPTION(NCOL-1) += "RI" : Endif
        [F:AMK2]NBLIGT(NCOL-1)  = [F:BTS]NBRLIG
     Endif
#     [F:AMK2]TRTAUTO = LMSKDES
     Write [AMK2]
     If fstat
         GOK=0 : Call FSTA("AMK2") From GLOCK : Goto AB_TR1
     Endif
     Read [AMZ]CODE = LMSKREF;"NBLIG"
     If fstat=0 : J=[F:AMZ]NUMBLOC : Else J=0 : Endif
     For [AMZ]CODZON Where CODMSK=LMSKREF
         NOL = find([F:AMZ]CODZON,[F:BTS]FLD(0..[F:BTS]NBRFLD-1))
         OK = 0
         If NOL & [F:BTS]DAC(NOL-1)<>0
             OK = 1 : RANG = [F:BTS]DAC(NOL-1)
         Endif
         If [F:AMZ]CODTYP="ABS"
             OK = 1 : RANG = 0
         Elsif [F:AMZ]CODZON ="FIE"   # FQ 53975 champ PEC tjs en position 1
             OK = 1 : RANG = 1
         Elsif [F:AMZ]SAIAFF=3 | (J & [F:AMZ]NUMBLOC<>J)
             OK = 1 : RANG = [F:AMZ]NOZONE
         Endif
         # Issue 110957 - 2015-10-08 by GH
         If [F:AMZ]CODZON = "CRID" & OK
            RANG+=0.1
         Endif
         If [F:AMZ]CODZON = "CRFLG"
            NOL = find("CRID",[F:BTS]FLD(0..[F:BTS]NBRFLD-1))
            If NOL & [F:BTS]DAC(NOL-1)<>0
               OK = 1 : RANG = [F:BTS]DAC(NOL-1)+0.2
            Endif
         Endif
         [F:AMZ2] = [F:AMZ]
         [F:AMZ2]CODMSK = LMSKDES
         [F:AMZ2]NOZONE = RANG
         If [F:AMZ]CODTYP="ABS"
             [F:AMZ2]SAIAFF = 1
         Elsif !OK | [F:AMZ]SAIAFF=3 |
&              [F:AMZ2]CODZON = "PLANNER" & [F:BTS]GESAFF = 3
             [F:AMZ2]SAIAFF = 3
             [F:AMZ2]TUNNEL = 1
             [F:AMZ2]LIEN   = 1
         Elsif [F:AMZ2]CODZON = "PLANNER" & [F:BTS]GESAFF = 2
             [F:AMZ2]SAIAFF = 2
             [F:AMZ2]TUNNEL = 1
             [F:AMZ2]LIEN   = 1
         Else
             [F:AMZ2]SAIAFF = [F:AMZ]SAIAFF
         Endif
         Gosub PE_MFGTRS From SUBMFX
         If [F:AMZ2]SAIAFF=3 & [F:AMZ2]OPTFOR<>"" & left$([F:AMZ2]OPTFOR,1)<>"-"
             [F:AMZ2]OPTFOR = "-"+[F:AMZ2]OPTFOR
         Endif
         Write [AMZ2]
         If fstat
             GOK=0 : Call FSTA("AMZ2") From GLOCK : Break
         Endif
     Next
     If     GOK < 0 : Goto ROLL_TR1
     Elsif !GOK     : Goto AB_TR1 : Endif
     For [AMA] Where TYPAFF=1 & CODAFF=LMSKREF
         [F:AMA2] = [F:AMA]
         [F:AMA2]CODAFF = LMSKDES
         Write [AMA2]
         If fstat
             GOK=0 : Call FSTA("AMA2") From GLOCK : Break
         Endif
     Next
     If     GOK < 0 : Goto ROLL_TR1
     Elsif !GOK     : Goto AB_TR1
     Endif
     For [AMP] Where TYPAFF=1 & CODAFF=LMSKREF
         [F:AMP2] = [F:AMP]
         [F:AMP2]CODAFF = LMSKDES
         Write [AMP2]
         If fstat
             GOK=0 : Call FSTA("AMP2") From GLOCK : Break
         Endif
     Next
     If     GOK < 0 : Goto ROLL_TR1
     Elsif !GOK     : Goto AB_TR1
     Endif
If LTRS = 1 : Commit : Endif
Return

$AB_TR1
If LTRS = 1 : Rollback : Endif
Return

$ROLL_TR1
If LTRS = 1 : Rollback : Endif
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif


######################################################################################
# Etiquettes gestion paramétrage affichage
######################################################################################
$CHARGE_CHAMP
# dans quel bloc se situe le tableau ?
Read [AMZ]CODE = MASKREF;"NBLIG"
If fstat=0 : J=[F:AMZ]NUMBLOC : Else J=0 : Endif

For [AMZ]CODZON Where CODMSK=MASKREF
    OK = 1
    # Issue 110957 - 2015-10-08 by GH # test [F:AMZ]INTIT
    If [F:AMZ]CODTYP="ABS" | [F:AMZ]SAIAFF=3 | (J & [F:AMZ]NUMBLOC<>J) | [F:AMZ]INTIT=0
        OK = 0
    Endif
    If OK & !find([F:AMZ]CODZON,[M]FLD(0..[M]NBRFLD-1))
        NOL = [M]NBRFLD
        [M]FLD(NOL) = [F:AMZ]CODZON
        Gosub LIBEL
        [M]NBRFLD += 1
    Endif
Next
Return

######################################################################################
$LIBEL
If [F:AMZ]INTEVAL <> ""
    Onerrgo ERRLIB
    ER = 0
    [M]INTIT(NOL) = evalue([F:AMZ]INTEVAL)
    If ER
        [M]INTIT(NOL) = [F:AMZ]INTEVAL
    Endif
    Onerrgo
Else
    Call TEXTE([F:AMZ]INTIT,LIBEL) From OBJDIV
    [M]INTIT(NOL) = LIBEL
Endif
Return

######################################################################################
$ERRLIB
ER = errn
Resume

######################################################################################
$TRI
For NOL=0 To [M]NBRFLD-1
 If [M]DAC(NOL)=0 : [M]DAC(NOL) = 9999 : Endif
Next NOL
Sorta [M]NBRFLD [M]NBRFLD Order By [M]DAC(indice)
For NOL=0 To [M]NBRFLD-1
 If [M]DAC(NOL)=9999 : [M]DAC(NOL) = 0 : Endif
Next NOL
Return

#-------------------------------------------------------------------------#
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 1 (Non actif)           #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
# Si action = "CREATION" ou "MODIF" avec ENAFLG = 2 (Actif)               #
# Génération fenêtre, traitement associé et mise à jour traitement objet  #
#-------------------------------------------------------------------------#
$TRT_GEN_FEN
If clalev([F:AWI])=0 : Local File =APPLI+".AWINDOW"  [AWI] : Endif :
If clalev([F:AWP])=0 : Local File =APPLI+".AWINPAR"  [AWP] : Endif :
If clalev([F:AWB])=0 : Local File =APPLI+".AWINBRO"  [AWB] : Endif :
If clalev([F:AWT])=0 : Local File =APPLI+".AWINBOUT" [AWT] : Endif :

#----- Suppression fenêtre si transaction non active -----#
Gosub TRT_SUP_FEN
If [M:MRL0]ENAFLG=1 : Return : Endif

#----- Génération fenêtre pour suivi si transaction active -----#
Delete [AWI] Where WIN=NOMWIN1
If     fstat = 1 : GOK = -1 : GLOCK="$AWINDOW"-NOMWIN1
Elsif  fstat     : GOK = 0  : Call RSTA ("AWI",NOMWIN1) From GLOCK
Endif
Delete [AWP] Where WIN=NOMWIN1
If     fstat = 1 : GOK = -1 : GLOCK="$AWINPAR"-NOMWIN1
Elsif  fstat     : GOK = 0  : Call RSTA ("AWP",NOMWIN1) From GLOCK
Endif
Read [AWI]AWI0=WINREF1
If !fstat
    [F:AWI]WIN       = NOMWIN1
    WNOMMSK="WT"+num$([M:MRL0]BTSTYP)+[M:MRL0]BTSNUM+"1"
    If find([M:MRL1]USRPRF,1,4)                : # GA 08/2006 Planif. ss-trait
        I = find("MFGPICK" ,[F:AWI]NOMMSK)-1 : If I < 0 : I = 1 : Endif
    Else
        I = find("MFGPICKA",[F:AWI]NOMMSK)-1 : If I < 0 : I = 1 : Endif
    Endif
    [F:AWI]NOMMSK(I) = WNOMMSK
    [F:AWI]ACS       = [M:MRL0]ACSCOD
    If dim([F:AWI]LIBEL)>0
        Call LECTEXTRA([F:AWI]LIBEL,"BENCHTRS","DESAXX",num$([M:MRL0]BTSTYP),[M:MRL0]BTSNUM) From ATEXTRA
    Endif
    [F:AWI]ENAFLG    = 2
    [F:AWI]TRN       = [M:MRL0]BTSNUM
    [F:AWI]MDL       = 1                # !!

    # Issue 79269 - New entry Point to Hide/Show Specific Tab
    Gosub PE_MFGTRSWIN From SUBMFX

    Write [AWI]
    If fstat : GOK = 0 : Call FSTA("AWI") From GLOCK : Return : Endif
    For [AWP]AWP0 Where WIN=WINREF1
        [F:AWP]WIN = NOMWIN1
        Write [AWP]
        If fstat : GOK = 0 : Call FSTA("AWP") From GLOCK : Break : Endif
    Next
    If GOK < 1 : Return : Endif
    For [AWB]AWB0 Where WIN=WINREF1
        [F:AWB]WIN = NOMWIN1
        Write [AWB]
        If fstat : GOK = 0 : Call FSTA("AWB") From GLOCK : Break : Endif
    Next
    For [AWT]AWT0 Where WIN=WINREF1
        [F:AWT]WIN = NOMWIN1
        Write [AWT]
        If fstat : GOK = 0 : Call FSTA("AWT") From GLOCK : Break : Endif
    Next
    If GOK < 1 : Return : Endif

Endif
Call VALID(NOMWIN1,APPLI,0,OK) From VALWIN
If !OK  : GOK=0 : Return : Endif
Return


#-------------------------------------------------------------------------#
# Si action = "ANNULE"                                                    #
# Suppression fenêtre, traitement associé et mise à jour traitement objet #
#-------------------------------------------------------------------------#
$TRT_SUP_FEN
#----- Suppression ----#
Call DELWIN(NOMWIN1,APPLI) From MSKDIV
Return


######################################################################################
# Etiquettes écran
######################################################################################

########################################
#-----------------------#
# Avant zone code actif #
#-----------------------#
Subprog AV_ENAFLG(VALEUR)
Variable Integer VALEUR
If GREP<>"C" & VALEUR=0 VALEUR=2 : Endif
End

########################################
Subprog AM_USRPRF(VALEUR)
Variable Integer VALEUR
Local Integer OK , I, NOL
Local Char    LIBEL(30) , MASKREF(GLONAMK)
Local Integer INC : INC = 0
Local Integer NBFLD

If find(VALEUR,2,3) & [M:MRL1]APPPRF=0 : Affzo [MRL1]APPPRF : Endif : # Issue 93655 GH 29/05/2018 - in creation, init APPPRF before testing it
Case VALEUR
    When 1:    Actzo [M:MRL1]20
               Grizo [M:MRL1]25
               Grizo [M:MRL1]28      : # GA 08/2006
               [M:MRL1]SCOPLN  = 1   : # GA 08/2006
               [M:MRL1]SCOLAN  = 1   : # GA 08/2006
               [M:MRL1]PLNPLN  = 2
               [M:MRL1]PLNLAN  = 2
               [M:MRL1]PLANNER = 2
               [M:MRL1]APPBUY  = 1
               [M:MRL1]APPINT  = 1
               [M:MRL1]INTBUY  = 1
               [M:MRL1]BUYER   = 1
               [M:MRL1]MFGTRS  = GMFGMTSNUM
               [M:MRL1]SCOTRS = ""
               MASKREF = "MFGPICK"
               NBFLD = 5
    When 2:    Grizo [M:MRL1]20
               Actzo [M:MRL1]25
               Grizo [M:MRL1]28      : # GA 08/2006
               [M:MRL1]SCOPLN  = 1   : # GA 08/2006
               [M:MRL1]SCOLAN  = 1   : # GA 08/2006
               [M:MRL1]PLNPLN  = 1
               [M:MRL1]PLNLAN  = 1
               [M:MRL1]PLANNER = 1
               Case [M:MRL1]APPPRF
                   When 1:    [M:MRL1]APPBUY = 2
                              [M:MRL1]APPINT = 1
                   When 2:    [M:MRL1]APPBUY = 1
                              [M:MRL1]APPINT = 2
                   When 3:    [M:MRL1]APPBUY = 2
                              [M:MRL1]APPINT = 2
               Endcase
               [M:MRL1]INTBUY = 1
               [M:MRL1]BUYER = 1
               [M:MRL1]MFGTRS = ""
               [M:MRL1]SCOTRS = ""
               MASKREF = "MFGPICKA"
               NBFLD = 7
    When 3:    Grizo [M:MRL1]20
               Actzo [M:MRL1]25
               Grizo [M:MRL1]28      : # GA 08/2006
               [M:MRL1]SCOPLN  = 1   : # GA 08/2006
               [M:MRL1]SCOLAN  = 1   : # GA 08/2006
               [M:MRL1]PLNPLN  = 1
               [M:MRL1]PLNLAN  = 1
               [M:MRL1]PLANNER = 1
               [M:MRL1]APPBUY  = 1
               [M:MRL1]APPINT  = 1
               Case [M:MRL1]APPPRF
                   When 1:    [M:MRL1]BUYER = 2
                              [M:MRL1]INTBUY = 1
                   When 2:    [M:MRL1]BUYER = 1
                              [M:MRL1]INTBUY = 2
                   When 3:    [M:MRL1]BUYER = 2
                              [M:MRL1]INTBUY = 2
               Endcase
               [M:MRL1]MFGTRS = ""
               [M:MRL1]SCOTRS = ""
               MASKREF = "MFGPICKA"
               NBFLD = 7
    When 4:    Actzo [M:MRL1]28     : # GA 08/2006 Planif. ss-trait.
               Grizo [M:MRL1]20
               Grizo [M:MRL1]25
               [M:MRL1]SCOPLN  = 2
               [M:MRL1]SCOLAN  = 2
               [M:MRL1]PLNPLN  = 1
               [M:MRL1]PLNLAN  = 1
               [M:MRL1]PLANNER = 2  : # !!! ne pas activer cet indicateur pour utiliser MFGPICKA
               [M:MRL1]APPBUY  = 1
               [M:MRL1]APPINT  = 1
               [M:MRL1]INTBUY  = 1
               [M:MRL1]BUYER   = 2
               [M:MRL1]MFGTRS  = ""
               [M:MRL1]SCOTRS  = GSCOPTRNUM
               MASKREF = "MFGPICK"
               NBFLD = 5
Endcase

# 15121 09.02 MM
If [M:MRL1]TRSCNL =2
    If [M:MRL1]PLNPLN =2 : [M:MRL1]PLNPLN =1 : Affzo [M:MRL1]PLNPLN : Endif
    If [M:MRL1]PLNLAN =2 : [M:MRL1]PLNLAN =1 : Affzo [M:MRL1]PLNLAN : Endif
    If [M:MRL1]MFGTRS <>"" : [M:MRL1]MFGTRS = "" : Affzo [M:MRL1]MFGTRS : Endif
    Grizo [M:MRL1]20-25
Endif

If GREP = "C" | [M:MRL2]NBRFLD = 0
    [M:MRL2]NBRFLD = 0
    Gosub CHARGE_CHAMP
Endif
# activation par défaut des 6 premiers champs si tableaux vide (création)
OK = max([M:MRL2]DAC(0..[M:MRL2]NBRFLD - 1))
If !OK
    For I = 0 To NBFLD
        INC += 5
        [M:MRL2]DAC(I) = INC
    Next I
Endif
If !GIMPORT : Affzo [M:MRL2]10 : Affzo [M:MRL1]20 : Affzo [M:MRL1]25 : Affzo [M:MRL1]28 : Endif

End

########################################
Subprog C_PLNLAN(VALEUR)
Variable Integer VALEUR
End

########################################
Subprog AM_BTSNUM(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog B1_NBRFLD
Local Integer I
If [M:MRL2]DAC(nolign-1) = 0
    [M:MRL2]DAC(nolign-1) = max([M:MRL2]DAC(0..[M:MRL2]NBRFLD - 1)) + 5
    If !GIMPORT : Affzo [M:MRL2]10 : Endif
Else
    For I = 0 To [M:MRL2]NBRFLD - 1
        If [M:MRL2]DAC(I) > [M:MRL2]DAC(nolign-1)
            [M:MRL2]DAC(I) -= 5
        Endif
    Next I
    [M:MRL2]DAC(nolign-1) = 0
    If !GIMPORT : Affzo [M:MRL2]10 : Endif
Endif
mkstat = 4
End

########################################
Subprog AS_NBRFLD
Raz GBOUT1, GBOUT2, GBOUT3
If [M:MRL2]FLD(nolign-1) <> ""
    GBOUT1 = mess(306,198,1)
    GBOUT2 = mess(396,198,1)
    GBOUT3 = mess(385,198,1)
Endif
End

########################################
Subprog B2_NBRFLD
Local Integer NOL
Gosub TRI
If !GIMPORT : Affzo [M:MRL2]10 : Endif
End

########################################
Subprog B3_NBRFLD
Local Integer I, NOL
Local Integer INC : INC = 0
Gosub TRI
For I = 0 To [M:MRL2]NBRFLD - 1
    If [M:MRL2]DAC(I) = 0 : Break : Endif
    INC += 5
    [M:MRL2]DAC(I) = INC
Next I
If !GIMPORT : Affzo [M:MRL2]10 : Endif
End


########################################
Subprog C_MFGTRS(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : End : Endif
If clalev ([F:MTS])  = 0 : Local File MFGTRS    [MTS] : Endif
If VALEUR <> ""
    Read [MTS]MTS0=1;VALEUR
    If fstat : GMESSAGE = mess(23,100,1) : mkstat = 2 : Endif
Endif
If [F:MTS]TRSAUTO <> 2 : GMESSAGE = mess(194,193,1) : mkstat = 2 : Endif
End

########################################
Subprog C_SCOTRS(VALEUR) : # GA 08/2006
Variable Char    VALEUR()
If GMODU(6) <> 2 | VALEUR = "" : End : Endif
If clalev ([F:PTR])  = 0 : Local File PURTRS    [PTR] : Endif
If VALEUR <> ""
    Read [PTR]PTR0=9;VALEUR
    If fstat : GMESSAGE = mess(23,100,1) : mkstat = 2 : End : Endif
Endif
If [F:PTR]TRSAUTO <> 2 : GMESSAGE = mess(194,193,1) : mkstat = 2 : Endif
End

########################################
Subprog AS_BTSNUM(VALEUR)
Variable Char    VALEUR()
[M:MRL0]BTSTYP = 53
End

########################################
# 15121 09.02 MM
Subprog AM_TRSCNL(VALEUR)
Variable Integer VALEUR

Case VALEUR
    When 1 : Case [M:MRL1]USRPRF
                    When 1 :     Actzo [M:MRL1]20  : # planificateur production
                                 MASKREF ="MFGPICK"
                    When 2,3 :   # approvisionneur
                                 Actzo [M:MRL1]25
                                 MASKREF= "MFGPICKA"
                    When 4 :     Actzo [M:MRL1]28  : # planificateur sous-traitance
                                 MASKREF= "MFGPICK"
                    When Default
            Endcase
            If [M:MRL1]USRPRF >=1 & [M:MRL1]USRPRF <=4  : # GA 08/2006 avant <=3
                Gosub CHARGE_CHAMP
            Endif
    When 2 : If [M:MRL1]PLNPLN =2 : [M:MRL1]PLNPLN =1 : Affzo [M:MRL1]PLNPLN : Endif
             If [M:MRL1]PLNLAN =2 : [M:MRL1]PLNLAN =1 : Affzo [M:MRL1]PLNLAN : Endif
             If [M:MRL1]MFGTRS <>"" : [M:MRL1]MFGTRS = "" : Affzo [M:MRL1]MFGTRS : Endif
             Grizo [M:MRL1]20-25
            # GA 08/2006 Raz et désactivation des paramétrages "Planificateur sous-traitance"
             [M:MRL1]SCOPLN=1 : [M:MRL1]SCOLAN=1 : Raz [M:MRL1]SCOTRS
             Affzo [M:MRL1]28 : Grizo [M:MRL1]28
Endcase
End

##########################################################################
Subprog AM_APPPRF(VALEUR)
Variable Integer VALEUR
# Type d'appro Menu local 2367
Case VALEUR
    When 1:    If [M:MRL1]USRPRF = 2
                   [M:MRL1]APPBUY = 2
                   [M:MRL1]APPINT = 1
                   [M:MRL1]BUYER  = 1
                   [M:MRL1]INTBUY = 1
               Else
                   [M:MRL1]BUYER = 2
                   [M:MRL1]INTBUY = 1
                   [M:MRL1]APPBUY = 1
                   [M:MRL1]APPINT = 1
               Endif
    When 2:    If [M:MRL1]USRPRF = 2
                   [M:MRL1]APPBUY = 1
                   [M:MRL1]APPINT = 2
                   [M:MRL1]BUYER = 1
                   [M:MRL1]INTBUY = 1
               Else
                   [M:MRL1]BUYER = 1
                   [M:MRL1]INTBUY = 2
                   [M:MRL1]APPBUY = 1
                   [M:MRL1]APPINT = 1
               Endif
    When 3:    If [M:MRL1]USRPRF = 2
                   [M:MRL1]APPBUY = 2
                   [M:MRL1]APPINT = 2
                   [M:MRL1]BUYER = 1
                   [M:MRL1]INTBUY = 1
               Else
                   [M:MRL1]BUYER = 2
                   [M:MRL1]INTBUY = 2
                   [M:MRL1]APPBUY = 1
                   [M:MRL1]APPINT = 1
               Endif
Endcase
End


########################################################################
# Pour exécution de la validation des transactions en gestion de patch #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(6)<>2 End : Endif
Call GENPATCH(53,APPLI) From FUNSTKTRS
End

###########################################################################
# Pour éxécution validation transaction par gestion de dossier            #
#                                       par l'utilitaire de revalidation  #
#      à partir du dictionnaire des types de transaction (ATN)            #
###########################################################################
Subprog GENDOS(APPLI)
Value Char APPLI

Call GENDOS(53,APPLI) From FUNSTKTRS
End
##########################################################################

########################################################
# Pour exécution de la copie en masse depuis le menu : #
# Utilitaires - Dictionnaire - Copie transactions      #
########################################################
$TRTCOP
Local Integer MODULE    : MODULE=7
Local Integer TYP       : TYP=53
Local Char    CODTAB(GLONTRS) : CODTAB=TABLE
#-----
Gosub OUVRE_COPTRS From SELTRS
Gosub EXEC_COPTRS  From SELTRS
Gosub FERME_COPTRS From SELTRS
Return

