#<AdxTL>@(#)9.0.0.0 $Revision$
#<AdxTL>@(#)9.0.0.0 $Revision$
#** V7 : Waiting Time Mangement **#
#*********************************#

Local Char PARAM(30)(1..3) , VALEUR(10)

[V]GWINDOW ="FVEPEXC"
[V]GPROG   ="VEPEXC"
[V]GPROGSPE=""
[L]PARAM(1)=[V]GREFNUM
[L]PARAM(2)=[V]GMOIPAY
[L]PARAM(3)=""
[L]PARAM(4)=""
Call SAISIE_CHAR([L]VALEUR,[L]PARAM,[V]GWINDOW,[V]GPROG,[V]GPROGSPE) From GSAISIE

End

################################################################################
$ACTION
Case [L]ACTION
 When "OUVRE"   : Goto OUVRE
 When "DEBUT"   : Goto DEBUT
 When "SETBOUT" : Goto SETBOUT
#-------------------------------------------------------------------------------
 When "BOUTON"  : If [L]BOUT="R" : Goto RECHERCHE : Endif
 When "MEN"     : If find([L]BOUT,"E","S","D") : [L]DEFILE=[L]BOUT : Endif
 When "RAF"     : Goto RECHERCHE
 When "SUI"     : Goto SUI
 When "PRE"     : Goto PRE
 When "FIR"     : Goto FIR
 When "LAS"     : Goto LAS
 When "FIN"     : Gosub FIN
Endcase
Return

################################################################################
#
# GSAISIE
#
################################################################################
$FIN
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

$OUVRE
If !clalev([F:ECH]) : Local File EXCEPTH  [ECH] : Endif
If !clalev([F:ECD]) : Local File EXCEPTD  [ECD] : Endif
If !clalev([F:ECV]) : Local File EXCEPTV  [ECV] : Endif
If !clalev([F:ECC]) : Local File EXCEPTC  [ECC] : Endif
If !clalev([F:RUB]) : Local File RUBRIQUE [RUB] : Endif
If !clalev([F:VRA]) : Local File VARIA    [VRA] : Endif
If !clalev([F:HRPOA]) : Local File POPULA   [HRPOA] : Endif
If !clalev([F:VEP]) : Local File VALEMP   [VEP] : Endif
#LIPET - 2017-05-23 - START
#** V7 : Waiting Time Mangement **#
#If !clalev([F:HRPEO]) : Local File HRPERIOD   [HRPEO] : Endif
#*!
If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR]:Endif
If !clalev([F:HRPEOD]) : Local File HRPEODET   [HRPEOD] : Endif
#LIPET - 2017-05-23 -END
If !clalev([F:ACC]) : Local File ACCES    [ACC] : Endif
Gosub OUVRE From WPDEFTABLE

Local Char MATRI([V]GLONEML), DEFILE(1), CRITERE(255)
Local Char FCY([V]GLONFCY), SRV([V]GLONSRV), PRF([V]GLONPRF)
Local Char TABECH(255)(0..)
#Local Char TABECH([V]GLONECH)(1+nbrecord([ECH]))
Local Date DATMAT
Local Char LESITE(GLONFCY)
Local Char CTR ([V]GLONHRCTR), CTRCRI([V]GLONEML+[V]GLONHRCTR+1+10)
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG : Endif
Return

#-------------------------------------------------------------------------------
$DEBUT
[L]DEFILE     ="D"
[M:VEX0]REFNUM=[L]PARAM(1)
If [L]PARAM(2)>"" : [M:VEX0]PYRDAT=[L]PARAM(2) : Affzo [VEX0]PYRDAT : Endif
If [L]PARAM(3)>"" : [M:VEX0]CTRNUM=[L]PARAM(3) : Affzo [VEX0]CTRNUM : Endif
If [L]PARAM(4)>"" : [M:VEX0]CTRDAT=[L]PARAM(4) : Affzo [VEX0]CTRDAT : Endif

[L]CRITERE="FLGPAY=2 & ENAFLG=2"
If [V]GUSRACS<>2
 [L]CRITERE-='& (CODACS="" | [ACC]CONSUL=2) & find(SRV,[V]GAUTSRV(1..[V]GNBSERV))'
Endif
If [V]GUSRFCY<>"\" & [V]GNBAUZ<>[V]GNBSITE
 [L]CRITERE-='& find(FCY,[V]GUSRFCY(1..[V]GNBAUZ))'
Endif
Link [ID] With [ACC]CODACC=[V]GUSER;CODACS As [LID] Where evalue([L]CRITERE)

If [M:VEX0]REFNUM>""
 Call LECTURE("EML",[M:VEX0]REFNUM,"") From CONTOBJ
 Call AM_REFNUM([M:VEX0]REFNUM)
 Affzo [VEX0] REFNUM
Endif

If [M:VEX0]REFNUM>"" & [M:VEX0]PYRDAT>[0/0/0] & [M:VEX0]CTRNUM>""
 Goto RECHERCHE
Else
 Raz [M:VEX1]
 Raz [M:VEX2]
 Raz [M:VEX3]
 For I=0 To 2
  [M:VEX0]TAB(I)=mess(184+I,10703,1) : # [Rubriques | Variables | Cumuls]
 Next
 Chgtfd [VEX1] [M:VEX0]TAB(0)
 Chgtfd [VEX2] [M:VEX0]TAB(1)
 Chgtfd [VEX3] [M:VEX0]TAB(2)
Endif
Return

#-------------------------------------------------------------------------------
$SETBOUT
If [M:VEX0]REFNUM="" : [L]CHBOU=ctrans([L]CHBOU,"<>09","") : Endif
[L]CHBOU +="="
[L]CHMEN +="R"+ctrans("ESD",[L]DEFILE,"")
[L]STADEF =[L]LBOUT(find("R",[L]CBOUT(1..[L]NBTEX)))
Return

################################################################################
#
# Evènements
#
################################################################################

$SUI
Case [L]DEFILE
When "E" : # Par matricule
 Read [LID]ID0>[M:VEX0]REFNUM
When "S" : # Par site/service
 Read [LID]ID2>[M:VEX0]FCY;[M:VEX0]SRV;[M:VEX0]REFNUM
When "D" : # Par date de paye
 LESITE = [M:VEX0]FCY
 #LIPET - 2017-05-23 - START
#** V7 : Waiting Time Mangement **#
# Call PERIO(LESITE,[M:VEX0]REFNUM) From SUBHRPEO
# Filter [HRPEO] Where find(FCY,"",LESITE)<>0 & PYRDAT>[M:VEX0]PYRDAT
#&      Order By Key CLE=PYRDAT;FCY Desc
# Read [HRPEO]CLE>[M:VEX0]PYRDAT;LESITE
# Filter [HRPEO]
#*!
If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR]:Endif
Filter [HRCTR] Where CTRNUM = [M:VEX0]CTRNUM
 Read [HRCTR] Last
 Call PERIO(LESITE,[M:VEX0]REFNUM) From SUBHRPEO
 Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD & PYRDAT>[M:VEX0]PYRDAT
&      Order By Key CLE= REFNUM;PYRDAT;PERCOD Desc
 Read [HRPEOD]CLE>[M:VEX0]PYRDAT;[F:HRCTR]PERCOD
 Filter [HRPEOD]
#LIPET - 2017-05-23 - END
Endcase
Goto SUIVPREC

#-------------------------------------------------------------------------------
$PRE
Case [L]DEFILE
When "E" : # Par matricule
 Read [LID]ID0<[M:VEX0]REFNUM
When "S" : # Par site/service
 Read [LID]ID2<[M:VEX0]FCY;[M:VEX0]SRV;[M:VEX0]REFNUM
When "D" : # Par date de paye
 LESITE = [M:VEX0]FCY
 #LIPET - 2017-05-23 - START
#** V7 : Waiting Time Mangement **#
# Call PERIO(LESITE,[M:VEX0]REFNUM) From SUBHRPEO
# Filter [HRPEO] Where find(FCY,"",LESITE)<>0 & PYRDAT<[M:VEX0]PYRDAT
#&      Order By Key CLE=PYRDAT Desc;FCY Desc
# Read [HRPEO]CLE>[M:VEX0]PYRDAT;LESITE
# Filter [HRPEO]
#*!
If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR]:Endif
Filter [HRCTR] Where CTRNUM = [M:VEX0]CTRNUM
 Read [HRCTR] Last
 Call PERIO(LESITE,[M:VEX0]REFNUM) From SUBHRPEO
 Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD & PYRDAT<[M:VEX0]PYRDAT
&      Order By Key CLE=PYRDAT Desc;PERCOD Desc
 Read [HRPEOD]CLE>[M:VEX0]PYRDAT;[F:HRCTR]PERCOD
 Filter [HRPEOD]
#LIPET - 2017-05-23 - END
Endcase
Goto SUIVPREC

#-------------------------------------------------------------------------------
$FIR
Case [L]DEFILE
When "E" : # Par matricule
 Read [LID]ID0 First
When "S" : # Par site/service
 Read [LID]ID2 First
When "D" : # Par date de paye
 LESITE = [M:VEX0]FCY
 #LIPET - 2017-05-23 - START
#** V7 : Waiting Time Mangement **#
# Call PERIO(LESITE,[M:VEX0]REFNUM) From SUBHRPEO
# Filter [HRPEO] Where find(FCY,"",LESITE)<>0 Order By Key CLE=PYRDAT;FCY Desc
# Read [HRPEO]CLE First
# Filter [HRPEO]
#*!
If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR]:Endif
Filter [HRCTR] Where CTRNUM = [M:VEX0]CTRNUM
 Read [HRCTR] Last
  Call PERIO(LESITE,[M:VEX0]REFNUM) From SUBHRPEO
  Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD Order By Key CLE=PYRDAT;PERCOD Desc
  Read [HRPEOD]CLE First
  Filter [HRPEOD]
#LIPET - 2017-05-23 - END
Endcase
Goto SUIVPREC

#-------------------------------------------------------------------------------
$LAS
Case [L]DEFILE
When "E" : # Par matricule
 Read [LID]ID0 Last
When "S" : # Par site/service
 Read [LID]ID2 Last
When "D" : # Par date de paye
 LESITE = [M:VEX0]FCY
 #LIPET - 2017-05-23 - START
#** V7 : Waiting Time Mangement **#
# Call PERIO(LESITE,[M:VEX0]REFNUM) From SUBHRPEO
# Filter [HRPEO] Where find(FCY,"",LESITE)<>0
#&      Order By Key CLE=PYRDAT Desc;FCY Desc
# Read [HRPEO]CLE First
# Filter [HRPEO]
#*!
If !clalev([F:HRCTR]) : Local File EMPLOCTR [HRCTR]:Endif
Filter [HRCTR] Where CTRNUM = [M:VEX0]CTRNUM
 Read [HRCTR] Last
  Call PERIO(LESITE,[M:VEX0]REFNUM) From SUBHRPEO
  Filter [HRPEOD] Where PERCOD=[F:HRCTR]PERCOD
&      Order By Key CLE=PYRDAT Desc;PERCOD Desc
  Read [HRPEOD]CLE First
  Filter [HRPEOD]
#LIPET - 2017-05-23 - END
Endcase
Goto SUIVPREC

################################################################################
#
# Routines
#
################################################################################

$SUIVPREC
If fstat
 [V]GMESSAGE=mess(11,100,1) : # Début/Fin de fichier
 [V]GERR    =1
 Return
Endif

If [L]DEFILE="D"
#LIPET - 2017-05-23 - START
#** V7 : Waiting Time Mangement **#
#[M:VEX0]PYRDAT=[F:HRPEO]PYRDAT
#*!
 [M:VEX0]PYRDAT=[F:HRPEOD]PYRDAT
#LIPET - 2017-05-23 - END
 Affzo [VEX0] PYRDAT
Else
 [M:VEX0]REFNUM=[F:ID]REFNUM
 Affzo [VEX0] REFNUM
 Call AM_REFNUM([M:VEX0]REFNUM)
Endif
Goto RECHERCHE

#-------------------------------------------------------------------------------
$RECHERCHE
[L]DATMAT=[M:VEX0]PYRDAT
[L]CTR=[M:VEX0]CTRNUM

If [L]MATRI<>[M:VEX0]REFNUM
 [L]MATRI=[M:VEX0]REFNUM
 Gosub LECEMP From WPDEFTABLE
Endif

[L]FCY=[F:HRCTR]ETRFCY : [L]PRF=[F:HRCTR]PROPRF : [L]SRV=[F:HRCTR]ETRSRV
[L]CTR = [F:HRCTR]CTRNUM

#**82073
[L]CTRCRI = [L]MATRI + "~" + [L]CTR +"~"+format$("D:YYYYMMDD",[M:VEX0]CTRDAT)

Call LECTURE("FCY",[L]FCY,"") From CONTOBJ
Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
GSOCIETE=[F:CPY]CPY
GCURLEG=[F:CPY]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif

Raz [M:VEX1], [M:VEX2], [M:VEX3], I

Link [ECH] With [HRPOA]POA1(1)~=[L]MATRI;POP As [LNK] Where [ECH]LEG=GCURLEG

Columns [LNK] ([ECH]COD, [ECH]CRI, [ECH]CTRCRI)

For [LNK]ECH0 Where find(FCY,"",[L]FCY)<>0 & find(PRF,"",[L]PRF)<>0
&                 & find(SRV,"",[L]SRV)<>0 & EMPSTR<=[L]MATRI
&                 & (EMPEND>=[L]MATRI | EMPEND="")
 If [F:ECH]CRI="" | evalue([F:ECH]CRI)
    #Ajout du controle sur les exceptions contrats
    If [F:ECH]CTRCRI(0) = "" or find([L]CTRCRI, [F:ECH]CTRCRI)
        [L]TABECH([L]I) = [F:ECH]COD
        [L]I += 1
    Endif
 Endif
Next
Columns [LNK]

If !I
 For I=0 To 2
  [M:VEX0]TAB(I)=mess(184+I,10703,1)-"= 0" : # [Rubriques | Variables | Cumuls]
 Next

Else
 nolign=0
 J     =dim([M:VEX1]COD)
 K     =1
 For [ECD]ECD0 Where LEG=GCURLEG & find(COD,[L]TABECH(0..I-1))<>0 & DATSTR<=[L]DATMAT
&                  & (DATEND>=[L]DATMAT | DATEND=[0/0/0])
  If nolign=J : K=2 : Break : Endif
  nolign  +=1
  [M:VEX1] =[F:ECD]
 Next
 [M:VEX1]NBRUB =nolign
 [M:VEX0]TAB(0)=mess(184,10703,1)-mid$("=>",K,1)-num$(nolign) : # Rubriques

 nolign=0
 J     =dim([M:VEX2]COD)
 K     =1
 For [ECV]ECV0 Where LEG=GCURLEG & find(COD,[L]TABECH(0..I-1))<>0 & DATSTR<=[L]DATMAT
&                  & (DATEND>=[L]DATMAT | DATEND=[0/0/0])
  If nolign=J : K=2 : Break : Endif
  nolign  +=1
  [M:VEX2] =[F:ECV]
  [M:VEX2]DATDEB(nolign-1) =[F:ECV]DATSTR
  [M:VEX2]DATFIN(nolign-1) =[F:ECV]DATEND
 Next
 [M:VEX2]NBVRA =nolign
 [M:VEX0]TAB(1)=mess(185,10703,1)-mid$("=>",K,1)-num$(nolign) : # Variables

 nolign=0
 J     =dim([M:VEX3]COD)
 K     =1
 For [ECC]ECC0 Where LEG=GCURLEG & find(COD,[L]TABECH(0..I-1))<>0 & DATSTR<=[L]DATMAT
&                  & (DATEND>=[L]DATMAT | DATEND=[0/0/0])
  If nolign=J : K=2 : Break : Endif
  nolign  +=1
  [M:VEX3] =[F:ECC]
 Next
 [M:VEX3]NBCUM =nolign
 [M:VEX0]TAB(2)=mess(186,10703,1)-mid$("=>",K,1)-num$(nolign) : # Cumuls
Endif

Chgtfd [VEX1] [M:VEX0]TAB(0)
Chgtfd [VEX2] [M:VEX0]TAB(1)
Chgtfd [VEX3] [M:VEX0]TAB(2)
Affzo [VEX1]
Affzo [VEX2]
Affzo [VEX3]
Return

################################################################################
#
# Etiquettes de l'écran VEPEXC0
#
################################################################################

########################################
Subprog AM_REFNUM(VALEUR)
Variable Char    VALEUR()

[M:VEX0]FCY   =[F:ID]FCY
[M:VEX0]SRV   =[F:ID]SRV
[M:VEX0]NAMSRN=[F:ID]NAM-[F:ID]SRN

Affzo [VEX0] NAMSRN

End

