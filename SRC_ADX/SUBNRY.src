#<AdxTL>@(#)6.0.0.0 $Revision$ Gestion objet NRY
Raz GPILOBJ
Call OBJET("NRY",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "RAZCRE"    : Gosub RAZCRE
 When "INICRE"    : Gosub INICRE
 When "INIMOD"    : Gosub INIMOD
 When "VERIF_MOD" : Gosub VERIF
 When "VERIF_CRE" : Gosub VERIF
 When Default
Endcase
Return

$OUVRE
If clalev([F:CPY])  = 0 : Local File COMPANY    [CPY]  : Endif
If clalev([F:GCM])  = 0 : Local File GACM       [GCM]  : Endif
If clalev([F:LED])  = 0 : Local File GLED       [LED]  : Endif
If clalev([F:COA])  = 0 : Local File GCOA       [COA]  : Endif
If clalev([F:PIT])  = 0 : Local File PIVOTS     [PIT] : Endif
Local Integer I
Return

$LIENS
Gosub LOAD_TAB
Return

$LOAD_TAB
For I=0 To dim([F:NRY]CPY)-1
 If [F:NRY]CPY(I)<>""
  [M]NBCPY = I+1
 Endif
Next I
For I=0 To dim([F:NRY]ACCROT)-1
 If [F:NRY]ACCROT(I)<>""
  [M]NBROT = I+1
 Endif
Next I
For I=0 To dim([F:NRY]ACC)-1
 If [F:NRY]ACC(I)<>""
  [M]NBACC = I+1
 Endif
Next I
If [M]NBCPY>1
 Effzo STRFCY, ENDFCY
 Grizo STRFCY, ENDFCY
Else
 Actzo STRFCY, ENDFCY
Endif
Call LECTURE("CPY",[M]CPY(0),"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
Call LECTURE("LED",[F:GCM]LED([M]LEDTYP-1),"") From CONTOBJ
[M]LED = [F:LED]LED
[M]COA = [F:LED]COA
[M]CUR = [F:GCM]CUR([M]LEDTYP-1)
Return

$RAZCRE
Read [PIT]PIT0 = "ENERGY"
If !fstat
 [M]CODPVT = [F:PIT]ID
 Affzo CODPVT
Endif
Return


$INICRE
$INIMOD
For I=[M:NRY1]NBCPY+1 To dim([F:NRY]CPY)-1
 Raz [F:NRY]CPY(I-1)
Next I
For I=[M:NRY1]NBROT+1 To dim([F:NRY]ACCROT)-1
 Raz [F:NRY]ACCROT(I-1)
Next I
For I=[M:NRY1]NBACC+1 To dim([F:NRY]ACC)-1
 Raz [F:NRY]ACC(I-1)
Next I
Return


$VERIF
If [M]NBACC=0 & [M]NBROT=0
 GMESSAGE=mess(234,107,1)
 GERR = 1 : OK = 0  : Return
Elsif [M]NBCPY=0
 GMESSAGE=mess(47,7779,1)
 GERR = 1 : OK = 0 : Return
Endif
Return

######################################################################################
## Etiquettes masque NRY1 - Interface ENERGY
######################################################################################
Subprog AM_CPYGRU(VALEUR)
Variable Char    VALEUR()
Local Integer OKSOC
Local Char    COMPANY(GLONCPY)
[M]NBCPY = 0
Raz [M]CPY, STRFCY, ENDFCY
Affzo
If VALEUR<>""
 If clalev([F:AGC])=0 : Local File AGRPCPY [AGC] : Endif
 Call CONTALLCPY(VALEUR) From CPTSUB
 If mkstat : End : Endif
 [M]NBCPY = 0
 For [AGC] Where GRP=VALEUR
  COMPANY= [F:AGC]CPY
  Gosub OKSOC
  If OKSOC
   Gosub CONTSOC
  Endif
  If OKSOC
   [M]CPY([M]NBCPY) = COMPANY
   [M]NBCPY += 1
  Endif
 Next
 If [M]NBCPY>1
  Effzo STRFCY, ENDFCY
  Grizo STRFCY, ENDFCY
 Else
  Actzo STRFCY, ENDFCY
 Endif
 Affzo LEDTYP
 Affzo 25
Else
 [M]LEDTYP = 2
 Affzo LEDTYP
Endif
End

$OKSOC
If [M]NBCPY=0
 Gosub DISPLAY_LEDTYP
 Call LECTURE("LED",[F:GCM]LED([M]LEDTYP-1),"") From CONTOBJ
 [M]LED = [F:LED]LED
 [M]COA = [F:LED]COA
 [M]CUR = [F:GCM]CUR([M]LEDTYP-1)
 OKSOC = 1
Else
 Call LECTURE("CPY",COMPANY,"") From CONTOBJ
 Call LEC_GCM([F:CPY]ACM) From CPTLEC
 Call LEC_LED([F:GCM]LED([M]LEDTYP-1)) From CPTLEC
 OKSOC = ([F:LED]LED=[M]LED) & ([F:GCM]CUR([M]LEDTYP-1)=[M]CUR)
Endif
Return

$DISPLAY_LEDTYP
Call LECTURE("CPY",COMPANY,"") From CONTOBJ
Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
[M]LEDTYP = [F:GCM]ANALEDTYP
Affzo LEDTYP
Return


Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
If [M]CPY(0)<>""
 Call LECTURE("CPY",[M]CPY(0),"") From CONTOBJ
 Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
 Call LEDTYP_CHOICE([M]CPY(0),3) From CPTDIV
Endif
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer I
Local Char    L_LED(GLONLED), L_CUR(GLONCUR)
For I=0 To [M]NBCPY-1
 Call LEC_CPY([M]CPY(I)) From CPTLEC
 Call LEC_GCM([F:CPY]ACM) From CPTLEC
 Call LEC_LED([F:GCM]LED(VALEUR-1)) From CPTLEC
 If I=0
  L_LED = [F:LED]LED : L_CUR = [F:GCM]CUR(VALEUR-1)
 Elsif [F:LED]LED<>L_LED or [F:GCM]CUR(VALEUR-1)<>L_CUR
  GMESSAGE = mess(113,103,1)
  mkstat = 2 : End
 Endif
Next
End

Subprog AM_LEDTYP(VALEUR)
Variable Integer VALEUR
If [M]CPY(0)<>""
 Call LEC_CPY([M]CPY(0)) From CPTLEC
 Call LEC_GCM([F:CPY]ACM) From CPTLEC
 Call LEC_LED([F:GCM]LED(VALEUR-1)) From CPTLEC
 [M]LED = [F:LED]LED : [M]COA = [F:LED]COA : [M]CUR = [F:GCM]CUR(VALEUR-1)
Endif
End

Subprog C_NBCPY
If status>=65 & status<=90
 Case status
  When 65, 68, 83 : # Annulation/Sup ligne
   Gosub SETNOL
   If NOL=0
    ## Deletion not possible
    GMESSAGE= mess(1,115,1)
    mkstat=2 :Endif
  Endcase
Endif
If [M]LED=""
 Call LEC_CPY([M]CPY(0)) From CPTLEC
 Call LEC_GCM([F:CPY]ACM) From CPTLEC
 Call LEC_LED([F:GCM]LED([M]LEDTYP-1)) From CPTLEC
 [M]LED = [F:LED]LED
 [M]COA = [F:LED]COA
Endif
End

Subprog APRES_NBCPY
If [M]NBCPY>2 | [M]NBCPY=2 & !find(status,65,68,83)
 Effzo STRFCY, ENDFCY
 Grizo STRFCY, ENDFCY
Else
 Actzo STRFCY, ENDFCY
Endif
End

Subprog AM_NBCPY
If find(status,65,68,83) & [M]NBCPY<=2
 Actzo STRFCY, ENDFCY
Else
 Effzo STRFCY, ENDFCY
 Grizo STRFCY, ENDFCY
Endif
End


Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Integer OKSOC
Local Char    COMPANY(GLONCPY)
Local Char    REFER(GLONLED)

Call UNICITE(VALEUR,[M]CPY) From OBJDIV
If mkstat : End : Endif

COMPANY = VALEUR
If nolign=1 & [M]NBCPY = 1 : [M]NBCPY = 0 : Endif
Gosub OKSOC
If nolign=1 & [M]NBCPY = 0 : [M]NBCPY = 1 : Endif
If !OKSOC
 If [F:LED]LED<>[M]LED
  # Incompatible ledger
  GMESSAGE = mess(82,103,1)
  mkstat = 2 : End
 Elsif [F:GCM]CUR([M]LEDTYP-1)<>[M]CUR
  # Incompatible currency
  GMESSAGE = mess(208,111,1)-mess([M]LEDTYP,2644,1)-":"-mess(90,103,1)
  mkstat = 2 : End
 Endif
Endif
Gosub CONTSOC
If !OKSOC
 # All Sites are not accessible in the Company
 GMESSAGE = mess(32,104,1)
 mkstat = 2 : End
Endif
End

$CONTSOC
If GUSRFCY(1)<>"\"
 Local Integer I
 Call LECTURE("CPY",COMPANY,"") From CONTOBJ
 For I=1 To GNBSITE
  If COMPANY=GSOCSITE(I) & !find(GSITE(I),GUSRFCY(1..GNBAUZ))
   OKSOC = 0 : Break
  Endif
 Next I
Endif
Return

Subprog C_STRFCY(VALEUR)
Variable Char VALEUR()
If VALEUR<>""
 Call LEC_FCY(VALEUR) From CPTLEC
 If [F:FCY]LEGCPY<>[M]CPY(0)
  GMESSAGE = mess(412,199,1)-[M]CPY(0)
  mkstat=2 : End
 Endif
Endif
End

Subprog C_ENDFCY(VALEUR)
Variable Char VALEUR()
If VALEUR<>""
 Call LEC_FCY(VALEUR) From CPTLEC
 If [F:FCY]LEGCPY<>[M]CPY(0)
  GMESSAGE = mess(412,199,1)-[M]CPY(0)
  mkstat=2 : End
 Endif
Endif
End

Subprog C_ACCROT(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]ACCROT) From OBJDIV
If mkstat : End : Endif
Call LEC_COA([M]COA) From CPTLEC
If vireblc(VALEUR,2)<>vireblc(format$([F:COA]ACCFMT,VALEUR),2)
 # Incorrect format
 GMESSAGE = mess(149,100,1)
 mkstat=2 : End
Endif
End

Subprog C_ACC(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]ACC) From OBJDIV
If mkstat : End : Endif
End


$SETNOL
Local Integer NOL
NOL = nolign-1
Return

Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR
If GBATCH & VALEUR=1
 GMESSAGE = mess(163,141,1)
 mkstat = 2 : End
Endif
End

Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 Raz [M]VOLFIL
 Grizo [M]VOLFIL
Else
 Actzo [M]VOLFIL
Endif
Affzo [M]VOLFIL
End

Subprog C_VOLFIL(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPEXP,VALEUR,[M]DRTWRK,E_TYPE_FOLDER,GMESSAGE)
End
