############################################################
# Traçabilité aval sur les relevés
# Une échéance peut avoir des échéances (distincts) : on cherche dans la table des lignes
#    Recherche des échéances :
Subprog FIND_TREE_AVAL_REL(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

  # FGR 13/01/2012 : X3SUIVI71278
  If !clalev([F:DUD]) Then Local File GACCDUDATE [DUD] : Endif
  # ---------------------
  If [M:PIV1]VCRTYPSEL = NUM_REL and [M:PIV1]VCRLINSEL > 0 Then
    Filter [DUD] Where [F:DUD]SOINUM = [F:PKW]VCRNUM and [F:DUD]LIG = [M:PIV1]VCRLINSEL
  Else
    Filter [DUD] Where [F:DUD]SOINUM = [F:PKW]VCRNUM
  Endif
  If rowcount([F:DUD]) > 0 Then
    For [F:DUD]
      NUM_F = [F:DUD]NUM
      NUM_L = [F:DUD]DUDLIG
      Gosub WRITE_PKW1_DUD
      WK = 1
    Next
  Endif
  Filter [DUD]
End

