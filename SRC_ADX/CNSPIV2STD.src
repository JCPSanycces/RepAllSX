End
############################################################
############################################################
# Traçabilité amont sur les devis
# Un devis peut avoir des affaires associées.
#    Recherche des affaires (distinctes) : on parcourt les affaires (pas le choix)
Subprog FIND_TREE_AMONT_SQH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

  # ---------------------
  If [F:PKW]VCRNUMCALC <> "" Then
    # Issue X3-70238 - 2018-03-28 by FGR : BEGIN
    #Read [F:OPP]OPP0=[F:PKW]VCRNUMCALC
    Read [F:PIM]PIM0=[F:PKW]VCRNUMCALC
    If fstat = [V]CST_AOK Then
      Read [F:OPP]OPP0=[F:PIM]OPPNUM
      If !fstat Then
        # Affaire
        Gosub WRITE_PKW1_PJT
        WK = 1
      Endif
    Endif
    # Issue X3-70238 - 2018-03-28 by FGR : END
  Endif
End

############################################################
# Traçabilité amont sur les livraisons
# Une livraison peut avoir soit des commandes, soit des demandes, soit des
# bons de préparation, soit des commandes ouvertes associés.
# 1. Recherche des demandes (distinctes) : on parcourt les lignes de la livraison
# 2. Recherche des bons de préparation (distinctes) : on parcourt les lignes de la livraison
# 3. Recherche des commandes (distinctes) : on parcourt les lignes de la livraison
Subprog FIND_TREE_AMONT_SDH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char PRH_F(GLONPRH)
Local Integer PRH_L
Local Char SOH_F(GLONSOH)
Local Integer SOH_L

  If !clalev([F:SDD]) Then Local File SDELIVERYD [SDD] : Endif
  # -----------------------
  # On recherche tous les bons prépa distincts associés à la livraison en interrogeant la table des livraisons
  If [M:PIV1]VCRTYPSEL = NUM_SDH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SDD] Where SDHNUM=[F:PKW]VCRNUM and SDDLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:SDD] Where SDHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:SDD]) > 0 Then
    Raz PRH_F
    For [F:SDD]
      If [F:SDD]PRHNUM <> "" Then
        PRH_F = [F:SDD]PRHNUM
        PRH_L = [F:SDD]PRELIN
        If func CONSPITOOLS.VERIF_LINE([F:SDD]SDDLIN, NUM_SDH) = G_OUI Then
          # Pour chacun de ces bons de préparation, on récupère les infos
          Read [F:PRH]PRH0=PRH_F
          If !fstat Then
            # Bon prépa
            Gosub WRITE_PKW1_PRH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  # ---------------------
  # Recherche des demandes de livraison (commandes ouvertes) ou commandes
  If rowcount([F:SDD]) > 0 Then
    Raz SOH_F
    For [F:SDD]
      If [F:SDD]SOHNUM <> "" Then
        SOH_F = [F:SDD]SOHNUM
        SOH_L = [F:SDD]SOPLIN
        # Pour chacune de ces demandes, on récupère les infos
        If func CONSPITOOLS.VERIF_LINE([F:SDD]SDDLIN, NUM_SDH) = G_OUI Then
          Read [F:SOH]SOH0=SOH_F
          If !fstat Then
            If [F:SOH]SOHCAT = 4 Then
              # Commande ouverte
              Read [F:SOC]SOC0=SOH_F
              If !fstat Then
                Gosub WRITE_PKW1_SOC
                WK = 1
              Endif
            Else
              # Commande
              Gosub WRITE_PKW1_SOH
              WK = 1
            Endif
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:SDD]
End

############################################################
# Traçabilité amont sur les retours
# Un retour peut avoir des livraisons associées.
#    Recherche des livraisons (distinctes) : on parcourt les lignes du retour.
Subprog FIND_TREE_AMONT_SRH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char SDH_F(GLONSDH)
Local Integer SDH_L
Local Integer OK_SDH

  If !clalev([F:SRD]) Then Local File SRETURND [SRD] Endif
  # -----------------------
  # Recherche d'une livraison associée au retour
  If [F:PKW]VCRNUMCALC = [F:PKW]VCRNUM Then
    Link [F:SRD] With [F:SRH]SRH0=SRHNUM As [SR] Where [F:SRD]SRHNUM=[F:PKW]VCRNUM
  Else
    Link [F:SRD] With [F:SRH]SRH0=SRHNUM As [SR] Where [F:SRD]SDHNUM=[F:PKW]VCRNUMCALC
  Endif
  If [M:PIV1]VCRTYPSEL = NUM_SRH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SR] Where [F:SRD]SRDLIN=[M:PIV1]VCRLINSEL
  Endif
  If rowcount([F:SR]) > 0 Then
    # Livraison
    Raz SDH_F
    For [F:SR]
      If [F:SRD]SDHNUM <> "" Then
        SDH_F = [F:SRD]SDHNUM
        SDH_L = [F:SRD]SDDLIN
        OK_SDH = G_OUI
        If [F:PKW]VCRNUMCALC = [F:PKW]VCRNUM Then
          OK_SDH = func CONSPITOOLS.VERIF_LINE([F:SRD]SRDLIN, NUM_SRH)
        Else
          OK_SDH = func CONSPITOOLS.VERIF_LINE([F:SRD]SDDLIN, NUM_SDH)
        Endif
        If OK_SDH = G_OUI Then
          # Pour chacune de ces livraisons, on récupère les infos
          Read [F:SDH]SDH0=SDH_F
          If !fstat Then
            Gosub WRITE_PKW1_SDH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:SR]
End

############################################################
# Traçabilité amont sur les factures :
# Une facture peut avoir soit des livraisons, soit des commandes associées.
# 1. Recherche des livraisons (distinctes) : on parcourt les lignes de facture
# 2. Recherche des commandes (distinctes) : on parcourt les lignes de la facture
# 2. Recherche des commandes ouvertes (distinctes) : on parcourt les lignes de la commande ouverte
Subprog FIND_TREE_AMONT_SIH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char SDH_F(GLONSDH)
Local Integer SDH_L
Local Char SOH_F(GLONSOH)
Local Integer SOH_L
Local Char SQH_F(GLONSDH)                                       # FGR 07/08/2014 : X3SUIVI102004
Local Integer SQH_L                                             # FGR 07/08/2014 : X3SUIVI102004
Local Char SRE_F(GLONSRE)                                       # FGR 08/08/2014 : X3SUIVI102007
Local Char CON_F(GLONCON)                                       # FGR 08/08/2014 : X3SUIVI102007

  If !clalev([F:SID]) Then Local File SINVOICED [SID] : Endif
  If !clalev([F:SIV]) Then Local File SINVOICEV [SIV] : Endif   # FGR 07/08/2014 : X3SUIVI102004
  If !clalev([F:SOC]) Then Local File SORDERC [SOC] : Endif
  # -----------------------
  # On recherche toutes les livraisons distinctes associées à la facture en parcourant les lignes de la facture
  If [M:PIV1]VCRTYPSEL = NUM_SIH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SID] Where [F:SID]NUM=[F:PKW]VCRNUM and [F:SID]SIDLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:SID] Where [F:SID]NUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:SID]) > 0 Then
    Raz SDH_F
    For [F:SID]
      If [F:SID]SDHNUM <> "" Then
        SDH_F = [F:SID]SDHNUM
        SDH_L = [F:SID]SDDLIN
        If func CONSPITOOLS.VERIF_LINE([F:SID]SIDLIN, NUM_SIH) = G_OUI Then
          # Pour chacune de ces livraisons, on récupère les infos
          Read [F:SDH]SDH0=SDH_F
          If !fstat Then
            # Livraison
            Gosub WRITE_PKW1_SDH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  # ---------------------
  # Recherche des commandes ou commandes ouvertes, on recherche toutes les commandes distinctes associées à la facture
  If rowcount([F:SID]) > 0 Then
    Raz SOH_F
    For [F:SID]
      If [F:SID]SOHNUM <> "" Then
        SOH_F = [F:SID]SOHNUM
        SOH_L = [F:SID]SOPLIN
        If func CONSPITOOLS.VERIF_LINE([F:SID]SIDLIN, NUM_SIH) = G_OUI Then
          # Pour chacune de ces commandes, on récupère les infos
          Read [F:SOH]SOH0=SOH_F
          If !fstat Then
            If [F:SOH]SOHCAT = 4 Then
              # Commande ouverte
              Read [F:SOC]SOC0=SOH_F
              If !fstat Then
                Gosub WRITE_PKW1_SOC
                WK = 1
              Endif
            Else
              # Commande
              Gosub WRITE_PKW1_SOH
              WK = 1
            Endif
          Endif
        Endif
      Endif
    Next
  Endif
  # ---------------------
  # FGR 07/08/2014 : X3SUIVI102004 (début) : Pour les proforma, l'origine peut être un devis.
  If rowcount([F:SID]) > 0 Then
    If [F:SIV]NUM <> [F:PKW]VCRNUM Then
      Read [SIV]SIV0=[F:PKW]VCRNUM
    Endif
    If [F:SIV]INVTYP = 5 and [F:SIV]SIHORI = 5 Then
      # Si c'est une facture pro-forma qui a un devis pour origine
      SQH_F = [F:SIV]SIHORINUM
      SQH_L = 0
      If func CONSPITOOLS.VERIF_LINE([F:SID]SIDLIN, NUM_SIH) = G_OUI Then
        If [F:SIV]SIHORINUM <> "" Then
          Read [F:SQH]SQH0=SQH_F
          If !fstat Then
            Gosub WRITE_PKW1_SQH
            WK = 1
          Endif
        Endif
      Endif
    Endif
  Endif
  # FGR 07/08/2014 : X3SUIVI102004 (fin)
  # ---------------------
  # FGR 08/07/2014 : X3SUIVI102007 (début)
  If rowcount([F:SID]) > 0 Then
    Raz SRE_F
    For [F:SID]
      If [F:SID]SRENUM <> "" Then
        SRE_F = [F:SID]SRENUM
        If func CONSPITOOLS.VERIF_LINE([F:SID]SIDLIN, NUM_SIH) = G_OUI Then
          # Pour chacune de ces commandes, on récupère les infos
          Read [F:SRE]SRE0=SRE_F
          If !fstat Then
            # Demande de service
            Gosub WRITE_PKW1_SRE
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  # ---------------------
  If rowcount([F:SID]) > 0 Then
    Raz CON_F
    For [F:SID]
      If [F:SID]CONNUM <> "" Then
        CON_F = [F:SID]CONNUM
        If func CONSPITOOLS.VERIF_LINE([F:SID]SIDLIN, NUM_SIH) = G_OUI Then
          # Pour chacune de ces commandes, on récupère les infos
          Read [F:CON]CON0=CON_F
          If !fstat Then
            # Contrat de service
            Gosub WRITE_PKW1_CON
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  # FGR 08/07/2014 : X3SUIVI102007 (fin)
  # ---------------------
  Filter [F:SID]
End

############################################################
# Traçabilité amont sur les avoirs
# Un avoir peut avoir soit des factures, soit des retours associés.
# 1. Recherche des factures (distinctes) : on parcourt la table des factures.
# 2. Recherche des retours (distincts) : on parcourt les lignes de retour (pas le choix)
Subprog FIND_TREE_AMONT_SIV(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char SIH_F(GLONSIH)
Local Char SRH_F(GLONSRH)

  If !clalev([F:SID]) Then Local File SINVOICED [SID] : Endif
  If !clalev([F:SIH]) Then Local File SINVOICE [SIH] : Endif
  # -----------------------
  # Recherche d'une facture associée à l'avoir
  # FGR 30/01/2014 : X3SUIVI96050 (début)
  #  Filter [F:SIH] Where NUM=[F:PKW]VCRNUMCALC and (INVTYP=1 or INVTYP=5)
  #  If rowcount([F:SIH]) > 0 Then
  #    Raz SIH_F
  #    For [F:SIH]
  #      # Facture
  #      If [F:SIH]NUM <> "" and !find([F:SIH]NUM, SIH_F) Then
  #        SIH_F = [F:SIH]NUM
  #        Gosub WRITE_PKW1_SIH
  #        WK = 1
  #      Endif
  #    Next
  #  Endif
  #  Filter [F:SIH]
  For [F:SID] Where [F:SID]NUM = [F:PKW]VCRNUM
    Filter [F:SIH] Where NUM=[F:SID]SIHORINUM and (INVTYP=1 or INVTYP=5)
    If rowcount([F:SIH]) > 0 Then
      Raz SIH_F
      For [F:SIH]
        # Facture
        If [F:SIH]NUM <> "" and !find([F:SIH]NUM, SIH_F) Then
          SIH_F = [F:SIH]NUM
          Gosub WRITE_PKW1_SIH
          WK = 1
        Endif
      Next
    Endif
    Filter [F:SIH]
  Next
  # FGR 30/01/2014 : X3SUIVI96050 (début)
  # ---------------------
  # Recherche d'un retour
  If [F:PKW]VCRNUMCALC <> "" Then
    If [M:PIV1]VCRTYPSEL = NUM_SIV and [M:PIV1]VCRLINSEL > 0 Then
      Link [F:SRH] With [F:SID]SID5=SRHNUM As [SR] Where [F:SID]NUM=[F:PKW]VCRNUM and [F:SID]SIDLIN=[M:PIV1]VCRLINSEL
    Else
      Link [F:SRH] With [F:SID]SID5=SRHNUM As [SR] Where [F:SID]NUM=[F:PKW]VCRNUM
    Endif
    If rowcount([F:SR]) > 0 Then
      # Retour
      Raz SRH_F
      For [SR]
        If [F:SRH]SRHNUM <> "" and !find([F:SRH]SRHNUM, SRH_F) Then
          SRH_F = [F:SRH]SRHNUM
          If func CONSPITOOLS.VERIF_LINE([F:SID]SIDLIN, NUM_SIV) = G_OUI Then
            Gosub WRITE_PKW1_SRH
            WK = 1
          Endif
        Endif
      Next
    Endif
  Endif
End

############################################################
# Traçabilité amont sur les commandes
# Une commande peut avoir soit des devis, soit des affaires associées.
# 1. Recherche des devis (distincts) : on parcourt les lignes de la commande
# 2. Recherche des affaires (distinctes) : on interroge la table des affaires (pas le choix)
Subprog FIND_TREE_AMONT_SOH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char SQH_F(GLONSQH)
Local Integer SQH_L

  If !clalev([F:SOP]) Then Local File SORDERP [SOP] : Endif
  # -----------------------
  # On recherche tous les devis distincts associées à la commande en parcourant les lignes de la commande
  If [M:PIV1]VCRTYPSEL = NUM_SOH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SOP] Where SOHNUM=[F:PKW]VCRNUM and SOPLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:SOP] Where SOHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:SOP]) > 0 Then
    Raz SQH_F
    For [F:SOP]
      If [F:SOP]SQHNUM <> "" Then
        SQH_F = [F:SOP]SQHNUM
        SQH_L = [F:SOP]SQDLIN
        If func CONSPITOOLS.VERIF_LINE([F:SOP]SOPLIN, NUM_SOH) = G_OUI Then
          # Pour chacun de ces devis, on récupère les infos
          Read [F:SQH]SQH0=SQH_F
          If !fstat Then
            # Devis
            Gosub WRITE_PKW1_SQH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:SOP]
  # ---------------------
  # Recherche d'une affaire
  If [F:PKW]VCRNUMCALC <> "" Then
    # Issue X3-70238 - 2018-03-28 by FGR : BEGIN
    #Read [F:OPP]OPP0=[F:PKW]VCRNUMCALC
    Read [F:PIM]PIM0=[F:PKW]VCRNUMCALC
    If fstat = [V]CST_AOK Then
      Read [F:OPP]OPP0=[F:PIM]OPPNUM
      If !fstat Then
        # Affaire
        Gosub WRITE_PKW1_PJT
        WK = 1
      Endif
    Endif
    # Issue X3-70238 - 2018-03-28 by FGR : END
  Endif
End

############################################################
# Traçabilité amont sur les demandes de livraison
#   ==> Pas de traçabilité amont pour les demandes de livraison
Subprog FIND_TREE_AMONT_SOC(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

End

############################################################
# Traçabilité amont sur les bons de préparation
# Un bon prépa peut avoir soit des commandes (ouvertes ou non), soit des listes de prépa associées.
# 1. Recherche des listes de préparation (distinctes) : on interroge les lignes
#    des bons de préparation.
# 2. Recherche des commandes (distinctes) : on interroge les lignes des bons
# 3. Recherche des commandes ouvertes (distinctes) : on interroge les lignes des bons
Subprog FIND_TREE_AMONT_PRH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char PRL_F(GLONPRL)
Local Integer PRL_L
Local Char SOH_F(GLONSOH)
Local Integer SOH_L

  If !clalev([F:PRE]) Then Local File STOPRED [PRE] : Endif
  If !clalev([F:SOC]) Then Local File SORDERC [SOC] : Endif
  # -----------------------
  # Recherche des liste de prépa associées au bon
  If [M:PIV1]VCRTYPSEL = NUM_PRH and [M:PIV1]VCRLINSEL > 0 Then
    Link [F:PRL] With [F:PRH]PRH0=PRHNUM, [F:PRE]PRE0=PRHNUM As [PR] Where PRHNUM=[F:PKW]VCRNUM and [F:PRE]PRELIN=[M:PIV1]VCRLINSEL
  Else
    Link [F:PRL] With [F:PRH]PRH0=PRHNUM, [F:PRE]PRE0=PRHNUM As [PR] Where PRHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PR]) > 0 Then
    Raz PRL_F
    For [F:PR]
      # Liste prépa
      If [F:PRL]PRLNUM <> "" Then
        PRL_F = [F:PRL]PRLNUM
        PRL_L = [F:PRL]PRLSEQ
        If func CONSPITOOLS.VERIF_LINE([F:PRE]PRELIN, NUM_PRH) = G_OUI Then
          Read [F:PRL]PRL0=PRL_F;PRL_L
          If !fstat Then
            Gosub WRITE_PKW1_PRL
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  # ---------------------
  # Recherche des commandes (ouvertes ou non) distinctes associées au bon
  If [M:PIV1]VCRTYPSEL = NUM_PRH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PRE] Where PRHNUM=[F:PKW]VCRNUM and PRELIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PRE] Where PRHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PRE]) > 0 Then
    Raz SOH_F
    For [F:PRE]
      If [F:PRE]ORINUM <> "" & find([F:PRE]ORITYP,1,2) Then
        SOH_F = [F:PRE]ORINUM
        SOH_L = [F:PRE]ORILIN
        If func CONSPITOOLS.VERIF_LINE([F:PRE]PRELIN, NUM_PRH) = G_OUI Then
          # Pour chacune de ces commandes, on récupère les infos
          Read [F:SOH]SOH0=SOH_F
          If !fstat Then
            If [F:SOH]SOHCAT = 4 Then
              # Commande ouverte
              Read [F:SOC]SOC0=SOH_F
              If !fstat Then
                Gosub WRITE_PKW1_SOC
                WK = 1
              Endif
            Else
              # Commande
              Gosub WRITE_PKW1_SOH
              WK = 1
            Endif
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PRE]
End

############################################################
# Traçabilité amont sur les listes de préparation
# Une liste de prépa peut avoir des commandes
#    Recherche des commandes ouvertes ou non (distinctes) : on parcourt la liste de prépa.
Subprog FIND_TREE_AMONT_PRL(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Integer OK_SOH
Local Char SOH_F(GLONSOH)
Local Integer SOH_L

  If !clalev([F:PRE]) Then Local File STOPRED [PRE] : Endif
  # -----------------------
  # On recherche toutes les commandes distinctes associées à la liste en parcourant la liste de préparation
  Filter [F:PRL] Where PRLNUM=[F:PKW]VCRNUM
  If rowcount([F:PRL]) > 0 Then
    Raz SOH_F
    For [F:PRL]
      If [F:PRL]ORINUM <> "" and !find([F:PRL]ORINUM, SOH_F) Then
        SOH_F = [F:PRL]ORINUM
        SOH_L = [F:PRL]ORILIN
        OK_SOH = G_OUI
        # Si la pièce d'origine est un bon prépa, on filtre les commandes relatives à ce bon prépa.
        If [F:PKW]VCRTYPORI = NUM_PRH Then
          Filter [F:PRE] Where ORINUM=SOH_F and PRHNUM=[F:PKW]VCRNUMORI
          If rowcount([F:PRE]) = 0 Then
            OK_SOH = G_NON
          Endif
          Filter [F:PRE]
        Endif
        # Pour chacune de ces commandes, on récupère les infos
        If OK_SOH = G_OUI Then
          Read [F:SOH]SOH0=SOH_F
          If !fstat Then
            If [F:SOH]SOHCAT = 4 Then
              # Commande ouverte
              Read [F:SOC]SOC0=SOH_F
              If !fstat Then
                Gosub WRITE_PKW1_SOC
                WK = 1
              Endif
            Else
              # Commande
              Gosub WRITE_PKW1_SOH
              WK = 1
            Endif
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PRL]
End

############################################################
# Traçabilité amont sur les échéances
# Une échéance peut avoir des factures
#    Recherche des commandes ouvertes ou non (distinctes) : on parcourt la liste de prépa.
Subprog FIND_TREE_AMONT_DUD(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char NUM_F(GLONVCR)
Local Integer NUM_L
Local Char SOINUM_F(GLONVCR)
Local Integer SOINUM_L
Local Char PIV_F(GLONVCR)
Local Integer PIV_L

  # --------------------------------------------------------------------------------------------------------
  # FGR 09/02/2012 : X3SUIVI71269
  # L'amont de DUD peut être soit dans les ventes, soit dans les achats. Obligé de les traiter en même temps
  # --------------------------------------------------------------------------------------------------------
  If !clalev([F:DUD]) Then Local File GACCDUDATE [DUD] : Endif
  If GMODU(6) = 2 Then
    # Module "Achats"
    If !clalev([F:POH]) Then Local File PORDER [POH] : Endif
    If !clalev([F:PIH]) Then Local File PINVOICE [PIH] : Endif
    If !clalev([F:PID]) Then Local File PINVOICED [PID] : Endif
  Endif
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  Filter [DUD] Where NUMDUD=[F:PKW]VCRNUM
  If rowcount([F:DUD]) > 0 Then
    For [F:DUD]
      If [F:DUD]BPRTYP = 1 Then
        # --------------------------------------
        # Client
        If [F:DUD]SOINUM = "" Then
          # Cas facture ou commande
          NUM_F = [F:DUD]NUM
          NUM_L = [F:DUD]LIG
          If [F:DUD]TYP = "*SO" Then
            Read [F:SOH]SOH0=[F:DUD]NUM
            If [F:SOH]SOHCAT = 4 Then
              # Commande ouverte
              Read [F:SOC]SOC0=[F:DUD]NUM
              If !fstat Then
                Gosub WRITE_PKW1_SOC
                WK = 1
              Endif
            Else
              # Commande
              Gosub WRITE_PKW1_SOH
              WK = 1
            Endif
          Else
            # Factures
            Read [F:SIH]SIH0=[F:DUD]NUM
            Gosub WRITE_PKW1_SIH
          Endif
        Else
          # Cas du relevé
          SOINUM_F = [F:DUD]SOINUM
          NUM_L = [F:DUD]DUDLIG
          Read [F:SOI]SOI0=SOINUM_F  # FGR 27/05/2013 : X3SUIVI90113
          Gosub WRITE_PKW1_REL
          WK = 1
        Endif
        # --------------------------------------
      Else
        # --------------------------------------
        # Fournisseur
        If [F:DUD]TYP = "*PO" Then
          # Cas commande (acompte)
          Read [POH]POH0=[F:PKW]VCRNUMCALC
          If fstat=0 Then
            If [F:POH]POHTYP = 2 Then
              # Commande ouverte
              Read [F:POC]POC0=[F:POH]NUM
              If !fstat Then
                Gosub WRITE_PKW1_POC From CNSPIA2STD
                WK = 1
              Endif
            Elsif [F:POH]POHTYP = 1 Then
              # Commande
              Gosub WRITE_PKW1_POH From CNSPIA2STD
              WK = 1
            Endif
          Endif
        Else
          # Cas facture
          Link [F:PID] With [F:PIH]PIH0~=NUM As [PV] Where [F:PIH]ACCNUM=[F:PKW]ACCNUM
          If rowcount([F:PV])>0 Then
            Raz PIV_F
            For [F:PV]
              # Avoir
              If [F:PID]NUM <> "" Then
                PIV_F = [F:PID]NUM
                PIV_L = [F:PID]PIDLIN
                If func CONSPITOOLS.VERIF_LINE([F:PID]PIDLIN, NUM_PIH) = G_OUI Then
                  If !fstat Then
                    If [F:PIH]INVTYP = 2 Then
                      Gosub WRITE_PKW1_PIV From CNSPIA2STD
                    Else
                      Gosub WRITE_PKW1_PIH From CNSPIA2STD
                    Endif
                    WK = 1
                  Endif
                Endif
              Endif
            Next
          Endif
        Endif
        # --------------------------------------
      Endif
    Next
  Endif
  Filter [DUD]
End

