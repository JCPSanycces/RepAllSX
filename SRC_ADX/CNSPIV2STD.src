############################################################
# Traçabilité aval sur les contrat de service
Subprog FIND_TREE_AVAL_CON(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char SIH_F(GLONSIH)
Local Integer SIH_L
Local Char SRENUM_F(GLONSIH)

  # FGR 13/01/2012 : X3SUIVI71278
  # ---------------------
  If !clalev([F:SID]) Then Local File SINVOICED [SID] : Endif
  If !clalev([F:SRE]) Then Local File SERREQUEST [SRE]  : Endif
  # ---------------------
  # Recherche des factures
  Filter [SID] Where [F:SID]CONNUM = [F:PKW]VCRNUM
  If rowcount([F:SID]) > 0 Then
    For [F:SID]
      SIH_F = [F:SID]NUM
      SIH_L = [F:SID]SIDLIN
      Read [F:SIH]SIH0=SIH_F
      Gosub WRITE_PKW1_SIH
      WK = 1
    Next
  Endif
  Filter [SID]
  # ---------------------
  # Recherche des demandes de service
  Filter [SRE] Where ([F:SRE]OVRCOV = 1 or [F:SRE]OVRCOV = 2 or [F:SRE]OVRCOV = 4) and [F:SRE]CONSPT = [F:PKW]VCRNUM
  If rowcount([F:SRE]) > 0 Then
    For [F:SRE]
      SRENUM_F = [F:SRE]SRENUM
      Gosub WRITE_PKW1_SRE
      WK = 1
    Next
  Endif
  Filter [SRE]
  # ---------------------
  # Recherche des tâches
  Call FIND_TSK_AVAL_FROM("HDK3", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # Recherche des appels
  Call FIND_CLL_AVAL_FROM("HDK3", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # Recherche des rendez-vous
  Call FIND_BAP_AVAL_FROM("HDK3", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
End

############################################################
# Traçabilité aval sur les parc client
Subprog FIND_TREE_AVAL_MAC(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

  # FGR 13/01/2012 : X3SUIVI71278
  # ---------------------
  If !clalev([F:SRM]) Then Local File SREMAC [SRM] : Endif
  # ---------------------
  # Recherche des demandes de service
  Filter [SRM] Where [F:SRM]MACNUM = [F:PKW]VCRNUM
  If rowcount([F:SRM]) > 0 Then
    For [F:SRM]
      Read [F:SRE]SRE0=[F:SRM]SRENUM
      Gosub WRITE_PKW1_SRE
      WK = 1
    Next
  Endif
  Filter [SRM]
  # ---------------------
  # Recherche des tâches
  Call FIND_TSK_AVAL_FROM("HDK4", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # Recherche des appels
  Call FIND_CLL_AVAL_FROM("HDK4", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # Recherche des rendez-vous
  Call FIND_BAP_AVAL_FROM("HDK4", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
End

############################################################
# Traçabilité aval sur les demandes de service
Subprog FIND_TREE_AVAL_SRE(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char SIH_F(GLONSIH)
Local Integer SIH_L
Local Char SOH_F(GLONSOH)
Local Integer SOH_L
Local Char NUM_F(GLONVCR)
Local Char SOL_F(GLONVCR)

  # FGR 13/01/2012 : X3SUIVI71278
  # ---------------------
  If !clalev([F:SID]) Then Local File SINVOICED [SID] : Endif
  # ---------------------
  # Recherche des interventions
  Filter [ITN] Where [F:ITN]SRVDEMNUM = [F:PKW]VCRNUM
  If rowcount([F:ITN]) > 0 Then
    For [F:ITN]
      NUM_F = [F:ITN]NUM
      Gosub WRITE_PKW1_ITN
      WK = 1
    Next
  Endif
  Filter [ITN]
  # ---------------------
  # Recherche des commande (cas d'une demande de service couverte par une commande)
  Read [F:SRE]SRE0=[F:PKW]VCRNUM
  If [F:SRE]OVRCOV = 5 Then
    Read [F:SOH]SOH0=[F:SRE]SRECOVNUM
    SOH_F = [F:SOH]SOHNUM
    SOH_L = 0
    Gosub WRITE_PKW1_SOH
    WK = 1
  Endif
  # ---------------------
  # Recherche des solutions
  Filter [SOL] Where [F:SOL]SRENUM = [F:PKW]VCRNUM
  If rowcount([F:SOL]) > 0 Then
    For [F:SOL]
      SOL_F = [F:SOL]NUM
      Gosub WRITE_PKW1_SOL
      WK = 1
    Next
  Endif
  Filter [SID]
  # ---------------------
  # Recherche des factures
  Filter [SID] Where [F:SID]SRENUM = [F:PKW]VCRNUM
  If rowcount([F:SID]) > 0 Then
    For [F:SID]
      SIH_F = [F:SID]NUM
      SIH_L = [F:SID]SIDLIN
      Read [F:SIH]SIH0=SIH_F
      Gosub WRITE_PKW1_SIH
      WK = 1
    Next
  Endif
  Filter [SID]
  # ---------------------
  # Recherche des tâches
  Call FIND_TSK_AVAL_FROM("HDK1", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # Recherche des appels
  Call FIND_CLL_AVAL_FROM("HDK1", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # Recherche des rendez-vous
  Call FIND_BAP_AVAL_FROM("HDK1", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
End

