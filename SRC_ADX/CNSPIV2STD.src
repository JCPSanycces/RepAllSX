############################################################
# Traçabilité aval sur les devis
# Un devis peut avoir des commandes associées.
#    Recherche des commandes (distinctes) : on parcourt les lignes du devis.
#    Si aucune commande n'est fournie dans les lignes d'avoir, on prend la commande
#    fournie dans l'en-tête d'avoir
Subprog FIND_TREE_AVAL_SQH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Integer IS_ONE_MINI
Local Char SOH_F(GLONSOH)
Local Integer SOH_L
Local Char SIH_F(GLONSIH)                                       # FGR 07/08/2014 : X3SUIVI102004
Local Integer SIH_L                                             # FGR 07/08/2014 : X3SUIVI102004

  If !clalev([F:SOP]) Then Local File SORDERP [SOP] : Endif
  If !clalev([F:SIV]) Then Local File SINVOICEV [SIV] : Endif   # FGR 07/08/2014 : X3SUIVI102004
  If !clalev([F:SID]) Then Local File SINVOICED [SID] : Endif   # FGR 07/08/2014 : X3SUIVI102004
  # ---------------------
  If [M:PIV1]VCRTYPSEL = NUM_SQH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SOP] Where SQHNUM=[F:PKW]VCRNUM and SQDLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:SOP] Where SQHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:SOP]) > 0 Then
    IS_ONE_MINI = G_NON
    Raz SOH_F
    For [F:SOP]
      If [F:SOP]SOHNUM <> "" Then
        IS_ONE_MINI = G_OUI
        SOH_F = [F:SOP]SOHNUM
        SOH_L = [F:SOP]SOPLIN
        If func CONSPITOOLS.VERIF_LINE([F:SOP]SQDLIN, NUM_SQH) = G_OUI Then
          # Pour chacune de ces commandes, on récupère les infos
          Read [F:SOH]SOH0=SOH_F
          If !fstat and [F:SOH]SOHCAT <> 4 Then
            # Commande
            Gosub WRITE_PKW1_SOH
            WK = 1
          Endif
        Endif
      Endif
    Next
    If IS_ONE_MINI = G_OUI and [F:PKW]VCRNUMCALC <> "" Then
      # Si pas de commande trouvée dans les lignes de devis, on prend directement celle du devis
      Read [F:SOH]SOH0=[F:PKW]VCRNUMCALC
      If !fstat Then
        # Commande
        Gosub WRITE_PKW1_SOH
        WK = 1
      Endif
    Endif
  Endif
  Filter [F:SOP]
  # ---------------------
  # FGR 07/08/2014 : X3SUIVI102004 (début) : Pour les proforma, l'origine peut être un devis.
  Link [F:SID] With [F:SIV]SIV0=[F:SID]NUM As [SI] Where [F:SIV]SIHORINUM=[F:PKW]VCRNUM and [F:SIV]INVTYP = 5 and [F:SIV]SIHORI = 5
  If rowcount([F:SI]) > 0 Then
    Raz SIH_F
    For [F:SI]
      If [F:SID]NUM <> "" Then
        SIH_F = [F:SID]NUM
        SIH_L = [F:SID]SIDLIN
        # Facture
        If func CONSPITOOLS.VERIF_LINE([F:SID]SDDLIN, NUM_SDH) = G_OUI Then
          Read [F:SIH]SIH0=SIH_F
          If !fstat Then
            Gosub WRITE_PKW1_SIH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  # FGR 07/08/2014 : X3SUIVI102004 (fin)
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des tâches
  Call FIND_TSK_AVAL_FROM("SAL1", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des appels
  Call FIND_CLL_AVAL_FROM("SAL1", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des rendez-vous
  Call FIND_BAP_AVAL_FROM("SAL1", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
End

############################################################
# Traçabilité aval sur les livraisons
# Une livraison peut avoir soit des factures, soit des retours associés.
# 1. Recherche des factures (distinctes) : on interroge les lignes de factures.
# 2. Recherche des retours (distincts) : on parcourt les lignes de retour associées à la livraison.
Subprog FIND_TREE_AVAL_SDH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Integer I
Local Char SIH_F(GLONSIH)
Local Integer SIH_L
Local Char SRH_F(GLONVCR)
Local Integer SRH_L

  If !clalev([F:SID]) Then Local File SINVOICED  [SID] : Endif
  If !clalev([F:SRD]) Then Local File SRETURND   [SRD] : Endif
  If !clalev([F:PKW3]) Then Local File PIWRK     [PKW3] : Endif
  # ---------------------
  # Recherche d'une facture associée à la livraison
  If [M:PIV1]VCRTYPSEL = NUM_SDH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SID] Where SDHNUM=[F:PKW]VCRNUM and SDDLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:SID] Where SDHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:SID]) > 0 Then
    Raz SIH_F
    For [F:SID]
      If [F:SID]NUM <> "" Then
        SIH_F = [F:SID]NUM
        SIH_L = [F:SID]SIDLIN
        # Facture
        If func CONSPITOOLS.VERIF_LINE([F:SID]SDDLIN, NUM_SDH) = G_OUI Then
          Read [F:SIH]SIH0=SIH_F
          If !fstat Then
            Gosub WRITE_PKW1_SIH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [SID]
  # ---------------------
  # Recherche d'un retour
  If [M:PIV1]VCRTYPSEL = NUM_SDH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SRD] Where SDHNUM=[F:PKW]VCRNUM and SDDLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:SRD] Where SDHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:SRD]) > 0 Then
    Raz SRH_F
    For [F:SRD]
      If [F:SRD]SRHNUM <> "" Then
        SRH_F = [F:SRD]SRHNUM
        SRH_L = [F:SRD]SRDLIN
        If func CONSPITOOLS.VERIF_LINE([F:SRD]SDDLIN, NUM_SDH) = G_OUI Then
          # Pour chacun de ces retours, on récupère les infos
          Read [F:SRH]SRH0=SRH_F
          If !fstat Then
            # Retour
            Gosub WRITE_PKW1_SRH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:SRD]
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des tâches
  Call FIND_TSK_AVAL_FROM("SAL3", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des appels
  Call FIND_CLL_AVAL_FROM("SAL3", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des rendez-vous
  Call FIND_BAP_AVAL_FROM("SAL3", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des contrat de service
  Call FIND_CON_AVAL_FROM(3, [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des parc client
  # FGR 10/12/2012 : X3SUIVI86461 : le parc dépend de la ligne
  #Call FIND_MAC_AVAL_FROM(3, [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  Call FIND_MAC_AVAL_FROM(3, [F:PKW]VCRNUM, [F:PKW]VCRLIN, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
End

############################################################
# Traçabilité aval sur les retours
# Un retour peut avoir des avoirs associés.
#    Recherche des avoirs (distincts) : on parcourt les lignes de retours.
Subprog FIND_TREE_AVAL_SRH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char SIH_F(GLONSRH)
Local Integer SIH_L

  If !clalev([F:SRD]) Then Local File SRETURND [SRD] : Endif
  # ---------------------
  # Recherche des avoirs associés au retour
  If [M:PIV1]VCRTYPSEL = NUM_SRH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SRD] Where SRHNUM=[F:PKW]VCRNUM and SRDLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:SRD] Where SRHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:SRD]) > 0 Then
    Raz SIH_F
    For [F:SRD]
      If [F:SRD]SIHNUM <> "" Then
        SIH_F = [F:SRD]SIHNUM
        SIH_L = [F:SRD]SIDLIN
        If func CONSPITOOLS.VERIF_LINE([F:SRD]SRDLIN, NUM_SRH) = G_OUI Then
          # Pour chacun de ces avoirs, on récupère les infos
          Read [F:SIH]SIH0=SIH_F
          If !fstat Then
            Gosub WRITE_PKW1_SIV
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:SRD]
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des tâches
  Call FIND_TSK_AVAL_FROM("SAL7", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des appels
  Call FIND_CLL_AVAL_FROM("SAL7", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des rendez-vous
  Call FIND_BAP_AVAL_FROM("SAL7", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
End

############################################################
# Traçabilité aval sur les factures
# Une facture peut avoir soit des avoirs, soit des pièces associés.
# 1. Recherche des avoirs (distincts) : on interroge la table des avoirs
#    ayant dans SIHORINUM le n° de la facture.
# 2. Recherche des pièces (distinctes) : on parcourt les lignes de pièces.
# 3. Recherche des échéances
############################################################
Subprog FIND_TREE_AVAL_SIH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char SIV_F(GLONSIH)
Local Integer SIV_L
Local Char HAE_F(GLONVCR)
Local Integer HAE_L
# Issue 103476 - 2014-10-24 by SR
Local Char    HAE_T(GLONGTE)
Local Char NUM_F(GLONVCR)
Local Integer NUM_L
Local Char SOINUM_F(GLONVCR)
Local Integer SOINUM_L

  If !clalev([F:SID]) Then Local File SINVOICED [SID] : Endif
  If !clalev([F:DAE]) Then Local File GACCENTRYD [DAE] : Endif
  If !clalev([F:DUD]) Then Local File GACCDUDATE [DUD] : Endif
  If GMODU(3) = G_OUI Then
    # Module "Tiers"
    If !clalev([F:SOI]) Then Local File SOI [SOI] : Endif
  Endif
  # ---------------------
  # Recherche d'un avoir associé à la facture
  If [M:PIV1]VCRTYPSEL = NUM_SIH and [M:PIV1]VCRLINSEL > 0 Then
    Link [F:SID] With [F:SIH]SIH0=NUM As [SI] Where SIHORINUM=[F:PKW]VCRNUM and [F:SIH]INVTYP=2 and SIDORILIN=[M:PIV1]VCRLINSEL
  Else
    Link [F:SID] With [F:SIH]SIH0=NUM As [SI] Where SIHORINUM=[F:PKW]VCRNUM and [F:SIH]INVTYP=2
  Endif
  If rowcount([F:SI]) > 0 Then
    Raz SIV_F
    For [F:SI]
      # Avoir
      If [F:SID]NUM <> "" Then
        SIV_F = [F:SID]NUM
        SIV_L = [F:SID]SIDLIN
        If func CONSPITOOLS.VERIF_LINE([F:SID]SIDORILIN, NUM_SIH) = G_OUI Then
          Read [F:SIH]SIH0=SIV_F
          If !fstat Then
            Gosub WRITE_PKW1_SIV
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  # ---------------------
  # Recherche d'une pièce
  # FGR 18/03/2014 : X3SUIVI92483 (début)
  If !clalev([F:SIH]) Then Local File SINVOICE [SIH] : Endif
  Read [SIH]SIH0=[F:PKW]VCRNUM
  If fstat Then
    Raz [F:SIH]
  Endif
  # FGR 18/03/2014 : X3SUIVI92483 (fin)
  # FGR 14/04/2014 : X3SUIVI92483 (début)
  #If [M:PIV1]VCRTYPSEL = NUM_SIH and [M:PIV1]VCRLINSEL > 0 Then
  #  #Filter [F:DAE] Where NUM=[F:PKW]VCRNUM and LIN=[M:PIV1]VCRLINSEL
  #  Filter [F:DAE] Where NUM=[F:PKW]VCRNUM and LIN=[M:PIV1]VCRLINSEL and TYP=[F:SIH]GTE  # FGR 18/03/2014 : X3SUIVI92483
  #Else
  #  #Filter [F:DAE] Where NUM=[F:PKW]VCRNUM
  #  Filter [F:DAE] Where NUM=[F:PKW]VCRNUM and TYP=[F:SIH]GTE                            # FGR 18/03/2014 : X3SUIVI92483
  #Endif
  Filter [F:DAE] Where NUM=[F:PKW]VCRNUM and TYP=[F:SIH]GTE                            # FGR 18/03/2014 : X3SUIVI92483
  # FGR 18/03/2014 : X3SUIVI92483 (fin)
  If rowcount([F:DAE]) > 0 Then
    Raz HAE_F
    For [F:DAE]
      # Pièce
      If [F:DAE]NUM <> "" Then
        HAE_F = [F:DAE]NUM
        HAE_L = [F:DAE]LIN
        # Issue 103476 - 2014-10-24 by SR
        HAE_T = [F:DAE]TYP
        # Issue 103476 - 2014-10-24 by SR
        Filter [F:HAE] Where NUM=HAE_F & TYP = HAE_T
        For [F:HAE]
          Gosub WRITE_PKW1_HAE
          WK = 1
        Next
        Filter [F:HAE]
      Endif
    Next
  Endif
  Filter [F:DAE]
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des échéances
  Read [SIH]SIH0=[F:PKW]VCRNUM
  # FGR 07/08/2014 : X3SUIVI99279 : pas de filtre sur les lignes ici
  #  If [M:PIV1]VCRTYPSEL = NUM_SIH and [M:PIV1]VCRLINSEL > 0 Then
  #    Filter [DUD] Where [F:DUD]SOINUM = "" and [F:DUD]TYP = [F:SIH]GTE and [F:DUD]NUM = [F:PKW]VCRNUM and [F:DUD]LIG = [M:PIV1]VCRLINSEL
  #  Else
  #    Filter [DUD] Where [F:DUD]SOINUM = "" and [F:DUD]TYP = [F:SIH]GTE and [F:DUD]NUM = [F:PKW]VCRNUM
  #  Endif
  Filter [DUD] Where [F:DUD]SOINUM = "" and [F:DUD]TYP = [F:SIH]GTE and [F:DUD]NUM = [F:PKW]VCRNUM
  If rowcount([F:DUD]) > 0 Then
    For [F:DUD]
      NUM_F = [F:DUD]NUM
      NUM_L = [F:DUD]DUDLIG
      Gosub WRITE_PKW1_DUD
      WK = 1
    Next
  Endif
  Filter [DUD]
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  If GMODU(3) = G_OUI Then
    # Module "Tiers"
    # Recherche des relevés
    Link [F:SOI] With [F:DUD]DUD2=[F:SOI]SOINUM As [SO_] Where [F:DUD]SOINUM <> "" Order By Key SO_0=[F:DUD]SOINUM;[F:DUD]DUDLIG
    # FGR 07/08/2014 : X3SUIVI99279 : pas de filtre sur les lignes ici
    #    If [M:PIV1]VCRTYPSEL = NUM_SIH and [M:PIV1]VCRLINSEL > 0 Then
    #      # FGR 27/05/2013 : X3SUIVI90113
    #      #Filter [SO_] Where [F:DUD]TYP = [F:SIH]SIVTYP and [F:DUD]NUM = [F:PKW]VCRNUM and [F:DUD]LIG = [M:PIV1]VCRLINSEL
    #      Filter [SO_] Where [F:DUD]TYP = [F:SIH]GTE and [F:DUD]NUM = [F:PKW]VCRNUM and [F:DUD]LIG = [M:PIV1]VCRLINSEL
    #    Else
    #      # FGR 27/05/2013 : X3SUIVI90113
    #      #Filter [SO_] Where [F:DUD]TYP = [F:SIH]SIVTYP and [F:DUD]NUM = [F:PKW]VCRNUM
    #      Filter [SO_] Where [F:DUD]TYP = [F:SIH]GTE and [F:DUD]NUM = [F:PKW]VCRNUM
    #    Endif
    Filter [SO_] Where [F:DUD]TYP = [F:SIH]GTE and [F:DUD]NUM = [F:PKW]VCRNUM
    If rowcount([F:SO_]) > 0 Then
      For [F:SO_]
        SOINUM_F = [F:DUD]SOINUM
        SOINUM_L = [F:DUD]DUDLIG
        Gosub WRITE_PKW1_REL
        WK = 1
      Next
    Endif
    Filter [SO_]
  Endif
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des tâches
  Call FIND_TSK_AVAL_FROM("SAL4", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des appels
  Call FIND_CLL_AVAL_FROM("SAL4", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des rendez-vous
  Call FIND_BAP_AVAL_FROM("SAL4", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des contrats de service
  Call FIND_CON_AVAL_FROM(4, [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des pârc client
  # FGR 10/12/2012 : X3SUIVI86461 : le parc dépend de la ligne
  #Call FIND_MAC_AVAL_FROM(4, [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  Call FIND_MAC_AVAL_FROM(4, [F:PKW]VCRNUM, [F:PKW]VCRLIN, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
End

############################################################
# Traçabilité aval sur les avoirs
# Un avoir peut avoir des pièces associées.
#    Recherche des pièces (distinctes) : on interroge les lignes de pièces.
Subprog FIND_TREE_AVAL_SIV(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char HAE_F(GLONVCR)
Local Integer HAE_L
# Issue 103476 - 2014-10-24 by SR
Local Char HAE_T(GLONGTE)

  If !clalev([F:DAE]) Then Local File GACCENTRYD [DAE] : Endif
  # ---------------------
  # Recherche d'une pièce associée à l'avoir
  # FGR 14/04/2014 : X3SUIVI92483 (début)
  If !clalev([F:SIH]) Then Local File SINVOICE [SIH] : Endif
  Read [SIH]SIH0=[F:PKW]VCRNUM
  If fstat Then
    Raz [F:SIH]
  Endif
  # FGR 14/04/2014 : X3SUIVI92483 (fin)
  # FGR 14/04/2014 : X3SUIVI92483 (début)
  #If [M:PIV1]VCRTYPSEL = NUM_SIV and [M:PIV1]VCRLINSEL > 0 Then
  #  Filter [F:DAE] Where NUM=[F:PKW]VCRNUM and LIN=[M:PIV1]VCRLINSEL and TYP=[F:SIH]GTE  # FGR 14/04/2014 : X3SUIVI92483
  #Else
  #  Filter [F:DAE] Where NUM=[F:PKW]VCRNUM and TYP=[F:SIH]GTE                            # FGR 14/04/2014 : X3SUIVI92483
  #Endif
  Filter [F:DAE] Where NUM=[F:PKW]VCRNUM and TYP=[F:SIH]GTE                            # FGR 14/04/2014 : X3SUIVI92483
  # FGR 14/04/2014 : X3SUIVI92483 (fin)
  If rowcount([F:DAE]) > 0 Then
    Raz HAE_F
    For [F:DAE]
      # Pièce
      If [F:DAE]NUM <> "" Then
        HAE_F = [F:DAE]NUM
        HAE_L = [F:DAE]LIN
        # Issue 103476 - 2014-10-24 by SR
        HAE_T = [F:DAE]TYP
        # FGR 14/04/2014 : X3SUIVI92483 (début)
        #If func CONSPITOOLS.VERIF_LINE([F:DAE]LIN, NUM_SIV) = G_OUI Then
        #  Read [F:HAE]HAE0=HAE_F
        #  If !fstat Then
        #    Gosub WRITE_PKW1_HAE
        #    WK = 1
        #  Endif
        #Endif
        # Issue 103476 - 2014-10-24 by SR
        Filter [F:HAE] Where NUM=HAE_F & TYP = HAE_T
        For [F:HAE]
          Gosub WRITE_PKW1_HAE
          WK = 1
        Next
        Filter [F:HAE]
        # FGR 14/04/2014 : X3SUIVI92483 (fin)
      Endif
    Next
  Endif
  Filter [F:DAE]
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des tâches
  Call FIND_TSK_AVAL_FROM("SAL4", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des appels
  Call FIND_CLL_AVAL_FROM("SAL4", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des rendez-vous
  Call FIND_BAP_AVAL_FROM("SAL4", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
End

############################################################
# Traçabilité aval sur les commandes
# Une commande peut avoir soit des listes des prépa, soit des bons prépa,
# soit des livraisons, soit des factures associées.
# 1. Recherche des listes de préparation (distinctes) : on interroge la table des listes de préparation.
# 2. Recherche des bons prépa (distincts) : on interroge les lignes de bons de préparation
# 3. Recherche des livraisons (distinctes) : on interroge les lignes de livraison
# 4. Recherche des factures (distinctes) : on interroge les lignes de facture
Subprog FIND_TREE_AVAL_SOH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char PRL_F(GLONPRL)
Local Integer PRL_L
Local Char PRH_F(GLONPRH)
Local Integer PRH_L
Local Char SDH_F(GLONSDH)
Local Integer SDH_L
Local Char SIH_F(GLONSIH)
Local Integer SIH_L
Local Char NUM_F(GLONVCR)
Local Integer NUM_L
Local Char SOINUM_F(GLONVCR)
Local Integer SOINUM_L

  If !clalev([F:PRE]) Then Local File STOPRED [PRE] : Endif
  If !clalev([F:SDD]) Then Local File SDELIVERYD [SDD] : Endif
  If !clalev([F:SID]) Then Local File SINVOICED [SID] : Endif
  If !clalev([F:DUD]) Then Local File GACCDUDATE [DUD] : Endif
  # ---------------------
  # Recherche d'une liste de prépa associée à la commande
  If [M:PIV1]VCRTYPSEL = NUM_SOH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PRL] Where ORINUM=[F:PKW]VCRNUM and ORILIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PRL] Where ORINUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PRL]) > 0 Then
    # Liste de prépa
    Raz PRL_F
    For [F:PRL]
      If [F:PRL]PRLNUM <> "" Then
        PRL_F = [F:PRL]PRLNUM
        PRL_L = [F:PRL]PRLSEQ
        If func CONSPITOOLS.VERIF_LINE([F:PRL]ORILIN, NUM_SOH) = G_OUI Then
          # Pour chacune de ces listes, on récupère les infos
          Gosub WRITE_PKW1_PRL
          WK = 1
        Endif
      Endif
    Next
  Endif
  Filter [F:PRL]
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278 (début)
  # Recherche des échéances
  # FGR 07/08/2014 : X3SUIVI99279 : pas de filtre sur les lignes ici
  #  If [M:PIV1]VCRTYPSEL = NUM_SOH and [M:PIV1]VCRLINSEL > 0 Then
  #    Filter [DUD] Where [F:DUD]SOINUM = "" and [F:DUD]TYP = "*SO" and [F:DUD]NUM = [F:PKW]VCRNUM and [F:DUD]LIG = [M:PIV1]VCRLINSEL
  #  Else
  #    Filter [DUD] Where [F:DUD]SOINUM = "" and [F:DUD]TYP = "*SO" and [F:DUD]NUM = [F:PKW]VCRNUM
  #  Endif
  Filter [DUD] Where [F:DUD]SOINUM = "" and [F:DUD]TYP = "*SO" and [F:DUD]NUM = [F:PKW]VCRNUM
  If rowcount([F:DUD]) > 0 Then
    For [F:DUD]
      NUM_F = [F:DUD]NUM
      NUM_L = [F:DUD]DUDLIG
      Gosub WRITE_PKW1_DUD
      WK = 1
    Next
  Endif
  Filter [DUD]
  # FGR 13/01/2012 : X3SUIVI71278 (fin)
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  If GMODU(3) = G_OUI Then
    # Module "Tiers"
    # Recherche des relevés
    Link [F:SOI] With [F:DUD]DUD2=[F:SOI]SOINUM As [SO_] Where [F:DUD]SOINUM <> "" Order By Key SO_0=[F:DUD]SOINUM;[F:DUD]DUDLIG
    # FGR 07/08/2014 : X3SUIVI99279 : pas de filtre sur les lignes ici
    #    If [M:PIV1]VCRTYPSEL = NUM_SOH and [M:PIV1]VCRLINSEL > 0 Then
    #      Filter [SO_] Where [F:DUD]TYP = "*SO" and [F:DUD]NUM = [F:PKW]VCRNUM and [F:DUD]LIG = [M:PIV1]VCRLINSEL
    #    Else
    #      Filter [SO_] Where [F:DUD]TYP = "*SO" and [F:DUD]NUM = [F:PKW]VCRNUM
    #    Endif
    Filter [SO_] Where [F:DUD]TYP = "*SO" and [F:DUD]NUM = [F:PKW]VCRNUM
    If rowcount([F:SO_]) > 0 Then
      For [F:SO_]
        SOINUM_F = [F:DUD]SOINUM
        SOINUM_L = [F:DUD]DUDLIG
        Gosub WRITE_PKW1_REL
        WK = 1
      Next
    Endif
    Filter [SO_]
  Endif
  # ---------------------
  # Recherche d'un bon de prépa associé à la commande
  If [M:PIV1]VCRTYPSEL = NUM_SOH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PRE] Where ORINUM=[F:PKW]VCRNUM and ORILIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PRE] Where ORINUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PRE]) > 0 Then
    Raz PRH_F
    For [F:PRE]
      If [F:PRE]PRHNUM <> "" Then
        PRH_F = [F:PRE]PRHNUM
        PRH_L = [F:PRE]PRELIN
        If (func CONSPITOOLS.VERIF_LINE([F:PRE]ORILIN, NUM_SOH)=G_OUI) Then
          # Pour chacun de ces bons, on récupère les infos
          Read [F:PRH]PRH0=PRH_F
          If !fstat Then
            Gosub WRITE_PKW1_PRH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PRE]
  # ---------------------
  # Recherche d'une livraison associée à la commande
  If [M:PIV1]VCRTYPSEL = NUM_SOH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SDD] Where SOHNUM=[F:PKW]VCRNUM and SOPLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:SDD] Where SOHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:SDD]) > 0 Then
    # Livraison
    Raz SDH_F
    For [F:SDD]
      # FGR 07/12/2012 : X3SUIVI86461 (début)
      #                  Si la livraison est issue d'un/ou n bon(s) de préparation elle n'est pas retenue ici
      #                  C'est plus un optimisation au niveau performance, mais ça ne corrige pas mon pb
      Read [PRH]PRH3=[F:SDD]SDHNUM
      If fstat Then
        # FGR 07/12/2012 : X3SUIVI86461 (fin)
        If [F:SDD]SDHNUM <> "" Then
          SDH_F = [F:SDD]SDHNUM
          SDH_L = [F:SDD]SDDLIN
          If func CONSPITOOLS.VERIF_LINE([F:SDD]SOPLIN, NUM_SOH) = G_OUI Then
            Read [F:SDH]SDH0=SDH_F
            If !fstat Then
              Gosub WRITE_PKW1_SDH
              WK = 1
            Endif
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:SDD]
  # ---------------------
  # Recherche d'une facture
  If [M:PIV1]VCRTYPSEL = NUM_SOH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SID] Where SOHNUM=[F:PKW]VCRNUM and SOPLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:SID] Where SOHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:SID]) > 0 Then
    # Facture
    Raz SIH_F
    For [F:SID]
      If [F:SID]NUM <> "" Then
        SIH_F = [F:SID]NUM
        SIH_L = [F:SID]SIDLIN
        If func CONSPITOOLS.VERIF_LINE([F:SID]SOPLIN, NUM_SOH) = G_OUI Then
          Read [F:SIH]SIH0=SIH_F
          If !fstat Then
            Gosub WRITE_PKW1_SIH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:SID]
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des tâches
  Call FIND_TSK_AVAL_FROM("SAL2", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des appels
  Call FIND_CLL_AVAL_FROM("SAL2", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des rendez-vous
  Call FIND_BAP_AVAL_FROM("SAL2", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des contrats de service
  Call FIND_CON_AVAL_FROM(2, [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
End

############################################################
# Traçabilité aval sur les demandes de livraison
# Une demande peut avoir soit des listes prépa, soit des bons prépa, soit
# des livraisons, soit des factures associés.
# 1. Recherche des listes de prépa (distinctes) : on interroge la table des listes de prépa
# 2. Recherche des bons prépa (distincts) : on interroge la table des bons prépa
# 3. Recherche des livraisons (distinctes) : on interroge la table des livraisons
# 4. Recherche des factures (distinctes) : on interroge la table des factures
Subprog FIND_TREE_AVAL_SOC(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char PRL_F(GLONPRL)
Local Integer PRL_L
Local Char PRH_F(GLONPRH)
Local Integer PRH_L
Local Char SDH_F(GLONSDH)
Local Integer SDH_L
Local Char SIH_F(GLONSIH)
Local Integer SIH_L
Local Char NUM_F(GLONVCR)
Local Integer NUM_L
Local Char SOINUM_F(GLONVCR)
Local Integer SOINUM_L

  If !clalev([F:PRL]) Then Local File STOPRELIS [PRL] : Endif
  If !clalev([F:PRE]) Then Local File STOPRED [PRE] : Endif
  If !clalev([F:SDD]) Then Local File SDELIVERYD [SDD] : Endif
  If !clalev([F:SID]) Then Local File SINVOICED [SID] : Endif
  If !clalev([F:DUD]) Then Local File GACCDUDATE [DUD] : Endif
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278 (début)
  # Recherche des échéances
  # FGR 07/08/2014 : X3SUIVI99279 : pas de filtre sur les lignes ici
  #  If [M:PIV1]VCRTYPSEL = NUM_SOH and [M:PIV1]VCRLINSEL > 0 Then
  #    Filter [DUD] Where [F:DUD]SOINUM = "" and [F:DUD]TYP = "*SO" and [F:DUD]NUM = [F:PKW]VCRNUM and [F:DUD]LIG = [M:PIV1]VCRLINSEL
  #  Else
  #    Filter [DUD] Where [F:DUD]SOINUM = "" and [F:DUD]TYP = "*SO" and [F:DUD]NUM = [F:PKW]VCRNUM
  #  Endif
  Filter [DUD] Where [F:DUD]SOINUM = "" and [F:DUD]TYP = "*SO" and [F:DUD]NUM = [F:PKW]VCRNUM
  If rowcount([F:DUD]) > 0 Then
    For [F:DUD]
     NUM_F = [F:DUD]NUM
      NUM_L = [F:DUD]DUDLIG
      Gosub WRITE_PKW1_DUD
      WK = 1
    Next
  Endif
  Filter [DUD]
  # FGR 13/01/2012 : X3SUIVI71278 (fin)
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  If GMODU(3) = G_OUI Then
    # Module "Tiers"
    # Recherche des relevés
    Link [F:SOI] With [F:DUD]DUD2=[F:SOI]SOINUM As [SO_] Where [F:DUD]SOINUM <> "" Order By Key SO_0=[F:DUD]SOINUM;[F:DUD]DUDLIG
    # FGR 07/08/2014 : X3SUIVI99279 : pas de filtre sur les lignes ici
    #    If [M:PIV1]VCRTYPSEL = NUM_SOH and [M:PIV1]VCRLINSEL > 0 Then
    #      Filter [SO_] Where [F:DUD]TYP = "*SO" and [F:DUD]NUM = [F:PKW]VCRNUM and [F:DUD]LIG = [M:PIV1]VCRLINSEL
    #    Else
    #      Filter [SO_] Where [F:DUD]TYP = "*SO" and [F:DUD]NUM = [F:PKW]VCRNUM
    #    Endif
    Filter [SO_] Where [F:DUD]TYP = "*SO" and [F:DUD]NUM = [F:PKW]VCRNUM
    If rowcount([F:SO_]) > 0 Then
      For [F:SO_]
        SOINUM_F = [F:DUD]SOINUM
        SOINUM_L = [F:DUD]DUDLIG
        Gosub WRITE_PKW1_REL
        WK = 1
      Next
    Endif
    Filter [SO_]
  Endif
  # ---------------------
  # Recherche d'une liste de prépa associée à la demande
  If [M:PIV1]VCRTYPSEL = NUM_SOC and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PRL] Where ORINUM=[F:PKW]VCRNUM and ORILIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PRL] Where ORINUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PRL]) > 0 Then
    # Livraison
    Raz PRL_F
    For [F:PRL]
      If [F:PRL]PRLNUM <> "" Then
        PRL_F = [F:PRL]PRLNUM
        PRL_L = [F:PRL]PRLSEQ
        If func CONSPITOOLS.VERIF_LINE([F:PRL]ORILIN, NUM_SOC) = G_OUI Then
          Gosub WRITE_PKW1_PRL
          WK = 1
        Endif
      Endif
    Next
  Endif
  Filter [F:PRL]
  # ---------------------
  # Recherche d'un bon de prépa associé à la demande
  If [M:PIV1]VCRTYPSEL = NUM_SOC and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PRE] Where ORINUM=[F:PKW]VCRNUM and ORILIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PRE] Where ORINUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:PRE]) > 0 Then
    Raz PRH_F
    # Bon prépa
    For [F:PRE]
      If [F:PRE]PRHNUM <> "" Then
        PRH_F = [F:PRE]PRHNUM
        PRH_L = [F:PRE]PRELIN
        If func CONSPITOOLS.VERIF_LINE([F:PRE]ORILIN, NUM_SOC) = G_OUI Then
          # Pour chacun de ces bons, on récupère les infos
          Read [F:PRH]PRH0=PRH_F
          If !fstat Then
            Gosub WRITE_PKW1_PRH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:PRE]
  # ---------------------
  # Recherche d'une livraison associée à la demande
  If [M:PIV1]VCRTYPSEL = NUM_SOC and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SDD] Where SOHNUM=[F:PKW]VCRNUM and SOPLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:SDD] Where SOHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:SDD]) > 0 Then
    # Livraison
    Raz SDH_F
    For [F:SDD]
      If [F:SDD]SDHNUM <> "" Then
        SDH_F = [F:SDD]SDHNUM
        SDH_L = [F:SDD]SDDLIN
        If func CONSPITOOLS.VERIF_LINE([F:SDD]SOPLIN, NUM_SOC) = G_OUI Then
          Read [F:SDH]SDH0=SDH_F
          If !fstat Then
            Gosub WRITE_PKW1_SDH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:SDD]
  # ---------------------
  # Recherche d'une facture
  If [M:PIV1]VCRTYPSEL = NUM_SOC and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SID] Where SOHNUM=[F:PKW]VCRNUM and SOPLIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:SID] Where SOHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:SID]) > 0 Then
    # Facture
    Raz SIH_F
    For [F:SID]
      If [F:SID]NUM <> "" Then
        SIH_F = [F:SID]NUM
        SIH_L = [F:SID]SIDLIN
        If func CONSPITOOLS.VERIF_LINE([F:SID]SOPLIN, NUM_SOC) = G_OUI Then
          Read [F:SIH]SIH0=SIH_F
          If !fstat Then
            Gosub WRITE_PKW1_SIH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:SID]
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des tâches
  Call FIND_TSK_AVAL_FROM("SAL5", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des appels
  Call FIND_CLL_AVAL_FROM("SAL5", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  # Recherche des rendez-vous
  Call FIND_BAP_AVAL_FROM("SAL5", [F:PKW]VCRNUM, 0, INIV, WLEV, GCOMMIT) From CNSPIVSTD
  # ---------------------
End

############################################################
# Traçabilité aval sur les bons de préparation
# Un bon prépa peut avoir soit des livraisons associées.
#    Recherche des livraisons (distinctes) : on cherche dans la table des lignes
#    de livraisons les enregistrements qui ont ce bon de préparation
Subprog FIND_TREE_AVAL_PRH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char SDH_F(GLONSDH)
Local Integer SDH_L

  If !clalev([F:SDD]) : Local File SDELIVERYD [SDD] : Endif
  # ---------------------
  # Recherche d'une livraison associée au bon
  If [M:PIV1]VCRTYPSEL = NUM_PRH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:SDD] Where PRHNUM=[F:PKW]VCRNUM and PRELIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:SDD] Where PRHNUM=[F:PKW]VCRNUM
  Endif
  If rowcount([F:SDD]) > 0 Then
    # Livraison
    Raz SDH_F
    For [F:SDD]
      If [F:SDD]SDHNUM <> "" Then
        SDH_F = [F:SDD]SDHNUM
        SDH_L = [F:SDD]SDDLIN
        If func CONSPITOOLS.VERIF_LINE([F:SDD]PRELIN, NUM_PRH) = G_OUI Then
          Read [F:SDH]SDH0=SDH_F
          If !fstat Then
            Gosub WRITE_PKW1_SDH
            WK = 1
          Endif
        Endif
      Endif
    Next
  Endif
  Filter [F:SDD]
End

############################################################
# Traçabilité aval sur les listes de préparation
# Une liste de prépa peut avoir des bons associés.
#    Recherche des bons prépa (distinctes) : on interroge les lignes de bons prépa
Subprog FIND_TREE_AVAL_PRL(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Integer OK_PRH
Local Char PRH_F(GLONPRH)

  If !clalev([F:PRE]) Then Local File STOPRED [PRE] Endif
  # ---------------------
  # Recherche d'un bon prépa associé à la liste
  Link [F:PRH] With [F:PRE]PRE0=PRHNUM As [PR] Where PRLNUM=[F:PKW]VCRNUM
  # Bon prépa
  If rowcount([F:PR]) > 0 Then
    Raz PRH_F
    For [F:PR]
      If [F:PR]PRHNUM <> "" Then
        PRH_F = [F:PR]PRHNUM
        OK_PRH = G_OUI
        # Si la pièce d'origine est une commande, on ne prend que les bons prépa relatifs à cette commande
        If [F:PKW]VCRTYPORI = NUM_SOH or [F:PKW]VCRTYPORI = NUM_SOC Then
          If [F:PRE]ORINUM <> [F:PKW]VCRNUMORI or ([F:PKW]VCRLINORI > 0 and [F:PRE]ORILIN <> [F:PKW]VCRLINORI) Then
            OK_PRH = G_NON
          Endif
        Endif
        # Pour chacun de ces bons, on récupère les infos
        If OK_PRH = G_OUI Then
          Gosub WRITE_PKW1_PRH
          WK = 1
        Endif
      Endif
    Next
  Endif
End

############################################################
# Traçabilité aval sur les échéances
# Une échéance peut avoir des règlements (distincts) : on cherche dans la table des lignes
#    Recherche des règlement :
Subprog FIND_TREE_AVAL_DUD(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char NUM_F(GLONPAY)
Local Integer NUM_L
Local Integer IPOSSLASH
Local Integer ITRDUDNUM
Local Integer ITRDUDLIG

  # FGR 13/01/2012 : X3SUIVI71278
  If !clalev([F:PYD]) Then Local File PAYMENTD [PYD] : Endif
  If !clalev([F:SOI]) Then Local File SOI [SOI] : Endif
  # ---------------------
  IPOSSLASH = instr(1, [F:PKW]VCRNUM, "/")
  ITRDUDNUM = val(seg$([F:PKW]VCRNUM, 1, IPOSSLASH-1))
  ITRDUDLIG = val(seg$([F:PKW]VCRNUM, IPOSSLASH+1, len([F:PKW]VCRNUM)))
  # ---------------------
  # Recherche d'une ligne de règlement associée au à l'échéance
  If ([M:PIV1]VCRTYPSEL = NUM_DUD or [M:PIV1]VCRTYPSEL = NUM_DUDA) and [M:PIV1]VCRLINSEL > 0 Then
    Filter [F:PYD] Where DUDNUM = ITRDUDNUM and DUDLIG = ITRDUDLIG and LIN=[M:PIV1]VCRLINSEL
  Else
    Filter [F:PYD] Where DUDNUM = ITRDUDNUM and DUDLIG = ITRDUDLIG
  Endif
  If rowcount([F:PYD]) > 0 Then
    Raz NUM_F
    For [F:PYD]
      NUM_F = [F:PYD]NUM
      NUM_L = [F:PYD]LIN
      If func CONSPITOOLS.VERIF_LINE([F:PYD]LIN, NUM_PYH) = G_OUI Then
        Read [F:PYH]PYH0=NUM_F
        If !fstat Then
          Gosub WRITE_PKW1_PYH
          WK = 1
        Endif
      Endif
    Next
  Endif
  Filter [F:PYD]
End

############################################################
# Traçabilité aval sur les factures tiers fournisseurs
# Une échéance peut avoir des règlements (distincts) : on cherche dans la table des lignes
#    Recherche des dépenses (immobilisations) :
Subprog FIND_TREE_AVAL_BIS(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char LOF_F(GLONVCR)
Local Integer LOF_L

  # FGR 24/10/2012 : X3SUIVI81498
  If !clalev([F:PIL]) Then Local File BPSINVLIG [PIL] : Endif
  # ---------------------
  If GMODU(14) = G_OUI Then
    If [M:PIV1]VCRTYPSEL = NUM_BIS and [M:PIV1]VCRLINSEL > 0 Then
      Filter [F:PIL] Where [F:PIL]NUM=[F:PKW]VCRNUM and [F:PIL]LIG=[M:PIV1]VCRLINSEL
    Else
      Filter [F:PIL] Where [F:PIL]NUM=[F:PKW]VCRNUM
    Endif
    If rowcount([F:PIL]) > 0 Then
      For [F:PIL]
        Filter [LOF] Where [F:LOF]CPMCREORI = 2 and [F:LOF]CODLOF = [F:PIL]NUM and [F:LOF]LIGORI = [F:PIL]LIG
        If rowcount([F:LOF]) > 0 Then
          Raz LOF_F
          For [F:LOF]
            LOF_F = [F:LOF]CODLOF
            LOF_L = [F:LOF]LINLOF
            Gosub WRITE_PKW1_LOF From CNSPIF2STD
            WK = 1
          Next
        Endif
        Filter [LOF]
      Next
    Endif
    Filter [F:PIL]
  Endif
End

