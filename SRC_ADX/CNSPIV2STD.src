############################################################
# Traçabilité amont sur les demandes de livraison
#   ==> Pas de traçabilité amont pour les demandes de livraison
Subprog FIND_TREE_AMONT_SRE(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char CONNUM_F(GLONVCR)

  # FGR 13/01/2012 : X3SUIVI71278
  # ---------------------
  If !clalev([F:SRM]) Then Local File SREMAC [SRM] : Endif
  # ---------------------
  # Contrat de service
  Read [F:SRE]SRE0=[F:PKW]VCRNUM
  If [F:SRE]CONSPT <> "" Then
    Read [F:CON]CON0=[F:SRE]CONSPT
    CONNUM_F = [F:CON]CONNUM
    Gosub WRITE_PKW1_CON
  Endif
  # ---------------------
  # Parc client
  Filter [SRM] Where [F:SRM]SRENUM = [F:PKW]VCRNUM
  If rowcount([F:SRM]) > 0 Then
    For [F:SRM]
      Read [F:MAC]MAC0=[F:SRM]MACNUM
      Gosub WRITE_PKW1_MAC
      WK = 1
    Next
  Endif
  Filter [SRM]
  # ---------------------
End

