End

############################################################
# Traçabilité amont sur les règlements
# Une échéance peut avoir des factures
#    Recherche des commandes ouvertes ou non (distinctes) : on parcourt la liste de prépa.
Subprog FIND_TREE_AMONT_PYH(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char NUM_F(GLONVCR)
Local Integer NUM_L

  If !clalev([F:DUD]) Then Local File GACCDUDATE [DUD] : Endif
  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  Filter [DUD] Where NUMDUD=[F:PKW]VCRNUMCALC
  If rowcount([F:DUD]) > 0 Then
    For [F:DUD]
      NUM_F = [F:DUD]NUM
      NUM_L = [F:DUD]LIG
      Gosub WRITE_PKW1_DUD
      WK = 1
    Next
  Endif
  Filter [DUD]
End

############################################################
# Traçabilité amont sur les règlements
# Une échéance peut avoir des factures
#    Recherche des commandes ouvertes ou non (distinctes) : on parcourt la liste de prépa.
Subprog FIND_TREE_AMONT_REL(INIV, WLEV, GCOMMIT)
Variable Integer INIV
Variable Char WLEV
Variable Integer GCOMMIT

Local Char NUM_F(GLONVCR)
Local Integer NUM_L

  # ---------------------
  # FGR 13/01/2012 : X3SUIVI71278
  Link [F:SOI] With [F:DUD]DUD2=[F:SOI]SOINUM As [SO_] Where [F:DUD]SOINUM <> "" Order By Key SO_0=[F:DUD]SOINUM;[F:DUD]DUDLIG
  If [M:PIV1]VCRTYPSEL = NUM_SIH and [M:PIV1]VCRLINSEL > 0 Then
    Filter [SO_] Where [F:DUD]SOINUM = [F:PKW]VCRNUM and [F:DUD]LIG = [M:PIV1]VCRLINSEL
  Else
    Filter [SO_] Where [F:DUD]SOINUM = [F:PKW]VCRNUM
  Endif
  If rowcount([F:SO_]) > 0 Then
    For [F:SO_]
      NUM_F = [F:DUD]NUM
      NUM_L = [F:DUD]LIG
      If [F:DUD]TYP = "*SO" Then
        Read [F:SOH]SOH0=[F:DUD]NUM
        If [F:SOH]SOHCAT = 4 Then
          # Commande ouverte
          Read [F:SOC]SOC0=[F:DUD]NUM
          If !fstat Then
            Gosub WRITE_PKW1_SOC
            WK = 1
          Endif
        Else
          # Commande
          Gosub WRITE_PKW1_SOH
          WK = 1
        Endif
      Else
        # Facture
        Read [F:SIH]SIH0=[F:DUD]NUM
        Gosub WRITE_PKW1_SIH
      Endif
      WK = 1
    Next
  Endif
  Filter [SO_]
End

