#<AdxTL>@(#)1.0.0.0 $Revision$
Raz GPILCOD, GBIDC1
Call OBJET("TXW",GBIDC1,GBIDC2) From GOBJET
End

####################################################################################
## Tableaux de bord : Traitement des fonctions de compta budgétaire
####################################################################################
$TRT_BUD
Gosub SETREFANA From CALTBD
Gosub SETEXE    From CALTBD

# Le code budget

C_BUD = ARG(1)
If func SUBTXSB.EXISTE(C_BUD)
 Call REPLACE(C_BUD,C_BUD) From SUBTXSB
Endif
Read [BUP]BUP0 = C_BUD
If fstat
 ER = 2 : ERARG = C_BUD
 Return
Endif

# La version

V_BUD = ARG(2)
If func SUBTXSB.EXISTE(V_BUD)
 Call REPLACE(V_BUD,V_BUD) From SUBTXSB
Endif
If V_BUD=""
 Filter [BUV] Where BUD=C_BUD & DEF=2
 Read [BUV] First
 Filter [BUV]
 V_BUD = [F:BUV]VER
Endif

# La nature
INAT  = 3
If func SUBTXSB.EXISTE(ARG(INAT))
 Call REPLACE(ARG(INAT),ARG(INAT)) From SUBTXSB
Endif
If ARG(INAT)="" : ARG(INAT) = "*" : Endif
K = instr(1,ARG(INAT),"..")
If K
 ARGDEB(INAT) = left$(ARG(INAT),K-1)
 ARGFIN(INAT) = right$(ARG(INAT),K+2)+chr$(255)
 JOKER(INAT)  = 3
Else
 K = instr(1,ARG(INAT),"(")
 If K
  ARGDEB(INAT) = left$(ARG(INAT),K-1)
  ARGFIN(INAT) = ARGDEB(INAT)+chr$(255)
  ARGEXC(INAT) = ARGDEB(INAT)+seg$(ARG(INAT),K+1,len(ARG(INAT))-1)
  JOKER(INAT)  = 4
 Else
  K = instr(1,ARG(INAT),".")
  If K
   JOKER(INAT)    = 2
   PYRAMIDE(INAT) = left$(ARG(INAT),K-1)
   If func SUBTXSB.EXISTE(PYRAMIDE(INAT))
    Call REPLACE(PYRAMIDE(INAT),PYRAMIDE(INAT)) From SUBTXSB
   Endif
   If [F:BUP]PYMACC<>"" & PYRAMIDE(INAT)<>[F:BUP]PYMACC
    ER = 30 : ERARG = PYRAMIDE(INAT)    : # Mauvaise pyramide
    Return
   Endif
   PYRGRP(INAT)   = right$(ARG(INAT),K+1)
   If func SUBTXSB.EXISTE(PYRGRP(INAT))
    Call REPLACE(PYRGRP(INAT),PYRGRP(INAT)) From SUBTXSB
   Endif
  Elsif [F:BUP]PYMACC<>""
   JOKER(INAT)    = 2
   PYRAMIDE(INAT) = [F:BUP]PYMACC
   PYRGRP(INAT)   = ARG(INAT)
  Elsif ARG(INAT)=vireblc(format$("K:80c",ARG(INAT)),2)
   JOKER(INAT) = 0
  Else
   JOKER(INAT) = 1
  Endif
  If JOKER(INAT)=2
   Read [GYM]GYM0 = PYRAMIDE(INAT)
   If fstat
    ER = 32 : ERARG = PYRAMIDE(INAT) : # Pyramide inexistante
    Return
   Endif
   Read [GRY]GRY0(2) = PYRAMIDE(INAT);PYRGRP(INAT)
   If fstat
    ER = 17 : ERARG = PYRGRP(INAT) : # Groupe de nature inexistante
    Return
   Endif
   PYRNIV(INAT)  = [F:GRY]LEV
   If PYRNIV(INAT)>[F:BUP]PYMACCLEV & [F:BUP]PYMACC=PYRAMIDE(INAT)
    ER = 31 : ERARG = PYRGRP(INAT)-num$(PYRNIV(INAT))-"/"-num$([F:BUP]PYMACCLEV) : # Mauvais niveau
    Return
   Elsif PYRNIV(INAT)<[F:BUP]PYMACCLEV
    Raz TBGRPNAT
    Raz TBNIVNAT
    NBGRPNAT    = 1
    TBGRPNAT(1) = PYRGRP(INAT)
    TBNIVNAT(1) = PYRNIV(INAT)
    Repeat
     OKGRP = 0
     J = 1
     While J<=NBGRPNAT
      If TBNIVNAT(J)<[F:BUP]PYMACCLEV
       For [GRY]GRY0 Where PYM=[F:BUP]PYMACC & GRU=TBGRPNAT(J) & SBBGRU<>""
        Read [GRY2]GRY0(2) = [F:GRY]PYM;[F:GRY]SBBGRU
        If !fstat & [F:GRY2]LEV<=[F:BUP]PYMACCLEV
         NBGRPNAT += 1
         TBGRPNAT(NBGRPNAT) = [F:GRY2]GRU
         TBNIVNAT(NBGRPNAT) = [F:GRY2]LEV
         OKGRP = 1
        Endif
       Next
      Endif
      J +=1
     Wend
    Until OKGRP=1
   Endif
  Endif
 Endif
Endif

# Les sections
For I=1 To [F:BUP]DIENBR
 ISEC = INAT+I
 If [F:BUP]DIE(I-1)<>"" or [F:BUP]PYMCCE(I-1)<>""
  If func SUBTXSB.EXISTE(ARG(ISEC))
   Call REPLACE(ARG(ISEC),ARG(ISEC)) From SUBTXSB
  Endif
  If ARG(ISEC)="" : ARG(ISEC) = "*" : Endif
  K = instr(1,ARG(ISEC),"..")
  If K
   ARGDEB(ISEC) = left$(ARG(ISEC),K-1)
   ARGFIN(ISEC) = right$(ARG(ISEC),K+2)+chr$(255)
   JOKER(ISEC)  = 3
  Else
   K = instr(1,ARG(ISEC),"(")
   If K
    ARGDEB(ISEC) = left$(ARG(ISEC),K-1)
    ARGFIN(ISEC) = ARGDEB(ISEC)+chr$(255)
    ARGEXC(ISEC) = ARGDEB(ISEC)+seg$(ARG(ISEC),K+1,len(ARG(ISEC))-1)
    JOKER(ISEC)  = 4
   Else
    K = instr(1,ARG(ISEC),".")
    If K
     JOKER(ISEC)    = 2
     PYRAMIDE(ISEC) = left$(ARG(ISEC),K-1)
     If func SUBTXSB.EXISTE(PYRAMIDE(ISEC))
      Call REPLACE(PYRAMIDE(ISEC),PYRAMIDE(ISEC)) From SUBTXSB
     Endif
     If [F:BUP]PYMCCE(I-1)<>"" & PYRAMIDE(ISEC)<>[F:BUP]PYMCCE(I-1)
      ER = 30 : ERARG = PYRAMIDE(ISEC)    : # Mauvaise pyramide
      Break
     Endif
     PYRGRP(ISEC)   = right$(ARG(ISEC),K+1)
     If func SUBTXSB.EXISTE(PYRGRP(ISEC))
      Call REPLACE(PYRGRP(ISEC),PYRGRP(ISEC)) From SUBTXSB
     Endif
    Elsif [F:BUP]PYMCCE(I-1)<>""
     JOKER(ISEC)    = 2
     PYRAMIDE(ISEC) = [F:BUP]PYMCCE(I-1)
     PYRGRP(ISEC)   = ARG(ISEC)
    Elsif ARG(ISEC)=vireblc(format$("K:80c",ARG(ISEC)),2)
     JOKER(ISEC) = 0
    Else
     JOKER(ISEC) = 1
    Endif
    If JOKER(ISEC)=2
     Read [CYM]CYM0 = PYRAMIDE(ISEC)
     If fstat
      ER = 32 : ERARG = PYRAMIDE(ISEC) : # Pyramide inexistante
      Break
     Endif
     Read [CRY]CRY0(2) = PYRAMIDE(ISEC);PYRGRP(ISEC)
     If fstat
      ER = 18 : ERARG = PYRGRP(ISEC) : # Groupe de section inexistante
      Break
     Endif
     PYRNIV(ISEC)  = [F:CRY]LEV
     If PYRNIV(ISEC)>[F:BUP]PYMCCELEV(I-1) & [F:BUP]PYMCCE(I-1)=PYRAMIDE(ISEC)
      ER = 31 : ERARG = PYRGRP(ISEC)-num$(PYRNIV(ISEC))-"/"-num$([F:BUP]PYMCCELEV(I-1)) : # Mauvais niveau
      Break
     Elsif PYRNIV(ISEC)<[F:BUP]PYMCCELEV(I-1)
      NBGRPSEC(I)   = 1
      TBGRPSEC(I,1) = PYRGRP(ISEC)
      TBNIVSEC(I,1) = PYRNIV(ISEC)
      Repeat
       OKGRP = 0
       For J=1 To NBGRPSEC(I)
        If TBNIVSEC(I,J)<[F:BUP]PYMCCELEV(I-1)
         For [CRY]CRY0 Where PYM=[F:BUP]PYMCCE(I-1) & GRU=TBGRPSEC(I,J) & SBBGRU<>""
          Read [CRY2]CRY0(2) = [F:CRY]PYM;[F:CRY]SBBGRU
          If !fstat & [F:CRY2]LEV<=[F:BUP]PYMCCELEV(I-1)
           NBGRPSEC(I) += 1
           TBGRPSEC(I,NBGRPSEC(I)) = [F:CRY2]GRU
           TBNIVSEC(I,NBGRPSEC(I)) = [F:CRY2]LEV
           OKGRP = 1
          Endif
         Next
        Endif
       Next J
      Until OKGRP=1
     Endif
    Endif
   Endif
  Endif
 Endif
Next I
If ER : Return : Endif

# ¨Parcours du budget

Case [F:BUP]LEV

 When 1 : # Société

  ISITE = 1
  For ISOC=1 To NBSOC
   Call GET_LEDCUR(GACTX,TSOC(ISOC),NUMREF,CODLED,DEVLED,GMESSAGE) From FINACM_SYRA
   Call LEC_LED(CODLED) From CPTLEC
   Gosub CRITBUD
   Call ADDCRIT(CRITERE,ICRIT,'[BUD]CPY="'+TSOC(ISOC)+'"') From CALTBD
   Call ADDCRIT(CRITERE,ICRIT,'[BUD]FCY=""') From CALTBD
   EDEB = TEDEB(ISOC)
   EFIN = TEFIN(ISOC)
   PDEB = TPDEB(ISOC)
   PFIN = TPFIN(ISOC)
   Call LECTURE("CPY",TSOC(ISOC),"") From CONTOBJ
   If [F:CPY]MAIFCY=""
    Filter [FCY] Where LEGCPY=TSOC(ISOC)
    Read [FCY]FCY1 First
    Filter [FCY]
    SITE = [F:FCY]FCY
   Else
    SITE = [F:CPY]MAIFCY
   Endif
   ISITE = find(SITE,TSITE(1..NBSITE))
   # If a company & a site are entered, TSITE is filled with the site, while the definition level of the budget is the company.
   If ISITE=0 : ISITE=1 : Endif
   Gosub EVAL_INFSIT From CALTBD
   Filter [LBUD] Where evalue(CRITERE(1..ICRIT))
&   Order By Key CLE = [F:BUD]CPY;[F:BUD]ACC;[F:BUD]CCE1;[F:BUD]CCE2;[F:BUD]CCE3;
&                      [F:BUD]CCE4;[F:BUD]CCE5;[F:BUD]CCE6;[F:BUD]CCE7;[F:BUD]CCE8;[F:BUD]CCE9;[F:BUD]FIY

   For [LBUD]CLE(2) : # Nature
    Raz SIT_CPTDEB, SIT_CPTCDT
    NATURE = [F:BUD]ACC
    PLAN   = [F:BUD]COA
    If PLAN=""
     Read [CPY]CPY0 = [F:BUD]CPY
     Read [GCM]GCM0 = [F:CPY]ACM
     Read [LED]LED0 = [F:GCM]LED(NUMREF-1)
     PLAN           = [F:LED]COA
    Endif
    COMPTE = NATURE

    Raz TYPNAT
    Call LEC_GAC(COMPTE,PLAN) From CPTLEC
    If !fstat : Call LEC_COA([F:GAC]COA) From CPTLEC : Endif
    If !fstat : Read [CLS]CLS0 = [F:COA]LEGCLS;[F:GAC]CLSCOD : Endif
    If !fstat : TYPNAT = [F:CLS]SNSANA : Endif

    If [F:BUP]PYMACC=""
     Gosub EVAL_INFACC From CALTBD
    Else
     Read [GRY]GRY0(2) = [F:BUP]PYMACC;NATURE
     Call LECTEXTRA(CPTINF,"GACCGRUPYM","DESTRA",[F:GRY]PYM,[F:GRY]GRU) From ATEXTRA
    Endif
    Case JOKER(INAT)
     When 0 : OK = (NATURE=ARG(INAT))
     When 1 : OK = pat(NATURE,ARG(INAT))
     When 2
      If [F:BUP]PYMACC=""
       Read [GYK]GYK0 = PYRAMIDE(INAT);PYRNIV(INAT);NATURE
       OK = (fstat=0 & [F:GYK]GRU=PYRGRP(INAT))
      Elsif PYRNIV(INAT)<[F:BUP]PYMACCLEV
       OK = find(NATURE,TBGRPNAT(1..NBGRPNAT))
      Else
       OK = 1
      Endif
     When 3 : OK = (NATURE>=ARGDEB(INAT) & NATURE<=ARGFIN(INAT))
     When 4 : OK = (NATURE>=ARGDEB(INAT) & NATURE<=ARGFIN(INAT)
&                &  left$(NATURE,len(ARGEXC(INAT)))<>ARGEXC(INAT))
    Endcase
    If OK
     For [LBUD]CLE(11) : # Sections
      OK = 1
      For I=1 To [F:BUP]DIENBR
       If [F:BUP]DIE(I-1)<>"" or [F:BUP]PYMCCE(I-1)<>""
        INDDIE = find([F:BUP]DIE(I-1),[F:LED]DIE(0..[F:LED]DIENBR-1))
        If INDDIE : SECTION = evalue("[F:BUD]CCE"+num$(INDDIE)) : Endif
        ISEC = INAT+I
        Case JOKER(ISEC)
         When 0 : OK *= (SECTION=ARG(ISEC))
         When 1 : OK *= pat(SECTION,ARG(ISEC))
         When 2
          If [F:BUP]PYMCCE(I-1)=""
           Read [CYK]CYK0 = PYRAMIDE(ISEC);PYRNIV(ISEC);SECTION
           OK *= (fstat=0 & [F:CYK]GRU=PYRGRP(ISEC))
          Elsif PYRNIV(ISEC)<[F:BUP]PYMCCELEV(I-1)
           JJ = 0
           For II=1 To NBGRPSEC(I)
            If SECTION=TBGRPSEC(I,II)
             JJ = 1 : Break
            Endif
           Next II
           OK *= JJ
          Endif
         When 3 : OK *= (SECTION>=ARGDEB(ISEC) & SECTION<=ARGFIN(ISEC))
         When 4 : OK *= (SECTION>=ARGDEB(ISEC) & SECTION<=ARGFIN(ISEC)
&                    &  left$(SECTION,len(ARGEXC(ISEC)))<>ARGEXC(ISEC))
        Endcase
        If !OK : Break : Endif
       Endif
      Next I
      If OK
       Raz MTDEB , MTCDT
       For [LBUD]CLE : # Exercice
        EXE = [F:BUD]FIY
        If EXE>=EDEB & EXE<=EFIN
         Gosub SUM_BUD
         If GOK<1 : Break 3 : Endif
        Endif
       Next : # Exercice
       If [L]DETCCE=2   : # Détail sections
        INDTXM += 1
        TYPMONT = 5
        INDDIE = find([F:BUP]DIE(0),[F:LED]DIE(0..[F:LED]DIENBR-1))
        If INDDIE : SECTION = evalue("[F:BUD]CCE"+num$(INDDIE)) : Endif
        AXE = [F:BUP]DIE(0)
        If [F:BUP]PYMCCE(0)=""
         Gosub EVAL_INFCCE From CALTBD
        Else
         Read [CRY]CRY0(2) = [F:BUP]PYMCCE(0);SECTION
         Call LECTEXTRA(CCEINF,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
        Endif
        Gosub ECR_BUD
       Endif
      Endif
     Next : # Sections
    Endif
    MTDEB  = SIT_CPTDEB(ISITE)
    MTCDT  = SIT_CPTCDT(ISITE)
    If DETACC=2
     INDTXM += 1
     TYPMONT = 2
     Gosub ECR_TXM From CALTBD
     If GOK<1 : Break 2 : Endif
    Endif
    # Cas où la formule traitée = GM() -L1. Il faut mettre à jour SAI_DEB
    For I=1 To NBSITE
     If (SIT_CPTDEB(I)<>0 or SIT_CPTCDT(I)<>0)
      SAI_DEB += SIT_CPTDEB(I)-SIT_CPTCDT(I)
     Endif
    Next I
   Next : # Nature
  Next ISOC : # Société
  Filter [LBUD]

 When 2 : # Site

  For ISOC=1 To NBSOC
   Call GET_LEDCUR(GACTX,TSOC(ISOC),NUMREF,CODLED,DEVLED,GMESSAGE) From FINACM_SYRA
   Call LEC_LED(CODLED) From CPTLEC
   Gosub CRITBUD
   If NBSITE=1
    Call ADDCRIT(CRITERE,ICRIT,'[BUD]FCY="'+TSITE(1)+'"') From CALTBD
    Call ADDCRIT(CRITERE,ICRIT,'[BUD]CPY="'+TSOC(ISOC)+'"') From CALTBD
   Else
    Call ADDCRIT(CRITERE,ICRIT,'find([BUD]FCY,TSITE(1..NBSITE))') From CALTBD
    Call ADDCRIT(CRITERE,ICRIT,'[BUD]CPY="'+TSOC(ISOC)+'"') From CALTBD
   Endif
   Filter [LBUD] Where evalue(CRITERE(1..ICRIT))
&   Order By Key CLE = [F:BUD]FCY;[F:BUD]ACC;[F:BUD]CCE1;[F:BUD]CCE2;[F:BUD]CCE3;
&                      [F:BUD]CCE4;[F:BUD]CCE5;[F:BUD]CCE6;[F:BUD]CCE7;[F:BUD]CCE8;[F:BUD]CCE9;[F:BUD]FIY

   For [LBUD]CLE(1) : # Site
    SITE = [F:BUD]FCY
    ISITE = find(SITE,TSITE(1..NBSITE))
    Gosub EVAL_INFSIT From CALTBD
    If ISITE
     EDEB = TEDEB(ISOC)
     EFIN = TEFIN(ISOC)
     PDEB = TPDEB(ISOC)
     PFIN = TPFIN(ISOC)
     For [LBUD]CLE(2) : # Nature
      Raz SIT_CPTDEB, SIT_CPTCDT
      NATURE = [F:BUD]ACC
      PLAN   = [F:BUD]COA
      If PLAN=""
       Read [CPY]CPY0 = TBSOC(ISOC)
       Read [GCM]GCM0 = [F:CPY]ACM
       Read [LED]LED0 = [F:GCM]LED(NUMREF-1)
       PLAN           = [F:LED]COA
      Endif
      COMPTE = NATURE

      Raz TYPNAT
      Call LEC_GAC(COMPTE,PLAN) From CPTLEC
      If !fstat : Call LEC_COA([F:GAC]COA) From CPTLEC : Endif
      If !fstat : Read [CLS]CLS0 = [F:COA]LEGCLS;[F:GAC]CLSCOD : Endif
      If !fstat : TYPNAT = [F:CLS]SNSANA : Endif

      If [F:BUP]PYMACC=""
       Gosub EVAL_INFACC From CALTBD
      Else
       Read [GRY]GRY0(2) = [F:BUP]PYMACC;NATURE
       Call LECTEXTRA(CPTINF,"GACCGRUPYM","DESTRA",[F:GRY]PYM,[F:GRY]GRU) From ATEXTRA
      Endif
      Case JOKER(INAT)
       When 0 : OK = (NATURE=ARG(INAT))
       When 1 : OK = pat(NATURE,ARG(INAT))
       When 2
        If [F:BUP]PYMACC=""
         Read [GYK]GYK0 = PYRAMIDE(INAT);PYRNIV(INAT);NATURE
         OK = (fstat=0 & [F:GYK]GRU=PYRGRP(INAT))
        Elsif PYRNIV(INAT)<[F:BUP]PYMACCLEV
         OK = find(NATURE,TBGRPNAT(1..NBGRPNAT))
        Else
         OK = 1
        Endif
       When 3 : OK = (NATURE>=ARGDEB(INAT) & NATURE<=ARGFIN(INAT))
       When 4 : OK = (NATURE>=ARGDEB(INAT) & NATURE<=ARGFIN(INAT)
&                  &  left$(NATURE,len(ARGEXC(INAT)))<>ARGEXC(INAT))
      Endcase
      If OK
       For [LBUD]CLE(11) : # Sections
        OK = 1
        For I=1 To [F:BUP]DIENBR
         If [F:BUP]DIE(I-1)<>"" or [F:BUP]PYMCCE(I-1)<>""
          INDDIE = find([F:BUP]DIE(I-1),[F:LED]DIE(0..[F:LED]DIENBR-1))
          If INDDIE : SECTION = evalue("[F:BUD]CCE"+num$(INDDIE)) : Endif
          ISEC = INAT+I
          Case JOKER(ISEC)
           When 0 : OK *= (SECTION=ARG(ISEC))
           When 1 : OK *= pat(SECTION,ARG(ISEC))
           When 2
            If [F:BUP]PYMCCE(I-1)=""
             Read [CYK]CYK0 = PYRAMIDE(ISEC);PYRNIV(ISEC);SECTION
             OK *= (fstat=0 & [F:CYK]GRU=PYRGRP(ISEC))
            Elsif PYRNIV(ISEC)<[F:BUP]PYMCCELEV(I-1)
             JJ = 0
             For II=1 To NBGRPSEC(I)
              If SECTION=TBGRPSEC(I,II)
               JJ = 1 : Break
              Endif
             Next II
             OK *= JJ
            Endif
           When 3 : OK *= (SECTION>=ARGDEB(ISEC) & SECTION<=ARGFIN(ISEC))
           When 4 : OK *= (SECTION>=ARGDEB(ISEC) & SECTION<=ARGFIN(ISEC)
&                      &  left$(SECTION,len(ARGEXC(ISEC)))<>ARGEXC(ISEC))
          Endcase
          If !OK : Break : Endif
         Endif
        Next I
        If OK
         Raz MTDEB , MTCDT
         For [LBUD]CLE : # Exercice
          EXE = [F:BUD]FIY
          If EXE>=EDEB & EXE<=EFIN
           Gosub SUM_BUD
           If GOK<1 : Break 3 : Endif
          Endif
         Next : # Exercice
         If [L]DETCCE=2   : # Détail sections
          INDTXM += 1
          TYPMONT = 5
          INDDIE = find([F:BUP]DIE(0),[F:LED]DIE(0..[F:LED]DIENBR-1))
          If INDDIE : SECTION = evalue("[F:BUD]CCE"+num$(INDDIE)) : Endif
          AXE = [F:BUP]DIE(0)
          If [F:BUP]PYMCCE(0)=""
           Gosub EVAL_INFCCE From CALTBD
          Else
           Read [CRY]CRY0(2) = [F:BUP]PYMCCE(0);SECTION
           Call LECTEXTRA(CCEINF,"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
          Endif
          Gosub ECR_BUD
         Endif
        Endif
       Next : # Sections
      Endif
      MTDEB = SIT_CPTDEB(ISITE)
      MTCDT = SIT_CPTCDT(ISITE)
      If DETACC=2
       INDTXM += 1
       TYPMONT = 2
       Gosub ECR_TXM From CALTBD
       If GOK<1 : Break 2 : Endif
      Endif
      # Cas où la formule traitée = GM() -L1. Il faut mettre à jour SAI_DEB
      For I=1 To NBSITE
       If (SIT_CPTDEB(I)<>0 or SIT_CPTCDT(I)<>0)
        SAI_DEB += SIT_CPTDEB(I)-SIT_CPTCDT(I)
       Endif
      Next I
     Next : # Nature
    Endif
   Next : # Site
  Next ISOC : # Société
  Filter [LBUD]
Endcase
Return

$SUM_BUD
If EDEB=EFIN
 PERDEB = max(0,PDEB-1) : PERFIN = PFIN-1
Elsif EXE=EDEB
 PERDEB = max(0,PDEB-1) : PERFIN = PMAX-1
Elsif EXE=EFIN
 PERDEB = 0 : PERFIN = PFIN-1
Else
 PERDEB = 0 : PERFIN = PMAX-1
Endif
If DEVPRN<>[F:BUP]CUR & TYPCOURS<>0
 Call CONVERT_TAB([F:BUD]CUR,DEVPRN,DEVPRN,TYPCOURS,datesyst,[F:BUD]AMT,[F:BUD]AMT,STAT) From TRTDEV
Endif
Case FONC
 When "GM"
  MTANA = sum([F:BUD]AMT(PERDEB..PERFIN))*SIGN
 When"GQ"
  MTANA = sum([F:BUD]QTY(PERDEB..PERFIN))*SIGN
Endcase
#If MTANA>0
# Si sum(..)>0 alors c'est un débit
If TYPNAT<>2 :# 1= Charge 2 = Produit
 #If SIGN=1
  MTDEB             += MTANA
  SIT_DEB(ISITE)    += MTANA
  SIT_CPTDEB(ISITE) += MTANA
 #Else
 # MTCDT             += MTANA
 # SIT_CDT(ISITE)    += MTANA
 # SIT_CPTCDT(ISITE) += MTANA
 #Endif
Else :# Produit
 #If SIGN=1
  MTCDT             += MTANA
  SIT_CDT(ISITE)    += MTANA
  SIT_CPTCDT(ISITE) += MTANA
 #Else
 # MTDEB             += MTANA
 # SIT_DEB(ISITE)    += MTANA
 # SIT_CPTDEB(ISITE) += MTANA
 #Endif
Endif
Return

#
# Critères de sélection et liens sur la table budget
#

$CRITBUD
LNKNAT = 0
LNKSEC = 0
Raz CRITERE
ICRIT = 1
Call ADDCRIT(CRITERE,ICRIT,'[BUD]LEDTYP='+num$(NUMREF)) From CALTBD
Call ADDCRIT(CRITERE,ICRIT,'[BUD]BUD="'+C_BUD+'"') From CALTBD
Call ADDCRIT(CRITERE,ICRIT,'[BUD]VER="'+V_BUD+'"') From CALTBD
If TEDEB(ISOC)=TEFIN(ISOC)
 Call ADDCRIT(CRITERE,ICRIT,'[BUD]FIY='+num$(TEDEB(ISOC))) From CALTBD
Else
 Call ADDCRIT(CRITERE,ICRIT,'[BUD]FIY>='+num$(TEDEB(ISOC))+' & [BUD]FIY<='+num$(TEFIN(ISOC))) From CALTBD
Endif
If [F:BUP]PYMACC="" : # Budget au niveau détail nature
 Case JOKER(INAT)
  When 0,1
   Call ADDJOK(CRITERE,ICRIT,'ACC',ARG(INAT)) From CALTBD
  When 2
   Call ADDCRIT(CRITERE,ICRIT,'[GYK]GRU="'+PYRGRP(INAT)+'"') From CALTBD
   LNKNAT = 1
  When 3
   Call ADDCRIT(CRITERE,ICRIT,'ACC>="'+ARGDEB(INAT)+'"') From CALTBD
   Call ADDCRIT(CRITERE,ICRIT,'ACC<="'+ARGFIN(INAT)+'"') From CALTBD
  When 4
   Call ADDCRIT(CRITERE,ICRIT,'ACC>="'+ARGDEB(INAT)+'"') From CALTBD
   Call ADDCRIT(CRITERE,ICRIT,'ACC<="'+ARGFIN(INAT)+'"') From CALTBD
   Call ADDCRIT(CRITERE,ICRIT,'left$(ACC,'+num$(len(ARGEXC(INAT)))+')<>"'+ARGEXC(INAT)+'"') From CALTBD
 Endcase
Elsif PYRNIV(INAT)=[F:BUP]PYMACCLEV
 Call ADDCRIT(CRITERE,ICRIT,'ACC="'+PYRGRP(INAT)+'"') From CALTBD
Endif
For I=1 To [F:BUP]DIENBR
 INDDIE = find([F:BUP]DIE(I-1),[F:LED]DIE(0..[F:LED]DIENBR-1))
 If INDDIE
  ISEC = INAT+I
  If [F:BUP]PYMCCE(I-1)=""
   Case JOKER(ISEC)
    When 0,1
     Call ADDJOK(CRITERE,ICRIT,'CCE'+num$(INDDIE),ARG(ISEC)) From CALTBD
    When 2
     If LNKSEC=0
      Call ADDCRIT(CRITERE,ICRIT,'[CYK]GRU="'+PYRGRP(ISEC)+'"') From CALTBD
      LNKSEC = I
      KSEC   = ISEC
     Endif
    When 3
     Call ADDCRIT(CRITERE,ICRIT,'CCE'+num$(INDDIE)+'>="'+ARGDEB(ISEC)+'"') From CALTBD
     Call ADDCRIT(CRITERE,ICRIT,'CCE'+num$(INDDIE)+'<="'+ARGFIN(ISEC)+'"') From CALTBD
    When 4
     Call ADDCRIT(CRITERE,ICRIT,'CCE'+num$(INDDIE)+'>="'+ARGDEB(ISEC)+'"') From CALTBD
     Call ADDCRIT(CRITERE,ICRIT,'CCE'+num$(INDDIE)+'<="'+ARGFIN(ISEC)+'"') From CALTBD
     Call ADDCRIT(CRITERE,ICRIT,'left$(CCE'+num$(INDDIE)+','+num$(len(ARGEXC(ISEC)))+')<>"'+ARGEXC(ISEC)+'"') From CALTBD
   Endcase
  Elsif PYRNIV(ISEC)=[F:BUP]PYMCCELEV(I-1)
   Call ADDCRIT(CRITERE,ICRIT,'CCE'+num$(INDDIE)+'="'+PYRGRP(ISEC)+'"') From CALTBD
  Endif
 Endif
Next I

If LNKNAT
 Case LNKSEC
  When 0
   Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BUD]ACC   As [LBUD]
  When 1
   Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BUD]ACC
&                , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE1  As [LBUD]
  When 2
   Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BUD]ACC
&                , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE2  As [LBUD]
  When 3
   Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BUD]ACC
&                , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE3  As [LBUD]
  When 4
   Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BUD]ACC
&                , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE4  As [LBUD]
  When 5
   Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BUD]ACC
&                , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE5  As [LBUD]
  When 6
   Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BUD]ACC
&                , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE6  As [LBUD]
  When 7
   Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BUD]ACC
&                , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE7  As [LBUD]
  When 8
   Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BUD]ACC
&                , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE8  As [LBUD]
  When 9
   Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                , [GYK]GYK0 ~= PYRAMIDE(INAT);PYRNIV(INAT);[F:BUD]ACC
&                , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE9  As [LBUD]
  Endcase
 Else
  Case LNKSEC
   When 0
    Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC As [LBUD]
   When 1
    Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE1  As [LBUD]
   When 2
    Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE2  As [LBUD]
   When 3
    Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE3  As [LBUD]
   When 4
    Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE4  As [LBUD]
   When 5
    Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE5  As [LBUD]
   When 6
    Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE6  As [LBUD]
   When 7
    Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE7  As [LBUD]
   When 8
    Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE8  As [LBUD]
   When 9
    Link [BUD] With [GAC]GAC0  = [F:BUD]COA;[F:BUD]ACC
&                 , [CYK]CYK0 ~= PYRAMIDE(KSEC);PYRNIV(KSEC);[F:BUD]CCE9  As [LBUD]
  Endcase
 Endif
Return

# Ecriture détail budget

$ECR_BUD
Raz [F:TXM]
[F:TXM]TXSNAM  = [M]TXSNAM
[F:TXM]VERSION = [M]VERSION
[F:TXM]LIG     = IL
[F:TXM]COL     = IC+1
[F:TXM]IND     = INDTXM
[F:TXM]AMTDEB  = num$(MTDEB)
[F:TXM]AMTCDT  = num$(MTCDT)
[F:TXM]AMTVAL  = num$(MTDEB - MTCDT)
[F:TXM]FCY     = SITE
[F:TXM]COA     = PLAN
[F:TXM]ACC     = NATURE
For I=1 To [F:BUP]DIENBR
 Assign "[F:TXM]DIE"+num$(I) With [F:BUP]DIE(I-1)
 INDDIE = find([F:BUP]DIE(I-1),[F:LED]DIE(0..[F:LED]DIENBR-1))
 If INDDIE
  Assign "[F:TXM]CCE"+num$(I) With evalue("[F:BUD]CCE"+num$(INDDIE))
 Endif
Next
[F:TXM]FCYINF  = SITINF
[F:TXM]ACCINF  = CPTINF
[F:TXM]TYPAMT  = TYPMONT
[F:TXM]CCEINF  = CCEINF
Write [TXM]
If fstat
 GOK=0 : Call FSTA("TXM") From GLOCK
Endif
Return

