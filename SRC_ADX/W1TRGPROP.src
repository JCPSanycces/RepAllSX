#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque TRGPROP 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:15:56"
A_USER  = "DOC"
A_STAMP = "20181109231556"
Return

$TITRES
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask TRGPROP [TRGP]
Gosub HORODAT
Local Inpbox "TRGPROP" From GFONCTION At A_STAMP With A_WINDPREV Mask [TRGP] As [SIM_]
Grizo [TRGP]5
Grizo [TRGP]10
Grizo [TRGP]20
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [TRGP]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=20 : X2(0)=93 : Y1(0)=8 : Y2(0)=10
X1(1)=20 : X2(1)=93 : Y1(1)=11 : Y2(1)=17
X1(2)=20 : X2(2)=93 : Y1(2)=18 : Y2(2)=20
Return

$ON_DATDEB
Onevent BEFORE_AREA Gosub AV_DATDEB From W1TRGPROP
Return

$AV_DATDEB
Chgfmt [M]DATDEB(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_DATFIN
Onevent BEFORE_AREA Gosub AV_DATFIN From W1TRGPROP
Return

$AV_DATFIN
Chgfmt [M]DATFIN(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_SUBMITTER
Onevent INIT_AREA Call D_SUBMITTER(zc) From W1TRGPROP
Onevent BEFORE_INPUT Call AS_SUBMITTER(zc) From W1TRGPROP
Return

Subprog D_SUBMITTER(VALEUR)
Variable Integer VALEUR
If varinit([M]SUBMITTER,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_SUBMITTER(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_DFV
Onevent AFTER_CHANGE Gosub AMM_DFV From W1TRGPROP
Onevent INIT_AREA Call D_DFV(zc) From W1TRGPROP
Onevent BEFORE_INPUT Call AS_DFV(zc) From W1TRGPROP
Return

Subprog D_DFV(VALEUR)
Variable Integer VALEUR
If varinit([M]DFV,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_DFV(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_DFV
Call AM_DFV(zc)
If !mkstat & GOBJET
 zoncou = "DFV" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_DFV(VALEUR)
Variable Integer VALEUR
## Action STD
Call AM_DFV(VALEUR) From TRGP
If mkstat : GERR = 1 : GZONE = "DFV" : GZNUM = 49958 : Endif
Gosub _AFF
End

