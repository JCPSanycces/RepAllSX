#<AdxTL>@(#)5.0.0.0 $Revision$
#########################################################################
# Contient les traitements utilisée pour la modélisation                #
# Etiquettes                                                            #
#########################################################################
#    ACTION MODELISATION E-COMMERCE                                     #
#                                                                       #
# GACTION  : TRTAUTSOF  : Action suppression automatique OF             #
#                                                                       #
#########################################################################
$ACTION
Case ACTION
 When "INIT"          : Gosub INIT
 When "INIT_DIA"      : Gosub INIT_DIA
 When "CONTROLE"      : Gosub CONTROLE
 When "EXEC"          : Gosub EXEC
 When "TERMINE"       : Gosub TERMINE
 When Default
Endcase
Return

#########################################################################
$INIT
# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub OUVRE
Return

#########################################################################
$INIT_DIA
# titre de la boîte
TIT = mess(127,195,1)
Raz [M:DIA]

Return

#########################################################################
$CONTROLE
If !GSERVEUR             &
&  [M:DIA]MFGNUMDEB = "" &
&  [M:DIA]MFGNUMFIN = "" &
&  [M:DIA]PJTDEB    = "" &
&  [M:DIA]PJTFIN    = "" &
&  [M:DIA]BPCNUMDEB = "" &
&  [M:DIA]BPCNUMFIN = "" &
&  [M:DIA]VCRNUMDEB = "" &
&  [M:DIA]VCRNUMFIN = "" &
&  [M:DIA]ITMREFDEB = "" &
&  [M:DIA]ITMREFFIN = "" &
&  [M:DIA]STRDATDEB = [0/0/0] &
&  [M:DIA]STRDATFIN = [0/0/0] &
&  [M:DIA]FORMULE   = ""
   GERR = 3
   GMESSAGE = mess(64,190,1)
   FOK = 0
   Return
Endif
TIT=" "
TMP=1
Return

#########################################################################
$EXEC
If !GSERVEUR
    TRA = 1
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("MAUTSUP","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

# préparation des critères de filtre
Gosub SEL_OF

# traitement des OF
Gosub TRT_OF

# V6 Réseaux MTO  FQ 46650
Gosub TRT_MTO
Return

#########################################################################
$TERMINE
If !GSERVEUR
    # fermeture trace
    Call FERME_TRACE From LECFIC
    # aucune suppression effectuee ou lecture trace
    If !NBOF & !NBMTO    : # FQ 46650
         GERR = 2 : GMESSAGE = mess(88,193,1)
    Endif
    # lecture trace
Endif
Return
########################################################################
$OUVRE
Local Integer  OK
Local Integer  NBOF,NBMTO
Local Integer  WFLGALL
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)
# sr 09.01 CUSFLT zone de filtres supplémentaires demande 10405
Local Char     CUSFLT(255)
#
Local Char     FORMULE1(255)
Local Char     WMESS(85)
Local Char     WMESS1(85)
Local Char     WMESS2(85)
Local Integer  WRET
Local Char     WITMREF
Local Char     WSTOFCY (GLONFCY)
Local Char     WVCRNUM
Local Integer  WVCRLIN
Local Date     WSTRDAT
Local Integer  WSTA

Gosub CHARG_PARAM
#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE      [MFO]  : Endif
If clalev([F:MFP])  = 0 : Local File MFGPRN      [MFP]  : Endif
If clalev([F:OPS])  = 0 : Local File OPERATIONS  [OPS]  : Endif
If clalev([F:SCH])  = 0 : Local File SCHEDULING  [SCH]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif
If clalev([F:ITV])  = 0 : Local File ITMMVT      [ITV]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT  [ITF]  : Endif
If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO]  : Endif
If clalev([F:PTO])  = 0 : Local File PARMTO      [PTO]  : Endif

# --- Déclaration classes ecran --- #
Local Mask ORDK    [ORDK]
Local Mask MFGK    [MFGK]


Return

########################################################################
# Préparation du filtre sur la table encours (WOx)                     #
########################################################################
$SEL_OF
Raz CRITERE
Raz CRITERE1
Raz CRITERE2

If [M:DIA]WOSFLG = 2
    CRITERE  = "WIPSTA=3"
    Gosub LOAD_CRITERE
Endif

If [M:DIA]WOPFLG = 2
    CRITERE  = "WIPSTA=2"
    Gosub LOAD_CRITERE
Endif

If [M:DIA]WOFFLG = 2
    CRITERE  = "WIPSTA=1"
    Gosub LOAD_CRITERE
Endif

# fin de la première partie
CRITERE1 += ")"

CRITERE = "WIPTYP=5"
Gosub LOAD_CRITERE2

CRITERE  = "STOFCY = [M:DIA]MFGFCY"                     # site de production
Gosub LOAD_CRITERE2

If [M:DIA]MFGNUMDEB <> ""                               # borne début OF
   CRITERE = "VCRNUM >= [M:DIA]MFGNUMDEB"
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]MFGNUMFIN <> ""                               # borne fin   OF
   CRITERE = "VCRNUM <= [M:DIA]MFGNUMFIN"
   Gosub LOAD_CRITERE2
Endif

# affaire
If [M:DIA]PJTDEB <> ""
   CRITERE = "PJT >= [M:DIA]PJTDEB"                     # borne début affaire
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]PJTFIN <> ""
   CRITERE = "PJT <= [M:DIA]PJTFIN"                     # borne fin   affaire
   Gosub LOAD_CRITERE2
Endif

# destinataire
If [M:DIA]BPCNUMDEB <> ""
   CRITERE = "BPRNUM >= [M:DIA]BPCNUMDEB"               # borne début destin.
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]BPCNUMFIN <> ""
   CRITERE = "BPRNUM <= [M:DIA]BPCNUMFIN"               # borne fin   destin.
   Gosub LOAD_CRITERE2
Endif

# no commande
If [M:DIA]VCRNUMDEB <> ""
   CRITERE = "VCRNUMORI >= [M:DIA]VCRNUMDEB"            # borne début n° commande
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]VCRNUMFIN <> ""
   CRITERE = "VCRNUMORI <= [M:DIA]VCRNUMFIN"            # borne fin   n° commande
   Gosub LOAD_CRITERE2
Endif

If [M:DIA]ITMREFDEB <> ""
   CRITERE = "ITMREF >= [M:DIA]ITMREFDEB"               # borne début article lancé
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]ITMREFFIN <> ""
   CRITERE = "ITMREF <= [M:DIA]ITMREFFIN"               # borne fin   matière
   Gosub LOAD_CRITERE2
Endif

If [M:DIA]STRDATDEB <> [0/0/0]
   CRITERE = "STRDAT >= [M:DIA]STRDATDEB"               # borne début date
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]STRDATFIN <> [0/0/0]
   CRITERE = "STRDAT <= [M:DIA]STRDATFIN"               # borne fin   date
   Gosub LOAD_CRITERE2
Endif


Gosub ANALYSE_FORMULE
If FORMULE1 = "" : FORMULE1 = "1=1" : Endif


Return

##################################################
$ANALYSE_FORMULE
# analyse présence formule de sélection
If [M:DIA]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
Else
    Read [F:TFO]TFO0=10;[M:DIA]FORMULE
    If fstat
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif
    Else
        If FORMULE1 = ""
            FORMULE1  = [F:TFO]FORFOR
        Else
            FORMULE1 += "&"
            FORMULE1 += [F:TFO]FORFOR
        Endif
    Endif
Endif

Return


############################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

############################################################
$LOAD_CRITERE2
If len(CRITERE)+len(CRITERE1)+1 < 225
  CRITERE1 += "&"
  CRITERE1 += CRITERE
Else
  If CRITERE2 <> ""
     CRITERE2 += "&"
  Endif
  CRITERE2 += CRITERE
Endif
Return



#---------------------------------------------------------------------#
# Traitement des ordres                                               #
#---------------------------------------------------------------------#
$TRT_OF
# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
# sr 09.01 demande 10405
Raz CUSFLT
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif
#
If CRITERE2 <> ""
    Filter [ORD] Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CUSFLT) & evalue(FORMULE1)
&                      Order By Key ORD0
Else
    Filter [ORD] Where evalue(CRITERE1) & evalue(CUSFLT) & evalue(FORMULE1)
&                      Order By Key ORD0
Endif
# boucle de lecture
For  [ORD]
      WITMREF = [F:ORD]ITMREF
      WSTOFCY = [F:ORD]STOFCY
      WVCRNUM = [F:ORD]VCRNUM
      WVCRLIN = [F:ORD]VCRLIN
      WSTRDAT = [F:ORD]STRDAT
      WSTA    = [F:ORD]WIPSTA
      If find([F:ORD]WIPSTA,1,2)
          Gosub SEL_OFCOMPL
          If OK = 1 : Goto NXT2 : Endif
      # Issue X3-26129 - 2017-02-02 by ALSHE : Exclude WOS in status "Being Optimized"
      Elsif [F:ORD]OPTFLG = 2
          Goto NXT2
      Endif
      #
      Gosub TRTSUP
$NXT2
Next
#
Filter [ORD]
#
Return

#-----------------------------------------------------------------------#
# Sélections complémentaires                                            #
#-----------------------------------------------------------------------#
$SEL_OFCOMPL

OK=1
# lecture article
If [F:ITM]ITMREF <> WITMREF
    Read [ITM]ITM0=WITMREF
    If fstat : Raz [F:ITM] : Return : Endif
Endif

# lecture article/site
If [F:ITF]ITMREF <> WITMREF | [F:ITF]STOFCY <> WSTOFCY
    Read [ITF]ITF0=WITMREF;WSTOFCY
    If fstat : Raz [F:ITF] : Return : Endif
Endif

# règle
If [F:ITF]PTOCOD <> ""
    Read [F:PTO]PTO0=[F:ITF]PTOCOD
    If fstat : Raz [PTO] : Endif
Endif
If [F:PTO]PTOCOD = ""
    Read [F:PTO]PTO0=GDEFPTO
    If fstat : Raz [PTO] : Endif
Endif

Call CHECK_FRCQTY(WSTOFCY, WITMREF, 10, WVCRNUM, WVCRLIN, 0, 5, WRET) From MTOLINKLIB
If WRET
    If [F:PTO]FRCPRO <> 2 : Return : Endif
Endif

# lecture enregistrement entête OF
Read [MFG]MFG0=WVCRNUM
If fstat : Raz [F:MFG] : Return : Endif

#
If [F:MFG]MFGTRKFLG > 3 : Return : Endif
# Issue X3-26129 - 2017-02-02 by ALSHE : Also exclude WO in status "Optimized"
# If [F:MFG]OPTFLG = 2    : Return : Endif
If [F:MFG]OPTFLG = 2 | [F:MFG]SCDFLG = 4          : Return : Endif
If [M:DIA]ALLFLG = 1 & [F:MFG]ALLSTA > 1          : Return : Endif
If [M:DIA]JALFLG = 1 & [F:MFG]SCDFLG > 1          : Return : Endif


# Suppression interdite si OF déjà pris en compte dans le plan de pesée - 49287 mm 09.08 + mm 05.11
If dim([F:MFG]WGGFLG) > 0 & find([F:MFG]WGGFLG,3,4,8)
    WMESS = mess(156,197,1)+" "+mess(WSTA,317,1)+" "+WVCRNUM+" "
    Call ECR_TRACE(WMESS + mess(235,190,1),0) From GESECRAN
    Return
Endif

# 01.07 demande 39076
# filtres supplementaires
GPE = 1
GPOINT = "MFGFLTSUP" : Gosub ENTREE From EXEFNC
If !GPE : Return : Endif
#
OK=2
Return

#-----------------------------------------------------------------------#
# Traitement suppression                                                #
#-----------------------------------------------------------------------#
$TRTSUP
# FQ 67806 GA 11/2010 PE BEFTRTLIG idem FUNMAUTO
Local Integer GPE : GPE=1
GPOINT = "BEFTRTLIG" : Gosub ENTREE From EXEFNC
If !GPE Return Endif

Gosub VERROU
If !OK : Return : Endif
Call DEBTRANS From GLOCK
GOK = 1
Gosub MAJSUP
Gosub DEVERROU
Return

#-----------------------------------------------------------------------#
# Suppression                                                           #
#-----------------------------------------------------------------------#
$MAJSUP
#
WMESS   = mess(156,197,1)+" "+mess(WSTA,317,1)+" "+WVCRNUM+" "+mess(175,197,1)
#
Trbegin [MFG]
    Raz [MFGK]
    [M:MFGK]CODMAJ     = "A"
    [M:MFGK]CODTRS     = 0
    [M:MFGK]MFGNUM     = WVCRNUM
    [M:MFGK]MFGLIN     = WVCRLIN
    [M:MFGK]MFGFCY     = WSTOFCY
    [M:MFGK]MFGSTA     = WSTA
    [M:MFGK]ITMREF     = WITMREF
    [M:MFGK]AUTOTRT    = 2                      # Issue 87289 GA 01/2013 pour résultat en trace
    [M:MFGK]PRVQTY     = [F:ORD]EXTQTY
    [M:MFGK]EXTQTY     = [F:ORD]EXTQTY
    [M:MFGK]VCRTYPORI  = [F:ORD]VCRTYPORI
    [M:MFGK]VCRNUMORI  = [F:ORD]VCRNUMORI
    [M:MFGK]VCRLINORI  = [F:ORD]VCRLINORI
    [M:MFGK]VCRSEQORI  = [F:ORD]VCRSEQORI
    [M:MFGK]WIPTYP     = [F:ORD]WIPTYP
    [M:MFGK]WIPNUM     = [F:ORD]WIPNUM
    [M:MFGK]FMI        = [F:ORD]FMI
    # MM 05.04 demande 22363 Point d'entrée permettant de mettre à jour des tables spécifiques
    GPOINT = "SUPPOFMAJ" : Gosub ENTREE From EXEFNC
    Call MAJ_OF From MFGAUTLIB
    If [M:MFGK]CODRET <> 0 : Goto AB_TRTSUP : Endif

    # traces
    Call ECR_TRACE(WMESS,0) From GESECRAN
    Raz WMESS, WMESS1, WMESS2
    NBOF += 1
Commit
Return


#-----------------------------------------------------------------------#
# Positionnement d'un verrou sur l'entête OF                            #
#-----------------------------------------------------------------------#
$VERROU
SYMBOLE = "MFG"+[F:MFG]MFGNUM
Lock = SYMBOLE With lockwait = 0
OK = 1
If fstat
    Call ECR_TRACE([F:MFG]MFGNUM - mess(10,100,1),1) From GESECRAN
    OK = 0
Endif
Return

#-----------------------------------------------------------------------#
# Suppression du verrou sur l'entête OF                                 #
#-----------------------------------------------------------------------#
$DEVERROU
Unlock=SYMBOLE
Return

$ROL_TRTSUP
Rollback
Call ROLL From GLOCK
If GROLL
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Else Goto MAJSUP : Endif
Return

$AB_TRTSUP
Rollback
# Issue X3-23527 - 2017-02-02 by ALSHE : No message when using PS and WO is in status "Being optimized" or "Optimized"
If (func AFNC.ACTIV("POPS") & ([F:MFG]OPTFLG=2 | [F:MFG]SCDFLG=4))
    NBOF += 1
Else
    Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Endif
OK=1
Return

########################################################################
$CHARG_PARAM
#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return


#---------------------------------------------------------------------#
# V6 Traitement des Réseaux MTO                                       #
# - suppression des réseaux MTO n'ayant plus d'OF/EO rattachés        #
#---------------------------------------------------------------------#
$TRT_MTO   : # FQ 46650
If dim([M]MTOFLG)<0 | [M]MTOFLG<2 Return Endif

If clalev([F:MTO])<=0 : Local File MTOHEAD [F:MTO] : Endif
If clalev([F:MFG])<=0 : Local File MFGHEAD [F:MFG] : Endif
If clalev([F:SCO])<=0 : Local File SCOHEAD [F:SCO] : Endif
For [F:MTO]MTO0
   Read [F:MFG]MFG2=[F:MTO]MTOREF
   If !fstat Goto NXT_MTO : Endif : # si OF trouvé, on passe au suivant

   Read [F:SCO]SCO2=[F:MTO]MTOREF
   If !fstat Goto NXT_MTO : Endif : # si EO trouvé, on passe au suivant

   Delete [F:MTO]
   Call ECR_TRACE(mess(85,187,1)-":"-[F:MTO]MTOREF-mess(377,177,1),0) From GESECRAN

   NBMTO += 1

$NXT_MTO
Next

Return


#######################################################################
#                     ETIQUETTES                                      #
#######################################################################

########################################
Subprog B1_BPCNUMDEB(VALEUR)
Variable Char    VALEUR()
# 06.03 WEB MM
If dim (GBPRSEL)>0  : Kill GBPRSEL : Endif
#
End

########################################
Subprog AS_BPCNUMDEB(VALEUR)
Variable Char    VALEUR()
GBOUT1=mess(72,198,1)
GBOUT2=mess(154,198,1)
End

########################################
Subprog B1_BPCNUMFIN(VALEUR)
Variable Char    VALEUR()
# 06.03 WEB MM
If dim (GBPRSEL)>0  : Kill GBPRSEL : Endif
#
End

########################################
Subprog AS_BPCNUMFIN(VALEUR)
Variable Char    VALEUR()
GBOUT1=mess(72,198,1)
GBOUT2=mess(154,198,1)
End


########################################
Subprog C_STRDATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:DIA]STRDATDEB : mkstat = 2 : Endif
End

########################################
Subprog AM_MFGNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]MFGNUMFIN = VALEUR : Endif
End

########################################
Subprog AM_PJTDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]PJTFIN = VALEUR : Endif
End

########################################
Subprog AM_BPCNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]BPCNUMFIN = VALEUR : Endif
End

########################################
Subprog AM_VCRNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]VCRNUMFIN = VALEUR : Endif
End

########################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]ITMREFFIN = VALEUR : Endif
End

########################################
Subprog C_WOFFLG(VALEUR)
Variable Integer VALEUR
If [M:DIA]WOSFLG = 1 &
&  [M:DIA]WOPFLG = 1 &
&  VALEUR = 1
    mkstat = 2
    GERR = 1 : GMESSAGE = mess(359,199,1) # une case au moins doit être cochée !
Endif
End

##########################################################################
# pour les batchs                                                        #
##########################################################################
Subprog PARAM(DOSSIER,USER,P1,P2,OK)
#-----------------------------#
# obligatoire pour les batchs #
#-----------------------------#
Value    Char    DOSSIER   : # dossier de lancement
Value    Char    USER      : # utilisateur
Variable Char    P1()(1..) : # on peut avoir 2 fois 50 chaînes de 15 caractères
Variable Char    P2()(1..)
Variable Integer OK

Gosub OUVRE

Local Char    WIN (GLONFEN)
WIN="DAUTSOF"
Call PARAM (DOSSIER,USER,P1,P2,OK,TIT,WIN) From CPTTRT

End
###########################################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End



########################################
Subprog AM_MFGFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY                   # mm 12.02
    GFCY=VALEUR                     # mm 12.02
    Gosub CHARG_PARAM
Endif                               # mm 12.02
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran MAUTSUP) 01/02/2006 10:22:16 (LLCX)
######################################################################################
Subprog AS_VCRNUMDEB(VALEUR)
Variable Char    VALEUR()
[M]ORDFILTER = "1=1"
If [M]BPCNUMDEB <> "" : [M]ORDFILTER += "&BPRNUM>=[M]BPCNUMDEB" : Endif
If [M]BPCNUMFIN <> "" : [M]ORDFILTER += "&BPRNUM<=[M]BPCNUMFIN" : Endif
If [M]PJTDEB    <> "" : [M]ORDFILTER += "&PJT>=[M]PJTDEB"       : Endif
If [M]PJTFIN    <> "" : [M]ORDFILTER += "&PJT<=[M]PJTFIN"       : Endif
End

Subprog AS_VCRNUMFIN(VALEUR)
Variable Char    VALEUR()
[M]ORDFILTER = "1=1"
If [M]BPCNUMDEB <> "" : [M]ORDFILTER += "&BPRNUM>=[M]BPCNUMDEB" : Endif
If [M]BPCNUMFIN <> "" : [M]ORDFILTER += "&BPRNUM<=[M]BPCNUMFIN" : Endif
If [M]PJTDEB    <> "" : [M]ORDFILTER += "&PJT>=[M]PJTDEB"       : Endif
If [M]PJTFIN    <> "" : [M]ORDFILTER += "&PJT<=[M]PJTFIN"       : Endif
End


######################################################################################

