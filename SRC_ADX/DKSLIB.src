#<AdxTL>@(#)6.0.0.0 $Revision$
##########################################################################################
##########################################################################################
### Revisions
### rev 00.01 - Changes on the DKSSTAFLG Subprog
###           01 -> Basic type nomeclatures changed according to the SAFT-PT rules
###           02 -> if it's not a dks counter and the document is not external,
###                 it should raise an error
###           03 -> With rev 00.02, checking docbastyp utilization is no longer
###                 needed.
### rev 00.02 - Document number will be checked against a legal format.
###           01 -> Added the CHECKCOUNTER label to check the counter conformity
###                 with document type. Documento type field lenght should be 3.
###                 Counter code should be equal to document type (with PT prefix
###                 if v6).
###           02 -> Ckeck document number format. Format is:
###                 doc type + minus sign + site + period + slash + seq number
### rev 00.03 - Counter related changes
###           01 -> We will allow not having the minus sign in the counter
###           02 -> If [SIH]UPDDAT its empty, use date$ for VALIDDAT
###           03 -> adapt the year and month to the nunber of characters defined in the counter
### rev 00.04 * 30-08-2011 * RMA * LEG Field was added to TABSIVTYP (it's part of the primary key)
###           01 -> We will get the LEG from the FACILITY table to read TSV
### rev 00.05 - Counters having "Chronological control" option activated
###             (for those having this option activated, the difference between defined length of
###              facility en the actual length is filled with "_"). Exp: FCL-ASN_111/....
##########################################################################################
##########################################################################################
###
##########################################################################################
##########################################################################################
###                                                                                    ###
###                                 INVOICE CREATION                                   ###
###                                                                                    ###
##########################################################################################
##########################################################################################
### Triggering the right init action, only SAFT-PT for now
#   if multiple legislations are active, and digital signature activated for 2
#   legislations, it will be necessary to trigger according to the current
#   legislation using a "case"
##########################################################################################
##########################################################################################
$DKS_INICRE_TRIGGER

Local Char    DKSKEY(10)  : DKSKEY  = "SAFT-PT"

Local Char DKSFCY(GLONFCY) : DKSFCY=""
Local Char DKSTYP(GLONTSV) : DKSTYP=""

If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([F:DKD]) : Local File DKSDATA    [DKD] : Endif
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
If !clalev([F:GTE]) : Local File GTYPACCENT [GTE] : Endif

Case DKSORIG
  When "SIH0" : [L]DKSFCY=[M:SIH0]SALFCY : [L]DKSTYP = [M:SIH0]SIVTYP
                If !clalev([F:TSV]) : Local File TABSIVTYP  [TSV] : Endif
                Default File [SIV]
  When "BIC0" : [L]DKSFCY=[F:SIH]FCY     : [L]DKSTYP = [M:BIC0]SIVTYP
                If !clalev([F:TSV]) : Local File TABSIVTYP  [TSV] : Endif
                Default File [SIH]
  When "SIV"  : [L]DKSFCY=[F:SIV]SALFCY  : [L]DKSTYP = [F:SIV]SIVTYP
                If !clalev([F:TSV]) : Local File TABSIVTYP  [TSV] : Endif
                Default File [SIV]
  When "SIH"  : [L]DKSFCY=[F:SIH]FCY     : [L]DKSTYP = [F:SIH]SIVTYP  #unpaye
                If !clalev([F:TSV]) : Local File TABSIVTYP  [TSV] : Endif
                Default File [SIH]
  When "PIH0" : [L]DKSFCY=[M:PIH0]FCY    : [L]DKSTYP = [M:PIH0]PIVTYP
                If !clalev([F:TPV]) : Local File TABPIVTYP  [TPV] : Endif
                Default File [PIV]
  When "BIS0" : [L]DKSFCY=[F:PIH]FCY     : [L]DKSTYP = [M:BIS0]PIVTYP
                If !clalev([F:TPV]) : Local File TABPIVTYP  [TPV] : Endif
                Default File [PIH]
  When "HEA"  : [L]DKSFCY=[F:HEA]FCY     : [L]DKSTYP = [F:HEA]SIVTYP  #fixed assets
                If !clalev([F:TSV]) : Local File TABSIVTYP  [TSV] : Endif
                Default File [HEA]
  When "TSIH" : [L]DKSFCY=[F:TSIH]FCY    : [L]DKSTYP = [F:TSIH]SIVTYP #recurring invoice - customer
                If !clalev([F:TSV]) : Local File TABSIVTYP  [TSV] : Endif
                Default File [TSIH]
  When "TPIH" : [L]DKSFCY=[F:TPIH]FCY    : [L]DKSTYP = [F:TPIH]PIVTYP #recurring invoice - supplier
                If !clalev([F:TPV]) : Local File TABPIVTYP  [TPV] : Endif
                Default File [TPIH]
  When Default
Endcase

If [F:FCY]FCY <> [L]DKSFCY
  Read [F:FCY]FCY0 = [L]DKSFCY
Endif

If [F:CPY]CPY <> [F:FCY]LEGCPY
  Read [F:CPY]CPY0 = [F:FCY]LEGCPY
Endif

If func AFNC.PARAM("PORDKS",DKSFCY)="2"
  Gosub DKS_INICRE
Endif

Return
##########################################################################################
##########################################################################################
$DKS_INICRE
# ----------------------------------------------------------- #
#          DKS activity code related (SAFT-PT)                #
# Check if we have to create a record in the DKSDATA table    #
# and, if so, do it.                                          #
# ----------------------------------------------------------- #
Local Integer DKSSTA   : DKSSTA  = 0
Local Integer WRET

Case DKSORIG
  When "SIH0"
    Call LEC_TSV_LEG(GCURLEG,DKSTYP,WRET) From TRTLECLEG
    If  [F:TSV]INVTYP = 5 : Return : Endif
    If GMANCOU = 2 & [F:TSV]RECTYP <> 4 : GMESSAGE = mess(84,7711,1) : Call MESSAGE (GMESSAGE) From GESECRAN : GOK = 0 : DKSRET = 0 : Return : Endif
    Gosub DOCUMENT
    Default File [SIV]

  When "TSIH":
    Call LEC_TSV_LEG([F:CPY]LEG,DKSTYP,WRET) From TRTLECLEG
    If  [F:TSV]INVTYP = 5 : Return : Endif
    If [F:GTE]MANNUM = 2 & [F:TSV]RECTYP <> 4 : GMESSAGE = mess(84,7711,1) : Call MESSAGE(GMESSAGE) From GESECRAN : GOK = 0 : Return : Endif
    Gosub DOCUMENT
    Default File [TSIH]

  When "SIV":
    Call LEC_TSV_LEG([F:CPY]LEG,DKSTYP,WRET) From TRTLECLEG
    If  [F:TSV]INVTYP = 5 : Return : Endif
    If [F:GTE]MANNUM = 2 & [F:TSV]RECTYP <> 4 : GMESSAGE = mess(84,7711,1) : Call MESSAGE(GMESSAGE) From GESECRAN : GOK = 0 : Return : Endif
    Gosub DOCUMENT
    Default File [SIV]

  When "BIC0":
    Call LEC_TSV_LEG([F:CPY]LEG,DKSTYP,WRET) From TRTLECLEG
    If  [F:TSV]INVTYP = 5 : Return : Endif
    If [F:GTE]MANNUM = 2 & [F:TSV]RECTYP <> 4 : GMESSAGE = mess(84,7711,1) : Call MESSAGE(GMESSAGE) From GESECRAN : GOK = 0 : Return : Endif
    Gosub DOCUMENT
    Default File [SIH]

  When "SIH":
    Call LEC_TSV_LEG([F:CPY]LEG,DKSTYP,WRET) From TRTLECLEG
    If  [F:TSV]INVTYP = 5 : Return : Endif
    If [F:GTE]MANNUM = 2 & [F:TSV]RECTYP <> 4 : GMESSAGE = mess(84,7711,1) : Call MESSAGE(GMESSAGE) From GESECRAN : GOK = 0 : Return : Endif
    Gosub DOCUMENT
    Default File [SIH]

  When "PIH0":
    Call LEC_TPV_LEG(GCURLEG,DKSTYP,WRET) From TRTLECLEG
    If GMANCOU = 2 & [F:TPV]RECTYP <> 4 : GMESSAGE = mess(84,7711,1) : Call MESSAGE(GMESSAGE) From GESECRAN : GOK = 0 : Return : Endif
    Gosub DOCUMENT
    Default File [PIV]

  When "BIS0":
    Call LEC_TPV_LEG(GCURLEG,DKSTYP,WRET) From TRTLECLEG
    If [F:GTE]MANNUM = 2 & [F:TPV]RECTYP <> 4 : GMESSAGE = mess(84,7711,1) : Call MESSAGE(GMESSAGE) From GESECRAN : GOK = 0 : Return : Endif
    Gosub DOCUMENT
    Default File [PIH]

  When "TPIH":
    Call LEC_TPV_LEG([F:CPY]LEG,DKSTYP,WRET) From TRTLECLEG
    If [F:GTE]MANNUM = 2 & [F:TPV]RECTYP <> 4 : GMESSAGE = mess(84,7711,1) : Call MESSAGE(GMESSAGE) From GESECRAN : GOK = 0 : Return : Endif
    Gosub DOCUMENT
    Default File [TPIH]

  When "HEA":
    Call LEC_GTE_LEG([F:CPY]LEG,G_GTE,WRET) From TRTLECLEG
    Call LEC_TSV_LEG([F:CPY]LEG,DKSTYP,WRET) From TRTLECLEG
    If [F:GTE]MANNUM = 2 & [F:TSV]RECTYP <> 4 : GMESSAGE = mess(84,7711,1) : Call MESSAGE(GMESSAGE) From GESECRAN : GOK = 0 : Return : Endif
    Gosub DOCUMENT
    Default File [HEA]

Endcase

Return
##########################################################################################
##########################################################################################
$DOCUMENT

Gosub ALIDKDVAR_MSKI From DKSLIB
If GOK
  Gosub CRE_DKD        From DKSLIB
  If !GOK : Call ECR_TRACE (GMESSAGE, 1) From GESECRAN : DKSRET = 0 : Endif
Else
  Call ECR_TRACE (GMESSAGE, 1) From GESECRAN : DKSRET = 0
Endif

Return
##########################################################################################
##########################################################################################
$ALIDKDVAR_MSKI

Case DKSKEY
    When "SAFT-PT"
        Local Char    SITE(GLONFCY), SIT(GLONFCY), SOC(GLONCPY), PERIOD(10), COMPL(GLONVCR), COMPLANM(GLONVCR)  # rev 02.02 -> no need for compl and period becomes char
        Local Char    PERIODP(10)                                                                               # rev 03.03
        Local Integer SEQNUM, SEQIND, COMPANMPOS, COMPDOCPOS, COMPLLNG, SITELNG                                 # rev 02.02 -> seqind added
        Local Char    DOCN(GLONVCR), DOCT(GLONTSV), DOCBT(2), DKDOCN(GLONVCR+GLONTSV+1), PDKDOCN(GLONVCR+GLONTSV+1), CTR_PDKDOCN(GLONVCR+GLONTSV+1)
        Local Date    DAT
        Local Char    ANMC(GLONANM)
        Local Integer RECTYP, SAFINVTYP
        Local Char    TMPDOCNUM(GLONVCR)

        Local Char    PREVDOC(GLONVCR)        : [L]PREVDOC   = ""
        Local Char    PATTERN(GLONVCR)        : [L]PATTERN   = ""
        Local Integer STAT                    : [L]STAT      = 0
        Local Integer SEQNUM                  : [L]SEQNUM    = 0

        PERIOD   = ""                         # rev 02.02 -> period becomes char
        PERIODP  = ""                         # rev 02.02 -> period becomes char
        SEQNUM  = 0
        Case DKSORIG
          When "SIH0"
            [L]RECTYP = [F:TSV]RECTYP
            [L]SAFINVTYP = [F:TSV]SAFTINVTYP
            SITE    = [M:SIH0]SALFCY
            DAT     = [M:SIH0]INVDAT
            #COMPL   = WJOURNAL
            [L]ANMC    = GCPT
            [L]DOCT    = [M:SIH0]SIVTYP
            If [L]RECTYP = 4 & GMANCOU = 2 & [M:SIH0]NUM <> ""
               [L]DOCN    = [M:SIH0]NUM
            Else
               [L]DOCN    = GNUM
            Endif
            [L]DOCBT = func GET_INVOICEBASTYP([F:TSV]SAFTINVTYP)
          When "BIC0"
            [L]RECTYP = [F:TSV]RECTYP
            [L]SAFINVTYP = [F:TSV]SAFTINVTYP
            SITE    = [M:BIC0]FCY
            DAT     = [M:BIC0]ACCDAT
            #COMPL   = JOURNAL
            [L]ANMC    = [F:GTE]COU
            [L]DOCT    = [M:BIC0]SIVTYP
            [L]DOCN    = [F:SIH]NUM
            [L]DOCBT = func GET_INVOICEBASTYP([F:TSV]SAFTINVTYP)
          When "SIV"
            [L]RECTYP = [F:TSV]RECTYP
            [L]SAFINVTYP = [F:TSV]SAFTINVTYP
            SITE    = [F:SIV]SALFCY
            DAT     = [F:SIV]INVDAT
            #COMPL   = WJOURNAL
            [L]ANMC    = GCPT
            [L]DOCT    = [F:SIV]SIVTYP
            [L]DOCN    = LNUM
            [L]DOCBT = func GET_INVOICEBASTYP([F:TSV]SAFTINVTYP)
          When "SIH"
            [L]RECTYP = [F:TSV]RECTYP
            [L]SAFINVTYP = [F:TSV]SAFTINVTYP
            SITE    = [F:SIH]FCY
            DAT     = [F:SIH]ACCDAT
            #COMPL   = [F:SIH]JOU
            [L]ANMC    = [F:GTE]COU
            [L]DOCT    = [F:SIH]SIVTYP
            [L]DOCN    = [F:SIH]NUM
            [L]DOCBT = func GET_INVOICEBASTYP([F:TSV]SAFTINVTYP)
          When "TSIH"
            [L]RECTYP = [F:TSV]RECTYP
            [L]SAFINVTYP = [F:TSV]SAFTINVTYP
            SITE    = [F:TSIH]FCY
            DAT     = [F:TSIH]ACCDAT
            #COMPL   = [F:SIH]JOU
            [L]ANMC    = [F:GTE]COU
            [L]DOCT    = [F:TSIH]SIVTYP
            [L]DOCN    = [F:TSIH]NUM
            [L]DOCBT = func GET_INVOICEBASTYP([F:TSV]SAFTINVTYP)
          When "PIH0"
            [L]RECTYP = [F:TPV]RECTYP
            [L]SAFINVTYP = [F:TPV]SAFTINVTYP
            SITE    = [M:PIH0]FCY
            DAT     = [M:PIH0]ACCDAT
            #COMPL   = JOURNAL
            [L]ANMC    = GCODNUM
            [L]DOCT    = [M:PIH0]PIVTYP
            [L]DOCN    = [M:PIH0]NUM
            [L]DOCBT = func GET_INVOICEBASTYP([F:TPV]SAFTINVTYP)
          When "BIS0"
            [L]RECTYP = [F:TPV]RECTYP
            [L]SAFINVTYP = [F:TPV]SAFTINVTYP
            SITE    = [M:BIS0]FCY
            DAT     = [M:BIS0]ACCDAT
            #COMPL   = JOURNAL
            [L]ANMC    = XPARAM
            [L]DOCT    = [M:BIS0]PIVTYP
            [L]DOCN    = [F:PIH]NUM
            [L]DOCBT = func GET_INVOICEBASTYP([F:TPV]SAFTINVTYP)
          When "TPIH"
            [L]RECTYP = [F:TPV]RECTYP
            [L]SAFINVTYP = [F:TPV]SAFTINVTYP
            SITE    = [F:TPIH]FCY
            DAT     = [F:TPIH]ACCDAT
            #COMPL   = JOURNAL
            [L]ANMC    = XPARAM
            [L]DOCT    = [F:TPIH]PIVTYP
            [L]DOCN    = [F:TPIH]NUM
            [L]DOCBT = func GET_INVOICEBASTYP([F:TPV]SAFTINVTYP)
          When "HEA"
            [L]RECTYP = [F:TSV]RECTYP
            [L]SAFINVTYP = [F:TSV]SAFTINVTYP
            SITE    = [F:HEA]FCY
            DAT     = [F:HEA]ACCDAT
            #COMPL   = [F:SIH]JOU
            [L]ANMC    = [F:GTE]COU
            [L]DOCT    = [F:HEA]SIVTYP
            [L]DOCN    = [F:HEA]NUM
            [L]DOCBT = func GET_INVOICEBASTYP([F:TSV]SAFTINVTYP)
        Endcase

        If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
        If [F:FCY]FCY <> SITE
          Read [F:FCY]FCY0 = SITE
        Endif

        # rev 02.02 -> check DOCTYP Vs Counter
        If !([L]RECTYP = 4 & GMANCOU = 2)
           Gosub CHECKCOUNTER
        Endif
        If GOK = 0
          Return
        Endif

        If [L]RECTYP <> 4

          #TMPDOCNUM = right$([L]DOCN,len([L]DOCT)+1)
          #Call NUMERO_PREC2([L]ANMC, TMPDOCNUM, [L]PREVDOC, [L]PATTERN, [L]SEQNUM, [L]STAT)
          Call NUMERO_PREC2([L]ANMC, DOCN, [L]PREVDOC, [L]PATTERN, [L]SEQNUM, [L]STAT)
          If [L]STAT <> 0
            GOK = 0 : GMESSAGE = mess(9,7711,1)+"." : Return
          Endif

          # Issue X3-91732 by MRDAB
          [L]DKDOCN = [L]DOCT + " " + [L]DOCN

          If [L]PREVDOC <> ""
            [L]PDKDOCN = [L]DOCT + " " + [L]PREVDOC
            Read [F:DKD]DKD1 = "SAFT-PT";[L]PDKDOCN
            If fstat # for the moment where we switch from old FCL SOC to the new FCL FCLSOC
              [L]CTR_PDKDOCN = right$([L]PREVDOC,len([L]DOCT)+1)
              [L]CTR_PDKDOCN = ctrans(CTR_PDKDOCN, "-_", "")
              [L]CTR_PDKDOCN = [L]DOCT + " " + [L]CTR_PDKDOCN
              [L]PDKDOCN     = ""
            Else
              [L]CTR_PDKDOCN = PDKDOCN
            Endif
          Else
            [L]PDKDOCN     = ""
            [L]CTR_PDKDOCN = ""
          Endif
          # Issue end

          If CTR_PDKDOCN <> ""
            Read [F:DKD]DKD1 = "SAFT-PT";CTR_PDKDOCN
            If fstat
              If find(DKSORIG,"BIS0","PIH0","TPIH")
                If !clalev([F:PIH2]) : Local File PINVOICE [PIH2] : Endif
                Filter [F:PIH2] Where pat([F:PIH2]NUM, [L]PATTERN) & [F:PIH2]NUM<>DOCN
                Read [F:PIH2] First
                Filter [F:PIH2]
                If !fstat
                  GOK = 0 : GMESSAGE = mess(16,7711,1)-CTR_PDKDOCN: Return
                Else
                  CTR_PDKDOCN = ""
                Endif
              Else
                If !clalev([F:SIH2]) : Local File SINVOICE [SIH2] : Endif
                Filter [F:SIH2] Where pat([F:SIH2]NUM, [L]PATTERN) & [F:SIH2]NUM<>DOCN
                Read [F:SIH2] First
                Filter [F:SIH2]
                If !fstat
                  GOK = 0 : GMESSAGE = mess(16,7711,1)-CTR_PDKDOCN : Return
                Else
                  CTR_PDKDOCN = ""
                Endif
              Endif
            Endif
          Endif

        Endif
    When Default
Endcase

Return
##########################################################################################
##########################################################################################
Funprog GET_INVOICEBASTYP(SAFTINVTYP)
Value Integer SAFTINVTYP

Local Char RETVAL(2)

Case [L]SAFTINVTYP
  When 1 : [L]RETVAL = "FT"
  When 2 : [L]RETVAL = "FS"
  When 3 : [L]RETVAL = "ND"
  When 4 : [L]RETVAL = "NC"
  When 5 : [L]RETVAL = "AA"
  When 6 : [L]RETVAL = "DA"
  When 7 : [L]RETVAL = "FR"
  When 8 : [L]RETVAL = "PF"
  When 9 : [L]RETVAL = "FC"
Endcase

End RETVAL
##########################################################################################
##########################################################################################
$CRE_DKD

Case DKSKEY
    When "SAFT-PT"
      If !clalev([F:DKD]) : Local File DKSDATA   [DKD] : Endif
      If [L]RECTYP = 4
        Local Char    LDKSDOCNUM(30)
        Local Char    LHASHSIGN(255)
        Local Integer LHASHCTR
        Local Integer LHASHCERTIF
        Local Char    LSYSENTDAT(19)
        Local Integer RETVAL

        Gosub CTROBLFLD
        If [L]RETVAL <> 2
          Raz [F:DKD]
          [F:DKD]DIGSIGN     = LHASHSIGN
          [F:DKD]DKSDOCNUM   = LDKSDOCNUM
          [F:DKD]KEYVER      = LHASHCTR
          [F:DKD]PRNCHAR     = mid$(LHASHSIGN, 1, 1) + mid$(LHASHSIGN, 11, 1) + mid$(LHASHSIGN, 21, 1) + mid$(LHASHSIGN, 31, 1)
          [F:DKD]CERNUM      = LHASHCERTIF
          [F:DKD]SYSENTDAT   = LSYSENTDAT
          [F:DKD]RECTYP      = [L]RECTYP
          [F:DKD]SAFTINVTYP  = [L]SAFINVTYP
          [F:DKD]DOCTYP      = DOCT
          [F:DKD]DOCNUM      = DOCN
          [F:DKD]KEYCODE     = DKSKEY
          [F:DKD]ANMCODE     = [L]ANMC
          [F:DKD]DOCBASTYP   = DOCBT
          [F:DKD]CREDAT      = date$
          [F:DKD]CRETIM      = time
          [F:DKD]CREUSR      = GUSER
        Endif
      Else
        Raz [F:DKD]
        [F:DKD]DOCTYP     = [L]DOCT
        [F:DKD]DOCNUM     = [L]DOCN
        [F:DKD]KEYCODE    = [L]DKSKEY
        [F:DKD]DKSDOCNUM  = [L]DKDOCN
        [F:DKD]PDKSDOCNUM = [L]PDKDOCN
        [F:DKD]ANMCODE    = [L]ANMC
        [F:DKD]DOCBASTYP  = [L]DOCBT
        [F:DKD]RECTYP     = [L]RECTYP
        [F:DKD]SAFTINVTYP = [L]SAFINVTYP
        [F:DKD]CREDAT     = date$
        [F:DKD]CRETIM     = time
        [F:DKD]CREUSR     = GUSER
      Endif

      If GOK
        Write [F:DKD]
        If fstat
          GOK = 0 : Call FSTA("DKD") From GLOCK : Return
        Endif
      Endif
    When Default
Endcase

Return
##########################################################################################
##########################################################################################
$CHECKCOUNTER

If func PORLEGLIB.ANM_OK(ANMC, GMESSAGE) <> 1
  GOK=0 : Return
Endif

# rev 00.02 -> check the conformity of the invoice number against the counter and the SIVTYP. invoice number must have the "/" character
Local Integer WKLEN : Raz WKLEN

If !clalev([F:ANM]) : Local File ACODNUM [ANM] : Endif

If [F:ANM]CODNUM <> [L]ANMC
    Read [F:ANM]ANM0 = [L]ANMC
Endif

If [F:ANM]CTLCHR<>2
    GOK = 0
    GMESSAGE = func AFNC.MES1(mess(43,7711,1),[L]ANMC)
Endif

WKLEN=len([L]ANMC)-len(DOCT)
If WKLEN<0 : Raz WKLEN : Endif

If [L]ANMC <> string$(left$([F:ANM]CODNUM,WKLEN)="PT","PT") + DOCT
    GOK      = 0
    GMESSAGE = func AFNC.MES2(mess(85,7711,1),[L]ANMC,DOCT)
Else
    #CPO for RM 30.12.2010
    #If len(DOCN)>=3
        #If left$(DOCN,3)<>DOCT
        If left$(DOCN,len(DOCT))<>DOCT
            GOK      = 0
            GMESSAGE = func AFNC.MES2(mess(85,7711,1),[L]ANMC,DOCT)
        Endif
    #Endif
Endif

Return
##########################################################################################
##########################################################################################
Subprog MESSAGE(DKSSTA, MESSA)
Value    Integer DKSSTA
Variable Char MESSA

Case DKSSTA
    When 2 : MESSA = mess(10,7711,1)
    When 3 : MESSA = mess(11,7711,1)
    When 4 : MESSA = mess(12,7711,1)
    When 5 : MESSA = mess(64,7711,1)
Endcase

End
##########################################################################################
##########################################################################################
###                                                                                    ###
###                                INVOICE VALIDATION                                  ###
###                                                                                    ###
##########################################################################################
##########################################################################################
### Triggering the right signature action, only SAFT-PT for now
##########################################################################################
$DKS_SIGN_TRIGGER
Local Char    DKSKEY(10)  : DKSKEY  = "SAFT-PT"
#The PORDKS is a localisation parameter and its active when the KPO activity code is active
#It has a company level definition and it's value allows
#to go further with the digital signature
Local Char DKSFCY(GLONFCY) : DKSFCY=""

Case DKSORIG
  When "VEN","BIC" : DKSFCY=[F:SIH]FCY
  When "PUR","BIS" : DKSFCY=[F:PIH]FCY
  When Default
Endcase

If func AFNC.PARAM("PORDKS",DKSFCY)="2"
  Gosub DKS_SIGN
Endif

Return
##########################################################################################
##########################################################################################
$DKS_SIGN

Case DKSORIG
  When "VEN","BIC"
    Local Integer WRET
    If !clalev([F:TSV]) : Local File TABSIVTYP [TSV] : Endif
    Call LEC_TSV_LEG(GCURLEG,[F:SIH]SIVTYP,WRET) From TRTLECLEG
    If [F:TSV]RECTYP=4 | [F:SIH]INVTYP > 4: Return : Endif
  When "PUR","BIS"
    Local Integer WRET
    If !clalev([F:TPV]) : Local File TABPIVTYP [TPV] : Endif
    Call LEC_TPV_LEG(GCURLEG,[F:PIH]PIVTYP,WRET) From TRTLECLEG
    If [F:TPV]RECTYP=4 | [F:PIH]INVTYP > 4: Return : Endif
Endcase

If !fstat
    Case DKSORIG
        When "VEN", "PUR"
                       Gosub GEN_SIHSAFTPT_SIGN From DKSLIB
                       If GOK < 1
                           If GTRACE <> ""
                              Call ECR_TRACE(GMESSAGE,1) From GESECRAN
                              Raz GMESSAGE
                           Else
                              Call MESSAGE(GMESSAGE) From GESECRAN
                           Endif
                           DKSRET = 0
                       Endif
        When "BIC", "BIS"
                       Gosub GEN_SIHSAFTPT_SIGN From DKSLIB
                       If GOK < 1
                           If GTRACE <> ""
                              If find(GFONCTION, "GESBIC", "GESBIS")
                                Call MESSAGE(GMESSAGE) From GESECRAN #trace is opened, but is never showned
                              Else
                                Call ECR_TRACE(GMESSAGE,1) From GESECRAN
                                Raz GMESSAGE
                              Endif
                           Else
                              Call MESSAGE(GMESSAGE) From GESECRAN
                           Endif
                           DKSRET = 0
                           #Call LEC_TRACE From LECFIC
                       Endif
   Endcase
Endif

Return
##########################################################################################
##########################################################################################
Subprog DKSSIGNSIH(KEYCODE, DKSORIG)
Value Char KEYCODE
Value Char DKSORIG

Case KEYCODE
    When "SAFT-PT"
        Gosub GEN_SIHSAFTPT_SIGN
Endcase

End
##########################################################################################
##########################################################################################
$GEN_SIHSAFTPT_SIGN
#assumes that we have DKD on-line
Local Char     MESTOSIGN(250) : MESTOSIGN   = ""
Local Char     SIGNEDMES(250)
Local Char     PREVDOC(GLONVCR+GLONTSV+1)
Local Char     VTIM(30)       : VTIM        = time$
Local Date     VDAT
Local Date     WACCDAT
Local Decimal  WAMTATI
Local Char     WINVTYP(GLONTSV)
Local Char     WDOCNUM(GLONVCR+GLONTSV+1)
Local Char     V_ERRMES(250)
Local Decimal  WWHOLDTAX

If !clalev([DKK]) : Local File DKSKEY  [DKK] : Endif

Case DKSORIG
  When "VEN", "BIC"
    If [F:SIH]UPDDAT = [0/0/0]
      VDAT = date$
    Else
      VDAT = [F:SIH]UPDDAT
    Endif
    WACCDAT = [F:SIH]ACCDAT
    WAMTATI = [F:SIH]AMTATIL
    Gosub SET_SIH_RATCUR
    If WAMTATI = 0
       WAMTATI = ar2(([F:SIH]AMTATI)*[L]WRATCUR)
    Endif
    WINVTYP = [F:SIH]SIVTYP
    WDOCNUM = [F:SIH]NUM
    Gosub SET_WHOLDTAX
    WAMTATI += WWHOLDTAX
  When "PUR", "BIS"
    If [F:PIH]UPDDAT = [0/0/0]
      VDAT = date$
    Else
      VDAT = [F:PIH]UPDDAT
    Endif
    WACCDAT = [F:PIH]ACCDAT
    WAMTATI = [F:PIH]AMTATIL
    If WAMTATI = 0
       If find([F:PIH]CURLED(0..9),"EUR")
         [L]WRATCUR = [F:PIH]RATMLT(find([F:PIH]CURLED(0..9),"EUR")-1)
       Else
         [L]WRATCUR = 1
       Endif
       If [L]WRATCUR = 0 : [L]WRATCUR = 1 : Endif
       WAMTATI = ar2(([F:PIH]AMTATI)*[L]WRATCUR)
    Endif
    WINVTYP = [F:PIH]PIVTYP
    WDOCNUM = [F:PIH]NUM
Endcase
#CPO for RM 10.01.2011
# rev 03.02

If !GOK
  If GTRACE = ""
    Call MESSAGE(GMESSAGE) From GESECRAN
  Endif
  DKSRET = 0
  Return
Endif

# Issue 110700
Local Integer EFAT_BPEI_ACTIVE : EFAT_BPEI_ACTIVE = 1
Local Integer EFAT_ATEI_ACTIVE : EFAT_ATEI_ACTIVE = 1

If (func AFNC.ACTIV("EFAT") = 1) and find(DKSORIG, "VEN", "BIC")
  Gosub CHECK_EFAT_BPEI_ATEI From PORLEGEFATLIB
Endif
# End issue 110700

If !clalev([DKD]) : Local File DKSDATA [DKD] : Endif
Read [F:DKD]DKD0="SAFT-PT";WINVTYP;WDOCNUM
If !fstat

  MESTOSIGN = format$("D:YYYY[-]MM[-]DD",WACCDAT) + ";" + format$("D:YYYY[-]MM[-]DD",VDAT)
&                   + "T" + VTIM + ";" + [F:DKD]DKSDOCNUM + ";" + ctrans(vireblc(format$("N20.2",ar2(WAMTATI)),4),",",".") + ";"

  If [F:DKD]PDKSDOCNUM<>""
      PREVDOC = [F:DKD]PDKSDOCNUM

      Read [F:DKD]DKD1="SAFT-PT";PREVDOC
      If !fstat
        If [F:DKD]DIGSIGN <> ""
          MESTOSIGN += [F:DKD]DIGSIGN
        Else
          GOK = 0 : GMESSAGE = mess(15,7711,1) + ": " - PREVDOC : Return
        Endif
      Else
        GOK = 0 : GMESSAGE = mess(16,7711,1) + ": " - PREVDOC : Return
      Endif

  Endif

  Filter [F:DKK] Where [F:DKK]KEYCODE = "SAFT-PT" & [F:DKK]STRDAT<=WACCDAT Order By STRDAT Desc; KEYVER Desc
  Read [F:DKK] First
  Filter [F:DKK]

  If !fstat
    Call GENSIGNATURE(MESTOSIGN,SIGNEDMES,V_ERRMES)

    If V_ERRMES <> '' | SIGNEDMES = ''
      GOK = 0 : GMESSAGE = V_ERRMES : Return
    Else
      Read [F:DKD]DKD0="SAFT-PT";WINVTYP;WDOCNUM
      [F:DKD]DIGSIGN     = SIGNEDMES
      [F:DKD]PRNCHAR     = mid$(SIGNEDMES, 1, 1) + mid$(SIGNEDMES, 11, 1) + mid$(SIGNEDMES, 21, 1) + mid$(SIGNEDMES, 31, 1)
      [F:DKD]VALIDDAT    = VDAT
      [F:DKD]VALIDTIM    = VTIM
      [F:DKD]DOCSTA      = 2
      [F:DKD]KEYVER      = [F:DKK]KEYVER
      [F:DKD]RATCUR      = [L]WRATCUR
      [F:DKD]UPDDAT      = date$
      [F:DKD]UPDTIM      = time
      [F:DKD]UPDUSR      = GUSER
      [F:DKD]WITHOLTAX   = WWHOLDTAX
      [F:DKD]GROSSTOT    = WAMTATI
      [F:DKD]GROSSTOTFLG = 2
      If EFAT_BPEI_ACTIVE = 2
        [F:DKD]BPEI = 1
      Endif
      If EFAT_ATEI_ACTIVE = 2
        [F:DKD]ATEI = 1
      Endif
      Rewrite [F:DKD]
      If fstat : GOK = 0 : GMESSAGE = mess(13,7711,1) : Endif
    Endif
  Endif
Endif

Return
##########################################################################################
##########################################################################################
$SET_SIH_RATCUR

Local Decimal  WRATCUR
Local Integer  WCURLED
Local Decimal  SDRATCUR

[L]WRATCUR = 0

WCURLED = find("EUR", [F:SIH]CURLED(0..9))
If WCURLED
  [L]WRATCUR = arr([F:SIH]RATMLT(WCURLED-1)/[F:SIH]RATDIV(WCURLED-1),10^-GDECRCU)
Else
  [L]WRATCUR = 1
Endif
If [L]WRATCUR = 0 : [L]WRATCUR = 1 : Endif

[L]SDRATCUR = [L]WRATCUR

Return
##########################################################################################
##########################################################################################
$SET_WHOLDTAX

Local Char     ACCRET(30), COA(GLONCOA), LEDTA(30), SOC(GLONCPY), SAFPRIRNC(30)
Local Integer  LEDT
Local Decimal  SAFPRIRND

If !clalev([F:CPY]) : Local File COMPANY   [CPY] : Endif
If !clalev([F:GCM]) : Local File GACM      [GCM] : Endif
If !clalev([F:LED]) : Local File GLED      [LED] : Endif

Raz WWHOLDTAX

[L]SOC = [F:SIH]CPY
Gosub SET_LEDT From SAFTGENPOR
Gosub SET_COA From SAFTGENPOR
Gosub SET_SAFPRIRND From SAFTGENPOR
Call PARAM([L]SOC, "SAFTACCRET",[L]ACCRET) From ADOVAL

If DKSORIG = "VEN"
  Gosub SET_VEN_WHOLDTAX
Elsif DKSORIG = "BIC"
  Gosub SET_BIC_WHOLDTAX
Endif

WWHOLDTAX = abs(WWHOLDTAX)

Return
##########################################################################################
##########################################################################################
$SET_VEN_WHOLDTAX

If !clalev([F:SVV]) : Local File SVCRVAT [SVV] : Endif

For [F:SVV] Where [F:SVV]VCRNUM=[F:SIH]NUM
  Gosub SET_IS_WITHHOLDINGTAX
  If [L]ISWITHHOLDINGTAX
    If [F:TVT]VATCHA = 2
      GOK = 0 : GMESSAGE = func AFNC.MES1(mess(239,7711,1),[F:TVT]VAT)
      Break
    Else
      WWHOLDTAX += [F:SVV]AMTTAX*[L]WRATCUR
    Endif
  Endif
Next

Return
##########################################################################################
##########################################################################################
$SET_BIC_WHOLDTAX

Local Decimal  SDLNETPRI

If !clalev([F:SIL]) : Local File BPCINVLIG [SIL] : Endif
If !clalev([F:GAC]) : Local File GACCOUNT  [GAC] : Endif

For [F:SIL] Where [F:SIL]NUM = [F:SIH]NUM
  If pat([F:SIL]ACC([L]LEDT-1), ACCRET+"*") & ACCRET <> ""
    Gosub SET_SIL_LIN_NETPRI From SAFTGENPORSIH
    [L]WWHOLDTAX += abs([L]SDLNETPRI)
  Endif
Next

Return
##########################################################################################
##########################################################################################
$SET_IS_WITHHOLDINGTAX

Local Integer ISWITHHOLDINGTAX
Local Integer K

If !clalev([F:CAC]) : Local File GACCCODE   [CAC] : Endif
If !clalev([F:TVT]) : Local File TABVAT     [TVT] : Endif

ISWITHHOLDINGTAX = 0

Call LEC_TVT_LEG(GCURLEG,[F:SVV]VAT,WRET) From TRTLECLEG

If [F:TVT]ACCCOD<>"" & [F:TVT]VATTYP > 1
  If [F:CAC]COA <> [L]COA | [F:CAC]TYP <> 10 | [F:CAC]ACCCOD <> [F:TVT]ACCCOD
    Read [F:CAC]CAC2 = [L]COA;10;[F:TVT]ACCCOD
    If fstat : Raz [F:CAC] : Endif
  Endif
  For K = 0 To dim([F:CAC]ACC)-1
    If [F:CAC]ACC(K) <> "" & pat([F:CAC]ACC(K), ACCRET+"*") & ACCRET <> ""
      ISWITHHOLDINGTAX = 1
      Break
    Endif
  Next
Endif

Return
######################################################################################
######################################################################################
Subprog GENSIGNATURE(P_MESTOSIGN,P_RETSIGNED,P_RETMES)
Value    Char P_MESTOSIGN
Variable Char P_RETSIGNED
Variable Char P_RETMES

Local Char    MODULE(100)  : MODULE   = 'bundle-sage-pt-cert/ptCert'
Local Char    FONCTION(30) : FONCTION = 'generateSignature'
Local Char    MODE(10)     : MODE     = 'wait'
Local Char    RETURNS(30)
Local Clbfile RESHEAD(0)
Local Clbfile RESBODY(0)
Local Integer STATUSCODE
Local Char    RETCODE(250), PRIVKEY(250)

Raz P_RETSIGNED
Raz P_RETMES

#------- data object -------
# Format data to JSON object
Local Clbfile DATA(0) :
DATA = '{'
Append DATA, '"message": "' + P_MESTOSIGN + '"'
Append DATA, '}'
#------- data object -------

#------- context object -------
Local Char PROP02(255) : PROP02 = "VVRDNhMGET1gOTMxIhEHBlVXVDEWFwIG"
PROP02 = num$(len(PROP02))+"-"+PROP02
PROP02 = func BYTOP(PROP02,P_MESTOSIGN, 0)
# Format context to JSON object
Local Clbfile CTX(0) : CTX = '{'
Append CTX, '"pvKeyName": "",'
Append CTX, '"operation": "generateSignature",'
Append CTX, '"prop01": "",'
Append CTX, '"prop02": "'+PROP02+'"'
Append CTX, '}'
#------- context object -------

#------- options object -------
Local Char DEBUGMODE(10) : DEBUGMODE = 'false'
If GTEST = 1 : DEBUGMODE = 'true' : Endif
# Format options to JSON object
Local Clbfile OPT(0) : OPT = '{'
Append OPT, '"debugMode": '+DEBUGMODE
Append OPT, '}'
#------- options object -------

Local Clbfile ARGUMENTS(0)
ARGUMENTS = DATA + ',' + CTX + ',' + OPT

Onerrgo ERR_SIGN
STATUSCODE = func ASYRWEBSER.EXEC_JS(MODULE, FONCTION, MODE, ARGUMENTS, '', 0, RETURNS, '0', RESHEAD, RESBODY)
Onerrgo

If GOK = 0
  P_RETMES = mess(8,7711,1) : End
Endif

If STATUSCODE = 200 #status ok - get the values
  # RETCODE = 0 - Generation of the signature was successful
  # RETCODE = 1 - Initialization of the variable in NodeJS
  # RETCODE = 2 - Error after update of the signature and Synchronous
  # RETCODE = 3 - Error signing
  RETCODE = func AJSONLIB.GET_PROP(RESBODY,"code")
  If RETCODE = "0"
    P_RETSIGNED = func AJSONLIB.GET_PROP(RESBODY,"value")
  Elsif find(RETCODE,"1","2","3")
    P_RETMES    = func AJSONLIB.GET_PROP(RESBODY,"message")
  Else
    P_RETMES    = RESBODY
  Endif
Else #status not ok, get error message
  P_RETMES = func AJSONLIB.GET_PROP(RESHEAD,"message")
Endif

End
##########################################################################################
##########################################################################################
$ERR_SIGN
GOK = 0
Resume
##########################################################################################
##########################################################################################
###                                                                                    ###
###                    TRANSPORT DOCUMENTS VALIDATION                                  ###
###                                                                                    ###
##########################################################################################
##########################################################################################
### Transport document digital signature
##########################################################################################
##########################################################################################
Funprog SIGNDOC_NEW(NUM, VCRTYP, TYP, MESTOSIGN, ANM, DATDOC, LASDAT, TIM, RECTYP,SAFTTYP, RETVAL)
Value    Char    NUM
Value    Integer VCRTYP #(2-SDH; 3 - SRH normal; 4 - SRH Loan; 5 - SRH subcontract; 6 - SGH intersite; 7 - SGH subcontract transfer; 8 - SGH subcontract return; 9 - PNH; 10 - TNH)
Value    Char    TYP
Value    Char    MESTOSIGN
Value    Char    ANM
Value    Date    DATDOC
Value    Date    LASDAT
Value    Char    TIM
Value    Integer RECTYP
Value    Integer SAFTTYP
Variable Integer RETVAL

Local Char    LHASHSIGN(255)
Local Char    LDKSDOCNUM(30)
Local Char    LPDKSDOCNUM(30)
Local Char    LPRNCHAR(4)
Local Integer LHASHCTR
Local Integer LHASHCERTIF
Local Char    LSYSENTDAT(19)
Local Char    LDOCBASTYP(2)

Local Char    KEYCODE(15)    : [L]KEYCODE   = "SAFT-PT"
Local Char    JAVMETHOD(250) : [L]JAVMETHOD = "pt.sage.swf.certification.Crypto:SHA1withRSA"
Local Char    SIGNEDMES(250) : [L]SIGNEDMES = ""
Local Char    PREVDOC(40)    : [L]PREVDOC   = ""
Local Char    PATTERN(40)    : [L]PATTERN   = ""
Local Integer STAT           : [L]STAT      = 0
Local Integer SEQNUM         : [L]SEQNUM    = 0

Local Integer RETVAL         : [L]RETVAL    = 3 # 0-digital signature created; 1-no error, but digital signature not created; 2-error

Local File DKSKEY  [DKK]
Local File DKSDATA [DKD]
Local File DKSJAV  [DKJ]

# Variable which receives the error message from JavaScript Bundle
Local Char V_ERRMES(250)
#

Filter [F:DKK] Where [F:DKK]KEYCODE = "SAFT-PT" & [F:DKK]STRDAT<= LASDAT Order By STRDAT Desc; KEYVER Desc
Read [F:DKK] First
Filter [F:DKK]

### ------------- Check if the document already exists on DKSDATA table (if external, for example) ------------- ###
Read [F:DKD]DKD0 = [L]KEYCODE;[L]TYP;[L]NUM
If !fstat
  [L]RETVAL = 1
  GMESSAGE = "DKSDATA"-tolower(mess(2,29,1))+"."-mess(22,100,1)
  End
Endif

### ------------- Counter mandatory ------------- ###
If [L]ANM=""
  GMESSAGE = mess(60,199,1)
  [L]RETVAL = 2
  End
Endif

Case [L]SAFTTYP
  When 1 : [L]LDOCBASTYP = 'GT'
  When 2 : [L]LDOCBASTYP = 'GR'
  When 3 : [L]LDOCBASTYP = 'GA'
  When 4 : [L]LDOCBASTYP = 'GC'
  When 5 : [L]LDOCBASTYP = 'GD'
Endcase

If [L]RECTYP = 4
  Gosub CTROBLFLD
  If [L]RETVAL = 2 : End : Endif
  If len([L]LHASHSIGN) = 172
    [L]LPRNCHAR = mid$([L]LDKSDOCNUM, 1, 1) + mid$([L]LDKSDOCNUM, 11, 1) + mid$([L]LDKSDOCNUM, 21, 1) + mid$([L]LDKSDOCNUM, 31, 1)
  Else
    [L]LPRNCHAR = ""
  Endif
  [L]LPDKSDOCNUM = ""
Else
  ### ------------- Obtenção da assinatura digital do documento anterior ------------- ###
  Call NUMERO_PREC2([L]ANM, [L]NUM, [L]PREVDOC, [L]PATTERN, [L]SEQNUM, [L]STAT)

  If [L]STAT <> 0
    [L]RETVAL = 2
    End
  Endif

  Read [F:DKD]DKD0="SAFT-PT";[L]TYP;[L]PREVDOC
  If !fstat
      If [F:DKD]DIGSIGN <> ""
          [L]MESTOSIGN += [F:DKD]DIGSIGN
      Else
        GMESSAGE = mess(15,7711,1)
        [L]RETVAL = 2
        End
      Endif
  Else
      Call CHECKPREV([L]VCRTYP, [L]PREVDOC, [L]PATTERN, [L]NUM, [L]STAT)
      If [L]STAT <> 0 : [L]RETVAL = 2 : End : Endif
  Endif

  ### ------------------------ Sign Document ------------------------ ###
  [L]STAT = 0
  # New method to sign the document
  Call GENSIGNATURE(MESTOSIGN,SIGNEDMES,V_ERRMES)
  If V_ERRMES <> '' | SIGNEDMES = ''
    [L]RETVAL = 2 : GMESSAGE = V_ERRMES : End
  Endif

  [L]LHASHSIGN   = [L]SIGNEDMES
  [L]LDKSDOCNUM  = [L]TYP + " " + [L]NUM
  If [L]PREVDOC <> ""
    [L]LPDKSDOCNUM = [L]TYP + " " + [L]PREVDOC
  Endif
  [L]LPRNCHAR    = mid$([L]SIGNEDMES, 1, 1) + mid$([L]SIGNEDMES, 11, 1) + mid$([L]SIGNEDMES, 21, 1) + mid$([L]SIGNEDMES, 31, 1)
  [L]LHASHCTR    = [F:DKK]KEYVER
  [L]LHASHCERTIF = 213
  [L]LSYSENTDAT  = ""
Endif

Raz [F:DKD]
[F:DKD]ANMCODE    = [L]ANM
[F:DKD]CERNUM     = [L]LHASHCERTIF
[F:DKD]CREDAT     = date$
[F:DKD]CRETIM     = time
[F:DKD]CREUSR     = GUSER
[F:DKD]DIGSIGN    = [L]LHASHSIGN
[F:DKD]DKSDOCNUM  = [L]LDKSDOCNUM
[F:DKD]DOCBASTYP  = [L]LDOCBASTYP
[F:DKD]DOCNUM     = [L]NUM
[F:DKD]DOCSTA     = 2
[F:DKD]DOCTYP     = [L]TYP
[F:DKD]KEYCODE    = [L]KEYCODE
[F:DKD]KEYVER     = [L]LHASHCTR
[F:DKD]PDKSDOCNUM = [L]LPDKSDOCNUM
[F:DKD]PRNCHAR    = [L]LPRNCHAR
[F:DKD]RECTYP     = [L]RECTYP
[F:DKD]SYSENTDAT  = [L]LSYSENTDAT
[F:DKD]VALIDDAT   = [L]LASDAT
[F:DKD]VALIDTIM   = [L]TIM
[F:DKD]VCRTYP     = [L]VCRTYP
[F:DKD]RECTYP     = [L]RECTYP
[F:DKD]SAFTTRNTYP = [L]SAFTTYP

Write [F:DKD]
If fstat
  [L]RETVAL = 2 : GMESSAGE = mess(13,100,1)  # error writing to file
Else
  [L]RETVAL = 0
Endif

End
##########################################################################################
##########################################################################################
Subprog CHECKPREV(VCRTYP, PREVDOC, PATTERN, NUM, STAT)
Value    Integer VCRTYP
Value    Char    PREVDOC
Value    Char    PATTERN
Value    Char    NUM
Variable Integer STAT

[L]STAT = 99
GMESSAGE = mess(16,7711,1)-[L]PREVDOC
Case [L]VCRTYP
  When 2
    Local File SDELIVERY [SDH]
    Filter [F:SDH] Where pat([F:SDH]SDHNUM, [L]PATTERN) & [F:SDH]SDHNUM<[L]NUM
    Read [F:SDH] First
    Filter [F:SDH]
    If fstat
      [L]STAT = 0 : End
    Endif
  When 3,4,5
    Local File SRETURN [SRH]
    Filter [F:SRH] Where pat([F:SRH]SRHNUM, [L]PATTERN) & [F:SRH]SRHNUM<[L]NUM
    Read [F:SRH] First
    Filter [F:SRH]
    If fstat
      [L]STAT = 0 : End
    Endif
  When 6,7,8
    Local File SCHGH [SGH]
    Filter [F:SGH] Where pat([F:SGH]VCRNUM, [L]PATTERN) & [F:SGH]VCRNUM<[L]NUM
    Read [F:SGH] First
    Filter [F:SGH]
    If fstat
      [L]STAT = 0 : End
    Endif
  When 9
    Local File PRETURN [PNH]
    Filter [F:PNH] Where pat([F:PNH]PNHNUM, [L]PATTERN) & [F:PNH]PNHNUM<[L]NUM
    Read [F:PNH] First
    Filter [F:PNH]
    If fstat
      [L]STAT = 0 : End
    Endif
  When 10
    Local File TRANNOTEH [TNH]
    Filter [F:TNH] Where pat([F:TNH]TNHNUM, [L]PATTERN) & [F:TNH]TNHNUM<[L]NUM
    Read [F:TNH] First
    Filter [F:TNH]
    If fstat
      [L]STAT = 0 : End
    Endif
  When Default
    GMESSAGE = num$([L]VCRTYP)+":"-mess(29,107,1)
  Endcase
End
##########################################################################################
##########################################################################################
Subprog NUMERO_PREC2(A_ANM, A_NUM, A_PREVNUM, A_PATTERN, A_SEQNUM, A_STAT)
Value    Char    A_ANM
Value    Char    A_NUM
Variable Char    A_PREVNUM
Variable Char    A_PATTERN
Variable Integer A_SEQNUM
Variable Integer A_STAT

A_STAT = 0
Local File ACODNUM [ANM]

Read [ANM]ANM0 = A_ANM
If fstat
  A_STAT = 99 : GMESSAGE = A_ANM+":"-mess(152,187,1) : End
Endif

A_PATTERN   = ""
A_PREVNUM   = ""
A_STAT      = 0
A_SEQNUM    = 0

Local Char    PART1(GLONVCR)
Local Char    PART2(GLONVCR)
Local Integer PART2LEN

PART2LEN  = [F:ANM]POSLNG([F:ANM]NBPOS-1)
PART1     = left$(A_NUM, instr(1,A_NUM,"/"))
A_PATTERN = PART1+string$(PART2LEN,"#")

Onerrgo ERR_NUMPREC
A_SEQNUM    = val(right$(A_NUM, [F:ANM]LNG-PART2LEN+1))
Onerrgo

If A_STAT <> 0   : End : Endif
If A_SEQNUM = 1  : End : Endif

PART2 = format$("N0:"+num$(PART2LEN)+"#",A_SEQNUM-1)

A_PREVNUM = PART1+PART2

End
##########################################################################################
##########################################################################################
$ERR_NUMPREC
A_STAT = 99
GMESSAGE = AFNC.MES1(mess(37,7711,1), A_ANM)
Resume
##########################################################################################
##########################################################################################
$CTROBLFLD

Local Integer LCOUNT : [L]LCOUNT = 0
If dim(GHASHSIGN)>0
  If GHASHSIGN = ""
    GMESSAGE = mess(38,7711,1) : [L]LCOUNT += 1
  Endif
  [L]LHASHSIGN = GHASHSIGN
Else
  GMESSAGE = mess(38,7711,1)   : [L]LCOUNT += 1
  Raz [L]LHASHSIGN
Endif
If dim(GEXTINVNUM)>0
  If GEXTINVNUM = ""
    GMESSAGE = mess(39,7711,1) : [L]LCOUNT += 1
  Endif
  [L]LDKSDOCNUM = GEXTINVNUM
Else
  Raz [L]LDKSDOCNUM
  GMESSAGE = mess(39,7711,1)   : [L]LCOUNT += 1
Endif
If dim(GHASHCTR)>0
  If GHASHCTR = 0
    GMESSAGE = mess(40,7711,1) : [L]LCOUNT += 1
  Endif
  [L]LHASHCTR = GHASHCTR
Else
  GMESSAGE = mess(40,7711,1)   : [L]LCOUNT += 1
  Raz [L]LHASHCTR
Endif
If dim(GHASHCERTIF)>0
  If GHASHCERTIF = 0
    GMESSAGE = mess(41,7711,1) : [L]LCOUNT += 1
  Endif
  [L]LHASHCERTIF = GHASHCERTIF
Else
  GMESSAGE = mess(41,7711,1)   : [L]LCOUNT += 1
  Raz [L]LHASHCERTIF
Endif
If dim(GSYSENTDAT)>0
  If GSYSENTDAT = ""
    GMESSAGE = mess(42,7711,1) : [L]LCOUNT += 1
  Endif
  [L]LSYSENTDAT = GSYSENTDAT
Else
  GMESSAGE = mess(42,7711,1)   : [L]LCOUNT += 1
  Raz [L]LSYSENTDAT
Endif

If [L]LCOUNT < 5 & [L]LCOUNT > 0
    [L]RETVAL = 2
Else
    GMESSAGE  = ""
Endif

Return
##########################################################################################
##########################################################################################
###
### Encode functions
###
##########################################################################################
##########################################################################################
### Two strings - starting point
##########################################################################################
Funprog BYTOP(STI1, STI2, MODO)
Value    Char    STI1
Value    Char    STI2
Value    Integer MODO

Local Integer BYO
Local Clbfile CLBO
Local Clbfile CLBOUT
Local Shortint K, W

If MODO = 1
  Call ECR_TRACE ("  -- BYTOP -- ",0) From GESECRAN
  Call ECR_TRACE ("  -- STI1 = " + STI1,0) From GESECRAN
  Call ECR_TRACE ("  -- STI2 = " + STI2,0) From GESECRAN
Endif

K = 1
For W = 1 To len(STI1)
  If K > len(STI2) : K = 1 : Endif
  BYO = func INTXOR(ascii(mid$(STI1,W,1)),ascii(mid$(STI2,K,1)), MODO)
  K += 1
  Append CLBO, func INT2BITSTR(BYO, MODO)
Next

If MODO = 1 : Call ECR_TRACE ("  -- len (CLBO) = "+num$(len(CLBO)) + "; CLBO = "+CLBO,0) From GESECRAN : Endif

CLBOUT = func BITSTR2B64(CLBO, MODO)

End CLBOUT
##########################################################################################
##########################################################################################
### Xor of 2 integers - returns the resulting integer
##########################################################################################
Funprog INTXOR(BYI1, BYI2, MODO)
Value    Integer BYI1
Value    Integer BYI2
Value    Integer MODO

Local Integer BYO
Local Shortint J, D

While 2^D < max(BYI1,BYI2)
 D += 1
Wend

For J = 1 To D
  BYO = setBit(BYO, J, getBit(BYI1,J) xor getBit(BYI2,J))
Next

If MODO = 1 : Call ECR_TRACE ("  xor of "+num$(BYI1)+" and "+num$(BYI2)+": " + num$(BYO) + " = "+chr$(BYO),0) From GESECRAN : Endif

End BYO
##########################################################################################
##########################################################################################
### Integer input - String of 0's and 1's output
##########################################################################################
Funprog INT2BITSTR(INTI, MODO)
Value    Integer INTI
Value    Integer MODO

Local Char     STRO(255)
Local Shortint J, D

If INTI < 0 | INTI > 65535 : Goto END_INT2BITSTR : Endif
If INTI = 0 : STRO = "0" : Endif

While 2^D <= INTI
  STRO = num$(getBit(INTI,D+1)) + STRO
  D += 1
Wend

While mod(D,8)<>0 | D = 0
  D+=1
Wend

STRO = string$(D-len(STRO),"0") + STRO

$END_INT2BITSTR
End STRO
##########################################################################################
##########################################################################################
### b64 encode - input as string of 0's and 1's
##########################################################################################
Funprog BITSTR2B64(CLBIN, MODO)
Value    Clbfile CLBIN
Value    Integer MODO

Local Integer K, I, J, INT64, INT64B
Local Char    STR6BIT(6)
Local Clbfile CLBOUT

If mod(len(CLBIN),8) <> 0 or len(CLBIN) = 0 : Goto END_BITSTR2B64 : Endif
K = mod(len(CLBIN),6)

If K <> 0
  Append CLBIN, string$(6-K,"0")
Endif

K = 0
I = 0
While 6*I<len(CLBIN)
  STR6BIT = mid$(CLBIN, K+1, 6)
  I += 1
  K = 6*I
  INT64  = 0
  INT64B = 0
  For J = 1 To 6
    INT64 = setBit(INT64, J, val(mid$(STR6BIT,6-J+1,1)))
  Next

  If INT64>=0 & INT64<=25
    INT64B = INT64 + 65
  Elsif INT64>25 & INT64<=51
    INT64B = INT64 + 71
  Elsif INT64>51 & INT64<=61
    INT64B = INT64 - 4
  Elsif INT64=62
    INT64B=43
  Elsif INT64=63
    INT64B=47
  Endif

  #If MODO = 1 : Call ECR_TRACE ("      -- "+num$(I)+" - STR6BIT = " + STR6BIT + "; INT64 = " + num$(INT64)+ "; INT64B = " + num$(INT64B)+ "; char = " + chr$(INT64B),0) From GESECRAN : Endif

  Append CLBOUT, chr$(INT64B)
Wend

K = mod(I,4)
If K > 0
  Append CLBOUT, string$(4-K,"=")
Endif

$END_BITSTR2B64
End CLBOUT
##########################################################################################
##########################################################################################
### b64 encode single string
##########################################################################################
Funprog B64SINGLE(STI1, MODO)
Value    Char    STI1
Value    Integer MODO

Local Integer BYO
Local Clbfile CLBO
Local Clbfile CLBOUT
Local Shortint K, W

K = 1
For W = 1 To len(STI1)
  BYO = ascii(mid$(STI1,W,1))
  Append CLBO, func INT2BITSTR(BYO, MODO)
  If MODO = 1 : Call ECR_TRACE ("  -- "+num$(BYO),0) From GESECRAN : Endif
Next

CLBOUT = func BITSTR2B64(CLBO, MODO)

End CLBOUT
##########################################################################################
