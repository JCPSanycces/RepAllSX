#<AdxTL>@(#)5.0.0.0 $Revision$
# Traitement de fin d'installation appelé par la console
#---------------------------------------------------------------#

Subprog INIT_CONSOLE(APPLI,RESULT,TRACE)
Value Char APPLI
Variable Char RESULT , TRACE

Local Integer OK , OKSUB , STAT, STAINI
Local Char    SERVERBO(50) , HISAPL(GLONADS) , APPBLB(GLONADS)

OK = 1

# Installation du dossier #

Call OUVRE_TRACE(func AFNC.MES(mess(147,125,1),APPLI)) From LECFIC

# 96797 : bug in menu, run with the infbox in INSTALL
Call INIGLOBVAR(STAINI) From GLOBVAR
Call CONNECTSIL From GESUSER

Onerrgo ERREUR

TRACE = filpath("TRA",GTRACE,"tra")

# Création de la fiche dossier si elle n'existe pas

Local File ADOSSIER [ADS]
Call LECPAR(APPLI)
If GOK<>1
 OK = 0
Else
 Read [ADS]DOSSIER=APPLI
 If fstat : OK = 0 : Endif
Endif
If !OK
 Call ECR_TRACE(APPLI-":"-mess(180,125,1),1) From GESECRAN : # Erreur en création de la fiche dossier
 Goto FIN_AINSTCONS : #110823
Endif

# Création du fichier folders

Call ECR_TRACE(mess(12,125,1)-"FOLDERS.xml",0) From GESECRAN : # Création du fichier
Call CREFOLDERS From VALCSTWEB

# Type de base
Read [ADS]DOSSIER=APPLI
Call ECR_TRACE(mess(57,0,1)-":"-mess([F:ADS]TYPDBA,57,1)-"("+[F:ADS]DOSSIER+")",0) From GESECRAN

# Mise à jour des droits sur la table ADICTRT à cause de la vue ADICADX

Call GENDROIT(APPLI,"ADICTRT")

# Création des vues dans le dossier histo (vues sur les tables du dossier std)

HISAPL = ""
Local File =APPLI+".ADOVAL"  [AD_]
Read [AD_]ADW0 = "";"";"HISDOS"
If !fstat & [F:AD_]VALEUR<>"" & filinfo(filpath("","","",[F:AD_]VALEUR),0)>=0
 HISAPL = [F:AD_]VALEUR
Endif
Close Local File [AD_]
If HISAPL<>""
 Call ECR_TRACE("Folder with historical folder",0) From GESECRAN
#107271 : il faut valider les vues sur les tables du dossier
# If func DOSSUB.RELEASE(APPLI)=func DOSSUB.RELSUP(APPLI)
  Call ECR_TRACE(mess(148,125,1)-HISAPL,0) From GESECRAN : # Création des vues
  Call INSTALL_VUE(APPLI,HISAPL,OKSUB) From CREHISTO
  If !OKSUB
   OK = 0 : Call ECR_TRACE(mess(6,123,1),0) From GESECRAN : # Erreur
  Endif
  Call ECR_TRACE(mess(15,125,1)-HISAPL,0) From GESECRAN : # MAJ dictionnaire
  Call INSTALL_DICO(APPLI,HISAPL,OKSUB) From CREHISTO :#107271
  If !OKSUB
   OK = 0 : Call ECR_TRACE(mess(6,123,1),0) From GESECRAN : # Erreur
  Endif
# Else
#  Call ECR_TRACE(APPLI+"/X3 version:"+func DOSSUB.RELEASE(APPLI)+"/"+func DOSSUB.RELSUP(APPLI)
#& -"-> views not updated on historical folder",0) From GESECRAN
# Endif
Else
 Call ECR_TRACE("Folder without historical folder",0) From GESECRAN
Endif

# Création des vues (vues normales du dossier std)

If filinfo(filpath("FIL","AVIEW","fde",APPLI),0)>0
 If func DOSSUB.RELEASE(APPLI)=func DOSSUB.RELSUP(APPLI)
  Call ECR_TRACE(mess(148,125,1),0) From GESECRAN : # Création des vues
  Call INSTALL_VUE(APPLI,OKSUB) From DOSVUE
  If !OKSUB
   OK = 0 : Call ECR_TRACE(mess(6,123,1),0) From GESECRAN : # Erreur
  Endif
 Else
  Call ECR_TRACE(APPLI+"/X3 version:"+func DOSSUB.RELEASE(APPLI)+"/"+func DOSSUB.RELSUP(APPLI)-"-> views not created",0) From GESECRAN
 Endif
Else
 Call ECR_TRACE("File AVIEW not found -> views not created",0) From GESECRAN
Endif

# Validation des datawarehouse

If filinfo(filpath("FIL","ABIDATWRH","fde",APPLI),0)>0
 If func DOSSUB.RELEASE(APPLI)=func DOSSUB.RELSUP(APPLI)
  If func DOSSUB.PATNUM(APPLI)=func DOSSUB.PATNUMSUP(APPLI)
   Call RECHPROP("component.busobj.servername",SERVERBO,STAT) From INTRUTILA
   If func ARECAUO.APPDEM(APPLI)
    Local File =APPLI+".ADOVAL"  [AD_]
    Read [AD_]ADW0 = "";"";"SUPDOS"
    If !fstat & [F:AD_]VALEUR<>""
     Local File =APPLI+".ADOVAL"  [AD2]
     Read [AD2]ADW0 = "";"";"LANDEMOBI"
     If !fstat & [F:AD2]VALEUR<>""
      Local File =APPLI+".ABIDATWRH" [ABW]
      Trbegin [ABW]
       Update [ABW]  With LAN=[F:AD2]VALEUR
      Commit
      Close Local File [ABW]
     Endif
     Close Local File [AD2]
    Endif
    Close Local File [AD_]
    If SERVERBO<>""
     Call ECR_TRACE(mess(2,148,1),0) From GESECRAN : # Validation datawarehouse
     Call VALTOT(APPLI,1,1,1,OKSUB) From ABIVALTOT
     If !OKSUB
      OK = 0 : Call ECR_TRACE(mess(6,123,1),0) From GESECRAN : # Erreur
     Endif
    Endif
   Endif
  Else
   Call ECR_TRACE(func AFNC.MES2(mess(162,148,1),APPLI,func DOSSUB.PATNUM(APPLI)),0) From GESECRAN
  Endif
 Endif
Endif

# Mise à jour des pièces jointes logos utilisées dans les états

If filinfo(filpath("FIL","ABLOB","fde",APPLI),0)>0
 Call ECR_TRACE(mess(152,125,1),0) From GESECRAN : # Mise à jour des blobs logos
 Local File =APPLI+".ABLOB" [ABB], =APPLI+".AOBJTXT" [AOX]
 Trbegin [ABB] , [AOX]
  APPBLB = ""
  For [ABB]ABB0 Where CODBLB="PJ_ADS" & left$(NAMBLB,4)="logo"
   APPBLB = [F:ABB]IDENT1 : Break
  Next ABB
  If APPBLB<>""
   For [ABB]ABB0 Where CODBLB="PJ_ADS" & left$(NAMBLB,4)="logo" & IDENT1=APPBLB With Stability
    Readlock [ABB]ABB0 Curr
    If fstat=1
     Call ERREUR("ABLOB"-[F:ABB]CODBLB-[F:ABB]NAMBLB,5) From DOSDIC
    Elsif fstat
     Call ERREUR("ABLOB"-[F:ABB]CODBLB-[F:ABB]NAMBLB,4) From DOSDIC
    Else
     [F:ABB]IDENT1 = APPLI
     Rewrite [ABB]
     If fstat
      Call ERREUR("ABLOB"-[F:ABB]CODBLB-[F:ABB]NAMBLB,2) From DOSDIC
     Endif
    Endif
   Next ABB
   For [AOX]AOX0 Where ABREV="ADS" & left$(NAM,4)="logo" & IDENT1=APPBLB With Stability
    Readlock [AOX]AOX0 Curr
    If fstat=1
     Call ERREUR("AOBJTXT"-[F:AOX]ABREV-[F:AOX]NAM,5) From DOSDIC
    Elsif fstat
     Call ERREUR("AOBJTXT"-[F:AOX]ABREV-[F:AOX]NAM,4) From DOSDIC
    Else
     [F:AOX]IDENT1 = APPLI
     Rewrite [AOX]
     If fstat
      Call ERREUR("AOBJTXT"-[F:AOX]ABREV-[F:AOX]NAM,2) From DOSDIC
     Endif
    Endif
   Next AOX
  Endif
 Commit
 Close Local File [ABB] , [AOX]
Endif

# Mise à niveau du rowid de la table AUDITH sous SQL

If func AFNC.ACTIVDOS(APPLI,"AUDIT") : # Sql
 If filinfo(filpath("FIL","AUDITH","fde",APPLI),0)>0
  Call ECR_TRACE("Set rowid AUDITH file",0) From GESECRAN
  Call GENDROIT(APPLI,"AUDITH")
  If [F:ADS]TYPDBA=2 : # Sql
   # Issue 84672 - 2012-10-15 by VPO : gestion ROWID AUDITH,AJSAUDIT,AUDITBI
   #Call SET_ROWID(APPLI,STAT) From SUBTRIGGER
   Call SET_ROWID_TABLE(APPLI,"AUDITH",STAT) From SUBTRIGGER
  Else
   # Issue 84672 - 2012-10-15 by VPO : gestion ROWID AUDITH,AJSAUDIT,AUDITBI
   #Call SET_ROWID_OR(APPLI,STAT) From SUBTRIGGER
   Call SET_ROWID_OR_TABLE(APPLI,"AUDITH",STAT) From SUBTRIGGER
  Endif
  If STAT
   # Erreur (Table AUDITH)
   OK = 0 : Call ECR_TRACE(mess(6,123,1)-"("+mess(56,123,1)-"AUDITH)",0) From GESECRAN
  Endif
 Endif
Endif

# Issue 84672 - 2012-10-15 by VPO : gestion ROWID AUDITH,AJSAUDIT,AUDITBI
If filinfo(filpath("FIL","AJSAUDIT","fde",APPLI),0)>0
  Call ECR_TRACE("Set rowid AJSAUDIT file",0) From GESECRAN
  Call GENDROIT(APPLI,"AJSAUDIT")
  If [F:ADS]TYPDBA=2 : # Sql
   Call SET_ROWID_TABLE(APPLI,"AJSAUDIT",STAT) From SUBTRIGGER
  Else
   Call SET_ROWID_OR_TABLE(APPLI,"AJSAUDIT",STAT) From SUBTRIGGER
  Endif
  If STAT
   # Erreur (Table AUDITH)
   OK = 0 : Call ECR_TRACE(mess(6,123,1)-"("+mess(56,123,1)-"AJSAUDIT)",0) From GESECRAN
  Endif
Endif

# Issue 84672 - 2012-10-15 by VPO : gestion ROWID AUDITH,AJSAUDIT,AUDITBI
If filinfo(filpath("FIL","AUDITBI","fde",APPLI),0)>0
  Call ECR_TRACE("Set rowid AUDITBI file",0) From GESECRAN
  Call GENDROIT(APPLI,"AUDITBI")
  If [F:ADS]TYPDBA=2 : # Sql
   Call SET_ROWID_TABLE(APPLI,"AUDITBI",STAT) From SUBTRIGGER
  Else
   Call SET_ROWID_OR_TABLE(APPLI,"AUDITBI",STAT) From SUBTRIGGER
  Endif
  If STAT
   # Erreur (Table AUDITH)
   OK = 0 : Call ECR_TRACE(mess(6,123,1)-"("+mess(56,123,1)-"AUDITBI)",0) From GESECRAN
  Endif
Endif

# Generation trigger fe toutes les table
#112168 only on same release, otherwise valdos
If func DOSSUB.RELEASE(APPLI)=func DOSSUB.RELSUP(APPLI)
 Call TRIGGER_ALL From DOSTAB
Endif

#94154 Génération JSON Processus
#94778 only on same release, otherwise valdos
If func DOSSUB.RELEASE(APPLI)=func DOSSUB.RELSUP(APPLI)
 Call GENAPR(APPLI,STAT)
 If STAT
  OK = 0
 Endif
Endif

# Insertion des utilisateurs nommés
Onerrgo RIEN
Call IMPORT(APPLI,STAT) From ARECAUO
Onerrgo ERREUR
If STAT<>1
 # Erreur x (Mise à jour des utilisateurs nommés)
 Call ECR_TRACE(mess(6,123,1)-num$(STAT)-"("+mess(197,125,1)+")",0) From GESECRAN
Endif

RESULT = num$(OK)

# Installation superviseur et mise à jour ??

If OK & 1=0 : # mb 16.6.14 A tester
 GOK = 1
 Call INSTALL From INSTALL
 If GOK<>1
  OK = 0
 Elsif filinfo(filpath("","X3","new",0),0)>=0 : # On a chargé une mise à jour
  Call MAJ From MAJX3
  If GOK<1 : OK = 0 : Endif
 Endif
Endif

#109897
If dim(GDOSX3)<0
 Global Char    GDOSX3(GLONADS)
Endif
Call PARAM("","SUPDOS",GDOSX3) From ADOVAL
Call PATCH(APPLI) From UTIMAJREPSRV


$FIN_AINSTCONS
Onerrgo
Call ECR_TRACE(mess(4,125,1),0) From GESECRAN : # Fin de génération
Call FERME_TRACE From LECFIC

End

#---------------------------------------------------------------#
# Pour savoir où ça plante
#---------------------------------------------------------------#

$ERREUR
GERREUR = errn
GMESSAGE = errp-"("+num$(errl)+")"-mess(6,123,1)-num$(GERREUR)-":"-errmes$(GERREUR)-errm
OK = 0
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
Resume

$RIEN
Resume

#--------------------------------------------------------------------------------#
# Affectation des droits sur une table à l'import d'un dossier
#--------------------------------------------------------------------------------#

Subprog GENDROIT(APPLI,TABLE)
Value Char APPLI , TABLE
Local Integer I
Local Char    COMMAND(250)
If APPLI="" : End : Endif
Gosub LEC_DOS
For I=1 To NBDOS
 # Table x/Mise à jour des droits dossier y
 Call ECR_TRACE(mess(106,142,1)-TABLE-":"-mess(191,139,1)-TBDOS(I),0) From GESECRAN
 System COMMAND=adxmac(0)+'@valfil -r'-TBDOS(I)-TABLE
Next I
End

#-------------------------------------------#
$LEC_DOS
Local Integer I , NBDOS
Local Char    FICAPL(250) , LIGNE(250) , TBDOS(GLONADS)(1..10)
FICAPL = filpath("","APL","ini",APPLI)
If filinfo(FICAPL,0)>=0
 Openi FICAPL Using [VUE]
 Rdseq LIGNE Using [VUE]
 While fstat=0
  LIGNE = vireblc(LIGNE,2)
  If left$(LIGNE,10)="adxmother("
   J = instr(1,LIGNE,"=")
   If J
    LIGNE = vireblc(right$(LIGNE,J+1),2)
    LIGNE = seg$(LIGNE,2,len(LIGNE)-1)
    If !find(LIGNE,TBDOS(1..NBDOS)) & filinfo(filpath("","","",LIGNE),0)>=0
     NBDOS += 1
     TBDOS(NBDOS) = LIGNE
    Endif
   Endif
  Endif
  Rdseq LIGNE Using [VUE]
 Wend
 Openi Using [VUE]
Endif
If !find(APPLI,TBDOS)
 NBDOS += 1
 TBDOS(NBDOS) = APPLI
Endif
Return

#---------------------------------------------------------------#
# Création d'une fiche dossier à partir du fichier PARAM.tmp
#---------------------------------------------------------------#

Subprog LECPAR(DOSSIER)
Value Char    DOSSIER
Local Char    FICPAR(GDIMFIC)
Local Integer TYP , I , J , K , CW , CC , CL , CD , ER , IUM
Local Char    DIME(5) , VARIA(GLONAVA) , VALEUR(GDIMFIC) , LIGNE(GDIMFIC) , CLASSE(5)
Local Integer WLNBLIEN , WLTYPLIEN(1..10) , WLLIENACT(1..10) , WLSERV(1..10) , WLTYPOS(1..10) , WLTYPDBA(1..10)
Local Char    WLDOSTARG(10)(1..10) , WLMAC(GLONAMC)(1..10) , WLSOL(GLONASO)(1..10) , WLREP(80)(1..10)
Local Char    WLSRC(10)(1..10) , WLDBA(30)(1..10) , WLUSR(20)(1..10) , WLPWD(24)(1..10)
Local Char    HISDOS(10) , SUPDOS(GLONADS) , APPLI(GLONADS)
Local Integer TYPDBA

#110823
If func DOSBASE.ISBASE_RESERVED_WORDS([L]DOSSIER)
 Call ECR_TRACE(func AFNC.MES1(mess(272,133,1),[L]DOSSIER),1) From GESECRAN : # $1$ est un mot réservé aux bases de données
 GOK = 0 : End
Endif

Local File    ADOSSIER [ADS] , ADOSACT [ADA] , ADOSDIM [ADE] , ADOSSOL [ADD]
If func APRODUCT.AGETRELEASESUP()>="17v.132" : Local File ADOSLIV [ADK] : Endif

FICPAR = filpath("","PARAM","tmp",DOSSIER)
If filinfo(FICPAR,0)<0
 FICPAR = filpath("","PARAM","ini",DOSSIER)
 If filinfo(FICPAR,0)<0
  FICPAR = filpath("","PARAM","tmp",DOSSIER)
  Call ECR_TRACE("|"+FICPAR-":"-mess(101,100,1),1) From GESECRAN : # Fichier inexistant
  End
 Endif
Endif
IUM = GUTF8
Gosub VERSION
If ER
 Call ECR_TRACE(mess(70,122,1)-"|"+FICPAR,1) From GESECRAN : # Erreur de lecture sur le fichier
 End
Endif

# Création du dossier

Call ECR_TRACE(mess(2,125,1)-DOSSIER,0) From GESECRAN
Openi FICPAR Using [P]
Iomode adxifs "" Using [P]
Iomode adxirs chr$(10) Using [P]
Iomode adxium IUM Using [P]
Call DEBTRANS From GLOCK
Gosub TR_DOS
Openi Using [P]

# Mise à jour des paramètres

For APPLI=nomap(0),nomap(1),nomap(2)
 If filinfo(filpath("FIL","ADOSSIER","fde",APPLI),0)>0
  SUPDOS = APPLI : Break
 Endif
Next APPLI
Read [ADS]DOSSIER=SUPDOS
If fstat
 # Paramètres d'installation impossible à déterminer\Dossier # inaccessible
 Call ECR_TRACE(func AFNC.MES(mess(184,125,1),SUPDOS),1) From GESECRAN
 TYPDBA = GTYPDBA
 GOK = 0
Else
 TYPDBA = [F:ADS]TYPDBA
Endif

Local File =DOSSIER+".ADOVAL" [ADW]
Call SETPAR("SUPDOS",SUPDOS)
Call SETPAR("HISDOS",HISDOS)
Call SETPAR("TYPDBA",num$(TYPDBA))
Close Local File [ADW]

Call DEBTRANS From GLOCK
Gosub TR_ADS

Close Local File [ADS] , [ADA] , [ADE] , [ADD]
If func APRODUCT.AGETRELEASESUP()>="17v.132" : Close Local File [ADK] : Endif
End

#---------------------------------------------------------------#
# Forçage des paramètres dans ADOSSIER
#---------------------------------------------------------------#

$TR_ADS
Trbegin [ADS]
 Readlock [ADS]DOSSIER = DOSSIER
 If fstat=1
  GOK = -1 : GLOCK = "$ADOSSIER"-DOSSIER : Goto ROLL_TR_ADS
 Elsif fstat
  GOK = 0 : Call RSTA("ADS",DOSSIER) From GLOCK : Goto AB_TR_ADS
 Endif
 [F:ADS]DOSHIS = HISDOS
 [F:ADS]TYPDBA = TYPDBA
 Rewrite [ADS]
 If fstat
  GOK = 0 : Call FSTA("ADS") From GLOCK : Goto AB_TR_ADS
 Endif
Commit
Return

$AB_TR_ADS
Rollback
Return

$ROLL_TR_ADS
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_ADS : Endif

#---------------------------------------------------------------#
# Transaction de création/maj dossier
#---------------------------------------------------------------#

$TR_DOS
GOK = 1
Trbegin [ADS]
 Delete [ADS] Where DOSSIER=[L]DOSSIER
 Delete [ADS] Where DOSSIER=[L]DOSSIER
 Delete [ADD] Where DOSSIER=[L]DOSSIER
 Delete [ADA] Where DOSSIER=[L]DOSSIER
 Delete [ADE] Where DOSSIER=[L]DOSSIER
 If func APRODUCT.AGETRELEASESUP()>="17v.132"
  Delete [ADK] Where DOSSIER=[L]DOSSIER
 Endif
 Rdseq LIGNE Using [P]
 While fstat=0
  If left$(LIGNE,1)="#"
   Gosub LECFIC
   If GOK<1 : Break : Endif
  Endif
  Rdseq LIGNE Using [P]
 Wend
 If GOK<1 : Goto AB_TR_DOS : Endif
Commit
Return

$AB_TR_DOS
Rollback
Return

$LECFIC
CLASSE = right$(LIGNE,2)
Repeat
 Rdseq VARIA Using [P]
 If VARIA<>"#"
  Rdseq DIME Using [P]
  J = val(DIME)
  Rdseq VALEUR Using [P]
  If evalue("dim([F:"+CLASSE+"]"+VARIA+")")>=J
   TYP = evalue("type([F:"+CLASSE+"]"+VARIA+")")
   Case TYP
    When 1,2,4,5,6,7,8,9
     Assign "[F:"+CLASSE+"]"+VARIA+"("+num$(J-1)+")" With val(VALEUR)
    When 3
     Assign "[F:"+CLASSE+"]"+VARIA+"("+num$(J-1)+")" With gdat$(VALEUR)
    When 525
     Assign "[F:"+CLASSE+"]"+VARIA+"("+num$(J-1)+")" With toUuid(VALEUR)
    When 526
     If find(VALEUR,"","0","null","0000-00-00T00:00:00Z")
      Assign "[F:"+CLASSE+"]"+VARIA+"("+num$(J-1)+")" With gdatetime$("")
     Else
      Assign "[F:"+CLASSE+"]"+VARIA+"("+num$(J-1)+")" With gdatetime$(VALEUR)
     Endif
    When Default
     Assign "[F:"+CLASSE+"]"+VARIA+"("+num$(J-1)+")" With VALEUR
   Endcase
  Elsif CLASSE="ADS"
   Case "VARIA"
    When "LNBIEN"   : [L]WLNBLIEN     = val(VALEUR)
    When "LTYPLIEN" : [L]WLTYPLIEN(J) = val(VALEUR)
    When "LDOSTARG" : [L]WLDOSTARG(J) = VALEUR
    When "LLIENACT" : [L]WLLIENACT(J) = val(VALEUR)
    When "LMAC"     : [L]WLMAC(J)     = VALEUR
    When "LSERV"    : [L]WLSERV(J)    = val(VALEUR)
    When "LTYPOS"   : [L]WLTYPOS(J)   = val(VALEUR)
    When "LTYPDBA"  : [L]WLTYPDBA(J)  = val(VALEUR)
    When "LSOL"     : [L]WLSOL(J)     = VALEUR
    When "LREP"     : [L]WLREP(J)     = VALEUR
    When "LSRC"     : [L]WLSRC(J)     = VALEUR
    When "LDBA"     : [L]WLDBA(J)     = VALEUR
    When "LUSR"     : [L]WLUSR(J)     = VALEUR
    When "LPWD"     : [L]WLPWD(J)     = VALEUR
   Endcase
  Endif
 Endif
Until VARIA="#"
Case CLASSE
 When "ADS"
  If !CW & GADONIX<>2 : [F:ADS]CREWIN = 2 : Endif
  If !CC & GADONIX<>2 : [F:ADS]CRECNS = 2 : Endif
  If !CD
   If dim(TBCRY)<0
    Gosub SETLEG From SUPMAJ30
   Endif
   K = find([F:ADS]CRYDEF,TBCRY(1..NBLEG))
   If K
    [F:ADS]DOSLEG(0) = TBLEG(K)
    [F:ADS]NBLEG = 1
   Endif
  Endif
  HISDOS = [F:ADS]DOSHIS
  Write [ADS]
  If fstat
   GOK = 0 : Call FSTA(CLASSE) From GLOCK
  Elsif CL
   For I=1 To [L]WLNBLIEN
    [F:ADD]LTYPLIEN = [L]WLTYPLIEN(I)
    [F:ADD]LDOSTARG = [L]WLDOSTARG(I)
    [F:ADD]LLIENACT = 1 : # Lien non actif
    [F:ADD]LMAC     = [L]WLMAC(I)
    [F:ADD]LSERV    = [L]WLSERV(I)
    [F:ADD]LTYPOS   = [L]WLTYPOS(I)
    [F:ADD]LTYPDBA  = [L]WLTYPDBA(I)
    [F:ADD]LSOL     = [L]WLSOL(I)
    [F:ADD]LREP     = [L]WLREP(I)
    [F:ADD]LSRC     = [L]WLSRC(I)
    [F:ADD]LDBA     = [L]WLDBA(I)
    [F:ADD]LUSR     = [L]WLUSR(I)
    [F:ADD]LPWD     = [L]WLPWD(I)
    [F:ADD]NUMLIG   = I
    [F:ADD]DOSSIER  = [L]DOSSIER
    Write [ADD]
    If fstat
     GOK = 0 : Call FSTA("ADD") From GLOCK : Break
    Endif
   Next I
  Endif
 When "ADD"
  [F:ADD]LLIENACT = 1 : # Lien non actif
  Write [ADD] : If fstat : GOK = 0 : Call FSTA("ADD") From GLOCK : Endif
 When "ADA"
  Write [ADA] : If fstat : GOK = 0 : Call FSTA("ADA") From GLOCK : Endif
 When "ADE"
  Write [ADE] : If fstat : GOK = 0 : Call FSTA("ADE") From GLOCK : Endif
 When "ADK"
  If func APRODUCT.AGETRELEASESUP()>="17v.132"
   Write [ADK] : If fstat : GOK = 0 : Call FSTA("ADK") From GLOCK : Endif
  Endif
Endcase
Return

# Parcours du fichier param pour déterminer les différences de versions

$VERSION
Raz ER , CW , CC , CD , CL
Onerrgo ERR
Openi FICPAR Using [P]
Iomode adxifs "" Using [P]
Iomode adxirs chr$(10) Using [P]
Iomode adxium IUM Using [P]
Rdseq LIGNE Using [P]
While !fstat
 If left$(LIGNE,1)="#"
  CLASSE = right$(LIGNE,2)
  Repeat
   Rdseq VARIA Using [P]
   If VARIA<>"#"
    Case CLASSE
     When "ADS"
      Case VARIA
       When "DOSLEG"  : CD = 1
       When "CREWIN"  : CW = 1
       When "CRECNS"  : CC = 1
       When "LNBLIEN" : CL = 1
      Endcase
    Endcase
    Rdseq DIME Using [P]
    Rdseq VALEUR Using [P]
   Endif
  Until VARIA="#"
 Endif
 Rdseq LIGNE Using [P]
Wend
Openi Using [P]
Onerrgo
If ER & IUM=GUTF8
 IUM = GASCII
 Goto VERSION
Endif
Return

$ERR
ER = errn
Resume

#---------------------------------------------------------------#
# Affectation d'un paramètre à une valeur
#---------------------------------------------------------------#

Subprog SETPAR(NOMPAR,VALPAR)
Value Char NOMPAR
Value Char VALPAR
Call DEBTRANS From GLOCK
Gosub TR_PAR
End

$TR_PAR
GOK = 1
Trbegin [ADW]
 Readlock [ADW]ADW0 = "";"";NOMPAR
 If fstat=1
  GOK = -1 : GLOCK = "$ADOVAL"-NOMPAR : Goto ROLL_TR_PAR
 Elsif fstat
  GOK = 0 : Call RSTA("ADW",NOMPAR) From GLOCK : Goto AB_TR_PAR
 Endif
 [F:ADW]VALEUR = VALPAR
 Rewrite [ADW]
 If fstat
  GOK = 0 : Call FSTA("ADW") From GLOCK : Goto AB_TR_PAR
 Endif
Commit
Return

$AB_TR_PAR
Rollback
Return

$ROLL_TR_PAR
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_PAR : Endif
Return

#---------------------------------------------------------------#
# Génération des JSON des processus
#---------------------------------------------------------------#

Subprog GENAPR(APPLI,STAT)
Value Char APPLI
Variable Integer STAT
Local Integer ERR
STAT = 0
Local File =APPLI+".APROCESSUS"  [APR_]
For [APR_]APR1
  ERR=func ARECOPRO.GENE_SYRA_JSON(APPLI,[APR_]CODPRO,[APR_]CODLEG)
  If ERR
   Call ECR_TRACE(mess(6,123,1)-mess(138,127,1)-[APR_]CODLEG+"~"+[APR_]CODPRO,0) From GESECRAN
   STAT=ERR
  Endif
Next
Close Local File [APR_]
End

