#<AdxTL>@(#)10.0.0.0 $Revision$
$ACTION
Case ACTION
 When "C_VALEUR_DEB" : Gosub C_VALEUR_DEB
 When "C_VALEUR_OBJ" : Gosub C_VALEUR_OBJ
Endcase
Return


$C_VALEUR_DEB

# Updating GSOCIETE,GCURLEG,GCURFCY to trigger controls on the group of sites/companies and on legislation in the CONTOBJ process
If dim([M]FCY)>0
 If [M]FCY<>""
  Call GETSOC([M]FCY) From DEVSUB
 Elsif [M]CMP<>""
  If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
  Call LEC_CPY([M]CMP) From CPTLEC
  If [F:CPY]MAIFCY<>""
   Call GETSOC([F:CPY]MAIFCY) From DEVSUB
  Elsif [F:CPY]LEG<>""
   GCURLEG = [F:CPY]LEG
  Endif
  Raz GCURFCY : # To not trigger control on the group in the CONTOBJ process
 Else
  If GNBLEG=1
   GCURLEG = GDOSLEG(1)
  Else
   GCURLEG = [M]LEG
  Endif
 Endif
Endif
Return

$C_VALEUR_OBJ

If [F:ADP]OBJET="PGT"
 If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif
 If dim([M:ADWP]CMP)>0
  Call CONTGTE(VALEUR,GCURLEG,[M:ADWP]CMP) From SUBGTE
 Else
  Call CONTGTE(VALEUR,GCURLEG,"") From SUBGTE
 Endif
 If mkstat : Return : Endif
 Call CONTEXE([F:GTE]ACS) From CPTSUB
Endif

If [F:ADP]OBJET="PCD"
 If clalev([F:CDA])=0 : Local File GACCDENCOD [CDA] : Endif
 If dim([M:ADWP]CMP)>0
  Call CONTCDA(VALEUR,GCURLEG,[M:ADWP]CMP) From SUBCDA
 Else
  Call CONTCDA(VALEUR,GCURLEG,"") From SUBCDA
 Endif
 If mkstat : Return : Endif
 Call CONTEXE([F:CDA]ACS) From CPTSUB
Endif

If [F:ADP]OBJET="PTP"
 If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
 If dim([M:ADWP]CMP)>0
  Call CONTTPY(VALEUR,GCURLEG,[M:ADWP]CMP) From SUBTPY
 Else
  Call CONTTPY(VALEUR,GCURLEG,"") From SUBTPY
 Endif
 If mkstat : Return : Endif
 Call CONTEXE([F:TPY]ACS) From CPTSUB
Endif
Return
