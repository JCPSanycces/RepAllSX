Unlock =SYMBOLE

#  SEGAY 10/11/10 LOT P02
# On fait afficher la trace des postes à la fin dans $TR1
#Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
#If NBPOT>0
# #Nombre de postes mis à jour :
# Call ECR_TRACE(mess(26,10720,1)-":"-num$(NBPOT),0) From GESECRAN
#Else
# #Aucun poste à traiter
# Call ECR_TRACE(mess(27,10720,1),0) From GESECRAN
#Endif
If !GSERVEUR
 Call FERME_TRACE From LECFIC
Endif
Return
#  SEGAY 10/11/10 LOT P02
#  Boucle sur GCP
#####################################
$FOR_GCP
   # To be sure...
   Filter [GCP] Where evalue(L_CRITGCP) & evalue(L_CRITGCD)
   Read [GCP]GCP0 Last
   If fstat>=4 & L_IJ=NIVGRP
    Call ERREUR([L]CODGRP-mess(10,112,1)) From GESECRAN
    #### Code inexistant
    GERR = 1 : SAI = 0 : Return
   Elsif fstat>=4
    Raz [F:GCP]
   Endif
   Filter [GCP]
   # JML 27/09/10 CG Parcourir tous les niveaux...
   For [GCP]GCP0 Where evalue(L_CRITGCP) & evalue(L_CRITGCD)
    WGOK=1 # SEGAY 25/10/12 US 930 81085
    Raz L_CPC, L_NIV, L_NB_CPC, L_ORI, L_LEG, L_LEG_NIV # SEGAY 25/10/12 US 930 81085
    L_LEG_NIV =[F:GCP]LEG # SEGAY 25/10/12 US 930 81085
#    If L_LEG_NIV_SUP <> "" & L_LEG_NIV <>"" &  L_LEG_NIV_SUP <> L_LEG_NIV
    If L_LEG_NIV_SUP <> ""  &  L_LEG_NIV_SUP <> L_LEG_NIV
 # Incompatibilié de législation
       Gosub MESSAGE_NIV
       WMESSAGE = mess(104,10720,1)-":"-mess(NIVGRP,10937,1)-[L]CODGRP-":"-L_LEG_NIV_SUP-"/"-mess(L_IJ,10937,1)-WMESSAGE-":"-L_LEG_NIV    # Incompatibilié de législation
       WGOK = 0
    Endif
    # SEGAY
    # Si maj Dossier il faut garder le lien entre GPC et GCD
    If NIVGRP = 1
     For [HRGCD]GCD0 Where UOMGRP=[F:GCP]UOMGRP & JOBGRP=[F:GCP]JOBGRP & CPCFAM=[F:GCP]CPCFAM & evalue(L_CRITGCP) & evalue(L_CRITGCD)
# SEGAY 25/10/12 US 930 81085
       Call LECTURE("CPC",[F:HRGCD]CPC,"") From CONTOBJ
       If ([F:CPC]LEG<>"" & [F:GCP]LEG<>"" & [F:CPC]LEG<>[F:GCP]LEG)
&    | ([F:GCP]LEG="" & [F:CPC]LEG<>[F:GCP]LEG)    Then

         WMESSAGE = mess(L_IJ,10937,1)-[F:GCP]UOMGRP-[F:GCP]JOBGRP-[F:GCP]CPCFAM-mess(37,10720,1)-": " +[F:HRGCD]CPC - mess(62,127,1)-":"-[F:CPC]LEG : # Réservé à la législation
         WGOK = 0
         Break(1)
       Endif
# END SEGAY 25/10/12 US 930 81085
       L_CPC(L_NB_CPC) = [F:HRGCD]CPC
       L_NIV(L_NB_CPC) = [F:HRGCD]NIV
       L_LEG(L_NB_CPC) = [F:CPC]LEG # SEGAY 25/10/12 US 930 81085
       L_NB_CPC += 1
     Next : # [HRGCD]GCD0
    Else
     For [HRGCD]GCD0 Where evalue(L_CRITGCP) & evalue(L_CRITGCD)
# SEGAY 25/10/12 US 930 81085
       Call LECTURE("CPC",[F:HRGCD]CPC,"") From CONTOBJ
       If ([F:CPC]LEG<>"" & [F:GCP]LEG<>"" & [F:CPC]LEG<>[F:GCP]LEG)
&    | ([F:GCP]LEG="" & [F:CPC]LEG<>[F:GCP]LEG)    Then

         WMESSAGE = mess(L_IJ,10937,1)-[F:GCP]UOMGRP-[F:GCP]JOBGRP-[F:GCP]CPCFAM-mess(37,10720,1)-": " +[F:HRGCD]CPC - mess(62,127,1)-":"-[F:CPC]LEG : # Réservé à la législation
         WGOK = 0
         Break(1)
       Endif
# END SEGAY 25/10/12 US 930 81085
       L_CPC(L_NB_CPC) = [F:HRGCD]CPC
       L_NIV(L_NB_CPC) = [F:HRGCD]NIV
       L_LEG(L_NB_CPC) = [F:CPC]LEG # SEGAY 25/10/12 US 930 81085
       L_NB_CPC += 1
     Next : # [HRGCD]GCD0
    Endif

    Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
#    Call ECR_TRACE(TIT-":"-mess(L_IJ,10937,1)-[F:GCP]UOMGRP-[F:GCP]JOBGRP-[F:GCP]CPCFAM,0) From GESECRAN
    Call ECR_TRACE(mess(23,10720,1)-":"-mess(L_IJ,10937,1)-[F:GCP]UOMGRP-[F:GCP]JOBGRP-[F:GCP]CPCFAM,0) From GESECRAN
    Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
# SEGAY 25/10/12 US 930 81085
    If !WGOK Then
     Call ECR_TRACE(WMESSAGE,1) From GESECRAN
    Else
# END SEGAY 25/10/12 US 930 81085
      # JML 30/07/10 LOT P02 Newfile GRPCPCD
      GOK = 1
      Call DEBTRANS From GLOCK
      Gosub TR1
      If GOK<1 : Break : Endif
    Endif
   Next : # [GCP]GCP0

Return

#####################################
$TR1
Trbegin [JOT],[POT]
NBJOT=0 : NBPOT=0
If L_IJ<>5
 Gosub CRITERE_JOT
 For [JOT]JOT0 Where evalue (CRITJOT)
  WOK=1 :# SEGAY 25/10/12 US 930 81085
  #Emploi type :
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
# SEGAY 25/10/12 US 930 81085
#  Call ECR_TRACE(mess(5,10937,1)-":"-[F:JOT]COD-[F:JOT]DES,0) From GESECRAN
  Call LECTEXTRA(WDESAX3,"JOBTYP","DES",[F:JOT]COD,"") From ATEXTRA
  Call ECR_TRACE(mess(5,10937,1)-":"-[F:JOT]COD-WDESAX3,0) From GESECRAN
# SEGAY 25/10/12 US 930 81085
#  If WOK & L_IJ <> 1 &  L_LEG_NIV<>"" & [F:JOT]LEG<>"" & L_LEG_NIV <>[F:JOT]LEG # SEGAY 25/10/12 US 930 81085
  If WOK & L_IJ <> 1 &  L_LEG_NIV<>""  & L_LEG_NIV <>[F:JOT]LEG # SEGAY 25/10/12 US 930 81085
     Gosub MESSAGE_NIV
     W_AFF_LEG1=L_LEG_NIV
     W_AFF_LEG2=[F:JOT]LEG
     If L_LEG_NIV =""
        W_AFF_LEG1=mess(91,187,1)
     Endif
     If [F:JOT]LEG  =""
        W_AFF_LEG2=mess(91,187,1)
     Endif
 # Incompatibilié de législation
     WMESSAGE = mess(104,10720,1)-":"-mess(L_IJ,10937,1)-WMESSAGE-":"-W_AFF_LEG1  -"/"- mess(5,10937,1)- [F:JOT]COD -":"-W_AFF_LEG2  # Incompatibilié de législation
     Call ECR_TRACE(WMESSAGE,1) From GESECRAN
     WOK = 0
  Endif
  # SEGAY 25/10/12 US 930 81085
  If WOK
     For L_JK=0 To L_NB_CPC
       If ([F:JOT]LEG <> "" & L_LEG(L_JK) <>  "" & L_LEG(L_JK)<>[F:JOT]LEG)
&       | ([F:JOT]LEG = "" & L_LEG(L_JK) <> [F:JOT]LEG) Then
        WMESSAGE = mess(L_IJ,10937,1) -":"- mess(103,10720,1)- L_CPC(L_JK) -mess(62,127,1)-":"-L_LEG(L_JK) : # Réservé à la législation
        Call ECR_TRACE(WMESSAGE,1) From GESECRAN
        WOK = 0
        Break
       Endif
     Next
  Endif
  If WOK
#  Gosub MAJ_JOT
#  ...
     Gosub MAJ_JOT_POT
     If !GOK : Break : Endif
# END SEGAY 25/10/12 US 930 81085
  Endif : # WOK SEGAY 25/10/12 US 930 81085
  # Segay 10/11/10 Fin Mise à jour du niveau pour les postes à emploi type
 Next
 If   GOK<0 : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
 Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
 If NBJOT>0
  #Nombre d'emplois type mis à jour :
  Call ECR_TRACE(mess(24,10720,1)-":"-num$(NBJOT),0) From GESECRAN
 Else
  #Aucun emploi type à traiter
  Call ECR_TRACE(mess(25,10720,1),0) From GESECRAN
 Endif
Endif

# Segay 10/11/10 lot P02 MAJ postes directement pour niveau = groupe de compétence ou = emploi type
If NIVGRP=4 or NIVGRP=5
  Gosub CRITERE_POT
  For [POT]POT0 Where evalue(CRITPOT)
   WOK=1 :# SEGAY 25/10/12 US 930 81085
   #Poste :
   Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
