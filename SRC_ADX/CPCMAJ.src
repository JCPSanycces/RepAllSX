#SEGAY 25/10/12 US 930 81085
$MAJ_JOT_POT
Gosub MAJ_JOT
If FLGMAJ=1
   [F:JOT]UPDDAT=date$ :  [F:JOT]UPDUSR=GUSER :  [F:JOT]UPDTIM=time
   Rewrite [F:JOT]
   If fstat
    GOK = 0 : Call FSTA("JOT") From GLOCK : Return
   Endif
# SEGAY 25/10/12 US 930 81085
#   Call ECR_TRACE(mess(29,10720,1)-":"-[F:JOT]COD-[F:JOT]DES,0) From GESECRAN
   Call LECTEXTRA(WDESAX3,"JOBTYP","DES",[F:JOT]COD,"") From ATEXTRA
   Call ECR_TRACE(mess(29,10720,1)-":"-[F:JOT]COD-WDESAX3,0) From GESECRAN
   NBJOT+=1
Endif
# SEGAY 10/11/10 mise à jour des postes liés à l'emploi type
For [POT]POT0 Where JOBPOT=[F:JOT]COD
   WOK=1 :# SEGAY 25/10/12 US 930 81085
   #Poste :
   Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
# SEGAY 25/10/12 US 930 81085
#     Call ECR_TRACE(space$(5)+mess(4,10939,1)-":"-[F:POT]COD-[F:POT]DES,0) From GESECRAN
   Call LECTEXTRA(WDESAX3,"POSTE","DES",[F:POT]COD,"") From ATEXTRA
   Call ECR_TRACE(space$(5)+mess(4,10939,1)-":"-[F:POT]COD-WDESAX3,0) From GESECRAN
# SEGAY 25/10/12 US 930 81085
#  If WOK & L_IJ<>1 & [F:POT]LEG<>"" & [F:JOT]LEG<>"" & [F:POT]LEG <> [F:JOT]LEG # SEGAY 25/10/12 US 930 81085
  If WOK & L_IJ<>1 &  [F:JOT]LEG<>"" & [F:POT]LEG <> [F:JOT]LEG # SEGAY 25/10/12 US 930 81085

     W_AFF_LEG1=[F:POT]LEG
     W_AFF_LEG2=[F:JOT]LEG
     If W_AFF_LEG1 =""
        W_AFF_LEG1=mess(91,187,1)
     Endif
     If W_AFF_LEG2  =""
        W_AFF_LEG2=mess(91,187,1)
     Endif
 # Incompatibilié de législation
     WMESSAGE = mess(104,10720,1)-":"-mess(5,10937,1) - [F:JOT]COD  -":"-W_AFF_LEG1 -"/"- mess(6,10937,1)- [F:POT]COD -":"-W_AFF_LEG2

     Call ECR_TRACE(WMESSAGE,1) From GESECRAN
     WOK = 0
  Endif

#   If WOK & [F:POT]LEG<>"" & [F:JOT]LEG<>"" & [F:POT]LEG <> [F:JOT]LEG Then
   If WOK & [F:JOT]LEG<>"" & [F:POT]LEG <> [F:JOT]LEG Then

      WMESSAGE = mess(6,10937,1)-[F:POT]COD -mess(62,127,1)-":"-[F:POT]LEG : # Réservé à la législation
      Call ECR_TRACE(WMESSAGE,1) From GESECRAN
      FLGMAJ=0
      WOK = 0
   Endif
   If WOK & [F:POT]LEG <> ""
      For L_JK=0 To dim([F:JOT]CPC)-1
         If  [F:JOT]CPC(L_JK)<> ""
           Call LECTURE("CPC",[F:JOT]CPC(L_JK),"") From CONTOBJ

           If ([F:CPC]LEG <>  "" & [F:POT]LEG <> "" & [F:CPC]LEG <> [F:POT]LEG)
&           | ([F:POT]LEG="" & [F:CPC]LEG<>[F:POT]LEG )    Then

            WMESSAGE = +mess(5,10937,1) -":"- mess(103,10720,1)-[F:JOT]CPC(L_JK) -mess(62,127,1)-":"-[F:CPC]LEG : # Réservé à la législation
            Call ECR_TRACE(WMESSAGE,1) From GESECRAN
            WOK = 0
            Break
           Endif
         Endif
      Next
   Endif

   If WOK
# END SEGAY 25/10/12 US 930 81085

     # Sauvegarde des tableau maj poste
     Raz L_SAV_CPC, L_SAV_NIV, L_SAV_NB_CPC, L_SAV_LEG # SEGAY 25/10/12 US 930 81085
#     For L_J=0 To L_NB_CPC
#        L_SAV_CPC(L_I)=L_CPC(L_I)
#     Next
#     For L_I=0 To L_NB_CPC
#        L_SAV_NIV(L_I)=L_NIV(L_I)
#     Next
     For L_I=0 To L_NB_CPC
        L_SAV_CPC(L_I)=L_CPC(L_I)
        L_SAV_NIV(L_I)=L_NIV(L_I)
        L_SAV_LEG(L_I)=L_LEG(L_I)
     Next
# ENDSEGAY 25/10/12 US 930 81085
     L_SAV_NB_CPC = L_NB_CPC
     Raz L_CPC, L_NIV, L_NB_CPC, L_ORI, L_LEG # SEGAY 25/10/12 US 930 81085
     For L_JK=0 To dim([F:JOT]CPC)-1
       If [F:JOT]CPC(L_JK)="" : Break : Endif
# SEGAY 25/10/12 US 930 81085
#    If !func SUBJOT.CHECKLEG_CPC([F:JOT]CPC(L_JK),[F:JOT]LEG)
       Call LECTURE("CPC",[F:JOT]CPC(L_JK),"") From CONTOBJ
       If ([F:CPC]LEG<>"" & [F:JOT]LEG<>"" & [F:CPC]LEG<>[F:JOT]LEG)
&       | ([F:JOT]LEG="" & [F:CPC]LEG<>[F:JOT]LEG )    Then

          WMESSAGE = mess(L_IJ,10937,1)-[F:JOT]COD-mess(37,10720,1)-": " +[F:JOT]CPC(L_JK) - mess(62,127,1)-":"-[F:CPC]LEG : # Réservé à la législation
          FLGMAJ=0
          WOK = 0
          Break(1)
       Endif
# END SEGAY 25/10/12 US 930 81085

       L_CPC(L_NB_CPC) = [F:JOT]CPC(L_JK)
       L_NIV(L_NB_CPC) = [F:JOT]NIV(L_JK)
       # SEGAY 10/11/10  LOT P02 origine de la compétence dans le groupe emploi type
       L_ORI(L_NB_CPC) = [F:JOT]ORI(L_JK)
       L_LEG(L_NB_CPC) = [F:CPC]LEG # SEGAY 25/10/12 US 930 81085
       L_NB_CPC += 1
     Next : # [HRGCD]GCD0
     If WOK # SEGAY 25/10/12 US 930 81085

     # Segay 10/11/10 On met le niveau maj pour les postes
       L_IP = 5
       Gosub MAJ_POT
#     Raz L_CPC, L_NIV, L_NB_CPC, L_ORI, L_LEG # SEGAY 25/10/12 US 930 81085
#     For L_I=0 To L_SAV_NB_CPC
#        L_CPC(L_I)=L_SAV_CPC(L_I)
#     Next
#     For L_I=0 To L_SAV_NB_CPC
#        L_NIV(L_I)=L_SAV_NIV(L_I)
#     Next
# END SEGAY 25/10/12 US 930 81085

       L_NB_CPC = L_SAV_NB_CPC

       If FLGMAJ=1
        [F:POT]UPDDAT=date$ :  [F:POT]UPDUSR=GUSER :  [F:POT]UPDTIM=time
        Rewrite [F:POT]
        If fstat
         GOK = 0 : Call FSTA("POT") From GLOCK : Return
        Endif
        NBPOT+=1
        #Mise à jour du poste :
# SEGAY 25/10/12 US 930 81085
#      Call ECR_TRACE(space$(5)+mess(28,10720,1)-":"-[F:POT]COD-[F:POT]DES,0) From GESECRAN
        Call LECTEXTRA(WDESAX3,"POSTE","DES",[F:POT]COD,"") From ATEXTRA
        Call ECR_TRACE(space$(5)+mess(28,10720,1)-":"-[F:POT]COD-WDESAX3,0) From GESECRAN
       Endif
     Endif : # WOK SEGAY 25/10/12 US 930 81085
     # SEGAY 25/10/12 US 930 81085
     Raz L_CPC, L_NIV, L_NB_CPC, L_ORI, L_LEG # SEGAY 25/10/12 US 930 81085
     For L_I=0 To L_SAV_NB_CPC
          L_CPC(L_I)=L_SAV_CPC(L_I)
          L_NIV(L_I)=L_SAV_NIV(L_I)
          L_LEG(L_I)=L_SAV_LEG(L_I)
     Next
     L_NB_CPC = L_SAV_NB_CPC
     # END SEGAY 25/10/12 US 930 81085
   Endif : # WOK SEGAY 25/10/12 US 930 81085
Next
Return

# SEGAY 25/10/12 US 930 81085
$MAJ_POT_OF_JOBPOT
# Segay 10/11/10 lot P02 MAJ postes par l'emploi type si le groupe de compétence n'existe pas dans l'emploi-type
If NIVGRP=4 & [F:POT]JOBPOT <> ""
  Call LECTURE("JOT",[F:POT]JOBPOT,"") From CONTOBJ
  If !fstat & !evalue(CRITJOT)
   # SEGAY 25/10/12 US 930 81085
   If  WOK & [F:JOT]LEG<>"" & [F:POT]LEG <> [F:JOT]LEG Then
      WMESSAGE = mess(6,10937,1)-[F:POT]COD -mess(62,127,1)-":"-[F:POT]LEG : # Réservé à la législation
      Call ECR_TRACE(WMESSAGE,1) From GESECRAN
      WOK = 0
      Return
   Endif

   # Sauvegarde des tableau maj poste
   Raz L_SAV_CPC, L_SAV_NIV, L_SAV_NB_CPC, L_SAV_LEG # SEGAY 25/10/12 US 930 81085
   For L_I=0 To L_NB_CPC
       L_SAV_CPC(L_I)=L_CPC(L_I)
       L_SAV_NIV(L_I)=L_NIV(L_I)
       L_SAV_LEG(L_I)=L_LEG(L_I)
   Next
# ENDSEGAY 25/10/12 US 930 81085

    L_SAV_NB_CPC = L_NB_CPC
    Raz L_CPC, L_NIV, L_NB_CPC, L_ORI, L_LEG # SEGAY 25/10/12 US 930 81085
    For L_JK=0 To dim([F:JOT]CPC)-1
       If [F:JOT]CPC(L_JK)="" : Break : Endif
# SEGAY 25/10/12 US 930 81085
       Call LECTURE("CPC",[F:JOT]CPC(L_JK),"") From CONTOBJ
       If ([F:CPC]LEG<>"" & [F:JOT]LEG<>"" & [F:CPC]LEG<>[F:JOT]LEG)
&      | ([F:JOT]LEG="" & [F:CPC]LEG<>[F:JOT]LEG )    Then

          WMESSAGE = mess(NIVGRP,10937,1)-[F:JOT]COD-mess(37,10720,1)-": " +[F:JOT]CPC(L_JK) - mess(62,127,1)-":"-[F:CPC]LEG : # Réservé à la législation
          Call ECR_TRACE(WMESSAGE,1) From GESECRAN
          FLGMAJ=0
          WOK = 0
          Break(1)
       Endif
  # END SEGAY 25/10/12 US 930 81085
       L_CPC(L_NB_CPC) = [F:JOT]CPC(L_JK)
       L_NIV(L_NB_CPC) = [F:JOT]NIV(L_JK)
       # SEGAY 10/11/10  LOT P02 origine de la compétence dans le groupe emploi type
       L_ORI(L_NB_CPC) = [F:JOT]ORI(L_JK)
       L_LEG(L_NB_CPC) = [F:CPC]LEG # SEGAY 25/10/12 US 930 81085

       L_NB_CPC += 1
     Next : # [HRGCD]GCD0
     If WOK # SEGAY 25/10/12 US 930 81085
       # Segay 10/11/10 On met le niveau maj pour les postes
       L_IP = 5
       NIVGRP = 5
       Gosub MAJ_POT
       NIVGRP = 4
     Endif
     Raz L_CPC, L_NIV, L_NB_CPC, L_ORI, L_LEG # SEGAY 25/10/12 US 930 81085
     For L_I=0 To  L_SAV_NB_CPC
         L_CPC(L_I)=L_SAV_CPC(L_I)
         L_NIV(L_I)=L_SAV_NIV(L_I)
         L_LEG(L_I)=L_SAV_LEG(L_I)
     Next
# END SEGAY 25/10/12 US 930 81085

     L_NB_CPC = L_SAV_NB_CPC
     If FLGMAJ=1
        [F:POT]UPDDAT=date$ :  [F:POT]UPDUSR=GUSER :  [F:POT]UPDTIM=time
        Rewrite [F:POT]
        If fstat
         GOK = 0 : Call FSTA("POT") From GLOCK : Return
        Endif
        NBPOT+=1
        #Mise à jour du poste :
# SEGAY 25/10/12 US 930 81085
#        Call ECR_TRACE(space$(5)+mess(28,10720,1)-":"-[F:POT]COD-[F:POT]DES,0) From GESECRAN
         Call LECTEXTRA(WDESAX3,"POSTE","DES",[F:POT]COD,"") From ATEXTRA
         Call ECR_TRACE(space$(5)+mess(28,10720,1)-":"-[F:POT]COD-WDESAX3,0) From GESECRAN
      Endif
  Endif
Endif
# Segay 10/11/10 On met le niveau maj pour les postes
L_IP = L_IJ
Gosub MAJ_POT
If FLGMAJ=1
  [F:POT]UPDDAT=date$ :  [F:POT]UPDUSR=GUSER :  [F:POT]UPDTIM=time
  Rewrite [F:POT]
  If fstat
   GOK = 0 : Call FSTA("POT") From GLOCK : Return
  Endif
  NBPOT+=1
  #Mise à jour du poste :
# SEGAY 25/10/12 US 930 81085
#    Call ECR_TRACE(space$(5)+mess(28,10720,1)-":"-[F:POT]COD-[F:POT]DES,0) From GESECRAN
   Call LECTEXTRA(WDESAX3,"POSTE","DES",[F:POT]COD,"") From ATEXTRA
   Call ECR_TRACE(space$(5)+mess(28,10720,1)-":"-[F:POT]COD-WDESAX3,0) From GESECRAN
Endif
Return

#Ajout dans les emplois type, des compétences groupes inexistantes.
#Maj des niveaux de compétences dans les emplois type, en fonction de ceux définis dans les groupes, à condition
#que les compétences à modifier proviennent du même héritage (et même famille si niveau famille)
#####################################
$MAJ_JOT
FLGMAJ=0
K = 0
Gosub SUPP_JOT
# Segay 10/11/10 lot P02
# K étant la prochaine position libre
#If K>=dim([F:JOT]CPC)-1
#If K>=dim([F:JOT]CPC)
# #Tableau des compétences plein
# Call ECR_TRACE(mess(5,10720,1)-":"-[F:JOT]COD-[F:JOT]DES,1) From GESECRAN
# Return
#Endif

If !(L_IJ=1 & NIVGRP=1 & [F:JOT]JOBGRP = "") # Bug 71019 récupération des compétences dossier, famille, métier que si le métier est renseigné
For I=0 To L_NB_CPC-1
 If L_CPC(I)<>""
  J=find(L_CPC(I),[F:JOT]CPC)
  If !J
   # K étant la prochaine position libre
   # Segay 10/11/10 lot P02
   If K>=dim([F:JOT]CPC)
    #Tableau des compétences plein
# SEGAY 25/10/12 US 930 81085
#    Call ECR_TRACE(mess(5,10720,1)-":"-[F:JOT]COD-[F:JOT]DES,1) From GESECRAN
    Call LECTEXTRA(WDESAX3,"JOBTYP","DES",[F:JOT]COD,"") From ATEXTRA
    Call ECR_TRACE(mess(5,10720,1)-":"-[F:JOT]COD-WDESAX3,1) From GESECRAN
    Break
   Endif

   [F:JOT]CPC(K) = L_CPC(I)
   [F:JOT]NIV(K) = L_NIV(I)
   [F:JOT]ORI(K) = L_IJ       : # ML 2400 (JML 27/09/10 ce n'est plus NIVGRP mais L_IJ)
   [F:JOT]WEI(K) = 1
   If NIVGRP=4 : # ML 2400 Groupe de compétence
    [F:JOT]CODORI(K) = [F:GCP]CPCFAM
   Else
    [F:JOT]CODORI(K) = ""
   Endif
   FLGMAJ =1
   #Compétence attribuée :
   Call ECR_TRACE(mess(14,10720,1)-":"-[F:JOT]CPC(K)-[F:JOT]NIV(K)-mess([F:JOT]ORI(K),10937,1),0) From GESECRAN
   K += 1
   # Segay 10/11/10 lot P02
   # K étant la prochaine position libre
   #If K=dim([F:JOT]CPC)-1
#   If K>=dim([F:JOT]CPC)
#    #Tableau des compétences plein
#    Call ECR_TRACE(mess(5,10720,1)-":"-[F:JOT]COD-[F:JOT]DES,1) From GESECRAN
#    Break
#   Endif
  Else
   If [F:JOT]ORI(J-1)= L_IJ & [F:JOT]NIV(J-1)<>L_NIV(I)  & (NIVGRP<>4 | [F:JOT]CODORI(J-1)=[F:GCP]CPCFAM)
    [F:JOT]NIV(J-1) = L_NIV(I)
    FLGMAJ=1
    #Mise à jour du niveau de compétence :
    Call ECR_TRACE(mess(16,10720,1)-":"-[F:JOT]CPC(J-1)-[F:JOT]NIV(J-1)-mess([F:JOT]ORI(J-1),10937,1),0) From GESECRAN
   Endif
  Endif
 Else
  Break
 Endif
Next
Endif # END_Bug 71019 récupération des compétences dossier, famille, métier que si le métier est renseigné
Return

#####################################
#Gestion des suppressions
#Si une compétence héritée du groupe courant, existe dans l'emploi type
#mais plus dans le groupe -> on la supprime
#En sortie de boucle K =  du 1er indice libre
$SUPP_JOT
# Segay 10/11/10 lot P02
# Pour eviter de reboucler sur le tableau CPC en mettant K=-1
# On lit le tableau CPC à l'envers en partant de la dernière item renseigné

#For K=0 To dim([F:JOT]CPC)-1
# If [F:JOT]CPC(K)="" : Break : Endif
## If [F:JOT]ORI(K)=NIVGRP & !find([F:JOT]CPC(K),L_CPC(0..L_NB_CPC)) & (NIVGRP<>4 | [F:JOT]CODORI(K)=[F:GCP]CPCFAM)
# If [F:JOT]ORI(K)=L_IJ & [F:JOT]ORI(K)<>7 & !find([F:JOT]CPC(K),L_CPC(0..L_NB_CPC))
#  # JML 27/09/10 CG on supprime si Origine & Origine<>Manuelle
#  #Compétence supprimée :
#  Call ECR_TRACE(mess(32,10720,1)-":"-[F:JOT]CPC(K)-[F:JOT]NIV(K),0) From GESECRAN
#  Dela K,1 [F:JOT]CPC, [F:JOT]NIV, [F:JOT]ORI, [F:JOT]WEI, [F:JOT]CODORI
#  K=-1     :#pour repartir de 0
#  FLGMAJ =1
# Endif
#Next

If dim([F:JOT]CPC)< 1
  Return
Endif
L_CPT=find ("",[F:JOT]CPC)
L_I = dim([F:JOT]CPC)
If L_CPT > 0
  L_I = L_CPT-1
Endif
For K=L_I-1 To 0 Step -1
 If [F:JOT]CPC(K)="" : Break : Endif
# If [F:JOT]ORI(K)=NIVGRP & !find([F:JOT]CPC(K),L_CPC(0..L_NB_CPC)) & (NIVGRP<>4 | [F:JOT]CODORI(K)=[F:GCP]CPCFAM)
# If [F:JOT]ORI(K)=L_IJ & [F:JOT]ORI(K)<>7 & !find([F:JOT]CPC(K),L_CPC(0..L_NB_CPC))
 If [F:JOT]ORI(K)=L_IJ & [F:JOT]ORI(K)<>len(mess(0,10937,1)) & !find([F:JOT]CPC(K),L_CPC(0..L_NB_CPC))
&   & (NIVGRP<>4 | (NIVGRP=4 & [F:JOT]CODORI(K)=[F:GCP]CPCFAM))
  # JML 27/09/10 CG on supprime si Origine & Origine<>Manuelle
  #Compétence supprimée :
  Call ECR_TRACE(mess(32,10720,1)-":"-[F:JOT]CPC(K)-[F:JOT]NIV(K)-mess([F:JOT]ORI(K),10937,1),0) From GESECRAN
  Dela K,1 [F:JOT]CPC, [F:JOT]NIV, [F:JOT]ORI, [F:JOT]WEI, [F:JOT]CODORI
#  K=-1     :#pour repartir de 0
  FLGMAJ =1
 Endif
 # Segay 10/11/10 lot P02
# Si on n'est pas en maj héritage groupe,
# on supprime compétences origine groupes si elles existent dans le père
# pour les mettre à jour avec la bonne origine du père
 If [F:JOT]ORI(K)<>L_IJ & [F:JOT]ORI(K)=4 & find([F:JOT]CPC(K),L_CPC(0..L_NB_CPC))
&   & NIVGRP<>4
  #Compétence supprimée :
  Call ECR_TRACE(mess(32,10720,1)-":"-[F:JOT]CPC(K)-[F:JOT]NIV(K)-mess([F:JOT]ORI(K),10937,1),0) From GESECRAN
  Dela K,1 [F:JOT]CPC, [F:JOT]NIV, [F:JOT]ORI, [F:JOT]WEI, [F:JOT]CODORI
#  K=-1     :#pour repartir de 0
  FLGMAJ =1
 Endif
# Bug 71019 récupération des compétences dossier, famille, métier que si le métier est renseigné
 If L_IJ=1 & [F:JOT]JOBGRP = "" & [F:JOT]ORI(K)<>4 and [F:JOT]ORI(K)<>len(mess(0,10937,1))
&   & NIVGRP=1
  #Compétence supprimée :
  Call ECR_TRACE(mess(32,10720,1)-":"-[F:JOT]CPC(K)-[F:JOT]NIV(K)-mess([F:JOT]ORI(K),10937,1),0) From GESECRAN
  Dela K,1 [F:JOT]CPC, [F:JOT]NIV, [F:JOT]ORI, [F:JOT]WEI, [F:JOT]CODORI
#  K=-1     :#pour repartir de 0
  FLGMAJ =1
 Endif
# END_Bug 71019 récupération des compétences dossier, famille, métier que si le métier est renseigné
Next
L_CPT=find ("",[F:JOT]CPC)
K = dim([F:JOT]CPC)
If L_CPT > 0
  K = L_CPT -1
Endif
Return

#Ajout dans les postes, des compétences venant de l'emploi type inexistantes
#Maj des niveaux de compétences dans les postes, en fonction de ceux définis dans les emplois type, à condition
#que les compétences à modifier proviennent du même héritage.
#####################################
$MAJ_POT
FLGMAJ=0
K = 0
Gosub SUPP_POT
# Segay 10/11/10 lot P02
# K étant la prochaine position libre
#If K>=dim([F:POT]CPC)-1
#If K>=dim([F:POT]CPC)
# #Tableau des compétences plein
# Call ECR_TRACE(space$(5)+mess(5,10720,1)-":"-[F:POT]COD-[F:POT]DES,1) From GESECRAN
# Return
#Endif
For I=0 To L_NB_CPC-1
 If L_CPC(I)<>""
  J=find(L_CPC(I),[F:POT]CPC)
  If !J
   # K étant la prochaine position libre
   # Segay 10/11/10 lot P02
   If K>=dim([F:POT]CPC)
    #Tableau des compétences plein
# SEGAY 25/10/12 US 930 81085
#    Call ECR_TRACE(space$(5)+mess(5,10720,1)-":"-[F:POT]COD-[F:POT]DES,1) From GESECRAN
    Call LECTEXTRA(WDESAX3,"POSTE","DES",[F:POT]COD,"") From ATEXTRA
    Call ECR_TRACE(space$(5)+mess(5,10720,1)-":"-[F:POT]COD-WDESAX3,1) From GESECRAN
    Break
   Endif

   [F:POT]CPC(K) = L_CPC(I)
   [F:POT]NIV(K) = L_NIV(I)
#   [F:POT]ORI(K) = L_IJ       : # ML 2400 (JML 27/09/10 ce n'est plus NIVGRP mais L_IJ)
   # Si le père = emploi type et que l'origine de l'empoi type = "Dossier ou Famille ou Métier"
   # on prend l'origine de l'emploi type, sinon origine = père
   If L_IP = 5 & L_ORI(I)<4 & L_ORI(I) > 0 # SEGAY 10/11/10  LOT P02 origine de la compétence dans le groupe emploi type
    [F:POT]ORI(K) = L_ORI(I)
   Else
    [F:POT]ORI(K) = L_IP       : # ML 2400 (SEGAY 10/11/10 ce n'est plus NIVGRP mais L_IP)
   Endif
   [F:POT]WEI(K) = 1
   If NIVGRP=4 : # ML 2400 Groupe de compétence
    [F:POT]CODORI(K) = [F:GCP]CPCFAM
   Else
    [F:POT]CODORI(K) = ""
   Endif
   FLGMAJ =1
   #Compétence attribuée :
   Call ECR_TRACE(space$(5)+mess(14,10720,1)-":"-[F:POT]CPC(K)-[F:POT]NIV(K)-mess([F:POT]ORI(K),10937,1),0) From GESECRAN
   K += 1
   # K étant la prochaine position libre
   # Segay 10/11/10 lot P02
#   If K=dim([F:POT]CPC)-1
#   If K>=dim([F:POT]CPC)
#    #Tableau des compétences plein
#    Call ECR_TRACE(space$(5)+mess(5,10720,1)-":"-[F:POT]COD-[F:POT]DES,1) From GESECRAN
#    Break
#   Endif
  Else
   # Si le père est emploi type
   If L_IP = 5
     FLGMAJMOD = 0
     # Si la compétence du poste a une origine <> "manuelle"  ou une origine "groupe" mais inexistant dans la liste des groupes du poste
#     If [F:POT]ORI(J-1)<>7 and ([F:POT]ORI(J-1)<>4 or ([F:POT]ORI(J-1) = 4 &  ([F:POT]CODORI(J-1)="" or !find([F:POT]CODORI(J-1),[F:POT]CPCFAM))))
     # Si la compétence du poste a une origine <> "manuelle"
     If [F:POT]ORI(J-1)<>len(mess(0,10937,1))
      # maj du niveau si niveau différent
      If [F:POT]NIV(J-1)<>L_NIV(I)
       [F:POT]NIV(J-1) = L_NIV(I)
       FLGMAJMOD=1
      Endif
      # Maj de l'origine
      # si origine <> de l'origine de l'emploi type(dont origine <> "manuelle" et <> "groupe"
      If (L_ORI(I)> 0  & L_ORI(I) <> len(mess(0,10937,1)) & L_ORI(I) <> 4)
       If [F:POT]ORI(J-1) <> L_ORI(I)
       # si origine du poste <> manuelle et <> groupe de compétence l'origine prend la valeur de l'origine de celle de emploi type
         FLGMAJMOD=1
         [F:POT]ORI(J-1) = L_ORI(I)
       Endif
      # si origine <> de "emploi type" et si emploi type à origine = "manuelle" ou = "groupe"
      Elsif L_ORI(I)> 0 & (L_ORI(I) = len(mess(0,10937,1)) or L_ORI(I) = 4) & [F:POT]ORI(J-1) <> L_IP
         FLGMAJMOD=1
         [F:POT]ORI(J-1) = L_IP       : # ML 2400 (SEGAY 10/11/10 ce n'est plus NIVGRP mais L_IP)
      Endif
      If FLGMAJMOD=1
         FLGMAJ=1
         #Mise à jour du niveau de compétence :
         Call ECR_TRACE(space$(5)+mess(16,10720,1)-":"-[F:POT]CPC(J-1)-[F:POT]NIV(J-1)-mess([F:POT]ORI(J-1),10937,1),0) From GESECRAN
       Endif
     Endif
   Else
     # Si le père <> emploi type
     If [F:POT]ORI(J-1)=L_IP & [F:POT]NIV(J-1)<>L_NIV(I)  & (NIVGRP<>4 | [F:POT]CODORI(J-1)=[F:GCP]CPCFAM)
      [F:POT]NIV(J-1) = L_NIV(I)
      FLGMAJ=1
      #Mise à jour du niveau de compétence :
      Call ECR_TRACE(space$(5)+mess(16,10720,1)-":"-[F:POT]CPC(J-1)-[F:POT]NIV(J-1)-mess([F:POT]ORI(J-1),10937,1),0) From GESECRAN
     Endif
   Endif
  Endif
 Else
  Break
 Endif
Next
Return

#####################################
#Gestion des suppressions
#Si une compétence héritée de l'emploi type, existe dans le poste
#mais plus dans l'emploi type -> on la supprime
#En sortie de boucle K =  du 1er indice libre
$SUPP_POT
# Segay 10/11/10 lot P02
# Pour eviter de reboucler sur le tableau CPC en mettant K=-1
# On lit le tableau CPC à l'envers en partant de la dernière item renseigné

#For K=0 To dim([F:POT]CPC)-1
# If [F:POT]CPC(K)="" : Break : Endif
## If [F:POT]ORI(K)=NIVGRP & !find([F:POT]CPC(K),[F:JOT]CPC) & (NIVGRP<>4 | [F:POT]CODORI(K)=[F:GCP]CPCFAM)
# If [F:POT]ORI(K)=L_IP & [F:POT]ORI(K)<>7 & !find([F:POT]CPC(K),L_CPC(0..L_NB_CPC))
#    # JML 27/09/10 CG on supprime si Origine & Origine<>Manuelle
#    #Compétence supprimée :
#    Call ECR_TRACE(space$(5)+mess(32,10720,1)-":"-[F:POT]CPC(K)-[F:POT]NIV(K)-mess([F:POT]ORI(K),10937,1),0) From GESECRAN
#    Dela K,1 [F:POT]CPC, [F:POT]NIV, [F:POT]ORI, [F:POT]WEI, [F:POT]CODORI
#    K=-1     :#pour repartir de 0
#    FLGMAJ =1
# Endif
#Next

If dim([F:POT]CPC)< 1
  Return
Endif
L_CPT=find ("",[F:POT]CPC)
L_I = dim([F:POT]CPC)
If L_CPT > 0
  L_I = L_CPT-1
Endif
For K=L_I-1 To 0 Step -1
 If [F:POT]CPC(K)="" : Break : Endif
# If [F:POT]ORI(K)=NIVGRP & !find([F:POT]CPC(K),[F:JOT]CPC) & (NIVGRP<>4 | [F:POT]CODORI(K)=[F:GCP]CPCFAM)
# If [F:POT]ORI(K)=L_IP & [F:POT]ORI(K)<>7 & !find([F:POT]CPC(K),L_CPC(0..L_NB_CPC))
 # Si père est emploi type
 If L_IP=5
  # Si Compétence fils n'existe pas dans le père et que l'origine du fils <> "manuelle" et  <> "groupe" ou (= "groupe" et que le groupe n'existe pas dans la liste des groupes)
  If ([F:POT]ORI(K)<>len(mess(0,10937,1)) & !find([F:POT]CPC(K),L_CPC(0..L_NB_CPC))
&   & [F:POT]ORI(K)<>4) or ([F:POT]ORI(K) = 4 & ([F:POT]CODORI(K)="" or !find([F:POT]CODORI(K),[F:POT]CPCFAM)))
    #Compétence supprimée :
    Call ECR_TRACE(space$(5)+mess(32,10720,1)-":"-[F:POT]CPC(K)-[F:POT]NIV(K)-mess([F:POT]ORI(K),10937,1),0) From GESECRAN
    Dela K,1 [F:POT]CPC, [F:POT]NIV, [F:POT]ORI, [F:POT]WEI, [F:POT]CODORI
#    K=-1     :#pour repartir de 0
    FLGMAJ =1
  Endif
 Else
  If [F:POT]ORI(K)=L_IP & [F:POT]ORI(K)<>len(mess(0,10937,1)) & !find([F:POT]CPC(K),L_CPC(0..L_NB_CPC))
&     & (NIVGRP<>4 | (NIVGRP=4 & [F:POT]CODORI(K)=[F:GCP]CPCFAM))
    # JML 27/09/10 CG on supprime si Origine & Origine<>Manuelle
    #Compétence supprimée :
    Call ECR_TRACE(space$(5)+mess(32,10720,1)-":"-[F:POT]CPC(K)-[F:POT]NIV(K)-mess([F:POT]ORI(K),10937,1),0) From GESECRAN
    Dela K,1 [F:POT]CPC, [F:POT]NIV, [F:POT]ORI, [F:POT]WEI, [F:POT]CODORI
#    K=-1     :#pour repartir de 0
    FLGMAJ =1
  Endif
 Endif
  # Segay 10/11/10 lot P02
# Si on n'est pas en maj héritage groupe,
# on supprime compétences origine groupes si elles existent dans le père
# pour les mettre à jour avec la bonne origine du père
 If [F:POT]ORI(K)<>L_IJ & [F:POT]ORI(K)=4 & find([F:POT]CPC(K),L_CPC(0..L_NB_CPC))
&   & NIVGRP<>4
  #Compétence supprimée :
    Call ECR_TRACE(space$(5)+mess(32,10720,1)-":"-[F:POT]CPC(K)-[F:POT]NIV(K)-mess([F:POT]ORI(K),10937,1),0) From GESECRAN
    Dela K,1 [F:POT]CPC, [F:POT]NIV, [F:POT]ORI, [F:POT]WEI, [F:POT]CODORI
#  K=-1     :#pour repartir de 0
  FLGMAJ =1
 Endif
Next
L_CPT=find ("",[F:POT]CPC)
K = dim([F:POT]CPC)
If L_CPT > 0
  K = L_CPT -1
Endif
Return

#####################################
# SEGAY 25/10/12 US 930 81085
$MESSAGE_NIV
 Case L_IJ
  When 1 : WMESSAGE =""                                   :#ML 2400 Dossier
  When 2 : WMESSAGE =[F:GCP]UOMGRP                        :#ML 2400 Famille
  When 3 : WMESSAGE =[F:GCP]JOBGRP                        :#ML 2400 Métier
  When 4 : WMESSAGE =[F:GCP]CPCFAM                        :#ML 2400 Groupe de compétence
  When 5 : WMESSAGE =CODGRP                               :#ML 2400 Emploi type
 Endcase
Return
#####################################

#####################################
$CRITERE_JOT
CRITJOT ="1=1"
#If L_IJ=NIVGRP
 Case L_IJ
  When 1 : CRITJOT ="1=1"                                                 :#ML 2400 Dossier
  When 2 : CRITJOT ="[F:JOT]UOMGRP='"+[F:GCP]UOMGRP+"'"                          :#ML 2400 Famille
  When 3 : CRITJOT ="[F:JOT]JOBGRP='"+[F:GCP]JOBGRP+"'"                          :#ML 2400 Métier
  When 4 : CRITJOT ="find([F:GCP]CPCFAM,[F:JOT]CPCFAM(0..dim([F:JOT]CPCFAM)-1))" :#ML 2400 Groupe de compétence
 Endcase
#Endif
Return
#####################################
$CRITERE_POT
CRITPOT ="1=1"
#If L_IJ=NIVGRP
 Case L_IJ
  When 1 : CRITPOT ="1=1"                                                 :#ML 2400 Dossier
  When 2 : CRITPOT ="[F:POT]UOMGRP='"+[F:GCP]UOMGRP+"'"                          :#ML 2400 Famille
  When 3 : CRITPOT ="[F:POT]JOBGRP='"+[F:GCP]JOBGRP+"'"                          :#ML 2400 Métier
  When 4 : CRITPOT ="find([F:GCP]CPCFAM,[F:POT]CPCFAM(0..dim([F:POT]CPCFAM)-1))" :#ML 2400 Groupe de compétence
  When 5 : CRITPOT ="[F:POT]JOBPOT='"+CODGRP+"'"                          :#ML 2400 Emploi type
 Endcase
#Endif
Return
#####################################
$AB_TR1
Rollback
Return

#####################################
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

