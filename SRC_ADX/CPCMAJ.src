#<AdxTL>@(#)0.0.0.0 $Revision$
##################################################################################
# Cette action CPCMAJ la mise à jours des compétences emploi-type et poste
# depuis les groupes de compétences
# JML 27/09/10 CG nouveau fonctionnement : on part de 4=Grp de cpc, 3=métier, 2=Famille, 1=Dossier en remontant
#              On supprime tout sauf si Manuel ou sur Famille on touche plus à métier,
#              sur dossier on touche plus à Famille, Métier
# JML 14/10/10 CG Ajout d'un niveau 5 sur Emploi type (Ajout GFLAG="5" sur fonction GESJOT, pas besoin, écrasé par GOBJET !)
#              Ajout Action CPCMAJ sur Fenêtre OJOT
# Modifications :
# SEGAY 10/11/10 EXI 66105 lot P02
#Dans les postes non reliés à un emploi type,
#les seuls héritages possibles sont « manuelle » ou « groupe de compétences ».
#Le seul cas où il peut arriver qu’on ait d’autres valeurs (famille, métier, emploi type)
#est le suivant : un poste était lié à un emploi type ; le lien a été enlevé.
# Si on n'est pas en maj héritage groupe,
# on supprime compétences origine groupes si elles existent dans le père
# pour les mettre à jour avec la bonne origine du père
#  A-Pour la MAJ héritage depuis GESJOT (emploi type)
#    on garde les niveaux de compétence et la colonne héritage (dossier, famille ou métier) de l’emploi type dans les postes.
#    Exception :
#    - les compétences issues d’un groupe de compétence dans l’emploi type, pour qui la colonne héritage devient « Emploi type » dans le poste.
#    - les compétences dont la colonne héritage est manuelle dans l’emploi type, pour qui la colonne héritage devient « Emploi type »
#  B-Pour la MAJ héritage depuis GESCP4 (Groupe de compétence)
#    Pour un groupe de compétences, on met à jour les emplois types
#    ayant un lien avec ce groupe, puis les postes liés pour chaque emploi type.
#    Enfin, on met à jour les postes restant (sans lien avec les emplois type mis à jour) mais ayant un lien avec le groupe de compétences.
#  C-Pour la MAJ héritage depuis GESCP3 (Métier)
#    on remet à jour tous les emplois type liés au métier et dans les postes (liés aux emplois type du métier),
#    on modifie toutes les compétences qui viennent de l’emploi type (et pas seulement les compétences métier).
#  D-Pour la MAJ héritage depuis GESCP2 (Famille)
#    On commence par mettre à  jour  les compétences des niveaux métiers qui ont une dépendance avec la famille.
#    Si pour la même famille on a plusieurs métiers, on boucle sur les métiers (comme dans C).
#    Puis on met à jour tous les emplois type liés à la famille,
#    et dans les postes (liés aux emplois type de la famille),
#    on modifie toutes les compétences qui viennent de l’emploi type (et pas seulement les compétences familles).
#  E-Pour la MAJ héritage depuis GESCP1 (Dossier)
#    par cette fonction l’utilisateur doit être capable de remettre à jour l’ensemble de son référentiel
#    et de restaurer tous les liens (dossier, famille, métier, emploi type, poste) qui ne serait plus cohérents.
# SEGAY - 24/01/11 LOT P02
#  Recherche s'il y a des origines de compétences dont le groupe n'existe plus
#  Il faut les supprimer
#  MABOS - 22/07/13 - FQ90539-US1804 - Action called from CONSRJO
#                                    - init & manage NIVGRP / new parameters on Action CPCMAJ
##################################################################################################
Raz GPILOBJ
GFLAG="4"
Call OBJET("GCP",GBIDC1,"") From GOBJET
End

$ACTION
# SEGAY 10/11/10 CG Bouton Héritage
# When "INIT" : TIT = mess(22,10720,1)  :#Voulez-vous mettre à jour les compétences des emplois type et des postes ?
Case ACTION
 When "INIT" : Gosub INIT
 When "EXEC" : Gosub EXEC
Endcase
Return
#####################################
$INIT
# SEGAY 10/11/10 CG Bouton Héritage  sur emploi type (Pas possible de gérer GFLAG sur GOBJET de GESJOT)
#MABOS-FQ90539-US1804-add paramters on Action CPCMAJ
Local Integer NIVGRP
NIVGRP=val(GFLAG)
If NIVGRP = 0 Then
  NIVGRP=val(PARAM(5))
Endif
#If val(GFLAG)=0
If NIVGRP>4
#end MABOS-FQ90539-US1804
Local Integer NIVGRP
  TIT = mess(64,10720,1)  :#Voulez-vous mettre à jour les compétences des postes liés à l'emploi type ?
Else
  TIT = mess(22,10720,1)  :#Voulez-vous mettre à jour les compétences des emplois type et des postes ?
Endif
Return
#####################################
$EXEC
TRA=1
If clalev([F:JOT])=0    : Local File JOBTYP     [JOT]   : Endif
If clalev([F:POT])=0    : Local File POSTE      [POT]   : Endif
If clalev([F:GCP])=0    : Local File GRPCPC     [GCP]   : Endif
If clalev([F:CPC])=0    : Local File COMPETENCE [CPC]   : Endif
If clalev([F:HRGCD])=0  : Local File GRPCPCD    [HRGCD] : Endif : # JML 30/07/10 LOT P02
If clalev([F:ADI])=0    : Local File ATABDIV    [ADI]   : Endif : # SEGAY 10/11/10 LOT P02

If clalev([F:JOT1])=0   : Local File JOBTYP     [JOT1]  : Endif

Local Char    CODGRP(GLONADI)
Local Integer NBJOT, NBPOT, FLGMAJ, I, J, K ,NIVGRP
Local Char    L_CRITGCP(GDIMFIC), L_CRITGCD(GDIMFIC) : # JML 30/07/10
Local Char    L_CPC(GLONCPC)(0..)                    : # JML 30/07/10 To charge GCD
Local Char    L_NIV(GLONNIV)(0..)                    : # JML 30/07/10 To charge GCD
Local Integer L_ORI(0..)                             : # SEGAY 10/11/10  LOT P02 origine de la compétence dans le groupe père
Local Char    L_LEG(5)(0..)                          : # SEGAY 25/10/12 US 930 81085
Local Char    L_LEG_NIV(5)                           : # SEGAY 25/10/12 US 930 81085
Local Char    L_LEG_NIV_SUP(5)                           : # SEGAY 25/10/12 US 930 81085

Local Integer L_NB_CPC
Local Integer L_IJ, L_JK
Local Integer L_I, L_CPT                             : # SEGAY 10/11/10 variable de compteur
Local Integer FLGMAJMOD                              : # SEGAY 10/11/10 flag si modification à faire(niveau ou origine) sur la ligne de compétence du poste
Local Integer L_IP                                   : # SEGAY 10/11/10 Indice du niveau de mise à jour 1=dossier 2=famille 3=metier 4=groupe compétence 5=emploi type
Local Integer L_IDEL                                 : # SEGAY 10/11/10 Indice du niveau supression cpc dans origine n'existe plus
Local Integer L_SAV_IJ                               : # SEGAY 10/11/10 Indice du niveau supression cpc dans origine n'existe plus

Local Char    L_SAV_CPC(GLONCPC)(0..)                : # SEGAY 10/11/10 sauvegarde des compétences à modifier
Local Char    L_SAV_NIV(GLONNIV)(0..)                : # SEGAY 10/11/10 sauvegarde des niveaux à modifier
Local Char    L_SAV_LEG(5)(0..)                          : # SEGAY 25/10/12 US 930 81085

Local Integer L_SAV_NB_CPC                           : # SEGAY 10/11/10 sauvegarde du nombre de compétence à modifier
Local Char    CRITJOT(GDIMFIC), CRITPOT(GDIMFIC)
Local Char    WMESSAGE(250)                          : # SEGAY 25/10/12 US 930 81085
Local Char    WDESAX3(30)                            : # SEGAY 25/10/12 US 930 81085
Local Char    W_AFF_LEG1(50)                         : # SEGAY 25/10/12 US 930 81085
Local Char    W_AFF_LEG2(50)                         : # SEGAY 25/10/12 US 930 81085
Local Integer WOK                                    : # SEGAY 25/10/12 US 930 81085
Local Char    SAV_CRITGCD(GDIMFIC) :# SEGAY 25/10/12 US 930 81085
SYMBOLE = "CPCMAJ"
Lock =SYMBOLE
If fstat
 GMESSAGE = mess(30,100,1) : # Opération en cours sur autre poste
 Unlock =SYMBOLE
 GERR = 1 : SAI = 0 : Return
Endif
# SEGAY 10/11/10 Indice du niveau de mise à jour 1=dossier 2=famille 3=metier 4=groupe compétence 5=emploi type
NIVGRP=val(GFLAG)
#MABOS-FQ90539-US1804-add paramters on Action CPCMAJ
If NIVGRP = 0 Then
  # from GESJOT & CONSRJO
  NIVGRP=val(PARAM(5))
Endif
If NIVGRP=1
 CODGRP = ""
#Elsif NIVGRP=0
# # JML 14/10/10 CG Bouton Héritage sur emploi type (Pas possible de gérer GFLAG sur GOBJET de GESJOT)
# NIVGRP = 5
# # ACTION CPCMAJ : 3 Paramètres : UOMGRP, JOBGRP, CPCFAM
# CODGRP = PARAM(1)
#end MABOS-FQ90539-US1804-
Else
 # ACTION CPCMAJ : 4 Paramètres : UOMGRP, JOBGRP, CPCFAM,JOBPOT
 CODGRP = PARAM(NIVGRP-1)
Endif

##################################################################################################
#Mise à jour des compétences dans les emplois type et les postes
TIT = mess(23,10720,1)-":"-mess(NIVGRP,10937)-CODGRP
If !GSERVEUR
 Call OUVRE_TRACE(TIT) From LECFIC
Endif

#####################################
# JML 30/07/10 LOT P02 Newfile GRPCPCD
# JML 27/09/10 CG nouveau fonctionnement : on part de 4=Grp de cpc, 3=métier, 2=Famille, 1=Dossier en remontant
# JML 29/09/10 CG ne pas faire Grp de cpc
# JML 14/10/10 CG Faire GRP de CPC et ajouter Niveau 5 Emploi type
For L_IJ=5 To NIVGRP Step -1
 Raz [F:GCP]
 If L_IJ=5 & NIVGRP=5
  # JML 14/10/10 CG Bouton Héritage sur emploi type
  CRITJOT ="1=0" : # On fait rien par défaut
  If NIVGRP=5
   CRITJOT ="[JOT]COD='"+CODGRP+"'"
  Endif
  For [JOT]JOT0 Where evalue(CRITJOT)
   Raz L_CPC, L_NIV, L_NB_CPC, L_ORI, L_LEG, L_LEG_NIV, L_LEG_NIV_SUP # SEGAY 25/10/12 US 930 81085
   L_LEG_NIV = [F:JOT]LEG                  : # SEGAY 25/10/12 US 930 81085
   For L_JK=0 To dim([F:JOT]CPC)-1
    If [F:JOT]CPC(L_JK)="" : Break : Endif
# SEGAY 25/10/12 US 930 81085
#    If !func SUBJOT.CHECKLEG_CPC([F:JOT]CPC(L_JK),[F:JOT]LEG)
    Call LECTURE("CPC",[F:JOT]CPC(L_JK),"") From CONTOBJ
    If ([F:CPC]LEG<>"" & [F:JOT]LEG<>"" & [F:CPC]LEG<>[F:JOT]LEG )
&    | ([F:JOT]LEG="" & [F:CPC]LEG<>[F:JOT]LEG )    Then
      WMESSAGE = mess(L_IJ,10937,1)-[F:JOT]COD-mess(37,10720,1)-": " +[F:JOT]CPC(L_JK) - mess(62,127,1)-":"-[F:CPC]LEG : # Réservé à la législation
      GOK = 0
      Break(1)
    Endif
# END SEGAY 25/10/12 US 930 81085
    L_CPC(L_NB_CPC) = [F:JOT]CPC(L_JK)
    L_NIV(L_NB_CPC) = [F:JOT]NIV(L_JK)
    # SEGAY 10/11/10  LOT P02 origine de la compétence dans le groupe Emploi type
    L_ORI(L_NB_CPC) = [F:JOT]ORI(L_JK)
    L_LEG(L_NB_CPC) = [F:CPC]LEG            : # SEGAY 25/10/12 US 930 81085
    L_NB_CPC += 1
   Next : # [HRGCD]GCD0

   Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
#   Call ECR_TRACE(TIT-":"-mess(L_IJ,10937,1)-[F:JOT]COD-": ("+CRITJOT+")",0) From GESECRAN
   Call ECR_TRACE(mess(23,10720,1)-":"-mess(L_IJ,10937,1)-[F:JOT]COD,0) From GESECRAN

   Call ECR_TRACE(string$(70,"*"),0) From GESECRAN

# SEGAY 25/10/12 US 930 81085
    If GOK<1
      If WMESSAGE <> ""
        Call ECR_TRACE(WMESSAGE,1) From GESECRAN
      Endif
      Break(1)
    Endif

# END SEGAY 25/10/12 US 930 81085
# SEGAY 10/11/10  LOT P02 même si on a aucune compétence il faut mettre à jour le poste
# Pour mettre à jour les suppressions dans les postes
   # JML 30/07/10 LOT P02 Newfile GRPCPCD
#   If L_NB_CPC>0
    GOK = 1
    Call DEBTRANS From GLOCK
    Gosub TR1
    If GOK<1 : Break(2) : Endif
#   Endif
  Next : # [JOT]JOT0
  # On s'arrete
  Break
 ####
 Else
 ####
#  SEGAY 10/11/10 LOT P02
#  If NIVGRP=4 | L_IJ<4
  If (NIVGRP=4 & L_IJ=NIVGRP) | L_IJ<4

   # On y va que pour dossier, Famille, Métier ou 1 seule fois GRP de CPC
   # ML 2400 De Emploi type à Famille, Dossier
   L_CRITGCP = "LEVGRP=L_IJ" : # ML 2400
   L_CRITGCD = "1=1"

#  SEGAY 24/01/11 LOT P02
#  Recherche s'il y a des origines de compétences dont le groupe n'existe plus
#  Il faut les supprimer
   If NIVGRP =1 & L_IJ=NIVGRP
    For L_IDEL = 4 To NIVGRP Step -1
    Case L_IDEL
     When 1 : # ML 2400 Dossier
      Filter [F:JOT1] Where find(L_IDEL,[F:JOT1]ORI(0..dim([F:JOT1]ORI)-1))
      For [F:JOT1]JOT0
        Filter [F:GCP] Where [F:GCP]LEVGRP=L_IDEL
        If !rowcount([F:GCP])>0 Then
          Raz [F:GCP]
          [F:GCP]LEVGRP=L_IDEL
          Raz L_CPC, L_NIV, L_NB_CPC, L_ORI, L_LEG, L_LEG_NIV, L_LEG_NIV_SUP # SEGAY 25/10/12 US 930 81085
          L_LEG_NIV = [F:GCP]LEG                  : # SEGAY 25/10/12 US 930 81085
          Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
          Call ECR_TRACE(mess(23,10720,1)-":"-mess(L_IDEL,10937,1)-[F:GCP]UOMGRP-[F:GCP]JOBGRP-[F:GCP]CPCFAM-mess(73,10720,1),0) From GESECRAN
          Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
          GOK = 1
          Call DEBTRANS From GLOCK
          L_SAV_IJ=L_IJ
          L_IJ=L_IDEL
          Gosub TR1
          L_IJ=L_SAV_IJ
          If GOK<1 :Filter [F:JOT1]: Break(3) : Endif
        Endif
      Next
      Filter [F:JOT1]
     When 2 : #ML 2400 FAMILLE
      Filter [F:JOT1] Where [F:JOT1]UOMGRP<>"" & find(L_IDEL,[F:JOT1]ORI(0..dim([F:JOT1]ORI)-1))
      For [F:JOT1]JOT0
        Filter [F:GCP] Where [F:GCP]LEVGRP=L_IDEL & [F:GCP]UOMGRP=[F:JOT1]UOMGRP
        If !rowcount([F:GCP])>0 Then
          Raz [F:GCP]
          [F:GCP]UOMGRP=[F:JOT1]UOMGRP
          [F:GCP]LEVGRP=L_IDEL
          Raz L_CPC, L_NIV, L_NB_CPC, L_ORI, L_LEG, L_LEG_NIV # SEGAY 25/10/12 US 930 81085
          L_LEG_NIV = [F:GCP]LEG                  : # SEGAY 25/10/12 US 930 81085
          Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
          Call ECR_TRACE(mess(23,10720,1)-":"-mess(L_IDEL,10937,1)-[F:GCP]UOMGRP-[F:GCP]JOBGRP-[F:GCP]CPCFAM-mess(73,10720,1),0) From GESECRAN
          Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
          GOK = 1
          Call DEBTRANS From GLOCK
          L_SAV_IJ=L_IJ
          L_IJ=L_IDEL
          Gosub TR1
          L_IJ=L_SAV_IJ
          If GOK<1 :Filter [F:JOT1]: Break(3) : Endif
        Endif
      Next
      Filter [F:JOT1]
     When 3 : # ML 2400 Metier
      Filter [F:JOT1] Where [F:JOT1]JOBGRP<>"" & find(L_IDEL,[F:JOT1]ORI(0..dim([F:JOT1]ORI)-1))
      For [F:JOT1]JOT0
        Filter [F:GCP] Where [F:GCP]LEVGRP=L_IDEL & [F:GCP]JOBGRP=[F:JOT1]JOBGRP
        If !rowcount([F:GCP])>0 Then
          Raz [F:GCP]
          [F:GCP]JOBGRP=[F:JOT1]JOBGRP
          [F:GCP]LEVGRP=L_IDEL
          Raz L_CPC, L_NIV, L_NB_CPC, L_ORI, L_LEG, L_LEG_NIV # SEGAY 25/10/12 US 930 81085
          L_LEG_NIV = [F:GCP]LEG                  : # SEGAY 25/10/12 US 930 81085
          Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
          Call ECR_TRACE(mess(23,10720,1)-":"-mess(L_IDEL,10937,1)-[F:GCP]UOMGRP-[F:GCP]JOBGRP-[F:GCP]CPCFAM-mess(73,10720,1),0) From GESECRAN
          Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
          GOK = 1
          Call DEBTRANS From GLOCK
          L_SAV_IJ=L_IJ
          L_IJ=L_IDEL
          Gosub TR1
          L_IJ=L_SAV_IJ
          If GOK<1 :Filter [F:JOT1]: Break(3) : Endif
        Endif
      Next
      Filter [F:JOT1]
     When 4 : # ML 2400 Groupe de compétence
      Filter [F:JOT1] Where find(L_IDEL,[F:JOT1]ORI(0..dim([F:JOT1]ORI)-1))
      For [F:JOT1]JOT0
        L_CPT=find ("",[F:JOT1]CPCFAM)
        L_I = 0
        If L_CPT > 0
         L_I = L_CPT-1
        Endif
        If L_I > 0
         Filter [F:GCP] Where [F:GCP]LEVGRP=L_IDEL & find([F:GCP]CPCFAM,[F:JOT1]CPCFAM(0..L_I))
         If !rowcount([F:GCP])>0 Then
          L_CPT=find ("",[F:JOT1]CPCFAM)
          L_I = dim([F:JOT1]CPCFAM)
          If L_CPT > 0
            L_I = L_CPT-1
          Endif
          For K=L_I-1 To 0 Step -1 # Compteur groupe de compétence
           If [F:JOT1]CPCFAM(K)="" : Break : Endif
           Raz [F:GCP]
           [F:GCP]CPCFAM=[F:JOT1]CPCFAM(K)
           [F:GCP]LEVGRP=L_IDEL
           Raz L_CPC, L_NIV, L_NB_CPC, L_ORI, L_LEG, L_LEG_NIV # SEGAY 25/10/12 US 930 81085
           L_LEG_NIV = [F:GCP]LEG                  : # SEGAY 25/10/12 US 930 81085
           Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
           Call ECR_TRACE(mess(23,10720,1)-":"-mess(L_IDEL,10937,1)-[F:GCP]UOMGRP-[F:GCP]JOBGRP-[F:GCP]CPCFAM-mess(73,10720,1),0) From GESECRAN
           Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
           GOK = 1
           Call DEBTRANS From GLOCK
           L_SAV_IJ=L_IJ
           L_IJ=L_IDEL
           Gosub TR1
           L_IJ=L_SAV_IJ
           If GOK<1 :Filter [F:JOT1]: Break(4) : Endif
          Next # Compteur groupe de compétence
        Endif
       Endif
      Next # Compteur emploi type
      Filter [F:JOT1]
    Endcase
    Next # Compteur niveau
   Endif


   If L_IJ=NIVGRP
    # JML 30/07/10 LOT P02 New size for CPC (from 5 to 15 car.) New file GRPCPCD
    # JML 27/09/10 On ne filtre le code que pour le niveau concerné, pour les 'sous niveaux' on prend tout
    Case NIVGRP
     When 1 : # ML 2400 Dossier
              L_CRITGCD = "1=1"
     When 2 : # ML 2400 Famille
              L_CRITGCD = "[F]UOMGRP='"+[L]CODGRP+"'"
     When 3 : # ML 2400 Métier
              L_CRITGCD = "[F]JOBGRP='"+[L]CODGRP+"'"
     When 4 : # ML 2400 Groupe de compétence
              L_CRITGCD = "[F]CPCFAM='"+[L]CODGRP+"'"
    Endcase
   Endif
   #  SEGAY 10/11/10 LOT P02
   #  Remplacer par FOR_GCP
   # To be sure...
#   Filter [GCP] Where evalue(L_CRITGCP) & evalue(L_CRITGCD)
#   Read [GCP]GCP0 Last
#   If fstat>=4 & L_IJ=NIVGRP
#    Call ERREUR([L]CODGRP-mess(10,112,1)) From GESECRAN
#    #### Code inexistant
#    GERR = 1 : SAI = 0 : Break
#   Elsif fstat>=4
#    Raz [F:GCP]
#   Endif
#   Filter [GCP]
#
#   # JML 27/09/10 CG Parcourir tous les niveaux...
#   For [GCP]GCP0 Where evalue(L_CRITGCP) & evalue(L_CRITGCD)
#    Raz L_CPC, L_NIV, L_NB_CPC
#    For [HRGCD]GCD0 Where evalue(L_CRITGCP) & evalue(L_CRITGCD)
#     L_CPC(L_NB_CPC) = [F:HRGCD]CPC
#     L_NIV(L_NB_CPC) = [F:HRGCD]NIV
#     L_NB_CPC += 1
#    Next : # [HRGCD]GCD0
#
#    Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
#    Call ECR_TRACE(TIT-":"-mess(L_IJ,10937,1)-[F:GCP]UOMGRP-[F:GCP]JOBGRP-[F:GCP]CPCFAM,0) From GESECRAN
#    Call ECR_TRACE(string$(70,"*"),0) From GESECRAN
#
#    # JML 30/07/10 LOT P02 Newfile GRPCPCD
#    GOK = 1
#    Call DEBTRANS From GLOCK
#    Gosub TR1
#    If GOK<1 : Break(2) : Endif
#   Next : # [GCP]GCP0
#   If NIVGRP=4  : # ML 2400 Groupe de compétence
#    Break
#   Endif
#  SEGAY 10/11/10 LOT P02
   L_LEG_NIV_SUP="" # SEGAY 25/10/12 US 930 81085
#  Pour le lancement Famille(niveau NIVGRP=2), pour les métiers(niveau L_IJ=3) dépendants de la famille, il faut prendre les compétences métier
#  sinon on passe au niveau Famille (L_IJ=2)
   If NIVGRP=2 & L_IJ = 3
     I = 0
# SEGAY 25/10/12 US 930 81085
     Read [F:ADI]CODE=10459;[L]CODGRP
     If !fstat
        L_LEG_NIV_SUP=[F:ADI]LEG
     Endif
# END SEGAY 25/10/12 US 930 81085
     Filter [ADI] Where NUMTAB=10460 & DEPCOD=[L]CODGRP
     If rowcount([F:ADI]) > 0
       SAV_CRITGCD = L_CRITGCD
       For [ADI]CODE
#         L_CRITGCD -= "& [F]JOBGRP='"+[F:ADI]CODE+"'"
         L_CRITGCD = SAV_CRITGCD+" & [F]JOBGRP='"+[F:ADI]CODE+"'"

         Gosub FOR_GCP
         If GOK<1 : Break(2) : Endif
       Next
     Endif
     Filter [F:ADI]
   Else : # NIVGRP=2 & L_IJ = 3
     Gosub FOR_GCP
     If GOK<1 : Break : Endif
   Endif
  Endif : # If (NIVGRP=4 & L_IJ=NIVGRP) | L_IJ<4
 Endif : # If L_IJ=5
Next L_IJ
