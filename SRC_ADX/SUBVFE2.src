#<AdxTL>@(#)0.0.0.0 $Revision$

# Issue X3-101747 - 2018-07-30 by CBO : Add URL to manage TEST / PrePROD / PROD environment
# Issue X3-101736 - 2018-07-25 by CBO : Manage return message from Submissions tool


####################################################################################################
# functions about GESVFE X3-101736
###########################################################################################################

$TRT_VALIDATE_VAT

  [M:VFE0]STA = [V]CST_VALIDATED
  Affzo [M:VFE0]STA

  Update [VFE] Where VATENTNUM = [M:VFE0]VATENTNUM and VATFNC = [M:VFE1]VATFNC and LEG = [M:VFE1]LEG and CPY = [M:VFE1]CPY
&              With STA = [M:VFE0]STA

Return

# Issue X3-85098
#**
#* prepare to submit VAT
#*!
$TRT_SUBMIT_VAT

  Local Clbfile RESHEAD      # Stream that contains the javascript result header
  Local Clbfile RESBODY      # Stream that contains the javascript result body

  If [M:VFE2]NBBOX < 9
    GMESSAGE = "NBBOX" - num$([M:VFE2]NBBOX)
    GOK = 0
    mkstat = 2
    Return
  Endif
  Read [CPY]CPY0 = [M:VFE1]CPY

  # Be carefull : it's version number + 1
  # issue X3-101747 add a new parameter WURL
  Call SBMVAT([M:VFE1]VATRTNTYP, [M:VFE1]DCLSTRDAT, [M:VFE1]DCLENDDAT,
&              year([M:VFE1]DCLENDDAT), [M:VFE1]PERNUM, WURL, [F:CPY]CPYNAM, WDIGIT_VAT_NUMBER,
&              [M:VFE0]VATENTNUM, [M:VFE1]VERSION + 1,
&              [M:VFE2]VATAMT(0), [M:VFE2]VATAMT(1), [M:VFE2]VATAMT(2), [M:VFE2]VATAMT(3), [M:VFE2]VATAMT(4),
&              [M:VFE2]VATAMT(5), [M:VFE2]VATAMT(6), [M:VFE2]VATAMT(7), [M:VFE2]VATAMT(8),
&              WRTRN_CODE, WMESSAGE,
&              RESHEAD, RESBODY)

  If WRTRN_CODE = "200"
    [M:VFE0]STA = [V]CST_SUBMITED
    [M:VFE1]VERSION += 1
    [M:VFE1]RESULT = RESBODY


    Affzo [M:VFE0]STA
    Affzo [M:VFE1]VERSION

    Read [VFE]VFE0 = [M:VFE0]VATENTNUM
    [F:VFE]LASSBM = datetime$
    [M:VFE1]LASSBM = func FMTDT([F:VFE]LASSBM)
    Affzo [M:VFE1]LASSBM
    [F:VFE]RESULT = [M:VFE1]RESULT
    [F:VFE]STA = [M:VFE0]STA
    [F:VFE]VERSION = [M:VFE1]VERSION
    Rewrite [VFE]

  Else

    [M:VFE0]STA = [V]CST_AERROR
    [M:VFE1]RESULT = RESBODY
    Affzo [M:VFE0]STA

    Read [VFE]VFE0 = [M:VFE0]VATENTNUM
    [F:VFE]LASSBM = datetime$
    [M:VFE1]LASSBM = func FMTDT([F:VFE]LASSBM)
    Affzo [M:VFE1]LASSBM
    [F:VFE]RESULT = [M:VFE1]RESULT
    [F:VFE]STA = [M:VFE0]STA
    Rewrite [VFE]

  Endif

Return

#**
#* Submit VAT to the bundle
#*
#* @param PTYPE
#* @param PTYPE_PERIOD
#* @param PSTRDAT
#* @param PENDDAT
#* @param PYEAR
#* @param PERIOD
#* @param CPYNAM
#* @param PCOMPVATNO
#* @param PVATDUESALES
#* @param PVATDUEACQUISITIONS
#* @param PTOTALVATDUE
#* @param PVATRECLAIMEDCURRPERIOD
#* @param PNETVATDUE
#* @param PTOTALVALUESALESEXVAT
#* @param PTOTALVALUEPURCHASESEXVAT
#* @param PTOTALVALUEGOODSSUPPLIEDEXVAT
#* @param PTOTALACQUISITIONSEXVAT
#* @param RTRN_CODE
#*!
# issue X3-101747 add a new parameter WURL
Subprog SBMVAT(PTYPE, PSTRDAT, PENDDAT, PYEAR, PERIOD, PURL, CPYNAM, PCOMPVATNO,
&                PVATENTNUM, PVERSION,
&                PVATDUESALES, PVATDUEACQUISITIONS, PTOTALVATDUE, PVATRECLAIMEDCURRPERIOD, PNETVATDUE,
&                PTOTALVALUESALESEXVAT, PTOTALVALUEPURCHASESEXVAT,PTOTALVALUEGOODSSUPPLIEDEXVAT, PTOTALACQUISITIONSEXVAT,
&                RTRN_CODE, RMESSAGE,
&                RESHEAD, RESBODY)

Value Shortint PTYPE
Value Date PSTRDAT()
Value Date PENDDAT()
Value Integer PYEAR
Value Integer PERIOD
Value Char PURL()
Value Char CPYNAM()
Value Char PCOMPVATNO

Value Char PVATENTNUM()
Value Shortint PVERSION

Value Decimal PVATDUESALES
Value Decimal PVATDUEACQUISITIONS
Value Decimal PTOTALVATDUE
Value Decimal PVATRECLAIMEDCURRPERIOD
Value Decimal PNETVATDUE

Value Decimal PTOTALVALUESALESEXVAT
Value Decimal PTOTALVALUEPURCHASESEXVAT
Value Decimal PTOTALVALUEGOODSSUPPLIEDEXVAT
Value Decimal PTOTALACQUISITIONSEXVAT

Variable Char RTRN_CODE()
Variable Char RMESSAGE()
Variable Clbfile RESHEAD, RESBODY

  Local Clbfile PARAMS
  Local Integer STATUSCODE, STARTPOS
  Local Char    ENCODING(255)
  Local Char    WFCT(255)

  Local Char    WTYPE(255)
  Local Char    WRTRN_CODE_HEADER(10)

  RMESSAGE = ""
  # to obtain UK-MTD-VAT100-MONTHLY for example
#  WTYPE = PTYPE + "-" + toupper(vireblc(PTYPE_PERIOD, 4))
  If PTYPE = 1
    WTYPE = "UK-MTD-VAT100-MONTHLY"
  Elsif PTYPE = 2
    WTYPE = "UK-MTD-VAT100-QUARTERLY"
  Elsif PTYPE = 3
    WTYPE = "UK-MTD-VAT100-YEARLY"
  Endif

  # prepare the JSON to send
  # issue X3-101747 add a new parameter PURL
  Call SET_JSON(PARAMS, WTYPE, PSTRDAT, PENDDAT, PYEAR, PERIOD, PURL, CPYNAM, PCOMPVATNO,
&                PVATENTNUM, PVERSION,
&                PVATDUESALES, PVATDUEACQUISITIONS, PTOTALVATDUE, PVATRECLAIMEDCURRPERIOD, PNETVATDUE,
&                PTOTALVALUESALESEXVAT, PTOTALVALUEPURCHASESEXVAT,PTOTALVALUEGOODSSUPPLIEDEXVAT, PTOTALACQUISITIONSEXVAT)


# Path of js file ( without ._js )
# javascript function
# Use "wait" because it's a streamline call (first parameter of the JavaScript function is '_'
# Params are the parameter
# Encoding is the encoding type of the parameter
# Reshead & resbody are the return parts

  WFCT = "sendVatForm"
  ENCODING = "0"

  STATUSCODE = func ASYRWEBSER.EXEC_JS(
&        "bundle-sage-rr/lib/rr",
&        WFCT,
&        "wait",
&        PARAMS,
&        ENCODING,
&        0, "", "0", RESHEAD, RESBODY)

  STARTPOS = 1
  RTRN_CODE = func GET_PROP(STARTPOS, RESBODY, "statusCode")
  If RTRN_CODE <> ""
    STARTPOS = 1
    RMESSAGE = func GET_PROP(STARTPOS, RESBODY, "message")
  Endif
  STARTPOS = 1
  WRTRN_CODE_HEADER = func GET_PROP(STARTPOS, RESHEAD, "statusCode")

  Call DSP_LOG_JSON(RTRN_CODE, WRTRN_CODE_HEADER, RMESSAGE, PARAMS, RESHEAD, RESBODY, "JSON FORMAT", "sent JSON ", "received HEADER ", "received BODY")

End

Funprog FMTDT(PLASSBM)
Value Datetime PLASSBM

Local Char WDATE(30)
  If PLASSBM = AVOID.ADATTIM
    WDATE = AVOID.ACHAR
  Else
    WDATE = format$("D:" + GFMDAT4, PLASSBM) - mid$(num$(PLASSBM), 12, 8)
  Endif

End WDATE
#**
#* prepare the JSON
#*
#* @param PARAMS
#* @param PTYPE
#* @param PSTRDAT
#* @param PENDDAT
#* @param PYEAR
#* @param PERIOD
#* @param CPYNAM
#* @param PCOMPVATNO
#* @param PVATDUESALES
#* @param PVATDUEACQUISITIONS
#* @param PTOTALVATDUE
#* @param PVATRECLAIMEDCURRPERIOD
#* @param PNETVATDUE
#* @param PTOTALVALUESALESEXVAT
#* @param PTOTALVALUEPURCHASESEXVAT
#* @param PTOTALVALUEGOODSSUPPLIEDEXVAT
#* @param PTOTALACQUISITIONSEXVAT
#*!
# issue X3-101747 add a new parameter PURL
Subprog SET_JSON(PARAMS, PTYPE, PSTRDAT, PENDDAT, PYEAR, PERNUM, PURL, CPYNAM, PCOMPVATNO,
&                PVATENTNUM, PVERSION,
&                PVATDUESALES, PVATDUEACQUISITIONS, PTOTALVATDUE, PVATRECLAIMEDCURRPERIOD, PNETVATDUE,
&                PTOTALVALUESALESEXVAT, PTOTALVALUEPURCHASESEXVAT,PTOTALVALUEGOODSSUPPLIEDEXVAT, PTOTALACQUISITIONSEXVAT)

Variable Clbfile PARAMS

Value Char PTYPE()
Value Date PSTRDAT()
Value Date PENDDAT()
Value Integer PYEAR
Value Integer PERNUM
Value Char PURL()
Value Char CPYNAM()
Value Char PCOMPVATNO

Value Char PVATENTNUM()
Value Shortint PVERSION

Value Decimal PVATDUESALES
Value Decimal PVATDUEACQUISITIONS
Value Decimal PTOTALVATDUE
Value Decimal PVATRECLAIMEDCURRPERIOD
Value Decimal PNETVATDUE

Value Decimal PTOTALVALUESALESEXVAT
Value Decimal PTOTALVALUEPURCHASESEXVAT
Value Decimal PTOTALVALUEGOODSSUPPLIEDEXVAT
Value Decimal PTOTALACQUISITIONSEXVAT

  PARAMS  = '{'
    PARAMS += ' "$context": {'

      PARAMS += ' "$type": "'                  + PTYPE                                 + '",'
      PARAMS += ' "startDate": "'              + format$("D:YYYY[-]MM[-]DD", PSTRDAT)  + '",'
      PARAMS += ' "endDate": "'                + format$("D:YYYY[-]MM[-]DD", PENDDAT)  + '",'
      PARAMS += ' "year": '                    + num$(PYEAR)                           + ','
#      PARAMS += ' "period": "'                 + '#' + format$("N0:3", PERNUM)         + '",' # It's also a return value # Issue X3-101745
      PARAMS += ' "period": "'                                                         + '",' # It's also a return value # Issue X3-101745
      PARAMS += ' "comp_name": "'              + CPYNAM                                + '",'
      PARAMS += ' "comp_vat_no": "'            + PCOMPVATNO                            + '",'
      PARAMS += ' "vatDeclarationNumber": "'   + PVATENTNUM                            + '",'
      PARAMS += ' "vatDeclarationVersion": '   + num$(PVERSION)                        + ','
      PARAMS += ' "mtdUrlEnv": "'              + PURL                                  + '",' # Issue X3-101747

      PARAMS += ' "calculations": {'

        PARAMS += ' "vatDueSales": '                    + num$(PVATDUESALES)                    + ','
        PARAMS += ' "vatDueAcquisitions": '             + num$(PVATDUEACQUISITIONS)             + ','
        PARAMS += ' "totalVatDue": '                    + num$(PTOTALVATDUE)                    + ','
        PARAMS += ' "vatReclaimedCurrPeriod": '         + num$(PVATRECLAIMEDCURRPERIOD)         + ','
        PARAMS += ' "netVatDue": '                      + num$(PNETVATDUE)                      + ','
        PARAMS += ' "totalValueSalesExVAT": '           + num$(PTOTALVALUESALESEXVAT)           + ','
        PARAMS += ' "totalValuePurchasesExVAT": '       + num$(PTOTALVALUEPURCHASESEXVAT)       + ','
        PARAMS += ' "totalValueGoodsSuppliedExVAT": '   + num$(PTOTALVALUEGOODSSUPPLIEDEXVAT)   + ','
        PARAMS += ' "totalAcquisitionsExVAT": '         + num$(PTOTALACQUISITIONSEXVAT)


      PARAMS += ' },'

    PARAMS += ' "finalised": true}'
  PARAMS += '}'

End
#**
#* Display the log (if authorized)
#*
#* @param PRTRN_CODE
#* @param P1
#* @param P2
#* @param P3
#*!
Subprog DSP_LOG_JSON(PRTRN_CODE_BODY, PRTRN_CODE_HEADER, PMESSAGE, P1, P2, P3, PT0, PT1, PT2, PT3)
Value Char PRTRN_CODE_BODY()
Value Char PRTRN_CODE_HEADER()
Value Char PMESSAGE()
Value Clbfile P1, P2, P3
Value Char PT0(), PT1(), PT2(), PT3()

Local Integer I, WNB, WLG_LINE

#  If GADONIX <> 2
#    End
#  Endif

  Call OUVRE_TRACE(PT0) From LECFIC

  Call ECR_TRACE("Date :" - format$("D:"+ GFMDAT4, date$) - "-" - time$, 0) From GESECRAN
  Call ECR_TRACE("Return code (BODY)   =" - PRTRN_CODE_BODY, 0) From GESECRAN
  Call ECR_TRACE("Return code (HEADER) =" - PRTRN_CODE_HEADER, 0) From GESECRAN
  If PMESSAGE <> ""
    Call ECR_TRACE("Message =" - PMESSAGE, 0) From GESECRAN
  Endif
  Call ECR_TRACE("", 0) From GESECRAN

  If P1 <> ""
    Call ECR_JSON(PT1, P1)
  Endif
  If P2 <> ""
    Call ECR_JSON(PT2, P2)
  Endif
  If P3 <> ""
    Call ECR_JSON(PT3, P3)
  Endif


  Call FERME_TRACE() From LECFIC

  If GSERVEUR = 0 and GADONIX = 2
    Call LEC_TRACE From LECFIC
  Endif

End

#**
#* Write an format a JSON (for log)
#*
#* @param PTITLE
#* @param PARAMS
#*!
Subprog ECR_JSON(PTITLE, PARAMS)
Value Char PTITLE()
Value Clbfile PARAMS

Local Integer I, WNB, WLG_LINE

  WLG_LINE = 110
  WNB = (len(PARAMS) / WLG_LINE) + 1
  Call ECR_TRACE(PTITLE - "(length =" - num$(len(PARAMS)) + ") :", 0) From GESECRAN
  Call ECR_TRACE("", 0) From GESECRAN

  For I = 1 To WNB
    Call ECR_TRACE(mid$(PARAMS, 1 + (I - 1)*WLG_LINE, WLG_LINE), 0) From GESECRAN
  Next

  Call ECR_TRACE("", 0) From GESECRAN
  Call ECR_TRACE("", 0) From GESECRAN

End

