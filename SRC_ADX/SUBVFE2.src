#**
#*  Gets the value of a property in a JSON from a start position
#*  Does not check if the JSON structure is ok
#*
#* @param STARTPOS
#* @param JSONSTRING
#* @param VARNAME
#*!
Funprog GET_PROP(STARTPOS, JSONSTRING, VARNAME)
Variable Integer STARTPOS
Value Clbfile JSONSTRING
Value Char VARNAME

Local Integer I, J, L

  If STARTPOS < 1
    STARTPOS = 1
  Endif

  I = instr(STARTPOS, JSONSTRING, '"' + VARNAME + '":"')
  If I
    L = len('"' + VARNAME + '":"')
    J = instr(I + L, JSONSTRING, '"')
    If J
      STARTPOS = I
      End seg$(JSONSTRING, I + L, J - 1)
    Endif
  Else
    I = instr(STARTPOS, JSONSTRING, '"' + VARNAME + '":')
    If I
      L = len('"' + VARNAME + '":')
      J = instr(I + L, JSONSTRING, ',')
      If J
        STARTPOS = I
        End seg$(JSONSTRING, I + L, J - 1)
      Endif
    Endif
  Endif

End ""

# issue X3-101747
#**
#* Get the choosen Url (for HMRC)
#* Choice in MTDENV parameter (1 to 3)
#* address in 3704 menu
#*
#* @param PVATFNC
#* @param PCPY
#* @param RURL
#* @param RMESSAGE
#*!
Funprog GET_CTRL_PARAM_URL(PVATFNC, PCPY, RDESURL, RURL, RMESSAGE)
Value Char PVATFNC()
Value Char PCPY()
Variable Char RDESURL()
Variable Char RURL()
Variable Char RMESSAGE()

Local Char WNUM_MES(2)
  RDESURL = "" # undefined
  RURL = ""
  RMESSAGE = ""
  If PVATFNC <> "DCLVATBRI"
    End [V]CST_AOK
  Endif

  If func AFNC.ACTIV("KUK")
    WNUM_MES = func AFNC.PARAM("MTDENV", PCPY)
    If WNUM_MES <> "" and  WNUM_MES <> "0"
      RDESURL = mess(val(WNUM_MES),3705,1)
      RURL = mess(val(WNUM_MES),3704,1)
    Endif
  Endif
  If RURL = ""
    RMESSAGE = mess(223,104,1)
    RDESURL = mess(4,3705,1)
    End [V]CST_AERROR
  Endif

End [V]CST_AOK
# End issue X3-101747

