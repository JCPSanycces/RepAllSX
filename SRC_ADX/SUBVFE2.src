##################################################
Subprog CHKSTS_SBMVAT(PVATENTNUM, PVERSION, RTRN_CODE)
Value Char PVATENTNUM()
Value Shortint PVERSION
Variable Char RTRN_CODE()

Local Char    WFCT(255), ENCODING(255)
Local Clbfile PARAMS

Local Clbfile RESHEAD      # Stream that contains the javascript result header
Local Clbfile RESBODY      # Stream that contains the javascript result body
Local Integer STATUSCODE


Local Clbfile WRESULT
  WFCT = "getResult"
  ENCODING = "0, 0"
  PARAMS = PVATENTNUM + "," + num$(PVERSION)

  STATUSCODE = func ASYRWEBSER.EXEC_JS(
&        "bundle-sage-rr/lib/rr",
&        WFCT,
&        "wait",
&        PARAMS,
&        ENCODING,
&        0, "", "0", RESHEAD, RESBODY)

  Call CHKSTS_SBMVAT_DISPLAY(1, PVATENTNUM, RTRN_CODE, PARAMS, RESHEAD, RESBODY)


  Call CHKSTS_SBMVAT_UPDATE(1, PVATENTNUM, RTRN_CODE, [M:VFE1]RESULT, [M:VFE0]STA)

End

#**
#* Check the result and displays
#*
#* @param PBUNDLE       boolean TRUE if X3 version >= V11 (= Bundle) else FALSE (= web service)
#* @param PVATENTNUM
#* @param PVERSION
#* @param RTRN_CODE
#* @param PARAMS
#* @param RESHEAD
#* @param RESBODY
#*!
Subprog CHKSTS_SBMVAT_DISPLAY(PBUNDLE, PVATENTNUM, RTRN_CODE,
&                           PARAMS, RESHEAD, RESBODY)
Value Integer PBUNDLE
Value Char PVATENTNUM()
Variable Char RTRN_CODE()
Variable Clbfile PARAMS, RESHEAD, RESBODY

Local Char TXT(100)(1..12)
Local Integer WOK, STARTPOS, I
Local Clbfile WRESULT(3)
Local Char WRTRN_CODE_HEADER(10)

  STARTPOS = 1
  WRTRN_CODE_HEADER = func GET_PROP(STARTPOS, RESHEAD, "statusCode")
  STARTPOS = 1
  RTRN_CODE = func GET_PROP(STARTPOS, RESBODY, "statusCode")

  If RTRN_CODE = "9201" # Issue CBO 201 comme 200
#    [M:VFE1]RESULT = "Status code =" - RTRN_CODE - "Result =" - func GET_RESULT(RESBODY)
    [M:VFE1]RESULT = RESBODY

#    STARTPOS = 1 # tracking : en cours, on attend la réponse de HMRC (pas tjrs)
#    Call AVERTIR(mess(190, 75, 1) - ":" - func GET_PROP(STARTPOS, RESBODY, "result"), WOK) From GESECRAN

  Elsif RTRN_CODE = "202"
#    [M:VFE1]RESULT = "Status code =" - RTRN_CODE - "Result =" - func GET_RESULT(RESBODY)
    [M:VFE1]RESULT = RESBODY

#    STARTPOS = 1  # periods ok
#    Call AVERTIR(mess(190, 75, 1) - ":" - func GET_PROP(STARTPOS, RESBODY, "result"), WOK) From GESECRAN

  Elsif RTRN_CODE = "200" or  RTRN_CODE = "201" # Issue CBO 201 comme 200
#    STARTPOS = 1 # final result
#    Call AVERTIR(mess(190, 75, 1) - ":" - func GET_PROP(STARTPOS, RESBODY, "result"), WOK) From GESECRAN

    # Issue X3-85094
#    [M:VFE1]RESULT = func GET_RESULT(RESBODY)
    [M:VFE1]RESULT = RESBODY
    [M:VFE0]STA = [V]CST_FINISHED
    Affzo [M:VFE0]STA
    # End Issue X3-85094


  Elsif RTRN_CODE = "300" or RTRN_CODE = "301" # Errors about periods or already submited

    TXT(1) = mess(7, 21, 1)  - ":" - RTRN_CODE - func GET_PROP(STARTPOS, RESBODY, "code")
    TXT(2) = mess(14, 75, 1)  - ":" - func GET_PROP(STARTPOS, RESBODY, "message")
    [M:VFE1]RESULT = RESBODY

    Gosub PREPARE_LIST_DATE_WHEN_ERROR

    TXT(I + 1) = mess(135, 126, 1) - "?"

    Call WARNING_CHX(TXT, mess(4, 115, 1), mess(2, 1, 1), mess(1, 1, 1), WOK) From GESECRAN
    If WOK = 2
      Call DSP_LOG_JSON(RTRN_CODE, WRTRN_CODE_HEADER, "", PARAMS, RESHEAD, RESBODY, "CHECK STATUS", "sent Params", "received HEADER", "received BODY")
    Endif
  Elsif RTRN_CODE = "400"

    TXT(1) = mess(7, 21, 1)  - ":" - RTRN_CODE - func GET_PROP(STARTPOS, RESBODY, "code")
    TXT(2) = mess(14, 75, 1)  - ":" - func GET_PROP(STARTPOS, RESBODY, "message")
    TXT(4) = mess(135, 126, 1) - "?"
    [M:VFE1]RESULT = RESBODY
    Call WARNING_CHX(TXT, mess(4, 115, 1), mess(2, 1, 1), mess(1, 1, 1), WOK) From GESECRAN
    If WOK = 2
      Call DSP_LOG_JSON(RTRN_CODE, WRTRN_CODE_HEADER, "", PARAMS, RESHEAD, RESBODY, "CHECK STATUS", "sent Params", "received HEADER", "received BODY")
    Endif
  Else

    STARTPOS = 1
    TXT(1) = mess(7, 21, 1)  - ":" - RTRN_CODE - func GET_PROP(STARTPOS, RESBODY, "message")
    TXT(3) = mess(135, 126, 1) - "?"
    Call WARNING_CHX(TXT, mess(4, 115, 1), mess(2, 1, 1), mess(1, 1, 1), WOK) From GESECRAN
    If WOK = 2
      Call DSP_LOG_JSON(RTRN_CODE, WRTRN_CODE_HEADER, "", PARAMS, RESHEAD, RESBODY, "CHECK STATUS", "sent JSON", "received HEADER", "received BODY")
    Endif
  Endif

#  Call AFFMES(TXT) From GESECRAN

End

#**
#* Update the form after check
#*
#* @param PBUNDLE        boolean TRUE if X3 version >= V11 (= Bundle) else FALSE (= web service)
#* @param PVATENTNUM
#* @param PRTRN_CODE
#* @param PRESULT
#* @param PSTA
#*!
Subprog CHKSTS_SBMVAT_UPDATE(PBUNDLE, PVATENTNUM, PRTRN_CODE, PRESULT, PSTA)
Value Integer PBUNDLE
Value Char PVATENTNUM()
Value Char PRTRN_CODE()
Variable Clbfile PRESULT
Value Shortint PSTA

  If clalev([F:VFE])  = 0   : Local File VATFRMENT    [VFE]  : Endif

  Read [VFE]VFE0 = PVATENTNUM

  [F:VFE]RESULT = PRESULT

  If PRTRN_CODE = "200" or PRTRN_CODE = "201" # Issue CBO 201 comme 200

    [F:VFE]STA = [V]CST_FINISHED
    [F:VFE]LASSBM = datetime$

  Else
    If PBUNDLE = 0
      [F:VFE]VERSION += 1
      [F:VFE]LASSBM = datetime$
    Endif
    If PRTRN_CODE = "201" or PRTRN_CODE = "202" # different states of check button

    Elsif PRTRN_CODE = "300" or PRTRN_CODE = "301" # Errors about periods or already submited

      [F:VFE]STA = [V]CST_AERROR

    Elsif PRTRN_CODE = "400"
      [F:VFE]STA = [V]CST_AERROR
    Else
      [F:VFE]STA = [V]CST_AERROR
    Endif
  Endif

  Rewrite [VFE]

End
# End Issue X3-101736

# prepare the list od dates when error
$PREPARE_LIST_DATE_WHEN_ERROR

#{"statusCode":"300","message":"Wrong periods","result":{"headers":{"X-Correlationid":"5b2a51512e00003c0011ec60
#"},
#"statusCode":200,"payload":{"obligations":[
#{"start":"2018-01-01","end":"2018-03-31","due":"2018-05-07","status":"F","periodKey":"#001","received":"2018-03-26"},
#{"start":"2018-04-01","end":"2018-06-30","due":"2018-08-06","status":"O","periodKey":"#002"},
#{"start":"2018-07-01","end":"2018-09-30","due":"2018-11-06","status":"O","periodKey":"#003"},
#{"start":"2018-10-01","end":"2018-12-31","due":"2019-02-07","status":"O","periodKey":"#004"}]}}}

Local Clbfile WPARAM
Local Char WSTART_DATE(20), WEND_DATE(20), WDUE_DATE(20), WRECEIVED_DATE(20), WSTATUS(20)
Local Integer J, K, WPOS

  For I = 3 To 10

    # select one line of array
    J = instr(STARTPOS, RESBODY, '{"start"')
    K = instr(J, RESBODY, '}')

    If J = 0 or K = 0
      Break
    Endif
    WPARAM = seg$(RESBODY, J, K)
    STARTPOS = K

    # treat the line
    WPOS = 1
    WSTART_DATE = func GET_PROP(WPOS, WPARAM, "start")
    If WSTART_DATE = ""
      Break
    Endif
    WEND_DATE = func GET_PROP(WPOS, WPARAM, "end")
    WDUE_DATE = func GET_PROP(WPOS, WPARAM, "due")
    WSTATUS = func GET_PROP(WPOS, WPARAM, "status")
    WRECEIVED_DATE = func GET_PROP(WPOS, WPARAM, "received")

    TXT(I)  = WSTATUS - ":"
    TXT(I) -= WSTART_DATE - "->" - WEND_DATE
    TXT(I) -= "due :" - WDUE_DATE
    If WRECEIVED_DATE <> ""
      TXT(I) -= "received :" - WRECEIVED_DATE
    Endif
  Next I

Return

# End Issue X3-101736


# Issue X3-85094
#**
#* Get the result when final step
#*
#* @param RESBODY
#*!
Funprog GET_RESULT(RESBODY)
Value Clbfile RESBODY

Local Clbfile WRESULT
Local Integer START_POS, J, BEFORE_LAST_POS, SV_POS

  WRESULT = ""
  START_POS = instr(1, RESBODY, '$results":{')
  If START_POS = 0
    End WRESULT
  Endif

  # we want the } in before last position
  J = START_POS
  BEFORE_LAST_POS = 0
  SV_POS = 0
  While J

    J = instr(SV_POS + 1, RESBODY, '}')
    If J
      BEFORE_LAST_POS = SV_POS
      SV_POS = J
    Else
      Break
    Endif
  Wend
  If BEFORE_LAST_POS > START_POS
    START_POS = instr(START_POS, RESBODY, '{')
    If START_POS
#    Infbox "LG" - num$(BEFORE_LAST_POS - START_POS)
      WRESULT = seg$(RESBODY, START_POS, BEFORE_LAST_POS)
    Endif
  Endif

#{"$title":"Submission results","$statusCode":200,"$status":"success",
  #"$results":{
    #"headers":{
