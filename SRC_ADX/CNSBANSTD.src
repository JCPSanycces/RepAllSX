#<AdxTL>@(#)4.0.0.0 $Revision$ Consultation BAN
Raz GTUNCPT
Local Char PARAM(10)(1..9)
PARAM(1)="DBA"
PARAM(2)="20031001"
PARAM(3)="20031231"
PARAM(4)=""
Call GCONSULT("BAN","",PARAM) From GCONSULT
End

$ACTION
Case ACTION
 When "AUTORIS"    : Gosub AUTORIS
 When "FERME"      : Gosub FERME
 When "OUVRE"      : Gosub OUVRE
 When "LECTURE"    : Gosub LECTURE
 When "AV_MAGNETO" : Gosub AV_MAGNETO
 When "AP_MAGNETO" : Gosub AP_MAGNETO
 When "CLECUR"     : If !CLECUR & [M:CBA1]BAN<>"" : CLECUR=1 : Endif
Endcase
Return

############################################
$AUTORIS
Local Libelle OTUNCPT
OTUNCPT=GTUNCPT(15)
If GTUNCPT(15)
 Call MESSAGE(mess(247,199,1)) From GESECRAN : OK=0
 # Une même fonction ne peut pas être appelée deux fois !
Else
 GTUNCPT(15) = 1
Endif
Return

############################################
$FERME
If dim(OTUNCPT)>0 : GTUNCPT(15) = OTUNCPT : Endif
Call DEBTRANS From GLOCK
Call TR_ANNUL From TRTCNSBAN
If GOK<1 : End : Endif
Call VALFIL_TBL From TRTCNSBAN
Return

############################################
$OUVRE
If clalev ([F:FCY]) =0 : Local File FACILITY   [FCY]  : Endif
If clalev ([F:BAN]) =0 : Local File BANK       [BAN]  : Endif
If clalev ([F:TCB]) =0 : Local File TMPCNSBAN  [TCB]  : Endif
If clalev ([F:PER]) =0 : Local File PERIOD     [PER]  : Endif
If clalev ([F:BAL]) =0 : Local File BALANCE    [BAL]  : Endif

#Critère pagination
Local Char CRITPAG (250)
Local Char CRITERE (250)
Local Char SAVCRIT (250)

#Clé de parcours pour la pagination
Local Date DCLEDAT , FCLEDAT
Local Char DCLENUM (GLONVCR)
Local Char FCLENUM (GLONVCR)
Local Char DCLEPAY (GLONTPY)
Local Char FCLEPAY (GLONTPY)
Local Integer DCLETCB,  FCLETCB
Local Integer SNS

#Solde virtuel (pied)
Local Decimal SOLDEV
Local Decimal SAVTOTB

#Solde progressif (colonne tableau)
Local Integer I, NBBLCVIR
Local Decimal SOLDLAST, SOLDFIRST, AMTFIRST
Raz [M:CBA1]
Gosub DEFCRIT
Return

############################################
#Affectation des zones par les paramètres
$DEFCRIT
If [M:CBA1]FCY<>"" & GUSRFCY(1)<>"\" & !find([M:CBA1]FCY,GUSRFCY(1..GNBAUZ))
 [M:CBA1]FCY=""
Endif
For I=1 To dim(PARAM)
 Case I
  When 1 :    :#Banque
   If PARAM(I)<>""
    Call LECTURE("BAN",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:CBA1]BAN = PARAM(I)
     Call C_BAN (PARAM(I))
    Endif
   Endif
  When 2 : # Date debut
   If PARAM(I)<>""
    If instr(1,PARAM(I),"/")
     [M:CBA1]DATDEB = "["+PARAM(I)+"]"
    Elsif PARAM(I)<>""
     [M:CBA1]DATDEB = PARAM(I)
    Endif
   Endif
  When 3 : # Date fin
   If PARAM(I)<>""
    If instr(1,PARAM(I),"/")
     [M:CBA1]DATFIN = "["+PARAM(I)+"]"
    Elsif PARAM(I)<>""
     [M:CBA1]DATFIN = PARAM(I)
    Endif
   Endif
  When 4 : # Site
   If PARAM(I)<>""
    Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
    If !fstat & (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
     If [M:CBA1]CPY<>"" & [M:CBA1]CPY=[F:FCY]LEGCPY
     [M:CBA1]FCY = PARAM(I)
     Endif
    Endif
   Endif
  Endcase
Next I
#Valeurs par défaut critère
If [M:CBAN]MEMO=""
 [M:CBAN]FLGSTA=1
 [M:CBAN]TRI=1
Endif
Default Mask [CBA1]
Gosub CRITENT From =PROGCNS
Return

############################################
$LECTURE
OK=0
#Il faut au mois une banque pour lancer une recherche
If [M:CBA1]BAN<>"" : OK=1 : Endif
If !OK or [M:CBA1]CPY="" or [M:CBA1]CUR="" : NBLU=0 : Return : Endif
Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif
If CHGPAG>0
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif

Effzo[M:CBA2]5
[M:CBA2]TOTBLCVIR=SAVTOTB
SAVCRIT=CRITERE

#Remplissage table temporaire si CRITERE a changé
Call REMPLIT_TBC (SOLDEV,CRITERE,PROGSPE) From TRTCNSBAN

If SAVCRIT<>CRITERE
 #Calcul solde bancaire (entête)
 Gosub SOLDBANK
 #Solde virtuel
 [M:CBA2]TOTBLCVIR=[M:CBA1]BLC+SOLDEV
 SAVTOTB = [M:CBA2]TOTBLCVIR
Endif

#Complément critères de selection pour la pagination
Gosub FILTRE

#Définition de la clé de parcours du fichier temporaire
Gosub ORDRE

#Boucle principale
NBBLCVIR=0
For [F:TCB]CLE
 If NBLU=1
  If CHGPAG=2 or CHGPAG=-2 : Effzo [M:CBA2]5 : Endif
  NBLU=2
 Endif
 If CHGPAG>0
  If NOL>=MAXLIG-1 : SUITE=2 : Break : Endif
  NOL += 1
  If NOL = 0
   DCLENUM  = [F:TCB]NUMPAY
   DCLEDAT  = [F:TCB]ACCDAT
   DCLEPAY  = [F:TCB]PAYTYP
   DCLETCB  = [F:TCB]TCBNUM
  Endif
  FCLENUM  = [F:TCB]NUMPAY
  FCLEDAT  = [F:TCB]ACCDAT
  FCLEPAY  = [F:TCB]PAYTYP
  FCLETCB  = [F:TCB]TCBNUM
 Else
  If NOL<=0 : RETOUR=2 : Break : Endif
  NOL-=1
  If NOL = MAXLIG-1
   FCLENUM  = [F:TCB]NUMPAY
   FCLEDAT  = [F:TCB]ACCDAT
   FCLEPAY  = [F:TCB]PAYTYP
   FCLETCB  = [F:TCB]TCBNUM
  Endif
  DCLENUM  = [F:TCB]NUMPAY
  DCLEDAT  = [F:TCB]ACCDAT
  DCLEPAY  = [F:TCB]PAYTYP
  DCLETCB  = [F:TCB]TCBNUM
 Endif
 nolign=NOL+1
 [M:CBA2]=[F:TCB]
 Gosub SOLDPROG
Next
Filter [F:TCB]
If NBBLCVIR=0 : SOLDFIRST = SOLDLAST : AMTFIRST  = 0 : Endif
Return

############################################
#Calcul du solde bancaire (entête)
$SOLDBANK
Read [F:BAN]BAN0=[M:CBA1]BAN
Call SOLDEBAL([M:CBA1]CUR,[M:CBA1]CPY,[M:CBA1]FCY,[F:BAN]BANACC,[F:BAN]BANBPR,SNS,[M:CBA1]DATFIN,[M:CBA1]BLC) From SUBCHK
If SNS=2 : [M:CBA1]BLC *= -1 : Endif
Affzo  [M:CBA1]BLC
SOLDLAST=[M:CBA1]BLC
Return

############################################
#Calcul de la colonne "solde virtuel progressif"
$SOLDPROG
If CHGPAG=1 & NBBLCVIR=0 : SOLDLAST = [M:CBA1]BLC : Endif

If [F:TCB]STA>8
 [M:CBA2]AMTBLCVIR(nolign-1)=0
Else
 NBBLCVIR+=1
 If CHGPAG=-2 :#retour
  [M:CBA2]AMTBLCVIR(nolign-1)=SOLDFIRST-AMTFIRST
  SOLDFIRST = [M:CBA2]AMTBLCVIR(nolign-1)
  AMTFIRST  = [M:CBA2]AMTBAN(nolign-1)
  If NBBLCVIR=1
   SOLDLAST = [M:CBA2]AMTBLCVIR(nolign-1)
  Endif
 Else
  [M:CBA2]AMTBLCVIR(nolign-1)=[M:CBA2]AMTBAN(nolign-1)+SOLDLAST
  SOLDLAST = [M:CBA2]AMTBLCVIR(nolign-1)
  If NBBLCVIR=1
   SOLDFIRST = [M:CBA2]AMTBLCVIR(nolign-1)
   AMTFIRST  = [M:CBA2]AMTBAN(nolign-1)
  Endif
 Endif
Endif
Return

############################################
#Complément critères de selection pour la pagination
$FILTRE
CRITPAG="USRCRE='"+GUSER+"'"
CRITPAG-="& ADXNUM="+num$(adxuid(2))
Case CHGPAG
When 2 :#suite
 Case [M:CBAN]TRI
   When 1 :  CRITPAG -= '&(([F:TCB]ACCDAT=['+format$(GFMD,FCLEDAT)+'] & [F:TCB]NUMPAY="'+ FCLENUM +'"'+
&                       '& [F:TCB]TCBNUM>'+num$(FCLETCB)+')'+
&                       '|([F:TCB]ACCDAT=['+format$(GFMD,FCLEDAT)+'] & [F:TCB]NUMPAY>"'+ FCLENUM +'")'+
&                       '| [F:TCB]ACCDAT > ['+ format$(GFMD,FCLEDAT)+'])'

   When 2 :  CRITPAG -= '&(([F:TCB]PAYTYP="'+FCLEPAY+'" & [F:TCB]NUMPAY="'+ FCLENUM +'"'+
&                       '& [F:TCB]TCBNUM>'+num$(FCLETCB)+')'+
&                       '|([F:TCB]PAYTYP="'+ FCLEPAY +'" & [F:TCB]NUMPAY>"'+ FCLENUM +'")'+
&                       '| [F:TCB]PAYTYP>"'+FCLEPAY+'")'
 Endcase
When -2 :#retour
 Case [M:CBAN]TRI
   When 1 :  CRITPAG -= '&(([F:TCB]ACCDAT=['+format$(GFMD,DCLEDAT)+'] & [F:TCB]NUMPAY="'+ DCLENUM +'"'+
&                       '& [F:TCB]TCBNUM<'+num$(DCLETCB)+')'+
&                       '|([F:TCB]ACCDAT=['+format$(GFMD,DCLEDAT)+'] & [F:TCB]NUMPAY<"'+ DCLENUM +'")'+
&                       '| [F:TCB]ACCDAT < ['+ format$(GFMD,DCLEDAT)+'])'
   When 2 :  CRITPAG -= '&(([F:TCB]PAYTYP="'+ DCLEPAY +'" & [F:TCB]NUMPAY="'+ DCLENUM +'"'+
&                       '& [F:TCB]TCBNUM<'+num$(DCLETCB)+')'+
&                       '|([F:TCB]PAYTYP="'+ DCLEPAY +'" & [F:TCB]NUMPAY<"'+ DCLENUM +'")'+
&                       '| [F:TCB]PAYTYP<"'+DCLEPAY+'")'
 Endcase
Endcase
Return

############################################
#Définition de la clé de parcours du fichier temporaire
$ORDRE
If CHGPAG>0   :#Asc
 Case [M:CBAN]TRI
  When 1 :
   Filter [F:TCB] Where evalue(CRITPAG) Order By Key CLE=ACCDAT;NUMPAY;TCBNUM
  When 2 :
   Filter [F:TCB] Where evalue(CRITPAG) Order By Key CLE=PAYTYP;NUMPAY;TCBNUM
 Endcase
Else
 Case [M:CBAN]TRI
  When 1 :
   Filter [F:TCB] Where evalue(CRITPAG) Order By Key CLE=ACCDAT Desc;NUMPAY Desc;TCBNUM Desc
  When 2 :
   Filter [F:TCB] Where evalue(CRITPAG) Order By Key CLE=PAYTYP Desc;NUMPAY Desc;TCBNUM Desc
 Endcase
Endif
Return

############################################
#Gestion des boutons magnéto.
$AV_MAGNETO
NOMFIC = "BANK"
ABFIC = "BAN"
CLE = "BAN0"
NBCMP = 1
CLECMP(0) = "BAN"
CLEMSK(0) = "BAN"
FILTRE=""
Default File [BAN]
Return

############################################
#Gestion des boutons magnéto.
$AP_MAGNETO
 Raz [M:CBA1]CPY
 Call C_BAN ([M:CBA1]BAN)
Return

##########################################################################
## Etiquettes écran
##########################################################################
Subprog C_BAN(VALEUR)
Variable Char    VALEUR()
Local Char COALED(GLONCOA), CURLED(GLONCUR)
If [M:CBA1]CPY<>"" & VALEUR=[M:CBA1]BAN : End : Endif #DdM31672
If VALEUR<>""
 Read[F:BAN]BAN0=VALEUR
 If !fstat
  Call SETMAINREF([F:BAN]CPY,GTYPGEN,GTYPANA) From CPTDIV
  Call LECLED([F:BAN]CPY,GTYPLED,[L]COALED,[L]CURLED) From CPTDIV
  [M:CBA1]CPY=[F:BAN]CPY
  [M:CBA1]FCY=[F:BAN]FCY
  Read[F:CPY]CPY0=[F:BAN]CPY
  If [F:BAN]CUR<>""
   [M:CBA1]CUR=[F:BAN]CUR
   [M:CBA2]CURTOTBLC=[F:BAN]CUR
  Else
   [M:CBA1]CUR=[L]CURLED
   [M:CBA2]CURTOTBLC=[L]CURLED
  Endif
  Call LEC_CPY([M]CPY) From CPTLEC
  GCURLEG  = [F:CPY]LEG
  GSOCIETE = [F:CPY]CPY
  Affzo [M:CBA1]
  Affzo [M:CBA2]CURTOTBLC
 Endif
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If [M:CBA1]CPY="" : Call C_BAN ([M:CBA1]BAN) : Endif
Call AS_FCY(VALEUR) From CONSSUB
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CONSSUB
Call GETSOC(VALEUR) From DEVSUB
End

Subprog IB_NBLIG
Raz GBOUT2, GBOUT3
If clalev ([F:PYH]) =0 : Local File PAYMENTH   [PYH]  : Endif
## Bouton 2 : Zoom sur réglement
If dim([M:CBA2]NUMPAY)>0
 Look [F:PYH]PYH0 = [M:CBA2]NUMPAY(nolign-1)
 If !fstat
  GBOUT2 = mess(47,109,1) : # Règlement
 Endif
Endif

If clalev ([F:HAE]) =0 : Local File GACCENTRY  [HAE]  : Endif
## Bouton 3 : Zoom sur pièce
If dim([M:CBA2]TYP)>0 & dim([M:CBA2]NUM)>0
 Look [F:HAE] = [M:CBA2]TYP(nolign-1);[M:CBA2]NUM(nolign-1)
 If !fstat
   GBOUT3 = mess(18,109,1) : #  Pièce
 Endif
Endif
End

Subprog AS_DATDEB(VALEUR)
Variable Date    VALEUR
If [M:CBA1]CPY="" : Call C_BAN ([M:CBA1]BAN) : Endif
End

Subprog AS_DATFIN(VALEUR)
Variable Date    VALEUR
If [M:CBA1]CPY="" : Call C_BAN ([M:CBA1]BAN) : Endif
End

Subprog AV_COLOR(VALEUR)
Variable Decimal VALEUR
If VALEUR=0 : Chgstl [M]NBLIG(nolign-1) With "MTC3" : Endif
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran CONSBAN1) 24/01/2008 09:56:12 (CP)
######################################################################################
Subprog AS_BANBPR(VALEUR)
Variable Char    VALEUR()
Call LECTURE("BAN",[M:CBA1]BAN,"") From CONTOBJ
If [F:BAN]BANBPR="" :  mkstat=2 : End : Endif
If VALEUR="" : VALEUR = [F:BAN]BANBPR : Endif
End


######################################################################################

######################################################################################
#########################################################################
# Pour éxécution validation écrans de consultation en gestion de patch  #
#########################################################################
Subprog PATCH(APPLI)
Value Char APPLI

If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(1)<>2 End Endif

Call VALGTC(APPLI,"BAN") From SUBGTC

End
