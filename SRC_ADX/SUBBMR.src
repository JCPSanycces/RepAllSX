#<AdxTL>@(#)3.0.0.0 $Revision$
# SUBBMR    -     Thierry Blanc Juillet 99
# Calcul besoins en composants
##########################################################################
# boite de dialogue initiale avec masque BOMRET0   (Web  Déc 2000)
# résultat du calcul         avec masque BOMRET1 et anomalies dans LECFIC
##########################################################################

$ACTION
# actions pour trt std
Case ACTION
 When "INIT"            Gosub INIT
 When "INIT_DIA"        Gosub INIT_DIA
 When "CONTROLE"        Gosub CONTROLE
 When "EXEC"            Gosub EXEC
 When "TERMINE"         Call FERME_TRACE From LECFIC
                        TRA = 1         # pour Lecture trace
                        If OK  SAI=1  Endif
 When "SORTIE"          Gosub SORTIE

 # actions pour saisie fenêtre principale
 When "OUVRE"           Gosub OUVRE     # 40728 mm 04.07
 When "DEBUT"           Gosub DEBUT
 When "TITRE"           Gosub TIT
Endcase
Return

$INIT
Local    Integer  OK
Local    Char     ERR(80), ERR_TRA(132)
Local    Char     SBOITE(GLONFEN)                 # 08.06 37275

Global Integer    GNIV, GORD
Global Decimal    GQTY

Local Mask LECFIC [LEC2] # pour conserver les msg de trace

If clalev([F:ACC]) = 0 : Local File ACCES      [ACC] : Endif
If clalev([F:TBO]) = 0 : Local File TABBOMALT  [TBO] : Endif
If clalev([F:ITB]) = 0 : Local File ITMBOM     [ITB] : Endif
If clalev([F:BOH]) = 0 : Local File BOM        [BOH] : Endif
If clalev([F:BOD]) = 0 : Local File BOMD       [BOD] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITG]) = 0 : Local File ITMCATEG   [ITG] : Endif

If clalev([F:SRU]) = 0 : Local File TABSTORUL  [SRU] : Endif     : # FQ 44655 GA 12/2007
Global   Integer  WSTA,WA,WQ,WR,WRET   # Local ne fonctionne pas : # FQ 44655 GA 12/2007

Return


$INIT_DIA
[M]STOFCY = GFCYDEF(0)
[M]DATREF = date$
Return

$CONTROLE
Call OUVRE_TRACE(mess(170,195,1)) From LECFIC

If [M:DIA]NBLIG = 0
  SAI = 1 : Return
Endif

# GH 14/09/2015 bug 109434
OK=2
For I=0 To  [M:DIA]NBLIG-1
   Look [ITF]ITF0 = [M:DIA]ITMREF(I);[M:DIA]STOFCY
   If fstat
      Call AVERTIR([M:DIA]ITMREF(I)-[M:DIA]STOFCY-":"-mess(139,197,1),OK) From GESECRAN
      If OK<>2 : Break : Endif
   Endif
Next
If OK<>2
   SAI=1 : Return
Endif

Raz [M:LEC2]
# ouvert localement puis refermé car il sera
# réouvert pour l'affichage avec des ordres de tri différents
Local File BOMRET     [BMR]

# effacer les anciens enregistrements ... Refonte du traitement : 03/01/02
Trbegin [BMR]
Delete [BMR] Where CREUSR = GUSER     : # & BMRUID = adxuid

If fstat=1  # au lieu de If fstat     21/05/03
    Rollback
#   "Problème à l'effacement du fichier temporaire"
    ERR_TRA = mess(155,197,1)
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
    [M:LEC2]LIGNE([M:LEC2]NBLIG) = ERR_TRA
    [M:LEC2]NBLIG += 1
Else
    Commit
Endif

Raz GORD, GNIV : OK=1
For nolign=1 To [M:DIA]NBLIG
  If [M:DIA]PRNFLG = 2
    Trbegin [BMR]
    Gosub HEAD
    If OK = 0
        Rollback
        Break
    Else
        Commit
    Endif
  Endif

  GQTY = [M:DIA]CLCQTY(nolign-1)
  # Traitement : Premier niveau, Dernier niv ou Multi niv (Menu Local 256)

  # Issue 85197 - 2018-05-22 by STLIG : Pass % scrap to every level (1 + % / 100) ..
  Case [M:DIA]TRT
     When 1 :     Call TRAITPREM([M:DIA]ITMREF(nolign-1),OK,1)
     When 2 :     Call TRAITDER([M:DIA]ITMREF(nolign-1),OK,1)
     When 3 :     Call TRAITMUL([M:DIA]ITMREF(nolign-1),OK,1)
     When 4 :     Call TRAITMUL([M:DIA]ITMREF(nolign-1),OK,1)
  Endcase
  If OK = 0 : Break : Endif
Next

If OK = 0 | [M:DIA]SCRFLG < 2  # pas d'affichage (04/01/02)
   # 08.06 37275
   SBOITE = BOITE
   BOITE = ""
   # positionner BOITE à vide pour sauter la saisie de fenêtre
   # et aller en TERMINE (trace avec erreur bloquante)
Else
   If BOITE = "" : BOITE = SBOITE : Endif            # 08.06 37275
Endif

# Effacer les lignes de fantômes traversés (pour 1er niveau) (09/01/02) 12130
If [M:DIA]AVATST = 1
  Trbegin [BMR]
  Delete [BMR] Where BMRUID = adxuid(1) & PHAFLG=2 & RETQTY > AVAQTY
  If fstat=1  # au lieu de If fstat     21/05/03
        Rollback
  Else
        Commit
  Endif
Endif


Close Local File [BMR]
Return

$EXEC
If [M:DIA]PRNFLG = 2  : Gosub EDITION : Endif
##   si Edition = non : effacer les BMR !??
Return

$APRES_MODIF
Return

$SORTIE
Raz [M:DIA]
Return

# Traitement Premier niveau
#############################

# Issue 85197 - 2018-05-22 by STLIG : Pass % scrap to every level (1 + % / 100) ..
Subprog TRAITPREM(ITM,OK,SCA)
Value    Char    ITM
Variable Integer OK
Value Decimal SCA

Local Decimal LQTN, LQTNA, LQTB, LQTBA
Local Decimal QTDIS : # qté disponible
Local Decimal SQTY : # pour sauvegarder les qtés aux noeuds de l'arborescence
Local Integer ITV_OK
Local Integer MANQ_DEJA # pour ne pas fausser une qté sous un fantome (07/02/03)
Local Char    ERR_TRA(132)
Local Integer CRE
Local Integer LSCATIA       # Issue 104942 - 2015-01-06 by CCC

Local Decimal LSCA  # Issue 85197 - 2018-05-22 by STLIG : Convert % scrap parameter (SCA) to % to use in LIKQTY.

Read [ITF]ITF0=ITM;[M:DIA]STOFCY
#LSCATIA = ([F:ITF]RELSCATIA=2) : # GH 14/09/2015 bug 109434
LSCATIA = (!fstat & [F:ITF]RELSCATIA=2)

# Issue 85980 GA 11/2012 ignore also CPNTYP=7
#&                           BOMSTRDAT <= [M:DIA]DATREF &
#&                          (BOMENDDAT >= [M:DIA]DATREF | BOMENDDAT = [0/0/0]) &
#&                           !find(CPNTYP,4,5,6) # (04.00 sous-produit)

Local File BOMD [BOD] Where ITMREF     = ITM    &
&                           BOMALT     = [M:DIA]BOMALT    &
&                           BOMALTTYP  = [M:DIA]BOMALTTYP &
&                           (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= [M:DIA]DATREF)) &
&                           (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= [M:DIA]DATREF)) &
&                           CPNTYP<4

For [BOD]

  SQTY = GQTY
  Raz MANQ_DEJA  # (07/02/03)
  Read [ITM]ITM0 = [F:BOD]CPNITMREF
  # Point d'entrée pour permettre de ne pas prendre en compte les matières en élaboration -
  # 37368 mm 03.07
  GPE = 0
  If find("SUBBMR",GENTSTD(1..GNBENTREE))
      GPOINT = "CHECK_ITMSTA" : Gosub ENTREE From EXEFNC
  Endif
  If GPE : Goto NXTPREM : Endif

  Read [BOH]BOH0 = ITM;[M:DIA]BOMALT;[M:DIA]BOMALTTYP # relu car récursivité possible
  # Point d'entrée pour permettre de ne pas prendre en compte les nomenclatures en élaboration -
  # 37368 mm 03.07
  GPE = 0
  If find("SUBBMR",GENTSTD(1..GNBENTREE))
      GPOINT = "CHECK_BOHSTA" : Gosub ENTREE From EXEFNC
  Endif
  If GPE : Break : Endif

  If [F:BOD]LIKQTY <> 0 & GQTY <> 0

    # Issue 85197 - 2018-05-22 by STLIG : If second+ level and "Fixed" component then
    #                                     combine % scrap parameter (SCA) with this component's % scrap and convert to %
    #                                     otherwise merely use this component's % scrap ..
    If (SCA > 1 & [F:BOD]LIKQTYCOD = 2)
      LSCA = SCA * (1 + [F:BOD]SCA / 100)
      LSCA = (LSCA - 1) * 100
    Else
      LSCA = [F:BOD]SCA
    Endif
    Call LIKQTY(GQTY,[F:ITM]STU,[F:BOH]BASQTY,[F:BOD]LIKQTYCOD,
&         [F:BOD]LIKQTY,[F:BOD]QTYRND,LSCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
#      Call LIKQTY(GQTY,[F:ITM]STU,[F:BOH]BASQTY,[F:BOD]LIKQTYCOD,
#&            [F:BOD]LIKQTY,[F:BOD]QTYRND,[F:BOD]SCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB

# Issue 104942 - 2015-01-05 by CCC : type of quantity has to be chosen according to [ITF]RELSCATIA
#      If dim(GSCAMAJ)>0 & GSCAMAJ = 1 GQTY = LQTNA Else GQTY = LQTBA Endif # Issue 88918
      If LSCATIA
          GQTY = LQTBA
      Else
          GQTY = LQTNA
      Endif

  Else
    GQTY = 0
  Endif

  # (ré)écriture de la table de travail
  Call DEBTRANS From GLOCK
  Trbegin [BMR]

  #---------
  # 08.06 37159 PE lecture sur clé spécifique
  # PE si GPE = 1
  GPE = 0
  GPOINT = "BMRUSRKEY"
  Gosub  ENTREE From EXEFNC
  #---------

  If !GPE : Read [BMR]BMR0 = adxuid(1);[F:BOD]CPNITMREF;1 : Endif

  If !fstat
      If [F:BMR]SHTQTY > 0 MANQ_DEJA=1 Endif  #  bug 17273 (07/02/03)
# 06.05 30724
#      [F:BMR]RETQTY += GQTY
      If ([F:BOH]BOMALTTYP = 1 & [F:ITM]SAUSTUCOE > 0)
          [F:BMR]RETQTY += GQTY / [F:ITM]SAUSTUCOE
      Else
          [F:BMR]RETQTY += GQTY
      Endif
      If [F:BMR]RETQTY >= [F:BMR]AVAQTY
         [F:BMR]SHTQTY = [F:BMR]RETQTY - [F:BMR]AVAQTY : # qté manquante màj
         Gosub DELAI
      Endif
      # 40295 mm 03.07
      [F:BMR]ITMCMP =  "*"
      [F:BMR]USESTA =  0
      #
      CRE=0
      Rewrite [BMR]
  Else
      Call LECITV2([M:DIA]STOFCY,[F:BOD]CPNITMREF,ITV_OK) From MFGLIB
      # GA 08/2007 FQ 42632 stock dispo au lieu d'afficher le stock total
      # Call STODISTOT("[F:ITV]",7,7,"",QTDIS) From STKLIB
      # GA 12/2007 FQ 44655 selon règle de gestion "Sortie OF"
      # Call STODISTOT("[F:ITV]",7,1,"",QTDIS) From STKLIB
      #Gosub  CALC_QTDIS : # GH 14/09/2015 bug 109434
      If ITV_OK=0 : Gosub  CALC_QTDIS : Else QTDIS=0 : Endif
      Raz [F:BMR]
      [F:BMR]STOFCY = [M:DIA]STOFCY
      [F:BMR]DATREF = [M:DIA]DATREF
      [F:BMR]BMRUID = adxuid(1)
      [F:BMR]NIV    = 1
      [F:BMR]TRTCOD = 1
      [F:BMR]BOMALT = [M:DIA]BOMALT
      [F:BMR]BOMALTTYP = [M:DIA]BOMALTTYP          # FQ 49980 GA 10/2008
      [F:BMR]ITMREF = [F:BOD]CPNITMREF
      [F:BMR]STU    = [F:ITM]STU
      [F:BMR]PURFLG = [F:ITM]PURFLG
      [F:BMR]MFGFLG = [F:ITM]MFGFLG
      [F:BMR]SCPFLG = [F:ITM]SCPFLG
      [F:BMR]SCSFLG = [F:ITM]SCSFLG
      [F:BMR]PHAFLG = [F:ITM]PHAFLG
      [F:BMR]GENFLG = [F:ITM]GENFLG
      [F:BMR]TOOFLG = [F:ITM]TOOFLG
      [F:BMR]DLVFLG = [F:ITM]DLVFLG
      [F:BMR]SALFLG = [F:ITM]SALFLG
      [F:BMR]INTFLG = [F:ITM]INTFLG
      [F:BMR]TCLCOD = [F:ITM]TCLCOD
# 06.05 30724
#      [F:BMR]RETQTY = GQTY
      If [F:BOH]BOMALTTYP = 1
          [F:BMR]RETQTY = GQTY * [F:ITM]SAUSTUCOE
      Else
          [F:BMR]RETQTY = GQTY
      Endif
      # écrire ausi la qté dispo dans la table pour éviter de relire ITV
      [F:BMR]AVAQTY = QTDIS
      If [F:BMR]RETQTY >= QTDIS
          [F:BMR]SHTQTY = [F:BMR]RETQTY - QTDIS : # qté manquante
          Gosub DELAI
      Endif
      # 40295 mm 03.07
      [F:BMR]ITMSTA = [F:ITM]ITMSTA
      [F:BMR]ITMCMP = [F:BOH]ITMREF
      [F:BMR]USESTA = [F:BOH]USESTA
      #
      [F:BMR]CREUSR = GUSER
      [F:BMR]CREDAT = date$

      #---------
      # 08.06 37159 PE lecture sur clé spécifique
      GPOINT = "BMRUSRDATA"
      Gosub  ENTREE From EXEFNC
      #---------
      CRE=1
      Write [BMR]
  Endif
  If fstat
      GOK = 0 : Rollback : Break
  Else
      Commit
      Gosub ANO_ITF
  Endif

  # si c'est un fantôme on descend au(x) niveau(x) plus bas (DM 12130  03/01/02)
  # le test doit être fait une fois la quantité cumulée (si plusieurs cas d'emploi)
  If [F:ITM]PHAFLG = 2 & (([F:BMR]RETQTY > [F:BMR]AVAQTY & [M:DIA]AVATST = 2) | [M:DIA]AVATST = 1)
     # le code Niv reste à 1 !
     If MANQ_DEJA=0  & [M:DIA]AVATST = 2       # Corr Bug 17273 (07/02/03) (que SHT soit > ou < !)
       GQTY = [F:BMR]SHTQTY # partir de la qté manquante
     Endif

     # Issue 85197 - 2018-05-22 by STLIG : Combine % scrap parameter (SCA) with this component's % scrap
     #                                     and pass to next level ..
     SCA = (1 + ([F:BOD]SCA / 100)) * SCA
     Call TRAITPREM([F:BOD]CPNITMREF,OK,SCA)

     If OK = 0 Break Endif
  Endif

  GQTY = SQTY
$NXTPREM
Next

If GOK = 0
  OK = 0  : # TRACER le problème
  ERR_TRA = mess(35,197,1)-[F:BOD]CPNITMREF : # "Composant ..."
  ERR_TRA -= mess(13,100,1)-"BOMRET"
  Call ECR_TRACE(ERR_TRA,1) From GESECRAN
  [M:LEC2]LIGNE([M:LEC2]NBLIG) = ERR_TRA
  [M:LEC2]NBLIG += 1
Endif
End

# Traitement Dernier niveau
#############################

# Issue 85197 - 2018-05-22 by STLIG : Pass % scrap to every level (1 + % / 100) ..
Subprog TRAITDER(ITM,OK,SCA)
Value    Char    ITM
Variable Integer OK
Value Decimal SCA

Local Integer I, ITV_OK
Local Decimal LQTN, LQTNA, LQTB, LQTBA, WPRIX
Local Decimal QTDIS : # qté disponible
Local Decimal SQTY : # pour sauvegarder les qtés aux noeuds de l'arborescence
Local Char    ERR_TRA(132)
Local Integer WLLCTYP
Local Integer CRE
Local Integer LSCATIA       # Issue 104942 - 2015-01-06 by CCC

Local Decimal LSCA  # Issue 85197 - 2018-05-22 by STLIG : Convert % scrap parameter (SCA) to % to use in LIKQTY.

Read [ITF]ITF0=ITM;[M:DIA]STOFCY
#LSCATIA = ([F:ITF]RELSCATIA=2) : # GH 14/09/2015 bug 109434
LSCATIA = (!fstat & [F:ITF]RELSCATIA=2)

# Issue 85980 GA 11/2012 ignore also CPNTYP=7
#&                           BOMSTRDAT <= [M:DIA]DATREF &
#&                          (BOMENDDAT >= [M:DIA]DATREF | BOMENDDAT = [0/0/0]) &
#&                           !find(CPNTYP,4,5,6) # (04.00 sous-produit)

Local File BOMD [BOD] Where ITMREF    = ITM &
&                           BOMALT    = [M:DIA]BOMALT &
&                           BOMALTTYP = [M:DIA]BOMALTTYP &
&                           (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= [M:DIA]DATREF)) &
&                           (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= [M:DIA]DATREF)) &
&                           CPNTYP<4

For [BOD]
    I += 1
    If I = 1 GNIV += 1 Endif : # augmenter le niveau qu'au premier composant
    SQTY = GQTY

    Read [ITM]ITM0 = [F:BOD]CPNITMREF
    # Point d'entrée pour permettre de ne pas prendre en compte les matières en élaboration -
    # 37368 mm 03.07
    GPE = 0
    If find("SUBBMR",GENTSTD(1..GNBENTREE))
        GPOINT = "CHECK_ITMSTA" : Gosub ENTREE From EXEFNC
    Endif
    If GPE : Goto NXTDER : Endif

    Read [BOH]BOH0 = [F:BOD]ITMREF;[F:BOD]BOMALT;[F:BOD]BOMALTTYP
    # Point d'entrée pour permettre de ne pas prendre en compte les nomenclatures en élaboration -
    # 37368 mm 03.07
    GPE = 0
    If find("SUBBMR",GENTSTD(1..GNBENTREE))
        GPOINT = "CHECK_BOHSTA" : Gosub ENTREE From EXEFNC
    Endif
    If GPE : Break : Endif

    If [F:BOD]LIKQTY <> 0 & GQTY <> 0

      # Issue 85197 - 2018-05-22 by STLIG : If second+ level and "Fixed" component then
      #                                     combine % scrap parameter (SCA) with this component's % scrap and convert to %
      #                                     otherwise merely use this component's % scrap ..
      If (SCA > 1 & [F:BOD]LIKQTYCOD = 2)
        LSCA = SCA * (1 + [F:BOD]SCA / 100)
        LSCA = (LSCA - 1) * 100
      Else
        LSCA = [F:BOD]SCA
      Endif
      Call LIKQTY(GQTY,[F:ITM]STU,[F:BOH]BASQTY,[F:BOD]LIKQTYCOD,
&           [F:BOD]LIKQTY,[F:BOD]QTYRND,LSCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
#        Call LIKQTY(GQTY,[F:ITM]STU,[F:BOH]BASQTY,[F:BOD]LIKQTYCOD,
#&            [F:BOD]LIKQTY,[F:BOD]QTYRND,[F:BOD]SCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
# Issue 104942 - 2015-01-05 by CCC : type of quantity has to be chosen according to [ITF]RELSCATIA
#        If dim(GSCAMAJ)>0 & GSCAMAJ = 1 GQTY = LQTNA Else GQTY = LQTBA Endif # Issue 88918
        If LSCATIA
            GQTY = LQTBA
        Else
            GQTY = LQTNA
        Endif
    Else
        GQTY = 0
    Endif
##  Infbox ([F:BOD]CPNITMREF-num$(GQTY)-"Niv"-num$(GNIV)) : # POUR TESTS
    WLLCTYP = func LLCLIB.LLCTYP([F:BOD]BOMALTTYP)
    Read [ITB]ITB0 = [F:BOD]CPNITMREF;[F:BOD]BOMALT;WLLCTYP
    If [F:ITB]BOMEXIFLG = 2

        # Issue 85197 - 2018-05-22 by STLIG : Combine % scrap parameter (SCA) with this component's % scrap
        #                                     and pass to next level ..
        SCA = (1 + ([F:BOD]SCA / 100)) * SCA
        Call TRAITDER([F:BOD]CPNITMREF,OK,SCA)

        If OK = 0 : Break : Endif
    Else
        Gosub ECR_BMR
    Endif
    GQTY = SQTY
$NXTDER
Next
If I > 0
    GNIV -=  1
Else
    # "Aucun lien de nomenclature valide " (indicatif, non bloquant)
    ERR_TRA = ITM -":"-mess(140,197,1)
    Call ECR_TRACE(ERR_TRA,0) From GESECRAN
    [M:LEC2]LIGNE([M:LEC2]NBLIG) = ERR_TRA
    [M:LEC2]NBLIG += 1
Endif
End

$HEAD
# enregistrement d'entête (composés sélectionnés) pour l'édition (NIV=0)
Raz [BMR]
[F:BMR]STOFCY = [M:DIA]STOFCY
[F:BMR]DATREF = [M:DIA]DATREF
[F:BMR]BOMALT = [M:DIA]BOMALT
[F:BMR]BOMALTTYP = [M:DIA]BOMALTTYP               # FQ 49980 GA 10/2008
[F:BMR]ITMREF = [M:DIA]ITMREF(nolign-1)
[F:BMR]RETQTY = [M:DIA]CLCQTY(nolign-1)
[F:BMR]STU    = [M:DIA]STU(nolign-1)
[F:BMR]TRTCOD = [M:DIA]TRT
[F:BMR]CREUSR = GUSER
[F:BMR]CREDAT = date$
[F:BMR]BMRUID = adxuid(1)
Write [BMR]
If fstat
    OK=0
    ERR_TRA = mess(34,197,1)-[M:DIA]ITMREF(nolign-1) : # "Composé ..."
    ERR_TRA -= mess(13,100,1)-"BOMRET"
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
    [M:LEC2]LIGNE([M:LEC2]NBLIG) = ERR_TRA
    [M:LEC2]NBLIG += 1
Endif
Return

$ECR_BMR
Call DEBTRANS From GLOCK

Trbegin [BMR]
#---------
# Issue 119035 GH 23/02/2017 - This entry point was missing for last level calculation mode
GPE = 0
GPOINT = "BMRUSRKEY"
Gosub  ENTREE From EXEFNC
#---------

If !GPE : Read [BMR]BMR0(2) = adxuid(1);[F:BOD]CPNITMREF : Endif : # indépendamment du niveau!

If !fstat
# 06.05 30724
#      [F:BMR]RETQTY += GQTY
      If [F:BOH]BOMALTTYP = 1
          [F:BMR]RETQTY += GQTY * [F:ITM]SAUSTUCOE
      Else
          [F:BMR]RETQTY += GQTY
      Endif
      [F:BMR]FLG     = "*"
      If [F:BMR]RETQTY >= [F:BMR]AVAQTY
         [F:BMR]SHTQTY = [F:BMR]RETQTY - [F:BMR]AVAQTY : # qté manquante  màj
         Gosub DELAI
      Endif
      If GNIV > [F:BMR]NIV
        [F:BMR]NIV = GNIV     : # le plus bas niveau où est trouvé ce cpn
      Endif
      # 40295 mm 03.07
      [F:BMR]ITMCMP =  "*"
      [F:BMR]USESTA =  0
      #
      CRE=0
      Rewrite [BMR]            : # chgt de clé POSSIBLE !!
Else
      Call LECITV2([M:DIA]STOFCY,[F:BOD]CPNITMREF,ITV_OK) From MFGLIB
      # GA 08/2007 FQ 42632 stock dispo au lieu d'afficher le stock total
      # Call STODISTOT("[F:ITV]",7,7,"",QTDIS) From STKLIB
      # GA 12/2007 FQ 44655 selon règle de gestion "Sortie OF"
      # Call STODISTOT("[F:ITV]",7,1,"",QTDIS) From STKLIB
      #Gosub  CALC_QTDIS : # GH 14/09/2015 bug 109434
      If ITV_OK=0 : Gosub  CALC_QTDIS : Else QTDIS=0 : Endif
      Raz [F:BMR]
      [F:BMR]STOFCY = [M:DIA]STOFCY
      [F:BMR]DATREF = [M:DIA]DATREF
      [F:BMR]BMRUID = adxuid(1)
      [F:BMR]NIV    = GNIV
      [F:BMR]TRTCOD = 2
      [F:BMR]BOMALT = [M:DIA]BOMALT
      [F:BMR]BOMALTTYP = [M:DIA]BOMALTTYP               # FQ 49980 GA 10/2008
      [F:BMR]ITMREF = [F:BOD]CPNITMREF
      [F:BMR]STU    = [F:ITM]STU
      [F:BMR]PURFLG = [F:ITM]PURFLG
      [F:BMR]MFGFLG = [F:ITM]MFGFLG
      [F:BMR]SCPFLG = [F:ITM]SCPFLG
      [F:BMR]SCSFLG = [F:ITM]SCSFLG
      [F:BMR]PHAFLG = [F:ITM]PHAFLG
      [F:BMR]GENFLG = [F:ITM]GENFLG
      [F:BMR]TOOFLG = [F:ITM]TOOFLG
      [F:BMR]DLVFLG = [F:ITM]DLVFLG
      [F:BMR]SALFLG = [F:ITM]SALFLG
      [F:BMR]INTFLG = [F:ITM]INTFLG
      [F:BMR]TCLCOD = [F:ITM]TCLCOD
# 06.05 30724
#      [F:BMR]RETQTY = GQTY
      If [F:BOH]BOMALTTYP = 1
          [F:BMR]RETQTY = GQTY * [F:ITM]SAUSTUCOE
      Else
          [F:BMR]RETQTY = GQTY
      Endif
#     écrire aussi la qté dispo dans la table pour éviter de relire ITV
      [F:BMR]AVAQTY = QTDIS
      If [F:BMR]RETQTY >= QTDIS
         [F:BMR]SHTQTY = [F:BMR]RETQTY - QTDIS : # qté manquante
         Gosub DELAI
      Endif
      # 40295 mm 03.07
      [F:BMR]ITMSTA = [F:ITM]ITMSTA
      [F:BMR]ITMCMP = [F:BOH]ITMREF
      [F:BMR]USESTA = [F:BOH]USESTA
      #
      [F:BMR]CREUSR = GUSER
      [F:BMR]CREDAT = date$

      #---------
      # 08.06 37159 PE lecture sur clé spécifique
      GPOINT = "BMRUSRDATA"
      Gosub  ENTREE From EXEFNC
      #---------
      CRE=1
      Write [BMR]
Endif
If fstat
   OK=0
   Rollback
   ERR_TRA = mess(35,197,1)-[F:BOD]CPNITMREF : # "Composant ..."
   ERR_TRA -= mess(13,100,1)-"BOMRET"
   Call ECR_TRACE(ERR_TRA,1) From GESECRAN
   [M:LEC2]LIGNE([M:LEC2]NBLIG) = ERR_TRA
   [M:LEC2]NBLIG += 1
Else
   Commit
   Gosub ANO_ITF
Endif
Return

$ECR_BMRMUL
Call DEBTRANS From GLOCK
Trbegin [BMR]

#---------
# 08.06 37159 PE lecture sur clé spécifique
# PE si GPE = 1
GPE = 0
GPOINT = "BMRUSRKEY"
Gosub  ENTREE From EXEFNC
#---------

If !GPE : Read [BMR]BMR0 = adxuid(1);[F:BOD]CPNITMREF;GNIV : Endif

If !fstat

# 06.05 30724
#      [F:BMR]RETQTY += GQTY
      If [F:BOH]BOMALTTYP = 1
          [F:BMR]RETQTY += GQTY * [F:ITM]SAUSTUCOE
      Else
          [F:BMR]RETQTY += GQTY
      Endif
      If [F:BMR]RETQTY >= [F:BMR]AVAQTY
         [F:BMR]SHTQTY = [F:BMR]RETQTY - [F:BMR]AVAQTY : # qté manquante  màj
         Gosub DELAI
      Endif
      # 40295 mm 03.07
      [F:BMR]ITMCMP =  "*"
      [F:BMR]USESTA =  0
      #
      CRE=0
      Rewrite [BMR]
Else
      Call LECITV2([M:DIA]STOFCY,[F:BOD]CPNITMREF,ITV_OK) From MFGLIB
      # GA 08/2007 FQ 42632 stock dispo au lieu d'afficher le stock total
      # Call STODISTOT("[F:ITV]",7,7,"",QTDIS) From STKLIB
      # GA 12/2007 FQ 44655 selon règle de gestion "Sortie OF"
      # Call STODISTOT("[F:ITV]",7,1,"",QTDIS) From STKLIB
      #Gosub  CALC_QTDIS : # GH 14/09/2015 bug 109434
      If ITV_OK=0 : Gosub  CALC_QTDIS : Else QTDIS=0 : Endif
      Raz [F:BMR]
      [F:BMR]STOFCY = [M:DIA]STOFCY
      [F:BMR]DATREF = [M:DIA]DATREF
      [F:BMR]BMRUID = adxuid(1)
      [F:BMR]NIV    = GNIV
      [F:BMR]IMULT  = GORD     : # ordre de parcours
      [F:BMR]TRTCOD = 3
      [F:BMR]BOMALT = [M:DIA]BOMALT
      [F:BMR]BOMALTTYP = [M:DIA]BOMALTTYP               # FQ 49980 GA 10/2008
      [F:BMR]ITMREF = [F:BOD]CPNITMREF
      [F:BMR]STU    = [F:ITM]STU
      [F:BMR]PURFLG = [F:ITM]PURFLG
      [F:BMR]MFGFLG = [F:ITM]MFGFLG
      [F:BMR]SCPFLG = [F:ITM]SCPFLG
      [F:BMR]SCSFLG = [F:ITM]SCSFLG
      [F:BMR]PHAFLG = [F:ITM]PHAFLG
      [F:BMR]GENFLG = [F:ITM]GENFLG
      [F:BMR]TOOFLG = [F:ITM]TOOFLG
      [F:BMR]DLVFLG = [F:ITM]DLVFLG
      [F:BMR]SALFLG = [F:ITM]SALFLG
      [F:BMR]INTFLG = [F:ITM]INTFLG
      [F:BMR]TCLCOD = [F:ITM]TCLCOD
# 06.05 30724
#      [F:BMR]RETQTY = GQTY
      If [F:BOH]BOMALTTYP = 1
          [F:BMR]RETQTY = GQTY * [F:ITM]SAUSTUCOE
      Else
          [F:BMR]RETQTY = GQTY
      Endif
 #     écrire aussi la qté dispo dans la table pour éviter de relire ITV
      [F:BMR]AVAQTY = QTDIS
      If [F:BMR]RETQTY >= QTDIS
           [F:BMR]SHTQTY = [F:BMR]RETQTY - QTDIS : # qté manquante
           Gosub DELAI
      Endif
      # 40295 mm 03.07
      [F:BMR]ITMSTA = [F:ITM]ITMSTA
      [F:BMR]ITMCMP = [F:BOH]ITMREF
      [F:BMR]USESTA = [F:BOH]USESTA
      #
      [F:BMR]CREUSR = GUSER
      [F:BMR]CREDAT = date$
      #---------
      # Issue 119035 GH 23/02/2017 - This entry point was missing for multi-level calculation mode
      GPOINT = "BMRUSRDATA"
      Gosub  ENTREE From EXEFNC
      #---------
      CRE=1
      Write [BMR]
Endif
If fstat
   OK=0
   Rollback
   ERR_TRA = mess(35,197,1)-[F:BOD]CPNITMREF : # "Composant ..."
   ERR_TRA -= mess(13,100,1)-"BOMRET"
   Call ECR_TRACE(ERR_TRA,1) From GESECRAN
   [M:LEC2]LIGNE([M:LEC2]NBLIG) = ERR_TRA
   [M:LEC2]NBLIG += 1
Else
   Commit
   Gosub ANO_ITF
Endif
Return

$ANO_ITF
If CRE
   Look [ITF]ITF0 = [F:BMR]ITMREF;[F:BMR]STOFCY
   If fstat
      ERR_TRA=[F:BMR]ITMREF-[F:BMR]STOFCY-":"-mess(139,197,1)
      If !find(ERR_TRA,[M:LEC2]LIGNE(0..[M:LEC2]NBLIG-1))
        #Call ECR_TRACE(ERR_TRA,1) From GESECRAN
        [M:LEC2]LIGNE([M:LEC2]NBLIG) = ERR_TRA
        [M:LEC2]NBLIG += 1
      Endif
   Endif
Endif
Return

$DELAI
# rajout du délai    TB  23/03/2000
# art ni fabriqué,ni fabriqué/acheté ni fantôme : délai OFS si non nul
If [F:BMR]LTI = 0
    Read [ITF]ITF0 = [F:BMR]ITMREF;[F:BMR]STOFCY
    If !fstat
      # FQ 44871 pb si OFS est nul sur [F:ITM] mais pas sur [F:ITF]
      # If [F:BMR]MFGFLG <> 2 & [F:BMR]PHAFLG <> 2 & [F:ITM]OFS <> 0
      #    [F:BMR]LTI    = [F:ITF]OFS : # délai d'achat
      If [F:BMR]MFGFLG <> 2 & [F:BMR]PHAFLG <> 2 & ([F:ITF]OFS>0 | [F:ITM]OFS>0)
       If [F:ITF]OFS>0
          [F:BMR]LTI    = [F:ITF]OFS : # délai d'achat (du site)
       Else
          [F:BMR]LTI    = [F:ITM]OFS : # délai d'achat (général)
       Endif
       [F:BMR]LTIUOM = 1 # jours calendaires
      Else
       [F:BMR]LTI    = [F:ITF]MFGLTI :# délai de fabrication
       [F:BMR]LTIUOM = 2 # jours ouvrés
      Endif
      #Si LTI est tjrs vide on prend le max des 3 (?) !! unité ?
      If [F:BMR]LTI = 0 [F:BMR]LTI = max([F:ITF]MFGLTI,[F:ITF]OFS,[F:ITM]OFS) Endif
    Endif
Endif
Return

# Traitement Multi niveau
#############################

# Issue 85197 - 2018-05-22 by STLIG : Pass % scrap to every level (1 + % / 100) ..
Subprog TRAITMUL(ITM,OK,SCA)
Value    Char    ITM
Variable Integer OK
Value Decimal SCA

Local Integer I, ITV_OK
Local Decimal LQTN, LQTNA, LQTB, LQTBA, WPRIX
Local Decimal QTDIS : # qté disponible
Local Decimal SQTY : # pour sauvegarder les qtés aux noeuds de l'arborescence
Local Char    ERR_TRA(132)
Local Integer WLLCTYP
Local Integer CRE
Local Integer LSCATIA       # Issue 104942 - 2015-01-06 by CCC

Local Decimal LSCA  # Issue 85197 - 2018-05-22 by STLIG : Convert % scrap parameter (SCA) to % to use in LIKQTY.

Read [ITF]ITF0=ITM;[M:DIA]STOFCY
#LSCATIA = ([F:ITF]RELSCATIA=2) : # GH 14/09/2015 bug 109434
LSCATIA = (!fstat & [F:ITF]RELSCATIA=2)

# Issue 85980 GA 11/2012 ignore also CPNTYP=7
#&                           BOMSTRDAT <= [M:DIA]DATREF &
#&                          (BOMENDDAT >= [M:DIA]DATREF | BOMENDDAT = [0/0/0]) &
#&                           !find(CPNTYP,4,5,6) # (04.00 sous-produit)

Local File BOMD [BOD] Where ITMREF    = ITM &
&                           BOMALT    = [M:DIA]BOMALT &
&                           BOMALTTYP = [M:DIA]BOMALTTYP &
&                           (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= [M:DIA]DATREF)) &
&                           (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= [M:DIA]DATREF)) &
&                           CPNTYP<4

For [BOD]
    I += 1
    If I = 1 GNIV += 1 Endif
    GORD += 1
    SQTY = GQTY

    Read [ITM]ITM0 = [F:BOD]CPNITMREF
    # Point d'entrée pour permettre de ne pas prendre en compte les matières en élaboration -
    # 37368 mm 03.07
    GPE = 0
    If find("SUBBMR",GENTSTD(1..GNBENTREE))
        GPOINT = "CHECK_ITMSTA" : Gosub ENTREE From EXEFNC
    Endif
    If GPE : Goto NXTMUL : Endif

    Read [BOH]BOH0 = [F:BOD]ITMREF;[F:BOD]BOMALT;[F:BOD]BOMALTTYP
    # Point d'entrée pour permettre de ne pas prendre en compte les nomenclatures en élaboration -
    # 37368 mm 03.07
    GPE = 0
    If find("SUBBMR",GENTSTD(1..GNBENTREE))
        GPOINT = "CHECK_BOHSTA" : Gosub ENTREE From EXEFNC
    Endif
    If GPE : Break : Endif

    If [F:BOD]LIKQTY <> 0 & GQTY <> 0

      # Issue 85197 - 2018-05-22 by STLIG : If second+ level and "Fixed" component then
      #                                     combine % scrap parameter (SCA) with this component's % scrap and convert to %
      #                                     otherwise merely use this component's % scrap ..
      If (SCA > 1 & [F:BOD]LIKQTYCOD = 2)
        LSCA = SCA * (1 + [F:BOD]SCA / 100)
        LSCA = (LSCA - 1) * 100
      Else
        LSCA = [F:BOD]SCA
      Endif
      Call LIKQTY(GQTY,[F:ITM]STU,[F:BOH]BASQTY,[F:BOD]LIKQTYCOD,
&           [F:BOD]LIKQTY,[F:BOD]QTYRND,LSCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
#      Call LIKQTY(GQTY,[F:ITM]STU,[F:BOH]BASQTY,[F:BOD]LIKQTYCOD,
#&           [F:BOD]LIKQTY,[F:BOD]QTYRND,[F:BOD]SCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
# Issue 104942 - 2015-01-05 by CCC : type of quantity has to be chosen according to [ITF]RELSCATIA
#        If dim(GSCAMAJ)>0 & GSCAMAJ = 1 GQTY = LQTNA Else GQTY = LQTBA Endif # Issue 88918
        If LSCATIA
            GQTY = LQTBA
        Else
            GQTY = LQTNA
        Endif
    Else
        GQTY = 0
    Endif
    If [M:DIA]TRT = 3
      Gosub ECR_BMRMUL
    Else
      Gosub ECR_BMR  # multi niveau cumulé : 1 enreg /article
    Endif
    If OK = 0 : Break : Endif
    WLLCTYP = func LLCLIB.LLCTYP([F:BOD]BOMALTTYP)
    Read [ITB]ITB0 = [F:BOD]CPNITMREF;[F:BOD]BOMALT;WLLCTYP
    # on descend la nomenclature que s'il y a du manquant

    If [F:ITB]BOMEXIFLG = 2 & ([F:BMR]RETQTY > [F:BMR]AVAQTY | [M:DIA]AVATST=1)
       If [M:DIA]AVATST = 2    # que si l'on teste le stock intermédiaire !
         If [F:BMR]SHTQTY < GQTY # Corr Bug 17273 (07/02/03)
           GQTY = [F:BMR]SHTQTY  # affecter la Qté avec le manquant (12130) 03/01/02
         Endif
       Endif

       # Issue 85197 - 2018-05-22 by STLIG : Combine % scrap parameter (SCA) with this component's % scrap
       #                                     and pass to next level ..
       SCA = (1 + ([F:BOD]SCA / 100)) * SCA
       Call TRAITMUL([F:BOD]CPNITMREF,OK,SCA)

       If OK = 0 : Break : Endif
    Endif
    GQTY = SQTY
$NXTMUL
Next
If I > 0
    GNIV -=  1
Else
    # "Aucun lien de nomenclature valide " (indicatif, non bloquant)
    ERR_TRA = ITM -":"-mess(140,197,1)     # comme pour dernier niv (09/01/02)
    Call ECR_TRACE(ERR_TRA,0) From GESECRAN
    [M:LEC2]LIGNE([M:LEC2]NBLIG) = ERR_TRA
    [M:LEC2]NBLIG += 1
Endif
End


$TIT
# titre pour la fenêtre principale (étiquette appelée depuis WGFBOMRET)
Case [M:DIA]TRT
  When 1
      TIT = mess(170,195,1)-"-"-mess(106,198,1) : # premier niveau
  When 2
      TIT = mess(170,195,1)-"-"-mess(107,198,1) : # Dernier niveau
  When 3
      TIT = mess(170,195,1)-"-"-mess(108,198,1) : # Multi niveau
  When 4
      TIT = mess(170,195,1)-"-"-mess(4,256,1)   : # Multi niveau cumulé
Endcase
Return

# pour GSAISIE
$OUVRE
# 40728 mm 04.07
Local    Char     RESOL(10)
Local    Integer  TYL
Local    Char     TITANO(GLONDES)
Return

$DEBUT
# charger différemment selon le type de traitement (ordre...)
If clalev([F:BMR])=0
 Case [M:DIA]TRT
  When 1
   Local File BOMRET [BMR] Where CREUSR=GUSER & BMRUID=adxuid(1) & NIV > 0
  When 2, 3, 4
   Local File BOMRET [BMR] Where CREUSR=GUSER & BMRUID=adxuid(1) & NIV > 0
&                          Order By NIV;ITMREF
 Endcase
Endif
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif

# 40728 mm 04.07
Call PARAM("","ECRRESOL",RESOL) From ADOVAL
Case RESOL
 When "1"     : TYL = 100 : # Basse résolution
 When Default : TYL = 115 : # Nombre de caractères dans une ligne en haute résolution
Endcase
[M:LEC2]FORMAT = "K:"+num$(TYL)+"X"
#

# chargement des écrans :
[M:BRH] = [M:DIA]

Raz [M:LECF]

# Issue X3-36381
#For nolign=1 To [M:LEC2]NBLIG
#  [M:LECF] = [M:LEC2]
#Next
Transmask [M:LEC2] To [M:LECF]

Raz [M:BMR1]
nolign = 0
For [BMR]
  # test de la capacité du tableau (bug 7561)  17/01/01
  If nolign = dim([M:BMR1]ITMREF)
     GMESSAGE = mess(26,100,1)    # "tableau plein"
     GERR = 2
     Break
  Endif

  nolign += 1
  [M:BMR1] = [F:BMR]
  If [M:BMR1]LTI(nolign-1)=0 [M:BMR1]LTIUOM(nolign-1) = 0 Endif
Next

[M:BMR1]NBLIG = nolign

Close Local File [BMR]

Affzo [BRH] : Diszo [BRH]
If [M:DIA]TRT > 2
  If [M:DIA]SRTCOD = 1
    Sorta [M:BMR1]NBLIG [M:BMR1]NBLIG Order By [M:BMR1]ITMREF(indice)
  Else
    Sorta [M:BMR1]NBLIG [M:BMR1]NBLIG Order By [M:BMR1]NIV(indice), [M:BMR1]ITMREF(indice)
  Endif
Endif
Affzo [BMR1]
Affzo [LECF]
If [M:LECF]NBLIG>0 : # GH 14/09/2015 bug 109434
   I = find("LECF",ABMSK(1,NBMASK))
   If I
       If clalev([F:AWI])=0 : Local File AWINDOW [AWI] : Endif
       If [F:AWI]WIN<>GBOITE
          Read [AWI]AWI0 = GBOITE
       Else
          fstat=0
       Endif
       If !fstat
          Call TEXTE([F:AWI]INTMSK(I-1),TITANO) From OBJDIV
          Chgtfd [M:LECF] TITANO-"("+num$([M:LECF]NBLIG)+")"
       Endif
   Endif
Endif
Return

$EDITION
Local Char TBPAR(10)(1..50), TBVAL(30)(1..50)
Call ETAT("BOMRET",GFONCTION,TBPAR,TBVAL) From ETAT
Return

########################################
# Calcul de la qté disponible
# FQ 44655 GA 12/2007
########################################
$CALC_QTDIS
Local Integer WTYPLOC : WTYPLOC = 5

  # Lecture de la règle de gestion
  If [F:BOH]BOMALTTYP=1 : # Nomenclature commerciale   TRSTYP=4 Livraison client
     Call LECSRU([M:DIA]STOFCY,[F:ITM]TCLCOD,4,"","",WRET) From STKLIB
  Elsif [F:BOH]BOMALTTYP=2 : # Nomenclature production TRSTYP=6 Sortie OF
     Call LECSRU([M:DIA]STOFCY,[F:ITM]TCLCOD,6,"","",WRET) From STKLIB
  Endif
  If WSTA=0 : WSTA=7 : Endif
  Raz WA,WQ,WR # Issue 102216 - 2014-11-12 by ALSHE
  # Statuts autorisés par la règle de gestion
  If find([F:SRU]AUZSTA,1,3,5,7) WA=1  Endif
  If find([F:SRU]AUZSTA,2,3,6,7) WQ=1  Endif
  If find([F:SRU]AUZSTA,4,5,6,7) WR=1  Endif
  WSTA = WA+2*WQ+4*WR
  # FQ 59443 ne pas tenir compte des emplacements Clients (stock en prêt)
  #Call STODISTOT("[F:ITV]",7,WSTA,"",QTDIS) From STKLIB
  Call STODISTOT("[F:ITV]",WTYPLOC,WSTA,"",QTDIS) From STKLIB
Return

########################################
# Zones de l'écran de sélection        #
########################################

########################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M:DIA]ITMREF) From OBJDIV
If mkstat > 0 End Endif
Read [BOH]BOH0 = VALEUR;[M:DIA]BOMALT;[M:DIA]BOMALTTYP
If fstat
    mkstat = 2
    GMESSAGE = mess(95,193,1) : # "Nomenclature inexistante"
    End
Elsif [M:DIA]DATREF <> [0/0/0] & [F:BOH]BOHSTRDAT > [M:DIA]DATREF
&     | ([F:BOH]BOHENDDAT <> [0/0/0] & [F:BOH]BOHENDDAT < [M:DIA]DATREF)
    mkstat = 2
    GMESSAGE = mess(54,199,1) : # "La nomenclature n'est pas valide à la date indiquée"
    End
Endif
If [F:ITM]ITMREF <> VALEUR
  Read [ITM]ITM0 = VALEUR
Endif
[M:DIA]STU(nolign-1) = [F:ITM]STU
Affzo STU(nolign-1)
End

########################################
Subprog D_CLCQTY(VALEUR)
Variable Decimal VALEUR
# Initialiser par la qté économique
Raz [F:ITF]
Read [ITF]ITF0 = [M:DIA]ITMREF(nolign-1);[M:DIA]STOFCY
If [F:ITF]REOMINQTY <> 0
   VALEUR = [F:ITF]REOMINQTY
Else
   VALEUR = [F:ITF]MFGLOTQTY
Endif
End

########################################
Subprog AM_TRT(VALEUR)
Variable Integer VALEUR
If VALEUR = 2  # dernier niv >> test stock dispo
  [M:DIA]AVATST=2 : Grizo AVATST
Else
  Actzo AVATST
Endif
End

########################################
Subprog AS_SRTCOD(VALEUR)
Variable Integer VALEUR
If [M]TRT < 3
  VALEUR = 1
  mkstat = 2
Endif
End

########################################
Subprog AS_TRT(VALEUR)
Variable Integer VALEUR
GMENLOC(5)=1
End


######################################################################################
Subprog C_BOMALTTYP(VALEUR)
Variable Integer VALEUR

# FQ 52225 ne pas planter si BOMALT n'est pas encore renseigné
If [M:DIA]BOMALT=0 End Endif

Read [TBO]TBO0 = VALEUR;[M:DIA]BOMALT
If fstat
   GMESSAGE = mess(95,193,1)
   mkstat = 2
   End
Endif
#  "Pas d'autorisation de consultation sur cette alternative"
Read [ACC]CODACC = GUSER;[F:TBO]ACSCOD
If !fstat & [F:ACC]CONSUL = 1
   mkstat=2 : GMESSAGE = mess(296,199,1) : End
Endif
If [F:TBO]FCY <> "" & [F:TBO]FCY <> [M:DIA]STOFCY
    mkstat = 2
    GMESSAGE = mess(48,193,1) :# "Alternative non valide sur ce site"
Endif
End

######################################################################################
Subprog AM_BOMALTTYP(VALEUR)
Variable Integer VALEUR

# GA 02/2009 filtrer correctement les listes de valeurs BOMALT
[M]OPTIONA=string$(VALEUR=1,"A")+string$(VALEUR=2,"B")+string$(VALEUR=3,"D")
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran BOMRET1) 23/03/2007 15:31:22 (MM)
######################################################################################
Subprog AV_FLG(VALEUR)
Variable Char    VALEUR()
If [M:BMR1]USESTA(nolign-1)= 1
    pcolor = GCOUL(1)
Else
    pcolor = GCOUL(0)
Endif
End


######################################################################################
## Issue 83625 24/07/2012 (GA)
######################################################################################
Subprog C_BOMALT(VALEUR)
Variable Decimal VALEUR
Read [TBO]TBO0=[M:DIA]BOMALTTYP;VALEUR
If !fstat
  #  "Pas d'autorisation de consultation sur cette alternative"
  Read [ACC]CODACC = GUSER;[F:TBO]ACSCOD
  If !fstat & [F:ACC]CONSUL = 1
     mkstat=2 : GMESSAGE = mess(296,199,1) : End
  Endif
  If [F:TBO]FCY <> "" & [F:TBO]FCY <> [M:DIA]STOFCY
     mkstat=2 : GMESSAGE = mess(48,193,1) : End
  Endif
Endif
End


