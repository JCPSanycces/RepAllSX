#<AdxTL>@(#)0.0.0.0 $Revision$Class Additional fields
# Supervisor
## CRUD-CLASSE ## EMPLOIDUKI
# 2018-11-06 07:05:57 939


############################################################################################
### Subprog _AUPDATE
############################################################################################
Subprog _AUPDATE(EMPLOIDUKI,ASTATUS)
Variable Instance EMPLOIDUKI Using C_EMPLOIDUKI
Variable Integer ASTATUS

If EMPLOIDUKI = null : End : Endif

Gosub _AVARIABLES From WMC00EMPLOIDUKI

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AUPDATE_EMPLOIDUKI

End

#-----------------------------------------------------#

############################################################################################
### Subprog AUPDATE
############################################################################################
Subprog AUPDATE(EMPLOIDUKI,ASTATUS)
Variable Instance EMPLOIDUKI Using C_EMPLOIDUKI
Variable Integer ASTATUS

If EMPLOIDUKI = null : End : Endif

Gosub AVARIABLES From WMC00EMPLOIDUKI
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
EMPLOIDUKI.ASTALIN = [V]CST_AUPD
Gosub AUPDATE_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

If !adxlog
 Gosub AUPDATE_TR_EMPLOIDUKI
Else
 Gosub AUPDATE_EMPLOIDUKI
Endif
If [L]ASTATUS>=[V]CST_AERROR : Goto AUPDATE_END : Endif

Gosub _AUPDATE_AFTER
[L]A_I = EMPLOIDUKI.freeSnapshot
EMPLOIDUKI.snapshotEnabled = 1
$AUPDATE_END
End


$AUPDATE_CONTROL
Gosub _AUPDATE_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOIDUKI._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOIDUKI._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet EMPLOIDUKI._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AUPDATE_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_BEFORE
If EMPLOIDUKI.ASTALIN = [V]CST_ANEWDEL : Return : Endif
EMPLOIDUKI.ASTALIN = [V]CST_AUPD
If [V]CST_ASTALIN(EMPLOIDUKI.ASTALIN)<>""
 [L]A_ASTALIN = EMPLOIDUKI.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_BEFORE"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif

Return

#-----------------------------------------------------#
$_AUPDATE_CONTROL_AFTER

If [V]CST_ASTALIN(EMPLOIDUKI.ASTALIN)<>""
 [L]A_ASTALIN = EMPLOIDUKI.ASTALIN
 [L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_CONTROL_AFTER"))
 If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Endif
Return

#-----------------------------------------------------#
$AUPDATE_TR_EMPLOIDUKI
Trbegin [F:IDUKI]
 Gosub AUPDATE_EMPLOIDUKI
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AUPDATE_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AUPDATE_EMPLOIDUKI
[L]A_ASTALIN = EMPLOIDUKI.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00EMPLOIDUKI._MAJSQL_EMPLOIDUKI(EMPLOIDUKI))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif


[L]A_ASTALIN = EMPLOIDUKI.ASTALIN
[L]ASTATUS = max([L]ASTATUS,fmet EMPLOIDUKI.ACTION([V]CST_ASTALIN([L]A_ASTALIN)+"_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AUPDATE_ABORT
Rollback
$_AUPDATE_ABORT
If EMPLOIDUKI.snapshotEnabled=1
 [L]A_RETIK = EMPLOIDUKI.revertUpdTick
Endif

[L]ASTATUS = max(fmet EMPLOIDUKI.ACTION("AUPDATE_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AUPDATE_AFTER
If find(EMPLOIDUKI.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 EMPLOIDUKI.ASTALIN = [V]CST_ALL
Endif
Return



