# Contenu DIRECTORIES LIBS
# - DIR_GETCONTENT  Subprog Directory browser
# - DIR_TAR         Subprog Directory tar
#
#
# Contenu PATH LIBS
# - FILEPATH_PARSE  Subprog
# - DIR_CONCAT      Funprog
# - PATH_CHECK      Funprog
# - DIRSEP          Funprog
# - DIRBADSEP       Funprog
# - STR_REPLACE     Funprog

############################################################################
# DIRECTORIES LIBS
############################################################################
# --------------------------------------------------------------------------
# Directory browser
# ASTATUS error/found/notfound
# --------------------------------------------------------------------------
Subprog DIR_GETCONTENT (ADIRPATH, ANBFILES, ANBDIRS, AFILENAME, AFILEMODIF, AFILESIZE, ADIRNAME, ASTATUS)
    Value     Char    ADIRPATH()
    Variable  Integer ANBFILES
    Variable  Integer ANBDIRS
    Variable  Char    AFILENAME()()
    Variable  Char    AFILEMODIF()
    Variable  Integer AFILESIZE()
    Variable  Char    ADIRNAME()()
    Variable  Char    ASTATUS()
    Local Char    WFILENAME(100)(dim(AFILENAME))

    Local Integer BEGINENDSEP
    Case GOS(1)
     When "dos"   : BEGINENDSEP=0
     When Default : BEGINENDSEP=1
    Endcase

    If filinfo(ADIRPATH,7)<0
        ASTATUS="notfound"
        End
    Else
        ASTATUS="found"
    Endif
    Local Shortint NB
    Call LISFIC(GOS(1),"",ADIRPATH,NB,WFILENAME) From SELFICREP

    ANBFILES=NB
    Local Integer I
    Char TPATH(255)

    For I=0 To ANBFILES-1
        TPATH=func DIR_CONCAT(ADIRPATH, WFILENAME(I), BEGINENDSEP)
         If(I>0 or filinfo(TPATH,0)>0)
              AFILENAME(I)=WFILENAME(I)
              AFILEMODIF(I)=num$(filinfo(TPATH,9))
              If(filinfo(TPATH,7)>0)
                  AFILESIZE(I)= filinfo(TPATH,7)
              Else
                  AFILESIZE(I)=-1
              Endif
        Endif
    Next I
    Call LISREP(GOS(1),"",ADIRPATH,NB,ADIRNAME) From SELFICREP
    ANBDIRS=NB
End
# --------------------------------------------------------------------------
# ADIRPATH : Directory location to tar and directory result location
# AUPDATE: 0:Update tar file if exist, 1:Do not update tar file, if exist create new
# ASTATUS  :
# --------------------------------------------------------------------------
Subprog DIR_TAR(ADIRPATH,AUPDATE, ASTATUS)
    Value Char ADIRPATH,AUPDATE
    Variable Char ASTATUS

    Local  Char DIRSEP (1)
    DIRSEP = func DIRSEP()
    Local Char WREPCMD(250), WFILLOC(250), WFILCMD(250), WFILEXCL(250), WFILTARREL(250),WFILETRACE(250),WFILETRACENAME(50)
    Local Integer WPOS
    Local Char WTARCMD(250)

    Local Char OPT,ORDRE(250)
    Local Integer STAT
    Local Integer AOKDEL

    # Create file command
    WFILLOC= filpath("tmp","","","")
    WFILCMD =WFILLOC+DIRSEP+"AYTTAR"+num$(adxuid(1))+"_"+num$(time)+".CMD"
    WFILEXCL =WFILLOC+DIRSEP+"AYTTAREXCLUDE"+num$(adxuid(1))+"_"+num$(time)


    Local Char WPARENTARRAY(255)(0..300)
    Local Char WPARENTPATH(255)
    Local Char WNAME(255)
    Local Char WERROR(255)
    Call FILEPATH_PARSE (ADIRPATH,WPARENTARRAY ,WPARENTPATH, WNAME, WERROR) From AFILESYS
    WFILTARREL=ADIRPATH+DIRSEP +WNAME+".tar"

    If GOS(1)<>"dos"
        Openo WFILEXCL ,0 Using [EXC_]
        Iomode adxifs "" Using [EXC_]
        Iomode adxirs chr$(10) Using [EXC_]
        Iomode adxium GASCII Using [EXC_]
        WSTR=WNAME+".tar"  : Wrseq WSTR Using [EXC_]
        Openo Using [EXC_]
    Endif

    WFILETRACENAME=WNAME+".info"
    WFILETRAC=ADIRPATH+DIRSEP+WFILETRACENAME
    If filinfo(WFILETRAC,7)<0
       Openo WFILETRAC,0 Using [TRA_]
    Else
       Openio WFILETRAC,0 Using [TRA_]
       Seek Last Using [TRA_]
    Endif
    Iomode adxifs "" Using [TRA_]
    Iomode adxirs chr$(10) Using [TRA_]
    Iomode adxium GASCII Using [TRA_]
    WSTR=WNAME+".tar"  +" " +GINSTID + " " + func APRODUCT.AGETRELEASESUP() + " " +GUSER + " " +date$ + " "+ time$: Wrseq WSTR Using [TRA_]
    Openo Using [TRA_]

    Openo WFILCMD,0 Using [CMD_]
    Iomode adxifs "" Using [CMD_]
    Iomode adxirs chr$(10) Using [CMD_]
    Iomode adxium GASCII Using [CMD_]

    If(AUPDATE<>"0")
        If (filinfo(WFILTARREL,7)>=0 )
            Call FILE_DELETE(WFILTARREL,AOKDEL)
        Endif
    Else
        If (filinfo(WFILTARREL,7)<0 ) AUPDATE="1" : Endif
    Endif

    If GOS(1)="dos"
        If(AUPDATE="0")  WTARCMD="7za.exe u -y "
        Else             WTARCMD="7za.exe a -y "
        Endif
        WSTR='cd "'+ADIRPATH+'"'                                          : Wrseq WSTR Using [CMD_]
        WSTR=WTARCMD +'"'+WNAME+'.tar"'+' -x!"'+WNAME+'.tar " -r'         : Wrseq WSTR Using [CMD_]
    Else
        WSTR="cd "+ADIRPATH                                               : Wrseq WSTR Using [CMD_]
        If(AUPDATE="0")
            WTARCMD="tar -uvf "
        Else
            WTARCMD="tar -cvf "
        Endif

        WSTR=WTARCMD + WNAME+".tar -X " +WFILEXCL+" ."                     : Wrseq WSTR Using [CMD_]
    Endif
    Openo Using [CMD_]
    ORDRE=WFILCMD : OPT="f"
    Call SYSTEME("",ORDRE,OPT,STAT) From ORDSYS


    Call FILE_DELETE(WFILCMD , AOKDEL)
    Call FILE_DELETE(WFILETRAC, AOKDEL)

    If GOS(1)<>"dos"
        Call FILE_DELETE(WFILEXCL, AOKDEL)
    Endif
End
# --------------------------------------------------------------------------
# ATARPATH : Tar file location to untar
# AREPLACE : (unused)
# ASTATUS  :
# --------------------------------------------------------------------------
Subprog FILE_UNTAR(ATARPATH,ADESTPATH,AREPLACE, ASTATUS)
    Value Char ATARPATH,AREPLACE,ADESTPATH
    Variable Char ASTATUS

    Local  Char DIRSEP (1)
    DIRSEP = func DIRSEP()
    Local Char WREPCMD(250), WFILLOC(250), WFILCMD(250)
    Local Integer WPOS

    Local Char OPT,ORDRE(250)
    Local Integer STAT

    # Create file command
    WFILLOC= filpath("tmp","","","")
    WFILCMD =WFILLOC+DIRSEP+"AYTUNTAR"+num$(adxuid(1))+"_"+num$(time)+".CMD"

    Local Char WPARENTARRAY(255)(0..300)
    Local Char WPARENTPATH(255)
    Local Char WNAME(255)
    Local Char WERROR(255)


    Openo WFILCMD,0 Using [CMD_]
    Iomode adxifs "" Using [CMD_]
    Iomode adxirs chr$(10) Using [CMD_]
    Iomode adxium GASCII Using [CMD_]
    If GOS(1)="dos"
        WSTR='cd "'+ADESTPATH+'"'                         : Wrseq WSTR Using [CMD_]
        WSTR='7za.exe x -y "'+ATARPATH +'"'            : Wrseq WSTR Using [CMD_]
    Else
        WSTR="cd "+ADESTPATH                              : Wrseq WSTR Using [CMD_]
        WSTR="tar -xvf "+ ATARPATH                        : Wrseq WSTR Using [CMD_]
    Endif
    Openo Using [CMD_]
    ORDRE=WFILCMD : OPT="f"
    Call SYSTEME("",ORDRE,OPT,STAT) From ORDSYS

    Local Integer AOKDEL
    Call FILE_DELETE(WFILCMD , AOKDEL)
End
############################################################################
# FILES LIBS
############################################################################
# --------------------------------------------------------------------------
# FILEPATH_DELETE
#  AFILEPATH    : Filepath with / or \ as path separator depending  GOS(1)
#  AOK          : 0 error 1:OK
# --------------------------------------------------------------------------
Subprog FILE_DELETE(AFILEPATH, AOK)
    Value Char AFILEPATH()
    Variable Integer AOK
    Local Char ORDRE(250),OPT
    Local Integer STAT
    If GOS(1)="dos"
       ORDRE="del "+ '"'+ AFILEPATH+'"'
    Else
        ORDRE="ae_rm "+ '"'+AFILEPATH+'"'
    Endif
    Call SYSTEME("",ORDRE,OPT,STAT) From ORDSYS
    If filinfo(AFILEPATH,7)<0 : AOK=1  : Else  AOK=0 : Endif
End
############################################################################
# PATH LIBS
############################################################################
# --------------------------------------------------------------------------
# FILEPATH_PARSE
#  APATH        : Filepath with / or \ as path separator
#  PARENTARRAY  : Array that contains parent file path parts
#  PARENTPATH   : Parent file path as string - X/Y/ or empty
#  NAME         : File name
#  ERROR        : ERROR message - "" if no error
# --------------------------------------------------------------------------
Subprog FILEPATH_PARSE (APATH, PARENTARRAY , PARENTPATH, NAME, ERROR)
    Value     Char    APATH()
    Variable  Char    PARENTARRAY ()()
    Variable  Char    PARENTPATH()
    Variable  Char    NAME()
    Variable  Char    ERROR()
    Local  Char DIRSEP (1)
    DIRSEP = func DIRSEP()
    Local Integer I,L
    Raz PARENTARRAY ,PARENTPATH , NAME, ERROR
    #tokenize file path
    Char TMP(50),C
    Local Integer J
    L=len(APATH)
    J=0
     For I=0 To L+1
        C=mid$(APATH,I,1)
        If C="/" or C="\" or I=L
          If I=L TMP+=C Endif
            If TMP<>""
                PARENTARRAY(J)=TMP
                J+=1
                TMP=""
            Endif
        Else
            TMP+=C
        Endif
    Next I
    #Calculate parent directory and file name
    Local Char NAME(255), PARENTPATH(255)
    If J=0
        ERROR = "Empty file path"
        End
    Elsif J=1
        PARENTPATH=""
        NAME=PARENTARRAY(0)
        PARENTARRAY(0)=""
    Else
        NAME=PARENTARRAY(J-1)
        PARENTARRAY(J-1)=""
        PARENTPATH =""
        L=J-2
        For I=0 To L
            PARENTPATH = PARENTPATH + DIRSEP + PARENTARRAY(I)
        Next I
    Endif
    If NAME=""
        ERROR="Filename is mandatory"
        End
    Endif
End
# --------------------------------------------------------------------------
# Return APATH1=a/b ou /a/b/ - APATH2= c/d ou /c/d - return APATH1 + APATH2
# OPT : begin/end separator - 0  a/b/c/d/ - 1  /a/b/c/d - 2 /a/b/c/d/
# --------------------------------------------------------------------------
Funprog DIR_CONCAT (APATH1,APATH2,OPT)
    Value     Char    APATH1()
    Value     Char    APATH2()
    Value     Integer OPT
    Local  Char     RESULT(255)
    Local  Char     DIRSEP (1)
    DIRSEP = func DIRSEP()
    Local Char  LASTSEP,FISRTSTEP
    APATH1=func PATH_CHECK(APATH1)
    If len (APATH1)>0
        LASTSEP=mid$ (APATH1,len(APATH1),1)
        If LASTSEP=DIRSEP
            APATH1=mid$(APATH1,1,len (APATH1)-1)
        Endif
        FISRTSTEP=mid$ (APATH1,1,1)
        If FISRTSTEP=DIRSEP
            APATH1=mid$(APATH1,2,len (APATH1)-1)
        Endif
    Endif
    APATH2=func PATH_CHECK(APATH2)
    If len (APATH2)>0
        LASTSEP=mid$ (APATH2,len(APATH2),1)
        If LASTSEP=DIRSEP
            APATH2=mid$(APATH2,1,len (APATH2)-1)
        Endif
        FISRTSTEP=mid$ (APATH2,1,1)
        If FISRTSTEP=DIRSEP
            APATH2=mid$(APATH2,2,len (APATH2)-1)
        Endif
    Endif
    If len (APATH1)=0 and len (APATH2)=0
        RESULT=""
    Elsif len (APATH1)=0
        RESULT=APATH2
    Elsif len (APATH2)=0
        RESULT=APATH1
    Else
        RESULT=APATH1+DIRSEP+APATH2
    Endif
    If len(RESULT)>0
        If OPT=0
            RESULT=RESULT+DIRSEP
        Elsif OPT=1
            RESULT=DIRSEP+RESULT
        Elsif OPT=2
            RESULT=DIRSEP+RESULT+DIRSEP
        #else no start/end separator
        Endif
    Endif
End RESULT
# --------------------------------------------------------------------------
Funprog STR_REPLACE(ASTR, AFINDSTR, ABYSTR)
    Value     Char    ASTR()
    Value     Char    AFINDSTR()
    Value     Char    ABYSTR()

    Local Char RESULT(255)
    Local Integer LF
    LF=len(AFINDSTR)
    If LF>0
        Local Integer POS
        POS=instr(1 ,ASTR, AFINDSTR)
        While  POS<>0
            RESULT+=left$(ASTR,POS-1)+ABYSTR
            POS+=LF
            ASTR=right$(ASTR,POS)
            POS=instr(1,ASTR, AFINDSTR)
        Wend
    Endif

    RESULT+=ASTR
End RESULT
# --------------------------------------------------------------------------
Funprog PATH_CHECK(APATH)
    Value     Char    APATH()
    Local     Char    RESULT(255)
    RESULT=func STR_REPLACE(vireblc(APATH,2),func DIRBADSEP(),func  DIRSEP())
End RESULT
# --------------------------------------------------------------------------
Funprog DIRSEP()
    Local Char   SEP(1)
    Case GOS(1)
     When "dos"   : SEP="\"
     When Default : SEP="/"
    Endcase
End SEP
# --------------------------------------------------------------------------
Funprog DIRBADSEP()
    Local Char   BADSEP(1)
    Case GOS(1)
     When "dos"   : BADSEP="/"
     When Default : BADSEP="\"
    Endcase
End BADSEP

