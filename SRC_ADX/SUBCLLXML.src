#<AdxTL>@(#)8.0.0.0 $Revision$
###############################################################################################################
#
#   Génération XML d'un Appel                                                              Version 140
#   Module CRM                             
#
#   XXXINXML    : Objet unique avec ses tables liées en multi-niveaux.
#   XXXLISTXML  : Liste filtrée de la table objet.
#   
###############################################################################################################
###############################################################################################################
Subprog CLLINXML(SZRECNUM, IGENERICFILENAME, SZXSLSHEET, SZPECONTEXT, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZRECNUM
Value Integer IGENERICFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF

  ICHAPTER = 0
  IERRINF = 0
  SZFULLRETFILE = ""
  SZRETFILENAME = ""
  If SZRECNUM = "" Then
    End
  Endif
  Gosub XMLPART1 From CRMXML140
  Call TEXTE(13606, SZHTMLTITLE) From OBJDIV      #Appel
  SZSUBPROG = "CLLINXML"
  SZAOBABREV = "CLL"
  Gosub XMLPART2 From CRMXML140
  If IERRINF Then
    End
  Endif
  Gosub DOCOREXML
  Gosub XMLPART3 From CRMXML140
End

#########################################################################################################################
Subprog CLLLISTXML(SZCUSTFILENAME, SZXSLSHEET, SZPECONTEXT, SZFILTER, SZFULLRETFILE, SZRETFILENAME, ICHAPTER, IERRINF)
Value Char SZCUSTFILENAME
Value Char SZXSLSHEET
Value Char SZPECONTEXT
Variable Char SZFILTER
Variable Char SZFULLRETFILE
Variable Char SZRETFILENAME
Variable Integer ICHAPTER
Variable Integer IERRINF

  ICHAPTER = 0
  IERRINF = 0
  SZFULLRETFILE = ""
  SZRETFILENAME = ""
  If SZFILTER = "" Then
    SZFILTER = "1=1"
  Endif
  Gosub XMLPART1 From CRMXML140
  Call TEXTE(14662, SZHTMLTITLE) From OBJDIV      #Appels
  SZSUBPROG = "CLLLISTXML"
  SZAOBABREV = "CLL"
  Gosub XMLPART2B From CRMXML140
  If IERRINF Then
    End
  Endif
  Gosub DOLISTXML
  Gosub XMLPART3 From CRMXML140
End

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOLISTXML
  Gosub SETCLLEXCEPT From CRMEXCEPT
  #On extrait
  Filter [CLL] Where evalue(SZFILTER)
  For [CLL]
    SZCTAOB = "CLL"
    SZCTAOBNUM = [F:CLL]CLLNUM
    SZCTLEVEL = "0"
    SZCTPARENTAOB = ""
    SZCTPARENTNUM = ""
    Gosub XMLCLL From CRMEXCEPT
  Next
  Filter [CLL]
Return

###################################################################
# Activation à la carte du contenu de la génération
###################################################################
$DOCOREXML
  Gosub SETCLLEXCEPT From CRMEXCEPT
  Gosub SETCTTEXCEPT From CRMEXCEPT
  #On extrait
  Filter [CLL] Where [F:CLL]CLLNUM = SZRECNUM
  For [CLL]
    SZCTAOB = "CLL"
    SZCTAOBNUM = [F:CLL]CLLNUM
    SZCTLEVEL = "0"
    SZCTPARENTAOB = ""
    SZCTPARENTNUM = ""
    Gosub XMLCLL From CRMEXCEPT
    Filter [CTT] Where [F:CTT]CLLNUM = SZRECNUM
    For [CTT]
      SZCTAOB = "CTT"
      SZCTAOBNUM = [F:CTT]CTTNUM
      SZCTLEVEL = "1"
      SZCTPARENTAOB = "CLL"
      SZCTPARENTNUM = [F:CLL]CLLNUM
      Gosub XMLCTT From CRMEXCEPT
    Next
    Filter [CTT]
  Next
  Filter [CLL]
Return
