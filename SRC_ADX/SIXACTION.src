#<AdxTL>@(#)3.0.0.0 $Revision$
#############################################################################
#  SIXACTION: pour les actions de bascule Integrale --> X3                  #
#############################################################################


#############################################################################
$ACTION
Case ACTION
 When "SEL_TABLE"     : Gosub SEL_TABLE     
 When "SEL_LISTE"     : Gosub SEL_LISTE 
 When Default
Endcase
Return

#############################################################################
$SEL_TABLE
Return

#############################################################################
$SEL_LISTE
Case LISTE
    When "SELSIXCOR"   : Gosub S_SIXCOR
    When "SELSIXCOR1"  : Gosub S_SIXCOR1
    When "SELSIXCOR2"  : Gosub S_SIXCOR2
Endcase
Return

#############################################################################

# --- Selection des articles port ou frais de intégrale ---------------------
$S_SIXCOR

Local Integer TYP    :    TYP= val(PARAM(1))

Local Integer CPT
Local Char    CRITERE (250) : CRITERE= "1=1" 

If !clalev([F:XART]) : Local File XIART   [XART] : Endif


If TYP=1  CRITERE +=" & NAT='PO'" : TIT=SI_MES(63)
   Else   CRITERE +=" & NAT='FR'" : TIT=SI_MES(64)
Endif  

Filter [XART] Where evalue(CRITERE)

For [XART]
    NBTEX +=1 
    TEX(NBTEX) = [F:XART]CODART
    TEXTE(NBTEX) = TEX(NBTEX)-[F:XART]DGN
Next
Filter[XART]

Return

# --- Selection de la colonne tarif ventes ----------------------------------
$S_SIXCOR1
Local Integer CHOIX       :    CHOIX= val(PARAM(1))
Local Char    LIBPRS (30)
If !clalev([F:PRS]) : Local File PRICSTRUCT [PRS] : Endif
If !clalev([F:AXX]) : Local File ATEXTRA    [AXX] : Endif

Read [F:PRS]PRS0=1;""
If fstat : Return : Endif

For JL=0 To dim([F:PRS]INCDCR)-1
   If [F:PRS]INCDCR(JL)=0 : Break : Endif
   Case CHOIX
     When 1  # -- Rem.art.% positive   
             If [F:PRS]INCDCR(JL)=2 & find([F:PRS]VALTYP(JL),2,3) : Gosub S_SIXCOR1A : Endif
     When 2  # -- Rem.art.% negative  
             If [F:PRS]INCDCR(JL)=1 & find([F:PRS]VALTYP(JL),2,3) : Gosub S_SIXCOR1A : Endif
     When 3  # Rem.art.mnt positive  
             If [F:PRS]INCDCR(JL)=2 & [F:PRS]VALTYP(JL)=1         : Gosub S_SIXCOR1A : Endif
     When 4  # Rem.art.mnt positive 
             If [F:PRS]INCDCR(JL)=1 & [F:PRS]VALTYP(JL)=1         : Gosub S_SIXCOR1A : Endif
     When 5  # Rem.cli.% positive   
             If [F:PRS]INCDCR(JL)=2 & find([F:PRS]VALTYP(JL),2,3) : Gosub S_SIXCOR1A : Endif
     When 6  # Rem.cli.% negative  
             If [F:PRS]INCDCR(JL)=1 & find([F:PRS]VALTYP(JL),2,3) : Gosub S_SIXCOR1A : Endif
   Endcase
Next JL
Return

$S_SIXCOR1A
Raz LIBPRS
Call LECTEXTRA (LIBPRS,"PRICSTRUCT","DESAXX("+num$(JL)+")","1","") From ATEXTRA
NBTEX +=1 
TEX(NBTEX) = num$(JL+1)
TEXTE(NBTEX)=mess(140,111,1)-num$(JL+1)+" = "-LIBPRS
Return


#####################################################
# SELSIXCOR2 : Sélection de la colonne tarif achats #
# ------------------------------------------------- #
# zone courante AZCI : Numéro colonne tarif         #
# PARAM(1) = CHOIX   : Code remise "Intégrale"      # 
#                      1 = % Remise tarif positive  #
#                      2 = % Remise fourn.positive  #
#                      3 = % Remise tarif négative  #
#                      4 = % Remise fourn.négative  #
#####################################################
$S_SIXCOR2
#-----
Local Integer I
#-----
If !clalev([F:PRS])  Local File PRICSTRUCT [PRS] : Endif
If !clalev([F:AXX])  Local File ATEXTRA    [AXX] : Endif
#-----
Read [F:PRS] PRS0=2;"" : If fstat  Raz [F:PRS] : Return : Endif
#-----
For I=0 To dim([F:PRS]INCDCR)-1
  If [F:PRS]INCDCR(I)=0  Break : Endif
  If find([F:PRS]VALTYP(I),2,3) & [F:PRS]CLCRUL(I)=1 & [F:PRS]NPRNOTFLG(I)=2
    Case val(PARAM(1))
      When 1,2 : If [F:PRS]INCDCR(I)=2  Gosub S_SIXCOR2A : Endif
      When 3,4 : If [F:PRS]INCDCR(I)=1  Gosub S_SIXCOR2A : Endif
    Endcase
  Endif
Next I
Return
#-----
$S_SIXCOR2A
NBTEX+=1 
Call LECTEXTRA (TEXTE(NBTEX),"PRICSTRUCT","DESAXX("+num$(I)+")","2","") From ATEXTRA
TEX  (NBTEX)=num$(I+1)
TEXTE(NBTEX)=mess(140,111,1)-num$(I+1)+" = "+TEXTE(NBTEX)
Return


#############################################################################
