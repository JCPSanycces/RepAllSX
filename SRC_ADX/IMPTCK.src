#<AdxTL>@(#)2.0.0.0 $Revision$

$ACTION
 Case ACTION
  When "IMP_OUVRE"     : Gosub IMP_OUVRE
  When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CRE
  When "IMP_VERIF_MOD" : Gosub IMP_VERIF_MOD
 Endcase
Return


$IMP_OUVRE
If clalev([CPY]) = 0 : Local File COMPANY  [CPY] : Endif
If clalev([FCY]) = 0 : Local File FACILITY [FCY] : Endif
If clalev([GCM]) = 0 : Local File GACM     [GCM] : Endif
If clalev([LED]) = 0 : Local File GLED     [LED] : Endif
If clalev([COA]) = 0 : Local File GCOA     [COA] : Endif
If clalev([GAC]) = 0 : Local File GACCOUNT [GAC] : Endif
If clalev([BPR]) = 0 : Local File BPARTNER [BPR] : Endif

Local Integer FLG
Local Char SOCSITE2(GLONCPY)
Return



$IMP_VERIF_CRE
$IMP_VERIF_MOD

OK=1
Gosub CONTROLE
Return



$CONTROLE
#--------- Le champs COA est obligatoire et existant
If [F:TCK]COA=""
 GMESSAGE ="COA"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Else
 Read [COA]COA0=[F:TCK]COA
 If fstat
  GMESSAGE = "COA"-mess(83,123,1)-[F:TCK]COA  # Valeur incorrecte
  OK=0 : Return
 Endif
Endif


#--------- Le champs FCY1 est obligatoire et doit alimentée le COA
If [F:TCK]FCY1=""
 GMESSAGE = "FCY1"-mess(10,123,1) # Zone obligatoire
 OK=0 : Return
Else
 Read [F:FCY]FCY0 = [F:TCK]FCY1
 Read [F:CPY]CPY0 = [F:FCY]LEGCPY
 Read [F:GCM]GCM0 = [F:CPY]ACM
 For I=0 To len(mess(0,2644,1))-1
  Read [LED]LED0 = [F:GCM]LED(I)
  If [F:LED]COA=[F:TCK]COA : FLG+=1 : Endif
 Next
 If !FLG
  GMESSAGE = [F:TCK]FCY1-mess(90,104,1)-[F:TCK]COA   # Site du société n'alimentant pas
  OK=0 : Return
 Endif
Endif

#--------- Le champs FCY2 est obligatoire et le FCY2 doit être dans la même société que le FCY1
If [F:TCK]FCY2=""
 GMESSAGE = "FCY1"-mess(10,123,1)  # Zone obligatoire
 OK=0 : Return
Elsif [F:TCK]FCY1=[F:TCK]FCY2
 GMESSAGE = "FCY1-FCY2"-mess(83,123,1)-[F:TCK]FCY1-[F:TCK]FCY2  # Valeur incorrecte
 OK=0 : Return
Else
 Read [FCY]FCY0 = [F:TCK]FCY2
 If !fstat
  SOCSITE2 = [F:FCY]LEGCPY
  If [F:TCK]FCY1<>""
   Read [FCY]FCY0 = [F:TCK]FCY1
   If (!fstat & [F:FCY]LEGCPY<>SOCSITE2)
    GMESSAGE = [F:TCK]FCY1-mess(30,106,1)-[F:FCY]LEGCPY # Ce site est dans la société
    GMESSAGE = [F:TCK]FCY2-mess(30,106,1)-SOCSITE2      # Ce site est dans la société
    OK=0 : Return
   Endif
  Endif
 Endif
Endif

#--------- Le champs SAC doit existé
If [F:TCK]SAC<>""
 Read [F:GAC]GAC1 = [F:TCK]COA;[F:TCK]SAC
 If fstat or [F:GAC]AUZBPR(5)<>2
  GMESSAGE = "FCY1-FCY2"-mess(51,102,1)-[F:TCK]FCY1-[F:TCK]FCY2  # Collectif incorrecte
  OK=0 : Return
 Endif
 [F:TCK]ACC = [F:GAC]ACC
Endif 

#--------- Le champs ACC doit existé
If [F:TCK]ACC<>""
 Read [F:GAC]GAC0 = [F:TCK]COA;[F:TCK]ACC
 If fstat
  GMESSAGE = "ACC"-mess(44,102,1) # Compte inexistant
  OK=0 : Return
 Else
  Read [F:GAC]GAC0 = [F:TCK]COA;[F:TCK]ACC
  Call VERIF([F:GAC]FCY,[F:TCK]FCY1,[F:TCK]ACC) From CFYSUB
  If GMESSAGE<>""  OK=0 : Return : Endif
  Call VERIF([F:GAC]FCY,[F:TCK]FCY2,[F:TCK]ACC) From CFYSUB
  If GMESSAGE<>""  OK=0 : Return : Endif
 Endif
Endif


#--------- Le champs BPR doit existé
If [F:TCK]SAC<>""
 Read [F:BPR]BPR0 = [F:TCK]BPR
 If fstat
  GMESSAGE = "BPR"-mess(83,123,1)-[F:TCK]BPR  # Valeur incorrecte
  OK=0 : Return
 Endif
Endif
Return



