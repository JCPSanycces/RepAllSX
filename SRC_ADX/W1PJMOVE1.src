#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque PJMOVE1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:05:50"
A_USER  = "DOC"
A_STAMP = "20181109230550"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBLIG"
  If [M]NBLIG=0
   If func PJMOVE.FORMAT("CMT6")<>""
    Chgfmt CMT6 With func PJMOVE.FORMAT("CMT6")
   Else
    Chgfmt CMT6 With "-K:1X"
   Endif
   If func PJMOVE.FORMAT("CMT7")<>""
    Chgfmt CMT7 With func PJMOVE.FORMAT("CMT7")
   Else
    Chgfmt CMT7 With "-K:1X"
   Endif
   If func PJMOVE.FORMAT("CMT8")<>""
    Chgfmt CMT8 With func PJMOVE.FORMAT("CMT8")
   Else
    Chgfmt CMT8 With "-K:1X"
   Endif
   If func PJMOVE.FORMAT("CMT17")<>""
    Chgfmt CMT17 With func PJMOVE.FORMAT("CMT17")
   Else
    Chgfmt CMT17 With "-K:1X"
   Endif
   If func PJMOVE.FORMAT("QTY")<>""
    Chgfmt QTY With func PJMOVE.FORMAT("QTY")
   Else
    Chgfmt QTY With "-K:1X"
   Endif
   If func PJMOVE.FORMAT("UOM")<>""
    Chgfmt UOM With func PJMOVE.FORMAT("UOM")
   Else
    Chgfmt UOM With "-K:1X"
   Endif
   If func PJMOVE.FORMAT("AVADAT")<>""
    Chgfmt AVADAT With func PJMOVE.FORMAT("AVADAT")
   Else
    Chgfmt AVADAT With "-K:1X"
   Endif
   If func PJMOVE.FORMAT("CMT5")<>""
    Chgfmt CMT5 With func PJMOVE.FORMAT("CMT5")
   Else
    Chgfmt CMT5 With "-K:1X"
   Endif
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask PJMOVE1 [POV1]
Gosub HORODAT
Local Inpbox "PJMOVE1" From GFONCTION At A_STAMP With A_WINDPREV Mask [POV1] As [SIM_]
Grizo [POV1]5
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [POV1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=100 : Y1(0)=1 : Y2(0)=20
X1(1)=1 : X2(1)=-2 : Y1(1)=1 : Y2(1)=0
Return

$ON_NBLIG
Onevent BEFORE_INPUT Call AS_NBLIG From W1PJMOVE1
Return

Subprog IB_NBLIG
Local Decimal BASPAG
## Action STD
Call IB_NBLIG From PJMOVE
## Action IBUPJMOPE
Call IBUPJMOPE([M:POV0]OPPNUM,[M:POV1]TASCOD(nolign-1),[M:POV1]OPENUM(nolign-1),[M:POV1]OPESPLNUM(nolign-1),"6") From PJMSELECT
Gosub _AFF
End

Subprog AS_NBLIG
Local Decimal BASPAG
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(41903,GBOUT1) From OBJDIV
Call TEXTE(44444,GBOUT2) From OBJDIV
Call TEXTE(44443,GBOUT3) From OBJDIV
Call TEXTE(43718,GBOUT4) From OBJDIV
Call TEXTE(56454,GBOUT5) From OBJDIV
Call TEXTE(56926,GBOUT6) From OBJDIV
Call TEXTE(55280,GBOUT7) From OBJDIV
Call TEXTE(1001392,GBOUT8) From OBJDIV
Call TEXTE(11543,GBOUT9) From OBJDIV
Call TEXTE(54486,GBOUT10) From OBJDIV
Call TEXTE(19528,GBOUT11) From OBJDIV
Call TEXTE(15505,GBOUT12) From OBJDIV
Call TEXTE(1436,GBOUT13) From OBJDIV
Call TEXTE(5727,GBOUT14) From OBJDIV
Call TEXTE(1002795,GBOUT15) From OBJDIV
Call TEXTE(5562,GBOUT16) From OBJDIV
Call IB_NBLIG
Onkey 129 Titled GBOUT1 Call B1_NBLIG From W1PJMOVE1
Onkey 130 Titled GBOUT2 Call B2_NBLIG From W1PJMOVE1
Onkey 131 Titled GBOUT3 Call B3_NBLIG From W1PJMOVE1
Onkey 132 Titled GBOUT4 Call B4_NBLIG From W1PJMOVE1
Onkey 133 Titled GBOUT5 Call B5_NBLIG From W1PJMOVE1
Onkey 134 Titled GBOUT6 Call B6_NBLIG From W1PJMOVE1
Onkey 135 Titled GBOUT7 Call B7_NBLIG From W1PJMOVE1
Onkey 136 Titled GBOUT8 Call B8_NBLIG From W1PJMOVE1
Onkey 137 Titled GBOUT9 Call B9_NBLIG From W1PJMOVE1
Onkey 138 Titled GBOUT10 Call B10_NBLIG From W1PJMOVE1
Onkey 139 Titled GBOUT11 Call B11_NBLIG From W1PJMOVE1
Onkey 140 Titled GBOUT12 Call B12_NBLIG From W1PJMOVE1
Onkey 170 Titled GBOUT13 Call B13_NBLIG From W1PJMOVE1
Onkey 171 Titled GBOUT14 Call B14_NBLIG From W1PJMOVE1
Onkey 172 Titled GBOUT15 Call B15_NBLIG From W1PJMOVE1
Onkey 173 Titled GBOUT16 Call B16_NBLIG From W1PJMOVE1
Gosub _AFF
End

Subprog B1_NBLIG
Local Decimal BASPAG
If !GWEBSERV
 ## Action PJMEVEN
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "PJMEVEN"
 Local Char ACTION(20), PROGSUB(GLONADC), PROGSPE(GLONADC), PROGSPV(GLONADC)
 ACTION = "AB1_NBLIG" : PROGSUB = "PJMOVE" : PROGSPE = "SPEOVE" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 PARMSK(1) = [M:POV1]CODE(nolign-1)
 PARMSK(2) = [M:POV1]CLE1(nolign-1)
 Call SAISIE_NUM(BASPAG,PARMSK,"OEVEN","SUBPEV","") From GSAISIE
 ACTION = "BB1_NBLIG" : PROGSUB = "PJMOVE" : PROGSPE = "SPEOVE" : PROGSPV = ""
 Gosub ACTSUB From GOBJSUB
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

