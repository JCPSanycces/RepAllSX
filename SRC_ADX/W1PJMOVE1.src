$ON_ICO
Onevent INIT_AREA Call D_ICO(zc) From W1PJMOVE1
Return

Subprog D_ICO(VALEUR)
Variable Char    VALEUR()
If varinit([M]ICO,indice)=0
 VALEUR = "Folder.gif"
Endif
Gosub _AFF
End

