########################################################################
$MOD_ITMREF_TEXTES

# Update xxxxx Where ITMREF = S_ITMSEL(0) With ITMREF = S_MODITM
#If [F:CSC]CMPFLG=2      # Issue 90818 GA 06/2013

  If clalev([F:BOHW]) = 0 : Local File BOM       [BOHW] : Endif
  If clalev([F:BOH])  = 0 : Local File BOM       [BOH]  : Endif

  Filter [F:BOH] Where ITMREF = S_MODITM # & BOMALT=[F:CSC]BOMALT & BOMALT=[F:CSC]BOMALTTYP
  For [F:BOH]
     [F:BOHW] = [F:BOH]
     [F:BOHW]ITMREF =S_ITMSEL(0)
     Gosub DUP_BOH_TEX
  Next
  Filter [F:BOH]
#Endif
#
#If [F:CSC]ROUFLG=2      # Issue 90818 GA 06/2013
  If clalev([F:ROHW]) = 0 : Local File ROUTING    [ROHW] : Endif
  If clalev([F:ROH])  = 0 : Local File ROUTING    [ROH]  : Endif

  Filter [F:ROH] Where ITMREF = S_MODITM # & ROUALT=[F:CSC]ROUALT & FCY=S_FCY
  For [F:ROH]
     [F:ROHW] = [F:ROH]
     [F:ROHW]ITMREF =S_ITMSEL(0)
     Gosub DUP_ROH_TEX
  Next
  Filter [F:ROH]
#Endif
Return

############################################################
# Traitement des enregistrements de la pile jusqu'a [F:CFP]PILREC
# L'appel doit tester GOK en retour
$SKIP_PILE
If [M:CFP]PILPHA([M:CFP]PILSTR) > [M:CFP]PILREC # Issue 90585 GA 06/2013
   Raz [M:CFP]PILSTR
Endif
For [M:CFP]PILIND = [M:CFP]PILSTR To [M:CFP]NBLIG-1
  If [M:CFP]PILPHA([M:CFP]PILIND) > [M:CFP]PILREC
    [M:CFP]PILSTR = [M:CFP]PILIND
    Break
  Endif
Next
Return
############################################################
# extrait de CFGLIBC car trop de lignes
############################################################
$TRT_SYMBOLE
Local Char W_VAR(250)
Onerrgo TRT_SYMB_ERRGO
  W_FOR = [M:CFP]PILCN1([M:CFP]PILIND)
  If W_FOR = "" | num$(evalue(W_FOR)) = "1"
    W_FOR = [M:CFP]PILCN2([M:CFP]PILIND)
    If W_FOR = "" | num$(evalue(W_FOR)) = "1"
      Gosub TRT_SYMBOLE From CFGLIBB
      If W_MSG<>"" Goto TRT_SYMB_ERR Endif
      If [M:CFP]PILTYP([M:CFP]PILIND)>6 | [M:CFP]PILTYP([M:CFP]PILIND)=1
        Call ECR_DEBUG("Phase="+num$([M:CFP]PILPHA([M:CFP]PILIND))
&                     -"Seq="+num$([M:CFP]PILSEQ([M:CFP]PILIND))
&                     -"Symbole:"-[M:CFP]PILSYM([M:CFP]PILIND)-"["-W_VAR-"]"
&                     - mess([M:CFP]PILTYP([M:CFP]PILIND),752,1) )
    # Issue 94492 GA 11/2013 plantage si symbole de type variable et W_VAR=""
      Elsif [M:CFP]PILTYP([M:CFP]PILIND)=2 & dim(W_VAR)>0 & W_VAR<>""
        Call ECR_DEBUG("Phase="+num$([M:CFP]PILPHA([M:CFP]PILIND))
&                     -"Seq="+num$([M:CFP]PILSEQ([M:CFP]PILIND))
&                     -"Variable:"-[M:CFP]PILSYM([M:CFP]PILIND)-"["-W_VAR-"]"
&                     - "=" - num$(evalue(W_VAR)) )
      Endif
    Endif
  Endif
Onerrgo
Return

$TRT_SYMB_ERRGO  # Issue 95655 suite GA 09/2014
If W_MSG=""
   #W_MSG=errmes$([L]ER)+"\"+errm # Issue 105672 GA 02/2015 stack overflow
   W_MSG=errmes$(errn)+"\"+errm
Endif
# Issue 105672 GA 02/2015
# If S_ABORT=0 | [M:CFP]PILCOD([M:CFP]PILIND)<>9
#  Call ECR_TRACE([M:CFP]PILSYM([M:CFP]PILIND)-"Warning:"-W_MSG, -1) # From GESECRAN
#Else
  GOK=0
  Call ECR_TRACE([M:CFP]PILSYM([M:CFP]PILIND)-"Error:"-W_MSG, 1) # From GESECRAN
#Endif
Raz W_MSG
Resume

$TRT_SYMB_ERR # Issue 95655 suite GA 09/2014
# Issue 104935 GA 01/2015
# If S_ABORT=0 | [M:CFP]PILCOD([M:CFP]PILIND)<>9
If !S_ABORT & [M:CFP]PILCOD([M:CFP]PILIND)<>9
  Call ECR_TRACE([M:CFP]PILSYM([M:CFP]PILIND)-"Warning:"-W_MSG, -1) # From GESECRAN
Else
  Call ECR_TRACE([M:CFP]PILSYM([M:CFP]PILIND)-"Error:"-W_MSG, 1) # From GESECRAN
Endif
Raz W_MSG
Return
########################################################################
# Extrait de CFGLIB/SEL_TABLE car source trop long :-(
$SELITF
  Local Char PARAM(250)(1..20) , SAVACT(10)  # Issue 92652 GA 09/2013 before PARAM(50)(1..20)
  PARAM(1) = S_FCY     # Issue 91368 GA 08/2013 LFCY Ko # Issue 81521 before [M]FCY
  PARAM(2) = ""
  PARAM(3) = ""
  PARAM(4) = ""
  PARAM(5) = ""
  PARAM(6) = ""
  If S_FILTER <> ""
    PARAM(7) = S_FILTER                         # Issue 89065 GA 06/2013 avant "S_FILTER" ne fonctionnait pas ???
  Else
    PARAM(7) = ""
  Endif
  PARAM(8) = ""
  SAVACT = GACTION : GACTION = "SELITF"
  If clalev([F:ACT]) = 0 : Local File ACTION [ACT] : Endif
  Read [ACT]ACTION = GACTION
  If !fstat
    Gosub SELTABLIEN                            # Issue 89065 GA 06/2013 ajouté au code initial
    Call S_TAB_CHAR(LVAL,PARAM,GACTION,[F:ACT]CODTRT,[F:ACT]SPETRT) From GACTION  # JPJ cght 140 action SELITF
  Endif
  Close Local File [ACT]
  GACTION = SAVACT
  If LVAL <> ""
    S_SELTBL = 1
  Endif
Return
########################################################################
# Appel depuis CFGLIB/SEL_TABLE car source trop long :-(
$SELITM                                         # Issue 89065 GA 06/2013
  Local Char PARAM(250)(1..20) , SAVACT(10)  # Issue 92652 GA 09/2013 before PARAM(50)(1..20)
  If S_FILTER <> ""
    PARAM(1) = S_FILTER
  Else
    PARAM(1) = ""
  Endif
  SAVACT = GACTION : GACTION = "SELITMF"
  If clalev([F:ACT]) = 0 : Local File ACTION [ACT] : Endif
  Read [ACT]ACTION = GACTION
  If !fstat
    Gosub SELTABLIEN                            # Issue 89065 GA 06/2013
    Call S_TAB_CHAR(LVAL,PARAM,GACTION,[F:ACT]CODTRT,[F:ACT]SPETRT) From GACTION
  Endif
  Close Local File [ACT]
  GACTION = SAVACT
  If LVAL <> ""
    S_SELTBL = 1
  Endif
Return

########################################################################
$SELTABLIEN
# On va lire l'objet dans X3 pour déterminer les tables à ouvrir (tables de l'environnement de l'objet avec
# une expression de lien) pour que le link dans OUVRE_LISTE soit sur des tables de la même base
  If dim(LOBJ)<0 | LOBJ="" | S_DOSSIER="" Return Endif
  Local File =S_DOSSIER+".AOBJTAB"   [AOT]
  For [AOT] Where ABREV=LOBJ
    If [F:AOT]TABABR <> "" & [F:AOT]TABFIC<>"ATEXTRA" & evalue("clalev([F:"+[F:AOT]TABABR+"])")<=0
      #Local File =S_DOSSIER+"."+[F:AOT]TABFIC
      Call ECR_TRACE("Missing table linked to"-LOBJ-[F:AOT]TABFIC-[F:AOT]TABABR,0) # From GESECRAN
    Endif
  Next
Return

########################################################################
# Issue 98703 GA 05/2014 Pour SUBCFH Purge des configurations
########################################################################
$VERF_DELITM
Local Char    CLECUR1(GLONID1) , CLECUR2(GLONID2)(0..1)
Local Integer WOK : WOK=1
#Local Char WTEMPITM(1) : WTEMPITM=left$([F:ITM]ITMREF,1)
#If [F:ITM]ITMREF<>"" & WTEMPITM<>"_" & S_UPDMOD<>2
If instr(1,[F:ITM]ITMREF,"_")<>1 & S_UPDMOD<>2
  [L]CLECUR1=[F:ITM]ITMREF : [L]CLECUR2(0) = "" : [L]CLECUR2(1) = ""

  # Issue 116197 - 2016-09-15 by STLIG : Mesbox of screen VALIDCAR (VLC) could be open e.g. Configuration History Delete,
  #                                      Open VLC in VERIF (pass "ITM") if no Mask [M:VLC]
  #                                      Do not open VLC in VERIF (pass "-ITM") if Mask [M:VLC] is open.
  If (dim([M:VLC]INTNUM)<0)
    Call VERIF(S_DOSSIER,"ITM",CLECUR1,CLECUR2,WOK) From ANUCOD
  Else
    Call VERIF(S_DOSSIER,"-ITM",CLECUR1,CLECUR2,WOK) From ANUCOD
  Endif

  If !WOK GOK=0 Endif
Else
  W_TRAMSG="VERF_DELITM: not necessary, updated product="-S_MODITM
  Gosub TRA_MSG From CFGLIBB
Endif
Return

########################################################################
# Issue 89095 GA 07/2013 Pour SUBCFH Purge des configurations
########################################################################
$DEL_ITM_SUITE
If [F:ITM]ITMREF<>""
  # Issue 84399 GA 10/2013 PE de suppression d'un article
  GPOINT = "DELITM" :  Gosub ENTREE From EXEFNC

  # FQ 50444 GA 11/2008 image & pieces jointes
  Delete [CBB] Where CODBLB="ITM" & IDENT1=[F:ITM]ITMREF
  Delete [AOX] Where ABREV ="ITM" & IDENT1=[F:ITM]ITMREF

  # Issue 107085 GA 03/2015
  If (GFONCTION="FUNCFGPUR" | left$([F:ITM]ITMREF,1)='_' | WNO_DEFAULT_TEXT<2)
    # Issue 89095 GA 06/2013
    Call DEL_AXX_FIC("ITMMASTER","[F:ITM]")
  Endif

  If (GFONCTION="FUNCFGPUR" | left$([F:ITC]ITMREF,1)='_')   # Issue 103969 GA 01/2015
  # Issue 100370 GA 05/2014
    Delete [ITF] Where ITMREF=[F:ITM]ITMREF
    If adxdlrec>0 Call ECR_DEBUG("Delete ITF="-[F:ITM]ITMREF-num$(adxdlrec)) From CFGLIBC1 Endif

   # Issue 103969 GA 01/2015 idem CFGLIBC
    For [ITC] Where ITMREF=[F:ITM]ITMREF
      # Issue 78402 GA 04/2012 suppress only when ITF was deleted
      Read [ITF]ITF1=[F:ITC]STOFCY;[F:ITC]ITMREF
      If !fstat Goto NEXT_ITC Endif

      # Issue 103969 GA 11/2014
      Gosub DEL_ITC_SUITE From CFGLIBC1
      If GOK<0 Break Endif  # Issue 104665

      # Coût
      Readlock [ITC] Curr
      Case fstat
        When 1 :
  GLOCK="$ITMCOST"-[F:ITC]STOFCY+"~"+[F:ITC]ITMREF+"~"+num$([F:ITC]CSTTYP)+"~"+num$([F:ITC]ITCSEQ)
  GOK=-1
          Break
        When 0 :
          Delete [ITC]
          If adxdlrec>0 Call ECR_DEBUG("Delete ITC="-[F:ITM]ITMREF-num$(adxdlrec)) From CFGLIBC1 Endif
         When Default :
          GOK = 0
          Call FSTACTX("ITC",W_TRASTP,"$DEL_ARTICLE") From CFGLIBD  # From GLOCK
          Break
      Endcase
$NEXT_ITC
    Next
  Endif

# Article nomenclature de travail ?
  If clalev([F:CFB])=0  : Local File ITMBOMCFG [CFB] Endif
  Filter [CFB] Where ITMREF = [F:ITM]ITMREF Order By Key ITB0
  For [CFB]
      Readlock [CFB] Curr
      Case fstat
        When 1 :
          GOK = -1
          Break
        When 0 :
          Delete [CFB]
          If fstat
            GOK = 0
            Call FSTA("CFB") From GLOCK
            Break
          Endif
          Call ECR_DEBUG("Delete CFB="-[F:CFB]ITMREF) From CFGLIBC1
        When Default :
          GOK = 0
          Call FSTA("CFB") From GLOCK
          Break
      Endcase
  Next
  Filter [CFB]

# V6 Cas d'emploi ?
  If clalev([F:BOW])=0  : Local File BOMWUS [BOW] Endif
  Filter [BOW] Where ITMREF = [F:ITM]ITMREF  Order By Key BOW0
  For [BOW]
      Readlock [BOW] Curr
      Case fstat
      When 1 :
        GOK = -1
        Break
      When 0 :
          Delete [BOW]
          If fstat
            GOK = 0
            Call FSTA("BOW") From GLOCK
            Break
          Endif
          Call ECR_DEBUG("Delete BOW="-[F:BOW]ITMREF) From CFGLIBC1
        When Default :
          GOK = 0
          Call FSTA("BOW") From GLOCK
          Break
      Endcase
  Next
  Filter [BOW]

# Article nomenclature (supprimé sinon dans DEL_NOMENCL)
  If clalev([F:ITBW])=0  : Local File ITMBOM [ITBW] Endif
#  Filter [ITB] Where ITMREF = [F:ITM]ITMREF or BOHITM=[F:ITM]ITMREF Order By Key ITB0
#  For [ITB]
#    Readlock [ITB] Curr
#    Case fstat
#      When 1 :
#        GOK = -1
#        Break
#      When 0 :
#        Delete [ITB]
#        If fstat
#          GOK = 0
#          Call FSTA("ITB") From GLOCK
#          Break
#        Endif
#        Call ECR_DEBUG("Delete ITB(1)="-[F:ITB]ITMREF) From CFGLIBC1
#      When Default :
#        GOK = 0
#        Call FSTA("ITB") From GLOCK
#        Break
#    Endcase
#  Next
  Filter [ITBW]
  Delete [ITBW] Where ITMREF = [F:ITM]ITMREF
  If adxdlrec>0 Call ECR_DEBUG("Delete ITB(1)="-[F:ITM]ITMREF-num$(adxdlrec)) From CFGLIBC1 Endif
  Delete [ITBW] Where BOHITM=[F:ITM]ITMREF
  If adxdlrec>0 Call ECR_DEBUG("Delete ITB(2)="-[F:ITM]ITMREF-num$(adxdlrec)) From CFGLIBC1 Endif
#
# Article ITMABCWRK ?
  If clalev([F:ITK])=0  : Local File ITMABCWRK [ITK] Endif
  Filter [ITK] Where ITMREF = [F:ITM]ITMREF Order By Key ITK0
  For [ITK]
    Readlock [ITK] Curr
    Case fstat
      When 1 :
        GOK = -1
        Break
      When 0 :
        Delete [ITK]
        If fstat
          GOK = 0
          Call FSTA("ITK") From GLOCK
          Break
        Endif
        Call ECR_DEBUG("Delete ITK="-[F:ITK]ITMREF-[F:ITK]STOFCY) From CFGLIBC1
      When Default :
          GOK = 0
          Call FSTA("ITK") From GLOCK
          Break
    Endcase
  Next
  Filter [ITK]

### Issue 104908 GA 12/2014 cf CFGLIBC/DEL_ARTICLE
#### Article ITMMVTHIS  ?
###  If clalev([F:ITH])=0  : Local File ITMMVTHIS [ITH] Endif
###  Filter [ITH] Where ITMREF = [F:ITM]ITMREF  Order By Key ITH0
###  For [ITH]
###    Readlock [ITH] Curr
###    Case fstat
###      When 1 :
###        GOK = -1
###        Break
###      When 0 :
###        Delete [ITH]
###        If fstat
###          GOK = 0
###          Call FSTA("ITH") From GLOCK
###          Break
###        Endif
###        Call ECR_DEBUG("Delete ITH="-[F:ITH]ITMREF-[F:ITH]STOFCY) From CFGLIBC1
###      When Default :
###        GOK = 0
###        Call FSTA("ITH") From GLOCK
###        Break
###    Endcase
###  Next
###  Filter [ITH]

Endif
Return

########################################################################
# Issue 89095 GA 07/2013 Pour SUBCFH Purge des configurations
########################################################################
$DEL_ITF_SUITE
Local Integer WRET
If [F:ITF]ITMREF<>""
  # FQ 73403 GA 05/2011 STJ eventuel généré par calcul des couts ?
  Delete [STJ] Where STOFCY=[F:ITF]STOFCY & ITMREF=[F:ITF]ITMREF
  # FQ 73403 GA 08/2011 spécial V6: nouvelle table STOJOUVAL SJV, STKMVTITC SMI
  Delete [SJV] Where STOFCY=[F:ITF]STOFCY & ITMREF=[F:ITF]ITMREF
  #Delete [SMI] Where STOFCY=[F:ITF]STOFCY & ITMREF=[F:ITF]ITMREF # see DEL_ITC_SUITE

  # Issue 107085 GA 03/2015
  If (GFONCTION="FUNCFGPUR" | left$([F:ITF]ITMREF,1)='_' | WNO_DEFAULT_TEXT<2)
      # Issue 89095 GA 06/2013
      Call DEL_AXX_FIC("ITMFACILIT","[F:ITF]")
  Endif

# Issue 103969 GA 11/2014 see DEL_ITC_SUITE
# Issue 100370 GA 05/2014 force deletion of those lines when [F:ITF] is deleted
#  Delete [ITC] Where STOFCY=[F:ITF]STOFCY & ITMREF=[F:ITF]ITMREF
#  Delete [ICN] Where STOFCY=[F:ITF]STOFCY & ITMREF=[F:ITF]ITMREF
#  Delete [ICC] Where STOFCY=[F:ITF]STOFCY & ITMREF=[F:ITF]ITMREF
#  Delete [IWC] Where STOFCY=[F:ITF]STOFCY & ITMREF=[F:ITF]ITMREF

  Call LECACT("WRH",WRET) From TRTX3
  If WRET=1 # Article ITMWRH  ?
    If clalev([F:ITW])=0  : Local File ITMWRH [ITW] Endif
    Filter [ITW] Where ITMREF = [F:ITF]ITMREF & STOFCY=[F:ITF]STOFCY Order By Key ITW0
    For [ITW]
      Readlock [ITW] Curr
      Case fstat
        When 1 :
          GOK = -1
          Break
        When 0 :
          Delete [ITW]
          If fstat
            GOK = 0
            Call FSTA("ITW") From GLOCK
            Break
          Endif
          Call ECR_DEBUG("Delete ITW="-[F:ITW]ITMREF-[F:ITW]STOFCY-[F:ITW]WRH) From CFGLIBC1
        When Default :
          GOK = 0
          Call FSTA("ITW") From GLOCK
          Break
      Endcase
    Next
    Filter [ITW]
  Endif
Endif
Return

########################################################################
# Issue 103969 GA 11/2014 code extracted from CFGLIBC
########################################################################
$DEL_ITC_SUITE
Local Integer WRET
#If [F:ITC]ITMREF<>"" & [F:ITC]CSTTYP>0 # Issue 103969 GA 12/2014
If [F:ITC]ITMREF<>"" & [F:ITC]CSTTYP>0 & (GFONCTION="FUNCFGPUR" | !S_AUTCFG | left$([F:ITC]ITMREF,1)='_')
    # Delete des natures FG
    Delete [ICN] Where STOFCY=[F:ITC]STOFCY & ITMREF=[F:ITC]ITMREF & CSTTYP=[F:ITC]CSTTYP
&                    & ITCSEQ=[F:ITC]ITCSEQ & UID = [F:ITC]UID
    If fstat=1  # au lieu de If fstat 21/05/03
          GOK = -1
          Call RSTACTX("ICN",
&       [F:ITC]STOFCY+"~"+[F:ITC]ITMREF+"~"+num$([F:ITC]CSTTYP)+"~"+num$([F:ITC]ITCSEQ),
&           W_TRASTP,"$DEL_ITC_SUITE") From CFGLIBD
        Return # Issue 104665 before: Break 2
    Endif
    # FQ 73403 GA 08/2011 spécial V6: nouvelles tables ITCMAT ICC, ITCWST IWC
    Delete [ICC] Where STOFCY=[F:ITC]STOFCY & ITMREF=[F:ITC]ITMREF & CSTTYP=[F:ITC]CSTTYP
&                    & ITCSEQ=[F:ITC]ITCSEQ
    Delete [IWC] Where STOFCY=[F:ITC]STOFCY & ITMREF=[F:ITC]ITMREF & CSTTYP=[F:ITC]CSTTYP
&                    & ITCSEQ=[F:ITC]ITCSEQ
    # Issue 103969 GA 11/2014
    Delete [SMI] Where STOFCY=[F:ITC]STOFCY & ITMREF=[F:ITC]ITMREF & CSTTYP=[F:ITC]CSTTYP
Else
    Call ECR_DEBUG("DEL_ITC_SUITE: No delete"-[F:ITC]ITMREF-[F:ITC]STOFCY-"Automate="-num$(S_AUTCFG)) From CFGLIBC1
Endif
Return

############################################################
# Ecriture historique configuration
# Issue 96688 GA 03/2014 déplacé depuis CFGLIBC car trop d'instructions
$ECR_HISTORIQUE
# Issue 98480 GA 04/2014 If S_UPDMOD = 2 only when product was updated
If S_UPDMOD = 2 & W_COM=1
  W_J = 0
  For W_I = 0 To dim(W_VARLAB)-1
    W_K =  evalue("dim("+W_VARLAB(W_I)+")")
    If W_K > 0
      Read [F:CQU]CQU0= mid$(W_VARLAB(W_I),3,GLONCQU)
      If fstat = 0
        If [F:CQU]HISFLG = 2
         If W_K = 1
            Raz [F:CFH]
            Case [F:CQU]ASWTYP
              When 1 :
                [F:CFH]VALALP = evalue(W_VARLAB(W_I))
              When 2 :
                [F:CFH]VALNUM = evalue(W_VARLAB(W_I))
              When 3 :
                [F:CFH]VALDAT = evalue(W_VARLAB(W_I))
              When 4 :
                [F:CFH]VALNUM = evalue(W_VARLAB(W_I))
              When 5 :
                [F:CFH]VALALP = evalue(W_VARLAB(W_I))
              When 6 :        # Issue 96688 GA 03/2014 Blob
                Setlob [F:CFH]VALBLB With evalue(W_VARLAB(W_I))
              When 7 :        # Issue 96688 GA 03/2014 Clob
                 # Issue 117679 - 2016-08-23 by STLIG : Record clob from W_VARLAB.
                 Local Char Z_ALP(250)
                 Setlob [F:CFH]VALCLB With evalue(W_VARLAB(W_I))
                 Call CLB_TO_CHAR(Z_ALP,W_VARLAB(W_I)) From CFGLIBD
                 [F:CFH]VALALP = Z_ALP
            Endcase
            Gosub ECR_SYMHIS
          Else
            If [F:CQU]ASWTYP = 1
              For W_L = 0 To W_K -1
                Raz [F:CFH]
                [F:CFH]SYMSEQ = W_L
                [F:CFH]VALALP = evalue(W_VARLAB(W_I)+"("+num$(W_L)+")")
                If [F:CFH]VALALP <> ""
                  Gosub ECR_SYMHIS
                Else
                  Break
                Endif
              Next W_L
            Endif
          Endif
        Endif
      Endif
    Endif
  Next W_I
# Ecriture entete historique
  If W_J <> 0
    [F:CHH]             = [F:CFH]
    [F:CHH]CFGBPRNUM    = S_BPRNUM
    [F:CHH]CFGBPRREF    = S_BPRREF
    [F:CHH]FCY          = S_FCY
    [F:CHH]ITMREF       = S_CURITM
    [F:CHH]BOMALT       = [F:CSC]BOMALT
    [F:CHH]BOMALTTYP    = [F:CSC]BOMALTTYP : # GA 09/2007 pour la V6
    [F:CHH]ROUNUM       = S_CURROU
    [F:CHH]ROUALT       = [F:CSC]ROUALT
    [F:CHH]QTYSTU       = S_ITMQTY
    If S_PURDAT = [0/0/0]
      [F:CHH]CFGDELDAT  = [31/12/2999]
    Else
      [F:CHH]CFGDELDAT  = S_PURDAT
    Endif
    If W_COM = 0
      [F:CHH]ITMCRE = 1
    Else
      [F:CHH]ITMCRE = 2
    Endif
    If W_BOH = 0
      [F:CHH]CPNCRE = 1
    Else
      [F:CHH]CPNCRE = 2
    Endif
    If W_ROH = 0
      [F:CHH]ROUCRE = 1
    Else
      [F:CHH]ROUCRE = 2
    Endif
    GPOINT = "BEFWRICHH"
    Gosub ENTREE From EXEFNC
    Write [CHH]
    If fstat
      Call FSTACTX("CHH",W_TRASTP,"$ECR_HISTORIQUE") From CFGLIBD  # From GLOCK
      GOK = 0
    Endif
  Endif
Endif
Return
############################################################
$ECR_SYMHIS
[F:CFH]CFGVCRNUM    = S_CPTCFG
[F:CFH]SCENUM       = [F:CSC]SCENUM
[F:CFH]SYMNUM       = [F:CQU]QSTNUM
[F:CFH]SYMTYP       = [F:CQU]QSTTYP
[F:CFH]SYMNAT       = [F:CQU]ASWTYP
[F:CFH]SYMORI       = [F:CQU]QSTORI
[F:CFH]EXPNUM       = [C]EXPORT
[F:CFH]CREUSR       = GUSER
[F:CFH]CREDAT       = date$
GPOINT = "BEFWRICFH"
Gosub ENTREE From EXEFNC
Write [CFH]
If fstat
  Call FSTACTX("CFH",W_TRASTP,"$ECR_HIS") From CFGLIBD  # From GLOCK
  GOK = 0
Else
  W_J = 1
Endif
Return
#############################################################
# Issue 103539 GA 10/2014 too many lines in CFGLIBC
#############################################################
$MOD_ITMREF# Une transaction en-cours existe
Local Char WABRFIC(6)
Readlock [ITM]ITM0=S_ITMSEL(0)
If fstat
  WABRFIC="ITM"
  GLOCK="$ITMMASTER"-S_ITMSEL(0): Goto MOD_ITMREF_ERR
Endif
If [F:ITM]CFGVCRNUM = S_CPTCFG
    W_TRAMSG= mess(197,188,1)-S_ITMSEL(0)-"($MOD_ITMREF)"-S_MODITM : Gosub TRA_MSG From CFGLIBB

  # Issue 113260 - 2016-07-11 by STLIG : Use SAVE_ITMREF to communicate temp. product to COPY_AXX_ITM
  Local Char SAVE_ITMREF(GLONITM)
  SAVE_ITMREF = [F:ITM]ITMREF

    [F:ITM]ITMREF = S_MODITM
    # Issue 89191 GA 04/2013
    Gosub PE_BEFREWITM From CFGLIBC
    Rewrite [ITM]
    If fstat
      Call FSTACTX("ITM",W_TRASTP,"$MOD_ITMREF") From CFGLIBD
      GOK = 0 : Goto MOD_ITMREF_FIN
    Endif

  # Issue 113260 - 2016-07-11 by STLIG : Copy Product description translations from SAVE_ITMREF (temp. product) to [F:ITM]ITMREF
  Call COPY_AXX_ITM(SAVE_ITMREF,[F:ITM]ITMREF)

  # Issue 89191 GA 04/2013 scénario ajoutant des lignes ITF
  # Update [ITF] Where ITMREF = S_ITMSEL(0) With ITMREF = S_MODITM
    If clalev([F:ITF1])= 0 : Local File ITMFACILIT     [ITF1]: Endif
    Filter [F:ITF] Where ITMREF = S_ITMSEL(0)
    For [F:ITF]
        Read [F:ITF1]ITF0=S_MODITM;[F:ITF]STOFCY
        If !fstat
           Delete [F:ITF1] Curr
           Call ECR_DEBUG("MOD_ITMREF: row ITF replaced"-S_MODITM-[F:ITF]STOFCY) From CFGLIBC1
        Endif
        [F:ITF]ITMREF = S_MODITM
        [F:ITF]UPDUSR=GUSER
        [F:ITF]UPDDAT=date$
        Gosub PE_BEFREWITF From CFGLIBC
        Rewrite [ITF]
        If fstat Break Endif
        Call ECR_DEBUG("MOD_ITMREF: row ITF updated:"-[F:ITF]ITMREF-[F:ITF]STOFCY) From CFGLIBC1
    Next
    Filter [F:ITF]
    If fstat
        WABRFIC="ITF"
        GLOCK="$ITMFACILIT"-S_ITMSEL(0): Goto MOD_ITMREF_ERR
    Endif

  # Issue 89191 GA 04/2013 scénario ajoutant des lignes ITF/ITV1
  #  Update [ITV1] Where ITMREF = S_ITMSEL(0) With ITMREF = S_MODITM
    If clalev([F:ITV1])= 0 : Local File ITMMVT     [ITV1]: Endif
    Filter [F:ITV] Where ITMREF = S_ITMSEL(0)
    For [F:ITV]
        Read [F:ITV1]ITV0=S_MODITM;[F:ITV]STOFCY
        If !fstat
           Delete [F:ITV1] Curr
           Call ECR_DEBUG("MOD_ITMREF: row ITV replaced"-S_MODITM-[F:ITV]STOFCY) From CFGLIBC1
        Endif
        [F:ITV]ITMREF = S_MODITM
        [F:ITV]UPDUSR=GUSER
        [F:ITV]UPDDAT=date$
        Gosub PE_BEFREWITV From CFGLIBC
        Rewrite [ITV]
        If fstat Break Endif
        Call ECR_DEBUG("MOD_ITMREF: row ITV updated:"-[F:ITV]ITMREF-[F:ITV]STOFCY) From CFGLIBC1
    Next
    Filter [F:ITV]
    If fstat
        WABRFIC="ITV"
        GLOCK="$ITMMVT"-S_ITMSEL(0): Goto MOD_ITMREF_ERR
    Endif

    # Nota Update fonctionne sur tous les enregistrements répondants aux critères
    #        et traite notamment les enreg. cout standard, actualisé et budget

    # FQ 49198 GA 09/2008 pb sur Duplicate Key, il vaut mieux boucler sur les lignes
    If clalev([F:ITC1]) = 0 : Local File ITMCOST     [ITC1]  : Endif
    # index ITC0=STOFCY+ITMREF+CSTTYP-ITCSEQ+UID - modifié en V6
    Filter [ITC] Where ITMREF = S_ITMSEL(0)
    For [ITC]ITC0 # With Lock
        # Ctrl si la clé existe déjà
        Read [ITC1]ITC0=[F:ITC]STOFCY;S_MODITM;[F:ITC]CSTTYP;[F:ITC]ITCSEQ;[F:ITC]UID  # V6
        If !fstat
           Delete [F:ITC1] Curr
           Call ECR_DEBUG("MOD_ITMREF: row ITC replaced"-S_MODITM-[F:ITC]STOFCY) From CFGLIBC1
        Endif
        [F:ITC]ITMREF = S_MODITM
        [F:ITC]UPDUSR=GUSER
        [F:ITC]UPDDAT=date$
        Gosub PE_BEFREWITC From CFGLIBC
        Rewrite [ITC]
        If fstat Break Endif
        Call ECR_DEBUG("MOD_ITMREF: row ITC updated:"-[F:ITC]ITMREF-[F:ITC]STOFCY) From CFGLIBC1
    Next
    Filter [ITC]

# ################ Issue 103969 GA 11/2014 - Start
  If !S_AUTCFG          # Tables ICN, ICC, IWC,SJI
    # ICN0 : STOFCY+ITMREF+CSTTYP-ITCSEQ+OVENAT+UID        Détail natures - Coûts
    If clalev([F:ICN]) = 0 :  Local File ITCNAT     [ICN]   : Endif
    If clalev([F:ICN1]) = 0 : Local File ITCNAT     [ICN1]  : Endif
    For [ICN] Where ITMREF=S_ITMSEL(0)
      # Ctrl si la clé existe déjà
      Read [ICN1]ICN0=[F:ICN]STOFCY;S_MODITM;[F:ICN]CSTTYP;[F:ICN]ITCSEQ;[F:ICN]OVENAT;[F:ICN]UID
      If !fstat Delete [F:ICN1] Curr  Endif
      [F:ICN]ITMREF=S_MODITM
      [F:ICN]UPDUSR= GUSER
      [F:ICN]UPDDAT= date$
      Rewrite [F:ICN]
      Call ECR_DEBUG("MOD_ITMREF: row ICN updated: "-[F:ICN]ITMREF-"ITCSEQ="-num$([F:ICN]ITCSEQ)) From CFGLIBC1
      If fstat Break Endif
    Next

    # ICC0 : STOFCY+ITMREF+CSTTYP-ITCSEQ+MATREF+CPNTYP+UID Articles - Coûts temporaire
    If clalev([F:ICC]) = 0 :  Local File ITCMAT     [ICC]   : Endif
    If clalev([F:ICC1]) = 0 : Local File ITCMAT     [ICC1]  : Endif
    For [ICC] Where ITMREF=S_ITMSEL(0)
      # Ctrl si la clé existe déjà
      # Issue 120536 GH 22/12/2016 - 2 version fields added in the key
      #Read [ICC1]ICC0=[F:ICC]STOFCY;S_MODITM;[F:ICC]CSTTYP;[F:ICC]ITCSEQ;[F:ICC]MATREF;[F:ICC]CPNTYP;[F:ICC]UID
      Read [ICC1]ICC0=[F:ICC]STOFCY;S_MODITM;[F:ICC]CSTTYP;[F:ICC]ITCSEQ;[F:ICC]MATREF;[F:ICC]ECCVALMAJ;[F:ICC]ECCVALMIN;[F:ICC]CPNTYP;[F:ICC]UID
      If !fstat Delete [F:ICC1] Curr  Endif
      [F:ICC]ITMREF=S_MODITM
      [F:ICC]UPDUSR= GUSER
      [F:ICC]UPDDAT= date$
      Rewrite [F:ICC]
      Call ECR_DEBUG("MOD_ITMREF: row ICC updated:"-[F:ICC]ITMREF-"ITCSEQ="-num$([F:ICC]ITCSEQ)) From CFGLIBC1
      If fstat Break Endif
    Next

    # IWC0 : STOFCY+ITMREF+CSTTYP-ITCSEQ+WST+SCOITMREF+UID Articles - Coûts temporaire
    If clalev([F:IWC]) = 0  : Local File ITCWST     [IWC]  : Endif
    If clalev([F:IWC1]) = 0 : Local File ITCWST     [IWC1]  : Endif
    For [IWC] Where ITMREF=S_ITMSEL(0)
      # Ctrl si la clé existe déjà
      Read [IWC1]IWC0=[F:IWC]STOFCY;S_MODITM;[F:IWC]CSTTYP;[F:IWC]ITCSEQ;[F:IWC]WST;[F:IWC]SCOITMREF;[F:IWC]UID
      If !fstat  Delete [F:IWC1] Curr  Endif
      [F:IWC]ITMREF=S_MODITM
      [F:IWC]UPDUSR= GUSER
      [F:IWC]UPDDAT= date$
      Rewrite [F:IWC]
      Call ECR_DEBUG("MOD_ITMREF: row IWC updated:"-[F:IWC]ITMREF-"ITCSEQ="-num$([F:IWC]ITCSEQ)) From CFGLIBC1
      If fstat Break Endif
    Next

    # SMI0 : ITCSTRDAT+ITMREF+STOFCY+CSTTYP
    If !clalev([F:SMI])  Local File STKMVTITC [F:SMI]  Endif
    If !clalev([F:SMI1]) Local File STKMVTITC [F:SMI1] Endif
    For [SMI] Where ITMREF=S_ITMSEL(0)
      # Ctrl si la clé existe déjà
      Read [SMI1]SMI0=[F:SMI]ITCSTRDAT;S_MODITM;[F:SMI]STOFCY;[F:SMI]CSTTYP
      If !fstat  Delete [F:SMI1] Curr  Endif
      [F:SMI]ITMREF=S_MODITM
      #[F:SMI]UPDUSR= GUSER  # Issue 107085
      #[F:SMI]UPDDAT= date$  # Issue 107085
      Rewrite [F:SMI]
      Call ECR_DEBUG("MOD_ITMREF: row SMI updated:"-[F:SMI]ITMREF-"ITCSEQ="-num$([F:SMI]ITCSEQ)) From CFGLIBC1
      If fstat Break Endif
    Next
  Else
    Call ECR_DEBUG("MOD_ITMREF: No ICN,ICC,IWC,SMI update: BOMSEQ="-num$(S_SEQ)-[F:ITC]ITMREF) From CFGLIBC1
  Endif # !S_AUTCFG
# ################ Issue 103969 GA 11/2014 - End

    # Issue 103539 GA 10/2014
    # Update [ITS] Where ITMREF = S_ITMSEL(0) With ITMREF = S_MODITM
    If clalev([F:ITS1])= 0 : Local File ITMSALES     [ITS1]: Endif
    Filter [F:ITS] Where ITMREF = S_ITMSEL(0)
    For [F:ITS]
        Read [F:ITS1]ITS0=S_MODITM
        If !fstat
           Delete [F:ITS1] Curr
           Call ECR_DEBUG("MOD_ITMREF: row ITS replaced"-S_MODITM) From CFGLIBC1
        Endif
        [F:ITS]ITMREF = S_MODITM
        [F:ITS]UPDUSR=GUSER
        [F:ITS]UPDDAT=date$
        Gosub PE_BEFREWITS From CFGLIBC
        Rewrite [ITS]
        If fstat Break Endif
        Call ECR_DEBUG("MOD_ITMREF: row ITS updated:"-[F:ITS]ITMREF) From CFGLIBC1
    Next
    Filter [F:ITS]
    If fstat
        WABRFIC="ITS"
        GLOCK="$ITMSALES"-S_ITMSEL(0): Goto MOD_ITMREF_ERR
    Endif

  # Issue 86230 GA 12/2012 scénario ajoutant des lignes ITU
    If clalev([F:ITU1])= 0 : Local File ITMBPC     [ITU1]: Endif
    Filter [F:ITU] Where ITMREF = S_ITMSEL(0)
    For [F:ITU]
        # Issue 89191 GA 04/2013 en reprise de configuration, conserver la réf client
        #Delete [ITU1] Where ITMREF = S_MODITM & BPSNUM=[F:ITU]BPCNUM
        Read [F:ITU1]ITU0=S_MODITM;[F:ITU]BPCNUM
        If !fstat
           [F:ITU]ITMREFBPC = [F:ITU1]ITMREFBPC
           [F:ITU]ITMDESBPC = [F:ITU1]ITMDESBPC
           Delete [F:ITU1] Curr
           Call ECR_DEBUG("MOD_ITMREF: row ITU1 replaced"-S_MODITM-[F:ITU]BPCNUM) From CFGLIBC1
        Else
            Local Shortint I,J
            J=dim(S_MODBPCNUM)-1
            I=find([F:ITU]BPCNUM,S_MODBPCNUM(0..J))
            If I>0
              [F:ITU]ITMREFBPC = S_MODITMREFBPC(I-1)
              [F:ITU]ITMDESBPC = S_MODITMDESBPC(I-1)
            Endif
        Endif
        #Update [ITU1] Where ITMREF = S_ITMSEL(0) With ITMREF = S_MODITM
        [F:ITU]ITMREF = S_MODITM
        Gosub CTL_ITMREFBPC From CFGLIBC1
        Gosub REWRITE_ITU From CFGLIBC1   # Issue 89191 GA 04/2013 avant Rewrite
        If fstat Break Endif
        Call ECR_DEBUG("MOD_ITMREF: row ITU1 updated:"-[F:ITU]ITMREF-[F:ITU]BPCNUM-[F:ITU]ITMREFBPC) From CFGLIBC1
    Next
    Filter [F:ITU]
    If fstat
        WABRFIC="ITU"
        GLOCK="$ITMBPC"-S_ITMSEL(0): Goto MOD_ITMREF_ERR
    Endif

    # Issue 86230 GA 12/2012 scénario ajoutant des lignes ITP1
    If clalev([F:ITP1])= 0 : Local File ITMBPS     [ITP1]: Endif
    Filter [F:ITP] Where ITMREF = S_ITMSEL(0)
    For [ITP]
        # Issue 89191 GA 04/2013 en reprise de configuration, conserver la réf fournisseur
        #Delete [ITP1] Where ITMREF = S_MODITM & BPSNUM=[F:ITP]BPSNUM
        Read [F:ITP1]ITP0=S_MODITM;[F:ITP]BPSNUM
        If !fstat
           [F:ITP]ITMREFBPS = [F:ITP1]ITMREFBPS
           [F:ITP]ITMDESBPS = [F:ITP1]ITMDESBPS
           Delete [F:ITP1] Curr
           Call ECR_DEBUG("MOD_ITMREF: row ITP1 replaced"-S_MODITM-[F:ITP]BPSNUM) From CFGLIBC1
        Else
           Local Shortint I,J
           J=dim(S_MODBPSNUM)-1
           I=find([F:ITP]BPSNUM,S_MODBPSNUM(0..J))
           If I>0
             [F:ITP]ITMREFBPS = S_MODITMREFBPS(I-1)
             [F:ITP]ITMDESBPS = S_MODITMDESBPS(I-1)
           Endif
        Endif
        #Update [ITP1] Where ITMREF = S_ITMSEL(0) With ITMREF = S_MODITM
        [F:ITP]ITMREF = S_MODITM
        Gosub CTL_ITMREFBPS From CFGLIBC1
        Gosub REWRITE_ITP From CFGLIBC1   # Issue 89191 GA 04/2013 avant Rewrite
        If fstat Break Endif
        Call ECR_DEBUG("MOD_ITMREF: row ITP1 updated:"-[F:ITP]ITMREF-[F:ITP]BPSNUM-[F:ITP]ITMREFBPS) From CFGLIBC1
    Next
    Filter [F:ITP]
    If fstat
        WABRFIC="ITP"
        GLOCK="$ITMBPS"-S_ITMSEL(0): Goto MOD_ITMREF_ERR
    Endif

  # Issue 103539 GA 10/2014
  # FQ 66981 GA 09/2010 transfert des images et PJ
  #  Update [CBB] Where CODBLB="ITM" & IDENT1 = S_ITMSEL(0) With IDENT1 = S_MODITM
    If clalev([F:CBB1])= 0 : Local File CBLOB     [CBB1]: Endif
    Filter [F:CBB] Where CODBLB="ITM" & IDENT1 = S_ITMSEL(0)
    For [CBB]
        Read [F:CBB1]CBB0="ITM";S_MODITM;[F:CBB]IDENT2
        If !fstat
           Delete [F:CBB1] Curr
           Call ECR_DEBUG("MOD_ITMREF: row CBB replaced"-S_MODITM) From CFGLIBC1
        Endif
        [F:CBB]IDENT1 = S_MODITM
        [F:CBB]UPDUSR=GUSER
        [F:CBB]UPDDAT=date$
        GPOINT = "BEFREWCBB" : Gosub ENTREE From EXEFNC
        Rewrite [CBB]
        If fstat Break Endif
        # Issue 103539 GA 01/2015 before ITMREF
        Call ECR_DEBUG("MOD_ITMREF: row CBB updated:"-[F:CBB]IDENT1) From CFGLIBC1
    Next
    Filter [F:CBB]
    If fstat
        WABRFIC="CBB"
        GLOCK="$CBLOB"-S_ITMSEL(0): Goto MOD_ITMREF_ERR
    Endif

  # Issue 103539 GA 10/2014
  # FQ 66981 GA 09/2010 transfert des images et PJ
  #  Update [AOX] Where ABREV="ITM" & IDENT1 = S_ITMSEL(0) With IDENT1 = S_MODITM
    If clalev([F:AOX1])= 0 : Local File AOBJTXT     [AOX1]: Endif
    Filter [F:AOX] Where ABREV="ITM" & IDENT1 = S_ITMSEL(0)
    For [AOX]
        Read [F:AOX1]AOX0=[F:AOX]ABREV;S_MODITM;[F:AOX]IDENT2;[F:AOX]IDENT3
        If !fstat
           Delete [F:AOX1] Curr
           Call ECR_DEBUG("MOD_ITMREF: row AOX replaced"-S_MODITM) From CFGLIBC1
        Endif
        [F:AOX]IDENT1 = S_MODITM
        #[F:AOX]UPDUSR=GUSER   # Issue 103539 GA 01/2015
        #[F:AOX]UPDDAT=date$   # Issue 103539 GA 01/2015
        GPOINT = "BEFREWAOX" : Gosub ENTREE From EXEFNC
        Rewrite [AOX]
        If fstat Break Endif
        # Issue 103539 GA 01/2015 before ITMREF
        Call ECR_DEBUG("MOD_ITMREF: row AOX updated:"-[F:AOX]IDENT1) From CFGLIBC1
    Next
    Filter [F:AOX]
    If fstat
        WABRFIC="AOX"
        GLOCK="$AOBJTXT"-S_ITMSEL(0): Goto MOD_ITMREF_ERR
    Endif

    If [F:CSC]CMPFLG=2

     # Issue 89191 GA 04/2013 scénario ajoutant une (alternative) nomenclature
      If S_MODITM<>"" & S_MODITM<>S_ITMSEL(0)
        Delete [BOH] Where ITMREF = S_MODITM #& BOMALT = [F:CSC]BOMALT & BOMALTTYP = [F:CSC]BOMALTTYP
        Delete [BOD] Where ITMREF = S_MODITM #& BOMALT = [F:CSC]BOMALT & BOMALTTYP = [F:CSC]BOMALTTYP
      Endif
    # Issue 89191 GA 04/2013 scénario avec une autre alternative
    #  Update [BOH] Where ITMREF = S_ITMSEL(0) & BOMALT = [F:CSC]BOMALT & BOMALTTYP = [F:CSC]BOMALTTYP With ITMREF = S_MODITM
    # Issue 92564 GA 09/2013 IDENT1 doit aussi être maj
    #  Update [BOH] Where ITMREF = S_ITMSEL(0) With ITMREF = S_MODITM
      Local Char W_CODKEY1(250)
      Call FIND_LNK("BOM","[F:BOH]","BOMDESAXX","CLECUR1",W_CODKEY1) From CFGLIBC1
      Filter [BOH] Where ITMREF = S_ITMSEL(0)
      For [BOH]
          [F:BOH]ITMREF=S_MODITM
          If W_CODKEY1<>""
             [F:BOH]IDENT1 = evalue(W_CODKEY1)
          Else
             [F:BOH]IDENT1 = [F:BOH]ITMREF + "~" + num$([F:BOH]BOMALT)
          Endif
          Rewrite [BOH]
      Next
      Filter [BOH]
      Call ECR_DEBUG("MOD_ITMREF: row BOH updated:"-S_MODITM-num$(adxuprec)) From CFGLIBC1
    # Issue 89191 GA 04/2013 scénario avec une autre alternative
    #  Update [BOD] Where ITMREF = S_ITMSEL(0) & BOMALT = [F:CSC]BOMALT & BOMALTTYP = [F:CSC]BOMALTTYP With ITMREF = S_MODITM
      Update [BOD] Where ITMREF = S_ITMSEL(0) With ITMREF = S_MODITM
      If fstat
          WABRFIC="BOD"
          GLOCK="$BOMD"-S_ITMSEL(0): Goto MOD_ITMREF_ERR
      Endif
      Call ECR_DEBUG("MOD_ITMREF: row BOD updated:"-S_MODITM-num$(adxuprec)) From CFGLIBC1
    Endif

    # Issue 85211 GA 11/2012
    #If clalev([F:ROH]) > 0
    If [F:CSC]ROUFLG=2
      # Issue 89191 GA 04/2013 scénario ajoutant une gamme (alternative/site différent)
      If S_MODITM<>"" & S_MODITM<>S_ITMSEL(0)
        Delete [ROH] Where ITMREF = S_MODITM #& ROUALT = [F:CSC]ROUALT & FCY=S_FCY
        Delete [ROO] Where ITMREF = S_MODITM #& ROUALT = [F:CSC]ROUALT & FCY=S_FCY
        Delete [ROS] Where ITMREF = S_MODITM #& ROUALT = [F:CSC]ROUALT & FCY=S_FCY
      Endif
    # Issue 89191 GA 04/2013 scénario avec une autre alternative/site
    #  Update [ROH] Where ITMREF = S_ITMSEL(0) & ROUALT = [F:CSC]ROUALT & FCY=S_FCY  With ITMREF = S_MODITM
    # Issue 92564 GA 09/2013 IDENT1 doit aussi être maj
    #  Update [ROH] Where ITMREF = S_ITMSEL(0) With ITMREF = S_MODITM
      Local Char W_CODKEY1(250)
      Call FIND_LNK("ROUTING","[F:ROH]","ROUDESAXX","CLECUR1",W_CODKEY1) From CFGLIBC1
      Filter [ROH] Where ITMREF = S_ITMSEL(0)
      For [ROH]
          [F:ROH]ITMREF=S_MODITM
          If W_CODKEY1<>""
             [F:ROH]IDENT1 = evalue(W_CODKEY1)
          Else
             [F:ROH]IDENT1 = [F:ROH]ITMREF + "~" + num$([F:ROH]ROUALT)
          Endif
          Rewrite [ROH]
      Next
      Filter [ROH]
      Call ECR_DEBUG("MOD_ITMREF: row ROH updated:"-S_MODITM-num$(adxuprec)) From CFGLIBC1

     # Issue 89191 GA 04/2013 scénario avec une autre alternative
     #   Update [ROO] Where ITMREF = S_ITMSEL(0) & ROUALT = [F:CSC]ROUALT With ITMREF = S_MODITM
      Update [ROO] Where ITMREF = S_ITMSEL(0) With ITMREF = S_MODITM
      If fstat
        WABRFIC="ROO"
        GLOCK="$ROUOPE"-S_ITMSEL(0): Goto MOD_ITMREF_ERR
      Endif
      Call ECR_DEBUG("MOD_ITMREF: row ROO updated:"-S_MODITM-num$(adxuprec)) From CFGLIBC1

     # Issue 89191 GA 04/2013 scénario avec une autre alternative
     # Update [ROS] Where ITMREF = S_ITMSEL(0) & ROUALT = [F:CSC]ROUALT With ITMREF = S_MODITM
      Update [ROS] Where ITMREF = S_ITMSEL(0) With ITMREF = S_MODITM
      If fstat
        WABRFIC="ROS"
        GLOCK="$ROUSCD"-S_ITMSEL(0): Goto MOD_ITMREF_ERR
      Endif
      Call ECR_DEBUG("MOD_ITMREF: row ROS updated:"-S_MODITM-num$(adxuprec)) From CFGLIBC1
    Endif

   # Issue 89191 GA 04/2013
    Gosub MOD_ITMREF_TEXTES From CFGLIBC1

    Update [CHH] Where CFGVCRNUM = S_CPTCFG With ITMREF = S_MODITM, ROUNUM = S_MODITM
    If fstat
        WABRFIC="CHH"
        GLOCK="$CFGHISHEA"-S_ITMSEL(0): Goto MOD_ITMREF_ERR
    Endif
Endif

$MOD_ITMREF_FIN
Return
$MOD_ITMREF_ERR
# FQ 66981 GA 09/2010 trop de lignes dans CFGLIBC
    Case fstat
      When 0, 4 :
      When 1 :
        GOK=-1
      When Default :
        GOK = 0
        Call RSTACTX(WABRFIC,"S_ITMSEL(0)",W_TRASTP,"$MOD_ITMREF") From CFGLIBD
    Endcase
    Goto MOD_ITMREF_FIN
Return
########################################################################
# Issue 89095 GA 06/2013 suppression des textes traduits
########################################################################
Subprog DEL_AXX_FIC(LFIC,LABR)
Value    Char LFIC
Value    Char LABR

#If clalev([F:ATB])=0  : Local File =S_DOSSIER+".ATABLE"  [ATB]  : Endif
If clalev([F:ATZ])=0  : Local File =S_DOSSIER+".ATABZON" [ATZ]  : Endif
Local Char W_VALKEY1(250),W_CODKEY1(250)
Local Char W_VALKEY2(250),W_CODKEY2(250)
For [ATZ] Where CODFIC=LFIC & find(CODTYP,"AXX","AX1","AX2","AX3")>0
      Raz W_CODKEY1, W_CODKEY2
    # Clé 1 ?
      Call FIND_LNK(LFIC,LABR,[F:ATZ]CODZONE,"CLECUR1",W_CODKEY1)
      If W_CODKEY1<>""
         W_VALKEY1 = evalue(W_CODKEY1)
         Call FIND_LNK(LFIC,LABR,[F:ATZ]CODZONE,"CLECUR2",W_CODKEY2)
         If W_CODKEY2<>"" W_VALKEY2 = evalue(W_CODKEY2) Else W_VALKEY2="" Endif
       # Clé 2 ?
         Call SUPTEXTRA([F:ATZ]CODFIC,[F:ATZ]CODZONE,W_VALKEY1,W_VALKEY2) From ATEXTRA
         W_TRA="DEL_AXX_FIC: Translated text deleted for"-[F:ATZ]CODFIC-[F:ATZ]CODZONE-W_VALKEY1-W_VALKEY2
         Call ECR_DEBUG(W_TRA)
      Endif
Next

# Issue 110631 GA 09/2015 TXC should never be suppressed, because reference copied in WO for example
# Issue 108077 GA 05/2015: current table contains at least one field with TXC datatype
#For [ATZ] Where CODFIC=LFIC & CODTYP="TXC"
#    Call DEL_TXC([F:ATZ]CODFIC,LABR,[F:ATZ]CODZONE)
#Next
End
############################################################
# Sous programme de suppression des textes rtf (TEX et TXC)
# Issue 108077 GA 05/2015
Subprog DEL_TXC(LFIC,LABR,LZON)
Value Char LFIC
Value Char LABR
Value Char LZON

Local Char    W_EVA(40)    # Field name for value TEX or TXC  (ex: '[F:ITM]MFGTEX')
Local Char    W_TEX(250)
Local Integer W_I, W_J, W_K,WSTAT

W_EVA   = LABR+LZON
W_TEX   = evalue(W_EVA)

If W_TEX <> ""
  Call SUP_CLOB(W_TEX, WSTAT) From TRTX3TEX
  If WSTAT=1          # Ok
    If W_TEX <> ""   # W_TEX non vide
       W_TRA="DEL_TXC_FIC: text deleted for"-LFIC-W_EVA-"="-W_TEX
       Call ECR_DEBUG(W_TRA)
    Endif
  Endif
Endif

End
########################################################################
# Issue 89095 GA 06/2013 lecture des textes traduits
########################################################################
Subprog LEC_AXX_FIC(LFIC,LABR,LZON,LTXT)
Value    Char LFIC
Value    Char LABR
Value    Char LZON
Variable Char LTXT

#If clalev([F:ATB])=0  : Local File =S_DOSSIER+".ATABLE"  [ATB]  : Endif
If clalev([F:ATZ])=0  : Local File =S_DOSSIER+".ATABZON" [ATZ]  : Endif
Local Char W_VALKEY1(250),W_CODKEY1(250)
Local Char W_VALKEY2(250),W_CODKEY2(250)
For [ATZ] Where CODFIC=LFIC & CODZONE=LZON & find(CODTYP,"AXX","AX1","AX2","AX3")>0 & left$(CODZONE,1)<>"Z"
      Raz W_CODKEY1, W_CODKEY2
    # Clé 1 ?
      Call FIND_LNK(LFIC,LABR,[F:ATZ]CODZONE,"CLECUR1",W_CODKEY1)
      If W_CODKEY1<>""
         W_VALKEY1 = evalue(W_CODKEY1)
         Call FIND_LNK(LFIC,LABR,[F:ATZ]CODZONE,"CLECUR2",W_CODKEY2)
         If W_CODKEY2<>"" W_VALKEY2 = evalue(W_CODKEY2) Else W_VALKEY2="" Endif
       # Clé 2 ?
         Call LECTEXTRA(LTXT,[F:ATZ]CODFIC,[F:ATZ]CODZONE,W_VALKEY1,W_VALKEY2) From ATEXTRA
         W_TRA="Phase="+num$(S_PHASE)-"LEC_AXX_FIC: Translated text read for"-[F:ATZ]CODFIC-[F:ATZ]CODZONE-W_VALKEY1-W_VALKEY2-LTXT
         Call ECR_DEBUG(W_TRA)
      Endif
Next
End
########################################################################
# Issue 89095 GA 06/2013 maj des textes traduits
########################################################################
Subprog UPD_AXX_FIC(LFIC,LABR,LZON,LTXT)
Value    Char LFIC
Value    Char LABR
Value    Char LZON
Value    Char LTXT

# Issue 107085 GA 03/2015 too many access to this table ATEXTRA
If LTXT=""  End Endif

#If clalev([F:ATB])=0  : Local File =S_DOSSIER+".ATABLE"  [ATB]  : Endif
If clalev([F:ATZ])=0  : Local File =S_DOSSIER+".ATABZON" [ATZ]  : Endif
Local Char W_VALKEY1(250),W_CODKEY1(250)
Local Char W_VALKEY2(250),W_CODKEY2(250)
For [ATZ] Where CODFIC=LFIC & CODZONE=LZON & find(CODTYP,"AXX","AX1","AX2","AX3")>0
      Raz W_CODKEY1, W_CODKEY2
    # Clé 1 ?
      Call FIND_LNK(LFIC,LABR,[F:ATZ]CODZONE,"CLECUR1",W_CODKEY1)
      If W_CODKEY1<>""
         W_VALKEY1 = evalue(W_CODKEY1)
       # Clé 2 ?
         Call FIND_LNK(LFIC,LABR,[F:ATZ]CODZONE,"CLECUR2",W_CODKEY2)
         If W_CODKEY2<>"" W_VALKEY2 = evalue(W_CODKEY2) Else W_VALKEY2="" Endif
         Call MAJTEXTRA(LTXT,[F:ATZ]CODFIC,[F:ATZ]CODZONE,W_VALKEY1,W_VALKEY2) From ATEXTRA
         If S_TRAFLG>=3  # Issue 107085 GA 03/2015 only if debug trace is activated
            W_TRA="Phase="+num$(S_PHASE)-"UPD_AXX_FIC: Translated text updated for"-[F:ATZ]CODFIC-[F:ATZ]CODZONE-W_VALKEY1-W_VALKEY2-LTXT
            Call ECR_TRACE(W_TRA,0) # From GESECRAN
         Endif
      Endif
Next
End
########################################################################
Subprog FIND_LNK(LFIC,LABR,LZONE,LPAR,LLNK)     # Issue 89095 GA 06/2013
Value    Char LFIC
Value    Char LABR
Value    Char LZONE
Value    Char LPAR
Variable Char LLNK

If clalev([F:AMP])=0  : Local File =S_DOSSIER+".AMSKPAR" [AMP] Endif
Local Char WCLECUR(60) : WCLECUR=""

Read [AMP]CODPAR=2;LFIC;LZONE;LPAR
If !fstat & [F:AMP]VALPAR<>"" & [F:AMP]VALPAR<>'""' & [F:AMP]VALPAR<>"''"
   If instr(1,[F:AMP]VALPAR,"(")
      If left$([F:AMP]VALPAR,4)="num$"
        WCLECUR = left$([F:AMP]VALPAR,instr(1,[F:AMP]VALPAR,"(")-1)
      Else
        WCLECUR = LABR+left$([F:AMP]VALPAR,instr(1,[F:AMP]VALPAR,"(")-1)
      Endif
      WCLECUR += "("+LABR+right$([F:AMP]VALPAR,instr(1,[F:AMP]VALPAR,"(")+1)
   Else
      WCLECUR = LABR+[F:AMP]VALPAR
   Endif
Endif
LLNK = WCLECUR
End

########################################################################
Subprog ECR_DEBUG(LMESS)                                  # GA 11/2010 #
Value Char LMESS
If LMESS<>"" & S_TRAFLG>=4
   Call ECR_TRACE(LMESS,0) # From GESECRAN
Endif
End


########################################################################
Subprog ECR_TRACE(LMESS, LNIV)                            # GA 05/2014 #
Value Char    LMESS
Value Integer LNIV
If LNIV<>0
   Call ECR_TRACE(LMESS,LNIV) From GESECRAN
Else
   W_TRAMSG= LMESS : Gosub TRA_MSG From CFGLIBB
Endif
End

# Issue 113260 - 2016-07-11 by STLIG : New subprog...
#**---------------------------------------------------------------------<br/>
#* COPY_AXX_ITM : Copy Product description translations from OLD_KEY to NEW_KEY
#**<br/>----------------------------------------------------------------<br/>
#* @param OLD_KEY = From Product key
#* @param NEW_KEY = To Product key
#**<br/>----------------------------------------------------------------
#*!
Subprog COPY_AXX_ITM(OLD_KEY,NEW_KEY)
Value Char OLD_KEY
Value Char NEW_KEY

Local Char PRODUCT_FIELD(GLONAVA)

If (clalev([F:ATZ])=0)
  Local File =S_DOSSIER+".ATABZON" [ATZ]
Endif

For [ATZ] Where CODFIC='ITMMASTER' & find(CODTYP,"AXX","AX1","AX2","AX3")>0

  Case ([F:ATZ]CODZONE)
    When "DES1AXX" : PRODUCT_FIELD="ITMDES1"
    When "DES2AXX" : PRODUCT_FIELD="ITMDES2"
    When "DES3AXX" : PRODUCT_FIELD="ITMDES3"
    When Default   : PRODUCT_FIELD=""
  Endcase

    If (PRODUCT_FIELD="" |
&       (evalue("dim([F:ITM]"+PRODUCT_FIELD+")>0") & evalue("dim([F:ITM1]"+PRODUCT_FIELD+")>0") &
&        evalue("[F:ITM]"+PRODUCT_FIELD)=evalue("[F:ITM1]"+PRODUCT_FIELD)))
      Call DUPTEXTRA([F:ATZ]CODFIC,[F:ATZ]CODZONE,OLD_KEY,"",[F:ATZ]CODFIC,[F:ATZ]CODZONE,NEW_KEY,"") From ATEXTRA
    Else
      Call SUPTEXTRA([F:ATZ]CODFIC,[F:ATZ]CODZONE,NEW_KEY,"") From ATEXTRA
    Endif

Next

End

