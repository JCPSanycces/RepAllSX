#<AdxTL>@(#)12.0.0.0 $Revision$
############################################################
# Eclatement de CFGLIBC
# CFGLIBC1  Version: 0001
############################################################
# FQ 69139 GA 11/2010 remplacement [CFT1] par [F:CFT1]
# Issue 80262 GA 02/2012 - Raz modif 69139
############################################################
# Traitement des sous scenarios
$TRT_SUBSCE
W_TRASTP=mess(185,188,1)-"($TRT_SUBSCE)" : Gosub TRA_STEP From CFGLIBB     # suivi

WW_CURITM    = S_CURITM
WW_CURROU    = S_CURROU
WW_BOMALTREF = [F:CSC]BOMALTREF
WW_ROUALTREF = [F:CSC]ROUALTREF
WW_BOMALT    = [F:CSC]BOMALT
WW_ROUALT    = [F:CSC]ROUALT
# Issue 80054 GA 06/2012
#If [F:CSC]BOMALTTYP>0 # FQ 75675 GA 08/2011 erreur si aucune nomenclature dans le scénario
If [F:CSC]BOMALTTYP>0 & [F:CSC]BOMALT>0
  WW_LLCTYPREF = func LLCLIB.LLCTYP([F:CSC]BOMALTTYP)   # FQ 69139 GA 11/2010 avant WW_BOMALTREF
  WW_LLCTYP    = func LLCLIB.LLCTYP([F:CSC]BOMALTTYP)   # FQ 69139 GA 11/2010 avant WW_BOMALT et WW_LLCTY(P)
Endif
WW_CSTCOD    = [F:CSC]CSTCOD
WW_COM       = W_COM
WW_BOH       = W_BOH
WW_ROH       = W_ROH
WW_CSTMAT = S_CSTMAT
WW_CSTMAC = S_CSTMAC
WW_CSTLAB = S_CSTLAB
WW_CSTSCO = S_CSTSCO
WW_CSTOVE = S_CSTOVE
WW_CSTTOT = S_CSTTOT
WW_ITMQTY = S_ITMQTY
#
For S_LEVEL = 1 To GBOMLEV
  Filter [F:CFT1] Where PRONUM = adxuid(1) &
&                       RECCOD = S_LEVEL
&               Order By Key CFT0
  For [F:CFT1]
    GOK=1 # Issue 98937 GA 04/2014
    Read [CSC]CSC0=[F:CFT1]CODZON
    If fstat = 0
      [F:CSC]BOMALTREF = WW_BOMALTREF      # Forcer les données avec celle du scénario maitre
      [F:CSC]ROUALTREF = WW_ROUALTREF
      [F:CSC]BOMALT    = WW_BOMALT
      [F:CSC]ROUALT    = WW_ROUALT
      [F:CSC]CSTCOD    = WW_CSTCOD
      Gosub TRT_UN_SUBSCE
      If W_MSG <> "" | S_ABORT | GOK <> 1
        Break 2
      Endif
    Endif
  Next
  Filter [F:CFT1]
Next S_LEVEL
# Issue GA 07/2012 ssi on a trouvé un sous-scénario ajout & S_SUBSCE<>""
# Reactualisation des articles crees par sous scenario
If W_MSG = "" & S_SUBSCE<>""
  For S_LEVEL = GBOMLEV To 1 Step -1
    Filter [F:CFT1] Where PRONUM = adxuid(1) &
&                         RECCOD = S_LEVEL
&                 Order By Key CFT0
    For [F:CFT1]
      Read [CSC]CSC0=[F:CFT1]CODZON
      If fstat = 0
        [F:CSC]BOMALTREF = WW_BOMALTREF      # Forcer les données avec celle du scénario maitre
        [F:CSC]ROUALTREF = WW_ROUALTREF
        [F:CSC]BOMALT    = WW_BOMALT
        [F:CSC]ROUALT    = WW_ROUALT
        [F:CSC]CSTCOD    = WW_CSTCOD
        W_RIT    = [F:CSC]PARITM # Issue 98937 GA 05/2014 ?
        Gosub REA_UN_SUBSCE
        If W_MSG <> "" | S_ABORT | GOK<>1
          Break 2
        Endif
      Endif
    Next
    Filter [F:CFT1]
  Next S_LEVEL
Endif
#
# Restauration situation avant sous scenarios
S_SUBSCE = ""
S_CURITM = WW_CURITM
S_CURROU = WW_CURROU
W_COM    = WW_COM
W_BOH    = WW_BOH
W_ROH    = WW_ROH
S_CSTMAT = WW_CSTMAT
S_CSTMAC = WW_CSTMAC
S_CSTLAB = WW_CSTLAB
S_CSTSCO = WW_CSTSCO
S_CSTOVE = WW_CSTOVE
S_CSTTOT = WW_CSTTOT
S_ITMQTY = WW_ITMQTY
#
Read [CSC]CSC0=S_SCENUM
If fstat
  GOK = 0
  Call FSTACTX("CSC",W_TRASTP,"$TRT_SUBSCE") From CFGLIBD  # From GLOCK
Else
  # Restauration situation avant sous scenarios     # JPJ E21260 - Certains clients altèrent les alternatives
  [F:CSC]BOMALTREF = WW_BOMALTREF                   #   pour des besoins spécifiques
  [F:CSC]ROUALTREF = WW_ROUALTREF
  [F:CSC]BOMALT    = WW_BOMALT
  [F:CSC]ROUALT    = WW_ROUALT
  #
  Gosub LOA_PILE_REA From CFGLIBB
Endif
Gosub CTL_PARAM_CSC # From CFGLIBC1
Return
############################################################
# Traitement d'un sous scenario
$TRT_UN_SUBSCE
#
S_SUBSCE = [F:CFT1]CODZON
S_CURITM = mid$([F:CFT1]CLE,9,GLONITM)   # Issue 106724 length control : 20 => GLONITM
S_ITMQTY = 1
#W_TRASTP=mess(191,188,1)-":"-S_SUBSCE-"/"-S_CURITM-"($TRT_UN_SUBSCE)" : Gosub TRA_STEP From CFGLIBB     # suivi
W_TRASTP=mess(191,188,1)-S_CURITM-"($TRT_UN_SUBSCE)" : Gosub TRA_STEP From CFGLIBB     # suivi
Gosub LOA_PILE From CFGLIBB

# Relecture composant cree
W_ITM = S_CURITM
Gosub LEC_ITM From CFGLIBB
If [F:ITM]ITMREF = ""
  GOK = 0
  Call FSTACTX("ITM",W_TRASTP,"$TRT_UN_SUBSCE") From CFGLIBD  # From GLOCK
  Goto TRT_UN_SUBSCE_FIN
Endif
# Traitement phase debut
W_TRASTP=mess(202,188,1) : Gosub TRA_STEP From CFGLIBB     # suivi

# FQ 61200 GA 01/2010 déclenchement d'un sous-scénario
GPOINT = "TRTSUBSCE"
Gosub ENTREE From EXEFNC

Raz [M:CFP]PILSTR
For [M:CFP]PILIND = 0 To [M:CFP]NBLIG-1
  If [M:CFP]PILPHA([M:CFP]PILIND) > 1
    [M:CFP]PILSTR = [M:CFP]PILIND
    Break
  Endif
  Gosub TRT_SYMBOLE From CFGLIBC1
  If (GOK<>1 | S_ABORT | W_MSG <> "")
     Break # Issue 104665 before: Break 2
  Endif
Next [M:CFP]PILIND
#
If GOK=-1 : Goto TRT_UN_SUBSCE_FIN : Endif
If (S_ABORT | GOK=0)      # abandon utilisateur ou pb maj)
  W_MSG = mess(53,188,1)+" ("+mess(1,188,1)+" : "+S_SUBSCE+")"
Endif
If W_MSG <> ""
  GMESSAGE = W_MSG +" ("+mess(1,188,1)+" : "+S_SUBSCE+")"
  Gosub TRA_ERR From CFGLIBB
  GERR     = 1
  FIN      = 1
  Goto TRT_UN_SUBSCE_FIN
Endif
# Traitement entete nomenclature et entete gamme
W_TRASTP=mess(210,188,1): Gosub TRA_STEP From CFGLIBB     # suivi
For [M:CFP]PILIND = [M:CFP]PILSTR To [M:CFP]NBLIG-1
  If [M:CFP]PILPHA([M:CFP]PILIND) > 2
    [M:CFP]PILSTR = [M:CFP]PILIND
    Break
  Endif
# Mise a etat initial buffer
  If [M:CFP]PILPHA([M:CFP]PILIND) <> [M:CFP]PILPHA([M:CFP]PILIND-1) |
&    [M:CFP]PILSEQ([M:CFP]PILIND) <> [M:CFP]PILSEQ([M:CFP]PILIND-1)
    S_PHASE = [M:CFP]PILPHA([M:CFP]PILIND)
    S_SEQ   = [M:CFP]PILSEQ([M:CFP]PILIND)
    S_LIN   = [M:CFP]PILLIN([M:CFP]PILIND)
    Gosub MEI_BUFFERS From CFGLIBB
  Endif
  If find([M:CFP]PILTYP([M:CFP]PILIND),17,19)
      Gosub TRT_SYMBOLE From CFGLIBC1
      If (GOK<>1 | S_ABORT | W_MSG <> "")
        Break # Issue 104665 before: Break 2
      Endif
  Endif
Next [M:CFP]PILIND
#
If GOK=-1 : Goto TRT_UN_SUBSCE_FIN : Endif
If ( S_ABORT | GOK=0 )
  W_MSG = mess(53,188,1)+" ("+mess(1,188,1)+" : "+S_SUBSCE+")"
Endif
If W_MSG <> ""
 GMESSAGE = W_MSG
  Gosub TRA_ERR From CFGLIBB
  GERR     = 1
  FIN      = 1
  Goto TRT_UN_SUBSCE_FIN
Endif
# Relecture composant cree
W_ITM = S_CURITM
Gosub LEC_ITM From CFGLIBB
If [F:ITM]ITMREF = ""
  GOK = 0
  Call FSTACTX("ITM",W_TRASTP,"$TRT_UN_SUBSCE") From CFGLIBD  # From GLOCK
  Goto TRT_UN_SUBSCE_FIN
Endif
############################################################
#
# Creation des composants
#
Call ECR_DEBUG("TRT_UN_SUBSCE: composants")
W_TRASTP=mess(233,188,1) : Gosub TRA_STEP From CFGLIBB     # suivi
# Controle article n'a pas de nomenclature
W_BOH = 0
W_SEQ = 0
Read [BOH]BOH0=[F:ITM]ITMREF;[F:CSC]BOMALT;[F:CSC]BOMALTTYP
If fstat = 0
  Goto TRT_UN_SUBSCE_1
Endif
# Deroulement de la pile jusqu'aux enregistrement composants
[M:CFP]PILREC = 4
Gosub SKIP_PILE From CFGLIBC
Local Integer WW_PILSTR : WW_PILSTR = [M:CFP]PILSTR # Issue 98937 GA 04/2014
If GOK =-1 : Goto TRT_UN_SUBSCE_FIN : Endif
If GOK=0
  GMESSAGE = mess(53,188,1)+" ("+mess(1,188,1)+" : "+S_SUBSCE+")"
  Gosub TRA_ERR From CFGLIBB
  GERR     = 1
  FIN      = 1
  Goto TRT_UN_SUBSCE_FIN
Endif
Filter [CSL] Where SCENUM    = [F:CSC]SCENUM &
&                  SCENUMTYP = 5             &
&                  SYMTYP    = 0
&            Order By Key CSL0
For [CSL]
  If [F:CSL]CNDFORLIN = "" | num$(evalue([F:CSL]CNDFORLIN)) = "1"
    S_PHASE = [F:CSL]SCENUMTYP
    S_SEQ   = [F:CSL]SCENUMSEQ
    S_LIN   = [F:CSL]SCENUMLIN
    Gosub MEI_BUFFERS From CFGLIBB
    W_ITM = [F:ITM]ITMREF
    W_TLP = [F:ITM]CFGLIN
    For [M:CFP]PILIND = [M:CFP]PILSTR To [M:CFP]NBLIG-1
      If [M:CFP]PILPHA([M:CFP]PILIND)             <> S_PHASE |
&        [M:CFP]PILSEQ([M:CFP]PILIND)             <> S_SEQ   |
&        mid$([M:CFP]PILKEY([M:CFP]PILIND),13,20) <> [F:CSL]ITMREF
        [M:CFP]PILSTR = [M:CFP]PILIND
        Gosub TRT_COMPOSANT  From CFGLIBC
        If (GOK <> 1 | GERR=1) : Break 2 : Endif
        Break
      Else
        If !(find([M:CFP]PILTYP([M:CFP]PILIND),4,5,8))
          Gosub TRT_SYMBOLE
          If (GOK<>1 | S_ABORT | W_MSG <> "")
            Break 2
          Endif
        Endif
      Endif
    Next
  Else
    While  [M:CFP]PILPHA([M:CFP]PILIND)             =  5                &
&          [M:CFP]PILSEQ([M:CFP]PILIND)             =  [F:CSL]SCENUMSEQ &
&          mid$([M:CFP]PILKEY([M:CFP]PILIND),13,20) =  [F:CSL]ITMREF
      [M:CFP]PILIND += 1
    Wend
   [M:CFP]PILSTR = [M:CFP]PILIND
  Endif
Next
Filter [CSL]
#
If GOK=-1 : Goto TRT_UN_SUBSCE_FIN : Endif
If (S_ABORT | GOK = 0 | GERR=1)
  W_MSG = mess(53,188,1)+" ("+mess(1,188,1)+" : "+S_SUBSCE+")"
Endif
If W_MSG <> ""
  GMESSAGE = W_MSG
  Gosub TRA_ERR From CFGLIBB
  GERR     = 1
  FIN      = 1
  Goto TRT_UN_SUBSCE_FIN
Endif
############################################################
# Traitement gamme operatoire
$TRT_UN_SUBSCE_1
W_TRASTP=mess(186,188,1) : Gosub TRA_STEP From CFGLIBB     # suivi
S_CURROU = ""
W_ROH    = 0
If [F:CSC]ROUFLG <>  2 | clalev([F:ROH]) <= 0
  Goto TRT_UN_SUBSCE_2
Endif
Read [ROH]ROH0=S_CURITM;[F:CSC]ROUALT;S_FCY   : # Beryl Site en fin de clé primaire
If fstat = 0
  S_CURROU = S_CURITM
  Goto TRT_UN_SUBSCE_2
Endif
#
# FQ 63278 GA 03/2010 charger la gamme de reference
If [F:CSC]ROUREF<>""
   Read [ROH]ROH0=[F:CSC]ROUREF;[F:CSC]ROUALTREF
Endif
[F:ROH]ITMREF = S_CURITM
[F:ROH]ROUALT = [F:CSC]ROUALT
[F:ROH]FCY    = S_FCY
Call ECR_DEBUG("TRT_UN_SUBSCE: opérations")
# Deroulement de la pile jusqu'aux enregistrements operations
[M:CFP]PILREC = 7
Gosub SKIP_PILE From CFGLIBC
If GOK =-1 : Goto TRT_UN_SUBSCE_FIN : Endif
If GOK=0
  GMESSAGE = mess(53,188,1)+" ("+mess(1,188,1)+" : "+S_SUBSCE+")"
  Gosub TRA_ERR From CFGLIBB
  GERR     = 1
  FIN      = 1
  Goto TRT_UN_SUBSCE_FIN
Endif
# Traitement des operations
Filter [CSL] Where SCENUM    = [F:CSC]SCENUM &
&                  SCENUMTYP = 8             &
&                  SYMTYP    = 0
&            Order By Key CSL0
For [CSL]
  If [F:CSL]CNDFORLIN = "" | num$(evalue([F:CSL]CNDFORLIN)) = "1"
    S_PHASE = [F:CSL]SCENUMTYP
    S_SEQ   = [F:CSL]SCENUMSEQ
    S_LIN   = [F:CSL]SCENUMLIN
    S_OPS   = [F:CSL]STDOPENUM
    Gosub MEI_BUFFERS From CFGLIBB
    For [M:CFP]PILIND = [M:CFP]PILSTR To [M:CFP]NBLIG-1
      If [M:CFP]PILPHA([M:CFP]PILIND)                <> S_PHASE |
&        [M:CFP]PILSEQ([M:CFP]PILIND)                <> S_SEQ   |
&        val(mid$([M:CFP]PILKEY([M:CFP]PILIND),9,4)) <> S_OPS
        [M:CFP]PILSTR = [M:CFP]PILIND
        Gosub TRT_OPERATION From CFGLIBC
        If (GOK <> 1 | GERR=1) : Break 2 : Endif
        Break
      Else
        If !(find([M:CFP]PILTYP([M:CFP]PILIND),4,5,8))
          Gosub TRT_SYMBOLE
          If (GOK<>1 | S_ABORT | W_MSG <> "")
            Break 2
          Endif
        Endif
      Endif
    Next
  Else
    While  [M:CFP]PILPHA([M:CFP]PILIND)                =  8                &
&          [M:CFP]PILSEQ([M:CFP]PILIND)                =  [F:CSL]SCENUMSEQ &
&          val(mid$([M:CFP]PILKEY([M:CFP]PILIND),9,4)) =  [F:CSL]STDOPENUM
      [M:CFP]PILIND += 1
    Wend
    [M:CFP]PILSTR = [M:CFP]PILIND
  Endif
Next
Filter [CSL]
#
If GOK=-1 : Goto TRT_UN_SUBSCE_FIN : Endif
If (S_ABORT | GOK=0 | GERR=1)
  W_MSG = mess(53,188,1)+" ("+mess(1,188,1)+" : "+S_SUBSCE+")"
Endif
If W_MSG <> ""
  GMESSAGE = W_MSG
  Gosub TRA_ERR From CFGLIBB
  GERR     = 1
  FIN      = 1
  Goto TRT_UN_SUBSCE_FIN
Endif
$TRT_UN_SUBSCE_2
If W_ROH <> 0
  If [M:CFP]PILSCD <> 0         # JPJ E19298
      Gosub CTR_JALONNEMENT From CFGLIBC
      If GOK <> 1
        Goto TRT_UN_SUBSCE_FIN
      Endif
      If W_MSG <> ""
        GMESSAGE = [F:ROH]ITMREF-num$([F:ROH]ROUALT)-W_MSG     # JPJ E19298
        W_MSG    = ""
        Call ERREUR(GMESSAGE) From GESECRAN
        Gosub TRA_ERR From CFGLIBB
        GMESSAGE = ""
      Endif
  Else                          # JPJ E19298 >
    Gosub ECR_JALONNEMENT From CFGLIBC
    If GOK <> 1
      Goto TRT_UN_SUBSCE_FIN
    Endif
  Endif                         # JPJ E19298 <
Endif
$TRT_UN_SUBSCE_FIN
Return
############################################################
# Traitement d'un sous scenario
$REA_UN_SUBSCE
#
S_SUBSCE = [F:CFT1]CODZON
S_CURITM = mid$([F:CFT1]CLE,9,20)
W_TRASTP=mess(212,188,1)-S_CURITM-"($REA_UN_SUBSCE)" : Gosub TRA_STEP From CFGLIBB     # suivi

Raz S_CSTMAT, S_CSTMAC, S_CSTLAB, S_CSTSCO, S_CSTOVE, S_CSTTOT

Gosub LOA_PILE_REA From CFGLIBB

# Balayage composants puis du composé
Read [ITM]ITM0=S_CURITM
If fstat = 0
    W_STU  = [F:ITM]STU
    Read [BOH]BOH0=S_CURITM;[F:CSC]BOMALT;[F:CSC]BOMALTTYP
    If fstat = 0
      W_BASQTY = [F:BOH]BASQTY
      # Recherche premier indice libre
      For W_J = 0 To  dim(S_CMPSEL)-1
        If S_CMPSEL(W_J) = ""
          Break
        Endif
      Next W_J
      # Balayage composants
      Filter [BOD] Where ITMREF    = S_CURITM      &
&                        BOMALT    = [F:CSC]BOMALT &
&                        BOMALTTYP = [F:CSC]BOMALTTYP
&                  Order By Key BOD0
      For [BOD]
        # Chargement composants S_CMPSEL
        If W_J < dim(S_CMPSEL)-1
          S_CMPSEL(W_J) = [F:BOD]CPNITMREF
          W_J += 1
        Endif
        # Calcul coûts matières par scenario
        If find([F:CSC]CSTCOD,3,7,8)    # Prix de base, Derniers prix, Evaluation de formules
            Read [ITM]ITM0=[F:BOD]CPNITMREF
            If fstat = 0
              Raz W_QTYN, W_QTYNA, W_QTYB, W_QTYBA
              Call LIKQTY(S_ITMQTY,[F:ITM]STU,W_BASQTY,[F:BOD]LIKQTYCOD,[F:BOD]LIKQTY,[F:BOD]QTYRND,
&                    [F:BOD]SCA,W_QTYN,W_QTYNA,W_QTYB,W_QTYBA)   From MFGLIB
              W_BES = W_QTYBA
              Call RNDQTY([F:ITM]STU,W_BES) From CFGLIBC
              W_CST = 0
              If [F:ITM]CFGVCRNUM <> S_CPTCFG   # Calcul normal
                 # GA 09/2007 avant 0 => W_DATNUL selon CFGLIBC
                  Call CAL_CST(1,[F:CSC]CSTCOD,S_FCY,[F:ITM]ITMREF,W_DATNUL,S_CUR,W_CST,W_RET) From CFGLIBD
                    # Sauvegarde du résultat de calcul en table de travail
                    Raz [CFT]
                    [F:CFT]PRONUM    = adxuid(1)
                    [F:CFT]RECCOD    = 9000 + S_LEVEL
                    [F:CFT]CODFIC    = "CST$"
                    [F:CFT]CODZON    = ""
                    [F:CFT]CLE       = format$("N0:8#",[F:BOD]BOMSEQ)+[F:BOD]CPNITMREF        # séquence, composant
                    [F:CFT]CLE1      = [F:BOD]ITMREF          # Composé
                    [F:CFT]CST       = W_CST
                    [F:CFT]CREUSR    = GUSER
                    [F:CFT]PROFLG    = W_RET    # Composant final (0 art, 10 référence...)
                    [F:CFT]CREDAT    = date$
                    [F:CFT]TXT       = S_SUBSCE    # pour info
                    Write [CFT]
                    If fstat
                        GOK = 0
                        Call FSTACTX("CFT",W_TRASTP,"$REA_UN_SUBSCE") From CFGLIBD
                        Break
                    Endif
              Else   # Recherche coût issu d'un sous-scénario
                    Call CAL_BYSUBSCE(S_LEVEL,[BOD]ITMREF,[F:BOD]CPNITMREF,[F:BOD]BOMSEQ,W_CST,W_RET) From CFGLIBD
              Endif
              S_CSTMAT += (W_CST*W_BES)
              S_CSTTOT += (W_CST*W_BES)
            Endif
        Endif # find
      Next
      Filter [BOD]
    Endif # fstat de BOH

    # Calcul coûts gamme par scenario
    If find([F:CSC]CSTCOD,8)    # Evaluation de formules
      If [F:CSC]ROUFLG = 2
        Read [ITM1]ITM0=[F:ROH]ITMREF
        If fstat = 0
          Filter [ROO] Where FCY    = [F:ROH]FCY    &
&                            ITMREF = [F:ROH]ITMREF &
&                            ROUALT = [F:ROH]ROUALT
&                  Order By Key ROO0
          For [ROO]
            # Poste de travail
            If [F:ROO]WST <> ""
              Read [MWS]WST0=[F:ROO]WST;S_FCY
              If fstat = 0
                W_CST = 0
                Case [F:MWS]WSTTYP
                  When 1 :
                  # GA 09/2007 avant 0 => W_DATNUL selon CFGLIBC
                    Call CAL_CST(2,[F:CSC]CSTCOD,S_FCY,[F:ROO]ITMREF,W_DATNUL,S_CUR,W_CST,W_RET) From CFGLIBD
                    S_CSTMAC += W_CST
                    S_CSTTOT += W_CST
                  When 2 :
                  # GA 09/2007 avant 0 => W_DATNUL selon CFGLIBC
                    Call CAL_CST(3,[F:CSC]CSTCOD,S_FCY,[F:ROO]ITMREF,W_DATNUL,S_CUR,W_CST,W_RET) From CFGLIBD
                    S_CSTLAB += W_CST
                    S_CSTTOT += W_CST
                Endcase
              Endif
            Endif
            # Main d'oeuvre
            If [F:ROO]LABWST <> ""
              Read [MWS]WST0=[F:ROO]LABWST;S_FCY
              If fstat = 0
                W_CST = 0
                Case [F:MWS]WSTTYP
                  When 1 :
                  # GA 09/2007 avant 0 => W_DATNUL selon CFGLIBC
                    Call CAL_CST(2,[F:CSC]CSTCOD,S_FCY,[F:ROO]ITMREF,W_DATNUL,S_CUR,W_CST,W_RET) From CFGLIBD
                    S_CSTMAC += W_CST
                    S_CSTTOT += W_CST
                  When 2 :
                  # GA 09/2007 avant 0 => W_DATNUL selon CFGLIBC
                    Call CAL_CST(3,[F:CSC]CSTCOD,S_FCY,[F:ROO]ITMREF,W_DATNUL,S_CUR,W_CST,W_RET) From CFGLIBD
                    S_CSTLAB += W_CST
                    S_CSTTOT += W_CST
                Endcase
              Endif
            Endif
            # Sous-traitance
            If  [F:ROO]SCOWST <> "" & [F:ROO]SCOCOD = 2
              Read [MWS]WST0=[F:ROO]SCOWST;S_FCY
              If fstat = 0
                W_CST = 0
              # GA 09/2007 avant 0 => W_DATNUL selon CFGLIBC
                Call CAL_CST(4,[F:CSC]CSTCOD,S_FCY,[F:ROO]ITMREF,W_DATNUL,S_CUR,W_CST,W_RET) From CFGLIBD
                S_CSTSCO += W_CST
                S_CSTTOT += W_CST
              Endif
            Endif
          Next
          Filter [ROO]
        Endif
      Endif
    Endif # find
Endif    # fstat de ITM

# Relecture composant cree
Read [ITM]ITM0=S_CURITM
If fstat
  GOK = 0
  Call FSTACTX("ITM",W_TRASTP,"$REA_UN_SUBSCE") From CFGLIBD  # From GLOCK
  Goto REA_UN_SUBSCE_FIN
Else    # Sauvegarde du coût global en table temporaire
    Raz [CFT]
    [F:CFT]PRONUM    = adxuid(1)
    [F:CFT]RECCOD    = 9000 + S_LEVEL -1
    [F:CFT]CODFIC    = "CST$"
    [F:CFT]CODZON    = ""
    [F:CFT]CLE       = [F:CFT1]CLE        # séquence, composant et composé pris sur la
    [F:CFT]CLE1      = [F:CFT1]CLE1       # demande du scénario
    [F:CFT]CST       = S_CSTTOT
    [F:CFT]PROFLG    = 50                 # indique un composant issu d'un calcul scénario (calcul intermédiaire)
    [F:CFT]CREUSR    = GUSER
    [F:CFT]CREDAT    = date$
    [F:CFT]TXT       = S_SUBSCE    # pour info
    Write [CFT]
    If fstat
        GOK = 0
        Call FSTACTX("CFT",W_TRASTP,"$REA_UN_SUBSCE") From CFGLIBD
    Endif
Endif
#
If [F:ITM]CFGVCRNUM = S_CPTCFG
  # FQ 61200 GA 01/2010 Réactualisation selon sous-scénario
  GPOINT = "REASUBSCE"
  Gosub ENTREE From EXEFNC

  Raz [M:CFP]PILSTR
  W_I = 0
  For [M:CFP]PILIND = [M:CFP]PILSTR To [M:CFP]NBLIG-1
    If [M:CFP]PILPHA([M:CFP]PILIND) = 2 & [M:CFP]PILCOD([M:CFP]PILIND) = 7
      W_I = 1
      Break
    Endif
  Next [M:CFP]PILIND
  If W_I <> 0
    W_TRAMSG=mess(213,188,1)-S_CURITM-"($REA_UN_SUBSCE)" : Gosub TRA_MSG From CFGLIBB     # suivi
    Gosub REA_COMPOSE From CFGLIBC
    If W_MSG <> ""
      GMESSAGE = W_MSG
      Gosub TRA_ERR From CFGLIBB
      GERR = 1
      Goto REA_UN_SUBSCE_FIN
    Endif
    If GOK <> 1
      Goto REA_UN_SUBSCE_FIN
    Endif
  Endif
Endif
#
$REA_UN_SUBSCE_FIN
Return

############################################################
# Ecriture multisites à partir de la fiche ITF de référence
# trouvée sur chaque site
# ECR_ART_ALLSITES_ITF déplacée depuis CFGLIBC (source trop long)
$ECR_ART_ALL_ITF
# Issue 85230 GA 10/2012 pour comportement des UPD_ITx_FROM_ASW
If dim(WCRE)<=0 Local Shortint WCRE Endif : WCRE=2
# en reprise sauf ligne S_FCY courante déjà créée/maj
# Issue 89191 GA 04/2013 en cas de reprise de configuration
If S_MODITM<>"" & [F:ITM]ITMREF="_"+S_MODITM
    Filter [ITF1] Where ITMREF  = S_MODITM
&                    &  STOFCY <> S_FCY
&                 Order By Key ITF0
Elsif S_ITMSEL(0) <>""                             # Issue 86230 GA 02/2013
    Filter [ITF1] Where ITMREF  = S_ITMSEL(0)
&                    &  STOFCY <> S_FCY
&                 Order By Key ITF0
Elsif W_RIT<>""
    Filter [ITF1] Where ITMREF  = W_RIT
&                    &  STOFCY <> S_FCY
&                 Order By Key ITF0
Else
    Filter [ITF1] Where 1=2
Endif
For [ITF1]
   [F:ITF]           = [F:ITF1]
   # Issue 89191 GA 04/2013 en cas de maj, la ligne ITF peut exister
    Read [ITF]=[F:ITM]ITMREF;[F:ITF1]STOFCY
    If !fstat
       [F:ITF]UPDUSR    = GUSER
       [F:ITF]UPDDAT    = date$
       WCRE=W_CFGUPD :  Gosub UPD_ITF_FROM_ASW From CFGLIBC1
       Rewrite [F:ITF]
    Else
       [F:ITF]ITMREF=[F:ITM]ITMREF
       [F:ITF]STOFCY=[F:ITF1]STOFCY
       # Issue 96443 GA 03/2014 Copie des article-sites sans MAJ des réponses
       #WCRE=2 : Gosub UPD_ITF_FROM_ASW From CFGLIBC1
       Gosub ECR_ART_ITF From CFGLIBC
    Endif
    # Issue 103814 GA 11/2014 Copie des article-coûts
    Gosub COPY_ITC From CFGLIBC
    Gosub COPY_ITC_SUITE From CFGLIBC
Next
Filter [ITF1]

# Issue 89191 GA 04/2013 idem ITP/ITU on complete si nécessaire
Local Char W_WRH(GLONFCY)
For W_V = 1 To 9
  If evalue("dim(S_FCYITF"+num$(W_V)+")>0")
    W_WRH = evalue("S_FCYITF"+num$(W_V))
    W_WRH = toupper(W_WRH)
    If W_WRH <> S_FCY
      Read [FCY1]FCY0=W_WRH
      If fstat = 0 & [F:FCY1]WRHFLG = 2
       # Issue 89191 GA 04/2013 en cas de maj, la ligne ITF peut exister
        Read [ITF]=[F:ITM]ITMREF;[F:ITF]STOFCY
        If !fstat
           [F:ITF]UPDUSR    = GUSER
           [F:ITF]UPDDAT    = date$
           WCRE=W_CFGUPD : Gosub UPD_ITF_FROM_ASW From CFGLIBC1
           Rewrite [F:ITF]
        Else
          Raz [F:ITF]
          [F:ITF]ITMREF     = [F:ITM]ITMREF
          [F:ITF]STOFCY     = W_WRH
          #Gosub INI_ITF From WUVAR
          WCRE=2 : Gosub UPD_ITF_FROM_ASW From CFGLIBC1
          Gosub ECR_ART_ITF From CFGLIBC
        Endif
      Endif
    Endif
  Endif
Next W_V

Return

############################################################
# Issue 82300 GA 05/2012 copying all existing [F:ITU]
$ECR_ART_ALL_ITU
# Issue 85230 GA 10/2012 pour comportement des UPD_ITx_FROM_ASW
If dim(WCRE)<=0 Local Shortint WCRE Endif : WCRE=2

# Issue 89172 GA 04/2013 uniquement article référence + revoir le cas de la reprise de configuration en V6
#If S_ITMSEL(0) <>""                             # Issue 86230 GA 02/2013
#    Filter [ITU1] Where ITMREF  = S_ITMSEL(0)
#&                 Order By Key ITU0
#    For [ITU1]
#        [F:ITU] = [F:ITU1]
#        Gosub UPD_ITU_FROM_ASW From CFGLIBC1
#        Gosub ECR_ART_ITU From CFGLIBC
#    Next
#Els
# Issue 96443 GA 03/2014 en reprise sauf ligne BPCNUM courante déjà créée/maj
# Issue 89191 GA 04/2013 en cas de reprise de configuration
If S_MODITM<>"" & [F:ITM]ITMREF="_"+S_MODITM
    Filter [ITU1] Where ITMREF  = S_MODITM
&                     & BPCNUM <> [F:ITU]BPCNUM
&                 Order By Key ITU0
Elsif W_RIT<>""
    Filter [ITU1] Where ITMREF  = W_RIT
&                 Order By Key ITU0
Else
    Filter [ITU1] Where 1=2
Endif
For [ITU1]
   # Issue 96443 GA 03/2014 en reprise sauf ligne BPCNUM courante déjà créée/maj
   # Issue 89191 GA 04/2013 en cas de maj, la ligne ITU peut exister
   # Read [ITU]=[F:ITM]ITMREF;[F:ITU1]BPCNUM
   # If !fstat
   #    WCRE=W_CFGUPD : Gosub UPD_ITU_FROM_ASW From CFGLIBC1
   #    Gosub REWRITE_ITU    # Issue 89191 GA 04/2013 avant Rewrite
   # Else
       [F:ITU] = [F:ITU1]
       WCRE=W_CFGUPD : Gosub UPD_ITU_FROM_ASW From CFGLIBC1
       [F:ITU]ITMREF=[F:ITM]ITMREF
       [F:ITU]BPCNUM=[F:ITU1]BPCNUM
       Gosub WRITE_ITU      # Issue 89191 GA 04/2013
   # Endif
Next
Filter [ITU1]

Local Shortint WITU
Local Char W_BPCNUM   (GLONBPS)
Local Char W_ITMREFBPC(GLONVCR)
Local Char W_ITMDESBPC(GLONDES)
For WITU = 1 To 9
  If evalue("dim(S_ITUITM"+num$(WITU)+")>0") |
&    evalue("dim(S_ITUDES"+num$(WITU)+")>0") |
&    evalue("dim(S_ITUBPR"+num$(WITU)+")>0")
    W_BPCNUM    = evalue("S_ITUBPR"+num$(WITU))
    W_ITMREFBPC = evalue("S_ITUITM"+num$(WITU))
    W_ITMDESBPC = evalue("S_ITUDES"+num$(WITU))
    Read [ITU1]=[F:ITM]ITMREF;W_BPCNUM
    If fstat
       Raz [F:ITU]
       Gosub INI_ITU From WUVAR
       [F:ITU]ITMREF = [F:ITM]ITMREF
       [F:ITU]BPCNUM = W_BPCNUM
       If W_ITMREFBPC <> ""  [F:ITU]ITMREFBPC=W_ITMREFBPC Endif
       If W_ITMDESBPC <> ""  [F:ITU]ITMDESBPC=W_ITMDESBPC Endif
       WCRE=2 : Gosub UPD_ITU_FROM_ASW From CFGLIBC1    # Issue 85230 GA 10/2012
       Gosub WRITE_ITU                         # Issue 89191 GA 04/2013
    Endif
  Endif
Next WITU

Return

############################################################
# Issue 82300 GA 05/2012 copying all existing [F:ITP]
$ECR_ART_ALL_ITP
# Issue 85230 GA 10/2012 pour comportement des UPD_ITx_FROM_ASW
If dim(WCRE)<=0 Local Shortint WCRE Endif : WCRE=2

# Issue 89172 GA 04/2013 uniquement article référence + revoir le cas de la reprise de configuration en V6
#If S_ITMSEL(0) <>""                             # Issue 86230 GA 02/2013
#    Filter [ITP1] Where ITMREF  = S_ITMSEL(0)
#&                 Order By Key ITP0
#    For [ITP1]
#        [F:ITP] = [F:ITP1]
#        Gosub UPD_ITP_FROM_ASW From CFGLIBC1
#        Gosub ECR_ART_ITP From CFGLIBC
#    Next
#Els
# Issue 96443 GA 03/2014 en reprise sauf ligne BPSNUM courante déjà créée/maj
# Issue 89191 GA 04/2013 en cas de reprise de configuration
If S_MODITM<>"" & [F:ITM]ITMREF="_"+S_MODITM
    Filter [ITP1] Where ITMREF  = S_MODITM
&                     & BPSNUM <> [F:ITP]BPSNUM
&                 Order By Key ITP0
Elsif W_RIT<>""
    Filter [ITP1] Where ITMREF  = W_RIT
&                 Order By Key ITP0
Else
    Filter [ITP1] Where 1=2
Endif
For [ITP1]
   # Issue 96443 GA 03/2014 en reprise sauf ligne BPCNUM courante déjà créée/maj
   # Issue 89191 GA 04/2013 en cas de maj, la ligne ITP peut exister
   # Read [ITP]=[F:ITM]ITMREF;[F:ITP1]BPSNUM
   # If !fstat
   #    WCRE=W_CFGUPD : Gosub UPD_ITP_FROM_ASW From CFGLIBC1
   #    Gosub REWRITE_ITP    # Issue 89191 GA 04/2013 avant Rewrite
   # Else
       [F:ITP] = [F:ITP1]
       WCRE=W_CFGUPD : Gosub UPD_ITP_FROM_ASW From CFGLIBC1
       [F:ITP]ITMREF=[F:ITM]ITMREF
       [F:ITP]BPSNUM=[F:ITP1]BPSNUM
       Gosub WRITE_ITP      # Issue 89191 GA 04/2013
   # Endif
Next
Filter [ITP1]

Local Shortint WITP
Local Char W_BPSNUM   (GLONBPS)
Local Char W_ITMREFBPS(GLONVCR)
Local Char W_ITMDESBPS(GLONDES)
For WITP = 1 To 9
  If evalue("dim(S_ITPITM"+num$(WITP)+")>0") |
&    evalue("dim(S_ITPDES"+num$(WITP)+")>0") |
&    evalue("dim(S_ITPBPR"+num$(WITP)+")>0")
    W_BPSNUM    = evalue("S_ITPBPR"+num$(WITP))
    W_ITMREFBPS = evalue("S_ITPITM"+num$(WITP))
    W_ITMDESBPS = evalue("S_ITPDES"+num$(WITP))
    Read [ITP1]=[F:ITM]ITMREF;W_BPSNUM
    If fstat & W_BPSNUM<>""
       Raz [F:ITP]
       Gosub INI_ITP From WUVAR
       [F:ITP]ITMREF = [F:ITM]ITMREF
       [F:ITP]BPSNUM = W_BPSNUM
       If W_ITMREFBPS <> ""  [F:ITP]ITMREFBPS=W_ITMREFBPS Endif
       If W_ITMDESBPS <> ""  [F:ITP]ITMDESBPS=W_ITMDESBPS Endif
       WCRE=2
       Gosub UPD_ITP_FROM_ASW From CFGLIBC1    # Issue 85230 GA 10/2012
       Gosub WRITE_ITP                         # Issue 89191 GA 04/2013
    Endif
  Endif
Next WITP

Return

######################################################################
# Issue 89006 GA 03/2013 [F:ITP]ITMREFBPS en reprise de configuration
######################################################################
$CTL_ITMREFBPS
Local Shortint W_V
Local Char W_BPSNUM   (GLONBPS)
Local Char W_ITMREFBPS(GLONVCR)
Local Char W_ITMDESBPS(GLONDES)
# Issue 104508 GA 12/2014 this has to be done while creation e.g. if S_MODITM=""
#If [F:ITP]ITMREF<>S_MODITM Return Endif
If S_MODITM<>"" & [F:ITP]ITMREF<>S_MODITM Return Endif
For W_V = 1 To 9
  If evalue("dim(S_ITPITM"+num$(W_V)+")>0") |
&    evalue("dim(S_ITPDES"+num$(W_V)+")>0") |
&    evalue("dim(S_ITPBPR"+num$(W_V)+")>0")
    W_BPSNUM    = evalue("S_ITPBPR"+num$(W_V))
    W_ITMREFBPS = evalue("S_ITPITM"+num$(W_V))
    W_ITMDESBPS = evalue("S_ITPDES"+num$(W_V))
    If W_BPSNUM = [F:ITP]BPSNUM
       If W_ITMREFBPS<>"" [F:ITP]ITMREFBPS=W_ITMREFBPS Endif
       If W_ITMDESBPS<>"" [F:ITP]ITMDESBPS=W_ITMDESBPS Endif
       Break
    Endif
 Else
    Break
 Endif
Next

Return
######################################################################
# Issue 89006 GA 03/2013 [F:ITU]ITMREFBPC en reprise de configuration
######################################################################
$CTL_ITMREFBPC
Local Shortint W_V
Local Char W_BPCNUM   (GLONBPC)
Local Char W_ITMREFBPC(GLONVCR)
Local Char W_ITMDESBPC(GLONDES)
# Issue 104508 GA 12/2014 this has to be done while creation e.g. if S_MODITM=""
#If [F:ITU]ITMREF<>S_MODITM Return Endif
If S_MODITM<>"" & [F:ITU]ITMREF<>S_MODITM Return Endif
For W_V = 1 To 9
  If evalue("dim(S_ITUITM"+num$(W_V)+")>0") |
&    evalue("dim(S_ITUDES"+num$(W_V)+")>0") |
&    evalue("dim(S_ITUBPR"+num$(W_V)+")>0")
    W_BPCNUM    = evalue("S_ITUBPR"+num$(W_V))
    W_ITMREFBPC = evalue("S_ITUITM"+num$(W_V))
    W_ITMDESBPC = evalue("S_ITUDES"+num$(W_V))
    If W_BPCNUM = [F:ITU]BPCNUM
       If W_ITMREFBPC<>"" [F:ITU]ITMREFBPC=W_ITMREFBPC Endif
       If W_ITMDESBPC<>"" [F:ITU]ITMDESBPC=W_ITMDESBPC Endif
       Break
    Endif
 Else
    Break
 Endif
Next

Return

# ------------------------------------------------------------------
# Issue 89191 GA 04/2013
# ------------------------------------------------------------------
$CTL_PARAM_CSC
# --- Issue 89191 selon 82989 --- New System Variables
If dim(S_BOMALTREF)>0 & S_BOMALTREF>0  [F:CSC]BOMALTREF=S_BOMALTREF Endif
If dim(S_BOMALT)   >0 & S_BOMALT   >0  [F:CSC]BOMALT   =S_BOMALT    Endif
If dim(S_ROUALTREF)>0 & S_ROUALTREF>0  [F:CSC]ROUALTREF=S_ROUALTREF Endif
If dim(S_ROUALT)   >0 & S_ROUALT   >0  [F:CSC]ROUALT   =S_ROUALT    Endif
Return

#############################################################
# Routine de maj des enregistrements liés à ITM
# la classe [ITM] doit etre chargee
#############################################################
# Issue 82983 GA 06/2012 compléter si Article-Site inexistant
#############################################################
$UPD_ARTICLE
Call ECR_DEBUG("UPD_ARTICLE: "-[F:ITM]ITMREF)
# Issue 89191 GA 05/2013 pour comportement des UPD_ITx_FROM_ASW
If dim(WCRE)<=0 Local Shortint WCRE Endif : WCRE=W_CFGUPD
Local Char SAV_CURITM(GLONITM)
Local Char SAV_MODITM(GLONITM)
# Chargement du compose
#
  SAV_CURITM=S_CURITM
  SAV_MODITM=S_MODITM
  If [F:ITG]TCLCOD <> [F:ITM]TCLCOD
     Read [ITG]ITG0=S_FCY;[F:ITM]TCLCOD
     If fstat
        Read [ITG]ITG0="";[F:ITM]TCLCOD
        If fstat Raz [F:ITG] Endif
     Endif
  Endif
  If S_MODITM=""          # Reconfiguration
     S_MODITM=S_CURITM
     S_CURITM="_"+S_MODITM
     S_ITMSEL(0)=S_CURITM  # nécessaire pour MOD_ITMREF dans CFGLIBC
  Else                    # Reprise de configuration
     S_CURITM="_"+S_MODITM
     S_ITMSEL(0)=S_CURITM  # nécessaire pour MOD_ITMREF dans CFGLIBC
  Endif
  Read [F:ITM1]ITM0=S_CURITM
  If !fstat
    # Article intermédiaire existant: suppression préalable
     W_ITM=S_CURITM
     Gosub DEL_ARTICLE From CFGLIBC
  Endif
  If [F:CSC]BOMALT>0    # Issue 89746 GA 05/2013
    Read [BOH]BOH0=S_CURITM;[F:CSC]BOMALT;[F:CSC]BOMALTTYP
    If !fstat
      # Nomenclature intermédiaire existante: suppression préalable
       W_ITM=S_CURITM
       Gosub DEL_NOMENCL  From CFGLIBC
    Endif
  Endif
  If [F:CSC]ROUALT>0    # Issue 89746 GA 05/2013
    Read [ROH]ROH0=S_CURITM;[F:CSC]ROUALT;S_FCY
    If !fstat
      # Gamme intermédiaire existante: suppression préalable
       W_ITM=S_CURITM
       Gosub DEL_GAMME  From CFGLIBC
    Endif
  Endif
  GOK=1
  S_PHASE=2
  S_SEQ=0
  #
  W_ITM=S_MODITM

  # Issue 112120 - 2016-03-11 by STLIG : Don't re-read product records.
  If (dim(S_MODITM)>0 & S_MODITM="")
    Gosub LEC_ITM From CFGLIBB # Issue 89191 GA 06/2013
  Endif

  #
  [F:ITM]ITMREF=S_CURITM
  Gosub UPD_VAR_FROM_ASW     # Issue 93960 GA 10/2013
  #
  Gosub UPD_ITM_FROM_ASW     # Issue 89191 GA 05/2013
  Gosub UPD_ITF_FROM_ASW     # Issue 89191 GA 06/2013
  Gosub UPD_ITC_FROM_ASW     # Issue 89191 GA 06/2013
  Gosub UPD_ITU_FROM_ASW     # Issue 89191 GA 06/2013
  Gosub UPD_ITS_FROM_ASW     # Issue 89191 GA 06/2013
  Gosub UPD_ITP_FROM_ASW     # Issue 89191 GA 06/2013
  #
  # Issue 87724 GA 05/2014
  If (GOK<>1 | S_ABORT) Goto UPD_ARTICLE_ERR Endif
  #
  Gosub ECR_ARTICLE From CFGLIBC
  If GOK <> 1 Goto UPD_ARTICLE_ERR Endif

  # Issue 113260 - 2016-07-11 by STLIG : Copy Product description translations from S_MODITM to S_CURITM (temp. product)
  Call COPY_AXX_ITM(S_MODITM,S_CURITM)

  #
  # Issue 93960 GA 10/2013 Create BOM/ROUTING
  If [F:CSC]BOMALT>0
    Raz [F:BOH]
    Gosub INI_BOH From WUVAR
    Gosub CREATE_BOM From CFGLIBC   # Création ex-nihilo
    If GOK <> 1 Goto UPD_ARTICLE_ERR Endif
  Endif
  If [F:CSC]ROUALT>0
    Raz [F:ROH] : Raz [F:ROO] : Raz [F:ROS]
    Gosub INI_ROH From WUVAR
    Gosub CREATE_ROUTING From CFGLIBC # Création ex-nihilo
    If GOK <> 1 Goto UPD_ARTICLE_ERR Endif
  Endif
  #
  S_PHASE = 3
  S_SEQ   = 0
  S_OPS   = 0
  Gosub UPD_VAR_FROM_ASW     # Issue 93960 GA 10/2013 Reinit Variables
  #
  # Issue 102652 GA 01/2015 don't loose existing BOM's !
  #If [F:CSC]BOMALT>0         # Issue 89746 GA 05/2013
    Gosub UPD_BOM            # Issue 89191 GA 04/2013 copy previous BOM
    If GOK <> 1 Goto UPD_ARTICLE_ERR Endif
  #Endif
  # Issue 102652 GA 01/2015 don't loose existing ROU's !
  #If [F:CSC]ROUALT>0         # Issue 89746 GA 05/2013
    Gosub UPD_ROU            # Issue 89191 GA 04/2013 copy previous ROUTING
    If GOK <> 1 Goto UPD_ARTICLE_ERR Endif
  #Endif
  W_COM=1  # Pas de validation si W_COM reste à 0
  If [F:ITM]ITMREF<>SAV_CURITM
     Read [ITM]ITM0=SAV_CURITM
  Endif
  If S_CURITM<>SAV_CURITM S_CURITM=SAV_CURITM Endif
  If S_MODITM<>SAV_MODITM S_MODITM=SAV_MODITM Endif
Return
$UPD_ARTICLE_ERR
If GOK<>1  # Article intermédiaire: suppression
  W_ITM=S_CURITM
  Gosub DEL_ARTICLE From CFGLIBC
  If W_BOH=1 Gosub DEL_NOMENCL  From CFGLIBC Endif
  If W_ROH=1 Gosub DEL_GAMME  From CFGLIBC Endif
Endif
If S_CURITM<>SAV_CURITM S_CURITM=SAV_CURITM Endif
If S_MODITM<>SAV_MODITM S_MODITM=SAV_MODITM Endif
Return

#############################################################
# Routine de maj des enregistrements Nomenclature
# la classe [ITM] doit etre chargee     #### Issue 89191 ####
#############################################################
$UPD_BOM
If [F:CSC]CMPFLG<>2 Return Endif
Call ECR_DEBUG("UPD_NOMENCL:")
If dim(WCRE)<=0 Local Shortint WCRE Endif : WCRE=W_CFGUPD
Local Char WIDENT1 (GLONDES) : WIDENT1=""
If clalev([F:BOHW])  = 0 : Local File BOM       [BOHW] : Endif
If clalev([F:BODW])  = 0 : Local File BOMD      [BODW] : Endif
If S_MODITM <> "" WIDENT1=S_MODITM Else WIDENT1=W_RIT Endif
If WIDENT1<>""
  # Issue 89191 si reprise de configuration: copie SANS maj des autres BOH/BOD associés à l'article maj
   Filter [BOH] Where ITMREF = WIDENT1 & (BOMALT<>[F:CSC]BOMALT | BOMALTTYP<>[F:CSC]BOMALTTYP)
   For [BOH]
       # Issue 89095 GA 06/2013 # Copie pour maj des textes DUP_BOH_TEX
       [F:BOHW] = [F:BOH]

       [F:BOH]ITMREF = S_CURITM
       Gosub ECR_BOH From CFGLIBC
       If GOK <> 1 Break Endif

       Gosub DUP_BOH_TEX # Issue 89095 GA 06/2013

       Filter [BOD] Where ITMREF = WIDENT1 & BOMALT=[F:BOH]BOMALT & BOMALTTYP=[F:BOH]BOMALTTYP
       For [BOD]
           [F:BOD]ITMREF = S_CURITM
           Gosub ECR_BOD From CFGLIBC
           If GOK <> 1 Break Endif
       Next
       Filter [BOD]
       If GOK <> 1 Break Endif

   Next
   Filter [BOH]
Endif
GOK=1
# Issue 102652 GA 01/2015 only if scenario with BOM update
If [F:CSC]CMPFLG=2 & [F:CSC]BOMALT>0
  # Issue 93690 GA 10/2013 new BOM created immediatly after ECR_ARTICLE
  #Read [BOH]BOH0=S_CURITM;[F:CSC]BOMALT;[F:CSC]BOMALTTYP
  #If fstat
  #   # Issue 90585 GA 06/2013 Raz déplacée depuis CFGLIBC/CREATE_BOM
  #   Raz [F:BOH]
  #   Gosub INI_BOH From WUVAR
  #   Gosub CREATE_BOM From CFGLIBC   # Création ex-nihilo
     Gosub UPD_CURRENT_BOM           # Maj selon saisie dans S_MODITM et réponses scénario
  #Else
  #   W_BOH=1
  #Endif
Endif
Return
# Cas particulier: maj de la nomenclature courante
$UPD_CURRENT_BOM
Local Integer WCPT  : WCPT=-1
If dim(WCRE)<=0 Local Shortint WCRE Endif : WCRE=2 # forcer la maj des réponses
If clalev([F:BOHW])  = 0 : Local File BOM       [BOHW] : Endif
If clalev([F:BODW])  = 0 : Local File BOMD      [BODW] : Endif
#
Read [BOH]BOH0=S_CURITM;[F:CSC]BOMALT;[F:CSC]BOMALTTYP
If fstat Return Endif
Read [BOHW]BOH0=S_MODITM;[F:CSC]BOMALT;[F:CSC]BOMALTTYP
If !fstat
  [F:BOH]=[F:BOHW]
  [F:BOH]ITMREF=S_CURITM
  [F:BOH]CFGVCRNUM=S_CPTCFG
  [F:BOH]UPDUSR=GUSER
  [F:BOH]UPDDAT=date$
Endif

S_PHASE = 2
S_SEQ   = 0
S_OPS   = 0
Gosub UPD_BOH_FROM_ASW
#
Local Char W_CODKEY1(250)   # Issue 89095 GA 06/2013
Call FIND_LNK("BOM","[F:BOH]","BOMDESAXX","CLECUR1",W_CODKEY1) From CFGLIBC1
If W_CODKEY1<>""
   [F:BOH]IDENT1 = evalue(W_CODKEY1)
Else
   [F:BOH]IDENT1 = [F:BOH]ITMREF + "~" + num$([F:BOH]BOMALT)  # Issue 89191
Endif
Gosub ECR_BOH_TEX
# Issue 108077 GA 05/2015 - suite issue 89095 - remaining fields with type TXC
Call CRE_TYPTEX("BOM") From CFGLIBC
#
Rewrite [BOH]
WCPT=0
S_PHASE = 5
S_SEQ   = 0
#
Filter [BOD] Where ITMREF = S_CURITM & BOMALT=[F:BOH]BOMALT & BOMALTTYP=[F:BOH]BOMALTTYP
For [BOD]
    #Read [BODW]BOD0=S_MODITM;[F:BOD]BOMALT;[F:BOD]BOMSEQ;[F:BOD]CPNITMREF;[F:BOD]BOMALTTYP
    Filter [BODW] Where ITMREF = S_MODITM & BOMALT=[F:BOH]BOMALT & BOMALTTYP=[F:BOH]BOMALTTYP & BOMSEQ=[F:BOD]BOMSEQ
    For [BODW]
       If [F:BOD]CPNITMREF=[F:BODW]CPNITMREF # Si et seulement si même composant
          [F:BOD]=[F:BODW]
          [F:BOD]ITMREF=S_CURITM
          # Issue 93690 GA 10/2013 à faire sur tous les composants because variables Cofel
          #S_SEQ = [F:BOD]BOMSEQ
          #Gosub UPD_BOD_FROM_ASW
          Break
       Endif
    Next
    Filter [BODW]
   # Issue 93690 GA 10/2013 redondant mais nécessaire sur les lignes nouvellement créées
    S_SEQ = [F:BOD]BOMSEQ
    Gosub UPD_BOD_FROM_ASW
    # Issue 108077 GA 05/2015 - suite issue 89095 - remaining fields with type TXC
    Call CRE_TYPTEX("BOMD") From CFGLIBC
    Rewrite [BOD]
    WCPT+=1
Next
Filter [BOD]

If WCPT=0
 Call ECR_DEBUG("UPD_CURRENT_BOM: Pas de composants dans la nomenclature courante"-S_MODITM)
 If [F:BOHW]ITMREF<>""
    Delete [BOHW] Curr
 Endif
Else
 Call ECR_DEBUG("UPD_CURRENT_BOM: Nouvelle nomenclature créée ex-nihilo"-S_CURITM-S_FCY-num$([F:CSC]BOMALT))
Endif
Return
#############################################################
# Routine de maj des enregistrements Gamme
# la classe [ITM] doit etre chargee     #### Issue 89191 ####
#############################################################
$UPD_ROU
If [F:CSC]ROUFLG<>2 Return Endif
Call ECR_DEBUG("UPD_GAMME:")
If dim(WCRE)<=0 Local Shortint WCRE Endif : WCRE=W_CFGUPD
If clalev([F:ROHW])  = 0 : Local File ROUTING    [ROHW]  : Endif
If clalev([F:ROOW])  = 0 : Local File ROUOPE     [ROOW]  : Endif
If clalev([F:ROSW])  = 0 : Local File ROUSCD     [ROSW]  : Endif
If S_MODITM <> "" WIDENT1=S_MODITM Else WIDENT1=W_RIT Endif
If WIDENT1<>""
  # Issue 89191 si reprise de configuration: copie SANS maj des autres ROH/ROO associés à l'article maj
   Filter [ROH] Where ITMREF = WIDENT1 & (FCY<>S_FCY | ROUALT<>[F:CSC]ROUALT)
   For [ROH]
       # Issue 89095 GA 06/2013 # Copie pour maj des textes DUP_ROH_TEX
       [F:ROHW] = [F:ROH]

       [F:ROH]ITMREF = S_CURITM
       Gosub ECR_ROH From CFGLIBC
       If GOK<>1 : Break : Endif

       Gosub DUP_ROH_TEX # Issue 89095 GA 06/2013

       Filter [ROO] Where ITMREF = WIDENT1 & FCY=[F:ROH]FCY & ROUALT=[F:ROH]ROUALT
       For [ROO]
           [F:ROO]ITMREF = [F:ROH]ITMREF
           Gosub ECR_ROO From CFGLIBC
           If GOK<>1 : Break : Endif

           Filter [ROS] Where ITMREF = WIDENT1 & FCY=[F:ROH]FCY & ROUALT=[F:ROH]ROUALT & OPENUM=[F:ROO]OPENUM
           For [ROS]
               [F:ROS]ITMREF = [F:ROH]ITMREF
               Gosub ECR_ROS From CFGLIBC
               If GOK<>1 : Break : Endif
           Next
           Filter [ROS]
           If GOK<>1 : Break : Endif

       Next
       Filter [ROO]
       If GOK<>1 : Break : Endif

   Next
   Filter [ROH]
Endif
GOK=1
# Issue 102652 GA 01/2015 only if scenario with ROU update
If [F:CSC]ROUFLG=2 & [F:CSC]ROUALT>0
  # Issue 93690 GA 10/2013 new ROUTING created immediatly after ECR_ARTICLE
  #Read [F:ROH]ROH0=S_CURITM;[F:CSC]ROUALT;S_FCY   : # Beryl Site en fin de clé primaire
  #If fstat
  #   # Issue 90585 GA 06/2013 Raz déplacée depuis CFGLIBC/CREATE_BOM
  #   Raz [F:ROH] : Raz [F:ROO] : Raz [F:ROS]
  #   Gosub INI_ROH From WUVAR
  #   Gosub CREATE_ROUTING From CFGLIBC # Création ex-nihilo
     Gosub UPD_CURRENT_ROUTING         # Maj selon saisie dans S_MODITM et réponses scénario
  #Else
  #   W_ROH=1
  #Endif
Endif
S_CURROU=S_CURITM
Return
# Cas particulier: maj de la gamme courante
$UPD_CURRENT_ROUTING
If clalev([F:ROHW])  = 0 : Local File ROUTING    [ROHW]  : Endif
If clalev([F:ROOW])  = 0 : Local File ROUOPE     [ROOW]  : Endif
If clalev([F:ROSW])  = 0 : Local File ROUSCD     [ROSW]  : Endif
If dim(WCRE)<=0 Local Shortint WCRE Endif : WCRE=2 # forcer la maj des réponses
Local Integer WCPT  : WCPT=-1

Read [ROH]ROH0=S_CURITM;[F:CSC]ROUALT;S_FCY
If fstat Return Endif
Read [ROHW]ROH0=S_MODITM;[F:CSC]ROUALT;S_FCY
If !fstat
  [F:ROH]=[F:ROHW]
  [F:ROH]ITMREF=S_CURITM
  [F:ROH]CFGVCRNUM=S_CPTCFG
  [F:ROH]UPDUSR=GUSER
  [F:ROH]UPDDAT=date$
Endif
S_PHASE = 2
S_SEQ   = 0
S_OPS   = 0
Gosub UPD_ROH_FROM_ASW
#
Local Char W_CODKEY1(250)   # Issue 89095 GA 06/2013
Call FIND_LNK("ROUTING","[F:ROH]","ROUDESAXX","CLECUR1",W_CODKEY1) From CFGLIBC1
If W_CODKEY1<>""
   [F:ROH]IDENT1 = evalue(W_CODKEY1)
Else
   [F:ROH]IDENT1 = [F:ROH]ITMREF + "~" + num$([F:ROH]ROUALT) # Issue 89191
Endif
Gosub ECR_ROH_TEX
#
# Issue 108077 GA 05/2015 - suite issue 89095 - remaining fields with type TXC
Call CRE_TYPTEX("ROUTING") From CFGLIBC
#
Rewrite [ROH]
S_PHASE = 8
WCPT=0
#
Filter [ROO] Where ITMREF = S_CURITM & FCY=S_FCY & ROUALT=[F:CSC]ROUALT
For [ROO]
   S_OPS   = [F:ROO]STDOPENUM  # Issue 93691 GA 10/2013 avant [F:ROO]OPENUM
   S_SEQ   = [F:ROO]OPENUM     # Issue 97528 GA 03/2014 S_SEQ nécessaire/ajouté
   Read [ROOW]ROO0=[F:ROO]FCY;S_MODITM;[F:ROO]ROUALT;[F:ROO]OPENUM;[F:ROO]RPLIND
   If !fstat & S_OPS=[F:ROOW]STDOPENUM
     [F:ROO]=[F:ROOW]
     [F:ROO]ITMREF = S_CURITM
   Endif
   Gosub UPD_ROO_FROM_ASW
   # Issue 108077 GA 05/2015 - suite issue 89095 - remaining fields with type TXC
   Call CRE_TYPTEX("ROUOPE") From CFGLIBC
   Rewrite [ROO]
   WCPT+=1

   Filter [ROS] Where ITMREF = S_CURITM & FCY=S_FCY & ROUALT=[F:ROO]ROUALT & OPENUM=[F:ROO]OPENUM
   For [ROS]
       Read [ROSW]ROS0=[F:ROS]FCY;S_MODITM;[F:ROS]ROUALT;[F:ROS]OPENUM
       If !fstat
         [F:ROS]=[F:ROSW]
         [F:ROS]ITMREF = S_CURITM
       Endif
       Gosub UPD_ROS_FROM_ASW
       # Issue 108077 GA 05/2015 - suite issue 89095 - remaining fields with type TXC
       Call CRE_TYPTEX("ROUSCD") From CFGLIBC
       Rewrite [ROS]
   Next
   Filter [ROS]
   If GOK<>1 : Break : Endif

Next
Filter [ROO]

If WCPT=0
 Call ECR_DEBUG("UPD_CURRENT_ROUTING: Pas d opérations dans la gamme courante"-S_MODITM-S_FCY-num$([F:CSC]ROUALT))
 If [F:ROHW]ITMREF<>""
    Delete [ROHW] Curr
 Endif
Else
 Call ECR_DEBUG("UPD_CURRENT_ROUTING: Nouvelle gamme créée ex-nihilo"-S_CURITM-S_FCY-num$([F:CSC]ROUALT))
Endif
Return
############################################################
# SAICFG: liste de paramètres
#   SCENUM    Scénario
#   FCY       Site
#   BPRNUM    Numéro tiers
#   BPRREF    Référence tiers
#   REFDAT    Date de référence
#   OPTION    Option
#   BOMALTREF Alt.nom. référence         --- Issue 82989 ---
#   BOMALT    Alternative nomencl        --- Issue 82989 ---
#   ROUALTREF Alt. gamme référence       --- Issue 82989 ---
#   ROUALT    Alt. gamme                 --- Issue 82989 ---
############################################################
$CHARGE_PARAM_SAICFG
[M:CFGF]CFGOPT = 1
[M:CFGF]SCENUM = PARAM(1)
[M:CFGF]FCY    = PARAM(2)
[M:CFGF]BPRNUM = PARAM(3)
[M:CFGF]BPRREF = PARAM(4)
[M:CFGF]IPTDAT = PARAM(5)
If [M:CFGF]FCY = ""
  [M:CFGF]FCY = GFCYDEF(0)
Endif
If [M:CFGF]IPTDAT = [0/0/0]
  [M:CFGF]IPTDAT = date$
Endif
# Issue 82989 GA 06/2012
Call AM_SCENUM(PARAM(01)) From SUBCFGF

# --- Issue 82989 --- New parameters for SAICFGSCE
If val(PARAM(7)) >0  [F:CSC]BOMALTREF=val(PARAM(7))  Endif
If val(PARAM(8)) >0  [F:CSC]BOMALT   =val(PARAM(8))  Endif
If val(PARAM(9)) >0  [F:CSC]ROUALTREF=val(PARAM(9))  Endif
If val(PARAM(10))>0  [F:CSC]ROUALT   =val(PARAM(10)) Endif

Return

#############################################################
# Calcul code plus bas niveau en génération
# GA 07/2012 déplacé depuis CFGLIBC car trop d'instructions
$MAJ_LLC
#
W_TRAMSG=mess(177,188,1)-"($MAJ_LLC)" : Gosub TRA_MSG From CFGLIBB

Close Local File      [ITB]
Local File ITMBOM     [ITB]      # travail sur la vrai table
Call DEBTRANS From GLOCK
$MAJ_LLC1
Trbegin [ITM]

#Gosub WRITE_ITB From LLCLIB
Gosub MAJ_ALLITB From CFGLIBD    # préparation ITB
If GOK = 1
    GNIV=0    # niveau de départ
    Call LLCUPD(S_CURITM,[F:CSC]BOMALT,[F:CSC]BOMALTTYP,"+") From LLCLIB
    If GOK<>10
        Goto MAJ_LLC_FIN
    Endif
Else
    Goto MAJ_LLC_FIN
Endif

$MAJ_LLC_FIN
Case GOK
  When 1  :
    Commit
  When -1 :
    Rollback
    W_TRAMSG=mess(179,188,1)-GLOCK : Gosub TRA_MSG From CFGLIBB        # suivi
    Call ROLL From GLOCK
    If !GROLL
      GOK=1 : Goto MAJ_LLC1
    Else
        GMESSAGE=W_TRAMSG                     # info trace sur lock
        Gosub TRA_ERR From CFGLIBB
        GMESSAGE=mess(181,188,1)                                      # Arrêt suite à une enreg. verrouillé
        GMESSAGE+="\"+mess(236,188,1) : Gosub TRA_ERR From CFGLIBB    # abandon nelle tentaive par utilisateur
    Endif
  When Default :
    Rollback
Endcase

Close Local File      [ITB]
Local File ITMBOMCFG  [ITB]         # Table configurateur

Return

########################################################################
# S_PHASE => Valeurs du menu local 764 'Type ligne scénario'
#  [M:CFP]PILPHA(I)   contient      [F:CSL]SCENUMTYP
# 1 - Sélection composé
# 2 - Création composé
# 3 - Sélection composants
# 4 - Liste composants
# 5 - Création composants
# 6 - Inutilisé
# 7 - Liste opérations
# 8 - Création opérations
# 9 - Contrôles finaux
########################################################################

# ------------------------------------------------------------------
# Issue 85230 GA 10/2012 code extrait de CFGLIBC (source trop long)
# Update [F:ITM] with current answers
# [M:CFP]PILTYP=13
# ------------------------------------------------------------------
$UPD_ITM_FROM_ASW
Local Integer WW_PILSTR : WW_PILSTR = [M:CFP]PILSTR # Issue 90585 GA 06/2013
Local Integer WW_PILIND : WW_PILIND = [M:CFP]PILIND # Issue 98937 GA 05/2014
Local Integer WW_PILREC : WW_PILREC = [M:CFP]PILREC # Issue 98937 GA 05/2014
    # Deroulement de la pile jusqu'aux enregistrements phase courante
    If [M:CFP]PILPHA([M:CFP]PILSTR) <> S_PHASE
       [M:CFP]PILREC = S_PHASE-1
       Gosub SKIP_PILE
    Endif
  For [M:CFP]PILIND = [M:CFP]PILSTR To [M:CFP]NBLIG-1
    If [M:CFP]PILPHA([M:CFP]PILIND) = S_PHASE &
&      [M:CFP]PILSEQ([M:CFP]PILIND) = S_SEQ   &
&      [M:CFP]PILTYP([M:CFP]PILIND) = 13      &
&     ([M:CFP]PILCOD([M:CFP]PILIND) = 7 | WCRE=2)
      If [M:CFP]PILSYM([M:CFP]PILIND) <> "ITMREF" | S_CURITM=""
        #If !(find([M:CFP]PILTYP([M:CFP]PILIND),4,5,8))
          Gosub TRT_SYMBOLE
          If (GOK<>1 | S_ABORT | W_MSG <> "")
            Break
          Endif
        #Endif
      Endif
    Elsif [M:CFP]PILPHA([M:CFP]PILIND)>S_PHASE
      Break
    Endif
  Next [M:CFP]PILIND
  [M:CFP]PILSTR = WW_PILSTR # Issue 90585 GA 06/2013
  [M:CFP]PILIND = WW_PILIND # Issue 98937 GA 05/2014
  [M:CFP]PILREC = WW_PILREC # Issue 98937 GA 05/2014
Return

# ------------------------------------------------------------------
# Issue 93690 GA 10/2013 Evalue current level variables
# [M:CFP]PILTYP=2
# ------------------------------------------------------------------
$UPD_VAR_FROM_ASW
Local Integer WW_PILSTR : WW_PILSTR = [M:CFP]PILSTR # Issue 90585 GA 06/2013
Local Integer WW_PILIND : WW_PILIND = [M:CFP]PILIND # Issue 98937 GA 05/2014
Local Integer WW_PILREC : WW_PILREC = [M:CFP]PILREC # Issue 98937 GA 05/2014
    # Deroulement de la pile jusqu'aux enregistrements phase courante
    If [M:CFP]PILPHA([M:CFP]PILSTR) <> S_PHASE
       [M:CFP]PILREC = S_PHASE-1
       Gosub SKIP_PILE
    Endif
  For [M:CFP]PILIND = [M:CFP]PILSTR To [M:CFP]NBLIG-1
# Issue 93690 GA 10/2013 evaluer les variables
# Issue 94693 & 87724 GA 11/2013 evaluer aussi lien table, procedure, message, etc ...
    If [M:CFP]PILPHA([M:CFP]PILIND) = S_PHASE &
&      [M:CFP]PILSEQ([M:CFP]PILIND) = S_SEQ   &
&     find([M:CFP]PILTYP([M:CFP]PILIND),2,6,7,8,9,24,25,26,27)  &
&     ([M:CFP]PILCOD([M:CFP]PILIND) = 7 | WCRE=2)
          Gosub TRT_SYMBOLE
          If (GOK<>1 | S_ABORT | W_MSG <> "")
            Break
          Endif
    Elsif [M:CFP]PILPHA([M:CFP]PILIND)>S_PHASE
      Break
    Endif
  Next [M:CFP]PILIND
  [M:CFP]PILSTR = WW_PILSTR # Issue 90585 GA 06/2013
  [M:CFP]PILIND = WW_PILIND # Issue 98937 GA 05/2014
  [M:CFP]PILREC = WW_PILREC # Issue 98937 GA 05/2014
Return

# ------------------------------------------------------------------
# Issue 85230 GA 10/2012 code extrait de CFGLIBC (source trop long)
# Update [F:ITC] with current answers
# [M:CFP]PILTYP=23
# ------------------------------------------------------------------
$UPD_ITC_FROM_ASW
# Scénario mono-site: Maj si et seulement si site courant
If [F:CSC]FCYFLG<>2 & [F:ITF]STOFCY<>S_FCY
   Return
Else
Local Integer WW_PILSTR : WW_PILSTR = [M:CFP]PILSTR # Issue 90585 GA 06/2013
Local Integer WW_PILIND : WW_PILIND = [M:CFP]PILIND # Issue 98937 GA 05/2014
Local Integer WW_PILREC : WW_PILREC = [M:CFP]PILREC # Issue 98937 GA 05/2014
    # Deroulement de la pile jusqu'aux enregistrements phase courante
    If [M:CFP]PILPHA([M:CFP]PILSTR) <> S_PHASE
       [M:CFP]PILREC = S_PHASE-1
       Gosub SKIP_PILE
    Endif
    For [M:CFP]PILIND = [M:CFP]PILSTR To [M:CFP]NBLIG-1
      If [M:CFP]PILPHA([M:CFP]PILIND) = S_PHASE &
&        [M:CFP]PILSEQ([M:CFP]PILIND) = S_SEQ   &
&        [M:CFP]PILTYP([M:CFP]PILIND) = 23      &
&        [M:CFP]PILSYM([M:CFP]PILIND) <> "ITMREF" &
&        ([M:CFP]PILCOD([M:CFP]PILIND) = 7 | WCRE=2)
        #If !(find([M:CFP]PILTYP([M:CFP]PILIND),4,5,8))
          Gosub TRT_SYMBOLE
          If (GOK<>1 | S_ABORT | W_MSG <> "")
            Break
          Endif
        #Endif
      Elsif [M:CFP]PILPHA([M:CFP]PILIND)>S_PHASE
        Break
      Endif
    Next [M:CFP]PILIND
    [M:CFP]PILSTR = WW_PILSTR # Issue 90585 GA 06/2013
    [M:CFP]PILIND = WW_PILIND # Issue 98937 GA 05/2014
    [M:CFP]PILREC = WW_PILREC # Issue 98937 GA 05/2014
Endif
Return

