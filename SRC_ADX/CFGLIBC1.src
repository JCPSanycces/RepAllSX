# Issue 84700 GA 11/2012 Cas des textes traduits Champ xxxAXX
$UPD_AXX_FROM_ASW

# Issue 107085 GA 03/2015 avoid the update of table ATEXTRA
If WNO_DEFAULT_TEXT=2 End Endif

Local Shortint WPILTYP,WWPHASE
Local Char W_VALKEY1(250),W_VALKEY2(250),W_MSG(250),W_ALP(250)
Local Integer WW_PILSTR : WW_PILSTR = [M:CFP]PILSTR # Issue 90585 GA 06/2013
Local Integer WW_PILIND : WW_PILIND = [M:CFP]PILIND # Issue 98937 GA 05/2014
Local Integer WW_PILREC : WW_PILREC = [M:CFP]PILREC # Issue 98937 GA 05/2014

  If dim(LFIC)<=0 | dim(W_VAL)<=0 | dim([M:CFP]PILAXXKEY1)<=0 Return Endif
  #Raz [M:CFP]PILSTR
  Case LFIC
    When "ITMMASTER"  : WPILTYP=13 : WWPHASE=S_PHASE # Article maitre
    When "ITMFACILIT" : WPILTYP=14 : WWPHASE=S_PHASE # Article site
    When "ITMMVT"     : WPILTYP=15 : WWPHASE=S_PHASE # Articles cumuls
    When "ITMSALES"   : WPILTYP=16 : WWPHASE=S_PHASE # Article ventes
    When "BOM"        : WPILTYP=17 : WWPHASE=2       # Entête nomenclature
    When "BOMD"       : WPILTYP=18 : WWPHASE=S_PHASE # Détail nomenclature
    When "ROUTING"    : WPILTYP=19 : WWPHASE=2       # Entête gamme
    When "ROUOPE"     : WPILTYP=20 : WWPHASE=S_PHASE # Opération gamme
    When "ITMBPC"     : WPILTYP=21 : WWPHASE=S_PHASE # Article client
    When "ROUSCD"     : WPILTYP=22 : WWPHASE=S_PHASE # Jalonnement opération
    When "ITMCOST"    : WPILTYP=23 : WWPHASE=S_PHASE # Article coûts
    When "ITMBPS"     : WPILTYP=28 : WWPHASE=S_PHASE # Article fournisseur
    When Default : Return
  Endcase

  # Deroulement de la pile jusqu'aux enregistrements phase courante
  If [M:CFP]PILPHA([M:CFP]PILSTR) <> WWPHASE
     [M:CFP]PILREC = WWPHASE-1
     Gosub SKIP_PILE
  Endif

  For [M:CFP]PILIND = [M:CFP]PILSTR To [M:CFP]NBLIG-1
    If [M:CFP]PILTYP([M:CFP]PILIND) = WPILTYP
&   & ([M:CFP]PILCOD([M:CFP]PILIND) = 7 | WCRE=2)
&   &  [M:CFP]PILAXXKEY1([M:CFP]PILIND)<>""
    #
      If [M:CFP]PILAXXKEY1([M:CFP]PILIND)<>""
           W_VALKEY1 = evalue([M:CFP]PILAXXKEY1([M:CFP]PILIND))
      Else W_VALKEY1 = "" Endif
    #
      If [M:CFP]PILAXXKEY2([M:CFP]PILIND)<>""
           W_VALKEY2 = evalue([M:CFP]PILAXXKEY2([M:CFP]PILIND))
      Else W_VALKEY2 = "" Endif
    #
      If S_MEMO=2  # Issue 92289 GA 12/2013 ssi relecture demandée
        Read [F:CME]CME0=0;S_SCENUM;GUSER;S_BPRNUM;S_BPRREF;[M:CFP]PILSYM([M:CFP]PILIND);[M:CFP]PILIND
        If fstat       Raz [F:CME]    Endif
      Else Raz [F:CME] Endif
    #
      If [F:CME]VALALP<>"" & W_VALKEY1<>""
          Call MAJTEXTRA([F:CME]VALALP, LFIC, [M:CFP]PILSYM([M:CFP]PILIND),W_VALKEY1,W_VALKEY2) From ATEXTRA
          If S_TRAFLG>=3
             W_TRA="UPD_AXX_FROM_ASW: Translated text inserted for"-LFIC- [M:CFP]PILSYM([M:CFP]PILIND)-W_VALKEY1-W_VALKEY2-"["+[F:CME]VALALP+"]"
             Call ECR_TRACE(W_TRA,0) # From GESECRAN
          Endif
      Elsif S_TRAFLG>=3 & [F:CME]VALALP<>""
          W_TRA="UPD_AXX_FROM_ASW: Translated text NOT inserted for"-LFIC- [M:CFP]PILSYM([M:CFP]PILIND)-W_VALKEY1-W_VALKEY2-"["+[F:CME]VALALP+"]"
          Call ECR_TRACE(W_TRA,0) # From GESECRAN
      Endif
    Endif
  Next [M:CFP]PILIND
  [M:CFP]PILSTR = WW_PILSTR # Issue 90585 GA 06/2013
  [M:CFP]PILIND = WW_PILIND # Issue 98937 GA 05/2014
  [M:CFP]PILREC = WW_PILREC # Issue 98937 GA 05/2014
Return
########################################################################
$WRITE_ITU                                               # Issue 89191 #
Local Shortint ICPT : Raz ICPT
    If [F:ITU]ITMREFBPC="" [F:ITU]ITMREFBPC=[F:ITU]ITMREF Endif  # Issue 89191 GA 04/2013 ligne ajoutée
    [F:ITU]CFGVCRNUM = S_CPTCFG                                  # Issue 89191 GA 04/2013 ligne ajoutée
    [F:ITU]EXPNUM    = [C]EXPORT
    [F:ITU]CREUSR    = GUSER
    [F:ITU]CREDAT    = date$
    [F:ITU]UPDUSR    = ""
    [F:ITU]UPDDAT    = [0/0/0]
    Gosub PE_BEFWRIITU From CFGLIBC
    If !GPE
      Call ECR_DEBUG("Insert ITU="-[F:ITU]ITMREF-[F:ITU]BPCNUM-[F:ITU]ITMREFBPC) From CFGLIBC1
    Else Return Endif
$WRITE_ITU1
    Write [ITU]
    Case fstat
      When 0 :
      When 3 :
        # Issue 85371 If [F:ITU]ITMREFBPC=""
        If [F:ITU]ITMREFBPC <> [F:ITM]ITMREF+num$(ICPT) & ICPT<10
          ICPT+=1
          [F:ITU]ITMREFBPC = [F:ITM]ITMREF+num$(ICPT)
          Goto WRITE_ITU1
        Endif
      When Default :
        GOK = 0
        Call FSTACTX("ITU",W_TRASTP,"$ECR_ART_ITU") From CFGLIBD  # From GLOCK
    Endcase
Return
########################################################################
$REWRITE_ITU                                             # Issue 89191 #
Local Shortint ICPT : Raz ICPT
    Call ECR_DEBUG("Update ITU="-[F:ITU]ITMREF-[F:ITU]BPCNUM-[F:ITU]ITMREFBPC) From CFGLIBC1
    If [F:ITU]ITMREFBPC="" [F:ITU]ITMREFBPC=[F:ITU]ITMREF Endif  # Issue 89191 GA 04/2013 ligne ajoutée
    [F:ITU]CFGVCRNUM = S_CPTCFG                                  # Issue 89191 GA 04/2013 ligne ajoutée
    [F:ITU]UPDUSR    = GUSER
    [F:ITU]UPDDAT    = date$
    Gosub PE_BEFREWITU From CFGLIBC
$REWRITE_ITU1
    Rewrite [ITU]  # Issue 96443 GA 03/2014 avant Write [ITU]
    Case fstat
      When 0 :
      When 3 :
        If [F:ITU]ITMREFBPC <> [F:ITM]ITMREF+num$(ICPT) & ICPT<10
          ICPT+=1
          [F:ITU]ITMREFBPC = [F:ITM]ITMREF+num$(ICPT)
          Goto REWRITE_ITU1
        Endif
      When Default :
        GOK = 0
        Call FSTACTX("ITU",W_TRASTP,"$ECR_ART_ITU") From CFGLIBD  # From GLOCK
    Endcase
Return
########################################################################
$WRITE_ITP                                               # Issue 89191 #
Local Shortint ICPT : Raz ICPT
    If [F:ITP]ITMREFBPS="" [F:ITP]ITMREFBPS=[F:ITP]ITMREF Endif  # Issue 89191 GA 04/2013 ligne ajoutée
    [F:ITP]CFGVCRNUM = S_CPTCFG                                  # Issue 89191 GA 04/2013 ligne ajoutée
    If [F:ITP]PUU=""                                             # ISsue 89251 GA 02/2014 champ obligatoire
       [F:ITP]PUU=[F:ITM]PUU
       [F:ITP]PUUSTUCOE=[F:ITM]PUUSTUCOE
    Endif
    [F:ITP]EXPNUM    = [C]EXPORT
    [F:ITP]CREUSR    = GUSER
    [F:ITP]CREDAT    = date$
    [F:ITP]UPDUSR    = ""
    [F:ITP]UPDDAT    = [0/0/0]
    Gosub PE_BEFWRIITP From CFGLIBC
    If !GPE
      Call ECR_DEBUG("Insert ITP="-[F:ITP]ITMREF-[F:ITP]BPSNUM-[F:ITP]ITMREFBPS) From CFGLIBC1
    Else Return Endif
$WRITE_ITP1
    Write [ITP]
    Case fstat
      When 0 :
      When 3 :
        # Issue 85371 If [F:ITP]ITMREFBPS=""
        If [F:ITP]ITMREFBPS <> [F:ITM]ITMREF+num$(ICPT) & ICPT<10
          ICPT+=1
          [F:ITP]ITMREFBPS = [F:ITM]ITMREF+num$(ICPT)
          Goto WRITE_ITP1
        Endif
      When Default :
        GOK = 0
        Call FSTACTX("ITP",W_TRASTP,"$ECR_ART_ITP") From CFGLIBD  # From GLOCK
    Endcase
Return
########################################################################
$REWRITE_ITP                                             # Issue 89191 #
Local Shortint ICPT : Raz ICPT
    Call ECR_DEBUG("Update ITP="-[F:ITP]ITMREF-[F:ITP]BPSNUM-[F:ITP]ITMREFBPS) From CFGLIBC1
    If [F:ITP]ITMREFBPS="" [F:ITP]ITMREFBPS=[F:ITP]ITMREF Endif  # Issue 89191 GA 04/2013 ligne ajoutée
    [F:ITP]CFGVCRNUM = S_CPTCFG                                  # Issue 89191 GA 04/2013 ligne ajoutée
    [F:ITP]UPDUSR    = GUSER
    [F:ITP]UPDDAT    = date$
    Gosub PE_BEFREWITP From CFGLIBC
$REWRITE_ITP1
    Rewrite [ITP]
    Case fstat
      When 0 :
      When 3 :
        If [F:ITP]ITMREFBPS <> [F:ITM]ITMREF+num$(ICPT) & ICPT<10
          ICPT+=1
          [F:ITP]ITMREFBPS = [F:ITM]ITMREF+num$(ICPT)
          Goto REWRITE_ITP1
        Endif
      When Default :
        GOK = 0
        Call FSTACTX("ITP",W_TRASTP,"$ECR_ART_ITP") From CFGLIBD  # From GLOCK
    Endcase
Return
############################################################
# Ecriture texte(s) entete nomenclature [BOH]
$ECR_BOH_TEX
Local Char SZDESAXX(GLONDES)

SZDESAXX = mess(59,188,1)
#Call LECTEXTRA(SZDESAXX,"BOM","BOMDESAXX",[F:BOH]ITMREF+"~"+num$([F:BOH]BOMALT),num$([F:BOH]BOMALTTYP)) From ATEXTRA
Call LEC_AXX_FIC("BOM","[F:BOH]","BOMDESAXX",SZDESAXX)

# Issue 106493 GA 05/2015 if text is not updated by configurator script parameters ...
If find(SZDESAXX,"",mess(59,188,1)) & dim([F:BOHW]ITMREF)>0 & [F:BOHW]ITMREF=S_MODITM
   Call LEC_AXX_FIC("BOM","[F:BOHW]","BOMDESAXX",SZDESAXX)
Endif

#If SZDESAXX = "" | SZDESAXX = mess(59,188,1)
  If dim([F:BOH]BOMDES)>0 & [F:BOH]BOMDES <> ""  # Issue 84700 GA 11/2012
    SZDESAXX = [F:BOH]BOMDES
#  Else
#    SZDESAXX = mess(59,188,1)
  Endif

  # Issue 107085 GA 03/2015 too many access to this table ATEXTRA
  If WNO_DEFAULT_TEXT=2 | (WNO_DEFAULT_TEXT=1 & SZDESAXX=mess(59,188,1)) Return Endif

  Call UPD_AXX_FIC("BOM","[F:BOH]","BOMDESAXX",SZDESAXX)
#Else
#  # Texte déjà ok
#Endif
Return
