#<AdxTL>@(#)43.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","DEVERROU","SAIDOS",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "EXEC" : Gosub EXEC
Endcase
Return

$EXEC
If [M]DOSSIER<>""
 If func DOSSUB.ISHISTFOLD([M]DOSSIER)         #X3-61702 - must specify screen [M]DOSSIER
  Local File =[M]DOSSIER+".ADOVALHIS" [AHW]
  Trbegin [AHW]
   Update [AHW] Where CMP="" & FCY="" & PARAM="MONO" With VALEUR = "0"
  Commit
  Close Local File [AHW]
 Else
  Local File =[M]DOSSIER+".ADOVAL" [ADW]
  Trbegin [ADW]
   Update [ADW] Where CMP="" & FCY="" & PARAM="MONO" With VALEUR = "0"
  Commit
  Close Local File [ADW]
 Endif
Endif
Return

