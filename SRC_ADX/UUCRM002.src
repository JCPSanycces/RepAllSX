# FGR 17/02/2009 : X3SUIVI53266
# Moulinette pour Initialiser OPPSTEADI avec la bonne table diverse.

  Call MAJ_UTICRM002(nomap)
End

########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  Call MAJ_UTICRM002(APPLI)
End

########################################################################
Subprog MAJ_UTICRM002(DOSSIER)
Value Char DOSSIER

Local Integer IERR

  If DOSSIER = "X3" Then
    End 
  Endif
  #------------------------------------------------------
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("DOSSIER : "+DOSSIER) From DOSSUB
  Call ECR_TIME("correction de la gestion de l'étape en cours") From DOSSUB
  #------------------------------------------------------
  IERR = 0
  Call ECR_TIME("DEBUT => Affaire (OPP)") From DOSSUB
  Call CRMSTEP3(DOSSIER, IERR) From CRMMAJ30
  Call ECR_TIME("FIN => Affaire (OPP)") From DOSSUB
  #------------------------------------------------------
End
