#<AdxTL>@(#)8.0.0.0 $Revision$
#######################################################################
# SUBCNTW   : Traitement lié à l'écran CNTW                           #
#             Ecran de sélection d'un contact                         #
#######################################################################
#######################################################################
# SAISELCNT : Action liée à l'écran CNTW                              #
#             Action de sélection d'un contact                        #
#######################################################################
#--- Actions liés au type fenêtre de saisie
$ACTION
Case ACTION 
 When "OUVRE"         : Gosub OUV_SAISELCNT
 When "DEBUT"         : Gosub DEB_SAISELCNT
 When "OK"            : Gosub OK_SAISELCNT
 When "ABA"           : Gosub ABA_SAISELCNT
Endcase
Return
#------------------------------------------------------------------------------#
$OUV_SAISELCNT
Local Integer LTYP    :    LTYP = val(PARAM(1))
Local Char    LNUM    :    LNUM = PARAM(2)
Local Char    LNAM    :    LNAM = PARAM(3)

If clalev([F:CNT]) = 0 Local File CONTACT    [CNT] : Endif
If clalev([F:AIN]) = 0 Local File CONTACTCRM [AIN] : Endif
If clalev([F:BPA]) = 0 Local File BPADDRESS  [BPA] : Endif
If clalev([F:TCY]) = 0 Local File TABCOUNTRY [TCY] : Endif

Return
#------------------------------------------------------------------------------#
$DEB_SAISELCNT

Raz [M:CNTW]
[M:CNTW]BPATYP    = LTYP
[M:CNTW]BPANUM    = LNUM
[M:CNTW]BPANAM(0) = LNAM(0)
[M:CNTW]BASPAG1    = 0
Filter [CNT] Where BPATYP = LTYP & BPANUM = LNUM
&             Order By Key CNT0
For [CNT]
  If [M:CNTW]BASPAG1 < dim([M:CNTW]CCNCRM)-1
    [M:CNTW]CCNCRM([M:CNTW]BASPAG1) = [F:CNT]CCNCRM
    Read [AIN]AIN0 =[F:CNT]CCNCRM
    If fstat : Raz [F:AIN] : Endif
    [M:CNTW]XCNTLNA([M:CNTW]BASPAG1)= [F:AIN]CNTLNA 
    [M:CNTW]BASPAG1 += 1
    If VALEUR = [M:CNTW]CCNCRM([M:CNTW]BASPAG1-1) nolign=[M:CNTW]BASPAG1 Endif
  Endif
Next
Filter [CNT]
If nolign=0 nolign = 1 Endif

If [M:CNTW]BASPAG1 = 0 
    GMESSAGE = mess(99,100,1) : GERR= 1 : FIN=1 
Else 
    Affzo [M:CNTW]
Endif

zonsui = "BASPAG1("+num$(nolign-1)+")"

Return
#------------------------------------------------------------------------------#
$OK_SAISELCNT

VALEUR = [M:CNTW]CCNCRM(nolign-1)
FIN=1

Return 
#------------------------------------------------------------------------------#
$ABA_SAISELCNT

VALEUR = ""

Return
#######################################################################
#--- Actions liés à l'écran CNTW             
Subprog AS_BASPAG1

  If nolign>[M:CNTW]BASPAG1 End Endif

  Local Integer SNOLIGN
  SNOLIGN = nolign

  If clalev([F:CNT]) = 0 Local File CONTACT    [CNT] : Endif
  If clalev([F:AIN]) = 0 Local File CONTACTCRM [AIN] : Endif
  If clalev([F:BPA]) = 0 Local File BPADDRESS  [BPA] : Endif

  Read [CNT]CNT0 =[M:CNTW]BPATYP;[M:CNTW]BPANUM;[M:CNTW]CCNCRM(nolign-1)
  If fstat : Raz [F:CNT] : Endif
  Read [AIN]AIN0 =[M:CNTW]CCNCRM(nolign-1)
  If fstat : Raz [F:AIN] : Endif

  [M:CNTW]CNTBPAADD = [F:CNT]BPAADD
  Read [BPA]BPA0 =[M:CNTW]BPATYP;[M:CNTW]BPANUM;[M:CNTW]CNTBPAADD
  If fstat : Raz [F:BPA] : Endif

  [M:CNTW] = [F:CNT]
  [M:CNTW] = [F:AIN]
  [M:CNTW]CRY       = [F:BPA]CRY
  [M:CNTW]CNTLIG    = [F:BPA]BPADES

  Affzo [M:CNTW]15
  nolign = SNOLIGN

End


