#<AdxTL>@(#)7.0.0.0 $Revision$
$ACTION
Case GACTION
 When "INTCPYZOOM"
  Case ACTION
   When "SEL_LISTE" : Gosub SEL_LISTE
   When "FIN_LISTE" : Gosub FIN_LISTE
  Endcase
Endcase
Return

############################################
## Inter company Journals Zoom            ##
############################################
$SEL_LISTE

Onerrgo ERREUR From CONTROLE
If clalev([F:ICF])=0  : Local File INTCOFLO     [ICF]  : Endif
If clalev([F:HAE2])=0 : Local File GACCENTRY   [HAE2]  : Endif
Onerrgo
If GERREUR : GERREUR=0 : OK=0 : Return : Endif

Local Char LABR(GLONABR), LNUM(GLONVCR)

NBTEX = 0
Filter [ICF] Where TYPVCR=PARAM(1) & NUMVCR = PARAM(2) & CPYTGR=GSOCIETE & FCYTGR=""
Read [ICF] First
Filter [ICF]
If !fstat
 LABR = [F:ICF]ABRFIC
 LNUM = [F:ICF]NUM
Endif

For [ICF] Where ABRFIC=LABR & NUM=LNUM & CPYTGR<>GSOCIETE & FCYTGR=""
 Read [HAE2]HAE0 = [F:ICF]TYPVCR;[F:ICF]NUMVCR
 If fstat=0
  NBTEX += 1
  TEX(NBTEX) = [F:HAE2]TYP-[F:HAE2]NUM
 Endif
Next
FORCE = 1
Return


$FIN_LISTE
If status = 7 : Return : Endif
Local Char    LTYP(GLONGTE), LNUM(GLONVCR)
Local Integer K
If VALEUR<>""
 K=instr(1,VALEUR," ")
 If K
  [L]LTYP=left$(VALEUR,K-1) : [L]LNUM=right$(VALEUR,K+1)
 Endif
Endif
[M]TYP = [L]LTYP
[M]NUM = [L]LNUM
Return


#################################################################################################
# This sub-programm allows the updating of the INTCOFLO Table that will be used in the
# Inter-company Automatic Journal
# * Different values for the CAS Local Variable
#     1 : Customer Invoices (GESBIC)
#     2 : Supplier Invoices (GESBIS)
#     3 : Inter-company Journal Entry (GESxxx)
# * Different values for the OPE Local Variable
#     1 : Invoice Creation
#     2 : Invoice Modification
#     3 : Invoice Deletion
#################################################################################################
Subprog UPD_INTCOFLO(CAS,OPE,NUM,NBRCPY)
Value Integer CAS    : # Call context (see below)
Value Integer OPE    : # 2:Creation or modification  3:Deletion
Value Char    NUM()  : # Document Number
Value Integer NBRCPY : # Number of companies involved (Source company included)

If clalev([F:TCI])=0   : Local File TABACCINT [TCI]   : Endif
If clalev([F:ICF])=0   : Local File INTCOFLO  [ICF]   : Endif
If clalev([F:ICF2])=0  : Local File INTCOFLO  [ICF2]  : Endif
If clalev([F:GCM])=0   : Local File GACM      [GCM]   : Endif
If clalev([F:GCM2])=0  : Local File GACM      [GCM2]  : Endif
If CAS = 3
 If clalev([F:HAE9])=0  : Local File GACCENTRY [HAE9]  : Endif
Endif

Local Char    ABREV(GLONABR)
Local Char    TABCPY(GLONCPY)(0..[M]NBLIG)
Local Char    TABFCY(GLONFCY)(0..[M]NBLIG)
Local Char    GCMCOD(GLONGCM), CODLED(GLONLED), DEVLED(GLONCUR), CURTRS(GLONCUR)
Local Char    REF_SIM(30)
Local Date    RAT_DAT
Local Integer RAT_TYP
Local Integer MODULE, NBCPY, NBFCY
Local Integer STAT, ICPY, NOLI, I, J, X
Local Integer LEDTYPGEN, IGENSRC, IGENTGR
Local Integer TABMAINLED(0..[M]NBLIG)
Local Decimal COURMUL, COURDIV
Local Decimal TDEBIT(0..[M]NBLIG), TCREDIT(0..[M]NBLIG)

Case CAS
 When 1
  ABREV = "SIH" : MODULE = 3
 When 2
  ABREV = "PIH" : MODULE = 3
 When 3
  ABREV = "GIC" : MODULE = 2
Endcase
[L]CURTRS = evalue("[F:"+ABREV+"]CUR")
[L]RAT_DAT = evalue("[F:"+ABREV+"]RATDAT")
If find(CAS,1,2)
 [L]RAT_TYP = evalue("[F:"+ABREV+"]CURTYP")
Else
 [L]RAT_TYP = evalue("[F:"+ABREV+"]TYPRAT")
Endif

Case OPE
 When 2, 3
  Delete [ICF] Where ABRFIC=[L]ABREV & NUM=[L]NUM
  If fstat=1
   GOK=-1 : GLOCK = "$INTCOFLO"-[L]ABREV-[L]NUM : End
  Endif
Endcase
If OPE = 3 : End : Endif

## Source company
TABCPY(0) = evalue("[F:"+ABREV+"]CPY")
Call LECLEDMAIN(1,TABCPY(0),[L]LEDTYPGEN) From CPTDIV
TABMAINLED(0) = [L]LEDTYPGEN
NBCPY = 1 : Gosub MAJICF
Call SETGCM(TABCPY(0),GCMCOD) From CPTDIV
Read  [GCM2]GCM0 = GCMCOD

## Target companies
For I=0 To [M]NBLIG-1
 If !find([M]CPYLIN(I),TABCPY(0..NBCPY-1))
  NBCPY += 1
  TABCPY(NBCPY-1) = [M]CPYLIN(I)
  Call LECLEDMAIN(1,TABCPY(NBCPY-1),[L]LEDTYPGEN) From CPTDIV
  TABMAINLED(NBCPY-1) = [L]LEDTYPGEN
  Gosub MAJICF
  If GOK<1 : Break : Endif
 Endif
Next I

If GOK<1 : End : Endif
End


$MAJICF
Raz [F:ICF]
[F:ICF]ABRFIC    = [L]ABREV
[F:ICF]NUM       = [L]NUM
[F:ICF]ORIMOD    = [L]MODULE
[F:ICF]ACCDAT     = evalue("[F:"+ABREV+"]ACCDAT")
If NBCPY = 1 : # Source company
 [F:ICF]CPYSRC    = evalue("[F:"+ABREV+"]CPY")
 [F:ICF]CPYTGR    = evalue("[F:"+ABREV+"]CPY")
 [F:ICF]FCY       = evalue("[F:"+ABREV+"]FCY")
 If CAS = 3
  [F:ICF]TYPVCR  = evalue("[F:"+ABREV+"]TYP")
  [F:ICF]JOUVCR  = evalue("[F:"+ABREV+"]JOU")
  X = find([F:ICF]CPYSRC,[M]CPYLIN(0..[M]NBLIG-1))
  If X : [F:ICF]NUMVCR  = [M]DOCNUMLIN(X-1) : Endif
 Endif
Else         : # Target companies
 [F:ICF]CPYSRC    = evalue("[F:"+ABREV+"]CPY")
 [F:ICF]CPYTGR    = TABCPY(NBCPY-1)
 # The Header Site in the Journal generated for the company XXX will be initialized by the first site entered on this company XXX
 [F:ICF]FCY       = [M]FCYLIN(I)
 If CAS = 3
  [F:ICF]TYPVCR  = [M]TYPLIN(I)
  [F:ICF]JOUVCR  = [M]JOULIN(I)
  [F:ICF]NUMVCR  = [M]DOCNUMLIN(I)
 Endif
Endif
[F:ICF]FCYTGR = ""
If CAS=3 & evalue("[F:"+ABREV+"]FLGPST")=2
 REF_SIM = "GIC"+evalue("[F:"+ABREV+"]NUM")
 Filter [HAE9] Where REFSIM=[L]REF_SIM & CPY=[F:ICF]CPYTGR
 Read [HAE9]HAE2 First
 Filter [HAE9]
 If !fstat
  [F:ICF]TYPVCR  = [F:HAE9]TYP
  [F:ICF]NUMVCR  = [F:HAE9]NUM
 Endif
Endif
Gosub INI_RAT
Write [ICF]
If fstat
 GOK = 0 : Call FSTA("ICF") From GLOCK : Return
Endif
If GOK<1 : Return : Endif

Gosub INI_INTCPYACC

If GOK<1 : Return : Endif
Return


$INI_RAT

If NBCPY = 1 : # Source Company
 For J=1 To len(mess(0,2644,1))
  [F:ICF]LED(J-1)    = evalue("[F:"+ABREV+"]LED("+num$(J-1)+")")
  [F:ICF]CURLED(J-1) = evalue("[F:"+ABREV+"]CURLED("+num$(J-1)+")")
  [F:ICF]RATDIV(J-1) = evalue("[F:"+ABREV+"]RATDIV("+num$(J-1)+")")
  [F:ICF]RATMLT(J-1) = evalue("[F:"+ABREV+"]RATMLT("+num$(J-1)+")")
 Next
Else : # Target Companies
 Case CAS
  When 3
   ## In GESGIC, the exchange rates are defined in the journal lines for the target companies.
   X = find(TABCPY(NBCPY-1),[M]CPYLIN(0..[M]NBLIG-1))
   For J=1 To len(mess(0,2644,1))
    Call LECLED(TABCPY(NBCPY-1),J,CODLED,DEVLED) From CPTDIV
    [F:ICF]LED(J-1)    = [L]CODLED
    [F:ICF]CURLED(J-1) = [L]DEVLED
    If X
     [F:ICF]RATDIV(J-1) = evalue("[M]RATDIV"+num$(J)+"("+num$(X-1)+")")
     [F:ICF]RATMLT(J-1) = evalue("[M]RATMLT"+num$(J)+"("+num$(X-1)+")")
    Endif
   Next
  When Default
   Call SETGCM(TABCPY(NBCPY-1),GCMCOD) From CPTDIV
   Call LEC_GCM(GCMCOD) From CPTLEC
   ICPY = find([M]CPYLIN(I),TABCPY(0..NBCPY-1))-1
   For J=1 To len(mess(0,2644,1))
    Call LECLED(TABCPY(ICPY),J,CODLED,DEVLED) From CPTDIV
    [F:ICF]LED(J-1)    = [L]CODLED
    [F:ICF]CURLED(J-1) = [L]DEVLED
    If [L]DEVLED = evalue("[F:"+ABREV+"]CURLED("+num$(J-1)+")") & [F:GCM]FLGVCRRAT(J-1)=[F:GCM2]FLGVCRRAT(J-1)
& &  [F:GCM]TYPRAT(J-1)=[F:GCM2]TYPRAT(J-1) & [F:GCM]DACRAT(J-1)=[F:GCM2]DACRAT(J-1) & [F:GCM]RNDOPTBAL(J-1)=[F:GCM2]RNDOPTBAL(J-1)
     [F:ICF]RATDIV(J-1) = evalue("[F:"+ABREV+"]RATDIV("+num$(J-1)+")")
     [F:ICF]RATMLT(J-1) = evalue("[F:"+ABREV+"]RATMLT("+num$(J-1)+")")
    Elsif [L]DEVLED = [L]CURTRS
     [F:ICF]RATDIV(J-1) = 1
     [F:ICF]RATMLT(J-1) = 1
    Else
     Gosub INI_COURS
    Endif
   Next
 Endcase
Endif
Return

$INI_COURS
Raz COURMUL, COURDIV
Call INI_COURS2([L]CURTRS,[F:ICF]CURLED(J-1),[L]RAT_TYP,[L]RAT_DAT,COURDIV,COURMUL,STAT) From SUBSCL
Case [F:GCM]DACRAT(J-1)
 When 1 : # Multiplicateur
  If STAT
   [F:ICF]RATMLT(J-1) = 0
   [F:ICF]RATDIV(J-1) = 1
  Else
   [F:ICF]RATMLT(J-1) = arr(COURMUL/COURDIV,10^-GDECRCU)
   [F:ICF]RATDIV(J-1) = 1
  Endif
 When 2 : # Diviseur
  If STAT
   [F:ICF]RATDIV(J-1) = 0
   [F:ICF]RATMLT(J-1) = 1
  Else
   [F:ICF]RATDIV(J-1) = arr(COURDIV/COURMUL,10^-GDECRCU)
   [F:ICF]RATMLT(J-1) = 1
  Endif
 When 3 : # Les 2
   If STAT
    [F:ICF]RATMLT(J-1) = 0
    [F:ICF]RATDIV(J-1) = 0
   Else
    [F:ICF]RATMLT(J-1) = COURMUL
    [F:ICF]RATDIV(J-1) = COURDIV
   Endif
 Endcase
Return


$INI_INTCPYACC
## Research & storage of the right Intercompany Account...
If NBCPY>1

 Case CAS

  When 1, 2
   Raz NBFCY, TABFCY, TCREDIT, TDEBIT
   For NOLI=0 To [M]NBLIG-1
    If [M]CPYLIN(NOLI) = TABCPY(NBCPY-1)
     If !find([M]FCYLIN(NOLI),TABFCY(0..NBFCY-1))
      NBFCY += 1
      TABFCY(NBFCY-1) = [M]FCYLIN(NOLI)
      IFCY = NBFCY
     Else
      IFCY = find([M]FCYLIN(NOLI),TABFCY(0..NBFCY-1))
     Endif
     If (CAS = 1 & (evalue("[F:"+ABREV+"]INVTYP")=1 or evalue("[F:"+ABREV+"]INVTYP")=3) & [M]AMTATILIN(NOLI)>0)
& or (CAS = 2 & (evalue("[F:"+ABREV+"]INVTYP")=2 or evalue("[F:"+ABREV+"]INVTYP")=3) & [M]AMTATILIN(NOLI)>0)
      TCREDIT(IFCY-1) += abs([M]AMTATILIN(NOLI))
     Else
      TDEBIT(IFCY-1)  += abs([M]AMTATILIN(NOLI))
     Endif
    Endif
   Next

  When 3
   Raz NBFCY, TABFCY, TCREDIT, TDEBIT
   For NOLI=0 To [M]NBLIG-1
    If [M]CPYLIN(NOLI) = TABCPY(NBCPY-1)
     If !find([M]FCYLIN(NOLI),TABFCY(0..NBFCY-1))
      NBFCY += 1
      TABFCY(NBFCY-1) = [M]FCYLIN(NOLI)
      IFCY = NBFCY
     Else
      IFCY = find([M]FCYLIN(NOLI),TABFCY(0..NBFCY-1))
     Endif
     If [M]CDT(NOLI)>0
      TCREDIT(IFCY-1) += [M]CDT(NOLI)
     Else
      TDEBIT(IFCY-1)  += [M]DEB(NOLI)
     Endif
    Endif
   Next

  When Default
 Endcase

 Read [TCI]TCI0 = TABCPY(0);TABCPY(NBCPY-1)
 If !fstat
  [L]IGENSRC = TABMAINLED(0)
  [L]IGENTGR = TABMAINLED(NBCPY-1)
  For J=0 To NBFCY-1
   Raz [F:ICF2]
   [F:ICF2] = [F:ICF]
   [F:ICF2]FCYTGR = TABFCY(J)
   If TDEBIT(J)>TCREDIT(J)
    [F:ICF2]COASRC(IGENSRC-1) = [F:TCI]COASRC : [F:ICF2]ACCSRC(IGENSRC-1) = [F:TCI]ACCSRCDEB : [F:ICF2]BPRSRC = [F:TCI]BPRSRC
    [F:ICF2]COATGR(IGENTGR-1) = [F:TCI]COATGR : [F:ICF2]ACCTGR(IGENTGR-1) = [F:TCI]ACCTGRCDT : [F:ICF2]BPRTGR = [F:TCI]BPRTGR
   Else
    [F:ICF2]COASRC(IGENSRC-1) = [F:TCI]COASRC : [F:ICF2]ACCSRC(IGENSRC-1) = [F:TCI]ACCSRCCDT : [F:ICF2]BPRSRC = [F:TCI]BPRSRC
    [F:ICF2]COATGR(IGENTGR-1) = [F:TCI]COATGR : [F:ICF2]ACCTGR(IGENTGR-1) = [F:TCI]ACCTGRDEB : [F:ICF2]BPRTGR = [F:TCI]BPRTGR
   Endif
   If [F:ICF2]ACCSRC(IGENSRC-1)="" | [F:ICF2]ACCTGR(IGENTGR-1)=""
    ## Intercompany accounts non-defined
    GMESSAGE = mess(149,102,1)-[L]TABCPY(0)-"->"-[L]TABCPY(NBCPY-1)
    GOK = 0 : Break
   Endif
   Write [ICF2]
   If fstat
    GOK = 0 : Call FSTA("ICF2") From GLOCK : Break
   Endif
  Next
 Elsif fstat
  ## Intercompany accounts non-defined
  GMESSAGE = mess(149,102,1)-[L]TABCPY(0)-"->"-[L]TABCPY(NBCPY-1)
  GOK = 0 : Return
 Endif

 If GOK<1 : Return : Endif

Endif
If GOK<1 : Return : Endif
Return

#####################################################################################################
# INTCOACC : This subprogram returns the intercompany account that has to be moved on the
#            Intercompany Journal.
#            This sub-program is called from the Intercompany Automatic Journals through the
#            INTCOACC Variable
#####################################################################################################
Subprog INTCOACC(ABREV,COMPANY,LEDTYP,ACCOUNT,STAT)
Value    Char    ABREV()
Value    Char    COMPANY()
Value    Integer LEDTYP
Variable Char    ACCOUNT()
Variable Integer STAT

If clalev([F:ICF2])=0  : Local File INTCOFLO  [ICF2]  : Endif

Local Libelle TYPLEDGEN, TYPLEDANA

Read [ICF2]ICF0 = ABREV;[F:TB0]NUM;[F:TB0]CPY;[F:TB1]CPYLIN;[F:TB1]FCYLIN
If !fstat
 # Journal Generation on the Source Company
 If GSOCIETE = [F:TB0]CPY
  ACCOUNT = [F:ICF2]ACCSRC(LEDTYP-1)
  If LEDTYP=1 & ACCOUNT=""
   Call SETMAINREF(GSOCIETE,TYPLEDGEN,TYPLEDANA) From CPTDIV
   ACCOUNT = [F:ICF2]ACCSRC(TYPLEDGEN-1)
  Endif
 Else
  # Journal Generation on the Target Company
  ACCOUNT = [F:ICF2]ACCTGR(LEDTYP-1)
  If LEDTYP=1 & ACCOUNT=""
   Call SETMAINREF(GSOCIETE,TYPLEDGEN,TYPLEDANA) From CPTDIV
   ACCOUNT = [F:ICF2]ACCTGR(TYPLEDGEN-1)
  Endif
 Endif
Endif
End

#####################################################################################################
# INTCOBPR : This subprogram returns the intercompany account that has to be moved on the
#            Intercompany Journal.
#            This sub-program is called from the Intercompany Automatic Journals through the
#            INTCOBPR Variable
#####################################################################################################
Subprog INTCOBPR(ABREV,COMPANY,PARTNER,STAT)
Value    Char    ABREV()
Value    Char    COMPANY()
Variable Char    PARTNER()
Variable Integer STAT

If clalev([F:ICF2])=0  : Local File INTCOFLO  [ICF2]  : Endif

Read [ICF2]ICF0 = ABREV;[F:TB0]NUM;[F:TB0]CPY;[F:TB1]CPYLIN;[F:TB1]FCYLIN
If !fstat
 If GSOCIETE = [F:TB0]CPY : # Journal Generation on the Source Company
  PARTNER = [F:ICF2]BPRTGR : # Business Partner for Source Company => Target BP
 Else                     : # Journal Generation on the Target Company
  PARTNER = [F:ICF2]BPRSRC : # Business Partner for Target Company => Source BP
 Endif
Endif
End



## This label is called in the Automatic Journals linked to the Customers Invoices and that allow
## the generation of the intercompany journals
$LIKICFSIH
If clalev([F:ICF])=0 : Local File INTCOFLO  [ICF] : Endif
Read [F:ICF]ICF0 = "SIH";[F:SIH]NUM;[F:SIH]CPY;GSOCIETE;""
Return

## This label is called in the Automatic Journals linked to the Suppliers Invoices and that allow
## the generation of the intercompany journals
$LIKICFPIH
If clalev([F:ICF])=0 : Local File INTCOFLO  [ICF] : Endif
Read [F:ICF]ICF0 = "PIH";[F:PIH]NUM;[F:PIH]CPY;GSOCIETE;""
Return

## This label is called in the Automatic Journals linked to the Intercompany GL and that allow
## the generation of the intercompany journals from the Intercompany GL Management (GESGIC Function)
$LIKICFGIC
If clalev([F:ICF])=0 : Local File INTCOFLO  [ICF] : Endif
Read [F:ICF]ICF0 = "GIC";[F:GIC]NUM;[F:GIC]CPY;GSOCIETE;""
Gosub READDIE
Return

$READDIE
If clalev([F:CPY9])=0 : Local File COMPANY  [CPY9] : Endif
fstat = 0
If [F:CPY9]CPY<>GSOCIETE
 Read [CPY9]CPY0 = GSOCIETE
Endif
Return

