#<AdxTL>@(#)0.0.0.0 $Revision$


TABSPEFLD(0,1)="CTR1_OCPSTA"
TABSPEFLD(0,0)="If func DIVPAYE.IS_KZM_LEG(GCURLEG)"
TABSPEFLD(1,1)="CTR1_CATCSP"
TABSPEFLD(1,0)="If func DIVPAYE.IS_KZM_LEG(GCURLEG)"
TABSPEFLD(2,1)="CTR1_PSNJOB"
TABSPEFLD(2,0)="If func DIVPAYE.IS_KZM_LEG(GCURLEG)"
TABSPEFLD(3,1)="CTR1_PSNJOB"
TABSPEFLD(3,0)="If func DIVPAYE.IS_LEG(GCURLEG)"
TABSPEFLD(4,1)="CTR2_PSNJOB"
TABSPEFLD(4,0)="If func DIVPAYE.IS_LEG(GCURLEG)"
TABSPEFLD(5,1)="CTR1_PSNJOB"
TABSPEFLD(5,0)="If func DIVPAYE.IS_LEG(GCURLEG)"
TABSPEFLD(6,1)="CTR0_REFNUM"
TABSPEFLD(6,0)="# specfields"

TABSPEFLDC(0,0)="If func DIVPAYE.IS_LEG(GCURLEG)"
TABSPEFLDC(0,1)="CTR0_CTRNUM"
TABSPEFLDC(1,0)="If func DIVPAYE.IS_LEG(GCURLEG)"
TABSPEFLDC(1,1)="CTR0_CTRDAT"
TABSPEFLDC(2,0)="#specfields CTR1_CTRDAT"
TABSPEFLDC(2,1)="CTR1_CTRDAT"

Call MANAGE_LOCALISATION_SHOW("OCTR",TABSPEFLD,TABSPEFLDC)


End



Subprog MANAGE_LOCALISATION_SHOW(THIS_WINDOW,TAB_HIDFLDS,TAB_SHOFLDS)
Value Char THIS_WINDOW()
Value Char TAB_HIDFLDS()(,)
Value Char TAB_SHOFLDS()(,)
Call DISPLAY_FIELDS_AUTO(THIS_WINDOW,TAB_HIDFLDS,TAB_SHOFLDS)

End


#########################################################################################
#
# Check if we need to regenerate the file
#
Funprog GENERATE_FILES(FEN)
Value Char FEN()


If !clalev([F:WAELT]) : Local File AELT [WAELT] : Endif
If !clalev([F:AWIZZ]) : Local File AWINDOW [AWIZZ]     : Endif
Local Integer RES : RES=1

Local Char NAMFIL(250),NAMFILADX(250)
Local Char WLIN(250)
Local Integer W_POS,WI
Local Char W_MSK(30)
Local Char W_TIMSTP_SH(30),W_TIMSTP(30)
Local Integer W_NB

NAMFIL=filpath("TRT","W"+FEN+"SHOWHIDE","src",nomap)
# don't exist if error on compilation... need to be regenerate
NAMFILADX=filpath("TRT","W"+FEN+"SHOWHIDE","adx",nomap)

If filinfo(NAMFIL,0)>=0 and filinfo(NAMFILADX,0)>=0
  fstat=0
  Openi NAMFIL Using [XML_]
  If ! fstat
    Iomode adxifs ""  Using [XML_]
    Iomode adxirs chr$(10)  Using [XML_]
    Iomode adxium GUTF8  Using [XML_]
    Rdseq WLIN Using [XML_]
    While fstat=0
      Rdseq WLIN Using [XML_]
      W_POS=instr(1,WLIN,'timestamp')
      If W_POS
         W_TIMSTP_SH=vireblc(right$(WLIN,instr(1,WLIN,":")+1),4)
        Break 1
      Endif
    Wend
    Openi Using [XML_]
    If  W_TIMSTP_SH<>""
      For [F:WAELT]ELT0(3) Where  ELTTYP="FENW" and ELT=[L]FEN
        If W_TIMSTP_SH< [F:WAELT]ELTSTP
          W_TIMSTP=[F:WAELT]ELTSTP
          Break
        Endif
      Next
      If W_TIMSTP_SH>=W_TIMSTP
        # need to check screen..
        Read [F:AWIZZ]AWI0 = [L]FEN
        If!fstat
          If [F:AWIZZ]MSKENT<>""
            [L]W_MSK=[F:AWIZZ]MSKENT
            Gosub CHECK_MSK
          Endif
          If W_TIMSTP_SH>=W_TIMSTP
            For WI=0 To dim([F:AWIZZ]MSKNOM)-1
              If [F:AWIZZ]MSKNOM(WI)<>""
                [L]W_MSK=[F:AWIZZ]MSKNOM(WI)
                Gosub CHECK_MSK
              Endif
              If W_TIMSTP_SH<W_TIMSTP : Break : Endif
            Next
          Endif
        Endif
      Endif
      If W_TIMSTP_SH>=W_TIMSTP
        RES=0
      Endif
    Endif
  Endif
Endif

End RES

##################################
# get timestamp of msk
#
$CHECK_MSK
  Read [F:WAELT]ELT0="SCRN";[L]W_MSK;"ALL"
  If !fstat
   If  W_TIMSTP_SH< [F:WAELT]ELTSTP
    W_TIMSTP=[F:WAELT]ELTSTP
   Endif
  Endif
Return

#########################################################################################
#
# TAB_HIDFLDS: fields to hide by legislation
# TAB_SHOFLDS: fields to show by legislation
#
Subprog DISPLAY_FIELDS_AUTO(THIS_WINDOW,TAB_HIDFLDS,TAB_SHOFLDS)
Value Char THIS_WINDOW()
Value Char TAB_HIDFLDS()(,)
Value Char TAB_SHOFLDS()(,)
Local Char THIS_SCREEN(12)
Local Char THIS_ACT(GLONACV)
Local Char DATA_TYPE(GLONATY)
Local Decimal TYP_LEN()
Local Integer INT_TYP()
Local Decimal SCR_LEN()
Local Char ADO_TYP(50)
Local Shortint LOM_NUM()
Local Char THIS_SCREENABR(GLONABR)
Local Integer FIRSTCHAR
Local Integer LOOPNUMBER
Local Integer CALLCOUNTER
Local Char BLOCACTARRAY(GLONACV)(1..)
Local Integer BLOC_NUM()
Local Char THIS_FIELD(GLONAVA)
Local Char THIS_SCREENACTCOD(GLONACV)
Local Char WT_REALDOCACT(20)(0..)
Local Integer WI_NB

# SBA specific format
Local Char SCR_OPT(30)
Local Char SCR_FMT(30)
Local Integer SCR_HIDDEN
Local Char TYP_OPT(50)
Local Char TYP_FMT(50)

Local Char W_VALFMT(250)
Local Integer W_VALADI
Local Char W_NAMSCR(20),W_NAMFLD(20)
Local Char W_VALFMT(250)

# fields to raz
Local Char W_FIELDSTORAZ(50)(0..1000)
Local Integer NB_FLDTORAZ
Local Char W_NAMWRITE(30)







If !clalev([F:ACVZZ])  : Local File ACTIV [ACVZZ]      : Endif     #First Instance
If !clalev([F:ACVZZ3]) : Local File ACTIV [ACVZZ3]     : Endif     #Third Instance

If !clalev([F:ADIZZ])  : Local File ATABDIV [ADIZZ]    : Endif
If !clalev([F:AMZZZ])  : Local File AMSKZON [AMZZZ]    : Endif
If !clalev([F:AMKZZ])  : Local File AMSK [AMKZZ]       : Endif
If !clalev([F:ADATYP]) : Local File ATYPE [ADATYP]     : Endif
If !clalev([F:AWIZZ]) : Local File AWINDOW [AWIZZ]     : Endif
If !clalev([F:ACVZZ2]) : Local File ACTIV [ACVZZ2]    : Endif     #Second Instance
# Table for type ADI
If !clalev([F:WADV])  : Local File ATABTAB [WADV]    : Endif
If !clalev([F:WAMP])  : Local File AMSKPAR [WAMP]    : Endif


Filter [F:ADIZZ] Where [F:ADIZZ]NUMTAB  = 10302

Read [F:AWIZZ]AWI0 = THIS_WINDOW
If fstat : Return : Endif


# polulate name mask
Local Char W_TABNAMMSK(20)(0..[F:AWIZZ]NBMSK,0..1) : # 1 entete+ [F:AWIZZ]NBMSK-1 msk
Local Integer W_NB,WI
If [F:AWIZZ]MSKENT<>""
  W_TABNAMMSK(W_NB,0)=[F:AWIZZ]MSKENT
  Gosub GET_ABREVMSK
  W_NB+=1
Endif

For I = 0 To [F:AWIZZ]NBMSK-1
  If [F:AWIZZ]NOMMSK(I)<>""
    W_TABNAMMSK(W_NB,0)=[F:AWIZZ]NOMMSK(I)
    Gosub GET_ABREVMSK
    W_NB+=1
  Endif
Next

#POPULATE SUBPROGS FOR ALL LOCALISATION ACTIVITY CODES
#write call subprog with activity code calls per Legislation
LOOPNUMBER=1

Gosub CREATE_SHOW_SCRIPT

Wrseq ''
Wrseq "End"

Filter [F:ACVZZ] Where [F:ACVZZ]FLACT=2 &
&                   ((left$([F:ACVZZ]CODACT,1)="K"|left$([F:ACVZZ]CODACT,2)="FK") | [F:ACVZZ]DEP=4)

For [F:ACVZZ]
  If find([F:ACVZZ]CODACT,WT_REALDOCACT(0..WI_NB))
    LOOPNUMBER=2
    #write heading for call subprog for activity codes that are active
    Gosub CREATE_SHOW_SCRIPT

    # fields in each msk
    For I=0 To dim(W_TABNAMMSK)-1
      THIS_SCREEN=W_TABNAMMSK(I,0)
      Gosub CHECK_FIELDS_FOR_SCREEN
    Next

    Wrseq ''
    Wrseq "End"
  Endif
Next

Gosub CREATE_SPEFIELD
Gosub CREATE_RAZFIELD

#close file
Openo
If GOK<>0
  Gosub COMPILE_SHOW_SCRIPT
Endif

End

##############################################################
$GET_ABREVMSK
W_TABNAMMSK(W_NB,1)=W_TABNAMMSK(W_NB,0)
If [F:AMKZZ]CODMSK<>W_TABNAMMSK(W_NB,0)
  Read [F:AMKZZ]CODMSK  = W_TABNAMMSK(W_NB,0)
Endif
If!fstat
  W_TABNAMMSK(W_NB,1)=[F:AMKZZ]ABRMSK
Endif
Return


#########################################################################################
# Code for specific fields
#
$CREATE_RAZFIELD
Raz I
Wrseq "Subprog RAZ_FLDS()"

While (W_FIELDSTORAZ(I)<>"")
  Wrseq " If varmode("+W_FIELDSTORAZ(I)+")=3 "+chr$(9)+chr$(9)+": Raz "+W_FIELDSTORAZ(I)+chr$(9)+" : Endif"
  I+=1
Wend
Wrseq "End"

Return
$CREATE_SPEFIELD
  Local Char W_KEY(100)
  Local Char W_FCT(100)
  Local Char W_SCRFLD(100)
  Local Integer I
  Local Integer W_POS
  Local Char W_TYP(1)
  Filter [F:AMZZZ]
  Wrseq ''
  Wrseq "Subprog HIDE_SPEFLDS(SIGN)"
  Wrseq 'Value Char SIGN()'
  Wrseq ''
  W_TYP="H"
  Raz I
  Gosub GENERATE_SCRIPTSPE
  Wrseq 'End'
  Wrseq ''

  Wrseq ''
  Wrseq "Subprog SHOW_SPEFLDS(SIGN)"
  Wrseq 'Value Char SIGN()'
  Wrseq ''
  Raz I,W_KEY
  W_TYP="S"
  Gosub GENERATE_SCRIPTSPE

  Wrseq 'End'
  Wrseq ''
  Wrseq ''
  Local Char W_TABGEN(30)(0..dim(TAB_HIDFLDS)+dim(TAB_SHOFLDS))
  W_NB=0
  # Generate labels links to the array TAB_HIDFLDS
  W_TYP="H"
  Gosub  GENERATE_SHOWHIDEFILEDS
  # Generate labels links to the array TAB_SHOFLDS
  W_TYP="S"
  Raz I
  Gosub  GENERATE_SHOWHIDEFILEDS

Return

#############################################
# set variable for loop
$SETVAR_FORSPEFLDS
  Case W_TYP
    When "H" :
      If (I<dim(TAB_HIDFLDS))
        W_FCT=TAB_HIDFLDS(I,0)
        W_SCRFLD=TAB_HIDFLDS(I,1)
      Else
         W_FCT=""
         W_SCRFLD=""
      Endif
   When "S" :
    If (I<dim(TAB_SHOFLDS))
      W_FCT=TAB_SHOFLDS(I,0)
      W_SCRFLD=TAB_SHOFLDS(I,1)
    Else
      W_FCT=""
      W_SCRFLD=""
    Endif
  Endcase

Return

#############################################
# loop to create function to call labels
$GENERATE_SCRIPTSPE
  Gosub SETVAR_FORSPEFLDS
  If W_FCT<>""
    Wrseq W_FCT
    W_KEY=W_FCT
    While(W_FCT<>"")
      If(W_KEY<>W_FCT)
        If! func IS_COMMENT(W_KEY)
          Wrseq 'Endif'
          Wrseq ''
        Endif
        Wrseq W_FCT
        W_KEY=W_FCT
      Endif
      If! func IS_COMMENT(W_KEY)
        Wrseq ' Gosub '+W_SCRFLD
      Endif
      I+=1
      Gosub SETVAR_FORSPEFLDS
    Wend
    If! func IS_COMMENT(W_KEY) & W_KEY<>""
      Wrseq 'Endif'
    Endif
  Endif
Return

#############################################
# loop to create labels
$GENERATE_SHOWHIDEFILEDS
  Raz I
  Gosub SETVAR_FORSPEFLDS

  If W_FCT<>""
    While(W_FCT<>"")
      W_POS=find(W_SCRFLD,W_TABGEN(0..W_NB))
      If !W_POS
        Wrseq "$"+W_SCRFLD
        W_POS=instr(1,W_SCRFLD,"_")
        THIS_SCREEN=left$(W_SCRFLD,W_POS-1)
        THIS_FIELD=right$(W_SCRFLD,W_POS+1)
        Gosub ADD_SPELINE
        Wrseq 'Return'
        Wrseq ''
        W_TABGEN(W_NB)=W_SCRFLD
        W_NB+=1
      Endif
      I+=1
      Gosub SETVAR_FORSPEFLDS
    Wend
  Endif
Return



#########################################################################################

Funprog IS_COMMENT(TEXT)
Variable Char TEXT()
Local Integer RES
RES=instr(1,TEXT,"#")=1
End RES


$CHECK_FIELDS_FOR_SCREEN

GOK=1
If [F:AMKZZ]CODMSK <> THIS_SCREEN
  Read [F:AMKZZ]CODMSK  = THIS_SCREEN
Endif

THIS_SCREENABR=[F:AMKZZ]ABRMSK
THIS_SCREENACTCOD=[F:AMKZZ]CODACT

Raz BLOCACTARRAY

For X = 0 To [F:AMKZZ]NBBLOC-1
  BLOCACTARRAY(X+1)=[F:AMKZZ]ACTBLOC(X)
Next

#write call subprog with activity code instructions
#If [AMZZZ]CODMSK <> THIS_SCREEN
  Filter [AMZZZ]
  Filter [AMZZZ] Where [AMZZZ]CODMSK = THIS_SCREEN
#Endif

 For [AMZZZ]
  LOOPNUMBER=3
  Gosub SET_DATA_MSK
  If !SCR_HIDDEN
    If [F:AMZZZ]CODACT<>"" THIS_ACT=[F:AMZZZ]CODACT : Endif
    If [F:AMZZZ]CODACT="" and BLOCACTARRAY(BLOC_NUM)<>"" THIS_ACT=BLOCACTARRAY(BLOC_NUM) : Endif
    If [F:AMZZZ]CODACT="" and BLOCACTARRAY(BLOC_NUM) ="" THIS_ACT=THIS_SCREENACTCOD      : Endif

    If THIS_ACT<>""
      Read [F:ACVZZ3]CODACT = THIS_ACT
      If [F:ACVZZ3]FLACT=2
        If THIS_ACT=[F:ACVZZ]CODACT
          Gosub SET_DATA_TYP
          Gosub CREATE_SHOW_SCRIPT
        Endif
      Endif
    Endif
  Endif

Next

Return

#########################################################################################
#  set fields for a record AMASKZON
$SET_DATA_MSK

  DATA_TYPE =[F:AMZZZ]CODTYP
  SCR_LEN =[F:AMZZZ]LONG
  LOM_NUM =[F:AMZZZ]NOLIB
  BLOC_NUM =[F:AMZZZ]NUMBLOC
  THIS_FIELD=[F:AMZZZ]CODZON
  # SBA specific format or option if $ take SCR_FMT
  SCR_OPT = [F:AMZZZ]OPTSAI
  SCR_FMT = [F:AMZZZ]OPTFOR
  SCR_HIDDEN=[F:AMZZZ]SAIAFF=3

Return

#########################################################################################
#  code to generate a line for specific fields
#
$ADD_SPELINE
#Try to find code
 Raz ISFOUND
 Gosub GET_LINEMSK
 If !ISFOUND
  For WI=0 To dim(W_TABNAMMSK)-1
    If(W_TABNAMMSK(WI,0)<>"")
      THIS_SCREEN=W_TABNAMMSK(WI,0)
      Gosub GET_LINEMSK
    Endif
    If ISFOUND : Break : Endif
  Next
 Endif
 If ISFOUND

  Gosub SET_DATA_MSK
  If !SCR_HIDDEN
    Gosub SET_DATA_TYP
    Gosub GET_FORMAT_FLD
    Gosub WRITE_LINEFORMAT
  Endif
 Endif
Return

#########################################################################################
# get the record for a line of a mask
$GET_LINEMSK
 Read [F:AMZZZ]CODE=THIS_SCREEN;THIS_FIELD
 If !fstat
  ISFOUND=1
  THIS_SCREENABR=W_TABNAMMSK(find(THIS_SCREEN,W_TABNAMMSK(0..,0))-1,1)
 Endif
Return


#########################################################################################
#Format link of a data type
$SET_DATA_TYP
Read [F:ADATYP]CODTYP = DATA_TYPE
INT_TYP=[F:ADATYP]TYPTYP
TYP_LEN =[F:ADATYP]LNGTYP
ADO_TYP =[F:ADATYP]FORTYP
TYP_FMT =[F:ADATYP]FORTYP
TYP_OPT= [F:ADATYP]OPTION
If DATA_TYPE="ADI"
  Gosub SET_INFO_TYPE_ADI
Endif
Return

#########################################################################################
# Format of a MT
$SET_INFO_TYPE_ADI
 TYP_LEN=GLONADI
 TYP_FMT =num$(TYP_LEN)+"B"
 Read [WAMP]CODPAR = 1;[F:AMZZZ]CODMSK;THIS_FIELD;DATA_TYPE
 If left$([F:WAMP]VALPAR,1)="'" or left$([F:WAMP]VALPAR,1)='"'
    W_VALADI = val(seg$([F:WAMP]VALPAR,2,len([F:WAMP]VALPAR)-1))
 Else
    W_VALADI=val([F:WAMP]VALPAR)
 Endif
 If W_VALADI<>0
  Read [WADV]CODE = W_VALADI
  If !fstat
    TYP_LEN=[F:WADV]LNG
    TYP_FMT =num$(TYP_LEN)+"B"
  Endif
 Endif
Return

#########################################################################################

$CREATE_SHOW_SCRIPT
Local Char RET_ACTCODE(GLONACV)(1..)
Local Char SEND_ACTCODE(GLONACV)(1..)
Local Char COMBINED_ACTCODE(GLONACV)(1..)
Local Integer ISFOUND
Local Char MISCACT(5)
Local Char MISCLEG(GLONADI)
Local Char W_TIMESTAMP(20)


# calculate time stamp to compare later with win json
Call ENVVAR(W_TIMESTAMP)From INTRUTILA


CALLCOUNTER+=1
If CALLCOUNTER=1 & LOOPNUMBER=1
#get filename
  SCRISRC = filpath("TRT","W"+THIS_WINDOW+"SHOWHIDE","src",nomap)

#open source file
  Openo SCRISRC,0
  adxifs = ""
  adxirs = chr$(10)

#write creation details
# SBA : need to do
  Wrseq "#<AdxT"+GADOVERS+">@(#)0.0.0.0 $Revision$"
  Wrseq '# User :'-GUSER
  Wrseq '# Date :'-format$("DD4",date$)
  Wrseq '# timestamp :'-W_TIMESTAMP
  Wrseq ''
  Wrseq "Subprog SHOW_HIDE()"
  Wrseq ''
  Wrseq 'Local Char SIGN(1)'
  Wrseq 'Local Char SAV_LEG(GLONADI) :  SAV_LEG=GCURLEG'
  Wrseq ''
  Wrseq 'GCURLEG=""'
  Wrseq 'SIGN="-"'
  Wrseq 'Call SHOW_LEGACTCALLS(SIGN)'
  Wrseq ''
  Wrseq 'GCURLEG=SAV_LEG'
  Wrseq 'SIGN=""'
  Wrseq 'Call SHOW_LEGACTCALLS(SIGN)'
  Wrseq ''
  Wrseq 'GCURLEG=""'
  Wrseq 'Call HIDE_SPEFLDS(SIGN)'
  Wrseq ''
  Wrseq 'GCURLEG=SAV_LEG'
  Wrseq 'SIGN="-"'
  Wrseq 'Call HIDE_SPEFLDS(SIGN)'
  Wrseq ''
  Wrseq 'GCURLEG=""'
  Wrseq 'Call SHOW_SPEFLDS(SIGN)'
  Wrseq ''
  Wrseq 'GCURLEG=SAV_LEG'
  Wrseq 'SIGN=""'
  Wrseq 'Call SHOW_SPEFLDS(SIGN)'
  Wrseq ''
  Wrseq 'Call RAZ_FLDS()'
  Wrseq ''
  Wrseq 'End'
  Wrseq ''
  Wrseq ''
  Wrseq "Subprog SHOW_LEGACTCALLS(SIGN)"
  Wrseq 'Value Char SIGN()'
  Wrseq ''


For [F:ADIZZ]

  ISFOUND=1
  MISCLEG=[F:ADIZZ]CODE
  MISCACT=[F:ADIZZ]A1

  Raz COMBINED_ACTCODE

  SEND_ACTCODE(1)=MISCACT
  COMBINED_ACTCODE(1)=MISCACT
  While ISFOUND=1
    Z=1
    Gosub FINDALL_ACTCODES
      If ISFOUND=1
        For Y =1 To maxtab(RET_ACTCODE)
          Z+=1
          COMBINED_ACTCODE(Z)=RET_ACTCODE(Y)
          Raz SEND_ACTCODE
          SEND_ACTCODE=RET_ACTCODE
        Next
      Endif
  Wend

  Wrseq "If GCURLEG ='"+MISCLEG+"' | GCURLEG=''"

  For X = 1 To maxtab(COMBINED_ACTCODE)
    Read [F:ACVZZ3]CODACT=COMBINED_ACTCODE(X)
    If [F:ACVZZ3]FLACT=2
      Wrseq " Call SHOW_"+COMBINED_ACTCODE(X)+"(SIGN)"
      If !find(COMBINED_ACTCODE(X),WT_REALDOCACT(0..WI_NB))
        WT_REALDOCACT(WI_NB)=COMBINED_ACTCODE(X)
        WI_NB+=1
      Endif
    Endif
  Next

  Wrseq "Endif"
  Wrseq ''
Next
Endif

If LOOPNUMBER=2
#write heading for each subprog per activity code
    Wrseq ''
    Wrseq "Subprog SHOW_"+[F:ACVZZ]CODACT+"(SIGN)"
    Wrseq "Value Char SIGN()"
    Wrseq ''
Endif

If LOOPNUMBER=3
#write write change formats to show fields for each activity code
  Gosub GET_FORMAT_FLD
  Gosub WRITE_LINEFORMAT
Endif

Return

#########################################################################################

$WRITE_LINEFORMAT
  If W_VALFMT<>""
     W_NAMWRITE="[M:"+THIS_SCREENABR+"]"+THIS_FIELD
     If DATA_TYPE="ABS"
      Wrseq '  If SIGN="-"'
      Wrseq "   Chgfmt "+W_NAMWRITE+" With "+W_VALFMT
      Wrseq '  Endif'
     Endif
     Wrseq "  Chgfmt "+W_NAMWRITE+" With SIGN+"+W_VALFMT
  Endif
  If !find(W_NAMWRITE,W_FIELDSTORAZ(0..NB_FLDTORAZ))
    W_FIELDSTORAZ(NB_FLDTORAZ)=W_NAMWRITE
    NB_FLDTORAZ+=1
  Endif
Return

#########################################################################################

$GET_FORMAT_FLD
W_VALFMT=""
Case INT_TYP
  When 1
   #"LA" (Local MENU)
   W_VALFMT = '"LA:'+num$(LOM_NUM)+'"'
  When 2,3,4,5,6
   #"NZ" (Number)
    W_VALFMT = func GETFMT_NUM(SCR_OPT,SCR_FMT,TYP_OPT,TYP_FMT,SCR_LEN,TYP_LEN)

  When 7
   #"K" (ALPHA)
    W_VALFMT =func GETFMT_ALPHA(SCR_OPT,SCR_FMT,TYP_OPT,TYP_FMT,SCR_LEN,TYP_LEN)
  When 8, 12
   #"D" (Date)
   W_VALFMT= func GETFMT_DAT(SCR_OPT,SCR_FMT,TYP_OPT)

Endcase

Return

#########################################################################################

$COMPILE_SHOW_SCRIPT

If dim(OK)<0 : Local Integer OK : Endif

Call VALID("TRT","W"+THIS_WINDOW+"SHOWHIDE",nomap,OK) From VALMSKSUB
If OK=0
  GOK=0
  GMESSAGE = mess(35, 11662, 1)
Endif

Return

#########################################################################################

$FINDALL_ACTCODES

ISFOUND=0
Y=0
Raz RET_ACTCODE

 For X = 1 To maxtab(SEND_ACTCODE)
    For [F:ACVZZ2] Where [F:ACVZZ2]DEP=4 & [F:ACVZZ2]FLACT=2
      If 1=1
       Gosub LOOP_FORMULAARRAY
        #Check if the legislation activity code was found in the array
          If find(SEND_ACTCODE(dim(X)),FORMULAARRAY(1..maxtab(FORMULAARRAY)))
            FNDACTCODE=[F:ACVZZ2]CODACT
            ISFOUND=1
            Y+=1
            RET_ACTCODE(Y)=FNDACTCODE
          Endif
     Endif
    Next
 Next

Return

#########################################################################################

$LOOP_FORMULAARRAY
Local Char FORMULAARRAY(GLONACV)(1..)

Raz FORMULAARRAY
TMPSTR=vireblc([F:ACVZZ2]ACTFOR,4)
ACTFORLEN=len(TMPSTR)
FIRSTCHAR=1
X=0

For AF = 1 To ACTFORLEN
  CHKPIPESTR=mid$([F:ACVZZ2]ACTFOR,1,AF)
  CHKPIPE=mid$(CHKPIPESTR,AF,1)
    If CHKPIPE="|"  | CHKPIPE="Or" | AF=ACTFORLEN  | CHKPIPE=" " | CHKPIPE="&" | CHKPIPE="And" | CHKPIPE="(" | CHKPIPE=")"
      If AF = ACTFORLEN FACTCODE=mid$([F:ACVZZ2]ACTFOR,FIRSTCHAR,AF-FIRSTCHAR+1) Else FACTCODE=mid$([F:ACVZZ2]ACTFOR,FIRSTCHAR,(AF-1)-FIRSTCHAR+1) : Endif
      X+=1
      FORMULAARRAY(X)=FACTCODE
      FIRSTCHAR=AF+1
    Endif
Next

Return

#####################################################################################################
#####################################################################################################


#SBA :  see VALMSKSUB for format
Funprog GETFMT_DAT(SCR_OPT,SCR_FMT,TYP_OPT)
Value  Char SCR_OPT(),SCR_FMT(),TYP_OPT()

Local Char RES(30)
Local Char WOPT(30),WRES_OPT(30)
Local Integer WOPT_NUM
Local Integer WI

If SCR_OPT <>"" and SCR_OPT="$"
  If !instr(0,SCR_FMT,":")
    RES='"D:'+SCR_FMT+'"'
  Else
    RES='"'+SCR_FMT+'"'
  Endif
Else
  WOPT=vireblc(SCR_OPT+TYP_OPT,4)
  For WI=0 To len(WOPT)-1
    If val(mid$(WOPT,WI,1))<>0
      WOPT_NUM=val(mid$(WOPT,WI,1))
      Break
    Endif
  Next
  If instr(1,WOPT,"z") : WRES_OPT += "z" : Endif       : # Commentaires non affichés
  If instr(1,WOPT,"Z") : WRES_OPT += "Z" : Endif       : # Date nulle autorisée
  If instr(1,WOPT,"W") : WRES_OPT += "W" : Endif       : # Non creusé
  If instr(1,WOPT,"c") : WRES_OPT += "c" : Endif       : # Colorisé
  RES='"D'+WRES_OPT+':"+'+func GET_NAMEDAT(WOPT_NUM)

Endif

End RES

#####################################################################################################
#####################################################################################################

Funprog GETFMT_NUM(SCR_OPT,SCR_FMT,TYP_OPT,TYP_FMT,SCR_LEN,TYP_LEN)
Value  Decimal SCR_LEN,TYP_LEN
Value  Char SCR_OPT(),SCR_FMT(),TYP_OPT(),TYP_FMT()
Local Char RES(30)


Local Char WOPT(30),WRES_OPT(30)
Local Char WFMT(30),WRES_FMT(30)
Local Integer WOPT_NUM
Local Integer WI

If SCR_OPT <>"" and SCR_OPT="$"
  If !instr(0,SCR_FMT,":")
    RES='N:'+SCR_FMT
  Else
    RES=SCR_FMT
  Endif
Else
   WOPT=vireblc(SCR_OPT+TYP_OPT,4)
   If TYP_FMT<>""
    WRES_FMT=TYP_FMT
   Else
    If SCR_LEN<>0
      WRES_FMT=num$(SCR_LEN)
    Else
      WRES_FMT=num$(TYP_LEN)
    Endif
    If instr(1,WOPT,"F") & val(WRES_FMT)=int(WRES_FMT)                    : # Flottant si pas de décimales
      WRES_FMT+ = "F"
    Else
      WRES_FMT+ ="#"
    Endif
   Endif
    If instr(1,WOPT,"+") : WRES_OPT += "+" : Endif       : # Nb > 0
    If instr(1,WOPT,"z") : WRES_OPT += "z" : Endif       : # Zéro non affiché
    If instr(1,WOPT,"0") : WRES_OPT += "0" : Endif       : # Paddé avec des 0
    If instr(1,WOPT,"3") : WRES_OPT += "3" : Endif       : # Séparateur de 3 chiffres
    If instr(1,WOPT,"W") : WRES_OPT += "W" : Endif       : # Non creusé
    If instr(1,WOPT,"-") : WRES_OPT += "-" : Endif       : # Signe forcé
    If instr(1,WOPT,"D") : WRES_OPT += "D" : Endif       : # Signe après
    If instr(1,WOPT,"c") : WRES_OPT += "c" : Endif       : # Colorisé
    RES='"N'+WRES_OPT+':'+WRES_FMT+'"'
Endif

End RES

#####################################################################################################
#####################################################################################################
Funprog GETFMT_ALPHA(SCR_OPT,SCR_FMT,TYP_OPT,TYP_FMT,SCR_LEN,TYP_LEN)
Value  Decimal SCR_LEN,TYP_LEN
Value  Char SCR_OPT(),SCR_FMT(),TYP_OPT(),TYP_FMT()

Local Char RES(30)

Local Char WOPT(30),WRES_OPT(30)
Local Char WFMT(30),WRES_FMT(30)
Local Integer WOPT_NUM
Local Integer WI

If SCR_OPT <>"" and SCR_OPT="$"
  If !instr(0,SCR_FMT,":")
    RES='K:'+SCR_FMT
  Else
    RES=SCR_FMT
  Endif
Else
   WOPT=vireblc(SCR_OPT+TYP_OPT,4)
   If TYP_FMT<>""
    WRES_FMT=TYP_FMT
   Else
    If SCR_LEN<>0
      WRES_FMT=num$(SCR_LEN)
    Else
      WRES_FMT=num$(TYP_LEN)
    Endif
    If instr(1,WOPT,"C")                  : # Flottant si pas de décimales
      WRES_FMT+ = "c"
    Elsif instr(1,WOPT,"A")
      If instr(1,WOPT,"#")
        WRES_FMT+ = "B"
      Else
        WRES_FMT+ = "A"
      Endif
    Elsif instr(1,WOPT,"#")
      WRES_FMT+ = "#"
    Else
      WRES_FMT+ = "X"
    Endif
   Endif

    If instr(1,WOPT,"T") : WRES_OPT += "T"
      Elsif instr(1,WOPT,"D") : WRES_OPT += "TD"
    Endif
    If instr(1,WOPT,"1") : WRES_OPT += "1" : Endif
    If instr(1,WOPT,"z") : WRES_OPT += "z" : Endif
    If instr(1,WOPT,"=") : WRES_OPT += "="
      Elsif instr(1,WOPT,"<") : WRES_OPT += "<"
        Elsif instr(1,WOPT,">") : WRES_OPT += ">"
    Endif
    If instr(1,WOPT,"U") : WRES_OPT += "U" : Endif       : # Format fichier
    If instr(1,WOPT,"W") : WRES_OPT += "W" : Endif       : # Non creusé
    If instr(1,WOPT,"X") : WRES_OPT += "X" : Endif       : # Saisie masquée
    If instr(1,WOPT,"c") : WRES_OPT += "c" : Endif       : # Colorisé

    If instr(1,WOPT,"W") : WRES_OPT += "W" : Endif       : # Non creusé
    If instr(1,WOPT,"-") : WRES_OPT += "-" : Endif       : # Signe forcé
    If instr(1,WOPT,"D") : WRES_OPT += "D" : Endif       : # Signe après
    If instr(1,WOPT,"c") : WRES_OPT += "c" : Endif       : # Colorisé
    RES='"K'+WRES_OPT+':'+WRES_FMT+'"'
Endif

End  RES

Funprog GET_NAMEDAT(TYP)
Value Integer TYP
Local Char RES(30)
Case TYP
  When 1 : RES="GFMDAT"
  When 2 : RES="GFMDAT4"
  When 3 : RES="GFMDAT3"
  When 4 : RES="GFMDAT9"
  When 5 : RES="GFMJOU"
  When 6 : RES="GFMMOI"
  When 7 : RES="GFMMOI4"
  When Default : RES="GFMDAT"
Endcase

End RES
########################################################################################
#
# use in files *LEG
#

# initialisation
$INI_TABSPE_FIELDS
  Local Char FLDTOHIDE(200)(0..,0..1)
  Local Char FLDTOSHOW(200)(0..,0..1)
  Local Integer NB_ELMTS_HD,NB_ELMTS_SH
  Local Char COND(200), W_MSK(8)
  Local Char W_TXT(20)
  # if the array never set the dim of array >32000 when we send it to a subprog. to minimize the dim, we must initialize them
  FLDTOHIDE(0,0)=""
  FLDTOSHOW(0,0)=""
Return

# add fields to hide by leg
$ADD_INTAB_FLDTOHIDE
  FLDTOHIDE(NB_ELMTS_HD,0)=COND
  FLDTOHIDE(NB_ELMTS_HD,1)=vireblc(W_MSK+'_'+W_TXT,4)
  NB_ELMTS_HD+=1
Return

# add fields to Show by leg
$ADD_INTAB_FLDTOSHOW
  FLDTOSHOW(NB_ELMTS_SH,0)=COND
  FLDTOSHOW(NB_ELMTS_SH,1)=vireblc(W_MSK+'_'+W_TXT,4)
  NB_ELMTS_SH+=1
Return


$KILL_VAR_ARRAY
Kill FLDTOHIDE,FLDTOSHOW
Return

