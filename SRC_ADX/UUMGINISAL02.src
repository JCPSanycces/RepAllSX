#<AdxTL>@(#)7.0.0.0 $Revision$
############################################################################
# UUMGINISAL02   Moulinette de Migration des commandes       Module Ventes #
#                                                                          #
# Migration en V6 :                                                        #
# ---------------                                                          #
#                                                                          #
# Pour toutes les versions                                                 #
# ------------------------                                                 #
# Détail commandes : SORDERP SORDERQ                                       #
# --------------------------                                               #
# Alim. SALFCY à partir de l'entête si différence                          #
# Alim. SOHCAT à partir de l'entête si différence                          #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGINISAL02") From LECFIC
  Endif
  #Call RAZ_UUMGINISAL02(DOSSIER)
  Call MAJ_UUMGINISAL02(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

##########################################################################
# UUMGINISAL02 Moulinette de Migration des commandes normales
Subprog MAJ_UUMGINISAL02(DOSSIER)
Value Char DOSSIER

# Issue 106947 - 20150811 by LD : Migration of historic folder
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
# Issue 106947 - 20150811 by LD

Local Integer TOTNBR
Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N = no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL02",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

#----- Récupération du n° de version
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL02",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif

Local Char WNAMSOHM,WNAMSOPM,WNAMSOQM
Call MIGTABNAME (DOSSIER,"SORDER", WNAMSOHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SORDERP",WNAMSOPM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SORDERQ",WNAMSOQM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL02",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMSOHM,"fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL02",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMSOPM,"fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL02",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMSOQM,"fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL02",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL02",2,ERR) From TRTMIG : #2=En cours

###################

Call ECR_TIME("UUMGINISAL02 Sales Order Process : Update SORDER-Q-P") From DOSSUB
Call ECR_TRACE("UUMGINISAL02 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG

#----- SORDER => TOTNBR= Number of lines  -----#
Call MIGGETTOTNBR (DOSSIER,"SORDER",TOTNBR,ERR) From TRTMIG
Trbegin [AMY]
Call MIGSTKTOTNBR (DOSSIER,"UUMGINISAL02",TOTNBR,ERR) From TRTMIG
Commit

#----- Ouverture des fichiers -----#
If clalev([F:SOHM]) = 0 : Local File =DOSSIER+"."+WNAMSOHM    [SOHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:SOPM]) = 0 : Local File =DOSSIER+"."+WNAMSOPM    [SOPM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:SOQM]) = 0 : Local File =DOSSIER+"."+WNAMSOQM    [SOQM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer NBLUS, NBCOMMIT
Local Integer NBMIGKEY : NBMIGKEY=4
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, NBCOMMIT

# Validation des écrans

# Issue 106947 - 20150811 by LD : Migration of historic folder
# Passage en V6
If VERSION<GMIGX3VER60
    Local Char WHISTFOLD(GLONADS)
    If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
        WHISTFOLD=[F:ADS]DOSSIER
    Else
        WHISTFOLD=[F:ADS]DOSREF
    Endif

    #Call VALIDDIRECT ("SOH0",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    #If GOK<>1
    #  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL02",7,ERR) From TRTMIG : #7=Erreur
    #  Goto FIN
    #Endif
    #Call VALIDDIRECT ("SOH1",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    #If GOK<>1
    #  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL02",7,ERR) From TRTMIG : #7=Erreur
    #  Goto FIN
    #Endif
    #Call VALIDDIRECT ("SOH2",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    #If GOK<>1
    #  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL02",7,ERR) From TRTMIG : #7=Erreur
    #  Goto FIN
    #Endif
    #Call VALIDDIRECT ("SOH3",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    #If GOK<>1
    #  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL02",7,ERR) From TRTMIG : #7=Erreur
    #  Goto FIN
    #Endif
    #Call VALIDDIRECT ("SOH4",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    #If GOK<>1
    #  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL02",7,ERR) From TRTMIG : #7=Erreur
    #  Goto FIN
    #Endif
    #Local Mask =[F:ADS]DOSSIER+".SOH0"    [SOH0]
    #Local Mask =[F:ADS]DOSSIER+".SOH1"    [SOH1]
    #Local Mask =[F:ADS]DOSSIER+".SOH2"    [SOH2]
    #Local Mask =[F:ADS]DOSSIER+".SOH3"    [SOH3]
    #Local Mask =[F:ADS]DOSSIER+".SOH4"    [SOH4]

    Call VALIDDIRECT ("SOH0",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    If GOK<>1
      Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL02",7,ERR) From TRTMIG : #7=Erreur
      Goto FIN
    Endif
    Call VALIDDIRECT ("SOH1",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    If GOK<>1
      Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL02",7,ERR) From TRTMIG : #7=Erreur
      Goto FIN
    Endif
    Call VALIDDIRECT ("SOH2",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    If GOK<>1
      Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL02",7,ERR) From TRTMIG : #7=Erreur
      Goto FIN
    Endif
    Call VALIDDIRECT ("SOH3",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    If GOK<>1
      Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL02",7,ERR) From TRTMIG : #7=Erreur
      Goto FIN
    Endif
    Call VALIDDIRECT ("SOH4",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    If GOK<>1
      Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL02",7,ERR) From TRTMIG : #7=Erreur
      Goto FIN
    Endif
    Local Mask =WHISTFOLD+".SOH0"    [SOH0]
    Local Mask =WHISTFOLD+".SOH1"    [SOH1]
    Local Mask =WHISTFOLD+".SOH2"    [SOH2]
    Local Mask =WHISTFOLD+".SOH3"    [SOH3]
    Local Mask =WHISTFOLD+".SOH4"    [SOH4]
Endif
# Issue 106947 - 20150811 by LD

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGINISAL02",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG

If NBCOMMIT=0
  #----- Suppression des incohérences entre tables avant migration -----#
  Gosub TRT_SQL
  If GOK<1 : Goto FIN : Endif
  Trbegin [AMY]
  NBLUS=TOTNBR
  NBCOMMIT=TOTNBR
  Call MIGSTKKEY (DOSSIER,"UUMGINISAL02",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
  Commit
Endif

$FIN
Close Local File [SOPM], [SOHM], [SOQM]

Call ECR_TIME("UUMGINISAL02 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB

Call MIGTRTEND (DOSSIER,"UUMGINISAL02") From TRTMIG
End


##########################################################################
Subprog RAZ_UUMGINISAL02(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : # N= no module
  End
Endif

Local Char WNAMSOHM,WNAMSOPM,WNAMSOQM
Call MIGTABNAME (DOSSIER,"SORDER", WNAMSOHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SORDERP",WNAMSOPM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SORDERQ",WNAMSOQM,ERR) From TRTMIG
If ERR : End : Endif

If filinfo(filpath("FIL",WNAMSOHM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table
If filinfo(filpath("FIL",WNAMSOPM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table
If filinfo(filpath("FIL",WNAMSOQM,"fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table

##2 - On vide les fichiers selon le cas
#######################################

##3 - On vide AMIGKEY pour le flux
####################
Call MIGRAZKEY (DOSSIER,"UUMGINISAL02",ERR) From TRTMIG

End

########################################################################
$TRT_SQL
 #2- alimenter la nouvelle colonne si vide
 #----- Ouverture des fichiers -----#
 #-----  Déclaration des variables -----#

 Call DEBTRANS From GLOCK
 Gosub SET_FIRST From TRTFIRST

 Trbegin [SOPM]
 GOK = 1

 Gosub TRT_SQL1
 Gosub TRT_SQL2

 If GOK<1
  Rollback
 Else
  Commit
 Endif

Gosub UNSET_FIRST From TRTFIRST

Return

########################################################################
# Mise à jour SALFCY SORDERP SORDERQ à partir de SALFCY SORDER
########################################################################
$TRT_SQL1
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL

REQSQL(0)="UPDATE"-DOSSIER+"."+WNAMSOPM+" SET SALFCY_0="
REQSQL(1)="(SELECT SOH.SALFCY_0 FROM"-DOSSIER+"."+WNAMSOHM+" SOH Where SOH.SOHNUM_0="+WNAMSOPM+".SOHNUM_0)"
REQSQL(2)=" WHERE "+WNAMSOPM+".SALFCY_0<>(SELECT SOH.SALFCY_0 From"-DOSSIER+"."+WNAMSOHM+" SOH Where SOH.SOHNUM_0="+WNAMSOPM+".SOHNUM_0) "
Execsql From num$(GTYPDBA*2+1) Sql REQSQL

REQSQL(0)="UPDATE"-DOSSIER+"."+WNAMSOQM+" SET SALFCY_0="
REQSQL(1)="(SELECT SOH.SALFCY_0 FROM"-DOSSIER+"."+WNAMSOHM+" SOH Where SOH.SOHNUM_0="+WNAMSOQM+".SOHNUM_0)"
REQSQL(2)=" WHERE "+WNAMSOQM+".SALFCY_0<>(SELECT SOH.SALFCY_0 From"-DOSSIER+"."+WNAMSOHM+" SOH Where SOH.SOHNUM_0="+WNAMSOQM+".SOHNUM_0) "
Execsql From num$(GTYPDBA*2+1) Sql REQSQL

Onerrgo
Return
########################################################################
# Mise à jour SOHCAT SORDERP SORDERQ à partir de SOHCAT SORDER
########################################################################
$TRT_SQL2
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL

REQSQL(0)="UPDATE"-DOSSIER+"."+WNAMSOPM+" SET SOHCAT_0="
REQSQL(1)="(SELECT SOH.SOHCAT_0 FROM"-DOSSIER+"."+WNAMSOHM+" SOH Where SOH.SOHNUM_0="+WNAMSOPM+".SOHNUM_0)"
REQSQL(2)=" WHERE "+WNAMSOPM+".SOHCAT_0<>(SELECT SOH.SOHCAT_0 From"-DOSSIER+"."+WNAMSOHM+" SOH Where SOH.SOHNUM_0="+WNAMSOPM+".SOHNUM_0) "
Execsql From num$(GTYPDBA*2+1) Sql REQSQL

REQSQL(0)="UPDATE"-DOSSIER+"."+WNAMSOQM+" SET SOHCAT_0="
REQSQL(1)="(SELECT SOH.SOHCAT_0 FROM"-DOSSIER+"."+WNAMSOHM+" SOH Where SOH.SOHNUM_0="+WNAMSOQM+".SOHNUM_0)"
REQSQL(2)=" WHERE "+WNAMSOQM+".SOHCAT_0<>(SELECT SOH.SOHCAT_0 From"-DOSSIER+"."+WNAMSOHM+" SOH Where SOH.SOHNUM_0="+WNAMSOQM+".SOHNUM_0) "
Execsql From num$(GTYPDBA*2+1) Sql REQSQL

Onerrgo
Return
###################################################################################################
$ERR_SQL
 GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
 Call ECR_TRACE(GMESSAGE,1) From GESECRAN
 GOK=0
Resume

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 106947 - 20150811 by LD : Migration of historic folder
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
# Issue 106947 - 20150811 by LD
Call MAJ_UUMGINISAL02(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGINISAL02(APPLI)
End

