#<AdxTL>@(#)4.0.0.0 $Revision$ Gestion objet BIN
Raz GPILOBJ
Call OBJET("BIN",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "RAZCRE"    : Gosub RAZCRE
 When "LIENS"     : Gosub LIENS
 When "VERIF_CRE" : Gosub VERIF_CRE
 When "APRES_CRE" : Gosub MAJPAR
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "APRES_MOD" : Gosub MAJPAR
 When "AP_CHANGE" : Gosub MAJPAR
 When "AP_ANNULE" : Gosub MAJPAR
 When "EXEBOUT"   : Gosub EXEBOUT
#39925
 When "SETBOUT"   : Gosub SETBOUT
Endcase
Return

$LIENS
Call C_LIG([F:BIN]LIG)
Call C_COL([F:BIN]COL)
Call C_TXTFLG([F:BIN]TXTFLG)
Gosub AIDE
Return

$MAJPAR
Call SETPAR From GENBILSOC
Return

$OUVRE
Local Char TEXAID(150)(1..300)
Openi filpath("TRT","SUBCALBIL","src")
Rdseq TEXAID(1)
K = 0
While K<dim(TEXAID) & fstat=0
 K += 1
 Rdseq TEXAID(K)
 TEXAID(K) += chr$(13)+chr$(10)
Wend
Openi
Gosub AIDE
Return

$RAZCRE
Gosub AIDE
Affzo [BIN3]AIDE
Return

$AIDE
Setlob [M:BIN3]AIDE With TEXAID
Return

$EXEBOUT
Case BOUT
 When "V"
  Call OUVRE_TRACE(mess(159,133,1)-"WWBILSOC") From LECFIC
  Call GENBILSOC(nomap) From GENBILSOC
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endcase
Return

$SETBOUT
#39925
If CLECUR=0 | REP<>"" | !VERROU
 Call VIREBOUT(CHAINE,"V") From GOBJET
Endif
Return

$VERIF_CRE
$VERIF_MOD
If [M:BIN1]LIG=10 & [M:BIN1]NBLIG<2
 [V]GMESSAGE=mess(20,10716,1)
 #           Pour une ventilation des lignes manuelle au moins 2 lignes doivent
 #           être définies
 [L]OK      =0
 Return
Endif
If [M:BIN1]COL=10 & [M:BIN1]NBCOL<2
 [V]GMESSAGE=mess(21,10716,1)
 #           Pour une ventilation des colonnes manuelle au moins 2 colonnes doivent
 #           être définies
 [L]OK      =0
 Return
Endif
Return

##########################################################
## Ecran BIN1
##########################################################
Subprog C_LIG(VALEUR)
Value Integer VALEUR
If VALEUR<>10
 Effzo [BIN1]NBLIG
 Grizo [BIN1]NBLIG
Else
 Actzo [BIN1]NBLIG
Endif
If VALEUR=1
 [M:BIN1]TOTLIG = 1
 Grizo [BIN1]TOTLIG
 Affzo [BIN1]TOTLIG
Else
 [M:BIN1]TXTFLG = 1
 Call C_TXTFLG([M:BIN1]TXTFLG)
 Affzo [BIN1]TXTFLG
 Actzo [BIN1]TOTLIG
Endif
End

Subprog C_COL(VALEUR)
Value Integer VALEUR

If [L]VALEUR=[M:BIN1]LIG & !find([L]VALEUR,1,10)
 [V]GMESSAGE=mess(22,10716,1)
 #           Les ventilations lignes et colonnes doivent être différentes
 mkstat     =2
 End
Endif

If VALEUR<>10
 Effzo [BIN1]NBCOL
 Grizo [BIN1]NBCOL
Else
 Actzo [BIN1]NBCOL
Endif
If VALEUR=1
 [M:BIN1]TOTCOL = 1
 Grizo [BIN1]TOTCOL
 Affzo [BIN1]TOTCOL
Else
 [M:BIN1]TXTFLG = 1
 Call C_TXTFLG([M:BIN1]TXTFLG)
 Affzo [BIN1]TXTFLG
 Actzo [BIN1]TOTCOL
Endif
End

Subprog C_TXTFLG(VALEUR)
Value Integer VALEUR
If VALEUR=2
 [M:BIN1]LIG = 1
 [M:BIN1]COL = 1
 [M:BIN1]DEC = 0
 Affzo [BIN1]LIG,COL,DEC
 Grizo [BIN1]DEC
 Call C_LIG([M:BIN1]LIG)
 Call C_COL([M:BIN1]COL)
Else
 Actzo [BIN1]DEC
Endif
End

Subprog C_TYP(VALEUR)
Variable Integer VALEUR
If VALEUR=4 & [M:BIN1]LIG<>1
 GMESSAGE = mess(1,10716,1) : # Type de graphique incorrect
 mkstat = 2 : End
Endif
End

######################################################################################
## Ecran BIN2
######################################################################################
Subprog C_CLB2(VALEUR)
Variable Clbfile VALEUR

Call CONT_CLOB([L]VALEUR)

End

Subprog C_CLB3(VALEUR)
Variable Clbfile VALEUR

Call CONT_CLOB([L]VALEUR)

End

Subprog C_CLB4(VALEUR)
Variable Clbfile VALEUR

Call CONT_CLOB([L]VALEUR)

End

Subprog CONT_CLOB(CLOB)
Variable Clbfile CLOB()
Local Char    TEXTE(80)(1..200)
Local Char    TRAIT(80)(1..200)
Local Char    LIGNE(80)
Local Integer I , J , K

Setlob TEXTE With CLOB
I = 1
K = 1
Raz TRAIT
While TEXTE(I)<>""
 J = instr(1,TEXTE(I),chr$(10))
 If J
  LIGNE = left$(TEXTE(I),J-1)
  TEXTE(I) = right$(TEXTE(I),J+1)
  If right$(LIGNE,len(LIGNE))=chr$(13)
   LIGNE = left$(LIGNE,len(LIGNE)-1)
  Endif
  TRAIT(K) += LIGNE
  K += 1
  If TEXTE(I)=""
   I + = 1
  Endif
 Else
  LIGNE = TEXTE(I)
  If right$(LIGNE,len(LIGNE))=chr$(13)
   LIGNE = left$(LIGNE,len(LIGNE)-1)
  Endif
  TRAIT(K) += LIGNE
  I += 1
 Endif
Wend
For I=1 To K
 TRAIT(I) = vireblc(format$("KT:250X",TRAIT(I)),1)+string$(I<K,chr$(13)+chr$(10))
Next I
Setlob CLOB With TRAIT(1..K)
End
