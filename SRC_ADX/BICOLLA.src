############################################################
Funprog TAUXFRAIS(COLLAB)
Value Char    COLLAB
Local Char TAUXFRAIS(10)

If clalev([F:EXM])=0 : Local File =GDOSSIER+".EXPARAM" [EXM] : Endif
If clalev([F:ADU])=0 : Local File =GDOSSIER+".ADOVALAUS" [ADU] : Endif

Local Integer ZKMFRAIS(1)
Local Integer ZCATFRAIS(1)

Read [ADU]ADU0 = [L]COLLAB;'EXPMIL'
If !fstat
    [L]ZKMFRAIS = val(left$([F:ADU]VALEUR,1))
    Read [ADU]ADU0 = [L]COLLAB;'EXPVHL'
    If !fstat
        [L]ZCATFRAIS= val(left$([F:ADU]VALEUR,1))
        Read [EXM]EXM0 = [L]ZKMFRAIS;[L]ZCATFRAIS
        If fstat
           Raz TAUXFRAIS
        Else
           TAUXFRAIS= left$([F:ADU]VALEUR,10)
        Endif
     Else
        Raz TAUXFRAIS
     Endif
Else
     Raz TAUXFRAIS
Endif
End TAUXFRAIS

####
# Pour filtre synchronisation EXPENSES
# Récupération du référentiel à partir de la société et du type de référentiel
##################################################################################
Funprog GETLED(CPY,LEDTYP) 
Value Char CPY
Value Integer LEDTYP
Local Char LED(GLONLED)
If !clalev([F:CPY]) : Local File COMPANY  [CPY] : Endif
If !clalev([F:GCM]) : Local File GACM     [GCM] : Endif
Call LECTURE ("CPY",CPY,"") From CONTOBJ
Call LECTURE ("GCM",[F:CPY]ACM,"") From CONTOBJ
LED=[F:GCM]LED(LEDTYP-1)
End LED


