############################################################
## Fonctions pour la BI Compta V6
## Univers Notes de frais
## Alimentation de la dimension COLLABORA
############################################################

############################################################
Funprog FORFHEB(COLLAB)
Value Char    COLLAB
Local Char FORFHEBERG(10)

If clalev([F:ADU])=0 : Local File =GDOSSIER+".ADOVALAUS" [ADU] : Endif
Read [ADU]ADU0 = [L]COLLAB;'EXPAMT1'
If fstat
 Raz FORFHEBERG
Else
    FORFHEBERG = vireblc(format$("N:8.2",left$([F:ADU]VALEUR,10)),4)
Endif
End FORFHEBERG

