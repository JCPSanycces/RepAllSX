#<AdxTL>@(#)3.0.0.0 $Revision$
############################################################
# CFGLIBE : présentation des écrans de saisie configurateur
# génération d'écrans paramétrés à partir de CFGINI,CFGSCE
############################################################
# Action SAICFGPOS appelée depuis les fenêtres/préfixe écran
#     -  OCFG Scénario                        WUX ou ZUX
#     -  OCFM Procédures                      WUI
#     -  OCOV Options/Variantes               WUA
#     -  OCSE Sélections configurateur        WUA (WUS ?)
#     -  OCSH Formes/Modèles                  WUF
# PARAM(01): dossier courant
# PARAM(02): écran de référence (CFGINI, CFGSCE, spécifique)
# PARAM(03): référence écran (scénario, symbole, ...)
# PARAM(04): option code xYYYzzz
#            x  : selon bouton C=Créer, M=Enregistrer, V=Validation
#            YYY: préfixe écran
#            zzz: position des blocs (12 ou 234) obsolète ?
# PARAM(05): symbole nom du champ/tableau contenant la liste des questions
# PARAM(06): titre
# PARAM(07): clé
# PARAM(08): intitulé
# PARAM(09): longueur des champs alphanumériques contrôlés (12)
# PARAM(10): code écran  (à créer), "" si modif/validation
# PARAM(11): code retour (sortie)
############################################################
# V6 FQ 42478
# - 09/2007 GA
#   jusqu'à 6 blocs paramétrables sur 2 lignes / 3 colonnes
# - 12/2007 GA
#   QSTNUM dans l'écran CFGWIN taille tableau de 140 => 250
############################################################
# Issue 82300 CQU 8c => 10c mid$(W_VAR,3,8) devient mid$(W_VAR,3,GLONCQU)
############################################################

Local Integer RET
Local Char WMSG(250)
Call LOCK_CFGSYM(RET, WMSG) From SUBCFG
#Infbox "Returned value:"-num$(RET)
End
#
# Action SAICFGPOS : saisie des positions fenetres saisie configurateur
#
############################################################
# Pas de traitement si tableau des questions vide
$INIT_POS
If evalue(PARAM(05)+"(0) = ''") | PARAM(02) = "" | GOK <> 1
  PARAM(11) = "0"
  FIN = 1
Else
  GSINTV1 = PARAM(06)
  If GFONC1 = "FUNCFGUTI"
    If GCFGVAL <> 2
      # FQ 52236 If clalev([M:CWIN]) = 0 : Local Mask CFGWIN [CWIN] : Endif
      Gosub OUVRE_POS From CFGLIBE
      Gosub DEBUT_POS From CFGLIBE
      Gosub OK_POS    From CFGLIBE
      FIN = 1
    Endif
  Endif
Endif
If GFONCTION = "FUNCFGUTI" & dim([M:CFGU]PRO) > 0
  [M:CFGU]PRO = PARAM(06)-PARAM(07)-PARAM(08)
  Affzo [M:CFGU]PRO
Endif
Return
############################################################
$OUVRE_POS                                                      # ex avec sélection de code WUAJJPLT
Local    Char    LAPP(GLONADS) : LAPP = PARAM(01)               #    Dossier courant (GX3APP)
Local    Char    LREF(10) : LREF = PARAM(02)                    #    CFGINI,CFGSCE        (param EcranRef)
Local    Char    LPAR(10) : LPAR = PARAM(04)                    #    MWUA12 (m:modif, WUA:prefixe ecran, positions des blocs) (param Option)
Local    Char    LMAJ(1)  : LMAJ = left$(LPAR,1)
Local    Char    LMSK(10) : LMSK = mid$(LPAR,2,3)+PARAM(03)     #    WUA + JJPLT  (param Ecran)
Local    Integer LOPT     : LOPT = val(PARAM(09))               #    12
#
Local    Integer W_STAT
Local    Char    W_PFX(3) : W_PFX = mid$(LPAR,2,3) : # GA ajout en V6 42478 09/2007 préfixe écran
Local    Char    W_SUF(4)
Local    Integer W_LAN
Local    Char    W_GLANGUE(3)
Local    Char    W_FICANU(GDIMFIC)
Local    Char    W_TRTANU(GDIMFIC)
Local    Char    W_FLD(20)                                      # FQ 52854
Local    Char    W_MSKSAI(10)                                   # FQ 52854
Local    Char    W_MSK(10)
#
Local    Decimal W_NBR, W_NBS

#
Local    Integer W_NBF    : # Nombre de questions
Local    Integer W_MAXQST : # Nombre maximum de Questions       # FQ 64278 GA 06/2010
Local    Integer W_NBL    : # Nombre de champs maximum
Local    Integer W_NBL1   : # Nombre de lignes blocs 1,2,3
Local    Integer W_NBL2   : # Nombre de lignes blocs 4,5,6
Local    Integer W_HEA    : # Nombre de lignes entete
Local    Integer W_HEAFLG : # Indicateur présence d'un bloc entete (0=Non, 1=Oui)
Local    Integer W_LAL    : # Longueur champs alphanumériques
Local    Integer W_BLONBR : # Numéro du bloc courant  # GA ajout en V6 42478 12/2007
#
Local    Integer W_I, W_J, W_K, W_L, W_M, W_N, W_O, W_POS
#
If clalev([M:CWIN])= 0 :  Local Mask =LAPP+".CFGWIN"    [CWIN]  : Endif        # FQ 52236 GA 02/2009
Gosub CFG_CONSTANTES From CFGLIB
#
If clalev([F:ADS1])= 0 :  Local File ADOSSIER           [ADS1]  : Endif
If clalev([F:ATY])= 0  :  Local File =LAPP+".ATYPE"     [ATY]   : Endif
If clalev([F:CQU])= 0  :  Local File =LAPP+".CFGQST"    [CQU]   : Endif
If clalev([F:CSH])=0   :  Local File =LAPP+".CFGSHA"    [CSH]   : Endif        # jpj 18/12/03
If clalev([F:AMK1])= 0 :  Local File =LAPP+".AMSK"      [AMK1]  : Endif
If clalev([F:AMK2])= 0 :  Local File =LAPP+".AMSK"      [AMK2]  : Endif
If clalev([F:AMZ1])= 0 :  Local File =LAPP+".AMSKZON"   [AMZ1]  : Endif
If clalev([F:AMZ2])= 0 :  Local File =LAPP+".AMSKZON"   [AMZ2]  : Endif
If clalev([F:AMA1])= 0 :  Local File =LAPP+".AMSKACT"   [AMA1]  : Endif
If clalev([F:AMA2])= 0 :  Local File =LAPP+".AMSKACT"   [AMA2]  : Endif
If clalev([F:AMP1])= 0 :  Local File =LAPP+".AMSKPAR"   [AMP1]  : Endif
If clalev([F:AMP2])= 0 :  Local File =LAPP+".AMSKPAR"   [AMP2]  : Endif
If clalev([F:AWT1])= 0 :  Local File =LAPP+".AWINBOUT"  [AWT1]  : Endif
If clalev([F:AWT2])= 0 :  Local File =LAPP+".AWINBOUT"  [AWT2]  : Endif
If clalev([F:AWB1])= 0 :  Local File =LAPP+".AWINBRO"   [AWB1]  : Endif
If clalev([F:AWB2])= 0 :  Local File =LAPP+".AWINBRO"   [AWB2]  : Endif
If clalev([M:COWI])= 0 :  Local Mask =LAPP+".CFGWIN"    [COWI]  : Endif
If clalev([F:ATX]) = 0 :  Local File =LAPP+".ATEXTE"    [ATX]   : Endif        # GA 09/2007
If clalev([F:AXX0])= 0 :  Local File =LAPP+".ATEXTRA"   [AXX0]  : Endif        # GA 09/2007
#CHECK IGNORE_BEGIN
If GVERSION>="1.7.0"   # Issue 83581
  If clalev([F:AMC1])= 0 :  Local File =LAPP+".AMOTCLE" [AMC1] : Endif
  If clalev([F:AMC2])= 0 :  Local File =LAPP+".AMOTCLE" [AMC2] : Endif
Endif
#CHECK IGNORE_END

# Recherche taille zones de type "DES"
Read [ATY]CODTYP="DES"
If fstat = 0
  W_LAL = [F:ATY]LNGTYP
Else
  W_LAL = 30
Endif
# Calcul de la taille du bloc entete
W_HEA = 0
Filter [AMZ1] Where CODMSK = LREF &
&                   SAIAFF < 3
&             Order By Key CODZON
For [AMZ1]
  Case [F:AMZ1]CODZON
    When "FLD"
      Break
    When Default :
      If [F:AMZ1]TYPGRAPH = 8
        If int([F:AMZ1]VAL1) > W_HEA
          W_HEA = int([F:AMZ1]VAL1)
        Endif
      Else
        If int([F:AMZ1]NOZONE) > W_HEA
          W_HEA = int([F:AMZ1]NOZONE)
        Endif
      Endif
   Endcase
Next
Filter [AMZ1]
W_HEA += 2
If W_HEA>2 W_HEAFLG=1 Else W_HEAFLG=0 Endif
#
############################################################
# Lecture parametres dossier
Read [ADS1]DOSSIER=LAPP
If fstat
  Call RSTA("ADS1",LAPP) From GLOCK
  GERR = 1
  FIN  = 1
  Goto OUVRE_POS_FIN
Endif
# Calcul nombre de questions
Gosub TAB_SYMBOLES From =LAPP+".WUVAR"
#
$OUVRE_POS_FIN
Return
############################################################
$DEBUT_POS
Local Integer WBLONBR,WLINNBR         # FQ 62993 GA 03/2010
Raz [M:CWIN]
Raz [M:COWI]
[M:CWIN]NUM    = PARAM(07)
[M:CWIN]DES    = PARAM(08)
If LMAJ = "C" & PARAM(10) <> ""
  W_MSK = W_PFX+PARAM(10)
Else
  W_MSK = LMSK
  # si écran absent, on reprend l'écran de référence
  Read [AMK2]CODMSK=LMSK
  If fstat W_MSK = LREF Endif
Endif
#
Local Integer IBLO1,IBLO2,IBLO3,IBLO4,IBLO5,IBLO6,IBLOI
IBLO1 = val(mid$(LPAR,5,1)) : If IBLO1=0 IBLO1=1 Endif
IBLO2 = val(mid$(LPAR,6,1)) : If IBLO2=0 IBLO2=2 Endif
IBLO3 = val(mid$(LPAR,7,1)) : If IBLO3=0 IBLO3=3 Endif
IBLO4 = val(mid$(LPAR,8,1)) : If IBLO4=0 IBLO4=4 Endif   # V6
IBLO5 = val(mid$(LPAR,9,1)) : If IBLO5=0 IBLO5=5 Endif   # V6
IBLO6 = val(mid$(LPAR,10,1)): If IBLO6=0 IBLO6=6 Endif   # V6
#
Read [AMK2]CODMSK=W_MSK
If fstat = 0 : # Ecran trouvé
################## A V A N T ##################################
####  For W_I = 0 To dim([F:AMK2]INTBLOC)-1
####    If [F:AMK2]INTBLOC(W_I) <> ""
####      Assign "[M:COWI]INTBLOC(W_I)" With  evalue([F:AMK2]INTBLOC(W_I))
####    Endif
####  Next W_I
####  W_I = 0
####  Filter [AMZ2] Where CODMSK = W_MSK  &
####&                     left$([F:AMZ2]CODZON,2) = W_PRQ
####&               Order By Key CODZON
####  For [AMZ2]
####    Assign "[M:COWI]QSTNUM(W_I)" With mid$([F:AMZ2]CODZON,3,GLONCQU)
####    Case [F:AMZ2]NUMBLOC
####      When val(mid$(LPAR,5,1)) :
####        Assign "[M:COWI]BLONBR(W_I)" With 1
####      When val(mid$(LPAR,6,1)) :
####        Assign "[M:COWI]BLONBR(W_I)" With 2
####      When val(mid$(LPAR,7,1)) :
####        Assign "[M:COWI]BLONBR(W_I)" With 3
####    Endcase
####    Assign "[M:COWI]LINNBR(W_I)" With [F:AMZ2]NOZONE
####    W_I += 1
####    Assign "[M:COWI]NBLIG"       With W_I
####  Next
####  Filter [AMZ2]
###############################################################

# GA pour la V6 42478 09/2007 jusqu'à 6 blocs paramétrables (sur 3 colonnes)
#                                   + 1 bloc invisible
#                                   + 1 bloc de sélection (dans cetains cas, si W_HEAFLG=1)
# Chargement des blocs dans masque temporaire [M:COWI]
  [M:COWI]NBRLIG  = [F:AMK2]NBRLIG     : # GA V6 12/2007
  [M:COWI]NBRCOL  = [F:AMK2]NBRCOL     : # GA V6 12/2007
  [M:COWI]BLOMAX  = [F:AMK2]NBBLOC-W_HEAFLG : # GA V6 27/12/2007 (nb de blocs sauf entête)
  For W_I = 0 To dim([F:AMK2]INTBLOC)-1
    If W_I < dim([M:CWIN]POSBLOC)
      W_J = W_I+W_HEAFLG : # le 1er bloc de l'écran peut être un bloc entête
      If [F:AMK2]INTBLOC(W_J)<>""
         Assign "[M:COWI]INTBLO(W_I)" With  evalue([F:AMK2]INTBLOC(W_J)) : # Texte evalué
      Endif
      [M:COWI]POSBLOC(W_I) = [F:AMK2]POSBLOC(W_J) : # GA V6 11/2007
      [M:COWI]TYPBLOC(W_I) = [F:AMK2]TYPBLOC(W_J) : # GA V6 11/2007
      [M:COWI]LNGLIB(W_I)  = [F:AMK2]LNGLIB(W_J)  : # GA V6 12/2007
    Endif
  Next W_I

# Chargement des champs dans masque temporaire [M:COWI]
  W_I = 0
  Filter [AMZ2] Where CODMSK = W_MSK  &
&                     left$([F:AMZ2]CODZON,2) = W_PRQ
&               Order By Key CODZON
  For [AMZ2]
    [M:COWI]QSTNUM(W_I) = mid$([F:AMZ2]CODZON,3,GLONCQU)
    [M:COWI]BLONBR(W_I) = [F:AMZ2]NUMBLOC-W_HEAFLG : # position du bloc +/- 1
    [M:COWI]LINNBR(W_I) = [F:AMZ2]NOZONE
    Case [F:AMZ2]NUMBLOC    # transcodif du Bloc ?
       When IBLO1 : [M:COWI]BLONBR(W_I)=1
       When IBLO2 : [M:COWI]BLONBR(W_I)=2
       When IBLO3 : [M:COWI]BLONBR(W_I)=3
       When IBLO4 : [M:COWI]BLONBR(W_I)=4
       When IBLO5 : [M:COWI]BLONBR(W_I)=5
       When IBLO6 : [M:COWI]BLONBR(W_I)=6
    Endcase
    W_I += 1
    [M:COWI]NBLIG = W_I
  Next
  Filter [AMZ2]
Endif
#
Read [AMK1]CODMSK=LREF
If fstat
  Call RSTA("AMK1",LREF) From GLOCK
  GOK  = 0
  GERR = 1
  FIN  = 1
  Goto DEBUT_POS_FIN
Endif
#
# GA pour la V6 42478 09/2007 jusqu'à 6 blocs paramétrables (sur 3 colonnes)
# dans certains cas, il faut pouvoir augmenter la largeur écran (NBRCOL)
#
[M:CWIN]BLOMIN = 1
[M:CWIN]BLOMAX = max([M:COWI]BLOMAX,max([M:COWI]BLONBR))
[M:CWIN]NBBLO  = [M:CWIN]BLOMAX
If [M:COWI]NBRCOL<>0
   [M:CWIN]NBRCOL = [M:COWI]NBRCOL          : # GA V6 12/2007
   [M:CWIN]NBRLIG = [M:COWI]NBRLIG          : # GA V6 12/2007
Else
   [M:CWIN]NBRCOL = [F:CSC]NBRCOL           : # GA V6 03/2009 FQ 52854
   [M:CWIN]NBRLIG = [F:CSC]NBRLIG           : # GA V6 03/2009 FQ 52854
Endif
#
For W_I=0 To [M:CWIN]BLOMAX-1
  [M:CWIN]INTBLO(W_I)  = [M:COWI]INTBLO(W_I)
  [M:CWIN]POSBLOC(W_I) = [M:COWI]POSBLOC(W_I)
  [M:CWIN]TYPBLOC(W_I) = [M:COWI]TYPBLOC(W_I)
  [M:CWIN]LNGLIB(W_I)  = [M:COWI]LNGLIB(W_I) : # GA V6 12/2007
  [M:CWIN]LINMIN(W_I)  = 1
  If [M:CWIN]TYPBLOC(W_I)=5 [M:CWIN]LINMAX(W_I)=99 Else [M:CWIN]LINMAX(W_I)=[M:CWIN]NBRLIG-W_HEA-1  Endif
Next
W_K = 0
W_L = 0
[M:CWIN]NBLIG = 0
# FQ 52854 masque de saisie contenant les champs Questions
If instr(1,PARAM(05),"]")
   W_MSKSAI = left$(PARAM(05),instr(1,PARAM(05),"]"))
Else
   Raz W_MSKSAI
Endif
For W_I = 0 To evalue("dim("+PARAM(05)+")-1")
  If evalue(PARAM(05)+"(W_I)")="" Break Endif   # FQ 62993 GA 03/2010
  W_VAR = W_PRS+evalue(PARAM(05)+"(W_I)")
  W_FLD = evalue(PARAM(05)+"(W_I)")
  W_J = find(W_VAR,W_VARLAB)
  If W_J <> 0
    Read [CQU]CQU0=W_FLD
    If fstat = 0 & [F:CQU]QSTTYP = 1
      W_L = [M:CWIN]NBLIG
      [M:CWIN]QSTNUM(W_L) = W_FLD
      [M:CWIN]QSTSHO(W_L) = evalue(W_PRX+mid$(W_VARLAB(W_J-1),3,GLONCQU))
      [M:CWIN]LINNBR(W_L) = 0
      [M:CWIN]BLONBR(W_L) = 0
      # -------------------------------------------------------------
      # 1er cas: no ligne et no bloc sont relus dans le paramétrage
      # -------------------------------------------------------------
      # FQ 52854 masque de saisie contenant les champs Questions
      If W_MSKSAI<>"" & evalue("dim("+W_MSKSAI+"BLONBR(W_I))")>0 & evalue("dim("+W_MSKSAI+"LINNBR(W_I))")>0
          # FQ 59026 GA 11/2009 nouveaux champs: laisser BLONBR/LINNBR à 0
          If [M:CWIN]QSTNUM(W_L) = evalue(W_MSKSAI+"QSTNUM(W_I)") # ssi on connait les coordonnées
             [M:CWIN]LINNBR(W_L) = evalue(W_MSKSAI+"LINNBR(W_I)")
             [M:CWIN]BLONBR(W_L) = evalue(W_MSKSAI+"BLONBR(W_I)")
          Elsif W_MSKSAI="[M:CFG0]"
             W_POS = find(W_FLD,[F:CSC]QSTNUM(0..dim([F:CSC]BLONBR)-1))
             If W_POS>0 & W_POS<>W_I+1
               [M:CWIN]LINNBR(W_L) = [F:CSC]LINNBR(W_POS-1)
               [M:CWIN]BLONBR(W_L) = [F:CSC]BLONBR(W_POS-1)
             Endif
          Endif
      Elsif [M:COWI]NBLIG = 0
      # -------------------------------------------------------------
      # 2eme cas: initialisation par défaut
      # -------------------------------------------------------------
# FQ 62993 GA 03/2010 =====  cf + bas init par défaut des nouveaux champs ==========
###          W_K += 1
###          [M:CWIN]BLONBR(W_L) = 1 : # par défaut on met tout dans le bloc 1
###          [M:CWIN]LINNBR(W_L) = W_K
      Else
      # -------------------------------------------------------------
      # 3eme cas: on a chargé l'écran dans [M:COWI]
      # -------------------------------------------------------------
       W_M = find(W_FLD,[M:COWI]QSTNUM(0..[M:COWI]NBLIG-1))
        If W_M > 0
          [M:CWIN]BLONBR(W_L) = [M:COWI]BLONBR(W_M-1)
          [M:CWIN]LINNBR(W_L) = [M:COWI]LINNBR(W_M-1)
        # FQ 52854 ne pas raz si ces infos sont déjà chargées depuis [F:CSC]
        #Else
        #  [M:CWIN]BLONBR(W_L) = 0
        #  [M:CWIN]LINNBR(W_L) = 0
        Endif
      Endif
      [M:CWIN]NBLIG += 1
    Endif
  Endif
Next W_I
# FQ 62993 GA 03/2010 ce serait mieux de ne pas chercher à remplir les trous ...
### # Affectation lignes nouvelles
### Local Integer WOCC([M:CWIN]BLOMAX+1,100)
### For W_I = 0 To [M:CWIN]NBLIG-1
###   If [M:CWIN]BLONBR(W_I) <> 0 & [M:CWIN]LINNBR(W_I) <> 0
###     WOCC([M:CWIN]BLONBR(W_I),[M:CWIN]LINNBR(W_I)) = 1
###   Endif
### Next W_I
### #
### For W_I = 0 To [M:CWIN]NBLIG-1
###   If [M:CWIN]BLONBR(W_I) = 0 | [M:CWIN]LINNBR(W_I) = 0
###     For W_J = [M:CWIN]BLOMIN To [M:CWIN]BLOMAX
###       For W_K =[M:CWIN]LINMIN(W_J) To [M:CWIN]LINMAX(W_J)
###         If WOCC(W_J,W_K) = 0
###           [M:CWIN]BLONBR(W_I) = W_J
###           [M:CWIN]LINNBR(W_I) = W_K
###           WOCC([M:CWIN]BLONBR(W_I),[M:CWIN]LINNBR(W_I)) = 1
###           Break 2
###         Endif
###       Next W_K
###     Next W_J
###   Endif
### Next W_I
For W_I = 0 To [M:CWIN]NBLIG-1
    If [M:CWIN]BLONBR(W_I) = 0 | [M:CWIN]LINNBR(W_I) = 0
      # FQ 62993 GA 03/2010 champ sous-scénario => Bloc invisible par défaut
      # -------------------------------------------------------------
      # Initialisation par défaut (nouveaux champs)
      # -------------------------------------------------------------
        If evalue("dim("+W_MSKSAI+"TABSCE(W_I))")>0
&        & evalue(W_MSKSAI+"TABSCE(W_I)")<>""
&        & evalue(W_MSKSAI+"TABSCE(W_I)")<>evalue(W_MSKSAI+"SCENUM")
          Call NEWPOS_INVISIBLE(WBLONBR,WLINNBR)
        Else
          Call NEWPOS_VISIBLE(WBLONBR,WLINNBR)
        Endif
        [M:CWIN]BLONBR(W_I)=WBLONBR
        [M:CWIN]LINNBR(W_I)=WLINNBR
   Endif
Next W_I
# Tri par bloc et ligne
Sorta [M:CWIN]NBLIG [M:CWIN]NBLIG Order By [M:CWIN]BLONBR(indice), [M:CWIN]LINNBR(indice)

# Taille de l'écran: Comptage du nb max de lignes des blocs (1,2,3) et (4,5,6)
For W_I = 0 To [M:CWIN]NBLIG-1
  WBLONBR = [M:CWIN]BLONBR(W_I)
  If WBLONBR>0 & find([M:CWIN]TYPBLOC(WBLONBR-1),2,9) : # Bloc Liste ou Html
    Case WBLONBR
      When 1,2,3 : W_NBL1 = max(W_NBL1,[M:CWIN]LINNBR(W_I)) : [M:CWIN]LINMAX(WBLONBR-1)=max(W_NBL1,10)
      When 4,5,6 : W_NBL2 = max(W_NBL2,[M:CWIN]LINNBR(W_I)) : [M:CWIN]LINMAX(WBLONBR-1)=max(W_NBL2,10)
    Endcase
  Endif
Next W_I
W_NBL = W_NBL1 + W_NBL2 + W_HEA + 1  # FQ 56186 ajout + 1
# FQ 53930 pour ne pas perdre [M:CWIN]NBRLIG
If [M:CWIN]NBRLIG<W_NBL
   [M:CWIN]NBRLIG=W_NBL
Endif

#
$DEBUT_POS_FIN
If GFONCTION = "FUNCFGUTI"        # fonction utilitaire et mode modif présentation
  If GCFGVAL = 2
    Affzo [M:CWIN]
  Endif
Else
  Affzo [M:CWIN]
Endif
Return
############################################################
$AVOK_POS
For W_I = 0 To [M:CWIN]NBLIG-1
  If [M:CWIN]BLONBR(W_I) < [M:CWIN]BLOMIN |
&    [M:CWIN]BLONBR(W_I) > [M:CWIN]BLOMAX |
&    [M:CWIN]LINNBR(W_I) = 0
    Break
  Endif
  For W_J = 0 To  [M:CWIN]NBLIG-1
    If W_J               <> W_I                &
&     [M:CWIN]BLONBR(W_I) =  [M:CWIN]BLONBR(W_J) &
&     [M:CWIN]LINNBR(W_I) =  [M:CWIN]LINNBR(W_J)
      Break
    Endif
  Next W_J
Next W_I
If W_I <= [M:CWIN]NBLIG -1
  GERR = 1
  FIN  = 0
  GMESSAGE = mess(7,188,1)
  Goto AVOK_POS_FIN
Endif
Sorta [M:CWIN]NBLIG [M:CWIN]NBLIG Order By [M:CWIN]BLONBR(indice), [M:CWIN]LINNBR(indice)
For W_I = 0 To [M:CWIN]NBLIG-1
  If W_I > 0                                   &
&    [M:CWIN]BLONBR(W_I) = [M:CWIN]BLONBR(W_I-1) &
&    [M:CWIN]LINNBR(W_I) = [M:CWIN]LINNBR(W_I-1)
      Break
  Endif
Next W_I
If W_I < [M:CWIN]NBLIG-1
  GERR = 1
  FIN  = 0
  GMESSAGE = mess(7,188,1)
  Goto AVOK_POS_FIN
Endif
$AVOK_POS_FIN
Return
############################################################
$OK_POS
# Effacement ancienne fenetre
Call DEL_WIN(LAPP,LMSK,"","") From CFGLIBA
#
# FQ 52854 masque de saisie contenant les champs Questions
If W_MSKSAI<>"" & evalue("dim("+W_MSKSAI+"BLONBR(W_I))")>0 & evalue("dim("+W_MSKSAI+"LINNBR(W_I))")>0
   For W_I=0 To [M:CWIN]NBLIG-1
    ### FQ 55722 GA 06/2009 recopier tout le tableau des questions sinon pb de maj
    ###   #W_K = find(evalue(W_MSKSAI+"QSTNUM(W_I)"),[M:CWIN]QSTNUM)
    ###   W_K = find(evalue(W_MSKSAI+"QSTNUM(W_I)"),[M:CWIN]QSTNUM(0..[M:CWIN]NBLIG-1))
    ###   If W_K>0
    ###      Assign W_MSKSAI+"LINNBR(W_I)" With [M:CWIN]LINNBR(W_K-1)
    ###      Assign W_MSKSAI+"BLONBR(W_I)" With [M:CWIN]BLONBR(W_K-1)
    ###   Endif
       Assign W_MSKSAI+"QSTNUM(W_I)" With [M:CWIN]QSTNUM(W_I)
       Assign W_MSKSAI+"LINNBR(W_I)" With [M:CWIN]LINNBR(W_I)
       Assign W_MSKSAI+"BLONBR(W_I)" With [M:CWIN]BLONBR(W_I)
   Next
   Assign W_MSKSAI+"QSTNBR" With [M:CWIN]NBLIG
Endif
#
W_NBL = max(10,[F:AMK1]NBRLIG)-W_HEA # FQ 56186 avant W_NBL1 + W_NBL2
W_NBF = [M:CWIN]NBLIG
#
[F:AMK2]       = [F:AMK1]
[F:AMK2]CODMSK = LMSK
Case [F:AMK1]CODMSK
When "CFGSHA"
    [F:AMK2]NBRLIG = max(6,W_NBL,W_NBL1+W_NBL2)+1  # gestion avec image (h+1)
When Default
    If dim([M:CWIN]NBRLIG)>0                             # FQ 56186 saisie nb lignes/colonnes
       [F:AMK2]NBRLIG = [M:CWIN]NBRLIG                   # avant max(4,W_NBL,W_NBL1+W_NBL2)+W_HEA
    Else
       [F:AMK2]NBRLIG = max(W_NBL,W_NBL1,W_NBL2)+W_HEA+1 # FQ 56186 ajout + 1
    Endif
Endcase
[F:AMK2]MDL    = 1 : # écran modèle = Faux
[F:AMK2]NBBLOC = [M:CWIN]NBBLO+W_HEAFLG
[F:AMK2]NBRCOL = [M:CWIN]NBRCOL
#
If dim([F:AMK2]INTBLOC) > 0
  For W_I = 0 To dim([F:AMK2]INTBLOC)-1
    If W_I < [M:CWIN]BLOMAX : # [M:CWIN]NBBLO
      W_J = W_I+W_HEAFLG : # le 1er bloc de l'écran peut être un bloc entête
      [F:AMK2]INTBLOC(W_J) = '"'+[M:CWIN]INTBLO(W_I)+'"'
      [F:AMK2]POSBLOC(W_J) =  [M:CWIN]POSBLOC(W_I)           :# GA V6 11/2007
      [F:AMK2]TYPBLOC(W_J) =  [M:CWIN]TYPBLOC(W_I)           :# GA V6 11/2007
      [F:AMK2]LNGLIB(W_J)  =  [M:CWIN]LNGLIB(W_I)            :# GA V6 12/2007
    Endif
  Next
Endif
#
# Issue 96434 GA 03/2014 Block Html: Write is done later
###Write [AMK2]
###If fstat
###  Call FSTA("AMK2") From GLOCK
###  GOK =0
###  Goto OK_POS_FIN
###Endif
# Mise a jour AMSKZON
Filter [AMZ1] Where CODMSK = LREF
&             Order By Key CODE
W_N = 1
For [AMZ1]
  If [F:AMZ1]CODZON = "FLD"
    W_J = 1
    For W_I = 0 To [M:CWIN]NBLIG-1
      [F:AMZ2]       = [F:AMZ1]
      [F:AMZ2]CODMSK = LMSK
#CHECK IGNORE_BEGIN
      If GVERSION>="1.7.0"  Raz [F:AMC2] Endif   # Issue 83581 MOTCLE déplacé dans AMOTCLE [AMC]
#CHECK IGNORE_END
      W_K = find(W_PRS+[M:CWIN]QSTNUM(W_I),W_VARLAB)
      Read [CQU]CQU0=[M:CWIN]QSTNUM(W_I)
      [F:AMZ2]CODZON  = W_PRQ+[M:CWIN]QSTNUM(W_I)
      [F:AMZ2]NUMBLOC = [M:CWIN]BLONBR(W_I)+W_HEAFLG
      [F:AMZ2]NOZONE  = [M:CWIN]LINNBR(W_I)
       If W_K <> 0
        [F:AMZ2]INTEVAL = W_PRX+[M:CWIN]QSTNUM(W_I)
      Else
        [F:AMZ2]INTEVAL = ""
      Endif
      Case [F:CQU]ASWTYP
        When 1 :
          [F:AMZ2]CODTYP   = "A"
          [F:AMZ2]LONG     = W_LAL
          [F:AMZ2]OPTLNG   = 20
          [F:AMZ2]OPTSAI   = ""
          [F:AMZ2]TYPGRAPH = 1
          [F:AMZ2]NOLIB    = 0
#CHECK IGNORE_BEGIN
          If GVERSION>="1.7.0"   # Issue 83581 MOTCLE déplacé dans AMOTCLE [AMC]
            [F:AMC2]TYPZON   = 2
            [F:AMC2]IDENT1   = [F:AMZ2]CODMSK
            [F:AMC2]IDENT2   = [F:AMZ2]CODZON
            [F:AMC2]MOTCLE   = "CFGFLDALP"
          Else
            [F:AMZ2]MOTCLE   = "CFGFLDALP"
          Endif
#CHECK IGNORE_END
        When 2 :
          [F:AMZ2]CODTYP   = "DCB"
          [F:AMZ2]LONG     = 20
          [F:AMZ2]OPTLNG   = 0
          [F:AMZ2]OPTSAI   = "zF"
          [F:AMZ2]TYPGRAPH = 1
          [F:AMZ2]NOLIB    = 0
#CHECK IGNORE_BEGIN
          If GVERSION>="1.7.0"   # Issue 83581 MOTCLE déplacé dans AMOTCLE [AMC]
            [F:AMC2]TYPZON   = 2
            [F:AMC2]IDENT1   = [F:AMZ2]CODMSK
            [F:AMC2]IDENT2   = [F:AMZ2]CODZON
            [F:AMC2]MOTCLE   = "CFGFLDNUM"
          Else
            [F:AMZ2]MOTCLE   = "CFGFLDNUM"
          Endif
#CHECK IGNORE_END
        When 3 :
          [F:AMZ2]CODTYP   = "D"
          [F:AMZ2]LONG     = 0
          [F:AMZ2]OPTLNG   = 0
          [F:AMZ2]OPTSAI   = "Zz2"
          [F:AMZ2]TYPGRAPH = 1
          [F:AMZ2]NOLIB    = 0
#CHECK IGNORE_BEGIN
          If GVERSION>="1.7.0"   # Issue 83581 MOTCLE déplacé dans AMOTCLE [AMC]
            [F:AMC2]TYPZON   = 2
            [F:AMC2]IDENT1   = [F:AMZ2]CODMSK
            [F:AMC2]IDENT2   = [F:AMZ2]CODZON
            [F:AMC2]MOTCLE   = "CFGFLDDAT"
          Else
            [F:AMZ2]MOTCLE   = "CFGFLDDAT"
          Endif
#CHECK IGNORE_END
        When 4 :
          [F:AMZ2]CODTYP   = "M"
          [F:AMZ2]LONG     = 30
          [F:AMZ2]OPTLNG   = 0
          [F:AMZ2]OPTSAI   = ""
          [F:AMZ2]TYPGRAPH = 2
          [F:AMZ2]NOLIB    = 1
#CHECK IGNORE_BEGIN
          If GVERSION>="1.7.0"   # Issue 83581 MOTCLE déplacé dans AMOTCLE [AMC]
            [F:AMC2]TYPZON   = 2
            [F:AMC2]IDENT1   = [F:AMZ2]CODMSK
            [F:AMC2]IDENT2   = [F:AMZ2]CODZON
            [F:AMC2]MOTCLE   = "CFGFLDCAS"
          Else
            [F:AMZ2]MOTCLE   = "CFGFLDCAS"
          Endif
#CHECK IGNORE_END
        When 5 :
          [F:AMZ2]CODTYP   = "A"
          [F:AMZ2]LONG     = 250       # FQ 32446 GA 11/2008 avant 240 (texte tronqué ?)
          [F:AMZ2]OPTLNG   = 40        # JPJ E24274
          [F:AMZ2]OPTSAI   = ""
          [F:AMZ2]TYPGRAPH = 1
          [F:AMZ2]NOLIB    = 0
#CHECK IGNORE_BEGIN
          If GVERSION>="1.7.0"   # Issue 83581 MOTCLE déplacé dans AMOTCLE [AMC]
            [F:AMC2]TYPZON   = 2
            [F:AMC2]IDENT1   = [F:AMZ2]CODMSK
            [F:AMC2]IDENT2   = [F:AMZ2]CODZON
            [F:AMC2]MOTCLE   = "CFGFLDTXT"
          Else
            [F:AMZ2]MOTCLE   = "CFGFLDTXT"
          Endif
#CHECK IGNORE_END
        When 6 :                    # FQ 50451 GA 11/2008
          [F:AMZ2]CODTYP   = "ABB"
          [F:AMZ2]LONG     = GLONABB
          [F:AMZ2]OPTLNG   = 0
          [F:AMZ2]OPTSAI   = ""
          [F:AMZ2]TYPGRAPH = 9      # 10=Texte multi-ligne,9=Photo
          If [F:AMZ2]VAL1=0 [F:AMZ2]VAL1 = 6  Endif    # Nb lignes   de la photo (par défaut)
          If [F:AMZ2]VAL2=0 [F:AMZ2]VAL2 = 20 Endif    # Nb colonnes de la photo (par défaut)
          If [F:AMZ2]VAL3=0 [F:AMZ2]VAL3 = 1  Endif    # Type de photo: 1=Normale, 2=Etirée, 3=Proportionnelle
          [F:AMZ2]NOLIB    = 0
#CHECK IGNORE_BEGIN
          If GVERSION>="1.7.0"   # Issue 83581 MOTCLE déplacé dans AMOTCLE [AMC]
            [F:AMC2]TYPZON   = 2
            [F:AMC2]IDENT1   = [F:AMZ2]CODMSK
            [F:AMC2]IDENT2   = [F:AMZ2]CODZON
            [F:AMC2]MOTCLE   = "CFGFLDBLB"
          Else
            [F:AMZ2]MOTCLE   = "CFGFLDBLB"
          Endif
#CHECK IGNORE_END
        When 7 :                    # FQ 50451 GA 11/2008
          [F:AMZ2]CODTYP   = "ACB"
          [F:AMZ2]LONG     = GLONACB
          [F:AMZ2]OPTLNG   = 0
          [F:AMZ2]OPTSAI   = ""
          [F:AMZ2]TYPGRAPH = 10     # 10=Texte multi-ligne
          [F:AMZ2]NOLIB    = 0
#CHECK IGNORE_BEGIN
          If GVERSION>="1.7.0"   # Issue 83581 MOTCLE déplacé dans AMOTCLE [AMC]
            [F:AMC2]TYPZON   = 2
            [F:AMC2]IDENT1   = [F:AMZ2]CODMSK
            [F:AMC2]IDENT2   = [F:AMZ2]CODZON
            [F:AMC2]MOTCLE   = "CFGFLDCLB"
          Else
            [F:AMZ2]MOTCLE   = "CFGFLDCLB"
          Endif
#CHECK IGNORE_END
          If [F:AMK2]TYPBLOC([F:AMZ2]NUMBLOC-1)=9 # Issue 96434 GA 03/2014 Block Html
             [F:AMK2]BASPAG ([F:AMZ2]NUMBLOC-1)=[F:AMZ2]CODZON
             [F:AMK2]COLBLOC([F:AMZ2]NUMBLOC-1)=2
          Endif
      Endcase
#CHECK IGNORE_BEGIN
      If [F:CQU]MOTCLE <> ""
          If GVERSION>="1.7.0"   # Issue 83581 MOTCLE déplacé dans AMOTCLE [AMC]
            [F:AMC2]TYPZON   = 2
            [F:AMC2]IDENT1   = [F:AMZ2]CODMSK
            [F:AMC2]IDENT2   = [F:AMZ2]CODZON
            [F:AMC2]MOTCLE   = [F:CQU]MOTCLE
          Else
            [F:AMZ2]MOTCLE = [F:CQU]MOTCLE
          Endif
      Endif
#CHECK IGNORE_END
      # jusqu'en V5:
      #  Case [M:CWIN]BLONBR(W_I)
      #    When 1, 2 : [F:AMZ2]SAIAFF = 1
      #    When 3    : [F:AMZ2]SAIAFF = 3
      #  Endcase
      # GA V6 11/2007
      Case [M:CWIN]TYPBLOC([M:CWIN]BLONBR(W_I)-1)
        When 2 : [F:AMZ2]SAIAFF = 1   : # Bloc Liste -> champ Affiché/Saisi
        When 5 : [F:AMZ2]SAIAFF = 3   : # Bloc Invisible
      Endcase
      # Issue 94871 GA 12/2013 condition de saisie ajoutée dans l'écran pour les F&M
      If dim([M:CWIN]CONSAI(W_I))>0 & [M:CWIN]CONSAI(W_I)<>""
         [F:AMZ2]CONSAI     = [M:CWIN]CONSAI(W_I)
      Else
         [F:AMZ2]CONSAI     = ""
      Endif
      [F:AMZ2]NUMLIG     = W_N
      W_N += 1
      Write [AMZ2]
      If fstat
        Call FSTA("AMZ2") From GLOCK
        GOK =0
        Break 2
      Endif
#CHECK IGNORE_BEGIN
      If GVERSION>="1.7.0" & [F:AMC2]MOTCLE<>""  # Issue 83581 MOTCLE déplacé dans AMOTCLE [AMC]
          Write [AMC2]
          If fstat ### Pas d'erreur si mot clé d'aide existant
          ###  Call FSTA("AMC2") From GLOCK
          ###  GOK =0
          ###  Break 3
          Endif
#CHECK IGNORE_END
      Endif
      # FQ 72873 GA 08/2011 ajout type de ctrl 6=Table diverse
      If LOPT > 0 & find([F:CQU]CTLTYP,2,3,4,6) : # type de ctrl: menu local 770
        [F:AMZ2]CODZON     = W_PRZ+[M:CWIN]QSTNUM(W_I)
        [F:AMZ2]INTIT      = 0
        [F:AMZ2]NOZONE    += 0.3
        [F:AMZ2]INTEVAL    = ""
      # jusqu'en V5:
      #  Case [M:CWIN]BLONBR(W_I)
      #    When 1, 2 : [F:AMZ2]SAIAFF = 2
      #    When 3    : [F:AMZ2]SAIAFF = 3 : # Bloc Invisible
      #  Endcase
      # GA V6 11/2007
        Case [M:CWIN]TYPBLOC([M:CWIN]BLONBR(W_I)-1)
          When 2 : [F:AMZ2]SAIAFF = 2   : # Bloc Liste -> champ Affiché/Saisi
          When 5 : [F:AMZ2]SAIAFF = 3   : # Bloc Invisible
        Endcase
        [F:AMZ2]OBLIG      = 1
        [F:AMZ2]CODTYP     = "A"
        [F:AMZ2]LONG       = LOPT
        [F:AMZ2]OPTSAI     = "W"
        [F:AMZ2]NUMLIG     = W_N
        W_N += 1
        Write [AMZ2]
        If fstat
          Call FSTA("AMZ2") From GLOCK
          GOK =0
          Break 2
        Endif
      Endif
      W_J += 1
#
# CCC (19/09/05) Bug 32161
      If [F:AMZ2]SAIAFF<>3
          Filter [AMA1] Where TYPAFF = 1     &
&                             CODAFF = LREF  &
&                             CODZON = "FLD"
&                       Order By Key TYPAFF
          For [AMA1]
            [F:AMA2]       = [F:AMA1]
            [F:AMA2]CODAFF = LMSK
            [F:AMA2]CODZON = W_PRQ+[M:CWIN]QSTNUM(W_I)
            Case [F:AMA1]TYPACT
              When 4 : # Avant_saisie
                Case [F:AMA1]ACTION
                  When "CFGASALP" :
                    Case [F:CQU]ASWTYP
                      When  1 : [F:AMA2]ACTION = "CFGASALP"
                                #If [F:CQU]SHACAT <> ""               # Issue GA 08/2013 on laisse CFGASALP voir + loin
                                #  Read [CSH]CSH0=[F:CQU]SHACAT
                                #  If fstat = 0 & [F:CSH]SHATYP = 2
                                #    [F:AMA2]ACTION = "SAICFGSHA"
                                #  Endif
                                #Endif
                      When  2 : [F:AMA2]ACTION = "CFGASNUM"
                      When  3 : [F:AMA2]ACTION = "CFGASDAT"
                      When  4 : [F:AMA2]ACTION = "CFGASCAS"
                      When  5 : [F:AMA2]ACTION = "CFGASTXT"
                      When  6 : [F:AMA2]ACTION = "CFGASBLB"  : # FQ 50451 GA 11/2008
                      When  7 : [F:AMA2]ACTION = "CFGASCLB"  : # FQ 50451 GA 11/2008
                    Endcase
                    Write [AMA2]
                    If fstat
                      Call FSTA("AMA2") From GLOCK
                      GOK =0
                      Break 2
                    Endif
                  When "SELTCA"
                    Case [F:CQU]CTLTYP
                      When 2 :
                        If [F:CQU]TCT    <> ""
                          Case [F:CQU]ASWTYP
                            When 1, 2 :
                              Write [AMA2]
                              If fstat
                                Call FSTA("AMA2") From GLOCK
                                GOK =0
                                Break 2
                              Endif
                           Endcase
                        Endif
                      When 4 :
                        If [F:CQU]SHACAT <> ""
                          Read [CSH]CSH0=[F:CQU]SHACAT
                          If fstat : GOK =0 : Break 1 : Endif
                          # Issue 94871 GA 12/2013 Cas d'une F&M
                          If [F:CSH]SHATYP <> 2
                            [F:AMA2]ACTION = "SELSHC"
                          Else
                            [F:AMA2]ACTION = "SAICFGSHA"
                          Endif
                          Write [AMA2]
                          If fstat
                             Call FSTA("AMA2") From GLOCK
                             GOK =0
                             Break 2
                          Endif
                        Endif
                      When 5 :
                        [F:AMA2]ACTION = "SAICFGFRT"
                        Write [AMA2]
                        If fstat
                          Call FSTA("AMA2") From GLOCK
                          GOK =0
                          Break 2
                        Endif
                      When 6 :  # FQ 72873 GA 08/2011 ajout type de ctrl 6=Table diverse
                    Endcase
                Endcase
              When 5 : # Contrôle
                Case [F:CQU]ASWTYP
                  When  1 :
                    If [F:CQU]TCT <> ""
                      [F:AMA2]ACTION = "CFGCTRALP"
                    Endif
                    If [F:CQU]CODFIC <> ""
                      [F:AMA2]ACTION = "CFGCTRTAB"
                    Endif
                    If [F:CQU]SHACAT <> ""
                      [F:AMA2]ACTION = "CFGCTRSHA"
                    Endif
                  When  2 : [F:AMA2]ACTION = "CFGCTRNUM"
                  When  3 : [F:AMA2]ACTION = "CFGCTRDAT"
                  When  4 : [F:AMA2]ACTION = "CFGCTRCAS"
                  When  5 : [F:AMA2]ACTION = "CFGCTRTXT"
                  When  6 : [F:AMA2]ACTION = "CFGCTRBLB"  : # FQ 50451 GA 11/2008
                  When  7 : [F:AMA2]ACTION = "CFGCTRCLB"  : # FQ 50451 GA 11/2008
                Endcase
                Write [AMA2]
                If fstat
                  Call FSTA("AMA2") From GLOCK
                  GOK =0
                  Break 2
                Endif
              When 6 :    # gestion après zone
                Case [F:AMA1]ACTION
                  When "CFGAZALP" :                      # Ok sur tab dernier champs
                    If [F:CQU]QSTTYP=1 # & [F:CQU]SHACAT=""    # uniquement sur les questions    # et pas une forme (car Après zone intervient avant Apres_modif des chps
                      Case [F:CQU]ASWTYP
                        When  1 : [F:AMA2]ACTION = "CFGAZALP"
                        When  2 : [F:AMA2]ACTION = "CFGAZNUM"
                        When  3 : [F:AMA2]ACTION = "CFGAZDAT"
                        When  4 : [F:AMA2]ACTION = "CFGAZCAS"
                        When  5 : [F:AMA2]ACTION = "CFGAZTXT"
                        When  6 : [F:AMA2]ACTION = "CFGAZBLB"  : # FQ 50451 GA 11/2008
                        When  7 : [F:AMA2]ACTION = "CFGAZCLB"  : # FQ 50451 GA 11/2008
                     Endcase
                     Write [AMA2]
                     If fstat
                        Call FSTA("AMA2") From GLOCK
                        GOK =0
                        Break 2
                     Endif
                    Endif
                  Endcase
              When 7 : # Apres_modif
                Case [F:AMA1]ACTION
                  When  "SAICFGSHA" :
                    If [F:CQU]ASWTYP = 1 & [F:CQU]SHACAT <> ""
                      [F:AMA2]ACTION = "SAICFGSHA"
                      Write [AMA2]
                      If fstat
                        Call FSTA("AMA2") From GLOCK
                        GOK =0
                        Break 2
                      Endif
                    Endif
                  When "CFGAMALP"
                    Case [F:CQU]ASWTYP
                      When  1 : [F:AMA2]ACTION = "CFGAMALP"
                      When  2 : [F:AMA2]ACTION = "CFGAMNUM"
                      When  3 : [F:AMA2]ACTION = "CFGAMDAT"
                      When  4 : [F:AMA2]ACTION = "CFGAMCAS"
                      When  5 : [F:AMA2]ACTION = "CFGAMTXT"
                      When  6 : [F:AMA2]ACTION = "CFGAMBLB"  : # FQ 50451 GA 11/2008
                      When  7 : [F:AMA2]ACTION = "CFGAMCLB"  : # FQ 50451 GA 11/2008
                    Endcase
                    Write [AMA2]
                    If fstat
                      Call FSTA("AMA2") From GLOCK
                      GOK =0
                      Break 2
                    Endif
                Endcase
              When 8 : # Selection
               # Issue 95386 GA 01/2014 [F:CQU]CTLTYP=6 table diverse, le code table se trouve dans [F:CQU]CODFIC
#&                  ([F:AMA1]ACTION="SELTAB" & [F:CQU]OBJET  <> "" ) |
#&                  ([F:AMA1]ACTION="SELADI" & [F:CQU]TCT    <> "") |
               # FQ 72873 GA 08/2011 SELADI pour les Questions avec contrôle de type Table diverse
                If ([F:AMA1]ACTION="SELTCT" & [F:CQU]TCT    <> "") |
&                  ([F:AMA1]ACTION="SELTAB" & ([F:CQU]OBJET  <> "" | [F:CQU]CTLTYP=6)) |
&                  ([F:AMA1]ACTION="SELADI" & [F:CQU]CODFIC <> "") |
&                  ([F:AMA1]ACTION="SELSHB" & [F:CQU]SHACAT <> "")
                   Write [AMA2]
                   If fstat
                     Call FSTA("AMA2") From GLOCK
                     GOK =0
                     Break 2
                   Endif
                 Endif
              When 9 : # Bouton 1
                Write [AMA2]
                If fstat
                  Call FSTA("AMA2") From GLOCK
                  GOK =0
                  Break 2
                Endif
              When 10 : # Bouton 2
                If [F:CQU]ASWTYP = 1 & [F:CQU]SHACAT <> ""
                  [F:AMA2]ACTION = "SAICFGSHA"
                  Write [AMA2]
                  If fstat
                    Call FSTA("AMA2") From GLOCK
                    GOK =0
                    Break 2
                  Endif
                Endif
              When 11 : # Bouton 3
    #            If [F:CQU]QSTTYP = 1 & [F:CQU]QSTPIC <> "" V130
                If [F:CQU]QSTTYP = 1
                  Raz [F:CBB]
                  Read [CBB]CBB0="CQU";[F:CQU]QSTNUM;""
                  If len([F:CBB]BLOB)<>0
                    [F:AMA2]ACTION = "VISUPIS"
                    Write [AMA2]
                    If fstat
                      Call FSTA("AMA2") From GLOCK
                      GOK =0
                      Break 2
                    Endif
                  Endif
                Endif
            Endcase
          Next
          Filter [AMA1]
    #
          Filter [AMP1] Where TYPAFF = 1     &
&                             CODAFF = LREF  &
&                             CODZON = "FLD"
&                       Order By Key CODPAR
          For [AMP1]
            [F:AMP2]       = [F:AMP1]
            [F:AMP2]CODAFF = LMSK
            [F:AMP2]CODZON = W_PRQ+[M:CWIN]QSTNUM(W_I)
            Case [F:AMP1]CODPAR
              When "QSTNUM" :
                [F:AMP2]VALPAR = '"'+[M:CWIN]QSTNUM(W_I)+'"'
                Write [AMP2]
                If fstat
                  Call FSTA("AMP2") From GLOCK
                  GOK =0
                  Break 2
                Endif
              When "SYMBOLE" :
                [F:AMP2]VALPAR = '"'+[M:CWIN]QSTNUM(W_I)+'"'
                Write [AMP2]
                If fstat
                  Call FSTA("AMP2") From GLOCK
                  GOK =0
                  Break 2
                Endif
              When "TCT"    :
                If [F:CQU]TCT <> ""
                  [F:AMP2] VALPAR = '"'+[F:CQU]TCT+'"'
                  Write [AMP2]
                  If fstat
                    Call FSTA("AMP2") From GLOCK
                    GOK =0
                    Break 2
                  Endif
                Endif
              When "SHA"    :
                If [F:CQU]SHACAT <> ""
                  [F:AMP2] VALPAR = '"'+[F:CQU]SHACAT+'"'
                  Write [AMP2]
                  If fstat
                    Call FSTA("AMP2") From GLOCK
                    GOK =0
                    Break 2
                  Endif
                Endif
              When "OBJET"    :
                If [F:CQU]OBJET <> ""
                  [F:AMP2] VALPAR = '"'+[F:CQU]OBJET+'"'
                  Write [AMP2]
                  If fstat
                    Call FSTA("AMP2") From GLOCK
                    GOK =0
                    Break 2
                  Endif
                Endif
              When "FCY"    :
                If [F:CQU]OBJET <> ""
                  [F:AMP2]VALPAR = '"'+[F:CQU]FCYFLD+'"'
                  Write [AMP2]
                  If fstat
                    Call FSTA("AMP2") From GLOCK
                    GOK =0
                    Break 2
                  Endif
                Endif
              When "ADI"    :    # action SELADI # Issue 95386 GA 01/2014 ctrl Table diverse
                If [F:CQU]CTLTYP=6 & [F:CQU]CODFIC <> ""
                  [F:AMP2] VALPAR = '"'+[F:CQU]CODFIC+'"'
                  Write [AMP2]
                  If fstat
                    Call FSTA("AMP2") From GLOCK
                    GOK =0
                    Break 2
                  Endif
                Endif
            Endcase
          Next
          Filter [AMP1]
      Endif    # CCC (19/09/05) Bug 32161
    Next W_I
  Elsif [F:AMZ1]CODZON = "R_FLD"                         # JPJ: gestion rang
    For W_I = 0 To [M:CWIN]NBLIG-1
      [F:AMZ2]       = [F:AMZ1]
      [F:AMZ2]CODMSK = LMSK
      W_K = find(W_PRS+[M:CWIN]QSTNUM(W_I),W_VARLAB)
      If W_K
          [F:AMZ2]CODZON  = W_PRR+[M:CWIN]QSTNUM(W_I)
          [F:AMZ2]VALDEF  = num$(W_I+1)
          [F:AMZ2]NOZONE  = [F:AMZ2]NOZONE+ ([M:CWIN]LINNBR(W_I)-1)     # NOZONE décimal: ligne,col
          [F:AMZ2]NUMLIG  = W_N      :       W_N += 1
          [F:AMZ2]NUMBLOC = [M:CWIN]BLONBR(W_I)+W_HEAFLG
          Write [AMZ2]
          If fstat
            Call FSTA("AMZ2") From GLOCK
            GOK =0
            Break 2
          Endif
      Endif
    Next
  Else
    [F:AMZ2]       = [F:AMZ1]
    [F:AMZ2]CODMSK = LMSK
    [F:AMZ2]NUMLIG = W_N
    W_N += 1
    Write [AMZ2]
    If fstat
      Call FSTA("AMZ2") From GLOCK
      GOK =0
      Break
    Endif
    Filter [AMA1] Where TYPAFF = 1              &
&                       CODAFF = LREF           &
&                       CODZON = [F:AMZ2]CODZON
&                 Order By Key TYPAFF
    For [AMA1]
      [F:AMA2]       = [F:AMA1]
      [F:AMA2]CODAFF = LMSK
      Write [AMA2]
      If fstat
        Call FSTA("AMA2") From GLOCK
        GOK =0
        Break
      Endif
    Next
    Filter [AMA1]
    Filter [AMP1] Where TYPAFF = 1              &
&                       CODAFF = LREF           &
&                       CODZON = [F:AMZ2]CODZON
&                 Order By Key CODPAR
    For [AMP1]
      [F:AMP2]       = [F:AMP1]
      [F:AMP2]CODAFF = LMSK
      Write [AMP2]
      If fstat
        Call FSTA("AMP2") From GLOCK
        GOK =0
        Break
      Endif
    Next
    Filter [AMP1]
  Endif
Next
Filter [AMZ1]
#
# Issue 96434 GA 03/2014 Block Html: Write is done at the end
Write [AMK2]
If fstat
  Call FSTA("AMK2") From GLOCK
  GOK =0
  Goto OK_POS_FIN
Endif
If GOK <> 1
  Goto OK_POS_FIN
Endif

# FQ 77122 GA 10/2011 code déplacé + cas particulier validation différée
Call GEN_MSK(LAPP,LREF,LMSK) From CFGLIBA
#
Call GEN_FEN(LAPP,LREF,LMSK) From CFGLIBA
[S]adxmbm = [S]adxmbm
############################################################
$OK_POS_FIN
If GOK = 1
  PARAM(11) = "0"
Else
  PARAM(11) = "1"
Endif
FIN = 1
Return
############################################################
$SETBOUT_POS
# FQ 62993 GA 03/2010
If clalev([M:CFG0])<=0 | [F:CSC]SCENUM<>[M:CFG0]SCENUM
   ETABOU(GSPE2) = 0 # Supprimer le Bouton "Raz" si creation/duplication
Endif
Return
############################################################
$BOUTON_POS
Case BOUT
  When "a" :
    Sorta [M:CWIN]NBLIG [M:CWIN]NBLIG Order By [M:CWIN]BLONBR(indice), [M:CWIN]LINNBR(indice)
    Affzo [M:CWIN]
  When "b" : # Bouton "Raz"   # FQ 62993 GA 03/2010 ré-ordonner les Questions
    Gosub RAZ_POS
    Affzo [M:CWIN]
Endcase
Return
############################################################
$END_POS
PARAM(11) = "1"
Return
############################################################
$RAZ_POS         # FQ 62993 GA 03/2010 NOUVEAU: ré-ordonner les champs selon scénario
If clalev([M:CFG0])<=0 Return Endif
Local Integer WBLONBR,WLINNBR
Raz [M:CWIN]NBLIG
Raz [M:CWIN]QSTNUM
Raz [M:CWIN]QSTSHO
Raz [M:CWIN]BLONBR
Raz [M:CWIN]LINNBR
Raz W_M,W_K,W_L
For W_I = 0 To dim([M:CFG0]QSTNUM)-1
  If [M:CFG0]QSTNUM(W_I)="" Break Endif

  W_VAR = W_PRS+[M:CFG0]QSTNUM(W_I)
  W_FLD = [M:CFG0]QSTNUM(W_I)
  W_J = find(W_VAR,W_VARLAB)
  If W_J <> 0
    Read [CQU]CQU0=W_FLD
    If fstat = 0 & [F:CQU]QSTTYP = 1
        [M:CWIN]NBLIG += 1
        [M:CWIN]QSTNUM([M:CWIN]NBLIG-1) = W_FLD
        [M:CWIN]QSTSHO([M:CWIN]NBLIG-1) = evalue(W_PRX+mid$(W_VARLAB(W_J-1),3,GLONCQU))
        # -------------------------------------------------------------
        # Initialisation par défaut (nouveaux champs)
        # -------------------------------------------------------------
        Raz WBLONBR,WLINNBR
        If dim([M:CFG0]TABSCE(W_I))>0
&            & [M:CFG0]TABSCE(W_I)<>""
&            & [M:CFG0]TABSCE(W_I)<>[M:CFG0]SCENUM
          Call NEWPOS_INVISIBLE(WBLONBR,WLINNBR)
        Else
          Call NEWPOS_VISIBLE(WBLONBR,WLINNBR)
        Endif
        [M:CWIN]BLONBR([M:CWIN]NBLIG-1)=WBLONBR
        [M:CWIN]LINNBR([M:CWIN]NBLIG-1)=WLINNBR
    Endif
  Endif
Next W_I
# Tri par bloc et ligne
Sorta [M:CWIN]NBLIG [M:CWIN]NBLIG Order By [M:CWIN]BLONBR(indice), [M:CWIN]LINNBR(indice)
Affzo [M:CWIN]
Return
############################################################
# Initialisation d'execution de l'automate par un programme specifique
# Un fichier trace doit etre ouvert
# Passage des parametres via le masque CFGFUN
# Doivent etre charges les champs suivant :
# [M:CFGF]FCY     : Site
# [M:CFGF]SCENUM  : Scenario
# [M:CFGF]BPRNUM  : Tiers (facultatif)
# [M:CFGF]BPRREF  : Reference tiers (facultatif)
# [M:CFGF]IPTADT  : Date imputation
# [M:CFGF]RETCOD  : Code retour
# [M:CFGF]BOMALTREF : Alternative de nomenclature de référence
# [M:CFGF]BOMALT    : Alternative de nomenclature
# [M:CFGF]ROUALTREF : Alternative de gamme de référence
# [M:CFGF]ROUALT    : Alternative de gamme
############################################################
#
$CFGINIBAT
# Nettoyage d'une exécution préalable   # JPJ E20220 ->
Raz GERR, GMESSAGE
Gosub SUP_GLOBALES From WUVAR    # purge gloabales cfg <-
#
Local Integer FIN, WRET     # JPJ E21934
Local Char    PARAM(20)(1..07)
Local Integer Z_I, Z_J
#
Call LOCK_CFGSYM(WRET, GMESSAGE) From SUBCFG        # JPJ E21934 - Protection par symbole logique
If WRET
    GERR=1
    [M:CFGF]RETCOD = 6    # Symbole logique vérouillé par un autre utilisateur
    Return
Endif
#
If clalev([F:CQU]) = 0  : Local File CFGQST     [CQU]  : Endif     # JPJ E19992
If clalev([F:FCY]) = 0  : Local File FACILITY   [FCY]  : Endif
If clalev([F:BPR]) = 0  : Local File BPARTNER   [BPR]  : Endif
If clalev([F:BPC]) = 0  : Local File BPCUSTOMER [BPC]  : Endif
If clalev([F:CSC]) = 0  : Local File CFGSCE     [CSC]  : Endif
#CHECK IGNORE_BEGIN
If GVERSION>="2.0.0"    # Issue 104077 GA 11/2014 Akira before GVERSION>="1.8.0"
   If clalev([F:CSQ]) = 0 : Local File CFGSCEQST  [CSQ] : Endif    # FQ 64278 GA 06/2010
Endif
#CHECK IGNORE_END
If clalev([F:CSL]) = 0  : Local File CFGSCELIN  [CSL]  : Endif
If clalev([F:TBO]) = 0  : Local File TABBOMALT  [TBO]  : Endif
#
If clalev([M:CFA0]) = 0 : Local Mask CFGAUT0    [CFA0] :Endif
mkstat = 0
Call CFGCTRFCY([M:CFGF]FCY) From CFGLIB
If mkstat
  [M:CFGF]RETCOD = 1
  Goto CFGINIBAT_FIN
Endif
Call CFGCTRSCE([M:CFGF]SCENUM,[M:CFGF]FCY) From CFGLIB
If mkstat
  [M:CFGF]RETCOD = 2
  Goto CFGINIBAT_FIN
Endif
If [M:CFGF]BPRNUM <> ""
  Read [BPR]BPR0=[M:CFGF]BPRNUM
  If fstat = 0
    If [F:BPR]BPCFLG = 2
      Read [BPC]BPC0=[BPR]BPRNUM    # S_BPRNUM JPJ
      If fstat
        Raz [F:BPC]
      Endif
    Else
      Raz [F:BPC]
    Endif
  Else
    [M:CFGF]RETCOD = 3
    Goto CFGINIBAT_FIN
  Endif
Else
  Raz [F:BPR]
  Raz [F:BPC]
Endif
If [M:CFGF]IPTDAT = [0/0/0]
  [M:CFGF]IPTDAT = date$
Endif
# Effacement du bloc questions reponses
For Z_I = 0 To dim([M:CFGF]QSTNUM)-1
  [M:CFGF]QSTNUM(Z_I) = ""
  [M:CFGF]ASWTYP(Z_I) = 0
  [M:CFGF]ASWALP(Z_I) = ""
  [M:CFGF]ASWNUM(Z_I) = 0
  [M:CFGF]ASWDAT(Z_I) = [0/0/0]
Next Z_I
[M:CFGF]QSTNBR = 0
# Creation du bloc questions reponses

#CHECK IGNORE_BEGIN
If GVERSION>="2.0.0"    # Issue 104077 GA 11/2014 Akira before GVERSION>="1.8.0"
  # FQ 64278 GA 06/2010 champs déplacés dans [F:CSQ]
  Filter [F:CSQ] Where SCENUM=[F:CSC]SCENUM
  For [F:CSQ]
      If Z_I < dim([M:CFGF]QSTNUM)-1
        [M:CFGF]QSTNUM(Z_I) = [F:CSQ]QSTNUM
        [M:CFGF]BLONBR(Z_I) = [F:CSQ]BLONBR
        [M:CFGF]LINNBR(Z_I) = [F:CSQ]LINNBR
        [M:CFGF]ASWTYP(Z_I) = [F:CSQ]ASWTYP
        [M:CFGF]QSTNBR   += 1
      Else     # pas assez de place
        [M:CFGF]RETCOD = 4
        Break
      Endif
    Z_I+=1
  Next
Endif
#CHECK IGNORE_END

If [M:CFGF]QSTNBR=0               # on a rien trouvé dans [F:CSQ]
####### Début - Code OBSOLETE en V8 ###############
    For Z_I = 0 To [F:CSC]QSTNBR-1
      If Z_I < dim([M:CFGF]QSTNUM)-1
        [M:CFGF]QSTNUM(Z_I) = [F:CSC]QSTNUM(Z_I)       # JPJ E19992 >
        If dim([M:CFGF]BLONBR)>0 & dim([M:CFGF]LINNBR)>0
           [M:CFGF]BLONBR(Z_I) = [F:CSC]BLONBR(Z_I)       # FQ 52854 GA 02/2009
           [M:CFGF]LINNBR(Z_I) = [F:CSC]LINNBR(Z_I)       # FQ 52854 GA 02/2009
        Endif
        Read [CQU]CQU0=[M:CFGF]QSTNUM(Z_I)               #  Lecture symbole pour trouver le type
        If !fstat
            [M:CFGF]ASWTYP(Z_I) = [F:CQU]ASWTYP    # Type
            [M:CFGF]QSTNBR   += 1
        Else    # symbole non trouvé
            [M:CFGF]RETCOD = 5
            [M:CFGF]QSTNBR   += 1     # JPJ E21805
            Break                     # JPJ E21805
        Endif
      Else     # pas assez de place
        [M:CFGF]RETCOD = 4
        Break                         # JPJ E21805 et JPJ E19992 <
      Endif
    Next Z_I
####### Fin - Code OBSOLETE ###############
Endif
#
$CFGINIBAT_FIN
Return
############################################################
# Traitement d'une configuration via l'automate par un programme specifique
#
# Passage des parametres via le masque CFGFUN
# Doivent etre charges les champs suivant :
#
# ASWALP(n) : reponses de type alphanumerique
# ASWNUM(n) : reponses de type numerique
# ASWDAT(n) : reponses de type date
# Le type est donne par ASWTYP(n) 1 = alpha / 2 = numerique / 3 = date
#
# Resultats de configuration dans la trace
#
$CFGEXEBAT
Local Integer FIN
Local Char    PARAM(20)(1..11)   # Issue 83644 GA 07/2012 + 4 parameters suite 82989
Local Integer Z_I
#
PARAM(01) = [M:CFGF]SCENUM
PARAM(02) = [M:CFGF]FCY
PARAM(03) = [M:CFGF]BPRNUM
PARAM(04) = [M:CFGF]BPRREF
PARAM(05) = [M:CFGF]IPTDAT
PARAM(06) = "0"
PARAM(07) = "0"
PARAM(08) = num$([M:CFGF]BOMALTREF)    # Issue 83644 GA 07/2012
PARAM(09) = num$([M:CFGF]BOMALT)       # Issue 83644 GA 07/2012
PARAM(10) = num$([M:CFGF]ROUALTREF)    # Issue 83644 GA 07/2012
PARAM(11) = num$([M:CFGF]ROUALT)       # Issue 83644 GA 07/2012

# JPJ E21260 - Ajout PE comme celui existant en TP
Global Char GPOINT(30)
GPOINT = "CFG_INIT"
GPE    = 0
Gosub  ENTREE From EXEFNC
If GPE = 0
 Gosub INIT_CFGSCE  From CFGLIBB
Endif
If GERR : Return : Endif

# JPJ E21260 - Ajout PE
GPOINT = "CFG_OUVRE"
GPE    = 0
Gosub  ENTREE From EXEFNC
If GPE = 0
    Gosub OUVRE_CFGSCE From CFGLIBB
Endif

# Mise en mode automate
S_AUTCFG = 1
# Ouverture masques de validation
If clalev([M:CFV0]) = 0 : Local Mask CFGVAL0 [CFV0] : Endif
If clalev([M:CFV1]) = 0 : Local Mask CFGVAL1 [CFV1] : Endif
If clalev([M:CFV2]) = 0 : Local Mask CFGVAL2 [CFV2] : Endif
If clalev([M:CFV3]) = 0 : Local Mask CFGVAL3 [CFV3] : Endif
If clalev([M:CFV4]) = 0 : Local Mask CFGVAL4 [CFV4] : Endif
If clalev([M:CFV9]) = 0 : Local Mask CFGVAL9 [CFV9] : Endif
# Effacement ecrans de validation
Raz [M:CFV0]
Raz [M:CFV1]
Raz [M:CFV2]
Raz [M:CFV3]
Raz [M:CFV4]
Raz [M:CFV9]
# Creation des questions et affectation des reponses
For Z_I = 0 To [M:CFGF]QSTNBR-1
  W_VAR = W_PRS+[M:CFGF]QSTNUM(Z_I) # JPJ E21757 à la place de: [F:CSC]QSTNUM(Z_I)
                                    # Ceci permet d'ajouter des questions non incluses dans le scénario
                                    # ex. typique: les questions d'un modèle pour une forme
  Gosub CRE_SYMBOLE From WUVAR
  Gosub SET_DEFAUT  From WUVAR
  Case [M:CFGF]ASWTYP(Z_I)
    When 1 : Assign W_PRS+[M:CFGF]QSTNUM(Z_I) With [M:CFGF]ASWALP(Z_I)
    When 2 : Assign W_PRS+[M:CFGF]QSTNUM(Z_I) With [M:CFGF]ASWNUM(Z_I)
    When 3 : Assign W_PRS+[M:CFGF]QSTNUM(Z_I) With [M:CFGF]ASWDAT(Z_I)
    When 4 : Assign "S_"+[M:CFGF]QSTNUM(Z_I) With [M:CFGF]ASWNUM(Z_I)    # Bool    JPJ E19992
    When 5 : Assign "S_"+[M:CFGF]QSTNUM(Z_I) With [M:CFGF]ASWALP(Z_I)    # Texte
  Endcase
Next Z_I
#
[M:CFGF]CFGVCRNUM = ""
[M:CFGF]ITMREF    = ""
#

# Issue 87724 GA 08/2014 TRT_SCENARIO necessary with automate mode
Gosub TRT_SCENARIO From CFGLIBB
If (GOK<>1 | S_ABORT | W_MSG <> "")
   Return
Else
   Gosub DEBUT_CFGVAL From CFGLIBC
Endif
If S_AUTCFG > 1
  GMESSAGE = S_AUTERR-mess(126,188,1)
  Call ECR_TRACE(S_AUTERR-mess(126,188,1),1) From GESECRAN
Else
  Case GERR
    When 0 :            # Conf. terminée avec succés / Données générées avec le n° de pièce
      Call ECR_TRACE(mess(52,188,1)-S_CPTCFG-"("+S_CURITM+")",0) From GESECRAN
      Gosub GENERATION_CFGVAL From CFGLIBC                 #  Nota: GENERATION_CFGVAL renvoit GERR=2 si OK
      [M:CFGF]CFGVCRNUM = S_CPTCFG
      [M:CFGF]ITMREF    = [M:CFV1]ITMREF(0)
    When 1 :
      Call ECR_TRACE(GMESSAGE-"\"+mess(53,188,1),1) From GESECRAN    # 53: Configuration abandonnée
      Gosub DEL_CONFIG From CFGLIBC
    When 2 :
      Call ECR_TRACE(GMESSAGE,0)                From GESECRAN
      S_UPDMOD = 2      # Issue 91682 GA 08/2013 Maj en mode automate ou import batch
      Gosub GENERATION_CFGVAL From CFGLIBC                 #  Nota: GENERATION_CFGVAL renvoit GERR=2 si OK
      [M:CFGF]CFGVCRNUM = S_CPTCFG
      [M:CFGF]ITMREF    = [M:CFV1]ITMREF(0)
  Endcase
#  GERR     = 0      # JPJ E20220 Pour pouvoir récuperer une erreur par le prgrm appelant
#  GMESSAGE = ""         # JPJ E20220
#
Endif
Return
############################################################
# Fin d'execution batch
$CFGENDBAT
Gosub SUP_GLOBALES From WUVAR
Call UNLOCK_CFGSYM() From SUBCFG        # JPJ E21934 - Protection par symbole logique
Return
############################################################
Subprog CFGWUS(LCOD,LVAL,LTRA)
Value    Integer    LCOD
Value    Char       LVAL
Value    Integer    LTRA
#
If clalev([F:CLN]) = 0 : Local File CFGLNK [CLN] : Endif
#
Gosub CFG_SYMBOLES From CFGLIB
#
Case LCOD
  When  1 : Call CFGWUSQST(LVAL,LTRA)
  When  2 : Call CFGWUSVAR(LVAL,LTRA)
  When  3 : Call CFGWUSSCE(LVAL,LTRA)
  When  4 : Call CFGWUSSEL(LVAL,LTRA)
  When  5 : Call CFGWUSOPV(LVAL,LTRA)
  When  7 : Call CFGWUSPRO(LVAL,LTRA)
  When  9 : Call CFGWUSSHA(LVAL,LTRA)
  When 30 : Call CFGWUSFOR(LVAL,LTRA)
Endcase
If GOK=0 # FQ 60365 GA 11/2009 Afficher une trace d'erreur
   Call ECR_TRACE("CFGWUS("-num$(LCOD)-","-LVAL-"):"-GMESSAGE,1) From GESECRAN
   GOK=1 : GMESSAGE="" # Raz de l'erreur ????
Endif
End
############################################################
# Generation cas d'emploi d'une question
Subprog CFGWUSQST(LVAL,LTRA)
Value    Char    LVAL
Value    Integer LTRA
#
Local    Char    WFOR(GLONAVA) # Issue 82989 suite GA 11/2012
Local    Char    WQSTSHO(GLONDES) # FQ 53410
#
If clalev([F:CQU0]) = 0 : Local File CFGQST [CQU0] : Endif
#
If LTRA <> 0
  Trbegin [CLN]
  GOK = 1
Endif
#
Call PURCLN(1,LVAL,0)
#
If GOK = 1
  If LVAL = "*"
    Filter [CQU0] Where QSTTYP     = 1
&                 Order By Key CQU0
  Else
    Filter [CQU0] Where QSTNUM     = LVAL &
&                       QSTTYP     = 1
&                 Order By Key CQU0
  Endif
  For [CQU0]
    If [F:CQU0]EVADEFVAL<> ""
       # FQ 60137 pas de LECTEXTRA ici - FQ 53410 lecture texte traduit [F:CQU0]QSTSHO
       Call QSTSHO([F:CQU0]QSTNUM,GLANGUE,WQSTSHO)
       # Issue 63311 GH 09/03/2018 - Detected errors in configurator symbols was always referring to the last one
       GMESSAGE=""
       Call CFGWUSEXP(1,[F:CQU0]QSTNUM,WQSTSHO,[F:CQU0]EVADEFVAL,"EVADEFVAL")
       If GMESSAGE<>"" : GMESSAGE-=mess(56,100,1)-[F:CQU0]QSTNUM : Endif
    Endif
    If [F:CQU0]FILFIC <> ""
       # FQ 60137 pas de LECTEXTRA ici - FQ 53410 lecture texte traduit [F:CQU0]QSTSHO
       Call QSTSHO([F:CQU0]QSTNUM,GLANGUE,WQSTSHO)
       Call ECRCLN(1,[F:CQU0]QSTNUM,WQSTSHO,"",30,[F:CQU0]FILFIC,"FILFIC")
    Endif
  Next
  Filter [CQU0]
Endif
#
If LTRA <> 0
  Case GOK
    When 1 :
      Commit
    When Default :
      # FQ 60365 GA 11/2009 Compléter le message d'erreur
      # If GMESSAGE<>"" GMESSAGE-=mess(56,100,1)-[F:CQU0]QSTNUM Endif
      Rollback
  Endcase
Endif
End
############################################################
# Generation cas d'emploi d'une question
Subprog CFGWUSVAR(LVAL,LTRA)
Value    Char    LVAL
Value    Integer LTRA
#
Local    Char    WFOR(GLONAVA) # Issue 82989 suite GA 11/2012
Local    Char    WQSTSHO(GLONDES) # FQ 53410
#
If clalev([F:CQU0]) = 0 : Local File CFGQST [CQU0] : Endif
#
If LTRA <> 0
  Trbegin [CLN]
  GOK = 1
Endif
#
Call PURCLN(2,LVAL,0)
#
If GOK = 1
  If LVAL = "*"
    Filter [CQU0] Where QSTTYP     = 2
&                 Order By Key CQU0
  Else
    Filter [CQU0] Where QSTNUM     = LVAL &
&                       QSTTYP     = 2
&                 Order By Key CQU0
  Endif
  For [CQU0]
    If [F:CQU0]EVADEFVAL<> ""
       # FQ 60137 pas de LECTEXTRA ici - FQ 53410 lecture texte traduit [F:CQU0]QSTSHO
       Call QSTSHO([F:CQU0]QSTNUM,GLANGUE,WQSTSHO)
       # Issue 63311 GH 09/03/2018 - Detected errors in configurator symbols was always referring to the last one
       GMESSAGE=""
       Call CFGWUSEXP(2,[F:CQU0]QSTNUM,WQSTSHO,[F:CQU0]EVADEFVAL,"EVADEFVAL")
       If GMESSAGE<>"" : GMESSAGE-=mess(56,100,1)-[F:CQU0]QSTNUM : Endif
    Endif
  Next
  Filter [CQU0]
Endif
#
If LTRA <> 0
  Case GOK
    When 1 :
      Commit
    When Default :
      # FQ 60365 GA 11/2009 Compléter le message d'erreur
      # If GMESSAGE<>"" GMESSAGE-=mess(56,100,1)-[F:CQU0]QSTNUM Endif
      Rollback
  Endcase
Endif
End
############################################################
# Generation cas d'emploi d'un scenario
Subprog CFGWUSSCE(LVAL,LTRA)
Value    Char    LVAL
Value    Integer LTRA
#
Local    Char    WFOR(GLONAVA) # Issue 82989 suite GA 11/2012
#
If clalev([F:CSC0]) = 0 : Local File CFGSCE    [CSC0] : Endif
If clalev([F:CSL0]) = 0 : Local File CFGSCELIN [CSL0] : Endif
#CHECK IGNORE_BEGIN
If GVERSION>="2.0.0"    # Issue 104077 GA 11/2014 Akira before GVERSION>="1.8.0"
   If clalev([F:CSQ]) = 0 : Local File CFGSCEQST  [CSQ] : Endif    # FQ 64278 GA 06/2010
Endif
#CHECK IGNORE_END
#
If LTRA <> 0
  Trbegin [CLN]
  GOK = 1
Endif
#
Call PURCLN(3,LVAL,0)
#
If GOK = 1
  If LVAL = "*"
    Filter [CSL0]
&                 Order By Key CSL0
  Else
    Filter [CSL0] Where SCENUM = LVAL
&                 Order By Key CSL0
  Endif
  For [CSL0]
    If [F:CSC0]SCENUM <> [F:CSL0]SCENUM
      Read [CSC0]CSC0=[F:CSL0]SCENUM
      If fstat
        Raz [F:CSC0]
      Endif
    Endif
    If find([F:CSL0]SYMTYP,1,2,4,5,7,9)
      Call ECRCLN(3,[F:CSL0]SCENUM,"","[F:CSC0]",[F:CSL0]SYMTYP,[F:CSL0]SYMNUM,"SYMNUM")
      If [F:CSL0]SYMTYP = 9
        Call ECRCLN(3,[F:CSL0]SCENUM,"","[F:CSC0]",1,[F:CSL0]SYMNUM,"SYMNUM")
      Endif
    Endif
    If find([F:CSL0]SYMTYP,24,25,26,27)
      Call ECRCLN(3,[F:CSL0]SCENUM,"","[F:CSC0]",2,[F:CSL0]SYMNUM,"SYMNUM")
    Endif
    If GOK = 1 & [F:CSL0]CNDFOR <> ""
      Call CFGWUSEXP(3,[F:CSL0]SCENUM,"",[F:CSL0]CNDFOR,"CNDFOR")
    Endif
    If GOK = 1 & [F:CSL0]FORFOR <> ""
      Call CFGWUSEXP(3,[F:CSL0]SCENUM,"",[F:CSL0]FORFOR,"FORFOR")
    Endif
    If GOK = 1 & [F:CSL0]ABQNUM <> ""
      Call ECRCLN(3,[F:CSL0]SCENUM,"","[F:CSL0]",10,[F:CSL0]ABQNUM,"ABQNUM")
    Endif
    If GOK = 1 & [F:CSL0]ABQVAL <> ""
      WFOR = W_PRS+[F:CSL0]ABQVAL
      Call CFGWUSEXP(3,[F:CSL0]SCENUM,"",WFOR,"ABQVAL")
    Endif
    If GOK = 1 & [F:CSL0]ABQVALY <> ""
      WFOR = W_PRS+[F:CSL0]ABQVALY
      Call CFGWUSEXP(3,[F:CSL0]SCENUM,"",WFOR,"ABQVALY")
    Endif
  # FQ 54722 GA 04/2009
    If GOK = 1 & [F:CSL0]CNDFORLIN <> ""
      Call CFGWUSEXP(3,[F:CSL0]SCENUM,"",[F:CSL0]CNDFORLIN,"CNDFORLIN")
    Endif
    If GOK = 1 & [F:CSL0]SUBSCENUM <> ""
      Call ECRCLN(3,[F:CSL0]SCENUM,"","[F:CSC0]",3,[F:CSL0]SUBSCENUM,"SUBSCENUM")
    Endif
    If GOK <> 1
      Break
    Endif
  Next
  Filter [CSL0]
Endif
#
If LTRA <> 0
  Case GOK
    When 1 :
      Commit
    When Default :
      # FQ 60365 GA 11/2009 Compléter le message d'erreur
      If GMESSAGE<>"" GMESSAGE-=mess(56,100,1)-[F:CSL0]SYMNUM-mess(1,188,1)-[F:CSL0]SCENUM Endif
      Rollback
  Endcase
Endif
End
############################################################
# Generation cas d'emploi d'une selection
Subprog CFGWUSSEL(LVAL,LTRA)
Value    Char    LVAL
Value    Integer LTRA
#
Local    Char    WFOR(GLONAVA) # Issue 82989 suite GA 11/2012
Local    Integer WI
#
If clalev([F:CSE0]) = 0 : Local File CFGSEL [CSE0] : Endif
#
If LTRA <> 0
  Trbegin [CLN]
  GOK = 1
Endif
#
Call PURCLN(4,LVAL,0)
#
If GOK = 1
  If LVAL = "*"
    Filter [CSE0]
&                 Order By Key CSE0
  Else
    Filter [CSE0] Where SELNUM = LVAL
&                 Order By Key CSE0
  Endif
  For [CSE0]
    If GOK = 1 & [F:CSE0]MACNUM <> ""
      Call ECRCLN(4,[F:CSE0]SELNUM,"","[F:CSE0]",7,[F:CSE0]MACNUM,"MACNUM")
    Endif
    If GOK = 1 & [F:CSE0]PRIFOR <> ""
      Call CFGWUSEXP(4,[F:CSE0]SELNUM,"",[F:CSE0]PRIFOR,"PRIFOR")
    Endif
    If GOK = 1 & [F:CSE0]QTYFOR <> ""
      Call CFGWUSEXP(4,[F:CSE0]SELNUM,"",[F:CSE0]QTYFOR,"QTYFOR")
    Endif
    If GOK = 1 & [F:CSE0]SELFIL <> ""
      Call CFGWUSEXP(4,[F:CSE0]SELNUM,"",[F:CSE0]SELFIL,"SELFIL")
    Endif
    If GOK = 1 & [F:CSE0]SELFORNBR > 0
      For WI = 0 To [F:CSE0]SELFORNBR -1
        If [F:CSE0]SELFOR(WI) <> ""
          Call CFGWUSEXP(4,[F:CSE0]SELNUM,"",[F:CSE0]SELFOR(WI),"SELFOR")
        Endif
      Next WI
    Endif
    If GOK = 1 & [F:CSE0]RULNBR > 0
      For WI = 0 To [F:CSE0]RULNBR -1
        If [F:CSE0]RULCND(WI) <> ""
          Call CFGWUSEXP(4,[F:CSE0]SELNUM,"",[F:CSE0]RULCND(WI),"RULCND")
        Endif
      Next WI
    Endif
    If GOK <> 1
      Break
    Endif
  Next
  Filter [CSE0]
Endif
#
If LTRA <> 0
  Case GOK
    When 1 :
      Commit
    When Default :
      # FQ 60365 GA 11/2009 Compléter le message d'erreur
      If GMESSAGE<>"" GMESSAGE-=mess(110,188,1)-[F:CSE0]SELNUM Endif
      Rollback
  Endcase
Endif
End
############################################################
# Generation cas d'emploi d'une option variante
Subprog CFGWUSOPV(LVAL,LTRA)
Value    Char    LVAL
Value    Integer LTRA
#
Local    Char    WFOR(GLONAVA) # Issue 82989 suite GA 11/2012
Local    Integer WI
#
If clalev([F:CSE0]) = 0 : Local File CFGSEL    [CSE0] : Endif
If clalev([F:COV0]) = 0 : Local File CFGOPTVAR [COV0] : Endif
#
If LTRA <> 0
  Trbegin [CLN]
  GOK = 1
Endif
#
Call PURCLN(5,LVAL,0)
#
If GOK = 1
  If LVAL = "*"
    Filter [CSE0]
&                 Order By Key CSE0
  Else
    Filter [CSE0] Where SELNUM = LVAL
&                 Order By Key CSE0
  Endif
  For [CSE0]
    If GOK = 1 & [F:CSE0]MACNUM <> ""
      Call ECRCLN(5,[F:CSE0]SELNUM,"","[F:CSE0]",7,[F:CSE0]MACNUM,"MACNUM")
    Endif
    If GOK = 1 & [F:CSE0]PRIFOR <> ""
      Call CFGWUSEXP(5,[F:CSE0]SELNUM,"",[F:CSE0]PRIFOR,"PRIFOR")
    Endif
    If GOK = 1 & [F:CSE0]QTYFOR <> ""
      Call CFGWUSEXP(5,[F:CSE0]SELNUM,"",[F:CSE0]QTYFOR,"QTYFOR")
    Endif
    If GOK = 1 & [F:CSE0]SELFIL <> ""
      Call CFGWUSEXP(5,[F:CSE0]SELNUM,"",[F:CSE0]SELFIL,"SELFIL")
    Endif
    If GOK = 1 & [F:CSE0]SELFORNBR > 0
      For WI = 0 To [F:CSE0]SELFORNBR -1
        If [F:CSE0]SELFOR(WI) <> ""
          Call CFGWUSEXP(5,[F:CSE0]SELNUM,"",[F:CSE0]SELFOR(WI),"SELFOR")
        Endif
      Next WI
    Endif
    If GOK = 1 & [F:CSE0]RULNBR > 0
      For WI = 0 To [F:CSE0]RULNBR -1
        If [F:CSE0]RULCND(WI) <> ""
          Call CFGWUSEXP(5,[F:CSE0]SELNUM,"",[F:CSE0]RULCND(WI),"RULCND")
        Endif
      Next WI
    Endif
    If GOK = 1
      Filter [COV0] Where SELNUM = [F:CSE0]SELNUM
&                   Order By Key COV0
      For [COV0]
        If [F:COV0]ITMREFFOR <> ""
          Call CFGWUSEXP(5,[F:CSE0]SELNUM,"",[F:COV0]ITMREFFOR,"ITMREFFOR")
        Endif
        If [F:COV0]ITMREFCAL <> ""
          Call CFGWUSEXP(5,[F:CSE0]SELNUM,"",[F:COV0]ITMREFCAL,"ITMREFCAL")
        Endif
        If GOK <> 1
          Break
        Endif
      Next
      Filter [COV0]
    Endif
    If GOK <> 1
      Break
    Endif
  Next
  Filter [CSE0]
Endif
#
If LTRA <> 0
  Case GOK
    When 1 :
      Commit
    When Default :
      # FQ 60365 GA 11/2009 Compléter le message d'erreur
      If GMESSAGE<>"" GMESSAGE-=mess(110,188,1)-[F:CSE0]SELNUM Endif
      Rollback
  Endcase
Endif
End
############################################################
# Generation cas d'emploi d'une procedure
Subprog CFGWUSPRO(LVAL,LTRA)
Value    Char    LVAL
Value    Integer LTRA
#
Local    Char    WFOR(GLONAVA) # Issue 82989 suite GA 11/2012
#
If clalev([F:CFM0]) = 0 : Local File CFGMAC [CFM0] : Endif
#
If LTRA <> 0
  Trbegin [CLN]
  GOK = 1
Endif
#
Call PURCLN(7,LVAL,0)
#
If GOK = 1
  If LVAL = "*"
    Filter [CFM0]
&                 Order By Key CFM0
  Else
    Filter [CFM0] Where MACNUM = LVAL
&                 Order By Key CFM0
  Endif
  For [CFM0]
    If find([F:CFM0]SYMTYP,1,2,4,5,7,9)
      Call ECRCLN(7,[F:CFM0]MACNUM,"","[F:CFM0]",[F:CFM0]SYMTYP,[F:CFM0]SYMNUM,"SYMNUM")
      If [F:CFM0]SYMTYP = 9
      # GA 09/2007 pas de SCENUM dans la table CFGMAC, le source V5 est ok
      # Call ECRCLN(7,[F:CFM0]SCENUM,"","[F:CFM0]",1,[F:CFM0]SYMNUM,"SYMNUM")
        Call ECRCLN(7,[F:CFM0]MACNUM,"","[F:CFM0]",1,[F:CFM0]SYMNUM,"SYMNUM")
      Endif
    Endif
    If find([F:CFM0]SYMTYP,24,25,26,27)
      Call ECRCLN(7,[F:CFM0]MACNUM,"","[F:CFM0]",2,[F:CFM0]SYMNUM,"SYMNUM")
    Endif
    If GOK = 1 & [F:CFM0]CNDFOR <> ""
      Call CFGWUSEXP(7,[F:CFM0]MACNUM,"",[F:CFM0]CNDFOR,"CNDFOR")
    Endif
    If GOK = 1 & [F:CFM0]FORFOR <> ""
      Call CFGWUSEXP(7,[F:CFM0]MACNUM,"",[F:CFM0]FORFOR,"FORFOR")
    Endif
    If GOK = 1 & [F:CFM0]ABQNUM <> ""
      Call ECRCLN(7,[F:CFM0]MACNUM,"","[F:CFM0]",10,[F:CFM0]ABQNUM,"ABQNUM")
    Endif
    If GOK = 1 & [F:CFM0]ABQVAL <> ""
      WFOR = W_PRS+[F:CFM0]ABQVAL
      Call CFGWUSEXP(7,[F:CFM0]MACNUM,"",WFOR,"ABQVAL")
    Endif
    If GOK = 1 & [F:CFM0]ABQVALY <> ""
      WFOR = W_PRS+[F:CFM0]ABQVALY
      Call CFGWUSEXP(7,[F:CFM0]MACNUM,"",WFOR,"ABQVALY")
    Endif
    If GOK <> 1
      Break
    Endif
  Next
  Filter [CFM0]
Endif
#
If LTRA <> 0
  Case GOK
    When 1 :
      Commit
    When Default :
      # FQ 60365 GA 11/2009 Compléter le message d'erreur
      If GMESSAGE<>"" GMESSAGE-=mess(79,188,1)-[F:CFM0]MACNUM Endif
      Rollback
  Endcase
Endif
End
############################################################
# Generation cas d'emploi des formes et modeles
Subprog CFGWUSSHA(LVAL,LTRA)
Value    Char    LVAL
Value    Integer LTRA
#
Local    Char    WFOR(GLONAVA) # Issue 82989 suite GA 11/2012
Local    Char    WCAT(10)
Local    Integer WI
#
If clalev([F:CSH0]) = 0 : Local File CFGSHA [CSH0] : Endif
#
If LTRA <> 0
  Trbegin [CLN]
  GOK = 1
Endif
#
Call PURCLN(9,LVAL,0)
#
If GOK = 1
  If LVAL = "*"
    Filter [CSH0]
&                 Order By Key CSH0
  Else
    Filter [CSH0] Where SHACAT = LVAL
&                 Order By Key CSH0
  Endif
  For [CSH0]
    WCAT = [F:CSH0]SHACAT+"-"+[F:CSH0]SHANUM
    Call ECRCLN(9,[F:CSH0]SHACAT,"","[F:CSH0]",9,WCAT,"SHANUM")
    WFOR = W_PRS+[F:CSH0]SHACAT
    Call CFGWUSEXP(9,[F:CSH0]SHACAT,"",WFOR,"SHACAT")
    If [F:CSH0]SYMNBR > 0
      For WI = 0 To [F:CSH0]SYMNBR -1
        WFOR = W_PRS+[F:CSH0]SYMNUM(WI)
        Call CFGWUSEXP(9,WCAT,"SHANUMAXX",WFOR,"SYMNUM")
        If [F:CSH0]SYMCND(WI) <> ""
          Call CFGWUSEXP(9,WCAT,"SHANUMAXX",[F:CSH0]SYMCND(WI),"SYMCND")
        Endif
      Next WI
    Endif
    If GOK = 1 & [F:CSH0]VARNBR > 0
      For WI = 0 To [F:CSH0]VARNBR -1
        WFOR = W_PRS+[F:CSH0]VARNUM(WI)
        Call CFGWUSEXP(9,WCAT,"SHANUMAXX",WFOR,"VARNUM")
        If [F:CSH0]VARFOR(WI) <> ""
          Call CFGWUSEXP(9,WCAT,"SHANUMAXX",[F:CSH0]VARFOR(WI),"VARFOR")
        Endif
      Next WI
    Endif
    If GOK <> 1
      Break
    Endif
  Next
  Filter [CSH0]
Endif
#
If LTRA <> 0
  Case GOK
    When 1 :
      Commit
    When Default :
      # FQ 60365 GA 11/2009 Compléter le message d'erreur
      If GMESSAGE<>"" GMESSAGE-=mess(135,188,1)-WCAT Endif
      Rollback
  Endcase
Endif
End
############################################################
# Generation cas d'emploi formules cataloguees
Subprog CFGWUSFOR(LVAL,LTRA)
Value    Char    LVAL
Value    Integer LTRA

Local Char DES(GLONAX3)
#
# CCC (05/12/05) Utiliser [F:TFO1] car [F:TFO] est utilisé par la fonction
# de gestion des formules dans laquelle est appelée ce sous-pro
If clalev([F:TFO1]) = 0 : Local File TABFOR [TFO1] : Endif
#
If LTRA <> 0
  Trbegin [CLN]
  GOK = 1
Endif
#
Call PURCLN(30,LVAL,0)
#
Filter [TFO1] Where FORTYP = 7
&            Order By Key TFO0
For [TFO1]
  Call LECTEXTRA(DES,"TABFOR","DES","7",[F:TFO1]FORCOD) From ATEXTRA
  # Issue 63311 GH 09/03/2018 - Detected errors in configurator formula was always referring to the last one
  GMESSAGE=""
  Call CFGWUSEXP(30,[F:TFO1]FORCOD,DES,[F:TFO1]FORFOR,"FORFOR")
  If GMESSAGE<>"" : GMESSAGE-=mess(135,105,1)-[F:TFO1]FORCOD : Endif
Next
Filter [TFO1]
#
If LTRA <> 0
  Case GOK
    When 1 :
      Commit
    When Default :
      # FQ 60365 GA 11/2009 Compléter le message d'erreur
      # If GMESSAGE<>"" GMESSAGE-=mess(135,105,1)-[F:TFO1]FORCOD Endif
      Rollback
  Endcase
Endif
End
############################################################
Subprog CFGWUSEXP(LTYP,LNUM,LDES,LEXP,LFLD)
Value    Shortint LTYP
Value    Char     LNUM
Value    Char     LDES
Value    Char     LEXP
Value    Char     LFLD
#
Local    Integer  W_I, W_J, W_L
Local    Shortint W_K
Local    Char     W_FOR(250) : W_FOR = format$("KT:250X",LEXP)
Local    Char     W_NEXTCAR(1)      # JPJ E20134
Local    Char     W_PREVCAR(1)      # FQ 54722 GA 05/2009 (suite)
Local    Char     W_SYMBOL(GLONVCR) # FQ 54722 GA 05/2009 (suite)
Local    Shortint W_RANG : W_RANG=1 # FQ 71542 GA 02/2011

If dim(W_PRS)>0 & W_PRS<>""
  # FQ 54722 GA 05/2009 (suite)
   W_L=-1
  # FQ 71542 GA 02/2011 ne pas boucler ...
  # While W_L<>0 & GOK=1
  #   W_L=instr(1,W_FOR,W_PRS)
   While W_L<>0 & GOK=1
     W_L=instr(W_RANG,W_FOR,W_PRS)
     # uniquement le préfixe "S_"
     If W_L>1
        W_PREVCAR=mid$(W_FOR, W_L-1, 1)
        W_RANG = W_L+1  # FQ 71542 GA 02/2011 pour ne pas boucler, recherche du symbole suivant
     Else
        W_PREVCAR=""
     Endif
     If W_L<>0 & not (W_PREVCAR>= "A" & W_PREVCAR<= "Z" | W_PREVCAR>= "0" & W_PREVCAR<= "9")
        # Extraction du nom de symbole complet
        W_J=len(W_PRS)
        Repeat
          W_NEXTCAR=mid$(W_FOR, W_L+W_J, 1)
          W_J+=1
        Until W_L+W_J>len(W_FOR) | not (W_NEXTCAR >= "A" & W_NEXTCAR <= "Z" | W_NEXTCAR >= "0" & W_NEXTCAR <= "9")
        W_SYMBOL = mid$(W_FOR,W_L,W_J-1)
      # symbole existant ou non ?
        W_I=find(W_SYMBOL,Z_VARLAB)
        If W_I<>0
           W_K = val(left$(Z_VARATT(W_I-1),1))          # FQ 55802 avant Z_VARATT(W_I)
           Call ECRCLN(LTYP,LNUM,LDES,"",W_K,right$(W_SYMBOL,len(W_PRS)+1),LFLD)
        Elsif evalue("dim("+W_SYMBOL+")")<0             # FQ 56221 sinon pb sur les variables du configurateur S_CPTCFG, ...
           # Variable inexistante
           GOK=0 : GMESSAGE=mess(11,108,1)-W_SYMBOL
        Endif
      # on enleve ce symbole de la formule pour passer au suivant
        W_FOR = left$(W_FOR,W_L-1)+mid$(W_FOR,W_L+len(W_SYMBOL),len(W_FOR))
        W_RANG = 1  # FQ 71542 GA 02/2011 on recommence à 1 si symbole trouvé
     Endif
   Wend
  # FIN - FQ 54722 GA 05/2009 (suite)
Elsif W_FOR <> ""
  # Selon LOA_SYMBOLES de CFGLIB en v130  # ancien code ... inutilisé ????
  For W_I = 0 To Z_VARNBR-1
    W_J = instr(1,W_FOR,Z_VARLAB(W_I))
    If W_J <> 0
        # Vérification si pas un symbole de même racine   JPJ E20134 ->
        W_NEXTCAR=mid$(W_FOR, W_J+len(Z_VARLAB(W_I)),1)
        If not(W_NEXTCAR >= "A" & W_NEXTCAR <= "Z" | W_NEXTCAR >= "0" & W_NEXTCAR <= "9")
              W_K = val(left$(Z_VARATT(W_I),1))
              Call ECRCLN(LTYP,LNUM,LDES,"",W_K,mid$(Z_VARLAB(W_I),3,GLONCQU),LFLD)
              W_FOR = left$(W_FOR,W_J-1)+mid$(W_FOR,W_J+len(Z_VARLAB(W_I)),len(W_FOR))
              If W_FOR = ""
                Break
              Endif
        Endif      # JPJ E20134 <-
    Endif
  Next W_I
Endif
End
############################################################
# Ecriture enregistrement CFGLNK
Subprog ECRCLN(LTYP1,LNUM1,LDES1,LABR,LTYP2,LNUM2,LFLD)
Value Shortint  LTYP1
Value Char      LNUM1
Value Char      LDES1
Value Char      LABR
Value Shortint  LTYP2
Value Char      LNUM2
Value Char      LFLD

Local Char      WTAB(GLONATB)

# FQ 60154+58317 GA 11/2009 pb de performances  CLN0=SYMTYPWUS+SYMNUMWUS+SYMTYP+SYMNUM
Read [F:CLN]CLN0=LTYP1;LNUM1;LTYP2;LNUM2
If fstat
    Raz [F:CLN]
    [F:CLN]SYMTYPWUS = LTYP1
    [F:CLN]SYMNUMWUS = LNUM1
    [F:CLN]SYMTYP    = LTYP2
    [F:CLN]SYMNUM    = LNUM2
    [F:CLN]CLE1      = num$([F:CLN]SYMTYPWUS)+"~"+[F:CLN]SYMNUMWUS
    [F:CLN]CLE2      = num$([F:CLN]SYMTYP)+"~"+[F:CLN]SYMNUM
    [F:CLN]FLD       = LFLD
    [F:CLN]CREUSR    = GUSER
    [F:CLN]CREDAT    = date$
    Write [CLN]
    Case fstat
      When 0, 3 :
      When Default :
        GOK = 0
        Call FSTA("CLN") From GLOCK
    Endcase
    LCHP=LDES1
    If find(LTYP1,3,4,5,7,9) & LABR<>""                           # V6 Textes traduits
        Local Char LABREV(10),LCHP(GLONAVA),LID1(GLONID1),LID2(GLONID2)
        LABREV = LABR
        If pat(LABR,"[F:*]")<>1 & pat(LABR,"[M:*]")<>1
            LABREV = "[F:"+LABR+"]"
        Endif
        Case LTYP1
            When 3:
                If LCHP="" : LCHP="SCEAXX" : Endif
                WTAB = "CFGSCE"
                If evalue("dim("+LABREV+"SCENUM)")>0 LID1 = evalue(LABREV+"SCENUM") Endif
                LID2 = ""
            When 4,5:
                If LCHP="" : LCHP="SELAXX" : Endif
                WTAB = "CFGSEL"
                If evalue("dim("+LABREV+"SELNUM)")>0 LID1 = evalue(LABREV+"SELNUM") Endif
                LID2 = ""
            When 7:
                If LCHP="" : LCHP="MACAXX" : Endif
                WTAB = "CFGMAC"
                If evalue("dim("+LABREV+"MACNUM)")>0 LID1 = evalue(LABREV+"MACNUM") Endif
                LID2 = ""
            When 9:
                If LCHP="" : LCHP="SHACATAXX" : Endif
                WTAB = "CFGSHA"
                If evalue("dim("+LABREV+"SHACAT)")>0 LID1 = evalue(LABREV+"SHACAT") Endif
                If evalue("dim("+LABREV+"SHANUM)")>0 LID2 = evalue(LABREV+"SHANUM") Endif
        Endcase
        If LID1<>""  # FQ 55760
           Call DUPTEXTRA(WTAB,LCHP,LID1,LID2,"CFGLNK","SYMAXXWUS",[F:CLN]CLE1,[F:CLN]CLE2) From ATEXTRA
        Endif
    Else
        Call MAJTEXTRA (LDES1,"CFGLNK","SYMAXXWUS",[F:CLN]CLE1,[F:CLN]CLE2) From ATEXTRA
    Endif
Endif
End
############################################################
# Effacement enregistreemnts CFGLNK
Subprog PURCLN(LTYP,LVAL,LTRA)
Value Integer LTYP
Value Char    LVAL
Value Integer LTRA
#
If clalev([F:CLN]) = 0 : Local File CFGLNK  [CLN] : Endif
If clalev([F:AXX]) = 0 : Local File ATEXTRA [AXX] : Endif
If LTRA <> 0
  Trbegin [CLN]
  GOK = 1
Endif
#
If LVAL = "*"
  If LTYP = 99
    Filter [CLN] Order By Key CLN0
  Else
    Filter [CLN] Where SYMTYPWUS = LTYP
&                Order By Key CLN0
  Endif
Else
  Filter [CLN] Where SYMTYPWUS = LTYP &
&                    SYMNUMWUS = LVAL
&              Order By Key CLN0
Endif
For [CLN]
  Readlock [CLN] Curr
  Case fstat
    When 0 :
      Delete [AXX] Where CODFIC="CFGLNK" & IDENT1=[F:CLN]CLE1 & IDENT2=[F:CLN]CLE2
      Delete [CLN] Curr
      If fstat
        GOK = 0
        Call FSTA("CLN") From GLOCK
        Break
      Endif
    When 1 :
      GOK = -1
      Break
    When Default :
      GOK = 0
      Call FSTA("CLN") From GLOCK
      Break
  Endcase
Next
Filter [CLN]
If LTRA <> 0
  Case GOK
    When 1       : Commit
    When Default : Rollback
  Endcase
Endif
End
############################################################
# Comparaison de deux listes de symboles
# LTAB1 : Table de symboles 1
# LNBR1 : Nombre de symboles table 1
# LTAB2 : Table de symboles 2
# LNBR2 : Nombre de symboles table 2
# LRET : code retour 0 = identique / 1 different
Subprog DIFSYM(LTAB1,LNBR1,LTAB2,LNBR2,LRET)
Value    Char    LTAB1()
Value    Decimal LNBR1
Value    Char    LTAB2()
Value    Decimal LNBR2
Variable Integer LRET
#
Local    Integer WI, WJ
Raz LRET
If LNBR1 <> LNBR2
  LRET = 1
Else
  For WI = 0 To LNBR1-1
    WJ = find(LTAB1(WI),LTAB2(0..LNBR2-1))
    If WJ = 0
      LRET = 1
      Break
    Endif
  Next WI
Endif
End
############################################################
Subprog QSTSCE(LSCE,LTABQST,LNBR,LNBS)
Value     Char    LSCE
Variable  Char    LTABQST()
Variable  Decimal LNBR
Variable  Decimal LNBS
#
If clalev([F:CLN0]) = 0 : Local File CFGLNK    [CLN0] : Endif
If clalev([F:CLN1]) = 0 : Local File CFGLNK    [CLN1] : Endif
If clalev([F:CLN2]) = 0 : Local File CFGLNK    [CLN2] : Endif
If clalev([F:CSL0]) = 0 : Local File CFGSCELIN [CSL0] : Endif # FQ 62993 GA 03/2010
#CHECK IGNORE_BEGIN
If GVERSION>="2.0.0"    # Issue 104077 GA 11/2014 Akira before GVERSION>="1.8.0"
   If clalev([F:CSQ0]) = 0 : Local File CFGSCEQST  [CSQ0] : Endif    # FQ 64278 GA 06/2010
Endif
#CHECK IGNORE_END
#
Local     Integer WI, WJ
#
# FQ 62993 GA 03/2010 utiliser l'ordre du scénario
###Filter [CLN0] Where SYMTYPWUS = 3    &
###&                   SYMNUMWUS = LSCE
###&            Order By Key CLN0
###For [CLN0]
## Issue 79886 GA 02/2012 - Raz de cette correction 62993
##Link [CSL0] With [CLN0]CLN0=3;LSCE;[F:CSL0]SYMTYP;[F:CSL0]SYMNUM As [LNK]
##&           Where [F:CSL0]SCENUM = LSCE & [F:CSL0]SYMTYP>0
##&           Order By Key CSL0
##For [LNK]
Filter [CLN0] Where SYMTYPWUS = 3    &
&                   SYMNUMWUS = LSCE
&             Order By Key CLN0
For [CLN0]
    Case [F:CLN0]SYMTYP
      When 1 : Call LOASYM([F:CLN0]SYMNUM,LTABQST,LNBR)
      When 2 :                                            # Variable
      When 3 : WJ = LNBR
               Call QSTSUB([F:CLN0]SYMNUM,LTABQST,LNBR)
               LNBS += (LNBR - WJ)
      When 4 : Call QSTSEL([F:CLN0]SYMNUM,LTABQST,LNBR)
      When 5 : Call QSTOPV([F:CLN0]SYMNUM,LTABQST,LNBR)
      When 7 : Call QSTPRO([F:CLN0]SYMNUM,LTABQST,LNBR)
      When 9 : Call QSTSHA([F:CLN0]SYMNUM,LTABQST,LNBR,LSCE)   # FQ 62993 GA 03/2010
    Endcase
Next
Filter [CLN0]

Call QSTQST(LTABQST,LNBR)
# FQ 59026 GA 11/2009 ne pas trier QSTNUM !!!!
#Sorta LNBR LTABQST Order By LTABQST(indice)
End

############################################################
# FQ 62993 GA 03/2010
# Recherche des Questions posées dans une Forme & modèle
# dont la saisie de la réponse peut être positionnée
# par défaut dans le bloc Invisible
############################################################
Subprog QSTTABSCE(LSCE,LTABQST,LNBR,LNBS,LTABSCE)
Value     Char     LSCE
Variable  Char     LTABQST()
Variable  Decimal  LNBR
Variable  Decimal  LNBS
Variable  Char     LTABSCE()
#CHECK IGNORE_BEGIN
If GVERSION>="2.0.0"    # Issue 104077 GA 11/2014 Akira before GVERSION>="1.8.0"
   If clalev([F:CSQ1]) = 0 : Local File CFGSCEQST [CSQ1] : Endif    # FQ 64278 GA 06/2010
Endif
#CHECK IGNORE_END
If clalev([F:CSL1]) = 0 : Local File CFGSCELIN [CSL1] : Endif
If clalev([F:CSH1]) = 0 : Local File CFGSHA    [CSH1] : Endif
If clalev([F:CSE1]) = 0 : Local File CFGSEL    [CSE1] : Endif

Local     Integer WI, WJ, WFOUND
For WI=0 To LNBR
   WFOUND=1
   # Est-ce une Question du scénario LSCE ?
   Read [F:CSL1]CSL1=1;LTABQST(WI);LSCE
   If !fstat LTABSCE(WI)=LSCE : WFOUND=2 : Endif
   If WFOUND=2 : Goto NXT_CSL : Endif

   # Si non, est-ce une F&M du scénario LSCE ?
   Read [F:CSL1]CSL1=9;LTABQST(WI);LSCE
   If !fstat LTABSCE(WI)=LSCE : WFOUND=2 : Goto NXT_CSL : Endif
   If WFOUND=2 : Goto NXT_CSL : Endif

   # Si non, est-ce une Sélection du scénario LSCE ?
   Read [F:CSL1]CSL1=4;LTABQST(WI);LSCE
   If !fstat LTABSCE(WI)=LSCE : WFOUND=2 : Goto NXT_CSL : Endif
   If WFOUND=2 : Goto NXT_CSL : Endif

   # Si non, est-ce une Question d'une F&M du scénario ?
   Link [F:CSH1] With [F:CSL1]CSL1=9;[F:CSH1]SHANUM;LSCE As [LNK]
   For [LNK] Where SCENUM=LSCE
       If find(LTABQST(WI),[F:CSH1]SYMNUM(0..14))
          LTABSCE(WI)=[F:CSH1]SHACAT
          WFOUND=2
          Break
       Endif
   Next
   If WFOUND=2 : Goto NXT_CSL : Endif

   # Si non, est-ce une Question d'une Sélection du scénario ?
   Link [F:CSE1] With [F:CSL1]CSL1=9;[F:CSE1]SELNUM;LSCE As [LNK]
   For [LNK] Where SCENUM=LSCE
       If find(LTABQST(WI),[F:CSE1]SYMNUM(0..14))
          LTABSCE(WI)=[F:CSE1]SELNUM
          WFOUND=2
          Break
       Endif
   Next
   If WFOUND=2 : Goto NXT_CSL : Endif

   # 4- Si non, ??? ?
   LTABSCE(WI)="XXX"
$NXT_CSL
Next WI
End
############################################################
Subprog LOASYM(LSYM,LTABQST,LNBR)
Value     Char    LSYM
Variable  Char    LTABQST()
Variable  Decimal LNBR
If !find(LSYM,LTABQST(0..LNBR-1))
  If LNBR < dim(LTABQST)-1
    LTABQST(LNBR) = LSYM
    LNBR      += 1
  Endif
Endif
End
############################################################
Subprog QSTSUB(LSCE,LTABQST,LNBR)
Value     Char    LSCE
Variable  Char    LTABQST()
Variable  Decimal LNBR
#
Local     Integer WI
#
If clalev([F:CSC0]) = 0 : Local File CFGSCE [CSC0] : Endif
#
Read [CSC0]CSC0=LSCE
If fstat = 0
  For WI = 0 To [F:CSC0]QSTNBR-1
    Call LOASYM([F:CSC0]QSTNUM(WI),LTABQST,LNBR)
  Next WI
Endif
End
############################################################
Subprog QSTSEL(LSEL,LTABQST,LNBR)
Value     Char    LSEL
Variable  Char    LTABQST()
Variable  Decimal LNBR
#
If clalev([F:CLN1]) = 0 : Local File CFGLNK [CLN1] : Endif
#
Filter [CLN1] Where SYMTYPWUS = 4    &
&                   SYMNUMWUS = LSEL &
&                  (SYMTYP    = 1 | SYMTYP = 7)
&            Order By Key CLN0
For [CLN1]
  Case [F:CLN1]SYMTYP
    When 1 :
      Call LOASYM([F:CLN1]SYMNUM,LTABQST,LNBR)
    When 7 :
      Call QSTPRO([F:CLN1]SYMNUM,LTABQST,LNBR)
  Endcase
Next
Filter [CLN1]
End
############################################################
Subprog QSTOPV(LOPV,LTABQST,LNBR)
Value     Char    LOPV
Variable  Char    LTABQST()
Variable  Decimal LNBR
#
If clalev([F:CLN1]) = 0 : Local File CFGLNK [CLN1] : Endif
#
Filter [CLN1] Where SYMTYPWUS = 5    &
&                   SYMNUMWUS = LOPV &
&                  (SYMTYP    = 1 | SYMTYP = 7)
&            Order By Key CLN0
For [CLN1]
 Case [F:CLN1]SYMTYP
    When 1 :
      Call LOASYM([F:CLN1]SYMNUM,LTABQST,LNBR)
    When 7 :
      Call QSTPRO([F:CLN1]SYMNUM,LTABQST,LNBR)
  Endcase
Next
Filter [CLN1]
End
############################################################
Subprog QSTPRO(LPRO,LTABQST,LNBR)
Value     Char    LPRO
Variable  Char    LTABQST()
Variable  Decimal LNBR
#
If clalev([F:CLN2]) = 0 : Local File CFGLNK [CLN2] : Endif
#
Filter [CLN2] Where SYMTYPWUS = 7    &
&                   SYMNUMWUS = LPRO
&            Order By Key CLN0
For [CLN2]
  Case [F:CLN2]SYMTYP
    When 1 : Call LOASYM([F:CLN2]SYMNUM,LTABQST,LNBR)
    When 4 : Call QSTSEL([F:CLN2]SYMNUM,LTABQST,LNBR)
    When 5 : Call QSTOPV([F:CLN2]SYMNUM,LTABQST,LNBR)
  Endcase
Next
Filter [CLN2]
End
############################################################
Subprog QSTSHA(LSHA,LTABQST,LNBR,LSCE)
Value     Char    LSHA
Variable  Char    LTABQST()
Variable  Decimal LNBR
Value     Char    LSCE         # FQ 62993 GA 03/2010
#
If clalev([F:CLN1]) = 0 : Local File CFGLNK [CLN1] : Endif
If clalev([F:CLN2]) = 0 : Local File CFGLNK [CLN2] : Endif # FQ 62993 GA 03/2010
#
Filter [CLN1] Where SYMTYPWUS = 9    &
&                   SYMNUMWUS = LSHA &
&                   SYMTYP    = 1
&            Order By Key CLN0
For [CLN1]
  Call LOASYM([F:CLN1]SYMNUM,LTABQST,LNBR)
Next
Filter [CLN1]
#
# FQ 62993 GA 03/2010
# Symboles de la F&M, s'ils sont utilisés par ailleurs dans le scénario
Filter [CLN1] Where SYMTYPWUS = 9    &
&                   left$(SYMNUMWUS,len(LSHA)+1) = LSHA+"-" &
&                   SYMTYP    = 1
&            Order By Key CLN0
For [CLN1]
  Filter [CLN2] Where SYMTYPWUS=3 & SYMNUMWUS=LSCE
&                   & SYMTYP=1    & SYMNUM=[F:CLN1]SYMNUM
  For [CLN2]
      Call LOASYM([F:CLN1]SYMNUM,LTABQST,LNBR)
      Break
  Next
  Filter [CLN2]
Next
Filter [CLN1]
End
############################################################
Subprog QSTQST(LTABQST,LNBR)
Variable  Char    LTABQST()
Variable  Decimal LNBR
#
If clalev([F:CLN1]) = 0 : Local File CFGLNK [CLN1] : Endif
#
Local     Integer WI
WI = 0
#
While WI < LNBR
  Filter [CLN1] Where (SYMTYPWUS = 1 | SYMTYPWUS = 30)  &
&                      SYMNUMWUS = LTABQST(WI) &
&                      SYMTYP    = 1
&              Order By Key CLN0
  For [CLN1]
    Call LOASYM([F:CLN1]SYMNUM,LTABQST,LNBR)
  Next
  Filter [CLN1]
  WI += 1
Wend
End
############################################################
Subprog QSTSHO(LQSTNUM,LLAN,LQSTSHO)            # FQ 60137 #
Value     Char    LQSTNUM
Value     Char    LLAN
Variable  Char    LQSTSHO
#
Local Shortint ILAN,WFOUND : WFOUND=1
#
If LQSTNUM<>[F:CQU]QSTNUM
   Read [F:CQU]=LQSTNUM
   If fstat Raz [F:CQU] Endif
Endif
For ILAN=0 To dim([F:CQU]QSTLAN)-1
   If [F:CQU]QSTLAN(ILAN)=LLAN
      LQSTSHO=[F:CQU]QSTSHO(ILAN)
      WFOUND=2 : Break
   Endif
Next
If WFOUND<>2
   Call LECTEXTRA(LQSTSHO,"CFGQST","QSTAXX",LQSTNUM,"") From ATEXTRA
Endif

End
################################################################
# Recherche de la position des champs dans un écran généré
# - Ligne [F:CSC] déjà chargée
# - Fichers [F:AMK2] et [F:AMZ2] déjà ouverts si dossier distant
################################################################
Subprog UPDATE_CSC_FROM_AMZ(LPAR)                   # FQ 52854 #
Value Char LPAR

Local Integer IQST
Local Char    W_PFX(3) : W_PFX = mid$(LPAR,2,3) # Prefixe masque ecran
If clalev([F:AMK2])= 0   Local File AMSK      [AMK2]  : Endif
If clalev([F:AMZ2])= 0   Local File AMSKZON   [AMZ2]  : Endif
If dim(W_PRQ)<=0 Local Char W_PRQ(2) : W_PRQ="Q_" Endif

Local Integer IBLO1,IBLO2,IBLO3,IBLO4,IBLO5,IBLO6
IBLO1 = val(mid$(LPAR,5,1)) : If IBLO1=0 IBLO1=1 Endif
IBLO2 = val(mid$(LPAR,6,1)) : If IBLO2=0 IBLO2=2 Endif
IBLO3 = val(mid$(LPAR,7,1)) : If IBLO3=0 IBLO3=3 Endif
IBLO4 = val(mid$(LPAR,8,1)) : If IBLO4=0 IBLO4=4 Endif   # V6
IBLO5 = val(mid$(LPAR,9,1)) : If IBLO5=0 IBLO5=5 Endif   # V6
IBLO6 = val(mid$(LPAR,10,1)): If IBLO6=0 IBLO6=6 Endif   # V6
If dim([F:CSC]BLONBR)>0
  Read [AMK2]CODMSK=W_PFX+[F:CSC]SCENUM
  If !fstat
     # Position des champs du scénario courant
     For IQST=0 To [F:CSC]QSTNBR-1
         Read [AMZ2]CODE=W_PFX+[F:CSC]SCENUM;W_PRQ+[F:CSC]QSTNUM(IQST)
         If !fstat
            Case [F:AMZ2]NUMBLOC    # transcodif du Bloc
              When IBLO1 : [F:CSC]BLONBR(IQST)=1
              When IBLO2 : [F:CSC]BLONBR(IQST)=2
              When IBLO3 : [F:CSC]BLONBR(IQST)=3
              When IBLO4 : [F:CSC]BLONBR(IQST)=4
              When IBLO5 : [F:CSC]BLONBR(IQST)=5
              When IBLO6 : [F:CSC]BLONBR(IQST)=6
            Endcase
            [F:CSC]LINNBR(IQST)=[F:AMZ2]NOZONE
         Endif
     Next
     If dim([F:CSC]NBRCOL)>0      # V6 on enregistre aussi NBRCOL et NBRLIG
        [F:CSC]NBRCOL=[F:AMK2]NBRCOL
        [F:CSC]NBRLIG=[F:AMK2]NBRLIG
     Endif
  Endif
Endif
End
################################################################
# Recherche de la position des champs dans un écran généré
# - Ligne [F:CSC] déjà chargée
# - Fichers [F:AMK2] et [F:AMZ2] déjà ouverts si dossier distant
################################################################
Subprog UPDATE_CSQ_FROM_AMZ(LPAR)                   # FQ 64278 #
Value Char LPAR

Local Integer IQST
Local Char    W_PFX(3) : W_PFX = mid$(LPAR,2,3)     # Prefixe masque ecran
Local Char    W_PFK(3) : W_PFK = mid$(LPAR,2,3)+"K" # Prefixe masque invisible
If clalev([F:AMK2])= 0   Local File AMSK      [AMK2]  : Endif
If clalev([F:AMZ2])= 0   Local File AMSKZON   [AMZ2]  : Endif
If dim(W_PRQ)<=0 Local Char W_PRQ(2) : W_PRQ="Q_" Endif

Local Integer IBLO1,IBLO2,IBLO3,IBLO4,IBLO5,IBLO6
IBLO1 = val(mid$(LPAR,5,1)) : If IBLO1=0 IBLO1=1 Endif
IBLO2 = val(mid$(LPAR,6,1)) : If IBLO2=0 IBLO2=2 Endif
IBLO3 = val(mid$(LPAR,7,1)) : If IBLO3=0 IBLO3=3 Endif
IBLO4 = val(mid$(LPAR,8,1)) : If IBLO4=0 IBLO4=4 Endif   # V6
IBLO5 = val(mid$(LPAR,9,1)) : If IBLO5=0 IBLO5=5 Endif   # V6
IBLO6 = val(mid$(LPAR,10,1)): If IBLO6=0 IBLO6=6 Endif   # V6
If [F:CSC]SCENUM<>"" & dim([F:CSQ]QSTNUM)>0
  Read [AMK2]CODMSK=W_PFX+[F:CSC]SCENUM   # Masque écran WUXaaaaa
  If !fstat
     # Position des Questions du scénario courant
     For [F:CSQ] Where SCENUM=[F:CSC]SCENUM
         Read [AMZ2]CODE=W_PFX+[F:CSQ]SCENUM;W_PRQ+[F:CSQ]QSTNUM
         If !fstat
            Case [F:AMZ2]NUMBLOC    # transcodif du Bloc
              When IBLO1 : [F:CSQ]BLONBR=1
              When IBLO2 : [F:CSQ]BLONBR=2
              When IBLO3 : [F:CSQ]BLONBR=3
              When IBLO4 : [F:CSQ]BLONBR=4
              When IBLO5 : [F:CSQ]BLONBR=5
              When IBLO6 : [F:CSQ]BLONBR=6
            Endcase
            [F:CSQ]LINNBR=[F:AMZ2]NOZONE
         Endif
     Next
     If dim([F:CSC]NBRCOL)>0      # V6 on enregistre aussi NBRCOL et NBRLIG
        [F:CSC]NBRCOL=[F:AMK2]NBRCOL
        [F:CSC]NBRLIG=[F:AMK2]NBRLIG
     Endif
  Endif

# Champs invisibles dans un second masque écran
  Read [AMK2]CODMSK=W_PFK+[F:CSC]SCENUM   # Masque écran WUXKaaaaa
  If !fstat
     # Position des Questions du scénario courant
     For [F:CSQ] Where SCENUM=[F:CSC]SCENUM
         Read [AMZ2]CODE=W_PFK+[F:CSQ]SCENUM;W_PRQ+[F:CSQ]QSTNUM
         If !fstat
            [F:CSQ]BLONBR=[F:AMZ2]NUMBLOC
            [F:CSQ]LINNBR=[F:AMZ2]NOZONE
         Endif
     Next
     If dim([F:CSC]NBRCOL)>0      # V6 on enregistre aussi NBRCOL et NBRLIG
        [F:CSC]NBRCOL=[F:AMK2]NBRCOL
        [F:CSC]NBRLIG=[F:AMK2]NBRLIG
     Endif
  Endif

Endif
End

################################################################
Subprog NEWPOS_INVISIBLE(LBLONBR,LLINNBR)           # FQ 62993 #
Variable Integer LBLONBR
Variable Integer LLINNBR

Local Integer I,J, NBL(1..7)
For I=7 To 1 Step -1           # Par défaut le bloc 7 est invisible (ancien Bloc 3)
   If [M:CWIN]TYPBLOC(I-1)=5   # Invisible
      NBL(I)=max(NBL(I),[M:CWIN]LINMIN(I-1)) # No ligne mini pour ce bloc
      For J=0 To [M:CWIN]NBLIG-1
        # Prochaine ligne libre sur le bloc I
         If [M:CWIN]BLONBR(J)=I NBL(I)=max(NBL(I),[M:CWIN]LINNBR(J)+1) Endif
      Next J
      If NBL(I)<=[M:CWIN]LINMAX(I-1)         # No ligne maxi pour ce bloc
         LBLONBR=I
         LLINNBR=NBL(I)
         Break
      Endif
   Endif
Next I
End
################################################################
Subprog NEWPOS_VISIBLE(LBLONBR,LLINNBR)             # FQ 62993 #
Variable Integer LBLONBR
Variable Integer LLINNBR
Local Integer I,J, NBL(1..6)
For I=1 To 6
   If [M:CWIN]TYPBLOC(I-1)=2   # Affiché/Saisi
      NBL(I)=max(NBL(I),[M:CWIN]LINMIN(I-1)) # No ligne mini pour ce bloc
      For J=0 To [M:CWIN]NBLIG-1
        # Prochaine ligne libre sur le bloc I
         If [M:CWIN]BLONBR(J)=I NBL(I)=max(NBL(I),[M:CWIN]LINNBR(J)+1) Endif
      Next J
      If NBL(I)<=[M:CWIN]LINMAX(I-1)         # No ligne maxi pour ce bloc
         LBLONBR=I
         LLINNBR=NBL(I)
         Break
      Endif
   Endif
Next I
End
############################################################
#  Renvoyer le message suite anomalie calcul compteur : NUMERO/SUBANM
#    E: Code erreur
#    S: Message
Subprog NUM_ERR(STAT,MESSA)
Value Integer STAT
Variable Char MESSA
Gosub MESSAGE From SUBANM
If STAT=99 : GMESSAGE-=GLOCK : Endif
End

