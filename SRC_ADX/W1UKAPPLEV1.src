#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque UKAPPLEV1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:06:59"
A_USER  = "DOC"
A_STAMP = "20181109230659"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBRAPPLEV"
  If [M]NBRAPPLEV=0
  Endif
 When "NBRCURLEV"
  If [M]NBRCURLEV=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask UKAPPLEV1 [APPLEV1]
Gosub HORODAT
Local Inpbox "UKAPPLEV1" From GFONCTION At A_STAMP With A_WINDPREV Mask [APPLEV1] As [SIM_]
Grizo [APPLEV1]5
Grizo [APPLEV1]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [APPLEV1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=14 : Y2(0)=25
X1(1)=1 : X2(1)=74 : Y1(1)=1 : Y2(1)=13
Return

$ON_MTH
Return

$ON_UPT
Onevent BEFORE_AREA Gosub AV_UPT From W1UKAPPLEV1
Return

$AV_UPT
Chgfmt [M]UPT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$ON_CURUPT
Onevent BEFORE_AREA Gosub AV_CURUPT From W1UKAPPLEV1
Return

$AV_CURUPT
Chgfmt [M]CURUPT(indice) With "DPZ:"+GFMDAT
Gosub _AFF
Return

$CHG_STY
Return


