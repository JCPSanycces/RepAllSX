#<AdxTL>@(#)9.0.0.0 $Revision$

##########################################################################
# UTIGPA05        Utilitaire de resynchronisation  OF      Module GPAO  #
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#   Détection  et résolution de désynchronisation entre les quantités    #
#   réalisées de l'entête OF et les quantités réalisées des articles     #
#   lancés                                                               #
##########################################################################

Call MAJ_UTIGPA05
End


Subprog MAJ_UTIGPA05
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("WO Synchronisation") From LECFIC
If DOSSIER <> ""
  Call EXE_UTIGPA05(DOSSIER) 
Endif
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End


Subprog EXE_UTIGPA05(DOSSIER)
Value Char DOSSIER
Call ECR_TRACE("UTIGPA05 : Process start "+DOSSIER,0) From GESECRAN
#----- Ouverture des fichiers -----#
If clalev([F:MFI])  =0  Local File =DOSSIER+".MFGITM"      [MFI]  : Endif
If clalev([F:MFG])  =0  Local File =DOSSIER+".MFGHEAD"     [MFG]  : Endif

#----- Variables locales -----#
Local Char     WMESSAGE(80)

Local Integer COMPTEUR, STOP 
Local Char     CLE1(20), CLE3(20), CRITERE(200)
Local Integer  CLE2, CLE4, CLE5

Local Integer  WMFGNBR, WCORNBR
Local Decimal  WCPLQTY, WREJCPLQTY, WQUACPLQTY, WRMNEXTQTY

Raz CLE1, CLE2, CLE3, CLE4, STOP, WCORNBR, WMFGNBR
$BOUCLE_MFG
If STOP = 1
  STOP = 0 : CRITERE='MFGNUM>"'+CLE1+'"'
Else
  CRITERE="1=1"
Endif

Raz COMPTEUR

Call DEBTRANS From GLOCK
Trbegin [MFG]

For [F:MFG]MFG0 Where evalue(CRITERE) 
    Readlock [F:MFG]MFG0 Curr
    If fstat
        Call ECR_TRACE("File MFGHEAD, Error ="-num$(fstat),1) From GESECRAN
    Else
        WMFGNBR +=1 
        
        WCPLQTY     = 0
        WREJCPLQTY  = 0
        WQUACPLQTY  = 0
        WRMNEXTQTY  = 0

        For [F:MFI] Where MFGNUM = [F:MFG]MFGNUM & [F:MFI]ITMTYP <> 2
            WCPLQTY     += [F:MFI]CPLQTY
            WREJCPLQTY  += [F:MFI]REJCPLQTY
            WQUACPLQTY  += [F:MFI]QUACPLQTY
        Next

        If [F:MFG]ITMLINNBR = [F:MFG]ITMCLENBR
            WRMNEXTQTY = 0
        Else
            WRMNEXTQTY =  [F:MFG]EXTQTY - WCPLQTY
        Endif
        Call QTEARR(WRMNEXTQTY,[F:MFG]STU) From TRTDIV 
        If WRMNEXTQTY < 0 : WRMNEXTQTY = 0 : Endif
        If WCPLQTY >= [F:MFG]EXTQTY : Raz WRMNEXTQTY : Endif
        If WRMNEXTQTY > [F:MFG]EXTQTY : WRMNEXTQTY = [F:MFG]EXTQTY : Endif

        If [F:MFG]CPLQTY <> WCPLQTY |
&          [F:MFG]REJCPLQTY <> WREJCPLQTY |
&          [F:MFG]QUACPLQTY <> WQUACPLQTY |
&          [F:MFG]RMNEXTQTY <> WRMNEXTQTY
            [F:MFG]CPLQTY     = WCPLQTY
            [F:MFG]REJCPLQTY  = WREJCPLQTY
            [F:MFG]QUACPLQTY  = WQUACPLQTY
            [F:MFG]RMNEXTQTY  = WRMNEXTQTY
            WCORNBR += 1
        Endif        
        Rewrite [MFG]
    Endif
    COMPTEUR += 1
    If COMPTEUR > GMAXUPDTRS 
        CLE1 = [F:MFG]MFGNUM
        STOP = 1 
        Break 
    Endif

Next
Commit
If STOP : Goto BOUCLE_MFG : Endif
Close Local File [MFG]
Close Local File [MFI]

Call ECR_TRACE("Analysed:"-num$(WMFGNBR),0) From GESECRAN
Call ECR_TRACE("Resynchronised:"-num$(WCORNBR),0) From GESECRAN
Call ECR_TRACE("UTIGPA05 : end of process",0) From GESECRAN

#----- Fin du traitement -----#
$FIN_UTIGPA05
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(7)<>2 End : Endif
Call EXE_UTIGPA05(APPLI)
End

