#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion de la fenêtre OMIGXTD

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(14)
Local Integer A_RESULT
A_DATE  = [09/11/2018]
A_HEURE = "23:14:25"
A_USER  = "DOC"
Call ISWINVALID(nomap,GLANGUE,"OMIGXTD",0,A_STAMP,A_RESULT,1) From INTRUTILB
Return

$NAVIGMSK
Local Char NAVMSK(200)
NAVMSK="MIGXTD0;MIGXTD1;MIGXTD2;"
Return

$OUVRE_BOITE
Gosub INIT_BOITE
Gosub DEF_BOITE
Gosub AFF_BOITE
Return

$INIT_BOITE
Local Char    OBJLIS(GLONAOB)(0..10), DESLIS(80)(0..10), BOX1(10)
Local Integer CHGLIS(0..10), BROLIS(0..10), TRELIS(0..10)
Local Char    SAIRAP(50)(1..16)
Local Integer DERLU , AFOLDEF
Local Char    ABRENA(GLONABR)
DERLU = 0
AFOLDEF = 1
ABRENA = ""
BOX1 = "GAU_CHE"
If clalev([M:MIGXTD0])=0 : Local Mask MIGXTD0 [MIGXTD0] : Endif
If clalev([M:MIGXTD1])=0 : Local Mask MIGXTD1 [MIGXTD1] : Endif
If clalev([M:MIGXTD2])=0 : Local Mask MIGXTD2 [MIGXTD2] : Endif
Gosub TIT
nolign = 1
Return

$DEF_BOITE
Gosub HORODAT From WGOMIGXTD
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OMIGXTD" From GFONCTION At A_STAMP With A_WINDPREV Mask [MIGXTD0]
&   Folder Mask [MIGXTD1]
& , Folder Mask [MIGXTD2]
& As [MIGXTD1]
Titled [MIGXTD1] TIT
Return

$VISU_BOITE
Gosub INIT_BOITE
Gosub HORODAT From WGOMIGXTD
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Inpbox "OMIGXTD" From GFONCTION At A_STAMP With A_WINDPREV Mask [MIGXTD0]
&   Folder Mask [MIGXTD1]
& , Folder Mask [MIGXTD2]
& As [MIGXTD1]
Titled [MIGXTD1] TIT
Gosub AFF_BOITE
Return

$AFF_BOITE
Boxact [MIGXTD1] Folder AFOLDEF
Return

$SAISIE_BOITE
Boxinp [MIGXTD1] Using REPONSE
Return

$FERME_BOITE
Onerrgo RIEN
Close Local Inpbox [MIGXTD1]
Onerrgo
Return

$RIEN
Resume

$TIT
Local Char TIT(60) , TITTRN(60)
Call TEXTE(1002866,TIT) From OBJDIV
If GPROGRAMME<>""
 If dim([L]ACTION)<0 : Local Char ACTION(20) : Endif
 [L]ACTION = "TITRE" : Gosub ACTION From =GPROGRAMME
Endif
Return

$REMPLIT_
Return

$DEFAUT_BRO
Return

$SETBOX
Return

$SETORDER
Return

$ENDORDER
Return

$PICKING
Return

$DEPICK
Return

$REPICK
Return

$SETCUR
Return

$DEFVAR
Local Char    ABMSK(GLONABR)(0..15) , NOMMSK(GLONAMK)(0..15)
Local Integer NBMASK , AMA(0..15) , NBMSKCMP
NOMMSK(0) = "MIGXTD0"      : ABMSK(0)  = "MIGXTD0"  : AMA(0) = 1
NOMMSK(1) = "MIGXTD1"      : ABMSK(1)  = "MIGXTD1"  : AMA(1) = 1
NOMMSK(2) = "MIGXTD2"      : ABMSK(2)  = "MIGXTD2"  : AMA(2) = 1
NBMASK = 2
NBMSKCMP = 0
Return

$SETMASK
Case MA
 When 0 : If clalev([M:MIGXTD0])>0 : Default Mask [MIGXTD0] : Endif
 When 1 : If clalev([M:MIGXTD1])>0 : Default Mask [MIGXTD1] : Endif
 When 2 : If clalev([M:MIGXTD2])>0 : Default Mask [MIGXTD2] : Endif
Endcase
Return

$TITMASK
Case MA
 When 0 : If clalev([M:MIGXTD0])>0 : Gosub TITRES From W1MIGXTD0 : Endif
 When 1 : If clalev([M:MIGXTD1])>0 : Gosub TITRES From W1MIGXTD1 : Endif
 When 2 : If clalev([M:MIGXTD2])>0 : Gosub TITRES From W1MIGXTD2 : Endif
Endcase
Return

$FERME_MASK
If clalev([M:MIGXTD0])>0 : Close Local Mask [MIGXTD0] : Endif
If clalev([M:MIGXTD1])>0 : Close Local Mask [MIGXTD1] : Endif
If clalev([M:MIGXTD2])>0 : Close Local Mask [MIGXTD2] : Endif
Return

$RAZMASK
Case MA
 When 0 : If clalev([M:MIGXTD0])>0 : Raz [M:MIGXTD0] : Endif
 When 1 : If clalev([M:MIGXTD1])>0 : Raz [M:MIGXTD1] : Endif
 When 2 : If clalev([M:MIGXTD2])>0 : Raz [M:MIGXTD2] : Endif
Endcase
Return

$AFFMASK
Case MA
 When 0 : If clalev([M:MIGXTD0])>0 : Affzo [M:MIGXTD0] : Endif
 When 1 : If clalev([M:MIGXTD1])>0 : Affzo [M:MIGXTD1] : Endif
 When 2 : If clalev([M:MIGXTD2])>0 : Affzo [M:MIGXTD2] : Endif
Endcase
Return

$OUVMSKCMP
Return

$FERMSKCMP
Return

$RAZMSKCMP
Return

$AFF_ENAFLG
Return

$CHARGEFIC
Case IMA
 When 0 : If clalev([M:MIGXTD0])>0 : [F:MIGXTDF] = [M:MIGXTD0] : Endif
 When 1 : If clalev([M:MIGXTD1])>0 : [F:MIGXTDF] = [M:MIGXTD1] : Endif
 When 2 : If clalev([M:MIGXTD2])>0 : [F:MIGXTDF] = [M:MIGXTD2] : Endif
Endcase
Return

$CHARGEMSK
Case IMA
 When 0 : If clalev([M:MIGXTD0])>0 : [M:MIGXTD0] = [F:MIGXTDF] : Endif
 When 1 : If clalev([M:MIGXTD1])>0 : [M:MIGXTD1] = [F:MIGXTDF] : Endif
 When 2 : If clalev([M:MIGXTD2])>0 : [M:MIGXTD2] = [F:MIGXTDF] : Endif
Endcase
Return

$GRISE_CLE
If AMA(0)
 Grizo [MIGXTD0]TMNBR,MIGREFNUM,TDFNBR
Else
 Grizo [MIGXTD1]TMNBR,MIGREFNUM,TDFNBR
Endif
Return

$DEGRISE_CLE
If AMA(0)
 Actzo [MIGXTD0]TMNBR,MIGREFNUM,TDFNBR
Else
 Actzo [MIGXTD1]TMNBR,MIGREFNUM,TDFNBR
Endif
Return

$BOUTON
STDBOUT = "ECSAN09<>RHILJMP"
NBTEX  = 0
Raz NBMEN, CMEN, TMEN, NMEN, LMEN
Return

$EXEBOUT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return

$EXEACT
Local Char    SAVACT(GLONACT)
Local Integer FLGEXE
SAVACT = GACTION
Case BOUT
Endcase
GACTION = SAVACT
Return


