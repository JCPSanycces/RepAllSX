#<AdxTL>@(#)3.0.0.0 $Revision$
##########################################################################
# UTIVEN03 : Utilitaire de détection et suppression         Module Vente #
#            des allocations restantes à tord (Bug 19442)                #  
# ---------------------------------------------------------------------- #
# Problème à résoudre :                                                  #
#   Des allocations restent : - sur des commandes soldées                #
#                             - sur des livraisons validées              #
#                             - sur des factures validées (de commandes) # 
#   Détection et suppression de ces allocations                          #
##########################################################################

Call MAJ_UTIVEN03
End

##################################
$ACTION
Case ACTION
 When "DEBUT"       : Gosub DEBUT
 When "FIN"         : Gosub FIN
 When Default
Endcase
Return

##################################
$DEBUT
[M]WDAT=[0/0/0]
[M]WPUR=1
Affzo [M]1,99
Return

$FIN
PARAM(1)=[M]WDAT
PARAM(2)=num$([M]WPUR)
Return

##################################
Subprog MAJ_UTIVEN03
Local Char DOSSIER(30) : DOSSIER=nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
   Call EXE_UTIVEN03(DOSSIER)
Endif
End

##################################
Subprog EXE_UTIVEN03(DOSSIER)
Value Char DOSSIER

Local Integer I, J, PURALL, LRET
Local Char    WSOHNUM

Local Char PARAM(30)(1..2)
Local Date DATREF
Call SAISIE_DAT(GBIDA1,PARAM,"UTIVEN03","UTIVEN03","XWUTIVEN03") From GSAISIE
DATREF = PARAM(1)
PURALL  = val(PARAM(2))

Call TEMPON("O") From GESECRAN
Call OUVRE_TRACE("UTIVEN03 : Liste des allocations restantes") From LECFIC  
Call ECR_TRACE("UTIVEN03 : Début traitement du dossier "+DOSSIER,0) From GESECRAN

#----- Ouverture des fichiers -----#
If clalev([F:SOH])=0  Local File =DOSSIER+".SORDER"     [SOH]  Endif
If clalev([F:SOQ])=0  Local File =DOSSIER+".SORDERQ"    [SOQ]  Endif
If clalev([F:SDH])=0  Local File =DOSSIER+".SDELIVERY"  [SDH]  Endif
If clalev([F:SDD])=0  Local File =DOSSIER+".SDELIVERYD" [SDD]  Endif
If clalev([F:STA])=0  Local File =DOSSIER+".STOALL"     [STA]  Endif
If clalev([F:STA1])=0 Local File =DOSSIER+".STOALL"     [STA1] Endif
If clalev([F:ITV])=0  Local File =DOSSIER+".ITMMVT"     [ITV]  Endif
If clalev([F:STO])=0  Local File =DOSSIER+".STOCK"      [STO]  Endif
If clalev([F:SIV])=0  Local File =DOSSIER+".SINVOICEV"  [SIV]  Endif
If clalev([F:SID])=0  Local File =DOSSIER+".SINVOICED"  [SID]  Endif
#--- Bug 73400
If clalev([F:PRH])=0  Local File =DOSSIER+".STOPREH"    [PRH]  Endif
If clalev([F:PRE])=0  Local File =DOSSIER+".STOPRED"    [PRE]  Endif
#---
Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE("Allocations restantes sur livraisons validées",0) From GESECRAN 
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
Call ECR_TRACE(" ",0) From GESECRAN 

Raz I
For [SDH]SDH0 Where CFMFLG=2 & SHIDAT>=DATREF With Nohint
   Raz J
   For [SDD]SDD0 Where SDHNUM=[F:SDH]SDHNUM & STOMGTCOD<>1
      For [STA1]STA1 Where VCRTYP=4 & VCRNUM=[F:SDD]SDHNUM & VCRLIN=[F:SDD]SDDLIN
         If J=0
            Call ECR_TRACE("*** Livraison :"-[F:SDH]SDHNUM-[F:SDH]STOFCY-format$("DD2",[F:SDH]CREDAT),0) From GESECRAN
         Endif
         If PURALL=2
            Call DEBTRANS From GLOCK
            Trbegin [STA1]
            Call SUPALL([F:STA1]STOFCY,[F:STA1]ITMREF,[F:STA1]STOCOU,[F:STA1]SEQ,LRET) From STKALL
            If LRET=0 
               Commit
               Call ECR_TRACE("Allocation"-mess([F:STA1]ALLTYP,294,1)-"restante :"-
&                             [F:STA1]ITMREF-num$([F:STA1]QTYSTUACT),1) From GESECRAN
            Else
               Rollback
               Call ECR_TRACE("Chrono stock"-num$([F:STA1]STOCOU)-"inexistant :"-
&                             "Allocation"-mess([F:STA1]ALLTYP,294,1)-"restante :"-
&                             [F:STA1]ITMREF-num$([F:STA1]QTYSTUACT),1) From GESECRAN
            Endif
         Else
            Call ECR_TRACE("Allocation"-mess([F:STA1]ALLTYP,294,1)-"restante :"-
&                          [F:STA1]ITMREF-num$([F:STA1]QTYSTUACT),1) From GESECRAN
         Endif
         J+=1
         I+=1
      Next
   Next
Next
If I=0
   Call ECR_TRACE("Aucune allocation restante",0) From GESECRAN
Endif

Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE("Allocations restantes sur factures validées",0) From GESECRAN 
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
Call ECR_TRACE(" ",0) From GESECRAN 

Raz I
For [SIV]SIV0 Where INVSTA=3 & INVDAT>=DATREF With Nohint
   Raz J
   For [SID]SID0 Where NUM=[F:SIV]NUM & STOMGTCOD<>1
      For [STA1]STA1 Where VCRTYP=5 & VCRNUM=[F:SID]NUM & VCRLIN=[F:SID]SIDLIN
         If J=0
            Call ECR_TRACE("*** Facture :"-[F:SIV]NUM-[F:SIV]STOFCY-format$("DD2",[F:SIV]CREDAT),0) From GESECRAN
         Endif
         If PURALL=2
            Call DEBTRANS From GLOCK
            Trbegin [STA1]
            Call SUPALL([F:STA1]STOFCY,[F:STA1]ITMREF,[F:STA1]STOCOU,[F:STA1]SEQ,LRET) From STKALL
            If LRET=0 
               Commit
               Call ECR_TRACE("Allocation"-mess([F:STA1]ALLTYP,294,1)-"restante :"-
&                             [F:STA1]ITMREF-num$([F:STA1]QTYSTUACT),1) From GESECRAN
            Else
               Rollback
               Call ECR_TRACE("Chrono stock"-num$([F:STA1]STOCOU)-"inexistant :"-
&                             "Allocation"-mess([F:STA1]ALLTYP,294,1)-"restante :"-
&                             [F:STA1]ITMREF-num$([F:STA1]QTYSTUACT),1) From GESECRAN
            Endif
         Else
            Call ECR_TRACE("Allocation"-mess([F:STA1]ALLTYP,294,1)-"restante :"-
&                          [F:STA1]ITMREF-num$([F:STA1]QTYSTUACT),1) From GESECRAN
         Endif
         J+=1
         I+=1
      Next
   Next
Next
If I=0
   Call ECR_TRACE("Aucune allocation restante",0) From GESECRAN
Endif

Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE("Allocations restantes sur commandes soldées",0) From GESECRAN 
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
Call ECR_TRACE(" ",0) From GESECRAN 

Raz I
Raz WSOHNUM
For [SOQ]SOQ3 Where SOQSTA=3 & ORDDAT>=DATREF
   For [STA1]STA1 Where VCRTYP=2 & VCRNUM=[F:SOQ]SOHNUM & VCRLIN=[F:SOQ]SOPLIN & VCRSEQ=[F:SOQ]SOQSEQ
      If [F:SOQ]SOHNUM<>WSOHNUM
         Call ECR_TRACE("*** Commande :"-[F:SOQ]SOHNUM-format$("DD2",[F:SOQ]CREDAT),0) From GESECRAN
         WSOHNUM=[F:SOQ]SOHNUM
      Endif
      If PURALL=2
         Call DEBTRANS From GLOCK
         Trbegin [STA1]
         Call SUPALL([F:STA1]STOFCY,[F:STA1]ITMREF,[F:STA1]STOCOU,[F:STA1]SEQ,LRET) From STKALL
         If LRET=0 
            Commit
            Call ECR_TRACE("Allocation"-mess([F:STA1]ALLTYP,294,1)-"supprimée :"-[F:STA1]ITMREF-
&                          "Quantité"-num$([F:STA1]QTYSTUACT),1) From GESECRAN
         Else
            Rollback
            Call ECR_TRACE("Chrono stock"-num$([F:STA1]STOCOU)-"inexistant :"-
&                          "Allocation"-mess([F:STA1]ALLTYP,294,1)-"restante :"-[F:STA1]ITMREF-
&                          "Quantité"-num$([F:STA1]QTYSTUACT),1) From GESECRAN
         Endif
      Else
         Call ECR_TRACE("Allocation"-mess([F:STA1]ALLTYP,294,1)-"restante :"-[F:STA1]ITMREF-
&                       "Quantité"-num$([F:STA1]QTYSTUACT),1) From GESECRAN
      Endif
      I+=1
   Next
Next
If I=0
   Call ECR_TRACE("Aucune allocation restante",0) From GESECRAN
Endif

#--- Bug 73400
Call ECR_TRACE(" ",0) From GESECRAN 
Call ECR_TRACE("Allocations restantes sur préparations livrées",0) From GESECRAN 
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
Call ECR_TRACE(" ",0) From GESECRAN 

Raz I
For [PRH]PRH0 Where DLVFLG>2 & SHIDAT>=DATREF With Nohint
   Raz J
   For [PRE]PRE0 Where PRHNUM=[F:PRH]PRHNUM & STOMGTCOD<>1
      For [STA1]STA1 Where VCRTYP=3 & VCRNUM=[F:PRE]PRHNUM & VCRLIN=[F:PRE]PRELIN
         If J=0
            Call ECR_TRACE("*** Préparation :"-[F:PRH]PRHNUM-[F:PRH]STOFCY-format$("DD2",[F:PRH]CREDAT),0) From GESECRAN
         Endif
         If PURALL=2
            Call DEBTRANS From GLOCK
            Trbegin [STA1]
            Call SUPALL([F:STA1]STOFCY,[F:STA1]ITMREF,[F:STA1]STOCOU,[F:STA1]SEQ,LRET) From STKALL
            If LRET=0 
               Commit
               Call ECR_TRACE("Allocation"-mess([F:STA1]ALLTYP,294,1)-"restante :"-
&                             [F:STA1]ITMREF-num$([F:STA1]QTYSTUACT),1) From GESECRAN
            Else
               Rollback
               Call ECR_TRACE("Chrono stock"-num$([F:STA1]STOCOU)-"inexistant :"-
&                             "Allocation"-mess([F:STA1]ALLTYP,294,1)-"restante :"-
&                             [F:STA1]ITMREF-num$([F:STA1]QTYSTUACT),1) From GESECRAN
            Endif
         Else
            Call ECR_TRACE("Allocation"-mess([F:STA1]ALLTYP,294,1)-"restante :"-
&                          [F:STA1]ITMREF-num$([F:STA1]QTYSTUACT),1) From GESECRAN
         Endif
         J+=1
         I+=1
      Next
   Next
Next
If I=0
   Call ECR_TRACE("Aucune allocation restante",0) From GESECRAN
Endif
#---

Call ECR_TRACE(" ",0) From GESECRAN
Call ECR_TRACE("Allocations orphelines",0) From GESECRAN 
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
Call ECR_TRACE(" ",0) From GESECRAN 

Raz I
#--- Bug 73400
#For [STA1]STA1 Where find(VCRTYP,2,4,5)
For [STA1]STA1 Where find(VCRTYP,2,3,4,5)
#---
   If [F:STA1]VCRTYP=2
      Look [F:SOQ]SOQ0=[F:STA1]VCRNUM;[F:STA1]VCRLIN;[F:STA1]VCRSEQ
      If fstat
         If PURALL=2
            Call DEBTRANS From GLOCK
            Trbegin [STA1]
            Call SUPALL([F:STA1]STOFCY,[F:STA1]ITMREF,[F:STA1]STOCOU,[F:STA1]SEQ,LRET) From STKALL
            If LRET=0 
               Commit
               WLIB="supprimée :" 
            Else
               Rollback
               WLIB="restante :" 
            Endif
         Else
            WLIB="restante :" 
         Endif
         Call ECR_TRACE("*** Allocation"-mess([F:STA1]ALLTYP,294,1)-WLIB-
&                       [F:STA1]ITMREF-num$([F:STA1]QTYSTUACT)-"--- Ligne commande :"-
&                       [F:STA1]VCRNUM-num$([F:STA1]VCRLIN)-num$([F:STA1]VCRSEQ),1)
&                       From GESECRAN
         I+=1
      Endif
   #--- Bug 73400      
   Elsif [F:STA1]VCRTYP=3
      Look [F:PRE]PRE0=[F:STA1]VCRNUM;[F:STA1]VCRLIN
      If fstat
         If PURALL=2
            Call DEBTRANS From GLOCK
            Trbegin [STA1]
            Call SUPALL([F:STA1]STOFCY,[F:STA1]ITMREF,[F:STA1]STOCOU,[F:STA1]SEQ,LRET) From STKALL
            If LRET=0 
               Commit
               WLIB="supprimée :" 
            Else
               Rollback
               WLIB="restante :" 
            Endif
         Else
            WLIB="restante :" 
         Endif
         Call ECR_TRACE("*** Allocation"-mess([F:STA1]ALLTYP,294,1)-WLIB-
&                       [F:STA1]ITMREF-num$([F:STA1]QTYSTUACT)-"--- Ligne préparation :"-
&                       [F:STA1]VCRNUM-num$([F:STA1]VCRLIN)-num$([F:STA1]VCRSEQ),1)
&                       From GESECRAN
         I+=1
      Endif
      #---      
   Elsif [F:STA1]VCRTYP=4
      Look [F:SDD]SDD0=[F:STA1]VCRNUM;[F:STA1]VCRLIN
      If fstat
         If PURALL=2
            Call DEBTRANS From GLOCK
            Trbegin [STA1]
            Call SUPALL([F:STA1]STOFCY,[F:STA1]ITMREF,[F:STA1]STOCOU,[F:STA1]SEQ,LRET) From STKALL
            If LRET=0 
               Commit
               WLIB="supprimée :" 
            Else
               Rollback
               WLIB="restante :" 
            Endif
         Else
            WLIB="restante :" 
         Endif
         Call ECR_TRACE("*** Allocation"-mess([F:STA1]ALLTYP,294,1)-WLIB-
&                       [F:STA1]ITMREF-num$([F:STA1]QTYSTUACT)-"--- Ligne livraison :"-
&                       [F:STA1]VCRNUM-num$([F:STA1]VCRLIN)-num$([F:STA1]VCRSEQ),1)
&                       From GESECRAN
         I+=1
      Endif
   Else
      Look [F:SID]SID0=[F:STA1]VCRNUM;[F:STA1]VCRLIN
      If fstat
         If PURALL=2
            Call DEBTRANS From GLOCK
            Trbegin [STA1]
            Call SUPALL([F:STA1]STOFCY,[F:STA1]ITMREF,[F:STA1]STOCOU,[F:STA1]SEQ,LRET) From STKALL
            If LRET=0 
               Commit
               WLIB="supprimée :" 
            Else
               Rollback
               WLIB="restante :" 
            Endif
         Else
            WLIB="restante :" 
         Endif
         Call ECR_TRACE("*** Allocation"-mess([F:STA1]ALLTYP,294,1)-WLIB-
&                       [F:STA1]ITMREF-num$([F:STA1]QTYSTUACT)-"--- Ligne facture :"-
&                       [F:STA1]VCRNUM-num$([F:STA1]VCRLIN)-num$([F:STA1]VCRSEQ),1)
&                       From GESECRAN
         I+=1
      Endif
   Endif 
Next
If I=0
   Call ECR_TRACE("Aucune allocation orpheline",0) From GESECRAN
Endif

$FIN_UTIVEN03
Call TEMPOFF     From GESECRAN
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC

End
