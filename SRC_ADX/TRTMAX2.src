#<AdxTL>@(#)3.0.0.0 $Revision$
################################################################################################################
# Récupération de sélection Tiers                                         Module CRM          28 novembre 2000 #
################################################################################################################
################################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When "OK"           : Gosub ONOK
    When Default
  Endcase
Return

################################################################################################################
$OUVRE
Global Char GSZPREOPG

  GSZPREOPG = ""
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:REP]) : Local File SALESREP [REP] : Endif
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
Return

################################################################################################################
$DEFBOUT
Return

################################################################################################################
$SETBOUT
Return

################################################################################################################
$OUVRE_BOITE
Return

################################################################################################################
$DEBUT
Local Integer IT

  IT = 0
  Filter [SEC] Where [F:SEC]SELTBL <> "CCN" Order By [F:SEC]SELDAT Desc
  For [SEC]
    If IT >= dim([M:MAX2]OPGNUM)-1 Then
      Break
    Endif
    [M:MAX2]OPGNUM(IT) = [F:SEC]OPGNUM
    Case [F:SEC]OPGTYP
      When "OMM"
        Read [OMM]OMM0=[F:SEC]OPGNUM
        If !fstat Then
          [M:MAX2]OPGDES(IT) = [F:OMM]DES
          Read [CMG]CMG0=[F:OMM]CMGNUM
          If !fstat Then
            [M:MAX2]CMGTTR(IT) = [F:CMG]TTR
          Endif
        Endif
      When "OMP"
        Read [OMP]OMP0=[F:SEC]OPGNUM
        If !fstat Then
          [M:MAX2]OPGDES(IT) = [F:OMP]DES
          Read [CMG]CMG0=[F:OMP]CMGNUM
          If !fstat Then
            [M:MAX2]CMGTTR(IT) = [F:CMG]TTR
          Endif
        Endif
      When Default
    Endcase
    IT += 1
  Next
  Filter [SEC]
  [M:MAX2]NBOPG = IT
  Affzo [M:MAX2]
Return

################################################################################################################
$AV_CHOIX
Return

################################################################################################################
AP_CHOIX
Return

################################################################################################################
$AVANT_BOUTON
Return

################################################################################################################
$FINSAI
  Raz [M:MAX2]
  Kill GSZPREOPG
Return

################################################################################################################
$FIN
Return

################################################################################################################
$ABANDON
Return

################################################################################################################
$APRES_MODIF
Return

################################################################################################################
$BOUTON
Return

################################################################################################################
$ONMENU
Return

#########################################################
# Sous-programmes
#########################################################
################################################################################################################
$ONOK
  GSZBPCFILT = [M:MAX2]SELCRI1 + [M:MAX2]SELCRI2 + [M:MAX2]SELCRI3 + [M:MAX2]SELCRI4 + [M:MAX2]SELCRI5
  Case [M:MAX2]SELTBL
    When 1
      GSZOBJSEL = "BPC"
    When 2
      GSZOBJSEL = "BPR"
    When Default
  Endcase
  FIN = 1
Return

#########################################################
# Chargement des caractéristiques de la sélection sélectionnée.
################################################################################################################
Subprog LOADOPGINF(SZOPGNUM, SZTBLTYP)
Value Char SZOPGNUM
Variable Char SZTBLTYP

  Raz [M:MAX2]SELDAT
  Raz [M:MAX2]SELTBL
  Raz [M:MAX2]SELREC
  Raz [M:MAX2]SELCRI1
  Raz [M:MAX2]SELCRI2
  Raz [M:MAX2]SELCRI3
  Raz [M:MAX2]SELCRI4
  Raz [M:MAX2]SELCRI5
  Filter [SEC] Where [F:SEC]OPGNUM = SZOPGNUM and [F:SEC]SELTBL <> "CCN"
  For [SEC]
    [M:MAX2]SELDAT = [F:SEC]SELDAT
    Case [F:SEC]SELTBL
      When "BPC"
        [M:MAX2]SELTBL = 1
      When "BPR"
        [M:MAX2]SELTBL = 2
      When Default
    Endcase
    SZTBLTYP = [F:SEC]SELTBL
    [M:MAX2]SELREC = [F:SEC]SELREC
    [M:MAX2]SELCRI1 = left$([F:SEC]SELCRI, 50)
    [M:MAX2]SELCRI2 = mid$([F:SEC]SELCRI, 51, 50)
    [M:MAX2]SELCRI3 = mid$([F:SEC]SELCRI, 101, 50)
    [M:MAX2]SELCRI4 = mid$([F:SEC]SELCRI, 151, 50)
    [M:MAX2]SELCRI5 = mid$([F:SEC]SELCRI, 201, 50)
    Break
  Next
  Filter [SEC]
End

#########################################################
# Chargement du contenu de la sélection sélectionnée.
################################################################################################################
Subprog LOADSEL(SZOPGNUM, SZTBLTYP)
Value Char SZOPGNUM
Value Char SZTBLTYP

Local Integer IR

  IR = 0
  Call TEMPON("R") From GESECRAN
  Raz [M:MAX2]BPRNUM
  Raz [M:MAX2]BPRNAM
  Raz [M:MAX2]BPRZIP
  Raz [M:MAX2]BPRCTY
  Raz [M:MAX2]BPRCRY
  Raz [M:MAX2]BPRTEL
  Raz [M:MAX2]BPRBUS
  Raz [M:MAX2]BPRORIPPT
  Raz [M:MAX2]BPRSALFCY
  Raz [M:MAX2]BPRREP
  Raz [M:MAX2]NBBPR
  Filter [SCL] Where [F:SCL]OPGNUM = SZOPGNUM and [F:SCL]RECTYP = SZTBLTYP
  For [SCL]
    If IR >= dim([M:MAX2]BPRNUM)-1 Then
      Break
    Endif
    [M:MAX2]BPRNUM(IR) = [F:SCL]RECNUM
    If SZTBLTYP = "BPR" Then
      Read [BPR]BPR0=[F:SCL]RECNUM
      If !fstat Then
        [M:MAX2]BPRNAM(IR) = [F:BPR]BPRNAM
        If [F:BPR]BPCFLG = 2 or [F:BPR]PPTFLG = 2 Then
          Read [BPC]BPC0=[F:SCL]RECNUM
          If !fstat Then
            [M:MAX2]BPRNAM(IR) = [F:BPC]BPCNAM
            Read [ADI]CODE=425;[F:BPC]BUS
            If !fstat Then
              # FGR 22/10/2009 : X3SUIVI58372
              #Call LECTURE([M:MAX2]BPRBUS(IR), [F:ADI]LNGDES) From TEXTE
              Call LECTEXTRA([M:MAX2]BPRBUS(IR),"ATABDIV","LNGDES","425",[F:BPC]BUS) From ATEXTRA
            Endif
            Read [ADI]CODE=413;[F:BPC]ORIPPT
            If !fstat Then
              # FGR 22/10/2009 : X3SUIVI58372
              #Call LECTURE([M:MAX2]BPRORIPPT(IR), [F:ADI]LNGDES) From TEXTE
              Call LECTEXTRA([M:MAX2]BPRORIPPT(IR),"ATABDIV","LNGDES","413",[F:BPC]ORIPPT) From ATEXTRA
            Endif
            # FGR 21/10/2008 : la rubrique [F:BPC]SALFCY n'existe plus
            #[M:MAX2]BPRSALFCY(IR) = [F:BPC]SALFCY
            Read [REP]REP0=[F:BPC]REP(0)
            If !fstat Then
              [M:MAX2]BPRREP(IR) = [F:REP]REPNAM
            Endif
          Endif
        Endif
      Endif
    Elsif SZTBLTYP = "BPC" Then
      Read [BPC]BPC0=[F:SCL]RECNUM
      If !fstat Then
        [M:MAX2]BPRNAM(IR) = [F:BPC]BPCNAM
        Read [ADI]CODE=425;[F:BPC]BUS
        If !fstat Then
          # FGR 22/10/2009 : X3SUIVI58372
          #Call LECTURE([M:MAX2]BPRBUS(IR), [F:ADI]LNGDES) From TEXTE
          Call LECTEXTRA([M:MAX2]BPRBUS(IR),"ATABDIV","LNGDES","425",[F:BPC]BUS) From ATEXTRA
        Endif
        Read [ADI]CODE=413;[F:BPC]ORIPPT
        If !fstat Then
          # FGR 22/10/2009 : X3SUIVI58372
          #Call LECTURE([M:MAX2]BPRORIPPT(IR), [F:ADI]LNGDES) From TEXTE
          Call LECTEXTRA([M:MAX2]BPRORIPPT(IR),"ATABDIV","LNGDES","413",[F:BPC]ORIPPT) From ATEXTRA
        Endif
        # FGR 21/10/2008 : la rubrique [F:BPC]SALFCY n'existe plus
        #[M:MAX2]BPRSALFCY(IR) = [F:BPC]SALFCY
        Read [REP]REP0=[F:BPC]REP(0)
        If !fstat Then
          [M:MAX2]BPRREP(IR) = [F:REP]REPNAM
        Endif
      Endif
    Endif
    Read [BPR]BPR0=[F:SCL]RECNUM
    If !fstat Then
      Read [BPA]BPA0=1;[F:SCL]RECNUM; [F:BPR]BPAADD
      If !fstat Then
        [M:MAX2]BPRCRY(IR) = [F:BPA]CRY
        [M:MAX2]BPRZIP(IR) = [F:BPA]POSCOD
        [M:MAX2]BPRCTY(IR) = [F:BPA]CTY
        [M:MAX2]BPRTEL(IR) = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
      Endif
    Endif
    IR += 1
  Next
  Filter [SCL]
  [M:MAX2]NBBPR = IR
  Call TEMPOFF From GESECRAN
End

