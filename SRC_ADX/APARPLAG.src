#<AdxTL>@(#)5.0.0.0 $Revision$
Raz GPILOBJ,GNBMASKOUV
Local Char PARAM(20)(1..3) , VALEUR(20)
PARAM(1) = ""
Call TRAITE_CHAR(VALEUR,PARAM,"","AIMP1","AIMP1",4,"") From GTRAITE
End

######################################################################################

$ACTION
Case ACTION
 When "INIT"  : Gosub INIT
 When "OUVRE" : Gosub OUVRE
 When "DEBUT" : Gosub DEBUT
 When "OK"    : Gosub OK
Endcase
Return

#########################################
$INIT
If dim([M:RPT]NBSEG) > 0
 If [M:RPT]NBSEG >0 :
  Call ERREUR(mess(254,133,1)) From GESECRAN : # Des valeurs de segmentation déjà saisies
  FIN = 1
 Endif
Endif
Return

#########################################

$OUVRE
Local Integer I,J,NOL,SAVNOL,NB
Local Char    WCOD(80)
Return

#########################################
$DEBUT
Raz [M:APG]

[M:APG]CODTYP   = PARAM(1)        : # type de donneés
[M:APG]LONG     = val(PARAM(2))   : # Longueur
[M:APG]NOLIB    = val(PARAM(3))   : # numero menu local
[M:APG]OPTION   = PARAM(4)        : # Option
[M:APG]SUPP     = PARAM(5)        : # Supp
[M:APG]TABCONT  = PARAM(6)        : # tab de controle
[M:APG]INT1     = PARAM(7)        : # valeur non affiche 1
[M:APG]VAL1     = PARAM(8)        : # valeur affichée 1
[M:APG]INT2     = PARAM(9)        : # valeur non affiche 2
[M:APG]VAL2     = PARAM(10)       : # valeur affichée 2
[M:APG]LABR     = PARAM(11)       : # abrevation du maque ou se trouve le tableau invicible
[M:APG]TRT      = PARAM(12)       : # trt ou on va chercher les sous prog de controle
[M:APG]WCOD     = PARAM(13)       : # code parametre
[M:APG]LIGNE    = val(PARAM(14))  : # nolign de l'ecran d'origine
#------------------------------- Pour les impressions
[M:APG]VALEUR4  = PARAM(15)   : # [M:RPT]PARTYP(nolign-1)
[M:APG]VALEUR5  = PARAM(16)   : # [M:RPT]PAROBJ(nolign-1)
[M:APG]VALEUR6  = PARAM(17)   : # num$([M:RPT]TYP(nolign-1))
[M:APG]VALEUR7  = PARAM(18)   : # [M:RPT]CONTROLE(nolign-1)
[M:APG]VALEUR8  = PARAM(19)   : # [M:RPT]OBJET(nolign-1)

### Remplissage du tableau invicible avec tous les parametres de AIMP1 : VALPAL1,VALPLAG2,PARPALG,NBPLAG
[M:APG]WNB =evalue("[M:"+[M:APG]LABR+"]NBPLAG")

For I=0 To [M:APG]WNB-1
 [M:APG]WPAR(J)  = evalue("[M:"+[M:APG]LABR+"]PARPLAG("+num$(I)+")")
 [M:APG]WVAL1(J) = evalue("[M:"+[M:APG]LABR+"]VALPLAG1("+num$(I)+")")
 [M:APG]WVAL2(J) = evalue("[M:"+[M:APG]LABR+"]VALPLAG2("+num$(I)+")")
 [M:APG]WBOR(J)  = evalue("[M:"+[M:APG]LABR+"]BORPLAG("+num$(I)+")")
 J+=1
Next

# On recupere les bonnes valeurs
NOL = 0
For I=0 To J-1
 If [M:APG]WPAR(I) = [M:APG]WCOD
  [M:APG]BORNE(NOL) = [M:APG]WBOR(I)
  Gosub AJOUT
  NOL += 1
 Endif
Next I

# On ajoute zc
If VALEUR <> ""
 [M:APG]WPAR(0)  = [M:APG]WCOD
 [M:APG]WVAL1(0) = VALEUR
 [M:APG]WVAL2(0) = ""
 If [M:APG]VAL2<>""
  [M:APG]WVAL2(0) = evalue("[M:"+[M:APG]LABR+"]"+[M:APG]VAL2+"("+num$([M:APG]LIGNE)+")")
 Endif
 [M:APG]WBOR(0)  = 1
 [M:APG]VALEUR1(0) = [M:APG]WVAL1(0)
 Call CHARGE([M:APG]VALEUR1(0),[M:APG]CODTYP,[M:APG]NOLIB,[M:APG]LONG,[M:APG]VALINT1(0)) From FMTVAR
 NOL += 1
 If [M:APG]WVAL2(0)<>""
  [M:APG]WBOR(0)  = 2
  [M:APG]VALEUR2(0) = [M:APG]WVAL2(0)
  Call CHARGE([M:APG]VALEUR2(0),[M:APG]CODTYP,[M:APG]NOLIB,[M:APG]LONG,[M:APG]VALINT2(0)) From FMTVAR
  NOL += 1
 Endif
 [M:APG]BORNE(0) = [M:APG]WBOR(0)
Endif

[M:APG]NBPAR = NOL
Affzo [M:APG]
Return

$AJOUT
[M:APG]VALEUR1(NOL) = [M:APG]WVAL1(I)
Call CHARGE([M:APG]VALEUR1(NOL),[M:APG]CODTYP,[M:APG]NOLIB,[M:APG]LONG,[M:APG]VALINT1(NOL)) From FMTVAR
If [M:APG]BORNE(NOL) = 2
 [M:APG]VALEUR2(NOL) = [M:APG]WVAL2(I)
 Call CHARGE([M:APG]VALEUR2(NOL),[M:APG]CODTYP,[M:APG]NOLIB,[M:APG]LONG,[M:APG]VALINT2(NOL)) From FMTVAR
Endif
Return

#########################################
$OK
J= find([M:APG]WCOD,[M:APG]WPAR(0..[M:APG]WNB))
While J
 Dela J-1 , 1 [M:APG]WPAR, [M:APG]WVAL1 , [M:APG]WVAL2 , [M:APG]WBOR
 If [M:APG]WNB > 0 : [M:APG]WNB -= 1 : Endif
 J= find([M:APG]WCOD,[M:APG]WPAR(0.. [M:APG]WNB))
Wend
J = [M:APG]WNB
For I = 0 To [M:APG]NBPAR-1
 [M:APG]WPAR(J+I)     = [M:APG]WCOD
 [M:APG]WVAL1(J+I)    = [M:APG]VALINT1(I)
 [M:APG]WVAL2(J+I)    = [M:APG]VALINT2(I)
 [M:APG]WBOR(J+I)     = [M:APG]BORNE(I)
 [M:APG]WNB+=1
Next I
### Raz du tableau origine
For I=0 To evalue("[M:"+[M:APG]LABR+"]NBPLAG")
 Assign ("[M:"+[M:APG]LABR+"]PARPLAG("+num$(I)+")")  With ""
 Assign ("[M:"+[M:APG]LABR+"]VALPLAG1("+num$(I)+")") With ""
 Assign ("[M:"+[M:APG]LABR+"]VALPLAG2("+num$(I)+")") With ""
 Assign ("[M:"+[M:APG]LABR+"]BORPLAG("+num$(I)+")")  With 0
Next

### Remplisage du tableau origine
For I=0 To [M:APG]WNB-1
 Assign ("[M:"+[M:APG]LABR+"]PARPLAG("+num$(I)+")")  With [M:APG]WPAR(I)
 Assign ("[M:"+[M:APG]LABR+"]VALPLAG1("+num$(I)+")") With [M:APG]WVAL1(I)
 Assign ("[M:"+[M:APG]LABR+"]VALPLAG2("+num$(I)+")") With [M:APG]WVAL2(I)
 Assign ("[M:"+[M:APG]LABR+"]BORPLAG("+num$(I)+")")  With [M:APG]WBOR(I)
Next
Assign ("[M:"+[M:APG]LABR+"]NBPLAG")  With [M:APG]WNB

If  [M:APG]NBPAR> 1
 VALEUR = ""
Else
 If (([M:APG]INT1 <> "" & [M:APG]VAL1 <> "") & ([M:APG]VAL2 <> "" & [M:APG]INT2 <> ""))
  K = find([M:APG]WCOD,[M:APG]WPAR(0..[M:APG]WNB))
  If K
   Assign ("[M:"+[M:APG]LABR+"]"+[M:APG]INT1+"("+num$([M:APG]LIGNE)+")") With [M:APG]WVAL1(K-1)
   Assign ("[M:"+[M:APG]LABR+"]"+[M:APG]VAL1+"("+num$([M:APG]LIGNE)+")") With [M:APG]VALEUR1(0)
   If [M:APG]WBOR(K-1) <2
    Assign ("[M:"+[M:APG]LABR+"]"+[M:APG]INT2+"("+num$([M:APG]LIGNE)+")") With [M:APG]WVAL1(K-1)
    Assign ("[M:"+[M:APG]LABR+"]"+[M:APG]VAL2+"("+num$([M:APG]LIGNE)+")") With [M:APG]VALEUR1(0)
   Else
    Assign ("[M:"+[M:APG]LABR+"]"+[M:APG]INT2+"("+num$([M:APG]LIGNE)+")") With [M:APG]WVAL2(K-1)
    Assign ("[M:"+[M:APG]LABR+"]"+[M:APG]VAL2+"("+num$([M:APG]LIGNE)+")") With [M:APG]VALEUR2(0)
   Endif
   If clalev([M:RPT])
    Affzo [M:RPT]
   Elsif clalev([M:DIA])
    Affzo [M:DIA]
   Endif
   VALEUR = [M:APG]VALEUR1(0)
  Endif
 Endif
Endif
mkstat = 4
Return

$ACTIONP
Local Integer OKTRT
If [M:APG]TRT<>""
 Call EXISTE_ADX("","",[M:APG]TRT,OKTRT) From ORDSYS
 If OKTRT
  Gosub ACTION From =[M:APG]TRT
 Endif
Endif
Return

######################################################################################
######################################################################################
Subprog AS_VALEUR2(VALEUR)
Variable Char    VALEUR()
If [M:APG]BORNE(nolign-1) = 1
 mkstat = 1
Endif
End

# Read [F:ATY]CODTYP = [M:APG]CODTYP
# If [F:ATY]OBJLIEN <>"" & !fstat
#  Local Char SUPP(10)
#  If [F:ATY]OBJLIEN="ADI"
#   SUPP = num$([L]NOLIB)
#  Elsif [L]PAROBJ<>""
#   SUPP = num$(evalue([L]PAROBJ)) : # mb 7.5.2 bug 14220
#  Endif
#  Call CONTROLE([L]OBJET,"!$"+[L]PAROPT,VALINT1,SUPP,mkstat) From CONTOBJ
#  If mkstat : End : Endif
# Endif

Subprog C_VALEUR1(VALEUR)
Variable Char    VALEUR()
Local Char ACTION(20)
ACTION = "CONTPAR1" : Gosub ACTIONP
If mkstat : End : Endif
If [M:APG]BORNE(nolign-1) <> 2
 For NOL=0 To [M:APG]NBPAR -1
  If NOL <> nolign-1
   If [M:APG]VALINT1(NOL) = [M:APG]VALINT1(nolign-1) & [M:APG]BORNE(NOL) <>2
    GMESSAGE = mess(24,123,1)-":"-num$(NOL+1) : # Valeur déjà existant
    mkstat = 2 : End
    Break
   Endif
  Endif
 Next
Endif
End

Subprog C_VALEUR2(VALEUR)
Variable Char    VALEUR()
Local Char ACTION(20)
ACTION = "CONTPAR2" : Gosub ACTIONP
If mkstat : End : Endif
For NOL=0 To [M:APG]NBPAR -1
 If NOL <> nolign-1
  If [M:APG]VALINT1(NOL)-[M:APG]VALINT2(NOL) = [M:APG]VALINT1(nolign-1)-[M:APG]VALINT2(nolign-1) & [M:APG]BORNE(NOL)=2
   GMESSAGE = mess(24,123,1)-":"-num$(NOL+1)  : # Valeur déjà existant
   mkstat = 2 : End
   Break
  Endif
 Endif
Next
End

Subprog AM_VALEUR1(VALEUR)
Variable Char    VALEUR()
Local Char ACTION(20)
ACTION = "MODIFPAR1" : Gosub ACTIONP
End

Subprog AM_VALEUR2(VALEUR)
Variable Char    VALEUR()
Local Char ACTION(20)
ACTION = "MODIFPAR2" : Gosub ACTIONP
End

##################################################
Subprog CTLSTYLE(VALEUR,CODE,LABR)
Variable Char VALEUR
Value    Char    CODE
Value    Char    LABR
Local Char ZONE(30)
Local Integer I,OK
Onerrgo RIEN
If clalev([F:AMK])=0 : Local File AMSK [AMK] : Endif
Read [AMK]CODMSK = maskcou
If !fstat
 ZONE = "[M:"+[F:AMK]ABRMSK+"]"+zoncou+"("+num$(indice)+")"
Endif
For I=0 To evalue("[M:"+LABR+"]NBPLAG")-1
 If [L]CODE = evalue("[M:"+LABR+"]PARPLAG("+num$(I)+")")
  Chgstl =ZONE With "APARPLAG"
  VALEUR = ""
  OK = 1
  Break
 Endif
Next I
If !OK
 Chgstl =ZONE With ""
Endif
Affzo =ZONE
Onerrgo
End


##################################################
Subprog AVZSTYLE(CODE,LABR)
Value    Char    CODE
Value    Char    LABR
Local Char ZONE(30)
Local Integer I,OK
Onerrgo RIEN
If clalev([F:AMK])=0 : Local File AMSK [AMK] : Endif
Read [AMK]CODMSK = maskcou
If !fstat
 ZONE = "[M:"+[F:AMK]ABRMSK+"]"+zoncou+"("+num$(indice)+")"
Endif
For I=0 To evalue("[M:"+LABR+"]NBPLAG")-1
 If [L]CODE = evalue("[M:"+LABR+"]PARPLAG("+num$(I)+")")
  Chgstl =ZONE With "APARPLAG"
  OK = 1
  Break
 Endif
Next I
If !OK
 Chgstl =ZONE With ""
Endif
Onerrgo
End


##################################################
Subprog IBSTYLE(CODE,LABR)
Value    Char    CODE
Value    Char    LABR
Local Integer I
Onerrgo RIEN
For I=0 To evalue("[M:"+LABR+"]NBPLAG")-1
 If [L]CODE = evalue("[M:"+LABR+"]PARPLAG("+num$(I)+")")
  GBOUTS = ""
  GBOUT1 = ""
  Break
 Endif
Next I
Onerrgo
End

$RIEN
Resume

