#<AdxTL>@(#)0.0.0.0 $Revision$Class ## ?IDENTQRY? SEARCH ##
# Supervisor
#WMSRHGACCOUNT GACCOUNT
# 2018-11-06 07:08:11 923

Funprog IS_IMPLEMENTED()
End 1
#---------------------------------------------------------------------------------------------------#
# List of tables to open
#---------------------------------------------------------------------------------------------------#
$ASEARCH_OPEN
If filinfo(filpath("FIL","GACCOUNT","fde",-1),0) <0  : ERROR=[V]CST_AERROR : Return : Endif 
Local File GACCOUNT [GAC]
Local File GACCOUNT [GAC_]
Local File ATEXTRA [AXX_1]
Local File ATEXTRA [AXX_2]
Local Char KEY_GAC(120)(1..3)
ACTION = "ASEARCH_OPEN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to close
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CLOSE
LogicClose File [GAC]
LogicClose File [GAC_]
LogicClose File [AXX_1]
LogicClose File [AXX_2]
ACTION = "ASEARCH_CLOSE_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN
Link [GAC] With
& [GAC_]GAC0=[GAC]COA;[GAC]ACC,
& [F:AXX_1]AXX0 = "GACCOUNT";"DESTRA";GACTX.LAN;[F:GAC]COA;[F:GAC]ACC,
& [F:AXX_2]AXX0 = "GACCOUNT";"SHOTRA";GACTX.LAN;[F:GAC]COA;[F:GAC]ACC
& As [LNK_]
& Where (1=1
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# List of tables to join
#---------------------------------------------------------------------------------------------------#
$ASEARCH_JOIN_INC
Link [GAC] With
& [GAC_]GAC0=[GAC]COA;[GAC]ACC,
& [F:AXX_1]AXX0 = "GACCOUNT";"DESTRA";GACTX.LAN;[F:GAC]COA;[F:GAC]ACC,
& [F:AXX_2]AXX0 = "GACCOUNT";"SHOTRA";GACTX.LAN;[F:GAC]COA;[F:GAC]ACC
& As [LNK_]
& Where (UPDDATTIM > gdatetime$(QUPDDATTIM)
& )
ACTION = "ASEARCH_JOIN_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# Create an instance of
#---------------------------------------------------------------------------------------------------#
$ASEARCH_CREATEINSTANCE
Local Integer ASTATUS
Local Integer FINS
#Create a new instance
INS = NewInstance C_GACCOUNT(GACTX,UIDINS,NUMLIN,null,"") AllocGroup null
INS.setaccessorEnabled = 0
Local Integer CI1
Local Integer CJ1
Local Char    SEPINS1(2) : SEPINS1=""
Local Char IS1(1)

Local Integer CCE1_MAXI:CCE1_MAXI= 0
If dim([F:GAC]CCEDEF)>0
    If CCE1_MAXI = 0
        CCE1_MAXI = dim([F:GAC]CCEDEF)
    Else
        CCE1_MAXI = min(CCE1_MAXI,dim([F:GAC]CCEDEF))
    Endif
Endif
CJ1=1
For CI1 = 0 To CCE1_MAXI-1
#Create a new instance
INS.CCE1(CJ1) = NewInstance C_GACCOUNT_CCE1(GACTX,UIDINS,NUMLIN,INS,"") AllocGroup INS
INS.CCE1(CJ1).setaccessorEnabled = 0
 CJ1+=1
Next CI1
Local Integer CNV_MAXI:CNV_MAXI= 0
If dim([F:GAC]CNVACC)>0
    If CNV_MAXI = 0
        CNV_MAXI = dim([F:GAC]CNVACC)
    Else
        CNV_MAXI = min(CNV_MAXI,dim([F:GAC]CNVACC))
    Endif
Endif
CJ1=1
For CI1 = 0 To CNV_MAXI-1
#Create a new instance
INS.CNV(CJ1) = NewInstance C_GACCOUNT_CNV(GACTX,UIDINS,NUMLIN,INS,"") AllocGroup INS
INS.CNV(CJ1).setaccessorEnabled = 0
 CJ1+=1
Next CI1
Local Integer COAGAC_MAXI:COAGAC_MAXI= 0
If dim([F:GAC]DEFACC)>0
    If COAGAC_MAXI = 0
        COAGAC_MAXI = dim([F:GAC]DEFACC)
    Else
        COAGAC_MAXI = min(COAGAC_MAXI,dim([F:GAC]DEFACC))
    Endif
Endif
CJ1=1
For CI1 = 0 To COAGAC_MAXI-1
#Create a new instance
INS.COAGAC(CJ1) = NewInstance C_GACCOUNT_COAGAC(GACTX,UIDINS,NUMLIN,INS,"") AllocGroup INS
INS.COAGAC(CJ1).setaccessorEnabled = 0
 CJ1+=1
Next CI1
Return

#---------------------------------------------------------------------------------------------------#
# Set an instance
#---------------------------------------------------------------------------------------------------#
$ASEARCH_SETINSTANCE

SetInstance INS With [F:GAC]
FINS = 1
Call ASETTEXTRA(INS.AXX,INS.ALLOCGRP(),"DESTRA",[F:AXX_1]TEXTE,GACTX.LAN) From ASYRSUB
Call ASETTEXTRA(INS.AXX,INS.ALLOCGRP(),"SHOTRA",[F:AXX_2]TEXTE,GACTX.LAN) From ASYRSUB
Local Integer CCE1_MAXI:CCE1_MAXI= 0
Local Integer CCE1_MAX:CCE1_MAX=0
If dim([F:GAC]CCEDEF)>0
    If CCE1_MAXI = 0
        CCE1_MAXI = dim([F:GAC]CCEDEF)
    Else
        CCE1_MAXI = min(CCE1_MAXI,dim([F:GAC]CCEDEF))
    Endif
Endif
CJ1=1
For CI1 = 0 To CCE1_MAXI-1
 Break ([F:GAC]CCEDEF(CI1)="")
 CCE1_MAX+=1
 INS.CCE1(CJ1).CCEDEF=[F:GAC]CCEDEF(CI1)
 CJ1+=1
Next CI1
Local Integer CNV_MAXI:CNV_MAXI= 0
Local Integer CNV_MAX:CNV_MAX=0
If dim([F:GAC]CNVACC)>0
    If CNV_MAXI = 0
        CNV_MAXI = dim([F:GAC]CNVACC)
    Else
        CNV_MAXI = min(CNV_MAXI,dim([F:GAC]CNVACC))
    Endif
Endif
CJ1=1
For CI1 = 0 To CNV_MAXI-1
 Break ([F:GAC]CNVACC(CI1)="")
 CNV_MAX+=1
 INS.CNV(CJ1).CNVACC=[F:GAC]CNVACC(CI1)
 CJ1+=1
Next CI1
Local Integer COAGAC_MAXI:COAGAC_MAXI= 0
Local Integer COAGAC_MAX:COAGAC_MAX=0
If dim([F:GAC]DEFACC)>0
    If COAGAC_MAXI = 0
        COAGAC_MAXI = dim([F:GAC]DEFACC)
    Else
        COAGAC_MAXI = min(COAGAC_MAXI,dim([F:GAC]DEFACC))
    Endif
Endif
CJ1=1
For CI1 = 0 To COAGAC_MAXI-1
 Break ([F:GAC]DEFACC(CI1)="")
 COAGAC_MAX+=1
 INS.COAGAC(CJ1).DEFACC=[F:GAC]DEFACC(CI1)
 CJ1+=1
Next CI1
[L]ASTATUS = fmet INS.ACTION("ASEARCH_TRANS_AFTER")
Gosub ASEARCH_TO_JSON
Return

#---------------------------------------------------------------------------------------------------#
# Serialize the entity in a JSON format
#---------------------------------------------------------------------------------------------------#
$ASEARCH_TO_JSON
If FINS=0 : Return : Endif
QCOUNT += 1
Onerrgo ERROR_VALUE
Append ASND.DATA ,SEPINS1
SEPINS1 = ','+chr$(10)
Append ASND.DATA ,'{'
Append ASND.DATA ,'"COA":'             +'"'+escJson(INS.COA)+'"'
Append ASND.DATA ,',"ACC":'            +'"'+escJson(INS.ACC)+'"'
Append ASND.DATA ,',"DESTRA":'         
Append ASND.DATA ,'"'
Append ASND.DATA ,escJson(func ASYRSUB.AGETTEXTRA(INS.AXX,"DESTRA",GACTX.LAN))
Append ASND.DATA ,'"'
Append ASND.DATA ,',"SHOTRA":'         
Append ASND.DATA ,'"'
Append ASND.DATA ,escJson(func ASYRSUB.AGETTEXTRA(INS.AXX,"SHOTRA",GACTX.LAN))
Append ASND.DATA ,'"'
Append ASND.DATA ,',"SUBACC":'         +'"'+escJson(INS.SUBACC)+'"'
Append ASND.DATA ,',"SUBBPR":'         +'"'+escJson(INS.SUBBPR)+'"'
Append ASND.DATA ,',"$access":'        +'"'+escJson(INS.ACS)+'"'
Append ASND.DATA ,',"GACPVS":'         +'"'+escJson(INS.GACPVS)+'"'
IS1=""
CJ1=1
Append ASND.DATA ,',"CCE1":['
For CI1=1 To CCE1_MAX
 Append ASND.DATA ,IS1+'{'
 Append ASND.DATA ,'"CCEDEF":'          +'"'+escJson(INS.CCE1(CJ1).CCEDEF)+'"'
 Append ASND.DATA ,'}'
 IS1=","
 CJ1+=1
Next CI1
Append ASND.DATA , "]"
IS1=""
CJ1=1
Append ASND.DATA ,',"CNV":['
For CI1=1 To CNV_MAX
 Append ASND.DATA ,IS1+'{'
 Append ASND.DATA ,'"CNVACC":'          +'"'+escJson(INS.CNV(CJ1).CNVACC)+'"'
 Append ASND.DATA ,'}'
 IS1=","
 CJ1+=1
Next CI1
Append ASND.DATA , "]"
IS1=""
CJ1=1
Append ASND.DATA ,',"COAGAC":['
For CI1=1 To COAGAC_MAX
 Append ASND.DATA ,IS1+'{'
 Append ASND.DATA ,'"DEFACC":'          +'"'+escJson(INS.COAGAC(CJ1).DEFACC)+'"'
 Append ASND.DATA ,'}'
 IS1=","
 CJ1+=1
Next CI1
Append ASND.DATA , "]"
Append ASND.DATA ,'}'
Onerrgo
FINS = 0
Return

#---------------------------------------------------------------------------------------------------#
# Errors
#---------------------------------------------------------------------------------------------------#
$ERROR_VALUE
SVALUE ='"<error'-errmes$(errn)+'>"'
Resume
#---------------------------------------------------------------------------------------------------#
# Link standard key
#---------------------------------------------------------------------------------------------------#
$AQUERY_PRIMARYKEYS
Local Char ASTDKEY(250)
ASTDKEY = ""
ASTDKEY += "[F:GAC]COA"
ASTDKEY += ";[F:GAC]ACC"
ACTION = "ASEARCH_PRIMARYKEYS_AFTER" : Gosub ASEARCH_ACTION
Return

#---------------------------------------------------------------------------------------------------#
# Actions
#---------------------------------------------------------------------------------------------------#
$ASEARCH_ACTION
Local Char CURPRO(250),CURPTH(250),AMETHOD(50),AEVENT(50)
[L]AEVENT = [L]ACTION
 Gosub METHODS From GACCOUNT_CSTD
 Gosub METHODS From GACCOUNT_CSTD
 Gosub METHODS From GACCOUNT_CSTD
Gosub METHODS From GACCOUNT_CSTD
Return

#---------------------------------------------------------------------------------------------------#
# APPEND_PROTOTYPE
#---------------------------------------------------------------------------------------------------#
Funprog APPEND_PROTOTYPE(ACTX,WCLOB,PSYR)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Clbfile   WCLOB
Variable Instance  PSYR     Using C_ASYR
Local Integer ERROR : ERROR = 0
Local Integer IND   : IND = 0
Local Char TRTNAME(80)
Local Char REPRESENTATION(80)
Local File ASHW    [ASW]
Filter [ASW] Where CODCLA="GACCOUNT" & DEFREP=2
Read [ASW]ASW0 First
If !fstat
 If  [ASW]ENAFAC(0) = 2
  REPRESENTATION = [ASW]CODREP
 Else
  WCLOB ="{}"
  End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"GACCOUNT")) 
 Endif
Endif
Close Local File [ASW]
If len(REPRESENTATION)=0
 WCLOB ="{}"
 End ERROR = func ASYRSUB._ASETSTATUS(ACTX,"",0,[V]CST_AERROR,[V]CST_AHTTP_NOT_FOUND,func ASYRFNC.MES1(mess(62,149,1),"GACCOUNT")) 
Endif
Append WCLOB,'{'
Append WCLOB,'"$baseUrl":"'+PSYR.PREFIX+'"'
Append WCLOB,',"$baseType":"'+PSYR.CNTPRE+"."+nomap+'"'
Append WCLOB,',"$classTitle":"'+func GET_RES_STRING(ACTX.LAN,6127)+'"'
Append WCLOB,',"$url":"{$baseUrl}/GACCOUNT'+PSYR.URLREP+''+REPRESENTATION+'.$search"'
Append WCLOB,',"$prototype":"{$baseUrl}/$prototypes('+"'"+'{$representation}.$thumb'+"'"+')"'
Append WCLOB,',"$type":"{$baseType}.'+REPRESENTATION+'.$search"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"$resources":{'
Append WCLOB,'"$type":"application/x-array"'
Append WCLOB,',"$item":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,6127)+' {$key}"'
Append WCLOB,',"$key":"{COA}~{ACC}"'
Append WCLOB,',"$url":"{$baseUrl}/GACCOUNT('+"'"+'{$key}'+"'"+')'+PSYR.URLREP+'GACCOUNT.searchItem"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"COA":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,29354)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":3'
Append WCLOB,"}"
Append WCLOB,',"ACC":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,3956)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":15'
Append WCLOB,"}"
Append WCLOB,',"DESTRA":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,26255)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":30'
Append WCLOB,"}"
Append WCLOB,',"SHOTRA":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,4010)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":12'
Append WCLOB,"}"
Append WCLOB,',"SUBACC":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,4300)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":15'
Append WCLOB,"}"
Append WCLOB,',"SUBBPR":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,4302)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":15'
Append WCLOB,"}"
Append WCLOB,',"$access":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,71)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":10'
Append WCLOB,"}"
Append WCLOB,',"GACPVS":{'
Append WCLOB,'"$title":"'+func GET_RES_STRING(ACTX.LAN,17243)+'"'
Append WCLOB,',"$capabilities":"sort,filter"'
Append WCLOB,',"$type":"application/x-string"'
Append WCLOB,',"$maxLength":15'
Append WCLOB,"}"
Append WCLOB,',"CCE1":{'
Append WCLOB,'"$type":"application/x-array"'
Append WCLOB,',"$minItems":0'
Append WCLOB,',"$maxItems":20'
Append WCLOB,',"$item":{'
Append WCLOB,'"$type":"application/json"'
Append WCLOB,',"$properties":{'
Append WCLOB,'"CCEDEF":{'
