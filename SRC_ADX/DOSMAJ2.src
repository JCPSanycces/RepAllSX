#<AdxTL>@(#)0.0.0.0 $Revision$
## Mise à jour release 2
## Avant mise à jour
Subprog AMAJ
End

## Après mise à jour
Subprog MAJ
Local Integer OKREF
Local Char    FICHIER (10)

## Zone module sur fichier PARSTA1, PARSTA2, CACCEDEF
FICHIER = "PARSTA1"    : Gosub MAJ_MODULE
FICHIER = "PARSTA2"    : Gosub MAJ_MODULE
FICHIER = "CACCEDEF"   : Gosub MAJ_MODULE
FICHIER = "AOBJEXT"    : Gosub MAJ_MODULE

End


$MAJ_MODULE
OKREF = 0
If filinfo(filpath("FIL",FICHIER,"fde",[F:ADS]DOSSIER),0)<0 : Return : Endif
Local File =[F:ADS]DOSSIER+"."+FICHIER [F1]
If dim([F:F1]MODULE)>0
 If filinfo(filpath("FIL",FICHIER,"fde",[F:ADS]DOSREF),0)>=0
  Local File =[F:ADS]DOSREF+"."+FICHIER [F0]
  If dim([F:F0]MODULE)>0 : OKREF = 1 : Endif
 Endif
 Trbegin [F1]
  [G:F1]currind = 1
  [G:F1]currlen = 0
  For [F1]
   If OKREF
    [F:F0] = [F:F1]
    Default File [F0]
    [G:F0]currind = 1
    [G:F0]currlen = 0
    Read =
    If !fstat
     [F:F1]MODULE = [F:F0]MODULE
    Else
     [F:F1]MODULE = 1
    Endif
   Else
    [F:F1]MODULE = 1
   Endif
   Rewrite [F1]
  Next
 Commit
Endif
Close Local File [F1]
If clalev([F:F0])>0 : Close Local File [F0] : Endif
Return




