#<AdxTL>@(#)10.0.0.0 $Revision$ Gestion du masque PSDW
##########################################################################
# SUBPSDW : Prise en compte d'une DA en AOF                 HN  31/03/00 #
# ---------------------------------------------------------------------- #
# Ce traitement n'est pas un objet mais est utilisé par le s/p           #
# de prise en compte des DA en AOF et ne sert qu'à gérer le masque       #
# écran "PSDW [PSDW]".                                                   #
##########################################################################

Subprog IB_NBDA
Raz GBOUT1
If dim([M:PSDW]ITMREF)<nolign End : Endif : # Maximum lignes atteint 
If [M:PSDW]PSHNUM(nolign-1)<>"" & GFONC1<>"GESPSH" 
  GBOUT1=mess(61,198,1)-[M:PSDW]PSHNUM(nolign-1)
Endif
End


