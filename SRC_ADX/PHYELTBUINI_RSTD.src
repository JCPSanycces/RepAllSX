#<AdxTL>@(#)0.0.0.0 $Revision$
# Issue 112576
# Qry of physical elements non inventoried (from a building)

$EVENTS

  Case [L]CURPTH
  When ""
    Case [L]AEVENT
    When "AQUERY_TRANS_AFTER"           : Gosub AQUERY_TRANS_AFTER
    Endcase
  Endcase

Return

$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

$PROPERTIES

Return

$AQUERY_TRANS_AFTER

  # this physical element has never been inventoried : must be seen
  If this.PHYELTB.IVYDAT = AVOID.ADATE
    Return
  Endif

  # A physical element is inventoried if the inventory date is greater or equal
  # than the current date minus the gap given by INVVALPER parameter : mustn't be seen
  If this.PHYELTB.IVYDAT >= date$ - fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, this.PHYELTB.CPY, "INVVALPER")
    [L]ASTATUS = [V]CST_AERROR
  Endif

Return

