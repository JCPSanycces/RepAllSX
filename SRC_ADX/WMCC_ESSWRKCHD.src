#<AdxTL>@(#)0.0.0.0 $Revision$Class Children
# Supervisor
## CRUD-CLASSE ## ESSWRKCHD
# 2018-10-23 06:53:15 322


############################################################################################
### Subprog _AINSERT
############################################################################################
Subprog _AINSERT(ESSWRKCHD,ASTATUS)
Variable Instance ESSWRKCHD Using C_ESSWRKCHD
Variable Integer ASTATUS

If ESSWRKCHD = null : End : Endif

Gosub _AVARIABLES From WMC00ESSWRKCHD

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_ESSWRKCHD

End

#-----------------------------------------------------#

############################################################################################
### Subprog AINSERT
############################################################################################
Subprog AINSERT(ESSWRKCHD,ASTATUS)
Variable Instance ESSWRKCHD Using C_ESSWRKCHD
Variable Integer ASTATUS

If ESSWRKCHD = null : End : Endif

Gosub AVARIABLES From WMC00ESSWRKCHD
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

[L]A_STRSITE = ""
[L]A_STRACC = ""
Gosub AINSERT_CONTROL
If [L]ASTATUS>=[V]CST_AERROR : Goto AINSERT_END : Endif

If !adxlog
 Gosub AINSERT_TR_ESSWRKCHD
Else
 Gosub AINSERT_ESSWRKCHD
Endif

Gosub _AINSERT_AFTER
[L]A_I = ESSWRKCHD.freeSnapshot
ESSWRKCHD.snapshotEnabled = 1
$AINSERT_END
End

#-----------------------------------------------------#

$AINSERT_CONTROL
Gosub _AINSERT_CONTROL_BEFORE
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
# Control mandatory
[L]ASTATUS =  max([L]ASTATUS,fmet ESSWRKCHD._AMANDATORY)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control format
[L]ASTATUS =  max([L]ASTATUS,fmet ESSWRKCHD._AFORMAT)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

# Control other
[L]ASTATUS =  max([L]ASTATUS,fmet ESSWRKCHD._AOTHERS)
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AINSERT_CONTROL_AFTER
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_BEFORE
If ESSWRKCHD.ASTALIN = [V]CST_ANEWDEL : Return : Endif
ESSWRKCHD.ASTALIN = [V]CST_ANEW
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKCHD.ACTION("AINSERT_CONTROL_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

Return

#-----------------------------------------------------#
$_AINSERT_CONTROL_AFTER

[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKCHD.ACTION("AINSERT_CONTROL_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_TR_ESSWRKCHD
Trbegin [F:EWCHD]
 Gosub AINSERT_ESSWRKCHD
 If [L]ASTATUS>=[V]CST_AERROR : Gosub AINSERT_ABORT : Return : Endif
Commit
Return

#-----------------------------------------------------#
#-----------------------------------------------------#
$AINSERT_ESSWRKCHD
Raz [F:EWCHD]
[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKCHD.ACTION("AINSERT_BEFORE"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,func WMC00ESSWRKCHD._MAJSQL_ESSWRKCHD(ESSWRKCHD))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif

[L]ASTATUS = max([L]ASTATUS,fmet ESSWRKCHD.ACTION("AINSERT_AFTER"))
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

#-----------------------------------------------------#
$AINSERT_ABORT
Rollback
$_AINSERT_ABORT
If ESSWRKCHD.snapshotEnabled=1
 [L]A_RETIK = ESSWRKCHD.revertUpdTick
Endif
[L]ASTATUS = max(fmet ESSWRKCHD.ACTION("AINSERT_ABORT"),[L]ASTATUS)
Return
#-----------------------------------------------------#


#-----------------------------------------------------#
$_AINSERT_AFTER
If find(ESSWRKCHD.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL,[V]CST_ALL)=0
 ESSWRKCHD.ASTALIN = [V]CST_ALL
Endif
Return



