#<AdxTL>@(#)3.0.0.0 $Revision$
################################################################################################################
# Etape 2 de la définition d'un mailing                                   Module CRM          28 novembre 2000 #
################################################################################################################
# Sélection prospect/client
################################################################################################################
################################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEFBOUT"      : Gosub DEFBOUT
    When "SETBOUT"      : Gosub SETBOUT
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE
    When "DEBUT"        : Gosub DEBUT
    When "AV_CHOIX"     : Gosub AV_CHOIX
    When "AP_CHOIX"     : Gosub AP_CHOIX
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "FINSAI"       : Gosub FINSAI
    When "FIN"          : Gosub FIN
    When "ABANDON"      : Gosub ABANDON
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "BOUTON"       : Gosub BOUTON
    When "MEN"          : Gosub ONMENU
    When Default
  Endcase
Return

################################################################################################################
$OUVRE
Global Char GSZBPCFILT(250)
Global Integer GISTATRET

  GSZBPCFILT = ""
  GISTATRET = 0
  If !clalev([F:SEC]) : Local File SELCMG [SEC] : Endif
  If !clalev([F:SCL]) : Local File SELCMGLIS [SCL] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
  If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
  If !clalev([F:BPA]) : Local File BPADDRESS [BPA] : Endif
Return

################################################################################################################
$DEFBOUT
Return

################################################################################################################
$SETBOUT
  If GSZBPCFILT <> "" Then
    ETABOU(GSPE5) = 1
    [M:MAI2]CRIEXX1 = left$(GSZBPCFILT, 84)
    [M:MAI2]CRIEXX2 = mid$(GSZBPCFILT, 85, 83)
    [M:MAI2]CRIEXX3 = mid$(GSZBPCFILT, 167, 83)
    Affzo [M:MAI2]CRIEXX1
    Affzo [M:MAI2]CRIEXX2
    Affzo [M:MAI2]CRIEXX3
    GSZBPCFILT = ""
  Else
    ETABOU(GSPE5) = 0
  Endif
Return

################################################################################################################
$OUVRE_BOITE
Return

################################################################################################################
$DEBUT
Local Integer IOPGEXIST

  IOPGEXIST = 0
  Filter [SEC] Where [F:SEC]OPGNUM = GSZOPGNUM and [F:SEC]SELTBL <> "CCN"
  For [SEC]
    Case [F:SEC]SELTBL
      When "BPC"
        [M:MAI2]CRITLB = 1
        GSZOBJSEL = "BPC"
      When "BPR"
        [M:MAI2]CRITLB = 2
        GSZOBJSEL = "BPR"
      When Default
    Endcase
    [M:MAI2]CRIEXX1 = left$([F:SEC]SELCRI, 84)
    [M:MAI2]CRIEXX2 = mid$([F:SEC]SELCRI, 85, 83)
    [M:MAI2]CRIEXX3 = mid$([F:SEC]SELCRI, 167, 83)
    IOPGEXIST = 1
    Break
  Next
  Filter [SEC]
  If !IOPGEXIST Then
    [M:MAI2]CRITLB = 1
    GSZOBJSEL = "BPC"
  Endif
  Affzo [M:MAI2]
Return

################################################################################################################
$AV_CHOIX
Return

################################################################################################################
AP_CHOIX
Return

################################################################################################################
$AVANT_BOUTON
Return

################################################################################################################
$FINSAI
  Raz [M:MAI2]
  Kill GSZBPCFILT
  Kill GISTATRET
Return

################################################################################################################
$FIN
Return

################################################################################################################
$ABANDON
Return

################################################################################################################
$APRES_MODIF
Return

################################################################################################################
$BOUTON
  Case BOUT
    When "c"
      Gosub ONNOTHING
    When "d"
      Gosub ONALL
    When "e"
      Gosub ONCONFIRM
    When Default
  Endcase
Return

################################################################################################################
$ONMENU
Return

#########################################################
# Sous-programmes
#########################################################
################################################################################################################
$ONCONFIRM
Local Char SZOPGTYP (GLONAOB)
Local Integer INBRECSEL
Local Char SZFILT(250)

  SZOPGTYP = ""
  INBRECSEL = 0
  SZFILT = ""
  #S"il n'y a pas de critères, on ne fait rien.
  If [M:MAI2]CRIEXX1 = "" Then
    Return
  Endif
  Case GSZWIZCOD
    When "MAILING"
      SZOPGTYP = "OMM"
    When "PHONING"
      SZOPGTYP = "OMP"
    When "TRADESHOW"
      SZOPGTYP = "OMT"
    When Default
  Endcase
  SZFILT = [M:MAI2]CRIEXX1 + [M:MAI2]CRIEXX2 + [M:MAI2]CRIEXX3
  Gosub RUNSEL
  Call DEBTRANS From GLOCK
  Trbegin [SEC]
  Readlock [SEC]SEC0=GSZOPGNUM; GSZOBJSEL
  If fstat Then
    #Il faut créer une nouvelle sélection
    [F:SEC]OPGNUM = GSZOPGNUM
    [F:SEC]OPGTYP = SZOPGTYP
    [F:SEC]SELDAT = date$
    [F:SEC]SELTBL = GSZOBJSEL
    [F:SEC]SELCRI = SZFILT
    [F:SEC]SELREC = INBRECSEL
    Write [SEC]
    If fstat Then
      GMESSAGE = mess(100,141,1) #Erreur création
      GERR = 1
      Unlock [SEC]
      Rollback
      End
    Else
      Commit
      Unlock [SEC]
    Endif
  Else
    # Il s'agit d'une modification
    [F:SEC]OPGNUM = GSZOPGNUM
    [F:SEC]OPGTYP = SZOPGTYP
    [F:SEC]SELDAT = date$
    [F:SEC]SELTBL = GSZOBJSEL
    [F:SEC]SELCRI = SZFILT
    [F:SEC]SELREC = INBRECSEL
    Rewrite [SEC]
    If fstat Then
      GMESSAGE = mess(101,141,1) #Erreur modification
      GERR = 1
      Unlock [SEC]
      Rollback
      End
    Else
      Commit
      Unlock [SEC]
    Endif
  Endif
  GISTECPL(GICSTEP-1) = 1
  FIN = 1
Return

################################################################################################################
$ONNOTHING
  Gosub CANCELSTEP
  GISTECPL(GICSTEP-1) = 1
  FIN = 1
Return

################################################################################################################
$ONALL
Local Char SZOPGTYP (GLONAOB)
Local Integer INBRECSEL
Local Char SZFILT(250)

  SZOPGTYP = ""
  INBRECSEL = 0
  SZFILT = ""
  Case GSZWIZCOD
    When "MAILING"
      SZOPGTYP = "OMM"
    When "PHONING"
      SZOPGTYP = "OMP"
    When "TRADESHOW"
      SZOPGTYP = "OMT"
    When Default
  Endcase
  Case [M:MAI2]CRITLB
    When 1
      SZFILT = "[F:BPC]BPCNUM >= " + '"' + '"'
    When 2
      SZFILT = "[F:BPR]BPRNUM >= " + '"' + '"'
    When Default
  Endcase
  Gosub RUNSEL
  Call DEBTRANS From GLOCK
  Trbegin [SEC]
  Readlock [SEC]SEC0=GSZOPGNUM;GSZOBJSEL
  If fstat Then
    #Il faut créer une nouvelle sélection
    [F:SEC]OPGNUM = GSZOPGNUM
    [F:SEC]OPGTYP = SZOPGTYP
    [F:SEC]SELDAT = date$
    [F:SEC]SELTBL = GSZOBJSEL
    [F:SEC]SELCRI = SZFILT
    [F:SEC]SELREC = INBRECSEL
    Write [SEC]
    If fstat Then
      GMESSAGE = mess(100,141,1) #Erreur création
      GERR = 1
      Unlock [SEC]
      Rollback
      End
    Else
      Commit
      Unlock [SEC]
    Endif
  Else
    # Il s'agit d'une modification
    [F:SEC]OPGNUM = GSZOPGNUM
    [F:SEC]OPGTYP = SZOPGTYP
    [F:SEC]SELDAT = date$
    [F:SEC]SELTBL = GSZOBJSEL
    [F:SEC]SELCRI = SZFILT
    [F:SEC]SELREC = INBRECSEL
    Rewrite [SEC]
    If fstat Then
      GMESSAGE = mess(101,141,1) #Erreur modification
      GERR = 1
      Unlock [SEC]
      Rollback
      End
    Else
      Commit
      Unlock [SEC]
    Endif
  Endif
  GISTECPL(GICSTEP-1) = 1
  FIN = 1
Return

################################################################################################################
$RUNSEL
Local Integer IPERF
Local Char SZVALPERF
Local Integer IVALPERF
Local Integer IPBL
Local Integer INTR
Local Integer ICLSNUM

  #Obtient la paramètre de performance de la sélection.
  Call PARAML("", "SELPERF", SZVALPERF) From ADOVAL      # FGR 28/07/2015 : X3SUIVI108078 : Plus Call PARAM (performances)
  IVALPERF = val(SZVALPERF)
  IPERF = 0
  IPBL = 0
  INTR = 0
  ICLSNUM = 0
  Call TEMPON("R") From GESECRAN
  Call DEBTRANS From GLOCK
  Trbegin [SCL]
  Delete [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP <> "CCN"
  If fstat Then
    Rollback
  Else
    Commit
  Endif
  Case GSZOBJSEL
    When "BPR"
      Filter [BPR] Where evalue(SZFILT)
      For [BPR]
        If IPERF = 0 Then
          Call DEBTRANS From GLOCK
          Trbegin [SCL]
          INTR = 1
        Endif
        [F:SCL]OPGNUM = GSZOPGNUM
        [F:SCL]RECTYP = GSZOBJSEL
        [F:SCL]RECNUM = [F:BPR]BPRNUM
        [F:SCL]CLSNUM = ICLSNUM
        ICLSNUM += 1
        Write [SCL]
        If fstat Then
          IPBL = 1
          GMESSAGE = mess(100,141,1) #Erreur création
          GERR = 1
          Rollback
          INTR = 0
          Break
        Else
          If IPERF >= IVALPERF Then
            Commit
            IPERF = 0
            INTR = 0
          Else
            IPERF += 1
          Endif
        Endif
        INBRECSEL += 1
      Next
      If INTR Then
        If !IPBL Then
          Commit
        Endif
      Endif
      Filter [BPR]
    When "BPC"
      Filter [BPC] Where evalue(SZFILT)
      For [BPC]
        If IPERF = 0 Then
          Call DEBTRANS From GLOCK
          Trbegin [SCL]
          INTR = 1
        Endif
        [F:SCL]OPGNUM = GSZOPGNUM
        [F:SCL]RECTYP = GSZOBJSEL
        [F:SCL]RECNUM = [F:BPC]BPCNUM
        [F:SCL]CLSNUM = ICLSNUM
        ICLSNUM += 1
        Write [SCL]
        If fstat Then
          IPBL = 1
          GMESSAGE = mess(100,141,1) #Erreur création
          GERR = 1
          Rollback
          INTR = 0
          Break
        Else
          If IPERF >= IVALPERF Then
            Commit
            IPERF = 0
            INTR = 0
          Else
            IPERF += 1
          Endif
        Endif
        INBRECSEL += 1
      Next
      If INTR Then
        If !IPBL Then
          Commit
        Endif
      Endif
      Filter [BPC]
  Endcase
  Call TEMPOFF From GESECRAN
Return

################################################################################################################
$CANCELSTEP
Local Integer ITRANSFLG

  If !clalev([F:SEC]) : Local File SELCMG [SEC] : Endif
  If !clalev([F:SCL]) : Local File SELCMGLIS [SCL] : Endif
  If adxlog Then
    ITRANSFLG = 1
  Else
    ITRANSFLG = 0
  Endif
  If !ITRANSFLG Then
    Call DEBTRANS From GLOCK
    Trbegin [SEC]
  Endif
  Delete [SEC] Where [F:SEC]OPGNUM = GSZOPGNUM and [F:SEC]SELTBL <> "CCN"
  If fstat Then
    If ITRANSFLG Then
      GOK = 0
      Call FSTA("SEC") From GLOCK
      Return
    Else
      Rollback
      Return
    Endif
  Endif
  If !ITRANSFLG Then
    Commit
  Endif
  If !ITRANSFLG Then
    Call DEBTRANS From GLOCK
    Trbegin [SCL]
  Endif
  Delete [SCL] Where [F:SCL]OPGNUM = GSZOPGNUM and [F:SCL]RECTYP <> "CCN"
  If fstat Then
    If ITRANSFLG Then
      GOK = 0
      Call FSTA("SCL") From GLOCK
      Return
    Else
      Rollback
      Return
    Endif
  Endif
  If !ITRANSFLG Then
    Commit
  Endif
Return

