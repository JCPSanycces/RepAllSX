#<AdxTL>@(#)9.0.0.0 $Revision$
Call IMPRIME("ATRACE",GFONCTION) From ETAT
End

#---------------#
$ACTION
Return

#----------------------------------------------------------------------------------------------------#
Subprog IMPRIME(NBPAR,PARAMETRES)
Variable Integer NBPAR
Variable Char    PARAMETRES()(1..)

Local Char    PARAM(GDIMFIC) , NOMFIC(GDIMFIC)
Local Char    TMP(250) , SUF(30)
Local Char    MACHINE(GDIMFIC) , APPLI(GLONADS)
Local Integer I , K , ER , ERL , REQUETE , NUMLIG , OPTERR , PAYSAGE , MAXCAR

Local File ATMPTRA [ATT]

Call GETPARAM("__REQUETE",NBPAR,PARAMETRES,PARAM) From ETAT
REQUETE = val(PARAM)
Call SETPARAM("numreq",NBPAR,PARAMETRES,PARAM) From ETAT
Call GETPARAM("erreur",NBPAR,PARAMETRES,PARAM) From ETAT
If PARAM="?????"
 PARAM = "0"
 Call SETPARAM("erreur",NBPAR,PARAMETRES,PARAM) From ETAT
Endif
OPTERR = val(PARAM)
Call GETPARAM("_Orientation",NBPAR,PARAMETRES,PARAM) From ETAT
If PARAM<>"?????"
 PAYSAGE = val(right$(PARAM,2))
Endif
If PAYSAGE
 MAXCAR = 135 : # Pour éditer la suite de la ligne sur une nouvelle ligne (on tronque sur un espace)
Else
 MAXCAR = type(TMP)-10 : # En mode portrait , il n'y a que les 90 premiers caractères qui sont édités
Endif
Call GETPARAM("nomfic",NBPAR,PARAMETRES,PARAM) From ETAT
Call MACHINE(PARAM,MACHINE,APPLI) From ORDSYS
If MACHINE=""
 If instr(1,PARAM,"/") or instr(1,PARAM,"\")
  NOMFIC = PARAM
 Else
  NOMFIC = filpath("TRA",PARAM,"tra")
 Endif
Elsif MACHINE="#"
 If (GBROWS & !GADXLOC)
  PARAM -= ":"-mess(85,150,1) : # Fonction non disponible en mode web
  Call SETPARAM("nomfic",NBPAR,PARAMETRES,PARAM) From ETAT
  End
 Endif
 NOMFIC = PARAM
Else
 NOMFIC = PARAM
Endif

Onerrgo ERFIL
K = filinfo(NOMFIC,0)
Onerrgo
If ER
 PARAM -= ":"-errmes$(abs(ER))
 Call SETPARAM("nomfic",NBPAR,PARAMETRES,PARAM) From ETAT
 End
Elsif K<=0
 PARAM -= ":"-mess(101,100,1) : # Fichier inexistant
 Call SETPARAM("nomfic",NBPAR,PARAMETRES,PARAM) From ETAT
 End
Endif

# Nom du fichier trace
Call SETNAM(NOMFIC,PARAM,SUF) From GOBJTXT
If SUF<>"" : PARAM += "."+SUF : Endif
Call SETPARAM("nomtra",NBPAR,PARAMETRES,PARAM) From ETAT

Openi NOMFIC Using [TRA_]
Iomode adxifs "" Using [TRA_]
Iomode adxirs chr$(10) Using [TRA_]
Iomode adxium GTRAFOR Using [TRA_]

If !adxlog
 Trbegin [ATT]
  Gosub MAJ_TMPTRA
 Commit
Else
 Gosub MAJ_TMPTRA
Endif

Openi Using [TRA_]

End

#----------------#
$MAJ_TMPTRA
Delete [ATT] Where NUMREQ=REQUETE
NUMLIG = 0
fstat = 0
adxium = GUTF8
ERL = 0
Onerrgo ERL
Rdseq TMP Using [TRA_]
If left$(TMP,5)="#<Adx"
 TMP = vireblc(right$(TMP,16),2)
Else
 Seek First Using [TRA_]
 adxium = GTRAFOR
 Rdseq TMP Using [TRA_]
Endif
Onerrgo
While fstat=0
 If !OPTERR | find(left$(TMP,1),"<",">")
  While TMP<>"\"
   If NUMLIG>=99999 : Break 2 : Endif
   NUMLIG += 1
   [F:ATT]NUMREQ = REQUETE
   [F:ATT]LIG    = NUMLIG
   K = MAXCAR
   If right$(TMP,K+1)<>""
    For I=K To 1 Step-1
     If mid$(TMP,I,1)=" " : K = I-1 : Break : Endif
    Next I
   Endif
   [F:ATT]TXT    = left$(TMP,K)
   TMP = right$(TMP,K+2) : # BY 21/12/04 Bug 27340
   If TMP="" : TMP = "\" : Endif
   If dim([F:ATT]CREDAT)>0 : [F:ATT]CREDAT = date$ : Endif
   If dim([F:ATT]CRETIM)>0 : [F:ATT]CRETIM = time  : Endif
   If dim([F:ATT]CREUSR)>0 : [F:ATT]CREUSR = GUSER : Endif
   Write [ATT]
  Wend
 Endif
 Onerrgo ERL
 Rdseq TMP Using [TRA_]
 Onerrgo
Wend
Onerrgo
Return

$ERFIL
ER = errn
Resume

$ERL
ERL = errn
TMP = "Read error"
Resume

