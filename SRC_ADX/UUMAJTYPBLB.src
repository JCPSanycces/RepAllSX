#<AdxTL>@(#)9.0.0.0 $Revision$
Call OUVRE_TRACE("MAJ Xtend AYZ AYT") From LECFIC
Call PATCH(nomap)
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End
##################################################

Subprog PATCH_X3(APPLI)
Value Char APPLI

If filinfo(filpath("FIL","AYTTEST","fde",APPLI),0) <0 or func AFNC.ACTIVDOS(APPLI,"AYT")<1
 End
Endif

Call MAJTYPBLBAYT(APPLI)

End
##################################################

Subprog PATCH(APPLI)
Value Char APPLI

If filinfo(filpath("FIL","AYTTEST","fde",APPLI),0) <0 or func AFNC.ACTIVDOS(APPLI,"AYT")<1
 End
Endif

Call MAJTYPBLBAYT(APPLI)

End

##################################################
## INIT champ typblb AYT
##################################################
Subprog MAJTYPBLBAYT(DOSSIER)
Value Char DOSSIER

Local File =DOSSIER+".AYTTEST"      [AYT]
Local File =DOSSIER+".AYTFRM"       [AYZ]


Trbegin [AYT]
 Call ECR_TRACE(mess(81,125,1)-"AYTTEST:"-time$,0) From GESECRAN
 For [AYT]AYT0
  If dim([F:AYZ]TYPBLB) & [F:AYT]TYPBLB=0
   [F:AYT]TYPBLB=3
   Rewrite [F:AYT]
   If fstat
    Call ERREUR("AYT",2) From DOSDIC
   Endif
  Endif
 Next

 Call ECR_TRACE(mess(81,125,1)-"AYTFRM:"-time$,0) From GESECRAN
 For [AYZ]AYZ0
  If dim([F:AYZ]TYPBLB) & [F:AYZ]TYPBLB=0
   [F:AYZ]TYPBLB=3
   Rewrite [F:AYZ]
   If fstat
    Call ERREUR("AYZ",2) From DOSDIC
   Endif
  Endif
 Next
 Commit

Close Local File [AYT],[AYZ]
End
