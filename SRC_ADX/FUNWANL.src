#<AdxTL>@(#)2.0.0.0 $Revision$

########################################################################
# FUNWANL: Edition des analyses ressources   GPAO  LLC - APR   1999 #
#
# Version modelisée                              MM - Septembre  2003 
# - modèle : traitement standard (GTRAITE)
# - Ecran principal   : MWANL                 
# - Fenêtre : IWANL   
# - Action TRTWANL                                   
########################################################################

$ACTION
#--- Actions liées au traitement standard
Case ACTION
 When "INIT"           :  Gosub INIT
 When "INIT_DIA"       :  Gosub INIT_DIA
 When "EXEC"           :  Gosub EXEC
 When Default
Endcase

Return

#########################################################################
$INIT
Gosub OUVRE

Return

#########################################################################
$INIT_DIA

Raz [M:DIA] 

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
[M:DIA]MFGFCY = GFCY              # FQ 54218
LASTMONTH = addmonth(date$,-1)
[M:DIA]MSTDAT = eomonth(LASTMONTH)

Return

########################################################################
$OUVRE
Local Integer  OK
Local Char     TIT(50)
Local Date    LASTMONTH 
Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)

Gosub CHARG_PARAM

#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
If clalev([F:TWD])  = 0 : Local File TABWEEDIA   [TWD]  : Endif
If clalev([F:MWS])  = 0 : Local File WORKSTATIO  [MWS]  : Endif
If clalev([F:TWC])  = 0 : Local File TABWRKCTR   [TWC]  : Endif
If clalev([F:WSA])  = 0 : Local File WSTANL      [WSA]  : Endif
If clalev([F:MFG])  = 0 : Local File MFGHEAD     [MFG]  : Endif
If clalev([F:MFI])  = 0 : Local File MFGITM      [MFI]  : Endif
If clalev([F:MFM])  = 0 : Local File MFGMAT      [MFM]  : Endif
If clalev([F:MFO])  = 0 : Local File MFGOPE      [MFO]  : Endif
If clalev([F:MFP])  = 0 : Local File MFGPRN      [MFP]  : Endif
If clalev([F:OPS])  = 0 : Local File OPERATIONS  [OPS]  : Endif
If clalev([F:SCH])  = 0 : Local File SCHEDULING  [SCH]  : Endif
If clalev([F:WKL])  = 0 : Local File WORKLOAD    [WKL]  : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif
If clalev([F:ITV])  = 0 : Local File ITMMVT      [ITV]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT  [ITF]  : Endif
If clalev([F:PJA])  = 0 : Local File PARJAL      [PJA]  : Endif
If clalev([F:MFA])  = 0 : Local File MFGANL      [MFA]  : Endif

# titre de la boîte 
TIT = mess(151,195,1)


Return 

######################################################################## 
$CHARG_PARAM 
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
Return 

######################################################################## 
# Edition                                                             #
$EXEC

# nouvelle analyse
If [M:DIA]CLCANA = 2 
    Call TEMPON(mess(152,195,1)) From GESECRAN
    Call WSTANL([M:DIA]MFGFCY,[M:DIA]STRANA,[M:DIA]MSTDAT) From ANLLIB 
    Call TEMPOFF From GESECRAN
Endif

# Appel édition
TBPAR(1)="wcrfcydeb"     : TBVAL(1) = [M:DIA]MFGFCY
TBPAR(2)="wcrfcyfin"     : TBVAL(2) = [M:DIA]MFGFCY
TBPAR(3)="wcrdeb"        : TBVAL(3) = [M:DIA]WCRDEB
TBPAR(4)="wcrfin"    
If [M:DIA]WCRFIN <> ""  
                           TBVAL(4) = [M:DIA]WCRFIN
Else
                           TBVAL(4) = "ZZZZZ"
Endif
TBPAR(5)="wstdeb"        : TBVAL(5) = [M:DIA]WSTDEB
TBPAR(6)="wstfin"    
If [M:DIA]WSTFIN <> ""  
                           TBVAL(6) = [M:DIA]WSTFIN
Else
                           TBVAL(6) = "ZZZZZZZZ"
Endif
TBPAR(7)="enddat"        : TBVAL(7) = gdat$([M:DIA]MSTDAT)
Case [M:DIA]PROANA
    When 1:    Call ETAT("UTIRESS","",TBPAR,TBVAL)  From ETAT
    When 2:    Call ETAT("RENDRESS","",TBPAR,TBVAL) From ETAT
Endcase
#
Return


