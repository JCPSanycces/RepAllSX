#<AdxTL>@(#)12.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
Call EXEC(NBPAR,PARAMETRE)
End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Local Char    CRITERE1(255), CRITERE2(255), PARAM(30), VALEUR(30), ETAT(10)
Local Char    CPTDEB(10), CPTFIN(10), COLDEB(3), COLFIN(3)
Local Integer NUMREQ, WNUMLIG

If clalev([F:RUB])=0  : Local File RUBRIQUE [RUB] : Endif
If clalev([F:ARM])=0  : Local File AREPORTM [ARM] : Endif


CRITERE1  = "1=1"
CRITERE2  = "1=1"

For I=0 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "__REQUETE" : [L]NUMREQ = val([L]VALEUR)
   When "X3ETA"     : [L]ETAT   = [L]VALEUR
   When "coldeb"    : If vireblc([L]VALEUR,4)<>""
                       [L]COLDEB = [L]VALEUR
                       [L]CRITERE1 -= ' & ([F:RUB]SAC(0)>="'+[L]VALEUR+'"'
                       [L]CRITERE1 -= ' | [F:RUB]SAC(1)>="'+[L]VALEUR+'"'
                       [L]CRITERE1 -= ' | [F:RUB]SAC(2)>="'+[L]VALEUR+'"'
                       [L]CRITERE1 -= ' | [F:RUB]SAC(3)>="'+[L]VALEUR+'")'
                      Endif
   When "colfin"    : If [L]VALEUR<>""
                       [L]COLFIN = [L]VALEUR
                       [L]CRITERE1 -= ' & ([F:RUB]SAC(0)<="'+[L]VALEUR+'"'
                       [L]CRITERE1 -= ' | [F:RUB]SAC(1)<="'+[L]VALEUR+'"'
                       [L]CRITERE1 -= ' | [F:RUB]SAC(2)<="'+[L]VALEUR+'"'
                       [L]CRITERE1 -= ' | [F:RUB]SAC(3)<="'+[L]VALEUR+'")'
                      Endif
   When "comptedeb" : If vireblc([L]VALEUR,4)<>""
                       [L]CPTDEB = [L]VALEUR
                       [L]CRITERE2 -= ' & ([F:RUB]ACC(0)>="'+[L]VALEUR+'"'
                       [L]CRITERE2 -= ' | [F:RUB]ACC(1)>="'+[L]VALEUR+'"'
                       [L]CRITERE2 -= ' | [F:RUB]ACC(2)>="'+[L]VALEUR+'"'
                       [L]CRITERE2 -= ' | [F:RUB]ACC(3)>="'+[L]VALEUR+'")'
                      Endif
   When "comptefin"   : If [L]VALEUR<>""
                       [L]CPTFIN = [L]VALEUR
                       [L]CRITERE2 -= ' & ([F:RUB]ACC(0)<="'+[L]VALEUR+'"'
                       [L]CRITERE2 -= ' | [F:RUB]ACC(1)<="'+[L]VALEUR+'"'
                       [L]CRITERE2 -= ' | [F:RUB]ACC(2)<="'+[L]VALEUR+'"'
                       [L]CRITERE2 -= ' | [F:RUB]ACC(3)<="'+[L]VALEUR+'")'
                      Endif

  Endcase
 Endif
Next

# Affectation du no de requête
PARAM = num$([L]NUMREQ)
Call SETPARAM("numedt",NBPAR,PARAMETRE,PARAM) From ETAT

Call DEBTRANS From GLOCK
Gosub TR1
Gosub TR2
End

$TR1
GOK = 1
Trbegin [ARM]
 Delete [ARM] Where RPTCOD=[L]ETAT & USR=GUSER & CREDAT<date$
Commit
Return

$TR2
Trbegin [ARM]
Filter [RUB] Where TYPRUB<>5 & TMPCAL<>2 & (DEC=0 | DEC>=GARODEV) & NBRACC>0 & LEG=GCURLEG &
&                  evalue(CRITERE1) & evalue(CRITERE2)
For [RUB]
 For I=0 To [F:RUB]NBRACC
  If [F:RUB]ACC(I)<>"" & ([L]CPTDEB="" | [F:RUB]ACC(I)>=[L]CPTDEB) &
&                        ([L]CPTFIN="" | [F:RUB]ACC(I)<=[L]CPTFIN) &
&                        ([L]COLDEB="" | [F:RUB]SAC(I)>=[L]COLDEB) &
&                        ([L]COLFIN="" | [F:RUB]SAC(I)<=[L]COLFIN)
   WNUMLIG +=1
   [F:ARM]USR     = GUSER
   [F:ARM]RPTCOD  = [L]ETAT
   [F:ARM]NUMREQ  = [L]NUMREQ
   [F:ARM]NUMLIG  = [L]WNUMLIG
   [F:ARM]CLEA1   = [F:RUB]ACC(I)
   [F:ARM]CLEN1   = [F:RUB]ROW
   [F:ARM]CREDAT  = date$
   Write [F:ARM]
   If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Break : Endif
  Endif
 Next I
Next
Filter [RUB]
If GOK=0 : Rollback : Return : Endif
Commit
Return
