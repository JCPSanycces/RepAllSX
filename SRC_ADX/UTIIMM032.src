################################################################################
#    TRAITEMENT DE MISE A JOUR DEPREC (FQ73777)
#    MWA
#    Ecran de lancement :UTIMM032
#    Création le : 23/02/2011
#    Modification le : --/--/----
#-------------------------------------------------------------------------------
#    Modification 
#    XXX - XX.XX.XXXX FQXXXXX : XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
################################################################################
# 
 
#

######################################################################
Local Char PARAM(10)(1..2), VALEUR(10) 
Call TRAITE_CHAR(VALEUR,PARAM,"","UTIIMM032","UTIIMM032",3,"") From GTRAITE
End


$ACTION
  #Infbox "UTIMM032 /"-ACTION
  Case ACTION
    When "EXEC" : Gosub EXEC
  Endcase
Return

$EXEC
  Gosub TR_UTIIMM032
Return


########################################
#### Corps de la moulinette - début ####
########################################

$TR_UTIIMM032

  Local Char CPY_FILTER(255)
  Local Char CNX_FILTER(255)
  
  # Filtre société
  If [M:UT32]FLGALLCPY = G_OUI
    CPY_FILTER = "1=1"
  Else
    CPY_FILTER = "CPY='"+[M:UT32]CPY+"'"
  Endif

  # Filtre contexte
  If [M:UT32]FLGALLCNX = G_OUI
    CNX_FILTER = "1=1"
  Else
    CNX_FILTER = "CNX="+num$([M:UT32]CNX)
  Endif

  If !clalev([F:ADW])   : Local File ADOVAL    [ADW] : Endif
  If !clalev([F:ADP])   : Local File ADOPAR    [ADP] : Endif
  If !clalev([F:CPY])   : Local File COMPANY   [CPY] : Endif
  If !clalev([F:CNX])   : Local File CONTEXT   [CNX] : Endif
  If !clalev([F:FIY])   : Local File FISCYEAR  [FIY] : Endif
  If !clalev([F:FAS])   : Local File FXDASSETS [FAS] : Endif
  If !clalev([F:DEP])   : Local File DEPREC    [DEP] : Endif        

  Call OUVRE_TRACE("UTIIMM032: DEPREC update") From LECFIC
   
  Call ECR_TRACE("UTIIMM032: Process Start  ",0) From GESECRAN
  Trbegin [DEP]
  
  Local Integer LPRVSITUPD
  Local Char    LPARAM
  Local Integer I_PLN  

  For [F:CPY] Where evalue(CPY_FILTER)   : # Pour chaque société du dossier
  
    Call TEMPON("Company :"+[F:CPY]CPY) From GESECRAN
    Call PARAM([F:CPY]CPY,"PRVSITUPD",LPARAM) From ADOVAL
    LPRVSITUPD = val(LPARAM)
    # CFF & GLE préfèrent ne pas tester cette condition
    #If (LPRVSITUPD = 1) Then : # Si la remise en cause de la situation antérieure est interdite
      For [F:CNX] Where CPY=[F:CPY]CPY and evalue(CNX_FILTER)
        Filter [FIY] Where CPY=[F:CPY]CPY & CNX=[F:CNX]CNX & STAFIY=2
        Read [FIY]FIY0 Last : Filter [FIY]
        For [F:FAS] Where CPY=[F:CPY]CPY  
          If ([F:FAS]AASIPTDAT <> [0/0/0] & [F:FAS]AASIPTDAT >= [F:FIY]DATSTRFIY &  [F:FAS]AASIPTDAT <= [F:FIY]DATENDFIY ) Then
            # Si la date de comptabilisation se situe dans l'exercice courant         
            For [F:DEP] Where ( CPY=[F:CPY]CPY and CNX=[F:CNX]CNX and AASREF = [F:FAS]AASREF and DPM <> "SA" and
&             FIYENDDAT=[F:FIY]DATENDFIY and PERENDDAT = [F:FIY]DATENDPER([F:FIY]INDCURPER-1) )
              If ( [F:DEP]STRDPRDAT < [F:FIY]DATSTRFIY & [F:DEP]DPRCUM = 0 & [F:DEP]DPRCUMFLG = 2 & [F:DEP]DPRBAS <> 0 &
&                  [F:DEP]MTCDPEDAT=[0/0/0] and [F:DEP]MTCTIADAT=[0/0/0] & [F:DEP]MTCTIATYP=0 & [F:DEP]MTCDEVADJ=0 ) Then
                  [F:DEP]MTCDPEDAT=[F:DEP]STRDPRDAT
                  [F:DEP]MTCTIADAT=[F:DEP]STRDPRDAT
                  [F:DEP]MTCTIATYP=1                :# Effet "Début amortissement"
                  [F:DEP]MTCDEVADJ=5                :# Rattrapage "Début de période"            
                  Rewrite [F:DEP] 
                  If fstat
                    GOK=0 
                    Call ECR_TRACE("UTIIMM032:"-[F:CPY]CPY-" "-[F:DEP]AASREF-" "-mess([F:DEP]DPRPLN,3101,1)-num$(fstat),1) From GESECRAN
                  Else
                    Call ECR_TRACE("UTIIMM032:"-[F:CPY]CPY-" "-[F:DEP]AASREF-" "-mess([F:DEP]DPRPLN,3101,1)-"UPDATED",0) From GESECRAN
                  Endif
              Endif
            Next
          Endif                 
        Next
      Next
    #Endif
    Call TEMPOFF     From GESECRAN
  Next

  If [M:UT32]FLGSIM = G_OUI or !GOK Then
    Gosub AB_UTIIMM032
  Else
    Commit
  Endif
  
  If ([M:UT32]FLGSIM = G_OUI) Then
    Call ECR_TRACE("\"+"UTIIMM032: Process Canceled ",1) From GESECRAN
  Else
  Call ECR_TRACE("\"+"UTIIMM032: Process End ",0) From GESECRAN
  Endif
      
  If clalev([F:ADW]) : Close Local File [ADW] : Endif
  If clalev([F:ADP]) : Close Local File [ADP] : Endif
  If clalev([F:CPY]) : Close Local File [CPY] : Endif
  If clalev([F:CNX]) : Close Local File [CNX] : Endif
  If clalev([F:FIY]) : Close Local File [FIY] : Endif
  If clalev([F:FAS]) : Close Local File [FAS] : Endif
  If clalev([F:DEP]) : Close Local File [DEP] : Endif
  

  
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
  
      
Return

$AB_UTIIMM032
 Rollback
Return

########################################
#### Corps de la moulinette - fin ######
########################################

################################################################################
# ACTIONS CHAMPS
################################################################################
Subprog AV_CPY(VALEUR)
Variable Char    VALEUR()
  If [M:UT32]FLGALLCPY = G_OUI
    VALEUR = ""
    Grizo [M:UT32]CPY
  Else
    Actzo [M:UT32]CPY
  Endif
End

Subprog AV_CNX(VALEUR)
Variable Integer VALEUR
  If [M:UT32]FLGALLCNX = G_OUI
    Grizo [M:UT32]CNX
  Else
    Actzo [M:UT32]CNX
  Endif
End

Subprog AS_CNX(VALEUR)
Variable Integer VALEUR
  If [M:UT32]CPY <> ""
    Local Shortint N_CNX
    If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif
    For N_CNX = 1 To G300MAX
      Look [F:CNX]CNX0=[M:UT32]CPY;N_CNX
      If fstat
        GMENLOC(N_CNX)=1
      Endif
    Next
  Endif
End


