################################################################################
# Cette fonction convertit le type d'assurance Abel Entreprise en type d'assurance ABX3
# Paramètre : 1 - type d'assurance Abel Entreprise
Funprog CONV_ISRTYP_AE(ISRTYP_AE)
Value Char    ISRTYP_AE
Local Integer RNUM
  #0 Non assuré
  #1 Assurance autre
  #2 Assurance bâtiment
  Case ISRTYP_AE
    When "","0"  : RNUM = 1
    When "1"     : RNUM = 2
    When "2"     : RNUM = 3
  Endcase
End RNUM

################################################################################
# Cette fonction convertit la nature Abel Entreprise en type de détention ABX3
# Paramètre : 1 - nature Abel Entreprise
Funprog CONV_OWNTYP_AE(OWNTYP_AE)
Value Char    OWNTYP_AE
Local Integer RNUM
  #1 Bien réel
  #2 Bien fictif
  #3 Bien en location
  #4 Bien en leasing
  #5 Bien sorti exercice antérieur
  #6 Bian annulé
  #7 Facture
  #8 Bien en-cours
  #9 Bien prévisionnel
  #A Fin location dans exercice antérieur
  #B Fin crédit-bail dans exercie antérieur
  Case OWNTYP_AE
    When "1","2","5","8"  : RNUM = 1
    When "3","A"          : RNUM = 2
    When "4","B"          : RNUM = 3
    When "6"              : RNUM = 7
    When "9"              : RNUM = 4
    When Default          : RNUM = 0
  Endcase
End RNUM

