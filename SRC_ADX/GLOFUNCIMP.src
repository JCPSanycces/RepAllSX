################################################################################
# Vérification des valeurs paramètres AEAXE1 à AEAXE4, AESCT1 et AESCT2
Subprog VERF_PARAM(PARAM, VALINT, RET)
Value Char       PARAM
Value Char       VALINT
Variable Integer RET

  Case PARAM
    When "AEAXE1", "AEAXE2", "AEAXE3", "AEAXE4"
      If VALINT <> ""
        Local Mask FASPARCPY [FPC]

        If [M:ADW1]CMP <> ""
          Call LOAD_FASPARCPY([M:ADW1]CMP,"",G_OUI,RET) From GLOFCYCPY
          If !find(VALINT,[M:FPC]DIE)
            Local Integer K
            RET = 0
            GMESSAGE = mess(12,GML_MSGMIS,1)
            K = instr(1,GMESSAGE,"#")
            If K : GMESSAGE = left$(GMESSAGE,K-1)+[M:ADW1]CMP+right$(GMESSAGE,K+1) : Endif
          Endif
        Endif

        Close Local Mask [FPC]
      Endif

    When "AESCT1", "AESCT2"
      If VALINT <> ""
        Local Mask FASPARCPY [FPC]

        If [M:ADW1]CMP <> ""
          Call LOAD_FASPARCPY([M:ADW1]CMP,"",G_OUI,RET) From GLOFCYCPY
          If (!find(VALINT,[M:FPC]DIE))
            Local Integer K
            RET = 0
            GMESSAGE = mess(12,GML_MSGMIS,1)
            K = instr(1,GMESSAGE,"#")
            If K : GMESSAGE = left$(GMESSAGE,K-1)+[M:ADW1]CMP+right$(GMESSAGE,K+1) : Endif
          Elsif instr(1,[M:FPC]DIECOA(find(VALINT,[M:FPC]DIE)-1),mess([M:FPC]IASLEDTYP,2644,1))=0
            Local Integer K
            RET = 0
            GMESSAGE = mess(13,GML_MSGMIS,1)
          Endif
        Endif

        Close Local Mask [FPC]
      Endif

    When Default
  Endcase
End

#** FQ85865
#*
#*
#* @param POSTE de liasse AE à convertir en X3
#*!
Funprog CONV_POSTEFLUX_AE(POSTE)
Value Char    POSTE
Local Integer RNUM

  Case POSTE
    When "14"      : RNUM = 40
    When "15"      : RNUM = 42
    When "16"      : RNUM = 43
    When "17"      : RNUM = 41
    When "0"       : RNUM = 99
    When Default
      If POSTE = ""
        RNUM = 99
      Else
        RNUM = val(POSTE)
      Endif
  Endcase
End RNUM

# FQ90641
#**
#* Vérifie que la version contenu dans le fichier est compatible avec le traitement d'import Abel Entreprise
#*
#* La version est de type A.B.C.D.E, A B C D et E sont des nombres. Le contrôle doit se faire sur D.
#*
#* Exemple : la version 5.3.1.2.14 est correcte si le niveau attendu est 2, incorrecte sinon
#*
#* @param VERSION   : Chaîne contenant la version lue dans le fichier à importer
#* @param NIVEAU_AE : Chaîne contenant le niveau attendu. Il faut donc vérifier que cette chaîne est égale à D
#*!
Funprog CTRL_VERSION(VERSION_AE,EXPECTLEVEL)
Value Char VERSION_AE  : # version
Value Char EXPECTLEVEL : # niveau attendu

Local Integer VERSION_OK : VERSION_OK = 1
Local Integer I, NB_PT : NB_PT = 0

Local Char VERSION(len(VERSION_AE)) : VERSION = vireblc(VERSION_AE,1)
Local Char LEVEL(3) : LEVEL = ""
Local Char CALU(1)

  # Vérification de la conformitée de la chaine : des chiffres et des points uniquement
  For I=1 To len(VERSION)
    CALU = mid$(VERSION,I,1)
    If !instr(1,"0123456789.",CALU) : VERSION_OK = 0 : Break : Endif
    If CALU='.'  : NB_PT += 1 : Endif
    If CALU<>'.' and NB_PT = 3 : LEVEL += CALU : Endif
  Next

  # Il doit y avoir exactement quatre points dans la version
  If NB_PT <> 4 : VERSION_OK = 0 : Endif

  # Contrôle du niveau par rapport au traitement d'extraction d'Abel Entreprise.
  If LEVEL <> EXPECTLEVEL : VERSION_OK = 0 : Endif

End VERSION_OK

