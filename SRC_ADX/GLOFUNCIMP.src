##################################################
# Création automatique codes en tables diverses
# La classe [F:ADI] doit être ouverte
#
Subprog TRT_TABDIV(ADI_TAB, ADI_COD, ADI_DES, ADI_A1, ADI_A2, ADI_N1, ADI_N2)
Value Integer ADI_TAB
Value Char    ADI_COD
Value Char    ADI_DES
Value Char    ADI_A1
Value Char    ADI_A2
Value Decimal ADI_N1
Value Decimal ADI_N2

Local Char TEXTE(80)
  GOK=1
  If !clalev([F:ADI]) : Local File ATABDIV [F:ADI] : Endif # Ajout table diverses
  If (ADI_TAB=0) or (ADI_COD="") Then : End : Endif : # Pas de création si le code n'est pas renseigné

  Look [F:ADI]CODE=ADI_TAB;ADI_COD
  If fstat
    Raz [F:ADI]
    [F:ADI]NUMTAB = ADI_TAB
    [F:ADI]CODE   = ADI_COD
    [F:ADI]A1     = ADI_A1
    [F:ADI]A2     = ADI_A2
    [F:ADI]N1     = ADI_N1
    [F:ADI]N2     = ADI_N2
    [F:ADI]CREDAT = date$
    [F:ADI]CREUSR = GUSER
    Write [ADI]
    If fstat
    # Donnée de base créée automatiquement : Table diverse n CODE LNGDES Erreur X
      Call ECR_TRACE(mess(46,GML_MSGLOF,1)-TEXTE-ADI_COD-ADI_DES-mess(7,21,1)-num$(fstat),1) From GESECRAN
      GOK=0
      End
    Endif
    If ADI_DES = ""
      ADI_DES=ADI_COD
    Endif
    Call MAJTEXTRA(ADI_DES,"ATABDIV","LNGDES",num$(ADI_TAB),ADI_COD) From ATEXTRA
    Call MAJTEXTRA(ADI_COD,"ATABDIV","SHODES",num$(ADI_TAB),ADI_COD) From ATEXTRA
    Call LECTEXTRA(TEXTE,"ATABTAB","LNGDES",num$(ADI_TAB),"") From ATEXTRA
    # Donnée de base créée automatiquement : Table diverse n CODE LNGDES
    Call ECR_TRACE(mess(46,GML_MSGLOF,1)-TEXTE-ADI_COD-ADI_DES,0) From GESECRAN
  Endif
End

#**
#* Creation of a Business Partner
#*
#* @param BPR     : Partner code
#* @param BPRNAM  : Partner designation
#*!
Subprog CRE_BPR(BPR, BPRNAM)
Value Char BPR
Value Char BPRNAM

  If BPR = "" : End : Endif

  Look [F:BPR]BPR0=BPR
  If fstat
    Raz [F:BPR]
    [F:BPR]BPRNUM=BPR
    If BPRNAM = ""
      [F:BPR]BPRNAM="XXX"-BPR-"XXX"
    Else
      [F:BPR]BPRNAM=BPRNAM
    Endif
    [F:BPR]CUR=GSYSCUR
    [F:BPR]BPCFLG=G_NON
    [F:BPR]BPSFLG=G_OUI
    [F:BPR]ENAFLG=G_OUI
    [F:BPR]EXPNUM=[C]EXPORT
    [F:BPR]CREDAT=date$
    [F:BPR]CREUSR=GUSER
    Write [BPR]
    If fstat
      # Donnée de base créée automatiquement : Fournisseur BPRNUM BPRNAM Erreur X
      Call ECR_TRACE(mess(46,GML_MSGLOF,1)-mess(47,GML_MSGLOF,1)-[F:BPR]BPRNUM-[F:BPR]BPRNAM-mess(7,21,1)-num$(fstat),1) From GESECRAN
    Else
      # Donnée de base créée automatiquement : Fournisseur BPRNUM BPRNAM
      Call ECR_TRACE(mess(46,GML_MSGLOF,1)-mess(47,GML_MSGLOF,1)-[F:BPR]BPRNUM-[F:BPR]BPRNAM,0) From GESECRAN
    Endif
  Endif
End
#**
#* Création BPS
#*
#* @param BPS     : Partner code
#* @param BPSNAM  : Partner designation
#*!
Subprog CRE_BPS(BPS, BPSNAM)
Value Char BPS
Value Char BPSNAM

  If !clalev([F:BPS]) : Local File BPSUPPLIER [BPS] : Endif
  If BPS = "" : End : Endif

  Look [F:BPS]BPS0=BPS
  If fstat
    Raz [F:BPS]
    [F:BPS]BPSNUM=BPS
    If BPSNAM = ""
      [F:BPS]BPSNAM="XXX"-BPS-"XXX"
    Else
      [F:BPS]BPSNAM=BPSNAM
    Endif
    [F:BPS]CUR=GSYSCUR
    [F:BPS]EXPNUM=[C]EXPORT
    [F:BPS]ENAFLG=G_OUI
    [F:BPS]CREDAT=date$
    [F:BPS]CREUSR=GUSER
    Write [F:BPS]
    If fstat
      # Donnée de base créée automatiquement : Fournisseur BPSNUM BPSNAM Erreur X
      Call ECR_TRACE(mess(46,GML_MSGLOF,1)-mess(47,GML_MSGLOF,1)-[F:BPS]BPSNUM-[F:BPS]BPSNAM-mess(7,21,1)-num$(fstat),1) From GESECRAN
    Else
      # Donnée de base créée automatiquement : Fournisseur BPSNUM BPSNAM
      Call ECR_TRACE(mess(46,GML_MSGLOF,1)-mess(47,GML_MSGLOF,1)-[F:BPS]BPSNUM-[F:BPS]BPSNAM,0) From GESECRAN
    Endif
  Endif
End



####################################################################
# Création automatique de l'article
# La classe [F:ITM] doit être ouverte
#
#*!
Subprog CRE_ITM(ITMREF,ITMDES1)
Value Char ITMREF
Value Char ITMDES1

  If ITMREF = "" : End : Endif

  Look [F:ITM]ITM0=ITMREF
  If fstat
    Raz [F:ITM]
    [F:ITM]ITMREF=ITMREF
    If ITMDES1 = ""
      [F:ITM]ITMDES1="XXX"-ITMREF-"XXX"
    Else
      [F:ITM]ITMDES1=ITMDES1
    Endif
    [F:ITM]STU=GDEFUOM
    [F:ITM]EXPNUM=[C]EXPORT
    [F:ITM]CREDAT=date$
    [F:ITM]CREUSR=GUSER
    [F:ITM]FLGFAS=G_OUI
    Write [ITM]
    If fstat
      # Donnée de base créée automatiquement : Article ITMREF ITMDES1 Erreur X
      Call ECR_TRACE(mess(46,GML_MSGLOF,1)-mess(48,GML_MSGLOF,1)-[F:ITM]ITMREF-[F:ITM]ITMDES1-mess(7,21,1)-num$(fstat),1) From GESECRAN
    Else
      # Donnée de base créée automatiquement : Article ITMREF ITMDES1
      Call ECR_TRACE(mess(46,GML_MSGLOF,1)-mess(48,GML_MSGLOF,1)-[F:ITM]ITMREF-[F:ITM]ITMDES1,0) From GESECRAN
      Call MAJTEXTRA([F:ITM]ITMDES1,"ITMMASTER","DES1AXX",[F:ITM]ITMREF,"") From ATEXTRA
    Endif
  Endif
End

####################################################################
# Création automatique de la section analytique
# La classe [F:CCE] doit être ouverte
#
Subprog CRE_CCE(DIE,CCE,DES)
Value Char    DIE
Value Char    CCE
Value Char    DES

  If CCE = "" : End : Endif

  Look [F:CCE]CCE0=DIE;CCE
  If fstat
    Raz [F:CCE]
    [F:CCE]DIE=DIE
    [F:CCE]CCE=CCE
    If DES = ""
      [F:CCE]DES="XXX"-CCE-"XXX"
    Else
      [F:CCE]DES=DES
    Endif
    [F:CCE]DESSHO=[F:CCE]CCE
    [F:CCE]EXPNUM=[C]EXPORT
    [F:CCE]BUDTRK=G_OUI
    [F:CCE]ENAFLG=G_OUI
    [F:CCE]CREDAT=date$
    [F:CCE]CREUSR=GUSER
    [F:CCE]IPT   =G_OUI : # FQ?????
    Write [CCE]
    If fstat
      # Donnée de base créée automatiquement : Axe n CCE DES Erreur X
      Call ECR_TRACE(mess(46,GML_MSGLOF,1)-[F:CCE]DIE-[F:CCE]CCE-[F:CCE]DES-mess(7,21,1)-num$(fstat),1) From GESECRAN
    Else
      # Donnée de base créée automatiquement : Axe n CCE DES
      Call ECR_TRACE(mess(46,GML_MSGLOF,1)-[F:CCE]DIE-[F:CCE]CCE-[F:CCE]DES,0) From GESECRAN
      Call MAJTEXTRA([F:CCE]DES,"CACCE","DESTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
      Call MAJTEXTRA([F:CCE]DESSHO,"CACCE","SHOTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
    Endif
  Endif
End

#**
#* Location creation
#*
#* @param PLCTCOD : Location code
#* @param PLCTDES : Location designation
#* @param PBUICOD : Building code
#* @param PFCY    : Site
#* @param PFLOOR  : Floor
#*!
Subprog CRE_LCT(PLCTCOD, PLCTDES, PBUICOD, PFCY, PFLOOR)
Value Char PLCTCOD : # Location code
Value Char PLCTDES : # Location designation
Value Char PBUICOD : # Building code
Value Char PFCY    : # Site
Value Char PFLOOR  : # Floor

  Local Integer  RET
  Local Instance LCT Using C_PHYLCT
  LCT = NewInstance C_PHYLCT AllocGroup null

  [L]RET = fmet LCT.AREAD(PLCTCOD)
  If [L]RET <> [V]CST_AOK #and LCT.FCY <> PFCY
    [L]RET = fmet LCT.AINIT()

    LCT.LCTCOD = PLCTCOD
    LCT.LCTDES = PLCTDES
    LCT.BUICOD = PBUICOD
    LCT.FCY    = PFCY
    LCT.FLOOR  = PFLOOR

    [L]RET = fmet LCT.AINSERT()
    If [L]RET = [V]CST_AOK
      Call ECR_TRACE(mess(46,GML_MSGLOF,1)-mess(122,GML_MSGINV,1)-LCT.LCTCOD-LCT.LCTDES,0) From GESECRAN
    Else
      Call WRITE_ERROR_STACK_CLASSIC(LCT, [V]CST_AERROR) From FXDFCT_SYRA
    Endif
  Endif
# Issue cfavre - 2015-08-04 by CFF : Forget FreeGroup syntax
  FreeGroup LCT
End

#**
#* Building creation
#*
#* @param PBUICOD : Building code
#* @param PBUIDES : Building designation
#*!
Subprog CRE_BUI(PBUICOD, PBUIDES)
Value Char PBUICOD : # Building code
Value Char PBUIDES : # Building designation

  Local Integer  RET
  Local Instance BUI Using C_PHYBUI
  BUI = NewInstance C_PHYBUI AllocGroup null

  [L]RET = fmet BUI.AREAD(PBUICOD)
  If [L]RET <> [V]CST_AOK
    [L]RET = fmet BUI.AINIT()

    BUI.BUICOD = PBUICOD
    BUI.BUIDES = PBUIDES

    [L]RET = fmet BUI.AINSERT()
    If [L]RET = [V]CST_AOK
      Call ECR_TRACE(mess(46,GML_MSGLOF,1)-mess(7,943,1)-BUI.BUICOD-BUI.BUIDES,0) From GESECRAN
    Else
      Call WRITE_ERROR_STACK_CLASSIC(BUI, [V]CST_AERROR) From FXDFCT_SYRA
    Endif
  Endif
# Issue cfavre - 2015-08-04 by CFF : Forget FreeGroup syntax
  FreeGroup BUI
End

####################################################################
# Création automatique du compte comptable
# La classe [F:GAC] doit être ouverte
#
Subprog CRE_ACC(COA,ACC,DES,ACN)
Value Char    COA
Value Char    ACC
Value Char    DES
Value Integer ACN

  If ACC="" : End : Endif

  Look [F:GAC]GAC0=COA;ACC

  If fstat
    Raz [F:GAC]
    [F:GAC]COA = COA
    [F:GAC]ACC = ACC
    If DES <> ""
      [F:GAC]DES = DES
    Else
      [F:GAC]DES = ACC
    Endif
    [F:GAC]GACACN = ACN

    If ACN = 3
      [F:GAC]CLSCOD    = "6"
      [F:GAC]FLGABL    = G_NON
      [F:GAC]FLGEXPCRE = G_NON
    Else
      # Compte d'immobilisation
      [F:GAC]CLSCOD    = "2"
      [F:GAC]FLGABL    = G_OUI
      [F:GAC]FLGEXPCRE = G_OUI
    Endif

    [F:GAC]ENAFLG = G_OUI

    [F:GAC]EXPNUM=[C]EXPORT
    [F:GAC]CREDAT=date$
    [F:GAC]CREUSR=GUSER

    Write [GAC]
    If fstat
      Call ECR_TRACE(mess(46,GML_MSGLOF,1)-mess(216,GML_MSGFAS,1)-[F:GAC]COA-[F:GAC]ACC-[F:GAC]DES-mess(7,21,1)-num$(fstat),1) From GESECRAN
    Else
      # Donnée de base créée automatiquement : Compte comptable ACC DES
      Call ECR_TRACE(mess(46,GML_MSGLOF,1)-mess(216,GML_MSGFAS,1)-[F:GAC]COA-[F:GAC]ACC-[F:GAC]DES,0) From GESECRAN
      Call MAJTEXTRA([F:GAC]DES,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
    Endif
  Endif
End

####################################################################
# Création automatique du code comptable
# La classe [F:CAC] doit être ouverte
#
Subprog CRE_CAC(COA,TYP,ACCCOD,DES,GAC)
Value Char    COA
Value Integer TYP
Value Char    ACCCOD
Value Char    DES
Value Char    GAC

  If ACCCOD="" or TYP=0 : End : Endif

  Look [F:CAC]CAC0=TYP;ACCCOD;COA

  If fstat
    Raz [F:CAC]
    [F:CAC]TYP     = TYP
    [F:CAC]COA     = COA
    [F:CAC]ACCCOD  = ACCCOD
    [F:CAC]ACC(0)  = GAC
    If DES <> ""
      [F:CAC]DES = DES
    Else
      [F:CAC]DES = ACCCOD
    Endif

    [F:CAC]EXPNUM=[C]EXPORT
    [F:CAC]CREDAT=date$
    [F:CAC]CREUSR=GUSER

    Write [CAC]
    If fstat
      Call ECR_TRACE(mess(46,GML_MSGLOF,1)-mess(215,GML_MSGFAS,1)-num$([F:CAC]TYP)-[F:CAC]COA-[F:CAC]ACCCOD-mess(7,21,1)-num$(fstat),1) From GESECRAN
    Else
      # Donnée de base créée automatiquement : Compte comptable ACC DES
      Call ECR_TRACE(mess(46,GML_MSGLOF,1)-mess(215,GML_MSGFAS,1)-num$([F:CAC]TYP)-[F:CAC]COA-[F:CAC]ACCCOD,0) From GESECRAN
      Call MAJTEXTRA([F:CAC]DES,"GACCCODE","DESTRA",num$([F:CAC]TYP),[F:CAC]ACCCOD) From ATEXTRA
      Call MAJTEXTRA([F:CAC]DES,"GACCCODE","SHOTRA",num$([F:CAC]TYP),[F:CAC]ACCCOD) From ATEXTRA
    Endif
  Endif
End

####################################################################
# Création automatique du secteur d'activité
# La classe [F:SEA] doit être ouverte
#
Subprog CRE_SAC(CPY,SAC,DES,TXPRO,TXDEF,FLGTXDEF,ASJCOE)
Value Char    CPY
Value Char    SAC
Value Char    DES
Value Decimal TXPRO
Value Decimal TXDEF
Value Integer FLGTXDEF
Value Decimal ASJCOE

  If SAC="" : End : Endif

  Look [F:SEA]SEA0=CPY;SAC

  If fstat
    Raz [F:SEA]
    [F:SEA]CPY = CPY
    [F:SEA]SAC = SAC
    If DES <> ""
      [F:SEA]SACDES = DES
    Else
      [F:SEA]SACDES = SAC
    Endif
    [F:SEA]TAXCOEINI = TXPRO
    [F:SEA]TAXCOEDEF = TXDEF
    [F:SEA]TAXCOEFLG = FLGTXDEF + 1
    [F:SEA]ASJCOE    = ASJCOE

    [F:SEA]CREDAT=date$
    [F:SEA]CREUSR=GUSER

    Write [SEA]
    If fstat
      Call ECR_TRACE(mess(46,GML_MSGLOF,1)-mess(336,GML_MSGFAS,1)-[F:SEA]CPY-[F:SEA]SAC-[F:SEA]SACDES-mess(7,21,1)-num$(fstat),1) From GESECRAN
    Else
      # Donnée de base créée automatiquement : Compte comptable ACC DES
      Call ECR_TRACE(mess(46,GML_MSGLOF,1)-mess(336,GML_MSGFAS,1)-[F:SEA]CPY-[F:SEA]SAC-[F:SEA]SACDES,0) From GESECRAN
    Endif
  Endif
End

################################################################################
##
##   IMPORTS DEPUIS ABEL ENTREPRISE
##
################################################################################

################################################################################
# Cette fonction convertit le type de sortie Abel Entreprise en type
# de sortie ABX3 ML 3159
# Paramètre : 1 - valeur du type de sortie Abel Entreprise
Funprog CONV_ISSTYP_AE(ISSTYP_AE)
Value Char    ISSTYP_AE
Local Integer RNUM
  #0 Non sorti
  #1 Vente
  #2 Rebut
  #3 Cession Intra-Groupe
  #4 Vol ou Disparition
  #5 Rebut avec Amortissement Exceptionnel
  #8 Fin de Contrat
  #9 Premier Bien Cédé de la Concession
  #E Apport partiel d'actif
  #F Fusion
  #G Scission
  #H Vente intra-groupe
  #I Contrat résilié
  #J Rebut avec solde des amortissements
  # Les autres valeurs sont à considérer comme une mise au rebut
  Case ISSTYP_AE
    When "","0"  : RNUM = 0
    When "1"     : RNUM = 1
    When "2"     : RNUM = 2
    When "3"     : RNUM = 3
    When "4"     : RNUM = 4
    When "5"     : RNUM = 2
    When "8"     : RNUM = 5
    When "9"     : RNUM = 12
    When "E"     : RNUM = 6
    When "F"     : RNUM = 7
    When "G"     : RNUM = 8
    When "H"     : RNUM = 3
    When "I"     : RNUM = 10
    When "J"     : RNUM = 2
    When Default : RNUM = 1 #X3-45561
  Endcase
End RNUM

################################################################################
# Cette fonction convertit le type de facture Abel Entreprise en type
# de facture ABX3
# Paramètre : 1 - valeur du type de facture Abel Entreprise
Funprog CONV_TYPVCR_AE(TYPVCR_AE)
Value Integer TYPVCR_AE
Local Integer RNUM
  #1 Facture
  #2 Avoir
  #3 Acompte
  #4 A recevoir
  #5 Reprise
  # Les autres valeurs sont à considérer comme une facture
  Case TYPVCR_AE
    When 1       : RNUM = 1
    When 2       : RNUM = 2
    When 3       : RNUM = 3
    When 4       : RNUM = 4
    When 5       : RNUM = 5
    When Default : RNUM = 1
  Endcase
End RNUM

################################################################################
# Cette fonction convertit la nature comptable Abel Entreprise en nature comptable ABX3
# Paramètre : 1 - valeur de la nature Abel Entreprise
Funprog CONV_ACN_AE(ACN_AE)
Value Integer ACN_AE
Local Integer RNUM
  #1 Immobilisation
  #2 Charge
  #3 En cours
  #4 Attente
  # Les autres valeurs sont à considérer comme une Autre
  Case ACN_AE
    When 1       : RNUM = 2
    When 2       : RNUM = 3
    When 3       : RNUM = 1
    When 4       : RNUM = 4
    When Default : RNUM = 4
  Endcase
End RNUM

################################################################################
# Cette fonction convertit la classification Abel Entreprise en nature comptable ABX3
