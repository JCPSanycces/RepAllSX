################################################################################
# Cette fonction convertit le mode d'amortissement Abel Entreprise en mode
# d'amortissement ABX3 avec prorata, règle particulière et coefficient d'accelération
# Paramètre : 1 - mode d'amortissement Abel Entreprise
Subprog CONV_DPM_AE(DPM_AE, RDPM, RALWCOD, RPRATYP, RACLCOE)
Value    Char    DPM_AE
Variable Char    RDPM
Variable Libelle RALWCOD
Variable Libelle RPRATYP
Variable Decimal RACLCOE
  #01 Caducité
  #02 Dégressif Belge
  #03 Dégressif Espagnol
  #04 Dégressif Français
  #05 Dégressif Mixte
  #06 Formes et Moules
  #07 Linge
  #08 Linéaire avec Décompte 1er Exercice
  #09 Logiciel
  #10 Linéaire
  #11 Progressif
  #12 Résiduel Jours
  #13 Résiduel Mois
  #14 Résiduel Semaines
  #15 Sans Amortissement
  #16 Softy
  #17 Unité d'Oeuvre
  #18 Linéaire au-delà valeur résiduelle nulle
  #19 Linéaire Impur Espagnol
  #20 Dégressif Mixte Espagnol
  #21 Progressif Inflaté
  #22 Dégressif Portugais
  #23 Ordinario
  #24 Anticipato
  #25 Declining Balance 1.5
  #26 Declining Balance 2
  #27 Progressif Linéaire
  #28 Slowdown
  #29 Dégressif Allemand
  #30 Dégressif Mixte Allemand
  #31 Linéaire de Caducité
  #32 Dégressif VALEO
  #34 Caducité résiduelle
  #35 Résiduel de Caducité
  Case DPM_AE
    When "01"    : RDPM = G_DPMCA
    When "02"    : RDPM = G_DPMDB
    When "03"    : RDPM = G_DPMDE
    When "04"    : RDPM = G_DPMDF
    When "05"    : RDPM = ""
    When "06"    : RDPM = G_DPMFM
    When "07"    : RDPM = G_DPMLG
    When "08"    : RDPM = G_DPMLP : RALWCOD = GVML_RPA1EXD
    When "09"    : RDPM = G_DPMLP : RALWCOD = GVML_RPALOGI
    When "10"    : RDPM = G_DPMLP : RALWCOD = GVML_RPAUCUN
    When "11"    : RDPM = G_DPMPR
    When "12"    : RDPM = G_DPMRE : RPRATYP = GVML_TPJOUR
    When "13"    : RDPM = G_DPMRE : RPRATYP = GVML_TPMOIS
    When "14"    : RDPM = G_DPMRE : RPRATYP = GVML_TPSEMA
    When "15"    : RDPM = G_DPMSA
    When "16"    : RDPM = G_DPMSY
    When "17"    : RDPM = G_DPMUO
    When "18"    : RDPM = G_DPMLV
    When "19"    : RDPM = G_DPMLE
    When "20"    : RDPM = G_DPMDI
    When "21"    : RDPM = G_DPMPR
    When "22"    : RDPM = G_DPMDP
    When "23"    : RDPM = G_DPMIT
    When "24"    : RDPM = G_DPMIT
    When "25"    : RDPM = G_DPMUD : RPRATYP = GVML_TPMOIS : RACLCOE = 1.5
    When "26"    : RDPM = G_DPMUD : RPRATYP = GVML_TPMOIS : RACLCOE = 2
    When "27"    : RDPM = ""
    When "28"    : RDPM = ""
    When "29"    : RDPM = G_DPMDA
    When "30"    : RDPM = G_DPMDX
    When "31"    : RDPM = ""
    When "32"    : RDPM = ""
    When "34"    : RDPM = ""
    When "35"    : RDPM = ""
    When Default
        If pat(DPM_AE,"!*")
          # Le mode libre ne peut pas être un mode standard
          If func TRTFAS.GET_MODE_DPM("",DPM_AE )
            RDPM = ""
          Else
            RDPM = DPM_AE
          Endif
        Else
          RDPM = ""
        Endif
  Endcase
End

################################################################################
