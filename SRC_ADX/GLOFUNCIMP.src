################################################################################ FQ79283
##
##   GESTION DES ZONES POUVANT ETRE ALIMENTEE PAR ASSOCIATION
##
################################################################################
# Si le fichier d'import donne une valeur égale à "", 0 ou [0/0/0] pour
# un champ déterminé par association, on considère la valeur non significative
# et on n'importe pas la valeur (OK = 0)
$IMP_ZONE_ASSOC
    Local Char IZ(50)
    If !clalev([F:ADI]) : Local File ATABDIV [F:ADI] : Endif # Ajout table diverses
    IZ="[F:"+IMPFIC+"]"+IMPZON
    If evalue("dim("+IZ+")") < 0 : Return : Endif
    Look [F:ADI]CODE=GTD_ASSOC;IMPZON
    If !fstat
      Case evalue("type("+IZ+")")
        When 1, 2, 4, 5, 6, 7, 9
          If evalue(IZ) = 0
            OK = 0
          Endif
        When 3
          If evalue(IZ) = [0/0/0]
            OK = 0
          Endif
        When Default
          If evalue(IZ) = ""
            OK = 0
          Endif
      Endcase
    Endif
Return

