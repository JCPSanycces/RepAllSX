#<AdxTL>@(#)0.0.0.0 $Revision$
Call OUVRE_TRACE("") From LECFIC
Local File ADOSSIER [ADS]
Read [ADS]DOSSIER = "DEMOFRA"
#Call ATRSMAJ30 From CPTMAJ30
Call SUPP_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

$FACTURE_TIERS

Local Char    TABLE_ENT(GLONATB), TABLE_LIG(GLONATB), TABLE_LIGANA(GLONATB)
Local Char    COAGEN(3), COAANA(3), COAIAS(3)
Local Char    LEDGEN(3), LEDANA(3), LEDIAS(3)
Local Integer IREF, AXE
Local Integer NBAXANA, NBAXIAS
Local Libelle LEDGENMAIN, LEDANAMAIN
Local Char    MODELE(3), SOCIETE(GLONCPY)
Local Decimal EXERCICE, PERIODE
Local Date    DAT

# MAJ de la Trace des écritures comptable
Local Integer TVD_IND
Local Char    TVD_DOC(20)
Local Integer TVD_NUM

Gosub SINVOICE
Gosub PINVOICE
Return


$SINVOICE
# Mise à jour des tables factures tiers clients V6
Local File =[F:ADS]DOSSIER+".SINVOICE"    [ENT]         # En-tête Factures Tiers clients
Local File =[F:ADS]DOSSIER+".BPCINVLIG"   [LIG]         # Lignes Factures Tiers clients
Local File =[F:ADS]DOSSIER+".BPCINVLIGA"  [LIA]         # Lignes analytiques Factures Tiers clients
Local File =[F:ADS]DOSSIER+".GACM"        [GCM]         # Modèles comptables 
Local File =[F:ADS]DOSSIER+".GLED"        [LED]         # Référentiels
Local File =[F:ADS]DOSSIER+".COMPANY"     [CPY]         # Sociétés
Local File =[F:ADS]DOSSIER+".PERIOD"      [PER]         # Périodes
Local File =[F:ADS]DOSSIER+".TRCVCRDOC"   [TVD]         # Trace des écritures comptables
Local File =[F:ADS]DOSSIER+".GACCDUDATE"  [DUD]         # Echéances

# MAJ de la Trace des écritures comptable
TVD_IND = 2

TABLE_ENT    = "SINVOICE"
TABLE_LIG    = "BPCINVLIG"
TABLE_LIGANA = "BPCINVLIGA"

Call ECR_TIME(mess(81,125,1)-":"-TABLE_ENT) From DOSSUB : # maj table

Gosub TR_FACTURE

Close Local File [ENT], [LIG], [LIA], [GCM], [LED], [CPY], [PER], [TVD], [DUD]
Return


$PINVOICE
# Mise à jour des tables factures tiers fournisseurs V6
Local File =[F:ADS]DOSSIER+".PINVOICE"    [ENT]         # En-tête Factures Tiers fournisseurs
Local File =[F:ADS]DOSSIER+".BPSINVLIG"   [LIG]         # Lignes Factures Tiers fournisseurs
Local File =[F:ADS]DOSSIER+".BPSINVLIGA"  [LIA]         # Lignes analytiques Factures Tiers fournisseurs
Local File =[F:ADS]DOSSIER+".GACM"        [GCM]         # Modèles comptables 
Local File =[F:ADS]DOSSIER+".GLED"        [LED]         # Référentiels
Local File =[F:ADS]DOSSIER+".COMPANY"     [CPY]         # Sociétés
Local File =[F:ADS]DOSSIER+".PERIOD"      [PER]         # Périodes
Local File =[F:ADS]DOSSIER+".TRCVCRDOC"   [TVD]         # Trace des écritures comptables
Local File =[F:ADS]DOSSIER+".GACCDUDATE"  [DUD]         # Echéances

# MAJ de la Trace des écritures comptable
TVD_IND = 1

TABLE_ENT    = "PINVOICE"
TABLE_LIG    = "BPSINVLIG"
TABLE_LIGANA = "BPSINVLIGA"

Call ECR_TIME(mess(81,125,1)-":"-TABLE_ENT) From DOSSUB : # maj table

Gosub TR_FACTURE
Close Local File [ENT], [LIG], [LIA], [GCM], [LED], [CPY], [PER], [TVD], [DUD]
Return


$TR_FACTURE
Filter [ENT] Where ORIMOD=3 Order By Key CLE=CPY;NUM

Gosub SET_FIRST From TRTFIRST 
Raz STOP

$LOOP_FAC
Raz NB
If STOP = 1 
 STOP = 2
 CRITERE = "[F:ENT]CPY='"+ACLE1+"' & [F:ENT]NUM>'"+ACLE2+"'"
Elsif STOP = 2
 STOP = 0
 CRITERE = "[F:ENT]CPY>='"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [ENT], [LIG], [LIA]
GOK = 1

For [ENT]CLE(1) Where evalue(CRITERE)

 If [F:ENT]CPY <> [F:CPY]CPY
  Read [CPY]CPY0 = [F:ENT]CPY
 Endif
 If [F:CPY]ACM <> [F:GCM]GCM
  Read [F:GCM]GCM0 = [F:CPY]ACM
 Endif
 SOCIETE    = [F:CPY]CPY
 LEDGENMAIN = [F:GCM]GENLEDTYP
 LEDANAMAIN = [F:GCM]ANALEDTYP
 LEDGEN     = [F:GCM]LED(0)
 LEDANA     = [F:GCM]LED(1)
 LEDIAS     = [F:GCM]LED(2)
 Raz COAGEN,COAANA, COAIAS 
 If LEDGEN <> [F:LED]LED
  Read [F:LED]LED0 = LEDGEN
 Endif
 COAGEN = [F:LED]COA
 If LEDANA <> [F:LED]LED
  Read [F:LED]LED0 = LEDANA
 Endif
 COAANA = [F:LED]COA
 If LEDIAS<>""
  If LEDIAS <> [F:LED]LED
   Read [F:LED]LED0 = LEDIAS
  Endif
  COAIAS = [F:LED]COA
 Endif

 For [ENT]CLE(2)

  ## Maj nouveaux champs FIY et PER
  [L]DAT = [F:ENT]ACCDAT
  Gosub GETPERSOC
  [F:ENT]FIY = [L]EXERCICE
  [F:ENT]PER = [L]PERIODE

  If dim([F:ENT]STARPT)>0
   If [F:ENT]STA>1
    [F:ENT]STARPT = 2
   Else
    [F:ENT]STARPT = 1
   Endif
  Endif

  For IREF=1 To dim([F:GCM]LED)
   If [F:GCM]LED(IREF-1)<>""
    [F:ENT]LED(IREF-1) = [F:GCM]LED(IREF-1)
    [F:ENT]CURLED(IREF-1) = [F:GCM]CUR(IREF-1)
    [F:ENT]RATDIV(IREF-1) = 1 
    If find(IREF,1,2,3)
     [F:ENT]RATMLT(IREF-1) = [F:ENT]RATCUR
    Else
     [F:ENT]RATMLT(IREF-1) = [F:ENT]RATRPT
    Endif
   Endif
  Next

  If [F:LED]LED<>LEDANA
   Read [LED]LED0 = LEDANA
  Endif
  For AXE=1 To [F:LED]DIENBR
   [F:ENT]DIE(AXE-1) = [F:LED]DIE(AXE-1)
  Next 
 
  ## Lignes facture tiers
  For [LIG] Where NUM=[F:ENT]NUM
  
   ## Les dates de prestation sont définies au niveau des lignes de facture
   [F:LIG]STRDAT = [F:ENT]STRDATSVC
   [F:LIG]ENDDAT = [F:ENT]ENDDATSVC
 
   For IREF=1 To dim([F:GCM]LED)
    If [F:GCM]LED(IREF-1)<>""
     [F:LIG]LED(IREF-1) = [F:GCM]LED(IREF-1)
     If find(IREF,1,2,3)
      If [F:LIG]LED(IREF-1)=LEDGEN
       [F:LIG]COA(IREF-1) = COAGEN
       [F:LIG]ACC(IREF-1) = [F:LIG]ACC
      Elsif [F:LIG]LED(IREF-1)=LEDANA
       [F:LIG]COA(IREF-1) = COAANA
       [F:LIG]ACC(IREF-1) = [F:LIG]CNA
      Elsif dim([F:LIG]ACCIAS)>0 & [F:LIG]LED(IREF-1)=LEDIAS
       [F:LIG]COA(IREF-1) = COAIAS
       [F:LIG]ACC(IREF-1) = [F:LIG]ACCIAS
      Endif
     Endif
    Endif
   Next
  
   ## Lignes analytiques facture tiers
   ## NB : Tout ce qui était dans BPCINVLIGA/BPSINVLIGA en V5 concerne l'analytique....
   For [LIA] Where NUM=[F:LIG]NUM & LIG=[F:LIG]LIG
    [F:LIA] = [F:LIA]
    For IREF=1 To dim([F:GCM]LED)
     If [F:GCM]LED(IREF-1)<>""
      If find(IREF,1,2,3)
       If [F:LIG]LED(IREF-1)=LEDGEN
        [F:LIA]COA(IREF-1) = COAGEN
        [F:LIA]ACC(IREF-1) = [F:LIG]ACC
       Elsif [F:LIG]LED(IREF-1)=LEDANA
        [F:LIA]COA(IREF-1) = COAANA
       [F:LIA]ACC(IREF-1) = [F:LIG]CNA
       Elsif dim([F:LIG]ACCIAS)>0 & [F:LIG]LED(IREF-1)=LEDIAS
        [F:LIA]COA(IREF-1) = COAIAS
        [F:LIA]ACC(IREF-1) = [F:LIG]ACCIAS
       Endif
      Endif
     Endif
    Next
    If LEDANA<>""
     Read [LED]LED0 = LEDANA
     For AXE=1 To [F:LED]DIENBR
      [F:LIA]DIE(AXE-1) = [F:LED]DIE(AXE-1)
     Next
    Endif
    If LEDIAS<>""
     ## On initialise les codes axes mais on n'aura pas de secteurs (champ CCE vide), puisqu'en V5 on
     ## n'imputait pas de secteurs sur les lignes de factures 
     Read [LED]LED0 = LEDANA
     NBAXANA = max(1,[F:LED]DIENBR)
     Read [LED]LED0 = LEDIAS
     NBAXIAS = [F:LED]DIENBR
     For AXE = NBAXANA To NBAXANA+NBAXIAS
      [F:LIA]DIE(AXE) = [F:LED]DIE(AXE-NBAXANA)
     Next
    Endif

    NB += 1
    Rewrite [LIA]
    If fstat 
     GOK = 0 : Call ERREUR(TABLE_LIGANA-[F:LIA]NUM-num$([F:LIA]LIG)-num$([F:LIA]ANALIG),1) From DOSDIC
    Endif
   Next

   NB += 1
   Rewrite [LIG]
   If fstat 
    GOK = 0 : Call ERREUR(TABLE_LIG-[F:LIG]NUM-num$([F:LIG]LIG),1) From DOSDIC
   Endif
  Next

  TVD_DOC = [F:ENT]NUM  : TVD_NUM = [F:ENT]ACCNUM
  Gosub UPD_TVD From TRSMAJ30B

  NB += 1
  Rewrite [ENT]
  If fstat
   GOK = 0 : Call ERREUR(TABLE_ENT-[F:ENT]NUM,1) From DOSDIC
  Endif

  If NB>GMAXUPDTRS
   ACLE1 = [F:ENT]CPY
   ACLE2 = [F:ENT]NUM
   STOP=1
   Break 2 
  Endif
 Next
Next

Commit

If STOP
 Goto LOOP_FAC
Endif
Gosub UNSET_FIRST From TRTFIRST
Return


##############################################################################################################
$UPD_TVD

If [L]TVD_NUM=0 : Return : Endif

# Trace des écritures comptables
Read [DUD]DUD1(1) = [L]TVD_NUM
If !fstat
 Raz [TVD]
 [F:TVD]TYPNUM = [L]TVD_IND
 [F:TVD]NUM    = [L]TVD_DOC
 [F:TVD]ACCNUM = [L]TVD_NUM
 [F:TVD]TYPVCR = [F:DUD]TYP
 [F:TVD]NUMVCR = [F:DUD]NUM
 [F:TVD]CREUSR = GUSER
 [F:TVD]CREDAT = date$
 [F:TVD]UPDUSR = GUSER
 [F:TVD]UPDDAT = date$
 Write [TVD] 
 If fstat
#  GOK = 0 : Call ERREUR("TRCVCRDOC"-[L]TVD_DOC,1) From DOSDIC
 Endif
Endif

Return
##############################################################################################################

$PAYMENTH
# Mise à jour des tables règlements V6
Local File =[F:ADS]DOSSIER+".PAYMENTH"   [PYH]         # En-tête règlements
Local File =[F:ADS]DOSSIER+".PAYMENTD"   [PYD]         # Lignes règlements
Local File =[F:ADS]DOSSIER+".PAYMENTA"   [PYA]         # Lignes analytiques règlements
Local File =[F:ADS]DOSSIER+".GACM"       [GCM]         # Modèles comptables 
Local File =[F:ADS]DOSSIER+".GLED"       [LED]         # Référentiels
Local File =[F:ADS]DOSSIER+".COMPANY"    [CPY]         # Société
Local File =[F:ADS]DOSSIER+".PERIOD"     [PER]         # Périodes

Local Char    COAGEN(3), COAANA(3), COAIAS(3)
Local Char    LEDGEN(3), LEDANA(3), LEDIAS(3)
Local Char    MODELE(3), SOCIETE(GLONCPY)
Local Integer IREF, AXE
Local Decimal EXERCICE, PERIODE
Local Date    DAT
Local Libelle LEDGENMAIN, LEDANAMAIN

Call ECR_TIME(mess(81,125,1)-": PAYMENTH") From DOSSUB : # maj table

For [CPY]CPY0 
 SOCIETE = [F:CPY]CPY
 MODELE  = [F:CPY]ACM
 If MODELE <> [F:GCM]GCM
  Read [F:GCM]GCM0 = [F:CPY]ACM
 Endif
 LEDGENMAIN = [F:GCM]GENLEDTYP
 LEDANAMAIN = [F:GCM]ANALEDTYP
 LEDGEN     = [F:GCM]LED(0)
 LEDANA     = [F:GCM]LED(1)
 LEDIAS     = [F:GCM]LED(2)
 Raz COAGEN,COAANA, COAIAS 
 Read [F:LED]LED0 = LEDGEN
 If !fstat :  COAGEN = [F:LED]COA : Endif
 Read [F:LED]LED0 = LEDANA
 If !fstat :  COAANA = [F:LED]COA : Endif
 If LEDIAS<>""
  Read [F:LED]LED0 = LEDIAS
  If !fstat :  COAIAS = [F:LED]COA : Endif
 Endif
 Gosub TR_REG
Next
Close Local File [PYH], [PYD], [PYA], [GCM], [LED], [CPY], [PER]
Return


$TR_REG

Gosub SET_FIRST From TRTFIRST 
Raz STOP

$LOOP_PYH
Raz NB
If STOP
 Raz STOP
 CRITERE = "[F:PYH]NUM>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [PYH], [PYD], [PYA]
GOK = 1

For [PYH]PYH0 Where CPY=[L]SOCIETE & evalue(CRITERE)

 ## Maj champ COA correspondant au plan de compte associé au référentiel général principal
 ## (on saisit en en-tête uniquement le compte tiers payeur du référentiel général principal) 
 [F:PYH]COA = [L]COAGEN

 ## Maj nouveaux champs FIY et PER
 [L]DAT = [F:PYH]ACCDAT
 Gosub GETPERSOC
 [F:PYH]FIY = [L]EXERCICE
 [F:PYH]PER = [L]PERIODE

 ## Lignes règlement
 For [PYD]PYD0 Where NUM=[F:PYH]NUM
  
  For IREF=1 To dim([F:GCM]LED)
   If [F:GCM]LED(IREF-1)<>""
    [F:PYD]LED(IREF-1) = [F:GCM]LED(IREF-1)
    If [F:PYD]LED(IREF-1)=LEDGEN
     [F:PYD]COA(IREF-1) = COAGEN
     [F:PYD]ACC(IREF-1) = [F:PYD]ACCLIN
    Elsif [F:PYD]LED(IREF-1)=LEDANA
     [F:PYD]COA(IREF-1) = COAANA
     [F:PYD]ACC(IREF-1) = [F:PYD]CNA
    Elsif [F:PYD]LED(IREF-1)=LEDIAS 
     [F:PYD]COA(IREF-1) = COAIAS
     ## Pas de compte IAS en V5. Il sera automatiquement généré lors de la validation
     ## du règlement 
    Endif
   Endif
  Next

  For [PYA]PYA0 Where NUM=[F:PYD]NUM & LIN=[F:PYD]LIN
   Read [LED]LED0 = LEDANA
   For AXE=1 To [F:LED]DIENBR
    [F:PYA]DIE(AXE-1) = [F:LED]DIE(AXE-1)
   Next
   If LEDIAS<>""
    ## On initialise les codes axes mais on n'aura pas de secteurs (champ CCE vide), puisqu'en V5 on
    ## n'imputait pas de secteurs sur les lignes de factures 
    NBAXANA = max(1,[F:LED]DIENBR)
    Read [LED]LED0 = LEDIAS
    NBAXIAS = [F:LED]DIENBR
    For AXE = NBAXANA To NBAXANA+NBAXIAS
     [F:PYA]DIE(AXE-1) = [F:LED]DIE(AXE-NBAXANA)
    Next
   Endif
   NB += 1
   Rewrite [PYA]
   If fstat
    GOK = 0 : Call ERREUR("PAYMENTD"-[F:PYA]NUM-num$([F:PYA]LIN)-num$([F:PYA]LINANA),1) From DOSDIC
   Endif

  Next

  NB += 1
  Rewrite [PYD]
  If fstat
   GOK = 0 : Call ERREUR("PAYMENTD"-[F:PYD]NUM-num$([F:PYD]LIN),1) From DOSDIC
  Endif

 Next

 Rewrite [PYH]
 If fstat
  GOK = 0 : Call ERREUR("PAYMENTH"-[F:PYH]NUM,1) From DOSDIC
 Endif

 NB += 1
 If NB>GMAXUPDTRS
  ACLE1 = [F:PYH]NUM
  STOP=1
  Break
 Endif

Next

Commit


If STOP
 Goto LOOP_PYH
Endif
Gosub UNSET_FIRST From TRTFIRST
Return

#############################################################################################################

$ECHEANCES
# Mise à jour des tables règlements V6
Local File =[F:ADS]DOSSIER+".GACCDUDATE"   [DUD]       # Echéances
Local File =[F:ADS]DOSSIER+".GLED"         [LED]       # Référentiels
Local File =[F:ADS]DOSSIER+".COMPANY"      [CPY]       # Société
Local File =[F:ADS]DOSSIER+".GACM"         [GCM]       # Modèles comptables 
Local File =[F:ADS]DOSSIER+".PERIOD"       [PER]       # Périodes
Local File =[F:ADS]DOSSIER+".BPARTNER"     [BPR]       # Business Partner

Local Libelle LEDGENMAIN, LEDANAMAIN
Local Decimal EXERCICE, PERIODE
Local Char    MODELE(3), SOCIETE(GLONCPY)
Local Date    DAT
Local Char    TIERS(20)

Call ECR_TIME(mess(81,125,1)-": GACCDUDATE") From DOSSUB : # maj table

For [CPY]CPY0
 SOCIETE = [F:CPY]CPY
 MODELE  = [F:CPY]ACM
 If MODELE <> [F:GCM]GCM
  Read [F:GCM]GCM0 = [F:CPY]ACM
 Endif
 LEDGENMAIN = [F:GCM]GENLEDTYP
 LEDANAMAIN = [F:GCM]ANALEDTYP

 Gosub TR_ECHEANCE
Next
Close Local File [DUD], [LED], [CPY], [PER], [GCM], [BPR]
Return


$TR_ECHEANCE

Gosub SET_FIRST From TRTFIRST 
Raz STOP

$LOOP_DUD
Raz NB
If STOP
 Raz STOP
 CRITERE = "[F:DUD]NUMDUD>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif

Trbegin [DUD]
GOK = 1

For [DUD]DUD8 Where CPY=[L]SOCIETE & evalue(CRITERE)

 ## Maj nouveaux champs FIY et PER
 [L]DAT = [F:DUD]DUDDAT
 Gosub GETPERSOC
 [F:DUD]FIY = [L]EXERCICE
 [F:DUD]PER = [L]PERIODE

 ## Nouveau champ BPAPAY : Adresse tiers
 TIERS=[F:DUD]BPRPAY
 If [F:BPR]BPRNUM<>TIERS
  Read [BPR]BPR0 = [F:DUD]BPRPAY
 Endif
 [F:DUD]BPAPAY=[F:BPR]BPAADD
  
 NB += 1
 Rewrite [DUD]
 If fstat
  GOK = 0 : Call ERREUR("GACCDUDATE"-[F:DUD]TYP-[F:DUD]NUM-num$([F:DUD]LIG)-num$([F:DUD]DUDLIG),1) From DOSDIC
 Endif

 If NB>GMAXUPDTRS
  ACLE1 = [F:DUD]NUMDUD
  STOP=1
  Break
 Endif

Next

Commit

If STOP
 Goto LOOP_DUD
Endif
Gosub UNSET_FIRST From TRTFIRST
Return



#############################################################################################################
$GETPERSOC
If [L]DAT>=[F:PER]PERSTR & [L]DAT<=[F:PER]PEREND & [L]SOCIETE=[F:PER]CPY & [L]LEDGENMAIN=[F:PER]LEDTYP
 [L]EXERCICE = [F:PER]FIYNUM
 [L]PERIODE  = [F:PER]PERNUM
 Return
Endif
For [PER]PER0 Where [F:PER]CPY=[L]SOCIETE & [F:PER]PERSTR<=[L]DAT & [F:PER]PEREND>=[L]DAT & [F:PER]LEDTYP=[L]LEDGENMAIN
 [L]EXERCICE = [F:PER]FIYNUM
 [L]PERIODE  = [F:PER]PERNUM
Next
Return


#############################################################################################################
$EXPENSES
#############################################################################################################

# Mise à jour des tables V6
Local File =[F:ADS]DOSSIER+".EXPENSES"    [EXS]    Order By Key CLE=CPY;ACCNUM

Local File =[F:ADS]DOSSIER+".GACM"        [GCM]         # Modèles comptables 
Local File =[F:ADS]DOSSIER+".COMPANY"     [CPY]         # Sociétés

Call ECR_TIME(mess(81,125,1)-": EXPENSES") From DOSSUB : # maj table

Gosub SET_FIRST From TRTFIRST
Raz STOP, CRITERE
$LOOP_EXS
Raz NB
If STOP = 1
 STOP = 2
 CRITERE = "[F:EXS]CPY='"+ACLE1+"' & [F:EXS]ACCNUM>"+num$(ICLE1)
Elsif STOP=2
 Raz STOP
 CRITERE = "[F:EXS]CPY>'"+ACLE1+"'"
Else
 CRITERE = "1=1"
Endif
 
Trbegin [EXS]
GOK = 1

For [EXS]CLE(1) Where evalue(CRITERE)

 Read [CPY]CPY0 = [F:EXS]CPY 
 If [F:CPY]ACM <> [F:GCM]GCM
  Read [F:GCM]GCM0 = [F:CPY]ACM
 Endif

 For [EXS]CLE

  #  Zones liées aux modèle comptable (ici STD... 3 lignes référentiel non autoamtique SOC/ANA/IAS et 3 lignes de reporting automatiques)
  For I=1 To dim([F:GCM]LED)
   If [F:GCM]LED(I-1)<>""
    [F:EXS]LED(I-1)    = [F:GCM]LED(I-1)
    [F:EXS]CURLED(I-1) = [F:GCM]CUR(I-1)
    [F:EXS]RATDIV(I-1) = 1 
    If I<3
     [F:EXS]RATMLT(I-1) = [F:EXS]RATCUR
    Else
     [F:EXS]RATMLT(I-1) = [F:EXS]RATRPT
    Endif
   Endif
  Next

  For I=1 To [L]MIGGOPTCANA
   [F:EXS]DIE(I-1) = "AX"+num$(I)
  Next

  Rewrite [EXS]
  If fstat
   GOK = 0 : Call ERREUR("EXPENSES"-[F:EXS]CPY-num$([F:EXS]ACCNUM),1) From DOSDIC
  Endif

  NB+=1
  If NB>GMAXUPDTRS 
   ACLE1 = [F:EXS]CPY
   ICLE1 = [F:EXS]ACCNUM
   STOP=1
   Break 2
  Endif
 Next
Next
#Pas de Rollback
#If GOK<1 : Rollback
#Else     : Commit
#Endif

Commit

If STOP
 Goto LOOP_EXS
Endif
Gosub UNSET_FIRST From TRTFIRST

Close Local File [EXS], [GCM], [CPY]


# Demande 54348 =>   => Fait en RAZFIL sous CPTMAJ30

#Local File =[F:ADS]DOSSIER+".TMPEXPENSE"    [EXT]   # Table temporaire Frais

#Call ECR_TIME(mess(81,125,1)-": TMPEXPENSE") From DOSSUB : # maj table

#Trbegin [EXT]
#Delete [EXT] Where 1=1
#If fstat
# GOK = 0 : Call ERREUR("TMPEXPENSE",3) From DOSDIC
#Endif
#Commit

#Close Local File [EXT]

Return





