#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "CONTPRT" : Gosub CONTPRT
Endcase
Return

#########################################################################

#-----------------------------------------#
# Contrôle destination (choix imprimante) #
# --------------------------------------- #
#  Préchargement du nombre de copies      #
#  Par défaut provient des destinations   #
#-----------------------------------------#
$CONTPRT
#------ Préchargement si contexte gestion de commandes de ventes -----#
If GFONCTION="GESSOH" & clalev([M:SOH0])
  If !find([M:RPT]IMPRIME,0,1,3,4)
    # FGR 24/03/2014 : X3SUIVI97819 (début)
    If [M:SOH0]BPCORD <> [F:BPC]BPCNUM Then
     Read [F:BPC]BPC0=[M:SOH0]BPCORD
    Endif
    # FGR 24/03/2014 : X3SUIVI97819 (début)
    #Fq73266-Gbn-uniquement s'il y a un modèle d'impression sur le tiers
    If [F:BPC]TPMCOD<>""
     [M:RPT]NBRCPY=max([M:SOH0]COPNBR,1) : # Nombre de copies
     Affzo [M:RPT]NBRCPY   # FGR 24/03/2014 : X3SUIVI97819
    Endif
  Else
    [M:RPT]NBRCPY=0 : # pas de copie pour prévisu, message, fichier
    Grizo [M:RPT]NBRCPY : Affzo [M:RPT]NBRCPY #Fq73266
  Endif
Endif
#-----
Return

#########################################################################

Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

Call EXEC(NBPAR,PARAMETRE)

End

######################################################################

Subprog EXEC(NBPAR,PARAMETRE)
Value Integer    NBPAR
Variable Char    PARAMETRE()()
# -- ARCCLIENT2
Local Date    DATREF


#--- ouverture des tables
Gosub OUVRE
#--- declaration des variables
Gosub DECLARE

[L]CRITERE = "1=1"
# -- ARCCLIENT2
[L]CRITERE2 = "1=1"

#--- analyse des paramètres
For I=1 To NBPAR
 J=instr(1,[L]PARAMETRE(I),"=")
 If J
  [L]PARAM  = left$([L]PARAMETRE(I),J-1)
  Call GETPARAM ([L]PARAM,NBPAR,PARAMETRE,VALEUR) From ETAT
#  [L]VALEUR = right$([L]PARAMETRE(I),J+1)
  Case [L]PARAM
   When "X3ETA"           : [L]ETAT = [L]VALEUR
   When "__REQUETE"       : [L]NUMREQ = val([L]VALEUR)
   #--- alimentation des paramètres utilisateur
   When "numedt"          : [L]PARAMETRE(I) = "numedt="+num$([L]NUMREQ)
   When "usr"             : [L]PARAMETRE(I) = "usr="+GUSER
   When "etat"            : [L]PARAMETRE(I) = "etat="+[L]ETAT
   When "euro"            : [L]PARAMETRE(I) = "euro="+GEURO
   #--- préparation du filtre à appliquer sur la table SOH
   When "sitedeb"         : [L]CRITERE -= "& SALFCY>='"+[L]VALEUR+"'"
   When "sitefin"         : [L]CRITERE -= "& SALFCY<='"+[L]VALEUR+"'"
   When "clientdeb"       : [L]CRITERE -= "& BPCORD>='"+[L]VALEUR+"'"
   When "clientfin"       : [L]CRITERE -= "& BPCORD<='"+[L]VALEUR+"'"
   When "commandedeb"     : [L]CRITERE -= "& SOHNUM>='"+[L]VALEUR+"'"
   When "commandefin"     : [L]CRITERE -= "& SOHNUM<='"+[L]VALEUR+"'"
   When "avenantdeb"      : [L]CRITERE -= "& REVNUM>="+num$([L]VALEUR)
   When "avenantfin"      : [L]CRITERE -= "& REVNUM<="+num$([L]VALEUR)
   When "codimp"          : [L]CRITERE -= "& OCNPRN="+num$([L]VALEUR)
                                             [L]IMPR = val([L]VALEUR)
# -- ARCCLIENT2
   When "datedeb"         : [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                          val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                            [L]CRITERE2 -= "& ORDDAT >=["+format$(GFMD,[L]DATREF)+']'
   When "datefin"         : [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                          val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                            [L]CRITERE2 -= "& ORDDAT <=["+format$(GFMD,[L]DATREF)+']'
   When "devdeb"          : [L]CRITERE2 -= "& CUR>='"+[L]VALEUR+"'"
   When "devfin"          : [L]CRITERE2 -= "& CUR<='"+[L]VALEUR+"'"
# -- Trop de critères passage de CRITERE (250) à (250)(1..2)
   When "typedeb"         : [L]CRITERE2 -= "& SOHTYP>='"+[L]VALEUR+"'"
   When "typefin"         : [L]CRITERE2 -= "& SOHTYP<='"+[L]VALEUR+"'"
   When "etatcomdeb"      : [L]CRITERE2 -= "& ORDSTA>="+num$([L]VALEUR)
   When "etatcomfin"      : [L]CRITERE2 -= "& ORDSTA<="+num$([L]VALEUR)
   When "etatfacdeb"      : [L]CRITERE2 -= "& INVSTA>="+num$([L]VALEUR)
   When "etatfacfin"      : [L]CRITERE2 -= "& INVSTA<="+num$([L]VALEUR)
   When "etatlivdeb"      : [L]CRITERE2 -= "& DLVSTA>="+num$([L]VALEUR)
   When "etatlivfin"      : [L]CRITERE2 -= "& DLVSTA<="+num$([L]VALEUR)
   When "datelivdeb"      : [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                          val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                            [L]CRITERE2 -= "& DEMDLVDAT >=["+format$(GFMD,[L]DATREF)+']'
   When "datelivfin"      : [L]DATREF   =  gdat$(val(right$([L]VALEUR,7)),
&                                          val(seg$([L]VALEUR,5,6)),val(left$([L]VALEUR,4)))
                            [L]CRITERE2 -= "& DEMDLVDAT <=["+format$(GFMD,[L]DATREF)+']'
   When "_PrinterCopies"  : [L]PARAMETRE(I) = "_PrinterCopies="+chr$(1)+"1"												:#--CPO 71937 Report
   When "categcomdeb"			  : If VALEUR<>"4" : [L]CRITERE -= "& SOHCAT>="+num$([L]VALEUR) : Endif :#--CPO 75115
	 When "categcomfin"			  : If VALEUR<>"4" : [L]CRITERE -= "& SOHCAT<="+num$([L]VALEUR) : Endif :#--CPO 75115
 Endcase
 Endif
Next

[L]CRITERE -= "& SOHCAT<>"+num$(4)

  Look [ARM]ARM0=[L]NUMREQ;GUSER;[F:ARP]RPTCOD;1   # FGR 22/10/2015 : X3SUIVI111379
  If fstat Then                                    # FGR 22/10/2015 : X3SUIVI111379
    Filter [F:SOH] Where evalue([L]CRITERE) & evalue([L]CRITERE2)
    Gosub TRT_SOH
  Endif                                            # FGR 22/10/2015 : X3SUIVI111379
End

###################################################################
###################################################################

$TRT_SOH
#Raz WNUMLIG
Raz WNUMLIG, WNUMCOP :#--CPO 71937 Report
Default File [SOH]

For [F:SOH]SOH0
   Call DEBTRANS From GLOCK
   Raz WNUMCOP :#--CPO 71937 Report
   If [L]IMPR = 1  Gosub TR1  : # impression
   Else            Gosub TR2  : # re-impression
   Endif
Next

Return

##########################################################################

$TR1
Trbegin [SOH] , [ARM], [TRPT]

# Mise à jour table entête commande si demande d'impression
If [L]IMPR = 1
 Readlock [F:SOH]SOH0 Curr
 If fstat = 1 : GOK = -1 : GLOCK = "$SORDER" : Goto ROLL_TR1
 Elsif fstat  : GOK = 0 : Call RSTA("SOH","*") From GLOCK : Goto AB_TR1
 Endif
 [F:SOH]OCNPRN = 2
 Rewrite [F:SOH]
 If fstat=1
  GOK=-1 : GLOCK="$SORDER"-[F:SOH]SOHNUM
  Goto ROLL_TR1
 Elsif fstat
  GOK=0 : Call RSTA("SORDER",[F:SOH]SOHNUM) From GLOCK : Goto AB_TR1
 Endif
Endif

#Création de l'enregistrement dans la table AREPORTM
#--CPO 71937 Report
#WNUMLIG      += 1
#
#Raz [F:ARM]
#[F:ARM]USR     = GUSER
#[F:ARM]RPTCOD  = [F:ARP]RPTCOD
#[F:ARM]NUMREQ  = [L]NUMREQ
#[F:ARM]NUMLIG  = WNUMLIG
#[F:ARM]CLEA1   = [F:SOH]SOHNUM
#[F:ARM]CREDAT  = date$
#Write [F:ARM]
#If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR1 : Endif
Local Integer INBCOP
For INBCOP=1 To max(1,[M:RPT]NBRCPY)
 WNUMLIG      += 1
 WNUMCOP      += 1
 Raz [F:ARM]
 [F:ARM]USR     = GUSER
 [F:ARM]RPTCOD  = [F:ARP]RPTCOD
 [F:ARM]NUMREQ  = [L]NUMREQ
 [F:ARM]NUMLIG  = WNUMLIG
 [F:ARM]NUMCOP  = WNUMCOP
 [F:ARM]CLEA1   = [F:SOH]SOHNUM
 [F:ARM]CREDAT  = date$
 Write [F:ARM]
 If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR1 : Endif
Next INBCOP
#--/CPO

# Issue 110704 - 2016-01-06 by BRBAN
If CKPO = 1
  Gosub ALIM_TMPSRPT
  If GOK = 0 : Goto AB_TR1 : Endif
Endif
#
Commit
Return

$ROLL_TR1
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

$AB_TR1
Rollback
Return

###########################
$TR2
Trbegin [ARM], [TRPT]
#Création de l'enregistrement dans la table AREPORTM
#--CPO 71937 Report
#WNUMLIG      += 1
#
#Raz [F:ARM]
#[F:ARM]USR     = GUSER
#[F:ARM]RPTCOD  = [F:ARP]RPTCOD
#[F:ARM]NUMREQ  = [L]NUMREQ
#[F:ARM]NUMLIG  = WNUMLIG
#[F:ARM]CLEA1   = [F:SOH]SOHNUM
#[F:ARM]CREDAT  = date$
#Write [F:ARM]
#If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR2 : Endif
#Commit
Local Integer INBCOP
For INBCOP=1 To max(1,[M:RPT]NBRCPY)
 WNUMLIG      += 1
 WNUMCOP      += 1
 Raz [F:ARM]
 [F:ARM]USR     = GUSER
 [F:ARM]RPTCOD  = [F:ARP]RPTCOD
 [F:ARM]NUMREQ  = [L]NUMREQ
 [F:ARM]NUMLIG  = WNUMLIG
 [F:ARM]NUMCOP  = WNUMCOP
 [F:ARM]CLEA1   = [F:SOH]SOHNUM
 [F:ARM]CREDAT  = date$
 Write [F:ARM]
 If fstat : GOK = 0 : Call FSTA("ARM") From GLOCK : Goto AB_TR2 : Endif
Next INBCOP

# Issue 110704 - 2016-01-04 by BRBAN
If CKPO = 1
  Gosub ALIM_TMPSRPT
  If GOK = 0 : Goto AB_TR2 : Endif
Endif
#

Commit
#--/CPO
Return

$ROLL_TR2
Rollback : Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif

$AB_TR2
Rollback
Return

###########################################################################

$OUVRE
Local File SORDER [SOH], AREPORTM [ARM]
# Issue 110704 - 2016-01-06 by BRBAN
Local Integer CKPO : [L]CKPO = 0
Local File TMPSRPT    [TRPT]
Return

$DECLARE
Local Char    CRITERE(250), CRITERE2(255), PARAM(30) , VALEUR(30) , ETAT(15)
#Local Integer WNUMLIG, NUMREQ, IMPR
Local Integer WNUMLIG, WNUMCOP, NUMREQ, IMPR :#--CPO 71937
# Issue 110704 - 2016-01-06 by BRBAN
If func AFNC.ACTIV('KPO')>0
  CKPO = 1
Endif
Return
###########################################################################
$ALIM_TMPSRPT

Raz [F:TRPT]

[F:TRPT]       = [F:ARM]
[F:TRPT]VCRNUM = [F:SOH]SOHNUM

Write [F:TRPT]
If fstat : GOK=0 : Call FSTA("TRPT") From GLOCK : Endif

Return

