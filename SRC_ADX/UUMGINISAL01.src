#<AdxTL>@(#)7.0.0.0 $Revision$
############################################################################
# UUMGINISAL01   Moulinette de Migration des devis           Module Ventes #
#                                                                          #
# Migration en V6 :                                                        #
# ---------------                                                          #
# Validation des masques SQH et ouverture                                  #
#                                                                          #
# Pour toutes les versions                                                 #
# ------------------------                                                 #
# Détail devis : SQUOTED                                                   #
# --------------------------                                               #
# Alim. SALFCY à partir de l'entête si différence                          #
############################################################################

Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGINISAL01") From LECFIC
  Endif

  #Call RAZ_UUMGINISAL01(DOSSIER)
  Call MAJ_UUMGINISAL01(DOSSIER)

  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End
##########################################################################
Subprog MAJ_UUMGINISAL01(DOSSIER)
Value Char DOSSIER

# Issue 106947 - 20150811 by LD : Migration of historic folder
#adxftl=10
#adxwrb=10
#NEWMOTEUR=1
# Issue 106947 - 20150811 by LD

Local Integer TOTNBR
Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

#----- Récupération du n° de version
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL01",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif

Local Char WNAMSQHM,WNAMSQDM
Call MIGTABNAME (DOSSIER,"SQUOTE", WNAMSQHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SQUOTED",WNAMSQDM,ERR) From TRTMIG
If ERR
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL01",7,ERR) From TRTMIG : #7=Erreur
  End
Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMSQHM, "fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
If filinfo(filpath("FIL",WNAMSQDM, "fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL01",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL01",2,ERR) From TRTMIG : #2=En cours

###################

Call ECR_TIME("UUMGINISAL01 Sales Quote Process : Update SQUOTE-D") From DOSSUB
Call ECR_TRACE("UUMGINISAL01 : Process Start on : "+DOSSIER,0) From GESECRAN

#----- Modification des fichiers où on va inserer -----#
Gosub MIG_OUVRE From TRTMIG

#----- SQUOTE => TOTNBR= Number of lines  -----#
Call MIGGETTOTNBR (DOSSIER,"SQUOTE",TOTNBR,ERR) From TRTMIG
Trbegin [AMY]
Call MIGSTKTOTNBR (DOSSIER,"UUMGINISAL01",TOTNBR,ERR) From TRTMIG
Commit

#----- Ouverture des fichiers -----#
If clalev([F:SQHM]) = 0 : Local File =DOSSIER+"."+WNAMSQHM   [SQHM] : Endif   # Fichier X3 renommé Avant Migration
If clalev([F:SQDM]) = 0 : Local File =DOSSIER+"."+WNAMSQDM   [SQDM] : Endif   # Fichier X3 renommé Avant Migration

#-----  Déclaration des variables -----#
# Déclaration des variables pour gérer les ruptures (évite les snapshot too old)
Local Integer NBLUS, NBCOMMIT
Local Integer NBMIGKEY : NBMIGKEY=3
Local Char TABMIGKEY(30)(1..NBMIGKEY)
Raz NBLUS, NBCOMMIT

# Validation des écrans

# Issue 106947 - 20150811 by LD : Migration of historic folder
# Passage en V6
If VERSION<GMIGX3VER60
    Local Char WHISTFOLD(GLONADS)
    If func DOSSUB.ISHISTFOLD([F:ADS]DOSSIER)=0
        WHISTFOLD=[F:ADS]DOSSIER
    Else
        WHISTFOLD=[F:ADS]DOSREF
    Endif

    #Call VALIDDIRECT ("SQH0",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    #If GOK<>1
    #  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL01",7,ERR) From TRTMIG : #7=Erreur
    #  Goto FIN
    #Endif
    #Call VALIDDIRECT ("SQH1",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    #If GOK<>1
    #  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL01",7,ERR) From TRTMIG : #7=Erreur
    #  Goto FIN
    #Endif
    #Call VALIDDIRECT ("SQH2",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    #If GOK<>1
    #  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL01",7,ERR) From TRTMIG : #7=Erreur
    #  Goto FIN
    #Endif
    #Call VALIDDIRECT ("SQH3",[F:ADS]DOSSIER,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    #If GOK<>1
    #  Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL01",7,ERR) From TRTMIG : #7=Erreur
    #  Goto FIN
    #Endif
    #Local Mask =DOSSIER+".SQH0"    [SQH0]
    #Local Mask =DOSSIER+".SQH1"    [SQH1]
    #Local Mask =DOSSIER+".SQH2"    [SQH2]
    #Local Mask =DOSSIER+".SQH3"    [SQH3]

    Call VALIDDIRECT ("SQH0",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    If GOK<>1
      Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL01",7,ERR) From TRTMIG : #7=Erreur
      Goto FIN
    Endif
    Call VALIDDIRECT ("SQH1",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    If GOK<>1
      Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL01",7,ERR) From TRTMIG : #7=Erreur
      Goto FIN
    Endif
    Call VALIDDIRECT ("SQH2",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    If GOK<>1
      Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL01",7,ERR) From TRTMIG : #7=Erreur
      Goto FIN
    Endif
    Call VALIDDIRECT ("SQH3",WHISTFOLD,1,[F:ADS]LANDEF,1,GOK) From VALMSK
    If GOK<>1
      Call MIGSTKENDFLG (DOSSIER,"UUMGINISAL01",7,ERR) From TRTMIG : #7=Erreur
      Goto FIN
    Endif

    Local Mask =WHISTFOLD+".SQH0"   [SQH0]
    Local Mask =WHISTFOLD+".SQH1"   [SQH1]
    Local Mask =WHISTFOLD+".SQH2"   [SQH2]
    Local Mask =WHISTFOLD+".SQH3"   [SQH3]
Endif
# Issue 106947 - 20150811 by LD

#-----  Lecture des clés -----#
# Read de la table AMIGKEY "index migration" pour alimenter ACLE1/ACLE2/ACLE3/STOP
Call MIGGETKEY (DOSSIER,"UUMGINISAL01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG

If NBCOMMIT=0
  Gosub TRT_SQL
  If GOK<1 : Goto FIN : Endif
  Trbegin [AMY]
  NBLUS=TOTNBR
  NBCOMMIT=TOTNBR
  Call MIGSTKKEY (DOSSIER,"UUMGINISAL01",NBMIGKEY,TABMIGKEY,NBLUS,NBCOMMIT,ERR) From TRTMIG
  Commit
Endif


$FIN
Close Local File [SQDM], [SQHM]

Call ECR_TIME("UUMGINISAL01 : "+num$(NBLUS)+" records read,"-num$(NBCOMMIT)+" records processed.") From DOSSUB

Call MIGTRTEND (DOSSIER,"UUMGINISAL01") From TRTMIG
End

##########################################################################
Subprog RAZ_UUMGINISAL01(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : # N= no module
  End
Endif

Local Char WNAMSQHM,WNAMSQDM
Call MIGTABNAME (DOSSIER,"SQUOTE", WNAMSQHM,ERR) From TRTMIG
Call MIGTABNAME (DOSSIER,"SQUOTED",WNAMSQDM,ERR) From TRTMIG
If ERR : End : Endif

#----- Présence des fichiers renommées...  -----#
If filinfo(filpath("FIL",WNAMSQHM, "fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table
If filinfo(filpath("FIL",WNAMSQDM, "fde",DOSSIER),0)<0 : End : Endif   : # XXXXXXM= code table

##2 - On vide les fichiers selon le cas
#######################################

##3 - On vide AMIGKEY pour le flux
####################
Call MIGRAZKEY (DOSSIER,"UUMGINISAL01",ERR) From TRTMIG
Call MIGRAZKEY (DOSSIER,"UUMGINISAL01/VALORISATION",ERR) From TRTMIG

End
########################################################################
$TRT_SQL

#2- alimenter la nouvelle colonne si vide

#-----  Déclaration des variables -----#

Call DEBTRANS From GLOCK
Gosub SET_FIRST From TRTFIRST

Trbegin [SQDM]
GOK = 1

Gosub TRT_SQL1

If GOK<1
  Rollback
Else
  Commit
Endif

Gosub UNSET_FIRST From TRTFIRST

Return

########################################################################
$TRT_SQL1
Local Char REQSQL (250) (3)

Onerrgo ERR_SQL
REQSQL(0)="UPDATE"-DOSSIER+"."+WNAMSQDM+" SET SALFCY_0="
REQSQL(1)="(SELECT SQH.SALFCY_0 FROM"-DOSSIER+"."+WNAMSQHM+" SQH Where SQH.SQHNUM_0="+WNAMSQDM+".SQHNUM_0)"
REQSQL(2)=" WHERE "+WNAMSQDM+".SALFCY_0<>(SELECT SQH.SALFCY_0 From"-DOSSIER+"."+WNAMSQHM+" SQH Where SQH.SQHNUM_0="+WNAMSQDM+".SQHNUM_0) "

Execsql From num$(GTYPDBA*2+1) Sql REQSQL
Onerrgo
Return

###################################################################################################
$ERR_SQL
GMESSAGE = errp-"("+num$(errl)+")"+"\"+mess(6,123,1)-num$(errn)-":"-errmes$(errn)+"\"+errm
Call ECR_TRACE(GMESSAGE,1) From GESECRAN
GOK=0
Resume

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 106947 - 20150811 by LD : Migration of historic folder
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
# Issue 106947 - 20150811 by LD
Call MAJ_UUMGINISAL01(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGINISAL01(APPLI)
End

