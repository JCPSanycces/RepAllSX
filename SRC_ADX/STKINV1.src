#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################
# FORMAT_INV_SNLSERE   Chargement des formats (invisibles) écran SNLSERE
########################################################################
$FORMAT_INV_SNLSERE
# LOTMGTCOD  politique gestion lot
#            1 = Non
#            2 = Oui facultatif
#            3 = Oui obligatoire
#            4 = Oui obligatoire + Sous lot
GWSINVLOT   = GSINVLOT
GWSINTLOT   = GSINTLOT
GWSINVSLO   = GSINVSLO
GWSINTSLO   = GSINTSLO
GWSINVEMP   = GSINVEMP
GWSINTEMP   = GSINTEMP

If [F:ITM]LOTMGTCOD = 1
   GWSINVLOT   = "-"+GSINVLOT
   GWSINVSLO   = "-"+GSINVSLO
   GWSINTLOT   = ""
   GWSINTSLO   = ""
Else
   GWSINVLOT   = GSINVLOT
   GWSINTLOT   = GSINTLOT
Endif

If [F:ITM]LOTMGTCOD = 4
   GWSINVSLO   = GSINVSLO
   GWSINTSLO   = GSINTSLO
Else
   GWSINVSLO   = "-"+GSINVSLO
   GWSINTSLO   = ""
Endif
If [F:ITF]LOCMGTCOD<>2
   GWSINVEMP = "-"+GSINVEMP
   GWSINTEMP = ""
Else
   GWSINVEMP = GSINVEMP
   GWSINTEMP = GSINTEMP
Endif

# Article géré en version ou non
GWSINVECCMAJ = "-"+GSINVECCMAJ
GWSINVECCMIN = "-"+GSINVECCMIN
If [F:ITM]ECCSTO > 1
   GWSINVECCMAJ = GSINVECCMAJ
Endif
# Article site non géré en version
If [F:ITM]ECCFLG <2
   GWSINVECCMAJ = "-"+GSINVECCMAJ
Endif

Return

########################################################################
# CTR_CUD_CSD   Controle cohérence CUNLISDET / CUNSERDET
########################################################################
$CTR_CUD_CSD
Raz WOK
Local Decimal WQTY

Local Char LITMNUM
Local Char LITM
Local Char LLOT
Local Char LSLO
Local Char LLOC
Local Char LSTA
Local Char LPCU
Local Char LQTYSTU
Local Char LQTYSTUNEW
Local Char LECA
Call TEXTFIC("CUNLISDET","ITMLISNUM",2,LITMNUM)    From OBJDIV
Call TEXTFIC("CUNLISDET","ITMREF",2,LITM)          From OBJDIV
Call TEXTFIC("CUNLISDET","LOT",2,LLOT)             From OBJDIV
Call TEXTFIC("CUNLISDET","SLO",2,LSLO)             From OBJDIV
Call TEXTFIC("CUNLISDET","LOC",2,LLOC)             From OBJDIV
Call TEXTFIC("CUNLISDET","STA",2,LSTA)             From OBJDIV
Call TEXTFIC("CUNLISDET","PCU",2,LPCU)             From OBJDIV
Call TEXTFIC("CUNLISDET","QTYSTU",2,LQTYSTU)       From OBJDIV
Call TEXTFIC("CUNLISDET","QTYSTUNEW",2,LQTYSTUNEW) From OBJDIV

# Lecture la table CUNSERDET
Filter [CSD] Where [F:CSD]CUNSSSNUM = [F:CUD]CUNSSSNUM &
&                  [F:CSD]CUNLISNUM = [F:CUD]CUNLISNUM &
&                  [F:CSD]SERSEQ    = [F:CUD]SERSEQ
&             Order By Key CSD0

For [CSD]
     WQTY += [F:CSD]QTY
Next
Filter [CSD]

If WQTY <> abs([F:CUD]QTYSTUNEW-[F:CUD]QTYSTU)
   WOK = 9
   MES = mess(246,199,1)+"\" # Le nb de no série ne correspond pas à la qté à traiter
   MES += LITMNUM+" : "+ num$([F:CUD]ITMLISNUM)+"\"
   MES += LITM+" : "+ [F:CUD]ITMREF+"\"
   If [F:CUD]LOT <> ""
      MES += LLOT+" : "+ [F:CUD]LOT+"\"
   Endif
   If [F:CUD]SLO <> ""
      MES += LSLO+" : "+ [F:CUD]SLO+"\"
   Endif
   If [F:CUD]LOC <> ""
      MES += LLOC+" : "+ [F:CUD]LOC+"\"
   Endif
   MES += LSTA+" : "+ [F:CUD]STA+"\"
   MES += LPCU+" : "+ [F:CUD]PCU+"\"
   MES += LQTYSTU+" : "+ num$([F:CUD]QTYSTU)+"\"
   MES += LQTYSTUNEW+" : "+ num$([F:CUD]QTYSTUNEW)+"\"
   MES += mess(654,199,1)+" : " +num$([F:CUD]QTYSTUNEW-[F:CUD]QTYSTU)+"\"
   Call ERREUR(MES) From GESECRAN
Endif
Return


########################################################################
# DEL_CSD                       suppression des séries d'une liste
#          LFCY : Site
#          LSSS : Numéro de session
#          LLIS : Numéro de liste
#                 Si LLIS = "" suppression de toute la session
#          LNUM : Numéro de ligne inventaire (ITMLISNUM)
#                 Si LNUM =  0 suppression de toute la liste d'inventaire
#                 Si LNUM <> 0 suppression d'une ligne d'inventaire de la liste
#          LRET : Code retour
########################################################################
Subprog DEL_CSD(LFCY,LSSS,LLIS,LNUM,LRET)
Value    Char    LFCY
Value    Char    LSSS
Value    Char    LLIS
Value    Integer LNUM
Variable Integer LRET

LRET = 2
If LLIS = ""
   Delete [F:CSD] Where STOFCY     = LFCY      &
&                       CUNSSSNUM  = LSSS
Else
   If LNUM = 0
      Delete [F:CSD] Where STOFCY     = LFCY      &
&                          CUNSSSNUM  = LSSS      &
&                          CUNLISNUM  = LLIS
   Else
      Delete [F:CSD] Where STOFCY     = LFCY      &
&                          CUNSSSNUM  = LSSS      &
&                          CUNLISNUM  = LLIS      &
&                          SERSEQ     = LNUM
   Endif
Endif
If clalev([M:SNLSW])=0 Local Mask SNLSEREW   [SNLSW] Endif
Raz [M:SNLSW]
End

########################################################################
# REC_SERSEQ_CUD                   recherche prochain SERSEQ d'une liste
#                   LFCY = Site
#                   LSSS = Numéro de session
#                   LLIS = Numéro de liste
#                   LSEQ = Dernier SERSEQ de la liste + 1
#                   LRET = Code retour
########################################################################
Subprog REC_SERSEQ_CUD(LFCY,LSSS,LLIS,LSEQ,LRET)
Value    Char    LFCY
Value    Char    LSSS
Value    Char    LLIS
Variable Integer LSEQ
Variable Integer LRET
Raz LSEQ
Raz LRET
Local File CUNLISDET [CUD1]
# Recherche dernier no de séquence
Columns [CUD1] (SERSEQ)
Filter [CUD1] Where CUNSSSNUM =  LSSS
&                 & CUNLISNUM =  LLIS
&                 & SERSEQ    <> 0
Read [CUD1]CUD0 Last
If !fstat
   LSEQ=[F:CUD1]SERSEQ+1
Endif
Filter  [CUD1]
Columns [CUD1]

End

########################################################################
# ECR_CSD                                      ecriture table CUNSERDET
#              LFCY : site
#              LSSS : session
#              LLIS : liste
#              LSEQ : séquence
#              LANU : si = 2  annulation des séres (stock nul)
#              LRET : code retour
########################################################################
Subprog ECR_CSD(LFCY,LSSS,LLIS,LSEQ,LANU,LRET)
Value    Char    LFCY
Value    Char    LSSS
Value    Char    LLIS
Value    Integer LSEQ
Value    Integer LANU
Variable Integer LRET
Local    Integer I
# supression de CUNSERDET pour SERSEQ

Delete [F:CSD] Where STOFCY     = LFCY      &
&                    CUNSSSNUM  = LSSS      &
&                    CUNLISNUM  = LLIS      &
&                    SERSEQ     = LSEQ
If LANU = 2
   End
Endif

# boucle sur le masque SNLSEREW et ecriture CUNSERDET
Raz [F:CSD]
[F:CSD]CUNSSSNUM = LSSS
[F:CSD]CUNLISNUM = LLIS
[F:CSD]SERSEQ    = LSEQ
[F:CSD]STOFCY    = LFCY
For I = 0 To [M:SNLSW]NBLIG-1
    If [M:SNLSW]SERSEQ(I) = LSEQ
       [F:CSD]QTY         = [M:SNLSW]QTY     (I)
       [F:CSD]SERDEB      = [M:SNLSW]SERNUM  (I)
       [F:CSD]SERFIN      = [M:SNLSW]SERNUMF (I)
       [F:CSD]ECART       = [M:SNLSW]ECART   (I)
       [F:CSD]SERIND      = I+1
       GPOINT = "WRICSD"
       Gosub  ENTREE From EXEFNC
       Write [CSD]
       If fstat
         GOK  = 0
         LRET = 9
         Call FSTA("CSD") From GLOCK
         End
       Endif
    Endif
Next

End
########################################################################
# CTR_SNLSERE               Controle que les séries ont bien ete saisies
#                           lors de l enregistrement du comptage
#              LSEQ : séquence
#              LNOL : numéro de ligne
#              LITM : article
#              LECA : écart de la ligne
#              LRET : code retour
########################################################################
Subprog CTR_SNLSERE(LSEQ,LNOL,LITM,LECA,LRET)
Value    Integer LSEQ
Value    Integer LNOL
Value    Char    LITM
Value    Decimal LECA
Variable Integer LRET
# lecture de l article
If [F:ITM]ITMREF <> LITM
   Read [F:ITM]ITM0=LITM
   If fstat
      Raz [F:ITM]
   Endif
Endif
# si LECA est > 0 (donc une entrée) et que le compteur serie est renseigné  la saisie n est pas obligatoire
If LECA > 0 & [F:ITM]SERCOU <> ""
   End
Endif
# si LECA est > 0 (donc une entrée) et que le compteur serie n'est ps renseigné  la saisie est obligatoire
# si LECA est < 0 (donc une sortie) : saisie obligatoire

# controle que les numéros de serie ont bien ete saisie
If !find(LSEQ,[M:SNLSW]SERSEQ(0..[M:SNLSW]NBLIG-1))
   Call ERREUR(mess(61,100,1)-num$(LNOL+1)-":"-mess(312,184,1)) From GESECRAN     # Les no série n'ont pas été renseignés
   LRET=-1
   End
Endif

End

########################################################################
# CAL_GOUVSNLS         détermination GOUVSNLS ouverture fenetre ISNLSERE
#              LABR : masque
#              LNOL : numéro de ligne
########################################################################
Subprog CAL_GOUVSNLS(LABR,LNOL)
Value Char    LABR
Value Integer LNOL
Local Char    LMABR(10)  : LMABR = "[M:"+LABR+"]"
Local Char    LITM
Local Decimal LCOU
Local Integer LSEQ
Local Char    LECA
Local Integer LRET
Raz GOUVSNLS
If clalev([F:STS])=0  Local File STOSER [STS]  Endif
#si multicomptage il faut que comptage 1 et 2 soient fait
If [M:SNL0]MULCTGFLG = 2
   If evalue(LMABR+"CTG1(LNOL)") <> 2
      End
   Endif
   If evalue(LMABR+"CTG2(LNOL)") <> 2
      End
   Endif
Endif
# il faut un écart sur la ligne
If evalue(LMABR+"QTYSTUDEV(LNOL)") = 0 & evalue(LMABR+"QTYSTUNEW(LNOL)") <> 0
   End
Endif

If LABR = "SNL0"
   LITM = evalue("[M:"+LABR+"]ITMREF    (LNOL)")
Else
   LITM = evalue("[M:"+LABR+"]ITMREF")
Endif
LSEQ    = evalue("[M:"+LABR+"]SERSEQ    (LNOL)")
LCOU    = evalue("[M:"+LABR+"]STOCOU    (LNOL)")
# si "Stock nul" pas d'ouverture mais stockage dans le masque SNLSEREW
If evalue(LMABR+"ZERSTOFLG(LNOL)") = 2
   If evalue(LMABR+"QTYSTUDEV(LNOL)") < 0
      LECA = "S"
   Else
      LECA = "E"
   Endif
   Call CHARG_SNLSW_DEB_FIN(LITM,LCOU,LSEQ,LECA,LRET) From STKINV1
   End
Endif
GOUVSNLS = 1
End



#################################################################################
# CHARG_SNLSW_DEB_FIN   Chargement de l'écran SNLSEREW à partir de la table STOSER
#                     # LITM  Article
#                     # LCOU  STOCOU
#                     # LSEQ  SERSEQ
#                     # LRET  Code retour
#################################################################################
Subprog CHARG_SNLSW_DEB_FIN(LITM,LCOU,LSEQ,LECA,LRET)
Value    Char    LITM
Value    Decimal LCOU
Value    Integer LSEQ
Value    Char    LECA
Variable Integer LRET

Local Char    PSER(GLONSER)
Local Integer I
Local Integer Y

#---- stockage dans le masque SNLSEREW
# si des lignes SERSEQ existent deja dans le masque SNLSEREW => suppression
I    = 0
Y    = 0
LRET = 0

For I = 0 To [M:SNLSW]NBLIG-1
    If I > [M:SNLSW]NBLIG
           [M:SNLSW]NBLIG = I
       Break
    Else
       If LSEQ    = [M:SNLSW]SERSEQ  (I)
          Dela I,1 [M:SNLSW]NBLIG
          I    -= 1
          [M:SNLSW]NBLIG -= 1
       Endif
    Endif
Next I
Y = [M:SNLSW]NBLIG
I = 0
Filter [STS] Where [F:STS]ITMREF = LITM &
&                  [F:STS]STOCOU = LCOU
&             Order By Key STS3
For [STS]
    If [M:SNLSW]SERNUM  (Y) = ""
       [M:SNLSW]QTY     (Y) = 1
       [M:SNLSW]SERNUM  (Y) = [F:STS]SERNUM
       [M:SNLSW]SERNUMF (Y) = [F:STS]SERNUM
       [M:SNLSW]SERSEQ  (Y) = LSEQ
       [M:SNLSW]ECART   (Y) = LECA
       [M:SNLSW]ITMREF  (Y) = LITM
       [M:SNLSW]STOCOU  (Y) = LCOU
    Else
       PSER = [M:SNLSW]SERNUMF (Y)
       Call PLUS_UN(PSER,PSER,LRET) From STKLIB
       If PSER = [F:STS]SERNUM
          [M:SNLSW]SERNUMF (Y) = [F:STS]SERNUM
          [M:SNLSW]QTY     (Y) += 1
       Else
           Y += 1
          [M:SNLSW]QTY     (Y) = 1
          [M:SNLSW]SERNUM  (Y) = [F:STS]SERNUM
          [M:SNLSW]SERNUMF (Y) = [F:STS]SERNUM
          [M:SNLSW]SERSEQ  (Y) = LSEQ
          [M:SNLSW]ECART   (Y) = LECA
          [M:SNLSW]ITMREF  (Y) = LITM
          [M:SNLSW]STOCOU  (Y) = LCOU
       Endif
    Endif
    I = 1
 Next
[M:SNLSW]NBLIG = Y+I

Filter [STS]
End
#################################################################################
# alimentation de l'écran STOWORK avec la table CUNSERDET
#################################################################################
$ALI_STW_CSD

Local Integer WLEC
Raz WLEC
# Lecture la table CUNSERDET
Filter [CSD] Where [F:CSD]CUNSSSNUM = [F:CUD]CUNSSSNUM &
&                  [F:CSD]CUNLISNUM = [F:CUD]CUNLISNUM &
&                  [F:CSD]SERSEQ    = [F:CUD]SERSEQ
&             Order By Key CSD0

For [CSD]
     WLEC +=1
     If WLEC = 1
        [M:STW]QTYSTU (NOL)   = [F:CSD]QTY
        [M:STW]QTYPCU (NOL)   = [F:CSD]QTY
        [M:STW]QTYSTUACT(NOL) = [F:CSD]QTY
        [M:STW]PCUSTUCOE(NOL) = 1
        [M:STW]SERNUM (NOL)   = [F:CSD]SERDEB
        [M:STW]SERNUMF(NOL)   = [F:CSD]SERFIN
        Gosub ORI_CUNLISDET_SVW From STKINT
     Else
        nolign += 1
        L = NOL
        NOL +=1
        If NOL >= ACTSTW
           GMESSAGE = mess(490,199,1)
           Gosub TRT_ERR From STKINT
           LRET = 4
           Break 2
        Endif
        Gosub ALI_NEW_STW From STKMAJ
        [M:STW]STOCOU   (L+1) =[M:STW]STOCOU(L)
        [M:STW]MAJCOD   (L+1) =[M:STW]MAJCOD(L)
        [M:STW]QTYSTU   (L+1) = [F:CSD]QTY
        [M:STW]QTYPCU   (L+1) = [F:CSD]QTY
        [M:STW]QTYSTUACT(L+1) = [F:CSD]QTY
        [M:STW]PCUSTUCOE(NOL) = 1
        [M:STW]SERNUM   (L+1) = [F:CSD]SERDEB
        [M:STW]SERNUMF  (L+1) = [F:CSD]SERFIN
        Gosub ORI_CUNLISDET_SVW From STKINT
        [M:STW]NBLIG +=1
     Endif
Next
Filter [CSD]

Return



########################################################################
# CTR_SENS                   Controle du sens  de l écart
#              LFCY : site
#              LSSS : session
#              LLIS : liste
#              LSEQ : séquence
#              LANU : si = 2  annulation des séres (stock nul)
#              LRET : code retour
########################################################################
$CTR_SENS
Local Integer WOK
Local Char    WECART
Local Char    WECARTNEW
Local Char    LMSKCOU
Local Integer WCUNLISSTA
Raz WOK
Raz WECART
Raz WECARTNEW
Raz LMSKCOU
Raz WCUNLISSTA
If GUSER = "HCB"
  # Dbgaff
Endif

LMSKCOU = func STKLIB.MSKDEF
If LMSKCOU = "[SNL0]"
   WCUNLISSTA = [M:SNL0]CUNLISSTAD(NOL)
Endif
If LMSKCOU = "[SNL1]"
   WCUNLISSTA = [M:SNL1]CUNLISSTA(NOL)
Endif
# si la ligne de stock est à "A compter" il ni a pas de controle
If WCUNLISSTA = 1
   Return
Endif

If [M]QTYSTUDEV(NOL) < 0
   WECART = "S"
Endif
If [M]QTYSTUDEV(NOL) > 0
   WECART = "E"
Endif
If [M]QTYSTUNEW(NOL)-[M]QTYSTU(NOL)  < 0
   WECARTNEW = "S"
Endif
If [M]QTYSTUNEW(NOL)-[M]QTYSTU(NOL)  > 0
   WECARTNEW = "E"
Endif

If WECART <> WECARTNEW
# Cette saisie inverse le sens de l'écart  : les numéros de séries saisis de type "Entrée & Sortie globale" seront effacés
   Call OUINON(mess(448,184,1),WOK) From GESECRAN
   If WOK <> 2
      mkstat = 2
      End
   Else
      Raz WOK
      If [M]SERSEQ(NOL) <> 0
         Call DEL_CSD([M]STOFCY,[M]CUNSSSNUM,[M]CUNLISNUM,[M]SERSEQ,WOK) From STKINV1
      Endif
      For I = 0 To [M:SNLSW]NBLIG-1
          If I > [M:SNLSW]NBLIG
                 [M:SNLSW]NBLIG = I
                 Break
          Else
             If [M:SNLSW]SERSEQ  (I) = [M]SERSEQ(NOL)
                Dela I,1 [M:SNLSW]NBLIG
                I    -= 1
                [M:SNLSW]NBLIG -= 1
             Endif
          Endif
      Next I
   Endif
Endif
Return

######################################################################################################
# verification que la quantité de la ligne de stock soit égale au nb de no série présents sur ce stock
#                              SNU4 :  Visu liste
#                              SNL0 :  Comptage regroupement
#                              SNL1 :  Comptage détail
#                              SIW  :  Creation inventaire
######################################################################################################
$VERIF_DESYNCHRO
Local Char    LITM(GLONITM)
Local Decimal LCOU
Local Decimal LQTY
Local Decimal WQTYSTS
Local Integer WIND
Local Char    LMSKCOU : LMSKCOU = func STKLIB.MSKDEF
Raz   WIND
Case LMSK
     When "SNU4"
          LITM =  [M:SNU4]ITMREF(LLLG)
          LCOU =  [M:SNU4]STOCOU(LLLG)
          LQTY =  [M:SNU4]QTYSTU(LLLG)
     When "SNL0"
          LITM =  [M:SNL0]ITMREF(LLLG)
          LCOU =  [M:SNL0]STOCOU(LLLG)
          LQTY =  [M:SNL0]QTYSTU(LLLG)
     When "SNL1"
          LITM =  [M:SNL1]ITMREF
          LCOU =  [M:SNL1]STOCOU(LLLG)
          LQTY =  [M:SNL1]QTYSTU(LLLG)
     When "SIW"
          LITM =  [F:STO]ITMREF
          LCOU =  [F:STO]STOCOU
          LQTY =  [F:STO]QTYSTU
          Raz WRET
     When Default
Endcase
Call VERIF_DESYNCHRO_SERIE(LITM,LCOU,LQTY,WIND) From STKLIB
If WIND = 2
   If LMSK <> "SIW"
      Default Mask "["+LMSK+"]"
      Chgstl [M]NBLIG(LLLG) With "STKSERDSY"      # série désynchronisé
      If LMSK <> "SNU4"
         [M]QTYPCUNEW       (LLLG) = [M]QTYPCU   (LLLG)
         [M]QTYSTUNEW       (LLLG) = [M]QTYSTU   (LLLG)
         If LMSK = "SNL0"
            [M]PCUSTUNEW    (LLLG) = format$("N>:5.6",[M]PCUSTUCOE (LLLG))
         Else
            [M]PCUSTUNEW    (LLLG) = [M]PCUSTUCOE(LLLG)
         Endif
         [M]MODFLG          (LLLG) = 2
         [M]QTYSTUDEV       (LLLG) = 0
         Grizo [M]QTYPCUNEW (LLLG)
         Grizo [M]QTYSTUNEW (LLLG)
         Grizo [M]PCUSTUNEW (LLLG)
         Grizo [M]ZERSTOFLG (LLLG)
      Endif
   Else
      WRET = 4
      WQTYSTS = rowcount([F:STS])
   Endif
Endif
Filter [STS]
Return


#                                                                     # hcb x3-68147  deb
########################################################################
# CTR_CUD_LPN   Controle cohérence contenant / emplacement
########################################################################
Subprog CTR_CUD_LPN(LSSS,LLIS,LLPN,LLOC,LRET)
Value Char LSSS
Value Char LLIS
Value Char LLPN
Value Char LLOC
Variable Integer LRET
Raz LRET
# controle Controle cohérence contenant / emplacement dans les lignes ajoutées
# Lecture la table CUNLISDET
Filter [CUD1] Where [F:CUD1]CUNSSSNUM = LSSS                      &
&                   [F:CUD1]CUNLISNUM = LLIS                      &
&                   [F:CUD1]CUNLISSTA < 3                         &
&                   [F:CUD1]LPNNUM    = LLPN                      &
&                   [F:CUD1]LOC       <> "" & [F:CUD1]LOC <> LLOC &
&                   [F:CUD1]STOCOU = 0
&             Order By Key CUD0

For [CUD1]
    LRET = 9
#   Les stocks à mettre dans le contenant xxx ne sont pas tous dans le même emplacement yyy
    Call ERREUR(func AFNC.MES2(mess(521,184,1),[F:CUD]LPNNUM,[F:CUD]LOC)) From GESECRAN
    Break
Next
Filter [CUD1]
End
#                                                                     # hcb x3-68147  fin

