If !mkstat
 ## Action STD
 Call C_LOCMGTCOD(VALEUR) From SUBITF
 If mkstat : GERR = 1 : GZONE = "LOCMGTCOD" : GZNUM = 5147 : Endif
Endif
Gosub _AFF
End

