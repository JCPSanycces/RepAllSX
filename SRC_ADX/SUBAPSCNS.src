Call SETDEBUGJON From ZZJPJDBG

Raz GPILOBJ,GNBMASKOUV,GMESSAGE
GCONSULT = 0

#Dbgaff
#Gosub FERME_BOITE From "WGWMALOSTD"    #=WINPROG
#Goto TESTALO
#Goto TESTAUD
Goto TESTAWW
#Goto TESTSUITE
End

# -----------------------------------------------------------
# SUBAPSCNS
# Version 003
#    Serveur de consultations
#        U_VIEWCODE        Code de la vue portail
#        [F:APV]           Enreg. en ligne de la table Vue portail (APTLVW)
#        M_ACTION          Code de l'action à traiter soumis par le provider Htc
#
#    002 - Gestion retour $PTL_INI
#    E60574 - Evalue - Pb parenthese
#    E60657 - Intitulés des boutons entre double quotes
#    003
#    E63631 - Routine calcul format (heure , date)
# -----------------------------------------------------------
# Gestion des niveaux type stat non faite --> tj niveau 1

# -----------------------------------------------------------
$C_EXECUTE                         # Init + type de dialogue
    #Call SETDEBUGJON From ZZJPJDBG
    # Trace
    U_TRAMES="--> Debut: " + "Serveur de consultations du portail": Gosub U_TRAPUT From SUBAPSUTI 

    ### Initialisations ###
    Gosub C_INIT
    # Code consultation
    C_CNSCODE = [F:APV]SRCCOD
    C_PROGCNS = "WWCNS" + C_CNSCODE

    # Code action equivalent prgrm consultation
    Case M_ACTION
    When CQ_ACTINIT
        C_ACTCNS = CQ_CNSFIRST
    When Default
        U_MESCODE="X3ACTUNKNOWN" : U_MESP1=M_ACTION : U_MESP2= [F:APV]SRCCODTYP : U_ERR=UC_ERRG 
        Gosub U_MESPUT From SUBAPSUTI : Goto C_EXE_END
    Endcase

    # Lecture des paramètres sources de données
    Raz C_CNSECR, C_CNSMAXROW
    For CW_I=0 To [F:APV]SRCPARNBR-1
        C_LSTPARCOD(CW_I)=[F:APV]SRCPARCOD(CW_I)
        U_PARCODE=C_LSTPARCOD(CW_I) : Gosub U_PARSRCREAD From SUBAPSUTI : If U_ERR=UC_ERRG : Break : Endif
        C_LSTPARVALC(CW_I)=U_PARVAL
        C_LSTPARVALN(CW_I) = U_PARVALTYP
        Case U_PARVALTYP
        When 3 # numérique
            C_LSTPARVALN(CW_I)=U_PARVALNUM
        When 7 # date
            C_LSTPARVALD(CW_I)=U_PARVALDAT
        Endcase
        # Code ecran consultation
        If C_LSTPARCOD(CW_I) = CC_CNSECRCOD : C_CNSECR = U_PARVAL : Endif
        # Nb de ligne maxi à retourner
        If C_LSTPARCOD(CW_I) = CC_CNSMAX    : C_CNSMAXROW = val(U_PARVAL) : Endif
    Next
    If U_ERR=UC_ERRG : Return : Endif



    #-- Appel Gestion initialisation consultation
    #-    Redéfiniton de certaines varaibles pour utiliser le modèle consultation en batch
    # - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 
    Local Char CNSCOD(GLONACN) : CNSCOD=C_CNSCODE
    Local Char CECRAN(GLONAMK) : CECRAN=C_CNSECR

    # Paramétres de l'action
    Gosub C_LDCNSACT

    # Initialisation consultation
    Gosub PTL_INI From SUBAPSCNS1                 # <-----
    If EXPSTA
        U_MESCODE="X3MES": U_MESP1=EXPMES: U_MESP2=""  : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI
        Goto C_EXE_END
    Endif

    #-- Appel Gestion infos consultation
    # Retour de PTL_INFOS:
    #    C_CNSTITLE    Titre consultation
    #    C_CNSMASKABR  Abr. mask support de l'échange des données (sous la forme [M:XXX] )
    #
    #    C_CLSCOD      Liste des codes des colonnes à présenter (code du champs dans le mask ci-dessus)
    #    C_CLSTITLE    Liste des libelles des colonnes
    #    C_CLSTYP      Liste des types des colonnes - valeurs issues du menu local 30
    #    C_CLSMNL      Liste des numéro menu local des colonnes ( le cas échant )
    #    C_CLSLNG      Liste des format sous forme 12.4 des colonnes ( le cas échant )
    #    C_CLSFMT      Liste des format exploitatable par format$
    #    C_CLSNB       Nb de colonnes 
    Gosub PTL_INFOS From SUBAPSCNS1               # <-----
    If EXPSTA
        U_MESCODE="X3MES": U_MESP1=EXPMES: U_MESP2=""  : U_ERR=UC_ERRG : Gosub U_MESPUT From SUBAPSUTI
        Goto C_EXE_END
    Endif
    Gosub C_INITDYN

    Gosub ISGETACT    # existence getact/wwcns[code]


    #-- Debut boucle lecture données par chargement d'écrans
    # - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - 
    # Ouverture XML 
    U_SEQPUT=' <Data>' : Gosub U_PUT From SUBAPSUTI         
    # Données
    CW_NBREC=0
    #If GUSER="JPJ1" : Dbgaff : Endif
    Gosub PAG_PREM From GCONSULT                  # <-----
    #lignes
    U_SEQPUT=' <Lines>' : Gosub C_SEQPUTDEC
$C_NXTPAG
    ## Ecriture Ecran en cours
    For CW_ROW=0 To evalue(C_CNSMASKABR+"NBLIG -1")
        CW_NBREC+=1
        Gosub C_LINEPUT
        If (CW_NBREC=C_CNSMAXROW)   # Trop de données (cas fonctionnel)
            # warning
            U_MESCODE="X3RESULTNOTALL" : U_ERR=UC_ERRW : Gosub U_MESPUT From SUBAPSUTI 
            Break
        Endif
        If U_OUTFLGMAX  # Trop de données (cas technique)
            Break
        Endif
    Next
    # Passage au suivant
    If (C_CNSMAXROW=0 or CW_NBREC<C_CNSMAXROW) & !U_OUTFLGMAX & SUITE<>1 & SUITE <>0
     Gosub PAG_SUIV From GCONSULT                 # <-----
     Goto C_NXTPAG
    Endif
    U_SEQPUT=' </Lines>' : Gosub C_SEQPUTDEC
   
    #-- Fin  boucle lecture données par chargement d'écrans


    # Titre (pas d'indication-Oui par défaut)
    U_QSCODE=CQ_TITLEOPT : Gosub U_QSREAD_UC From SUBAPSUTI
    If (!U_QSEXIST or (U_QSEXIST and  U_QSVAL<>UC_NO))
        Gosub C_TIT : If U_ERR=UC_ERRG : Goto ERRXMLCLOSE : Endif 
    Endif
    # Fermeture XML 
    U_SEQPUT=' </Data>' : Gosub U_PUT From SUBAPSUTI



    #-- Appel Gestion fermeture consultation
    Gosub PTL_FIN From SUBAPSCNS1                 # <-----

    
$C_EXE_END
    # Trace
    U_TRAMES="--> Fin: " + "Serveur de consultations du portail": Gosub U_TRAPUT From SUBAPSUTI 
    Setmode    # Pour être sur
Return


$ERRXMLCLOSE    
    # fermeture XML 
    U_SEQPUT=' </Data>' : Gosub U_PUT From SUBAPSUTI
    # Trace
    U_TRAMES="--> Fin avec ERREUR : " + "Serveur de consultations du portail": Gosub U_TRAPUT From SUBAPSUTI 
Return


  
# ------------------------------------------------------------
#     G O S U B
# ------------------------------------------------------------
# 

# - - - - - - - - - - - - - - - - - -
#   Données
# - - - - - - - - - - - - - - - - - -
$C_LINEPUT
    #--- ecriture ligne
    U_SEQPUT='  <Line ID="' + num$(CW_ROW+1) + '" >' : Gosub C_SEQPUTDEC
    
    #-- boutons contextuels (au début suite demande flash)
    Gosub C_GETROWINF   

    If C_LSTBTNTIT(0)<>""          # Un bouton est actif si !""
        U_SEQPUT='   <Actions>' : Gosub C_SEQPUTDEC
        # Raz TMPURL     #$$$$$$  pour test temp
        For CW_BTN=0 To CC_BTNMAX-1
            If C_LSTBTNTIT(CW_BTN)<>""     
                Call GETURLACT("CNS", C_LSTBTNINF(CW_BTN), CW_URL) From SUBAPSOBJ
                If CW_URL<>""        # Vérif. lg maxi autorisée
                     U_SEQPUT='   <Action X3Link=' : Gosub C_SEQPUTDEC        # En 2 ligne pour passer une chaine d'au moins 150
                     U_HEXTOTXT=CW_URL : Gosub U_TXTTOHEX From SUBAPSUTI
                     U_SEQPUT='"' + U_TXTTOHEX + '" >' :  Gosub U_PUT From SUBAPSUTI

                     U_HEXTOTXT=C_LSTBTNTIT(CW_BTN)  : Gosub U_TXTTOHEX From SUBAPSUTI
                     U_SEQPUT=U_TXTTOHEX             :  Gosub U_PUT From SUBAPSUTI       #E60657
                     
                     U_SEQPUT='   </Action>' : Gosub C_SEQPUTDEC
                Endif
            Endif
        Next
    U_SEQPUT='   </Actions>' : Gosub C_SEQPUTDEC
    Endif

    # -- Parcours des colonnes
    For CW_COL=0 to C_CLSNB-1
        CW_STREVAL = C_CNSMASKABR + C_CLSCOD(CW_COL) + "(" + num$(CW_ROW) + ")"
        Case C_CLSTYP(CW_COL)      # Type de données - valeurs issues du menu local 30
        When 1            # menu local
            CW_I=evalue(CW_STREVAL)
            CW_STRINTVAL=num$(CW_I)
            If CW_I<>0 and C_CLSMNL(CW_COL)<>0    # récupération message
                U_HEXTOTXT=mess(CW_I,C_CLSMNL(CW_COL),1) : Gosub U_TXTTOHEX From SUBAPSUTI
                CW_STRVAL=U_TXTTOHEX
            Else
                CW_STRVAL=""        # CW_STRINTVAL
            Endif
        When 2,3    # entier
            CW_I=evalue(CW_STREVAL)
            CW_STRINTVAL=num$(CW_I)

            CW_STRVAL=format$(C_CLSFMT(CW_COL),CW_I)    # E63631
            # CW_STRVAL=format$("Nz:8#",CW_I)  
        When 4,5,6        # décimal
            CW_DEC=evalue(CW_STREVAL)
            CW_STRINTVAL=num$(CW_DEC)

            CW_STRVAL=format$(C_CLSFMT(CW_COL),CW_DEC)    # E63631
            #If C_CLSLNG(CW_COL) <> 0    #  JPJ 50629
            #    CW_STRVAL=format$("N3zZ:" + num$(C_CLSLNG(CW_COL)),CW_DEC)         # JPJ 50629
            #Else 
            #    CW_STRVAL=format$("N3zZ:" + GFM92,CW_DEC)         # JPJ E24321
            #Endif
        When 7            # texte
            CW_STRVAL=format$(C_CLSFMT(CW_COL),evalue(CW_STREVAL))    # E63631
            U_HEXTOTXT=CW_STRVAL : Gosub U_TXTTOHEX From SUBAPSUTI     # JPJ E27480
            CW_STRVAL=U_TXTTOHEX                                    
            #CW_STRINTVAL=CW_STRVAL  
            CW_STRINTVAL=""
        When 8            # date
            CW_DAT=evalue(CW_STREVAL)
            If CW_DAT<>[00/00/00]
                CW_STRINTVAL=format$("D:YYYYMMDD",CW_DAT)     

                CW_STRVAL=format$(C_CLSFMT(CW_COL),CW_DAT)    # E63631
                #CW_STRVAL=format$("DPZ:"+GFMDAT, CW_DAT)
            Else
                CW_STRINTVAL="0"
                CW_STRVAL=""
            Endif
        When Default
            CW_STRINTVAL=""
            CW_STRVAL=""
        Endcase

        #-- Colonne
        U_SEQPUT='   <Col Num="' + num$(CW_COL+1) + '" X3Type="' + num$(C_CLSTYP(CW_COL))  + '" >': Gosub C_SEQPUTDEC

        # Attribut X3link (à activer pour un link par cellule)
        #U_SEQPUT='   <Col Num="' + num$(CW_COL+1) + '" ' : Gosub C_SEQPUTDEC
        #        If CW_COL<10 & TMPURL(CW_COL)<>""
        #                 U_SEQPUT=' X3Link=' : Gosub C_SEQPUTDEC
        #                 U_SEQPUT='"' + TMPURL(CW_COL) + '"' : Gosub U_PUT From SUBAPSUTI
        #        Endif
        #U_SEQPUT=' X3Type="' + num$(C_CLSTYP(CW_COL))  + '" >': Gosub C_SEQPUTDEC


        #  valeurs
        If C_CLSTYP(CW_COL) <> 7    # information non utile sur les textes
            If len(CW_STRINTVAL)>200 : CW_STRINTVAL=left$(CW_STRINTVAL,200)-"..." : Endif
            U_SEQPUT='     <X3IntVal>' + CW_STRINTVAL + '</X3IntVal>' : Gosub C_SEQPUTDEC
        Endif
        If len(CW_STRVAL)>200 : CW_STRVAL=left$(CW_STRVAL,200)-"..." : Endif
        U_SEQPUT='     <X3Value>' + CW_STRVAL + '</X3Value>' : Gosub C_SEQPUTDEC    # valeur avec conversion
        #  fin colonne
        U_SEQPUT="    </Col>": Gosub C_SEQPUTDEC
    Next CW_COL
        
    # fin ligne
    U_SEQPUT='   </Line>' : Gosub C_SEQPUTDEC
Return


# ------------------------------------------------------------
#  Accès aux titres des colonnes
# ------------------------------------------------------------
$C_TIT
    U_SEQPUT='<Titles>' : Gosub C_SEQPUTDEC
    U_HEXTOTXT=C_CNSTITLE : Gosub U_TXTTOHEX From SUBAPSUTI
    U_SEQPUT=' <Title>' + U_TXTTOHEX + '</Title>' : Gosub C_SEQPUTDEC
    For CW_COL=0 To C_CLSNB-1  # les colonnes
        U_HEXTOTXT=C_CLSTITLE(CW_COL) : Gosub U_TXTTOHEX From SUBAPSUTI
        U_SEQPUT=' <ColTitle Num="' + num$(CW_COL+1) +'" X3Type="'+ num$(C_CLSTYP(CW_COL)) +'">' + U_TXTTOHEX + '</ColTitle>' : Gosub C_SEQPUTDEC
    Next
    U_SEQPUT='</Titles>' : Gosub C_SEQPUTDEC
Return


# ------------------------------------------------------------
# Chargement param. associés à l'action de la consultation
# ------------------------------------------------------------
$C_LDCNSACT
    If !clalev([F:ATR]) : Local File ACTPAR [ATR] : Endif
    #
    Filter [ATR] Where ACTION="CONS"+C_CNSCODE
    CW_I = rowcount([ATR])+1 
    #Local Char C_PARCOD(GLONAAR)(1..CW_I)
    Local Char PARAM(250)(1..CW_I)
    #
    CW_I=0
    For [ATR]NOPAR 
        CW_I+=1
        CW_J=find([F:ATR]CODPAR, C_LSTPARCOD) 
        If CW_J
            PARAM(CW_I)=C_LSTPARVALC(CW_J-1)
        Endif
    Next    
    Filter [ATR]   
Return

# Caractéristiques liées à une ligne
# nota: CW_ROW = numero ligne courant (0 à nblig-1)
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$C_GETROWINF
# Action sur la ligne
If C_ISGETACT
    Raz C_LSTBTNTIT, C_LSTBTNINF
    Onerrgo GETACT_ERR
    Call GETACT(CW_ROW+1, C_LSTBTNTIT, C_LSTBTNINF) From ="WWCNS"+C_CNSCODE   
    Onerrgo
Endif
Return

# Existance du sous-programme GETACT (C_ISGETACT=0 non)
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$ISGETACT
C_ISGETACT = 1 
Onerrgo GETACT_ERR
Call GETACT(1, C_LSTBTNTIT, C_LSTBTNINF) From ="WWCNS"+C_CNSCODE
Onerrgo
Return

$GETACT_ERR
C_ISGETACT = 0
Raz C_LSTBTNTIT, C_LSTBTNINF
Resume

# Variables
# - - - - - - - - - - - - - - - - - -
$C_INIT
# Travail
Local Integer CW_I, CW_DES, CW_ROW, CW_COL, CW_BTN, CW_NBREC
Local Char CW_STRINTVAL(200), CW_STRVAL(200), CW_STREVAL(30)         # E60544
Local Char CW_URL(220)            # 30 de reserves pour le codage
Local Decimal CW_DEC
Local Date    CW_DAT
# Actions portails
Local Char CQ_ACTINIT(10) : CQ_ACTINIT='LOAD'                # Donnée à partir du début niveau 1

#        Pour compatibilité tableau
Local Char CQ_ACTREFRESH(10) : CQ_ACTREFRESH='REFRESH'     
Local Char C_ACTCNS       # Action prgrms consultation      

# Action ss-prgrm consultations
Local Char CQ_CNSFIRST(10) : CQ_CNSFIRST='TOP'              # Données depuis le début
Local Char CQ_CNSNEXT(10) : CQ_CNSNEXT='NEXT'               # Données suivantes

# Zones de messages communes
Local Integer  C_NBMES
Local Integer  C_TYPMES(0..10)
Local Char     C_MES(200)(0..10)

# Table type
If clalev([F:ATY])  = 0 : Local File ATYPE [ATY] : Endif
# Elts principaux de la consultation
Call LECTURE("ATY","ACN","") From CONTOBJ
Local Char C_CNSCODE([F:ATY]LNGTYP)    # Code
Call LECTURE("ATY","GTC","") From CONTOBJ
Local Char C_CNSECR([F:ATY]LNGTYP)      # Ecran éventuel

#Paramètres sources de données
Local Char CC_ECRAN(5) : CC_ECRAN="ECRAN"
Local Integer C_LEVEL
Local Char C_PROGCNS

# Parametres issus de la vue portail
Local Integer CC_PTLPARDIM : CC_PTLPARDIM = dim([F:APV]SRCPARCOD)
Local Char    C_LSTPARCOD(10)(0..CC_PTLPARDIM -1)
Local Integer C_LSTPARTYP(0..CC_PTLPARDIM -1)
Local Char    C_LSTPARVALC(200)(0..CC_PTLPARDIM -1)
Local Date    C_LSTPARVALD(0..CC_PTLPARDIM -1)
Local Decimal C_LSTPARVALN(0..CC_PTLPARDIM -1)
Local Char    CC_CNSECRCOD : CC_CNSECRCOD = "CNS_ECR"
Local Char    CC_CNSMAX    : CC_CNSMAX    = "CNS_MAX"

# Informations générales consultations
Call LECTURE("ATY","DES","") From CONTOBJ : CW_DES = [F:ATY]LNGTYP
Local Char    C_CNSTITLE(CW_DES)
Call LECTURE("ATY","AMK","") From CONTOBJ
Local Char    C_CNSMASK([F:ATY]LNGTYP)
Local Char    C_CNSMASKABR(GLONABR+4)  # [M:xx]
Local Integer C_CNSMAXROW
Local Integer CC_NBMAXCOL : CC_NBMAXCOL = 50    # Nb maxi de colonne géré
Local Char    C_CLSCOD(10)(0..CC_NBMAXCOL-1)
Local Char    C_CLSTITLE(CW_DES)(0..CC_NBMAXCOL-1)
Local Integer C_CLSTYP(0..CC_NBMAXCOL-1)
Local Integer C_CLSMNL(0..CC_NBMAXCOL-1)
Local Decimal C_CLSLNG(0..CC_NBMAXCOL-1)       # Format de la zone sous forme 12.4
Local Char    C_CLSFMT(30)(0..CC_NBMAXCOL-1)       # Format de la zone sous forme 12.4
Local Integer C_CLSFLGEXP(0..CC_NBMAXCOL-1)    # 0: non exporté  - 1: exporté
Local Integer C_CLSNB
Local Integer C_ISGETACT                       # Flg presence GETACT/WWCNS[code] 1: oui, 2: non

# Informations données
Local Char    C_NEXTDATAINF (200)
Local Integer CC_BTNMAX    : CC_BTNMAX=10      # nb btn gérés
Local Integer C_MOREDATA
Local Char    C_NEXTDATAINF(200)       
Local Char    C_PTLNEXTINF(200)        # information passé par le portail en QS pour obtenir la suite
Local Integer CC_INFOMAX    : CC_INFOMAX=150    # nb car. maxi passer en info sur un bouton

# Option en QS
Local Char CQ_TITLEOPT(5) : CQ_TITLEOPT='TITLE'               # Option titre

Local Char TMPURL(250)(0..10) #$$$$$$  pour test temp

Return

#-- Ecriture output avec decalage
$C_SEQPUTDEC
  U_SEQPUT=space$(4)+U_SEQPUT :  Gosub U_PUT From SUBAPSUTI
Return

# Variables dimensionnées en fct des retours du ssprgrm PTLGETINFOS
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$C_INITDYN
# Informations données 
Local Char    C_LSTBTNTIT(CW_DES)(0..CC_BTNMAX-1)        
Local Char    C_LSTBTNACT(10) (0..CC_BTNMAX-1)  # boutons
Local Char    C_LSTBTNINF(200)(0..CC_BTNMAX-1)  # La limite est à 150 pour la donnée utile (avant conversion + infos techniques)

Return



# ------------------------------------------------------------
#  S E C T I O N  T E S T S
# ------------------------------------------------------------
# Traitement de test du sous programme "MONITEUR". Appel via F5
# <=> mode web
# ------------------------------------------------------------
#
# Exemple paramètre de type date: nday$(nday(date$)-1)   
#

$TESTALO
  Local Char WPARAMID(50)(1..10)
  Local Char WPARAMVALUE(250)(1..10)
  Local Integer WI,WNBPARAM

  Local Clbfile WCLOBOUT(10)        # Attention doit être en phase avec HTCCLBSIZ

  # Paramètres
  #  technique
  [L]WPARAMID(1) = "HTCCLBSIZ" :   [L]WPARAMVALUE(1) = "10"     # Taille blob (spécif WEB)
  [L]WPARAMID(2) = "TRACE" :   [L]WPARAMVALUE(2) = "ON"     # trace X3 on/off

  #  demande
  [L]WPARAMID(3) = "HTCPRVTYP" :   [L]WPARAMVALUE(3) = "PORTALCNS"
  [L]WPARAMID(4) = "ACTION"    :   [L]WPARAMVALUE(4) = "LOAD"
  #  en fonction de la demande
  [L]WPARAMID(5) = "PVIEWCODE"      :   [L]WPARAMVALUE(5) = "ZZJCNSALO"
  [L]WNBPARAM = 5

  #maxmem = maxmem + 10000000
  #Infbox("Free: "-num$(freemem) -"max: "- num$(maxmem))

  #Appel du point d'entrée du portail 
  Call MONITEUR( [L]WNBPARAM ,[L]WPARAMID ,[L]WPARAMVALUE, [L]WCLOBOUT) From SUBAPSMON
  Infbox("Taille de ClobOut=["+ num$(len([L]WCLOBOUT)) +"]")

  Local Char WRESCLB(150)(1..200)
  Setlob WRESCLB With [L]WCLOBOUT
  For WI=1 To 200
       Call ECR_TRACE(WRESCLB(WI),0) From GESECRAN
  Next
  Call LEC_TRACE From LECFIC
End

$TESTAUD
  Local Char WPARAMID(50)(1..10)
  Local Char WPARAMVALUE(250)(1..10)
  Local Integer WI,WNBPARAM

  Local Clbfile WCLOBOUT(10)        # Attention doit être en phase avec HTCCLBSIZ

  # Paramètres
  #  technique
  [L]WPARAMID(1) = "HTCCLBSIZ" :   [L]WPARAMVALUE(1) = "10"     # Taille blob (spécif WEB)
  [L]WPARAMID(2) = "TRACE" :   [L]WPARAMVALUE(2) = "ON"     # trace X3 on/off

  #  demande
  [L]WPARAMID(3) = "HTCPRVTYP" :   [L]WPARAMVALUE(3) = "PORTALCNS"
  [L]WPARAMID(4) = "ACTION"    :   [L]WPARAMVALUE(4) = "LOAD"
  #  en fonction de la demande
  [L]WPARAMID(5) = "PVIEWCODE"      :   [L]WPARAMVALUE(5) = "ZZJCNSAUD"
  [L]WNBPARAM = 5

  #maxmem = maxmem + 10000000
  #Infbox("Free: "-num$(freemem) -"max: "- num$(maxmem))

  #Appel du point d'entrée du portail 
  Call MONITEUR( [L]WNBPARAM ,[L]WPARAMID ,[L]WPARAMVALUE, [L]WCLOBOUT) From SUBAPSMON
  Infbox("Taille de ClobOut=["+ num$(len([L]WCLOBOUT)) +"]")

  Local Char WRESCLB(150)(1..200)
  Setlob WRESCLB With [L]WCLOBOUT
  For WI=1 To 200
       Call ECR_TRACE(WRESCLB(WI),0) From GESECRAN
  Next
  Call LEC_TRACE From LECFIC
End

$TESTAWW
  Local Char WPARAMID(50)(1..10)
  Local Char WPARAMVALUE(250)(1..10)
  Local Integer WI,WNBPARAM

  Local Clbfile WCLOBOUT(10)        # Attention doit être en phase avec HTCCLBSIZ

  # Paramètres
  #  technique
  [L]WPARAMID(1) = "HTCCLBSIZ" :   [L]WPARAMVALUE(1) = "10"     # Taille blob (spécif WEB)
  [L]WPARAMID(2) = "TRACE" :   [L]WPARAMVALUE(2) = "ON"     # trace X3 on/off

  #  demande
  [L]WPARAMID(3) = "HTCPRVTYP" :   [L]WPARAMVALUE(3) = "PORTALCNS"
  [L]WPARAMID(4) = "ACTION"    :   [L]WPARAMVALUE(4) = "LOAD"
  #  en fonction de la demande
  [L]WPARAMID(5) = "PVIEWCODE"      :   [L]WPARAMVALUE(5) = "ZZJCNSAWW"
  [L]WNBPARAM = 5

  #maxmem = maxmem + 10000000
  #Infbox("Free: "-num$(freemem) -"max: "- num$(maxmem))

  #Appel du point d'entrée du portail 

  Call MONITEUR( [L]WNBPARAM ,[L]WPARAMID ,[L]WPARAMVALUE, [L]WCLOBOUT) From SUBAPSMON
  Infbox("Taille de ClobOut=["+ num$(len([L]WCLOBOUT)) +"]")

  Local Char WRESCLB(150)(1..200)
  Setlob WRESCLB With [L]WCLOBOUT
  For WI=1 To 200
       Call ECR_TRACE(WRESCLB(WI),0) From GESECRAN
  Next
  Call LEC_TRACE From LECFIC
End

