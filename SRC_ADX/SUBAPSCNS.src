$TESTSUITE
  Local Char WPARAMID(50)(1..10)
  Local Char WPARAMVALUE(250)(1..10)
  Local Integer WI,WNBPARAM
  Local Clbfile WCLOBOUT(10)        

  # Paramètres
  #  technique
  [L]WPARAMID(1) = "HTCCLBSIZ" :   [L]WPARAMVALUE(1) = "10"     # Taille blob (spécif WEB)
  [L]WPARAMID(2) = "TRACE" :   [L]WPARAMVALUE(2) = "OFF"     # trace X3 on/off
  #  demande
  [L]WPARAMID(3) = "HTCPRVTYP" :   [L]WPARAMVALUE(3) = "PORTALCNS"
  [L]WPARAMID(4) = "ACTION"    :   [L]WPARAMVALUE(4) = "NEXT"
  #  en fonction de la demande
  [L]WPARAMID(5) = "PVIEWCODE"      :   [L]WPARAMVALUE(5) = "ZZJPJCNS"
  [L]WPARAMID(6) = "NEXTINFO"      :   [L]WPARAMVALUE(6) = "SEQ >= 27684"

  [L]WNBPARAM = 6

  #Appel du point d'entrée du portail 
  Call MONITEUR( [L]WNBPARAM ,[L]WPARAMID ,[L]WPARAMVALUE, [L]WCLOBOUT) From SUBAPSMON
  Infbox("Taille de ClobOut=["+ num$(len([L]WCLOBOUT)) +"]")
  Call LEC_TRACE From LECFIC
End

