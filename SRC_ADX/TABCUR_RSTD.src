#<AdxTL>@(#)0.0.0.0 $Revision$
# Structure TABCUR

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When "TCU"
    Case [L]AEVENT
      When "AINSERT_AFTER"                  : Gosub AINSERT_AFTER
      When "AUPDATE_AFTER"                  : Gosub AUPDATE_AFTER
      When "AREAD_AFTER"                    : Gosub AREAD_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "TCU.EURFLG"                         : Gosub EURFLG
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return


###############################################################################################
$AINSERT_AFTER
  Gosub TABCUR_DISPLAY
Return

###############################################################################################
$AUPDATE_AFTER
  Gosub TABCUR_DISPLAY
Return

###############################################################################################
$AREAD_AFTER
  Gosub TABCUR_DISPLAY
Return

###############################################################################################
$TABCUR_DISPLAY
Gosub EURFLG_DISPLAY
Return

###############################################################################################

$EURFLG
Case [L]ARULE
  When "PROPAGATE"                           : Gosub EURFLG_PROPAGATE
Endcase
Return

$EURFLG_PROPAGATE
Gosub EURFLG_DISPLAY
Return

###############################################################################################
$EURFLG_DISPLAY
Local Integer MY_STATUS
  If this.EURFLG <> [V]CST_AYES
    [L]MY_STATUS = fmet this.ASETATTRIBUTE("EURRAT", "$isDisabled", "true")
    [L]MY_STATUS = fmet this.ASETATTRIBUTE("EURDAT", "$isDisabled", "true")
    [L]MY_STATUS = fmet this.ASETATTRIBUTE("CURENDDAT", "$isDisabled", "true")
  Else
    [L]MY_STATUS = fmet this.ASETATTRIBUTE("EURRAT", "$isDisabled", "false")
    [L]MY_STATUS = fmet this.ASETATTRIBUTE("EURDAT", "$isDisabled", "false")
    [L]MY_STATUS = fmet this.ASETATTRIBUTE("CURENDDAT", "$isDisabled", "false")
  Endif
Return

