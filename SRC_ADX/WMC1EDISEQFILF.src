#<AdxTL>@(#)0.0.0.0 $Revision$Class Sequential files
# Supervisor
## ACLA-CLASSE ## EDISEQFILF
# 2018-11-06 07:05:12 202


####################################################################
# Labels of the main class and methods 
####################################################################

####################################################################
# 1 : MSGCOD Message mapping ID ( Field EDC 20)
####################################################################

$SET_MSGCOD
If [L]_AOLDVAL<>this.MSGCOD
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_MSGCOD
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.MSGCOD
 Gosub PROPAGATE_MSGCOD
Endif
Return

$INIT_MSGCOD
Gosub DECLARE_VAR From WMC0EDISEQFILF
[L]CURPRO = "MSGCOD"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return
 
$CONTROL_MSGCOD
Gosub DECLARE_VAR From WMC0EDISEQFILF
[L]CURPRO = "MSGCOD"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_MSGCOD                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_MSGCOD                : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_MSGCOD
[L]CURPRO = "MSGCOD"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & vireblc(this.MSGCOD,2)=""
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_MSGCOD
[L]CURPRO = "MSGCOD"
If vireblc(this.MSGCOD,2)<>vireblc(format$("K:20X",this.MSGCOD),2)
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(149,100,1)) :  Return : # Incorrect Format
Endif
Return

$_AOTHERS_MSGCOD
[L]CURPRO = "MSGCOD"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_MSGCOD
[L]CURPRO = "MSGCOD"
If vireblc(this.MSGCOD,2)<>""
 If fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent")=""
  [L]ASTATUS =  func WMTYPEDC.ACTRLREF(this,"MSGCOD",this.MSGCOD,this.MSGCOD,this.MSGREL,"")
  If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
 Else
  If this.MSGCOD<>evalue("this.APARENT."+fmet this.AGETATTRIBUTE([L]CURPRO,"$namProParent"))
   [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(83,123,1)) :  Return : # Invalid value
  Endif
 Endif
Endif
Return

$PROPAGATE_MSGCOD
this.isReadonly = 0
[L]CURPRO = "MSGCOD"
Gosub _LNKPRO_MSGCOD
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_MSGCOD
Gosub DECLARE_VAR From WMC0EDISEQFILF
[L]CURPRO = "MSGCOD"
$_LNKPRO_MSGCOD
If vireblc(this.MSGCOD,2)<>""
 # Link EDIMSG
 Local File EDIMSG [WEMS]
 Read [F:WEMS]EMS0 = this.MSGCOD;this.MSGREL
 If !fstat
  [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGCOD","$title",[F:WEMS]MSGDES)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGCOD","$description",[F:WEMS]MSGDES)
 Endif
 LogicClose File [WEMS]
Endif
Return

$_ALOADATTRIBUTE_MSGCOD
[L]ASTATUS = fmet this.ASETATTRIBUTE("MSGCOD","$isMandatory","true")
Return


