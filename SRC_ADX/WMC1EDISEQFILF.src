####################################################################
# 8 : MANDATORY Mandatory ( Field Local menu number 1)
####################################################################

$SET_MANDATORY
If [L]_AOLDVAL<>this.MANDATORY
 Call _ASTATUSPARENT(this) From ASYRSUB
Endif
Gosub CONTROL_MANDATORY
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If [L]_AOLDVAL<>this.MANDATORY
 Gosub PROPAGATE_MANDATORY
Endif
Return

$INIT_MANDATORY
Gosub DECLARE_VAR From WMC0EDISEQFILF
[L]CURPRO = "MANDATORY"
[L]ARULE = "INIT" : [L]ACTION = "INIT" : Gosub ACTION From ASYRSUB
If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
If this.MANDATORY=0 and fmet this.AGETATTRIBUTE("MANDATORY","$isMandatory")="true"
 this.MANDATORY = 1
Endif
Return
 
$CONTROL_MANDATORY
Gosub DECLARE_VAR From WMC0EDISEQFILF
[L]CURPRO = "MANDATORY"
[L]ASTATUS = fmet this.ADELETEERROR([L]CURPRO)
Gosub _AFORMAT_MANDATORY             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Gosub _AOTHERS_MANDATORY             : If [L]ASTATUS>=[V]CST_AERROR : Return : Endif
Return

$_AMANDATORY_MANDATORY
[L]CURPRO = "MANDATORY"
If fmet this.AGETATTRIBUTE([L]CURPRO,"$isMandatory")="true" & this.MANDATORY=0
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(10,123,1)) :  Return : # Mandatory field
Endif
Return

$_AFORMAT_MANDATORY
[L]CURPRO = "MANDATORY"
If this.MANDATORY<0 or this.MANDATORY>len(mess(0,1,1))
 # Pop / Invalid option
 [L]ASTATUS = func ASYRSUB._ASETSTATUS(this,[L]CURPRO,0,[V]CST_AERROR,[V]CST_AHTTP_BAD_REQUEST,mess(4,11,1)-"1 ->"-num$(this.MANDATORY)-mess(99,123,1)):  Return : # Local menu "1 -> Invalid option
Endif
Return

$_AOTHERS_MANDATORY
[L]CURPRO = "MANDATORY"
[L]ARULE = "CONTROL" : [L]ACTION = "CONTROL" : Gosub ACTION From ASYRSUB
Return

$_AOTHERS_REF_MANDATORY
[L]CURPRO = "MANDATORY"
Return

$PROPAGATE_MANDATORY
this.isReadonly = 0
[L]CURPRO = "MANDATORY"
[L]ARULE = "PROPAGATE" : [L]ACTION = "PROPAGATE" : Gosub ACTION From ASYRSUB
this.isReadonly = 1
Return

$LNKPRO_MANDATORY
Gosub DECLARE_VAR From WMC0EDISEQFILF
[L]CURPRO = "MANDATORY"
$_LNKPRO_MANDATORY
