  [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGREL","$title",[F:WEMS]MSGDES)
  [L]ASTATUS = fmet this.ASETATTRIBUTE("MSGREL","$description",[F:WEMS]MSGDES)
