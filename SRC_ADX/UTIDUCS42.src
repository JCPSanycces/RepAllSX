#<AdxTL>@(#)8.0.0.0 $Revision$
################################################################################
# Mise à jour des objets DUCS v4.2                                             #
################################################################################

##################################################################
#Comments(1)                                                     #
# Manips à faire                                                 #
#   1. Remplacer UTIXXX par le nom de votre programme            #
#   2. Action OUVRE_TRACE : mettre un titre                      #
#   3. cf Comments(2)                                            #
#   4. cf Comments(3)                                            #
##################################################################

Local Char DOSSIER(30)
DOSSIER = nomap
Call SAIDOS(DOSSIER,"") From SAIDOS
If DOSSIER<>""
 Call TEMPON("O") From GESECRAN
 Call OUVRE_TRACE("UTIDUCS42: Mise à jour des objets relatifs à la DUCS 4.2") From LECFIC
 Call EXE_UTIDUCS42(DOSSIER)
 Call TEMPOFF     From GESECRAN
 Call FERME_TRACE From LECFIC
 Call LEC_TRACE   From LECFIC
Endif
End

###################################################################################################
#Comments(2)                                                                                      #
# Pour exécution automatique en gestion de patch de EXE_UTIXXX                                    #
#   1. Ne pas faire de ouvre_trace/ferme_trace/lec_trace dans cette partie de programme           #
#      (le fichier trace est déjà ouvert / l'intégration de patch peut se faire en batch )        #
#                                             
#   2. Pour les ecr_trace :                                                                       #
#         Utiliser des messages avec l'instruction mess(nnn,ccc,1) ou alors des textes en anglais #
#                                             
#   3. Attention à la déclaration des fichiers : pensez que le client n'a pas forcémment activer  #
#      tous les modules dans ses dossiers
#                                             
#   4. Attention aux moulinettes sur de gros volumes (Erreur Rollback en Oracle)                  #
###################################################################################################

Subprog EXE_UTIDUCS42(APPLI)
Value Char APPLI
Local Integer OK ,I

Call ECR_TRACE("UTIDUCS42: Process Start on : "+APPLI,0) From GESECRAN

#### Corps de la moulinette - début

Local File =APPLI+".AOBJLST" [AOL]

Call DEBTRANS From GLOCK
Gosub MAJOBJ

#### Corps de la moulinette - fin 

Call ECR_TRACE("UTIDUCS42: Process End on : "+APPLI,0) From GESECRAN

Close Local File [AOL]
End


$MAJOBJ
Trbegin [AOL]
GOK = 1
Readlock[F:AOL]AOL0="DCS"
If !fstat
 I=find("EMP", [F:AOL]SELZON(0..[F:AOL]NBSEL-1))
 If I
  Gosub SUPPRIME
  If I<>[F:AOL]NBSEL :#Pas en derniere position : il faut tout décaler !
   Gosub DECALE
   I=[F:AOL]NBSEL
   Gosub SUPPRIME
  Endif
  [F:AOL]NBSEL-=1
  Rewrite [F:AOL]
  If fstat
   GOK = 0 : Call FSTA("ORG") From GLOCK
  Endif
 Else
  GOK=0 : Goto AB_MAJOBJ
 Endif
Else
 GOK=0 : Goto AB_MAJOBJ
Endif
If GOK
 Call VALID("DCS",APPLI,0,OK) From VALOBJ
 If !OK :  Goto AB_MAJOBJ : Endif
 Call VALID("ODCS",APPLI,0,OK) From VALWIN
 If !OK :  Goto AB_MAJOBJ : Endif
Endif 
Commit
Return

$AB_MAJOBJ
Rollback
Return

$SUPPRIME
[F:AOL]SELZON(I-1)=""
[F:AOL]SELFIC(I-1)=""
[F:AOL]SELEXP(I-1)=""
[F:AOL]SELINT(I-1)=0
[F:AOL]SELTYP(I-1)=""
[F:AOL]SELSAI(I-1)=""
[F:AOL]SELLNG(I-1)=0
Return

$DECALE
For J=I To [F:AOL]NBSEL-1
[F:AOL]SELZON(J-1)=[F:AOL]SELZON(J)
[F:AOL]SELFIC(J-1)=[F:AOL]SELFIC(J)
[F:AOL]SELEXP(J-1)=[F:AOL]SELEXP(J)
[F:AOL]SELINT(J-1)=[F:AOL]SELINT(J)
[F:AOL]SELTYP(J-1)=[F:AOL]SELTYP(J)
[F:AOL]SELSAI(J-1)=[F:AOL]SELSAI(J)
[F:AOL]SELLNG(J-1)=[F:AOL]SELLNG(J)
Next
Return


###################################################################################################
#Comments(3)                                                                                      #
# Pour exécution automatique  en gestion de patch                                                 #
#   1. Si le traitement ne doit pas s'éxécuter dans le dossier X3 (moulinette applicative)        #
#        ==> Décocher la ligne 1                                                                  #
#                                                                                                 #
#   2. Si le traitement doit s'éxécuter uniquement dans les dossiers ayant activé un module donné #
#        ==> Décocher la ligne 2  et renseigner le n° de module                                   #
#            attention à la numérotation du module qui commence à 0 :                             #
#             (0=superviseur / 1= compta / 2= tiers ... etc ... )                                 #
###################################################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

##1## IF APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
##2## If [F:ADS]MODULE(1) <> 2 : End : Endif
Call EXE_UTIDUCS42(APPLI)
End




