#<AdxTL>@(#)0.0.0.0 $Revision$
########################################################################################################################
#
# GESTION DES BIENS - SUPPRESSION : FENETRE DE GESTION DES EXTOURNES - Provisions pour renouvellement
# ===================================================================================================
#
# @ver        1.0.0
# @date       xx/xx/xxxx
# @user       GBO
# @modif      xx/xx/xxxx
#
# Liste des sous-programmes :
# -------------------------
#
#
#
# Liste des fonctions :
# -------------------
#
#
# Liste des routines :
# ------------------
#
# $ACTION
#
########################################################################################################################
# Modifications :
# -------------
#
# - USR - xx.xx.xxxx - Fq yyyyy - Commentaire
# - GLE - 22.01.2014 - Fq 90143 - La date de comptabilisation par défaut est toujours las fin de période courante
# - GBO - 07.05.2010 - Fq 64544 - Gestion des écarts entre plans d'amortissement
########################################################################################################################

#----------------------------------------
# CHARGEMENT DE L'ONGLET PROVISIONS
#----------------------------------------
$LOAD_PSTRPR

If 1=1
 If G_ACTCCN <> G_OUI : Local Integer NORPR : Return : Endif
 If G_CCNRPR <> G_OUI : Local Integer NORPR : Return : Endif

 Local Integer NORPR
 Local Integer I_DPRPLN

 # Chargement des information date début / fin exercice courant et suivant pour les sélections de DEPREC

 Read [F:CNX]CNX0 =[M:FC0]CPY;G300CPFI
 Read [F:FIYC]FIY1=[M:FC0]CPY;[F:CNX]CNX;GVML_TECOURA
 Read [F:FIYS]FIY1=[M:FC0]CPY;[F:CNX]CNX;GVML_TESUIV

 I_DPRPLN=find([M:FPC]DPRPLNLED(find (G301CPT,[M:FPC]DPRPLNCNX)-1),[M:FPC]DPRPLN)

 # Chargement du tableau pour l'exercice courant
 # =============================================

 For I_PER=1 To [F:FIYC]NBRPER
  If [F:FIYC]TYPPST(I_PER-1)=GVML_TPSTDEF
   Read [RPR]RPR0=[M:FC0]AASREF;[F:FIYC]DATENDFIY;[F:FIYC]DATENDPER(I_PER-1)
   If !fstat
    If [F:RPR]PSTACGRPR | [F:RPR]PSTFISRPR

     # Montants comptabilisés

     [M:FC2]STAFIYI([M:FC2]NBRPR)    = GVML_TECOURA
     If dim(LFIRST)<0
      [M:FC2]STAFIY([M:FC2]NBRPR)    = GVML_TECOURA
     Else
      [M:FC2]STAFIY([M:FC2]NBRPR)    = 0
     Endif
     [M:FC2]FIYENDDAT([M:FC2]NBRPR) = [F:RPR]FIYENDDAT
     [M:FC2]PERENDDAT([M:FC2]NBRPR) = [F:RPR]PERENDDAT
     [M:FC2]PSTACGRPR([M:FC2]NBRPR) = [F:RPR]PSTACGRPR
     [M:FC2]PSTFISRPR([M:FC2]NBRPR) = [F:RPR]PSTFISRPR

     # Imputations analytiques

     [M:FC2]DSP([M:FC2]NBRPR) = func GENEVE.GET_DSP_DAT([F:DEP]PERENDDAT,"[F:FAS]")
     If [M:FC2]DSP([M:FC2]NBRPR)=""
      Local Integer I_AXE
      Local Char    L_NOMCHAMP
      For I_AXE=1 To 9
       L_NOMCHAMP="[M:FC2]DIE"+num$(I_AXE)+"([M:FC2]NBRPR)"
       Assign L_NOMCHAMP With evalue("[M:FPC]DPRPLNDIE"+num$(I_AXE)+"("+num$(I_DPRPLN-1)+")")
       L_NOMCHAMP="[M:FC2]CCE"+num$(I_AXE)+"([M:FC2]NBRPR)"
       Assign L_NOMCHAMP With func GENEVE.GET_CCE_DAT([F:DEP]PERENDDAT,"[F:FAS]","","",L_PLN,evalue("[M:FC2]DIE"+num$(I_AXE)+"([M:FC2]NBRPR)"))
      Next I_AXE
     Endif

     # Cumuls exercices antérieurs

     If dim(LFIRST)<0
      [M:FC2]E_1ACGRPR([M:FC2]NBRPR) = [F:RPR]E_1ACGRPR
      [M:FC2]E_1FISRPR([M:FC2]NBRPR) = [F:RPR]E_1FISRPR
      [M:FC2]E_1RVERPR([M:FC2]NBRPR) = [F:RPR]E_1RVERPR
      [M:FC2]E_1SUPCAD([M:FC2]NBRPR) = [F:RPR]E_1SUPCAD
      Local Integer LFIRST
     Endif

     [M:FC2]NBRPR+=1
    Endif
   Endif
  Endif
 Next I_PER

 # Chargement du tableau pour l'exercice suivant
 # =============================================

 If dim(LFIRST)>0 : Kill LFIRST : Endif
 For I_PER=1 To [F:FIYS]NBRPER
  If [F:FIYS]TYPPST(I_PER-1)=GVML_TPSTDEF
   Read [RPR]RPR0=[M:FC0]AASREF;[F:FIYS]DATENDFIY;[F:FIYS]DATENDPER(I_PER-1)
   If !fstat
    If [F:RPR]PSTACGRPR | [F:RPR]PSTFISRPR

     # Montants comptabilisés

     [M:FC2]STAFIYI([M:FC2]NBRPR)    = GVML_TESUIV
     If dim(LFIRST)<0
      [M:FC2]STAFIY([M:FC2]NBRPR)    = GVML_TESUIV
     Else
      [M:FC2]STAFIY([M:FC2]NBRPR)    = 0
     Endif
     [M:FC2]FIYENDDAT([M:FC2]NBRPR) = [F:RPR]FIYENDDAT
     [M:FC2]PERENDDAT([M:FC2]NBRPR) = [F:RPR]PERENDDAT
     [M:FC2]PSTACGRPR([M:FC2]NBRPR) = [F:RPR]PSTACGRPR
     [M:FC2]PSTFISRPR([M:FC2]NBRPR) = [F:RPR]PSTFISRPR

     # Imputations analytiques

     [M:FC2]DSP([M:FC2]NBRPR) = func GENEVE.GET_DSP_DAT([F:DEP]PERENDDAT,"[F:FAS]")
     If [M:FC2]DSP([M:FC2]NBRPR)=""
      Local Integer I_AXE
      Local Char    L_NOMCHAMP
      For I_AXE=1 To 9
       L_NOMCHAMP="[M:FC2]DIE"+num$(I_AXE)+"([M:FC2]NBRPR)"
       Assign L_NOMCHAMP With evalue("[M:FPC]DPRPLNDIE"+num$(I_AXE)+"("+num$(I_DPRPLN-1)+")")
       L_NOMCHAMP="[M:FC2]CCE"+num$(I_AXE)+"([M:FC2]NBRPR)"
       Assign L_NOMCHAMP With func GENEVE.GET_CCE_DAT([F:DEP]PERENDDAT,"[F:FAS]","","",L_PLN,evalue("[M:FC2]DIE"+num$(I_AXE)+"([M:FC2]NBRPR)"))
      Next I_AXE
     Endif

     If dim(LFIRST)<0
      Local Integer LFIRST
     Endif

     [M:FC2]NBRPR+=1
    Endif
   Endif
  Endif
 Next I_PER

 # Préparation des événement d'annulation

 If [M:FC2]NBRPR
  Call PREP_EVT_RPRCNL From TRTFASCNLRPR
  If dim(LFIRST)>0 : Kill LFIRST : Endif
 Endif

 # Alimentation du flag d'annulation du renouvellement et du tableau des biens père :

 [M:FC2]CCNETRTYP=[F:FAS]CCNETRTYP
 [M:FC2]RNWDONFLG=[F:FAS]RNWDONFLG
 Local Integer LRNWCAN
 If [F:FAS]CCNETRTYP=GVML_NARENEW & [F:FAS]RNWDONFLG=G_OUI
  # Recherche de l'événement de renouvellement et vérification qu'il n'est pas annulé
  If !clalev([F:E31]) : Local File EFASRNW [E31] : Endif
  Filter [E31] Where REF=[F:FAS]AASREF & SNSEVE=GVML_TEACT
  Read [E31] Last
  If !fstat
   If !clalev([F:E31C]) : Local File EFASRNW [E31C] : Endif
   Filter [E31C] Where REF=[F:FAS]AASREF & SNSEVE=GVML_TEAACT & TIMSTPO=[F:E31]TIMSTP
   Read [F:E31C] First
   If !fstat
    LRNWCAN=G_NON
   Else
    LRNWCAN=G_OUI
    [M:FC2]EVTREF    = [F:E31]REF
    [M:FC2]EVTTIMSTP = [F:E31]TIMSTP
   Endif
   Filter [E31C]
  Else
   LRNWCAN=G_NON
  Endif
  Filter [E31]
  # Alimentation du tableau des biens père
  If !clalev([F:MOTH]) : Local File FXDASSETS [MOTH] : Endif
  For [MOTH] Where RNWAASREF=[F:FAS]AASREF
   [M:FC2]MOTHAASREF([M:FC2]NBMOTH)=[F:MOTH]AASREF
   [M:FC2]MOTHAASDES([M:FC2]NBMOTH)=[F:MOTH]AASDES1
   [M:FC2]NBMOTH+=1
  Next
  Close Local File [F:MOTH]
 Else
  LRNWCAN=G_NON
 Endif

 # Condtionnement de l'accès au flag d'annulation du renouvellement
 If LRNWCAN=G_NON
  [M:FC2]RNWCANFLG=G_NON : Grizo [M:FC2]RNWCANFLG
 Else
  [M:FC2]RNWCANFLG=G_OUI : Actzo [M:FC2]RNWCANFLG
 Endif

 Affzo [M:FC2]
 Diszo [M:FC2]CPTDATINT
 If ![M:FC2]NBRPR
  NORPR=1
 Endif
Endif
Return

#----------------------------------------
# Préparation des événements d'annulation
# de provisions pour renouvellement
#----------------------------------------
Subprog PREP_EVT_RPRCNL()

  Local Char    CHAMP
  Local Integer I
  Local Integer I_OCC
  Local Integer R_FIY
  Local Integer S_FIY
  Local Integer R_CCE
  Local Char    S_CCE
  Local Char    C_CCE
  Local Decimal T_PSTACGRPR, T_PSTFISRPR
  Local Decimal T_E_1ACGRPR, T_E_1FISRPR, T_E_1RVERPR, T_E_1SUPCAD

  For I_OCC=1 To [M:FC2]NBRPR

   If I_OCC=1
    S_FIY=[M:FC2]STAFIYI(I_OCC-1)
    S_CCE=[M:FC2]DSP(I_OCC-1)
    For I=1 To 9
     S_CCE+="~"+evalue("[M:FC2]CCE"+num$(I)+"(I_OCC-1)")
    Next I_CCE
   Else
    # Rupture Exercice ?
    If S_FIY<>[M:FC2]STAFIYI(I_OCC-1) : R_FIY=1 : S_FIY=[M:FC2]STAFIYI(I_OCC-1) : Else : R_FIY=0 : Endif
    # Rupture analytique ?
    C_CCE=[M:FC2]DSP(I_OCC-1)
    For I=1 To 9
     C_CCE+="~"+evalue("[M:FC2]CCE"+num$(I)+"(I_OCC-1)")
    Next I_CCE
    If S_CCE<>C_CCE : R_CCE=1 : S_CCE=C_CCE : Else : R_CCE=0 : Endif
   Endif

   # Rupture, on ajoute l'événement

   If R_FIY | R_CCE : Gosub ADD_CNLRPR_EVENT : Endif

   # Totalisation

   T_PSTACGRPR    += [M:FC2]PSTACGRPR(I_OCC-1)
   T_PSTFISRPR    += [M:FC2]PSTFISRPR(I_OCC-1)

   If S_FIY=GVML_TECOURA & [M:FC2]FLGEXTANTR=G_OUI & dim(LFIRST)<0
    Local Integer LFIRST
    T_E_1ACGRPR = [M:FC2]E_1ACGRPR(I_OCC-1)
    T_E_1FISRPR = [M:FC2]E_1FISRPR(I_OCC-1)
    T_E_1RVERPR = [M:FC2]E_1RVERPR(I_OCC-1)
    T_E_1SUPCAD = [M:FC2]E_1SUPCAD(I_OCC-1)
   Endif

  Next I_OCC
  If I_OCC=1 : I_OCC=2 : Endif

  If [M:FC2]NBRPR>0 | I_OCC
   Gosub ADD_CNLRPR_EVENT
  Endif
  If dim(LPREM) >0 : Kill LPREM  : Endif
  If dim(LFIRST)>0 : Kill LFIRST : Endif

End

#----------------------------------------
# Ajout d'un événement d'annulation de
# provisions pour renouvellement si
# rupture
#----------------------------------------
$ADD_CNLRPR_EVENT
  [M:FC2]EFIYSTA([M:FC2]NBEVR)    = [M:FC2]STAFIYI(I_OCC-2)
  [M:FC2]EVTDAT([M:FC2]NBEVR)     = [M:FC2]PERENDDAT(I_OCC-2)
  # DEB FQ90143
  #[M:FC2]CPTDATINT([M:FC2]NBEVR)  = [M:FC2]PERENDDAT(I_OCC-2)
  #[M:FC2]CPTDATSAV([M:FC2]NBEVR)  = [M:FC2]PERENDDAT(I_OCC-2)
  [M:FC2]CPTDATINT([M:FC2]NBEVR)  = PLNPERENDDAT(0)
  [M:FC2]CPTDATSAV([M:FC2]NBEVR)  = PLNPERENDDAT(0)
  # FIN FQ90143

  [M:FC2]EPSTACGRPR([M:FC2]NBEVR) = T_PSTACGRPR
  [M:FC2]EPSTFISRPR([M:FC2]NBEVR) = T_PSTFISRPR

  [M:FC2]EDSP([M:FC2]NBEVR)       = [M:FC2]DSP(I_OCC-2)
  For I=1 To 9
   CHAMP="[M:FC2]EDIE"+num$(I)+"([M:FC2]NBEVR)"
   Assign CHAMP With evalue("[M:FC2]DIE"+num$(I)+"(I_OCC-2)")
   CHAMP="[M:FC2]ECCE"+num$(I)+"([M:FC2]NBEVR)"
   Assign CHAMP With evalue("[M:FC2]CCE"+num$(I)+"(I_OCC-2)")
  Next I

  If [M:FC2]EFIYSTA([M:FC2]NBEVR)=GVML_TECOURA & dim(LPREM)<0 & [M:FC2]FLGEXTANTR=G_OUI
   Local Integer LPREM
   [M:FC2]EE_1ACGRPR([M:FC2]NBEVR) = T_E_1ACGRPR
   [M:FC2]EE_1FISRPR([M:FC2]NBEVR) = T_E_1FISRPR
   [M:FC2]EE_1RVERPR([M:FC2]NBEVR) = T_E_1RVERPR
   [M:FC2]EE_1SUPCAD([M:FC2]NBEVR) = T_E_1SUPCAD
  Else
   Raz [M:FC2]EE_1ACGRPR([M:FC2]NBEVR),EE_1FISRPR([M:FC2]NBEVR),EE_1RVERPR([M:FC2]NBEVR),EE_1SUPCAD([M:FC2]NBEVR)
  Endif

  Raz T_PSTACGRPR, T_PSTFISRPR
  Raz T_E_1ACGRPR, T_E_1FISRPR, T_E_1RVERPR, T_E_1SUPCAD
  If R_FIY : R_FIY=0 : Endif
  If R_CCE : R_CCE=0 : Endif
  [M:FC2]NBEVR+=1
Return

######################################################################################
# ACTIONS CHAMPS ECRAN FASCNL2
######################################################################################

#----------------------------------------
Subprog AP_FLGEXTANTR(VALEUR)
Variable Integer VALEUR
 Raz [M:FC2]NBEVR
 [M:FC2]FLGEXTANTR=VALEUR
 Call PREP_EVT_RPRCNL From TRTFASCNLRPR
 Affzo [M:FC2]20
End

#----------------------------------------
Subprog AP_FLGUPDDATR(VALEUR)
Variable Integer VALEUR
 If VALEUR=G_NON
  Local Integer I
  For I=1 To [M:FC2]NBEVR
   [M:FC2]CPTDATINT(I-1)=[M:FC2]CPTDATSAV(I-1)
  Next I
  Diszo [M:FC2]CPTDATINT
 Else
  Actzo [M:FC2]CPTDATINT
 Endif
 Affzo [M:FC2]CPTDATINT
End
