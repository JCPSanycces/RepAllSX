#<AdxTL>@(#)10.0.0.0 $Revision$

# Structure COMPANY

##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AINSERT_CONTROL_BEFORE"       : Gosub AINSERT_CONTROL_BEFORE
      When "AINSERT_CONTROL_AFTER"        : Gosub AINSERT_CONTROL_AFTER
      When "AINSERT_AFTER"                : Gosub AINSERT_AFTER

      When "AUPDATE_CONTROL_BEFORE"       : Gosub AUPDATE_CONTROL_BEFORE
      When "AUPDATE_CONTROL_AFTER"        : Gosub AUPDATE_CONTROL_AFTER
      When "AUPDATE_AFTER"                : Gosub AUPDATE_AFTER

      When "ADELETE_AFTER"                : Gosub ADELETE_AFTER
    Endcase
  When "BPA"
    Case [L]AEVENT
      When "ADELLINE_BEFORE"              : Gosub BPA_ADELLINE_BEFORE
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
Case [L]CURPRO
  When "CPYLEGFLG"        : Gosub CPYLEGFLG
  When "MAIFCY"           : Gosub MAIFCY
  When "NID"              : Gosub NID
  When "RGCCUR"           : Gosub RGCCUR
  When "CRY"              : Gosub CRY
  When "EECNUM"           : Gosub EECNUM
  When "BPA.BPAADD"       : Gosub BPA_BPAADD
  When "BPA.BPAADDFLG"    : Gosub BPA_BPAADDFLG
  When "BID.BPAADD"       : Gosub BID_BPAADD
  When "BID.BIDNUM"       : Gosub BID_BIDNUM
  When "BID.BIDNUMFLG"    : Gosub BID_BIDNUMFLG
  When "ORICERFLG"        : Gosub ORICERFLG     :#X3-60504
Endcase
Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#Case [L]AMETHOD
#Endcase
Return

##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return




###############################################################################################
$AINSERT_CONTROL_BEFORE
Gosub COMPANY_CODE_CONTROL
Gosub COMPANY_DEPENDENCY
Return

###############################################################################################
$AINSERT_CONTROL_AFTER
Gosub BPA_CONTROL
Gosub BID_CONTROL
Return

$AINSERT_AFTER
# No multi-legislation
If func ASYRFNC.ACTIV("LEG") = [V]CST_ATRUE
  [F:CPY]LEG = this.LEG
Endif

# Insert Company Grouping
If this.CPYLEGFLG=[V]CST_AYES
  Local Instance AGRPCPY Using C_AGRPCPY
  AGRPCPY = NewInstance C_AGRPCPY AllocGroup null
  AGRPCPY.GRP = this.CPY
  AGRPCPY.CPY = this.CPY
  [L]ASTATUS = fmet AGRPCPY.AINSERT()
  If [L]ASTATUS<>[V]CST_AOK
    [L]ASTATUS = fmet this.ASETERROR("AGRPCPY","insert error message text",[V]CST_AERROR)
  Endif
  FreeGroup AGRPCPY
  If [L]ASTATUS<>[V]CST_AOK : Return : Endif
Endif

# Insert Site Grouping
Local Instance AGRPFCY Using C_AGRPFCY
AGRPFCY = NewInstance C_AGRPFCY AllocGroup null
AGRPFCY.GRP    = this.CPY
AGRPFCY.DES    = this.CPYNAM
AGRPFCY.SHO    = this.CPYSHO
AGRPFCY.FLGCPY = this.CPYLEGFLG
AGRPFCY.FLGLEG = this.CPYLEGFLG
[L]ASTATUS = fmet AGRPFCY.AINSERT()
If [L]ASTATUS<>[V]CST_AOK
  [L]ASTATUS = fmet this.ASETERROR("AGRPFCY","insert error message text",[V]CST_AERROR )
Endif
FreeGroup AGRPFCY

Return

###############################################################################################
$AUPDATE_CONTROL_BEFORE
Gosub COMPANY_DEPENDENCY
Return

###############################################################################################
$AUPDATE_CONTROL_AFTER
Gosub BPA_CONTROL
Gosub BID_CONTROL
Return

###############################################################################################
$AUPDATE_AFTER
# Update Site Groupings
If this.snapshot.CPYNAM <> this.CPYNAM
&  | this.snapshot.CPYSHO <> this.CPYSHO
&  | this.snapshot.CPYLEGFLG <> this.CPYLEGFLG
  Local Instance AGRPFCY Using C_AGRPFCY
  AGRPFCY = NewInstance C_AGRPFCY AllocGroup null
  [L]ASTATUS = fmet AGRPFCY.AREAD(this.CPY)
  If [L]ASTATUS = [V]CST_AOK
    AGRPFCY.DES    = this.CPYNAM
    AGRPFCY.SHO    = this.CPYSHO
    AGRPFCY.FLGCPY = this.CPYLEGFLG
    AGRPFCY.FLGLEG = this.CPYLEGFLG
    [L]ASTATUS = fmet AGRPFCY.AUPDATE()
    If [L]ASTATUS<>[V]CST_AOK
      [L]ASTATUS = fmet this.ASETERROR("AGRPFCY","update error message text",[V]CST_AERROR )
    Endif
  Else
    [L]ASTATUS = fmet this.ASETERROR("AGRPFCY","unable to read"-AGRPFCY,[V]CST_AERROR)
  Endif
  FreeGroup AGRPFCY
Endif
Return

###############################################################################################
$ADELETE_AFTER
# Delete AGRPFCY
Local Instance AGRPFCY Using C_AGRPFCY
AGRPFCY = NewInstance C_AGRPFCY AllocGroup null
[L]ASTATUS = fmet AGRPFCY.AREAD(this.CPY)
If [L]ASTATUS = [V]CST_AOK
  [L]ASTATUS = fmet AGRPFCY.ADELETE()
  If [L]ASTATUS <> [V]CST_AOK
    [L]ASTATUS = fmet this.ASETERROR("AGRPFCY","Delete error message",[V]CST_AERROR)
  Endif
Else
    [L]ASTATUS = fmet this.ASETERROR("AGRPFCY","Read error message",[V]CST_AERROR)
Endif
FreeGroup AGRPFCY
If [L]ASTATUS <> [V]CST_AOK : Return : Endif

# Delete AGRPCPY
Local File AGRPCPY [AGC]
Local Instance AGRPCPY Using C_AGRPCPY
For [F:AGC] Where CPY=this.CPY
  AGRPCPY = NewInstance C_AGRPCPY AllocGroup null
  SetInstance AGRPCPY With [F:AGC]
  [L]ASTATUS = fmet AGRCPY.ADELETE()
  If [L]ASTATUS <> [V]CST_AOK
    [L]ASTATUS= fmet this.ASETERROR("AGRPCPY","Delete error message",[V]CST_ERROR)
  Endif
  FreeGroup AGRPCPY
  If [L]ASTATUS <> [V]CST_AOK : Break : Endif
Next
If [L]ASTATUS <> [V]CST_AOK : Return : Endif

# Delete FACGROUP
Local File FACGROUP [FGR]
Local Instance FACGROUP Using C_FACGROUP

For [F:FGR] Where CPY=this.CPY
  FACGROUP = NewInstance C_FACGROUP AllocGroup null
  SetInstance FACGROUP With [F:FGR]
  [L]ASTATUS = fmet FACGROUP.ADELETE()
  If [L]ASTATUS <> [V]CST_AOK
    [L]ASTATUS=fmet this.ASETERROR("FACGROUP","Delete error message",[V]CST_AERROR)
  Endif
  FreeGroup FACGROUP
  If [L]ASTATUS <> [V]CST_AOK : Break : Endif
Next

Return

###############################################################################################
$BPA_CONTROL
[L]ASTATUS = func BPADDRESS_CSTD.CTRL_ADR(this.BPA)
Return

###############################################################################################
$BID_CONTROL
Local Integer BID_DEFAULT_INDEX
[L]ASTATUS = func BID_CSTD.CTRL_BID(this.BID, BID_DEFAULT_INDEX)
If BID_DEFAULT_INDEX>0
  this.BIDNUM = this.BID(BID_DEFAULT_INDEX).BIDNUM
Else
  this.BIDNUM = AVOID.ACHAR
Endif

Return

###############################################################################################
$COMPANY_CODE_CONTROL
Local Instance FACILITY Using C_FACILITY
Local Integer CPYMAXLEN,CPYMINLEN
Local Clbfile ENTMES(1)
Local Char    TEXMES(250)

If this.ASTALIN = [V]CST_ANEW
  FACILITY = NewInstance C_FACILITY AllocGroup null
  If fmet FACILITY.AREAD(this.CPY) = [V]CST_AOK
    # This code already exists as a site
    [L]ASTATUS = fmet this.ASETERROR(this.CPY,mess(39,133,1),[V]CST_AERROR)
  Endif
  FreeGroup FACILITY

  CPYMAXLEN = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"CPYMAXLEN")
  CPYMINLEN = fmet this.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"CPYMINLEN")
  If CPYMAXLEN>0 & CPYMAXLEN=CPYMINLEN & len(this.CPY)<>CPYMAXLEN
    # Afin de garantir une homogénéité dans la numérotation des documents si vous avez inséré le code $1$ dans la structure des
    # compteurs correspondants, il ne vous est pas possible de créer un code $2$ avec un code de longueur différente de $3$.
    # Si vous voulez passer outre, l'administrateur général devra passer renseigner des valeurs différentes, pour les
    # paramètres $4$ et $5$. Les numérotations de documents qui intègrent un code $6$
    # complèteront alors les codes $7$ de longueur inférieure à $8$ avec des caractères $9$.
    # ENTMES = mess(226,125,1)+mess(227,125,1)+mess(228,125,1)+mess(229,125,1)+mess(230,125,1)

    TEXMES = mess(26,113,1)+"~"+mess(26,113,1)+"~"+num$(CPYMAXLEN)+"~CPYMINLEN~CPYMAXLEN~"+mess(26,113,1)
    TEXMES += "~"+mess(26,113,1)+"~"+num$(CPYMAXLEN)+"~_"
    ENTMES = func ASYRFNC.MESNC(ENTMES,TEXMES)
    [L]ASTATUS = fmet this.ASETERROR(this.CPY,TEXMES ,[V]CST_AERROR)
  Endif
Endif

Return

###############################################################################################
$COMPANY_DEPENDENCY

# Default Company Fields
#Set Company Attributes
[L]ASTATUS = fmet this.ASETATTRIBUTE("NID","$isMandatory","false")
[L]ASTATUS = fmet this.ASETATTRIBUTE("CRN","$isMandatory","false")
[L]ASTATUS = fmet this.ASETATTRIBUTE("EECNUM","$isMandatory","false")

#Control on CPYLEGFLG - Read facility by 2nd index - Legal Company/Facility
If this.CPYLEGFLG=[V]CST_AYES
  [L]ASTATUS = fmet this.ASETATTRIBUTE("STRPER","$isMandatory","true")
  [L]ASTATUS = fmet this.ASETATTRIBUTE("CRY","$isMandatory","true")
  Local File FACILITY [FCY]
  Read [FCY]FCY1(1) = this.CPY
  If fstat = [V]CST_AOK & AEVENT<>"AUPDATE_BEFORE"
     # Sites created in this legal company
     [L]ASTATUS = fmet this.ASETERROR("FACILITY",mess(42,133,1),[V]CST_AWARNING)
  Endif
  If this.CRY<>AVOID.ACHAR
   If fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"CRNOBL")<>[V]CST_AYES
     [L]ASTATUS = fmet this.ASETATTRIBUTE("NID","$isMandatory","true")
     [L]ASTATUS = fmet this.ASETATTRIBUTE("CRN","$isMandatory","true")
     [L]ASTATUS = fmet this.ASETATTRIBUTE("EECNUM","$isMandatory","true")
   Endif
   [L]ASTATUS = fmet this.ASETATTRIBUTE("RGCCUR","$isMandatory","true")
  Else
     this.CRY = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"CRYDEF")
  Endif
Else
  this.STRPER = AVOID.ADATE
  this.RGCCUR = AVOID.ACHAR
  If this.RGCCUR=AVOID.ACHAR
    this.RGCCUR = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"SYSCUR")
  Endif
  this.RGCAMT = AVOID.ADEC
  this.ACCCUR = AVOID.ACHAR
  this.CRN    = AVOID.ACHAR
  this.NID    = AVOID.ACHAR
  If this.CRY<>AVOID.ACHAR & fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"EECFLG")=[V]CST_AYES
     this.EECNUM = fmet this.ACTX.ACACHE.ACRY.AGETVALCHAR(this.CRY,"CRYVATNUM")
  Endif
Endif

Return

###############################################################################################
$BPA_ADELLINE_BEFORE
Local Integer I

For I = 1 To maxtab(this.BID)
  If this.BID(I).BPAADD = this.BPA(ALINE).BPAADD
    If find(this.BID(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) = [V]CST_AFALSE
      [L]ASTATUS = fmet this.ASETERROR("BPAADD",this.BPA(ALINE).BPAADD-mess(169,133,1)-this.BID(I).BIDNUM,[V]CST_AERROR)
    Endif
  Endif
Next
Return

###############################################################################################
$CPYLEGFLG
# Country
Case [L]ARULE
  When "PROPAGATE"             : Gosub CPYLEGFLG_PROPAGATE
Endcase
Return

$CPYLEGFLG_PROPAGATE
Gosub COMPANY_DEPENDENCY
Return

###############################################################################################
$CRY
# Country
Case [L]ARULE
  When "INIT"             : Gosub CRY_INIT
  When "PROPAGATE"        : Gosub CRY_PROPAGATE  :#X3-60504
Endcase
Return

$CRY_INIT
If this.CRY=AVOID.ACHAR
  this.CRY = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"CRYDEF")
Endif
Return

#X3-60504
$CRY_PROPAGATE
  #X3-69093
  If dim(this.ORICERFLG)>=0
&  & fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"EECFLG")<>[V]CST_AYES
&  & fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"GSPFLG")<>[V]CST_AYES
    this.ORICERFLG=[V]CST_ANO
  Endif
Return
#End X3-60504

###############################################################################################
$EECNUM
# Country
Case [L]ARULE
  When "INIT"             : Gosub EECNUM_INIT
Endcase
Return

$EECNUM_INIT
If this.CRY<>AVOID.ACHAR & fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"EECFLG")=[V]CST_AYES
   this.EECNUM = fmet this.ACTX.ACACHE.ACRY.AGETVALCHAR(this.CRY,"CRYVATNUM")
Endif
Return

###############################################################################################
$MAIFCY
# Main facility
Case [L]ARULE
  When "CONTROL"            : Gosub MAIFCY_CONTROL
Endcase
Return

$MAIFCY_CONTROL
If this.MAIFCY<>AVOID.ACHAR
  If this.CPY<>fmet this.ACTX.ACACHE.AFCY.AGETVALCHAR(this.MAIFCY, "LEGCPY")
    # This site is in the company (Main facility is in a different company)
    [L]ASTATUS = fmet this.ASETERROR("MAIFCY",mess(43,133,1)-[L]LEGCPY ,[V]CST_AERROR)
  Endif
Endif
Return

###############################################################################################
$NID
# Identification number
Case [L]ARULE
  When "CONTROL"            : Gosub NID_CONTROL
Endcase
Return

$NID_CONTROL
If this.NID=AVOID.ACHAR and this.CRY<>AVOID.ACHAR
  If fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"CRNOBL")=[V]CST_AYES
    [L]ASTATUS = fmet this.ASETATTRIBUTE("NID","$isMandatory","true")
  Else
    [L]ASTATUS = fmet this.ASETATTRIBUTE("NID","$isMandatory","false")
  Endif
Endif
Return

###############################################################################################
$RGCCUR
# Capital currency
Case [L]ARULE
  When "INIT"             : Gosub RGCCUR_INIT
Endcase
Return

$RGCCUR_INIT
If this.CPYLEGFLG = [V]CST_AYES
  If this.RGCCUR= AVOID.ACHAR
    this.RGCCUR = fmet this.ACTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD,this.ACTX.AFOLDER,"SYSCUR")
  Endif
Endif
Return

###############################################################################################
$BPA_BPAADD
Case [L]ARULE
  When "CONTROL"          : Gosub BPA_BPAADD_CONTROL
Endcase
Return

$BPA_BPAADD_CONTROL
Local Integer I,CNT

If this.APARENT.BPA<>null
  For I=1 To maxtab(this.APARENT.BPA)
      If find(this.APARENT.BPA(I).ASTALIN,[V]CST_ADEL, [V]CST_ANEWDEL)=[V]CST_AFALSE
        If this.APARENT.BPA(I).BPAADD=this.BPAADD
          CNT+=1
        Endif
      Endif
  Next
  If CNT>1
    [L]ASTATUS = fmet this.APARENT.ASETERROR("BPADDRESS",this.BPAADD-mess(29,100,1),[V]CST_AERROR)
  Endif
Endif
Return

###############################################################################################
$BPA_BPAADDFLG
Case [L]ARULE
  When "PROPAGATE"        : Gosub BPA_BPAADDFLG_PROPAGATE
Endcase
Return

$BPA_BPAADDFLG_PROPAGATE
Local Integer I

If this.BPAADDFLG= [V]CST_AYES
  For I=1 To maxtab(this.APARENT.BPA)
    If this.APARENT.BPA(I)<> null
     If this.APARENT.BPA(I).BPAADDFLG = [V]CST_AYES
        this.APARENT.BPA(I).BPAADDFLG = [V]CST_ANO
      Endif
    Endif
  Next
  this.BPAADDFLG= [V]CST_AYES
  this.APARENT.BPAADD = this.BPAADD
 Endif

Return

###############################################################################################
$BID_BIDNUMFLG
# Bank id default
Case [L]ARULE
  When "PROPAGATE"        : Gosub BID_BIDNUMFLG_PROPAGATE
Endcase
Return

$BID_BIDNUMFLG_PROPAGATE
Local Integer I

If this.BIDNUMFLG= [V]CST_AYES
  For I=1 To maxtab(this.APARENT.BID)
    If this.APARENT.BID(I)<> null
      If this.APARENT.BID(I).BIDNUMFLG = [V]CST_AYES
        this.APARENT.BID(I).BIDNUMFLG = [V]CST_ANO
      Endif
    Endif
  Next
  this.BIDNUMFLG= [V]CST_AYES
  this.APARENT.BIDNUM = this.BIDNUM
 Endif
Return

###############################################################################################
$BID_BPAADD
# Bank Id address code
Case [L]ARULE
  When "CONTROL"          : Gosub BID_BPAADD_CONTROL
Endcase
Return

$BID_BPAADD_CONTROL
Local Integer I,OK

If this.BPAADD<>AVOID.ACHAR
  [L]OK=[V]CST_AFALSE
  If this.APARENT.BPA<>null
    For I=1 To maxtab(this.APARENT.BPA)
        If find(this.APARENT.BPA(I).ASTALIN,[V]CST_ADEL, [V]CST_ANEWDEL)=[V]CST_AFALSE
          If this.APARENT.BPA(I).BPAADD=this.BPAADD
            [L]OK=[V]CST_ATRUE
            Break               # address found
          Endif
        Endif
    Next
  Endif
  If [L]OK=[V]CST_AFALSE
    # Address code does not exist
    [L]ASTATUS = fmet this.APARENT.ASETERROR("BPAADD",this.BPAADD-mess(46,133,1),[V]CST_AERROR)
  Endif
Endif
Return

###############################################################################################
$BID_BIDNUM
# Bank Id number
Case [L]ARULE
  When "CONTROL"          : Gosub BID_BIDNUM_CONTROL
Endcase
Return

$BID_BIDNUM_CONTROL
Local Integer I,CNT

CNT=0
If this.APARENT.BID<>null
  For I=1 To maxtab(this.APARENT.BID)
      If find(this.APARENT.BID(I).ASTALIN,[V]CST_ADEL, [V]CST_ANEWDEL)=[V]CST_AFALSE
        If this.APARENT.BID(I).BIDNUM=this.BIDNUM
          CNT+=1
        Endif
      Endif
  Next
  If CNT>1
    # [BIDNUM] already entered on line
    [L]ASTATUS = fmet this.APARENT.ASETERROR("BIDNUM",this.BIDNUM-mess(29,100,1),[V]CST_AERROR)
  Endif
Endif

Return

###############################################################################################
#X3-60504
$ORICERFLG
# Origin's auto-certification
  Case [L]ARULE
    When "INIT"             : Gosub ORICERFLG_INIT
    When "PROPAGATE"        : Gosub ORICERFLG_PROPAGATE
  Endcase
Return

$ORICERFLG_INIT
  If this.ORICERFLG<[V]CST_ANO
    this.ORICERFLG = [V]CST_ANO
  Elsif this.CRY<>AVOID.ACHAR & fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"EECFLG")<>[V]CST_AYES & fmet this.ACTX.ACACHE.ACRY.AGETVALNUM(this.CRY,"GSPFLG")<>[V]CST_AYES
    this.ORICERFLG=[V]CST_ANO
  Endif
Return

$ORICERFLG_PROPAGATE
  If this.ORICERFLG<>[V]CST_AYES
    this.REXNUM = AVOID.ACHAR
  Endif
Return
#End X3-60504
###############################################################################################

