##############################################################################
## MAJ de l'onglet sélection de l'objet AYF (Champs)
##############################################################################

Subprog EXE_SELAYF(APPLI)
Value Char APPLI

Call ECR_TRACE("SELAyF : Process Start on : "+APPLI,0) From GESECRAN

Call DEBTRANS From GLOCK
Call MAJ_SEL(APPLI,"AYF") From PATCHAOB
Call ECR_TRACE("SELAYF : Process End on : "+APPLI,0) From GESECRAN
End


Subprog PATCH(APPLI)
Value Char    APPLI
Call EXE_SELAYF(APPLI)
End
