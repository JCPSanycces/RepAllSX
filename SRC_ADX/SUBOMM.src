#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du fichier MAILING
Call OBJET ("OMM", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"       : Gosub OUVRE
    When "OUVRE_BOITE" : Gosub OUVRE_BOITE
    When "FERME"       : Gosub FERME
    When "RAZCRE"      : Gosub RAZCRE
    When "LIENS"       : Gosub LIENS
    When "SETBOUT"     : Gosub SETBOUT
    When "INICRE"      : Gosub INICRE
    When "VERIF_CRE"   : Gosub VERIF_CRE
    When "VERIF_MOD"   : Gosub VERIF_MOD
    When "CREATION"    : Gosub CREATION
    When "MODIF"       : Gosub MODIF
    When "APRES_CRE"   : Gosub APRES_CRE
    When "APRES_MOD"   : Gosub APRES_MOD
    When "VERF_ANU"    : Gosub VERF_ANU
    When "AV_ANNULE"   : Gosub AV_ANNULE
    When "ANNULE"      : Gosub ANNULE
    When "AVANTBOUT"   : Gosub AVANTBOUT
    When "FILGAUCHE"   : Gosub FILGAUCHE
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char GCOMMCPT(GLONANM)   # Code compteur pour une opération marketing

Local Char SZBOXOMM(10)
Local Char SZBOXOM2(10)
Local Char SZSITE(GLONFCY)

  SZSITE = ""
  Call SITECRMDEF ("ACT", SZSITE) From CRM_UTIL
  GFCY = SZSITE
  Call GETDEV(GFCY) From DEVSUB
Return

##########################################################################################################
$OUVRE_BOITE
  #---------------------------------------------------#
  # FGR 30/07/2014 : X3SUIVI101463
  Link [OMM] With [O_MM]OMM0=[F:OMM]OMMNUM,
&                 [AFF]AFF0~=[F:OMM]FCY;GPROFIL;GUSRFCT,
&                 [FGR]FGR0=GGRPFCY;[F:OMM]FCY
&              As [OM2]
  #---------------------------------------------------#
  #Chargement des noms des cuurbox de chaque tiroir
  If OBJLIS(0) = "OMM" Then
    SZBOXOMM = "GAU_CHE"
  Else
    SZBOXOMM = "GAU_CHE" + num$(find("OMM",OBJLIS(1..8))) : # Publipostages actifs
  Endif
  If OBJLIS(0) = "OM2" Then
    SZBOXOM2 = "GAU_CHE"
  Else
    SZBOXOM2 = "GAU_CHE" + num$(find("OM2",OBJLIS(1..8))) : # Publipostages clôturés
  Endif
Return

##########################################################################################################
$FERME
  If type(GSZWIZCOD) > 0 Then
    Gosub FINSAI From TRTWIZ2
  Endif
  If GPILNAV > 1 Then
    If GNAVIG(GPILNAV-1) = "GESCMG" Then
      Call LOAD_OPG From SUBCMGB
    Endif
  Endif
  # FGR 15/06/2015 : X3SUIVI108846 (début)
  If dim(GCOMMCPT) >= 0 Then
    Kill GCOMMCPT            # Code compteur pour une opération marketing.
  Endif
  # FGR 15/06/2015 : X3SUIVI108846 (fin)
Return

##########################################################################################################
$FILGAUCHE
  Default File [OMM]
  If currbox = SZBOXOMM Then
    # Publipostages actifs
    Call ADDCRIT(FILGAUCHE, IFILGAUCHE, "FILGAUCHE", "CLO <> 2", "&") From GOBJSUB
  Elsif currbox = SZBOXOM2 Then
    # Publipostages clôturés
    Call ADDCRIT(FILGAUSUP, IFILGAUSUP, "FILGAUSUP", "CLO = 2", "&") From GOBJSUB
    Call AJOUTE_CONDITION_ROLE (FILGAUSUP, IFILGAUSUP, "OMM") From CRMUTIL150  # FGR 14/04/2009 : X3SUIVI54295 : réactivation des rôles
  Endif
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  # FGR 15/06/2015 : X3SUIVI108846 (début)
  If dim(GCOMMCPT) < 0 Then
    Global Char GCOMMCPT(GLONANM)   # Code compteur pour une opération marketing
  Endif
  # FGR 15/06/2015 : X3SUIVI108846 (fin)
  Call READ_COUNTER([M:OMM0]FCY, 13, 2, GSOCIETE, GCURLEG, GCOMMCPT, GMANCOU) From CRM_UTIL        # FGR 20/05/2015 : X3SUIVI107775
  # Récupération du compteur
  If func CRM_UTIL.GET_NUMERO_CHRONO ("ACT", [M:OMM0]FCY, GCOMMCPT, date$, "", [M:OMM0]OMMNUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
      [F:OMM]OMMNUM = [M:OMM0]OMMNUM
      Affzo [M:OMM0]OMMNUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GOK = 0
      Return
    Endif
  Endif
  [F:OMM]TYPFULOBJ = "OMM"
  [F:OMM]NUMFULOBJ = [M:OMM0]OMMNUM
  [M:OMM1]TYPFULOBJ = "OMM"
  [M:OMM1]NUMFULOBJ = [M:OMM0]OMMNUM
Return

##########################################################################################################
$VERIF_CRE
  # FGR 06/08/2014 : X3SUIVI95250 (début)
  #  #Synthèse Objet de l'action
  #  If [M:OMM1]FULOBJ = "" Then
  #    [M:OMM1]OBJ = ""
  #  Else
  #    [M:OMM1]OBJ = left$([M:OMM1]FULOBJ,250)
  #  Endif
  # FGR 06/08/2014 : X3SUIVI95250 (fin)
Return

##########################################################################################################
$VERIF_MOD
  # FGR 06/08/2014 : X3SUIVI95250 (début)
  #  #Synthèse Objet de l'action
  #  If [M:OMM1]FULOBJ = "" Then
  #    [M:OMM1]OBJ = ""
  #  Else
  #    [M:OMM1]OBJ = left$([M:OMM1]FULOBJ,250)
  #  Endif
  # FGR 06/08/2014 : X3SUIVI95250 (fin)
  Gosub CHECKMODIF From SUBOMMB
Return

##########################################################################################################
$CREATION
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBOMMB
  If GOK < 1 Then
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("OMM",1) From SUBPS2
Return

##########################################################################################################
$MODIF
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBOMMB
  If GOK < 1 Then
    Return
  Endif
  # Maj des statistiques
  Call VALSTA("OMM",-1) From SUBPS2
  Call VALSTA("OMM",1) From SUBPS2
Return

##########################################################################################################
$APRES_CRE
  [M:OMM0]OMMPRECLO = [M:OMM2]CLO
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBOMMB
  Affzo [M:OMM1]1-99
Return

##########################################################################################################
$APRES_MOD
  [M:OMM0]OMMPRECLO = [M:OMM2]CLO
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBOMMB
  Affzo [M:OMM1]
Return

##########################################################################################################
$VERF_ANU
  Gosub CONFIRM_ANU
Return

##########################################################################################################
$CONFIRM_ANU
Local Integer IMESSREP

  IMESSREP = 0
  #La suppression d'une opération marketing interdit toute analyse ultérieure de ses retours. Confirmez-vous sa suppression ?
  Call OUINON(mess(698,182,1), IMESSREP) From GESECRAN
  If IMESSREP = 2 Then
    #Tous les historiques relatifs à cette opération seront supprimés. Confirmez-vous sa suppression ?
    Call OUINON(mess(700,182,1), IMESSREP) From GESECRAN
    If IMESSREP <> 2 Then
      #La suppression de l'opération marketing est abandonnée.
      GMESSAGE = mess(699,182,1)
      GERR = 2
      OK = 0
    Endif
  Else
    #La suppression de l'opération marketing est abandonnée.
    GMESSAGE = mess(699,182,1)
    GERR = 2
    OK = 0
  Endif
Return

##########################################################################################################
$AV_ANNULE
Local Char GSZOPGNUM(type([M:OMM0]OMMNUM)-10)
Local Integer IDELTODOCALL

  IDELTODOCALL = 0
  GSZOPGNUM = [M:OMM0]OMMNUM
  Gosub ANNULEOMM
Return

##########################################################################################################
$ANNULEOMM
  Gosub CANCELSTEP From TRTMGD1
  If GOK = 0 Then
     Return
  Endif
  Gosub CANCELSTEP From TRTMAI3
  If GOK = 0 Then
     Return
  Endif
  Gosub RAZ2OMMRES From TRTMAI4
  If GOK = 0 Then
     Return
  Endif
  Gosub CANCELSTEP From TRTMAI6
  If GOK = 0 Then
     Return
  Endif
  Gosub CLEANHISTO From SUBOMMB
  If GOK = 0 Then
     Return
  Endif
  #Suppression des clobs
  Gosub DELCLOB2 From SUBOMMB
  If GOK = 0 Then
     Return
  Endif
Return

##########################################################################################################
$ANNULE
  # Maj des statistiques
  Call VALSTA("OMM",-1) From SUBPS2
Return

##########################################################################################################
$SETBOUT
  # On ne peut pas rééxpédier un mailing d'une campagne clôturée
  Read [CMG]CMG0=[M:OMM0]CMGNUM
  If !fstat Then
    If [F:CMG]CLO <> 2 Then
      If REP = "" Then
        CHMEN += "G"
      Endif
    Endif
  Endif
  # Echantillon
  If REP <> "" Then
    Call VIREBOUT(CHAINE, "I") From GOBJET
  Endif
  # Retours marketing
  If REP <> "" Then
    Call VIREBOUT(CHAINE, "P") From GOBJET
  Else
    If [M:OMM0]CMGNUM = "" Then
      Call VIREBOUT(CHAINE, "P") From GOBJET
    Endif
    If [M:OMM0]OMMNUM = "" Then
      Call VIREBOUT(CHAINE, "P") From GOBJET
    Endif
  Endif
  #----- Activation menus ToolBar a partir des codes contenus dans CHMEN -----#
  Gosub SET_BOUT_SPE From GSAISIE
  Call VIREBOUT(CHAINE, "HC") From GOBJET
Return

##########################################################################################################
$AVANTBOUT
  If BOUT = "I" Then
    Local Char PARAM(30)(2)

    Raz PARAM
    PARAM(1) = "MAILING"
    Gosub OUVRE From TRTWIZ2
    GIFSTEP = 1
    GICSTEP = 4
    GINBSTEP = 8
    GILSTEP = 8
    Gosub SETWIZVAR From TRTWIZ2
    GSZCMGNUM = [M:OMM0]CMGNUM
    Gosub SETVAR From TRTWIZ2
    GSZOPGNUM = [M:OMM0]OMMNUM
    If GSZOPGNUM = "" Then
      #Aucun chrono d'opération publipostage n'a pu être obtenu.
      GMESSAGE = mess(673,182,1)
      GERR = 1
      Gosub FINSAI From TRTWIZ2
      OK = 0
    Endif
  Endif
Return

##########################################################################################################
$RAZCRE
  #Initialise le site par défaut
  Call SITECRMDEF("ACT", [M:OMM0]FCY) From CRM_UTIL
  GFCY = [M:OMM0]FCY
  Call GETDEV(GFCY) From DEVSUB
  #Initialise la devise par défaut
  [M:OMM1]CUR = GSYSCUR
  [M:OMM2]CLO = 1
  Raz [M:OMM2]CLODAT
  #Initialise les informations d'expéditions
  [M:OMM2]SHIDAT = [00/00/00]
  [M:OMM2]SHIMOD = 0
  [M:OMM2]SHISTA = 0
  [M:OMM2]SHIMODX = ""
  [M:OMM2]SHISTAX = ""
  [M:OMM2]NBQSND = 0
  [M:OMM0]OMMNUM  = ""
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBOMMB
  Affzo [M:OMM0]1-99
  Affzo [M:OMM1]1-99
  Affzo [M:OMM2]1-99
Return

##########################################################################################################
$LIENS
  GFCY = [M:OMM0]FCY
  Call GETDEV(GFCY) From DEVSUB
  #---------------------------------------------------#
  #Lecture des clobs
  #---------------------------------------------------#
  Gosub LOADCLOB From SUBOMMB
  #Affiche le nom de la campagne
  If [M:OMM0]CMGNUM <> "" Then
    Read [CMG]CMG0=[M:OMM0]CMGNUM
    If fstat Then
      [M:OMM0]CMGTTR = [M:OMM0]CMGNUM
    Else
      [M:OMM0]CMGTTR = [F:CMG]TTR
    Endif
  Endif
  # Affichage des informations d'expédition
  If [M:OMM2]SHIMOD = 0 Then
    [M:OMM2]SHIMODX = ""
  Elsif [M:OMM2]SHIMOD = 1 Then
    [M:OMM2]SHIMODX = mess(395,196,1)  # Expédié via courrier
  Elsif [M:OMM2]SHIMOD = 2 Then
    [M:OMM2]SHIMODX = mess(396,196,1)  # Expédié via E-Mail
  Elsif [M:OMM2]SHIMOD = 3 Then
    [M:OMM2]SHIMODX = mess(397,196,1)  # Expédié via Fax
  Elsif [M:OMM2]SHIMOD = 4 Then
    [M:OMM2]SHIMODX = mess(665,182,1)  # Expédié XML
  Endif
  If [M:OMM2]SHISTA = 0 Then
    [M:OMM2]SHISTAX = ""
  Elsif [M:OMM2]SHISTA = 1 Then
    [M:OMM2]SHISTAX = mess(1,968,1)    # Terminé avec succès
  Elsif [M:OMM2]SHISTA = 2 Then
    [M:OMM2]SHISTAX = mess(2,968,1)    # Interrompu
  Endif
  [M:OMM0]OMMPRECLO = [M:OMM2]CLO
  #---------------------------------------------------#
  #Affichage des icônes
  #---------------------------------------------------#
  Gosub DISPICON From SUBOMMB
  Affzo [M:OMM0]1-99
  Affzo [M:OMM1]1-99
  Affzo [M:OMM2]1-99
  #---------------------------------------------------#
  # FGR 16/01/2013 : X3SUIVI92373 : pour le moment on l'envlève
#  Local Integer LRET_VALUE
#  Local Char SKEY(type([M:OMM0]OMMNUM)-10)
#
#  SKEY = [M:OMM0]OMMNUM
#  If [M:OMM2]TYPMRG = 2 Then
#    # Seulement si le document a été envoyé via Word.
#    LRET_VALUE = func AOFFDOC.WORD_MAILMERGE("OMMRESULT", "OMMRESULT", SKEY, 1, isomess, "", "", "")
#  Else
#    # Sinon, on l'efface
#    LRET_VALUE = func AOFFDOC.WORD_MAILMERGE("OMMRESULT", "OMMRESULT", SKEY, 0, isomess, "", "", "")
#  Endif
  #---------------------------------------------------#
Return

##########################################################################################################
Subprog IB_FULOBJ
  Raz GBOUT1
  If [M:OMM1]FULOBJ<> "" Then
    If len([M:OMM1]FULOBJ) > GLONCLE Then
      Call TEXTE(23819, GBOUT1) From OBJDIV      # Synthèse
    Endif
  Endif
End

##########################################################################################################
Subprog AM_FULOBJ (VALEUR)
Variable Clbfile VALEUR

  Call GERE_TEXTE_SYNTHESE([M:OMM1]FULOBJ, VALEUR, [M:OMM1]OBJ) From CRMUTIL150  # FGR 06/08/2014 : X3SUIVI95250
  [M:OMM1]FULOBJ = VALEUR
  Gosub DISPICON From SUBOMMB
  Affzo [M:OMM1]1-99
End

##########################################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  GFCY = VALEUR
  Call GETDEV(GFCY) From DEVSUB
End

##########################################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  If VALEUR <> "" Then
    Call CMGCTRLFCY(VALEUR,[M:OMM0]CMGNUM,IERRINF,ICHAPTER,IBRETOUR) From SUBCMGB
    If IBRETOUR = 0 Then
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GERR = 1
      mkstat = 2
      End
    Endif
  Endif
End

##########################################################################################################
Subprog AV_FCY(VALEUR)
Variable Char    VALEUR()

  # FGR 21/01/2013 : X3SUIVI71937
  If dim(GCOMMCPT) < 0 Then
    Global Char GCOMMCPT(GLONANM)   # Code compteur pour une opération marketing
  Endif
End

##########################################################################################################
Subprog AM_CLO(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    If [M:OMM0]OMMPRECLO <> 2 Then
      [M:OMM2]CLODAT = date$
    Endif
  Endif
End

