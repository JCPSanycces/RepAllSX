#<AdxTL>@(#)44.0.0.0 $Revision$
Call OBJET("DTP",GBIDC1,GBIDC2) From GOBJET 
End 
 
$ACTION
Case ACTION
 When "RAZCRE"    : Gosub RAZCRE 
 When "VERIF_CRE" : Gosub VERIF
 When "VERIF_MOD" : Gosub VERIF
 When "LIENS"     : Gosub LIENS
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "AP_CHANGE" : Gosub AP_CHANGE
 When "ANNULE"    : Gosub ANNULE
 When "INICRE"    : Gosub INICRE
 When "INIMOD"    : Gosub INIMOD
 When Default
Endcase
Return

$INICRE
$INIMOD
If dim([F:DTP]DES)>0
 [F:DTP]DES = [M:DTP1]DESTRA
Endif
Return


$RAZCRE 
[M]NBMOIS = 12 
Affzo 20
Return 
 
$VERIF
If sum([M]COE)=0
 GMESSAGE = mess(6,104,1) : # La somme des coefficients doit être non nulle
 OK = 0
 If !GINTRA : zonsui = "NBMOIS" : Endif
Endif
Return

$LIENS
Call LECTEXTRA([M:DTP1]DESTRA,"CADISTMP","DESTRA",[M:DTP1]DTP,"") From ATEXTRA
Call LECTEXTRA([M:DTP1]SHOTRA,"CADISTMP","SHOTRA",[M:DTP1]DTP,"") From ATEXTRA
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("CADISTMP","DESTRA",CLECUR1,"","CADISTMP","DESTRA",[M:DTP1]DTP,"")  From ATEXTRA
 Call DUPTEXTRA("CADISTMP","SHOTRA",CLECUR1,"","CADISTMP","SHOTRA",[M:DTP1]DTP,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M:DTP1]DESTRA,"CADISTMP","DESTRA",[M:DTP1]DTP,"") From ATEXTRA
Call MAJTEXTRA([M:DTP1]SHOTRA,"CADISTMP","SHOTRA",[M:DTP1]DTP,"") From ATEXTRA
Return


$AP_CHANGE
Call CHGTEXTRA("CADISTMP","DESTRA",[M:DTP1]DTP,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("CADISTMP","SHOTRA",[M:DTP1]DTP,"",NCODE,"") From ATEXTRA
Return


$ANNULE
Call SUPTEXTRA("CADISTMP","DESTRA",[M:DTP1]DTP,"") From ATEXTRA
Call SUPTEXTRA("CADISTMP","SHOTRA",[M:DTP1]DTP,"") From ATEXTRA
Return





########################################
Subprog AV_NBMOIS
[M]NBMOIS = 12
End

