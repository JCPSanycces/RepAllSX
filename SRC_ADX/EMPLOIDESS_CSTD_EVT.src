$PASS_CLASSES_WORKFLOW

#The following steps must be followed to trigger the workflow for all employee related records
#Declare all variables - Standard no custom code needed
Gosub PASS_CLASSES_WORKFLOW_VARIABLES From ESS_WRKFLOW_FUNC

#Using activity codes - Check all classes and pass to workflow function in ESS_FUNCTIONS
#All legislations - No activity code check needed
#Getting paramater values
If this.EMPESS <> null
  #Pass the main class of the basic class EMPESSB to get the main table details (Table name, Abbr)
  CLASSPARAMFNC = func ESS_FUNCTIONS.GET_CLASS_PARAMETERS("EMPLOID",CTABLE,CABR)
  If CLASSPARAMFNC = [V]CST_AOK and this.EMPESS(COLLECTION_IND) <> null
    #Before creating possible workflow records - indicate any properties that must be excluded (SYSPROP - From (30)
    CLASS_WRKFLOW = func ESS_WRKFLOW_FUNC.GENESSWRKFLOW_DETAIL(this.EMPESS(COLLECTION_IND), CTABLE, CABR,CLASS_ERROR,SYSPROP)
    #Handle return messages
    Gosub HANDLE_CLASS_WRKFLOW From ESS_WRKFLOW_FUNC
  Endif
Endif

Return

$DECLARE_AREAD_VAR
Local Integer COL_INDEX,L,READSTATUS,K,M,N,O
COL_INDEX = 1
L = 1
Return


$AREAD_CLASSTRNS_EMPESS
Local File EMPLOID [ID2]
Local File EMPLOIDRT [IDR3]
Gosub DECLARE_AREAD_VAR #Set COL_INDEX = 1, L = 1

Read [F:ID2]ID0 = this.REFNUM
If fstat = [V]CST_AOK
  #Do class transfer
  If this.EMPESS(COL_INDEX) = null
    L = fmet this.ADDLINE("EMPESS",COL_INDEX)
  Endif
  SetInstance this.EMPESS(L) With [F:ID2]

  #Title - KZA
  If func DIVPAYE.IS_KZA(this.TCH_LEG)>0
    this.TCH_CIVKZA = [F:ID2]CIV
  Endif
  #FRLAA 2018-01-30 X3-74425 - START
  #Title - KUK
  If func DIVPAYE.IS_KUK_LEG(this.TCH_LEG)>0
    this.TCH_CIVKUK = [F:ID2]CIV
  Endif
  #FRLAA 2018-01-30 X3-74425 - END
Endif


#begin Employe Contract Spouse
#Load Contract Spouse infromation into class
#TODO: Use class transfer and not per field
Local File EMPLOCTR [EMPCTR]

Filter [F:EMPCTR] Where REFNUM = this.REFNUM
Local Integer INDX : INDX = 1

For [EMPCTR]
  L = fmet this.ADDLINE("CTRJNT",INDX)
  this.CTRJNT(L).SITFAM = [EMPCTR]SITFAM
  this.CTRJNT(L).JNTREFNUM = [EMPCTR]JNTREFNUM
  this.CTRJNT(L).JNTNAM = [EMPCTR]JNTNAM
  this.CTRJNT(L).JNTSRN = [EMPCTR]JNTSRN
  this.CTRJNT(L).JNTDATBRN = [EMPCTR]JNTDATBRN
  this.CTRJNT(L).JNTCRY = [EMPCTR]JNTCRY
  this.CTRJNT(L).JNTTEL = [EMPCTR]JNTTEL
  If func DIVPAYE.IS_KUK_LEG(this.TCH_LEG)>0
    Local File EMPLOCTRUKI [CTRUKI3]
    Read [CTRUKI3]CTRUKI0 = [F:EMPCTR]REFNUM;[F:EMPCTR]CTRNUM;[F:EMPCTR]CTRDAT
    If fstat = [V]CST_AOK
      this.CTRJNT(L).SITFAMUKI    = [F:EMPCTR]SITFAM
      this.CTRJNT(L).PARTTL       = [F:CTRUKI3]PARTTL
      this.CTRJNT(L).PARSECNAM    = [F:CTRUKI3]PARSECNAM
      this.CTRJNT(L).PARINI       = [F:CTRUKI3]PARINI
      this.CTRJNT(L).PARNIN       = [F:CTRUKI3]PARNIN
    Endif
    LogicClose File [CTRUKI3]
  Endif
  INDX = INDX + 1
Next

Filter [F:EMPCTR]
LogicClose File [EMPCTR]


#Persons to contact
Local Instance I_EMPLOID Using C_EMPLOID
If (I_EMPLOID <> null) : FreeGroup I_EMPLOID : Endif
I_EMPLOID = NewInstance C_EMPLOID AllocGroup null
[L]READSTATUS = fmet I_EMPLOID.AREAD(this.REFNUM)
If ([L]READSTATUS  >= [V]CST_AERROR)
  #Error not handled - no class transfer will be performed
Else
  If I_EMPLOID.PERCNT <> null
    For K = 1 To maxtab(I_EMPLOID.PERCNT)
      If I_EMPLOID.PERCNT(K).NAMCNT <> AVOID.ACHAR
        L = fmet this.EMPESS.ADDLINE("PERCNT",K)
        Raz [F:IDR3]
        SetInstance [F:IDR3] With I_EMPLOID.PERCNT(K)
        SetInstance this.EMPESS.PERCNT(L) With [F:IDR3]
        this.EMPESS.PERCNT(L).TCH_CNTSTA = "T"
        #JOJAC - 2017-06-01 - START
        this.EMPESS.NBCNT = L
        #JOJAC - 2017-06-01 - END
      Endif
    Next
  Endif
Endif


#Relationship type
#RSA and Africa
If func DIVPAYE.IS_AFRICA_LEG(this.TCH_LEG)>0 or func DIVPAYE.IS_KZA(this.TCH_LEG)>0
  Local Instance I_EMPLOIDSA Using C_EMPLOIDSA
  If (I_EMPLOIDSA <> null) : FreeGroup I_EMPLOIDSA : Endif
  I_EMPLOIDSA = NewInstance C_EMPLOIDSA AllocGroup null


  [L]READSTATUS = fmet I_EMPLOIDSA.AREAD(this.REFNUM)
  If ([L]READSTATUS  >= [V]CST_AERROR)
    #Error not handled - no class transfer will be performed
  Else
    #Persons to contact
    If I_EMPLOIDSA.PERCNT <> null
      For K = 1 To maxtab(I_EMPLOIDSA.PERCNT)
        If this.EMPESS.PERCNT(K) <> null
          If this.EMPESS.PERCNT(K).ESSUIDCNT = I_EMPLOIDSA.PERCNT(K).ESSUIDCNT or this.EMPESS.PERCNT(K).ESSUIDCNT = 0
            this.EMPESS.PERCNT(K).CNTTYP = I_EMPLOIDSA.PERCNT(K).CNTTYP
          Endif
        Endif
      Next
    Endif
  Endif
Endif


#FRLAA 2018-01-30 X3-74425 - START
Local Instance I_EMPLOID Using C_EMPLOID
If (I_EMPLOID <> null) : FreeGroup I_EMPLOID : Endif
I_EMPLOID = NewInstance C_EMPLOID AllocGroup null


[L]READSTATUS = fmet I_EMPLOID.AREAD(this.REFNUM)
If ([L]READSTATUS  >= [V]CST_AERROR)
  #Error not handled - no class transfer will be performed
Else
  If I_EMPLOID.PASDET <> null
    For K = 1 To maxtab(I_EMPLOID.PASDET)
      L = fmet this.EMPESS.ADDLINE("PASDET",K)
      Raz [F:IDR3]
      SetInstance [F:IDR3] With I_EMPLOID.PASDET(K)
      SetInstance this.EMPESS.PASDET(L) With [F:IDR3]
      this.EMPESS.PASDET(L).TCH_PASSTA = "T"
      this.EMPESS.NBRPAS = L
    Next
  Endif
Endif
#FRLAA 2018-01-30 X3-74425 - END



LogicClose File [ID2]
LogicClose File [IDR3]


Return

#FRLAA 2018-01-22 X3-71892 - START

#**
#* Check and assign unique ESS ID to the record for persons to contact
#* @param EMPLOIDESS Variable class instance (EMPLOIDESS)
#* @return ESS_UPDATE Local Integer - Default [V]CST_AOK
#*!
Funprog ASSIGNESSUIDCNT(V_EMPLOIDESS)
Variable Instance V_EMPLOIDESS Using C_EMPLOIDESS
Local Integer ESS_UPDATE_NEWREC,ESS_UPDATE
Local Integer K, NEW_ESSUID

Local File EMPLOID    [ID4]
Local File EMPLOID    [ID5]
Local File EMPLOIDSA  [IDES5]

ESS_UPDATE_NEWREC = [V]CST_AOK
ESS_UPDATE        = [V]CST_AOK

If V_EMPLOIDESS.EMPESS.PERCNT <> null
  For K = 1 To maxtab(V_EMPLOIDESS.EMPESS.PERCNT)
    If V_EMPLOIDESS.EMPESS.PERCNT(K) <> null
      If V_EMPLOIDESS.EMPESS.PERCNT(K).ESSUIDCNT = 0
        ESS_UPDATE_NEWREC = [V]CST_ANEW
        NEW_ESSUID = uniqid([F:ID5])
        V_EMPLOIDESS.EMPESS.PERCNT(K).ESSUIDCNT = NEW_ESSUID
        #Update existing records only - New records will be updated after approval
        If V_EMPLOIDESS.EMPESS.PERCNT(K).TCH_CNTSTA = "T"
          Update [F:ID5] Where REFNUM = V_EMPLOIDESS.REFNUM  With ESSUIDCNT(K-1) = NEW_ESSUID
        Endif
        If fstat <> [V]CST_AOK
          ESS_UPDATE = [V]CST_AERROR #Variable declared in $DECLARE_ESS_UID_STAT
          Break
        Else
          If func DIVPAYE.IS_AFRICA_LEG(V_EMPLOIDESS.TCH_LEG)>0 or func DIVPAYE.IS_KZA(V_EMPLOIDESS.TCH_LEG)>0
            If V_EMPLOIDESS.EMPESS.PERCNT(K).TCH_CNTSTA = "T"
              Update [IDES5] Where REFNUM = V_EMPLOIDESS.REFNUM  With ESSUIDCNT(K-1) = NEW_ESSUID
            Endif
            If fstat <> [V]CST_AOK
              ESS_UPDATE = [V]CST_AERROR #Variable declared in $DECLARE_ESS_UID_STAT
              Break
            Endif
          Endif
        Endif
      Endif
    Endif
  Next K
Endif
End ESS_UPDATE
#FRLAA 2018-01-22 X3-71892 - END

#**
#* Check and assign unique ESS ID to the record for passport details
#* @param EMPLOIDESS Variable class instance (EMPLOIDESS)
#* @return ESS_UPDATE Local Integer - Default [V]CST_AOK
#*!
Funprog ASSIGNESSUIDPASKZA(V_EMPLOIDESS)
Variable Instance V_EMPLOIDESS Using C_EMPLOIDESS
Local Integer ESS_UPDATE_NEWREC,ESS_UPDATE
Local Integer K, NEW_ESSUID

Local File EMPLOIDSA    [ESA4]
Local File EMPLOIDSA    [ESA5]

ESS_UPDATE_NEWREC = [V]CST_AOK
ESS_UPDATE        = [V]CST_AOK

If V_EMPLOIDESS.EMPESSSA.PASDET <> null
  For K = 1 To maxtab(V_EMPLOIDESS.EMPESSSA.PASDET)
    If V_EMPLOIDESS.EMPESSSA.PASDET(K) <> null
      If V_EMPLOIDESS.EMPESSSA.PASDET(K).ESSUIDPAS = 0
        ESS_UPDATE_NEWREC = [V]CST_ANEW
        NEW_ESSUID = uniqid([F:ESA5])
        V_EMPLOIDESS.EMPESSSA.PASDET(K).ESSUIDPAS = NEW_ESSUID

        #Update existing records only - New records will be updated after approval
        If V_EMPLOIDESS.EMPESSSA.PASDET(K).TCH_PASSTA = "T"
          Update [F:ESA5] Where REFNUM = V_EMPLOIDESS.REFNUM  With ESSUIDPAS(K-1) = NEW_ESSUID
        Endif
        If fstat <> [V]CST_AOK
          ESS_UPDATE = [V]CST_AERROR #Variable declared in $DECLARE_ESS_UID_STAT
          Break
        Endif

      Endif
    Endif
  Next K
Endif
End ESS_UPDATE

#FRLAA 2018-01-23 X3-71893 - START
#**
#* Check and assign unique ESS ID to the record for passport details - EMPLOID
#* @param EMPLOIDESS Variable class instance (EMPLOIDESS)
#* @return ESS_UPDATE Local Integer - Default [V]CST_AOK
#*!
Funprog ASSIGNESSUIDPAS(V_EMPLOIDESS)
Variable Instance V_EMPLOIDESS Using C_EMPLOIDESS
Local Integer ESS_UPDATE_NEWREC,ESS_UPDATE
Local Integer K, NEW_ESSUID

Local File EMPLOID      [ID4]
Local File EMPLOID      [ID5]

ESS_UPDATE_NEWREC = [V]CST_AOK
ESS_UPDATE        = [V]CST_AOK

If V_EMPLOIDESS.EMPESS.PASDET <> null
  For K = 1 To maxtab(V_EMPLOIDESS.EMPESS.PASDET)
    If V_EMPLOIDESS.EMPESS.PASDET(K) <> null
      If V_EMPLOIDESS.EMPESS.PASDET(K).ESSUIDPAS = 0
        ESS_UPDATE_NEWREC = [V]CST_ANEW
        NEW_ESSUID = uniqid([F:ID5])
        V_EMPLOIDESS.EMPESS.PASDET(K).ESSUIDPAS = NEW_ESSUID

        #Update existing records only - New records will be updated after approval
        If V_EMPLOIDESS.EMPESS.PASDET(K).TCH_PASSTA = "T"
          Update [F:ID5] Where REFNUM = V_EMPLOIDESS.REFNUM  With ESSUIDPAS(K-1) = NEW_ESSUID
        Endif
        If fstat <> [V]CST_AOK
          ESS_UPDATE = [V]CST_AERROR #Variable declared in $DECLARE_ESS_UID_STAT
          Break
        Endif

      Endif
    Endif
  Next K
Endif
End ESS_UPDATE
#FRLAA 2018-01-23 X3-71893 - END


