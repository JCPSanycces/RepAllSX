this.NUMLIG = 1 + max(this.APARENT.EMPLOPOTESS(1..maxtab(this.APARENT.EMPLOPOTESS)).NUMLIG)
#ASTATUS=fmet this.ASETERROR("",num$(this.NUMLIG),[V]CST_AINFO)
