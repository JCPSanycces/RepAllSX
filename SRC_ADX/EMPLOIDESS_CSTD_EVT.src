#end Employee Contract Spouse

#begin Employee Contract Addresses
#Load Contract Address infromation into class

Local File EMPLOCTRSA [EMPCTRSA]

Filter [F:EMPCTRSA] Where REFNUM = this.REFNUM
Local Integer K

For [EMPCTRSA]
  For K = 0 To [EMPCTRSA]NBRADD - 1
    L = fmet this.ADDLINE("CTRADR",K + 1)
    this.CTRADR(L).ADDPRI = [EMPCTRSA]ADDPRI(K)
    this.CTRADR(L).ADDTYP = [EMPCTRSA]ADDTYP(K)
    this.CTRADR(L).ADDSRVTYP = [EMPCTRSA]ADDSRVTYP(K)
    #this.CTRADR(L).ADDPOSOTH = [EMPCTRSA]ADDPOSOTH(K)
    this.CTRADR(L).ADDPOSNUM = [EMPCTRSA]ADDPOSNUM(K)
    this.CTRADR(L).ADDPOSNAM = [EMPCTRSA]ADDPOSNAM(K)
    this.CTRADR(L).ADDPOSAGN = [EMPCTRSA]ADDPOSAGN(K)
    this.CTRADR(L).ADDPOSCOF = [EMPCTRSA]ADDPOSCOF(K)
    this.CTRADR(L).ADDPOSINM = [EMPCTRSA]ADDPOSINM(K)
    this.CTRADR(L).ADDCPX = [EMPCTRSA]ADDCPX(K)
    this.CTRADR(L).ADDSTRNUM = [EMPCTRSA]ADDSTRNUM(K)
    this.CTRADR(L).ADDSTRNAM = [EMPCTRSA]ADDSTRNAM(K)
    this.CTRADR(L).ADDSUB = [EMPCTRSA]ADDSUB(K)
    this.CTRADR(L).ADDTWN = [EMPCTRSA]ADDTWN(K)
    this.CTRADR(L).ADDPOSCDE = [EMPCTRSA]ADDPOSCDE(K)
    this.CTRADR(L).ADDCNTCDE = [EMPCTRSA]ADDCNTCDE(K)
    this.CTRADR(L).ADDPRV = [EMPCTRSA]ADDPRV(K)
    this.CTRADR(L).ADDCOR = [EMPCTRSA]ADDCOR(K)
    this.CTRADR(L).ADDSTA = [EMPCTRSA]ADDSTA(K)
  Next K
Next

Filter [F:EMPCTRSA]

LogicClose File [EMPCTRSA]

#end Employe Contract Addresses


#Free tables and class instances
LogicClose File [ESA2]
LogicClose File [ESAR3]

If (I_EMPLOIDSA <> null) : FreeGroup I_EMPLOIDSA : Endif
Return


$AREAD_CLASSTRNS_KAQ
Local File EMPLOIDAFR     [EAF2]
Local File EMPLOIDAFRRT   [EAFR3]
Gosub DECLARE_AREAD_VAR #Set COL_INDEX = 1, L = 1

Read [EAF2]EAF0 = this.REFNUM
If fstat = [V]CST_AOK
  #Do class transfer
  If this.EMPESSAFR(COL_INDEX) = null
    L = fmet this.ADDLINE("EMPESSAFR",COL_INDEX)
  Endif
  SetInstance this.EMPESSAFR(L) With [F:EAF2]
  this.EMPESSAFR(L).TCH_AFRSTA = "T"
Endif

#Address fields - A routing table has been created to do a class transfer due to dimension fields in the table
#No records will ever be saved in this table - used for class transfer only!
#Do class transfer  - Africa - EMPLOIDAFR.EMPADR

Local Instance I_EMPLOIDAFR Using C_EMPLOIDAFR
If (I_EMPLOIDAFR <> null) : FreeGroup I_EMPLOIDAFR : Endif
I_EMPLOIDAFR = NewInstance C_EMPLOIDAFR AllocGroup null

[L]READSTATUS = fmet I_EMPLOIDAFR.AREAD(this.REFNUM)
If ([L]READSTATUS  >= [V]CST_AERROR)
  #Error not handled - no class transfer will be performed
Else
  If I_EMPLOIDAFR.EMPADR <> null
    For K = 1 To maxtab(I_EMPLOIDAFR.EMPADR)
      L = fmet this.EMPESSAFR.ADDLINE("EMPADR",K)
      Raz [F:EAFR3]
      SetInstance [F:EAFR3] With I_EMPLOIDAFR.EMPADR(K)
      SetInstance this.EMPESSAFR.EMPADR(L) With [F:EAFR3]
      this.EMPESSAFR.EMPADR(L).TCH_ADDSTA = "T"
    Next
  Endif
Endif


#Passport details
#Paspport details KZA/KAQ
Gosub DECLARE_AREAD_VAR #Set COL_INDEX = 1, L = 1
Local File EMPLOIDSART [ESAR3]

