STAT = func ASYRWRKCLASSIC.WORKFLOW(F_EMPLOIDESS.ACTX,TYPEVT,CODEVT,OPERAT,CLEOBJ,REQNUM,MSG)

End STAT
############################################################################################################
$WORKFLOW_UPDATE_STAT
#
Local Integer REQNUM,TYPEVT,STAT
Local Char    CODEVT(30)
Local Char    MSG(250)

TYPEVT=2         : # Object based event
CODEVT="ESWD"     : # The object is EXS

# Current key
#CLEOBJ must be set by the calling program - multiple programs

Return
