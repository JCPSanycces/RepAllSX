#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS

#ASTATUS=fmet this.ASETERROR("",[L]CURPTH,[V]CST_AINFO)
Case [L]CURPTH
  When ""
    Case [L]AEVENT
      When "AINIT"                            : Gosub AINIT
      When "AREAD_AFTER"                      : Gosub AREAD_AFTER
      When "AINSERT_CONTROL_AFTER"            : Gosub AINSERT_CONTROL_AFTER #Creation of record on this class not allowed - future extension
      When "AUPDATE_CONTROL_AFTER"            : Gosub AUPDATE_CONTROL_AFTER
      When "AINSERT_CONTROL_BEFORE"           : Gosub AINSERT_CONTROL_BEFORE #Creation of record on this class not allowed - future extension
      When "AUPDATE_CONTROL_BEFORE"           : Gosub AUPDATE_CONTROL_BEFORE
      When "AINSERT_AFTER"                    : Gosub AINSERT_AFTER         #Creation of record on this class not allowed - future extension
      When "AUPDATE_AFTER"                    : Gosub AUPDATE_AFTER
      When "ADDLINE_AFTER"                    : Gosub ADDLINE_AFTER
    Endcase
Endcase
Return


$AINIT
##Assigning the current X3 user as technical property
#this.TCH_USR = GACTX.USER
Return

$AREAD_AFTER

#Set the current legislation for the record
this.TCH_LEG = func DIVPAYE_SOA.GET_LEG_EMP(this.REFNUM, 1) #Site level

