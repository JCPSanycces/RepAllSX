this.NUMLIG = 1 + max(this.APARENT.EMPLOJNTESS(1..maxtab(this.APARENT.EMPLOJNTESS)).NUMLIG)
Return

$EMPLOCHDESS_ADDLINE_BEFORE
this.REFNUM = this.APARENT.REFNUM
this.NUMLIG = 1 + max(this.APARENT.EMPLOCHDESS(1..maxtab(this.APARENT.EMPLOCHDESS)).NUMLIG)
Return

$EMPLOPOTESS_ADDLINE_BEFORE
Local Integer INDEX
#If ALINE=[V]CST_AFIRSTPOS : INDEX=1 : Endif
#If ALINE<>[V]CST_ALASTPOS : INDEX=fmet this.AGETINDBYLINE("EMPLOPOTESS",ALINE) : Endif
#If INDEX = 0 : Return : Endif

