      SetInstance this.EMPESSAFR.PASDET(L) With [F:ESAR3]
      this.EMPESSAFR.PASDET(L).TCH_PASSTA = "T"
      this.EMPESSAFR.NBRPAS = L
    Next
  Endif
Endif
LogicClose File [ESAR3]


#Free tables and class instances
LogicClose File [EAF2]
LogicClose File [EAFR3]
If (I_EMPLOIDAFR <> null) : FreeGroup I_EMPLOIDAFR : Endif
Return

