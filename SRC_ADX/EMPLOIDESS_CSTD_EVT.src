#FRLAA 2018-01-30 X3-74425 - START
$AREAD_CLASSTRNS_KUK
Local File EMPLOIDUKI   [IDUKI1]
Local File CTRUKIRT     [UKIRT1]
Local File EMPLOCTRUKI  [CTRUKI1]

Gosub DECLARE_AREAD_VAR #Set COL_INDEX = 1, L = 1

Read [F:IDUKI1]IDUKI0 = this.REFNUM
If fstat = [V]CST_AOK
  #Do class transfer
  If this.EMPESSUKI(COL_INDEX) = null
    L = fmet this.ADDLINE("EMPESSUKI",COL_INDEX)
  Endif
  SetInstance this.EMPESSUKI(L) With [F:IDUKI1]
  this.EMPESSUKI(L).TCH_EMPSTA = "T"
Endif


#Transfer contract information from EMPLOCTRUKI

Raz L,N,O
For [CTRUKI1] Where REFNUM = this.REFNUM #No additional filters specified
  L+=1
  If this.CTRESSUKI(L) = null
    K = fmet this.ADDLINE("CTRESSUKI",L)
  Endif
  SetInstance this.CTRESSUKI(K) With [F:CTRUKI1]
  Local Instance I_EMPLOCTRUKI Using C_EMPLOCTRUKI
  If (I_EMPLOCTRUKI <> null) : FreeGroup I_EMPLOCTRUKI : Endif
  I_EMPLOCTRUKI = NewInstance C_EMPLOCTRUKI AllocGroup null
  [L]READSTATUS = fmet I_EMPLOCTRUKI.AREAD(this.REFNUM,[F:CTRUKI1]CTRNUM,[F:CTRUKI1]CTRDAT)
  If ([L]READSTATUS  >= [V]CST_AERROR)
    #Error not handled - no class transfer will be performed
  Else
    If I_EMPLOCTRUKI.UKADD <> null
      For M = 1 To maxtab(I_EMPLOCTRUKI.UKADD)
         O = fmet this.CTRESSUKI(K).ADDLINE("UKADD",M)
        Raz [F:UKIRT1]
        SetInstance [F:UKIRT1] With I_EMPLOCTRUKI.UKADD(M)
        SetInstance this.CTRESSUKI(K).UKADD(O) With [F:UKIRT1]
      Next
    Endif
Endif
Next

LogicClose File  [IDUKI1]
LogicClose File  [UKIRT1]
LogicClose File  [CTRUKI1]

Return
#FRLAA 2018-01-30 X3-74425 - END

Funprog EMPLOYEE_WORKFLOW(F_EMPLOIDESS,CLEOBJ)
Variable Instance F_EMPLOIDESS Using C_EMPLOIDESS
Value Char CLEOBJ
Local Integer I
