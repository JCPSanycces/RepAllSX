#Do class transfer  - UK
If func DIVPAYE.IS_KUK_LEG(this.TCH_LEG)
  Gosub AREAD_CLASSTRNS_KUK
Endif

Return

$SET_LEG_UPDATE_REP

Local Char CURFOLDER(100):CURFOLDER = nomap
Local Integer OK, TYPAGE
Local Char REPLINK(GLONASW)

If func DIVPAYE.IS_KZA(this.TCH_LEG)
  REPLINK = "EMPLOIDESKZA"
Endif

If func DIVPAYE.IS_AFRICA_LEG(this.TCH_LEG)
  REPLINK = "EMPLOIDESKFR"
Endif


#Set the "Update" represenation link on EMPLOIDESS
Local File ASHWLNK [ASWK2]
Filter [ASWK2] Where CODREP = "EMPLOIDESS" and AFFLNK = 5 and CODLNK = "LEGREP" and REPLNK = REPLINK
Read [ASWK2] First
If fstat <> [V]CST_AOK #Only update if not already set
  Trbegin [ASWK2]

  Update [ASWK2] Where CODREP = "EMPLOIDESS" and AFFLNK = 5 and CODLNK = "LEGREP" With REPLNK = REPLINK
  If fstat = [V]CST_AOK
    Commit
    GBROWS = 1
    Call VALIDATION(0,"EMPLOIDESS",CURFOLDER,1,1,0,TYPAGE,OK) From ASHWVAL
  Else
    Rollback
  Endif
Endif

Return

$AINSERT_CONTROL_BEFORE
$AUPDATE_CONTROL_BEFORE
