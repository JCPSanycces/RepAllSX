#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#                                                                       #
#      TRAITEMENTS LIES au CREDIT CLIENT dans les VENTES                #
#                                                                       #
#########################################################################
#                                                                       #
# Subprog ALIOST(BPCINV, CURORD, DATORD, CHGTYP, OST, OSTAUZ)           #
#      Alimentation de l'en-cours autorisé et de l'en-cours calculé     #
#       dans la devise du document                                      #
#                                                                       #
# Subprog CALACO (NUMCDE,DAT,ACOMPTE)                                   #
#      Calcul du montant non versé d'acompte sur une commande           #
#                                                                       #
# Subprog SDCDTSTA(NUMPIE, CLI, CHGTYP, DAT, MAJ,CDTSTA,OST,OSTAUZ)     #
#      Calcul de l'état crédit                                          #
#   ACTION : SDCDTSTA                                                   #
#                                                                       #
#########################################################################


#---------------------------------------------------------------#
# Action D_CDTSTA : Calcul de l'état crédit                     #
#---------------------------------------------------------------#
# Entrée  NUMPIE   : Numero de pièce (Ex: n.cde)                #
#         CLI      : Client                                     #
#         CHGTYP   : Type de cours                              #
#         WCHGRAT  : Cours de la devise ou 0                    #
#         CUR      : Devise du document                         #
#         DAT      : Date de référence                          #
#         UNL      : Code déblocage                             #
#         MAJ      : Flag de maj état crédit sur la cde         #
# Sortie  CDTSTA   : Etat crédit calculé                        #
#         OST      : En-cours calculé                           #
#         OSTAUZ   : En-cours autorisé                          #
#---------------------------------------------------------------#
# NUMPIE <> "" --> contrôle versement acomptes                  #
# CUR    <> "" --> alimentation param OST et OSTAUZ             #
# MAJ    =  1  --> Calcul état crédit sans maj entête commande  #
#           2  --> Calcul état crédit avec maj entête commande  #
#---------------------------------------------------------------#
Subprog SDCDTSTA(OBJORI, CTX, COMPANY, NUMPIE, CLI, CHGTYP, WCHGRAT, CUR, DAT, UNL, MAJ, CDTSTA, OST, OSTAUZ)
Value    Instance OBJORI Using OBJECT       # Référence sur l'objet générique
Value    Instance CTX Using C_WMACONTEXT    # Référence sur le contexte (obligé de le passer. OBJORI peut être NULL)
Value    Char     COMPANY
Value    Char     NUMPIE
Value    Char     CLI
Value    Libelle  CHGTYP
Value    Decimal  WCHGRAT
Value    Char     CUR
Value    Date     DAT
Value    Libelle  UNL
Value    Shortint MAJ
Variable Tinyint  CDTSTA # Variable Integer  CDTSTA
Variable Decimal  OST
Variable Decimal  OSTAUZ

Local Date     WOSTDAT
Local Libelle  WOSTCHGTYP
Local Decimal  ENCOURS, ENCOURSSHR, MONT, WCOURS
Local Integer  ORICDTSTA, SPSTAT
Local Char     WOSTCUR(GLONCUR)
Local Integer  WTRBEGIN
Local Char     WPARAM(10)
Local Decimal  WOSTAUZ  #-- X3Suivi 79222 : Encours max défini par client/société (Appel du point d'entrée) ------#

Local Integer CTX_OSTCTL
Local Integer CTX_OSTCHGTYP
Local Char    CTX_LOCALDEV(GLONCUR)
Local Char    CTX_CURSHR(GLONCUR)
Local Integer CTX_LOKORD

  #GPOINT="CALCREDIT0" : Gosub ENTREE From EXEFNC
  ORICDTSTA = CDTSTA
  Local File BPCUSTOMER [BPC]
  # On recherche d'abord le tiers risque lié au client
  Read [BPC]BPC0=CLI
  If fstat Then
    Raz [F:BPC]
  Endif
  If [F:BPC]BPCRSK = "" Then
    End
  Endif
  # On lit le tiers risque
  If [F:BPC]BPCRSK <> CLI Then
    Read [BPC]BPC0=[F:BPC]BPCRSK
    If fstat Then
      Raz [F:BPC]
      End
    Endif
  Endif
  # -------------------------------------
  Local File COMPANY [CPY]
  Read [F:CPY]CPY0=COMPANY
  If fstat Then
    Raz [F:CPY]
  Endif
  CTX_LOCALDEV = [F:CPY]ACCCUR
  # -------------------------------------
  # 99481 : Ctrl en-cours client : Pb conversion devise
  # (Paramètre au niveau société, il devrait être au niveau dossier (dde de modif créée))
  #CTX_OSTCTL = fmet OBJORI.ACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, CTX.AFOLDER, "OSTCTL")
  CTX_OSTCTL = fmet OBJORI.ACTX.APARAM.AGETVALNUM([V]CST_ALEVCPY, COMPANY, "OSTCTL")
  # 99481
  If CTX_OSTCTL = 1 Then
    WOSTCUR = fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, CTX.AFOLDER, "CURSHRFLD") # Ctrl niveau dossier : Devise : Devise dossier
  Else
    WOSTCUR = fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, CTX.AFOLDER, "SYSCUR")    # Ctrl niveau société : Devise : Devise société
  Endif
  CTX_OSTCHGTYP = fmet CTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD, CTX.AFOLDER, "OSTCHGTYP")
  If CTX_OSTCHGTYP = 2 Then
    # Si Origine cours pour contrôle en-cours = actualisé
    WOSTDAT = datesyst                                        : # Date          : date du jour
    WOSTCHGTYP = fmet CTX.APARAM.AGETVALNUM ([V]CST_ALEVCPY, COMPANY, "OSTTYPCUR") :#-- Type de cours pour contrôle au cours actualisé
  Else
    # Si Origine cours pour contrôle en-cours = historique
    WOSTDAT = DAT                                             : # Date          : date du document
    WOSTCHGTYP = CHGTYP                                       : # Type de cours : Type de cours du document
  Endif
  CTX_CURSHR = fmet CTX.APARAM.AGETVALCHAR([V]CST_ALEVFOLD, CTX.AFOLDER, "CURSHRFLD")
  # ---------------------------------------
  # Calcul de l'état crédit de la commande
  CDTSTA = 1
  # --> Bloqué : On bloque la commande sf si déblocage autorisé
  If [F:BPC]OSTCTL = 3 and UNL <> 2 Then
    CDTSTA = 2
  Endif
  #-- X3Suivi 79222 : Encours max défini par client/société (Appel du point d'entrée) ------#
  If [F:BPC]OSTCTL = 1 Then
    WOSTAUZ = [F:BPC]OSTAUZ
  Endif
  # --> Contrôlé : On contrôle l'en-cours sf si déblocage autorisé
  If [F:BPC]OSTCTL = 1 and UNL <> 2 Then
    # Calcul de l'en-cours en devise dossier (CTX_OSTCTL=1) ou société (CTX_OSTCTL=2)
    Call CALENC(OBJORI.ACTX, [F:BPC]BPCRSK, WOSTDAT, ENCOURS) From TRTBPMVT_SYRA
    # Conversion de l'en-cours en devise dossier car l'en-cours autorisé est tjs stocké en devise dossier
    If WOSTCUR <> GCURSHR YHEN
      Call CONVERT(CTX, WOSTCUR, CTX_CURSHR, CTX_LOCALDEV, WOSTCHGTYP, WOSTDAT, ENCOURS, ENCOURSSHR, SPSTAT) From TRTDEV_SYRA
    Else
      ENCOURSSHR = ENCOURS
    Endif
    #
    #-- X3Suivi 79222 : Encours max défini par client/société (Appel du point d'entrée) ------#
    #GPOINT="CALCREDIT1" : Gosub ENTREE From EXEFNC
    #
    #-- Controle en-cours autorisé en devise dossier --#
    If ENCOURSSHR > WOSTAUZ Then
      CDTSTA = 3
    Endif
  Endif
  # --> On vérifie si les acomptes ont bien été versés
  If (CDTSTA = 1 or CDTSTA = 3) and NUMPIE <> "" and UNL <> 2 Then
    # order holds
    Call CALACO(NUMPIE, date$, MONT)
    # Si pas blocage (en cas d'acompte non versé) ou contrôle ok
    Local File SORDER [SOH]
    Read [F:SOH]SOH0=NUMPIE
    CTX_LOKORD = fmet CTX.APARAM.AGETVALNUM([V]CST_ALEVFCY, [F:SOH]SALFCY, "LOKORD")
    If CTX_LOKORD = 2 or CDTSTA = 1 Then
      If MONT <> 0 Then
        CDTSTA = 4
      Endif
    Endif
  Endif

  # 78411 Sage Exchange
  If MAJ = 2 Then
    If OBJORI <> null and OBJORI.ObjectType = "C_SORDER" Then  # FLORENT ICI A TESTER
      If func AFNC.ACTIV("SEPP") Then
        Gosub CDTSTA From SEPPCDT_SYRA #--- 5 = Sage Exchange ---#
      Endif
    Endif
  Endif

  #GPOINT="CALCREDIT" : Gosub ENTREE From EXEFNC

  #--> maj état crédit dans la commande
  If MAJ = 2 and CDTSTA <> ORICDTSTA Then
    If OBJORI <> null and OBJORI.ObjectType = "C_SORDER" Then  # FLORENT ICI A TESTER
      OBJORI.CDTSTA = CDTSTA
    Endif
  Endif

  # Conversion de l'en-cours autorisé devise dossier vers devise commande
  # Conversion de l'en-cours          devise dossier ou societé vers devise commande
  # attention !! maj montant si devise renseignée dans param entrée
  If CUR <> "" Then
    # Si en-cours non contrôlé : Initialisation au maximum
    If [F:BPC]OSTCTL <> 1 Then
      OSTAUZ = 9999999999.99
    Else
      # Conversion de l'en-cours autorisé devise dossier vers devise document
      If CTX_CURSHR <> CUR Then
        #-- X3Suivi 79222 : Encours max défini par client/société (Appel du point d'entrée) ------#
        Call COURMNT(CTX, CTX_CURSHR, CUR, CTX_LOCALDEV, WOSTCHGTYP, WOSTDAT, 1, WOSTAUZ, MONT, 0, SPSTAT) From TRTDEV_SYRA
        OSTAUZ  = MONT
      Else
        #-- X3Suivi 79222 : Encours max défini par client/société (Appel du point d'entrée) ------#
        OSTAUZ = WOSTAUZ
      Endif
      # Conversion de l'en-cours          devise dossier ou societé vers devise document
      If CUR <> WOSTCUR and CUR <> CTX_CURSHR Then
        # Si l'en-cours est en devise société il faut convertir avec le cours du document
        If CTX_OSTCTL = 1 Then
          WCOURS = 0
        Else
          WCOURS = WCHGRAT
        Endif
        Call COURMNT(CTX, WOSTCUR, CUR, CTX_LOCALDEV, WOSTCHGTYP, WOSTDAT, 1, ENCOURS, MONT, WCOURS, SPSTAT) From TRTDEV_SYRA
        OST = MONT
      Elsif CUR = CTX_CURSHR Then
        OST = ENCOURSSHR
      Else
        OST = ENCOURS
      Endif
    Endif
  Endif
End

#--------------------------------------
# Calcul du montant d'acompte non versé
#--------------------------------------
# Entrée  NUMCDE   : Numéro commande
#         DAT      : Date
# Sortie  ACOMPTE  : Acompte non versé
#---
Subprog CALACO(NUMCDE, DAT, ACOMPTE)
Value Char NUMCDE
Value Date DAT
Variable Decimal ACOMPTE

  Local File GACCDUDATE [DUD]
  ACOMPTE = 0
  For [DUD]DUD0 Where [F:DUD]TYP = "*SO" and [F:DUD]NUM = NUMCDE
    If [F:DUD]SENINS = 2 Then
      If DAT >= [F:DUD]DUDDAT Then
        ACOMPTE += [F:DUD]AMTCUR - [F:DUD]PAYCUR
      Endif
    Endif
  Next
End
