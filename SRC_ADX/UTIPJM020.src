#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIPJM020 Delete PIM0 PIM1 Screen and OPIM window
#
# Issue X3-35865 - 2017-05-04 by FGR
##########################################################################
Local Char DOSSIER(30)

  DOSSIER = nomap
  Call SAIDOS(DOSSIER, "") From SAIDOS
  If DOSSIER <> "" Then
    If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
    Read [ADS]DOSSIER=[L]DOSSIER
    If fstat Then
      Raz [F:ADS]
    Endif
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("Correction") From LECFIC
    # -------------------------
    Call MAJ_UTIPJM020(DOSSIER)
    # -------------------------
    Call TEMPOFF From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
End

##########################################################################
Subprog MAJ_UTIPJM020(DOSSIER)
Value Char DOSSIER

Local Integer COMPTEUR
Local Integer IERR
Local Integer IUPDATE
Local Integer STAT
Local Char    TRTANU(GLONAFC)

  Call ECR_TRACE("UTIPJM020: Process Start on : "+DOSSIER,0) From GESECRAN
  IERR = 0
  #----- Ouverture des fichiers -----#
  Local File =DOSSIER + ".AMSK"  [AMK]
  Local File =DOSSIER + ".AMSKZON"  [AMZ]
  Local File =DOSSIER + ".AMSKACT"  [AMA]
  Local File =DOSSIER + ".AMSKPAR"  [AMP]
  Local File =DOSSIER + ".AWINDOW"  [AWI]
  Local File =DOSSIER + ".AFONCTION"  [AFC]
  Local File =DOSSIER + ".AOBJET"  [AOB]
  #Local File =DOSSIER + ".AREPORTV"  [ARV]
  #Local File =DOSSIER + ".AFCTFCY"  [AFF]
  #Local File =DOSSIER + ".AFCTPRF"  [AFP]
  #Local File =DOSSIER + ".ABATTAC"  [ABT]
  #Local File =DOSSIER + ".AOBJTAB"  [AOT]
  #Local File =DOSSIER + ".AOBJLST"  [AOL]
  # -----------------
  Raz COMPTEUR
  # -----------------
  Trbegin [AMK]
  Filter [AMK] Where [F:AMK]CODMSK = "PIM0" or [F:AMK]CODMSK = "PIM1"
  For [AMK]
    # Delete the wrong action
    COMPTEUR += 1
    Delete [AMZ] Where CODMSK=[F:AMK]CODMSK
    If fstat Then
      Call ECR_TRACE("File AMSKZON" - [F:AMK]CODMSK + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
    # -----------------
    Delete [AMA] Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK
    If fstat Then
      Call ECR_TRACE("File AMSKACT" - [F:AMK]CODMSK + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
    # -----------------
    Delete [AMP] Where TYPAFF=1 & CODAFF=[F:AMK]CODMSK
    If fstat Then
      Call ECR_TRACE("File AMSKPAR" - [F:AMK]CODMSK + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
    # -----------------
    Delete [AMK]Curr
    If fstat Then
      Call ECR_TRACE("File AMSKACT" - [F:AMK]CODMSK + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
    # -----------------
    Call DEL_TRTMSK([F:AMK]CODMSK, DOSSIER) From MSKDIV
  Next
  Filter [AMK]
  # -----------------
  Filter [AWI] Where [F:AWI]WIN = "OPIM"
  For [AWI]
    COMPTEUR += 1
    Call DELWIN([F:AWI]WIN, DOSSIER) From MSKDIV
    If GOK < 0 Then
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
  Next
  Filter [AWI]
  # -----------------
  Filter [AFC] Where [F:AFC]CODINT = "GESPIM"
  For [AFC]
    COMPTEUR += 1
    Delete [AFC]Curr
    If fstat Then
      Call ECR_TRACE("File AFONCTION" - [F:AFC]CODINT + ", Error =" - num$(fstat), 1) From GESECRAN
      GOK = 1
      IERR = 1
      NCOUNTERROR += 1
    Endif
    # -----------------
    Call  UPDATE_RIGHTSETAG(DOSSIER) From ASYRFNC
  Next
  Filter [AFC]
  # -----------------
  If IERR = 0 Then
    Commit
    Call ECR_TRACE("UTIPJM020 :" - num$(COMPTEUR) - "records processed",0) From GESECRAN
  Else
    Rollback
    Call ECR_TRACE("UTIPJM020 : records processed with error(s).", 0) From GESECRAN
  Endif
  Close Local File [AMK]
  Close Local File [AMZ]
  Close Local File [AMA]
  Close Local File [AMP]
  Close Local File [AWI]
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  #If APPLI = GDOSX3 Then # Run on all folders
  #  End
  #Endif
  #If clalev([F:ADS]) = 0 : Local File ADOSSIER [ADS] : Endif
  #If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
  Call MAJ_UTIPJM020(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI

  #If APPLI = GDOSX3 Then # Run on all folders
  #  End
  #Endif
  Call MAJ_UTIPJM020(APPLI)
End






