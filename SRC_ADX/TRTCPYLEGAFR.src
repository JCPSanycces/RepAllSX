#JOJAC - 2016-08-25 - X3PEOP-1318 - START
#FRLAA and JASMI - 2015-02-18 - Requirement 104592 US 3260 - START
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "OK"           : Gosub OK
  Endcase
Return

$OUVRE
  If clalev([F:CPYAFR])=0 : Local File HRCOMPANYAFR [CPYAFR]  : Endif
  # generate file for display hide
#JASMI - 2017-05-11 - START
#  Call MANAGE_LOCALISATIONNEW("CPYLEGAFR","TRTCPYLEGAFRLEG") From DIVPAYE
  Call MANAGE_LOCALISATION("CPYLEGAFR") From DIVPAYE
#JASMI - 2017-05-11 - END

Return

$DEBUT
  Raz [M:CLAFR]
  #JASMI - 2017-12-14 - X3-57401 - START
  If GCURLEG='GHA'
    If [M:CLAFR]TAXCLC<3 | [M:CLAFR]TAXCLC>4
      [M:CLAFR]TAXCLC=3
    Endif
  Endif
#JASMI - 2017-12-14 - X3-57401 - END
  [M]CPY = [M:CPY0]CPY
  Read [F:CPYAFR]CPYAFR0 = [M:CPY0]CPY
  If !fstat
    [M:CLAFR] = [F:CPYAFR]
  Else
    Affzo [M:CLAFR]
    Gosub HIDE_FIELDS
    Return
  Endif

  Gosub HIDE_FIELDS
  Call CHECK_TAXCALC
  Affzo [M:CLAFR]
Return

$HIDE_FIELDS
