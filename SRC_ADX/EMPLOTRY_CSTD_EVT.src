#<AdxTL>@(#)0.0.0.0 $Revision$
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AINIT"                      : Gosub AINIT
      When "AINSERT_CONTROL_BEFORE"      : Gosub AINSERT_CONTROL_BEFORE
    Endcase
Endcase
Return


$AINIT


Return

$AINSERT_CONTROL_BEFORE
#Set the line number
Gosub SET_LIGNUM
Return

$SET_LIGNUM
If this.NUMLIG <> 0 : Return: Endif
Local Integer MAXLIGNUM
Local File EMPLOTRY [TRY2]
Filter [TRY2] Where REFNUM = this.REFNUM
For [TRY2]
  If [F:TRY2]NUMLIG > MAXLIGNUM
    MAXLIGNUM = [F:TRY2]NUMLIG
  Endif
Next

MAXLIGNUM+=1
this.NUMLIG = MAXLIGNUM
LogicClose File [TRY2]
Return

