#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestion du masque ITW0

$ACTION
Case ACTION
 When "OUVRE"        : Gosub OUVRE
 When "FILTRE"       : Gosub FILTRE
 When "LIENS"        : Gosub LIENS
 When "VERF_ANU"     : Gosub VERF_ANU
 When "FERME"        : Gosub FERME
 When Default
Endcase
Return

$OUVRE
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
If !clalev([F:STO])  Local File STOCK      [STO]  Endif
If !clalev([F:STA])  Local File STOALL     [STA]  Endif
If !clalev([F:STJ])  Local File STOJOU     [STJ]  Endif
If !clalev([F:ITG])  Local File ITMCATEG   [ITG]  Endif
If !clalev([F:ITF])  Local File ITMFACILIT [ITF]  Endif
Return

$FILTRE
If GFLTITM <> "" : # (positionnée avant le call OBJET)
   FILTSUP = "ITMREF=GFLTITM"
Endif
If GFLTFCY <> "" : # (positionnée avant le call OBJET)
   If FILTSUP<>""
      FILTSUP += "& STOFCY=GFLTFCY"
   Else
     FILTSUP  = "STOFCY=GFLTFCY"
   Endif
Endif
Return

$LIENS
I=0
#lire l'article
Read [ITM]ITM0 = [M:ITW0]ITMREF
If fstat 
   Raz [F:ITM] 
Endif

Read [ITF]ITF0 = [M:ITW0]ITMREF;[M:ITW0]STOFCY
If fstat 
   Raz [F:ITF] 
Endif

#--- Bug TS
If [F:ITF]LOCMGTCOD<2
   Call ERREUR([M:ITW0]ITMREF-[M:ITW0]STOFCY-":"-mess(392,184,1)-":"-[M:ITW0]ITMREF-[M:ITW0]WRH) From GESECRAN
Endif
#---

[M:ITW1]STU = [F:ITM]STU

# charger le tableau d'intitulés d'emplacements de la catégorie
Read [ITG]ITG1=[F:ITM]TCLCOD;[M:ITW0]STOFCY
If fstat
   Read [ITG]ITG1=[F:ITM]TCLCOD;"" # catégorie générale
Endif
If !fstat & dim([F:ITG]LOCMGTCOD)>0 & [F:ITG]LOCMGTCOD>1 & [M:ITW1]LOCDEFFLG = 2
   While I < dim([M:ITW1]LOCNUM) & [F:ITG]LOCDES(I) > 0
      [M:ITW1]LOCNUM(I) = [F:ITG]LOCDES(I)
      I += 1
   Wend
   If dim([M:ITW1]LOCNUM)>0 [M:ITW1]NBLOC=I Endif
Endif

If [M:ITW1]CUNWRHFLG = 1 & [M:ITW1]CUNCOD <> 3
    [M:ITW1]CUNCOD = 3
Endif
If [M:ITW1]CUNWRHFLG = 1
    Diszo [M:ITW1]CUNCOD
Else    
    Actzo [M:ITW1]CUNCOD
Endif
If [M:ITW1]LOCDEFFLG = 1
    Diszo [ITW1]20
Else
    Actzo [ITW1]20
Endif
#-------------------------------
#Alimentation de l'onglet stock
#-------------------------------
# A partir des stocks (stocks A,Q,R et alloué détail)
For [STO]STO3 Where ITMREF=[M:ITW0]ITMREF & STOFCY=[M:ITW0]STOFCY &
&                   WRH=[M:ITW0]WRH 
  If [F:STO]OWNER=[F:STO]STOFCY | [F:STO]OWNER=""
    Case left$([F:STO]STA,1)
      When "A" : If [F:STO]LOCCAT=1
                    [M:ITW2]PHYSTO    += [F:STO]QTYSTUACT
                 Elsif [F:STO]LOCCAT=2
                    [M:ITW2]PLFPHYSTO += [F:STO]QTYSTUACT
                 Endif
                 [M:ITW2]PHYALL       += [F:STO]CUMALLQTA
      When "Q" : If [F:STO]LOCCAT=1
                    [M:ITW2]CTLSTO    += [F:STO]QTYSTUACT
                 Elsif [F:STO]LOCCAT=2
                    [M:ITW2]PLFCTLSTO += [F:STO]QTYSTUACT
                 Endif
                 [M:ITW2]CTLALL       += [F:STO]CUMALLQTA
      When "R" : If [F:STO]LOCCAT=1
                    [M:ITW2]REJSTO    += [F:STO]QTYSTUACT 
                 Elsif [F:STO]LOCCAT=2
                    [M:ITW2]PLFREJSTO += [F:STO]QTYSTUACT
                 Endif
                 [M:ITW2]REJALL       += [F:STO]CUMALLQTA
    Endcase
  Else
    [M:ITW2]SCCLNDSTO += [F:STO]QTYSTUACT
    [M:ITW2]SCCALL    += [F:STO]CUMALLQTA
  Endif
Next
# A partir des allocation (alloué et manquant global, manquant détail)
For [STA]STA0 Where STOFCY=[M:ITW0]STOFCY & ITMREF=[M:ITW0]ITMREF & 
&                   WRH=[M:ITW0]WRH & find(ALLTYP,1,4,5) 
  If [F:STA]ALLTYP=1
     [M:ITW2]GLOALL += [F:STA]QTYSTUACT
  Elsif [F:STA]ALLTYP=4
     [M:ITW2]DETSHT += [F:STA]QTYSTUACT
  Elsif [F:STA]ALLTYP=5
     [M:ITW2]GLOSHT += [F:STA]QTYSTUACT
  Endif
Next
# A partir des mouvements de stock (sorties en attente)
For [STJ]STJ0 Where STOFCY=[M:ITW0]STOFCY & UPDCOD=1 & ITMREF=[M:ITW0]ITMREF & 
&                   WRH=[M:ITW0]WRH & REGFLG=1 
    [M:ITW2]WAISTO += [F:STJ]ACTQTY
Next

Return

$VERF_ANU
# Il ne doit plus y avoir de stock sur le dépôt
Filter [STO] Where STOFCY=[F:ITW]STOFCY & ITMREF=[F:ITW]ITMREF & WRH=[F:ITW]WRH 
If rowcount([STO])<>0
   Filter [STO]
   GERR = 1 : GMESSAGE = mess(956,196,1)
   OK = 0   : Return
Endif
Filter [STO]
Return

$FERME
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#-----
If dim(GFLTITM)>0 Raz GFLTITM Endif
If dim(GFLTFCY)>0 Raz GFLTFCY Endif

Return

###############################################################################

Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
# Lecture article site si dépôt et donc site connu
If VALEUR <>"" & [M:ITW0]STOFCY<>""
   Read [ITF]ITF0 = VALEUR;[M:ITW0]STOFCY
   If fstat
      Raz [M:ITW0]WRH, [M:ITW0]STOFCY 
      Raz [F:ITF] 
      Affzo WRH, STOFCY
   Else
      Gosub CHARG_ITG
   Endif
Else
   Raz [F:ITF]
Endif
End

Subprog AM_WRH(VALEUR)
Variable Char    VALEUR()
# Lecture article site
#--- Bug 74104
#If [M:ITW0]STOFCY<>[F:WRH]STOFCY
#   Call CONTFCY([F:WRH]STOFCY) From EXEFNC
#   If mkstat=2 : End : Endif
#   Read [ITF]ITF0 = [M:ITW0]ITMREF;[F:WRH]STOFCY
#   If fstat
#      mkstat=2 : End
#   Else
#      [M:ITW0]STOFCY=[F:WRH]STOFCY
#      Gosub CHARG_ITG
#      Affzo STOFCY
#   Endif
#Else
#   Gosub CHARG_ITG
#   Affzo STOFCY
#Endif
If [M:ITW0]STOFCY<>[F:WRH]STOFCY
   Call CONTFCY([F:WRH]STOFCY) From EXEFNC
   If mkstat=2 : End : Endif
   Read [ITF]ITF0 = [M:ITW0]ITMREF;[F:WRH]STOFCY
   If fstat
      mkstat=2 : End
   Else
      [M:ITW0]STOFCY=[F:WRH]STOFCY
   Endif
Endif
If [F:ITF]LOCMGTCOD<2
   Call ERREUR([M:ITW0]ITMREF-[M:ITW0]STOFCY-":"-mess(392,184,1)-":"-[M:ITW0]ITMREF-VALEUR) From GESECRAN
Endif
Gosub CHARG_ITG
Affzo STOFCY
#---
End

Subprog AM_CUNWRHFLG(VALEUR)
Variable Integer VALEUR
Local Date    WDAT 
WDAT = date$
If VALEUR = 2
    Actzo[M:ITW1]CUNCOD
    [M:ITW1]CUNCOD = 1
    Call CAL_NEXINVITW([M:ITW0]STOFCY,[F:ITM]TCLCOD,WDAT,[M:ITW1]CUNCOD) From STKINV
    [M:ITW1]NEXCUNDAT = [F:ITW]NEXCUNDAT
    Affzo [M:ITW1]NEXCUNDAT
    Affzo [M:ITW1]CUNCOD 
Else
    Diszo [M:ITW1]CUNCOD
    Raz   [M:ITW1]NEXCUNDAT
    [M:ITW1]CUNCOD = 3
    Affzo [M:ITW1]NEXCUNDAT
    Affzo [M:ITW1]CUNCOD 
Endif

End

Subprog AM_LOCDEFFLG(VALEUR)
Variable Integer VALEUR
If VALEUR = 2
    [M:ITW1]LOCDEFFLG = VALEUR
    Gosub CHARG_ITG
Else
    Effzo[ITW1]20
Endif
End

Subprog AS_LOCNUM(VALEUR)
Variable Integer VALEUR
mkstat = 2 # chargé depuis les catégories
End

Subprog C_DEFLOCTYP(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : End : Endif
VALEUR = toupper(VALEUR)
#--- Bug 66735
If instr(1,VALEUR,"?") | instr(1,VALEUR,"#") | instr(1,VALEUR,"!") : End : Endif
# Si joker, controle de format seulement
If instr(1,VALEUR,"*")
   J = instr(1,VALEUR,"*")
   If J > 0 & mid$(VALEUR,J+1,len(VALEUR)-J) <> ""
      mkstat = 2
      # "Le joker(*) ne doit pas être suivi de caractère"
      GMESSAGE = mess(15,196,1)
      End
   Endif
Else
   Call CONTROLE("TLO","!",VALEUR,[M:ITW0]STOFCY,mkstat) From CONTOBJ
   #--- Bug 65422
   If mkstat<>0 End Endif
Endif

#--- Bug 65422
# Si le type ne contient pas de caractére joker, contrôle
# qu'il existe au moins un emplacement pour le type et le dépôt
If instr(1,VALEUR,"*")|instr(1,VALEUR,"?")|instr(1,VALEUR,"#")|instr(1,VALEUR,"!")
   End
Endif   
Filter [STC] Where LOCTYP=VALEUR & WRH=[M:ITW0]WRH 
Look [STC] First
If fstat 
   mkstat=2 : GMESSAGE=mess(558,199,1)
Endif
Filter [STC]
#---

End

Subprog C_DEFLOC(VALEUR)
Variable Char    VALEUR()
VALEUR = toupper(VALEUR)
## > contrôler que la chaine contient que des lettres ou des caractères
##  interprétable par l'instruction pat : * # ? !  (type de donnée ?)
For I=1 To len(VALEUR)
    If !instr(1,"ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789*#!?",seg$(VALEUR,I,I))
        mkstat = 2 : GMESSAGE = mess(149,100,1) # format incorrect
        Break
    Endif
Next
If mkstat | VALEUR="" End Endif
If !clalev([STF]) Local File STOLOCAFF [STF] Endif
Read [STC]STC0=[M:ITW0]STOFCY;VALEUR
If !fstat
 # L'emplacement correspond-il au type d'emplacement ?
   If !pat([F:STC]LOCTYP,[M]DEFLOCTYP(nolign-1))
      mkstat=2 : GMESSAGE = mess(68,184,1) : End
   Endif
 # L'emplacement est-il sur le dépôt ?
   If [F:STC]WRH<>[M:ITW0]WRH
      mkstat=2 : GMESSAGE = mess(341,184,1) : End
   Endif
   If [F:STC]DEDFLG = 2
  # si l'emplacement est de type dédié : contrôler que l'article est dans la liste
  # des affectations de l'emplacement
      Look [STF]STF0=[M:ITW0]STOFCY;VALEUR;[M:ITW0]ITMREF
      If fstat
        GERR = 2
        GMESSAGE = mess(451,199,1) #"aucun affectation d'emplacmt n'est établie pour cet article..."
      Endif
   Endif
Else
  If !instr(1,VALEUR,"*") & !instr(1,VALEUR,"?")
&  & !instr(1,VALEUR,"#") & !instr(1,VALEUR,"!")
     mkstat = 2
     GMESSAGE = mess(23,100,1) # "Fiche inexistante"
  Endif
Endif

End

$CHARG_ITG
Local Integer I
# on lit l'article avant de recharger la catégorie
If [M:ITW0]ITMREF <>""
   Read [ITM]ITM0 = [M:ITW0]ITMREF
   If fstat
      Raz [F:ITM] 
   Endif
Else
  Raz [F:ITM]
Endif

   
Read [ITG]ITG1=[F:ITM]TCLCOD;[M:ITW0]STOFCY
If fstat
   Read [ITG]ITG1=[F:ITM]TCLCOD;"" # catégorie générale
Endif
#---------------------------#
# Chargement proprement dit #
#---------------------------#
Effzo [ITW1]20  # emplacements
[M:ITW1]    = [F:ITG]
[M:ITW1]STU = [F:ITM]STU

If dim([F:ITG]LOCMGTCOD) > 0
   If [F:ITG]STOMGTCOD>1 & [F:ITG]LOCMGTCOD>1           
      Raz I
      While I < dim([M:ITW1]LOCNUM) & [F:ITG]LOCDES(I) > 0
        [M:ITW1]LOCNUM(I) = [F:ITG]LOCDES(I)
        If varinit([M:ITW1]DEFLOCTYP,I)=0
          [M:ITW1]DEFLOCTYP(I)="*"
        Endif
        I += 1
      Wend
      If dim([M:ITW1]LOCNUM)>0 [M:ITW1]NBLOC=I Endif
    Else
      For I=0 To dim([M:ITW1]LOCNUM)-1
        Raz [M:ITW1]LOCNUM(I)
      Next I
      If dim([M:ITW1]LOCNUM)>0 Raz [M:ITW1]NBLOC Endif
    Endif
Endif
If [M:ITW1]LOCDEFFLG = 2
    Affzo [ITW1]20  # emplacements
    Actzo [ITW1]20
Else
    Effzo [ITW1]20
    Diszo [ITW1]20
Endif
Return

Subprog AM_CUNCOD(VALEUR)
Variable Integer VALEUR
Local Date WDAT
WDAT = date$
Call CAL_NEXINVITW([M:ITW0]STOFCY,[F:ITM]TCLCOD,WDAT,VALEUR) From STKINV
[M:ITW1]NEXCUNDAT = [F:ITW]NEXCUNDAT
Affzo [M:ITW1]NEXCUNDAT

End

######################################################################################
