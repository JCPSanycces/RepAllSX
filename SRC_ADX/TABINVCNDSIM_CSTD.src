#<AdxTL>@(#)0.0.0.0 $Revision$
# Classe TABINVCNDSIM_INVCNDCOLL
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
     When ""
        Case [L]AEVENT
          When "AREAD"       : Gosub AREAD
        Endcase
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
  Case [L]AOPERATION
          When "OP_SIMULATE" : Gosub OP_SIMULATE
  Endcase
Return
#--------------------------------------
#**
#* Label for coding your operations
#* @param AMETHOD Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
          When "SIMULATE"    : Gosub SIMULATE
  Endcase
Return
#--------------------------------------
$PROPERTIES
  Case [L]CURPRO
  Endcase
Return
#--------------------------------------
$AREAD
Local Date PSTARTDATE
Local Char PSALFCY(GLONFCY)
Local Char PBPCORD(GLONBPC)
Local Char PBPAADD(GLONADR)
Local Char PCURRENCY(GLONCUR)
Local Decimal PAMOUNT

  PSTARTDATE = date$
  PSALFCY    = AVOID.ACHAR
  PBPCORD    = AVOID.ACHAR
  PCURRENCY  = AVOID.ACHAR
  PAMOUNT    = 0

  #--Calling the method
  [L]ASTATUS = fmet this.SIMULATE(PSALFCY,PBPCORD,PSTARTDATE,PCURRENCY,PAMOUNT)
  If [L]ASTATUS>=[V]CST_AERROR
    Return
  Endif

Return
#--------------------------------------
$OP_SIMULATE
#--Key :
#INVCND
#LEG
#--Parameters :
#PSALFCY
#PBPCORD
#PSTARTDATE
#PCURRENCY
#PAMOUNT
  this.INVCND    = [L]INVCND
  this.LEG       = [L]LEG

  #--Calling the method
  [L]ARET_VALUE = fmet this.SIMULATE(PSALFCY,PBPCORD,PSTARTDATE,PCURRENCY,PAMOUNT)
  If [L]ARET_VALUE>=[V]CST_AERROR
    Return
  Endif

Return
#--------------------------------------
$SIMULATE
#--Parameters :
#PSALFCY
#PBPCORD
#PSTARTDATE
#PCURRENCY
#PAMOUNT

Local File TABINVCND    [INVCND]
Local File TABINVCNDLIN [INVCNDD]
Local File FACILITY     [FCY]
Local File TABCUR       [TCU]

Local Integer IJK

  If PSTARTDATE=[0/0/0] : PSTARTDATE = date$ : Endif
  this.STARTDATE = PSTARTDATE

  Read [INVCND]INVCND0 = this.INVCND;this.LEG
  If fstat :
    [L]ARET_VALUE = fmet this.ASETERROR("SIMULATE",func AFNC.MES1(mess(453,192,1),this.INVCND+"~"+this.LEG),[V]CST_AERROR)
    Return
  Endif

  this.INVCND    = [F:INVCND]INVCND
  this.INVCNDTYP = [F:INVCND]INVCNDTYP
  this.LEG       = [F:INVCND]LEG

  #--For call to func CALDAT
  this.SALFCY = [L]PSALFCY
  If [L]PSALFCY<>AVOID.ACHAR
    Read [FCY]FCY0=[L]PSALFCY
    If fstat : Raz [F:FCY] : Endif
  Endif

  this.CURRENCY = PCURRENCY
  If [L]PCURRENCY<>AVOID.ACHAR
    Read [F:TCU]TCU0=PCURRENCY
    If fstat : Raz [F:TCU] : Endif
  Endif
  this.SIMTOT = arr(PAMOUNT,10^(-[F:TCU]DECNBR))

  #--Starting by deleting existing collection lines
  For IJK=1 To maxtab(this.INVCNDCOLL)
    If this.INVCNDCOLL(IJK)<>null and find(this.INVCNDCOLL(IJK).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      ARET_VALUE = fmet this.ADELLINE("INVCNDCOLL",this.INVCNDCOLL(IJK).AORDER)
      If ARET_VALUE=[V]CST_ANOTDEFINED
        #--Message...
        #--"Error deleting INVCNDCOLL collection line"
        [L]ARET_VALUE = fmet this.ASETERROR("SIMULATE",func AFNC.MES1(mess(454,192,1),num$(IJK)),[V]CST_AERROR)
        Break
      Endif
    Endif
  Next
  #--
  Case this.INVCNDTYP
    When 1 :#--Normal
           Gosub _CREATE_SCHEDINV_TYPE_NORMAL
    When 2 :#--Fixed percent
           Gosub _CREATE_SCHEDINV_TYPE_FIXEDPERCENT
    When 3 :#--Periodicity
           Gosub _CREATE_SCHEDINV_TYPE_PERIODICITY
    When Default :#--Other : should we raise an error before returning ? (I'm thinking partners)
  Endcase

Return
#--------------------------------------
$_CREATE_SCHEDINV_TYPE_NORMAL
  If    this.INVCNDTYP=1  #--Normal

  Endif
Return
#--------------------------------------
$_CREATE_SCHEDINV_TYPE_FIXEDPERCENT
Local Integer WTIM_OK,WLINE
Local Integer WMAXTAB
Local Decimal WMINAMTNOT_CONV, WSKYP_PREV_INVPERCENT
Local Integer WSKYP_CURRENT,WROWCOUNT_INVCNDD,WCOUNT_INVCNDD,WLINE_PREV

  WTIM_OK=0

  If this.INVCNDTYP =2 #--Fixed percent

    WTIM_OK               = 0
    WSKYP_CURRENT         = 0
    WSKYP_PREV_INVPERCENT = 0
    WCOUNT_INVCNDD        = 0

    Filter [INVCNDD] Where INVCND=this.INVCND & LEG=this.LEG
&                    Order By Key MACLE=INVCND Asc;INVNBMONTHS Asc; INVNBDAYS Asc;INVDAYMON Asc
    WROWCOUNT_INVCNDD = rowcount([F:INVCNDD])
    For [INVCNDD]MACLE
      WTIM_OK=1
      WCOUNT_INVCNDD += 1
      If WSKYP_CURRENT = 0
        #--We keep adding a line if not on the last INVCNDD record or if the last record does not have a min amount filled
        WLINE_PREV = WLINE
        WLINE = fmet this.ADDLINE("INVCNDCOLL",[V]CST_ALASTPOS)
        If WLINE=[V]CST_ANOTDEFINED
          #--Message...
          #--"Error inserting into INVCNDCOLL collection"
          [L]ARET_VALUE = fmet this.ASETERROR("_CREATE_SCHEDINV_COMMON",mess(455,192,1),[V]CST_AERROR)
          Break
        Endif
        WSKYP_PREV_INVPERCENT = 0
        WPREV_INVCNDD_MINAMT = [F:INVCNDD]MINAMTNOT
        #--Setting properties from TABINVCND to the actual collection line
        #--It is done during the ADDLINE_AFTER event...
        this.INVCNDCOLL(WLINE).INVCNDLIN=[F:INVCNDD]INVCNDLIN
        If this.INVCNDCOLL(WLINE).INVPERCENT=0 #--Could have be done by ADDLINE_AFTER
          #--This will prevent property's accessor to be triggered
          this.INVCNDCOLL(WLINE).INVPERCENT=[F:INVCNDD]INVPERCENT
        Endif
        If WCOUNT_INVCNDD=WROWCOUNT_INVCNDD and [F:INVCNDD]MINAMTNOT>0
          #--CPO 05/02/2016
          #If arr((this.INVCNDCOLL(WLINE).INVPERCENT*this.SIMTOT)/100,10^(-[F:TCU]DECNBR))<[F:INVCNDD]MINAMTNOT
          [L]WMINAMTNOT_CONV = [F:INVCNDD]MINAMTNOT
          If [F:INVCNDD]MINAMTNOTCUR<>this.CURRENCY
            Call CONVERT(this.ACTX,[F:INVCNDD]MINAMTNOTCUR,this.CURRENCY,AVOID.ACHAR,AVOID.AINT,this.STARTDATE,[F:INVCNDD]MINAMTNOT,WMINAMTNOT_CONV,ARET_VALUE) From TRTDEV_SYRA
            If [L]ARET_VALUE > 0
              [L]ARET_VALUE = fmet this.ASETERROR("",mess(463,192,1),[V]CST_AERROR)
              Break
            Endif
          Endif
          If arr((this.INVCNDCOLL(WLINE).INVPERCENT*this.SIMTOT)/100,10^(-[F:TCU]DECNBR))< [L]WMINAMTNOT_CONV #[F:INVCNDD]MINAMTNOT
          #--
            [L]ASTATUS = fmet this.ADELLINE("INVCNDCOLL",this.INVCNDCOLL(WLINE).AORDER)
            If [L]ASTATUS=[V]CST_ANOTDEFINED
              #--"Error deleting INVCNDCOLL collection line"
              [L]ARET_VALUE = fmet this.ASETERROR("SIMULATE",func AFNC.MES1(mess(454,192,1),num$(WLINE)),[V]CST_AERROR)
              Break
            Endif
            WLINE = WLINE_PREV
            this.INVCNDCOLL(WLINE).INVPERCENT += [F:INVCNDD]INVPERCENT
          Endif
        Endif
      Else
        WSKYP_CURRENT = 0
        this.INVCNDCOLL(WLINE).INVCNDLIN=[F:INVCNDD]INVCNDLIN
        #--This will prevent property's accessor to be triggered
        this.INVCNDCOLL(WLINE).INVPERCENT= WSKYP_PREV_INVPERCENT+[F:INVCNDD]INVPERCENT
        WSKYP_PREV_INVPERCENT = 0
      Endif

      #--Is the calculated amount greater then the min amount of the scheduling invoice condition ?
      If [F:INVCNDD]MINAMTNOT<>0
        #--Always controlling the +Vat amount
        #--First convert the MINAMTNOT into the document's currency
        #--CPO 05/02/2016
        [L]WMINAMTNOT_CONV = [F:INVCNDD]MINAMTNOT
        If [F:INVCNDD]MINAMTNOTCUR<>this.CURRENCY
          Call CONVERT(this.ACTX,[F:INVCNDD]MINAMTNOTCUR,this.CURRENCY,AVOID.ACHAR,AVOID.AINT,this.STARTDATE,[F:INVCNDD]MINAMTNOT,WMINAMTNOT_CONV,ARET_VALUE) From TRTDEV_SYRA
          If [L]ARET_VALUE > 0
            [L]ARET_VALUE = fmet this.ASETERROR("",mess(463,192,1),[V]CST_AERROR)
            Break
          Endif
        Endif
        #--
        If arr((this.INVCNDCOLL(WLINE).INVPERCENT*this.SIMTOT)/100,10^(-[F:TCU]DECNBR))<[L]WMINAMTNOT_CONV
          #--The last line
          If WCOUNT_INVCNDD<WROWCOUNT_INVCNDD
            [L]WSKYP_CURRENT = 1
            WSKYP_PREV_INVPERCENT += this.INVCNDCOLL(WLINE).INVPERCENT #[F:INVCNDD]INVPERCENT
          Else
            #--We have to continue filling for the last line (in this case, WLINE is the previous good line)
            [L]WSKYP_CURRENT = 1
            #--Does the modified previous line respect the min amount ?
            If arr((this.INVCNDCOLL(WLINE).INVPERCENT*this.SIMTOT)/100,10^(-[F:TCU]DECNBR))<WPREV_INVCNDD_MINAMT
              [L]WSKYP_CURRENT = 0
            Endif
          Endif
        Endif
      Endif
      If [L]WSKYP_CURRENT=0

        #--Setting the PERFROM/PERTO/NEXINVDAT properties
        Gosub _SET_INVCNDCOLL_VCRINVCNDDAT_2

        this.INVCNDCOLL(WLINE).SIMAMT = arr((this.INVCNDCOLL(WLINE).INVPERCENT*this.SIMTOT)/100,10^(-[F:TCU]DECNBR))
        If [L]ARET_VALUE>=[V]CST_AERROR
          Break
        Endif

        #--Very important !
        #--Check if accessors triggered errors
        [L]ARET_VALUE = fmet this.AGETMAXERROR('')
        If [L]ARET_VALUE>=[V]CST_AERROR : Break : Endif
      Endif
    Next
    Filter [F:INVCNDD]

    Gosub CHECK_TOTALLINES
    #--If error, no need to go further...
    If [L]ARET_VALUE>=[V]CST_AERROR : Return : Endif
  Endif
Return
#--------------------------------------
$_CREATE_SCHEDINV_TYPE_PERIODICITY
Local Integer WTIM_OK,WNBLIGCOLL,WLINE

  If this.INVCNDTYP=3 #--Periodicity
    #--There is only one entry into the TABINVCND table
    #--The number of lines to be added is given by TABINVCND's property:
    #--FREQINV
    Read [F:INVCND]INVCND0=this.INVCND;this.LEG
    If fstat
      this.LEG=AVOID.ACHAR
      Read [F:INVCND]INVCND0=this.INVCND;this.LEG
      If fstat
        #--Message...
        #--"No entry found for the current INVCND code"
        [L]ARET_VALUE = fmet this.ASETERROR("_CREATE_SCHEDINV_TYPE_PERIODICITY",func AFNC.MES1(mess(453,192,1),this.INVCND+"~"+this.LEG),[V]CST_AERROR)
      Endif
    Endif
    If [L]ARET_VALUE>=[V]CST_AERROR : Return : Endif
    For WNBLIGCOLL=1 To [F:INVCND]FREQINV
      WLINE = fmet this.ADDLINE("INVCNDCOLL",[V]CST_ALASTPOS)
      If WLINE=[V]CST_ANOTDEFINED
        #--Message...
        #--"Error inserting into INVCNDCOLL collection"
        [L]ARET_VALUE = fmet this.ASETERROR("_CREATE_SCHEDINV_TYPE_PERIODICITY",mess(455,192,1),[V]CST_AERROR)
        Break
      Endif
      #--Setting properties from TABINVCND to the actual collection line
      #--It is done during the ADDLINE_AFTER event...
      this.INVCNDCOLL(WLINE).INVCNDLIN = WNBLIGCOLL
#      If this.INVCNDCOLL(WLINE).INVPERCENT=0
#        this.INVCNDCOLL(WLINE).INVPERCENT=arr(100/[F:INVCND]FREQINV,0.01)
#      Endif
      #--Setting the PERFROM/PERTO/NEXINVDAT properties
      Gosub _SET_INVCNDCOLL_VCRINVCNDDAT_3
      #this.INVCNDCOLL(WLINE).SIMAMT = arr((this.INVCNDCOLL(WLINE).INVPERCENT*this.SIMTOT)/100,10^(-[F:TCU]DECNBR))
      this.INVCNDCOLL(WLINE).SIMAMT    = arr((this.SIMTOT/[F:INVCND]FREQINV),10^(-[F:TCU]DECNBR))
      this.INVCNDCOLL(WLINE).INVPERCENT= arr((this.INVCNDCOLL(WLINE).SIMAMT*100/this.SIMTOT),0.01)
      If [L]ARET_VALUE>=[V]CST_AERROR
        Break
      Endif

    Next WNBLIGCOLL
    Gosub CHECK_TOTALLINES
  Endif

Return
#--------------------------------------
$_SET_INVCNDCOLL_VCRINVCNDDAT_2
Local Integer IJL,PREVIOUS_LINE
Local Char    WMESS(255)

  #--First, check if lines beeing updated/deleted exists
  #--as this $ is also called from AINSERT/AUPDATE_CONTROL_BEFORE, I'll have to test ASTALIN !!!
  #--INVCNDCOLL(LINE-1) is beeing used without testing the ASTALIN flag
  For IJL = WLINE-1 To 1 Step -1
    If this.INVCNDCOLL(IJL)<>null and find(this.INVCNDCOLL(IJL).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      PREVIOUS_LINE = IJL
      Break
    Endif
  Next

  If [F:INVCND]INVCNDTYP=2
    WTIM_OK=1

    this.INVCNDCOLL(WLINE).NEXINVDAT = PSTARTDATE

    [L]ARET_VALUE = func SVCRINVCND_LIB.CALDATE(this.ACTX,PSTARTDATE,
&                        this.INVCND,this.LEG,this.INVCNDCOLL(WLINE).INVCNDLIN,
&                        this.SALFCY,[F:FCY]UVYCOD,this.INVCNDCOLL(WLINE).NEXINVDAT,WMESS)

    If [L]ARET_VALUE>[V]CST_AOK
      [L]ARET_VALUE = fmet this.ASETERROR("_SET_INVCNDCOLL_VCRINVCNDDAT",WMESS,[L]ARET_VALUE)
      If [L]ARET_VALUE>=[V]CST_AERROR
        Return
      Endif
    Endif

    #--Filling Periode from/to date
    DAT_PERTO      = this.INVCNDCOLL(WLINE).NEXINVDAT
    If PREVIOUS_LINE=0
      DAT_PERFROM = PSTARTDATE
    Else
      If    DAT_PERTO>this.INVCNDCOLL(PREVIOUS_LINE).PERTO
        DAT_PERFROM = this.INVCNDCOLL(PREVIOUS_LINE).PERTO+1
      Elsif DAT_PERTO=this.INVCNDCOLL(PREVIOUS_LINE).PERTO
        DAT_PERFROM = this.INVCNDCOLL(PREVIOUS_LINE).PERFROM
      Else
        WMESS = mess(456,192,1)
        [L]ARET_VALUE = fmet this.ASETERROR("_SET_INVCNDCOLL_VCRINVCNDDAT",WMESS,[L]ARET_VALUE)
        If [L]ARET_VALUE>=[V]CST_AERROR
          Return
        Endif
      Endif
    Endif
    this.INVCNDCOLL(WLINE).PERFROM   = DAT_PERFROM
    this.INVCNDCOLL(WLINE).PERTO     = DAT_PERTO

Endif

Return
#--------------------------------------------------------------------------------------------------
$_SET_INVCNDCOLL_VCRINVCNDDAT_3
Local Integer IJL,PREVIOUS_LINE
Local Char    WMESS(255)

  #--First, check if lines beeing updated/deleted exists
  #--as this $ is also called from AINSERT/AUPDATE_CONTROL_BEFORE, I'll have to test ASTALIN !!!
  #--INVCNDCOLL(LINE-1) is beeing used without testing the ASTALIN flag
  For IJL = WLINE-1 To 1 Step -1
    If this.INVCNDCOLL(IJL)<>null and find(this.INVCNDCOLL(IJL).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      PREVIOUS_LINE = IJL
      Break
    Endif
  Next

  If this.INVCNDTYP=3

    WTIM_OK=1
    If PREVIOUS_LINE=0
      WRET = func SVCRINVCND_LIB.GET_PERFROM_PERTO([F:INVCND]PERINV,PSTARTDATE,[0/0/0],
&                  this.INVCNDCOLL(WLINE).PERFROM,this.INVCNDCOLL(WLINE).PERTO,WMESS)
    Else
      WRET = func SVCRINVCND_LIB.GET_PERFROM_PERTO([F:INVCND]PERINV,PSTARTDATE,this.INVCNDCOLL(PREVIOUS_LINE).PERTO,
&                  this.INVCNDCOLL(WLINE).PERFROM,this.INVCNDCOLL(WLINE).PERTO,WMESS)
    Endif
    If [L]ARET_VALUE>[V]CST_AOK
      [L]ARET_VALUE = fmet this.ASETERROR("_SET_INVCNDCOLL_VCRINVCNDDAT",WMESS,[L]ARET_VALUE)
      If [L]ARET_VALUE>=[V]CST_AERROR
        Return
      Endif
    Endif

    If    [F:INVCND]INVMETH=1
      #Pré-facturation (Terme à échoir)
      this.INVCNDCOLL(WLINE).NEXINVDAT=this.INVCNDCOLL(WLINE).PERFROM
    Elsif [F:INVCND]INVMETH=2
      #Post-facturation (Terme échu)
      this.INVCNDCOLL(WLINE).NEXINVDAT=this.INVCNDCOLL(WLINE).PERTO
    Else

    Endif

    [L]ARET_VALUE = func SVCRINVCND_LIB.CALDATE(this.ACTX,PSTARTDATE,
&                        this.INVCND,this.LEG,this.INVCNDCOLL(WLINE).INVCNDLIN,
&                        this.SALFCY,[F:FCY]UVYCOD,this.INVCNDCOLL(WLINE).NEXINVDAT,WMESS)
    If [L]ARET_VALUE>[V]CST_AOK
      [L]ARET_VALUE = fmet this.ASETERROR("_SET_INVCNDCOLL_VCRINVCNDDAT",WMESS,[L]ARET_VALUE)
      If [L]ARET_VALUE>=[V]CST_AERROR
        Return
      Endif
    Endif
    ## X3-19101
    If WLINE=1 & this.INVCNDCOLL(WLINE).NEXINVDAT<PSTARTDATE & [F:INVCND]INVMETH=1
       this.INVCNDCOLL(WLINE).NEXINVDAT=PSTARTDATE
       If day(this.INVCNDCOLL(WLINE).NEXINVDAT)<[F:INVCND]INVDAY
          this.INVCNDCOLL(WLINE).NEXINVDAT=gdat$([F:INVCND]INVDAY, month(this.INVCNDCOLL(WLINE).NEXINVDAT),year(this.INVCNDCOLL(WLINE).NEXINVDAT))
       Endif
    Endif
    ## END X3-19101
  Endif

Return
#--------------------------------------
$CHECK_TOTALLINES
Local Decimal WTOTINVPERCENT,WTOTSIMAMT
Local Decimal PERCENT_TO_DISTRIB,PERCENT_TO_DISTRIB_PER_LINE,PERCENT_TO_DISTRIB_PER_LINE_LAST_LINE
Local Integer IJL,W,TROUVE,WMAXTAB

  For IJL=1 To maxtab(this.INVCNDCOLL)
    If this.INVCNDCOLL(IJL)<>null and find(this.INVCNDCOLL(IJL).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      WTOTINVPERCENT += this.INVCNDCOLL(IJL).INVPERCENT
      WTOTSIMAMT     += this.INVCNDCOLL(IJL).SIMAMT
      WMAXTAB         = IJL #--Last "good" indice
    Endif
  Next

  If WTOTINVPERCENT<>100 or (this.SIMTOT>0 and WTOTSIMAMT<>this.SIMTOT)
    If this.SIMTOT>0
      this.INVCNDCOLL(WMAXTAB).SIMAMT += this.SIMTOT -WTOTSIMAMT
    Endif
    PERCENT_TO_DISTRIB = 100-WTOTINVPERCENT
    #--I'll have to find how many lines I can use in order to have a PERCENT_TO_DISTRIB_PER_LINE>0 due to the round
    PERCENT_TO_DISTRIB_PER_LINE = arr(PERCENT_TO_DISTRIB/WMAXTAB,0.001)
    If WMAXTAB*PERCENT_TO_DISTRIB_PER_LINE<>PERCENT_TO_DISTRIB
      PERCENT_TO_DISTRIB_PER_LINE_LAST_LINE = PERCENT_TO_DISTRIB-WMAXTAB*PERCENT_TO_DISTRIB_PER_LINE
    Endif
    #--Now, we add the percentage to distribute
    For IJL=1 To WMAXTAB-1
      If this.INVCNDCOLL(IJL)<>null and find(this.INVCNDCOLL(IJL).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
        this.INVCNDCOLL(IJL).INVPERCENT += PERCENT_TO_DISTRIB_PER_LINE
      Endif
    Next
    this.INVCNDCOLL(WMAXTAB).INVPERCENT += PERCENT_TO_DISTRIB_PER_LINE_LAST_LINE
  Endif
Return

