#<AdxTL>@(#)8.0.0.0 $Revision$

Call OBJET("SMR", GBIDC1, GBIDC2) From GOBJET
End

########################################
#
# Sous programmes divers
#
#
# DISLIG              : Grise tous les champs d'une ligne du tableau
# ACTLIG              : Active tous les champs d'une ligne du tableauf
# REACTLIG            : Active ou désactive les champs d'une ligne de SMR1 en fonction de l'article
# REINILIG            : Idem REACTLIG + initialisation des valeurs
# TRT_MAJ_DOCUMENT    : Met à jour la table détail du document après le passage dans la fenêtre
#                        composant commun "modification de détail"
# CHARG_PARAM_STOENT  : Charge l'en-tête de l'écran composant commun "Détail de ligne de document"
# CHARG_PARAM_STOENTM : Charge l'en-tête de l'écran composant commun "Modification détail de ligne de document"
#
########################################


$SET_NOL
    Local Integer NOL
    NOL = nolign-1
Return

########################################
# Se positionne sur les fichiers qui sont utilisés dans les actions champs
# Ce n'est pas top mais cela permet de centraliser le positionnement dans les fichiers
Subprog POSTABLE
Local Integer LRET
    Gosub SET_NOL
    If [M:SMR1]ITMREF(NOL)<>""
        Read [F:ITM]ITM0=[M:SMR1]ITMREF(NOL)
        Read [F:ITF]ITF0=[M:SMR1]ITMREF(NOL);[M:SMR0]STOFCY
        Call LECSRU([M:SMR0]STOFCY, [M:SMR1]TCLCOD(NOL), [M:SMR0]TRSTYP, [M:SMR0]TRSCOD, "", [L]LRET) From STKLIB
        If [L]LRET
            mkstat = 2
        Endif
    Endif
End

########################################
# REINILIG     Active ou désactive les champs d'une ligne de SMR1
#              en fonction de l'article passé en paramètre
#              Et remet les valeurs par défaut dans les champs.
#
# Paramètres E : PITM = article à utiliser
#                PLIG = numéro de la ligne de SMR1 à traiter
#
# Utilisé par RAZDUP
########################################
Subprog REINILIG(PITM, PLIG)
Value Char PITM
Value Integer PLIG
Local Integer LRET
Local Char    WWRH(GLONWRH)
    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif                # hcb 50197
    If [F:SRT]SRTTYP <> 1 | [F:SRT]SRTNUM <> GSMRNUM                   # hcb 50197
       Read [SRT]SRT0=1;GSMRNUM : If fstat Raz [F:SRT] : Endif
    Endif
    Read [F:ITM]ITM0=PITM
    Read [F:ITF]ITF0=PITM;[M:SMR0]STOFCY
    [M:SMR1]TCLCOD(PLIG) = [F:ITM]TCLCOD
    Call LECSRU([M:SMR0]STOFCY, [M:SMR1]TCLCOD(PLIG), [M:SMR0]TRSTYP, [M:SMR0]TRSCOD, "", [L]LRET) From STKLIB
    If [L]LRET
        mkstat = 2
        End
    Endif

    Actzo [M:SMR1]ITMREF(PLIG),ITMDES1(PLIG),PCU(PLIG),QTYPCU(PLIG),STA(PLIG)
    If dim([M:SMR1]BPSLOT)>0
       Actzo [M:SMR1]BPSLOT(PLIG)   # hcb 63559
    Endif

    [M:SMR1]STU(PLIG)    = [F:ITM]STU
    Call STKINISTA([M:SMR1]STA(PLIG),"",1) From STKACT

    Affzo [M:SMR1]ITMDES1(PLIG),PCU(PLIG),STU(PLIG),PCUSTUCOE(PLIG),STA(PLIG)
    Diszo [M:SMR1]PCUSTUCOE(PLIG)

    #pas de saisie emplacement si Article ne gere pas l emplacement
    If dim([M:SMR1]LOC)>0
        If [F:ITF]LOCMGTCOD = 1
            Raz [M:SMR1]LOCTYP(PLIG), [M:SMR1]LOC(PLIG)
            Grizo [M:SMR1]LOCTYP(PLIG), LOC(PLIG)
        # Sinon recherche l'emplacement par défaut
        Else
            If dim([M:SMR1]WRH) > 0
              WWRH=[M:SMR1]WRH(PLIG)
            Else
              WWRH=""
            Endif

            Actzo [M:SMR1]LOCTYP(PLIG), LOC(PLIG)
            Local Integer I
            # Récupération type emplacement par défaut de l'art-site pour le type mouvement
            [L]I = find([F:SRU]LOCNUM-1,[F:ITF]LOCNUM(0..dim([F:ITF]LOCNUM)-1))
            If [L]I>0
                #--- Bug 72649 ajout paramètre emplacement
                # Récupération type emplacement par défaut de l'art-site pour le type mouvement
                Call STKSUGTLO(100000+[M:SMR1]WSTOSEQ(PLIG),[M:SMR0]TRSTYP,
&                              [M:SMR0]TRSCOD,[M:SMR0]STOFCY,[M:SMR1]ITMREF(PLIG),
&                              [M:SMR1]PCU(PLIG),[M:SMR1]QTYPCU(PLIG),[M:SMR1]STA(PLIG),
&                              [M:SMR1]LOCTYP(PLIG),"QU","",WWRH,[M:SMR1]LOC(PLIG)) From STKLOC
                mkstat=0
            Endif
            # Récupération de l'emplacement par défaut de l'art-site pour le type mouvement
            [L]I = find([F:SRU]LOCNUM-1,[F:ITF]LOCNUM(0..dim([F:ITF]LOCNUM)-1))
            If I>0
                # Récupération de l'emplacement par défaut de l'art-site pour le type mouvement
                Call STKSUGEMP(100000+[M:SMR1]WSTOSEQ(PLIG),[M:SMR0]TRSTYP,
&                              [M:SMR0]TRSCOD,[M:SMR0]STOFCY,[M:SMR1]ITMREF(PLIG),
&                              [M:SMR1]PCU(PLIG),[M:SMR1]QTYPCU(PLIG),[M:SMR1]STA(PLIG),
&                              [M:SMR1]LOCTYP(PLIG),[M:SMR1]LOC(PLIG),"","QU","",WWRH)
&                              From STKLOC
                mkstat=0
            Endif
        Endif
        Affzo [M:SMR1]LOCTYP(PLIG), LOC(PLIG)
    Endif

#                                 # hcb X3-98216 deb
    If dim([M:SMR1]LPNNUM)>0
       Raz [M:SMR1]LPNNUM(PLIG)
       If [F:ITF]LPNMGTCOD=2
          Actzo [M:SMR1]LPNNUM(PLIG)
       Else
          Grizo [M:SMR1]LPNNUM(PLIG)
       Endif
    Endif
    If dim([M:SMR1]TCTRNUM)>0
       Raz [M:SMR1]TCTRNUM(PLIG)
       If [F:ITF]LPNMGTCOD=2
          Actzo [M:SMR1]TCTRNUM(PLIG)
          [M:SMR1]TCTRNUM(PLIG) = [F:ITF]TCTRDEF
       Else
          Grizo [M:SMR1]TCTRNUM(PLIG)
      Endif
    Endif
#                                 # hcb X3-98216 fin
    # Vérifie si l'article est configuré avec gestion de lot
    If dim([M:SMR1]LOT)>0
        If [F:ITM]LOTMGTCOD = 1
            Grizo [M:SMR1]LOT(PLIG)
            Raz   [M:SMR1]LOT(PLIG)
        Else
            If [F:ITM]LOTCOU<>""
                GESLOT(PLIG) = "C"
            Endif
            Call INIT_GOUVLOT("SRT") From STKENT
            Actzo [M:SMR1]LOT(PLIG)
            Raz   [M:SMR1]LOT(PLIG)
        Endif
        Affzo [M:SMR1]LOT(PLIG)

        If dim([M:SMR1]SLO)>0
            If [F:ITM]LOTMGTCOD <> 4  # Si on ne gère pas les sous lots
                Grizo [M:SMR1]NBSLO(PLIG)
                Grizo [M:SMR1]SLO(PLIG)
                Raz [M:SMR1]NBSLO(PLIG), [M:SMR1]SLO(PLIG)
            Else
                Actzo [M:SMR1]NBSLO(PLIG)
                Actzo [M:SMR1]SLO(PLIG)
                [M:SMR1]NBSLO(PLIG) = 1
                Raz [M:SMR1]SLO(PLIG)
                Raz [M:SMR1]SLOF(PLIG)
            Endif
            Affzo [M:SMR1]NBSLO(PLIG), SLO(PLIG), SLOF(PLIG)
        Endif
# ECC
        If dim([M:SMR1]ECCVALMAJ)>0
            If [F:ITM]ECCSTO = 1
                Raz [M:SMR1]ECCVALMAJ(PLIG), [M:SMR1]ECCVALMIN(PLIG), [M:SMR1]ECCSAIFLG(PLIG)
            Else
                If [F:ITM]ECCSTO >  1
                   Raz [M:SMR1]ECCVALMAJ(PLIG)
                   Raz [M:SMR1]ECCSAIFLG(PLIG)
                Endif
                 If [F:ITM]ECCSTO > 2
                   Raz [M:SMR1]ECCVALMIN(PLIG)
                   Raz [M:SMR1]ECCSAIFLG(PLIG)
                Endif

            Endif
            Affzo [M:SMR1]ECCVALMAJ(PLIG), ECCVALMIN(PLIG)
        Endif
# ECC end
        # Init avec la règle de gestion
        If [F:SRU]QLYCTLFLG=2
            # Controle du compteur fiche d'analyse
            Call CTRCPT(GSTKCPT(1),type([F:STJ]QLYCTLDEM),[L]LRET) From STKLIB
            If LRET <> 0
                GMESSAGE = mess(88,199,1)
                GERR = 1
                GOK  = 0
                mkstat = 2
            Endif
        Endif

        If [F:SRU]LOTSUPINH=3
            [M:SMR1]LOT(PLIG) = [M:SMR0]VCRNUM
        Endif
        If [F:SRU]DACLOT = 1
           If dim([M:SMR1]LOT) > 0
               Grizo [M:SMR1]LOT(PLIG)
           Endif
        Endif
    Endif

    # Si le n° de série n'est pas géré en entrée on desactive la saisie
    If dim([M:SMR1]SERNUM)>0
        If [F:ITM]SERMGTCOD = 3
            If dim([M:SMR1]NBSLO)>0
                Diszo [M:SMR1]NBSLO(PLIG)
                [M:SMR1]NBSLO(PLIG) = 1
                Raz [M:SMR1]SLO(PLIG)
                Raz [M:SMR1]SLOF(PLIG)
                Affzo [M:SMR1]NBSLO(PLIG), SLO(PLIG), SLOF(PLIG)
            Endif
            Actzo [M:SMR1]SERNUM(PLIG)
        Else
            Grizo [M:SMR1]SERNUM(PLIG)
            Raz [M:SMR1]SERNUM(PLIG), [M:SMR1]SERNUMF(PLIG)
        Endif
        Affzo [M:SMR1]SERNUM(PLIG), SERNUMF(PLIG)
    Endif

    # Init du prix ne peut se faire qu'après la saisie de champs lot et sous-lot
    # Cela est donc fait en avant saisie. Ici on n'effectue qu'une RAZ
End

########################################
$TRT_MAJ_DOCUMENT
Local Integer LOK

# Mise à jour des quantités
Gosub MAJ_LIGNE_DOCUMENT

#-- Maj du détail entrées
# 1- Locker l'enregistrement de la ligne de document
Readlock [SMD]SMD0=[M:SMR0]VCRTYP;[M:SMR0]VCRNUM;[M:SMR1]VCRLIN(LLIGDOC)
If fstat = 1
   GOK = -1
   GLOCK = "$SMVTD"-[M:SMR0]VCRNUM-num$([M:SMR1]VCRLIN(LLIGDOC))
   Return
Elsif fstat
   GOK =  0
   Call RSTA ("SMD",[M:SMR0]VCRNUM-num$([M:SMR1]VCRLIN(LLIGDOC))) From GLOCK
   Return
Endif

# 2- Si la nouvelle quantité est nulle...
If [M:SMR1]QTYSTU (LLIGDOC) = 0
    # ... supprimer la ligne ...
    Delete [SMD]
    #----- Suppression  sections de la ligne de document  -----#     # ana
    Delete [CAL] Where ABRFIC="SMD" & VCRTYP=[F:SMD]VCRTYP & VCRNUM=[F:SMD]VCRNUM & VCRLIN=[F:SMD]VCRLIN # ana
    If fstat=1                                                                                           # ana
       GOK=-1 : GLOCK="$CPTANALIN SMD 0"-[F:SMD]VCRNUM-num$([F:SMD]VCRLIN) : Return                      # ana
    Endif                                                                                                # ana
    # ... et s'il n'y a plus de ligne proposer la suppression du document
    Readlock [SMD]SMD0(2)=[M:SMR0]VCRTYP;[M:SMR0]VCRNUM
    [G:SMD]currlen=0
    If fstat
        LOK = 2
            Call OUINONT( [M:SMR0]VCRNUM - mess(8, 184, 1), LOK ) From GESECRAN    # Document Vide    # hcb 94728
        If LOK=2
            Delete [SMH]SMH0=[M:SMR0]VCRTYP;[M:SMR0]VCRNUM
            If fstat
                GOK = 0
                Call FSTA("SMH") From GLOCK
            Else
                Effzo [M:SMR0]
                Effzo [M:SMR1]
            Endif
        Else
            fstat = 0
        Endif
    Endif
Else
    # 3- Si la nouvelle quantité n'est pas nulle enregistrer cette nouvelle quantité
    [F:SMD]QTYPCU    = [M:SMR1]QTYPCU(LLIGDOC)
    [F:SMD]QTYSTU    = [M:SMR1]QTYSTU(LLIGDOC)
    [F:SMD]PCU       = [M:SMR1]PCU(LLIGDOC)
    [F:SMD]PCUSTUCOE = [M:SMR1]PCUSTUCOE(LLIGDOC)
    Rewrite [SMD]
Endif
# 4- Délocker l'enregistrement
If fstat
    GOK=0
    Call FSTA("SMD") From GLOCK
    Return
Endif


GRELITSMR = 1

Return

########################################
Subprog CHARG_PARAM_STOENT(LLIG)
Value    Integer LLIG
Variable Integer LRET
    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif                # hcb 50197
    If [F:SRT]SRTTYP <> 1 | [F:SRT]SRTNUM <> GSMRNUM                   # hcb 50197
       Read [SRT]SRT0=1;GSMRNUM : If fstat Raz [F:SRT] : Endif
    Endif
    [M:ENT]STOFCY    = [M:SMR0]STOFCY
    [M:ENT]ITMREF    = [M:SMR1]ITMREF(LLIG)
    [M:ENT]QTYTOENT  = [M:SMR1]QTYPCU(LLIG)
    [M:ENT]PCUTOENT  = [M:SMR1]PCU(LLIG)
    [M:ENT]COETOENT  = [M:SMR1]PCUSTUCOE(LLIG)
    [M:ENT]STU       = [M:SMR1]STU(LLIG)
    [M:ENT]VCRNUM    = [M:SMR0]VCRNUM
    [M:ENT]VCRLIN    = [M:SMR1]VCRLIN(LLIG)
    [M:ENT]WSTOSEQ   = [M:SMR1]WSTOSEQ(LLIG)
    [M:ENT]MVTDES    = [M:SMR1]MVTDES(LLIG)
    [M:ENT]PRI       = [M:SMR1]PRIORD(LLIG)
    [M:ENT]QUAFLG    = [M:SMR1]QUAFLG(LLIG)       # hcb V6CQ
    [M:ENT]QUAFRE    = [M:SMR1]QUAFRE(LLIG)       # hcb V6CQ
    If dim([M:SMR1]WRH)>0
      [M:ENT]XWRH    = [M:SMR1]WRH(LLIG)
    Endif
    [M:ENT]TRSTYP    = 1                        # entree diverse
    [M:ENT]TYPBPR      = 1                        # hcb 71276
    [M:ENT]TRSCOD    = [M:SMR0]TRSCOD           # code mouvement
    [M:ENT]TRSFAM    = [M:SMR0]TRSFAM           # famille mouvement
    [M:ENT]IPTDAT    = [M:SMR0]IPTDAT           # date imputation
    [M:ENT]CUR       = GLOCALDEV
    [M:ENT]CCECODS   = [F:DTR]STOCCECOD                          # Ana
    [M:ENT]SRGWAIFLG = [M:SMR0]SRGWAIFLG         # hcb 50197
    [M:ENT]PRNCOD1   = [F:SRT]PRNCOD1
    [M:ENT]PRNNBFLG1 = [F:SRT]PRNNBFLG1
    If dim([M:ENT]ECCBOMFLG)>0
       Raz [M:ENT]ECCBOMFLG                                     # hcb 71276
    Endif

End
########################################
Subprog CHARG_PARAM_STOENTM(LLIG)
Value Integer LLIG
    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif                # hcb 50197
    If [F:SRT]SRTTYP <> 1 | [F:SRT]SRTNUM <> GSMRNUM                   # hcb 50197
       Read [SRT]SRT0=1;GSMRNUM : If fstat Raz [F:SRT] : Endif
    Endif
    [M:ENM]STOFCY    = [M:SMR0]STOFCY
    [M:ENM]ITMREF    = [M:SMR1]ITMREF(LLIG)
    [M:ENM]QTYTOENT  = [M:SMR1]QTYPCU(LLIG)
    [M:ENM]PCUTOENT  = [M:SMR1]PCU(LLIG)
    [M:ENM]COETOENT  = [M:SMR1]PCUSTUCOE(LLIG)
    [M:ENM]STU       = [M:SMR1]STU(LLIG)
    [M:ENM]VCRNUM    = [M:SMR0]VCRNUM
    [M:ENM]VCRLIN    = [M:SMR1]VCRLIN(LLIG)
    [M:ENM]MVTDES    = [M:SMR1]MVTDES(LLIG)
    [M:ENM]QUAFLG    = [M:SMR1]QUAFLG(LLIG)       # hcb V6CQ
    [M:ENM]QUAFRE    = [M:SMR1]QUAFRE(LLIG)       # hcb V6CQ
    If dim([M:SMR1]WRH)>0
      [M:ENM]XWRH    = [M:SMR1]WRH(LLIG)
    Endif
    [M:ENM]PJT       = [M:SMR0]PJT
    [M:ENM]TRSTYP    = 1                        # entree diverse
    [M:ENM]TYPBPR      = 1                        # hcb 71276

    [M:ENM]TRSCOD    = [M:SMR0]TRSCOD           # code mouvement
    [M:ENM]TRSFAM    = [M:SMR0]TRSFAM           # famille mouvement
    [M:ENM]IPTDAT    = [M:SMR0]IPTDAT           # date imputation
    [M:ENM]ENTCOD    = [M:SMR0]ENTCOD           # Code pièce auto
    [M:ENM]SRGWAIFLG = [M:SMR0]SRGWAIFLG         # hcb 50197
    [M:ENM]PRNCOD1   = [F:SRT]PRNCOD1
    [M:ENM]PRNNBFLG1 = [F:SRT]PRNNBFLG1
    [M:ENM]UPDPRI    = 1+([M:SMR1]PRISAI(LLIG)=GPRISAIMAN)
    If dim([M:ENT]ECCBOMFLG)>0
       Raz [M:ENT]ECCBOMFLG                                     # hcb 71276
    Endif
End

################################################
# Alimente le masque STOWORK
# Ce sous programme est à appeler sur les actions:
#    VALLIG
################################################
Subprog ALISTW( NOL )
Value Integer NOL

Local Decimal LQTA
Local Decimal LSHT
Local Integer LRET
Local Integer LNBR, LNBJ

# Initialisation de l'en-tête
Raz [M:STW]       # hcb 82225
[M:STW]STOFCY     = [M:SMR0]STOFCY      # Site
[M:STW]TRSTYP     = [M:SMR0]TRSTYP      # Type mouvement (M.704)
[M:STW]VCRTYP     = [M:SMR0]VCRTYP      # Type pièce (M.701)
[M:STW]VCRNUM     = [F:SMH]VCRNUM       # Numéro pièce
[M:STW]VCRLIN     = [F:SMD]VCRLIN       # Numero ligne pièce
[M:STW]ITMREF     = [M:SMR1]ITMREF(NOL) # Article
[M:STW]MVTDES     = [M:SMR1]MVTDES(NOL) # Désignation mouvement
[M:STW]PRIORDH    = [M:SMR1]PRIORD(NOL) # Prix de l'ordre
[M:STW]PJT        = [M:SMR0]PJT         # Affaire
[M:STW]TRSFAM     = [M:SMR0]TRSFAM      # Famille mouvement
[M:STW]ENTCOD     = [M:SMR0]ENTCOD      # Code pièce auto
[M:STW]IPTDAT     = [M:SMR0]IPTDAT      # Date imputation
[M:STW]TRSCOD     = [M:SMR0]TRSCOD      # Code mouvement
[M:STW]CCECOD     = "STJEND"
[M:STW]CUR        = GLOCALDEV
If [M:SMR1]PRISAI(NOL)=GPRISAIAUT
    [M:STW]UPDPRI = 1
Else
    [M:STW]UPDPRI = 2
Endif
Call ALISTOWORK( 2, [M:SMR1]WSTOSEQ(NOL), LQTA, LSHT, LNBR, LNBJ, LRET ) From STKINT
If !LRET
    Call MAJ_STOCK From STKMAJ
    If GOK
       Call STKFREQCQ("SMR1",[M:SMR0]STOFCY,NOL,[M:SMR1]ITMREF(NOL),"","V",[M:SMR1]QUAFLG(NOL),0) From STKACT   # hcb V6CQ (freq)
    Endif
Else
    GOK=0
Endif

End



###############################################################################
# MAJ_LIGNE_DOCUMENT : appelé à partir de l'action SAISTOENT
#                      après clic sur bouton "Enregistrer"
#                      Permet de mettre à jour les quantités
###############################################################################
$MAJ_LIGNE_DOCUMENT
    # Vérifie que le coefficient UC/US peut être modifié,
    # que le coef est unique (>0)
    # et que l'unité est unique
    If clalev ([F:SRT])=0 Local File STKTRS [SRT] Endif                # hcb 50197
    If [F:SRT]SRTTYP <> 1 | [F:SRT]SRTNUM <> GSMRNUM                   # hcb 50197
       Read [SRT]SRT0=1;GSMRNUM : If fstat Raz [F:SRT] : Endif
    Endif
    [M:SMR1]QTYSTU(LLIGDOC) = LQTYSTU
    If [F:SRT]UOMSAIFLG=2 & LCOEF>0 & LPCU<>""
        [M:SMR1]PCU(LLIGDOC)       = LPCU
        [M:SMR1]PCUSTUCOE(LLIGDOC) = LCOEF
#       [M:SMR1]QTYPCU(LLIGDOC)    = LQTYSTU / LCOEF   # hcb 160205 28512
        [M:SMR1]QTYPCU(LLIGDOC)    = LQTYPCU           # hcb 160205 28512
    Else    # Met tout en US
        [M:SMR1]PCU(LLIGDOC)       = [M:SMR1]STU(LLIGDOC)
        [M:SMR1]PCUSTUCOE(LLIGDOC) = 1
        [M:SMR1]QTYPCU(LLIGDOC)    = LQTYSTU
    Endif
    Affzo [M:SMR1]QTYSTU(LLIGDOC), PCU(LLIGDOC), QTYPCU(LLIGDOC), PCUSTUCOE(LLIGDOC)
Return

