#<AdxTL>@(#)0.0.0.0 $Revision$
# Function allowing to update status of AUDIT records
Call UPD_STABI(nomap)
End

$ACTION
Case ACTION
    When "INIT_DIA"    : Gosub INIT_DIA
    When "CONTROLE"    : Gosub CONTROLE
    When "CONT_BATCH"  : Gosub CONT_BATCH
    When "EXEC"        : Gosub EXEC
Endcase
Return

$INIT_DIA
Raz [M]
If PARAM(1)<>""
    [M]DOSSIER = PARAM(1)
Else
    [M]DOSSIER = nomap
Endif
Return

$CONTROLE
$CONT_BATCH
If [M]DOSSIER=""
 SAI = 1 : Return
Endif
Return

$EXEC
Call UPD_STABI([M]DOSSIER)
Return

Subprog UPD_STABI(APPLI)
Value Char APPLI

Local Integer TRA
If !GSERVEUR
    TRA = 1
Endif

If TRA
    Call OUVRE_TRACE("Update STABI flag in AUDIT table") From LECFIC
Endif

If (filinfo(filpath("FIL","AUDITBI","fde",APPLI),0)>0)
    TABAUDIT = "AUDITBI"
Else
    TABAUDIT = "AUDITH"
Endif

Local File =APPLI+"."+TABAUDIT [AUD]

Trbegin [AUD]
Update [AUD] Where STABI=4
&            With STABI=3
Call ECR_TRACE (num$(adxuprec)-mess(104,141,1),0) From GESECRAN
Commit

If TRA
    Call FERME_TRACE From LECFIC
Endif

LogicClose File [AUD]

End

