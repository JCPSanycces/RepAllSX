#<AdxTL>@(#)2.0.0.0 $Revision$
#########################################################################
# Contient les traitements utilisée pour la modélisation                #
# Etiquettes                                                            #
#########################################################################
#    ACTION MODELISATION E-COMMERCE                                     #
#                                                                       #
# GACTION  : TRTPURSUG  : Action purge suggestions                      #
#                                                                       #
#########################################################################
$ACTION
Case ACTION
 When "INIT"          : Gosub INIT
 When "INIT_DIA"      : Gosub INIT_DIA
 When "CONTROLE"      : Gosub CONTROLE
 When "EXEC"          : Gosub EXEC
 When "TERMINE"       : Gosub TERMINE
 When Default
Endcase
Return

#########################################################################
$INIT
# En batch , il vaut mieux mettre onerrgo
If GSERVEUR
    Onerrgo ERRBATCH
Endif

Call FIND_GFCYDEF(8) From TRTX3   # FQ 54218
Gosub OUVRE

# initialisation type de commande
# contrôle des autorisations   - FQ 44688 GUSRACC n'existe plus en V5
#If   GUSRACC(1)=0 & GUSRACC(2)=0    
#     GERR = 1 : GMESSAGE = mess(1,123,1) : FIN = 1
#     Return  
#Endif 
Return

#########################################################################
$INIT_DIA
# titre de la boîte 
TIT = mess(233,195,1)
Raz [M:DIA] 

Return

#########################################################################
$CONTROLE
TIT=" "
TMP=1
Return

#########################################################################
$EXEC
If !GSERVEUR
    TRA = 1
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
    Call PRTSCR("MAUTSUG","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN 
    Call ECR_TRACE(" ",0) From GESECRAN 
Endif

# préparation des critères de filtre
Gosub SEL_ORD

# traitement des suggestions
Gosub TRT_ORD
Return

#########################################################################
$TERMINE
If !GSERVEUR
    # fermeture trace 
    Call FERME_TRACE From LECFIC
    # aucune suppression effectuee ou lecture trace
    If !NBORD 
         GERR = 2 : GMESSAGE = mess(104,199,1)
    Endif
    # lecture trace
Endif
Return
########################################################################
$OUVRE
Local Integer  OK
Local Integer  NBORD
Local Char     TIT(50)
Local Char     CRITERE(255)
Local Char     CRITERE1(255)
Local Char     CRITERE2(255)(1..2)
Local Char     CRITERE3(255) : # FQ 43708 Purge des MWS/SCS orphelines
Local Char     FORMULE1(255)
Local Char     WMESS(85)
Local Char     WMESS1(85)
Local Char     WMESS2(85)
Local Integer  WRET
Local Char     WITMREF(GLONITM)
Local Char     WSTOFCY(GLONFCY)
Local Integer  WORI

Gosub CHARG_PARAM
#---------------------------------------#
# Ouverture des fichiers utilisés       #
#---------------------------------------#
If clalev([F:ORD])  = 0 : Local File ORDERS      [ORD]  : Endif
If clalev([F:ORD1]) = 0 : Local File ORDERS      [ORD1] : Endif
If clalev([F:ITM])  = 0 : Local File ITMMASTER   [ITM]  : Endif
If clalev([F:ITF])  = 0 : Local File ITMFACILIT  [ITF]  : Endif
If clalev([F:TFO])  = 0 : Local File TABFOR      [TFO]  : Endif 
If clalev([F:FCY])  = 0 : Local File FACILITY    [FCY]  : Endif

If GMODU(8) = 2
    If clalev([F:OPS])  = 0 : Local File OPERATIONS  [OPS]  : Endif
    If clalev([F:SCH])  = 0 : Local File SCHEDULING  [SCH]  : Endif
    If clalev([F:WKL])  = 0 : Local File WORKLOAD    [WKL]  : Endif
    If clalev([F:TWD])  = 0 : Local File CAPVAR      [CPV]  : Endif
Endif

Return

########################################################################
# Préparation du filtre sur la table encours                           #
########################################################################
$SEL_ORD
Raz CRITERE
Raz CRITERE1
Raz CRITERE2

If [M:DIA]WOSFLG = 2
    CRITERE  = "WIPTYP=5"
    Gosub LOAD_CRITERE
Endif

If [M:DIA]POSFLG = 2
    CRITERE  = "WIPTYP=2"
    Gosub LOAD_CRITERE
Endif

If [M:DIA]INTFLG = 2
    CRITERE  = "WIPTYP=7"
    Gosub LOAD_CRITERE
Endif

# FQ 73178 GA 04/2011  ajout des EOS
If [M:DIA]EOSFLG = 2
    CRITERE  = "WIPTYP=13"
    Gosub LOAD_CRITERE
Endif

# fin de la première partie
CRITERE1 += ")"

CRITERE = "WIPSTA=3"
Gosub LOAD_CRITERE2

CRITERE  = "STOFCY=[M:DIA]STOFCY"                     # site 
Gosub LOAD_CRITERE2

CRITERE = "ORI>=[M:DIA]ORIDEB"
Gosub LOAD_CRITERE2

CRITERE = "ORI<=[M:DIA]ORIFIN"
Gosub LOAD_CRITERE2

CRITERE = "ORI<>4"

If [M:DIA]ITMREFDEB <> ""
   CRITERE = "ITMREF>=[M:DIA]ITMREFDEB"               # borne début article
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]ITMREFFIN <> ""
   CRITERE = "ITMREF<=[M:DIA]ITMREFFIN"               # borne fin   article
   Gosub LOAD_CRITERE2
Endif

If [M:DIA]ENDDATDEB <> [0/0/0]
   CRITERE = "ENDDAT>=[M:DIA]ENDDATDEB"               # borne début date         
   Gosub LOAD_CRITERE2
Endif
If [M:DIA]ENDDATFIN<>[0/0/0]
   CRITERE = "ENDDAT<=[M:DIA]ENDDATFIN"               # borne fin   date
   Gosub LOAD_CRITERE2
Endif

# FQ 43708 Purge des 6=MWS/4=SCS orphelines
If [M:DIA]WOSFLG = 2 
    CRITERE  = "(find(WIPTYP,4,6) & BOMALTTYP=2)"
    Gosub LOAD_CRITERE3
Endif

# FQ 73178 GA 04/2011 ajout des EOS
# Purge des 3=MSS/4=SCS orphelines
If [M:DIA]EOSFLG = 2 
    CRITERE  = "(find(WIPTYP,3,4) & BOMALTTYP=3)"
    Gosub LOAD_CRITERE3
Endif
If len(CRITERE3)>0 CRITERE3 += ")" Endif

Return

############################################################
$LOAD_CRITERE
If len(CRITERE1)=0 
    CRITERE1 += "("
Else 
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE  
Return

############################################################
$LOAD_CRITERE2
# FQ 43708 laisser les criteres dans CRITERE2 pour la 2eme passe
#If len(CRITERE)+len(CRITERE1)+1 < 225
#  CRITERE1 += "&"
#  CRITERE1 += CRITERE  
#Else
If len(CRITERE)+len(CRITERE2(1))+1 < 250
  If CRITERE2(1) <> ""
     CRITERE2(1) += "&"
  Endif
  CRITERE2(1) += CRITERE
Elsif len(CRITERE)+len(CRITERE2(2))+1 < 250
  CRITERE2(2) += "&"
  CRITERE2(2) += CRITERE
Endif
Return

############################################################
$LOAD_CRITERE3
If len(CRITERE3)=0 
    CRITERE3 += "("
Else 
    CRITERE3 += "|"
Endif
CRITERE3 += CRITERE  
Return


#---------------------------------------------------------------------#
# Traitement des ordres                                               #
#---------------------------------------------------------------------#
$TRT_ORD
Raz FORMULE1
# analyse présence formule de sélection
If [M:DIA]FORMULE  = ""
    If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif     
Else
    Read [F:TFO]TFO0=10;[M:DIA]FORMULE
    If fstat 
        If FORMULE1 = "" :  FORMULE1 = "1=1" : Endif 
    Else  
        If FORMULE1 = "" 
            FORMULE1  = [F:TFO]FORFOR                
        Else
            FORMULE1 += "&" 
            FORMULE1 += [F:TFO]FORFOR                
        Endif
    Endif
Endif

If CRITERE2 = "" : CRITERE2 = "1=1" : Endif

Link [ORD] With [ITF]ITF0=[F:ORD]ITMREF;[F:ORD]STOFCY, [ITM]ITM0=[F:ORD]ITMREF As [ORDX] 
&          Where  evalue(CRITERE1) & evalue(CRITERE2) & evalue(FORMULE1)
&          Order By Key ORD0 

# boucle de lecture 
For  [ORDX]
      Gosub TRTSUP
$NXT2
Next 

# FQ 73178 GA 04/2011 ajout des EOS
# FQ 43708 Purge des MWS/SCS orphelines
If ([M:DIA]WOSFLG = 2 | [M:DIA]EOSFLG = 2 ) & CRITERE2<>"1=1" & GOK=1 
   Gosub TRTMWS
Endif

Return

#-----------------------------------------------------------------------#
# Traitement suppression                                                #
#-----------------------------------------------------------------------#
$TRTSUP
Call DEBTRANS From GLOCK
GOK = 1
Gosub MAJSUP
Return

#-----------------------------------------------------------------------#
# Suppression                                                           #
#-----------------------------------------------------------------------#
$MAJSUP
#
WORI = [F:ORD]ORI
If WORI = 0 : WORI = 6 : Endif
WMESS = mess(WORI,298,1)+"/"+mess([F:ORD]WIPTYP,341,1)+mess([F:ORD]WIPSTA,342,1)+":"-[F:ORD]VCRNUM 
&       -[F:ORD]ITMREF-mess(175,197,1)
#
Trbegin [ORD]
    Gosub SUP_SUG
    # traces
    Call ECR_TRACE(WMESS,0) From GESECRAN
    Raz WMESS, WMESS1, WMESS2
    NBORD += 1
Commit
Return

$ROL_TRTSUP
Rollback
Call ROLL From GLOCK
If GROLL 
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Else Goto MAJSUP :ENDIF
Return

$AB_TRTSUP
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

######################################################################### 
# suppression
$SUP_SUG
# FQ 43396 GA 10/2007 performances ajout VCRTYP et remplact du | par 2 boucles
#For [ORD1]ORD3 Where (STOFCY=[F:ORD]STOFCY) & (VCRNUM=[F:ORD]VCRNUM | VCRNUMORI=[F:ORD]VCRNUM)
# FQ 61261 GA 01/2010 ajout & WIPSTA=3 sinon on perd les SOF rattachées à la WOS supprimée
For [ORD1]ORD3 Where STOFCY=[F:ORD]STOFCY & VCRTYP=[F:ORD]VCRTYP & VCRNUM=[F:ORD]VCRNUM & WIPSTA=3
    Readlock [ORD1]  Curr
    If fstat=1 & !GSERVEUR : Goto ROL_TRTSUP : Endif
    If fstat : GOK=0 : Call RSTA("ORD1","ORD0") From GLOCK : Goto AB_TRTSUP : Endif
    If [F:ORD1]WIPTYP = 5 
        Call PUR_LOA_SUG([F:ORD1]STOFCY, [F:ORD1]VCRNUM) From CBNLIBO  
    Endif
    Delete [ORD1]
Next
# FQ 61261 GA 01/2010 ajout & WIPSTA=3 sinon on perd les SOF rattachées à la WOS supprimée
For [ORD1]ORD3 Where STOFCY=[F:ORD]STOFCY & VCRTYP=[F:ORD]VCRTYPORI & VCRNUM=[F:ORD]VCRNUMORI & WIPSTA=3
    Readlock [ORD1]  Curr
    If fstat=1 & !GSERVEUR : Goto ROL_TRTSUP : Endif
    If fstat : GOK=0 : Call RSTA("ORD1","ORD0") From GLOCK : Goto AB_TRTSUP : Endif
    If [F:ORD1]WIPTYP = 5 
        Call PUR_LOA_SUG([F:ORD1]STOFCY, [F:ORD1]VCRNUM) From CBNLIBO  
    Endif
    Delete [ORD1]
Next
# deuxième passe pour les TPS    (10.04 25668)
If [M:DIA]INTFLG <> 2 : Return : Endif
# 03.05 Performances # FQ 61261 GA 01/2010 ajout & WIPSTA=3
For [ORD1]ORD0 Where (WIPTYP=8 & WIPSTA=3) & (ORIFCY=[F:ORD]STOFCY) & (VCRNUM=[F:ORD]VCRNUM | VCRNUMORI=[F:ORD]VCRNUM)
    Readlock [ORD1]  Curr
    If fstat=1 & !GSERVEUR : Goto ROL_TRTSUP : Endif
    If fstat : GOK=0 : Call RSTA("ORD1","ORD0") From GLOCK : Goto AB_TRTSUP : Endif
    Delete [ORD1]
Next
Return

######################################################################### 
# FQ 43708 Purge des MWS/SCS orphelines
#-----------------------------------------------------------------------#
# Boucle de suppression                                                 #
#-----------------------------------------------------------------------#
$TRTMWS
Call DEBTRANS From GLOCK
GOK = 1
Filter [ORD] Where  evalue(CRITERE3) & evalue(CRITERE2) & evalue(FORMULE1)
&            Order By Key ORD0 

# boucle de lecture 
For  [ORD]
     Gosub MAJMWS
$NXT_MWS
Next 
Return

#-----------------------------------------------------------------------#
# Transaction pour les suppressions                                     #
#-----------------------------------------------------------------------#
$MAJMWS
#
WORI = [F:ORD]ORI
If WORI = 0 : WORI = 6 : Endif
WMESS = mess(WORI,298,1)+"/"+mess([F:ORD]WIPTYP,341,1)+mess([F:ORD]WIPSTA,342,1)+":"-[F:ORD]VCRNUM 
&       -[F:ORD]ITMREF-mess(175,197,1)
#
Trbegin [ORD]
    If [F:ORD]WIPTYP=4 : # Cas particulier d'une SCS
       Gosub SUP_SCS
    ##### Else # If find([F:ORD]WIPTYP,6,3) : # Cas d'une MWS ou MSS
    Elsif find([F:ORD]WIPTYP,6,3) : # si et seulement si MWS ou MSS
       Gosub SUP_MWS
    Endif
    # traces
    Call ECR_TRACE(WMESS,0) From GESECRAN
    Raz WMESS, WMESS1, WMESS2
    NBORD += 1
Commit
Return

$ROL_TRTMWS
Rollback
Call ROLL From GLOCK
If GROLL 
     Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Else Goto MAJMWS :ENDIF
Return

$AB_TRTMWS
Rollback
Call ECR_TRACE(mess(17,107,1),1) From GESECRAN
Return

#-----------------------------------------------------------------------#
# suppression
#-----------------------------------------------------------------------#
$SUP_MWS
  Readlock [ORD1]ORD0=[F:ORD]WIPTYP;[F:ORD]WIPNUM;[F:ORD]ITMREF
  If fstat=1 & !GSERVEUR : Goto ROL_TRTMWS : Endif
  If fstat : GOK=0 : Call RSTA("ORD1","ORD0") From GLOCK : Goto AB_TRTMWS : Endif
  Delete [ORD1]
Return

$SUP_SCS
If GMODU(8) = 2 & [F:ORD]BOMALTTYP=2 # ssi sous-traitance d'OF
  For [F:OPS] Where WIPNUM=[F:ORD]WIPNUM & OPESTA=[F:ORD]WIPSTA
      Readlock [OPS] Curr
      If fstat=1 & !GSERVEUR : Goto ROL_TRTMWS : Endif
      If fstat : GOK=0 : Call RSTA("OPS","OPS0") From GLOCK : Goto AB_TRTMWS : Endif
      Delete [OPS]
      For [F:SCH] Where MFGNUM=[F:OPS]MFGNUM & OPENUM=[F:OPS]OPENUM
          Readlock [SCH] Curr
          If fstat=1 & !GSERVEUR : Goto ROL_TRTMWS : Endif
          If fstat : GOK=0 : Call RSTA("SCH","SCH0") From GLOCK : Goto AB_TRTMWS : Endif
          Delete [SCH]
      Next
  Next
Endif
Readlock [ORD1]ORD0=[F:ORD]WIPTYP;[F:ORD]WIPNUM;[F:ORD]ITMREF
If fstat=1 & !GSERVEUR : Goto ROL_TRTMWS : Endif
If fstat : GOK=0 : Call RSTA("ORD1","ORD0") From GLOCK : Goto AB_TRTMWS : Endif
Delete [ORD1]
Return

######################################################################## 
$CHARG_PARAM 
#----- Variables globales stock 
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
If GMODU(8) = 2
    Call GLOBVAR(GFCY)    From WWGLOBGPA
Endif
Return 



#######################################################################
#                     ETIQUETTES                                      #
#######################################################################

########################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> GFCY                   # mm 12.02
    GFCY=VALEUR                     # mm 12.02
    Gosub CHARG_PARAM
Endif                               # mm 12.02
End

########################################
Subprog C_ENDDATFIN(VALEUR)
Variable Date    VALEUR
If VALEUR < [M:DIA]ENDDATDEB : mkstat = 2 : Endif
End


########################################
Subprog AM_ITMREFDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M:DIA]ITMREFFIN = VALEUR : Endif
End

########################################
Subprog C_INTFLG(VALEUR)
Variable Integer VALEUR
If [M:DIA]WOSFLG = 1 & 
&  [M:DIA]EOSFLG = 1 & 
&  [M:DIA]POSFLG = 1 &
&  VALEUR = 1
    mkstat = 2
    GERR = 1 : GMESSAGE = mess(359,199,1) # une case au moins doit être cochée !
Endif
End

########################################
Subprog AS_ORIDEB(VALEUR)
Variable Integer VALEUR
GMENLOC(1)=1
GMENLOC(2)=1
GMENLOC(4)=1
End

########################################
Subprog AS_ORIFIN(VALEUR)
Variable Integer VALEUR
GMENLOC(1)=1
GMENLOC(2)=1
GMENLOC(4)=1
End

########################################
Subprog C_ORIFIN(VALEUR)
Variable Integer VALEUR
If VALEUR < [M:DIA]ORIDEB : mkstat = 2 : Endif
End


##########################################################################
# pour les batchs                                                        #
##########################################################################
Subprog PARAM(DOSSIER,USER,P1,P2,OK) 
#-----------------------------#
# obligatoire pour les batchs #
#-----------------------------#
Value    Char    DOSSIER   : # dossier de lancement
Value    Char    USER      : # utilisateur
Variable Char    P1()(1..) : # on peut avoir 2 fois 50 chaînes de 15 caractères
Variable Char    P2()(1..) 
Variable Integer OK 
 
Gosub OUVRE

Local Char    WIN (GLONFEN)
WIN="DAUTSUG" 
Call PARAM (DOSSIER,USER,P1,P2,OK,TIT,WIN) From CPTTRT

End  
###########################################################################################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
