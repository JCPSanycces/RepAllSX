# Supervisor
## ACLA-CLASSE ## ACODNUM_NBCOMPONENT
# 2018-11-06 07:00:49 723

####################################################################
# AINIT
####################################################################

$AINIT
Gosub DECLARE_VAR From WMC0ACODNUM_NBCOMPONENT
Local Integer ALINE,TBLINE,ASTASNAPSHOT,ALLSTAT
If this.APARENT=null & this.snapshotEnabled=0
 this.snapshotEnabled = 1
Elsif this.APARENT<>null
 this.snapshotEnabled = this.APARENT.snapshotEnabled
Endif
If this.ASTALIN=[V]CST_ALL : this.ASTALIN = [V]CST_ANEW : Endif
Gosub INIT_POSTYP From WMC1ACODNUM_NBCOMPONENT : Gosub TESTALLSTAT
Gosub INIT_POSLNG From WMC1ACODNUM_NBCOMPONENT : Gosub TESTALLSTAT
Gosub INIT_POSCTE From WMC1ACODNUM_NBCOMPONENT : Gosub TESTALLSTAT
Gosub AINIT From WMC0ACODNUM_NBCOMPONENT : Gosub TESTALLSTAT
If this.snapshotEnabled=1 & this.APARENT=null
 [L]ASTASNAPSHOT = this.freeSnapshot
Endif
Return

####################################################################
# _ALOADATTRIBUTE
####################################################################

$_ALOADATTRIBUTE
Gosub DECLARE_VAR From WMC0ACODNUM_NBCOMPONENT
Return

####################################################################
# _ALNKPRO
####################################################################

$_ALNKPRO
Gosub DECLARE_VAR From WMC0ACODNUM_NBCOMPONENT
Return

$TESTALLSTAT
[L]ALLSTAT = max([L]ALLSTAT,[L]ASTATUS)
Return



