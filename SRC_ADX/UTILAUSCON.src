#<AdxTL>@(#)11.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# Mise à jour du flag USRCONXTD à Oui si USRCONNECT=2
#----------------------------------------------------------------------------------------#

Call OUVRE_TRACE("Update AUTILIS USRCONTXD field") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
Gosub MAJAUS
End

#-------------------#
$MAJAUS

# Mise à jour de la table AUTILIS
Call ECR_TRACE(mess(81,125,1)-"AUTILIS:"-time$,0) From GESECRAN

Local File =DOSSIER+".AUTILIS" [AUS]

For [AUS] Where USRCONNECT=2 & [F:AUS]USRCONXTD<>2
 [F:AUS]USRCONXTD = 2
 Rewrite [AUS]
 If fstat : Call ERREUR("AUTILIS"-[F:AUS]USR,2) From DOSDIC : Endif   
Next AUS

Close Local File [AUS]

Return
