#<AdxTL>@(#)0.0.0.0 $Revision$ Inquiry VCI
$ACTION
#    Infbox ACTION
    Case ACTION
        When "OUVRE"       : Gosub OUVRE
        When "LECTURE"     : Gosub LECTURE
        When "AB1_NBLIG"   : Gosub AB1_NBLIG
        When "BB1_NBLIG"   : Gosub BB_NBLIG
        When Default
    Endcase
Return

## Tunnel vers les pièces
$AB1_NBLIG
Gosub SAV_CONSULT From CONSSUB
Call B1_NBLIG From CONSSUB
Return


$BB_NBLIG
 Gosub RST_CONSULT From CONSSUB
Return


######################################################################################
## Section automatically added (screen VCI0) 08/09/2017 10:12:54 (RAFAX)
######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
    # Get the main ledger and the corresponding COA.
    Read [CPY]CPY0 = VALEUR
    If fstat : Call ERREURT(( mess(231,111,1)), 1 ) From GESECRAN : mkstat = 2 : End : Endif

    Read [GCM]GCM0 = [F:CPY]ACM # accounting core model
    If fstat : Call ERREURT( ( mess(198,105,1)), 1 ) From GESECRAN : mkstat = 2 : End : Endif

    Read [LED]LED0 = [GCM]LED( [GCM]GENLEDTYP - 1 ) # ledger
    If fstat : Call ERREURT(( mess(112,106,1)), 1 ) From GESECRAN : mkstat = 2 : End : Endif

    Read [F:COA]COA0 = [LED]COA # COA = chart of accounts
    If fstat : Call ERREURT(( mess(217,111,1)), 1 ) From GESECRAN : mkstat = 2 : End : Endif

    GSOCIETE = VALEUR
    GCURLEG = [F:CPY]LEG
End

######################################################################################
## OPEN TABLES and DECLARE VARIABLES
######################################################################################
$OUVRE

  # Company table. Field ACM, Account core model assigned to the company.
  If !clalev([F:CPY]) : Local File COMPANY[CPY] : Endif
  # Site table.
  If !clalev([F:FCY]) : Local File FACILITY[FCY] : Endif
  # Account core model table. Fields GENLEDTYP, Main general ledger type, and LED, Ledger.
  If !clalev([F:GCM]) : Local File GACM[GCM] : Endif
  # Ledger table. Field LED, Ledger and COA, Chart code.
  If !clalev([F:LED]) : Local File GLED[LED] : Endif
  # Chart of accounts table. Field COA, Chart code.
  If !clalev([F:COA]) : Local File GCOA[COA] : Endif
  # Accounting entries
  If !clalev([F:HAE]) : Local File GACCENTRY[HAE] : Endif
  # Accounting entry lines
  If !clalev([F:DAE]) : Local File GACCENTRYD[DAE] : Endif
  # Accounts
  If !clalev([F:GAC]) : Local File GACCOUNT[GAC] : Endif
  # Document types
  If !clalev([F:GTE]) : Local File GTYPACCENT[GTE] : Endif

  Local Char FIL(255)

Return


$LECTURE

# CPY is mandatory
  If [VCI0]CPY <> ""
    Call SETFILTERSTRINGS(FIL)
        Local Integer COUNT

    Raz [M:VCI1]

    Link [DAE]
&   With [F:CPY]CPY0 = [F:DAE]CPY
&       ,[F:GCM]GCM0 = [F:CPY]ACM
&       ,[F:LED]LED0 = [F:GCM]LED
&       ,[F:COA]COA0 = [F:LED]COA
&       ,[F:HAE]HAE0 = [F:DAE]TYP ; [F:DAE]NUM
&       ,[F:GAC]GAC0 = [F:DAE]COA ; [F:DAE]ACC
&   As [LNKN]
&    Where [F:DAE]TAX <> [F:GAC]VAT(0)
&       and [F:DAE]LEDTYP = [F:GCM]GENLEDTYP
&       and evalue(FIL)

    If rowcount([LNKN]) <> COUNT : COUNT = rowcount([LNKN]) : Endif

    nolign = 0

# loop into the query results
    For [LNKN]
    If nolign >= dim([M:VCI1]SNS)
      Call MESSAGE(func AFNC.MES1(mess(20,3653,1),num$(dim([M:VCI1]SNS)))) From GESECRAN
      Break
    Endif

#mapping data to the grid field by field as it have not the same structure
#line number is necesary in each line or data will not be placed correctly

      [M:VCI1]ACC(nolign) = [F:DAE]ACC
      [M:VCI1]AMTCUR(nolign) = [F:DAE]AMTCUR
      [M:VCI1]CPY(nolign) = [F:DAE]CPY
      [M:VCI1]CUR(nolign) = [F:DAE]CUR
      [M:VCI1]FCY(nolign) = [F:DAE]FCYLIN
      [M:VCI1]LIN(nolign) = [F:DAE]LIN
      [M:VCI1]NUM(nolign) = [F:DAE]NUM
      [M:VCI1]OFFACC(nolign) = [F:DAE]OFFACC
      [M:VCI1]SNS(nolign) = [F:DAE]SNS
      [M:VCI1]TYP(nolign) = [F:DAE]TYP
      [M:VCI1]TAX1(nolign) = [F:DAE]TAX
      [M:VCI1]TAX2(nolign) = [F:GAC]VAT(0)
      [M:VCI1]BPR(nolign) = [F:DAE]BPR
      [M:VCI1]NBLIG=nolign + 1
            nolign+=1
    Next
Endif
Return


######################################################################################
#*  Set the filterstrings for the result screen
#*  @param FIL  Variable Char -> Filter string
######################################################################################
Subprog SETFILTERSTRINGS(FIL)
  Variable Char FIL
  Local Date WDATE
  Raz FIL

# Company
    FIL = "[F:DAE]CPY='" + [M:VCI0]CPY + "'"

# Site
  If [M:VCI0]FCY <> ""
    FIL += " &[F:DAE]FCYLIN = '" + [M:VCI0]FCY + "'"
  Endif

# Entry type
  If [M:VCI0]TYP <> ""
    FIL += " &[F:DAE]TYP = '" + [M:VCI0]TYP + "'"
  Endif

# Document number
  If  [M:VCI0]NUM <> ""
    FIL += " &[F:DAE]NUM >= '" + [M:VCI0]NUM + "'"
  Endif
  If  [M:VCI0]NUM2 <> ""
    FIL += " &[F:DAE]NUM <= '" + [M:VCI0]NUM2 + "'"
  Endif


# Date
  If [M:VCI0]DATE1 <> WDATE
    FIL += " &[F:DAE]ACCDAT >= [M:VCI0]DATE1 "
  Endif
  If [M:VCI0]DATE2 <> WDATE
    FIL += " &[F:DAE]ACCDAT <= [M:VCI0]DATE2 "
  Endif


End

######################################################################################
## Section automatically added (screen VCI0) 09/04/2017 14:48:47 (RAFAX)
######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

Read [FCY]FCY0=VALEUR
If not fstat
If [F:FCY]LEGCPY <>  [M:VCI0]CPY

      Call MESSAGE(func AFNC.MES1(mess(171,104,1),[M:VCI0]CPY)) From GESECRAN
Endif
Endif

End


######################################################################################

######################################################################################
## Section automatically added (screen VCI0) 09/05/2017 13:42:50 (RAFAX)
######################################################################################
Subprog AM_TYP(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
Read [CPY]CPY0=[M:VCI0]CPY
If not fstat
  ## read types with index GTE0 (typ + LEG)
  Read [GTE]GTE0=VALEUR;[F:CPY]LEG
  If fstat
       ## read types with index GTE0 (typ + LEG); empty leg means that the typ is good for any legislation
       Read [GTE]GTE0=VALEUR;""
      If fstat
           Call MESSAGE(mess(126,7778,1)) From GESECRAN
      Endif
  Endif
Endif
Endif



End


######################################################################################

######################################################################################
## Section automatically added (screen CNSVCI0) 09/07/2017 08:21:16 (RAFAX)
######################################################################################

Subprog C_DATE1(VALEUR)
  Variable Date    VALEUR
  Local Date WDATE : Raz WDATE
  If VALEUR <> WDATE : Call C_DATDEB(VALEUR) From CONSSUB : Endif
End

Subprog C_DATE2(VALEUR)
  Variable Date    VALEUR
  Local Date WDATE : Raz WDATE
  If VALEUR <> WDATE : Call C_DATFIN(VALEUR) From CONSSUB : Endif
End

