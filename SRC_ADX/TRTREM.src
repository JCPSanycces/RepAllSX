#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Modification :
#     SEGAY - 11/08/11 - 75605
# TRT TRTANA,TRTREM,TRTSYN,TRTTPS passage de MAXSEM de 8 à 12
#     SEGAY - 11/10/11 - 76639
#       Rajout du point d'entree "MAJCALTPS" qui permet aprés avoir mis à jour
#       les temps avec GTPSW pour le remplissage des trous (TR1) sans évènement,
#       de  vérifier si l'événement GTPSW à un type extraction des temps
#       qui pourrait modifier la DATFIN, et de faire les modifications en conséquence
#     SEGAY - 05/01/12 - 79072
#       Faire commencer DATDEB à la date du contrat si celui est Postérieur à DATDEB
#     MABON - 24/09/13 - FQ92826 - TRT TRTANA,TRTREM,TRTSYN,TRTTPS passage de MAXSEM de 12 à 15
#     FQ93131 - 08/10/13 - Pour affecter les valeurs sur le bon bulletin, il faut ajouter la date du contrat dans le critère de filtre
#     FQ81491 - 12/12/13 - Prise en compte rétroactivité
#     FQ92826 - 14/03/14 - TRT TRTANA,TRTREM,TRTSYN,TRTTPS passage de MAXSEM de 15 à 20
#     FQ99390 - 16/05/14 - Réaffectation de DATFIN sur la date de sortie si celle-ci est à la fin du mois
#     FQ92876 - 20/06/14 - Ajout des axes dans les temps
######################################################################################
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","TRTTPS","TRTTPS",4,"") From GTRAITE
End

# FQ97072 - 27/03/14 - Ajout critère sur la date du contrat
Subprog MAJ_GEN(MATRI,DATPAY,CTR,DETAIL,NUMWEK,CTRDAT_GEN)
Value Char    MATRI
Value Date    DATPAY
Value Char    CTR
Value Integer DETAIL
Value Integer NUMWEK
Value Date    CTRDAT_GEN
Local Char    CRITCTRR (250)

CRITCTRR="1=1"
If CTRDAT_GEN<>[0/0/0] Then
 CRITCTRR -= '& [F:CTRR]CTRDAT=CTRDAT_GEN'
Endif

# FQ97072 - 27/03/14 - Séparation de chaque action
If DETAIL & GTRACE<>""
 #LIPET - 2017-01-18 - START
 #Call ECR_TRACE("-->"-mess(201,709,1)-MATRI-CTR-num$(CTRDAT_GEN),0) From GESECRAN : # Génération automatique
 Call ECR_TRACE("-->"-mess(201,10709,1)-MATRI-CTR-num$(CTRDAT_GEN),0) From GESECRAN : # Génération automatique
 #LIPET - 2017-01-18 - END
Endif

Goto MAJ_TPS


################################################################################
## Remplissage des temps
################################################################################
# 91688 06/08/13 abreviation [CTRR] au lieu de [CTR] pour ne pas avoir de problème de désynchronisation dans boucle for
#MIPEA - 2017-01-25- X3-12033- START
#Subprog MAJ(MATRI,DATPAY,CTR,DETAIL,PERNUM)
Subprog MAJ(MATRI,DATPAY,CTR,DETAIL,NUMWEK)
#MIPEA - 2017-01-25- X3-12033- END
Value Char    MATRI
Value Date    DATPAY
Value Char    CTR
Value Integer DETAIL
#MIPEA - 2017-01-25- X3-12033- START
#Value Integer PERNUM
Value Integer NUMWEK
#MIPEA - 2017-01-25- X3-12033- END

Local Char CRITCTRR (250)
CRITCTRR="1=1"

# FQ97072 - 27/03/14 - Séparation de chaque action
If DETAIL & GTRACE<>""
 #LIPET - 2017-01-18 - START
 #Call ECR_TRACE("-->"-mess(201,709,1)-MATRI-CTR,0) From GESECRAN : # Génération automatique
 Call ECR_TRACE("-->"-mess(201,10709,1)-MATRI-CTR,0) From GESECRAN : # Génération automatique
 #LIPET - 2017-01-18 - END
Endif

$MAJ_TPS
# NUMWEK=0  Génération des temps pour un mois de paie
# NUMWEK<>0 Génération des temps pour une semaine
Local Integer MAXSEM
MAXSEM   = 20

Local Integer I , J , K , T
Local Date    DATDEB , DATFIN , DATFIN_P , DAT , DATMAT, FINMOIS, DATDEB_P : # Bug 79072 05/01/12 Segay
Local Decimal PHEURE(1..7*MAXSEM) , PJOUR(1..7*MAXSEM)
Local Integer PJNUIT(1..7*MAXSEM) , PRE(1..7*MAXSEM)
Local Decimal RHEURE(1..7*MAXSEM) , RJOUR(1..7*MAXSEM)
Local Integer RJNUIT(1..7*MAXSEM) , EVT(1..7*MAXSEM)
Local Decimal HEURES , JOURS
Local Decimal HEURE , JOUR
Local Integer JNUIT
Local Integer MODULATION
Local Integer AXE
Local Date    TABPYRDAT(1..7), TABDAT(1..7)
Local Integer STAT

Local Integer ANNEE , SEMAINE , K , L, INI
Local Char    SEMTYP(GLONSTY)
Local Date    DEBUT , FIN
Local Date    DEBCTR , FINCTR
Local Char    PLNCUR(GLONPLN)
Local Char    PNATACT (GLONNAT)(1..7*MAXSEM)
# FQ92876 - 20/06/14 - Comme GOPTCANA peut être > à 9, on passe maintenant plutôt par un tableau pour éviter de déclarer plus de 20 tableaux
#Local Char    PCCE1 (GLONCCE)(1..7*MAXSEM)
#Local Char    PCCE2 (GLONCCE)(1..7*MAXSEM)
#Local Char    PCCE3 (GLONCCE)(1..7*MAXSEM)
#Local Char    PCCE4 (GLONCCE)(1..7*MAXSEM)
#Local Char    PCCE5 (GLONCCE)(1..7*MAXSEM)
#Local Char    PCCE6 (GLONCCE)(1..7*MAXSEM)
#Local Char    PCCE7 (GLONCCE)(1..7*MAXSEM)
#Local Char    PCCE8 (GLONCCE)(1..7*MAXSEM)
#Local Char    PCCE9 (GLONCCE)(1..7*MAXSEM)
Local Char    PCCE (GLONCCE)(1..max(1,GOPTCANA),1..7*MAXSEM)
# FQ92876 - 20/06/14 - Ajout de l'axe DIE dans les temps
Local Char    PDIE (GLONDIE)(1..max(1,GOPTCANA),1..7*MAXSEM)
Local Integer OK, EXITSAL
Local Char    TIMEVT(GLONTPS)(1..7*MAXSEM)

Local Integer TYPJOU, NUMPLG, MAXPLG
Local Decimal JR(1..2) , HR(1..2), TPSBRK
Local Char HREDEB (GLONHM)
Local Char HREFIN (GLONHM)
Local Char NATACT (GLONNAT)
# FQ92876 - 20/06/14 - Ajout de l'axe DIE
Local Char CCE    (GLONCCE) (1..max(1,GOPTCANA))
Local Char DIE    (GLONDIE) (1..max(1,GOPTCANA))
Local Decimal VALHMDEB, VALHMFIN
Local Date DATDEBCTR

Local Char    SAVGTPSW(30)

Local Date    CTRD
Local Integer OKLOCK
Local Date    CTRDAT_VEP
Local Char    MESSA(250)

Gosub OUVFIC From TRTTPS
# Abreviation [CTRR] au lieu de [CTR] pour ne pas avoir de problème de désynchronisation dans boucle for
If clalev([F:CTRR])=0 : Local File EMPLOCTR [CTRR] : Endif

# FQ82073 - MABON 12/02/13 - La période d'extraction peut varier d'un contrat à l'autre, si contrats successifs.
# Il faut donc traiter contrat par contrat, donc englober la recherche des dates dans la boucle For sur les contrats

## Présence de l'employé
Local Char    CTRETRFCY(GLONFCY),CTRETRSRV(GLONSRV)
#MIPEA - 2017-01-25- X3-12033- START
Local Char    CTRPERCOD(GLONHRPEO)
#MIPEA - 2017-01-25- X3-12033- END
#Local Char CRITCTRR (250)
#CRITCTRR="1=1"
#If dim([M:VEP0]CTRDAT)>0 & [M:VEP0]CTRDAT<>[0/0/0] Then
# CRITCTRR -= '& [F:CTRR]CTRDAT=[M:VEP0]CTRDAT'
#Endif
# Affectation SAVGTPSW déplacée ici sinon risque d'écraser GTPSW en fin de traitement, avec ""
#JOJAC - 2017-04-19 - X3-22982 - START
#MIPEA - 2017-01-25- X3-12033- START
##Getting Travail PARAMETER manually as it is not being set upon entering the system and therefore not setting GTPSW global variable
Local Char PARAM(30)
Global Char     GTPSW(30)           : # Time code for work
Call PARAM(GCURLEG,"TRAVAIL",PARAM) From ADOVAL
GTPSW = PARAM
#MIPEA - 2017-01-25- X3-12033- END
#JOJAC - 2017-04-19 - X3-22982 - END
SAVGTPSW = GTPSW

If clalev([F:CRR2])=0 : Local File EMPLOCTR [CRR2] : Endif
For [CTRR]CTR1 Where REFNUM=MATRI & CTRNUM=CTR
& & evalue(CRITCTRR) # FQ93131 - 02/12/13
#MIPEA - 2017-11-27- US X3-63170- START
Call SET_GFIRDAY([F:CTRR]PERCOD) From SUBHRPEO
#MIPEA - 2017-11-27- US X3-63170- END
  Raz PRE
  #LIPET - 2017-01-18 - START
  #CTRETRFCY=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTRR]CTRDAT,DATPAY,"ETRFCY","CTR")
  CTRETRFCY=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTRR]CTRDAT,DATPAY,"ETRFCY","CTRR")
#MIPEA - 2017-01-25- X3-12033- START
  CTRPERCOD=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTRR]CTRDAT,DATPAY,"PERCOD","CTRR")
#MIPEA - 2017-01-25- X3-12033- END
  #LIPET - 2017-01-18 - END
#  If dim([M]NUMWEK)>0 & dim([M]YEA)>0 Then
#    #LIPET - 2017-01-18 - START
#    Filter [PEO] Where (FCY=CTRETRFCY | FCY="") & find([M]YEA,YEAWEK)<>0  & find([M]NUMWEK,NUMWEK)<>0 Order By FCY Desc
#    STAT = 0
#    For [PEO]
#     I = find([M]NUMWEK,[F:PEO]NUMWEK)
#     If [F:PEO]YEAWEK(I-1)=[M]YEA
#      DATDEB = [F:PEO]PERSTR
#      DATFIN = [F:PEO]PEREND
#      DATPAY = [F:PEO]PYRDAT
#      Break
#     Endif
#    Next
#    Filter [PEO]
#  Else
#    Read [F:PEO]PEO0=CTRETRFCY;DATPAY
#    If fstat Then
#      Read [F:PEO]PEO0="";DATPAY
#    Endif
#
#    I = find(NUMWEK,[F:PEO]NUMWEK)
#    I -=1
#    If NUMWEK=0 or I<0
#     DATDEB = [F:PEO]PERSTR
#     DATFIN = [F:PEO]PEREND
#    Else
#     DATDEB = [F:PEO]PERSTR+(I*7)
#     DATFIN = DATDEB+6
#     Call SEMAINE([F:PEO]YEAWEK(I),NUMWEK,DATDEB,DATFIN) From SUBPLN #Pb 2006,52 ne renvoie pas 26/12/05 01/01/06
#    Endif
#  Endif
#MIPEA - 2017-01-25- X3-12033- START
  If dim([M]NUMWEK)>0 & dim([M]YEA)>0 Then
#  If dim([M]NUMWEK)>0 & dim([M]YEA)>0 Then
#MIPEA - 2017-01-25- X3-12033- END

#MIPEA - 2017-01-25- X3-12033- START
    Filter [HRPEOD] Where (PERCOD=[L]CTRPERCOD) & find([M]YEA,YEAWEK)<>0  & find([M]NUMWEK,NUMWEK)<>0 Order By PERCOD
    STAT = 0
    For [HRPEOD]
     I = find([M]NUMWEK,[F:HRPEOD]NUMWEK)
     If [F:HRPEOD]YEAWEK(I-1)=[M]YEA
      DATDEB = [F:HRPEOD]PERSTR
      DATFIN = [F:HRPEOD]PEREND
      DATPAY = [F:HRPEOD]PYRDAT
      Break
     Endif
    Next
    Filter [HRPEOD]
  Else
    Read [F:HRPEOD]HRPEOD1=[L]CTRPERCOD;DATPAY
    I = find(NUMWEK,[F:HRPEOD]NUMWEK)
    I -=1
    If NUMWEK=0 or I<0
     DATDEB = [F:HRPEOD]PERSTR
     DATFIN = [F:HRPEOD]PEREND
    Else
     DATDEB = [F:HRPEOD]PERSTR+(I*7)
     DATFIN = DATDEB+6
     Call SEMAINE([F:HRPEOD]YEAWEK(I),NUMWEK,DATDEB,DATFIN) From SUBPLN #Pb 2006,52 ne renvoie pas 26/12/05 01/01/06
    Endif
  Endif
#    Filter [HRPEOD] Where (PERCOD=[F:HRCTR]PERCOD) & find([M]YEA,PERYEA)<>0  & find([M]NUMWEK,NUMWEK)<>0 Order By PERCOD
#    STAT = 0
#    For [HRPEOD]
#     I = find([M]NUMWEK,[F:HRPEOD]NUMWEK)
#     If [F:HRPEOD]PERYEA(I-1)=[M]YEA
#      DATDEB = [F:HRPEOD]PERSTR
#      DATFIN = [F:HRPEOD]PEREND
#      DATPAY = [F:HRPEOD]PYRDAT
#      Break
#     Endif
#    Next
#    Filter [HRPEOD]
#  Else
#    Read [F:HRPEOD]HRPEOD1=[F:HRCTR]PERCOD;DATPAY
#    If fstat Then
#      Read [F:HRPEOD]HRPEOD1=[F:HRCTR]PERCOD;DATPAY
#    Endif
#    I = find(NUMWEK,[F:HRPEOD]NUMWEK)
#    I -=1
#    If NUMWEK=0 or I<0
#     DATDEB = [F:HRPEOD]PERSTR
#     DATFIN = [F:HRPEOD]PEREND
#    Else
#     DATDEB = [F:HRPEOD]PERSTR+(I*7)
#     DATFIN = DATDEB+6
#     Call SEMAINE([F:HRPEOD]PERYEA(I),NUMWEK,DATDEB,DATFIN) From SUBPLN #Pb 2006,52 ne renvoie pas 26/12/05 01/01/06
#    Endif
#  Endif
#MIPEA - 2017-01-25- X3-12033- END
  #LIPET - 2017-01-18 - END
  # FQ65062 - 24/10/13 - On vérifie le verrou du bulletin avant de générer les temps
  OKLOCK=1
#MIPEA - 2017-01-25- X3-12033- START
  If GPAYE & NUMWEK=0
#  If GPAYE & NUMWEK=0
#MIPEA - 2017-01-25- X3-12033- END
    # Pour affecter les valeurs sur le bon bulletin, il faut ajouter la date du contrat dans le critère de filtre
    CTRDAT_VEP=[F:CTRR]CTRDAT
    If dim(GNUMBUL)<0 Then Global Char GNUMBUL (GLONVCR) : Endif : # Verrouillé US 2022 65062
    Raz GNUMBUL : # Verrouillé US 2022 65062
    Gosub FILTRE_VEP From TRTTPS
    Filter [VEP] Where EMP=MATRI & PYRDAT=DATPAY & CTRNUM=CTR & evalue(CRITVEP)
    Read [VEP]VEP0 Last
    Filter [VEP]
    If !fstat
#      If dim(GNUMBUL)<0 Then Global Char GNUMBUL (GLONVCR) : Endif
      GNUMBUL=[F:VEP]BUL
      If [F:VEP]FLGLOCK=2 : # Verrouillé US 2022 65062
        OKLOCK=0
        #LIPET - 2017-01-18 - START
        #MESSA =MATRI-"("+mess(6,506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:VEP]CTRDAT)+") :"-[F:VEP]BUL-format$(GFMD,[F:VEP]PYRDAT)-mess(224,703,1)
        MESSA =MATRI-"("+mess(6,10506,1)-CTR-mess(40,101,1)-format$(GFMD,[F:VEP]CTRDAT)+") :"-[F:VEP]BUL-format$(GFMD,[F:VEP]PYRDAT)-mess(224,10703,1)
        #LIPET - 2017-01-18 - END
        If GTRACE<>""
          Call ECR_TRACE(MESSA, 1) From GESECRAN
        Else
          Infbox MESSA
        Endif
      Endif
    Endif
  Endif

  If OKLOCK Then
    CTRD=[F:CTRR]CTRDAT
    DAT = DATDEB
    DATDEBCTR=[F:CTRR]CTRDAT
    If [F:CTRR]FLGRET=2 & [F:CTRR]RETDATEFF<>[0/0/0] Then
     DATDEBCTR=[F:CTRR]RETDATEFF
    Endif
    If DATDEBCTR>[L]DAT Then [L]DAT=DATDEBCTR : Endif

    Call DAT(DAT,ANNEE,SEMAINE) From SUBPLN
    OKPLE=0
    Read [PLE]PLE0=MATRI;DATDEB;CTR
    If fstat
     Gosub SETSEM From SUBPLN
     If PLNCUR=""
      If DETAIL & GTRACE<>""
       #LIPET - 2017-01-18 - START
       # FQ97072 - 27/03/14 - Message plus complet
#       Call ECR_TRACE(MATRI-":"-mess(124,709,1),0) From GESECRAN : # Salarié sans planning
       #Call ECR_TRACE(MATRI-":"-mess(124,709,1)+"."-mess(200,709,1),0) From GESECRAN : # Salarié sans planning. Aucune mise à jour effectuée.
       Call ECR_TRACE(MATRI-":"-mess(124,10709,1)+"."-mess(200,10709,1),0) From GESECRAN : # Salarié sans planning. Aucune mise à jour effectuée.
       #LIPET - 2017-01-18 - END
      Endif
      # On ne sort pas, on passe plutôt au contrat suivant pour générer tout ce qu'on peut
#      End
     Endif
    Else
      OKPLE=1
    Endif
    ###

    # FQ97072 - 27/03/14 - On ne sort pas, on passe plutôt au contrat suivant pour générer tout ce qu'on peut, d'où le test sur PLNCUR
    If OKPLE=1 | PLNCUR<>"" Then
      #LIPET - 2017-01-18 - START
      #MODULATION = (val(func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTRR]CTRDAT,DATPAY,"MODTPS","CTR"))=2)
      MODULATION = (val(func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTRR]CTRDAT,DATPAY,"MODTPS","HRCTR"))=2)
      #LIPET - 2017-01-18 - END

      Call LECTURE("FCY",CTRETRFCY,"") From CONTOBJ
      Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
      #LIPET - 2017-01-18 - START
      #Call LECTURE("TIM",GTPSW,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
       Call LECTURE("HRTIM",GTPSW,GCURLEG) From CONTOBJ
#       Call LECTURE("HRTIM",GTPSW,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
      #LIPET - 2017-01-18 - END

      # Affectation SAVGTPSW déplacée en dehors de cette boucle, sinon risque d'écraser GTPSW en fin de traitement, avec ""
  #    SAVGTPSW = GTPSW

      GPOINT = "MAJW" : Gosub ENTREE From EXEFNC

      #LIPET - 2017-01-18 - START
      #If MODULATION & NUMWEK=0
       #Call MODULATION(DATPAY,DATDEB,DATFIN,MATRI,CTR) From TPSSTD
      #Elsif MODULATION & NUMWEK<>0
#MIPEA - 2017-01-25- X3-12033- START
      If MODULATION & NUMWEK=0
        Call MODULATION(DATPAY,DATDEB,DATFIN,MATRI,CTR) From TPSSTD
      Elsif MODULATION & NUMWEK<>0
#            If MODULATION & NUMWEK=0
#       Call MODULATION(DATPAY,DATDEB,DATFIN,MATRI,CTR) From TPSSTD
#      Elsif MODULATION & NUMWEK<>0
#MIPEA - 2017-01-25- X3-12033- END
      #LIPET - 2017-01-18 - END
       # FQ99390 - 16/05/14 - Réaffectation de DATFIN sur la date de sortie si celle-ci est à la fin du mois (ex : 31/03/14 est un lundi, donc
       # avant DATFIN était égal à 30/03/14)
        If [F:CTRR]XITDAT<>[0/0/0] & dim([M]FMOIS)>0 & [F:CTRR]XITDAT<=[M]FMOIS & DATFIN<[F:CTRR]XITDAT Then DATFIN=[F:CTRR]XITDAT : Endif
       # Fin FQ99390
         DATFIN_P=DATFIN
       # FQ99390 - 16/05/14 - Ajout nouveaux paramètres dans CALC_DATEND
#MIPEA - 2017-01-20- X3-12122- START
        Call CALC_DATEND(CTRETRFCY, DATPAY, [F:CTRR]XITDAT, [F:CTRR]XITFNL, [F:CTRR]CLEEVETIM, DATDEB, DATFIN, FINMOIS, EXITSAL, [F:CTRR]PERCOD) From TRTTPS
#       Call CALC_DATEND(CTRETRFCY, DATPAY, [F:CTRR]XITDAT, [F:CTRR]XITFNL, [F:CTRR]CLEEVETIM, DATDEB, DATFIN, FINMOIS, EXITSAL) From TRTTPS
#MIPEA - 2017-01-20- X3-12122- END
        If DATFIN_P<DATFIN Then DATFIN_P=DATFIN : Endif
           For K=1 To (DATFIN-DATDEB)+1
            TABDAT(K) = DATDEB+K-1
           Next
        Call MAJ_PYRDAT(MATRI,CTR,[F:FCY]FCY,DATPAY,TABDAT,TABPYRDAT,STAT) From TPSJOU
         If STAT=1 : Break : Endif
       Endif
       DATFIN_P=DATFIN
      # FQ99390 - 16/05/14 :
      #     - Réaffectation de DATFIN sur la date de sortie si celle-ci est à la fin du mois (ex : 31/03/14 est un lundi, donc
      # avant DATFIN était égal à 30/03/14)Recalcul de [F:CTR]
      #     - Ajout nouveaux paramètres dans CALC_DATEND
      If [F:CTRR]XITDAT<>[0/0/0] & dim([M]FMOIS)>0 & [F:CTRR]XITDAT<=[M]FMOIS & DATFIN<[F:CTRR]XITDAT Then DATFIN=[F:CTRR]XITDAT : Endif
#MIPEA - 2017-01-20- X3-12122- START
        Call CALC_DATEND(CTRETRFCY, DATPAY, [F:CTRR]XITDAT, [F:CTRR]XITFNL, [F:CTRR]CLEEVETIM, DATDEB, DATFIN, FINMOIS, EXITSAL, [F:CTRR]PERCOD) From TRTTPS
#      Call CALC_DATEND(CTRETRFCY, DATPAY, [F:CTRR]XITDAT, [F:CTRR]XITFNL, [F:CTRR]CLEEVETIM, DATDEB, DATFIN, FINMOIS, EXITSAL) From TRTTPS
#MIPEA - 2017-01-20- X3-12122- END
      # Fin FQ99390
        If DATFIN_P<DATFIN Then DATFIN_P=DATFIN : Endif

          DATDEB_P=DATDEB
          DATDEBCTR=[F:CTRR]CTRDAT
          If [F:CTRR]FLGRET=2 & [F:CTRR]RETDATEFF<>[0/0/0] Then
           DATDEBCTR=[F:CTRR]RETDATEFF
          Endif
      # FQ99390 - 06/06/14 - Si le contrat démarre après la date de début de période, mais qu'un contrat précédent se termine juste avant,
      # il faut créer les temps entre la fin de période et le début du contrat
      Filter [F:CRR2] Where REFNUM=MATRI & CTRNUM=CTR & XITDAT<[F:CTRR]CTRDAT Order By CTRDAT Desc
      Read [F:CRR2] Last
      Local Integer PREVCTR
      PREVCTR=0
      If !fstat and [F:CRR2]XITDAT<>[0/0/0] Then
        If [F:CRR2]XITDAT>=DATDEB & [F:CRR2]CTRDAT<=DATDEB Then PREVCTR=1 : Endif
      Endif
      If DATDEBCTR > DATDEB & DATDEBCTR <= DATFIN_P & !PREVCTR
        DATDEB=max(DATDEB,DATDEBCTR)
      Endif
      ## Lecture du planning
      Call VALORDET(DATDEB,DATFIN_P,MATRI,GTPSW,PJOUR,PHEURE,[F:FCY]FCY,CTR) From SUBPLN

  #    Read [CTRR]CTR0=MATRI;CTR;CTRD # FQ93131 - 02/12/13

      ## Lecture des natures d'activité et sections analytiques pour NUMPLG=0
      For K=1 To (DATFIN-DATDEB)+1
       # FQ92876 - 20/06/14 - Récupération des axes
#       Call JOUR(MATRI,DATDEB+K-1,TYPJOU,JR,HR,JNUIT,[F:FCY]FCY,CTR,NUMPLG,HREDEB,HREFIN,TPSBRK,NATACT,CCE,INI) From SUBPLN    #CHECK IGNORE_LINE
       Call JOUR_AXE(MATRI,DATDEB+K-1,TYPJOU,JR,HR,JNUIT,[F:FCY]FCY,CTR,NUMPLG,HREDEB,HREFIN,TPSBRK,NATACT,CCE,INI,DIE) From SUBPLN    #CHECK IGNORE_LINE
       PNATACT(K)= NATACT
       PJNUIT(K) = JNUIT
       For AXE=1 To GOPTCANA
         # FQ92876 - 20/06/14 - PCCEx remplacés par PCCE() + Ajout de l'axe DIE dans les temps
#         Assign "PCCE"+num$(AXE)+"(K)" With CCE(AXE)
         PCCE(AXE,K)=CCE(AXE)
         PDIE(AXE,K)=DIE(AXE)
       Next
      Next

      # FQ99390 - 06/06/14 - Le max entre DATDEB et DATDEBCTR a déjà été fait avant
#      DATDEBCTR=[F:CTRR]CTRDAT
#      If [F:CTRR]FLGRET=2 & [F:CTRR]RETDATEFF<>[0/0/0] Then
#        DATDEBCTR=[F:CTRR]RETDATEFF
#      Endif
      If [F:CTRR]XITDAT=[0/0/0] & DATDEBCTR<=DATFIN
#        For I=max(DATDEB,DATDEBCTR)-DATDEB+1 To DATFIN-DATDEB+1
        For I=1 To DATFIN-DATDEB+1
          PRE(I) = 1
        Next I
      Elsif [F:CTRR]XITDAT>=DATDEB & DATDEBCTR<=DATFIN
#        For I=max(DATDEB,DATDEBCTR)-DATDEB+1 To min(DATFIN,[F:CTRR]XITDAT)-DATDEB+1
        For I=1 To min(DATFIN,[F:CTRR]XITDAT)-DATDEB+1
          PRE(I) = 1
        Next
      Endif

      ## Lecture du réel
      Raz RHEURE,RJOUR,EVT
      For [TIP]TIP1 Where REFNUM=MATRI & ENDDAT>=DATDEB & STRDAT<=DATFIN & CTRNUM=CTR # & CTRDAT=CTRD
       DAT = max(DATDEB,[F:TIP]STRDAT)
       For K=max(DATDEB,[F:TIP]STRDAT)-DATDEB+1 To min(DATFIN,[F:TIP]ENDDAT)-DATDEB+1
        If [F:TIP]STRDAT=[F:TIP]ENDDAT
         HEURES = [F:TIP]NBRHOU
         JOURS  = [F:TIP]NBRDAY
        Else
         Call VALORIS(DAT,DAT,MATRI,[F:TIP]TIM,JOUR,HEURE,[F:TIP]FCY,[F:TIP]CTRNUM) From SUBPLN
         HEURES = HEURE
         JOURS  = JOUR
        Endif
        EVT(K)     = 1
        RHEURE(K) += HEURES
        RJOUR(K)  += JOURS
        RJNUIT(K)  = [F:TIP]DAYNGT
        TIMEVT(K)  = [F:TIP]TIM
        DAT += 1
       Next K
      Next
      GPOINT = "MAJTPS" : Gosub ENTREE From EXEFNC

      Call DEBTRANS From GLOCK
      Gosub TR1

      Call DEBTRANS From GLOCK
      Gosub TR2

      # FQ93131 - 08/10/13 - Pour un même salarié, avec plusieurs périodes d'activité, on peut avoir plusieurs bulletins avec la même date
      # de paie. Il faut donc déplacer la mise à jour des bulletins à l'intérieur de la boucle sur les contrats.
#MIPEA - 2017-01-25- X3-12033- START
      If GPAYE & GOK & NUMWEK=0
&       & GNUMBUL <> ""
#      If GPAYE & GOK & NUMWEK=0
#&       & GNUMBUL <> "" # FQ93131 - 02/12/13
#MIPEA - 2017-01-25- X3-12033- END
       Call MAJFLGTPS (MATRI,DATPAY,CTR,1,2,[0/0/0]) From SUBVEP
      Endif
    Endif
  Endif
Next

If dim(GNUMBUL)>0 Then Kill GNUMBUL : Endif

GPOINT = "MAJCALTPS" : Gosub ENTREE From EXEFNC

GTPSW = SAVGTPSW
End

## Remplissage pour les jours sans événement
$TR1
GOK = 1
#LIPET - 2017-01-18 - START
#Call LECTURE("TIM",GTPSW,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- START
Call LECTURE("HRTIM",GTPSW,GCURLEG) From CONTOBJ
#Call LECTURE("HRTIM",GTPSW,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
#LIPET - 2017-01-18 - END
Trbegin [TIP]
 K = 1 : MAXPLG=1
 While K<=DATFIN-DATDEB+1
  # Pas d'évènement saisi + heures dans planning +salarié présent
  If !EVT(K) & PHEURE(K)<>0 & PRE(K)
   #Une ligne par plage
   If GNBHOR & [F:TIM]PLGHOR=2
    MAXPLG = GNBHOR
    J = K
   Else
    #Une ligne par semaine et/ou par nature d'activité
    J = K
    JNUIT = PJNUIT(J)
    NATACT = PNATACT (J)
    For AXE=1 To GOPTCANA
     # FQ92876 - 20/06/14 - PCCEx remplacés par PCCE() + Ajout de l'axe DIE dans les temps
#     CCE(AXE) = evalue("PCCE"+num$(AXE)+"("+num$(J)+")")
     CCE(AXE) = PCCE(AXE,J)
     DIE(AXE) = PDIE(AXE,J)
    Next
    While J<DATFIN-DATDEB+1 & !EVT(J+1) & PRE(J+1)
     If PJNUIT(J+1)<>JNUIT
      Break
     Endif
     If PNATACT(J+1)<>NATACT
      Break
     Endif
     For AXE=1 To GOPTCANA
      # FQ92876 - 20/06/14 - PCCEx remplacés par PCCE()
#      If evalue("PCCE"+num$(AXE)+"("+num$(J+1)+")")<>CCE(AXE)
      If PCCE(AXE,J+1)<>CCE(AXE)
       Break 2
      Endif
     Next
     If PHEURE(J+1)=0 : Break : Endif
     J += 1
    Wend
    While PHEURE(J)=0
     J -= 1
    Wend
   Endif
   For NUMPLG=1 To MAXPLG
    If sum(PJOUR(K..J))+sum(PHEURE(K..J))<>0
     Raz [F:TIP]
     [F:TIP]REFNUM = MATRI
     [F:TIP]CTRNUM = CTR
     [F:TIP]CTRDAT = CTRD
     [F:TIP]LIG    = uniqid([TIP])
     [F:TIP]STRDAT = DATDEB+K-1
     [F:TIP]ENDDAT = DATDEB+J-1
     [F:TIP]TIM    = GTPSW
     [F:TIP]NBRDAY = sum(PJOUR(K..J))
     [F:TIP]NBRHOU = sum(PHEURE(K..J))
#MIPEA - 2017-01-25- X3-12033- START
     [F:TIP]CMT    = mess(26,10709,1) : # Génération automatique
#     [F:TIP]CMT    = mess(26,709,1) : # Génération automatique
#MIPEA - 2017-01-25- X3-12033- START
     [F:TIP]AUTFLG = 1
     [F:TIP]STAFLG = GUSER
#MIPEA - 2017-01-25- X3-12033- START
     If MODULATION & NUMWEK<>0
#     If MODULATION & NUMWEK<>0
#MIPEA - 2017-01-25- X3-12033- END
      [F:TIP]DATPYR = TABPYRDAT(K)
     Else
      #LIPET - 2017-01-18 - START
      #[F:TIP]DATPYR = [F:PEO]PYRDAT
      [F:TIP]DATPYR = [F:HRPEOD]PYRDAT
      #LIPET - 2017-01-18 - END
     Endif
     If [F:TIM]TYPDAY=2
      Case dayn([F:TIP]STRDAT)
       When 6,7     : [F:TIP]TYPDAY = 2
       When Default : [F:TIP]TYPDAY = 1
      Endcase
     Endif
     # On a le matricule, le contrat et la date => lecture directe du contrat plutôt qu'une recherche
#MIPEA - 2017-01-25- X3-12033- START
     Read [F:HRCTR]CTR0=MATRI;CTR;CTRD
#     Read [F:CTR]CTR0=MATRI;CTR;CTRD
#MIPEA - 2017-01-25- X3-12033- END
     If !fstat
       #LIPET - 2017-01-18 - START
#      [F:TIP]FCY=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,[F:TIP]DATPYR,"ETRFCY","CTR")
#      Call LECTURE("FCY",[F:TIP]FCY,"") From CONTOBJ
#      [F:TIP]CPY = [F:FCY]LEGCPY
#      [F:TIP]SRV=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,[F:TIP]DATPYR,"ETRSRV","CTR")
      [F:TIP]FCY=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,[F:TIP]DATPYR,"ETRFCY","HRCTR")
      Call LECTURE("FCY",[F:TIP]FCY,"") From CONTOBJ
      [F:TIP]CPY = [F:FCY]LEGCPY
      [F:TIP]SRV=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,[F:TIP]DATPYR,"ETRSRV","HRCTR")
      #LIPET - 2017-01-18 - END
     Endif
     If dim([F:TIP]CREDAT)>0 : [F:TIP]CREDAT = date$ : Endif
     If dim([F:TIP]CREUSR)>0 : [F:TIP]CREUSR = GUSER : Endif
     If dim([F:TIP]CRETIM)>0 : [F:TIP]CRETIM = time  : Endif
     If GNBHOR & [F:TIM]PLGHOR=2
      # FQ92876 - 20/06/14 - Récupération des axes
#      Call JOUR(MATRI,DATDEB+K-1,TYPJOU,JR,HR,JNUIT,[F:FCY]FCY,CTR,NUMPLG,HREDEB,HREFIN,TPSBRK,NATACT,CCE,INI) From SUBPLN  #CHECK IGNORE_LINE
      Call JOUR_AXE(MATRI,DATDEB+K-1,TYPJOU,JR,HR,JNUIT,[F:FCY]FCY,CTR,NUMPLG,HREDEB,HREFIN,TPSBRK,NATACT,CCE,INI,DIE) From SUBPLN  #CHECK IGNORE_LINE
      [F:TIP]STRTIM=HREDEB
      [F:TIP]ENDTIM=HREFIN
      [F:TIP]BRKTIM=TPSBRK
      Call CONVERTHM(HREDEB,VALHMDEB)From SUBSTY
      Call CONVERTHM(HREFIN,VALHMFIN)From SUBSTY
      If VALHMFIN>=VALHMDEB
       [F:TIP]NBRHOU = VALHMFIN-VALHMDEB
      Else
       [F:TIP]NBRHOU = 24-VALHMDEB+VALHMFIN
      Endif
      [F:TIP]NBRHOU -=  TPSBRK
      [F:TIP]NBRHOU  = ar2([F:TIP]NBRHOU)
      # FQ81491 - 12/12/13 - Calcul au réel du nombre d'heures réalisées
      RHEURE(K)+=[F:TIP]NBRHOU
      Call VALORIS([F:TIP]STRDAT,[F:TIP]ENDDAT,MATRI,GTPSW,JR,HR,[F:TIP]FCY,CTR) From SUBPLN
      If HR<>0
       [F:TIP]NBRDAY = ar2([F:TIP]NBRHOU*JR/HR)
      Else
       [F:TIP]NBRDAY = 0
      Endif
     Endif
     If [F:TIP]NBRHOU>0
      [F:TIP]DAYNGT = JNUIT
      # FQ92876 - 26/09/14 - Déplacé ici pour initialiser [F:TIP]NATCOD
      If [F:TIM]NATACT=2
       If NATACT<>""
#MIPEA - 2017-01-25- X3-12033- START
        Call LECTURE("NAT",NATACT,GCURLEG) From CONTOBJ
#        Call LECTURE("NAT",NATACT,"") From CONTOBJ
#MIPEA - 2017-01-25- X3-12033- END
        [F:TIP]NATCOD=[F:NAT]COD
        [F:TIP]DAYNGT=[F:NAT]DAYNGT
        [F:TIP]TYPDAY=[F:NAT]TYPDAY
        [F:TIP]QTY1=[F:NAT]QTY1
        [F:TIP]QTY2=[F:NAT]QTY2
        [F:TIP]FLD1=[F:NAT]FLD1
        [F:TIP]FLD2=[F:NAT]FLD2
       Endif
      Endif
      If INI=1
       Local Char CPY_TIP(GLONCPY) : CPY_TIP=[F:TIP]CPY
       Gosub LISTDIE From TPSSUB
       Local Integer JS : JS=0
       For AXE=1 To GOPTCANA
        If find(DIE(AXE),WLSTDIE(1..WNBRDIE)) Then
          [F:TIP]CCE(JS) = CCE(AXE)
          # FQ92876 - 20/06/14 - Ajout des axes dans les temps
          [F:TIP]DIE(JS) = DIE(AXE)
          JS += 1
        Endif
       Next
      Else
       If [F:ID]REFNUM<>[L]MATRI : Read [ID]ID0=[L]MATRI : Endif
       Gosub INISEC From TPSSUB
       Gosub VERFSEC
      Endif
#      If [F:TIM]NATACT=2
#       If NATACT<>""
#        Call LECTURE("NAT",NATACT,"") From CONTOBJ
#        [F:TIP]NATCOD=[F:NAT]COD
#        [F:TIP]DAYNGT=[F:NAT]DAYNGT
#        [F:TIP]TYPDAY=[F:NAT]TYPDAY
#        [F:TIP]QTY1=[F:NAT]QTY1
#        [F:TIP]QTY2=[F:NAT]QTY2
#        [F:TIP]FLD1=[F:NAT]FLD1
#        [F:TIP]FLD2=[F:NAT]FLD2
#       Endif
#      Endif
    #DEHEN - 2016-10-19 - X3PEOP-2178 - START
    GPOINT = "TR1BEFWRITIP" : Gosub ENTREE From EXEFNC
    #DEHEN - 2016-10-19 - X3PEOP-2178 - END
      Write [TIP]
      If fstat
       GOK = 0 : Call FSTA("TIP") From GLOCK : Break 3
      Endif
     Endif
#MIPEA - 2017-01-25- X3-12033- START
     Filter [HRCTR]
#     Filter [CTR]
#MIPEA - 2017-01-25- X3-12033- END
     #
     # FQ97072 - 01/04/14 - Si plusieurs plages horaires, [F:TIP]NBRHOU ne représente pas la totalité de la journée
     # Il faut donc mettre cette trace à l'intérieur de la boucle NUMPLG
     If DETAIL
      If GTRACE<>"" & [F:TIP]NBRHOU>0
       #LIPET - 2017-01-18 - START
#       Call ECR_TRACE(MATRI-":"-mess(26,709,1)
#&      -format$("D:"+GFMDAT,[F:TIP]STRDAT)-"-"-format$("D:"+GFMDAT,[F:TIP]ENDDAT)
#&       -num$([F:TIP]NBRHOU)-GTPSW,0) From GESECRAN
       Call ECR_TRACE(MATRI-":"-mess(26,10709,1)
&      -format$("D:"+GFMDAT,[F:TIP]STRDAT)-"-"-format$("D:"+GFMDAT,[F:TIP]ENDDAT)
&       -num$([F:TIP]NBRHOU)-GTPSW,0) From GESECRAN
       #LIPET - 2017-01-18 - END
      Endif
     Endif
    Endif
   Next NUMPLG
   For I=K To J
    EVT(I) = 1
    # FQ81491 - 12/12/13 - On ne met RHEURE à PHEURE que si on n'a pas calculé au réel le nombre d'heures réalisées
    If GNBHOR & [F:TIM]PLGHOR=2 Then
    Else
      RHEURE(I) = PHEURE(I)
    Endif
   Next I
   # FQ97072 - 01/04/14 - Si plusieurs plages horaires, [F:TIP]NBRHOU ne représente pas la totalité de la journée
   # Il faut donc mettre cette trace dans la boucle NUMPLG au-dessus
#   If DETAIL
#    If GTRACE<>""
#     Call ECR_TRACE(MATRI-":"-mess(26,709,1)
#&     -format$("D:"+GFMDAT,[F:TIP]STRDAT)-"-"-format$("D:"+GFMDAT,[F:TIP]ENDDAT)
#&     -num$([F:TIP]NBRHOU)-GTPSW,0) From GESECRAN
#    Endif
#   Endif
   K = J+1
  Else
   K += 1
  Endif
 Wend
 If GOK<1 : Goto AB_TR1 : Endif
Commit
Return

$AB_TR1
Rollback
Return

$TR2
GOK = 1
Trbegin [TIP]
 K = 1
 While K<=DATFIN-DATDEB+1
  If RHEURE(K)<PHEURE(K) & PRE(K)
   OK = 1
   If MODULATION & EVT(K)=1
#MIPEA - 2017-01-25- X3-12033- START
    Read [TIM]TIM0=GCURLEG;TIMEVT(K)
#    Read [TIM]TIM0=TIMEVT(K)
#MIPEA - 2017-01-25- X3-12033- END
    If fstat | [F:TIM]CATTIM=1
     OK = 0
    Endif
   Endif
   If OK=1
    Raz [F:TIP]
    [F:TIP]REFNUM = MATRI
    [F:TIP]CTRNUM = CTR
    [F:TIP]CTRDAT = CTRD
    [F:TIP]LIG    = uniqid([TIP])
    [F:TIP]STRDAT = DATDEB+K-1
    [F:TIP]ENDDAT = DATDEB+K-1
    [F:TIP]TIM    = GTPSW
    [F:TIP]DAYNGT = PJNUIT(K)
    [F:TIP]NBRHOU = PHEURE(K)-RHEURE(K)
    If PHEURE(K)<>0
     [F:TIP]NBRDAY = ar2(min(PJOUR(K),PJOUR(K)*[F:TIP]NBRHOU/PHEURE(K)))
    Else
     [F:TIP]NBRDAY = 0
    Endif
    #LIPET - 2017-01-18 - START
    #[F:TIP]CMT    = mess(26,709,1) : # Génération automatique
    [F:TIP]CMT    = mess(26,10709,1) : # Génération automatique
    #LIPET - 2017-01-18 - END
    If dim([F:TIP]CREDAT)>0 : [F:TIP]CREDAT = date$ : Endif
    If dim([F:TIP]CREUSR)>0 : [F:TIP]CREUSR = GUSER : Endif
    If dim([F:TIP]CRETIM)>0 : [F:TIP]CRETIM = time  : Endif
    # On a le matricule, le contrat et la date => lecture directe du contrat plutôt qu'une recherche
    #LIPET - 2017-01-18 - START
    #Read [F:CTR]CTR0=MATRI;CTR;CTRD
    Read [F:HRCTR]CTR0=MATRI;CTR;CTRD
    #LIPET - 2017-01-18 - END
    If [F:ID]REFNUM<>[L]MATRI : Read [ID]ID0=[L]MATRI : Endif
    Gosub INISEC From TPSSUB
    Gosub VERFSEC
    #LIPET - 2017-01-18 - START
#    [F:TIP]AUTFLG = 1
#    [F:TIP]STAFLG = GUSER
#    [F:TIP]DATPYR = [F:PEO]PYRDAT
#    [F:TIP]FCY=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,[F:TIP]DATPYR,"ETRFCY","CTR")
#    Call LECTURE("FCY",[F:TIP]FCY,"") From CONTOBJ
#    [F:TIP]CPY = [F:FCY]LEGCPY
#    [F:TIP]SRV=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:CTR]CTRDAT,[F:TIP]DATPYR,"ETRSRV","CTR")
#    Filter [CTR]
    [F:TIP]AUTFLG = 1
    [F:TIP]STAFLG = GUSER
    [F:TIP]DATPYR = [F:HRPEOD]PYRDAT
    [F:TIP]FCY=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,[F:TIP]DATPYR,"ETRFCY","HRCTR")
    Call LECTURE("FCY",[F:TIP]FCY,"") From CONTOBJ
    [F:TIP]CPY = [F:FCY]LEGCPY
    [F:TIP]SRV=func SUBCTRRET.FIND_RETRO_FLD(MATRI,CTR,[F:HRCTR]CTRDAT,[F:TIP]DATPYR,"ETRSRV","HRCTR")
    Filter [HRCTR]
    #LIPET - 2017-01-18 - END
    #
    #DEHEN - 2016-10-19 - X3PEOP-2178 - START
    GPOINT = "TR2BEFWRITIP" : Gosub ENTREE From EXEFNC
    #DEHEN - 2016-10-19 - X3PEOP-2178 - END
    Write [TIP]
    If fstat
     GOK = 0 : Call FSTA("TIP") From GLOCK : Break
    Endif
    If DETAIL
     If GTRACE<>""
      #LIPET - 2017-01-18 - START
#      Call ECR_TRACE(MATRI-":"-mess(26,709,1)
#&     -format$("D:"+GFMDAT,[F:TIP]STRDAT)-"-"-num$([F:TIP]NBRHOU)-GTPSW,0) From GESECRAN
      Call ECR_TRACE(MATRI-":"-mess(26,10709,1)
&     -format$("D:"+GFMDAT,[F:TIP]STRDAT)-"-"-num$([F:TIP]NBRHOU)-GTPSW,0) From GESECRAN
      #LIPET - 2017-01-18 - END
     Endif
    Endif
   Endif
  Endif
  K += 1
 Wend
 If GOK<1 : Goto AB_TR2 : Endif
Commit
Return

$AB_TR2
Rollback
Return

$VERFSEC
For AXE=1 To GOPTCANA
 mkstat = 0
 Call CONTCCE([F:TIP]CCE(AXE-1),AXE,[F:TIP]FCY,[F:TIP]STRDAT,[F:TIP]TIM,"",0) From TPSSTD
 If mkstat
  [F:TIP]CCE(AXE-1) = ""
  # FQ92876 - 20/06/14 - Ajout de l'axe DIE dans les temps
  [F:TIP]DIE(AXE-1) = ""
 Endif
Next AXE
Return

