$PSH_PSD_ITMREF_CONTROL
  Local Char WMESSAGE (250)
  If func TRTACHCTL1_SYRA.C_ITMREF(this.ITMREF, this.PSHFCY, WMESSAGE)=[V]CST_AERROR
    [L]ASTATUS=fmet this.ASETERROR("ITMREF",WMESSAGE,[V]CST_AERROR)
  Endif
Return

$PSH_PSD_ITMREF_PROPAGATE
  Local File ITMFACILIT [ITF]

  If this.PSHFCY <> AVOID.ACHAR
    Read [ITF]ITF0 = this.ITMREF;this.PSHFCY
    If fstat = 0 & [F:ITF]OFS <> 0
      this.OFS = [F:ITF]OFS
      # Planned Order Date
      If this.EXTRCPDAT <> AVOID.ADATE & this.EXTORDDAT = AVOID.ADATE
        this.EXTORDDAT =this.EXTRCPDAT-this.OFS
      Endif
    Endif
  Endif

  If this.BPSNUM=AVOID.ACHAR
    WRET = fmet this._MET_INIBPSNUM()
  Endif

  If this.BPSNUM<>""
    #lecture BPR
    Local File BPARTNER[BPR]
    Read [BPR] BPR0=this.BPSNUM
    If fstat Raz [F:BPR] : Endif
    If [F:BPR]LAN="" : [F:BPR]LAN=this.ACTX.LAN : Endif
    If this.ITMDES = AVOID.ACHAR
      Call CHARGE_DEFITMDES("DES1AXX",[F:BPR]LAN,this.ITMREF,this.ITMDES, "[F:ITM]") From TRTX3_SYRA
    Endif
    # Load VAT
    WRET = fmet this._MET_LOADVAT()
    If WRET <> [V]CST_AOK : Return : Endif
    #Pas implémenté pour le moment Load Price
    #WRET = fmet this._MET_DIVPSHITM()
  Else
    If this.ITMDES = AVOID.ACHAR
      Call CHARGE_DEFITMDES("DES1AXX",this.ACTX.LAN,this.ITMREF,this.ITMDES, "[F:ITM]") From TRTX3_SYRA
    Endif
  Endif

  If this.ITMDES1 = AVOID.ACHAR
    Call CHARGE_DEFITMDES("DES1AXX",this.ACTX.LAN,this.ITMREF,this.ITMDES1, "[F:ITM]") From TRTX3
  Endif

  #l'article fait partie d'une commande ouverte
  Local File PORDERC[POC]
  Filter [POC] Where ITMREF=this.ITMREF & STRDAT<=date$ & ENDDAT>=date$
  Look [POC] POC2 First
  Filter [POC]
  If fstat=0
    [L]ASTATUS=fmet this.ASETERROR("ITMREF",mess(1,194,1),[V]CST_AINFO)
  Endif
Return

$PSH_PSD_BPSNUM_PROPAGATE
  Local Char WITMDES(30)
  Local File ITMMASTER[ITM]
  Local File ITMBPS[ITP]
  Local   Decimal  WQTY, WCOEUOM, QTEUA
  Local   Char     WUOM(GLONUOM)
  Local   Char     WPUU(GLONUOM)
  #rechargement de la désignation si le fournisseur
  If this.ITMREF<>""
    #lecture BPR
    Local File BPARTNER[BPR]
    Read [BPR] BPR0=this.BPSNUM
    If fstat Raz [F:BPR] : Endif
    If [F:BPR]LAN="" : [F:BPR]LAN=this.ACTX.LAN : Endif
    Call CHARGE_DEFITMDES("DES1AXX",[F:BPR]LAN,this.ITMREF,WITMDES, "[F:ITM]") From TRTX3_SYRA
    If this.ITMDES <> WITMDES
      this.ITMDES = WITMDES
    Endif
  Endif
  If this.ITMREF <> ""
    #----- Lecture ITMMASTER si nécessaire -----#
    If [F:ITM]ITMREF<>this.ITMREF
      Read [ITM] ITM0=this.ITMREF
      If fstat
        [L]ASTATUS = fmet this.ASETERROR([L]CURPRO, mess(23,100,1), [V]CST_AERROR)
        Return
      Endif
    Endif
    WRET = fmet this._MET_LOADVAT()
    #----- Vérification couple article-fournisseur -----#
    Read [ITP] ITP0=this.ITMREF;this.BPSNUM :
    If fstat  WPUU = [F:ITM]PUU : Else WPUU = [F:ITP]PUU : Endif
    If !find(this.PUU,[F:ITM]PCU(0..dim([F:ITM]PCU)-1)) & this.PUU<>[F:ITP]PCU
       WUOM=WPUU
    Else
      WUOM=this.PUU
    Endif

    #----- Conversion quantité dans la nouvelle unité -----#
    If this.QTYPUU <> 0
      If WUOM=this.PUU
        #----- Conversion à partir de L'UA -----#
        Call PCAL_QTY(this.QTYPUU,this.PUU,WQTY,[F:ITM]STU,this.ITMREF,this.BPSNUM,1,WCOEUOM) From TRTACHQTE1_SYRA
        If WQTY<>this.QTYSTU
          this.QTYSTU=WQTY
          WQTY=this.QTYPUU : this.QTYPUU+=1 : # Pour provoquer une différence
        Else
          WQTY=this.QTYPUU
        Endif
      Else
        #----- Conversion à partir de l'US -----#
        Call PCAL_QTY(this.QTYSTU,this.STU,WQTY,WUOM,this.ITMREF,this.BPSNUM,1,WCOEUOM) From TRTACHQTE1_SYRA
        WPUU=this.PUU : # Sauvegarde PUU de l'écran
        #-----
  # PE : Comment ça marche maintenant ?
       this.PUU=WUOM : QTEUA=WQTY  #Gosub POINT_PURQTYRND From SUBPOHB
        #----- Si quantité en UA modifiée, il faut recalculer la quantité en US -----#
        If WQTY<>QTEUA | (this.QTYSTU*WCOEUOM)<>QTEUA
           WQTY=QTEUA
           Call PCAL_QTY(WQTY,WUOM,this.QTYSTU,this.STU,this.ITMREF,this.BPSNUM,1,WCOEUOM) From TRTACHQTE1_SYRA
        Endif
        #-----
        this.PUU=WPUU : # Restitution PUU de l'écran
      Endif
      #----- Réajustement des unités et des quantités si nécessaire -----#
      If WUOM<>this.PUU | WQTY<>this.QTYPUU
        this.PUU   =WUOM
        this.QTYPUU=WQTY
        #----- Conversion qté consommée dans la nouvelle unité à partir de l'US -----#
        If this.WQTYORDPUU<>0 | this.WQTYORDSTU
          Call PCAL_QTY(this.WQTYORDSTU,this.STU,this.WQTYORDPUU,this.PUU,this.ITMREF,this.BPSNUM,1,WCOEUOM) From TRTACHQTE1_SYRA
        Endif
      Endif
    Endif
    #-----
  Endif
Return

$PSH_PSD_EXTRCPDAT_CONTROL
  Local Char WMESSAGE(250)
  Local File FACILITY[FCY]

  Read [FCY]FCY0=this.PSHFCY
  #Controle date hors période indisponibilité + décalage de la date si besoin
  If func CONTX3_SYRA.CTL_JOU2(this.EXTRCPDAT,this.EXTRCPDAT,[F:FCY]UVYDAY,this.PSHFCY,1,WMESSAGE)=[V]CST_AERROR
    [L]ASTATUS = fmet this.ASETERROR ("EXTRCPDAT", WMESSAGE, [V]CST_AERROR)
    Return
  Endif
Return

$PSH_PSD_EXTORDDAT_CONTROL
  Local Char WMESSAGE(250)
  #controle sur la date théorique de demande qui doit être hors de la période d'indisponibilté du fournisseur
  If this.EXTORDDAT <> AVOID.ADATE & this.BPSNUM<>AVOID.ACHAR
    If func CONTX3_SYRA.CTL_PER(this.EXTORDDAT,this.BPSNUM,2,WMESSAGE) = [V]CST_AERROR
        [L]ASTATUS = fmet this.ASETERROR ("EXTORDDAT", WMESSAGE, [V]CST_AERROR)
        Return
    Endif
  Endif
Return


$PSH_PSD_NETPRI_PROPAGATE
  #Le prix a été saisi, mise à jour du flag pour lancer la recherche tarif
  #this.PSH.PSD.PRIFLG = 2
  this.PRIFLG = 2
Return

$PSH_PSD_QTYPUU_PROPAGATE
  Local   Decimal  WQTY, WCOEUOM, QTEUA
  Local   Char     WUOM(GLONUOM)
  Local   Char     WPUU(GLONUOM)
  Local File ITMMASTER[ITM]
  #----- Vérification couple article-fournisseur -----#
  If this.BPSNUM <> AVOID.ACHAR & this.ITMREF<>AVOID.ACHAR
   #----- Lecture ITMMASTER si nécessaire -----#
    If [F:ITM]ITMREF<>this.ITMREF
      Read [ITM] ITM0=this.ITMREF
      If fstat
        [L]ASTATUS = fmet this.ASETERROR([L]CURPRO, mess(23,100,1), [V]CST_AERROR)
        Return
      Endif
    Endif
    #Lecture de ITMBPS
    Local File ITMBPS[ITP]
    Read [ITP] ITP0=this.ITMREF;this.BPSNUM :
    If fstat  WPUU = [F:ITM]PUU : Else WPUU = [F:ITP]PUU : Endif
    If !find(this.PUU,[F:ITM]PCU(0..dim([F:ITM]PCU)-1)) & this.PUU<>[F:ITP]PCU
       WUOM=WPUU
    Else
      WUOM=this.PUU
    Endif

    #----- Conversion quantité dans la nouvelle unité -----#
    If this.QTYPUU <> 0
      If WUOM=this.PUU
        #----- Conversion à partir de L'UA -----#
        Call PCAL_QTY(this.QTYPUU,this.PUU,WQTY,[F:ITM]STU,this.ITMREF,this.BPSNUM,1,WCOEUOM) From TRTACHQTE1_SYRA
        If WQTY<>this.QTYSTU
          this.QTYSTU=WQTY
          WQTY=this.QTYPUU : this.QTYPUU+=1 : # Pour provoquer une différence
        Else
          WQTY=this.QTYPUU
        Endif
      Else
        #----- Conversion à partir de l'US -----#
        Call PCAL_QTY(this.QTYSTU,this.STU,WQTY,WUOM,this.ITMREF,this.BPSNUM,1,WCOEUOM) From TRTACHQTE1_SYRA
        WPUU=this.PUU : # Sauvegarde PUU de l'écran
        #-----
        # PE : Comment ça marche maintenant ?
        this.PUU=WUOM : QTEUA=WQTY #Gosub POINT_PURQTYRND From SUBPOHB
        #----- Si quantité en UA modifiée, il faut recalculer la quantité en US -----#
        If WQTY<>QTEUA | (this.QTYSTU*WCOEUOM)<>QTEUA
           WQTY=QTEUA
           Call PCAL_QTY(WQTY,WUOM,this.QTYSTU,this.STU,this.ITMREF,this.BPSNUM,1,WCOEUOM) From TRTACHQTE1_SYRA
        Endif
        #-----
        this.PUU=WPUU : # Restitution PUU de l'écran
      Endif
      #----- Réajustement des unités et des quantités si nécessaire -----#
      If WUOM<>this.PUU | WQTY<>this.QTYPUU
        this.PUU   =WUOM
        this.QTYPUU=WQTY
        #----- Conversion qté consommée dans la nouvelle unité à partir de l'US -----#
        If this.WQTYORDPUU<>0 | this.WQTYORDSTU
          Call PCAL_QTY(this.WQTYORDSTU,this.STU,this.WQTYORDPUU,this.PUU,this.ITMREF,this.BPSNUM,1,WCOEUOM) From TRTACHQTE1_SYRA
        Endif
      Endif
    Endif
    #-----
  Endif
Return

