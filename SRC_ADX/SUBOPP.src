##########################################################################################################
Subprog IB_OPPORITXT

  Raz GBOUT1
  If [M:OPP1]OPPORITYP <> 4 Then
    If varmode([M:OPP1]OPPORITXT, 0) = 0 Then
      Raz GBOUT2
    Else
      Raz GBOUT2
      Raz GBOUTS
      GBOUT2 = mess(257,177,1)
    Endif
  Else
    Raz GBOUT2
    Raz GBOUTS
  Endif
End

##########################################################################################################
Subprog AM_OPPORITXT(VALEUR)
Variable Char    VALEUR()

Local Char SZOPPORIOBC(GLONAOB)

  # Définition du type de pièce
  If VALEUR = AVOID.ACHAR Then
    [M:OPP1]OPPORI = 1
  Endif
  If [M:OPP1]OPPORI = 1 and VALEUR <> AVOID.ACHAR Then
    VALEUR = AVOID.ACHAR
  Endif
  # ------------------------
  GZINSOPP.OPPORI = [M:OPP1]OPPORI
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSOPP) From SUBOPPA
  If GERR = 1 Then
    GZINSOPP.OPPORI = GZINSOPP.snapshot.OPPORI
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_OPPOR_HEADER() From SUBOPPA
  Endif
  # ------------------------
  SZOPPORIOBC = [M:OPP1]OPPORIOBC
  Gosub DEFOBJORI From SUBOPPB
  If SZOPPORIOBC <> [M:OPP1]OPPORIOBC Then
    Raz [M:OPP1]OPPORIVCR
    Raz [M:OPP1]OPPCMGNUM
    Raz [M:OPP1]OPPOPGTYP
    Raz [M:OPP1]OPPOPGNUM
    Raz [M:OPP1]OPPORIVCRD
    Affzo [M:OPP1]1-99
  Endif
End

##########################################################################################################
Subprog B2_OPPORITXT(VALEUR)
Variable Char    VALEUR()

  Actzo [M:OPP1]OPPORITXT
  Actzo [M:OPP1]OPPORIVCR
  mkstat = 4
End

##########################################################################################################
Subprog IB_OPPORIVCR

  Raz GBOUT1
  If [M:OPP1]OPPORITYP <> 4 Then
    If varmode([M:OPP1]OPPORIVCR, 0) <> 0 Then
      Raz GBOUTS
      Raz GBOUT2
      GBOUT2 = mess(257,177,1)
    Else
      Raz GBOUT2
    Endif
  Else
    Raz GBOUTS
    Raz GBOUT2
  Endif
  If [M:OPP1]OPPORIOBC  <> AVOID.ACHAR and [M:OPP1]OPPORIVCR <> AVOID.ACHAR Then
    GBOUT1 = mess(103,182,1)  # Détail pièce
  Endif
End

##########################################################################################################
Subprog B2_OPPORIVCR(VALEUR)
Variable Char    VALEUR()

  Actzo [M:OPP1]OPPORITXT
  Actzo [M:OPP1]OPPORIVCR
  mkstat = 4
End

##########################################################################################################
Subprog C_OPPORIVCR(VALEUR)
Variable Char    VALEUR()

Local Char SZMESSAGE(250)
Local Integer IBRETOUR

  If [M:OPP1]OPPORIOBC = AVOID.ACHAR Then
    If VALEUR <> AVOID.ACHAR Then
      GMESSAGE = mess(526,177,1)
      mkstat = 1
      End
    Endif
  Endif
  If VALEUR <> AVOID.ACHAR and [M:OPP1]OPPORIOBC <> AVOID.ACHAR Then
    Call VERIFOBJCODE([M:OPP1]OPPORIOBC, [M:OPP0]SALFCY, VALEUR, SZMESSAGE, IBRETOUR) From CRMUTIL150
    If IBRETOUR = 0 Then
      GMESSAGE = SZMESSAGE
      mkstat = 1
      End
    Endif
  Endif
End

##########################################################################################################
Subprog AM_OPPORIVCR(VALEUR)
Variable Char    VALEUR()

Local Char SZMESSAGE(250)
Local Integer IBRETOUR
Local Char SZCMGNUM(GLONVCR)

  If VALEUR <> AVOID.ACHAR and [M:OPP1]OPPORIOBC <> AVOID.ACHAR Then
    Call GETCMG_OBJCODE(AVOID.ACHAR, [M:OPP1]OPPORIOBC, VALEUR, SZCMGNUM, SZMESSAGE, IBRETOUR) From CRMUTIL150
    If IBRETOUR = 0 Then
      GMESSAGE = SZMESSAGE
      mkstat = 1
      End
    Endif
    [M:OPP1]OPPCMGNUM = SZCMGNUM
    [M:OPP1]OPPOPGTYP = [M:OPP1]OPPORIOBC
    [M:OPP1]OPPOPGNUM = VALEUR
    # ------------------------
    # Issue X3-67702 - 2018-03-21 by FGR : BEGIN
    GZINSOPP.OPPOPGTYP = [M:OPP1]OPPORIOBC
    GZINSOPP.OPPORIVCR = VALEUR
    GZINSOPP.OPPOPGNUM = VALEUR
    GZINSOPP.OPPCMGNUM = SZCMGNUM
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSOPP) From SUBOPPA
    If GERR = 1 Then
      GZINSOPP.OPPCMGNUM = GZINSOPP.snapshot.OPPCMGNUM
      GERR = 1
      mkstat = 2
      End
    Else
      Call SHOW_OPPOR_HEADER() From SUBOPPA
    Endif
    # Issue X3-67702 - 2018-03-21 by FGR : END
    # ------------------------
  Else
    # Issue X3-67702 - 2018-03-21 by FGR : BEGIN
    Raz GZINSOPP.OPPCMGNUM
    Raz GZINSOPP.OPPOPGTYP
    Raz GZINSOPP.OPPOPGNUM
    Raz GZINSOPP.OPPORIVCR
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSOPP) From SUBOPPA
    If GERR = 1 Then
      GZINSOPP.OPPOPGNUM = GZINSOPP.snapshot.OPPOPGNUM
      GERR = 1
      mkstat = 2
      End
    Else
      Call SHOW_OPPOR_HEADER() From SUBOPPA
    Endif
    # Issue X3-67702 - 2018-03-21 by FGR : END
  Endif
End

##########################################################################################################
##########################################################################################################
# OPP2
##########################################################################################################
Subprog C_NBOPP2

  If status = 82 or status = 73 Then
    # Insert line
    If [M:OPP2]CPP(nolign-1) = AVOID.ACHAR Then
      ILINE = fmet GZINSOPP.ADDLINE("CPP", [V]CST_ALASTPOS)
      If ILINE <> [V]CST_ANOTDEFINED Then
        Call SHOW_OPPOR_OPP2(ILINE) From SUBOPPA
      Else
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSOPP)
        GERR = 4
        mkstat = 2
        GOK = 1
        End
      Endif
      Affzo [M:OPP2]5
    Endif
  Elsif status = 65 Then
    # Delete a line
    IRET = fmet GZINSOPP.ADELLINE("CPP", GZINSOPP.CPP([M:OPP2]COLLIN(nolign-1)).AORDER)
    If IRET = [V]CST_ANOTDEFINED Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSOPP)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

