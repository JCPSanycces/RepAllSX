##########################################################################################################
Subprog IB_OPPMCN

  Filter [AIN]
  If [M:OPP0]OPPCMP = AVOID.ACHAR Then
    Raz GBOUT2
  Endif
End

##########################################################################################################
Subprog AM_OPPMCN(VALEUR)
Variable Char    VALEUR()

  GZINSOPP.OPPMCN = VALEUR
