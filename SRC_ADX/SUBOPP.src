    GZINSOPP.OPPREP = GZINSOPP.snapshot.OPPREP
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_OPPOR_HEADER() From SUBOPPA
  Endif
  # ------------------------
  Call SETAFFVALCUR([M:OPP0]CUR) From SUBOPPB
End

