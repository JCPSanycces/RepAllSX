##########################################################################################################
##########################################################################################################
# OPP4
##########################################################################################################
Subprog C_NBOPP4

  If status = 82 or status = 73 Then
    # Insert line
    If [M:OPP4]ENDDATX(nolign-1) = [0/0/0] Then
      ILINE = fmet GZINSOPP.CRM(1).ADDLINE("STPSTA", [V]CST_ALASTPOS)
      If ILINE <> [V]CST_ANOTDEFINED Then
        Call SHOW_OPPOR_OPP4(ILINE) From SUBOPPA
      Else
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSOPP)
        GERR = 4
        mkstat = 2
        GOK = 1
        End
      Endif
      Affzo [M:OPP4]5
    Endif
  Elsif status = 65 Then
    # Delete a line
    IRET = fmet GZINSOPP.CRM(1).ADELLINE("STPSTA", GZINSOPP.CRM(1).STPSTA([M:OPP4]COLLIN(nolign-1)).AORDER)
    If IRET = [V]CST_ANOTDEFINED Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSOPP)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

