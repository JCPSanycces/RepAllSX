##########################################################################################################
##########################################################################################################
# OPP5
##########################################################################################################
Subprog C_NBOPP5

  If status = 82 or status = 73 Then
    # Insert line
    If [M:OPP5]SBBPJT(nolign-1) = AVOID.ACHAR Then
      ILINE = fmet GZINSOPP.ADDLINE("SBB", [V]CST_ALASTPOS)
      If ILINE <> [V]CST_ANOTDEFINED Then
        Call SHOW_OPPOR_OPP5(ILINE) From SUBOPPA
      Else
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSOPP)
        GERR = 4
        mkstat = 2
        GOK = 1
        End
      Endif
      Affzo [M:OPP5]5
    Endif
  Elsif status = 65 Then
    # Delete a line
    IRET = fmet GZINSOPP.ADELLINE("SBB", GZINSOPP.SBB([M:OPP5]COLLIN(nolign-1)).AORDER)
    If IRET = [V]CST_ANOTDEFINED Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSOPP)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

