##########################################################################################################
##########################################################################################################
# OPP1
##########################################################################################################
Subprog IB_OPPREP
  Raz GBOUT3
  If [M:OPP0]OPPCMP <> AVOID.ACHAR Then
    Read [BPC]BPC0=[M:OPP0]OPPCMP
    If !fstat Then
      # Représentants secondaires
      Call TEXTE(15800, GBOUT3) From OBJDIV
    Endif
  Endif
End

##########################################################################################################
Subprog AM_OPPREP(VALEUR)
