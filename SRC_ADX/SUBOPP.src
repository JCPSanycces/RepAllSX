##########################################################################################################
##########################################################################################################
# OPP3
##########################################################################################################
Subprog IB_NBOPP3

  If [M:OPP3]STEORIVCR(nolign-1) = AVOID.ACHAR or [M:OPP3]STEORIAOB(nolign-1) = AVOID.ACHAR Then
    Raz GBOUT1
  Else
    Case [M:OPP3]STEORIAOB(nolign-1)
      When "CLL"
        GBOUT1 = mess(3,967,1)
      When "BAP"
        GBOUT1 = mess(2,967,1)
      When "SQH"
        GBOUT1 = mess(121,198,1)
      When "SOH"
        GBOUT1 = mess(191,198,1)
      When Default
        Raz GBOUT1
    Endcase
  Endif
End

##########################################################################################################
Subprog C_NBOPP3

  If status = 82 or status = 73 Then
    # Insert line
    If [M:OPP3]ENDDAT(nolign-1) = [0/0/0] Then
      ILINE = fmet GZINSOPP.CRM(1).ADDLINE("STPSTB", [V]CST_ALASTPOS)
      If ILINE <> [V]CST_ANOTDEFINED Then
        Call SHOW_OPPOR_OPP3(ILINE) From SUBOPPA
      Else
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSOPP)
        GERR = 4
        mkstat = 2
        GOK = 1
        End
      Endif
      Affzo [M:OPP3]5
    Endif
  Elsif status = 65 Then
    # Delete a line
    IRET = fmet GZINSOPP.CRM(1).ADELLINE("STPSTB", GZINSOPP.CRM(1).STPSTB([M:OPP3]COLLIN(nolign-1)).AORDER)
    If IRET = [V]CST_ANOTDEFINED Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSOPP)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

