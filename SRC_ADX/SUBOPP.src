#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion du fichier OPPOR
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE               From SUBOPPA
    When "FERME"        : Gosub FERME               From SUBOPPA
    When "LIENS"        : Gosub LIENS               From SUBOPPA
    When "BOITE"        : Gosub BOITE               From SUBOPPA
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE         From SUBOPPA
    When "FILTRE"       : Gosub FILTRE              From SUBOPPA
    When "FILGAUCHE"    : Gosub FILGAUCHE           From SUBOPPA
    When "SETBOUT"      : Gosub SETBOUT             From SUBOPPA
    When "AVANTBOUT"    : Gosub AVANTBOUT           From SUBOPPA
    When "EXEBOUT"      : Gosub EXEBOUT             From SUBOPPA
    When "AVANT_CHOI"   : Gosub AVANT_CHOI          From SUBOPPA
    When "RAZCRE"       : Gosub RAZCRE              From SUBOPPA
    When "RAZDUP"       : Gosub RAZDUP              From SUBOPPA
    When "CREATION"     : Gosub CREATION            From SUBOPPA
    When "APRES_CRE"    : Gosub APRES_CRE           From SUBOPPA
    When "MODIF"        : Gosub MODIF               From SUBOPPA
    When "APRES_MOD"    : Gosub APRES_MOD           From SUBOPPA
    When "AV_ANNULE"    : Gosub AV_ANNULE           From SUBOPPA
    When "ANNULE"       : Gosub ANNULE              From SUBOPPA
    When Default
  Endcase
Return

##########################################################################################################
##########################################################################################################
# Zones écrans
##########################################################################################################
# OPP0
##########################################################################################################
##########################################################################################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()

  # ------------------------
  If GZINSOPP = null Then
    GMESSAGE = mess(1013,196,1)
    GERR = 1
    mkstat = 2
    End
  Endif
  # ------------------------
  GZINSOPP.SALFCY = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSOPP) From SUBOPPA
  If GERR = 1 Then
    GZINSOPP.SALFCY = GZINSOPP.snapshot.SALFCY
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_OPPOR_HEADER() From SUBOPPA
  Endif
  # ------------------------
  GFCY = [M:OPP0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
End

##########################################################################################################
Subprog AM_OPPNUM(VALEUR)
Variable Char    VALEUR()

  If GREP = AVOID.ACHAR Then
    # Issue X3-61731 - 2018-04-19 by FGR : BEGIN
    If VALEUR = AVOID.ACHAR Then
      GMESSAGE = mess(1182,196,1)
      GERR = 1
      mkstat = 2
      End
    Else
      Local File OPPOR [OPP]
      Look [OPP]OPP0=VALEUR
      If fstat <> [V]CST_AOK Then
        GMESSAGE = mess(1182,196,1)
        GERR = 1
        mkstat = 2
        End
      Endif
    Endif
    # Issue X3-61731 - 2018-04-19 by FGR : END
  Else
    GZINSOPP.OPPNUM = VALEUR
    Call RECOVERS_ERROR_IN_CLASSIC(GZINSOPP) From SUBOPPA
    If GERR = 1 Then
      GZINSOPP.OPPNUM = GZINSOPP.snapshot.OPPNUM
      GERR = 1
      mkstat = 2
      End
    Else
      Call SHOW_OPPOR_HEADER() From SUBOPPA
    Endif
  Endif
End

##########################################################################################################
Subprog IB_OPPDESAXX

  If [M:OPP0]OPPSRENUM = AVOID.ACHAR Then
    Raz GBOUT2
  Else
    GBOUT2 = mess(287,196,1) # Demande de service.
  Endif
End

##########################################################################################################
Subprog AM_OPPDESAXX(VALEUR)
Variable Char    VALEUR()

  GZINSOPP.PIMPL.PIMDESAXX = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSOPP) From SUBOPPA
  If GERR = 1 Then
    GZINSOPP.PIMPL.PIMDESAXX = GZINSOPP.PIMPL.snapshot.PIMDESAXX
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_OPPOR_HEADER() From SUBOPPA
  Endif
End

##########################################################################################################
Subprog IB_OPPCMP

  GBOUT1 = [M:OPP0]OPPCMPLIB
  If [M:OPP0]OPPCMPAOB = "BPR" Then
    Raz GBOUT3
  Endif
  Call IB_NOTECHECK([M:OPP0]OPPCMP, "CRM", 4)  From TRTNTSCTL # CRM notes
End

##########################################################################################################
Subprog AM_OPPCMP(VALEUR)
Variable Char    VALEUR()

  GZINSOPP.OPPCMP = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSOPP) From SUBOPPA
  If GERR = 1 Then
    GZINSOPP.OPPCMP = GZINSOPP.snapshot.OPPCMP
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_OPPOR_HEADER() From SUBOPPA
  Endif
  # ------------------------
  Local File BPARTNER [BPR]  # Issue X3-80586 - 2018-04-11 by FGR
  Read [BPR]BPR0=VALEUR
  If fstat Then
    # Affiche le nom en clair du tiers sélectionné.
    [M:OPP0]BPRINFO = 0
  Else
    #Affiche le nom en clair du tiers sélectionné.
    If [F:BPR]BPCFLG = 2 Then
      # Client
      [M:OPP0]BPRINFO = 2
    Elsif [F:BPR]PPTFLG = 2 Then
      # Prospect
      [M:OPP0]BPRINFO = 1
    Else
      [M:OPP0]BPRINFO = 0
    Endif
  Endif
  Call SETAFFVALCUR([M:OPP0]CUR) From SUBOPPB
  # Affiche le type du tiers sélectionné.
  Call AFFICHE_BCK_TIERS(VALEUR) From SUBOPPB
  #[M:OPP0]OPPCMP = VALEUR  # TODO Not sure still necessary
  Gosub DISPCCN From SUBOPPB
  # Affichage background OPPMCN
  Gosub DISPBKGCCN From SUBOPPB
  Affzo [M:OPP0]1-99
  Affzo [M:OPP1]1-99
End

##########################################################################################################
Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()

  GZINSOPP.CUR = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSOPP) From SUBOPPA
  If GERR = 1 Then
    GZINSOPP.CUR = GZINSOPP.snapshot.CUR
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_OPPOR_HEADER() From SUBOPPA
  Endif
  # ------------------------
  Call SETAFFVALCUR(VALEUR) From SUBOPPB
  Affzo [M:OPP1]1-99
End

