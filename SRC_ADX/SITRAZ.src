#<AdxTL>@(#)3.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","SITRAZ","",1,"") From GTRAITE
End

######################################################################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "EXEC"        : Gosub EXEC
Endcase
Return

######################################################################################
$INIT
Gosub SI_CONTEXT From SIXFONCTION
If clalev([F:ATB])=0 : Local File ATABLE    [ATB] : Endif 
Filter [ATB] Where left$([F:ATB]CODFIC,2)="XI"
If rowcount([ATB])>0
 OK=1
 # Ce traitement va supprimer toutes les tables XI de la base de données
 # ainsi que leur identification dans le dictionnaire des tables. 
 # Une sauvegarde complète du dossier est conseillée au préalable. Confirmez-vous le traitement ? 
 Call OUINON(SI_MES(261)-SI_MES(262)-"\"-SI_MES(263)-"\"-SI_MES(264),OK) From GESECRAN
 If OK<>2 : FIN = 1 : Return :  Endif
Endif
Filter [ATB]
Call OUVRE_TRACE("") From LECFIC
TMP = 1 : TRA = 1
Return

######################################################################################
$EXEC
If clalev([F:ADS])=0 : Local File ADOSSIER  [ADS] : Endif
If clalev([F:ATB])=0 : Local File ATABLE    [ATB] : Endif 
If clalev([F:ATZ])=0 : Local File ATABZON   [ATZ] : Endif 
If clalev([F:ATI])=0 : Local File ATABIND   [ATI] : Endif 
If clalev([F:ATY])=0 : Local File ATYPE     [ATY] : Endif
If clalev([F:ANX])=0 : Local File AINDEX    [ANX] : Endif
If clalev([F:ACV])=0 : Local File ACTIV     [ACV] : Endif
If clalev([F:ADA])=0 : Local File ADOSACT   [ADA] : Endif

# Demande 49006
Local Integer FLGERR,NBRERR,NBRTAB
Filter [ATB] Where left$([F:ATB]CODFIC,2)="XI"
For [ATB]
 If filinfo(filpath("FIL",[F:ATB]CODFIC,"fde",nomap),0)>0
  Call ANNULE(nomap,[F:ATB]CODFIC,FLGERR)
  If !FLGERR
   NBRERR+=1
  Else
   Call ECR_TRACE(mess(53,125,1)-[F:ATB]CODFIC,-1) From GESECRAN
   NBRTAB+=1
  Endif
 Endif
Next
Filter [ATB]

# Suppressions
If !NBRTAB
 # Aucune suppression
 Call ECR_TRACE(SI_MES(265),0) From GESECRAN
Else
 # tables supprimées dans la base de données
 Call ECR_TRACE(num$(NBRTAB)-SI_MES(266),0) From GESECRAN
Endif

If NBRERR : Return : Endif
#

$TR_RAZX3
Trbegin [ATB], [ATZ], [ATI]

 ## 1) On efface les tables Intégrales créées dans X3 
 ## Les tables intégrale ont toutes le préfixe 'XI'

 Delete [ATB] Where left$([F:ATB]CODFIC,2)="XI"
 If fstat
  # Erreur d'effacement
  GOK = 0 : Call ECR_TRACE(mess(28,125,1),1) From GESECRAN
 Endif
 Delete [ATZ] Where left$([F:ATZ]CODFIC,2)="XI"
 If fstat
  # Erreur d'effacement
  GOK = 0 : Call ECR_TRACE(mess(28,125,1),1) From GESECRAN
 Endif
 Delete [ATI] Where left$([F:ATI]CODFIC,2)="XI"
 If fstat
  # Erreur d'effacement
  GOK = 0 : Call ECR_TRACE(mess(28,125,1),1) From GESECRAN
 Endif

 Delete [ACV] Where CODACT = "XXI"
 If fstat
  # Erreur d'effacement
  GOK = 0 : Call ECR_TRACE(mess(28,125,1),1) From GESECRAN
 Endif

 Delete [ADA] Where DOSSIER=nomap & CODACT = "XXI"
 If fstat
  # Erreur d'effacement
  GOK = 0 : Call ECR_TRACE(mess(28,125,1),1) From GESECRAN
 Endif

 If GOK<0   : Goto ROLL_TR_RAZX3
 Elsif !GOK : Goto AB_TR_RAZX3
 Endif

Commit
# Fin normale de trace
Call ECR_TRACE(mess(44,126,1),0) From GESECRAN


#DdM45254
#Read [ATY]CODTYP = "AVA"
#If !fstat & [F:ATY]LNGTYP<>10
# Trbegin [ATY]
# Update [ATY] Where CODTYP="AVA" With LNGTYP=10, FORTYP="A9u"
# If fstat
#  # Erreur d'écriture
#  Call ECR_TRACE("ATYPE : AVA"-mess(26,125,1)-func SIXFONCTION.FSTATMSG(fstat),1) From GESECRAN
#  Rollback : Return
# Endif
# Commit
# Call VALIDATION(nomap) From SUBATY
# Call MAJFIC("ATABZON",nomap,1) From VALDIC
# Call MAJFIC("AMSKZON",nomap,1) From VALDIC
# Call MAJFIC("AMSKACT",nomap,1) From VALDIC
# Call MAJFIC("AMSKPAR",nomap,1) From VALDIC
# Call VALID("ATB2",nomap,1,GLANGUE,1,GOK) From VALMSK
# Call VALID("AMK2",nomap,1,GLANGUE,1,GOK) From VALMSK
#Endif

Return

$AB_TR_RAZX3
Rollback
Return

$ROLL_TR_RAZX3
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_RAZX3 : Endif

#######################################################################################
Subprog ANNULE(DOSSIER,TABLE,OK)
Value Char DOSSIER , TABLE
Variable Integer OK
Local Char    MACHINE(GLONAMC) , APPLI(GLONADS) , ORDSYS(250)(1..2) , FICTRA(GDIMFIC)
Local Char    MESSAGE(250)(1..3)
Local Integer STAT
If DOSSIER=""
 APPLI = nomap
 MACHINE = adxmac(0)
Else
 Call MACHINE(DOSSIER,MACHINE,APPLI) From ORDSYS
Endif
If filinfo(filpath("FIL",TABLE,"fde",DOSSIER),0)>0
 FICTRA  = filpath("tmp",TABLE,"tra",DOSSIER)
 If filinfo(FICTRA,0)>0
  Call EFFACE(FICTRA,STAT) From ORDSYS
 Endif
 ORDSYS(1) = "valfil -d"
 ORDSYS(1) -= APPLI-TABLE
 ORDSYS(2)  = FICTRA
 Call SYSTEME(MACHINE,ORDSYS,"",STAT) From ORDSYS
 Openi FICTRA Using [TR_]
 Iomode adxifs "" Using [TR_]
 Iomode adxirs chr$(10) Using [TR_]
 Iomode adxium GUTF8 Using [TR_]
 Raz MESSAGE
 Rdseq MESSAGE(1) Using [TR_]
 Rdseq MESSAGE(2) Using [TR_]
 Rdseq MESSAGE(3) Using [TR_]
 Openi Using [TR_]
 Call EFFACE(FICTRA,STAT) From ORDSYS
 If MESSAGE(1)<>""
  Call ECR_TRACE(mess(183,125,1)-TABLE+"\|"+MESSAGE(1)+"|\|"+MESSAGE(2)+"|\|"+MESSAGE(3),1) From GESECRAN
  # Erreur en suppression de la table
  OK = 0 : End
 Endif
Endif
OK = 1
End




