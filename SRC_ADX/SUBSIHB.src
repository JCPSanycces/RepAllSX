#<AdxTL>@(#)11.0.0.0 $Revision$
#########################################################################
# SUBSIHB : GESTION DES FACTURES                                        #
#########################################################################
#                                                                       #
# Etiquettes appelées par SUBSIH                                        #
#                                                                       #
#  $TEST_INS        : Test d'insertion d'une ligne de commande          #
#  $TEST_ANU        : Test de suppression d'une ligne de commande       #
#  $TEST_MOD        : Test de modification d'une ligne de commande      #
#  $TEST_VAL        : Test de gestion des tarifs groupés                #
#  $CTR_QTY         : Contrôle qtée cdée avec qtée mini et maxi         #
#  $RECALC_LIGNE    : Traitement des lignes                             #
#  $CHARG_ZONES_DEV : Chargement champs relatifs à la conversion devise #
#  $INIT_COURS      : Initialisation et grisage des cours saisis        #
#                                                                       #
# Etiquettes appelées par SUBSIHA                                       #
#  $RECALC_GROUPE : Recalcul des lignes suite à tarif groupé            #
#  $MAJADRESSE    : Mise à jour de l'adresse                            #
#  $CHARGE_ADRBPI : Chargement de l'adresse facture                     #
#  $CHARGE_ADRBPD : Chargement de l'adresse livraison                   #
#  $CHARGE_ADRBPY : Chargement de l'adresse règlement (tiers payeur)    #
#  $GEN_AVO       : génération d'un avoir sur facture                   #
#                                                                       #
# Traitements appelés par SUBSIHA                                       #
#                                                                       #
#  Subprog RECH_DERFACSOH()                                             #
#       Recherche dernier numéro facture d'une commande suite à supp.   #
#                                                                       #
#  Subprog MAJ_ORIPRF(WTYPACT, WORI, WORINUM, WNUM)                     #
#       Maj du n° proforma dans le document d'origine (devis, cde, liv) #
#                                                                       #
# Traitements communs et Etiquettes communes                            #
#                                                                       #
#  Subprog LECT_FIC(NLIG)                                               #
#       Lecture de tous les fichiers utiles à une ligne                 #
#  Subprog INIT_SIH(NLIG, AFF)                                          #
#       Init. des zones détails venant de l'entête                      #
#  Subprog INIT_ITM(NLIG, ITM)                                          #
#       Init. des zones détails venant de l'article                     #
#  Subprog VERIF_VATCOD(NLIG)                                           #
#       Vérification des codes taxes                                    #
#  Subprog APRES_LIGNE(NLIG, AFF)                                       #
#       Traitement d'apres lignes                                       #
#  Subprog ADD_TOT(NLIG, AFF)                                           #
#       Calcul des montants total de la commande en +                   #
#  Subprog SUB_TOT(NLIG, AFF)                                           #
#       Calcul des montants total de la commande en -                   #
#  Subprog RECH_GROUPE()                                                #
#       Recherche tarif groupe                                          #
#  Subprog SUP_LIG(NLIG, WRET                                           #
#       Suppression d'une ligne dans le tableau                         #
#  Subprog CONVERT_MONTANT (DEV,TYP)                                    #
#       Conversion des éléments de facturation et des montants en-cours #
#  Subprog RECH_ORINUM ()                                               #
#       Recherche du no origine (cde,liv) de la facture                 #
#  $CALC_INV      : Calcul mnts ht et ttc d'une ligne commande          #
#                                                                       #
# Traitements appelés par le composant d'entrée en stock                #
#                                                                       #
#  $MAJ_STOCK       : Mise à jour des stocks                            #
#  $MAJ_LIG_SIH     : Donne la main pour maj ligne du document          #
#  $CONV_LIG_SAUSTU : Passage de la ligne avoir en US                   #
#  $CTL_LIG_SIH     : Donne la main avant stockage dans STOENTW         #
#  $TRT_MAJ_DOCUMENT: Maj du document origine suite à modifications     #
#                                                                       #
#                                                                       #
#  Subprog CHARG_PARAM_STOENT (LLIG)                                    #
#       Chargement Ecran STOENT creations des entrées                   #
#  Subprog CHARG_PARAM_STOENTM (LLIG)                                   #
#       Chargement Ecran STOENTM modification des entrées               #
#                                                                       #
# Traitements appelés pour les avoirs                                   #
#  $RAZ_TABL_STOCK  : Effacement des champs stock                       #
#                                                                       #
#                                                                       #
#########################################################################
# Issue 106150 - 20160316 by LD : Entry point ADD_TOT and SUB_TOT
# Issue X3-38450 - 20171030 by LD : Invalid sales invoice without currency rate
# Issue X3-63491 - 20171214 by LD : Wrong amount in sales invoice elements in amounts with a different currency
# Issue X3-64430 - 20171227 by LD : Contrôle du cours multiplicateur

#---------------------------#
# Test d'insertion de ligne #
#---------------------------#
TEST_INS
If GREP="D"
# --> Ctrl particulier en dupli. pour l'euro : vérifier que ce n'est pas une devise "in"
    Call CONTDEV([M:SIH2]CUR,[M:SIH0]INVDAT) From TRTDEV
    If mkstat=2 Return Endif
Endif
If [M:SIH1]STOFCY="" & [M:SIH1]STOMVTFLG=2
   GMESSAGE = mess(174,192,1) : mkstat=2 : Return
Endif
# Issue X3-38450
# Le cours de la devise doit être renseigné
# Issue X3-64430
#If [M:SIH2]RAT2=0
If [M:SIH2]RAT1=0 | [M:SIH2]RAT2=0
# End issue X3-64430
   GMESSAGE=mess(548,192,1) : mkstat=2 : Return
Endif
# End issue X3-38450
If dim([M:SIH4]ITMREF) < [M:SIH4]NBLIG + 2
   GMESSAGE = mess(122,199,1) : mkstat = 2 : Return
Endif
# --> pas d'insertion si composant
If ([M:SIH4]LINTYP(NOL)>2 & [M:SIH4]LINTYP(NOL)<=5) | ([M:SIH4]LINTYP(NOL)>10 & [M:SIH4]LINTYP(NOL)<=13)
   GMESSAGE = mess(97,192,1) : mkstat=2
Endif
If [M:SIH4]LINTYP(NOL) > 6 & [M:SIH4]LINTYP(NOL) <=9
   GMESSAGE = mess(97,192,1) : mkstat=2
Endif
# --> pas d'insertion si gratuit
If [M:SIH4]FOCFLG(NOL) = 3
   GMESSAGE = mess(98,192,1) : mkstat=2
Endif
# --> pas d'insertion si la facture/avoir est validée
If [M:SIH0]INVTYP <> 5 & [M:SIH1]INVSTA = 3
   mkstat=2 : Return
Endif
Return

#------------------------------#
# Test de suppression de ligne #
#------------------------------#
$TEST_ANU

# --> pour supprimer cette ligne, il faut la désélectionner de la liste 'sélection commandes'
If [M:SIH1]SIHORI=2 & [M:SIH4]SOHNUM(NOL)<>"" & [M:SIH4]CREFLG(NOL)=0
   GMESSAGE=mess(182,192,1) : mkstat=2 : Return
Endif
# --> pour supprimer cette ligne, il faut la désélectionner de la liste 'sélection factures'
If [M:SIH1]SIHORI=4 & [M:SIH4]XSIHORINUM(NOL)<>"" & [M:SIH4]CREFLG(NOL)=0
   GMESSAGE=mess(207,192,1) : mkstat=2 : Return
Endif
# --> pour supprimer cette ligne, il faut la désélectionner de la liste 'sélection retours'
If [M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)<>"" & [M:SIH4]CREFLG(NOL)=0
   GMESSAGE=mess(208,192,1) : mkstat=2 : Return
Endif
# --> pour supprimer cette ligne, il faut la désélectionner de la liste 'sélection contrats'
If [M:SIH1]SIHORI=7 & [M:SIH4]CONNUM(NOL)<>"" & [M:SIH4]CREFLG(NOL)=0
   GMESSAGE=mess(209,192,1) : mkstat=2 : Return
Endif
# Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) #
If [M:SIH1]SIHORI=10 & [M:SIH4]SOHNUM(NOL)<>"" & [M:SIH4]CREFLG(NOL)=0 & [M:SIH4]VCRINVCNDLIN(NOL)>0
  If [M:SIH4]SIDORI(NOL)=10 and [M:SIH4]VCRINVCNDTYP(NOL)=10
    GMESSAGE=mess(516,192,1) : mkstat=2 : Return
  Else
    #--For futures schedule invoice types
  Endif
Endif
# --> pas de suppression sur un composant kit/sous-traité
If ([M:SIH4]LINTYP(NOL)>2 & [M:SIH4]LINTYP(NOL)<=5) | ([M:SIH4]LINTYP(NOL)>10 & [M:SIH4]LINTYP(NOL)<=13)
   GMESSAGE = mess(26,192,1):mkstat=2
#  MSG=traitement impossible : composant d'un kit
Endif
# --> Pas de Suppression multiple s'il y a des composants de nomenclatures
If status = 83 & find([M:SIH4]LINTYP(NOL),7,8,9)
   GMESSAGE = mess(172,192,1) : mkstat=2 : Return
Endif
# --> Pas de Suppression multiple s'il y a des gratuits
If status = 83 & [M:SIH4]FOCFLG(NOL) = 3
    GMESSAGE = mess(172,192,1) : mkstat=2 : Return
Endif
# --> Ligne issue d'une livraison
If [M:SIH0]INVTYP=1 & [M:SIH4]SDHNUM(NOL) <> ""
    # Dde 62603 : Suppression des lignes d'un BL
#    If find ([M:SIH4]SDHNUM(NOL), [M:SIH4]SDHNUM(0..NOL-1)) | find ([M:SIH4]SDHNUM(NOL), [M:SIH4]SDHNUM(NOL+1..[M]NBLIG-1))
    # MSG : Attention, cette ligne est issue d'une livraison
    # Vous devez suppprimer toutes les lignes issues de cette livraison à l'aide du bouton Suppression lignes livraison
        GMESSAGE = mess(43,187,1)-","-mess(234,191,1)-":\"-mess(235,191,1)
        Call MESSAGE(GMESSAGE) From GESECRAN : Raz GMESSAGE
        mkstat=2 : Return
#    Endif
Endif

# --> pas de suppression s'il s'agit d'une ligne facture issue d'un transfert
#If [M:SIH0]INVTYP=1 & ([M:SIH4]SDHNUM(NOL) <> "" | [M:SIH4]SGHNUM(NOL) <> "")
If [M:SIH0]INVTYP=1 & [M:SIH4]SGHNUM(NOL) <> ""
    GMESSAGE = mess(80,192,1):mkstat=2 : Return
    #  MSG=traitement impossible : ligne issue d'une livraison
Endif
# --> pas de suppression si la facture/avoir est validée
If [M:SIH0]INVTYP <> 5 & [M:SIH1]INVSTA = 3
   GMESSAGE=mess(76,192,1): mkstat=2 : Return
Endif

#LSE 17/07/2007 FQ41694
If [M:SIH1]SIHORI=7 & [M:SIH4]CONNUM(NOL)<>""
    Read [CON] CON0=[M:SIH4]CONNUM(NOL)
    If fstat=0
        If [M:SIH0]NUM<>"" and [F:CON]OINV<>""
            If [F:CON]OINV<>[M:SIH0]NUM
                #Des contrats de service associés ont déjà été facturés. Suppression impossible.
                GMESSAGE=mess(528,177,1)
                mkstat=2
                Return
            Endif
        Endif
    Endif
Endif

  # FGR 07/10/2015 : X3SUIVI111550 (début)
  If [M:SIH1]SIHORI = 8 and [M:SIH4]SRENUM(NOL) <> "" Then
    # La facturation partielle d'une demande de service n'est pas autorisée.
    # Donc on ne peut pas supprimer une ligne liée à une demande de service.
    GMESSAGE = mess(434,192,1)
    mkstat = 2
    Return
  Endif
  # FGR 07/10/2015 : X3SUIVI111550 (fin)
Return

#-------------------------------#
# Test de modification de ligne #
#-------------------------------#
$TEST_MOD
NOL=nolign-1
# --> pas de modification sur un composant kit
If ([M:SIH4]LINTYP(NOL)>2 & [M:SIH4]LINTYP(NOL)<=5)

# --> Test pour ne pas avoir le message en creation !
    If [M:SIH4]CREFLG(NOL) <> 0 GMESSAGE = mess(26,192,1) Endif
# MSG=traitement impossible : composant d'un kit
    mkstat=2
Endif
Return

#-------------------------------------------#
# Contrôle qte avec qte mini et qte maxi    #
# (uniquement si facture et ligne directe)  #
#-------------------------------------------#
$CTR_QTY
Local    Decimal QTY_UV

If [M:SIH0]INVTYP > 1 : Return : Endif
If [M:SIH4]SOHNUM(NOL) <> "" | [M:SIH4]SDHNUM(NOL) <> "" Return : Endif
# --> Calcul de la qtée cdée en UV
If [M:SIH4]SAU(NOL) <> [F:ITM]SAU
     Call SCAL_QUV(VALEUR, [M:SIH4]ITMREF(NOL),[M]BPCORD,[M:SIH4]SAU(NOL),
&                  [F:ITM]SAU, QTY_UV, GBIDD1) From TRTVENQTE
Else
     QTY_UV = VALEUR
Endif
# --> Controle qte cdee >= a la qte minimale
If QTY_UV < [F:ITS]MINQTY & [F:ITS]MINQTY > 0
    GMESSAGE = sum(mess(12,192,1), format$("N:"+GFMTQTY, num$([F:ITS]MINQTY)), " ",[F:ITM]SAU)
#   MSG=qte < a la qte minimale
    If GDACLOK = 1 mkstat=2:Return
    Else           GERR=2 : Endif
Endif
# --> Controle qte cdee <= a la qte maximale
If QTY_UV > [F:ITS]MAXQTY & [F:ITS]MAXQTY > 0
    If GERR=2 GMESSAGE += "\" Endif
    GMESSAGE = sum(mess(13,192,1), format$("N:"+GFMTQTY, num$([F:ITS]MAXQTY)), " ",[F:ITM]SAU)
#   MSG=qte > a la qte maximale de
    If GDACLOK = 1 mkstat=2
    Else           GERR=2 : Endif
Endif
Return

#-------------------------------------------------------------------------#
# Appelé en am_modif : Date fac, Devise, Régime, Type prix,               #
#                      Adresse de livraison, représentants                #
#                      cours devise                                       #
#                      VATDAT                                             #  # 95785 : Recalcul tarif/taxe si modification VATDAT
#  --> Si Recalcul des taxes  : GTARFLG= "2"                              #  # 95785
#  --> Si dde Recherche tarif : GTARFLG= "1"                              #
#  --> Si modif.régime        : GTARFLG= "V" Recalc. prix, marge, totaux  #
#  --> Si modif.type prix     : GTARFLG= "P" Bascule prix                 #
#  --> Si modif.devise        : GTARFLG= "C" Conversion des montants      #
#-------------------------------------------------------------------------#
$RECALC_LIGNE
Local Char     NOMD, NOME, ACT(1)
Local Integer  NLIG, I, J, WIND, SPSTAT, ORI
Local Decimal  MNTORI, MNTDES
Local Char     VAT(GLONVAT)(3), WREP

Local Char     WVACITM(GLONTVI)(3)
Local Integer  WINICPRPRI            : # 89253

Raz ACT

If [M:SIH1]INVSTA = 3 Return : Endif
# --> Dde recherche tarif

#If GTARFLG = "1" | GTARFLG = "V" | GTARFLG = "C"                   : # 89253 : Modif cours devise
#If find (GTARFLG,"1","V","C") | find(WZONCOU,"RATDIV","RATMLT")    : # 95785 : Recalcul tarif/taxe si modification VATDAT
If find (GTARFLG,"1","2","V","C") | find(WZONCOU,"RATDIV","RATMLT") : # 95785
    Raz [M:SIH4]INVNOT, INVATI, PFMTOT
    Raz [M:SIH0]DSPTOTQTY,DSPTOTVOL,DSPTOTWEI       :#--CPO 80622 Il faut refaire les totaux
Endif
#----------------------------------------------------------------#
# Modification des lignes détails en fonction des modifs entetes #
#----------------------------------------------------------------#
Raz NLIG
While NLIG < [M:SIH4]NBLIG
    If WZONCOU = "BPAADD"
        # --> Alimentation des représentants et des commissions
        For WIND=0 To dim([M:SIH1]REP)-1
            WREP = evalue("[M:SIH1]REP("+num$(WIND)+")")
            Assign ("[M:SIH4]REP"+num$(WIND+1)+"(NLIG)") With WREP
            Assign ("[M:SIH4]REPRAT"+num$(WIND+1)+"(NLIG)") With 0
            Gosub MOD_REP
        Next
    Endif
    If WZONCOU = "REP"
        NOMD = sum(WZONCOU, num$(indice+1))
        If evalue ("dim([M:SIH4]"+NOMD+"(NLIG))")>0
            WREP=VALEUR
            WIND=indice
            Assign "[M:SIH4]"+NOMD+"(NLIG)" With WREP
            Assign ("[M:SIH4]REPRAT"+num$(WIND+1)+"(NLIG)") With 0
            Gosub MOD_REP
        Endif
    Endif
    # 89253 : Modification des cours : Recalcul de la marge
    If find(WZONCOU,"RATDIV","RATMLT")
        Call LECT_FIC(NLIG)
        WINICPRPRI=1            : # 89253
        Gosub RECALC_TOT
    Endif
    # 89253
#    If find(GTARFLG, "1", "C", "V", "P")           : # 95785 : Recalcul tarif/taxe si modification VATDAT
    If find(GTARFLG, "1", "2", "C", "V", "P")       : # 95785 : Recalcul tarif/taxe si modification VATDAT
        Call LECT_FIC(NLIG)
#     --> Recherche tarif
        If GTARFLG = "1"
            Gosub RECALC_TARIF
#     --> Recalcul des taxes                        : # 95785 : Recalcul tarif/taxe si modification VATDAT
        Elsif GTARFLG = "2"                         : # 95785
            WINICPRPRI=1                            : # 95785
            Gosub RECALC_TOT                        : # 95785
        Else
#     --> Modif. devise en dupplication : Conversion des montants
            If GTARFLG = "C"
                Gosub CONV_LIGNE
#     --> Modif. regime de taxe         : Recalcul des prix, de la marge et des totaux
            Elsif GTARFLG = "V"
                WVACITM(0) = [M:SIH4]VACITM1(NLIG)
                WVACITM(1) = [M:SIH4]VACITM2(NLIG)
                WVACITM(2) = [M:SIH4]VACITM3(NLIG)
                #Call ALITAXEV(VALEUR,WVACITM,VAT) From TRTX3
                Call RECHVATCOD(1,1,[M:SIH1]BPCORD,[M:SIH4]ITMREF(NLIG),"SIH4",NLIG,VAT) From TRTX3
                # Bug 75162 : Contrôle que le code taxe1 est bien renseigné
                Call CTLVAT(VAT(0)) From TRTVENCTL
                If mkstat=2
                    GMESSAGE = [M:SIH4]ITMREF(NLIG)-" : "-GMESSAGE : Break
                Endif
                # Bug 75162
                # 92192 : Si modif. code taxe principal, forcer une redétermination du compte de la ligne
                If [M:SIH4]VAT1(NLIG) <> VAT(0) & dim([M:SIH4]INIACCFLG)>0
                    #[M:SIH4]INIACCFLG(nolign-1)=2 : # 103619
                    [M:SIH4]INIACCFLG(NLIG)=2      : # 103619
                 Endif
                # 92192
                [M:SIH4]VAT1(NLIG) = VAT(0)
                [M:SIH4]VAT2(NLIG) = VAT(1)
                [M:SIH4]VAT3(NLIG) = VAT(2)
                WINICPRPRI=0            : # 89253
                Gosub RECALC_TOT
#     --> Modif. Type de prix           : Bascule des prix HT et TTC
            Elsif GTARFLG = "P"
                Gosub RECALC_PRI
            Endif
        Endif
    Endif
    [M]UPDFLG(NLIG) = 1
    NLIG+=1
Wend
If mkstat=2 Return Endif        :  # Bug 75162
# Spécificité USA
Local Char WKU_MAJ : WKU_MAJ="2"
Gosub CHARG_TABLEAUX From TRTVENFACC
Gosub CAL_FACTURE From TRTVENFACC
[M:SIH0]INVCLCFLG=1

Raz GTARFLG

[M:SIH4]INVNOT = [M:SIHV]INVNOT
[M:SIH4]INVATI = [M:SIHV]INVATI

Affzo [M:SIH4]1-99
Affzo [M:SIHV]1-99
Return

#---------------------------------------------------------------------------------#
#  Suite à la modification d'un représentant : Recherche des taux de commissions  #
#---------------------------------------------------------------------------------#
$MOD_REP
If WREP <> ""
    If [F:REP]REPNUM <> WREP
        Read [F:REP]REP0 = WREP
        If fstat Raz [F:REP] : Endif
    Endif
    If [F:BPC]BPCNUM<>[M:SIH0]BPCINV
        Read [F:BPC]BPC0 = [M:SIH0]BPCINV
        If fstat Raz [F:BPC] :Endif
    Endif
    If [F:BPC]COMCAT <> 0
        Assign ("[M:SIH4]REPRAT"+num$(WIND+1)+"(NLIG)") With evalue("[F:REP]COMRAT"+num$(WIND+1)+"([F:BPC]COMCAT-1)")
    Endif
Endif
Return

#-------------------------------------#
# Convertion des montants lignes      #
#-------------------------------------#
$CONV_LIGNE

# --> Dans ANC_CUR     : Ancienne devise
# --> Dans [M:SIH0]CUR : Nouvelle devise

If [M:SIH4]QTY(NLIG)<>0
    Call CONVERT2(ANC_CUR, [M:SIH0]CUR, GLOCALDEV, [M]CHGTYP, [M]INVDAT, [M]GROPRI(NLIG), MNTDES, SPSTAT) From TRTDEV
    [M]GROPRI(NLIG) = arr(MNTDES, 10^-GDECPRI)

    For I = 1 To 9
        If evalue ("dim([m:sih4]discrgval"+num$(I)+"(nlig))")>0
            If GFMTREM(I-1)="M"
                MNTORI = evalue("[m:sih4]discrgval"+num$(I)+"(NLIG)")
                Call CONVERT(ANC_CUR, [M:SIH0]CUR, GLOCALDEV, [M]CHGTYP, [M]INVDAT, MNTORI, MNTDES, SPSTAT) From TRTDEV
                Assign "[m:sih4]discrgval"+num$(I)+"(NLIG)" With MNTDES
            Endif
        Endif
    Next
    Call CONVERT2(ANC_CUR, [M:SIH0]CUR, GLOCALDEV, [M]CHGTYP, [M]INVDAT, [M]NETPRI(NLIG), MNTDES, SPSTAT) From TRTDEV
    [M]NETPRI(NLIG) = arr(MNTDES, 10^-GDECPRI)

    Call CONVERT2(ANC_CUR, [M:SIH0]CUR, GLOCALDEV, [M]CHGTYP, [M]INVDAT, [M]CPRPRI(NLIG), MNTDES, SPSTAT) From TRTDEV
    [M]CPRPRI(NLIG) = arr(MNTDES, 10^-GDECPRI)

    # Traitement des montants de base de calcul
    If [M]CLCAMT1(NLIG) <> 0 | [M]CLCAMT2(NLIG) <> 0
        # Ces montants dépendent d'une formule donc d'opérandes divers
        # Pas de conversion mais Recalcul
        Call ALICLCAMT([M]ITMREF(NLIG), [M]QTY(NLIG), NLIG, "SIH4", [M]CLCAMT1(NLIG), [M]CLCAMT2(NLIG)) From TRTX3
    Endif

    WINICPRPRI=0            : # 89253
    Gosub RECALC_TOT
Else
    Call CONVERT2(ANC_CUR, [M:SIH0]CUR, GLOCALDEV, [M]CHGTYP, [M]INVDAT, [M]AMTLIN(NLIG), MNTDES, SPSTAT) From TRTDEV
    [M]AMTLIN(NLIG) = arr(MNTDES, 10^-GDECPRI)
Endif

Return

#-------------------------------------#
# Rebascul des prix HT et TTC         #
#-------------------------------------#
$RECALC_PRI

If [M:SIH4]QTY(NLIG)=0 Return Endif

If [M]PRITYP=1
   [M]NETPRI(NLIG) = [M]NETPRINOT(NLIG)
Else
   [M]NETPRI(NLIG) = [M]NETPRIATI(NLIG)
Endif
Return

#-------------------------------------#
# Recalcul des totaux                 #
#-------------------------------------#
$RECALC_TOT
Local Integer AFF
If dim(WINICPRPRI)<=0 Local Integer WINICPRPRI : WINICPRPRI=0 Endif    : # 89253

Call CLCPFM([M]DSTOFCY(NLIG), [M:SIH1]PRITYP, [M]CHGTYP, [M:SIH0]INVDAT, [M:SIH0]CUR,
&           NLIG,WINICPRPRI) From TRTVENPRI                            : # 89253
#&           NLIG,0) From TRTVENPRI                                    : # 89253
Call CTLPFM([M:SIH0]CUR,[M:SIH4]CPRPRI(NLIG), NLIG) From TRTVENPRI

mkstat=0
If [M]QTY(NLIG)<>0 : Gosub CALC_INV: Gosub CALC_DSP From TRTVENDIV : Endif
Call ADD_TOT(NLIG)
AFF = 0
Return

#-------------------------------------#
# Recalcul des tarifs                 #
#-------------------------------------#
$RECALC_TARIF
Local Integer TYPRECH
Local Decimal GROPRI

# Pas de recalcul tarif pour les avoirs en valeur
If [M]QTY(NLIG)=0 Return Endif

If find([M]LINTYP(NLIG), 1,2,6,10)
    TYPRECH = 1
Else
    Local Integer ORI : ORI=NLIG
    While !find([M]LINTYP(ORI),2,6,10) & ORI >= 0 ORI-=1 Wend
    If find([M]LINTYP(ORI),2,6,10) GPNTITMREF=[M]ITMREF(ORI) Endif
    TYPRECH=4
Endif
If [M]FOCFLG(NLIG) = 3 Return: Endif
Call ALICLCAMT([M]ITMREF(NLIG), [M]QTY(NLIG), NLIG, "SIH4", [M]CLCAMT1(NLIG), [M]CLCAMT2(NLIG)) From TRTX3
Call RECH_TARIF(TYPRECH,[M]ITMREF(NLIG),NLIG,[M]QTY(NLIG),"SIH",GROPRI) From TRTVENTAR
# Action sur les gratuits
If GFOCITMREF  = "" & [M]FOCFLG(NLIG) = 2  ACT = "S" : [M]FOCFLG(NLIG)=1 : Endif
If GFOCITMREF <> "" & [M]FOCFLG(NLIG) = 2  ACT = "C" : Endif
If GFOCITMREF <> "" & [M]FOCFLG(NLIG) = 1  ACT = "I" : Endif
[M]GROPRI(NLIG)= GROPRI
Call CLCNETPRI([M]QTY(NLIG),[M]CUR,NLIG) From TRTVENPRI
Call CLCPFM([M]DSTOFCY(NLIG), [M]PRITYP,[M]CHGTYP, [M]INVDAT, [M]CUR, NLIG,1) From TRTVENPRI
Call APRES_LIGNE(NLIG, 0)

Gosub RECALC_TARIF From LIBSAL_INVCND_SIH # Issue 107888 US140 - 2016-03-25 by CPO : Scheduled invoices object management

ORI = NLIG
Gosub TRTGRA
Return
#-------------------------------------#
# Traitement des gratuits             #
#-------------------------------------#
$TRTGRA
Local Integer LIGGRA
Local Integer RET

If ACT = "S" | ACT = "C"
    LIGGRA = find(3, [M]FOCFLG(NLIG+1..[M]NBLIG-1))
    If LIGGRA <> 0
        LIGGRA = LIGGRA + NLIG
#       Suppression du gratuit
        If ACT = "S"
            Call SUPGRA(ORI, 4, RET) From TRTVENBOM
            If RET = 0 [M]FOCFLG(ORI)=1 : Endif
        Endif
#       Remplacement du gratuit : Suppression et création
        If ACT = "C" & [M]ITMREF(LIGGRA) <> GFOCITMREF
            Call SUPGRA(LIGGRA-1, 4, RET) From TRTVENBOM
            If RET = 0
                Call CREGRA("G",0, ORI, [M:SIH0]INVDAT, 4, LIGGRA, RET) From TRTVENBOM
                If RET = 0 [M]UPDFLG(LIGGRA-1) = 1:Endif
            Endif
#       Creation du gratuit
        Elsif ACT = "C" & [M]QTY(LIGGRA) <> GFOCQTY
            [M]QTY(LIGGRA) = GFOCQTY
            [M]UPDFLG(LIGGRA) = 1
        Endif
    Endif
Endif
If ACT = "I"
    LIGGRA = NLIG + 1
    While LIGGRA < [M:SIH4]NBLIG & !find([M:SIH4]LINTYP(LIGGRA),1,2,6,10)
        LIGGRA += 1
    Wend
    Call CREGRA("G", 0, ORI, [M:SIH0]INVDAT, 4, LIGGRA, RET) From TRTVENBOM
Endif
Raz ACT
Return

###########################################################################
# Traitements appelés par SUBSIHA                                         #
###########################################################################
#------------------------------------------#
# Recalcul des lignes suite à tarif groupé #
#------------------------------------------#
$RECALC_GROUPE
Local Integer I

# Issue 107888 US140 - 2016-03-25 by CPO : Scheduled invoices object management
Local Integer WSAVE_NOL,IS_RECALC_GROUP
IS_RECALC_GROUP = [V]CST_AYES
WSAVE_NOL=-1
If dim(NOL)<0
  Local Integer NOL
Else
  WSAVE_NOL = NOL
Endif
# End issue 107888

# --> Recalcul prix net, marge des lignes modifiées et recalcul totaux
If sum([M:SIH4]GRPFLG) <> 0
    For I=0 To [M]NBLIG-1
        If [M:SIH4]GRPFLG(I) = 1
            Call SUB_TOT(I)
            GNETMAR = 0
            Call CLCNETPRI([M]QTY(I),[M]CUR,I) From TRTVENPRI
            Call CLCPFM([M]DSTOFCY(I), [M]PRITYP,[M]CHGTYP, [M]INVDAT, [M]CUR, I,0) From TRTVENPRI
            Call APRES_LIGNE(I,0)
            # Issue 107888 US140 - 2016-03-25 by CPO : Scheduled invoices object management
            Gosub RECALC_GROUPE From LIBSAL_INVCND_SIH
            If OK=0 : Break : Endif
            # End issue 107888
            GNETMAR = 1
            [M:SIH4]UPDFLG(I) = 1
        Endif
    Next
    # Spécificité USA
    Local Char WKU_MAJ : WKU_MAJ="2"
    [M:SIH0]INVCLCFLG=2   : # modif dans les lignes --> recalcul facture
    Raz [M:SIH4]GRPFLG
Endif

# Issue 107888 US140 - 2016-03-25 by CPO : Scheduled invoices object management
IS_RECALC_GROUP = [V]CST_ANO
If WSAVE_NOL>-1 : NOL = WSAVE_NOL : Endif
# End issue 107888

If [M:SIH0]INVCLCFLG=2 & !(dim(G_SIH_CAL)>0 & G_SIH_CAL<>"C")
    Gosub CHARG_TABLEAUX From TRTVENFACC
    Gosub CAL_FACTURE From TRTVENFACC
    [M:SIH0]INVCLCFLG=1
    Affzo [M:SIH2] : Affzo [M:SIH4] : Affzo [M:SIHV]
Endif

Return

#--------------------------------------------------------------------#
# Mise à jour de l'adresse                                           #
#--------------------------------------------------------------------#
$MAJADRESSE
Call DEBTRANS From GLOCK
$TR_ADR
GOK=1
Trbegin [SIH],[SIV]
  If BOUT="H" : # Menu Adresse client facture
#      If [M]CNTNAM <> [M:ADB3]CNTNAM | (dim([M]EECNUM)>0 & [M]EECNUM<>[M:ADB3]EECNUM)
#      If [M]CNTNAM <> [M:ADB3]CNTNAM
      Readlock [SIV] SIV0=[M]NUM #RMA #82772
      If fstat=1  GOK=-1 : GLOCK="$SINVOICEV"-[M]NUM           : Goto ROLL_ADR
      Elsif fstat GOK=0  : Call RSTA("SIV",[M]NUM) From GLOCK : Goto AB_ADR : Endif
      If [M]CNTNAM <> [M:ADB3]CNTNAM | (dim([M:SIH0]BPIEECNUM)>0 & [M:SIH0]BPIEECNUM<>[F:SIV]BPIEECNUM)
          [F:SIV]CNINAM    = [M:ADB3]CNTNAM
#          If dim([M:ADB3]EECNUM)>0 [F:SIV]BPIEECNUM = [M:ADB3]EECNUM Endif
          If dim([M:SIH0]BPIEECNUM)>0 : [F:SIV]BPIEECNUM = [M:SIH0]BPIEECNUM : Endif #RMA #82772
          Rewrite [SIV]
          If fstat GOK=0 : Call FSTA("SIV") From GLOCK : Goto AB_ADR : Endif
      Endif
      If [M:ADB3]ADBFLG = 2
          Readlock [SIH] SIH0=[M]NUM
          If fstat=1  GOK=-1 : GLOCK="$SINVOICE"-[M]NUM           : Goto ROLL_ADR
          Elsif fstat GOK=0  : Call RSTA("SIH",[M]NUM) From GLOCK : Goto AB_ADR : Endif
          Gosub CHARGE_ADRBPI
          Rewrite [SIH]
          If fstat GOK=0 : Call FSTA("SIH") From GLOCK : Goto AB_ADR : Endif
      Endif
  Elsif BOUT="Q" : # Menu Adresse tiers payeur - règlement
      If [M]CNTNAM <> [M:ADI4]CNTNAM
          Readlock [SIV] SIV0=[M]NUM
          If fstat=1  GOK=-1 : GLOCK="$SINVOICEV"-[M]NUM           : Goto ROLL_ADR
          Elsif fstat GOK=0  : Call RSTA("SIV",[M]NUM) From GLOCK : Goto AB_ADR : Endif
          [F:SIV]CNINAM    = [M:ADI4]CNTNAM
          Rewrite [SIV]
          If fstat GOK=0 : Call FSTA("SIV") From GLOCK : Goto AB_ADR : Endif
      Endif
      If [M:ADI4]ADBFLG = 2
          Readlock [SIH] SIH0=[M]NUM
          If fstat=1  GOK=-1 : GLOCK="$SINVOICE"-[M]NUM           : Goto ROLL_ADR
          Elsif fstat GOK=0  : Call RSTA("SIH",[M]NUM) From GLOCK : Goto AB_ADR : Endif
          Gosub CHARGE_ADRBPY
          Rewrite [SIH]
          If fstat GOK=0 : Call FSTA("SIH") From GLOCK : Goto AB_ADR : Endif
      Endif
  Else
      Readlock [SIV] SIV0=[M]NUM
      If fstat=1  GOK=-1 : GLOCK="$SINVOICEV"-[M]NUM             : Goto ROLL_ADR
      Elsif fstat GOK=0  : Call RSTA("SIV",[M]NUM) From GLOCK : Goto AB_ADR : Endif
      [F:SIV]CNDNAM = [M:ADB2]CNTNAM
      If [M:ADB2]ADBFLG = 2 Gosub CHARGE_ADRBPD : Endif
      Rewrite [SIV]
      If fstat GOK=0 : Call FSTA("SIV") From GLOCK : Goto AB_ADR : Endif
      Endif
Commit
Gosub RELIT From GOBJSUB  # FGR 24/07/2014 : X3SUIVI100377
Return

$ROLL_ADR
Rollback : Call ROLL From GLOCK
#if GROLL Gosub RELIT From GOBJSUB
#else     Goto TR_ADR : ENDIF
If !GROLL Goto TR_ADR : Endif
Return

$AB_ADR
Rollback
#osub RELIT From GOBJSUB
Return

# -------------------------------------- #
# Alimentation de l'adresse facturation  #
# -------------------------------------- #
$CHARGE_ADRBPI
[F:SIH]BPAINV       = [M:ADB3]BPAADD
[F:SIH]BPRNAM(0)    = [M:ADB3]BPRNAM(0)
[F:SIH]BPRNAM(1)    = [M:ADB3]BPRNAM(1)
[F:SIH]BPAADDLIG(0) = [M:ADB3]BPAADDLIG(0)
[F:SIH]BPAADDLIG(1) = [M:ADB3]BPAADDLIG(1)
[F:SIH]BPAADDLIG(2) = [M:ADB3]BPAADDLIG(2)
[F:SIH]POSCOD       = [M:ADB3]POSCOD
[F:SIH]CTY          = [M:ADB3]CTY
[F:SIH]SAT          = [M:ADB3]SAT
[F:SIH]CRY          = [M:ADB3]CRY
[F:SIH]CRYNAM       = [M:ADB3]CRYNAM
[F:SIH]CRN          = [M:SIH0]CRN # X3-84945:Review mandatory mentions / Sales invoices (French law) X3-85350 (LCC 22/05/18)
Return
# -------------------------------------- #
# Alimentation de l'adresse livraison    #
# -------------------------------------- #
$CHARGE_ADRBPD
[F:SIV]BPDNAM(0)    = [M:ADB2]BPRNAM(0)
[F:SIV]BPDNAM(1)    = [M:ADB2]BPRNAM(1)
[F:SIV]BPDADDLIG(0) = [M:ADB2]BPAADDLIG(0)
[F:SIV]BPDADDLIG(1) = [M:ADB2]BPAADDLIG(1)
[F:SIV]BPDADDLIG(2) = [M:ADB2]BPAADDLIG(2)
[F:SIV]BPDPOSCOD    = [M:ADB2]POSCOD
[F:SIV]BPDCTY       = [M:ADB2]CTY
[F:SIV]BPDSAT       = [M:ADB2]SAT
[F:SIV]BPDCRY       = [M:ADB2]CRY
[F:SIV]BPDCRYNAM    = [M:ADB2]CRYNAM
If dim([F:SIV]ADRVAL) > 0 and dim([M:ADB2]ADRVAL) > 0  #LTA.sn
  [F:SIV]ADRVAL       = [M:ADB2]ADRVAL
Endif                                                  #LTA.en
Return

# -------------------------------------- #
# Alimentation de l'adresse règlement    #
# -------------------------------------- #
$CHARGE_ADRBPY
[F:SIH]BPAPAY       = [M:ADI4]BPAADD
[F:SIH]BPYNAM(0)    = [M:ADI4]BPRNAM(0)
[F:SIH]BPYNAM(1)    = [M:ADI4]BPRNAM(1)
[F:SIH]BPYADDLIG(0) = [M:ADI4]BPAADDLIG(0)
[F:SIH]BPYADDLIG(1) = [M:ADI4]BPAADDLIG(1)
[F:SIH]BPYADDLIG(2) = [M:ADI4]BPAADDLIG(2)
[F:SIH]BPYPOSCOD    = [M:ADI4]POSCOD
[F:SIH]BPYCTY       = [M:ADI4]CTY
[F:SIH]BPYSAT       = [M:ADI4]SAT
[F:SIH]BPYCRY       = [M:ADI4]CRY
[F:SIH]BPYCRYNAM    = [M:ADI4]CRYNAM
Return



#########################################################################
# Traitement appelées par SUBSIHA                                       #
#########################################################################

#--------------------------------------------------------------------#
# Recherche dernier no facture d'une commande suite à suppression    #
#--------------------------------------------------------------------#
# FGR 08/10/2015 : X3SUIVI111440 (début)
Subprog RECH_DERFACSOH()
Local Shortint WOK
Local Char     CRITERE(200)

# Pb d'optimisation
# Il faudrait ne passer içi que si la cde n'a pas été traitée sur une des lignes précédentes
# Or on a aucun moyen de le savoir
# Même si la cde est présente sur une ligne précédente, on ne passe içi que si cette ligne a été supprimée...

# Si date ligne livraison < date dernière liv de la cde, on ne change rien
If [F:SOH]LASINVDAT > [F:SIV]INVDAT End Endif

# FGR 08/10/2015 : X3SUIVI111440 (début)
Local File SINVOICE [SIH]
Local File SINVOICED [SID1]

Link [F:SID1] With [F:SIH]SIH0~=[F:SID1]NUM
&             As [LSID]
&             Where [F:SIH]INVTYP <> 5
&             Order By Key KLSID=[F:SID1]SOHNUM;[F:SID1]CREDAT;[F:SID1]NUM
# FGR 08/10/2015 : X3SUIVI111440 (fin)

# Pour trouver la dernière facture d'une commande
# On recherche toutes les lignes de facture de la commande
#CRITERE="BPCINV=[F:SOH]BPCINV & SALFCY=[F:SOH]SALFCY & SOHNUM=[F:SOQ]SOHNUM & NUM<>[F:SOH]PRFNUM"
#CRITERE="SOHNUM=[F:SOQ]SOHNUM & NUM<>[F:SOH]PRFNUM"                 # FGR 08/10/2015 : X3SUIVI111440
CRITERE="[F:SID1]SOHNUM=[F:SOQ]SOHNUM & [F:SID1]NUM<>[F:SOH]PRFNUM"  # FGR 08/10/2015 : X3SUIVI111440
# En suppression facture, on peut exclure les lignes de la facture en cours de suppression
#If GREP="A" CRITERE -= "& NUM<>[F:SID]NUM" Endif                    # FGR 08/10/2015 : X3SUIVI111440
If GREP="A" CRITERE -= "& [F:SID1]NUM<>[F:SID]NUM" Endif             # FGR 08/10/2015 : X3SUIVI111440

#Filter [SID1] Where evalue(CRITERE) Order By Key NEWCLE=CREDAT;SOHNUM
#Filter [SID1] Where evalue(CRITERE) Order By Key SID2               # FGR 08/10/2015 : X3SUIVI111440
Filter [LSID] Where evalue(CRITERE)                                  # FGR 08/10/2015 : X3SUIVI111440

WOK = 1
Raz [F:SOH]LASINVNUM, [F:SOH]LASINVDAT
#Read [SID1] Last
#Read [SID1]SID2 Last                                                # FGR 08/10/2015 : X3SUIVI111440
Read [LSID]KLSID Last                                                # FGR 08/10/2015 : X3SUIVI111440
If fstat
# --- Plus de ligne pour cette commande
   WOK = 0
   Goto RECH_FIN
Endif

# La facture lue est celle qu'on est entrain de traiter
While [F:SID1]NUM = [F:SID]NUM
   If !find([F:SID1]SOHNUM,[M:SIH4]SOHNUM(0..[M:SIH4]NBLIG-1))
#      Read [SID1]NEWCLE Prev
      #Read [SID1]SID2 Prev                                          # FGR 08/10/2015 : X3SUIVI111440
      Read [LSID]KLSID Prev                                          # FGR 08/10/2015 : X3SUIVI111440
   Else
# --- La ligne trouvée existe toujours : on la prend
      WOK = 1 : Break
   Endif
# --- Plus de ligne pour cette commande
   If fstat
      WOK = 0 : Break
   Endif
Wend

$RECH_FIN
If WOK = 1
    [F:SOH]LASINVNUM = [F:SID1]NUM
# -- A modifier : lire entete pour avoir la bonne date
    # FGR 12/11/2009 : X3SUIVI59833/X3SUIVI59938 : Relire l'entête.
    #Local File SINVOICE [SIH]                                       # FGR 08/10/2015 : X3SUIVI111440
    Read [SIH]SIH0=[F:SID1]NUM
    If fstat Then
      [F:SOH]LASINVDAT = [F:SID1]CREDAT
    Else
      [F:SOH]LASINVDAT = [F:SIH]ACCDAT
    Endif
Endif

Filter [SID1]
#Close Local File [SID1]

End

