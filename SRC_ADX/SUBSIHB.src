#########################################################################
# Traitements communs                                                   #
#########################################################################
#--------------------------------------------------------------------#
# Lecture de ts les fichiers utiles à une ligne                      #
#--------------------------------------------------------------------#
Subprog LECT_FIC(NLIG)
Value Integer NLIG

If [F:ITS]ITMREF <> [M:SIH4]ITMREF(NLIG)
     Read [F:ITS]ITS0 = [M:SIH4]ITMREF(NLIG)
     If fstat  Raz [F:ITS] : Endif
Endif
If [F:ITM]ITMREF <> [M:SIH4]ITMREF(NLIG)
     Read [F:ITM]ITM0 = [M:SIH4]ITMREF(NLIG)
     If fstat  Raz [F:ITM] : Endif
Endif
End
#--------------------------------------------------------------------#
# Initialisation des zones venant de l'entete commande               #
#--------------------------------------------------------------------#
Subprog INIT_SIH(NLIG, AFF)
Value Integer NLIG
Value Integer AFF
Local Integer I

[M:SIH4]DSTOFCY(NLIG)         = [M:SIH1]STOFCY

# --> Alimentation des commissions représentants
For I=0 To dim([M:SIH1]REP)-1
  Assign ("[M:SIH4]REP"+num$(I+1)+"(NLIG)") With evalue("[M:SIH1]REP("+num$(I)+")")
  If evalue ("[m:sih4]rep"+num$(I+1)+"(nlig)") <> ""
        If [F:BPC]BPCNUM<>[M:SIH0]BPCINV
            Read [F:BPC]BPC0 = [M:SIH0]BPCINV
            If fstat Raz [F:BPC] : Endif
        Endif
        If [F:REP]REPNUM <> evalue("[M:SIH4]REP"+num$(I+1)+"(NLIG)")
            Read [F:REP]REP0 = evalue("[M:SIH4]REP"+num$(I+1)+"(NLIG)")
            If fstat Raz [F:REP] : Endif
        Endif
        If [F:BPC]COMCAT <> 0
            Assign ("[M:SIH4]REPRAT"+num$(I+1)+"(NLIG)") With evalue("[F:REP]COMRAT"+num$(I+1)+"([F:BPC]COMCAT-1)")
        Endif
  Endif
Next

If dim([M:SIH2]STRDATSVC)>0 & !GLOCITAPRE
  [M:SIH4]STRDAT(NLIG)=[M:SIH2]STRDATSVC
  [M:SIH4]ENDDAT(NLIG)=[M:SIH2]ENDDATSVC
Endif

# --> Init du flag flux physique CEE
# If dim([M:SIH4]EECFLOPHY)>0 : [M:SIH4]EECFLOPHY(NLIG)=[M:SIH1]STOMVTFLG : Endif :# CPO transféré dans INIT_ITM
End

#--------------------------------------------------------------------#
# Initialisation des zones venant de l'article dans une ligne        #
#--------------------------------------------------------------------#
Subprog INIT_ITM(NLIG, ITM)
Value    Integer NLIG
Value    Char    ITM

Local    Char    VAT(GLONVAT)(3)

Raz [M]STAFIL(NLIG)

#[M]ITMDES1(NLIG)    = [F:ITS]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX", GLANGUE,[F:ITM]ITMREF,[M:SIH4]ITMDES1(NLIG), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
#Call CHARGE_ITMDES("DES1AXX", [M:SIH0]LAN,[F:ITM]ITMREF,[M:SIH4]ITMDES(NLIG)) From TRTX3
#If [M:SIH4]ITMDES(NLIG) = "" [M:SIH4]ITMDES(NLIG) = [M:SIH4]ITMDES1(NLIG) Endif
Call CHARGE_DEFITMDES("DES1AXX", [M:SIH0]LAN,[F:ITM]ITMREF,[M:SIH4]ITMDES(NLIG), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129

[M]SAU(NLIG)       = [F:ITM]SAU
[M]SAUSTUCOE(NLIG) = [F:ITM]SAUSTUCOE
[M]DACSAUCOE(NLIG) = [F:ITM]DACSAUCOE
[M]STU(NLIG)       = [F:ITM]STU
[M:SIH4]XSERMGTCOD(NLIG) = [F:ITM]SERMGTCOD
[M:SIH4]VACITM1(NLIG)  = [F:ITM]VACITM(0)
[M:SIH4]VACITM2(NLIG)  = [F:ITM]VACITM(1)
[M:SIH4]VACITM3(NLIG)  = [F:ITM]VACITM(2)
If dim([M:SIH4]SSTCOD)>0 : [M:SIH4]SSTCOD(NLIG)  = [F:ITM]SSTCOD : Endif    #101380.n
#Call ALITAXEV([M]VACBPR,[F:ITM]VACITM,VAT) From TRTX3
Call RECHVATCOD(1,1,[M:SIH1]BPCORD,ITM,"SIH4",NLIG,VAT) From TRTX3

[M]VAT1(NLIG)  = VAT(0)
[M]VAT2(NLIG)  = VAT(1)
[M]VAT3(NLIG)  = VAT(2)

If dim([M]TSICOD1(NLIG))>0: [M]TSICOD1(NLIG) = [F:ITM]TSICOD(0):Endif
If dim([M]TSICOD2(NLIG))>0: [M]TSICOD2(NLIG) = [F:ITM]TSICOD(1):Endif
If dim([M]TSICOD3(NLIG))>0: [M]TSICOD3(NLIG) = [F:ITM]TSICOD(2):Endif
If dim([M]TSICOD4(NLIG))>0: [M]TSICOD4(NLIG) = [F:ITM]TSICOD(3):Endif
If dim([M]TSICOD5(NLIG))>0: [M]TSICOD5(NLIG) = [F:ITM]TSICOD(4):Endif

[M]STOMGTCOD(NLIG) = [F:ITM]STOMGTCOD
If [F:ITM]STOMGTCOD>1
    If [F:ITF]ITMREF <> ITM | [F:ITF]STOFCY <> [M:SIH4]DSTOFCY(NLIG)
        Read [ITF] ITF0=ITM;[M:SIH4]DSTOFCY(NLIG)
        If fstat Raz [F:ITF] : Endif
    Endif
    # Si STOMVTFLG=1, le site expé.peut être à blc ITF peut être à blc
    If [F:ITF]STOMGTCOD>0 [M]STOMGTCOD(NLIG) = [F:ITF]STOMGTCOD Endif
Endif

# Alimentation flag stock maj
#If [M:SIH0]INVTYP=2 & [M:SIH1]STOMVTFLG=2 & [M:SIH4]STOMGTCOD(NLIG)<>1
#   [M:SIH4]RTNSTOUPD(NLIG) = 1
#Else
#   [M:SIH4]RTNSTOUPD(NLIG) = 2
#Endif
If [F:ITU]ITMREF <> ITM | [F:ITU]BPCNUM <> [M:SIH1]BPCORD
   Read [ITU] ITU0=ITM;[M:SIH1]BPCORD
   If fstat Raz [F:ITU] Endif
Endif
If [F:ITU]SAU <> "" & find([M:SIH4]LINTYP(NLIG), 1,2,6,10) & [M:SIH4]FOCFLG(NLIG) <> 3
    [M:SIH4]SAU(NLIG) = [F:ITU]SAU
    [M:SIH4]SAUSTUCOE(NLIG) = [F:ITU]SAUSTUCOE
    [M:SIH4]DACSAUCOE(NLIG) = 1
Endif
#Call ALISAUCOE(ITM, [M:SIH1]BPCORD, [M:SIH4]SAU(NLIG), [M:SIH4]STU(NLIG), [M:SIH4]SAUSTUCOE(NLIG)) From TRTVENQTE
Raz [M]SIDTEX(NLIG)
If find(GSALTEXLIN,3,4,5)
   [M:SIH4]SIDTEX(NLIG) = [F:ITU]ITSTEX
   If [M:SIH4]SIDTEX(NLIG)=""
      [M:SIH4]SIDTEX(NLIG) = [F:ITS]ITSTEX
   Endif
Endif

# CPO 24/07/2008 Pour la DEB
If dim([M:SIH4]EECFLOPHY)>0
  # --- Si article non soumis à la DEB => EECFLOPHY = Non
  If [F:ITM]EECGES = 2
      [M:SIH4]EECFLOPHY(NLIG)=[M:SIH1]STOMVTFLG
  Else
      [M:SIH4]EECFLOPHY(NLIG)=1 : Diszo [M:SIH4]EECFLOPHY(NLIG)
  Endif
Endif
# fin CPO

End

#----------------------------------------------------------------------------------#
# Vérification des codes taxes :                                                   #
# Appelé en fin de saisie de ligne pour vérifier si les codes taxes ont changé     #
#        suite à modification d'un champs entrant dans la détermination de la taxe #
# --> Si changement : Chargement des codes taxes                                   #
#                     Recalcul des montants de base calcul taxe (CLCAMT1 et 2)     #
#                     Dde recherche tarif si TTC                                   #
#                     Recalcul de la marge                                         #
#----------------------------------------------------------------------------------#
Subprog VERIF_VATCOD (NLIG)
Value Integer NLIG

Local Char    WVAT(GLONVAT)(3)
Local Integer INICPRPRI : INICPRPRI=1

Call RECHVATCOD(1,1,[M:SIH1]BPCORD,[M:SIH4]ITMREF(NLIG),"SIH4",NLIG,WVAT) From TRTX3

If [M:SIH4]VAT1(NLIG)<>WVAT(0) | [M:SIH4]VAT2(NLIG)<>WVAT(1) | [M:SIH4]VAT3(NLIG)<>WVAT(2)
    [M:SIH4]VAT1(NLIG) = WVAT(0)
    [M:SIH4]VAT2(NLIG) = WVAT(1)
    [M:SIH4]VAT3(NLIG) = WVAT(2)
    # 101874 : V9 : Taxe code control
    #If [M:SIH4]QTY(NLIG)<>0 Call TRTRECTARD("SIH", [M:SIH2]CUR, NLIG) From TRTVENTAR Endif
    If [M:SIH4]QTY(NLIG)<>0
      Local Integer WOK : WOK=1
      If !GIMPORT Call OUINON (mess(247,191,1)-":"-mess(21,191,1),WOK) From GESECRAN : Endif
      If WOK=2
        Call TRTRECTARD("SIH", [M:SIH2]CUR, NLIG) From TRTVENTAR
      Endif
    Endif
    # 101874
    Call CLCPFM([M:SIH4]DSTOFCY(NLIG), [M]PRITYP, [M]CHGTYP, [M:SIH0]INVDAT, [M:SIH2]CUR,
&           NLIG,INICPRPRI) From TRTVENPRI
Endif

End

#-------------------------------------#
# Traitement apres ligne              #
#-------------------------------------#
Subprog APRES_LIGNE(NLIG, AFF)
Value Integer NLIG
Value Integer AFF

# --> Contrôle du prix net
Call CTLNETPRI([M:SIH1]BPCORD, [M:SIH2]CURTYP, [M:SIH0]INVDAT, [M:SIH0]CUR,NLIG) From TRTVENPRI
#If mkstat=2 End Endif
# --> Contrôle de la marge
Call CTLPFM([M:SIH0]CUR,[M:SIH4]CPRPRI(NLIG), NLIG) From TRTVENPRI
#If mkstat=2 End Endif
# --> Calcul du montant cde ht et ttc de la ligne
Gosub CALC_INV
Gosub CALC_DSP From TRTVENDIV
Call ADD_TOT(NLIG)
If !GIMPORT & AFF = 1 Affzo [M:SIH4]PFMTOT : Endif
End
#-------------------------------------------------------------#
# Calcul des montants total de la facture                     #
#-------------------------------------------------------------#
Subprog ADD_TOT(NLIG)
Value Integer NLIG
If [M:SIH4]QTY(NLIG)<>0
    MNTPFM = [M:SIH4]PFM(NLIG)*[M:SIH4]QTY(NLIG)
    Call ARRDEV (MNTPFM, [M:SIH0]CUR) From TRTDIV
Else
    MNTPFM = [M:SIH4]PFM(NLIG)
Endif
[M:SIH4]PFMTOT += MNTPFM

[M:SIH0]DSPTOTQTY += [M:SIH4]QTYSTU(NLIG)
# Issue 107888 - 2016-06-20 by CPO : US120 Normal order -> Invoices (by using a scheduling invoice)
#[M:SIH0]DSPTOTWEI += [M:SIH4]DSPLINWEI(NLIG)
#[M:SIH0]DSPTOTVOL += [M:SIH4]DSPLINVOL(NLIG)
If [M:SIH0]INVTYP=1 and [M:SIH4]SIDORI(NLIG)=10 and [M:SIH4]VCRINVCNDLIN(NLIG)>0
  If [M:SIH4]VCRINVCNDTYP(NLIG)=10
    #--No weight or volume
    Raz [M:SIH4]DSPLINWEI(NLIG), [M:SIH4]DSPLINVOL(NLIG)
  Else
    #--For now, we do as normaly
    [M:SIH0]DSPTOTWEI += [M:SIH4]DSPLINWEI(NLIG)
    [M:SIH0]DSPTOTVOL += [M:SIH4]DSPLINVOL(NLIG)
  Endif
Else
  [M:SIH0]DSPTOTWEI += [M:SIH4]DSPLINWEI(NLIG)
  [M:SIH0]DSPTOTVOL += [M:SIH4]DSPLINVOL(NLIG)
Endif
# End issue 107888 US120

Local Char VCRENT(GLONVCR)
If [M:SIH4]SDHNUM(NLIG)<>""
    VCRENT=[M:SIH4]SDHNUM(NLIG)
Elsif [M:SIH4]SOHNUM(NLIG)<>""
    VCRENT=[M:SIH4]SOHNUM(NLIG)
Elsif [M:SIH4]SQHNUM(NLIG)<>""
    VCRENT=[M:SIH4]SQHNUM(NLIG)
Elsif [M:SIH4]SRHNUM(NLIG)<>""
    #--CPO 79550 Transferts : Retours -> Avoirs sur retours
    #--Il faut passer le numéro de la livraison de la ligne de retour...
    If clalev([F:SRD])>0
      If ([F:SRD]SRHNUM<>[M:SIH4]SRHNUM(NLIG) or [F:SRD]SRDLIN<>[M:SIH4]SRDLIN(NLIG))
        Read [F:SRD]SRD0=[M:SIH4]SRHNUM(NLIG);[M:SIH4]SRDLIN(NLIG)
        If fstat : Raz [F:SRD] : Endif
      Endif
      VCRENT=[F:SRD]SDHNUM
    Else
      #If clalev([F:SRD99])=0 : Local File SRETURND [F:SRD99] : Endif #--Je l'ai fait dans le $OUVRE
      If ([F:SRD99]SRHNUM<>[M:SIH4]SRHNUM(NLIG) or [F:SRD99]SRDLIN<>[M:SIH4]SRDLIN(NLIG))
        Read [F:SRD99]SRD0=[M:SIH4]SRHNUM(NLIG);[M:SIH4]SRDLIN(NLIG)
        If fstat : Raz [F:SRD99] : Endif
      Endif
      VCRENT=[F:SRD99]SDHNUM
    Endif
    #--/
Elsif [M:SIH4]CONNUM(NLIG)<>"" #--CPO 79550 Transferts : Contrats de services -> Factures
    VCRENT=[M:SIH4]CONNUM(NLIG)
Elsif [M:SIH4]XSIHORINUM(NLIG)<>""
    VCRENT=[M:SIH4]XSIHORINUM(NLIG)
Endif

# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
#-- Normal order -> Invoices (by using a scheduling invoice)
If [M:SIH0]INVTYP=1 and [M:SIH4]SIDORI(NLIG)=10 and [M:SIH4]VCRINVCNDLIN(NLIG)>0
  If [M:SIH4]VCRINVCNDTYP(NLIG)=10
    VCRENT=[M:SIH4]SOHNUM(NLIG)
  Else
    #--For later scheduling invoice origins...
  Endif
Endif
# End issue 107888

If [M:SIH4]QTY(NLIG)<>0
    Call MAJ_SFIT_QTY("M", "SIH2", VCRENT, [M:SIH4]QTYSTU(NLIG), [M:SIH4]QTY(NLIG) * [M:SIH4]NETPRINOT(NLIG), [M:SIH4]DSPLINWEI(NLIG), [M:SIH4]DSPLINVOL(NLIG)) From SUBSFIT
Endif

# Issue 106150
#---------------------------------------------------------------------#
# Point d'entree pour le calcul  de montants spécifiques              #
#---------------------------------------------------------------------#
GPOINT="ADD_TOT" : Gosub ENTREE From EXEFNC
# End issue 106150

End

Subprog SUB_TOT(NLIG)
Value Integer NLIG

If [M:SIH4]QTY(NLIG)<>0
    MNTPFM = [M:SIH4]PFM(NLIG)*[M:SIH4]QTY(NLIG)
    Call ARRDEV (MNTPFM, [M:SIH0]CUR) From TRTDIV
Else
    MNTPFM = [M:SIH4]PFM(NLIG)
Endif
[M:SIH4]PFMTOT -= MNTPFM

[M:SIH0]DSPTOTQTY -= [M:SIH4]QTYSTU(NLIG)
# Issue 107888 - 2016-06-20 by CPO : US120 Normal order -> Invoices (by using a scheduling invoice)
#[M:SIH0]DSPTOTWEI -= [M:SIH4]DSPLINWEI(NLIG)
#[M:SIH0]DSPTOTVOL -= [M:SIH4]DSPLINVOL(NLIG)
If [M:SIH0]INVTYP=1 and [M:SIH4]SIDORI(NLIG)=10 and [M:SIH4]VCRINVCNDLIN(NLIG)>0
  If [M:SIH4]VCRINVCNDTYP(NLIG)=10
    #--Don't have weight or volume
    Raz [M:SIH4]DSPLINWEI(NLIG), [M:SIH4]DSPLINVOL(NLIG)
  Else
    #--For now, we do as for normal
    [M:SIH0]DSPTOTWEI -= [M:SIH4]DSPLINWEI(NLIG)
    [M:SIH0]DSPTOTVOL -= [M:SIH4]DSPLINVOL(NLIG)
  Endif
Else
  [M:SIH0]DSPTOTWEI -= [M:SIH4]DSPLINWEI(NLIG)
  [M:SIH0]DSPTOTVOL -= [M:SIH4]DSPLINVOL(NLIG)
Endif
# End issue 107888 US120

Local Char VCRENT(GLONVCR)
If [M:SIH4]SDHNUM(NLIG)<>""
    VCRENT=[M:SIH4]SDHNUM(NLIG)
Elsif [M:SIH4]SOHNUM(NLIG)<>""
    VCRENT=[M:SIH4]SOHNUM(NLIG)
Elsif [M:SIH4]SQHNUM(NLIG)<>""
    VCRENT=[M:SIH4]SQHNUM(NLIG)
Elsif [M:SIH4]SRHNUM(NLIG)<>""
    #--CPO 79550 Transferts : Retours -> Avoirs sur retours
    #--Il faut passer le numéro de la livraison de la ligne de retour...
    If clalev([F:SRD])>0
      If ([F:SRD]SRHNUM<>[M:SIH4]SRHNUM(NLIG) or [F:SRD]SRDLIN<>[M:SIH4]SRDLIN(NLIG))
        Read [F:SRD]SRD0=[M:SIH4]SRHNUM(NLIG);[M:SIH4]SRDLIN(NLIG)
        If fstat : Raz [F:SRD] : Endif
      Endif
      VCRENT=[F:SRD]SDHNUM
    Else
      If clalev([F:SRD99])=0 : Local File [F:SRD99] : Endif
      If ([F:SRD99]SRHNUM<>[M:SIH4]SRHNUM(NLIG) or [F:SRD99]SRDLIN<>[M:SIH4]SRDLIN(NLIG))
        Read [F:SRD99]SRD0=[M:SIH4]SRHNUM(NLIG);[M:SIH4]SRDLIN(NLIG)
        If fstat : Raz [F:SRD99] : Endif
      Endif
      VCRENT=[F:SRD99]SDHNUM
    Endif
    #--/
Elsif [M:SIH4]CONNUM(NLIG)<>"" #--CPO 79550 Transferts : Contrats de services -> Factures
    VCRENT=[M:SIH4]CONNUM(NLIG)
Elsif [M:SIH4]XSIHORINUM(NLIG)<>""
    VCRENT=[M:SIH4]XSIHORINUM(NLIG)
Endif

# Issue 107888 - 2015-10-28 by CPO : Scheduled invoices object management
#-- Normal order -> Invoices (by using a scheduling invoice)
If [M:SIH0]INVTYP=1 and [M:SIH4]SIDORI(NLIG)=10 and [M:SIH4]VCRINVCNDLIN(NLIG)>0
  If [M:SIH4]VCRINVCNDTYP(NLIG)=10
    VCRENT=[M:SIH4]SOHNUM(NLIG)
  Else
    #--For later scheduling invoice origins...
  Endif
Endif
# End issue 107888

Call MAJ_SFIT_QTY("M", "SIH2", VCRENT, -1*[M:SIH4]QTYSTU(NLIG), -1*[M:SIH4]QTY(NLIG) * [M:SIH4]NETPRINOT(NLIG), -1*[M:SIH4]DSPLINWEI(NLIG), -1*[M:SIH4]DSPLINVOL(NLIG)) From SUBSFIT

# Issue 106150
#---------------------------------------------------------------------#
# Point d'entree pour le calcul  de montants spécifiques              #
#---------------------------------------------------------------------#
GPOINT="SUB_TOT" : Gosub ENTREE From EXEFNC
# End issue 106150

End

#-----------------------------------------#
# Suppression d'une ligne dans le tableau #
#-----------------------------------------#
Subprog SUP_LIG(NLIG, WRET)
Value Integer NLIG
Variable Integer WRET    : WRET = 0

Call SUB_TOT(NLIG) From SUBSIHB

If  [M:SIH0]INVTYP=1 & [M:SIH4]STOMGTCOD(NLIG)<>1 &
& (([M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG=2)      | [M:SIH1]SIHORI=2 |
&  ([M:SIH1]SIHORI=3 & [M:SIH4]SDHNUM(NLIG)=""))
   Call DELSTOSORW(NLIG,NLIG,"SIH4",[M:SIH4]DSTOFCY(NLIG),WRET) From STKSOR
   If WRET<>0 mkstat=2 : End Endif
Endif

#--CPO 79343
If GREP<>"C" and GSIHSUPPLIGDSP <> 999999
  Local Integer WTEMPDSP : Raz WTEMPDSP
  Call CTLSUPP_EXISTDSP("SIH",NLIG,WTEMPDSP) From TRTVENDIV
  If WTEMPDSP=1
    If [M:SIH4]CREFLG(NLIG)<>0
      GSIHSUPPLIGDSP = 999999 :#--CPO La suppression d'une ligne non pickée est définitive si on enregistre...
    Endif
  Endif
Endif
#--/CPO

If dim([M]ITMREF) = [M]NBLIG
     Dela NLIG,1 [M:SIH4]NBLIG
Else Dela NLIG,1,[M:SIH4]NBLIG-1 [M:SIH4]NBLIG:Endif
[M:SIH4]NBLIG -=1

End

#########################################################################
#     GENERATION d'une FACTURE à partir du bouton FACTURE               #
#########################################################################

$GEN_FAC

Local Integer I

Default Mask [SIH4]



# Bug 60948
## Si facture, on récupère le type de facture utilisateur comme en facturation automatique
#If GINVTYP=1 & dim(GSIVTYP)<>0 & GSIVTYP<>""
#    Read [TSV]TSV0=GSIVTYP
#    If !fstat
#        [M:SIH0]SIVTYP=GSIVTYP
#        Call GET_ATEXTRA("TABSIVTYP","SHOAXX",GLANGUE,[M:SIH0]ZSIVTYP) From TRTX3TEX
#    Endif
#Endif

#Gosub RAZCRE From SUBSIHA
Gosub RAZCRE_BOUTON From SUBSIHA
# Bug 60948


GREP="C" : # On gère le mode création, pour les calculs de SUBSFIT

GOK = 1

# Bouton facture --> on force détermination auto du stock
GSLTSTKFLG = 2

Call TEMPON("V") From GESECRAN

#------------------------------
# Alimentation entête facture
#------------------------------
Case WORI
 When 1 : GFCY = [M:SQH0]SALFCY
 When 2 : GFCY = [M:SOH0]SALFCY
 When 3 : GFCY = [M:SDH0]SALFCY
 When 6 : GFCY = [M:SOH0]SALFCY # Issue 107888 - 2016-08-19 by CPO : Scheduling invoice - Invoice button from Orders
Endcase
Raz I
#Call GETDEV(GFCY) From DEVSUB
# Chargement globales référenciels, comptes et sections de la société
##VPO 27/08/09 56370 pb en creation depuis livraison (pas les axes)
##Call GETCPY(GFCY,"SLT",4,GFLAG) From TRTX3CPT
#Call GETCPY(GFCY,"SLT",5,GFLAG) From TRTX3CPT                              : # Bug 60948
Gosub CHARG_PARAM From SUBSIHA : If GERR=1 Raz GOK : Goto GEN_FAC_FIN Endif : # Bug 60948
Call GLOBVAR(GFCY,"VEN") From TRTX3
# Bug 60948

# Si facture, on récupère le type de facture utilisateur comme en facturation automatique
If GINVTYP=1 & dim(GSIVTYP)<>0 & GSIVTYP<>""
    #- X3Suivi 71937 Multi-législation -#
    Local Integer WRET
    Call LEC_TSV_LEG(GCURLEG,GSIVTYP,WRET) From TRTLECLEG
    If !WRET
    #--CPO 71937 T757 Contrôle de cohérence
    Call CTL_ML_CONSISTENCY("TSV", "NON",[F:TSV]SIVTYP,[F:TSV]LEG,AVOID.ACHAR,GFCY,GCURLEG,WRET,AVOID.ACHAR) From TRTVENCTL
    If !WRET
    #--/
          [M:SIH0]SIVTYP=GSIVTYP
          Call GET_ATEXTRA("TABSIVTYP","SHOAXX",GLANGUE,[M:SIH0]ZSIVTYP) From TRTX3TEX
          Local Char WSIVTYP(GLONTSV) #X3-96149 (JUCON 16/06/2018)
          Gosub INIT_SIVTYP From SUBSIHB #X3-96149 (JUCON 16/06/2018)
#          Gosub CHARG_SIVTYP From SUBSIHB #--CPO 71937 T757 Contrôle de cohérence (déplacé dans le IF !WRET) #X3-96149 (JUCON 16/06/2018)
        Endif
    Endif
    #Gosub CHARG_SIVTYP From SUBSIHB #--CPO 71937 T757 Contrôle de cohérence (déplacé dans le IF !WRET)
Endif
If [M:SIH0]SIVTYP=""
    Local Char WSIVTYP(GLONTSV)
    # Initiliasation du type facture et chargement des données
    Gosub INIT_SIVTYP From SUBSIHB
    If GERR=1 Raz GOK : Goto GEN_FAC_FIN : Endif
    [M:SIH0]SIVTYP=WSIVTYP
Endif
# Bug 60948

#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
If func AFNC.ACTIV("KPO")
  If func PORLEGLIB.PORLEG([M:SIH0]SALFCY,"")=1
    If !clalev([F:TSV])    Local File TABSIVTYP  [TSV]  : Endif

    Local Integer STAT

    Call LEC_TSV_LEG(GCURLEG, [M:SIH0]SIVTYP, STAT) From TRTLECLEG

    If STAT = 0
      If [F:TSV]SAFTINVTYP = 2
        GMESSAGE = mess(79,7711,1)
        GERR = 1 : Raz GOK : Goto GEN_FAC_FIN
      Endif
    Endif
  Endif
Endif
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END

[M]SALFCY=GFCY  : # Bug 72188
# Bug 69179 : Ctrl date de facture
Call C_INVDAT([M]INVDAT) From SUBSIH
If mkstat GMESSAGE=mess(60,124,1)-":"-format$(GFMDAT,[M]INVDAT)-":"-GMESSAGE : GERR=1 : Raz GOK : Goto GEN_FAC_FIN : Endif

Case WORI
 When 1 : Read [SQH]SQH0=[M:SQH0]SQHNUM     : # Origine devis
          If fstat
             Call RSTA("SQH",[M:SQH0]SQHNUM) From GLOCK
             Raz GOK : Goto GEN_FAC_FIN
          Endif
          # Contrôle de l'insertion
          If [M:SIH4]NBLIG+[F:SQH]LINNBR >= dim([M:SIH4]ITMREF)-1
             GERR=1 : GMESSAGE=mess(122,199,1)
             Raz GOK : Goto GEN_FAC_FIN
          Endif
          Call ALISQHSIH From TRTVENFAC
 When 2 : Read [SOH]SOH0=[M:SOH0]SOHNUM     : # Origine commande
          If fstat
             Call RSTA ("SOH",[M:SOH0]SOHNUM) From GLOCK
             Raz GOK : Goto GEN_FAC_FIN
          Endif
          # Simulation picking commande pour utilisation du composant commun
          currbox = GBOXSO3
          Call ALISOHSIH From TRTVENFAC
 When 3 : Read [SDH]SDH0=[M:SDH0]SDHNUM     : # Origine livraison
          If fstat
             Call RSTA ("SDH",[M:SDH0]SDHNUM) From GLOCK
             Raz GOK : Goto GEN_FAC_FIN
          Endif
          # Contrôle de l'insertion
          If [M:SIH4]NBLIG+[F:SDH]LINNBR >= dim([M:SIH4]ITMREF)-1
             GERR=1 : GMESSAGE=mess(122,199,1)
             Raz GOK : Goto GEN_FAC_FIN
          Endif
          Call ALISDHSIH From TRTVENFAC
Endcase

# Suppression factures non validées
Call PARAML(GFCY,"SIVSUP",WPARAM) From ADOVAL
GSIVSUP = val(WPARAM)
# Ligne à 0 interdites
Call PARAML(GFCY,"SIVNULL",WPARAM) From ADOVAL
GSIVNULL = val(WPARAM)

#------------------------------
# Alimentation lignes facture
#------------------------------
Case WORI
 When 1 : # Boucle de lecture du devis pour traiter les lignes à facturer
          For IJL=0 To [M:SQH2]NBLIG-1
             Read [SQD]SQD0=[M:SQH0]SQHNUM;[M:SQH2]SQDLIN(IJL)
             If fstat
                Call RSTA ("SQD",[M:SQH0]SQHNUM-num$([M:SQH2]SQDLIN(IJL))) From GLOCK
                Raz GOK : Break
             Endif
             Gosub TRT_LIGDEV From SUBSIHC
             Raz GERR  # FGR 02/12/2011 : X3SUIVI71065
          Next IJL

 When 2 : # Boucle de lecture de la commande pour traiter les lignes à facturer
          For IJL=0 To [M:SOH4]NBLIG-1
             # Si GRPFLG(IJL) est à Oui ou si proforma, la ligne est à facturer
#             If [M:SOH4]GRPFLG(IJL) = 2 | GINVTYP = 5
             If [M:SOH4]GRPFLG(IJL) = 2
                Read [SOQ]SOQ0=[M:SOH0]SOHNUM;[M:SOH4]SOPLIN(IJL);[M:SOH4]SOPLIN(IJL)
                If fstat
                   Call RSTA ("SOQ",[M:SOH0]SOHNUM-num$([M:SOH4]SOPLIN(IJL))) From GLOCK
                   Raz GOK : Break
                Endif
                Read [SOP]SOP0=[M:SOH0]SOHNUM;[M:SOH4]SOPLIN(IJL);[M:SOH4]SOPLIN(IJL)
                If fstat
                   Call RSTA ("SOP",[M:SOH0]SOHNUM-num$([M:SOH4]SOPLIN(IJL))) From GLOCK
                   Raz GOK : Break
                Endif
                #--- Lecture des tables articles
                Gosub LEC_TABART From SUBSIHC
                # Contrôle de l'insertion
                If [M:SIH4]NBLIG+1 >= dim([M:SIH4]ITMREF)-1
                   GERR=1 : GMESSAGE=mess(122,199,1)
                   Raz GOK : Break
                Endif
                # On simule un picking commande pour utiliser un composant commun
                currbox = GBOXSO3

                Gosub TRT_LIGCDE From SUBSIHC
                Raz GERR  # FGR 02/12/2011 : X3SUIVI71065
             Endif
          Next IJL

 When 3 : # Boucle de lecture de la livraison pour traiter les lignes à facturer
          For IJL=0 To [M:SDH1]NBLIG-1
             # Point d'entrée pour interdire la facturation d'une ligne de livraison
             Local Integer WPE_SDHINVLIG : WPE_SDHINVLIG = 1
             GPOINT="SDHINVLIG" : Gosub ENTREE From EXEFNC
             # la ligne est à facturer uniquement si tout n'est pas retourné
             #If ((GDLVRTNCNO=1 & [M:SDH1]QTY(IJL)>[M:SDH1]RTNQTY(IJL)) | GDLVRTNCNO=2) & WPE_SDHINVLIG=1
             # Dde 71811 : Si livraisons pour sous-traitance, on facture ce qui n'est pas retourné (Lors d'une proforma)
             # Dde 71811 : Si livraisons inter-site, on facture ce qui n'est pas retourné (Lors d'une proforma)
             # Bug 46937
             # Si liv. de prêt, on facture ce qui n'est pas retourné
             # Si liv. normales et pas de facturation qté retournée (GDLVRTNCNO=1), on ne facture que ce qui n'est pas retourné
             # Si liv. normales et facturation qté retournée (GDLVRTNCNO=2), on facture tout
             If (([M:SDH1]QTY(IJL)>[M:SDH1]RTNQTY(IJL) & ([M:SDH0]LND=2 | GDLVRTNCNO=1 | (dim([M:SDH0]SCO)>0 & [M:SDH0]SCO=2) | ([M]BETFCY=2 & [M]BETCPY<=1)))     |
&               ([M:SDH0]LND=1 & GDLVRTNCNO=2 & (dim([M:SDH0]SCO)<0 | [M:SDH0]SCO=1) & ([M]BETFCY=1 | [M]BETCPY=2))) & WPE_SDHINVLIG=1
                 Read [SDD]SDD0=[M:SDH0]SDHNUM;[M:SDH1]SDDLIN(IJL)
                 If fstat
                    Call RSTA ("SDD",[M:SDH0]SDHNUM-num$([M:SDH1]SDDLIN(IJL))) From GLOCK
                    Raz GOK : Break
                 Endif
                 # On simule un picking livraison pour utiliser un composant commun
                 currbox = GBOXSD1
                 Gosub TRT_LIGLIV From SUBSIHC
                 Raz GERR  # FGR 02/12/2011 : X3SUIVI71065
             Endif
           Next IJL
Endcase

# Issue 107888 - 2016-08-19 by CPO : Scheduling invoice - Invoice button from Orders
If WORI = 6
  Gosub GEN_FAC_SOH_SVIC From LIBSAL_INVCND_SIH
  If GOK=0 Goto GEN_FAC_FIN Endif

Endif
# End issue 107888

# Simulation de picking : FIN_PICK
Case WORI
 When 1 : # Boucle de lecture du devis pour traiter les lignes à facturer
    Call SQH_SIH_CALCUL From SUBSFIT
 When 2 : # Boucle de lecture de la commande pour traiter les lignes à facturer
    Call SOH_SIH_CALCUL From SUBSFIT
 When 3 : # Boucle de lecture de la livraison pour traiter les lignes à facturer
    Call SDH_SIH_CALCUL From SUBSFIT
 When 6 : # Issue 107888 - 2016-08-19 by CPO : Scheduling invoice - Invoice button from Orders
          #--No need to call : done in the $GEN_FAC_SOH_SVIC from LIBSAL_INVCND_SIH
Endcase

GREP="" : # On gère le mode création, pour les calculs de SUBSFIT

Call PJT_INFO_MSG() From TRTPJT  # FGR 14/12/2011 : X3SUIVI71065

Raz currbox

If [M:SIH4]NBLIG=0
   GERR=1 : GMESSAGE=mess(68,192,1) : Raz GOK
Endif
If GOK=0 Goto GEN_FAC_FIN Endif

# Spécificité USA
Local Char WKU_MAJ : WKU_MAJ="2"

Gosub NEW_FACTURE From TRTVENFACC
Gosub CHARG_TABLEAUX From TRTVENFACC
Gosub CAL_FACTURE    From TRTVENFACC

[M:SIH4]INVNOT = [M:SIHV]INVNOT
[M:SIH4]INVATI = [M:SIHV]INVATI

# --> Lignes à zéro interdites (1=non 2=oui)
If GSIVNULL=2 & sum([M:SIH4]AMTNOTLIN)=0
   GERR=1  : GMESSAGE = mess(91,106,1)
   Call TEMPOFF From GESECRAN
   Raz GOK : Return
Endif

#--CPO 87923 Gestion des prélèvements SDD
#--Hors proformas
If find([M:SIH0]INVTYP, 1,2)
Gosub INIT_CTL_UMRNUM
Endif
#--/

# Création de la facture
Gosub CREATION From GOBJET1

$GEN_FAC_FIN
Call TEMPOFF From GESECRAN

Return

#########################################################################
#########################################################################
#     TRAITEMENT POUR LA GESTION DES STOCKS DANS LES AVOIRS             #
#########################################################################
#########################################################################
#     Etiquette appelée dans l'action VALLIG                            #
#########################################################################
#-------------------------------#
# Maj des stocks                #
#-------------------------------#
$MAJ_STOCK

Local Decimal LQTA
Local Decimal LSHT
Local Integer LNBR, LNBJ, LRET

Raz [M:STW]
[M:STW]STOFCY  = [M:SIH4]DSTOFCY(NOL)
[M:STW]TRSTYP  = 12
[M:STW]TRAFLG  = 1 : # Pas de trace
[M:STW]VCRTYP  = 18
[M:STW]VCRNUM  = [M:SIH0]NUM
[M:STW]VCRLIN  = [M:SIH4]SIDLIN (NOL)
[M:STW]ITMREF  = [M:SIH4]ITMREF (NOL)
[M:STW]MVTDES  = [M:SIH4]MVTDES (NOL)
[M:STW]PRIORDH = [M:SIH4]PRIORD (NOL)
[M:STW]PJT     = ""
[M:STW]TRSFAM  = [M:SIH1]TRSFAM
[M:STW]TRSCOD  = [M:SIH0]TRSCOD
[M:STW]ENTCOD  = [M:SIH0]ENTCOD
[M:STW]BPRNUM  = [M:SIH0]BPCINV
[M:STW]CUR     = [M:SIH0]CUR

[M:STW]IPTDAT  = [M:SIH0]INVDAT
[M:STW]BETCPY  = [M:SIH1]BETCPY
If [M:SIH1]BETFCY=2
    [M:STW]TRFFCY = [M:SIH4]DSTOFCY(NOL)
Endif
If [M:SIH4]XSIHORINUM(NOL)<>""
    [M:STW]VCRTYPORI = 5
    [M:STW]VCRNUMORI = [M:SIH4]XSIHORINUM(NOL)
    [M:STW]VCRLINORI = [M:SIH4]SIDORILIN(NOL)
    # 87686
    # (SID1 normalement ouvert ds OUVRE)
    If !clalev([F:SID1]) Local File SINVOICED [SID1] Endif
    ##--- Bug 78387
    #If [F:SID]NUM<>[M:STW]VCRNUMORI & [F:SID]SIDLIN<>[M:STW]VCRLINORI
    #   Read [SID]SID0=[M:STW]VCRNUMORI;[M:STW]VCRLINORI
    #Endif
    #[M:STW]ORIFCY = [F:SID]STOFCY
    If [F:SID1]NUM<>[M:STW]VCRNUMORI & [F:SID1]SIDLIN<>[M:STW]VCRLINORI
       Read [SID1]SID0=[M:STW]VCRNUMORI;[M:STW]VCRLINORI
    Endif
    [M:STW]ORIFCY = [F:SID1]STOFCY
    #87686
    #---
Endif
[M:STW]CCECOD  ="STKAVO"

Call ALISTOWORK (2,[M:SIH4]WSTOSEQ(NOL),LQTA,LSHT,LNBR,LNBJ,LRET) From STKINT
Call MAJ_STOCK From STKMAJ
If GOK
   If GREP <> "A"
      Call STKFREQCQ("SIH4",[M:SIH4]DSTOFCY(NOL),NOL,[M:SIH4]ITMREF(NOL),"","V",[M:SIH4]QUAFLG(NOL),0) From STKACT   # hcb V6CQ (freq)
   Endif
Endif

Return

##########################################################################
##########################################################################
#     ETIQUETTES APPELEES PAR LES COMPOSANTS D'ENTREE EN STOCK
##########################################################################
#########################################################################
# Bouton Détail  en click droit sur NBLIG  Action SAISTOENT             #
# Fenêtre Détail en APRES_NBLIG            Action SAISTOENT             #
#########################################################################
# ETIQUETTES APPELEES PAR TRTSTOENTA                                    #
#########################################################################
#-----------------------------------------------------------------------#
# Appelée dans CHARG_PARAM_STOENT                                       #
# Chargement Ecran STOENT (partie parametrage) creations des entrées    #
#-----------------------------------------------------------------------#
Subprog CHARG_PARAM_STOENT (LLIG)
Value Integer LLIG

[M:ENT]STOFCY    = [M:SIH4]DSTOFCY(LLIG)
[M:ENT]ITMREF    = [M:SIH4]ITMREF(LLIG)
[M:ENT]QTYTOENT  = [M:SIH4]QTY(LLIG)
[M:ENT]PCUTOENT  = [M:SIH4]SAU(LLIG)
[M:ENT]COETOENT  = [M:SIH4]SAUSTUCOE(LLIG)
[M:ENT]STU       = [M:SIH4]STU(LLIG)
[M:ENT]VCRNUM    = [M:SIH0]NUM
[M:ENT]VCRLIN    = [M:SIH4]SIDLIN(LLIG)
[M:ENT]WSTOSEQ   = [M:SIH4]WSTOSEQ(LLIG)
[M:ENT]MVTDES    = [M:SIH4]MVTDES(LLIG)
[M:ENT]PRI       = [M:SIH4]PRIORD(LLIG)
[M:ENT]QUAFLG    = [M:SIH4]QUAFLG(LLIG)        # hcb V6CQ
[M:ENT]QUAFRE    = [M:SIH4]QUAFRE(LLIG)        # hcb V6CQ
If dim([M:SIH4]WRH)>0
  [M:ENT]XWRH      = [M:SIH4]WRH(LLIG)
Endif
[M:ENT]TRSTYP    = 12                   : # Type mouvement (M.704) : Retour livraison
[M:ENT]TRSCOD    = [M:SIH0]TRSCOD       : # Code mouvement
[M:ENT]TRSFAM    = [M:SIH1]TRSFAM
[M:ENT]IPTDAT    = [M:SIH0]INVDAT       : # Date imputation
[M:ENT]BPRNUM    = [M:SIH0]BPCINV
[M:ENT]CUR       = [M:SIH0]CUR

[M:ENT]SRGWAIFLG = GSLTSRGWAIFLG
[M:ENT]PRNCOD1   = GSLTPRNCOD1
[M:ENT]PRNNBFLG1 = GSLTPRNNBFLG1
[M:ENT]CCECODS   = GSTODIE

If [M:SIH1]SIHORI=4 & [M:SIH4]XSIHORINUM(LLIG) <> ""
    [M:ENT]VCRTYPORI = 5
    [M:ENT]VCRNUMORI = [M:SIH4]XSIHORINUM(LLIG)
    [M:ENT]VCRLINORI = [M:SIH4]SIDORILIN(LLIG)
    If [F:SID]NUM <> [M:SIH4]XSIHORINUM(LLIG) | [F:SID]SIDLIN <> [M:SIH4]SIDORILIN(LLIG)
        Read [SID]SID0=[M:SIH4]XSIHORINUM(LLIG);[M:SIH4]SIDORILIN(LLIG)
        If fstat Raz [F:SIV] Endif
    Endif
    [M:ENT]STOFCYORI = [F:SID]STOFCY
    GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
Else
    GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
Endif
[M:ENT]BPRNUM = [M:SIH1]BPCORD

End
#-----------------------------------------------------------------------#
# Appelée dans MAJ_LIGNE_DOCUMENT                                       #
# Chargement Ecran STOENT (partie parametrage) creations des entrées    #
# Donne la main pour maj ligne du document, et grise les champs stock   #
# LPCU    : Unité utilisée dans le détail                               #
# LCOEF   : Coefficient utilisé dans  le détail                         #
# LQTYSTU : Qté en US à répercuter dans le doc                          #
#-----------------------------------------------------------------------#
$MAJ_LIG_SIH

Local Decimal WQTYSAU, WQTY

Local Integer NOL : NOL=LLIGDOC
#--- Cas de la suppression : 24/11/03 (tests HN)
If LQTYSTU=0
  If [M:SIH4]CREFLG(NOL)<>0
    [M:SIH4]QTY(NOL)=0
    [M:SIH4]QTYSTU(NOL)=0
    Return
  Elsif [M:SIH4]CREFLG(NOL)=0
    Raz [M:SIH4]WSTOFLG(NOL) : Grizo [M:SIH4]QTY(NOL)
  Endif
Endif
# Dans la fenêtre détail : l'unité ou le coefficient UV-US ou la qté sont différents du document d'origine
# Si la qté en US est modifiée report sur la ligne document origine

If LQTYSTU<>[M:SIH4]QTYSTU(LLIGDOC)

    # J'ai besoin de remettre SIH4 par défaut pour appeler CLCNETPRI et CLCPFM
    #--- Issue 122875 remplacement WSIHMSKCOU(7) par WSIHMSKCOU(10)
    Local Char    WSIHMSKCOU(10)    : WSIHMSKCOU = func STKLIB.MSKDEF
    Default Mask [SIH4]

    Call SUB_TOT(LLIGDOC) From SUBSIHB

    If LCOEF<>0
    # -- Coef. unique sur toutes les lignes
        If LPCU=[M:SIH4]SAU(LLIGDOC)
        # -- L'entrée a été saisie dans l'unité du document (UV) : On récalcule la qté retour en UV
            If LCOEF=[M:SIH4]SAUSTUCOE(LLIGDOC)
                [M:SIH4]QTY(LLIGDOC)=LQTYSTU / LCOEF
                [M:SIH4]QTYSTU(LLIGDOC)=LQTYSTU
            Else
                # Le coefficient a été modifié
                If [M:SIH4]DACSAUCOE(LLIGDOC)=2
                    # Il est modifiable       : Il est répercuté
                    [M:SIH4]QTY(LLIGDOC)=LQTYSTU / LCOEF
                    [M:SIH4]QTYSTU(LLIGDOC)=LQTYSTU
                    # Recalcul de l'ancienne qté avec le nvx coefficient
                    WQTY=[M:SIH4]YQTYSTU(LLIGDOC) / LCOEF
                    Call QTEARR(WQTY, [M:SIH4]SAU(LLIGDOC)) From TRTDIV
                    [M:SIH4]YQTY(LLIGDOC)= WQTY
                    Local Decimal WCOEF     : WCOEF=LCOEF
                    Local Char    WMESS(100) : WMESS=mess(158,191,1)
                    Gosub CONV_PRIX : # Changement du coef : Convertion des prix
                    #[M:SIH4]SAUSTUCOE(LLIGDOC)=LCOEF : # Bug 62988
                Else
                    # -- Il n'est pas modifiable : Il n'est pas répercuté
                    #    On recalcule la qté retour ds l'unité du document(UV)
                    #    Si on tombe sur un chiffre rond ok sinon on met tout en US
                    Gosub RECALC_QTYSAU
                Endif
            Endif
        Else
        # -- L'entrée a été saisie en US ou ds une autre unité
        #    On recalcule la qté retour ds l'unité du document(UV)
        #    Si on tombe sur un chiffre rond ok sinon on met tout en US
            Gosub RECALC_QTYSAU
        Endif
    Else
    # -- Coef. non unique sur toutes les lignes : on met tout en US
         Gosub CONV_LIG_SAUSTU
    Endif
    # Il faudra reforcer un calcul
    [M:SIH0]INVCLCFLG=2
    Call APRES_LIGNE (NOL,1) From SUBSIHB
    Affzo [M:SIH4]SAU(LLIGDOC), QTY(LLIGDOC), SAUSTUCOE(LLIGDOC)

    Default Mask WSIHMSKCOU

Endif

If [M:SIH4]SAU(LLIGDOC)=[M:SIH4]STU(LLIGDOC)
  Affzo [M:SIH4]SAUSTUCOE(LLIGDOC) : # pb diszo
  Diszo [M:SIH4]SAUSTUCOE(LLIGDOC)
  Affzo [M:SIH4]SAUSTUCOE(LLIGDOC) : # pb diszo
Endif

Return
$RECALC_QTYSAU
# ------------------------------------------------------------- #
# Recalcul de la qté retour ds l'unité du document (UV)         #
#    Si on tombe sur un chiffre rond ok sinon on met tout en US #
# ------------------------------------------------------------- #
# Calcul de la qté en UV
WQTYSAU=LQTYSTU / [M:SIH4]SAUSTUCOE(LLIGDOC)
WQTY=WQTYSAU
Call QTEARR(WQTY,[M:SIH4]SAU(LLIGDOC)) From TRTDIV
If WQTYSAU=WQTY
    # On tombe sur un chiffre rond : ok
    [M:SIH4]QTY(LLIGDOC)=WQTYSAU
    [M:SIH4]QTYSTU(LLIGDOC)=LQTYSTU
Else
    # On ne tombe pas sur un chiffre rond : on met tout en US
    Gosub CONV_LIG_SAUSTU
Endif
Return
# ------------------------------------------------------------- #
# Passage de la ligne avoir en US                               #
# --> L'UV devient l'US                                         #
# --> La qté en UV devient la qté en US                         #
# --> Conversion en US toutes les quantités qui étaient en UV   #
# --> Le coef. UV-US est forcé à 1                              #
# ------------------------------------------------------------- #
$CONV_LIG_SAUSTU
[M:SIH4]QTYSTU(NOL)=LQTYSTU
[M:SIH4]SAU(NOL)=[M:SIH4]STU (NOL)
[M:SIH4]QTY(NOL)=LQTYSTU
# Il faut reconvertir en US toutes les quantités qui étaient en UV
[M:SIH4]YQTY(NOL)   =[M:SIH4]YQTY(NOL)*[M:SIH4]SAUSTUCOE(NOL)
[M:SIH4]CQTY(NOL)   =[M:SIH4]CQTY(NOL)*[M:SIH4]SAUSTUCOE(NOL)

# Convertion des prix de l'UV vers l'US
Local Decimal WCOEF     : WCOEF=1
Local Char    WMESS(100) : WMESS=mess(159,191,1)
Gosub CONV_PRIX
#[M:SIH4]SAUSTUCOE(NOL)=1 : # Bug 62988

Return

# ----------------------------------------------------------------------------- *
# Conversion des prix lors d'un changement d'unité ou de coef. conversion UV-US
# ----------------------------------------------------------------------------- *
$CONV_PRIX
# ------------------------------------------ #
# Convertion des prix dans la nouvelle unité #
# ------------------------------------------ #
Local Decimal WGROPRI
# --> Calcul des montants de base calcul de taxe
Call ALICLCAMT([M:SIH4]ITMREF(NOL), [M:SIH4]QTY(NOL), NOL, "SIH4", [M:SIH4]CLCAMT1(NOL), [M:SIH4]CLCAMT2(NOL)) From TRTX3
# --> Conversion du prix brut
WGROPRI=([M:SIH4]GROPRI(NOL)/[M:SIH4]SAUSTUCOE(NOL))*WCOEF
WGROPRI=arr(WGROPRI,10^-GDECPRI)
[M:SIH4]GROPRI(NOL)=WGROPRI
# --> Conversion des frais/remises
Local Integer I
Local Decimal MAJREM(0..8), NETPRI, QTY

For I=1 To 9
   If evalue("dim([M:SIH4]DISCRGVAL"+num$(I)+"(NOL))")>0
      MAJREM(I-1)=evalue("[M:SIH4]DISCRGVAL"+num$(I)+"(NOL)")
   Endif
Next I
Call CNVREM (1,"", MAJREM,[M:SIH2]CUR,[M:SIH4]SAUSTUCOE(NOL),WCOEF) From TRTVENFAC

If GMESSAGE<>"" Call MESSAGE(WMESS-"\"-GMESSAGE) From GESECRAN Endif

For I=1 To 9
   If evalue("dim([M:SIH4]DISCRGVAL"+num$(I)+"(NOL))")>0
      Assign ("[M:SIH4]DISCRGVAL"+num$(I)+"(NOL)") With MAJREM(I-1)
   Endif
Next I
Gosub AFF_RECH_TAR From SUBSIH

[M:SIH4]SAUSTUCOE(NOL)=WCOEF : # Bug 62988
# --> Calcul du prix net
Call CLCNETPRI([M:SIH4]QTY(NOL), [M:SIH2]CUR, NOL) From TRTVENPRI
# --> Recalcul du prix de revient et de la marge
Call CLCPFM([M:SIH4]DSTOFCY(NOL), [M:SIH1]PRITYP,[M:SIH0]CHGTYP, [M:SIH0]INVDAT, [M:SIH2]CUR, NOL,2) From TRTVENPRI
[M:SIH4]AMTNOTLIN(NOL)=[M:SIH4]QTY(NOL)*[M:SIH4]NETPRINOT(NOL)
[M:SIH4]AMTATILIN(NOL)=[M:SIH4]QTY(NOL)*[M:SIH4]NETPRIATI(NOL)
Affzo [M:SIH4]NETPRI(NOL), CPRPRI(NOL), PFM(NOL)

Return

#########################################################################
# ETIQUETTES APPELEES PAR TRTSTOENTB                                    #
#########################################################################
#-----------------------------------------------------------------------#
# Appelée dans CTL_LIGNE_DOCUMENT                                       #
# Donne la main pour effectuer avant stockage dans STOENTW:             #
#  - contrôles de quantités                                             #
#  - affectation diverses                                               #
# En cas d'erreur, donner une valeur différente de 0 à mkstat           #
# Attention : Il est de la responsabilité de chaque document d'afficher #
#             les messages d'erreurs.                                   #
# Variables disponibles :                                               #
# LQTYSTU = Quantité totale en unité de stock des lignes de détail      #
# LPCU    = Unité utilisée dans le détail si unique sinon ""            #
# LCOEF   = Coefficient UC/US si unique sinon ""                        #
#-----------------------------------------------------------------------#
$CTL_LIG_SIH
#------------------------------------------#
# Contrôle au sortir de la saisie de stock #
# ou modif de stock                        #
#------------------------------------------#
If dim(NOL)<0       : Local Shortint NOL       : Endif
If dim(TRTLIG)<0    : Local Char     TRTLIG(1) : Endif
If dim(SVGNOL)<0    : Local Integer  SVGNOL    : Endif

Local Integer OK
SVGNOL=nolign : # Sauvegarde du nolign ecran stock
NOL=LLIGDOC
nolign=NOL+1
NEWQTE =LQTYSTU

Local Shortint   WSUPP : Raz WSUPP

# Contrôle du stock retourné
If [M:SIH4]XSIHORINUM(NOL) <> ""
    Call CTR_STK_RETCLI(OK) From STKENT
    If OK mkstat = 2 : Return Endif
Endif

Local Integer OK : OK=1
If [M:SIH4]CREFLG(NOL)<>0
  #-- Si la quantité est à 0 (suppression de ligne)
  If LQTYSTU = 0
    TRTLIG="A" : status=65
    Gosub TEST_ANU From SUBSIHB
    If mkstat=0
        # Si la ligne doit être supprimée, on regarde s'il y en a d'autres
        # pour déterminer si l'entête doit être supprimée
        Filter [SID] Where NUM=[M:SIH0]NUM & SIDLIN<>[M:SIH4]SIDLIN(NOL)
&                    Order By Key SID0
        Read [SID]SID0 First
        If fstat WSUPP = 1 Endif
        Filter [SID]
        If WSUPP=1
            # --> Avoir non supprimable si interdit par paramétre
            If GSIVSUP = 1
                GMESSAGE=mess(159,192,1) : mkstat=2
            Else
                # --> Ctrl autorisation suppression
                GBIDC2="S": Gosub AUTORIS_OPT From CONTX3
                If !GBIDI2  GMESSAGE=mess(2,104,1) : mkstat=2 Endif
            Endif
        Endif
    Endif
  Else
    TRTLIG="M" : status=75
    Gosub TEST_MOD From SUBSIHB
  Endif
  If mkstat Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE : nolign=SVGNOL : Return : Endif
Endif
nolign=SVGNOL
Return
#########################################################################
# ETIQUETTES APPELEES PAR TRTSTOENMA                                    #
#########################################################################
#-----------------------------------------------------------------------#
# Appelée dans CHARG_PARAM_STOENTM                                      #
# Chargement Ecran STOENTM (partie parametrage) modification des entrées#
#-----------------------------------------------------------------------#
Subprog CHARG_PARAM_STOENTM (LLIG)
Value Integer LLIG

If LLIG<>999999
  [M:ENM]STOFCY   = [M:SIH4]DSTOFCY(LLIG)
  [M:ENM]ITMREF   = [M:SIH4]ITMREF(LLIG)
  [M:ENM]QTYTOENT = [M:SIH4]QTY(LLIG)
  [M:ENM]PCUTOENT = [M:SIH4]SAU(LLIG)
  [M:ENM]COETOENT = [M:SIH4]SAUSTUCOE(LLIG)
  [M:ENM]STU      = [M:SIH4]STU(LLIG)
  [M:ENM]VCRNUM   = [M:SIH0]NUM
  [M:ENM]VCRLIN   = [M:SIH4]SIDLIN(LLIG)
  [M:ENM]MVTDES   = [M:SIH4]MVTDES(LLIG)
  [M:ENM]QUAFLG   = [M:SIH4]QUAFLG(LLIG)        # hcb V6CQ
  [M:ENM]QUAFRE   = [M:SIH4]QUAFRE(LLIG)        # hcb V6CQ
  If dim([M:SIH4]WRH)>0
    [M:ENM]XWRH   = [M:SIH4]WRH(LLIG)
  Endif

  [M:ENM]PJT      = ""
  [M:ENM]TRSTYP   = 12                   : # Type mouvement (M.704)
  [M:ENM]TRSCOD   = [M:SIH0]TRSCOD       : # Code mouvement
  [M:ENM]TRSFAM   = [M:SIH1]TRSFAM
  [M:ENM]BPRNUM   = [M:SIH1]BPCORD
  [M:ENM]ENTCOD   = [M:SIH0]ENTCOD
  If [M:SIH1]BETFCY=2 [M:ENM]TRFFCY = [M:SIH4]DSTOFCY(LLIG) Endif
  If [M:SIH4]XSIHORINUM (LLIG)<> ""
      GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
  Else
      GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
  Endif
Else : # Cas de la suppression
# ???
  [M:ENM]STOFCY   = [F:SID]STOFCY
  [M:ENM]ITMREF   = [F:SID]ITMREF
  [M:ENM]QTYTOENT = [F:SID]QTY
  [M:ENM]PCUTOENT = [F:SID]SAU
  [M:ENM]COETOENT = [F:SID]SAUSTUCOE
  [M:ENM]STU      = [F:SID]STU
  [M:ENM]VCRNUM   = [F:SID]NUM
  [M:ENM]VCRLIN   = [F:SID]SIDLIN
  [M:ENM]MVTDES   = ""
  [M:ENM]PJT      = ""
  [M:ENM]TRSTYP   = 12                   : # Type mouvement (M.704)
  [M:ENM]TRSCOD   = [F:SIV]TRSCOD        : # Code mouvement
  [M:ENM]TRSFAM   = [F:SIH]TRSFAM
  [M:ENM]BPRNUM   = [F:SIV]BPCORD
  [M:ENM]ENTCOD   = [F:SIV]ENTCOD
  If [M:SIH1]BETFCY=2 [M:ENM]TRFFCY = [M:SID]STOFCY Endif
  If [F:SID]SIHORINUM <> ""
      GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
  Else
      GSAIFLG="000000000000000" : # "PCU,QTYPCU,PCUSTUCOE,STA,LOCTYP,LOC,LOTAFF,,SLOAFF,BPSLOTAFF,SERNUM"
  Endif
Endif
[M:ENM]SRGWAIFLG = GSLTSRGWAIFLG
[M:ENM]PRNCOD1   = GSLTPRNCOD1
[M:ENM]PRNNBFLG1 = GSLTPRNNBFLG1
End
#-----------------------------------------------------------------------#
# Appelée dans MAJ_MODIFICATION_LIGNE                                   #
# Mise à jour du document origine suite à modifications                 #
# le masque du document origine est chargé avec les nouvelles valeurs   #
#-----------------------------------------------------------------------#
########################################
$TRT_MAJ_DOCUMENT
Local Integer LOK

If dim(NOL)<0 :  Local Shortint NOL: Endif
If dim(TRTLIG)<0 Local Char    TRTLIG(1) : Endif
# Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) - Scheduled invoices picking left list on sales invoices
#Local Char       SYMBOLE2(30)
Local Char       SYMBOLE2(50)
# End issue 107888
If dim(WSUPP)<0  Local Shortint   WSUPP : Raz WSUPP : Endif
Local Integer    SIGN, WSTAT, SAVNOLIGN, I, OK, WSIDLIN, WRET
Local Decimal    WLIVTTC, DELTAQTY, DELTAQTYSTU
Local Decimal    MAJREM(0..8)

NOL=LLIGDOC
nolign=NOL+1
WSIDLIN=[M:SIH4]SIDLIN(NOL)

Raz WLIVTTC
# Mise à jour des quantités

Gosub MAJ_LIG_SIH

If [M:SIH4]QTYSTU(NOL)=0
    TRTLIG="A"
#    # Si la ligne doit être supprimée, on regarde s'il y en a d'autre sur le retour
#    # pour déterminer si l'entête retour doit être supprimée
#    Filter [SID] Where NUM=[M:SIH0]NUM & SIDLIN<>[M:SIH4]SIDLIN(NOL)
#&                Order By Key SID0
#    Read [SID]SID0 First
#    If fstat WSUPP = 1 Endif
#    Filter [SID]
Else
    TRTLIG="M"
Endif
# --- Contrôles OK, suite de la mise à jour
If [M:SIH4]QTYSTU(NOL)=0
#  status=65 : nolign=NOL+1 : Call AVANT_NBLIG From SUBSIH
  status=65 : nolign=NOL+1
  Dela NOL,1,[M:SIH4]NBLIG-1 [M:SIH4]NBLIG : [M:SIH4]NBLIG-=1
Endif

# --- Lecture de l'entête avoir
If WSUPP = 1
   Readlock [SIH]SIH0=[M:SIH0]NUM
Else
   Read [SIH]SIH0=[M:SIH0]NUM
Endif
If fstat = 1 GOK = -1
   GLOCK = "$SINVOICE"-[M:SIH0]NUM : Return
Elsif fstat  GOK =  0
   Call RSTA ("SIH",[M:SIH0]NUM) From GLOCK : Return
Endif
# --- Lecture de l'entête avoir
If WSUPP = 1
   Readlock [SIV]SIV0=[M:SIH0]NUM
Else
   Read [SIV]SIV0=[M:SIH0]NUM
Endif
If fstat = 1 GOK = -1
   GLOCK = "$SINVOICEV"-[M:SIH0]NUM : Return
Elsif fstat  GOK =  0
   Call RSTA ("SIV",[M:SIH0]NUM) From GLOCK : Return
Endif

#-- Maj du détail avoir
Readlock [SID]SID0=[M:SIH0]NUM;WSIDLIN
If fstat = 1 GOK = -1
   GLOCK = "$SINVOICED"-[M:SIH0]NUM-num$(WSIDLIN)
   Return
Elsif fstat  GOK =  0
   Call RSTA ("SID",[M:SIH0]NUM-num$(WSIDLIN)) From GLOCK
   Return
Endif
SIGN=-1

If [M:SIH4]NBLIG<>0
   # Spécificité USA
   Local Char     WKU_MAJ : WKU_MAJ="2"
   Local Integer  OK
   Call TEMPON ("C") From GESECRAN

   Gosub CHARG_TABLEAUX From TRTVENFACC
   # 101874 : V9 : Taxe code control
   #Local Integer WOK : WOK=2
   #---- Paramètres complementaires appel valorisation
   # PARAM_T(0) : Flag contrôle des taxes             (1=Non/2=Oui)
   # PARAM_T(1) : Lecture de la trace par le sous-pro (1=Non/2=Oui)
   # PARAM_T(2) : Flag retour                         (1=KO/2=OK)
   Local    Char     PARAM_T (25) (0..10)
   PARAM_T(0)="2"      : # Contrôle des taxes lors de la création
   PARAM_T(1)="1"      : # Pas de lecture de la trace (c'est le moteur entrée en stock qui lit la trace)
   PARAM_T(2)="0"
   Gosub CTLVAT From TRTVENFACC1
   If PARAM_T(2)="1" GOK=0 : mkstat=2 : GRELITSIH=1 : Call TEMPOFF From GESECRAN : Return Endif
   # 101874

   Gosub CAL_FACTURE From TRTVENFACC

   [M:SIH0]INVCLCFLG=1
   [M:SIH4]INVNOT = [M:SIHV]INVNOT
   [M:SIH4]INVATI = [M:SIHV]INVATI

   Gosub CHARGE_SIH From TRTVENFACC

   Gosub MOD_DATE_ECHE From TRTVENFACC

   Call TEMPOFF From GESECRAN
Endif

If TRTLIG="A"
  DELTAQTY    = -1 * [F:SID]QTY
  DELTAQTYSTU = -1 * [F:SID]QTYSTU
  #-- Suppression texte ligne
  If left$([F:SID]SIDTEX,3)="SID"
        Call SUP_CLOB([F:SID]SIDTEX,WRET) From TRTX3TEX
  Endif
  #-- Suppression de la ligne de retour
  Delete [SID] Where NUM=[M:SIH0]NUM & SIDLIN=WSIDLIN
  If fstat GOK=0 : Call FSTA("SID") From GLOCK : Return : Endif
  #-- Suppression comptes et sections de la ligne d'avoir
  Delete [CAL] Where ABRFIC="SID" & VCRNUM=[F:SID]NUM & VCRLIN=[F:SID]SIDLIN
  If fstat=1
      GOK=-1 : GLOCK="$CPTANALIN SID 0"-[F:SID]NUM-num$([F:SID]SIDLIN) : Return
  Endif
Else
#  DELTAQTY    = [M:SIH4]QTY(NOL) - [F:SID]QTY
#  DELTAQTYSTU = [M:SIH4]QTYSTU(NOL) - [F:SID]QTYSTU
  DELTAQTY    = [M:SIH4]QTY(NOL) - [M:SIH4]YQTY(NOL)
  DELTAQTYSTU = [M:SIH4]QTYSTU(NOL) - [M:SIH4]YQTYSTU(NOL)
  [F:SID]QTY      =[M:SIH4]QTY(NOL)
  [F:SID]QTYSTU   =[M:SIH4]QTYSTU(NOL)
  [F:SID]SAU      =[M:SIH4]SAU(NOL)
  [F:SID]SAUSTUCOE=[M:SIH4]SAUSTUCOE(NOL)
  [F:SID]GROPRI   =[M:SIH4]GROPRI(NOL)
  For I=1 To 9
     If evalue("dim([M:SIH4]DISCRGVAL"+num$(I)+"(NOL))")>0
        MAJREM(I-1)=evalue("[M:SIH4]DISCRGVAL"+num$(I)+"(NOL)")
        Assign ("[F:SID]DISCRGVAL"+num$(I)) With MAJREM(I-1)
     Endif
  Next I
  [F:SID]NETPRI    =[M:SIH4]NETPRI(NOL)
  [F:SID]NETPRINOT =[M:SIH4]NETPRINOT(NOL)
  [F:SID]NETPRIATI =[M:SIH4]NETPRIATI(NOL)
  [F:SID]CPRPRI    =[M:SIH4]CPRPRI(NOL)
  [F:SID]PFM       =[M:SIH4]PFM(NOL)
  [F:SID]AMTNOTLIN =[M:SIH4]AMTNOTLIN(NOL)
  [F:SID]AMTATILIN =[M:SIH4]AMTATILIN(NOL)
# Remettre à jour les prix s'il y a eu conversion en US
  SIGN=1
  #-- Réécriture de la ligne d'avoir
  Rewrite [SID]
  If fstat GOK=0 : Call FSTA("SID") From GLOCK : Return : Endif
Endif

#----- Si tout s'est bien déroulé -----#
If GOK = 1
  GRELITSIH = 1
Endif

#----------------------------------------------------------------#
# Traitement sur un avoir sur facture                            #
#----------------------------------------------------------------#
If TRTLIG="A" & [F:SIV]INVTYP=2 & [F:SIV]SIHORI = 4 & [F:SID]SIHORINUM <> ""
   Call MAJ_FACORI(TRTLIG) From SUBSIHA
Endif
#----------------------------------------------------------------#
# Traitement sur un avoir sur retour                             #
#----------------------------------------------------------------#
If TRTLIG="A" & [F:SIV]INVTYP=2 & [F:SIV]SIHORI = 6
   If [F:SID]SRHNUM <> ""
      Call MAJ_RETORI(TRTLIG) From SUBSIHA
   Endif
   If [F:SID]SIHORINUM <> ""
     Call MAJ_FACORI(TRTLIG) From SUBSIHA
   Endif
Endif

If WSUPP=1
  If left$([F:SIV]SIHTEX1,3)="SIV"
      Call SUP_CLOB([F:SIV]SIHTEX1,WRET) From TRTX3TEX
  Endif
  If left$([F:SIV]SIHTEX2,3)="SIV"
      Call SUP_CLOB([F:SIV]SIHTEX2,WRET) From TRTX3TEX
  Endif
  Delete  [SIH]
  If fstat GOK=0 : Call FSTA("SIH") From GLOCK : Return : Endif
  Delete  [SIV]
  If fstat GOK=0 : Call FSTA("SIV") From GLOCK : Return : Endif
  Call SUP_ECHEANCES From TRTVENFACC :   # Suppression des echeances de la facture
  If GOK < 1 : Return : Endif

  #----------------------------------------------------------------#
  # Suppression des enregistrements sans SVCRVAT et SVCRFOOT       #
  #----------------------------------------------------------------#
  Call UPD_VALORISATION ("A","SIH") From TRTVENFACC
  If GOK < 1 Return Endif

Else
  Rewrite [SIH]
  If fstat GOK=0 : Call FSTA("SIH") From GLOCK : Return : Endif
  Rewrite [SIV]
  If fstat GOK=0 : Call FSTA("SIV") From GLOCK : Return : Endif

  #----------------------------------------------------------------#
  # Modification des enregistrements sans SVCRVAT et SVCRFOOT      #
  #----------------------------------------------------------------#
  Call UPD_VALORISATION ("M","SIH") From TRTVENFACC
  If GOK < 1 Return Endif
Endif

WTTC = DELTAQTYSTU * arr([F:SID]NETPRIATI/[F:SID]SAUSTUCOE,10^-GDECPRI)

# Maj mouvement client (facturé non comptabilisé)
If WTTC <> 0
   Local Decimal WCOURS : WCOURS=0
   If [F:SIH]RATDIV(GTYPGEN-1)<>0 WCOURS=arr([F:SIH]RATMLT(GTYPGEN-1)/[F:SIH]RATDIV(GTYPGEN-1), 10^-GDECRCU) : Endif
   Call MAJMVC ([F:SIV]BPCINV, [F:SIV]CUR, [F:SIH]CURTYP, WCOURS, [F:SIV]INVDAT, [F:SIV]NUM, [F:SIV]SALFCY,
&               0, WTTC, "-", "I", "", 0) From TRTBPMVT
   If GOK < 1 Return Endif
Endif
Return
##########################################################################
########################################################################
# A AVOIR SI UTILISE
$CONV_DELTAQTY
#-----------------------------------------------------------------------------#
# Conversion delta de la qté avoir dans l'unité de vente de la facture        #
#-----------------------------------------------------------------------------#
# -- Alimentation quantité retournée en UV
If [F:SDD]SAU=[F:SRD]SAU & [F:SDD]SAUSTUCOE=[F:SRD]SAUSTUCOE
    WCNVDELTAQTY    = DELTAQTY
Else
    WCNVDELTAQTY=DELTAQTYSTU/[F:SDD]SAUSTUCOE
#    Call QTEARR(WCNVDELTAQTY, [F:SDD]SAU) From TRTDIV
    WCNVDELTAQTY = arr(WCNVDELTAQTY,0.000001)
Endif
Return

##########################################################################
$RAZ_TABL_STOCK
#----- Effacement des champs stock -----#
If dim([M:SIH4]STA)>0     Raz [M:SIH4]STA     : Endif
If dim([M:SIH4]LOCTYP)>0  Raz [M:SIH4]LOCTYP  : Endif
If dim([M:SIH4]LOC)>0     Raz [M:SIH4]LOC     : Endif
If dim([M:SIH4]BPSLOT)>0  Raz [M:SIH4]BPSLOT  : Endif
If dim([M:SIH4]LOT)>0     Raz [M:SIH4]LOT     : Endif
If dim([M:SIH4]NBSLO)>0   Raz [M:SIH4]NBSLO   : Endif
If dim([M:SIH4]SLO)>0     Raz [M:SIH4]SLO     : Endif
If dim([M:SIH4]SLOF)>0    Raz [M:SIH4]SLOF    : Endif
If dim([M:SIH4]SERNUM)>0  Raz [M:SIH4]SERNUM  : Endif
If dim([M:SIH4]SERNUMF)>0 Raz [M:SIH4]SERNUMF : Endif
If dim([M:SIH4]PALNUM)>0  Raz [M:SIH4]PALNUM  : Endif
If dim([M:SIH4]CTRNUM)>0  Raz [M:SIH4]CTRNUM  : Endif
If dim([M:SIH4]PRIORD)>0  Raz [M:SIH4]PRIORD  : Endif
If dim([M:SIH4]MVTDES)>0  Raz [M:SIH4]MVTDES  : Endif

#  If dim([M]WSTOSAI)>NOL [M]WSTOSAI(NOL)="000222222222222" : Endif
Return

########################################################################
# CONVERT_MONTANT : S/P de conversion des éléments de facturation      #
#                   et des montants en-cours et en-cours autorisé      #
#                   après un changement de devise ou de type de cours  #
# -------------------------------------------------------------------- #
# Subprog CONVERT_MONTANT (NVXDEV, ANCDEV,TYP)                         #
#    NVXDEV  : Nouveau code devise                                     #
#    ANCDEV  : Ancien  code devise                                     #
#    TYP     : Nouveau type de cours                                   #
########################################################################
Subprog CONVERT_MONTANT (NVXDEV,ANCDEV,TYP)
Value Char    NVXDEV
Value Char    ANCDEV
Value Integer TYP

Local Integer SPSTAT, I
Local Decimal MONTANT, MNTORG (0..1), MNTDES (0..1)
Local Date    WOSTDAT
Local Libelle WOSTCHGTYP

# --> Recalcul de l'en-cours et de l'en-cours autorise
If [M]OSTAUZ  <> 99999999999.99
   MNTORG(0) =  [M]OST
   MNTORG(1) =  [M]OSTAUZ
   If GOSTCHGTYP=2
       # Si Origine cours pour contrôle en-cours = actualisé
       WOSTDAT=datesyst                                        : # Date          : date du jour
       WOSTCHGTYP= GOSTTYPCUR                                  : # Type de cours : Type de cours ctrl au cours actualisé
   Else
       # Si Origine cours pour contrôle en-cours = historique
       WOSTDAT=[M]INVDAT                                       : # Date          : date du document
       WOSTCHGTYP=TYP                                    : # Type de cours : Type de cours du document
   Endif

#   Call CONVERT(ANCDEV, NVXDEV, GLOCALDEV, TYP, [M]INVDAT, MNTORG(0),MNTDES(0),SPSTAT) From TRTDEV
#   Call CONVERT(ANCDEV, NVXDEV, GLOCALDEV, TYP, [M]INVDAT, MNTORG(1),MNTDES(1),SPSTAT) From TRTDEV
   Call CONVERT(ANCDEV, NVXDEV, GLOCALDEV, WOSTCHGTYP, WOSTDAT, MNTORG(0),MNTDES(0),SPSTAT) From TRTDEV
   Call CONVERT(ANCDEV, NVXDEV, GLOCALDEV, WOSTCHGTYP, WOSTDAT, MNTORG(1),MNTDES(1),SPSTAT) From TRTDEV
   [M]OST    = MNTDES(0)
   [M]OSTAUZ = MNTDES(1)
Endif
# --> Recalcul des montants de facturation
If [M]NBFAC <> 0
   For I = 0 To [M]NBFAC-1
      If [M:SIH2]AMTCOD(I) = 2
         [M:SIH2]FORMAT(I) = "NZ:"+[F:TCU]CURFMT1
         Call CONVERT(ANCDEV, NVXDEV, GLOCALDEV, TYP, [M]INVDAT,
&                     [M:SIH2]INVDTAAMT(I),MNTDES,SPSTAT) From TRTDEV
         [M:SIH2]INVDTAAMT(I) = MNTDES
      Endif
   Next I
Endif
End

# Issue 63491
#################################################################################
# CTL_EXIST_RAT_CUR : Controle de l'existence d'un cours devise entre 2 devises #
#                   : Control a rate cur exists between 2 currencies            #
# ----------------------------------------------------------------------------- #
#    Variables à déclarer et charger avant appel de l'étiquette :               #
#    Variables to declare and charge before label call          :               #
#       WNVXCUR  : Nouveau code devise/New currency                             #
#       WOLDCUR  : Ancien  code devise/Old currency                             #
#       WCURTYP  : Type de cours/Currency typ                                   #
#       WINVDAT  : Date facture/Invoice date                                    #
#    Variables à déclarer avant appel de l'étiquette :                          #
#    Variables to declare before label call          :                          #
#       SPSTAT                                                                  #
#################################################################################
$CTL_EXIST_RAT_CUR
Local Decimal WMNTORG, WMNTDES

# Issue X3-102523
#WMNTORG=1
## Il n'existe pas de sous-pro permettant de récupérer un cours devise entre 2 devises
## --> Conversion du montant 1,00. Si le montant converti=0, c'est qu'il n'y a pas de cours devise
## There is no subprog that gives the rate cur between 2 currency
## --> Convert the amount 1,00. If the convert amount=0, there is no rate cur
# On peut avoir un montant converti=0 bien que l'on ait un cours devise
# Utilisation du souspro COURDEV qui donne le cours entre 2 devises
# We can have the convert amount=0 although we have a rate cur
# Use of the subprog COURDEV that dives the rate cur between 2 currency
#Call CONVERT(WOLDCUR, WNEWCUR, GLOCALDEV, WCURTYP, WINVDAT,
#&                     WMNTORG, WMNTDES, SPSTAT) From TRTDEV
#If SPSTAT<>0
#    GMESSAGE=mess(278,196,1)-"\"-mess(26,105,1)-":"-WOLDCUR-mess(18,105,1)-mess(41,197,1)-":"-WNEWCUR
#    Return
#Endif
#If WMNTDES=0
#    GMESSAGE=mess(278,196,1)-"\"-mess(26,105,1)-":"-WOLDCUR-mess(18,105,1)-mess(41,197,1)-":"-WNEWCUR
#    SPSTAT=99
#    Return
#Endif
Local Decimal WCOURS
Call COURDEV(WOLDCUR, WNEWCUR, WCURTYP, WINVDAT, WCOURS,SPSTAT) From TRTDIV
WCOURS=arr(WCOURS,10^(-GDECRCU))
If SPSTAT=99
    Return
Elsif WCOURS=0
    GMESSAGE=mess(278,196,1)-"\"-mess(26,105,1)-":"-WOLDCUR-mess(18,105,1)-mess(41,197,1)-":"-WNEWCUR
    Return
Endif
# End issue X3-102523

Return
# End issue 63491

########################################################################
# RECH_ORINUM : Recherche du no origine (commande ou livraison)        #
#               de la facture                                          #
########################################################################
Subprog RECH_ORINUM
Local Integer I

# Proforma de devis : Toujours 1 seul devis/proforma
If [M:SIH0]INVTYP=5 & [M:SIH1]SIHORI=5
    If sum([M:SIH4]SQHNUM)="" Raz [M:SIH1]SIHORINUM, [M:SIH1]SIHORIDAT : [M:SIH1]SIHORI=1 : Endif
    End
Endif

# Facture de demande de service : Toujours 1 seul dde/facture
If [M:SIH0]INVTYP=1 & [M:SIH1]SIHORI=8
    If sum([M:SIH4]SRENUM)="" Raz [M:SIH1]SIHORINUM, [M:SIH1]SIHORIDAT : [M:SIH1]SIHORI=1 : Endif
    End
Endif

#Raz [M:SIH1]SIHORINUM, [M:SIH1]SIHORIDAT
Raz [M:SIH1]SIHORINUM
Case [M:SIH1]SIHORI
 When 2       : For I=0 To [M:SIH4]NBLIG-1                      : # Commandes
                   If [M:SIH4]SOHNUM(I)<>""
                      If [M:SIH1]SIHORINUM=""
                         [M:SIH1]SIHORINUM=[M:SIH4]SOHNUM(I)
                      Elsif [M:SIH1]SIHORINUM<>[M:SIH4]SOHNUM(I)
                         Raz [M:SIH1]SIHORINUM, [M:SIH1]SIHORIDAT
                         Break
                      Endif
                   Endif
                Next I
                # La facture redevient direct ssi plus aucune ligne issue d'une commande
                If [M:SIH1]SIHORINUM="" & sum([M:SIH4]SOHNUM)="" [M:SIH1]SIHORI=1 : Endif
 When 3       : For I=0 To [M:SIH4]NBLIG-1                      : # Livraisons
                   If [M:SIH4]SDHNUM(I)<>""
                      If [M:SIH1]SIHORINUM=""
                         [M:SIH1]SIHORINUM=[M:SIH4]SDHNUM(I)
                      Elsif [M:SIH1]SIHORINUM<>[M:SIH4]SDHNUM(I)
                         Raz [M:SIH1]SIHORINUM, [M:SIH1]SIHORIDAT
                         Break
                      Endif
                   Endif
                Next I
                # La facture redevient direct ssi plus aucune ligne issue d'une livraison
                If [M:SIH1]SIHORINUM="" & sum([M:SIH4]SDHNUM)="" [M:SIH1]SIHORI=1 : Endif
 When 4       : For I=0 To [M:SIH4]NBLIG-1                      : # Factures
                   If [M:SIH4]XSIHORINUM(I)<>""
                      If [M:SIH1]SIHORINUM=""
                         [M:SIH1]SIHORINUM=[M:SIH4]XSIHORINUM(I)
                      Elsif [M:SIH1]SIHORINUM<>[M:SIH4]XSIHORINUM(I)
                         Raz [M:SIH1]SIHORINUM, [M:SIH1]SIHORIDAT
                         Break
                      Endif
                   Endif
                Next I
                # L'avoir redevient direct ssi plus aucune ligne issue d'une facture
                If [M:SIH1]SIHORINUM="" & sum([M:SIH4]XSIHORINUM)="" [M:SIH1]SIHORI=1 : Endif
 When 6       : For I=0 To [M:SIH4]NBLIG-1                      : # Retour
                   If [M:SIH4]SRHNUM(I)<>""
                      If [M:SIH1]SIHORINUM=""
                         [M:SIH1]SIHORINUM=[M:SIH4]SRHNUM(I)
                      Elsif [M:SIH1]SIHORINUM<>[M:SIH4]SRHNUM(I)
                         Raz [M:SIH1]SIHORINUM, [M:SIH1]SIHORIDAT
                         Break
                      Endif
                   Endif
                Next I
                # L'avoir redevient direct ssi plus aucune ligne issue d'un retour
                If [M:SIH1]SIHORINUM="" & sum([M:SIH4]SRHNUM)="" [M:SIH1]SIHORI=1 : Endif
 When 7       : For I=0 To [M:SIH4]NBLIG-1                     : # Contrats
                   If [M:SIH4]CONNUM(I)<>""
                      If [M:SIH1]SIHORINUM=""
                         [M:SIH1]SIHORINUM=[M:SIH4]CONNUM(I)
                      Elsif [M:SIH1]SIHORINUM<>[M:SIH4]CONNUM(I)
                         Raz [M:SIH1]SIHORINUM, [M:SIH1]SIHORIDAT
                         Break
                      Endif
                   Endif
                Next I
                # La facture redevient direct ssi plus aucune ligne issue d'un contrat
                If [M:SIH1]SIHORINUM="" & sum([M:SIH4]CONNUM)="" [M:SIH1]SIHORI=1 : Endif
 When 10      : # 107888 : Scheduled invoices : (LD:10/05/16)
                # For the moment, we manage only scheduled invoices from order
                For I=0 To [M:SIH4]NBLIG-1
                   If [M:SIH4]SOHNUM(I)<>""
                      If [M:SIH1]SIHORINUM=""
                         [M:SIH1]SIHORITYP=10
                         [M:SIH1]SIHORINUM=[M:SIH4]SOHNUM(I)
                      Elsif [M:SIH1]SIHORINUM<>[M:SIH4]SOHNUM(I)
                         Raz [M:SIH1]SIHORITYP
                         Raz [M:SIH1]SIHORINUM, [M:SIH1]SIHORIDAT
                         Break
                      Endif
                   Endif
                Next I
                # La facture redevient direct ssi plus aucune ligne issue d'une commande
                If [M:SIH1]SIHORINUM="" & sum([M:SIH4]SOHNUM)="" [M:SIH1]SIHORI=1 : Endif
                # 107888 : Scheduled invoices : (LD:10/05/16)
 When Default
Endcase
End


$CALC_INV
Local Decimal MNTCALC

If [F:ITM]ITMREF <> [M]ITMREF(NLIG)
    Read [ITM]ITM0=[M]ITMREF(NLIG)
    If fstat Raz [F:ITM] Endif
Endif

Return

#-----------------------------------------------------------------#
# Traitement particulier pour les proformas                       #
# Maj du n° proforma dans le document d'origine (devis, cde, liv) #
#-----------------------------------------------------------------#
Subprog MAJ_ORIPRF(WTYPACT, WORI, WORINUM, WNUM)
Value Char    WTYPACT
Value Integer WORI
Value Char    WORINUM
Value Char    WNUM

Case WORI
    When 2 : # --> Maj commande
        Readlock [SOH] SOH0=WORINUM
        If fstat = 1 GOK = -1
           GLOCK = "$SORDER"-WORINUM : End
        Elsif fstat = 0
           If WTYPACT="C"
               [F:SOH]PRFNUM=WNUM
           Elsif WTYPACT="A"
               Raz [F:SOH]PRFNUM
           Endif

           Rewrite [SOH]
           If fstat : GOK = 0 : Call FSTA("SOH") From GLOCK : End : Endif
        Endif
    When 3 : # --> Maj livraison
        Readlock [SDH] SDH0=WORINUM
        If fstat = 1 GOK = -1
           GLOCK = "$SDELIVERY"-WORINUM : Return
        Elsif fstat = 0
           If WTYPACT="C"
               [F:SDH]PRFNUM=WNUM
           Elsif WTYPACT="A"
               Raz [F:SDH]PRFNUM
           Endif
           Rewrite [SDH]
           If fstat : GOK = 0 : Call FSTA("SDH") From GLOCK : End : Endif
        Endif
    When 5 : # --> Maj devis
        If clalev ([F:SQH])=0 : Local File SQUOTE [SQH] : Endif
        Readlock [SQH] SQH0=WORINUM
        If fstat = 1 GOK = -1
           GLOCK = "$SQUOTE"-WORINUM : End
        Elsif fstat = 0
           If WTYPACT="C"
               [F:SQH]PRFNUM=WNUM
           Elsif WTYPACT="A"
               Raz [F:SQH]PRFNUM
           Endif
           Rewrite [SQH]
           If fstat : GOK = 0 : Call FSTA("SQH") From GLOCK : End : Endif
        Endif
        Close Local File [SQH]
    When Default
Endcase
End

##########################################################################################################

# ---------------------------------------------------------------------- #
# Initialisation du type de facture                                      #
# Si un type est trouvé, chargement des données à partir du type facture #
# ---------------------------------------------------------------------- #
$INIT_SIVTYP
Local Integer WSORTIR,WOK
Local Integer  WRETCTL #--CPO 71937 T757 Contrôle de cohérence

If !clalev([F:FGR]) : Local File FACGROUP  [FGR] : Endif
If !clalev([F:TSV]) : Local File TABSIVTYP [TSV] : Endif
#-------- CPO 68872
Local Char  WKFILROLE(250)
#--- Existe-il des filtres sur les rôles ?
Call FILROLE("TSV",WKFILROLE) From SUBARL
If WKFILROLE="" : WKFILROLE = "1=1" : Endif
#--------

# 89226
Local Char  WKFILSUP
# PE pour intervernir sur le type de facture
GPOINT="ALISIVTYP" : Gosub ENTREE From EXEFNC
If WKFILSUP="" : WKFILSUP = "1=1" : Endif
# 89226

Raz WSIVTYP : WOK=0
#--CPO 71937 T757 Contrôle de cohérence
#--Le Link n'a rien à faire dans la boucle While => déplacé avant
Link [TSV] With [FGR]FGR0=[F:TSV]GFY;GCURFCY As [KTSV]
#--/CPO
While WSORTIR=0

#--CPO 71937 T757 Contrôle de cohérence
#--Le Link n'a rien à faire dans la boucle While => déplacé avant
    #Link [TSV] With [FGR]FGR0=[F:TSV]GFY;GCURFCY As [KTSV]
    #--/CPO
    #-------- CPO 68872
    #-- X3suivi 71937 - T249 : Multi-Leg--#
    # 89226
#    Filter [KTSV] Where [TSV]INVTYP=[M:SIH0]INVTYP & ([TSV]GFY="" | [FGR]FCY=GCURFCY) & ([TSV]LEG="" | [TSV]LEG=GCURLEG)
#&                       & evalue(WKFILROLE)
# BRBAN 105200 - Needed to filter invoice cancellation types
Local Char WKINVCAN(50)  : [L]WKINVCAN = '1=1'

If func AFNC.ACTIV("INVCA") > 0 & GFONCTION = 'GESSIH'
  If [F:SLT]INVCAN=2 & find([M:SIH0]INVTYP,2,4)
    WKINVCAN -= "& [F:TSV]INVCAN=2"
  Endif
Endif

If instr(1,WKFILROLE,"[F:TSV]GFY")>0  # Ini X3-58117 (JUCON 15/11/17)
  Filter [KTSV] Where [TSV]INVTYP=[M:SIH0]INVTYP & ([FGR]FCY=GCURFCY) & ([TSV]LEG="" | [TSV]LEG=GCURLEG)
&                       & evalue(WKFILROLE) & evalue(WKFILSUP)
&          Order By Key CLE=[F:TSV]SIVTYP Asc; [F:TSV]LEG Desc

Else                                  # End X3-58117
  Filter [KTSV] Where [TSV]INVTYP=[M:SIH0]INVTYP & ([TSV]GFY="" | [FGR]FCY=GCURFCY) & ([TSV]LEG="" | [TSV]LEG=GCURLEG)
&                       & evalue(WKFILROLE) & evalue(WKFILSUP)
&          Order By Key CLE=[F:TSV]SIVTYP Asc; [F:TSV]LEG Desc
Endif

    #--------
    #--CPO 71937 T757 Contrôle de cohérence
#    Read [KTSV]CLE First
#    If fstat=0
#        WSIVTYP = [F:TSV]SIVTYP
#        Call GET_ATEXTRA("TABSIVTYP","SHOAXX",GLANGUE,[M:SIH0]ZSIVTYP) From TRTX3TEX
#        WSORTIR=1
#        WOK=1
#    Else
For [KTSV]CLE
      Call CTL_ML_CONSISTENCY("TSV", "NON",[F:KTSV]SIVTYP,[F:KTSV]LEG,AVOID.ACHAR,GCURFCY,GCURLEG,WRETCTL,AVOID.ACHAR) From TRTVENCTL
      If WRETCTL=0
        WSIVTYP = [F:TSV]SIVTYP
        [M:SIH0]SIVTYP=WSIVTYP  # X3-113544 Retreive Sale invoice type accorting to the role (JUCON 19/10/2018)
        Call GET_ATEXTRA("TABSIVTYP","SHOAXX",GLANGUE,[M:SIH0]ZSIVTYP) From TRTX3TEX
        WSORTIR=1
        WOK=1
        Break
      Endif
Next
If WSORTIR=0
#--/
        If GFACTYP=5
          If [M]INVTYP=1
            [M]INVTYP=2
          Elsif [M]INVTYP=2
            [M]INVTYP=5
          Else
            WSORTIR=1
          Endif
        Elsif GFACTYP=4
          If [M]INVTYP=1
            [M]INVTYP=5
          Else
            WSORTIR=1
          Endif
        Else
          WSORTIR=1
        Endif
    Endif
Wend

#--CPO 71937 T757 Contrôle de cohérence
#If WOK=0 GERR=1 : GMESSAGE = mess(185,192,1) : Return : Endif #X3-58117 (JUCON 15/11/17)
If WOK=0 or rowcount([KTSV])=0 :  GMESSAGE = mess(185,192,1) :mkstat=1: Endif #X3-58117 (JUCON 15/11/17)
Filter [KTSV] #Filter [TSV]

# -- Chargement des données à partir du type de facture
#    --> Alimentation catégorie facture, type pièce, code journal
#    --> Alimentation infos compteur
#    --> Si type pièce renseigné : Contrôle et récup infos compteur
Gosub CHARG_SIVTYP
If GERR=1 :  Return Endif

Return

##########################################################################################################
# -------------------------------------------------------------- #
# Chargement à partir du type de facture                         #
# --> Alimentation catégorie facture, type pièce, code journal   #
# --> Alimentation infos compteur                                #
# --> Si type pièce renseigné : Contrôle et récup infos compteur #
# -------------------------------------------------------------- #
$CHARG_SIVTYP

If !clalev([F:GTE]) : Local File GTYPACCENT [GTE] : Endif
# Alimentation catégorie facture, type pièce, code journal
[M:SIH0]INVTYP = [F:TSV]INVTYP
[M:SIH0]GTE    = [F:TSV]GTE
[M:SIH0]JOU    = [F:TSV]JOU
[M:SIH0]COD    = [F:TSV]COD

Case [M:SIH0]INVTYP
    When 1    : # Facture
        GMANCOU = [F:TCA]MANCOU(3) : GCPT = [F:TCA]CODNUM(3)
    When 2    : # Avoir
        GMANCOU = [F:TCA]MANCOU(4) : GCPT = [F:TCA]CODNUM(4)
    When 5    : # Proforma
        GMANCOU = [F:TCA]MANCOU(5) : GCPT = [F:TCA]CODNUM(5)
Endcase

If [M]INVTYP <> 5 & [M]GTE <> ""
   # Lecture type pièce
   If [F:GTE]TYP <> [M]GTE
      #--CPO 30/09/2016 Il restait un Read [GTE] => remplacé par LEC_GTE_LEG !
      Local Integer WRET
      Call LEC_GTE_LEG(GCURLEG,[M]GTE,WRET) From TRTLECLEG
   Endif
   # Type de pièce inexistant
   If [F:GTE]TYP="" GERR=1 : GMESSAGE = [M]GTE-mess(17,114,1)  : Return : Endif
   # Type de pièce inactive
   If [F:GTE]ENAFLG<>2 GERR=1 : GMESSAGE = [M]GTE-mess(274,199,1) : Return : Endif
   # Type de pièce non réel
   If [F:GTE]VCRREA<>2 GERR=1 : GMESSAGE = [M]GTE-mess(59,119,1) : Return : Endif
   # Vous n'avez pas les droits d'exécution
   If [F:GTE]ACS<>""
      Call CONTEXE([F:GTE]ACS) From CPTSUB
      If mkstat GERR=1:GMESSAGE=[F:GTE]ACS-GMESSAGE : Return : Endif
   Endif
   # Récupération des infos compteur à partir du type de pièce
   If [F:GTE]COU<>""
      GMANCOU=[F:GTE]MANNUM : GCPT=[F:GTE]COU
   Endif
Endif

Return
################################################################################################
################################################################################################
$SHDCLEECNUM

If ! dim([M:SIH1]DCLEECNUM)>0 : Return : Endif
Local Shortint SHOWFIELD #1 - reg; 2 - display; 3 - hidden
Local Char     CRYEECFMT(30), BPRNUM(GLONBPR)

#set flg to show or hide the field
If [F:SLT]STRTYP <> 5 | [F:SLT]STRNUM <> GFLAG
  Read [F:SLT]SLT0 = 5;GFLAG
Endif
If fstat : Raz [F:SLT] : Endif

SHOWFIELD = [F:SLT]DCLEECNUMCOD               # transaction value
If func AFNC.PARAM("PORVAT", GSOCIETE) <> "2" # if porvat parameter not on, hide
  SHOWFIELD = 3
Endif
If SHOWFIELD = 1 & [M:SIH1]INVSTA=3        # if in reg. state and invoice is posted, set to display only
  SHOWFIELD = 2
Endif

#get contry EECFMT of current bpr
Raz CRYEECFMT
If zoncou = "BPCINV"
  BPRNUM = VALEUR
Else
  BPRNUM = [M:SIH0]BPCINV
Endif
If BPRNUM <> ""
  Call LEC_BPR(BPRNUM) From CPTLEC
  Call LEC_TCY([F:BPR]CRY) From CPTLEC
  CRYEECFMT = [F:TCY]EECFMT
Else
  CRYEECFMT = num$(GLONEEC)+"X"
Endif
If CRYEECFMT = "" : FIELDFMT = "20X" : Endif

#show/hide
Case SHOWFIELD
  When 1 : Chgfmt [M:SIH1]DCLEECNUM With "K:"+CRYEECFMT
  When 2 : Chgfmt [M:SIH1]DCLEECNUM With "KP:"+CRYEECFMT
  When 3 : Chgfmt [M:SIH1]DCLEECNUM With "-K:"+CRYEECFMT
Endcase

Return
################################################################################################
#--CPO 87923 Gestion des prélèvements SDD
#-----------------------------------------------#
#--On initialise et on contrôle le mandat       #
#-----------------------------------------------#
$INIT_CTL_UMRNUM
Local Char WMESS_UMRNUM(250)

Raz WMESS_UMRNUM
If dim([M:SIH2]UMRNUM)>0
  Call INIT_CTL_UMRNUM(GSOCIETE,[M:SIH1]BPRPAY,[M:SIH2]PTE,[M:SIH2]UMRNUM,WMESS_UMRNUM) From TRTVENSDD
  If WMESS_UMRNUM<>""
    Call ECR_TRACE(WMESS_UMRNUM,0) From GESECRAN
  Endif
Endif

Return
