#<AdxTL>@(#)5.0.0.0 $Revision$
Local Char PARAM(10)(1..2) , VALEUR(10)
GERR = 0
Call TRAITE_CHAR(VALEUR,PARAM,"","BALCONSO","BALCONSO",4,"") From GTRAITE
End

########################################
Subprog C_GRUGPY(VALEUR)
Variable Char    VALEUR()
Call LECTURE("AGF",VALEUR,"") From CONTOBJ
If [F:AGF]FLGCPY<>2
 GMESSAGE = VALEUR-":"-mess(137,107,1) : # N'est pas un groupe de sociétés
 mkstat = 2 : End
Endif
Call CONTALLCPY(VALEUR) From CPTSUB
End

Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
# bug 12539 (CP:22/01/02)
#Call AS_ALLCPY(VALEUR) From CPTTRT
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 mkstat = 1 : End 
Endif
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CPYDEB,CPYFIN
 Grizo CPYDEB,CPYFIN
Else
 Actzo CPYDEB,CPYFIN
Endif
End

Subprog AS_CPYDEB(VALEUR)
Variable Char    VALEUR()
If [M]ALLCPY=2 : mkstat = 1 : End : Endif
End

Subprog AS_CPYFIN(VALEUR)
Variable Char    VALEUR()
If [M]ALLCPY=2 : mkstat = 1 : End : Endif
If VALEUR=""
 VALEUR = [M]CPYDEB
Endif
End

Subprog C_CPYFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR<[M]CPYDEB : mkstat = 1 : End : Endif
If GUSRFCY(1)="\" : End : Endif
For [CPY]CPY0 Where CPY>=[M]CPYDEB & CPY<=VALEUR
 For I=1 To GNBSITE
  If GSOCSITE(I)=[F:CPY]CPY & !find(GSITE(I),GUSRFCY(1..GNBAUZ))
   GMESSAGE = mess(32,104,1)-[F:CPY]CPY : # Tous les sites ne sont pas accessibles dans la société
   mkstat = 1 : Break
  Endif
 Next I
Next
End

Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR = [0/0/0]
 VALEUR = GDATEDEB : [M]ENDDAT = GDATEFIN
Endif
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
If VALEUR<>[M]LEDTYP & [M]ANA=2
 [M]LEDTYP = VALEUR
 Gosub INIAXE
Endif
End

Subprog AS_CUR(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 For [AGC] Where GRP=[M]GRUGPY
  If [M]ALLCPY=2 or ([F:AGC]CPY>=[M]CPYDEB & ([M]CPYFIN="" or [F:AGC]CPY<=[M]CPYFIN))
   Read [CPY]CPY0 = [F:AGC]CPY
   Read [GCM]GCM0 = [F:CPY]ACM
   VALEUR = [F:GCM]CUR([M]LEDTYP-1)
   Break
  Endif
 Next
Endif
End

Subprog AM_ANA(VALEUR)
Variable Integer VALEUR
Local Integer I
If VALEUR=1
 Effzo 20
 Grizo 20
Else
 Gosub INIAXE
Endif
End

$INIAXE
Actzo 20
[M]NBAXE = 0
For [AGC] Where GRP=[M]GRUGPY
 If [M]ALLCPY=2 or ([F:AGC]CPY>=[M]CPYDEB & ([M]CPYFIN="" or [F:AGC]CPY<=[M]CPYFIN))
  Call LECTURE("CPY",[F:AGC]CPY,"") From CONTOBJ
  Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
  Call LECTURE("LED",[F:GCM]LED([M]LEDTYP-1),"") From CONTOBJ
  For I=0 To [F:LED]DIENBR-1
   If [M]NBAXE<dim([M]AXE) & !find([F:LED]DIE(I),[M]AXE(0..[M]NBAXE-1))
    [M]AXE([M]NBAXE) = [F:LED]DIE(I)
    [M]NBAXE += 1
   Endif
  Next I
 Endif
Next
Affzo 20
Return

Subprog AS_NBAXE
If [M]ANA<>2
 mkstat = 1 : End
Endif
End

Subprog C_AXE(VALEUR)
Variable Char VALEUR()
Local Integer OK
Call UNICITE(VALEUR,[M]AXE) From OBJDIV
If mkstat : End : Endif
OK = 0
For [AGC] Where GRP=[M]GRUGPY
 If [M]ALLCPY=2 or ([F:AGC]CPY>=[M]CPYDEB & ([M]CPYFIN="" or [F:AGC]CPY<=[M]CPYFIN))
  Call LECTURE("CPY",[F:AGC]CPY,"") From CONTOBJ
  Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
  Call LECTURE("LED",[F:GCM]LED([M]LEDTYP-1),"") From CONTOBJ
  If find(VALEUR,[F:LED]DIE(0..[F:LED]DIENBR-1))
   OK = 1 : Break
  Endif
 Endif
Next
If !OK
 GMESSAGE = mess(40,103,1) : # Axe incorrect
 mkstat = 2 : End
Endif
End


######################################################################################

