Subprog AM_GPGCODDEB(VALEUR)
Variable Char    VALEUR()
If [M]GPGCODFIN="" [M]GPGCODFIN=VALEUR : Affzo [M]GPGCODFIN : Endif
If [M]GPGCODFIN < VALEUR [M]GPGCODFIN = VALEUR : Affzo [M]GPGCODFIN : Endif
End

