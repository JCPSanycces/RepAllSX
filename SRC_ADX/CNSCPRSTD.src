#<AdxTL>@(#)6.0.0.0 $Revision$
#########################################################################
# CNSCPRSTD : Consultation des réceptions d'achat          HN  10/05/00 #
# ECRAN 1   : CONSCPR1                                                  #
# ECRAN 2   : CONSCPR2                                                  #
# ECRAN CRIT: CRITCPR                                                   #
#########################################################################
Local Char PARAM(20)(1..2)
PARAM(1) = "2204"
PARAM(2) = "GAL"
Call GCONSULT("CPR","",PARAM) From GCONSULT
End
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When Default
Endcase
Return

############################################################
$AUTORIS
Return

############################################################
$SETBOUT
CHMEN+="BC"
Return

###################################################################
# analyse paramères, initialisations, ouvertures et déclarations  #
###################################################################
$OUVRE
NAVIG="CONSCPR"
Local Char    WFIL(250),WFIL1(250),WFIL2(250),WFIL3(250)
Local Char    DEBNUM(GLONPTH), FINNUM(GLONPTH)
Local Date    DEBDAT, FINDAT
Gosub DEFCRIT
# Issue 84130 - 2013-01-31 by MAE : Déclaration des variables pour les requetes
Local Char REQUETE(255)(3)
Local Char REQUETEPID(255)(2)
Local Char REQUETECPR(255)(3)
Local Integer BASE
Local Decimal WDISCGRAMTMAX, WDISCGRAMTMIN, WAMTNOTLIN
Local Integer LRET  # Issue 84130 - 2013-04-08 by MAE :

# Issue 84130 - 2013-04-08 by MAE : ouverture de l'écran [CTS2]
If !clalev([M:CST2]) Local Mask CSTLIN2 [CST2]  : Endif
If !clalev([F:PTD])  Local File PRECEIPTD [PTD]  : Endif

If !clalev([F:PID])  Local File PINVOICED [PID]  : Endif
If !clalev([F:PFI])  Local File PFOOTINV [PFI]  : Endif
If !clalev([F:PVF])  Local File PVCRFOOT [PVF]  : Endif

Case GTYPDBA
    When 1 : BASE=3 : # Oracle
    When 2 : BASE=5 : # Sql
    When 3 : BASE=2 : # Cisam
    When 4 : BASE=4 : # DB2
  Endcase
#fin MAE 84130

# Issue 121785 - 2017-03-01 by MUARN : GTYPGEN non alimenté
Call GETDEV(GSOCIETE) From DEVSUB
Return

# --------------------------------------------------------------------------#
# Analyse paramères, initialisations                                        #
# --------------------------------------------------------------------------#
$DEFCRIT
If GNBAUZ=1 : PARAM(2) = GUSRFCY(1) : Endif
For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre Fournisseur
      If PARAM(I) <> ""
        If [F:BPS]BPSNUM <> PARAM(I) Read [BPS] BPS0 = PARAM(I)
                                     If fstat  Raz [F:BPS], PARAM(I) : Endif
        Endif
#        [M:CPR1]BPSNUM = PARAM(I)   #US 71069/138  by RBA
        [M:CPR1]BPSNUMDEB = PARAM(I)
        [M:CPR1]BPSNUMFIN = PARAM(I)
      Endif
    When 2 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)    Read [FCY] FCY0 = PARAM(I)
                                     If fstat  Raz [F:FCY], PARAM(I) : Endif
        Endif
        If (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
            [M:CPR1]PRHFCY = PARAM(I)
            Call GETDEV([M:CPR1]PRHFCY) From DEVSUB
            [M:CPR1]CPY = GSOCIETE
            [M:CPR1]CUR = GLOCALDEV
        Endif
      Endif
    When 3 :    : # Nom du champ
      If PARAM(I) <> ""
        Case PARAM(I)
          When "NIVDLV" : [M:CPR1]INVFLGO=1 : [M:CPR1]INVFLGN=2
        Endcase
      Endif
     # Issue 84130 - 2013-02-07 by MAE : landed cost
   When 4 :    : # Parametre Commande
      If PARAM(I) <> ""
        [M:CPR1]PTHNUMDEB = PARAM(I)
        [M:CPR1]PTHNUMFIN = PARAM(I)
      Endif
  Endcase
Next I
[M:CPR1]CURD=GSYSCUR
If [M:CPR1]CUR=""  [M:CPR1]CUR=GSYSCUR : Endif
# facturée oui
If !find([M:CPR1]INVFLGO,1,2) : [M:CPR1]INVFLGO= 2 : Endif
# facturée non
If !find([M:CPR1]INVFLGN,1,2) : [M:CPR1]INVFLGN= 2 : Endif
# comptabilisée oui
If !find([M:CPR1]PSTFLGO,1,2) : [M:CPR1]PSTFLGO= 2 : Endif
# comptabilisée non
If !find([M:CPR1]PSTFLGN,1,2) : [M:CPR1]PSTFLGN= 2 : Endif
# imprimée oui
If !find([M:CCPR]PRNFLGO,1,2) : [M:CCPR]PRNFLGO= 2 : Endif
# imprimée non
If !find([M:CCPR]PRNFLGN,1,2) : [M:CCPR]PRNFLGN= 2 : Endif
If !find([M:CCPR]TRI,1,2)     : [M:CCPR]TRI = 1   : Endif
#----- Initialisation dates début et fin -----#
#MAE, 84130, si on vient d'une réception, on n'initialise pas les dates et on initialise le code regroupement
If GPILNAV>1
  If find(GNAVIG(GPILNAV-1),"GESPTH")| find(GNAVIG(GPILNAV-1),"GESPTH2")
    [M:CPR1]GPGCODDEB = [F:PTH]GPGCOD
    [M:CPR1]GPGCODFIN = [F:PTH]GPGCOD
  Else
    Gosub INIT_DATES From TRTACHGRH1
    [M:CPR1]RCPDATDEB=WDATDEB
    [M:CPR1]RCPDATFIN=WDATFIN
  Endif
Else
  Gosub INIT_DATES From TRTACHGRH1
  [M:CPR1]RCPDATDEB=WDATDEB
  [M:CPR1]RCPDATFIN=WDATFIN
Endif
#----- Copie du masque 1 (CPR1) vers l'écran critères (CCPR) -----#
Gosub CRITENT From =PROGCNS
Return

############################################################
$LECTURE
Local   Decimal  WCLCAMT(1..7)
Local   Decimal  WMNTORG(0..1), WMNTDES(0..1), WMNTHT, WMNTTTC
Local   Integer  SPSTAT
#----- Grisage du champ fournisseur si consultation depuis celui-ci -----#
If GPILNAV>1
  If find(GNAVIG(GPILNAV-1),"GESBPS")
#    Diszo [CPR1]BPSNUM :
    Diszo [M:CPR1]BPSNUMDEB : Diszo [M:CPR1]BPSNUMFIN
  Endif

Endif
#-----
Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCPR]TRI
      When 1 : # tri par numéro
        Filter [PTH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) Order By Key PTH0
      When 2 : # tri par date
        Filter [PTH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&                    Order By Key PTH3
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCPR]TRI
      When 1 : # tri par numéro
        Filter [PTH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3) Order By Key PTH0 Desc
      When 2 : # tri par date
        Filter [PTH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) & evalue(WFIL3)
&                    Order By Key PTH3 Desc
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CPR2] : Endif

#-- lecture
$BOUCLE
For [PTH]

# Filtre sur la société
  If [M:CPR1]CPY <> ""
      If [F:FCY]FCY <> [F:PTH]PRHFCY Read [FCY] FCY0 = [F:PTH]PRHFCY
                                     If fstat  Raz [F:FCY] : Endif
                                     Endif
      If [F:FCY]LEGCPY <> [M:CPR1]CPY Goto SUIV : Endif
      # Issue 91193 - 2013-08-09 by MUARN : Réaffectation Globale
      GSOCIETE = [M:CPR1]CPY
  Else  #MAE, 84130, si la société est vide, on réaffecte les variables globales
    GLOCALDEV=[F:PTH]CUR
    GSOCIETE = [F:PTH]CPY
  Endif

  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:CPR2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
     NOL    += 1
     If NOL=0
         DEBNUM = [F:PTH]PTHNUM
         DEBDAT = [F:PTH]RCPDAT
     Endif
     FINNUM = [F:PTH]PTHNUM
     FINDAT = [F:PTH]RCPDAT
  Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
     NOL    -= 1
     If NOL=MAXLIG-1
         FINNUM = [F:PTH]PTHNUM
         FINDAT = [F:PTH]RCPDAT
     Endif
     DEBNUM = [F:PTH]PTHNUM
     DEBDAT = [F:PTH]RCPDAT
  Endif
  nolign = NOL+1
  [M:CPR2] = [F:PTH]
# Lecture de la devise pour récupérer le format
  If clalev([F:TCU])= 0 : Local File TABCUR [TCU] : Endif
  If [F:TCU]CUR <> [F:PTH]CUR
     Read [TCU] TCU0 = [F:PTH]CUR
     If fstat Raz [F:TCU] : Endif
  Endif
# Recherche du montant HT
  Raz WMNTORG(0), WMNTORG(1), WAMTNOTLIN
  For [PTD] PTD0 Where PTHNUM=[F:PTH]PTHNUM
#   calcul du montant HT de la ligne
    Raz WMNTHT, WMNTTTC
    WMNTHT    =[F:PTD]NETPRIPUU * [F:PTD]QTYPUU
    WCLCAMT(1)=[F:PTD]CLCAMT1
    WCLCAMT(2)=[F:PTD]CLCAMT2
    WCLCAMT(3)=[F:PTD]CLCAMT3
    Call CLCTAXEMNT2(WMNTHT,[F:PTD]VAT,1,GSOCIETE,[F:PTD]RCPDAT,WCLCAMT,WMNTTTC) From TRTX3
    WMNTORG(0) += arr(WMNTHT, [F:TCU]CURRND)
    WMNTORG(1) += arr(WMNTTTC,[F:TCU]CURRND)
    # Issue 84130 - 2013-04-08 by MAE : lecteure des factures complémentaires
    Call COST_ADDINV(2,[F:PTD]PTHNUM,[F:PTD]PTDLIN,0,[F:PTD]PRHFCY,[F:PTD]ITMREF,LRET) From STCLIB
    If LRET
      GMESSAGE = mess(44,199,1)
      mkstat = 2
    Endif
    For J=0 To [M:CST2]NBNONDET-1
      If [M:CST2]CURCPY3(J) <> [F:PTH]CUR & [F:PTH]CHGCOE<>0
        [M:CPR2]AMTNOTLIND(nolign-1) += arr([M:CST2]AMTNDTCPY(J)/[F:PTH]CHGCOE,[F:TCU]CURRND)
      Else
        [M:CPR2]AMTNOTLIND(nolign-1) += [M:CST2]AMTNDTCPY(J)
      Endif
    Next
    # Issue 84130 - 2013-04-08 by MAE : Fin lecture factures complémentaires
  Next
  [M:CPR2]TOTPRH(nolign-1)    = [F:PTH]TOTAMTNOT
  [M:CPR2]TTCPRH(nolign-1)    = [F:PTH]TOTAMTATI


# Montants en devise société
  If [F:PTH]CUR<>[M:CPR1]CUR
    Call CONVERT2([F:PTH]CUR,[M:CPR1]CUR,[M:CPR1]CUR,[F:PTH]CHGTYP,datesyst,
&                 WMNTORG(0),WMNTDES(0),SPSTAT) From TRTDEV
    Call CONVERT2([F:PTH]CUR,[M:CPR1]CUR,[M:CPR1]CUR,[F:PTH]CHGTYP,datesyst,
&                 WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
    If [F:TCU]CUR <> [M:CPR1]CUR
       Read [F:TCU]TCU0 = [M:CPR1]CUR
       If fstat Raz [F:TCU] : Endif
    Endif
    [M:CPR2]TOTPRHLOC(nolign-1) = arr(WMNTDES(0),[F:TCU]CURRND)
    [M:CPR2]TTCPRHLOC(nolign-1) = arr(WMNTDES(1),[F:TCU]CURRND)
  Else
    [M:CPR2]TOTPRHLOC(nolign-1) = [M:CPR2]TOTPRH(nolign-1)
    [M:CPR2]TTCPRHLOC(nolign-1) = [M:CPR2]TTCPRH(nolign-1)
  Endif
# Montants en devise dossier
  If [M:CPR1]CUR=[M:CPR1]CURD
    [M:CPR2]TOTPRHDOS(nolign-1) = [M:CPR2]TOTPRHLOC(nolign-1)
    [M:CPR2]TTCPRHDOS(nolign-1) = [M:CPR2]TTCPRHLOC(nolign-1)
  Else
    Call CONVERT2([F:PTH]CUR,[M:CPR1]CURD,[M:CPR1]CURD,[F:PTH]CHGTYP,datesyst,
&                 WMNTORG(0),WMNTDES(0),SPSTAT) From TRTDEV
    Call CONVERT2([F:PTH]CUR,[M:CPR1]CURD,[M:CPR1]CURD,[F:PTH]CHGTYP,datesyst,
&                 WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
    If [F:TCU]CUR <> [M:CPR1]CURD
       Read [F:TCU]TCU0 = [M:CPR1]CUR
       If fstat Raz [F:TCU] : Endif
    Endif
    [M:CPR2]TOTPRHDOS(nolign-1) = arr(WMNTDES(0),[F:TCU]CURRND)
    [M:CPR2]TTCPRHDOS(nolign-1) = arr(WMNTDES(1),[F:TCU]CURRND)
  Endif
# Site de réception
  [M:CPR2]PRHFCY(nolign-1)     = [F:PTH]PRHFCY
# N BL fournisseur
  [M:CPR2]BPSNDE(nolign-1)     = [F:PTH]BPSNDE
# Flag de facturation
  [M:CPR2]INVFLG(nolign-1)     = [F:PTH]INVFLG
  # sr 08.12 issue 79772
#----- Réajustement indicateur "facturée" si nécessaire -----#
  If [F:PTH]INVFLG=3
       # Issue 84972 - 2012-10-08 by SR
       If [F:PTH]INVFLG=3  [M:CPR2]CLEFLG(nolign-1)=2 Else [M:CPR2]CLEFLG(nolign-1)=1 : Endif
       Filter [F:PTD] Where (PTHNUM = [F:PTH]PTHNUM) & (INVQTYSTU < QTYSTU)
       If rowcount([F:PTD]) > 0
          [M:CPR2]INVFLG(nolign-1)=2
       Endif
       Filter [F:PTD]
  Endif
# Flag de comptabilisation
  [M:CPR2]PSTFLG(nolign-1)     = [F:PTH]PSTFLG
  If [F:PTH]PSTFLG = 0
    [M:CPR2]PSTFLG(nolign-1)   = 1
  Endif
# Flag d'impression
  [M:CPR2]PRNFLG(nolign-1)     = [F:PTH]PRNFLG

  #US 71069/12  PJT by RBA
  [M:CPR2]PJTH(nolign-1)       = [F:PTH]PJTH
  #/US 71069/12  PJT by RBA

  # Issue 84130 - 2013-01-31 by MAE : Lecture les lignes de commande pour récupérer les montants

  #Calcul sur la somme des lignes de commande
  #Charges directes, coût achat,  montant ligne hors taxes
  REQUETE(0) = "SELECT SUM(FCSCSTPUR_0),SUM(LINAMT_0),SUM(LINCSTPUR_0)"
  #taxes non déductibles
  REQUETE(1)=
&
&
&
&
&
&
&
&
&
&
&
&
&
&
&
&
& 
& ",SUM((AMTTAXLIN1_0-DEDTAXLIN1_0)+(AMTTAXLIN2_0-DEDTAXLIN2_0)+(AMTTAXLIN3_0-DEDTAXLIN3_0)+(AMTTAXRCP_0-DEDTAXRCP_0)+(AMTTAXISS_0-DEDTAXISS_0)+(AMTTAXOTH1_0-DEDTAXOTH1_0)+(AMTTAXOTH2_0-DEDTAXOTH2_0))"
  REQUETE(2)=" from PRECEIPTD WHERE PTHNUM_0='"+[M:CPR2]PTHNUM(nolign-1)+"'"

  For (Decimal WFCSCSTPUR,Decimal WLINAMT,Decimal WLINCSTPUR,Decimal WNONDEDTAX) From num$(BASE) Sql REQUETE As [SPOQ]
    If [F:PTH]CHGCOE<>0
      [M:CPR2]FCSCSTPURD(nolign-1)= arr([SPOQ]WFCSCSTPUR/[F:PTH]CHGCOE,[F:TCU]CURRND)
      [M:CPR2]LINCSTPUR(nolign-1)=  arr([SPOQ]WFCSCSTPUR/[F:PTH]CHGCOE,10^-GDECPRI)
    Else
      [M:CPR2]FCSCSTPURD(nolign-1)= arr([SPOQ]WFCSCSTPUR,[F:TCU]CURRND)
      [M:CPR2]LINCSTPUR(nolign-1)=  arr([SPOQ]WFCSCSTPUR,10^-GDECPRI)
    Endif
    [M:CPR2]LINAMT(nolign-1)=  arr(WLINAMT,[F:TCU]CURRND)
    [M:CPR2]NONDEDTAXD(nolign-1)=  arr(WNONDEDTAX,[F:TCU]CURRND)
   Next

#Calcul total coefficient d'approche sur les lignes en coeff d'approche
REQUETECPR(0)="select SUM(LINCSTPUR_0),SUM(LINAMT_0), SUM(DISCRGAMT1_0+DISCRGAMT2_0+DISCRGAMT3_0+DISCRGAMT4_0+DISCRGAMT5_0+DISCRGAMT6_0+DISCRGAMT7_0+DISCRGAMT8_0+DISCRGAMT9_0),"
REQUETECPR(1)=
& "SUM((AMTTAXLIN1_0-DEDTAXLIN1_0)+(AMTTAXLIN2_0-DEDTAXLIN2_0)+(AMTTAXLIN3_0-DEDTAXLIN3_0)+(AMTTAXRCP_0-DEDTAXRCP_0)+(AMTTAXISS_0-DEDTAXISS_0)+(AMTTAXOTH1_0-DEDTAXOTH1_0)+(AMTTAXOTH2_0-DEDTAXOTH2_0))"
REQUETECPR(2)=" from PRECEIPTD WHERE PTHNUM_0='"+[M:CPR2]PTHNUM(nolign-1)+"' and (CPRCOE_0<>1 or CPRAMT_0<>0)"

  For (Decimal WLINCSTPURCA,Decimal WLINAMTCA,Decimal WDISCGRAMT,Decimal WDEDTAXLIN) From num$(BASE) Sql REQUETECPR As [SPCP]
    If [F:PTH]CHGCOE<>0
      [M:CPR2]TOTCOEFFAPPD(nolign-1) =  arr([SPCP]WLINCSTPURCA/[F:PTH]CHGCOE - [SPCP]WLINAMTCA - [SPCP]WDISCGRAMT - [SPCP]WDEDTAXLIN,[F:TCU]CURRND)
    Else
      [M:CPR2]TOTCOEFFAPPD(nolign-1) =  arr([SPCP]WLINCSTPURCA - [SPCP]WLINAMTCA - [SPCP]WDISCGRAMT - [SPCP]WDEDTAXLIN,[F:TCU]CURRND)
    Endif
  Next

Raz WDISCGRAMTMAX, WDISCGRAMTMIN

#Total éléments de facturation :Lecture de PVCRFOOT pour sommer les éléments de facturation
Filter [PVF] Where [F:PVF]VCRNUM = [F:PTH]PTHNUM & [F:PVF]VCRTYP=6
  For [PVF]
    Read [PFI] PFI0=[F:PVF]INVDTA : If fstat Raz [F:PFI] : Endif
    If [F:PFI]INCDCR=1
      WDISCGRAMTMAX +=[F:PVF]INVDTAAMT
    Else
      WDISCGRAMTMIN +=[F:PVF]INVDTAAMT
    Endif
 Next
[M:CPR2]DISCGRAMTMID(nolign-1) = WDISCGRAMTMIN
[M:CPR2]DISCGRAMTMAD(nolign-1) = WDISCGRAMTMAX

#Total des charges : charges directes + Elts fact maj + taxes non ded + fac compl
#                    + frais approche
[M:CPR2]TOTCHARGESD(nolign-1) = [M:CPR2]FCSCSTPURD(nolign-1) + [M:CPR2]DISCGRAMTMAD(nolign-1) +
&                              [M:CPR2]NONDEDTAXD(nolign-1) + [M:CPR2]AMTNOTLIND(nolign-1) +
&                              [M:CPR2]TOTCOEFFAPPD(nolign-1)

#Total cout achat = mtt HT+charges directes +Elt fact majo+Elt facto min + Taxes non ded
#                  +FCC + frais d'approche
[M:CPR2]TOTCOUTACHD(nolign-1) = [M:CPR2]LINAMT(nolign-1)+[M:CPR2]FCSCSTPURD(nolign-1)+
&                              [M:CPR2]DISCGRAMTMAD(nolign-1)+[M:CPR2]DISCGRAMTMID(nolign-1)+
&                              [M:CPR2]NONDEDTAXD(nolign-1)+ [M:CPR2]AMTNOTLIND(nolign-1) +
&                              [M:CPR2]TOTCOEFFAPPD(nolign-1)

#MAE, exi 91193
#conversion en devise société
If [M:CPR1]CUR <> [F:PTH]CUR & [F:PTH]CHGCOE<>0
  [M:CPR2]LINAMTSOC(nolign-1) = arr([M:CPR2]LINAMT(nolign-1)*[F:PTH]CHGCOE,[F:TCU]CURRND)
  [M:CPR2]DISCGRAMTMIS(nolign-1) = arr([M:CPR2]DISCGRAMTMID(nolign-1)*[F:PTH]CHGCOE,[F:TCU]CURRND)
  [M:CPR2]TOTCHARGESS(nolign-1) = arr([M:CPR2]TOTCHARGESD(nolign-1)*[F:PTH]CHGCOE,[F:TCU]CURRND)
  [M:CPR2]TOTCOUTACHS(nolign-1) = arr([M:CPR2]TOTCOUTACHD(nolign-1)*[F:PTH]CHGCOE,[F:TCU]CURRND)
  # MUARN, exi 91193
  [M:CPR2]DISCGRAMTMAS(nolign-1) = arr([M:CPR2]DISCGRAMTMAD(nolign-1)*[F:PTH]CHGCOE,[F:TCU]CURRND)
  [M:CPR2]NONDEDTAXS(nolign-1) = arr([M:CPR2]NONDEDTAXD(nolign-1)*[F:PTH]CHGCOE,[F:TCU]CURRND)
  [M:CPR2]FCSCSTPURS(nolign-1) = arr([M:CPR2]FCSCSTPURD(nolign-1)*[F:PTH]CHGCOE,[F:TCU]CURRND)
  [M:CPR2]AMTNOTLINS(nolign-1) = arr([M:CPR2]AMTNOTLIND(nolign-1)*[F:PTH]CHGCOE,[F:TCU]CURRND)
  [M:CPR2]TOTCOEFFAPPS(nolign-1) = arr([M:CPR2]TOTCOEFFAPPD(nolign-1)*[F:PTH]CHGCOE,[F:TCU]CURRND)
Else
  [M:CPR2]LINAMTSOC(nolign-1) = [M:CPR2]LINAMT(nolign-1)
  [M:CPR2]DISCGRAMTMIS(nolign-1) = [M:CPR2]DISCGRAMTMID(nolign-1)
  [M:CPR2]TOTCHARGESS(nolign-1) = [M:CPR2]TOTCHARGESD(nolign-1)
  [M:CPR2]TOTCOUTACHS(nolign-1) = [M:CPR2]TOTCOUTACHD(nolign-1)
  # MUARN, exi 91193
  [M:CPR2]DISCGRAMTMAS(nolign-1) = [M:CPR2]DISCGRAMTMAD(nolign-1)
  [M:CPR2]NONDEDTAXS(nolign-1) = [M:CPR2]NONDEDTAXD(nolign-1)
  [M:CPR2]FCSCSTPURS(nolign-1) = [M:CPR2]FCSCSTPURD(nolign-1)
  [M:CPR2]AMTNOTLINS(nolign-1) = [M:CPR2]AMTNOTLIND(nolign-1)
  [M:CPR2]TOTCOEFFAPPS(nolign-1) = [M:CPR2]TOTCOEFFAPPD(nolign-1)
Endif
#fin MAE 91193

  $SUIV
Next
Filter [PTH]

Return

############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"
WFIL3 = "1=1"

# Site de réception
If [M:CPR1]PRHFCY <> ""
   WFIL += "&[F:PTH]PRHFCY=[M:CPR1]PRHFCY"
Endif
# Autorisation site
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
   WFIL += "& find([F:PTH]PRHFCY,GUSRFCY(1..GNBAUZ))"
Endif
## Numéro de fournisseur
#If [M:CPR1]BPSNUM <> ""
#   WFIL += "&[F:PTH]BPSNUM =[M:CPR1]BPSNUM"
#Endif

# Numéro de fournisseur #US 71069/138  by RBA
If [M:CPR1]BPSNUMDEB <> ""
   WFIL3 += "&[F:PTH]BPSNUM >=[M:CPR1]BPSNUMDEB"
Endif
If [M:CPR1]BPSNUMFIN <> ""
   WFIL3 += "&[F:PTH]BPSNUM <=[M:CPR1]BPSNUMFIN"
Endif


# Issue 84130 - 2013-01-31 by MAE : Prise en compte des numéros de commande
If [M:CPR1]PTHNUMDEB <> ""
   WFIL += "&[F:PTH]PTHNUM>=[M:CPR1]PTHNUMDEB"
Endif
If [M:CPR1]PTHNUMFIN <> ""
   WFIL += "&[F:PTH]PTHNUM<=[M:CPR1]PTHNUMFIN"
Endif

# Issue 89502 - 2013-04-22 by MUARN : landed cost - code regroupement
If [M:CPR1]GPGCODDEB <> ""
   WFIL1 += "&[F:PTH]GPGCOD>=[M:CPR1]GPGCODDEB"
Endif
If [M:CPR1]GPGCODFIN <> ""
   WFIL1 += "&[F:PTH]GPGCOD<=[M:CPR1]GPGCODFIN"
Endif

#    Prise en compte des réceptions facturées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPR1]INVFLGO= 1
   WFIL1 += "&[F:PTH]INVFLG<3"
Endif

#    Prise en compte des réceptions non facturées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPR1]INVFLGN= 1
   WFIL1 += "&[F:PTH]INVFLG>2"
Endif

#    Prise en compte des réceptions comptabilisées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPR1]PSTFLGO= 1
   WFIL1 += "&[F:PTH]PSTFLG<>2"
Endif

#    Prise en compte des réceptions non comptabilisées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CPR1]PSTFLGN= 1
   WFIL1 += "&[F:PTH]PSTFLG=2"
Endif

#    Prise en compte des réceptions imprimées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPR]PRNFLGO= 1
   WFIL1 += "&[F:PTH]PRNFLG<>2"
Endif

#    Prise en compte des réceptions non imprimées
#    --> Si 1 : Pas de prise en compte
#    --> Si 2 : On prend tout
If [M:CCPR]PRNFLGN= 1
   WFIL1 += "&[F:PTH]PRNFLG=2"
Endif

If [M:CCPR]RCPDATDEB <> [0/0/0]
   WFIL += "&[F:PTH]RCPDAT>=[M:CCPR]RCPDATDEB"
Endif
If [M:CCPR]RCPDATFIN <> [0/0/0]
   WFIL += "&[F:PTH]RCPDAT<=[M:CCPR]RCPDATFIN"
Endif

#US 71069/12  PJT by RBA
If [M:CCPR]PJTHDEB <> ""
   WFIL3 += "&[F:PTH]PJTH>=[M:CCPR]PJTHDEB"
Endif
If [M:CCPR]PJTHFIN <> ""
   WFIL3 += "&[F:PTH]PJTH<=[M:CCPR]PJTHFIN"
Endif
#/US 71069/12  PJT by RBA

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCPR]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:PTH]PTHNUM>=DEBNUM"
       When 2 : # tri par date
           WFIL += "&([F:PTH]RCPDAT>DEBDAT | ([F:PTH]RCPDAT=DEBDAT & [F:PTH]PTHNUM>=DEBNUM))"
     Endcase
   When 2 : # suite
     Case [M:CCPR]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:PTH]PTHNUM>FINNUM"
       When 2 : # tri par date
           WFIL += "&([F:PTH]RCPDAT>FINDAT | ([F:PTH]RCPDAT=FINDAT & [F:PTH]PTHNUM>FINNUM))"
     Endcase
   When -2 : # retour
     Case [M:CCPR]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:PTH]PTHNUM<DEBNUM"
       When 2 : # tri par date
           WFIL += "&([F:PTH]RCPDAT<DEBDAT | ([F:PTH]RCPDAT=DEBDAT & [F:PTH]PTHNUM<DEBNUM))"
     Endcase
Endcase

Return

############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT

Return


#############################################################
##     Etiquettes masques CONSPOH1 & CONSPOH2 & CRITPOH    ##
#############################################################
Subprog AV_CPY(VALEUR)
#---------------------#
# Avant zone          #
#---------------------#
Variable Char     VALEUR
If GNBAUZ=1 : Diszo [M]CPY, PRHFCY : Endif
End

Subprog C_CPY(VALEUR)
#-------------------------------#
# Contrôle de la société        #
#-------------------------------#
Variable Char     VALEUR
If VALEUR <> ""
  [M]CUR = [F:CPY]ACCCUR : GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]PRHFCY = ""
  # GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
  # mkstat = 2
  # Raz [M]CUR
  [M]CUR=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
Endif
End

Subprog AM_CPY(VALEUR)
#-------------------------------#
# Après modif de la société     #
# Utilisé par 2 écrans          #
#-------------------------------#
Variable Char     VALEUR
Affzo CUR, ZCPY
Raz [M]PRHFCY, [M]ZPRHFCY, [M]PRHFCY
Affzo ZPRHFCY
If VALEUR<>""  GSOCIETE=VALEUR : Endif
# Issue 93530 - 2013-10-16 by MUARN : mise à jour masque critère
If clalev([M:CCPR])  : [M:CCPR]CPY = VALEUR : Raz [M:CCPR]PRHFCY : Endif
End

Subprog C_PRHFCY(VALEUR)
#------------------------------------------------#
# Contrôle du site par defaut pour achat         #
# on regarde en fonction des autorisations sites #
# uniquement dans le cas site par defaut = ""    #
# complément de l'action VERIFCY en avant saisie #
#------------------------------------------------#
Variable Char    VALEUR()
If VALEUR <> ""
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
    [M]CUR = GLOCALDEV
Elsif [M]CPY = ""
    # GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    # mkstat = 2
    [M]CUR=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
    [M]CUR=""
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif
End

#-------------------------------#
# Après modif du site           #
# Utilisé par 2 écrans          #
#-------------------------------#
Subprog AM_PRHFCY(VALEUR)
Variable Char     VALEUR
If VALEUR <> ""
  Affzo CUR, CPY, ZCPY
Endif
# Issue 93530 - 2013-10-16 by MUARN : mise à jour masque critère
If clalev([M:CCPR])  : [M:CCPR]PRHFCY=VALEUR : Endif                     # hcb 99146
End

#-------------------------------#
# Avant saisie de la ligne      #
#-------------------------------#
Subprog IB_NBLIG
Raz GBOUT1
If [M:CPR2]NBLIG<>0
   If clalev([M:PTH1])=0
     GBOUT1=mess(117,198,1)-[M:CPR2]PTHNUM (nolign -1) : # Réceptions
   Endif
Endif
End

#----------------------------------------#
# Après modification de la date de début #
#----------------------------------------#
Subprog AM_RCPDATDEB(VALEUR)
Variable Date     VALEUR
#----- Recalcul date fin en fonction de la périodicité et du nbre de périodes -----#
If dim([M]PERCOD)>0
  Local Date WDATE
  Call CALDATPER([M]PERCOD,[M]PERNBR,"+",[M]RCPDATDEB,VALEUR,WDATE) From TRTX3DAT
  If WDATE<>[0/0/0]
    [M]RCPDATFIN=WDATE : Affzo RCPDATFIN
  Endif
Elsif VALEUR>[M]RCPDATFIN
  [M]RCPDATFIN=VALEUR
Endif
End

#-----------------------------------#
# Après modification de la date fin #
#-----------------------------------#
Subprog AM_RCPDATFIN(VALEUR)
Variable Date    VALEUR
If dim([M]PERCOD)<1  End : Endif
#----- Recalcul date début en fonction de la périodicité et du nbre de périodes -----#
Local Date WDATE
Call CALDATPER([M]PERCOD,[M]PERNBR,"-",[M]RCPDATFIN,VALEUR,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]RCPDATDEB=WDATE : Affzo RCPDATDEB
Endif
#-----
End

#---------------------------------------------------#
#      Controle du numéro de réceptionfin           #
# ------------------------------------------------- #
Subprog C_PTHNUMFIN(VALEUR)
Variable Char     VALEUR
If VALEUR<>"" & VALEUR<[M]PTHNUMDEB
  GMESSAGE = mess(44,199,1)
  mkstat = 2
Endif
End

#--------------------------#
# Avant saisie périodicité #
#--------------------------#
Subprog AS_PERCOD(VALEUR)
Variable Integer VALEUR
GMENLOC(1)=0 : # Jour      Ok
GMENLOC(2)=0 : # Semaine   Ok
GMENLOC(3)=1 : # Quinzaine
GMENLOC(4)=0 : # Mois      Ok
GMENLOC(5)=0 : # Trimestre Ok
GMENLOC(6)=0 : # Semestre  Ok
GMENLOC(7)=0 : # Année     Ok
GMENLOC(8)=1 : # décade
End

#-------------------------#
# Après modif périodicité #
#-------------------------#
Subprog AM_PERCOD(VALEUR)
Variable Integer VALEUR
#----- Recalcul du nbre de périodes -----#
Call CALPERNBR([M]PERCOD,VALEUR,[M]PERNBR) From TRTX3DAT
Affzo PERNBR
[M]PERCOD=VALEUR
Call AM_PERNBR([M]PERNBR)
#-----
End

#------------------------------#
# Après modif nbre de périodes #
#------------------------------#
Subprog AM_PERNBR(VALEUR)
Variable Decimal VALEUR
#----- Recalcul date fin en fonction de la périodicité et du nbre de périodes -----#
Local Date WDATE
Call CALDATPER([M]PERCOD,VALEUR,"+",[0/0/0],[M]RCPDATDEB,WDATE) From TRTX3DAT
If WDATE<>[0/0/0]
  [M]RCPDATFIN=WDATE : Affzo RCPDATFIN
Endif
#-----
End


#########################################################################
# Pour exécution de la validation des consultations en gestion de patch #
#########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If [F:ADS]MODULE(5)<>2 End : Endif
Call VALGTC(APPLI,"CPR") From SUBGTC
End
