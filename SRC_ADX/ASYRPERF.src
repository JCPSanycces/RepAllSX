#<AdxTL>@(#)0.0.0.0 $Revision$
#----------------------------------------------------------------------------------------------------------#
# This operation does nothing. It is meant to be used as a ping
#
# use this url
# http://sosyrsuperv:8124/sdata/x3/erp/SUPERV/$service/perf
#
#----------------------------------------------------------------------------------------------------------#

Funprog HANDLER_GET(ACTX,ASWK,ARCV,PSYR,ASND)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND

Local Integer   ERROR : ERROR = [V]CST_AOK

Local Char COUNTER(20)
Local Integer LIMIT(20)

COUNTER      =  func ASYRMAIN.PARVAL(ARCV,"counter")
LIMIT      =  val(func ASYRMAIN.PARVAL(ARCV,"limit"))
Local Integer MAXI:MAXI=1000
If(LIMIT) MAXI=LIMIT : Endif

If  len(COUNTER)
 Case(toupper(COUNTER))
  When 'CPU'
   # http://sosyrsuperv:8124/sdata/x3/erp/SUPERV/$service/perf?counter=cpu&limit=1000
   Local Decimal I,J,K
   If(LIMIT) MAXI=LIMIT : Endif
   For I=1 To MAXI
    For J=0 To 1000
     K+=1
    Next J
   Next I
  When 'FILE-IO'
   # http://sosyrsuperv:8124/sdata/x3/erp/SUPERV/$service/perf?counter=file-io&limit=1000
   Local Char PATH(250)
   PATH = filpath("TMP","perf","dmp",0)
   Openo PATH,0 Using [PRF]
   Iomode adxifs "" Using [PRF]
   Iomode adxirs chr$(10) Using [PRF]
   Iomode adxium GUTF8 Using [PRF]
   If(LIMIT) MAXI=LIMIT : Endif
   For I=1 To MAXI
    For J=1 To 10
     Wrseq string$(100,chr$(ascii('0')+mod(I,10))) Using [PRF]
    Next J
   Next I
   Openo Using [PRF]
  When 'DBMS-IO'
    # http://sosyrsuperv:8124/sdata/x3/erp/SUPERV/$service/perf?counter=dbms-io&limit=10
    Local Integer I,J
    Raz J
    If(LIMIT) MAXI=LIMIT : Else MAXI=1: Endif
    For I=1 To MAXI
     Local File "AFCTPRF"   [AFP]
     For [AFP]
        J += 1
        Break (J=1000)
      Next
     LogicClose File [AFP]
    Next I
  When 'DBMS-LATENCY'
     If(LIMIT)
      MAXI=LIMIT
     Else
      MAXI=500
     Endif
     MAXI /= 2 :#to take into trbegin+commit
     Local File "AFCTPRF"   [AFP]
     For I=1 To MAXI
      Trbegin [AFP]
      Commit
     Next I
     LogicClose File [AFP]
 Endcase
Endif

ASND.URL      = PSYR.PREFIX+'/perf'
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+".perf"
End ERROR


#--------------------------------#----------------------------------------------------------------------------------------------------------#
# This operation does nothing. It is meant to be used as a ping
#
# use this url
# http://sosyrsuperv:8124/sdata/x3/erp/SUPERV/$service/perf
#
#----------------------------------------------------------------------------------------------------------#

#**
#* Funprog HANDLER_POST()
#*!
Funprog HANDLER_POST(ACTX,ASWK,ARCV,PSYR,ASND,JSON)
Variable Instance ACTX Using =[V]CST_C_NAME_CLASS_CONTEXT
Variable Instance ASWK(1..) Using C_ASYRWRK
Variable Instance ARCV Using C_ASYRRCV
Variable Instance PSYR Using C_ASYR
Variable Instance ASND Using C_ASYRSND
Variable Instance JSON Using C_ASYRJSO

Local Integer ERROR : ERROR=[V]CST_AOK

ASND.URL      = PSYR.PREFIX+'/perf'
ASND.CONTTYPE = PSYR.CNTPRE+"."+nomap+".perf"
End ERROR
