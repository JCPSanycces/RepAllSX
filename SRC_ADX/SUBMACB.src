#<AdxTL>@(#)1.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires pour la gestion des contrats de services      Module CRM
#
#   LOAD_ADD     : Chargement des lignes d'adresse du client d'implantation actuelle.
#   DISP_ADD     : Affiche l'adresse sélectionnée dans le tableau de gauche
#   RESET_SI     : Réaffecte le site d'installation de la machine parmi les adresse du client
#   LOAD_CON     : Chargement du tableau des contrats de service.
#   SAVE_CON     : Enregistrement du tableau des contrats de service.
#   LOAD_ITN     : Chargement du tableau des implantations.
#   SAVE_ITN     : Enregistrement du tableau des implantations.
#   ECLATE       : Effectue l'éclatement d'une fiche parc
#   LOAD_MWR     : Chargement du tableau des demandes de garanties
#   CPTCOVNUM    : Calcul une nouvelle clé pour une couverture de niveau fiche parc
#   SETWARTYP    : Affichage la garantie applicable d'une fiche parc en fonction de son implantation en prêt.
#   SETGRAY      : Grise ou dégrise des champs.
#   SETTOTFLTMAC : Calcul le total de fiches parc client résultant du filtre appliqué à un browser
#   CHECKFIEMAC  : Traitement des champs exception de la table MACHINES
##########################################################################################################
##########################################################################################################
Subprog RAZ_MAC7
  Raz [M:MAC7]
  [M:MAC7]IMAC7FLG = 1
End

##########################################################################################################
Subprog ALIMENTE_DEFAUT_MAC7
  # Alimente MAC7 avec les valeurs normales. Les appelant peuvent ensuite remplacer ces valeurs.
  # FGR 17/06/2009 : X3SUIVI55894 : Test "[M:MAC7]IMAC7FLG = 1" pour ne le faire qu'une fois
  #Call RAZ_MAC7
  If [M:MAC7]IMAC7FLG = 1 Then
    [M:MAC7]MACNUM   = [M:MAC0]MACNUM
    [M:MAC7]ITNTYP   = [M:MAC1]MACITNTYP
    [M:MAC7]BPCNUM   = [M:MAC1]BPCNUM
    [M:MAC7]ITNFCY   = [M:MAC3]FCYITN
    [M:MAC7]PLE      = [M:MAC3]PLE
    [M:MAC7]CCNNUM   = [M:MAC1]CCNNUM
    [M:MAC7]RSL      = [M:MAC1]MACRSL
    [M:MAC7]LND      = [M:MAC1]MACITNLND
    [M:MAC7]ITNDAT   = [M:MAC1]MACITNDAT
    [M:MAC7]ORI      = [M:MAC1]MACORI
    [M:MAC7]ORIVCR   = [M:MAC1]MACORIVCR
    [M:MAC7]ORIVCRL  = [M:MAC1]MACORIVCRL
    [M:MAC7]PURDAT   = [M:MAC1]MACPURDAT
    [M:MAC7]SALPRI   = [M:MAC1]MACSALPRI
    [M:MAC7]CUR      = [M:MAC1]CUR
    [M:MAC7]BPCDAT   = [M:MAC1]MACBPCDAT
    [M:MAC7]BPCPRI   = [M:MAC1]MACBPCPRI
    [M:MAC7]BPCCUR   = [M:MAC1]MACBPCCUR
    [M:MAC7]ENDITN   = date$
    [M:MAC7]SECPRI   = 0
    [M:MAC7]SECCUR   = ""
    [M:MAC7]IMAC7FLG = 2
  Endif
End

##########################################################################################################
Subprog CTRL_NOSER (SZMACNUM, SZMACPDTCOD, SZMACSERNUM, IGNORE_NULL, IERROR, SZMESSAGE)
Value Char SZMACNUM
Value Char SZMACPDTCOD
Value Char SZMACSERNUM
Value Integer IGNORE_NULL
Variable Integer IERROR
Variable Char SZMESSAGE

Local Integer IMESSREP
Local Integer IBGESNUMSERIE
Local Integer IHTRFOUND

  # FGR 01/04/2009 : X3SUIVI12201 : Déjà contrôle existance numéro de série
  Raz SZMESSAGE
  IERROR = 0
  If SZMACPDTCOD <> "" Then
    Read [ITM]ITM0=SZMACPDTCOD
    If !fstat Then
      If [F:ITM]STOMGTCOD <> 1 Then
        #Article géré en stock
        If [F:ITM]SERMGTCOD <> 1 Then
          IBGESNUMSERIE = 1
          If SZMACSERNUM = "" and IGNORE_NULL = 1 Then
            # Cette fiche parc concerne un article géré en numéro de série.
            # Confirmez-vous son enregistrement en l'absence de numéro de série ?
            IMESSREP = 0
            Call OUINON(mess(496,182,1), IMESSREP) From GESECRAN
            If IMESSREP <> 2 Then
              IERROR = 1
              End
            Endif
          Endif
        Endif
      Endif
      #Vérifie que le numero de serie est unique pour l'article
      If IBGESNUMSERIE = 1 and SZMACSERNUM <> "" Then
        IHTRFOUND = 0
        Filter [MAC] Where [F:MAC]MACPDTCOD = SZMACPDTCOD and [F:MAC]MACSERNUM = SZMACSERNUM and [F:MAC]MACNUM <> SZMACNUM
        For [MAC]Hint Key MAC5
          IHTRFOUND = 1
          Break
        Next
        Filter [MAC]
        If IHTRFOUND = 1 Then
          #On a trouve le même artice avec le même numero de serie
          #Un parc existe déjà avec même code article et même numéro de série.
          SZMESSAGE = mess(196,177,1) - [F:MAC]MACNUM
          IERROR = 1
          End
        Endif
      Endif
    Endif
  Endif
End

##########################################################################################################
# Chargement du tableau des prestations couvertes
###########################################################
Subprog LOAD_ADD
Local Integer H

  H = 0
  #Affichage des adresse Tiers
  If [M:MAC1]BPCNUM <> "" and [M:MAC1]CCNNUM = "" Then
    If !clalev([F:BPR]) Local File BPARTNER [BPR] : Endif
      Read[BPR]BPR0=[M:MAC1]MACCUTBPC
      If [M:MAC3]FCYITN = "" Then
        [M:MAC3]FCYITN = [F:BPR]BPAADD
      Else
        [M:MAC3]FCYITN = [F:MAC]FCYITN
      Endif
      Close Local File [BPR]
      If !clalev([F:BPA]) Local File BPADDRESS [BPA] : Endif
      Filter [BPA] Where BPATYP = 1 and BPANUM = [M:MAC1]MACCUTBPC
      For [BPA]
        [M:MAC3]MACADDCOD(H) = [F:BPA]BPAADD
        [M:MAC3]MACFCYITN(H) = 1
        If [F:BPA]BPAADD = [M:MAC3]FCYITN Then
          [M:MAC3]MACFCYITN(H) = 2
          [M:MAC3]MACFCYITNX = 2
          [M:MAC3]MACADD(0) = [F:BPA]BPAADDLIG(0)
          [M:MAC3]MACADD(1) = [F:BPA]BPAADDLIG(1)
          [M:MAC3]MACADD(2) = [F:BPA]BPAADDLIG(2)
          [M:MAC3]MACZIP = [F:BPA]POSCOD
          [M:MAC3]MACCTY = [F:BPA]CTY
          [M:MAC3]MACCRY = [F:BPA]CRY
          [M:MAC3]MACSAT = [F:BPA]SAT
          [M:MAC3]MACTEL = [F:BPA]TEL(0)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]TEL
          [M:MAC3]MACFAX = [F:BPA]TEL(1)  # FGR 21/08/2015 : X3SUIVI109994 plus [F:BPA]FAX
        Endif
        H += 1
      Next
      Filter [BPA]
      Close Local File [BPA]
      [M:MAC3]NBLIG = H
      Affzo [M:MAC3]1-99
  Endif
  If [M:MAC1]BPCNUM = "" and [M:MAC1]CCNNUM <> "" Then
    Gosub CCNADDDISP
  Endif
End

##########################################################################################################
#  Affichage d'une adresse sélectionnée
############################################################################
Subprog DISP_ADD
  If [M:MAC1]BPCNUM <> "" and [M:MAC1]CCNNUM = "" Then
    If !clalev([F:BPA]) Local File BPADDRESS [BPA] : Endif
    Read [BPA]BPA0=1;[M:MAC1]MACCUTBPC;[M:MAC3]MACADDCOD(nolign-1)
    If [M:MAC3]MACFCYITN(nolign-1) = 2 Then
      [M:MAC3]MACFCYITNX = 2
    Else
      [M:MAC3]MACFCYITNX = 1
    Endif
    [M:MAC3]MACADD(0) = [F:BPA]BPAADDLIG(0)
    [M:MAC3]MACADD(1) = [F:BPA]BPAADDLIG(1)
    [M:MAC3]MACADD(2) = [F:BPA]BPAADDLIG(2)
    [M:MAC3]MACZIP = [F:BPA]POSCOD
    [M:MAC3]MACCTY = [F:BPA]CTY
    [M:MAC3]MACCRY = [F:BPA]CRY
    [M:MAC3]MACSAT = [F:BPA]SAT
    [M:MAC3]MACTEL = [F:BPA]TEL(0)   # FGR 21/10/2015 : X3SUIVI111906 ajout indice
    [M:MAC3]MACFAX = [F:BPA]TEL(1)   # FGR 21/10/2015 : X3SUIVI111906 plus [F:BPA]FAX
    Close Local File [BPA]
    Affzo [M:MAC3]10
  Endif
  If [M:MAC1]BPCNUM = "" and [M:MAC1]CCNNUM <> "" Then
    Gosub CCNADDDISP
  Endif
End

##########################################################################################################
#Affichage de l'adresse Interlocuteur
################################################################
$CCNADDDISP
  If !clalev([F:AIN]) Local File CONTACTCRM [AIN] : Endif
  Read [AIN]AIN0=[M:MAC1]MACCUTBPC
  If fstat Then
    [M:MAC3]MACADDCOD(0) = ""
    [M:MAC3]MACFCYITN(0) = 1
    [M:MAC3]NBLIG = 0
    [M:MAC3]MACADD(0) = ""
    [M:MAC3]MACADD(1) = ""
    [M:MAC3]MACADD(2) = ""
    [M:MAC3]MACZIP = ""
    [M:MAC3]MACCTY = ""
    [M:MAC3]MACCRY = ""
    [M:MAC3]MACSAT = ""
    [M:MAC3]MACTEL = ""
    [M:MAC3]MACFAX = ""
    [M:MAC3]MACFCYITNX = 1
  Else
    [M:MAC3]MACADDCOD(0) = ""
    [M:MAC3]MACFCYITN(0) = 1
    [M:MAC3]NBLIG = 0
    [M:MAC3]MACADD(0) = [F:AIN]ADD(0)
    [M:MAC3]MACADD(1) = [F:AIN]ADD(1)
    [M:MAC3]MACADD(2) = [F:AIN]ADD(2)
    [M:MAC3]MACZIP = [F:AIN]ZIP
    [M:MAC3]MACCTY = [F:AIN]CTY
    [M:MAC3]MACCRY = [F:AIN]CRY
    [M:MAC3]MACSAT = [F:AIN]SAT
    [M:MAC3]MACTEL = [F:AIN]CNTETS
    [M:MAC3]MACFAX = [F:AIN]CNTFAX
    [M:MAC3]MACFCYITNX = 2
  Endif
  Affzo [M:MAC3]1-99
Return

##########################################################################################################
#  Modification du site d'installation
###########################################################################
Subprog RESET_SI
Local Integer Z

  [M:MAC3]FCYITN = [M:MAC3]MACADDCOD(nolign-1)
  For Z = 0 To [M:MAC3]NBLIG-1
    If [M:MAC3]MACADDCOD(Z) = "" Then
      Break
    Endif
    If [M:MAC3]MACADDCOD(Z) = [M:MAC3]FCYITN Then
      [M:MAC3]MACFCYITN(Z) = 2
    Else
      [M:MAC3]MACFCYITN(Z) = 1
    Endif
  Next
  Affzo [M:MAC3]5
End

##########################################################################################################
Subprog LOAD_COUV_IND

  # FGR 17/06/2009 : X3SUIVI55514
  [M:MAC2]STDCOV = 1
  [M:MAC2]CRSCOV = 1
  #---------------------
  If [M:MAC1]MACPDTCOD = "" Then
    End
  Endif
  Read [ITM]ITM0=[M:MAC1]MACPDTCOD
  If fstat Then
    End
  Endif
  #---------------------
  # Couvertures normales
  # Couverture de niveau référence article
  Filter [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]BPC = [M:MAC1]BPCNUM and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "ITM"
&                and [F:CCV]CMT = [M:MAC1]MACPDTCOD and [F:CCV]PAEKEY(0) = ""
  For [CCV]CCV1
    [M:MAC2]STDCOV = 2
    Break
  Next
  Filter [CCV]
  If [M:MAC2]STDCOV = 1 Then
    #Couverture de niveau famille commerciale
    Filter [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]BPC = [M:MAC1]BPCNUM and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "CIA"
&                  and [F:CCV]CMT = [F:ITM]TSICOD(GFAMCIA-1) and [F:CCV]PAEKEY(0) = ""
    For [CCV]CCV1
      [M:MAC2]STDCOV = 2
      Break
    Next
    Filter [CCV]
  Endif
  If [M:MAC2]STDCOV = 1 Then
    #Couverture de type tous le parc
    Filter [CON] Where [F:CON]CONBPC = [M:MAC1]BPCNUM and [F:CON]EVRMAC = 2
    For [CON]CON2
      [M:MAC2]STDCOV = 2
      Break
    Next
    Filter [CON]
  Endif
  #---------------------
  # Couvertures croisées
  # Couverture de niveau fiche parc
  Filter [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "MAC" and [F:CCV]CMT = [M:MAC0]MACNUM and [F:CCV]PAEKEY(0) <> ""
  For [CCV]
    [M:MAC2]CRSCOV = 2
    Break
  Next
  Filter [CCV]
  If [M:MAC2]CRSCOV = 1 Then
    #Couverture de niveau référence article
    Filter [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]BPC = [M:MAC1]BPCNUM and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "ITM" and [F:CCV]CMT = [M:MAC1]MACPDTCOD
&                  and [F:CCV]PAEKEY(0) <> ""
    For [CCV]CCV1
      [M:MAC2]CRSCOV = 2
      Break
    Next
    Filter [CCV]
  Endif
  If [M:MAC2]CRSCOV = 1 Then
    #Couverture de niveau famille commerciale
    Filter [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]BPC = [M:MAC1]BPCNUM and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "CIA" and [F:CCV]CMT = [F:ITM]TSICOD(GFAMCIA-1)
&                  and [F:CCV]PAEKEY(0) <> ""
    For [CCV]CCV1
      [M:MAC2]CRSCOV = 2
      Break
    Next
    Filter [CCV]
  Endif
  #---------------------
End

##########################################################################################################
#  Chargement du tableau des contrats de service.
###########################################################################
Subprog LOAD_CON
Local Integer I

  I = 0
  Filter [CCV] Where [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "MAC" and [F:CCV]CMT = [M:MAC0]MACNUM and [F:CCV]PAEKEY(0) = ""
  For [CCV]CCV0 Hint Key CCV2
    If I >= dim([M:MAC2]MACCONNUM)-1 Then
      Break
    Endif
    If [F:CCV]RECNUM <> "" Then
      [M:MAC2]MACCONNUM(I) = [F:CCV]CONNUM
      [M:MAC2]MACORD(I) = [F:CCV]RECNUM
      Read [CON]CON0=[M:MAC2]MACCONNUM(I)
      If !fstat Then
        [M:MAC2]MACCONTYP(I) = [F:CON]CONCAT
        [M:MAC2]MACCONNAM(I) = [F:CON]CONNAM
        [M:MAC2]CONENDDAT(I) = [F:CON]CONENDDAT
        Read [BPR]BPR0=[F:CON]CONBPC
        If fstat Then
          [M:MAC2]CONBPC(I) = [F:CON]CONBPC
        Else
          [M:MAC2]CONBPC(I) = [F:BPR]BPRNAM
        Endif
      Endif
      I += 1
    Endif
  Next
  [M:MAC2]NBCON = I
  Filter [CCV]
End

##########################################################################################################
#  Enregistrement du tableau des contrats de service.                                  #
########################################################################################
Subprog SAVE_CON
Local Integer IRECNUM
Local Char SZRECNUM
Local Integer ZI
Local Integer IMACNUM
Local Integer ICOVMAC
Local Char SZCONBPC
Local Integer ICRSCOVSAM

  #CHECK FILE_DECLARE CONTCOV [CCV2]
  IMACNUM = 0
  ICOVMAC = 0
  SZCONBPC = ""
  ICRSCOVSAM = 0
  #Enregistrement des articles couverts
  For ZI = 0 To [M:MAC2]NBCON-1
    IMACNUM = 0
    If [M:MAC2]MACCONNUM(ZI) <> "" Then
      Read [CON]CON0=[M:MAC2]MACCONNUM(ZI)
      If fstat Then
        SZCONBPC = ""
        ICRSCOVSAM = 0
      Else
        ICRSCOVSAM = [F:CON]CRSCOVSAM
        SZCONBPC = [F:CON]CONBPC
      Endif
      #Couverture simple
      ICOVMAC = 0
      IMACNUM = 0
      Filter [CCV] Where [F:CCV]CONNUM = [M:MAC2]MACCONNUM(ZI) and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "MAC"
&                    and [F:CCV]CMT = [M:MAC0]MACNUM and [F:CCV]PAEKEY(0) = ""
      For [CCV]CCV0
        ICOVMAC = 1
      Next
      Filter [CCV]
      If !ICOVMAC Then
        # Cet article n'est pas couvert. Il faut le couvrir.
        Call DEBTRANS From GLOCK
        Trbegin [CCV]
        Raz [F:CCV]
        [F:CCV]CONNUM = [M:MAC2]MACCONNUM(ZI)
        [F:CCV]TPL = 1
        [F:CCV]BPC = SZCONBPC
        [F:CCV]RECTYP = "MAC"
        [F:CCV]SBBRECTYP = "MAC"
        [F:CCV]RECNUM = [M:MAC2]MACORD(ZI)
        [F:CCV]CMT = [M:MAC0]MACNUM
        [F:CCV]PAEKEY(0) = ""
        [F:CCV]PAEKEY(1) = ""
        [F:CCV]PAEKEY(2) = ""
        Write [CCV]
        If fstat Then
          #Erreur lors de l'ajout de convertures article concernant la fiche parc.
          GMESSAGE = mess(296,182,1)
          GERR = 1
          Rollback
          Break
        Else
          Commit
        Endif
      Endif
      #Couverture croisée
      If ICRSCOVSAM = 2 Then
        Filter [CCV2] Where [F:CCV2]CONNUM = [M:MAC2]MACCONNUM(ZI) and [F:CCV2]TPL <> 2 and [F:CCV2]RECTYP = "PBL"
        For [CCV2]
          ICOVMAC = 0
          IMACNUM = 0
          Filter [CCV] Where [F:CCV]CONNUM = [M:MAC2]MACCONNUM(ZI) and [F:CCV]TPL <> 2 and [F:CCV]RECTYP = "MAC" and [F:CCV]SBBRECTYP = "MAC"
&                        and [F:CCV]CMT = [M:MAC0]MACNUM and [F:CCV]PAEKEY(0) = [F:CCV2]RECNUM
          For [CCV]CCV0
            ICOVMAC = 1
          Next
          Filter [CCV]
          If !ICOVMAC Then
            # Cet article n'est pas couvert. Il faut le couvrir.
            IRECNUM = 0
            SZRECNUM = ""
            Call CPTCOVNUM([M:MAC2]MACCONNUM(ZI), 1, [F:CCV2]RECNUM, SZRECNUM, IRECNUM) From SUBMACB
            Call DEBTRANS From GLOCK
            Trbegin [CCV]
            Raz [F:CCV]
            [F:CCV]CONNUM = [M:MAC2]MACCONNUM(ZI)
            [F:CCV]TPL = 1
            [F:CCV]BPC = SZCONBPC
            [F:CCV]RECTYP = "MAC"
            [F:CCV]SBBRECTYP = "MAC"
            [F:CCV]RECNUM = SZRECNUM
            [F:CCV]CMT = [M:MAC0]MACNUM
            [F:CCV]PAEKEY(0) = [F:CCV2]RECNUM
            [F:CCV]PAEKEY(1) = ""
            [F:CCV]PAEKEY(2) = ""
            Write [CCV]
            If fstat Then
              #Erreur lors de l'ajout de couvertures croisées concernant la fiche parc.
              GMESSAGE = mess(444,182,1)
              GERR = 1
              Rollback
              Break
            Else
              Commit
            Endif
          Endif
        Next
        Filter [CCV2]
      Endif
    Endif
  Next
End

##########################################################################################################
#  Chargement du tableau des implantations
###########################################################################
Subprog LOAD_ITN
Local Integer I

  I = 0
  Filter [MAI] Where [F:MAI]MACNUM = [M:MAC0]MACNUM
  For [MAI]MAI1
    If I >= dim([M:MAC4]ITNTYP)-1 Then
      Break
    Endif
    If [F:MAI]ITNTYP = 0 Then
      [M:MAC4]ITNTYP(I) = 1
    Else
      [M:MAC4]ITNTYP(I) = [F:MAI]ITNTYP
    Endif
    [M:MAC4]LND(I) = [F:MAI]LND
    [M:MAC4]ITNDAT(I) = [F:MAI]ITNDAT
    [M:MAC4]ENDITN(I) = [F:MAI]ENDITN
    [M:MAC4]SECPRI(I) = [F:MAI]SECPRI
    [M:MAC4]SECCUR(I) = [F:MAI]SECCUR
    [M:MAC4]CLSNUM(I) = [F:MAI]CLSNUM
    [M:MAC4]ITNFCY(I) = ""
    If [F:MAI]ITNTYP = 0 or [F:MAI]ITNTYP = 1 Then
      #Implantation utilisateur final
      If [F:MAI]BPCTYP = "BPC" Then
        If [F:MAI]BPC = "" Then
          [M:MAC4]BPCCLA(I) = ""
        Else
          Read [BPR]BPR0=[F:MAI]BPC
          If fstat Then
            [M:MAC4]BPCCLA(I) = [F:MAI]BPC
          Else
            [M:MAC4]BPCCLA(I) = [F:BPR]BPRNAM
          Endif
          If [F:MAI]ITNFCY <> "" Then
            Read [BPA]BPA0=1;[F:MAI]BPC;[F:MAI]ITNFCY
            If !fstat Then
              [M:MAC4]ITNFCY(I) = [F:BPA]BPAADD
            Endif
          Endif
        Endif
      Elsif [F:MAI]BPCTYP = "CCN" Then
        Read [AIN]AIN0=[F:MAI]BPC
        If fstat Then
          [M:MAC4]BPCCLA(I) = [F:MAI]BPC
        Else
          Call BUILDFULNAM("AIN", [M:MAC4]BPCCLA(I)) From CRMUTIL140
        Endif
      Endif
    Elsif [F:MAI]ITNTYP = 2 or [F:MAI]ITNTYP = 3 Then
      #Implantation Revendeur ou Grossiste
      If [F:MAI]RSL = "" Then
        [M:MAC4]BPCCLA(I) = ""
      Else
        Read [BPR]BPR0=[F:MAI]RSL
        If fstat Then
          [M:MAC4]BPCCLA(I) = ""
        Else
          [M:MAC4]BPCCLA(I) = [F:BPR]BPRNAM
        Endif
        If [F:MAI]ITNFCY <> "" Then
          [M:MAC4]ITNFCY(I) = [F:MAI]ITNFCY
        Endif
      Endif
    Elsif [F:MAI]ITNTYP = 4 or [F:MAI]ITNTYP = 5 Then
      #Implantation En stock ou Mis au rebut
      [M:MAC4]BPCCLA(I) = ""
    Endif
    #Origine de l'implantation
    If [F:MAI]ORI = 0 Then
      [M:MAC4]ORI(I) = 1
      [M:MAC4]ORIVCR(I) = ""
      [M:MAC4]ORIVCRL(I) = 0
    Else
      [M:MAC4]ORI(I) = [F:MAI]ORI
      [M:MAC4]ORIVCR(I) = [F:MAI]ORIVCR
      [M:MAC4]ORIVCRL(I) = [F:MAI]ORIVCRL
    Endif
    #Définition du type de pièce
    Case [F:MAI]ORI
      When 1
        [M:MAC4]VCRTYP(I) = ""
      When 2
        [M:MAC4]VCRTYP(I) = ""
      When 3
        [M:MAC4]VCRTYP(I) = "SDH"
      When 4
        [M:MAC4]VCRTYP(I) = "SIH"
      When 5
        [M:MAC4]VCRTYP(I) = "RQW"
      When 6
        [M:MAC4]VCRTYP(I) = ""
      When 7
        [M:MAC4]VCRTYP(I) = "SRH"
      When 8
        [M:MAC4]VCRTYP(I) = "SRL"
      When Default
        [M:MAC4]VCRTYP(I) = ""
    Endcase
    I += 1
  Next
  [M:MAC4]NBLIG = I
  Filter [MAI]
End

##########################################################################################################
#  Enregistrement du tableau des implantations                                         #
########################################################################################
Subprog SAVE_ITN
Local Integer ZI

  If !clalev([F:MAI]) : Local File MACITN [MAI] : Endif
  Call DEBTRANS From GLOCK
  Trbegin [MAI]
  #Enregistrement des informations de reprise
  For ZI = 0 To [M:MAC4]NBLIG-1
    Read [MAI]MAI1=[M:MAC0]MACNUM;[M:MAC4]CLSNUM(ZI)
    If !fstat Then
      [F:MAI]ENDITN = [M:MAC4]ENDITN(ZI)
      [F:MAI]SECPRI = [M:MAC4]SECPRI(ZI)
      [F:MAI]SECCUR = [M:MAC4]SECCUR(ZI)
      Gosub PE_MAIAUTO1 From TRTCRMPE # FGR 25/09/2009 : X3SUIVI57808
      Rewrite [MAI]
      If fstat Then
        #Erreur lors de la création de l'historique des implantations. Transaction abandonnée.
        GMESSAGE = mess(305,196,1)
        GERR = 1
        Rollback
        Break
      Endif
    Endif
  Next
  If !GERR Then
    Commit
  Endif
End

##########################################################################################################
# Effectue l'éclatement d'une fiche parc
####################################################################
Subprog ECLATE_MAC(SZMACNUM, SZMESSAGE, INOERROR)
Value Char SZMACNUM
Variable Char SZMESSAGE
Variable Integer INOERROR

#Intégration du parc client
Local Integer ITER
Local Integer IMACQTY
Local Char SZMACTODUP
Local Integer IBDEBTRANSFLG
Local Decimal ECA_MACSALPRI
Local Decimal ECA_MACBPCPRI
Local Decimal ORI_MACSALPRI
Local Decimal ORI_MACBPCPRI

  SZMESSAGE = ""
  INOERROR = 1
  If adxlog = 1 Then
    IBDEBTRANSFLG = 1
  Else
    IBDEBTRANSFLG = 0
  Endif
  Call TEMPON(mess(95,182,1)) From GESECRAN
  #
  ECA_MACSALPRI = 0
  ECA_MACBPCPRI = 0
  #Tout d'abord, on met à jour la fiche parc courante avec une quantité de 1
  Read [MAC]MAC0=SZMACNUM
  If !fstat Then
    If [F:MAC]MACQTY > 1 Then
      IMACQTY = [F:MAC]MACQTY
      ORI_MACSALPRI = [F:MAC]MACSALPRI
      ORI_MACBPCPRI = [F:MAC]MACBPCPRI
      If IBDEBTRANSFLG = 0 Then
        Call DEBTRANS From GLOCK
        Trbegin [MAC]
      Endif
      If [F:MAC]MACSALPRI > 0 Then
        [F:MAC]MACSALPRI = [F:MAC]MACSALPRI / [F:MAC]MACQTY
        Call ARRDEV ([F:MAC]MACSALPRI, [F:MAC]CUR) From TRTDIV
        ECA_MACSALPRI = ORI_MACSALPRI - ([F:MAC]MACSALPRI * [F:MAC]MACQTY)
      Endif
      If [F:MAC]MACBPCPRI > 0 Then
        [F:MAC]MACBPCPRI = [F:MAC]MACBPCPRI / [F:MAC]MACQTY
        Call ARRDEV ([F:MAC]MACBPCPRI, [F:MAC]MACBPCCUR) From TRTDIV
        ECA_MACBPCPRI = ORI_MACBPCPRI - ([F:MAC]MACBPCPRI * [F:MAC]MACQTY)
      Endif
      [F:MAC]MACQTY = 1
      [F:MAC]MACSERNUM = ""
      Rewrite [MAC]
      If fstat Then
        #La définition de la nouvelle quantité de la fiche parc courante a échoué.
        SZMESSAGE = mess(96,182,1) - [F:MAC]MACNUM
        INOERROR = 0
      Else
        #Eclatement du parc
        For ITER = 1 To IMACQTY-1
          #Appel du composant de duplication
          Call DUPLIPARC(SZMACNUM, SZMACTODUP, SZMESSAGE, INOERROR) From SUBMACC
          If INOERROR = 0 Then
            Break
          Endif
          #Modification de l'origine des fiches parc résultant de l'éclatement.
          Read [MAC]MAC0=SZMACTODUP
          If !fstat Then
            [F:MAC]MACORI = 2
            [F:MAC]MACORIVCR = SZMACNUM
            [F:MAC]MACORIVCRL = 0
            Rewrite [MAC]
            If fstat Then
              #La mise à jour de la pièce origine sur les fiches parc résultant de l'éclatement a échoué.
              SZMESSAGE = mess(407,182,1) - SZMACTODUP
              INOERROR = 0
              Break
            Endif
          Endif
        Next
        If INOERROR = 1 Then
          # FGR 11/03/2009 : X3SUIVI26161
          If ECA_MACSALPRI <> 0 or ECA_MACBPCPRI <> 0 Then
            # Si on détecte un écart sur l'un ou l'autre des montants, on l'affecte au parc d'origine
            Read [MAC]MAC0=SZMACNUM
            If fstat Then
              SZMESSAGE = mess(96,182,1) - SZMACNUM
              INOERROR = 0
            Else
              [F:MAC]MACSALPRI = [F:MAC]MACSALPRI + ECA_MACSALPRI
              [F:MAC]MACBPCPRI = [F:MAC]MACBPCPRI + ECA_MACBPCPRI
              Rewrite [MAC]
              If fstat Then
                #La définition de la nouvelle quantité de la fiche parc courante a échoué.
                SZMESSAGE = mess(96,182,1) - [F:MAC]MACNUM
                INOERROR = 0
              Endif
            Endif
          Endif
        Endif
      Endif
      If INOERROR = 1 Then
        If IBDEBTRANSFLG = 0 Then
          Commit
        Endif
      Else
        If IBDEBTRANSFLG = 0 Then
          Rollback
        Endif
      Endif
    Endif
  Endif
  Call TEMPOFF From GESECRAN
End

##########################################################################################################
#  Chargement du tableau des demandes de garantie
###########################################################################
Subprog LOAD_MWR
Local Integer I

  I = 0
  Filter [MWR] Where [F:MWR]MACNUM = [M:MAC0]MACNUM Order By [F:MWR]CREDAT Asc
  For [MWR]
    If I >= dim([M:MAC2]WRENUM)-1 Then
      Break
    Endif
    [M:MAC2]WRENUM(I) = [F:MWR]WRENUM
    [M:MAC2]CREDAT(I) = [F:MWR]CREDAT
    If [F:MWR]CONNUM = "" Then
      [M:MAC2]WARNUM(I) = ""
      [M:MAC2]WARAPL(I) = ""
    Else
      Read [CON]CON0=[F:MWR]CONNUM
      If fstat Then
        [M:MAC2]WARNUM(I) = ""
        [M:MAC2]WARAPL(I) = ""
      Else
        [M:MAC2]WARNUM(I) = [F:MWR]CONNUM
        [M:MAC2]WARAPL(I) = [F:CON]CONNAM
      Endif
    Endif
    I += 1
  Next
  [M:MAC2]NBWRE = I
  Filter [MWR]
End

##########################################################################################################
# Calcul une nouvelle clé pour une couverture de niveau fiche parc
#########################################################
Subprog CPTCOVNUM(SZCONNUM, ICRS, SZPBL, SZMACORD, IMACORD)
Value Char SZCONNUM
Value Integer ICRS
Value Char SZPBL
Variable Char SZMACORD
Variable Integer IMACORD

Local Integer INBREC
Local Integer ICOUNT        # Issue X3-90641 - 2018-06-01 by FGR
Local Integer ILRECNUM
Local Char SZRECNUM(GLONVCR)
Local Char REQSQL(250)(5)

  # FGR 28/10/2015 : X3SUIVI112034 : version SQL
  INBREC = 0
  Raz REQSQL
  If ICRS Then
    #Filter [CCV8] Where [F:CCV8]CONNUM = SZCONNUM and [F:CCV8]TPL <> 2 and [F:CCV8]RECTYP = "MAC" and [F:CCV8]PAEKEY(0) = SZPBL
    # Issue X3-90641 - 2018-06-01 by FGR : BEGIN
    REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND PAEKEY_0='" + SZPBL + "'"
    # Issue X3-90641 - 2018-06-01 by FGR : END
  Else
    #Filter [CCV8] Where [F:CCV8]CONNUM = SZCONNUM and [F:CCV8]TPL <> 2 and [F:CCV8]RECTYP = "MAC" and [F:CCV8]PAEKEY(0) = ""
    # Issue X3-90641 - 2018-06-01 by FGR : BEGIN
    #REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND PAEKEY_0=''"
    REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND PAEKEY_0=' '"
    # Issue X3-90641 - 2018-06-01 by FGR : END
  Endif
  For (Integer IRECNUM) From num$(GTYPDBA*2+1) Sql REQSQL(0..0) As [BZZ]
    #ICOUNT = ICOUNT         # Issue X3-90641 - 2018-06-01 by FGR
    [L]ILRECNUM = [F:BZZ]IRECNUM  # Issue X3-90641 - 2018-06-01 by FGR
    Break
  Next
  #IRECNUM = INBREC          # Issue X3-90641 - 2018-06-01 by FGR
  #SZRECNUM = num$(IRECNUM)  # Issue X3-90641 - 2018-06-01 by FGR
  SZRECNUM = num$([L]ILRECNUM)  # Issue X3-90641 - 2018-06-01 by FGR
  [L]ICOUNT = 0
  While 1
    If ICRS Then
      #Filter [CCV8] Where [F:CCV8]CONNUM = SZCONNUM and [F:CCV8]TPL <> 2 and [F:CCV8]RECTYP = "MAC" and [F:CCV8]PAEKEY(0) = SZPBL and [F:CCV8]RECNUM = SZRECNUM
      # Issue X3-90641 - 2018-06-01 by FGR : BEGIN
      REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND PAEKEY_0='" + SZPBL + "' AND RECNUM_0='" + SZRECNUM + "'"
      # Issue X3-90641 - 2018-06-01 by FGR : END
    Else
      #Filter [CCV8] Where [F:CCV8]CONNUM = SZCONNUM and [F:CCV8]TPL <> 2 and [F:CCV8]RECTYP = "MAC" and [F:CCV8]PAEKEY(0) = "" and [F:CCV8]RECNUM = SZRECNUM
      # Issue X3-90641 - 2018-06-01 by FGR : BEGIN
      #REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND PAEKEY_0='' AND RECNUM_0='" + SZRECNUM + "'"
      REQSQL(0)="SELECT COUNT(*) FROM CONTCOV WHERE CONNUM_0='" + SZCONNUM + "' AND TPL_0<>2 AND RECTYP_0='MAC' AND PAEKEY_0=' ' AND RECNUM_0='" + SZRECNUM + "'"
      # Issue X3-90641 - 2018-06-01 by FGR : END
    Endif
    For (Integer ICOUNT) From num$(GTYPDBA*2+1) Sql REQSQL(0..0) As [BZZ]
      #ICOUNT = ICOUNT       # Issue X3-90641 - 2018-06-01 by FGR
      [L]ICOUNT = [F:BZZ]ICOUNT # Issue X3-90641 - 2018-06-01 by FGR
      Break
    Next
    If [L]ICOUNT > 0 Then
      #IRECNUM += 1                    # Issue X3-90641 - 2018-06-01 by FGR
      #SZRECNUM = num$(IRECNUM)        # Issue X3-90641 - 2018-06-01 by FGR
      [L]ILRECNUM += 1                 # Issue X3-90641 - 2018-06-01 by FGR
      SZRECNUM = num$(ILRECNUM)        # Issue X3-90641 - 2018-06-01 by FGR
    Else
      #IMACORD = IRECNUM               # Issue X3-90641 - 2018-06-01 by FGR
      IMACORD = [L]ILRECNUM            # Issue X3-90641 - 2018-06-01 by FGR
      SZMACORD = SZRECNUM
      Break
    Endif
  Wend
End

