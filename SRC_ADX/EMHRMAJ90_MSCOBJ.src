#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# EMHRMAJ90_MSCOBJ UTI process                                  PAY Module
#                  Migration To U12 - Vnext version
#
# ==>  Update MISCELLANEOUS tables to OBJECTS
#
##########################################################################

Local Char WDOSSIER(30) : WDOSSIER = nomap
Call SAIDOSHIS(WDOSSIER,"") From SAIDOSHIS

If WDOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]WDOSSIER)=0 : End : Endif

  # Check Payroll Module
  If [F:ADS]MODULE(14)<>2 : End : Endif

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Update MISCELLANEOUS tables to OBJECTS") From LECFIC

  Call MAJ_EMHRMAJ90_MSCOBJ(WDOSSIER)

  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Endif

Close Local File
End

Subprog MAJ_EMHRMAJ90_MSCOBJ(LDOSSIER)
Value Char LDOSSIER
Local Char DOSLEGMIG(5)
Local Char NUMTABARRAY(GLONATB)(1..)
Local Char NEWTABLEARRAY(GLONATB)(1..)
Local Char OLDTABLEARRAY(GLONATB)(1..)
Local Char OBJARRAY(GLONATB)(1..)
Local Integer STAT : STAT = 1
Local Integer NBRREC, I, NBRTAB
Local Char MSG(100)

  Onerrgo CYCLECHECKERROR

#begin migration tasks

  #raise dialog box to enter the folder name to migrate from
#  Call SAIDOS(LDOSSIER,"") From SAIDOS

  Call ECR_TRACE("EMHRMAJ90_MSCOBJ: Update MISCELLANEOUS tables to OBJECTS",0) From GESECRAN
  Call ECR_TRACE("EMHRMAJ90_MSCOBJ: Start of process on : "+LDOSSIER,0) From GESECRAN

  #gets the folder legislation
  DOSLEGMIG = func EMHRMAJ90_LEG.GET_LEG(LDOSSIER)

  #Adding the Miscellaneous Tables to an array for migration
  Gosub ADD_TABLE_ARRAY_LEG

  #Loop through the tables and calls the migration subprog
  Gosub PROCESS_DATA
  Gosub UPDATE_TABLE_REFERENCES

#  Gosub CLEAN_TEMP_TABLES

  Call ECR_TRACE("EMHRMAJ90_MSCOBJ : End of process on : "+LDOSSIER,0) From GESECRAN

End #end migration process ###########################################################################################

$CYCLECHECKERROR
  Call ECR_TRACE("Error in EMHRMAJ90_MSCOBJ: " + num$(errn)-errmes$(errn)-errm, -1) From GESECRAN
  UPD_OK = 1
Resume

$ADD_TABLE_ARRAY_LEG
  #Add the tables here needed to migrate for legislation
  #Index start at 1
  I  = 0
  I += 1 :  NUMTABARRAY(I) = "354" : NEWTABLEARRAY(I) = "WHRNATCON" : OLDTABLEARRAY(I) = "HRNATCON" : OBJARRAY = "HRNCT"
  I += 1 :  NUMTABARRAY(I) = "358" : NEWTABLEARRAY(I) = "WHRCLLCVT" : OLDTABLEARRAY(I) = "HRCLLCVT" : OBJARRAY = "HRCLV"
  I += 1 :  NUMTABARRAY(I) = "359" : NEWTABLEARRAY(I) = "WHRXITGRD" : OLDTABLEARRAY(I) = "HRXITGRD" : OBJARRAY = "HRXGD"
  I += 1 :  NUMTABARRAY(I) = "395" : NEWTABLEARRAY(I) = "WHRMEDTYP" : OLDTABLEARRAY(I) = "HRMEDTYP" : OBJARRAY = "HRMDT"
  I += 1 :  NUMTABARRAY(I) = "386" : NEWTABLEARRAY(I) = "WHRCTRGRD" : OLDTABLEARRAY(I) = "HRCTRGRD" : OBJARRAY = "HRCGD"
  #... add

  #store the number of rows in the tablearray array
  [L]NBRTAB = I

Return

$UPDATE_TABLE_REFERENCES
  If clalev([F:HRTBZ]) = 0 :Local File =LDOSSIER+".ATABZON" [HRTBZ] : Endif

  For COUNTER = 1 To NBRTAB
    Call ECR_TRACE("EMHRMAJ90_LMRNG: Updating ATABZON on Misc Table number : " + NUMTABARRAY(COUNTER),0) From GESECRAN

    Filter [F:HRTBZ] Where [F:HRTBZ]CODTYP = "ADI" & left$([F:HRTBZ]EXPLIEN, 3) = NUMTABARRAY(COUNTER)
    For [F:HRTBZ]
      [F:HRTBZ]CODTYP = OBJARRAY(COUNTER)
      [F:HRTBZ]EXPLIEN = [F:HRTBZ]CODZONE+";[V]GSUPCLE"
      Rewrite [F:HRTBZ]
      Call CREATE_OBJ_PARAMETERS(LDOSSIER, NUMTABARRAY(COUNTER), OLDTABLEARRAY(COUNTER), OBJARRAY(COUNTER), [F:HRTBZ]CODZONE)
    Next

  Next
  Close File [F:HRTBZ]
Return


Subprog CREATE_OBJ_PARAMETERS(LDOSSIER, MISC_TABLE, TABLE, OBJ, FIELD_NAME)
Value Char LDOSSIER
Value Char MISC_TABLE
Value Char TABLE
Value Char OBJ
Value Char FIELD_NAME
  If clalev([F:HRAMSK]) = 0 :Local File =LDOSSIER+".AMSKPAR" [HRAMSK] : Endif

  Call ECR_TRACE("EMHRMAJ90_LMRNG: Creating 2 records on AMSKPAR for object : " + OBJ,0) From GESECRAN
  Raz [F:HRAMSK]
  [F:HRAMSK]CODAFF = TABLE
  [F:HRAMSK]CODZON = FIELD_NAME
  [F:HRAMSK]TYPAFF = 2
  [F:HRAMSK]CODPAR = "LEG"
  [F:HRAMSK]VALPAR = "GCURLEG"
  Write [F:HRAMSK]
  Raz [F:HRAMSK]
  [F:HRAMSK]CODAFF = TABLE
  [F:HRAMSK]CODZON = FIELD_NAME
  [F:HRAMSK]TYPAFF = 2
  [F:HRAMSK]CODPAR = "SOCIETE"
  [F:HRAMSK]VALPAR = "GSOCIETE"
  Write [F:HRAMSK]
  Close File [F:HRAMSK]
End

$PROCESS_DATA
  For I = 1 To [L]NBRTAB
    If clalev([F:HRSRC]) = 0 : Local File =LDOSSIER+"."+[L]NEWTABLEARRAY(I) [HRSRC] : Endif
    If clalev([F:HRDES]) = 0 : Local File =LDOSSIER+"."+[L]OLDTABLEARRAY(I) [HRDES] : Endif

    Filter [F:HRSRC]
    For [F:HRSRC]
      [F:HRDES] = [F:HRSRC]
      Write [F:HRDES]
    Next
    Filter [F:HRSRC]

    Close File [F:HRSRC], [F:HRDES]
  Next
Return

$CLEAN_TEMP_TABLES
  If clalev([HRATB])=0  : Local File ATABLE  [HRATB]  : Endif
  If clalev([HRTAB])=0  : Local File ATABZON [HRTAB]  : Endif
  If clalev([HRIND])=0  : Local File ATABIND [HRIND]  : Endif

  For I = 1 To [L]NBRTAB
    Delete [HRIND] Where [HRIND]CODFIC = [L]NEWTABLEARRAY(I)
    Delete [HRTAB] Where [HRTAB]CODFIC = [L]NEWTABLEARRAY(I)
    Delete [HRATB] Where [HRATB]CODFIC = [L]NEWTABLEARRAY(I)
  Next

  Close File [HRATB], [HRTAB], [HRIND]
Return


########################################################################
# To  execute during integration of list of patches                    #
# call in integration if UTICPT90 is in patch as EXE
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3 : End : Endif
  If clalev([F:ADS])=0  : Local File ADOSSIER [ADS] : Endif
  If func DOSSUB.FILL_ADS([L]APPLI)=0 : End : Endif
  If [F:ADS]MODULE(14)<>2 : End : Endif
  Call MAJ_EMHRMAJ90_MSCOBJ(APPLI)

End

#######################################################################
# To execute during DOSMAJ90 process (validation of folder)
# call by DOSMAJ90
########################################################################
Subprog UTI_MOUL(APPLI)
Value Char    APPLI

  If APPLI=GDOSX3: End : Endif
  If [F:ADS]MODULE(14)<>2 : End : Endif
  Call MAJ_EMHRMAJ90_MSCOBJ(APPLI)

End

