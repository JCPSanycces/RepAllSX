#<AdxTL>@(#)3.0.0.0 $Revision$
#----------------------------------------------------------------------------------------#
# SData
# SData - Version 002_S
#  - P001: maj code activité ASD à oui sur le dossier mere
#  - P999: exemple maj parametre ASDTRTAPP
#----------------------------------------------------------------------------------------#

# Routine à lancer manuellement sur les environnements d'indus pour mettre à jour tous les dossiers
Call OUVRE_TRACE("SData patch") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER

gosub MAJACV_ASD    # P001

End

#-------------------#
# P001: maj code activité ASD à oui sur le dossier mere
#-------------------#
$MAJACV_ASD
If [L]DOSSIER <> GDOSX3 
    Call ECR_TRACE("Not on reference folder"-[F:ADS2]DOSSIER-"- Activity code ASD not modified",0) From GESECRAN
    Return
endif

Call ECR_TRACE("Set Activity code 'ASD' to Yes on parent folder"-[F:ADS2]DOSSIER,0) From GESECRAN

Local File =DOSSIER+".ADOSACT"   [ADA] 
Trbegin [ADA]
 For [ADA]ADA0 where DOSSIER=[L]DOSSIER and CODACT="ASD"
  If [F:ADA]FLACT=1
    [F:ADA]FLACT=2
    Rewrite [ADA]
    If fstat
      Call ERREUR("ADOSACT - Key: ASD ",2) From DOSDIC
    Endif 
  Endif
 Next
Commit

Close Local File [ADA]

Return



#-------------------#
# P999: exemple maj parametre ASDTRTAPP
#       Dans un patch applicatif:  A dupliquer en remplacant xxxxxxx et en faisant l'appel
#-------------------#
$MAJADW_ASDTRTAPP
Call ECR_TRACE("Set parameter 'ASDTRTAPP' to 'xxxxxxxx' on parent folder"-DOSSIER,0) From GESECRAN

Local File =DOSSIER+".ADOVAL" [ADW]
Look [ADW]ADW0="";"";"ASDTRTAPP"
If fstat = 0
    Trbegin [ADW]
        Readlock [ADW]ADW0="";"";"ASDTRTAPP"
        If fstat = 0
            [F:ADW]VALEUR="xxxxxxxx"
            [F:ADW]UPDDAT = date$
            [F:ADW]UPDTIM = time
            [F:ADW]UPDUSR = GUSER
            Rewrite [ADW]
        Endif 
    Commit
Else
    Call ERREUR('ADOVAL - Key: "";"";"ASDTRTAPP" not found',2) From DOSDIC
Endif
Close Local File [ADW]

Return

# Test
#DOSSIER="GX3APP"
#Dbgaff
#Gosub MAJADW_ASDTRTAPP
#End




