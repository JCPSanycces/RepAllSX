#########################################################
$HTMLSRE
#Demande de service
Call TEXTE(14603, SZHTMLTITLE) From OBJDIV
Gosub DOSTARTTABLE From CRMXML140

#On extrait les champs de la table
ITERSORT = 1
For ITERSORT = 1 To 250
    ISERREQUEST = 0
    For ISERREQUEST  = 0 To dim(SZTAGSRE) - 1
        If SZTAGSRE(ISERREQUEST) = "" : Break : Endif

        If IHIDESRE(ISERREQUEST) = 0
            If ISORTSRE(ISERREQUEST) = ITERSORT
                Case SZTAGSRE(ISERREQUEST)
                    When "SREHD1CLOB0"
                        #On extrait le clob Texte
                        ISERREQUEST = dim(SZTAGSRE) - 1
                        Raz SZBUFFTOFILL
                            Read [HD1]HD10 = [F:SRE]NUMFULDES;[F:SRE]TYPFULDES
                            If !fstat
                                Raz SZDESCLOBSRE
                                Setlob SZDESCLOBSRE With [F:HD1]CLOB
                                If SZDESCLOBSRE(0) <> ""
                                    SZLABELFORFILL = SZLABELSRE(ISERREQUEST)
                                    Gosub ADDDEBTRCLOB From CRMXML140

                                    ITERCLOB = 0
                                    For ITERCLOB = 0 To dim(SZDESCLOBSRE) - 1
                                        If SZDESCLOBSRE(ITERCLOB) <> ""
                                            SZBUFFTOFILL(0) = SZDESCLOBSRE(ITERCLOB)
                                            Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                                            Wrseq SZBUFFTOFILL(0) Using [FXML]
                                        Endif
                                    Next

                                    Gosub ADDENDTRCLOB From CRMXML140
                                Endif
                            Endif

                    When Default
                        SZABR = "SRE"
                        SZFIE = SZFIESRE(ISERREQUEST)
                        SZTABLE = "SERREQUEST"
                        SZLABELFORFILL = SZLABELSRE(ISERREQUEST)
                        Gosub WRITEHTMLTR From CRMXML140
                Endcase
            Endif
        Endif
    Next
Next

Gosub DOENDTABLE From CRMXML140
Return

######################################################################
# Tiers
######################################################################
$SETBPREXCEPT

#Tables de travail
If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif

#Tables pour gestion des exceptions
If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR
SZAOBEXPTAB = "BPARTNER"
SZAOBEXPABR = "BPR"

Gosub SETAOBEXCEPT

Local Integer IBPARTNER
IBPARTNER = IAOBEXPCOUNT

Local Char SZTAGBPR(30)(IBPARTNER)
Local Char SZFIEBPR(30)(IBPARTNER)
Local Integer IHIDEBPR(IBPARTNER)
Local Integer ISORTBPR(IBPARTNER)
Local Char SZLABELBPR(30)(IBPARTNER)
Local Integer IDISPLAYBPR
IDISPLAYBPR = 1
Raz IHIDEBPR
Raz ISORTBPR
Raz SZLABELBPR
IBPARTNER = 0

Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB

For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")

    ITERDIM = 0
    For ITERDIM = 0 To IDIMCONTROL - 1
        SZTAGBPR(IBPARTNER) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
        If ITERDIM = 0
            SZFIEBPR(IBPARTNER) = [F:ATZ]CODZONE
        Else
            SZFIEBPR(IBPARTNER) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif

        Call TEXTE([F:ATZ]NOLONG, SZLABELBPR(IBPARTNER)) From OBJDIV

        IBPARTNER += 1
    Next
Next

Filter [ATZ]

IDIMCONTROL = dim(SZTAGBPR) - 1

#Définition des attributs
ITER = 0
For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETBPRHIDE
Next

#Attribut de tri
Gosub SETBPRSORT

#On vérifie les doublons possibles de tags
IDUPLICATE = 0
While 1
    IDUPLICATE = 0
    ITER = 0
    For ITER = 0 To IDIMCONTROL
        ITER2 = 0
        For ITER2 = 0 To IDIMCONTROL
            If ITER2 <> ITER
                If SZTAGBPR(ITER) <> ""
                    If SZTAGBPR(ITER2) <> ""
                        If SZTAGBPR(ITER2) = SZTAGBPR(ITER)
                            SZTAGBPR(ITER2) = SZTAGBPR(ITER2) + "X"
                            IDUPLICATE = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Next
        If IDUPLICATE : Break : Endif
    Next
    If IDUPLICATE = 0 : Break : Endif
Wend

#Modification de la présentation et du tri par point d'entrée
Gosub PE_AOBEXP From TRTCRMPE

Return

