$HTMLOPP
  #Affaire
  Call TEXTE(18260, SZHTMLTITLE) From OBJDIV
  Gosub HTMLOPP3
Return

######################################################################
$HTMLOPP2
  #Affaire associée
  Call TEXTE(24811, SZHTMLTITLE) From OBJDIV
  Gosub HTMLOPP3
Return

######################################################################
$HTMLOPP3
  Gosub DOSTARTTABLE From CRMXML140
  #On extrait les champs de la table
  For ITERSORT = 1 To 250
    For IOPPOR = 0 To dim(SZTAGOPP)-1
      If SZTAGOPP(IOPPOR) = "" Then
        Break
      Endif
      If IHIDEOPP(IOPPOR) = 0 Then
        If ISORTOPP(IOPPOR) = ITERSORT Then
          SZABR = "OPP"
          SZFIE = SZFIEOPP(IOPPOR)
          SZTABLE = "OPPOR"
          SZLABELFORFILL = SZLABELOPP(IOPPOR)
          Gosub WRITEHTMLTR From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTABLE From CRMXML140
Return

######################################################################
# Tâche
######################################################################
$SETTSKEXCEPT

#Tables de travail
If !clalev([F:TSK]) : Local File TASK [TSK] : Endif
If !clalev([F:HD4]) : Local File HD4CLOB [HD4] : Endif
If !clalev([F:HD6]) : Local File HD6CLOB [HD6] : Endif

#Tables pour gestion des exceptions
If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR
SZAOBEXPTAB = "TASK"
SZAOBEXPABR = "TSK"

Gosub SETAOBEXCEPT

Local Integer ITASK
ITASK = IAOBEXPCOUNT

ITASK += 2 #Pour les clobs
Local Char SZTAGTSK(30)(ITASK)
Local Char SZFIETSK(30)(ITASK)
Local Integer IHIDETSK(ITASK)
Local Integer ISORTTSK(ITASK)
Local Char SZLABELTSK(30)(ITASK)
Local Integer IDISPLAYTSK
IDISPLAYTSK = 1
Raz IHIDETSK
Raz ISORTTSK
Raz SZLABELTSK
ITASK = 0

Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB

For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")

    ITERDIM = 0
    For ITERDIM = 0 To IDIMCONTROL - 1
        SZTAGTSK(ITASK) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
        If ITERDIM = 0
            SZFIETSK(ITASK) = [F:ATZ]CODZONE
        Else
            SZFIETSK(ITASK) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif

        Call TEXTE([F:ATZ]NOLONG, SZLABELTSK(ITASK)) From OBJDIV

        ITASK += 1
    Next
Next

Filter [ATZ]

SZTAGTSK(ITASK) = "TSKHD6CLOB0"
Call TEXTE(6468, SZLABELTSK(ITASK)) From OBJDIV   #Description
ITASK += 1
SZTAGTSK(ITASK) = "TSKHD4CLOB0"
Call TEXTE(14438, SZLABELTSK(ITASK)) From OBJDIV   #Compte-rendu

IDIMCONTROL = dim(SZTAGTSK) - 1

#Définition des attributs
ITER = 0
For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETTSKHIDE
Next

#Attribut de tri
Gosub SETTSKSORT

#On vérifie les doublons possibles de tags
IDUPLICATE = 0
While 1
    IDUPLICATE = 0
    ITER = 0
    For ITER = 0 To IDIMCONTROL
        ITER2 = 0
        For ITER2 = 0 To IDIMCONTROL
            If ITER2 <> ITER
                If SZTAGTSK(ITER) <> ""
                    If SZTAGTSK(ITER2) <> ""
                        If SZTAGTSK(ITER2) = SZTAGTSK(ITER)
                            SZTAGTSK(ITER2) = SZTAGTSK(ITER2) + "X"
                            IDUPLICATE = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Next
        If IDUPLICATE : Break : Endif
    Next
    If IDUPLICATE = 0 : Break : Endif
Wend

#Dimensionnement des buffers clobs
Local Integer I4LNGCLOB
Local Integer I4NBBYTES
Local Integer I4BUFFSIZE
Local Integer I6LNGCLOB
Local Integer I6NBBYTES
Local Integer I6BUFFSIZE

#Description
Read [ATY] CODTYP = "HD6"
If fstat
    I6LNGCLOB = 3
Else
    I6LNGCLOB = [F:ATY]LNGTYP
Endif

If I6LNGCLOB = 0
    I6LNGCLOB = 3
Endif

I6NBBYTES = 1024*(2^I6LNGCLOB)
I6BUFFSIZE = I6NBBYTES / 35
I6BUFFSIZE += 5
Local Char SZOBJCLOBTSK(35)(I6BUFFSIZE)


#Compte-rendu
Read [ATY] CODTYP = "HD4"
If fstat
    I4LNGCLOB = 6
Else
    I4LNGCLOB = [F:ATY]LNGTYP
Endif

If I4LNGCLOB = 0
    I4LNGCLOB = 6
Endif

I4NBBYTES = 1024*(2^I4LNGCLOB)
I4BUFFSIZE = I4NBBYTES / 35
I4BUFFSIZE += 5
Local Char SZRPOCLOBTSK(35)(I4BUFFSIZE)

#Modification de la présentation et du tri par point d'entrée
Gosub PE_AOBEXP From TRTCRMPE

Return

################################################
#Attribut de visibilité
################################################
$SETTSKHIDE
#Par défaut, chaque champ est visible
IHIDETSK(ITER) = 0

#Clob
If SZFIETSK(ITER) = "TYPFULOBJ"
    IHIDETSK(ITER) = 1
Endif

#Clob
If SZFIETSK(ITER) = "NUMFULOBJ"
    IHIDETSK(ITER) = 1
Endif

#Clob
If SZFIETSK(ITER) = "OBJFLG"
    IHIDETSK(ITER) = 1
Endif

#Clob
If SZFIETSK(ITER) = "TYPFULRPO"
    IHIDETSK(ITER) = 1
Endif

#Clob
If SZFIETSK(ITER) = "NUMFULRPO"
    IHIDETSK(ITER) = 1
Endif

#Clob
If SZFIETSK(ITER) = "RPOFLG"
    IHIDETSK(ITER) = 1
Endif

If SZFIETSK(ITER) = "TSKDEL"
    IHIDETSK(ITER) = 1
Endif

# FGR 08/03/2010 : X3SUIVI62924
#If SZFIETSK(ITER) = "TSKORITXT"
#    IHIDETSK(ITER) = 1
#Endif

If SZFIETSK(ITER) = "TSKCMGNUM"
    IHIDETSK(ITER) = 1
Endif

If SZFIETSK(ITER) = "TSKOPGNUM"
    IHIDETSK(ITER) = 1
Endif

If SZFIETSK(ITER) = "TSKOPGTYP"
    IHIDETSK(ITER) = 1
Endif

#Date modif
If SZFIETSK(ITER) = "UPDDAT"
    IHIDETSK(ITER) = 1
Endif

#Opérateur modif
If SZFIETSK(ITER) = "UPDUSR"
    IHIDETSK(ITER) = 1
Endif

Return

################################################
#Attribut de tri
################################################
$SETTSKSORT
ISORT = 0

ITER = 0
For ITER = 0 To dim(SZTAGTSK) - 1
    ISORT = 0

    If SZFIETSK(ITER) = "TSKNUM"
        ISORT = 1
    Endif

    If SZFIETSK(ITER) = "SALFCY"
        ISORT = 2
    Endif

    If SZFIETSK(ITER) = "TSKCMP"
        ISORT = 3
    Endif

    If SZFIETSK(ITER) = "TSKCCN"
        ISORT = 4
    Endif

    If SZFIETSK(ITER) = "TSKPJT"
        ISORT = 5
    Endif

    If SZFIETSK(ITER) = "TSKTYP"
        ISORT = 6
    Endif

    If SZFIETSK(ITER) = "TSKDAT"
        ISORT = 7
    Endif

    If SZFIETSK(ITER) = "TSKSTR"
        ISORT = 8
    Endif

    If SZFIETSK(ITER) = "TSKPIOLEV"
        ISORT = 9
    Endif

    If SZFIETSK(ITER) = "TSKREP"
        ISORT = 10
    Endif

    If SZFIETSK(ITER) = "TSKDES"
        ISORT = 11
    Endif

    If SZTAGTSK(ITER) = "TSKHD6CLOB0"
        ISORT = 12
    Endif

    If SZFIETSK(ITER) = "TSKDON"
        ISORT = 13
    Endif

    If SZFIETSK(ITER) = "TSKRPO"
        ISORT = 14
    Endif

    If SZTAGTSK(ITER) = "TSKHD4CLOB0"
        ISORT = 15
    Endif

    If SZFIETSK(ITER) = "HOUTIMSPG"
        ISORT = 16
    Endif

    If SZFIETSK(ITER) = "MNTTIMSPG"
        ISORT = 17
    Endif

    If SZFIETSK(ITER) = "TSKSAO"
        ISORT = 18
    Endif
    # FGR 08/03/2010 : X3SUIVI62924 (début)
    #If SZFIETSK(ITER) = "TSKORI"
    #    ISORT = 19
    #Endif
    If SZFIETSK(ITER) = "TSKORIADI"
        ISORT = 19
    Endif
    # FGR 08/03/2010 : X3SUIVI62924 (fin)
    If SZFIETSK(ITER) = "TSKORIVCR"
        ISORT = 20
    Endif

    If SZFIETSK(ITER) = "TSKORIVCRL"
        ISORT = 21
    Endif

    ISORTTSK(ITER) = ISORT
Next

ISORT = 22

ITER = 0
For ITER = 0 To dim(SZTAGTSK) - 1
    If ISORTTSK(ITER) = 0
        ISORTTSK(ITER) = ISORT
    Endif
    ISORT += 1
Next

Return

#########################################################
$TSKEXCEPTION
  If SZFIE = "TSKCCN" Then
    #Interlocuteur
    If [F:TSK]TSKCCN <> "" Then
      Read [AIN]AIN0=[F:TSK]TSKCCN
      If !fstat Then
        Call BUILDFULNAM("AIN", SZBUFFTOFILL(0)) From CRMUTIL140
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Elsif SZFIE = "CREUSR" Then
    If [F:TSK]CREUSR <> "" Then
      Read [AUS]CODUSR=[F:TSK]CREUSR
      If !fstat Then
        SZBUFFTOFILL(0) = "(" + [F:AUS]USR + ")" - [F:AUS]NOMUSR
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Endif
Return

#########################################################
$XMLTSK
  Gosub XMLTSK From CRMEXCEPT2
Return

#########################################################
$HTMLTSK
Call TEXTE(1195, SZHTMLTITLE) From OBJDIV      #Tâche

Gosub DOSTARTTABLE From CRMXML140

#On extrait les champs de la table INTERVEN
ITERSORT = 1
For ITERSORT = 1 To 250
    ITASK = 0
    For ITASK = 0 To dim(SZTAGTSK) - 1
        If SZTAGTSK(ITASK) = "" : Break : Endif

        If IHIDETSK(ITASK) = 0
            If ISORTTSK(ITASK) = ITERSORT
                Case SZTAGTSK(ITASK)
                    When "TSKHD6CLOB0"
                        #On extrait le clob Description
                        ITASK = dim(SZTAGTSK) - 2
                        Raz SZBUFFTOFILL
                        If [F:TSK]TYPFULOBJ <> ""
                            If [F:TSK]NUMFULOBJ <> ""
                                Read [HD6]HD60=[F:TSK]NUMFULOBJ;[F:TSK]TYPFULOBJ
                                If !fstat
                                    Raz SZOBJCLOBTSK
                                    Setlob SZOBJCLOBTSK With [F:HD6]CLOB
                                    If SZOBJCLOBTSK(0) <> ""
                                        SZLABELFORFILL = SZLABELTSK(ITASK)
                                        Gosub ADDDEBTRCLOB From CRMXML140

                                        ITERCLOB = 0
                                        For ITERCLOB = 0 To dim(SZOBJCLOBTSK) - 1
                                            If SZOBJCLOBTSK(ITERCLOB) <> ""
                                                SZBUFFTOFILL(0) = SZOBJCLOBTSK(ITERCLOB)
                                                Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                                                Wrseq SZBUFFTOFILL(0) Using [FXML]
                                            Endif
                                        Next

                                        Gosub ADDENDTRCLOB From CRMXML140
                                    Endif
                                Endif
                            Endif
                        Endif

                    When "TSKHD4CLOB0"
                        #On extrait le clob Compte-rendu
                        ITASK = dim(SZFIETSK) - 1
                        Raz SZBUFFTOFILL
                        If [F:TSK]TYPFULRPO <> ""
                            If [F:TSK]NUMFULRPO <> ""
                                Read [HD4]HD40 = [F:TSK]NUMFULRPO;[F:TSK]TYPFULRPO
                                If !fstat
                                    Raz SZRPOCLOBTSK
                                    Setlob SZRPOCLOBTSK With [F:HD4]CLOB
                                    If SZRPOCLOBTSK(0) <> ""
                                        SZLABELFORFILL = SZLABELTSK(ITASK)
                                        Gosub ADDDEBTRCLOB From CRMXML140

                                        ITERCLOB = 0
                                        For ITERCLOB = 0 To dim(SZRPOCLOBTSK) - 1
                                            If SZRPOCLOBTSK(ITERCLOB) <> ""
                                                SZBUFFTOFILL(0) = SZRPOCLOBTSK(ITERCLOB)
                                                Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                                                Wrseq SZBUFFTOFILL(0) Using [FXML]
                                            Endif
                                        Next

                                        Gosub ADDENDTRCLOB From CRMXML140
                                    Endif
                                Endif
                            Endif
                        Endif

                    When Default
                        SZABR = "TSK"
                        SZFIE = SZFIETSK(ITASK)
                        SZTABLE = "TASK"
                        SZLABELFORFILL = SZLABELTSK(ITASK)
                        Gosub WRITEHTMLTR From CRMXML140
                Endcase
            Endif
        Endif
    Next
Next

Gosub DOENDTABLE From CRMXML140
Return

######################################################################
# Appel
######################################################################
$SETCLLEXCEPT

#Tables de travail
If !clalev([F:CLL]) : Local File PHONECALL [CLL] : Endif
If !clalev([F:HD4]) : Local File HD4CLOB [HD4] : Endif
If !clalev([F:HD5]) : Local File HD5CLOB [HD5] : Endif

#Tables pour gestion des exceptions
If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR
SZAOBEXPTAB = "PHONECALL"
SZAOBEXPABR = "CLL"

Gosub SETAOBEXCEPT

Local Integer IPHONECALL
IPHONECALL = IAOBEXPCOUNT

IPHONECALL += 2 #Pour les clobs
Local Char SZTAGCLL(30)(IPHONECALL)
Local Char SZFIECLL(30)(IPHONECALL)
Local Integer IHIDECLL(IPHONECALL)
Local Integer ISORTCLL(IPHONECALL)
Local Char SZLABELCLL(30)(IPHONECALL)
Local Integer IDISPLAYCLL
IDISPLAYCLL = 1
Raz IHIDECLL
Raz ISORTCLL
Raz SZLABELCLL
IPHONECALL = 0

Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB

For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")

    ITERDIM = 0
    For ITERDIM = 0 To IDIMCONTROL - 1
        SZTAGCLL(IPHONECALL) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
        If ITERDIM = 0
            SZFIECLL(IPHONECALL) = [F:ATZ]CODZONE
        Else
            SZFIECLL(IPHONECALL) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif

        Call TEXTE([F:ATZ]NOLONG, SZLABELCLL(IPHONECALL)) From OBJDIV

        IPHONECALL += 1
    Next
Next

Filter [ATZ]

SZTAGCLL(IPHONECALL) = "CLLHD5CLOB0"
Call TEXTE(15309, SZLABELCLL(IPHONECALL)) From OBJDIV   #Objet de l'appel
IPHONECALL += 1
SZTAGCLL(IPHONECALL) = "CLLHD4CLOB0"
Call TEXTE(14438, SZLABELCLL(IPHONECALL)) From OBJDIV   #Compte-rendu

IDIMCONTROL = dim(SZTAGCLL) - 1

#Définition des attributs
ITER = 0
For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETCLLHIDE
Next

#Attribut de tri
Gosub SETCLLSORT

#On vérifie les doublons possibles de tags
IDUPLICATE = 0
While 1
    IDUPLICATE = 0
    ITER = 0
    For ITER = 0 To IDIMCONTROL
        ITER2 = 0
        For ITER2 = 0 To IDIMCONTROL
            If ITER2 <> ITER
                If SZTAGCLL(ITER) <> ""
                    If SZTAGCLL(ITER2) <> ""
                        If SZTAGCLL(ITER2) = SZTAGCLL(ITER)
                            SZTAGCLL(ITER2) = SZTAGCLL(ITER2) + "X"
                            IDUPLICATE = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Next
        If IDUPLICATE : Break : Endif
    Next
    If IDUPLICATE = 0 : Break : Endif
Wend

#Dimensionnement des buffers clobs
Local Integer I4LNGCLOB
Local Integer I4NBBYTES
Local Integer I4BUFFSIZE
Local Integer I5LNGCLOB
Local Integer I5NBBYTES
Local Integer I5BUFFSIZE

#Description
Read [ATY] CODTYP = "HD5"
If fstat
    I5LNGCLOB = 5
Else
    I5LNGCLOB = [F:ATY]LNGTYP
Endif

If I5LNGCLOB = 0
    I5LNGCLOB = 5
Endif

I5NBBYTES = 1024*(2^I5LNGCLOB)
I5BUFFSIZE = I5NBBYTES / 35
I5BUFFSIZE += 5
Local Char SZOBJCLOBCLL(35)(I5BUFFSIZE)


#Compte-rendu
Read [ATY] CODTYP = "HD4"
If fstat
    I4LNGCLOB = 6
Else
    I4LNGCLOB = [F:ATY]LNGTYP
Endif

If I4LNGCLOB = 0
    I4LNGCLOB = 6
Endif

I4NBBYTES = 1024*(2^I4LNGCLOB)
I4BUFFSIZE = I4NBBYTES / 35
I4BUFFSIZE += 5
Local Char SZRPOCLOBCLL(35)(I4BUFFSIZE)

