        Else
            SZFIESRN(ISREMACCPN) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif

        Call TEXTE([F:ATZ]NOLONG, SZLABELSRN(ISREMACCPN)) From OBJDIV

        ISREMACCPN += 1
    Next
Next

Filter [ATZ]

IDIMCONTROL = dim(SZTAGSRN) - 1

#Définition des attributs
ITER = 0
For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETSRNHIDE
Next

#Attribut de tri
Gosub SETSRNSORT

#On vérifie les doublons possibles de tags
IDUPLICATE = 0
While 1
    IDUPLICATE = 0
    ITER = 0
    For ITER = 0 To IDIMCONTROL
        ITER2 = 0
        For ITER2 = 0 To IDIMCONTROL
            If ITER2 <> ITER
                If SZTAGSRN(ITER) <> ""
                    If SZTAGSRN(ITER2) <> ""
                        If SZTAGSRN(ITER2) = SZTAGSRN(ITER)
                            SZTAGSRN(ITER2) = SZTAGSRN(ITER2) + "X"
                            IDUPLICATE = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Next
        If IDUPLICATE : Break : Endif
    Next
    If IDUPLICATE = 0 : Break : Endif
Wend

#Modification de la présentation et du tri par point d'entrée
Gosub PE_AOBEXP From TRTCRMPE

Return

