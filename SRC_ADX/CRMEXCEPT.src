######################################################################
# Solution
######################################################################
$SETSOLEXCEPT

#Tables de travail
If !clalev([F:SOL]) : Local File SOLUTION [SOL] : Endif
If !clalev([F:HD3]) : Local File HD3CLOB [HD3] : Endif

#Tables pour gestion des exceptions
If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR
SZAOBEXPTAB = "SOLUTION"
SZAOBEXPABR = "SOL"

Gosub SETAOBEXCEPT

Local Integer ISOLUTION
ISOLUTION = IAOBEXPCOUNT

ISOLUTION += 2 #Pour les clobs
Local Char SZTAGSOL(30)(ISOLUTION)
Local Char SZFIESOL(30)(ISOLUTION)
Local Integer IHIDESOL(ISOLUTION)
Local Integer ISORTSOL(ISOLUTION)
Local Char SZLABELSOL(30)(ISOLUTION)
Local Integer IDISPLAYSOL
IDISPLAYSOL = 1
Raz IHIDESOL
Raz ISORTSOL
Raz SZLABELSOL
ISOLUTION = 0

Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB

For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")

    ITERDIM = 0
    For ITERDIM = 0 To IDIMCONTROL - 1
        SZTAGSOL(ISOLUTION) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
        If ITERDIM = 0
            SZFIESOL(ISOLUTION) = [F:ATZ]CODZONE
        Else
            SZFIESOL(ISOLUTION) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif

        Call TEXTE([F:ATZ]NOLONG, SZLABELSOL(ISOLUTION)) From OBJDIV

        ISOLUTION += 1
    Next
Next

Filter [ATZ]

SZTAGSOL(ISOLUTION) = "PBLHD3CLOB0"
Call TEXTE(23912, SZLABELSOL(ISOLUTION)) From OBJDIV   #Description de la demande
ISOLUTION += 1
SZTAGSOL(ISOLUTION) = "SOLHD3CLOB0"
Call TEXTE(14611, SZLABELSOL(ISOLUTION)) From OBJDIV   #Description de la solution

IDIMCONTROL = dim(SZTAGSOL) - 1

#Définition des attributs
ITER = 0
For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETSOLHIDE
Next

#Attribut de tri
Gosub SETSOLSORT

#On vérifie les doublons possibles de tags
IDUPLICATE = 0
While 1
    IDUPLICATE = 0
    ITER = 0
    For ITER = 0 To IDIMCONTROL
        ITER2 = 0
        For ITER2 = 0 To IDIMCONTROL
            If ITER2 <> ITER
                If SZTAGSOL(ITER) <> ""
                    If SZTAGSOL(ITER2) <> ""
                        If SZTAGSOL(ITER2) = SZTAGSOL(ITER)
                            SZTAGSOL(ITER2) = SZTAGSOL(ITER2) + "X"
                            IDUPLICATE = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Next
        If IDUPLICATE : Break : Endif
    Next
    If IDUPLICATE = 0 : Break : Endif
Wend

#Dimensionnement des buffers clobs
Local Integer I3LNGCLOB
Local Integer I3NBBYTES
Local Integer I3BUFFSIZE

Read [ATY] CODTYP = "HD3"
If fstat
    I3LNGCLOB = 6
Else
    I3LNGCLOB = [F:ATY]LNGTYP
Endif

If I3LNGCLOB = 0
    I3LNGCLOB = 6
Endif

I3NBBYTES = 1024*(2^I3LNGCLOB)
I3BUFFSIZE = I3NBBYTES / 35
I3BUFFSIZE += 5
Local Char SZPBLCLOBSOL(35)(I3BUFFSIZE)
Local Char SZSOLCLOBSOL(35)(I3BUFFSIZE)

#Modification de la présentation et du tri par point d'entrée
Gosub PE_AOBEXP From TRTCRMPE

Return

################################################
#Attribut de visibilité
################################################
$SETSOLHIDE
#Par défaut, chaque champ est visible
IHIDESOL(ITER) = 0

If SZFIESOL(ITER) = "PBLDESFLG"
    IHIDESOL(ITER) = 1
Endif

If SZFIESOL(ITER) = "TYPPBLDES"
    IHIDESOL(ITER) = 1
Endif

If SZFIESOL(ITER) = "NUMPBLDES"
    IHIDESOL(ITER) = 1
Endif

If SZFIESOL(ITER) = "TYPSOLDES"
    IHIDESOL(ITER) = 1
Endif

If SZFIESOL(ITER) = "NUMSOLDES"
    IHIDESOL(ITER) = 1
Endif

If SZFIESOL(ITER) = "SOLDESFLG"
    IHIDESOL(ITER) = 1
Endif

If left$(SZFIESOL(ITER), 6) = "KEYWRD"
    IHIDESOL(ITER) = 1
Endif

If left$(SZFIESOL(ITER), 6) = "CODSOL"
    IHIDESOL(ITER) = 1
Endif

If SZFIESOL(ITER) = "UPDUSR"
    IHIDESOL(ITER) = 1
Endif

If SZFIESOL(ITER) = "UPDDAT"
    IHIDESOL(ITER) = 1
Endif

Return

################################################
#Attribut de tri
################################################
$SETSOLSORT
ISORT = 0

ITER = 0
For ITER = 0 To dim(SZTAGSOL) - 1
    ISORT = 0

    If SZFIESOL(ITER) = "NUM"
        ISORT = 1
    Endif

    If SZFIESOL(ITER) = "SRENUM"
        ISORT = 2
    Endif

    If SZFIESOL(ITER) = "CAT"
        ISORT = 3
    Endif

    If SZFIESOL(ITER) = "PBLGRP"
        ISORT = 4
    Endif

    If SZFIESOL(ITER) = "TTR"
        ISORT = 5
    Endif

    If SZFIESOL(ITER) = "PBLDES"
        ISORT = 6
    Endif

    If SZTAGSOL(ITER) = "PBLHD3CLOB0"
        ISORT = 7
    Endif

    If SZFIESOL(ITER) = "SOLDES"
        ISORT = 8
    Endif

    If SZTAGSOL(ITER) = "SOLHD3CLOB0"
        ISORT = 9
    Endif

    If SZFIESOL(ITER) = "CREDAT"
        ISORT = 10
    Endif

    If SZFIESOL(ITER) = "CREHOU"
        ISORT = 11
    Endif

    If SZFIESOL(ITER) = "CREUSR"
        ISORT = 12
    Endif

    ISORTSOL(ITER) = ISORT
Next

ISORT = 13

ITER = 0
For ITER = 0 To dim(SZTAGSOL) - 1
    If ISORTSOL(ITER) = 0
        ISORTSOL(ITER) = ISORT
    Endif
    ISORT += 1
Next

Return

#########################################################
$SOLEXCEPTION
  If SZFIE = "CREUSR" Then
    If [F:SOL]CREUSR <> "" Then
      Read [AUS]CODUSR=[F:SOL]CREUSR
      If !fstat Then
        SZBUFFTOFILL(0) = "(" + [F:AUS]USR + ")" - [F:AUS]NOMUSR
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Endif
Return

#########################################################
$XMLSOL
  Gosub XMLSOL From CRMEXCEPT2
Return

#########################################################
$XMLSOL2
  Gosub XMLSOL2 From CRMEXCEPT2
Return

#########################################################
$HTMLSOL
  Call TEXTE(14610, SZHTMLTITLE) From OBJDIV      #Solution
  Gosub HTMLSOL3
Return

#########################################################
$HTMLSOL2
  Call TEXTE(24810, SZHTMLTITLE) From OBJDIV      #Solution associée
  Gosub HTMLSOL3
Return

#########################################################
$HTMLSOL3

Gosub DOSTARTTABLE From CRMXML140

#On extrait les champs de la table
ITERSORT = 1
For ITERSORT = 1 To 250
    ISOLUTION = 0
    For ISOLUTION = 0 To dim(SZTAGSOL) - 1
        If SZTAGSOL(ISOLUTION) = "" : Break : Endif

        If IHIDESOL(ISOLUTION) = 0
            If ISORTSOL(ISOLUTION) = ITERSORT
                Case SZTAGSOL(ISOLUTION)
                    When "PBLHD3CLOB0"
                        #On extrait le clob Description de la demande
                        ISOLUTION = dim(SZTAGSOL) - 2
                        Raz SZBUFFTOFILL
                        If [F:SOL]TYPPBLDES <> ""
                            If [F:SOL]NUMPBLDES <> ""
                                Read [HD3]HD30 = [F:SOL]NUMPBLDES;[F:SOL]TYPPBLDES
                                If !fstat
                                    Raz SZPBLCLOBSOL
                                    Setlob SZPBLCLOBSOL With [F:HD3]CLOB
                                    If SZPBLCLOBSOL(0) <> ""
                                        SZLABELFORFILL = SZLABELSOL(ISOLUTION)
                                        Gosub ADDDEBTRCLOB From CRMXML140

                                        ITERCLOB = 0
                                        For ITERCLOB = 0 To dim(SZPBLCLOBSOL) - 1
                                            If SZPBLCLOBSOL(ITERCLOB) <> ""
                                                SZBUFFTOFILL(0) = SZPBLCLOBSOL(ITERCLOB)
                                                Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                                                Wrseq SZBUFFTOFILL(0) Using [FXML]
                                            Endif
                                        Next

                                        Gosub ADDENDTRCLOB From CRMXML140
                                    Endif
                                Endif
                            Endif
                        Endif

                    When "SOLHD3CLOB0"
                        #On extrait le clob Description de la solution
                        ISOLUTION = dim(SZFIESOL) - 1
                        Raz SZBUFFTOFILL
                        If [F:SOL]TYPSOLDES <> ""
                            If [F:SOL]NUMSOLDES <> ""
                                Read [HD3]HD30 = [F:SOL]NUMSOLDES;[F:SOL]TYPSOLDES
                                If !fstat
                                    Raz SZSOLCLOBSOL
                                    Setlob SZSOLCLOBSOL With [F:HD3]CLOB
                                    If SZSOLCLOBSOL(0) <> ""
                                        SZLABELFORFILL = SZLABELSOL(ISOLUTION)
                                        Gosub ADDDEBTRCLOB From CRMXML140

                                        ITERCLOB = 0
                                        For ITERCLOB = 0 To dim(SZSOLCLOBSOL) - 1
                                            If SZSOLCLOBSOL(ITERCLOB) <> ""
                                                SZBUFFTOFILL(0) = SZSOLCLOBSOL(ITERCLOB)
                                                Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                                                Wrseq SZBUFFTOFILL(0) Using [FXML]
                                            Endif
                                        Next

                                        Gosub ADDENDTRCLOB From CRMXML140
                                    Endif
                                Endif
                            Endif
                        Endif

                    When Default
                        SZABR = "SOL"
                        SZFIE = SZFIESOL(ISOLUTION)
                        SZTABLE = "SOLUTION"
                        SZLABELFORFILL = SZLABELSOL(ISOLUTION)
                        Gosub WRITEHTMLTR From CRMXML140
                Endcase
            Endif
        Endif
    Next
Next

Gosub DOENDTABLE From CRMXML140
Return

######################################################################
# Affaire
######################################################################
$SETOPPEXCEPT

#Tables de travail
If !clalev([F:OPP]) : Local File OPPOR [OPP] : Endif

#Tables pour gestion des exceptions
If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR
SZAOBEXPTAB = "OPPOR"
SZAOBEXPABR = "OPP"

Gosub SETAOBEXCEPT

Local Integer IOPPOR
IOPPOR = IAOBEXPCOUNT

Local Char SZTAGOPP(30)(IOPPOR)
Local Char SZFIEOPP(30)(IOPPOR)
Local Integer IHIDEOPP(IOPPOR)
Local Integer ISORTOPP(IOPPOR)
Local Char SZLABELOPP(30)(IOPPOR)
Local Integer IDISPLAYOPP
IDISPLAYOPP = 1
Raz IHIDEOPP
Raz ISORTOPP
Raz SZLABELOPP
IOPPOR = 0

Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB

For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")

    ITERDIM = 0
    For ITERDIM = 0 To IDIMCONTROL - 1
        SZTAGOPP(IOPPOR) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
        If ITERDIM = 0
            SZFIEOPP(IOPPOR) = [F:ATZ]CODZONE
        Else
            SZFIEOPP(IOPPOR) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif

        Call TEXTE([F:ATZ]NOLONG, SZLABELOPP(IOPPOR)) From OBJDIV

        IOPPOR += 1
    Next
Next

Filter [ATZ]

IDIMCONTROL = dim(SZTAGOPP) - 1

#Définition des attributs
ITER = 0
For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETOPPHIDE
Next

#Attribut de tri
Gosub SETOPPSORT

#On vérifie les doublons possibles de tags
IDUPLICATE = 0
While 1
    IDUPLICATE = 0
    ITER = 0
    For ITER = 0 To IDIMCONTROL
        ITER2 = 0
        For ITER2 = 0 To IDIMCONTROL
            If ITER2 <> ITER
                If SZTAGOPP(ITER) <> ""
                    If SZTAGOPP(ITER2) <> ""
                        If SZTAGOPP(ITER2) = SZTAGOPP(ITER)
                            SZTAGOPP(ITER2) = SZTAGOPP(ITER2) + "X"
                            IDUPLICATE = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Next
        If IDUPLICATE : Break : Endif
    Next
    If IDUPLICATE = 0 : Break : Endif
Wend

#Modification de la présentation et du tri par point d'entrée
Gosub PE_AOBEXP From TRTCRMPE

Return

################################################
#Attribut de visibilité
################################################
$SETOPPHIDE
#Par défaut, chaque champ est visible
IHIDEOPP(ITER) = 0

If SZFIEOPP(ITER) = "OPPSTEA2"
    IHIDEOPP(ITER) = 1
Endif

If SZFIEOPP(ITER) = "OPPSTE"
    IHIDEOPP(ITER) = 1
Endif

If SZFIEOPP(ITER) = "OPPCLO"
    IHIDEOPP(ITER) = 1
Endif

If SZFIEOPP(ITER) = "OPPCMGNUM"
    IHIDEOPP(ITER) = 1
Endif

If SZFIEOPP(ITER) = "OPPOPGNUM"
    IHIDEOPP(ITER) = 1
Endif

If SZFIEOPP(ITER) = "OPPOPGTYP"
    IHIDEOPP(ITER) = 1
Endif

If SZFIEOPP(ITER) = "OPPORITXT"
    IHIDEOPP(ITER) = 1
Endif

If left$(SZFIEOPP(ITER), 3) = "CPP"
    IHIDEOPP(ITER) = 1
Endif

If left$(SZFIEOPP(ITER), 6) = "CPPAMT"
    IHIDEOPP(ITER) = 1
Endif

If left$(SZFIEOPP(ITER), 3) = "ASE"
    IHIDEOPP(ITER) = 1
Endif

If left$(SZFIEOPP(ITER), 3) = "SHC"
    IHIDEOPP(ITER) = 1
Endif

If left$(SZFIEOPP(ITER), 3) = "STE"
    IHIDEOPP(ITER) = 1
Endif

If left$(SZFIEOPP(ITER), 3) = "DON"
    IHIDEOPP(ITER) = 1
Endif

If left$(SZFIEOPP(ITER), 6) = "ENDDAT"
    IHIDEOPP(ITER) = 1
Endif

If left$(SZFIEOPP(ITER), 3) = "REN"
    IHIDEOPP(ITER) = 1
Endif

If left$(SZFIEOPP(ITER), 6) = "SBBPJT"
    IHIDEOPP(ITER) = 1
Endif

#Date modif
If SZFIEOPP(ITER) = "UPDDAT"
    IHIDEOPP(ITER) = 1
Endif

#Opérateur modif
If SZFIEOPP(ITER) = "UPDUSR"
    IHIDEOPP(ITER) = 1
Endif

Return

################################################
#Attribut de tri
################################################
$SETOPPSORT
ISORT = 0

ITER = 0
For ITER = 0 To dim(SZTAGOPP) - 1
    ISORT = 0

    If SZFIEOPP(ITER) = "OPPNUM"
        ISORT = 1
    Endif

    If SZFIEOPP(ITER) = "SALFCY"
        ISORT = 2
    Endif

    If SZFIEOPP(ITER) = "OPPDES"
        ISORT = 3
    Endif

    If SZFIEOPP(ITER) = "OPPSRENUM"
        ISORT = 4
    Endif

    If SZFIEOPP(ITER) = "OPPCMP"
        ISORT = 5
    Endif

    If SZFIEOPP(ITER) = "OPPMCN"
        ISORT = 6
    Endif

    If SZFIEOPP(ITER) = "OPPREP"
        ISORT = 7
    Endif

    If SZFIEOPP(ITER) = "OPPCDA"
        ISORT = 8
    Endif

    If SZFIEOPP(ITER) = "OPPREACDA"
        ISORT = 9
    Endif

    If SZFIEOPP(ITER) = "OPPTYP"
        ISORT = 10
    Endif

    If SZFIEOPP(ITER) = "OPPSTE"
        ISORT = 11
    Endif

    If SZFIEOPP(ITER) = "STRSTE"
        ISORT = 12
    Endif

    If SZFIEOPP(ITER) = "OPPNBQ"
        ISORT = 13
    Endif

    If SZFIEOPP(ITER) = "OPPAMT"
        ISORT = 14
    Endif

    If SZFIEOPP(ITER) = "CUR"
        ISORT = 15
    Endif

    If SZFIEOPP(ITER) = "PBYPRJ"
        ISORT = 16
    Endif

    If SZFIEOPP(ITER) = "PBYPRJAAM"
        ISORT = 17
    Endif

    If SZFIEOPP(ITER) = "OPPSUC"
        ISORT = 18
    Endif

    If SZFIEOPP(ITER) = "OPPAAM"
        ISORT = 19
    Endif

    If SZFIEOPP(ITER) = "DAM"
        ISORT = 20
    Endif

    If SZFIEOPP(ITER) = "DAMAVE"
        ISORT = 21
    Endif

    If SZFIEOPP(ITER) = "DAMCUM"
        ISORT = 22
    Endif

    If SZFIEOPP(ITER) = "OPPORI"
        ISORT = 23
    Endif

    If SZFIEOPP(ITER) = "OPPORIVCR"
        ISORT = 24
    Endif

    If SZFIEOPP(ITER) = "OPPORIVCRL"
        ISORT = 25
    Endif

    If SZFIEOPP(ITER) = "CREDAT"
        ISORT = 26
    Endif

    If SZFIEOPP(ITER) = "CREHOU"
        ISORT = 27
    Endif

    If SZFIEOPP(ITER) = "CREUSR"
        ISORT = 28
    Endif

    ISORTOPP(ITER) = ISORT
Next

ISORT = 29

ITER = 0
For ITER = 0 To dim(SZTAGOPP) - 1
    If ISORTOPP(ITER) = 0
        ISORTOPP(ITER) = ISORT
    Endif
    ISORT += 1
Next

Return

#########################################################
$OPPEXCEPTION
  #Interlocuteur
  If SZFIE = "OPPMCN" Then
    If [F:OPP]OPPMCN <> "" Then
      Read [AIN]AIN0=[F:OPP]OPPMCN
      If !fstat Then
        Call BUILDFULNAM("AIN", SZBUFFTOFILL(0)) From CRMUTIL140
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Elsif SZFIE = "CREUSR" Then
    If [F:OPP]CREUSR <> "" Then
      Read [AUS]CODUSR=[F:OPP]CREUSR
      If !fstat Then
        SZBUFFTOFILL(0) = "(" + [F:AUS]USR + ")" - [F:AUS]NOMUSR
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Endif
Return

