    If SZFIEMAC(ITER) = "MACNUM"
        ISORT = 1
    Endif

    If SZFIEMAC(ITER) = "SALFCY"
        ISORT = 2
    Endif

    If SZFIEMAC(ITER) = "MACPDTCOD"
