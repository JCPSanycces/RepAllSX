################################################
$SETBPRSORT
ISORT = 0

ITER = 0
For ITER = 0 To dim(SZTAGBPR) - 1
    ISORT = 0

    If SZFIEBPR(ITER) = "BPRNUM"
        ISORT = 1
    Endif

    If SZFIEBPR(ITER) = "BPRSHO"
        ISORT = 2
    Endif

    If SZFIEBPR(ITER) = "BPRLOG"
        ISORT = 3
    Endif

    If SZFIEBPR(ITER) = "BPRNAM"
        ISORT = 4
    Endif

