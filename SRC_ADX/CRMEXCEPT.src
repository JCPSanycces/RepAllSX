ISORT = 0

ITER = 0
For ITER = 0 To dim(SZTAGAIN) - 1
    ISORT = 0

    If SZFIEAIN(ITER) = "CNTNUM"
        ISORT = 1
    Endif

    If SZFIEAIN(ITER) = "CNTTTL"
        ISORT = 2
    Endif

    If SZFIEAIN(ITER) = "CNTFNA"
        ISORT = 3
    Endif

    If SZFIEAIN(ITER) = "CNTLNA"
        ISORT = 4
    Endif

    If SZFIEAIN(ITER) = "CNTETS"
        ISORT = 5
    Endif

    If SZFIEAIN(ITER) = "CNTFAX"
        ISORT = 6
    Endif

    If SZFIEAIN(ITER) = "CNTMOB"
        ISORT = 7
    Endif

    If SZFIEAIN(ITER) = "CNTEMA"
        ISORT = 8
    Endif

    If SZFIEAIN(ITER) = "CNTLAN"
