$SRNEXCEPTION
  If SZFIE = "CREUSR" Then
    If [F:SRN]CREUSR <> "" Then
      Read [AUS]CODUSR=[F:SRN]CREUSR
      If !fstat Then
        SZBUFFTOFILL(0) = "(" + [F:AUS]USR + ")" - [F:AUS]NOMUSR
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Endif
Return

#########################################################
$XMLSRN
  Gosub XMLSRN From CRMEXCEPT2
Return

#########################################################
$XSDSRN
  Gosub XSDSRN From CRMEXCEPT2
Return

######################################################################
$HTMLSRN
  #Composant concerné
  Call TEXTE(22092, SZHTMLTITLE) From OBJDIV
  Gosub DOSTARTTABLE From CRMXML140
  #On extrait les champs de la table
  For ITERSORT = 1 To 250
    For ISREMACCPN = 0 To dim(SZTAGSRN)-1
      If SZTAGSRN(ISREMACCPN) = "" Then
        Break
      Endif
      If IHIDESRN(ISREMACCPN) = 0 Then
        If ISORTSRN(ISREMACCPN) = ITERSORT Then
          SZABR = "SRN"
          SZFIE = SZFIESRN(ISREMACCPN)
          SZTABLE = "SREMACCPN"
          SZLABELFORFILL = SZLABELSRN(ISREMACCPN)
          Gosub WRITEHTMLTR From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTABLE From CRMXML140
Return

######################################################################
# Demandes de service
######################################################################
$SETSREEXCEPT

#Tables de travail
If !clalev([F:SRE]) : Local File SERREQUEST [SRE] : Endif
If !clalev([F:HD1]) : Local File HD1CLOB [HD1] : Endif

#Tables pour gestion des exceptions
If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
If !clalev([F:QUE]) : Local File QUEUE [QUE] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR
SZAOBEXPTAB = "SERREQUEST"
SZAOBEXPABR = "SRE"

Gosub SETAOBEXCEPT

Local Integer ISERREQUEST
ISERREQUEST = IAOBEXPCOUNT

ISERREQUEST += 1 #Pour les clobs
Local Char SZTAGSRE(30)(ISERREQUEST)
Local Char SZFIESRE(30)(ISERREQUEST)
Local Integer IHIDESRE(ISERREQUEST)
Local Integer ISORTSRE(ISERREQUEST)
Local Char SZLABELSRE(30)(ISERREQUEST)
Local Integer IDISPLAYSRE
IDISPLAYSRE = 1
Raz IHIDESRE
Raz ISORTSRE
Raz SZLABELSRE
ISERREQUEST = 0

Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB

For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")

    ITERDIM = 0
    For ITERDIM = 0 To IDIMCONTROL - 1
        SZTAGSRE(ISERREQUEST) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
        If ITERDIM = 0
            SZFIESRE(ISERREQUEST) = [F:ATZ]CODZONE
        Else
            SZFIESRE(ISERREQUEST) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif

        Call TEXTE([F:ATZ]NOLONG, SZLABELSRE(ISERREQUEST)) From OBJDIV

        ISERREQUEST += 1
    Next
Next

Filter [ATZ]

SZTAGSRE(ISERREQUEST) = "SREHD1CLOB0"
Call TEXTE(6468, SZLABELSRE(ISERREQUEST)) From OBJDIV   #Description

IDIMCONTROL = dim(SZTAGSRE) - 1

#Définition des attributs
ITER = 0
For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETSREHIDE
Next

#Attribut de tri
Gosub SETSRESORT

#On vérifie les doublons possibles de tags
IDUPLICATE = 0
While 1
    IDUPLICATE = 0
    ITER = 0
    For ITER = 0 To IDIMCONTROL
        ITER2 = 0
        For ITER2 = 0 To IDIMCONTROL
            If ITER2 <> ITER
                If SZTAGSRE(ITER) <> ""
                    If SZTAGSRE(ITER2) <> ""
                        If SZTAGSRE(ITER2) = SZTAGSRE(ITER)
                            SZTAGSRE(ITER2) = SZTAGSRE(ITER2) + "X"
                            IDUPLICATE = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Next
        If IDUPLICATE : Break : Endif
    Next
    If IDUPLICATE = 0 : Break : Endif
Wend

#Dimensionnement des buffers clobs
Local Integer I1LNGCLOB
Local Integer I1NBBYTES
Local Integer I1BUFFSIZE

#Description
Read [ATY] CODTYP = "HD1"
If fstat
    I1LNGCLOB = 6
Else
    I1LNGCLOB = [F:ATY]LNGTYP
Endif

If I1LNGCLOB = 0
    I1LNGCLOB = 6
Endif

I1NBBYTES = 1024*(2^I1LNGCLOB)
I1BUFFSIZE = I1NBBYTES / 35
I1BUFFSIZE += 5
Local Char SZDESCLOBSRE(35)(I1BUFFSIZE)

#Modification de la présentation et du tri par point d'entrée
Gosub PE_AOBEXP From TRTCRMPE

Return

