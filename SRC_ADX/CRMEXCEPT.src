# Composants concernés
######################################################################
$SETSRNEXCEPT

If !clalev([F:SRN]) : Local File SREMACCPN [SRN] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR
SZAOBEXPTAB = "SREMACCPN"
SZAOBEXPABR = "SRN"

