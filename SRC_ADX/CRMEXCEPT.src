ISORT = 0

ITER = 0
For ITER = 0 To dim(SZTAGREP) - 1
    ISORT = 0

    If SZFIEREP(ITER) = "REPNUM"
        ISORT = 1
    Endif

    If SZFIEREP(ITER) = "REPNAM"
        ISORT = 2
    Endif

    If SZFIEREP(ITER) = "FCY"
        ISORT = 3
    Endif

    If SZFIEREP(ITER) = "OBJCLL"
        ISORT = 4
    Endif

    If SZFIEREP(ITER) = "CLLDEL"
        ISORT = 5
    Endif

    If SZFIEREP(ITER) = "NSE"
        ISORT = 6
    Endif

    ISORTREP(ITER) = ISORT
Next

ISORT = 7

ITER = 0
For ITER = 0 To dim(SZTAGREP) - 1
    If ISORTREP(ITER) = 0
        ISORTREP(ITER) = ISORT
    Endif
    ISORT += 1
Next

Return

#########################################################
$REPEXCEPTION
  If SZFIE = "CREUSR" Then
    If [F:REP]CREUSR <> "" Then
      Read [AUS]CODUSR=[F:REP]CREUSR
      If !fstat Then
        SZBUFFTOFILL(0) = "(" + [F:AUS]USR + ")" - [F:AUS]NOMUSR
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Endif
Return

#########################################################
$XMLREP
  Gosub XMLREP From CRMEXCEPT2
Return

######################################################################
$HTMLREP
  #Représentant
  Call TEXTE(2929, SZHTMLTITLE) From OBJDIV
  Gosub DOSTARTTABLE From CRMXML140
  #On extrait les champs de la table
  For ITERSORT = 1 To 250
    For ISALESREP = 0 To dim(SZTAGREP)-1
      If SZTAGREP(ISALESREP) = "" Then
        Break
      Endif
      If IHIDEREP(ISALESREP) = 0 Then
        If ISORTREP(ISALESREP) = ITERSORT Then
          SZABR = "REP"
          SZFIE = SZFIEREP(ISALESREP)
          SZTABLE = "SALESREP"
          SZLABELFORFILL = SZLABELREP(ISALESREP)
          Gosub WRITEHTMLTR From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTABLE From CRMXML140
Return

######################################################################
# Relation Entité / Interlocuteurs
######################################################################
$SETCNTEXCEPT

#Tables de travail
If !clalev([F:CNT]) : Local File CONTACT [CNT] : Endif

#Tables pour gestion des exceptions
If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR
SZAOBEXPTAB = "CONTACT"
SZAOBEXPABR = "CNT"

Gosub SETAOBEXCEPT

Local Integer ICONTACT
ICONTACT = IAOBEXPCOUNT

ICONTACT += 1 #Pour la civilité, prénom et nom
Local Char SZTAGCNT(30)(ICONTACT)
Local Char SZFIECNT(30)(ICONTACT)
Local Integer IHIDECNT(ICONTACT)
Local Integer ISORTCNT(ICONTACT)
Local Char SZLABELCNT(30)(ICONTACT)
Local Integer IDISPLAYCNT
IDISPLAYCNT = 1
Raz IHIDECNT
Raz ISORTCNT
Raz SZLABELCNT
ICONTACT = 0

Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB

For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")

    ITERDIM = 0
    For ITERDIM = 0 To IDIMCONTROL - 1
        SZTAGCNT(ICONTACT) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
        If ITERDIM = 0
            SZFIECNT(ICONTACT) = [F:ATZ]CODZONE
        Else
            SZFIECNT(ICONTACT) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif

        Call TEXTE([F:ATZ]NOLONG, SZLABELCNT(ICONTACT)) From OBJDIV

        ICONTACT += 1
    Next
Next

Filter [ATZ]

SZTAGCNT(ICONTACT) = "CCNFULNAM"
Call TEXTE(6253, SZLABELCNT(ICONTACT)) From OBJDIV   #Identité

IDIMCONTROL = dim(SZTAGCNT) - 1

#Définition des attributs
ITER = 0
For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETCNTHIDE
Next

#Attribut de tri
Gosub SETCNTSORT

#On vérifie les doublons possibles de tags
IDUPLICATE = 0
While 1
    IDUPLICATE = 0
    ITER = 0
    For ITER = 0 To IDIMCONTROL
        ITER2 = 0
        For ITER2 = 0 To IDIMCONTROL
            If ITER2 <> ITER
                If SZTAGCNT(ITER) <> ""
                    If SZTAGCNT(ITER2) <> ""
                        If SZTAGCNT(ITER2) = SZTAGCNT(ITER)
                            SZTAGCNT(ITER2) = SZTAGCNT(ITER2) + "X"
                            IDUPLICATE = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Next
        If IDUPLICATE : Break : Endif
    Next
    If IDUPLICATE = 0 : Break : Endif
Wend

#Modification de la présentation et du tri par point d'entrée
Gosub PE_AOBEXP From TRTCRMPE

Return

################################################
#Attribut de visibilité
################################################
$SETCNTHIDE
#Par défaut, chaque champ est visible
IHIDECNT(ITER) = 0

If SZFIECNT(ITER) = "BPATYP"
    IHIDECNT(ITER) = 1
Endif

If SZFIECNT(ITER) = "BPANUM"
    IHIDECNT(ITER) = 1
Endif

If SZFIECNT(ITER) = "EXPNUM"
    IHIDECNT(ITER) = 1
Endif

#Date création
If SZFIECNT(ITER) = "CREDAT"
    IHIDECNT(ITER) = 1
Endif

#Heure création
If SZFIECNT(ITER) = "CRETIM"
    IHIDECNT(ITER) = 1
Endif

#Opérateur création
If SZFIECNT(ITER) = "CREUSR"
    IHIDECNT(ITER) = 1
Endif

#Date modif
If SZFIECNT(ITER) = "UPDDAT"
    IHIDECNT(ITER) = 1
Endif

#Heure modif
If SZFIECNT(ITER) = "UPDTIM"
    IHIDECNT(ITER) = 1
Endif

#Opérateur modif
If SZFIECNT(ITER) = "UPDUSR"
    IHIDECNT(ITER) = 1
Endif

Return

################################################
#Attribut de tri
################################################
$SETCNTSORT
ISORT = 0

ITER = 0
For ITER = 0 To dim(SZTAGCNT) - 1
    ISORT = 0

    If SZFIECNT(ITER) = "CCNCRM"
        ISORT = 1
    Endif

    If SZTAGCNT(ITER) = "CCNFULNAM"
        ISORT = 2
    Endif

    If SZFIECNT(ITER) = "CNTFNC"
        ISORT = 3
    Endif

    If SZFIECNT(ITER) = "CNTSRV"
        ISORT = 4
    Endif

    If SZFIECNT(ITER) = "CNTMSS"
        ISORT = 5
    Endif

    If SZFIECNT(ITER) = "CNTFLG"
        ISORT = 6
    Endif

    If SZFIECNT(ITER) = "BPAADD"
        ISORT = 7
    Endif

    If SZFIECNT(ITER) = "TEL"
        ISORT = 8
    Endif

    If SZFIECNT(ITER) = "FAX"
        ISORT = 9
    Endif

    If SZFIECNT(ITER) = "WEB"
        ISORT = 10
    Endif

    ISORTCNT(ITER) = ISORT
Next

ISORT = 11

ITER = 0
For ITER = 0 To dim(SZTAGCNT) - 1
    If ISORTCNT(ITER) = 0
        ISORTCNT(ITER) = ISORT
    Endif
    ISORT += 1
Next

Return

#########################################################
$CNTEXCEPTION
  If SZFIE = "CREUSR" Then
    If [F:CNT]CREUSR <> "" Then
      Read [AUS]CODUSR=[F:CNT]CREUSR
      If !fstat Then
        SZBUFFTOFILL(0) = "(" + [F:AUS]USR + ")" - [F:AUS]NOMUSR
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Endif
Return

#########################################################
$XMLCNT
  Gosub XMLCNT From CRMEXCEPT2
Return

######################################################################
$HTMLCNT
  #Interlocuteur
  Call TEXTE(10981, SZHTMLTITLE) From OBJDIV
  Gosub DOSTARTTABLE From CRMXML140
  #On extrait les champs de la table
  For ITERSORT = 1 To 250
    For ICONTACT = 0 To dim(SZTAGCNT)-1
      If SZTAGCNT(ICONTACT) = "" Then
        Break
      Endif
      If IHIDECNT(ICONTACT) = 0 Then
        If ISORTCNT(ICONTACT) = ITERSORT Then
          If SZTAGCNT(ICONTACT) = "CCNFULNAM" Then
            Read [AIN]AIN0=[F:CNT]CCNCRM
            If !fstat Then
              Call BUILDFULNAM("AIN", SZDATAFORFILL) From CRMUTIL140
              SZLABELFORFILL = SZLABELCNT(ICONTACT)
              Gosub WRITEHTMLTR From CRMXML140
            Endif
          Else
            SZABR = "CNT"
            SZFIE = SZFIECNT(ICONTACT)
            SZTABLE = "CONTACT"
            SZLABELFORFILL = SZLABELCNT(ICONTACT)
            Gosub WRITEHTMLTR From CRMXML140
          Endif
        Endif
      Endif
    Next
  Next
  Gosub DOENDTABLE From CRMXML140
Return

######################################################################
# Parc client
######################################################################
$SETMACEXCEPT

#Tables de travail
If !clalev([F:MAC]) : Local File MACHINES [MAC] : Endif

#Tables pour gestion des exceptions
If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR
SZAOBEXPTAB = "MACHINES"
SZAOBEXPABR = "MAC"

Gosub SETAOBEXCEPT

Local Integer IMACHINES
IMACHINES = IAOBEXPCOUNT

Local Char SZTAGMAC(30)(IMACHINES)
Local Char SZFIEMAC(30)(IMACHINES)
Local Integer IHIDEMAC(IMACHINES)
Local Integer ISORTMAC(IMACHINES)
Local Char SZLABELMAC(30)(IMACHINES)
Local Integer IDISPLAYMAC
IDISPLAYMAC = 1
Raz IHIDEMAC
Raz ISORTMAC
Raz SZLABELMAC
IMACHINES = 0

Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB

For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")

    ITERDIM = 0
    For ITERDIM = 0 To IDIMCONTROL - 1
        SZTAGMAC(IMACHINES) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
        If ITERDIM = 0
            SZFIEMAC(IMACHINES) = [F:ATZ]CODZONE
        Else
            SZFIEMAC(IMACHINES) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif

        Call TEXTE([F:ATZ]NOLONG, SZLABELMAC(IMACHINES)) From OBJDIV

        IMACHINES += 1
    Next
Next

Filter [ATZ]

IDIMCONTROL = dim(SZTAGMAC) - 1

#Définition des attributs
ITER = 0
For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETMACHIDE
Next

#Attribut de tri
Gosub SETMACSORT

#On vérifie les doublons possibles de tags
IDUPLICATE = 0
While 1
    IDUPLICATE = 0
    ITER = 0
    For ITER = 0 To IDIMCONTROL
        ITER2 = 0
        For ITER2 = 0 To IDIMCONTROL
            If ITER2 <> ITER
                If SZTAGMAC(ITER) <> ""
                    If SZTAGMAC(ITER2) <> ""
                        If SZTAGMAC(ITER2) = SZTAGMAC(ITER)
                            SZTAGMAC(ITER2) = SZTAGMAC(ITER2) + "X"
                            IDUPLICATE = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Next
        If IDUPLICATE : Break : Endif
    Next
    If IDUPLICATE = 0 : Break : Endif
Wend

#Modification de la présentation et du tri par point d'entrée
Gosub PE_AOBEXP From TRTCRMPE

Return

################################################
#Attribut de visibilité
################################################
$SETMACHIDE
#Par défaut, chaque champ est visible
IHIDEMAC(ITER) = 0

If SZFIEMAC(ITER) = "MACBRACLA"
    IHIDEMAC(ITER) = 1
Endif

If SZFIEMAC(ITER) = "MACDES"
    IHIDEMAC(ITER) = 1
Endif

If SZFIEMAC(ITER) = "BPCNUM"
    IHIDEMAC(ITER) = 1
Endif

If SZFIEMAC(ITER) = "CCNNUM"
    IHIDEMAC(ITER) = 1
Endif

If SZFIEMAC(ITER) = "MACORI"
    IHIDEMAC(ITER) = 1
Endif

If SZFIEMAC(ITER) = "PREORI"
    IHIDEMAC(ITER) = 1
Endif

If SZFIEMAC(ITER) = "PREORIVCR"
    IHIDEMAC(ITER) = 1
Endif

If SZFIEMAC(ITER) = "PREORIVCRL"
    IHIDEMAC(ITER) = 1
Endif

#Date modif
If SZFIEMAC(ITER) = "UPDDAT"
    IHIDEMAC(ITER) = 1
Endif

#Opérateur modif
If SZFIEMAC(ITER) = "UPDUSR"
    IHIDEMAC(ITER) = 1
Endif

Return

################################################
