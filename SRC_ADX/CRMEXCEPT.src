#########################################################
$SREEXCEPTION
Local Char SZDES(GLONDCO)   # FGR 23/09/2009 : X3SUIVI58037

  If SZFIE = "SRECCN" Then
    #Interlocuteur
    If [F:SRE]SRECCN <> "" Then
      Read [AIN]AIN0=[F:SRE]SRECCN
      If !fstat Then
        Call BUILDFULNAM("AIN", SZBUFFTOFILL(0)) From CRMUTIL140
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Elsif SZFIE = "SREDET" Then
    #Affectation en clair
    If [F:SRE]SREDET <> "" Then
      Case [F:SRE]SREASS
        When 1
          Read [FCY]FCY0=[F:SRE]SREDET
          If !fstat Then
            SZBUFFTOFILL(0) = "(" + [F:SRE]SREDET + ")" - [F:FCY]FCYNAM
            IRUNBYEXCEPTION = 1
          Endif
        When 2
          Read [AUS]CODUSR=[F:SRE]SREDET
          If !fstat Then
            SZBUFFTOFILL(0) = "(" + [F:SRE]SREDET + ")" - [F:AUS]NOMUSR
            IRUNBYEXCEPTION = 1
          Endif
        When 3
          Read [QUE]QUE0=[F:SRE]SREDET
          If !fstat Then
            # FGR 23/09/2009 : X3SUIVI58037
            #SZBUFFTOFILL(0) = "(" + [F:SRE]SREDET + ")" - [F:QUE]TTR
            Call LECTEXTRA(SZDES,"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
            SZBUFFTOFILL(0) = "(" + [F:SRE]SREDET + ")" - SZDES
            IRUNBYEXCEPTION = 1
          Endif
        When Default
      Endcase
    Endif
  Elsif SZFIE = "CREUSR" Then
    If [F:SRE]CREUSR <> "" Then
      Read [AUS]CODUSR=[F:SRE]CREUSR
      If !fstat Then
        SZBUFFTOFILL(0) = "(" + [F:AUS]USR + ")" - [F:AUS]NOMUSR
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Endif
Return

