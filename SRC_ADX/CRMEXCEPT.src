    If SZFIEAIN(ITER) = "CNTBIR"
        ISORT = 10
    Endif

    If SZFIEAIN(ITER) = "CNTCSP"
        ISORT = 11
    Endif

    ISORTAIN(ITER) = ISORT
Next

ISORT = 12

