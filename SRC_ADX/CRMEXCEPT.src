#########################################################
$XMLMAC
  Gosub XMLMAC From CRMEXCEPT2
Return

######################################################################
$HTMLMAC
  #Parc
  Call TEXTE(16568, SZHTMLTITLE) From OBJDIV
  Gosub DOSTARTTABLE From CRMXML140
  #On extrait les champs de la table
  For ITERSORT = 1 To 250
    For IMACHINES = 0 To dim(SZTAGMAC)-1
      If SZTAGMAC(IMACHINES) = "" Then
        Break
      Endif
      If IHIDEMAC(IMACHINES) = 0 Then
        If ISORTMAC(IMACHINES) = ITERSORT Then
          SZABR = "MAC"
          SZFIE = SZFIEMAC(IMACHINES)
          SZTABLE = "MACHINES"
          SZLABELFORFILL = SZLABELMAC(IMACHINES)
          Gosub WRITEHTMLTR From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTABLE From CRMXML140
Return

######################################################################
# Secteur de marché
######################################################################
$SETMSTEXCEPT

#Tables de travail
If !clalev([F:MST]) : Local File MARSCT [MST] : Endif
If !clalev([F:HD6]) : Local File HD6CLOB [HD6] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR
SZAOBEXPTAB = "MARSCT"
SZAOBEXPABR = "MST"

Gosub SETAOBEXCEPT

Local Integer IMARSCT
IMARSCT = IAOBEXPCOUNT

IMARSCT += 1 #Pour les clobs
Local Char SZTAGMST(30)(IMARSCT)
Local Char SZFIEMST(30)(IMARSCT)
Local Integer IHIDEMST(IMARSCT)
Local Integer ISORTMST(IMARSCT)
Local Char SZLABELMST(30)(IMARSCT)
Local Integer IDISPLAYMST
IDISPLAYMST = 1
Raz IHIDEMST
Raz ISORTMST
Raz SZLABELMST
IMARSCT = 0

Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB

For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")

    ITERDIM = 0
    For ITERDIM = 0 To IDIMCONTROL - 1
        SZTAGMST(IMARSCT) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
        If ITERDIM = 0
            SZFIEMST(IMARSCT) = [F:ATZ]CODZONE
        Else
            SZFIEMST(IMARSCT) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif

        Call TEXTE([F:ATZ]NOLONG, SZLABELMST(IMARSCT)) From OBJDIV

        IMARSCT += 1
    Next
Next

Filter [ATZ]

SZTAGMST(IMARSCT) = "MSTHD6CLOB0"
Call TEXTE(6468, SZLABELMST(IMARSCT)) From OBJDIV   #Description

IDIMCONTROL = dim(SZTAGMST) - 1

#Définition des attributs
ITER = 0
For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETMSTHIDE
Next

#Attribut de tri
Gosub SETMSTSORT

#On vérifie les doublons possibles de tags
IDUPLICATE = 0
While 1
    IDUPLICATE = 0
    ITER = 0
    For ITER = 0 To IDIMCONTROL
        ITER2 = 0
        For ITER2 = 0 To IDIMCONTROL
            If ITER2 <> ITER
                If SZTAGMST(ITER) <> ""
                    If SZTAGMST(ITER2) <> ""
                        If SZTAGMST(ITER2) = SZTAGMST(ITER)
                            SZTAGMST(ITER2) = SZTAGMST(ITER2) + "X"
                            IDUPLICATE = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Next
        If IDUPLICATE : Break : Endif
    Next
    If IDUPLICATE = 0 : Break : Endif
Wend

#Dimensionnement des buffers clobs
Local Integer I6LNGCLOB
Local Integer I6NBBYTES
Local Integer I6BUFFSIZE

#Complément d'informations
Read [ATY] CODTYP = "HD6"
If fstat
    I6LNGCLOB = 3
Else
    I6LNGCLOB = [F:ATY]LNGTYP
Endif

If I6LNGCLOB = 0
    I6LNGCLOB = 3
Endif

I6NBBYTES = 1024*(2^I6LNGCLOB)
I6BUFFSIZE = I6NBBYTES / 35
I6BUFFSIZE += 5
Local Char SZDESCLOBMST(35)(I6BUFFSIZE)

#Modification de la présentation et du tri par point d'entrée
Gosub PE_AOBEXP From TRTCRMPE

Return

################################################
#Attribut de visibilité
################################################
$SETMSTHIDE
#Par défaut, chaque champ est visible
IHIDEMST(ITER) = 0

If SZFIEMST(ITER) = "TYPFULDES"
    IHIDEMST(ITER) = 1
Endif

If SZFIEMST(ITER) = "NUMFULDES"
    IHIDEMST(ITER) = 1
Endif

If SZFIEMST(ITER) = "MARSCTREP"
    IHIDEMST(ITER) = 1
Endif

If SZFIEMST(ITER) = "MARSCTREP(1)"
    IHIDEMST(ITER) = 1
Endif

If SZFIEMST(ITER) = "GRUDEF"
    IHIDEMST(ITER) = 1
Endif


Return

################################################
#Attribut de tri
################################################
$SETMSTSORT
  ISORT = 0
  ITER = 0
  For ITER = 0 To dim(SZTAGMST) - 1
    ISORT = 0
    Case SZFIEMST(ITER)
      When "MARSCTNUM"
        ISORT = 1
      When "MARSCTAXX"
        ISORT = 2
      When "MARSCTDES"
        ISORT = 3
      When "MSTHD6CLOB0"
        ISORT = 4
    Endcase
    ISORTMST(ITER) = ISORT
  Next
  ISORT = 5
  For ITER = 0 To dim(SZTAGMST)-1
    If ISORTMST(ITER) = 0 Then
      ISORTMST(ITER) = ISORT
    Endif
    ISORT += 1
  Next
Return

#########################################################
$MSTEXCEPTION
Return

#########################################################
$XMLMST
  Gosub XMLMST From CRMEXCEPT2
Return

#########################################################
$HTMLMST
Call TEXTE(18418, SZHTMLTITLE) From OBJDIV      #Secteur de marché

Gosub DOSTARTTABLE From CRMXML140

#On extrait les champs de la table
ITERSORT = 1
For ITERSORT = 1 To 250
    IMARSCT = 0
    For IMARSCT = 0 To dim(SZTAGMST) - 1
        If SZTAGMST(IMARSCT) = "" : Break : Endif

        If IHIDEMST(IMARSCT) = 0
            If ISORTMST(IMARSCT) = ITERSORT
                If SZTAGMST(IMARSCT) = "MSTHD6CLOB0"
                    #On extrait le clob Description
                    IMARSCT = dim(SZTAGMST) - 1
                    Raz SZBUFFTOFILL
                    If [F:MST]TYPFULDES <> ""
                        If [F:MST]NUMFULDES <> ""
                            Read [HD6]HD60=[F:MST]NUMFULDES;[F:MST]TYPFULDES
                            If !fstat
                                Raz SZDESCLOBMST
                                Setlob SZDESCLOBMST With [F:HD6]CLOB
                                If SZDESCLOBMST(0) <> ""
                                    SZLABELFORFILL = SZLABELMST(IMARSCT)
                                    Gosub ADDDEBTRCLOB From CRMXML140

                                    ITERCLOB = 0
                                    For ITERCLOB = 0 To dim(SZDESCLOBMST) - 1
                                        If SZDESCLOBMST(ITERCLOB) <> ""
                                            SZBUFFTOFILL(0) = SZDESCLOBMST(ITERCLOB)
                                            Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                                            Wrseq SZBUFFTOFILL(0) Using [FXML]
                                        Endif
                                    Next

                                    Gosub ADDENDTRCLOB From CRMXML140
                                Endif
                            Endif
                        Endif
                    Endif
                Else
                    SZABR = "MST"
                    SZFIE = SZFIEMST(IMARSCT)
                    SZTABLE = "MARSCT"
                    SZLABELFORFILL = SZLABELMST(IMARSCT)
                    Gosub WRITEHTMLTR From CRMXML140
                Endif
            Endif
        Endif
    Next
Next

Gosub DOENDTABLE From CRMXML140
Return

######################################################################
# Représentant secondaire
######################################################################
$SETRSEEXCEPT

#Tables de travail
If !clalev([F:RSE]) : Local File REPSEC [RSE] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR
SZAOBEXPTAB = "REPSEC"
SZAOBEXPABR = "RSE"

Gosub SETAOBEXCEPT

Local Integer IREPSEC
IREPSEC = IAOBEXPCOUNT

Local Char SZTAGRSE(30)(IREPSEC)
Local Char SZFIERSE(30)(IREPSEC)
Local Integer IHIDERSE(IREPSEC)
Local Integer ISORTRSE(IREPSEC)
Local Char SZLABELRSE(30)(IREPSEC)
Local Integer IDISPLAYRSE
IDISPLAYRSE = 1
Raz IHIDERSE
Raz ISORTRSE
Raz SZLABELRSE
IREPSEC = 0

Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB

For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")

    ITERDIM = 0
    For ITERDIM = 0 To IDIMCONTROL - 1
        SZTAGRSE(IREPSEC) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
        If ITERDIM = 0
            SZFIERSE(IREPSEC) = [F:ATZ]CODZONE
        Else
            SZFIERSE(IREPSEC) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif

        Call TEXTE([F:ATZ]NOLONG, SZLABELRSE(IREPSEC)) From OBJDIV

        IREPSEC += 1
    Next
Next

Filter [ATZ]

IDIMCONTROL = dim(SZTAGRSE) - 1

#Définition des attributs
ITER = 0
For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETRSEHIDE
Next

#Attribut de tri
Gosub SETRSESORT

#On vérifie les doublons possibles de tags
IDUPLICATE = 0
While 1
    IDUPLICATE = 0
    ITER = 0
    For ITER = 0 To IDIMCONTROL
        ITER2 = 0
        For ITER2 = 0 To IDIMCONTROL
            If ITER2 <> ITER
                If SZTAGRSE(ITER) <> ""
                    If SZTAGRSE(ITER2) <> ""
                        If SZTAGRSE(ITER2) = SZTAGRSE(ITER)
                            SZTAGRSE(ITER2) = SZTAGRSE(ITER2) + "X"
                            IDUPLICATE = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Next
        If IDUPLICATE : Break : Endif
    Next
    If IDUPLICATE = 0 : Break : Endif
Wend

#Modification de la présentation et du tri par point d'entrée
Gosub PE_AOBEXP From TRTCRMPE

Return

################################################
#Attribut de visibilité
################################################
$SETRSEHIDE
  #Par défaut, chaque champ est visible
  IHIDERSE(ITER) = 0
  If SZFIERSE(ITER) = "BPCNUM" Then
    IHIDERSE(ITER) = 1
  Elsif SZFIERSE(ITER) = "AUTASS" Then
    IHIDERSE(ITER) = 1
  Endif
Return

################################################
#Attribut de tri
################################################
$SETRSESORT
ISORT = 0

ITER = 0
For ITER = 0 To dim(SZTAGRSE) - 1
    ISORT = 0

    If SZFIERSE(ITER) = "REPNUM"
        ISORT = 1
    Endif

    If SZFIERSE(ITER) = "MSS"
        ISORT = 2
    Endif

    If SZFIERSE(ITER) = "GRPITM"
        ISORT = 3
    Endif

    ISORTRSE(ITER) = ISORT
Next

ISORT = 4

ITER = 0
For ITER = 0 To dim(SZTAGRSE) - 1
    If ISORTRSE(ITER) = 0
        ISORTRSE(ITER) = ISORT
    Endif
    ISORT += 1
Next

Return

#########################################################
$RSEEXCEPTION
Local Integer IADINUM

  If SZFIE = "MSS" Then
    #Rôle
    If [F:RSE]MSS <> "" Then
      Call GET_LIB(414, [F:RSE]MSS, SZBUFFTOFILL(0)) From CRM_UTIL
      IRUNBYEXCEPTION = 1
    Endif
  Elsif SZFIE = "GRPITM" Then
    #Famille de produit
    If [F:RSE]GRPITM <> "" Then
      IADINUM = 19 + GFAMCIA
      Call GET_LIB(IADINUM, [F:RSE]GRPITM, SZBUFFTOFILL(0)) From CRM_UTIL
      IRUNBYEXCEPTION = 1
    Endif
  Endif
Return

#########################################################
$XMLRSE
  Gosub XMLRSE From CRMEXCEPT2
Return

######################################################################
$HTMLRSE
  #Représentant secondaire
  SZHTMLTITLE = mess(94,177,1)
  Gosub DOSTARTTABLE From CRMXML140
  #On extrait les champs de la table
  For ITERSORT = 1 To 250
    For IREPSEC = 0 To dim(SZTAGRSE)-1
      If SZTAGRSE(IREPSEC) = "" Then
        Break
      Endif
      If IHIDERSE(IREPSEC) = 0 Then
        If ISORTRSE(IREPSEC) = ITERSORT Then
          SZABR = "RSE"
          SZFIE = SZFIERSE(IREPSEC)
          SZTABLE = "REPSEC"
          SZLABELFORFILL = SZLABELRSE(IREPSEC)
          Gosub WRITEHTMLTR From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTABLE From CRMXML140
Return

######################################################################
# Représentant secondaire (Secteur de marché)
######################################################################
$SETMAREXCEPT

#Tables de travail
If !clalev([F:MAR]) : Local File MARASSREP [MAR] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR
SZAOBEXPTAB = "MARASSREP"
SZAOBEXPABR = "MAR"

Gosub SETAOBEXCEPT

Local Integer IMARASSREP
IMARASSREP = IAOBEXPCOUNT

Local Char SZTAGMAR(30)(IMARASSREP)
Local Char SZFIEMAR(30)(IMARASSREP)
Local Integer IHIDEMAR(IMARASSREP)
Local Integer ISORTMAR(IMARASSREP)
Local Char SZLABELMAR(30)(IMARASSREP)
Local Integer IDISPLAYMAR
IDISPLAYMAR = 1
Raz IHIDEMAR
Raz ISORTMAR
Raz SZLABELMAR
IMARASSREP = 0

Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB

For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")

    ITERDIM = 0
    For ITERDIM = 0 To IDIMCONTROL - 1
        SZTAGMAR(IMARASSREP) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
        If ITERDIM = 0
            SZFIEMAR(IMARASSREP) = [F:ATZ]CODZONE
        Else
            SZFIEMAR(IMARASSREP) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif

        Call TEXTE([F:ATZ]NOLONG, SZLABELMAR(IMARASSREP)) From OBJDIV

        IMARASSREP += 1
    Next
Next

Filter [ATZ]

IDIMCONTROL = dim(SZTAGMAR) - 1

#Définition des attributs
ITER = 0
For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETMARHIDE
Next

#Attribut de tri
Gosub SETMARSORT

#On vérifie les doublons possibles de tags
IDUPLICATE = 0
While 1
    IDUPLICATE = 0
    ITER = 0
    For ITER = 0 To IDIMCONTROL
        ITER2 = 0
        For ITER2 = 0 To IDIMCONTROL
            If ITER2 <> ITER
                If SZTAGMAR(ITER) <> ""
                    If SZTAGMAR(ITER2) <> ""
                        If SZTAGMAR(ITER2) = SZTAGMAR(ITER)
                            SZTAGMAR(ITER2) = SZTAGMAR(ITER2) + "X"
                            IDUPLICATE = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Next
        If IDUPLICATE : Break : Endif
    Next
    If IDUPLICATE = 0 : Break : Endif
Wend

#Modification de la présentation et du tri par point d'entrée
Gosub PE_AOBEXP From TRTCRMPE

Return

################################################
#Attribut de visibilité
################################################
