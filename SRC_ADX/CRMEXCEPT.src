#<AdxTL>@(#)8.0.0.0 $Revision$
###############################################################################################################
#   Gestion des exceptions de présentation XML et HTML                                         Version 140
#   Module CRM
#
#   SETITNEXCEPT : Interventions
#   SETRRSEXCEPT : Réservations de ressources
#   SETHDTEXCEPT : Consommations
#   SETSRMEXCEPT : Parc concerné sur demande de service
#   SETSRNEXCEPT : Composant concerné sur demande de service
#   SETSREEXCEPT : Demande de service
#   SETBPREXCEPT : Tiers
#   SETBPCEXCEPT : Client
#   SETBPAEXCEPT : Adresse
#   SETMSTEXCEPT : Secteur de marché
#   SETREPEXCEPT : Représentant
#   SETRSEEXCEPT : Représentant secondaire
#   SETMAREXCEPT : Représentant secondaire affecté par secteur de marché
#   SETCNTEXCEPT : Relation Entité / Interlocuteur
#   SETMACEXCEPT : Parc client
#   SETSOLEXCEPT : Solution
#   SETOPPEXCEPT : Affaire
#   SETTSKEXCEPT : Tâche
#   SETCLLEXCEPT : Appel
#   SETCTTEXCEPT : Tentative d'appel
#   SETBAPEXCEPT : Rendez-vous
#   SETAINEXCEPT : Interlocuteur
#
###############################################################################################################

######################################################################
# Partie commune
######################################################################
$SETAOBEXCEPT
Local Integer IAOBEXPCOUNT
Local Integer IDIMCONTROL
Local Integer IDUPLICATE
Local Integer ITER
Local Integer ITER2
Local Integer ITERDIM
Local Integer ISORT

  If !clalev([F:ACV]) : Local File ACTIV [ACV] : Endif
  If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
  If !clalev([F:ADI]) : Local File ATABDIV [ADI] : Endif
  If !clalev([F:ATZ]) Then
    Local File ATABZON [ATZ]  Where [F:ATZ]CODZONE <> "CREDATTIM" and [F:ATZ]CODZONE <> "UPDDATTIM" and [F:ATZ]CODZONE <> "AUUID"
  Endif
  If !clalev([F:ATB]) : Local File ATABLE [ATB] : Endif
  If !clalev([F:AOB]) : Local File AOBJET [AOB] : Endif
  If !clalev([F:ATI]) : Local File ATABIND [ATI] : Endif
  IAOBEXPCOUNT = 0
  Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB
  For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")
    IAOBEXPCOUNT += IDIMCONTROL
  Next
  Filter [ATZ]
Return

######################################################################
#Interventions
######################################################################
$SETITNEXCEPT
  #Tables de travail
  If !clalev([F:ITN]) : Local File INTERVEN [ITN] : Endif
  If !clalev([F:HD2]) : Local File HD2CLOB [HD2] : Endif
  If !clalev([F:HD6]) : Local File HD6CLOB [HD6] : Endif
  #Tables pour gestion des exceptions
  If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif
  If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif
  If !clalev([F:TCY]) : Local File TABCOUNTRY [TCY] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR

  SZAOBEXPTAB = "INTERVEN"
  SZAOBEXPABR = "ITN"
  Gosub SETAOBEXCEPT

Local Integer IINTERVEN

  IINTERVEN = IAOBEXPCOUNT
  IINTERVEN += 2 #Pour les clobs

Local Char SZTAGITN(30)(IINTERVEN)
Local Char SZFIEITN(30)(IINTERVEN)
Local Integer IHIDEITN(IINTERVEN)
Local Integer ISORTITN(IINTERVEN)
Local Char SZLABELITN(30)(IINTERVEN)
Local Integer IDISPLAYITN

  IDISPLAYITN = 1
  Raz IHIDEITN
  Raz ISORTITN
  Raz SZLABELITN
  IINTERVEN = 0
  Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB
  For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")
    For ITERDIM = 0 To IDIMCONTROL-1
      SZTAGITN(IINTERVEN) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
      If ITERDIM = 0 Then
          SZFIEITN(IINTERVEN) = [F:ATZ]CODZONE
      Else
          SZFIEITN(IINTERVEN) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
      Endif
      Call TEXTE([F:ATZ]NOLONG, SZLABELITN(IINTERVEN)) From OBJDIV
      IINTERVEN += 1
    Next
  Next
  Filter [ATZ]
  SZTAGITN(IINTERVEN) = "ITNHD6CLOB0"
  Call TEXTE(17567, SZLABELITN(IINTERVEN)) From OBJDIV   #Complément d'information
  IINTERVEN += 1
  SZTAGITN(IINTERVEN) = "ITNHD2CLOB0"
  Call TEXTE(14438, SZLABELITN(IINTERVEN)) From OBJDIV   #Compte-rendu
  IDIMCONTROL = dim(SZTAGITN)-1
  #Définition des attributs
  For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETITNHIDE
  Next
  #Attribut de tri
  Gosub SETITNSORT
  #On vérifie les doublons possibles de tags
  IDUPLICATE = 0
  While 1
    IDUPLICATE = 0
      For ITER = 0 To IDIMCONTROL
        For ITER2 = 0 To IDIMCONTROL
          If ITER2 <> ITER Then
            If SZTAGITN(ITER) <> "" Then
              If SZTAGITN(ITER2) <> "" Then
                If SZTAGITN(ITER2) = SZTAGITN(ITER) Then
                  SZTAGITN(ITER2) = SZTAGITN(ITER2) + "X"
                  IDUPLICATE = 1
                  Break
                Endif
              Endif
            Endif
          Endif
        Next
        If IDUPLICATE Then
          Break
        Endif
    Next
    If IDUPLICATE = 0 Then
      Break
    Endif
  Wend

#Dimensionnement des buffers clobs
Local Integer I2LNGCLOB
Local Integer I2NBBYTES
Local Integer I2BUFFSIZE
Local Integer I6LNGCLOB
Local Integer I6NBBYTES
Local Integer I6BUFFSIZE

  #Complément d'informations
  Read [ATY]CODTYP="HD6"
  If fstat Then
    I6LNGCLOB = 3
  Else
    I6LNGCLOB = [F:ATY]LNGTYP
  Endif
  If I6LNGCLOB = 0 Then
    I6LNGCLOB = 3
  Endif
  I6NBBYTES = 1024*(2^I6LNGCLOB)
  I6BUFFSIZE = I6NBBYTES / 35
  I6BUFFSIZE += 5

Local Char SZOBJCLOBITN(35)(I6BUFFSIZE)

  #Compte-rendu
  Read [ATY]CODTYP="HD2"
  If fstat Then
    I2LNGCLOB = 6
  Else
    I2LNGCLOB = [F:ATY]LNGTYP
  Endif
  If I2LNGCLOB = 0 Then
    I2LNGCLOB = 6
  Endif
  I2NBBYTES = 1024*(2^I2LNGCLOB)
  I2BUFFSIZE = I2NBBYTES / 35
  I2BUFFSIZE += 5

Local Char SZRPOCLOBITN(35)(I2BUFFSIZE)

  #Modification de la présentation et du tri par point d'entrée
  Gosub PE_AOBEXP From TRTCRMPE
Return

################################################
#Attribut de visibilité
################################################
$SETITNHIDE
  #Par défaut, chaque champ est visible
  IHIDEITN(ITER) = 0
  Case SZFIEITN(ITER)
    When "DATX"
      #Conversion semaine
      IHIDEITN(ITER) = 1
    When"MAC"
      #Parc
      IHIDEITN(ITER) = 1
    When"MACGRU"
      #Regroupement
      IHIDEITN(ITER) = 1
    When"TYPFULOBJ"
      #Clob
      IHIDEITN(ITER) = 1
    When "NUMFULOBJ"
      #Clob
      IHIDEITN(ITER) = 1
    When "OBJFLG"
      #Clob
      IHIDEITN(ITER) = 1
    When "TIMSPG"
      #Temps passé
      IHIDEITN(ITER) = 1
    When "MANTIMFLG"
      #Saisie manuelle
      IHIDEITN(ITER) = 1
    When "SRVCONCOV"
      #Couverture
      IHIDEITN(ITER) = 1
    When "CONNUM"
      #Contrat
      IHIDEITN(ITER) = 1
    When "ORDNUM"
      #Commande
      IHIDEITN(ITER) = 1
    When "SCOAMT"
      #Montant sous-traité
      IHIDEITN(ITER) = 1
    When "CUR"
      #Devise
      IHIDEITN(ITER) = 1
    When "TYPFULRPO"
      #Clob
      IHIDEITN(ITER) = 1
    When "NUMFULRPO"
      #Clob
      IHIDEITN(ITER) = 1
    When "RPOFLG"
      #Synthèse
      IHIDEITN(ITER) = 1
    When "ITNTYPADD"
      #Adresses
      IHIDEITN(ITER) = 1
    When "ITNCODADD"
      #Adresses
      IHIDEITN(ITER) = 1
    When "ITNRECADD"
      #Adresses
      IHIDEITN(ITER) = 1
    When "ITNORI"
      #Origine
      IHIDEITN(ITER) = 1
    When "ITNORIVCR"
      #Origine
      IHIDEITN(ITER) = 1
    When "ITNORIVCRL"
      #Origine
      IHIDEITN(ITER) = 1
    When "UPDDAT"
      #Date modif
      IHIDEITN(ITER) = 1
    When "UPDUSR"
      #Opérateur modif
      IHIDEITN(ITER) = 1
    When Default
      #Réservations de ressources
      If left$(SZFIEITN(ITER), 3) = "RER"
        IHIDEITN(ITER) = 1
      Endif
  Endcase
Return

################################################
#Attribut de tri
################################################
$SETITNSORT
  ISORT = 0
  For ITER = 0 To dim(SZTAGITN)-1
    ISORT = 0
    Case SZFIEITN(ITER)
      When "NUM"
        ISORT = 1
      When "SALFCY"
        ISORT = 2
      When "SRVDEMNUM"
        ISORT = 3
      When "BPC"
        ISORT = 4
      When "CCN"
        ISORT = 5
      When "TYP"
        ISORT = 6
      When "DAT"
        ISORT = 7
      When "HOU"
        ISORT = 8
      When "DATEND"
        ISORT = 9
      When "HOUEND"
        ISORT = 10
      When "FULDAY"
        ISORT = 11
      When "WEE"
        ISORT = 12
      When "DUR"
        ISORT = 13
      When "OBJ"
        ISORT = 14
      When "SCO"
        ISORT = 16
      When "SCONUM"
        ISORT = 17
      When "REP"
        ISORT = 18
      When "ADD"
        ISORT = 19
      When "ADD(1)"
        ISORT = 20
      When "ADD(2)"
        ISORT = 21
      When "ZIP"
        ISORT = 22
      When "CTY"
        ISORT = 23
      When "SAT"
        ISORT = 24
      When "CRY"
        ISORT = 25
      When "TEL"
        ISORT = 26
      When "IFFADD"
        ISORT = 27
      When "DTCKIL"
        ISORT = 28
      When "TRITIM"
        ISORT = 29
      When "DON"
        ISORT = 30
      When "RPO"
        ISORT = 31
      When "PBLSOL"
        ISORT = 33
      When "HTOTTIMSPG"
        ISORT = 34
      When "MTOTTIMSPG"
        ISORT = 35
      When Default
        If SZTAGITN(ITER) = "ITNHD6CLOB0" Then
          ISORT = 15
        Elsif SZTAGITN(ITER) = "ITNHD2CLOB0" Then
          ISORT = 32
        Endif
    Endcase
    ISORTITN(ITER) = ISORT
  Next
  ISORT = 36
  For ITER = 0 To dim(SZTAGITN)-1
    If ISORTITN(ITER) = 0 Then
      ISORTITN(ITER) = ISORT
    Endif
    ISORT += 1
  Next
Return

#########################################################
$ITNEXCEPTION
  If SZFIE = "CCN" Then
    #Interlocuteur
    If [F:ITN]CCN <> "" Then
      Read [AIN]AIN0=[F:ITN]CCN
      If !fstat Then
        Call BUILDFULNAM("AIN", SZBUFFTOFILL(0)) From CRMUTIL140
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Elsif SZFIE = "REP" Then
    If [F:ITN]REP <> "" Then
      Read [AUS]CODUSR=[F:ITN]REP
      If !fstat Then
        SZBUFFTOFILL(0) = "(" + [F:AUS]USR + ")" - [F:AUS]NOMUSR
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Elsif SZFIE = "SCONUM" Then
    If [F:ITN]SCONUM <> "" Then
      Read [BPR]BPR0=[F:ITN]SCONUM
      If !fstat Then
        SZBUFFTOFILL(0) = "(" + [F:BPR]BPRNUM + ")" - [F:BPR]BPRNAM
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Elsif SZFIE = "CRY" Then
    If [F:ITN]CRY <> "" Then
      Read [TCY]TCY0=[F:ITN]CRY
      If !fstat Then
        Call LECTEXTRA(SZBUFFTOFILL(0),"TABCOUNTRY","CRYDES",[F:ITN]CRY,"") From ATEXTRA
        SZBUFFTOFILL(0) = "(" + [F:TCY]CRY + ")" - SZBUFFTOFILL(0)
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Elsif SZFIE = "CREUSR" Then
    If [F:ITN]CREUSR <> "" Then
      Read [AUS]CODUSR=[F:ITN]CREUSR
      If !fstat Then
        SZBUFFTOFILL(0) = "(" + [F:AUS]USR + ")" - [F:AUS]NOMUSR
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Endif
Return

#########################################################
$XMLITN
  Gosub XMLITN From CRMEXCEPT2
Return

#########################################################
$HTMLITN
  Call TEXTE(14563, SZHTMLTITLE) From OBJDIV      #Intervention
  Gosub DOSTARTTABLE From CRMXML140
  #On extrait les champs de la table INTERVEN
  For ITERSORT = 1 To 250
    For IINTERVEN = 0 To dim(SZTAGITN)-1
      If SZTAGITN(IINTERVEN) = ""  Then
        Break
      Endif
      If IHIDEITN(IINTERVEN) = 0 Then
        If ISORTITN(IINTERVEN) = ITERSORT Then
          Case SZTAGITN(IINTERVEN)
            When "ITNHD6CLOB0"
              #On extrait le clob Complément d'informations
              IINTERVEN = dim(SZTAGITN) - 2
              Raz SZBUFFTOFILL
              If [F:ITN]TYPFULOBJ <> "" Then
                If [F:ITN]NUMFULOBJ <> "" Then
                  Read [HD6]HD60=[F:ITN]NUMFULOBJ;[F:ITN]TYPFULOBJ
                  If !fstat Then
                    Raz SZOBJCLOBITN
                    Setlob SZOBJCLOBITN With [F:HD6]CLOB
                    If SZOBJCLOBITN(0) <> "" Then
                      SZLABELFORFILL = SZLABELITN(IINTERVEN)
                      Gosub ADDDEBTRCLOB From CRMXML140
                      For ITERCLOB = 0 To dim(SZOBJCLOBITN)-1
                        If SZOBJCLOBITN(ITERCLOB) <> "" Then
                          SZBUFFTOFILL(0) = SZOBJCLOBITN(ITERCLOB)
                          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                          Wrseq SZBUFFTOFILL(0) Using [FXML]
                        Endif
                      Next
                      Gosub ADDENDTRCLOB From CRMXML140
                    Endif
                  Endif
                Endif
              Endif
            When "ITNHD2CLOB0"
              #On extrait le clob Compte-rendu
              IINTERVEN = dim(SZFIEITN) - 1
              Raz SZBUFFTOFILL
              If [F:ITN]TYPFULRPO <> "" Then
                If [F:ITN]NUMFULRPO <> "" Then
                  Read [HD2]HD20=[F:ITN]NUMFULRPO;[F:ITN]TYPFULRPO
                  If !fstat Then
                    Raz SZRPOCLOBITN
                    Setlob SZRPOCLOBITN With [F:HD2]CLOB
                    If SZRPOCLOBITN(0) <> "" Then
                      SZLABELFORFILL = SZLABELITN(IINTERVEN)
                      Gosub ADDDEBTRCLOB From CRMXML140
                      For ITERCLOB = 0 To dim(SZRPOCLOBITN)-1
                        If SZRPOCLOBITN(ITERCLOB) <> "" Then
                          SZBUFFTOFILL(0) = SZRPOCLOBITN(ITERCLOB)
                          Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                          Wrseq SZBUFFTOFILL(0) Using [FXML]
                        Endif
                      Next
                      Gosub ADDENDTRCLOB From CRMXML140
                    Endif
                  Endif
                Endif
              Endif
            When Default
              SZABR = "ITN"
              SZFIE = SZFIEITN(IINTERVEN)
              SZTABLE = "INTERVEN"
              SZLABELFORFILL = SZLABELITN(IINTERVEN)
              Gosub WRITEHTMLTR From CRMXML140
          Endcase
        Endif
      Endif
    Next
  Next
  Gosub DOENDTABLE From CRMXML140
Return

######################################################################
#Réservations de ressources
######################################################################
$SETRRSEXCEPT
Local Char SZAOBEXPTAB(GLONATB)
Local Char SZAOBEXPABR(GLONABR)
Local Integer IRESRES
Local Integer IDISPLAYRRS

  If !clalev([F:RRS]) : Local File RESRES [RRS] : Endif
  SZAOBEXPTAB = "RESRES"
  SZAOBEXPABR = "RRS"
  Gosub SETAOBEXCEPT
  IRESRES = IAOBEXPCOUNT

Local Char SZTAGRRS(30)(IRESRES)
Local Char SZFIERRS(30)(IRESRES)
Local Integer IHIDERRS(IRESRES)
Local Integer ISORTRRS(IRESRES)
Local Char SZLABELRRS(30)(IRESRES)

  IDISPLAYRRS = 1
  Raz IHIDERRS
  Raz ISORTRRS
  Raz SZLABELRRS
  IRESRES = 0
  Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB
  For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")
    For ITERDIM = 0 To IDIMCONTROL-1
      SZTAGRRS(IRESRES) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
      If ITERDIM = 0 Then
        SZFIERRS(IRESRES) = [F:ATZ]CODZONE
      Else
        SZFIERRS(IRESRES) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
      Endif
      Call TEXTE([F:ATZ]NOLONG, SZLABELRRS(IRESRES)) From OBJDIV
      IRESRES += 1
    Next
  Next
  Filter [ATZ]
  IDIMCONTROL = dim(SZTAGRRS)-1
  #Définition des attributs
  For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETRRSHIDE
  Next
  #Attribut de tri
  Gosub SETRRSSORT
  #On vérifie les doublons possibles de tags
  IDUPLICATE = 0
  While 1
    IDUPLICATE = 0
    For ITER = 0 To IDIMCONTROL
      For ITER2 = 0 To IDIMCONTROL
        If ITER2 <> ITER Then
          If SZTAGRRS(ITER) <> "" Then
            If SZTAGRRS(ITER2) <> "" Then
              If SZTAGRRS(ITER2) = SZTAGRRS(ITER) Then
                SZTAGRRS(ITER2) = SZTAGRRS(ITER2) + "X"
                IDUPLICATE = 1
                Break
              Endif
            Endif
          Endif
        Endif
      Next
      If IDUPLICATE Then
        Break
      Endif
    Next
    If IDUPLICATE = 0 Then
      Break
    Endif
  Wend
  #Modification de la présentation et du tri par point d'entrée
  Gosub PE_AOBEXP From TRTCRMPE
Return

################################################
#Attribut de visibilité
################################################
$SETRRSHIDE
  #Par défaut, chaque champ est visible
  IHIDERRS(ITER) = 0
  Case SZFIERRS(ITER)
    When "CRESNC"
      #Réservé depuis le
      IHIDERRS(ITER) = 1
    When "RRSORI"
      #Origine
      IHIDERRS(ITER) = 1
    When "RRSORIVCR"
      #Origine
      IHIDERRS(ITER) = 1
    When "RRSORIVCRL"
      #Origine
      IHIDERRS(ITER) = 1
    When "UPDDAT"
      #Date modif
      IHIDERRS(ITER) = 1
    When "UPDUSR"
      #Opérateur modif
      IHIDERRS(ITER) = 1
  Endcase
Return

################################################
#Attribut de tri
################################################
$SETRRSSORT
  ISORT = 0
  For ITER = 0 To dim(SZTAGRRS) - 1
    ISORT = 0
    Case SZFIERRS(ITER)
      When "NUM"
        ISORT = 1
      When "RSSNUM"
        ISORT = 2
      When "RSSCATCLA"
        ISORT = 3
      When "RSSTTR"
        ISORT = 4
      When "RERDAT"
        ISORT = 5
      When "HOUSTR"
        ISORT = 6
      When "RERDATEND"
        ISORT = 7
      When "HOUEND"
        ISORT = 8
      When "RERREP"
        ISORT = 9
    Endcase
    ISORTRRS(ITER) = ISORT
  Next
  ISORT = 10
  For ITER = 0 To dim(SZTAGRRS)-1
    If ISORTRRS(ITER) = 0 Then
      ISORTRRS(ITER) = ISORT
    Endif
    ISORT += 1
  Next
Return

#########################################################
$RRSEXCEPTION
Return

#########################################################
$XMLRRS
  Gosub XMLRRS From CRMEXCEPT2
Return

#########################################################
$HTMLRRS
  Call TEXTE(24749, SZHTMLTITLE) From OBJDIV      #Ressource réservée
  Gosub DOSTARTTABLE From CRMXML140
  #On extrait les champs de la table
  For ITERSORT = 1 To 250
    For IRESRES = 0 To dim(SZTAGRRS)-1
      If SZTAGRRS(IRESRES) = "" Then
        Break
      Endif
      If IHIDERRS(IRESRES) = 0 Then
        If ISORTRRS(IRESRES) = ITERSORT Then
          SZABR = "RRS"
          SZFIE = SZFIERRS(IRESRES)
          SZTABLE = "RESRES"
          SZLABELFORFILL = SZLABELRRS(IRESRES)
          Gosub WRITEHTMLTR From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTABLE From CRMXML140
Return

######################################################################
#Consommations
######################################################################
$SETHDTEXCEPT

#Tables de travail
If !clalev([F:HDT]) : Local File HDKTASK [HDT] : Endif
If !clalev([F:TXC]) : Local File TEXCLOB [TXC] : Endif

#Tables pour gestion des exceptions
If !clalev([F:BPR]) : Local File BPARTNER [BPR] : Endif
If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR
SZAOBEXPTAB = "HDKTASK"
SZAOBEXPABR = "HDT"

Gosub SETAOBEXCEPT

Local Integer IHDKTASK
IHDKTASK = IAOBEXPCOUNT

#Effectué / Non effectué
Local Integer IHDTDON
IHDTDON = 1

IHDKTASK += 1 #Pour les clobs
Local Char SZTAGHDT(30)(IHDKTASK)
Local Char SZFIEHDT(30)(IHDKTASK)
Local Integer IHIDEHDT(IHDKTASK)
Local Integer ISORTHDT(IHDKTASK)
Local Char SZLABELHDT(30)(IHDKTASK)
Local Integer IDISPLAYHDT
IDISPLAYHDT = 1
Raz IHIDEHDT
Raz ISORTHDT
Raz SZLABELHDT
IHDKTASK = 0

Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB

For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")

    ITERDIM = 0
    For ITERDIM = 0 To IDIMCONTROL - 1
        SZTAGHDT(IHDKTASK) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
        If ITERDIM = 0
            SZFIEHDT(IHDKTASK) = [F:ATZ]CODZONE
        Else
            SZFIEHDT(IHDKTASK) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif

        Call TEXTE([F:ATZ]NOLONG, SZLABELHDT(IHDKTASK)) From OBJDIV

        IHDKTASK += 1
    Next
Next

Filter [ATZ]

SZTAGHDT(IHDKTASK) = "HDTACBCLOB0"
Call TEXTE(4685, SZLABELHDT(IHDKTASK)) From OBJDIV   #Texte

IDIMCONTROL = dim(SZTAGHDT) - 1

#Définition des attributs
ITER = 0
For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETHDTHIDE
Next

#Attribut de tri
Gosub SETHDTSORT

#On vérifie les doublons possibles de tags
IDUPLICATE = 0
While 1
    IDUPLICATE = 0
    ITER = 0
    For ITER = 0 To IDIMCONTROL
        ITER2 = 0
        For ITER2 = 0 To IDIMCONTROL
            If ITER2 <> ITER
                If SZTAGHDT(ITER) <> ""
                    If SZTAGHDT(ITER2) <> ""
                        If SZTAGHDT(ITER2) = SZTAGHDT(ITER)
                            SZTAGHDT(ITER2) = SZTAGHDT(ITER2) + "X"
                            IDUPLICATE = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Next
        If IDUPLICATE : Break : Endif
    Next
    If IDUPLICATE = 0 : Break : Endif
Wend

#Dimensionnement des buffers clobs
Local Integer I0LNGCLOB
Local Integer I0NBBYTES
Local Integer I0BUFFSIZE

#Texte
Read [ATY] CODTYP = "ACB"
If fstat
    I0LNGCLOB = 6
Else
    I0LNGCLOB = [F:ATY]LNGTYP
Endif

If I0LNGCLOB = 0
    I0LNGCLOB = 6
Endif

I0NBBYTES = 1024*(2^I0LNGCLOB)
I0BUFFSIZE = I0NBBYTES / 35
I0BUFFSIZE += 5
Local Char SZACBCLOBHDT(35)(I0BUFFSIZE)

#Modification de la présentation et du tri par point d'entrée
Gosub PE_AOBEXP From TRTCRMPE

Return

################################################
#Attribut de visibilité
