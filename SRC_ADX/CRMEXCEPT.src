#Attribut de visibilité
################################################
$SETCLLHIDE
#Par défaut, chaque champ est visible
IHIDECLL(ITER) = 0

#Clob
If SZFIECLL(ITER) = "TYPFULOBJ"
    IHIDECLL(ITER) = 1
