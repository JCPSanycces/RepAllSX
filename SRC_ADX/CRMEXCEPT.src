#########################################################
$HTMLCTT
  Call TEXTE(14505, SZHTMLTITLE) From OBJDIV      #Tentative d'appel
  Gosub DOSTARTTABLE From CRMXML140
  #On extrait les champs de la table
  For ITERSORT = 1 To 250
    For ICALLATTEMP = 0 To dim(SZTAGCTT)-1
      If SZTAGCTT(ICALLATTEMP) = "" Then
        Break
      Endif
      If IHIDECTT(ICALLATTEMP) = 0 Then
        If ISORTCTT(ICALLATTEMP) = ITERSORT Then
          SZABR = "CTT"
          SZFIE = SZFIECTT(ICALLATTEMP)
          SZTABLE = "CALLATTEMP"
          SZLABELFORFILL = SZLABELCTT(ICALLATTEMP)
          Gosub WRITEHTMLTR From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTABLE From CRMXML140
Return

######################################################################
# Interlocuteur
######################################################################
$SETAINEXCEPT

If !clalev([F:AIN]) : Local File CONTACTCRM [AIN] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR
SZAOBEXPTAB = "CONTACTCRM"
SZAOBEXPABR = "AIN"

Gosub SETAOBEXCEPT

Local Integer ICONTACTCRM
ICONTACTCRM = IAOBEXPCOUNT

Local Char SZTAGAIN(30)(ICONTACTCRM)
Local Char SZFIEAIN(30)(ICONTACTCRM)
Local Integer IHIDEAIN(ICONTACTCRM)
Local Integer ISORTAIN(ICONTACTCRM)
Local Char SZLABELAIN(30)(ICONTACTCRM)
Local Integer IDISPLAYAIN
IDISPLAYAIN = 1
Raz IHIDEAIN
Raz ISORTAIN
Raz SZLABELAIN
ICONTACTCRM = 0

Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB

For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")

    ITERDIM = 0
    For ITERDIM = 0 To IDIMCONTROL - 1
        SZTAGAIN(ICONTACTCRM) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
        If ITERDIM = 0
            SZFIEAIN(ICONTACTCRM) = [F:ATZ]CODZONE
        Else
            SZFIEAIN(ICONTACTCRM) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif

        Call TEXTE([F:ATZ]NOLONG, SZLABELAIN(ICONTACTCRM)) From OBJDIV

        ICONTACTCRM += 1
    Next
Next

Filter [ATZ]

IDIMCONTROL = dim(SZTAGAIN) - 1

#Définition des attributs
ITER = 0
For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETAINHIDE
Next

#Attribut de tri
Gosub SETAINSORT

#On vérifie les doublons possibles de tags
IDUPLICATE = 0
While 1
    IDUPLICATE = 0
    ITER = 0
    For ITER = 0 To IDIMCONTROL
        ITER2 = 0
        For ITER2 = 0 To IDIMCONTROL
            If ITER2 <> ITER
                If SZTAGAIN(ITER) <> ""
                    If SZTAGAIN(ITER2) <> ""
                        If SZTAGAIN(ITER2) = SZTAGAIN(ITER)
                            SZTAGAIN(ITER2) = SZTAGAIN(ITER2) + "X"
                            IDUPLICATE = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Next
        If IDUPLICATE : Break : Endif
    Next
    If IDUPLICATE = 0 : Break : Endif
Wend

#Modification de la présentation et du tri par point d'entrée
Gosub PE_AOBEXP From TRTCRMPE

Return

