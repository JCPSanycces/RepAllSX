$SETBPCEXCEPT

#Tables de travail
If !clalev([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif

#Tables pour gestion des exceptions
If !clalev([F:AUS]) : Local File AUTILIS [AUS] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR
SZAOBEXPTAB = "BPCUSTOMER"
SZAOBEXPABR = "BPC"

Gosub SETAOBEXCEPT

Local Integer IBPCUSTOMER
IBPCUSTOMER = IAOBEXPCOUNT

Local Char SZTAGBPC(30)(IBPCUSTOMER)
Local Char SZFIEBPC(30)(IBPCUSTOMER)
Local Integer IHIDEBPC(IBPCUSTOMER)
Local Integer ISORTBPC(IBPCUSTOMER)
Local Char SZLABELBPC(30)(IBPCUSTOMER)
Local Integer IDISPLAYBPC
IDISPLAYBPC = 1
Raz IHIDEBPC
Raz ISORTBPC
Raz SZLABELBPC
IBPCUSTOMER = 0

Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB

For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")

    ITERDIM = 0
    For ITERDIM = 0 To IDIMCONTROL - 1
        SZTAGBPC(IBPCUSTOMER) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
        If ITERDIM = 0
            SZFIEBPC(IBPCUSTOMER) = [F:ATZ]CODZONE
        Else
            SZFIEBPC(IBPCUSTOMER) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif

        Call TEXTE([F:ATZ]NOLONG, SZLABELBPC(IBPCUSTOMER)) From OBJDIV

        IBPCUSTOMER += 1
    Next
Next

Filter [ATZ]

IDIMCONTROL = dim(SZTAGBPC) - 1

#Définition des attributs
ITER = 0
For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETBPCHIDE
Next

#Attribut de tri
Gosub SETBPCSORT

#On vérifie les doublons possibles de tags
IDUPLICATE = 0
While 1
    IDUPLICATE = 0
    ITER = 0
    For ITER = 0 To IDIMCONTROL
        ITER2 = 0
        For ITER2 = 0 To IDIMCONTROL
            If ITER2 <> ITER
                If SZTAGBPC(ITER) <> ""
                    If SZTAGBPC(ITER2) <> ""
                        If SZTAGBPC(ITER2) = SZTAGBPC(ITER)
                            SZTAGBPC(ITER2) = SZTAGBPC(ITER2) + "X"
                            IDUPLICATE = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Next
        If IDUPLICATE : Break : Endif
    Next
    If IDUPLICATE = 0 : Break : Endif
Wend

#Modification de la présentation et du tri par point d'entrée
Gosub PE_AOBEXP From TRTCRMPE

Return

