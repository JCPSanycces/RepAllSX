        ISORT = 4
    Endif

    If SZFIEMAC(ITER) = "MACSERNUM"
        ISORT = 5
    Endif

    If SZFIEMAC(ITER) = "MACBRA"
        ISORT = 6
    Endif

    If SZFIEMAC(ITER) = "MACITSDAT"
        ISORT = 7
    Endif

    If SZFIEMAC(ITER) = "MACITNTYP"
        ISORT = 8
    Endif

    If SZFIEMAC(ITER) = "MACITNLND"
        ISORT = 9
    Endif

    If SZFIEMAC(ITER) = "MACRSL"
        ISORT = 10
    Endif

    If SZFIEMAC(ITER) = "MACCUTBPC"
        ISORT = 11
    Endif

    If SZFIEMAC(ITER) = "MACSALPRI"
        ISORT = 12
    Endif

    If SZFIEMAC(ITER) = "MACPURDAT"
        ISORT = 13
    Endif

    If SZFIEMAC(ITER) = "CUR"
        ISORT = 14
    Endif

    If SZFIEMAC(ITER) = "MACBPCPRI"
        ISORT = 15
    Endif

    If SZFIEMAC(ITER) = "MACBPCDAT"
        ISORT = 16
    Endif

    If SZFIEMAC(ITER) = "MACBPCCUR"
        ISORT = 17
    Endif

    If SZFIEMAC(ITER) = "MACITNDAT"
        ISORT = 18
    Endif

    If SZFIEMAC(ITER) = "FCYITN"
        ISORT = 19
    Endif

    If SZFIEMAC(ITER) = "PLE"
        ISORT = 20
    Endif

    If SZFIEMAC(ITER) = "MACORI"
        ISORT = 21
    Endif

    If SZFIEMAC(ITER) = "MACORIVCR"
        ISORT = 22
    Endif

    If SZFIEMAC(ITER) = "MACORIVCRL"
        ISORT = 23
    Endif

    ISORTMAC(ITER) = ISORT
Next

ISORT = 24

ITER = 0
For ITER = 0 To dim(SZTAGMAC) - 1
    If ISORTMAC(ITER) = 0
        ISORTMAC(ITER) = ISORT
    Endif
    ISORT += 1
Next

Return

#########################################################
$MACEXCEPTION
  If SZFIE = "CREUSR" Then
    If [F:MAC]CREUSR <> "" Then
      Read [AUS]CODUSR=[F:MAC]CREUSR
      If !fstat Then
        SZBUFFTOFILL(0) = "(" + [F:AUS]USR + ")" - [F:AUS]NOMUSR
        IRUNBYEXCEPTION = 1
      Endif
    Endif
