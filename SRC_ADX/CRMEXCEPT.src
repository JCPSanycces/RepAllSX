#Clob
If SZFIECLL(ITER) = "OBJFLG"
    IHIDECLL(ITER) = 1
Endif

#Clob
If SZFIECLL(ITER) = "TYPFULRPO"
    IHIDECLL(ITER) = 1
Endif

#Clob
If SZFIECLL(ITER) = "NUMFULRPO"
    IHIDECLL(ITER) = 1
Endif

#Clob
If SZFIECLL(ITER) = "RPOFLG"
    IHIDECLL(ITER) = 1
Endif

If SZFIECLL(ITER) = "CLLDATX"
    IHIDECLL(ITER) = 1
Endif

If SZFIECLL(ITER) = "CLLCCNCRY"
    IHIDECLL(ITER) = 1
Endif

#If SZFIECLL(ITER) = "CLLORITXT"
#    IHIDECLL(ITER) = 1
#Endif

If SZFIECLL(ITER) = "CLLCMGNUM"
    IHIDECLL(ITER) = 1
Endif

If SZFIECLL(ITER) = "CLLCMGFLG"
    IHIDECLL(ITER) = 1
Endif

If SZFIECLL(ITER) = "CLLOPGNUM"
    IHIDECLL(ITER) = 1
Endif

If SZFIECLL(ITER) = "CLLOPGTYP"
    IHIDECLL(ITER) = 1
Endif

#Date modif
If SZFIECLL(ITER) = "UPDDAT"
    IHIDECLL(ITER) = 1
Endif

#Opérateur modif
If SZFIECLL(ITER) = "UPDUSR"
    IHIDECLL(ITER) = 1
Endif

Return

################################################
#Attribut de tri
################################################
$SETCLLSORT
ISORT = 0

ITER = 0
For ITER = 0 To dim(SZTAGCLL) - 1
    ISORT = 0

    If SZFIECLL(ITER) = "CLLNUM"
        ISORT = 1
    Endif

    If SZFIECLL(ITER) = "SALFCY"
        ISORT = 2
    Endif

    If SZFIECLL(ITER) = "CLLCMP"
        ISORT = 3
    Endif

    If SZFIECLL(ITER) = "CLLOPP"
        ISORT = 4
    Endif

    If SZFIECLL(ITER) = "CLLDAT"
        ISORT = 5
    Endif

    If SZFIECLL(ITER) = "CLLHOU"
        ISORT = 6
    Endif

    If SZFIECLL(ITER) = "CLLWEE"
        ISORT = 7
    Endif

    If SZFIECLL(ITER) = "CLLCAT"
        ISORT = 8
    Endif

    If SZFIECLL(ITER) = "CLLTYP"
        ISORT = 9
    Endif

    If SZFIECLL(ITER) = "CLLCCN"
        ISORT = 10
    Endif

    If SZFIECLL(ITER) = "CLLETS"
        ISORT = 11
    Endif

    If SZFIECLL(ITER) = "CLLMOB"
        ISORT = 12
    Endif

    If SZFIECLL(ITER) = "CLLOBJ"
        ISORT = 13
    Endif

    If SZTAGCLL(ITER) = "CLLHD5CLOB0"
        ISORT = 14
    Endif

    If SZFIECLL(ITER) = "CLLREP"
        ISORT = 15
    Endif

    If SZFIECLL(ITER) = "CLLPIOLEV"
        ISORT = 16
    Endif

    If SZFIECLL(ITER) = "CLLDUR"
        ISORT = 17
    Endif

    If SZFIECLL(ITER) = "CLLTNTPRE"
        ISORT = 18
    Endif

    If SZFIECLL(ITER) = "CLLDON"
        ISORT = 19
    Endif

    If SZFIECLL(ITER) = "CLLRPO"
        ISORT = 20
    Endif

    If SZTAGCLL(ITER) = "CLLHD4CLOB0"
        ISORT = 21
    Endif

    If SZFIECLL(ITER) = "CLLSAO"
        ISORT = 22
    Endif
    # FGR 05/03/2010 : X3SUIVI62924 (début)
    #If SZFIECLL(ITER) = "CLLORI"
    #    ISORT = 23
    #Endif
    If SZFIECLL(ITER) = "CLLORIADI"
        ISORT = 23
    Endif
    # FGR 05/03/2010 : X3SUIVI62924 (fin)
    If SZFIECLL(ITER) = "CLLORIVCR"
        ISORT = 24
    Endif

    If SZFIECLL(ITER) = "CLLORIVCRL"
        ISORT = 25
    Endif

    ISORTCLL(ITER) = ISORT
Next

ISORT = 26

ITER = 0
For ITER = 0 To dim(SZTAGCLL) - 1
    If ISORTCLL(ITER) = 0
        ISORTCLL(ITER) = ISORT
    Endif
    ISORT += 1
Next

Return

#########################################################
$CLLEXCEPTION
  If SZFIE = "CLLCCN" Then
    #Interlocuteur
    If [F:CLL]CLLCCN <> "" Then
      Read [AIN]AIN0=[F:CLL]CLLCCN
      If !fstat Then
        Call BUILDFULNAM("AIN", SZBUFFTOFILL(0)) From CRMUTIL140
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Elsif SZFIE = "CREUSR" Then
    If [F:CLL]CREUSR <> "" Then
      Read [AUS]CODUSR=[F:CLL]CREUSR
      If !fstat Then
        SZBUFFTOFILL(0) = "(" + [F:AUS]USR + ")" - [F:AUS]NOMUSR
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Endif
Return

#########################################################
$XMLCLL
  Gosub XMLCLL From CRMEXCEPT2
Return

#########################################################
$HTMLCLL
Call TEXTE(13606, SZHTMLTITLE) From OBJDIV      #Appel

Gosub DOSTARTTABLE From CRMXML140

#On extrait les champs de la table INTERVEN
ITERSORT = 1
For ITERSORT = 1 To 250
    IPHONECALL = 0
    For IPHONECALL = 0 To dim(SZTAGCLL) - 1
        If SZTAGCLL(IPHONECALL) = "" : Break : Endif

        If IHIDECLL(IPHONECALL) = 0
            If ISORTCLL(IPHONECALL) = ITERSORT
                Case SZTAGCLL(IPHONECALL)
                    When "CLLHD5CLOB0"
                        #On extrait le clob Description
                        IPHONECALL = dim(SZTAGCLL) - 2
                        Raz SZBUFFTOFILL
                        If [F:CLL]TYPFULOBJ <> ""
                            If [F:CLL]NUMFULOBJ <> ""
                                Read [HD5]HD50 = [F:CLL]NUMFULOBJ;[F:CLL]TYPFULOBJ
                                If !fstat
                                    Raz SZOBJCLOBCLL
                                    Setlob SZOBJCLOBCLL With [F:HD5]CLOB
                                    If SZOBJCLOBCLL(0) <> ""
                                        SZLABELFORFILL = SZLABELCLL(IPHONECALL)
                                        Gosub ADDDEBTRCLOB From CRMXML140

                                        ITERCLOB = 0
                                        For ITERCLOB = 0 To dim(SZOBJCLOBCLL) - 1
                                            If SZOBJCLOBCLL(ITERCLOB) <> ""
                                                SZBUFFTOFILL(0) = SZOBJCLOBCLL(ITERCLOB)
                                                Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                                                Wrseq SZBUFFTOFILL(0) Using [FXML]
                                            Endif
                                        Next

                                        Gosub ADDENDTRCLOB From CRMXML140
                                    Endif
                                Endif
                            Endif
                        Endif

                    When "CLLHD4CLOB0"
                        #On extrait le clob Compte-rendu
                        IPHONECALL = dim(SZFIECLL) - 1
                        Raz SZBUFFTOFILL
                        If [F:CLL]TYPFULRPO <> ""
                            If [F:CLL]NUMFULRPO <> ""
                                Read [HD4]HD40 = [F:CLL]NUMFULRPO;[F:CLL]TYPFULRPO
                                If !fstat
                                    Raz SZRPOCLOBCLL
                                    Setlob SZRPOCLOBCLL With [F:HD4]CLOB
                                    If SZRPOCLOBCLL(0) <> ""
                                        SZLABELFORFILL = SZLABELCLL(IPHONECALL)
                                        Gosub ADDDEBTRCLOB From CRMXML140

                                        ITERCLOB = 0
                                        For ITERCLOB = 0 To dim(SZRPOCLOBCLL) - 1
                                            If SZRPOCLOBCLL(ITERCLOB) <> ""
                                                SZBUFFTOFILL(0) = SZRPOCLOBCLL(ITERCLOB)
                                                Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                                                Wrseq SZBUFFTOFILL(0) Using [FXML]
                                            Endif
                                        Next

                                        Gosub ADDENDTRCLOB From CRMXML140
                                    Endif
                                Endif
                            Endif
                        Endif

                    When Default
                        SZABR = "CLL"
                        SZFIE = SZFIECLL(IPHONECALL)
                        SZTABLE = "PHONECALL"
                        SZLABELFORFILL = SZLABELCLL(IPHONECALL)
                        Gosub WRITEHTMLTR From CRMXML140
                Endcase
            Endif
        Endif
    Next
Next

Gosub DOENDTABLE From CRMXML140
Return

######################################################################
# Tentative d'appel
######################################################################
$SETCTTEXCEPT

If !clalev([F:CTT]) : Local File CALLATTEMP [CTT] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR
SZAOBEXPTAB = "CALLATTEMP"
SZAOBEXPABR = "CTT"

Gosub SETAOBEXCEPT

Local Integer ICALLATTEMP
ICALLATTEMP = IAOBEXPCOUNT

Local Char SZTAGCTT(30)(ICALLATTEMP)
Local Char SZFIECTT(30)(ICALLATTEMP)
Local Integer IHIDECTT(ICALLATTEMP)
Local Integer ISORTCTT(ICALLATTEMP)
Local Char SZLABELCTT(30)(ICALLATTEMP)
Local Integer IDISPLAYCTT
IDISPLAYCTT = 1
Raz IHIDECTT
Raz ISORTCTT
Raz SZLABELCTT
ICALLATTEMP = 0

Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB

For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")

    ITERDIM = 0
    For ITERDIM = 0 To IDIMCONTROL - 1
        SZTAGCTT(ICALLATTEMP) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
        If ITERDIM = 0
            SZFIECTT(ICALLATTEMP) = [F:ATZ]CODZONE
        Else
            SZFIECTT(ICALLATTEMP) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif

        Call TEXTE([F:ATZ]NOLONG, SZLABELCTT(ICALLATTEMP)) From OBJDIV

        ICALLATTEMP += 1
    Next
Next

Filter [ATZ]

IDIMCONTROL = dim(SZTAGCTT) - 1

#Définition des attributs
ITER = 0
For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETCTTHIDE
Next

#Attribut de tri
Gosub SETCTTSORT

#On vérifie les doublons possibles de tags
IDUPLICATE = 0
While 1
    IDUPLICATE = 0
    ITER = 0
    For ITER = 0 To IDIMCONTROL
        ITER2 = 0
        For ITER2 = 0 To IDIMCONTROL
            If ITER2 <> ITER
                If SZTAGCTT(ITER) <> ""
                    If SZTAGCTT(ITER2) <> ""
                        If SZTAGCTT(ITER2) = SZTAGCTT(ITER)
                            SZTAGCTT(ITER2) = SZTAGCTT(ITER2) + "X"
                            IDUPLICATE = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Next
        If IDUPLICATE : Break : Endif
    Next
    If IDUPLICATE = 0 : Break : Endif
Wend

#Modification de la présentation et du tri par point d'entrée
Gosub PE_AOBEXP From TRTCRMPE

Return

################################################
#Attribut de visibilité
################################################
$SETCTTHIDE
#Par défaut, chaque champ est visible
IHIDECTT(ITER) = 0

If SZFIECTT(ITER) = "CTTNUM"
    IHIDECTT(ITER) = 1
Endif

If SZFIECTT(ITER) = "CLLNUM"
    IHIDECTT(ITER) = 1
Endif

If SZFIECTT(ITER) = "CTTCMP"
    IHIDECTT(ITER) = 1
Endif

If SZFIECTT(ITER) = "CTTCCN"
    IHIDECTT(ITER) = 1
Endif

If SZFIECTT(ITER) = "CTTREP"
    IHIDECTT(ITER) = 1
Endif

Return

################################################
#Attribut de tri
################################################
$SETCTTSORT
ISORT = 0

ITER = 0
For ITER = 0 To dim(SZTAGCTT) - 1
    ISORT = 0

    If SZFIECTT(ITER) = "CTTDAT"
        ISORT = 1
    Endif

    If SZFIECTT(ITER) = "HOUCRE"
        ISORT = 2
    Endif

    ISORTCTT(ITER) = ISORT
Next

ISORT = 3

ITER = 0
For ITER = 0 To dim(SZTAGCTT) - 1
    If ISORTCTT(ITER) = 0
        ISORTCTT(ITER) = ISORT
    Endif
    ISORT += 1
Next

Return

