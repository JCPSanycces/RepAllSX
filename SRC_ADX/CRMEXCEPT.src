################################################
#Attribut de tri
################################################
$SETHDTSORT
ISORT = 0

ITER = 0
For ITER = 0 To dim(SZTAGHDT) - 1
    ISORT = 0

    If SZFIEHDT(ITER) = "HDTMACSRE"
        ISORT = 1
    Endif

    If SZFIEHDT(ITER) = "HDTCPN"
        ISORT = 2
    Endif

    If SZFIEHDT(ITER) = "HDTTYP"
        ISORT = 3
    Endif

    If SZFIEHDT(ITER) = "HDTITM"
        ISORT = 4
    Endif

    If SZFIEHDT(ITER) = "HDTQTY"
        ISORT = 5
    Endif

    If SZFIEHDT(ITER) = "HDTUOM"
        ISORT = 6
    Endif

    If SZFIEHDT(ITER) = "HDTTEX"
        ISORT = 7
    Endif

    If SZTAGHDT(ITER) = "HDTACBCLOB0"
        ISORT = 8
    Endif

    If SZFIEHDT(ITER) = "HDTAUSTYP"
        ISORT = 9
    Endif

    If SZFIEHDT(ITER) = "HDTAUS"
        ISORT = 10
    Endif

    If SZFIEHDT(ITER) = "HDTPLNDAT"
        ISORT = 11
    Endif

    If SZFIEHDT(ITER) = "HDTDONDAT"
        ISORT = 12
    Endif

    If SZFIEHDT(ITER) = "SPGTIMHOU"
        ISORT = 13
    Endif

    If SZFIEHDT(ITER) = "SPGTIMMNT"
        ISORT = 14
    Endif

    If SZFIEHDT(ITER) = "HDTINV"
        ISORT = 15
    Endif

    If SZFIEHDT(ITER) = "HDTAMT"
        ISORT = 16
    Endif

    If SZFIEHDT(ITER) = "HDTAMTINV"
        ISORT = 17
    Endif

    If SZFIEHDT(ITER) = "HDTCUR"
        ISORT = 18
    Endif

    If SZFIEHDT(ITER) = "HDTSTOISS"
        ISORT = 19
    Endif

    If SZFIEHDT(ITER) = "HDTSTOFCY"
        ISORT = 20
    Endif

    If SZFIEHDT(ITER) = "HDTISSQTY"
        ISORT = 21
    Endif

    If SZFIEHDT(ITER) = "HDTISSISS"
        ISORT = 22
    Endif

    If SZFIEHDT(ITER) = "HDTNUM"
        ISORT = 23
    Endif

    ISORTHDT(ITER) = ISORT
Next

ISORT = 24

ITER = 0
For ITER = 0 To dim(SZTAGHDT) - 1
    If ISORTHDT(ITER) = 0
        ISORTHDT(ITER) = ISORT
    Endif
    ISORT += 1
Next

Return

#########################################################
$HDTEXCEPTION
  If SZFIE = "HDTAUS" Then
    If [F:HDT]HDTAUS <> "" Then
      If [F:HDT]HDTAUSTYP = 1 Then
        Read [AUS]CODUSR=[F:HDT]HDTAUS
        If !fstat Then
          SZBUFFTOFILL(0) = "(" + [F:AUS]USR + ")" - [F:AUS]NOMUSR
          IRUNBYEXCEPTION = 1
        Endif
      Elsif [F:HDT]HDTAUSTYP = 2 Then
        Read [BPR]BPR0=[F:HDT]HDTAUS
        If !fstat Then
          SZBUFFTOFILL(0) = "(" + [F:BPR]BPRNUM + ")" - [F:BPR]BPRNAM
          IRUNBYEXCEPTION = 1
        Endif
      Endif
    Endif
  Endif
Return

#########################################################
$XMLHDT
  Gosub XMLHDT From CRMEXCEPT2
Return

#########################################################
$HTMLHDT
  If [F:HDT]HDTDONDAT = [00/00/00] Then
    #Consommation à effectuer
    SZHTMLTITLE = mess(77,177,1)
  Else
    #Consommation effectuée
    SZHTMLTITLE = mess(78,177,1)
  Endif
  Gosub DOSTARTTABLE From CRMXML140
  #On extrait les champs de la table
  For ITERSORT = 1 To 250
    For IHDKTASK = 0 To dim(SZTAGHDT)-1
      If SZTAGHDT(IHDKTASK) = "" Then
        Break
      Endif
      If IHIDEHDT(IHDKTASK) = 0 Then
        If ISORTHDT(IHDKTASK) = ITERSORT Then
          Case SZTAGHDT(IHDKTASK)
            When "HDTACBCLOB0"
              #On extrait le clob Texte
              IHDKTASK = dim(SZTAGHDT) - 1
              Raz SZBUFFTOFILL
              If [F:HDT]HDTSALTEX <> "" Then
                Read [TXC]TXC0=[F:HDT]HDTSALTEX
                If !fstat Then
                  Raz SZACBCLOBHDT
                  Setlob SZACBCLOBHDT With [F:TXC]TEXTE
                  If SZACBCLOBHDT(0) <> "" Then
                    SZLABELFORFILL = SZLABELHDT(IHDKTASK)
                    Gosub ADDDEBTRCLOB From CRMXML140
                    For ITERCLOB = 0 To dim(SZACBCLOBHDT)-1
                      If SZACBCLOBHDT(ITERCLOB) <> "" Then
                        SZBUFFTOFILL(0) = SZACBCLOBHDT(ITERCLOB)
                        Call MODVAL(SZBUFFTOFILL(0)) From CRMXML140
                        Wrseq SZBUFFTOFILL(0) Using [FXML]
                      Endif
                    Next
                    Gosub ADDENDTRCLOB From CRMXML140
                  Endif
                Endif
              Endif
            When Default
              SZABR = "HDT"
              SZFIE = SZFIEHDT(IHDKTASK)
              SZTABLE = "HDKTASK"
              SZLABELFORFILL = SZLABELHDT(IHDKTASK)
              Gosub WRITEHTMLTR From CRMXML140
          Endcase
        Endif
      Endif
    Next
  Next
  Gosub DOENDTABLE From CRMXML140
Return

######################################################################
# Parc concerné
######################################################################
$SETSRMEXCEPT

If !clalev([F:SRM]) : Local File SREMAC [SRM] : Endif

Local Char SZAOBEXPTAB
Local Char SZAOBEXPABR
SZAOBEXPTAB = "SREMAC"
SZAOBEXPABR = "SRM"

Gosub SETAOBEXCEPT

Local Integer ISREMAC
ISREMAC = IAOBEXPCOUNT

Local Char SZTAGSRM(30)(ISREMAC)
Local Char SZFIESRM(30)(ISREMAC)
Local Integer IHIDESRM(ISREMAC)
Local Integer ISORTSRM(ISREMAC)
Local Char SZLABELSRM(30)(ISREMAC)
Local Integer IDISPLAYSRM
IDISPLAYSRM = 1
Raz IHIDESRM
Raz ISORTSRM
Raz SZLABELSRM
ISREMAC = 0

Filter [ATZ] Where [F:ATZ]CODFIC = SZAOBEXPTAB

For [ATZ]CODZONE
    IDIMCONTROL = evalue("Dim([F:" + SZAOBEXPABR + "]" + [F:ATZ]CODZONE + ")")

    ITERDIM = 0
    For ITERDIM = 0 To IDIMCONTROL - 1
        SZTAGSRM(ISREMAC) = SZAOBEXPABR + [F:ATZ]CODZONE + num$(ITERDIM)
        If ITERDIM = 0
            SZFIESRM(ISREMAC) = [F:ATZ]CODZONE
        Else
            SZFIESRM(ISREMAC) = [F:ATZ]CODZONE + "(" + num$(ITERDIM) + ")"
        Endif

        Call TEXTE([F:ATZ]NOLONG, SZLABELSRM(ISREMAC)) From OBJDIV

        ISREMAC += 1
    Next
Next

Filter [ATZ]

IDIMCONTROL = dim(SZTAGSRM) - 1

#Définition des attributs
ITER = 0
For ITER = 0 To IDIMCONTROL
    #Attribut de visibilité
    Gosub SETSRMHIDE
Next

#Attribut de tri
Gosub SETSRMSORT

#On vérifie les doublons possibles de tags
IDUPLICATE = 0
While 1
    IDUPLICATE = 0
    ITER = 0
    For ITER = 0 To IDIMCONTROL
        ITER2 = 0
        For ITER2 = 0 To IDIMCONTROL
            If ITER2 <> ITER
                If SZTAGSRM(ITER) <> ""
                    If SZTAGSRM(ITER2) <> ""
                        If SZTAGSRM(ITER2) = SZTAGSRM(ITER)
                            SZTAGSRM(ITER2) = SZTAGSRM(ITER2) + "X"
                            IDUPLICATE = 1
                            Break
                        Endif
                    Endif
                Endif
            Endif
        Next
        If IDUPLICATE : Break : Endif
    Next
    If IDUPLICATE = 0 : Break : Endif
Wend

#Modification de la présentation et du tri par point d'entrée
Gosub PE_AOBEXP From TRTCRMPE

Return

################################################
#Attribut de visibilité
################################################
$SETSRMHIDE
#Par défaut, chaque champ est visible
IHIDESRM(ITER) = 0

#Demande de service
If SZFIESRM(ITER) = "SRENUM"
    IHIDESRM(ITER) = 1
Endif

#Regroupement
If SZFIESRM(ITER) = "ITNGRU"
    IHIDESRM(ITER) = 1
Endif

#Motif de non couverture
If SZFIESRM(ITER) = "MACCOVREN"
    IHIDESRM(ITER) = 1
Endif

#Date création
If SZFIESRM(ITER) = "CREDAT"
    IHIDESRM(ITER) = 1
Endif

#Opérateur création
If SZFIESRM(ITER) = "CREUSR"
    IHIDESRM(ITER) = 1
Endif

#Date modif
If SZFIESRM(ITER) = "UPDDAT"
    IHIDESRM(ITER) = 1
Endif

#Opérateur modif
If SZFIESRM(ITER) = "UPDUSR"
    IHIDESRM(ITER) = 1
Endif

Return

################################################
#Attribut de tri
################################################
$SETSRMSORT
ISORT = 0

ITER = 0
For ITER = 0 To dim(SZTAGSRM) - 1
    ISORT = 0

    If SZFIESRM(ITER) = "MACNUM"
        ISORT = 1
    Endif

    If SZFIESRM(ITER) = "PBLNUM"
        ISORT = 2
    Endif

    If SZFIESRM(ITER) = "COVFLG"
        ISORT = 3
    Endif

    If SZFIESRM(ITER) = "COVSPT"
        ISORT = 4
    Endif

    If SZFIESRM(ITER) = "COVVCR"
        ISORT = 5
    Endif

    ISORTSRM(ITER) = ISORT
Next

ISORT = 6

ITER = 0
For ITER = 0 To dim(SZTAGSRM) - 1
    If ISORTSRM(ITER) = 0
        ISORTSRM(ITER) = ISORT
    Endif
    ISORT += 1
Next

Return

#########################################################
$SRMEXCEPTION
  If SZFIE = "CREUSR" Then
    If [F:SRM]CREUSR <> "" Then
      Read [AUS]CODUSR=[F:SRM]CREUSR
      If !fstat Then
        SZBUFFTOFILL(0) = "(" + [F:AUS]USR + ")" - [F:AUS]NOMUSR
        IRUNBYEXCEPTION = 1
      Endif
    Endif
  Endif
Return

#########################################################
$XMLSRM
  Gosub XMLSRM From CRMEXCEPT2
Return

#########################################################
$XSDSRM
  Gosub XSDSRM From CRMEXCEPT2
Return

######################################################################
$HTMLSRM
  #Parc concerné
  Call TEXTE(22065, SZHTMLTITLE) From OBJDIV
  Gosub DOSTARTTABLE From CRMXML140
  #On extrait les champs de la table
  For ITERSORT = 1 To 250
    For ISREMAC = 0 To dim(SZTAGSRM)-1
      If SZTAGSRM(ISREMAC) = "" Then
        Break
      Endif
      If IHIDESRM(ISREMAC) = 0 Then
        If ISORTSRM(ISREMAC) = ITERSORT Then
          SZABR = "SRM"
          SZFIE = SZFIESRM(ISREMAC)
          SZTABLE = "SREMAC"
          SZLABELFORFILL = SZLABELSRM(ISREMAC)
          Gosub WRITEHTMLTR From CRMXML140
        Endif
      Endif
    Next
  Next
  Gosub DOENDTABLE From CRMXML140
Return

