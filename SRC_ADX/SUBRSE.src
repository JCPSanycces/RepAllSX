#<AdxTL>@(#)1.0.0.0 $Revision$ Gestion du fichier RESOURCES
Call OBJET ("RSE", GBIDC1, GBIDC2) From GOBJET
End
##########################################################################################################

##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "SETBOUT"    : Gosub SETBOUT
    When "RAZCRE"     : Gosub RAZCRE
    When "INICRE"     : Gosub INICRE
    When "LIENS"      : Gosub LIENS
    When "FERME"      : Gosub FERME
    When "CREATION"   : Gosub CREATION
    When "MODIF"      : Gosub MODIF
    When "AV_ANNULE"  : Gosub AV_ANNULE
    When "ANNULE"     : Gosub ANNULE     # FGR 24/09/2009 : X3SUIVI58059
    When Default
  Endcase
Return

##########################################################################################################
$OUVRE
Global Char     GCRSECPT(GLONANM)   # Code compteur pour ressource

  #------------------------------------------------------------#
  # --> Récupération du code compteur                          #
  #------------------------------------------------------------#
  # ----------------------------------------------------------
  # FGR 20/12/2012 : X3SUIVI71937 (début) : c'est plus là
  #  If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
  #  Read [TCA]TCA0=13
  #  If fstat Then
  #    GERR = 1
  #    GMESSAGE = mess(64,199,1)
  #    OK = 0
  #    Return
  #  Endif
  #  GMANCOU = [F:TCA]MANCOU(6)
  #  GCRSECPT = [F:TCA]CODNUM(6)
  # FGR 20/12/2012 : X3SUIVI71937 (fin)
  # ----------------------------------------------------------
Return

##########################################################################################################
$FERME
  Kill GCRSECPT            # Code compteur pour ressource
Return

##########################################################################################################
$SETBOUT
  Call VIREBOUT(CHAINE,"H") From GOBJET
Return

##########################################################################################################
$RAZCRE
  #Initialise les valeurs par défaut de l'enregistrement
  [M:RSS1]CREDAT = date$
  Affzo [M:RSS1]CREDAT
  Affzo [M:RSS1]1-99
Return

##########################################################################################################
$LIENS
  #Lecture des clobs
  Gosub LOADCLOB From SUBRSEB
  Affzo [M:RSS1]1-99
Return

##########################################################################################################
$INICRE
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR

  Call READ_COUNTER([M:RSS0]SALFCY, 13, 6, GSOCIETE, GCURLEG, GCRSECPT, GMANCOU) From CRM_UTIL     # FGR 20/05/2015 : X3SUIVI107775
  # Récupération du compteur de contrat de service.
  If func CRM_UTIL.GET_NUMERO_CHRONO ("ACT", [M:RSS0]SALFCY, GCRSECPT, date$, "", [M:RSS0]NUM, IERRINF, ICHAPTER, IBRETOUR) = 1 Then
    If IBRETOUR = 1 Then
      [F:RSS]NUM = [M:RSS0]NUM
      Affzo [M:RSS0]NUM
    Else
      # problème lors de la récupération du compteur
      GERR = 1
      GMESSAGE = mess(IERRINF,ICHAPTER,1)
      GOK = 0
      Return
    Endif
  Endif
  [F:RSS]TYPFULDES = "RSE"
  [F:RSS]NUMFULDES = [M:RSS0]NUM
  [M:RSS1]TYPFULDES = "RSE"
  [M:RSS1]NUMFULDES = [M:RSS0]NUM
Return

##########################################################################################################
$CREATION
  # FGR 24/09/2009 : X3SUIVI58059
  #--- maj de la table des libéllés traduisibles
  Call MAJTEXTRA([M:RSS1]RSSDESAXX,"RESOURCES","RSSDESAXX",[M:RSS0]NUM,"") From ATEXTRA
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBRSEB
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$MODIF
  # FGR 24/09/2009 : X3SUIVI58059
  #--- maj de la table des libéllés traduisibles
  Call MAJTEXTRA([M:RSS1]RSSDESAXX,"RESOURCES","RSSDESAXX",[M:RSS0]NUM,"") From ATEXTRA
  #Enregistrement des clobs
  Gosub SAVECLOB From SUBRSEB
  If GOK < 1 Then
    Return
  Endif
Return

##########################################################################################################
$ANNULE
  # FGR 24/09/2009 : X3SUIVI58059
  #--- maj de la table des libéllés traduisibles
  Call SUPTEXTRA("RESOURCES","RSSDESAXX",[M:RSS0]NUM,"") From ATEXTRA
Return

##########################################################################################################
$AV_ANNULE
  #Suppression des clobs
  Gosub DELCLOB From SUBRSEB
  If GOK < 1 Then
    Return
  Endif
Return

