#<AdxTL>@(#)8.0.0.0 $Revision$
##############################################
# NETBPS : Details Netvibes pour le code BPS #
#             Liste des fournisseurs         #
##############################################


#------------#
# Pour tests #
#------------#
If !clalev([F:BPS])  Local File BPSUPPLIER [BPS] : Endif
#-----
Local Char    WMSG(250)
Local Char    COD_OBJ(GLONAOB)
Local Char    WWKEYS(GLONBPS)
Local Char    CHAMPS_LUS(50)(1..8)
Local Blbfile BLOB_LUS(1)
Local Date DATMIN : DATMIN=gdat$( 1, 1,year(date$))
Local Date DATMAX : DATMAX=gdat$(31,12,year(date$))
#-----
COD_OBJ="BPS"
WWKEYS="2204"
Call LECTURE(COD_OBJ,WWKEYS,CHAMPS_LUS,BLOB_LUS) From WMNETBPS
#-----
WMSG ="Fournisseur ="-WWKEYS-"-"-CHAMPS_LUS(1)+"\"
WMSG+="Encours autorisûˋ ="-CHAMPS_LUS(5)-GLOCALDEV+"\"
WMSG+="Nbre commandes ="-CHAMPS_LUS(6)+"\"
WMSG+="Total facturûˋ ="-CHAMPS_LUS(7)-GLOCALDEV+"\"
WMSG+="Mt moyen/cde ="-CHAMPS_LUS(8)-GLOCALDEV+"\"
WMSG+="Pour la pûˋriode du"-num$(DATMIN)-"au"-num$(DATMAX)
Call MESSAGE(WMSG) From GESECRAN
#-----
End


#############################################
$ACTION
Case ACTION
 When "DESC_LISTE" : Gosub DESC_LISTE
 When "DESC_LEC"   : Gosub DESC_LEC
 When "LISTE"      : Gosub LISTE
 When "LECTURE"    : Gosub LECTURE
 When "RAFRAICHIR" : Gosub RAFRAICHIR
Endcase
Return
#############################################


#-------------------------------------------------------#
# Sous-programme de description du web service de liste #
#-------------------------------------------------------#
$DESC_LISTE
Return

#---------------------------------------------------------#
# Sous-programme de description du web service de lecture #
#---------------------------------------------------------#
$DESC_LEC
#-----
CODE_CHAMPS(6)="NBRPOH"
CODE_CHAMPS(7)="INVBPS"
CODE_CHAMPS(8)="AVEPOH"
#-----
INTIT_CHAMPS(6)=mess(404,194,1) : # Nbre commandes annûˋe en cours
INTIT_CHAMPS(7)=mess(405,194,1) : # Total facturûˋ annûˋe en cours
INTIT_CHAMPS(8)=mess(406,194,1) : # Mt moyen d'une commande
#-----
TYPE_CHAMPS(6)=3
TYPE_CHAMPS(7)=4
TYPE_CHAMPS(8)=4
#-----
LEN_CHAMPS(6)=8
LEN_CHAMPS(7)=9.2
LEN_CHAMPS(8)=9.2
#-----
Return


#-------------------------#
# Sous-programme de liste #
#-------------------------#
$LISTE
#-----
Return


#----------------------------------#
# Sous-programme de lecture dûˋtail #
# -------------------------------- #
# WWKEYS       = Code fournisseur #
#                                  #
# CHAMPS_LUS(6) = Nbre commandes   #
# CHAMPS_LUS(7) = Total facturûˋ    #
# CHAMPS_LUS(8) = Mt moyen cde     #
#                                  #
# La classe [F:BPS] est chargûˋe    #
#----------------------------------#
$LECTURE
#----- Le montant encours autorisûˋ est mal affichûˋ en standard ?? -----#
CHAMPS_LUS(5)=format$("N3:11.2",[BPS]OSTAUZAMT)
#-----
Local Date DATMIN : DATMIN=gdat$( 1, 1,year(date$))
Local Date DATMAX : DATMAX=gdat$(31,12,year(date$))
#----- Nombre de commandes chez le fournisseur pour l'annûˋe en cours -----#
CHAMPS_LUS(6)=num$(func TRTX3FNC.GETNBRPOH(WWKEYS,DATMIN,DATMAX))
#----- Total facturûˋ chez le fournisseur pour l'annûˋe en cours -----#
CHAMPS_LUS(7)=num$(func TRTX3FNC.GETINVBPS(WWKEYS,DATMIN,DATMAX))

#----- Montant moyen d'une commande chez le fournisseur -----#
CHAMPS_LUS(8)=num$(func TRTX3FNC.GETAVEPOH(WWKEYS,DATMIN,DATMAX))
#-----
Return


#--------------------------------------------#
# Sous-programme de rafraichissement favoris #
#--------------------------------------------#
$RAFRAICHIR
#-----
Return



