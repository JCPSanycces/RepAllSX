#<AdxTL>@(#)0.0.0.0 $Revision$
#*X3-39795   MDJ  Manage ORIGIN and ORICOD fields in GL Entry
$ACTION
  Case ACTION
    When "INIT"        : Gosub OUVRE
    When "OUVRE_BATCH" : Gosub OUVRE
    When "INIT_DIA"    : Gosub INIT_DIA
    When "CONTROLE"    : Gosub CONTROLE
    When "EXEC"        : Gosub EXEC
    When "TERMINE"     : Gosub TERMINE
  Endcase
Return

######################################################################################
$OUVRE
  If GSERVEUR : Onerrgo ERRBATCH : Endif
  If GSERVEUR=1
    Local Mask CPTMURANO [DIA]
  Endif

  If clalev([F:KPH])=0  : Local File KPYIMPHDR  [KPH]  : Endif
  If clalev([F:KPD])=0  : Local File KPYIMPDTL  [KPD]  : Endif
  If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
  If clalev([F:FCY])=0  : Local File FACILITY   [FCY]  : Endif

  Local Char TXT(70), TIT(70)

Return

######################################################################################
$INIT_DIA
  Raz [M:DIA]
  If GUSRFCY(1)="\" or GNBAUZ=GNBSITE
    [M:DIA]ALLCPY=2
    [M:DIA]ALLFCY=2
    Diszo [M:DIA]ALLFCY,CPY,FCY
  Else
    Diszo [M:DIA]ALLCPY
    Call INICPY([M:DIA]CPY) From SUPCPT
    Call INIFCY([M:DIA]FCY,[M:DIA]CPY) From SUPCPT
  Endif
Return

######################################################################################
$CONTROLE
  If [M:DIA]CPY=""
    SYMBOLE="CPTMURANO\All"
    Lock =SYMBOLE With lockwait=0
    If fstat
      GMESSAGE= mess(30,100,1)   # The record is used by an other user
      GERR=2 : FIN=1 : Return
    Endif
  Else
    SYMBOLE="CPTMURANO\All"
    Lock =SYMBOLE With lockwait=0
    If fstat
      GMESSAGE= mess(30,100,1)   # The record is used by an other user
      GERR=2 : FIN=1 : Return
    Else
      Unlock =SYMBOLE
      SYMBOLE="CPTMURANO\"+[M:DIA]CPY
      Lock =SYMBOLE With lockwait=0
      If fstat
        GMESSAGE= mess(30,100,1)   # The record is used by an other user
        GERR=2 : FIN=1 : Return
      Endif
    Endif
  Endif

  Call TEXTE(55032,TXT) From OBJDIV
  TIT= TXT
  TMP=1

Return

######################################################################################
$EXEC
  If !GSERVEUR
    Call OUVRE_TRACE(TIT) From LECFIC
  Endif
  Call ECR_TRACE(TIT,0) From GESECRAN
  Call ECR_TRACE(string$(90,"-"),0) From GESECRAN
  Call PRTSCR("CPTMURANO","DIA","",0,1) From ATRTX3
  Call ECR_TRACE(string$(90,"-"),0) From GESECRAN

  Gosub SELECT_SITES

  If !GSERVEUR: Call FERME_TRACE From LECFIC : Endif
Return

######################################################################################
$TERMINE
  Unlock =SYMBOLE
  If !GSERVEUR
    TRA=1
  Else
    TRA=0
  Endif

Return

######################################################################################
$ERRBATCH
   Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

######################################################################################
$SELECT_SITES
  Local Char CRITERE(250), CRITDAT (250),  WMSG(250), WFCY(GLONFCY)(0..)
  Local Integer I, NBS, NBREC, NBTRAIT

  # Criteria
  If [M:DIA]ALLFCY=2 and [M:DIA]CPY<>"": CRITERE="[F:KPH]CPY='"+[M:DIA]CPY+"' & ": Endif
  If [M:DIA]FCY<>"" : CRITERE="[F:KPH]FCY='"+[M:DIA]FCY+"' & ": Endif

  CRITERE+="[F:KPH]STA<>2 & [F:KPH]FLGVAL=2 & [F:KPH]ORIPAY=2"

  If [M:DIA]LOT<>"": CRITERE+=" & [F:KPH]LOT='"+[M:DIA]LOT+"'"  : Endif

  CRITDAT="[F:KPH]ACCDAT>=["+format$(GFMD,[M:DIA]STRDAT)+"] & [F:KPH]ACCDAT<=["+format$(GFMD,[M:DIA]ENDDAT)+"]"

  Link [KPH] With [FCY]FCY0=[F:KPH]FCY As [TABX] Where evalue(CRITERE) & evalue(CRITDAT) Order By FCY
  For [TABX]
    K=find([F:TABX]FCY, WFCY)
    WFCY(NBS)=[F:TABX]FCY
    NBS+=1
    If K=0
      Call ECR_TRACE(string$(90," "),0) From GESECRAN
      Call ECR_TRACE(mess(3,45,1)+":"- [F:KPH]FCY,0) From GESECRAN
      Call ECR_TRACE(string$(90,"-"),0) From GESECRAN
    Endif
    Gosub MASS_POSTING
  Next

  If NBTRAIT=0
    WMSG=mess(197,104,1)
    Call ECR_TRACE(WMSG,1) From GESECRAN
  Else
    If [M:DIA]TRC=1
      Call ECR_TRACE(" ",0 )  From GESECRAN
      Call ECR_TRACE(mess (22,3701,1),0 )  From GESECRAN # Automatic Journal Creation completed
    Endif
  Endif

Return


######################################################################################
## Section automatically added (screen CPTMURANO) 03/11/2016 12:31:22 (JUCON)
######################################################################################
Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    Grizo ALLCPY
    Actzo CPY
    mkstat = 1 : End
  Endif
End

######################################################################################
Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
  If VALEUR=2
    Effzo [M]CPY,FCY : Diszo [M]CPY,FCY
    [M]ALLFCY=2 : Affzo ALLFCY : Diszo ALLFCY
  Else
    Actzo CPY,ALLFCY
  Endif
End

######################################################################################
Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
  If [M]ALLCPY=2 : mkstat = 1 : Endif
End

######################################################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
  If [M]ALLCPY<>2 and VALEUR="" : mkstat=1 : Endif
  If VALEUR<>""
    Filter [KPH] Where CPY=VALEUR
    If rowcount([KPH])=0:  GMESSAGE=mess(197,104,1): mkstat=2 : Endif  # No records to process in this company or site
    Filter [KPH]
  Endif
End

######################################################################################
Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
  Call INIALLFCY(VALEUR,[M]CPY) From CPTTRT
  If [M]ALLCPY=2 : VALEUR = 2 : Endif
  If VALEUR=2
    Effzo FCY : Grizo FCY
  Else
    Actzo FCY
  Endif
End

######################################################################################
Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
  If VALEUR=2 : Effzo FCY : Diszo FCY : Else : Actzo FCY : Endif
End

######################################################################################
Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
 If [M]ALLFCY=2 : mkstat = 1 : Endif
End

######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
  If [M]ALLFCY<>2 and VALEUR="" : mkstat=1 : Endif
  If VALEUR<>""
    Filter [KPH] Where FCY=VALEUR
    If rowcount([KPH])=0:  GMESSAGE=mess(197,104,1): mkstat=2 : Endif  # No records to process in this company or site
    Filter [KPH]
  Endif
End

######################################################################################
Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
  If VALEUR=[00/00/00]: GMESSAGE=mess(10,123,1): mkstat=2: Endif
End

######################################################################################
$MASS_POSTING
  Local Char    CRIT(250)            # record selection criteria
  Local Char    DKEY(30)             # source transation ID
  Local Char    MESSAGE(250)         # message returned by create auto journal process
  Local Integer STAT                 # status flag returned by create auto journal process
  Local Char    AUTOJNCODE(GLONGAU)  # automatic journal
  Local Date    SAVEDAT              # RPODAT save
  Local Char    TZONE(10)(1..10)     : # Table of the zones to be forced (Ex: ORICOD)   #*X3-39795
  Local Char    TVAL(30)(1..10)      : # Table of values for zones to be forced         #*X3-39795

  AUTOJNCODE= [F:KPH]COD
  [F:KPH]STALOT=[M:DIA]STALOT
  If [M:DIA]ENTDAT<>[00/00/00]
    SAVEDAT=[F:KPH]RPODAT
    [F:KPH]RPODAT=[M:DIA]ENTDAT
  Endif
  NBTRAIT+=1


  If [F:KPH]FLGDET=1  # Global type
    Local Char CRITCUR(80), GRPCUR(30)(1..)
    Local Integer I, K, NBCUR

    # ckecking if this record was traited before
    Read [KPH]KPYH0=[F:KPH]RECID
    If [F:KPH]STA=2: Goto GO_NEXT : Endif

    Gosub CHECK_CUR   #Split by currency

    For I=1 To NBCUR
      Call CTR_LINES(GRPCUR(I))
    Next

    If NBCUR>1
      For I=1 To NBCUR
        CRITCUR= "[F:KPH]GRPGAS = " + chr$(34) + GRPCUR(I) + chr$(34)
        TZONE(5) = "ORIGIN" : TVAL(5) = "2"        :#Automatic loading  #*X3-39795
        TZONE(6) = "ORICOD" : TVAL(6) = AUTOJNCODE                      #*X3-39795

        #*X3-39795 Call VALPCE2(AUTOJNCODE ,CRITCUR ,STAT,MESSAGE) From CPTAUTO
        Call VALPCE4(AUTOJNCODE,CRITCUR,STAT,MESSAGE,TZONE,TVAL) From CPTAUTO

        If STAT<>0: Break
        Else
          NBREC+=1
          If [M:DIA]TRC=2 and MESSAGE<>""
            Call ECR_TRACE(mess (20,3701,1) - MESSAGE - mess (21,3701,1) ,0) From GESECRAN
          Endif
          Local File KPYIMPHDR [KPHX]
          Filter [KPHX] Where GRPGAS=GRPCUR(I)
          For [KPHX]
            Gosub TR1
          Next
          Close File [KPHX]
        Endif
      Next
    Else
      CRIT= "[F]GRPGAS = " + chr$(34) + GRPCUR + chr$(34)
      TZONE(5) = "ORIGIN" : TVAL(5) = "2"        :#Automatic loading  #*X3-39795
      TZONE(6) = "ORICOD" : TVAL(6) = AUTOJNCODE                      #*X3-39795

      #*X3-39795  Call VALPCE2(AUTOJNCODE ,CRIT ,STAT,MESSAGE) From CPTAUTO
      Call VALPCE4(AUTOJNCODE,CRIT,STAT,MESSAGE,TZONE,TVAL) From CPTAUTO

      If STAT = 0 and MESSAGE <> ""
        NBREC+=1
        If [M:DIA]TRC=2
          Call ECR_TRACE(mess (20,3701,1) - MESSAGE - mess (21,3701,1) ,0) From GESECRAN
        Endif

          Local File KPYIMPHDR [KPHX]
          Filter [KPHX] Where GRPGAS=GRPCUR
          For [KPHX]
            Gosub TR1
          Next
          Close File [KPHX]
       Endif
    Endif
  Else
    DBKEY = evalue("[F:KPH]RECID")
    CRIT = "[F]RECID = " + chr$(34) + DBKEY + chr$(34)
    TZONE(5) = "ORIGIN" : TVAL(5) = "2"        :#Automatic loading  #*X3-39795
    TZONE(6) = "ORICOD" : TVAL(6) = AUTOJNCODE                      #*X3-39795

    #*X3-39795 Call VALPCE2(AUTOJNCODE ,CRIT ,STAT,MESSAGE) From CPTAUTO
    Call VALPCE4(AUTOJNCODE,CRIT,STAT,MESSAGE,TZONE,TVAL) From CPTAUTO

    # If journal posted ok inform user and write journal no to Payroll record
    If STAT = 0 and MESSAGE <> ""
      NBREC+=1
      If [M:DIA]TRC=2
        Call ECR_TRACE(mess (20,3701,1) - MESSAGE - mess (21,3701,1) ,0) From GESECRAN
      Endif

      Trbegin [KPH]
      [F:KPH]RPODAT=SAVEDAT
      [F:KPH]NUM = MESSAGE
      [F:KPH]STA = 2
      Rewrite [KPH]
      If STAT = 0
        Commit
      Else
        Rollback
      Endif
    Endif

    If [M:DIA]TRC=2 and STAT <> 0
      Call ECR_TRACE(mess (17,3701,1)+":"-[F:KPH]RECID+"." -MESSAGE,1) From GESECRAN
    Endif
  Endif
$GO_NEXT
Return

####################################################
# Validate the records when their origin is Murano #
# SAM 106404 JUCON                                 #
####################################################
Subprog VALREC(NUM)
Value    Char NUM
  If clalev([F:GAC])=0  : Local File GACCOUNT [GAC]  : Endif
  Local File KPYIMPHDR  [KPHX]
  Local File KPYIMPDTL  [KPDX]

  Local Integer J, L, OK, NBCOA, NBPOS, VLOT
  Local Decimal CRETOT, DEBTOT
  Local Char WOTHACC(GLONGAC), WMSG(250), WLOT(20), WMLOT(150)
  OK = 2

  If [F:KPH]FLGDET=1
    WMLOT=mess(201,104,1)
  # In a global mode, only a global validation can be done.
  Endif

  WMLOT=WMLOT - mess(191,104,1)

  ## Do you want to validate all records of this lot?
  Call OUINON(WMLOT,OK) From GESECRAN
  If OK<>2
    Read [KPHX]KPYH0=NUM
    If fstat=[V]CST_AOK
      If [F:KPHX]FLGDET=2  # When the payroll record is detailed can be validated only one
        ## Do you want to validate only this record?
        Call OUINON(mess(192,104,1),OK) From GESECRAN
        If OK<>2: OK = 0: End: Endif
        Gosub VALID_RECORD
      Endif
    Endif
  Else
    VLOT=1
  Endif
  If VLOT=1
    Read [KPHX]KPYH0=NUM
    If fstat=[V]CST_AOK
      WLOT=[F:KPHX]LOT
      Call OUVRE_TRACE(mess(3,904,1)) From LECFIC
      Call ECR_TRACE(mess(43,197,1)-WLOT,0) From GESECRAN
      Call ECR_TRACE(" ",0) From GESECRAN
      Gosub VALID_LOT
      Call LEC_TRACE From LECFIC
    Endif
  Endif

  Close File [KPHX], [KPDX]

  If WMSG<>"": Call ECR_TRACE(mess(198,124,1)-NUM+":"-WMSG,1) From GESECRAN:  Endif

End

######################################################################################
$VALID_RECORD
  Trbegin [KPHX]
    Read [F:KPHX]KPYH0=[F:KPH]RECID
    [F:KPHX]FLGVAL=2
    Rewrite [KPHX]
    If fstat
      Call ECR_TRACE(mess(198,124,1)-[F:KPHX]RECID-mess(100,107,1),0)  From GESECRAN #not validated
    Else
      Call ECR_TRACE(mess(198,124,1)-[F:KPHX]RECID-mess(157,100,1),0) From GESECRAN
    Endif

    Actzo [M:KPYH]FLGVAL: [M:KPYH]FLGVAL=2: Affzo [M:KPYH]FLGVAL: Diszo [M:KPYH]FLGVAL
    Commit

Return

######################################################################################
$VALID_LOT
  #For all payroll record with the same LOT number
  Trbegin [KPHX]
    Filter [KPHX] Where LOT=WLOT and FLGVAL<>2
    For [KPHX]KPYH0
      [F:KPHX]FLGVAL=2
      Rewrite [KPHX]
      If fstat
        Call ECR_TRACE(mess(198,124,1)-[F:KPHX]RECID-mess(100,107,1),0)  From GESECRAN #not validated
      Else
        Call ECR_TRACE(mess(198,124,1)-[F:KPHX]RECID-mess(157,100,1),0) From GESECRAN
      Endif
    Next

    Actzo [M:KPYH]FLGVAL: [M:KPYH]FLGVAL=2: Affzo [M:KPYH]FLGVAL: Diszo [M:KPYH]FLGVAL
    Commit

Return

######################################################################################
$CHECK_CUR
  Local File KPYIMPHDR [KPHX]
  Filter [KPHX] Where LOT=[F:KPH]LOT
  For [KPHX]
    I=find([F:KPHX]GRPGAS,GRPCUR)
    If I=0 : NBCUR+=1: GRPCUR(NBCUR)= [F:KPHX]GRPGAS: Endif
  Next
  Close File [KPHX]
Return

######################################################################################
$TR1
  Trbegin [KPHX]
 [F:KPHX]NUM = MESSAGE
 [F:KPHX]STA = 2
 Rewrite [KPHX]
 If STAT = 0
   Commit
 Else
   Rollback
 Endif

Return

######################################################################################
Subprog CTR_LINES(WGRP)
Value Char WGRP

  Local File KPYIMPHDR  [KPHX]
  Local File KPYIMPDTL  [KPDX]

  Local Integer WNBACC, WNBDIE, WNBCOA, WNBCCE, WMAXGAS, WMAXVTL, WNBLINE, WNBJE, K, J
  Local Char FLD(10)

  WMAXGAS=func AFNC.ACTIV("GAS")
  WMAXVTL=func AFNC.ACTIV("VTL")

  # Variables to control the lines of the accounts
  Local Char WNACC1(GLONGAC)(1..), WNACC2(GLONGAC)(1..), WNACC3(GLONGAC)(1..), WNACC4(GLONGAC)(1..), WNACC5 (GLONGAC)(1..)
  Local Char WNACC6(GLONGAC)(1..), WNACC7(GLONGAC)(1..), WNACC8(GLONGAC)(1..), WNACC9(GLONGAC)(1..), WNACC10(GLONGAC)(1..)

  # Variables to control the lines of the analytical dimensions
  Local Char WNCCE1(GLONCCE)(1..), WNCCE2(GLONCCE)(1..), WNCCE3(GLONCCE)(1..), WNCCE4(GLONCCE)(1..), WNCCE5 (GLONCCE)(1..)
  Local Char WNCCE6(GLONCCE)(1..), WNCCE7(GLONCCE)(1..), WNCCE8(GLONCCE)(1..), WNCCE9(GLONCCE)(1..), WNCCE10(GLONCCE)(1..)
  Local Char WNCCE11(GLONCCE)(1..),WNCCE12(GLONCCE)(1..),WNCCE13(GLONCCE)(1..),WNCCE14(GLONCCE)(1..),WNCCE15(GLONCCE)(1..)
  Local Char WNCCE16(GLONCCE)(1..),WNCCE17(GLONCCE)(1..),WNCCE18(GLONCCE)(1..),WNCCE19(GLONCCE)(1..),WNCCE20(GLONCCE)(1..)

  Trbegin [KPHX]

    Filter [KPHX] Where [F:KPHX]GRPGAS=WGRP   #Filtering all record of this group
    For [KPHX]
      WNBLINE+=1
      # Ckeking number of lines not upper to GAS limit
      For [KPDX] Where RECID=[F:KPHX]RECID
        For J=1 To 10
          FLD = "WNACC"+num$(J)
          K=find([F:KPDX]ACC(J-1),evalue(FLD))
          If K=0
            Assign "WNACC"+num$(J)+"("+num$(WNBLINE)+")" With [F:KPDX]ACC(J-1)
            WNBACC+=1
            If WNBACC=WMAXGAS : WNBJE+=1: Raz WNBACC: Break 2: Endif
          Endif
        Next
        #Cheking nmber of lines not upper to VTL limit
        For J=1 To 20
          FLD = "WNCCE"+num$(J)
          K=find([F:KPDX]CCE(J-1),evalue(FLD))
          If K=0
            Assign "WNCCE"+num$(J)+"("+num$(WNBLINE)+")" With [F:KPDX]CCE(J-1)
            WNBCCE+=1
          Endif
          If WNBCCE=WMAXVTL : WNBJE+=1: Raz WNBCCE: Break 2: Endif
        Next
      Next

      If WNBJE>0
        [F:KPHX]GRPGAS=[F:KPHX]GRPGAS+num$(WNBJE)
        Rewrite [KPHX]
      Endif
    Next

    Filter [KPHX]

  If WNBJE>0
    Commit
  Else
    Rollback
  Endif

  Close File [KPHX], [KPDX]

End

