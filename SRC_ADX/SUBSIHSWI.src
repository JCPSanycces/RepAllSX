######################################################################################################
# Module        : Sales
# Description   : Swiss specific initializations for sales invoices
######################################################################################################
 # Updates :
 # Date     |Author|Version|Description
######################################################################################################


$ACTION
Case ACTION
 When "SEL_TABLE"     : Gosub SEL_TABLE
 When Default
Endcase
Return


#############################################################################################
$SEL_TABLE
If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
Default File [BAN]
OBJET = "BAN"
CRITERE = 'CPY="'+num$(PARAM(1))+'" & (FCY = "' + num$(PARAM(2)) + '" | FCY="")'
Return


#############################################################################################
Subprog SHOW_HIDE_BVRFIELDS(FCY,INVTYP,PTE,CUR)
Value Char FCY
Value Integer INVTYP
Value Char PTE
Value Char CUR
Local Integer SHOW

If func AFNC.ACTIV("KSW") Then
    Gosub CHECK_SHOW
    If SHOW
      Chgfmt [M:SIH2]BVRREFNUM With "K:27X"
      Chgfmt [M:SIH2]PAYBAN With "K:5c"
    Else
      Raz [M:SIH2]BVRREFNUM               # clear field
      Raz [M:SIH2]PAYBAN                  # clear field
      Chgfmt [M:SIH2]BVRREFNUM With "-K:27X"
      Chgfmt [M:SIH2]PAYBAN With "-K:5c"
    Endif
    If !GIMPORT Affzo [M:SIH2]BVRREFNUM : Endif
    If !GIMPORT Affzo [M:SIH2]PAYBAN : Endif
Endif
End


#############################################################################################
Subprog CALC_PAYBAN(FCY,INVTYP,PTE,BPRPAY,CUR)
Value Char FCY
Value Integer INVTYP
Value Char PTE
Value Char BPRPAY
Value Char CUR
Local Integer SHOW

Gosub CHECK_SHOW
If SHOW
  [M:SIH2]PAYBAN = func SWILIB0.GET_PAYBAN([F:CPY]CPY,FCY,BPRPAY)
  # If paying bank is not found, display an error message
  If [M:SIH2]PAYBAN = ""
     GMESSAGE = mess(59,3648,1) # No paying bank for ISR generation could be determined.
     mkstat = 2 : End
  Endif
  Chgfmt [M:SIH2]BVRREFNUM With "K:27X"
  Chgfmt [M:SIH2]PAYBAN With "K:5c"
Else
  Raz [M:SIH2]BVRREFNUM               # clear field
  Raz [M:SIH2]PAYBAN                  # clear field
  Chgfmt [M:SIH2]BVRREFNUM With "-K:27X"
  Chgfmt [M:SIH2]PAYBAN With "-K:5c"
Endif
If !GIMPORT Affzo [M:SIH2]BVRREFNUM : Endif
If !GIMPORT Affzo [M:SIH2]PAYBAN : Endif
End


#############################################################################################
Subprog CONTROL_PAYBAN(CPY,FCY,PAYBAN)
Value Char CPY
Value Char FCY
Value Char PAYBAN
If PAYBAN <> ""
    Local Char P_SWICUSBVR(1) : P_SWICUSBVR = ""
    Call PARAM(FCY,"SWICUSBVR",P_SWICUSBVR) From ADOVAL
    If P_SWICUSBVR = "2"   # Parameter set
       If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
       Call LEC_BAN(PAYBAN) From CPTLEC
       If fstat=0
          If [F:BAN]CPY <> CPY
             GMESSAGE = func AFNC.MES2( mess(55,3648,1), PAYBAN,CPY)
                # The payment bank account $1$ does not belong to the company $2$.
             mkstat = 2 : End
          Endif
          If  ([F:BAN]FCY <> "" and [F:BAN]FCY <> FCY)
             GMESSAGE = func AFNC.MES2( mess(58,3648,1), PAYBAN,FCY)
                # The payment bank account $1$ does not belong to the site $2$.
             mkstat = 2 : End
          Endif
          If [F:BAN]BVRNUM = ""
             GMESSAGE = func AFNC.MES1( mess(57,3648,1), PAYBAN)
                # No ISR customer number given in bank account $1$. Please enter an ISR customer number in the bank account management.
             mkstat = 2
          Endif
       Endif
    Endif
Endif
End


#############################################################################################
Subprog CALC_BVRFIELDS(FCY,INVTYP,PTE,BPRPAY,CUR)
Value Char FCY
Value Integer INVTYP
Value Char PTE
Value Char BPRPAY
Value Char CUR
Local Integer SHOW

Gosub CHECK_SHOW
If SHOW
   If [F:SIH]AMTATI = 0 : SHOW = 0 : Endif   # no paying bank and ISR reference number if invoice amount = 0
Endif
GPOINT = "CALCBVRFIELDS" : Gosub ENTREE From EXEFNC                 # entry point to overwrite conditions for SHOW

If SHOW
  If [F:SIH]PAYBAN = ""                # paying bank not yet entered -> calculate it
     [F:SIH]PAYBAN = func SWILIB0.GET_PAYBAN([F:CPY]CPY,FCY,BPRPAY)
     # if paying bank is not found, display an error message
     If [F:SIH]PAYBAN = ""
        GMESSAGE = mess(59,3648,1) # No paying bank for ISR generation could be determined.
        GOK = 0 : GERR = 1 : End
     Endif
  Endif
  If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
  Call CONTROL_PAYBAN([F:CPY]CPY,FCY,[F:SIH]PAYBAN)  # if paying bank determined -> do additional checks
  If mkstat = 2 : GOK = 0 : GERR = 1 : End : Endif

  [F:SIH]BVRREFNUM = func SWILIB0.BUILD_BVRREFNUM(FCY,[F:BAN]BVRCUSTID,BPRPAY,[F:SIH]ACCDAT,[F:SIH]NUM) # calculate BVRREFNUM
Else
  Raz [F:SIH]BVRREFNUM               # clear field
  Raz [F:SIH]PAYBAN                  # clear field
Endif
End


#############################################################################################
# Check all conditions for showing or hiding fields BVRNUMREF and PAYBAN:
# 1. Parameter "SWICUSBVR" for site has to be set to "yes"
# 2. Invoice type must be "Invoice" (INVTYP = 1)
# 3. Currency of the invoice must be "CHF"
# 4. payment method of payment term must be of type "ISR print"
# If all conditions are true SHOW = 1 else SHOW = 0
#############################################################################################
$CHECK_SHOW
Local Char P_SWICUSBVR(1) : P_SWICUSBVR = ""
SHOW = 1
Call PARAM(FCY,"SWICUSBVR",P_SWICUSBVR) From ADOVAL
If P_SWICUSBVR <> "2"   # Parameter not set -> hide
   SHOW = 0
Else
   If INVTYP <> 1       # Invoice type <> "Invoice" -> hide
       SHOW = 0
   Else
      If CUR <> "CHF" and CUR <> ""  # Currency <> "CHF" -> hide ## angre 01.03.16 Currency is initaly "", so do not hide if empty
          SHOW = 0
      Else
          Local Char LEG(GLONADI) : Raz LEG
          Local Integer RET
          If GSOCIETE <> "" Then
             Local File COMPANY [CPY]
             Read [CPY]CPY0=GSOCIETE
             LEG = [F:CPY]LEG
          Endif
          If !clalev([F:TPT]) : Local File TABPAYTERM [TPT] : Endif   # payment terms
          If !clalev([F:TAM]) : Local File TABPAM [TAM]     : Endif   # payment methods
          Call LEC_TPT_LEG(LEG, PTE, 1, RET) From TRTLECLEG
          If RET Then
             # not found
          Else
              Call LEC_TAM([F:TPT]LEG, [F:TPT]PAM) From CPTLEC
              If !fstat
                 If [F:TAM]SWIPAMBVR <> 2  # payment method not of type "ISR printing" -> hide
                    SHOW = 0
                 Endif
              Endif
          Endif
      Endif
   Endif
Endif
Return

