#<AdxTL>@(#)10.0.0.0 $Revision$
##########################################################################################################
#  Sous programmes pour la gestion des ressources                        Module CRM     15 Décembre 2003 #
##########################################################################################################
#                                                                                                        #
#  SAVECLOB     : Enregistrement des CLOBs
#  DELCLOB      : Suppression des CLOBs
#  LOADCLOB     : Chargement du CLOB
#                                                                                                        #
##########################################################################################################
##########################################################################################################
#Enregistrement des CLOBs
######################################################
$SAVECLOB
  Gosub DELCLOB
  If GOK < 1 Then
    Return
  Endif
  If [M:RSS1]FULDES <>"" Then
    Raz [F:HD6]
    [F:HD6]NUM = [M:RSS1]NUMFULDES
    [F:HD6]TYP = [M:RSS1]TYPFULDES
    [F:HD6]CLOB = [M:RSS1]FULDES
    Write [HD6]
    If fstat Then
      #Erreur lors de l'enregistrement des caractéristiques de la ressource. Transaction abandonnée.
      GMESSAGE = mess(891,182,1)
      GERR = 1
      Call FSTA("HD6") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
Return

##########################################################################################################
#Suppression des CLOBs
######################################################
$DELCLOB
  Delete [HD6] Where [F:HD6]NUM = [M:RSS1]NUMFULDES and [F:HD6]TYP = [M:RSS1]TYPFULDES
  If fstat Then
    #Erreur lors de la suppression des caractéristiques de la ressource. Transaction abandonnée.
    GMESSAGE = mess(892,182,1)
    GERR = 1
    Call FSTA("HD6") From GLOCK
    GOK = 0
    Return
  Endif
Return

##########################################################################################################
# Chargement du CLOB
######################################################
$LOADCLOB
Local Integer ILOOKFORCLOB

  ILOOKFORCLOB = 1
  If [M:RSS1]NUMFULDES = "" Then
    Raz [M:RSS1]FULDES
    ILOOKFORCLOB = 0
  Endif
  If [M:RSS1]TYPFULDES = "" Then
    Raz [M:RSS1]FULDES
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB Then
    Read [HD6]HD60=[M:RSS1]NUMFULDES;[M:RSS1]TYPFULDES
    If fstat Then
      Raz [M:RSS1]FULDES
    Else
      [M:RSS1]FULDES = [F:HD6]CLOB
    Endif
  Endif
Return
