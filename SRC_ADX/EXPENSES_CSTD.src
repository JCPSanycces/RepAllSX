#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
  When ""
    Case [L]AEVENT
       When "AINSERT_CONTROL_BEFORE" : Gosub AINSERT_CONTROL_BEFORE
       When "AUPDATE_CONTROL_BEFORE" : Gosub AUPDATE_CONTROL_BEFORE
       When "AINSERT_CONTROL_AFTER"  : Gosub AINSERT_CONTROL_AFTER
       When "AUPDATE_CONTROL_AFTER"  : Gosub AUPDATE_CONTROL_AFTER
       When "AREAD_AFTER"            : Gosub AREAD_AFTER
       When "AINIT"                  : Gosub AINIT
       When "AINSERT_AFTER"          : Gosub AINSERT_AFTER
    Endcase
Endcase
Return

##########################################################################################################
#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
#Case [L]CURPRO
#    Case [L]ARULE
#    Endcase
#Endcase

Case [L]CURPRO
 When "DATEXS"     : Gosub DATEXS
 When "FCY"        : Gosub FCY
 When "CODEXP"     : Gosub CODEXP
 When "QTY"        : Gosub QTY
 When "CUR"        : Gosub CUR
 When "DES"        : Gosub DES
Endcase

Return

##########################################################################################################
#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "LOAD_TECPJT"   Gosub LOAD_TECPJT
  Endcase
Return


##########################################################################################################
#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return
##########################################################################################################

##########################################################################################################
## After pressing the Create button when the window is opened we load the DIMCEN collection
##########################################################################################################
$AINIT
# Load the collection DIMCEN
Local Integer I, NUMCUR
Local Char USRCLB(GLONBPR)
Local File AUTILIS[AUS]
Local File BPARTNER[BPR]
Read [AUS]CODUSR=this.ACTX.USER
If fstat=[V]CST_AOK
 USRCLB = fmet GACTX.APARAM.AGETUSERVALCHAR("EXPBPR")
 If USRCLB=""
  ASTATUS = fmet this.ASETERROR("",this.ACTX.USER-mess(43,129,1),[V]CST_AERROR)
  Return
 Else
  Read [BPR]BPR0=USRCLB
  If fstat | [F:BPR]BPRACC<>2
   ASTATUS = fmet this.ASETERROR("",this.ACTX.USER-mess(43,129,1),[V]CST_AERROR)
   Return
  Endif
 Endif
 I=0
 While [F:AUS]DIE(I)<>""
  NUMCUR = fmet this.ADDLINE("DIMCEN",[V]CST_ALASTPOS)
  this.DIMCEN(NUMCUR).DIE=[F:AUS]DIE(I)
  I+=1
 Wend
Endif
this.TYPRAT = 1
this.snapshotEnabled=1
Return

##########################################################################################################
## Assign the values by default to the properties of the EXS class before the controls of the properties
##########################################################################################################
$AINSERT_CONTROL_BEFORE
Local File EXPENSES  [EXP2]
this.CLB = this.ACTX.USER
# STA - Non comptabilisé
this.STA = 1
this.TYPRAT = 1
# ACCNUM
If this.ACCNUM=0 : Call ACCNUM(this.ACCNUM) : Endif
# NBREXS
For [EXP2] Where CLB=this.CLB & DATEXS=this.DATEXS
 this.NBREXS = max(this.NBREXS,[F:EXP2]NBREXS)
Next
this.NBREXS = max(1,this.NBREXS+1)
Return

## à tester this.ACCNUM = uniqid([F:XXX])
Subprog ACCNUM(NUMERO)
Variable Integer NUMERO
Local File EXPENSES [XXX]
NUMERO = uniqid([F:XXX])
End

##########################################################################################################
$AUPDATE_CONTROL_BEFORE
Local Integer I
Local Char    OLDLIG(250), NEWLIG(250)

# Update the VISA property
NEWLIG = this.FCY+this.DATEXS+this.CODEXP+num$(this.QTY)+num$(this.AMTATI)+this.CUR
&       +this.VAT+num$(this.CODEXPENS(1).RATDIV)+num$(this.CODEXPENS(1).RATMLT)+this.TAX1+this.TAX2
&       +num$(this.AMTTAX1)+num$(this.AMTTAX2)+num$(this.DEDVAT)+num$(this.DEDTAX1)
&       +num$(this.AMTVAT)+num$(this.DEDTAX2)

this.snapshotEnabled=1

OLDLIG = this.snapshot.FCY +this.snapshot.DATEXS+this.snapshot.CODEXP+num$(this.snapshot.QTY)
&       +num$(this.snapshot.AMTATI)+this.snapshot.CUR+this.snapshot.VAT+num$(this.CODEXPENS(1).snapshot.RATDIV)
&       +num$(this.CODEXPENS(1).snapshot.RATMLT)+this.snapshot.TAX1+this.snapshot.TAX2
&       +num$(this.snapshot.AMTVAT)+num$(this.snapshot.AMTTAX1)+num$(this.snapshot.AMTTAX2)
&       +num$(this.snapshot.DEDVAT)+num$(this.snapshot.DEDTAX1)+num$(this.snapshot.DEDTAX2)


For I=1 To maxtab(this.DIMCEN)
 If !find(this.DIMCEN(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & this.DIMCEN(I).DIE<>""
  NEWLIG +=this.DIMCEN(I).CCE
  OLDLIG +=this.DIMCEN(I).snapshot.CCE
 Endif
Next

If OLDLIG<>NEWLIG & this.VISA<>""
 this.VISA = this.ACTX.USER
Endif

Return

##########################################################################################################
## Assign the values by default to the properties of the EXS class after the controls of the properties
##########################################################################################################
$AINSERT_CONTROL_AFTER
$AUPDATE_CONTROL_AFTER
Local File TABEXPENS [TES]
Local File GACCOUNT  [GAC]
Local File GACCCODE  [CAC]
Local File AUTILIS   [AUS]
Local File GLED      [LED]
Local File COMPANY   [CPY]
Local File GACM      [GCM]
Local File TABVAT    [TVT]

# RATMLT & RATDIV
Gosub UPDATE_RATE

# Update the reimbursed amount before determinig the VAT
If func NOUPD_AMTATI or this.AMTATI=0
 Call CALCUL_AMTATI(this.AMTATI,this)
Endif

# VAT & tax amount
Gosub UPDATE_VAT

# Dimension type
## In the expense recording, if the CCE is set up as "can't be modified" then CCE is reset by default value
## In the mobile application, we can't set the attribute "" to CCE if the CCE is set up
## as "can't be modified" in the expense recording
Gosub INIT_CCE
Gosub CTL_CCE
Return

##########################################################################################################
## Assign the values by default to the properties of RATEXPENS collection
##########################################################################################################
$UPDATE_RATE
# maxtab(this.LNKRATLED)=maxtab(this.CODEXPENS)=len(mess(0,2644,1))
For I=1 To maxtab(this.LNKRATLED)
 If this.LNKRATLED(I).LIGLED>0
  this.CODEXPENS(I).RATDIV = this.RATEXPENS(this.LNKRATLED(I).LIGLED).RATDIV2
  this.CODEXPENS(I).RATMLT = this.RATEXPENS(this.LNKRATLED(I).LIGLED).RATMLT2
 Endif
Next
Return

##########################################################################################################
## Assign the values by default to the VAT properties
##########################################################################################################
$UPDATE_VAT
Local Char PLAN(GLONCOA)
Local Integer WRET

Call LECMAINPLAN(1,this.CPY,PLAN) From FINLIBINI
Read [TES]TES0=this.CODEXP
Call LEC_CAC(20,[F:TES]ACCCOD,PLAN) From CPTLEC
Call LEC_GAC([F:CAC]ACC(0),PLAN) From CPTLEC
Raz this.VAT
If [F:GAC]ACC="" | [F:GAC]FLGVAT>=2    # Compte  soumis à la TVA
 Call LEC_CPY(this.CPY) From CPTLEC
 Call LEC_TVT_LEG(GACTX,[F:CPY]LEG,[F:TES]VAT,WRET) From TRTLECLEG_SYRA
 If WRET=0 : this.LEGVAT = [F:TVT]LEG : Endif
 this.VAT = [F:TES]VAT
 Gosub CALTVA
Endif
Return


$CALTVA
Local Char    TAXES(GLONVAT)(1..3), MESSAGE(250)
Local Decimal MONTVAT(1..3) , MONTDED(1..3)
Local Integer TYPREG , STAT
Local Date    DATREF

TAXES(1) = this.TAX1
TAXES(2) = this.TAX2
TAXES(3) = this.VAT
DATREF   = this.DATEXS
Call CALTAXE(this.ACTX,this.CPY,DATREF,"",this.CUR,3,TAXES,2,this.AMTATI,MONTVAT,MONTDED,TYPREG,STAT) From LIBVATSYR
If STAT<>0
 Call  ERR_CALTAXE(STAT,MESSAGE) From LIBVATSYR
 ASTATUS = fmet this.ASETERROR("",MESSAGE,[V]CST_AERROR)
 Return
Endif
If TYPREG<>1
 Raz MONTVAT, MONTDED
Endif
this.AMTTAX1 = MONTVAT(1)
this.AMTTAX2 = MONTVAT(2)
this.AMTVAT  = MONTVAT(3)
this.DEDTAX1 = MONTDED(1)
this.DEDTAX2 = MONTDED(2)
this.DEDVAT  = MONTDED(3)
this.AMTCUR  = this.AMTATI-this.AMTTAX1-this.AMTTAX2-this.AMTVAT
Return



##########################################################################################################
## Load the RATEXPENS collection
##########################################################################################################
$AREAD_AFTER
Local Integer I
Local File COMPANY  [CPY]
Local File GACM     [GCM]
Local File TABVAT   [TVT]
Local Integer WRET

WRET = fmet this.LOAD_TECPJT()

Gosub LOAD_RATEXPENS
For I=1 To maxtab(this.LNKRATLED)
 If this.LNKRATLED(I).LIGLED>0
  this.RATEXPENS(this.LNKRATLED(I).LIGLED).RATDIV2 = this.CODEXPENS(I).RATDIV
  this.RATEXPENS(this.LNKRATLED(I).LIGLED).RATMLT2 = this.CODEXPENS(I).RATMLT
 Endif
Next

# Mise à jour LEGVAT
Call LEC_CPY(this.CPY) From CPTLEC
Call LEC_TVT_LEG(GACTX,[F:CPY]LEG,this.VAT,WRET) From TRTLECLEG_SYRA
If WRET=0 : this.LEGVAT = [F:TVT]LEG : Endif
Return

##########################################################################################################
## Create a recording in the EXPENSESH table if no record exists for the user
##########################################################################################################
$AINSERT_AFTER
Local Instance EXPENH Using C_EXPENSESH
EXPENH = NewInstance [EXPH] With C_EXPENSESH
If fmet EXPENH.AREAD(this.CLB)<> [V]CST_AOK
 Local File AUTILIS [AUS]
 Read [AUS]CODUSR = this.ACTX.USER
 If fstat=[V]CST_AOK
  # Don't use "this" before EXPENH. It's a local instance. It isn't a member of the EXPENSES class.
  EXPENH.CLB    = this.ACTX.USER
  EXPENH.ACSEXS = [F:AUS]ACSUSR
  ASTATUS = fmet EXPENH.AINSERT()
  If ASTATUS<>[V]CST_AOK
   # Insert method failed : Display an error message
   ASTATUS = fmet this.ASETERROR("",mess(157,123,1),[V]CST_AERROR)
  Endif
 Endif
Endif
FreeInstance [EXPH]
Return



##########################################################################################################
##########################################################################################################
####################################
$DATEXS
Case [L]ARULE
  When "CONTROL"   : Gosub DATEXS_CONTROL
  When "PROPAGATE" : Gosub DATEXS_PROPAGATE
Endcase
Return

$DATEXS_CONTROL
Local Integer OK
Local Char  MESSAGE (250)
Local Date DATSTR, DATEND
Local File AOBJET[AOB]
Read [AOB]ABREV="EXS"
If fstat=[V]CST_AOK & dim(this.DATEXS)>0
 If [F:AOB]MODULE = 2 #Comptabilité
  DATSTR = fmet this.ACTX.APARAM.AGETUSERVALDATE("CPTSTRDAT")
  DATEND = fmet this.ACTX.APARAM.AGETUSERVALDATE("CPTENDDAT")
 Elsif [F:AOB]MODULE = 3 #Tiers
 # ASTATUS = fmet this.ACTX.ACACHE.CLEAN()
  DATSTR  = fmet this.ACTX.APARAM.AGETUSERVALDATE("TRSSTRDAT")
  DATEND  = fmet this.ACTX.APARAM.AGETUSERVALDATE("TRSENDDAT")
 Endif
 Call CTLDATMOD([F:AOB]MODULE,this.DATEXS,this.CPY,DATSTR,DATEND,MESSAGE,OK) From FINLIBCTL
 If OK=0
  ASTATUS = fmet this.ASETERROR("DATEXS",MESSAGE,[V]CST_AERROR)
 Endif
Endif
Return

$DATEXS_PROPAGATE
this.RATDAT = this.DATEXS
Return

####################################
$FCY
Case [L]ARULE
 When "INIT"      : Gosub FCY_INIT
 When "CONTROL"   : Gosub FCY_CONTROL
 When "PROPAGATE" : Gosub FCY_PROPAGATE
Endcase
Return

$FCY_INIT
Local File AFCTFCT   [AFT]
Local File AMETUTI   [AME]
Local File AUTILIS   [AUS]
Read [F:AUS]=this.ACTX.USER
If [F:AUS]PRFFCT=""
 Read [AME]AME0 = [F:AUS]CODMET
 If fstat=[V]CST_AOK
  Read [AFT]AFT0 = [F:AME]PRFFCT
 Endif
Else
 Read [AFT]AFT0 = [F:AUS]PRFFCT
Endif
If fstat=[V]CST_AOK
 this.FCY=[F:AFT]FCYDEF(0)
Endif
Return


$FCY_CONTROL
Local Char    MESSAGE(250)
Local Integer OK
Call CONTBPRCPY(this.ACTX.USER,this.FCY,"","","F",MESSAGE,OK) From FINLIBCTL
If !OK
 ASTATUS = fmet this.ASETERROR("FCY",MESSAGE,[V]CST_AERROR)
Endif
Return

$FCY_PROPAGATE
Local Integer WRET
  WRET = fmet this.LOAD_TECPJT()
Return

####################################
$CODEXP
Case [L]ARULE
 When "CONTROL"   : Gosub CODEXP_CONTROL
Endcase
Return

$CODEXP_CONTROL
Local Char    MESSAGE(250)
Local Integer OK
Local Instance TABEXP Using C_TABEXPENS
TABEXP = NewInstance [TES] With C_TABEXPENS

ASTATUS = fmet TABEXP.AREAD(this.CODEXP)
If ASTATUS<>[V]CST_AOK : FreeInstance [TES] : Return : Endif
Call VERIF(TABEXP.GFY,this.FCY,this.CODEXP,MESSAGE,OK) From FINLIBCTL
If !OK
 ASTATUS = fmet this.ASETERROR("CODEXP",MESSAGE,[V]CST_AERROR)
Endif

Call CONTEXE(TABEXP.ACS,this.ACTX.USER,MESSAGE,OK) From FINLIBCTL
If !OK
 ASTATUS = fmet this.ASETERROR("CODEXP",MESSAGE,[V]CST_AERROR)
Endif

Call CTLVLYDAT(this.DATEXS,TABEXP.VLYSTR,TABEXP.VLYEND,MESSAGE,OK) From FINLIBCTL
If !OK
 ASTATUS = fmet this.ASETERROR("CODEXP",MESSAGE,[V]CST_AERROR)
Endif

FreeInstance [TES]
Return

####################################
$QTY
Case [L]ARULE
 When "INIT"      : Gosub QTY_INIT
Endcase
Return

$QTY_INIT
this.QTY = 1
Return

####################################
$CUR
Case [L]ARULE
 When "CONTROL"   : Gosub CUR_CONTROL
Endcase
Return

$CUR_CONTROL
Local Char    MESSAGE(250)
Local Integer OK
Call CONTDEV(this.CUR,this.RATDAT,MESSAGE,OK) From FINLIBCTL
If !OK
 ASTATUS = fmet this.ASETERROR("CUR",MESSAGE,[V]CST_AERROR)
Endif
Return

####################################
$DES
Case [L]ARULE
 When "CONTROL" : Gosub DES_CONTROL
Endcase
Return

$DES_CONTROL
If this.DES=""
 Local File TABEXPENS [TES]
 Read [TES]TES0 = this.CODEXP
 If fstat=[V]CST_AOK & [F:TES]DESFLG=2
  ASTATUS = fmet this.ASETERROR("DES",mess(4,129,1),[V]CST_AERROR)
 Endif
Endif
Return


##########################################################################################################
# LABELS
##########################################################################################################

$INIT_CCE
## Reset CCE if the dimension type (DIE) doesn't belong to one of the legder of the account core model
## or if the dimension type doesn't belong to the account
Local Integer I, J, OK, RES1, RES2
Read [TES]TES0 = this.CODEXP
If fstat=[V]CST_AOK
 For I=1 To maxtab(this.DIMCEN)
  If this.DIMCEN(I)<>null & this.DIMCEN(I).DIE<>"" & !find(this.DIMCEN(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
    OK = 0
    For J=1 To maxtab(this.CODEXPENS)
     If this.CODEXPENS(J)<>null & !find(this.CODEXPENS(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
      Read [LED]LED0=this.CODEXPENS(J).LED
      If fstat=[V]CST_AOK
       If find(this.DIMCEN(I).DIE,[F:LED]DIE)
        Call LEC_GAC(this.CODEXPENS(J).ACC,this.CODEXPENS(J).COA) From CPTLEC
        If fstat=[V]CST_AOK & find(this.DIMCEN(I).DIE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
         OK = 1
        Endif
       Endif
      Endif
     Endif
    Next
    If OK=0 : this.DIMCEN(I).CCE="" : Endif
   Endif
   If OK=1
    # CCE initialized from the CCE of the expense
    RES1 = find(this.DIMCEN(I).DIE,[F:TES]DIE)
    If RES1 & ([F:TES]CCEFLG(RES1-1)=1 | this.DIMCEN(I).CCE="")
     Case num$([F:TES]INICCE(RES1-1))
      When "1" : this.DIMCEN(I).CCE = [F:TES]CCE(RES1-1)
      When "2" : Read[AUS]CODUSR=this.ACTX.USER
                 RES2 = find(this.DIMCEN(I).DIE,[F:AUS]DIE)
                 If RES2
                  this.DIMCEN(I).CCE = [F:AUS]CCE(RES2-1)
                 Endif
     Endcase
    Endif
   Endif
  Next
Endif
Return

####################################
$CTL_CCE
Local Integer OK, I ,J
Local Char  MESSAGE (250)
For J=1 To maxtab(this.DIMCEN)
 If this.DIMCEN(J)<>null & this.DIMCEN(J).DIE<>"" & !find(this.DIMCEN(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)
  For I=1 To maxtab(this.CODEXPENS)
   If !find(this.CODEXPENS(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL) & this.CODEXPENS(I).LED<>""
    [L]ASTATUS = func FINCCE_SYRA.CTL_CCEACCSYRA(GACTX,this.DIMCEN,this.DIMCEN(J).CCE,this.CODEXPENS(I).LED,
&                this.DIMCEN(J).DIE,this.FCY,this.DATEXS,this.CODEXPENS(I).ACC,"",this.CPY,MESSAGE)
    If [L]ASTATUS=[V]CST_AERROR
     [L]ASTATUS = fmet this.ASETERROR("DIMCEN.CCE",MESSAGE,[V]CST_AERROR)
    Endif
   Endif
  Next I
 Endif
Next J
Return

####################################
$LOAD_CODEXPENS
Local Integer I
# A tester
# Delete For i=maxtab(this.CODEXPENS) to 1
#  NUMCUR = fmet this.ADELLINE("CODEXPENS",I)
#  If NUMCUR = [V]CST_ANOTDEFINED : Break : Endif

# In an INSERT action, maxtab(this.CODEXPENS)=0
If maxtab(this.CODEXPENS)=0
 For I=1 To len(mess(0,2644,1))
  NUMCUR = fmet this.ADDLINE("CODEXPENS",[V]CST_ALASTPOS)
 Next
Endif

# Load properties LED  CURLED COA ACC
Read [GCM]GCM0=[F:CPY]ACM
If fstat=[V]CST_AOK
 For I=1 To len(mess(0,2644,1))
  Read [LED]LED0=[F:GCM]LED(I-1)
  If fstat=[V]CST_AOK
   this.CODEXPENS(I).LED    = [F:GCM]LED(I-1)
   this.CODEXPENS(I).CURLED = [F:GCM]CUR(I-1)
   this.CODEXPENS(I).COA    = [F:LED]COA
   Raz this.CODEXPENS(I).ACC, this.CODEXPENS(I).RATMLT,this.CODEXPENS(I).RATDIV
  Else
   Raz this.CODEXPENS(I).LED,this.CODEXPENS(I).CURLED,this.CODEXPENS(I).COA
   Raz this.CODEXPENS(I).ACC, this.CODEXPENS(I).RATMLT,this.CODEXPENS(I).RATDIV
  Endif
 Next
Endif
Return

####################################
$LOAD_RATEXPENS
# Bug CCL 88520 : On doit pouvoir afficher/cacher la collection
Local Integer J,K,NUMCUR
Local Decimal COURS, TYPCOURS
Local Char    DEVLED(GLONCUR), DEVTRS(GLONCUR)
Local Integer CURFLG
Local Libelle LEDFLG(1..len(mess(0,2644,1)))
Local Char    EURO(GLONCUR)
Local Date    DATCOURS
Local Integer STAT
Local Decimal COURMUL, COURDIV
Local Integer DECRCU

DATCOURS = this.RATDAT
EURO     = fmet this.ACTX.APARAM.AGETVALCHAR(1,"","EURO")
DEVTRS   = this.CUR
TYPCOURS = 1
DECRCU   = fmet this.ACTX.APARAM.AGETVALNUM(1,"","DECRCU")

Call SETFLGDEV(this.CUR,this.CPY,DATCOURS,CURFLG,LEDFLG) From FINLIBINI

Read [CPY]CPY0=this.CPY
If fstat=[V]CST_AOK
 Read [GCM]GCM0=[F:CPY]ACM
Endif

# Delete RATEXPENS
For J=1 To maxtab(this.RATEXPENS)
 NUMCUR = fmet this.ADELLINE("RATEXPENS",1)
Next

# Update LNKRATLED
If maxtab(this.LNKRATLED)=0
 For J=1 To len(mess(0,2644,1))
  NUMCUR = fmet this.ADDLINE("LNKRATLED",[V]CST_ALASTPOS)
 Next
Else
 For J=1 To len(mess(0,2644,1))
  Raz this.LNKRATLED(J).LIGLED
 Next
Endif

# Update RATEXPENS
For J=1 To len(mess(0,2644,1))
 DEVLED = [F:GCM]CUR(J-1)
 # ledger currency <> expense currency
 If [F:GCM]LED(J-1)<>"" & DEVLED<>DEVTRS
  K = find(DEVLED,this.RATEXPENS(1..maxtab(this.RATEXPENS)).CURLED2)
  #FLGVCRRAT = type cours document = Document rate type
  If J=1 or [F:GCM]FLGVCRRAT(J-1)=1 or ([F:GCM]FLGVCRRAT(J-1)=2 & !K)
   NUMCUR = fmet this.ADDLINE("RATEXPENS",[V]CST_ALASTPOS)
   this.RATEXPENS(NUMCUR).LIBLED = mess(J,2644,1)
   this.RATEXPENS(NUMCUR).LEDTYP = J
   this.LNKRATLED(J).LIGLED      = NUMCUR
   this.RATEXPENS(NUMCUR).CURTRS = DEVTRS
   If CURFLG=2 & DEVTRS<>EURO & LEDFLG(J)=1 : this.RATEXPENS(NUMCUR).CURTRS=EURO : Endif
   this.RATEXPENS(NUMCUR).CURLED2 = DEVLED
   If CURFLG=1 & DEVLED<>EURO & LEDFLG(J)=2 : this.RATEXPENS(NUMCUR).CURLED2=EURO : Endif
  Elsif [F:GCM]FLGVCRRAT(J-1)=2 & K : # Document rate type = 'Yes'
   this.RATEXPENS(K).LIBLED = "*"
   this.LNKRATLED(J).LIGLED = K
  Endif
  If [F:GCM]FLGVCRRAT(J-1)=2 : # Document rate type = 'Yes'
   COURS = TYPCOURS
  Else
   COURS = [F:GCM]TYPRAT(J-1)
  Endif

  Call INI_COURS2(DEVTRS,DEVLED,COURS,DATCOURS,COURDIV,COURMUL,STAT) From FINLIBINI

  Case [F:GCM]DACRAT(J-1)
   When 1 : # Multiplicateur
    If STAT
     this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATMLT1 = 0
     this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATDIV1 = 1
    Else
     this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATMLT1 = arr(COURMUL/COURDIV,10^-DECRCU)
     this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATDIV1 = 1
    Endif
    this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATDIV2 = 1
    this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATMLT2 = this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATMLT1
   When 2 : # Diviseur
     If STAT
      this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATDIV1 = 0
      this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATMLT1 = 1
     Else
      this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATDIV1 = arr(COURDIV/COURMUL,10^-DECRCU)
      this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATMLT1 = 1
     Endif
     this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATMLT2 = 1
     this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATDIV2 = this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATDIV1
    When 3 : # Les 2
     If STAT
      this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATMLT1 = 0
      this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATDIV1 = 0
     Else
      this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATMLT1 = COURMUL
      this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATDIV1 = COURDIV
     Endif
     this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATMLT2 = this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATMLT1
     this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATDIV2 = this.RATEXPENS(this.LNKRATLED(J).LIGLED).RATDIV1
  Endcase
 Endif
Next
Return

####################################
Subprog CALCUL_AMTATI(MNT,EXPEN)
Variable    Decimal  MNT
Variable    Instance EXPEN Using OBJECT

Local Integer STAT
Local Char    DEVCUR (GLONCUR)
Local Char TYPCOU(10)

Local File TABCUR    [TCU]
Local File TABEXPENS [TES]
Local File EXPARAM   [EXM]
Local File COMPANY   [CPY]

DEVCUR  = fmet EXPEN.ACTX.APARAM.AGETVALCHAR(1,"","CURSHRFLD")
If DEVCUR=""
 DEVCUR  = fmet EXPEN.ACTX.APARAM.AGETVALCHAR(1,"","SYSCUR")
Endif

# Calcul par rapport au code tâche
Read [TES]TES0 = EXPEN.CODEXP

Case [F:TES]TYPVLT
 When 1 : # Valorisation du code frais = Valeur fixe
   If DEVCUR=EXPEN.CUR
    # Même devise entre la note de frais et la devise reporting
    If [F:TES]VLTPFDUNI>0 & EXPEN.AMTPAY>[F:TES]VLTPFDUNI*EXPEN.QTY
     # Montant plafonné
     MNT = [F:TES]VLTPFDUNI*EXPEN.QTY
    Else
     # Montant remboursé = montant réel
     MNT = EXPEN.AMTPAY
    Endif
   Else
    # La devise de la note de frais est différente de la devise reporting
    If [F:TES]VLTPFDUNI>0
     # Montant plafonné
     Local Decimal PFDCUR
     Read [CPY]CPY0 = EXPEN.CPY
     TYPCOU = fmet EXPEN.ACTX.APARAM.AGETVALCHAR(3,EXPEN.FCY,"CNSTYPCUR")
     Call CONVERT3(EXPEN.ACTX,DEVCUR,EXPEN.CUR,[F:CPY]ACCCUR,val(TYPCOU),EXPEN.DATEXS,
&                  [F:TES]VLTPFDUNI,PFDCUR,0,STAT) From FINLIBINI
     If EXPEN.AMTPAY>PFDCUR*EXPEN.QTY
      MNT = PFDCUR*EXPEN.QTY
     Else
      MNT = EXPEN.AMTPAY
     Endif
    Else
     MNT = EXPEN.AMTPAY
    Endif
   Endif

 When 2 : # Valorisation du code frais = Valeur utilisateur
   Local Decimal PFDPAR : # Plafond
   PFDPAR = fmet EXPEN.ACTX.APARAM.AGETUSERVALNUM([F:TES]VLTPFDPAR)
   If DEVCUR=EXPEN.CUR
    # Même devise entre la note de frais et la devise reporting
    If PFDPAR>0 & EXPEN.AMTPAY>PFDPAR*EXPEN.QTY
     # Montant plafonné
     MNT = PFDPAR*EXPEN.QTY
    Else
     # Montant remboursé = montant réel
     MNT = EXPEN.AMTPAY
    Endif
   Else
    # La devise de la note de frais est différente de la devise reporting
    If PFDPAR>0
     # Montant plafonné
     Local Decimal PFDCUR
     Read [CPY]CPY0 = EXPEN.CPY
     TYPCOU = fmet EXPEN.ACTX.APARAM.AGETVALCHAR(3,EXPEN.FCY,"CNSTYPCUR")
     Call CONVERT3(EXPEN.ACTX,DEVCUR,EXPEN.CUR,[F:CPY]ACCCUR,val(TYPCOU),EXPEN.DATEXS,
&                  PFDPAR,PFDCUR,0,STAT) From FINLIBINI
     If EXPEN.AMTPAY>PFDCUR*EXPEN.QTY
      MNT = PFDCUR*EXPEN.QTY
     Else
      MNT = EXPEN.AMTPAY
     Endif
    Else
     MNT = EXPEN.AMTPAY
    Endif
   Endif

 When 3 : # Valorisation du code frais = Frais kilométriques
   Local Integer MILPAR, VHLPAR
   MILPAR = fmet EXPEN.ACTX.APARAM.AGETUSERVALNUM("EXPMIL")
   VHLPAR = fmet EXPEN.ACTX.APARAM.AGETUSERVALNUM("EXPVHL")
   Read [EXM]EXM0=MILPAR;VHLPAR
   If fstat=[V]CST_AOK
    If DEVCUR=EXPEN.CUR
     MNT = [F:EXM]INDRAT*EXPEN.QTY
    Else
     Read [CPY]CPY0 = EXPEN.CPY
     TYPCOU = fmet EXPEN.ACTX.APARAM.AGETVALCHAR(3,EXPEN.FCY,"CNSTYPCUR")
     Call CONVERT3(EXPEN.ACTX,DEVCUR,EXPEN.CUR,[F:CPY]ACCCUR,val(TYPCOU),EXPEN.DATEXS,
&                  [F:EXM]INDRAT*EXPEN.QTY,MNT,0,STAT) From FINLIBINI
    Endif
   Endif
Endcase

If MNT<>0
 If [F:TCU]CUR<>EXPEN.CUR
  Read [TCU]TCU0 = EXPEN.CUR
 Endif
 MNT = arr(MNT,[F:TCU]CURRND)
Endif
End

####################################
Subprog CALCUL_AMTPAY(MNT,EXPEN)
Variable    Decimal  MNT
Variable    Instance EXPEN Using OBJECT

If MNT<>0 : End : Endif

Local Integer STAT
Local Char    DEVCUR(GLONCUR)
Local Decimal DEFCUR
Local Char TYPCOU(10)

Local File TABEXPENS [TES]
Local File COMPANY   [CPY]

DEVCUR  = fmet EXPEN.ACTX.APARAM.AGETVALCHAR(1,"","CURSHRFLD")
If DEVCUR=""
 DEVCUR  = fmet EXPEN.ACTX.APARAM.AGETVALCHAR(1,"","SYSCUR")
Endif

Read [TES]TES0 = EXPEN.CODEXP

Case [F:TES]TYPVLT
 When 1 : # Valorisation du code frais = Valeur fixe
   # Même devise entre la note de frais et la devise reporting => Valeur par défaut*qté
   If DEVCUR=EXPEN.CUR
    MNT = [F:TES]VLTDEFUNI*EXPEN.QTY
   Else
    # La devise de la note de frais est différente de la devise reporting
    Read [CPY]CPY0 = EXPEN.CPY
    TYPCOU = fmet EXPEN.ACTX.APARAM.AGETVALCHAR(3,EXPEN.FCY,"CNSTYPCUR")
    Call CONVERT3(EXPEN.ACTX,DEVCUR,EXPEN.CUR,[F:CPY]ACCCUR,val(TYPCOU),EXPEN.DATEXS,
&                [F:TES]VLTDEFUNI,DEFCUR,0,STAT) From FINLIBINI
    MNT = DEFCUR*EXPEN.QTY
   Endif
  When 2 : # Valorisation du code frais = Valeur utilisateur
   Local Decimal DEFPAR
   DEFPAR = fmet EXPEN.ACTX.APARAM.AGETUSERVALNUM([F:TES]VLTDEFPAR)
   # Même devise entre la note de frais et la devise reporting => Valeur par défaut*qté
   If DEVCUR=EXPEN.CUR
    MNT = DEFPAR*EXPEN.QTY
   Else
    # La devise de la note de frais est différente de la devise reporting
    Read [CPY]CPY0 = EXPEN.CPY
    TYPCOU = fmet EXPEN.ACTX.APARAM.AGETVALCHAR(3,EXPEN.FCY,"CNSTYPCUR")
    Call CONVERT3(EXPEN.ACTX,DEVCUR,EXPEN.CUR,[F:CPY]ACCCUR,val(TYPCOU),EXPEN.DATEXS,
&                 DEFPAR,DEFCUR,0,STAT) From FINLIBINI
    MNT= DEFCUR*EXPEN.QTY
   Endif
Endcase

End


##########################################################################################################
## Return 1 if the user doesn't have the authorization to modify the AMTATI amount
## Return 0 if the user has the authorization to modify the AMTATI amount
##########################################################################################################
Funprog NOUPD_AMTATI

Local File AUTILIS   [AUS]
Local File AFCTFCT   [AFT]
Local File AFONCTION [AFC]
Local File AFCTPRF   [AFP]
Local File AFCTFCY   [AFF]

Read [AUS]CODUSR=GACTX.USER
If fstat<>[V]CST_AOK : End 0 : Endif
Read [AFT]AFT0=[F:AUS]PRFFCT
# Authorization for all functions
If fstat<>[V]CST_AOK | [F:AFT]ALLFCT=2 : End 0 : Endif

Read [AFC]CODINT="GESEXS"
If fstat<>[V]CST_AOK : End 0 : Endif
If [F:AFC]FCYAUZ<>2
 # Authorization site = No
 Read[AFP]AFP0=[F:AUS]PRFFCT;"GESEXS";""
 If fstat<>[V]CST_AOK | [F:AFP]OPT<>1
  End 1
 Endif
Else
 # Authorization site = yes
 If dim(this.FCY)>0
  Read [AFF]AFF0=this.FCY;[F:AUS]PRFFCT;"GESEXS"
 Else
  Read [AFF]AFF0="";[F:AUS]PRFFCT;"GESEXS"
 Endif
 If fstat<>[V]CST_AOK | !instr(1,[F:AFF]OPT,"1")
  End 1
 Endif
Endif
End 0

####################################################################################################
$LOAD_TECPJT
# X3_25696
Local Integer NLINE

  [L]ARET_VALUE = [V]CST_AOK
  # -----------------------------------
  If this.TECPJT = null Then
    NLINE = fmet this.ADDLINE("TECPJT",[V]CST_ALASTPOS)
  Endif
  this.TECPJT.IMODULE      = 3
  this.TECPJT.SFROM        = AVOID.ACHAR                  # Used only for SQH/SOH/SIH
  this.TECPJT.IBOOCRM      = [V]CST_ANO
  this.TECPJT.IBOOPJM      = [V]CST_AYES
  this.TECPJT.IBOOPJMBUD   = [V]CST_AYES
  this.TECPJT.IBOOPJMTAC5  = [V]CST_AYES
  this.TECPJT.IBOOPJMTAC6  = [V]CST_AYES
  this.TECPJT.IBOOPJMTAC7  = [V]CST_AYES
  this.TECPJT.IUSEDISPJM   = [V]CST_ANO
  this.TECPJT.IUSEDISBUD   = [V]CST_ANO
  this.TECPJT.IUSEDISTAC   = [V]CST_ANO
  this.TECPJT.SSITE        = this.FCY
  this.TECPJT.SSOCIETE     = AVOID.ACHAR
  this.TECPJT.SBPR         = AVOID.ACHAR
  this.TECPJT.SAIN         = AVOID.ACHAR
  this.TECPJT.SPJTFLDH     = AVOID.ACHAR
  this.TECPJT.SCOLLECTION  = AVOID.ACHAR
  this.TECPJT.SPJTFLDD     = AVOID.ACHAR
  this.TECPJT.TCHSNGDOCANS = [V]CST_AYES         # 1 : NO
                                                 # 2 : Yes
                                                 # 3 : Yes if same value
  # -----------------------------------
Return

