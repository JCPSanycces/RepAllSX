#<AdxTL>@(#)7.0.0.0 $Revision$
#--------------------------------------------------------------------------
#                       Budgets Opérationnels
#--------------------------------------------------------------------------
#   Objet    : BUT
#   Fonction : GESBUT - Type de budget
#   Action   : GOBJET
#   Ecran concerné : BUT1
#   Description : Définition de type de budget pour les budgets opérationnels
#                 
#--------------------------------------------------------------------------

Raz GPILOBJ
Call OBJET("BUT",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"        :  Gosub OUVRE
 When "LIENS"        :  Gosub LIENS
 When "CREATION"     :  Gosub CREATION 
 When "INICRE"       :  Gosub INICRE
 When "INIMOD"       :  Gosub INIMOD
 When "MODIF"        :  Gosub MODIF 
 When "AP_CHANGE"    :  Gosub AP_CHANGE
 When "ANNULE"       :  Gosub ANNULE
 When "FERME"        :  Gosub FERME
 When Default
Endcase
Return

$OUVRE
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$LIENS
GCURLEG = [F:BUT]LEG
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
Call LECTEXTRA([M:BUT1]DESTRA,"BUDTYP","DESTRA",[M:BUT1]BUDCOD,"") From ATEXTRA
Call LECTEXTRA([M:BUT1]SHOTRA,"BUDTYP","SHOTRA",[M:BUT1]BUDCOD,"") From ATEXTRA
Return

$INICRE
$INIMOD
If func AFNC.ACTIV("LEG")=0
 [F:BUT]LEG=GDOSLEG(1)
Endif
Return

$CREATION
$MODIF
Gosub TEXTRA
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("BUDTYP","DESTRA",CLECUR1,"","BUDTYP","DESTRA",[M:BUT1]BUDCOD,"")  From ATEXTRA
 Call DUPTEXTRA("BUDTYP","SHOTRA",CLECUR1,"","BUDTYP","SHOTRA",[M:BUT1]BUDCOD,"")  From ATEXTRA
Endif
Call MAJTEXTRA([M:BUT1]DESTRA,"BUDTYP","DESTRA",[M:BUT1]BUDCOD,"") From ATEXTRA
Call MAJTEXTRA([M:BUT1]SHOTRA,"BUDTYP","SHOTRA",[M:BUT1]BUDCOD,"") From ATEXTRA
Return

$AP_CHANGE
Call CHGTEXTRA("BUDTYP","DESTRA",[M:BUT1]BUDCOD,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("BUDTYP","SHOTRA",[M:BUT1]BUDCOD,"",NCODE,"") From ATEXTRA
Return

$ANNULE
# Annulation des Textes Traduisibles
Call SUPTEXTRA("BUDTYP","DESTRA",[M:BUT1]BUDCOD,"") From ATEXTRA
Call SUPTEXTRA("BUDTYP","SHOTRA",[M:BUT1]BUDCOD,"") From ATEXTRA
Return

$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

######################################################################################
## Etiquette de l'écran BUT1
######################################################################################

Subprog C_COU(VALEUR)
Variable Char    VALEUR()
If [M]MANCOU=1 & VALEUR=""
 #Zone obligatoire
 GMESSAGE=mess(10,123,1) 
 mkstat=2
Endif
If VALEUR<>""
 Local File ACODNUM [ANM]
 Read [ANM]ANM0=VALEUR
 If!fstat
  If [F:ANM]LNG>GLONENV
   #Compteur incorrect, longueur supérieure au type de donnée associé! / Le nombre de caratère est limité à
   GMESSAGE=mess(223,199,1)+chr$(10)+"("+mess(76,126,1)-num$(GLONENV)+")"
   mkstat=2
  Endif
 Endif
Endif
End

Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG = VALEUR
End

Subprog C_GFY(VALEUR)
Variable Char    VALEUR()
Local Shortint STAT
Local Char MESSA(250)
Call CNTCOHGRPLEG(VALEUR,GCURLEG,STAT,MESSA) From CPTCNT
If !STAT
 GMESSAGE=MESSA
 mkstat=2 : End
Endif
End


######################################################################################

