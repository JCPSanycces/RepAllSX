#<AdxTL>@(#)5.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires pour la gestion des queues
#
#   LOADFAMQUE   : Chargement des compétences.
#   SAVEFAMQUE   : Enregistrement des compétences.
#   DELPBLLINE   : Effacement d'une ligne de compétence.
#   SAVECLOB     : Enregistrement des CLOBs
#   DELCLOB      : Suppression des CLOBs
#   LOADCLOB     : Chargement du CLOB
#
#############################################################################################

##########################################################################################################
# Chargement des tableaux
###########################################################
$LOADFAMQUE
Local Integer IINDICE

  IINDICE = 0
  Filter [PBQ] Where [F:PBQ]QUENUM = [M:QUE0]NUM and [F:PBQ]STTFLG = 0
  For [PBQ] PBQ1
    [M:QUE2]PBLGRP(IINDICE) = [F:PBQ]GRPPBLNUM
    If [M:QUE2]PBLGRP(IINDICE) = "" Then
      [M:QUE2]PBLCLA(IINDICE) = ""
    Else
      Read [PBL]PBL0=[M:QUE2]PBLGRP(IINDICE)
      If fstat Then
        [M:QUE2]PBLCLA(IINDICE) = ""
      Else
        # FGR 23/09/2009 : X3SUIVI58024
        #[M:QUE2]PBLCLA(IINDICE) = [F:PBL]GRPPBLDES
        Call LECTEXTRA([M:QUE2]PBLCLA(IINDICE),"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
      Endif
    Endif
    IINDICE = IINDICE + 1
  Next
  Filter [PBQ]
  [M:QUE2]NBLIG = IINDICE
Return

##########################################################################################################
# Gestion du tableau des queues concernées.
#####################################################################
$SAVEFAMQUE
Local Integer IINDICE
Local Integer IINDICETAB
Local Integer IBTROUVE
Local Integer IBDELETE

  IINDICE = 0
  IBTROUVE = 0
  IBDELETE = 0
  #suppression des lignes supprimer
  If INBTAB_PBLGRP > 0 and [M:QUE0]NUM <> "" Then
    For IINDICETAB = 0 To INBTAB_PBLGRP-1  
      IBDELETE=0
      IBTROUVE=0
      If SZTAB_PBLGRP(IINDICETAB) <> "" Then
        IINDICE = 0
        While IINDICE < [M:QUE2]NBLIG
          If [M:QUE2]PBLGRP(IINDICE) = SZTAB_PBLGRP(IINDICETAB) Then
            IBTROUVE = 1
            Break
          Endif
          IINDICE = IINDICE + 1
        Wend
      Endif
      If IBTROUVE = 0 Then
        IBDELETE = 1
      Endif
      If IBDELETE = 1 Then
        Read [PBQ]PBQ2=SZTAB_PBLGRP(IINDICETAB);[M:QUE0]NUM
        If fstat = 0 Then
          If [F:PBQ]SRECOU <= 0 Then
            Delete [PBQ] Where [F:PBQ]GRPPBLNUM=SZTAB_PBLGRP(IINDICETAB) and [F:PBQ]QUENUM=[M:QUE0]NUM  
            If fstat <> 0 Then
              #Erreur lors de la suppression de la famille de compétence
              GMESSAGE = mess(725,182,1)
              GOK = 0
              Break
            Endif
          Else
            Readlock [PBQ]PBQ2=SZTAB_PBLGRP(IINDICETAB);[M:QUE0]NUM
            If fstat <> 0 Then
              #Erreur lors de la suppression de la famille de compétence
              GMESSAGE = mess(725,182,1)
              GOK = 0
              Break
            Else
              [F:PBQ]STTFLG = 1
              Rewrite [PBQ]
              If fstat <> 0 Then
                #Erreur lors de la suppression de la famille de compétence
                GMESSAGE = mess(725,182,1)
                GOK = 0
                Break
              Endif
            Endif
          Endif
        Endif
      Endif
    Next
  Endif
  If GOK < 1 Then
    Return
  Endif
  #Enregistrement des lignes saisies
  For IINDICE = 0 To [M:QUE2]NBLIG-1
    If [M:QUE2]PBLGRP(IINDICE) <> "" Then
      Read [PBQ]PBQ2=[M:QUE2]PBLGRP(IINDICE);[M:QUE0]NUM
      If fstat Then
        #Il s'agit d'un nouvel enregistrement
        [F:PBQ]GRPPBLNUM = [M:QUE2]PBLGRP(IINDICE)
        [F:PBQ]QUENUM = [M:QUE0]NUM
        # FGR 23/09/2009 : X3SUIVI58037
        #[F:PBQ]QUENAM = [M:QUE0]TTR
        Call LECTEXTRA([F:PBQ]QUENAM,"QUEUE","QUEDESAXX",[F:QUE]NUM,"") From ATEXTRA
        [F:PBQ]SRECOU = 0
        [F:PBQ]STTFLG = 0
        Write [PBQ]
        If fstat Then
          #L'enregistrement des familles de compétence a échoué.
          GMESSAGE = mess(723,182,1)
          GERR = 1
          GOK = 0
          Break
        Endif
      Else
        Readlock [PBQ]PBQ2=[M:QUE2]PBLGRP(IINDICE);[M:QUE0]NUM
        If fstat Then
          #L'enregistrement des familles de compétence a échoué pour cause de verrouillage tiers.
          # Transaction abandonnée
          GMESSAGE = mess(724,182,1)
          GERR = 1
          GOK = 0
          Break
        Else
          [F:PBQ]STTFLG = 0
          Rewrite [PBQ]
          If fstat
            #L'enregistrement des familles de compétence a échoué.
            GMESSAGE = mess(723,182,1)
            GERR = 1
            GOK = 0
            Break
          Endif
        Endif
      Endif
    Endif
  Next
Return

##########################################################################################################
$RAZ_SZTAB_PBLGRP

  Raz SZTAB_PBLGRP
  Raz INBTAB_PBLGRP
Return

##########################################################################################################
$LOAD_SZTAB_PBLGRP
  Local Integer  IINDICE

  Gosub RAZ_SZTAB_PBLGRP
  ILIGNE = 0
  While ILIGNE < [M:QUE2]NBLIG
    If [M:QUE2]PBLGRP(ILIGNE) <> "" Then
      SZTAB_PBLGRP(INBTAB_PBLGRP) = [M:QUE2]PBLGRP(ILIGNE)
      INBTAB_PBLGRP = INBTAB_PBLGRP + 1
    Endif
    ILIGNE = ILIGNE + 1
  Wend
Return

##########################################################################################################
#Suppression de toutes les familles concernés
DEL_ALLPBQ
  For IINDICE = 0 To [M:QUE2]NBLIG-1
    If [M:QUE2]PBLGRP(IINDICE) <> "" Then
      Read [PBQ]PBQ2=[M:QUE2]PBLGRP(IINDICE);[M:QUE0]NUM
      If fstat = 0 Then
        If [F:PBQ]SRECOU <= 0 Then
          Delete [PBQ] Where [F:PBQ]GRPPBLNUM=SZTAB_PBLGRP(IINDICETAB) and [F:PBQ]QUENUM=[M:QUE0]NUM  
          If fstat <> 0 Then
            #Erreur lors de la suppression de la famille de compétence
            GMESSAGE = mess(725,182,1)
            GOK = 0
            Break
          Endif
        Else
          Readlock [PBQ]PBQ2=[M:QUE2]PBLGRP(NUMLIGNE);[M:QUE0]NUM
          If fstat <> 0 Then
            #Erreur lors de la suppression de la famille de compétence
            GMESSAGE = mess(725,182,1)
            GOK = 0
            Break
          Else
            [F:PBQ]STTFLG = 1
            Rewrite [PBQ]
            If fstat <> 0 Then
              #Erreur lors de la suppression de la famille de compétence
              GMESSAGE = mess(725,182,1)
              GOK = 0
              Break
            Endif
          Endif
        Endif
      Endif
    Endif
  Next
Return

######################################################
#Enregistrement des CLOBs
######################################################
$SAVECLOB
  Gosub DELCLOB
  If GOK < 1 Then
    Return
  Endif

  #Description
Local Char SZCTLCLOB(250)

  Raz SZCTLCLOB
  Setlob SZCTLCLOB With [M:QUE1]FULDES
  If SZCTLCLOB <> "" Then
    Raz [F:HD6]
    [F:HD6]NUM = [M:QUE1]NUMFULDES
    [F:HD6]TYP = [M:QUE1]TYPFULDES
    [F:HD6]CLOB = [M:QUE1]FULDES
    Write [HD6]
    If fstat Then
      #Erreur lors de l'enregistrement de la description. Transaction abandonnée.
      GMESSAGE = mess(895,182,1)
      GERR = 1
      Call FSTA("HD6") From GLOCK
      GOK = 0
      Return
    Endif
  Endif
Return

######################################################
#Suppression des CLOBs
######################################################
$DELCLOB
  Delete [HD6] Where [F:HD6]NUM = [M:QUE1]NUMFULDES and [F:HD6]TYP = [M:QUE1]TYPFULDES
  If fstat Then
    #Erreur lors de la suppression de la description. Transaction abandonnée.
    GMESSAGE = mess(896,182,1)
    GERR = 1
    Call FSTA("HD6") From GLOCK
    GOK = 0
    Return
  Endif
Return

######################################################
# Chargement du CLOB
######################################################
$LOADCLOB
Local Integer ILOOKFORCLOB

  ILOOKFORCLOB = 1
  If [M:QUE1]NUMFULDES = "" Then
    Raz [M:QUE1]FULDES
    ILOOKFORCLOB = 0
  Endif
  If [M:QUE1]TYPFULDES = "" Then
    Raz [M:QUE1]FULDES
    ILOOKFORCLOB = 0
  Endif
  If ILOOKFORCLOB
    Read [HD6]HD60=[M:QUE1]NUMFULDES;[M:QUE1]TYPFULDES
    If fstat Then
      Raz [M:QUE1]FULDES
    Else
      [M:QUE1]FULDES = [F:HD6]CLOB
    Endif
  Endif
Return
