#<AdxTL>@(#)7.0.0.0 $Revision$
#Goto TEST
Local Clbfile WCLOBOUT(13)        # Attention doit être en phase avec HTCCLBSIZ
Local Char  MW_STR1(200)
Local Char U_ADXIFS(1), U_ADXIRS(2) , U_SVADXIFS(1), U_SVADXIRS(1) : U_ADXIFS="" : U_ADXIRS= chr$(13)+chr$(10)
Local Integer U_ADXIUM, U_SVADXIUM, U_ADXIRSLEN  : U_ADXIUM=GUTF8 : U_ADXIRSLEN=2

MW_STR1="/produits/v160/SOLSUPV6/dossiers/SUPERV/tmp/jpjtest.ptl"
#MW_STR1="/produits/v160/SOLSUPV6/dossiers/SUPERV/tmp/1519642.ptl"
#MW_STR1="/produits/v160/SOLSUPV6/dossiers/SUPERV/tmp/1388610.ptl"

U_SVADXIRS=adxirs : U_SVADXIFS=adxifs : U_SVADXIUM=adxium

Dbgaff
Openo MW_STR1,0 Using [FSEQ]
Iomode adxifs U_ADXIFS Using [FSEQ]
Iomode adxirs U_ADXIRS Using [FSEQ]
Iomode adxium GUTF8 Using [FSEQ]
Wrseq "test ligne 1" Using [FSEQ] 
Wrseq "test ligne 2" Using [FSEQ] 
Wrseq "test ligne 3" Using [FSEQ] 
Openo Using [FSEQ]

Openi MW_STR1,0 Using [FSEQ]
Iomode adxifs "" Using [FSEQ]
Iomode adxirs "" Using [FSEQ]
Iomode adxium GUTF8 Using [FSEQ]

#adxirs="" : adxifs="" : adxium=U_ADXIUM  # Pas de séparateur pour tout lire en un seul ordre

Dbgaff
Rdseq WCLOBOUT Using [FSEQ]

Openi Using [FSEQ]
adxirs=U_SVADXIRS : adxifs=U_SVADXIFS : adxium=U_SVADXIUM
Infbox num$(len(WCLOBOUT ))
End

$TEST
Local Char WPARAMID(50)(1..10)
  Local Char WPARAMVALUE(250)(1..10)
  Local Integer WI,WNBPARAM
  Local Clbfile WCLOBOUT(13)        # Attention doit être en phase avec HTCCLBSIZ
  # Paramètres
  #  technique
  [L]WPARAMID(1) = "HTCCLBSIZ" :   [L]WPARAMVALUE(1) = "13"
  #  demande
  [L]WPARAMID(2) = "HTCPRVTYP" :   [L]WPARAMVALUE(2) = "PORTALTBL"
  [L]WPARAMID(3) = "ACTION"    :   [L]WPARAMVALUE(3) = ""
  # 
  [L]WPARAMID(4) = "PVIEWCODE"      :   [L]WPARAMVALUE(4) = "JPJMSK"
  [L]WNBPARAM = 4

  #maxmem = maxmem + 10000000
  #Infbox("Free: "-num$(freemem) -"max: "- num$(maxmem))

  #Appel du point d'entrée du portail 
  #Dbgaff
  Call MONITEUR( [L]WNBPARAM ,[L]WPARAMID ,[L]WPARAMVALUE, [L]WCLOBOUT) From SUBAPSMON
  #Visualisation du flux Xml retourné
  Local Char WSTROUT(250)(1..100) :# 25 Ko Max !
  Setlob [L]WSTROUT With [L]WCLOBOUT
  Infbox("Taille de ClobOut=["+ num$(len([L]WCLOBOUT)) +"]"+ chr$(13) +"Contenu de ClobOut" + chr$(13) + [L]WSTROUT )
End

# ------------------------------------------------------------
# SUBAPSMSK
# Version: 0001      
#
#    Traitement permettant l'appel d'un sous-programme chargé
#        de remplir un mask d'écran pour les données
#        L'ensemble du parametrage du composant graphique est lié à l'écran (type flash, colonne...) 
#
#    Nota: le composant d'affichage est un flash
#
#    Contexte
#        U_VIEWCODE        Code de la vue portail
#        [F:APV]           Enreg. en ligne de la table Vue portail (APTLVW)
#        M_ACTION          Code de l'action à traiter soumis par le provider Htc 
#        M_HTCTYPE         Type de provider Htc  (ex: PORTALREQ, PORTALSTA...)
#
#
# ------------------------------------------------------------

# Traitement d'extraction (I1)
# ------------------------------------------------------------
$T_EXECUTE     
    Onerrgo    # Suppression gestion d'erreur du prgrm appelant 
  
    Gosub T_INIT    # Initialisation

    #T_MSKCOD=[F:APV]MSKCOD
    T_MSKCOD="ZJPJMSK"   #$$$ Ligne de test
    Local Mask =T_MSKCOD [APT]

    # Description ecran - retour dans paramètres et [F:APV]
    Call MSKINF(T_MSKCOD, T_MSKTRTCOD,T_COLMSKMAX,T_ROWMSKMAX )        # CC
    # Description ecran - retour dans paramètres et [F:APV]
    Local Char    T_NBLIG(GLONAVA)                            # Nom variable bas de tableau
    Local Char    T_BLCDES(GLONDES)                            # Titre tableau
    Local Char    T_COLNAM(GLONAVA)(1..T_COLMSKMAX)           # Colonne - Nom champ
    Local Char    T_COLDES(GLONDES)(1..T_COLMSKMAX)           # Colonne - Titre
    Local Integer T_COLTYP(1..T_COLMSKMAX)                    # Colonne - Type selon menu 30
    Local Integer T_COLMEN(1..T_COLMSKMAX)                    # Colonne - N° menu local le cas échéant
    Local Integer T_COLTUN(1..T_COLMSKMAX)                    # Colonne - Valeurs: 0-non 1-tunnel std  2-tunnel Geode 
    Local Char    T_COLOBJ(GLONAOB)(1..T_COLMSKMAX)           # Colonne - Code objet 
    Local Char    T_COLSEC(GLONDES)(0..5,1..T_COLMSKMAX)      # Colonne - Valeur ou n° clé secondaire 
    Local Integer T_COLSECTYP(0..5,1..T_COLMSKMAX)            # Colonne - Type valeur clé secondaire (0:aucune - 1:n° colonne - 2: valeur)
    Local Char    T_CMPCODTYP(GLONAPP)                        # Composant visuel (facultatif) - Nom du composant visuel
    Local Char    T_CMPPARCOD(10)(0..dim([F:APV]CMPPARCOD))    # Composant visuel (facultatif) - Code paramètre
    Local Char    T_CMPPARFOR(80)(0..dim([F:APV]CMPPARCOD))    # Composant visuel (facultatif) - Formule associée au code paramètre
    Call MSKDESC(T_MSKCOD, T_NBLIG, T_BLCDES,T_COLDES,T_COLTYP,T_COLMEN,T_COLTUN,T_COLOBJ,T_COLSEC,T_COLSECTYP)        # CC
    
    #
    If [F:APV]CMPCODTYP<>"TB1"    # Rien à récuperer sur type TB1
        If T_CMPPARCOD(0)<>""        # Des infos sont passées par  MSKINF sinon on utilises celles de la vue
            Raz [F:APV]CMPPARNBR : TW_I=0
            [F:APV]CMPCODTYP=T_CMPCODTYP
            While T_CMPPARCOD(TW_I)<>""
                [F:APV]CMPPARCOD(TW_I)=T_CMPPARCOD : [F:APV]CMPPARFOR(TW_I)=T_CMPPARFOR    : TW_I+=1
            Wend
            [F:APV]CMPPARNBR=WI
        Endif
    Endif
    # Ajout infos vue en zone technique
    Gosub $M_TECVIEW From SUBAPSMON
    If U_ERR=UC_ERRG : Goto T_ENDKO : Endif    # erreur 

    # 
    Call EXISTE_ADX("","",T_MSKTRTCOD,T_OKTRT) From ORDSYS
    If T_OKTRT>0
       # Verif presence routine chgt
       TW_COL=0 : TW_ROW=0 
       Onerrgo TRT_ERR :  TW_ETQ="MOVDATA"       
       Gosub MOVDATA From =T_MSKTRTCOD
       Onerrgo 

       # Chargement des données
       Onerrgo TRT_ERR  :  TW_ETQ="LOADMSK"
       Call LOADMSK(U_VIEWCODE, APARAMIDS, APARAMVALUES, M_ACTION, T_ERRTRT, T_MESERR) From =T_MSKTRTCOD
       Onerrgo
    Else
       U_MESCODE="X3TRTNOTFOUND" : U_MESP1=T_MSKTRTCOD : U_ERR=UC_ERRG 
       Gosub U_MESPUT From SUBAPSUTI
    Endif
    If U_ERR=UC_ERRG : Goto T_ENDKO : Endif
    
    If T_ERRTRT=UC_ERRG        # Erreur gérée par développeur
       U_MESCODE="X3TRTMSKERR" : U_MESP1=T_MESERR : U_ERR=UC_ERRG 
       Gosub U_MESPUT From SUBAPSUTI
       Goto T_ENDKO        
    Endif
       
    #-- Génération flux XML
    U_SEQPUT=' <Data>' : Gosub U_PUT From SUBAPSUTI

    # Section lignes de données
    Gosub $SEC_LINES : If U_ERR=UC_ERRG : Goto ERRXMLCLOSE : Endif
    
    # Section titres        Après les données car codage en dur flash
    Gosub $SEC_TITLES : If U_ERR=UC_ERRG : Goto ERRXMLCLOSE: Endif
    
    # Parties techniques (à voir avec moniteur)


    $ERRXMLCLOSE    # fermeture XML listes
    #-- XML 
    U_SEQPUT=' </Data>' : Gosub U_PUT From SUBAPSUTI

    $T_ENDKO
    Close Mask [APT]
Return

  
# ------------------------------------------------------------
#     G O S U B
# ------------------------------------------------------------
# Section données
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$SEC_LINES
T_ROWDATMAX=evalue("[M:APT]"+T_NBLIG)-1
U_SEQPUT='  <Lines>' : Gosub T_SEQPUT
For TW_ROWBCL=0 To (T_ROWDATMAX)
  U_SEQPUT='  <Line>' : Gosub T_SEQPUT
  For TW_COLBCL=1 To T_COLMSKMAX
        TW_ROW=TW_ROWBCL : TW_COL=TW_COLBCL : Gosub GET_VAL   
        TW_STRINTCUR=TW_STRINTVAL : TW_STRCUR=TW_STRVAL
        U_SEQPUT='    <Col Num="' +num$(TW_COLBCL)+ '" X3Type="' +num$(T_COLTYP(TW_COLBCL))+ '"' 
        Gosub LNKCOL                            # Gestion des colonnes avec lien 
        U_SEQPUT+='>' : Gosub T_SEQPUT
        U_SEQPUT='     <X3IntVal>' + TW_STRINTCUR+ '</X3IntVal>' : Gosub T_SEQPUT
        U_SEQPUT='     <X3Value>' + TW_STRCUR + '</X3Value>' : Gosub T_SEQPUT
        #If T_COLTYP(TW_COLBCL)=1         # Menu pour alleger xml
        #     U_SEQPUT='     <X3Value>' + TW_STRCUR + '</X3Value>' : Gosub T_SEQPUT
        #Endif
        U_SEQPUT='    </Col>' : Gosub T_SEQPUT
  Next
  U_SEQPUT='  </Line>' : Gosub T_SEQPUT
Next
U_SEQPUT='  </Lines>' : Gosub T_SEQPUT
Return

# Gestion des colonnes avec lien
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$LNKCOL
If T_COLTUN(TW_COLBCL)=0 : Return : Endif
TW_URL=""
# Rappel hyp: la clé primaire est tj la colonne en-cours    
If T_COLSECTYP(0,TW_COLBCL)=0    # Clé simple
    If T_COLTUN(TW_COLBCL)=1   
        Call GETURLCLEPRIM(T_COLOBJ(TW_COLBCL), TW_STRINTCUR, M_MODE, TW_URL) From SUBAPSOBJ
    Elsif T_COLTUN(RW_COLBCL)=2
        TW_ROW=TW_ROWBCL : TW_COL=-1 : Gosub GET_VAL :  TW_COLGXFCY=TW_STRINTVAL        # Site GX       (col: -1)
        TW_ROW=TW_ROWBCL : TW_COL=-2 : Gosub GET_VAL :  TW_COLGXDEP=TW_STRINTVAL        # Deposant GX   (col: -2)
        Call GETURLCLEPGX(T_COLOBJ(RW_COLBCL), TW_COLGXFCY, TW_COLGXDEP, TW_STRINTCUR, M_MODE, TW_URL) From SUBAPSOBJ
    Endif
Else                    # Clé composite
    # gestion des clés secondaires
    Raz TW_I,TW_EVACLESEC
    While T_COLSECTYP(TW_I, TW_COLBCL)<>0
      Case T_COLSECTYP(TW_I,TW_COLBCL)
      When 1        # cas colonne
        TW_ROW=TW_ROWBCL : TW_COL=T_COLSEC(TW_I,TW_COLBCL) : Gosub GET_VAL :  TW_EVACLESEC(TW_I)=TW_STRINTVAL     
      When 2        # cas valeur
        TW_EVACLESEC(TW_I)=T_COLSEC(TW_I,TW_COLBCL)     
      Endcase
      TW_I+=1
    Wend

    If T_COLTUN(TW_COLBCL)=1     
        Call GETURLCLECMP(T_COLOBJ(TW_COLBCL), TW_STRINTCUR,TW_EVACLESEC, M_MODE, TW_URL) From SUBAPSOBJ
    Else
        TW_ROW=TW_ROWBCL : TW_COL=-1 : Gosub GET_VAL :  TW_COLGXFCY=TW_STRINTVAL        # Site GX       (col: -1)
        TW_ROW=TW_ROWBCL : TW_COL=-2 : Gosub GET_VAL :  TW_COLGXDEP=TW_STRINTVAL        # Deposant GX   (col: -2)
        Call GETURLCLECGX(T_COLOBJ(TW_COLBCL), TW_COLGXFCY, TW_COLGXDEP, TW_STRINTCUR,RW_EVACLESEC, M_MODE, TW_URL) From SUBAPSOBJ
    Endif
Endif 

# Attribut X3link
If TW_URL<>""
     U_HEXTOTXT=TW_URL : Gosub U_TXTTOHEX From SUBAPSUTI
     U_SEQPUT+=' X3Link="' + U_TXTTOHEX + '" '
Endif
Return

# Section titres
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$SEC_TITLES
#
U_SEQPUT='<Titles>' : Gosub T_SEQPUT
  # Titre
  U_HEXTOTXT=T_BLCDES : Gosub U_TXTTOHEX From SUBAPSUTI 
  U_SEQPUT=' <Title>'+U_TXTTOHEX+'</Title>' : Gosub T_SEQPUT   
  # Colonnes
  For TW_COL=1 To T_COLMSKMAX
    U_HEXTOTXT=T_COLDES(TW_COL) : Gosub U_TXTTOHEX From SUBAPSUTI        
    U_SEQPUT=' <ColTitle Num="'+num$(TW_COL)+'" X3Type="'+num$(T_COLTYP(TW_COL))+'">'+U_TXTTOHEX+'</ColTitle>' : Gosub T_SEQPUT    
  Next
U_SEQPUT='</Titles>' : Gosub T_SEQPUT
Return 

# Valeur interne pour une cellule
#       Entrée
#         TW_COL, TW_ROW
#       Sortie
#         TW_STRINTVAL, TW_STRVAL (menu)  
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$GET_VAL
Raz TW_STRINTVAL, TW_STRVAL, TW_VALSTR, TW_VALINT, TW_VALDAT, TW_VALDEC
Gosub MOVDATA From =T_MSKTRTCOD     # Retourne TW_VALSTR,TW_VALINT,TW_VALDEC,TW_VALDAT

# Site, deposant geode
If find(TW_COL,-1,-2)
    TW_STRINTVAL=TW_VALSTR  
    TW_STRVAL=""
    Return
Endif

# Type de données
Case T_COLTYP(TW_COL)      # valeurs issues du menu local 30
    When 1            # menu local
         TW_STRINTVAL=num$(TW_VALINT)
         If T_COLMEN(TW_COL)<>0    # récupération message
             U_HEXTOTXT=mess(TW_VALINT,T_COLMEN(TW_COL),1) : Gosub U_TXTTOHEX From SUBAPSUTI
             TW_STRVAL=U_TXTTOHEX
         Endif
    When 2,3    # entier
        TW_STRINTVAL=num$(TW_VALINT)
        TW_STRVAL=format$("Nz:8#",TW_VALINT)
    When 4,5,6        # décimal
        TW_STRINTVAL=num$(TW_VALDEC)
        TW_STRVAL=format$("N3zZ:" + GFM92,TW_VALDEC)        
    When 7            # texte
        U_HEXTOTXT=TW_VALSTR : Gosub U_TXTTOHEX From SUBAPSUTI   
        TW_STRINTVAL=U_TXTTOHEX  
        TW_STRVAL=TW_STRINTVAL
    When 8            # date
        TW_STRINTVAL=format$("D:YYYYMMDD",TW_VALDAT)      
        TW_STRVAL=format$("DPZ:"+GFMDAT, TW_VALDAT)
    When Default
Endcase
Return

# Initialisations
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
#    info: Pour ne pas interferer avec les autres programmes, les variables commencent par 'T'
$T_INIT
#
#    info - T:prefixe traitement, TW: travail, TC: cste
#
Local Char     T_MSKCOD(GLONAMK)                     # Code mask
Local Char     T_MSKTRTCOD(GLONADC)                  # Programme lié au mask
Local Char     TC_MSKABR(GLONABR) : TC_MSKABR="APT"  # Abréviation mask imposée
Local Integer  TW_I,T_OKTRT, T_ERRTRT
Local Integer  TW_COLBCL, T_COLMSKMAX                 # Colonne: indice interne boucle (de 1 à T_COLMSKMAX), maxi
Local Integer  TW_ROWBCL, T_ROWDATMAX, T_ROWMSKMAX    # Ligne  : indice interne boucle (de 0 à T_ROWDATMAX-1), maxi données, maxi ecran
Local Char     TW_EVACLESEC(200)(0..5)               # tableau des valeurs des cles supplémentaires
If GPRODUIT=1
    Local Char     TW_COLGXFCY(GLONFCY)                  # Site GX       (col: -1)
    Local Char     TW_COLGXDEP(GLONDEP)                  # Deposant GX   (col: -2)
Endif

# <gosub GET_VAL>
Local Integer  TW_COL, TW_ROW                        # Indices 
Local Char     TW_STRINTVAL(200),TW_STRVAL(200), TW_VALSTR(200)
Local Integer  TW_VALINT
Local Decimal  TW_VALDEC
Local Date     TW_VALDAT
# </gosub GET_VAL>

Local Char     TW_STRINTCUR(200),TW_STRCUR(200)   # Infos cellules courantes
Local Char     TW_URL(100)                           # Url de débranchement

Local Char     TW_STR1(100), T_MESERR(100), TW_ETQ(12)
Return

# Ecriture XML 
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$T_SEQPUT
Gosub U_PUT From SUBAPSUTI
Return

# erreur en appel de traitement
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
$TRT_ERR
U_MESCODE="X3TRTERR" : U_MESP1=errmes$(errn) : U_MESP2=T_MSKTRTCOD-TW_ETQ : U_ERR=UC_ERRG 
Gosub U_MESPUT From SUBAPSUTI
Resume
Return




#**  CCORA (2 parties)
# Information ecran
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
Subprog MSKINF(MSKCOD,MSKTRTCOD,NBCOLMSK, NBROWMSK)
Value    Char    MSKCOD()                       # Code du mask
Variable Char    MSKTRTCOD                      # Nom trt 
Variable Integer NBCOLMSK                       # Nb colonne
Variable Integer NBROWMSK                       # Nb ligne
MSKTRTCOD="SUBZJPJMSK"
NBCOLMSK=6
NBROWMAX=22
End

# Description ecran
# - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - - -
Subprog MSKDESC(MSKCOD,NBLIG,BLCDES,COLDES,COLTYP,COLMEN,COLTUN,COLOBJ,COLSEC,COLSECTYP)
Value    Char    MSKCOD()                       # Code du mask
Variable Char    NBLIG()(1..)                   # Nom variable bas de tableau
Variable Char    BLCDES()                       # Titre tableau
Variable Char    COLNAM()(1..)                  # Colonne - Nom
Variable Char    COLDES()(1..)                  # Colonne - Titre
Variable Integer COLTYP(1..)                    # Colonne - Type selon menu 30
Variable Integer COLMEN(1..)                    # Colonne - Num menu local le cas échéant
Variable Integer COLTUN(1..)                    # Colonne - Valeurs: 0-non 1-tunnel std  2-tunnel Geode 
Variable Char    COLOBJ()(1..)                  # Colonne - Code objet 
Variable Char    COLSEC()(0..5,1..)             # Colonne - Valeur ou n° clé secondaire 
Variable Integer COLSECTYP(0..5,1..)            # Colonne - Type valeur clé secondaire (0:aucune - 1:n° colonne - 2: valeur)
Local Integer WI : WI=1

NBLIG ="NBLIG"
BLCDES="Test titre"
COLDES(WI)="Pays"        : COLTYP(WI)=7 : COLTUN(WI)=1  
  COLOBJ(WI)="TCY"         :  COLSEC(0,WI)="" :  COLSECTYP(0,WI)=0 : WI+=1
COLDES(WI)="Langue"      : COLTYP(WI)=7 : COLTUN(WI)=1  
  COLOBJ(WI)="TLA"         :  COLSEC(0,WI)="" :  COLSECTYP(0,WI)=0 : WI+=1
COLDES(WI)="Nom"         : COLTYP(WI)=7 : COLTUN(WI)=0  
  COLOBJ(WI)="TCY"         :  COLSEC(0,WI)="" :  COLSECTYP(0,WI)=0 : WI+=1
COLDES(WI)="Continent"   : COLTYP(WI)=7 : COLTUN(WI)=1  
  COLOBJ(WI)="ADI"         :  COLSEC(0,WI)="918" :  COLSECTYP(0,WI)=2 : WI+=1

COLDES(WI)="Nb commandes" : COLTYP(WI)=2 : COLTUN(WI)=0  
  COLOBJ(WI)="" :  COLSEC(0,WI)="" :  COLSECTYP(0,WI)=0 : WI+=1
COLDES(WI)="Chiffres d'affaires" : COLTYP(WI)=4 : COLTUN(WI)=0  
  COLOBJ(WI)="" :  COLSEC(0,WI)="" :  COLSECTYP(0,WI)=0 : WI+=1

# Parametrage flash
#   Les données doivent être renseignées dans [F:APV]   (<=> à saisie d'une vue)
#   [F:APV]CMPPARNBR, [F:APV]CMPPARCOD(n), [F:APV]CMPPARFOR(n)
#
If (1=1)    # Si le paramètrage n'existe pas dans l'écran --> ne rien faire, celui définit sur la vue sera appliquée
    CMPCODTYP="FGRP"
    WI=0
    CMPPARCOD(WI)="FGCTYPE" : [F:APV]CMPPARFOR(WI)='"XPERSO"'    : WI+=1
    [F:APV]CMPPARCOD(WI)="FGCLABEL": [F:APV]CMPPARFOR(WI)='"1"'         : WI+=1
    [F:APV]CMPPARCOD(WI)="FGCVAL"  : [F:APV]CMPPARFOR(WI)='"5,b;6,l"'   : WI+=1
    [F:APV]CMPPARCOD(WI)="FGCSELG" : [F:APV]CMPPARFOR(WI)='"2"'         : WI+=1
    [F:APV]CMPPARCOD(WI)="FGCSELC" : [F:APV]CMPPARFOR(WI)='"2"'         : WI+=1
    [F:APV]CMPPARCOD(WI)="FGCDEF"  : [F:APV]CMPPARFOR(WI)='"5;6"'       : WI+=1
Endif

End

# A reprendre de SUBZJMSK
$MOVDATA
Return
