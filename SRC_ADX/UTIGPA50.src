#<AdxTL>@(#)0.0.0.0 $Revision$
##########################################################################
# UTIGPA50   Deletion of FDMA recalculation parameters                   #
##########################################################################

  Call TEMPON("O") From GESECRAN
  Call OUVRE_TRACE("Delete FDMA parameters PSFDMARECB and PSFDMARECD") From LECFIC
  Call PATCH(nomap)
  Call TEMPOFF     From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
End

##########################################################################
Subprog MAJ_UTIGPA50(DOSSIER)
Value Char     DOSSIER

# Only when module manufacturing
If [F:ADS]MODULE(8)<>2 : End : Endif

If func AFNC.ACTIV("POPS") = 0 : End : Endif

Call ECR_TRACE("UTIGPA50: Process Start on : "+DOSSIER,0) From GESECRAN

If filinfo(filpath("FIL","ADOPAR","fde",DOSSIER),0)>0 &
&  filinfo(filpath("FIL","ADOVAL","fde",DOSSIER),0)>0
   Local File =DOSSIER+".ADOPAR"  [ADP]
   Local File =DOSSIER+".ADOVAL"  [ADW]
   Trbegin [ADP]
     Delete [ADP] Where find(PARAM,'PSFDMARECB','PSFDMARECD')<>0
     Delete [ADW] Where find(PARAM,'PSFDMARECB','PSFDMARECD')<>0
   Commit
   Call ECR_TRACE("UTIGPA50: Parameters PSFDMARECB & PSFDMARECD deleted",0) From GESECRAN
Endif

Call ECR_TRACE("UTIGPA50: Process End",0) From GESECRAN
End

########################################################################
# for automatic start at patch-management                            #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI="X3" : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
Call MAJ_UTIGPA50(APPLI)
End

#######################################################################
# for start in dosmaj (validation folder)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI="X3" End : Endif
Call MAJ_UTIGPA50(APPLI)
End

