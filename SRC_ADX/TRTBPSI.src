#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################
# Program Name: TRTBPSI
# Description : Products by supplier
# Date        : 04/10/2015
####################################################################################

$ACTION

Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "DEBUT"        : Gosub DEBUT
  When "SETBOUT"      : Gosub SETBOUT
  When "BOUTON"       : Gosub BOUTON
  When "APRES_MODIF"  : Gosub APRES_MODIF
Endcase

Return

####################################################################################
$OUVRE

If !clalev([F:TCY])   : Local File TABCOUNTRY [TCY] : Endif
If !clalev([F:BPA])   : Local File BPADDRESS  [BPA] : Endif
If !clalev([F:BPS])   : Local File BPSUPPLIER [BPS] : Endif
If !clalev([F:ITP])   : Local File ITMBPS     [ITP] : Endif

If !clalev([M:ORDK])  : Local Mask ORDK             : Endif

Local Integer NOL : NOL = val(PARAM(1))
Local Char MSK(8) : MSK = PARAM(2)

Case MSK
  When "MGP"
		Read [BPS]BPS0 = [M:MGP]BPSNUM(NOL)
		If fstat : GERR = 1 : GMESSAGE = mess(136, 100, 1) : FIN = 1 : Endif
  When "MGB"  # No BPSNUM here, so use BPRNUM
    Read [BPS]BPS0 = [M:MGB]BPRNUM(NOL)
    If fstat : GERR = 1 : GMESSAGE = mess(136, 100, 1) : FIN = 1 : Endif
Endcase

Read [BPR]BPR0 = [F:BPS]BPSNUM
Read [BPA]BPA0 = 1; [F:BPR]BPRNUM; [F:BPR]BPAADD
If fstat : Raz [F:BPA] : Endif

Return

####################################################################################
$DEBUT

Raz [M:BPSI]

[M:BPSI]BPSNUM    = [F:BPS]BPSNUM
[M:BPSI]CRY       = [F:BPA]CRY
[M:BPSI]TEL       = [F:BPA]TEL
[M:BPSI]FAX       = [F:BPA]FAX
[M:BPSI]WEB       = [F:BPA]WEB

If evalue("[M:"+MSK+"]STOFCY(NOL)") <> ""
  [M:BPSI]FCY     = evalue("[M:"+MSK+"]STOFCY(NOL)")
Else
  [M:BPSI]FCY     = evalue("[M:"+MSK+"]FCY")
Endif

If GSYSCUR <> GLOCALDEV
  Local Integer STAT
  Call CONVERT (GSYSCUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,date$,[F:BPS]ORDMINAMT,[M:BPSI]ORDMINAMT,STAT) From TRTDEV
  Call CONVERT (GSYSCUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,date$,[F:BPS]ORDFREFRT,[M:BPSI]ORDFREFRT,STAT) From TRTDEV
Else
  [M:BPSI]ORDMINAMT = [F:BPS]ORDMINAMT
  [M:BPSI]ORDFREFRT = [F:BPS]ORDFREFRT
Endif
[M:BPSI]CUR = GLOCALDEV

Gosub LOAD_LINES

Return

####################################################################################
$APRES_MODIF

  REP="M"

Return

####################################################################################
$SETBOUT

If REP<>"M"
  Call VIREBOUT(CHMEN, '12') From GOBJET
Endif

Return

####################################################################################
$BOUTON

Case BOUT
  When '1'    # Save
    Gosub SAVE
  When '2'    # End
    Raz REP
    Effzo [M:BPSI]PECQTY, TOTWEI, TOTVOL, TOTCOST
Endcase

Return

####################################################################################
# Load products supplied by current supplier
####################################################################################
$LOAD_LINES

Local Integer I, NBLIG, STAT
#Local Char DAT : # Issue 120235 GH 28/12/2016 - Type incorrect
Local Date DAT : [L]DAT = evalue("[M:"+MSK+"]STRDAT(0)")
Effzo [BPSI]15

For [ITP] Where BPSNUM = [M:BPSI]BPSNUM
  If I>=dim([M:BPSI]ITMREF) : Break : Endif : # Issue 120235 GH 28/12/2016 - stop the grid feeding when it is fulfilled

  OK = 1

  # Only products defined on current site
  Read [ITF]ITF0 = [F:ITP]ITMREF; [M:BPSI]FCY
  If fstat : Goto NEXT_ITP : Endif

  # Exclude products already suggested in grouping workbench
  NBLIG = evalue("[M:"+MSK+"]NBLIG - 1")
  For J = 0 To NBLIG
    If evalue("[M:"+MSK+"]WIPTYPSTA(J)") = 'POS' & evalue("[M:"+MSK+"]ITMREF(J)") = [F:ITP]ITMREF
			OK=0 : Break
		Endif
	Next
	If !OK : Goto NEXT_ITP : Endif

	Read [ITM]ITM0 = [F:ITP]ITMREF
  [M:BPSI]ITMREF(I)     = [F:ITM]ITMREF
  [M:BPSI]STU(I)        = [F:ITM]STU
  [M:BPSI]PUU(I)        = [F:ITP]PUU
  [M:BPSI]PUUSTUCOE(I)  = [F:ITP]PUUSTUCOE
  [M:BPSI]ITMWEI(I)     = [F:ITM]ITMWEI * [F:ITP]PUUSTUCOE
  [M:BPSI]ITMVOU(I)     = [F:ITM]ITMVOU * [F:ITP]PUUSTUCOE

	Read [ITV]ITV0 = [F:ITM]ITMREF; [M:BPSI]FCY
  If fstat : Raz [F:ITV] : Endif
  [M:BPSI]AVASTO(I)     = [F:ITV]PHYSTO - [F:ITV]PHYALL
  [M:BPSI]ORDSTO(I)     = [F:ITV]ORDSTO

  Read [ITF]ITF0 = [F:ITM]ITMREF; [M:BPSI]FCY
  If fstat : Raz [F:ITF] : Endif
  [M:BPSI]REOMINQTY(I)  = [F:ITF]REOMINQTY
  [M:BPSI]SAFSTO(I)     = [F:ITF]SAFSTO
  [M:BPSI]PURBASPRI(I)  = [F:ITM]PURBASPRI * [F:ITP]PUUSTUCOE
  If GSYSCUR <> GLOCALDEV
    Call CONVERT(GSYSCUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,[L]DAT,[M:BPSI]PURBASPRI(I),[M:BPSI]PURBASPRI(I),STAT) From TRTDEV
  Endif

  For [ORD]ORD1 Where STOFCY = [M:BPSI]FCY & ITMREF = [F:ITM]ITMREF & WIPTYP = 2 & WIPSTA = 3
		[M:BPSI]SUGSTO(I) += [F:ORD]RMNEXTQTY - [F:ORD]MTOQTY
	Next

	I += 1
$NEXT_ITP
Next

[M:BPSI]NBLIG = I

Affzo [BPSI]

Return

####################################################################################
# Create new POS
####################################################################################
$SAVE
Local Integer EXCEEDED

Trbegin [ORD]
GOK = 1

For I = 0 To [M:BPSI]NBLIG - 1
  If [M:BPSI]PECQTY(I) > 0
    Raz [M:ORDK]

    [M:ORDK]MAJCOD  = 'C'
    [M:ORDK]WIPTYP  = 2
    [M:ORDK]WIPSTA  = 3
    [M:ORDK]VCRTYP  = 11
    [M:ORDK]ITMREF  = [M:BPSI]ITMREF(I)
    [M:ORDK]ORIFCY  = [M:BPSI]FCY
    [M:ORDK]STOFCY  = [M:BPSI]FCY
    [M:ORDK]BPRNUM  = [M:BPSI]BPSNUM
    [M:ORDK]EXTQTY  = [M:BPSI]PECQTY(I) * [M:BPSI]PUUSTUCOE(I)
    [M:ORDK]STRDAT  = date$
    [M:ORDK]PIO     = 1
    [M:ORDK]FMI     = 1
    [M:ORDK]ORI     = 6

    Call WIP From TRTWIP
    If !GOK : Break : Endif

    [M:ORDK]VCRNUM  = [M:ORDK]WIPNUM

    Case MSK
      When "MGP"
        If [M:MGP]NBLIG < dim([M:MGP]WIPTYP)
          nolign = [M:MGP]NBLIG + 1
          Gosub ADD_MGP_LINE
          [M:MGP]NBLIG += 1
        Elsif !EXCEEDED
          Call MESSAGE(mess(321, 107, 1)) From GESCRAN
          EXCEEDED = 1
        Endif
      When "MGB"
        If [M:MGB]NBLIG < dim([M:MGB]WIPTYP)
          nolign = [M:MGB]NBLIG + 1
          Gosub ADD_MGB_LINE
          [M:MGB]NBLIG += 1
        Elsif !EXCEEDED
          Call MESSAGE(mess(321, 107, 1)) From GESCRAN
          EXCEEDED = 1
        Endif
    Endcase
  Endif
Next

If !GOK : Rollback : Return : Endif

Commit
Raz REP

Case MSK
  When "MGP"
    Call UPD_PPHEADER From FUNMPICK
    Affzo [M:MGP]
  When "MGB"
    Affzo [M:MGB]
Endcase

Gosub LOAD_LINES

Return


####################################################################################
# Add a line in Grouping workbench
####################################################################################
$ADD_MGP_LINE
Local Char WSOHNUM(GLONVCR), WBPSNUM(GLONBPS)
Local Integer WFIND, STAT
Local Date WDATE
Local Decimal WCOEF
Local Integer NOL2 : NOL2=nolign-1

If [F:ORD]ITMREF <> [M:ORDK]ITMREF
  Read [ORD]ORD0=[M:ORDK]WIPTYP;[M:ORDK]WIPNUM;[M:ORDK]ITMREF
Endif

If [F:ITM]ITMREF <> [F:ORD]ITMREF
  Read [ITM]ITM0 = [F:ORD]ITMREF
Endif

If [F:ITF]ITMREF <> [F:ORD]ITMREF or [F:ITF]STOFCY <> [F:ORD]STOFCY
  Read [ITF]ITF0 = [F:ORD]ITMREF ; [F:ORD]STOFCY
Endif

#Verify the VCRNUM
If [M:ORDK]VCRNUM<>[F:ORD]VCRNUM
  [F:ORD]VCRNUM=[M:ORDK]WIPNUM
  Rewrite [F:ORD]
Endif

[M:MGP] = [F:ORD]
[M:MGP]WIPTYPSTA(NOL2) = mess([F:ORD]WIPTYP,341,1)+mess([F:ORD]WIPSTA,342,1)

If [F:ORD]WIPTYP = 2 & GMODU(6) = 2
  [M:MGP]BPSNUM(NOL2) = [F:ORD]BPRNUM
Endif

# Units
[M:MGP]STU(NOL2)        = [F:ITM]STU
[M:MGP]PUU(NOL2)        = [F:ITM]PUU
[M:MGP]POHFCY(NOL2)     = [M:BPSI]FCY
[M:MGP]ITMDES1(NOL2)    = [F:ITM]ITMDES1
[M:MGP]PUUSTUCOE(NOL2)  = [F:ITM]PUUSTUCOE
[M:MGP]PLANNER2(NOL2)   = [F:ITF]PLANNER
[M:MGP]BUY(NOL2)        = [F:ITF]BUY
[M:MGP]PECQTY(NOL2)     = [M:MGP]RMNEXTQTY(NOL2) - [M:MGP]MTOQTY(NOL2)
[M:MGP]TOTPECQTY       += [M:MGP]PECQTY(NOL2)
[M:MGP]POHIND(NOL2)     = 1
[M:MGP]FIE(NOL2)        = 2

[M:MGP]PURBASPRI(NOL2)  = [F:ITM]PURBASPRI
[M:MGP]LINAMT(NOL2)     = [M:MGP]PURBASPRI(NOL2) * [M:MGP]PECQTY(NOL2)
If GSYSCUR <> GLOCALDEV
  Call CONVERT (GSYSCUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,[M:MGP]STRDAT(0),[M:MGP]LINAMT(NOL2),[M:MGP]LINAMT(NOL2),STAT) From TRTDEV
Endif

[M:MGP]ITMWEI(NOL2)     = [F:ITM]ITMWEI
[M:MGP]LINWEU(NOL2)     = [F:ITM]WEU
[M:MGP]LINWEI(NOL2)     = [M:MGP]ITMWEI(NOL2) * [M:MGP]PECQTY(NOL2)
[M:MGP]LINTCTRWEI(NOL2) = [M:MGP]LINWEI(NOL2)

[M:MGP]ITMVOL(NOL2)     = [F:ITM]ITMVOU
[M:MGP]LINVOL(NOL2)     = [M:MGP]ITMVOL(NOL2) * [M:MGP]PECQTY(NOL2)
[M:MGP]LINVOU(NOL2)     = [F:ITM]VOU
[M:MGP]LINTCTRVOL(NOL2) = [M:MGP]LINVOL(NOL2)

If [M:MGP]LINWEU(NOL2)<>[M:MGP]TCTRWEU
  Call CONVERT_QTY([M:MGP]LINWEU(NOL2),[M:MGP]TCTRWEU,[M:MGP]LINTCTRWEI(NOL2))From TRTX3
Endif
If [M:MGP]LINVOU(NOL2)<>[M:MGP]TCTRVOU
  Call CONVERT_QTY([M:MGP]LINVOU(NOL2),[M:MGP]TCTRVOU,[M:MGP]LINTCTRVOL(NOL2))From TRTX3
Endif

If GMODU(6) = 2
  # Get contract
  OK = 0

  Filter [POC] Where ITMREF = [F:ORD]ITMREF & PRHFCY = [F:ORD]STOFCY & ENDDAT >= [0/0/0]
  WPOHNUM = ""

  Raz WFIND, WDATE

  For [POC]POC2
    If [F:POH]POHNUM <> [F:POC]POHNUM
      Read [POH]POH0 = [F:POC]POHNUM
      If fstat : Goto N_POC : Endif
    Endif

    If !find([F:POH]APPFLG,3,4,5)                   : Goto N_POC : Endif
    If [F:POH]CLEFLG = 2                            : Goto N_POC : Endif
    If [F:POH]BETFCY = 2 & !find([M:MGP]APPPRF,2,3) : Goto N_POC : Endif
    If [F:POH]BETFCY = 1 & !find([M:MGP]APPPRF,1,3) : Goto N_POC : Endif

    [M:MGP]POHIND(NOL2) = 2

    If WPOHNUM = "" : WPOHNUM = [F:POH]POHNUM : WBPSNUM = [F:POH]BPSNUM : Endif

    # Vérification des dates de validité du contrat - 36120 mm 05.06
    If !WFIND
      If [M:MGP]ENDDAT(NOL2) >= date$
        WDATE = [M:MGP]ENDDAT(NOL2)
      Else
        WDATE = date$
      Endif

      Filter [WPOC] Where ITMREF= [M:MGP]ITMREF(NOL2) & POHNUM = [F:POC]POHNUM & PRHFCY = [M:MGP]STOFCY(NOL2)
      For [WPOC]POC1
        If [F:WPOC]ENDDAT >= WDATE
          WFIND = 1
        Endif
      Next
      Filter [WPOC]

      If !WFIND
        # il n'existe pas de contrat valide  , on réinitialise
        [M:MGP]POHIND(NOL2) = 1
        Raz WPOHNUM,WBPSNUM
        Goto N_POC
      Endif
    Endif

    If [M:MGP]POHNUM(NOL2) <> "" & [F:POC]POHNUM = [M:MGP]POHNUM(NOL2)
      [M:MGP]PUU(NOL2) = [F:POC]PUU
      OK = 1
    Endif

$N_POC
  Next
  Filter [POC]

  If !OK : [M:MGP]POHNUM(NOL2) = "" : Endif

  If [M:MGP]POHIND(NOL2) = 2  & [M:MGP]POHNUM(NOL2) = ""
    [M:MGP]POHNUM(NOL2) = WPOHNUM
    [M:MGP]BPSNUM(NOL2) = WBPSNUM
  Endif

Endif

Call PCAL_QTY([M:MGP]PECQTY(NOL2), [M:MGP]STU(NOL2),[M:MGP]PUUPECQTY(NOL2),[M:MGP]PUU(NOL2),
&             [M:MGP]ITMREF(NOL2),[M:MGP]BPSNUM(NOL2),1,WCOEF) From TRTACHQTE1
If WCOEF <> 0 : [M:MGP]PUUSTUCOE(NOL2) = 1/WCOEF : Endif

Call APRES_NBLIG From TRTBPSI

Return

$ADD_MGB_LINE
Local Char WSOHNUM(GLONVCR), WBPSNUM(GLONBPS)
Local Integer WFIND, STAT
Local Date WDATE
Local Decimal WCOEF
Local Integer NOL2 : NOL2=nolign-1

If [F:ORD]ITMREF <> [M:ORDK]ITMREF
  Read [ORD]ORD0=[M:ORDK]WIPTYP;[M:ORDK]WIPNUM;[M:ORDK]ITMREF
Endif

If [F:ITM]ITMREF <> [F:ORD]ITMREF
  Read [ITM]ITM0 = [F:ORD]ITMREF
Endif

If [F:ITF]ITMREF <> [F:ORD]ITMREF or [F:ITF]STOFCY <> [F:ORD]STOFCY
  Read [ITF]ITF0 = [F:ORD]ITMREF ; [F:ORD]STOFCY
Endif

#Verify the VCRNUM
If [M:ORDK]VCRNUM<>[F:ORD]VCRNUM
  [F:ORD]VCRNUM=[M:ORDK]WIPNUM
  Rewrite [F:ORD]
Endif

[M:MGB] = [F:ORD]
[M:MGB]WIPTYPSTA(NOL2) = mess([F:ORD]WIPTYP,341,1)+mess([F:ORD]WIPSTA,342,1)

If [F:ORD]WIPTYP = 2 & GMODU(6) = 2
  [M:MGB]BPRNUM(NOL2) = [F:ORD]BPRNUM
Endif

# Units
[M:MGB]STU(NOL2)        = [F:ITM]STU
[M:MGB]ITMDES1(NOL2)    = [F:ITM]ITMDES1
[M:MGB]PLANNER2(NOL2)   = [F:ITF]PLANNER
[M:MGB]BUY(NOL2)        = [F:ITF]BUY

[M:MGB]LINAMT(NOL2)     = [F:ITM]PURBASPRI * [M:MGB]RMNEXTQTY(NOL2)
[M:MGB]LINAMTCUR(NOL2)  = GLOCALDEV
If GSYSCUR <> GLOCALDEV
  Call CONVERT (GSYSCUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,[M:MGB]STRDAT(0),[M:MGB]LINAMT(NOL2),[M:MGB]LINAMT(NOL2),STAT) From TRTDEV
Endif

[M:MGB]LINWEI(NOL2)     = [F:ITM]ITMWEI * [M:MGB]RMNEXTQTY(NOL2)
[M:MGB]LINWEU(NOL2)     = [F:ITM]WEU

[M:MGB]LINVOL(NOL2)     = [F:ITM]ITMVOU * [M:MGB]RMNEXTQTY(NOL2)
[M:MGB]LINVOU(NOL2)     = [F:ITM]VOU

[M:MGB]XMRPMES(NOL2)    = mess(1,318,1)
[M:MGB]REQDAT(NOL2)     = [M:MGB]ENDDAT(NOL2)

Call APRES_NBLIG From TRTBPSI

Return

######################################################################################
Subprog APRES_NBLIG

Local Integer I : I = nolign-1

[M:BPSI]TOTWEI(I)  = [M:BPSI]ITMWEI(I)    * [M:BPSI]PECQTY(I)
[M:BPSI]TOTVOL(I)  = [M:BPSI]ITMVOU(I)    * [M:BPSI]PECQTY(I)
[M:BPSI]TOTCOST(I) = [M:BPSI]PURBASPRI(I) * [M:BPSI]PECQTY(I)

Affzo [M:BPSI]TOTWEI(I), TOTVOL(I), TOTCOST(I)

End

