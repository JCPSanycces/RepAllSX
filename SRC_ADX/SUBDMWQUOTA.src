$LIENS_LIG
 # If GUSER = "ANGRE"
 #   Infbox num$(NBLIG)
#    Infbox "LIENS_LIG " + [M:DMWQUO1]PKGMAT(nolign-1)
#    Affzo [M:DMWQUO1]PKGMAT(nolign-1)
#    Infbox "LIENS_LIG " + [M:DMWQUO1]PKGMAT(nolign-1)
#  Endif
  Call UPDATEIDDESCRIPTION([M:DMWQUO1]PKGMAT(nolign-1), 2)
  Call UPDATEIDDESCRIPTION([M:DMWQUO1]PKGSIZ(nolign-1), 3)
  Call UPDATEIDDESCRIPTION([M:DMWQUO1]TAFTYP (nolign-1), 4)
Return


Subprog UPDATEIDDESCRIPTION(TYPID, TYP)
  Variable Char TYPID
  Value Tinyint TYP
  Local Char DESCRIPTION(30)
  Call LECTEXTRA(DESCRIPTION,"DMWPAORD","DES",[M:DMWQUO0]SCMCOD,num$(TYP) +"~"+ TYPID) From ATEXTRA
  Case TYP
    When 2
      [M:DMWQUO1]PKGMATDES(nolign-1) = DESCRIPTION#func GETTYPIDDES([M:DMWPPA0]SCMCOD,TYPID,TYP)
      Affzo [M:DMWQUO1]PKGMATDES(nolign-1)
    When 3
      [M:DMWQUO1]PKGSIZDES(nolign-1) = DESCRIPTION#func GETTYPIDDES([M:DMWPPA0]SCMCOD,TYPID,TYP)
      Affzo [M:DMWQUO1]PKGSIZDES(nolign-1)
    When 4
      [M:DMWQUO1]TAFTYPDES(nolign-1) = DESCRIPTION#func GETTYPIDDES([M:DMWPPA0]SCMCOD,TYPID,TYP)
      Affzo [M:DMWQUO1]TAFTYPDES(nolign-1)
  Endcase

End


