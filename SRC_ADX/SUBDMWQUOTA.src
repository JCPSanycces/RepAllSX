#########################################################################
## Validation of Percentage for Grouped PM & PS
## we have to validate the percentage of Package material and Package size
## we do this by having 2 arrays where we store a key and the corespondending percentage value
#########################################################################
Subprog PERCENTAGE_VALIDATION()
  Local Char    PCTKEY(60)
  Local Char    ERRORMESSAGE(255)
  Local Char    KEYS_ARRAY(60)(1..)
  Local Decimal KEYPCT
  Local Decimal KEYPCT_ARRAY(1..)
  Local Integer I
  Local Integer KEYINDEX

  For I=1 To [M:DMWQUO1]NBLIG
    PCTKEY = [M:DMWQUO1]PKGMAT(I-1) + ' / ' + [M:DMWQUO1]PKGSIZ(I-1)
    # search if key is already in array. if this is the case then we get the according percentage value to the key
    # otherwise get a new index we may store the data and set the key percentage to 0
    KEYINDEX = find(PCTKEY, KEYS_ARRAY)
    If KEYINDEX : KEYPCT = KEYPCT_ARRAY(KEYINDEX) : Else KEYINDEX = maxtab(KEYPCT_ARRAY) + 1 : KEYPCT = 0 : Endif
    # add the percentage of the current line and store it again in the array
    KEYPCT += [M:DMWQUO1]QUOTA(I-1)
    KEYPCT_ARRAY(KEYINDEX)  = KEYPCT
    KEYS_ARRAY(KEYINDEX)    = PCTKEY
  Next

  # now check percentage array if there is one index != 100% and if so, then output error and deny modif or create
  For I=1 To maxtab(KEYPCT_ARRAY)
    If KEYPCT_ARRAY(I) <> 100
      If GMESSAGE = '' : GMESSAGE += mess(9,7707,1) + '\' : Endif
      GOK=0 : GERR = 1 :  GMESSAGE+= KEYS_ARRAY(I) + " = " + num$(KEYPCT_ARRAY(I)) + '% (' + mess(00029,03701,1) + ': ' + num$(100 - KEYPCT_ARRAY(I)) + '%)\'
    Endif
  Next
End

