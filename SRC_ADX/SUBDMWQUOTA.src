Subprog C_ITMGRP(VALEUR)
Variable Char    VALEUR()

  If !clalev([DMWPAOR]) : Local File DMWPAORD [DMWPAOR] : Endif
  Filter [F:DMWPAOR] Where COD = [M:DMWQUO0]SCMCOD and TYP = 1 and TYPID = VALEUR
  If rowcount([F:DMWPAOR]) <= 0
    Call ERREUR (func AFNC.MES1(mess(4,7707,1),[M:DMWQUO0]SCMCOD)) From GESECRAN
    mkstat = 2
  Endif
  Filter [F:DMWPAOR]
End


######################################################################################

