$ACTION
Case ACTION
   When "OUVRE"       : Gosub DECLARE From TABLEAUX
   When "FILTRE"      : Default File [DMWQUOH]
   When "LIENS"       : Gosub LIENS From TABLEAUX
   When "MODIF"       : Gosub MODIF #From TABLEAUX
   When "ANNULE"      : Gosub ANNULE From TABLEAUX
   When "APRES_CRE"   : Gosub LIENS From TABLEAUX
   When "APRES_MOD"   : Gosub LIENS From TABLEAUX
   When "CREATION"    : Gosub CREATION# From TABLEAUX
   When "DEFLIG"      : Gosub DEFLIG
   When "INICRE_LIG"  : Gosub INICRE_LIG
   When "LIENS_LIG"   : Gosub LIENS_LIG
   When "INICRE"      : Gosub INICRE
   When "ANNULE"      : Gosub ANNULE From TABLEAUX
   When "SETBOUT"     : Gosub SETBOUT
 When Default
Endcase
Return

#########################################################################
# Tableaux inits
#########################################################################
$DEFLIG
  #Infbox "deflig"
  Default Mask [DMWQUO1]
  Default File [DMWQUOD]
  CRIT    = 'QUOTANUM='+num$([F:DMWQUOH]QUOTANUM)# + ' and ' + ' VER='+num$([M:DMWPPA0]VER)
  FICLIG  = "DMWQUOTAD"
  ABLIG   = "DMWQUOD"
  ZONLIG  = "LIN"
 # NBLIG = 2
Return


#########################################################################
## Creation
#########################################################################
$CREATION
  Call PERCENTAGE_VALIDATION()
  If GOK=1 : Gosub CREATION From TABLEAUX : Endif
Return

#########################################################################
## Modification
#########################################################################
$MODIF
  #Gosub MODIF From TABLEAUX
  Call PERCENTAGE_VALIDATION()
#  If GUSER = "ANGRE"
#    Infbox num$(GOK)
#  Endif
  If GOK=1 : Gosub MODIF From TABLEAUX : Endif
Return



#########################################################################
# Initialisation
# we have a unique counter field (PKGNUM) and a version counter field (PKGVERSION)
# the version counterfield is related to COD
#########################################################################
$INICRE
 # Raz [F:DMWQUOH]
  [F:DMWQUOH]QUOTANUM     = func GETNEXTNUM()
  [F:DMWQUOH]QUOTANUM     = [F:DMWQUOH]QUOTANUM
  #[F:DMWQUOH]ITMGRP = [M:DMWQUO0]ITMGRP
  #[F:DMWQUOH]SCMCOD = [M:DMWQUO0]SCMCOD
  #Infbox "PKGNUM = " + num$([F:DMWPPAH]PKGNUM)
  [F:DMWQUOH]VER   = func GETNEXTVERSIONNUMBER([F:DMWQUOH]SCMCOD, [F:DMWQUOH]ITMGRP)
  #[F:DMWQUOH]STRDAT = [M:DMWQUO0]STRDAT
 # [F:DMWQUOH]ENDDAT = [M:DMWQUO0]ENDDAT
  [M:DMWQUO0]VER  = [F:DMWQUOH]VER

  Affzo [M:DMWQUO0]VER
  #if already lines exist (copy) then update
  #Call UPDATELINE([M:DMWPPA0]PKGNUM,[M:DMWPPA0]VER)
Return


