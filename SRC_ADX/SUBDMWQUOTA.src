#########################################################################
# Initialisation detail
#########################################################################
$INICRE_LIG
  [F:DMWQUOD]QUOTANUM     = [F:DMWQUOH]QUOTANUM
  #[F:DMWQUOH]QUOTANUM     = [M:DMWQUO0]QUOTANUM
