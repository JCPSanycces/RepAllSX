#<AdxTL>@(#)3.0.0.0 $Revision$
#################################################################################
## VALMSK Programme principal
#################################################################################
Close Local Mask
GTEST = 0
Local Char    LAN(GLONLAN)(1..5) , ECRAN(GLONAMK)
Local Integer OK
ECRAN = "AFT1"
LAN(1) = "FRA"
#LAN(2) = "ITA"
GTRACE = ""
#Call ACTIVE From TIMING
Call VALID(ECRAN,nomap,1,LAN,0,OK)

#Call ARRET From TIMING
If OK
#Call VISUM(ECRAN) From SUBAMK
Endif
End

#################################################################################
## VALMSK        Prog principal
## VALMSKLEC     Lecture en mémoire
## VALMSKCAL     Calcul coordonnées
## VALMSKSRM     Ecriture du "srm" et validation de l'écran
## VALMSKTRT     Ecriture du traitement automatique
## VALMSKSTD     Mise à jour des TrT standard et spécifiques
## VALMSKIMP     Ecriture du traitement d'import
## VALMSKSUB     Sous-programmes divers (formats, longueur, ...)
#################################################################################

##X3-39935 : If ISVALIDFULL=[V]CST_AYES, validation of screens will be made by taking into
##            account hidden fields of screens. So there will be more functions and programs
##            created to manage screens.

#X3-39935 : Modifications to use Gosub VALIDMSK in place of goto VALIDMSK
Subprog VALIDDIRECT(MASQUE,APPLI,NBLAN,LAN,SILENCE,MOK)
Value    Char    MASQUE
Value    Char    APPLI
Value    Integer NBLAN
Value    Char    LAN()(1..)
Value    Integer SILENCE
Variable Integer MOK
Local Integer VALIDDIFF
Local Integer ISVALIDFULL :#X3-39935

  ISVALIDFULL=[V]CST_ANO :#X3-39935
  VALIDDIFF=1
  Onerrgo ERREUR
  Gosub VALIDMSK
  Onerrgo
End

# --------------------------------------------------------------------------------
#X3-39935
Subprog VALIDFULL(MASQUE,APPLI,NBLAN,LAN,SILENCE,MOK)
Value    Char    MASQUE
Value    Char    APPLI
Value    Integer NBLAN
Value    Char    LAN()(1..)
Value    Integer SILENCE
Variable Integer MOK
Local Integer ISVALIDFULL

  ISVALIDFULL=[V]CST_AYES

  Gosub INIVALIDDIFF
  Onerrgo ERREUR
  Gosub VALIDMSK
  Onerrgo
End
#End X3-39935
# --------------------------------------------------------------------------------
#X3-39935 : Modifications to use Gosub VALIDMSK
Subprog VALID(MASQUE,APPLI,NBLAN,LAN,SILENCE,MOK)
Value    Char    MASQUE
Value    Char    APPLI
Value    Integer NBLAN
Value    Char    LAN()(1..)
Value    Integer SILENCE
Variable Integer MOK
Local Integer ISVALIDFULL

  ISVALIDFULL=[V]CST_ANO
  Gosub INIVALIDDIFF
  Onerrgo ERREUR
  Gosub VALIDMSK
  Onerrgo
End

#X3-39935
$INIVALIDDIFF
Local Integer VALIDDIFF
Local Char EXCLUDDIF(200)
  #  Masques à exclure de la validation différée
  EXCLUDDIF=":TEMPO:VALPCENT:VALIDCAR:AASEL:"

  If dim(GVALIDDIFF)>0 and GVALIDDIFF=3 and instr(1,EXCLUDDIF,":"+MASQUE+":")<=0 and left$(MASQUE,8)<>"DEBUGGER" :  VALIDDIFF=2 : Endif
Return
#end X3-39935

$VALIDMSK
Local Integer TEST : TEST = 0
  MOK = 1

  If TEST
  Call OUVRE_TRACE("") From LECFIC
  Endif

  If !SILENCE
   If VALIDDIFF=2
     Call TEMPON(mess(261,133,1)-MASQUE) From GESECRAN : # Validation différée de l'écran
   Else
     Call TEMPON(mess(74,133,1)-MASQUE) From GESECRAN : # Validation de l'écran
   Endif
  Endif
  If GTRACE<>""
   If VALIDDIFF=2
     Call ECR_TRACE(mess(261,133,1)-MASQUE,0) From GESECRAN : # Validation différée de l'écran
   Else
     Call ECR_TRACE(mess(74,133,1)-MASQUE,0) From GESECRAN : # Validation de l'écran
   Endif
  Endif

  #X3-39935: modifications to not use goto FIN
  If VALIDDIFF=2
    Call GENERDIFFSCREEN(APPLI,MASQUE) From INTRUTILB
  Else

    #  Rajoute de la mémoire si il en manque(si moins de 15 Mo de libre)
    If int(freemem/1024) < 15000
      maxmem = int(maxmem/1024)+15000-int(freemem/1024)
    Endif

    #103231
    #adxmto = max(adxmto,200)
    adxmto = max(adxmto,220)

    # Pour forcer l'allocation de 6 Mo de mémoire (perfs)

    Local Schar TOTO(10)(1024,600)
    Kill TOTO

    Gosub OUVFIC  From VALMSKLEC

    Gosub DEFVAR  From VALMSKLEC

    SAVIFS = adxifs
    SAVIRS = adxirs
    SAVIUM = adxium
    adxifs = ""
    adxirs = chr$(10)
    adxium = GUTF8
    VALFUL=ISVALIDFULL :#X3-39935
    If TEST : Gosub SAV_VAR : Endif
    ECRAN = MASQUE

    Gosub DEFRES From VALMSKLEC

    Gosub LECTURE From VALMSKLEC
    If !OK : Gosub PERDU : Return : Endif

    Gosub PILCAL  From VALMSKCAL
    If !OK : Gosub PERDU : Return : Endif

    Gosub LIENS   From VALMSKLEC
    If !OK : Gosub PERDU : Return : Endif
    Gosub PROG    From VALMSKLEC
    If !OK : Gosub PERDU : Return : Endif

    #Gosub VALMSK  From VALMSKSRM
    #If !OK : Goto PERDU : Endif

    Gosub VALTRT From VALMSKTRT
    Gosub VALTRT From VALMSKSTD

    Gosub VALTRT From VALMSKIMP

    Gosub VALWEB From VALMSKWEB

    Gosub VALMSK From VALMSKMSK

    If TEST : Gosub TRACE_MEM : Endif
    ## Stockage des coordonnées (on en a besoin pour les hard copy)
    #                  Supprimé le 17/01/2006  - CC
    #If adxlog=0
    # Trbegin [AMK]
    #  Gosub MAJX1X2
    # Commit
    #Else
    # Gosub MAJX1X2
    #Endif

    # Géode : validation des interfaces
    If GPRODUIT=1
    Call VALID_ECRAN(APPLI,MASQUE) From GENTRTWE
    Endif
  Endif

  Gosub FIN :#X3-39935
Return

$FIN
  If !SILENCE
    Call TEMPOFF From GESECRAN
  Endif
  If TEST
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  If VALIDDIFF<>2
    adxifs = SAVIFS
    adxirs = SAVIRS
    adxium = SAVIUM
  Endif
#X3-39935
Return

$MAJX1X2
Raz [F:AMK]X1,[F:AMK]X2,[F:AMK]Y1,[F:AMK]Y2
  For B=1 To BLC_NBR
    If BLC_TYP(B)<>5
      [F:AMK]X1(B-1) = BLC_X(B)
      [F:AMK]X2(B-1) = BLC_X(B)+BLC_NCO(B)-1
      [F:AMK]Y1(B-1) = BLC_Y(B)
      [F:AMK]Y2(B-1) = BLC_Y(B)+BLC_NLI(B)-1
    Endif
  Next B
  Rewrite [AMK]
  If fstat
    GOK = 0 : Call FSTA("AMK") From GLOCK
  Endif
Return

$PERDU
  If GMESSAGE<>""
    Call ECR_TRACE(GMESSAGE,1) From GESECRAN
    Raz GMESSAGE
  Endif
  Raz MOK
  Call DEL_TRTMSK(MASQUE,APPLI) From MSKDIV
  Gosub FIN :#X3-39935
#X3-39935
Return

$ERREUR
  Call ECR_TRACE(errp-mess(93,100,1)-num$(errl)+"\"+errmes$(errn)-"("+num$(errn)+")|"-errm,1) From GESECRAN
  MOK = 0
End

############################################################################################
$TRACE_MEM
  Call ECR_TRACE("Mémoire consommée"-num$(CONSOMME),0) From GESECRAN
  Call ECR_TRACE("Mémoire restante"-num$(freemem),0) From GESECRAN
  Call ECR_TRACE("",0) From GESECRAN
Return

$SAV_VAR
Local Integer WOLDVAR , WNEWVAR , WI
Local Char    WTYP(10) , WWVAR(20)
  WOLDVAR = clanbs([L],1)+1
Local Char    WVAR(20)(1..WOLDVAR)
  For WI=1 To WOLDVAR
    WVAR(WI) = clavar([L],WI)
  Next WI
Return

$TEST_VAR
  WNEWVAR = clanbs([L],1)
  If WNEWVAR<>WOLDVAR
    Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
    Call ECR_TRACE("Variables non déclarées",1) From GESECRAN
    For WI=1 To WNEWVAR
      WWVAR = clavar([L],WI)
      If !find(WWVAR,WVAR(1..WOLDVAR))
       Case evalue("type([L]"+WWVAR+")")
        When 1       : WTYP = "Libelle"
        When 2       : WTYP = "Shortint"
        When 3       : WTYP = "Date"
        When 4       : WTYP = "Integer"
        When 5       : WTYP = "Float"
        When 6       : WTYP = "Double"
        When 7,8,9   : WTYP = "Decimal"
        When Default : WTYP = "Char"
       Endcase
       Call ECR_TRACE(WWVAR-"("+WTYP+")",0) From GESECRAN
      Endif
    Next WI
    Call ECR_TRACE(string$(80,"-"),0) From GESECRAN
  Endif
Return

