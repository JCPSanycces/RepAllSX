##########################################################################################################
##########################################################################################################
#Moulinette AVANT
#Module Support client
Subprog AHDKMAJ60
End

#######################################################################
#Moulinette AVANT
#Module Action commerciale
Subprog ACRMMAJ60
End

##########################################################################################################
#Moulinette APRES
#Module Support client
Subprog HDKMAJ60

  Call MAJHDKV8V9([F:ADS]DOSSIER)
End

#######################################################################
#Moulinette APRES
#Module Action commerciale
Subprog CRMMAJ60
End

##########################################################################################################
##########################################################################################################
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
#                SUPPORT CLIENT
#Mise à jour mosdule Support client
#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#

##########################################################################################################
Subprog MAJHDKV8V9(SZAPPLI)
Value Char SZAPPLI

Local Integer IERRFLG
Local Integer IERRCOUNT

  IERRFLG = 0
  IERRCOUNT = 0
  # Appels des différentes moulinettes successives
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("Start CRM Migration V8 to V9") From DOSSUB
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  #-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#-#
  # Moulinette 1
  # Migration transations de saisie SRE
  #---------------------------------------------------#
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("HDK Step 1 : Update table HDKTRS for SRE") From DOSSUB
  IERRFLG = 0
  Call HDKSTEP1(SZAPPLI, IERRFLG)
  If IERRFLG Then
    Call ECR_TIME("HDK Step 1 migration aborted due to errors.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    IERRCOUNT += 1
  Else
    Call ECR_TIME("HDK Step 1 : Completed.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Endif
  # Moulinette 2
  # Migration transations de saisie ITN
  #---------------------------------------------------#
  Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Call ECR_TIME("HDK Step 2 : Update table HDKTRS for ITN") From DOSSUB
  IERRFLG = 0
  Call HDKSTEP2(SZAPPLI, IERRFLG)
  If IERRFLG Then
    Call ECR_TIME("HDK Step 2 migration aborted due to errors.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
    IERRCOUNT += 1
  Else
    Call ECR_TIME("HDK Step 2 : Completed.") From DOSSUB
    Call ECR_TRACE("--------------------------------------",0) From GESECRAN
  Endif
End

###########################################################################################
# Mise à jour des champs de la table HDKTRS-SRE
###########################################################################################
Subprog HDKSTEP1(APPLI, IERR)
Value Char APPLI
Variable Integer IERR

Local Integer INDIC

  #--------------------------------
  # UTIHDK001
  #--------------------------------
  IERR = 0
  If filinfo(filpath("FIL","HDKTRS","fde",APPLI),0) <= 0 Then
    Return
  Endif
  If filinfo(filpath("FIL","HDKTRSVAL","fde",APPLI),0) <= 0 Then
    Return
  Endif
  If filinfo(filpath("FIL","HDKTASK","fde",APPLI),0) <= 0 Then
    Return
  Endif
  #--------------------------------
  Local File =APPLI+".HDKTRS"    [HTR]
  Local File =APPLI+".HDKTRSVAL" [HTV]
  Local File =APPLI+".HDKTASK"   [HDT]
  #--------------------------------
  Local File ADOSSIER [ADS]
  Read [ADS]DOSSIER=[L]APPLI
  #--------------------------------
  Trbegin [HTR]
  For [HTR]HTR0 Where HTRTYP = 2
    # --------------------------
    Read [HTV]HTV0=[F:HTR]HTRTYP;[F:HTR]HTRNUM
    # --------------------------
    Raz INDIC
    If dim([F:HTR]ECCCOD) > 0 Then
      If !find([F:HTR]ECCCOD,1,2,3) Then
        # Version majeure (invisible)
        INDIC = 1
        [F:HTR]ECCCOD = 3
        For NI = 0 To dim([F:HTV]FIENAM)-1
          If [F:HTV]FIENAM(NI) = "" Then
            [F:HTV]FIENAM(NI) = "[SRE9]ECCVALMAJ"
            [F:HTV]FIEVAL(NI) = num$([F:HTR]ECCCOD)
            Break
          Endif
        Next NI
      Endif
    Endif
    If dim([F:HTR]ECCCODMIN) > 0 Then
      If !find([F:HTR]ECCCODMIN,1,2,3) Then
        # Version mineure (invisible)
        INDIC = 1
        [F:HTR]ECCCODMIN = 3
        For NI = 0 To dim([F:HTV]FIENAM)-1
          If [F:HTV]FIENAM(NI) = "" Then
            [F:HTV]FIENAM(NI) = "[SRE9]ECCVALMIN"
            [F:HTV]FIEVAL(NI) = num$([F:HTR]ECCCODMIN)
            Break
          Endif
        Next NI
      Endif
    Endif
    If INDIC = 1 Then
      Rewrite [HTR]
      If fstat Then
        IERR = 1
        Call ECR_TRACE("File HDKTRS, Error =" - num$(fstat), 1) From GESECRAN
      Else
        Rewrite [HTV]
        If fstat Then
          IERR = 1
          Call ECR_TRACE("File HDKTRSVAL, Error =" - num$(fstat), 1) From GESECRAN
        Endif
      Endif
    Endif
  Next
  #--------------------------------
  If IERR = 1 Then
    Rollback
  Else
    Commit
  Endif
  #--------------------------------
End

###########################################################################################
# Mise à jour des champs de la table HDKTRS-ITN
###########################################################################################
Subprog HDKSTEP2(APPLI, IERR)
Value Char APPLI
Variable Integer IERR

Local Integer INDIC

  #--------------------------------
  # UTIHDK001
  #--------------------------------
  IERR = 0
  If filinfo(filpath("FIL","HDKTRS","fde",APPLI),0) <= 0 Then
    Return
  Endif
  If filinfo(filpath("FIL","HDKTRSVAL","fde",APPLI),0) <= 0 Then
    Return
  Endif
  If filinfo(filpath("FIL","HDKTASK","fde",APPLI),0) <= 0 Then
    Return
  Endif
  #--------------------------------
  Local File =APPLI+".HDKTRS"    [HTR]
  Local File =APPLI+".HDKTRSVAL" [HTV]
  Local File =APPLI+".HDKTASK"   [HDT]
  #--------------------------------
  Local File ADOSSIER [ADS]
  Read [ADS]DOSSIER=[L]APPLI
  #--------------------------------
  Trbegin [HTR]
  For [HTR]HTR0 Where HTRTYP = 3
    # --------------------------
    Read [HTV]HTV0=[F:HTR]HTRTYP;[F:HTR]HTRNUM
    # --------------------------
    Raz INDIC
    If dim([F:HTR]ECCCOD) > 0 Then
      If !find([F:HTR]ECCCOD,1,2,3) Then
        # Version majeure (invisible)
        INDIC = 1
        [F:HTR]ECCCOD = 3
        For NI = 0 To dim([F:HTV]FIENAM)-1
          If [F:HTV]FIENAM(NI) = "" Then
            [F:HTV]FIENAM(NI) = "[ITN8]ECCVALMAJ"
            [F:HTV]FIEVAL(NI) = num$([F:HTR]ECCCOD)
            Break
          Endif
        Next NI
      Endif
    Endif
    If dim([F:HTR]ECCCODMIN) > 0 Then
      If !find([F:HTR]ECCCODMIN,1,2,3) Then
        # Version mineure (invisible)
        INDIC = 1
        [F:HTR]ECCCODMIN = 3
        For NI = 0 To dim([F:HTV]FIENAM)-1
          If [F:HTV]FIENAM(NI) = "" Then
            [F:HTV]FIENAM(NI) = "[ITN8]ECCVALMIN"
            [F:HTV]FIEVAL(NI) = num$([F:HTR]ECCCODMIN)
            Break
          Endif
        Next NI
      Endif
    Endif
    If INDIC = 1 Then
      Rewrite [HTR]
      If fstat Then
        IERR = 1
        Call ECR_TRACE("File HDKTRS, Error =" - num$(fstat), 1) From GESECRAN
      Else
        Rewrite [HTV]
        If fstat Then
          IERR = 1
          Call ECR_TRACE("File HDKTRSVAL, Error =" - num$(fstat), 1) From GESECRAN
        Endif
      Endif
    Endif
  Next
  #--------------------------------
  If IERR = 1 Then
    Rollback
  Else
    Commit
  Endif
  #--------------------------------
End

