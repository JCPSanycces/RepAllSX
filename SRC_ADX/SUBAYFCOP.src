#<AdxTL>@(#)2.0.0.0 $Revision$
#<AdxTL>@(#)2.0.0.0 $Revision$
######################################################################################
##  Xtend: Copie fiche Element champ
##  Version 0001
######################################################################################
#    GACTION
#        AYSCOP        Copie d'une donnée Xtend
#        AYSFCYCOP     Copie globale d'un site
#    [L]
#        FCYORG, DOSORG
#        FCYDES, DOSDES
#        ELTCOD
#    [F:AYS1] Site origine       Ouvert et lu
#    [F:AYS2] Site destination   Ouvert et lu
######################################################################################
$TRTCOP
If [L]DOSORG=nomap
 Local File AYTELTFLD [AYF1]
 Local File ATEXTE    [ATX1]
 Local File ATEXTRA   [AXX1]
Else
 Local File =[L]DOSORG+".AYTELTFLD"  [AYF1]
 Local File =[L]DOSORG+".ATEXTE"     [ATX1]
 Local File =[L]DOSORG+".ATEXTRA"    [AXX1]
Endif
If [L]DOSDES=nomap
 Local File AYTELTFLD  [AYF2]
 Local File ATEXTE     [ATX2]
 Local File ATEXTRA    [AXX2]
Else
 Local File =[L]DOSDES+".AYTELTFLD"  [AYF2]
 Local File =[L]DOSDES+".ATEXTE"     [ATX2]
 Local File =[L]DOSDES+".ATEXTRA"    [AXX2]
Endif

Read [AYF1]AYF0 = [L]FCYORG;[L]ELTCOD
If fstat
  OK=0
  Call RSTA("AYF",[L]FCYORG-[L]ELTCOD) From GLOCK
  Goto FINALLY
Endif

Read [AYF2]AYF0 = [L]FCYDES;[L]ELTCOD
DES_ELTCOD=[F:AYF2]FIECOD : Gosub MSGDESOBJ From AYTCOP
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif


$FINALLY
Close Local File [AYF1], [ATX1] , [AXX1]
&              , [AYF2], [ATX2] , [AXX2]
Return

$TR_COP
GOK = 1
Trbegin [AYF2] , [ATX2]
 If DES_HASELT
     Delete [AYF2] Where FCYCOD=[L]FCYDES and FIECOD=[L]DES_ELTCOD
     If fstat=1
      GOK=-1 : GLOCK = "$"+[L]DOSDES+".AYTELTFLD" : Goto ROLL_TR_COP
     Elsif fstat>5
      GOK = 0 : Call RSTA("AYF2","") From GLOCK : Goto AB_TR_COP
     Endif
 Endif

 For [AYF1]AYF0 Where FCYCOD=[L]FCYORG & FIECOD=[L]ELTCOD
  [F:AYF2] = [F:AYF1]
  [F:AYF2]FCYCOD = [L]FCYDES
  Call COPTEXTRA("AYTELTFLD","INTIT",[F:AYF1]FCYCOD,[F:AYF1]FIECOD,[L]FCYDES) From SUBAYS
  If GOK<1 : Break : Endif
  [F:AYF2]UPDUSR = GUSER
  [F:AYF2]UPDDAT = date$
  # [F:AYF2]UPDTIM = time  - 93575
  Call SET_UPDTIM("AYF2") From AYTCOP # 93575
  [F:AYF2]BRWX3  = [F:AYF2]FCYCOD+"_"+[F:AYF2]FIECOD
#*  [F:AYF2]CODACT = [L]ELTCODACT
  Write [AYF2]
  If fstat
   GOK=0 : Call FSTA("AYF2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif

Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif
