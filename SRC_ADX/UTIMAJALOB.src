#<AdxTL>@(#)4.0.0.0 $Revision$
Call GENE
End

#----------------------------------------------------------------------------------------#
# Fill CNTTYP colummn in ACLOB and ABLOB tables
#----------------------------------------------------------------------------------------#

Subprog GENE
Call OUVRE_TRACE("Fill CNTTYP colummn in ACLOB and ABLOB tables") From LECFIC
Local File ADOSSIER [ADS2]
If nomap<>GDOSX3
 Call ECR_TRACE("*** Update folder"-nomap,0) From GESECRAN
 Call PATCH(nomap)
Else
 For [ADS2]
  mkstat = 0
  Call C_APPLI([F:ADS2]DOSSIER) From VALDICO
  If mkstat
   Call ECR_TRACE(GMESSAGE,-1) From GESECRAN
  Else
   Call ECR_TRACE("*** Update folder"-[F:ADS2]DOSSIER,0) From GESECRAN
   Call PATCH([F:ADS2]DOSSIER)
  Endif
 Next ADS2
Endif
Close Local File [ADS2]
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC
End

#----------------------------------------------#
Subprog PATCH(DOSSIER)
Value Char DOSSIER
If DOSSIER=nomap
 Local File ABLOB [ABB]
 Local File ACLOB [ACB]
 Local File ATYPEPRO [ATYP]
 Local File ATABDIV [ADI]
 Local File ATABTAB [ADV]
Else
 Local File =DOSSIER+".ABLOB" [ABB]
 Local File =DOSSIER+".ACLOB" [ACB]
 Local File =DOSSIER+".ATYPEPRO" [ATYP]
 Local File =DOSSIER+".ATABDIV" [ADI]
 Local File =DOSSIER+".ATABTAB" [ADV]
Endif


If dim([ABB]CNTTYP)>0
Gosub MAJ_CNTTYP_ABLOB
Endif

If dim([ACB]CNTTYP)>0
Gosub MAJ_CNTTYP_ACLOB
Endif

Close Local File [ABB]
Close Local File [ACB]
Close Local File [ADI]
Close Local File [ADV]
Close Local File [ATYP]
End

#----------------------------------------------------------------------------------------#
$MAJ_CNTTYP_ACLOB
Local Char SQLREQ (250) (3)
Local Char WTABADI902 (GLONADI) (1..)
Local Integer WNBADI902,WNOADI902
Local Char WATYP(GLONATYP)

If pat(DOSSIER,"*@*")

 For [ACB] Where CNTTYP=""
  [F:ACB]CNTTYP=func ASYRLOB.F_ADI902_TO_CNTTYP(CST_ATYPCLOB,DOSSIER,[F:ACB]TYPDOC)
  Rewrite [F:ACB]
  If fstat
   Call ERREUR("ACLOB"-[F:ACB]CODBLB-[F:ACB]IDENT1-[F:ACB]IDENT2-[F:ACB]IDENT3,2) From DOSDIC
  Endif
 Next

Else

  Raz SQLREQ
  SQLREQ(0) = "SELECT DISTINCT A.TYPDOC_0 "
  SQLREQ(1) = "FROM "+DOSSIER+".ACLOB A "
  SQLREQ(2) = "WHERE A.CNTTYP_0=' ' "

  For (Char VTYPDOC(GLONADI)) From num$((GTYPDBA*2)+1)  Sql SQLREQ  As [ZZZ0]
   WNBADI902+=1
   WTABADI902(WNBADI902)=[ZZZ0]VTYPDOC
  Next

  For WNOADI902=1 To WNBADI902
   WATYP=func ASYRLOB.F_ADI902_TO_CNTTYP(CST_ATYPCLOB,DOSSIER,WTABADI902(WNOADI902))
   If WATYP<>""
    Trbegin [ACB]
    Update [ACB] Where CNTTYP="" & TYPDOC=WTABADI902(WNOADI902) With CNTTYP=WATYP
    Commit
   Endif
  Next
Endif

Return

#----------------------------------------------------------------------------------------#
$MAJ_CNTTYP_ABLOB
Local Char WATYP(GLONATYP)

Trbegin [ABB]
WATYP=func ASYRLOB.F_AML7806_TO_ATYP(7)
Update [ABB] Where CNTTYP="" & TYPBLB=7 With CNTTYP=WATYP
Commit

Trbegin [ABB]
WATYP=func ASYRLOB.F_AML7806_TO_ATYP(6)
Update [ABB] Where CNTTYP="" & TYPBLB=6 With CNTTYP=WATYP
Commit

Trbegin [ABB]
WATYP=func ASYRLOB.F_AML7806_TO_ATYP(5)
Update [ABB] Where CNTTYP="" & TYPBLB=5 With CNTTYP=WATYP
Commit

Trbegin [ABB]
WATYP=func ASYRLOB.F_AML7806_TO_ATYP(4)
Update [ABB] Where CNTTYP="" & TYPBLB=4 With CNTTYP=WATYP
Commit

Trbegin [ABB]
WATYP=func ASYRLOB.F_AML7806_TO_ATYP(3)
Update [ABB] Where CNTTYP="" & TYPBLB=3 With CNTTYP=WATYP
Commit

Trbegin [ABB]
WATYP=func ASYRLOB.F_AML7806_TO_ATYP(2)
Update [ABB] Where CNTTYP="" & TYPBLB=2 With CNTTYP=WATYP
Commit

Trbegin [ABB]
WATYP=func ASYRLOB.F_AML7806_TO_ATYP(1)
Update [ABB] Where CNTTYP="" & TYPBLB=1 With CNTTYP=WATYP
Commit

Trbegin [ABB]
WATYP=func ASYRLOB.F_AML7806_TO_ATYP(0)
Update [ABB] Where CNTTYP="" & TYPBLB=0 With CNTTYP=WATYP
Commit

Trbegin [ABB]
WATYP=func ASYRLOB.F_AML7806_TO_ATYP(0)
Update [ABB] Where CNTTYP="" & TYPBLB>7 With CNTTYP=WATYP
Commit

Return

#-----------------------------------------------------#
