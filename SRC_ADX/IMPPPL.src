#<AdxTL>@(#)7.0.0.0 $Revision$
######################################################################
# IMPPPL : Import des Tarifs Achats                                  #         
######################################################################
$ACTION
Case ACTION
  When "IMP_OUVRE"               : Gosub IMP_OUVRE
  When "IMP_DEFTRT"              : Gosub IMP_DEFTRT
  When "AP_IMPORT"               : Gosub AP_IMPORT    
  When "IMPORT"                  : Gosub IMPORT
  When "IMP_ZONE"                : Gosub IMP_ZONE
  When "IMP_TAB"                 : Gosub IMP_TAB
  When "EXPORT"                  : Gosub EXPORT 
Endcase
Return

######################################################################
# --- 
$IMP_OUVRE
Global Char    GXPLBOULIB (20) (1..9)
Global Char    GXPLBOUZC  (20) (1..9)
Global Char    GXPLBOUZS  (20) (1..9)

If clalev([M:PPLW])<=0 : Local Mask PPLW    [PPLW] : Endif
If clalev([F:TUN])<=0  : Local File TABUNIT [TUN]  : Endif   
If clalev([F:TCU])<=0  : Local File TABCUR  [TCU]  : Endif   

Gosub DECLARE From TABLEAUX

GSPLZON=""     : # pour traitements zones
GPPLTYP=""     : # pour visu libelle

#----- Alimentation du compteur fiche tarif -----#
If !clalev([F:TCA])    Local File TABCOUAFF [TCA]       : Endif
If dim(OK)<1           Local Integer OK                 : Endif
If dim(SAV_GSOCIETE)<1 Local Char SAV_GSOCIETE(GLONCPY) : Endif
#-----
SAV_GSOCIETE=GSOCIETE
Raz GSOCIETE : Call LECTCA(6,OK) From SUBTCA
GSOCIETE=SAV_GSOCIETE
If fstat | !OK
  Call ERREUR(mess(64,199,1)) From GESECRAN : OK=0 : Return
Endif
GMANCOU=[F:TCA]MANCOU(11)
GCODNUM=[F:TCA]CODNUM(11)
Return

######################################################################
# --- il faut changer de fenètre si on change de tarif
#     si c'est le premier enr. ou si on est en rupture
$AP_IMPORT
If GNBIMP=0 | RUPT
  If [L]TRTMSK <> "W0WA1"+num$([F]PLI)+"1"                          : # JL le 22/04/04
     [L]TRTMSK="W0WA1"+num$([F]PLI)+"1"                             : # JL le 22/04/04
      GFLTPLI=[F]PLI : GFLAG=[F]PLI
     Close Mask [PPLW] : Local Mask ="WA1"+num$([F]PLI)+"1" [PPLW]  : # JL le 22/04/04
     # sr 02.12 Demande 80297
     Call ISSCREENOK (nomap,"WA1"+num$([F]PLI)+"1") From INTRUTILB
     Read [PPC] PPC0=[F]PLI
  Endif
Endif

Return

######################################################################
# --- Chargement du nom du bon AUTxxx suivant le paramétrage
$IMP_DEFTRT
GFLTPLI=[F]PLI : GFLAG=[F]PLI
[L]TRTMSK="W0WA1"+num$([F]PLI)+"1"    : # JL le 22/04/04
# sr 02.12 Demande 80297
Call ISSCREENOK (nomap,"WA1"+num$([F]PLI)+"1") From INTRUTILB
Return

######################################################################
# ---
$IMPORT
Local Integer OKCHAMP, NOL
Local Char    TRTTARIF (10)
Global Char G_IMPFIC (5)      : # contient IMPFIC pour eviter controle critères sur entete 
G_IMPFIC=IMPFIC
NOL=[M]NBLIG
TRTTARIF="WAT"+GFLTPLI
Case IMPFIC
  When "PPL"
       # -- Init. des zones de [F:PPL] à ne pas charger en fonction du tarif 
       Gosub INI_IMPORT From =TRTTARIF
       # -- Lignes de la fiche tarif (savoir si c'est une nouvelle ligne)
       Gosub IMP_DECLARE From TRTX3IMP
       If GREP="M"
         ICLEPRIM(0) = "PLILIN"             
         ICLEPRIM(1) = "IMPNUMLIG" 
         NBASTAB = "NBLIG"
         Gosub RECHERCHE_LIGNE From TRTX3IMP
       Endif
       If [F:PPL]IMPNUMLIG : [M]IMPNUMLIG(NOL)=[F:PPL]IMPNUMLIG : Endif
Endcase
Return

######################################################################
# ---
$IMP_TAB
Local Char    IMPZONMSK (20), IMPZONFIC (20)
Local Integer IJL, OKCHAMP 
Local Integer IJLT, ERDATS
Local Date    JLDATE 

Case IMPZON
  When "CRIT1", "CRIT2", "CRIT3", "CRIT4", "CRIT5" 
    IJL = val(mid$(IMPZON,5,1))  
    IMPZONMSK="[M]"+IMPZON+"("+num$(nolign-1)+")" 

    IJLT=evalue ("type ("+IMPZONMSK+")")

    If find(IJLT,1,2,4,5,6,7,9)  
       If evalue (IMPZONMSK) <> val(GIMP(IJL))     
          IMPMOD=1
          Assign IMPZONMSK With val(GIMP(IJL))
       Endif  
    Elsif IJLT=3
       Call SETDATE(JLDATE,GIMP(IJL),[M:AOE1]OPTDAT,ERDATS) From SUBIMPOBJ
       If evalue (IMPZONMSK) <> JLDATE     
          IMPMOD=1
          Assign IMPZONMSK With JLDATE
       Endif  
    Elsif IJLT>10
       If evalue (IMPZONMSK) <> GIMP(IJL)     
          IMPMOD=1
          Assign IMPZONMSK With GIMP(IJL)
       Endif  
    Endif

  When "XFRAREM1", "XFRAREM2", "XFRAREM3", "XFRAREM4", "XFRAREM5", "XFRAREM6", "XFRAREM7", "XFRAREM8", "XFRAREM9"
    IJL = val(mid$(IMPZON,8,1))-1 
    IMPZONMSK = "[M]"+IMPZON+"("+num$(nolign-1)+")" 
    IMPZONFIC = "DCGVAL("+num$(IJL)+")" 
    If evalue("dim("+IMPZONMSK+")")>0    : # la zone masque existe ?
      Call TST_CHAMP("PPL",IMPZONFIC,OKCHAMP) From SUBIMPOBJ
      If OKCHAMP                         : # la zone est dans le parametrage
        If evalue (IMPZONMSK) <> evalue ("[F:PPL]"+IMPZONFIC)
          IMPMOD=1
          Assign IMPZONMSK With evalue ("[F:PPL]"+IMPZONFIC)
        Endif
      Endif 
    Endif
  When Default 
Endcase
Return


######################################################################
# ---
$IMP_ZONE
Return
######################################################################
 
######################################################################
# --- 
$EXPORT
# éclatement des critères
Local Integer JK, RG
Local Char    MANIP (250)
MANIP=[F:PPL]PLICRI
For RG=1 To 5
 JK=instr(1,MANIP,"~")
 If JK
   Assign "GIMP("+num$(RG)+")" With left$(MANIP,JK-1)
   MANIP=(right$(MANIP,JK+1))
 Endif
Next RG
Return
######################################################################
 
