#<AdxTL>@(#)0.0.0.0 $Revision$ Object management BCREG
######################################################################################
## Section automatically added (Object BCREG) 06/01/2017 07:57:58 (MANOW)
######################################################################################
$ACTION

  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "LIENS"        : Gosub LIENS
    When "RAZCRE"       : Gosub RAZCRE
    When "AVANT_CHOI"   : Gosub AVANT_CHOI
    When "CREATION"     : Gosub CREATION
    When "APRES_CRE"    : Gosub APRES_CRE
    When "MODIF"        : Gosub MODIF
    When "APRES_MOD"    : Gosub APRES_MOD
    When "AVANT_MOD"    : Gosub AVANT_MOD
    When "SETBOUT"      : Gosub SETBOUT
    When "EXEBOUT"      : Gosub EXEBOUT
    When "AVANTBOUT"    : Gosub AVANTBOUT
    When "AV_ANNULE"    : Gosub AV_ANNULE
    When "ANNULE"       : Gosub ANNULE
    When "FERME"        : Gosub FERME
    When "BB2_NBSEC"    : Gosub BB2_NBSEC
    When "APRES_MODIF"  : Gosub APRES_MODIF
  Endcase

Return
######################################################################################
######################################################################################
#
#   Object Events (ACTION)
#
######################################################################################
######################################################################################
$OUVRE

  ANOWRITE = 1

  If !clalev([F:BAN])    : Local File BANK         [BAN]    : Endif
  If !clalev([F:PYH])    : Local File PAYMENTH     [PYH]    : Endif
  If !clalev([F:FCY])    : Local File FACILITY     [FCY]    : Endif
  If !clalev([F:CPY])    : Local File COMPANY      [CPY]    : Endif
  If !clalev([F:GCM])    : Local File GACM         [GCM]    : Endif
  If !clalev([F:BAL])    : Local File BALANCE      [BAL]    : Endif

  Global Instance WBANKCASHREG Using C_BANKCASHREG

  Local Integer CREATION_MODE
  CREATION_MODE = (rowcount([F:BCREG]) = 0 )

Return
######################################################################################
$LIENS

  Local  Integer WRET

  WBANKCASHREG = NewInstance C_BANKCASHREG AllocGroup null
  [L]WRET = fmet WBANKCASHREG.AREAD([M:BCREG0]REGNUM)

  If [L]WRET >= [V]CST_AERROR
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WBANKCASHREG)
    Raz WBANKCASHREG.AERROR
    GERR = 1
    Raz [F:BCREG] : Raz [M:BCREG0]
    Return
  Endif

  Gosub REFRESH_PAYMENT_TAB
  If [M:BCREG0]STA = 1
    Raz [L]REPORT1
  Else
    If [M:BCREG0]REGTYP = 1
      [L]REPORT1 = "BANKREGISTER"
    Else
      [L]REPORT1 = "CASHREGISTER"
    Endif
  Endif

Return
######################################################################################
$RAZCRE

  Gosub INITIALIZE
  Affzo [M:BCREG0]

Return
######################################################################################
$AVANT_CHOI

  # creation mode for the very first register record
  If CREATION_MODE
    CREATION_MODE = 0
    REPONSE=GSTANEW
    Gosub NOUVEAU From GOBJSUB
    Gosub SETBOUT From GOBJSUB
  Endif

Return
######################################################################################
$CREATION

  Local  Integer WRET

  SetInstance WBANKCASHREG With [F:BCREG]
  [L]WRET = fmet WBANKCASHREG.AINSERT()
  If [L]WRET >= [V]CST_AERROR
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WBANKCASHREG)
    Raz WBANKCASHREG.AERROR
    GOK = 0 : GERR = 1
    Return
  Endif

  SetInstance [F:BCREG] With WBANKCASHREG

Return
######################################################################################
$APRES_CRE

  Gosub RELIT From GOBJSUB

Return
######################################################################################
$AVANT_MOD

  If([M:BCREG0]STA = 2)
      OK = 0 : GERR = 1
      GMESSAGE =  mess(20,7702,1)
  Endif

Return
######################################################################################
$MODIF

  Local  Integer WRET

  SetInstance WBANKCASHREG With [F:BCREG]

  [L]WRET = fmet WBANKCASHREG.AUPDATE()
  If [L]WRET >= [V]CST_AERROR
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WBANKCASHREG)
    Raz WBANKCASHREG.AERROR
    GOK = 0 : GERR = 1
    Return
  Endif

Return
######################################################################################
$APRES_MOD

  Gosub RELIT From GOBJSUB

Return
######################################################################################
$SETBOUT

  Local Char BUTTONS_TO_DISABLE(30)

  # set global common GFCY to be used by AUTORIS_OPT
  GFCY=[M:BCREG0]FCY

  # disable duplication
  BUTTONS_TO_DISABLE = "D"

  # disable Delete button
  If([M:BCREG0]STA = 2 | GREP <> "" | !CLECUR)
    BUTTONS_TO_DISABLE += "A"
  Endif

  # disable Close button
  GBIDC2="L" : Gosub AUTORIS_OPT From CONTX3
  If([M:BCREG0]STA = 2 | GREP <> "" | !CLECUR | !GBIDI2)
    Call VIREBOUT (CHAINE,"2") From GOBJET
  Endif

  If ![M:BCREG0]UNPOSTEDPAYS
    BUTTONS_TO_DISABLE += "3"
  Else
    GBIDC2 = "G" : Gosub AUTORIS_OPT From CONTX3
    If !GBIDI2
      BUTTONS_TO_DISABLE += "3"
    Endif
  Endif

  # disable Payments button
  GBIDC2="P" : Gosub AUTORIS_OPT From CONTX3
  If !GBIDI2
	BUTTONS_TO_DISABLE += "1"
  Endif

  Call VIREBOUT (CHAINE, BUTTONS_TO_DISABLE) From GOBJET

  # ISSUE 58984 by MRDAB 2017-10-21 - enable Open register action/button
  If([M:BCREG0]STA = 2 and fmet WBANKCASHREG.PERIOD_CLOSED() = 0)
    GBIDC2="O" : Gosub AUTORIS_OPT From CONTX3
    If GBIDI2
      CHMEN += "G"
    Endif
  Endif
  # ISSUE END

Return
######################################################################################
$AV_ANNULE

  ANOWRITE = 1

Return
######################################################################################
$ANNULE

  Local  Integer WRET

  WRET = fmet WBANKCASHREG.ADELETE()
  If WRET >= [V]CST_AERROR
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WBANKCASHREG)
    Raz WBANKCASHREG.AERROR
    GOK = 0 : GERR = 1
    Return
  Endif

Return
######################################################################################
$FERME

  If (WBANKCASHREG <> null) : FreeGroup WBANKCASHREG : Endif
  Kill WBANKCASHREG

Return
######################################################################################
$EXEBOUT

Case BOUT
  When "1"  : Gosub UPDATE_BC_REGISTER #This is the payments button. After payments we update balance
              Gosub RELIT From GOBJSUB
  When "2"  : Gosub CLOSE_REGISTER
  When "3"  : Gosub POST_PAYMENTS
Endcase

Return
######################################################################################
######################################################################################
$AVANTBOUT
Case BOUT
  When "G"  : Gosub OPEN_REGISTER # ISSUE 58984 by MRDAB 2017-10-22 - Open register menu handled
Endcase

Return
######################################################################################
######################################################################################
$BB2_NBSEC

  Global Tinyint FROM_LINE
  mkstat = 4

Return
######################################################################################
######################################################################################
$APRES_MODIF

If COUZON = "NBSEC"
  If dim ([V]FROM_LINE)>0
    Kill [V]FROM_LINE
    Gosub UPDATE_BC_REGISTER
    REP="M"
    Gosub ABANDON From GOBJSUB
  Endif
Endif

Return
######################################################################################
######################################################################################
#
#   Button Events (BOUT)
#
######################################################################################
######################################################################################
$UPDATE_BC_REGISTER

  #After Payments, force an update on not closed Bank\Cash register
  #This will recalculate the closing balance
  If WBANKCASHREG.STA = 1
    Local Integer WRET

    [L]WRET = fmet WBANKCASHREG.AUPDATE()
    If [L]WRET >= [V]CST_AERROR
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WBANKCASHREG)
      Raz WBANKCASHREG.AERROR
      GOK = 0 : GERR = 1
      Return
    Endif

  Endif

Return
######################################################################################
$CLOSE_REGISTER

  Local  Integer WRET
  Local Integer YESNO : YESNO = 2 :# Yes

  Call OUINON(mess(1, 7702, 1), YESNO) From GESECRAN

  If YESNO <> 2
      Return
  Endif

  [L]WRET = fmet WBANKCASHREG.CLOSE_REGISTER()

  If [L]WRET >= [V]CST_AERROR
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WBANKCASHREG)
      Raz WBANKCASHREG.AERROR
      GERR = 1
      Return
  Endif

  Gosub RELIT From GOBJSUB

Return
######################################################################################
######################################################################################
# ISSUE 58984 by MRDAB 2017-10-22
$OPEN_REGISTER

  Local  Integer WRET

  [L]WRET = fmet WBANKCASHREG.OPEN_REGISTER()
  If [L]WRET >= [V]CST_AERROR
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WBANKCASHREG)
      Raz WBANKCASHREG.AERROR
      GERR = 1
      Return
  Endif

  Gosub RELIT From GOBJSUB

Return
# ISSUE END
######################################################################################
######################################################################################
#
#   Screen field events (Subprog #_FIELD)
#
######################################################################################
######################################################################################
Subprog C_FCY(VALEUR)
Variable Char    VALEUR()

  WBANKCASHREG.FCY = VALEUR
  Gosub CHECK_IF_ERROR

  If !mkstat
    [M:BCREG0]CPY = WBANKCASHREG.CPY
  Endif

End
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()

  If [M:BCREG0]FCY <> ""
    Local Integer SAVREGTYP : SAVREGTYP = [M:BCREG0]REGTYP
    Gosub INITIALIZE
    [M:BCREG0]FCY = VALEUR
    [M:BCREG0]REGTYP = SAVREGTYP
  Endif

  WBANKCASHREG.FCY = VALEUR
  WBANKCASHREG.REGTYP = [M:BCREG0]REGTYP
  [M:BCREG0]CPY = WBANKCASHREG.CPY

  Affzo [M:BCREG0]

End
######################################################################################
Subprog AM_REGTYP(VALEUR)
Variable Integer VALEUR

  Local Char SAVFCY(GLONFCY) : SAVFCY = [M:BCREG0]FCY
  Gosub INITIALIZE
  [M:BCREG0]FCY = SAVFCY
  [M:BCREG0]REGTYP = VALEUR

  WBANKCASHREG.FCY = [M:BCREG0]FCY
  WBANKCASHREG.REGTYP = [M:BCREG0]REGTYP
  [M:BCREG0]CPY = WBANKCASHREG.CPY

  Affzo [M:BCREG0]

End
######################################################################################
Subprog C_REGCOD(VALEUR)
Variable Char    VALEUR()

  Local  Integer WRET

  [L]WRET = fmet WBANKCASHREG.REGCOD_VALIDATE([M:BCREG0]REGNUM, VALEUR, [M:BCREG0]REGTYP, [M:BCREG0]CPY, [M:BCREG0]FCY, [M:BCREG0]STARTDAT, [M:BCREG0]FINDAT)

  If [L]WRET >= [V]CST_AERROR
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WBANKCASHREG)
    Raz WBANKCASHREG.AERROR
    mkstat = 2
    GERR = 1
  Endif

End
######################################################################################
## Section automatically added (screen BCREG0) 08/04/2017 16:44:30 (MADOR)
######################################################################################
Subprog AM_REGCOD(VALEUR)
Variable Char    VALEUR()

  #Set property value on class
  WBANKCASHREG.REGCOD = VALEUR

  #Intialize currency
  [M:BCREG0]CUR = WBANKCASHREG.CUR

  #Initialize start date and end date
  [M:BCREG0]STARTDAT = fmet WBANKCASHREG.STARTDAT_INITIALIZE([M:BCREG0]REGNUM, VALEUR, [M:BCREG0]FCY)
  WBANKCASHREG.STARTDAT = [M:BCREG0]STARTDAT
  [M:BCREG0]FINDAT = [M:BCREG0]STARTDAT
  WBANKCASHREG.FINDAT = [M:BCREG0]FINDAT

  #Intialize opening balance and closing balance
  [M:BCREG0]OPENBAL = fmet WBANKCASHREG.OPENBAL_INITIALIZE([M:BCREG0]REGNUM, VALEUR, [M:BCREG0]FCY, [M:BCREG0]STARTDAT)
  WBANKCASHREG.OPENBAL = [M:BCREG0]OPENBAL
  [M:BCREG0]CLOSEBAL = [M:BCREG0]OPENBAL
  WBANKCASHREG.CLOSEBAL = [M:BCREG0]CLOSEBAL

  #Check if openbal field should be available for user to input a value or not
  Call OPENBAL_DISPLAY ([M:BCREG0]REGNUM, VALEUR, [M:BCREG0]FCY, [M:BCREG0]STARTDAT)

  #Refresh screen
  Affzo [M:BCREG0]10-99

End
######################################################################################
Subprog C_STARTDAT(VALEUR)
Variable Date    VALEUR

  Local  Integer WRET

  [L]WRET = fmet WBANKCASHREG.STARTDAT_VALIDATE([M:BCREG0]REGNUM, [M:BCREG0]REGCOD, [M:BCREG0]CPY, [M:BCREG0]FCY, VALEUR, [M:BCREG0]FINDAT)

  If [L]WRET >= [V]CST_AERROR
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WBANKCASHREG)
    Raz WBANKCASHREG.AERROR
    mkstat = 2
    GERR = 1
  Endif

End
######################################################################################
Subprog AM_STARTDAT(VALEUR)
Variable Date    VALEUR

  WBANKCASHREG.STARTDAT = VALEUR
  [M:BCREG0]FINDAT = WBANKCASHREG.FINDAT

  If GREP = "C"

    #Intialize opening balance and closing balance
    [M:BCREG0]OPENBAL = fmet WBANKCASHREG.OPENBAL_INITIALIZE([M:BCREG0]REGNUM, [M:BCREG0]REGCOD, [M:BCREG0]FCY, VALEUR)
    WBANKCASHREG.OPENBAL = [M:BCREG0]OPENBAL
    [M:BCREG0]CLOSEBAL = [M:BCREG0]OPENBAL
    WBANKCASHREG.CLOSEBAL = [M:BCREG0]CLOSEBAL

    #Check if openbal field should be available for user to input a value or not
    Call OPENBAL_DISPLAY ([M:BCREG0]REGNUM, [M:BCREG0]REGCOD, [M:BCREG0]FCY, VALEUR)

  Endif

  #Refresh screen
  Affzo [M:BCREG0]10-99

End
######################################################################################
Subprog C_FINDAT(VALEUR)
Variable Date    VALEUR

  Local  Integer WRET

  [L]WRET = fmet WBANKCASHREG.FINDAT_VALIDATE([M:BCREG0]REGNUM, [M:BCREG0]REGCOD, [M:BCREG0]CPY, [M:BCREG0]FCY, [M:BCREG0]STARTDAT, VALEUR)

  If [L]WRET >= [V]CST_AERROR
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WBANKCASHREG)
    Raz WBANKCASHREG.AERROR
    mkstat = 2
    GERR = 1
  Endif

End
######################################################################################
## Section automatically added (screen BCREG0) 08/07/2017 09:30:23 (MADOR)
######################################################################################
Subprog AM_FINDAT(VALEUR)
Variable Date    VALEUR

  WBANKCASHREG.FINDAT= [M:BCREG0]FINDAT

End
######################################################################################
Subprog AM_OPENBAL(VALEUR)
Variable Decimal VALEUR

  WBANKCASHREG.OPENBAL = VALEUR
  [M:BCREG0]CLOSEBAL = WBANKCASHREG.CLOSEBAL
  Affzo [M:BCREG0]CLOSEBAL

End
######################################################################################
######################################################################################
Subprog IB_NBSEC

  Raz GBOUT2
  If GREP = ""
    Call TEXTE(7013,GBOUT2) From OBJDIV
  Endif

End
######################################################################################
######################################################################################
######################################################################################
######################################################################################
#
#   Miscellanueous functions ans labels
#
######################################################################################
######################################################################################
$CHECK_IF_ERROR

  GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WBANKCASHREG)
  If GMESSAGE <> ""
    Raz WBANKCASHREG.AERROR
    GOK = 0 : GERR = 1
    mkstat = 2
  Endif

Return
######################################################################################
$REFRESH_PAYMENT_TAB

  Local Integer I, WRET
  Local Decimal BALANCE
  Local Char    DEVLED(GLONCUR)

  Call SETCUR(1,[M:BCREG0]CPY,DEVLED) From CPTDIV
  [M:BCREG0]UNPOSTEDPAYS = 0

  If WBANKCASHREG.REGNUM <> ""
      BALANCE           = WBANKCASHREG.OPENBAL
      nolign = 0
      Filter [F:PYH] Where [F:PYH]REGNUM = WBANKCASHREG.REGNUM Order By [F:PYH]CREDATTIM
      For [F:PYH]
        If [F:PYH]STA < 9 : [M:BCREG0]UNPOSTEDPAYS += 1 : Endif
        I = nolign
        [M:BCREG0]PYHSNS(I) = [F:PYH]SNS
        [M:BCREG0]PYHNUM(I) = [F:PYH]NUM
        [M:BCREG0]PYHSTA(I) = [F:PYH]STA
        [M:BCREG0]PYHVALDAT(I) = [F:PYH]VALDAT
        [M:BCREG0]PYHACCDAT(I) = [F:PYH]ACCDAT
        [M:BCREG0]PYHAMTCUR(I) = [F:PYH]AMTCUR
        [M:BCREG0]PYHAMTBAN(I) = [F:PYH]AMTBAN
        If [F:PYH]CURRAT <> 0
            [M:BCREG0]PYHCURRAT(I) = [F:PYH]CURRAT
        Else
            [M:BCREG0]PYHCURRAT(I) = func GET_CURRAT([M:BCREG0]CUR, [F:PYH]CUR, [F:PYH]AMTBAN,
&                                                    DEVLED, [F:PYH]PAYTYP, [F:PYH]ACCDAT)
        Endif
        [M:BCREG0]PYHCUR(I) = [F:PYH]CUR
        [M:BCREG0]PYHDES(I) = [F:PYH]DES
        [M:BCREG0]PYHBPR(I) = [F:PYH]BPR
        [M:BCREG0]PYHACC(I) = [F:PYH]ACC
        If num$([F:PYH]SNS) = "1"
          BALANCE             = BALANCE - [F:PYH]AMTBAN
          [M:BCREG0]PYHBAL(I) = BALANCE
        Elsif num$([F:PYH]SNS) = "2"
          BALANCE             = BALANCE + [F:PYH]AMTBAN
          [M:BCREG0]PYHBAL(I) = BALANCE
        Endif
        nolign += 1
        If nolign >= dim([M:BCREG0]PYHNUM)
          Break
        Endif
      Next
      Filter [F:PYH]
      [M:BCREG0]NBSEC = nolign
  Endif

  Gosub REFRESH_SCREEN

Return
######################################################################################
$INITIALIZE

  Local  Integer WRET

  [M:BCREG0]UNPOSTEDPAYS = 0

  If (WBANKCASHREG <> null) : FreeGroup WBANKCASHREG : Endif
  WBANKCASHREG = NewInstance C_BANKCASHREG AllocGroup null

  WRET = fmet WBANKCASHREG.AINIT()
  If WRET >= [V]CST_AERROR
    GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(WBANKCASHREG)
    Raz WBANKCASHREG.AERROR
    GOK = 0 : GERR = 1
    Return
  Endif

  SetInstance [F:BCREG] With WBANKCASHREG
  [M:BCREG0] = [F:BCREG]

Return
######################################################################################
$REFRESH_SCREEN

  If([M:BCREG0]STA = 2)
    Diszo [M:BCREG0]
  Else
    Actzo [M:BCREG0]
    Diszo [M:BCREG0]FCY
    Diszo [M:BCREG0]REGTYP
    Diszo [M:BCREG0]REGCOD
    # only for the first register opening balance is enabled
    Call OPENBAL_DISPLAY ([M:BCREG0]REGNUM, [M:BCREG0]REGCOD, [M:BCREG0]FCY, [M:BCREG0]STARTDAT)
  Endif

  Affzo [M:BCREG0]

  If [M:BCREG0]PYHSTA([M:BCREG0]NBSEC) > 0
    [M:BCREG0]PYHSTA([M:BCREG0]NBSEC) = 0
    Affzo [M:BCREG0]PYHSTA([M:BCREG0]NBSEC)
    [M:BCREG0]PYHSNS([M:BCREG0]NBSEC) = 0
    Affzo [M:BCREG0]PYHSNS([M:BCREG0]NBSEC)
  Endif

Return
######################################################################################
$POST_PAYMENTS

Local Integer  SAI
Local Char     NUM(GLONVCR), DEVLOC(GLONCUR), SEP(3)
Local Libelle  PAYTYP(GLONTPY)
Local Integer  I, PAYNB
Local Decimal  MT, MT2

Call OUINON(mess(211,121,1), I) From GESECRAN

If I <> 2 : Return : Endif

If clalev([M:DIA]) : Close Mask [DIA] : Endif
Local Mask PAYREMBAN [DIA]

[M:DIA]ALLCPY = 1
[M:DIA]ALLFCY = 1
[M:DIA]CPY = [M:BCREG0]CPY
Call C_CPY([M:DIA]CPY) From PAYREMBAN
Call AM_CPY([M:DIA]CPY) From PAYREMBAN
[M:DIA]FCY = [M:BCREG0]FCY
Call C_CPY([M:DIA]CPY) From PAYREMBAN
[M:DIA]ALLTYP = 2
[M:DIA]ALLLOT = 2
[M:DIA]ALLBAN = 1
[M:DIA]BAN = [M:BCREG0]REGCOD
[M:DIA]ALLUSR = 2
[M:DIA]USR = ""
[M:DIA]ALLFRMTYP = 2
[M:DIA]PRO = 2
[M:DIA]TRC = 2
[M:DIA]ACCSTA=9
[M:DIA]BCREG = 2
[M:DIA]NB=0

Call OUVRE_TRACE(GMESSAGE) From LECFIC

For I = 0 To [M:BCREG0]NBSEC-1
  If [M:BCREG0]PYHSTA(I) < 9
    Read [F:PYH]PYH0 = [M:BCREG0]PYHNUM(I)
    [M:DIA]PAY5=2 : [M:DIA]PAY7=1 : [M:DIA]PAY9=1
    Call PAYCPT([M:BCREG0]PYHNUM(I)) From PAYCPTA
    [M:DIA]PAY5=1 : [M:DIA]PAY7=2 : [M:DIA]PAY9=1
    Call PAYCPT([M:BCREG0]PYHNUM(I)) From PAYCPTA
    [M:DIA]PAY5=1 : [M:DIA]PAY7=1 : [M:DIA]PAY9=2
    Call PAYCPT([M:BCREG0]PYHNUM(I)) From PAYCPTA
    PAYNB += 1
    If sum([M:DIA]NB(0..2)) <> PAYNB : Break : Endif
  Endif
Next

Call FERME_TRACE From LECFIC

If sum([M:DIA]NB(0..2))=0
  # No payment processed
  Call MESSAGE (mess(2,117,1)) From GESECRAN
Endif

Close Mask [DIA]

Call LEC_TRACE                          From LECFIC

Raz GMESSAGE

Gosub REFRESH_PAYMENT_TAB

Return
######################################################################################
Funprog GET_CURRAT(CURBAN, CUR, AMTBAN, CURCPY, PAYTYP, ACCDAT)
Value Char       CURBAN
Value Char       CUR
Value Decimal    AMTBAN
Value Char       CURCPY
Value Char       PAYTYP
Value Date       ACCDAT

  Local Decimal CURRAT(0..1)
  Local Integer STAT
  Local Decimal AMTC, AMTC1

  If clalev([F:TPY])=0 : Local File TABPAYTYP [TPY] : Endif
  Read [TPY]TPY0 = PAYTYP;GCURLEG

  If (CURBAN = CUR or AMTBAN = 0) and CUR <> CURCPY
    Call CONVERT4(CUR,CURCPY,CURCPY,[F:TPY]RATTYP,ACCDAT,AMTC,AMTC1,[L]STAT,[L]CURRAT) From TRTDEV
  Else
    Call CONVERT4(CURBAN,CURCPY,CURCPY,[F:TPY]RATTYP,ACCDAT,AMTC,AMTC1,[L]STAT,[L]CURRAT) From TRTDEV
  Endif

  Filter [F:TPY]

  LogicClose File [TPY]

End [L]CURRAT(0)
######################################################################################
Subprog OPENBAL_DISPLAY (P_REGNUM, P_REGCOD, P_FCY, P_STRDAT)
Value Char P_REGNUM
Value Char P_REGCOD
Value Char P_FCY
Value Date P_STRDAT

  If !clalev([F:BCREG2]) : Local File BANKCASHREG  [BCREG2] : Endif

  #Check if openbal field should be available for user to input a value or not
  Filter [F:BCREG2] Where [F:BCREG2]REGCOD = P_REGCOD & [F:BCREG2]REGNUM <> P_REGNUM &
&                         [F:BCREG2]FCY = P_FCY Order By [F:BCREG2]STARTDAT Asc
  Read [F:BCREG2] First
  Filter [F:BCREG2]
  If !fstat & (P_STRDAT<>AVOID.ADATE & [F:BCREG2]STARTDAT< P_STRDAT)
    Diszo [M:BCREG0]OPENBAL
  Else
    Actzo [M:BCREG0]OPENBAL
  Endif

  LogicClose File [F:BCREG2]

End
######################################################################################
