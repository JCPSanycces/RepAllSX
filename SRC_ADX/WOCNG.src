# Superviseur
# Gestion objet CNG

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:07:26"
A_USER  = "DOC"
A_STAMP = "20181109230726"
Return

$DEFAUT
Default File [CNG]
Return

$OUVFIC
Local File CNGCPY [CNG]
Return

$NOMFIC
Local Integer NBLNK , TITLNK(1..20)
Local Char    OBJLNK(GLONAOB)(1..20) , CODLNK(GLONADI)(1..20)
Local Char    DESLNK(20)(1..20) , ABRLNK(GLONABR)(1..20)
Local Integer NUMLNK(1..20) , LIGLNK(1..20)
Local Char    NOMFIC(GLONATB) , ABFIC(GLONABR) , ABTAB(GLONABR) , NOMINT(GLONAVA)
Local Integer TYPGES , FLGSTAT , SELORD , TYPOBJ
Local Char    ZSITE(GLONAVA), ZACC(GLONAVA), FLDGRF(GLONAVA), FLDLEG(GLONAVA), FLDGRC(GLONAVA)
Local Char    REPORT1(GLONARP) , REPORT2(GLONARP) , NOMKEY(GLONAVA)
Local Integer DELDEF, FCYREQ
Local Char    SELIND(250) , ADDURL(250)
NOMFIC = "CNGCPY"
ABFIC  = "CNG"
ABTAB  = "CNG"
NOMINT = ""
TYPGES = 1
SELORD = 1
ZSITE  = ""
ZACC   = ""
FLDGRF = ""
FLDGRC = ""
FLDLEG = ""
FCYREQ = 0
PPAG   = 0
SELIND = ""
DELDEF = 0
ADDURL = ""
FLGSTAT = 0
TITOBJ = 56643
NBLNK = 0
Raz NUMLNK , LIGLNK
Return

$OUVRE
If clalev([F:CPY])=0 : Local File COMPANY      [CPY] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA      [AXX] : Endif
Return

$ESPION
NUMESPION = 1
Return

$TIT
Local Char TIT(60)
Call TEXTE(56643,TIT) From OBJDIV
Return

$SETCLE
Local Char CLEPRIM(GLONAVA) , CLESEC(GLONAVA)(0..1) , CLELIG(GLONAVA)
CLEPRIM = 'YEA'
CLESEC(0) = 'CPY'
CLESEC(1) = 'TIM'
Return

$OPTIONS
Local Integer  NBCOND
Local Char     CONDIT(50)(1..20)
Local Char     OPT(1)(1..20) , OPTSEL(20)
Local Char     LIBOPT(30)(1..20), MESSAG(80)(1..20)
NBCOND = 0
OPTSEL = ''
Return

$LIBPAR
Local Char LIBPAR(30)
Call TEXTE(0,LIBPAR) From OBJDIV
Return

$OUVFIC_DERLU
Local Decimal  A_BUFI(0..GNBDERNIER)
Local Char     A_BUFC(200)(0..GNBDERNIER)
Local Char     A_BUF1(5)(0..GNBDERNIER)
Local Shortint A_BUF2(0..GNBDERNIER)
Local Char     A_BUF3(5)(0..GNBDERNIER)
Local Char     A_BUF4(80)(0..GNBDERNIER)
If clalev([F:CNG9])>0 : Close Local File [CNG9] : Endif
Local File (
& Decimal  A_TABI,
& Char     A_TABC(200),
& Char     A_TAB1(5),
& Shortint A_TAB2,
& Char     A_TAB3(5),
& Char     A_TAB4(80)
& ) From Variable A_BUFI,A_BUFC,A_BUF1,A_BUF2,A_BUF3,A_BUF4
& As [CNG9]
Return

$LEC_DERLU
Read [CPY]CPY0=[F:CNG]CPY
If fstat : Raz [F:CPY] : Endif
Read [AXX]AXX0="TIMCOD";"DES";GLANGUE;[F:CPY]LEG;[F:CNG]TIM
If fstat : Raz [F:AXX] : Endif
Return

$CHARGE_DERLU
If clalev([F:CNG9])>0
 Read [CNG9] = [F:CNG9]A_TABI
 [L]CLE = [F:CNG9]A_TABC
Endif
Return

$REMP_DERLU
If clalev([F:CNG9])>0
 Filter [CNG9]
& Where A_TABI<>0
& Order by A_TABI
 Fillbox [CNG0] GAU_CHE9
Endif
Return

$CLE_DERLU
If clalev([F:CNG9])>0
 Local Integer A_IND
 Local Char    A_CLEDERLU(200)
 A_CLEDERLU = ""
 A_CLEDERLU = num$([F:CNG]YEA)+"~"
 A_CLEDERLU += [F:CNG]CPY+"~"
 A_CLEDERLU += [F:CNG]TIM+"~"
 A_IND = find(A_CLEDERLU,A_BUFC)
 If A_IND
  [F:CNG9]A_TABI = A_BUFI(A_IND-1)
 Else
  Raz [F:CNG9]
 Endif
Endif
Return

$OUVRE_LISTE
Local Integer NBSEL , NBTRI , SELCAR
Local Char    SELZON(30)(0..16)
Local Char    SELEXP(200)(0..16)
Local Char    SELLIB(30)(0..16)
Local Char    SELFMT(30)(0..16)
Local Schar   SELFOR(30)(0..16)
Local Integer SELTYP(0..16)
Local Integer SELMAJ(0..16)
Local Char    TRIZON(20)(0..16)
Local Char    TRILIB(30)(0..16)
SELCAR = 2
NBSEL = 0 : NBTRI = 0
NBSEL += 1
SELZON(NBSEL) = "[F:CNG]CPY"
Call TEXTE(1343,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5c"
SELMAJ(NBSEL) = 1
NBTRI += 1
TRIZON(NBTRI) = "[F:CNG]CPY"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:CNG]YEA"
Call TEXTE(1879,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 2
SELFMT(NBSEL) = "N:4F"
SELFOR(NBSEL) = "N:4#"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:CNG]YEA"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:CNG]TIM"
Call TEXTE(1360,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:5X"
SELFOR(NBSEL) = "K:5X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:CNG]TIM"
TRILIB(NBTRI) = SELLIB(NBSEL)
NBSEL += 1
SELZON(NBSEL) = "[F:AXX]TEXTE"
Call TEXTE(4685,SELLIB(NBSEL)) From OBJDIV
SELTYP(NBSEL) = 7
SELFMT(NBSEL) = "K:80X"
SELFOR(NBSEL) = "K:80X"
SELMAJ(NBSEL) = 0
NBTRI += 1
TRIZON(NBTRI) = "[F:AXX]TEXTE"
TRILIB(NBTRI) = SELLIB(NBSEL)
If clalev([F:CNG_])=0
 Gosub OUVFIC_LISTE
Endif
Return

$OUVFIC_LISTE
If clalev([F:CPY])=0 : Local file COMPANY [CPY] : Endif
If clalev([F:AXX])=0 : Local file ATEXTRA [AXX] : Endif
Link [CNG] With
& [CPY]CPY0=[F:CNG]CPY,
& [AXX]AXX0="TIMCOD";"DES";GLANGUE;[F:CPY]LEG;[F:CNG]TIM
& As [CNG_]
[G:CNG_]currind = 1
Return

$DEFAUT_LISTE
Default file [CNG_]
Return

$OUVRE_JOIN
Local Char    ORDRE_JOI(250)
ORDRE_JOI = "A_TABJ1;A_TABJ2;A_TABJ3"
Local Char     A_BUFJ1(5)(1..GNBSEL)
Local Shortint A_BUFJ2(1..GNBSEL)
Local Char     A_BUFJ3(5)(1..GNBSEL)
Local Char     A_BUFJ4(15)(1..GNBSEL)
Local Char     A_BUFJ5(80)(1..GNBSEL)
Local File(
& Char     A_TABJ1(5),
& Shortint A_TABJ2,
& Char     A_TABJ3(5),
& Char     A_TABJ4(15),
& Char     A_TABJ5(80)
& ) From Variable A_BUFJ1, A_BUFJ2, A_BUFJ3, A_BUFJ4, A_BUFJ5
& As [PCEJ]
Return

$TIT_JOIN
Local Char TITJOI(30)(1..5)
Call TEXTE(1343,TITJOI(1)) From OBJDIV
Call TEXTE(1879,TITJOI(2)) From OBJDIV
Call TEXTE(47937,TITJOI(3)) From OBJDIV
TITJOI(4) = mess(59,100,1) : # Type
TITJOI(5) = mess(38,100,1) : # Nom
Return

Subprog FORMCLE(FMT,LG,TIT)
Variable Char    FMT()
Variable Integer LG
Variable Char    TIT()
FMT = "Nf:4#"
LG = 0
TIT = ""
End

Subprog FORMCLE2(FMT)
Variable Char    FMT()
FMT = "Kf:5c"
End

$LIENS
Read [CPY]CPY0 = [F:CNG]CPY
If fstat : Raz [F:CPY] : Endif
Read [AXX]AXX0 = "TIMCOD";"DES";GLANGUE;[F:CPY]LEG;[F:CNG]TIM
If fstat : Raz [F:AXX] : Endif
Return

$LIAISONS
Return

Subprog TITTRN(COD,TIT)
Value Char COD
Variable Char TIT
Local Integer OUV
Local Char    CRITERE(250)
TIT = ""
End

