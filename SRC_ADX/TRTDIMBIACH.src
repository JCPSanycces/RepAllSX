#<AdxTL>@(#)0.0.0.0 $Revision$
# TRTDIMBIACH    Traitement pour les dimensions des documents d'achats BI         #
# ------------------------------------------------------------------------------- #
# FIN_PREQUIS_DEM_ACHAT : Màj dimension PREQUIS avec les commandes d'achat        #
# FIN_PORDER_DEM_LIVR   : Màj dimension PORDER avec les demandes de livraison     #
# FIN_PORDER_ELT_FAC    : Màj dimension PORDER avec les éléments de facturation   #
# FIN_PRECEIPT_ELT_FAC  : Màj dimension PRECEIPT avec les éléments de facturation #
# FIN_PINVOICE_ELT_FAC  : Màj dimension PINVOICE avec les éléments de facturation #
# FIN_PINVOICE_ECHEANCE : Màj dimension PINVOICE avec les échéances               #
###################################################################################
# 06/01/2010 (SYMEU) : Si toutes les règles de synchronisation alimentées par la  #
# Fiche 61356          table d'origine de la dimension sont désactivées, le trai- #
#                      tement n'est pas exécuté                                   #
###################################################################################
# 12/01/2010 (SYMEU) : Problème dans la requête sql avec les demandes de livraison#
# Fiche 61511          fermes quand on est sous sql                               #
###################################################################################
# 15/01/2010 (SYMEU) : Pb d'écriture sous sql-server quand le code postal con-    #
# Fiche 61649          tient des espaces                                          #
###################################################################################

###################################################################
## ACTION Mise à jour des dimensions X3                           #
###################################################################
$ACTION
  Case ACTION
    When "DEBUT_DIM"  : Gosub DEBUT_DIM
    When "OUVRE_DIM"  : Gosub OUVRE_DIM  #--CPO 92324 V7.1: BI modification for data by legislation
    When "FERME_DIM"  : Gosub FERME_DIM  #--CPO 92324 V7.1: BI modification for data by legislation
    When "FIN_DIM"    : Gosub FIN_DIM
  Endcase
Return

$DEBUT_DIM
  #Case TABLE
  #  When "D_XXX" : Gosub DEBUT_XXX
  #Endcase
Return

$FIN_DIM
  Gosub FIN_TABLE
Return

###################################################################################
#--CPO 92324 V7.1: BI modification for data by legislation
$OUVRE_DIM
  Gosub FERME_DIM
  Case TABLE
    When "D_PREQUIS"   : Gosub OUVRE_DIM_PREQUIS
    When "D_PORDER"    : Gosub OUVRE_DIM_PORDER
    When "D_PRECEIPT"  : Gosub OUVRE_DIM_PRECEIPT
    When "D_PINVOICE"  : Gosub OUVRE_DIM_PINVOICE
    When "D_PRETURN"   : Gosub OUVRE_DIM_PRETURN
  Endcase
Return

#----------------------------------------------------------------------------------
$OUVRE_DIM_PREQUIS
  Local File   =GDOSSIER+".PREQUISD"   [WPSD]     # FGR 16/06/2014 : X3SUIVI98503
Return

#----------------------------------------------------------------------------------
$OUVRE_DIM_PORDER
  Local File   =GDOSSIER+".TABVACBPR"  [TVB]
  Local File   =GDOSSIER+".TABVAT"     [TVT]
  Local File   =GDOSSIER+".TABPAYTERM" [TPT]
  Local File   =GDOSSIER+".PORDERQ"    [WPOQ]    # FGR 16/06/2014 : X3SUIVI98503
  Local File   =GDOSSIER+".PORDERP"    [WPOP]    # FGR 16/06/2014 : X3SUIVI98503
  Local File   =GDOSSIER+".PORDERC"    [WPOC]    # FGR 16/06/2014 : X3SUIVI98503
Return

#----------------------------------------------------------------------------------
$OUVRE_DIM_PRECEIPT
  Local File   =GDOSSIER+".TABVACBPR"  [TVB]
  Local File   =GDOSSIER+".TABVAT"     [TVT]
  Local File   =GDOSSIER+".TABPAYTERM" [TPT]
  Local File   =GDOSSIER+".TABDEPAGIO" [TDA]
  If GACTDEB = [V]CST_AYES Then                  # FGR 20/06/2014 : X3SUIVI98503 If func AFNC.ACTIV("DEB") = 1 Then
    Local File =GDOSSIER+".TABEECNAT"  [TEC]
    Local File =GDOSSIER+".TABEECSCH"  [TSC]
  Endif
  Local File   =GDOSSIER+".PRECEIPTD"  [WPTD]    # FGR 16/06/2014 : X3SUIVI98503
Return

#----------------------------------------------------------------------------------
$OUVRE_DIM_PINVOICE
  Local File   =GDOSSIER+".TABVACBPR"  [TVB]
  Local File   =GDOSSIER+".TABVAT"     [TVT]
  Local File   =GDOSSIER+".TABPAYTERM" [TPT]
  Local File   =GDOSSIER+".TABDEPAGIO" [TDA]
  Local File   =GDOSSIER+".TABPIVTYP"  [TPV]
  If GACTDEB = [V]CST_AYES Then                  # FGR 20/06/2014 : X3SUIVI98503 If func AFNC.ACTIV("DEB") = 1 Then
    Local File =GDOSSIER+".TABEECNAT"  [TEC]
    Local File =GDOSSIER+".TABEECSCH"  [TSC]
  Endif
  Local File   =GDOSSIER+".PINVOICED"  [WPID]    # FGR 16/06/2014 : X3SUIVI98503
Return

#----------------------------------------------------------------------------------
$OUVRE_DIM_PRETURN
  Local File   =GDOSSIER+".TABVACBPR"  [TVB]
  Local File   =GDOSSIER+".TABVAT"     [TVT]
  Local File   =GDOSSIER+".TABPAYTERM" [TPT]
  Local File   =GDOSSIER+".TABDEPAGIO" [TDA]
  If GACTDEB = [V]CST_AYES Then                  # FGR 20/06/2014 : X3SUIVI98503 If func AFNC.ACTIV("DEB") = 1 Then
    Local File =GDOSSIER+".TABEECNAT"  [TEC]
    Local File =GDOSSIER+".TABEECSCH"  [TSC]
  Endif
  Local File   =GDOSSIER+".PRETURND"   [WPND]    # FGR 16/06/2014 : X3SUIVI98503
Return

###################################################################################
#--CPO 92324 V7.1: BI modification for data by legislation
$FERME_DIM
  If clalev([F:TVB])  : Close Local File [TVB] : Endif
  If clalev([F:TVT])  : Close Local File [TVT] : Endif
  If clalev([F:TPT])  : Close Local File [TPT] : Endif
  If clalev([F:TDA])  : Close Local File [TDA] : Endif
  If clalev([F:TPV])  : Close Local File [TPV] : Endif
  If clalev([F:TSC])  : Close Local File [TSC] : Endif
  If clalev([F:TEC])  : Close Local File [TEC] : Endif
  If clalev([F:WPSD])  : Close Local File [WPSD] : Endif     # FGR 16/06/2014 : X3SUIVI98503
  If clalev([F:WPOQ])  : Close Local File [WPOQ] : Endif     # FGR 16/06/2014 : X3SUIVI98503
  If clalev([F:WPOP])  : Close Local File [WPOP] : Endif     # FGR 16/06/2014 : X3SUIVI98503
  If clalev([F:WPOC])  : Close Local File [WPOC] : Endif     # FGR 16/06/2014 : X3SUIVI98503
  If clalev([F:WPTD])  : Close Local File [WPTD] : Endif     # FGR 16/06/2014 : X3SUIVI98503
  If clalev([F:WPID])  : Close Local File [WPID] : Endif     # FGR 16/06/2014 : X3SUIVI98503
  If clalev([F:WPND])  : Close Local File [WPND] : Endif     # FGR 16/06/2014 : X3SUIVI98503
Return

###################################################################################
###################################################################################
## FIN_TABLE : Mise à jour des dimensions avec les éléments de facturation        #
###################################################################################
$FIN_TABLE
  Gosub DECL_VAR
  Gosub READ_DIM
  # SYMEU - Fiche 61356 - début
  # Toutes les règles de synchronisation alimentées par la table d'origine de la dimension sont
  # désactivées : on n'exécute pas le traitement
  If [L]DESFLG = 2 Then
    Return
  Endif
  # SYMEU - Fiche 61356 - fin
  Case TABLE
    When "D_PREQUIS"  : Local File =MACHINE+"@"+[F:ABW]COD+".D_PREQUIS" [F:BBB_]  # Dimension PREQUIS
    When "D_PORDER"   : Local File =MACHINE+"@"+[F:ABW]COD+".D_PORDER" [F:BBB_]   # Dimension PORDER
    When "D_PRECEIPT" : Local File =MACHINE+"@"+[F:ABW]COD+".D_PRECEIPT" [F:BBB_] # Dimension PRECEIPT
    When "D_PINVOICE" : Local File =MACHINE+"@"+[F:ABW]COD+".D_PINVOICE" [F:BBB_] # Dimension PINVOICE
    When Default      : Return  # FGR 16/06/2014 : X3SUIVI98503
  Endcase
  # Boucle sur les dossiers
  For D=1 To NBDOS
    If [F:ABI]MULDOS <> 2 & D = 2 Then
      Break
    Endif
    # la dimension n'est pas multi-dossier
    GDOSSIER=TBDOS(D)
    Case TABLE
      When "D_PREQUIS"  : Gosub FIN_PREQUIS_DEM_ACHAT
      When "D_PORDER"   : Gosub FIN_PORDER_DEM_LIVR
                          Gosub FIN_PORDER_ELT_FAC
      When "D_PRECEIPT" : Gosub FIN_PRECEIPT_ELT_FAC
      When "D_PINVOICE" : Gosub FIN_PINVOICE_ELT_FAC
                          Gosub FIN_PINVOICE_ECHEANCE
    Endcase
  Next D
  Close Local File [F:BBB_]
Return

###################################################################################
## Parcours de PREQUISO pour alimenter la dimension PREQUIS avec les commandes d'achat
# liées aux demandes d'achat
###################################################################################
$FIN_PREQUIS_DEM_ACHAT
  If filinfo(filpath("FIL","PREQUISO","fde",GDOSSIER),0) > 0 Then
    IBBB_WRITE = 0   # FGR 16/06/2014 :X3SUIVI98503
    ITIMEBEG = time  # FGR 16/06/2014 :X3SUIVI98503
    Call ECR_TRACE("**   TRTDIMBIACH : PREQUISO"-mess(5,2246,1) - "(" + mess(2,138,1) - ":" - time$ + ")",0) From GESECRAN
    # Requête de sélection des enregistrements de PREQUISO
    WREQ(0)= "select PSD.PSHNUM_0, PSD.PSDLIN_0, PSO.POHNUM_0, PSO.POPLIN_0, PSO.POQSEQ_0, "
    WREQ(0)+="PSH.PRQDAT_0, PSD.EXTRCPDAT_0, PSD.EXTORDDAT_0, PSD.LINCLEFLG_0, PSD.LINORDFLG_0, PSD.LINAPPFLG_0, "
    WREQ(1)="PSD.FBUFLG_0, PSH.REQUSR_0, PSD.LINBUY_0, PSD.ITMDES1_0, PSO.PUU_0, PSD.GROPRI_0, PSD.NETPRI_0, "
    WREQ(1)+="PSD.ORI_0, PSD.CMMPRPNUM_0, PSD.PQHNUM_0, PSD.PPDLIN_0, PSD.WIPNUM_0 "
    WREQ(2)="From "+GDOSSIER+".PREQUISO PSO,"+GDOSSIER+".PREQUIS PSH,"+GDOSSIER+".PREQUISD PSD "
    WREQ(2)+="Where PSH.PSHNUM_0=PSO.PSHNUM_0 and PSD.PSHNUM_0=PSO.PSHNUM_0 and PSD.PSDLIN_0=PSO.PSDLIN_0"
    # FGR 10/10/2014 : X3SUIVI102999
#    For (Char PSHNUM(20), Integer PSDLIN, Char POHNUM(20), Integer POPLIN, Integer POQSEQ,
#&        Date PRQDAT, Date EXTRCPDAT, Date EXTORDDAT, Integer LINCLEFLG, Integer LINORDFLG, Integer LINAPPFLG,
#&        Integer FBUFLG, Char REQUSR(5), Char LINBUY(5), Char ITMDES1(30), Char PUU(3), Decimal GROPRI, Decimal NETPRI,
#&        Integer ORI, Char CMMPRPNUM(20), Char PQHNUM(20), Integer PPDLIN, Char WIPNUM(20))
#&       From WBASE Sql WREQ(0..2) As [F:REQ_]
    For (Char PSHNUM(GLONVCR), Integer PSDLIN, Char POHNUM(GLONPOH), Integer POPLIN, Integer POQSEQ,
&        Date PRQDAT, Date EXTRCPDAT, Date EXTORDDAT, Integer LINCLEFLG, Integer LINORDFLG, Integer LINAPPFLG,
&        Integer FBUFLG, Char REQUSR(GLONAUS), Char LINBUY(GLONAUS), Char ITMDES1(GLONDES), Char PUU(GLONUOM), Decimal GROPRI, Decimal NETPRI,
&        Integer ORI, Char CMMPRPNUM(GLONVCR), Char PQHNUM(GLONVCR), Integer PPDLIN, Char WIPNUM(GLONVCR))
&       From WBASE Sql WREQ(0..2) As [F:REQ_]
      #Read [F:BBB_]PSD0=[F:REQ_]PSHNUM;[F:REQ_]PSDLIN;[F:REQ_]POHNUM+num$([F:REQ_]POPLIN)+num$([F:REQ_]POQSEQ)
      Look [F:BBB_]PSD0=[F:REQ_]PSHNUM;[F:REQ_]PSDLIN;[F:REQ_]POHNUM+num$([F:REQ_]POPLIN)+num$([F:REQ_]POQSEQ)  # FGR 16/06/2014 : X3SUIVI98503
      If fstat Then
        Raz [F:BBB_]
        # Alimentation de la dimension PREQUIS avec les commandes liées aux demandes d'achat
        [F:BBB_]PSHNUM = [F:REQ_]PSHNUM  #--CPO Elément de clé => pas de test if dim()
        [F:BBB_]PSDLIN = [F:REQ_]PSDLIN  #--CPO Elément de clé => pas de test if dim()
        [F:BBB_]PSHPOH = [F:REQ_]POHNUM+num$([F:REQ_]POPLIN)+num$([F:REQ_]POQSEQ)  #--CPO Elément de clé => pas de test if dim()
        #--CPO 81446 Test sur l'existence d'un champ avant init
        If dim([F:BBB_]PRQDAT)>0    : [F:BBB_]PRQDAT    = [F:REQ_]PRQDAT    : Endif
        If dim([F:BBB_]EXTRCPDAT)>0 : [F:BBB_]EXTRCPDAT = [F:REQ_]EXTRCPDAT : Endif
        If dim([F:BBB_]EXTORDDAT)>0 : [F:BBB_]EXTORDDAT = [F:REQ_]EXTORDDAT : Endif
        If dim([F:BBB_]LINCLEFLG)>0 : [F:BBB_]LINCLEFLG = [F:REQ_]LINCLEFLG : Endif
        If dim([F:BBB_]LINORDFLG)>0 : [F:BBB_]LINORDFLG = [F:REQ_]LINORDFLG : Endif
        If dim([F:BBB_]LINAPPFLG)>0 : [F:BBB_]LINAPPFLG = [F:REQ_]LINAPPFLG : Endif
        If dim([F:BBB_]FBUFLG)>0    : [F:BBB_]FBUFLG    = [F:REQ_]FBUFLG    : Endif
        If dim([F:BBB_]REQUSR)>0    : [F:BBB_]REQUSR    = [F:REQ_]REQUSR    : Endif
        If dim([F:BBB_]LINBUY)>0    : [F:BBB_]LINBUY    = [F:REQ_]LINBUY    : Endif
        If dim([F:BBB_]ITMDES1)>0   : [F:BBB_]ITMDES1   = [F:REQ_]ITMDES1   : Endif
        If dim([F:BBB_]PUU)>0       : [F:BBB_]PUU       = [F:REQ_]PUU       : Endif
        If dim([F:BBB_]GROPRI)>0    : [F:BBB_]GROPRI    = [F:REQ_]GROPRI    : Endif
        If dim([F:BBB_]NETPRI)>0    : [F:BBB_]NETPRI    = [F:REQ_]NETPRI    : Endif
        If dim([F:BBB_]ORI)>0       : [F:BBB_]ORI       = [F:REQ_]ORI       : Endif
        If dim([F:BBB_]CMMPRPNUM)>0 : [F:BBB_]CMMPRPNUM = [F:REQ_]CMMPRPNUM : Endif
        If dim([F:BBB_]PQHNUM)>0    : [F:BBB_]PQHNUM    = [F:REQ_]PQHNUM    : Endif
        If dim([F:BBB_]PPDLIN)>0    : [F:BBB_]PPDLIN    = [F:REQ_]PPDLIN    : Endif
        If dim([F:BBB_]WIPNUM)>0    : [F:BBB_]WIPNUM    = [F:REQ_]WIPNUM    : Endif
        If dim([F:BBB_]POHNUM)>0    : [F:BBB_]POHNUM    = [F:REQ_]POHNUM    : Endif
        If dim([F:BBB_]POPLIN)>0    : [F:BBB_]POPLIN    = [F:REQ_]POPLIN    : Endif
        If dim([F:BBB_]POQSEQ)>0    : [F:BBB_]POQSEQ    = [F:REQ_]POQSEQ    : Endif
        #--CPO
        IBBB_WRITE += 1   # FGR 16/06/2014 :X3SUIVI98503
        CHAINE = [F:BBB_]PSHNUM-num$([F:BBB_]PSDLIN)-[F:BBB_]PSHPOH
        Write [F:BBB_]
        If fstat Then
          Call ERREUR(TABLE-CHAINE,1) From DOSDIC
        Else
          CRE += 1
          If [L]DET = 2 Then
            Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
          Endif
        Endif
      Endif
    Next
    Call ECR_TRACE("**   TRTDIMBIACH : PREQUIS"-mess(5,2246,1) - "(" + mess(4,138,1) - ":" - time$ - num$(time-ITIMEBEG) - mess(25,154,1) - num$(IBBB_WRITE) - mess(176,116,1) + ")",0)
&        From GESECRAN
  Endif
Return

################################################################################################
## Parcours de PORDERQ pour alimenter la dimension PORDER avec les demandes de livraison fermes
################################################################################################
$FIN_PORDER_DEM_LIVR
  If filinfo(filpath("FIL","PORDERQ","fde",GDOSSIER),0) > 0 Then
    IBBB_WRITE = 0   # FGR 16/06/2014 :X3SUIVI98503
    ITIMEBEG = time  # FGR 16/06/2014 :X3SUIVI98503
    Call ECR_TRACE("**   TRTDIMBIACH : PORDERQ"-mess(6,2246,1)-"PORDER" - "(" + mess(2,138,1) - ":" - time$ + ")",0) From GESECRAN
    # Requête de sélection des enregistrements de PORDERQ
    WREQ(0)= "select POQ.POHNUM_0, POQ.POPLIN_0, POQ.POQSEQ_0, POH.POHTYP_0, POH.ORDDAT_0, POH.REVNUM_0, "
    WREQ(0)+="POQ.LINCLEFLG_0, POQ.LININVFLG_0, POQ.RCPCLEFLG_0, POH.APPFLG_0, POQ.FBUFLG_0, POQ.LINOCNDAT_0, "
    WREQ(0)+="POQ.EXTRCPDAT_0, POQ.RETRCPDAT_0, POQ.DEMRCPDAT_0, POQ.OFS_0, "
    WREQ(1)= "POH.MDL_0, POH.EECICT_0, POH.BPTNUM_0, POH.FFWNUM_0, POH.VACBPR_0, POH.PTE_0, POQ.LINTYP_0, POQ.PUU_0, POQ.UOM_0, "
    WREQ(1)+="POQ.UOMPUUCOE_0, POQ.ORI_0, POH.BPRNAM_0, POH.POSCOD_0, POH.CTY_0, POH.CRY_0, "
    WREQ(1)+="POH.BPONAM_0, POH.BPOPOSCOD_0, "
    WREQ(2)= "POH.BPOCTY_0, POH.BPOCRY_0, POQ.CMMNUM_0, POQ.PQHNUM_0, POQ.PPDLIN_0, CPY.LEG_0 "
    WREQ(2)+="From "+GDOSSIER+".PORDERQ POQ,"+GDOSSIER+".PORDER POH,"+GDOSSIER+".COMPANY CPY "
    WREQ(2)+="Where POQ.POHTYP_0=2 and POQ.WIPSTA_0=1 and POH.POHNUM_0=POQ.POHNUM_0 and CPY.CPY_0=POH.CPY_0 "
    #
    # FGR 10/10/2014 : X3SUIVI102999
#    For (Char POHNUM(20), Integer POPLIN, Integer POQSEQ, Integer POHTYP, Date ORDDAT, Integer REVNUM,
#&        Integer LINCLEFLG, Integer LININVFLG, Integer RCPCLEFLG, Integer APPFLG, Integer FBUFLG, Date LINOCNDAT,
#&        Date EXTRCPDAT, Date RETRCPDAT, Date DEMRCPDAT, Decimal OFS, Char MDL(5),
#&        Char EECICT(5), Char BPTNUM(15), Char FFWNUM(15), Char VACBPR(5), Char PTE(15), Integer LINTYP,
#&        Char PUU(3), Char UOM(3), Decimal UOMPUUCOE, Integer ORI, Char BPRNAM(35), Char POSCOD(10),
#&        Char CTY(40), Char CRY(3), Char BPONAM(35), Char BPOPOSCOD(10), Char BPOCTY(40),
#&        Char BPOCRY(3), Char CMMNUM(20), Char PQHNUM(20), Integer PPDLIN, Char CPYLEG(3))
#&        From WBASE Sql WREQ(0..2) As [F:REQ_]
    For (Char POHNUM(GLONPOH), Integer POPLIN, Integer POQSEQ, Integer POHTYP, Date ORDDAT, Integer REVNUM,
&        Integer LINCLEFLG, Integer LININVFLG, Integer RCPCLEFLG, Integer APPFLG, Integer FBUFLG, Date LINOCNDAT,
&        Date EXTRCPDAT, Date RETRCPDAT, Date DEMRCPDAT, Decimal OFS, Char MDL(GLONMDL),
&        Char EECICT(GLONICT), Char BPTNUM(GLONBPR), Char FFWNUM(GLONBPR), Char VACBPR(GLONTVB), Char PTE(GLONPTE), Integer LINTYP,
&        Char PUU(GLONUOM), Char UOM(GLONUOM), Decimal UOMPUUCOE, Integer ORI, Char BPRNAM(GLONNAM), Char POSCOD(GLONPOS),
&        Char CTY(GLONCTY), Char CRY(GLONCRY), Char BPONAM(GLONNAM), Char BPOPOSCOD(GLONPOS), Char BPOCTY(GLONCTY),
&        Char BPOCRY(GLONCRY), Char CMMNUM(GLONVCR), Char PQHNUM(GLONVCR), Integer PPDLIN, Char CPYLEG(GLONADI))
&        From WBASE Sql WREQ(0..2) As [F:REQ_]
      #Read [F:BBB_]POQ0=[F:REQ_]POHNUM;[F:REQ_]POPLIN;[F:REQ_]POQSEQ
      Look [F:BBB_]POQ0=[F:REQ_]POHNUM;[F:REQ_]POPLIN;[F:REQ_]POQSEQ   # FGR 16/06/2014 :X3SUIVI98503
      If fstat Then
        # Pour chaque demande de livraison, je vais rechercher le bon enregistrement dans PORDERP, pour valoriser la demande
        WREQ3(0)= "select POP.VAT_0, POP.ITMDES1_0, POP.GROPRI_0, POP.NETPRI_0, POP.LINBUY_0, POP.ORICRY_0, POP.QUAFLG_0 "
        WREQ3(0)+="From "+GDOSSIER+".PORDERP POP "
        WREQ3(1)="Where POP.POHNUM_0='"+[F:REQ_]POHNUM+"' and POP.POPLIN_0="+num$([F:REQ_]POPLIN)+" and POP.STRDAT_0<="
        If WBASE = "3" Then # Oracle
          WREQ3(1)+="TO_DATE('"+[F:REQ_]DEMRCPDAT+"','YYYYMMDD')"
        Else
          #          WREQ3(1)+="'"+num$([F:REQ_]DEMRCPDAT)+"'" # SYMEU 61511
          WREQ3(1)+="convert(char,"+[F:REQ_]DEMRCPDAT+")" # SYMEU 61511
        Endif
        WREQ3(1)+=" Order by POP.STRDAT_0 desc"
        Raz [F:BBB_]
        [F:BBB_]POHNUM = [F:REQ_]POHNUM  #--CPO Elément de clé => pas de test if dim()
        [F:BBB_]POPLIN = [F:REQ_]POPLIN  #--CPO Elément de clé => pas de test if dim()
        [F:BBB_]POQSEQ = [F:REQ_]POQSEQ  #--CPO Elément de clé => pas de test if dim()
        #--CPO 81446 Test sur l'existence d'un champ avant init
        If dim([F:BBB_]POHTYP)>0      : [F:BBB_]POHTYP     = [F:REQ_]POHTYP    : Endif
        If dim([F:BBB_]ORDDAT)>0      : [F:BBB_]ORDDAT     = [F:REQ_]ORDDAT    : Endif
        If dim([F:BBB_]REVNUM)>0      : [F:BBB_]REVNUM     = [F:REQ_]REVNUM    : Endif
        If dim([F:BBB_]LINCLEFLG)>0   : [F:BBB_]LINCLEFLG  = [F:REQ_]LINCLEFLG : Endif
        If dim([F:BBB_]LININVFLG)>0   : [F:BBB_]LININVFLG  = [F:REQ_]LININVFLG : Endif
        If dim([F:BBB_]RCPCLEFLG)>0   : [F:BBB_]RCPCLEFLG  = [F:REQ_]RCPCLEFLG : Endif
        If dim([F:BBB_]APPFLG)>0      : [F:BBB_]APPFLG     = [F:REQ_]APPFLG    : Endif
        If dim([F:BBB_]FBUFLG)>0      : [F:BBB_]FBUFLG     = [F:REQ_]FBUFLG    : Endif
        If dim([F:BBB_]LINOCNDAT)>0   : [F:BBB_]LINOCNDAT  = [F:REQ_]LINOCNDAT : Endif
        If dim([F:BBB_]EXTRCPDAT)>0   : [F:BBB_]EXTRCPDAT  = [F:REQ_]EXTRCPDAT : Endif
        If dim([F:BBB_]RETRCPDAT)>0   : [F:BBB_]RETRCPDAT  = [F:REQ_]RETRCPDAT : Endif
        If dim([F:BBB_]DEMRCPDAT)>0   : [F:BBB_]DEMRCPDAT  = [F:REQ_]DEMRCPDAT : Endif
        If dim([F:BBB_]OFS)>0         : [F:BBB_]OFS        = [F:REQ_]OFS       : Endif
        If dim([F:BBB_]MDL)>0         : [F:BBB_]MDL        = [F:REQ_]MDL       : Endif
        If dim([F:BBB_]EECICT)>0      : [F:BBB_]EECICT     = [F:REQ_]EECICT    : Endif
        If dim([F:BBB_]BPTNUM)>0      : [F:BBB_]BPTNUM     = [F:REQ_]BPTNUM    : Endif
        If dim([F:BBB_]FFWNUM)>0      : [F:BBB_]FFWNUM     = [F:REQ_]FFWNUM    : Endif
        If dim([F:BBB_]VACBPR)>0      : [F:BBB_]VACBPR     = [F:REQ_]VACBPR    : Endif
        If dim([F:BBB_]VACBPR_LEG)>0  : [F:BBB_]VACBPR_LEG = func TRTX3BITC.GETLEG_VACBPR([F:REQ_]VACBPR, [F:REQ_]CPYLEG) : Endif
        If dim([F:BBB_]PTE)>0         : [F:BBB_]PTE        = [F:REQ_]PTE       : Endif
        If dim([F:BBB_]PTE_LEG)>0     : [F:BBB_]PTE_LEG    = func TRTX3BITC.GETLEG_PTE([F:REQ_]PTE, [F:REQ_]CPYLEG) : Endif
        If dim([F:BBB_]LINTYP)>0      : [F:BBB_]LINTYP     = [F:REQ_]LINTYP    : Endif
        If dim([F:BBB_]PUU)>0         : [F:BBB_]PUU        = [F:REQ_]PUU       : Endif
        If dim([F:BBB_]UOM)>0         : [F:BBB_]UOM        = [F:REQ_]UOM       : Endif
        If dim([F:BBB_]UOMPUUCOE)>0   : [F:BBB_]UOMPUUCOE  = [F:REQ_]UOMPUUCOE : Endif
        If dim([F:BBB_]ORI)>0         : [F:BBB_]ORI        = [F:REQ_]ORI       : Endif
        If dim([F:BBB_]BPRNAM)>0      : [F:BBB_]BPRNAM     = [F:REQ_]BPRNAM    : Endif
        #       [F:BBB_]POSCOD = [F:REQ_]POSCOD # SYMEU 61649
        If dim([F:BBB_]POSCOD)>0      : [F:BBB_]POSCOD     = vireblc([F:REQ_]POSCOD,1) : Endif  # SYMEU 61649
        If dim([F:BBB_]CTY)>0         : [F:BBB_]CTY        = [F:REQ_]CTY       : Endif
        If dim([F:BBB_]CRY)>0         : [F:BBB_]CRY        = [F:REQ_]CRY       : Endif
        If dim([F:BBB_]BPONAM)>0      : [F:BBB_]BPONAM     = [F:REQ_]BPONAM    : Endif
        #       [F:BBB_]BPOPOSCOD = [F:REQ_]BPOPOSCOD # SYMEU 61649
        If dim([F:BBB_]BPOPOSCOD)>0   : [F:BBB_]BPOPOSCOD=vireblc([F:REQ_]BPOPOSCOD,1) : Endif  # SYMEU 61649
        If dim([F:BBB_]BPOCTY)>0      : [F:BBB_]BPOCTY     = [F:REQ_]BPOCTY    : Endif
        If dim([F:BBB_]BPOCRY)>0      : [F:BBB_]BPOCRY     = [F:REQ_]BPOCRY    : Endif
        If dim([F:BBB_]CMMNUM)>0      : [F:BBB_]CMMNUM     = [F:REQ_]CMMNUM    : Endif
        If dim([F:BBB_]PQHNUM)>0      : [F:BBB_]PQHNUM     = [F:REQ_]PQHNUM    : Endif
        If dim([F:BBB_]PPDLIN)>0      : [F:BBB_]PPDLIN     = [F:REQ_]PPDLIN    : Endif
        # FGR 10/10/2014 : X3SUIVI102999
#        For (Char VAT(5), Char ITMDES1(30), Decimal GROPRI, Decimal NETPRI, Char LINBUY(5), Char ORICRY(3),
#&            Integer QUAFLG) From WBASE Sql WREQ3(0..1) As [RE3_]
        For (Char VAT(GLONVAT), Char ITMDES1(GLONDES), Decimal GROPRI, Decimal NETPRI, Char LINBUY(GLONAUS), Char ORICRY(GLONCRY),
&            Integer QUAFLG) From WBASE Sql WREQ3(0..1) As [RE3_]
          # Alimentation de la dimension PORDER avec les demandes de livraison
          If dim([F:BBB_]VAT)>0       : [F:BBB_]VAT        = [RE3_]VAT       : Endif
          If dim([F:BBB_]VAT_LEG)>0   : [F:BBB_]VAT_LEG    = func TRTX3BITC.GETLEG_VAT([F:RE3_]VAT, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]ITMDES1)>0   : [F:BBB_]ITMDES1    = [RE3_]ITMDES1   : Endif
          If dim([F:BBB_]GROPRI)>0    : [F:BBB_]GROPRI     = [RE3_]GROPRI    : Endif
          If dim([F:BBB_]NETPRI)>0    : [F:BBB_]NETPRI     = [RE3_]NETPRI    : Endif
          If dim([F:BBB_]LINBUY)>0    : [F:BBB_]LINBUY     = [RE3_]LINBUY    : Endif
          If dim([F:BBB_]ORICRY)>0    : [F:BBB_]ORICRY     = [RE3_]ORICRY    : Endif
          If dim([F:BBB_]QUAFLG)>0    : [F:BBB_]QUAFLG     = [RE3_]QUAFLG    : Endif
          Break # On ne prend que le premier enregistrement de PORDERP
        Next
        #--/CPO
        IBBB_WRITE += 1   # FGR 16/06/2014 :X3SUIVI98503
        CHAINE = [F:BBB_]POHNUM-num$([F:BBB_]POPLIN)-num$([F:BBB_]POQSEQ)
        Write [F:BBB_]
        If fstat
          Call ERREUR(TABLE-CHAINE,1) From DOSDIC
        Else
          CRE += 1
          If [L]DET=2
            Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
          Endif
        Endif
      Endif
    Next
    Call ECR_TRACE("**   TRTDIMBIACH : PORDERQ"-mess(6,2246,1)-"PORDER" - "(" + mess(4,138,1) - ":" - time$ - num$(time-ITIMEBEG) - mess(25,154,1) - num$(IBBB_WRITE) - mess(176,116,1) + ")",0)
&        From GESECRAN
  Endif
Return

###################################################################################
## Parcours de PVCRFOOT pour alimenter la dimension PORDER
###################################################################################
$FIN_PORDER_ELT_FAC
Local Integer W_POPLIN

  # SYMEU - Fiche 61356 - début
  # Lecture de la règle de synchro PORDERINV.
  # Si elle est désactivée : on n'exécute pas le traitement.
  [L]DESFLG = func READ_REGLE("PORDERINV")
  If [L]DESFLG = 2 Then
    Return
  Endif
  # SYMEU - Fiche 61356 - fin
  If filinfo(filpath("FIL","PVCRFOOT","fde",GDOSSIER),0) > 0 Then
    IBBB_WRITE = 0   # FGR 16/06/2014 :X3SUIVI98503
    ITIMEBEG = time  # FGR 16/06/2014 :X3SUIVI98503
    Call ECR_TRACE("**   TRTDIMBIACH : PVCRFOOT"-mess(7,2246,1)-"PORDER" - "(" + mess(2,138,1) - ":" - time$ + ")",0) From GESECRAN
    # Requête de sélection des enregistrements de PVCRFOOT
    WREQ(0)= "select PVF.VCRNUM_0, PVF.IND_0, POH.POHTYP_0, POH.ORDDAT_0, POH.REVNUM_0, POH.APPFLG_0, POH.EECICT_0, "
    WREQ(0)+="POH.BPTNUM_0, POH.FFWNUM_0, POH.VACBPR_0, PVF.INVDTAVAT_0, POH.PTE_0, POH.BUY_0, PFI.ITMREF_0, "
    WREQ(0)+="POH.BPRNAM_0, POH.POSCOD_0, POH.CTY_0, "
    WREQ(1)= "POH.CRY_0, POH.BPONAM_0, POH.BPOPOSCOD_0, POH.BPOCTY_0, POH.BPOCRY_0, CPY.LEG_0 "
    WREQ(1)+="From "+GDOSSIER+".PVCRFOOT PVF,"+GDOSSIER+".PFOOTINV PFI,"+GDOSSIER+".PORDER POH,"+GDOSSIER+".COMPANY CPY "
    WREQ(2)= "Where PFI.PFINUM_0=PVF.INVDTA_0 and POH.POHNUM_0=PVF.VCRNUM_0 "
    WREQ(2)+="and PVF.VCRTYP_0=3 and PFI.ENAFLG_0=2 and PFI.DSPLIN_0>0 and PFI.ITMREF_0<>' ' and CPY.CPY_0=POH.CPY_0 "
    #
    # FGR 10/10/2014 : X3SUIVI102999
#    For (Char VCRNUM(20), Integer IND, Integer POHTYP, Date ORDDAT, Integer REVNUM, Integer APPFLG,
#&        Char EECICT(5), Char BPTNUM(15), Char FFWNUM(15), Char VACBPR(5), Char INVDTAVAT(5), Char PTE(15),
#&        Char BUY(5), Char ITMREF(20), Char BPRNAM(35), Char POSCOD(10), Char CTY(40),
#&        Char CRY(3), Char BPONAM(35), Char BPOPOSCOD(10), Char BPOCTY(40), Char BPOCRY(3), Char CPYLEG(3))
#&        From WBASE Sql WREQ(0..2) As [F:REQ_]

#MGG X3-38337_Product_Code_length_GLONITM_function
    For (Char VCRNUM(GLONVCR), Integer IND, Integer POHTYP, Date ORDDAT, Integer REVNUM, Integer APPFLG,
&        Char EECICT(GLONICT), Char BPTNUM(GLONBPR), Char FFWNUM(GLONBPR), Char VACBPR(GLONTVB), Char INVDTAVAT(GLONVAT), Char PTE(GLONPTE),
&        Char BUY(GLONAUS), Char ITMREF(GLONITM), Char BPRNAM(35), Char POSCOD(10), Char CTY(40),
&        Char CRY(GLONCRY), Char BPONAM(GLONNAM), Char BPOPOSCOD(GLONPOS), Char BPOCTY(GLONCTY), Char BPOCRY(GLONCRY), Char CPYLEG(GLONADI))
&        From WBASE Sql WREQ(0..2) As [F:REQ_]
 #MGG X3-38337_Product_Code_length_GLONITM_function

      # Vérification que la commande existe dans la dimension PORDER qui vient d'être alimentée (par sécurité)
      # FGR 16/06/2014 : X3SUIVI98503 (début)
      #Filter [F:BBB_] Where POHNUM=[F:REQ_]VCRNUM
      #NB_ENREG=rowcount([F:BBB_])
      #Filter [F:BBB_]
      NB_ENREG = 0
      Look [F:BBB_]POQ0(1)=[F:REQ_]VCRNUM
      If !fstat Then
        NB_ENREG = 1
      Endif
      # FGR 16/06/2014 : X3SUIVI98503 (fin)
      If NB_ENREG > 0 Then # la commande a été trouvée
        W_POPLIN = func TRTX3BI.GETLASTLIN("PORDERQ",[F:REQ_]VCRNUM)+[F:REQ_]IND
        #Read [F:BBB_]POQ0=[F:REQ_]VCRNUM;W_POPLIN;1000
        Look [F:BBB_]POQ0=[F:REQ_]VCRNUM;W_POPLIN;1000   # FGR 16/06/2014 : X3SUIVI98503
        If fstat Then
          Raz [F:BBB_]
          # Alimentation de la dimension PORDER avec les éléments de facturation
          [F:BBB_]POHNUM = [F:REQ_]VCRNUM   #--CPO Elément de clé => pas de test if dim()
          [F:BBB_]POPLIN = W_POPLIN         #--CPO Elément de clé => pas de test if dim()
          [F:BBB_]POQSEQ = 1000             # Issue X3-50715 - 2017-09-05 by CPO : Duplicates in BO Synchronisation on PURCHASE Datamart, TRTDIMBIACH : PVCRFOOT
          #--CPO 81446 Test sur l'existence d'un champ avant init
          If dim([F:BBB_]POHTYP)>0      : [F:BBB_]POHTYP     = [F:REQ_]POHTYP    : Endif
          If dim([F:BBB_]ORDDAT)>0      : [F:BBB_]ORDDAT     = [F:REQ_]ORDDAT    : Endif
          If dim([F:BBB_]REVNUM)>0      : [F:BBB_]REVNUM     = [F:REQ_]REVNUM    : Endif
          If dim([F:BBB_]APPFLG)>0      : [F:BBB_]APPFLG     = [F:REQ_]APPFLG    : Endif
          If dim([F:BBB_]EECICT)>0      : [F:BBB_]EECICT     = [F:REQ_]EECICT    : Endif
          If dim([F:BBB_]BPTNUM)>0      : [F:BBB_]BPTNUM     = [F:REQ_]BPTNUM    : Endif
          If dim([F:BBB_]FFWNUM)>0      : [F:BBB_]FFWNUM     = [F:REQ_]FFWNUM    : Endif
          If dim([F:BBB_]VACBPR)>0      : [F:BBB_]VACBPR     = [F:REQ_]VACBPR    : Endif
          If dim([F:BBB_]VACBPR_LEG)>0  : [F:BBB_]VACBPR_LEG = func TRTX3BITC.GETLEG_VACBPR([F:REQ_]VACBPR, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]VAT)>0         : [F:BBB_]VAT        = [F:REQ_]INVDTAVAT : Endif
          If dim([F:BBB_]VAT_LEG)>0     : [F:BBB_]VAT_LEG    = func TRTX3BITC.GETLEG_VAT([F:REQ_]INVDTAVAT, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]PTE)>0         : [F:BBB_]PTE        = [F:REQ_]PTE       : Endif
          If dim([F:BBB_]PTE_LEG)>0     : [F:BBB_]PTE_LEG    = func TRTX3BITC.GETLEG_PTE([F:REQ_]PTE, [F:REQ_]CPYLEG) : Endif
          # Lecture de la désignation traduite de l'article de l'élément de facturation (qui est forcément renseigné, cf la clause where du select)
          If dim([F:BBB_]ITMDES1)>0     : [F:BBB_]ITMDES1    = func LECT_DES_TRAD([F:REQ_]ITMREF,WBASE) : Endif
          If dim([F:BBB_]LINBUY)>0      : [F:BBB_]LINBUY     = [F:REQ_]BUY       : Endif
          If dim([F:BBB_]BPRNAM)>0      : [F:BBB_]BPRNAM     = [F:REQ_]BPRNAM    : Endif
          #         [F:BBB_]POSCOD = [F:REQ_]POSCOD # SYMEU 61649
          If dim([F:BBB_]POSCOD)>0      : [F:BBB_]POSCOD     = vireblc([F:REQ_]POSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]CTY)>0         : [F:BBB_]CTY        = [F:REQ_]CTY       : Endif
          If dim([F:BBB_]CRY)>0         : [F:BBB_]CRY        = [F:REQ_]CRY       : Endif
          If dim([F:BBB_]BPONAM)>0      : [F:BBB_]BPONAM     = [F:REQ_]BPONAM    : Endif
          #         [F:BBB_]BPOPOSCOD = [F:REQ_]BPOPOSCOD # SYMEU 61649
          If dim([F:BBB_]BPOPOSCOD)>0   : [F:BBB_]BPOPOSCOD  = vireblc([F:REQ_]BPOPOSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]BPOCTY)>0      : [F:BBB_]BPOCTY     = [F:REQ_]BPOCTY    : Endif
          If dim([F:BBB_]BPOCRY)>0      : [F:BBB_]BPOCRY     = [F:REQ_]BPOCRY    : Endif
          #--/CPO
          IBBB_WRITE += 1   # FGR 16/06/2014 :X3SUIVI98503
          CHAINE = [F:BBB_]POHNUM-num$([F:BBB_]POPLIN)-num$([F:BBB_]POQSEQ)
          Write [F:BBB_]
          If fstat Then
            Call ERREUR(TABLE-CHAINE,1) From DOSDIC
          Else
            CRE += 1
            If [L]DET = 2 Then
              Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
            Endif
          Endif
        Endif
      Endif
    Next
    Call ECR_TRACE("**   TRTDIMBIACH : PVCRFOOT"-mess(7,2246,1)-"PORDER" - "(" + mess(4,138,1) - ":" - time$ - num$(time-ITIMEBEG) - mess(25,154,1) - num$(IBBB_WRITE) - mess(176,116,1) + ")",0)
&        From GESECRAN
  Endif
Return

###################################################################################
## Parcours de PVCRFOOT pour alimenter la dimension PRECEIPT
###################################################################################
$FIN_PRECEIPT_ELT_FAC
Local Integer W_PTDLIN

  # SYMEU - Fiche 61356 - début
  # Lecture de la règle de synchro PRECEIPTIN.
  # Si elle est désactivée : on n'exécute pas le traitement.
  [L]DESFLG = func READ_REGLE("PRECEIPTIN")
  If [L]DESFLG = 2 Then
    Return
  Endif
  # SYMEU - Fiche 61356 - fin
  If filinfo(filpath("FIL","PVCRFOOT","fde",GDOSSIER),0) > 0 Then
    IBBB_WRITE = 0   # FGR 16/06/2014 :X3SUIVI98503
    ITIMEBEG = time  # FGR 16/06/2014 :X3SUIVI98503
    Call ECR_TRACE("**   TRTDIMBIACH : PVCRFOOT"-mess(7,2246,1)-"PRECEIPT" - "(" + mess(2,138,1) - ":" - time$ + ")",0) From GESECRAN
    # Requête de sélection des enregistrements de PVCRFOOT
    WREQ(0)= "select PVF.VCRNUM_0, PVF.IND_0, PTH.BPSNDE_0, PTH.RCPDAT_0, PTH.NDEDAT_0, PTH.MDL_0, "
    WREQ(0)+="PTH.EECICT_0, PTH.EECSCH_0, PTH.EECNAT_0, PTH.BPTNUM_0, PTH.FFWNUM_0, PTH.VACBPR_0, "
    WREQ(0)+="PVF.INVDTAVAT_0, BPS.BPSNAM_0, BPS.PTE_0, BPS.DEP_0, PFI.ITMREF_0, PTH.BPONAM_0, "
    WREQ(1)= "PTH.BPOPOSCOD_0, PTH.BPOCTY_0, PTH.BPOCRY_0, "
    WREQ(1)+="BPA.POSCOD_0, BPA.CTY_0, BPA.CRY_0, CPY.LEG_0 "
    WREQ(1)+="From "+GDOSSIER+".PVCRFOOT PVF,"+GDOSSIER+".PFOOTINV PFI,"+GDOSSIER+".PRECEIPT PTH,"+GDOSSIER+".BPSUPPLIER BPS,"+GDOSSIER+".BPADDRESS BPA "
    WREQ(2)= ","+GDOSSIER+".COMPANY CPY Where PFI.PFINUM_0=PVF.INVDTA_0 and PTH.PTHNUM_0=PVF.VCRNUM_0 and BPS.BPSNUM_0=PTH.BPSINV_0 "
    WREQ(3) ="and BPA.BPATYP_0=1 and BPA.BPANUM_0=PTH.BPSINV_0 and BPA.BPAADD_0=PTH.BPAINV_0 "                           # FGR 16/01/2015 : X3SUIVI105492 : pb de longueur de chaîne
    WREQ(3)+= "and PVF.VCRTYP_0=6 and PFI.ENAFLG_0=2 and PFI.DSPLIN_0>0 and PFI.ITMREF_0<>' ' and CPY.CPY_0=PTH.CPY_0 "  # FGR 16/01/2015 : X3SUIVI105492 : pb de longueur de chaîne
    #
    # FGR 10/10/2014 : X3SUIVI102999
#    For (Char VCRNUM(20), Integer IND, Char BPSNDE(20), Date RCPDAT, Date NDEDAT, Char MDL(5), Char EECICT(5),
#&        Char EECSCH(5), Char EECNAT(5), Char BPTNUM(15), Char FFWNUM(15), Char VACBPR(5), Char INVDTAVAT(5),
#&        Char BPSNAM(35), Char PTE(15), Char DEP(3), Char ITMREF(20), Char BPONAM(35), Char BPOPOSCOD(10),
#&        Char BPOCTY(40), Char BPOCRY(3), Char POSCOD(10), Char CTY(40),
#&        Char CRY(3), Char CPYLEG(3)) From WBASE Sql WREQ(0..3) As [F:REQ_]
    # Issue 113406 - 2016-01-04 by CPO : BI : error during synchronizing PINVOICE dimension
#    For (Char VCRNUM(GLONVCR), Integer IND, Char BPSNDE(20), Date RCPDAT, Date NDEDAT, Char MDL(GLONMDL), Char EECICT(GLONICT),
#&        Char EECSCH(GLONTSC), Char EECNAT(GLONTEC), Char BPTNUM(GLONBPR), Char FFWNUM(GLONBPR), Char VACBPR(GLONTVB), Char INVDTAVAT(GLONVAT),
#&        Char BPSNAM(GLONNAM), Char PTE(GLONPTE), Char DEP(GLONTDA), Char ITMREF(GLONITM), Char BPONAM(GLONNAM), Char BPOPOSCOD(GLONPOS),
#&        Char BPOCTY(GLONCTY), Char BPOCRY(GLONCRY), Char POSCOD(GLONPOS), Char CTY(GLONCTY),
#&        Char CRY(GLONCRY), Char CPYLEG(GLONADI)) From WBASE Sql WREQ(0..3) As [F:REQ_]
    # GLONTSC/GLONTEC attached to objects that are activity code dependent (DEB)
    Local Integer WLONTSC,WLONTEC
    If dim(GLONTSC)<0
      WLONTSC=5
    Else
      WLONTSC=GLONTSC
    Endif
    If dim(GLONTEC)<0
      WLONTEC=5
    Else
      WLONTEC=GLONTEC
    Endif
    For (Char VCRNUM(GLONVCR), Integer IND, Char BPSNDE(20), Date RCPDAT, Date NDEDAT, Char MDL(GLONMDL), Char EECICT(GLONICT),
&        Char EECSCH(WLONTSC), Char EECNAT(WLONTEC), Char BPTNUM(GLONBPR), Char FFWNUM(GLONBPR), Char VACBPR(GLONTVB), Char INVDTAVAT(GLONVAT),
&        Char BPSNAM(GLONNAM), Char PTE(GLONPTE), Char DEP(GLONTDA), Char ITMREF(GLONITM), Char BPONAM(GLONNAM), Char BPOPOSCOD(GLONPOS),
&        Char BPOCTY(GLONCTY), Char BPOCRY(GLONCRY), Char POSCOD(GLONPOS), Char CTY(GLONCTY),
&        Char CRY(GLONCRY), Char CPYLEG(GLONADI)) From WBASE Sql WREQ(0..3) As [F:REQ_]
    # End issue 113406

      # Vérification que la réception existe dans la dimension PRECEIPT qui vient d'être alimentée (par sécurité)
      # FGR 16/06/2014 : X3SUIVI98503 (début)
      #Filter [F:BBB_] Where PTHNUM=[F:REQ_]VCRNUM
      #NB_ENREG=rowcount([F:BBB_])
      #Filter [F:BBB_]
      NB_ENREG = 0
      Look [F:BBB_]PTD0(1)=[F:REQ_]VCRNUM
      If !fstat Then
        NB_ENREG = 1
      Endif
      # FGR 16/06/2014 : X3SUIVI98503 (fin)
      If NB_ENREG > 0 Then # la réception a été trouvée
        W_PTDLIN = func TRTX3BI.GETLASTLIN("PRECEIPTD",[F:REQ_]VCRNUM)+[F:REQ_]IND
        #Read [F:BBB_]PTD0=[F:REQ_]VCRNUM;W_PTDLIN
        Look [F:BBB_]PTD0=[F:REQ_]VCRNUM;W_PTDLIN   # FGR 16/06/2014 : X3SUIVI98503
        If fstat Then
          Raz [F:BBB_]
          # Alimentation de la dimension PRECEIPT avec les éléments de facturation
          [F:BBB_]PTHNUM = [F:REQ_]VCRNUM   #--CPO Elément de clé => pas de test if dim()
          [F:BBB_]PTDLIN = W_PTDLIN       #--CPO Elément de clé => pas de test if dim()
          #--CPO 81446 Test sur l'existence d'un champ avant init
          If dim([F:BBB_]BPSNDE)>0      : [F:BBB_]BPSNDE     = [F:REQ_]BPSNDE    : Endif
          If dim([F:BBB_]RCPDAT)>0      : [F:BBB_]RCPDAT     = [F:REQ_]RCPDAT    : Endif
          If dim([F:BBB_]NDEDAT)>0      : [F:BBB_]NDEDAT     = [F:REQ_]NDEDAT    : Endif
          If dim([F:BBB_]MDL)>0         : [F:BBB_]MDL        = [F:REQ_]MDL       : Endif
          If dim([F:BBB_]EECICT)>0      : [F:BBB_]EECICT     = [F:REQ_]EECICT    : Endif
          If dim([F:BBB_]EECSCH)>0      : [F:BBB_]EECSCH     = [F:REQ_]EECSCH    : Endif
          If dim([F:BBB_]EECSCH_LEG)>0  : [F:BBB_]EECSCH_LEG = func TRTX3BITC.GETLEG_EECSCH([F:REQ_]EECSCH, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]EECNAT)>0      : [F:BBB_]EECNAT     = [F:REQ_]EECNAT    : Endif
          If dim([F:BBB_]EECNAT_LEG)>0  : [F:BBB_]EECNAT_LEG = func TRTX3BITC.GETLEG_EECNAT([F:REQ_]EECNAT, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]BPTNUM)>0      : [F:BBB_]BPTNUM     = [F:REQ_]BPTNUM    : Endif
          If dim([F:BBB_]FFWNUM)>0      : [F:BBB_]FFWNUM     = [F:REQ_]FFWNUM    : Endif
          If dim([F:BBB_]VACBPR)>0      : [F:BBB_]VACBPR     = [F:REQ_]VACBPR    : Endif
          If dim([F:BBB_]VACBPR_LEG)>0  : [F:BBB_]VACBPR_LEG = func TRTX3BITC.GETLEG_VACBPR([F:REQ_]VACBPR, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]VAT)>0         : [F:BBB_]VAT        = [F:REQ_]INVDTAVAT : Endif
          If dim([F:BBB_]VAT_LEG)>0     : [F:BBB_]VAT_LEG    = func TRTX3BITC.GETLEG_VAT([F:REQ_]INVDTAVAT, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]PTE)>0         : [F:BBB_]PTE        = [F:REQ_]PTE       : Endif
          If dim([F:BBB_]PTE_LEG)>0     : [F:BBB_]PTE_LEG    = func TRTX3BITC.GETLEG_PTE([F:REQ_]PTE, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]DEP)>0         : [F:BBB_]DEP        = [F:REQ_]DEP       : Endif
          If dim([F:BBB_]DEP_LEG)>0     : [F:BBB_]DEP_LEG    = func TRTX3BITC.GETLEG_DEP([F:REQ_]DEP, [F:REQ_]CPYLEG) : Endif
          # Lecture de la désignation traduite de l'article de l'élément de facturation (qui est forcément renseigné, cf la clause where du select)
          If dim([F:BBB_]ITMDES1)>0     : [F:BBB_]ITMDES1    = func LECT_DES_TRAD([F:REQ_]ITMREF,WBASE) : Endif
          If dim([F:BBB_]BPONAM)>0      : [F:BBB_]BPONAM     = [F:REQ_]BPONAM    : Endif
          #         [F:BBB_]BPOPOSCOD = [F:REQ_]BPOPOSCOD # SYMEU 61649
          If dim([F:BBB_]BPOPOSCOD)>0   : [F:BBB_]BPOPOSCOD  = vireblc([F:REQ_]BPOPOSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]BPOCTY)>0      : [F:BBB_]BPOCTY     = [F:REQ_]BPOCTY    : Endif
          If dim([F:BBB_]BPOCRY)>0      : [F:BBB_]BPOCRY     = [F:REQ_]BPOCRY    : Endif
          If dim([F:BBB_]BPINAM)>0      : [F:BBB_]BPINAM     = [F:REQ_]BPSNAM    : Endif
          #         [F:BBB_]BPIPOSCOD = [F:REQ_]POSCOD # SYMEU 61649
          If dim([F:BBB_]BPIPOSCOD)>0   : [F:BBB_]BPIPOSCOD  = vireblc([F:REQ_]POSCOD,1) : Endif # SYMEU 61649
          If dim([F:BBB_]BPICTY)>0      : [F:BBB_]BPICTY     = [F:REQ_]CTY       : Endif
          If dim([F:BBB_]BPICRY)>0      : [F:BBB_]BPICRY     = [F:REQ_]CRY       : Endif
          #--CPO
          IBBB_WRITE += 1   # FGR 16/06/2014 :X3SUIVI98503
          CHAINE = [F:BBB_]PTHNUM-num$([F:BBB_]PTDLIN)
          Write [F:BBB_]
          If fstat
            Call ERREUR(TABLE-CHAINE,1) From DOSDIC
          Else
            CRE += 1
            If [L]DET=2
              Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
            Endif
          Endif
        Endif
      Endif
    Next
    Call ECR_TRACE("**   TRTDIMBIACH : PVCRFOOT"-mess(7,2246,1)-"PRECEIPT" - "(" + mess(4,138,1) - ":" - time$ - num$(time-ITIMEBEG) - mess(25,154,1) - num$(IBBB_WRITE) - mess(176,116,1) + ")",0)
&        From GESECRAN
  Endif
Return

###################################################################################
## Parcours de PVCRFOOT pour alimenter la dimension PINVOICE
###################################################################################
$FIN_PINVOICE_ELT_FAC
Local Integer W_PIDLIN

  # SYMEU - Fiche 61356 - début
  # Lecture de la règle de synchro PINVOICEIN.
  # Si elle est désactivée : on n'exécute pas le traitement.
  [L]DESFLG = func READ_REGLE("PINVOICEIN")
  If [L]DESFLG = 2 Then
    Return
  Endif
  # SYMEU - Fiche 61356 - fin
  If filinfo(filpath("FIL","PVCRFOOT","fde",GDOSSIER),0) > 0 Then
    IBBB_WRITE = 0   # FGR 16/06/2014 :X3SUIVI98503
    ITIMEBEG = time  # FGR 16/06/2014 :X3SUIVI98503
    Call ECR_TRACE("**   TRTDIMBIACH : PVCRFOOT"-mess(7,2246,1)-"PINVOICE" - "(" + mess(2,138,1) - ":" - time$ + ")",0) From GESECRAN
    # Requête de sélection des enregistrements de PVCRFOOT
    WREQ(0)= "select PVF.VCRNUM_0, PVF.IND_0, PIH.PIVTYP_0, PIH.INVTYP_0, PIH.PIHTYP_0, PIH.ACCDAT_0, "
    WREQ(0)+="PIH.BPRVCR_0, PIH.BPRDAT_0, PIH.EECICT_0, PIH.EECSCH_0, PIH.EECNAT_0, PIH.FFWNUM_0, "
    WREQ(0)+="PIH.VAC_0, PVF.INVDTAVAT_0, PIH.PTE_0, PIH.DEP_0, PFI.ITMREF_0, PIH.BPRNAM_0, "
    WREQ(1)= "PIH.BPYNAM_0, PIH.POSCOD_0, PIH.CTY_0, PIH.CRY_0, "
    WREQ(1)+="PIH.BPYPOSCOD_0, PIH.BPYCTY_0, PIH.BPYCRY_0, CPY.LEG_0 "
    WREQ(1)+="From "+GDOSSIER+".PVCRFOOT PVF,"+GDOSSIER+".PFOOTINV PFI,"+GDOSSIER+".PINVOICE PIH,"+GDOSSIER+".COMPANY CPY "
    WREQ(2)= "Where PFI.PFINUM_0=PVF.INVDTA_0 and PIH.NUM_0=PVF.VCRNUM_0 and CPY.CPY_0=PIH.CPY_0 "
    WREQ(2)+="and PVF.VCRTYP_0=8 and PFI.ENAFLG_0=2 and PFI.DSPLIN_0>0 and PFI.ITMREF_0<>' ' and PIH.ORIMOD_0=6"
    #
    # FGR 10/10/2014 : X3SUIVI102999
#    For (Char VCRNUM(20), Integer IND, Char PIVTYP(5), Integer INVTYP, Integer PIHTYP, Date ACCDAT,
#&        Char BPRVCR(20), Date BPRDAT, Char EECICT(5), Char EECSCH(5), Char EECNAT(5), Char FFWNUM(15),
#&        Char VAC(5), Char INVDTAVAT(5), Char PTE(15), Char DEP(3), Char ITMREF(20), Char BPRNAM(35),
#&        Char BPYNAM(35), Char POSCOD(10), Char CTY(40), Char CRY(3), Char BPYPOSCOD(10),
#&        Char BPYCTY(40), Char BPYCRY(3), Char CPYLEG(3)) From WBASE Sql WREQ(0..2) As [F:REQ_]
    # Issue 113406 - 2016-01-04 by CPO : BI : error during synchronizing PINVOICE dimension
#    For (Char VCRNUM(GLONVCR), Integer IND, Char PIVTYP(GLONTPV), Integer INVTYP, Integer PIHTYP, Date ACCDAT,
#&        Char BPRVCR(20), Date BPRDAT, Char EECICT(GLONICT), Char EECSCH(GLONTSC), Char EECNAT(GLONTEC), Char FFWNUM(GLONBPR),
#&        Char VAC(GLONTVB), Char INVDTAVAT(GLONVAT), Char PTE(GLONPTE), Char DEP(GLONTDA), Char ITMREF(GLONITM), Char BPRNAM(GLONNAM),
#&        Char BPYNAM(GLONNAM), Char POSCOD(GLONPOS), Char CTY(GLONCTY), Char CRY(GLONCRY), Char BPYPOSCOD(GLONPOS),
#&        Char BPYCTY(GLONCTY), Char BPYCRY(GLONCRY), Char CPYLEG(GLONADI)) From WBASE Sql WREQ(0..2) As [F:REQ_]
    # GLONTSC/GLONTEC attached to objects that are activity code dependent (DEB)
    Local Integer WLONTSC,WLONTEC
    If dim(GLONTSC)<0
      WLONTSC=5
    Else
      WLONTSC=GLONTSC
    Endif
    If dim(GLONTEC)<0
      WLONTEC=5
    Else
      WLONTEC=GLONTEC
    Endif
    For (Char VCRNUM(GLONVCR), Integer IND, Char PIVTYP(GLONTPV), Integer INVTYP, Integer PIHTYP, Date ACCDAT,
&        Char BPRVCR(20), Date BPRDAT, Char EECICT(GLONICT), Char EECSCH(WLONTSC), Char EECNAT(WLONTEC), Char FFWNUM(GLONBPR),
&        Char VAC(GLONTVB), Char INVDTAVAT(GLONVAT), Char PTE(GLONPTE), Char DEP(GLONTDA), Char ITMREF(GLONITM), Char BPRNAM(GLONNAM),
&        Char BPYNAM(GLONNAM), Char POSCOD(GLONPOS), Char CTY(GLONCTY), Char CRY(GLONCRY), Char BPYPOSCOD(GLONPOS),
&        Char BPYCTY(GLONCTY), Char BPYCRY(GLONCRY), Char CPYLEG(GLONADI)) From WBASE Sql WREQ(0..2) As [F:REQ_]
    # End issue 113406
      # Vérification que la facture existe dans la dimension PINVOICE qui vient d'être alimentée (par sécurité)
      # FGR 16/06/2014 : X3SUIVI98503 (début)
      #Filter [F:BBB_] Where PIHNUM=[F:REQ_]VCRNUM
      #NB_ENREG=rowcount([F:BBB_])
      #Filter [F:BBB_]
      NB_ENREG = 0
      Look [F:BBB_]PID0(1)=[F:REQ_]VCRNUM
      If !fstat Then
        NB_ENREG = 1
      Endif
      # FGR 16/06/2014 : X3SUIVI98503 (fin)
      If NB_ENREG > 0 Then
        # la facture a été trouvée
        W_PIDLIN = func TRTX3BI.GETLASTLIN("PINVOICED",[F:REQ_]VCRNUM)+[F:REQ_]IND
        #Read [F:BBB_]PID0=[F:REQ_]VCRNUM;W_PIDLIN
        Look [F:BBB_]PID0=[F:REQ_]VCRNUM;W_PIDLIN   # FGR 16/06/2014 : X3SUIVI98503
        If fstat Then
          Raz [F:BBB_]
          # Alimentation de la dimension PINVOICE avec les éléments de facturation
          [F:BBB_]PIHNUM = [F:REQ_]VCRNUM   #--CPO Elément de clé => pas de test if dim()
          [F:BBB_]PIDLIN = W_PIDLIN       #--CPO Elément de clé => pas de test if dim()
          #--CPO 81446 Test sur l'existence d'un champ avant init
          If dim([F:BBB_]PIVTYP)>0      : [F:BBB_]PIVTYP     = [F:REQ_]PIVTYP    : Endif
          If dim([F:BBB_]INVTYP)>0      : [F:BBB_]INVTYP     = [F:REQ_]INVTYP    : Endif
          If dim([F:BBB_]PIHTYP)>0      : [F:BBB_]PIHTYP     = [F:REQ_]PIHTYP    : Endif
          If dim([F:BBB_]ACCDAT)>0      : [F:BBB_]ACCDAT     = [F:REQ_]ACCDAT    : Endif
          If dim([F:BBB_]BPRVCR)>0      : [F:BBB_]BPRVCR     = [F:REQ_]BPRVCR    : Endif
          If dim([F:BBB_]BPRDAT)>0      : [F:BBB_]BPRDAT     = [F:REQ_]BPRDAT    : Endif
          If dim([F:BBB_]EECICT)>0      : [F:BBB_]EECICT     = [F:REQ_]EECICT    : Endif
          If dim([F:BBB_]EECSCH)>0      : [F:BBB_]EECSCH     = [F:REQ_]EECSCH    : Endif
          If dim([F:BBB_]EECSCH_LEG)>0  : [F:BBB_]EECSCH_LEG = func TRTX3BITC.GETLEG_EECSCH([F:REQ_]EECSCH, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]EECNAT)>0      : [F:BBB_]EECNAT     = [F:REQ_]EECNAT    : Endif
          If dim([F:BBB_]EECNAT_LEG)>0  : [F:BBB_]EECNAT_LEG = func TRTX3BITC.GETLEG_EECNAT([F:REQ_]EECNAT, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]FFWNUM)>0      : [F:BBB_]FFWNUM     = [F:REQ_]FFWNUM    : Endif
          If dim([F:BBB_]VACBPR)>0      : [F:BBB_]VACBPR     = [F:REQ_]VAC       : Endif
          If dim([F:BBB_]VACBPR_LEG)>0  : [F:BBB_]VACBPR_LEG = func TRTX3BITC.GETLEG_VACBPR([F:REQ_]VAC, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]VAT)>0         : [F:BBB_]VAT        = [F:REQ_]INVDTAVAT : Endif
          If dim([F:BBB_]VAT_LEG)>0     : [F:BBB_]VAT_LEG    = func TRTX3BITC.GETLEG_VAT([F:REQ_]INVDTAVAT, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]PTE)>0         : [F:BBB_]PTE        = [F:REQ_]PTE       : Endif
          If dim([F:BBB_]PTE_LEG)>0     : [F:BBB_]PTE_LEG    = func TRTX3BITC.GETLEG_PTE([F:REQ_]PTE, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]DEP)>0         : [F:BBB_]DEP        = [F:REQ_]DEP       : Endif
          If dim([F:BBB_]DEP_LEG)>0     : [F:BBB_]DEP_LEG    = func TRTX3BITC.GETLEG_DEP([F:REQ_]DEP, [F:REQ_]CPYLEG) : Endif
          # Lecture de la désignation traduite de l'article de l'élément de facturation (qui est forcément renseigné, cf la clause where du select)
          If dim([F:BBB_]ITMDES1)>0     : [F:BBB_]ITMDES1    = func LECT_DES_TRAD([F:REQ_]ITMREF,WBASE) : Endif
          If dim([F:BBB_]BPRNAM)>0      : [F:BBB_]BPRNAM     = [F:REQ_]BPRNAM    : Endif
          #         [F:BBB_]POSCOD = [F:REQ_]POSCOD # SYMEU 61649
          If dim([F:BBB_]POSCOD)>0      : [F:BBB_]POSCOD     = vireblc([F:REQ_]POSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]CTY)>0         : [F:BBB_]CTY        = [F:REQ_]CTY       : Endif
          If dim([F:BBB_]CRY)>0         : [F:BBB_]CRY        = [F:REQ_]CRY       : Endif
          If dim([F:BBB_]BPYNAM)>0      : [F:BBB_]BPYNAM     = [F:REQ_]BPYNAM    : Endif
          #         [F:BBB_]BPYPOSCOD = [F:REQ_]BPYPOSCOD # SYMEU 61649
          If dim([F:BBB_]BPYPOSCOD)>0   : [F:BBB_]BPYPOSCOD  = vireblc([F:REQ_]BPYPOSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]BPYCTY)>0      : [F:BBB_]BPYCTY     = [F:REQ_]BPYCTY    : Endif
          If dim([F:BBB_]BPYCRY)>0      : [F:BBB_]BPYCRY     = [F:REQ_]BPYCRY    : Endif
          #--/CPO
          IBBB_WRITE += 1   # FGR 16/06/2014 :X3SUIVI98503
          CHAINE = [F:BBB_]PIHNUM-num$([F:BBB_]PIDLIN)
          Write [F:BBB_]
          If fstat Then
            Call ERREUR(TABLE-CHAINE,1) From DOSDIC
          Else
            CRE += 1
            If [L]DET = 2 Then
              Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
            Endif
          Endif
        Endif
      Endif
    Next
    Call ECR_TRACE("**   TRTDIMBIACH : PVCRFOOT"-mess(7,2246,1)-"PINVOICE" - "(" + mess(4,138,1) - ":" - time$ - num$(time-ITIMEBEG) - mess(25,154,1) - num$(IBBB_WRITE) - mess(176,116,1) + ")",0)
&        From GESECRAN
  Endif
Return

###################################################################################
## Parcours de GACCDUDATE pour alimenter la dimension PINVOICE
###################################################################################
$FIN_PINVOICE_ECHEANCE
Local Integer W_PIDLIN

  # SYMEU - Fiche 61356 - début
  # Lecture de la règle de synchro PINVOICEDU.
  # Si elle est désactivée : on n'exécute pas le traitement.
  [L]DESFLG = func READ_REGLE("PINVOICEDU")
  If [L]DESFLG = 2 Then
    Return
  Endif
  # SYMEU - Fiche 61356 - fin
  If filinfo(filpath("FIL","GACCDUDATE","fde",GDOSSIER),0) > 0 Then
    IBBB_WRITE = 0   # FGR 16/06/2014 :X3SUIVI98503
    ITIMEBEG = time  # FGR 16/06/2014 :X3SUIVI98503
    Call ECR_TRACE("**   TRTDIMBIACH : GACCDUDATE"-mess(8,2246,1)-"PINVOICE" - "(" + mess(2,138,1) - ":" - time$ + ")",0) From GESECRAN
    # Requête de sélection des enregistrements de GACCDUDATE
    # FGR 16/06/2014 : X3SUIVI98503 : Ajout de , DUD.DUDLIG_0
    WREQ(0)= "select DUD.NUM_0, DUD.LIG_0, DUD.DUDLIG_0, PIH.PIVTYP_0, PIH.INVTYP_0, PIH.PIHTYP_0, PIH.ACCDAT_0, "
    WREQ(0)+="PIH.BPRVCR_0, PIH.BPRDAT_0, PIH.EECICT_0, PIH.EECSCH_0, PIH.EECNAT_0, PIH.FFWNUM_0, "
    WREQ(0)+="PIH.VAC_0, PIH.PTE_0, PIH.DEP_0, PIH.BPRNAM_0, PIH.BPYNAM_0, "
    WREQ(1)= "PIH.POSCOD_0, PIH.CTY_0, PIH.CRY_0, "
    WREQ(1)+="PIH.BPYPOSCOD_0, PIH.BPYCTY_0, PIH.BPYCRY_0, CPY.LEG_0 "
    WREQ(1)+="From "+GDOSSIER+".GACCDUDATE DUD,"+GDOSSIER+".PINVOICE PIH,"+GDOSSIER+".COMPANY CPY "
    WREQ(2)= "Where PIH.NUM_0=DUD.NUM_0 and PIH.STA_0=3 and PIH.ORIMOD_0=6 and CPY.CPY_0=PIH.CPY_0 "
    WREQ(2)+="and DUD.BPRTYP_0=2 and (DUD.PAYCUR_0+DUD.TMPCUR_0)>0"
    #
    # FGR 10/10/2014 : X3SUIVI102999
#    For (Char NUM(20), Integer LIG, Integer DUDLIG, Char PIVTYP(5), Integer INVTYP, Integer PIHTYP, Date ACCDAT,
#&        Char BPRVCR(20), Date BPRDAT, Char EECICT(5), Char EECSCH(5), Char EECNAT(5), Char FFWNUM(15),
#&        Char VAC(5), Char PTE(15), Char DEP(3), Char BPRNAM(35), Char BPYNAM(35), Char POSCOD(10),
#&        Char CTY(40), Char CRY(3), Char BPYPOSCOD(10), Char BPYCTY(40),
#&        Char BPYCRY(3), Char CPYLEG(3)) From WBASE Sql WREQ(0..2) As [F:REQ_]
    # Issue 113406 - 2016-01-04 by CPO : BI : error during synchronizing PINVOICE dimension
#    For (Char NUM(GLONVCR), Integer LIG, Integer DUDLIG, Char PIVTYP(GLONTPV), Integer INVTYP, Integer PIHTYP, Date ACCDAT,
#&        Char BPRVCR(20), Date BPRDAT, Char EECICT(GLONICT), Char EECSCH(GLONTSC), Char EECNAT(GLONTEC), Char FFWNUM(GLONBPR),
#&        Char VAC(GLONTVB), Char PTE(GLONPTE), Char DEP(GLONTDA), Char BPRNAM(GLONNAM), Char BPYNAM(GLONNAM), Char POSCOD(GLONPOS),
#&        Char CTY(GLONCTY), Char CRY(GLONCRY), Char BPYPOSCOD(GLONPOS), Char BPYCTY(GLONCTY),
#&        Char BPYCRY(GLONCRY), Char CPYLEG(GLONADI)) From WBASE Sql WREQ(0..2) As [F:REQ_]
    # GLONTSC/GLONTEC attached to objects that are activity code dependent (DEB)
    Local Integer WLONTSC,WLONTEC
    If dim(GLONTSC)<0
      WLONTSC=5
    Else
      WLONTSC=GLONTSC
    Endif
    If dim(GLONTEC)<0
      WLONTEC=5
    Else
      WLONTEC=GLONTEC
    Endif
    For (Char NUM(GLONVCR), Integer LIG, Integer DUDLIG, Char PIVTYP(GLONTPV), Integer INVTYP, Integer PIHTYP, Date ACCDAT,
&        Char BPRVCR(20), Date BPRDAT, Char EECICT(GLONICT), Char EECSCH(WLONTSC), Char EECNAT(WLONTEC), Char FFWNUM(GLONBPR),
&        Char VAC(GLONTVB), Char PTE(GLONPTE), Char DEP(GLONTDA), Char BPRNAM(GLONNAM), Char BPYNAM(GLONNAM), Char POSCOD(GLONPOS),
&        Char CTY(GLONCTY), Char CRY(GLONCRY), Char BPYPOSCOD(GLONPOS), Char BPYCTY(GLONCTY),
&        Char BPYCRY(GLONCRY), Char CPYLEG(GLONADI)) From WBASE Sql WREQ(0..2) As [F:REQ_]
    # End issue 113406
      # Vérification que la facture existe dans la dimension PINVOICE qui vient d'être alimentée (par sécurité)
      # FGR 16/06/2014 : X3SUIVI98503 (début)
      #Filter [F:BBB_] Where PIHNUM=[F:REQ_]NUM
      #NB_ENREG=rowcount([F:BBB_])
      #Filter [F:BBB_]
      NB_ENREG = 0
      Look [F:BBB_]PID0(1)=[F:REQ_]NUM
      If !fstat Then
        NB_ENREG = 1
      Endif
      # FGR 16/06/2014 : X3SUIVI98503 (fin)
      If NB_ENREG > 0 Then # la facture a été trouvée
        #W_PIDLIN = func TRTX3BI.GETLASTLIN("PINVOICED",[F:REQ_]NUM)+1000+[F:REQ_]LIG
        W_PIDLIN = func TRTX3BI.GETLASTLIN("PINVOICED",[REQ_]NUM)+1000+([REQ_]LIG*100)+[REQ_]DUDLIG   # FGR 16/06/2014 : X3SUIVI98503
        #Read [F:BBB_]PID0=[F:REQ_]NUM;W_PIDLIN
        Look [F:BBB_]PID0=[F:REQ_]NUM;W_PIDLIN   # FGR 16/06/2014 : X3SUIVI98503
        If fstat
          Raz [F:BBB_]
          # Alimentation de la dimension PINVOICE avec les échéances
          [F:BBB_]PIHNUM = [F:REQ_]NUM   #--CPO Elément de clé => pas de test if dim()
          [F:BBB_]PIDLIN = W_PIDLIN    #--CPO Elément de clé => pas de test if dim()
          #--CPO 81446 Test sur l'existence d'un champ avant init
          If dim([F:BBB_]PIVTYP)>0      : [F:BBB_]PIVTYP     = [F:REQ_]PIVTYP    : Endif
          If dim([F:BBB_]INVTYP)>0      : [F:BBB_]INVTYP     = [F:REQ_]INVTYP    : Endif
          If dim([F:BBB_]PIHTYP)>0      : [F:BBB_]PIHTYP     = [F:REQ_]PIHTYP    : Endif
          If dim([F:BBB_]ACCDAT)>0      : [F:BBB_]ACCDAT     = [F:REQ_]ACCDAT    : Endif
          If dim([F:BBB_]BPRVCR)>0      : [F:BBB_]BPRVCR     = [F:REQ_]BPRVCR    : Endif
          If dim([F:BBB_]BPRDAT)>0      : [F:BBB_]BPRDAT     = [F:REQ_]BPRDAT    : Endif
          If dim([F:BBB_]EECICT)>0      : [F:BBB_]EECICT     = [F:REQ_]EECICT    : Endif
          If dim([F:BBB_]EECSCH)>0      : [F:BBB_]EECSCH     = [F:REQ_]EECSCH    : Endif
          If dim([F:BBB_]EECSCH_LEG)>0  : [F:BBB_]EECSCH_LEG = func TRTX3BITC.GETLEG_EECSCH([F:REQ_]EECSCH, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]EECNAT)>0      : [F:BBB_]EECNAT     = [F:REQ_]EECNAT    : Endif
          If dim([F:BBB_]EECNAT_LEG)>0  : [F:BBB_]EECNAT_LEG = func TRTX3BITC.GETLEG_EECNAT([F:REQ_]EECNAT, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]FFWNUM)>0      : [F:BBB_]FFWNUM     = [F:REQ_]FFWNUM    : Endif
          If dim([F:BBB_]VACBPR)>0      : [F:BBB_]VACBPR     = [F:REQ_]VAC       : Endif
          If dim([F:BBB_]VACBPR_LEG)>0  : [F:BBB_]VACBPR_LEG = func TRTX3BITC.GETLEG_VACBPR([F:REQ_]VAC, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]PTE)>0         : [F:BBB_]PTE        = [F:REQ_]PTE       : Endif
          If dim([F:BBB_]PTE_LEG)>0     : [F:BBB_]PTE_LEG    = func TRTX3BITC.GETLEG_PTE([F:REQ_]PTE, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]DEP)>0         : [F:BBB_]DEP        = [F:REQ_]DEP       : Endif
          If dim([F:BBB_]DEP_LEG)>0     : [F:BBB_]DEP_LEG    = func TRTX3BITC.GETLEG_DEP([F:REQ_]DEP, [F:REQ_]CPYLEG) : Endif
          If dim([F:BBB_]BPRNAM)>0      : [F:BBB_]BPRNAM     = [F:REQ_]BPRNAM    : Endif
          #         [F:BBB_]POSCOD = [F:REQ_]POSCOD # SYMEU 61649
          If dim([F:BBB_]POSCOD)>0      : [F:BBB_]POSCOD     = vireblc([F:REQ_]POSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]CTY)>0         : [F:BBB_]CTY        = [F:REQ_]CTY       : Endif
          If dim([F:BBB_]CRY)>0         : [F:BBB_]CRY        = [F:REQ_]CRY       : Endif
          If dim([F:BBB_]BPYNAM)>0      : [F:BBB_]BPYNAM     = [F:REQ_]BPYNAM    : Endif
          #         [F:BBB_]BPYPOSCOD = [F:REQ_]BPYPOSCOD # SYMEU 61649
          If dim([F:BBB_]BPYPOSCOD)>0   : [F:BBB_]BPYPOSCOD  = vireblc([F:REQ_]BPYPOSCOD,1) : Endif  # SYMEU 61649
          If dim([F:BBB_]BPYCTY)>0      : [F:BBB_]BPYCTY     = [F:REQ_]BPYCTY    : Endif
          If dim([F:BBB_]BPYCRY)>0      : [F:BBB_]BPYCRY     = [F:REQ_]BPYCRY    : Endif
          #--/CPO
          IBBB_WRITE += 1   # FGR 16/06/2014 :X3SUIVI98503
          CHAINE = [F:BBB_]PIHNUM-num$([F:BBB_]PIDLIN)
          Write [F:BBB_]
          If fstat Then
            Call ERREUR(TABLE-CHAINE,1) From DOSDIC
          Else
            CRE += 1
            If [L]DET = 2 Then
              Call ECR_TRACE("**   "+mess(59,123,1)-CHAINE,0) From GESECRAN
            Endif
          Endif
        Endif
      Endif
    Next
    Call ECR_TRACE("**   TRTDIMBIACH : GACCDUDATE"-mess(8,2246,1)-"PINVOICE" - "(" + mess(4,138,1) - ":" - time$ - num$(time-ITIMEBEG) - mess(25,154,1) - num$(IBBB_WRITE) - mess(176,116,1) + ")",0)
&        From GESECRAN
  Endif
Return

###################################################################
# Déclarations des variables de travail communes
###################################################################
$DECL_VAR
Local Char WREQ(255)(4)  : Raz WREQ : # Requete générique pour base Oracle et SqlServer 7
Local Char WREQ2(255)    : Raz WREQ2 # Requete secondaire pour lire ATEXTRA
Local Char WREQ3(255)(2) : Raz WREQ3 : # Requete pour lire PORDERP

Local Integer D
Local Integer NB_ENREG : NB_ENREG=0
Local Char WBASE(1)       : WBASE=" "
Local Integer DESFLG, NBACT, NBDES   # SYMEU - Fiche 61356

Local Integer ITIMEBEG               # FGR 16/06/2014 :X3SUIVI98503 : time début
Local Integer IBBB_WRITE             # FGR 16/06/2014 :X3SUIVI98503 : time début

  # Alimentation du type de Database
  Gosub ALIM_WBASE
Return

#####################################################################
# Lecture de la dimension, pour voir si elle gère le multi-dossiers #
# Lecture de(s) la (les) règles de synchro                          #
#####################################################################
$READ_DIM
  If clalev([F:ABI]) = 0 : Local File =APPLI+".ABIDIM" [ABI] : Endif
  If [F:ABI]CODDIM <> right$(TABLE,3) Then
    Read [ABI] ABI0 = right$(TABLE,3)
    If fstat Then
      Raz [F:ABI]
    Endif
  Endif
  # SYMEU - Fiche 61356 - début
  # On teste si toutes les règles de synchronisation ayant la même table d'origine que la dimension
  # sont désactivées. Si c'est le cas, le traitement de la dimension n'est pas exécuté
  [L]DESFLG = 1
  [L]NBACT = 0 # nombre de règles activées
  [L]NBDES = 0 # nombre de règles désactivées
  If [F:ABI]TABORG <> "" Then
    If clalev([F:ABV]) = 0 : Local File =APPLI+".ABIREGORG" [ABV] : Endif
    For [F:ABV] Where TABORG = [F:ABI]TABORG
      If dim([F:ABV]DESFLG) > 0 Then
        If [F:ABV]DESFLG = 2 Then # règle désactivée
          [L]NBDES+=1
        Else                      # règle activée
          [L]NBACT+=1
        Endif
      Endif
    Next
  Endif
  If [L]NBACT = 0 and [L]NBDES <> 0 Then
    # on n'a trouvé que des règles de synchro désactivées
    [L]DESFLG = 2
  Endif
  # SYMEU - Fiche 61356 - fin
Return

###################################################################
## ALIM_WBASE alimentation de la variable donnant le type de      #
## DATABASE à partir de GTYPDBA                                   #
###################################################################
$ALIM_WBASE
  Case GTYPDBA
    When 1 : WBASE = "3" : # Oracle
    When 2 : WBASE = "5" : # Sql
    When 3 : WBASE = "2" : # Cisam
    When 4 : WBASE = "4" : # DB2
  Endcase
Return

##########################################################################################
# LECT_DES_TRAD : Lecture de la désignation traduite d'un article reçu en paramètre
##########################################################################################
# Parameters E : code de l'article
# Return       : désignation 1 traduite de l'article
##########################################################################################
Funprog LECT_DES_TRAD(P_ITMREF,P_WBASE)
Value    Char P_ITMREF
Value    Char P_WBASE

Local    Char  DESAXX(80)  # Désignation traduite

  DESAXX=""
  WREQ2="select TEXTE_0 From "+GDOSSIER+".ATEXTRA Where CODFIC_0='ITMMASTER' and ZONE_0='DES1AXX' and LANGUE_0='"+GLANGUE+"' and IDENT1_0='"+P_ITMREF+"'"
  For (Char TEXTE(80)) From P_WBASE Sql WREQ2 As [RE2_]
    DESAXX = [RE2_]TEXTE
    Break
  Next
End DESAXX

##########################################################################################
# SYMEU - Fiche 61356
##########################################################################################
# READ_REGLE : Lecture des règles de synchro
##########################################################################################
# Parameters E : règle de synchro à lire
# Return       : flag de désactivation de la règle de synchro
##########################################################################################
Funprog READ_REGLE(CODE_REGLE)
Value Char CODE_REGLE

Local Integer DESACT

  DESACT = 1
  If CODE_REGLE <> "" Then
    If clalev([F:ABV]) = 0 : Local File =APPLI+".ABIREGORG" [ABV] : Endif
    Read [F:ABV]ABV0=CODE_REGLE
    If !fstat and dim([F:ABV]DESFLG) > 0 Then
      DESACT = [F:ABV]DESFLG
    Endif
  Endif
End DESACT

