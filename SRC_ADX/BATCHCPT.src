#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################
## Exécution de la tâche comptable BATCHCPT             ##
##########################################################

# Issue X3-113302 - 2018-10-22 by CBO : manage Lock when Lettrage
# Issue X3-111845 - 2018-10-05 by CBO : manage n folders
# Issue X3-111553 - 2018-10-04 by CBO : put the good folder in ABA : new field CODABT
# Issue X3-59028 - 2018-01-09 by CBO : Changes of accounting task for mindo

Call VALID()
End

$INIT_VALID

Local Integer I, OKECR , OKLET , OKBAL
GSERVEUR = 1
Local Char    TYP(GLONGTE) , PIECE(GLONVCR) , TACHE(10)
Local Char WCODABT(GLONABA) # Issue X3-111553
Local Char    TYPLET(GLONGTE)(1..5) , LET(GLONVCR)(1..5)
Local Char    MESSA(250), SVTRACE(250)
Local Integer TEMPO , OK , STA , STAT , COMPTE , TEMPS , FLERR , MORT
Local Char    FILTRACE(250) #, FILTOURNE(250) , FILARRET(250) # Issue X3-59028
Local Char    PARAM(10) #, FILSTA(250)  # Issue X3-59028
Local Decimal ECHCUR , ECHLED
Local Integer FLECHE , ECHNUM , MAXECT
Local Decimal EXERCICE, PERIODE
Local Integer FLCHRNUM

Call PARAM("","MTCNBR", PARAM) From ADOVAL
MAXECT = min(32767,max(1000,val(PARAM)))

Local Integer NBECH , TBECR(1..MAXECT) , TBECH(1..MAXECT)
Local Decimal TBIPT(1..MAXECT)
Local Integer NUMLET , CAS , FLTRANS , FLOK
Local Integer CURCPT
Local Integer CURNUM
Local Integer NBMAX , NBOPE , TEMPX , NUMREQ
Local Integer NBFIL , NBFIT , NBFIB
Local Char    FILTRE(250)(1..30)
Local Char    FILLET(250)(1..30)
Local Char    FILBAL(250)(1..30)

Local Integer OKSOC
Local Integer NBLOK , ILOK
Local Char    TBLOK(GLONCPY)(1..100)
Local Char    LOKSOC(GLONCPY) , OLDSOC(GLONCPY)

Local Char LSTTYPLED(10) : # Liste des types référentiels flagués 'Double Entry Method'
Local Integer PSTLEDTYP(10)

Local Integer EP_BATCHCPT
Raz EP_BATCHCPT
Local Integer WB_WE_STOP, WB_AT_LEAST_ONE_DONE

  If dim(GNBENTREE) > 0 and GNBENTREE > 0 and find("BATCHCPT", GENTSTD(1..GNBENTREE))
    EP_BATCHCPT = 1
  Endif

  FLTRANS = 0
  If clalev([F:ABA9])=0 : Local File ABATABT   [ABA9] : Endif # Issue X3-59028

  Local File ABATRQTL [ABL9] , BATCH [BTC]
  If dim(GBATCHRQT) > 0
    NUMREQ = val(GBATCHRQT)
  Else
    NUMREQ = val(getenv$("RQT_ENTREP"))
  Endif

  Local File ABATRQT [ABR9]
  Read [ABR9]NUMREQ = NUMREQ
  If fstat
    GMESSAGE = "- ABATRQT [ABR9] NUMREQ =" - num$(NUMREQ) - "fstat =" - num$(fstat)
    GOK = 0
    Return
  Endif
  WCODABT = [F:ABR9]CODABT # Issue X3-111553

  Read [BTC]BTC1 = WCODABT # Issue X3-111553

  If fstat
    GMESSAGE = "- BATCH : [ABA] =" - WCODABT - "NUMREQ =" - num$(NUMREQ) - "fstat =" - num$(fstat)

    GOK = 0
    Return
  Endif

# controle not tested in QA
If 1 = 2
  If WCODABT = func SUBBTC.GET_TEMPLATE_ACCTASK_ABA()
    Local File ABATABT   [ABA]
    Trbegin [ABA]
    Read [ABA]CODABT = WCODABT
    If fstat = 0
      [F:ABA]ENAFLG = [V]CST_ANO
      Rewrite [ABA]
    Endif
    Commit
    GMESSAGE = WCODABT - ": (template of) recurring task is desactivated"
    GOK = 0
    Return
  Endif

  Local Char WPARAM(10)
  Call PARAM("", "MULBATCH", WPARAM) From ADOVAL
  If WPARAM = "2"
    If [F:BTC]COD = "ACCENTRY"
      Local File ABATABT   [ABA]
      Trbegin [ABA]
      Read [ABA]CODABT = WCODABT
      If fstat = 0
        [F:ABA]ENAFLG = [V]CST_ANO
        Rewrite [ABA]
      Endif
      Commit
      GMESSAGE = WCODABT - ": recurring task is desactivated for" - [F:BTC]COD - "accounting task."
      GOK = 0
      Return

    Endif
  Else
    If [F:BTC]COD <> "ACCENTRY"
      Local File ABATABT   [ABA]
      Trbegin [ABA]
      Read [ABA]CODABT = WCODABT
      If fstat = 0
        [F:ABA]ENAFLG = [V]CST_ANO
        Rewrite [ABA]
      Endif
      Commit
      GMESSAGE = WCODABT - ": recurring task is desactivated for" - [F:BTC]COD - "accounting task."
      GOK = 0
      Return

    Endif
  Endif
Endif

  TACHE = [F:BTC]COD # Issue X3-111553
  If TACHE = "ACCENTRY"
    OKECR    = 1
    OKLET    = 1
    OKBAL    = 1
  Else
    OKECR    = ([F:BTC]ACC=2)
    OKLET    = ([F:BTC]MTC=2)
    OKBAL    = ([F:BTC]BAL=2)
  Endif

  # personnal logfile of recurring task of AREQUETE function
#  Call ECR_TRACE("- Logfile =" - TACHE, 0) From GESECRAN-------------------------------------------------

  # general logfile of AREQUETE function : unauthorize to write in this log
#  If filinfo(filpath("SRV/TRA","serveur","tra"), 1) >= 0 and 1 = 0
#    Openo filpath("SRV/TRA","serveur","tra") , -1
#    Wrseq " - Recurring task of accounting task =" - TACHE;
#    Wrseq ""
#    Openo
#  Endif

  FLERR = 0
  FILTRACE  = filpath("TRA", TACHE, "tra", 0)
  SVTRACE = GTRACE

  adxifs = ""
  adxirs = chr$(10)

  # On force les droits d'accès
  For I=1 To GNBSITE
    GUSRFCY(I) = GSITE(I)
    GUSRAUZ(I) = "CMS"
  Next
  GNBAUZ = GNBSITE

  # On vérifie bien qu'il y a la compta
  If filinfo(filpath("FIL","GACCENTRY","fde",0),0)<0
    GOK = 0
    GMESSAGE = "- No accounting module"
    Return
  Endif

  # Ouverture fichiers
  Local File
&          GACCENTRY  [HAE] , GACCENTRYD [DAE] , GACCENTRYA [DAA]
&        , GACCTMP    [HAT] , GACCTMPD   [DAT] , GACCTMPA   [AAT]
&        , BALANCE    [BAL] , BALANA     [BLA] , BLAQTY     [BLQ]
&        , GTYPACCENT [GTE] , GACCDUDATE [DUD]
&        , COMPANY    [CPY] , FACILITY   [FCY] , FISCALYEAR [FIY]
&        , PERIOD     [PER] , TABCUR     [TCU] , GACCOUNT   [GAC]
&        , MATCHCODE  [MTC] , MTCBATCH   [MTB] , BPARTNER   [BPR] , GLED [LED]

  If filinfo(filpath("FIL","BALDEM","fde",0),0) >=0
    Local File BALDEM [BAM], BALDEMIDT [BAI]
  Endif

  If dim(EP_BATCHCPT) > 0 and EP_BATCHCPT
    GPOINT = "OPNATB"
    Gosub ENTREE From EXEFNC
  Endif

  # On vérifie s'il n'y en a pas un autre
  Lock =TACHE
  If fstat=1
    STA = 1
    MESSA = TACHE - mess(37,114,1) - [F:BTC]PID
    # Processus déjà actif
    Gosub MESSAGE
    GMESSAGE = MESSA
    GOK = 0
    Return
  Endif

  TEMPO = max([F:BTC]TIMOUT(0),5)
  TEMPS = max([F:BTC]TIMOUT(1),1)
  NBMAX = [F:BTC]TIMOUT(2)
  TEMPX = [F:BTC]TIMOUT(3)
  CURCPT = 0
  NBOPE = 0
  NBFIL = 0
  NBFIT = 0
  NBFIB = 0

  # Prepare a condition :
  # Different of every line which has a selection
  # it's for a line which has NO selection : so, no enreg of the other lines must be treated
  If [F:BTC]CRI <> ""
    NBFIL = 1
    FILTRE(1) = [F:BTC]CRI
    NBFIT = 1
    FILLET(1) = [F:BTC]CRI
    NBFIB = 1
    FILBAL(1) = [F:BTC]CRI
  Elsif TACHE <> "ACCENTRY"
    For [BTC]BTC0 Where CRI <> "" and ACC = 2
      If NBFIL=0
        NBFIL = 1
      Else
        If len(FILTRE(NBFIL))+len([F:BTC]CRI)+8>250
          NBFIL += 1
        Endif
        FILTRE(NBFIL) -= "&"
      Endif
      FILTRE(NBFIL) -= "!("+[F:BTC]CRI+")"
    Next

    For [BTC]BTC0 Where CRI <> "" and MTC = 2
      If NBFIT=0
        NBFIT = 1
      Else
        If len(FILLET(NBFIT)) + len([F:BTC]CRI) + 8 > 250
          NBFIT += 1
        Endif
        FILLET(NBFIT) -= "&"
      Endif
      FILLET(NBFIT) -= "!("+[F:BTC]CRI+")"
    Next

    For [BTC]BTC0 Where CRI <> "" and BAL = 2
      If NBFIB=0
        NBFIB = 1
      Else
        If len(FILBAL(NBFIB)) + len([F:BTC]CRI) + 8 > 250
          NBFIB += 1
        Endif
        FILBAL(NBFIB) -= "&"
      Endif
      FILBAL(NBFIB) -= "!("+[F:BTC]CRI+")"
    Next
    Read [BTC]BTC0 = TACHE
  Endif

  If NBFIL = 0
    NBFIL = 1
    FILTRE(1) = "1=1"
  Endif
  If NBFIT = 0
    NBFIT = 1
    FILLET(1) = "1=1"
  Endif
  If NBFIB = 0
    NBFIB = 1
    FILBAL(1) = "1=1"
  Endif

Return

$UPDATE_BATCH_TABLE

  # Issue X3-59028
  Trbegin [BTC]
  FLTRANS = 1
  Readlock [BTC]BTC0 = TACHE
  [F:BTC]RQT = val(GBATCHRQT)

  [F:BTC]PID = num$(adxpid)
  Rewrite [BTC]
  Commit

  FLTRANS = 0
  STA = 0

  MESSA = mess(31,114,1) - "(" + TACHE - "PID =" + num$([F:BTC]PID) - "Qry num =" - num$(NUMREQ) + ")"

  # Démarrage tâche
  Gosub MESSAGE
  If [F:BTC]ACC = 2
    MESSA = mess(154,105,1) : # Comptabilisation
    MESSA -= "("+mess(156,105,1)-":"-FILTRE(1)+")"
    Gosub MESSAGE
  Endif
  If [F:BTC]MTC=2
    MESSA = mess(155,105,1) : # Lettrage
    MESSA -= "("+mess(156,105,1)-":"-FILLET(1)+")"
    Gosub MESSAGE
  Endif
  If [F:BTC]BAL=2
    MESSA = mess(60,116,1) : # Balance
    MESSA -= "("+mess(156,105,1)-":"-FILBAL(1)+")"
    Gosub MESSAGE
  Endif
#  Gosub DEL_FIC_STATUT

Return




#**
#* Principal subprog : loop
#*!
Subprog VALID()

  Gosub INIT_VALID
  If GOK = 0
    End
  Endif

  Gosub UPDATE_BATCH_TABLE
  If GOK = 0
    End
  Endif

  WB_WE_STOP = 0
  While (1=1)
    While (1=1)

      WB_AT_LEAST_ONE_DONE = 0
      If OKECR
        Filter [HAT] Where FLG=0 & evalue(FILTRE(1..NBFIL)) & find(CPY,TBLOK(1..NBLOK))=0
        Read [HAT]HAT1 First
        If fstat=0
          WB_AT_LEAST_ONE_DONE = 1
          Readlock [HAT]HAT1 Curr
          If fstat=0

            Gosub VALID_PCE
            NBOPE += 1

            Unlock [HAT]
            If FLOK
              Gosub TEST_END_REC
              If WB_WE_STOP
                Break 2
              Else
                Break
              Endif
            Endif
          Endif
        Endif
      Endif

      If OKLET
        Filter [MTB] Where MTCFLG<2 & evalue(FILLET(1..NBFIT)) & find(CPY,TBLOK(1..NBLOK))=0
        Read [MTB]MTB0 First
        If fstat=0
          Readlock [MTB]MTB0 Curr
          If fstat=0
            WB_AT_LEAST_ONE_DONE = 1

            Gosub LETTRAGE
            NBOPE += 1

            Unlock [MTB]
            If FLOK
              Gosub TEST_END_REC
              If WB_WE_STOP
                Break 2
              Else
                Break
              Endif
            Endif
          Endif
         Endif
      Endif

      If OKBAL
        Filter [HAT] Where FLG=100 & evalue(FILBAL(1..NBFIB)) & find(CPY,TBLOK(1..NBLOK))=0
        Read [HAT]HAT1 First
        If fstat=0
          WB_AT_LEAST_ONE_DONE = 1
          Readlock [HAT]HAT1 Curr
          If fstat=0

            Gosub VALID_BAL
            NBOPE += 1

            Unlock [HAT]
            If FLOK
              Gosub TEST_END_REC
              If WB_WE_STOP
                Break 2
              Else
                Break
              Endif
            Endif
          Endif
        Endif
      Endif

      # On libère la dernière société traitée
      Call UNLOCKCPY From AX3MONO
      OLDSOC = ""
      # Et on revoit la table des sociétés lockées
      ILOK = 1
      While ILOK <= NBLOK
        Call LOCKCPY(TBLOK(ILOK), OKSOC) From AX3MONO
        If OKSOC
          Call UNLOCKCPY From AX3MONO
          Dela ILOK,1,NBLOK TBLOK
          NBLOK -= 1
        Else
          ILOK += 1
        Endif
      Wend

      # De temps en temps on réessaye les pièces pour lesquelles
      # on a eu un pb transactionnel
      CURNUM  = 0
      CURNUM2 = 0
      CURCPT += 1
      Gosub RETRY

      Gosub TEST_END_REC
      # stop asked or nothing done and waiting time finished
      If WB_WE_STOP or WB_AT_LEAST_ONE_DONE = 0
        Break 2
      Endif

    Wend
  Wend

  GTRACE = SVTRACE
End

# Does the task must be stopped ?
$TEST_END_REC

  WB_WE_STOP = 0
  # Issue X3-59028
  Read [ABA9]CODABT = WCODABT # Issue X3-111553
  If fstat = 0
    If [F:ABA9]ENAFLG <> [V]CST_AYES
      # recurring task must be stopped

      Gosub END_REC
      Unlock =TACHE
      Call UNLOCKCPY From AX3MONO

      WB_WE_STOP = 1
      Return
    Endif
  Endif

  NBMAX = max(1, [F:BTC]NBRREC)
  #  Max number of operations done or nothing done
  If NBOPE >= NBMAX or WB_AT_LEAST_ONE_DONE = 0

    Gosub END_REC
    Unlock =TACHE
    Call UNLOCKCPY From AX3MONO
    WB_WE_STOP = 1
    Return
  Endif

Return

$END_REC

  If !FLERR
    Trbegin [BTC]
    FLTRANS = 1
    Readlock [BTC]BTC0 = TACHE
    [F:BTC]PID = ""
    Rewrite [BTC]

    Commit
    FLTRANS = 0
  Endif

  STA = 0

  MESSA = mess(32,114,1) : # Arrêt de la tâche
  MESSA -= "(" + num$(NBOPE) - mess(00192,00124,1)  + ")"
  Gosub MESSAGE

Return



$RETRY

  If CURCPT=10

    Filter [HAT] Where FLG >= 2 and FLG < 100 and evalue(FILTRE(1..NBFIL))
    Read [HAT]HAT1 > CURNUM
    If fstat = 0 or fstat = 2
      WB_AT_LEAST_ONE_DONE = 1
      Readlock [HAT]HAT1 Curr
      If fstat=0
        CURNUM = [F:HAT]NUMPCE
        Gosub VALID_PCE
        Unlock [HAT]

        Goto RETRY
      Endif
    Endif

    Filter [HAT] Where FLG>=102 & evalue(FILBAL(1..NBFIB))
    Read [HAT]HAT1 > CURNUM
    If fstat = 0 or fstat = 2
      WB_AT_LEAST_ONE_DONE = 1
      Readlock [HAT]HAT1 Curr
      If fstat=0
        CURNUM = [F:HAT]NUMPCE
        Gosub VALID_BAL
        Unlock [HAT]

        Goto RETRY
      Endif
    Endif
    Filter [HAT]

   CURCPT = 0
  Endif

Return


$ERREUR

  ERR = errn
  STA = 9999 : MESSA = errmes$(errn)-errp-num$(errl)-errm
  FLERR = 1
  Gosub MESSAGE
  Gosub END_REC
  If FLTRANS & ERR<>75 : # Arrêt de la base
    Rollback : # Sinon Adonix fait un commit
  Endif
  GERREUR = ERR
End

#$RIEN
#Resume

$MESSAGE

  If filinfo(FILTRACE,0)<0
    Openo FILTRACE , 0
    Wrseq "#<AdxV"+GADOVERS+">@(#)%I% "+mess(33,114,1)
   # Validation des pièces comptables
    Openo
  Endif
  Openo FILTRACE , -1
  If STA=0
    Wrseq "=";
  Else
    Wrseq "<";
  Endif
  Wrseq format$("N0:4#",STA);
  Wrseq " ";format$("D:"+GFMDAT4,date$);
  Wrseq " ";time$;
  Wrseq " ";MESSA;
  If STA
    Wrseq " ("+num$(STA)+")";
  Endif
  Wrseq
  Openo

Return

## Sous-programme d'activation du flag
Subprog SETFLG
# -----------------------------subprog must be deleted after tests
  End # Issue X3-59028

  If clalev([F:BTC])=0 : Local File BATCH [BTC] : Endif
  Call DEBTRANS From GLOCK
  Gosub TR9
  If GOK<1
    Call ERREUR(mess(52,126,1)) From GESECRAN : # Attention vous devez redémarrer la tâche comptable
  Endif

End

$TR9

  GOK=1
  Trbegin [BTC]
  Update [BTC] Where 1=1 With STA=9
  If fstat=1
    GOK = -1 : GLOCK = "$BATCH" : Goto ROLL_TR9
  Elsif fstat
    GOK = 0 : Call RSTA("BTC","ACCENTRY") From GLOCK : Goto AB_TR9
  Endif
  Commit

Return

$AB_TR9

  Rollback

Return

$ROLL_TR9

  Rollback
  Call ROLL From GLOCK
  If GROLL
    Return
  Else
    Goto TR9
  Endif

###################################################################
## Validation d'une pièce                                        ##
###################################################################
$VALID_PCE

FLOK = 0
TYP = [F:HAT]TYP
PIECE  = [F:HAT]NUM
# On vérifie que la société n'est pas en "mono-utilisateur"
LOKSOC = [F:HAT]CPY
Gosub MONOCPY
If !OKSOC : Return : Endif
# Si elle y est déjà, on la flague
Look [HAE]HAE0 = TYP;PIECE
If fstat=0
 STA = 10 : MESSA = mess(19,114,1)-TYP-PIECE
# Pièce réelle déjà existante
 Call DEBTRANS From GLOCK
 FLAG = 1 : Gosub TR3
Else
 Call DEBTRANS From GLOCK
 Gosub TR2
 If GOK=1
  STA = 0 : MESSA = mess(34,114,1)-TYP-PIECE
#         Validation pièce
  FLOK = 1
  If dim(GUPDBAL)>0 and GUPDBAL=2
   Call DEBTRANS From GLOCK
   FLAG = 100 : Gosub TR3
  Endif
 Else
  MESSA = mess(35,114,1)-TYP-PIECE
  Gosub MESSAGE
  MESSA = "("+num$([F:HAT]FLG)+")"-GMESSAGE : # Pour être un peu plus précis
# Erreur en transaction de création
  Call DEBTRANS From GLOCK
  If [F:HAT]FLG=0 or GOK=0 : # On n'y arrivera pas la 2ème fois non plus
   FLAG = 2
  Elsif [F:HAT]FLG>=9      : # Là c'est desespéré
   FLAG = 1
  Else
   FLAG = [F:HAT]FLG+1     : # Là , il y a une chance...
  Endif
  Gosub TR3
 Endif
Endif
Gosub MESSAGE

Return

$TR2

GOK = 1 : STA=0
Trbegin [HAE] , [DAE] , [DAA] , [HAT] , [DAT] , [DAA] , [DUD] , [LED]
 FLTRANS = 1
 Raz [F:HAE]
 [F:HAE] = [F:HAT]
 Call GETSOC([F:HAE]FCY) From DEVSUB
 Call LEC_GTE_LEG(GCURLEG,TYP) From CPTLEC
 Call LEDTYPDEM([F:HAE]CPY,LSTTYPLED) From CPTDIV
 If [F:HAE]STA>1
  For I=0 To dim([F:HAE]FNLPSTNUM)-1
   [L]PSTLEDTYP(I) = 0
  Next
 Endif
 For [DAT] Where [F]TYP=[L]TYP & NUM=PIECE
  Raz [F:DAE]
  [F:DAE] = [F:HAE]
  [F:DAE] = [F:DAT]
  If [F:DAE]ACCNUM=0
   Read [DUD]DUD0(3) = [F:DAE]TYP;[F:DAE]NUM;[F:DAE]LIN
   If fstat=0 : [F:DAE]ACCNUM = [F:DUD]ACCNUM : Endif
  Endif
  FLCHRNUM = 2
  Gosub INICHR From SUBGAS : If GOK<1 : STA=13 : Break : Endif
  [L]PSTLEDTYP([F:DAE]LEDTYP-1)=1
  If dim([F:DAE]EXPNUM)>0 : [F:DAE]EXPNUM = [C]EXPORT : Endif
  Write [DAE]
  If fstat
   GOK = 0 : Call FSTA("DAE") From GLOCK : STA=14 : Break
  Endif

  If dim(EP_BATCHCPT)>0 & EP_BATCHCPT
   GPOINT = "AFTWRIDAE" : Gosub ENTREE From EXEFNC
   If !GOK : Break : Endif
  Endif

  If dim(GUPDBAL)<1 or GUPDBAL<>2
   Call LEC_LED([F:DAE]LED) From CPTLEC
   If [F:LED]GEN=2
    Call BALANCE(1) From CPTBAL
    If GOK<1 : STA=15 : Break : Endif
   Endif
  Endif
  If [F:DAE]SAC<>"" & [F:DAE]LEDTYP=GTYPGEN
   FLECHE = 2 : Gosub VALECHE From SUBGAS
   If GOK<1 : STA=16 : Break : Endif
  Endif
  For [AAT] Where [F]TYP=[L]TYP & NUM=PIECE & LIN=[F:DAT]LIN & LEDTYP=[F:DAT]LEDTYP
  Raz [F:DAA]
   [F:DAA] = [F:HAE]
   [F:DAA] = [F:DAE]
   [F:DAA] = [F:AAT]
   Write [DAA]
   If fstat
    GOK = 0 : Call FSTA("DAA") From GLOCK : STA=17 : Break 2
   Endif
   If [F:HAE]CAT<>3
    If dim(GUPDBAL)<1 or GUPDBAL<>2
     Call BALANA(1) From CPTBAL
     # Issue X3-59028
#     If GTRACE<>"" & GOK<1 : Call ECR_TRACE("BATCHCPT/$TR2 505 : AP Call BALANA from CPTBAL",1) From GESECRAN : Endif
     If GOK < 1
       MESSA = "BATCHCPT/$TR2 505 : AP Call BALANA from CPTBAL"
       Gosub MESSAGE
     Endif
      # End Issue X3-59028
     If GOK<1 : STA=18 : Break 2 : Endif

     ## Mise à jour Balance Russe si on est sur le référentiel Russe et sur une ligne éclatée
     If instr(1,LSTTYPLED,num$([F:DAE]LEDTYP)) & [F:DAT]ACCNUMDOE = 0 : # On est sur un référentiel Russe et une ligne éclatée
      Call BALDEM(1) From CPTBAL
     Endif
    Endif
   Endif
  Next
  Call VALSTA("GAS",+1) From SUBPS2
  If GOK<1 : STA=19 : Break : Endif
 Next
 If   GOK<0 : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 If dim(GUPDBAL)<1 or GUPDBAL<>2
  Delete [HAT] Where [F]TYP=[L]TYP & NUM=PIECE
  If fstat=1
   GOK = -1 : GLOCK = "$GACCTMP"-TYP-PIECE : STA=21 : Goto ROLL_TR2
  Endif
  Delete [DAT] Where [F]TYP=[L]TYP & NUM=PIECE
  If fstat=1
   GOK = -1 : GLOCK = "$GACCTMPD"-TYP-PIECE : STA=22 : Goto ROLL_TR2
  Endif
  Delete [AAT] Where [F]TYP=[L]TYP & NUM=PIECE
  If fstat=1
   GOK = -1 : GLOCK = "$GACCTMPA"-TYP-PIECE : STA=23 : Goto ROLL_TR2
  Endif
 Endif
 If dim(EP_BATCHCPT)>0 & EP_BATCHCPT
  GPOINT = "BEFWRIHAE" : Gosub ENTREE From EXEFNC
 Endif
 Gosub INI_FNLPSTNUM From SUBGAS : If GOK<1 : STA=13 : Goto AB_TR2 : Endif
 If dim([F:HAE]EXPNUM)>0 : [F:HAE]EXPNUM = [C]EXPORT : Endif
 Write [HAE] : # on termine par là!!
 If fstat
  GOK = 0 : Call FSTA("HAE") From GLOCK : STA=24 : Goto AB_TR2
 Endif
Commit
FLTRANS = 0
GPOINT = "AP_COMMIT" : Gosub ENTREE From EXEFNC

Return


$AB_TR2

Rollback
FLTRANS = 0

Return

$ROLL_TR2

Rollback
FLTRANS = 0
Call ROLL From GLOCK
If GROLL
  Return
Else
  Goto TR2
Endif

$TR3

GOK=1
Trbegin [HAT]
 FLTRANS = 1
 [F:HAT]FLG = FLAG
 Rewrite [HAT]
Commit
FLTRANS = 0

Return

$MONOCPY

If LOKSOC<>OLDSOC
 If OLDSOC<>""
  Call UNLOCKCPY From AX3MONO
  OLDSOC = ""
 Endif
 Call LOCKCPY(LOKSOC,OKSOC) From AX3MONO
 If !OKSOC
  NBLOK += 1
  TBLOK(NBLOK) = LOKSOC
 Else
  OLDSOC = LOKSOC
 Endif
Endif

Return

###################################################################
## MAJ Balance via GUPDBAL                                       ##
###################################################################
$VALID_BAL

FLOK = 0
TYP = [F:HAT]TYP
PIECE  = [F:HAT]NUM
# On vérifie que la société n'est pas en "mono-utilisateur"
LOKSOC = [F:HAT]CPY
Gosub MONOCPY
If !OKSOC : Return : Endif
# Si elle n'existe pas, on la flague
#Read [HAE]HAE0 = TYP;PIECE
#If fstat
 #STA = 101 : MESSA = mess(28,107,1)-TYP-PIECE
 # Pièce inexistante
 #Call DEBTRANS From GLOCK
 #FLAG = 101 : Gosub TR3_BAL
#Else
 Call DEBTRANS From GLOCK
 Gosub TR2_BAL
 If GOK=1
  STA = 0 : MESSA = mess(48,114,1)-TYP-PIECE
#         MAJ Balance
  FLOK = 1
 Else
  MESSA = mess(48,114,1)-TYP-PIECE
  Gosub MESSAGE
  MESSA = "("+num$([F:HAT]FLG)+")"-GMESSAGE : # Pour être un peu plus précis
# Erreur en transaction de création
  Call DEBTRANS From GLOCK
  If [F:HAT]FLG=100 or GOK=0 : # On n'y arrivera pas la 2ème fois non plus
   FLAG = 102
  Elsif [F:HAT]FLG>=109      : # Là c'est desespéré
   FLAG = 101
  Else
   FLAG = [F:HAT]FLG+1     : # Là , il y a une chance...
  Endif
  Gosub TR3_BAL
 Endif
#Endif
Gosub MESSAGE

Return

$TR2_BAL

GOK = 1 : STA=0
Trbegin [HAE] , [DAE] , [DAA] , [HAT] , [DAT] , [DAA] , [DUD] , [LED]
 FLTRANS = 1
 Raz [F:HAE]
 [F:HAE] = [F:HAT]
 Call GETSOC([F:HAE]FCY) From DEVSUB
 Call LEC_GTE_LEG(GCURLEG,TYP) From CPTLEC
 Call LEDTYPDEM([F:HAE]CPY,LSTTYPLED) From CPTDIV
 For [DAT] Where [F]TYP=[L]TYP & NUM=PIECE
  Raz [F:DAE]
  [F:DAE] = [F:HAE]
  [F:DAE] = [F:DAT]
  Call LEC_LED([F:DAE]LED) From CPTLEC
  If [F:LED]GEN=2
   Call BALANCE(1) From CPTBAL
   If GOK<1 : STA=115 : Break : Endif
  Endif
  For [AAT] Where [F]TYP=[L]TYP & NUM=PIECE & LIN=[F:DAT]LIN & LEDTYP=[F:DAT]LEDTYP
   Raz [F:DAA]
   [F:DAA] = [F:HAE]
   [F:DAA] = [F:DAE]
   [F:DAA] = [F:AAT]
   If [F:HAE]CAT<>3
    Call BALANA(1) From CPTBAL
     # Issue X3-59028
#
#    If GTRACE<>"" & GOK<1 : Call ECR_TRACE("BATCHCPT/$TR2 505 : AP Call BALANA from CPTBAL",1) From GESECRAN : Endif
     If GOK < 1
       MESSA = "BATCHCPT/$TR2 505 : AP Call BALANA from CPTBAL"
       Gosub MESSAGE
     Endif
      # End Issue X3-59028

    If GOK<1 : STA=118 : Break 2 : Endif

    ## Mise à jour Balance Russe si on est sur le référentiel Russe et sur une ligne éclatée
    If instr(1,LSTTYPLED,num$([F:DAE]LEDTYP)) & [F:DAT]ACCNUMDOE = 0 : # On est sur un référentiel Russe et une ligne éclatée
     Call BALDEM(1) From CPTBAL
    Endif
   Endif
  Next
 Next
 If   GOK<0 : Goto ROLL_TR2_BAL
 Elsif !GOK : Goto AB_TR2_BAL
 Endif
 Delete [HAT] Where [F]TYP=[L]TYP & NUM=PIECE
 If fstat=1
  GOK = -1 : GLOCK = "$GACCTMP"-TYP-PIECE : STA=121 : Goto ROLL_TR2_BAL
 Endif
 Delete [DAT] Where [F]TYP=[L]TYP & NUM=PIECE
 If fstat=1
  GOK = -1 : GLOCK = "$GACCTMPD"-TYP-PIECE : STA=122 : Goto ROLL_TR2_BAL
 Endif
 Delete [AAT] Where [F]TYP=[L]TYP & NUM=PIECE
 If fstat=1
  GOK = -1 : GLOCK = "$GACCTMPA"-TYP-PIECE : STA=123 : Goto ROLL_TR2_BAL
 Endif
Commit
FLTRANS = 0

Return


$AB_TR2_BAL

Rollback
FLTRANS = 0

Return

$ROLL_TR2_BAL

Rollback
FLTRANS = 0
Call ROLL From GLOCK
If GROLL
  Return
Else
  Goto TR2_BAL
Endif

$TR3_BAL

GOK=1
Trbegin [HAT]
 FLTRANS = 1
 [F:HAT]FLG = FLAG
 Rewrite [HAT]
Commit
FLTRANS = 0

Return


######################################################
## Lettrage en différé                              ##
######################################################
$LETTRAGE

FLOK = 0 : # Flag qui indique si on fait quelque chose de positif

$LET_SUITE
# A cause des lettrages trop long
#Gosub DEL_FIC_STATUT
# On vérifie que la société n'est pas en "mono-utilisateur"
LOKSOC = [F:MTB]CPY
Gosub MONOCPY
If !OKSOC : Return : Endif
NUMLET = [F:MTB]MTCNUM
# Vérification de l'existence des pièces
OK = 1
NBECH = 0
For [MTB]MTB0 Where MTCNUM=NUMLET
 Read [DAE]DAE2 = [F:MTB]ACCNUM
 If fstat : OK = 0 : Break : Endif
 NBECH += 1
 If NBECH > MAXECT
  STA=1 : MESSA = mess(42,114,1)  :# Paramètre MTCNBR (Nb lignes lettrage) trop petit
  Gosub MESSAGE
  Break
 Endif
 TBECR(NBECH) = [F:MTB]ACCNUM
 TBECH(NBECH) = [F:MTB]DUDLIG
 TBIPT(NBECH) = [F:MTB]AMTIPT
 CAS = [F:MTB]MTCTYP
Next
If STA=1 : Return : Endif
If OK
# On tente le lettrage
 STA = 0
 Call DEBTRANS From GLOCK
 Gosub TR4
 If STA
  Gosub TR5
 Elsif GOK>0
  FLOK = 1 : # Là, on a lettré quelque chose
 Endif
Else
# On incrémente le flag
 Trbegin [MTB]
  FLTRANS = 1
  Update [MTB] Where MTCNUM=NUMLET With MTCFLG = 1
 Commit
 FLTRANS = 0
Endif
# On tente la suivante
Read [MTB]MTB0(1) > NUMLET
If fstat<=2 : Goto LET_SUITE : Endif

Return

$TR4

GOK = 1
Trbegin [MTB]
 FLTRANS = 1
 Openo FILTRACE , -1

 SVTRACE = GTRACE # Issue X3-59028
 GTRACE = TACHE
 Call LETTRAGE(NBECH,TBECR,TBECH,TBIPT,CAS,1,STA,MESSA,TYPLET,LET) From CPTLET
 GTRACE = SVTRACE # Issue X3-59028
 Openo

 # Issue X3-113302 : to validate
  If GOK<1 : Goto AB_TR4 : Endif
# If GOK < 0
#   Goto ROLL_TR4
# Elsif GOK = 0
#   Goto AB_TR4
# Endif
# End Issue X3-111845

 If STA=0
  Delete [MTB] Where MTCNUM=NUMLET
  If fstat=1 : GLOCK = "$MTCBATCH"-num$(NUMLET) : Goto ROLL_TR4 : Endif
 Endif
Commit
FLTRANS = 0

Return


$AB_TR4

Rollback
FLTRANS = 0

Return

$ROLL_TR4

Rollback
FLTRANS = 0
Call ROLL From GLOCK
If GROLL
  Return
Else
  Goto TR4
Endif

$TR5

GOK=1
Trbegin [MTB]
 FLTRANS = 1
 Update [MTB] Where MTCNUM=NUMLET With MTCFLG=2
# Y'a rien à faire si ça ne marche pas!!!
Commit
FLTRANS = 0

Return

