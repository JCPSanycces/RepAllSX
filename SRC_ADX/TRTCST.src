#<AdxTL>@(#)0.0.0.0 $Revision$
#--------------------------------------#
#--- Traitement de calcul des couts ---#
#--------------------------------------#

#<gen>
# CLCOPE : Calcule les montants des opérations
# CLCSCO : Calcule les montants des opérations de sous-traitance
# CLCOVEMAT : Calcule les FG des composants
# CLCOVEITM : Calcule les FG des produits ou sous-produits
# CLCOVEWST : Calcule les FG des opérations
# CLCOVESCO : Calcule les FG des opérations de sous-traitance
# CLCOVE : Fonction générique pour calculer des FG
# CLCCST : Lance le calcul de coût des produits avec FG
# INITCSTOVE : Calcule tous les FG (mat, mac, lab, sco et /s-produit)
# VERIF : Vérifie que les calculs sont possibles
# INITCST : Efface les zones à calculer des produits et récupére les valeurs de mat, mac, mo, sco et sp
# SUMMAT : Somme des composantes de coût d'une matière
# COPSDP2CST : Copie les valeurs du masque SDP dans une ligne de CST
# SUMQTY : Renvoie la quantité de produits, matières ou sous-produits
# SUMOVE : Renvoie la somme des FG pour une ligne de mat, poste, sst, produit ou sp
# INIVALMAT : Récupére les valeurs des matières
# INIVALSP : Récupére les valeurs des sous-produits
# INIVALWST : Récupére les valeurs des opérations
# INIVALSCO : Récupére les valeurs de la sous-traitance
# GETPRI : Récupère le prix d'un article en fonction du paramètre LCST
#</gen>

##############################################
# CLCOPE : Calcule les montants des opérations
##############################################
Subprog CLCOPE
Local Integer I

For I=0 To [M:CST]NBWST-1
    If [M:CST]WRATCOD(I)>0
        [M:CST]WSETAMT(I) = [M:CST]WSETTIM(I) * [M:CST]WSETCST(I)
        [M:CST]WOPEAMT(I) = [M:CST]WOPETIM(I) * [M:CST]WOPECST(I)
#        [M:CST]WSTTOT(I)  = [M:CST]WSETAMT(I) + [M:CST]WOPEAMT(I)
    Endif
Next
End

##############################################
# Calcule les montants des opérations de sous-traitance
##############################################
Subprog CLCSCO
Local Integer I, J

For I=0 To [M:CST]NBSCO-1
    If [M:CST]SRATCOD(I)>0
        [M:CST]SSETAMT(I) = [M:CST]SSETTIM(I) * [M:CST]SSETCST(I)
        [M:CST]SOPEAMT(I) = [M:CST]SOPETIM(I) * [M:CST]SOPECST(I)
#        [M:CST]SCOTOT(I)  = [M:CST]SSETAMT(I) + [M:CST]SOPEAMT(I)
    Endif
    [M:CST]SITMAMT(I) = [M:CST]PRISCO(I) * ([M:CST]SQTYSCOITM(I) + ([M:CST]SQTYSCOITM(I)=0))
Next
End

##############################################
# CLCOVEMAT : Calcule les FG des composants
##############################################
Subprog CLCOVEMAT

If !clalev([F:OVE]) : Local File OVERHEAD [OVE] : Endif

Local Integer I, J, K, LTRG
Local Char    LCOL(1)
Local Char    LTABNAT(GLONONA)(dim([F:OVE]OVENAT))
Local Decimal LTABFXD(dim([F:OVE]OVENAT))
Local Decimal LTABVAR(dim([F:OVE]OVENAT))
Local Integer LTABTYP(dim([F:OVE]OVENAT))
Local Decimal LBASE, COE_PRO

# Ne pas effacer les FG récupérés des matières
# Call EFFZOCST(35)

For I=0 To [M:CST]NBMAT-1
    # Pas de FG sur les articles fournis par le sous-traitant
    If [M:CST]MOVECOD(I)<>"" & [M:CST]SCOFLG(I)<=2
&    & [M:CST]MQTYSTU(I)<>0    # Issue 100887 - 2014-10-29 by CCC : aggregate WIP by tracking
        Case [M:CST]MOVECOL(I)
          When 1 LCOL = "A"
          When 2 LCOL = "B"
          When 3 LCOL = "C"
          When 4 LCOL = "D"
        Endcase
        If [F:OVE]OVECOD<>[M:CST]MOVECOD(I)
            Read [OVE]OVE0 = [M:CST]MOVECOD(I)
            If fstat
                Raz [F:OVE]
            Endif
        Endif
        If [F:OVE]CLCLEV = 2
            # Positionnement sur les tables pouvant être utilisées dans les formules de FG
            If clalev([F:ITM])>0
                Read [ITM]ITM0=[M:CST]MATREF(I)
            Endif
            If clalev([F:ITF])>0
                Read [ITF]ITF0=[M:CST]MATREF(I);[M:CST0]STOFCY
            Endif
            If clalev([F:ITV])>0
                Read [ITV]ITV0=[M:CST]MATREF(I);[M:CST0]STOFCY
            Endif
            For LTRG = 1 To 2
                If find(LTRG,[F:OVE]VCRTRG)
&                & (LTRG<>2 | !sigma(0,I-1,(indcum+1)*([M:CST]MLNK(I)=[M:CST]MLNK(indcum) & [M:CST]MATREF(I)=[M:CST]MATREF(indcum) & [M:CST]MQTYSTU(indcum)<>0)))
# Issue 100887 - 2014-10-29 by CCC : aggregate WIP by tracking
#                 & (LTRG<>2 | !sigma(0,I-1,(indcum+1)*([M:CST]MLNK(I)=[M:CST]MLNK(indcum) & [M:CST]MATREF(I)=[M:CST]MATREF(indcum))))    # Issue 100887 - 2014-10-29 by CCC : aggregate WIP by tracking
                    Raz LTABNAT,LTABFXD,LTABVAR
                    Raz LBASE
                    Case [F:OVE]FORBASIS
                        When 1 :
                            If LTRG=1
                                LBASE =  sigma(0,GACTMAT-1,[M:CST]MMATCST(I*GACTMAT+indcum))
&                                  + sigma(0,GACTMAC-1,[M:CST]MMACCST(I*GACTMAC+indcum))
&                                  + sigma(0,GACTLAB-1,[M:CST]MLABCST(I*GACTLAB+indcum))
&                                  + [M:CST]MSCOCST(I)
                            Else
                                LBASE = sigma(J=I,[M:CST]NBMAT-1, ([M:CST]MLNK(I)=[M:CST]MLNK(J) & [M:CST]MATREF(I)=[M:CST]MATREF(J))*
&                                   (sigma(0,GACTMAT-1,[M:CST]MMATCST(J*GACTMAT+indcum))
&                                  + sigma(0,GACTMAC-1,[M:CST]MMACCST(J*GACTMAC+indcum))
&                                  + sigma(0,GACTLAB-1,[M:CST]MLABCST(J*GACTLAB+indcum))
&                                  + [M:CST]MSCOCST(indcum)) )
                            Endif
                        When 2 :
                            If LTRG=1
                                LBASE = [M:CST]MQTYSTU(I)
                            Else
                                LBASE = sigma(I,[M:CST]NBMAT-1, ([M:CST]MLNK(I)=[M:CST]MLNK(indcum) & [M:CST]MATREF(I)=[M:CST]MATREF(indcum))*[M:CST]MQTYSTU(indcum))
                            Endif
                    Endcase

                    GPOINT = "BASFGMAT"
                    Gosub ENTREE From EXEFNC
                    Call CLCOVE(LBASE,[M:CST]MOVECOD(I),LCOL,LTRG,LTABNAT,LTABTYP,LTABFXD,LTABVAR)
                    If sum(LTABFXD)<>0 | sum(LTABVAR)<>0
                        For J=0 To dim(LTABNAT)-1
                            If LTABNAT(J) = "" : Break : Endif
                            K=sigma(0,[M:CST]NBFGMAT-1,(indcum+1)
&                                                 *(  [M:CST]NATMAT(indcum)=LTABNAT(J)
&                                                   & [M:CST]OMATREF(indcum)=[M:CST]MATREF(I)
&                                                   & [M:CST]MOLNK(indcum)=[M:CST]MLNK(I) )
&                              )-1
                            If K<0
                                If [M:CST]NBFGMAT=dim([M:CST]NATMAT)-1
                                    Break
                                Endif
                                [M:CST]NATMAT([M:CST]NBFGMAT)  = LTABNAT(J)
                                [M:CST]OMATREF([M:CST]NBFGMAT) = [M:CST]MATREF(I)
                                [M:CST]MOLNK([M:CST]NBFGMAT)   = [M:CST]MLNK(I)
                                If LTABTYP(J) = 1
                                    [M:CST]MOVETYP([M:CST]NBFGMAT) = 2
                                Else
                                    [M:CST]MOVETYP([M:CST]NBFGMAT) = LTABTYP(J)
                                Endif
                                [M:CST]CLCLEV([M:CST]NBFGMAT)  = 2
                                If [M:CST]MOLNK([M:CST]NBFGMAT)=0
                                    [M:CST]MFXDAMT([M:CST]NBFGMAT) = LTABFXD(J)
                                Else
                                    Raz K
                                    COE_PRO = 1
                                        K=sigma(0,[M:CST]NBITM-1,(indcum+1)
&                                                             *(  [M:CST]ITMTYP(indcum)=1
&                                                               & [M:CST]MOLNK([M:CST]NBFGMAT)=[M:CST]ILNK(indcum)
&                                                               & K=0 & sigma(K=1,1,1) )
&                                          )-1
                                    If K>=0
                                        COE_PRO = [M:CST]ICOEPRO(K)
                                    Endif
                                    [M:CST]MFXDAMT([M:CST]NBFGMAT) = LTABFXD(J)*COE_PRO
                                Endif
                                [M:CST]MVARAMT([M:CST]NBFGMAT) = LTABVAR(J)
                                [M:CST]NBFGMAT += 1
                            Else
                                [M:CST]MFXDAMT(K) += LTABFXD(J)
                                [M:CST]MVARAMT(K) += LTABVAR(J)
                            Endif
                        Next
                    Endif
                Endif
            Next
        Endif
    Endif
Next

End

##############################################
# CLCOVEITM : Calcule les FG des produits ou sous-produits
##############################################
Subprog CLCOVEITM(PTYP)
Value Integer PTYP

If !clalev([F:OVE]) : Local File OVERHEAD [OVE] : Endif

Local Integer I, J, K, LTRG
Local Char    LCOL(1)
Local Char    LTABNAT(GLONONA)(dim([F:OVE]OVENAT))
Local Decimal LTABFXD(dim([F:OVE]OVENAT))
Local Decimal LTABVAR(dim([F:OVE]OVENAT))
Local Integer LTABTYP(dim([F:OVE]OVENAT))
Local Decimal LBASE

For I=0 To [M:CST]NBITM-1
    If [M:CST]ITMTYP(I) = PTYP
        J = find([M:CST]ITMREF(I),[M:CST]OITMREF)-1
        While J>=0
            Dela J,1 [M:CST]NBFGITM
            [M:CST]NBFGITM -= 1
            J = find([M:CST]ITMREF(I),[M:CST]OITMREF)-1
        Wend
    Endif
Next
For I=0 To [M:CST]NBITM-1
    # Si la quantité du composé est nulle, on ne calcule pas de FG
    # sinon cela crée des écarts en calcul de PRF entre le coût réel car il n'y a pas de WIP pour les FG de produit
    If [M:CST]IOVECOD(I)<>"" & [M:CST]ITMTYP(I) = PTYP & [M:CST]IQTYSTU(I)<>0
        Case [M:CST]IOVECOL(I)
          When 1 LCOL = "A"
          When 2 LCOL = "B"
          When 3 LCOL = "C"
          When 4 LCOL = "D"
        Endcase
        If [F:OVE]OVECOD<>[M:CST]IOVECOD(I)
            Read [OVE]OVE0 = [M:CST]IOVECOD(I)
            If fstat
                Raz [F:OVE]
            Endif
        Endif
        If [F:OVE]CLCLEV = 1
            # Positionnement sur les tables pouvant être utilisées dans les formules de FG
            If clalev([F:ITM])>0
                Read [ITM]ITM0=[M:CST]ITMREF(I)
            Endif
            If clalev([F:ITF])>0
                Read [ITF]ITF0=[M:CST]ITMREF(I);[M:CST0]STOFCY
            Endif
            If clalev([F:ITV])>0
                Read [ITV]ITV0=[M:CST]ITMREF(I);[M:CST0]STOFCY
            Endif
            If clalev([F:BOH])>0
                Read [BOH]BOH0=[M:CST]ITMREF(I);[M:CTP]BOMALT;[M:CTP]BOMALTTYP
            Endif
            For LTRG = 1 To 2
                If find(LTRG,[F:OVE]VCRTRG)
&                & (LTRG<>2 | !sigma(0,I-1,(indcum+1)*([M:CST]ILNK(I)=[M:CST]ILNK(indcum) & [M:CST]ITMREF(I)=[M:CST]ITMREF(indcum) & [M:CST]IQTYSTU(indcum)<>0)))
# Issue 100887 - 2014-10-29 by CCC : aggregate WIP by tracking
#&                & (LTRG<>2 | !sigma(0,I-1,(indcum+1)*([M:CST]ILNK(I)=[M:CST]ILNK(indcum) & [M:CST]ITMREF(I)=[M:CST]ITMREF(indcum))))
                    Raz LTABNAT,LTABFXD,LTABVAR
                    Raz LBASE
                    Case [F:OVE]FORBASIS
                    When 1 :
                        If [F:ITF]ITMREF<>[M:CST]ITMREF(I) | [F:ITF]STOFCY<>[M:CST0]STOFCY
                            Read [ITF]ITF0=[M:CST]ITMREF(I);[M:CST0]STOFCY
                            If fstat : Raz [F:ITF] : Endif
                        Endif
                        If LTRG=1
                            LBASE =  sigma(0,GACTMAT-1,[M:CST]IMATCST(I*GACTMAT+indcum) + [M:CST]ISMATCST(I*GACTMAT+indcum) + [M:CST]IFMATCST(I*GACTMAT+indcum) + [M:CST]IFSMATCST(I*GACTMAT+indcum))
&                              + sigma(0,GACTMAC-1,[M:CST]IMACCST(I*GACTMAC+indcum) + [M:CST]IFMACCST(I*GACTMAC+indcum))
&                              + sigma(0,GACTLAB-1,[M:CST]ILABCST(I*GACTLAB+indcum) + [M:CST]IFLABCST(I*GACTLAB+indcum))
&                              + [M:CST]ISCOCST(I) + [M:CST]IFSCOCST(I)
                            J=find(5,[F:ITF]OTRSTYP)-1
                            If J>=0
                                # En mono-niveau, il ne faut pas prendre en compte les FG des composants si le paramétrage dans l'ITF l'indique
                                If [M:CTP]NIV=1
&                            & [F:ITF]OVECPNFLG(J)=1
                                    LBASE -= [M:CST]IOVECPN(I)
                                # En multi-niveau, il faut prendre en compte les FG des composants si le paramétrage dans l'ITF l'indique
                                Elsif [M:CTP]NIV=2
&                            & [F:ITF]OVECPNFLG(J)=2
                                    LBASE += [M:CST]IOVECPN(I)
                                Endif
                            Endif
                        Else
                            LBASE = sigma(J=0,[M:CST]NBITM-1, ([M:CST]ILNK(I)=[M:CST]ILNK(J) & [M:CST]ITMREF(I)=[M:CST]ITMREF(J))*
&                               (sigma(0,GACTMAT-1,[M:CST]IMATCST(J*GACTMAT+indcum) + [M:CST]ISMATCST(J*GACTMAT+indcum) + [M:CST]IFMATCST(J*GACTMAT+indcum) + [M:CST]IFSMATCST(J*GACTMAT+indcum))
&                              + sigma(0,GACTMAC-1,[M:CST]IMACCST(J*GACTMAC+indcum) + [M:CST]IFMACCST(J*GACTMAC+indcum))
&                              + sigma(0,GACTLAB-1,[M:CST]ILABCST(J*GACTLAB+indcum) + [M:CST]IFLABCST(J*GACTLAB+indcum))
&                              + [M:CST]ISCOCST(J) + [M:CST]IFSCOCST(J)) )
                            J=find(5,[F:ITF]OTRSTYP)-1
                            If J>=0
                                # En mono-niveau, il ne faut pas prendre en compte les FG des composants si le paramétrage dans l'ITF l'indique
                                If [M:CTP]NIV=1
&                            & [F:ITF]OVECPNFLG(J)=1
                                    LBASE -= sigma(0,[M:CST]NBITM-1,( [M:CST]ILNK(I)=[M:CST]ILNK(indcum)
&                                                                &[M:CST]ITMREF(I)=[M:CST]ITMREF(indcum))
&                                                               * [M:CST]IOVECPN(indcum))
                                # En multi-niveau, il faut prendre en compte les FG des composants si le paramétrage dans l'ITF l'indique
                                Elsif [M:CTP]NIV=2
&                            & [F:ITF]OVECPNFLG(J)=2
                                    LBASE += sigma(0,[M:CST]NBITM-1,( [M:CST]ILNK(I)=[M:CST]ILNK(indcum)
&                                                                &[M:CST]ITMREF(I)=[M:CST]ITMREF(indcum))
&                                                               * [M:CST]IOVECPN(indcum))
                                Endif
                            Endif
                        Endif
                    When 2 :
                        If LTRG=1
                            LBASE = [M:CST]IQTYSTU(I)
                        Else
                            LBASE = sigma(I,[M:CST]NBITM-1, ([M:CST]ILNK(I)=[M:CST]ILNK(indcum))*[M:CST]IQTYSTU(indcum))
                        Endif
                    Endcase

                    GPOINT = "BASFGPROD"
                    Gosub ENTREE From EXEFNC
                    Call CLCOVE(LBASE,[M:CST]IOVECOD(I),LCOL,LTRG,LTABNAT,LTABTYP,LTABFXD,LTABVAR)
                    If sum(LTABFXD)<>0 | sum(LTABVAR)<>0
                        For J=0 To dim(LTABNAT)-1
                            If LTABNAT(J) = "" : Break : Endif
                            K=sigma(0,[M:CST]NBFGITM-1,(indcum+1)
&                                                 *(  [M:CST]NATITM(indcum)=LTABNAT(J)
&                                                   & [M:CST]OITMREF(indcum)=[M:CST]ITMREF(I)
&                                                   & [M:CST]IOLNK(indcum)=[M:CST]ILNK(I) )
&                              )-1
                            If K<0
                                If [M:CST]NBFGITM=dim([M:CST]NATITM)-1
                                    Break
                                Endif
                                [M:CST]NATITM([M:CST]NBFGITM)  = LTABNAT(J)
                                [M:CST]OITMREF([M:CST]NBFGITM) = [M:CST]ITMREF(I)
                                [M:CST]IOLNK([M:CST]NBFGITM)   = [M:CST]ILNK(I)
                                If LTABTYP(J) = 1
                                    [M:CST]IOVETYP([M:CST]NBFGITM) = 2
                                Else
                                    [M:CST]IOVETYP([M:CST]NBFGITM) = LTABTYP(J)
                                Endif
                                If [M:CST]IOLNK([M:CST]NBFGITM)=0
                                    [M:CST]IFXDAMT([M:CST]NBFGITM) = LTABFXD(J)
                                Else
                                    Raz K
                                    COE_PRO = 1
                                    If [M:CST]ITMTYP(I)=2
                                        K=sigma(0,[M:CST]NBITM-1,(indcum+1)
&                                                             *(  [M:CST]ITMTYP(indcum)=1
&                                                               & [M:CST]MOLNK([M:CST]NBFGMAT)=[M:CST]ILNK(indcum)
&                                                               & K=0 & sigma(K=1,1,1) )
&                                          )-1
                                    Else
                                        K=I
                                    Endif
                                    If K>=0
                                        COE_PRO = [M:CST]ICOEPRO(K)
                                    Endif
                                    [M:CST]IFXDAMT([M:CST]NBFGITM) = LTABFXD(J)*COE_PRO
                                Endif
                                [M:CST]IVARAMT([M:CST]NBFGITM) = LTABVAR(J)
                                [M:CST]NBFGITM += 1
                            Else
                                [M:CST]IFXDAMT(K) += LTABFXD(J)
                                [M:CST]IVARAMT(K) += LTABVAR(J)
                            Endif
                        Next
                    Endif
                Endif
            Next
        Endif
    Endif
Next
End

##############################################
# CLCOVEWST : Calcule les FG des opérations
##############################################
Subprog CLCOVEWST

If !clalev([F:OVE]) : Local File OVERHEAD [OVE] : Endif

Local Integer I, LTRG
Local Char    LCOL(1)
Local Char    LTABNAT(GLONONA)(dim([F:OVE]OVENAT))
Local Decimal LTABFXD(dim([F:OVE]OVENAT))
Local Decimal LTABVAR(dim([F:OVE]OVENAT))
Local Integer LTABTYP(dim([F:OVE]OVENAT))
Local Decimal LBASE

For I=0 To [M:CST]NBWST-1
    If [M:CST]WOVECOD(I)<>""
&    & ([M:CST]WOPETIM(I)<>0 | [M:CST]WSETTIM(I)<>0)    # Issue 100887 - 2014-10-29 by CCC : aggregate WIP by tracking
        Case [M:CST]WOVECOL(I)
          When 1 LCOL = "A"
          When 2 LCOL = "B"
          When 3 LCOL = "C"
          When 4 LCOL = "D"
        Endcase
        If [F:OVE]OVECOD<>[M:CST]WOVECOD(I)
            Read [OVE]OVE0 = [M:CST]WOVECOD(I)
            If fstat
                Raz [F:OVE]
            Endif
        Endif
        # Positionnement sur les tables pouvant être utilisées dans les formules de FG
        If clalev([F:MWS])>0
            Read [MWS]WST0=[M:CST]WST(I);[M:CST0]STOFCY
            If clalev([F:MWC])>0
                Read [MWC]WCT0 = [F:MWS]VLTCCE;[F:MWS]WCRFCY
            Endif
        Endif
        For LTRG = 1 To 2    # 1: FG doc    2: FG doc ori
            If find(LTRG,[F:OVE]VCRTRG)
&            & (LTRG<>2 | !sigma(0,I-1,(indcum+1)*([M:CST]WLNK(I)=[M:CST]WLNK(indcum) & [M:CST]WST(I)=[M:CST]WST(indcum) & ([M:CST]WOPETIM(indcum)<>0 | [M:CST]WSETTIM(indcum)<>0))))
    # Issue 100887 - 2014-10-29 by CCC : aggregate WIP by tracking
#&            & (LTRG<>2 | !sigma(0,I-1,(indcum+1)*([M:CST]WLNK(I)=[M:CST]WLNK(indcum) & [M:CST]WST(I)=[M:CST]WST(indcum))))
                Raz LTABNAT,LTABFXD,LTABVAR
                Raz LBASE
                # Issue 83249 - 2012-06-29 by CCC : Calcul de la base sur document origine
                If LTRG=2
                    Case [F:OVE]FORBASIS
                        When 1 : LBASE = sigma(0,[M:CST]NBWST-1,([M:CST]WLNK(I)=[M:CST]WLNK(indcum) & [M:CST]WST(I)=[M:CST]WST(indcum))*([M:CST]WSETAMT(indcum)+[M:CST]WOPEAMT(indcum)))
                        When 2 : LBASE = sigma(0,[M:CST]NBWST-1,([M:CST]WLNK(I)=[M:CST]WLNK(indcum) & [M:CST]WST(I)=[M:CST]WST(indcum))*([M:CST]WSETTIM(indcum)+[M:CST]WOPETIM(indcum)))
                    Endcase
                Else
                    Case [F:OVE]FORBASIS
                        When 1 : LBASE = [M:CST]WSETAMT(I)+[M:CST]WOPEAMT(I)
                        When 2 : LBASE = [M:CST]WSETTIM(I)+[M:CST]WOPETIM(I)
                    Endcase
                Endif

                GPOINT = "BASFGOPE"
                Gosub ENTREE From EXEFNC
                Call CLCOVE(LBASE,[M:CST]WOVECOD(I),LCOL,LTRG,LTABNAT,LTABTYP,LTABFXD,LTABVAR)
                For J=0 To dim(LTABNAT)-1
                    If LTABNAT(J) = "" : Break : Endif
                    K=sigma(0,[M:CST]NBFGWST-1,(indcum+1)
&                                             *(  [M:CST]NATWST(indcum)=LTABNAT(J)
&                                               & [M:CST]OWST(indcum)=[M:CST]WST(I)
&                                               & [M:CST]WOLNK(indcum)=[M:CST]WLNK(I) )
&                          )-1
                    If K<0
                        If [M:CST]NBFGWST=dim([M:CST]NATWST)-1
                            Break
                        Endif
                        [M:CST]NATWST([M:CST]NBFGWST)  = LTABNAT(J)
                        [M:CST]OWST([M:CST]NBFGWST)    = [M:CST]WST(I)
                        [M:CST]WOLNK([M:CST]NBFGWST)   = [M:CST]WLNK(I)
                        If LTABTYP(J) = 1
                            [M:CST]WOVETYP([M:CST]NBFGWST) = [M:CST]WSTTYP(I)+2    # --> 3=MA , 4=MO
                        Else
                            [M:CST]WOVETYP([M:CST]NBFGWST) = LTABTYP(J)
                        Endif
                        If [M:CST]WOLNK([M:CST]NBFGWST)=0
                            [M:CST]WFXDAMT([M:CST]NBFGWST) = LTABFXD(J)
                        Else
                            Raz K
                            COE_PRO = 1
                            K=sigma(0,[M:CST]NBITM-1,(indcum+1)
&                                                        *( [M:CST]ITMTYP(indcum)=1
&                                                        & [M:CST]WOLNK([M:CST]NBFGWST)=[M:CST]ILNK(indcum)
&                                                        & K=0 & sigma(K=1,1,1) )
&                                      )-1
                            If K>=0
                                COE_PRO = [M:CST]ICOEPRO(K)
                            Endif
                            [M:CST]WFXDAMT([M:CST]NBFGWST) = LTABFXD(J)*COE_PRO
                        Endif
                        [M:CST]WVARAMT([M:CST]NBFGWST) = LTABVAR(J)
                        [M:CST]NBFGWST += 1
                    Else
                        [M:CST]WFXDAMT(K) += LTABFXD(J)
                        [M:CST]WVARAMT(K) += LTABVAR(J)
                    Endif
                Next
            Endif
        Next
    Endif
Next

End

##############################################
# CLCOVESCO : Calcule les FG des opérations de sous-traitance
##############################################
Subprog CLCOVESCO

If !clalev([F:OVE]) : Local File OVERHEAD [OVE] : Endif

Local Integer I, J, K, LTRG
Local Char    LCOL(1)
Local Char    LTABNAT(GLONONA)(dim([F:OVE]OVENAT))
Local Decimal LTABFXD(dim([F:OVE]OVENAT))
Local Decimal LTABVAR(dim([F:OVE]OVENAT))
Local Integer LTABTYP(dim([F:OVE]OVENAT))
Local Decimal LBASE

For I=0 To [M:CST]NBSCO-1
    If [M:CST]SOVECOD(I) <> ""
&    & ([M:CST]SOPETIM(I)<>0 | [M:CST]SSETTIM(I)<>0)    # Issue 100887 - 2014-10-29 by CCC : aggregate WIP by tracking
        Case [M:CST]SOVECOL(I)
          When 1 LCOL = "A"
          When 2 LCOL = "B"
          When 3 LCOL = "C"
          When 4 LCOL = "D"
        Endcase
        If [F:OVE]OVECOD<>[M:CST]SOVECOD(I)
            Read [OVE]OVE0 = [M:CST]SOVECOD(I)
            If fstat
                Raz [F:OVE]
            Endif
        Endif
        # Positionnement sur les tables pouvant être utilisées dans les formules de FG
        If clalev([F:MWS])>0
            Read [MWS]WST0=[M:CST]SCOWST(I);[M:CST0]STOFCY
            If clalev([F:MWC])>0
                Read [MWC]WCT0 = [F:MWS]VLTCCE;[F:MWS]WCRFCY
            Endif
        Endif

        For LTRG = 1 To 2
            If find(LTRG,[F:OVE]VCRTRG)
&            & (LTRG<>2 | !sigma(0,I-1,(indcum+1)*([M:CST]SLNK(I)=[M:CST]SLNK(indcum) & [M:CST]SCOWST(I)=[M:CST]SCOWST(indcum) & ([M:CST]SOPETIM(indcum)<>0 | [M:CST]SSETTIM(indcum)<>0))))
# Issue 100887 - 2014-10-29 by CCC : aggregate WIP by tracking
#&            & (LTRG<>2 | !sigma(0,I-1,(indcum+1)*([M:CST]SLNK(I)=[M:CST]SLNK(indcum) & [M:CST]SCOWST(I)=[M:CST]SCOWST(indcum))))
                Raz LTABNAT,LTABFXD,LTABVAR
                Raz LBASE
                If LTRG=2
                    Case [F:OVE]FORBASIS
                        When 1 : LBASE = sigma(0,[M:CST]NBSCO-1,([M:CST]SLNK(I)=[M:CST]SLNK(indcum) & [M:CST]SCOWST(I)=[M:CST]SCOWST(indcum))*([M:CST]SSETAMT(indcum)+[M:CST]SOPEAMT(indcum)))
                        When 2 : LBASE = sigma(0,[M:CST]NBSCO-1,([M:CST]SLNK(I)=[M:CST]SLNK(indcum) & [M:CST]SCOWST(I)=[M:CST]SCOWST(indcum))*([M:CST]SSETTIM(indcum)+[M:CST]SOPETIM(indcum)))
                    Endcase
                Else
                    Case [F:OVE]FORBASIS
                        When 1 : LBASE = [M:CST]SSETAMT(I)+[M:CST]SOPEAMT(I)
                        When 2 : LBASE = [M:CST]SSETTIM(I)+[M:CST]SOPETIM(I)
                    Endcase
                Endif

                GPOINT = "BASFGSCO"
                Gosub ENTREE From EXEFNC
                Call CLCOVE(LBASE,[M:CST]SOVECOD(I),LCOL,LTRG,LTABNAT,LTABTYP,LTABFXD,LTABVAR)

                Gosub ADD_OVESCO
            Endif
        Next
    Endif
Next

For I=0 To [M:CST]NBSCO-1
    If [M:CST]SIOVECOD(I) <> ""
&    & func SUMQTY("P", [M:CST]SLNK(I))<>0    # Issue 100887 - 2014-10-29 by CCC : aggregate WIP by tracking
        Case [M:CST]SIOVECOL(I)
          When 1 LCOL = "A"
          When 2 LCOL = "B"
          When 3 LCOL = "C"
          When 4 LCOL = "D"
        Endcase
        If [F:OVE]OVECOD<>[M:CST]SIOVECOD(I)
            Read [OVE]OVE0 = [M:CST]SIOVECOD(I)
            If fstat
                Raz [F:OVE]
            Endif
        Endif
        # Positionnement sur les tables pouvant être utilisées dans les formules de FG
        If clalev([F:ITM])>0
            Read [ITM]ITM0=[M:CST]SCOITMREF(I)
        Endif
        If clalev([F:ITF])>0
            Read [ITF]ITF0=[M:CST]SCOITMREF(I);[M:CST0]STOFCY
            If fstat : Raz [F:ITF] : Endif
        Endif
        If clalev([F:ITV])>0
            Read [ITV]ITV0=[M:CST]SCOITMREF(I);[M:CST0]STOFCY
            If fstat : Raz [F:ITV] : Endif
        Endif

        For LTRG = 1 To 2
            If find(LTRG,[F:OVE]VCRTRG)
&            & (LTRG<>2 | !sigma(0,I-1,(indcum+1)*([M:CST]SLNK(I)=[M:CST]SLNK(indcum) & [M:CST]SCOWST(I)=[M:CST]SCOWST(indcum) & func SUMQTY("P", [M:CST]SLNK(indcum))<>0)))
# Issue 100887 - 2014-10-29 by CCC : aggregate WIP by tracking
#& (LTRG<>2 | !sigma(0,I-1,(indcum+1)*([M:CST]SLNK(I)=[M:CST]SLNK(indcum) & [M:CST]SCOWST(I)=[M:CST]SCOWST(indcum))))
                Raz LTABNAT,LTABFXD,LTABVAR
                Raz LBASE
                Case [F:OVE]FORBASIS
                    When 1 : LBASE = [M:CST]PRISCO(I)*[M:CST]SCOEQTY(I) * func SUMQTY("P", [M:CST]SLNK(I))
                    When 2 : LBASE = func SUMQTY("P", [M:CST]SLNK(I))
                Endcase
                GPOINT = "BASFGSCO2"
                Gosub ENTREE From EXEFNC
                Call CLCOVE(LBASE,[M:CST]SIOVECOD(I),LCOL,LTRG,LTABNAT,LTABTYP,LTABFXD,LTABVAR)
                Gosub ADD_OVESCO
            Endif
        Next
    Endif
Next

End

$ADD_OVESCO
    For J=0 To dim(LTABNAT)-1
        If LTABNAT(J) = "" : Break : Endif
        K=sigma(0,[M:CST]NBFGSCO-1,(indcum+1)
&                                 *(  [M:CST]NATSCO(indcum)=LTABNAT(J)
&                                   & [M:CST]OSCOWST(indcum)=[M:CST]SCOWST(I)
&                                   & [M:CST]SOLNK(indcum)=[M:CST]SLNK(I) )
&              )-1
        If K<0
            If [M:CST]NBFGSCO=dim([M:CST]NATSCO)-1
                Break
            Endif
            [M:CST]NATSCO([M:CST]NBFGSCO)  = LTABNAT(J)
            [M:CST]OSCOWST([M:CST]NBFGSCO) = [M:CST]SCOWST(I)
            [M:CST]SOLNK([M:CST]NBFGSCO)   = [M:CST]SLNK(I)
            If LTABTYP(J) = 1
                [M:CST]SOVETYP([M:CST]NBFGSCO) = 5
            Else
                [M:CST]SOVETYP([M:CST]NBFGSCO) = LTABTYP(J)
            Endif
            If [M:CST]SOLNK([M:CST]NBFGSCO)=0
                [M:CST]SFXDAMT([M:CST]NBFGSCO) = LTABFXD(J)
            Else
                Raz K
                COE_PRO = 1
                    K=sigma(0,[M:CST]NBITM-1,(indcum+1)
&                                           *(  [M:CST]ITMTYP(indcum)=1
&                                             & [M:CST]SOLNK([M:CST]NBFGSCO)=[M:CST]ILNK(indcum)
&                                             & K=0 & sigma(K=1,1,1) )
&                          )-1
                If K>=0
                    COE_PRO = [M:CST]ICOEPRO(K)
                Endif
                [M:CST]SFXDAMT([M:CST]NBFGSCO) = LTABFXD(J)*COE_PRO
            Endif
            [M:CST]SVARAMT([M:CST]NBFGSCO) = LTABVAR(J)
            [M:CST]NBFGSCO += 1
        Else
            [M:CST]SFXDAMT(K) += LTABFXD(J)
            [M:CST]SVARAMT(K) += LTABVAR(J)
        Endif
    Next
Return

##############################################
# CLCOVE : Fonction générique pour calculer des FG
##############################################
# Paramètres E : PBAS = base de calcul (Qté, Temps ou Montant)
#                POVE = code FG
#                PCOL = choix colonne ('A', 'B', 'C' ou 'D')
#                PVCRTRG = 1:FG document 2:FG document origine
#            S : PTABNAT() = Natures
#                PTABTYP() = Type de frais généraux (mat, mac, mo ou stt)
#                PTABFXD() = Valeur des frais fixes par nature
#                PTABVAR() = Valeur des frais variables par nature
##############################################
Subprog CLCOVE(PBAS, POVE, PCOL, PVCRTRG, PTABNAT, PTABTYP, PTABFXD, PTABVAR)
Value    Decimal PBAS
Value    Char    POVE
Value    Char    PCOL
Value    Integer PVCRTRG
Variable Char    PTABNAT()
Variable Integer PTABTYP()
Variable Decimal PTABFXD()
Variable Decimal PTABVAR()

Local Integer I_NAT, J
Local Decimal CLC_NAT, CUM_NAT
Local Char    COD_FOR(GLONFOR)
Local Decimal BASE, OH_BASE    # Variables utilisées dans les formules

If !clalev([F:OVE]) : Local File OVERHEAD [OVE] : Endif
If !clalev([F:ONA]) : Local File OVENAT   [ONA] : Endif
If !clalev([F:TFO]) : Local File TABFOR   [TFO] : Endif

Raz PTABNAT, PTABTYP, PTABFXD, PTABVAR

If [F:OVE]OVECOD<>POVE
    Read [OVE]OVE0 = POVE
    If fstat
        End
    Endif
Endif

If !find(PCOL,"A","B","C","D")
    PCOL = "A"
Endif

Onerrgo ERR_FOR


BASE    = PBAS
OH_BASE = PBAS

CUM_NAT = PBAS : # pour calcul de la 1ère nature (avec formule)
For I_NAT = 0 To dim([F:OVE]OVENAT) -1
    If [F:OVE]VCRTRG(I_NAT)=PVCRTRG
        J=find([F:OVE]OVENAT(I_NAT),PTABNAT)-1
        If J<0
            J=find("",PTABNAT)-1
            If J<0 : Break : Endif
            PTABNAT(J) = [F:OVE]OVENAT(I_NAT)
            Raz [F:ONA]
            Read [ONA]ONA0=PTABNAT(J)
            PTABTYP(J) = [F:ONA]TYPCST
        Endif

        Raz GPE
        # point d'entrée pour calculer les frais/nature DM 11785
        GPOINT = "CALCFG"
        Gosub ENTREE From EXEFNC

        If GPE=0
            If evalue("[F:OVE]FXDOVE"+PCOL+"(I_NAT)") <> 0 & [F:OVE]OVENAT(I_NAT) <> ""
                CLC_NAT = evalue("[F:OVE]FXDOVE"+PCOL+"("+num$(I_NAT)+")")
                PTABFXD(J) += CLC_NAT

                #MJH X3-31260 / SAM 104060.n 4/26/2017
                #If the quantity is negative, it means that it is a cancellation and
                # the fixed overhead amount needs to be negated. This already happens
                # with variable overhead since it is multiplied by the quantity.
                If dim([F:MWI]QTY)> 0 and  [F:MWI]QTY < 0
                    PTABFXD(J) *= -1
                Endif

            Elsif [F:OVE]OVENAT(I_NAT) <> ""
                COD_FOR = evalue("[F:OVE]FORCOD"+PCOL+"("+num$(I_NAT)+")")
                Read [TFO]TFO0 = 5;COD_FOR
                If !fstat
                    If [F:OVE]CLCMOD = 1    # Mode calcul par cumul
                         CLC_NAT = evalue([F:TFO]FORFOR) * PBAS
                    Else                    # Mode calcul par cascade
                         CLC_NAT = evalue([F:TFO]FORFOR) * CUM_NAT
                    Endif
                    PTABVAR(J) += CLC_NAT
               Endif
            Endif
        Endif
        CUM_NAT += CLC_NAT
    Endif

Next

Onerrgo

End

##############################################
$ERR_FOR
# Issue 84715 - 2012-11-28 by CCC
Local Char LMSG(250)
LMSG = errmes$(errn)+"\|"+ errm +"|"
LMSG += "\"+mess(152,197,1)- [F:OVE]OVECOD -"("+ COD_FOR + ")"
If GTRACE<>""
    Call ECRTRACE(LMSG,1) From TRTCST
Else
    Call ERREUR(LMSG) From GESECRAN
Endif
Resume

#############################################
# CLCCST : Lance le calcul de coût des produits avec FG
#############################################
Subprog CLCCST
Local Integer I,J
Local Decimal LSUMIQTY,LSUMIQTYLNK, LSUMVAL, LSUMVAL0
Local Decimal LCOE, LTMPVAL, LTMPVAL0, LCOE0, LCOELNK

If dim(GDIMCST)<=0
    Global Integer GDIMCST
    GDIMCST = GACTMAT+GACTMAC+GACTLAB+2+4     # = dim mat + dim mac + dim lab + sco + invdta + fg mat + fg mac + fg lab + fg sco
Endif
Local Decimal LCUMVAL(GDIMCST+1), LCUMRND(GDIMCST+1), LCUMVAL0, LCUMRND0    # +1 pour IOVECPN
Local Integer LCUMIND
Local Decimal LARRONDI

If func VERIF
    Call ERREUR(GMESSAGE) From GESECRAN
    End
Endif

# Issue 79711 - 2012-02-13 by CCC
GPOINT = "AVINITCST"
Gosub ENTREE From EXEFNC

# Issue 101060 - 2014-06-26 by CCC : Choose when calculate overheads in AVINITCST (always by default)
If dim([M:CTP]CLCOVEFLG)<=0 | find([M:CTP]CLCOVEFLG,0,[M:CTP]NIV)
    # On efface les FG avant l'initialisation par les matières et avant le calcul
    Call EFFZOCST(20)
    Call EFFZOCST(35)
    Call EFFZOCST(45)
    Call EFFZOCST(55)
Endif

Call INITCST
If dim([M:CTP]CLCOVEFLG)<=0 | find([M:CTP]CLCOVEFLG,0,[M:CTP]NIV)
    Call INITCSTOVE
Endif

LARRONDI = 0
GPOINT = "INITCST"
Gosub ENTREE From EXEFNC

If GTEST
    Gosub DEBUG_CST
Endif

If LARRONDI>0
    Call ARRCST(LARRONDI)
Endif

LSUMIQTY = func SUMQTY("P", 0)    # Qté totale des produits (sous-produits exclus)

$CPN
#--------------- Composants --------------------#
If [M:CTP]NIV=1
    For I=0 To [M:CST]NBMAT-1
        If [M:CST]MLNK(I) = 0
            # Répartition du coût matière sur tous les produits
        Else
            # Ajout du coût matière sur le produit lié    (==> un seul produit lié, et les /s-prod sont après le produit)
            LSUMIQTYLNK = func SUMQTY("P", [M:CST]MLNK(I))    # Qté totale des produits pour 1 lien donné
        Endif
        LSUMVAL = func SUMMAT("M",I)-[M:CST]MINVDTA(I)
        LSUMVAL0 = func SUMMAT("M0",I)-([M:CST]MATFLG(I)=2)*[M:CST]MINVDTA(I)
        Raz LCUMVAL, LCUMRND, LCUMVAL0, LCUMRND0
        For J=0 To [M:CST]NBITM-1
            Raz LCUMIND
            If  [M:CST]ITMTYP(J)<>2
&             & ([M:CST]MLNK(I) = 0 | [M:CST]MLNK(I)=[M:CST]ILNK(J))
                If [M:CST]MLNK(I) = 0
                    If LSUMIQTY=0
                        LTMPVAL  = LSUMVAL
                        LTMPVAL0 = LSUMVAL0
                    Else
                        LTMPVAL  = LSUMVAL*[M:CST]IQTYSTU(J)/LSUMIQTY
                        LTMPVAL0 = LSUMVAL0*[M:CST]IQTYSTU(J)/LSUMIQTY
                    Endif
                Else
                    If LSUMIQTYLNK=0
                        LTMPVAL  = LSUMVAL
                        LTMPVAL0 = LSUMVAL0
                    Else
                        LTMPVAL  = LSUMVAL*[M:CST]IQTYSTU(J)/LSUMIQTYLNK
                        LTMPVAL0 = LSUMVAL0*[M:CST]IQTYSTU(J)/LSUMIQTYLNK
                    Endif
                Endif
                If LARRONDI>0
                    Gosub ARR_VAL
                    LCUMVAL0 += LTMPVAL0
                    LTMPVAL0 = arr(LCUMVAL0-LCUMRND0,LARRONDI)
                    LCUMRND0 += LTMPVAL0
                Endif
                If [M:CST]MQTYCOD(I)=2
                    If [M:CST]SCOFLG(I)=3
                        [M:CST]IFSMATCST(J*GACTMAT+[M:CST]MBRDCOD(I)-1) += LTMPVAL
                    Else
                        [M:CST]IFMATCST(J*GACTMAT+[M:CST]MBRDCOD(I)-1) += LTMPVAL
                    Endif
                    [M:CST]IFMATLEV0(J*GACTMAT+[M:CST]MBRDCOD(I)-1) += LTMPVAL0
                Else
                    If [M:CST]SCOFLG(I)=3
                        [M:CST]ISMATCST(J*GACTMAT+[M:CST]MBRDCOD(I)-1) += LTMPVAL
                    Else
                        [M:CST]IMATCST(J*GACTMAT+[M:CST]MBRDCOD(I)-1) += LTMPVAL
                    Endif
                    [M:CST]IMATLEV0(J*GACTMAT+[M:CST]MBRDCOD(I)-1) += LTMPVAL0
                Endif

                If LSUMIQTY=0
                    [M:CST]IOVECPN(J)+= ([M:CST]MOVEMATCST(I)+[M:CST]MOVEMACCST(I)+[M:CST]MOVELABCST(I)+[M:CST]MOVESCOCST(I))
                Else
                    LTMPVAL = ([M:CST]MOVEMATCST(I)+[M:CST]MOVEMACCST(I)+[M:CST]MOVELABCST(I)+[M:CST]MOVESCOCST(I))*[M:CST]IQTYSTU(J)/LSUMIQTY
                    If LARRONDI>0 : Gosub ARR_VAL : Endif
                    [M:CST]IOVECPN(J)+= LTMPVAL
                Endif
            Endif
        Next
    Next
Else
    For I=0 To [M:CST]NBMAT-1
        If [M:CST]MLNK(I) <> 0
            LSUMIQTYLNK = func SUMQTY("P", [M:CST]MLNK(I))    # Qté totale des produits pour 1 lien donné
        Endif
        Raz LCUMVAL, LCUMRND, LCUMVAL0, LCUMRND0
        For J=0 To [M:CST]NBITM-1
            Raz LCUMIND
            If [M:CST]ITMTYP(J)<>2
&            & ([M:CST]MLNK(I)=0 | [M:CST]MLNK(I)=[M:CST]ILNK(J))
                If [M:CST]MLNK(I) = 0
                    If LSUMIQTY=0
                        LCOE = 1
                    Else
                        LCOE = [M:CST]IQTYSTU(J) / LSUMIQTY
                    Endif
                Else
                    If LSUMIQTYLNK=0
                        LCOE = 1
                    Else
                        LCOE = [M:CST]IQTYSTU(J) / LSUMIQTYLNK
                    Endif
                Endif
                If [M:CST]MQTYCOD(I)=2
                    If [M:CST]SCOFLG(I)=3
                        # Il n'y a que du coût matière sur une matière fournie par sous-traitant
                        For K=0 To GACTMAT-1
                            LTMPVAL = [M:CST]MMATCST(I*GACTMAT+K) * LCOE
                            If LARRONDI>0 : Gosub ARR_VAL : Endif
                            [M:CST]IFSMATCST(J*GACTMAT+K) += LTMPVAL
                        Next
                    Else
                        For K=0 To GACTMAT-1
                            LTMPVAL = [M:CST]MMATCST(I*GACTMAT+K) * LCOE
                            If LARRONDI>0 : Gosub ARR_VAL : Endif
                            [M:CST]IFMATCST(J*GACTMAT+K) += LTMPVAL
                        Next

                        For K=0 To GACTMAC-1
                            LTMPVAL = [M:CST]MMACCST(I*GACTMAC+K) * LCOE
                            If LARRONDI>0 : Gosub ARR_VAL : Endif
                            [M:CST]IFMACCST(J*GACTMAC+K) += LTMPVAL
                        Next

                        For K=0 To GACTLAB-1
                            LTMPVAL = [M:CST]MLABCST(I*GACTLAB+K) * LCOE
                            If LARRONDI>0 : Gosub ARR_VAL : Endif
                            [M:CST]IFLABCST(J*GACTLAB+K) += LTMPVAL
                        Next

                        LTMPVAL = [M:CST]MSCOCST(I)  * LCOE
                        If LARRONDI>0 : Gosub ARR_VAL : Endif
                        [M:CST]IFSCOCST(J)  += LTMPVAL

                        # Issue 79521 - 2012-03-26 by CCC : La part élément de facturation est mise dans la part matière pour les coûts standards
                        LTMPVAL = [M:CST]MINVDTA(I)  * LCOE
                        If LARRONDI>0 : Gosub ARR_VAL : Endif
                        If [M:CTP]TYPCST=1
                            [M:CST]IFMATCST(J*GACTMAT+[M:CST]MBRDCOD(I)-1) += LTMPVAL
                        Else
                            [M:CST]IFINVDTA(J)  += LTMPVAL
                        Endif

                        LTMPVAL = [M:CST]MOVEMATCST(I) * LCOE
                        If LARRONDI>0 : Gosub ARR_VAL : Endif
                        [M:CST]IFOMATCST(J)  += LTMPVAL
                        LTMPVAL = [M:CST]MOVEMACCST(I) * LCOE
                        If LARRONDI>0 : Gosub ARR_VAL : Endif
                        [M:CST]IFOMACCST(J)  += LTMPVAL
                        LTMPVAL = [M:CST]MOVELABCST(I) * LCOE
                        If LARRONDI>0 : Gosub ARR_VAL : Endif
                        [M:CST]IFOLABCST(J)  += LTMPVAL
                        LTMPVAL = [M:CST]MOVESCOCST(I) * LCOE
                        If LARRONDI>0 : Gosub ARR_VAL : Endif
                        [M:CST]IFOSCOCST(J)  += LTMPVAL
                    Endif
                Else
                    If [M:CST]SCOFLG(I)=3
                        # Il n'y a que du coût matière sur une matière fournie par sous-traitant
                        For K=0 To GACTMAT-1
                            LTMPVAL = [M:CST]MMATCST(I*GACTMAT+K) * LCOE
                            If LARRONDI>0 : Gosub ARR_VAL : Endif
                            [M:CST]ISMATCST(J*GACTMAT+K) += LTMPVAL
                        Next
                    Else
                        For K=0 To GACTMAT-1
                            LTMPVAL = [M:CST]MMATCST(I*GACTMAT+K) * LCOE
                            If LARRONDI>0 : Gosub ARR_VAL : Endif
                            [M:CST]IMATCST(J*GACTMAT+K) += LTMPVAL
                        Next

                        For K=0 To GACTMAC-1
                            LTMPVAL = [M:CST]MMACCST(I*GACTMAC+K) * LCOE
                            If LARRONDI>0 : Gosub ARR_VAL : Endif
                            [M:CST]IMACCST(J*GACTMAC+K) += LTMPVAL
                        Next

                        For K=0 To GACTLAB-1
                            LTMPVAL = [M:CST]MLABCST(I*GACTLAB+K) * LCOE
                            If LARRONDI>0 : Gosub ARR_VAL : Endif
                            [M:CST]ILABCST(J*GACTLAB+K) += LTMPVAL
                        Next

                        LTMPVAL = [M:CST]MSCOCST(I)  * LCOE
                        If LARRONDI>0 : Gosub ARR_VAL : Endif
                        [M:CST]ISCOCST(J)  += LTMPVAL

                        # Issue 79521 - 2012-03-26 by CCC : La part élément de facturation est mise dans la part matière pour les coûts standards
                        LTMPVAL = [M:CST]MINVDTA(I)  * LCOE
                        If LARRONDI>0 : Gosub ARR_VAL : Endif
                        If [M:CTP]TYPCST=1
                            [M:CST]IMATCST(J*GACTMAT+[M:CST]MBRDCOD(I)-1) += LTMPVAL
                        Else
                            [M:CST]IINVDTA(J)  += LTMPVAL
                        Endif

                        LTMPVAL = [M:CST]MOVEMATCST(I) * LCOE
                        If LARRONDI>0 : Gosub ARR_VAL : Endif
                        [M:CST]IOVEMATCST(J)  += LTMPVAL
                        LTMPVAL = [M:CST]MOVEMACCST(I) * LCOE
                        If LARRONDI>0 : Gosub ARR_VAL : Endif
                        [M:CST]IOVEMACCST(J)  += LTMPVAL
                        LTMPVAL = [M:CST]MOVELABCST(I) * LCOE
                        If LARRONDI>0 : Gosub ARR_VAL : Endif
                        [M:CST]IOVELABCST(J)  += LTMPVAL
                        LTMPVAL = [M:CST]MOVESCOCST(I) * LCOE
                        If LARRONDI>0 : Gosub ARR_VAL : Endif
                        [M:CST]IOVESCOCST(J)  += LTMPVAL
                    Endif
                Endif
                LTMPVAL = ([M:CST]MOVEMATCST(I)+[M:CST]MOVEMACCST(I)+[M:CST]MOVELABCST(I)+[M:CST]MOVESCOCST(I))*LCOE
                If LARRONDI>0 : Gosub ARR_VAL : Endif
                [M:CST]IOVECPN(J)+= LTMPVAL
            Endif
        Next
    Next
Endif

$WST
#------------ Opérations -----------------#
    For I=0 To [M:CST]NBWST-1
        Raz LCUMVAL, LCUMRND
        If [M:CST]WLNK(I) = 0
            For J=0 To [M:CST]NBITM-1
                Raz LCUMIND
                If [M:CST]ITMTYP(J)<>2
                    If LSUMIQTY=0
                        LCOE = 1
                    Else
                        LCOE = [M:CST]IQTYSTU(J) / LSUMIQTY
                    Endif
                    # Répartition du coût opé sur tous les produits
                    LTMPVAL = ([M:CST]WSETAMT(I)+[M:CST]WOPEAMT(I)*([M:CST]WCSTTYP(I)=2)) * LCOE
                    If LARRONDI>0 : Gosub ARR_VAL : Endif
                    Case [M:CST]WSTTYP(I)
                        When 1:
                            [M:CST]IFMACCST(J*GACTMAC+[M:CST]WBRDCOD(I)-1) += LTMPVAL
                        When 2:
                            [M:CST]IFLABCST(J*GACTLAB+[M:CST]WBRDCOD(I)-1) += LTMPVAL
                    Endcase
                    LTMPVAL = ([M:CST]WOPEAMT(I)*([M:CST]WCSTTYP(I)<>2)) * LCOE
                    If LARRONDI>0 : Gosub ARR_VAL : Endif
                    Case [M:CST]WSTTYP(I)
                        When 1:
                            [M:CST]IMACCST(J*GACTMAC+[M:CST]WBRDCOD(I)-1) += LTMPVAL
                        When 2:
                            [M:CST]ILABCST(J*GACTLAB+[M:CST]WBRDCOD(I)-1) += LTMPVAL
                    Endcase
                Endif
            Next
        Else
            # Ajout du coût MA ou MO sur le produit lié    (==> un seul produit lié et les /s-prod ne sont pas forcément après le produit)
            LSUMIQTYLNK = func SUMQTY("P", [M:CST]WLNK(I))    # Qté totale des produits pour 1 lien donné
            For J=0 To [M:CST]NBITM-1
                Raz LCUMIND
                If [M:CST]ITMTYP(J)<>2 & [M:CST]ILNK(J)=[M:CST]WLNK(I)
                    If LSUMIQTYLNK=0
                        LCOE = 1
                    Else
                        LCOE = [M:CST]IQTYSTU(J) / LSUMIQTYLNK
                    Endif
                    LTMPVAL = ([M:CST]WSETAMT(I)+[M:CST]WOPEAMT(I)*([M:CST]WCSTTYP(I)=2)) * LCOE
                    If LARRONDI>0 : Gosub ARR_VAL : Endif
                    Case [M:CST]WSTTYP(I)
                        When 1:
                            [M:CST]IFMACCST(J*GACTMAC+[M:CST]WBRDCOD(I)-1) += LTMPVAL
                        When 2:
                            [M:CST]IFLABCST(J*GACTLAB+[M:CST]WBRDCOD(I)-1) += LTMPVAL
                    Endcase
                    LTMPVAL = ([M:CST]WOPEAMT(I)*([M:CST]WCSTTYP(I)<>2)) * LCOE
                    If LARRONDI>0 : Gosub ARR_VAL : Endif
                    Case [M:CST]WSTTYP(I)
                        When 1:
                            [M:CST]IMACCST(J*GACTMAC+[M:CST]WBRDCOD(I)-1) += LTMPVAL
                        When 2:
                            [M:CST]ILABCST(J*GACTLAB+[M:CST]WBRDCOD(I)-1) += LTMPVAL
                    Endcase
                Endif
            Next
        Endif
    Next

$SCO
#----------- Sous-traitance ----------------#
    For I=0 To [M:CST]NBSCO-1
        Raz LCUMVAL, LCUMRND
        LSUMIQTYLNK = func SUMQTY("P", [M:CST]SLNK(I))    # Qté totale des produits pour 1 lien donné
        # Répartition du coût sous-traitance sur les produits
        For J=0 To [M:CST]NBITM-1
            Raz LCUMIND
            If [M:CST]ITMTYP(J)<>2 & ([M:CST]ILNK(J)=[M:CST]SLNK(I) | [M:CST]SLNK(I)=0)
                If [M:CST]SLNK(I) = 0
                    If LSUMIQTY=0
                        LCOE = 1
                    Else
                        LCOE = [M:CST]IQTYSTU(J) / LSUMIQTY
                    Endif
                Else
                    If LSUMIQTYLNK=0
                        LCOE = 1
                    Else
                        LCOE = [M:CST]IQTYSTU(J) / LSUMIQTYLNK
                    Endif
                Endif
                LTMPVAL = ([M:CST]SOPEAMT(I) + [M:CST]SITMAMT(I)) * LCOE
                If LARRONDI>0 : Gosub ARR_VAL : Endif
                [M:CST]ISCOCST(J)  += LTMPVAL
                LTMPVAL = [M:CST]SSETAMT(I) * LCOE
                If LARRONDI>0 : Gosub ARR_VAL : Endif
                [M:CST]IFSCOCST(J) += LTMPVAL
            Endif
        Next
    Next
$SPRO
#----------- Sous-produits -------------------#
If [M:CTP]NIV=1
    For I=0 To [M:CST]NBITM-1
        If [M:CST]ITMTYP(I)=2
            Raz LCUMVAL, LCUMRND
            If [M:CST]ILNK(I) = 0
            Else
                LSUMIQTYLNK = func SUMQTY("P", [M:CST]ILNK(I))    # Qté totale des produits pour 1 lien donné
            Endif
            # Soustraction de la valeur des sous-produits sur tous les produits
            For J=0 To [M:CST]NBITM-1
                If [M:CST]ITMTYP(J)<>2 & ([M:CST]ILNK(I)=0 | [M:CST]ILNK(I)=[M:CST]ILNK(J))
                    Raz LCUMIND
                    If [M:CST]ILNK(I) = 0
                        If LSUMIQTY=0
                            LTMPVAL  = func SUMMAT("SP",I)
                            LTMPVAL0 = func SUMMAT("SP0",I)
                        Else
                            LTMPVAL  = func SUMMAT("SP",I)*[M:CST]IQTYSTU(J)/LSUMIQTY
                            LTMPVAL0 = func SUMMAT("SP0",I)*[M:CST]IQTYSTU(J)/LSUMIQTY
                        Endif
                    Else
                        If LSUMIQTYLNK=0
                            LTMPVAL  = func SUMMAT("SP",I)
                            LTMPVAL0 = func SUMMAT("SP0",I)
                        Else
                            LTMPVAL  = func SUMMAT("SP",I)*[M:CST]IQTYSTU(J)/LSUMIQTYLNK
                            LTMPVAL0 = func SUMMAT("SP0",I)*[M:CST]IQTYSTU(J)/LSUMIQTYLNK
                        Endif
                    Endif
                    If LARRONDI>0
                        Gosub ARR_VAL
                        LCUMVAL0 += LTMPVAL0
                        LTMPVAL0 = arr(LCUMVAL0-LCUMRND0,LARRONDI)
                        LCUMRND0 += LTMPVAL0
                    Endif
                    If [M:CST]IQTYCOD(I)=2
                        [M:CST]IFMATCST(J*GACTMAT+[M:CST]IBRDCOD(I)-1) -= LTMPVAL
                        [M:CST]IFMATLEV0(J*GACTMAT+[M:CST]IBRDCOD(I)-1) -= LTMPVAL0
                    Else
                        [M:CST]IMATCST(J*GACTMAT+[M:CST]IBRDCOD(I)-1) -= LTMPVAL
                        [M:CST]IMATLEV0(J*GACTMAT+[M:CST]IBRDCOD(I)-1) -= LTMPVAL0
                    Endif
                Endif
            Next
        Endif
    Next
Else
    For I=0 To [M:CST]NBITM-1
        Raz LCUMVAL, LCUMRND
        If [M:CST]ITMTYP(I)=2
            If [M:CST]ILNK(I) = 0
            Else
                LSUMIQTYLNK = func SUMQTY("P", [M:CST]ILNK(I))    # Qté totale des produits pour 1 lien donné
            Endif
            For J=0 To [M:CST]NBITM-1
                If [M:CST]ITMTYP(J)<>2 & ([M:CST]ILNK(I) = 0 | [M:CST]ILNK(I)=[M:CST]ILNK(J))
                    Raz LCUMIND
                    If [M:CST]ILNK(I) = 0
                        If LSUMIQTY=0
                            LCOE = 1
                        Else
                            LCOE = [M:CST]IQTYSTU(J) / LSUMIQTY
                        Endif
                    Else
                        If LSUMIQTYLNK=0
                            LCOE = 1
                        Else
                            LCOE = [M:CST]IQTYSTU(J) / LSUMIQTYLNK
                        Endif
                    Endif
                    For K=0 To GACTMAT-1
                        LTMPVAL = [M:CST]IMATCST(I*GACTMAT+K) * LCOE
                        If LARRONDI>0 : Gosub ARR_VAL : Endif
                        [M:CST]IMATCST(J*GACTMAT+K) -= ([M:CST]IQTYCOD(I)<>2) * LTMPVAL
                        [M:CST]IFMATCST(J*GACTMAT+K) -= ([M:CST]IQTYCOD(I)=2) * LTMPVAL
                    Next

                    For K=0 To GACTMAC-1
                        LTMPVAL = [M:CST]IMACCST(I*GACTMAC+K) * LCOE
                        If LARRONDI>0 : Gosub ARR_VAL : Endif
                        [M:CST]IMACCST(J*GACTMAC+K) -= ([M:CST]IQTYCOD(I)<>2) * LTMPVAL
                        [M:CST]IFMACCST(J*GACTMAC+K) -= ([M:CST]IQTYCOD(I)=2) * LTMPVAL
                    Next

                    For K=0 To GACTLAB-1
                        LTMPVAL = [M:CST]ILABCST(I*GACTLAB+K) * LCOE
                        If LARRONDI>0 : Gosub ARR_VAL : Endif
                        [M:CST]ILABCST(J*GACTLAB+K) -= ([M:CST]IQTYCOD(I)<>2) * LTMPVAL
                        [M:CST]IFLABCST(J*GACTLAB+K) -= ([M:CST]IQTYCOD(I)=2) * LTMPVAL
                    Next

                    LTMPVAL = [M:CST]ISCOCST(I)  * LCOE
                    If LARRONDI>0 : Gosub ARR_VAL : Endif
                    [M:CST]ISCOCST(J)  -= ([M:CST]IQTYCOD(I)<>2) * LTMPVAL
                    [M:CST]IFSCOCST(J)  -= ([M:CST]IQTYCOD(I)=2) * LTMPVAL

                    LTMPVAL = [M:CST]IINVDTA(I)  * LCOE
                    If LARRONDI>0 : Gosub ARR_VAL : Endif
                    [M:CST]IINVDTA(J)  -= ([M:CST]IQTYCOD(I)<>2) * LTMPVAL
                    [M:CST]IFINVDTA(J)  -= ([M:CST]IQTYCOD(I)=2) * LTMPVAL

                    LTMPVAL = [M:CST]IOVEMATCST(I) * LCOE
                    If LARRONDI>0 : Gosub ARR_VAL : Endif
                    [M:CST]IOVEMATCST(J) -= ([M:CST]IQTYCOD(I)<>2) * LTMPVAL
                    [M:CST]IFOMATCST(J)  -= ([M:CST]IQTYCOD(I)=2) * LTMPVAL
                    LTMPVAL = [M:CST]IOVEMACCST(I) * LCOE
                    If LARRONDI>0 : Gosub ARR_VAL : Endif
                    [M:CST]IOVEMACCST(J) -= ([M:CST]IQTYCOD(I)<>2) * LTMPVAL
                    [M:CST]IFOMACCST(J)  -= ([M:CST]IQTYCOD(I)=2) * LTMPVAL
                    LTMPVAL = [M:CST]IOVELABCST(I) * LCOE
                    If LARRONDI>0 : Gosub ARR_VAL : Endif
                    [M:CST]IOVELABCST(J) -= ([M:CST]IQTYCOD(I)<>2) * LTMPVAL
                    [M:CST]IFOLABCST(J)  -= ([M:CST]IQTYCOD(I)=2) * LTMPVAL
                    LTMPVAL = [M:CST]IOVESCOCST(I) * LCOE
                    If LARRONDI>0 : Gosub ARR_VAL : Endif
                    [M:CST]IOVESCOCST(J) -= ([M:CST]IQTYCOD(I)<>2) * LTMPVAL
                    [M:CST]IFOSCOCST(J)  -= ([M:CST]IQTYCOD(I)=2) * LTMPVAL
                Endif
            Next
        Endif
    Next
Endif

$INVDTA
#------------------------ Eléments de facturation -----------------------#
For I=0 To [M:CST]NBINVDTA-1
    Raz LCUMVAL, LCUMRND
    # Répartition du coût élément de facture sur les produits
    If [M:CST]DLNK(I) = 0
    Else
        LSUMIQTYLNK = func SUMQTY("P", [M:CST]DLNK(I))    # Qté totale des produits pour 1 lien donné
    Endif
    For J=0 To [M:CST]NBITM-1
        If [M:CST]ITMTYP(J)<>2 & ( [M:CST]DLNK(I) = 0 | [M:CST]ILNK(J)=[M:CST]DLNK(I))
            Raz LCUMIND
            # Issue 85203 - 2012-11-15 by CCC : calcul du coef dans la boucle
            If [M:CST]DLNK(I) = 0
                If LSUMIQTY=0
                    LCOE = 1
                Else
                    LCOE = [M:CST]IQTYSTU(J) / LSUMIQTY
                Endif
            Else
                If LSUMIQTYLNK=0
                    LCOE = 1
                Else
                    LCOE = [M:CST]IQTYSTU(J) / LSUMIQTYLNK
                Endif
            Endif
            LTMPVAL = [M:CST]DAMT(I) * LCOE
            If LARRONDI>0 : Gosub ARR_VAL : Endif
            [M:CST]IINVDTA(J)  += LTMPVAL
        Endif
    Next
Next

$OVE
If dim([M:CTP]CLCOVEFLG)<=0 | find([M:CTP]CLCOVEFLG,0,[M:CTP]NIV)
    Call CLCOVEITM(1)    # FG produits
Endif

If LARRONDI>0
    Call ARROVEITM(LARRONDI)
Endif

#--- ITM OVE ---#
For I=0 To [M:CST]NBFGITM-1
    If [M:CST]IOLNK(I) = 0
    Else
        LSUMIQTYLNK = func SUMQTY("P", [M:CST]IOLNK(I))    # Qté totale des produits pour 1 lien donné
    Endif
    Raz LCUMVAL, LCUMRND
    For J=0 To [M:CST]NBITM-1
        If [M:CST]ITMTYP(J)<>2 & ( [M:CST]IOLNK(I) = 0 | [M:CST]ILNK(J)=[M:CST]IOLNK(I))
            Raz LCUMIND
            If [M:CST]IOLNK(I) = 0
                If LSUMIQTY=0
                    LCOE = 1
                Else
                    LCOE = [M:CST]IQTYSTU(J) / LSUMIQTY
                Endif
            Else
                If LSUMIQTYLNK=0
                    LCOE = 1
                Else
                    LCOE = [M:CST]IQTYSTU(J) / LSUMIQTYLNK
                Endif
            Endif
            LTMPVAL = ([M:CST]IFXDAMT(I)+[M:CST]IVARAMT(I)) * LCOE
            If LARRONDI>0 : Gosub ARR_VAL : Endif
            Case [M:CST]IOVETYP(I)
                When 2 : [M:CST]IOVEMATCST(J)  += LTMPVAL
                When 3 : [M:CST]IOVEMACCST(J)  += LTMPVAL
                When 4 : [M:CST]IOVELABCST(J)  += LTMPVAL
                When 5 : [M:CST]IOVESCOCST(J)  += LTMPVAL
            Endcase
        Endif
    Next
Next

$ADD_INVDTA_NIV1
If [M:CTP]NIV=1
    For I=0 To [M:CST]NBMAT-1
        If [M:CST]MLNK(I) = 0
            # Répartition du coût matière sur tous les produits
        Else
            # Ajout du coût matière sur le produit lié    (==> un seul produit lié, et les /s-prod sont après le produit)
            LSUMIQTYLNK = func SUMQTY("P", [M:CST]MLNK(I))    # Qté totale des produits pour 1 lien donné
        Endif
        LSUMVAL = [M:CST]MINVDTA(I)
        LSUMVAL0 = ([M:CST]MATFLG(I)=2)*[M:CST]MINVDTA(I)
        Raz LCUMVAL, LCUMRND, LCUMVAL0, LCUMRND0
        For J=0 To [M:CST]NBITM-1
            Raz LCUMIND
            If  [M:CST]ITMTYP(J)<>2
&             & ([M:CST]MLNK(I) = 0 | [M:CST]MLNK(I)=[M:CST]ILNK(J))
                If [M:CST]MLNK(I) = 0
                    If LSUMIQTY=0
                        LTMPVAL  = LSUMVAL
                        LTMPVAL0 = LSUMVAL0
                    Else
                        LTMPVAL  = LSUMVAL*[M:CST]IQTYSTU(J)/LSUMIQTY
                        LTMPVAL0 = LSUMVAL0*[M:CST]IQTYSTU(J)/LSUMIQTY
                    Endif
                Else
                    If LSUMIQTYLNK=0
                        LTMPVAL  = LSUMVAL
                        LTMPVAL0 = LSUMVAL0
                    Else
                        LTMPVAL  = LSUMVAL*[M:CST]IQTYSTU(J)/LSUMIQTYLNK
                        LTMPVAL0 = LSUMVAL0*[M:CST]IQTYSTU(J)/LSUMIQTYLNK
                    Endif
                Endif
                If LARRONDI>0
                    Gosub ARR_VAL
                    LCUMVAL0 += LTMPVAL0
                    LTMPVAL0 = arr(LCUMVAL0-LCUMRND0,LARRONDI)
                    LCUMRND0 += LTMPVAL0
                Endif
                If [M:CST]MQTYCOD(I)=2
                    If [M:CST]SCOFLG(I)=3
                        [M:CST]IFSMATCST(J*GACTMAT+[M:CST]MBRDCOD(I)-1) += LTMPVAL
                    Else
                        [M:CST]IFMATCST(J*GACTMAT+[M:CST]MBRDCOD(I)-1) += LTMPVAL
                    Endif
                    [M:CST]IFMATLEV0(J*GACTMAT+[M:CST]MBRDCOD(I)-1) += LTMPVAL0
                Else
                    If [M:CST]SCOFLG(I)=3
                        [M:CST]ISMATCST(J*GACTMAT+[M:CST]MBRDCOD(I)-1) += LTMPVAL
                    Else
                        [M:CST]IMATCST(J*GACTMAT+[M:CST]MBRDCOD(I)-1) += LTMPVAL
                    Endif
                    [M:CST]IMATLEV0(J*GACTMAT+[M:CST]MBRDCOD(I)-1) += LTMPVAL0
                Endif

            Endif
        Next
    Next
Endif


#--- MAT OVE ---#
For I=0 To [M:CST]NBFGMAT-1
  If [M:CST]CLCLEV(I)=2
    If [M:CST]MOLNK(I) = 0
    Else
        LSUMIQTYLNK = func SUMQTY("P", [M:CST]MOLNK(I))    # Qté totale des produits pour 1 lien donné
    Endif
    Raz LCUMVAL, LCUMRND
    For J=0 To [M:CST]NBITM-1
        If [M:CST]ITMTYP(J)<>2 & ( [M:CST]MOLNK(I) = 0 | [M:CST]ILNK(J)=[M:CST]MOLNK(I))
            Raz LCUMIND
            If [M:CST]MOLNK(I) = 0
                If LSUMIQTY=0
                    LCOE = 1
                Else
                    LCOE = [M:CST]IQTYSTU(J) / LSUMIQTY
                Endif
            Else
                If LSUMIQTYLNK=0
                    LCOE = 1
                Else
                    LCOE = [M:CST]IQTYSTU(J) / LSUMIQTYLNK
                Endif
            Endif
            LTMPVAL = ([M:CST]MFXDAMT(I)+[M:CST]MVARAMT(I)) * LCOE
            If LARRONDI>0 : Gosub ARR_VAL : Endif
            Case [M:CST]MOVETYP(I)
                When 2 : [M:CST]IOVEMATCST(J)  += LTMPVAL
                When 3 : [M:CST]IOVEMACCST(J)  += LTMPVAL
                When 4 : [M:CST]IOVELABCST(J)  += LTMPVAL
                When 5 : [M:CST]IOVESCOCST(J)  += LTMPVAL
            Endcase
        Endif
    Next
  Endif
Next


#--- WST OVE ---#
For I=0 To [M:CST]NBFGWST-1
    If [M:CST]WOLNK(I) = 0
    Else
        LSUMIQTYLNK = func SUMQTY("P", [M:CST]WOLNK(I))    # Qté totale des produits pour 1 lien donné
    Endif
    Raz LCUMVAL, LCUMRND
    For J=0 To [M:CST]NBITM-1
        If [M:CST]ITMTYP(J)<>2 & ( [M:CST]WOLNK(I) = 0 | [M:CST]ILNK(J)=[M:CST]WOLNK(I))
            Raz LCUMIND
            If [M:CST]WOLNK(I) = 0
                If LSUMIQTY=0
                    LCOE = 1
                Else
                    LCOE = [M:CST]IQTYSTU(J) / LSUMIQTY
                Endif
            Else
                If LSUMIQTYLNK=0
                    LCOE = 1
                Else
                    LCOE = [M:CST]IQTYSTU(J) / LSUMIQTYLNK
                Endif
            Endif
            LTMPVAL = ([M:CST]WFXDAMT(I)+[M:CST]WVARAMT(I)) * LCOE
            If LARRONDI>0 : Gosub ARR_VAL : Endif
            Case [M:CST]WOVETYP(I)
                When 2 : [M:CST]IOVEMATCST(J)  += LTMPVAL
                When 3 : [M:CST]IOVEMACCST(J)  += LTMPVAL
                When 4 : [M:CST]IOVELABCST(J)  += LTMPVAL
                When 5 : [M:CST]IOVESCOCST(J)  += LTMPVAL
            Endcase
        Endif
    Next
Next

#--- SCO OVE ---#
For I=0 To [M:CST]NBFGSCO-1
    If [M:CST]SOLNK(I) = 0
    Else
        LSUMIQTYLNK = func SUMQTY("P", [M:CST]SOLNK(I))    # Qté totale des produits pour 1 lien donné
    Endif
    Raz LCUMVAL, LCUMRND
    For J=0 To [M:CST]NBITM-1
        If [M:CST]ITMTYP(J)<>2 & ( [M:CST]SOLNK(I) = 0 | [M:CST]ILNK(J)=[M:CST]SOLNK(I))
            Raz LCUMIND
            If [M:CST]SOLNK(I) = 0
                If LSUMIQTY=0
                    LCOE = 1
                Else
                    LCOE = [M:CST]IQTYSTU(J) / LSUMIQTY
                Endif
            Else
                If LSUMIQTYLNK=0
                    LCOE = 1
                Else
                    LCOE = [M:CST]IQTYSTU(J) / LSUMIQTYLNK
                Endif
            Endif
            LTMPVAL = ([M:CST]SFXDAMT(I)+[M:CST]SVARAMT(I)) * LCOE
            If LARRONDI>0 : Gosub ARR_VAL : Endif
            Case [M:CST]SOVETYP(I)
                When 2 : [M:CST]IOVEMATCST(J)  += LTMPVAL
                When 3 : [M:CST]IOVEMACCST(J)  += LTMPVAL
                When 4 : [M:CST]IOVELABCST(J)  += LTMPVAL
                When 5 : [M:CST]IOVESCOCST(J)  += LTMPVAL
            Endcase
        Endif
    Next
Next

For I=0 To [M:CST]NBITM-1
    [M:CST]ICSTTOT(I) = sigma(0,GACTMAT-1,[M:CST]IMATCST(I*GACTMAT+indcum)+[M:CST]IFMATCST(I*GACTMAT+indcum))
&                      +sigma(0,GACTMAT-1,[M:CST]ISMATCST(I*GACTMAT+indcum)+[M:CST]IFSMATCST(I*GACTMAT+indcum))
&                      +sigma(0,GACTMAC-1,[M:CST]IMACCST(I*GACTMAC+indcum)+[M:CST]IFMACCST(I*GACTMAC+indcum))
&                      +sigma(0,GACTLAB-1,[M:CST]ILABCST(I*GACTLAB+indcum)+[M:CST]IFLABCST(I*GACTLAB+indcum))
&                      +[M:CST]ISCOCST(I)+[M:CST]IFSCOCST(I)
&                      +[M:CST]IINVDTA(I)+[M:CST]IFINVDTA(I)
    [M:CST]IOVETOT(I) = [M:CST]IOVEMATCST(I)+[M:CST]IOVEMACCST(I)+[M:CST]IOVELABCST(I)+[M:CST]IOVESCOCST(I)
&                     + [M:CST]IFOMATCST(I)+[M:CST]IFOMACCST(I)+[M:CST]IFOLABCST(I)+[M:CST]IFOSCOCST(I)
Next

# Issue 102821 - 2014-09-26 by CCC
GPOINT = "APCLCCST"
Gosub ENTREE From EXEFNC

End

###############################################
# Calcule tous les FG (mat, mac, lab, sco et /s-produit)
###############################################
Subprog INITCSTOVE

Call CLCOVEMAT
Call CLCOVEITM(2)    # Non: # FG sous-produits : on ne les calcule pas: on conserve la valeur qui a été donnée pour la valo du mouvement
Call CLCOVEWST
Call CLCOVESCO


End

###############################################
# Vérifie que les calculs sont possibles
###############################################
Funprog VERIF
Local Integer LRET, I

#    If func SUMQTY("P", 0)=0    # Qté totale des produits (sous-produits exclus)
#        GMESSAGE = mess(171,197,1)
#        End 1
#    Endif

    #--------- Vérifier que les articles destinations sont bien dans la liste des produits -------#
    LRET = sigma(0,[M:CST]NBMAT-1, (indcum+1)
&                                * (I=0 & ([M:CST]MLNK(indcum)<>0) & !find([M:CST]MLNK(indcum),[M:CST]ILNK) & sigma(I=1,1,1)))
    If LRET
        GMESSAGE = "MLNK("+num$(LRET)+")"
        End 2
    Endif

End 0

##############################################
# Efface les zones à calculer des produits et récupére les valeurs de mat, mac, mo, sco et sp
##############################################
Subprog INITCST
Local Integer I,J
#--------- Initialisation des zones nécessaires ------------#
For I=0 To [M:CST]NBMAT-1
    Read [ITM]ITM0 = [M:CST]MATREF(I)
    [M:CST]MBRDCOD(I)=[F:ITM]BRDCOD
Next

#--------- Récupération des valeurs -------------#
#--- Matières ---#
Call INIVALMAT

#--- Sous-produits ---#
Call INIVALSP

#--- Machine/Main d'oeurvre ---#
Call INIVALWST

#--- Sous-traitance ---#
Call INIVALSCO

#--------- Effacement des zones à calculer -----------#
For I=0 To [M:CST]NBITM-1
    If [M:CST]ITMTYP(I)<>2
        # On n'efface les valeurs que si elles doivent être recalculées (elles sont bien initialisées lors du calcul du coût std des matières)
        If [M:CST]NBMAT<>0 | [M:CST]NBWST<>0 | [M:CST]NBSCO<>0
            For J=0 To GACTMAT-1
                Raz [M:CST]IMATCST(I*GACTMAT+J), [M:CST]ISMATCST(I*GACTMAT+J),[M:CST]IFMATCST(I*GACTMAT+J),[M:CST]IFSMATCST(I*GACTMAT+J)
            Next
            For J=0 To GACTMAC-1
                Raz [M:CST]IMACCST(I*GACTMAC+J),[M:CST]IFMACCST(I*GACTMAC+J)
            Next
            For J=0 To GACTLAB-1
                Raz [M:CST]ILABCST(I*GACTLAB+J),[M:CST]IFLABCST(I*GACTLAB+J)
            Next
            Raz [M:CST]ISCOCST(I)
            Raz [M:CST]IINVDTA(I)
            Raz [M:CST]ICSTTOT(I),[M:CST]IOVETOT(I),[M:CST]IOVECPN(I)
            Raz [M:CST]IFSCOCST(I)
        Endif
        # Par contre les FG sont toujours recalculés
        Raz [M:CST]IOVEMATCST(I),[M:CST]IOVEMACCST(I),[M:CST]IOVELABCST(I),[M:CST]IOVESCOCST(I)
        Raz [M:CST]IFOMATCST(I),[M:CST]IFOMACCST(I),[M:CST]IFOLABCST(I),[M:CST]IFOSCOCST(I)
    Endif
Next
End

##############################################
# Somme des composantes de coût d'une matière
Funprog SUMMAT(PTYP, PLIN)
Value Char    PTYP
Value Integer PLIN

Local Decimal LRES
Local Integer I

Case PTYP
    When "M0":
        If [M:CST]MATFLG(PLIN)=2
            LRES = sigma(I=0,GACTMAT-1,[M:CST]MMATCST(PLIN*GACTMAT+I))
&                + [M:CST]MINVDTA(PLIN)
        Else
            LRES = 0
        Endif
    When "M" :
        LRES = sigma(I=0,GACTMAT-1,[M:CST]MMATCST(PLIN*GACTMAT+I))
&            + sigma(I=0,GACTMAC-1,[M:CST]MMACCST(PLIN*GACTMAC+I))
&            + sigma(I=0,GACTLAB-1,[M:CST]MLABCST(PLIN*GACTLAB+I))
&            + [M:CST]MSCOCST(PLIN)
&            + [M:CST]MINVDTA(PLIN)
&            + [M:CST]MOVEMATCST(PLIN)+[M:CST]MOVEMACCST(PLIN)+[M:CST]MOVELABCST(PLIN)+[M:CST]MOVESCOCST(PLIN)
    When "SP0":
        If [M:CST]IMATFLG(PLIN)=2
            LRES = sigma(I=0,GACTMAT-1,[M:CST]IMATCST(PLIN*GACTMAT+I))
        Else
            LRES = 0
        Endif
    When "SP" :
        LRES = sigma(I=0,GACTMAT-1,[M:CST]IMATCST(PLIN*GACTMAT+I))
&            + sigma(I=0,GACTMAC-1,[M:CST]IMACCST(PLIN*GACTMAC+I))
&            + sigma(I=0,GACTLAB-1,[M:CST]ILABCST(PLIN*GACTLAB+I))
&            + [M:CST]ISCOCST(PLIN)
&            + [M:CST]IINVDTA(PLIN)
&            + [M:CST]IOVEMATCST(PLIN)+[M:CST]IOVEMACCST(PLIN)+[M:CST]IOVELABCST(PLIN)+[M:CST]IOVESCOCST(PLIN)
Endcase

End LRES

##############################################
# Copie les valeurs du masque SDP dans une ligne de CST
##############################################
# Paramètres E : PTYP = 'M' -> Matière, 'I'->Produit
#                PIND = indice dans le tablkeau des matières ou produits
#                PADD = 0:écrase les valeurs de CST, 1:ajoute aux valeurs de CST
#                PCOE = coefficient CST=SDP*PCOE
##############################################
Subprog COPSDP2CST(PTYP, PIND, PADD, PCOE)
Value Char    PTYP
Value Integer PIND
Value Integer PADD
Value Decimal PCOE

Local Integer I

For I=0 To GACTMAT-1
    Assign "[M:CST]"+PTYP+"MATCST(PIND*GACTMAT+I)" With PADD*evalue("[M:CST]"+PTYP+"MATCST(PIND*GACTMAT+I)") + [M:SDP]MATCST(I) * PCOE
Next
For I=0 To GACTMAC-1
    Assign "[M:CST]"+PTYP+"MACCST(PIND*GACTMAC+I)" With PADD*evalue("[M:CST]"+PTYP+"MACCST(PIND*GACTMAC+I)") + [M:SDP]MACCST(I) * PCOE
Next
For I=0 To GACTLAB-1
    Assign "[M:CST]"+PTYP+"LABCST(PIND*GACTLAB+I)" With PADD*evalue("[M:CST]"+PTYP+"LABCST(PIND*GACTLAB+I)") + [M:SDP]LABCST(I) * PCOE
Next
Assign "[M:CST]"+PTYP+"SCOCST(PIND)" With PADD*evalue("[M:CST]"+PTYP+"SCOCST(PIND)") + [M:SDP]SCOTOT * PCOE
Assign "[M:CST]"+PTYP+"INVDTA(PIND)" With PADD*evalue("[M:CST]"+PTYP+"INVDTA(PIND)") + [M:SDP]INVDTACST * PCOE

Assign "[M:CST]"+PTYP+"OVEMATCST(PIND)" With PADD*evalue("[M:CST]"+PTYP+"OVEMATCST(PIND)") + [M:SDP]OVEMATCST * PCOE
Assign "[M:CST]"+PTYP+"OVEMACCST(PIND)" With PADD*evalue("[M:CST]"+PTYP+"OVEMACCST(PIND)") + [M:SDP]OVEMACCST * PCOE
Assign "[M:CST]"+PTYP+"OVELABCST(PIND)" With PADD*evalue("[M:CST]"+PTYP+"OVELABCST(PIND)") + [M:SDP]OVELABCST * PCOE
Assign "[M:CST]"+PTYP+"OVESCOCST(PIND)" With PADD*evalue("[M:CST]"+PTYP+"OVESCOCST(PIND)") + [M:SDP]OVESCOCST * PCOE

End


##############################################
# Renvoie la quantité de produits, matières ou sous-produits
##############################################
# Paramètres E : PTYP = "M" --> Matières
#                      "SP"--> Sous-produits
#                      "P" --> Produits
#                PLNK = N° de lien (si =0 => qté totale sans distinction de lien)
##############################################
Funprog SUMQTY(PTYP,PLNK)
Value Char    PTYP
Value Integer PLNK

Local Integer I
Local Decimal LQTY

Case PTYP
    When "M" :
        LQTY = sigma(I=0,[M:CST]NBMAT-1,(PLNK=0 | PLNK=[M:CST]MLNK(I))*[M:CST]MQTYSTU(I))
    When "SP" :
        LQTY = sigma(I=0,[M:CST]NBITM-1,(PLNK=0 | PLNK=[M:CST]ILNK(I))*[M:CST]IQTYSTU(I)*([M:CST]ITMTYP(I)=2))
    When "P" :
        LQTY = sigma(I=0,[M:CST]NBITM-1,(PLNK=0 | PLNK=[M:CST]ILNK(I))*[M:CST]IQTYSTU(I)*([M:CST]ITMTYP(I)<>2))
Endcase

End LQTY

##############################################
# Renvoie la somme des FG pour une ligne de mat, poste, sst, produit
##############################################
Funprog SUMOVE(PTYP,PTYPCST,PLNK)
Value Char    PTYP
Value Integer PTYPCST
Value Integer PLNK

Local Integer I

Case PTYP
    When "M" :
# Issue 78017 & 78853 - 2011-12-23 by CCC : Les FG en entrée sur composants ont déjà été pris en compte auparavant
## Issue 74153 - 2011-06-08 by CCC
## Tous les FG doivent être pris en compte car on est en train de charger les FG en multi-niveaux
        LRES = sigma(I=0,[M:CST]NBFGMAT-1,([M:CST]MFXDAMT(I)+[M:CST]MVARAMT(I))
&                                      *(  [M:CST]CLCLEV(I)=2
&                                        & (PTYPCST=0 | [M:CST]MOVETYP(I)=PTYPCST)
&                                        & [M:CST]MOLNK(I)=PLNK) )
#        LRES = sigma(I=0,[M:CST]NBFGMAT-1,([M:CST]MFXDAMT(I)+[M:CST]MVARAMT(I))
#&                                      *(  (PTYPCST=0 | [M:CST]MOVETYP(I)=PTYPCST)
#&                                        & [M:CST]MOLNK(I)=PLNK) )
    When "W" :
        LRES = sigma(I=0,[M:CST]NBFGWST-1,([M:CST]WFXDAMT(I)+[M:CST]WVARAMT(I))
&                                      *(  (PTYPCST=0 | [M:CST]WOVETYP(I)=PTYPCST)
&                                        & [M:CST]WOLNK(I)=PLNK) )
    When "S" :
        LRES = sigma(I=0,[M:CST]NBFGSCO-1,([M:CST]SFXDAMT(I)+[M:CST]SVARAMT(I))
&                                      *(  (PTYPCST=0 | [M:CST]SOVETYP(I)=PTYPCST)
&                                        & [M:CST]SOLNK(I)=PLNK) )
    When "P" :    # Pas de sous-produit, car il n'y a pas de calcul des FG des sous-produits
        LRES = sigma(I=0,[M:CST]NBFGITM-1,([M:CST]IFXDAMT(I)+[M:CST]IVARAMT(I))
&                                      *(  (PTYPCST=0 | [M:CST]IOVETYP(I)=PTYPCST)
&                                        & [M:CST]IOLNK(I)=PLNK) )
Endcase

End LRES

#################################################
# Récupére les valeurs des matières
#################################################
Subprog INIVALMAT
Local Integer I, LRET
Local Decimal LPRI
Local Char MAT_SITE(5)

If !clalev([M:SDP]) : Local Mask SAIDECPRI  [SDP] : Endif
If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif
If !clalev([F:ITC]) : Local File ITMCOST    [ITC] : Endif    # --> pour récupérer la clé
If !clalev([F:ICN]) : Local File ITCNAT     [ICN] : Endif

    For I = 0 To [M:CST]NBMAT-1
        Raz [F:ITC]    # Sera chargé par GETPRI

        If [M:CST]MATFCY(I) <> "" #Issue X3-8247.sn MJH 8 March 2017
          MAT_SITE = [M:CST]MATFCY(I)
        Else
          MAT_SITE = [M:CST0]STOFCY
        Endif #X3-8247.en

        #Issue X3-8247. MJH 8 March 2017.
        #Replaced [M:CST0]STOFCY with MAT_SITE in the GETPRI call. We want to get the price of the material
        # at the site from the line, not necessarily the header site.
        If dim([M:CST]MECCVALMAJ)>0   # Issue By GA 07/2015
          Call GETPRI([M:CST]MCSTCOD(I),[M:CST]MATREF(I),[M:CST]MECCVALMAJ(I),[M:CST]MECCVALMIN(I),MAT_SITE,[M:CTP]CLCDAT,[M:CST]MQTYSTU(I),LPRI,LRET)
        Else
          Call GETPRI([M:CST]MCSTCOD(I),[M:CST]MATREF(I),"","",MAT_SITE,[M:CTP]CLCDAT,[M:CST]MQTYSTU(I),LPRI,LRET)
        Endif
        # Issue 84715 - 2012-11-27 by CCC
        If LRET=-2
          #Issue X3-8247. Changed [M:CST0]STOFCY to MAT_SITE
          #We want the error message to have the correct site.
          If dim([M:CST]MECCVALMAJ)>0   # Issue By GA 07/2015
            Call ECRTRACE(mess(5,198,1) - mess(23,100,1)-[M:CST]MATREF(I)-[M:CST]MECCVALMAJ(I)-[M:CST]MECCVALMIN(I)-MAT_SITE-num$([M:CTP]CLCDAT),1) From TRTCST
          Else
            Call ECRTRACE(mess(5,198,1) - mess(23,100,1)-[M:CST]MATREF(I)-"No ECCVALMAJ/MIN"-MAT_SITE-num$([M:CTP]CLCDAT),1) From TRTCST
          Endif
        Endif
        If !LRET
            Call COPSDP2CST("M",I,0,[M:CST]MQTYSTU(I))
            # Si valorisation avec un coût standard, on peut renseigner les natures
            If dim([M:CTP]CLCOVEFLG)<=0 | find([M:CTP]CLCOVEFLG,0,[M:CTP]NIV)
                If find([M:CST]MCSTCOD(I),1,2,10,11)
                    # charger tab avec natures FG entrée de la matière
                    For [ICN] Where STOFCY=[F:ITC]STOFCY
&                             & ITMREF=[F:ITC]ITMREF
&                             & CSTTYP=[F:ITC]CSTTYP
&                             & ITCSEQ=[F:ITC]ITCSEQ
&                             & UID   =[F:ITC]UID
                            K=sigma(0,[M:CST]NBFGMAT-1,(indcum+1)
&                                                 *(  [M:CST]NATMAT(indcum)=[F:ICN]OVENAT
&                                                   & [M:CST]OMATREF(indcum)=[M:CST]MATREF(I)
&                                                   & [M:CST]MOLNK(indcum)=[M:CST]MLNK(I) )
&                              )-1
                            If K<0
                                If [M:CST]NBFGMAT=dim([M:CST]NATMAT)-1
                                    Break
                                Endif
                                # Issue 66978 - 2010-09-01 by CCC : il faut conserver le type de FG d'un niveau à l'autre
                                For J=1 To dim([F:ICN]NATAMTLEV)-1
                                    If [F:ICN]NATAMTSSE(J)+[F:ICN]NATAMTLEV(J)>0
                                        [M:CST]NATMAT([M:CST]NBFGMAT)  = [F:ICN]OVENAT
                                        [M:CST]OMATREF([M:CST]NBFGMAT) = [M:CST]MATREF(I)
                                        [M:CST]MOLNK([M:CST]NBFGMAT)   = [M:CST]MLNK(I)
                                        [M:CST]CLCLEV([M:CST]NBFGMAT)  = 1
                                        If find(J,1,6)
                                            [M:CST]MOVETYP([M:CST]NBFGMAT) = 2
                                        Else
                                            [M:CST]MOVETYP([M:CST]NBFGMAT) = J
                                        Endif
                                        # Suite à la DM 5920, les FG fixes des composants sont considérés comme variables...
                                        [M:CST]MVARAMT([M:CST]NBFGMAT) = ([F:ICN]NATAMTSSE(J)+[F:ICN]NATAMTLEV(J))*[M:CST]MQTYSTU(I)
                                        [M:CST]NBFGMAT += 1
                                    Endif
                                Next

                            Else
                                # Suite à la DM 5920, les FG fixes des composants sont considérés comme variables...
                                [M:CST]MVARAMT(K) += ([F:ICN]NATAMTLEV+[F:ICN]NATAMTSSE)*[M:CST]MQTYSTU(I)
                            Endif
                    Next
                Endif
            Endif
        Endif
    Next
End

#################################################
# Récupére les valeurs des sous-produits
#################################################
Subprog INIVALSP
Local Integer I, LRET
Local Decimal LPRI

If !clalev([M:SDP]) : Local Mask SAIDECPRI  [SDP] : Endif
If !clalev([F:TCM]) : Local File TABCOSTMET [TCM] : Endif

    # Sous-produits
    For I = 0 To [M:CST]NBITM-1
        If [M:CST]ITMTYP(I) = 2 & [M:CST]ICSTCOD(I)>1    # Si prix non saisi
            Raz [M:SDP]
            If dim([M:CST]IECCVALMAJ)>0   # Issue By GA 07/2015
              Call GETPRI([M:CST]ICSTCOD(I)-1,[M:CST]ITMREF(I),[M:CST]IECCVALMAJ(I),[M:CST]IECCVALMIN(I),[M:CST0]STOFCY,[M:CTP]CLCDAT,[M:CST]IQTYSTU(I),LPRI,LRET)
            Else
              Call GETPRI([M:CST]ICSTCOD(I)-1,[M:CST]ITMREF(I),"","",[M:CST0]STOFCY,[M:CTP]CLCDAT,[M:CST]IQTYSTU(I),LPRI,LRET)
            Endif
            # Issue 84715 - 2012-11-27 by CCC
            If LRET=-2
                Call ECRTRACE(mess(5,198,1) - mess(23,100,1)-[M:CST]ITMREF(I)-[M:CST0]STOFCY-num$([M:CTP]CLCDAT),1) From TRTCST
            Endif
            If !LRET
                Call COPSDP2CST("I",I,0,[M:CST]IQTYSTU(I))
            Endif
        Endif
    Next
End

#################################################
# Récupére les valeurs des opérations
#################################################
Subprog INIVALWST
Local Integer I

If [M:CST]NBWST=0 : End : Endif # Dans le cas de la sous-traitance et sans module GPAO il ne faut pas ouvrir les tables MWS et MWC

If !clalev([F:MWS]) : Local File WORKSTATIO [MWS] : Endif
If !clalev([F:MWC]) : Local File WORKCOST   [MWC] : Endif

    For I=0 To [M:CST]NBWST-1
        Read [MWS]WST0 = [M:CST]WST(I);[M:CST0]STOFCY
        If !fstat
            Read [MWC]WCT0 = [F:MWS]VLTCCE;[F:MWS]WCRFCY : # lecture de la section de valorisation
            If !fstat
                Case [M:CST]WRATCOD(I)
                 When 1
                    [M:CST]WSETCST(I) = [F:MWC]STDSETCST
                    [M:CST]WOPECST(I) = [F:MWC]STDOPECST
                 When 2
                    [M:CST]WSETCST(I) = [F:MWC]CUTSETCST
                    [M:CST]WOPECST(I) = [F:MWC]CUTOPECST
                 When 3
                    [M:CST]WSETCST(I) = [F:MWC]BUDSETCST
                    [M:CST]WOPECST(I) = [F:MWC]BUDOPECST
                 When 4
                    [M:CST]WSETCST(I) = [F:MWC]SIMSETCST
                    [M:CST]WOPECST(I) = [F:MWC]SIMOPECST
                Endcase
            Endif
            # Issue 84715 - 2012-11-28 by CCC
            If [F:MWS]VLTCCE<>"" & GTRACE<>""
                # si le taux est nul, le signaler en trace (sugg 7165)
                If [M:CST]WSETCST(I)=0
                    Call ECRTRACE(mess(385,197,1) -":"- [F:MWS]VLTCCE+";"+[F:MWS]WCRFCY,0) From TRTCST
                Endif
                If [M:CST]WOPECST(I)=0
                    Call ECRTRACE(mess(387,197,1) -":"- [F:MWS]VLTCCE+";"+[F:MWS]WCRFCY,0) From TRTCST
                Endif
            Endif
        Endif
    Next
    Call CLCOPE
End

#################################################
# Récupére les valeurs de la sous-traitance
#################################################
Subprog INIVALSCO
Local Integer I, LRET
Local Decimal LPRI


If !clalev([M:SDP]) : Local Mask SAIDECPRI  [SDP] : Endif
If GMODU(8)=2
    If !clalev([F:MWS]) : Local File WORKSTATIO [MWS] : Endif
    If !clalev([F:MWC]) : Local File WORKCOST   [MWC] : Endif
Endif

    For I=0 To [M:CST]NBSCO-1
        If [M:CST]SCOWST(I)<>"" & GMODU(8)=2
            Read [MWS]WST0 = [M:CST]SCOWST(I);[M:CST0]STOFCY
            If !fstat
# Issue 78534 - 2012-02-13 by CCC : Le taux peut déjà être chargé par les WIPCOST
#                Raz [M:CST]SSETCST(I),[M:CST]SOPECST(I)
                Read [MWC]WCT0 = [F:MWS]VLTCCE;[F:MWS]WCRFCY : # lecture de la section de valorisation
                If !fstat
                    Case [M:CST]SRATCOD(I)
                     When 1
                        [M:CST]SSETCST(I) = [F:MWC]STDSETCST
                        [M:CST]SOPECST(I) = [F:MWC]STDOPECST
                     When 2
                        [M:CST]SSETCST(I) = [F:MWC]CUTSETCST
                        [M:CST]SOPECST(I) = [F:MWC]CUTOPECST
                     When 3
                        [M:CST]SSETCST(I) = [F:MWC]BUDSETCST
                        [M:CST]SOPECST(I) = [F:MWC]BUDOPECST
                     When 4
                        [M:CST]SSETCST(I) = [F:MWC]SIMSETCST
                        [M:CST]SOPECST(I) = [F:MWC]SIMOPECST
                    Endcase
                Endif
                # Issue 84715 - 2012-11-28 by CCC
                If [F:MWS]VLTCCE<>"" & GTRACE<>""
                    # si le taux est nul, le signaler en trace (sugg 7165)
                    If [M:CST]SSETCST(I)=0
                        Call ECRTRACE(mess(385,197,1) -":"- [F:MWS]VLTCCE+";"+[F:MWS]WCRFCY,0) From TRTCST
                    Endif
                    If [M:CST]SOPECST(I)=0
                        Call ECRTRACE(mess(387,197,1) -":"- [F:MWS]VLTCCE+";"+[F:MWS]WCRFCY,0) From TRTCST
                    Endif
                Endif
            Endif
        Endif
        Call GETPRI([M:CST]SCSTCOD(I),[M:CST]SCOITMREF(I),"","",[M:CST0]STOFCY,[M:CTP]CLCDAT,1,LPRI,LRET)
        # Issue 84715 - 2012-11-27 by CCC
        If LRET=-2
            Call ECRTRACE(mess(5,198,1) - mess(23,100,1)-[M:CST]SCOITMREF(I)-[M:CST0]STOFCY-num$([M:CTP]CLCDAT),1) From TRTCST
        Endif
        If (!LRET)
          # Issue 109989 - 2016-03-02 by STLIG : Return sub-contract minus overhead cost for standard cost calculations.
          If ([M:CST]SIOVECOD(I)<>"" & find([M:CST]SCSTCOD(I),1,2,10,11))
            [M:CST]PRISCO(I) = [F:ITC]CSTTOT
          Else
            [M:CST]PRISCO(I) = LPRI
          Endif
        Endif
    Next
    Call CLCSCO

End

###########################################################
# Récupère le prix d'un article en fonction du paramètre LCST
###########################################################
# Paramètres E : PCST = Méthode da valorisation à utiliser
#                       (1,2,3,4,5,6,8 : application directe         )
#                       (7 : Rien n'est à faire, la valeur est saisie)
#                       (9 : Recherche de la méthode de sortie       )
#                PITM = Article
#                PECCMAJ = Main version number
#                PECCMIN = Minor version number
#                PFCY = Site
#                PDAT = date de valorisation (utile pour coût std)
#                PQTY = quantité à valoriser (utile pour FIFO et LIFO)
#
#            S : PPRI = Prix de l'article
#                PRET = Code retour (0 :Le prix a été recherché et trouvé sans erreur)
#                                   (-1:Le prix n'a pas été cherché)
#                                   (>0:Erreur Cf STKVAL.GETPRI)
###########################################################
Subprog GETPRI(PCST,PITM,PECCMAJ,PECCMIN,PFCY,PDAT,PQTY,PPRI,PRET)
Value    Integer PCST
Value    Char    PITM
Value    Char    PECCMAJ
Value    Char    PECCMIN
Value    Char    PFCY
Value    Date    PDAT
Value    Decimal PQTY
Variable Decimal PPRI
Variable Integer PRET

Local Integer LCSTCOD

Raz PRET
LCSTCOD = 0
Case PCST
    When 7 :    # Prix ordre <=> saisi
        LCSTCOD = 0
    When 9 :    # Méthode de sortie
        Call GETTCM(PITM,[M:CST0]STOFCY, PTCM, PRET) From STKVAL
        If !PRET
            LCSTCOD = [F:TCM]ISSVLTCOD(0)
        Endif
    When Default : LCSTCOD = PCST
Endcase

If find(LCSTCOD,1,2,10,11)
    If !clalev([F:ITC]) : Local File ITMCOST [ITC] : Endif
    Raz [F:ITC]
    # Issue 89527 - 2013-07-31 by CCC : Forcer la récupération du détail du coût standard
    #Call GETPRISTD(PITM,PFCY,PDAT,[M:CTP]UID,LCSTCOD,PPRI,PRET) From STKVAL
    Call GETPRISTD2(PITM,PECCMAJ,PECCMIN,PFCY,PDAT,[M:CTP]UID,LCSTCOD,1,PPRI,PRET) From STKVAL
    # Issue 84715 - 2012-11-27 by CCC
    If [F:ITC]ITMREF=""
        PRET=-2
    Endif
Elsif LCSTCOD
    Raz [M:SDP]
    Call GETPRI(PITM,PECCMAJ,PECCMIN,PFCY,PDAT,PQTY,"","",LCSTCOD,PPRI,PRET) From STKVAL
Else
    PRET = -1
Endif

End

###########################################################
Subprog EFFZOCST(PBLOC)
Value Integer PBLOC
Case PBLOC
    When 10: Raz [M:CST]NBITM,[M:CST]ILNK,[M:CST]ITMREF,[M:CST]IVCRNUM,[M:CST]ITMTYP,[M:CST]IQTYSTU,[M:CST]ISTU,[M:CST]IQTYCOD
             Raz [M:CST]IOVECOD,[M:CST]IOVECOL,[M:CST]ICOEPRO,[M:CST]IBRDCOD,[M:CST]ICSTCOD,[M:CST]ICSTTOT,[M:CST]IOVETOT
             Raz [M:CST]IOVECPN
             Raz [M:CST]IFSCOCST,[M:CST]ISCOCST,[M:CST]IINVDTA,[M:CST]IFINVDTA
             Raz [M:CST]IFOMATCST,[M:CST]IOVEMATCST,[M:CST]IFOMACCST,[M:CST]IOVEMACCST,[M:CST]IFOLABCST,[M:CST]IOVELABCST,[M:CST]IFOSCOCST,[M:CST]IOVESCOCST

             If [M:CST0]AFFZON=2 : Affzo [M:CST]10 : Endif

    When 15: Raz [M:CST]IFMATCST,[M:CST]IMATCST,[M:CST]IOVECPN
             Raz [M:CST]IFSMATCST,[M:CST]ISMATCST
             Raz [M:CST]IFMACCST,[M:CST]IMACCST
             Raz [M:CST]IFLABCST,[M:CST]ILABCST

             If [M:CST0]AFFZON=2 : Affzo [M:CST]15 : Endif

    When 20: Raz [M:CST]NBFGITM,[M:CST]OITMREF,[M:CST]IOLNK,[M:CST]NATITM,[M:CST]IOVETYP,[M:CST]IFXDAMT,[M:CST]IVARAMT


             If [M:CST0]AFFZON=2 : Affzo [M:CST]20 : Endif

    When 25: Raz [M:CST]NBMAT,[M:CST]MLNK,[M:CST]MATREF,[M:CST]MVCRNUM,[M:CST]MQTYSTU,[M:CST]MSTU,[M:CST]MBRDCOD
             Raz [M:CST]MQTYCOD,[M:CST]MOVECOD,[M:CST]MOVECOL,[M:CST]MCSTCOD
             Raz [M:CST]MSCOCST,[M:CST]MINVDTA
             Raz [M:CST]MOVEMATCST,[M:CST]MOVEMACCST,[M:CST]MOVELABCST,[M:CST]MOVESCOCST

             If [M:CST0]AFFZON=2 : Affzo [M:CST]25 : Endif

    When 30: Raz [M:CST]MMATCST,[M:CST]MMACCST,[M:CST]MLABCST
             If [M:CST0]AFFZON=2 : Affzo [M:CST]30 : Endif


    When 35: Raz [M:CST]NBFGMAT,[M:CST]OMATREF,[M:CST]MOLNK,[M:CST]NATMAT,[M:CST]MOVETYP,[M:CST]CLCLEV,[M:CST]MFXDAMT,[M:CST]MVARAMT
             If [M:CST0]AFFZON=2 : Affzo [M:CST]35 : Endif


    When 40: Raz [M:CST]NBWST,[M:CST]WLNK,[M:CST]WST,[M:CST]WVCRNUM,[M:CST]WBRDCOD,[M:CST]WOVECOD,[M:CST]WOVECOL,[M:CST]WSTTYP,[M:CST]WCSTTYP,[M:CST]WRATCOD
             Raz [M:CST]WSETCST,[M:CST]WSETTIM,[M:CST]WOPECST,[M:CST]WOPETIM,[M:CST]WSETAMT,[M:CST]WOPEAMT

             If [M:CST0]AFFZON=2 : Affzo [M:CST]40 : Endif

    When 45: Raz [M:CST]NBFGWST,[M:CST]OWST,[M:CST]WOLNK,[M:CST]NATWST,[M:CST]WOVETYP,[M:CST]WFXDAMT,[M:CST]WVARAMT

             If [M:CST0]AFFZON=2 : Affzo [M:CST]45 : Endif

    When 50: Raz [M:CST]NBSCO,[M:CST]SLNK,[M:CST]SCOWST,[M:CST]SVCRNUM,[M:CST]SBRDCOD,[M:CST]SCSTTYP,[M:CST]SRATCOD,[M:CST]SOVECOD,[M:CST]SOVECOL
             Raz [M:CST]SCOITMREF,[M:CST]SIOVECOD,[M:CST]SIOVECOL,[M:CST]SCSTCOD,[M:CST]PRISCO
             Raz [M:CST]SSETCST,[M:CST]SSETTIM,[M:CST]SSETAMT,[M:CST]SOPECST,[M:CST]SOPETIM,[M:CST]SOPEAMT

             If [M:CST0]AFFZON=2 : Affzo [M:CST]50 : Endif

    When 55: Raz [M:CST]NBFGSCO,[M:CST]OSCOWST,[M:CST]SOLNK,[M:CST]NATSCO,[M:CST]SOVETYP,[M:CST]SFXDAMT,[M:CST]SVARAMT

             If [M:CST0]AFFZON=2 : Affzo [M:CST]55 : Endif

    When 60: Raz [M:CST]NBINVDTA,[M:CST]DLNK,[M:CST]DAMT

             If [M:CST0]AFFZON=2 : Affzo [M:CST]60 : Endif

Endcase
End

$DEBUG_CST
If GTEST
     Local Char    PARMSK(250)(1..20) , SAVACT(20), VALEUR(250)
     SAVACT = GACTION : GACTION = "CLCCST"
     Raz PARMSK, VALEUR
     Call TRAITE_CHAR(VALEUR,PARMSK,"CLCCST","SUBCST","",1,"XYSUBCST") From GTRAITE
     GACTION = SAVACT
    Local Integer CCRET
    Call OUINON("Debug [M:CST] ?",CCRET) From GESECRAN
    If CCRET<>2
        Return
    Endif
    Dbgaff    #CHECK IGNORE_LINE
Endif
Return

#######################################################
# Calcul le total global de l'écran CST
#######################################################
Funprog TOTAL
Local Integer I, L
Local Decimal LTOT

For L=0 To [M:CST]NBITM-1
    If [M:CST]ITMTYP(L)=2
        LTOT -= sigma(I=0,GACTMAT-1,[M:CST]IMATCST(L*GACTMAT+I))
&            + sigma(I=0,GACTMAC-1,[M:CST]IMACCST(L*GACTMAC+I))
&            + sigma(I=0,GACTLAB-1,[M:CST]ILABCST(L*GACTLAB+I))
&            + [M:CST]ISCOCST(L)
&            + [M:CST]IINVDTA(L)
&            + [M:CST]IOVEMATCST(L)+[M:CST]IOVEMACCST(L)+[M:CST]IOVELABCST(L)+[M:CST]IOVESCOCST(L)
    Endif
Next

LTOT += sum([M:CST]MMATCST) + sum([M:CST]MMACCST) + sum([M:CST]MLABCST) + sum([M:CST]MSCOCST) + sum([M:CST]MINVDTA)
# Les FG mat sont déjà dans le tableau des FG

LTOT += sum([M:CST]WOPEAMT) + sum([M:CST]WSETAMT)

LTOT += sum([M:CST]SOPEAMT) + sum([M:CST]SSETAMT) + sum([M:CST]SITMAMT)

LTOT += sum([M:CST]DAMT)

LTOT += sum([M:CST]IFXDAMT)+sum([M:CST]IVARAMT)
&     + sum([M:CST]MFXDAMT)+sum([M:CST]MVARAMT)
&     + sum([M:CST]WFXDAMT)+sum([M:CST]WVARAMT)
&     + sum([M:CST]SFXDAMT)+sum([M:CST]SVARAMT)

End LTOT

##################################################
Subprog ARRCST(PRND)
Value Decimal PRND

If PRND=0 : End : Endif

Local Integer I, L

Local Decimal LTOT, LTOTRND, LCUMVAL, LCUMRND, LVAL

LTOT = func TOTAL
If PRND<>0
    LTOTRND = arr(LTOT, PRND)
Endif
Raz LCUMVAL, LCUMRND

For L=0 To [M:CST]NBITM-1
    If [M:CST]ITMTYP(L)=2
        For I=0 To GACTMAT-1
            LVAL = [M:CST]IMATCST(L*GACTMAT+I) : Gosub CAL_RND : [M:CST]IMATCST(L*GACTMAT+I) = LVAL
        Next
        For I=0 To GACTMAC-1
            LVAL = [M:CST]IMACCST(L*GACTMAC+I) : Gosub CAL_RND : [M:CST]IMACCST(L*GACTMAC+I) = LVAL
        Next
        For I=0 To GACTLAB-1
            LVAL = [M:CST]ILABCST(L*GACTLAB+I) : Gosub CAL_RND : [M:CST]ILABCST(L*GACTLAB+I) = LVAL
        Next
        LVAL = [M:CST]ISCOCST(L) : Gosub CAL_RND : [M:CST]ISCOCST(L) = LVAL
        LVAL = [M:CST]IINVDTA(L) : Gosub CAL_RND : [M:CST]IINVDTA(L) = LVAL
        LVAL = [M:CST]IOVEMATCST(L) : Gosub CAL_RND : [M:CST]IOVEMATCST(L) = LVAL
        LVAL = [M:CST]IOVEMACCST(L) : Gosub CAL_RND : [M:CST]IOVEMACCST(L) = LVAL
        LVAL = [M:CST]IOVELABCST(L) : Gosub CAL_RND : [M:CST]IOVELABCST(L) = LVAL
        LVAL = [M:CST]IOVESCOCST(L) : Gosub CAL_RND : [M:CST]IOVESCOCST(L) = LVAL
    Endif
Next

For L=0 To [M:CST]NBMAT-1
    For I=0 To GACTMAT-1
        LVAL = [M:CST]MMATCST(L*GACTMAT+I) : Gosub CAL_RND : [M:CST]MMATCST(L*GACTMAT+I) = LVAL
    Next
    For I=0 To GACTMAC-1
        LVAL = [M:CST]MMACCST(L*GACTMAC+I) : Gosub CAL_RND : [M:CST]MMACCST(L*GACTMAC+I) = LVAL
    Next
    For I=0 To GACTLAB-1
        LVAL = [M:CST]MLABCST(L*GACTLAB+I) : Gosub CAL_RND : [M:CST]MLABCST(L*GACTLAB+I) = LVAL
    Next
    LVAL = [M:CST]MSCOCST(L) : Gosub CAL_RND : [M:CST]MSCOCST(L) = LVAL
    LVAL = [M:CST]MINVDTA(L) : Gosub CAL_RND : [M:CST]MINVDTA(L) = LVAL
    # Les FG mat sont déjà dans le tableau des FG
Next

For L=0 To [M:CST]NBWST-1
    LVAL = [M:CST]WOPEAMT(L) : Gosub CAL_RND : [M:CST]WOPEAMT(L) = LVAL
    LVAL = [M:CST]WSETAMT(L) : Gosub CAL_RND : [M:CST]WSETAMT(L) = LVAL
Next

For L=0 To [M:CST]NBSCO-1
    LVAL = [M:CST]SOPEAMT(L) : Gosub CAL_RND : [M:CST]SOPEAMT(L) = LVAL
    LVAL = [M:CST]SSETAMT(L) : Gosub CAL_RND : [M:CST]SSETAMT(L) = LVAL
    LVAL = [M:CST]SITMAMT(L) : Gosub CAL_RND : [M:CST]SITMAMT(L) = LVAL
Next

For L=0 To [M:CST]NBINVDTA-1
    LVAL = [M:CST]DAMT(L) : Gosub CAL_RND : [M:CST]SITMAMT(L) = LVAL
Next

For L=0 To [M:CST]NBFGITM-1
    LVAL = [M:CST]IFXDAMT(L) : Gosub CAL_RND : [M:CST]IFXDAMT(L) = LVAL
    LVAL = [M:CST]IVARAMT(L) : Gosub CAL_RND : [M:CST]IVARAMT(L) = LVAL
Next
For L=0 To [M:CST]NBFGITM-1
    LVAL = [M:CST]MFXDAMT(L) : Gosub CAL_RND : [M:CST]MFXDAMT(L) = LVAL
    LVAL = [M:CST]MVARAMT(L) : Gosub CAL_RND : [M:CST]MVARAMT(L) = LVAL
Next
For L=0 To [M:CST]NBFGITM-1
    LVAL = [M:CST]WFXDAMT(L) : Gosub CAL_RND : [M:CST]WFXDAMT(L) = LVAL
    LVAL = [M:CST]WVARAMT(L) : Gosub CAL_RND : [M:CST]WVARAMT(L) = LVAL
Next
For L=0 To [M:CST]NBFGITM-1
    LVAL = [M:CST]SFXDAMT(L) : Gosub CAL_RND : [M:CST]SFXDAMT(L) = LVAL
    LVAL = [M:CST]SVARAMT(L) : Gosub CAL_RND : [M:CST]SVARAMT(L) = LVAL
Next


End

Subprog ARROVEITM(PRND)
Value Decimal PRND
If PRND=0 : End : Endif

Local Integer I, L
Local Decimal LTOT, LTOTRND, LCUMVAL, LCUMRND, LVAL

Raz LTOT, LTOTRND, LCUMVAL, LCUMRND, LVAL

For L=0 To [M:CST]NBITM-1
    If [M:CST]ITMTYP(L)=1 & (L=0 | !find([M:CST]ILNK(L),[M:CST]ILNK(0..L-1)))
        LTOT += sigma(0,[M:CST]NBFGITM-1,([M:CST]ILNK(L)=[M:CST]IOLNK(indcum))
&                                       *([M:CST]IFXDAMT(indcum)+[M:CST]IVARAMT(indcum)))
    Endif
Next

LTOTRND = arr(LTOT,PRND)

For L=0 To [M:CST]NBITM-1
    If [M:CST]ITMTYP(L)=1 & (L=0 | !find([M:CST]ILNK(L),[M:CST]ILNK(0..L-1)))
        For I=0 To [M:CST]NBFGITM-1
            If [M:CST]ILNK(L)=[M:CST]IOLNK(I)
                LVAL = [M:CST]IFXDAMT(I) : Gosub CAL_RND : [M:CST]IFXDAMT(I) = LVAL
                LVAL = [M:CST]IVARAMT(I) : Gosub CAL_RND : [M:CST]IVARAMT(I) = LVAL
            Endif
        Next
    Endif
Next
End



$CAL_RND
LCUMVAL += LVAL
LVAL = arr(LTOTRND * LCUMVAL / LTOT - LCUMRND, PRND)
LCUMRND += LVAL
Return


$ARR_VAL
If LCUMIND>=dim(LCUMVAL)
    Return
Endif
    LCUMVAL(LCUMIND) += LTMPVAL
    LTMPVAL = arr(LCUMVAL(LCUMIND)-LCUMRND(LCUMIND),LARRONDI)
    LCUMRND(LCUMIND) += LTMPVAL
    LCUMIND+=1
Return

############################################################
# ECRTRACE : Ecrit les messages de trace du calcul de coût
#            Ne doit être utilisé que dans les parties chargement de [M:CST] et calcul
############################################################
# Parametres E : PMSG = message
#                PERR = niveau de message (0=normal, 1=erreur, -1=warning)
############################################################
Subprog ECRTRACE(PMSG, PERR)
Value Char PMSG
Value Integer PERR

Call ECRTRACE2(PMSG, PERR, "")
End

############################################################
# ECRTRACE2 : Ecrit les messages de trace du calcul de coût
############################################################
# Parametres E : PMSG = message
#                PERR = niveau de message (0=normal, 1=erreur, -1=warning)
#                PSUP = options ("2" = écrire le message même pour le calcul du multi-niveaux)
############################################################
Subprog ECRTRACE2(PMSG, PERR, PSUP)
Value Char PMSG
Value Integer PERR
Value Char PSUP

# Par défaut, les messages lors du calcul multi-niveaux ne sont pas affichés
# car normalement les erreurs sont les mêmes qu'en mono-niveau et celui-ci est le 1er lancé
If [M:CTP]NIV=2 & !instr(1,PSUP,"2")
    End
Endif

Case [M:CTP]TRANIV
    When  0 : # Rien
    When -1 : # Messages d'erreurs à l'écran
              If PERR=1
                Call ERREUR(PMSG) From GESECRAN
              Endif
    When  1 : # Trace des erreurs seulement
              If PERR=1
                Call ECR_TRACE(PMSG,PERR) From GESECRAN
              Endif
    When  2 : # Trace tout
              Call ECR_TRACE(PMSG,PERR) From GESECRAN
    When  3 : # Trace configurateur
              If clalev([M:CFV4]) > 0
                  Call CFG_CSTERR(PMSG,PERR) From CFGLIBD
              Else
                  Call ECR_TRACE(PMSG,PERR) From GESECRAN
              Endif
    When  Default : # Trace tout
              Call ECR_TRACE(PMSG,PERR) From GESECRAN

Endcase
End

