#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque CPYLEGAUS 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:03:30"
A_USER  = "DOC"
A_STAMP = "20181109230330"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "ADDID"
  If [M]ADDID=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask CPYLEGAUS [CLAUS]
Gosub HORODAT
Local Inpbox "CPYLEGAUS" From GFONCTION At A_STAMP With A_WINDPREV Mask [CLAUS] As [SIM_]
Grizo [CLAUS]5
Grizo [CLAUS]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [CLAUS]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=27 : X2(0)=86 : Y1(0)=10 : Y2(0)=13
X1(1)=27 : X2(1)=86 : Y1(1)=14 : Y2(1)=19
Return

$ON_CPY
Return

$ON_ZCPY
Onevent BEFORE_AREA Gosub AV_ZCPY From W1CPYLEGAUS
Return

$AV_ZCPY
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",num$([M]CPY(indice)),"") From CONTOBJ
zc = [F:CPY]CPYNAM
Gosub _AFF
Return

$ON_ABNNUM
Onevent CONTROL Call C_ABNNUM(zc) From W1CPYLEGAUS
Return

Subprog C_ABNNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_ABNNUM(VALEUR) From TRTCPYLEGAUS
If mkstat : GERR = 1 : GZONE = "ABNNUM" : GZNUM = 56088 : Endif
Gosub _AFF
End

$ON_WPNNUM
Onevent CONTROL Call C_WPNNUM(zc) From W1CPYLEGAUS
Return

Subprog C_WPNNUM(VALEUR)
Variable Char    VALEUR()
## Action STD
Call C_WPNNUM(VALEUR) From TRTCPYLEGAUS
If mkstat : GERR = 1 : GZONE = "WPNNUM" : GZNUM = 56090 : Endif
Gosub _AFF
End

$ON_ADDTYP
Onevent INIT_AREA Call D_ADDTYP(zc) From W1CPYLEGAUS
Onevent BEFORE_INPUT Call AS_ADDTYP(zc) From W1CPYLEGAUS
Return

Subprog D_ADDTYP(VALEUR)
Variable Integer VALEUR
If varinit([M]ADDTYP,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_ADDTYP(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_ADDR1
Onevent BEFORE_AREA Gosub AV_ADDR1 From W1CPYLEGAUS
Return

$AV_ADDR1
## Action FMTADRPAY
Call FMTADRPAY("") From TRTDIV
If GFMT<>""
 Chgfmt [M]ADDR1(indice) With "K:"+GFMT
Else
 Chgfmt [M]ADDR1(indice) With "-K:1X"
Endif
Gosub _AFF
Return

$ON_ADDR2
Onevent BEFORE_AREA Gosub AV_ADDR2 From W1CPYLEGAUS
Return

$AV_ADDR2
## Action FMTADRPAY
Call FMTADRPAY("") From TRTDIV
If GFMT<>""
 Chgfmt [M]ADDR2(indice) With "K:"+GFMT
Else
 Chgfmt [M]ADDR2(indice) With "-K:1X"
Endif
Gosub _AFF
Return

$ON_ADDR3
Onevent BEFORE_AREA Gosub AV_ADDR3 From W1CPYLEGAUS
Return

$AV_ADDR3
## Action FMTADRPAY
Call FMTADRPAY("") From TRTDIV
If GFMT<>""
 Chgfmt [M]ADDR3(indice) With "K:"+GFMT
Else
 Chgfmt [M]ADDR3(indice) With "-K:1X"
Endif
Gosub _AFF
Return

$ON_ADDR4
Onevent BEFORE_AREA Gosub AV_ADDR4 From W1CPYLEGAUS
Return

$AV_ADDR4
## Action FMTADRPAY
Call FMTADRPAY("") From TRTDIV
If GFMT<>""
 Chgfmt [M]ADDR4(indice) With "K:"+GFMT
Else
 Chgfmt [M]ADDR4(indice) With "-K:1X"
Endif
Gosub _AFF
Return

$ON_XSAT
Onevent BEFORE_AREA Gosub AV_XSAT From W1CPYLEGAUS
Onevent BEFORE_INPUT Call AS_XSAT(zc) From W1CPYLEGAUS
Onevent CONTROL Call C_XSAT(zc) From W1CPYLEGAUS
Return

Subprog IB_XSAT(VALEUR)
Variable Char    VALEUR()
## Action INISAT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "INISAT"
PARMSK(1) = CRY
PARMSK(2) = ""
Call S_AFF_CHAR(VALEUR,PARMSK,"INISAT","TRTDIV","") From GACTION
GACTION = SAVACT
Gosub _AFF
End

$AV_XSAT
If !GWEBSERV
 ## Action FMTSAT
 Call FMTSATPAY(CRY,"") From TRTDIV
Endif
If GFMT<>""
 Chgfmt [M]XSAT(indice) With "K:"+GFMT
Else
 Chgfmt [M]XSAT(indice) With "-K:1X"
Endif
Gosub _AFF
Return

Subprog AS_XSAT(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(31745,GBOUT2) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call IB_XSAT(VALEUR)
If  GWEBSERV
 ## Action SAISAT
 Call SAISAT(CRY,"") From TRTDIV
 If mkstat=2
  [M]XSAT(INDIC) = VALEUR
  Affzo XSAT(INDIC) : mkstat = 2
 Endif
Endif
Onkey 130 Titled GBOUT2 Call B2_XSAT(zc) From W1CPYLEGAUS
Onkey   2 Titled GBOUTS Call S_XSAT(zc) From W1CPYLEGAUS
Gosub _AFF
End

Subprog C_XSAT(VALEUR)
Variable Char    VALEUR()
## Action CTLSAT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "CTLSAT"
PARMSK(1) = CRY
PARMSK(2) = ""
Call S_AFF_CHAR(VALEUR,PARMSK,"CTLSAT","TRTDIV","") From GACTION
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "XSAT" : GZNUM = 51590 : Endif
Gosub _AFF
End

Subprog S_XSAT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELSAT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELSAT"
 PARMSK(1) = CRY
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELSAT","TRTDIV","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B2_XSAT(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action TUNSAT
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "TUNSAT"
 PARMSK(1) = CRY
 PARMSK(2) = ""
 Call S_AFF_CHAR(VALEUR,PARMSK,"TUNSAT","TRTDIV","") From GACTION
 GACTION = SAVACT
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_CRY
Onevent CONTROL Call C_CRY(zc) From W1CPYLEGAUS
Onevent BEFORE_INPUT Call AS_CRY(zc) From W1CPYLEGAUS
Onevent INIT_AREA Call D_CRY(zc) From W1CPYLEGAUS
Return

Subprog D_CRY(VALEUR)
Variable Char    VALEUR()
If varinit([M]CRY,indice)=0
 VALEUR = GPAYS
Endif
Gosub _AFF
End

Subprog AS_CRY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(53316,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CRY(zc) From W1CPYLEGAUS
Onkey   2 Titled GBOUTS Call S_CRY(zc) From W1CPYLEGAUS
Onkey 144 Titled GBOUTP Call P_CRY(zc) From W1CPYLEGAUS
Onkey 146 Titled GBOUTA Call SA_CRY(zc) From W1CPYLEGAUS
Gosub _AFF
End

Subprog C_CRY(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("TCY","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 263 : Endif
Gosub _AFF
End

Subprog S_CRY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TCY"
PARMSK(2) = "!"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_CRY(VALEUR)
Variable Char    VALEUR()
Call OBJET("TCY",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CRY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CRY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$CHG_STY
Return


