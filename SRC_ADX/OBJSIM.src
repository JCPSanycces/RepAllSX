#<AdxTL>@(#)9.0.0.0 $Revision$
################################################################################
# Simulation de saisie objet
## GH 03/2015
################################################################################

$DEFVAR
Local Integer  SAVGIMPORT, SAVGPICK
Local Char     SAVGCLE(50), ACTION(20), SAVGABREV([V]GLONAOB), SAVGREP(1), SAVBOITE(GLONFEN)

# Définition des variables GOBJET
Local Integer XOK

Gosub DEFVAR From GOBJET
[L]FILROLE = "1" : # Toujours vérifié

[L]SAVGIMPORT=[V]GIMPORT
[L]SAVGPICK  =[V]GPICK
[L]SAVGCLE   =[V]GCLE
[L]SAVGABREV =[V]GABREV
[L]SAVGREP   =[V]GREP
[L]SAVBOITE = [V]GBOITE

[V]GBOITE="O"+[L]ABREV
If dim([L]TRTGBM)=1 & [L]TRTGBM<>""
  [L]ACTION="BOITE" : Gosub ACTION From =[L]TRTGBM
Endif
Call NOMTRTWIN([V]GBOITE,[L]WINPROG) From MSKDIV

Gosub DEFVAR From =[L]WINPROG
For [L]MA=0 To [L]NBMASK
 If !evalue("clalev([M:"+[L]ABMSK([L]MA)+"])")
  Local Mask =[L]NOMMSK(MA)
 Endif
Next

Local Integer  INBAFF
Local Integer  IAFFCOD
Local Char     IAFFMASK(4)
Local Char     IAFFCHP(50)
Local Integer  IAFFIND
Local Char     IAFFTXT(250)
Local Integer  IAFFRANG
Local Integer  IAFFOPT1
Local Integer  IAFFOPT2
Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2

If evalue("clalev([F:"+[L]ABFIC+"])")=0 : Local File =[L]NOMFIC : Endif
[L]ACTION="AVANT_OUVRE" : Gosub ACTION From GOBJSUB

Gosub OUVRE From =[L]PROGOBJ
#Gosub OUVOBJ From GOBJET
[L]ACTION="OUVRE" : Gosub ACTION From GOBJSUB

[V]GIMPORT=1
[V]GCLE   =""
[V]GPICK  =0
[V]GABREV =[L]ABREV
[L]XOK    =1
Return

################################################################################
$RESTGLO
If !find([V]GABREV,GPILCOD(1..GPILOBJ))
& & SAVGIMPORT<>1   # Issue 115658 - 2016-10-10 by CCC : Action "FERME" will be called later at the end of the import. GPILCOD="" during import
   [L]ACTION ="FERME" : Gosub ACTION From GOBJSUB
Endif

[V]GIMPORT=[L]SAVGIMPORT
[V]GCLE   =[L]SAVGCLE
[V]GPICK  =[L]SAVGPICK
[V]GABREV =[L]SAVGABREV
[V]GREP   =[L]SAVGREP
[V]GBOITE =[L]SAVBOITE
Setmode
Return

################################################################################
$CHARGE
[V]GMESSAGE=""
[V]GREP    =""
Gosub SET_CLE From GOBJSUB
For MA=0 To [L]NBMASK
  Gosub SETMASK From =[L]WINPROG
Next
For [L]MA=0 To [L]NBMASK
  Gosub RAZMASK From =[L]WINPROG
Next
For [L]IMA=0 To [L]NBMASK
  Gosub CHARGEMSK From =[L]WINPROG
Next
Setmode INBAFF,IAFFCOD,IAFFMASK,IAFFCHP,IAFFIND,IAFFTXT,IAFFRANG,IAFFOPT1,IAFFOPT2
[L]ACTION="LIENS" : Gosub ACTION From GOBJSUB
Setmode
Return

################################################################################
$CREATION
OK = 1
ACTION = "VERIF_CRE" : Gosub ACTION From GOBJSUB
If !OK : GOK = 0 : Return : Endif

#Call DEBTRANS From GLOCK
Gosub TR1
If GOK>=1
 Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
 ACTION = "APRES_CRE" : Gosub ACTION From GOBJSUB
 If dim(NBLNK)>0 & NBLNK>0 : Gosub LIAISONS From GOBJET1 : Endif
 Call ESPION(NOMFIC,1,IDENT,"") From ESPION
 #If GRPDEB<>"" : Call ENVOI_GROUPE(GRPDEB) From AWRK : Endif
 If GADONIX=2 : Call TRACE_COR(ABREV,CLECUR1,CLECUR2,"C") From GOBJET : Endif
Else
 #If GRPDEB<>""
 #  Call VIRE_GROUPE(GRPDEB) From AWRK
 #  GOK = 0
 #Endif
 #Gosub RSTCLE From GOBJSUB
Endif
Return

$TR1
#GOK = 1
#GRPDEB=""
#Trbegin ADOVAL
 Gosub DEFAUT From =PROGOBJ
 Raz [F]
 nolign = 1
 For IMA=0 To NBMASK
  Gosub CHARGEFIC From =[L]WINPROG
 Next IMA
 Gosub INICRE From GOBJSUB
 ACTION = "INICRE" : Gosub ACTION From GOBJSUB
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
# Vérification du rôle
 Onerrgo RIEN From GOBJET1
 ER = 0
 OK = evalue(FILROLE)
 Onerrgo
 If !ER & !OK
  Call ERREUR(mess(97,126,1)) From GESECRAN
  #           Vous n'avez pas les droits pour créer cette fiche
  GOK = 0 : Goto AB_TR1
 Endif
 Write
 If fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK
  Goto AB_TR1
 Endif

 ACTION = "CREATION" : Gosub ACTION From GOBJSUB
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif

 Gosub SET_CLE From GOBJSUB
 Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT
 Call WRKGLOB(170,IDENT,NOMFIC,NOMINT) From GOBJACT
 Call WORKPLUS(2,ABREV,"C",IDENT,"",0,1,0,GRPDEB) From AWRK
 If GOK<0   : Goto ROLL_TR1
 Elsif !GOK : Goto AB_TR1
 Endif
#Commit
Return

$AB_TR1
#Rollback
ACTION = "AB_CREATION" : Gosub ACTION From GOBJSUB
Return

$ROLL_TR1
#Rollback
#Call ROLL From GLOCK
#If GROLL
If mod([V]GNBROL+1,[V]GROLLBACK)=0
 ACTION = "AB_CREATION" : Gosub ACTION From GOBJSUB
 Return
Else
# Goto TR1
 Return
Endif

################################################################################
$MODIF
OK = 1
ACTION = "VERIF_MOD" : Gosub ACTION From GOBJSUB
If !OK : GOK = 0 : Return : Endif
Call IDENT3(ABREV,IDENT,CLECUR1,CLECUR2) From GOBJTXT

#Call DEBTRANS From GLOCK
Gosub TR2
If GOK>=1
 ACTION = "APRES_MOD" : Gosub ACTION From GOBJSUB
 If dim(NBLNK)>0 & NBLNK>0 : Gosub LIAISONS From GOBJET1 : Endif
 Call ESPION(NOMFIC,2,IDENT,"") From ESPION
 #If GRPDEB<>"" : Call ENVOI_GROUPE(GRPDEB) From AWRK : Endif
 If GADONIX=2 : Call TRACE_COR(ABREV,CLECUR1,CLECUR2,"M") From GOBJET : Endif
#Elsif GRPDEB<>""
# Call VIRE_GROUPE(GRPDEB) From AWRK
# GOK = 0
Endif
Return

$TR2
#GOK = 1
#GRPDEB=""
#Trbegin ADOVAL
 Gosub DEFAUT From =PROGOBJ
 Gosub AFF_CLE From GOBJSUB
 Assign "[G:"+ABFIC+"]currind" With 1
 Assign "[G:"+ABFIC+"]currlen" With 0
 Readlock =
 If fstat=1
  GOK=-1 : GLOCK="$"+NOMFIC-CLECUR1 : Goto ROLL_TR2
 Elsif fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif
 Gosub SAV_LIAISONS From GOBJET1
 ACTION = "AVANT_MODFIC" : Gosub ACTION From GOBJSUB
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Call WRKGLOB(171,[L]IDENT,[L]NOMFIC,[L]NOMINT) From GOBJACT
 Call WORKPLUS(2,ABREV,"M",IDENT,"",0,1,1,GRPDEB) From AWRK
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif

 nolign = 1
 For IMA=0 To NBMASK
  Gosub CHARGEFIC From =WINPROG
 Next IMA
 Gosub INIMOD From GOBJSUB
 ACTION = "INIMOD" : Gosub ACTION From GOBJSUB
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
 Gosub DEFAUT From =PROGOBJ
# Vérification du rôle
 Onerrgo RIEN From GOBJET1
 ER = 0
 OK = evalue(FILROLE)
 Onerrgo
 If !ER & !OK
  Call ERREUR(mess(97,126,1)) From GESECRAN : # Vous n'avez pas les droits pour créer cette fiche
  GOK = 0 : Goto AB_TR1
 Endif
 Rewrite
 If fstat
  GOK=0 : Call FSTA(ABFIC) From GLOCK : Goto AB_TR2
 Endif

 ACTION = "MODIF" : Gosub ACTION From GOBJSUB
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif

 Call WORKPLUS(2,ABREV,"M",IDENT,"",0,1,2,GRPDEB) From AWRK
 If GOK<0   : Goto ROLL_TR2
 Elsif !GOK : Goto AB_TR2
 Endif
#Commit
Return

$AB_TR2
#Rollback
ACTION = "AB_MODIF" : Gosub ACTION From GOBJSUB
Return

$ROLL_TR2
#Rollback
#Call ROLL From GLOCK
#If GROLL
If mod([V]GNBROL+1,[V]GROLLBACK)=0
 ACTION = "AB_MODIF" : Gosub ACTION From GOBJSUB
 Return
Else
# Goto TR2
 Return
Endif

######################################################################################################
## Selection for browser OBJET
######################################################################################################

$SELBROWSER
Call SETPROG(OBJET,PROGOBJ,PROGSUB,PROGSPE,PROGSPV,PSTD,PSUB,PSPE,PSPV) From CONTOBJ
If !PSTD : Return : Endif

Gosub OUVFIC From =PROGOBJ
Gosub OUVRE From =PROGOBJ
Gosub NOMFIC From =PROGOBJ
Gosub OUVRE_LISTE From =PROGOBJ
Gosub DEFAUT_LISTE From =PROGOBJ

For I=1 To NBSEL
 If J<dim(COL) & I<=dim(SELEXP)
   J += 1
   If SELEXP(I)<>""
     COL(J) = SELEXP(I)
   Else
     COL(J) = SELZON(I)
   Endif
   TIT(J) = SELLIB(I)
   If left$(SELFMT(I),2)="LA"
    COL(J) = "mess("+COL(J)+","+num$(val(right$(SELFMT(I),3)))+",1)"
   Endif
   If dim(SELFOR)>0
    FMTCOL(J) = SELFOR(I)
   Endif
  Endif
Next I
NBCOL = J
Call TEXTE(TITOBJ,TIT(0)) From OBJDIV
TIT(0)  = mess(12,123,1)-TIT(0) : # Choix
SENS=SELORD
Return

######################################################################################################
## Texte repris d'une zone écran
######################################################################################################

Funprog TEXAMZ(MSK,ZON)
Value Char MSK(), ZON()

Local Char MSG(GLONDES)

Call LIENS("AMZ","AMSKZON",ZON,MSK,"num$([F:AMZ]INTIT)",MSG) From CONTOBJ
Call TEXTE(val(MSG),MSG) From OBJDIV
End MSG

######################################################################################################
## Affichage d'une ligne d'un tableau
######################################################################################################

Subprog AFFLIG(MSK,ABR,BASPAG,NOL)
Value Char    MSK(), ABR(), BASPAG()
Value Integer NOL

If ABR<>"" & evalue("clalev([M:"+ABR+"])")=0
   Call ERREUR(ABR-":"-mess(1105,144,1)) From GESECRAN
   End
Endif

Local Integer I, J, K
If dim([V]GTABZON)<0
   Global Char GTABZON(GLONAVA)(252)
Elsif !find(GTABZON(0),"",MSK) | GTABZON(1)<>BASPAG
   Raz [V]GTABZON
Endif
If GTABZON(0)=""
   Local File AMSK [AMK], AMSKZON [AMZ]
   If ABR="" & clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif : # optimisation
   Read [AMK]CODMSK = [L]MSK
   If fstat
      Call ERREUR(MSK-":"-mess(72,123,1)) From GESECRAN : End
   Endif
   K = find([L]BASPAG,[F:AMK]BASPAG(0..[F:AMK]NBBLOC-1))
   If K<1
      Call ERREUR([L]BASPAG-":"-mess(141,123,1)-"("+mess(255,115,1)-MSK+")") From GESECRAN : End
   Endif
   J=dim([V]GTABZON)
   [V]GTABZON(I)=[L]MSK    : I+=1
   [V]GTABZON(I)=[L]BASPAG : I+=1
   Columns [AMZ] (CODZON, LIEN, CODACT)
   For [AMZ]CODZON Where CODMSK=[L]MSK & NUMBLOC=K & SAIAFF<3
    If [F:AMZ]CODACT="" | (ABR<>"" & evalue("dim([M:"+ABR+"]"+[F:AMZ]CODZON+")")>0)
&                       | (ABR="" & func AFNC.ACTIV([F:AMZ]CODACT))
       If I>=J : Call ERREUR(mess(225,133,1)-MSK-"("+mess(15,115,1)-[L]BASPAG+")") From GESECRAN : Break : Endif
       [V]GTABZON(I) = [F:AMZ]CODZON : I+=1
       If [F:AMZ]LIEN>1
          [V]GTABZON(I) = "Z"+[F:AMZ]CODZON : I+=1
       Endif
    Endif
   Next
   Columns [AMZ]
Endif
If ABR="" : End : Endif               : # enable to load GTABZON with no display

Local Char    SUFNOL(7), SAVDEFMSK(250)
[L]SAVDEFMSK = dbgstr(1)              : # restore default mask
SUFNOL="("+num$(NOL)+")"
Default Mask "["+ABR+"]"
For I=2 To dim([V]GTABZON)-1
  If [V]GTABZON(I)="" : Break : Endif
  Affzo =[V]GTABZON(I)+SUFNOL         : # does not crash if the screen field does not exist !!
Next
Default Mask [L]SAVDEFMSK             : # restore default mask
End

