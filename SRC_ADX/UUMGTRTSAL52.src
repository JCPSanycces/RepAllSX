#<AdxTL>@(#)0.0.0.0 $Revision$ Migration Mouvements clients :
#####################################################
#  Appel de la resynchro des encours clients        #
# ------------------------------------------------- #
# Ne rien faire si le module vente n'est pas actif  #
#####################################################
Local Char DOSSIER(30) : DOSSIER = nomap
If !GSERVEUR
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Call SAIDOS(DOSSIER,"") From SAIDOS
  Call SAIDOSHIS(DOSSIER,"") From SAIDOSHIS
  # Issue 106947 - 20150811 by LD
Endif
If DOSSIER <> ""
  If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
  # Issue 106947 - 20150811 by LD : Migration of historic folder
  #Read [ADS] DOSSIER=[L]DOSSIER : If fstat Raz [F:ADS] : Endif
  If func DOSSUB.FILL_ADS([L]DOSSIER)=0 : End : Endif
  # Issue 106947 - 20150811 by LD

  #Call ACTIVE From TIMING
  If !GSERVEUR
    Call TEMPON("O") From GESECRAN
    Call OUVRE_TRACE("UUMGTRTSAL52") From LECFIC
  Endif

  Call MAJ_UUMGTRTSAL52(DOSSIER)
  If !GSERVEUR
    Call TEMPOFF     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
  #Call ARRET From TIMING
Endif
End

#######################################################################
# Suppression pour pouvoir relancer la moulinette
########################################################################
Subprog RAZ_UUMGTRTSAL52(DOSSIER)
Value Char DOSSIER

Local Integer ERR

##1 - verifications
####################
If [F:ADS]MODULE(4)<>2 : : # N= no module
  End
Endif

##2 - On vide les fichiers selon le cas
#######################################

##3 - On vide AMIGKEY pour le flux
####################
Call MIGRAZKEY (DOSSIER,"UUMGTRTSAL52",ERR) From TRTMIG

End

#######################################################################
#######################################################################
Subprog MAJ_UUMGTRTSAL52(DOSSIER)
Value Char DOSSIER

Local Integer ERR

# Issue 106947 - 20150811 by LD : Migration of historic folder
If func DOSVUE.ISVIEW(DOSSIER,"BPCUSTMVT")=1 | func DOSVUE.ISVIEW(DOSSIER,"LASTCUSMVT")=1
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL52",3,ERR) From TRTMIG : #3=Terminée
  End
Endif
# Issue 106947 - 20150811 by LD

##1 - verifications
####################

If [F:ADS]MODULE(4)<>2 : : # N= no module
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL52",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

# 101462 : Exécuter ssi on vient d'une version antérieure à la V6
##1.1 - Récupération du n° de version
#Gbn-121203/X3-25868
#####################################
Local Char    CVERSION(3)
Local Integer VERSION
Call MIGGETVERSION (DOSSIER,CVERSION,ERR) From TRTMIG
If ERR
  # N° de version incorrecte
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL52",7,ERR) From TRTMIG : #7=Erreur
  End
Else
 VERSION=val(CVERSION)
Endif
#If val(VERSION)>=GMIGX3VER60 End Endif
# 101462

If filinfo(filpath("FIL","BPCUSTMVT","fde",DOSSIER),0)<0
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL52",3,ERR) From TRTMIG : #3=Terminée
  End
Endif

##2 - Traitements en cours
####################

Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL52",2,ERR) From TRTMIG : #2=En cours

###################

#-----
Gosub SET_FIRST   From TRTFIRST
#-----
Call ECR_TIME("UUMGTRTSAL52 Customer Transactions Process 2 : Update BPCUSTMVT") From DOSSUB

#----- Tables tronc commun et superviseur -----#
Local File =[F:ADS]DOSSIER+".BPCUSTMVT"   [MVC]
Local File =[F:ADS]DOSSIER+".BPSUPPMVT"   [MVS]
Local File =[F:ADS]DOSSIER+".LASTCUSMVT"  [LCM]
Local File =[F:ADS]DOSSIER+".LASTSUPMVT"  [LSM]
#Local File =[F:ADS]DOSSIER+".BPARTNER"    [BPR] #Gbn-121203/X3-25868
#Local File =[F:ADS]DOSSIER+".BPCUSTOMER"  [BPC] #Gbn-121203/X3-25868
Local File =[F:ADS]DOSSIER+".BPSUPPLIER"  [BPS]
#Local File =[F:ADS]DOSSIER+".ITMMASTER"   [ITM] #Gbn-121203/X3-25868
Local File =[F:ADS]DOSSIER+".SINVOICE"    [SIH]
Local File =[F:ADS]DOSSIER+".PINVOICE"    [PIH]
Local File =[F:ADS]DOSSIER+".PERIOD"      [PER]
Local File =[F:ADS]DOSSIER+".FISCALYEAR"  [FIY]
Local File =[F:ADS]DOSSIER+".GACCOUNT"    [GAC]
#Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU]  #Gbn-121203/X3-25868
#Local File =[F:ADS]DOSSIER+".TABCUR"     [TCU0] #Gbn-121203/X3-25868
#Local File =[F:ADS]DOSSIER+".TABCHANGE"   [TCH] #Gbn-121203/X3-25868
#Local File =[F:ADS]DOSSIER+".COMPANY"     [CPY] #Gbn-121203/X3-25868
#Local File =[F:ADS]DOSSIER+".FACILITY"    [FCY] #Gbn-121203/X3-25868
#----- Tables vente -----#
Local File =[F:ADS]DOSSIER+".SQUOTE"      [SQH]
Local File =[F:ADS]DOSSIER+".SQUOTED"     [SQD]
Local File =[F:ADS]DOSSIER+".SORDER"      [SOH]
Local File =[F:ADS]DOSSIER+".SDELIVERY"   [SDH]
Local File =[F:ADS]DOSSIER+".SDELIVERYD"  [SDD]
Local File =[F:ADS]DOSSIER+".SINVOICEV"   [SIV]
Local File =[F:ADS]DOSSIER+".SRETURN"     [SRH]
#----- Tables achats -----#
If [F:ADS]MODULE(5)=2
  Local File =[F:ADS]DOSSIER+".PQUOTAT"   [PQH]
  Local File =[F:ADS]DOSSIER+".PORDER"    [POH]
  Local File =[F:ADS]DOSSIER+".PORDERQ"   [POQ]
  Local File =[F:ADS]DOSSIER+".PRECEIPT"  [PTH]
  Local File =[F:ADS]DOSSIER+".PRECEIPTD" [PTD]
Endif
#----- Tables tiers -----#
If [F:ADS]MODULE(2)=2
  Local File =[F:ADS]DOSSIER+".PAYMENTH"  [PYH]
  Local File =[F:ADS]DOSSIER+".TABPAYTYP" [TPY]
Endif
#----- Tables comptabilité -----#
If [F:ADS]MODULE(1)=2
  Local File =[F:ADS]DOSSIER+".BALANCE"   [BAL]
Endif

#Gbn-121203/X3-25868
Gosub OUVRE_SAL From UUMGTRTSAL00
If GOK<>1
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL52",7,ERR) From TRTMIG : #7=Erreur
  Goto FIN
Endif

#If val(VERSION)<GMIGX3VER60      : # 101462  : Exécuter ssi on vient d'une version antérieure à la V6
If VERSION<GMIGX3VER60
  #Gosub INISOC From UUMGTRTSAL00 : # 101462 #Gbn-121203/X3-25868- Call to OUVRE_SAL added above. call to INISOC at the end of OUVRE_SAL.

  #--------------------------------------------#
  # L_TOUSOC    : Indicateur toutes société    #
  #               1 = Non,  2 = Oui            #
  # L_SOC       : Société à traiter            #
  # L_TOUCLIENT : Indicateur tous clients      #
  #               1 = Non,  2 = Oui            #
  # L_CLIENT    : Client à traiter             #
  # L_TRACE     : Ecriture d'une trrace        #
  #               1 = Non,  2 = Oui            #
  #--------------------------------------------#
  Call RESYNCHRO_BPCMVT(2,"",2,"",2) From FUNBPCMVT
Endif                            : # 101462

#Gbn-121203/X3-25868
If GOK<1
  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL52",7,ERR) From TRTMIG : #7=Erreur
Endif

$FIN #Gbn-121203/X3-25868

#-----
Close Local File [MVC], [LCM], [BPR], [BPC], [ITM], [SIH], [PER], [FIY], [GAC],
&                [TCU], [TCU0], [TCH], [CPY], [FCY], [SQH], [SQD], [SOH], [SDH], [SDD],
&                [SIV], [SRH]
#-----
If [F:ADS]MODULE(2)=2 Close Local File [PYH], [TPY] : Endif
If [F:ADS]MODULE(1)=2 Close Local File [BAL] : Endif
#If GOK<1
#  Call MIGSTKENDFLG (DOSSIER,"UUMGTRTSAL52",7,ERR) From TRTMIG : #7=Erreur
#Endif
Call MIGTRTEND (DOSSIER,"UUMGTRTSAL52") From TRTMIG
#-----
Gosub UNSET_FIRST From TRTFIRST

Call ECR_TIME("UUMGTRTSAL52 Customer Transactions Process 2 : Ended") From DOSSUB
End

########################################################################
# Pour exécution automatique  en gestion de patch                      #
########################################################################
Subprog PATCH(APPLI)
Value Char    APPLI
If APPLI=GDOSX3 : End : Endif
If clalev([F:ADS])=0  Local File ADOSSIER [ADS] : Endif
# Issue 106947 - 20150811 by LD : Migration of historic folder
#Read [ADS] DOSSIER=APPLI : If fstat Raz [F:ADS] : Endif
If func DOSSUB.FILL_ADS(APPLI)=0 : End : Endif
# Issue 106947 - 20150811 by LD
Call MAJ_UUMGTRTSAL52(APPLI)
End

#######################################################################
# Pour exécution depuis dosmaj (validation dossier)
########################################################################
Subprog UTI_MOUL (APPLI)
Value Char    APPLI
If APPLI=GDOSX3 End : Endif
Call MAJ_UUMGTRTSAL52(APPLI)
End

