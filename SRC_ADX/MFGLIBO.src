############################################################################################
# Mise à jour de la liste des opérations liées à l'OF
Subprog UPDOPE(LCOD,LMSG, LALT)
Value    Integer  LCOD
Value    Integer  LMSG
Value    Integer  LALT
Local    Date     WDAT
# Issue 110935 - 2016-04-20 by BEEBE : Deactivate EP PE_ROUDATCTL for product managed by version
Local Char WITMREF(GLONITM)

# un petit message pour patienter ...
If LMSG = 1 : Call TEMPON(mess(93,195,1)) From GESECRAN : Endif

# Issue 105251 GA 04/2015 EP to use end date instead of [M:MFG1]STRDAT to check availability of operations
#WDAT=[M:MFG1]STRDAT
# Check validity date of the link

WITMREF = [M:MFG1]ITMREF
If clalev([F:ITM])=0 | [F:ITM]ITMREF <> WITMREF
    Gosub READ_ITM From ITMLIB
Endif

Local Integer WROUDATCTL : WROUDATCTL=2
If dim([F:ITM]ECCFLG)<=0 | [F:ITM]ECCFLG<>2
    Gosub PE_ROUDATCTL From MFGAUTLIB
Endif
# End issue 110935
Case WROUDATCTL
   When 1       : WDAT=[M:MFG1]ENDDAT
   When Default : WDAT=[M:MFG1]STRDAT  # standard mode
Endcase
If WDAT=[0/0/0] WDAT=date$ Endif

Case LCOD
    When 1
      Call SUPOPE(2)
    When 2
      # Issue 111414 - 2015-12-30 by GH : Operation load for a version in derogation
      If dim([M:MFG1]ROUECCMAJ)=1 & [M:MFG1]ROUECCMAJ<>""
         Call CORDAT([M:MFG1]ROUNUM,[M:MFG1]ROUECCMAJ,[M:MFG1]ROUECCMIN,[M:MFG0]MFGFCY,WDAT) From RVMLIB
      Endif
      # Issue X3-55362 - 2017-09-11 by JUSYN : Call prog to clarify if Route load is modification for a versioned product
      Call VROULOAD
      # End issue X3-55362
      Call GENOPE(WDAT,LALT,LMSG)
Endcase

If LMSG = 1 : Call TEMPOFF From GESECRAN : Endif
End

############################################################
# Recherche des opérations de la gamme lancée
Subprog GENOPE(CDAT,CALT,CMSG)
Value    Date     CDAT     # date référence
Value    Integer  CALT     # alternative gamme
Value    Integer  CMSG     # message
Local    Integer  I
Local    Integer  VOPE

# si des opérations existent (cas de la modif de gamme), on les supprime
If [M:MFG3]NBLIG <> 0 : Call SUPOPE(1) : Endif

# point d'entrée génération liste opérations 12264
Local Integer LRET : LRET = 0
GPOINT = "ROUDET" : Gosub ENTREE From EXEFNC
If LRET = 9 : LRET = 0 : End : Endif

# lecture de l'entête de gamme (déjà contrôlée)
If [F:ROH]ITMREF <> [M:MFG1]ROUNUM
    Read [ROH]ROH0=[M:MFG1]ROUNUM;CALT;[M:MFG0]MFGFCY : # Beryl Site en fin de clé primaire
    If fstat : End : Endif
Endif

# recherche des opérations valides
VOPE=0
# FQ 77863 GA 11/2011 vérifier aussi VALSTRDAT # 10.02 Performances
For [ROO]ROO0 Where FCY = [F:ROH]FCY & ITMREF = [F:ROH]ITMREF & ROUALT = [F:ROH]ROUALT
&             & OPENUM<>VOPE
&             & (VALENDDAT=[0/0/0] | (VALENDDAT >= CDAT & VALENDDAT<>[0/0/0]) )
&             & (VALSTRDAT=[0/0/0] | (VALSTRDAT <= CDAT & VALSTRDAT<>[0/0/0]) )
    If [F:ROO]OPENUM<>VOPE
        VOPE=[F:ROO]OPENUM
        Call DISPLAY_OPE
    Endif
    If dim([M:MFG3]EXTWST) < [M:MFG3]NBLIG + 2 : Break : Endif
Next
#
Call RESEQ_JAL From MFGSCD
If [M:MFG3]NBLIG <> 0
    [M:MFG0]CFMFLG = 2
    If CMSG <> 0 : Affzo [M:MFG3]1-99 : End : Endif
Endif
#
End

############################################################
# alimentation de la classe écran
Subprog DISPLAY_OPE
Local Integer LIG, SLIG
Local Decimal WMFGEXTQTY
Local Integer I, J
Local Decimal WCOEFF
Local Char    WCCE(20) : # sections analytiques (TB 21/03/00)
#
LIG = [M:MFG3]NBLIG
#
#    llc 03.01 8593
nolign = LIG + 1
[M:MFG3] = [F:ROO]

[M:MFG3]MFOTEX(LIG)    = [F:ROO]ROOTEX
[M:MFG3]OPENUM(LIG)    = [F:ROO]OPENUM
[M:MFG3]STDOPENUM(LIG) = [F:ROO]STDOPENUM
[M:MFG3]ROUOPENUM(LIG) = [F:ROO]OPENUM
[M:MFG3]OPESPLNUM(LIG) = 0
[M:MFG3]RPLIND(LIG)    = [F:ROO]RPLIND
[M:MFG3]OPESTA(LIG)    = 1
[M:MFG3]EXTWST(LIG)    = [F:ROO]WST
# lecture poste pour centre de charge et type
Read [MWS]WST0=[F:ROO]WST;[M:MFG0]MFGFCY
If ! fstat
    [M:MFG3]WCR(LIG)        = [F:MWS]WCR
    [M:MFG3]EXTWSTSHO(LIG)  = [F:MWS]WSTSHO
    [M:MFG3]WSTTYP(LIG)     = [F:MWS]WSTTYP
    [M:MFG3]XWSTTYP(LIG)    = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
    [M:MFG3]WSTEFF(LIG)     = [F:MWS]EFF
Endif
# y a t-il une matière associée à cette opération ?
Call ANALYSE_OPELOC([M:MFG3]OPENUM(LIG), LIG, [M:MFG3]EXTWST(LIG),[M:MFG0]MFGFCY)
Call ANALYSE_OPESTR("MFG3",[M:MFG3]OPENUM(LIG), LIG, [M:MFG3]EXTWST(LIG),[M:MFG0]MFGFCY) # llc 07.01 9728 (sous-traitance)
# OF non jalonné pour l'instant, dates = dates entête OF
[M:MFG3]OPESTR(LIG)    = [M:MFG1]STRDAT
[M:MFG3]OPEEND(LIG)    = [M:MFG1]ENDDAT
#
[M:MFG3]ROODES(LIG)    = [F:ROO]ROODES
[M:MFG3]TIMUOMCOD(LIG) = [F:ROH]TIMUOMCOD
[M:MFG3]OPEUOM(LIG)    = [F:ROO]OPEUOM
# sr 08.02 1.4.0 récup éventuelle de la formule 6617
If [F:ROO]OPESTUFOR <> ""
   Read [F:TFO]TFO0=2;[F:ROO]OPESTUFOR
   If !fstat
       # se repositionner éventuellement sur l'article produit
       If [F:ITM]ITMREF <> [M:MFG1]ITMREF(0)
           Read [F:ITM]ITM0 = [M:MFG1]ITMREF(0)
           If fstat : Raz [F:ITM] : Endif
       Endif
       If [F:ITF]ITMREF <> [M:MFG1]ITMREF(0) | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
           Read [F:ITF]ITF0 = [M:MFG1]ITMREF(0);[M:MFG0]MFGFCY
           If fstat : Raz [F:ITF] : Endif
       Endif
       If evalue([F:TFO]FORFOR) <> 0
           [M:MFG3]OPESTUCOE(LIG) = evalue([F:TFO]FORFOR)
       Elsif [F:ROO]OPESTUCOE <> 0
           [M:MFG3]OPESTUCOE(LIG) = [F:ROO]OPESTUCOE
       Else
            [M:MFG3]OPESTUCOE(LIG) = 1
       Endif
   Else
    [M:MFG3]OPESTUCOE(LIG) = [F:ROO]OPESTUCOE
   Endif
Else
   [M:MFG3]OPESTUCOE(LIG) = [F:ROO]OPESTUCOE
Endif
[M:MFG3]SCOCOD(LIG)    = [F:ROO]SCOCOD
[M:MFG3]SCOWST(LIG)    = [F:ROO]SCOWST
# si sous-traitance, lecture poste correspondant
If [F:ROO]SCOCOD <> 1
    Read [MWS]WST0=[F:ROO]SCOWST;[M:MFG0]MFGFCY
    If ! fstat : [M:MFG3]SCOWCR(LIG)= [F:MWS]WCR : Endif
Endif
[M:MFG3]SCOITMREF(LIG) = [F:ROO]SCOITMREF
[M:MFG3]BPRNUM(LIG)    = [F:ROO]BPRNUM                # llc 02.01 5977 + 12.03 MM
[M:MFG3]BPAADD(LIG)    = [F:ROO]BPAADD                # FQ 55167 GA 05/2009
[M:MFG3]REFPRI(LIG)    = [F:ROO]REFPRI                # llc 02.01 5977
# si article sous-traitance renseigné, on récupère le délai et l'UA
# FQ 74274 GA 10/2011 code déplacé dans une fonction pour réutilisation depuis SUBMFG3 et MFGAUTLIB
Call COMPLETE_OPEUOM([F:ROH]ITMREF,[F:ROO]SCOITMREF,[F:ROO]BPRNUM,[M:MFG3]SCOLTI(LIG)
&                   ,[M:MFG3]OPEUOM(LIG),[M:MFG3]OPESTRCOE(LIG),[M:MFG3]SCOPUU(LIG))
[M:MFG3]EXTLAB(LIG)    = [F:ROO]LABWST
# lecture poste pour centre de charge m-o
Read [MWS]WST0=[F:ROO]LABWST;[M:MFG0]MFGFCY
If ! fstat
    [M:MFG3]LABWCR(LIG)     = [F:MWS]WCR
    [M:MFG3]EXTLABSHO(LIG)  = [F:MWS]WSTSHO
Endif
#
[M:MFG3]EXTWSTNBR(LIG) = [F:ROO]WSTNBR
[M:MFG3]EXTLABNBR(LIG) = [F:ROO]LABNBR
[M:MFG3]SETLABCOE(LIG) = [F:ROO]SETLABCOE
[M:MFG3]OPELABCOE(LIG) = [F:ROO]OPELABCOE
# sr 08.02 1.4.0 récup éventuelle de la formule
If [F:ROO]OPESTUFOR <> ""
   Read [F:TFO]TFO0=2;[F:ROO]OPESTUFOR
   If !fstat
       # se repositionner éventuellement sur l'article produit
       If [F:ITM]ITMREF <> [M:MFG1]ITMREF(0)
           Read [F:ITM]ITM0 = [M:MFG1]ITMREF(0)
           If fstat : Raz [F:ITM] : Endif
       Endif
       If [F:ITF]ITMREF <> [M:MFG1]ITMREF(0) | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
           Read [F:ITF]ITF0 = [M:MFG1]ITMREF(0);[M:MFG0]MFGFCY
           If fstat : Raz [F:ITF] : Endif
       Endif
       If evalue([F:TFO]FORFOR) <> 0
           [M:MFG3]OPESTUCOE(LIG) = evalue([F:TFO]FORFOR)
       Elsif [F:ROO]OPESTUCOE <> 0
           [M:MFG3]OPESTUCOE(LIG) = [F:ROO]OPESTUCOE
       Else
           [M:MFG3]OPESTUCOE(LIG) = 1
       Endif
   Else
    [M:MFG3]OPESTUCOE(LIG) = [F:ROO]OPESTUCOE
   Endif
Else
   [M:MFG3]OPESTUCOE(LIG) = [F:ROO]OPESTUCOE
Endif

[M:MFG3]ROOTIMCOD(LIG) = [F:ROO]ROOTIMCOD
[M:MFG3]TIMCOD(LIG)    = [F:ROO]TIMCOD
[M:MFG3]BASQTY(LIG)    = [F:ROO]BASQTY
[M:MFG3]CAD(LIG)       = [F:ROO]CAD
[M:MFG3]OPEPLNNUM(LIG) = [F:ROO]OPEPLNNUM
[M:MFG3]OPEROUPCT(LIG) = [F:ROO]OPEROUPCT
[M:MFG3]TECCRD(LIG)    = [F:ROO]TECCRD
[M:MFG3]EQUNUM(LIG)    = [F:ROO]EQUNUM
[M:MFG3]FXGNUM(LIG)    = [F:ROO]FXGNUM
[M:MFG3]PRGNUM(LIG)    = [F:ROO]PRGNUM
[M:MFG3]EFF(LIG)       = [F:ROO]EFF
[M:MFG3]SHR(LIG)       = [F:ROO]SHR
# données capacité finie
If dim([M:MFG3]OPENUMLEV(I)) > 0 : [M:MFG3]OPENUMLEV(LIG) = [F:ROO]OPENUMLEV : Endif
If dim([M:MFG3]ALTOPECOD(I)) > 0 : [M:MFG3]ALTOPECOD(LIG) = [F:ROO]ALTOPECOD : Endif
If dim([M:MFG3]SPLCOD(I))    > 0 : [M:MFG3]SPLCOD(LIG)    = [F:ROO]SPLCOD    : Endif
If dim([M:MFG3]SPLMAXNBR(I)) > 0 : [M:MFG3]SPLMAXNBR(LIG) = [F:ROO]SPLMAXNBR : Endif
If dim([M:MFG3]RSTMAC(I))    > 0 : [M:MFG3]RSTMAC(LIG)    = [F:ROO]RSTMAC    : Endif
If dim([M:MFG3]SCHGRP(I))    > 0 : [M:MFG3]SCHGRP(LIG)    = [F:ROO]SCHGRP    : Endif
If dim([M:MFG3]SCHSBB(I))    > 0 : [M:MFG3]SCHSBB(LIG)    = [F:ROO]SCHSBB    : Endif            # 08.05 distinction des exemplaires
If dim([M:MFG3]GRPSETTIM(I)) > 0 : [M:MFG3]GRPSETTIM(LIG) = [F:ROO]GRPSETTIM : Endif

# llc 10.02 regroupement
If dim([M:MFG3]SCHGRP(I))    > 0
    [M:MFG3]SCHGRP(LIG)    = [F:ROO]SCHGRP
    If [F:ROO]SCHGRPFOR <> ""
       Read [F:TFO]TFO0=9;[F:ROO]SCHGRPFOR
       If !fstat
           # se repositionner éventuellement sur l'article produit
           If [F:ITM]ITMREF <> [M:MFG1]ITMREF(0)
               Read [F:ITM]ITM0 = [M:MFG1]ITMREF(0)
               If fstat : Raz [F:ITM] : Endif
           Endif
           If [F:ITF]ITMREF <> [M:MFG1]ITMREF(0) | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
               Read [F:ITF]ITF0 = [M:MFG1]ITMREF(0);[M:MFG0]MFGFCY
               If fstat : Raz [F:ITF] : Endif
           Endif
           If [F:MWS]WST <> [F:ROO]WST | [F:MWS]WCRFCY <> [M:MFG0]MFGFCY
               Read [MWS]WST0=[F:ROO]WST;[M:MFG0]MFGFCY
               If fstat : Raz [F:MWS] : Endif
           Endif
            If evalue([F:TFO]FORFOR) <> ""
               [M:MFG3]SCHGRP(LIG) = evalue([F:TFO]FORFOR)
           Elsif [F:ROO]SCHGRP <> ""
               [M:MFG3]SCHGRP(LIG) = [F:ROO]SCHGRP
           Endif
       Else
        [M:MFG3]SCHGRP(LIG) = [F:ROO]SCHGRP
       Endif
    Endif
Endif
# 08.05 distinction des exemplaires
If dim([M:MFG3]SCHSBB(I))    > 0
    [M:MFG3]SCHSBB(LIG)    = [F:ROO]SCHSBB
    If [F:ROO]SCHSBBFOR <> ""
       Read [F:TFO]TFO0=9;[F:ROO]SCHSBBFOR
       If !fstat
           # se repositionner éventuellement sur l'article produit
           If [F:ITM]ITMREF <> [M:MFG1]ITMREF(0)
               Read [F:ITM]ITM0 = [M:MFG1]ITMREF(0)
               If fstat : Raz [F:ITM] : Endif
           Endif
           If [F:ITF]ITMREF <> [M:MFG1]ITMREF(0) | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
               Read [F:ITF]ITF0 = [M:MFG1]ITMREF(0);[M:MFG0]MFGFCY
               If fstat : Raz [F:ITF] : Endif
           Endif
           If [F:MWS]WST <> [F:ROO]WST | [F:MWS]WCRFCY <> [M:MFG0]MFGFCY
               Read [MWS]WST0=[F:ROO]WST;[M:MFG0]MFGFCY
               If fstat : Raz [F:MWS] : Endif
           Endif
            If evalue([F:TFO]FORFOR) <> ""
               [M:MFG3]SCHSBB(LIG) = evalue([F:TFO]FORFOR)
           Elsif [F:ROO]SCHSBB <> ""
               [M:MFG3]SCHSBB(LIG) = [F:ROO]SCHSBB
           Endif
       Else
        [M:MFG3]SCHSBB(LIG) = [F:ROO]SCHSBB
       Endif
    Endif
Endif

# calcul des temps
WMFGEXTQTY    = [M:MFG1]MFGEXTQTY
Call CAL_OPE_TIME("MFG3", WMFGEXTQTY, LIG, [M:MFG1]NBLIG, [M:MFG1]LTIREDCOE)
#
# lecture des données jalonnements
Read [ROS]ROS0=[F:ROH]FCY;[F:ROH]ITMREF;[F:ROH]ROUALT;[F:ROO]OPENUM
If !fstat
    [M:MFG3]NEXOPENUM(LIG) = [F:ROS]NEXOPENUM
    [M:MFG3]SCDCOD(LIG)    = [F:ROS]SCDCOD
    [M:MFG3]SCDTIM(LIG)    = [F:ROS]SCDTIM
    [M:MFG3]SCDQTY(LIG)    = [F:ROS]SCDQTY
    [M:MFG3]SCDLOT(LIG)    = [F:ROS]SCDLOT
    [M:MFG3]DACMST(LIG)    = [F:ROS]DACMST
    [M:MFG3]MFGMST(LIG)    = [F:ROS]MFGMST
    If [F:ROS]SCDCOD = 2
        Read [ITF]ITF0=[F:ROH]ITMREF;[M:MFG0]MFGFCY
        If !fstat : [M:MFG3]LOTQTY(LIG) = [F:ITF]MFGLOTQTY : Endif
    Else
        [M:MFG3]LOTQTY(LIG) = 0
    Endif
Endif
#
[M:MFG3]STDWST(LIG)        = [M:MFG3]EXTWST(LIG)
[M:MFG3]STDLAB(LIG)        = [M:MFG3]EXTLAB(LIG)
[M:MFG3]STDWSTNBR(LIG)     = [M:MFG3]EXTWSTNBR(LIG)
[M:MFG3]STDLABNBR(LIG)     = [M:MFG3]EXTLABNBR(LIG)
[M:MFG3]STDUNTTIM(LIG)     = [M:MFG3]EXTUNTTIM(LIG)
[M:MFG3]STDSETTIM(LIG)     = [M:MFG3]EXTSETTIM(LIG)
[M:MFG3]STDOPETIM(LIG)     = [M:MFG3]EXTOPETIM(LIG)
[M:MFG3]STDQTY(LIG)        = [M:MFG3]EXTQTY(LIG)
#
[M:MFG3]MFOTRKFLG(LIG)     = 1
[M:MFG3]ITMLINNBR(LIG)     = [M:MFG1]NBLIG
# Issue X3-55362 - 2017-09-12 by JUSYN : Set revision code to 1 if operations have been reloaded and are now displayed
If dim([M:MFG1]ROUECCMAJ) > 0
    If dim([M:MFG3]REVCOD(I)) > 0
        If GOPECRICHG & GMFGROPE > 0 & GMFGREV=2 & GREP <> "C"
            # Permission to do critical changes on operations / reload on route / revision history written / not for creation of WO
            [M:MFG3]REVCOD(LIG) = 1  # = Add
        Endif
    Endif
Endif
# End issue X3-55362
####################################################################################
# chargement des sections analytiques (machine et m-o)
# car l'init ne se fait pas en chargeant et affichant l'écran   (TB  21/03/00)
SLIG = nolign
nolign = LIG + 1 : # pour que le parametrage section par défaut marche
If [F:MWS]WST <> [F:ROO]WST
  Read [MWS]WST0=[F:ROO]WST;[F:ROO]FCY
Endif
For J = 1 To GNBDIE
  Call INISEC(WCCE,"MFO",J) From TRTX3CPT
  Assign "[M:MFG3]CCE"+num$(J)+"("+num$(LIG)+")" With WCCE
Next
# lecture POSTE MAIN d'oeuvre pour section de valo (contenant les CCE)(28/09)
If [M:MFG3]EXTLAB(LIG) <> ""
 Read [MWS]WST0=[M:MFG3]EXTLAB(LIG);[F:ROO]FCY
 If !fstat
  For J = 1 To GNBDIE
    Call INISEC(WCCE,"MFO",J) From TRTX3CPT
    Assign "[M:MFG3]LABCCE"+num$(J)+"("+num$(LIG)+")" With WCCE
  Next
 Endif
Endif

# FQ 64447 SAGE(OMA) 29/04/2010
GPOINT = "ROULIG" : Gosub ENTREE From EXEFNC

nolign = SLIG
######################################################################################

# incrémentation du nombre de ligne + nombre opés
[M:MFG3]NBLIG     += 1
[M:MFG1]DOPENBR   += 1
#
End

############################################################
# Suppression des opérations
Subprog SUPOPE(LDIS)
Value Integer LDIS

# 02.05 28382    raz emplacement des matières liées à une opération
Local Integer I
For I = 0 To [M:MFG2]NBLIG - 1
    # Issue X-55362 - 2017-09-12 by JUSYN : Revision treatment for deletion of versioned products
    If dim([M:MFG1]ROUECCMAJ) > 0
        If GMFGREV=2 & [M:MFG1]ROUECCMAJ <> ""
            [M:MFG3]REVCOD(I) = 3 # Excluded (Cancelled)
            [M:MFG3]REVREASON(I) = mess(407,193,1)   # Operation has been deleted
            Call HISTO_REVMFG ("MOR",3 , I, "G") From TRTREVMFG
        Endif
    Endif
    # End issue X3-55362
    If [M:MFG2]BOMOPE(I) <> 0 : [M:MFG2]LOC(I) = "" : Endif
Next I

# FQ 59777 GA 11/2009 plantage si le tableau est vide
If [M:MFG3]NBLIG>0
    # suppression des lignes
    Dela 0,[M:MFG3]NBLIG [M:MFG3]NBLIG
    [M:MFG3]NBLIG = 0
Endif

[M:MFG1]DOPENBR = 0
[M:MFG3]SCDFLG  = 1      # 80808
# affichage si demandé
Case LDIS
    When 1:    # ben rien ...
    When 2:    Affzo [M:MFG3]1-99
Endcase
#
End

####################################################################################
# calcul des quantités et temps d'opération à partir de la gamme
# [F:ROO] doit être chargé
Subprog CAL_OPE_TIME(ABMSK, LMFGEXTQTY, L, NBART, LLTIRED)
Value     Char     ABMSK        # masque à alimenter
Value     Decimal  LMFGEXTQTY   # quantité lancée
Value     Shortint L            # no ligne masque
Value     Shortint NBART        # nombre d'article(s) lancé(s)
Value     Decimal  LLTIRED      # % compression

#
Case ABMSK
    When "MFO1":
        # calcul de la quantité de l'opération (quantité lancée / coeff US/UO)
        # dans la première version on ne gère pas de perte sur les opérations ...
        # sr 08.02 1.4.0 récup éventuelle de la formule
        If [F:ROO]OPESTUFOR <> ""
           Read [F:TFO]TFO0=2;[F:ROO]OPESTUFOR
           If !fstat
               # se repositionner éventuellement sur l'article produit
               If [F:ITM]ITMREF <> [M:MFG1]ITMREF(0)
                   Read [F:ITM]ITM0 = [M:MFG1]ITMREF(0)
                   If fstat : Raz [F:ITM] : Endif
               Endif
               If [F:ITF]ITMREF <> [M:MFG1]ITMREF(0) | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
                   Read [F:ITF]ITF0 = [M:MFG1]ITMREF(0);[M:MFG0]MFGFCY
                   If fstat : Raz [F:ITF] : Endif
               Endif
               If evalue([F:TFO]FORFOR) <> 0
                   [M:MFO1]EXTQTY = LMFGEXTQTY * evalue([F:TFO]FORFOR)
               Elsif [F:ROO]OPESTUCOE <> 0
                   [M:MFO1]EXTQTY = LMFGEXTQTY *[F:ROO]OPESTUCOE
               Else
                   [M:MFO1]EXTQTY = LMFGEXTQTY
               Endif
           Else
                [M:MFO1]EXTQTY = LMFGEXTQTY *[F:ROO]OPESTUCOE
           Endif
        Else
          [M:MFO1]EXTQTY = LMFGEXTQTY * [F:ROO]OPESTUCOE
        Endif

        # application de la perte
        If [F:ROO]SHR <> 0
            # 37492 MM 08.06: Point d'entrée permettant d'ignorer la perte opératoire
            GPE =0
            GPOINT = "WITHSHR" : Gosub ENTREE From EXEFNC
            If !GPE
                [M:MFO1]EXTQTY = [M:MFO1]EXTQTY * (1 + ([F:ROO]SHR / 100))
            Endif
        Endif
        #sr 06.01
        Call QTEARR([M:MFO1]EXTQTY,[M:MFO1]OPEUOM) From TRTDIV        # llc 26.09.01

        [M:MFO1]EXTSTUQTY    = LMFGEXTQTY
        [M:MFO1]EXTSTRQTY    = [M:MFO1]EXTQTY    *  [M:MFO2]OPESTRCOE
        # FQ 77413 GA 10/2011 arrondir
        Call QTEARR([M:MFO1]EXTSTRQTY,[M:MFO1]SCOPUU) From TRTDIV

        # initialisation temps fixes (appliqués 1 fois pour l'OF)
        [M:MFO1]PRPTIM       = [F:ROO]PRPTIM
        [M:MFO1]PSPTIM       = [F:ROO]PSPTIM
        [M:MFO1]EXTSETTIM    = [F:ROO]SETTIM
        [M:MFO1]WAITIM       = [F:ROO]WAITIM

        # application du taux de compression des temps morts
        # si 1    <= % compression <= 100, on comprime les temps suivant le pourcentage
        # si 101  <= % compression <= n  , on augmente les temps de (pourcentage - 100)
        # exemple: compression = 40 %, temps passe de 1h à 0,6 h
        #          compression = 120%, temps passe de 1h à 1,2 h
        If LLTIRED > 100
            LLTIRED -= 100
            LLTIRED *= -1
        Endif
        Case GTPSCOMP
            When 1:    # ben rien
            When 2:    # compression temps attente uniquement
                       [M:MFO1]WAITIM       = [M:MFO1]WAITIM    *
&                                             ((100 - LLTIRED) / 100)
            When 3:    # compression temps préparation + post-opératoire
                       [M:MFO1]PRPTIM       = [M:MFO1]PRPTIM    *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFO1]PSPTIM       = [M:MFO1]PSPTIM    *
&                                             ((100 - LLTIRED) / 100)
            When 4:    # compression des 3 temps
                       [M:MFO1]WAITIM       = [M:MFO1]WAITIM    *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFO1]PRPTIM       = [M:MFO1]PRPTIM    *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFO1]PSPTIM       = [M:MFO1]PSPTIM    *
&                                             ((100 - LLTIRED) / 100)
            When 5:    # compresssion temps de préparation
                       [M:MFO1]PRPTIM       = [M:MFO1]PRPTIM    *
&                                             ((100 - LLTIRED) / 100)
            When 6:    # compresssion temps post-opératoire
                       [M:MFO1]PSPTIM       = [M:MFO1]PSPTIM    *
&                                             ((100 - LLTIRED) / 100)
            When 7:    # compression temps préparation + attente
                       [M:MFO1]PRPTIM       = [M:MFO1]PRPTIM    *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFO1]WAITIM       = [M:MFO1]WAITIM    *
&                                             ((100 - LLTIRED) / 100)
            When 8:    # compression temps post-opératoire + attente
                       [M:MFO1]PSPTIM       = [M:MFO1]PSPTIM    *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFO1]WAITIM       = [M:MFO1]WAITIM    *
&                                             ((100 - LLTIRED) / 100)
        Endcase

        # calcul temps variable (dépendant de la quantité)
        # on ne divise pas le temps opératoire par le nombre de postes m-o,
        # le moteur de jalonnement s'en occupera ...
        Case [F:ROO]ROOTIMCOD    # suivant type tps opératoire
            When 1: # proportionnel     (temps = quantité / quantité base * temps)
                    [M:MFO1]EXTOPETIM       = [M:MFO1]EXTQTY    *
&                                             [F:ROO]OPETIM           /
&                                             [F:ROO]BASQTY
            When 2: # cadence (temps = quantité / cadence)
                    # llc 02.02 13175
                    If [F:ROO]CAD <> 0
                        [M:MFO1]EXTOPETIM       = [M:MFO1]EXTQTY    /
&                                                 [F:ROO]CAD
                    Endif
            When 3: # forfaitaire
                    [M:MFO1]EXTOPETIM       = [F:ROO]OPETIM
        Endcase


# llc 03.01 multi-exemplaire
# si nombre poste > 1, on divise le temps
# opératoire par le nombre de poste
#        If [M:MFO1]EXTWSTNBR    > 1
#            [M:MFO1]EXTOPETIM    = [M:MFO1]EXTOPETIM    /
#&                                  [M:MFO1]EXTWSTNBR
#        Endif
        # application de l'efficience du poste de charge et de l'opération
        # (l'efficience ne concerne que les temps de réglage et opératoire)
        # temps = temps * efficience poste/100 * efficience opération/100
        Case GWSTEFFINH
            When 1:            # Issue 94895 - 2014-11-18 by CCC
                               If clalev([F:MWS])=0 : Local File WORKSTATIO [MWS] : Endif
                               Raz [F:MWS]
                               If [M:MFO1]EXTLAB<>""
                                   Read [MWS]WST0=[M:MFO1]EXTLAB;[M:MFG0]MFGFCY
                               Endif
                               If [F:MWS]EFF=0 : [F:MWS]EFF=100 : Endif

                               # 04.05 13839
                               If GOPEEFFAPP = 1
                                   [M:MFO1]EXTSETTIM        = [M:MFO1]EXTSETTIM    /
&                                                             ([F:ROO]EFF / 100) /
&                                                             ([M:MFO1]WSTEFF    / 100)
                                   # Issue 94895 - 2014-11-18 by CCC
                                   [M:MFO1]SETLABCOE        = arr([M:MFO1]SETLABCOE /
&                                                             ([F:MWS]EFF    / 100),0.001)

                               Endif
                               [M:MFO1]EXTOPETIM        = [M:MFO1]EXTOPETIM    /
&                                                         ([F:ROO]EFF / 100) /
&                                                         ([M:MFO1]WSTEFF    / 100)
                               # Issue 94895 - 2014-11-18 by CCC
                               [M:MFO1]OPELABCOE        = arr( [M:MFO1]OPELABCOE /
&                                                         ([F:MWS]EFF    / 100), 0.001)
            When Default:      # 04.05 13839
                               If GOPEEFFAPP = 1
                                   [M:MFO1]EXTSETTIM        = [M:MFO1]EXTSETTIM    /
&                                                             ([F:ROO]EFF / 100)
                               Endif
                               [M:MFO1]EXTOPETIM        = [M:MFO1]EXTOPETIM    /
&                                                         ([F:ROO]EFF / 100)
        Endcase

        # calcul du temps unitaire = temps opératoire calculé / quantité
        If [M:MFO1]EXTQTY<>0
            [M:MFO1]EXTUNTTIM        =  [M:MFO1]EXTOPETIM    / [M:MFO1]EXTQTY
        Endif

        # calcul du total hors charge, uniquement pour affichage
        # Formule: tps préparation + (le plus grand entre tps attente et post-opératoire)
        # car on considère que les tps d'attente et post-opératoire sont //
        If  [M:MFO1]WAITIM       > [M:MFO1]PSPTIM
            [M:MFO1]FXDTIM    = [M:MFO1]PRPTIM    +
&                               [M:MFO1]WAITIM
        Else
            [M:MFO1]FXDTIM    = [M:MFO1]PRPTIM    +
&                               [M:MFO1]PSPTIM
        Endif

        # calcul du total charge, uniquement pour affichage
        # Formule: tps réglage + tps opératoire
        [M:MFO1]VARTIM        = [M:MFO1]EXTSETTIM    +
&                               [M:MFO1]EXTOPETIM

        # arrondis
        [M:MFO1]WAITIM        = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]WAITIM   )
        [M:MFO1]PRPTIM        = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]PRPTIM   )
        [M:MFO1]PSPTIM        = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]PSPTIM   )
        [M:MFO1]EXTSETTIM     = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]EXTSETTIM   )
        [M:MFO1]EXTOPETIM     = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]EXTOPETIM   )
        [M:MFO1]EXTUNTTIM     = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]EXTUNTTIM   )
        [M:MFO1]FXDTIM        = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]FXDTIM   )
        [M:MFO1]VARTIM        = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]VARTIM   )
    When Default:
        # calcul de la quantité de l'opération (quantité lancée / coeff US/UO)
        # dans la première version on ne gère pas de perte sur les opérations ...
        # sr 08.02 1.4.0 récup éventuelle de la formule
        If [F:ROO]OPESTUFOR <> ""
           Read [F:TFO]TFO0=2;[F:ROO]OPESTUFOR
           If !fstat
                # se repositionner éventuellement sur l'article produit
               If [F:ITM]ITMREF <> [M:MFG1]ITMREF(0)
                   Read [F:ITM]ITM0 = [M:MFG1]ITMREF(0)
                   If fstat : Raz [F:ITM] : Endif
               Endif
               If [F:ITF]ITMREF <> [M:MFG1]ITMREF(0) | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
                   Read [F:ITF]ITF0 = [M:MFG1]ITMREF(0);[M:MFG0]MFGFCY
                   If fstat : Raz [F:ITF] : Endif
               Endif
               If evalue([F:TFO]FORFOR) <> 0
                   [M:MFG3]EXTQTY(L) = LMFGEXTQTY * evalue([F:TFO]FORFOR)
               Elsif [F:ROO]OPESTUCOE <> 0
                   [M:MFG3]EXTQTY(L) = LMFGEXTQTY *[F:ROO]OPESTUCOE
               Else
                   [M:MFG3]EXTQTY(L) = LMFGEXTQTY
               Endif
           Else
                [M:MFG3]EXTQTY(L) = LMFGEXTQTY *[F:ROO]OPESTUCOE
           Endif
        Else
          [M:MFG3]EXTQTY(L) = LMFGEXTQTY * [F:ROO]OPESTUCOE
        Endif

        # application de la perte
        If [F:ROO]SHR <> 0
            # 37492 MM 08.06: Point d'entrée permettant d'ignorer la perte opératoire
            GPE =0
            GPOINT = "WITHSHR" : Gosub ENTREE From EXEFNC
            If !GPE
                [M:MFG3]EXTQTY(L) = [M:MFG3]EXTQTY(L) * (1 + ([F:ROO]SHR / 100))
            Endif
        Endif
       #sr 06.01
        Call QTEARR([M:MFG3]EXTQTY(L),[M:MFG3]OPEUOM(L)) From TRTDIV

        [M:MFG3]EXTSTUQTY(L) = LMFGEXTQTY
        [M:MFG3]EXTSTRQTY(L) = [M:MFG3]EXTQTY(L) *  [M:MFG3]OPESTRCOE(L)
        # FQ 77413 GA 10/2011 arrondir
        Call QTEARR([M:MFG3]EXTSTRQTY(L),[M:MFG3]SCOPUU(L)) From TRTDIV

        # initialisation temps fixes (appliqués 1 fois pour l'OF)
        [M:MFG3]PRPTIM(L)    = [F:ROO]PRPTIM
        [M:MFG3]PSPTIM(L)    = [F:ROO]PSPTIM
        [M:MFG3]EXTSETTIM(L) = [F:ROO]SETTIM
        [M:MFG3]WAITIM(L)    = [F:ROO]WAITIM

        # application du taux de compression des temps morts
        # si 1    <= % compression <= 100, on comprime les temps suivant le pourcentage
        # si 101  <= % compression <= n  , on augmente les temps de (pourcentage - 100)
        # exemple: compression = 40 %, temps passe de 1h à 0,6 h
        #          compression = 120%, temps passe de 1h à 1,2 h
        If LLTIRED > 100
            LLTIRED -= 100
            LLTIRED *= -1
        Endif
        Case GTPSCOMP
            When 1:    # ben rien
            When 2:    # compression temps attente uniquement
                       [M:MFG3]WAITIM(L)    = [M:MFG3]WAITIM(L) *
&                                             ((100 - LLTIRED) / 100)
            When 3:    # compression temps préparation + post-opératoire
                       [M:MFG3]PRPTIM(L)    = [M:MFG3]PRPTIM(L) *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFG3]PSPTIM(L)    = [M:MFG3]PSPTIM(L) *
&                                             ((100 - LLTIRED) / 100)
            When 4:    # compression des 3 temps
                       [M:MFG3]WAITIM(L)    = [M:MFG3]WAITIM(L) *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFG3]PRPTIM(L)    = [M:MFG3]PRPTIM(L) *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFG3]PSPTIM(L)    = [M:MFG3]PSPTIM(L) *
&                                             ((100 - LLTIRED) / 100)
            When 5:    # compresssion temps de préparation
                       [M:MFG3]PRPTIM(L)    = [M:MFG3]PRPTIM(L) *
&                                             ((100 - LLTIRED) / 100)
            When 6:    # compresssion temps post-opératoire
                       [M:MFG3]PSPTIM(L)    = [M:MFG3]PSPTIM(L) *
&                                             ((100 - LLTIRED) / 100)
            When 7:    # compression temps préparation + attente
                       [M:MFG3]PRPTIM(L)    = [M:MFG3]PRPTIM(L) *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFG3]WAITIM(L)    = [M:MFG3]WAITIM(L) *
&                                             ((100 - LLTIRED) / 100)
            When 8:    # compression temps post-opératoire + attente
                       [M:MFG3]PSPTIM(L)    = [M:MFG3]PSPTIM(L) *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFG3]WAITIM(L)    = [M:MFG3]WAITIM(L) *
&                                             ((100 - LLTIRED) / 100)
        Endcase

        # calcul temps variable (dépendant de la quantité)
        # on ne divise pas le temps opératoire par le nombre de postes m-o,
        # le moteur de jalonnement s'en occupera ...
        Case [F:ROO]ROOTIMCOD    # suivant type tps opératoire
            When 1: # proportionnel     (temps = quantité / quantité base * temps)
                    [M:MFG3]EXTOPETIM(L)    = [M:MFG3]EXTQTY(L) *
&                                             [F:ROO]OPETIM           /
&                                             [F:ROO]BASQTY
            When 2: # cadence (temps = quantité / cadence)
                    # llc 02.02 13175
                    If [F:ROO]CAD <> 0
                        [M:MFG3]EXTOPETIM(L)    = [M:MFG3]EXTQTY(L) /
&                                                 [F:ROO]CAD
                    Endif
            When 3: # forfaitaire
                    [M:MFG3]EXTOPETIM(L)    = [F:ROO]OPETIM
        Endcase

# llc 03.01 multi-exemplaire
# si nombre poste, on divise le temps
# opératoire par le nombre de poste
#        If [M:MFG3]EXTWSTNBR(L) > 1
#            [M:MFG3]EXTOPETIM(L) = [M:MFG3]EXTOPETIM(L) /
#&                                  [M:MFG3]EXTWSTNBR(L)
#        Endif

        # application de l'efficience du poste de charge et de l'opération
        # (l'efficience ne concerne que les temps de réglage et opératoire)
        # temps = temps * efficience poste/100 * efficience opération/100
      Case GWSTEFFINH
            When 1:                # Issue 94895 - 2014-11-18 by CCC
                                   If clalev([F:MWS])=0 : Local File WORKSTATIO [MWS] : Endif
                                   Raz [F:MWS]
                                   If [M:MFG3]EXTLAB(L)<>""
                                       Read [MWS]WST0=[M:MFG3]EXTLAB(L);[M:MFG0]MFGFCY
                                   Endif
                                   If [F:MWS]EFF=0 : [F:MWS]EFF=100 : Endif

                                   # 04.05 13839
                                   If GOPEEFFAPP = 1
                                       [M:MFG3]EXTSETTIM(L)     = [M:MFG3]EXTSETTIM(L) /
&                                                                 ([F:ROO]EFF / 100) /
&                                                                 ([M:MFG3]WSTEFF(L) / 100)
                                       # Issue 94895 - 2014-11-18 by CCC
                                       [M:MFG3]SETLABCOE(L)     = arr([M:MFG3]SETLABCOE(L) /
&                                                                 ([F:MWS]EFF    / 100), 0.001)
                                   Endif
                                   [M:MFG3]EXTOPETIM(L)     = [M:MFG3]EXTOPETIM(L) /
&                                                             ([F:ROO]EFF / 100) /
&                                                             ([M:MFG3]WSTEFF(L) / 100)
                                   # Issue 94895 - 2014-11-18 by CCC
                                   [M:MFG3]OPELABCOE(L)     = arr( [M:MFG3]OPELABCOE(L) /
&                                                             ([F:MWS]EFF    / 100), 0.001)
            When Default:          # 04.05 13839
                                   If GOPEEFFAPP = 1
                                       [M:MFG3]EXTSETTIM(L)     = [M:MFG3]EXTSETTIM(L) /
&                                                                 ([F:ROO]EFF / 100)
                                   Endif
                                   [M:MFG3]EXTOPETIM(L)     = [M:MFG3]EXTOPETIM(L) /
&                                                             ([F:ROO]EFF / 100)
        Endcase

        # calcul du temps unitaire = temps opératoire calculé / quantité
        If [M:MFG3]EXTQTY(L)<>0
            [M:MFG3]EXTUNTTIM(L)     =  [M:MFG3]EXTOPETIM(L) / [M:MFG3]EXTQTY(L)
        Endif

        # calcul du total hors charge, uniquement pour affichage
        # Formule: tps préparation + (le plus grand entre tps attente et post-opératoire)
        # car on considère que les tps d'attente et post-opératoire sont //
        If  [M:MFG3]WAITIM(L)    > [M:MFG3]PSPTIM(L)
            [M:MFG3]FXDTIM(L) = [M:MFG3]PRPTIM(L) +
&                               [M:MFG3]WAITIM(L)
        Else
            [M:MFG3]FXDTIM(L) = [M:MFG3]PRPTIM(L) +
&                               [M:MFG3]PSPTIM(L)
        Endif

        # calcul du total charge, uniquement pour affichage
        # Formule: tps réglage + tps opératoire
        [M:MFG3]VARTIM(L)     = [M:MFG3]EXTSETTIM(L) +
&                               [M:MFG3]EXTOPETIM(L)

        # arrondis
        [M:MFG3]WAITIM(L)     = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]WAITIM(L))
        [M:MFG3]PRPTIM(L)     = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]PRPTIM(L))
        [M:MFG3]PSPTIM(L)     = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]PSPTIM(L))
        [M:MFG3]EXTSETTIM(L)  = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]EXTSETTIM(L))
        [M:MFG3]EXTOPETIM(L)  = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]EXTOPETIM(L))
        [M:MFG3]EXTUNTTIM(L)  = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]EXTUNTTIM(L))
        [M:MFG3]FXDTIM(L)     = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]FXDTIM(L))
        [M:MFG3]VARTIM(L)     = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]VARTIM(L))
Endcase
#
End

####################################################################################
# calcul des quantités et temps d'opération à partir d'une opération standard
# [F:ROT] doit être chargé
# 17809 MM 07.05 : gestion d'un coef permettant de multiplier les temps liés à une ope standard
Subprog CAL_ROT_TIME(ABMSK, LMFGEXTQTY, L, NBART, LLTIRED,LTIMCOE)
Value     Char     ABMSK        # masque à alimenter
Value     Decimal  LMFGEXTQTY   # quantité lancée
Value     Shortint L            # no ligne masque
Value     Shortint NBART        # nombre d'article(s) lancé(s)
Value     Decimal  LLTIRED      # % compression
Value     Decimal  LTIMCOE      # coef multiplicateur des temps


Case ABMSK
    When "MFO1":
        # calcul de la quantité de l'opération (quantité lancée / coeff US/UO)
        # dans la première version on ne gère pas de perte sur les opérations ...
        # sr 08.02 1.4.0 récup éventuelle de la formule
        If [F:ROO]OPESTUFOR <> ""
           Read [F:TFO]TFO0=2;[F:ROO]OPESTUFOR
           If !fstat
               # se repositionner éventuellement sur l'article produit
               If [F:ITM]ITMREF <> [M:MFG1]ITMREF(0)
                   Read [F:ITM]ITM0 = [M:MFG1]ITMREF(0)
                   If fstat : Raz [F:ITM] : Endif
               Endif
               If [F:ITF]ITMREF <> [M:MFG1]ITMREF(0) | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
                   Read [F:ITF]ITF0 = [M:MFG1]ITMREF(0);[M:MFG0]MFGFCY
                   If fstat : Raz [F:ITF] : Endif
               Endif
               If  evalue([F:TFO]FORFOR) <> 0
                   [M:MFO1]EXTQTY = LMFGEXTQTY * evalue([F:TFO]FORFOR)
               Elsif [F:ROO]OPESTUCOE <> 0
                   [M:MFO1]EXTQTY = LMFGEXTQTY *[M:MFO1]OPESTUCOE
               Else
                   [M:MFO1]EXTQTY = LMFGEXTQTY
               Endif
           Else
                [M:MFO1]EXTQTY = LMFGEXTQTY *[M:MFO1]OPESTUCOE
           Endif
        Else
          [M:MFO1]EXTQTY = LMFGEXTQTY * [M:MFO1]OPESTUCOE
        Endif

        # application de la perte
        If [F:ROT]SHR <> 0
            [M:MFO1]EXTQTY = [M:MFO1]EXTQTY * (1 + ([F:ROT]SHR / 100))
        Endif

        [M:MFO1]EXTSTUQTY    = LMFGEXTQTY
        [M:MFO1]EXTSTRQTY    = [M:MFO1]EXTQTY    *  [M:MFO2]OPESTRCOE
        # FQ 77413 GA 10/2011 arrondir
        Call QTEARR([M:MFO1]EXTSTRQTY,[M:MFO1]SCOPUU) From TRTDIV

        # application du taux de compression des temps morts
        # si 1    <= % compression <= 100, on comprime les temps suivant le pourcentage
        # si 101  <= % compression <= n  , on augmente les temps de (pourcentage - 100)
        # exemple: compression = 40 %, temps passe de 1h à 0,6 h
        #          compression = 120%, temps passe de 1h à 1,2 h
        If LLTIRED > 100
            LLTIRED -= 100
            LLTIRED *= -1
        Endif
        Case GTPSCOMP
            When 1:    # ben rien
            When 2:    # compression temps attente uniquement
                       [M:MFO1]WAITIM       = [M:MFO1]WAITIM    *
&                                             ((100 - LLTIRED) / 100)
            When 3:    # compression temps préparation + post-opératoire
                       [M:MFO1]PRPTIM       = [M:MFO1]PRPTIM    *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFO1]PSPTIM       = [M:MFO1]PSPTIM    *
&                                             ((100 - LLTIRED) / 100)
            When 4:    # compression des 3 temps
                       [M:MFO1]WAITIM       = [M:MFO1]WAITIM    *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFO1]PRPTIM       = [M:MFO1]PRPTIM    *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFO1]PSPTIM       = [M:MFO1]PSPTIM    *
&                                             ((100 - LLTIRED) / 100)
            When 5:    # compresssion temps de préparation
                       [M:MFO1]PRPTIM       = [M:MFO1]PRPTIM    *
&                                             ((100 - LLTIRED) / 100)
            When 6:    # compresssion temps post-opératoire
                       [M:MFO1]PSPTIM       = [M:MFO1]PSPTIM    *
&                                             ((100 - LLTIRED) / 100)
            When 7:    # compression temps préparation + attente
                       [M:MFO1]PRPTIM       = [M:MFO1]PRPTIM    *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFO1]WAITIM       = [M:MFO1]WAITIM    *
&                                             ((100 - LLTIRED) / 100)
            When 8:    # compression temps post-opératoire + attente
                       [M:MFO1]PSPTIM       = [M:MFO1]PSPTIM    *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFO1]WAITIM       = [M:MFO1]WAITIM    *
&                                             ((100 - LLTIRED) / 100)

        Endcase

        # calcul temps variable (dépendant de la quantité)
        # on ne divise pas le temps opératoire par le nombre de postes m-o,
        # le moteur de jalonnement s'en occupera ...
        Case [F:ROT]ROOTIMCOD    # suivant type tps opératoire
            When 1: # proportionnel     (temps = quantité / quantité base * temps)
                    [M:MFO1]EXTOPETIM       = [M:MFO1]EXTQTY    *
&                                             [F:ROT]OPETIM * LTIMCOE   /
&                                             [F:ROT]BASQTY
            When 2: # cadence (temps = quantité / cadence)
                    # llc 02.02 13175
                    If [F:ROT]CAD <> 0
                        [M:MFO1]EXTOPETIM       = [M:MFO1]EXTQTY    /
&                                                 [F:ROT]CAD
                    Endif
            When 3: # forfaitaire
                    [M:MFO1]EXTOPETIM       = [F:ROT]OPETIM * LTIMCOE    # 17809 MM 07.05
        Endcase


        # application de l'efficience du poste de charge et de l'opération
        # (l'efficience ne concerne que les temps de réglage et opératoire)
        # temps = temps * efficience poste/100 * efficience opération/100
        Case GWSTEFFINH
            When 1:            # Issue 94895 - 2014-11-18 by CCC
                               If clalev([F:MWS])=0 : Local File WORKSTATIO [MWS] : Endif
                               Raz [F:MWS]
                               If [M:MFO1]EXTLAB<>""
                                   Read [MWS]WST0=[M:MFO1]EXTLAB;[M:MFG0]MFGFCY
                               Endif
                               If [F:MWS]EFF=0 : [F:MWS]EFF=100 : Endif

                               # 04.05 13839
                               If GOPEEFFAPP = 1
                                   [M:MFO1]EXTSETTIM        = [M:MFO1]EXTSETTIM    /
&                                                             ([F:ROT]EFF / 100) /
&                                                             ([M:MFO1]WSTEFF    / 100)
                                   # Issue 94895 - 2014-11-18 by CCC
                                   [M:MFO1]SETLABCOE        = arr( [M:MFO1]SETLABCOE /
&                                                             ([F:MWS]EFF    / 100), 0.001)

                               Endif
                               [M:MFO1]EXTOPETIM        = [M:MFO1]EXTOPETIM    /
&                                                         ([F:ROT]EFF / 100) /
&                                                         ([M:MFO1]WSTEFF    / 100)
                               # Issue 94895 - 2014-11-18 by CCC
                               [M:MFO1]OPELABCOE        = arr([M:MFO1]OPELABCOE /
&                                                         ([F:MWS]EFF    / 100), 0.001)
            When Default:      # 04.05 13839
                               If GOPEEFFAPP = 1
                                   [M:MFO1]EXTSETTIM        = [M:MFO1]EXTSETTIM    /
&                                                             ([F:ROT]EFF / 100)
                               Endif
                               [M:MFO1]EXTOPETIM        = [M:MFO1]EXTOPETIM    /
&                                                         ([F:ROT]EFF / 100)
        Endcase

        # calcul du temps unitaire = temps opératoire calculé / quantité
        [M:MFO1]EXTUNTTIM        =  [M:MFO1]EXTOPETIM    / [M:MFO1]EXTQTY

        # calcul du total hors charge, uniquement pour affichage
        # Formule: tps préparation + (le plus grand entre tps attente et post-opératoire)
        # car on considère que les tps d'attente et post-opératoire sont //
        If  [M:MFO1]WAITIM       > [M:MFO1]PSPTIM
            [M:MFO1]FXDTIM    = [M:MFO1]PRPTIM    +
&                               [M:MFO1]WAITIM
        Else
            [M:MFO1]FXDTIM    = [M:MFO1]PRPTIM    +
&                               [M:MFO1]PSPTIM
        Endif

        # calcul du total charge, uniquement pour affichage
        # Formule: tps réglage + tps opératoire
        [M:MFO1]VARTIM        = [M:MFO1]EXTSETTIM    +
&                               [M:MFO1]EXTOPETIM

        # arrondis
        [M:MFO1]WAITIM        = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]WAITIM   )
        [M:MFO1]PRPTIM        = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]PRPTIM   )
        [M:MFO1]PSPTIM        = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]PSPTIM   )
        [M:MFO1]EXTSETTIM     = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]EXTSETTIM   )
        [M:MFO1]EXTOPETIM     = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]EXTOPETIM   )
        [M:MFO1]EXTUNTTIM     = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]EXTUNTTIM   )
        [M:MFO1]FXDTIM        = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]FXDTIM   )
        [M:MFO1]VARTIM        = func TRTX3.ARRTYP("", "", "TIH", [M:MFO1]VARTIM   )
    When Default:
        # calcul de la quantité de l'opération (quantité lancée / coeff US/UO)
        # dans la première version on ne gère pas de perte sur les opérations ...
        # sr 08.02 1.4.0 récup éventuelle de la formule
        If [F:ROO]OPESTUFOR <> ""
           Read [F:TFO]TFO0=2;[F:ROO]OPESTUFOR
           If !fstat
               # se repositionner éventuellement sur l'article produit
               If [F:ITM]ITMREF <> [M:MFG1]ITMREF(0)
                   Read [F:ITM]ITM0 = [M:MFG1]ITMREF(0)
                   If fstat : Raz [F:ITM] : Endif
               Endif
               If [F:ITF]ITMREF <> [M:MFG1]ITMREF(0) | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
                  Read [F:ITF]ITF0 = [M:MFG1]ITMREF(0);[M:MFG0]MFGFCY
                   If fstat : Raz [F:ITF] : Endif
               Endif
               If evalue([F:TFO]FORFOR) <> 0
                   [M:MFG3]EXTQTY(L) = LMFGEXTQTY * evalue([F:TFO]FORFOR)
               Elsif [F:ROO]OPESTUCOE <> 0
                   [M:MFG3]EXTQTY(L) = LMFGEXTQTY *[F:ROO]OPESTUCOE
               Else
                    [M:MFG3]EXTQTY(L) = LMFGEXTQTY
               Endif
           Else
                [M:MFG3]EXTQTY(L) = LMFGEXTQTY *[F:ROO]OPESTUCOE
           Endif
        Else
          [M:MFG3]EXTQTY(L) = LMFGEXTQTY * [F:ROO]OPESTUCOE
        Endif

        # application de la perte
        If [F:ROT]SHR <> 0
            [M:MFG3]EXTQTY(L) = [M:MFG3]EXTQTY(L) * (1 + ([F:ROT]SHR / 100))
        Endif

        [M:MFG3]EXTSTUQTY(L) = LMFGEXTQTY
        [M:MFG3]EXTSTRQTY(L) = [M:MFG3]EXTQTY(L) *  [M:MFG3]OPESTRCOE(L)
        # FQ 77413 GA 10/2011 arrondir
        Call QTEARR([M:MFG3]EXTSTRQTY(L),[M:MFG3]SCOPUU(L)) From TRTDIV

        # application du taux de compression des temps morts
        # si 1    <= % compression <= 100, on comprime les temps suivant le pourcentage
        # si 101  <= % compression <= n  , on augmente les temps de (pourcentage - 100)
        # exemple: compression = 40 %, temps passe de 1h à 0,6 h
        #          compression = 120%, temps passe de 1h à 1,2 h
        If LLTIRED > 100
            LLTIRED -= 100
            LLTIRED *= -1
        Endif
        Case GTPSCOMP
            When 1:    # ben rien
            When 2:    # compression temps attente uniquement
                       [M:MFG3]WAITIM(L)    = [M:MFG3]WAITIM(L) *
&                                             ((100 - LLTIRED) / 100)
            When 3:    # compression temps préparation + post-opératoire
                       [M:MFG3]PRPTIM(L)    = [M:MFG3]PRPTIM(L) *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFG3]PSPTIM(L)    = [M:MFG3]PSPTIM(L) *
&                                             ((100 - LLTIRED) / 100)
            When 4:    # compression des 3 temps
                       [M:MFG3]WAITIM(L)    = [M:MFG3]WAITIM(L) *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFG3]PRPTIM(L)    = [M:MFG3]PRPTIM(L) *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFG3]PSPTIM(L)    = [M:MFG3]PSPTIM(L) *
&                                             ((100 - LLTIRED) / 100)
            When 5:    # compresssion temps de préparation
                       [M:MFG3]PRPTIM(L)    = [M:MFG3]PRPTIM(L) *
&                                             ((100 - LLTIRED) / 100)
            When 6:    # compresssion temps post-opératoire
                       [M:MFG3]PSPTIM(L)    = [M:MFG3]PSPTIM(L) *
&                                             ((100 - LLTIRED) / 100)
            When 7:    # compression temps préparation + attente
                       [M:MFG3]PRPTIM(L)    = [M:MFG3]PRPTIM(L) *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFG3]WAITIM(L)    = [M:MFG3]WAITIM(L) *
&                                             ((100 - LLTIRED) / 100)
            When 8:    # compression temps post-opératoire + attente
                       [M:MFG3]PSPTIM(L)    = [M:MFG3]PSPTIM(L) *
&                                             ((100 - LLTIRED) / 100)
                       [M:MFG3]WAITIM(L)    = [M:MFG3]WAITIM(L) *
&                                             ((100 - LLTIRED) / 100)
        Endcase

        # calcul temps variable (dépendant de la quantité)
        # on ne divise pas le temps opératoire par le nombre de postes m-o,
        # le moteur de jalonnement s'en occupera ...

        Case [F:ROO]ROOTIMCOD    # suivant type tps opératoire
            When 1: # proportionnel     (temps = quantité / quantité base * temps)
                    [M:MFG3]EXTOPETIM(L)    = [M:MFG3]EXTQTY(L) *
&                                             [F:ROT]OPETIM * LOPETIM    /
&                                             [F:ROT]BASQTY
            When 2: # cadence (temps = quantité / cadence)
                    # llc 02.02 13175
                    If [F:ROT]CAD <> 0
                        [M:MFG3]EXTOPETIM(L)    = [M:MFG3]EXTQTY(L) /
&                                                 [F:ROT]CAD
                    Endif
            When 3: # forfaitaire
                    [M:MFG3]EXTOPETIM(L)    = [F:ROT]OPETIM * LOPETIM      # 17809 MM 07.05
        Endcase

# llc 03.01 multi-exemplaire
# si nombre poste, on divise le temps
# opératoire par le nombre de poste
#        If [M:MFG3]EXTWSTNBR(L) > 1
#            [M:MFG3]EXTOPETIM(L) = [M:MFG3]EXTOPETIM(L) /
#&                                  [M:MFG3]EXTWSTNBR(L)
#        Endif

        # application de l'efficience du poste de charge et de l'opération
        # (l'efficience ne concerne que les temps de réglage et opératoire)
        # temps = temps * efficience poste/100 * efficience opération/100
      Case GWSTEFFINH
            When 1:                If clalev([F:MWS])=0 : Local File WORKSTATIO [MWS] : Endif
                                   Raz [F:MWS]
                                   If [M:MFG3]EXTLAB(L)<>""
                                       Read [MWS]WST0=[M:MFG3]EXTLAB(L);[M:MFG0]MFGFCY
                                   Endif
                                   If [F:MWS]EFF=0 : [F:MWS]EFF=100 : Endif

                                   # 04.05 13839
                                   If GOPEEFFAPP = 1
                                       [M:MFG3]EXTSETTIM(L)     = [M:MFG3]EXTSETTIM(L) /
&                                                                 ([F:ROT]EFF / 100) /
&                                                                 ([M:MFG3]WSTEFF(L) / 100)
                                       # Issue 94895 - 2014-11-18 by CCC
                                       [M:MFG3]SETLABCOE(L)     = arr( [M:MFG3]SETLABCOE(L) /
&                                                                 ([F:MWS]EFF    / 100), 0.001)
                                   Endif
                                   [M:MFG3]EXTOPETIM(L)     = [M:MFG3]EXTOPETIM(L) /
&                                                             ([F:ROT]EFF / 100) /
&                                                             ([M:MFG3]WSTEFF(L) / 100)
                                   # Issue 94895 - 2014-11-18 by CCC
                                   [M:MFG3]OPELABCOE(L)     = arr( [M:MFG3]OPELABCOE(L) /
&                                                             ([F:MWS]EFF    / 100), 0.001)
            When Default:          # 04.05 13839
                                   If GOPEEFFAPP = 1
                                       [M:MFG3]EXTSETTIM(L)     = [M:MFG3]EXTSETTIM(L) /
&                                                                 ([F:ROT]EFF / 100)
                                   Endif
                                   [M:MFG3]EXTOPETIM(L)     = [M:MFG3]EXTOPETIM(L) /
&                                                             ([F:ROT]EFF / 100)
        Endcase

        # calcul du temps unitaire = temps opératoire calculé / quantité
        [M:MFG3]EXTUNTTIM(L)     =  [M:MFG3]EXTOPETIM(L) / [M:MFG3]EXTQTY(L)

        # calcul du total hors charge, uniquement pour affichage
        # Formule: tps préparation + (le plus grand entre tps attente et post-opératoire)
        # car on considère que les tps d'attente et post-opératoire sont //
        If  [M:MFG3]WAITIM(L)    > [M:MFG3]PSPTIM(L)
            [M:MFG3]FXDTIM(L) = [M:MFG3]PRPTIM(L) +
&                               [M:MFG3]WAITIM(L)
        Else
            [M:MFG3]FXDTIM(L) = [M:MFG3]PRPTIM(L) +
&                               [M:MFG3]PSPTIM(L)
        Endif

        # calcul du total charge, uniquement pour affichage
        # Formule: tps réglage + tps opératoire
        [M:MFG3]VARTIM(L)     = [M:MFG3]EXTSETTIM(L) +
&                               [M:MFG3]EXTOPETIM(L)

        # arrondis
        [M:MFG3]WAITIM(L)     = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]WAITIM(L))
        [M:MFG3]PRPTIM(L)     = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]PRPTIM(L))
        [M:MFG3]PSPTIM(L)     = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]PSPTIM(L))
        [M:MFG3]EXTSETTIM(L)  = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]EXTSETTIM(L))
        [M:MFG3]EXTOPETIM(L)  = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]EXTOPETIM(L))
        [M:MFG3]EXTUNTTIM(L)  = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]EXTUNTTIM(L))
        [M:MFG3]FXDTIM(L)     = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]FXDTIM(L))
        [M:MFG3]VARTIM(L)     = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]VARTIM(L))
Endcase
#
End

##############################################################################
# Routine de mise à jour de l'encours opération
# [F:MFO] doit être chargé avant l'appel
# LCOD = C,SC  Création OWx
# LCOD = M,SM  Modification OWx
# LCOD = A,SA  Suppression OWx
# LCOD = P,    Création OWx à la prise de commande sous-traitance (splittage)
# LCOD = PM,   Modification OWx splittée à la prise de commande sous-traitance
##############################################################################
# mise à jour encours opération
Subprog UPDATE_OWX(LCOD, LPJT)
Value Char    LCOD
Value Char    LPJT
Local Integer STAT
#
# si sous-traitance, mise à jour encours (SC-x)
If [F:MWS]WST <> [F:MFO]EXTWST
    Read [F:MWS]WST0=[F:MFO]EXTWST;[F:MFO]MFGFCY
    If fstat : End : Endif
Endif
#
If ([F:MWS]WSTTYP = 3 & [F:MFO]OPESTA < 4) # si sous-traitance en attente
    Call UPDATE_SCX(LCOD,LPJT)
Else
    # si ex sous-traitance (poste modifié), suppression SC-x
    If [F:MFO]WIPNUM <> ""
        Call UPDATE_SCX("A",LPJT)
    Endif
    [F:MFO]WIPNUM=""
Endif
#
#si opération soldée ou exclue, suppression de l'encours de charge   sr 1710
If find([F:MFO]OPESTA,5,6) : LCOD = "A" : Endif
Case LCOD
    When "C","P","SC","BC": If [F:MFO]OPESTA=6 : [F:MFO]OPSNUM="" : End : Endif
               # création encours charge
               Call NUMERO(GOPS,[F:MFO]MFGFCY,[F:MFO]OPESTR,"",[F:MFO]OPSNUM,STAT) From SUBANM
               If STAT <> 0 : Call ERREUR("WOP"-mess(60,199,1)-GOPS-num$(STAT)) From GESECRAN : Endif
               Call LOAD_OPSK
               [M:OPSK]PJT = LPJT
               Call ENCOURS_OPE("C", [F:MFO]OPSNUM) From TRTOPS
    When "M","PM","SM": # modification encours charge
               Call LOAD_OPSK
               [M:OPSK]PJT = LPJT
               Call ENCOURS_OPE("M", [F:MFO]OPSNUM) From TRTOPS
               # si qté prévue = 0 ou qté restante = 0, encours supprimé par TRTOPS
               If ([F:MFO]OPESTA=6) | ([F:MFO]EXTQTY<=[F:MFO]CPLQTY) : [F:MFO]OPSNUM="" : Endif
    When "A","SA","SP": # suppression encours
               Call LOAD_OPSK
               Call ENCOURS_OPE("A", [F:MFO]OPSNUM) From TRTOPS
Endcase
#
End

##################################################################
# Routine de mise à jour de l'encours service sous-traitance
# [F:MFO] doit être chargé avant l'appel
# LCOD = C,    Création SCx
# LCOD = M,    Modification SCx
# LCOD = A,    Suppression SCx
##################################################################
Subprog UPDATE_SCX(LCOD, LPJT)
Value Char    LCOD
Value Char    LPJT
Local Integer STAT
Local Char    WITM(GLONITM)
Local Integer WRET
#
# Issue 98921 GA 04/2014
Raz [M:ORDK]

#si opération soldée ou exclue, suppression de l'encours de charge   llc 06.01 9535
If find([F:MFO]OPESTA,5,6) : LCOD = "A" : Endif
If find(LCOD,"C","M", "BC", "SC", "SM") : Call RECH_ORI(LCOD, WITM, WRET) : Endif        # 10.05 32356
Case LCOD
    When "C","SC", "BC": If [F:MFO]OPESTA=6 : [F:MFO]WIPNUM="" : End : Endif
               # création encours
               Call NUMERO(GWIP,[F:MFO]MFGFCY,[F:MFO]OPESTR,"",[F:MFO]WIPNUM,STAT) From SUBANM
               If STAT <> 0 : Call ERREUR("WOR"-mess(60,199,1)-GWIP-num$(STAT)) From GESECRAN : Endif
               #
               [M:ORDK]MAJCOD     = "C"
               [M:ORDK]WIPTYP     = 4
               [M:ORDK]WIPSTA     = [F:MFO]MFGSTA
               [M:ORDK]WIPNUM     = [F:MFO]WIPNUM
               [M:ORDK]ITMREF     = [F:MFO]SCOITMREF
               [M:ORDK]ORIFCY     = [F:MFO]PLNFCY
               [M:ORDK]STOFCY     = [F:MFO]MFGFCY
               [M:ORDK]PJT        = LPJT
               [M:ORDK]BPRNUM     = [F:MFO]BPRNUM            # llc 02.01 5977 + 12.03 MM
               [M:ORDK]STRDAT     = [F:MFO]OPESTR
               [M:ORDK]ENDDAT     = [F:MFO]OPEEND
               [M:ORDK]VCRTYP     = 10
               [M:ORDK]VCRNUM     = [F:MFO]MFGNUM
               [M:ORDK]VCRLIN     = 0
               [M:ORDK]VCRSEQ     = 0
               # FQ 74274 GA 10/2011 modif raz la SCF doit etre en STU de l'article sous-traitance
               # la quantité prévue doit être exprimée en US
               # [M:ORDK]EXTQTY     = [F:MFO]EXTSTUQTY   # FQ 63036 GA 04/2010 US de l'article lancé
               # Issue 80045 Suite FQ 74274 GA 02/2012
               # [M:ORDK]EXTQTY     = [F:MFO]EXTSTRQTY
               [M:ORDK]EXTQTY     = [F:MFO]EXTQTY
               [M:ORDK]CPLQTY     = 0
               [M:ORDK]ALLQTY     = 0
               [M:ORDK]SHTQTY     = 0
               [M:ORDK]FMI        = 1
               [M:ORDK]MRPMES     = 1
               [M:ORDK]VCRTYPORI  = 10
               [M:ORDK]VCRNUMORI  = [F:MFO]MFGNUM
               [M:ORDK]VCRLINORI  = 0
               [M:ORDK]VCRSEQORI  = 0
               [M:ORDK]ITMREFORI  = WITM
               [M:ORDK]BOMALT     = 0
               [M:ORDK]ORI        = 4
               [M:ORDK]ABBFIL     = "MFO"
               [M:ORDK]PIO        = [F:MFO]MFGPIO
               If [F:MFO]OPESTA = 6
                   [M:ORDK]ORDSTA = 4
               Else
                   [M:ORDK]ORDSTA = 1
               Endif
               Call WIP From TRTWIP
    When "M","SM": # modification encours
               [M:ORDK]MAJCOD     = "M"
               [M:ORDK]WIPTYP     = 4
               [M:ORDK]WIPSTA     = [F:MFO]MFGSTA
               [M:ORDK]WIPNUM     = [F:MFO]WIPNUM
               [M:ORDK]ITMREF     = [F:MFO]SCOITMREF
               [M:ORDK]ORIFCY     = [F:MFO]PLNFCY
               [M:ORDK]STOFCY     = [F:MFO]MFGFCY
               [M:ORDK]PJT        = LPJT
               [M:ORDK]BPRNUM     = [F:MFO]BPRNUM            # llc 02.01 5977 + 12.03 MM
               [M:ORDK]STRDAT     = [F:MFO]OPESTR
               [M:ORDK]ENDDAT     = [F:MFO]OPEEND
               [M:ORDK]VCRTYP     = 10
               [M:ORDK]VCRNUM     = [F:MFO]MFGNUM
               [M:ORDK]VCRLIN     = 0
               [M:ORDK]VCRSEQ     = 0
               # FQ 74274 GA 10/2011 modif raz la SCF doit etre en STU de l'article sous-traitance
               # la quantité prévue doit être exprimée en US
               # [M:ORDK]EXTQTY     = [F:MFO]EXTSTUQTY   # FQ 63036 GA 04/2010 US de l'article lancé
               # Issue 80045 Suite FQ 74274 GA 02/2012
               # [M:ORDK]EXTQTY     = [F:MFO]EXTSTRQTY
               [M:ORDK]EXTQTY     = [F:MFO]EXTQTY
               [M:ORDK]CPLQTY     = [F:MFO]CPLQTY
               [M:ORDK]ALLQTY     = 0
               [M:ORDK]SHTQTY     = 0
               [M:ORDK]FMI        = 1
               [M:ORDK]MRPMES     = 1
               [M:ORDK]VCRTYPORI  = 10
               [M:ORDK]VCRNUMORI  = [F:MFO]MFGNUM
               [M:ORDK]VCRLINORI  = 0
               [M:ORDK]VCRSEQORI  = 0
               [M:ORDK]ITMREFORI  = WITM
               [M:ORDK]BOMALT     = 0
               [M:ORDK]ORI        = 4
               [M:ORDK]ABBFIL     = "MFO"
               [M:ORDK]PIO        = [F:MFO]MFGPIO
               If [F:MFO]OPESTA = 6
                   [M:ORDK]ORDSTA = 4
               Else
                   [M:ORDK]ORDSTA = 1
               Endif
               Call WIP From TRTWIP
               [F:MFO]WIPNUM      = [M:ORDK]WIPNUM
               # si exclue ou qté restante = 0, encours supprimé par TRTWIP
               If ([F:MFO]OPESTA=6) | ([F:MFO]EXTQTY<=[F:MFO]CPLQTY) : [F:MFO]WIPNUM="" : Endif
    When "A","SA": # suppression encours
               [M:ORDK]MAJCOD     = "A"
               [M:ORDK]WIPTYP     = 4
               [M:ORDK]WIPNUM     = [F:MFO]WIPNUM
               [M:ORDK]ITMREF     = [F:MFO]SCOITMREF
               Call WIP From TRTWIP
               [F:MFO]WIPNUM=""
    When "P","PM","SP": # ben rien
Endcase
#
End

##################################################################
# chargement buffer encours charge OPSK
Subprog LOAD_OPSK
#

[M:OPSK]          = [F:MFO]
[M:OPSK]EXTWSTTYP = [F:MWS]WSTTYP
[M:OPSK]OPSTYP    = 1
[M:OPSK]OPSSTA    = [F:MFO]MFGSTA
[M:OPSK]ABBFIL    = "MFO"
[M:OPSK]ORI       = 4
If [F:MWS]WSTTYP = 3
    [M:OPSK]SCOFLG = 2
Else
    [M:OPSK]SCOFLG = 1
Endif
#
End

##################################################################
# modification globale des quantités des opérations
Subprog UPD_QTY_GLOB(LMIN, LMAX)
Value Integer LMIN  # ligne départ
Value Integer LMAX  # ligne fin
Local Integer WRET
Local Integer TSBC(0..GMFOMAX,4)                    # llc 07.01 9977
Local Decimal TQTY(0..GMFOMAX)                      # llc 07.01 9977
Local Integer NOPE
Local Integer I,L,K
Local Decimal WOFFSET
Local Decimal WOFFABS
Local Decimal WWORK, WUNTTIM                        # llc 04.02 14041


# un petit message pour patienter ...
Call TEMPON(mess(93,195,1)) From GESECRAN
# boucle de recherche des opérations concernées
# premier passage, on ignore la sous-traitance ...
For I=LMIN To LMAX
    If [M:MFG3]WSTTYP(I) <> 3 & [M:MFG3]OPESTA(I) < 5
        # recalcul de la quantité de l'opération (quantité lancée * coeff US/UO)
        # llc 04.02 13460 ne pas iminuer en deça du réalisé
#        [M:MFG3]EXTQTY(I)    = [M:MFG1]MFGEXTQTY * [M:MFG3]OPESTUCOE(I)
        # application de la perte
#        If [M:MFG3]SHR(I) <> 0
#            [M:MFG3]EXTQTY(I) = [M:MFG3]EXTQTY(I) * (1 + ([M:MFG3]SHR(I) / 100))
#        Endif

        # recalcul temps unitaire avant de changer la quantité
        WUNTTIM = [M:MFG3]EXTOPETIM(I) / [M:MFG3]EXTQTY(I)     # llc 04.02 14041(+)
        WWRK = [M:MFG1]MFGEXTQTY * [M:MFG3]OPESTUCOE(I)
        If WWRK >= [M:MFG3]CPLQTY(I)
            [M:MFG3]EXTQTY(I) = WWRK
            # application de la perte
            If [M:MFG3]SHR(I) <> 0
                [M:MFG3]EXTQTY(I) = [M:MFG3]EXTQTY(I) * (1 + ([M:MFG3]SHR(I) / 100))
            Endif
        Else
            [M:MFG3]EXTQTY(I) = [M:MFG3]CPLQTY(I)
        Endif

        Call QTEARR([M:MFG3]EXTQTY(I),[M:MFG3]OPEUOM(I)) From TRTDIV

        # recalcul de la quantité en US (quantité UO / coeff US/UO)
        [M:MFG3]EXTSTUQTY(I) = [M:MFG3]EXTQTY(I) / [M:MFG3]OPESTUCOE(I)
        Call QTEARR([M:MFG3]EXTSTUQTY(I),[M:MFG1]MFGSTU) From TRTDIV
        [M:MFG3]EXTSTRQTY(I) = [M:MFG3]EXTQTY(I) * [M:MFG3]OPESTRCOE(I)
        # FQ 77413 GA 10/2011 arrondir
        Call QTEARR([M:MFG3]EXTSTRQTY(I),[M:MFG3]SCOPUU(I)) From TRTDIV

        # Issue 104004 GA 12/2014
        #### recalcul temps unitaire
        ###If [M:MFG3]ROOTIMCOD(I) = 3 & [M:MFG3]EXTQTY(I)<>0
        ###    [M:MFG3]EXTUNTTIM(I)  = [M:MFG3]EXTOPETIM(I) / [M:MFG3]EXTQTY(I)
        ###    [M:MFG3]EXTUNTTIM(I) =  func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]EXTUNTTIM(I))
        ###Endif
        ###
        #### recalcul du temps opératoire via temps unitaire sauf si forfaitaire sr 091100
        ###If [M:MFG3]ROOTIMCOD(I) <> 3
        ###    [M:MFG3]EXTOPETIM(I) =  [M:MFG3]EXTQTY(I) * WUNTTIM    # llc 04.02 14041
        ###Endif
        If [M:MFG3]EXTQTY(I)<>0 & [M:MFG3]OPENUM(I)<>0
           Local Decimal WCAD,WBASQTY
           #Issue X3-80825 25/05/2018 By GEBIL : NON-EXPECTED OPERATION, OPERATIONAL time LOST
           #If [F:ROO]OPENUM<>[M:MFG3]OPENUM(I) | [F:ROO]ITMREF<>[M:MFG1]ROUNUM
              # Index ROO0: FCY+ITMREF+ROUALT+OPENUM+RPLIND
              # Issue 49150 GH 01/09/2017 - RPLIND part of the index was missing
              # Read [F:ROO]ROO0=[M:MFG0]MFGFCY;[M:MFG1]ROUNUM;[M:MFG1]ROUALT;[M:MFG3]OPENUM(I)
              #Read [ROO]ROO0=[M:MFG0]MFGFCY;[M:MFG1]ROUNUM;[M:MFG1]ROUALT;[M:MFG3]OPENUM(I);[M:MFG3]RPLIND(I)
              #If fstat : Raz [F:ROO] : Endif
           #Endif
           Case [M:MFG3]ROOTIMCOD(I)
            When 1: # proportionnel     (temps = (quantité * temps) / quantité base)
                    WBASQTY = [M:MFG3]BASQTY(I)
                    If WBASQTY <= 0 : WBASQTY = 1 : Endif
                    [M:MFG3]EXTUNTTIM(I)*=[M:MFG3]EFF(I)/100
                    If GWSTEFFINH=1 : [M:MFG3]EXTUNTTIM(I)*=[M:MFG3]WSTEFF(I)/100 : Endif
                    [M:MFG3]EXTUNTTIM(I) =  func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]EXTUNTTIM(I))
                    [M:MFG3]EXTOPETIM(I) = ([M:MFG3]EXTQTY(I) * [M:MFG3]EXTUNTTIM(I)) / WBASQTY
            When 2: # cadence          (temps = quantité / cadence)
                    WCAD = [M:MFG3]CAD(I)
                    If WCAD <= 0 : WCAD = 1 : Endif
                    [M:MFG3]EXTOPETIM(I) = [M:MFG3]EXTQTY(I) / WCAD
            When 3: # forfaitaire
                    [M:MFG3]EXTOPETIM(I)*=[M:MFG3]EFF(I)/100
                    If GWSTEFFINH=1 : [M:MFG3]EXTOPETIM(I)*=[M:MFG3]WSTEFF(I)/100 : Endif
           Endcase
           #Issue X3-92481 01/06/2018 by GEBIL : Work center efficiency is considered twice => GOPEEFFAPP temporary changed
           Local Integer WOPTSAV : WOPTSAV = GOPEEFFAPP
           GOPEEFFAPP = 2
           Call UPD_OPE_UNI(6,"MFG3",I,[M:MFG3]EFF(I)) : # GH 24/03/2016 bug 114686 to take in account efficience coeff
           GOPEEFFAPP = WOPTSAV
        Endif

        # recalcul du total hors charge
        If [M:MFG3]WAITIM(I) > [M:MFG3]PSPTIM(I)
            [M:MFG3]FXDTIM(I) = [M:MFG3]PRPTIM(I) + [M:MFG3]WAITIM(I)
        Else
            [M:MFG3]FXDTIM(I) = [M:MFG3]PRPTIM(I) + [M:MFG3]PSPTIM(I)
        Endif
        # recalcul du total charge
        [M:MFG3]VARTIM(I) = [M:MFG3]EXTSETTIM(I) + [M:MFG3]EXTOPETIM(I)

        #[M:MFG3]EXTOPETIM(I) = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]EXTOPETIM(I)) # GH 24/03/2016 bug 114686 already done
        [M:MFG3]FXDTIM(I)    = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]FXDTIM(I))
        #
        [M:MFG3]STDOPETIM(I)     = [M:MFG3]EXTOPETIM(I)
        [M:MFG3]STDQTY(I)        = [M:MFG3]EXTQTY(I)
        # mise à jour nombre articles lancés
        [M:MFG3]ITMLINNBR(I) = [M:MFG1]NBLIG
        # vérification seuil solde automatique atteint
        Call CONT_SOLDE_OPE([M:MFG0]MFGFCY,[M:MFG3]EXTWST(I), [M:MFG3]CPLQTY(I) ,
&                           [M:MFG3]EXTQTY(I), WRET) From MFGLIBO
        If WRET = 1
            [M:MFG3]OPESTA(I)=5
            [M:MFG1]DOPECLENBR += 1
        Endif
        # Issue X3-55362 - 2017-09-12 by JUSYN : Revision treatment for quantity change for versioned products
        If dim([M:MFG1]ROUECCMAJ) > 0
            If GMFGREV=2 & [M:MFG1]ROUECCMAJ <> ""
                [M:MFG3]REVCOD(I) = 2 # = Modify
                [M:MFG3]REVREASON(I) = mess(406,193,1)   # Product quantity has been changed
            Endif
        Endif
        # End issue X3-55362
    Endif
Next I

# deuxième passage, analyse sous-traitance - chargement configuration
Raz TSBC
NOPE = 0
For I = LMIN To LMAX
    If [M:MFG3]WSTTYP(I) = 3
        If TSBC(0,0) = 0
            TSBC(0,0) = [M:MFG3]OPENUM(I)
            If [M:MFG3]OPESPLNUM(I) = 0
                TSBC(0,1)  = 1
            Else
                TSBC(0,2)  = 1
            Endif
            TSBC(0,3)  = I
            TQTY(0) = [M:MFG3]EXTQTY(I)
            Goto NEXT_OPE
        Endif
        If [M:MFG3]OPENUM(I) > TSBC(NOPE,0)
            NOPE += 1
            TSBC(NOPE,0) = [M:MFG3]OPENUM(I)
            If [M:MFG3]OPESPLNUM(I) = 0
                TSBC(NOPE,1)  = 1
            Else
                TSBC(NOPE,2)  = 1
            Endif
            TSBC(NOPE,3)  = I
            TQTY(NOPE) = [M:MFG3]EXTQTY(I)
            Goto NEXT_OPE
        Endif
        If [M:MFG3]OPENUM(I) = TSBC(NOPE,0)
            TSBC(NOPE,2) += 1
            TQTY(NOPE)   += [M:MFG3]EXTQTY(I)
        Endif
    Endif
$NEXT_OPE
Next I

# application mises à jour à partir de la configuration
I=0
# sr 02/00 Tester la valeur de I par rapport à la taille réelle du tableau
While I < [M:MFG3]NBLIG & (TSBC(I,0) <> 0) # tant qu'il y a des opérations de sous-traitance à traiter
    If TSBC(I,1) = 1 & TSBC(I,2) = 0 # si opération non commandée

        WUNTTIM = [M:MFG3]EXTOPETIM(TSBC(I,3)) / [M:MFG3]EXTQTY(TSBC(I,3))     # llc 04.02 14041

        # recalcul de la quantité de l'opération (quantité lancée * coeff US/UO)
        [M:MFG3]EXTQTY(TSBC(I,3))    = [M:MFG1]MFGEXTQTY * [M:MFG3]OPESTUCOE(TSBC(I,3))

        # application de la perte
        If [M:MFG3]SHR(TSBC(I,3)) <> 0
            [M:MFG3]EXTQTY(TSBC(I,3)) = [M:MFG3]EXTQTY(TSBC(I,3)) * (1 + ([M:MFG3]SHR(TSBC(I,3)) / 100))
        Endif

        Call QTEARR([M:MFG3]EXTQTY(TSBC(I,3)),[M:MFG3]OPEUOM(TSBC(I,3))) From TRTDIV
        # recalcul de la quantité en US (quantité UO / coeff US/UO)
        [M:MFG3]EXTSTUQTY(TSBC(I,3)) = [M:MFG3]EXTQTY(TSBC(I,3)) / [M:MFG3]OPESTUCOE(TSBC(I,3))
        Call QTEARR([M:MFG3]EXTSTUQTY(TSBC(I,3)),[M:MFG1]MFGSTU) From TRTDIV
        [M:MFG3]EXTSTRQTY(TSBC(I,3)) = [M:MFG3]EXTQTY(TSBC(I,3)) * [M:MFG3]OPESTRCOE(TSBC(I,3))
        # FQ 77413 GA 10/2011 arrondir
        Call QTEARR([M:MFG3]EXTSTRQTY(TSBC(I,3)),[M:MFG3]SCOPUU(TSBC(I,3))) From TRTDIV

        # recalcul temps unitaire
        If [M:MFG3]ROOTIMCOD(TSBC(I,3)) = 3 & [M:MFG3]EXTQTY(TSBC(I,3))<>0
            [M:MFG3]EXTUNTTIM(TSBC(I,3))  = [M:MFG3]EXTOPETIM(TSBC(I,3)) / [M:MFG3]EXTQTY(TSBC(I,3))
            [M:MFG3]EXTUNTTIM(TSBC(I,3)) =  func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]EXTUNTTIM(TSBC(I,3)))
        Endif

        # recalcul du temps opératoire via temps unitaire sauf forfaitaire sr 091100
        If [M:MFG3]ROOTIMCOD(TSBC(I,3)) <> 3
            [M:MFG3]EXTOPETIM(TSBC(I,3)) =  [M:MFG3]EXTQTY(TSBC(I,3)) * WUNTTIM    # llc 04.02 14041
            [M:MFG3]EXTOPETIM(TSBC(I,3)) = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]EXTOPETIM(TSBC(I,3)))
        Endif
        #
        [M:MFG3]STDOPETIM(TSBC(I,3)) = [M:MFG3]EXTOPETIM(TSBC(I,3))
        [M:MFG3]STDQTY(TSBC(I,3))    = [M:MFG3]EXTQTY(TSBC(I,3))
        # recalcul du total hors charge
        If [M:MFG3]WAITIM(TSBC(I,3)) > [M:MFG3]PSPTIM(TSBC(I,3))
            [M:MFG3]FXDTIM(TSBC(I,3)) = [M:MFG3]PRPTIM(TSBC(I,3)) + [M:MFG3]WAITIM(TSBC(I,3))
        Else
            [M:MFG3]FXDTIM(TSBC(I,3)) = [M:MFG3]PRPTIM(TSBC(I,3)) + [M:MFG3]PSPTIM(TSBC(I,3))
        Endif
        [M:MFG3]FXDTIM(TSBC(I,3)) = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]FXDTIM(TSBC(I,3)))
        # recalcul du total charge
        [M:MFG3]VARTIM(TSBC(I,3)) = [M:MFG3]EXTSETTIM(TSBC(I,3)) + [M:MFG3]EXTOPETIM(TSBC(I,3))
        [M:MFG3]VARTIM(TSBC(I,3)) = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]VARTIM(TSBC(I,3)))
        # mise à jour nombre articles lancés
        [M:MFG3]ITMLINNBR(TSBC(I,3)) = [M:MFG1]NBLIG
        Goto NEXT_STR
    Endif
    If TSBC(I,1) = 1     # opération commandée partiellement
        # calcul de la différence
        WOFFSET = (([M:MFG1]MFGEXTQTY * [M:MFG3]OPESTUCOE(I)) * (1 + ([M:MFG3]SHR(I)) / 100)) - TQTY(I)
        Call QTEARR(WOFFSET,[M:MFG3]OPEUOM(I)) From TRTDIV
        If WOFFSET <= 0     # si diminution quantité
            WABS = WOFFSET * -1
            # si écart >= quantité restante, on supprime l'opération restante
            If WABS >= [M:MFG3]EXTQTY(TSBC(I,3))
                Dela TSBC(I,3),1 [M:MFG3]NBLIG
                [M:MFG3]NBLIG -= 1
            Else
            # sinon diminution quantité opération
               WWRK = [M:MFG3]EXTQTY(TSBC(I,3)) + WOFFSET
#               Call UPD_OPE_UNI(2, "MFG3", TSBC(I,3), [M:MFG3]EFF(TSBC(I,3))) From MFGLIBO
# (llc 09.00)
               Call UPD_OPE_UNI(2, "MFG3", TSBC(I,3), WWRK) From MFGLIBO
               [M:MFG3]EXTQTY(TSBC(I,3)) = WWRK
               [M:MFG3]STDOPETIM(TSBC(I,3)) = [M:MFG3]EXTOPETIM(TSBC(I,3))
               [M:MFG3]STDQTY(TSBC(I,3))    = [M:MFG3]EXTQTY(TSBC(I,3))
               # recalcul temps unitaire
               If [M:MFG3]ROOTIMCOD(TSBC(I,3)) = 3 & [M:MFG3]EXTQTY(TSBC(I,3))<>0
                   [M:MFG3]EXTUNTTIM(TSBC(I,3)) = [M:MFG3]EXTOPETIM(TSBC(I,3)) / [M:MFG3]EXTQTY(TSBC(I,3))
                   [M:MFG3]EXTUNTTIM(TSBC(I,3)) = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]EXTUNTTIM(TSBC(I,3)))
               Endif
            Endif
        Endif
        If WOFFSET > 0    # si augmentation quantité
            # augmentation quantité opération
            WWRK = [M:MFG3]EXTQTY(TSBC(I,3)) + WOFFSET
#           Call UPD_OPE_UNI(2, "MFG3", TSBC(I,3), [M:MFG3]EFF(TSBC(I,3))) From MFGLIBO
# (llc 09.00)
           Call UPD_OPE_UNI(2, "MFG3", TSBC(I,3), WWRK) From MFGLIBO
           [M:MFG3]EXTQTY(TSBC(I,3)) = WWRK
           [M:MFG3]STDOPETIM(TSBC(I,3)) = [M:MFG3]EXTOPETIM(TSBC(I,3))
           [M:MFG3]STDQTY(TSBC(I,3))    = [M:MFG3]EXTQTY(TSBC(I,3))
           # recalcul temps unitaire
           If [M:MFG3]ROOTIMCOD(TSBC(I,3)) = 3 & [M:MFG3]EXTQTY(TSBC(I,3))<>0
               [M:MFG3]EXTUNTTIM(TSBC(I,3))  = [M:MFG3]EXTOPETIM(TSBC(I,3)) / [M:MFG3]EXTQTY(TSBC(I,3))
               [M:MFG3]EXTUNTTIM(TSBC(I,3)) =  func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]EXTUNTTIM(TSBC(I,3)))
           Endif
        Endif
        Goto NEXT_STR
    Endif

    If TSBC(I,1) = 0    # opération totalement commandée
        # calcul de la différence
        WOFFSET = (([M:MFG1]MFGEXTQTY * [M:MFG3]OPESTUCOE(I)) * (1 + ([M:MFG3]SHR(TSBC(I,3)) / 100))) - TQTY(I)
        Call QTEARR(WOFFSET,[M:MFG3]OPEUOM(I)) From TRTDIV
        # si augmentation quantité on traite sinon on ne fait rien ...
        If WOFFSET > 0
            # duplication de la première opération commandée
            # on ne dispose pas (aujourdh'ui) de fonction de copie d'une ligne
            # d'un tableau donc on fait tout à la main ...
            L = [M:MFG3]NBLIG
            K = TSBC(I,3)
            [M:MFG3]OPENUM(L)    = [M:MFG3]OPENUM(K)
            [M:MFG3]ROUOPENUM(L) = [M:MFG3]ROUOPENUM(K)
            [M:MFG3]OPESPLNUM(L) = 0
            [M:MFG3]STDOPENUM(L) = [M:MFG3]STDOPENUM(K)
            [M:MFG3]RPLIND(L)    = [M:MFG3]RPLIND(K)
            [M:MFG3]OPESTA(L)    = 1
            [M:MFG3]EXTWST(L)    = [M:MFG3]EXTWST(K)
            [M:MFG3]WCR(L)       = [M:MFG3]WCR(K)
            [M:MFG3]EXTWSTSHO(L) = [M:MFG3]EXTWSTSHO(K)
            [M:MFG3]WSTTYP(L)    = [M:MFG3]WSTTYP(K)
            [M:MFG3]XWSTTYP(L)   = format$("K:2X",mess([M:MFG3]WSTTYP(L),313,1))
            [M:MFG3]WSTEFF(L)    = [M:MFG3]WSTEFF(K)
            [M:MFG3]OPESTR(L)    = [M:MFG1]STRDAT
            [M:MFG3]OPEEND(L)    = [M:MFG1]ENDDAT
            [M:MFG3]ROODES(L)    = [M:MFG3]ROODES(K)
            [M:MFG3]TIMUOMCOD(L) = [M:MFG3]TIMUOMCOD(K)
            [M:MFG3]EXTSETTIM(L) = [M:MFG3]EXTSETTIM(K)
            [M:MFG3]EXTUNTTIM(L) = [M:MFG3]EXTUNTTIM(K)
            [M:MFG3]EXTOPETIM(L) = [M:MFG3]EXTOPETIM(K)
            [M:MFG3]EXTQTY(L)    = [M:MFG3]EXTQTY(K)
            [M:MFG3]EXTSTUQTY(L) = [M:MFG3]EXTSTUQTY(K)
            [M:MFG3]EXTSTRQTY(L) = [M:MFG3]EXTSTRQTY(K)
            [M:MFG3]OPEUOM(L)    = [M:MFG3]OPEUOM(K)
            [M:MFG3]SCOCOD(L)    = [M:MFG3]SCOCOD(K)
            [M:MFG3]SCOWST(L)    = [M:MFG3]SCOWST(K)
            [M:MFG3]SCOITMREF(L) = [M:MFG3]SCOITMREF(K)
            [M:MFG3]BPRNUM(L)    = [M:MFG3]BPRNUM(K)          # llc 02.01 5977 + 12.03 MM
            [M:MFG3]BPAADD(L)    = [M:MFG3]BPAADD(K)          # 12.03 MM
            [M:MFG3]REFPRI(L)    = [M:MFG3]REFPRI(K)          # llc 02.01 5977
            [M:MFG3]SCOLTI(L)    = [M:MFG3]SCOLTI(K)
            [M:MFG3]SCOPUU(L)    = [M:MFG3]SCOPUU(K)
            [M:MFG3]EXTLAB(L)    = [M:MFG3]EXTLAB(K)
            [M:MFG3]LABWCR(L)    = [M:MFG3]LABWCR(K)
            [M:MFG3]EXTLABSHO(L) = [M:MFG3]EXTLABSHO(K)
            [M:MFG3]SETLABCOE(L) = [M:MFG3]SETLABCOE(K)
            [M:MFG3]OPELABCOE(L) = [M:MFG3]OPELABCOE(K)
            [M:MFG3]OPESTUCOE(L) = [M:MFG3]OPESTUCOE(K)
            [M:MFG3]OPESTRCOE(L) = [M:MFG3]OPESTRCOE(K)
            [M:MFG3]ROOTIMCOD(L) = [M:MFG3]ROOTIMCOD(K)
            [M:MFG3]TIMCOD(L)    = [M:MFG3]TIMCOD(K)
            [M:MFG3]BASQTY(L)    = [M:MFG3]BASQTY(K)
            [M:MFG3]CAD(L)       = [M:MFG3]CAD(K)
            [M:MFG3]EFF(L)       = [M:MFG3]EFF(K)
            [M:MFG3]SHR(L)       = [M:MFG3]SHR(K)
            [M:MFG3]WAITIM(L)    = [M:MFG3]WAITIM(K)
            [M:MFG3]PSPTIM(L)    = [M:MFG3]PSPTIM(K)
            [M:MFG3]EXTWSTNBR(L) = [M:MFG3]EXTWSTNBR(K)
            [M:MFG3]EXTLABNBR(L) = [M:MFG3]EXTLABNBR(K)
            [M:MFG3]PRPTIM(L)    = [M:MFG3]PRPTIM(K)
            [M:MFG3]OPEROUPCT(L) = [M:MFG3]OPEROUPCT(K)
            [M:MFG3]OPEPLNNUM(L) = [M:MFG3]OPEPLNNUM(K)
            [M:MFG3]TECCRD(L)    = [M:MFG3]TECCRD(K)
            [M:MFG3]EQUNUM(L)    = [M:MFG3]EQUNUM(K)
            [M:MFG3]FXGNUM(L)    = [M:MFG3]FXGNUM(K)
            [M:MFG3]PRGNUM(L)    = [M:MFG3]PRGNUM(K)

            # 11.04 26396
            [M:MFG3]NEXOPENUM(L)     = [M:MFG3]NEXOPENUM(K)
            [M:MFG3]SCDCOD(L)        = [M:MFG3]SCDCOD(K)
            [M:MFG3]SCDTIM(L)        = [M:MFG3]SCDTIM(K)
            [M:MFG3]SCDQTY(L)        = [M:MFG3]SCDQTY(K)
            [M:MFG3]SCDLOT(L)        = [M:MFG3]SCDLOT(K)
            [M:MFG3]DACMST(L)        = [M:MFG3]DACMST(K)
            [M:MFG3]MFGMST(L)        = [M:MFG3]MFGMST(K)

            # données capacité finie
            If dim([M:MFG3]OPENUMLEV(L)) > 0 : [M:MFG3]OPENUMLEV(L)=[M:MFG3]OPENUMLEV(K) : Endif
            If dim([M:MFG3]ALTOPECOD(L)) > 0 : [M:MFG3]ALTOPECOD(L)=[M:MFG3]ALTOPECOD(K) : Endif
            If dim([M:MFG3]SPLCOD(L))    > 0 : [M:MFG3]SPLCOD(L)   =[M:MFG3]SPLCOD(K)    : Endif
            If dim([M:MFG3]SPLMAXNBR(L)) > 0 : [M:MFG3]SPLMAXNBR(L)=[M:MFG3]SPLMAXNBR(K) : Endif
            If dim([M:MFG3]RSTMAC(L))    > 0 : [M:MFG3]RSTMAC(L)   =[M:MFG3]RSTMAC(K)    : Endif
            If dim([M:MFG3]SCHGRP(L))    > 0 : [M:MFG3]SCHGRP(L)   =[M:MFG3]SCHGRP(K)    : Endif
            If dim([M:MFG3]SCHSBB(L))    > 0 : [M:MFG3]SCHSBB(L)   =[M:MFG3]SCHSBB(K)    : Endif    # 08.05 distinction des exemplaires
            If dim([M:MFG3]GRPSETTIM(L)) > 0 : [M:MFG3]GRPSETTIM(L)=[M:MFG3]GRPSETTIM(K) : Endif
           #
            [M:MFG3]MFOTRKFLG(L) = 1
            [M:MFG3]ITMLINNBR(L) = [M:MFG1]NBLIG
            [M:MFG3]FXDTIM(L)    = [M:MFG3]FXDTIM(K)
            [M:MFG3]VARTIM(L)    = [M:MFG3]VARTIM(K)
            [M:MFG3]NBLIG       += 1

            # augmentation quantité opération
            WWRK = WOFFSET
#            Call UPD_OPE_UNI(2, "MFG3", L, [M:MFG3]EFF(L)) From MFGLIBO
# (llc 09.00)
            Call UPD_OPE_UNI(2, "MFG3", L, WWRK) From MFGLIBO
            [M:MFG3]EXTQTY(L) = WWRK
#
            [M:MFG3]STDWST(L)        = [M:MFG3]EXTWST(L)
            [M:MFG3]STDLAB(L)        = [M:MFG3]EXTLAB(L)
            [M:MFG3]STDWSTNBR(L)     = [M:MFG3]EXTWSTNBR(L)
            [M:MFG3]STDLABNBR(L)     = [M:MFG3]EXTLABNBR(L)
            [M:MFG3]STDUNTTIM(L)     = [M:MFG3]EXTUNTTIM(L)
            [M:MFG3]STDSETTIM(L)     = [M:MFG3]EXTSETTIM(L)
            [M:MFG3]STDOPETIM(L)     = [M:MFG3]EXTOPETIM(L)
            [M:MFG3]STDQTY(L)        = [M:MFG3]EXTQTY(L)
        Endif
    Endif
$NEXT_STR
    I += 1
Wend
#
Sorta [M:MFG3]NBLIG [M:MFG3]NBLIG Order By [M:MFG3]OPENUM(indice),
&     [M:MFG3]OPESPLNUM(indice)
Affzo [M:MFG3]10

Call TEMPOFF From GESECRAN
#
End

##################################################################
# modification globale des quantités des opérations
Subprog UPD_DAT_GLOB(LMIN, LMAX, LDEB, LFIN)
Value Integer LMIN  # ligne départ
Value Integer LMAX  # ligne fin
Value Date    LDEB  # nouvelle date début
Value Date    LFIN  # nouvelle date fin

# un petit message pour patienter ...
Call TEMPON(mess(93,195,1)) From GESECRAN

# boucle de recherche des opérations concernées
For I=LMIN To LMAX
    # llc 06.02 14484
    If [M:MFG3]OPESTA(I) <> 7
        [M:MFG3]OPESTR(I)    = LDEB
        [M:MFG3]OPEEND(I)    = LFIN
    Endif
Next I
#
Affzo [M:MFG3]10
Call TEMPOFF From GESECRAN
#
End

##################################################################
# modification unitaire des opérations
# LCOD indique quelle zone a été modifiée
#                 1 = poste de charge (donc efficience poste)
#                 2 = quantité opératoire
#                 3 = temps réglage
#                 4 = temps unitaire
#                 5 = temps opératoire
#                 6 = efficience opération
#                 7 = temps préparation
#                 8 = temps attente
#                 9 = temps post-opératoire
#                10 = coefficient US/UO
#                11 = appliquer % compression
#                12 = décompression
#                13 = nombre de postes (si main d'oeuvre)
#                14 = annulation efficience
#                15 = annulation perte
#                16 = perte
#                17 = cadence
# ABMSK est le masque origine
# L     est le no ligne si ABMSK = tableau
# LWRK  est la donnée modifiée
# c'est un peu compliqué et répétitif mais il ne semble pas y avoir de méthode simple ...
# on pourrait avoir un algorithme unique indépendant du masque via des "assign" et des
# "evalue" mais cela serait encore moins lisible !!
#########################################################################################
Subprog UPD_OPE_UNI(LCOD, ABMSK, L, LWRK)
Value     Integer  LCOD
Value     Char     ABMSK        # masque à alimenter
Value     Integer  L
Value     Decimal  LWRK #, LSAV, WUNTTIM    # llc 04.02 14041
Local     Decimal  LSAV, WUNTTIM            # llc 04.02 14041  # GA 11/2010 ctrl des sources
Local     Char     DEST(20), DEST2(20), LSAV2(20)       # llc 05.02 cohérence
#

Case ABMSK
    When "MFO1" : DEST  = "[M:"+ABMSK+"]"
                  DEST2 = "[M:MFO2]"
    When "MFO"  : DEST = "[F:"+ABMSK+"]"
                  DEST2 = "[F:MFO]"
Endcase
#

Case ABMSK
    When "MFO1", "MFO":
            Case LCOD
                When 1:    If GWSTEFFINH = 1
                               # 04.05 13839
                               If GOPEEFFAPP = 1
                                   # recalcul temps réglage (tps / eff anc poste * eff nouv poste)
                                   Assign DEST+"EXTSETTIM" With evalue(DEST+"EXTSETTIM")  /
&                                                (evalue(DEST+"EFF")   / 100) /
&                                                (LWRK                    / 100)
                               Endif
                               # recalcul temps opératoire
                               Assign DEST+"EXTOPETIM" With evalue(DEST+"EXTOPETIM")  /
&                                            (evalue(DEST+"EFF")   / 100) /
&                                            (LWRK                    / 100)
                               # recalcul temps unitaire
                               If evalue(DEST+"EXTQTY")<>0
                                   Assign DEST+"EXTUNTTIM" With evalue(DEST+"EXTOPETIM") /
&                                                evalue(DEST+"EXTQTY")
                               Endif
                               If ABMSK = "MFO1"
                                   # recalcul temps charge
                                   Assign DEST+"VARTIM" With evalue(DEST+"EXTSETTIM")    +
&                                                evalue(DEST+"EXTOPETIM")
                               Endif
                            Endif
                When 2:    # recalcul temps opératoire sauf si temps forfaitaire
                          # Issue 88145 GA 03/2013 sauf si evalue(DEST+"EXTQTY")=0
                           If evalue(DEST+"ROOTIMCOD") <> 3 & evalue(DEST+"EXTQTY")<>0
#                               Assign DEST+"EXTOPETIM" With LWRK *
#&                                        evalue(DEST+"EXTUNTTIM")
                               WUNTTIM = evalue(DEST+"EXTOPETIM") / evalue(DEST+"EXTQTY") # llc 04.02 14041
                               Assign DEST+"EXTOPETIM" With LWRK * WUNTTIM                # llc 04.02 14041
                               If ABMSK = "MFO1"
                                   # recalcul temps charge
                                   Assign DEST+"VARTIM" With evalue(DEST+"EXTSETTIM") +
&                                            evalue(DEST+"EXTOPETIM")
                               Endif
                           Elsif evalue(DEST+"ROOTIMCOD") = 3 & LWRK<>0 : # GH 29/11/2013 bug 94842
                               Assign DEST+"EXTUNTTIM" With evalue(DEST+"EXTOPETIM") / LWRK
                           Endif
                          # Issue 88145 GA 03/2013 sauf si evalue(DEST+"OPESTUCOE")=0
                           If evalue(DEST+"OPESTUCOE")<>0
                              Assign DEST+"EXTSTUQTY" With LWRK / evalue(DEST+"OPESTUCOE")
                           Endif
                           Assign DEST+"EXTSTRQTY" With LWRK * evalue(DEST2+"OPESTRCOE")
                When 3:    If ABMSK = "MFO1"
                               # recalcul temps charge
                               Assign DEST+"VARTIM" With LWRK + evalue(DEST+"EXTOPETIM")
                           Endif
                When 4:    # recalcul temps opératoire
                           Assign DEST+"EXTOPETIM" With evalue(DEST+"EXTQTY") * LWRK
                           If ABMSK = "MFO1"
                               # recalcul temps charge
                               Assign DEST+"VARTIM" With evalue(DEST+"EXTSETTIM") +
&                                           evalue(DEST+"EXTOPETIM")
                           Endif
                When 5:    # recalcul temps unitaire
                           If evalue(DEST+"EXTQTY")<>0
                               Assign DEST+"EXTUNTTIM" With LWRK / evalue(DEST+"EXTQTY")
                           Endif
                           If ABMSK = "MFO1"
                               # recalcul temps charge
                               Assign DEST+"VARTIM" With evalue(DEST+"EXTSETTIM") + LWRK
                           Endif
                When 6:    Case GWSTEFFINH
                               When 1:
                                    # 04.05 13839
                                    If GOPEEFFAPP = 1
                                        # recalcul temps réglage
                                        Assign DEST+"EXTSETTIM" With evalue(DEST+"EXTSETTIM")   /
&                                                                   (evalue(DEST+"WSTEFF") / 100) /
&                                                                   (LWRK               / 100)
                                    Endif
                                    # recalcul temps opératoire
                                    Assign DEST+"EXTOPETIM" With evalue(DEST+"EXTOPETIM") /
&                                                               (evalue(DEST+"WSTEFF")  / 100) /
&                                                               (LWRK                / 100)
                               When Default:
                                    # 04.05 13839
                                    If GOPEEFFAPP = 1
                                        # recalcul temps réglage
                                        Assign DEST+"EXTSETTIM" With evalue(DEST+"EXTSETTIM")   /
&                                                                   (LWRK               / 100)
                                    Endif
                                    # recalcul temps opératoire
                                    Assign DEST+"EXTOPETIM" With evalue(DEST+"EXTOPETIM") /
&                                                               (LWRK                / 100)
                           Endcase
                           # recalcul temps unitaire
                           If evalue(DEST+"EXTQTY")<>0
                               Assign DEST+"EXTUNTTIM" With evalue(DEST+"EXTOPETIM") /
&                                       evalue(DEST+"EXTQTY")
                           Endif
                           If ABMSK = "MFO1"
                               # recalcul temps charge
                               Assign DEST+"VARTIM" With evalue(DEST+"EXTSETTIM") +
&                                           evalue(DEST+"EXTOPETIM")
                           Endif
                When 7:    If ABMSK = "MFO1"
                               # recalcul temps hors charge
                               If  evalue(DEST+"WAITIM") > evalue(DEST+"PSPTIM")
                                   Assign DEST+"FXDTIM" With LWRK + evalue(DEST+"WAITIM")
                               Else
                                   Assign DEST+"FXDTIM" With LWRK + evalue(DEST+"PSPTIM")
                               Endif
                           Endif
                When 8:    If ABMSK = "MFO1"
                               # recalcul temps hors charge
                               If  LWRK > evalue(DEST+"PSPTIM")
                                   Assign DEST+"FXDTIM" With evalue(DEST+"PRPTIM") + LWRK
                               Else
                                   Assign DEST+"FXDTIM" With evalue(DEST+"PRPTIM") +
&                                          evalue(DEST+"PSPTIM")
                               Endif
                            Endif
                When 9:    If ABMSK = "MFO1"
                               # recalcul temps hors charge
                               If  evalue(DEST+"WAITIM") > LWRK
                                   Assign DEST+"FXDTIM" With evalue(DEST+"PRPTIM") +
&                                         evalue(DEST+"WAITIM")
                               Else
                                   Assign DEST+"FXDTIM" With evalue(DEST+"PRPTIM") + LWRK
                               Endif
                            Endif
                When 10:   # recalcul quantité opération
                           Assign DEST+"EXTQTY" With evalue(DEST+"EXTSTUQTY") * LWRK
                           LSAV  = evalue (DEST+"EXTQTY")
                           LSAV2 = evalue (DEST+"OPEUOM")
                           Call QTEARR(LSAV,LSAV2) From TRTDIV
                           # 36660 mm 06.06
                           Assign DEST+"EXTQTY" With LSAV
                           Assign DEST+"EXTSTRQTY" With LSAV * evalue(DEST2+"OPESTRCOE")
                           # recalcul du temps unitaire
                           If evalue (DEST+"EXTQTY")<>0
                               Assign DEST+"EXTUNTTIM" With evalue(DEST+"EXTOPETIM") /
&                                                           evalue (DEST+"EXTQTY")
                           Endif
                When 11,12:# rien
                When 13:
# llc 03.01 multi-exemplaire
# recalcul temps opératoire
#                            Assign DEST+"EXTOPETIM" With evalue(DEST+"EXTOPETIM") *
#&                                       evalue(DEST+"EXTWSTNBR")                 /
#&                                       LWRK
#                           # recalcul temps unitaire
#                           Assign DEST+"EXTUNTTIM" With evalue(DEST+"EXTOPETIM") /
#&                                       evalue(DEST+"EXTQTY")
#                           If ABMSK = "MFO1"
#                               # recalcul temps charge
#                               Assign DEST+"VARTIM" With evalue(DEST+"EXTSETTIM") +
#&                                           evalue(DEST+"EXTOPETIM")
#                           Endif
                When 14:    # annulation efficience
                           Case GWSTEFFINH
                               When 1:
                                   # 04.05 13839
                                   If GOPEEFFAPP = 1
                                       Assign DEST+"EXTSETTIM" With evalue(DEST+"EXTSETTIM")   *
&                                                                   (evalue(DEST+"WSTEFF") / 100) *
&                                                                   (LWRK               / 100)
                                   Endif
                                   # recalcul temps opératoire
                                   Assign DEST+"EXTOPETIM" With evalue(DEST+"EXTOPETIM") *
&                                                               (evalue(DEST+"WSTEFF")  / 100) *
&                                                               (LWRK                / 100)
                               When Default:
                                   # 04.05 13839
                                   If GOPEEFFAPP = 1
                                       Assign DEST+"EXTSETTIM" With evalue(DEST+"EXTSETTIM")   *
&                                                                   (LWRK               / 100)
                                   Endif
                                   # recalcul temps opératoire
                                   Assign DEST+"EXTOPETIM" With evalue(DEST+"EXTOPETIM") *
&                                                               (LWRK                / 100)
                           Endcase
                           # recalcul temps unitaire
                           If evalue(DEST+"EXTQTY")<>0
                               Assign DEST+"EXTUNTTIM" With evalue(DEST+"EXTOPETIM") /
&                                       evalue(DEST+"EXTQTY")
                           Endif
                           If ABMSK = "MFO1"
                               # recalcul temps charge
                               Assign DEST+"VARTIM" With evalue(DEST+"EXTSETTIM") +
&                                           evalue(DEST+"EXTOPETIM")
                           Endif
                When 15:    # annulation perte
                           Assign DEST+"EXTQTY" With evalue (DEST+"EXTQTY") / (1 + (LWRK / 100))
                           LSAV = evalue (DEST+"EXTQTY")
                           LSAV2= evalue (DEST+"OPEUOM")
                           Call QTEARR(LSAV,LSAV2) From TRTDIV
                           Assign DEST+"EXTQTY" With LSAV
                          # Issue 88145 GA 03/2013 sauf si evalue(DEST+"EXTQTY")=0
                           If evalue(DEST+"ROOTIMCOD") <> 3 & evalue(DEST+"EXTQTY")<>0
#                               Assign DEST+"EXTOPETIM" With evalue(DEST+"EXTQTY") *
#&                                        evalue(DEST+"EXTUNTTIM")
                               WUNTTIM = evalue(DEST+"EXTOPETIM") / evalue(DEST+"EXTQTY")     # llc 04.02 14041
                               Assign DEST+"EXTOPETIM" With evalue(DEST+"EXTQTY") * WUNTTIM   # llc 04.02 14041
                               If ABMSK = "MFO1"
                                   # recalcul temps charge
                                   Assign DEST+"VARTIM" With evalue(DEST+"EXTSETTIM") +
&                                             evalue(DEST+"EXTOPETIM")
                               Endif
                           Endif
                           Assign DEST+"EXTSTUQTY" With evalue(DEST+"EXTQTY") / evalue(DEST+"OPESTUCOE")
                           Assign DEST+"EXTSTRQTY" With evalue(DEST+"EXTQTY") * evalue(DEST2+"OPESTRCOE")
                When 16:   # perte
                           Assign DEST+"EXTQTY" With evalue (DEST+"EXTQTY") * (1 + (LWRK / 100))
                           LSAV = evalue (DEST+"EXTQTY")
                           LSAV2= evalue (DEST+"OPEUOM")
                           Call QTEARR(LSAV,LSAV2) From TRTDIV
                           Assign DEST+"EXTQTY" With LSAV
                          # Issue 88145 GA 03/2013 sauf si evalue(DEST+"EXTQTY")=0
                           If evalue(DEST+"ROOTIMCOD") <> 3 & evalue(DEST+"EXTQTY")<>0
#                              Assign DEST+"EXTOPETIM" With evalue(DEST+"EXTQTY") *
#&                                        evalue(DEST+"EXTUNTTIM")
                               WUNTTIM = evalue(DEST+"EXTOPETIM") / evalue(DEST+"EXTQTY")     # 97325 mm 05.2014
                               Assign DEST+"EXTOPETIM" With evalue(DEST+"EXTQTY") * WUNTTIM   # 97325 mm 05.2014
                               If ABMSK = "MFO1"
                                   # recalcul temps charge
                                   Assign DEST+"VARTIM" With evalue(DEST+"EXTSETTIM") +
&                                            evalue(DEST+"EXTOPETIM")
                               Endif
                           Endif
                           Assign DEST+"EXTSTUQTY" With evalue(DEST+"EXTQTY") / evalue(DEST+"OPESTUCOE")
                           Assign DEST+"EXTSTRQTY" With evalue(DEST+"EXTQTY") * evalue(DEST2+"OPESTRCOE")
                When 17:    # recalcul temps unitaire
                           # GH 04/02/13 bug 87174 prise en compte de l'efficience
                           # Assign DEST+"EXTOPETIM" With evalue(DEST+"EXTQTY") / LWRK
                           Case GWSTEFFINH
                               When 1:
                                    Assign DEST+"EXTOPETIM" With evalue(DEST+"EXTQTY") / LWRK /
&                                                               (evalue(DEST+"EFF")  / 100) /
&                                                               (evalue(DEST+"WSTEFF")  / 100)
                               When Default:
                                    Assign DEST+"EXTOPETIM" With evalue(DEST+"EXTQTY") / LWRK /
&                                                               (evalue(DEST+"EFF")  / 100)
                           Endcase
                           If evalue(DEST+"EXTQTY")<>0
                               Assign DEST+"EXTUNTTIM" With evalue(DEST+"EXTOPETIM") / evalue(DEST+"EXTQTY")
                           Endif
                           If ABMSK = "MFO1"
                               # recalcul temps charge
                               Assign DEST+"VARTIM" With evalue(DEST+"EXTSETTIM") + evalue(DEST+"EXTOPETIM")
                           Endif
            Endcase
            Assign DEST+"PRPTIM"    With func TRTX3.ARRTYP("", "", "TIH", evalue(DEST+"PRPTIM"))
            Assign DEST+"PSPTIM"    With func TRTX3.ARRTYP("", "", "TIH", evalue(DEST+"PSPTIM"))
            Assign DEST+"EXTSETTIM" With func TRTX3.ARRTYP("", "", "TIH", evalue(DEST+"EXTSETTIM"))
            Assign DEST+"EXTOPETIM" With func TRTX3.ARRTYP("", "", "TIH", evalue(DEST+"EXTOPETIM"))
            Assign DEST+"EXTUNTTIM" With func TRTX3.ARRTYP("", "", "TIH", evalue(DEST+"EXTUNTTIM"))
            If ABMSK <> "MFO"
               Assign DEST+"FXDTIM" With func TRTX3.ARRTYP("", "", "TIH", evalue(DEST+"FXDTIM(L)"))
               Assign DEST+"VARTIM" With func TRTX3.ARRTYP("", "", "TIH", evalue(DEST+"VARTIM(L)"))
               If LCOD <> 2 : Affzo [M:MFO1]EXTQTY    : Endif
               If LCOD <> 3 : Affzo [M:MFO1]EXTSETTIM : Endif
               If LCOD <> 4 : Affzo [M:MFO1]EXTUNTTIM : Endif
               If LCOD <> 5 : Affzo [M:MFO1]EXTOPETIM : Endif
            Endif
    When Default:
                Case LCOD
                When 1:    If GWSTEFFINH = 1
                               # 04.05 13839
                               If GOPEEFFAPP = 1
                                   # recalcul temps réglage (tps / eff anc poste * eff nouv poste)
                                   [M:MFG3]EXTSETTIM(L) = [M:MFG3]EXTSETTIM(L) /
&                                                         ([M:MFG3]EFF(L)    / 100) /
&                                                         (LWRK              / 100)
                               Endif
                               # recalcul temps opératoire
                               [M:MFG3]EXTOPETIM(L) = [M:MFG3]EXTOPETIM(L) /
&                                                     ([M:MFG3]EFF(L)      / 100) /
&                                                     (LWRK                / 100)
                               # recalcul temps unitaire
                               If [M:MFG3]EXTQTY(L)<>0
                                   [M:MFG3]EXTUNTTIM(L) = [M:MFG3]EXTOPETIM(L) / [M:MFG3]EXTQTY(L)
                               Endif
                               # recalcul temps charge
                               [M:MFG3]VARTIM(L) = [M:MFG3]EXTSETTIM(L) + [M:MFG3]EXTOPETIM(L)
                           Endif
                When 2:    # recalcul temps opératoire sauf si temps forfaitaire
                          # Issue 88145 GA 03/2013 sauf si evalue(DEST+"EXTQTY")=0
                           If [M:MFG3]ROOTIMCOD(L) <> 3 & [M:MFG3]EXTQTY(L)<>0
#                               [M:MFG3]EXTOPETIM(L) = LWRK * [M:MFG3]EXTUNTTIM(L)
                               WUNTTIM = [M:MFG3]EXTOPETIM(L) / [M:MFG3]EXTQTY(L)     # llc 04.02 14041
                               [M:MFG3]EXTOPETIM(L) =  LWRK * WUNTTIM                 # llc 04.02 14041
                           Elsif [M:MFG3]ROOTIMCOD(L) = 3 & LWRK<>0 : #  # GH 29/11/2013 bug 94842
                               [M:MFG3]EXTUNTTIM(L) =  [M:MFG3]EXTOPETIM(L) / LWRK
                           Endif
                           # recalcul temps charge
                           [M:MFG3]VARTIM(L) = [M:MFG3]EXTSETTIM(L) + [M:MFG3]EXTOPETIM(L)
                           [M:MFG3]EXTSTUQTY(L) = LWRK / [M:MFG3]OPESTUCOE(L)
                           Call QTEARR([M:MFG3]EXTSTUQTY(L),[M:MFG1]MFGSTU) From TRTDIV
                           [M:MFG3]EXTSTRQTY(L) = LWRK * [M:MFG3]OPESTRCOE(L)
                           # FQ 77413 GA 10/2011 arrondir
                           Call QTEARR([M:MFG3]EXTSTRQTY(L),[M:MFG3]SCOPUU(L)) From TRTDIV
                When 3:    # recalcul temps charge
                           [M:MFG3]VARTIM(L) = LWRK + [M:MFG3]EXTOPETIM(L)
                When 4:    # recalcul temps opératoire
                           [M:MFG3]EXTOPETIM(L) = [M:MFG3]EXTQTY(L) * LWRK
                           # recalcul temps charge
                           [M:MFG3]VARTIM(L) = [M:MFG3]EXTSETTIM(L) + [M:MFG3]EXTOPETIM(L)
                When 5:    # recalcul temps unitaire
                           If [M:MFG3]EXTQTY(L)<>0
                               [M:MFG3]EXTUNTTIM(L) = LWRK / [M:MFG3]EXTQTY(L)
                           Endif
                           # recalcul temps charge
                           [M:MFG3]VARTIM(L) = [M:MFG3]EXTSETTIM(L) + LWRK
                           Affzo [M:MFG3]EXTUNTTIM(L)
                When 6: Case GWSTEFFINH
                               When 1:
                                   # 04.05 13839
                                   If GOPEEFFAPP = 1   : #Issue X3-92481 01/06/2018 by GEBIL : Fix #X3-58295.n canceled : Not consistent with all cases
                                   #If GOPEEFFAPP = 1 and [M:MFG3]ROOTIMCOD(L) <> 3        #X3-58295.n
                                       # recalcul temps réglage
                                       [M:MFG3]EXTSETTIM(L) = [M:MFG3]EXTSETTIM(L) /
&                                                             ([M:MFG3]WSTEFF(L) / 100) /
&                                                             (LWRK           / 100)
                                   Endif

                                   # recalcul temps opératoire
                                   [M:MFG3]EXTOPETIM(L) = [M:MFG3]EXTOPETIM(L) /
&                                                          ([M:MFG3]WSTEFF(L) / 100) /
&                                                          (LWRK           / 100)
                               When Default:
                                   # 04.05 13839
                                   If GOPEEFFAPP = 1
                                       # recalcul temps réglage
                                       [M:MFG3]EXTSETTIM(L) = [M:MFG3]EXTSETTIM(L) /
&                                                             (LWRK           / 100)
                                   Endif
                                   # recalcul temps opératoire
                                   [M:MFG3]EXTOPETIM(L) = [M:MFG3]EXTOPETIM(L) /
&                                                         (LWRK           / 100)
                           Endcase
                           # recalcul temps unitaire
                           If [M:MFG3]EXTQTY(L)<>0
                               [M:MFG3]EXTUNTTIM(L) = [M:MFG3]EXTOPETIM(L) / [M:MFG3]EXTQTY(L)
                           Endif

                           # recalcul temps charge
                           [M:MFG3]VARTIM(L) = [M:MFG3]EXTSETTIM(L) + [M:MFG3]EXTOPETIM(L)
                When 7:    # recalcul temps hors charge
                           If  [M:MFG3]WAITIM(L) > [M:MFG3]PSPTIM(L)
                               [M:MFG3]FXDTIM(L) = LWRK + [M:MFG3]WAITIM(L)
                           Else
                               [M:MFG3]FXDTIM(L) = LWRK + [M:MFG3]PSPTIM(L)
                           Endif
                When 8:    # recalcul temps hors charge
                           If  LWRK > [M:MFG3]PSPTIM(L)
                               [M:MFG3]FXDTIM(L) = [M:MFG3]PRPTIM(L) + LWRK
                           Else
                               [M:MFG3]FXDTIM(L) = [M:MFG3]PRPTIM(L) + [M:MFG3]PSPTIM(L)
                           Endif
                When 9:    # recalcul temps hors charge
                           If  [M:MFG3]WAITIM(L) > LWRK
                               [M:MFG3]FXDTIM(L) = [M:MFG3]PRPTIM(L) + [M:MFG3]WAITIM(L)
                           Else
                               [M:MFG3]FXDTIM(L) = [M:MFG3]PRPTIM(L) + LWRK
                           Endif
                When 10:   # recalcul quantité opération
                           [M:MFG3]EXTQTY(L)     = [M:MFG3]EXTSTUQTY(L) * LWRK
                           Call QTEARR([M:MFG3]EXTQTY(L),[M:MFG3]OPEUOM(L)) From TRTDIV
                           [M:MFG3]EXTSTRQTY(L)  = [M:MFG3]EXTQTY(L)    * [M:MFG3]OPESTRCOE(L)    # 07.05 31330
                           # FQ 77413 GA 10/2011 arrondir
                           Call QTEARR([M:MFG3]EXTSTRQTY(I),[M:MFG3]SCOPUU(I)) From TRTDIV
                          # recalcul du temps unitaire
                           If [M:MFG3]EXTQTY(L)<>0
                               [M:MFG3]EXTUNTTIM(L) = [M:MFG3]EXTOPETIM(L) / [M:MFG3]EXTQTY(L)
                           Endif
                When 11:   # recalcul des temps hors charge
                           If LWRK > 100
                               LWRK -= 100
                               LWRK *= -1
                           Endif
                           Case GTPSCOMP
                               When 1:    # rien
                               When 2:    # compression temps attente uniquement
                                          [M:MFG3]WAITIM(L) = [M:MFG3]WAITIM(L) *
&                                                             ((100 - LWRK) / 100)
                               When 3:    # compression temps préparation + post-opératoire
                                          [M:MFG3]PRPTIM(L) = [M:MFG3]PRPTIM(L) *
&                                                             ((100 - LWRK) / 100)
                                          [M:MFG3]PSPTIM(L) = [M:MFG3]PSPTIM(L) *
&                                                             ((100 - LWRK) / 100)
                               When 4:    # compression des 3 temps
                                          [M:MFG3]WAITIM(L) = [M:MFG3]WAITIM(L) *
&                                                             ((100 - LWRK) / 100)
                                          [M:MFG3]PRPTIM(L) = [M:MFG3]PRPTIM(L) *
&                                                             ((100 - LWRK) / 100)
                                          [M:MFG3]PSPTIM(L) = [M:MFG3]PSPTIM(L) *
&                                                             ((100 - LWRK) / 100)
                               When 5:    # compresssion temps de préparation
                                          [M:MFG3]PRPTIM(L)    = [M:MFG3]PRPTIM(L) *
&                                                             ((100 - LWRK) / 100)
                               When 6:    # compresssion temps post-opératoire
                                           [M:MFG3]PSPTIM(L)    = [M:MFG3]PSPTIM(L) *
&                                                             ((100 - LWRK) / 100)
                               When 7:    # compression temps préparation + attente
                                          [M:MFG3]PRPTIM(L)    = [M:MFG3]PRPTIM(L) *
&                                                             ((100 - LWRK) / 100)
                                          [M:MFG3]WAITIM(L)    = [M:MFG3]WAITIM(L) *
&                                                             ((100 - LWRK) / 100)
                               When 8:    # compression temps post-opératoire + attente
                                          [M:MFG3]PSPTIM(L)    = [M:MFG3]PSPTIM(L) *
&                                                             ((100 - LWRK) / 100)
                                          [M:MFG3]WAITIM(L)    = [M:MFG3]WAITIM(L) *
&                                                             ((100 - LWRK) / 100)
                           Endcase
                           If  [M:MFG3]WAITIM(L) > [M:MFG3]PSPTIM(L)
                               [M:MFG3]FXDTIM(L) = [M:MFG3]PRPTIM(L) +
&                                                  [M:MFG3]WAITIM(L)
                           Else
                               [M:MFG3]FXDTIM(L) = [M:MFG3]PRPTIM(L) +
&                                                  [M:MFG3]PSPTIM(L)
                           Endif
                When 12:   # recalcul des temps hors charge
                           If LWRK > 100
                               LWRK -= 100
                               LWRK *= -1
                           Endif
                           Case GTPSCOMP
                               When 1:    # rien
                               When 2:    # décompression temps attente uniquement
                                          If LWRK <> 100
                                              [M:MFG3]WAITIM(L) = [M:MFG3]WAITIM(L) /
&                                                                 ((100 - LWRK) / 100)
                                          Endif
                               When 3:    # compression temps préparation + post-opératoire
                                          If LWRK <> 100
                                              [M:MFG3]PRPTIM(L) = [M:MFG3]PRPTIM(L) /
&                                                                 ((100 - LWRK) / 100)
                                              [M:MFG3]PSPTIM(L) = [M:MFG3]PSPTIM(L) /
&                                                                 ((100 - LWRK) / 100)
                                          Endif
                               When 4:    # compression des 3 temps
                                          If LWRK <> 100
                                              [M:MFG3]WAITIM(L) = [M:MFG3]WAITIM(L) /
&                                                                 ((100 - LWRK) / 100)
                                              [M:MFG3]PRPTIM(L) = [M:MFG3]PRPTIM(L) /
&                                                                 ((100 - LWRK) / 100)
                                              [M:MFG3]PSPTIM(L) = [M:MFG3]PSPTIM(L) /
&                                                                 ((100 - LWRK) / 100)
                                       Endif
                               When 5:    # compresssion temps de préparation
                                          If LWRK <> 100
                                              [M:MFG3]PRPTIM(L)    = [M:MFG3]PRPTIM(L) /
&                                                                 ((100 - LWRK) / 100)
                                          Endif
                               When 6:    # compresssion temps post-opératoire
                                          If LWRK <> 100
                                              [M:MFG3]PSPTIM(L)    = [M:MFG3]PSPTIM(L) /
&                                                                 ((100 - LWRK) / 100)
                                          Endif
                               When 7:    # compression temps préparation + attente
                                          If LWRK <> 100
                                              [M:MFG3]PRPTIM(L)    = [M:MFG3]PRPTIM(L) /
&                                                                 ((100 - LWRK) / 100)
                                              [M:MFG3]WAITIM(L)    = [M:MFG3]WAITIM(L) /
&                                                                 ((100 - LWRK) / 100)
                                          Endif
                               When 8:    # compression temps post-opératoire + attente
                                          If LWRK <> 100
                                              [M:MFG3]PSPTIM(L)    = [M:MFG3]PSPTIM(L) /
&                                                                 ((100 - LWRK) / 100)
                                              [M:MFG3]WAITIM(L)    = [M:MFG3]WAITIM(L) /
&                                                                 ((100 - LWRK) / 100)
                                          Endif
                           Endcase
                           If  [M:MFG3]WAITIM(L) > [M:MFG3]PSPTIM(L)
                               [M:MFG3]FXDTIM(L) = [M:MFG3]PRPTIM(L) +
&                                                  [M:MFG3]WAITIM(L)
                           Else
                               [M:MFG3]FXDTIM(L) = [M:MFG3]PRPTIM(L) +
&                                                  [M:MFG3]PSPTIM(L)
                           Endif
                When 13:
# llc 03.01 multi-exemplaire
# recalcul temps opératoire
#                           [M:MFG3]EXTOPETIM(L) = [M:MFG3]EXTOPETIM(L) *
#&                                                 [M:MFG3]EXTWSTNBR(L) /
#&                                                 LWRK
#                           # recalcul temps unitaire
#                           [M:MFG3]EXTUNTTIM(L) = [M:MFG3]EXTOPETIM(L) / [M:MFG3]EXTQTY(L)
#                           # recalcul temps charge
#                           [M:MFG3]VARTIM(L) = [M:MFG3]EXTSETTIM(L) + [M:MFG3]EXTOPETIM(L)
                When 14:    Case GWSTEFFINH
                               When 1:
                                   # 04.05 13839
                                   If GOPEEFFAPP = 1
                                       # annulation efficience
                                       [M:MFG3]EXTSETTIM(L) = [M:MFG3]EXTSETTIM(L) *
&                                                             ([M:MFG3]WSTEFF(L) / 100) *
&                                                             (LWRK           / 100)
                                   Endif
                                   # recalcul temps opératoire
                                   [M:MFG3]EXTOPETIM(L) = [M:MFG3]EXTOPETIM(L) *
&                                                         ([M:MFG3]WSTEFF(L) / 100) *
&                                                         (LWRK           / 100)
                               When Default:
                                   # 04.05 13839
                                   If GOPEEFFAPP = 1
                                       # annulation efficience
                                       [M:MFG3]EXTSETTIM(L) = [M:MFG3]EXTSETTIM(L) *
&                                                             (LWRK           / 100)
                                   Endif
                                   # recalcul temps opératoire
                                   [M:MFG3]EXTOPETIM(L) = [M:MFG3]EXTOPETIM(L) *
&                                                         (LWRK           / 100)
                           Endcase
                           # recalcul temps unitaire
                           If [M:MFG3]EXTQTY(L)<>0
                               [M:MFG3]EXTUNTTIM(L) = [M:MFG3]EXTOPETIM(L) / [M:MFG3]EXTQTY(L)
                           Endif
                           # recalcul temps charge
                           [M:MFG3]VARTIM(L) = [M:MFG3]EXTSETTIM(L) + [M:MFG3]EXTOPETIM(L)
                When 15:   # annulation perte
                           [M:MFG3]EXTQTY(L) = [M:MFG3]EXTQTY(L) / (1 + (LWRK / 100))
                           Call QTEARR([M:MFG3]EXTQTY(L),[M:MFG3]OPEUOM(L)) From TRTDIV

                          # Issue 88145 GA 03/2013 sauf si evalue(DEST+"EXTQTY")=0
                           If [M:MFG3]ROOTIMCOD(L) <> 3 & [M:MFG3]EXTQTY(L)<>0
#                               [M:MFG3]EXTOPETIM(L) = [M:MFG3]EXTQTY(L) * [M:MFG3]EXTUNTTIM(L)
                               WUNTTIM = [M:MFG3]EXTOPETIM(L) / [M:MFG3]EXTQTY(L)     # llc 04.02 14041
                               [M:MFG3]EXTOPETIM(L) =  [M:MFG3]EXTQTY(L) * WUNTTIM    # llc 04.02 14041
                            Endif
                           # recalcul temps charge
                           [M:MFG3]VARTIM(L) = [M:MFG3]EXTSETTIM(L) + [M:MFG3]EXTOPETIM(L)
                           [M:MFG3]EXTSTUQTY(L) = [M:MFG3]EXTQTY(L) / [M:MFG3]OPESTUCOE(L)
                           Call QTEARR([M:MFG3]EXTSTUQTY(L),[M:MFG1]MFGSTU) From TRTDIV
                           [M:MFG3]EXTSTRQTY(L) = [M:MFG3]EXTQTY(L) * [M:MFG3]OPESTRCOE(L)
                           # FQ 77413 GA 10/2011 arrondir
                           Call QTEARR([M:MFG3]EXTSTRQTY(L),[M:MFG3]SCOPUU(L)) From TRTDIV
                When 16:   # perte
                           [M:MFG3]EXTQTY(L) = [M:MFG3]EXTQTY(L) * (1 + (LWRK / 100))
                           Call QTEARR([M:MFG3]EXTQTY(L),[M:MFG3]OPEUOM(L)) From TRTDIV
                           If [M:MFG3]ROOTIMCOD(L) <> 3
                               #[M:MFG3]EXTOPETIM(L) = [M:MFG3]EXTQTY(L) * [M:MFG3]EXTUNTTIM(L)
                               WUNTTIM = [M:MFG3]EXTOPETIM(L) / [M:MFG3]EXTQTY(L)     # 97325 mm 05.2014
                               [M:MFG3]EXTOPETIM(L) =  [M:MFG3]EXTQTY(L) * WUNTTIM     # 97325 mm 05.2014
                           Endif
                           # recalcul temps charge
                           [M:MFG3]VARTIM(L) = [M:MFG3]EXTSETTIM(L) + [M:MFG3]EXTOPETIM(L)
                           [M:MFG3]EXTSTUQTY(L) = [M:MFG3]EXTQTY(L) / [M:MFG3]OPESTUCOE(L)
                           Call QTEARR([M:MFG3]EXTSTUQTY(L),[M:MFG1]MFGSTU) From TRTDIV
                           [M:MFG3]EXTSTRQTY(L) = [M:MFG3]EXTQTY(L) * [M:MFG3]OPESTRCOE(L)
                           # FQ 77413 GA 10/2011 arrondir
                           Call QTEARR([M:MFG3]EXTSTRQTY(L),[M:MFG3]SCOPUU(L)) From TRTDIV
                When 17:   # recalcul temps unitaire
                           [M:MFG3]EXTOPETIM(L) = [M:MFG3]EXTQTY(L) / LWRK
                           If [M:MFG3]EXTQTY(L)<>0
                               [M:MFG3]EXTUNTTIM(L) = [M:MFG3]EXTOPETIM(L) / [M:MFG3]EXTQTY(L)
                           Endif
                           [M:MFG3]VARTIM(L) = [M:MFG3]EXTSETTIM(L) + [M:MFG3]EXTOPETIM(L)
            Endcase
            # arrondis
            [M:MFG3]WAITIM(L)    = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]WAITIM(L))
            [M:MFG3]PRPTIM(L)    = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]PRPTIM(L))
            [M:MFG3]PSPTIM(L)    = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]PSPTIM(L))
            [M:MFG3]EXTSETTIM(L) = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]EXTSETTIM(L))
            [M:MFG3]EXTOPETIM(L) = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]EXTOPETIM(L))
            [M:MFG3]EXTUNTTIM(L) = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]EXTUNTTIM(L))
            [M:MFG3]FXDTIM(L)    = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]FXDTIM(L))
            [M:MFG3]VARTIM(L)    = func TRTX3.ARRTYP("", "", "TIH", [M:MFG3]VARTIM(L))
            If LCOD <> 2 : Affzo [M:MFG3]EXTQTY(L)    : Endif
            If LCOD <> 3 : Affzo [M:MFG3]EXTSETTIM(L) : Endif
            If LCOD <> 4 : Affzo [M:MFG3]EXTUNTTIM(L) : Endif
            If LCOD <> 5 : Affzo [M:MFG3]EXTOPETIM(L) : Endif
            Affzo [M:MFG3]FXDTIM(L)
            Affzo [M:MFG3]VARTIM(L)
#
Endcase
#
End

#########################################################################################
# contrôle d'atteinte du seuil de solde automatique
Subprog CONT_SOLDE_OPE(LFCY,LWST, LCPL, LEXT, LRET)
Value     Char     LFCY    # Site
Value     Char     LWST    # poste de charge
Value     Decimal  LCPL    # quantité réalisée
Value     Decimal  LEXT    # quantité prévue
Variable  Integer  LRET    # code retour        0 = rien, 1 = à solder
Local     Decimal  LWRK
Local     Decimal  LPCT
# lecture poste si nécessaire
If [F:MWS]WST <> LWST | [F:MWS]WCRFCY <> LFCY
    Read [MWS]WST0=LWST;LFCY
    If fstat : LRET = 0 : End : Endif
Endif
# calcul seuil pour solde
If [F:MWS]CLEPCTAUT = 0
    LPCT = 100
Else
    LPCT = [F:MWS]CLEPCTAUT
Endif
LWRK = LEXT * (LPCT / 100)
If LWRK <= LCPL
    LRET = 1
Else  # CCC (10/12/08) Bug 50774 : forcer la valeur à 0 si pas de solde
    LRET = 0
Endif
#
End

#########################################################################################
# conversion délai (exprimé en jours calendaires) en heures suivant calendrier
Subprog CONV_LTI_TIME(LFCY, LLTI, LTIMUOM, LTWD, LDAT, LTIME)
Value     Char    LFCY    # site de production
Value     Decimal LLTI    # délai en jours calendaires
Value     Integer LTIMUOM # unité temps (heures, minutes)
Value     Char    LTWD    # schéma hebdomadaire
Value     Date    LDAT    # date de référence
Variable  Decimal LTIME   # temps calculé
Local     Date    WDAT
Local     Decimal WLTI
Local     Decimal WTIM
Local     Integer  I, J, K, IDISP

If LDAT = [0/0/0] : LTIME = 0 : End : Endif
If LLTI = 0       : LTIME = 0 : End : Endif
#
If clalev ([F:TUV]) = 0 : Local File TABUNAVAIL [TUV] : Endif
If clalev ([F:TWD]) = 0 : Local File TABWEEDIA  [TWD]: Endif
#
WDAT = LDAT
WLTI = LLTI

Call LECTURE ("FCY", LFCY, "") From CONTOBJ

# lecture indisponibilités
If  [F:TUV]UVYCOD <> [F:FCY]UVYCOD : Read [F:TUV]UVY0=[F:FCY]UVYCOD     : Endif
If fstat <> 0 : Raz [F:TUV] : Endif

# lecture schéma de référence
If  [F:TWD]TWD <> LTWD : Read [F:TWD]TWD0=LTWD     : Endif
If fstat <> 0 : End : Endif

While (WLTI > 0)

    J = dayn(WDAT) - 1

    # si capacité non nulle pour le jour
    If [F:TWD]DAYCAP(J) <> 0
        IDISP = 1

        If [F:TUV]UVYNBR <> 0
            # indisponibilité ?
            For K = 0 To [F:TUV]UVYNBR - 1
                If WDAT >= [F:TUV]UVYSTRDAT(K) & WDAT <= [F:TUV]UVYENDDAT(K)
                    IDISP = 0
                    Break
                Endif
            Next
        Endif

        # jour OK, décrémentation du délai à appliquer
        If IDISP : WLTI -= 1 : LTIME += [F:TWD]DAYCAPNOM : Endif
    Endif
    WDAT += 1
Wend


#
End

#########################################################################################
# passage en mode sous-traitance
Subprog SUB_CONTRACT(ABMSK,L, LWST)
Value     Char     ABMSK
Value     Integer  L
Variable  Char     LWST
Local     Decimal  WTIME
Local     Decimal  WCOEFF, MCOEFF

Case ABMSK
    When "MFO": Read [MWS]WST0=[M:MFO2]SCOWST;[M:MFG0]MFGFCY
                If fstat : End : Endif
                [M:MFO1]EXTWST      = [F:MWS]WST
                [M:MFO1]WCR         = [F:MWS]WCR
                [M:MFO1]WSTTYP      = [F:MWS]WSTTYP
#                [M:MFO1]WSTDES      = [F:MWS]WSTDES
                #LECTURE du libellé traduisible
                Call LECTEXTRA([M:MFO1]WSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
                [M:MFO1]XWSTTYP     = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
                [M:MFO1]WSTEFF      = [F:MWS]EFF
                [M:MFO2]SCOCOD      = 3
                [M:MFO2]SCOWST      = [F:MWS]WST
                [M:MFO1]LABWCR      = ""
                [M:MFO1]EXTLAB      = ""
                [M:MFO1]LABWSTTYP   = 0
                [M:MFO1]LABWSTDES   = ""
                [M:MFO1]XLABWSTTYP  = ""
                [M:MFO1]ROOTIMCOD   = 3
                [M:MFO1]TIMCOD      = 0
                [M:MFO1]BASQTY      = 0
                [M:MFO1]CAD         = 3
                [M:MFO1]X           = ""
                [M:MFO1]TIMUOM3     = ""
                [M:MFO1]EXTSETTIM   = 0
                [M:MFO1]EXTOPETIM   = 0
                [M:MFO1]EXTUNTTIM   = 0
                [M:MFO1]EXTWSTNBR   = 1
                [M:MFO1]EXTLABNBR   = 1
                [M:MFO1]SETLABCOE   = 0
                [M:MFO1]OPELABCOE   = 0
                [M:MFO1]PRPTIM      = 0
                [M:MFO1]WAITIM      = 0
                [M:MFO1]PSPTIM      = 0
                [M:MFO1]OPEUOM      = [M:MFO1]SCOPUU
                [M:MFO1]VARTIM      = [M:MFO1]EXTOPETIM
                [M:MFO1]FXDTIM      = 0
                [M:MFO2]TECCRD      = ""
                [M:MFO2]OPEPLNNUM   = ""
                [M:MFO2]OPEROUPCT   = ""
                [M:MFO2]EQUNUM      = ""
                [M:MFO2]FXGNUM      = ""
                [M:MFO2]PRGNUM      = ""
                If dim([M:MFO3]SCHGRP)    > 0 : [M:MFO3]SCHGRP      = "" : Endif
                If dim([M:MFO3]SCHSBB)    > 0 : [M:MFO3]SCHSBB      = "" : Endif        # 08.05 distinction des exemplaires
                If dim([M:MFO3]GRPSETTIM) > 0 : [M:MFO3]GRPSETTIM   = 0  : Endif
                If dim([M:MFO3]RSTMAC)    > 0 : [M:MFO3]RSTMAC      = "" : Endif

                # annulation ancienne perte
                Call UPD_OPE_UNI(15, "MFO1", 0, [M:MFO1]SHR) From MFGLIBO

                # recherche coefficient US/UO
                MCOEFF = [M:MFO1]OPESTUCOE
                Call RECH_COEFF([M:MFG1]MFGSTU, [M:MFO1]OPEUOM, WCOEFF) From MFGLIB
                If WCOEFF <> 0
                    [M:MFO1]OPESTUCOE = WCOEFF
                Else
                    [M:MFO1]OPESTUCOE = 1
                    # 42973 mm 09.07 - remplacer l'UO par l'US si pas de coeff US/UO dans TABCOEFF
                    [M:MFO1]OPEUOM = [M:MFG1]MFGSTU
                    Call QTEARR([M:MFO1]EXTSTUQTY,[M:MFO1]OPEUOM) From TRTDIV
                Endif
                If WCOEFF <> MCOEFF
                    Call UPD_OPE_UNI(10, "MFO1", 0, [M:MFO1]OPESTUCOE) From MFGLIBO
                Endif

                # prise en compte du changement de poste (donc d'efficience + perte)
                Case GWSTEFFINH
                    When 1:       Call UPD_OPE_UNI(14, "MFO1", 0, [M:MFO1]EFF) From MFGLIBO
                                  [M:MFO1]WSTEFF=[F:MWS]EFF
                                  Call UPD_OPE_UNI(1,  "MFO1", 0, [M:MFO1]WSTEFF) From MFGLIBO
                    When 2:       Call UPD_OPE_UNI(14, "MFO1", 0, [M:MFO1]EFF) From MFGLIBO
                                  [M:MFO1]EFF = [F:MWS]EFF
                                  Call UPD_OPE_UNI(6,  "MFO1", 0, [M:MFO1]EFF) From MFGLIBO
                Endcase

                # recalcul avec nouvelle perte
                [M:MFO1]SHR=[F:MWS]SHR
                Call UPD_OPE_UNI(16,  "MFO1", 0, [M:MFO1]SHR) From MFGLIBO

                # FQ 74274 GA 10/2011 - FQ 79166 GA 01/2012 avant VALEUR remplacé par [M:MFO1]OPEUOM
                Call COMPLETE_OPEUOM([M:MFG1]ROUNUM,[M:MFO2]SCOITMREF,[M:MFO2]BPRNUM,[M:MFO1]SCOLTI
&                                   ,[M:MFO1]OPEUOM,[M:MFO2]OPESTRCOE,[M:MFO1]SCOPUU)

                [M:MFO1]EXTSTRQTY = [M:MFO1]EXTQTY * [M:MFO2]OPESTRCOE
                # FQ 77413 GA 10/2011 arrondir
                Call QTEARR([M:MFO1]EXTSTRQTY,[M:MFO1]SCOPUU) From TRTDIV
                Actzo [M:MFO2]25
    When "MFG": Read [MWS]WST0=[M:MFG3]SCOWST(L);[M:MFG0]MFGFCY
                If fstat : End : Endif
                LWST                    = [F:MWS]WST
                [M:MFG3]EXTWSTSHO(L)    = [F:MWS]WSTSHO
                [M:MFG3]WCR(L)          = [F:MWS]WCR
                [M:MFG3]WSTTYP(L)       = [F:MWS]WSTTYP
                [M:MFG3]XWSTTYP(L)      = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
                [M:MFG3]WSTEFF(L)       = [F:MWS]EFF
                [M:MFG3]SCOCOD(L)       = 3
                [M:MFG3]SCOWST(L)       = [F:MWS]WST
                [M:MFG3]LABWCR(L)       = ""
                [M:MFG3]EXTLAB(L)       = ""
                [M:MFG3]ROOTIMCOD(L)    = 3
                [M:MFG3]TIMCOD(L)       = 0
                [M:MFG3]BASQTY(L)       = 0
                [M:MFG3]CAD(L)          = 3
                [M:MFG3]EXTSETTIM(L)    = 0
                [M:MFG3]EXTOPETIM(L)    = 0
                [M:MFG3]EXTUNTTIM(L)    = 0
                [M:MFG3]EXTWSTNBR(L)    = 1
                [M:MFG3]EXTLABNBR(L)    = 1
                [M:MFG3]EFF(L)          = [F:MWS]EFF
                [M:MFG3]SETLABCOE(L)    = 0
                [M:MFG3]OPELABCOE(L)    = 0
                [M:MFG3]PRPTIM(L)       = 0
                [M:MFG3]WAITIM(L)       = 0
                [M:MFG3]PSPTIM(L)       = 0
                [M:MFG3]OPEUOM(L)       = [M:MFG3]SCOPUU(L)
                [M:MFG3]VARTIM(L)       = [M:MFG3]EXTOPETIM(L)
                [M:MFG3]FXDTIM(L)       = 0
                [M:MFG3]TECCRD(L)       = ""
                [M:MFG3]OPEPLNNUM(L)    = ""
                [M:MFG3]OPEROUPCT(L)    = ""
                [M:MFG3]EQUNUM(L)       = ""
                [M:MFG3]FXGNUM(L)       = ""
                [M:MFG3]PRGNUM(L)       = ""
                If dim([M:MFG3]SCHGRP(L))    > 0 : [M:MFG3]SCHGRP(L)       = "" : Endif
                If dim([M:MFG3]SCHSBB(L))    > 0 : [M:MFG3]SCHSBB(L)       = "" : Endif        # 08.05 distinction des exemplaires
                If dim([M:MFG3]GRPSETTIM(L)) > 0 : [M:MFG3]GRPSETTIM(L)    = 0  : Endif
                If dim([M:MFG3]RSTMAC(L))    > 0 : [M:MFG3]RSTMAC(L)       = "" : Endif

                # annulation ancienne perte
                Call UPD_OPE_UNI(15, "MFG3", L, [M:MFG3]SHR(L)) From MFGLIBO

                # recherche coefficient US/UO
                MCOEFF = [M:MFG3]OPESTUCOE(L)
                Call RECH_COEFF([M:MFG1]MFGSTU, [M:MFG3]OPEUOM(L), WCOEFF) From MFGLIB
                If WCOEFF <> 0
                    [M:MFG3]OPESTUCOE(L) = WCOEFF
                Else
                    [M:MFG3]OPESTUCOE(L) = 1
                    # 42973 mm 09.07 - remplacer l'UO par l'US si pas de coeff US/UO dans TABCOEFF
                    [M:MFG3]OPEUOM(L) = [M:MFG1]MFGSTU
                    Call QTEARR([M:MFG3]EXTSTUQTY(L),[M:MFG3]OPEUOM(L)) From TRTDIV
                Endif
                If WCOEFF <> MCOEFF
                    Call UPD_OPE_UNI(10, "MFG3", L, [M:MFG3]OPESTUCOE(L)) From MFGLIBO
                Endif

                # prise en compte du changement de poste (donc d'efficience + perte)
                Case GWSTEFFINH
                    When 1:       Call UPD_OPE_UNI(14, "MFG3", L, [M:MFG3]EFF(L)) From MFGLIBO
                                  [M:MFG3]WSTEFF(L)=[F:MWS]EFF
                                  Call UPD_OPE_UNI(1,  "MFG3", L, [M:MFG3]WSTEFF(L)) From MFGLIBO
                    When 2:       Call UPD_OPE_UNI(14, "MFG3", L, [M:MFG3]EFF(L)) From MFGLIBO
                                  [M:MFG3]EFF(L) = [F:MWS]EFF
                                  Call UPD_OPE_UNI(6,  "MFG3", L, [M:MFG3]EFF(L)) From MFGLIBO
                Endcase

                # recalcul avec nouvelle perte
                [M:MFG3]SHR(L)=[F:MWS]SHR
                Call UPD_OPE_UNI(16,  "MFG3", L, [M:MFG3]SHR(L)) From MFGLIBO

                # FQ 74274 GA 10/2011
                Call COMPLETE_OPEUOM([M:MFG1]ROUNUM,[M:MFG3]SCOITMREF(L),[M:MFG3]BPRNUM(L),[M:MFG3]SCOLTI(L)
&                                   ,[M:MFG3]OPEUOM(L),[M:MFG3]OPESTRCOE(L),[M:MFG3]SCOPUU(L))

                [M:MFG3]EXTSTRQTY(L) = [M:MFG3]EXTQTY(L) * [M:MFG3]OPESTRCOE(L)
                # FQ 77413 GA 10/2011 arrondir
                Call QTEARR([M:MFG3]EXTSTRQTY(L),[M:MFG3]SCOPUU(L)) From TRTDIV

                # code jalonnement devient "successeur"    llc 02.01 7900
                [M:MFG3]SCDCOD(L) = 1
                [M:MFG3]SCDTIM(L)=0
                [M:MFG3]SCDQTY(L)=0
                [M:MFG3]SCDLOT(L)=0
                Affzo [M:MFG3]10
Endcase
#
End


#########################################################################################
# annulation du mode sous-traitance
Subprog ASUB_CONTRACT(ABMSK,L, LWST)
Value     Char     ABMSK
Value     Integer  L
Variable  Char     LWST
Local     Decimal  WMFGEXTQTY
Local     Integer  I
Local     Decimal  WCOEFF, WLTI
Local     Integer  VOPE
Local     Integer  OK
Local     Decimal  KHM, VOPESTUCOE, WCOEFF


Case ABMSK
    When "MFO": Raz [M:MFO2]
                If [M:MFO1]ROUOPENUM = 0 : Goto OPE_STD1 : Endif
                # lecture de l'entête de gamme (déjà contrôlée)
                If [F:ROH]ITMREF <> [M:MFG1]ROUNUM
                    Read [ROH]ROH0=[M:MFG1]ROUNUM;[M:MFG1]ROUALT;[M:MFG0]MFGFCY : # Beryl Site en fin de clé primaire
                    If fstat : End : Endif
                Endif


                # recherche de l'opération d'origine
                VOPE=0
                 # FQ 77863 GA 11/2011 vérifier aussi VALSTRDAT # 10.02 Performances
                For [ROO]ROO0 Where FCY = [F:ROH]FCY & ITMREF = [F:ROH]ITMREF & ROUALT = [F:ROH]ROUALT
&                            & OPENUM = [M:MFO1]ROUOPENUM
&                            & (VALENDDAT=[0/0/0] | (VALENDDAT >= [M:MFG1]STRDAT & VALENDDAT<>[0/0/0]) )
&                            & (VALSTRDAT=[0/0/0] | (VALSTRDAT <= [M:MFG1]STRDAT & VALSTRDAT<>[0/0/0]) )
                    If [F:ROO]OPENUM<>VOPE
                        VOPE=[F:ROO]OPENUM
                        Break
                    Endif
                Next
                If VOPE = 0
                    GMESSAGE = mess(138,193,1)
                    Call ERREUR(GMESSAGE) From GESECRAN
                    End
                Endif

                [M:MFO0]             = [F:ROO]
                [M:MFO1]             = [F:ROO]
                [M:MFO2]             = [F:ROO]

                # alimentation de l'opération
                [M:MFO0]OPENUM       = [F:ROO]OPENUM
                [M:MFO0]STDOPENUM    = [F:ROO]STDOPENUM
                [M:MFO1]ROUOPENUM    = [F:ROO]OPENUM
                [M:MFO0]OPESPLNUM    = 0
                [M:MFO1]RPLIND       = [F:ROO]RPLIND
                [M:MFO0]OPESTA       = 1
                [M:MFO1]EXTWST       = [F:ROO]WST
                LWST                 = [F:ROO]WST
                # lecture poste pour centre de charge et type
                Read [MWS]WST0=[F:ROO]WST;[F:ROO]FCY
                If !fstat
                    [M:MFO1]WCR           = [F:MWS]WCR
#                    [M:MFO1]WSTDES        = [F:MWS]WSTDES
                    #LECTURE du libellé traduisible
                    Call LECTEXTRA([M:MFO1]WSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
                    [M:MFO1]WSTTYP        = [F:MWS]WSTTYP
                    [M:MFO1]XWSTTYP       = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
                    [M:MFO1]WSTEFF        = [F:MWS]EFF
                Endif
                #
                [M:MFO0]ROODES       = [F:ROO]ROODES
                [M:MFO0]TIMUOMCOD    = [F:ROH]TIMUOMCOD
                [M:MFO1]OPEUOM       = [F:ROO]OPEUOM
                # sr 08.02 1.4.0 récup éventuelle de la formule
                If [F:ROO]OPESTUFOR <> ""
                   Read [F:TFO]TFO0=2;[F:ROO]OPESTUFOR
                   If !fstat
                       # se repositionner éventuellement sur l'article produit
                       If [F:ITM]ITMREF <> [M:MFG1]ITMREF(0)
                           Read [F:ITM]ITM0 = [M:MFG1]ITMREF(0)
                           If fstat : Raz [F:ITM] : Endif
                       Endif
                       If [F:ITF]ITMREF <> [M:MFG1]ITMREF(0) | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
                           Read [F:ITF]ITF0 = [M:MFG1]ITMREF(0);[M:MFG0]MFGFCY
                           If fstat : Raz [F:ITF] : Endif
                       Endif
                       If evalue([F:TFO]FORFOR) <> 0
                           [M:MFO1]OPESTUCOE =  evalue([F:TFO]FORFOR)
                       Elsif [F:ROO]OPESTUCOE <> 0
                           [M:MFO1]OPESTUCOE = [F:ROO]OPESTUCOE
                       Else
                           [M:MFO1]OPESTUCOE = 1
                       Endif
                   Else
                        [M:MFO1]OPESTUCOE = [F:ROO]OPESTUCOE
                   Endif
                Else
                    [M:MFO1]OPESTUCOE    = [F:ROO]OPESTUCOE
                Endif
                [M:MFO2]SCOCOD       = [F:ROO]SCOCOD
                [M:MFO2]SCOWST       = [F:ROO]SCOWST
                # si sous-traitance, lecture poste correspondant
                If [F:ROO]SCOCOD <> 1
                    Read [MWS]WST0=[F:ROO]SCOWST;[F:ROO]FCY
                    If !fstat
                        [M:MFO2]SCOWCR = [F:MWS]WCR
#                        [M:MFO2]SCOWSTDES = [F:MWS]WSTDES
                        #LECTURE du libellé traduisible
                        Call LECTEXTRA([M:MFO2]SCOWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA

                    Endif
                Endif
                [M:MFO2]SCOITMREF    = [F:ROO]SCOITMREF
                [M:MFO2]BPRNUM       = [F:ROO]BPRNUM            # llc 02.01 5977 + 12.03 MM
                [M:MFO2]BPAADD       = [F:ROO]BPAADD            # 12.03 MM
                [M:MFO2]REFPRI       = [F:ROO]REFPRI            # llc 02.01 5977

                # 83074
                Call COMPLETE_OPEUOM([M:MFG1]ROUNUM,[M:MFO2]SCOITMREF,[M:MFO2]BPRNUM,[M:MFO1]SCOLTI
&                                   ,[M:MFO1]OPEUOM,[M:MFO2]OPESTRCOE,[M:MFO1]SCOPUU)

                [M:MFO1]EXTLAB       = [F:ROO]LABWST
                # lecture poste pour centre de charge m-o
                Read [MWS]WST0=[F:ROO]LABWST;[F:ROO]FCY
                If ! fstat
                    [M:MFO1]LABWCR        = [F:MWS]WCR
#                    [M:MFO1]LABWSTDES     = [F:MWS]WSTDES
                    #LECTURE du libellé traduisible
                    Call LECTEXTRA([M:MFO1]LABWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
                Endif
                #
                [M:MFO1]EXTWSTNBR    = [F:ROO]WSTNBR
                [M:MFO1]EXTLABNBR    = [F:ROO]LABNBR
                [M:MFO1]SETLABCOE    = [F:ROO]SETLABCOE
                [M:MFO1]OPELABCOE    = [F:ROO]OPELABCOE
                # sr 08.02 1.4.0 récup éventuelle de la formule
                If [F:ROO]OPESTUFOR <> ""
                   Read [F:TFO]TFO0=2;[F:ROO]OPESTUFOR
                   If !fstat
                   # se repositionner éventuellement sur l'article produit
                       If [F:ITM]ITMREF <> [M:MFG1]ITMREF(0)
                           Read [F:ITM]ITM0 = [M:MFG1]ITMREF(0)
                           If fstat : Raz [F:ITM] : Endif
                       Endif
                       If [F:ITF]ITMREF <> [M:MFG1]ITMREF(0) | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
                           Read [F:ITF]ITF0 = [M:MFG1]ITMREF(0);[M:MFG0]MFGFCY
                           If fstat : Raz [F:ITF] : Endif
                       Endif
                       If evalue([F:TFO]FORFOR) <> 0
                           [M:MFO1]OPESTUCOE =  evalue([F:TFO]FORFOR)
                       Elsif [F:ROO]OPESTUCOE <> 0
                           [M:MFO1]OPESTUCOE = [F:ROO]OPESTUCOE
                       Else
                           [M:MFO1]OPESTUCOE = 1
                       Endif
                   Else
                        [M:MFO1]OPESTUCOE = [F:ROO]OPESTUCOE
                   Endif
                Else
                    [M:MFO1]OPESTUCOE    = [F:ROO]OPESTUCOE
                Endif
                [M:MFO1]ROOTIMCOD    = [F:ROO]ROOTIMCOD
                [M:MFO1]TIMCOD       = [F:ROO]TIMCOD
                [M:MFO1]BASQTY       = [F:ROO]BASQTY
                [M:MFO1]CAD          = [F:ROO]CAD
                [M:MFO2]OPEPLNNUM    = [F:ROO]OPEPLNNUM
                [M:MFO2]OPEROUPCT    = [F:ROO]OPEROUPCT
                [M:MFO2]TECCRD       = [F:ROO]TECCRD
                [M:MFO2]EQUNUM       = [F:ROO]EQUNUM
                [M:MFO2]FXGNUM       = [F:ROO]FXGNUM
                [M:MFO2]PRGNUM       = [F:ROO]PRGNUM
                [M:MFO1]EFF          = [F:ROO]EFF

                # lecture des données jalonnements llc 02.01 7900
                Read [ROS]ROS0=[F:ROH]FCY;[F:ROH]ITMREF;[F:ROH]ROUALT;[F:ROO]OPENUM
                If !fstat
                    [M:MFG3]NEXOPENUM(L) = [F:ROS]NEXOPENUM
                    [M:MFG3]SCDCOD(L)    = [F:ROS]SCDCOD
                    [M:MFG3]SCDTIM(L)    = [F:ROS]SCDTIM
                    [M:MFG3]SCDQTY(L)    = [F:ROS]SCDQTY
                    [M:MFG3]SCDLOT(L)    = [F:ROS]SCDLOT
                    [M:MFG3]DACMST(L)    = [F:ROS]DACMST
                    [M:MFG3]MFGMST(L)    = [F:ROS]MFGMST
                    If [F:ROS]SCDCOD = 2
                        Read [ITF]ITF0=[F:ROH]ITMREF;[M:MFG0]MFGFCY
                        If !fstat : [M:MFG3]LOTQTY(L) = [F:ITF]MFGLOTQTY : Endif
                    Else
                        [M:MFG3]LOTQTY(L) = 0
                    Endif
                Endif

                Call RESEQ_JAL From MFGSCD  # 69363

                # données capacité finie
                If dim([M:MFO3]OPENUMLEV) > 0 : [M:MFO3]OPENUMLEV = [F:ROO]OPENUMLEV : Endif
                If dim([M:MFO3]ALTOPECOD) > 0 : [M:MFO3]ALTOPECOD = [F:ROO]ALTOPECOD : Endif
                If dim([M:MFO3]SPLCOD)    > 0 : [M:MFO3]SPLCOD    = [F:ROO]SPLCOD    : Endif
                If dim([M:MFO3]SPLMAXNBR) > 0 : [M:MFO3]SPLMAXNBR = [F:ROO]SPLMAXNBR : Endif
                If dim([M:MFO3]RSTMAC)    > 0 : [M:MFO3]RSTMAC    = [F:ROO]RSTMAC    : Endif
                If dim([M:MFO3]SCHGRP)    > 0 : [M:MFO3]SCHGRP    = [F:ROO]SCHGRP    : Endif
                If dim([M:MFO3]SCHSBB)    > 0 : [M:MFO3]SCHSBB    = [F:ROO]SCHSBB    : Endif        # 08.05 distinction des exemplaires
                If dim([M:MFO3]GRPSETTIM) > 0 : [M:MFO3]GRPSETTIM = [F:ROO]GRPSETTIM : Endif

                WMFGEXTQTY    = [M:MFG1]MFGEXTQTY
                Call CAL_OPE_TIME("MFO1", WMFGEXTQTY, L, [M:MFG1]NBLIG, [M:MFG1]LTIREDCOE)

                Goto F_MFO
$OPE_STD1
                If clalev([ROT])=0 : Local File ROUOPESTD [ROT] : Endif
                If clalev([TCO])=0 : Local File TABCOEFF  [TCO] : Endif
                Read [ROT]ROT0=[M:MFO0]STDOPENUM;[M:MFG0]MFGFCY
                If !fstat
                    If [F:ROT]OPEUOM=""
                        [F:ROT]OPEUOM = [M:MFG1]MFGSTU
                        VOPESTUCOE    = 1
                    Else
                        Read [TCO]TCO0=[M:MFG1]MFGSTU;[F:ROT]OPEUOM
                        If !fstat
                            VOPESTUCOE=[F:TCO]COEUOM
                        Else
                            VOPESTUCOE=1
                        Endif
                    Endif
                    Gosub CONVERSION From SUBMFG3
                    [M:MFO0]            = [F:ROT]
                    [M:MFO1]            = [F:ROT]
                    [M:MFO2]            = [F:ROT]
                    If dim([M:MFG3]OPENUMLEV(I)) > 0 : [M:MFO3] = [F:ROT] : Endif
                    [M:MFO1]TIMUOMCOD   = [M:MFO1]XTIMUOMCOD
                    [M:MFO1]ROUOPENUM   = 0
                    # FGR 21/09/2009 : X3SUIVI57981
                    #[M:MFO0]ROODES      = [F:ROT]STDOPEDES
                    # FGR 01/10/2009 : X3SUIVI58277 : il y avait GLANGUE comme paramètre en trop
                    Call LECTEXTRA([M:MFO0]ROODES,"ROUOPESTD","STDOPEDESAXX",num$([F:ROT]STDOPENUM),[F:ROT]FCY) From ATEXTRA
                    [M:MFO1]EXTWST      = [F:ROT]WST
                    # lecture poste pour centre de charge et type
                    Read [MWS]WST0=[F:ROT]WST;[F:ROT]FCY
                    If ! fstat
                        [M:MFO1]WCR             = [F:MWS]WCR
#                        [M:MFO1]WSTDES          = [F:MWS]WSTDES
                        #LECTURE du libellé traduisible
                        Call LECTEXTRA([M:MFO1]WSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
                        [M:MFO1]WSTTYP          = [F:MWS]WSTTYP
                        [M:MFO1]XWSTTYP         = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
                        [M:MFO1]WSTEFF          = [F:MWS]EFF
                    Endif
                    # lecture poste pour centre de charge et type
                    If [F:ROT]LABWST <> ""
                        Read [MWS]WST0=[F:ROT]LABWST;[F:ROT]FCY
                        If !fstat
                            [M:MFO1]LABWCR          = [F:MWS]WCR
#                            [M:MFO1]LABWSTDES       = [F:MWS]WSTDES
                            #LECTURE du libellé traduisible
                            Call LECTEXTRA([M:MFO1]LABWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
                            [M:MFO1]LABWSTTYP       = [F:MWS]WSTTYP
                            [M:MFO1]XLABWSTTYP      = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
                        Endif
                    Endif
                    [M:MFO1]EXTLAB      = [F:ROT]LABWST
                    [M:MFO1]EXTSETTIM   = [F:ROT]SETTIM
                    [M:MFO1]EXTOPETIM   = [F:ROT]OPETIM
                    [M:MFO1]EXTWSTNBR   = [F:ROT]WSTNBR
                    [M:MFO1]EXTLABNBR   = [F:ROT]LABNBR
                    # si sous-traitance, lecture poste correspondant
                    If [F:ROT]SCOCOD <> 1
                        Read [MWS]WST0=[F:ROT]SCOWST;[F:ROT]FCY
                        If !fstat
                            [M:MFO2]SCOWCR          = [F:MWS]WCR
#                            [M:MFO2]SCOWSTDES       = [F:MWS]WSTDES
                            #LECTURE du libellé traduisible
                            Call LECTEXTRA([M:MFO2]SCOWSTDES,"WORKSTATIO","WSTDESAXX",[F:MWS]WST,[F:MWS]WCRFCY) From ATEXTRA
                            [M:MFO2]SCOWSTTYP       = [F:MWS]WSTTYP
                            [M:MFO2]XSCOWSTTYP      = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
                        Endif
                    Endif
                    [M:MFO2]SCOITMREF = [F:ROT]SCOITMREF
                    [M:MFO1]OPESTUCOE   = VOPESTUCOE

                    # 83074
                    Call COMPLETE_OPEUOM([M:MFG1]ROUNUM,[M:MFO2]SCOITMREF,[M:MFO2]BPRNUM,[M:MFO1]SCOLTI
&                                       ,[M:MFO1]OPEUOM,[M:MFO2]OPESTRCOE,[M:MFO1]SCOPUU)

                    [M:MFO1]OPESTUCOE   = VOPESTUCOE
                    WMFGEXTQTY    = [M:MFG1]MFGEXTQTY
                    Call CAL_ROT_TIME("MFO1", WMFGEXTQTY, L, [M:MFG1]NBLIG, [M:MFG1]LTIREDCOE,1) From MFGLIBO   # 17809 MM 07.05
                Endif
$F_MFO
    When "MFG": # lecture de l'entête de gamme (déjà contrôlée)
                If [F:ROH]ITMREF <> [M:MFG1]ROUNUM
                    Read [ROH]ROH0=[M:MFG1]ROUNUM;[M:MFG1]ROUALT;[M:MFG0]MFGFCY : # Beryl Site en fin de clé primaire
                    If fstat : End : Endif
                Endif


                # recherche de l'opération d'origine
                VOPE=0
                # FQ 77863 GA 11/2011 vérifier aussi VALSTRDAT # 10.02 Performances
                For [ROO]ROO0 Where FCY = [F:ROH]FCY & ITMREF = [F:ROH]ITMREF & ROUALT = [F:ROH]ROUALT
&                            &   OPENUM = [M:MFG3]ROUOPENUM(L)
&                            & (VALENDDAT=[0/0/0] | (VALENDDAT >= [M:MFG1]STRDAT & VALENDDAT<>[0/0/0]) )
&                            & (VALSTRDAT=[0/0/0] | (VALSTRDAT <= [M:MFG1]STRDAT & VALSTRDAT<>[0/0/0]) )
                        If [F:ROO]OPENUM<>VOPE
                        VOPE=[F:ROO]OPENUM
                        Break
                    Endif
                Next
                If VOPE = 0 : End : Endif
                # alimentation de l'opération

                #    llc 03.01 8593
                nolign = L + 1
                [M:MFG3]             = [F:ROO]

                [M:MFG3]OPENUM(L)    = [F:ROO]OPENUM
                [M:MFG3]STDOPENUM(L) = [F:ROO]STDOPENUM
                [M:MFG3]ROUOPENUM(L) = [F:ROO]OPENUM
                [M:MFG3]OPESPLNUM(L) = 0
                [M:MFG3]RPLIND(L)    = [F:ROO]RPLIND
                [M:MFG3]OPESTA(L)    = 1
                [M:MFG3]EXTWST(L)    = [F:ROO]WST
                LWST                 = [F:ROO]WST
                # lecture poste pour centre de charge et type
                Read [MWS]WST0=[F:ROO]WST;[F:ROO]FCY
                If !fstat
                    [M:MFG3]WCR(L)        = [F:MWS]WCR
                    [M:MFG3]EXTWSTSHO(L)  = [F:MWS]WSTSHO
                    [M:MFG3]WSTTYP(L)     = [F:MWS]WSTTYP
                    [M:MFG3]XWSTTYP(L)    = format$("K:2X",mess([F:MWS]WSTTYP,313,1))
                    [M:MFG3]WSTEFF(L)     = [F:MWS]EFF
                Endif
                #
                [M:MFG3]ROODES(L)    = [F:ROO]ROODES
                [M:MFG3]TIMUOMCOD(L) = [F:ROH]TIMUOMCOD
                [M:MFG3]OPEUOM(L)    = [F:ROO]OPEUOM
                # sr 08.02 1.4.0 récup éventuelle de la formule
                If [F:ROO]OPESTUFOR <> ""
                   Read [F:TFO]TFO0=2;[F:ROO]OPESTUFOR
                   If !fstat
                       # se repositionner éventuellement sur l'article produit
                       If [F:ITM]ITMREF <> [M:MFG1]ITMREF(0)
                           Read [F:ITM]ITM0 = [M:MFG1]ITMREF(0)
                           If fstat : Raz [F:ITM] : Endif
                       Endif
                       If [F:ITF]ITMREF <> [M:MFG1]ITMREF(0) | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
                           Read [F:ITF]ITF0 = [M:MFG1]ITMREF(0);[M:MFG0]MFGFCY
                           If fstat : Raz [F:ITF] : Endif
                       Endif
                       If evalue([F:TFO]FORFOR) <> 0
                           [M:MFG3]OPESTUCOE(L) =  evalue([F:TFO]FORFOR)
                       Elsif [F:ROO]OPESTUCOE <> 0
                           [M:MFG3]OPESTUCOE(L) = [F:ROO]OPESTUCOE
                       Else
                           [M:MFG3]OPESTUCOE(L) = 1
                       Endif
                   Else
                        [M:MFG3]OPESTUCOE(L) = [F:ROO]OPESTUCOE
                   Endif
                Else
                   [M:MFG3]OPESTUCOE(L) = [F:ROO]OPESTUCOE
                Endif
                [M:MFG3]SCOCOD(L)    = [F:ROO]SCOCOD
                [M:MFG3]SCOWST(L)    = [F:ROO]SCOWST
                # si sous-traitance, lecture poste correspondant
                If [F:ROO]SCOCOD <> 1
                    Read [MWS]WST0=[F:ROO]SCOWST;[F:ROO]FCY
                    If !fstat : [M:MFG3]SCOWCR(L) = [F:MWS]WCR : Endif
                Endif
                [M:MFG3]SCOITMREF(L) = [F:ROO]SCOITMREF
                [M:MFG3]BPRNUM(L) = [F:ROO]BPRNUM                # llc 02.01  5977 + 12.03 MM
                [M:MFG3]BPAADD(L) = [F:ROO]BPAADD                # 12.03 MM
                [M:MFG3]REFPRI(L) = [F:ROO]REFPRI                # llc 02.01  5977

                # FQ 74274 GA 10/2011
                Call COMPLETE_OPEUOM([M:MFG1]ROUNUM,[M:MFG3]SCOITMREF(L),[M:MFG3]BPRNUM(L),[M:MFG3]SCOLTI(L)
&                                   ,[M:MFG3]OPEUOM(L),[M:MFG3]OPESTRCOE(L),[M:MFG3]SCOPUU(L))

                [M:MFG3]EXTLAB(L)    = [F:ROO]LABWST
                # lecture poste pour centre de charge m-o
                Read [MWS]WST0=[F:ROO]LABWST;[F:ROO]FCY
                If ! fstat
                    [M:MFG3]LABWCR(L)     = [F:MWS]WCR
                    [M:MFG3]EXTLABSHO(L)  = [F:MWS]WSTSHO
                Endif
                #
                [M:MFG3]EXTWSTNBR(L) = [F:ROO]WSTNBR
                [M:MFG3]EXTLABNBR(L) = [F:ROO]LABNBR
                [M:MFG3]SETLABCOE(L) = [F:ROO]SETLABCOE
                [M:MFG3]OPELABCOE(L) = [F:ROO]OPELABCOE
                # sr 08.02 1.4.0 récup éventuelle de la formule
                If [F:ROO]OPESTUFOR <> ""
                   Read [F:TFO]TFO0=2;[F:ROO]OPESTUFOR
                   If !fstat
                      # se repositionner éventuellement sur l'article produit
                       If [F:ITM]ITMREF <> [M:MFG1]ITMREF(0)
                           Read [F:ITM]ITM0 = [M:MFG1]ITMREF(0)
                           If fstat : Raz [F:ITM] : Endif
                       Endif
                       If [F:ITF]ITMREF <> [M:MFG1]ITMREF(0) | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
                           Read [F:ITF]ITF0 = [M:MFG1]ITMREF(0);[M:MFG0]MFGFCY
                           If fstat : Raz [F:ITF] : Endif
                       Endif
                       If evalue([F:TFO]FORFOR) <> 0
                           [M:MFG3]OPESTUCOE(L) =  evalue([F:TFO]FORFOR)
                       Elsif [F:ROO]OPESTUCOE <> 0
                           [M:MFG3]OPESTUCOE(L) = [F:ROO]OPESTUCOE
                       Else
                           [M:MFG3]OPESTUCOE(L) = 1
                       Endif
                   Else
                        [M:MFG3]OPESTUCOE(L) = [F:ROO]OPESTUCOE
                   Endif
                Else
                   [M:MFG3]OPESTUCOE(L) = [F:ROO]OPESTUCOE
                Endif
                [M:MFG3]ROOTIMCOD(L) = [F:ROO]ROOTIMCOD
                [M:MFG3]TIMCOD(L)    = [F:ROO]TIMCOD
                [M:MFG3]BASQTY(L)    = [F:ROO]BASQTY
                [M:MFG3]CAD(L)       = [F:ROO]CAD
                [M:MFG3]OPEPLNNUM(L) = [F:ROO]OPEPLNNUM
                [M:MFG3]OPEROUPCT(L) = [F:ROO]OPEROUPCT
                [M:MFG3]TECCRD(L)    = [F:ROO]TECCRD
                [M:MFG3]EQUNUM(L)    = [F:ROO]EQUNUM
                [M:MFG3]FXGNUM(L)    = [F:ROO]FXGNUM
                [M:MFG3]PRGNUM(L)    = [F:ROO]PRGNUM
                [M:MFG3]EFF(L)       = [F:ROO]EFF

                # lecture des données jalonnements llc 02.01 7900
                Read [ROS]ROS0=[F:ROH]FCY;[F:ROH]ITMREF;[F:ROH]ROUALT;[F:ROO]OPENUM
                If !fstat
                    [M:MFG3]NEXOPENUM(L) = [F:ROS]NEXOPENUM
                    [M:MFG3]SCDCOD(L)    = [F:ROS]SCDCOD
                    [M:MFG3]SCDTIM(L)    = [F:ROS]SCDTIM
                    [M:MFG3]SCDQTY(L)    = [F:ROS]SCDQTY
                    [M:MFG3]SCDLOT(L)    = [F:ROS]SCDLOT
                    [M:MFG3]DACMST(L)    = [F:ROS]DACMST
                    [M:MFG3]MFGMST(L)    = [F:ROS]MFGMST
                    If [F:ROS]SCDCOD = 2
                        Read [ITF]ITF0=[F:ROH]ITMREF;[M:MFG0]MFGFCY
                        If !fstat : [M:MFG3]LOTQTY(L) = [F:ITF]MFGLOTQTY : Endif
                    Else
                        [M:MFG3]LOTQTY(L) = 0
                    Endif
                Endif

                Call RESEQ_JAL From MFGSCD  # 69363

                # données capacité finie
                If dim([M:MFG3]OPENUMLEV(I)) > 0 : [M:MFG3]OPENUMLEV(L) = [F:ROO]OPENUMLEV : Endif
                If dim([M:MFG3]ALTOPECOD(I)) > 0 : [M:MFG3]ALTOPECOD(L) = [F:ROO]ALTOPECOD : Endif
                If dim([M:MFG3]SPLCOD(I))    > 0 : [M:MFG3]SPLCOD(L)    = [F:ROO]SPLCOD    : Endif
                If dim([M:MFG3]SPLMAXNBR(I)) > 0 : [M:MFG3]SPLMAXNBR(L) = [F:ROO]SPLMAXNBR : Endif
                If dim([M:MFG3]RSTMAC(I))    > 0 : [M:MFG3]RSTMAC(L)    = [F:ROO]RSTMAC    : Endif
                If dim([M:MFG3]SCHGRP(I))    > 0 : [M:MFG3]SCHGRP(L)    = [F:ROO]SCHGRP    : Endif
                If dim([M:MFG3]SCHSBB(I))    > 0 : [M:MFG3]SCHSBB(L)    = [F:ROO]SCHSBB    : Endif      # 08.05 distinction des exemplaires
                If dim([M:MFG3]GRPSETTIM(I)) > 0 : [M:MFG3]GRPSETTIM(L) = [F:ROO]GRPSETTIM : Endif

                # calcul des temps
                WMFGEXTQTY    = [M:MFG1]MFGEXTQTY
                Call CAL_OPE_TIME("MFG3", WMFGEXTQTY, L, [M:MFG1]NBLIG, [M:MFG1]LTIREDCOE)
                #
                Affzo [M:MFG3]10
Endcase
#
End

#########################################################################
# Analyse et mise à jour de l'emplacement matière par défaut            #
#########################################################################
Subprog ANALYSE_OPELOC(LOPENUM, LLIG, LWST,LFCY)
Value Integer LOPENUM
Value Integer LLIG
Value Char    LWST
Value Char    LFCY
Local Integer I
#
If [M:MFG2]NBLIG <> 0
    If find(LOPENUM,[M:MFG2]BOMOPE(0..[M:MFG2]NBLIG-1))
        For I=0 To [M:MFG2]NBLIG-1
            If [M:MFG2]BOMOPE(I) = LOPENUM
                Read [MWS]WST0=LWST;LFCY
                If !fstat
                    If [F:MWS]STOLOC <> "" : [M:MFG2]LOC(I) = [F:MWS]STOLOC : Endif
                Endif
            Endif
           # sr 06.04 demande 22886
           GPOINT = "CUSUPDLOC" : Gosub ENTREE From EXEFNC
        Next I
    Endif
Endif
#
End

#########################################################################
# Analyse et mise à jour de l'emplacement matière par défaut            #
#########################################################################
# modification: llc 07.01 9728 (sous-traitance)
Subprog ANALYSE_OPESTR(ABMSK,LOPENUM, LLIG, LWST,LFCY)
Value Char ABMSK
Value Integer LOPENUM
Value Integer LLIG
Value Char    LWST
Value Char    LFCY
Local Integer I
Local Char    WBPRNUM(GLONBPR)
Local Char    WBPAADD(GLONBPD)
Local Integer TROUVE
#

If [M:MFG2]NBLIG <> 0
    # llc 07.01 9728 (sous-traitance)+12.03 MM : Multi-emplacement,la notion de tiers remplace celle de fournisseur.
    Case ABMSK
        When "MFG3": WBPRNUM = [M:MFG3]BPRNUM(LLIG)
                     WBPAADD = [M:MFG3]BPAADD(LLIG)
        When "MFO":  WBPRNUM = [M:MFO2]BPRNUM
                     WBPAADD = [M:MFO2]BPAADD
    Endcase

    Read [MWS]WST0=LWST;LFCY
    If fstat : End : Endif
    If find(LOPENUM,[M:MFG2]BOMOPE(0..[M:MFG2]NBLIG-1))
        For I=0 To [M:MFG2]NBLIG-1
            If [M:MFG2]BOMOPE(I) = LOPENUM
                If [F:MWS]WSTTYP = 3
                    [M:MFG2]SCOFLG(I) = 2
                    Affzo [M:MFG2]SCOFLG(I)            # 10038
                    TROUVE=0
                    # stock conso
                    # 12.03 MM : multi-emplacement
                    # Recherche de l'emplacement du client livré
                    If WBPRNUM <> "" & WBPAADD <> ""
                        If clalev([F:BPD])   = 0 : Local File BPDLVCUST   [BPD]   : Endif
                        Read [BPD]BPD0=WBPRNUM;WBPAADD
                        If fstat : End : Endif
                        If [F:BPD]SCOLOC <>""
                            [M:MFG2]LOC(I) = [F:BPD]SCOLOC
                            TROUVE =1
                        Endif
                    Endif
                    # Recherche de l'emplacement du fournisseur
                    If TROUVE =0
                        If WBPRNUM <> ""
                            If clalev([F:BPS])   = 0 : Local File BPSUPPLIER    [BPS]   : Endif
                            Read [BPS]BPS0=WBPRNUM
                            If !fstat
                                If [F:BPS]LOC <> ""
                                    [M:MFG2]LOC(I) = [F:BPS]LOC
                                Endif
                            Endif
                        Endif
                    Endif
                Else
                    [M:MFG2]SCOFLG(I) = 1
                Endif
           Endif
        Next I
    Endif
Endif
#
End

#########################################################
# test état jalonnement
Subprog TST_JAL(LRET)
Variable Integer LRET
Local    Integer OK
Local Char WMESS(80)                # llc 10.02

#
If GASW : LRET = 2 : End : Endif
If [M:MFG0]MFGNUM = "" : LRET = 2 : End : Endif
LRET = 0
If  [M:MFG1]MFGTRKFLG > 3
    OK=1
    Call OUINON(mess(66,190,1),OK) From GESECRAN
    LRET = OK
    GASW = 1
    End
Endif
If  [M:MFG1]MFGTRKFLG > 2
    OK=1
    Call OUINON(mess(65,190,1),OK) From GESECRAN
    LRET = OK
    GASW = 1
    End
Endif
If [M:MFG3]NBLIG <> 0 & find([M:MFG3]SCDFLG,2,4)
    OK=1
    # llc 10.02
    Case [M:MFG3]SCDFLG
        When 2:    WMESS = mess(39,190,1)
        When 4:    WMESS = mess(176,190,1)
    Endcase
    Call OUINON(WMESS,OK) From GESECRAN
    LRET = OK
    GASW = 1
Endif

#
End

#########################################################
# modif état jalonnement
Subprog MOD_JAL
# Issue 96561 GA 02/2014 optimized WO
#If [M:MFG3]SCDFLG = 2 : [M:MFG3]SCDFLG = 3 : Endif            # 05.05 30281
If find([M:MFG3]SCDFLG,2,4) : [M:MFG3]SCDFLG = 3 : Endif
If find([M:MFG1]SCDFLG,2,4) : [M:MFG1]SCDFLG = 3 : Endif
If dim([M:MFG1]XSCDFLG)>0   : [M:MFG1]XSCDFLG = mess([M:MFG1]SCDFLG,335,1) : Affzo [M:MFG1]XSCDFLG : Endif
Affzo [M:MFG3]5
End

#########################################################################
# Recherche article origine                                             #
#########################################################################
Subprog RECH_ORI(LCOD, LITM, LRET)
Value    Char    LCOD
Variable Char    LITM
Variable Integer LRET
#

LRET = 0
If GFONC1 = "GESMFG" : LCOD = "C" : Endif
Case LCOD
    When "C":
              If [M:MFG1]NBLIG = 1
                  LITM = [M:MFG1]ITMREF(0)
              Else
                  LITM = [M:MFG1]ROUNUM
              Endif
    When "M", "SM":                                        # 10.05 32356
             Read [ORD]ORD0=4;[F:MFO]WIPNUM;[F:MFO]SCOITMREF
             If fstat : LITM = "" : End : Endif
             #
             # Issue 102085 GA 12/2014
             If [F:ORD]ITMREFORI=""
               Read [F:MFG]MFG0=[F:OPS]MFGNUM : If fstat Raz [F:MFG] Endif
               If [F:MFG]ITMLINNBR=1
                  Read [F:MFI]MFI0(1)=[F:OPS]MFGNUM : If fstat Raz [F:MFI] Endif
                  LITM = [F:MFI]ITMREF
               Else
                  LITM = [F:MFG]ROUNUM
               Endif
             Else
               LITM = [F:ORD]ITMREFORI
             Endif
    When "SC": # 04.08 mm 46843
             # Cmde classique ou inter-société, cmde inter-site non autorisée sur article de SST
             # FQ 69046 GA 11/2010 avant VCRNUMORI=[F:MFO]MFGNUM & ITMREF=[F:MFO]SCOITMREF
             #                     or on arrive ici lorsque [F:MFO] n'a pas été trouvée ...
             Filter [ORD] Where VCRTYP=2 & VCRNUM=[F:OPS]POHNUM
&                             & VCRTYPORI=10 & VCRNUMORI=[F:OPS]MFGNUM
&                             & ITMREF=[F:OPS]SCOITMREF
             # FQ 69046 GA 11/2010 manque la table et le Raz du filter si on sort en erreur
             #Read First
             #If fstat : LITM = "" : End : Endif
             Read  [F:ORD] First
             If fstat Raz [F:ORD] Endif
             # Issue 102085 GA 12/2014
             If [F:ORD]ITMREFORI=""
               Read [F:MFG]MFG0=[F:OPS]MFGNUM : If fstat Raz [F:MFG] Endif
               If [F:MFG]ITMLINNBR=1
                  Read [F:MFI]MFI0(1)=[F:OPS]MFGNUM : If fstat Raz [F:MFI] Endif
                  LITM = [F:MFI]ITMREF
               Else
                  LITM = [F:MFG]ROUNUM
               Endif
             Else
               LITM = [F:ORD]ITMREFORI
             Endif
             Filter [ORD]
    When "BC":
             LITM = GRELITM
Endcase
#
End

#########################################################################
# Contrôle des dates forcées d'un OF / traitement auto                  #
#########################################################################
Subprog CONT_FRC_AUTO(LMFGNUM, LOPE, LOPESPLNUM, LDAT)
Value     Char    LMFGNUM
Value     Integer LOPE
Value     Integer LOPESPLNUM
Value     Date    LDAT
Local     Char    WMFGNUM(GLONVCR)
Local     Integer WOPE
Local     Integer WOPESPLNUM
Local     Integer WSCDCOD, WNEX
Local     Date    TODAY : TODAY = date$
Local     Integer FLG

Local File SCHEDULING  [SCH]
Local File MFGOPE      [MFO]

# date dans le passé
If LDAT < TODAY : Goto MSG1 : Endif

# FQ 77397 GA 02/2012 (suite)
If find([F:MFO]OPESTA,5,6,7) : Goto MSG3 : Endif

WMFGNUM     = LMFGNUM
WOPE        = LOPE
WOPESPLNUM  = LOPESPLNUM
# contrôle aval
$CONT1
# contrôle cohérence avec opération suivante
Read [SCH]SCH0=WMFGNUM;WOPE;WOPESPLNUM
If fstat : Goto CONT2 : Endif

If [F:SCH]NEXOPENUM = 0 : Goto CONT2 : Endif
WSCDCOD = [F:SCH]SCDCOD
WNEX    = [F:SCH]NEXOPENUM

# 10.02 Performances
For [SCH]SCH0 Where MFGNUM=WMFGNUM & OPENUM=WNEX
    Read [MFO]MFO0=WMFGNUM;[F:SCH]OPENUM;[F:SCH]OPESPLNUM
    If fstat : Goto NXT1 : Endif
    WOPESPLNUM = [F:SCH]OPESPLNUM
    If [F:MFO]FRCSTRDAT <> [0/0/0]
        Case WSCDCOD
            When 1,2,3,4:  If LDAT >  [F:MFO]FRCSTRDAT : Goto MSG2 : Endif
            When 5:        If LDAT <> [F:MFO]FRCSTRDAT : Goto MSG2 : Endif
            When Default:  # ben rien
        Endcase
    Endif
$NXT1
Next
WOPE = WNEX
Goto CONT1

# contrôle amont
$CONT2
WMFGNUM     = LMFGNUM
WOPE        = LOPE
WOPESPLNUM  = LOPESPLNUM
$LOOP2
FLG = 0
# 10.02 Performances
For [SCH]SCH0 Where MFGNUM=WMFGNUM & NEXOPENUM=WOPE
    Read [MFO]MFO0=WMFGNUM;[F:SCH]OPENUM;[F:SCH]OPESPLNUM
    If fstat : Goto NXT2 : Endif
    WOPE       = [F:SCH]OPENUM
    WOPESPLNUM = [F:SCH]OPESPLNUM
    If WSCDCOD <> 6 : WSCDCOD    = [F:SCH]SCDCOD : Endif
    If [F:MFO]FRCSTRDAT <> [0/0/0]
        Case WSCDCOD
            When 1,2,3,4:  If LDAT <  [F:MFO]FRCSTRDAT : Goto MSG2 : Endif
            When 5:        If LDAT <> [F:MFO]FRCSTRDAT : Goto MSG2 : Endif
            When Default:  # ben rien
        Endcase
    Endif
    FLG = 1
    Break
$NXT2
Next
Case FLG
    When 0: Goto FIN_CONT
    When 1: Goto LOOP2
Endcase
# date antérieure à la date du jour
$MSG1
GMESSAGE = mess(60,193,1)
Goto FIN_CONT

# incohérence dates forcées / codes jalonnement
$MSG2
GMESSAGE = mess(112,193,1)
Goto FIN_CONTM

# FQ 77397 GA 11/2011: Opération commandée, exclue ou soldée : forçage des dates impossible
$MSG3
GMESSAGE = mess(292,193,1)

$FIN_CONT
End

#########################################################################
# Contrôle des dates forcées d'un OF / traitement manuel                #
#########################################################################
Subprog CONT_FRC_MAN(LLIG, LDAT)
Value     Integer LLIG
Value     Date    LDAT
Local     Integer WSCDCOD, WNEX, I, WOPE
Local     Date    TODAY : TODAY = date$
Local     Integer WLIG

# date dans le passé
If LDAT < TODAY : Goto MSGM1 : Endif

WLIG = LLIG

# FQ 77397 GA 11/2011
If find([M:MFG3]OPESTA(WLIG),5,6,7) : Goto MSGM3 : Endif

# contrôle aval
$CONTM1
# contrôle cohérence avec opération suivante
If [M:MFG3]NEXOPENUM(WLIG) = 0 : Goto CONTM2 : Endif
WNEX    = [M:MFG3]NEXOPENUM(WLIG)
WSCDCOD = [M:MFG3]SCDCOD(WLIG)

For I=WLIG+1 To [M:MFG3]NBLIG-1
    If [M:MFG3]OPENUM(I) <> WNEX : Break : Endif
    WNEX    = [M:MFG3]NEXOPENUM(I)
    WSCDCOD = [M:MFG3]SCDCOD(I-1)
    If [M:MFG3]FRCSTRDAT(I) <> [0/0/0]
        Case WSCDCOD
            When 1,2,3,4:  If LDAT >  [M:MFG3]FRCSTRDAT(I) : Goto MSGM2 : Endif
            When 5:        If LDAT <> [M:MFG3]FRCSTRDAT(I) : Goto MSGM2 : Endif
            When Default:  # ben rien
        Endcase
    Endif
$NXTM1
Next
If I >= [M:MFG3]NBLIG-1 : Goto CONTM2 : Endif
WLIG = I
Goto CONTM1

# contrôle amont
$CONTM2
WLIG    = LLIG
WOPE    = [M:MFG3]OPENUM(WLIG)
$LOOPM2
For I=WLIG-1 To 0 Step -1
    If WSCDCOD <> 6 : WSCDCOD = [M:MFG3]SCDCOD(I) : Endif
    If [M:MFG3]NEXOPENUM(I) <> WOPE : Break : Endif
    WOPE  = [M:MFG3]OPENUM(I)
    If [M:MFG3]FRCSTRDAT(I) <> [0/0/0]
        Case WSCDCOD
            When 1,2,3,4:  If LDAT <  [M:MFG3]FRCSTRDAT(I) : Goto MSGM2 : Endif
            When 5:        If LDAT <> [M:MFG3]FRCSTRDAT(I) : Goto MSGM2 : Endif
            When Default:  # ben rien
        Endcase
    Endif
$NXTM2
Next
If I <= 0 : Goto FIN_CONTM : Endif
WLIG -= 1
WOPE  = [M:MFG3]OPENUM(I)
Goto LOOPM2

# date antérieure à la date du jour
$MSGM1
GMESSAGE = mess(60,193,1)
Goto FIN_CONTM

# incohérence dates forcées / codes jalonnement
$MSGM2
GMESSAGE = mess(112,193,1)
Goto FIN_CONTM

# FQ 77397 GA 11/2011: Opération commandée, exclue ou soldée : forçage des dates impossible
$MSGM3
GMESSAGE = mess(292,193,1)

$FIN_CONTM
End

#########################################################################
# Contrôle des heures forcées d'un OF / traitement manuel               #
#########################################################################
Subprog CONT_FRCH_MAN(LLIG, LDAT, LHOU)
Value     Integer LLIG
Value     Date    LDAT  # FGR 14/01/2010 : X3SUIVI60986 LDATE
Value     Char    LHOU
Local     Integer WSCDCOD, WNEX, I, WOPE
Local     Date    TODAY : TODAY = date$
Local     Integer WLIG
Local     Decimal WFRAC1, WFRAC2

Call CONVHOU(LHOU(I), WFRAC1) From JALLIBB

If WFRAC1 = 0 : End : Endif

WLIG = LLIG
# contrôle aval
$CONTH1
# contrôle cohérence avec opération suivante
If [M:MFG3]NEXOPENUM(WLIG) = 0 : Goto CONTH2 : Endif
WNEX    = [M:MFG3]NEXOPENUM(WLIG)
WSCDCOD = [M:MFG3]SCDCOD(WLIG)

For I=WLIG+1 To [M:MFG3]NBLIG-1
    If [M:MFG3]OPENUM(I) <> WNEX : Break : Endif
    WNEX    = [M:MFG3]NEXOPENUM(I)
    WSCDCOD = [M:MFG3]SCDCOD(I-1)
    Call CONVHOU([M:MFG3]FRCSTRHOU(I), WFRAC2) From JALLIBB
    If [M:MFG3]FRCSTRDAT(I) <> [0/0/0] & WFRAC2 <> 0
        Case WSCDCOD
            When 1,2,3,4:  If [M:MFG3]FRCSTRDAT(I) = LDAT &
&                             WFRAC1 >  WFRAC2
                               Goto MSGH2
                           Endif
            When 5:        If [M:MFG3]FRCSTRDAT(I) = LDAT &
&                             WFRAC1 <>  WFRAC2
                               Goto MSGH2
                           Endif
            When Default:  # ben rien
        Endcase
    Endif
$NXTH1
Next
If I >= [M:MFG3]NBLIG-1 : Goto CONTH2 : Endif
WLIG = I
Goto CONTH1

# contrôle amont
$CONTH2
WLIG    = LLIG
WOPE    = [M:MFG3]OPENUM(WLIG)
$LOOPH2
For I=WLIG-1 To 0 Step -1
    If WSCDCOD <> 6 : WSCDCOD = [M:MFG3]SCDCOD(I) : Endif
    If [M:MFG3]NEXOPENUM(I) <> WOPE : Break : Endif
    WOPE  = [M:MFG3]OPENUM(I)
    Call CONVHOU([M:MFG3]FRCSTRHOU(I), WFRAC2) From JALLIBB
    If [M:MFG3]FRCSTRDAT(I) <> [0/0/0] & WFRAC2 <> 0
        Case WSCDCOD
            When 1,2,3,4:  If [M:MFG3]FRCSTRDAT(I) = LDAT &
&                             WFRAC1 <  WFRAC2
                               Goto MSGH2
                           Endif
            When 5:        If [M:MFG3]FRCSTRDAT(I) = LDAT &
&                             WFRAC1 >  WFRAC2
                               Goto MSGH2
                           Endif
            When Default:  # ben rien
        Endcase
    Endif
$NXTH2
Next
If I <= 0 : Goto FIN_CONTH : Endif
WLIG -= 1
WOPE  = [M:MFG3]OPENUM(I)
Goto LOOPH2

# date antérieure à la date du jour
$MSGH1
GMESSAGE = mess(60,193,1)
Goto FIN_CONTH
# incohérence dates forcées / codes jalonnement
$MSGH2
GMESSAGE = mess(112,193,1)

$FIN_CONTH
End

#########################################################################
# récupération des temps hors charge de la gamme
Subprog UPD_OPE_HC(LLIG)
Value Integer LLIG
Local Integer VOPE

# FQ 77863 GA 11/2011 vérifier aussi VALSTRDAT
For [ROO]ROO0 Where FCY    = [M:MFG0]MFGFCY &
&                   ITMREF = [M:MFG1]ROUNUM & ROUALT = [M:MFG1]ROUALT &
&                   OPENUM = [M:MFG3]OPENUM(LLIG)
&                & (VALENDDAT=[0/0/0] | (VALENDDAT >= [M:MFG1]STRDAT & VALENDDAT<>[0/0/0]) )
&                & (VALSTRDAT=[0/0/0] | (VALSTRDAT <= [M:MFG1]STRDAT & VALSTRDAT<>[0/0/0]) )
    If [F:ROO]OPENUM <> VOPE
        VOPE = [F:ROO]OPENUM
        Break
    Endif
Next

If VOPE = 0 : End : Endif
[M:MFG3]WAITIM(LLIG) = [F:ROO]WAITIM
[M:MFG3]PSPTIM(LLIG) = [F:ROO]PSPTIM
[M:MFG3]PRPTIM(LLIG) = [F:ROO]PRPTIM
If  [M:MFG3]WAITIM(LLIG) > [M:MFG3]PSPTIM(LLIG)
    [M:MFG3]FXDTIM(LLIG) = [M:MFG3]PRPTIM(LLIG) + [M:MFG3]WAITIM(LLIG)
Else
    [M:MFG3]FXDTIM(LLIG) = [M:MFG3]PRPTIM(LLIG) + [M:MFG3]PSPTIM(LLIG)
Endif

End

############################################################################################
# GA 05/2008 pour la V6 selon SUBMFG3 - appelé par SBCLIB - [F:MFO] est chargée
############################################################################################
Subprog UPDMFO_CPTANALIN(LRET)
Variable  Integer  LRET
If dim(WI)<1 : Local Integer WI : Endif
If dim(WEXISTE)<1 : Local Integer WEXISTE : Endif
If dim(WLABWST)<1 : Local Integer WLABWST : Endif
If dim(WOPESPLNUM)<1 : Local Integer WOPESPLNUM : Endif

# Issue 38555 GH 18/10/2017 - For a new record [MFO] with OPESPLNUM=0, it considers existing [MFO] records
#                             with OPESPLNUM>0 (in priority, the one with OPESPLNUM=LRET) to duplicate analytical dimensions
#LRET = 0
#Read [CAL] CAL0="MFO";0;[F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM;"EXTWST";1
#If !fstat
#   WEXISTE=0 : WOPESPLNUM = [F:MFO]OPESPLNUM
#Else
#   Read [CAL] CAL0="MFO";0;[F:MFO]MFGNUM;[F:MFO]OPENUM;0;"EXTWST";1
#   If !fstat
#      WEXISTE=0  : WOPESPLNUM = 0
#   Else
#      WEXISTE=1
#   Endif
#Endif
Read [CAL]CAL0="MFO";0;[F:MFO]MFGNUM;[F:MFO]OPENUM;[F:MFO]OPESPLNUM;"EXTWST";1
If fstat & [F:MFO]OPESPLNUM<>0
   Read [CAL]CAL0="MFO";0;[F:MFO]MFGNUM;[F:MFO]OPENUM;0;"EXTWST";1
Endif
If fstat & !find(LRET,0,[F:MFO]OPESPLNUM)
   Read [CAL]CAL0="MFO";0;[F:MFO]MFGNUM;[F:MFO]OPENUM;LRET;"EXTWST";1
Endif
If fstat
   Filter [CAL] Where ABRFIC="MFO" & VCRTYP=0 & VCRNUM=[F:MFO]MFGNUM & VCRLIN=[F:MFO]OPENUM & CPLCLE="EXTWST" & ANALIG=1
   Read [CAL]CAL0 Last
   Filter [CAL]
Endif
If fstat<=2 : WEXISTE=0 : WOPESPLNUM=[F:CAL]VCRSEQ
Else        : WEXISTE=1 : WOPESPLNUM=[F:MFO]OPESPLNUM
Endif
LRET=0

If WEXISTE = 0
    Readlock [CAL]CAL0="MFO";0;[F:MFO]MFGNUM;[F:MFO]OPENUM;WOPESPLNUM;"EXTWST";1
    If fstat=1
        GOK=-1 : GLOCK="$CPTANALIN MFO 0"-[F:MFO]MFGNUM-num$([F:MFO]OPENUM)-num$(WOPESPLNUM)-"EXTWST" : End
    Elsif fstat
        GOK=0  : Call RSTA("CAL","MFO 0"-[F:MFO]MFGNUM-num$([F:MFO]OPENUM)-num$(WOPESPLNUM)-"EXTWST") From GLOCK : End
    Endif
    # on conserve la ligne trouvée, avec maj de [F:MFO]OPESPLNUM
    If [F:CAL]VCRSEQ<>[F:MFO]OPESPLNUM : [F:CAL]VCRSEQ=[F:MFO]OPESPLNUM : WEXISTE=1 : Endif

    # Issue 90006 GA 05/2013 conserver la ligne CAL fraction 0 en cas de splittage d'une opé
    # If WOPESPLNUM<>[F:MFO]OPESPLNUM : WEXISTE=1 : Endif
Else
    # in theory, this part should not be used anymore
    Raz [F:CAL]
    [F:CAL]ABRFIC="MFO"
    [F:CAL]VCRNUM=[F:MFO]MFGNUM
    [F:CAL]VCRLIN=[F:MFO]OPENUM
    [F:CAL]VCRSEQ=[F:MFO]OPESPLNUM
    [F:CAL]CPLCLE="EXTWST"
    [F:CAL]ANALIG=1

    For WI=1 To max(GNBCOA,2)
      [F:CAL]LED(WI-1)=GLEDSOC(WI)
      [F:CAL]COA(WI-1)=GCOA(WI)
    Next WI
    For WI=1 To max(GNBDIE,GOPTCANA)
      [F:CAL]DIE(WI-1)=GDIE(WI)
      #### ???? [F:CAL]CCE(WI-1)=evalue("[M:MFG3]CCE"+num$(WI)+"(nolign-1)")
    Next WI
Endif
#-----
If WEXISTE=0 : Rewrite [CAL] : Else  Write [CAL] : Endif
If fstat : GOK=0 : Call FSTA("CAL") From GLOCK : End : Endif
#
If [F:MFO]EXTLAB = "" : End : Endif

# Poste secondaire L'enregistrement peut ne pas exister même en modif (si le poste secondaire a été rajouté)
#WLABWST  = 1
# If WEXISTE=0 : # Issue 38555 GH 18/10/2017 - don't test WEXISTE till changes introduced by issue 90006
   Readlock [CAL]CAL0="MFO";0;[F:MFO]MFGNUM;[F:MFO]OPENUM;WOPESPLNUM;"EXTLAB";1
   If !fstat  : WLABWST= 0 : Else WLABWST=1 : Endif
#Endif
If WLABWST  = 1
    # in theory, this part should not be used anymore
    Raz [F:CAL]
    [F:CAL]ABRFIC="MFO"
    [F:CAL]VCRNUM=[F:MFO]MFGNUM
    [F:CAL]VCRLIN=[F:MFO]OPENUM
    [F:CAL]VCRSEQ=[F:MFO]OPESPLNUM
    [F:CAL]CPLCLE="EXTLAB"
    [F:CAL]ANALIG=1
    #-----
    For WI=1 To max(GNBCOA,2)
      [F:CAL]LED(WI-1)=GLEDSOC(WI)
      [F:CAL]COA(WI-1)=GCOA(WI)
    Next WI
    For WI=1 To max(GNBDIE,GOPTCANA)
      [F:CAL]DIE(WI-1)=GDIE(WI)
      #### ???? [F:CAL]CCE(WI-1)=evalue("[M:MFG3]LABCCE"+num$(WI)+"(nolign-1)")
    Next WI
Else
    # on conserve la ligne trouvée, avec maj de [F:MFO]OPESPLNUM
    If [F:CAL]VCRSEQ<>[F:MFO]OPESPLNUM : [F:CAL]VCRSEQ=[F:MFO]OPESPLNUM : WLABWST=1 : Endif

    # Issue 90006 GA 05/2013 conserver la ligne CAL fraction 0 en cas de splittage d'une opé
    #If WOPESPLNUM<>[F:MFO]OPESPLNUM : WLABWST=1 : Endif
Endif
#-----
If WLABWST=0 : Rewrite [CAL] : Else Write [CAL] : Endif
If fstat : GOK=0 : Call FSTA("CAL") From GLOCK : End : Endif

End

#########################################################################
# FQ 74274 GA 10/2011 initialisation OPEUOM et champs associés par défaut
#########################################################################
Subprog COMPLETE_OPEUOM(LROUNUM,LSCOITMREF,LBPRNUM, LSCOLTI,LOPEUOM,LOPESTRCOE,LSCOPUU)
Value    Char    LROUNUM
Value    Char    LSCOITMREF
Value    Char    LBPRNUM
Variable Decimal LSCOLTI
Variable Char    LOPEUOM
Variable Decimal LOPESTRCOE
Variable Char    LSCOPUU

If LSCOITMREF = "" : End : Endif

Local Decimal WCOEFF

If !clalev([F:ITMW]) : Local File ITMMASTER [ITMW] : Endif
If !clalev([F:ITPW]) : Local File ITMBPS    [ITPW] : Endif

# si article sous-traitance renseigné, on récupère le délai et l'UA
#If LSCOITMREF <> ""
    # Issue 92821 GA 09/2013 code remonté pour simplifier
    If LBPRNUM <> ""       # FQ 63036 GA 04/2010 recup des infos Article-Fournisseur
        Read [ITPW]ITP0=LSCOITMREF;LBPRNUM
        If fstat
           Raz [F:ITPW]
        Elsif [F:ITPW]DOUFLG > 1
           LBPRNUM = ""
        Else
           If [F:ITPW]PUU<>""   : LSCOPUU = [F:ITPW]PUU    : Endif
           If [F:ITPW]SCOLTI<>0 : LSCOLTI = [F:ITPW]SCOLTI : Endif
        Endif
    Endif

    Read [ITMW]ITM0=LSCOITMREF
    If !fstat
        # Issue 92821 GA 09/2013 UO=US article sous-traitance sinon pb par la suite
        #If LOPEUOM="" LOPEUOM = [F:ITMW]STU Endif
        If LOPEUOM <> [F:ITMW]STU
           #Call ECR_TRACE("COMPLETE_OPEUOM: remplacement LOPEUOM"-LOPEUOM-"->"-[F:ITMW]STU,0) From GESECRAN
           LOPEUOM = [F:ITMW]STU
        Endif
        If LSCOLTI=0  : LSCOLTI=[F:ITMW]OFS : Endif
        If LSCOPUU="" : LSCOPUU=[F:ITMW]PUU : Endif
        # Issue 92821 GA 09/2013 en priorité le coef sur [F:ITPW]
        # FQ 77413 GA 10/2011 en priorité le coef sur [F:ITMW]
        #If LSCOPUU=[F:ITMW]PUU
        If LSCOPUU=[F:ITPW]PUU  & LOPEUOM = [F:ITMW]STU & [F:ITPW]PUUSTUCOE<>0
           LOPESTRCOE = 1/[F:ITPW]PUUSTUCOE
        Elsif LSCOPUU=[F:ITMW]PUU  & LOPEUOM = [F:ITMW]STU & [F:ITMW]PUUSTUCOE<>0 # Issue 89563 GA 05/2013  ssi UO = US article sous-traitance
           LOPESTRCOE = 1/[F:ITMW]PUUSTUCOE                                    # Issue 80045 coeff STU=>PUU et non pas PUU=>STU
        Else
          Call RECH_COEFF(LOPEUOM, [F:ITMW]STU, WCOEFF) From MFGLIB
          If WCOEFF <> 0
              LOPESTRCOE = WCOEFF
          Else
              LOPESTRCOE = 1
              LSCOPUU = [F:ITMW]STU # 42973 mm 09.07
          Endif
        Endif
    Endif
# 83407 - Hors sous-traitance, on laisse les données issues de la gamme
#Else
#    If [F:ITMW]ITMREF<>LROUNUM
#      Read [ITMW]ITM0=LROUNUM
#      If fstat  Endif
#    Endif
#    LOPEUOM = [F:ITMW]STU
#    LOPESTRCOE = 1
#Endif
End

## GH 20/07/2016 bug 117694 - subprog added
#**----------------------------------------------------------------<br/>
#* UPDCOE : Recalculate time coef for secondary workstation
#**<br/>----------------------------------------------------------------<br/>
#* @param PFCY = site
#* @param POLDLAB = Old lab workstation
#* @param PNEWLAB = New lab workstation
#* @param PSETCOE = setting time coef
#* @param PLABCOE = operation time coef
#**<br/>----------------------------------------------------------------
#*!
Subprog UPDCOE(PFCY, POLDLAB, PNEWLAB, PSETCOE, POPECOE)
Value Char PFCY
Value Char PNEWLAB
Value Char POLDLAB
Variable Decimal PSETCOE
Variable Decimal POPECOE

If PFCY="" | PNEWLAB="" | POLDLAB=""
    End
Endif

If GWSTEFFINH=1
    If clalev([F:XMWS])=0 : Local File WORKSTATIO [XMWS] : Endif
    If [F:MWS]WST<>PNEWLAB | [F:MWS]WCRFCY<>PFCY
        Read [MWS]WST0=PNEWLAB;PFCY
        If fstat
            End
        Endif
    Endif
    If [F:XMWS]WST<>POLDLAB | [F:XMWS]WCRFCY<>PFCY
        Read [XMWS]WST0=POLDLAB;PFCY
        If fstat
            End
        Endif
    Endif
    If GOPEEFFAPP = 1
        PSETCOE = arr(PSETCOE * [F:XMWS]EFF / [F:MWS]EFF,0.001)
    Endif
    POPECOE = arr(POPECOE * [F:XMWS]EFF / [F:MWS]EFF,0.001)
Endif

End

#############################################################################################################
# Issue X3-55362 - 2017-09-11 by JUSYN : Check for Route load for versioned product for audit operation's changes
#############################################################################################################
Subprog VROULOAD()
Value Integer L
Local Integer I,J,K

If dim([M:MFG1]ROUECCMAJ) < 0 : End : Endif
If GMFGREV <> 2 : End : Endif
If GREP = "C"   : End : Endif

If [M:MFG1]ROUECCMAJ <> ""
    GMFGROPE = 1
Endif

End

