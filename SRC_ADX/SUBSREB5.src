#<AdxTL>@(#)2.0.0.0 $Revision$
##########################################################################################################
#   Programmes utilitaires pour la gestion des demandes de services      Module CRM          11 mars 2005
#   ONSELSET           : Chargement modele de demande de service
#   LOADSETMAC         : Chargement du parc listé sur modèle demande
#   LOADSETMACCPN      : Chargement des composants à partir d'un modèle demande
#   LOADSETHDT         : Chargement des consommations à partir d'un modèle de demande pour un parc
#   LOADALLSETHDT      : Chargement des consommations à partir d'un modèle de demande pour tout le parc
##########################################################################################################
#Chargement modele de demande de service
##########################################################################################################
$ONSELSET
  Read [SET]SET0=[M:SRE1]SRETPL
  If fstat = 0 Then
    GISETFCOT = 1
    #Site
    If [M:SRE0]SALFCY = "" Then
      [M:SRE0]SALFCY = [F:SET]SALFCY
    Endif
    If [M:SRE8]STOFCY = "" Then
      [M:SRE8]STOFCY = [F:SET]SALFCY
    Endif
    #DESIGNATION, description
    [SRE1]SRETTR = [F:SET]TTR
    If [F:SET]TYPFULDES <> "" Then
      If [F:SET]NUMFULDES <> "" Then
        Read [HD1]HD10=[M:SRE1]NUMFULDES;[M:SRE1]TYPFULDES
        If fstat = 0 Then
          [M:SRE1]SREFULDES = [F:HD1]CLOB
        Endif
      Endif
    Endif
    #Famille de compétence
    [M:SRE7]SREPBLGRP = [F:SET]PBL
    #Parc
    [M:SRE7]TYPMAC = [F:SET]TYPMAC
    [M:SRE7]MACFLT = [F:SET]MACFLT
    [M:SRE7]MACFLTINT = [F:SET]MACFLTINT
    If [F:SET]TYPMAC = 1 Then
      Call LOADSETMAC([M:SRE0]SREBPC, [F:SET]SETNUM)
    Else
      Call ONMACFLT([M:SRE0]SRENUM, [M:SRE7]MACFLT, [M:SRE7]MACFLTINT) From SUBSREB2
      Call LOADALLSETHDT([M:SRE1]SRETPL)
    Endif
  Endif
  Affzo [M:SRE0]1-99
  Affzo [M:SRE1]1-99
  Affzo [M:SRE2]1-99
  Affzo [M:SRE7]1-99
  Affzo [M:SRE8]1-99
  Affzo [M:SRE9]1-99
End

##########################################################################################################
#Chargement du parc listé sur modèle demande
#####################################################################
Subprog LOADSETMAC (SZBPCNUM, SZSETNUM)
Value Char SZBPCNUM
Value Char SZSETNUM    # FGR 10/08/2009 : X3SUIVI57084

Local Integer ILINDEB
Local Integer INBMAC
Local Integer ISAVENOLIGN
Local Integer IERRINF
Local Integer ICHAPTER
Local Integer IBRETOUR
Local Integer ICOVNOL
Local Integer IERROR  # FGR 08/02/2010 : X3SUIVI60986

  IERROR = 0   # FGR 08/02/2010 : X3SUIVI60986
  IERRINF = 0
  ICHAPTER = 0
  IBRETOUR = 1
  ILINDEB = 0
  INBMAC  = 0
  ISAVENOLIGN = 0
  ISAVENOLIGN = nolign
  If !clalev([F:MAC0]) : Local File MACHINES[MAC0] : Endif
  Raz [M:SRE7]NBMAC
  Raz [M:SRE7]NBMACSEL
  Raz [M:SRE7]MAC
  Raz [M:SRE7]ITM
  Raz [M:SRE7]ITMDES
  Raz [M:SRE7]SER
  Raz [M:SRE7]QTY
  Raz [M:SRE7]LND
  Raz [M:SRE7]PBL
  Raz [M:SRE7]PBLCLA
  Raz [M:SRE7]COVFLG
  Raz [M:SRE7]COVSPT
  Raz [M:SRE7]COVVCR
  If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
    # FGR 30/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
    Raz [M:SRE7]PITMAC
  Endif
  Raz [M:SRE7]MACCOVCLA
  Raz [M:SRE7]MACCOVREN
  Raz [M:SRE7]ITNGRU
  Raz [M:SRE7]MACDEF
  Raz [M:SRE7]CKKHDTAMT
  If SZBPCNUM = "" Then
    End
  Endif
  Filter [SEM] Where [F:SEM]SETNUM = SZSETNUM Order By [F:SEM]ITMREF Asc
  nolign = 0
  For [SEM]
    If ILINDEB >= dim([M:SRE7]MAC) Then
      Break
    Endif
    #On recherche si un artice identique appartient au parc client
    INBMAC = 0
    Filter [MAC0] Where (([F:MAC0]MACITNTYP=1 and [F:MAC0]BPCNUM=SZBPCNUM) or ([F:MAC0]MACITNTYP>=2 and [F:MAC0]MACITNTYP<=3 and [F:MAC0]MACRSL=SZBPCNUM))
&                        and [F:MAC0]MACPDTCOD = [F:SEM]ITMREF
    For [MAC0]MAC1
      INBMAC += 1
      If INBMAC >= 2 Then
        Break
      Endif
    Next
    Filter [MAC0]
    If INBMAC > 0 Then
      nolign += 1
      IERRINF = 0
      If ILINDEB = 0 Then
        [M:SRE7]NBMACSEL(ILINDEB) = "->"
      Else
        [M:SRE7]NBMACSEL(ILINDEB) = ""
      Endif
      [M:SRE7]ITM(nolign-1) = [F:MAC0]MACPDTCOD
      If [M:SRE7]ITM(nolign-1) = "" Then
        [M:SRE7]ITMDES(nolign-1) = ""
      Else
        #Call LECTEXTRA([M:SRE7]ITMDES(nolign-1), "ITMMASTER", "DES1AXX", [M:SRE7]ITM(nolign-1), "") From ATEXTRA
        Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[M:SRE7]ITM(nolign-1),[M:SRE7]ITMDES(nolign-1), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
      Endif
      If INBMAC = 1 Then
        [M:SRE7]SER(nolign-1) = [F:MAC0]MACSERNUM
        [M:SRE7]QTY(nolign-1) = [F:MAC0]MACQTY
        If [M:SRE7]QTY(nolign-1) = 0 Then
          [M:SRE7]QTY(nolign-1) = 1
        Endif
        [M:SRE7]LND(nolign-1) = [F:MAC0]MACITNLND
        #S'il n'y aucun parc par défaut, celui-ci va le devenir
        If [M:SRE0]SREMAC = "" Then
          [M:SRE7]MACDEF(nolign-1) = 2
          [M:SRE0]SREMAC = [F:MAC0]MACNUM
        Else
          If [M:SRE7]MACDEF(nolign-1) <> 2 Then
            [M:SRE7]MACDEF(nolign-1) = 1
          Endif
        Endif
        If [M:SRE7]SREPBLGRP <> "" Then
          If [M:SRE7]PBL(nolign-1) = "" Then
            [M:SRE7]PBL(nolign-1) = [M:SRE7]SREPBLGRP
            Read [PBL]PBL0=[M:SRE7]PBL(nolign-1)
            If fstat Then
              [M:SRE7]PBLCLA(nolign-1) = ""
            Else
              # FGR 23/09/2009 : X3SUIVI58024
              #[M:SRE7]PBLCLA(nolign-1) = [F:PBL]GRPPBLDES
              Call LECTEXTRA([M:SRE7]PBLCLA(nolign-1),"FAMPB","GRPPBLDESAXX",[F:PBL]NUM,"") From ATEXTRA
            Endif
          Endif
        Endif
      Endif
      #On supprime les composants
      If [M:SRE7]MAC(nolign-1) <> "" Then
        Gosub RAZCPN From SUBSREB2
      Endif
      #---------------------------------------------------#
      # Suppression des points de l'ancienne fiche parc
      #---------------------------------------------------#
      ICOVNOL = nolign-1
      If [M:SRE7]MAC(nolign-1) <> "" Then
        Call DELPITCOV(GREP, 1, ICOVNOL, IERRINF) From TRTCOVER
        If IERRINF Then
          #Erreur lors de suppression des couvertures par points. Le contrôle de couverture est abandonné.
          GMESSAGE = mess(IERRINF,182,1)
          GERR = 1
          # FGR 08/02/2010 : X3SUIVI60986
          #End
          IERROR = 1   # FGR 08/02/2010 : X3SUIVI60986
          Break
        Endif
      Endif
      If INBMAC = 1 Then
        [M:SRE7]MAC(nolign-1) = [F:MAC0]MACNUM
        Call LOADSETMACCPN (SZSETNUM, [F:MAC0]MACNUM)
        Call SAVECPN([M:SRE0]CRESEQ, [M:SRE7]MAC(nolign-1), 0, IERRINF, ICHAPTER, IBRETOUR) From SUBSREB1
        If IBRETOUR = 0 Then
          GMESSAGE = mess(IERRINF,ICHAPTER,1)
          GERR = 1
          IERROR = 1   # FGR 08/02/2010 : X3SUIVI60986
          Break
        Endif
        Call LOADSETHDT(SZSETNUM, [M:SRE7]ITM(nolign-1), [M:SRE7]MAC(nolign-1))
      Endif
      ILINDEB += 1
      #---------------------------------------------------#
      # Contrôle de la couverture
      #---------------------------------------------------#
      Call COVERML(ICOVNOL) From TRTCOVER
    Endif
  Next
  Filter [SEM]
  If IERROR Then
    # FGR 08/02/2010 : X3SUIVI60986
    End
  Endif
  [M:SRE7]NBMAC = ILINDEB
  nolign = ISAVENOLIGN 
End

##########################################################################################################
#Chargement du parc listé sur modèle demande
#####################################################################
Subprog LOADSETMACCPN (SZSETNUM, SZITMNUM)
Value Char SZSETNUM
Value Char SZITMNUM

Local Integer ILINCPN
Local Integer ICOVNOL
Local Integer ISAVENOLIGN 

  ILINCPN = 0
  ICOVNOL = 0
  ISAVENOLIGN = nolign
  Raz [M:SRE7]NBCPN
  Raz [M:SRE7]CPNITM
  Raz [M:SRE7]CPNQTY
  Raz [M:SRE7]CPNCOVFLG
  Raz [M:SRE7]CPNCOVSPT
  Raz [M:SRE7]CPNCOVVCR
  Raz [M:SRE7]CPNCOVCLA
  Raz [M:SRE7]CPNCOVREN
  Raz [M:SRE7]CPNSEQ
  Raz [M:SRE7]CPNCKKHDT
  If SZSETNUM = "" Then
    End
  Endif
  If SZITMNUM = "" Then
    End
  Endif
  Filter [SEN] Where [F:SEN]SETNUM = SZSETNUM and [F:SEN]ITMREF = SZITMNUM and [F:SEN]TPYFLG = 0 Order By [F:SEN]ITMREF Asc
  nolign = 0
  For [SEN]
    If ILINCPN >= dim([M:SRE7]CPNITM) Then
      Break
    Endif
    nolign += 1
    [M:SRE7]CPNITM(nolign-1 ) = [F:SEN]CPNITM
    #Call LECTEXTRA([M:SRE7]CPNITMDES(nolign-1), "ITMMASTER", "DES1AXX", [M:SRE7]CPNITM(nolign-1), "") From ATEXTRA
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[M:SRE7]CPNITM(nolign-1),[M:SRE7]CPNITMDES(nolign-1), "") From TRTX3 # FGR 02/07/2009 : X3SUIVI56296
    [M:SRE7]CPNSEQ(nolign-1 ) = [F:SEN]CPNSEQ
    [M:SRE7]CPNQTY(nolign-1 ) = [F:SEN]CPNQTY
    #---------------------------------------------------#
    # Contrôle de la couverture
    #---------------------------------------------------#
    ICOVNOL = nolign-1
    Call COVERMLC(ICOVNOL, [M:SRE7]PRESRE7NOL) From TRTCOVER
    ILINCPN += 1
  Next
  Filter [SEN]
  [M:SRE7]NBCPN = ILINCPN
  nolign = ISAVENOLIGN
End

##########################################################################################################
#Chargement des consommations à partir d'un modèle de demande pour un parc
#####################################################################
Subprog LOADSETHDT (SZSETNUM, SZITMNUM, SZMACNUM)
Value Char SZSETNUM
Value Char SZITMNUM
Value Char SZMACNUM

Local Integer INOLIGNSRE9
Local Integer IWORK
Local Integer IWORKTAB
Local Integer ITABMACNUM
Local Integer INBTABMACNUM
Local Char SZTABMACNUM(GLONVCR)(0..[M:SRE7]NBMAC)
Local Integer ITRAITE
Local Integer INOGLOBAL
Local Integer ISAVENOLIGN
Local Integer ISAVNOLIGNSRE9
Local Integer J
Local Integer IERRINF
Local Char    SECTION 
Local Integer INOL
Local Integer ITEST
Local Decimal IPITHDT     # FGR 24/02/2010 : X3SUIVI62770 : Pour le moment tout doit être decimal
Local Decimal IINVPITFLG  # FGR 24/02/2010 : X3SUIVI62770 : Pour le moment tout doit être decimal

  IERRINF = 0
  INOLIGNHDT = 0
  ISAVNOLIGNSRE9 = 0
  ITABMACNUM = 0
  INBTABMACNUM = 0
  ITRAITE = 0
  INOGLOBAL = 0
  ISAVENOLIGN = nolign
  If SZSETNUM= "" Then
    End
  Endif
  If SZITMNUM= "" Then
    End
  Endif
  If SZMACNUM= "" Then
    End
  Endif
  Filter [HDT] Where [F:HDT]SRENUM = SZSETNUM and [F:HDT]HDTMACSET = SZITMNUM and [F:HDT]TPL = 2 Order By [F:HDT]HDTMACSET Asc
  INOLIGNSRE9 = [M:SRE9]NBLIG
  For [HDT] Hint Key HDT1
    If INOLIGNSRE9 >= dim([M:SRE7]CPNITM) Then
      Break
    Endif
    ITRAITE = 1
    #Type d'exécution global/par parc
    If [F:HDT]HDTTYPRUU = 1 Then
      #Execution global, on va l'affecter sur le premier 
      #Il faut regarder si un article de ce type a été déjà saisi
      #On construit tableau parc correspondant à cet article si pas déjà créer
      If ITABMACNUM = 0 Then
        INBTABMACNUM = 0
        For IWORKTAB = 0 To [M:SRE7]NBMAC-1
          If [M:SRE7]ITM(IWORKTAB) = SZITMNUM Then
            If [M:SRE7]MAC(IWORKTAB) <> SZMACNUM Then
              SZTABMACNUM(INBTABMACNUM) = [M:SRE7]MAC(IWORKTAB)
              INBTABMACNUM += 1
            Endif
          Endif
        Next
        #RECHERCHE si article déjà saisie
        For IWORK = 0 To [M:SRE9]NBLIG-1
          For IWORKTAB = 0 To INBTABMACNUM 
            If SZTABMACNUM(IWORKTAB) = [M:SRE9]HDTMACSRE(IWORK) Then
              INOGLOBAL = 1
              Break
            Endif
          Next
          If INOGLOBAL = 1 Then
            Break
          Endif
        Next
        ITABMACNUM = 1
      Endif
      If INOGLOBAL = 1 Then
        ITRAITE = 0
      Endif
    Endif
    If ITRAITE = 1 Then
      INOLIGNSRE9 += 1
      ISAVNOLIGNSRE9 = nolign
      nolign= INOLIGNSRE9 
      [M:SRE9] = [F:HDT]
      nolign = ISAVNOLIGNSRE9
      [M:SRE9]HDTNUM(INOLIGNSRE9-1) = ""        
      [M:SRE9]HDTMACSRE(INOLIGNSRE9-1) = SZMACNUM
      [M:SRE9]HDTSTOFCY(INOLIGNSRE9-1) = ""
      [M:SRE9]HDTSTOISS(INOLIGNSRE9-1) = 1
      Read [ITM]ITM0=[M:SRE9]HDTITM(INOLIGNSRE9-1)
      If fstat Then
        [M:SRE9]HDTUOM(INOLIGNSRE9-1) = ""
        [M:SRE9]HDTSTU(INOLIGNSRE9-1) = ""
      Else
        [M:SRE9]HDTUOM(INOLIGNSRE9-1) = [F:ITM]SAU
        [M:SRE9]HDTSTU(INOLIGNSRE9-1) = [F:ITM]STU
        [M:SRE9]STOMGTCOD(INOLIGNSRE9-1) = [F:ITM]STOMGTCOD
        If [M:SRE9]HDTTYP(INOLIGNSRE9-1) = 2 Then
          [M:SRE9]HDTSTOFCY(INOLIGNSRE9-1) = [M:SRE8]STOFCY
          If [F:ITM]STOISSDEF = 2 Then
            [M:SRE9]HDTSTOISS(INOLIGNSRE9-1) = 2
          Endif
        Endif
      Endif
      [M:SRE9]HDTISSQTY(INOLIGNSRE9-1) = 0
      [M:SRE9]HDTAVA(INOLIGNSRE9-1) = 0
      [M:SRE9]HDTAVAUOM(INOLIGNSRE9 - 1) = ""
      [M:SRE9]HDTAMT(INOLIGNSRE9-1) = 0
      [M:SRE9]HDTCUR(INOLIGNSRE9-1) = [M:SRE8]SRECUR
      [M:SRE9]MANAMTFLG(INOLIGNSRE9-1) = 1
      If [M:SRE9]HDTAUS(INOLIGNSRE9-1) = "" Then
        [M:SRE9]HDTAUSTYP(INOLIGNSRE9-1) = 1
        [M:SRE9]HDTAUS(INOLIGNSRE9-1) = GUSER
        Read [AUS]CODUSR=GUSER
        If fstat Then
          [M:SRE9]HDTAUSCOD(INOLIGNSRE9-1) = ""
        Else
          [M:SRE9]HDTAUSCOD(INOLIGNSRE9-1) = [F:AUS]NOMUSR
        Endif
      Endif
      #Sorties de stock
      INOL = INOLIGNSRE9 - 1
      Call INIZONSOR("SRE9", [M:SRE9]HDTITM(INOLIGNSRE9-1), [M:SRE9]HDTSTOFCY(INOLIGNSRE9-1), INOL, 24, [M:SRE0]TRSCOD , "") From STKECR
      #Sections analytiques à la ligne
      For J = 1 To GNBDIE
        If evalue("[M:SRE9]CCE"+num$(J)+"(INOL)") = "" Then
          Call INISEC(SECTION,"HDT",J) From TRTX3CPT
          Assign "[M:SRE9]CCE"+num$(J)+"(INOL)" With SECTION 
        Endif
      Next
      Call RUNTARIF(0, [M:SRE9]HDTITM(INOL), [M:SRE9]HDTQTY(INOL), [M:SRE9]HDTUOM(INOL), INOL) From SUBSREB2
      #Détermination du montant facturable par défaut
      If func CRMUTIL150.GET_CODE_ACTIVITE("PIT") = 2 Then
        # FGR 29/01/2009 : X3SUIVI41698 : seulement si on gère les point (PIT) sinon le champs n'est pas là
        Call AMOUNT(1, "SRE9", INOLIGNSRE9 - 1, [M:SRE9]HDTAMT(INOLIGNSRE9-1), [M:SRE9]HDTINV(INOLIGNSRE9-1), [M:SRE9]HDTAMTINV(INOLIGNSRE9-1),
&                   [M:SRE9]PITHDT(INOLIGNSRE9-1), [M:SRE9]INVPITFLG(INOLIGNSRE9-1), IERRINF) From TRTAMOUNT
      Else
        IPITHDT = 0
        IINVPITFLG = 0
        Call AMOUNT(1, "SRE9", INOLIGNSRE9 - 1, [M:SRE9]HDTAMT(INOLIGNSRE9-1), [M:SRE9]HDTINV(INOLIGNSRE9-1), [M:SRE9]HDTAMTINV(INOLIGNSRE9-1),
&                   IPITHDT, IINVPITFLG, IERRINF) From TRTAMOUNT
      Endif
      If IERRINF Then
        Break
      Endif
    Endif
  Next
  Filter [HDT]
  [M:SRE9]NBLIG = INOLIGNSRE9
  Call LOADTOTPIT(1) From SUBSREB1
  Call LOADTOTHDT(1) From SUBSREB1
  Affzo [M:SRE9]1-99
  nolign = ISAVENOLIGN
End

##########################################################################################################
#Chargement des consommations à partir d'un modèle de demande pour tout le parc
#####################################################################
Subprog LOADALLSETHDT (SZSETNUM)
Value Char SZSETNUM

Local Integer IWORK

  For IWORK = 0 To [M:SRE7]NBMAC-1
    If [M:SRE7]MAC(IWORK) <> "" Then
      Call LOADSETHDT(SZSETNUM, [M:SRE7]ITM(IWORK), [M:SRE7]MAC(IWORK))
    Endif
  Next
End
