#<AdxTL>@(#)0.0.0.0 $Revision$
# Superviseur
# Gestion du masque HRMAT1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [09/11/2018]
A_HEURE = "23:04:38"
A_USER  = "DOC"
A_STAMP = "20181109230438"
Return

$TITRES
Chgtzn [M:EMP1]ADD1 With [F:TCY]ADRNAM(0)
Chgtzn [M:EMP1]ADD2 With [F:TCY]ADRNAM(1)
Chgtzn [M:EMP1]ADD3 With [F:TCY]ADRNAM(2)
Return

$CHG_FMT
Case zoncou
 When "NBCNT"
  If [M]NBCNT=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask HRMAT1 [EMP1]
Gosub HORODAT
Local Inpbox "HRMAT1" From GFONCTION At A_STAMP With A_WINDPREV Mask [EMP1] As [SIM_]
Grizo [EMP1]10
Grizo [EMP1]20
Grizo [EMP1]30
Grizo [EMP1]45
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [EMP1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=95 : Y1(0)=1 : Y2(0)=13
X1(1)=1 : X2(1)=51 : Y1(1)=14 : Y2(1)=19
X1(2)=52 : X2(2)=95 : Y1(2)=14 : Y2(2)=19
X1(3)=1 : X2(3)=95 : Y1(3)=20 : Y2(3)=23
Return

$ON_CRY
Onevent CONTROL Call C_CRY(zc) From W1HRMAT1
Onevent AFTER_CHANGE Gosub AMM_CRY From W1HRMAT1
Onevent BEFORE_INPUT Call AS_CRY(zc) From W1HRMAT1
Onevent INIT_AREA Call D_CRY(zc) From W1HRMAT1
Return

Subprog D_CRY(VALEUR)
Variable Char    VALEUR()
If varinit([M]CRY,indice)=0
 VALEUR = GPAYS
Endif
Gosub _AFF
End

Subprog AS_CRY(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(53316,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CRY(zc) From W1HRMAT1
Onkey   2 Titled GBOUTS Call S_CRY(zc) From W1HRMAT1
Onkey 144 Titled GBOUTP Call P_CRY(zc) From W1HRMAT1
Onkey 146 Titled GBOUTA Call SA_CRY(zc) From W1HRMAT1
Gosub _AFF
End

Subprog C_CRY(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 235 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("TCY","",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 235 : Endif
 If !mkstat
  ## Action INIPAYS
  Call INIPAYS(VALEUR,[M]CRYNAM) From TRTDIV
  If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 235 : Endif
  If !mkstat
   ## Action STD
   Call C_CRY(VALEUR) From SUBEML2
   If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 235 : Endif
  Endif
 Endif
Endif
Gosub _AFF
End

$AMM_CRY
Call AM_CRY(zc)
If !mkstat & GOBJET
 zoncou = "CRY" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CRY(VALEUR)
Variable Char    VALEUR()
## Action STD
Call AM_CRY(VALEUR) From SUBEML2
If mkstat : GERR = 1 : GZONE = "CRY" : GZNUM = 235 : Endif
Gosub _AFF
End

Subprog S_CRY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "TCY"
PARMSK(2) = ""
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_CRY(VALEUR)
Variable Char    VALEUR()
Call OBJET("TCY",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CRY(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "TCY"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CRY(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("TCY",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_CRYNAM
Onevent BEFORE_INPUT Call AS_CRYNAM(zc) From W1HRMAT1
Return

Subprog AS_CRYNAM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
If !GWEBSERV
 ## Action SAIPAYS
 Call SAIPAYS([M]CRY) From TRTDIV
 If mkstat=2
  [M]CRYNAM(INDIC) = VALEUR
  Affzo CRYNAM(INDIC) : mkstat = 2
 Endif
Endif
Gosub _AFF
End

$ON_ADD1
Onevent BEFORE_AREA Gosub AV_ADD1 From W1HRMAT1
Return

$AV_ADD1
## Action FMTADRPAY
Call FMTADRPAY([M]CRY) From TRTDIV
If GFMT<>""
 Chgfmt [M]ADD1(indice) With "K:"+GFMT
Else
 Chgfmt [M]ADD1(indice) With "-K:1X"
Endif
Gosub _AFF
Return

