Subprog AS_CODPOS(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(649,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
## Action STD
Call AS_CODPOS(VALEUR) From SUBEML2
If mkstat=2
 [M]CODPOS(INDIC) = VALEUR
 Affzo CODPOS(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CODPOS(zc) From W1HRMAT1
Onkey   2 Titled GBOUTS Call S_CODPOS(zc) From W1HRMAT1
Gosub _AFF
End

