$ON_CODSEE
Onevent BEFORE_INPUT Call AS_CODSEE(zc) From W1HRMAT1
Return

Subprog AS_CODSEE(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(649,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
## Action STD
Call AS_CODSEE(VALEUR) From SUBEML2
If mkstat=2
 [M]CODSEE(INDIC) = VALEUR
 Affzo CODSEE(INDIC) : mkstat = 2
Endif
Onkey 129 Titled GBOUT1 Call B1_CODSEE(zc) From W1HRMAT1
Onkey   2 Titled GBOUTS Call S_CODSEE(zc) From W1HRMAT1
Gosub _AFF
End

Subprog S_CODSEE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELINSEE
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELINSEE"
 PARMSK(1) = [M]CTY
 PARMSK(2) = [M]CRY
 PARMSK(3) = [M]CODPOS
 PARMSK(4) = VALEUR
 Call S_TAB_CHAR(VALEUR,PARMSK,"","TRTINSEE","") From GACTION
 [M]CTY = PARMSK(1)
 [M]CODPOS = PARMSK(3)
 VALEUR = PARMSK(4)
 GACTION = SAVACT
Endif
If !GWEBSERV
 ## Action AFFZO
 If !GIMPORT : Affzo : Endif
Endif
Gosub _AFF
End

Subprog B1_CODSEE(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CODINSEE
 Call CODINSEE("POS",[M]CODPOS,[M]CRY,[M]CTY,VALEUR) From TRTINSEE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
End

$ON_EMPTAXNBR
