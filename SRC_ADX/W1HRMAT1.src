$ON_CODACS
Onevent CONTROL Call C_CODACS(zc) From W1HRMAT1
Onevent BEFORE_INPUT Call AS_CODACS(zc) From W1HRMAT1
Onevent AFTER_CHANGE Gosub AMM_CODACS From W1HRMAT1
Return

Subprog AS_CODACS(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(189,GBOUT1) From OBJDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_CODACS(zc) From W1HRMAT1
Onkey   2 Titled GBOUTS Call S_CODACS(zc) From W1HRMAT1
Onkey 144 Titled GBOUTP Call P_CODACS(zc) From W1HRMAT1
Onkey 146 Titled GBOUTA Call SA_CODACS(zc) From W1HRMAT1
Gosub _AFF
End

Subprog C_CODACS(VALEUR)
Variable Char    VALEUR()
## Action %CNTOBJ
Call CONTSEL("ACS","!",VALEUR,"",mkstat) From CONTOBJ
If mkstat : GERR = 1 : GZONE = "CODACS" : GZNUM = 729 : Endif
If !mkstat
 ## Action CONTACC
 Call CONTACC(VALEUR) From SUBACS
 If mkstat : GERR = 1 : GZONE = "CODACS" : GZNUM = 729 : Endif
Endif
Gosub _AFF
End

$AMM_CODACS
Call AM_CODACS(zc)
If !mkstat & GOBJET
 zoncou = "CODACS" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_CODACS(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZCODACS)")>indice
 [M]CODACS(indice) = VALEUR
 Affzo ZCODACS(indice)
Endif
Gosub _AFF
End

Subprog S_CODACS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELACC
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELACC"
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELACC","SUBACS","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CODACS(VALEUR)
Variable Char    VALEUR()
Call OBJET("ACS",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_CODACS(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ACS"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_CODACS(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("ACS",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZCODACS
Onevent BEFORE_AREA Gosub AV_ZCODACS From W1HRMAT1
Return

$AV_ZCODACS
Call LECTEXTRA(zc,"ACCCOD","DESACC",num$([M]CODACS(indice)),"") From ATEXTRA
Gosub _AFF
Return

