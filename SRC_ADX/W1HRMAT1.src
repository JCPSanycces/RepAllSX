$ON_HABCOD
Onevent INIT_AREA Call D_HABCOD(zc) From W1HRMAT1
Onevent CONTROL Call C_HABCOD(zc) From W1HRMAT1
Onevent BEFORE_INPUT Call AS_HABCOD(zc) From W1HRMAT1
Onevent AFTER_CHANGE Gosub AMM_HABCOD From W1HRMAT1
Return

Subprog D_HABCOD(VALEUR)
Variable Char    VALEUR()
If varinit([M]HABCOD,indice)=0
 ## Action INILEG
 Call INILEG(VALEUR,"11559","") From SUBADI
Endif
Gosub _AFF
End

Subprog AS_HABCOD(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TITADI(GBOUT1,"11559") From TRTDIV
Call TEXTE(6028,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_HABCOD(zc) From W1HRMAT1
Onkey   2 Titled GBOUTS Call S_HABCOD(zc) From W1HRMAT1
Onkey 144 Titled GBOUTP Call P_HABCOD(zc) From W1HRMAT1
Onkey 146 Titled GBOUTA Call SA_HABCOD(zc) From W1HRMAT1
Gosub _AFF
End

Subprog C_HABCOD(VALEUR)
Variable Char    VALEUR()
## Action CONTADI
Call CONTADI(VALEUR,"11559","") From SUBADI
If mkstat : GERR = 1 : GZONE = "HABCOD" : GZNUM = 55138 : Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("ADI","!",VALEUR,"11559",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "HABCOD" : GZNUM = 55138 : Endif
Endif
Gosub _AFF
End

$AMM_HABCOD
Call AM_HABCOD(zc)
If !mkstat & GOBJET
 zoncou = "HABCOD" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_HABCOD(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZHABCOD)")>indice
 [M]HABCOD(indice) = VALEUR
 Affzo ZHABCOD(indice)
Endif
Gosub _AFF
End

Subprog S_HABCOD(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELADI
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELADI"
 PARMSK(1) = "11559"
 PARMSK(2) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELADI","SUBADI","") From GACTION
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_HABCOD(VALEUR)
Variable Char    VALEUR()
Call OBJET("ADI",VALEUR,"11559") From GOBJET
Gosub _AFF
End

Subprog SA_HABCOD(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "ADI"
PARMSK(2) = "11559"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_HABCOD(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = "11559"
Call VISU("ADI",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZHABCOD
Onevent BEFORE_AREA Gosub AV_ZHABCOD From W1HRMAT1
Return

$AV_ZHABCOD
