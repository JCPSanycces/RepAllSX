Subprog AM_CODPOS(VALEUR)
Variable Char    VALEUR()
## Action CPCONT
Local Char    PARMSK(250)(1..20) , SAVACT(20)
SAVACT = GACTION : GACTION = "CPCONT"
PARMSK(1) = [M]CRY
PARMSK(2) = [M]CTY
PARMSK(3) = ""
Call S_AFF_CHAR(VALEUR,PARMSK,"CPCONT","SUBPOS","") From GACTION
[M]CTY = PARMSK(2)
GACTION = SAVACT
If mkstat : GERR = 1 : GZONE = "CODPOS" : GZNUM = 210 : Endif
If !mkstat
 ## Action SELCTY2
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELCTY2"
 PARMSK(1) = [M]CRY
 PARMSK(2) = [M]CTY
 PARMSK(3) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELCTY2","SUBPOS","") From GACTION
 [M]CTY = PARMSK(2)
 GACTION = SAVACT
 If mkstat : GERR = 1 : GZONE = "CODPOS" : GZNUM = 210 : Endif
 If !mkstat
  ## Action STD
  Call AM_CODPOS(VALEUR) From SUBEML2
  If mkstat : GERR = 1 : GZONE = "CODPOS" : GZNUM = 210 : Endif
 Endif
Endif
Gosub _AFF
End

Subprog S_CODPOS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action SELPOS
 Local Char    PARMSK(250)(1..20) , SAVACT(20)
 SAVACT = GACTION : GACTION = "SELPOS"
 PARMSK(1) = [M]CRY
 PARMSK(2) = [M]CTY
 PARMSK(3) = ""
 PARMSK(4) = ""
 Call S_TAB_CHAR(VALEUR,PARMSK,"SELPOS","SUBPOS","") From GACTION
 [M]CTY = PARMSK(2)
 GACTION = SAVACT
Endif
Gosub _AFF
End

Subprog B1_CODPOS(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CODINSEE
 Call CODINSEE("POS",VALEUR,[M]CRY,[M]CTY,GCTYBRNSEE) From TRTINSEE
Endif
If mkstat=99 : mkstat = 0 : Elsif mkstat=0 : mkstat = 2 : Endif
Gosub _AFF
