AXE = 19 : Goto APRCCE
Subprog AP_CCE20(VALEUR)
Variable Char    VALEUR()
AXE = 20 : Goto APRCCE

$APRCCE
Local Integer I , NOL , OK
Local Char SECTION(GLONCCE)
NOL = nolign-1
If VALEUR="" : End : Endif

Call LECTURE("CCE",VALEUR,[M]DIE(AXE-1)) From CONTOBJ
Call COMPAT([M]FCY,[F:CCE]FCY,VALEUR) From CFYSUB
If mkstat : End : Endif

Call CONTACC([F:CCE]ACS) From CPTSUB
If mkstat
 GMESSAGE = VALEUR-GMESSAGE
 Gosub AVERTIR
 If OK<>2
  mkstat = 2 : End
 Else
  mkstat = 0
 Endif
Endif
End

$AVERTIR
If !GIMPORT
 OK = 2 : Call AVERTIR(GMESSAGE,OK) From GESECRAN
 Raz GMESSAGE
 If OK<>2
  mkstat = 2 : Return
 Endif
Endif
Return

