#<AdxTL>@(#)3.0.0.0 $Revision$
Raz GPILOBJ
Call OBJET("DSP",GBIDC1,GBIDC2) From GOBJET
End

$ACTION
Case ACTION
 When "OUVRE"     : Gosub OUVRE
 When "LIENS"     : Gosub LIENS
 When "RAZCRE"    : Gosub RAZCRE
 When "VERIF_CRE" : Gosub VERIF_CRE
 When "VERIF_MOD" : Gosub VERIF_MOD
 When "CREATION"  : Gosub CREATION
 When "MODIF"     : Gosub MODIF
 When "AP_CHANGE" : Gosub AP_CHANGE
 When "ANNULE"    : Gosub ANNULE
 When "INICRE"    : Gosub INICRE
 When "INIMOD"    : Gosub INIMOD
Endcase
Return

$OUVRE
If clalev([DIE]) = 0 : Local File GDIE [DIE] :  Endif
Local Char    INTIT(250)
Local Integer X, AXE, NOLI
Return

$INICRE
$INIMOD
If dim([F:DSP]DES)>0
 [F:DSP]DES = [M:DSP1]DESTRA
Endif
Return

$LIENS
Call LECTEXTRA([M:DSP1]DESTRA,"CADSP","DESTRA",[M:DSP1]DSP,"") From ATEXTRA
Call LECTEXTRA([M:DSP1]SHOTRA,"CADSP","SHOTRA",[M:DSP1]DSP,"") From ATEXTRA
Gosub INIFMT_CCE
Return

$RAZCRE
[M]NBRDIE=0
INTIT=""
FMT="-K:10X"
For N=1 To dim([M]DIE)
 Gosub INTIT_CCE
Next
zoncou="NBRDSP" # nécessaire pour déclencher l'affichage/masquage des colonnes dans $CHG_FMT From W1DSP1
Gosub CHG_FMT From W1DSP1
Affzo
Return

$INIFMT_CCE
Local Integer NBRDIE
[L]NBRDIE=[M]NBRDIE
# affichage des colonnes
For N=1 To [L]NBRDIE
 If [M]DIE(N-1)<>""
  # lecture du format
  Call INICCEFMT([M]DIE(N-1)) From SETGLBDIE
  FMT = "K:"+GCCEFMT
  Call LECTEXTRA(INTIT,"GDIE","COLHEA",[M]DIE(N-1),"") From ATEXTRA
 Else
  INTIT = ""
 Endif
 Gosub INTIT_CCE
Next
# masquage des colonnes
INTIT=""
FMT = "-K:10X"
For N=[L]NBRDIE+1 To dim([M]DIE)
 Gosub INTIT_CCE
Next
Return

$INTIT_CCE
If INTIT=""
 For L=0 To [M]NBRDSP-1
  Assign "[M:DSP1]CCE"+num$(N)+"("+num$(L)+")" With ''
 Next
Endif
If !GIMPORT Then
  Case N
   When 1  : Titcol [M]NBRDSP INTIT For CCE1
   When 2  : Titcol [M]NBRDSP INTIT For CCE2
   When 3  : Titcol [M]NBRDSP INTIT For CCE3
   When 4  : Titcol [M]NBRDSP INTIT For CCE4
   When 5  : Titcol [M]NBRDSP INTIT For CCE5
   When 6  : Titcol [M]NBRDSP INTIT For CCE6
   When 7  : Titcol [M]NBRDSP INTIT For CCE7
   When 8  : Titcol [M]NBRDSP INTIT For CCE8
   When 9  : Titcol [M]NBRDSP INTIT For CCE9
   When 10 : Titcol [M]NBRDSP INTIT For CCE10
   When 11 : Titcol [M]NBRDSP INTIT For CCE11
   When 12 : Titcol [M]NBRDSP INTIT For CCE12
   When 13 : Titcol [M]NBRDSP INTIT For CCE13
   When 14 : Titcol [M]NBRDSP INTIT For CCE14
   When 15 : Titcol [M]NBRDSP INTIT For CCE15
   When 16 : Titcol [M]NBRDSP INTIT For CCE16
   When 17 : Titcol [M]NBRDSP INTIT For CCE17
   When 18 : Titcol [M]NBRDSP INTIT For CCE18
   When 19 : Titcol [M]NBRDSP INTIT For CCE19
   When 20 : Titcol [M]NBRDSP INTIT For CCE20
  Endcase
Endif
If FMT<>"" : Assign "[M:DSP1]FMTCCE"+num$(N) With FMT : Endif
Return


$VERIF_CRE
Gosub VERIF
If !OK : Return : Endif
Gosub VERIF_COEF
If !OK : Return : Endif
Gosub COMPAT
If !OK : Return : Endif
Return

$VERIF_MOD
Gosub VERIF
If !OK : Return : Endif
Gosub VERIF_COEF
If !OK : Return : Endif
Gosub COMPAT
If !OK : Return : Endif
Return

$VERIF
For NOLI=0 To [M]NBRDSP-1
 X = 0
 For AXE=1 To [M]NBRDIE
  If evalue("[M]CCE"+num$(AXE)+"("+num$(NOLI)+")")<>"" : X+=1 : Endif
 Next
 If X=0
  ## Ligne X : Vous devez définir au moins une section par ligne
  OK = 0 : GMESSAGE = mess(3,61,1)-num$(NOLI+1)-":"-mess(88,104,1) : Break
 Endif
Next
If !OK : Return : Endif
Return


$VERIF_COEF
If [M]NBRDIE=0
 # Vous devez définir au moins un axe
 OK = 0 : GMESSAGE = mess(95,104,1)
 SUIZON   = "NBRDIE"
Endif
Return

# Vérification de la compatibilité entre site lié à la répartition et les sites liés aux sections
$COMPAT
If [M]FCY="" : Return : Endif
For J=0 To [M]NBRDSP-1
 For I=0 To [M]NBRDIE-1
  Call LECTURE("CCE",evalue("CCE"+num$(I+1)+"("+num$(J)+")"),[M]DIE(I)) From CONTOBJ
  Call COMPAT([M]FCY,[F:CCE]FCY,evalue("CCE"+num$(I+1)+"("+num$(J)+")")) From CFYSUB
  If mkstat : OK = 0 : Break 2 : Endif
 Next
Next
If !OK : Return : Endif
Return

$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$MODIF
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("CADSP","DESTRA",CLECUR1,"","CADSP","DESTRA",[M:DSP1]DSP,"") From ATEXTRA
 Call DUPTEXTRA("CADSP","SHOTRA",CLECUR1,"","CADSP","SHOTRA",[M:DSP1]DSP,"") From ATEXTRA
Endif
Call MAJTEXTRA([M:DSP1]DESTRA,"CADSP","DESTRA",[M:DSP1]DSP,"") From ATEXTRA
Call MAJTEXTRA([M:DSP1]SHOTRA,"CADSP","SHOTRA",[M:DSP1]DSP,"") From ATEXTRA
Return

$AP_CHANGE
Call CHGTEXTRA("CADSP","DESTRA",OCODE,"",NCODE,"") From ATEXTRA
Call CHGTEXTRA("CADSP","SHOTRA",OCODE,"",NCODE,"") From ATEXTRA
Return

$ANNULE
Call SUPTEXTRA("CADSP","DESTRA",[M:DSP1]DSP,"") From ATEXTRA
Call SUPTEXTRA("CADSP","SHOTRA",[M:DSP1]DSP,"") From ATEXTRA
Return


##################################################################################
## Etiquette du masque DSP1
##################################################################################
Subprog AM_DIE(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]DIE) From OBJDIV
If mkstat : End : Endif
If [M]ODIE<>""
 Case nolign
  When 1  : Raz [M]CCE1
  When 2  : Raz [M]CCE2
  When 3  : Raz [M]CCE3
  When 4  : Raz [M]CCE4
  When 5  : Raz [M]CCE5
  When 6  : Raz [M]CCE6
  When 7  : Raz [M]CCE7
  When 8  : Raz [M]CCE8
  When 9  : Raz [M]CCE9
  When 10 : Raz [M]CCE10
  When 11 : Raz [M]CCE11
  When 12 : Raz [M]CCE12
  When 13 : Raz [M]CCE13
  When 14 : Raz [M]CCE14
  When 15 : Raz [M]CCE15
  When 16 : Raz [M]CCE16
  When 17 : Raz [M]CCE17
  When 18 : Raz [M]CCE18
  When 19 : Raz [M]CCE19
  When 20 : Raz [M]CCE20
 Endcase
Endif
End

Subprog AVANT_NBRDIE
[M]ODIE = [M]DIE(nolign-1)
End

Subprog APRES_NBRDIE
Local Integer NBRDIE, I, J
[L]NBRDIE=[M]NBRDIE
If status=65 # annulation de ligne
 For J=nolign To [M]NBRDIE-1
  For I=0 To [M]NBRDSP-1
   Assign "CCE"+num$(J)+"("+num$(I)+")" With evalue("CCE"+num$(J+1)+"("+num$(I)+")")
  Next
 Next
 [L]NBRDIE=[M]NBRDIE-1
 Gosub AFFDIE
 Affzo
Elsif find(status,1,71) # ajout/insertion ou modif de ligne
 If [M]ODIE='' # ajout/insertion de ligne
  For J=[M]NBRDIE To nolign Step -1
   For I=0 To [M]NBRDSP-1
    Assign "CCE"+num$(J+1)+"("+num$(I)+")" With evalue("CCE"+num$(J)+"("+num$(I)+")")
   Next
  Next
  # Effacer la colonne ou insertion il y a
  For I=0 To [M]NBRDSP-1
   Assign "CCE"+num$(nolign)+"("+num$(I)+")" With ""
  Next
  If nolign>[M]NBRDIE
   [L]NBRDIE=[M]NBRDIE+1
  Else
   [L]NBRDIE=[M]NBRDIE
  Endif
  Gosub AFFDIE
  zoncou = "NBRDSP"
  Gosub CHG_FMT From W1DSP1
 Else # modif de ligne
  [L]NBRDIE=[M]NBRDIE
  Gosub AFFDIE
 Endif
 Affzo
Endif
End

$AFFDIE
Local Char INTIT(250)
# affichage des colonnes
For N=1 To [L]NBRDIE
 # lecture du format
 If status=65 and N>=nolign # annulation d'une ligne
  Call LECTEXTRA(INTIT,"GDIE","COLHEA",[M]DIE(N),"") From ATEXTRA
  Read [DIE]DIE0=[M]DIE(N)
 Elsif (status=71 or status=73) and N>=nolign # ajout/insertion d'une ligne
  If N-1>=0 #and N<>nolign
   Call LECTEXTRA(INTIT,"GDIE","COLHEA",[M]DIE(N-1),"") From ATEXTRA
  Else
   INTIT=""
  Endif
  Read [DIE]DIE0=[M]DIE(N-1)
 Else
  Call LECTEXTRA(INTIT,"GDIE","COLHEA",[M]DIE(N-1),"") From ATEXTRA
  Read [DIE]DIE0=[M]DIE(N-1)
 Endif
 FMT = "K:"+[DIE]CCEFMT
 Gosub INTIT_CCE
Next
# masquage des colonnes
INTIT=""
FMT = "-K:10X"
For N=[L]NBRDIE+1 To dim([M]DIE)
 Gosub INTIT_CCE
Next
Return

Subprog B1_NBRDIE
Local Integer NBRDIE
Call DIELOAD([M]FCY) From CPTBOUT
[L]NBRDIE=[M]NBRDIE
Gosub AFFDIE
zoncou = "NBRDSP"
Gosub CHG_FMT From W1DSP1
Affzo
End

