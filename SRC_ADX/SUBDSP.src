#JOJAC - 2016-10-28 - START
#JASMI - 2016-05-31 - REQ 114309 - START
# Appeler depuis les autres gestions
#########################################
#FQ92876-US2582- called by CTRLDSP from TRTHRCPT
#**
#* Contrôle du code répartition analytique
#* Paramètres à passer au sous-programme :
#* @param  VALEUR   : Code répartition à contrôler
#* @param  FCY      : Site financier de la société ou site comptable
#* @param  DAT      : Date
#*!
Subprog CONTDSP(VALEUR,FCY,DAT)
Variable Char    VALEUR
Value    Char    FCY
Value    Date    DAT
If VALEUR = "" : End : Endif
Call LECTURE("DSP",VALEUR,"1") From CONTOBJ

If fstat
 # Répartition inexistante
 GMESSAGE = VALEUR-mess(37,106,1)
 mkstat = 2 : End
Endif
Call VERIF([F:DSP]FCY,[L]FCY,VALEUR) From CFYSUB
If mkstat : End : Endif
Call CTLVLYDAT([L]DAT,[F:DSP]VLYSTR,[F:DSP]VLYEND) From CPTSUB
If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
Call CONTEXE([F:DSP]ACS) From CPTSUB
If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
End
#JASMI - 2016-05-31 - REQ 114309 - END
#JOJAC - 2016-10-28 - END

$CONTLIN
Local Integer X
X=0
If VALEUR="" & AXE=[M]NBRDIE
 For I=1 To [M]NBRDIE
  If I<>AXE & evalue("[M]CCE"+num$(I)+"("+num$(nolign-1)+")")<>"" : X+=1 : Endif
 Next
 If X=0
  ## Vous devez définir au moins une section par ligne
  GMESSAGE = mess(88,104,1)
  mkstat = 2 : Return
 Endif
Endif
Return

$CONTVLYCCE
Local Integer OK
If VALEUR="" : End : Endif
Call LECTURE("CCE",VALEUR,[M:DSP1]DIE(AXE-1)) From CONTOBJ
 ## Dates validité
If [M]VLYSTR<>[0/0/0]
 If [F:CCE]VLYEND<>[0/0/0] & [F:CCE]VLYEND<[M]VLYSTR
& | [F:CCE]VLYSTR<>[0/0/0] & [F:CCE]VLYSTR>[M]VLYEND
  # Section inactive
  GMESSAGE = mess(7,103,1)
  mkstat=2 : Return
 Elsif [CCE]VLYSTR<>[0/0/0] & [CCE]VLYSTR>[M]VLYSTR
&  | [CCE]VLYEND<>[0/0/0] & [CCE]VLYEND<[M]VLYEND
  # Si la section n'est pas active sur la totalité de l'année, on met un message
  # d'avertissement
  # Section non active sur la totalité de l'année
  OK = 2 : Call AVERTIR(VALEUR-":"-mess(150,105,1),OK) From GESECRAN
  If OK<>2 : mkstat = 2 : Return : Endif
 Endif
Endif
If [F:CCE]IPT<>2
 # Section non imputable
 OK = 2 : Call AVERTIR(VALEUR-":"-mess(24,106,1),OK) From GESECRAN
 If OK<>2 : mkstat = 2 : Return : Endif
Endif
Return

