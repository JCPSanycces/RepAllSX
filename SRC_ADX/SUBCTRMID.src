#JASMI - 2016-06-06 - REQ 114309 - START
##JOJAC - 2016-06-02 - REQ114309 US215 - START
#Call DISPLAY_HIDE() From SUBCTRLEG
##JOJAC - 2016-06-02 - REQ114309 US215 - END
#JASMI - 2016-06-06 - REQ 114309 - END

$OUVRE
If clalev([F:CTRMID]) = 0 : Local File EMPLOCTRMID    [CTRMID]         : Endif
Return

$FILTRE
If clalev([F:CTRMID]) = 0 : Local File EMPLOCTRMID    [CTRMID]         : Endif

#JOJAC - 2016-06-02 - REQ114309 US215 - START
#If [F:CTR]REFNUM <> [F:CTRMID]REFNUM or [F:CTR]CTRNUM <> [F:CTRMID]CTRNUM or [F:CTR]CTRDAT <> [F:CTRMID]CTRDAT
If [F:HRCTR]REFNUM <> [F:CTRMID]REFNUM or [F:HRCTR]CTRNUM <> [F:CTRMID]CTRNUM or [F:HRCTR]CTRDAT <> [F:CTRMID]CTRDAT
#JOJAC - 2016-06-02 - REQ114309 US215 - END
  If dim([M]CTRNUM)>0 & dim([M]REFNUM)>0 & dim([M]CTRDAT)>0 Then
    Read [CTRMID]CTRMID0 = [M]REFNUM; [M]CTRNUM; [M]CTRDAT
  Endif
Endif
Return

$LIENS
Read [CTRMID]CTRMID0 = [M:CTR0]REFNUM; [M:CTR0]CTRNUM; [M:CTR0]CTRDAT
If !fstat
  [M:CTR1] = [F:CTRMID]
  [M:CTR8] = [F:CTRMID] #FRLAA 2015-10-30 - Requirement 105483 US 4077
Endif

#FRLAA 2015-07-22 - Requirement 109427 US 3712 - START
For nolign = 1 To dim([M:EMP3]NBRHAB)
  If [M:EMP3]CAT(nolign-1) <> 1
    Diszo [M:EMP3]PMTTYP(nolign-1)
  Else
    Affzo [M:EMP3]PMTTYP(nolign-1)
  Endif
Next
#FRLAA 2015-07-22 - Requirement 109427 US 3712 - END

Return

#FRLAA 2015-06-02 - Requirement 105483 US 3675 - START
$VERIF_MOD
$VERIF_CRE
Return
#FRLAA 2015-06-02 - Requirement 105483 US 3675 - END

$MODIF
$CREATION

Delete [CTRMID] Where CTRNUM = [M:CTR0]CTRNUM & REFNUM = [M:CTR0]REFNUM & CTRDAT = [M:CTR0]CTRDAT
  If fstat = 1
    GOK = -1
    GLOCK = "$EMPLOCTRMID" - [M:CTR0]CTRNUM - [M:CTR0]REFNUM - [M:CTR0]CTRDAT
    Return
  Elsif fstat>5
    GOK = 0
    Call RSTA("CTRMID", [M:CTR0]REFNUM - [M:CTR0]CTRNUM - [M:CTR0]CTRDAT) From GLOCK
    Return
  Endif
  [F:CTRMID] = [M:CTR0]
  [F:CTRMID] = [M:CTR1]
  [F:CTRMID] = [M:CTR8] #FRLAA 2015-10-30 - Requirement 105483 US 4077
  Write [CTRMID]
  If fstat
    GOK = 0 : Return
  Endif

Return

$ANNULE

Delete [F:CTRMID]  Where [F:CTRMID]REFNUM = [M:CTR0]REFNUM
&                         & [F:CTRMID]CTRNUM = [M:CTR0]CTRNUM
&                         & [F:CTRMID]CTRDAT = [M:CTR0]CTRDAT

If fstat : Call FSTA("CTRMID") From GLOCK  : Endif
Return



