$ACTION
If func AFNC.ACTIV("KMIEA")>0 Then
  Case ACTION
   When "OUVRE"         : Gosub OUVRE
   When "LIENS"         : Gosub LIENS
   When "MODIF"         : Gosub MODIF
   When "CREATION"      : Gosub CREATION
   When "FILTRE"        : Gosub FILTRE
   When "ANNULE"        : Gosub ANNULE
   When "STYLE"         : Gosub STYLE  #FRLAA 2015-10-30 - Requirement 105483 US 4077
   When "OUVRE_BOITE"   : Gosub OUVRE_BOITE #FRLAA 2015-07-10 - Requirement 109427 US 3712
   #FRLAA 2015-06-02 - Requirement 105483 US 3675 - START
   When "VERIF_CRE"     : Gosub VERIF_CRE
   When "VERIF_MOD"     : Gosub VERIF_MOD
   #FRLAA 2015-06-02 - Requirement 105483 US 3675 - END
  Endcase
Endif
Return

