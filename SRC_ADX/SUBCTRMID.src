Subprog AM_JOBPOT(VALEUR)
Variable Char    VALEUR()
If clalev([F:JOT])=0 : Local File JOBTYP  [JOT] : Endif
Read [F:JOT]JOT0 = VALEUR
  If !fstat
#JOJAC - START
#[M:CTR1]JOB = [F:JOT]DES
 [M:CTR1]JOB = [F:JOT]COD
#JOJAC - END
   [M:CTR1]JOB = VALEUR
    Affzo [M:CTR1]JOB
  Endif
End



#FRLAA 2015-06-02 - Requirement 105483 US 3675 - START
Subprog C_ENDTRY(VALEUR)
Variable Date     VALEUR
Local Integer NMONTH
#JASMI - 2016-06-02 - REQ 114309 - START
#If !func AFNC.ACTIV("KAE") : End : Endif #UAE
If !func DIVPAYE.IS_KAE_LEG(GCURLEG) : End : Endif #UAE
#JASMI - 2016-06-02 - REQ 114309 - END
If VALEUR <> [00/00/00]
  If func DIVPAYE.EXISTE_KXX("SAFUNCTIONS")
    NMONTH = func SAFUNCTIONS.CALDATMM(VALEUR,[M:CTR0]CTRDAT)
    If NMONTH > 6
      GMESSAGE = mess(00017,11738,1) : mkstat = 2 : End
    Elsif NMONTH = 6
      If day(VALEUR) > day([M:CTR0]CTRDAT)
        GMESSAGE = mess(00017,11738,1) : mkstat = 2 : End
      Endif
    Endif
  Endif
Endif
End


Subprog C_ENDTRY2(VALEUR)
Variable Date     VALEUR
Local Integer NMONTH
#JASMI - 2016-06-02 - REQ 114309 - START
#If !func AFNC.ACTIV("KAE") : End : Endif #UAE
If !func DIVPAYE.IS_KAE_LEG(GCURLEG) : End : Endif #UAE
#JASMI - 2016-06-02 - REQ 114309 - END
If VALEUR <> [00/00/00]
  If func DIVPAYE.EXISTE_KXX("SAFUNCTIONS")
    NMONTH = func SAFUNCTIONS.CALDATMM(VALEUR,[M:CTR1]ENDTRY)
    If NMONTH >= 6
      GMESSAGE = mess(00017,11738,1) : mkstat = 2 : End
    Endif
#    Elsif NMONTH = 6
#      If day(VALEUR) > day([M:CTR1]ENDTRY)
#        GMESSAGE = mess(00017,11738,1) : mkstat = 2 : End
#       Endif
#    Endif
  Endif
Endif
End

Subprog AM_EMPCFM(VALEUR)
Variable Integer VALEUR
#JASMI - 2016-06-02 - REQ 114309 - START
#If !func AFNC.ACTIV("KAE") : End : Endif #UAE
If !func DIVPAYE.IS_KAE_LEG(GCURLEG) : End : Endif #UAE
#JASMI - 2016-06-02 - REQ 114309 - END
If VALEUR = 2
  If [M:CTR1]ENDTRY2 <> [00/00/00]
    [M:CTR1]DATANC = [M:CTR1]ENDTRY2 + 1
  Elsif [M:CTR1]ENDTRY <> [00/00/00]
    [M:CTR1]DATANC = [M:CTR1]ENDTRY + 1
  Elsif [M:CTR0]CTRDAT <> [00/00/00]
    [M:CTR1]DATANC = [M:CTR0]CTRDAT
  Endif
Else
  Raz [M:CTR1]DATANC
Endif
Affzo [M:CTR1]DATANC
End

Subprog C_ENDCON(VALEUR)
Variable Date     VALEUR
Local Integer NYEAR
#JASMI - 2016-06-02 - REQ 114309 - START
#If !func AFNC.ACTIV("KAE") : End : Endif #UAE
If !func DIVPAYE.IS_KAE_LEG(GCURLEG) : End : Endif #UAE
#JASMI - 2016-06-02 - REQ 114309 - END
If [M:CTR1]CTRTYP = 1
  If VALEUR <> [00/00/00]
    If func DIVPAYE.EXISTE_KXX("SAFUNCTIONS")
      NYEAR = func SAFUNCTIONS.CALDATYY(VALEUR,[M:CTR0]CTRDAT)
      If NYEAR > 4
        GMESSAGE = mess(00011,11738,1) : mkstat = 2 : End
      Elsif NYEAR = 4
        If month(VALEUR) > month([M:CTR0]CTRDAT)
          GMESSAGE = mess(00011,11738,1) : mkstat = 2 : End
        Elsif month(VALEUR) = month([M:CTR0]CTRDAT)
          If day(VALEUR) > day([M:CTR0]CTRDAT)
            GMESSAGE = mess(00011,11738,1) : mkstat = 2 : End
          Endif
        Endif
      Endif
    Endif
  Endif
Endif
End

