#<AdxTL>@(#)10.0.0.0 $Revision$
Local Char PARAM(30)(1..2) , VALEUR(10)
#PARAM(1) = "SUP_*DAT*"
#PARAM(1) = "*DAT*"
Call SAISIE_CHAR(VALEUR,PARAM,"ADOVAL","ADOVAL","XWADOVAL") From GSAISIE
End

#---------------------------------------------------------------------------
$ACTION
 Case ACTION
  When "DEBUT"       : Gosub DEBUT
  When "APRES_MODIF" : Gosub APRES_MODIF
  When "ENR"         : Gosub ENREGISTRE
  When "ABA"         : Gosub ABANDON
  When "END"         : Gosub FIN
  When "SEL_TABLE"   : Gosub SEL_TABLE
  When Default
 Endcase
Return

#---------------------------------------------------------------------------
$DEBUT
Return

#---------------------------------------------------------------------------
$APRES_MODIF
Return

#---------------------------------------------------------------------------
$ENREGISTRE

 If dim(GUPDPARAM)>0
  If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
  If !clalev([F:CNX]) : Local File CONTEXT [CNX] : Endif
  GOK=1
  Local Integer I_PARAM, RCOD
  For I_PARAM=1 To dim(GUPDPARAM)
   If GUPDPARAM(I_PARAM)
    If [M:ADW1]CMP<>""
     Filter [CPY] Where CPY=[M:ADW1]CMP
    Else
     Filter [CPY]
    Endif
    For [F:CPY]
     Filter [CNX] Where CPY=[F:CPY]CPY
     For [F:CNX]
      If GPARLIST(I_PARAM) = "DEROENCOUR"
       If [F:CNX]CNX = G300CPFI
         Call ADD_UPD_WAI_CNX([F:CPY]CPY, [F:CNX]CNX, "ADP", GPARLIST(I_PARAM), "", "", RCOD) From UPDWAICNX
       Endif
      Else
       Call ADD_UPD_WAI_CNX([F:CPY]CPY, [F:CNX]CNX, "ADP", GPARLIST(I_PARAM), "", "", RCOD) From UPDWAICNX
      Endif
      If RCOD
       Local Integer I_PAR : I_PAR=find(GPARLIST(I_PARAM),[M]PARAM)
       [M]VALINT(I_PAR-1)=GUPDPARVAL(I_PARAM)
       If [M]TYP(I_PAR-1)="M"
        [M]VALEUR(I_PAR-1)=mess(val([M]VALINT(I_PAR-1)),[M]NOLIB(I_PAR-1),1)
       Else
        [M]VALEUR(I_PAR-1)=[M]VALINT(I_PAR-1)
       Endif
       Affzo [M]VALEUR(I_PAR-1)
       GOK=0
       Errbox GPARLIST(I_PARAM)-"/"-"ADOVALB-$ENREGISTRE =>"-num$(RCOD)
      Endif
     Next
    Next
   Endif
  Next I_PARAM
  Filter [CPY]
  Filter [CNX]
  Kill GUPDPARAM
 Endif

#90370 - Cash VAT
 If func AFNC.ACTIV("KSP")
   If dim(GCSHVATSPA)>0
     If GCSHVATSPA=1 and [M:ADW1]CMP<>""
       I=find("SPACSHVAT",[M:ADW1]PARAM())
       J=find("SPACSHDAT",[M:ADW1]PARAM())
       Call CSHVATSPA([M:ADW1]CMP,[M:ADW1]VALEUR(I-1),[M:ADW1]VALEUR(J-1)) From DCLVATSPA
     Endif
     Kill GCSHVATSPA
   Endif
 Endif
#90370 - Cash VAT
#
# Issue X3-25003 - 2017-05-12 by SR : Valorisation des réceptions
If dim(GUPDPARAMB)>0
  GOK=1
  Local Integer I_PARAM, RCOD
  For I_PARAM=1 To dim(GUPDPARAMB)
   If GUPDPARAMB(I_PARAM)
      If GPARLIST(I_PARAM) = "PRIFLG"
        Raz RCOD
        Call UPD_PSVSTRDAT([M:ADW1]CMP,[M:ADW1]FCY,val(GUPDPARVALB(I_PARAM)),DEL,RCOD) From PURTRTPARAM
        If RCOD
         Local Integer I_PAR : I_PAR=find(GPARLIST(I_PARAM),[M]PARAM)
         [M]VALINT(I_PAR-1)=GUPDPARVALB(I_PARAM)
         If [M]TYP(I_PAR-1)="M"
          [M]VALEUR(I_PAR-1)=mess(val([M]VALINT(I_PAR-1)),[M]NOLIB(I_PAR-1),1)
         Else
          [M]VALEUR(I_PAR-1)=[M]VALINT(I_PAR-1)
         Endif
         Affzo [M]VALEUR(I_PAR-1)
         GOK=0
         Errbox GPARLIST(I_PARAM)-"/"-"ADOVALB-$ENREGISTRE =>"-num$(RCOD)
        Endif
      Endif
   Endif
  Next
  Kill GUPDPARAMB
 Endif
# End issue X3-25003

 If !GOK
  Gosub TR1 From ADOVAL
 Endif

Return

#---------------------------------------------------------------------------
$ABANDON
 If dim(GUPDPARAM)>0  : Kill GUPDPARAM  : Endif
 If dim(GUPDPARVAL)>0 : Kill GUPDPARVAL : Endif
 If dim(GCSHVATSPA)>0 : Kill GCSHVATSPA : Endif   #90370 - Cash VAT
 # Issue X3-25003 - 2017-05-12 by SR : Valorisation des réceptions
 If dim(GUPDPARAMB)>0  : Kill GUPDPARAMB  : Endif
 If dim(GUPDPARVALB)>0 : Kill GUPDPARVALB : Endif
 # End issue X3-25003
Return

#---------------------------------------------------------------------------
$FIN
 If dim(GUPDPARAM)>0  : Kill GUPDPARAM : Endif
 If dim(GUPDPARVAL)>0 : Kill GUPDPARVAL : Endif
 If dim(GCSHVATSPA)>0 : Kill GCSHVATSPA : Endif   #90370 - Cash VAT
 # Issue X3-25003 - 2017-05-12 by SR : Valorisation des réceptions
 If dim(GUPDPARAMB)>0  : Kill GUPDPARAM   : Endif
 If dim(GUPDPARVALB)>0 : Kill GUPDPARVALB : Endif
Return

#---------------------------------------------------------------------------
$AB_TR1
Rollback
Return

#---------------------------------------------------------------------------
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Gosub TR1 From ADOVAL : Endif

#---------------------------------------------------------------------------
$SEL_TABLE
Case OBJET
 When "PJO"  : Gosub RAZPAR : Gosub SELJOU From SELJOU
 When "PGT"  : Gosub RAZPAR : Gosub SELGTE From SELGTE
 When "PCD"  : Gosub RAZPAR : Gosub SELCDA From SELCDA
 When "PTP"  : Gosub RAZPAR : Gosub SELTPY From SELTPY
 When "PTS2" : Gosub SELTSV From SUBTSV :#--JDE 71937 TSV
 When "PTS"  : Gosub SELTSD From SUBTSD :#--CPO 75115 Nouveau champ SDHTYP
 When "TVBW" : Gosub SELTVB From SUBTVB :# 71937 : Multilégislation : Table régime de taxe
 When "TVTW" : Gosub SELTVT From SUBTVT :#--CPO 71937 VAT
 When "TPVB" : Gosub SELTPVLEG From SUBTPV :#--FGR 02/01/2013 : X3SUIVI71937
 When "TSQ2" : Gosub SELTSQ From SUBTSQ # FGR 19/02/2015 : X3SUIVI104383
 When "TSO2" : Gosub SELTSOLEG2 From SUBTSO # FGR 20/02/2015 : X3SUIVI104383
 When "INVCND2" : Gosub SELINVCND From SUBINVCND # Issue 107888 - 2016-09-09 by CPO : US150 Free products not deliverable invoicing
 When Default
  # Updating GSOCIETE,GCURLEG,GCURFCY to trigger controls on the group of sites/companies and on legislation in the CONTOBJ process
  If dim([M]FCY)>0
   If [M]FCY<>""
    Call GETSOC([M]FCY) From DEVSUB
   Elsif [M]CMP<>""
    If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
    Call LEC_CPY([M]CMP) From CPTLEC
    Call GETSOC([F:CPY]MAIFCY) From DEVSUB
    Raz GCURFCY
   Elsif dim([M]LEG)>0
    GCURLEG = [M]LEG
   Endif
  Endif
Endcase
Return

$RAZPAR
If dim(PARAM)>0 : Raz PARAM : Endif
Return

