########################################
Subprog B2_NBLIG
Local Integer WAUTO, WMATCLENBR
Local    Integer  MEMSTA : MEMSTA = [F:MFM]ALLSTA # mémo statut
Gosub DECL_VAR From SUBMTKC

Call DEBTRANS From GLOCK
Trbegin [MFG]
Readlock[F:MFM]MFM0 = [M:MFS0]MFGNUM;[M:MFS3]MFGLIN(nolign-1);[M:MFS3]BOMSEQ(nolign-1);
&                                 [M:MFS3]ITMREF(nolign-1)
If fstat=1  GOK=-1 : GLOCK="$MFGMAT"-[M:MFS3]ITMREF(nolign-1) : Goto TR_ROLL
Elsif fstat GOK=0  : Call RSTA("MFM",[M:MFS3]ITMREF(nolign-1)) From GLOCK : Goto TR_ROLL
Endif
Raz WMATCLENBR
WAUTO = 0
If [M:MFS3]MATSTA(nolign-1) < 3
    Gosub SOLDE_MAT From FUNMFGS
Else
    Gosub DESOLDE_MAT From FUNMFGS
Endif
If GOK < 1 : Goto TR_ROLL : Endif
If [F:MFM]MFGLIN <> 0
    Read [F:MFI]MFI0 = [F:MFM]MFGNUM;[F:MFM]MFGLIN
    If fstat : GOK=0: Call RSTA("MFI",num$([F:MFM]MFGLIN)) From GLOCK : Goto TR_ROLL : Endif  # llc 05.02 cohérence
Else
    Filter [F:MFI] Where MFGNUM = [F:MFM]MFGNUM
    Read [F:MFI]MFI0 First
    If fstat : GOK=0: Call RSTA("MFI",num$([F:MFM]MFGLIN)) From GLOCK : Goto TR_ROLL : Endif  # llc 05.02 cohérence
    Filter [F:MFI]
Endif
If [F:MFM]MATSTA = 3
    Call UPDATE_MFX("A", [F:MFI]PJT,[F:MFI]BOMALT, 0) From MFGLIBM
Else
    Raz [F:MFM]WIPNUM
    Call UPDATE_MFX("M", [F:MFI]PJT,[F:MFI]BOMALT, 0) From MFGLIBM
Endif
Rewrite [F:MFM]
If fstat
   GOK = 0 : Call FSTA("MFM") From GLOCK : Goto TR_ROLL
Endif
#----------------------- Maj  Entête OF ------------------------------------#
Readlock [F:MFG]MFG0 = [F:MFM]MFGNUM
If fstat=1  GOK=-1 : GLOCK="$MFGHEAD"-num$([M:MFS0]MFGNUM) : Goto TR_ROLL
Elsif fstat GOK=0  : Call RSTA("MFG",num$([M:MFS0]MFGNUM)) From GLOCK :Goto TR_ROLL
Endif
[F:MFG]MATCLENBR += WMATCLENBR
If [F:MFG]OPECLENBR = [F:MFG]OPELINNBR &
&  [F:MFG]ITMCLENBR = [F:MFG]ITMLINNBR &
&  [F:MFG]MATCLENBR = [F:MFG]MATLINNBR : [F:MFG]MFGTRKFLG = 5
Else                                   : [F:MFG]MFGTRKFLG = 4
Endif
If [F:MFM]MATSTA < 3 : Gosub MAJMFG : Endif
Rewrite [F:MFG]
If fstat
   GOK = 0 : Call FSTA("MFG") From GLOCK : Goto TR_ROLL
Else Commit
     [M:MFS1]ALLSTA           = [F:MFG]ALLSTA
     [M:MFS1]MFGTRKFLG        = [F:MFG]MFGTRKFLG
     [M:MFS3]MATSTA(nolign-1) = [F:MFM]MATSTA
     # Issue 85198 - 2012-10-25 by CCC
     [M:MFS3]XMATSTA(nolign-1) = mess([M:MFS3]MATSTA(nolign-1),363,1)
     [M:MFS3]ALLQTY(nolign-1) = [F:MFM]ALLQTY
     [M:MFS3]SHTQTY(nolign-1) = [F:MFM]SHTQTY
     Affzo [M:MFS1]MFGTRKFLG, ALLSTA
     Affzo [M:MFS3]
     mkstat = 4
     Goto FIN
Endif

$TR_ROLL
Rollback

$FIN
End

########################################
Subprog IB_NBLIG
#GBOUT2 = "Solde" "Annulation solde"
Raz GBOUT1, GBOUT2
# Issue 104610 - 2015-02-03 by JUSYN : Additionally GESMFG allowed to close.
# If GFONC1 <> "FUNMCLOSE" : End : Endif
If GFONC1 <> "FUNMCLOSE" & GFONC1 <> "GESMFG" : End : Endif

If [M:MFS3]CPNTYP(nolign-1) = 5  : End : Endif
# sr 11.04
Read [F:MFG]MFG0 = [M:MFS0]MFGNUM
If fstat : Raz [F:MFG] : End : Endif
If [F:MFG]MFGTRKFLG < 4  : End : Endif
If [F:MFG]MFGSTA    = 4  : End : Endif
If [M:MFS3]MFMITMREF(nolign-1) = "" : End : Endif
# Issue 104610 - 2015-02-03 by JUSYN : Activate Buttons only with closing action.
If GACTION = "TRTMCLOSE"
    If    [M:MFS3]MATSTA(nolign-1) < 3 : GBOUT2 = mess(012,198,1)
    Elsif [M:MFS3]MATSTA(nolign-1) = 3 : GBOUT2 = mess(400,198,1)
    Endif
Endif
End

#-----------------------------------------------------------------------#
# Mise à jour de l'entete OF                                            #
#-----------------------------------------------------------------------#
$MAJMFG
Local Integer XTOT
Local Integer I
#
Case [F:MFM]ALLSTA    # évaluation nouveaux totaux en fonction de l'évolution du statut
    When 1:  Case MEMSTA
                When 2:    [F:MFG]OVRALLNBR -= 1
                           [F:MFG]SHTMATNBR -= 1
                When 3:    [F:MFG]OVRALLNBR -= 1
                When 4:    [F:MFG]DETALLNBR -= 1
                           [F:MFG]SHTMATNBR -= 1
                When 5:    [F:MFG]DETALLNBR -= 1
             Endcase
    When 2:  Case MEMSTA
                When 1:    [F:MFG]OVRALLNBR += 1
                           [F:MFG]SHTMATNBR += 1
                When 3:    [F:MFG]SHTMATNBR += 1
             Endcase
    When 3:  Case MEMSTA
                When 1:    [F:MFG]OVRALLNBR += 1
                When 2:    [F:MFG]SHTMATNBR -= 1
             Endcase
    When 4:  Case MEMSTA
                When 1:    [F:MFG]DETALLNBR += 1
                           [F:MFG]SHTMATNBR += 1
                When 2:    [F:MFG]OVRALLNBR -= 1
                           [F:MFG]DETALLNBR += 1
                When 3:    [F:MFG]OVRALLNBR -= 1
                           [F:MFG]DETALLNBR += 1
                           [F:MFG]SHTMATNBR += 1
                When 5:    [F:MFG]SHTMATNBR += 1
             Endcase
    When 5:  Case MEMSTA
                When 1:    [F:MFG]DETALLNBR += 1
                When 2:    [F:MFG]OVRALLNBR -= 1
                           [F:MFG]SHTMATNBR -= 1
                           [F:MFG]DETALLNBR += 1
                When 3:    [F:MFG]OVRALLNBR -= 1
                           [F:MFG]DETALLNBR += 1
                When 4:    [F:MFG]SHTMATNBR -= 1
             Endcase
Endcase
#
Gosub MAJSTATUT
#
Return

#-----------------------------------------------------------------------#
# Recalcul statut allocation                                            #
#-----------------------------------------------------------------------#
$MAJSTATUT
Local Integer XTOT
# nouveau statut allocation (non alloué, partiel, complet)
XTOT = [F:MFG]OVRALLNBR + [F:MFG]DETALLNBR
If (XTOT = 0)
    [F:MFG]ALLSTA = 1
Else
    If (XTOT < [F:MFG]MATLINNBR - [F:MFG]MATCLENBR)          # llc 04.02 14090
        [F:MFG]ALLSTA = 2
    Else
        # sr 07.02 demande 15130  tester >= au lieu de =
        If (XTOT >= [F:MFG]MATLINNBR - [F:MFG]MATCLENBR)      # llc 04.02 14090
            [F:MFG]ALLSTA = 3
        Endif
    Endif
Endif
# si des ruptures existent, statut allocation + 2
If [F:MFG]SHTMATNBR <> 0 : [F:MFG]ALLSTA += 2 : Endif
# si toutes les matières sont soldées, on force le statut à "complet" ...
If [F:MFG]MATCLENBR = [F:MFG]MATLINNBR
    [F:MFG]ALLSTA = 3
Endif
Return
######################################################################################
## Etiquette ajoutée par le superviseur (écran MFS3) 12/11/2004 14:47:26 (SR)
######################################################################################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
If [M:MFS3]MFMITMREF(nolign-1)  = "" & [M:MFS3]CPNTYP(nolign-1) <> 5
   pcolor = GCOUL(3)
Else
   pcolor = GCOUL(0)
Endif

End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran MFS3) 23/06/2010 11:34:12 (CCC)
######################################################################################
Subprog B2_NBCPN
Local Integer LIND

[M:MFS3]AFFFLG([M:MFS3]NUMLIGCPN(nolign-1)-1) = 1
Affzo [M:MFS3]AFFFLG([M:MFS3]NUMLIGCPN(nolign-1)-1)

For I=[M:MFS3]NUMLIGCPN(nolign-1) To [M:MFS3]NBLIG-1
    [M:MFS3]NUMLIG(I)-=1
Next
Affzo [M:MFS3]NUMLIG

Dela nolign-1, 1 [M:MFS3]NBCPN
[M:MFS3]NBCPN -=1
Affzo [M:MFS3]10

End

######################################################################################
Subprog AM_AFFFLG(VALEUR)
Variable Integer VALEUR
Local Integer I
If VALEUR=1
    Dela [M:MFS3]NUMLIG(nolign-1)-1, 1 [M:MFS3]NBCPN
    [M:MFS3]NBCPN -=1
    Affzo [M:MFS3]10
    For I=nolign To [M:MFS3]NBLIG-1
        [M:MFS3]NUMLIG(I)-=1
    Next
Else
    Insa [M:MFS3]NUMLIG(nolign-1)-1, 1 [M:MFS3]NBCPN
    [M:MFS3]MATREF([M:MFS3]NUMLIG(nolign-1)-1)      = [M:MFS3]ITMREF(nolign-1)
    [M:MFS3]STUG([M:MFS3]NUMLIG(nolign-1)-1)        = [M:MFS3]STU(nolign-1)
    [M:MFS3]RETQTYG([M:MFS3]NUMLIG(nolign-1)-1)     = [M:MFS3]RETQTY(nolign-1)
    [M:MFS3]USEQTYG([M:MFS3]NUMLIG(nolign-1)-1)     = [M:MFS3]USEQTY(nolign-1)
    [M:MFS3]NUMLIGCPN([M:MFS3]NUMLIG(nolign-1)-1)   = nolign
    [M:MFS3]NBCPN +=1
    Affzo [M:MFS3]10
    For I=nolign To [M:MFS3]NBLIG-1
        [M:MFS3]NUMLIG(I)+=1
    Next
Endif
Affzo [M:MFS3]NUMLIG
End


