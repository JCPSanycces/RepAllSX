#<AdxTL>@(#)2.0.0.0 $Revision$
## GPROG    = Traitement
## GTYPPROG = 1:Direct  2:O/N   3:Dialogue  4:Autre
## GWINDOW  = Ecran de saisie
## GWINCRIT = Ecran de critères

Local Char PARAM(10)(1..2) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,GWINDOW,GPROG,GWINCRIT,GTYPPROG,GPROGSPE)
End

Subprog TRAITE_CHAR(VALEUR,PARAM,BOITE,PROG,BCRIT,TYPPRG,PROGSPE)
Variable Char    VALEUR
Variable Char    PARAM()(1..)
Value    Char    BOITE
Value    Char    PROG
Value    Char    BCRIT
Value    Integer TYPPRG
Value    Char    PROGSPE
Local Integer TYPARG
TYPARG = 1
Goto TRAITE

Subprog TRAITE_NUM(VALEUR,PARAM,BOITE,PROG,BCRIT,TYPPRG,PROGSPE)
Variable Decimal VALEUR
Variable Char    PARAM()(1..)
Value    Char    BOITE
Value    Char    PROG
Value    Char    BCRIT
Value    Integer TYPPRG
Value    Char    PROGSPE
Local Integer TYPARG
TYPARG = 2
Goto TRAITE

Subprog TRAITE_DAT(VALEUR,PARAM,BOITE,PROG,BCRIT,TYPPRG,PROGSPE)
Variable Date    VALEUR
Variable Char    PARAM()(1..)
Value    Char    BOITE
Value    Char    PROG
Value    Char    BCRIT
Value    Integer TYPPRG
Value    Char    PROGSPE
Local Integer TYPARG
TYPARG = 3
Goto TRAITE

Subprog TRAITE_LIB(VALEUR,PARAM,BOITE,PROG,BCRIT,TYPPRG,PROGSPE)
Variable Integer VALEUR
Variable Char    PARAM()(1..)
Value    Char    BOITE
Value    Char    PROG
Value    Char    BCRIT
Value    Integer TYPPRG
Value    Char    PROGSPE
Local Integer    TYPARG
TYPARG = 4
Goto TRAITE

Subprog TRAITE_BLOB(VALEUR,PARAM,BOITE,PROG,BCRIT,TYPPRG,PROGSPE)
Variable Blbfile VALEUR
Variable Char    PARAM()(1..)
Value    Char    BOITE
Value    Char    PROG
Value    Char    BCRIT
Value    Integer TYPPRG
Value    Char    PROGSPE
Local Integer    TYPARG
TYPARG = 5
Goto TRAITE

Subprog TRAITE_CLOB(VALEUR,PARAM,BOITE,PROG,BCRIT,TYPPRG,PROGSPE)
Variable Clbfile VALEUR
Variable Char    PARAM()(1..)
Value    Char    BOITE
Value    Char    PROG
Value    Char    BCRIT
Value    Integer TYPPRG
Value    Char    PROGSPE
Local Integer    TYPARG
TYPARG = 6
Goto TRAITE

###############################################
$TRAITE
Local Char    ACTION(20) , TIT(200) , TRTWIN(GLONADC)
Local Char    TRTCRIT(GLONADC) , TITCRIT(200) , MSKCRIT(GLONAMK)(0..15) , ABRCRIT(GLONABR)(0..15)
Local Integer OK , SAI , FIN , TRA , TMP , FOK , OUVDIA , PSPE
Local Integer SAVTITCOL , SAVNBMASKOUV
Local Char    SAVBOITE(GLONFEN) , SAVGREP(1) , SAVGGRPFCY(GLONAGF)
Local Char    SAVSOCIETE(GLONCPY) , SAVCURLEG(GLONADI) , SAVCURFCY(GLONFCY)
Local Char    NAVIG(GLONANG)
Local Integer FLNAV

## Vérification des paramètres
Gosub VERIF
If !OK : End : Endif

## Action préliminaire
SAVBOITE   = GBOITE
SAVTITCOL  = GORITITCOL
GERR = 0
FIN  = 0
TMP  = 0
FOK  = 1
OUVDIA = 0
GADIFDAT = [00/00/00] : GADIFTIM = "" : # Pour l'action ADIFERRE
SAVGREP = GREP
SAVGGRPFCY = GGRPFCY
SAVSOCIETE = GSOCIETE
SAVCURLEG  = GCURLEG
SAVCURFCY  = GCURFCY
SAVNBMASKOUV = GNBMASKOUV

If clalev([F:ATX])=0 : Local File ATEXTE   [ATX] : Endif
If clalev([F:AXX])=0 : Local File ATEXTRA  [AXX] : Endif

ACTION = "INIT" : Gosub ACTION
If GERR         : Gosub ERREUR : Endif
If FIN or !FOK  : Goto SORTIE  : Endif

## GH 08/08/05 bug 29793

If GPRODUIT=1 : ## GEODE
 Gosub FILENV From CHGENV
Endif

## Contrôle fenêtre critère

If BCRIT<>"" & !find(TYPPRG,5,6)
 Call NOMTRTWINOPT(BCRIT,TRTCRIT) From MSKDIV
Endif

## Navigation

If NAVIG<>""
 FLNAV = 1
 GPILNAV += 1
 GNAVIG(GPILNAV) = NAVIG
Endif

###############################################
$SAI
ACTION = "AVANT_PAR" : Gosub ACTION
Case TYPPRG
 When 2  : # Oui/non
  OK = 2
  If !GSERVEUR
   Call OUINON(TIT,OK) From GESECRAN
   If OK<>2 : Goto SORTIE : Endif
  Endif
 When 3  : # Dialogue
  If BCRIT<>""
   GBOITE = BCRIT
   Call SETCRIT(BCRIT,TRTCRIT,MSKCRIT,ABRCRIT,TITCRIT) : # Recherche infos écran critère
   If evalue("clalev([M:"+ABRCRIT(1)+"])")=0
    Local Mask =MSKCRIT(1)
    OUVDIA = 1
    ACTION = "INIT_DIA" : Gosub ACTION
   Endif
   ACTION = "TIT_DIA" : Gosub ACTION
   If !GSERVEUR
    OK = 2
    Call DIALWIN(OK,TITCRIT,BCRIT) From GESECRAN
    If OK<>2 : GBOITE = SAVBOITE : Goto SORTIE : Endif
    GSTATUT = GSTAOK
    # Création requête si traitement en différé
    If GADIFDAT<>[0/0/0] & GADIFTIM<>""
     Call REQUETE(GADIFDAT,GADIFTIM,BCRIT) From ADIFFERE
    Endif
   Else
    Call GETPAR(TRTCRIT,ABRCRIT)
   Endif
   GBOITE = SAVBOITE
  Endif
 When 4 : # Fenêtre quelconque
  If BCRIT<>""
   Call SETCRIT(BCRIT,TRTCRIT,MSKCRIT,ABRCRIT,TITCRIT)
   OUVDIA = 0
   # Bug 36678 Il faut que ce soit le GSAISIE qui ouvre les écrans, sinon, on perd les masques par défaut
   If GBATCH
    For I=0 To dim(ABRCRIT)-1
     If ABRCRIT(I)<>"" & evalue("clalev([M:"+ABRCRIT(I)+"])")=0
      Local Mask =MSKCRIT(I)
      OUVDIA = 1
     Endif
    Next I
    If OUVDIA
     ACTION = "INIT_DIA" : Gosub ACTION
    Endif
   Endif
   If !GSERVEUR
    Case type(VALEUR)
     When 3
      Call SAISIE_DAT(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GSAISIE
     When 1,2,4
      Call SAISIE_LIB(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GSAISIE
     When 5,6,7,9
      Call SAISIE_NUM(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GSAISIE
     When 522
      Call SAISIE_BLOB(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GSAISIE
     When 523
      Call SAISIE_CLOB(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GSAISIE
     When Default
      Call SAISIE_CHAR(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GSAISIE
    Endcase
    If GBATCH & GSTATUT<>GSTAESC : GSTATUT = GSTAOK : Endif
    # Création requête si traitement en différé
    If GADIFDAT<>[0/0/0] & GADIFTIM<>"" & GSTATUT=GSTAOK
     Call REQUETE(GADIFDAT,GADIFTIM,BCRIT) From ADIFFERE
    Endif
   Else
    Call GETPAR(TRTCRIT,ABRCRIT)
   Endif
  Endif
 When 5 : # Sélection dans une liste
  If !GSERVEUR
   Case type(VALEUR)
    When 3
     Call S_LIS_DAT(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GACTION
    When 1,2,4
     Call S_LIS_LIB(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GACTION
    When 5,6,7,9
     Call S_LIS_NUM(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GACTION
    When 522
     Call S_LIS_BLOB(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GACTION
    When 523
     Call S_LIS_CLOB(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GACTION
    When Default
     Call S_LIS_CHAR(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GACTION
   Endcase
  Endif
 When 6 : # Sélection dans une table
  If !GSERVEUR
   Case type(VALEUR)
    When 3
     Call S_TAB_DAT(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GACTION
    When 1,2,4
     Call S_TAB_LIB(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GACTION
    When 5,6,7,9
     Call S_TAB_NUM(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GACTION
    When 522
     Call S_TAB_BLOB(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GACTION
    When 523
     Call S_TAB_CLOB(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GACTION
    When Default
     Call S_TAB_CHAR(VALEUR,PARAM,BCRIT,PROG,PROGSPE) From GACTION
   Endcase
  Endif
Endcase

## Vérifs éventuelles

GERR = 0
FIN  = 0
SAI  = 0
FOK  = 1
If GSERVEUR : GSTATUT = GSTAOK : Endif : # En batch on fait comme si on avait répondu OK
If GADIFDAT > [00/00/00] & GADIFTIM > ""
 ACTION = "CONT_BATCH" : Gosub ACTION
Else
 ACTION = "CONTROLE" : Gosub ACTION
Endif
If GERR : Gosub ERREUR : Endif
If FIN  : Goto SORTIE  : Endif
If (SAI or !FOK)
 If !GSERVEUR : Goto  SAI : Else : Goto SORTIE : Endif
Endif
If GADIFDAT > [00/00/00] & GADIFTIM > "" : Goto SORTIE : Endif

## Saisie fenêtre principale

If BOITE<>"" & !GSERVEUR
 Case type(VALEUR)
  When 3
   Call SAISIE_DAT(VALEUR,PARAM,BOITE,PROG,PROGSPE) From GSAISIE
  When 1,2,4
   Call SAISIE_LIB(VALEUR,PARAM,BOITE,PROG,PROGSPE) From GSAISIE
  When 5,6,7,9
   Call SAISIE_NUM(VALEUR,PARAM,BOITE,PROG,PROGSPE) From GSAISIE
  When 522
   Call SAISIE_BLOB(VALEUR,PARAM,BOITE,PROG,PROGSPE) From GSAISIE
  When 523
   Call SAISIE_CLOB(VALEUR,PARAM,BOITE,PROG,PROGSPE) From GSAISIE
  When Default
   Call SAISIE_CHAR(VALEUR,PARAM,BOITE,PROG,PROGSPE) From GSAISIE
 Endcase
Endif

## Copie des écrans de saisie des paramètres dans la trace du serveur batch

If BCRIT<>"" & GSERVEUR & dim(GPARTRABTC)>0 & GPARTRABTC=2
 Call TRACE_MASQUE(MSKCRIT,ABRCRIT,nomap)
Endif

## Exécution proprement dite

FOK = 1
If TMP & !GSERVEUR
 Call TEMPON(TIT) From GESECRAN
Endif
ACTION = "EXEC"  : Gosub ACTION
If TMP & !GSERVEUR
 Call TEMPOFF From GESECRAN
Endif
If GERR : Gosub ERREUR : Endif

If SAI
 If GSERVEUR & !GIMPORT : Goto SORTIE : Else : Goto SAI : Endif
Endif

If FIN or !FOK
 If TRA : Goto TRACE  : Else : Goto SORTIE : Endif
Endif

## Fin

FOK = 1

ACTION = "TERMINE" : Gosub ACTION
If GERR : Gosub ERREUR : Endif

###############################################
$TRACE
If !GSERVEUR
 Case TRA
  When 0 : # rien
  When 8       : Call CONS_TRACE From LECFIC : # Trace "impossible à virer"
  When 9       : Call SUPP_TRACE From LECFIC : # Trace "virée après lecture"
  When Default : Call LEC_TRACE From LECFIC  : # Trace "à garder"
 Endcase
Elsif dim(GTRALIG)>1 and GTRANBR>0
 Call FLUSH_TRACE From GESECRAN
Endif
If FIN                       : Goto SORTIE  : Endif
If (SAI or !FOK) & !GSERVEUR : Goto  SAI    : Endif

###############################################
$SORTIE
ACTION = "SORTIE" : Gosub ACTION
If FLNAV
 GPILNAV -= 1
 GPILNAV = max(GPILNAV,0)
Endif
GREP = SAVGREP
GGRPFCY  = SAVGGRPFCY
GSOCIETE = SAVSOCIETE
GCURLEG  = SAVCURLEG
GCURFCY  = SAVCURFCY
If dim(GNBMASKOUV)>0 and BOITE<>"" and GNBMASKOUV<>SAVNBMASKOUV
 GNBMASKOUV-=1
 GNBMASKOUV=max(0,GNBMASKOUV)
Endif
GORITITCOL = SAVTITCOL

## Fermeture masque critère
If !instr(1,adxpno(1),"EXEFNC") : # C'est qu'on revient au menu
 For I=0 To dim(ABRCRIT)-1
  If ABRCRIT(I)<>"" & evalue("clalev([M:"+ABRCRIT(I)+"])")>0
   Gosub FERME_MASK From =TRTCRIT
   Break
  Endif
 Next I
Endif
End

###############################################
$ACTION
GPE = 0
If dim(PSPE) & PSPE
 Gosub ACTION From =PROGSPE
Endif
If !GPE & dim(PROG)>0 & PROG<>""
 Gosub ACTION From =PROG
Endif
Return

########################################################
$VERIF
OK = 1
PSPE = 0
If PROGSPE<>""
 Call EXISTE_ADX("","",PROGSPE,PSPE) From ORDSYS
Endif
If dim([V]GCHGENV)>0 & GCHGENV & (instr(1,adxpno(2),"EXEFNC") | instr(1,adxpno(2),"GESUSER"))
 If (GFCY="" & GCHGENV) | (GDEP="" & GCHGENV=2)
  # Fonction incompatible avec l'environnement
  Call ECR_TRACE(mess(5,310,1),1) From GESECRAN
  OK=0
 Endif
Endif
If dim(GACTX)>0
 If fmet GACTX.AGETLIC_EXPIRED(func ASYRLIC.GET_CHPRODUCTSTDCODE)=[V]CST_ATRUE | fmet GACTX.AGETLICFCT(GFONCTION)<>[V]CST_ATRUE
 OK=0
 Endif
Endif
Return

###############################################
$ERREUR
Gosub ERR From GSAISIE
FOK = XOK
Return

#################################################################
## Recherche infos écran saisie de critères
#################################################################

Subprog SETCRIT(BCRIT,TRTCRIT,MSKCRIT,ABRCRIT,TITCRIT)
Value    Char BCRIT
Variable Char TRTCRIT
Variable Char MSKCRIT()
Variable Char ABRCRIT()
Variable Char TITCRIT
Local Char    SAVGPROG(GLONADC)
Local Integer I
SAVGPROG = GPROGRAMME
GPROGRAMME = ""
Call NOMTRTWINOPT(BCRIT,TRTCRIT) From MSKDIV
Gosub DEFVAR From =TRTCRIT
For I=0 To NBMASK
 MSKCRIT(I) = NOMMSK(I)
 ABRCRIT(I) = ABMSK(I)
Next I
Gosub TIT From =TRTCRIT
TITCRIT = TIT
GPROGRAMME = SAVGPROG
End

########################################################
## Sous-programmes pour les batchs
########################################################

## Lecture des paramètres saisis et remplissage de l'écran critère (en principe DIA)

Subprog GETPAR(TRTCRIT,ABRCRIT)
Value Char TRTCRIT , ABRCRIT()
If clalev([F:ABR])=0 : Local File ABATRQT [ABR] : Endif
If clalev([F:ABL])=0 : Local File ABATRQTL [ABL] : Endif
Local Char    ZON(30) , DATNEW(10) , DATAFF(10) , ZONINT(30) , ZONAFF(30)
Local Integer MA , NUMREQ , I , DIME , K , MAJ
Local Date    DAT
For MA=0 To dim(ABRCRIT)-1
 If ABRCRIT(MA)<>""
  Gosub RAZMASK From =TRTCRIT
 Endif
Next MA
#109897
#[L]NUMREQ = val(getenv$("RQT_ENTREP"))
[L]NUMREQ = val(GBATCHRQT)
Default File [ABL]
Filter [F:ABL] Where NUMREQ = [L]NUMREQ
Call GETPAR(ABRCRIT) From REQUETES
Filter [ABL]
Default File [ABR]
MAJ = 0
Read [ABR]NUMREQ = [L]NUMREQ
If !fstat & [F:ABR]CODABT<>""
 If clalev([F:ABA])=0 : Local File ABATABT [ABA] : Endif
 Read [ABA]CODABT=[F:ABR]CODABT
 If !fstat & dim([F:ABA]NBDAT)>0
  Onerrgo RIEN
  For I=1 To [F:ABA]NBDAT
   ZON = [F:ABA]DATZON(I-1)
   K = instr(1,ZON,"(")
   If K : ZON = left$(ZON,K-1) : Endif
   If left$(ZON,1)<>"["
    ZON = "[M]"+ZON
   Endif
   If evalue("dim("+ZON+")")>0
    ZON = [F:ABA]DATZON(I-1)
    If left$(ZON,1)<>"["
     ZON = "[M]"+ZON
    Endif
    # Gestion des dates relatives
    DAT = func ADATREL.CALDAT(date$,[F:ABA]DATDEP(I-1),[F:ABA]DATNBR(I-1),[F:ABA]DATJRS(I-1),[F:ABA]DATFRM(I-1))
    If evalue("type("+ZON+")")=3
     Assign ZON With DAT
    Else
     DATNEW = DAT
     DATAFF = DAT
     Call CONTROLE(DATAFF,"D",0,0,DATNEW) From FMTVAR
     Assign ZON With ctrans(DATAFF,"-","/")
     ZONAFF = ZON
     K = instr(1,ZONAFF,"]")
     If K : ZONAFF = right$(ZONAFF,K+1) : Endif
     K = instr(1,ZONAFF,"(")
     If K : ZONAFF = left$(ZONAFF,K-1) : Endif
     Gosub DEFVAR From =TRTCRIT
     ZONINT = ""
     Local File AMSKPAR [AM2_]
     For MA=0 To NBMASK
      Read [AM2_]CODPAR=1;NOMMSK(MA);ZONAFF;"VALEUR"
      If !fstat
       ZONINT = [F:AM2_]VALPAR
       Break
      Endif
     Next MA
     Close Local File [AM2_]
     If ZONINT<>""
      K = instr(1,ZONINT,"]")
      If K : ZONINT = right$(ZONINT,K+1) : Endif
      K = instr(1,ZONINT,"(")
      If K : ZONINT = left$(ZONINT,K-1) : Endif
      K = instr(1,ZON,ZONAFF)
      ZON = left$(ZON,K-1)+ZONINT+right$(ZON,K+len(ZONAFF))
      Assign ZON With DATNEW
     Endif
    Endif
    MAJ = 1
   Endif
  Next I
  Onerrgo
 Endif
Endif
If MAJ
 # Mise à jour des paramètres pour la consultation des paramètres de la requête
 If clalev([F:ABL])=0 : Local File ABATRQTL [ABL] : Endif
 Trbegin [ABL]
  Delete [ABL] Where NUMREQ=[L]NUMREQ
  Call SETPAR(ABRCRIT,[L]NUMREQ) From REQUETES
 Commit
Endif
End

$RIEN
Resume

$SET_DIMPAR
Local Shortint DIMPAR
If clalev([F:ABP])=0 : Local File ABATPAR [ABP] : Endif
If [F:ABP]APPLI=""
 Readlock [ABP]SPOOL First
Endif
If dim([F:ABP]NBZONE)>0
 DIMPAR = min(32767,max([F:ABP]NBZONE,500))
Else
 DIMPAR = 500
Endif
Return

######################################################################################################
# Copie des écrans de saisie des paramètres d'une tâche dans la trace de la requête (author LST)
######################################################################################################

Subprog TRACE_MASQUE(COD,ABR,APPLI)
Value Char COD(), ABR(), APPLI

Onerrgo RIEN

Local File =APPLI+".AMSK"    [AMK]
Local File =APPLI+".AMSKZON" [AMZ]
Local File =APPLI+".ATYPE"   [ATY]
Local File =APPLI+".AMSKZON" [AMZ2]
Local File =APPLI+".ATYPE"   [ATY2]
Local File =APPLI+".ADOVAL"  [ADW]

Local Libelle I, J, K, L, N, LT, MA, OK
Local Char    INTITULE(255), LIGNE(255), F(80), CADRE(255)

Call PARAM("","ECRRESOL",[L]LIGNE) From ADOVAL
If [L]LIGNE="3" : L=112 : Else L=97 : Endif

Call ECR_TRACE("",0) From GESECRAN

OK = 1
For MA=0 To dim([L]ABR)-1
 If [L]ABR(MA)<>"" & evalue("clalev([M:"+[L]ABR(MA)+"])")=0
  OK = 0 : Break
 Endif
Next MA
If !OK : End : Endif
For MA=0 To dim(COD)-1
 Read [AMK]CODMSK=[L]COD(MA)
 If !fstat
  For [AMZ]CODZON(2) Where CODMSK=[L]COD(MA) & SAIAFF<>3 & CODTYP<>"W"
   Call TEXTE([F:AMK]TITBLOC(I),[L]INTITULE) From OBJDIV
   Call ECR_TRACE("|"+left$("+-"+[L]INTITULE+string$(L,"-"),L+1)+"+",0) From GESECRAN
   If [F:AMZ]CODTYP<>"ABS"
    [L]LIGNE="!"
    J       =int([F:AMZ]NOZONE)
    For [AMZ]CODZON
     If evalue("dim([M:"+[L]ABR(MA)+"]"+[F:AMZ]CODZON+")")>0
      Read [ATY]CODTYP = [F:AMZ]CODTYP
      If int([F:AMZ]NOZONE)>J
       [L]LIGNE=format$("K:"+num$(L+1)+"X",[L]LIGNE)+"!"
       Call ECR_TRACE("|"+[L]LIGNE,0) From GESECRAN
       [L]LIGNE="!"
       J       =int([F:AMZ]NOZONE)
      Endif
      If [F:AMZ]INTIT
       Call TEXTE([F:AMZ]INTIT,[L]INTITULE) From OBJDIV
       If !find(right$([L]LIGNE,len([L]LIGNE)),"!"," ")
        [L]INTITULE=" "+[L]INTITULE
       Endif
       If [F:ATY]TYPTYP=1 & [F:AMZ]NOLIB=1
        [L]LIGNE+=format$("K>:"+num$([F:AMZ]LONG)+"X[ :]",[L]INTITULE)
       Else
        [L]LIGNE+=format$("K>:"+num$([F:AMK]LNGLIB(I))+"X[ :]",[L]INTITULE)
       Endif
      Endif
      Case [F:ATY]TYPTYP
       When 1
        F        ="K:"+num$([F:AMZ]LONG)+"X"
        K        =max(1,evalue("[M:"+[L]ABR(MA)+"]"+[F:AMZ]CODZON))
        [L]LIGNE-=format$(F,mess(K,[F:AMZ]NOLIB,1))
       When 2,3,4,5,6
        F        ="N"+[F:AMZ]OPTSAI+":"+num$([F:AMZ]LONG)+"#"
        [L]LIGNE-=format$(F,evalue("[M:"+[L]ABR(MA)+"]"+[F:AMZ]CODZON))
       When 7
        If [F:AMZ]LONG=0
         If [F:ATY]FORTYP>"" : F="Kv1:"+[F:ATY]FORTYP
         Else                : F="Kv1:"+num$([F:ATY]LNGTYP)+"X"
         Endif
        Else               F="Kv1:"+num$([F:AMZ]LONG)+"X"
        Endif
        [L]CADRE=format$(F,evalue("[M:"+[L]ABR(MA)+"]"+[F:AMZ]CODZON))
        K        =len([L]LIGNE)
        If L-K<=0
         [L]LIGNE=format$("K:"+num$(L+1)+"X",[L]LIGNE)+"!"
         Call ECR_TRACE("|"+[L]LIGNE,0) From GESECRAN
         [L]LIGNE = "!"+[L]CADRE
        Else
         [L]LIGNE-=left$([L]CADRE,L-K)
         [L]CADRE =right$([L]CADRE,L+1-K)
         While [L]CADRE>""
          [L]LIGNE =format$("K:"+num$(L+1)+"X",[L]LIGNE)+"!"
          Call ECR_TRACE("|"+[L]LIGNE,0) From GESECRAN
          [L]LIGNE=format$("K:"+num$(L+1)+"X","!"+left$([L]CADRE,L))
          If len([L]CADRE)<L
           [L]LIGNE += space$(L-len([L]CADRE))
           [L]CADRE = ""
          Else
           [L]CADRE=right$([L]CADRE,L+1)
          Endif
         Wend
        Endif
       When 8
        F        ="D"+[F:AMZ]OPTSAI+":"+right$([V]GFMD,3)
        [L]LIGNE-=format$(F,evalue("[M:"+[L]ABR(MA)+"]"+[F:AMZ]CODZON))
      Endcase
     Endif
    Next AMZ
    [L]LIGNE=format$("K:"+num$(L+1)+"X",[L]LIGNE)+"!"
    Call ECR_TRACE("|"+[L]LIGNE,0) From GESECRAN
   Elsif evalue("dim([M:"+[L]ABR(MA)+"]"+[F:AMZ]CODZON+")")>0
    N=evalue("[M:"+[L]ABR(MA)+"]"+[F:AMZ]CODZON)
    For nolign=-1 To N
     [L]LIGNE=""
     Filter [AMZ2] Where CODMSK=[L]COD(MA) & find(SAIAFF,1,2)
&                        & NUMBLOC=[F:AMZ]NUMBLOC & CODZON<>[F:AMZ]CODZON
     [L]LT=int(L/rowcount([F:AMZ2]))
     For [AMZ2]CODZON
      If evalue("dim([M:"+[L]ABR(MA)+"]"+[F:AMZ2]CODZON+")")>0
       Read [ATY2]CODTYP = [F:AMZ2]CODTYP
       If [F:AMZ2]LONG=0 : J=[F:ATY2]LNGTYP : Else J=[F:AMZ2]LONG : Endif
       J=min(J,[L]LT)
       Case nolign
        When -1
         Call TEXTE([F:AMZ2]INTIT,[L]INTITULE) From OBJDIV
         [L]LIGNE+="!"+format$("K:"+num$(len([L]INTITULE))+"X",[L]INTITULE)
        When 0
         [L]LIGNE+="!"+string$(J,"-")
        When Default
         Case [F:ATY2]TYPTYP
          When 1
           F="K:"+num$(J)+"X"
           K=max(1,evalue("[M:"+[L]ABR(MA)+"]"+[F:AMZ2]CODZON+"(nolign-1)"))
           If [F:AMZ2]NOLIB=1 & K<2 : [L]LIGNE+="!"+format$(F," ")
           Else                       [L]LIGNE+="!"+format$(F,mess(K,[F:AMZ2]NOLIB,1))
           Endif
          When 2,3,4,5,6
           F        ="N"+[F:AMZ2]OPTSAI+":"+num$(J)+"#"
           [L]LIGNE+="!"+format$(F,evalue("[M:"+[L]ABR(MA)+"]"+[F:AMZ2]CODZON+"(nolign-1)"))
          When 7
           F="Kv1:"+num$(J)+"X"
           [L]LIGNE+="!"+format$(F,evalue("[M:"+[L]ABR(MA)+"]"+[F:AMZ2]CODZON+"(nolign-1)"))
          When 8
           F        ="D"+[F:AMZ2]OPTSAI+":"+right$([V]GFMD,3)
           [L]LIGNE-=format$(F,evalue("[M:"+[L]ABR(MA)+"]"+[F:AMZ2]CODZON+"(nolign-1)"))
         Endcase
       Endcase
      Endif
     Next AMZ2
     [L]LIGNE=format$("K:"+num$(L+1)+"X",[L]LIGNE+"!")+"!"
     Call ECR_TRACE("|"+[L]LIGNE,0) From GESECRAN
    Next nolign
   Endif
   I +=1
  Next AMZ
 Endif
Next MA
Close Local File [AMZ] , [AMK] , [AMZ2] , [ATY2] , [ATY] , [ADW]
Call ECR_TRACE("+"+string$(L,"-")+"+",0) From GESECRAN
Call ECR_TRACE("",0) From GESECRAN

Onerrgo

End

