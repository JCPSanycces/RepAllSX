#<AdxTL>@(#)0.0.0.0 $Revision$
$CTR_UNISTEP
Local Integer I
Local Char WTRKAUUID(40)

[L]ARET_VALUE = [V]CST_AOK

For I=1 To maxtab(this.TKTD)
  If this.TKTD(I) <> null and find(this.TKTD(I).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) < 1
    # Check if current code already exists
    OK = fmet this.IS_STEP_EXIST(AVOID.ACHAR, this.TKTD(I).TRKCOD, WTRKAUUID)
    If OK = [V]CST_ATRUE
      # Code already exist. It is my current row ?
      If (WTRKAUUID <> num$(this.TKTD(I).AUUID))
        [L]ARET_VALUE = fmet this.ASETERROR("TRKCOD", this.TKTD(I).TRKCOD + " : " + mess(565,194,1), [V]CST_AERROR)
        Break
      Endif
    Endif
  Endif
Next I
Return

#**
#* @param pass AVOID.ACHAR because this method is a static method)
#* @param TRKCOD Value to control
#* @param RTRKAUUID UUID of line collection (optionnal)
#* @return CST_ATRUE if yes, CST_AFALSE otherwise
#*!
$IS_STEP_EXIST
Local Integer I

  [L]ARET_VALUE = [V]CST_AFALSE

  If TRKCOD = AVOID.ACHAR
    Return
  Endif

  For I=1 To maxtab(this.TKTD)
    If this.TKTD(I) <> null and find(this.TKTD(I).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) < 1
      If this.TKTD(I).TRKCOD = TRKCOD
        RTRKAUUID = num$(this.TKTD(I).AUUID)
        [L]ARET_VALUE = [V]CST_ATRUE
        Break
      Endif
    Endif
  Next  I
Return

