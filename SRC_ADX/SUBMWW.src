#<AdxTL>@(#)5.0.0.0 $Revision$
$ACTION
Case ACTION
 When "LIENS"    : Gosub LIENS    
 When "SETBOUT"  : Gosub SETBOUT     
 When Default
Endcase
Return

########################################################### 
$SETBOUT 
Call VIREBOUT(CHAINE,"CMADH") From GOBJET 

# pas de charge si tableau vide
If [M:MWW1]NBLIG = 0 | GBROWS
    Call VIREBOUT(CHAINE,"1") From GOBJET
Endif

Return



###########################################################
# chargement des cas d'emploi
$LIENS
If clalev ([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif  # FGR 18/09/2009 : X3SUIVI57927

# lecture centre pour intitulé
If [M:MWW1]WCR <> [F:TWC]WCR
    Read [TWC]TWC0=[M:MWW1]WCR
    If fstat : Raz [F:TWC] : Endif
Endif
#[M:MWW1]WCRDES = [F:TWC]WCRDES

Local Integer WMAX : WMAX = dim([M:MWW1]ROUNUM)
nolign = 0

# 1ere phase, cas d'emploi en poste principal
Filter [F:ROO] Where WST = [M:MWW1]WST & FCY = [M:MWW1]WCRFCY
# 11.02 Performances 2
For [F:ROO]ROO2
    If nolign + 1 >= WMAX : Break : Endif
    nolign += 1
    Gosub LOAD_MWW
Next
Filter [F:ROO]

# 2nd phase, cas d'emploi en poste secondaire
Filter [F:ROO] Where LABWST = [M:MWW1]WST & FCY = [M:MWW1]WCRFCY
# 11.02 Performances 2
For [F:ROO]ROO3
    If nolign + 1 >= WMAX : Break : Endif
    nolign += 1
    Gosub LOAD_MWW
Next
Filter [F:ROO]

[M:MWW1]NBLIG = nolign
Sorta [M:MWW1]NBLIG [M:MWW1]NBLIG Order By [M:MWW1]ROUNUM(indice)
Grizo [M:MWW1]WCR, XWSTTYP
Return

###########################################################
# chargement ligne
$LOAD_MWW
[M:MWW1] = [F:ROO]    
[M:MWW1]ROUNUM(nolign-1)    = [F:ROO]ITMREF

# lecture article pour US
If [F:ITM]ITMREF <> [F:ROO]ITMREF
    Read [ITM]ITM0=[F:ROO]ITMREF
    If fstat : Raz [ITM] : Endif
Endif
[M:MWW1]STU(nolign-1)       = [F:ITM]STU

# lecture alternative pour intitulé
If [F:TRO]ROUALT <> [F:ROO]ROUALT
    Read [TRO]TRO0=[F:ROO]ROUALT
    If fstat : Raz [TRO] : Endif
Endif
# FGR 18/09/2009 : X3SUIVI57927
#[M:MWW1]TROSHO(nolign-1)    = [F:TRO]TROSHO
Call LECTEXTRA([M:MWW1]TROSHO(nolign-1),"TABROUALT","TROSHOAXX",num$([F:TRO]ROUALT),"") From ATEXTRA

# lecture entête gamme
If ([F:ROH]ITMREF <> [F:ROO]ITMREF) | ([F:ROH]ROUALT <> [F:ROO]ROUALT) | ([F:ROH]FCY <> [F:ROO]FCY)
    Read [ROH]ROH1=[F:ROO]FCY;[F:ROO]ITMREF;[F:ROO]ROUALT
    If fstat : Raz [ROH] : Endif
Endif
[M:MWW1]WORMINQTY(nolign-1)    = [F:ROH]WORMINQTY
[M:MWW1]WORMAXQTY(nolign-1)    = [F:ROH]WORMAXQTY
[M:MWW1]LASWORQTY(nolign-1)    = [F:ROH]LASWORQTY
[M:MWW1]LASWORDAT(nolign-1)    = [F:ROH]LASWORDAT
# FGR 02/10/2009 : X3SUIVI58337
#[M:MWW1]ROUDES(nolign-1)       = [F:ROH]ROUDES
Call LECTEXTRA([M:MWW1]ROUDES(nolign-1),"ROUTING", "ROUDESAXX", [F:ROH]ITMREF+"~"+num$([F:ROH]ROUALT),[F:ROH]FCY) From ATEXTRA

# sous-traitance ?
If [F:ROO]SCOCOD = 3 
    [M:MWW1]SUBSOL(nolign-1) = 2
Else
    [M:MWW1]SUBSOL(nolign-1) = 1
Endif

# remplaçant ?
Read [RPW]RPW0=[F:MWS]WST;[F:MWS]WCRFCY
If fstat =0
    If [F:RPW]RPLWST(0)<>""
        [M:MWW1]RPLSOL(nolign-1) = 2
    Else
        [M:MWW1]RPLSOL(nolign-1) = 1
    Endif
Else 
    [M:MWW1]RPLSOL(nolign-1) = 1
Endif


Return

########################################
Subprog S_WST(VALEUR)
Variable Char    VALEUR()
If [F:MWS]WST = "" : End : Endif
Read [F:MWS]WST0 Curr
If !fstat & [F:MWS]WST = VALEUR
    [M:MWW1] = [F:MWS]
    Effzo [M:MWW1]10
Endif
End


########################################
Subprog B1_NBLIG
GROUALT (0) = [M:MWW1]ROUALT(nolign-1)
Local Char WALT(3) : WALT = num$([M:MWW1]ROUALT(nolign-1))

# GH 04/09/12 bug 84237
#Local Char     WITM    : WITM = [M:MWW1]ROUNUM(nolign-1)
#Call OBJET("ROU",WALT, WITM) From GOBJET 

Local Char SUPP(max(GLONITM,GLONFCY))(2)
SUPP(0)=[M:MWW1]ROUNUM(nolign-1)
SUPP(1)=[M:MWW1]WCRFCY
Call OBJET("ROU",WALT, SUPP) From GOBJET  
End

########################################
Subprog AS_NBLIG
Raz GBOUT1  
If [M:MWW1]ROUNUM(nolign-1) <> "" 
    GBOUT1 = mess(63,198,1) 
Endif    
End

########################################
Subprog AM_WCRFCY(VALEUR)
Variable Char    VALEUR()
Effzo [M:MWW1]10
End

########################################
Subprog C_WST(VALEUR)
Variable Char    VALEUR()
    [M:MWW1] = [F:MWS]
#    Effzo [M:MWW1]10
End


######################################################################################
Subprog AM_WST(VALEUR)
Variable Char    VALEUR()
  Effzo [M:MWW1]10
End


######################################################################################

