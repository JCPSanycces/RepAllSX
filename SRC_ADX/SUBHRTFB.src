$ACTION
Case ACTION
 When "SETBOUT"    : Gosub SETBOUT
 When "APRES_CHOI" : Gosub APRES_CHOI
 When "LIENS0"     : Gosub LIENS0
 When "LIENS2"     : Gosub LIENS2
 When "RAZDUP"     : Gosub RAZDUP
 When "RAZCRE"     : Gosub RAZCRE
 When "ABANDON"    : Gosub ABANDON
 When "MODIF"      : Gosub MODIF
#MIPEA - 2017/03/07 - JIRA X3-11251 - START
 When "INICRE"      : Gosub INICRE
 When "INIMOD"      : Gosub INIMOD
#MIPEA - 2017/03/07 - JIRA X3-11251 - END
#DIRAS - 2017/03/06 - JIRA X3-27507 - START
 When "FILGAUCHE"  : Gosub FILGAUCHE
#DIRAS - 2017/03/06 - JIRA X3-27507 - END
 When "SEL_TABLE"  : Case COUZON
                      When "COD","BAN","RECTYP","ORDNUM" : Gosub S_TFB
                     Endcase
#DIRAS - 2017/02/13 - JIRA X3-11251 - START
 When "VERF_TABLE" : Case OBJET
                      When "HRTFB" : Gosub V_TFB
                     Endcase
 #When "VERF_TABLE" : Case OBJET
 #                     When "TFB" : Gosub V_TFB
 #                    Endcase
#DIRAS - 2017/02/13 - JIRA X3-11251 - END
Endcase
Return

#87897
$LIENS0
Local Integer TMPFMT
#DIRAS - 2017/02/13 - JIRA X3-11251 - START
TMPFMT=[F:HRTFB]FMT
#TMPFMT=[F:TFB]FMT
#DIRAS - 2017/02/13 - JIRA X3-11251 - END
Call AM_FMT(TMPFMT)
Call C_FMT(TMPFMT)
Return

#JASMI - 2017-03-06 - START
$OUVRE

If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
Return

$LIENS2
If dim([M]LEG)>0 : Affzo [M]LEG : GCURLEG=[M]LEG Endif
If GNBLEG = 1 : GCURLEG = GDOSLEG : Endif
#JASMI - 2017-03-06 - END

If [M]RECTYP>1
 Call SET_CURMULT
 Grizo CURMULT, FILREF, FILEXT
Else
 Actzo CURMULT, FILREF
 #87897
 If [M]FMT=1
   Grizo [M]FILEXT
 Else
   Actzo [M]FILEXT
 Endif
 #
Endif
Return

$RAZDUP
$RAZCRE
If COUZON="RECTYP"
 If zc>1
  Grizo CURMULT, FILREF
 Else
  Actzo CURMULT, FILREF
 Endif
Endif
Return

$ABANDON
Actzo CURMULT, FILREF
Return

Subprog SET_CURMULT
Local File HRTABFILBAN [HRTFB]
Read [HRTFB]TFB0(3) = [M]COD;[M]BAN;1
If fstat
 Read [HRTFB]TFB0(3) = [M]COD;"";1
 If fstat : Raz [F:HRTFB] : Endif
Endif
If [F:HRTFB]CURMULT=2 : [M]CURMULT=2 : Else [M]CURMULT=1 : Endif
[M]FILREF=[F:HRTFB]FILREF
End

#87897
$MODIF
#JASMI - 2017-03-06 - START
Gosub TEXTRA
If GOK<1 : Return : Endif
#JASMI - 2017-03-06 - END

If clalev([F:TFB2])=0 : Local File HRTABFILBAN [TFB2] : Endif
 For [F:TFB2]TFB0 Where COD=[F:HRTFB]COD and BAN=[F:HRTFB]BAN and RECTYP>1
    [F:TFB2]FILEXT=[F:HRTFB]FILEXT
    Rewrite [TFB2]
    If fstat<>0
     GOK = 0 : Call FSTA("TFB2") From GLOCK : Break
    Endif
 Next
 If GOK<1 : Return : Endif
Return
#
#MIPEA - 2017/03/07 - JIRA X3-11251 - START
$INICRE
$INIMOD
[F:HRTFB]BANLEG = [HRTFB]BAN+"~"+[HRTFB]LEG
Return
#MIPEA - 2017/03/07 - JIRA X3-11251 - END

#JASMI - 2017-03-06 - START
$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 WCLECUR1 = CLECUR1+"~"+CLECUR2(3)
 Call DUPTEXTRA("HRTABFILBAN","DES",CLECUR2,WCLECUR1,"HRTABFILBAN","DES",[F:HRTFB]COD,[F:HRTFB]BAN+"~"+[F:HRTFB]LEG) From ATEXTRA
 Call DUPTEXTRA("HRTABFILBAN","DESSHO",CLECUR2,WCLECUR1,"HRTABFILBAN","DESSHO",[F:HRTFB]COD,[F:HRTFB]BAN+"~"+[F:HRTFB]LEG) From ATEXTRA
Endif
Call MAJTEXTRA([M:HRTFB1]DES,"HRTABFILBAN","DES",[F:HRTFB]COD,[F:HRTFB]BAN+"~"+[F:HRTFB]LEG) From ATEXTRA
Call MAJTEXTRA([M:HRTFB1]DESSHO,"HRTABFILBAN","DESSHO",[F:HRTFB]COD,[F:HRTFB]BAN+"~"+[F:HRTFB]LEG) From ATEXTRA
Return
#JASMI - 2017-03-06 - END

#DIRAS - 2017/03/06 - JIRA X3-27507 - START
$FILGAUCHE
FILGAUCHE = "(([F:HRTFB]LEG<>'' & (find([F:HRTFB]LEG,'"+GLEGFIL+"','')>0)) | [F:HRTFB]LEG='' | GLEGFIL='')"
Return
#DIRAS - 2017/03/06 - JIRA X3-27507 - END

$SETBOUT
If CLECUR & SUPPR : CHAINE+="A" : Endif
If !CLECUR | REP<>"" | !VERROU
 Call VIREBOUT(CHAINE,"1") From GOBJET : # Copie
Endif
Return

$APRES_CHOI
Case REPONSE
 When GSTAANU : Gosub ANNULER : REPONSE=0
Endcase
Return

$ANNULER
If !VERROU
 Gosub VERROU From GOBJET
 If !VERROU
  Call ERREUR(mess(10,100,1)) From GESECRAN : Return
 Else
  AFFICHE = 1 : Gosub RELIT From GOBJSUB
 Endif
Endif
OK = 2
If dim([V]GCONF)<=0 or [V]GCONF(1)=2 : # Suppression
 Call OUINON(mess(53,123,1)-[M]COD-[M]BAN-mess([M]RECTYP,656,1)-num$(ORDNUM),OK) From GESECRAN : # Suppression
Endif
If OK<>2 : Return : Endif
Call DEBTRANS From GLOCK
Gosub TR3
CLECUR = 0
Gosub RELIT From GOBJSUB
Return


$TR3
GOK=1
Trbegin [HRTFB]
#LIPET - 2018-01-19 - X3-72514 - START
 #Delete [HRTFB] Where COD=[M]COD & BAN=[M]BAN & RECTYP=[M]RECTYP & ORDNUM=[M]ORDNUM
 Delete [HRTFB] Where COD=[M]COD & BAN=[M]BAN & RECTYP=[M]RECTYP & ORDNUM=[M]ORDNUM & LEG=[M]LEG
#LIPET - 2018-01-19 - X3-72514 - END
Commit

#JASMI - 2017-03-06 - START
# suppression des textes traduisibles seulement si inutilisés
#MIPEA - 2017/06/16 - JIRA X3-11251 - START
Filter [HRTFB] Where COD=[M]COD & BAN=[M]BAN & LEG=[M]LEG
#Filter [TFB] Where COD=[M]COD & BAN=[M]BAN & LEG=[M]LEG
#MIPEA - 2017/06/16 - JIRA X3-11251 - END
#MIPEA - 2017/06/16 - JIRA X3-11251 - START
If rowcount([HRTFB])=0
#If rowcount([TFB])=0
#MIPEA - 2017/06/16 - JIRA X3-11251 - END
 Call SUPTEXTRA("HRTABFILBAN","DES",[M]COD,[M]BAN+"~"+[M]LEG) From ATEXTRA
 Call SUPTEXTRA("HRTABFILBAN","DESSHO",[M]COD,[M]BAN+"~"+[M]LEG) From ATEXTRA
Endif
#MIPEA - 2017/06/16 - JIRA X3-11251 - START
Filter [HRTFB]
#Filter [TFB]
#MIPEA - 2017/06/16 - JIRA X3-11251 - END
#JASMI - 2017-03-06 - END

Return

########################################
## Copie par couple (Fichier+Banque)  ##
########################################

Subprog COPIE(TABLE,TABLE2)
Value Char TABLE  : # Code
Value Char TABLE2 : # Banque
Local Integer OK
If clalev([M:DIA2])=0
 Local Mask ACOPIE [DIA2]
 Raz [M:DIA2]
 [M]OBJET = mess(41,121,1)-":"-TABLE
 OK=2 : zonsui = "DOSDES"
 #Call DIALO(OK,mess(41,121,1)) From GOBJTXT : # Fichiers bancaires
 Call AVERTIR(mess(41,121,1),OK) From GESECRAN
 If OK<>2 : End : Endif
Endif
Call TEMPON("T") From GESECRAN
Gosub TRTCOP
Call TEMPOFF From GESECRAN
End

$TRTCOP
If [M]DOSORG=nomap
 Local File HRTABFILBAN  [TFB1]
Else
 Local File =[M]DOSORG+".HRTABFILBAN"  [TFB1]
Endif
If [M]DOSDES=nomap
 Local File HRTABFILBAN [TFB2]
Else
 Local File =[M]DOSDES+".HRTABFILBAN"  [TFB2]
Endif
Call DEBTRANS From GLOCK
Gosub TR_COP
Close Local File [TFB1], [TFB2]
Return

$TR_COP
GOK = 1
Trbegin [TFB2]
 Delete [TFB2] Where COD=TABLE & BAN=TABLE2
 If fstat=1
#DIRAS - 2017/03/08 - JIRA X3-11251 - START
 GOK=-1 : GLOCK = "$"+[M]DOSDES+".HRTABFILBAN" : Goto ROLL_TR_COP
  #GOK=-1 : GLOCK = "$"+[M]DOSDES+".TABFILBAN" : Goto ROLL_TR_COP
#DIRAS - 2017/03/08 - JIRA X3-11251 - END
 Elsif fstat>5
  GOK = 0 : Call RSTA("TFB2","") From GLOCK : Goto AB_TR_COP
 Endif
 For [TFB1] Where COD=TABLE & BAN=TABLE2
  [F:TFB2] = [F:TFB1]
  If dim([F:TFB2]UPDUSR)>0 : [F:TFB2]UPDUSR = GUSER : Endif
  If dim([F:TFB2]UPDDAT)>0 : [F:TFB2]UPDDAT = date$ : Endif
  Write [TFB2]
  If fstat
   GOK = 0 : Call FSTA("TFB2") From GLOCK : Break
  Endif
 Next
 If   GOK<0 : Goto ROLL_TR_COP
 Elsif !GOK : Goto AB_TR_COP
 Endif
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

########################################
## Ecran TFB1                         ##
########################################

Subprog IB_BAN
GBOUT1 = mess(22,123,1)-mess(1,653,1) : # Sélection Banque
End

$S_TFB
#DIRAS - 2017/02/13 - JIRA X3-11251 - START
OBJET = "HRTFB"
#OBJET = "HRTFB"
#DIRAS - 2017/02/13 - JIRA X3-11251 - END
Local Char ZONE(20)

# Critère de sélection
For ZONE="COD","BAN","RECTYP","ORDNUM"
 If ZONE=COUZON : Break : Endif
 CRITERE += " & "+ZONE+"=[M]"+ZONE
Next
If CRITERE<>""
 CRITERE=right$(CRITERE,4)
 Filter [HRTFB] Where evalue(CRITERE)
Endif

# Positionnement par défaut dans la fenêtre de sélection
If !GBROWS #72698
 # EXPSTART n'est pas gérée en intradon
 For ZONE="COD","BAN","RECTYP","ORDNUM"
  If ZONE=COUZON : Assign "[F:HRTFB]"+ZONE With VALEUR
  Else           : Assign "[F:HRTFB]"+ZONE With evalue("[M]"+ZONE)
  Endif
 Next
 Read [HRTFB]TFB0(4) =
 If !fstat
  For ZONE="COD","BAN","RECTYP","ORDNUM"
   If ZONE=COUZON : EXPSTART += " & "+ZONE+"=[L]VALEUR"
   Else           : EXPSTART += " & "+ZONE+"=[M]"+ZONE
   Endif
  Next
  EXPSTART=right$(EXPSTART,4)
 Endif
Endif
If EXPSTART=""
 START = COUZON
Endif

If CRITERE<>"" : Filter [HRTFB] : Endif
Return

$V_TFB
For ZONE="COD","BAN","RECTYP","ORDNUM"
 If ZONE<>COUZON
  Assign "[M]"+ZONE With evalue("[F:HRTFB]"+ZONE)
 Endif
Next
mkstat=4
Return

#JASMI - 2017-03-06 - START
$FERME
If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return
#JASMI - 2017-03-06 - END

Subprog AP_RECTYP(VALEUR)
Variable Integer VALEUR
If VALEUR<>2 : [M]ORDNUM=0 : Endif
End

Subprog AS_ORDNUM(VALEUR)
Variable Decimal VALEUR
If [M]RECTYP<>2 : mkstat=2 : Endif
End

Subprog C_ORDNUM(VALEUR)
Variable Decimal VALEUR
If VALEUR = 0 : VALEUR = 1 : Endif
End

Subprog AV_POS(VALEUR)
Variable Decimal  VALEUR
If nolign=1
 VALEUR = 1
Else
 VALEUR = [M]POS(nolign-2) + [M]LNG(nolign-2)
Endif
End

Subprog AS_LNG(VALEUR)
Variable Decimal VALEUR
Case [M]FLDTYP(nolign-1)
 When 3,4 : VALEUR = 6 : mkstat = 2 : # Date (JJMMAA), Date (AAMMJJ)
 When 6,7 : VALEUR = 2 : mkstat = 2 : # Mois, Jour
Endcase
End

Subprog C_LNG(VALEUR)
Variable Decimal VALEUR
Case [M]FLDTYP(nolign-1)
 When 5 : # Année
  If !find(VALEUR,1,2,4) : mkstat = 1 : End : Endif
Endcase
End

Subprog APRES_NBLIG
If !GIMPORT : Affzo TOTLNG, POS : Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran TFB1) 06/02/2013 14:56:37 (LANEG)
######################################################################################
#87897
Subprog AM_FMT(VALEUR)
Variable Integer VALEUR
If VALEUR=1
 # le format est ‘Fixe’ => affichage des colonnes qui existent aujourd’hui : type champ, position, longueur, formule titre
 Chgfmt [M]STRSEP With "-K:250"
 Chgfmt [M]ENDSEP With "-K:250"
 Chgfmt [M]OBY With "-K:5"
 Chgfmt [M]CND With "-K:250"
 Chgfmt [M]POS With "N:4"
 Chgfmt [M]TOTLNG With "N:4"
Else
 # le format est ‘Variable’ => affichage des colonnes suivantes : type champ, longueur (long max, non obligatoire),
 # séparateur début (dans lequel sera définie la balise dans le cas de fichier XML. Ex : ''), Formule, séparateur fin.
 Chgfmt [M]POS With "-N:4"
 Chgfmt [M]TOTLNG With "-N:4"
 Chgfmt [M]STRSEP With "K:250"
 Chgfmt [M]ENDSEP With "K:250"
 Chgfmt [M]OBY With "K:5"
 Chgfmt [M]CND With "K:250"
Endif
End

#87897
Subprog C_FMT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Actzo [M]FILEXT
Else
  Effzo [M]FILEXT
  Grizo [M]FILEXT
Endif
End

#87897
Subprog C_FRM(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
 [M]OBY(nolign-1) = 0
 Grizo [M]OBY(nolign-1)
Else
 Actzo [M]OBY(nolign-1)
Endif
End

#87897
Subprog AV_OBY(VALEUR)
Variable Integer VALEUR
Call C_FRM([M]FRM(nolign-1))
End

#87897
Subprog AS_ENDSEP(VALEUR)
Variable Char    VALEUR()
If [M]STRSEP(nolign-1)<>"" and [M]FRM(nolign-1)<>"" and VALEUR=""
 VALEUR = "</"+mid$([M]STRSEP(nolign-1), 2, len([M]STRSEP(nolign-1)))
Endif
End

#87897
Subprog C_ENDSEP(VALEUR)
Variable Char    VALEUR()
Local Integer OK
Local Char ENDSEP(250)
ENDSEP = "</"+mid$([M]STRSEP(nolign-1), 2, len([M]STRSEP(nolign-1)))
If [M]STRSEP(nolign-1)<>"" and [M]FRM(nolign-1)<>"" and VALEUR<>[L]ENDSEP
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- START
 Call OUINON(func AFNC.MES1(mess(27,10704,1), ENDSEP), OK) From GESECRAN
# Call OUINON(func AFNC.MES1(mess(27,704,1), ENDSEP), OK) From GESECRAN
#MIPEA - 2017-03-10- US X3-11264 ST X3-25377- END
 If OK=2 : VALEUR = [L]ENDSEP : Endif
Endif
End

#87897
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM     # Nom du paramètre en cours de saisie
Value Char VALEUR    # Valeur saisie à contrôler
Variable Integer OK    # 1 si contrôle satisfait, 0 si saisie incorrecte
                                 # Si OK=0, renseigner la variable GMESSAGE avec le message d’erreur
If PARAM="FMTBAN"
 If VALEUR="": End: Endif: #90761
 If clalev([F:HRTFB])=0 : Local File HRTABFILBAN    [HRTFB] : Endif
  Filter [HRTFB] Where RECTYP=1
  Read [F:HRTFB]TFB0(1)=toupper(VALEUR)
  Filter[HRTFB]
  If fstat
    OK=0
    GMESSAGE=mess(83,123,1)
    End
  Endif
Endif
End

######################################################################################
## Section automatically added (screen HRTFB1) 03/06/2017 16:06:36 (DIRAS)
######################################################################################
Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
#MIPEA - 2017/03/08 - JIRA X3-11251 - START
If clalev([F:BAN])=0 : Local File BANK [BAN] : Endif
#MIPEA - 2017/03/08 - JIRA X3-11251 - END
If [M]BAN<>"" & VALEUR<>""
 Call LEC_BAN(VALEUR) From CPTLEC
 Call LEC_CPY([F:BAN]CPY) From CPTLEC
 If [F:CPY]LEG<>"" & [F:CPY]LEG<>VALEUR
  # Banque incompatible avec la législation
  GMESSAGE = mess(261,117,1)
  mkstat = 2 : End
 Endif
Endif
GCURLEG = VALEUR
End
