########################################################################
#  Action                                         appeles par les ecrans
########################################################################
# STKSELLIS                                   Sélection liste inventaire
# STKVERLIS                                Vérification liste inventaire
# PASSAISNL1      desactivation rubrique ecran SNL1 (statut + zerstoflg)
# PASSAISNL                   desactivation rubrique ecran SNL1 (statut)
# PASSAISNL0                           desactivation rubrique ecran SNL0


########################################################################
# CAL_NEXINV                    calcul de la prochaine date d'inventaire
########################################################################
# LFCY = site
# LTCL = Catégorie article
# LDAT = Date de référence par défaut
# LCOD = code inventaire
# Classe [STE] ouverte
# Classe [ITV] chargées
########################################################################
Subprog CAL_NEXINV(LFCY,LTCL,LDAT,LCOD)
Variable Char    LFCY
Variable Char    LTCL
Variable Date    LDAT
Variable Integer LCOD
Local    Decimal WPERA : WPERA = 0
Local    Decimal WPERB : WPERB = 0
Local    Decimal WPERC : WPERC = 0
Local    Decimal WPERD : WPERD = 0
Local    Date    WDAT
If [F:ITV]LASCUNDAT = [0/0/0]
  WDAT = LDAT
Else
  WDAT = [F:ITV]LASCUNDAT
Endif
Case LCOD
  When 1 :
    Read [STE]STE0=LFCY;LTCL
      If fstat= 0
        WPERA = [F:STE]DAYGAPCLSA
        WPERB = [F:STE]DAYGAPCLSB
        WPERC = [F:STE]DAYGAPCLSC
        WPERD = [F:STE]DAYGAPCLSD
      Else
        Read [STE]STE0=LFCY;""
          If fstat = 0
            WPERA = [F:STE]DAYGAPCLSA
            WPERB = [F:STE]DAYGAPCLSB
            WPERC = [F:STE]DAYGAPCLSC
            WPERD = [F:STE]DAYGAPCLSD
          Endif
      Endif
      Case [F:ITF]ABCCLS
        When 1 :
          [F:ITV]NEXCUNDAT = WDAT + WPERA
        When 2 :
          [F:ITV]NEXCUNDAT = WDAT + WPERB
        When 3 :
          [F:ITV]NEXCUNDAT = WDAT + WPERC
        When 4 :
          [F:ITV]NEXCUNDAT = WDAT + WPERD
        When Default :
          [F:ITV]NEXCUNDAT = [0/0/0]
       Endcase
  When 2 :
    [F:ITV]NEXCUNDAT = WDAT+365
  When 3 :
    [F:ITV]NEXCUNDAT = [0/0/0]
Endcase

# hcb 40367
GPOINT = "CALNEXINV"
Gosub  ENTREE From EXEFNC


End


########################################################################
# CAL_NEXINVITW   calcul de la prochaine date d'inventaire article depot
########################################################################
# LFCY = site
# LTCL = Catégorie article
# LDAT = Date de référence par défaut
# LCOD = code inventaire
# Classe [STE] ouverte
# Classe [ITW] chargée
# Classe [ITF] chargée
########################################################################
Subprog CAL_NEXINVITW(LFCY,LTCL,LDAT,LCOD)
Variable Char    LFCY
Variable Char    LTCL
Variable Date    LDAT
Variable Integer LCOD
Local    Decimal WPERA : WPERA = 0
Local    Decimal WPERB : WPERB = 0
Local    Decimal WPERC : WPERC = 0
Local    Decimal WPERD : WPERD = 0
Local    Date    WDAT
If [F:ITW]LASCUNDAT = [0/0/0]
  WDAT = LDAT
Else
  WDAT = [F:ITW]LASCUNDAT
Endif
Case LCOD
  When 1 :
    Read [STE]STE0=LFCY;LTCL
      If fstat= 0
        WPERA = [F:STE]DAYGAPCLSA
        WPERB = [F:STE]DAYGAPCLSB
        WPERC = [F:STE]DAYGAPCLSC
        WPERD = [F:STE]DAYGAPCLSD
      Else
        Read [STE]STE0=LFCY;""
          If fstat = 0
            WPERA = [F:STE]DAYGAPCLSA
            WPERB = [F:STE]DAYGAPCLSB
            WPERC = [F:STE]DAYGAPCLSC
            WPERD = [F:STE]DAYGAPCLSD
          Endif
      Endif
      Case [F:ITF]ABCCLS
        When 1 :
          [F:ITW]NEXCUNDAT = WDAT + WPERA
        When 2 :
          [F:ITW]NEXCUNDAT = WDAT + WPERB
        When 3 :
          [F:ITW]NEXCUNDAT = WDAT + WPERC
        When 4 :
          [F:ITW]NEXCUNDAT = WDAT + WPERD
        When Default :
          [F:ITW]NEXCUNDAT = [0/0/0]
       Endcase
  When 2 :
    [F:ITW]NEXCUNDAT = WDAT+365
  When 3 :
    [F:ITW]NEXCUNDAT = [0/0/0]
Endcase

GPOINT = "CALINVITW"
Gosub  ENTREE From EXEFNC

End

########################################################################
# TRT_VALEUR                     calcul valeur unitaire ligne inventaire
#                 valorisation de type sortie
#                 type de mouvement = 13 (inventaire)
#                 code mouvement    = "SNX (generation inventaire)
# Le code mouvement "SNX" est passé lors de la création d'un inventaire
# afin de valoriser le stock comme en sortie (-> donne une valeur indicative du stock)
########################################################################
Subprog TRT_VALEUR(LLIG,LABR)
Value Integer LLIG
Value Char    LABR
Local Decimal WPRI
Local Integer WRET
Local Integer WCOD
# 0=Ok
# 1=Erreur dans le calcul)
# 2=Article-site non trouvé !)
# 3=Méthode valorisation non trouvée !)
# 4=Prix nul non autorisé !)

#--- Bug 78677
If clalev([F:ITV])=0  Local File ITMMVT  [ITV]  Endif

Local Char    LLOT(GLONLOT)
Local Char    LSLO(GLONSLO)
Local Char    LABRMSK
Local Decimal LQTE
Local Char    LITM(GLONITM)     # hcb 68829
Local Char    LFCY(GLONFCY)     # hcb 68829
Local Char    LECCMAJ(GLONECS)
Local Char    LECCMIN(GLONEVL)

#                                                           # hcb 57798 deb
Local Date    LDAT
Raz LDAT
# Issue 80177 - 2012-02-16 by CCC
#If evalue("dim("+LABRMSK+"CUNLISDAT)")>0
If evalue("dim([M:"+LABR+"]CUNLISDAT)")>0
   LDAT = evalue("[M:"+LABR+"]CUNLISDAT")
Endif
If LDAT = [0/0/0]
   LDAT = date$
Endif
#                                                            # hcb 57798 fin

Local Decimal LPRIORD                                        # hcb 51773
Raz   LPRIORD                                                # hcb 51773
LABRMSK  = "[M:"+LABR+"]"

If evalue("dim("+LABRMSK+"LOT(LLIG))")>0
   LLOT = evalue("[M:"+LABR+"]LOT(LLIG)")
Endif
If evalue("dim("+LABRMSK+"SLO(LLIG))")>0
   LSLO = evalue("[M:"+LABR+"]SLO(LLIG)")
Endif
If evalue("dim("+LABRMSK+"PRIORD(LLIG))")>0                  # hcb 51773
   LPRIORD = evalue("[M:"+LABR+"]PRIORD(LLIG)")
Endif
#                                             # hcb 68829 deb
#LQTE = evalue("[M:"+LABR+"]QTYSTU(LLIG)")
LITM = evalue("[M:"+LABR+"]ITMREF(LLIG)")
LFCY = evalue("[M:"+LABR+"]STOFCY")

#--- Issue 103815
# Lecture ITV
#Call LECITV(LFCY,LITM,"",WRET) From STKLIB
#If WRET > 1
#   Erreur lecture fichier !
#    Call ECR_TRACE(mess(6,9004,1)-"ITMMVT"-LFCY-LITM,1) From GESECRAN
#    End
#Endif
Read [ITV]ITV0=LITM;LFCY
If fstat
  Call ECR_TRACE(mess(6,9004,1)-"ITMMVT"-LFCY-LITM,1) From GESECRAN
  End
Endif
#---

LQTE = [F:ITV]AVCBASQTY
#                                             # hcb 68829 fin
Raz LECCMAJ, LECCMIN
If evalue("dim([M:"+LABR+"]ECCVALMAJ)")>0
    [L]LECCMAJ = evalue("string$([M:"+LABR+"]ECCVALMAJ(LLIG)<>'$',[M:"+LABR+"]ECCVALMAJ(LLIG))")
    [L]LECCMIN = evalue("string$([M:"+LABR+"]ECCVALMIN(LLIG)<>'$',[M:"+LABR+"]ECCVALMIN(LLIG))")
Endif

Call DEFPRI(evalue("[M:"+LABR+"]ITMREF(LLIG)"),LECCMAJ,LECCMIN,evalue("[M:"+LABR+"]STOFCY"),13,
&           "SNX",LLOT,LSLO,LDAT,LQTE,LQTE,LPRIORD,WCOD,WPRI,WRET) From STKVAL           # hcb 51773  57798

Assign "[M:"+LABR+"]CUNCST    (LLIG)" With WPRI
If evalue("dim("+LABRMSK+"CUNCSTCOD(LLIG))")>0
   Assign "[M:"+LABR+"]CUNCSTCOD (LLIG)" With WCOD
Endif
End

########################################################################
# EXI_CUD            Contrôle pas d'inventaire en cours pour cet article
########################################################################
Subprog EXI_CUD(LFCY,LITM,LLOT,LSLO,LMAJ,LLPN,LLOC,LSTA,LSER,LPCU,LCOE,LPAL,LCTR,LQLY,LOWN,LWRH,LSF1,LSF2,LRET)
Value    Char    LFCY
Value    Char    LITM
Value    Char    LLOT
Value    Char    LSLO
Value    Char    LMAJ
Value    Char    LLPN                   # hcb X3-68147
Value    Char    LLOC
Value    Char    LSTA
Value    Char    LSER
Value    Char    LPCU
Value    Decimal LCOE
Value    Char    LPAL
Value    Char    LCTR
Value    Char    LQLY
Value    Char    LOWN
Value    Char    LWRH
Value    Char    LSF1
Value    Char    LSF2
Variable Integer LRET
Local Char WFILCUD(20)
If GWRHACT = 2
   WFILCUD = "[F:CUD]WRH = LWRH"
Else
   WFILCUD = "1=1"
Endif

# si existe l article doit etre au moins en statut validée
# si existe et numero de serie stock nul doit etre à oui
LRET = 0
Filter [CUD] Where STOFCY    = LFCY           &
&                  ITMREF    = LITM           &
&                  LOC       = LLOC           &
&                  LPNNUM    = LLPN           &
&                  LOT       = LLOT           &
&                  SLO       = LSLO           &
&                  ECCVALMAJ = LMAJ           &
&                  STA       = LSTA           &
&                  SERNUM    = LSER           &
&                  PCU       = LPCU           &
&                  PCUSTUCOE = LCOE           &
&                  PALNUM    = LPAL           &
&                  CTRNUM    = LCTR           &
&                  QLYCTLDEM = LQLY           &
&                  OWNER     = LOWN           &
&                  STOFLD1   = LSF1           &
&                  STOFLD2   = LSF2           &
&                  evalue(WFILCUD)            &
&                  CUNLISSTA < 3
&            Order By Key CUD2
For [CUD]
  If LSER =  ""
     LRET = 1
  Else
     If [F:CUD]ZERSTOFLG <> 2
        LRET = 1
     Endif
  Endif
  If LRET = 1
     Break
  Endif
Next
Filter [CUD]
End

########################################################################
# DEL_CUD                              suppression details d une session
########################################################################
Subprog DEL_CUD(LFCY,LSSS,LLIS,LRET)
Value    Char    LFCY
Value    Char    LSSS
Value    Char    LLIS
Variable Integer LRET
Local Char    WFILTRE(100)
Local Char    WLIS(GLONVCR)
WFILTRE  = "[F:CUD]STOFCY=LFCY & [F:CUD]CUNSSSNUM = LSSS"
If LLIS <> ""
    WFILTRE += "&[F:CUD]CUNLISNUM = LLIS"
Endif
LRET = 2
Local Integer WMAJSTO
Raz WMAJSTO
Local Char WCUNLISNUM
Raz WLIS
Raz [F:ITF]
Filter [CUD] Where evalue(WFILTRE)
&            Order By Key CUD0
For [CUD]
  Readlock [CUD] Curr
  If fstat
     LRET = 0
     Call FSTA("CUD") From GLOCK
     Break
  Endif
  If [F:CUD]ITMREF = ""
     Goto DELETE_CUD
  Endif
#Depositionnement flag en inventaire
  If [F:ITF]STOFCY <> LFCY | [F:ITF]ITMREF <> [F:CUD]ITMREF | WLIS <>  [F:CUD]CUNLISNUM
     WLIS = [F:CUD]CUNLISNUM
     Readlock [ITF]ITF0=[F:CUD]ITMREF;LFCY
     If fstat <> 5
        If fstat
           LRET = 0
           Break
        Endif
        WMAJSTO = 0
        Call EXI_LIS_BLO(LFCY,[F:ITF]ITMREF,[F:CUD]CUNLISNUM,WCUNLISNUM) From STKINV
        If WCUNLISNUM = ""
           [F:ITF]CUNLISNUM = ""
           [F:ITF]CUNFLG    = 1
        Else
           [F:ITF]CUNLISNUM = WCUNLISNUM
        Endif
        Rewrite [ITF]
        If fstat
           LRET = 0
           Call FSTA("ITF") From GLOCK
           Break

        Endif
     Else
        WMAJSTO = 1
     Endif
  Endif
# Dépositionnement flag inventaire et numero de liste sur STO
  If WMAJSTO = 0
     Call UPD_STO(LFCY,[F:CUD]STOCOU,[F:CUD]ITMREF,3,WCUNLISNUM) From STKINV
     Case fstat
          When 0, 4, 5 :
          When Default :
          LRET = 0
          Break
     Endcase
  Endif
# Suppression lot crée par l'inventaire
  Call SUP_LOT([F:CUD]ITMREF,LFCY,[F:CUD]LOT,[F:CUD]SLO,[F:CUD]CUNLISNUM)

$DELETE_CUD
# Effacement ligne inventaire
  Delete [CUD]
  If fstat
    LRET = 0
    Call FSTA("CUD") From GLOCK
    Break
  Endif
Next
Filter [CUD]
#                                                                        # hcb 110327 deb
If LRET <> 0
   Call DEL_CSD(LFCY,LSSS,LLIS,0,LRET) From STKINV1
Endif
#                                                                        # hcb 110327 end


End
########################################################################
# DEL_CUD_CUD                   suppression details d une liste sans maj
#                               suppression details d une liste sans maj avant rénumérotation
########################################################################
Subprog DEL_CUD_CUD(LFCY,LSSS,LLIS,LRET)
Value    Char    LFCY
Value    Char    LSSS
Value    Char    LLIS
Variable Integer LRET
LRET = 2
Delete [F:CUD] Where STOFCY     = LFCY      &
&                    CUNSSSNUM  = LSSS      &
&                    CUNLISNUM  = LLIS
End

########################################################################
# DEL_CUL                              suppression listes  d une session
########################################################################
Subprog DEL_CUL(LFCY,LSSS,LRET)
Value    Char    LFCY
Value    Char    LSSS
Variable Integer LRET
If !clalev([F:STJ])   Local File STOJOU     [STJ]  : Endif    # hcb 104062
LRET = 2
Delete [F:CUL] Where STOFCY     = LFCY      &
&                    CUNSSSNUM  = LSSS
#                                              # hcb 104062 deb
Delete  [STJ] Where STOFCY   = LFCY
&                         & UPDCOD   = 2
&                         & MVTIND   = 0
&                         & VCRTYP   = 9
&                         & VCRNUMORI= LSSS
&                         & REGFLG   = 2
#                                              # hcb 104062 fin


End

########################################################################
# DEL_CUL_LIS                                    suppression d une liste
########################################################################
Subprog DEL_CUL_LIS(LFCY,LSSS,LLIS,LRET)
Value    Char    LFCY
Value    Char    LSSS
Value    Char    LLIS
Variable Integer LRET
If !clalev([F:STJ])   Local File STOJOU     [STJ]  : Endif    # hcb 104062

LRET = 2
Delete [F:CUL] Where STOFCY     = LFCY      &
&                    CUNSSSNUM  = LSSS      &
&                    CUNLISNUM  = LLIS

#                                              # hcb 104062 deb
Delete  [STJ] Where STOFCY   = LFCY
&                         & UPDCOD   = 2
&                         & MVTIND   = 0
&                         & VCRTYP   = 9
&                         & VCRNUM   = LLIS
&                         & VCRNUMORI= LSSS
&                         & REGFLG   = 2
#                                              # hcb 104062 fin

End

########################################################################
# EXI_LIS          Recherche ligne d'inventaire même article non validée
########################################################################
Subprog EXI_LIS(LFCY,LITM,LLST,LLIS,LWRH)
Value    Char  LFCY
Value    Char  LITM
Value    Char  LLST
Variable Char  LLIS
Value    Char  LWRH

Local Char WFILSUP
WFILSUP = "1=1"
If LWRH <> ""
   WFILSUP = "[F:CUD1]WRH = LWRH"
Endif
If clalev([F:CUD1]) = 0 : Local File CUNLISDET [CUD1] : Endif
LLIS = ""
Filter [CUD1]  Where STOFCY     = LFCY              &
&                    ITMREF     = LITM              &
&                    CUNLISNUM <> LLST              &
&                    evalue(WFILSUP)                &
&                    CUNLISSTA <  3
&              Order By Key CUD1
For [CUD1]
  LLIS = [F:CUD1]CUNLISNUM
  Break
Next
Filter [CUD1]
Close Local File [CUD1]
End

########################################################################
# EXI_LIS_BLO   Recherche ligne d'inventaire même article non validée bloquée
########################################################################
Subprog EXI_LIS_BLO(LFCY,LITM,LLST,LLIS)
Value    Char  LFCY
Value    Char  LITM
Value    Char  LLST
Variable Char  LLIS
If clalev([F:CUD1]) = 0 : Local File CUNLISDET [CUD1] : Endif

LLIS = ""
Filter [CUD1]  Where STOFCY     = LFCY              &
&                    ITMREF     = LITM              &
&                    CUNLISNUM <> LLST              &
&                    CUNLOKFLG =  2                 &
&                    CUNLISSTA <  3
&              Order By Key CUD1
For [CUD1]
  LLIS = [F:CUD1]CUNLISNUM
  Break
Next
Filter [CUD1]
Close Local File [CUD1]
End

########################################################################
# SUP_LOT                    suppression des lots crées par l inventaire
########################################################################
Subprog SUP_LOT(LITM,LFCY,LLOT,LSLO,LLIS)
Value Char LITM
Value Char LFCY
Value Char LLOT
Value Char LSLO
Value Char LLIS
Local Integer I
If clalev([F:STL]) = 0 : Local File STOLOT    [STL] : Endif
If clalev([F:SLF]) = 0 : Local File STOLOTFCY [SLF] : Endif
Read[STL]STL0=LITM;LLOT;LSLO
If fstat = 0
  If [F:STL]VCRTYP    = 9                &
&    [F:STL]VCRNUM    = LLIS
    I = 0
    Filter [STO] Where ITMREF = LITM &
&                      STOFCY = LFCY &
&                      LOT    = LLOT &
&                      SLO    = LSLO
&                Order By Key STO3
    For [STO]
      I = 1
      Break
    Next
    Filter [STO]
    If I = 0
      Delete [STL]
      If fstat
        GOK = 0
        Call FSTA("STL") From GLOCK
        End
      Endif
      Read[SLF]SLF0=LITM;LLOT;LSLO;LFCY
      If fstat = 0
         Delete [SLF]
         If fstat
            GOK = 0
            Call FSTA("SLF") From GLOCK
         Endif
      Endif
    Endif
  Endif
Endif
End
########################################################################
# UPD_LOT                       Dépositionnement flag inventaire sur STO
########################################################################
Subprog UPD_STO(LFCY,LCOU,LITM,LFLG,LLIS)
Value Char    LFCY
Value Decimal LCOU
Value Char    LITM
Value Integer LFLG
Value Char    LLIS
If !clalev([F:STO])   Local File STOCK   [STO]  : Endif
If LFLG = 3
   Update [STO] Where STOFCY    = LFCY &
&                     STOCOU    = LCOU &
&                     ITMREF    = LITM
&               With  CUNLOKFLG = 1 , CUNLISNUM=""

Else
   Update [STO] Where STOFCY    = LFCY &
&                     STOCOU    = LCOU &
&                     ITMREF    = LITM
&               With  CUNLOKFLG = LFLG
Endif
End

########################################################################
# CRE_NEW_INV                          Creation nouvell liste inventaire
########################################################################
Subprog CRE_NEW_INV

If [M:SIW]NBLIG = 0
   End
Endif
If dim(GSIMSNU) > 0
   Gosub CAL_SIMULATION From SUBSNXA
   End
Endif
# Création du numéro de liste
If GSTKCPTMAN(06)<>2 | [M:SIW]CUNLISNUM = ""
   Call NUM_INV([M:SIW]STOFCY,[M:SIW]CUNLISDAT,[M:SIW]CUNLISNUM) From SUBSNXA
   If [M:SIW]CUNLISNUM = ""
      GOK = 0 :
      GERR = 1
      GMESSAGE= GSTKCPT(6)-":"-mess(104,117,1)
      End
   Endif
Endif
Gosub CRE_INV From STKINV
If GOK = 1
   If [F:CUN]CUNSSSTYP = 1
#comptage par classe abcd uniquement si type inventaire = article
      Gosub CAL_SEL From SUBSNXA
   Endif
   Raz [M:SIW]
Endif

End
########################################################################
# TRT_DEBLOCAGE                                Deblocage lignes de stock
#     LCUL = "O"  deblocage CUNLISTE
#     LCUL = "P"  deblocage partiel CUNLISTE
########################################################################
Subprog TRT_DEBLOCAGE(LFILTRE,CRITER1,LG,LCUL)
Value Char    LFILTRE
Value Char    CRITER1()()
Value Integer LG
Variable Char LCUL
Local Char    LSSS
Local Char    LLIS
Raz LSSS
Raz LLIS
Raz LCUL

Local Integer WOK
Call OUINON(mess(240,184,1)+"\"+mess(207,184,1),WOK) From GESECRAN
If WOK <> 2
   End
Endif

If CRITER1 = ""
   CRITER1 = "1=1"
Endif
Local Integer WMODIF
Raz WMODIF
Call DEBTRANS From GLOCK
Trbegin [CUD]

Filter [CUD] Where evalue(LFILTRE)&evalue(CRITER1)
&                Order By Key CUD0
For [CUD]
Readlock [CUD] Curr
If fstat
   GOK = 0
   Call FSTA("CUD") From GLOCK
   Gosub AB_TRT
   Break
Endif

# Dépositionnement flag blocage inventaire  sur STO
If [F:CUD]STOCOU <> 0
   Call UPD_STO([F:CUD]STOFCY,[F:CUD]STOCOU,[F:CUD]ITMREF,1,[F:CUD]CUNLISNUM) From STKINV
Endif

# Dépositionnement flag blocage inventaire sur CUD

[F:CUD]CUNLOKFLG = 1
[F:CUD]UPDUSR    = GUSER
[F:CUD]UPDDAT    = date$
If LSSS = ""
   LSSS = [F:CUD]CUNSSSNUM
Endif
If LLIS = ""
   LLIS = [F:CUD]CUNLISNUM
Endif

Rewrite [F:CUD]
If fstat
   GOK = 0
   Call FSTA("CUD") From GLOCK
   Gosub AB_TRT
   Break
Endif
WMODIF = 2
Next
Filter [CUD]
If GOK=0 End Endif

If WMODIF = 2

# Dépositionnement flag blocage inventaire sur CUL si tous les CUD sont dépositionnés

# verification que tous les CUD soient dépositionnés
   Filter [CUD] Where CUNSSSNUM = LSSS &
&                     CUNLISNUM = LLIS &
&                     CUNLOKFLG = 2

   Look [CUD]CUD0 First
   Filter [CUD]
   If fstat
      LCUL = "O"
   Else
      LCUL = "P"
   Endif
   Readlock [CUL]CUL0=LSSS;LLIS
   Case fstat
        When 0 :
        When 1 :
             GOK = -1
             GMESSAGE = mess(20,100,1)-"CUNLISTE"-LSSS
             Gosub AB_TRT
             End
        When Default :
             GOK = 0
             Call FSTA("CUL") From GLOCK
             Gosub AB_TRT
             End
       Endcase
   If LCUL = "O"
      [F:CUL]CUNLOKFLG = 1
   Else
      [F:CUL]CUNLOKFLG = 3
   Endif
   [F:CUL]UPDUSR    = GUSER
   [F:CUL]UPDDAT    = date$

   Rewrite  [CUL]
   If fstat
      GOK = 0
      Call FSTA("CUL") From GLOCK
      Gosub AB_TRT
      End
   Endif

# Dépositionnement flag blocage inventaire  sur ITF si tous les CUD sont dépositionnés
   If LCUL = "O"
      Filter [CUD] Where CUNSSSNUM = LSSS &
&                        CUNLISNUM = LLIS
&             Order By Key CUD0

      For [CUD]
          Read [CUD] Curr
          If fstat
             GOK = 0
             Call FSTA("CUD") From GLOCK
             Gosub AB_TRT
             Break
          Endif

      Local Char WCUNLISNUM
#Depositionnement flag en inventaire sur itf
      If [F:ITF]STOFCY <> [F:CUD]STOFCY | [F:ITF]ITMREF <> [F:CUD]ITMREF
         Readlock [ITF]ITF0=[F:CUD]ITMREF;[F:CUD]STOFCY
         If fstat
            GOK = 0
            Call FSTA("ITF") From GLOCK
            Gosub AB_TRT
            Break
         Endif
         Call EXI_LIS_BLO([F:CUD]STOFCY,[F:ITF]ITMREF,[F:CUD]CUNLISNUM,WCUNLISNUM) From STKINV
         If WCUNLISNUM = ""
            [F:ITF]CUNLISNUM = ""
            [F:ITF]CUNFLG    = 1
         Else
            [F:ITF]CUNLISNUM = WCUNLISNUM
         Endif
         Rewrite [ITF]
         If fstat
            GOK = 0
            Call FSTA("ITF") From GLOCK
            Gosub AB_TRT
            Break
         Endif
      Endif
      Next
      Filter [CUD]
      If GOK=0 End Endif
   Endif
Endif
Commit
End


########################################################################
# TRT_SUPPRESSION           Suppression de lignes ou article d une liste
########################################################################
Subprog TRT_SUPPRESSION(LFILTRE,LCRITER1,LART,LLIS,LFCY,LG)
Value Char    LFILTRE
Value Char    LCRITER1
Value Char    LART
Value Char    LLIS
Value Char    LFCY
Value Integer LG

Local Char    WCUNLISNUM
Local Integer WOK
Call OUINON(mess(215,184,1),WOK) From GESECRAN
If WOK <> 2
   End
Endif

Raz WCUNLISNUM
If LCRITER1 = ""
   LCRITER1 = "1=1"
Endif
Raz [F:ITF]
Call DEBTRANS From GLOCK
Trbegin [CUD]

Filter [CUD] Where evalue(LFILTRE)&evalue(LCRITER1)
&                Order By Key CUD0
For [CUD]
  Readlock [CUD] Curr
  If fstat
     GOK = 0
     Call FSTA("CUD") From GLOCK
     Break
  Endif
  If [F:CUD]ITMREF = ""
     Goto SUPPRES_CUD
  Endif
# Dépositionnement flag inventaire et numero de liste sur STO
  If [F:CUD]STOCOU <> 0
     Call UPD_STO(LFCY,[F:CUD]STOCOU,[F:CUD]ITMREF,3,"") From STKINV
     Case fstat
          When 0, 4, 5 :
          When Default :
               GOK = 0
               Break
     Endcase
  Endif

$SUPPRES_CUD
# Effacement ligne inventaire
#                                                                        # hcb 110327 deb
  If [F:CUD]SERSEQ <> 0
     Call DEL_CSD([F:CUD]STOFCY,[F:CUD]CUNSSSNUM,[F:CUD]CUNLISNUM,[F:CUD]SERSEQ,LG) From STKINV1
  Endif
#                                                                        # hcb 110327 end

  Delete [CUD]
  If fstat
    GOK = 0
    Call FSTA("CUD") From GLOCK
    Break
  Endif
Next
Filter [CUD]

If GOK <> 1
   Gosub AB_TRT From STKINV
Else

#Depositionnement flag en inventaire ITF
   If LART <> ""
      If [F:ITF]STOFCY <> LFCY | [F:ITF]ITMREF <> LART
         Readlock [ITF]ITF0=LART;LFCY
         If fstat
            Gosub AB_TRT From STKINV
            End
         Endif
         Call EXI_LIS_BLO(LFCY,[F:ITF]ITMREF,LLIS,WCUNLISNUM) From STKINV
         If WCUNLISNUM = ""
            [F:ITF]CUNLISNUM = ""
            [F:ITF]CUNFLG    = 1
         Else
            [F:ITF]CUNLISNUM = WCUNLISNUM
         Endif
         Rewrite [ITF]
         If fstat
            Gosub AB_TRT From STKINV
            End
         Endif
      Endif
   Endif
Commit

# initialisation à 1 rubrique ajout ligne d inventaire
GAJOUINV = 1

Endif

End


#########################################################################
# LOAD_SNL3                             Chargement de l onglet liste SNL3
#########################################################################
Subprog LOAD_SNL3
Raz [M:SNL3]
Local Integer I
I = 0

Filter [CUL] Where [F:CUL]CUNSSSNUM = [F:CUN]CUNSSSNUM & [F:CUL]CUNLISSTA <> 2
& Order By Key CUL0

For [CUL]

    If I > dim([SNL3]CUNLISNUM)-1 : Break : Endif
    If I >  GCOD_INL : Break : Endif
    [M:SNL3]CUNLISNUM    (I) = [F:CUL]CUNLISNUM
    [M:SNL3]NBRLIG       (I) = [F:CUL]NBRLIG
    [M:SNL3]CUNLISSTA    (I) = [F:CUL]CUNLISSTA
    [M:SNL3]CUNLOKFLG    (I) = [F:CUL]CUNLOKFLG
    [M:SNL3]CUNSTADAT    (I) = [F:CUL]CUNSTADAT
    [M:SNL3]USR          (I) = [F:CUL]USR
    [M:SNL3]CUNLISDES    (I) = [F:CUL]CUNLISDES
    If  [M:SNL3]USR      (I) = ""
        [M:SNL3]USR      (I) = [F:CUL]UPDUSR
         If  [M:SNL3]USR (I) = ""
             [M:SNL3]USR (I) = [F:CUL]CREUSR
         Endif
    Endif
    I += 1
Next
[M:SNL3]NBLIG = I
Filter [CUL]

Affzo [M:SNL3]
End

########################################################################
# DEF_CRITERE_RGP                        Définition critère regroupement
########################################################################
Subprog DEF_CRITERE_RGP(LABR,LG,CRIT_RGP,RGP_FILTRE,RGP_FILTRE1,RGP_FILTRE2)
Value Char    LABR
Value Decimal LG
Variable Char CRIT_RGP()()
Variable Char RGP_FILTRE                                                                  # hcb 71659
Variable Char RGP_FILTRE1                                                                 # hcb 71659
Variable Char RGP_FILTRE2                                                                 # hcb 71659
RGP_FILTRE  = "1=1"                                                                       # hcb 71659
RGP_FILTRE1 = "1=1"                                                                       # hcb 71659
RGP_FILTRE2 = "1=1"                                                                       # hcb 71659
RGP_FILTRE += "&[F:CUD1]CUNSSSNUM=[M:SNL0]CUNSSSNUM&[F:CUD1]CUNLISNUM=[M:SNL0]CUNLISNUM"  # hcb 71659

Raz CRIT_RGP
Raz GBIDI1
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 6 | [F:SRT]SRTNUM <> GSNLNUM                   # hcb 50197
    Read [SRT]SRT0=6;GSNLNUM : If fstat Raz [F:SRT] : Endif
Endif


If dim([M:SNL0]ITMREF)>0
   Call ADDCRIT(CRIT_RGP,GBIDI1,"CRIT_RGP","[F:CUD]ITMREF=[M:SNL0]ITMREF(LG)","&") From GOBJSUB
   RGP_FILTRE1 += "&[F:CUD1]ITMREF=[M:SNL0]ITMREF(LLIG)"                                  # hcb 71659
Endif
If [F:CUN]CUNSSSTYP = 2
   If dim([M:SNL0]LOC1)>0
      Call ADDCRIT(CRIT_RGP,GBIDI1,"CRIT_RGP","[F:CUD]LOC=[M:SNL0]LOC(LG)","&") From GOBJSUB
      RGP_FILTRE1 += "&[F:CUD1]LOC=[M:SNL0]LOC(LLIG)"                                     # hcb 71659
   Endif
Endif
If [F:SRT]LOCCOD = 1
   If dim([M:SNL0]LOC)>0
      Call ADDCRIT(CRIT_RGP,GBIDI1,"CRIT_RGP","[F:CUD]LOC=[M:SNL0]LOC(LG)","&") From GOBJSUB
      RGP_FILTRE1 += "&[F:CUD1]LOC=[M:SNL0]LOC(LLIG)"                                     # hcb 71659
   Endif
Endif
If [F:SRT]LPNCOD = 1                                                                      # hcb x3-68147
   If dim([M:SNL0]LPNNUM)>0
      Call ADDCRIT(CRIT_RGP,GBIDI1,"CRIT_RGP","[F:CUD]LPNNUM=[M:SNL0]LPNNUM(LG)","&") From GOBJSUB
      RGP_FILTRE1 += "&[F:CUD1]LOC=[M:SNL0]LPNNUM(LLIG)"
   Endif
Endif
If [F:SRT]LOTCOD = 1
   If dim([M:SNL0]LOT)>0
      Call ADDCRIT(CRIT_RGP,GBIDI1,"CRIT_RGP","[F:CUD]LOT=[M:SNL0]LOT(LG)","&") From GOBJSUB
      RGP_FILTRE1 += "&[F:CUD1]LOT=[M:SNL0]LOT(LLIG)"                                     # hcb 71659
   Endif
Endif
If [F:SRT]SLOCOD = 1
   If dim([M:SNL0]SLO)>0
      Call ADDCRIT(CRIT_RGP,GBIDI1,"CRIT_RGP","[F:CUD]SLO=[M:SNL0]SLO(LG)","&") From GOBJSUB
      RGP_FILTRE1 += "&[F:CUD1]SLO=[M:SNL0]SLO(LLIG)"                                     # hcb 71659
   Endif
Endif
If dim([M:SNL0]PCU)>0
   Call ADDCRIT(CRIT_RGP,GBIDI1,"CRIT_RGP","[F:CUD]PCU=[M:SNL0]PCU(LG)","&") From GOBJSUB
   RGP_FILTRE1 += "&[F:CUD1]PCU=[M:SNL0]PCU(LLIG)"                                        # hcb 71659
Endif
If dim([M:SNL0]PCUSTUCOE)>0
   Call ADDCRIT(CRIT_RGP,GBIDI1,"CRIT_RGP","[F:CUD]PCUSTUCOE=[M:SNL0]PCUSTUCOE(LG)","&") From GOBJSUB
   RGP_FILTRE2 += "&[F:CUD1]PCUSTUCOE=[M:SNL0]PCUSTUCOE(LLIG)"                            # hcb 71659
Endif
If [F:SRT]STACOD = 1
   If dim([M:SNL0]STA)>0
      Call ADDCRIT(CRIT_RGP,GBIDI1,"CRIT_RGP","[F:CUD]STA=[M:SNL0]STA(LG)","&") From GOBJSUB
      RGP_FILTRE2 += "&[F:CUD1]STA=[M:SNL0]STA(LLIG)"                                     # hcb 71659
   Endif
Endif
If [F:SRT]SERCOD = 1
   If dim([M:SNL0]SERNUM)>0
      Call ADDCRIT(CRIT_RGP,GBIDI1,"CRIT_RGP","[F:CUD]SERNUM=[M:SNL0]SERNUM(LG)","&") From GOBJSUB
      RGP_FILTRE2 += "&[F:CUD1]SERNUM=[M:SNL0]SERNUM(LLIG)"                               # hcb 71659
   Endif
Endif

If [F:SRT]IDECOD1 = 1
   If dim([M:SNL0]PALNUM)>0
      Call ADDCRIT(CRIT_RGP,GBIDI1,"CRIT_RGP","[F:CUD]PALNUM=[M:SNL0]PALNUM(LG)","&") From GOBJSUB
      RGP_FILTRE2 += "&[F:CUD1]PALNUM=[M:SNL0]PALNUM(LLIG)"                               # hcb 71659
   Endif
Endif
If [F:SRT]IDECOD2 = 1
   If dim([M:SNL0]CTRNUM)>0
      Call ADDCRIT(CRIT_RGP,GBIDI1,"CRIT_RGP","[F:CUD]CTRNUM=[M:SNL0]CTRNUM(LG)","&") From GOBJSUB
      RGP_FILTRE2 += "&[F:CUD1]CTRNUM=[M:SNL0]CTRNUM(LLIG)"                               # hcb 71659
   Endif
Endif
If [F:SRT]WRHCOD = 1
   If dim([M:SNL0]WRH)>0
      Call ADDCRIT(CRIT_RGP,GBIDI1,"CRIT_RGP","[F:CUD]WRH=[M:SNL0]WRH(LG)","&") From GOBJSUB
      RGP_FILTRE2 += "&[F:CUD1]WRH=[M:SNL0]WRH(LLIG)"                                     # hcb 71659
   Endif
Endif

End
########################################################################
# VPD_DISZO_RGP       Valeurs par defaut et desactivation rubriques SNL1
########################################################################
Subprog VPD_DISZO_RGP(LABR,LG,NOL,DZO)
Value Char    LABR
Value Decimal LG
Value Decimal NOL
Value Integer DZO
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 6 | [F:SRT]SRTNUM <> GSNLNUM                   # hcb 50197
    Read [SRT]SRT0=6;GSNLNUM : If fstat Raz [F:SRT] : Endif
Endif

If [F:CUN]CUNSSSTYP = 2
   If dim([M:SNL0]LOC1)>0
      If dim([M:SNL1]LOC)>0
         [M:SNL1]LOC = [M:SNL0]LOC(LG)
         If DZO = 2
            Grizo  [M:SNL1]LOC
         Endif
      Endif
   Endif
Endif
If [F:SRT]LPNCOD = 1                                                    # hcb x3-68147
   If dim([M:SNL0]LPNNUM)>0
      If dim([M:SNL1]LPNNUM)>0
         [M:SNL1]LPNNUM = [M:SNL0]LPNNUM(LG)
         If DZO = 2
            Grizo  [M:SNL1]LPNNUM
         Endif
      Endif
   Endif
Endif

If [F:SRT]LOCCOD = 1
   If dim([M:SNL0]LOC)>0
      If dim([M:SNL1]LOC)>0
         [M:SNL1]LOC = [M:SNL0]LOC(LG)
         If DZO = 2
            Grizo  [M:SNL1]LOC
         Endif
      Endif
   Endif
Endif
If [F:SRT]LOTCOD = 1
   If dim([M:SNL0]LOT)>0
      If dim([M:SNL1]LOT)>0
         [M:SNL1]LOT = [M:SNL0]LOT(LG)
         If DZO = 2
            Grizo  [M:SNL1]LOT
         Endif
      Endif
   Endif
Endif
If [F:SRT]SLOCOD = 1
   If dim([M:SNL0]SLO)>0
      If dim([M:SNL1]SLO)>0
         [M:SNL1]SLO = [M:SNL0]SLO(LG)
         If DZO = 2
            Grizo  [M:SNL1]SLO
         Endif
      Endif
   Endif
Endif
If dim([M:SNL0]PCU)>0
   If dim([M:SNL1]PCU)>0
      [M:SNL1]PCU = [M:SNL0]PCU(LG)
      If DZO = 2
         Grizo  [M:SNL1]PCU
      Endif
   Endif
Endif

If dim([M:SNL0]PCUSTUCOE)>0
   If dim([M:SNL1]PCUSTUCOE)>0
      [M:SNL1]PCUSTUCOE = [M:SNL0]PCUSTUCOE(LG)
   Endif
   If dim([M:SNL1]PCUSTUNEW)>0
      [M:SNL1]PCUSTUNEW = [M:SNL0]PCUSTUCOE(LG)
      If DZO = 2
         Grizo  [M:SNL1]PCUSTUNEW
      Endif
   Endif
Endif
#                                                                                         # hcb 71659 deb
   If [M:SNL0]MULCTGFLG = 2
      [M:SNL1]PCUSTUNEW1 = [M:SNL0]PCUSTUCOE(LG)
      If DZO = 2
         Grizo  [M:SNL1]PCUSTUNEW1
      Endif
      [M:SNL1]PCUSTUNEW2 = [M:SNL0]PCUSTUCOE(LG)
      If DZO = 2
         Grizo  [M:SNL1]PCUSTUNEW2
      Endif
   Endif
#                                                                                         # hcb 71659 fin


If [F:SRT]STACOD = 1
   If dim([M:SNL0]STA)>0
      If dim([M:SNL1]STA)>0
         [M:SNL1]STA = [M:SNL0]STA(LG)
         If DZO = 2
            Grizo  [M:SNL1]STA
         Endif
      Endif
   Endif
Endif


If [F:SRT]IDECOD1 = 1
   If dim([M:SNL0]PALNUM)>0
      If dim([M:SNL1]PALNUM)>0
         [M:SNL1]PALNUM = [M:SNL0]PALNUM(LG)
         If DZO = 2
            Grizo  [M:SNL1]PALNUM
         Endif
      Endif
   Endif
Endif

If [F:SRT]IDECOD2 = 1
   If dim([M:SNL0]CTRNUM)>0
      If dim([M:SNL1]CTRNUM)>0
         [M:SNL1]CTRNUM = [M:SNL0]CTRNUM(LG)
         If DZO = 2
            Grizo  [M:SNL1]CTRNUM
         Endif
      Endif
   Endif
Endif

If [F:SRT]WRHCOD = 1
   If dim([M:SNL0]WRH)>0
      If dim([M:SNL1]WRH)>0
         [M:SNL1]WRH = [M:SNL0]WRH(LG)
         If DZO = 2
            Grizo  [M:SNL1]WRH
         Endif
      Endif
   Endif
Endif

End

########################################################################
# RENUM                 Renumérotation des numéros de ligne 1000 en 1000
# LSCR = classe écran exemple "[M:INV2]"
# LTAB = Nom champs bas de tableau
# LZON = Nom champs numéro
########################################################################
Subprog RENUM(LSCR,LTAB,LZON,LRET)
Value    Char     LSCR
Value    Char     LTAB
Value    Char     LZON
Variable Integer  LRET
#
Local    Char     WTAB(30) : WTAB = LSCR+LTAB+"-1"
Local    Char     WZOI(30) : WZOI = LSCR+LZON+"(I)"
Local    Char     WZOJ(30) : WZOJ = LSCR+LZON+"(J)"
#
Local    Decimal  WRK1, WRK2, WRK3
Local    Integer  I, J, K
#
Raz WRK1,WRK2, WRK3, LRET
For I = 0 To evalue(WTAB)
  If evalue(WZOI) <> 0
    WRK1 = evalue(WZOI)
  Else
    K    = 1
    WRK2 = 0
    For J = I To evalue(WTAB)
      If evalue(WZOJ) = 0
        K += 1
      Else
        WRK2 = evalue(WZOJ)
        Break
      Endif
    Next J
    If WRK2 = 0
      For J = I To evalue(WTAB)
        Assign WZOJ With WRK1+1000
        WRK1 += 1000
      Next J
    Else
      WRK3 = int((WRK2-WRK1)/K)
      If WRK3 <= 0
        LRET = 1
        Break 2
      Endif
      For J = I To evalue(WTAB)
        If evalue(WZOJ) = 0
          Assign WZOJ With WRK1+WRK3
          WRK1  += WRK3
        Else
          Break
        Endif
      Next J
    Endif
  Endif
Next I
End
########################################################################
#  PASSAISNL0                          desactivation rubrique ecran SNL0
########################################################################
Subprog PASSAISNL0(LZON,LLIN)                                                             # hcb 71659
Value    Char     LZON                                                                    # hcb 71659
Value    Integer  LLIN                                                                    # hcb 71659

# si validée ou cloturée pas de modif possible
If [F:CUL]CUNLISSTA > 4
    mkstat=2
Endif
#                                                                                         # hcb 71659 deb

Case LZON
     When "QTYPCUNEW"
          # si comptage present pas de saisie
          Gosub CTR_COMPTAGE From SUBSNL
          If [M:SNL0]PCU(nolign-1) = ""
             mkstat = 2
          Endif
     When "QTYSTUNEW"
          # si comptage present pas de saisie
          Gosub CTR_COMPTAGE From  SUBSNL
          #si saisie UC alors Saisie US desactivée
          If [M:SNL0]QTYPCUNEW(nolign-1) <> 0
             mkstat = 2
          Endif
     When "ZERSTOFLG"
          If [M:SNL0]QTYSTUNEW(nolign-1) <> 0
             mkstat = 2
          Endif
          If [M:SNL0]CUNLISSTAD(nolign-1) > 1
             mkstat = 2
          Endif
Endcase

If [M:SNL0]MULCTGFLG = 2
   Case LZON
        When "QTYPCUNEW", "QTYSTUNEW", "ZERSTOFLG"
              If [M:SNL0]CTG1(nolign-1) <> 2
                 mkstat=2
              Endif
              If [M:SNL0]CTG2(nolign-1) <> 2
                 mkstat=2
              Endif
        When "QTYPCUNEW1"
              If [M:SNL0]CTG1(nolign-1) =  2
                 mkstat=2
              Endif
             # si comptage present pas de saisie
             Gosub CTR_COMPTAGE1 From SUBSNL
             If [M:SNL0]PCU(nolign-1) = ""
                mkstat = 2
             Endif
        When "QTYSTUNEW1"
              If [M:SNL0]CTG1(nolign-1) =  2
                 mkstat=2
              Endif
             # si comptage present pas de saisie
             Gosub CTR_COMPTAGE1 From  SUBSNL
             #si saisie UC alors Saisie US desactivée
             If [M:SNL0]QTYPCUNEW1(nolign-1) <> 0
                mkstat = 2
             Endif
        When "ZERSTOFLG1"
              If [M:SNL0]CTG1(nolign-1) =  2
                 mkstat=2
              Endif
             If [M:SNL0]QTYSTUNEW1(nolign-1) <> 0
                mkstat = 2
             Endif
             If [M:SNL0]CUNLISSTAD(nolign-1) > 1
                mkstat = 2
             Endif
        When "QTYPCUNEW2"
              If [M:SNL0]CTG1(nolign-1) <> 2
                 mkstat=2
              Endif
              If [M:SNL0]CTG2(nolign-1) =  2
                 mkstat=2
              Endif
             # si comptage present pas de saisie
             Gosub CTR_COMPTAGE2 From SUBSNL
             If [M:SNL0]PCU(nolign-1) = ""
                mkstat = 2
             Endif
        When "QTYSTUNEW2"
              If [M:SNL0]CTG1(nolign-1) <> 2
                 mkstat=2
              Endif
              If [M:SNL0]CTG2(nolign-1) =  2
                 mkstat=2
              Endif
             # si comptage present pas de saisie
             Gosub CTR_COMPTAGE2 From  SUBSNL
             #si saisie UC alors Saisie US desactivée
             If [M:SNL0]QTYPCUNEW2(nolign-1) <> 0
                mkstat = 2
             Endif
        When "ZERSTOFLG2"
              If [M:SNL0]CTG1(nolign-1) <> 2
                 mkstat=2
              Endif
              If [M:SNL0]CTG2(nolign-1) =  2
                 mkstat=2
              Endif
             If [M:SNL0]QTYSTUNEW2(nolign-1) <> 0
                mkstat = 2
             Endif
             If [M:SNL0]CUNLISSTAD(nolign-1) > 1
                mkstat = 2
             Endif
   Endcase
Endif
#                                                                                         # hcb 71659 fin

End

########################################################################
#  PASSAISNL1     desactivation rubrique ecran SNL1 (statut + zerstoflg)
########################################################################
Subprog PASSAISNL1(LZON,LLIN)                                                             # hcb 71659
Value    Char     LZON                                                                    # hcb 71659
Value    Integer  LLIN                                                                    # hcb 71659

# si nouvelle ligne on permet tout
If [M:SNL1]LINFLG(nolign-1) <> 2 & [M:SNL0]MULCTGFLG <> 2                                 # hcb 71659
   End
Endif

# si liste validée ou cloturée pas de modif possible
If [F:CUL]CUNLISSTA > 4
    mkstat=2
    End
Endif
#si detail validé ou abandonnée pas de modif possible
If [M:SNL1]CUNLISSTA(nolign-1) > 2
   mkstat = 2
   End
Endif

If [M:SNL1]ZERSTOFLG (nolign-1) = 2
   mkstat=2
   End
Endif
#
#


#                                                                                      # hcb 71659 deb
Case LZON
     When "LOC", "LOT" , "SLO" , "PCU", "STA", "SERNUM", "PALNUM", "CTRNUM" , "STOFLD1", "STOFLD2", "OWNER", "LPNNUM"   # hcb x3-68147
           If [M:SNL1]STOCOU(nolign-1) <> 0
              mkstat=2
            Endif
Endcase

If [M:SNL0]MULCTGFLG = 2
   Case LZON
        When "QTYPCUNEW1", "QTYSTUNEW1" , "PCUSTUNEW1","ZERSTOFLG1"
              If [M:SNL1]CTG1(nolign-1) =  2
                 mkstat=2
              Endif
              If [M:SNL1]ZERSTOFLG1 (nolign-1) = 2
                 mkstat=2
              Endif
        When "QTYPCUNEW2", "QTYSTUNEW2" , "PCUSTUNEW2","ZERSTOFLG2"
              If [M:SNL1]CTG1(nolign-1) <> 2
                 mkstat=2
              Endif
              If [M:SNL1]CTG2(nolign-1) =  2
                 mkstat=2
              Endif
              If [M:SNL1]ZERSTOFLG2 (nolign-1) = 2
                 mkstat=2
              Endif

        When "QTYPCUNEW",  "QTYSTUNEW" ,  "PCUSTUNEW","ZERSTOFLG"
              If [M:SNL1]CTG1(nolign-1) <> 2
                 mkstat=2
              Endif
              If [M:SNL1]CTG2(nolign-1) <> 2
                 mkstat=2
              Endif
   Endcase

Endif
#                                                                                         # hcb 71659 fin

End
########################################################################
#  PASSAISNL                  desactivation rubrique ecran SNL1 (statut)
########################################################################
Subprog PASSAISNL(LZON,LLIN)                                                              # hcb 71659
Value    Char     LZON                                                                    # hcb 71659
Value    Integer  LLIN                                                                    # hcb 71659
# si liste validée ou cloturée pas de modif possible
If [F:CUL]CUNLISSTA > 4
    mkstat=2
    End
Endif
#si detail validé ou abandonnée pas de modif possible
If [M:SNL1]CUNLISSTA(LLIN) > 2
   mkstat = 2
   End
Endif
#                                                                                         # hcb 71659 deb
If [M:SNL0]MULCTGFLG = 2
   Case LZON
        When  "ZERSTOFLG1"
              If [M:SNL1]CTG1(LLIN) =  2
                 mkstat=2
              Endif
        When  "ZERSTOFLG2"
              If [M:SNL1]CTG1(LLIN) <> 2
                 mkstat=2
              Endif
              If [M:SNL1]CTG2(LLIN) =  2
                 mkstat=2
              Endif
        When  "ZERSTOFLG"
              If [M:SNL1]CTG1(LLIN) <> 2
                 mkstat=2
              Endif
              If [M:SNL1]CTG2(LLIN) <> 2
                 mkstat=2
              Endif
   Endcase
Endif
#                                                                                         # hcb 71659 fin
End

########################################################################
# TRT_CLOTURE                                              Cloture liste
#     LCUL = "L"  Cloture liste CUNLISTE
#     LCUL = "S"  Cloture liste et Session CUNLISTE / CUNSESSION
########################################################################
Subprog TRT_CLOTURE(LFILTRE,CRITER1,LG,LCUL,LSSS,LLIS)
Value Char    LFILTRE
Value Char    CRITER1
Value Integer LG
Variable Char LCUL
Value Char    LSSS
Value Char    LLIS
Raz LCUL
Local Integer WOK
Raz WOK
Raz [F:ITF]

If CRITER1 = ""
   CRITER1 = "1=1"
Endif

# verification que tous les CUD soient validés ou annulés

Filter [CUD] Where evalue(LFILTRE)&evalue(CRITER1)
&                Order By Key CUD0
Look [CUD]CUD0 First
Filter [CUD]

If !fstat
   Call OUINON(mess(40,184,1),WOK) From GESECRAN      # cloture impossible des détails ne sont pas validés
      If WOK <> 2
         mkstat = 2
         End
      Endif
Endif

Call DEBTRANS From GLOCK
Trbegin [CUD]

# positionnement flag statut "abandonné"  sur CUD si pas validée
If WOK = 2
   Filter [CUD] Where evalue(LFILTRE)&evalue(CRITER1)
&                Order By Key CUD0
   For [CUD]
   Readlock [CUD] Curr
   If fstat
      GOK = 0
      Call FSTA("CUD") From GLOCK
      Gosub AB_TRT
      Break
   Endif

# Dépositionnement flag blocage inventaire  et numero de liste sur STO
    If [F:CUD]STOCOU <> 0                                #      hcb 31139
       Call UPD_STO([F:CUD]STOFCY,[F:CUD]STOCOU,[F:CUD]ITMREF,3,[F:CUD]CUNLISNUM) From STKINV
   Endif
   Local Char WCUNLISNUM
#Depositionnement flag en inventaire sur itf
   If [F:ITF]STOFCY <> [F:CUD]STOFCY | [F:ITF]ITMREF <> [F:CUD]ITMREF
      Readlock [ITF]ITF0=[F:CUD]ITMREF;[F:CUD]STOFCY
      If fstat
         GOK = 0
         Call FSTA("ITF") From GLOCK
         Gosub AB_TRT
         Break
      Endif
      Call EXI_LIS_BLO([F:CUD]STOFCY,[F:ITF]ITMREF,[F:CUD]CUNLISNUM,WCUNLISNUM) From STKINV
      If WCUNLISNUM = ""
         [F:ITF]CUNLISNUM = ""
         [F:ITF]CUNFLG    = 1
      Else
         [F:ITF]CUNLISNUM = WCUNLISNUM
      Endif
      Rewrite [ITF]
      If fstat
         GOK = 0
         Call FSTA("ITF") From GLOCK
         Gosub AB_TRT
         Break
      Endif
   Endif

# Dépositionnement flag blocage inventaire sur CUD
   [F:CUD]CUNLOKFLG = 1
# mis en statut "abandonné"
   [F:CUD]CUNLISSTA = 3
   [F:CUD]UPDUSR    = GUSER
   [F:CUD]UPDDAT    = date$

   Rewrite [F:CUD]
   If fstat
      GOK = 0
      Call FSTA("CUD") From GLOCK
      Gosub AB_TRT
      Break
   Endif

   Next
   Filter [CUD]
   If GOK=0 End Endif
Endif

# mis en statut "clos" sur CUL

Readlock [CUL]CUL0=LSSS;LLIS
Case fstat
     When 0 :
     When 1 :
          GOK = -1
          GMESSAGE = mess(20,100,1)-"CUNLISTE"-LSSS
          Gosub AB_TRT
          End
     When Default :
          GOK = 0
          Call FSTA("CUL") From GLOCK
          Gosub AB_TRT
          End
Endcase
# Dépositionnement flag blocage inventaire sur CUL si positionné
If  [F:CUL]CUNLOKFLG <>1
    [F:CUL]CUNLOKFLG = 1
Endif
[F:CUL]CUNLISSTA = 6
[F:CUL]UPDUSR    = GUSER
[F:CUL]UPDDAT    = date$

Rewrite  [CUL]
If fstat
   GOK = 0
   Call FSTA("CUL") From GLOCK
   Gosub AB_TRT
   End
Endif
LCUL = "L"

# verification si tous les CUL sont clos
   Filter [CUL] Where CUNSSSNUM = LSSS &
&                     CUNLISSTA <> 6

   Look [CUL]CUL0 First
   Filter [CUL]
# si tous clos statut de la session à clos
   If fstat
      Readlock [CUN]CUN0=LSSS
      Case fstat
            When 0 :
            When 1 :
                 GOK = -1
                 GMESSAGE = mess(20,100,1)-"CUNSESSION"-LSSS
                 Gosub AB_TRT
                 End
            When Default :
                 GOK = 0
                 Call FSTA("CUN") From GLOCK
                 Gosub AB_TRT
                 End
      Endcase
      [F:CUN]CUNSSSSTA = 3
      [F:CUN]UPDUSR    = GUSER
      [F:CUN]UPDDAT    = date$

      Rewrite  [CUN]
      If fstat
         GOK = 0
         Call FSTA("CUN") From GLOCK
         Gosub AB_TRT
         End
      Endif
#                                 # hcb  106202 deb
      If !clalev([F:STJ])   Local File STOJOU     [STJ]  : Endif
      Delete  [STJ] Where STOFCY   = [F:CUN]STOFCY
&                       & UPDCOD   = 2
&                       & MVTIND   = 0
&                       & VCRTYP   = 9
&                       & VCRNUMORI= LSSS
&                       & REGFLG   = 2
#                                 # hcb 106202 fin
      LCUL = "S"
Endif
Commit
End

########################################################################
# TRT_VALIDATION                                        Validation liste
#     LCUL = "D"  Validation détail  CUNLISDET
#     LCUL = "L"  Validation liste   CUNLISTE
########################################################################
Subprog TRT_VALIDATION(LFILTRE,CRITER1,LG,LCUL,LSSS,LLIS)
Value Char    LFILTRE
Value Char    CRITER1
Value Integer LG
Variable Char LCUL
Value Char    LSSS
Value Char    LLIS
Raz LCUL
Local Integer WOK
Local Integer I
Local Integer WNBRLIG       # hcb 35876

Raz WOK
# Attention les comptages validés ne seront plus modifiables
If !GIMPORT
   Call OUINON(mess(379,184,1),WOK) From GESECRAN
   If WOK <> 2
      End
   Endif
   Raz WOK
Endif


# si ajout de lignes il faut renumeroter la liste
If GAJOUINV = 1
# renumerotation
   Gosub RENUM_CUD From STKINV
   If !GOK
      End
   Endif
Else                                                 # hcb 25876 deb
   Raz WNBRLIG
#comptage nombre de ligne
   Filter [CUD] Where [F:CUD]CUNSSSNUM = LSSS &
&                     [F:CUD]CUNLISNUM = LLIS
&               Order By Key CUD0
   For [CUD]
       WNBRLIG += 1
   Next
   Filter [CUD]
   If WNBRLIG <> [F:CUL]NBRLIG
      Gosub RENUM_CUD From STKINV
      If !GOK
         End
      Endif
   Endif                                             # hcb 25876 fin
Endif

If clalev([M:STW])=0   Local Mask STOWORK   [STW]    Endif  #  ecran stockage mvt à mettre à jour
If !clalev([M:VALW]) : Local Mask STOVALW   [VALW] : Endif
Raz [M:VALW]
If !clalev([M:SVW])  : Local Mask STOVALWORK [SVW] : Endif
If clalev([F:CUD1]) = 0 : Local File CUNLISDET [CUD1] : Endif                      # hcb x3-68147
Raz WOK
If CRITER1 = ""
   CRITER1 = "1=1"
Endif

# tableau des articles validables
Local Char    TITM(GLONITM)([F:CUL]NBRLIG)
# tableau erreur
Local Integer TERR    ([F:CUL]NBRLIG)
Local Integer IITM

Raz TITM, TERR, IITM

If !GIMPORT
   Call OUVRE_TRACE(mess(10,725,1)-LSSS-LLIS) From LECFIC
Endif
# selection sur  site , session , liste , detail compté

#recensement des articles validables donc  comptes
Filter [CUD] Where evalue(LFILTRE)&evalue(CRITER1) & [F:CUD]CUNLISSTA = 2
&            Order By Key CUD0
For [CUD]
    If !find([F:CUD]ITMREF,TITM(0..IITM))
       TITM(IITM) = [F:CUD]ITMREF
       IITM += 1
    Endif
#                                                                     # hcb 110327 deb
# si la ligne d'iventaire gere les séries global il faut controler que la qty comptée soit cohérente avec la table CUNSERDET
    If [F:CUD]SERSEQ <> 0
       Gosub CTR_CUD_CSD From STKINV1
       If WOK <> 0
          Break
       Endif
    Endif
#                                                                     # hcb 110327 fin

#                                                                     # hcb x3-68147  deb
# sur nouvelle ligne d'iventaire si l article gere les contenants il faut controler la coherence de l emplacement du contenant
    If [F:CUD]STOCOU = 0 & [F:CUD]LPNNUM <> ""
       Call CTR_CUD_LPN([F:CUD]CUNSSSNUM,[F:CUD]CUNLISNUM,[F:CUD]LPNNUM,[F:CUD]LOC,WOK) From STKINV1
       If WOK <> 0
          Break
       Endif
    Endif
#                                                                     # hcb x3-68147 fin
Next
Filter [CUD]

#                                                                     # hcb 110327 deb
If WOK <> 0
   End
Endif
#                                                                     # hcb 110327 fi

# controle que pour chaque article il ni ai plus de comptage à faire
For I = 0 To IITM-1
    Filter [CUD] Where evalue(LFILTRE)&evalue(CRITER1) & [F:CUD]CUNLISSTA = 1  & [F:CUD]ITMREF = TITM(I)
&                Order By Key CUD0

    Look [CUD]CUD0 First
    Filter [CUD]
    If !fstat
       Gosub ECR_TRACE_ARTICLE
       TITM(I) = ""
       TERR(I) = 1
    Endif
    If TITM(I) <> "" & [M:SNL0]IPTDAT < [M:SNL0]CREDAT
       Call TRT_CTR_IPTDAT([M:SNL0]STOFCY,TITM(I),"","",[M:SNL0]IPTDAT,[M:SNL0]CREDAT,"VAL","",WOK) From STKINV
       If WOK = 9
          Break
       Endif
    Endif
Next I
If WOK = 9
   End
Endif

If sum(TERR(0..IITM-1)) = IITM
# Aucun article à traiter en validation
   If GIMPORT
      Call ECR_TRACE(mess(291,199,1)-" : "-LSSS-","-LLIS,0) From GESECRAN
   Else
      Call ERREUR(mess(291,199,1)) From GESECRAN
   Endif
Else
   For I = 0 To IITM-1
       If TITM(I) <> ""
          Gosub MAJ_INVENTAIRE From STKINV
       Endif
   Next I
Endif


Local Integer WVALID
Raz WVALID
# WVALID = 0 pas de detail validé
# WVALID = 4 au moins un détail de validé
# WVALID = 5 plus de détail a valider

# y a t il au moins un detail de validé
Filter [CUD] Where evalue(LFILTRE)&evalue(CRITER1) & [F:CUD]CUNLISSTA = 4
&            Order By Key CUD0

Look [CUD]CUD0 First
Filter [CUD]
# si tous clos statut de la session à clos
If !fstat
   WVALID = 4
Endif

If WVALID = 4
   Call DEBTRANS From GLOCK
   Trbegin [CUD]

# y a t il encore des details a validé
   Filter [CUD] Where evalue(LFILTRE)&evalue(CRITER1) & [F:CUD]CUNLISSTA < 3
&               Order By Key CUD0

   Look [CUD]CUD0 First
   Filter [CUD]
   If fstat
      WVALID = 5
   Endif

#maj  liste inventaire
   Readlock [CUL]CUL0=LSSS;LLIS
   Case fstat
        When 0 :
        When 1 :
             GOK = -1
             GMESSAGE = mess(20,100,1)-"CUNLISTE"-LSSS
             Gosub AB_TRT
             End
        When Default :
             GOK = 0
             Call FSTA("CUL") From GLOCK
             Gosub AB_TRT
             End
   Endcase
     [F:CUL]CUNLISSTA = WVALID
     If WVALID = 5
       [F:CUL]CUNLOKFLG = 1
     Endif
     If WVALID = 4 & [F:CUL]CUNLOKFLG = 2
       [F:CUL]CUNLOKFLG = 3
     Endif
     [F:CUL]MVTDES    = [M:SNL0]MVTDES
     [F:CUL]UPDUSR    = GUSER
     [F:CUL]UPDDAT    = date$
     If [F:CUL]IPTDAT  = [0/0/0]
        [F:CUL]IPTDAT  = [M:SNL0]IPTDAT
     Endif
     [F:CUL]LASIPTDAT = date$
     [F:CUL]USR       = [M:SNL0]USR
     Rewrite  [CUL]
     If fstat
        GOK = 0
        Call FSTA("CUL") From GLOCK
        Gosub AB_TRT
        End
     Endif
     LCUL = "L"
  Commit
Endif

If !GIMPORT
   Call FERME_TRACE From LECFIC
   Call LEC_TRACE   From LECFIC
Endif

End

########################################################################
# RECH_STOALL    recherche des allocations correspondantes (limiter à 3)
########################################################################
# Paramètres E : LFCY    = Site
#                LITM    = Article
#                LSTOCOU = Chrono stock
#                LSUP    = S si une allocation existe et que lon modifie les caracteristiques
#                            de la ligne de stock
# Prérequis    : Ces tables doivent être ouvertes   STOALL  [STA]
########################################################################
Subprog RECH_STOALL(LFCY,LITM,LSTOCOU,LSUP)
Value    Char     LFCY
Value    Char     LITM
Value    Decimal  LSTOCOU
Value    Char     LSUP
Local Integer I
Raz I
Local Char MES(255)
MES = mess(450,199,1)+"\"           # La qté allouée est supérieure à la qte comptée
If LSUP = "S"
   MES = mess(482,199,1)+"\"        # Ligne de stock faisant l objet d une allocation
Endif
# hcb 37171

Filter [STA] Where    STOFCY = LFCY     &
&                     ITMREF = LITM     &
&                     STOCOU = LSTOCOU  &
&                     ALLTYP = 2
&            Order By Key STA0
Columns [STA] (VCRNUM, VCRLIN, QTYSTU, VCRTYP)
For [STA]
    I += 1
    If I > 3
       Break
    Endif
MES += mess([F:STA]VCRTYP,701,1)-[F:STA]VCRNUM-mess(3,40,1)-num$([F:STA]VCRLIN)-mess(33,105,1)-num$([F:STA]QTYSTU)+"\"
Next
Filter  [STA]
Columns [STA]
Call MESSAGE(MES) From GESECRAN
End

########################################################################
#  Sous programmes                                     appeles par GOSUB
########################################################################

########################################################################
# CRE_INV                                      Creation liste inventaire
########################################################################
$CRE_INV

Local Decimal WLIN
Local Integer I,J
# tri inventaire

Raz GPE                         # hcb 52308
GPOINT = "TRICREINV"            # hcb 52308
Gosub  ENTREE From EXEFNC       # hcb 52308
If GPE =  0                     # hcb 52308
   Case [F:CUN]CUNSRTCOD
        When 2 :
          Sorta [M:SIW]NBLIG [M:SIW]NBLIG Order By [M:SIW]LOC(indice),[M:SIW]ITMREF(indice),[M:SIW]STOCOU(indice)
        When Default :
          Sorta [M:SIW]NBLIG [M:SIW]NBLIG Order By [M:SIW]ITMREF(indice),[M:SIW]LOC(indice),[M:SIW]STOCOU(indice)
   Endcase
Endif                           # hcb 52308
#
#Raz [F:ITM]                                # hcb tst V6
#Raz [F:ITF]                                # hcb tst V6
For I = 0 To [M:SIW]NBLIG-1
  nolign = I+1
  WLIN   = (I+1)*1000
#creation détail inventaire
  Gosub CRE_CUD From STKINV
  If GOK <> 1
    Break
  Endif

Next I
#creation liste inventaire
If GOK = 1
  Gosub CRE_CUL From STKINV
Endif

Return

########################################################################
# CRE_CUD                                     Creation détail inventaire
########################################################################
$CRE_CUD
If clalev([F:ITF1]) = 0 : Local File ITMFACILIT [ITF1] : Endif
If clalev([F:STO1]) = 0 : Local File STOCK      [STO1] : Endif
#ocal Integer IANA
Local Integer Y
If dim(WRET)<0 Local Integer WRET : Endif

Raz [F:CUD]
[F:CUD]CUNSSSNUM = [M:SIW]CUNSSSNUM
[F:CUD]CUNLISNUM = [M:SIW]CUNLISNUM
[F:CUD]ITMLISNUM = WLIN


[F:CUD]STOFCY    = [M:SIW]STOFCY
[F:CUD]CUNDAT    = [M:SIW]CUNLISDAT
[F:CUD]CUNLOKFLG = 2
[F:CUD]CUNLISSTA = 1

If [M:SIW]CUR = ""
   Call GETDEV([M:SIW]STOFCY) From DEVSUB
   [M:SIW]CUR = GLOCALDEV
Endif

[F:CUD]CUR       = [M:SIW]CUR
[F:CUD]LINFLG    = [M:SIW]LINFLG    (I)
[F:CUD]ITMREF    = [M:SIW]ITMREF    (I)
[F:CUD]LOT       = [M:SIW]LOT       (I)
[F:CUD]WRH       = [M:SIW]WRH       (I)
[F:CUD]LOC       = [M:SIW]LOC       (I)
[F:CUD]LPNNUM    = [M:SIW]LPNNUM    (I)                               # hcb X3-68147
[F:CUD]STA       = [M:SIW]STA       (I)
[F:CUD]ABCCLS    = [M:SIW]ABCCLS    (I)
[F:CUD]PCU       = [M:SIW]PCU       (I)
[F:CUD]QTYPCU    = [M:SIW]QTYPCU    (I)
[F:CUD]QTYPCUNEW = [M:SIW]QTYPCUNEW (I)
[F:CUD]PCUSTUCOE = [M:SIW]PCUSTUCOE (I)
[F:CUD]QTYSTU    = [M:SIW]QTYSTU    (I)
[F:CUD]QTYSTUNEW = [M:SIW]QTYSTUNEW (I)
[F:CUD]SLO       = [M:SIW]SLO       (I)
[F:CUD]ECCVALMAJ = [M:SIW]ECCVALMAJ (I)
[F:CUD]SERNUM    = [M:SIW]SERNUM    (I)
[F:CUD]CUNCST    = [M:SIW]CUNCST    (I)
[F:CUD]CUNCSTCOD = [M:SIW]CUNCSTCOD (I)
[F:CUD]STOCOU    = [M:SIW]STOCOU    (I)
[F:CUD]ZERSTOFLG = [M:SIW]ZERSTOFLG (I)
[F:CUD]DEPRAT    = [M:SIW]DEPRAT    (I)
[F:CUD]DEPAMT    = [M:SIW]DEPAMT    (I)
[F:CUD]PALNUM    = [M:SIW]PALNUM    (I)
[F:CUD]CTRNUM    = [M:SIW]CTRNUM    (I)
[F:CUD]QLYCTLDEM = [M:SIW]QLYCTLDEM (I)
[F:CUD]OWNER     = [M:SIW]OWNER     (I)
[F:CUD]STOFLD1   = [M:SIW]STOFLD1   (I)
[F:CUD]STOFLD2   = [M:SIW]STOFLD2   (I)
#                                                                                         # hcb 71659 deb
[F:CUD]QTYSTUNEW1 = [M:SIW]QTYSTUNEW1 (I)
[F:CUD]QTYPCUNEW1 = [M:SIW]QTYPCUNEW1 (I)
[F:CUD]ZERSTOFLG1 = [M:SIW]ZERSTOFLG1 (I)
[F:CUD]QTYSTUNEW2 = [M:SIW]QTYSTUNEW2 (I)
[F:CUD]QTYPCUNEW2 = [M:SIW]QTYPCUNEW2 (I)
[F:CUD]ZERSTOFLG2 = [M:SIW]ZERSTOFLG2 (I)
#                                                                                         # hcb 71659 fin


If [F:CUD]PCUSTUCOE = 0 & [F:CUD]LINFLG = 1 & [F:CUD]QTYSTUNEW <> 0 & [F:CUD]QTYPCUNEW <> 0  # hcb 31134
   [F:CUD]PCUSTUCOE =     [F:CUD]QTYSTUNEW /  [F:CUD]QTYPCUNEW                               # hcb 31134
Endif                                                                                        # hcb 31134

If clalev([M:VIW])
    For J=0 To GACTMAT-1
        [F:CUD]MATCST(J)  = [M:VIW]OMATCST(I*GACTMAT+J)
    Next
    [F:CUD]OVEMATCST  = [M:VIW]OOVEMATCST(I)

    For J=0 To GACTMAC-1
        [F:CUD]MACCST(J)  = [M:VIW]OMACCST(I*GACTMAC+J)
    Next
    [F:CUD]OVEMACCST  = [M:VIW]OOVEMACCST(I)

    For J=0 To GACTLAB-1
        [F:CUD]LABCST(J)  = [M:VIW]OLABCST(I*GACTLAB+J)
    Next
    [F:CUD]OVELABCST  = [M:VIW]OOVELABCST(I)

    [F:CUD]SCOCST     = [M:VIW]OSCOTOT(I)
    [F:CUD]OVESCOCST  = [M:VIW]OOVESCOCST(I)

    [F:CUD]INVDTACST  = [M:VIW]OINVDTACST(I) # Issue 81304 - 2012-06-11 by CCC : INVDTACST n'était pas alimenté

    [F:CUD]PRIORD     = [M:VIW]PRI(I)
Else
    If GIMPORT                                                   # hcb 75176
       [F:CUD]PRIORD     = [M:SIW]PRIORD    (I)
    Endif
Endif

#If [F:CUD]STOCOU    = 0    # hcb 62373
#   [F:CUD]CUNLOKFLG = 1
#Endif

If [F:CUD]ZERSTOFLG = 2
   [F:CUD]CUNLISSTA = 2
Endif

# Les sections ana peuvent être modifiables
For Y=1 To GNBDIE                               # Ana
    [F:CUD]CCE(Y-1) =  evalue("[M:SIW]CCE"+num$(Y)+"(I)")       # Ana
    [F:CUD]DIE(Y-1) =  GDIE(Y)                 # Ana
Next

[F:CUD]CREUSR    = GUSER
[F:CUD]CREDAT    = date$
[F:CUD]EXPNUM    = [C]EXPORT

If [F:CUD]ZERSTOFLG = 0
   [F:CUD]ZERSTOFLG = 1
Endif
#                                                                                         # hcb 71659 deb
If [F:CUD]ZERSTOFLG1 = 0
   [F:CUD]ZERSTOFLG1 = 1
Endif
If [F:CUD]ZERSTOFLG2 = 0
   [F:CUD]ZERSTOFLG2 = 1
Endif
#                                                                                         # hcb 71659 fin

If [F:CUD]QTYSTUNEW  <> 0
   [F:CUD]CUNLISSTA = 2
Endif

If [F:CUD]ZERSTOFLG = 2
   [F:CUD]CUNLISSTA = 2
Endif


# Lecture et lock article maitre
If [F:ITM]ITMREF <> [F:CUD]ITMREF
  Readlock [ITM]ITM0=[F:CUD]ITMREF
  Case fstat
    When 0 :
    When 1 :
      GOK = -1
      GMESSAGE = mess(20,100,1)-"ITMMASTER"-[F:CUD]ITMREF
      Return
    When Default :
      GOK = 0
      Call FSTA("ITM") From GLOCK
      Return
  Endcase
Endif
#Positionnement flag en inventaire ITMFACILIT
If [F:ITF1]STOFCY <> [M:SIW]STOFCY | [F:ITF1]ITMREF <> [F:CUD]ITMREF
  Readlock [ITF1]ITF0=[F:CUD]ITMREF;[M:SIW]STOFCY
  Case fstat
    When 0 :
    When 1 :
      GOK = -1
      GMESSAGE = mess(20,100,1)-"ITMFACILIT"-[F:CUD]ITMREF-[M:SIW]STOFCY
      Return
    When Default :
      GOK = 0
      Call FSTA("ITM") From GLOCK
      Return
  Endcase
  If [F:ITF1]CUNLISNUM <> [F:CUD]CUNLISNUM | [F:ITF1]CUNFLG <> 2
     [F:ITF1]CUNLISNUM =  [F:CUD]CUNLISNUM
     [F:ITF1]CUNFLG    = 2
     Rewrite [ITF1]
     If fstat
        GOK = 0
        Call FSTA("ITF") From GLOCK
        Return
     Endif
  Endif
Endif

#Positionnement flag en inventaire STOCK
If [M:SIW]STOCOU (I) <> 0
   Readlock [STO1]STO0=[M:SIW]STOFCY;[M:SIW]STOCOU (I)
   Case fstat
        When 0 :
        When 1 :
             GMESSAGE = mess(20,100,1)-"STOCK"-[F:CUD]ITMREF-[M:SIW]STOCOU (I)
             GOK = -1
             Return
        When 5 :
             Return                  # hcb 43817
        When Default :
             GOK = 0
             Call FSTA("STO") From GLOCK
             Return
   Endcase
   [F:STO1]CUNLOKFLG = 2
   [F:STO1]CUNLISNUM = [M:SIW]CUNLISNUM
   Rewrite [STO1]
   If fstat
      GOK = 0
      Call FSTA("STO") From GLOCK
      Return
   Endif

Endif

$ECR_CUD

# Ecriture détail inventaire avec point d'entrée avant ecriture WRICUD
If GOK = 1
   If dim([F:CUD]NETCUNCST) > 0
      [F:CUD]NETCUNCST = [F:CUD]CUNCST
      [F:CUD]DEPRAT    = 0
      [F:CUD]DEPAMT    = 0
   Endif
   #                                                                        # hcb 110327 deb
# si l article gère les numéros de série en "globale" initialisation de la rubrique SERSEQ
# en creation de liste [M:SIW]SERSEQ n est pas renseigné
# en ajout de ligne    [M:SIW]SERSEQ est calculé : [SNL0]LASSERSEQ + 1
    If [F:ITM]SERMGTCOD = 4
      If [M:SIW]SERSEQ (I) <> 0
         [F:CUD]SERSEQ     =  [M:SIW]SERSEQ (I)
      Else
         [F:CUD]SERSEQ     =  I+1
      Endif
   Endif
#                                                                        # hcb 110327 fin
   GPOINT = "WRICUD"
   Gosub  ENTREE From EXEFNC
   Write [CUD]
   If fstat
      GOK = 0
      Call FSTA("CUD") From GLOCK
      Return
   Endif
Endif
$CRE_CUD_FIN
Return

########################################################################
# CRE_CUL                                      Creation liste inventaire
########################################################################
$CRE_CUL
Raz [F:CUL]
[F:CUL]STOFCY    = [M:SIW]STOFCY
[F:CUL]CUNLISNUM = [M:SIW]CUNLISNUM
[F:CUL]CUNSSSNUM = [M:SIW]CUNSSSNUM
[F:CUL]CUNLISDAT = [M:SIW]CUNLISDAT
[F:CUL]CUNLISDES = [M:SNU0]CUNSSSDES # hcb 70723
[F:CUL]WRH       = [M:SIW]WRHCUL
[F:CUL]IPTDAT    = date$
[F:CUL]CUNLOKFLG = 2

[F:CUL]CUNLISSTA = 1
[F:CUL]CUNSTADAT = date$
[F:CUL]NBRLIG    = [M:SIW]NBLIG
[F:CUL]CREUSR    = GUSER
[F:CUL]CREDAT    = date$
[F:CUL]EXPNUM    = [C]EXPORT

Local Integer Y
Local Char    SECTION

For Y = 1 To GNBDIE
    If dim([F:CUL]CCE(Y-1)) >0
        Call INISEC(SECTION, "STKINVH", Y) From TRTX3CPT
        [F:CUL]CCE(Y-1) =  SECTION
    Endif
Next

GPOINT = "WRICUL"                         # hcb x3-47401
Gosub  ENTREE From EXEFNC                 # hcb x3-47401
Write [CUL]
If fstat
   GOK = 0
   Call FSTA("CUL") From GLOCK
   Return
Endif

Return

########################################################################
# MAJ_CUN                                         Maj session inventaire
########################################################################
$MAJ_CUN
# si simulation pas de maj
If dim(GSIMSNU) > 0
   Return
Endif

Local Integer WOK
# verification qu il y ai au moins une liste
Filter [CUL] Where CUNSSSNUM = [M:SNU0]CUNSSSNUM
Look [CUL]CUL0 First
Filter [CUL]
If fstat
   Return
Endif
Filter [CUL]

If clalev([F:CUN1])=0 Local File CUNSESSION [CUN1]  Endif

Readlock [CUN1]CUN0=[M:SNU0]CUNSSSNUM
Case fstat
     When 0 :
     When 1 :
             GOK = -1
             GMESSAGE = mess(20,100,1)-"CUNSESSION"-[M:SNU0]CUNSSSNUM
             Return
     When Default :
             GOK = 0
             Call FSTA("CUN") From GLOCK
             Return
     Endcase

[F:CUN1]CPLCUNNBRA = [M:SNU1]CPLCUNNBRA
[F:CUN1]CPLCUNNBRB = [M:SNU1]CPLCUNNBRB
[F:CUN1]CPLCUNNBRC = [M:SNU1]CPLCUNNBRC
[F:CUN1]CPLCUNNBRD = [M:SNU1]CPLCUNNBRD

[F:CUN1]CUNSSSSTA = 2
[F:CUN1]CREUSR    = GUSER
[F:CUN1]CREDAT    = date$

Rewrite  [CUN1]
If fstat
   GOK = 0
   Call FSTA("CUN") From GLOCK
   Return
Endif

Close Local File [CUN1]

# read pour rafraichir le buffer CUN
Read [CUN]CUN0=[M:SNU0]CUNSSSNUM
[M:SNU0]CUNSSSSTA = 2
Affzo [M:SNU0]CUNSSSSTA
Return


#########################################################################
#SET_NOL                                        Alimentation rubrique NOL
#########################################################################
$SET_NOL
Local Integer NOL : NOL = nolign-1
Return

########################################################################
# AB_TRT                                       Abandon de la transaction
########################################################################
$AB_TRT
Rollback
Return
########################################################################
# FORMAT_INV                        Chargement des formats (invisibles)
########################################################################
$FORMAT_INV

#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 6 | [F:SRT]SRTNUM <> GSNLNUM                   # hcb 50197
    Read [SRT]SRT0=6;GSNLNUM : If fstat Raz [F:SRT] : Endif
Endif

#Emplacement
#tri Article /emplacement
If [F:CUN]CUNSRTCOD  = 1
   GWSINVLOC1 = "-"+GSINVLOC1
   GWSINTEMP  = ""
   If [F:SRT]LOCCOD = 1
      GWSINVLOC2 = GSINVLOC2
   Else
      GWSINVLOC2 = "-"+GSINVLOC2
   Endif
Else
   GWSINVLOC1 = GSINVLOC1
   GWSINTEMP  = GSINTEMP
   GWSINVLOC2 = "-"+GSINVLOC2
Endif

Return


########################################################################
# FORMAT_INV_SNL1     Chargement des formats (invisibles) écran SNL1
########################################################################
$FORMAT_INV_SNL1
# LOTMGTCOD  politique gestion lot
#            1 = Non
#            2 = Oui facultatif
#            3 = Oui obligatoire
#            4 = Oui obligatoire + Sous lot



GWSINVLOT   = GSINVLOT
GWSINTLOT   = GSINTLOT
GWSINVSLO   = GSINVSLO
GWSINTSLO   = GSINTSLO
GWSINVSER   = GSINVSER
GWSINTSER   = GSINTSER
GWSINVEMP   = GSINVEMP
GWSINVEMPT  = GSINVEMPT
GWSINTEMP   = GSINTEMP

If [F:ITM]LOTMGTCOD = 1
   GWSINVLOT   = "-"+GSINVLOT
   GWSINVSLO   = "-"+GSINVSLO
   GWSINTLOT   = ""
   GWSINTSLO   = ""
Else
   GWSINVLOT   = GSINVLOT
   GWSINTLOT   = GSINTLOT
Endif

If [F:ITM]LOTMGTCOD = 4
   GWSINVSLO   = GSINVSLO
   GWSINTSLO   = GSINTSLO
Else
   GWSINVSLO   = "-"+GSINVSLO
   GWSINTSLO   = ""
Endif
If [F:ITM]SERMGTCOD<2   | [F:ITM]SERMGTCOD = 4                          # hcb 110327
   GWSINVSER = "-"+GSINVSER
   GWSINTSER = ""
Else
   GWSINVSER = GSINVSER
   GWSINTSER = GSINTSER
Endif
If [F:ITF]LOCMGTCOD<>2
   GWSINVEMP = "-"+GSINVEMP
   GWSINVEMPT= "-"+GSINVEMPT
   GWSINTEMP = ""
   GWSINTEMPT= ""
Else
   GWSINVEMP = GSINVEMP
   GWSINVEMPT= GSINVEMPT
   GWSINTEMP = GSINTEMP
   GWSINTEMPT= GSINTEMPT
Endif

# Article géré en version ou non
GWSINVECCMAJ = "-"+GSINVECCMAJ
GWSINVECCMIN = "-"+GSINVECCMIN
If [F:ITM]ECCSTO > 1
   GWSINVECCMAJ = GSINVECCMAJ
Endif
# Article site non géré en version
If [F:ITM]ECCFLG <2
   GWSINVECCMAJ = "-"+GSINVECCMAJ
Endif

If GWRHACT<>2
   GWSINVWRH = "-"+GSINVWRH
# Site avec gestion de dépôt ou non
Else
   If clalev([F:FCY])=0 : Local File FACILITY [FCY] : Endif
   If [F:ITF]STOFCY<>[F:FCY]FCY
      Read [FCY]FCY0=[F:ITF]STOFCY
      If fstat Raz [F:FCY] Endif
   Endif
   If [F:FCY]WRHGES=2
      GWSINVWRH = GSINVWRH
   Else
      GWSINVWRH = "-"+GSINVWRH
   Endif
Endif

#                                                         # hcb X3-68147 deb
# Gestion des contenants
If [F:ITF]LPNMGTCOD<>2
   GWSINVLPNNUM  = "-"+GSINVLPNNUM
Else
   GWSINVLPNNUM  = GSINVLPNNUM
Endif
#                                                         # hcb X3-68147 fin

Gosub FORMAT_INV_MULTI From STKINV                                                        # hcb 71659
Return
#                                                                                         # hcb 71659 deb
##########################################################################
# FORMAT_INV_MULTI     Chargement des formats (invisibles) multi-comptages
##########################################################################
$FORMAT_INV_MULTI
# MULCTGFLG  Multi-comptages
#            0/1 = Non
#            2 = Oui
GSINVQTY      = "Nz:"+GUNTFMT
GWSINVQTY     = GSINVQTY
GWSINVCOE     = GSINVCOE
GWSINVZER     = GSINVZER
GWSINVCTGUSR  = GSINVCTGUSR
GWSINVSAICOD  = GSINVSAICOD

If [F:CUN]MULCTGFLG <> 2
   GWSINVQTY     = "-"+GSINVQTY          # format QTY
   GWSINVCOE     = "-"+GSINVCOE          # format Coefficients
   GWSINVZER     = "-"+GSINVZER          # format Stock nul
   GWSINVCTGUSR  = "-"+GSINVCTGUSR       # format Inventoriste
   GWSINVSAICOD  = "-"+GSINVSAICOD       # format SAICOD
Endif
Return
#                                                                                         # hcb 71659 fin

########################################################################
# TRT_CLE_REGROUPEMENT            Constitution de la cle du regroupement
########################################################################
$TRT_CLE_REGROUPEMENT
Local Char     RB(9)    (13)                                                   # hcb x3-68147
Raz RB
Local Integer I
I = 0
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 6 | [F:SRT]SRTNUM <> GSNLNUM                   # hcb 50197
    Read [SRT]SRT0=6;GSNLNUM : If fstat Raz [F:SRT] : Endif
Endif
Raz GPE                         # hcb 52308
GPOINT = "TRICLEREG"            # hcb 52308
Gosub  ENTREE From EXEFNC       # hcb 52308
If GPE =  0                     # hcb 52308
   If [F:CUN]CUNSRTCOD <> 2
      RB(I) = "ITMREF"
      If [F:SRT]LOCCOD = 1
         I += 1
         RB(I) = "LOC"
      Endif
   Else
      RB (I) = "LOC"
      I += 1
      RB (I) = "ITMREF"
   Endif
Endif                           # hcb 52308
If [F:SRT]LPNCOD = 1                                               # hcb x3-68147
   I += 1
   RB(I) = "LPNNUM"
Endif
If [F:SRT]WRHCOD = 1
   I += 1
   RB(I) = "WRH"
Endif

If [F:SRT]LOTCOD = 1
   I += 1
   RB(I) = "LOT"
Endif
If [F:SRT]SLOCOD = 1
   I += 1
   RB(I) = "SLO"
Endif
I += 1
RB(I) = "PCU"
I += 1
RB(I) = "PCUSTUCOE"
If [F:SRT]STACOD = 1
   I += 1
   RB(I) = "STA"
Endif
If [F:SRT]SERCOD = 1
   I += 1
   RB(I) = "SERNUM"
Endif
If [F:SRT]IDECOD1 = 1
   I += 1
   RB(I) = "PALNUM"
Endif
If [F:SRT]IDECOD2 = 1
   I += 1
   RB(I) = "CTRNUM"
Endif

Case I

    When 2 :
     Filter [CUD] Where CUNSSSNUM=[M:SNL0]CUNSSSNUM & CUNLISNUM = [M:SNL0]CUNLISNUM
&    Order By Key CLE = evalue(RB(0));evalue(RB(1));evalue(RB(2))
    When 3 :
     Filter [CUD] Where CUNSSSNUM=[M:SNL0]CUNSSSNUM & CUNLISNUM = [M:SNL0]CUNLISNUM
&    Order By Key CLE = evalue(RB(0));evalue(RB(1));evalue(RB(2));evalue(RB(3))
    When 4 :
     Filter [CUD] Where CUNSSSNUM=[M:SNL0]CUNSSSNUM & CUNLISNUM = [M:SNL0]CUNLISNUM
&    Order By Key CLE = evalue(RB(0));evalue(RB(1));evalue(RB(2));evalue(RB(3));evalue(RB(4))
    When 5 :
     Filter [CUD] Where CUNSSSNUM=[M:SNL0]CUNSSSNUM & CUNLISNUM = [M:SNL0]CUNLISNUM
&    Order By Key CLE = evalue(RB(0));evalue(RB(1));evalue(RB(2));evalue(RB(3));evalue(RB(4));evalue(RB(5))
    When 6 :
     Filter [CUD] Where CUNSSSNUM=[M:SNL0]CUNSSSNUM & CUNLISNUM = [M:SNL0]CUNLISNUM
&    Order By Key CLE = evalue(RB(0));evalue(RB(1));evalue(RB(2));evalue(RB(3));evalue(RB(4));evalue(RB(5));evalue(RB(6))
    When 7 :
     Filter [CUD] Where CUNSSSNUM=[M:SNL0]CUNSSSNUM & CUNLISNUM = [M:SNL0]CUNLISNUM
&    Order By Key CLE = evalue(RB(0));evalue(RB(1));evalue(RB(2));evalue(RB(3));evalue(RB(4));evalue(RB(5));evalue(RB(6));evalue(RB(7))
    When 8 :
     Filter [CUD] Where CUNSSSNUM=[M:SNL0]CUNSSSNUM & CUNLISNUM = [M:SNL0]CUNLISNUM
&    Order By Key CLE = evalue(RB(0));evalue(RB(1));evalue(RB(2));evalue(RB(3));evalue(RB(4));evalue(RB(5));evalue(RB(6));evalue(RB(7));
&                       evalue(RB(8))
    When 9 :
     Filter [CUD] Where CUNSSSNUM=[M:SNL0]CUNSSSNUM & CUNLISNUM = [M:SNL0]CUNLISNUM
&    Order By Key CLE = evalue(RB(0));evalue(RB(1));evalue(RB(2));evalue(RB(3));evalue(RB(4));evalue(RB(5));evalue(RB(6));evalue(RB(7));
&                       evalue(RB(8));evalue(RB(9))
    When 10 :
     Filter [CUD] Where CUNSSSNUM=[M:SNL0]CUNSSSNUM & CUNLISNUM = [M:SNL0]CUNLISNUM
&    Order By Key CLE = evalue(RB(0));evalue(RB(1));evalue(RB(2));evalue(RB(3));evalue(RB(4));evalue(RB(5));evalue(RB(6));evalue(RB(7));
&                       evalue(RB(8));evalue(RB(9));evalue(RB(10))
    When 11 :
     Filter [CUD] Where CUNSSSNUM=[M:SNL0]CUNSSSNUM & CUNLISNUM = [M:SNL0]CUNLISNUM
&    Order By Key CLE = evalue(RB(0));evalue(RB(1));evalue(RB(2));evalue(RB(3));evalue(RB(4));evalue(RB(5));evalue(RB(6));evalue(RB(7));
&                       evalue(RB(8));evalue(RB(9));evalue(RB(10));evalue(RB(11))
    When 12 :                                                                          # hcb X3-68147
     Filter [CUD] Where CUNSSSNUM=[M:SNL0]CUNSSSNUM & CUNLISNUM = [M:SNL0]CUNLISNUM
&    Order By Key CLE = evalue(RB(0));evalue(RB(1));evalue(RB(2));evalue(RB(3));evalue(RB(4));evalue(RB(5));evalue(RB(6));evalue(RB(7));
&                       evalue(RB(8));evalue(RB(9));evalue(RB(10));evalue(RB(11));evalue(RB(12))

Endcase

Return

########################################################################
# TRT_TRT_REGROUPEMENT                        Traitement du regroupement
########################################################################
$TRT_TRT_REGROUPEMENT
Local Char RGP_RUPTURE(250)                            # hcb x3-68147
Local Char RGP_LECTURE(250)                            # hcb x3-68147
Local Char RGP_FILTRE (250)                                                               # hcb 71659
Local Char RGP_FILTRE1(250)                                                               # hcb 71659
Local Char RGP_FILTRE2(250)                                                               # hcb 71659

Raz RGP_RUPTURE
Raz RGP_LECTURE
Local Decimal WQTYSTUNEW
Local Decimal WQTYPCUNEW
Raz WQTYSTUNEW
Raz WQTYPCUNEW
#                                                                                         # hcb 71659 deb
Local Decimal WQTYSTUNEW1
Local Decimal WQTYPCUNEW1
Raz WQTYSTUNEW1
Raz WQTYPCUNEW1
Local Decimal WQTYSTUNEW2
Local Decimal WQTYPCUNEW2
Raz WQTYSTUNEW2
Raz WQTYPCUNEW2
#                                                                                         # hcb 71659 fin


For [CUD]
    Gosub TRT_RGP_LECTURE

    If RGP_LECTURE = RGP_RUPTURE
       Gosub RGP_CUM_CUMUL
    Else
       If [M:SNL0]NBLIG  >  GCOD_INV : Break : Endif
       Gosub RGP_NEW_CUMUL
       Gosub RGP_CUM_CUMUL
    Endif
Next
Filter [CUD]

Return
########################################################################
# TRT_RGP_LECTURE                             Chargement du regroupement
########################################################################
$TRT_RGP_LECTURE
Local Integer I
Raz I
Raz RGP_LECTURE
RGP_FILTRE  = "1=1"                                                                       # hcb 71659
RGP_FILTRE1 = "1=1"                                                                       # hcb 71659
RGP_FILTRE2 = "1=1"                                                                       # hcb 71659
RGP_FILTRE += "&[F:CUD1]CUNSSSNUM=[F:CUD]CUNSSSNUM&[F:CUD1]CUNLISNUM=[F:CUD]CUNLISNUM"    # hcb 71659

For I = 0 To 12                                                                # hcb x3-68147
    If RB(I) = ""
       Break
    Endif
    If RB(I) = "ITMREF"
       RGP_LECTURE += [F:CUD]ITMREF
       RGP_FILTRE1 += "&[F:CUD1]ITMREF=[F:CUD]ITMREF"                                     # hcb 71659
    Endif
    If RB(I) = "WRH"
       If [F:CUD]WRH = ""
          RGP_LECTURE += "  "
       Else
          RGP_LECTURE += [F:CUD]WRH
          RGP_FILTRE1 += "&[F:CUD1]WRH=[F:CUD]WRH"                                        # hcb 71659
       Endif
    Endif
    If RB(I) = "LPNNUM"                                                                      # hcb x3-68147
       If [F:CUD]LPNNUM = ""
          RGP_LECTURE += "  "
       Else
          RGP_LECTURE += [F:CUD]LPNNUM
          RGP_FILTRE1 += "&[F:CUD1]LPNNUM=[F:CUD]LPNNUM"
       Endif
    Endif
    If RB(I) = "LOC"
       If [F:CUD]LOC = ""
          RGP_LECTURE += "  "
       Else
          RGP_LECTURE += [F:CUD]LOC
          RGP_FILTRE1 += "&[F:CUD1]LOC=[F:CUD]LOC"                                        # hcb 71659
       Endif
    Endif
    If RB(I) = "LOT"
       If [F:CUD]LOT = ""
          RGP_LECTURE += "  "
       Else
          RGP_LECTURE += [F:CUD]LOT
          RGP_FILTRE1 += "&[F:CUD1]LOT=[F:CUD]LOT"                                        # hcb 71659
       Endif
    Endif
    If RB(I) = "SLO"
       If [F:CUD]SLO = ""
          RGP_LECTURE += "  "
       Else
          RGP_LECTURE += [F:CUD]SLO
          RGP_FILTRE1 += "&[F:CUD1]SLO=[F:CUD]SLO"                                        # hcb 71659
       Endif
    Endif
    If RB(I) = "PCU"
       RGP_LECTURE += [F:CUD]PCU
       RGP_FILTRE1 += "&[F:CUD1]PCU=[F:CUD]PCU"                                           # hcb 71659
    Endif
    If RB(I) = "PCUSTUCOE"
       RGP_LECTURE += num$([F:CUD]PCUSTUCOE)
       RGP_FILTRE1 += "&[F:CUD1]PCUSTUCOE=[F:CUD]PCUSTUCOE"                               # hcb 71659
    Endif
    If RB(I) = "STA"
       RGP_LECTURE += [F:CUD]STA
       RGP_FILTRE += "&[F:CUD1]STA=[F:CUD]STA"                                            # hcb 71659
    Endif
    If RB(I) = "SERNUM"
       If [F:CUD]SERNUM = ""
          RGP_LECTURE += "  "
       Else
          RGP_LECTURE += [F:CUD]SERNUM
          RGP_FILTRE2 += "&[F:CUD1]SERNUM=[F:CUD]SERNUM"                                  # hcb 71659
       Endif
    Endif
    If RB(I) = "PALNUM"
       If [F:CUD]PALNUM = ""
          RGP_LECTURE += "  "
       Else
          RGP_LECTURE += [F:CUD]PALNUM
          RGP_FILTRE2 += "&[F:CUD1]PALNUM=[F:CUD]PALNUM"                                  # hcb 71659
       Endif
    Endif
    If RB(I) = "CTRNUM"
       If [F:CUD]CTRNUM = ""
          RGP_LECTURE += "  "
       Else
          RGP_LECTURE += [F:CUD]CTRNUM
          RGP_FILTRE2 += "&[F:CUD1]CTRNUM=[F:CUD]CTRNUM"                                  # hcb 71659
       Endif
    Endif
Next I

Return

########################################################################
# RGP_CUM_CUMUL                                       Cumul regroupement
########################################################################
$RGP_CUM_CUMUL

#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 6 | [F:SRT]SRTNUM <> GSNLNUM                   # hcb 50197
    Read [SRT]SRT0=6;GSNLNUM : If fstat Raz [F:SRT] : Endif
Endif

# calcul statut code regroupement
If [M:SNL0]CUNLISSTAM(LLIG) < [F:CUD]CUNLISSTA
   [M:SNL0]CUNLISSTAM(LLIG) = [F:CUD]CUNLISSTA
Endif
If [M:SNL0]CUNLISSTAN(LLIG) > [F:CUD]CUNLISSTA
   [M:SNL0]CUNLISSTAN(LLIG) = [F:CUD]CUNLISSTA
Endif
If [M:SNL0]CUNLISSTAM(LLIG) = [M:SNL0]CUNLISSTAN(LLIG)
   [M:SNL0]CUNLISSTAD(LLIG) = [M:SNL0]CUNLISSTAN(LLIG)
Else
   [M:SNL0]CUNLISSTAD(LLIG) = [M:SNL0]CUNLISSTAM(LLIG) + 6
Endif

# si code stock different alors code stock "partiel"
If [M:SNL0]CUNLOKFLG(LLIG) <>  [F:CUD]CUNLOKFLG
   [M:SNL0]CUNLOKFLG(LLIG) =  3
Endif
# calcul nombre de detail du regroupement
[M:SNL0]NBDETAIL(LLIG)  += 1
# calcul alloué
#                                                                     # hcb 110327 deb
If [M:SNL0]NBDETAIL(LLIG) > 1
   Raz [M:SNL0]SERSEQ(LLIG)
Endif
If [F:CUD]SERSEQ     > [M:SNL0]LASSERSEQ
   [M:SNL0]LASSERSEQ = [F:CUD]SERSEQ
Endif
#                                                                     # hcb 110327 end
If  [F:CUD]STOCOU <> 0
    If  [M:SNL0]CUMALLQTY(LLIG) = 0
        Read [STO]STO0=[M:SNL0]STOFCY;[F:CUD]STOCOU
        If  fstat = 0
            [M:SNL0]CUMALLQTY(LLIG) += [F:STO]CUMALLQTY
            If [M:SNL0]NBDETAIL(LLIG)  = 1
               [M:SNL0]STOCOU   (LLIG) += [F:CUD]STOCOU
            Endif
        Endif
    Endif
Endif

#                                                                              # hcb 43661 deb
# Point d'entrée pre_chargement quantité comptée sur regroupement
Local Char RGPPRECHARG(100)
Raz RGPPRECHARG
Raz GPE
RGPPRECHARG = "[F:CUD]CUNLISSTA = 1 & [F:SRT]LODCOD1 = 2 & [M:SNL0]NBDETAIL(LLIG)  = 1"
GPOINT = "RGP_PRECHARG" : Gosub ENTREE From EXEFNC
If GPE <> 0
   RGPPRECHARG = "[F:CUD]CUNLISSTA = 1 & [F:SRT]LODCOD1 = 2"
Endif
#                                                                              # hcb 43661 fin

# si enregistrement à compter et parametrage prechargement à oui et nbre detail = 1 alors comptée = theorique

If evalue(RGPPRECHARG)                                                         # hcb 43661
   If [M:SNL0]MULCTGFLG <> 2                                                              # hcb 71659
      If dim([M:SNL0]QTYPCUNEW) > 0
         [M:SNL0]QTYPCUNEW (LLIG) += [F:CUD]QTYPCU                                # hcb 43661
         WQTYPCUNEW              += [F:CUD]QTYPCU                                # hcb 43661
      Endif
      If dim([M:SNL0]QTYSTUNEW) > 0
         [M:SNL0]QTYSTUNEW (LLIG) += [F:CUD]QTYSTU                                # hcb 43661
         WQTYSTUNEW              += [F:CUD]QTYSTU                                # hcb 43661
      Endif
      If dim([M:SNL0]MODFLG) > 0
         If [F:CUD]QTYPCU <> 0
            [M:SNL0]MODFLG       (LLIG) = 2
         Endif
      Endif
      If [M:SNL0]QTYPCUNEW (LLIG) = 0 & [M:SNL0]QTYSTUNEW (LLIG)= 0 & [M:SNL0]STOCOU   (LLIG) = 0  # hcb 63659 deb
         If dim([M:SNL0]ZERSTOFLG) > 0
            [M:SNL0]ZERSTOFLG    (LLIG) = 2
         Endif
         If dim([M:SNL0]MODFLG) > 0
            [M:SNL0]MODFLG       (LLIG) = 2
         Endif
      Endif                                                                                        # hcb 63659 deb

      If dim([M:SNL0]PCUSTUW) > 0                                                       # hcb 31134
         If [M:SNL0]QTYSTUNEW(LLIG) <> 0 & [M:SNL0]QTYPCUNEW(LLIG) <>0                  # hcb 31134
            [M:SNL0]PCUSTUW  (LLIG) = [M:SNL0]QTYSTUNEW(LLIG) / [M:SNL0]QTYPCUNEW(LLIG) # hcb 31134
         Endif                                                                          # hcb 31134
      Endif                                                                             # hcb 31134
      [M:SNL0]PCUSTUNEW (LLIG) = format$("N>:5.6",[M:SNL0]PCUSTUW  (LLIG))              # hcb 31134
#                                                                                         # hcb 71659 deb
   Else
       Raz [M:SNL0]PCUSTUW1    (LLIG)
       [M:SNL0]PCUSTUNEW1 (LLIG) = format$("N>:5.6",[M:SNL0]PCUSTUW1  (LLIG))
       [M:SNL0]PCUSTUNEW2 (LLIG) = format$("N>:5.6",[M:SNL0]PCUSTUW1  (LLIG))
       [M:SNL0]PCUSTUNEW  (LLIG) = format$("N>:5.6",[M:SNL0]PCUSTUW1  (LLIG))
       Case [M:SNL0]SAICOD(LLIG)
            When "+","+1"
#                                          # pré-chargement comptage 1
               If [F:CUD]QTYPCUNEW1 = 0
                  [M:SNL0]QTYPCUNEW1     (LLIG) += [F:CUD]QTYPCU
                  WQTYPCUNEW1                   += [F:CUD]QTYPCU
                  [M:SNL0]QTYSTUNEW1     (LLIG) += [F:CUD]QTYSTU
                  WQTYSTUNEW1                   += [F:CUD]QTYSTU
               Else
                  [M:SNL0]QTYPCUNEW1     (LLIG) += [F:CUD]QTYPCUNEW1
                  [M:SNL0]QTYSTUNEW1     (LLIG) += [F:CUD]QTYSTUNEW1
                  [M:SNL0]ZERSTOFLG1     (LLIG) =  [F:CUD]ZERSTOFLG1
               Endif
               If [F:CUD]QTYPCU <> 0
                  [M:SNL0]MODFLG      (LLIG) =  2
               Endif
               If [M:SNL0]QTYPCUNEW1  (LLIG) =  0 & [M:SNL0]QTYSTUNEW1 (LLIG)= 0 & [M:SNL0]STOCOU   (LLIG) = 0
                  [M:SNL0]ZERSTOFLG1  (LLIG) =  2
                  [M:SNL0]MODFLG      (LLIG) =  2
               Endif
               If [M:SNL0]QTYSTUNEW1  (LLIG) <> 0 & [M:SNL0]QTYPCUNEW1(LLIG) <>0
                  [M:SNL0]PCUSTUW1    (LLIG) =  [M:SNL0]QTYSTUNEW1(LLIG) / [M:SNL0]QTYPCUNEW1(LLIG)
               Endif
               [M:SNL0]PCUSTUNEW1     (LLIG) =  format$("N>:5.6",[M:SNL0]PCUSTUW1  (LLIG))
            When "*1"
#                                          # pré-chargement comptage 2 chargement comptage 1 calcul comptage 3
               [M:SNL0]QTYPCUNEW2     (LLIG) += [F:CUD]QTYPCU
               WQTYPCUNEW2                   += [F:CUD]QTYPCU
               [M:SNL0]QTYSTUNEW2     (LLIG) += [F:CUD]QTYSTU
               WQTYSTUNEW2                   += [F:CUD]QTYSTU
               If [F:CUD]QTYPCU <> 0
                  [M:SNL0]MODFLG      (LLIG) =  2
               Endif
               If [M:SNL0]QTYPCUNEW2  (LLIG) =  0 & [M:SNL0]QTYSTUNEW2 (LLIG)= 0 & [M:SNL0]STOCOU   (LLIG) = 0
                  [M:SNL0]ZERSTOFLG2  (LLIG) =  2
                  [M:SNL0]MODFLG      (LLIG) =  2
               Endif
               If [M:SNL0]QTYSTUNEW2  (LLIG) <> 0 & [M:SNL0]QTYPCUNEW2(LLIG) <>0
                  [M:SNL0]PCUSTUW2    (LLIG) =  [M:SNL0]QTYSTUNEW2(LLIG) / [M:SNL0]QTYPCUNEW2(LLIG)
               Endif
               [M:SNL0]PCUSTUNEW2     (LLIG) =  format$("N>:5.6",[M:SNL0]PCUSTUW2  (LLIG))

               [M:SNL0]QTYPCUNEW1     (LLIG) += [F:CUD]QTYPCUNEW1
               [M:SNL0]QTYSTUNEW1     (LLIG) += [F:CUD]QTYSTUNEW1
               [M:SNL0]ZERSTOFLG1     (LLIG) =  [F:CUD]ZERSTOFLG1
               If [M:SNL0]QTYSTUNEW1  (LLIG) <> 0 & [M:SNL0]QTYPCUNEW1(LLIG) <>0
                  [M:SNL0]PCUSTUW1    (LLIG) =  [M:SNL0]QTYSTUNEW1(LLIG) / [M:SNL0]QTYPCUNEW1(LLIG)
               Endif
               [M:SNL0]PCUSTUNEW1     (LLIG) =  format$("N>:5.6",[M:SNL0]PCUSTUW1  (LLIG))

               If [M:SNL0]PCUSTUNEW1 (LLIG) = [M:SNL0]PCUSTUNEW2 (LLIG) &
&                 [M:SNL0]QTYSTUNEW1 (LLIG) = [M:SNL0]QTYSTUNEW2 (LLIG) &
&                 [M:SNL0]QTYPCUNEW1 (LLIG) = [M:SNL0]QTYPCUNEW2 (LLIG) &
&                 [M:SNL0]ZERSTOFLG1 (LLIG) = [M:SNL0]ZERSTOFLG2 (LLIG)
                  [M:SNL0]PCUSTUNEW  (LLIG) = [M:SNL0]PCUSTUNEW2 (LLIG)
                  [M:SNL0]QTYSTUNEW  (LLIG) = [M:SNL0]QTYSTUNEW2 (LLIG)
                  [M:SNL0]QTYPCUNEW  (LLIG) = [M:SNL0]QTYPCUNEW2 (LLIG)
                  [M:SNL0]ZERSTOFLG  (LLIG) = [M:SNL0]ZERSTOFLG2 (LLIG)
               Endif
            When "*2",""
#                                          # pré-chargement comptage 2 chargement comptage 1 calcul comptage 3
               [M:SNL0]QTYPCUNEW1     (LLIG) += [F:CUD]QTYPCUNEW1
               WQTYPCUNEW1                   += [F:CUD]QTYPCUNEW1
               [M:SNL0]QTYSTUNEW1     (LLIG) += [F:CUD]QTYSTUNEW1
               WQTYSTUNEW1                   += [F:CUD]QTYSTUNEW1
               [M:SNL0]ZERSTOFLG1     (LLIG) =  [F:CUD]ZERSTOFLG1
               If [M:SNL0]QTYSTUNEW1  (LLIG) <> 0 & [M:SNL0]QTYPCUNEW1(LLIG) <>0
                  [M:SNL0]PCUSTUW1    (LLIG) =  [M:SNL0]QTYSTUNEW1(LLIG) / [M:SNL0]QTYPCUNEW1(LLIG)
               Endif
               [M:SNL0]PCUSTUNEW1     (LLIG) =  format$("N>:5.6",[M:SNL0]PCUSTUW1  (LLIG))

               [M:SNL0]QTYPCUNEW2     (LLIG) += [F:CUD]QTYPCUNEW2
               WQTYPCUNEW2                   += [F:CUD]QTYPCUNEW2
               [M:SNL0]QTYSTUNEW2     (LLIG) += [F:CUD]QTYSTUNEW2
               WQTYSTUNEW2                   += [F:CUD]QTYSTUNEW2
               [M:SNL0]ZERSTOFLG2     (LLIG) =  [F:CUD]ZERSTOFLG2
               If [M:SNL0]QTYSTUNEW2  (LLIG) <> 0 & [M:SNL0]QTYPCUNEW2(LLIG) <>0
                  [M:SNL0]PCUSTUW2    (LLIG) =  [M:SNL0]QTYSTUNEW2(LLIG) / [M:SNL0]QTYPCUNEW2(LLIG)
               Endif
               [M:SNL0]PCUSTUNEW2     (LLIG) =  format$("N>:5.6",[M:SNL0]PCUSTUW2  (LLIG))

               [M:SNL0]QTYPCUNEW      (LLIG) += [F:CUD]QTYPCUNEW
               WQTYPCUNEW                    += [F:CUD]QTYPCUNEW
               [M:SNL0]QTYSTUNEW      (LLIG) += [F:CUD]QTYSTUNEW
               WQTYSTUNEW                    += [F:CUD]QTYSTUNEW
               [M:SNL0]ZERSTOFLG1      (LLIG) =  [F:CUD]ZERSTOFLG
               If [M:SNL0]QTYSTUNEW   (LLIG) <> 0 & [M:SNL0]QTYPCUNEW(LLIG) <>0
                  [M:SNL0]PCUSTUW     (LLIG) =  [M:SNL0]QTYSTUNEW(LLIG) / [M:SNL0]QTYPCUNEW(LLIG)
               Endif
               [M:SNL0]PCUSTUNEW      (LLIG) =  format$("N>:5.6",[M:SNL0]PCUSTUW  (LLIG))

       Endcase
   Endif
#                                                                                         # hcb 71659 fin

Else

   If dim([M:SNL0]QTYPCUNEW(LLIG)) > 0
      [M:SNL0]QTYPCUNEW(LLIG)  += [F:CUD]QTYPCUNEW
      If WQTYPCUNEW <> 0
        [M:SNL0]QTYPCUNEW(LLIG)  -= WQTYPCUNEW
        Raz WQTYPCUNEW
      Endif
   Endif
   If dim([M:SNL0]QTYSTUNEW(LLIG)) > 0
      [M:SNL0]QTYSTUNEW(LLIG)  += [F:CUD]QTYSTUNEW
      If WQTYSTUNEW <> 0
        [M:SNL0]QTYSTUNEW(LLIG)  -= WQTYSTUNEW
        Raz WQTYSTUNEW
      Endif
   Endif

   If dim([M:SNL0]PCUSTUW) > 0                                                                # hcb 31134
      If  [M:SNL0]PCUSTUW(LLIG)  <> 0                                                         # hcb 31134
          If [M:SNL0]QTYSTUNEW(LLIG) <> 0 & [M:SNL0]QTYPCUNEW(LLIG) <>0                       # hcb 31134
             If  [M:SNL0]PCUSTUW  (LLIG) <> [M:SNL0]QTYSTUNEW(LLIG) / [M:SNL0]QTYPCUNEW(LLIG) # hcb 31134
                 [M:SNL0]PCUSTUNEW (LLIG) = "$"                                               # hcb 31134
             Else                                                                             # hcb 31134
                 [M:SNL0]PCUSTUNEW (LLIG) = format$("N>:5.6",[M:SNL0]PCUSTUW  (LLIG))         # hcb 31134
             Endif                                                                            # hcb 31134
          Endif                                                                               # hcb 31134
      Else                                                                                    # hcb 31134
          If [M:SNL0]QTYSTUNEW(LLIG) <> 0 & [M:SNL0]QTYPCUNEW(LLIG) <>0                       # hcb 31134
             [M:SNL0]PCUSTUW  (LLIG) = [M:SNL0]QTYSTUNEW(LLIG) / [M:SNL0]QTYPCUNEW(LLIG)      # hcb 31134
          Endif                                                                               # hcb 31134
         [M:SNL0]PCUSTUNEW (LLIG) = format$("N>:5.6",[M:SNL0]PCUSTUW  (LLIG))                 # hcb 31134
      Endif                                                                                   # hcb 31134
   Endif                                                                                    # hcb 31134

#                                                                                         # hcb 71659 deb
   If [M:SNL0]MULCTGFLG = 2
      [M:SNL0]QTYPCUNEW1   (LLIG)     += [F:CUD]QTYPCUNEW1
         If WQTYPCUNEW1 <> 0
            [M:SNL0]QTYPCUNEW1(LLIG)  -= WQTYPCUNEW1
            Raz WQTYPCUNEW1
         Endif
      [M:SNL0]QTYSTUNEW1   (LLIG)     += [F:CUD]QTYSTUNEW1
      If WQTYSTUNEW1 <> 0
         [M:SNL0]QTYSTUNEW1(LLIG)  -= WQTYSTUNEW1
         Raz WQTYSTUNEW1
      Endif
      If [M:SNL0]PCUSTUW1  (LLIG)    <> 0
         If [M:SNL0]QTYSTUNEW1     (LLIG) <> 0 & [M:SNL0]QTYPCUNEW1 (LLIG) <>0
            If  [M:SNL0]PCUSTUW1   (LLIG) <> [M:SNL0]QTYSTUNEW1     (LLIG) / [M:SNL0]QTYPCUNEW1(LLIG)
                [M:SNL0]PCUSTUNEW1 (LLIG) = "$"
            Else
                [M:SNL0]PCUSTUNEW1 (LLIG) = format$("N>:5.6",[M:SNL0]PCUSTUW1  (LLIG))
            Endif
         Endif
      Else
         If [M:SNL0]QTYSTUNEW1     (LLIG) <> 0 & [M:SNL0]QTYPCUNEW1 (LLIG) <>0
            [M:SNL0]PCUSTUW1       (LLIG) = [M:SNL0]QTYSTUNEW1      (LLIG) / [M:SNL0]QTYPCUNEW1(LLIG)
         Else
            [M:SNL0]PCUSTUW1       (LLIG) = [M:SNL0]PCUSTUCOE       (LLIG)
         Endif
         [M:SNL0]PCUSTUNEW1        (LLIG) = format$("N>:5.6",[M:SNL0]PCUSTUW1  (LLIG))
      Endif
      If [M:SNL0]NBDETAIL(LLIG)  > 1
         If [M:SNL0]ZERSTOFLG1(LLIG)  <> [F:CUD]ZERSTOFLG1
            [M:SNL0]ZERSTOFLG1(LLIG) = 1
         Endif
      Endif
      [M:SNL0]QTYPCUNEW2   (LLIG)     += [F:CUD]QTYPCUNEW2
      If WQTYPCUNEW2 <> 0
         [M:SNL0]QTYPCUNEW2(LLIG)  -= WQTYPCUNEW2
         Raz WQTYPCUNEW2
      Endif
      [M:SNL0]QTYSTUNEW2   (LLIG)     += [F:CUD]QTYSTUNEW2
      If WQTYSTUNEW2 <> 0
         [M:SNL0]QTYSTUNEW2(LLIG)  -= WQTYSTUNEW2
         Raz WQTYSTUNEW2
      Endif
      If [M:SNL0]PCUSTUW2  (LLIG)    <> 0
         If [M:SNL0]QTYSTUNEW2     (LLIG) <> 0 & [M:SNL0]QTYPCUNEW2 (LLIG) <>0
            If  [M:SNL0]PCUSTUW2   (LLIG) <> [M:SNL0]QTYSTUNEW2     (LLIG) / [M:SNL0]QTYPCUNEW2(LLIG)
                [M:SNL0]PCUSTUNEW2 (LLIG) = "$"
            Else
                [M:SNL0]PCUSTUNEW2 (LLIG) = format$("N>:5.6",[M:SNL0]PCUSTUW2  (LLIG))
            Endif
         Endif
      Else
         If [M:SNL0]QTYSTUNEW2     (LLIG) <> 0 & [M:SNL0]QTYPCUNEW2 (LLIG) <>0
            [M:SNL0]PCUSTUW2       (LLIG) = [M:SNL0]QTYSTUNEW2      (LLIG) / [M:SNL0]QTYPCUNEW2(LLIG)
         Else
            [M:SNL0]PCUSTUW2       (LLIG) = [M:SNL0]PCUSTUCOE       (LLIG)
         Endif
         [M:SNL0]PCUSTUNEW2         (LLIG) = format$("N>:5.6",[M:SNL0]PCUSTUW2  (LLIG))
      Endif
      If [M:SNL0]NBDETAIL(LLIG)  > 1
         If [M:SNL0]ZERSTOFLG2(LLIG)  <> [F:CUD]ZERSTOFLG2
            [M:SNL0]ZERSTOFLG2(LLIG) = 1
         Endif
      Endif
      [M:SNL0]QTYPCUNEWS1(LLIG) = [M:SNL0]QTYPCUNEW1(LLIG)
      [M:SNL0]QTYSTUNEWS1(LLIG) = [M:SNL0]QTYSTUNEW1(LLIG)
      [M:SNL0]ZERSTOFLGS1(LLIG) = [M:SNL0]ZERSTOFLG1(LLIG)
      [M:SNL0]QTYPCUNEWS2(LLIG) = [M:SNL0]QTYPCUNEW2(LLIG)
      [M:SNL0]QTYSTUNEWS2(LLIG) = [M:SNL0]QTYSTUNEW2(LLIG)
      [M:SNL0]ZERSTOFLGS2(LLIG) = [M:SNL0]ZERSTOFLG2(LLIG)

   Endif
#                                                                                         # hcb 71659 fin



   If dim([M:SNL0]MODFLG) > 0
      [M:SNL0]MODFLG       (LLIG) = 1
   Endif
Endif


If dim([M:SNL0]QTYPCU(LLIG))    > 0
       [M:SNL0]QTYPCU(LLIG)     += [F:CUD]QTYPCU
Endif
If dim([M:SNL0]QTYSTU(LLIG))    > 0
       [M:SNL0]QTYSTU(LLIG)     += [F:CUD]QTYSTU
Endif
If dim([M:SNL0]QTYSTUDEV(LLIG)) > 0
       [M:SNL0]QTYSTUDEV(LLIG)  += ([F:CUD]QTYSTUNEW-[F:CUD]QTYSTU)
Endif
If dim([M:SNL0]PRCDEV(LLIG))    > 0
   If  [M:SNL0]QTYSTU(LLIG)     = 0
       [M:SNL0]PRCDEV(LLIG)     = 0
   Else
       [M:SNL0]PRCDEV(LLIG)     = ([M:SNL0]QTYSTUDEV(LLIG)/[M:SNL0]QTYSTU(LLIG))*100
   Endif
Endif

# valeur unitaire
If dim([M:SNL0]CUNCST(LLIG))    > 0
       [M:SNL0]CUNCST(LLIG)     = [F:CUD]CUNCST
Endif
If dim([M:SNL0]CUNAMT(LLIG))    > 0
       [M:SNL0]CUNAMT(LLIG)     = [M:SNL0]CUNCST(LLIG)*[M:SNL0]QTYSTU(LLIG)
Endif
# valeur Comptée = valeur unitaire * qte comptée
If dim([M:SNL0]CUNAMTNEW(LLIG)) > 0
       [M:SNL0]CUNAMTNEW(LLIG)  = [M:SNL0]CUNCST(LLIG)*[M:SNL0]QTYSTUNEW(LLIG)
Endif


If dim([M:SNL0]ZERSTOFLG(LLIG)) > 0                         # hcb 63659 deb
#       If [F:CUD]ZERSTOFLG = 2
   If [M:SNL0]NBDETAIL(LLIG)  > 1
      If [M:SNL0]ZERSTOFLG(LLIG)  <> [F:CUD]ZERSTOFLG
         [M:SNL0]ZERSTOFLG(LLIG) = 1
      Endif
   Else                                                 # hcb 118433
      [M:SNL0]ZERSTOFLG(LLIG)  = [F:CUD]ZERSTOFLG       # hcb 118433
   Endif
Endif                                                       # hcb 63659 deb

[M:SNL0]QTYPCUNEWS(LLIG) = [M:SNL0]QTYPCUNEW(LLIG)
[M:SNL0]QTYSTUNEWS(LLIG) = [M:SNL0]QTYSTUNEW(LLIG)
#                                                                                         # hcb 71659 deb
[M:SNL0]QTYPCUNEWS1(LLIG) = [M:SNL0]QTYPCUNEW1(LLIG)
[M:SNL0]QTYSTUNEWS1(LLIG) = [M:SNL0]QTYSTUNEW1(LLIG)
[M:SNL0]QTYPCUNEWS2(LLIG) = [M:SNL0]QTYPCUNEW2(LLIG)
[M:SNL0]QTYSTUNEWS2(LLIG) = [M:SNL0]QTYSTUNEW2(LLIG)
#                                                                                         # hcb 71659 fin

Return
########################################################################
# RGP_NEW_CUMUL                                     Rupture regroupement
########################################################################
$RGP_NEW_CUMUL

# hcb 090205 28218 deb
Raz WQTYSTUNEW
Raz WQTYPCUNEW
# hcb 090205 28218 fin
#                                                                                         # hcb 71659 deb
Raz WQTYSTUNEW1
Raz WQTYPCUNEW1
Raz WQTYSTUNEW2
Raz WQTYPCUNEW2
#                                                                                         # hcb 71659 fin

RGP_RUPTURE = RGP_LECTURE
Local Integer LLIG

LLIG = [M:SNL0]NBLIG

If [F:ITM]ITMREF<>[F:CUD]ITMREF
   Read [ITM]ITM0=[F:CUD]ITMREF
   If fstat
      Raz [F:ITM]
   Endif
Endif
#                                                                                         # hcb 71659 deb
If [M:SNL0]MULCTGFLG = 2
   Call SIT_MULTI_COMPTAGE(RGP_FILTRE,RGP_FILTRE1,RGP_FILTRE2,LLIG)
   If [F:CUD]ZERSTOFLG1 = 2
      [M:SNL0]ZERSTOFLG1(LLIG)  = [F:CUD]ZERSTOFLG1
   Endif
   If [F:CUD]ZERSTOFLG2 = 2
      [M:SNL0]ZERSTOFLG2(LLIG)  = [F:CUD]ZERSTOFLG2
   Endif
Endif
#                                                                                         # hcb 71659 fin

[M:SNL0]NBDETAIL(LLIG)          = 0
[M:SNL0]CUMALLQTY(LLIG)         = 0

If dim([M:SNL0]LOC1(LLIG))      > 0
       [M:SNL0]LOC1(LLIG)       = [F:CUD]LOC
Endif
If dim([M:SNL0]ITMREF(LLIG))    > 0
       [M:SNL0]ITMREF(LLIG)     = [F:CUD]ITMREF
Endif
If dim([M:SNL0]ITMDES1(LLIG))    > 0
   Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SNL0]ITMDES1(LLIG), "[F:ITM]") From TRTX3
Endif

If dim([M:SNL0]WRH(LLIG))       > 0
       [M:SNL0]WRH(LLIG)        = [F:CUD]WRH
Endif
If dim([M:SNL0]LPNNUM(LLIG))    > 0                                          # hcb x3-68147
       [M:SNL0]LPNNUM(LLIG)     = [F:CUD]LPNNUM
Endif
If dim([M:SNL0]LOC(LLIG))       > 0
       [M:SNL0]LOC(LLIG)        = [F:CUD]LOC
Endif
If dim([M:SNL0]LOT(LLIG))       > 0
       [M:SNL0]LOT(LLIG)        = [F:CUD]LOT
Endif
If dim([M:SNL0]SLO(LLIG))       > 0
       [M:SNL0]SLO(LLIG)        = [F:CUD]SLO
Endif
If dim([M:SNL0]PCU(LLIG))       > 0
       [M:SNL0]PCU(LLIG)        = [F:CUD]PCU
Endif
If dim([M:SNL0]STA(LLIG))       > 0
       [M:SNL0]STA(LLIG)        = [F:CUD]STA
Endif
If dim([M:SNL0]PCUSTUCOE(LLIG)) > 0
       [M:SNL0]PCUSTUCOE(LLIG)  = [F:CUD]PCUSTUCOE
Endif
If dim([M:SNL0]SERNUM(LLIG))    > 0
       [M:SNL0]SERNUM(LLIG)     = [F:CUD]SERNUM
Endif
If dim([M:SNL0]ABC(LLIG))       > 0
       [M:SNL0]ABC(LLIG)        = [F:CUD]ABCCLS
Endif
If dim([M:SNL0]ZERSTOFLG(LLIG)) > 0
       If [F:CUD]ZERSTOFLG = 2
          [M:SNL0]ZERSTOFLG(LLIG)  = [F:CUD]ZERSTOFLG
       Endif
Endif
If dim([M:SNL0]PALNUM(LLIG))    > 0
       [M:SNL0]PALNUM(LLIG)     = [F:CUD]PALNUM
Endif
If dim([M:SNL0]CTRNUM(LLIG))    > 0
       [M:SNL0]CTRNUM(LLIG)     = [F:CUD]CTRNUM
Endif


[M:SNL0]CUNLISSTAM(LLIG)       = 1
[M:SNL0]CUNLISSTAN(LLIG)       = 9
[M:SNL0]CUNLOKFLG(LLIG)         = [F:CUD]CUNLOKFLG
[M:SNL0]MODFLG(LLIG)            = 1
[M:SNL0]LINFLG(LLIG)            = 2
If [F:ITM]ITMREF<>[F:CUD]ITMREF
    Read [F:ITM]ITM0=[F:CUD]ITMREF
    If fstat
       Raz [F:ITM]
    Endif
Endif
If dim([M:SNL0]STU(LLIG))       > 0
       [M:SNL0]STU(LLIG)        = [F:ITM]STU
Endif

[M:SNL0]SERSEQ(LLIG)     = [F:CUD]SERSEQ                              # hcb 110327

[M:SNL0]NBLIG += 1

Return


########################################################################
# MOD_INV Comptages à partir du détail / ajout lignes crées (ecran SNL0)
########################################################################
$MOD_INV

Local  Integer  WI, I, J,  WRET, IANA
Local  Integer WI
Raz WI
Call DEBTRANS From GLOCK
Trbegin [CUD]

Call MOD_ECRSTJBID([M:SNL1]STOFCY,[M:SNL1]CUNSSSNUM,[M:SNL1]CUNLISNUM ,WRET) From STKINV
If !GOK
   Goto MOD_INV_SUITE
Endif


# si  ajout de ligne depuis clic droit sur fin tableau regroupement (gouvinv = 4)
# il faut tester l existance d l enregistrement bidon
If GOUVINV = 4

   If !clalev([F:STJ])   Local File STOJOU     [STJ] : Endif
   Columns [STJ] (MVTSEQ)
   Filter [STJ] Where STOFCY   =[M:SNL1]STOFCY
&                   & UPDCOD   =2
&                   & ITMREF   =[M:SNL1]ITMREF
&                   & IPTDAT   =[M:SNL0]IPTDAT
&                   & MVTIND   =0
&                   & VCRTYP   =9
&                   & VCRNUM   =[M:SNL1]CUNLISNUM
&                   & VCRNUMORI=[M:SNL1]CUNSSSNUM
&                   & REGFLG   =2

   Read [STJ] STJ0 First
   Filter  [STJ]
   Columns [STJ]
   If fstat
      If !clalev([F:STJ1])  Local File STOJOU     [STJ1] : Endif
      If !clalev([F:ITG])   Local File ITMCATEG   [ITG]  : Endif
      If !clalev([F:ITM])   Local File ITMMASTER  [ITM]  : Endif
      Raz [F:STJ]
      [F:STJ]STOFCY    = [M:SNL1]STOFCY
      [F:STJ]OWNER     = [M:SNL1]STOFCY
      [F:STJ]UPDCOD    = 2
      [F:STJ]REGFLG    = 2
      [F:STJ]ITMREF    = [M:SNL1]ITMREF
      [F:STJ]VCRTYP    = 9
      [F:STJ]VCRNUM    = [M:SNL1]CUNLISNUM
      [F:STJ]VCRNUMORI = [M:SNL1]CUNSSSNUM
      [F:STJ]IPTDAT    = [M:SNL0]IPTDAT
      If [F:ITM]ITMREF<>[M:SNL1]ITMREF
         Read [ITM]ITM0=[M:SNL1]ITMREF
         If fstat
            Raz [F:ITM]
         Endif
      Endif
      #----- Création du mouvement de stock -----#
      Call ECRSTJ(0,WRET) From STKLIB
      If WRET <> 0
         GOK = 0
         Goto MOD_INV_SUITE
      Endif
   Endif
Endif

For WI = 0 To [M:SNL1]NBLIG-1

# test si ligne ajoutée
  If [M:SNL1]ITMLISNUMS(WI) = 0  | (GIMPORT & [M:SNL1]STOCOU  (WI) = 0 )     # hcb 68491

# DEBUT SPECIFICITES IMPORT : dans le cas d un import ITMREF est à la ligne
     If GIMPORT | GVTMOD               #  modif ADC    # hcb 68000
# si  ajout de ligne (ITMLISNUMS(WI) = 0) sans ligne de stock existant il faut tester si le lot existe
#     et le creer le cas echeant
        Local Char WSLO(GLONSLO)
        Raz WSLO
        If dim([M:SNL1]SLO) > 0 & [F:ITM]LOTMGTCOD = 4
           WSLO = [M:SNL1]SLO(WI)
        Endif
        If [M:SNL1]STOCOU  (WI) = 0
# L'article est géré par lot et la rubrique lot présente(Code activité LOT OK)
           If dim([M:SNL1]LOT) > 0
              If [M:SNL1]LOTMGT_IMP(WI) <> 1
                 If  [M:SNL1]QTYSTUNEW(WI) <> 0 | [M:SNL1]QTYSTUNEW1(WI) <> 0 | [M:SNL1]QTYSTUNEW2(WI) <> 0 # hcb 71659
                     If [M:SNL1]LOTMGT_IMP(WI)= 4
                        Read [STL]STL0=[M:SNL1]ITMREF_IMP(WI);[M:SNL1]LOT(WI);WSLO
                        If  fstat
                            Filter [F:STL] Where ITMREF = [M:SNL1]ITMREF_IMP(WI) & LOT = [M:SNL1]LOT(WI)
&                           Order By Key STL0
                            Read [STL] First
                            If fstat
                               Raz [F:STL]
                               [F:STL]ITMREF    = [M:SNL1]ITMREF_IMP(WI)
                               [F:STL]LOT       = [M:SNL1]LOT(WI)
                               [F:STL]SLO       = WSLO
                               [F:STL]VCRTYP    = 9
                               [F:STL]VCRNUM    = [M:SNL1]CUNLISNUM
                               [F:STL]VCRLIN    = 0
                               [F:STL]ACT       = 1
                               If dim([M:SNL1]ECCVALMAJ) > 0
                                  [F:STL]ECCVALMAJ = [M:SNL1]ECCVALMAJ (WI)
                                  [F:STL]ECCVALMIN = [M:SNL1]ECCVALMIN (WI)
                               Endif
                               [F:STL]POT       = [M:SNL1]POT      (WI)
                               [F:STL]SHL       = [M:SNL1]SHL      (WI)
                               [F:STL]SHLDAT    = [M:SNL1]SHLDAT   (WI)
                               [F:STL]REFPER    = [M:SNL1]REFPER   (WI)
                               [F:STL]DLUDAT    = [M:SNL1]DLUDAT   (WI)       # v6per
                               [F:STL]NEWLTIDAT = [M:SNL1]NEWLTIDAT(WI)       # v6per
                               [F:STL]SHLUOM    = [M:SNL1]SHLUOM   (WI)       # v6per
                               [F:STL]SHLLTI    = [M:SNL1]SHLLTI   (WI)       # v6per
                               [F:STL]SHLLTIUOM = [M:SNL1]SHLLTIUOM(WI)       # v6per
                               [F:STL]DLU       = [M:SNL1]DLU      (WI)       # v6per
                               [F:STL]LOTCREDAT = date$
                               Call ECRSTL From STKLIB
                               If fstat
#                                                                           hcb 68000 deb
                                  If GIMPORT                #  modif ADC
                                      WIMPORT_ERR = 17
                                      Gosub ECR_ERREUR From IMPSNXS
                                      GOK = 0
                                      Goto MOD_INV_SUITE
                                  Endif                        #  modif ADC
                                  If GVTMOD                    #  modif ADC
                                     GMESSAGE = mess(13,100,1) #  modif ADC
                                      GOK = 0                  #  modif ADC
                                      Goto MOD_INV_SUITE       #  modif ADC
                                  Endif                        #  modif ADC
#                                                                           hcb 68000 end
                               Endif
#flag creation STOLOT à oui
                               [M:SNL1]STLFLG(WI) = 2
                               Raz [F:SLF]                    # hcb 93726
                               [F:SLF]       = [F:STL]
                               [F:SLF]STOFCY = [M:SNL1]STOFCY
                               Call ECRSLF From STKLIB
                               If fstat
#                                                                           hcb 68000 deb
                                  If GIMPORT                   #  modif ADC
                                     WIMPORT_ERR = 35
                                     Gosub ECR_ERREUR From IMPSNXS
                                     GOK = 0
                                     Goto MOD_INV_SUITE
                                  Endif
                                  If GVTMOD                    #  modif ADC
                                     GMESSAGE = mess(13,100,1) #  modif ADC
                                     GOK = 0                   #  modif ADC
                                     Goto MOD_INV_SUITE        #  modif ADC
                                  Endif                        #  modif ADC
#                                                                           hcb 68000 end
                               Endif
                            Else
                               [F:STL]VCRTYP    = 9
                               [F:STL]SLO       = WSLO
                               [F:STL]VCRNUM    = [M:SNL1]CUNLISNUM
                               [F:STL]VCRLIN    = 0
                               [F:STL]LOTCREDAT = date$
                               Call ECRSTL From STKLIB
                               If fstat
#                                                                           hcb 68000 deb
                                  If GIMPORT                   #  modif ADC
                                      WIMPORT_ERR = 17
                                      Gosub ECR_ERREUR From IMPSNXS
                                      GOK = 0
                                      Goto MOD_INV_SUITE
                                  Endif                        #  modif ADC
                                  If GVTMOD                    #  modif ADC
                                     GMESSAGE = mess(13,100,1) #  modif ADC
                                      GOK = 0                  #  modif ADC
                                      Goto MOD_INV_SUITE       #  modif ADC
                                  Endif                        #  modif ADC
#                                                                           hcb 68000 end
                               Endif
#flag creation STOLOT à oui
                               [M:SNL1]STLFLG(WI) = 2
                            Endif
                            Filter [F:STL]
                        Endif
                     Else
                        Read [STL]STL0=[M:SNL1]ITMREF_IMP(WI);[M:SNL1]LOT(WI);""
                        If  fstat
                               Raz [F:STL]
                               [F:STL]ITMREF    = [M:SNL1]ITMREF_IMP(WI)
                               [F:STL]LOT       = [M:SNL1]LOT(WI)
                               [F:STL]SLO       = ""
                               [F:STL]VCRTYP    = 9
                               [F:STL]VCRNUM    = [M:SNL1]CUNLISNUM
                               [F:STL]VCRLIN    = 0
                               [F:STL]ACT       = 1
                               If dim([M:SNL1]ECCVALMAJ) > 0
                                  [F:STL]ECCVALMAJ = [M:SNL1]ECCVALMAJ (WI)
                                  [F:STL]ECCVALMIN = [M:SNL1]ECCVALMIN (WI)
                               Endif
                               [F:STL]POT       = [M:SNL1]POT      (WI)
                               [F:STL]SHL       = [M:SNL1]SHL      (WI)
                               [F:STL]SHLDAT    = [M:SNL1]SHLDAT   (WI)
                               [F:STL]REFPER    = [M:SNL1]REFPER   (WI)
                               [F:STL]DLUDAT    = [M:SNL1]DLUDAT   (WI)       # v6per
                               [F:STL]NEWLTIDAT = [M:SNL1]NEWLTIDAT(WI)       # v6per
                               [F:STL]SHLUOM    = [M:SNL1]SHLUOM   (WI)       # v6per
                               [F:STL]SHLLTI    = [M:SNL1]SHLLTI   (WI)       # v6per
                               [F:STL]SHLLTIUOM = [M:SNL1]SHLLTIUOM(WI)       # v6per
                               [F:STL]DLU       = [M:SNL1]DLU      (WI)       # v6per
                               [F:STL]LOTCREDAT = date$
                               Call ECRSTL From STKLIB
                               If fstat
#                                                                           hcb 68000 deb
                                  If GIMPORT                   #  modif ADC
                                      WIMPORT_ERR = 17
                                      Gosub ECR_ERREUR From IMPSNXS
                                      GOK = 0
                                      Goto MOD_INV_SUITE
                                  Endif                        #  modif ADC
                                  If GVTMOD                    #  modif ADC
                                     GMESSAGE = mess(13,100,1) #  modif ADC
                                     GOK = 0                   #  modif ADC
                                     Goto MOD_INV_SUITE        #  modif ADC
                                  Endif                        #  modif ADC
#                                                                           hcb 68000 end
                               Endif
#flag creation STOLOT à oui
                               [M:SNL1]STLFLG(WI) = 2
                               Raz [F:SLF]                    # hcb 93726
                               [F:SLF]       = [F:STL]
                               [F:SLF]STOFCY = [M:SNL1]STOFCY
                               Call ECRSLF From STKLIB
                               If fstat
#                                                                           hcb 68000 deb
                                  If GIMPORT                   #  modif ADC
                                     WIMPORT_ERR = 35
                                     Gosub ECR_ERREUR From IMPSNXS
                                     GOK = 0
                                     Goto MOD_INV_SUITE
                                  Endif
                                  If GVTMOD                    #  modif ADC
                                     GMESSAGE = mess(13,100,1) #  modif ADC
                                     GOK = 0                   #  modif ADC
                                     Goto MOD_INV_SUITE        #  modif ADC
                                  Endif                        #  modif ADC
#                                                                           hcb 68000 end
                               Endif
                        Endif
                     Endif
                 Endif
              Else
# creation lot blanc pour les articles non gere en lot
                 Raz WSLO
                 Read [STL]STL0=[M:SNL1]ITMREF_IMP(WI);"";WSLO
                 If  fstat
                     [F:STL]ITMREF    = [M:SNL1]ITMREF_IMP(WI)
                     [F:STL]LOT       = ""
                     [F:STL]SLO       = WSLO
                     Raz [F:STL]ECCVALMAJ
                     Raz [F:STL]ECCVALMIN
                     [F:STL]VCRTYP    = 9
                     [F:STL]VCRNUM    = [M:SNL1]CUNLISNUM
                     [F:STL]VCRLIN    = 0
                     [F:STL]REFPER    = date$
                     [F:STL]LOTCREDAT = date$
                     #--- Bug 60996
                     [F:STL]POT       = 100
                     [F:STL]ACT       = 1
                     #---
                     Call ECRSTL From STKLIB
                     If fstat
#                                                                           hcb 68000 deb
                        If GIMPORT                      #  modif ADC
                           WIMPORT_ERR = 17
                           Gosub ECR_ERREUR From IMPSNXS
                           GOK = 0
                           Goto MOD_INV_SUITE
                        Endif                           #  modif ADC
                           If GVTMOD                    #  modif ADC
                              GMESSAGE = mess(13,100,1) #  modif ADC
                              GOK = 0                   #  modif ADC
                              Goto MOD_INV_SUITE        #  modif ADC
                           Endif                        #  modif ADC
#                                                                           hcb 68000 end
                     Endif
#flag creation STOLOT à oui
                     [M:SNL1]STLFLG(WI) = 2
                     Raz [F:SLF]                    # hcb 93726
                     [F:SLF]       = [F:STL]
                     [F:SLF]STOFCY = [M:SNL1]STOFCY
                     Call ECRSLF From STKLIB
                     If fstat
#                                                                           hcb 68000 deb
                        If GIMPORT                   #  modif ADC
                           WIMPORT_ERR = 35
                           Gosub ECR_ERREUR From IMPSNXS
                           GOK = 0
                           Goto MOD_INV_SUITE
                        Endif
                        If GVTMOD                    #  modif ADC
                           GMESSAGE = mess(13,100,1) #  modif ADC
                           GOK = 0                   #  modif ADC
                           Goto MOD_INV_SUITE        #  modif ADC
                        Endif                        #  modif ADC
#                                                                           hcb 68000 end
                     Endif
                 Endif
              Endif
           Endif
        Endif
        If GIMPORT & [M:SNL1]STLFLG(WI) <> 2     # hcb 75176
           Raz [M:SNL1]PRIORD(WI)
        Endif
     Endif

# # FIN SPECIFICITES IMPORT: dans le cas d un import ITMREF est à la ligne
     If [M:SNL1]ITMLISNUMS(WI) = 0                                      # hcb 68491
       nolign = WI+1
#recherche dernier rang pour la liste
       Filter [CUD] Where  CUNSSSNUM     = [M:SNL1]CUNSSSNUM  &
&                          CUNLISNUM     = [M:SNL1]CUNLISNUM
&                          Order By Key CUD0 Desc
       Read [CUD] First
       If fstat   = 0 & [F:CUD]ITMLISNUM<> 0
           WLIN   =[F:CUD]ITMLISNUM
       Else
           WLIN   = 999
       Endif

       Filter [CUD]

       WLIN += 1
       Raz [F:ITM]
       Raz [F:ITF]
       If clalev([M:SIW])=0 Local Mask STOINVW   [SIW] Endif  #  ecran détail inventaire
       Raz [M:SIW]
       I = 0
       [M:SIW]CUNSSSNUM      = [M:SNL1]CUNSSSNUM
       [M:SIW]CUNLISNUM      = [M:SNL1]CUNLISNUM
       [M:SIW]STOFCY         = [M:SNL1]STOFCY
       [M:SIW]CUNLISDAT      = date$
       [M:SIW]CUR            = GLOCALDEV
       [M:SIW]ITMREF    (I)  = [M:SNL1]ITMREF
       [M:SIW]LINFLG    (I)  = [M:SNL1]LINFLG    (WI)
       If dim([M:SNL1]LOT) > 0
          [M:SIW]LOT    (I)  = [M:SNL1]LOT       (WI)
       Endif
       If dim([M:SNL1]LOC) > 0
          [M:SIW]LOC    (I)  = [M:SNL1]LOC       (WI)
       Endif
       If dim([M:SNL1]LPNNUM) > 0                                            # hcb X3-68147
          [M:SIW]LPNNUM (I)  = [M:SNL1]LPNNUM    (WI)
       Endif
       If dim([M:SNL1]WRH) > 0
          [M:SIW]WRH    (I)  = [M:SNL1]WRH       (WI)
       Endif
       [M:SIW]STA       (I)  = [M:SNL1]STA       (WI)
       [M:SIW]ABCCLS    (I)  = [M:SNL1]ABCCLS
       [M:SIW]PCU       (I)  = [M:SNL1]PCU       (WI)
       [M:SIW]QTYPCU    (I)  = [M:SNL1]QTYPCU    (WI)
       [M:SIW]QTYPCUNEW (I)  = [M:SNL1]QTYPCUNEW (WI)
       [M:SIW]PCUSTUCOE (I)  = [M:SNL1]PCUSTUCOE (WI)
       [M:SIW]QTYSTU    (I)  = [M:SNL1]QTYSTU    (WI)
       [M:SIW]QTYSTUNEW (I)  = [M:SNL1]QTYSTUNEW (WI)
       If dim([M:SNL1]SLO) > 0
          [M:SIW]SLO    (I)  = [M:SNL1]SLO       (WI)
       Endif
        If dim([M:SNL1]ECCVALMAJ) > 0
           [M:SIW]ECCVALMAJ (I)  = [M:SNL1]ECCVALMAJ (WI)
        Endif
        If dim([M:SNL1]ECCVALMIN) > 0
           [M:SIW]ECCVALMIN (I)  = [M:SNL1]ECCVALMIN (WI)
        Endif
       If dim([M:SNL1]SERNUM) > 0
          [M:SIW]SERNUM (I)  = [M:SNL1]SERNUM    (WI)
       Endif
       [M:SIW]CUNCST    (I)  = [M:SNL1]CUNCST    (WI)
       [M:SIW]STOCOU    (I)  = [M:SNL1]STOCOU    (WI)
       [M:SIW]ZERSTOFLG (I)  = [M:SNL1]ZERSTOFLG (WI)
       [M:SIW]DEPRAT    (I)  = [M:SNL1]DEPRAT    (WI)
       [M:SIW]DEPAMT    (I)  = [M:SNL1]DEPAMT    (WI)
       [M:SIW]PRIORD    (I)  = [M:SNL1]PRIORD    (WI)
       If dim([M:SNL1]PALNUM) > 0
          [M:SIW]PALNUM    (I)  = [M:SNL1]PALNUM (WI)
       Endif
       If dim([M:SNL1]CTRNUM) > 0
          [M:SIW]CTRNUM    (I)  = [M:SNL1]CTRNUM (WI)
       Endif
       [M:SIW]QLYCTLDEM (I)  = [M:SNL1]QLYCTLDEM (WI)
       [M:SIW]OWNER     (I)  = [M:SNL1]OWNER     (WI)
       If [M:SIW]OWNER  (I)  = ""
          [M:SIW]OWNER  (I)  = [M:SIW]STOFCY
       Endif
       If dim([M:SNL1]STOFLD1) > 0
          [M:SIW]STOFLD1(I)  = [M:SNL1]STOFLD1(WI)
       Endif
       If dim([M:SNL1]STOFLD2) > 0
          [M:SIW]STOFLD2(I)  = [M:SNL1]STOFLD2(WI)
       Endif
#                                                                                         # hcb 71659 deb
      If [M:SNL0]MULCTGFLG = 2
         [M:SIW]QTYSTUNEW1 (I) = [M:SNL1]QTYSTUNEW1 (WI)
         [M:SIW]QTYPCUNEW1 (I) = [M:SNL1]QTYPCUNEW1 (WI)
         [M:SIW]ZERSTOFLG1 (I) = [M:SNL1]ZERSTOFLG1 (WI)
         [M:SIW]QTYSTUNEW2 (I) = [M:SNL1]QTYSTUNEW2 (WI)
         [M:SIW]QTYPCUNEW2 (I) = [M:SNL1]QTYPCUNEW2 (WI)
         [M:SIW]ZERSTOFLG2 (I) = [M:SNL1]ZERSTOFLG2 (WI)
      Endif
#                                                                                         # hcb 71659 fin
      [M:SIW]SERSEQ      (I) = [M:SNL1]SERSEQ     (WI)              # hcb 110327

       If clalev([M:VALW])
           If clalev([M:VIW])=0 Local Mask STOVALW   [VIW] Endif  #  ecran détail inventaire
           For J=0 To GACTMAT-1
               [M:VIW]OMATCST(I*GACTMAT+J)   = [M:VALW]OMATCST(WI*GACTMAT+J)
           Next
           [M:VIW]OOVEMATCST(I) = [M:VALW]OOVEMATCST(WI)

           For J=0 To GACTMAC-1
               [M:VIW]OMACCST(I*GACTMAC+J)   = [M:VALW]OMACCST(WI*GACTMAC+J)
           Next
           [M:VIW]OOVEMACCST(I) = [M:VALW]OOVEMACCST(WI)

           For J=0 To GACTLAB-1
               [M:VIW]OLABCST(I*GACTLAB+J)   = [M:VALW]OLABCST(WI*GACTLAB+J)
           Next
           [M:VIW]OOVELABCST(I) = [M:VALW]OOVELABCST(WI)

           [M:VIW]OSCOTOT(I)    = [M:VALW]OSCOTOT(WI)
           [M:VIW]OOVESCOCST(I) = [M:VALW]OOVESCOCST(WI)

            [M:VIW]OINVDTACST(I) = [M:VALW]OINVDTACST(WI)

           [M:VIW]PRI(I)        = [M:VALW]PRI(WI)
        Endif

# dans le cas d un import ITMREF et ABCCLS sont à la ligne
        If GIMPORT
          [M:SIW]ABCCLS (I)  = [M:SNL1]ABCCLS_IMP(WI)
          [M:SIW]ITMREF (I)  = [M:SNL1]ITMREF_IMP(WI)
        Endif

# Les sections ana peuvent être modifiables
        For IANA =1 To GNBDIE                               # Ana
            Assign "[M:SIW]CCE"+num$(IANA)+"(I)" With [M:SNL1]CCE(IANA-1)       # Ana
        Next
        Call TRT_VALEUR  (I,"SIW") From STKINV                 # hcb 41104
        GPOINT = "SNL_SIW"                    # hcb 54067
        Gosub  ENTREE From EXEFNC             # hcb 54067
        Gosub CRE_CUD
        If GOK <> 1
           Break
        Endif
        #     si comptée et que serseq est <> 0 alors  mise à jour des numeros de series globals
      If [F:CUD]CUNLISSTA = 2 & [F:CUD]SERSEQ <> 0
         Call ECR_CSD([F:CUD]STOFCY,[F:CUD]CUNSSSNUM,[F:CUD]CUNLISNUM,[F:CUD]SERSEQ,[F:CUD]ZERSTOFLG,WRET) From STKINV1
         If WRET = 9
            GOK  = 0
            Break
         Endif
      Endif
#                                                                     # hcb 110327 end
# on passe le flg creation lot à 1 pour ne pas le supprimer en sortant
        If [M:SNL1]STLFLG (WI) = 2
           [M:SNL1]STLFLG (WI) = 1
        Endif

# gajouinv = ajout de ligne   (pour renumeroter la liste en sortie du menu inventaire)
        GAJOUINV = 1
#flag modification de liste à oui
        GMOD_INV = 2
# hcb 68491  deb
     Endif
     If [M:SNL1]ITMLISNUMS(WI) <> 0 & GIMPORT & [M:SNL1]STOCOU (WI) = 0
        If [M:SNL1]MODFLG(WI) = 2
           Readlock [CUD]CUD0=[M:SNL1]CUNSSSNUM;[M:SNL1]CUNLISNUM;[M:SNL1]ITMLISNUMS(WI)
           Case fstat
                When 0 :
                When 1 :
                   GMESSAGE = mess(20,100,1)-"CUNLISDET"-[M:SNL1]CUNLISNUM-num$([M:SNL1]ITMLISNUMS(WI))
                   GOK = -1
                   Break
                When Default :
                   GOK = 0
                   Call FSTA("CUD") From GLOCK
                   Break
           Endcase
           [F:CUD]STA             = [M:SNL1]STA(WI)
           If dim([M:SNL1]LOT) > 0
              [F:CUD]LOT          = [M:SNL1]LOT(WI)
           Endif
           If dim([M:SNL1]SLO) > 0
              [F:CUD]SLO          = [M:SNL1]SLO(WI)
           Endif
           If dim([M:SNL1]ECCVALMAJ) > 0
              [F:CUD]ECCVALMAJ    = [M:SNL1]ECCVALMAJ(WI)
           Endif
           If dim([M:SNL1]ECCVALMIN) > 0
              [F:CUD]ECCVALMIN    = [M:SNL1]ECCVALMIN(WI)
           Endif
           If dim([M:SNL1]LOC) > 0
             [F:CUD]LOC          = [M:SNL1]LOC(WI)
           Endif
           If dim([M:SNL1]LPNNUM) > 0                                               # hcb X3-68147
              [F:CUD]LPNNUM      = [M:SNL1]LPNNUM(WI)
           Endif
           If dim([M:SNL1]PALNUM) > 0
              [F:CUD]PALNUM       = [M:SNL1]PALNUM(WI)
           Endif
           If dim([M:SNL1]CTRNUM) > 0
              [F:CUD]CTRNUM       = [M:SNL1]CTRNUM(WI)
           Endif
           If dim([M:SNL1]STOFLD1) > 0
              [F:CUD]STOFLD1      = [M:SNL1]STOFLD1(WI)
           Endif
           If dim([M:SNL1]STOFLD2) > 0
              [F:CUD]STOFLD2      = [M:SNL1]STOFLD2(WI)
           Endif
           If dim([M:SNL1]WRH) > 0
              [F:CUD]WRH          = [M:SNL1]WRH      (WI)
           Endif
           [F:CUD]QTYPCUNEW       = [M:SNL1]QTYPCUNEW(WI)
           [F:CUD]QTYSTUNEW       = [M:SNL1]QTYSTUNEW(WI)
           [F:CUD]ZERSTOFLG       = [M:SNL1]ZERSTOFLG(WI)
           [F:CUD]DEPRAT          = [M:SNL1]DEPRAT   (WI)
           [F:CUD]DEPAMT          = [M:SNL1]DEPAMT   (WI)
           [F:CUD]OWNER           = [M:SNL1]OWNER    (WI)
#                                                                                         # hcb 71659 deb
           If [M:SNL0]MULCTGFLG = 2
              [F:CUD]QTYSTUNEW1      = [M:SNL1]QTYSTUNEW1 (WI)
              [F:CUD]QTYPCUNEW1      = [M:SNL1]QTYPCUNEW1 (WI)
              [F:CUD]ZERSTOFLG1      = [M:SNL1]ZERSTOFLG1 (WI)
              [F:CUD]QTYSTUNEW2      = [M:SNL1]QTYSTUNEW2 (WI)
              [F:CUD]QTYPCUNEW2      = [M:SNL1]QTYPCUNEW2 (WI)
              [F:CUD]ZERSTOFLG2      = [M:SNL1]ZERSTOFLG2 (WI)
           Endif
#                                                                                         # hcb 71659 fin

           If clalev([M:VALW])
              For J=0 To GACTMAT-1
                  [F:CUD]MATCST(J)  = [M:VALW]OMATCST(WI*GACTMAT+J)
              Next
              [F:CUD]OVEMATCST  = [M:VALW]OOVEMATCST(WI)
              For J=0 To GACTMAC-1
                  [F:CUD]MACCST(J)  = [M:VALW]OMACCST(WI*GACTMAC+J)
              Next
              [F:CUD]OVEMACCST  = [M:VALW]OOVEMACCST(WI)
              For J=0 To GACTLAB-1
                 [F:CUD]LABCST(J)  = [M:VALW]OLABCST(WI*GACTLAB+J)
              Next
              [F:CUD]OVELABCST  = [M:VALW]OOVELABCST(WI)
              [F:CUD]SCOCST     = [M:VALW]OSCOTOT(WI)
              [F:CUD]OVESCOCST  = [M:VALW]OOVESCOCST(WI)
              [F:CUD]INVDTACST  = [M:VALW]OINVDTACST(WI)
              [F:CUD]PRIORD     = [M:VALW]PRI(WI)
           Endif
           If [F:CUD]QTYPCUNEW  = 0 &  [F:CUD]QTYSTUNEW = 0 & [F:CUD]ZERSTOFLG <> 2
              [F:CUD]CUNLISSTA = 1
              [F:CUD]ZERSTOFLG = 1
           Else
              [F:CUD]CUNLISSTA = 2
           Endif
           #                                                                     # hcb 110327 deb
#     si comptée et que serseq est <> 0 alors  mise à jour des numeros de series globals
      If [F:CUD]CUNLISSTA = 2 & [F:CUD]SERSEQ <> 0
         Call ECR_CSD([F:CUD]STOFCY,[F:CUD]CUNSSSNUM,[F:CUD]CUNLISNUM,[F:CUD]SERSEQ,[F:CUD]ZERSTOFLG,WRET) From STKINV1
         If WRET = 9
            GOK  = 0
            Break
         Endif
      Endif
#                                                                     # hcb 110327 end
           [F:CUD]UPDUSR    = GUSER
           [F:CUD]UPDDAT    = date$
           GPOINT = "SNL_CUD"
           Gosub  ENTREE From EXEFNC
           Rewrite [CUD]
           If fstat
              GOK = 0
              Call FSTA("CUD") From GLOCK
              Break
           Endif
# on passe le flg creation lot à 1 pour ne pas le supprimer en sortant
           If [M:SNL1]STLFLG (WI) = 2
              [M:SNL1]STLFLG (WI) = 1
           Endif
#flag modification de liste à oui
           GMOD_INV = 2
        Endif
     Endif
#             hcb 68491           fin
  Else
# si ligne pas ajoutée test si modifiée
    If [M:SNL1]MODFLG(WI) = 2
      Readlock [CUD]CUD0=[M:SNL1]CUNSSSNUM;[M:SNL1]CUNLISNUM;[M:SNL1]ITMLISNUMS(WI)
      Case fstat
        When 0 :
        When 1 :
          GMESSAGE = mess(20,100,1)-"CUNLISDET"-[M:SNL1]CUNLISNUM-num$([M:SNL1]ITMLISNUMS(WI))    # hcb 45291
          GOK = -1
          Break
        When Default :
          GOK = 0
          Call FSTA("CUD") From GLOCK
          Break
      Endcase
      [F:CUD]STA             = [M:SNL1]STA(WI)
      If dim([M:SNL1]LOT) > 0
         [F:CUD]LOT          = [M:SNL1]LOT(WI)
      Endif
      If dim([M:SNL1]SLO) > 0
         [F:CUD]SLO          = [M:SNL1]SLO(WI)
      Endif
      If dim([M:SNL1]ECCVALMAJ) > 0
         [F:CUD]ECCVALMAJ    = [M:SNL1]ECCVALMAJ(WI)
      Endif
      If dim([M:SNL1]LOC) > 0
         [F:CUD]LOC          = [M:SNL1]LOC(WI)
      Endif
      If dim([M:SNL1]LPNNUM) > 0                                               # hcb X3-68147
         [F:CUD]LPNNUM       = [M:SNL1]LPNNUM(WI)
      Endif
      If dim([M:SNL1]PALNUM) > 0
         [F:CUD]PALNUM       = [M:SNL1]PALNUM(WI)
      Endif
      If dim([M:SNL1]CTRNUM) > 0
         [F:CUD]CTRNUM       = [M:SNL1]CTRNUM(WI)
      Endif
      If dim([M:SNL1]STOFLD1) > 0
         [F:CUD]STOFLD1      = [M:SNL1]STOFLD1(WI)
      Endif
      If dim([M:SNL1]STOFLD2) > 0
         [F:CUD]STOFLD2      = [M:SNL1]STOFLD2(WI)
      Endif
      If dim([M:SNL1]WRH) > 0
         [F:CUD]WRH          = [M:SNL1]WRH      (WI)
      Endif
      [F:CUD]QTYPCUNEW       = [M:SNL1]QTYPCUNEW(WI)
      [F:CUD]QTYSTUNEW       = [M:SNL1]QTYSTUNEW(WI)
      [F:CUD]ZERSTOFLG       = [M:SNL1]ZERSTOFLG(WI)
      [F:CUD]DEPRAT          = [M:SNL1]DEPRAT   (WI)
      [F:CUD]DEPAMT          = [M:SNL1]DEPAMT   (WI)
      [F:CUD]OWNER           = [M:SNL1]OWNER    (WI)
#                                                                                         # hcb 71659 deb
      If [M:SNL0]MULCTGFLG = 2
         [F:CUD]QTYSTUNEW1      = [M:SNL1]QTYSTUNEW1 (WI)
         [F:CUD]QTYPCUNEW1      = [M:SNL1]QTYPCUNEW1 (WI)
         [F:CUD]ZERSTOFLG1      = [M:SNL1]ZERSTOFLG1 (WI)
         [F:CUD]QTYSTUNEW2      = [M:SNL1]QTYSTUNEW2 (WI)
         [F:CUD]QTYPCUNEW2      = [M:SNL1]QTYPCUNEW2 (WI)
         [F:CUD]ZERSTOFLG2      = [M:SNL1]ZERSTOFLG2 (WI)
      Endif
#                                                                                         # hcb 71659 fin
      If clalev([M:VALW])
        For J=0 To GACTMAT-1
            [F:CUD]MATCST(J)  = [M:VALW]OMATCST(WI*GACTMAT+J)
        Next
        [F:CUD]OVEMATCST  = [M:VALW]OOVEMATCST(WI)

        For J=0 To GACTMAC-1
            [F:CUD]MACCST(J)  = [M:VALW]OMACCST(WI*GACTMAC+J)
        Next
        [F:CUD]OVEMACCST  = [M:VALW]OOVEMACCST(WI)

        For J=0 To GACTLAB-1
            [F:CUD]LABCST(J)  = [M:VALW]OLABCST(WI*GACTLAB+J)
        Next
        [F:CUD]OVELABCST  = [M:VALW]OOVELABCST(WI)

        [F:CUD]SCOCST     = [M:VALW]OSCOTOT(WI)
        [F:CUD]OVESCOCST  = [M:VALW]OOVESCOCST(WI)

        [F:CUD]PRIORD     = [M:VALW]PRI(WI)
      Endif

      If [F:CUD]QTYPCUNEW  = 0 &  [F:CUD]QTYSTUNEW = 0 & [F:CUD]ZERSTOFLG <> 2
         [F:CUD]CUNLISSTA = 1
         [F:CUD]ZERSTOFLG = 1
      Else
        [F:CUD]CUNLISSTA = 2
      Endif
      [F:CUD]UPDUSR    = GUSER
      [F:CUD]UPDDAT    = date$

      GPOINT = "SNL_CUD"                    # hcb 54067
      Gosub  ENTREE From EXEFNC             # hcb 54067

      Rewrite [CUD]
      If fstat
        GOK = 0
        Call FSTA("CUD") From GLOCK
        Break
      Endif
# on passe le flg creation lot à 1 pour ne pas le supprimer en sortant
      If [M:SNL1]STLFLG (WI) = 2
         [M:SNL1]STLFLG (WI) = 1
      Endif

#flag modification de liste à oui
      GMOD_INV = 2
    Endif
  Endif
  [M:SNL1]MODFLG(WI) = 0                                                                  # hcb 71659
  [M:SNL1]LINFLG(WI) = 2                                                                  # hcb x3*68147
Next WI
# si ajout de ligne est que la liste etait validée il faut la passéee en validée partielle
If GAJOUINV = 1
#maj  liste inventaire
      Readlock [CUL]CUL0=[M:SNL1]CUNSSSNUM;[M:SNL1]CUNLISNUM
      Case fstat
           When 0 :
           When 1 :
               GOK = -1
               GMESSAGE = mess(20,100,1)-"CUNLISTE"-[M:SNL1]CUNSSSNUM
           When Default :
               GOK = 0
               Call FSTA("CUL") From GLOCK
      Endcase
      If GOK
         If [F:CUL]CUNLISSTA = 5
            [F:CUL]CUNLISSTA = 4
            [F:CUL]UPDUSR    = GUSER
            [F:CUL]UPDDAT    = date$
            Rewrite  [CUL]
            If fstat
               GOK = 0
               Call FSTA("CUL") From GLOCK
            Endif
         Endif
      Endif
Endif
$MOD_INV_SUITE
If GOK < 1
   Gosub AB_TRT
Else
   Commit
# si ajout de ligne depuis le regroupement les lignes ajoutées ne sont pas effacées il faut donc
# initialisé modflg à 1 et itmlisnum <> 0
   If (GAJOUINV = 1 &  (GOUVINV = 3 | GOUVINV = 4 )) | GIMPINV = 1
      Raz WI
      For WI = 0 To [M:SNL1]NBLIG-1
          If [M:SNL1]ITMLISNUMS(WI) = 0
             [M:SNL1]ITMLISNUMS(WI) = WLIN
          Endif
          [M:SNL1]MODFLG(WI) = 1
      Next WI
   Endif
Endif
#                                                                       # hcb 68147 deb
# Controle cohérence conteanant / emplacement
# fait ici une premiere fois pour ne pas perdre la saisie
# l utilisateur a peut etre renseigner l emplecement du contenant ds un autre comptage de la liste
Raz WI
If [M:SNL1]LPNMGTCOD = 2 & GAJOUINV = 1
   For WI = 0 To [M:SNL1]NBLIG-1
       If [M:SNL1]LPNNUM(WI) <> ""
          Call CTR_CUD_LPN([M:SNL1]CUNSSSNUM,[M:SNL1]CUNLISNUM,[M:SNL1]LPNNUM(WI),[M:SNL1]LOC(WI),WRET) From STKINV1
       Endif
       If WRET <> 0
          Break
       Endif
   Next I

Endif
#                                                                       # hcb 68147 fin

Return


########################################################################
# MOD_INV_RGP          Comptages à partir des regroupements (ecran SNL0)
########################################################################
$MOD_INV_RGP
Local  Integer  LG, I,   WRET, IANA
Local Char    CRITER0(80)
Local Char    CRITER1(250)(3)
Local Char    CRITER2(50)
Local Char RGP_FILTRE (250)                                                               # hcb 71659
Local Char RGP_FILTRE1(250)                                                               # hcb 71659
Local Char RGP_FILTRE2(250)                                                               # hcb 71659


Call MOD_ECRSTJBID([M:SNL0]STOFCY,[M:SNL0]CUNSSSNUM,[M:SNL0]CUNLISNUM ,WRET) From STKINV
If !GOK
   Return
Endif


CRITER0 = "[F:CUD]CUNSSSNUM = [M:SNL0]CUNSSSNUM & [F:CUD]CUNLISNUM = [M:SNL0]CUNLISNUM"
CRITER2 = "[F:CUD]QTYSTUNEW = 0 & [F:CUD]ZERSTOFLG <> 2"

For LG = 0 To [M:SNL0]NBLIG-1
    If [M:SNL0]MODFLG (LG) =  2
       nolign = LG+1
       Raz [F:ITM]
       Raz [F:ITF]
       Call DEF_CRITERE_RGP("SNL0",LG,CRITER1,RGP_FILTRE,RGP_FILTRE1,RGP_FILTRE2) From STKINV # hcb 71659
       If CRITER1 = ""
          CRITER1 = "1=1"
       Endif
       Filter [CUD] Where evalue(CRITER0)&evalue(CRITER1)&evalue(CRITER2)
&                   Order By Key CUD0

       For [CUD]
           Readlock [F:CUD] Curr
           Case fstat
                When 0 :
                When 1 :
                     GMESSAGE = mess(20,100,1)-"CUNLISDET"-[M:SNL0]CUNLISNUM
                     GOK = -1
                     Break
                When Default :
                     GOK = 0
                     Call FSTA("CUD") From GLOCK
                     Break
                Endcase
#                                                                                         # hcb 71659 deb
            If [M:SNL0]MULCTGFLG <> 2
               If [M:SNL0]ZERSTOFLG(LG) = 2
                  [F:CUD]QTYPCUNEW = 0
                  [F:CUD]QTYSTUNEW = 0
                  [F:CUD]ZERSTOFLG = 2
               Else
                  If [M:SNL0]NBDETAIL(LG)  = 1
                     [F:CUD]QTYPCUNEW = [M:SNL0]QTYPCUNEW(LG)
                     [F:CUD]QTYSTUNEW = [M:SNL0]QTYSTUNEW(LG)
                     [F:CUD]ZERSTOFLG = 1
                  Else
                     [F:CUD]QTYPCUNEW = [F:CUD]QTYPCU
                     [F:CUD]QTYSTUNEW = [F:CUD]QTYSTU
                     [F:CUD]ZERSTOFLG = 1
                  Endif
               Endif
            Else
               If [M:SNL0]CTG1(LG)  = 0
                  If [M:SNL0]ZERSTOFLG1(LG) = 2
                     [F:CUD]QTYPCUNEW1 = 0
                     [F:CUD]QTYSTUNEW1 = 0
                     [F:CUD]ZERSTOFLG1 = 2
                  Else
                     If [M:SNL0]NBDETAIL(LG)  = 1
                        [F:CUD]QTYPCUNEW1 = [M:SNL0]QTYPCUNEW1(LG)
                        [F:CUD]QTYSTUNEW1 = [M:SNL0]QTYSTUNEW1(LG)
                        [F:CUD]ZERSTOFLG1 = 1
                     Else
                        [F:CUD]QTYPCUNEW1 = [F:CUD]QTYPCU
                        [F:CUD]QTYSTUNEW1 = [F:CUD]QTYSTU
                        [F:CUD]ZERSTOFLG1 = 1
                     Endif
                  Endif
               Elsif [M:SNL0]CTG2(LG)  = 0
                     If [M:SNL0]ZERSTOFLG2(LG) = 2
                        [F:CUD]QTYPCUNEW2 = 0
                        [F:CUD]QTYSTUNEW2 = 0
                        [F:CUD]ZERSTOFLG2 = 2
                        If [M:SNL0]ZERSTOFLG(LG) = 2
                           [F:CUD]QTYPCUNEW = 0
                           [F:CUD]QTYSTUNEW = 0
                           [F:CUD]ZERSTOFLG = 2
                        Endif
                     Else
                        If [M:SNL0]NBDETAIL(LG)  = 1
                           [F:CUD]QTYPCUNEW2 = [M:SNL0]QTYPCUNEW2(LG)
                           [F:CUD]QTYSTUNEW2 = [M:SNL0]QTYSTUNEW2(LG)
                           [F:CUD]ZERSTOFLG2 = 1
                           [F:CUD]QTYPCUNEW  = [M:SNL0]QTYPCUNEW(LG)
                           [F:CUD]QTYSTUNEW  = [M:SNL0]QTYSTUNEW(LG)
                           [F:CUD]ZERSTOFLG  = 1
                        Else
                           [F:CUD]QTYPCUNEW2 = [F:CUD]QTYPCU
                           [F:CUD]QTYSTUNEW2 = [F:CUD]QTYSTU
                           [F:CUD]ZERSTOFLG2 = 1
                           If [M:SNL0]QTYPCUNEW(LG) <> 0
                              [F:CUD]QTYPCUNEW = [F:CUD]QTYPCU
                              [F:CUD]QTYSTUNEW = [F:CUD]QTYSTU
                              [F:CUD]ZERSTOFLG = 1
                           Endif
                        Endif
                     Endif
               Else
                  If [M:SNL0]ZERSTOFLG(LG) = 2
                     [F:CUD]QTYPCUNEW = 0
                     [F:CUD]QTYSTUNEW = 0
                     [F:CUD]ZERSTOFLG = 2
                  Else
                     If [M:SNL0]NBDETAIL(LG)  = 1
                        [F:CUD]QTYPCUNEW = [M:SNL0]QTYPCUNEW(LG)
                        [F:CUD]QTYSTUNEW = [M:SNL0]QTYSTUNEW(LG)
                        [F:CUD]ZERSTOFLG = 1
                     Else
                        [F:CUD]QTYPCUNEW = [F:CUD]QTYPCU
                        [F:CUD]QTYSTUNEW = [F:CUD]QTYSTU
                        [F:CUD]ZERSTOFLG = 1
                     Endif
                  Endif
               Endif
            Endif
#                                                                                         # hcb 71659 fin
# hcb 59590
           If [F:CUD]QTYPCUNEW  = 0 &  [F:CUD]QTYSTUNEW = 0 & [F:CUD]ZERSTOFLG <> 2
              [F:CUD]CUNLISSTA = 1
              [F:CUD]ZERSTOFLG = 1
           Else
              [F:CUD]CUNLISSTA = 2
           Endif
# hcb 59590
#                                                                     # hcb 110327 deb

#          si comptée et que serseq est <> 0 alors  mise à jour des numeros de series globals
           If [F:CUD]CUNLISSTA = 2 & [F:CUD]SERSEQ <> 0
              Call ECR_CSD([F:CUD]STOFCY,[F:CUD]CUNSSSNUM,[F:CUD]CUNLISNUM,[F:CUD]SERSEQ,[F:CUD]ZERSTOFLG,WRET) From STKINV1
              If WRET = 9
                 GOK  = 0
                 Break
              Endif
           Endif
#                                                                     # hcb 110327 end
           [F:CUD]UPDUSR    = GUSER
           [F:CUD]UPDDAT    = date$

           GPOINT = "SNL0_CUD"                   # hcb 54067
           Gosub  ENTREE From EXEFNC             # hcb 54067

           Rewrite [CUD]
           If fstat
              GOK = 0
              Call FSTA("CUD") From GLOCK
              Break
           Endif
           GMOD_INV = 2
       Next
       Filter [CUD]
    Endif
Next LG

Return

#########################################################################
# DZO_SNL1_RGP                  desactivation rubriques regroupement SNL1
#########################################################################
$DZO_SNL1_RGP
# dans le cas de ligne sans stocou , c est à dire sans stock
# toutes les rubriques sont modifiables ...

# dans le cas d un inventaire article-depot le depot n est pas modifiable
If dim([M:SNL1]WRH) > 0 & [F:CUN]CUNITMWRH = 2
   Grizo [M:SNL1]WRH
Endif
If [M:SNL1]STOCOU(0) =  0 & [M:SNL1]NBLIG = 1  & [M:SNL1]CUNLISSTA(0) =  1
   Return
Endif

# on dessactive les rubriques qui ne servent qu en ajout de lignes
If [F:ITF]LOCMGTCOD =2
   If dim([M:SNL1]LOC) > 0
      Grizo  [M:SNL1]LOC
   Endif
Endif
If [F:ITF]LPNMGTCOD =2                                             # hcb x3-68147
   If dim([M:SNL1]LPNNUM) > 0
      Grizo  [M:SNL1]LPNNUM
   Endif
Endif
If [F:ITM]LOTMGTCOD > 1
   If dim([M:SNL1]LOT) > 0
      Grizo  [M:SNL1]LOT
   Endif
   If [F:ITM]LOTMGTCOD = 4
      If dim([M:SNL1]SLO) > 0
         Grizo  [M:SNL1]SLO
      Endif
   Endif
Endif
If dim([M:SNL1]WRH) > 0
   Grizo  [M:SNL1]WRH
Endif
If dim([M:SNL1]PCU) > 0
   Grizo  [M:SNL1]PCU
Endif
If dim([M:SNL1]STA) > 0
   Grizo  [M:SNL1]STA
Endif
If dim([M:SNL1]OWNER) > 0
   Grizo  [M:SNL1]OWNER
Endif
If dim([M:SNL1]PCUSTUNEW) > 0                     # hcb 31134
   Grizo  [M:SNL1]PCUSTUNEW                       # hcb 31134
Endif                                             # hcb 31134
If dim([M:SNL1]SERNUM) > 0
   Grizo  [M:SNL1]SERNUM
Endif

If dim([M:SNL1]PALNUM) > 0                     # hcb 32226
   Grizo  [M:SNL1]PALNUM                       # hcb 32226
Endif                                          # hcb 32226
If dim([M:SNL1]CTRNUM) > 0                     # hcb 32226
   Grizo  [M:SNL1]CTRNUM                       # hcb 32226
Endif                                          # hcb 32226
If dim([M:SNL1]STOFLD1) > 0
   Grizo  [M:SNL1]STOFLD1
Endif
If dim([M:SNL1]STOFLD2) > 0
   Grizo  [M:SNL1]STOFLD2
Endif
If dim([M:SNL1]ECCVALMAJ) > 0
   Grizo  [M:SNL1]ECCVALMAJ
Endif
If dim([M:SNL1]ECCVALMIN) > 0
   Grizo  [M:SNL1]ECCVALMIN
Endif
#                                                                                         # hcb 71659 deb
If [M:SNL0]MULCTGFLG = 2
   Grizo  [M:SNL1]PCUSTUNEW1
   Grizo  [M:SNL1]PCUSTUNEW2
Endif
#                                                                                         # hcb 71659 fin

Return


#########################################################################
# AZO_SNL0_RGP                  activation rubriques nouvelle ligne  SNL0
#########################################################################
$AZO_SNL0_RGP
# si liste cloturée ajout ligne interdit
If [M:SNL0]CUNLISSTA  = 6
   Return
Endif

#activation des rubriques itmref et emplacement pour rajout de ligne
Actzo  [M:SNL0]ITMREF(NOL)
If dim([M:SNL0]LOC1) > 0
   Actzo  [M:SNL0]LOC1  (NOL)
Endif
If dim([M:SNL0]LOC) > 0
   Actzo  [M:SNL0]LOC   (NOL)
Endif
If dim([M:SNL0]WRH) > 0
   If  [M:SNL0]CUNITMWRH = 2
       [M:SNL0]WRH        (NOL) = [M:SNL0]WRHCUL
       Grizo [M:SNL0]WRH  (NOL)
   Else
       Actzo  [M:SNL0]WRH (NOL)
   Endif
Endif
Grizo  [M:SNL0]QTYPCUNEW(NOL)
Grizo  [M:SNL0]QTYSTUNEW(NOL)
Grizo  [M:SNL0]ZERSTOFLG(NOL)
#                                                                                         # hcb 71659 deb
If [M:SNL0]MULCTGFLG = 2
   Grizo  [M:SNL0]QTYPCUNEW1(NOL)
   Grizo  [M:SNL0]QTYSTUNEW1(NOL)
   Grizo  [M:SNL0]ZERSTOFLG1(NOL)
   Grizo  [M:SNL0]QTYPCUNEW2(NOL)
   Grizo  [M:SNL0]QTYSTUNEW2(NOL)
   Grizo  [M:SNL0]ZERSTOFLG2(NOL)
   [M:SNL0]SAICOD(NOL) = "+"
   Affzo [M:SNL0]SAICOD(NOL)
Endif
#                                                                                         # hcb 71659 fin
Return


#########################################################################
# AZO_SNL1                      activation rubriques nouvelle ligne  SNL1
#########################################################################
$AZO_SNL1
# si liste cloturée ajout ligne interdit
If [M:SNL0]CUNLISSTA  = 6
   Return
Endif
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 6 | [F:SRT]SRTNUM <> GSNLNUM                   # hcb 50197
    Read [SRT]SRT0=6;GSNLNUM : If fstat Raz [F:SRT] : Endif
Endif

# gouvinv = 1 automatique comptage sur ligne
#     desactivation rubriques du regroument
# gouvinv = 2 clic droit comtage sur ligne
#     desactivation rubriques du regroument
# gouvinv = 3 clic droit sur ligne
#     desactivation rubriques du regroument
# gouvinv = 4 clic droit sur fin tableau
#     aucune desactivation

#                                                                     # hcb 110327 deb
# si article suivi en serie entrée/sortie seul le numero de serie est saisissable
#If [F:ITM]SERMGTCOD = 3                         # hcb 62419
#   [M:SNL1]QTYPCUNEW              (NOL) = 1
#   [M:SNL1]QTYSTUNEW              (NOL) = 1
#   Grizo  [M:SNL1]QTYPCUNEW       (NOL)     # hcb 31134
#   Grizo  [M:SNL1]QTYSTUNEW       (NOL)     # hcb 31134
#   Grizo  [M:SNL1]ZERSTOFLG       (NOL)     # hcb 31134
#Else
#   Actzo  [M:SNL1]QTYPCUNEW       (NOL)
#   Actzo  [M:SNL1]QTYSTUNEW       (NOL)
#   Actzo  [M:SNL1]ZERSTOFLG       (NOL)
#Endif
Case [F:ITM]SERMGTCOD
     When 3 :
        [M:SNL1]QTYPCUNEW              (NOL) = 1
        [M:SNL1]QTYSTUNEW              (NOL) = 1
        Grizo  [M:SNL1]QTYPCUNEW       (NOL)
        Grizo  [M:SNL1]QTYSTUNEW       (NOL)
        Grizo  [M:SNL1]ZERSTOFLG       (NOL)
     When 4 :
        Grizo  [M:SNL1]SERNUM          (NOL)
        Grizo  [M:SNL1]ZERSTOFLG       (NOL)
     When Default
        Actzo  [M:SNL1]QTYPCUNEW       (NOL)
        Actzo  [M:SNL1]QTYSTUNEW       (NOL)
        Actzo  [M:SNL1]ZERSTOFLG       (NOL)
Endcase
#                                                                     # hcb 110327 end


# dans le cas d un inventaire article-depot le depot n est pas modifiable
If dim([M:SNL1]WRH) > 0
   If  [F:CUN]CUNITMWRH <> 2 & [F:SRT]WRHCOD = 2  & GOUVINV > 2   # hcb 115294
       Actzo [M:SNL1]WRH (NOL)
   Else
      Grizo  [M:SNL1]WRH    (NOL)
      [M:SNL1]WRH           (NOL) =   [M:SNL0]WRH     (GLIG_SNL0)
   Endif
Endif

If dim([M:SNL1]DEPRAT) > 0
   If [F:SRT]DEPRATCOD1 = 1
      Actzo  [M:SNL1]DEPRAT    (NOL)
   Endif
Endif
If dim([M:SNL1]DEPAMT) > 0
   If [F:SRT]DEPAMTCOD1 = 1
      Actzo  [M:SNL1]DEPAMT    (NOL)
   Endif
Endif

If dim([M:SNL1]ECCVALMAJ) > 0
   Diszo [M:SNL1]ECCVALMAJ
   Diszo [M:SNL1]ECCVALMIN
Endif

#If GOUVINV  = 4 | GIMPINV = 1                                                            # hcb 71659
If GOUVINV  = 4                                                                           # hcb 71659

   If [F:ITF]LOCMGTCOD =2
      If dim([M:SNL1]LOC) > 0
         Actzo  [M:SNL1]LOC       (NOL)
      Endif
   Else
      If dim([M:SNL1]LOC) > 0
         Grizo   [M:SNL1]LOC       (NOL)   # hcb 31134
      Endif
   Endif
#                                                                               # hcb x3-68147 deb
   If [F:ITF]LPNMGTCOD =2
      If dim([M:SNL1]LPNNUM) > 0
         Actzo  [M:SNL1]LPNNUM       (NOL)
      Endif
   Else
      If dim([M:SNL1]LPNNUM) > 0
         Grizo   [M:SNL1]LPNNUM      (NOL)
      Endif
   Endif
#                                                                               # hcb x3-68147 fin

   If [F:ITM]LOTMGTCOD > 1
      If dim([M:SNL1]LOT) > 0
         Actzo  [M:SNL1]LOT       (NOL)
      Endif
      If [F:ITM]LOTMGTCOD = 4
         If dim([M:SNL1]SLO) > 0
            Actzo  [M:SNL1]SLO       (NOL)
         Endif
      Else
         If dim([M:SNL1]SLO) > 0
            Grizo      [M:SNL1]SLO       (NOL)   # hcb 31134
         Endif
      Endif
   Else
      If dim([M:SNL1]LOT) > 0
         Grizo         [M:SNL1]LOT       (NOL)   # hcb 31134
      Endif
      If dim([M:SNL1]SLO) > 0
         Grizo         [M:SNL1]SLO       (NOL)   # hcb 31134
      Endif
   Endif

   If dim([M:SNL1]STA) > 0
      Actzo  [M:SNL1]STA       (NOL)
   Endif
   If dim([M:SNL1]OWNER) > 0
      Actzo  [M:SNL1]OWNER     (NOL)
   Endif

   If dim([M:SNL1]PALNUM) > 0                     # hcb 32226
      Actzo  [M:SNL1]PALNUM    (NOL)              # hcb 32226
   Endif                                          # hcb 32226
   If dim([M:SNL1]CTRNUM) > 0                     # hcb 32226
      Actzo  [M:SNL1]CTRNUM    (NOL)              # hcb 32226
   Endif                                          # hcb 32226
   If dim([M:SNL1]STOFLD1) > 0
      Actzo  [M:SNL1]STOFLD1   (NOL)     # hcb 110327
   Endif
   If dim([M:SNL1]STOFLD2) > 0
      Actzo  [M:SNL1]STOFLD2   (NOL)    # hcb 110327
   Endif

   If [F:ITM]SERMGTCOD > 1
      If dim([M:SNL1]PCU) > 0
         [M:SNL1]PCU       (NOL) = [F:ITM]STU
         Grizo   [M:SNL1]PCU       (NOL)          # hcb 31134
      Endif
      If dim([M:SNL1]PCUSTUNEW) > 0                    # hcb 31134
         [M:SNL1]PCUSTUNEW (NOL) = 1                   # hcb 31134
         If [F:ITM]SERMGTCOD = 3                      # hcb 62419
            Grizo  [M:SNL1]PCUSTUNEW (NOL)                 # hcb 31134
         Endif
      Endif                                            # hcb 31134
#                                                                                         # hcb 71659 deb
      If [M:SNL0]MULCTGFLG = 2
         [M:SNL1]PCUSTUNEW1 (NOL) = 1
         [M:SNL1]PCUSTUNEW2 (NOL) = 1
         If [F:ITM]SERMGTCOD = 3
             Grizo  [M:SNL1]PCUSTUNEW1 (NOL)
             Grizo  [M:SNL1]PCUSTUNEW2 (NOL)
         Endif
      Endif
#                                                                                         # hcb 71659 fin
      If [F:SRT]SERCOD1 = 2
         If dim([M:SNL1]SERNUM) > 0
            Actzo  [M:SNL1]SERNUM (NOL)
         Endif
      Else
         If dim([M:SNL1]SERNUM) > 0
            Grizo   [M:SNL1]SERNUM (NOL)              # hcb 31134
         Endif
      Endif
   Else
      If dim([M:SNL1]PCU) > 0
         Actzo  [M:SNL1]PCU       (NOL)
      Endif
      If dim([M:SNL1]PCUSTUNEW) > 0                   # hcb 31134
         Actzo  [M:SNL1]PCUSTUNEW (NOL)               # hcb 31134
      Endif                                           # hcb 31134
      If dim([M:SNL1]SERNUM) > 0
         Grizo   [M:SNL1]SERNUM (NOL)                 # hcb 31134
      Endif
#                                                                                         # hcb 71659 deb
      If [M:SNL0]MULCTGFLG = 2
         Actzo  [M:SNL1]PCUSTUNEW1 (NOL)
         Actzo  [M:SNL1]PCUSTUNEW2 (NOL)
      Endif
#                                                                                         # hcb 71659 fin

   Endif
Else
   If [F:CUN]CUNSSSTYP = 2
         If dim([M:SNL1]LOC) > 0
            Grizo  [M:SNL1]LOC     (NOL)             # hcb 31134
            [M:SNL1]LOC           (NOL) =   [M:SNL0]LOC     (GLIG_SNL0)
         Endif
   Endif

   If dim([M:SNL1]LOC) > 0
      If [F:SRT]LOCCOD = 1
         Grizo  [M:SNL1]LOC     (NOL)                # hcb 31134
         [M:SNL1]LOC           (NOL) =   [M:SNL0]LOC     (GLIG_SNL0)
      Else
         If [F:ITF]LOCMGTCOD =2
            Actzo [M:SNL1]LOC     (NOL)
         Else
            Grizo  [M:SNL1]LOC     (NOL)             # hcb 31134
         Endif
      Endif
   Endif
#                                                                               # hcb x3-68147 deb
   If dim([M:SNL1]LPNNUM) > 0
      If [F:SRT]LPNCOD = 1
         Grizo  [M:SNL1]LPNNUM     (NOL)
         [M:SNL1]LPNNUM            (NOL) =   [M:SNL0]LPNNUM    (GLIG_SNL0)
      Else
         If [F:ITF]LPNMGTCOD =2
            Actzo [M:SNL1]LPNNUM   (NOL)
         Else
            Grizo  [M:SNL1]LPNNUM  (NOL)
         Endif
      Endif
   Endif
#                                                                               # hcb x3-68147 fin

   If dim([M:SNL1]LOT) > 0
      If [F:SRT]LOTCOD = 1
        Grizo  [M:SNL1]LOT     (NOL)                 # hcb 31134
         [M:SNL1]LOT           (NOL) =   [M:SNL0]LOT     (GLIG_SNL0)
      Else
         If [F:ITM]LOTMGTCOD > 1
            Actzo [M:SNL1]LOT     (NOL)
         Else
            Grizo  [M:SNL1]LOT     (NOL)             # hcb 31134
            If dim([M:SNL1]SLO) > 0
               Grizo  [M:SNL1]SLO     (NOL)          # hcb 31134
            Endif
         Endif
      Endif
   Endif

   If dim([M:SNL1]SLO) > 0
      If [F:SRT]SLOCOD = 1
         Grizo [M:SNL1]SLO     (NOL)                 # hcb 31134
         [M:SNL1]SLO           (NOL) =   [M:SNL0]SLO     (GLIG_SNL0)
      Else
         If [F:ITM]LOTMGTCOD = 4
            Actzo [M:SNL1]SLO     (NOL)
         Else
            Grizo  [M:SNL1]SLO     (NOL)             # hcb 31134
         Endif
      Endif
   Endif

   If dim([M:SNL0]PCU)>0
       Grizo  [M:SNL1]PCU       (NOL)                # hcb 31134
       [M:SNL1]PCU             (NOL) =   [M:SNL0]PCU     (GLIG_SNL0)
       If [M:SNL1]PCU          (NOL) = ""
          [M:SNL1]PCU          (NOL) = [F:ITM]STU
       Endif
   Endif

#                                                                      hcb 31134 deb
   If dim([M:SNL1]PCUSTUNEW)>0
       Grizo  [M:SNL1]PCUSTUNEW (NOL)
       [M:SNL1]PCUSTUNEW       (NOL) =   [M:SNL0]PCUSTUCOE (GLIG_SNL0)
       If  [M:SNL1]PCUSTUNEW   (NOL) = 0
           [M:SNL1]PCUSTUNEW   (NOL) = 1
       Endif
   Endif
   If dim([M:SNL1]PCUSTUCOE)>0
#       Diszo [M:SNL1]PCUSTUCOE (NOL)
        [M:SNL1]PCUSTUCOE       (NOL) =   [M:SNL0]PCUSTUCOE (GLIG_SNL0)
        If  [M:SNL1]PCUSTUCOE   (NOL) = 0
            [M:SNL1]PCUSTUCOE   (NOL) = 1
        Endif
    Endif
#                                                                      hcb 31134 fin

#                                                                                         # hcb 71659 deb
      If [M:SNL0]MULCTGFLG = 2
         Grizo  [M:SNL1]PCUSTUNEW1 (NOL)
         [M:SNL1]PCUSTUNEW1       (NOL) =   [M:SNL0]PCUSTUCOE (GLIG_SNL0)
         If  [M:SNL1]PCUSTUNEW1   (NOL) = 0
             [M:SNL1]PCUSTUNEW1   (NOL) = 1
         Endif
         Grizo  [M:SNL1]PCUSTUNEW2 (NOL)
         [M:SNL1]PCUSTUNEW2       (NOL) =   [M:SNL0]PCUSTUCOE (GLIG_SNL0)
         If  [M:SNL1]PCUSTUNEW2   (NOL) = 0
             [M:SNL1]PCUSTUNEW2   (NOL) = 1
         Endif
      Endif
#                                                                                         # hcb 71659 fin
   If dim([M:SNL1]STA)>0
      If [F:SRT]STACOD = 1
         Grizo  [M:SNL1]STA     (NOL)                                 # hcb 31134
         [M:SNL1]STA           (NOL) =   [M:SNL0]STA     (GLIG_SNL0)
      Else
         Actzo [M:SNL1]STA     (NOL)
      Endif
   Endif
   If dim([M:SNL1]OWNER)>0
      If [F:SRT]OWNERCOD <> 1
         Grizo  [M:SNL1]OWNER    (NOL)                                 # hcb 31134
      Else
         Actzo [M:SNL1]OWNER     (NOL)
      Endif
   Endif
# hcb 32226 uniquement 150 deb

   If dim([M:SNL1]PALNUM)>0
      If [F:SRT]IDECOD1 = 1
         Grizo  [M:SNL1]PALNUM     (NOL)                             # hcb 31134
         [M:SNL1]PALNUM            (NOL) =   [M:SNL0]PALNUM     (GLIG_SNL0)
      Else
         Actzo [M:SNL1]PALNUM      (NOL)
      Endif
   Endif
   If dim([M:SNL1]CTRNUM)>0
      If [F:SRT]IDECOD2 = 1
         Grizo  [M:SNL1]CTRNUM     (NOL)                                  # hcb 31134
         [M:SNL1]CTRNUM           (NOL) =   [M:SNL0]CTRNUM     (GLIG_SNL0)
      Else
         Actzo [M:SNL1]CTRNUM     (NOL)
      Endif
   Endif
# hcb 32226 uniquement 150 fin
   If dim([M:SNL1]STOFLD1) > 0
      Actzo  [M:SNL1]STOFLD1 (NOL)
   Endif
   If dim([M:SNL1]STOFLD2) > 0
      Actzo  [M:SNL1]STOFLD2 (NOL)
   Endif

   If dim([M:SNL1]SERNUM) > 0
      If [F:SRT]SERCOD1 = 2 & [F:ITM]SERMGTCOD > 1
         Actzo  [M:SNL1]SERNUM (NOL)
      Else
         Grizo  [M:SNL1]SERNUM (NOL)                                  # hcb 31134
      Endif
   Endif


Endif
#                                                                                         # hcb 71659 deb

If [M:SNL0]MULCTGFLG = 2 & [M:SNL1]LINFLG(NOL) = 1
# l ajout de ligne  fait depuis un regroupement hérite de la situation du comptage
# détection saisie comptage 1
   If find([M:SNL0]SAICOD(GLIG_SNL0),"+ ","+1","*1")
      [M:SNL1]CTG1(NOL)  = 1
      [M:SNL1]CTG2(NOL)  = 2
      [M:SNL1]CTG (NOL)  = 2
# détection saisie comptage 2
   Elsif find([M:SNL0]SAICOD(GLIG_SNL0),"+2","*2")
         [M:SNL1]CTG1(NOL)  = 2
         [M:SNL1]CTG2(NOL)  = 1
         [M:SNL1]CTG (NOL)  = 2
         [M:SNL1]PCUSTUNEW1 (NOL) = 1
         [M:SNL1]QTYPCUNEW1 (NOL) = 0
         [M:SNL1]QTYSTUNEW1 (NOL) = 0
         [M:SNL1]ZERSTOFLG1 (NOL) = 2
# détection comptage
   Elsif find([M:SNL0]SAICOD(GLIG_SNL0),"")
         [M:SNL1]CTG1(NOL)  = 2
         [M:SNL1]CTG2(NOL)  = 2
         [M:SNL1]CTG (NOL)  = 1
         [M:SNL1]PCUSTUNEW1 (NOL) = 1
         [M:SNL1]QTYPCUNEW1 (NOL) = 0
         [M:SNL1]QTYSTUNEW1 (NOL) = 0
         [M:SNL1]ZERSTOFLG1 (NOL) = 2
         [M:SNL1]PCUSTUNEW2 (NOL) = 1
         [M:SNL1]QTYPCUNEW2 (NOL) = 0
         [M:SNL1]QTYSTUNEW2 (NOL) = 0
         [M:SNL1]ZERSTOFLG2 (NOL) = 2
   Endif
Endif
#                                                                                         # hcb 71659 fin
Return


#########################################################################
# RENUM_CUD                              renumerotation de la liste (CUD)
#########################################################################
$RENUM_CUD
Local Integer Y,J

If clalev([M:SIW])=0 Local Mask STOINVW   [SIW] Endif  #  ecran détail inventaire
Raz [M:SIW]

I = 0
Local Integer WOK
Raz WOK
Filter [CUD] Where [F:CUD]CUNSSSNUM = [M:SNL0]CUNSSSNUM &
&                  [F:CUD]CUNLISNUM = [M:SNL0]CUNLISNUM
&             Order By Key CUD0

For [CUD]
    If I >= GCOD_INV
       Call ERREUR(mess(191,199,1)) From GESECRAN
       WOK = 9
       Break
    Endif
    [M:SIW]CUNSSSNUM  = [F:CUD]CUNSSSNUM
    [M:SIW]CUNLISNUM  = [F:CUD]CUNLISNUM
    [M:SIW]STOFCY     = [F:CUD]STOFCY
    [M:SIW]CUR        = [F:CUD]CUR

    [M:SIW]CUNLISSTA  (I) = [F:CUD]CUNLISSTA
    [M:SIW]ITMREF     (I) = [F:CUD]ITMREF
    [M:SIW]WRH        (I)  = [F:CUD]WRH
    [M:SIW]LOC        (I) = [F:CUD]LOC
    [M:SIW]LPNNUM     (I) = [F:CUD]LPNNUM                                 # hcb X3-68147
    [M:SIW]LOT        (I) = [F:CUD]LOT
    [M:SIW]SLO        (I) = [F:CUD]SLO
    [M:SIW]ECCVALMAJ  (I) = [F:CUD]ECCVALMAJ
    [M:SIW]PCU        (I) = [F:CUD]PCU
    [M:SIW]STA        (I) = [F:CUD]STA
    [M:SIW]QTYPCU     (I) = [F:CUD]QTYPCU
    [M:SIW]QTYPCUNEW  (I) = [F:CUD]QTYPCUNEW
    [M:SIW]PCUSTUCOE  (I) = [F:CUD]PCUSTUCOE
    [M:SIW]QTYSTU     (I) = [F:CUD]QTYSTU
    [M:SIW]QTYSTUNEW  (I) = [F:CUD]QTYSTUNEW
    [M:SIW]ZERSTOFLG  (I) = [F:CUD]ZERSTOFLG
    [M:SIW]SERNUM     (I) = [F:CUD]SERNUM
    [M:SIW]CUNCST     (I) = [F:CUD]CUNCST
    [M:SIW]CUNCSTCOD  (I) = [F:CUD]CUNCSTCOD
    [M:SIW]IPTDAT     (I) = [F:CUD]IPTDAT
    [M:SIW]CUNLOKFLG  (I) = [F:CUD]CUNLOKFLG
    [M:SIW]STOCOU     (I) = [F:CUD]STOCOU
    [M:SIW]ABCCLS     (I) = [F:CUD]ABCCLS
    [M:SIW]LINFLG     (I) = [F:CUD]LINFLG
    [M:SIW]DEPRAT     (I) = [F:CUD]DEPRAT
    [M:SIW]DEPAMT     (I) = [F:CUD]DEPAMT
    [M:SIW]NETCUNCST  (I) = [F:CUD]NETCUNCST

    [M:SIW]CUNLISDATL (I) = [F:CUD]CUNDAT
    [M:SIW]CREUSR     (I) = [F:CUD]CREUSR
    [M:SIW]CREDAT     (I) = [F:CUD]CREDAT
    [M:SIW]PALNUM     (I) = [F:CUD]PALNUM
    [M:SIW]CTRNUM     (I) = [F:CUD]CTRNUM
    [M:SIW]QLYCTLDEM  (I) = [F:CUD]QLYCTLDEM
    [M:SIW]OWNER      (I) = [F:CUD]OWNER
    [M:SIW]STOFLD1    (I) = [F:CUD]STOFLD1
    [M:SIW]STOFLD2    (I) = [F:CUD]STOFLD2
#                                                                                         # hcb 71659 deb
    [M:SIW]QTYSTUNEW1 (I) = [F:CUD]QTYSTUNEW1
    [M:SIW]QTYPCUNEW1 (I) = [F:CUD]QTYPCUNEW1
    [M:SIW]ZERSTOFLG1 (I) = [F:CUD]ZERSTOFLG1
    [M:SIW]QTYSTUNEW2 (I) = [F:CUD]QTYSTUNEW2
    [M:SIW]QTYPCUNEW2 (I) = [F:CUD]QTYPCUNEW2
    [M:SIW]ZERSTOFLG2 (I) = [F:CUD]ZERSTOFLG2
#                                                                                         # hcb 71659 fin
   [M:SIW]SERSEQ     (I) = [F:CUD]SERSEQ                             # hcb 110327


    # Issue 79416 - 2012-01-19 by CCC : SIW est trié => conserver le lien entre SIW et VIW
    [M:SIW]VIWIND     (I) = I
    If dim([F:CUD]MATCST)>0
        If clalev([M:VIW])=0 Local Mask STOVALW   [VIW] Endif
        For J=0 To GACTMAT-1
            [M:VIW]OMATCST([M:SIW]VIWIND(I)*GACTMAT+J)   = [F:CUD]MATCST(J)
        Next
        [M:VIW]OOVEMATCST([M:SIW]VIWIND(I)) = [F:CUD]OVEMATCST

        For J=0 To GACTMAC-1
            [M:VIW]OMACCST([M:SIW]VIWIND(I)*GACTMAC+J)   = [F:CUD]MACCST(J)
        Next
        [M:VIW]OOVEMACCST([M:SIW]VIWIND(I)) = [F:CUD]OVEMACCST

        For J=0 To GACTLAB-1
            [M:VIW]OLABCST([M:SIW]VIWIND(I)*GACTLAB+J)   = [F:CUD]LABCST(J)
        Next
        [M:VIW]OOVELABCST([M:SIW]VIWIND(I)) = [F:CUD]OVELABCST

        [M:VIW]OSCOTOT([M:SIW]VIWIND(I))    = [F:CUD]SCOCST
        [M:VIW]OOVESCOCST([M:SIW]VIWIND(I)) = [F:CUD]OVESCOCST

        [M:VIW]OINVDTACST([M:SIW]VIWIND(I))    = [F:CUD]INVDTACST

        [M:VIW]PRI([M:SIW]VIWIND(I))        = [F:CUD]PRIORD
    Endif

    For Y=1 To GNBDIE
        Assign "[M:SIW]CCE"+num$(Y)+"(I)" With    [F:CUD]CCE(Y-1)      # Ana
    Next                                             # Ana

    GPOINT = "CUD_SIW"                    # hcb 42169
    Gosub  ENTREE From EXEFNC             # hcb 42169

    I += 1
Next
[M:SIW]NBLIG = I
Filter [CUD]
If WOK = 9
   GOK = 0
   Return
Endif
# tri inventaire
Raz GPE                         # hcb 52308
GPOINT = "TRIRENUM"             # hcb 52308
Gosub  ENTREE From EXEFNC       # hcb 52308
If GPE =  0                     # hcb 52308
   Case [F:CUN]CUNSRTCOD
      When 2 :
# Issue 79416 - 2012-01-19 by CCC
#        If !clalev([M:VIW])
           Sorta [M:SIW]NBLIG [M:SIW]NBLIG Order By [M:SIW]LOC(indice),[M:SIW]ITMREF(indice)
#        Else
#           Sorta [M:SIW]NBLIG [M:SIW]NBLIG, [M:VIW]NBLIG Order By [M:SIW]LOC(indice),[M:SIW]ITMREF(indice)
#        Endif
      When Default :
#        If !clalev([M:VIW])
           Sorta [M:SIW]NBLIG [M:SIW]NBLIG Order By [M:SIW]ITMREF(indice),[M:SIW]LOC(indice)
#        Else
#           Sorta [M:SIW]NBLIG [M:SIW]NBLIG, [M:VIW]NBLIG Order By [M:SIW]ITMREF(indice),[M:SIW]LOC(indice)
#        Endif
   Endcase
Endif                           # hcb 52308
#
Call DEBTRANS From GLOCK
Trbegin [CUD]
Local Decimal WLIN
# delete liste inventaire

Call DEL_CUD_CUD([M:SIW]STOFCY,[M:SIW]CUNSSSNUM ,[M:SIW]CUNLISNUM,WOK) From STKINV
If WOK <> 2
   Gosub AB_TRT From STKINV
   GOK = 0
   Return
Endif

For I = 0 To [M:SIW]NBLIG-1
    nolign = I+1
    WLIN   = (I+1)*1000

#creation détail inventaire
    Gosub CRE_CUD_REN From STKINV
    If GOK <> 1
       Break
    Endif

Next I

If GOK <> 1
   Gosub AB_TRT From STKINV
   Return
Endif

#maj  liste inventaire
Readlock [CUL]CUL0=[M:SNL0]CUNSSSNUM;[M:SNL0]CUNLISNUM
Case fstat
       When 0 :
       When 1 :
             GOK = -1
             GMESSAGE = mess(20,100,1)-"CUNLISTE"-LSSS
             Gosub AB_TRT
             Return
       When Default :
             GOK = 0
             Call FSTA("CUL") From GLOCK
             Gosub AB_TRT
             Return
Endcase
[F:CUL]UPDUSR    = GUSER
[F:CUL]UPDDAT    = date$
[F:CUL]NBRLIG    = [M:SIW]NBLIG
Rewrite  [CUL]
If fstat
   GOK = 0
   Call FSTA("CUL") From GLOCK
   Gosub AB_TRT
   Return
Endif

GAJOUINV  = 0

Commit
Return

########################################################################
# CRE_CUD_REN               Creation détail inventaire en renumérotation
########################################################################
$CRE_CUD_REN
Local Integer IANA, J
Raz [F:CUD]
[F:CUD]CUNSSSNUM = [M:SIW]CUNSSSNUM
[F:CUD]CUNLISNUM = [M:SIW]CUNLISNUM
[F:CUD]ITMLISNUM = WLIN

[F:CUD]STOFCY    = [M:SIW]STOFCY
[F:CUD]LINFLG    = [M:SIW]LINFLG     (I)
[F:CUD]CUNLOKFLG = [M:SIW]CUNLOKFLG  (I)
[F:CUD]CUNLISSTA = [M:SIW]CUNLISSTA  (I)

If [M:SIW]CUR = ""
   Call GETDEV([M:SIW]STOFCY) From DEVSUB
   [M:SIW]CUR = GLOCALDEV
Endif

[F:CUD]CUR       = [M:SIW]CUR

[F:CUD]ITMREF    = [M:SIW]ITMREF    (I)
[F:CUD]WRH       = [M:SIW]WRH       (I)
[F:CUD]LOT       = [M:SIW]LOT       (I)
[F:CUD]LOC       = [M:SIW]LOC       (I)
[F:CUD]LPNNUM    = [M:SIW]LPNNUM    (I)                                        # hcb X3-68147
[F:CUD]STA       = [M:SIW]STA       (I)
[F:CUD]ABCCLS    = [M:SIW]ABCCLS    (I)
[F:CUD]PCU       = [M:SIW]PCU       (I)
[F:CUD]QTYPCU    = [M:SIW]QTYPCU    (I)
[F:CUD]QTYPCUNEW = [M:SIW]QTYPCUNEW (I)
[F:CUD]PCUSTUCOE = [M:SIW]PCUSTUCOE (I)
[F:CUD]QTYSTU    = [M:SIW]QTYSTU    (I)
[F:CUD]QTYSTUNEW = [M:SIW]QTYSTUNEW (I)
[F:CUD]SLO       = [M:SIW]SLO       (I)
[F:CUD]ECCVALMAJ = [M:SIW]ECCVALMAJ (I)
[F:CUD]SERNUM    = [M:SIW]SERNUM    (I)
[F:CUD]CUNCST    = [M:SIW]CUNCST    (I)
[F:CUD]CUNCSTCOD = [M:SIW]CUNCSTCOD (I)
[F:CUD]STOCOU    = [M:SIW]STOCOU    (I)
[F:CUD]ZERSTOFLG = [M:SIW]ZERSTOFLG (I)
[F:CUD]DEPRAT    = [M:SIW]DEPRAT    (I)
[F:CUD]DEPAMT    = [M:SIW]DEPAMT    (I)
[F:CUD]IPTDAT    = [M:SIW]IPTDAT    (I)
[F:CUD]PALNUM    = [M:SIW]PALNUM    (I)
[F:CUD]CTRNUM    = [M:SIW]CTRNUM    (I)
[F:CUD]QLYCTLDEM = [M:SIW]QLYCTLDEM (I)
[F:CUD]OWNER     = [M:SIW]OWNER     (I)
[F:CUD]STOFLD1   = [M:SIW]STOFLD1   (I)
[F:CUD]STOFLD2   = [M:SIW]STOFLD2   (I)
#                                                                                         # hcb 71659 deb
[F:CUD]QTYSTUNEW1 = [M:SIW]QTYSTUNEW1 (I)
[F:CUD]QTYPCUNEW1 = [M:SIW]QTYPCUNEW1 (I)
[F:CUD]ZERSTOFLG1 = [M:SIW]ZERSTOFLG1 (I)
[F:CUD]QTYSTUNEW2 = [M:SIW]QTYSTUNEW2 (I)
[F:CUD]QTYPCUNEW2 = [M:SIW]QTYPCUNEW2 (I)
[F:CUD]ZERSTOFLG2 = [M:SIW]ZERSTOFLG2 (I)
#                                                                                         # hcb 71659 fin

[F:CUD]SERSEQ     = [M:SIW]SERSEQ     (I)                             # hcb 110327

If clalev([M:VIW])
    For J=0 To GACTMAT-1
        [F:CUD]MATCST(J) = [M:VIW]OMATCST([M:SIW]VIWIND(I)*GACTMAT+J)
    Next
    [F:CUD]OVEMATCST = [M:VIW]OOVEMATCST([M:SIW]VIWIND(I))

    For J=0 To GACTMAC-1
        [F:CUD]MACCST(J) = [M:VIW]OMACCST([M:SIW]VIWIND(I)*GACTMAC+J)
    Next
    [F:CUD]OVEMACCST = [M:VIW]OOVEMACCST([M:SIW]VIWIND(I))

    For J=0 To GACTLAB-1
        [F:CUD]LABCST(J) = [M:VIW]OLABCST([M:SIW]VIWIND(I)*GACTLAB+J)
    Next
    [F:CUD]OVELABCST = [M:VIW]OOVELABCST([M:SIW]VIWIND(I))

    [F:CUD]SCOCST    = [M:VIW]OSCOTOT([M:SIW]VIWIND(I))
    [F:CUD]OVESCOCST = [M:VIW]OOVESCOCST([M:SIW]VIWIND(I))

    [F:CUD]PRIORD     = [M:VIW]PRI([M:SIW]VIWIND(I))
Endif

[F:CUD]CREUSR    = [M:SIW]CREUSR    (I)
[F:CUD]CREDAT    = [M:SIW]CREDAT    (I)
[F:CUD]UPDUSR    = GUSER
[F:CUD]UPDDAT    = date$
[F:CUD]EXPNUM    = [C]EXPORT


For IANA =1 To GNBDIE                                             # Ana
    [F:CUD]CCE(IANA-1) = evalue("[M:SIW]CCE"+num$(IANA)+"(I)")    # Ana
    [F:CUD]DIE(IANA-1) =  GDIE(IANA)                              # Ana
Next                                                              # Ana

[F:CUD]CUNDAT    = [M:SIW]CUNLISDATL(I)
[F:CUD]NETCUNCST = [M:SIW]NETCUNCST (I)
[F:CUD]CUNLOKFLG = [M:SIW]CUNLOKFLG (I)

GPOINT = "SIW_CUD"                          # hcb 42169
Gosub  ENTREE From EXEFNC                   # hcb 42169

Write [CUD]
If fstat
   GOK = 0
   Call FSTA("CUD") From GLOCK
   Return
Endif
Return

########################################################################
# TEST_INSERT_SNL0            Test pour insertion d'une ligne ecran SNL0
########################################################################
$TEST_INSERT_SNL0
Local Integer WRET
# si liste cloturee insertion interdit
If [M:SNL0]CUNLISSTA  =  6
    mkstat = 2
    GMODIF = 1  # pour bug moteur
Else
      Gosub AZO_SNL0_RGP From STKINV
Endif
Return
########################################################################
# TEST_INSERT_SNL1            Test pour insertion d'une ligne ecran SNL1
########################################################################
$TEST_INSERT_SNL1
Local Integer WRET
# si liste cloturee insertion interdit
If [M:SNL0]CUNLISSTA  =  6
    mkstat = 2
    GMODIF = 1  # pour bug moteur
Else
    Gosub AZO_SNL1 From STKINV
Endif
Return

########################################################################
# ECR_TRACE_ARTICLE     Trace : Saisie incomplète des quantités comptées
########################################################################
$ECR_TRACE_ARTICLE
#Saisie incomplète des quantités comptées
If GIMPORT
   Call ECR_TRACE(mess(45,184,1)-" : "-LSSS-","-LLIS-","-TITM(I),0) From GESECRAN
Else
   Call ECR_TRACE(TITM(I)-mess(45,184,1),1) From GESECRAN
Endif
Return
############################################################
$ECR_TRACE1
#Quantité supérieure au stock disponible
Call ECR_TRACE(TITM(I)- mess(148,199,1)-num$(WDIS),1) From GESECRAN
Return

########################################################################
# MAJ_INVENTAIRE                       validation inventaire par article
########################################################################
$MAJ_INVENTAIRE
Local Decimal LQTA
Local Decimal LSHT
Local Integer LNBR
Local Integer LNBJ
Local Integer LRET
Local Integer K
Local Integer WCOD

Call DEBTRANS From GLOCK
Trbegin [CUD]
#Mise à jour des stock
Local Char WCUNLISNUM
#Lecture article maitre
Read [ITM]ITM0= TITM(I)
If fstat
#   Erreur lecture fichier !
    Call ECR_TRACE(mess(6,9004,1)-"ITMMASTER"-TITM(I),1) From GESECRAN
    Gosub AB_TRT From STKINV
    Return
Endif

#lecture [ITF] et effacement flag bloqué inventaire
Readlock [ITF]ITF0=TITM(I);[M:SNL0]STOFCY
If fstat
#   Erreur lecture fichier !
    Call ECR_TRACE(mess(6,9004,1)-"ITMFACILIT"-TITM(I),1) From GESECRAN
    Gosub AB_TRT From STKINV
    Return
Endif
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 6 | [F:SRT]SRTNUM <> GSNLNUM                   # hcb 50197
    Read [SRT]SRT0=6;GSNLNUM : If fstat Raz [F:SRT] : Endif
Endif


Call EXI_LIS_BLO([M:SNL0]STOFCY,[F:ITF]ITMREF,LLIS,WCUNLISNUM) From STKINV
If WCUNLISNUM = ""
  [F:ITF]CUNLISNUM = ""
  [F:ITF]CUNFLG    = 1
Else
  [F:ITF]CUNLISNUM = WCUNLISNUM
Endif
Rewrite [ITF]
If fstat
#   Erreur à la réécriture du fichier
    Call ECR_TRACE(mess(5,9004,1)-"ITMFACILIT"-TITM(I),1) From GESECRAN
    Gosub AB_TRT From STKINV
    Return
Endif

#########################################
# Initialisation de l'en-tête STOWORK
Raz [M:STW]
[M:STW]STOFCY     = [M:SNL0]STOFCY      # Site
[M:STW]TRSTYP     = 13                  # inventaire t  (M.704)
[M:STW]VCRTYP     = 9                   # inventaire    (M.701)
[M:STW]VCRNUM     = LLIS                # Numéro liste
[M:STW]VCRLIN     = 0                   # Numero ligne = itmlisnum dans le détail
[M:STW]VCRTYPORI  = 0
[M:STW]VCRNUMORI  = LSSS                # Session
[M:STW]VCRLINORI  = 0
[M:STW]ITMREF     = TITM(I)             # Article
[M:STW]MVTDES     = [M:SNL0]MVTDES      # Désignation mouvement
[M:STW]PRIORDH    = 0
[M:STW]PJT        = ""
[M:STW]TRSFAM     = [F:SRT]TRSFAM       # famille mouvement
[M:STW]ENTCOD     = [F:SRT]ENTCOD       # code piece auto
[M:STW]TRSCOD     = ""
[M:STW]IPTDAT     = [M:SNL0]IPTDAT      # Date imputation
[M:STW]CCECOD     = "STJINV"            # CODE section analytique stock
[M:STW]CUR       = GLOCALDEV
[M:STW]BPRNUM    = ""
# LQTA = Total qté inventaire calculé
# LSHT = Total qté inventaire compté
# LNBR = Nombre inventaires
# LNBJ = Nombre inventaires justes
Call ALISTOWORK( 8, 0, LQTA, LSHT,LNBR,LNBJ, LRET ) From STKINT
#Mise à jour des stock

If LRET <> 0 | GOK < 1
   Gosub AB_TRT From STKINV
   Return
Endif

# appel uniquement si écarts d inventaire
If [M:STW]NBLIG <> 0
   Raz GPE                         # hcb 82349
   GPOINT = "MAJ_STOCK"            # hcb 82349
   Gosub  ENTREE From EXEFNC       # hcb 82349
   If GPE =  0                     # hcb 82349
      Call MAJ_STOCK From STKMAJ
      If LRET <> 0 | GOK < 1
         Gosub AB_TRT From STKINV
         Return
      Endif
   Endif                           # hcb 82349
Endif

# lecture STE
Readlock [STE]STE0=[M:SNL0]STOFCY;""
If fstat
#   Erreur lecture fichier !
    Call ECR_TRACE(mess(6,9004,1)-"STOPAR"-[M:SNL0]STOFCY,1) From GESECRAN
    Gosub AB_TRT From STKINV
    Return
Endif

# Lecture ITV
Call LECITV([M:SNL0]STOFCY,TITM(I),"",LRET) From STKLIB
If LRET > 1
#   Erreur lecture fichier !
    Call ECR_TRACE(mess(6,9004,1)-"ITMMVT"-[M:SNL0]STOFCY-TITM(I),1) From GESECRAN
    Gosub AB_TRT From STKINV
    Return
Endif
# Mise à jour ITV partie inventaire
#date dernier inventaire si inventaire globale et multiliste à non et article dépot à non
Raz GPE                                              # hcb 83997
GPOINT = "LASCUNDAT"                                 # hcb 83997
Gosub  ENTREE From EXEFNC                            # hcb 83997
If GPE =  0                                          # hcb 83997
   If [F:CUN]CUNLASFLG = 2 &  [F:CUN]MULLISFLG <> 2 & [F:CUN]CUNITMWRH <> 2
      [F:ITV]LASCUNDAT     =  [M:SNL0]IPTDAT
      [F:ITV]LASCUNLIS     =  LLIS
   Endif
Else                                                 # hcb 83997
   If [F:CUN]MULLISFLG <> 2 & [F:CUN]CUNITMWRH <> 2  # hcb 83997
      [F:ITV]LASCUNDAT     =  [M:SNL0]IPTDAT         # hcb 83997
      [F:ITV]LASCUNLIS     =  LLIS                   # hcb 83997
   Endif                                             # hcb 83997
Endif                                                # hcb 83997

# si inventaire article et complet controle alloué global   hcb 36955
If [F:CUN]CUNSSSTYP = 1 & [F:CUN]CUNLASFLG = 2
   If LSHT < [F:ITV]GLOALL
      If GTRACE<>""
         Call ECR_TRACE(TITM(I)-":"-mess(280,184,1)-"("-num$([F:ITV]GLOALL)-"/"-num$(LSHT)-")",0) From GESECRAN
      Else
         Call MESSAGE(TITM(I)-":"-mess(280,184,1)-"("-num$([F:ITV]GLOALL)-"/"-num$(LSHT)-")")     From GESECRAN
      Endif
#                                      hcb 45885 deb
      Local Integer I1                 # hcb 57381
      Raz I1                           # hcb 57381
      Local Char MES(255)
      Raz MES
      Filter [STA] Where    STOFCY = [M:SNL0]STOFCY    &
&                           ITMREF = TITM(I)           &
&                           STOCOU = 0                 &
&                           ALLTYP = 1
&                           Order By Key STA0
      Columns [STA] (VCRNUM, VCRLIN, QTYSTUACT, VCRTYP)
      For [STA]
          I1 += 1                      # hcb 57381
          If I1 > 3                    # hcb 57381
             Break
          Endif
          MES += mess([F:STA]VCRTYP,701,1)-[F:STA]VCRNUM-mess(3,40,1)-num$([F:STA]VCRLIN)-mess(33,105,1)-num$([F:STA]QTYSTUACT)+"\"
      Next
      Filter  [STA]
      Columns [STA]
      If GTRACE<>""
         Call ECR_TRACE(MES,0) From GESECRAN
      Else
         Call MESSAGE(MES)     From GESECRAN
      Endif
#                                      hcb 45885 fin

   Endif
Endif

#Mise à jour stock dernier inventaire (compté)
[F:ITV]CUNSTO        =  LSHT
# raz compteurs nombre entrées
[F:ITV]CUNRCPMVT     =  0
# raz compteurs nombre sorties #
[F:ITV]CUNISSMVT     =  0
#Cumul nombre inventaires
[F:ITV]CUNNBR        +=  1
#Cumul nombre inventairesjustes
If LNBR = LNBJ
  [F:ITV]CUNNBREQU   +=  1
Endif
#Mise à jour statistiques inventaires
For K = dim([F:ITV]CUNDAT)-2 To 0 Step -1
   [F:ITV]CUNDAT   (K+1) = [F:ITV]CUNDAT   (K)
   [F:ITV]CUNQTYCLC(K+1) = [F:ITV]CUNQTYCLC(K)
   [F:ITV]CUNQTYNEW(K+1) = [F:ITV]CUNQTYNEW(K)
Next K
[F:ITV]CUNDAT(0)     = [M:SNL0]IPTDAT
#Mise à jour stock dernier inventaire (calculé)
[F:ITV]CUNQTYCLC(0)  = LQTA
#Mise à jour stock dernier inventaire (compté)
[F:ITV]CUNQTYNEW(0)  = LSHT
#calcul nombre de ligne statistique
If [F:ITV]CUNDIM < dim([F:ITV]CUNDAT)
   [F:ITV]CUNDIM += 1
Endif

WCOD = [F:ITF]CUNCOD
#CALCUL date prochain inventaire ITV si article depot à non
If [F:CUN]CUNITMWRH <> 2
   Call CAL_NEXINV([M:SNL0]STOFCY,[F:ITM]TCLCOD,[M:SNL0]IPTDAT,WCOD) From STKINV

# Mise à jour ITW partie inventaire
Else
   Readlock [ITW]ITW0=TITM(I);[F:CUL]WRH
   If fstat
#   Erreur lecture fichier !
      Call ECR_TRACE(mess(6,9004,1)-"ITMWRH"-TITM(I)-[F:CUL]WRH,1) From GESECRAN
      Gosub AB_TRT From STKINV
      Return
   Endif
#date dernier inventaire
   If [F:CUN]CUNLASFLG = 2
      [F:ITW]LASCUNDAT     =  [M:SNL0]IPTDAT
      [F:ITW]LASCUNLIS     =  LLIS
   Endif
   If [F:ITW]CUNWRHFLG = 2
      WCOD = [F:ITW]CUNCOD
#CALCUL date prochain inventaire ITW si mode inventaire depot à non sinon ITV
      Call CAL_NEXINVITW([M:SNL0]STOFCY,[F:ITM]TCLCOD,[M:SNL0]IPTDAT,WCOD) From STKINV
   Else
      Call CAL_NEXINV([M:SNL0]STOFCY,[F:ITM]TCLCOD,[M:SNL0]IPTDAT,WCOD) From STKINV
   Endif
   # Réécriture ITW
   Call REWITW From STKLIB
   If fstat
#   Erreur à la réécriture du fichier
      Call ECR_TRACE(mess(5,9004,1)-"ITMWRH"-TITM(I)-[F:CUL]WRH,1) From GESECRAN
      Gosub AB_TRT From STKINV
      Return
   Endif
Endif
# Réécriture ITV

Call REWITV From STKLIB
If fstat
#   Erreur à la réécriture du fichier
    Call ECR_TRACE(mess(5,9004,1)-"STOPAR"-[M:SNL0]STOFCY-TITM(I),1) From GESECRAN
    Gosub AB_TRT From STKINV
    Return
Endif

# Mise à jour STE

Case [F:ITF]ABCCLS
  When 1 :
    [F:STE]CUNNBRA += 1
    [F:STE]LASCUNDATA = [M:SNL0]IPTDAT
  When 2 :
    [F:STE]CUNNBRB += 1
    [F:STE]LASCUNDATB = [M:SNL0]IPTDAT
  When 3 :
    [F:STE]CUNNBRC += 1
    [F:STE]LASCUNDATC = [M:SNL0]IPTDAT
  When 4 :
    [F:STE]CUNNBRD += 1
    [F:STE]LASCUNDATD = [M:SNL0]IPTDAT
Endcase

Rewrite [STE]
If fstat
#   Erreur à la réécriture du fichier
    Call ECR_TRACE(mess(5,9004,1)-"STOPAR"-[M:SNL0]STOFCY,1) From GESECRAN
    Gosub AB_TRT From STKINV
    Return
Endif


If GIMPORT
# Validation de la liste
   Call ECR_TRACE(mess(198,184,1)-" : "-LSSS-","-LLIS,0) From GESECRAN
   GSTK_LISVAL += 1
Endif

# Transaction bien terminée
Commit
Return


########################################################################
# CHANGE_AWI                               chargement traitement fenetre
########################################################################
$CHANGE_AWI
Local Integer OK
If clalev([F:AWI])=0  : Local File AWINDOW [AWI] : Endif
Read [AWI]AWI0=BOITE
If fstat
    GMESSAGE = BOITE-":"-mess(6,126,1)                 : # Fenêtre inexistante
    GERR = 1
    FIN = 1
    Return
Endif
GBOITE     = BOITE
Call NOMTRTWIN(GBOITE,WINPROG) From MSKDIV
Gosub DEFVAR From =WINPROG

#If filinfo(filpath("TRT",WINPROG,"adx"),0)<0
Call EXISTE_ADX("","",WINPROG,OK) From ORDSYS
If OK=0
    GMESSAGE = BOITE-":"-mess(6,126,1)                 : # Fenêtre inexistante
    GERR = 1
    FIN = 1
Endif
Return


########################################################################
#  Action                                         appeles par les ecrans
########################################################################
# STKSELLIS                                   Sélection liste inventaire
# STKVERLIS                                Vérification liste inventaire

$ACTION

#---------------------------------#
Case ACTION
 When "SEL_TABLE"     : Gosub SELTABLE   From STKINV
 When "VERF_TABLE"    : Gosub VERFTABLE  From STKINV
 When Default
Endcase
Return

######################################################################"
# SELTABLE
######################################################################"
$SELTABLE

Case GACTION
     When "STKSELLIS"       : Gosub STKSELLIS
Endcase
Return

######################################################################"
# VERFTABLE
######################################################################"
$VERFTABLE

Case TABLE
     When "STKSELLIS"       : Gosub STKVERLIS
Endcase
Return



#########################################################################
# STKSELLIS                                   Sélection liste inventaire
#########################################################################
$STKSELLIS
Local Char    LSSS         : LSSS =      PARAM(1)
Local Char LFIC(10)
LFIC = "CUNLISTE"

If clalev([F:CUL])  = 0 : Local File CUNLISTE  [CUL]  : Endif
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ]  : Endif
#
TIT(0) = mess(429,199,1)

NBCOL = 1  : COL(NBCOL) = "CUNLISNUM"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "CUNLISDES"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "NBRLIG"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "CUNLISSTA"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV

Local Char WLISTE(15)
WLISTE = ""
#
ORDRE   = "CUNSSSNUM;CUNLISNUM"
CRITERE = "[F:CUL]CUNSSSNUM=LSSS"
START   = "CUNLISNUM"
SIZLIG  = 100
SIZCOL  = 200
Default File [CUL]
Return

#########################################################################
# STKVERLIS                                Vérification liste inventaire
#########################################################################
$STKVERLIS
Read [CUL]CUL0=LSSS;[F:CUL]CUNLISNUM
If fstat
   Return
Endif
Return


#########################################################################
# TRT_ECRSTJBID                      Ecriture enregistrement STOJOU bidon
#########################################################################

$TRT_ECRSTJBID

# si simulation pas de maj
If dim(GSIMSNU) > 0
   Return
Endif

Local Integer WCUNLISSTA
WCUNLISSTA = 1
If GIMPORT
   WCUNLISSTA = 2
Endif

Local Char    WITMREF(GLONITM)
Local Char    WLIS             # hcb 140205 27888
Raz WITMREF
Raz WLIS
GOK = 1
Filter [CUD] Where STOFCY    = [M:SNU0]STOFCY         &
&                  CUNSSSNUM = [M:SNU0]CUNSSSNUM      &
&                  CUNLISSTA = WCUNLISSTA
&            Order By Key CUD3
For [CUD]
  If WITMREF <> [F:CUD]ITMREF | WLIS <>  [F:CUD]CUNLISNUM  # hcb 140205 27888
     WITMREF =  [F:CUD]ITMREF
     WLIS    =  [F:CUD]CUNLISNUM                           # hcb 140205 27888
     Gosub ECR_ECRSTJBID
     If GOK < 1
        Break
     Endif
  Endif
Next
Filter [CUD]

Return
#########################################################################
# ECR_ECRSTJBID                      Ecriture enregistrement STOJOU bidon
#########################################################################
$ECR_ECRSTJBID

Local Integer WRET
If !clalev([F:STJ1])  Local File STOJOU     [STJ1] : Endif
If !clalev([F:STJ])   Local File STOJOU     [STJ]  : Endif
If !clalev([F:ITG])   Local File ITMCATEG   [ITG]  : Endif
If !clalev([F:ITM])   Local File ITMMASTER  [ITM]  : Endif

Raz [F:STJ]
[F:STJ]STOFCY    = [M:SNU0]STOFCY
[F:STJ]OWNER     = [M:SNU0]STOFCY
[F:STJ]UPDCOD    = 2
[F:STJ]REGFLG    = 2
[F:STJ]ITMREF    = [F:CUD]ITMREF
[F:STJ]VCRTYP    = 9
[F:STJ]VCRNUM    = [F:CUD]CUNLISNUM
[F:STJ]VCRNUMORI = [F:CUD]CUNSSSNUM
[F:STJ]IPTDAT    =  date$

If [F:ITM]ITMREF<>[F:CUD]ITMREF
   Read [ITM]ITM0=[F:CUD]ITMREF
   If fstat
      Raz [F:ITM]
   Endif
Endif

#----- Création du mouvement de stock -----#
Call ECRSTJ(0,WRET) From STKLIB
If WRET <> 0
   GOK = 0
Endif
Return

#########################################################################
# MOD_IPTDAT                                 modification date imputation
# l ecran SNL0 doit etre chargé
#########################################################################
Subprog MOD_ECRSTJBID(LFCY,LSSS,LLIS,LRET)
Value    Char    LFCY
Value    Char    LSSS
Value    Char    LLIS
Variable Integer LRET
Local    Integer WRET
Local Char       WITMREF(GLONITM)
# si la date d imputation n a pas ete modifiée  : sortie
If [M:SNL0]CULIPTDAT = [M:SNL0]IPTDAT
   End
Endif

If !clalev([F:STJ1])  Local File STOJOU     [STJ1] : Endif
If !clalev([F:STJ])   Local File STOJOU     [STJ]  : Endif
If !clalev([F:ITG])   Local File ITMCATEG   [ITG]  : Endif
If !clalev([F:ITM])   Local File ITMMASTER  [ITM]  : Endif
GOK = 1

# reecriture cunliste avec nouvelle iptdat
Readlock [CUL]CUL0=LSSS;LLIS
Case fstat
     When 0 :
     When 1 :
          GOK = -1
          GMESSAGE = mess(20,100,1)-"CUNLISTE"-LLIS
          End
     When Default :
          GOK = 0
          Call FSTA("CUL") From GLOCK
          End
Endcase
[F:CUL]IPTDAT = [M:SNL0]IPTDAT
[F:CUL]UPDUSR = GUSER
[F:CUL]UPDDAT = date$
Rewrite  [CUL]
If fstat
   GOK = 0
   Call FSTA("CUL") From GLOCK
   End
Endif

# suppression enregistrement stojou bidon ancienne date imputation

Delete [F:STJ] Where STOFCY    =LFCY
&                   & UPDCOD   =2
&                   & IPTDAT   =[M:SNL0]CULIPTDAT
&                   & MVTIND   =0
&                   & VCRTYP   =9
&                   & VCRNUM   =LLIS
&                   & VCRNUMORI=LSSS
&                   & REGFLG   =2

# création enregistrement stojou bidon nouvelle date imputation

Filter [CUD] Where STOFCY    = LFCY        &
&                  CUNSSSNUM = LSSS        &
&                  CUNLISNUM = LLIS
&            Order By Key CUD3
For [CUD]
    If WITMREF <> [F:CUD]ITMREF
       WITMREF =  [F:CUD]ITMREF
       Raz [F:STJ]
       [F:STJ]STOFCY    = LFCY
       [F:STJ]OWNER     = LFCY
       [F:STJ]UPDCOD    = 2
       [F:STJ]REGFLG    = 2
       [F:STJ]ITMREF    = [F:CUD]ITMREF
       [F:STJ]VCRTYP    = 9
       [F:STJ]VCRNUM    = LLIS
       [F:STJ]VCRNUMORI = LSSS
       [F:STJ]IPTDAT    = [M:SNL0]IPTDAT
       If [F:ITM]ITMREF<>[F:CUD]ITMREF
          Read [ITM]ITM0=[F:CUD]ITMREF
          If fstat
             Raz [F:ITM]
          Endif
       Endif
       #----- Création du mouvement de stock -----#
       Call ECRSTJ(0,WRET) From STKLIB
       If WRET <> 0
          GOK = 0
          Break
       Endif
    Endif
Next
Filter [CUD]
If GOK
   [M:SNL0]CULIPTDAT = [M:SNL0]IPTDAT
Endif
End


#########################################################################
# TRT_CTR_IPTDAT                                 controle date imputation
# LFCY : Site
# LITM : Article
# LSSS : Session inventaire
# LLIS : Liste inventaire
# LIPT : Date imputation saisie
# LCRE : Date creation liste
# LORI : Origine du controle   SAI :  à la saisie de la date
#                              VAL :  à la validation
# LSUP : Code supplementaire
# LRET : Code retour  9 = erreur)
#
# CUNLISTE doit etre chargé
#########################################################################
Subprog TRT_CTR_IPTDAT(LFCY,LITM,LSSS,LLIS,LIPT,LCRE,LORI,LSUP,LRET)
Value    Char    LFCY
Value    Char    LITM
Value    Char    LSSS
Value    Char    LLIS
Value    Date    LIPT
Value    Date    LCRE
Value    Char    LORI
Value    Char    LSUP
Variable Integer LRET
Local    Char CRITERE(255)
Raz CRITERE
# point d entrée servant suivant l'origine de désactiver le controle en initialisant LORI
GPOINT = "CTR_IPTDAT"
Gosub  ENTREE From EXEFNC

If LORI = ""
   End
Endif
If CRITERE = ""
   CRITERE = "1=1"
Endif

Case LORI
     When "SAI" :
          # tableau des articles validables
          Local Char    TITM(GLONITM)([F:CUL]NBRLIG)
          Local Integer IITM
          Local Integer I
          Raz TITM,IITM
          #recensement des articles non validés
          Filter [CUD] Where [F:CUD]STOFCY = LFCY & [F:CUD]CUNSSSNUM = LSSS & [F:CUD]CUNLISNUM = LLIS & [F:CUD]CUNLISSTA < 3
&                      Order By Key CUD0
              For [CUD]
                  If !find([F:CUD]ITMREF,TITM(0..IITM))
                     TITM(IITM) = [F:CUD]ITMREF
                     IITM += 1
                  Endif
              Next
          Filter [CUD]
          For I = 0 To IITM-1
              If TITM(I) <> ""
                 Call CTR_IPTDAT(LFCY,TITM(I),LIPT,LCRE,CRITERE,LSUP,LRET)
              Endif
              If LRET = 9
                 Break
              Endif
          Next I
     When "VAL" :
          Call CTR_IPTDAT(LFCY,LITM,LIPT,LCRE,CRITERE,LSUP,LRET)
     When Default :
Endcase

End
#########################################################################
# CTR_IPTDAT                                     controle date imputation
# LFCY : Site
# LITM : Article
# LIPT : Date imputation saisie
# LCRE : Date creation liste
# LCRI : Critere
# LSUP : Code supplementaire
# LRET : Code retour  9 = erreur)
#########################################################################
Subprog CTR_IPTDAT(LFCY,LITM,LIPT,LCRE,LCRI,LSUP,LRET)
Value    Char    LFCY
Value    Char    LITM
Value    Date    LIPT
Value    Date    LCRE
Value    Char    LCRI
Value    Char    LSUP
Variable Integer LRET

If clalev([F:STJ]) = 0 : Local File STOJOU[STJ] : Endif

Filter [STJ] Where STOFCY=LFCY & VCRTYP<>9 & ITMREF=LITM & REGFLG<>2 & IPTDAT>= LIPT & IPTDAT <= LCRE & evalue(LCRI)
       Look [STJ]STJ0 First
Filter [STJ]
If !fstat
   If GIMPORT
      Call ECR_TRACE(mess(388,184,1)-" : "-LITM,0) From GESECRAN
   Else
      Call ERREUR(mess(388,184,1)) From GESECRAN
   Endif
   LRET = 9
   End
Endif

End

#                                                                                         # hcb 71659 deb
########################################################################
# SIT_MULTI_COMPTAGE                   situation du multi_comptages
########################################################################
Subprog SIT_MULTI_COMPTAGE(LRGP_FILTRE,LRGP_FILTRE1,LRGP_FILTRE2,LLIG)
Value    Char    LRGP_FILTRE
Value    Char    LRGP_FILTRE1
Value    Char    LRGP_FILTRE2
Value    Integer LLIG
Local Integer WUN
Raz WUN
# SAICOD = ""    Comptage complet
# SAICOD = "+"   aucun comptage de fait

# SAICOD = "+1"  comptage 1 en cours
# SAICOD = "*1"  comptage 1 fini
# SAICOD = "+2"  comptage 2 en cours
# SAICOD = "*2"  comptage 2 fini
# SAICOD = "+!"  comptage hétérogène
Local File CUNLISDET [CUD1]

[M:SNL0]SAICOD(LLIG)   = "+"
#        premier passage détection si le comptage est complet
Filter [CUD1] Where  evalue(LRGP_FILTRE) & evalue(LRGP_FILTRE1) & evalue(LRGP_FILTRE2)
&                  & [F:CUD1]CUNLISSTA <2
       Look [CUD1]CUD0 First
Filter [CUD1]
If fstat
   [M:SNL0]SAICOD(LLIG)   = ""
   [M:SNL0]CTG1  (LLIG)   = 2
   [M:SNL0]CTG2  (LLIG)   = 2
   End
Endif
#        deuxieme  passage détection si le comptage 2 est complet
Filter [CUD1] Where  evalue(LRGP_FILTRE) & evalue(LRGP_FILTRE1) & evalue(LRGP_FILTRE2)
&                  & [F:CUD1]QTYSTUNEW2 = 0 & [F:CUD1]ZERSTOFLG2 < 2
       Look [CUD1]CUD0 First
Filter [CUD1]
If fstat
   [M:SNL0]SAICOD(LLIG)   = "*2"
   [M:SNL0]CTG2  (LLIG)   = 2
Endif
#        troisieme  passage détection si le comptage 2 est commmencé
If [M:SNL0]SAICOD(LLIG)  = "+"
    Filter [CUD1] Where  evalue(LRGP_FILTRE) & evalue(LRGP_FILTRE1) & evalue(LRGP_FILTRE2)
&                      & ([F:CUD1]QTYSTUNEW2 <> 0 | [F:CUD1]ZERSTOFLG2 = 2)
           Look [CUD1]CUD0 First
    Filter [CUD1]
    If !fstat
      [M:SNL0]SAICOD(LLIG)   = "+2"
   Endif
Endif


#                  # [F:CUD1]QTYSTUNEW1 = 0 & [F:CUD1]ZERSTOFLG1 < 2  & [F:CUD1]STOCOU <>0

#        quatrieme passage détection si le comptage 1 est complet
Filter [CUD1] Where  evalue(LRGP_FILTRE) & evalue(LRGP_FILTRE1) & evalue(LRGP_FILTRE2)
&                  & [F:CUD1]QTYSTUNEW1 = 0 & [F:CUD1]ZERSTOFLG1 < 2
       Look [CUD1]CUD0 First
Filter [CUD1]
If fstat
   If [M:SNL0]SAICOD(LLIG)  = "+"
      [M:SNL0]SAICOD(LLIG)  = "*1"
   Endif
   [M:SNL0]CTG1  (LLIG)   = 2
Endif

#        cinqueme passage détection si le comptage 1 est commmencé
#                  # ([F:CUD1]QTYSTUNEW1 <> 0 | [F:CUD1]ZERSTOFLG1 = 2)  & [F:CUD1]STOCOU <>0

Filter [CUD1] Where  evalue(LRGP_FILTRE) & evalue(LRGP_FILTRE1) & evalue(LRGP_FILTRE2)
&                  & ([F:CUD1]QTYSTUNEW1 <> 0 | [F:CUD1]ZERSTOFLG1 = 2)

       Look [CUD1]CUD0 First
Filter [CUD1]
If !fstat
    If [M:SNL0]SAICOD(LLIG)  = "+"
       [M:SNL0]SAICOD(LLIG)  = "+1"
    Else
       If [M:SNL0]CTG1  (LLIG)   <> 2
          [M:SNL0]SAICOD(LLIG)   = "+!"
          [M:SNL0]CTG1  (LLIG)   = 2
          [M:SNL0]CTG2  (LLIG)   = 2
      Endif
   Endif
Endif
#                                                             # hcb 110327 deb
If [M:SNL0]SAICOD(LLIG) <> "*2"
   Global Char GSNLSERE
Endif
#                                                             # hcb 110327 fin

End

#                                                                                         # hcb 71659 fin

