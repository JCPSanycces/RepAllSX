#<AdxTL>@(#)12.0.0.0 $Revision$ Gestion objet TFOLEG
Raz GPILOBJ , GNBMASKOUV
Call OBJET("TFOLEG",GBIDC1,GBIDC2) From GOBJET
End

#----------------------------------------#
$ACTION
If dim([L]PSUBB)<=0
 Local Integer PSUBB
 Call EXISTE_ADX("","","SUBTFOLEGB",PSUBB) From ORDSYS
Endif
Case ACTION
 When "LIENS2"      : Gosub LIENS2
 When "INICRE"      : Gosub INICRE
 When "MODIF"       : Gosub MODIF
 When "CREATION"    : Gosub CREATION
 When "ANNULE"      : Gosub ANNULE
 When "RAZCRE"      : Gosub RAZCRE
 When "RAZDUP"      : Gosub RAZDUP
 When "AFFMASK"     : Gosub AFFMASK
Endcase
If PSUBB
 Gosub ACTION From SUBTFOLEGB
Endif
Return

#-----------------------#
$AFFMASK
If dim([M:TFOLEG1]LEG)>0
 If !func AFNC.ACTIV("LEG")
  Chgfmt [M:TFOLEG1]LEG With "-K:"+num$(GLONADI)+"B"
  If dim([M:TFOLEG1]ZLEG)>0
   Chgfmt [M:TFOLEG1]ZLEG With "-K:"+num$(type([M:TFOLEG1]ZLEG)-10)+"X"
  Endif
 Endif
Endif
Return

#---------------------------#
$MODIF
Gosub CREATION
Return

#---------------------#
$LIENS2
If !func AFNC.ACTIV("LEG")
 [M:TFOLEG1]NBLIG = 1
Endif
Return

#---------------------#
$INICRE
If !func AFNC.ACTIV("LEG")
 #108980 [F:TFOLEG]CODLEG = GDOSLEG
 [F:TFOLEG]LEG = GDOSLEG
Endif
Return

#---------------------#
$RAZCRE
$RAZDUP
If dim([M:TFOLEG1]LEG)>0 & !func AFNC.ACTIV("LEG")
 [M:TFOLEG1]LEG = GDOSLEG
Endif
Return

#----------------#
$CREATION
Call MAJTEXTRA([M]DES,"TABFORLEG","DES",[M]FORCOD,"") From ATEXTRA
If GOK<1 : Return : Endif
Call MAJTEXTRA([M]DESSHO,"TABFORLEG","DESSHO",[M]FORCOD,"") From ATEXTRA
If GOK<1 : Return : Endif
Return

#------------------#
$ANNULE
Delete [AXX] Where CODFIC="TABFORLEG" & IDENT1=[L]CODE
If fstat=1 | fstat>5
 GOK=0 : Call RSTA("AXX",[L]CODE) From GLOCK : Return
Endif
Return

#---------------------------------------------------------#
$TRTCOP
If [M]DOSORG=nomap
 Local File TABFORLEG [TFOLEG1]
 Local File ATEXTRA   [AXX1]
Else
 Local File =[M]DOSORG+".TABFORLEG" [TFOLEG1]
 Local File =[M]DOSORG+".ATEXTRA"   [AXX1]
Endif
If [M]DOSDES=nomap
 Local File TABFORLEG [TFOLEG2]
 Local File ATEXTRA   [AXX2]
Else
 Local File =[M]DOSDES+".TABFORLEG" [TFOLEG2]
 Local File =[M]DOSDES+".ATEXTRA"   [AXX2]
Endif
Gosub OUVDOS From ATEXTRA
Local Char DOSDESLEG(GLONADI)(1..dim(GDOSLEG))
Local Integer NBDESLEG , OK
Call SETLEG([M]DOSDES,DOSDESLEG,NBDESLEG) From DOSCONT
OK = 1
If GTRACE=""
 Read [TFOLEG2]TFOLEG0(1) = TABLE
 If !fstat
  # Fiche déjà existante
  OK=1 : Call AVERTIR([M]DOSDES-TABLE-mess(22,100,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
If OK
 Call DEBTRANS From GLOCK
 Gosub TR_COP
Endif
Close Local File [TFOLEG1] , [TFOLEG2] , [AXX1] , [AXX2]
Return

#--------------------#
$TR_COP
GOK = 1
Trbegin [TFOLEG2]
 Delete [TFOLEG2] Where FORCOD=TABLE
 Call COPTEXTRA("TABFORLEG","DES",TABLE,"") From ATEXTRA
 Call COPTEXTRA("TABFORLEG","DESSHO",TABLE,"") From ATEXTRA
 For [TFOLEG1] Where FORCOD=TABLE
  If find([F:TFOLEG1]LEG,DOSDESLEG)
   [F:TFOLEG2] = [F:TFOLEG1]
   If dim([F:TFOLEG2]CREUSR)>0 : [F:TFOLEG2]CREUSR = GUSER : Endif
   If dim([F:TFOLEG2]CREDAT)>0 : [F:TFOLEG2]CREDAT = date$ : Endif
   If dim([F:TFOLEG2]CRETIM)>0 : [F:TFOLEG2]CRETIM = time  : Endif
   Write [TFOLEG2]
   If fstat
    GOK=0 : Call FSTA("TFOLEG2") From GLOCK : Goto AB_TR_COP
   Endif
  Endif
 Next TFOLEG1
Commit
Return

$AB_TR_COP
Rollback
Return

$ROLL_TR_COP
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR_COP : Endif

#---------------------------------------------------------------------#
Subprog C_NBLIG
If !func AFNC.ACTIV("LEG") & !adxgtb & nolign>1
 mkstat = 1
Endif
End

Subprog AS_FORFOR(VALEUR)
Variable Char    VALEUR()
Local Char ACTION(20)
ACTION = "AS_FORFOR" : Gosub ACTION
End

Subprog C_FORFOR(VALEUR)
Variable Char    VALEUR()
Local Char ACTION(20)
ACTION = "C_FORFOR" : Gosub ACTION
End

Subprog C_LEG(VALEUR)
Variable Char     VALEUR
Call UNICITE(VALEUR,[M]LEG(0..[M]NBLIG-1)) From OBJDIV
If mkstat : End : Endif
If VALEUR<>"" & !find(VALEUR,GDOSLEG)
 mkstat = 1 : GMESSAGE = mess(249,133,1)
Endif
End

