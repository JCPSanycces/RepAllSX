#SR947.bn
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
If [M:BIC0]BPR <> ""
#   Alimentation flag inter-site et inter-sociťtť
    Call ALIBETCPY(5,VALEUR,[M:BIC0]BPR,GBIDC1,GBIDC2,GBIDC3,[M:BIC0]YINTER,[M:BIC0]YINTER) From TRTVENISOC
Endif
Affzo [M:BIC0]YINTER
End

Subprog AM_BPR(VALEUR)
Variable Char    VALEUR()
If [M:BIC0]FCY <> ""
#   Alimentation flag inter-site et inter-sociťtť
    Call ALIBETCPY(5,[M:BIC0]FCY,VALEUR,GBIDC1,GBIDC2,GBIDC3,[M:BIC0]YINTER,[M:BIC0]YINTER) From TRTVENISOC
Endif
Affzo [M:BIC0]YINTER
End

