#SR947.bn
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
If [M:PAY1]BPR <> ""
#   Alimentation flag inter-site et inter-société
    Call ALIBETCPY(5,VALEUR,[M:PAY1]BPR,GBIDC1,GBIDC2,GBIDC3,[M:PAY0]YINTER,[M:PAY0]YINTER) From TRTVENISOC
Endif
Affzo [M:PAY0]YINTER
End

Subprog AM_BPR(VALEUR)
Variable Char    VALEUR()
If [M:PAY1]FCY <> ""
#   Alimentation flag inter-site et inter-société
    Call ALIBETCPY(5,[M:PAY1]FCY,VALEUR,GBIDC1,GBIDC2,GBIDC3,[M:PAY0]YINTER,[M:PAY0]YINTER) From TRTVENISOC
Endif
Affzo [M:PAY0]YINTER
End

