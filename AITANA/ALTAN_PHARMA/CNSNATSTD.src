#<AdxTL>@(#)0.0.0.0 $Revision$
#*********************************************************************************#
#* ACCOUNT By DIMENSION INQUIRY - CONSNAT
#*
# Issue X3-146607 - 2019-07-15 by MDJ : test on [V]GCNSEXPORTXLS value changed from "=ANO" to "<>AYES"
# Issue X3-116770 - 2019-03-13 by BEFOU : Perf update on export  : using  [V]GCNSEXPORTXLS to know if we are on export to not calcul summary
#*!

Raz GNBMASKOUV
Raz GTUNCPT
Local Char PARAM(10)(1..9)
PARAM(1)="APN"        :# Sociťtť
PARAM(2)="ASN"        :# Site
PARAM(3)="2"          :# Type de rťfťrentiel
PARAM(4)="ACHATDIVRS" :# Compte analytique
PARAM(5)=""           :# Tiers
PARAM(6)=""           :# Collectif
PARAM(7)="20030101"   :# Date dťbut
PARAM(8)="20101231"   :# Date fin
PARAM(9)="EUR"        :# Devise
Call GCONSULT("NAT","",PARAM) From GCONSULT
End

Subprog PATCH(APPLI)
Value Char APPLI
If APPLI="X3" End Endif
If !clalev([F:ADS]) Local File ADOSSIER [ADS] Endif
Read [ADS]DOSSIER=APPLI
If !fstat & [F:ADS]MODULE(1)<>2 End Endif
Call VALGTC(APPLI,"NAT") From SUBGTC
End
#
# Issue X3-98590 - 2018-02-08 MDJ : Error Incorrect index L_CUR (10)
#
$ACTION
Case ACTION
 When "AUTORIS"    : Gosub AUTORIS
 When "FERME"      : Gosub FERME
 When "OUVRE"      : Gosub OUVRE
 When "LECTURE"    : Gosub LECTURE
 When "SETBOUT"    : Gosub SETBOUT
 When "DEB_CRIT"   : Gosub DEB_CRIT
 When "EXEBOUT2"   : Gosub EXEBOUT2
 When "FIN_CRIT"   : Gosub FIN_CRIT
 When "SEL_LISTE"  : Gosub SEL_LISTE
 When "VERF_LISTE" : Gosub VERF_LISTE
 When "AB1_NBLIG"  : Gosub AB1_NBLIG
 When "AB2_NBLIG"  : Gosub AB2_NBLIG
 When "BB1_NBLIG"  : Gosub BB_NBLIG
 When "BB2_NBLIG"  : Gosub BB_NBLIG
 When "TRT_DIV"    : Gosub TRT_DIV From CONSSUB
 When "AV_AFFICHE" : Gosub AV_AFFICHE
 When "AV_MAGNETO" : Gosub AV_MAGNETO
 When "AP_MAGNETO" : Gosub AP_MAGNETO
 When "CLECUR"     : If !CLECUR & [M:NAT1]TIERS<>"" : CLECUR=1 : Endif
 When "SET_DERLU"  : Gosub SET_DERLU
Endcase
Return

$AUTORIS
Local Libelle OTUNCPT : OTUNCPT=GTUNCPT(3)
If GTUNCPT(3)
 Call MESSAGE(mess(247,199,1)) From GESECRAN : OK=0
 # Une mÍme fonction ne peut pas Ítre appelťe deux fois !
Else
 GTUNCPT(3) = 1
Endif
If PARAM(2)<>""
 If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
 Call LECTURE("FCY",PARAM(2),"") From CONTOBJ
 If [F:FCY]FINFLG<>2
  Call MESSAGE(mess(217,107,1)) From GESECRAN : OK=0
 Endif
Endif
Return

$FERME
If dim(OTUNCPT)>0 : GTUNCPT(3) = OTUNCPT : Endif
If dim(GCALL_PT)>0 : Kill GCALL_PT : Endif
Return

$OUVRE
#Tables
If !clalev([F:GSC]) : Local File GRPSAC     [GSC] : Endif
If !clalev([F:GAC]) : Local File GACCOUNT   [GAC] : Endif
If !clalev([F:GCM]) : Local File GACM       [GCM] : Endif
If !clalev([F:LED]) : Local File GLED       [LED] : Endif
If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([F:FIY]) : Local File FISCALYEAR [FIY] : Endif
If !clalev([F:PER]) : Local File PERIOD     [PER] : Endif
If !clalev([F:CPY]) : Local File COMPANY    [CPY] : Endif
If !clalev([F:FCY]) : Local File FACILITY   [FCY] : Endif
If !clalev([F:FGR]) : Local File FACGROUP   [FGR] : Endif
If !clalev([F:TCU]) : Local File TABCUR     [TCU] : Endif
If !clalev([F:GAC]) : Local File GACCOUNT   [GAC] : Endif
If !clalev([F:BAL]) : Local File BALANCE    [BAL] : Endif
If !clalev([F:BLA]) : Local File BALANA     [BLA] : Endif
If !clalev([F:DAE]) : Local File GACCENTRYD [DAE] : Endif
If !clalev([F:DAA]) : Local File GACCENTRYA [DAA] : Endif
If !clalev([F:HAE]) : Local File GACCENTRY  [HAE] : Endif
If !clalev([F:GT2]) : Local File GTABACC2   [GT2] : Endif
If !clalev([F:COA]) : Local File GCOA       [COA] : Endif
If !clalev([F:CLS]) : Local File GACCCLS    [CLS] : Endif

#Variables
Local Integer I, J, OK, AX, ISITE, COURTYP, SPSTAT, OKCRS
Local Char    NATCUR(GLONCNA), TRSCUR(GLONBPR), COLCUR(GLONSAC), GRPCUR(GLONGSC),
&             FCYCUR(GLONFCY), CPYCUR(GLONCPY),
&             DEVSOC(GLONCUR), DEVLOC(GLONCUR),
&             DEVLED(GLONCUR), COACUR(GLONCOA)
Local Decimal EXERCICE, PERIODE, AMT
Local Integer NBSITE, NBSOC
# Issue X3-76126
#*X3-98590 Local Char  L_CUR(GLONCUR)(10)
# Issue X3-76126

# GH 02/02/00 bug 4189
NBSITE = max(1,GNBSITE)
Local Char    TSITE(GLONFCY)(1..NBSITE), TDEVSOC(GLONCUR)(1..NBSITE)
Local Char    TDEVLED(GLONCUR)(1..NBSITE)
Local Integer LEDTYPCUR
Local Char    DEVAFFCUR

Local Integer TPFIN(1..NBSITE), TEFIN(1..NBSITE), TEDEB(1..NBSITE), PFIN, EFIN, EDEB
#---------------------------------------------
# 72673/72606 - Consultation sur plusieur exercice sans ecriture de cloture
Local Char    TSOC(GLONCPY)(1..NBSITE)
Local Integer NBFIY : NBFIY=1
Local Integer FIYLST(1..NBFIY),FIYPEND(1..NBFIY)
Local Char    FILTCLO(250)
#---------------------------------------------
NBSITE = 0
Local Date    DDEB, DFIN, DEBDAT, FINDAT, DFCUR, DDCUR
Local Char    FILLIG(250) , FILTET(250), FILTLCT(250), FILNAT(250)
Local Char    DEBHAE(GLONVCR), FINHAE(GLONVCR), DEBTYP(GLONGTE), FINTYP(GLONGTE)
Local Integer DEBNUM, FINNUM, DEBLIG, FINLIG
Local Char    DEBCCE(10)(1..9), FINCCE(10)(1..9), VALCCE(10)(1..9)
Local Char    EXPCLE(250), ORDANA(9), OPT(1), TRICUR(10)
Local Libelle GRP, PLEIN, FLTRI, XDEV
Local Integer COHGRP
Local Date    DEBEX
Local Mask    VENTILE  [VTL]
Local Mask    VENTILE2 [VT2]

#----- Dates ------
Local Char    SEPDAT(1)
Local Char    NULDAT(5)
SEPDAT = mid$(GFMDAT,4,1)
NULDAT = "0"+SEPDAT+"0"+SEPDAT+"0"
#------------------

# Inclure tous les AN si on gŤre les ťcritures de clŰture (DBA le 21/05/03 : Sugg. 17917)
Local Integer FLGCLO

Local Decimal TBRATMLT(0..100)
Local Decimal TBRATDIV(0..100)
Local Integer NBLIN
Local Char    OLDCPTDEF(5)

Global Integer GCALL_PT : Raz GCALL_PT
If dim(GNBENTREE)>0 & GNBENTREE>0 & find("CONTROLE",GENTSTD(1..GNBENTREE))
 GCALL_PT=1
Endif

Call PARAM("","CNSTYPCUR",OPT) From ADOVAL
COURTYP = val(OPT) : OPT=""
Gosub DEFCRIT
If [M:NAT1]CPTANA<>"" | [M:NAT1]COLLEC<>"" | [M:NAT1]GROUPE<>""
 Gosub SET_ECRAN
Endif
Return

$SET_ECRAN
If CECRAN<>""
 Return
Elsif [M:NAT1]COA<>"" & [M:NAT1]CPTANA<>""
 Read [GAC]GAC0 = [M:NAT1]COA;[M:NAT1]CPTANA
Elsif [M:NAT1]COA<>"" & [M:NAT1]COLLEC<>""
 Read [GAC]GAC1 = [M:NAT1]COA;[M:NAT1]COLLEC
Elsif [M:NAT1]GROUPE<>""
 Read [GSC]GSC0 = [M:NAT1]COA;[M:NAT1]GROUPE;1
Else
 Return
Endif
OK = 0
For I=len([F:GAC]ACC) To 1 Step -1
 Read [GT2]GT20 = [M:NAT1]COA;left$([F:GAC]ACC,I)
 If !fstat
  If [F:GT2]SCECODANA<>"" & [F:GT2]SCECODANA<>OLDCPTDEF
   [M:CNAT]ECRAN = [F:GT2]SCECODANA
   OLDCPTDEF = [F:GT2]SCECODANA
  Endif
  OK = 1
  Break
 Endif
Next I
If !OK
 If OLDCPTDEF<>""
  [M:CNAT]ECRAN = ""
  OLDCPTDEF = ""
 Endif
Endif
Return


$DEFCRIT
# ParamŤtres
# Il faut faire attention ŗ ce que les paramŤtres restent cohťrents entre eux
If [M:NAT1]FCY<>"" & GUSRFCY(1)<>"\" & !find([M:NAT1]FCY,GUSRFCY(1..GNBAUZ))
 [M:NAT1]FCY=""
Endif
DDEB=[M:NAT1]DATDEB
DFIN=[M:NAT1]DATFIN

For I=1 To dim(PARAM)
 Case I
  When 1 : # Sociťtť
   If PARAM(I)<>""
    Call LECTURE("CPY",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:NAT1]CPY = PARAM(I)
     If [M:NAT1]FCY<>""
      Call LECTURE("FCY",[M:NAT1]FCY,"") From CONTOBJ
      If [F:FCY]LEGCPY<>[M:NAT1]CPY : [M:NAT1]FCY="" : Endif
     Endif
    Endif
   Endif
  When 2 : # Site
   If PARAM(I)<>""
    Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
    If !fstat & (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
     [M:NAT1]FCY = PARAM(I)
     [M:NAT1]CPY = [F:FCY]LEGCPY
     PARAM(1)=""
    Endif
   Endif
  When 3 : # Type de rťfťrentiel
   If val(PARAM(I))<>0
    If dim([M:NAT1]CPY)>0 & [M:NAT1]CPY<>""
     Call LECTURE("CPY",[M:NAT1]CPY,"") From CONTOBJ
     If [F:CPY]CPYLEGFLG<>2
      Read [FGR]FGR0(1) = [M:NAT1]CPY
      Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
      Call LECTURE("CPY",[F:FCY]LEGCPY,"") From CONTOBJ
     Endif
     Call LECTURE("GCM",[F:CPY]ACM,"")  From CONTOBJ
     If [F:GCM]LED(val(PARAM(I))-1)<>""
      Call LECTURE ("LED",[F:GCM]LED(val(PARAM(I))-1),"") From CONTOBJ
      [M:NAT1]LEDTYP = val(PARAM(I))
      [M:NAT1]CURLED = [F:GCM]CUR(val(PARAM(I))-1)
      [M:NAT1]COA    = [F:LED]COA
     Endif
    Endif
   Else
    Call SETMAINREF([M:NAT1]CPY,GTYPGEN,GTYPANA) From CPTDIV
    [M:NAT1]LEDTYP = GTYPANA
    Call LECPLAN([M:NAT1]CPY,GTYPANA,[M:NAT1]COA) From CPTDIV
   Endif
   If [M:NAT1]LEDTYP = 0 :  [M:NAT1]LEDTYP = 2 : Endif
  When 4 : # Nature=>150=>Compte analytique
   If PARAM(I)<>""
    Call LECTURE("GAC",PARAM(I),[M:NAT1]COA) From CONTOBJ
    If !fstat : [M:NAT1]CPTANA = PARAM(I) : Endif
   Endif
  When 5 : # Tiers
   If PARAM(I)<>""
    Call LECTURE("BPR",PARAM(I),"") From CONTOBJ
    If !fstat :  [M:NAT1]TIERS = PARAM(I) : [M:NAT1]CPTANA="" :  Endif
   Endif
  When 6 : # Collectif
   If PARAM(I)<>""
    Read [GAC]GAC1 = [M:NAT1]COA;PARAM(I)
    If !fstat & [F:GAC]SAC=2 : [M:NAT1]COLLEC = PARAM(I) : [M:NAT1]CPTANA="" : Endif
   Endif
  When 7 : # Date dťbut
   Gosub DATUS From CNSCPTSTD
   If PARAM(I)<>"" & PARAM(I)<>NULDAT & PARAM(I)<>"000000"
    If instr(1,PARAM(I),SEPDAT)
     [M:NAT1]DATDEB = evalue("["+ctrans(PARAM(I),SEPDAT,"/")+"]")
    Elsif PARAM(I)<>""
     [M:NAT1]DATDEB = PARAM(I)
    Endif
   Endif
  When 8 : # Date fin
   Gosub DATUS From CNSCPTSTD
   If PARAM(I)<>""  & PARAM(I)<>NULDAT& PARAM(I)<>"000000"
    If instr(1,PARAM(I),SEPDAT)
     [M:NAT1]DATFIN = evalue("["+ctrans(PARAM(I),SEPDAT,"/")+"]")
    Elsif PARAM(I)<>""
     [M:NAT1]DATFIN = PARAM(I)
    Endif
   Endif
  When 9 : # Devise
   If PARAM(I)<>""
    Call LECTURE("TCU",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:NAT1]CURSEL = PARAM(I)
     [M:CNAT]CURSEL = PARAM(I)
    Endif
   Endif
  When 10 : # Filtre sur GACCENTRYA [DAA]
   [M:CNAT]FILTECT(2) = PARAM(I)
  When 11 : # Option
   For J=1 To len(PARAM(I))
    OPT = mid$(PARAM(I),J,1)
    If OPT="1" or OPT="2"
     Case J
      When 1 : # A nouveau
       [M:CNAT]ANOUV = val(OPT)
      When 2 : # Cloture
       [M:CNAT]CLOTURE = val(OPT)
     Endcase
    Endif
   Next J
 Endcase
Next I
Affzo [M]

# Cas du tunnel
Default Mask [NAT1]
If [M:NAT1]CPY<>""
 Local Char CODLED(GLONLED) , DEVLED(GLONCUR)
 Local Integer STAT
 Local Char MESSA(250)
 Call CNTCOHLED([M:NAT1]CPY,[M:NAT1]LEDTYP,CODLED,DEVLED,STAT,MESSA) From CPTCNT
 If STAT=0
  Filter [FGR] Where CPY=[M:NAT1]CPY
  Read [FGR]FGR0 First
  Filter [FGR]
  Read [FCY]FCY0 = [F:FGR]FCY
  [M:NAT1]CPY = [F:FCY]LEGCPY
  [M:NAT1]FCY = [F:FCY]FCY
  MESSA += "\"+mess(63,109,1)-[F:FCY]FCY : # Consultation limitťe au site
  Call MESSAGE(MESSA) From GESECRAN
 Endif
Endif
Call C_LEDTYP([M:NAT1]LEDTYP)

# Valeurs par dťfaut
Call INIT(DDEB,DFIN) From CONSSUB

If [M:CNAT]ANOUV   =0 : [M:CNAT]ANOUV   = 2 : Endif
If [M:CNAT]CLOTURE =0 : [M:CNAT]CLOTURE = 2 : Endif
If [M:CNAT]SIMUL   =0 : [M:CNAT]SIMUL   = 2 : Endif
If [M:CNAT]TRI     =0 : [M:CNAT]TRI     = 1 : Endif

Gosub CRITENT From =PROGCNS
Affzo [M:NAT1]
Return

$LECTURE
If [M:NAT1]CPTANA<>""
 Read [GAC]GAC0 = [M:NAT1]COA;[M:NAT1]CPTANA
 If !fstat
  Call LECTEXTRA([M:NAT1]LIBCPTANA,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 Else
  NBLU=0
 Endif
Else
 [M:NAT1]LIBCPTANA = "" #: NBLU=0
Endif

If [M:NAT1]CPY="" or [M:NAT1]DATDEB=[0/0/0] or [M:NAT1]DATFIN=[0/0/0]
 NBLU=0 : Return
Endif

# Changement d'ťcran ?
Gosub SET_ECRAN
Gosub CHANGE_MSK From GCONSULT

XDEV = 0
Gosub INIT
If GRP & !COHGRP & CHGPAG=1
 Call MESSAGE(mess(64,109,1)) From GESECRAN : # Les exercices de ce groupe sont dťcalťs, pas de soldes
Endif

FLGCLO = ([F:LED]ENDVCR=2)

If !GRP
 [M:NAT1]DEVISE = DEVLED
Else
 [M:NAT1]DEVISE = TDEVLED(1)
 If [M:NAT1]DEVISE=""
  [M:NAT1]DEVISE = [M:NAT1]CURLED
 Else
  For I=2 To NBSITE
   If TDEVLED(1)<>TDEVLED(I) : [M:NAT1]DEVISE = [M:NAT1]CURLED : XDEV=1 : Break : Endif
  Next I
 Endif
Endif
[M:NAT1]SYSCUR = [M:NAT1]CURLED

Raz [M:NAT1]CURSEL
[M:NAT1]CURSEL = [M:CNAT]CURSEL

Gosub FILTRE

Case [M:CNAT]TRI
 When 1
  EXPCLE = "ACCDAT"
 When 2
  EXPCLE = "TYP;NUM"
 When 3
  EXPCLE=""
  Local Char     LSTAXEANA(GLONDIE)(1..dim([F:DAA]DIE))
  Local Integer  NBRAXEANA, N_AXE : NBRAXEANA=0 : NUMAXE=0
  If [M:CNAT]TRIANA<>""
   Call PARSE_TRIANA([M:CNAT]TRIANA,LSTAXEANA,NBRAXEANA)
   For I=1 To NBRAXEANA
    Call GETNUMAXE([M:NAT1]CPY,[M:NAT1]LEDTYP,LSTAXEANA(I),N_AXE) From CPTDIV
    If N_AXE<>0
     If EXPCLE<>"" : EXPCLE +=";" : Endif
     EXPCLE +="CCE("+num$(N_AXE-1)+")"
    Endif
   Next I
  Endif
Endcase

If EXPCLE<>"" : EXPCLE+=";" : Endif
EXPCLE += "ACCNUM;ANALIN"
If CHGPAG<0
 I = 1
 Repeat
  J = instr(I,EXPCLE,";")
  If J
   EXPCLE = left$(EXPCLE,J-1)+" Desc"+right$(EXPCLE,J)
   I = J+6
  Endif
 Until !J
 EXPCLE +=" Desc"
Endif

If PROGSPE<>""
 ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

Link [DAA] With [DAE]DAE0=[F:DAA]TYP;[F:DAA]NUM;[F:DAA]LIN;[F:DAA]LEDTYP, [HAE]HAE0=[F:DAA]TYP;[F:DAA]NUM
&    As [LNK2]
&    Where [F:DAA]COA=[M:NAT1]COA & [F:DAA]LEDTYP=[M:NAT1]LEDTYP
&        & evalue(FILLIG)
&        & evalue(FILTET)
&        & evalue(FILNAT)
&    Order With EXPCLE

#&        & evalue(FILTLCT)

If CHGPAG>0
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:NAT2] : Endif

PLEIN=0 : OK=0 : FLTRI=0

If NATCUR=[M:NAT1]CPTANA
 Case CHGPAG
  When 3 : # Rafraichissement
   Case [M:CNAT]TRI
    When 1 : # Date comptable
     For [LNK2] Where Key >= DEBDAT;DEBNUM;DEBLIG
      Gosub REMPLIT : If PLEIN : Break : Endif
     Next
    When 2 : # PiŤce comptable
     For [LNK2] Where Key >= DEBTYP;DEBHAE;DEBNUM;DEBLIG
      Gosub REMPLIT : If PLEIN : Break : Endif
     Next
    When 3 : # Analytique
     For I=1 To NBRAXEANA
      Call GETNUMAXE([M:NAT1]CPY,[M:NAT1]LEDTYP,LSTAXEANA(I),N_AXE) From CPTDIV
      If N_AXE<>0
       VALCCE(I) = DEBCCE(N_AXE)
      Endif
     Next
     Case NBRAXEANA
      When 1
       For [LNK2] Where Key >= VALCCE(1);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 2
       For [LNK2] Where Key >= VALCCE(1);VALCCE(2);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 3
       For [LNK2] Where Key >= VALCCE(1);VALCCE(2);VALCCE(3);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 4
       For [LNK2] Where Key >= VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 5
       For [LNK2] Where Key >= VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 6
       For [LNK2] Where Key >= VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 7
       For [LNK2] Where Key >= VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 8
       For [LNK2] Where Key >= VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);VALCCE(8);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 9
       For [LNK2] Where Key >= VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);VALCCE(8);VALCCE(9);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
     Endcase
   Endcase
   OK=1
  When 2 : # Suite
   Case [M:CNAT]TRI
    When 1 : #  # Date comptable
     For [LNK2] Where Key > FINDAT;FINNUM;FINLIG
      Gosub REMPLIT : If PLEIN : Break : Endif
     Next
    When 2 : # PiŤce comptable
     For [LNK2] Where Key > FINTYP;FINHAE;FINNUM;FINLIG
      Gosub REMPLIT : If PLEIN : Break : Endif
     Next
    When 3 : # Analytique
     For I=1 To NBRAXEANA
      Call GETNUMAXE([M:NAT1]CPY,[M:NAT1]LEDTYP,LSTAXEANA(I),N_AXE) From CPTDIV
      If N_AXE<>0
       VALCCE(I) = FINCCE(N_AXE)
      Endif
     Next
     Case NBRAXEANA
      When 1
       For [LNK2] Where Key > VALCCE(1);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 2
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 3
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 4
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 5
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 6
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 7
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 8
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);VALCCE(8);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 9
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);VALCCE(8);VALCCE(9);FINNUM;FINLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
     Endcase
   Endcase
   OK=1
  When -2 : # Retour
   Case [M:CNAT]TRI
    When 1 : #  # Date comptable
     For [LNK2] Where Key > DEBDAT;DEBNUM;DEBLIG
      Gosub REMPLIT : If PLEIN : Break : Endif
     Next
    When 2 : # PiŤce comptable
     For [LNK2] Where Key > DEBTYP;DEBHAE;DEBNUM;DEBLIG
      Gosub REMPLIT : If PLEIN : Break : Endif
     Next
    When 3 : # Analytique
     For I=1 To NBRAXEANA
      Call GETNUMAXE([M:NAT1]CPY,[M:NAT1]LEDTYP,LSTAXEANA(I),N_AXE) From CPTDIV
      If N_AXE<>0
       VALCCE(I) = DEBCCE(N_AXE)
      Endif
     Next
     Case NBRAXEANA
      When 1
       For [LNK2] Where Key > VALCCE(1);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 2
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 3
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 4
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 5
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 6
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 7
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 8
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);VALCCE(8);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
      When 9
       For [LNK2] Where Key > VALCCE(1);VALCCE(2);VALCCE(3);VALCCE(4);VALCCE(5);VALCCE(6);VALCCE(7);VALCCE(8);VALCCE(9);DEBNUM;DEBLIG
        Gosub REMPLIT : If PLEIN : Break : Endif
       Next
     Endcase
   Endcase
   OK=1
 Endcase
Endif


$BOUCLE
If !OK
 For [LNK2]
  Gosub REMPLIT : If PLEIN | FLTRI=2 : Break : Endif
 Next
Endif
# Changement d'ordre de tri
If TRICUR<>num$([M:CNAT]TRI)+[M:CNAT]TRIANA
 If CHGPAG=3 & !FLTRI
  FLTRI=1 : RETOUR=1 : OK=0 : Goto BOUCLE
 Endif
  TRICUR=num$([M:CNAT]TRI)+[M:CNAT]TRIANA
Endif

Raz [M:NAT1]SOLDE, [M:NAT1]LIBSOL
If dim([M:SOL2]DAT)>0 : Raz [M:SOL2] : Endif

If COHGRP

 Local Char DEVAFF,DEVLED
 DEVLED=[M:NAT1]CURLED

# Calculation of balance in the header
# Issue X3-116770
# Issue X3-146607 If [V]GCNSEXPORTXLS=[V]CST_ANO
If [V]GCNSEXPORTXLS <> [V]CST_AYES
 If !GRP
  Call SOLDAT([M:NAT1]GROUPE,[M:NAT1]COLLEC,[M:NAT1]CPTANA,[M:NAT1]TIERS,[M:NAT1]CPY,[M:NAT1]FCY,[M:NAT1]LEDTYP,[M:NAT1]CURSEL,COURTYP,[M:NAT1]DATFIN,[M:NAT1]SOLDE)
 Else
  Call SOLDAT2([M:NAT1]GROUPE,[M:NAT1]COLLEC,[M:NAT1]CPTANA,[M:NAT1]TIERS,NBSITE,TSITE,[M:NAT1]LEDTYP,[M:NAT1]CURSEL,COURTYP,[M:NAT1]DATFIN,[M:NAT1]SOLDE)
 Endif
Endif

 If [M:NAT1]CURSEL=""
  [M:NAT1]DEVISE=DEVLED
 Else
  [M:NAT1]DEVISE=[M:NAT1]CURSEL
 Endif

 Call LEC_TCU([M:NAT1]DEVISE) From CPTLEC
 If [M:NAT1]SOLDE=0
  [M:NAT1]LIBSOL = "N"+right$(format$("N3:"+[F:TCU]CURFMT1,[M:NAT1]SOLDE),2)
 Elsif [M:NAT1]SOLDE>0
  [M:NAT1]LIBSOL = "D"+right$(format$("N3:"+[F:TCU]CURFMT1,[M:NAT1]SOLDE),2)
 Else
  [M:NAT1]SOLDE  = -[M:NAT1]SOLDE
  [M:NAT1]LIBSOL = "C"+right$(format$("N3:"+[F:TCU]CURFMT1,[M:NAT1]SOLDE),2)
 Endif

 NATCUR    = [M:NAT1]CPTANA
 TRSCUR    = [M:NAT1]TIERS
 COLCUR    = [M:NAT1]COLLEC
 GRPCUR    = [M:NAT1]GROUPE
 CPYCUR    = [M:NAT1]CPY
 FCYCUR    = [M:NAT1]FCY
 DDCUR     = [M:NAT1]DATDEB
 DFCUR     = [M:NAT1]DATFIN
 LEDTYPCUR = [M:NAT1]LEDTYP
 DEVSELCUR = [M:NAT1]CURSEL
 COACUR    = [M:NAT1]COA

# # Filled in the 2nd tab
 # Issue X3-116770 - 2019-03-08 by BEFOU : Perf add [V]GCNSEXPORTXLS=[V]CST_ANO
 # Issue X3-146607 If (CHGPAG=1 or CHGPAG=3) & dim([M:SOL2]DAT)>0 & [V]GCNSEXPORTXLS=[V]CST_ANO
 If (CHGPAG=1 or CHGPAG=3) & dim([M:SOL2]DAT)>0 & [V]GCNSEXPORTXLS<>[V]CST_AYES
  Raz [M:SOL2]
  Call LEC_CPY(CPYCUR) From CPTLEC
  If [F:CPY]CPYLEGFLG<>1
   Call GETPERSOC(CPYCUR,LEDTYPCUR,DDCUR,EXERCICE,PERIODE) From CPTSUB
   EDEB = EXERCICE
   Call GETPERSOC(CPYCUR,LEDTYPCUR,DFCUR,EXERCICE,PERIODE) From CPTSUB
   EFIN = EXERCICE
   Call SOLDNAT(LEDTYPCUR,COACUR,GRPCUR,COLCUR,NATCUR,TRSCUR,CPYCUR,FCYCUR,DEVLED,DEVSELCUR,EDEB,EFIN,GERR) From SOLDNAT
  Else
   ###############################################################################
   #  + Bug sur les pťriodes incompatibles
   ######################################################################################
   #  Call CONTEXE(CPYCUR,LEDTYPCUR,DDCUR,DFCUR,OK) From CONSSUB
   #  If !OK
   #   # Pťriodes incompatibles pour la sociťtť
   #   GERR=1 : GMESSAGE = mess(11,101,1)-[M:NAT1]CPY
   #  Elsif [M:NAT1]CURSEL="" & XDEV
   If [M:NAT1]CURSEL="" & XDEV
    # Devises hťtťrogŤnes pour ce regroupement
    GERR=1 : GMESSAGE = mess(54,109,1)-[M:NAT1]CPY
   Else
    NBSITE = 0
    For [FGR]FGR0 Where CPY = CPYCUR
      Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
     If [F:FCY]FINFLG=2
      Filter [FIY] Where CPY=[F:FCY]LEGCPY & LEDTYP=LEDTYPCUR
      Read [FIY]FIY0 First
      If [M:NAT1]DATDEB>=[F:FIY]FIYSTR : DDEB = [M:NAT1]DATDEB : Else : DDEB = [F:FIY]FIYSTR : Endif
      Read [FIY]FIY0 Last
      If [M:NAT1]DATFIN<=[F:FIY]FIYEND : DFIN = [M:NAT1]DATFIN : Else : DFIN = [F:FIY]FIYEND : Endif
      Filter [FIY]
      If DDEB<=DFIN
       NBSITE += 1
       TSITE(NBSITE) = [F:FGR]FCY
      Endif
     Endif
    Next : # [FGR]
    DEVISE = [M:NAT1]CURLED
    Call SOLDNAT2(LEDTYPCUR,COACUR,GRPCUR,COLCUR,NATCUR,TRSCUR,NBSITE,TSITE,DEVLED,DEVSELCUR,[M:NAT1]DATDEB,[M:NAT1]DATFIN,GERR) From SOLDNAT
   Endif
  Endif
  # Remplissage du 2Ťme bloc : si total des consultations est sous forme d'onglet.
  If func AFNC.ACTIV("CNT")
   Gosub SOLDPCE
  Endif
 Endif

Elsif (CHGPAG=1 or CHGPAG=3)
  If dim([M:SOL2]DAT)>0 : Effzo [SOL2] : Endif
Endif : # COHGRP
Return

$REMPLIT
OK = 1
If GRP
 ISITE = find([F:DAA]FCYLIN,TSITE(1..NBSITE))
 #DEVSOC = TDEVSOC(ISITE)
 DEVLED = TDEVLED(ISITE)
 EDEB   = TEDEB(ISITE)
 EFIN   = TEFIN(ISITE)
 PFIN   = TPFIN(ISITE)
Endif
# 72673/72606 -------------Pour filtre sans piŤce de clŰture------------
FILTCLO = num$([F:HAE]FIY)+">="+num$(EDEB)-"&"-num$([F:HAE]FIY)+"<="+num$(EFIN)
If GRP
 #--------------------------
 #FILTCLO = "([F:HAE]FIY="+num$(EFIN)-"| [F:HAE]FIY="+num$(EDEB)+") & [F:HAE]PER>"+num$(PFIN)
 If EFIN>EDEB & [M:CNAT]CLOTURE<>2
 Local Integer CF,LF,LP :# CurrentFiscalyear / LastFiscalyear / LastPeriod
 Local Date SDF, EDF    :# StartDateFiscalyear / EndDateFiscalyear
   NBFIY=EFIN-EDEB+1
   Local Integer FIYLST(1..NBFIY),FIYPEND(1..NBFIY)
   CF=max(1,EDEB)
   For I=1 To NBFIY
    FIYLST(I)=CF
    Call DATFIY(TSOC(ISITE),[F:DAE]LEDTYP,CF,SDF,EDF) From CPTSUB
    Call GETPERIOD(TSOC(ISITE),[F:DAE]LEDTYP,EDF,LF,LP) From CPTSUB
    FIYPEND(I)=LP
    CF+=1
   Next
 Endif
Endif
If EFIN>EDEB & find([F:HAE]FIY,FIYLST(1..NBFIY))  : #Quand on rentre dans la fonction on peut tomber en erreur
 FILTCLO -= "&"-num$([F:HAE]PER)+">"+num$(FIYPEND(find([F:HAE]FIY,FIYLST(1..NBFIY))))
Elsif EFIN=EDEB
 FILTCLO -= "&"-num$([F:HAE]PER)+">"+num$(PFIN)
Endif

# 72673/72606
#If [M:CNAT]CLOTURE<>2 & ([F:DAE]FIY=EFIN |[F:DAE]FIY=EDEB) & [F:DAE]PER>PFIN
If [M:CNAT]CLOTURE<>2 & evalue(FILTCLO)
 OK=0
Else
 If FLGCLO=0 : # ClŰture italienne
  If [F:DAE]PER=0 & ([M:CNAT]ANOUV<>2 | [F:DAE]FIY<>EDEB) : OK=0 : Endif
 Else
  If [F:DAE]PER=0 & [M:CNAT]ANOUV<>2 : OK=0 : Endif
 Endif
Endif

If [M:CNAT]FILTECT(0)<>"" & OK : OK *= evalue([M:CNAT]FILTECT(0)) : Endif
If [M:CNAT]FILTECT(1)<>"" & OK : OK *= evalue([M:CNAT]FILTECT(1)) : Endif
If [M:CNAT]FILTECT(2)<>"" & OK : OK *= evalue([M:CNAT]FILTECT(2)) : Endif
If OK : GPOINT = "CONTROLE" : Gosub ENTREE From EXEFNC : Endif
If OK
 If FLTRI
  If [F:DAA]ACCNUM<>DEBNUM | [F:DAA]ANALIN<>DEBLIG : RETOUR=2 : Endif
  FLTRI=2 : Return
 Endif

 If NBLU=1
  If CHGPAG=2 or CHGPAG=-2 : Raz [M:NAT2] : Endif
  NBLU=2
 Endif

 If CHGPAG>0
  If NOL>=MAXLIG-1 : SUITE = 2 : PLEIN = 1 : Return : Endif
  NOL += 1
  If NOL=0
   DEBNUM = [F:DAA]ACCNUM
   DEBLIG = [F:DAA]ANALIN
   DEBDAT = [F:DAA]ACCDAT
   DEBTYP = [F:HAE]TYP
   DEBHAE = [F:HAE]NUM
   For AX=1 To dim([F:DAA]DIE): DEBCCE(AX) = [F:DAA]CCE(AX-1) : Next AX
  Endif
  FINNUM = [F:DAA]ACCNUM
  FINLIG = [F:DAA]ANALIN
  FINDAT = [F:DAA]ACCDAT
  FINTYP = [F:HAE]TYP
  FINHAE = [F:HAE]NUM
  For AX=1 To dim([F:DAA]DIE): FINCCE(AX) = [F:DAA]CCE(AX-1) : Next AX
 Else
  If NOL<=0 : RETOUR = 2 : PLEIN = 1 : Return : Endif
  NOL -= 1
  If NOL=MAXLIG-1
   FINNUM = [F:DAA]ACCNUM
   FINLIG = [F:DAA]ANALIN
   FINDAT = [F:DAA]ACCDAT
   FINTYP = [F:HAE]TYP
   FINHAE = [F:HAE]NUM
   For AX=1 To dim([F:DAA]DIE): FINCCE(AX) = [F:DAA]CCE(AX-1) : Next AX
  Endif
  DEBNUM = [F:DAA]ACCNUM
  DEBLIG = [F:DAA]ANALIN
  DEBDAT = [F:DAA]ACCDAT
  DEBTYP = [F:HAE]TYP
  DEBHAE = [F:HAE]NUM
  For AX=1 To dim([F:DAA]DIE): DEBCCE(AX) = [F:DAA]CCE(AX-1) : Next AX
 Endif

 nolign = NOL+1
 [M:NAT2] = [F:HAE]
 [M:NAT2] = [F:DAE]
 [M:NAT2] = [F:DAA]

# Issue X3-76126 **** go back with the JIRA #*X3-98590
##*X3-98590 Strangly, the first transclass [F:HAE] erases [M:NAT2]CURLED-1, it may be an X3 bug
##*X3-98590 CURLED of HAE is dimensionned (only the first element contains a value, the others are blank)
##*X3-98590 Local Integer I_L
##*X3-98590 L_CUR(NOL) = [M:NAT2]CURLED(NOL)
##*X3-98590 For I_L = 0 To NOL
##*X3-98590  [M:NAT2]CURLED(I_L) = L_CUR(I_L)
##*X3-98590 Next I_L
#*X3-98590# # End issue X3-76126

 For AX=1 To dim([F:DAA]DIE)
  Assign "[M:NAT2]CCE"+num$(AX)+"("+num$(NOL)+")" With [F:DAA]CCE(AX-1)
 Next AX

 [M:NAT2]CURCPY(NOL)      = DEVLED

 [M:NAT2]MLTRAT(NOL)     = [F:HAE]RATMLT([F:DAA]LEDTYP-1)
 [M:NAT2]DIVRAT(NOL)     = [F:HAE]RATDIV([F:DAA]LEDTYP-1)
 [M:NAT2]FNLPSTNUMW(NOL) = [F:HAE]FNLPSTNUM([F:DAA]LEDTYP-1)
 [M:NAT2]CREUSR(NOL)     = [F:HAE]CREUSR
 [M:NAT2]UPDUSR(NOL)     = [F:HAE]UPDUSR

 If [F:DAE]SNS=1
  [M:NAT2]DEBIT (NOL)  = [F:DAA]AMTCUR
  [M:NAT2]DEBLED(NOL)  = [F:DAA]AMTLED
 Else
  [M:NAT2]CREDIT(NOL)  = [F:DAA]AMTCUR
  [M:NAT2]CDTLED(NOL)  = [F:DAA]AMTLED
 Endif
Endif

Return

$SOLDPCE
OKCRS=0
For [LNK2] Nohint
 OK = 1
 If GRP
  ISITE = find([F:DAA]FCYLIN,TSITE(1..NBSITE))
  DEVLED = TDEVLED(ISITE)
  EDEB   = TEDEB(ISITE)
  EFIN   = TEFIN(ISITE)
  PFIN   = TPFIN(ISITE)
 Endif
 # 72673/72606 -------------Pour filtre sans piŤce de clŰture------------
 FILTCLO = num$([F:HAE]FIY)+">="+num$(EDEB)-"&"-num$([F:HAE]FIY)+"<="+num$(EFIN)
 If GRP
  #--------------------------
  #FILTCLO = "([F:HAE]FIY="+num$(EFIN)-"| [F:HAE]FIY="+num$(EDEB)+") & [F:HAE]PER>"+num$(PFIN)
  If EFIN>EDEB & [M:CNAT]CLOTURE<>2
   Local Integer CF,LF,LP :# CurrentFiscalyear / LastFiscalyear / LastPeriod
   Local Date SDF, EDF    :# StartDateFiscalyear / EndDateFiscalyear
   NBFIY=EFIN-EDEB+1
   Local Integer FIYLST(1..NBFIY),FIYPEND(1..NBFIY)
   CF=max(1,EDEB)
   For I=1 To NBFIY
    FIYLST(I)=CF
    Call DATFIY(TSOC(ISITE),[F:DAE]LEDTYP,CF,SDF,EDF) From CPTSUB
    Call GETPERIOD(TSOC(ISITE),[F:DAE]LEDTYP,EDF,LF,LP) From CPTSUB
    FIYPEND(I)=LP
    CF+=1
   Next
  Endif
 Endif
 If EFIN>EDEB & find([F:HAE]FIY,FIYLST(1..NBFIY))  : #Quand on rentre dans la fonction on peut tomber en erreur
  FILTCLO -= "&"-num$([F:HAE]PER)+">"+num$(FIYPEND(find([F:HAE]FIY,FIYLST(1..NBFIY))))
 Elsif EFIN=EDEB
  FILTCLO -= "&"-num$([F:HAE]PER)+">"+num$(PFIN)
 Endif

 # 72673/72606
 #If [M:CNAT]CLOTURE<>2 & ([F:DAE]FIY=EFIN |[F:DAE]FIY=EDEB) & [F:DAE]PER>PFIN
 If [M:CNAT]CLOTURE<>2 & evalue(FILTCLO)
  OK=0
 Else
  If FLGCLO=0 : # ClŰture italienne
   If [F:DAE]PER=0 & ([M:CNAT]ANOUV<>2 | [F:DAE]FIY<>EDEB) : OK=0 : Endif
  Else
   If [F:DAE]PER=0 & [M:CNAT]ANOUV<>2 : OK=0 : Endif
  Endif
 Endif

 If [M:CNAT]FILTECT(0)<>"" & OK : OK *= evalue([M:CNAT]FILTECT(0)) : Endif
 If [M:CNAT]FILTECT(1)<>"" & OK : OK *= evalue([M:CNAT]FILTECT(1)) : Endif
 If [M:CNAT]FILTECT(2)<>"" & OK : OK *= evalue([M:CNAT]FILTECT(2)) : Endif

 If GCALL_PT & OK : GPOINT = "CONTROLE" : Gosub ENTREE From EXEFNC : Endif
 If OK
  If [F:DAA]SNS=1
   [M:SOL2]DEBLOC  += [F:DAA]AMTLED
   If [M:NAT1]CURSEL<>""
    [M:SOL2]DEBCUR  += [F:DAA]AMTCUR
   Endif
  Else
   [M:SOL2]CRELOC  += [F:DAA]AMTLED
   If [M:NAT1]CURSEL<>""
    [M:SOL2]CRECUR  += [F:DAA]AMTCUR
   Endif
  Endif
 Endif
Next

[M:SOL2]DEVLOC  = [M:NAT1]CURLED
[M:SOL2]DEVLOC2 = [M:NAT1]CURLED
[M:SOL2]SNSSOL  = ""
[M:SOL2]DEVCUR  = [M:NAT1]CURSEL
[M:SOL2]DEVCUR2 = [M:NAT1]CURSEL
[M:SOL2]SNSSOL2 = ""

If [M:SOL2]DEBLOC>[M:SOL2]CRELOC
 [M:SOL2]SOLLOC = [M:SOL2]DEBLOC-[M:SOL2]CRELOC
 If [M:SOL2]SOLLOC<>0
  [M:SOL2]SNSSOL   = mess(1,610,1) : # "D"
 Endif
 If [M:NAT1]CURSEL<>""
  [M:SOL2]SOLCUR = [M:SOL2]DEBCUR-[M:SOL2]CRECUR
  If [M:SOL2]SOLCUR<>0
   [M:SOL2]SNSSOL2 = mess(1,610,1) : # "D"
  Endif
 Endif
Else
 [M:SOL2]SOLLOC = [M:SOL2]CRELOC-[M:SOL2]DEBLOC
 If [M:SOL2]SOLLOC<>0
  [M:SOL2]SNSSOL   = mess(2,610,1) : # "C"
 Endif
 If [M:NAT1]CURSEL<>""
  [M:SOL2]SOLCUR = [M:SOL2]CRECUR-[M:SOL2]DEBCUR
  If [M:SOL2]SOLCUR<>0
   [M:SOL2]SNSSOL2 = mess(2,610,1) : # "C"
  Endif
 Endif
Endif
Affzo [SOL2]
Return

$INIT
Call LECTURE("CPY",[M:NAT1]CPY,"") From CONTOBJ
GRP=([F:CPY]CPYLEGFLG=1)
If !GRP
 DEVLED = [M:NAT1]CURLED
 Call GETPERSOC([M:NAT1]CPY,[M:NAT1]LEDTYP,[M:NAT1]DATDEB,EXERCICE,PERIODE) From CPTSUB
 EDEB = EXERCICE
 Call GETPERSOC([M:NAT1]CPY,[M:NAT1]LEDTYP,[M:NAT1]DATFIN,EXERCICE,PERIODE) From CPTSUB
 PFIN = PERIODE
 EFIN = EXERCICE
 COHGRP = 1
 #---------------------------------------------
 # 72673/72606 - Consultation sur plusieur exercice sans ecriture de cloture
 If EFIN>EDEB
  Local Integer CF,LF,LP :# CurrentFiscalyear / LastFiscalyear / LastPeriod
  Local Date SDF, EDF    :# StartDateFiscalyear / EndDateFiscalyear
  NBFIY=EFIN-EDEB+1
  Local Integer FIYLST(1..NBFIY),FIYPEND(1..NBFIY)
  CF=max(1,EDEB)
  For I=1 To NBFIY
   FIYLST(I)=CF
   Call DATFIY([M:NAT1]CPY,[M:NAT1]LEDTYP,CF,SDF,EDF) From CPTSUB
   Call GETPERIOD([M:NAT1]CPY,[M:NAT1]LEDTYP,EDF,LF,LP) From CPTSUB
   FIYPEND(I)=LP
   CF+=1
  Next
 Endif
 #---------------------------------------------
Else
 NBSITE = 0
 COHGRP = 1
 For [FGR]FGR0 Where CPY = [M:NAT1]CPY
  Call LECTURE("FCY",[F:FGR]FCY,"") From CONTOBJ
  If [F:FCY]FINFLG=2
   Filter [FIY] Where CPY=[F:FCY]LEGCPY & LEDTYP=[M:NAT1]LEDTYP
   Read [FIY]FIY0 First
   If [M:CNAT]DATDEB>=[F:FIY]FIYSTR : DDEB=[M:NAT1]DATDEB : Else DDEB=[F:FIY]FIYSTR : Endif
   Read [FIY]FIY0 Last
   If [M:CNAT]DATFIN<=[F:FIY]FIYEND : DFIN=[M:NAT1]DATFIN : Else DFIN=[F:FIY]FIYEND : Endif
   Filter [FIY]
   If DDEB<=DFIN
    NBSITE+=1
    TSITE(NBSITE) = [F:FGR]FCY
    # 72673/72606 - Consultation sur plusieur exercice sans ecriture de cloture
    TSOC(NBSITE) = [F:FCY]LEGCPY
    #--
    Call GETPERSOC([F:FCY]LEGCPY,[M:NAT1]LEDTYP,DDEB,EXERCICE,PERIODE) From CPTSUB
    TEDEB(NBSITE) = EXERCICE
    Call GETPERSOC([F:FCY]LEGCPY,[M:NAT1]LEDTYP,DFIN,EXERCICE,PERIODE) From CPTSUB
    TEFIN(NBSITE) = EXERCICE
    TPFIN(NBSITE) = PERIODE
    TDEVLED(NBSITE) = [M:NAT1]CURLED
    Read [FIY]FIY0 = [F:FCY]LEGCPY;[M:NAT1]LEDTYP;EXERCICE
    If NBSITE=1
     DEBEX = [F:FIY]FIYSTR
    Elsif DEBEX<>[F:FIY]FIYSTR
     COHGRP = 0
    Endif
   Endif
  Endif
 Next
Endif
Return

$AV_MAGNETO
If [M:NAT1]COLLEC<>"" or [M:NAT1]GROUPE<>"" or [M:NAT1]TIERS<>""
 FILTRE=""
 If [M:NAT1]COLLEC<>""
  Read [GAC]GAC1 = [M:NAT1]COA;[M:NAT1]COLLEC
  If !fstat
   For I=0 To len(mess(0,277,1))-1
    If [F:GAC]AUZBPR(I)=2
     Case I+1
      When 1 :# Client
       FILTRE="BPCFLG=2"
      When 2 :# Fournisseur
       If FILTRE="" : FILTRE="BPSFLG=2" : Else : FILTRE-="| BPSFLG=2" : Endif
      When 3 :# Transporteur
       If FILTRE="" : FILTRE="BPTFLG=2" : Else : FILTRE-="| BPTFLG=2" : Endif
      When 4 :# Factor
       If FILTRE="" : FILTRE="FCTFLG=2" : Else : FILTRE-="| FCTFLG=2" : Endif
      When 5 :# Reprťsentant
       If FILTRE="" : FILTRE="REPFLG=2" : Else : FILTRE-="| REPFLG=2" : Endif
      When 6 :# tiers divers
       If FILTRE="" : FILTRE="BPRACC=2" : Else : FILTRE-="| BPRACC=2" : Endif
     Endcase
    Endif
   Next
  Endif
 Elsif [M:NAT1]GROUPE<>""
  Local Integer K1,K2,K3,K4,K5,K6
  K1=0 : K2=0 : K3=0 : K4=0 : K5=0 : K6=0
  Filter [GSC] Where COA=[M:NAT1]COA & GRU=[M:NAT1]GROUPE
  For [GSC]GSC0
   Read [GAC]GAC1 = [F:GSC]COA;[F:GSC]SAC
   If !fstat
    For J=0 To len(mess(0,277,1))-1
     If [F:GAC]AUZBPR(J)=2
      Case J+1
       When 1 : K1=1
       When 2 : K2=1
       When 3 : K3=1
       When 4 : K4=1
       When 5 : K5=1
       When 6 : K6=1
      Endcase
     Endif
    Next :#J
   Endif
  Next :#GSC0
  If K1 : FILTRE="BPCFLG=2" : Endif
  If K2 : If FILTRE="" : FILTRE="BPSFLG=2" : Else : FILTRE-="| BPSFLG=2" : Endif : Endif
  If K3 : If FILTRE="" : FILTRE="BPTFLG=2" : Else : FILTRE-="| BPTFLG=2" : Endif : Endif
  If K4 : If FILTRE="" : FILTRE="FCTFLG=2" : Else : FILTRE-="| FCTFLG=2" : Endif : Endif
  If K5 : If FILTRE="" : FILTRE="REPFLG=2" : Else : FILTRE-="| REPFLG=2" : Endif : Endif
  If K6 : If FILTRE="" : FILTRE="BPRACC=2" : Else : FILTRE-="| BPRACC=2" : Endif : Endif
 Endif
 NOMFIC = "BPARTNER"
 ABFIC = "BPR"
 CLE = "BPR0"
 NBCMP = 1
 CLECMP(0) = "BPRNUM"
 CLEMSK(0) = "TIERS"
 Default File [BPR]
Else
 NOMFIC = "GACCOUNT"
 ABFIC = "GAC"
 CLE = "GAC0"
 NBCMP = 2
 CLECMP(0) = "COA"
 CLEMSK(0) = "COA"
 CLECMP(1) = "ACC"
 CLEMSK(1) = "CPTANA"
 FILTRE='SAC<>2 & COA="'+[M]COA+'" & ENAFLG=2'
Endif
Return

$AP_MAGNETO
FILTRE=""
Return

$SET_DERLU
If NOMFIC="BPARTNER"
 NOMFIC = "GACCOUNT"
 ABFIC = "GAC"
 CLE = "GAC0"
 NBCMP = 2
 CLECMP(0) = "COA"
 CLEMSK(0) = "COA"
 CLECMP(1) = "ACC"
 CLEMSK(1) = "CPTANA"
 FILTRE='SAC<>2 & COA="'+[M]COA+'" & ENAFLG=2'
Endif
Return

$FILTRE
If !GRP
 FILLIG = '[F:DAA]CPY="'+[M:NAT1]CPY+'"'
 If [M:CNAT]FCY<>""
  FILLIG -= '& [F:DAA]FCYLIN="'+[M:CNAT]FCY+'"'
 Endif
Else
 # Groupement de sites
 FILLIG = "find([F:DAA]FCYLIN,TSITE(1..NBSITE))"
Endif
If [M:CNAT]DATDEB<>[0/0/0]
 FILLIG -= '& [F:DAA]ACCDAT>=['+format$(GFMD,[M:CNAT]DATDEB)+']'
Endif
If [M:CNAT]DATFIN<>[0/0/0]
 FILLIG -= '& [F:DAA]ACCDAT<=['+format$(GFMD,[M:CNAT]DATFIN)+']'
Endif

#If [M:CNAT]CPTANA<>""
# FILTLCT = '[F:DAA]ACC="'+[M:CNAT]CPTANA+'"'
#Else
# FILTLCT = '1=1'
#Endif
FILTLCT = '1=1'

If [M:CNAT]SIMUL=2
 FILTET = '([F:HAE]CAT<3 | [F:HAE]CAT=4)'
Else
 FILTET = '([F:HAE]CAT=1 | [F:HAE]CAT=4)'
Endif
If [M:CNAT]CURSEL<>""
 FILTET -= '& [F:HAE]CUR="'+[M:CNAT]CURSEL+'"'
Endif

# Compte / Tiers
FILNAT = '1=1'
If [M:NAT1]CPTANA<>""
 FILNAT -= '& [F:DAA]ACC="'+[M:NAT1]CPTANA+'"'
Else
 # Collectif et groupe de collectif
 If [M:NAT1]COLLEC<>""
  Read [GAC]GAC1 = [M:NAT1]COA;[M:NAT1]COLLEC
  If !fstat
   FILNAT -= '& [F:DAA]ACC="'+[F:GAC]ACC+'"'
  Endif
 Elsif [M:NAT1]GROUPE<>""
  FILNAT -= '& find([F:DAA]ACC'
  For [GSC]GSC0 Where COA=[M:NAT1]COA & GRU=[M:NAT1]GROUPE
   Read [GAC]GAC1 = [M:NAT1]COA;[F:GSC]SAC
   If !fstat
    FILNAT -= ',"'+[F:GAC]ACC+'"'
   Endif
  Next
  FILNAT += ')'
 Else
 Endif
Endif
If [M:NAT1]TIERS<>""
 FILNAT -= '& [F:DAA]BPR="'+[M:NAT1]TIERS+'"'
Endif
Return

$SETBOUT
If [M:NAT1]CPTANA<>""
 Call CONTEXE([M:NAT1]CPY,[M:NAT1]LEDTYP,[M:NAT1]DATDEB,[M:NAT1]DATFIN,OK) From CONSSUB
Else OK=0
Endif
If !OK : Call VIREBOUT(CHAINE,"O") From GCONSULT : Endif
Return

$DEB_CRIT
Local Char FILTRE(250)(3)
FILTRE(0) = [M:CNAT]FILTECT(0)
If FILTRE(0)<>"" : [M:CNAT]CRITTET=2 : Else [M:CNAT]CRITTET=1 : Endif
FILTRE(1) = [M:CNAT]FILTECT(1)
If FILTRE(1)<>"" : [M:CNAT]CRITLIG=2 : Else [M:CNAT]CRITLIG=1 : Endif
FILTRE(2) = [M:CNAT]FILTECT(2)
If FILTRE(2)<>"" : [M:CNAT]CRITANA=2 : Else [M:CNAT]CRITANA=1 : Endif
Return

$EXEBOUT2
Case BOUT
 When "P" : # En-tÍte
  If [M:CNAT]FILTECT(0)<>"" & [M:CNAT]CRITTET<>2
   [M:CNAT]CRITTET=2 : GNBAFF=1
  Elsif [M:CNAT]FILTECT(0)="" & [M:CNAT]CRITTET=2
   [M:CNAT]CRITTET=1 : GNBAFF=1
  Endif
 When "Q" : # Ligne
  If [M:CNAT]FILTECT(1)<>"" & [M:CNAT]CRITLIG<>2
   [M:CNAT]CRITLIG=2 : GNBAFF=1
  Elsif [M:CNAT]FILTECT(1)="" & [M:CNAT]CRITLIG=2
   [M:CNAT]CRITLIG=1 : GNBAFF=1
  Endif
 When "O" : # Analytique
  If [M:CNAT]FILTECT(2)<>"" & [M:CNAT]CRITANA<>2
   [M:CNAT]CRITANA=2 : GNBAFF=1
  Elsif [M:CNAT]FILTECT(2)="" & [M:CNAT]CRITANA=2
   [M:CNAT]CRITANA=1 : GNBAFF=1
  Endif
Endcase
Return

$FIN_CRIT
Case REPONSE
 When GSTAOK, GSTARET
  If [M:CNAT]FILTECT(0)<>FILTRE(0) |
&    [M:CNAT]FILTECT(1)<>FILTRE(1) |
&    [M:CNAT]FILTECT(2)<>FILTRE(2)
   [L]CHANGE=2
  Endif
  If [M:CNAT]FILTECT(0)<>""
   Onerrgo ERR_FILTECT
   OK = evalue([M:CNAT]FILTECT(0))
   Onerrgo
  Endif
  If [M:CNAT]FILTECT(1)<>""
   Onerrgo ERR_FILTECT
   OK = evalue([M:CNAT]FILTECT(1))
   Onerrgo
  Endif
  If [M:CNAT]FILTECT(2)<>""
   Onerrgo ERR_FILTECT
   OK = evalue([M:CNAT]FILTECT(2))
   Onerrgo
  Endif
 When GSTAFIN, GSTAESC
  [M:CNAT]FILTECT(0) = FILTRE(0)
  [M:CNAT]FILTECT(1) = FILTRE(1)
  [M:CNAT]FILTECT(2) = FILTRE(2)
Endcase
Return


$ERR_FILTECT
Call ERREUR(mess(33,100,1)) From GESECRAN
[L]CHANGE=1
[M:CNAT]FILTECT(0) = FILTRE(0)
[M:CNAT]FILTECT(1) = FILTRE(1)
[M:CNAT]FILTECT(2) = FILTRE(2)
Resume



$AV_AFFICHE
#Gestion de l'affichage des colonnes lors de changement d'ťcran
Local Integer I, J
Local Char MSKCOL(17) : MSKCOL=""
Local Char VARMSK(15)(1..3) , VARABR(5)(1..3)
I = 1 : J = 1
Repeat
 If masknam( I ) <> ""
  VARMSK( J ) = masknam( I )
  VARABR( J ) = maskabr( I )
  If VARABR(J)="NAT2"
   MSKCOL="W1"+masknam(I)
  Endif
  J += 1
 Endif
 I += 1
Until I > 3
#Infbox MSKCOL+chr$(10)+VARMSK(1)+"/"+VARABR(1)+chr$(10)+VARMSK(2)+"/"+VARABR(2)+chr$(10)+VARMSK(3)+"/"+VARABR(3)
If MSKCOL<>""
 zoncou = "NBLIG"
 Gosub CHG_FMT From =MSKCOL
 Affzo [M:NAT2]
Endif
Return

#############################################################
##         Solde ŗ une date donnťe                         ##
#############################################################
#Subprog SOLDAT(NATURE,SOCIETE,SITE,LEDTYP,DEVSEL,COURS,DATSOL,SOLDE)
Subprog SOLDAT(GROUPE,COLLEC,NATURE,TIERS,SOCIETE,SITE,LEDTYP,DEVSEL,COURS,DATSOL,SOLDE)
Value    Char    GROUPE
Value    Char    COLLEC
Value    Char    NATURE
Value    Char    TIERS
Value    Integer LEDTYP
Value    Char    SOCIETE
Value    Char    SITE
Value    Char    DEVSEL
Value    Integer COURS
Value    Date    DATSOL
Variable Decimal SOLDE
Raz SOLDE
Gosub SOL_DAT
SOLDE = SOLD
End

#Subprog SOLDAT2(NATURE,NBSITE,TSITE,LEDTYP,DEVSEL,COURS,DATSOL,SOLDE)
Subprog SOLDAT2(GROUPE,COLLEC,NATURE,TIERS,NBSITE,TSITE,LEDTYP,DEVSEL,COURS,DATSOL,SOLDE)
Value    Char    GROUPE
Value    Char    COLLEC
Value    Char    NATURE
Value    Char    TIERS
Value    Integer NBSITE
Value    Char    TSITE()(1..)
Value    Char    DEVSEL
Value    Integer LEDTYP
Value    Integer COURS
Value    Date    DATSOL
Variable Decimal SOLDE
Local Char    SITE(GLONFCY), SOCIETE(GLONCPY)
Local Integer J
If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
Raz SOLDE
For J=1 To NBSITE
 SITE = TSITE(J)
 Call LEC_FCY(SITE) From CPTLEC
 SOCIETE = [F:FCY]LEGCPY
 Gosub SOL_DAT
 SOLDE += SOLD
Next
End

$SOL_DAT
Local Char BALSIT(GLONFCY) , BALCNA(GLONGAC) , BALBPR(GLONBPR)
Local Char CODLED(GLONLED), DEVLED(GLONCUR), PLAN(GLONCOA)
Local Date    DATECT
Local Integer I , FLECT , SPSTAT, GRP
Local Decimal PDEB , PFIN , PMAX , EDEB , EFIN
Local Decimal EXERCICE , PERIODE , SOLD

Raz SOLD

BALSIT = SITE

Call LEC_CPY(SOCIETE) From CPTLEC
GRP=([F:CPY]CPYLEGFLG=1)

Call LECLED(SOCIETE,LEDTYP,CODLED,DEVLED) From CPTDIV
Call LECPLAN(SOCIETE,LEDTYP,PLAN) From CPTDIV

Call GETPERSOC(SOCIETE,LEDTYP,DATSOL,EFIN,PERIODE) From CPTSUB
If DATSOL = [F:PER]PEREND
 PFIN = PERIODE : FLECT = 0
Else
 PFIN = PERIODE-1 : FLECT = 1 : DATECT = [F:PER]PERSTR
Endif

#Dmd 70766
## Exercice complŤtement Ouvert ou Fermť uniquement en compta gťnťrale
#Filter [FIY] Where CPY=SOCIETE & LEDTYP=[L]LEDTYP & (FIYSTA=2 | FIYSTA=3)
#->filtre & (FIYSTA=2 | FIYSTA=3) issu de la suggestion 15007 pour la 140 avant LEDTYP...
# Le fait de prendre l'exercice fermť empŤche la prise en compte des ŗ nouveau, car
# sur un exercice fermť puis un exercice ouvert, l'ouvert se retrouve EFIN et plus bas
# dans CUMSOLDAT on passe dans la condition EXERCICE=EFIN et donc on cumul sur periode
# 1 ŗ PFIN.

Filter [FIY] Where CPY=SOCIETE & LEDTYP=[L]LEDTYP & FIYSTA=2
Read [FIY]FIY0 First
Filter [FIY]
EDEB = [F:FIY]FIYNUM
If EFIN<EDEB : EDEB = EFIN : Endif
PMAX = dim([F:BLA]DEB)-1
If !FLECT
 Call GETEXE(SOCIETE,LEDTYP,DATSOL,EXERCICE) From CPTSUB
 If DATSOL=[F:FIY]FIYEND : PFIN=PMAX : Endif
Endif

Call LEC_COA(PLAN) From CPTLEC
For EXERCICE=EDEB To EFIN
 If TIERS<>""
  If COLLEC<>""
   Read [GAC]GAC1 = PLAN;COLLEC
   Call LEC_CLS([F:COA]LEGCLS, [F:GAC]CLSCOD) From CPTLEC
   If [F:CLS]ERA=2 or EXERCICE=EFIN
    BALCNA = [F:GAC]ACC : BALBPR = TIERS : Gosub CUMSOLDAT
   Endif
  Elsif GROUPE<>""
   For [GSC]GSC0 Where COA=PLAN & GRU=GROUPE
    Read [GAC]GAC1 = PLAN;[F:GSC]SAC
    Call LEC_CLS([F:COA]LEGCLS, [F:GAC]CLSCOD) From CPTLEC
    If [F:CLS]ERA=2 or EXERCICE=EFIN
     BALCNA = [F:GAC]ACC : BALBPR = TIERS : Gosub CUMSOLDAT
    Endif
   Next
  Else
   For [GAC]GAC1 Where COA=PLAN & ACCSHO<>""
    Call LEC_CLS([F:COA]LEGCLS, [F:GAC]CLSCOD) From CPTLEC
    If [F:CLS]ERA=2 or EXERCICE=EFIN
     BALCNA = [F:GAC]ACC : BALBPR = TIERS : Gosub CUMSOLDAT
    Endif
   Next
  Endif
 Else
  Call LEC_GAC(NATURE, PLAN) From CPTLEC
  Call LEC_CLS([F:COA]LEGCLS, [F:GAC]CLSCOD) From CPTLEC
  If [F:CLS]ERA=2 or EXERCICE=EFIN
   BALCNA = NATURE : BALBPR = "" : Gosub CUMSOLDAT
  Endif
 Endif
Next
Return

$CUMSOLDAT
If DEVSEL<>"" & !GRP
 Filter [BLA] Where LEDTYP=[L]LEDTYP & CPY=SOCIETE & FCY=BALSIT
&                  & FIY=EXERCICE & ACC=BALCNA & BPR=BALBPR
&                  & CUR=DEVSEL
Else
  Filter [BLA] Where LEDTYP=[L]LEDTYP & CPY=SOCIETE & FCY=BALSIT
&                  & FIY=EXERCICE & ACC=BALCNA & BPR=BALBPR
Endif

For [BLA]BLA0
 If EDEB=EFIN
  If PFIN>0 :
   If DEVSEL<>"" & !GRP
    SOLD += sum([F:BLA]DEB(0..PFIN))-sum([F:BLA]CDT(0..PFIN))
   Else
    SOLD += sum([F:BLA]DEBLED(0..PFIN))-sum([F:BLA]CDTLED(0..PFIN))
   Endif
  Endif
Elsif EXERCICE=EDEB
  If DEVSEL<>"" & !GRP
   SOLD += sum([F:BLA]DEB(0..PMAX))-sum([F:BLA]CDT(0..PMAX))
  Else
   SOLD += sum([F:BLA]DEBLED(0..PMAX))-sum([F:BLA]CDTLED(0..PMAX))
  Endif
 Elsif EXERCICE=EFIN
  If DEVSEL<>"" & !GRP
   SOLD += sum([F:BLA]DEB(1..PFIN))-sum([F:BLA]CDT(1..PFIN))
  Else
   SOLD += sum([F:BLA]DEBLED(1..PFIN))-sum([F:BLA]CDTLED(1..PFIN))
  Endif
 Else
  If DEVSEL<>"" & !GRP
   SOLD += sum([F:BLA]DEB(1..PMAX))-sum([F:BLA]CDT(1..PMAX))
  Else
   SOLD += sum([F:BLA]DEBLED(1..PMAX))-sum([F:BLA]CDTLED(1..PMAX))
  Endif
 Endif
Next
Filter [BLA]

If FLECT & EXERCICE=EFIN
 If DEVSEL<>"" & !GRP
  Filter [DAA] Where CPY=SOCIETE & LEDTYP=[L]LEDTYP
&                   & ACC=BALCNA & BPR=BALBPR
&                   & ACCDAT>=DATECT & ACCDAT<=DATSOL
&                   & (SITE="" | FCYLIN=SITE)
&                   & CUR=DEVSEL
 Else
  Filter [DAA] Where CPY=SOCIETE & LEDTYP=[L]LEDTYP
&                   & ACC=BALCNA & BPR=BALBPR
&                   & ACCDAT>=DATECT & ACCDAT<=DATSOL
&                   & (SITE="" | FCYLIN=SITE)
 Endif

 For [DAA]
  If DEVSEL<>"" & !GRP
   SOLD += [F:DAA]SNS*[F:DAA]AMTCUR
  Else
   SOLD += [F:DAA]SNS*[F:DAA]AMTLED
  Endif
 Next
 Filter [DAA]
Endif
Return

#############################################################
##     Etiquettes masques CONSNAT1 & CRITNAT & CONSNAT2    ##
#############################################################

## Ecrans CONSNAT1 & CRITNAT ##

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Local Char SOCIETE(GLONCPY)
Call C_CPY(VALEUR) From CONSSUB
## Si on a saisi un regroupement de sites, on contrŰle qu'on ait accŤs ŗ tous les sites du regroupement
Call LEC_CPY(VALEUR) From CPTLEC
If [F:CPY]CPYLEGFLG<>2
 Call CONTALLFCY(VALEUR) From CPTSUB : # AccŤs ŗ tous les sites de la sociťtť ?
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
Call AS_FCY(VALEUR) From CONSSUB
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CONSSUB
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Integer OPTION
OPTION=3 : #Rťfťrentiel de type de comptabilitť analytique
Call LEDTYP_CHOICE([M]CPY,OPTION) From CPTDIV
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Call C_LEDTYP(VALEUR) From CONSSUB
End


Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
Call C_DATDEB(VALEUR) From CONSSUB
End

Subprog C_DATFIN(VALEUR)
Variable Date    VALEUR
Call C_DATFIN(VALEUR) From CONSSUB
End

Subprog C_CPTANA(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Raz [M]TIERS,[M]COLLEC, [M]GROUPE
 Affzo TIERS, COLLEC, GROUPE , LIBCPTANA
 #Call CONTROLE("GAC","G",VALEUR,"",mkstat) From CONTOBJ
 Read [GAC]GAC0 = [M]COA;VALEUR
 If !fstat
  Call LECTEXTRA([M:NAT1]LIBCPTANA,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
 Endif
Else
 [M:NAT1]LIBCPTANA = ""
Endif
Affzo [M:NAT1]LIBCPTANA
End

Subprog C_COLLEC(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Raz [M]GROUPE, [M]CPTANA
 Affzo CPTANA, GROUPE
 Read [GAC]GAC1 = [M]COA;VALEUR
 If [F:GAC]ACS<>""
  Local Integer DROIT
  Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
  If !DROIT
   ## Vous n'avez pas les droits pour ce code
   GMESSAGE = mess(4,104,1)
   mkstat = 2 : End
  Endif
 Endif
Endif
End

Subprog C_GROUPE(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Raz [M]COLLEC,[M]CPTANA
 Affzo CPTANA, COLLEC
 Call LECTURE("GSC",VALEUR,"") From CONTOBJ
 For [GSC]GSC0 Where COA=[M:NAT1]COA & GRU=VALEUR
  Read [GAC]GAC1 = [M:NAT1]COA;[F:GSC]SAC
  If !fstat & [F:GAC]ACS<>""
   Local Integer DROIT
   Call CONSACC([F:GAC]ACS,DROIT) From CPTSUB
   If !DROIT
    # Vous n'avez pas les droits pour ce code
    GMESSAGE = mess(4,104,1)-" : "-[F:GSC]SAC
    mkstat = 2 : Break
   Endif
  Endif
 Next
 If mkstat : End : Endif
Endif
End

Subprog C_TIERS(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & ([M]COLLEC<>"" | [M]GROUPE<>"")
 ## Zone obligatoire
 GMESSAGE = mess(10,123,1)
 mkstat = 2 : End
Elsif VALEUR = "" & [M]CPTANA = ""
 ## Un compte ou un tiers doit Ítre renseignť
 GMESSAGE = mess(139,104,1)
 mkstat = 2 : End
Elsif VALEUR<>""
 Raz [M]CPTANA
 Affzo CPTANA
 Call CONTROLE("BPR","",VALEUR,"",mkstat) From CONTOBJ

 #Compatibilitť du tiers avec le/les collectifs
 If !clalev([F:GAC]) : Local File GACCOUNT [GAC] : Endif
 If !clalev([F:GSC]) : Local File GRPSAC   [GSC] : Endif
 Local Integer OK
 Raz OK
 If [M]COLLEC<>""
  Read [GAC]GAC1 = [M]COA;[M]COLLEC
  If !fstat
   Gosub CTRL_BPR_COLL
   If !OK
    #  Tiers incompatible avec le collectif
    GMESSAGE = mess(45,106,1)
    mkstat=2 : End
   Endif
  Endif
 Elsif [M]GROUPE<>""
  Filter [GSC] Where COA=[M]COA & GRU=[M]GROUPE
  For [GSC]GSC0
   Read [GAC]GAC1 = [M]COA;[F:GSC]SAC
   If !fstat
    Gosub CTRL_BPR_COLL
    If OK : Break : Endif
   Endif
  Next
  If !OK
   #  Tiers incompatible avec le collectif
   GMESSAGE = mess(45,106,1)-[F:GSC]SAC
   mkstat=2 : End
  Endif
  Filter [GSC]
 Endif
Endif
End

$CTRL_BPR_COLL
#ContrŰle de compatibilitť avec le tiers pour compte collectif
Call LECTURE("BPR",VALEUR,"") From CONTOBJ
OK += [F:BPR]BPCFLG=2 & [F:GAC]AUZBPR(0)=2
OK += [F:BPR]BPSFLG=2 & [F:GAC]AUZBPR(1)=2
OK += [F:BPR]BPTFLG=2 & [F:GAC]AUZBPR(2)=2
OK += [F:BPR]FCTFLG=2 & [F:GAC]AUZBPR(3)=2
OK += [F:BPR]REPFLG=2 & [F:GAC]AUZBPR(4)=2
OK += [F:BPR]BPRACC=2 & [F:GAC]AUZBPR(5)=2
Return


## Ecran CRITNAT ##

Subprog AS_TRIANA(VALEUR)
Variable Char    VALEUR()
Call AS_TRIANA(VALEUR) From CONSSUB
End

Subprog C_TRIANA(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 VALEUR=vireblc(VALEUR,2)
 Local Integer NB_AR
 Local Char LIST_AR(GLONDIE)(1..dim([M:CNAT]DIE))
 Call PARSE_TRIANA(VALEUR,LIST_AR,NB_AR)

 Local Integer NBAXE
 Local Char    LSTAXE(GLONDIE)(1..dim([F:DAA]DIE))
 Call GETLSTAXE([M:NAT1]CPY,[M:NAT1]LEDTYP,NBAXE,LSTAXE) From CPTDIV
 If !find(LIST_AR(NB_AR),LSTAXE(1..NBAXE))
   [M:CNAT]TRIANA=[M:CNAT]TRIANA : Affzo [M:CNAT]TRIANA
  # Cet axe n'est pas dťfini dans le rťfťrentiel choisi
  GMESSAGE=mess(111,104,1)
  mkstat=2
 Endif
 If NB_AR>1
  If find(LIST_AR(NB_AR),LIST_AR(1..(NB_AR-1)))
   [M:CNAT]TRIANA=[M:CNAT]TRIANA : Affzo [M:CNAT]TRIANA
   GMESSAGE=mess(80,105,1) :# Axe dťjŗ dťfini
   mkstat=2
  Endif
 Endif
Endif
End

Subprog PARSE_TRIANA(VALEUR,LSTAXEANA,NBRAXEANA)
Variable Char    VALEUR()
Variable Char    LSTAXEANA()(1..)
Variable Integer NBRAXEANA

Local Char    CHAINE(len(VALEUR))
Local Integer NB_ESPACE, I, J

NB_ESPACE=-1 : I=0 : J=1
Raz LSTAXEANA

#Comptage du nombre d'axe renseignť dans Valeur (le sťparateur et un espace)
Repeat I=instr(I+1,VALEUR," ") : NB_ESPACE+=1 : Until I=0
#Le nombre d'axe est le nb d'espace +1 si un seul espace entre les axe
NBRAXEANA=NB_ESPACE+1
If NBRAXEANA>1
 CHAINE=VALEUR
 Repeat I=instr(1,CHAINE," ")
  If I<>0
   LSTAXEANA(J)=vireblc(left$(CHAINE,I-1),2)
   CHAINE=vireblc(right$(CHAINE,I+1),2)
  Else
   LSTAXEANA(J)=vireblc(CHAINE,2)
  Endif
  J+=1
 Until I=0
 NBRAXEANA=J-1
Else
 LSTAXEANA(1)=VALEUR
Endif
End

$SEL_LISTE
Case LISTE
 When "TRIANA"  : Gosub SEL_TRIANA
Endcase
Return

$VERF_LISTE
Case LISTE
 When "TRIANA"  : Gosub VERF_TRIANA
Endcase
Return

$SEL_TRIANA
Local Char WVALZON(80)
Local Char NTRI(1)
WVALZON = VALEUR
VALEUR = ""
Local Char TEX(GLONDIE)(1..20)
Local Char TEXTE(GLONDES)(1..20,1..2)
TIT = mess(175,105,1) :# Choix d'un axe
TIT(1)=mess(206,111,1) :# Axe
TIT(2)=mess(30,109,1) :# Intitulť
Local Integer NBAXE
Local Char    LSTAXE(GLONDIE)(1..dim([F:DAA]DIE))
Call GETLSTAXE([M:NAT1]CPY,[M:NAT1]LEDTYP,NBAXE,LSTAXE) From CPTDIV
For I=1 To NBAXE
 NBTEX+=1
 TEX(NBTEX)= LSTAXE(I)
 TEXTE(NBTEX,1)= LSTAXE(I)
 Call LECTEXTRA(TEXTE(NBTEX,2),"GDIE","DESTRA",LSTAXE(I),"") From ATEXTRA
Next
Return

$VERF_TRIANA
VALEUR=WVALZON
If [M:CNAT]DIE(0)=""
 Call C_LEDTYP([M:CNAT]LEDTYP)
Endif
If TEX(CHOIX)<>""
 If find(TEX(CHOIX),[M:CNAT]DIE(0..dim([M:CNAT]DIE)-1))  & !instr(1,VALEUR,TEX(CHOIX))
  If VALEUR=""
   VALEUR = TEX(CHOIX)
  Else
   VALEUR -= TEX(CHOIX)
  Endif
 Endif
Endif
Return

## Ecran CONSNAT2 ##

Subprog IB_NBLIG
Call IB_NBLIG From CONSSUB
End

## Tunnel vers les piŤces
$AB1_NBLIG
Gosub SAV_CONSULT From CONSSUB
Call B1_NBLIG From CONSSUB
Return

## Tunnel vers les factures et rŤglements
$AB2_NBLIG
Gosub SAV_CONSULT From CONSSUB
Call B2_NBLIG From CONSSUB
Return

$BB_NBLIG
Gosub RST_CONSULT From CONSSUB
Return

