#<AdxTL>@(#)0.0.0.0 $Revision$ Artículos
$ACTION
Case ACTION
 When "AVANT_MOD" :  Gosub AVANT_MOD
 When "INICRE"    :  Gosub INICRE
 When "INIMOD"    :  Gosub INIMOD
 When "MAJ_AXX"   :  Gosub MAJ_AXX
 When "LIENS"     :  Gosub LIENS
 When Default
Endcase
Return

$AVANT_MOD
[M:ITM0]XSAVDLAXX = [M:ITM0]XDESCLAXX
Return

$MAJ_AXX
If ([M:ITM0]XSAVDLAXX<>[M:ITM0]XDESCLAXX) | GREP = "C" | GREP = "D"
  Call MAJTEXTRA ([M:ITM0]XDESCLAXX,"ITMMASTER","XDESCLAXX",[F:ITM]ITMREF,"") From ATEXTRA
Endif

[F:ITM]XDESCL = [M:ITM0]XDESCLAXX

Return

$INICRE
  Gosub MAJ_AXX
Return

$INIMOD
  Gosub MAJ_AXX
Return

$LIENS
  Local Char XWITMDES(GLONDES)
  Call CHARGE_ITMDES("XDESCLAXX",GLANGUE,[M:ITM0]ITMREF,XWITMDES) From TRTX3
  If XWITMDES = "" and [F:ITM]XDESCL <> "" Then
      [M:ITM0]XDESCLAXX = [F:ITM]XDESCL

      Chgstl [M:ITM0]XDESCLAXX With "NTRANSLATE"
  Else
    Chgstl [M:ITM0]XDESCLAXX With ""
  Endif
Return


