#<AdxTL>@(#)0.0.0.0 $Revision$
# GestiÛn de la m·scara PTH1 (Especifico)
# SUPPORT-3473 [Ticket #001717] Fecha VE provî, nunca deje poner una fecha anterior a la fecha de realizaciÛn del Pedido.
######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla PTH1) 01/04/2016 09:30:27 (ADMIN)
######################################################################################
$ACTION
Case ACTION
 When "CREATION" : Gosub CREATION
 When Default
Endcase
Return

#**
#* Si se crea una recepciÛn y el artÌculo es serializable, grabarlo en la tabla
#* icordstatus con status 7
#*
#*!
$CREATION
  Local Char LDOSSIER(20)
  If [M:PTH0]BETFCY = 1 Then
    If clalev([F:ZITM]) = 0 Then : Local File ITMMASTER [ZITM] : Endif
    For I = 0 To [M:PTH1]NBLIG-1
      Read [F:ZITM]ITM0 = [M:PTH1]ITMREF(I)
      If !fstat Then # ariculo encontrado
        If [F:ZITM]XSERIALIZADO = 2 Then  # articulo es serializable
            # insertar en la tabla ICORDSTATUS
              LDOSSIER = [S]nomap(0)
              # MAB.29092020,NEW - A—ADO PTDLIN A ICORDSTATUS
              Execsql From "S"  Sql "INSERT INTO " + LDOSSIER + ".ICORDSTATUS (ORDERNAME_0, XSTATUS_0, NUMCOMITEM_0, NUMDECITEM_0) VALUES ('" + [M:PTH0]PTHNUM + "_" + num$([M:PTH1]PTDLIN(I)) + "',7,"
& +
& num$([M:PTH1]QTYUOM(I)) +
& ",0)"
#              Execsql From "S"  Sql "INSERT INTO " + LDOSSIER + ".ICORDSTATUS (ORDERNAME_0, XSTATUS_0, NUMCOMITEM_0, NUMDECITEM_0) VALUES ('" + [M:PTH0]PTHNUM + "',7," + num$([M:PTH1]QTYUOM(I)) +
#& ",0)"
#              Break # articulo de la recepciÛn es serializable, por lo tanto, salir del bucle # MAB.29092020,NEW - A—ADO PTDLIN A ICORDSTATUS
        Endif
      Endif
     Next
    Close File [ZITM]
  Endif

  # SUPPORT-3473 [Ticket #001717] Fecha VE provî, nunca deje poner una fecha anterior a la fecha de realizaciÛn del Pedido.
  # RECORRER TODOS LOS PEDIDOS DE LA RECEPCI”N Y REVISAR LA FECHA DEL PEDIDO CONTRA FECHA VE PROV. Si esta fecha es inferÌor a la fecha del alg˙n pedido,
  # mostrar el mensaje y no permitir crear la recepciÛn.
  If !clalev([ZPOH]) Then : Local File PORDER [ZPOH] : Endif

  For I = 0 To [M:PTH1]NBLIG
    If [M:PTH1]POHNUM(I) <> "" Then
      Read [ZPOH]POH0=[M:PTH1]POHNUM(I)
      If !fstat Then
          If [F:ZPOH]ORDDAT > [M:PTH0]NDEDAT Then
            Infbox "No es posible la creaciÛn de la recepciÛn. El pedido " + [M:PTH1]POHNUM(I) + " tiene una fecha superior a la Fecha VE prov."
            GOK = 0
          Endif
      Endif
    Endif
  Next
  Close File [ZPOH]
  # SUPPORT-3473 [Ticket #001717] Fecha VE provî

Return

######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla PTH0) 31/10/2017 09:44:15 (ADMIN)
######################################################################################
Subprog C_NDEDAT(VALEUR)
Variable Date    VALEUR
  If VALEUR > date$ Then
    Call MESSAGE("La fecha de recepciÛn no puede ser mayor que la fecha actual") From GESECRAN
    mkstat=2
  Endif
End


######################################################################################

######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla PTH0) 01/03/2018 17:06:21 (ADMIN)
######################################################################################
Subprog AS_RCPDAT(VALEUR)
Variable Date    VALEUR
   If !GSERVEUR Then
     mkstat=2
   Endif
End


