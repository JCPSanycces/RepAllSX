$ACTION
Case ACTION
 When Default
Endcase
Return

Subprog C_SHLDAT(VALEUR)
Variable Date    VALEUR
 If VALEUR < date$ Then
    Call MESSAGE("La fecha de caducidad no puede ser menor que la fecha actual") From GESECRAN
    mkstat=2
  Endif
End

Subprog C_NEWLTIDAT(VALEUR)
Variable Date    VALEUR
  If VALEUR < date$ Then
    Call MESSAGE("La fecha de recontrol no puede ser menor que la fecha actual") From GESECRAN
    mkstat=2
  Endif
End


