#<AdxTL>@(#)6.0.0.0 $Revision$
########################################################
## Déclaration des variables
########################################################
$DECLARE
Local Char SAVACT(GLONACT) : SAVACT=ACTION

ACTION = "DEFLIG" : Gosub T_ACTION
Local Char    FICLIG(GLONATB) , ABLIG(GLONABR) , CRIT(250) , TRTLIG(1)
Local Integer STAT , SIGN , MAXLIG
Local Integer ONUM(evalue("dim([M]"+ZONLIG+")"))

ACTION=SAVACT
Return

########################################################
## Lecture des lignes
########################################################
$LIENS
Local Char SAVACT(GLONACT) : SAVACT=ACTION

ACTION = "DEFLIG" : Gosub T_ACTION
Assign "[G:"+ABLIG+"]currind" With 1              : # mbt 24/04/2002
Assign "[G:"+ABLIG+"]currlen" With 0              : # mbt 24/04/2002
nolign = 0
For [F] Where evalue(CRIT)
 If nolign>=dim([M]UPDFLG)
  Break
 Endif
 nolign += 1
 [M] = [F]
 [M]UPDFLG(nolign-1) = 0                          : # Flag de modif
 [M]CREFLG(nolign-1) = nolign                     : # Flag d'annulation
 ONUM(nolign-1)      = evalue("[F]"+ZONLIG)       : # Identificateur pour annul
 ACTION = "LIENS_LIG" : Gosub T_ACTION
Next
[M]NBLIG = nolign
MAXLIG = nolign

ACTION=SAVACT
Return

########################################################
## Enregistrement des lignes
########################################################
$CREATION
Local Char SAVACT(GLONACT) : SAVACT=ACTION

ACTION = "DEFLIG" : Gosub T_ACTION
Assign "[G:"+ABLIG+"]currind" With 1                 : # mbt 24/04/2002
Assign "[G:"+ABLIG+"]currlen" With 0                 : # mbt 24/04/2002
For nolign=1 To [M]NBLIG
 Raz [F]
 [F] = [M]
 Assign "[F]"+ZONLIG With 1000*nolign : # On numérote de 1000 en 1000
 Gosub INICRE_LIG
 # GA 11/2007 fait dans INIMOD_LIG pour les appels directs ŕ cette action
 #ACTION = "INICRE_LIG" : Gosub T_ACTION
 If GOK<1 : Break : Endif : # Propagation des erreurs
 Write
 If fstat
  GOK=0 : Call FSTA(ABLIG) From GLOCK : Break
 Endif
 TRTLIG = "C"
 SIGN = +1 : Gosub VALLIG
 If GOK<1 : Break : Endif : # Propagation des erreurs
Next nolign

ACTION=SAVACT
Return

########################################################
## Modification des lignes (optimisée)
########################################################
$MODIF
Local Char SAVACT(GLONACT) : SAVACT=ACTION

ACTION = "DEFLIG" : Gosub T_ACTION
Assign "[G:"+ABLIG+"]currind" With 1                 : # mbt 24/04/2002
Assign "[G:"+ABLIG+"]currlen" With 0                 : # mbt 24/04/2002
## Premičre passe, lignes annulées
For nolign=1 To MAXLIG
 If !find(nolign,[M]CREFLG(0..[M]NBLIG-1))
  Filter [F] Where evalue(CRIT) & evalue(ZONLIG+"="+num$(ONUM(nolign-1)))
  Readlock First
  Filter [F]
  If fstat=1
   GOK=-1 : GLOCK = "$"+FICLIG-num$(nolign) : Break
  Elsif !fstat : # Au cas oů
   TRTLIG = "A"
   SIGN = -1 : Gosub VALLIG
   If GOK<1 : Break : Endif
   Delete
  Endif
 Endif
Next nolign
## Deuxičme passe, créations et modifications
For nolign=1 To [M]NBLIG
 If [M]CREFLG(nolign-1)=0  : # C'est une nouvelle ligne
  Raz [F]
  [F] = [M]
  Gosub INICRE_LIG
 # GA 11/2007 fait dans INIMOD_LIG pour les appels directs ŕ cette action
 #ACTION = "INICRE_LIG" : Gosub T_ACTION
  If GOK<1 : Break : Endif
  Write
  If fstat
   GOK=0 : Call FSTA(ABLIG) From GLOCK : Break
  Endif
  TRTLIG = "C"
  SIGN = +1 : Gosub VALLIG
  If GOK<1 : Break : Endif
 Elsif [M]UPDFLG(nolign-1)<>0 : # La ligne a été modifiée
  Filter [F] Where evalue(CRIT) & evalue(ZONLIG+"=[M]"+ZONLIG+"("+num$(nolign-1)+")")
  Readlock First
  Filter [F]
  If fstat=1
   GOK=-1 : GLOCK = "$"+FICLIG-num$(nolign) : Break
  Elsif !fstat : # Au cas oů
   TRTLIG = "M"
   SIGN = -1 : Gosub VALLIG
   If GOK<1 : Break : Endif
  Endif
  [F] = [M]
  Gosub INIMOD_LIG
 # GA 11/2007 fait dans INIMOD_LIG pour les appels directs ŕ cette action
 #ACTION = "INIMOD_LIG" : Gosub T_ACTION
  If GOK<1 : Break : Endif
  Rewrite
  If fstat
   GOK=0 : Call FSTA(ABLIG) From GLOCK : Break
  Endif
  TRTLIG = "M"
  SIGN = +1 : Gosub VALLIG
  If GOK<1 : Break : Endif
 Endif
Next nolign

ACTION=SAVACT
Return

$ANNULE
Local Char CRIT(250) , TRTLIG(1)
Local Integer SIGN
Local Char SAVACT(GLONACT) : SAVACT = [L]ACTION

[L]ACTION = "DEFLIG" : Gosub T_ACTION
Assign "[G:"+ABLIG+"]currind" With 1              : # mbt 24/04/2002
Assign "[G:"+ABLIG+"]currlen" With 0              : # mbt 24/04/2002
For [F] Where evalue(CRIT)
 [L]TRTLIG = "A"
 [L]SIGN = -1 : Gosub VALLIG
 If GOK<1 : Break : Endif
Next
If GOK<1 : Return : Endif
Delete [F] Where evalue(CRIT)
If fstat=1
 GOK=-1 : GLOCK = "$"+FICLIG : Return
Endif

[L]ACTION = SAVACT
Return

# Traitements complémentaires (stocks, en-cours clients, ....)
$VALLIG
[L]ACTION = "VALLIG" : Gosub T_ACTION
Return

###############################################################
$T_ACTION
GPE = 0
GPV = 0
If dim(PSPE)>0 & PSPE
 If GTEST : Infbox PROGSPE+".$"+ACTION At (24,80) : Endif
 Gosub ACTION From =PROGSPE
Endif
If dim(PSPV)>0 & PSPV & !GPV
 If dim(GENTOBJ)>0 & dim(PROGSPV)>1
  Local Integer IPETAB
  For IPETAB=1 To dim(PROGSPV)
   If PROGSPV(IPETAB)="" : Break : Endif
    If GTEST : Infbox PROGSPV(IPETAB)+".$"+ACTION At (24,80) : Endif
    Gosub ACTION From =PROGSPV(IPETAB)
  Next IPETAB
 Else
  If GTEST : Infbox PROGSPV+".$"+ACTION At (24,80) : Endif
  Gosub ACTION From =PROGSPV
 Endif
Endif
If dim(PSUB)>0 & PSUB & !GPE
 If GTEST : Infbox PROGSUB+".$"+ACTION At (24,80) : Endif
 Gosub ACTION From =PROGSUB
Endif
Return

###############################################################
#-------------------------------------------#
# initialisation date creation et operateur #
#-------------------------------------------#
$INICRE_LIG
If evalue ("dim([F:"+ABLIG+"]CREDAT)") > 0
 Assign "[F:"+ABLIG+"]CREDAT" With date$
Endif
If evalue ("dim([F:"+ABLIG+"]CRETIM)") > 0
 Assign "[F:"+ABLIG+"]CRETIM" With time
Endif
If evalue ("dim([F:"+ABLIG+"]CREUSR)") > 0
 Assign "[F:"+ABLIG+"]CREUSR" With GUSER
Endif
If evalue ("dim([F:"+ABLIG+"]EXPNUM)") > 0
 Assign "[F:"+ABLIG+"]EXPNUM" With [C]EXPORT
Endif
# GA 11/2007
ACTION = "INICRE_LIG" : Gosub T_ACTION
Return

#----------------------------------------#
# initialisation date modif et operateur #
#----------------------------------------#
$INIMOD_LIG
If evalue ("dim([F:"+ABLIG+"]UPDDAT)") > 0
 Assign "[F:"+ABLIG+"]UPDDAT" With date$
Endif
If evalue ("dim([F:"+ABLIG+"]UPDTIM)") > 0
 Assign "[F:"+ABLIG+"]UPDTIM" With time
Endif
If evalue ("dim([F:"+ABLIG+"]UPDUSR)") > 0
 Assign "[F:"+ABLIG+"]UPDUSR" With GUSER
Endif
If evalue ("dim([F:"+ABLIG+"]EXPNUM)") > 0
 Assign "[F:"+ABLIG+"]EXPNUM" With [C]EXPORT
Endif
# GA 11/2007
ACTION = "INIMOD_LIG" : Gosub T_ACTION
Return

########################################################################
# Contrôle de l'insertion
Subprog INSERE(ZONLIG)
Value Char ZONLIG

If status= 72 | status= 73
 #-----------------------------------------------#
 # cg le 6 Mars 1998                             #
 # problčme lors de l'insertion d'une ligne en   #
 # premičre position dans un tableau si tous les #
 # enregistrements n'ont pas été chargés dans    #
 # celui-ci : risque de dupplicate key           #
 # (cf commandes ouvertes)                       #
 #-----------------------------------------------#
 If dim(GQSEQ) >=0
  If (nolign=1 & evalue("[M]"+ZONLIG+"(0)")=GQSEQ+1)
&  | (nolign>1 & evalue("[M]"+ZONLIG+"("+num$(nolign-1)+")")
&  =evalue("[M]"+ZONLIG+"("+num$(nolign-2)+")")+1)
   Call ERREUR (mess(122,199,1)) From GESECRAN
   mkstat = 2
  Endif
 Else
  If (nolign=1 & evalue("[M]"+ZONLIG+"(0)")=1)
&  | (nolign>1 & evalue("[M]"+ZONLIG+"("+num$(nolign-1)+")")
&  =evalue("[M]"+ZONLIG+"("+num$(nolign-2)+")")+1)
   Call ERREUR (mess(122,199,1)) From GESECRAN
   mkstat = 2
  Endif
 Endif
Endif
End

########################################################################
# Attribution du no de ligne en saisie
Subprog LINNUM(ZONLIG)
Value Char ZONLIG
#-------------------------------------------------------#
# MB 28/9/98 Sortie de saisie par Return -> status 71   #
# MB 30/3/99 Changement de ligne en modif -> status 75  #
#-------------------------------------------------------#
Local Integer OK
OK  = 0
OK += (status=6)
OK += (status=7)
OK += (status>=27 & status<=70)
OK += (status>=72 & status<=74)
OK += (status>=76 & status<=91)
OK += (status>=94 & status<=99)
OK += (status >= 1792)
If OK : End : Endif

[M]UPDFLG(nolign-1)=1

If evalue("[M]"+ZONLIG+"("+num$(nolign-1)+")")=0
 Local Integer NOL , NOL1 , NOL2 , DEB , FIN , INC
 NOL1 = nolign-1
 While NOL1>0 & [M]CREFLG(NOL1-1)=0 : NOL1 -= 1 : Wend
 #-----------------------------------------------#
 # cg le 6 Mars 1998                             #
 # problčme lors de l'insertion d'une ligne en   #
 # premičre position dans un tableau si tous les #
 # enregistrements n'ont pas été chargés dans    #
 # celui-ci : risque de dupplicate key           #
 # (cf commandes ouvertes)                       #
 #-----------------------------------------------#
 If NOL1<=0
  DEB = 0
  If dim (GQSEQ) >= 0 : DEB = GQSEQ : Endif    : # cg
 Else
  DEB = evalue("[M]"+ZONLIG+"("+num$(NOL1-1)+")")
 Endif
 NOL2 = nolign-1
 While NOL2<[M]NBLIG-1 & [M]CREFLG(NOL2+1)=0 : NOL2 += 1 : Wend
 If NOL2>=[M]NBLIG-1
  If (DEB=0 | NOL1>0) & (NOL2=0 | evalue("[M]"+ZONLIG+"("+num$(NOL2-1)+")")>0) & NOL1=NOL2
   If NOL2=0
    Assign "[M]"+ZONLIG+"("+num$(NOL2)+")" With 1000
   Else
    Assign "[M]"+ZONLIG+"("+num$(NOL2)+")" With evalue("[M]"+ZONLIG+"("+num$(NOL2-1)+")")+1000
   Endif
  Else
   For NOL=NOL1 To NOL2
    Assign "[M]"+ZONLIG+"("+num$(NOL)+")" With  DEB+1000*(NOL-NOL1+1)
   Next
  Endif
 Else
  FIN = evalue("[M]"+ZONLIG+"("+num$(NOL2+1)+")")
  INC = int((FIN-DEB)/(NOL2-NOL1+2))
  If INC<1
   Call ERREUR (mess(122,199,1)) From GESECRAN
   mkstat=2 : End
  Else
   For NOL=NOL1 To NOL2
    Assign "[M]"+ZONLIG+"("+num$(NOL)+")" With DEB+INC*(NOL-NOL1+1)
   Next NOL
  Endif
 Endif
Endif
End

