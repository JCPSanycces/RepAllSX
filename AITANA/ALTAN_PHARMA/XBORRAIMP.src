Local File AREPORTM[ARPT]  
[F:ARPT]UPDTICK='1'
[F:ARPT]USR='MALAR'
[F:ARPT]NUMREQ=999999
[F:ARPT]RPTCOD='XSBONFACP3'
Trbegin [ARPT]
Write [ARPT]
If [S]fstat
  Rollback
  Call ERREURT('ROLLBACK', 0) From GESECRAN
Else
  Commit
  Call ERREURT('COMMIT', 0) From GESECRAN
  #Read [ARPT]RPTCOD = [F:ARPT]RPTCOD :# you go to it
