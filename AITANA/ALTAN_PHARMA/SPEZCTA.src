#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
 Case Action
  When "DEBUT" Gosub DEBUT
  When "OK" Gosub OK
  When Default 
 Endcase
Return

$OK  
  If [M:ZCTA]UPDFLG=1 Then
     If !Clalev([F:XSIH]) Then Local File SINVOICE [XSIH] : Endif
     Readlock [F:SIH]SIH0=[M:ZCTA]NUM
     If !fstat Then
        [F:SIH]XASIGNCONT=[M:ZCTA]ZXASIGNCONT
        Rewrite [F:SIH] Curr
        Call Message("Contra albar·n actualizado") From GESECRAN
     Else
        #error
        GERR=1
        GOK=0
        GMESSAGE="No se puede actualizar los datos"
        Call Message("No se ha podido actualizar") From GESECRAN
     Endif
  Endif
Return


$DEBUT
  [M:ZCTA]UPDFLG=0
  If Dim([M:SIH2]XASIGNCONT) Then
     [M:ZCTA]NUM=[M:SIH0]NUM
     [M:ZCTA]ZXASIGNCONT=[M:SIH2]XASIGNCONT
  Endif
Return

######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla ZCONTRALBA) 10/02/2017 10:47:16 (ADMIN)
######################################################################################
Subprog AV_NUM(VALEUR)
Variable Char    VALEUR()

End

Subprog AM_ZXASIGNCONT(VALEUR)
Variable Char    VALEUR()
  [M:ZCTA]UPDFLG=1
End


