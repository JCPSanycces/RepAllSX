#<AdxTL>@(#)0.0.0.0 $Revision$ Recepciones
# Gestión de la máscara PTH1 (Especifico)
# SUPPORT-3473 [Ticket #001717] Fecha VE prov”, nunca deje poner una fecha anterior a la fecha de realización del Pedido.
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla PTH1) 01/04/2016 09:30:27 (ADMIN)
######################################################################################
$ACTION
Case ACTION
 When "CREATION" : Gosub CREATION
 When Default
Endcase
Return

#**
#* Si se crea una recepción y el artículo es serializable, grabarlo en la tabla
#* icordstatus con status 7
#*
#*!
$CREATION
    Local Char LDOSSIER(20)


  # SUPPORT-3473 [Ticket #001717] Fecha VE prov”, nunca deje poner una fecha anterior a la fecha de realización del Pedido.
  # RECORRER TODOS LOS PEDIDOS DE LA RECEPCIÓN Y REVISAR LA FECHA DEL PEDIDO CONTRA FECHA VE PROV. Si esta fecha es inferíor a la fecha del algún pedido,
  # mostrar el mensaje y no permitir crear la recepción.
  If !clalev([ZPOH]) Then : Local File PORDER [ZPOH] : Endif

  For I = 0 To [M:PTH1]NBLIG
    If [M:PTH1]POHNUM(I) <> "" Then
      Read [ZPOH]POH0=[M:PTH1]POHNUM(I)
      If !fstat Then
          If [F:ZPOH]ORDDAT > [M:PTH0]NDEDAT Then
            Infbox "No es posible la creación de la recepción. El pedido " + [M:PTH1]POHNUM(I) + " tiene una fecha superior a la Fecha VE prov."
            GOK = 0
          Endif
      Endif
    Endif
  Next
  Close File [ZPOH]
  # SUPPORT-3473 [Ticket #001717] Fecha VE prov”
  # LLAMO AL ESTANDAR PARA QUE GRABE LA RECEPCIÓN

  Gosub CREATION From SUBPTHA
  GPE = 1

  If [M:PTH0]BETFCY = 1 Then
    If clalev([F:ZITM]) = 0 Then : Local File ITMMASTER [ZITM] : Endif

    If clalev([F:YICO]) = 0 Then : Local File YICORDTMP [YICO] : Endif # tabla tmp icordtmp para líneas de recepciones MAB.001.NEW
    For I = 0 To [M:PTH1]NBLIG-1
      Read [F:ZITM]ITM0 = [M:PTH1]ITMREF(I)
      If !fstat Then # ariculo encontrado
        If [F:ZITM]XSERIALIZADO = 2 Then  # articulo es serializable
            # insertar en la tabla ICORDSTATUS
              #  Infbox "dENTRO LINEA " + num$(I) + " - " +  num$([M:PTH1]PTDLIN(I))
              LDOSSIER = [S]nomap(0)
              # MAB.29092020,NEW - AŃADO PTDLIN A ICORDSTATUS
#              Execsql From "S"  Sql "INSERT INTO " + LDOSSIER + ".ICORDSTATUS (ORDERNAME_0, XSTATUS_0, NUMCOMITEM_0, NUMDECITEM_0) VALUES ('" + [M:PTH0]PTHNUM + "_" + num$([M:PTH1]PTDLIN(I)) + "',7,"
#& +
#& num$([M:PTH1]QTYUOM(I)) +
#& ",0)"

              Execsql From "S"  Sql "INSERT INTO " + LDOSSIER + ".ICORDSTATUS (ORDERNAME_0, XSTATUS_0, NUMCOMITEM_0, NUMDECITEM_0) VALUES ('" + [M:PTH0]PTHNUM  + "',7,"
& +
& num$([M:PTH1]QTYUOM(I)) +
& ",0)"
             # Break # articulo de la recepción es serializable, por lo tanto, salir del bucle # COMENTO ESTA LÍNEA
             # MAB.001.SNEW
#             Trbegin [YICO]
             If !clalev([F:YSTJ]) Then : Local File STOJOU [YSTJ] : Endif
             Filter [F:YSTJ] Where VCRTYP = 6 and VCRNUM = [M:PTH0]PTHNUM and VCRLIN = [M:PTH1]PTDLIN(I)
             #Infbox "Regsitros encontrados:" + num$(rowcount([YSTJ]))
             For [F:YSTJ]
               [F:YICO]FCY    = [M:PTH0]PRHFCY
               [F:YICO]PTHNUM = [M:PTH0]PTHNUM
               [F:YICO]NUMLIG = [M:PTH1]PTDLIN(I)
               [F:YICO]ITMREF = [M:PTH1]ITMREF(I)
               [F:YICO]LOT = [F:YSTJ]LOT
               [F:YICO]SLO = [F:YSTJ]SLO
               [F:YICO]QTY = [F:YSTJ]QTYPCU
               [F:YICO]PROCESADO = 1
               Write [F:YICO]
            Next
             # MAB.001.ENEW
        Endif
      Endif
     Next
    Close File [ZITM]
    Close File [YICO]
  Endif



Return

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla PTH0) 31/10/2017 09:44:15 (ADMIN)
######################################################################################
Subprog C_NDEDAT(VALEUR)
Variable Date    VALEUR
  If VALEUR > date$ Then
    Call MESSAGE("La fecha de recepción no puede ser mayor que la fecha actual") From GESECRAN
    mkstat=2
  Endif
End


######################################################################################

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla PTH0) 01/03/2018 17:06:21 (ADMIN)
######################################################################################
Subprog AS_RCPDAT(VALEUR)
Variable Date    VALEUR
   If !GSERVEUR Then
     mkstat=2
   Endif
End


