# Gestión de la máscara SCS1 (Especifico)

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla SCS1) 21/10/2016 13:30:54 (ADMIN)
######################################################################################
$ACTION
Case ACTION
 When default
Endcase
Return

Subprog D_ZSHLDAT(VALEUR)
Variable Date    VALEUR
   If !Clalev ([F:XSTL]) Then Local File STOLOT [XSTL] : Endif

   Read [F:XSTL]STL0 = [M:SCS1]ITMREF(nolign-1);[M:SCS1]LOT(nolign-1);[M:SCS1]SLO(nolign-1)
   If !fstat Then 
      VALEUR=[F:XSTL]SHLDAT
   Else
      VALEUR=""
   Endif
End


