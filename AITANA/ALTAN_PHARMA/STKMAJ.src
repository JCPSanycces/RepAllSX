#<AdxTL>@(#)5.0.0.0 $Revision$
#############################################################################
# Traitement STKMAJ - Librairie des composants de màj stock            V140 #
#                     Entrée - Sortie - Changement d'emplacement   MBT 2003 #
#############################################################################
# Sous-programme
#
# MAJ_STOCK Appel du moteur de mise à jour des stocks
#
#----------------------------------------------------------------------------
# Etiquettes appelées par Gosub depuis ce traitement :
#
# ENTREES           Traitement des entrées en stock      dans le STKMAJE
# SORTIES           Traitement des sorties de stock      dans le STKMAJS
# CHGEMPL           Traitement changements d'emplacement dans le STKMAJC
# INVENTAIRE        Traitement des inventaires           dans le STKMAJI
# TRACE_DETAILLEE   Trace détaillée et hyper détaillée   dans le STKMAJSUP
#
#----------------------------------------------------------------------------
# Autres étiquettes appelées par Gosub depuis les STKMAJ-E-S-C-I:
#
# TRT_ERRGEN        Traitement d'une erreur générale (erreur programmation ...etc)
# TRT_LCK           Traitement des blocages (conflit d'accès)
# TRT_ERR           Traitement des erreurs
# CUMULS_QTES       Cumuls des qtés pour màj des tables STOQUAL et ITMMVT
# CUMULS_QTEALL     Cumuls des qtés allouées pour màj de la table ITMMVT
# LECSTL            Lecture enregistrement lot avec création si nécessaire
# LECSLF            Lecture enregistrement lot-site avec création si nécessaire
# LECQLY            Lecture demande d'analyse ou création d'une nouvelle si nécessaire
# CLESTP            Recherche existence enregistrement couts stocks FIFO correspondant
# MAJENT_WAI        Mise à jour mvt en attente dans le cas d'une entrée
# MAJSOR_WAI        Mise à jour mvt en attente dans le cas d'une sortie
# MAJ_WAI           Mise à jour mvt en attente (commun)
# MAJ_FIFO          Mise à jour couts stock FIFO (STOCOST)
# REAJUST_FIFO      Réjustement couts stock FIFO (STOCOST) si correction d'entrée avec écart
# PURGE_FIFO        Purge coûts stock FIFO (STOCOST) sortie normale ou entrée négative
# CLESTJINV         Recherche mvt d'inventaire bidon
# SPLITTAGE         Splittage ligne lorsque le décond-rompu-fract est partiel
# DECONDITION_ROMPU Déconditionnement ou rompu (recalcul du coef UC-US)
# FRACTION          Fractionnement (recalcul UC)
# MAJ_STOQLYD       Mise à jour du contrôle qualité (table STOQLYD)
# CRE_STOQLYD       Création du contrôle qualité (table STOQLYD)
# PURGE_STOQLYD     Purge du contrôle qualité lors d'une sortie en statut "Q"
# MAJ_ITMMVT        Mise à jour des cumuls article-site (table ITMMVT)
# MAJ_ITMMVTHIS     Màj de l'historique cumuls article-site (table ITMMVTHIS)
# CTL_VALDEF_LIG    Contrôles, réajustements, valeurs par défaut sur ligne à traiter
# LEC_FICHIERS      Début de mise à jour : Lecture tables et Raz variables
# MAJ_PMP_RCP       Màj des champs de la classe [F:ITV] concernant le PMP en entrée
# MAJ_PMP_ISS       Màj des champs de la classe [F:ITV] concernant le PMP en sortie
# CHARG_PARAM       Chargement des paramètres stock du site [L]WFCY
# MAJ_STOJOU        Màj du mvt de stock (STOJOU) et repérage des mvts qui s'annulent
# SPEC_SRG1         Spécificités pour plan de rangement
# SPEC_SRG2         Spécificités pour déconditionnement dans le plan de rangement
# ECRSTJ            Chargement et écriture du mouvement de stock
# ECRSTO            Ecriture de la ligne stock (STOCK)
# REWSTO            Réécriture de la ligne stock (STOCK) ou suppression si qtés à zéro
# VERIF_ALLOC       Vérification et calcul qtés allouées à déplacer
# TRT_ALLOCATION    Traitement allocations (faire suivre sur nouvelle ligne de stock
# MAJALL_TOTAL      Mise à jour totale de l'allocation
# MAJALL_PARTIEL    Mise à jour partielle de l'allocation
# ECRSTA            Ecriture de l'allocation
# REWSTA            Réécriture de l'allocation
#
#############################################################################

#############################################################################
# MAJ_STOCK : S/P de mise à jour des stocks                        MBT 2003 #
# ------------------------------------------------------------------------- #
# Subprog MAJ_STOCK                                                         #
#   Les paramètres sont passés par l'écran STOWORK [STW]                    #
#     ---------------- A l'appel du sous-programme --------------------     #
#     TRSTYP   : Type mouvement                       Entrée Sortie Change  #
#                  1 = Entrée diverse                    E                  #
#                  2 = Sortie diverse                           S           #
#                  3 = Réception fournisseur             E                  #
#                  4 = Livraison client                         S           #
#                  5 = Entrée OF                         E                  #
#                  6 = Sortie OF                                S           #
#                  7 = Changement d'emplacement                        C    #
#                  8 = Contrôle qualité                                C    #
#                  9 = Changement de statut                            C    #
#                 11 = Retour réception                  E-                 #
#                 12 = Retour livraison                         S-          #
#                 13 = Inventaire                        E      S           #
#                 14 = Transfert inter-sites                           C    #
#                 16 = Réception de sous-traitance       E                  #
#                 17 = Livraison de prêt                               C    #
#                 18 = Retour livraison de prêt                        C    #
#                 19 = Réintégration en stock                   S-          #
#                 20 = Livraison pour sous-traitance                   C    #
#                 21 = Déconditionnement - rompu                       C    #
#                 22 = Plan de rangement                               C    #
#                 24 = Demande de service                       S           #
#                 25 = Réapprovisionnement                             C    #
#                 29 = Sortie ordre de sous-traitance           S           #
#                 32 = Retour réception de s-traitance   E-                 #
#                 33 = Retour livraison pour s-traitance               C    #
#                 34 = Demande d'analyse                               C    #
#     MSGFLG   : Code affichage message de temporisation                    #
#                0-1 = Non                                                  #
#                  2 = Oui ("Mise à jour des stocks en cours ...")          #
#     TRAFLG   : Code fichier trace                                         #
#                0-1 = Non                                                  #
#                  2 = Oui écriture des messages dans un fichier trace      #
#                  3 = Oui écriture de tous les évènements (mise au point)  #
#                  4 = Oui écriture hyper détaillée (mise au point)         #
#     ---------------- Au retour du sous-programme --------------------     #
#     ERRCOD   : Code erreur au retour du S/P                               #
#                 0 = OK pas d'erreur                                       #
#                99 = Erreurs diverses                                      #
#     GMESSAGE : Contient le texte de l'erreur (ERRCOD=1-98)                #
#                ou de la dernière erreur recontrée (ERRCOD=99)             #
#############################################################################
# Variables locales                                                         #
#---------------------------------------------------------------------------#
#     WMAJCOD    :  C = Création ligne document                             #
#                   M = Modification ligne document                         #
#                   A = Annulation ligne document                           #
#     WMAJCODSTO :  C = Création mouvement (sur une ligne de stock)         #
#                   M = Modification mouvement (sur une ligne de stock)     #
#                   A = Annulation mouvement (sur une ligne de stock)       #
#     WMAJTYP    :  E = Entrée                                              #
#                   S = Sortie                                              #
#                   C = Changement emplacement                              #
#     WCODFONC   :  1 = Entrée                                              #
#                   2 = Sortie                                              #
#                   3 = Changement emplacement                              #
#     WFLUX      :  1 = Flux d'entrée                                       #
#                   2 = Flux de sortie                                      #
#     WMODLOT    :  1 = Modification lot ([M:STW]VCRTYP=35)                 #
#---------------------------------------------------------------------------#
#     Si WCODFONC = 1               SIGN     SENS                           #
#        Entrée                      +1       +1    --> Maj_Fifo            #
#        Annulation entrée           -1       +1    --> Maj_Fifo (en -)     #
#        Entrée négative             +1       -1    --> Purge_Fifo          #
#        Annulation entrée négative  -1       -1    --> Maj_Fifo            #
#                                                                           #
#     Si WCODFONC = 2               SIGN     SENS                           #
#        Sortie                      -1       +1    --> Purge_Fifo          #
#        Annulation sortie           +1       +1    --> Maj_Fifo            #
#        Sortie négative             -1       -1    --> Maj_Fifo            #
#        Annulation sortie négative  +1       -1    --> Maj_Fifo (en -)     #
#                                                                           #
#############################################################################
Subprog MAJ_STOCK
Local Shortint SAVNOLIGN : SAVNOLIGN=nolign
Local Char     PTRACE

Local Integer   WARRONDI   : # Arrondi des montants de valorisation
                             # 0=déc type donnée MDx / 1=déc devise
[L]WARRONDI=0

#----- Point d'entrée STKMAJ -----1
GPOINT="STKMAJ" : Gosub ENTREE From EXEFNC :  #CHECK IGNORE_LINE
#----- Message pour patienter -----#
If [M:STW]MSGFLG=2 Call TEMPON(mess(177,198,1)) From GESECRAN : Endif
#----- Traitement des erreurs générales (erreur de programmation ...etc) -----#
Onerrgo TRT_ERRGEN
#-----

[M:STW]TRAFLG = GSTOTRACE
# Si trace non ouverte, on force le niveau de trace utilisateur à 'pas de trace'
If [M:STW]TRAFLG>1 & GTRACE=""
  [M:STW]TRAFLG = 1
Endif

Raz GMESSAGE, [M:STW]ERRCOD
#----- 1ères vérifications : type de mvt et nbre de ligne, ... -----#
If [M:STW]TRSTYP=0
  [M:STW]ERRCOD=1  : Gosub TRT_ERR : Goto FIN_MAJ_STOCK
Endif
If [M:STW]NBLIG=0
  [M:STW]ERRCOD=2  : Gosub TRT_ERR : Goto FIN_MAJ_STOCK
Endif
If [M:STW]TRSTYP=14 & [M:STW]TRFFCY=""
  [M:STW]ERRCOD=20 : Gosub TRT_ERR : Goto FIN_MAJ_STOCK
Endif

#----- Variables locales -----#
Local Libelle   WCODFONC, WREGFLG, WUPDCOD, WPCURUL, WTRSTYP, WCRESER, WMAJITV, WMAJSTL
Local Libelle   WLOCCAT, WFLUX, WCTLSER, WRECOND, WMODLOT
Local Integer   WRET, WSEQ, WPMP, WMVTSEQ, WMVTIND, WCTR_MVTSEQ, WCTR_MVTIND, WANALIN
Local Shortint  IA, SIGN, SENS, WDEC_UC, WDEC_US               # hcb 100436
Local Integer   I, J, K, L                                     # hcb 100436

Local Integer   MOIS, ANNEE, WVCRTYP, WVCRLIN
Local Decimal   WEXERCICE, WPERIODE
Local Date      DAT, WLASRCPDAT
Local Decimal   WRND_SOC, WRND_RPT, WQTYPCU, WQTYSTU, WQTYSTUACT
Local Decimal   WPCUSTUCOE, WPCUSTUCOE_ORI
Local Char      WSTA(GLONSTA), WVCRNUM(GLONVCR), WLOCRUP(GLONLOC)
#----- Cumul qtés STU physique par lot pour màj  STOQUAL -----#
Local Decimal   WQTYSTQ,    WQTYSTQ_A,    WQTYSTQ_Q,    WQTYSTQ_R
#----- Cumul qtés PCU et STU physique pour màj STOQLYD -----#
Local Decimal   WQTYPCU_QLY, WQTYSTU_QLY
#----- Cumul qtés pour les entrées et sorties confondues -----#
Local Decimal   WQTY,       WQTY_A,       WQTY_Q,       WQTY_R       : # Qtés STU physique
Local Decimal   WQTYACT,    WQTYACT_A,    WQTYACT_Q,    WQTYACT_R    : # Qtés STU actif
Local Decimal   WQTYACTINT, WQTYACTINT_A, WQTYACTINT_Q, WQTYACTINT_R : # Qtés interne
Local Decimal   WQTYACTPLF, WQTYACTPLF_A, WQTYACTPLF_Q, WQTYACTPLF_R : # Qtés quai
Local Decimal   WQTYACTBPR, WQTYACTBPR_A, WQTYACTBPR_Q, WQTYACTBPR_R : # Qtés tiers
Local Decimal   WQTYACTSCO, WQTYACTSCO_A, WQTYACTSCO_Q, WQTYACTSCO_R : # Qtés sous-traitant
Local Decimal   WQTYACTSCC                                           : # Qtés tiers
#----- Qtés, montants, date et compteur pour les entrées -----#
Local Decimal   WQTY_RCP,   WQTYACT_RCP,  WQTYWAI_RCP,  WPCUSTUCOE_RCP
Local Decimal   WAMT_RCP,   WQTYPCU_RCP,  WQTYSTU_RCP,  WQTYSTUACT_RCP
Local Decimal   WAMTORD_RCP
Local Date      WLASDAT_RCP
Local Shortint  WCTR_RCP, WNBRWAI_RCP
Local Char      WSTA_RCP(GLONSTA), WLOT_RCP(GLONLOT), WSLO_RCP(GLONSLO)
Local Char      WPALNUM_RCP(GLONPAL), WCTRNUM_RCP(GLONCTR)
Local Char      WBPSLOT_RCP(GLONLOT), WPCU_RCP(GLONUOM), WQLYCTLDEM_RCP(GLONVCR)
Local Integer   WMVTSEQ_RCP,  WMVTIND_RCP
#----- Qtés, montants, date et compteur pour les sorties -----#
Local Decimal   WQTY_ISS,   WQTYACT_ISS,  WQTYWAI_ISS,  WPCUSTUCOE_ISS
Local Decimal   WAMT_ISS,   WQTYPCU_ISS,  WQTYSTU_ISS,  WQTYSTUACT_ISS
Local Decimal   WAMTORD_ISS
Local Date      WLASDAT_ISS
Local Shortint  WCTR_ISS, WNBRWAI_ISS
Local Char      WSTA_ISS(GLONSTA), WLOT_ISS(GLONLOT), WSLO_ISS(GLONSLO)
Local Char      WPALNUM_ISS(GLONPAL), WCTRNUM_ISS(GLONCTR)
#--- Bug 62360
Local Char      WOWNER_ISS(GLONBPF)
Local Char      WBPSLOT_ISS(GLONLOT), WPCU_ISS(GLONUOM)
Local Integer   WMVTSEQ_ISS,  WMVTIND_ISS
# CCC (14/02/05) Bug 28345 : Utilisation devise société dans la valeur du lot
Local Decimal   WCNVRPT    # Taux de conversion devise société vers devise dossier
#----- Cumuls qtés transférées et en transit pour inter-site -----#
Local Decimal   WQTYACT_TRA, WQTYACT_TRF
Local Decimal   WAMTTRA,WQTYTRA
#----- Pour gestion des numéros de série -----#
Local Integer   WNBRSER, WOWNFLG
Local Char      WSERNUM(GLONSER), WSERNUMF(GLONSER), WSERNUM_SVG(GLONSER)
Local Char      WSERNUM_ISS(GLONSER), WSERNUM_RCP(GLONSER)
Local Decimal   WQTYSTU_SER, WQTYSTUACT_SER, WQTYPCU_SER, WDIFALLQTY_SER, WDIFALLQTA_SER
Local Char      WSERCOU(GLONANM)
#----- Pour gestion des couts FIFO -----#
Local Date      WCSTDAT
Local Char      WCSTTIM(8)
Local Decimal   WCSTCOU
Local Libelle   WCSTFLG, WSPLFLG
#----- Pour gestion contrôle qualité
Local Integer   WVCRTYPANA, WVCRLINANA                               # TS_BESIN
Local Char      WVCRNUMANA(GLONVCR)                                  # TS_BESIN
Local Integer   WVCRLINORI
Local Char      WQLYCTLDEM
#-----
Local Integer   WQLDLIN1, WQLDLIN2
Local Decimal   WPHYALL, WCTLALL, WREJALL, WSCOPHYALL, WSCOCTLALL, WSCOREJALL, WSCCALL
Local Decimal   WTOTQTE, WQTE, WQTE1, WQTE2, WQTER, WCUMQTE, WQTEACT, WWIPQTY
Local Decimal   WALLQTY, WALLQTA, WDIFALLQTY, WDIFALLQTA, WQTYPCU_ORI, WQTYSTU_ORI
Local Decimal   WSPLITQTY, WSPLITSTU, WSPLITPCU
Local Decimal   WSTOCOU, WSTOCOU_SVG, WSTOCOU_RCP, WSTOCOU_ISS
Local Decimal   WQTYSTUACT_SVG, WDIFF, WQTYSTUARR
Local Libelle   WLOCCAT_SVG
Local Char      WGESLIBEMP(1)            : #--- Bug 65765

# hcb 36578  WLoctyp_svg
Local Char      WLOC_SVG(GLONEMP), WLOCTYP_SVG(GLONTLO)
Local Char      WWRH_SVG(GLONWRH), WQLYCTLDEM_SVG(GLONVCR)
Local Char      WFIC(10), WCLE(60), WCTEUR(GLONANM), WZON(10)
Local Char      WMAJCOD(1), WMAJCODSTO(1), WMAJTYP(1)
Local Char      WANA(GLONSTQ), WLOT(GLONLOT), WFCY(GLONFCY), WITMREF(GLONITM)
Local Char      WSTU(GLONUOM), WPCU(GLONUOM), WPCU_ORI(GLONUOM)
Local Char      WDEVORI(GLONCUR), WDEVDES(GLONCUR)
Local Char      WMESSAGE(100), WPARAM(15), WCRIT(240)
Local Char      WTIME(8)
# Quand la quantité de base du PMP passe à 0, le résidu de AVCBASAMT est mis dans AMTDEV
# L'écart non absorbé est détaillé pour le cas de la régul de sortie
Local Decimal   WAMTDEV_AVC(GACTVLT2+1,(GACTMAT+GACTMAC+GACTLAB+6)+1) : Raz WAMTDEV_AVC
Local Decimal   WAMTDEV_LOT(GACTVLT2+1,(GACTMAT+GACTMAC+GACTLAB+6)+1) : Raz WAMTDEV_LOT
Local Decimal   WAMTDEV_STP(GACTVLT2+1,(GACTMAT+GACTMAC+GACTLAB+6)+1) : Raz WAMTDEV_STP
# 84744
Local Decimal   WAMTDEV_ITC(GACTVLT2+1,(GACTMAT+GACTMAC+GACTLAB+6)+1) : Raz WAMTDEV_ITC

Local Char      WTCM(GLONTCM) # Méthode de valo

# CCC (24/05/05) Bug 30369 : Répartir le non absorbé sur tous les nouveaux mouvements
Local Decimal   WAMTDEV_TOT(GACTVLT2+1,(GACTMAT+GACTMAC+GACTLAB+6)+1)    # Total écart non absorbé pour répartition sur les nouveaux mouvements
Local Integer   WMVTSEQSTR     # 1er n° de séquence utilisé pour les nouveaux mouvements


#----- Paramètres de sortie -----#
Local Decimal   WAAAQTY, WQQQQTY, WRRRQTY
#------ Gestion des ruptures pour màj demande d'analyse (contrôle qualité) -------#
# WRUPTPREC : Valeur précédente (Article + Lot + Sous-lot + No série)             #
# WRUPTACTU : Valeur en cours de traitement (Article + Lot + Sous-lot + No série) #
# WRUPTFLG1 : 1 = Par article                                                     #
#             2 = Par article et lot                                              #
#             3 = Par article, lot et sous-lot                                    #
#             4 = Par article, lot, sous-lot et numéro de série                   #
# WRUPTFLG2 : 1 = Par ligne de pièce (ex. ligne de réception)                     #
#             2 = Toutes lignes de pièces confondues                              #
#---------------------------------------------------------------------------------#
Local Char      WRUPTPREC(GLONITM+GLONLOT+GLONSLO+GLONSER)
Local Char      WRUPTACTU(GLONITM+GLONLOT+GLONSLO+GLONSER)
Local Libelle   WRUPTFLG1 : [L]WRUPTFLG1=1
Local Libelle   WRUPTFLG2 : [L]WRUPTFLG2=1
#--- Bug 78767
Local Integer WPCURUL_QLD

#----- Vérification des compteurs de stock -----#
#Call CTRCPT (GSTKCPT(0),7,[L]WRET) From STKLIB
#If [L]WRET<>0
#  [M:STW]ERRCOD=24 : [L]WCTEUR=GSTKCPT(0)  : Gosub TRT_ERR : Goto FIN_MAJ_STOCK
#Endif
#Call CTRCPT (GSTKCPT(2),7,[L]WRET) From STKLIB
#If [L]WRET<>0
#  [M:STW]ERRCOD=26 : [L]WCTEUR=GSTKCPT(2)  : Gosub TRT_ERR : Goto FIN_MAJ_STOCK
#Endif

#----- Vérification type de mise à jour sur 1ère ligne -----#
If [M:STW]MAJTYP(0)<>"C" & [M:STW]MAJTYP(0)<>"E" & [M:STW]MAJTYP(0)<>"S"
  [M:STW]ERRCOD=17 : [L]WZON="MAJTYP" : Gosub TRT_ERR : Goto FIN_MAJ_STOCK
Endif
#----- Verification si type de mise à jour non renseigné -----#
If sigma(J=0,[M:STW]NBLIG-1,([M:STW]MAJTYP(J)=""))
  [M:STW]ERRCOD=17 : [L]WZON="MAJTYP" : Gosub TRT_ERR : Goto FIN_MAJ_STOCK
Endif
#----- Ouverture des tables -----#
Gosub OPEN_FILES From STKLIB

#----- link pour gestion demandes d'analyse -----#
If !clalev([F:QLX])
  Link [QLD] With [QLH] QLH0=28;[F:QLD]VCRNUM As [QLX]
Endif
#----- Détermination du code mise à jour (Création, Modification, Annulation) -----#
If [M:STW]MAJCODH="" [M:STW]MAJCODH="C" Endif
[L]WMAJCOD = [M:STW]MAJCODH

#----- Stockage identifiants pièce pour maj contrôle qualité
[L]WVCRTYPANA = [M:STW]VCRTYP                                                   # TS_BESIN
[L]WVCRNUMANA = [M:STW]VCRNUM                                                   # TS_BESIN
[L]WVCRLINANA = [M:STW]VCRLIN                                                   # TS_BESIN

If [M:STW]TRSTYP=22  [L]WMESSAGE=mess(27,701,1) : Endif : # Plan de rangement
#----- Trace début de mise à jour d'une ligne de document -----#
If [M:STW]TRAFLG>2
  [L]WMESSAGE="#######"-[L]WMESSAGE-mess(18,197,1)
  If [M:STW]VCRTYP<>0 & [M:STW]VCRNUM<>""
    [L]WMESSAGE-=mess([M:STW]VCRTYP,701,1)-":"-[M:STW]VCRNUM-"/"-num$([M:STW]VCRLIN)
  Endif
  [L]WMESSAGE-="#######"
  Call ECR_TRACE ([L]WMESSAGE,0) From GESECRAN
  If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
Endif
#----- Effacement de paramètres de sortie -----#
Raz [L]WMESSAGE, [L]WAAAQTY, [L]WQQQQTY, [L]WRRRQTY
#----- Indicateur 'Modif lot' pour restreindre la maj ITMMVT
Raz [L]WMODLOT


If [M:STW]VCRTYP=35 [L]WMODLOT=1 Endif
Case [M:STW]TRSTYP
  When 1,3,5,16                         : [L]SENS=+1 : Gosub ENTREES    From STKMAJE
  When 11,32                            : [L]SENS=-1 : Gosub ENTREES    From STKMAJE
  When 2,4,6,24,29                      : [L]SENS=+1 : Gosub SORTIES    From STKMAJS
  When 12,19                            : [L]SENS=-1 : Gosub SORTIES    From STKMAJS
  When 7,8,9,14,17,18,20,21,22,25,33,34 : [L]SENS=+1 : Gosub CHGEMPL    From STKMAJC
  When 13                               : [L]SENS=+1 : Gosub INVENTAIRE From STKMAJI
Endcase
#----- Création des Wipcost pour les mouvements issus de la GP (TB) -----#
If find([M:STW]TRSTYP,5,6,3,19,29)
  Onerrgo
  Call MAJ_WIPCOST([L]WRET) From MWIPLIB
  Onerrgo TRT_ERRGEN
  If [L]WRET<>0
    [M:STW]ERRCOD=42 : Gosub TRT_ERR : Goto FIN_MAJ_STOCK
  Endif
Endif


Call AFTUPDLIN From STKVALMAJ

#-------------------------------#
# Fin de mise à jour des stocks #
#-------------------------------#
$FIN_MAJ_STOCK
Onerrgo
Raz GMESSAGE
If [M:STW]TRAFLG>2 & dim([L]WMESSAGE)>0
  [L]WMESSAGE="###############"-format$("D:"+GFMDAT4,date$)-time$
  [L]WMESSAGE-=mess(65,123,1)-"###############"
  Call ECR_TRACE ([L]WMESSAGE,0) From GESECRAN
Endif
#----- Effacement message -----#
If [M:STW]MSGFLG=2 Call TEMPOFF From GESECRAN : Endif
#----- Nettoyage de l'écran STOWORKK (sauf code erreur et paramètres de sortie) -----#
I=[M:STW]ERRCOD

If !clalev([M:SDP]) : Local Mask SAIDECPRI : Endif
Call SUMSVW2SDP("SDP",0) From SUBSDPCOM    # A faire avant le Raz [STW] car [m:stw]nblig est utilisé
Gosub CAL_TOT From SUBSDP
Raz [M:SVW]

#--- Bug 77900
If [M:STW]VCRTYP<>35 | [M:STW]TRSTYP<>1 | WMODLOT<>1
   Raz [M:STW]
Endif
#Raz [M:STW]
#---

[M:STW]ERRCOD   =I
If dim([L]WAAAQTY)>0
  [M:STW]AAAQTY   =[L]WAAAQTY
  [M:STW]QQQQTY   =[L]WQQQQTY
  [M:STW]RRRQTY   =[L]WRRRQTY
  [M:STW]ISSAMTVAL=[M:SDP]PRI    # Différence de montant de la ligne de doc
Endif
#-----
nolign=SAVNOLIGN
End


#------------------------------------------------------------#
# Traitement erreur générale (erreur de programmation ..etc) #
#------------------------------------------------------------#
$TRT_ERRGEN
GMESSAGE =mess(137,188,1)-num$(errn)-mess(34,134,1)-errp-mess(18,197,1)-num$(errl)
GMESSAGE-="\"-errmes$(errn)-errm
[M:STW]ERRCOD=99
If [M:STW]TRAFLG>1
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
Else
  Call ERREUR(GMESSAGE)      From GESECRAN
Endif
GOK=0
Goto FIN_MAJ_STOCK : # Il faut sortir de suite par End !!


#-------------------------------------------#
# Traitement des blocages (conflit d'accès) #
#-------------------------------------------#
$TRT_LCK
GMESSAGE=GLOCK-mess(60,100,1)
If [M:STW]TRAFLG>1
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
Else
  Call ERREUR(GMESSAGE)      From GESECRAN
Endif
GOK=-1
Return


#-----------------------------------------------------------------------------#
#                          Traitement des erreurs                    MBT 2003 #
# --------------------------------------------------------------------------- #
#  1 = Type de mouvement stock non traité !                                   #
#  2 = Aucune ligne à traiter                                                 #
#  3 = Article inexistant !                                                   #
#  4 = Article-site introuvable !                                             #
#  5 = xxxxx yyy Catégorie article inexistante                                #
#  6 = xxx Site inexistant                                                    #
#  7 = xxx L'unité de conditionnement n'a pas été trouvée                     #
#  8 = xxx Unité de stock incorrecte !                                        #
#  9 = ITMMVT Erreur d'accès sur le fichier                                   #
# 10 = xxx Statut de stock incorrect                                          #
# 11 = Prix du mouvement non trouvé !                                         #
# 12 = Ce mouvement ne peut être effectué, il génère un stock négatif         #
# 13 = xxxxx Emplacement non disponible ou absent                             #
# 14 = Plus d'emplacement libre ou pas d'emplacement affecté à l'article      #
# 15 = Problème en mise à jour des allocation (Suppression)                   #
# 16 = STJ Problème en mise à jour des statistiques                           #
# 17 = xxxxxxxx Valeur incorrecte                                             #
# 18 = Avec no de série la quantité doit être un nombre entier !              #
# 19 = Pas de cours devise XXX -> YYY (JJ/MM/AA)                              #
# 20 = Le site de transfert n'est pas renseigné !                             #
# 21 = xxxxx yyy zzzz Quantité supérieure au stock disponible ! ( ? > ? )     #
# 22 = xxxxxxxxxx Compteur de numéro de série absent                          #
# 23 = xxx Méthode de valorisation introuvable !                              #
# 24 = xxx Le compteur 'Chrono stock' est incorrect ou non défini             #
# 25 = xxx Le compteur 'Numéro d'analyse' est incorrect ou non défini         #
# 26 = xxx Le compteur 'Chrono FIFO' est incorrect ou non défini              #
# 27 = xxx Le compteur 'Numéro de série' est incorrect ou non défini          #
# 28 = Mouvement d'entrée non trouvé !                                        #
# 29 = xxx Méthode de valorisation introuvable !                              #
# 30 = Prix nul non autorisé !                                                #
# 31 = Le nombre de no série ne correspond pas à la quantité à traiter        #
# 32 = Présence de no série alors que l'article ne les gère pas !             #
# 33 = Erreur sur incrémentation des numéros de série !                       #
# 34 = Le fichier trace doit être ouvert dans le programme appelant !         #
# 35 = No de série renseigné et quantité sortie différente de 1 !             #
# 36 = vvvvvvv www xxxxxx yyyyyy zzzzz Elément pile FIFO non trouvé !         #
# 37 = xxxxxx yyy Les qtés bloquées ne peuvent pas être déconditionnées !     #
# 38 = Traitement de fin de mois non effectué                                 #
# 39 = La quantité restante à ranger est négative ! (-999999,999)             #
# 40 = Quantité rangée supérieure à la réception ! ( ? > ? )                  #
# 41 = vvv wwwwww x yyyyy zzz Le mouvement d'entrée n'a pas été trouvé !      #
# 42 = Erreur sur "Call MAJ_WIPCOST"                                          #
# 43 = www x yyyyyyyy zz/zz/zz Mouvement d'inventaire introuvable !           #
# 44 = Qtés en traitement/allouées non nulles, modification titre interdite ! #
# 45 = La ligne de stock indiquée ne concerne pas le même site ou article !   #
# 46 = La valeur du code activité 'STW' est insuffisante                      #
#                                                                             #
# 50 = xxx Problème lors de la récupération du compteur                       #
#                                                                             #
# 60 = Erreur d'accès sur le fichier xxxxxxxxxx yyyyyyyyyyyyyyy               #
#                                                                             #
# 70 = Erreur d'écriture sur le fichier xxxxxxxxxx                            #
#-----------------------------------------------------------------------------#
$TRT_ERR
Case [M:STW]ERRCOD
  When  1 : GMESSAGE=num$([M:STW]TRSTYP)
            GMESSAGE-=mess([M:STW]TRSTYP,704,1)
            GMESSAGE+=mess(371,199,1)
  When  2 : GMESSAGE=mess(71,197,1)
  When  3 : GMESSAGE=[L]WITMREF-mess(212,199,1)
  When  4 : GMESSAGE=[L]WITMREF-[L]WFCY-mess(248,197,1)
  When  5 : GMESSAGE=[F:ITM]TCLCOD-mess(338,199,1)
  When  6 : GMESSAGE=[L]WFCY-mess(14,114,1)
  When  7 : GMESSAGE=[M:STW]PCU(I)-mess(74,194,1)
  When  8 : GMESSAGE=[M:STW]STU(I)-mess(228,197,1)
  When  9 : GMESSAGE="ITMMVT"-mess(12,100,1)
  When 10 : GMESSAGE=[M:STW]STA(I)-mess(255,199,1)
  When 11 : GMESSAGE=mess(373,199,1)
  When 12 : GMESSAGE=[L]WITMREF-":"-mess(241,199,1)
  When 13 : GMESSAGE=[M:STW]LOC(I)-mess(18,196,1)
  When 14 : GMESSAGE=mess(17,196,1)
  When 15 : GMESSAGE=mess(96,197,1)
  When 16 : GMESSAGE="STJ"-mess(226,197,1)
  When 17 : GMESSAGE=[L]WZON-mess(83,123,1)
  When 18 : GMESSAGE=[M:STW]SERNUM(I)-num$([M:STW]QTYSTU(I))-mess(470,197,1)
  When 19 : GMESSAGE=mess(16,114,1)-[L]WDEVORI-"->"-[L]WDEVDES
            GMESSAGE-="("+format$("D:"+GFMDAT,[STW]IPTDAT)-")"
  When 20 : GMESSAGE=mess(471,197,1)
  When 21 : GMESSAGE=[L]WITMREF-[L]WFCY-[M:STW]LOT(I)-mess(207,197,1)
            GMESSAGE-="("-num$([M:STW]QTYSTU(I))-">"-num$([L]WQTE2)-")"
  When 22 : GMESSAGE=[L]WITMREF-mess(816,196,1)
  When 23 : GMESSAGE=[F:ITF]VLTCOD-mess(472,197,1)
  When 24 : GMESSAGE=[L]WCTEUR-mess(87,199,1)
  When 25 : GMESSAGE=[L]WCTEUR-mess(88,199,1)
  When 26 : GMESSAGE=[L]WCTEUR-mess(111,199,1)
  When 27 : GMESSAGE=[L]WCTEUR-mess(384,199,1)
  When 28 : GMESSAGE=mess(473,197,1)
  When 29 : GMESSAGE=[F:ITF]VLTCOD-mess(472,197,1)
  When 30 : GMESSAGE=[L]WITMREF-mess(753,197,1)
  When 31 : GMESSAGE=mess(246,199,1)-"("+mess(453,197,1)+":"+num$([L]WNBRSER)-"/"
            GMESSAGE-=mess(449,197,1)+num$([M:STW]QTYSTU(I))+")"
  When 32 : GMESSAGE=[M:STW]SERNUM(I)-[L]WITMREF-mess(475,197,1)
  When 33 : GMESSAGE=[M:STW]SERNUM(I)-mess(476,197,1)
  When 34 : GMESSAGE=mess(386,199,1)
  When 35 : GMESSAGE=[M:STW]SERNUM(I)-num$([M:STW]QTYSTU(I))-mess(477,197,1)
  When 36 : GMESSAGE=[L]WITMREF-[L]WFCY-num$([M:STW]CSTDAT(I))-[M:STW]CSTTIM(I)
            GMESSAGE-=num$([M:STW]CSTCOU(I))-mess(482,197,1)
  When 37 : GMESSAGE=[L]WITMREF-[L]WFCY-mess(488,197,1)
            GMESSAGE-="("+num$([F:STO]CUMWIPQTY+[L]WWIPQTY)-[F:ITM]STU+")"
  When 38 : GMESSAGE=mess(257,199,1)
  When 39 : GMESSAGE=mess(499,197,1)-"("+num$([F:SRG]QTYSTUACT)+")"
  When 40 : GMESSAGE=[L]WITMREF-[L]WFCY-[M:STW]VCRNUM-mess(502,197,1)
            GMESSAGE-="("-num$([M:STW]QTYSTU(I))-">"-num$([L]WQTYSTU)-")"
  When 41 : GMESSAGE=[F:STO]STOFCY-[F:STO]ITMREF-num$([M:STW]VCRTYP)-[M:STW]VCRNUM
            GMESSAGE-=num$([M:STW]VCRLIN)-mess(503,197,1)
  When 42 : GMESSAGE =mess(20,2363,1)-GMESSAGE
  When 43 : GMESSAGE =[L]WFCY-"2"-[L]WITMREF-num$([M:STW]IPTDAT)-mess(529,197,1)
  When 44 : GMESSAGE =[F:STO]STOFCY-num$([F:STO]STOCOU)-[F:STO]ITMREF-[F:STO]LOT
            GMESSAGE-=mess(552,197,1)
  When 45 : GMESSAGE=mess(597,197,1)-"("+[F:STO]ITMREF+"-"+[M:STW]ITMREFLIG(I)-"/"
            GMESSAGE-=[F:STO]STOFCY+"-"+[L]WFCY+")"
  When 46 : GMESSAGE=mess(490,199,1)
  When 50 : GMESSAGE=[L]WCTEUR-mess(60,199,1)
  When 60 : GMESSAGE=mess(12,100,1)-[L]WFIC-[L]WCLE
  When 70 : GMESSAGE=mess(13,100,1)-[L]WFIC
Endcase
If [M:STW]TRAFLG>1
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
Else
  Call ERREUR(GMESSAGE)      From GESECRAN
Endif
GOK=0
Return


#-------------------------------------------------------#
# Cumuls des qtés pour màj des tables STOQLYD et ITMMVT #
# ----------------------------------------------------- #
# [L]WSTA    = Statut                                   #
# [L]WLOCCAT = Catégorie emplacement                    #
# [L]WFLUX   = Flux (1=entrée, 2=sortie)                #
#-------------------------------------------------------#
$CUMULS_QTES
Case left$([L]WSTA,1)
  When "A"
    [L]WQTYSTQ_A +=[M:STW]QTYSTU(I)*[L]SIGN                  : # Par lot unité physique (A)
    [L]WQTY_A    +=[M:STW]QTYSTU(I)*[L]SIGN                  : # Stock unité physique (A)
    [L]WQTYACT_A +=[M:STW]QTYSTUACT(I)*[L]SIGN               : # Stock unité active (A)
    [L]WAAAQTY   +=[M:STW]QTYSTU(I)*[L]SIGN                  : # Cumul qtés acceptées
    If [M:STW]OWNER(I)=[L]WFCY
       Case [L]WLOCCAT
         When 1 : WQTYACTINT_A +=[M:STW]QTYSTUACT(I)*[L]SIGN : # Stock interne (A)
         When 2 : WQTYACTPLF_A +=[M:STW]QTYSTUACT(I)*[L]SIGN : # Stock quai (A)
         When 3 : WQTYACTBPR_A +=[M:STW]QTYSTUACT(I)*[L]SIGN : # Stock prêté (A)
         When 4 : WQTYACTSCO_A +=[M:STW]QTYSTUACT(I)*[L]SIGN : # Stock sous-traitant (A)
       Endcase
    Endif
  When "Q"
    [L]WQTYSTQ_Q   +=[M:STW]QTYSTU(I)*[L]SIGN                : # Par lot unité physique (Q)
    [L]WQTY_Q      +=[M:STW]QTYSTU(I)*[L]SIGN                : # Stock unité physique (Q)
    [L]WQTYACT_Q   +=[M:STW]QTYSTUACT(I)*[L]SIGN             : # Stock unité active (Q)
    [L]WQTYSTU_QLY +=[M:STW]QTYSTU(I)*[L]SIGN                : # Ctrl qualité STU phys (Q)

    # Si type mvt = changement d'emplacement
    # et (annulation du flux d'entrée ou création du flux de sortie)
    # les caractéristiques stock ne sont pas ds [M:STW]--> utiliser la ligne stock
    If [L]WMAJTYP="C" &
&    (([M:STW]MAJCOD(I)="A" & [L]WFLUX=1) | ([M:STW]MAJCOD(I)="C" & [L]WFLUX=2))
      If [F:STO]PCUSTUCOE=0 [F:STO]PCUSTUCOE=1 Endif
      [L]WQTYPCU_QLY +=[M:STW]QTYSTU(I)*[L]SIGN/[F:STO]PCUSTUCOE
    Else
      [L]WQTYPCU_QLY +=[M:STW]QTYPCU(I)*[L]SIGN
    Endif

    [L]WQQQQTY+=[M:STW]QTYSTU(I)*[L]SIGN                     : # Cumul qtés sous contrôle
    If [M:STW]OWNER(I)=[L]WFCY
       Case [L]WLOCCAT
         When 1 : WQTYACTINT_Q +=[M:STW]QTYSTUACT(I)*[L]SIGN : # Stock interne (Q)
         When 2 : WQTYACTPLF_Q +=[M:STW]QTYSTUACT(I)*[L]SIGN : # Stock quai (Q)
         When 3 : WQTYACTBPR_Q +=[M:STW]QTYSTUACT(I)*[L]SIGN : # Stock prêté (Q)
         When 4 : WQTYACTSCO_Q +=[M:STW]QTYSTUACT(I)*[L]SIGN : # Stock sous-traitant (Q)
       Endcase
    Endif
  When "R"
    [L]WQTYSTQ_R +=[M:STW]QTYSTU(I)*[L]SIGN                  : # Par lot unité physique (R)
    [L]WQTY_R    +=[M:STW]QTYSTU(I)*[L]SIGN                  : # Stock unité physique (R)
    [L]WQTYACT_R +=[M:STW]QTYSTUACT(I)*[L]SIGN               : # Stock unité active (R)
    [L]WRRRQTY+=[M:STW]QTYSTU(I)*[L]SIGN                     : # Cumul qtés rejetées
    If [M:STW]OWNER(I)=[L]WFCY
       Case [L]WLOCCAT
         When 1 : WQTYACTINT_R +=[M:STW]QTYSTUACT(I)*[L]SIGN : # Stock interne (R)
         When 2 : WQTYACTPLF_R +=[M:STW]QTYSTUACT(I)*[L]SIGN : # Stock quai (R)
         When 3 : WQTYACTBPR_R +=[M:STW]QTYSTUACT(I)*[L]SIGN : # Stock prêté (R)
         When 4 : WQTYACTSCO_R +=[M:STW]QTYSTUACT(I)*[L]SIGN : # Stock sous-traitant (R)
       Endcase
    Endif
Endcase
If [M:STW]OWNER(I)<>[L]WFCY
   [L]WQTYACTSCC +=[M:STW]QTYSTUACT(I)*[L]SIGN               : # Stock tiers
Endif

[L]WQTYSTQ+=[M:STW]QTYSTU(I)*[L]SIGN                         : # Par lot unité physique (A+Q+R)
[L]WQTY   +=[M:STW]QTYSTU(I)*[L]SIGN                         : # Stock unité physique (A+Q+R)
[L]WQTYACT+=[M:STW]QTYSTUACT(I)*[L]SIGN                      : # Stock unité active (A+Q+R)

If [M:STW]OWNER(I)=[L]WFCY
   Case [L]WLOCCAT
     When 1 : [L]WQTYACTINT +=[M:STW]QTYSTUACT(I)*[L]SIGN    : # Stock interne (A+Q+R)
     When 2 : [L]WQTYACTPLF +=[M:STW]QTYSTUACT(I)*[L]SIGN    : # Stock quai (A+Q+R)
     When 3 : [L]WQTYACTBPR +=[M:STW]QTYSTUACT(I)*[L]SIGN    : # Stock prêté (A+Q+R)
     When 4 : [L]WQTYACTSCO +=[M:STW]QTYSTUACT(I)*[L]SIGN    : # Stock sous-traitant (A+Q+R)
   Endcase
Endif

#TS If [L]WCODFONC<>3 | [M:STW]STOFCY<>[M:STW]TRFFCY
# Entrée, sortie ou transfert inter-sites
If [L]WCODFONC<>3 | [M:STW]TRSTYP=14
  Case [L]WFLUX
    When 1
      [L]WQTY_RCP    +=[M:STW]QTYSTU(I)*[L]SIGN              : # Entrée unité physique (A+Q+R)
      [L]WQTYACT_RCP +=[M:STW]QTYSTUACT(I)*[L]SIGN           : # Entrée unité active (A+Q+R)
    When 2
      [L]WQTY_ISS    -=[M:STW]QTYSTU(I)*[L]SIGN              : # Sortie unité physique (A+Q+R)
      [L]WQTYACT_ISS -=[M:STW]QTYSTUACT(I)*[L]SIGN           : # Sortie unité active (A+Q+R)
  Endcase
Endif
Return

#----------------------------------------------------#
# Cumuls des quantités allouées pour màj de l'ITMMVT #
#  appelé dans le cas d'un changement d'emplacement  #
# -------------------------------------------------- #
# [L]WALLQTY     : Qté à traiter en US               #
# [L]WALLQTA     : Qté à traiter en US active        #
# [L]WFLUX       : Flux (1=entrée, 2=sortie)         #
# [L]WSTA_RCP    : Statut d'entrée                   #
# [L]WSTA_ISS    : Statut de sortie                  #
#----------------------------------------------------#
$CUMULS_QTEALL
If [L]WALLQTA=0  Return : Endif
Case [L]WFLUX
  When 1 : # Appel depuis les entrées (Changement emplacement)
    If [L]WLOCCAT_SVG=4
      Case left$([L]WSTA_ISS,1)
        When "A" : [L]WSCOPHYALL-=[L]WALLQTA
        When "Q" : [L]WSCOCTLALL-=[L]WALLQTA
        When "R" : [L]WSCOREJALL-=[L]WALLQTA
      Endcase
    Else
      Case left$([L]WSTA_ISS,1)
        When "A" : [L]WPHYALL-=[L]WALLQTA
        When "Q" : [L]WCTLALL-=[L]WALLQTA
        When "R" : [L]WREJALL-=[L]WALLQTA
      Endcase
    Endif
    #-----
    If [M:STW]LOCCAT(I)=4
      Case left$([L]WSTA_RCP,1)
        When "A" : [L]WSCOPHYALL+=[L]WALLQTA
        When "Q" : [L]WSCOCTLALL+=[L]WALLQTA
        When "R" : [L]WSCOREJALL+=[L]WALLQTA
      Endcase
    Else
      Case left$([L]WSTA_RCP,1)
        When "A" : [L]WPHYALL+=[L]WALLQTA
        When "Q" : [L]WCTLALL+=[L]WALLQTA
        When "R" : [L]WREJALL+=[L]WALLQTA
      Endcase
    Endif
  When 2 : # Appel depuis les sorties (Annulation changement emplacement)
    If [M:STW]LOCDESCAT(I)=4
      Case [L]WSTA_RCP
        When "A" : [L]WSCOPHYALL+=[L]WALLQTA
        When "Q" : [L]WSCOCTLALL+=[L]WALLQTA
        When "R" : [L]WSCOREJALL+=[L]WALLQTA
      Endcase
    Else
      Case [L]WSTA_RCP
        When "A" : [L]WPHYALL+=[L]WALLQTA
        When "Q" : [L]WCTLALL+=[L]WALLQTA
        When "R" : [L]WREJALL+=[L]WALLQTA
      Endcase
    Endif
    #-----
    If [M:STW]LOCCAT(I)=4
      Case [L]WSTA_ISS
        When "A" : [L]WSCOPHYALL-=[L]WALLQTA
        When "Q" : [L]WSCOCTLALL-=[L]WALLQTA
        When "R" : [L]WSCOREJALL-=[L]WALLQTA
      Endcase
    Else
      Case [L]WSTA_ISS
        When "A" : [L]WPHYALL-=[L]WALLQTA
        When "Q" : [L]WCTLALL-=[L]WALLQTA
        When "R" : [L]WREJALL-=[L]WALLQTA
      Endcase
    Endif
Endcase
Return


#--------------------------------------------------------#
# Lecture enregistrement lot avec création si nécessaire #
#--------------------------------------------------------#
$LECSTL

#--- Issue 95246 by TS
#Readlock [STL] STL0=[M:STW]ITMREFLIG(I);[M:STW]LOT(I);[M:STW]SLO(I)
If (func STKLIB.QTYLOT([M:STW]ITMREFLIG(I),[M:STW]LOT(I),[M:STW]SLO(I),"")=0) |
&  ([L]WMODLOT=1 & [L]WCODFONC=1) | WMAJTYP="C"
  Readlock [STL] STL0=[M:STW]ITMREFLIG(I);[M:STW]LOT(I);[M:STW]SLO(I)
Else
  Read [STL] STL0=[M:STW]ITMREFLIG(I);[M:STW]LOT(I);[M:STW]SLO(I)
Endif
#---

Case fstat
  When 0
    If (func STKLIB.QTYLOT([F:STL]ITMREF,[F:STL]LOT,[F:STL]SLO,"")=0) |
&      ([L]WMODLOT=1 & [L]WCODFONC=1)
      If [M:STW]REFPER(I)    <> [0/0/0] [F:STL]REFPER    = [M:STW]REFPER(I)  : Endif
      If [M:STW]SHL(I)       <> 0       [F:STL]SHL       = [M:STW]SHL(I)     : Endif
      If [M:STW]SHLDAT(I)    <> [0/0/0] [F:STL]SHLDAT    = [M:STW]SHLDAT(I)  : Endif
      If [M:STW]SHLUOM(I)    <> 0       [F:STL]SHLUOM    = [M:STW]SHLUOM(I)  : Endif
      If [M:STW]SHLLTI(I)    <> 0       [F:STL]SHLLTI    = [M:STW]SHLLTI(I)  : Endif
      If [M:STW]SHLLTIUOM(I) <> 0       [F:STL]SHLLTIUOM = [M:STW]SHLLTIUOM(I)  : Endif
      If [M:STW]NEWLTIDAT(I) <> [0/0/0] [F:STL]NEWLTIDAT = [M:STW]NEWLTIDAT(I)  : Endif
      If [M:STW]DLU(I)       <> 0       [F:STL]DLU       = [M:STW]DLU(I)        : Endif
      If [M:STW]DLUDAT(I)    <> [0/0/0] [F:STL]DLUDAT    = [M:STW]DLUDAT(I)     : Endif

      If [M:STW]POT(I)    <>0        [F:STL]POT    =[M:STW]POT(I)     : Endif
      If [M:STW]ACT(I)    <>0        [F:STL]ACT    =[M:STW]ACT(I)     : Endif
      If [M:STW]BPSLOT(I) <>""       [F:STL]BPSLOT =[M:STW]BPSLOT(I)  : Endif
      If [M:STW]USRFLD1(I)<>""       [F:STL]USRFLD1=[M:STW]USRFLD1(I) : Endif
      If [M:STW]USRFLD2(I)<>""       [F:STL]USRFLD2=[M:STW]USRFLD2(I) : Endif
      If [M:STW]USRFLD3(I)<>0        [F:STL]USRFLD3=[M:STW]USRFLD3(I) : Endif
      If [M:STW]USRFLD4(I)<>[0/0/0]  [F:STL]USRFLD4=[M:STW]USRFLD4(I) : Endif
    Endif
    [F:STL]UPDDAT=date$
    [F:STL]UPDUSR=GUSER
    [F:STL]EXPNUM=[C]EXPORT
  When 1
    GLOCK="$STOLOT"-[M:STW]ITMREFLIG(I)-[M:STW]LOT(I)-[M:STW]SLO(I)
    [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
  When 4,5
    Raz [F:STL]
    nolign=I+1 : [F:STL]=[M:STW]
    If [F:ITM]EXYMGTCOD<2
      Raz [F:STL]REFPER, [F:STL]SHL, [F:STL]SHLDAT, [F:STL]DLUDAT, [F:STL]NEWLTIDAT, [F:STL]SHLUOM, [F:STL]SHLLTI
      Raz [F:STL]DLU, [F:STL]SHLLTIUOM
    Endif
    If [F:STL]SHLDAT=[0/0/0]
      [F:STL]SHLDAT=[31/12/2999]
    Endif
    If [F:STL]DLUDAT=[0/0/0]
      [F:STL]DLUDAT=[31/12/2999]
    Endif
    If [F:STL]NEWLTIDAT=[0/0/0]
      [F:STL]NEWLTIDAT=[31/12/2999]
    Endif
    [F:STL]BPSNUM   =[M:STW]BPRNUM
    [F:STL]LOTCREDAT=[M:STW]IPTDAT
    If [F:STL]ACT=0 [F:STL]ACT=1   : Endif
    If [F:STL]POT=0 [F:STL]POT=100 : Endif
    Call ECRSTL From STKLIB
    If fstat
      Call FSTA("STL") From GLOCK
      [M:STW]ERRCOD=70 : [L]WFIC="STOLOT" : Gosub TRT_ERR : Return
    Endif
    If [M:STW]TRAFLG>1 & [L]WLOT<>""
      #----- Lot XXXXXXX YYYYYYY ZZZZZ créé ! -----#
      [L]WMESSAGE=mess(43,197,1)-[L]WITMREF-[L]WLOT-[M:STW]SLO(I)-mess(233,197,1)
      Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
      If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
    Endif
    Goto LECSTL
Endcase
[M:STW]SHLDAT(I)=[F:STL]SHLDAT

If [M:STW]TRSTYP<>14 : # TS - STOLOTFCY
  Gosub LECSLF
Endif                : # TS - STOLOTFCY

Return

#-----------------------------------------------------------------#
# Lecture enregistrement lot/site avec création si nécessaire     #
# Il faut appeler LECSTL avant, afin d'être sûr que le lot existe #
#-----------------------------------------------------------------#
$LECSLF
Readlock [SLF] SLF0=[M:STW]ITMREFLIG(I);[M:STW]LOT(I);[M:STW]SLO(I);WFCY
Case fstat
  When 1
    GLOCK="$STOLOTFCY"-[M:STW]ITMREFLIG(I)-[M:STW]LOT(I)-[M:STW]SLO(I)-WFCY
    [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
  When 4,5
    Read [STL] STL0=[M:STW]ITMREFLIG(I);[M:STW]LOT(I);[M:STW]SLO(I)
    Raz [F:SLF]
    [F:SLF] = [F:STL]
    [F:SLF]STOFCY   =WFCY
    [F:SLF]CUR      =GSYSCUR
    Call ECRSLF From STKLIB
    If fstat
      Call FSTA("SLF") From GLOCK
      [M:STW]ERRCOD=70 : [L]WFIC="STOLOT" : Gosub TRT_ERR : Return
    Endif
    If [M:STW]TRAFLG>1 & [L]WLOT<>""
      #----- Lot XXXXXXX YYYYYYY ZZZZZ créé ! -----#
      [L]WMESSAGE=mess(43,197,1)+"/"+mess(498,197,1)-[L]WITMREF-[L]WLOT-[M:STW]SLO(I)-WFCY-mess(233,197,1)
      Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
      If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
    Endif
    Readlock [SLF] SLF0=[M:STW]ITMREFLIG(I);[M:STW]LOT(I);[M:STW]SLO(I);WFCY
Endcase
Return


#--------------------------------------------------------------------#
# Lecture demande d'analyse ou création d'une nouvelle si nécessaire #
#--------------------------------------------------------------------#
$LECQLY
# Alimentation d'un critère spécifique pour lecture QLH
GPOINT="QLH_CRIT" : Gosub ENTREE From EXEFNC

#----- Si no renseigné, reprise même demande d'analyse -----#
If [M:STW]QLYCTLDEM(I)<>""
  [L]WFIC="STOQLYH"
  [L]WCLE="28"-[M:STW]QLYCTLDEM(I)
  Read [QLH] QLH0=28;[M:STW]QLYCTLDEM(I)
  If !fstat
    #----- Analyse trouvée et non terminée, récupération du numéro -----#
    If [F:QLH]STOFCY=[L]WFCY    &
&      [F:QLH]ITMREF=[L]WITMREF &
&      [F:QLH]VALFLG<>2
      [L]WANA=[M:STW]QLYCTLDEM(I) : Return
    #----- Si annulation entrée ou inventaire et analyse validée, ne rien faire -----#
    Elsif [L]WMAJCOD="A" | [M:STW]TRSTYP=13
      #----- Notifier dans la trace que l'analyse est validée -----#
      If [M:STW]TRAFLG>1
        [L]WMESSAGE=[L]WCLE-mess(538,197,1) : # Demande d'analyse validée !
        Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
        If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
      Endif
      Return
    #----- Dévalidation de l'analyse et récupération du numéro -----#
    Else
      Update [QLH] Where VCRTYP=28 & VCRNUM=[M:STW]QLYCTLDEM(I) With VALFLG=1
      If fstat=1
        GLOCK="$STOQLYH"-[L]WCLE
        [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
      Elsif fstat
        Call RSTA("QLH",[L]WCLE) From GLOCK
        [M:STW]ERRCOD=60 : Gosub TRT_ERR : Return
      Endif
      If [M:STW]TRAFLG>1
        [L]WMESSAGE=[L]WCLE-mess(538,197,1) : # La demande d'analyse devient non validée !
        Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
        If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
      Endif
      [L]WANA=[M:STW]QLYCTLDEM(I) : Return
    Endif
  #----- Si analyse non trouvée et statut différent de "Q", ne rien faire -----#
  Elsif left$([M:STW]STA(I),1)<>"Q"
    Return
  #--- Bug 70170
  #----- Si inventaire, il faut recréer la demande d'analyse
  Elsif [M:STW]TRSTYP=13
    [L]WANA=""
  #---
  #----- Si analyse non trouvée et statut "Q" -----#
  Else
    Raz [F:QLH]
    #----- Notifier dans la trace que l'analyse est introuvable -----#
    If [M:STW]TRAFLG>1
      [L]WMESSAGE=[L]WCLE-mess(537,197,1)
      Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
      If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
    Endif
    #----- Si annulation, pas de création d'une nouvelle analyse -----#
    If [M:STW]MAJCOD(I)="A"
      Return
    Endif
    #----- Dans les autres cas, pas de recréation de la demande d'analyse -----#
    Return
  Endif
#----- Recherche si une demande d'analyse non validée existe déjà pour la pièce -----#
Else
  If dim(WQLH_CRIT)<=0
     Local Char WQLH_CRIT : WQLH_CRIT="1=1"
  Endif
  For [QLH] QLH3 Where VCRTYPORI=[L]WVCRTYPANA
&                    & VCRNUMORI=[L]WVCRNUMANA
&                    & ITMREF   =[L]WITMREF
&                    & STOFCY   =[L]WFCY
&                    & evalue(WQLH_CRIT)
    If [F:QLH]VALFLG<>2
      [L]WANA=[F:QLH]VCRNUM
      [M:STW]QLYCTLDEM(I)=[F:QLH]VCRNUM
      Break
    Endif
  Next
  If [M:STW]QLYCTLDEM(I)<>""
    Return
  #----- Recherche si une demande d'analyse existe avec mêmes caractéristiques -----#
  #----- Inactif : la séquence est conservée au cas où ... -----#
  Elsif [L]WRUPTFLG2=2
    Columns [QLX] ([QLD]VCRNUM,[QLH]VCRTYPORI,[QLH]VCRNUMORI)
    For [QLX] QLD1 Where [QLD]ITMREF   =[L]WITMREF
&                      & [QLD]STOFCY   =[L]WFCY
&                      & [QLD]VCRTYP   =28
&                      & [QLD]LOT      =[M:STW]LOT(I)
&                      & [QLD]SLO      =[M:STW]SLO(I)
&                      & [QLD]PALNUM   =[M:STW]PALNUM(I)
&                      & [QLD]CTRNUM   =[M:STW]CTRNUM(I)
&                      & [QLD]STA      =[M:STW]STA(I)
&                      & [QLD]LOC      =[M:STW]LOC(I)
&                      & [QLD]PCU      =[M:STW]PCU(I)
&                      & [QLD]PCUSTUCOE=[M:STW]PCUSTUCOE(I)
&                      & [QLD]SERNUM   =[M:STW]SERNUM(I)
&                      & [QLD]OWNER    =[M:STW]OWNER(I)
&                      & [QLH]PJT      =[M:STW]PJT
&                      & [QLH]VALFLG  <>2
      [L]WANA=[F:QLD]VCRNUM : [M:STW]QLYCTLDEM(I)=[F:QLD]VCRNUM : Break
    Next
    Columns [QLX]
    If [M:STW]QLYCTLDEM(I)<>""  Return : Endif
  Endif
Endif
#----- Création d'une nouvelle demande d'analyse -----#
GPOINT="GENANA" : Gosub ENTREE From EXEFNC
If [L]WANA=""
  If [M:STW]QLYCTLDEM(I)<>""
    [L]WANA=[M:STW]QLYCTLDEM(I) : # Recréation demande d'analyse disparue
    If [M:STW]STOCOU(I)<>0
      [L]WFIC="STOCK"
      [L]WCLE=[L]WFCY-num$([M:STW]STOCOU(I))
      Read [STO] STO0=[L]WFCY;[M:STW]STOCOU(I)
      If !fstat
        [L]WQTYPCU_QLY+=[F:STO]QTYPCU
        [L]WQTYSTU_QLY+=[F:STO]QTYSTU
      Else
        Call RSTA("STO",[L]WCLE) From GLOCK
        [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
      Endif
    Endif
  Else
    Call NUMERO(GSTKCPT(1),[L]WFCY,[M:STW]IPTDAT,"",[L]WANA,[L]WRET) From SUBANM
    If GOK<0
      [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
    Elsif GOK<1 | [L]WRET<>0
      [M:STW]ERRCOD=50 : [L]WCTEUR=GSTKCPT(1) : Gosub TRT_ERR : Return
    Endif
    [M:STW]QLYCTLDEM(I)=[L]WANA
  Endif
  #----- Ecriture contrôle qualité (demande d'analyse) -----#
  Raz [F:QLH]
  nolign=I+1 : [F:QLH]=[M:STW]
  [F:QLH]VCRTYP   =28
  [F:QLH]VCRNUM   =[L]WANA
  [F:QLH]STOFCY   =[L]WFCY
  [F:QLH]ITMREF   =[L]WITMREF
#  [F:QLH]VCRTYPORI=[M:STW]VCRTYP                                               # TS_BESIN
#  [F:QLH]VCRNUMORI=[M:STW]VCRNUM                                               # TS_BESIN
  [F:QLH]VCRTYPORI=[L]WVCRTYPANA                                                # TS_BESIN
  [F:QLH]VCRNUMORI=[L]WVCRNUMANA                                                # TS_BESIN
  [F:QLH]TRSCOD   =[M:STW]TRSCOD
  [F:QLH]ENDCTLDAT=[M:STW]IPTDAT+[F:ITF]QUALTI

  #--- Bug 64766
  #--- Décalage date fin de contrôle si jour non ouvré
  Call CTL_JOU([F:QLH]ENDCTLDAT,[F:FCY]UVYDAY,[F:FCY]UVYCOD,0) From CONTX3

# [F:QLH]QLYCRD   =[F:ITM]QLYCRD                    # hcb V6CQ
  [F:QLH]VALFLG   =1
  Call ECRQLH From STKLIB
  If fstat
    Call FSTA("QLH") From GLOCK
    [M:STW]ERRCOD=70 : [L]WFIC="STOQLYH" : Gosub TRT_ERR : Return
  Endif
  If [M:STW]TRAFLG>1
    #----- Demande d'analyse XXXXXXX YYYYYYY ZZZZZ créée ! -----#
    [L]WMESSAGE=mess(469,197,1)-"28"-[L]WANA-[L]WFCY-[L]WITMREF-mess(224,197,1)
    Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
    If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
  Endif
Else
  [M:STW]QLYCTLDEM(I)=[L]WANA
Endif
Return



#-----------------------------------------------------#
# Mise à jour mvt en attente dans le cas d'une entrée #
#-----------------------------------------------------#
$MAJENT_WAI
If [M:STW]MAJCOD(I)="C"  [L]WNBRWAI_RCP+=1 : Endif
Gosub MAJ_WAI
Return


#-----------------------------------------------------#
# Mise à jour mvt en attente dans le cas d'une sortie #
#-----------------------------------------------------#
$MAJSOR_WAI
If [M:STW]MAJCOD(I)="C"  [L]WNBRWAI_ISS+=1 : Endif
#----- Gestion des nos série, la quantité doit être un nombre entier -----#
If [F:ITM]SERMGTCOD>1
  If mod([M:STW]QTYSTU(I),1)
    [M:STW]ERRCOD=18 : Gosub TRT_ERR : Return
  Endif
  #-----
  [L]WSERNUM =[M:STW]SERNUM(I)
  [L]WSERNUMF=[M:STW]SERNUMF(I)
Endif
#----- Pas de gestion de no série, la champ doit être vide -----#
If [F:ITM]SERMGTCOD<2 & [M:STW]SERNUM(I)<>""
  [M:STW]ERRCOD=32 : Gosub TRT_ERR : Return
Endif
#-----
If [M:STW]SERNUM(I)<>""
  #----- Contrôle correspondance qté et no série renseignés -----#
  [L]WNBRSER=val(ctrans([L]WSERNUMF,sigma(J=1,47,chr$(J))+sigma(J=58,255,chr$(J)),""))
&           -val(ctrans([L]WSERNUM,sigma(J=1,47,chr$(J))+sigma(J=58,255,chr$(J)),""))+1
  If [L]WNBRSER<>abs([M:STW]QTYSTU(I))
    [M:STW]ERRCOD=31 : Gosub TRT_ERR : Return
  Endif
  Gosub MAJ_WAI
Else
  Gosub MAJ_WAI
Endif
Return


#----------------------------#
# Mise à jour mvt en attente #
#----------------------------#
$MAJ_WAI
If [M:STW]MAJCOD(I)="C"
  #----- Création du mouvement en attente -----#
  Case [L]WFLUX
    When 1 : [L]WQTYWAI_RCP-=[M:STW]QTYSTUACT(I)*[L]SIGN : # Cumul entrées en attente
    When 2 : [L]WQTYWAI_ISS-=[M:STW]QTYSTUACT(I)*[L]SIGN : # Cumul sorties en attente
  Endcase
  [L]WREGFLG=1
  [L]WTRSTYP=[M:STW]TRSTYP : Gosub ECRSTJ : # Ecriture mvt en attente
  If GOK<1  Return : Endif
Else
  #----- Régularisation ou suppression du mouvement en attente -----#
  [L]WFIC ="STOJOU"
  [L]WCLE =[L]WFCY-"1"-[L]WITMREF-num$([M:STW]IPTDAT)-num$([M:STW]MVTSEQ(I))
  [L]WCLE-=num$([M:STW]MVTIND(I))
  Readlock [STJ] STJ0=[L]WFCY;1;[L]WITMREF;[M:STW]IPTDAT;[M:STW]MVTSEQ(I);[M:STW]MVTIND(I)
  If fstat=1
    GLOCK="$STOJOU"-[L]WCLE
    [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
  Elsif fstat
    Call RSTA("STJ",[L]WCLE) From GLOCK
    [M:STW]ERRCOD=60 : Gosub TRT_ERR : Return
  Endif
  If [F:STJ]ACTQTY+[M:STW]QTYSTUACT(I)*[L]SIGN>=0
    [L]WQTYWAI_ISS+=[F:STJ]ACTQTY
    Delete  [STJ] : [L]WMESSAGE=mess(175,197,1)
  Else
    [L]WQTEACT=[M:STW]QTYSTUACT(I)*[L]SIGN
    [F:STJ]AMTORD-=arr(([F:STJ]AMTORD*[L]WQTEACT)/[F:STJ]ACTQTY,WRND_SOC)
    [F:STJ]AMTVAL-=arr(([F:STJ]AMTVAL*[L]WQTEACT)/[F:STJ]ACTQTY,WRND_SOC)
    [F:STJ]VARORD-=arr(([F:STJ]VARORD*[L]WQTEACT)/[F:STJ]ACTQTY,WRND_SOC)
    [F:STJ]VARVAL-=arr(([F:STJ]VARVAL*[L]WQTEACT)/[F:STJ]ACTQTY,WRND_SOC)
    [F:STJ]ACTQTY+=[M:STW]QTYSTUACT(I)*[L]SIGN
    [F:STJ]QTYPCU =[F:STJ]ACTQTY
    [F:STJ]QTYSTU =[F:STJ]ACTQTY
    [L]WQTYWAI_ISS-=[M:STW]QTYSTUACT(I)*[L]SIGN
    Rewrite [STJ] : [L]WMESSAGE=mess(232,197,1)
  Endif
  If fstat
    Call FSTA("STJ") From GLOCK
    [M:STW]ERRCOD=70 : [L]WFIC="STOJOU" : Gosub TRT_ERR : Return
  Endif
  If [M:STW]TRAFLG>2  Gosub TRACE_DETAILLEE From STKMAJSUP : Endif
Endif
Return



#----------------------------------#
# Recherche mvt d'inventaire bidon #
#----------------------------------#
$CLESTJINV
Filter [STJ] Where STOFCY   =[L]WFCY
&                & UPDCOD   =2
&                & ITMREF   =[L]WITMREF
&                & IPTDAT   =[M:STW]IPTDAT
&                & MVTIND   =0
&                & VCRTYP   =9
&                & VCRNUM   =[M:STW]VCRNUM
&                & VCRNUMORI=[M:STW]VCRNUMORI
&                & REGFLG   =2
Read [STJ] STJ0 First
If !fstat
  [L]WCTR_MVTSEQ=[F:STJ]MVTSEQ
  [L]WCTR_MVTIND=99999999
Else
  Call RSTA("STJ",[L]WFCY-"2"-[L]WITMREF-num$([M:STW]IPTDAT)) From GLOCK
  [M:STW]ERRCOD=43 : Gosub TRT_ERR
Endif
Filter [STJ]
Filter [STJ] Where STOFCY   =[L]WFCY
&                & UPDCOD   =2
&                & ITMREF   =[L]WITMREF
&                & IPTDAT   =[M:STW]IPTDAT
&                & MVTSEQ   =[L]WCTR_MVTSEQ
&                & MVTIND   >0
Read [STJ] STJ0 First
If !fstat
  [L]WCTR_MVTIND=[F:STJ]MVTIND-1
Endif
Filter [STJ]
Return


#--------------------------------------------#
# Splittage d'une ligne lorsque le           #
# déconditionnement, rompu ou fractionnement #
# est partiel                                #
# Création d'une nouvelle ligne dans [M:STW] #
#--------------------------------------------#
$SPLITTAGE

Raz [L]WSPLFLG
#----- Recherche code fractionnement -----#
If find([F:STO]PCU,[F:ITM]PCU)
  [L]WPCURUL=[F:ITM]PCURUL(find([F:STO]PCU,[F:ITM]PCU)-1)
  If [L]WPCURUL<1 | [L]WPCURUL>3  [L]WPCURUL=1 : Endif
Else
  [L]WPCURUL=1
Endif

If [L]WPCURUL=1
  # Si déconditionnement, recherche s'il est nécessaire selon les décimales UC
  Call CTRQTYPCU([F:STO]PCU,[F:STO]PCUSTUCOE,[M:STW]QTYSTU(I),[L]WQTYSTUARR) From STKLIB
  If [M:STW]QTYSTU(I)=[L]WQTYSTUARR
     Raz [L]WPCURUL : Return
  Endif
Endif

#----- Pas de splittage si fractionnement -----#
If [L]WPCURUL=3
  Raz [L]WPCURUL : Return : # Splittage inutile, on s'en va !
Else
  Raz [L]WPCURUL
Endif
#-----

#--- Bug 61604
WSPLITPCU=mod([M:STW]QTYSTU(I),[F:STO]PCUSTUCOE)/[M:STW]PCUSTUCOE(I)
WSPLITSTU=arr([L]WSPLITPCU*[M:STW]PCUSTUCOE(I),10^-[L]WDEC_US)
If WSPLITSTU=0 Return Endif
#---

If I+1 >= dim([M:STW]TRSTYPLIG)-1
   [M:STW]ERRCOD=46 : Gosub TRT_ERR : Return
Endif

[L]WSPLFLG=1
Insa I+1,1,[M:STW]NBLIG+1 [M:STW]NBLIG : [M:STW]NBLIG+=1

#--- Bug 24085 : TS le 24.08.04 ---
[M:STW]STOCOU(I+1)   =[M:STW]STOCOU(I)
L=I
Gosub ALI_NEW_STW

[M:STW]QTYPCU(I)=mod([M:STW]QTYSTU(I),[F:STO]PCUSTUCOE)/[M:STW]PCUSTUCOE(I)
#[M:STW]QTYPCU(I)=fix([M:STW]QTYSTU(I)/[F:STO]PCUSTUCOE)
[L]WQTE         =[M:STW]QTYPCU(I)
#If [M:STW]PCUSTUCOE(I)<>[F:STO]PCUSTUCOE
#  [L]WQTE=[L]WQTE*[F:STO]PCUSTUCOE/[M:STW]PCUSTUCOE(I)
#Endif
[M:STW]QTYSTU(I)   =arr([L]WQTE*[M:STW]PCUSTUCOE(I),10^-[L]WDEC_US)
[M:STW]QTYSTUACT(I)=arr([M:STW]QTYSTUACT(I)*[M:STW]QTYSTU(I)/[M:STW]QTYSTU(I+1)
&                       ,10^-[L]WDEC_US)
#[M:STW]PCU(I)      =[F:STO]PCU
#[M:STW]PCUSTUCOE(I)=[F:STO]PCUSTUCOE

If [M:STW]QTYSTU(I+1)<>0
    Call SPLIT_SVW(I,([M:STW]QTYSTU(I+1)-[M:STW]QTYSTU(I))/[M:STW]QTYSTU(I+1)) From STKVALMAJ
Endif

[M:STW]QTYPCU(I+1)   -=[L]WQTE
[M:STW]QTYSTU(I+1)   -=[M:STW]QTYSTU(I)
[M:STW]QTYSTUACT(I+1)-=[M:STW]QTYSTUACT(I)

# Quantité restant à traiter après splittage (non déconditionnée ou rompue)
[L]WSPLITQTY = [M:STW]QTYSTU(I+1)

Return

$ALI_NEW_STW
[M:STW]ITMREFLIG(L+1)=[M:STW]ITMREFLIG(L)
[M:STW]TRSTYPLIG(L+1)=[M:STW]TRSTYPLIG(L)
[M:STW]STU(L+1)      =[M:STW]STU(L)
[M:STW]MVTSEQ(L+1)   =[M:STW]MVTSEQ(L)
[M:STW]MVTIND(L+1)   =[M:STW]MVTIND(L)
[M:STW]CSTDAT(L+1)   =[M:STW]CSTDAT(L)
[M:STW]CSTTIM(L+1)   =[M:STW]CSTTIM(L)
[M:STW]CSTCOU(L+1)   =[M:STW]CSTCOU(L)
[M:STW]WAIFLG(L+1)   =[M:STW]WAIFLG(L)
[M:STW]LOT(L+1)      =[M:STW]LOT(L)
[M:STW]SLO(L+1)      =[M:STW]SLO(L)
[M:STW]BPSLOT(L+1)   =[M:STW]BPSLOT(L)
[M:STW]STA(L+1)      =[M:STW]STA(L)
[M:STW]LOC(L+1)      =[M:STW]LOC(L)
[M:STW]LOCTYP(L+1)   =[M:STW]LOCTYP(L)
[M:STW]LOCCAT(L+1)   =[M:STW]LOCCAT(L)
[M:STW]LOCDES(L+1)   =[M:STW]LOCDES(L)
[M:STW]LOCDESTYP(L+1)=[M:STW]LOCDESTYP(L)
[M:STW]LOCDESCAT(L+1)=[M:STW]LOCDESCAT(L)
[M:STW]WRH(L+1)      =[M:STW]WRH(L)
[M:STW]WRHDES(L+1)   =[M:STW]WRHDES(L)
[M:STW]SERNUM(L+1)   =[M:STW]SERNUM(L)
[M:STW]SERNUMF(L+1)  =[M:STW]SERNUMF(L)
[M:STW]REFPER(L+1)   =[M:STW]REFPER(L)
[M:STW]SHL(L+1)      =[M:STW]SHL(L)
[M:STW]SHLDAT(L+1)   =[M:STW]SHLDAT(L)
[M:STW]SHLUOM    (L+1)  =[M:STW]SHLUOM   (L)
[M:STW]SHLLTI    (L+1)  =[M:STW]SHLLTI   (L)
[M:STW]SHLLTIUOM (L+1)  =[M:STW]SHLLTIUOM(L)
[M:STW]NEWLTIDAT (L+1)  =[M:STW]NEWLTIDAT(L)
[M:STW]DLU       (L+1)  =[M:STW]DLU      (L)
[M:STW]DLUDAT    (L+1)  =[M:STW]DLUDAT   (L)
[M:STW]POT(L+1)      =[M:STW]POT(L)
[M:STW]ACT(L+1)      =[M:STW]ACT(L)
[M:STW]PALNUM(L+1)   =[M:STW]PALNUM(L)
[M:STW]CTRNUM(L+1)   =[M:STW]CTRNUM(L)
[M:STW]OWNER(L+1)    =[M:STW]OWNER(L)
[M:STW]USRFLD1(L+1)  =[M:STW]USRFLD1(L)
[M:STW]USRFLD2(L+1)  =[M:STW]USRFLD2(L)
[M:STW]USRFLD3(L+1)  =[M:STW]USRFLD3(L)
[M:STW]USRFLD4(L+1)  =[M:STW]USRFLD4(L)
[M:STW]QTYSTU(L+1)   =[M:STW]QTYSTU(L)
[M:STW]QTYSTUACT(L+1)=[M:STW]QTYSTUACT(L)
[M:STW]PCU(L+1)      =[M:STW]PCU(L)
[M:STW]QTYPCU(L+1)   =[M:STW]QTYPCU(L)
[M:STW]PCUSTUCOE(L+1)=[M:STW]PCUSTUCOE(L)
[M:STW]PCUORI(L+1)   =[M:STW]PCUORI(L)
[M:STW]PCUSTUORI(L+1)=[M:STW]PCUSTUORI(L)
[M:STW]PRIORD(L+1)   =[M:STW]PRIORD(L)
[M:STW]PRIVAL(L+1)   =[M:STW]PRIVAL(L)
[M:STW]PRINAT(L+1)   =[M:STW]PRINAT(L)
[M:STW]QLYCTLDEM(L+1)=[M:STW]QLYCTLDEM(L)
[M:STW]QLYCTLFLG(L+1)=[M:STW]QLYCTLFLG(L)
[M:STW]LBEFMT(L+1)   =[M:STW]LBEFMT(L)
[M:STW]LBENBR(L+1)   =[M:STW]LBENBR(L)
#--- Bug 71421
[M:STW]QUAFLG(L+1)   =[M:STW]QUAFLG(L)
[M:STW]QUAFRE(L+1)   =[M:STW]QUAFRE(L)
[M:STW]ACTORI(L+1)   =[M:STW]ACTORI(L)
[M:STW]POTORI(L+1)   =[M:STW]POTORI(L)
[M:STW]QTYACTORI(L+1)=[M:STW]QTYACTORI(L)
#---

For IA=1 To 20
  If evalue("dim([M:STW]CCE"+num$(IA)+")") >0
    Assign "[M:STW]CCE"+num$(IA)+"(L+1)" With evalue("[M:STW]CCE"+num$(IA)+"(L)")
  Endif
Next IA

[M:STW]MAJTYP(L+1)   =[M:STW]MAJTYP(L)
[M:STW]MAJCOD(L+1)   =[M:STW]MAJCOD(L)

Return
#--- Fin Bug 24085 : TS le 24.08.04 ---

#-----------------------------------------------------#
# Déconditionnement ou rompu (recalcul du coef UC-US) #
# --------------------------------------------------- #
# [L]WPCURUL: Type de fractionnement                  #
#                1 = Déconditionnement                #
#                2 = Rompu                            #
# [L]WQTE   : Qté restante non fractionnée en US      #
# [L]WQTE1  : Qté restante non fractionnée en UC      #
# [L]WQTE2  : Qté fractionnée en UC                   #
# [L]WWIPQTY: Cumul des qtés bloquées                 #
# [L]WALLQTY: Partie de la qté allouée à faire suivre #
#             sur nouvelle ligne fractionnée          #
# [L]WALLQTA: Idem mais en unité active               #
#-----------------------------------------------------#
$DECONDITION_ROMPU

[L]WPCU_ORI      =[F:STO]PCU
[L]WPCUSTUCOE_ORI=[F:STO]PCUSTUCOE
#----- Calcul des quantités bloquées -----#
Raz [L]WWIPQTY
If GWIPSTOLCK=2
  For [TWS] TWS0 Where STOCOU=[F:STO]STOCOU
    [L]WWIPQTY+=[F:TWS]WIPQTY
  Next
Endif
#-----
[L]WQTE1=fix(([F:STO]QTYSTU+[M:STW]QTYSTU(I)*[L]SIGN)/[F:STO]PCUSTUCOE)
[L]WQTE2=[F:STO]QTYPCU-[L]WQTE1
[L]WQTE =arr([L]WQTE1*[F:STO]PCUSTUCOE,10^-[L]WDEC_US)
# Quantité restante (en US) sur ligne de stock non fractionnée
# après maj du ou des deux [STW]
[L]WQTER=max([L]WQTE+[L]WSPLITQTY*[L]SIGN,0)

#----- Les quantités bloquées ne peuvent pas être fractionnées -----#
If [L]WQTE<[F:STO]CUMWIPQTY+[L]WWIPQTY
  [M:STW]ERRCOD=37 : Gosub TRT_ERR : Return
Endif
#-----
[L]WQTYPCU   =-[L]WQTE2
[L]WQTYSTU   =arr([L]WQTYPCU*[F:STO]PCUSTUCOE,10^-[L]WDEC_US)
[L]WQTYSTUACT=[L]WQTYSTU
[L]WALLQTY   =max([F:STO]CUMALLQTY-([L]WQTER-([F:STO]CUMWIPQTY+[L]WWIPQTY)),0)
[L]WALLQTA   =[L]WALLQTY
Case [F:ITF]STOMGTCOD
  When 3 : If [F:STL]POT<>0
             [L]WQTYSTUACT=arr([L]WQTYSTU*[F:STL]POT/100,10^-[L]WDEC_US)
             [L]WALLQTA   =arr([L]WALLQTY*[F:STL]POT/100,10^-[L]WDEC_US)
           Endif
  When 4 : If [F:STL]ACT<>0
             [L]WQTYSTUACT=arr([L]WQTYSTU*[F:STL]ACT,10^-[L]WDEC_US)
             [L]WALLQTA   =arr([L]WALLQTY*[F:STL]ACT,10^-[L]WDEC_US)
           Endif
Endcase


#--- TS le 07.06.04 ---#
# Si type de mouvement autre que contrôle qualité et
# ligne de stock avec demande d'analyse, il faut la mettre à jour
If [M:STW]TRSTYP<>8 & [F:STO]QLYCTLDEM<>""
  # Récupération du no ligne correspondant à la ligne de stock traitée
  Filter [QLD] Where VCRTYP   =28
&                  & VCRNUM   =[F:STO]QLYCTLDEM
&                  & LOT      =[F:STO]LOT
&                  & SLO      =[F:STO]SLO
&                  & SERNUM   =[F:STO]SERNUM
&                  & PALNUM   =[F:STO]PALNUM
&                  & CTRNUM   =[F:STO]CTRNUM
&                  & STA      =[F:STO]STA
&                  & LOC      =[F:STO]LOC
&                  & PCU      =[F:STO]PCU
&                  & PCUSTUCOE=[F:STO]PCUSTUCOE
&                  & OWNER    =[F:STO]OWNER
  Read [QLD]QLD2 First
  If !fstat WQLDLIN1=[F:QLD]VCRLIN Endif
  Filter [QLD]
Endif
#--- TS ---#


#----- Eclatement de la ligne de stock -----#
[L]WSTOCOU_SVG   =[F:STO]STOCOU      : # Pour màj des allocations
[L]WQLYCTLDEM_SVG=[F:STO]QLYCTLDEM
[L]WQTEACT       =[L]WQTYSTUACT      : # Pour le plan de rangement
[F:STO]QTYPCU   +=[L]WQTYPCU
[F:STO]QTYSTU   +=[L]WQTYSTU
[F:STO]QTYSTUACT+=[L]WQTYSTUACT
[F:STO]CUMALLQTY-=[L]WALLQTY
[F:STO]CUMALLQTA-=[L]WALLQTA
#----- Réécriture ligne stock qtés restantes avec le même conditionnement -----#
Gosub REWSTO : If GOK<1  Return : Endif


#--- TS le 07.06.04 ---#
If [M:STW]TRSTYP<>8 & [F:STO]QLYCTLDEM<>""
  If [F:STO]QTYSTU<>0
    # Ecriture d'un nouveau détail d'analyse à partir de l'ancien
    [F:QLD]QTYSTU   =[F:STO]QTYSTU
    [F:QLD]QTYPCU   =[F:STO]QTYPCU
    [F:QLD]PCUSTUCOE=[F:STO]PCUSTUCOE
    [F:QLD]CRDFLG   =2
    Call ECRQLD From STKLIB
    If fstat
      Call FSTA("QLD") From GLOCK
      [M:STW]ERRCOD=70 : Gosub TRT_ERR : Return
    Endif
    # Ecriture des réponses
    For [QLA] Where QLYCTLDEM=[F:QLD]VCRNUM & VCRLIN=WQLDLIN1 With Stability
      [F:QLA1]=[F:QLA]
      [F:QLA1]VCRLIN=[F:QLD]VCRLIN
      Write [QLA1]
    Next
  Endif
Endif
#--- TS ---#


#----- Création du mouvement de sortie de la partie à fractionner -----#
[L]WREGFLG=2
[L]WPCU      =[F:STO]PCU
[L]WPCUSTUCOE=[F:STO]PCUSTUCOE
#----- Ne pas générer de mouvement de sortie si déconditionnement -----#
#If [L]WPCURUL<>2
#  [L]WTRSTYP=96 : Gosub ECRSTJ : If GOK<1  Return : Endif
#Endif
#----- Si plan de rangement et flux de sortie -----#
If [M:STW]TRSTYP=22 & [L]WFLUX=2
  Gosub SPEC_SRG2 : If GOK<1  Return : Endif
Endif
#----- Traitement ligne de stock avec qté déconditionnée -----#
[L]WQTYPCU_ORI=-[L]WQTYPCU
[L]WQTYSTU_ORI=-[L]WQTYSTU
#-----
[L]WQTYSTU=arr([L]WQTE2*[F:STO]PCUSTUCOE,10^-[L]WDEC_US)
If [L]WPCURUL=1               : # Déconditionnement
  [L]WPCU      =[M:STW]STU(I)
  [L]WPCUSTUCOE=1
  [L]WQTYPCU   =[L]WQTYSTU
  #--- TS le 24.08.04 remis le 01.09.04
  [M:STW]PCU(I)      =[M:STW]STU(I)
  [M:STW]QTYPCU(I)   =[M:STW]QTYSTU(I)
  [M:STW]PCUSTUCOE(I)=1
Else                          : # Rompu
  [L]WPCU      =[F:STO]PCU
  [L]WPCUSTUCOE=arr([L]WQTYSTU+[M:STW]QTYSTU(I)*[L]SIGN,10^-6)

  # Modif TS le 04.06.04
  [L]WQTYPCU   =1
  [L]WQTYSTU   =[L]WPCUSTUCOE
  #[L]WQTYPCU   =1-([M:STW]QTYSTU(I)/[L]WPCUSTUCOE*[L]SIGN)
  #--- TS le 24.08.04 remis le 01.09.04
  [M:STW]PCU(I)      =[M:STW]STU(I)
  [M:STW]QTYPCU(I)   =[M:STW]QTYSTU(I)
  [M:STW]PCUSTUCOE(I)=1
Endif
[L]WQTYSTUACT=[L]WQTYSTU
Case [F:ITF]STOMGTCOD
  When 3 : If [F:STL]POT<>0
             [L]WQTYSTUACT=arr([L]WQTYSTU*[F:STL]POT/100,10^-[L]WDEC_US)
           Endif
  When 4 : If [F:STL]ACT<>0
             [L]WQTYSTUACT=arr([L]WQTYSTU*[F:STL]ACT,10^-[L]WDEC_US)
           Endif
Endcase
Raz [M:STW]STOCOU(I)

# Si déconditionnement
If [L]WPCURUL=1
  GPOINT="PCU_IDENT"
  Gosub ENTREE From EXEFNC
Endif

#----- Recherche existence ligne de stock avec les mêmes caractéristiques -----#
nolign=I+1 : [F:STJ1]=[M:STW]
[F:STJ1]PCU      =[L]WPCU
[F:STJ1]PCUSTUCOE=[L]WPCUSTUCOE
Call CLESTO([L]WFCY,[L]WITMREF,[F:STJ1]LOT,[F:STJ1]SLO,[F:STJ1]BPSLOT,
&           [F:STJ1]PALNUM,[F:STJ1]CTRNUM,[F:STJ1]STA,[F:STJ1]LOC,[F:STJ1]PCU,
&           [F:STJ1]PCUSTUCOE,[F:STJ1]SERNUM,[F:STJ1]QLYCTLDEM,[F:STJ1]OWNER,
&           [L]WSTOCOU) From STKLIB
[M:STW]STOCOU(I)=[L]WSTOCOU

#----- Création d'une nouvelle ligne de stock -----#
If [L]WSTOCOU=0
  #----- Attribution du chrono stock -----#
  Call NUMERO(GSTKCPT(0),[L]WFCY,[M:STW]IPTDAT,"",[L]WPARAM,[L]WRET) From SUBANM
  If GOK<0
    [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
  Elsif GOK<1 | [L]WRET<>0
    [M:STW]ERRCOD=50 : [L]WCTEUR=GSTKCPT(0)  : Gosub TRT_ERR : Return
  Endif
  [M:STW]STOCOU(I)=val(WPARAM)
  [L]WSTOCOU      =val(WPARAM)
  #----- Chargement et écriture ligne de stock avec qté fractionnée -----#
  Raz [F:STO]
  nolign=I+1 : [F:STO]=[M:STW]

  [F:STO]STOFCY   =[L]WFCY
  # Au cas où !
  If [F:STO]OWNER="" : [F:STO]OWNER=[L]WFCY : Endif
  [F:STO]ITMREF   =[L]WITMREF
  [F:STO]PCUORI   =[L]WPCU_ORI
  [F:STO]QTYPCUORI=[L]WQTYPCU_ORI
  [F:STO]QTYSTUORI=[L]WQTYSTU_ORI
  [F:STO]PCU      =[L]WPCU
  [F:STO]PCUSTUCOE=[L]WPCUSTUCOE
  [F:STO]QTYPCU   =[L]WQTYPCU
  [F:STO]QTYSTU   =[L]WQTYSTU
  [F:STO]QTYSTUACT=[L]WQTYSTUACT
  [F:STO]CUMALLQTY=[L]WALLQTY
  [F:STO]CUMALLQTA=[L]WALLQTA
  [F:STO]QLYCTLDEM=[L]WQLYCTLDEM_SVG
  #--- Bug 83861
  If [F:STO]PCU<>[F:ITM]STU : [F:STO]SERNUM="" : Endif
  Gosub ECRSTO : If GOK<1  Return : Endif
Else
  #----- Mise à jour ancienne ligne de stock avec qté fractionnée -----#
  [L]WFIC="STOCK"
  [L]WCLE=[L]WFCY-num$([L]WSTOCOU)
  Readlock [STO] STO0=[L]WFCY;[L]WSTOCOU
  If fstat=1
    GLOCK="$STOCK"-[L]WCLE
    [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
  Elsif fstat
    Call RSTA("STO",[L]WCLE) From GLOCK
    [M:STW]ERRCOD=60 : Gosub TRT_ERR : Return
  Endif
  [F:STO]QTYPCU   +=[L]WQTYPCU
  [F:STO]QTYSTU   +=[L]WQTYSTU
  [F:STO]QTYSTUACT+=[L]WQTYSTUACT
  [F:STO]CUMALLQTY+=[L]WALLQTY
  [F:STO]CUMALLQTA+=[L]WALLQTA
  If [F:STO]QTYSTU=0  [F:STO]QTYPCU=0 : Endif
  [L]WQTEACT=[L]WQTYSTUACT : # Pour le plan de rangement
  Gosub REWSTO : If GOK<1  Return : Endif
Endif


#--- TS le 07.06.04 ---#
If [M:STW]TRSTYP<>8 & [F:STO]QLYCTLDEM<>""
  [L]WCLE=[F:STO]QLYCTLDEM-num$(WQLDLIN1)
  Readlock [QLD]QLD0=28;[F:STO]QLYCTLDEM;WQLDLIN1
  If fstat=1
    GLOCK="$STOQLYD"-[L]WCLE
    [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
  Elsif fstat
    Call RSTA("QLD",[L]WCLE) From GLOCK
    [M:STW]ERRCOD=60 : Gosub TRT_ERR : Return
  Else
    # Si déconditionnement
    If [L]WPCURUL=1
      # Réécriture du détail d'analyse
      [F:QLD]QTYSTU   =[F:STO]QTYSTU
      [F:QLD]QTYPCU   =[F:STO]QTYPCU
      [F:QLD]PCU      =[F:STO]PCU
      [F:QLD]PCUSTUCOE=[F:STO]PCUSTUCOE
      Call REWQLD From STKLIB
      If fstat
        Call FSTA("QLD") From GLOCK
        [M:STW]ERRCOD=70 : Gosub TRT_ERR : Return
      Endif
    # Si rompu
    Else
      # Réécriture du détail d'analyse pour la qté traitée
      [F:QLD]QTYSTU   =[M:STW]QTYSTU(I)
      [F:QLD]QTYPCU   =[M:STW]QTYSTU(I)
      [F:QLD]PCU      =[M:STW]STU(I)
      [F:QLD]PCUSTUCOE=1
      Call REWQLD From STKLIB
      If fstat
        Call FSTA("QLD") From GLOCK
        [M:STW]ERRCOD=70 : Gosub TRT_ERR : Return
      Endif
      # Ecriture d'un nouveau détail d'analyse pour la nouvelle ligne de stock
      [F:QLD]QTYSTU   =[F:STO]QTYSTU
      [F:QLD]QTYPCU   =[F:STO]QTYPCU
      [F:QLD]PCU      =[F:STO]PCU
      [F:QLD]PCUSTUCOE=[F:STO]PCUSTUCOE
      [F:QLD]PCUSTUCOE=[F:STO]PCUSTUCOE
      [F:QLD]CRDFLG   =2
      Call ECRQLD From STKLIB
      If fstat
        Call FSTA("QLD") From GLOCK
        [M:STW]ERRCOD=70 : Gosub TRT_ERR : Return
      Endif
      # Ecriture des réponses
      For [QLA] Where QLYCTLDEM=[F:QLD]VCRNUM & VCRLIN=WQLDLIN1 With Stability
        [F:QLA1]=[F:QLA]
        [F:QLA1]VCRLIN=[F:QLD]VCRLIN
        Write [QLA1]
      Next
    Endif
  Endif
Endif
#--- TS ---#

#----- Création du mouvement d'entrée de la partie fractionnée -----#
# [L]WPCU      =[L]WPCU_ORI       : # à activer si le mvt d'entrée doit
# [L]WPCUSTUCOE=[L]WPCUSTUCOE_ORI : # correspondre strictement au mvt de
# [L]WQTYPCU   =[L]WQTE2          : # sortie et non à la nouvelle ligne stock créée
#----- Ne pas générer de mouvement d'entrée si déconditionnement -----#
#If [L]WPCURUL<>2
#  [L]WTRSTYP=96 : Gosub ECRSTJ : If GOK<1  Return : Endif
#Endif
#----- Relecture ligne de stock pour enfin effectuer la véritable sortie -----#
[L]WFIC="STOCK"
[L]WCLE=[L]WFCY-num$([L]WSTOCOU)
Readlock [STO] STO0=[L]WFCY;[L]WSTOCOU
If fstat=1
  GLOCK="$STOCK"-[L]WCLE
  [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
Elsif fstat
  Call RSTA("STO",[L]WCLE) From GLOCK
  [M:STW]ERRCOD=60 : Gosub TRT_ERR : Return
Endif
#----- Faire suivre d'éventuelles allocations sur la nouvelle ligne de stock -----#
If [L]WALLQTY<>0
  Gosub TRT_ALLOCATION : If GOK<1  Return : Endif

#--- Bug 86815
# Si série en sortie et mode de déstockage 'rompu'
# on fait suivre les [M:STW] liés au chrono stock supprimé vers le nouveau
Elsif [F:ITM]SERMGTCOD=2 & [L]WPCURUL=2 & I < dim([M:STW]ITMREFLIG)-1
  WI=I+1
  While [M:STW]ITMREFLIG(WI)<>""
    If [M:STW]STOCOU(WI)=[L]WSTOCOU_SVG
      [M:STW]STOCOU(WI)   =[L]WSTOCOU
      [M:STW]PCU(WI)      =[F:STO]PCU
      [M:STW]PCUSTUCOE(WI)=[F:STO]PCUSTUCOE
      [M:STW]QTYPCU(WI)   =[M:STW]QTYSTU(WI)/[M:STW]PCUSTUCOE(WI)
    Endif
    WI+=1
  Wend
#---

Endif

# Modif TS le 04.06.04
#----- Màj ligne de stock -----#
#If [L]WPCURUL=1
#  [F:STO]QTYPCU +=[M:STW]QTYPCU(I)*[M:STW]PCUSTUCOE(I)/[F:STO]PCUSTUCOE*[L]SIGN
#Else
#  [F:STO]QTYPCU +=[M:STW]QTYSTU(I)/[F:STO]PCUSTUCOE*[L]SIGN
#Endif
#[F:STO]QTYSTU   +=[M:STW]QTYSTU(I)*[L]SIGN
#[F:STO]QTYSTUACT+=[M:STW]QTYSTUACT(I)*[L]SIGN
# Maj de la ligne de stock si déconditionnement
# Si rompu, elle a déjà été mise à jour
If [L]WPCURUL=1
  [F:STO]QTYPCU   +=[M:STW]QTYPCU(I)*[M:STW]PCUSTUCOE(I)/[F:STO]PCUSTUCOE*[L]SIGN
  [F:STO]QTYSTU   +=[M:STW]QTYSTU(I)*[L]SIGN
  [F:STO]QTYSTUACT+=[M:STW]QTYSTUACT(I)*[L]SIGN
  [L]WQTEACT=[M:STW]QTYSTUACT(I)*[L]SIGN : # Pour le plan de rangement
Else
  Raz [L]WQTEACT : # Pas de maj du plan de rangement (le SRG n'a pas été créé)
Endif

#--- Bug 24085 : TS le 24.08.04 ---
# Si chgt emp, ctrl qualité, chgt statut, trf inter-site ou plan de rangement
If find([M:STW]TRSTYP,7,8,9,14,22)
   If I<[M:STW]NBLIG-1
      WNEWQTYSTU = [F:STO]QTYSTU
      # Si la somme des qtés restant à traiter pour ce chrono est > qté restant sur ce chrono
      #If sigma(J=I+1,[M:STW]NBLIG-1,[M:STW]QTYSTU(J)*([M:STW]STOCOU(J)=[M:STW]STOCOU(I))) > [L]WQTYSTU_ORI
      J=I+1
      While J<[M:STW]NBLIG & WNEWQTYSTU>0
         If [M:STW]STOCOU(J)=[L]WSTOCOU_SVG
            Gosub SPLIT_STW
            If GOK<1 Return Endif
         Endif
         J+=1
      Wend
      #Endif
   Endif
Endif

Return

$SPLIT_STW
# Si la ligne suivante à traiter n'est pas un nb entier d'UC
# et que le reste est <= la quantité de la ligne de stock créée
WRESQTYSTU = mod([M:STW]QTYSTU(J),[L]WPCUSTUCOE_ORI)

If WRESQTYSTU<>0 & WRESQTYSTU<=WNEWQTYSTU

   If J+1 >= dim([M:STW]TRSTYPLIG)
      [M:STW]ERRCOD=46 : Gosub TRT_ERR : Return
   Endif

   Insa J+1,1,[M:STW]NBLIG+1 [M:STW]NBLIG : [M:STW]NBLIG+=1

   [M:STW]STOCOU(J+1)    =[F:STO]STOCOU
   L=J
   Gosub ALI_NEW_STW

   [M:STW]QTYSTU(J)     -=WRESQTYSTU
   [M:STW]QTYPCU(J)     -=WRESQTYSTU/[M:STW]PCUSTUCOE(J)
   [M:STW]QTYSTUACT(J)   =arr([M:STW]QTYSTUACT(J+1)*[M:STW]QTYSTU(J)/
&                             [M:STW]QTYSTU(J+1),10^-[L]WDEC_US)

    If [M:STW]QTYSTU(J+1)<>0
        Call SPLIT_SVW(J,([M:STW]QTYSTU(J+1)-[M:STW]QTYSTU(J))/[M:STW]QTYSTU(J+1)) From STKVALMAJ
    Endif

   [M:STW]QTYSTU(J+1)   -=[M:STW]QTYSTU(J)
   [M:STW]QTYPCU(J+1)   -=[M:STW]QTYPCU(J)
   [M:STW]QTYSTUACT(J+1)-=[M:STW]QTYSTUACT(J)

   WNEWQTYSTU -= WRESQTYSTU

Endif

Return
#--- Fin Bug 24085 : TS le 24.08.04 ---


#------------------------------#
# Fractionnement (recalcul UC) #
#------------------------------#
$FRACTION
[L]WQTE=[F:STO]QTYPCU
[F:STO]QTYSTU   +=[M:STW]QTYSTU(I)*[L]SIGN
[F:STO]QTYSTUACT+=[M:STW]QTYSTUACT(I)*[L]SIGN
If [F:STO]PCUSTUCOE=0  [F:STO]PCUSTUCOE=1 : [M:STW]PCUSTUCOE(I)=1 : Endif
[F:STO]QTYPCU=[F:STO]QTYSTU/[F:STO]PCUSTUCOE
Call QTEARR ([F:STO]QTYPCU,[F:STO]PCU) From TRTDIV
[L]WQTEACT=[M:STW]QTYSTUACT(I)*[L]SIGN : # Pour le plan de rangement
Return


#-------------------------------------------------------------------------#
# Reconditionnement ou reconstitution d'un rompu (recalcul du coef UC-US) #
#-------------------------------------------------------------------------#
$RECONDITION_ENTIER
Raz [L]WRECOND
#----- Ne rien faire si les champs sont vides -----#
If [M:STW]PCUORI(I)="" | [M:STW]PCUSTUORI(I)=0  Return : Endif
#-----
If find([M:STW]PCUORI(I),[F:ITM]PCU)
  [L]WPCURUL=[F:ITM]PCURUL(find([M:STW]PCUORI(I),[F:ITM]PCU)-1)
  If [L]WPCURUL<1 | [L]WPCURUL>3  [L]WPCURUL=1 : Endif
Else
  [L]WPCURUL=1
Endif
If [L]WPCURUL=3  Return : Endif : # Si Fractionnement ne rien faire !
#----- Recherche ligne de stock résultant du déconditionnement -----#
nolign=I+1 : [F:STJ1]=[M:STW]
If [L]WPCURUL=2
  [F:STJ1]PCU      =[M:STW]PCUORI(I)
  [F:STJ1]PCUSTUCOE=[M:STW]PCUSTUORI(I)-[M:STW]QTYSTU(I)
Endif
Call CLESTO([L]WFCY,[L]WITMREF,[F:STJ1]LOT,[F:STJ1]SLO,[F:STJ1]BPSLOT,
&           [F:STJ1]PALNUM,[F:STJ1]CTRNUM,[F:STJ1]STA,[F:STJ1]LOC,[F:STJ1]PCU,
&           [F:STJ1]PCUSTUCOE,[F:STJ1]SERNUM,[F:STJ1]QLYCTLDEM,[F:STJ1]OWNER,
&           [L]WSTOCOU) From STKLIB
[M:STW]STOCOU(I)=[L]WSTOCOU

If [L]WSTOCOU=0  Return : Endif : # Ligne de stock non trouvée, ne rien faire !
#----- Contrôle que la quantité est suffisante pour reconstituer l'unité d'origine -----#
Read [STO] STO0=[L]WFCY;[L]WSTOCOU
Call STODIS("","","",[L]WQTE1,[L]WQTE2,[L]WQTEACT) From STKLIB
If [L]WQTE2<[M:STW]PCUSTUORI(I)-([M:STW]QTYSTU(I)*[L]SIGN)  Return : Endif
#----- Traitement du reconditionnement -----#
[L]WRECOND=1
[L]WFIC="STOCK"
[L]WCLE=[L]WFCY-num$([L]WSTOCOU)
Readlock [STO] STO0=[L]WFCY;[L]WSTOCOU
If fstat=1
  GLOCK="$STOCK"-[L]WCLE
  [M:STW]ERRCOD=99 : Gosub TRT_LCK From STKMAJ : Return
Elsif fstat
  Call RSTA("STO",[L]WCLE) From GLOCK
  [M:STW]ERRCOD=60 : Gosub TRT_ERR From STKMAJ : Return
Endif
#----- Réécriture ligne de stock -----#
If [L]WPCURUL=1 : # Déconditionnement
  [L]WQTE1  =[M:STW]PCUSTUORI(I)-([M:STW]QTYSTU(I)*[L]SIGN)
  [L]WQTE2  =[L]WQTE1
  [L]WQTEACT=arr([L]WQTE2*[F:STO]QTYSTUACT/[F:STO]QTYSTU,10^-[L]WDEC_US)
Else            : # Rompu
  [L]WQTE1  =1
  [L]WQTE2  =[F:STO]PCUSTUCOE
  [L]WQTEACT=arr([L]WQTE2*[F:STO]QTYSTUACT/[F:STO]QTYSTU,10^-[L]WDEC_US)
Endif
[F:STO]QTYPCU   -=[L]WQTE1
[F:STO]QTYSTU   -=[L]WQTE2
[F:STO]QTYSTUACT-=[L]WQTEACT
Gosub REWSTO From STKMAJ : If GOK<1  Return : Endif
[L]WRECOND=2
#----- Sauvegarde valeurs ligne écran -----#
[L]WQTYPCU   =[M:STW]QTYPCU(I)
[L]WQTYSTU   =[M:STW]QTYSTU(I)
[L]WQTYSTUACT=[M:STW]QTYSTUACT(I)
#----- Modif valeurs ligne écran pour màj ligne de stock (STOCK) -----#
[L]WQTEACT=arr([M:STW]PCUSTUORI(I)*[M:STW]QTYSTUACT(I)/[M:STW]QTYSTU(I),10^-[L]WDEC_US)
[M:STW]PCU(I)      =[M:STW]PCUORI(I)
[M:STW]PCUSTUCOE(I)=[M:STW]PCUSTUORI(I)
[M:STW]QTYPCU(I)   =1
[M:STW]QTYSTU(I)   =[M:STW]PCUSTUORI(I)
[M:STW]QTYSTUACT(I)=[L]WQTEACT
Return


#-------------------------------------------------#
# Mise à jour du contrôle qualité (table STOQLYD) #
#-------------------------------------------------#
$MAJ_STOQLYD
If [L]WANA<>"" & ([L]WQTYPCU_QLY<>0 | [L]WQTYSTU_QLY<>0)
  WCRIT = 'ITMREF=[L]WITMREF & STOFCY=[L]WFCY & VCRTYP=28 & VCRNUM=[L]WANA'
  #If [F:QLH]VCRTYPORI=[M:STW]VCRTYP & [F:QLH]VCRNUMORI=[M:STW]VCRNUM           # TS_BESIN
  #   [L]WVCRLIN=[M:STW]VCRLIN                                                  # TS_BESIN
  #   WCRIT += '&VCRLINORI=[M:STW]VCRLIN'                                       # TS_BESIN
  If [F:QLH]VCRTYPORI=[L]WVCRTYPANA & [F:QLH]VCRNUMORI=[L]WVCRNUMANA            # TS_BESIN
     [L]WVCRLIN=[L]WVCRLINANA                                                   # TS_BESIN
     WCRIT += '&VCRLINORI=[L]WVCRLINANA'                                        # TS_BESIN
  Else
     [L]WVCRLIN=0
  Endif
  # Si type mvt = changement d'emplacement
  # et (annulation du flux d'entrée ou création du flux de sortie)
  # les caractéristiques stock ne sont pas ds [M:STW]--> utiliser la ligne stock
  If [L]WMAJTYP="C" &
&  (([M:STW]MAJCOD(I)="A" & [L]WFLUX=1) | ([M:STW]MAJCOD(I)="C" & [L]WFLUX=2))
    #--- Bug 78767
    # Si rompu, il faut filter PCU et PCUSTUCOE avec STW
    If WPCURUL_QLD=2
      Filter [QLD] Where evalue(WCRIT)
&                    & LOT      =[F:STO]LOT
&                    & SLO      =[F:STO]SLO
&                    & PALNUM   =[F:STO]PALNUM
&                    & CTRNUM   =[F:STO]CTRNUM
&                    & STA      =[F:STO]STA
&                    & LOC      =[F:STO]LOC
&                    & PCU      =[M:STW]PCU(I)
&                    & PCUSTUCOE=[M:STW]PCUSTUCOE(I)
&                    & SERNUM   =[F:STO]SERNUM
&                    & OWNER    =[F:STO]OWNER
    Else
    #---
      Filter [QLD] Where evalue(WCRIT)
&                    & LOT      =[F:STO]LOT
&                    & SLO      =[F:STO]SLO
&                    & PALNUM   =[F:STO]PALNUM
&                    & CTRNUM   =[F:STO]CTRNUM
&                    & STA      =[F:STO]STA
&                    & LOC      =[F:STO]LOC
&                    & PCU      =[F:STO]PCU
&                    & PCUSTUCOE=[F:STO]PCUSTUCOE
&                    & SERNUM   =[F:STO]SERNUM
&                    & OWNER    =[F:STO]OWNER
    #--- Bug 78767
    Endif

  Else
    Filter [QLD] Where evalue(WCRIT)
&                    & LOT      =[M:STW]LOT(I)
&                    & SLO      =[M:STW]SLO(I)
&                    & PALNUM   =[M:STW]PALNUM(I)
&                    & CTRNUM   =[M:STW]CTRNUM(I)
&                    & STA      =[M:STW]STA(I)
&                    & LOC      =[M:STW]LOC(I)
&                    & PCU      =[M:STW]PCU(I)
&                    & PCUSTUCOE=[M:STW]PCUSTUCOE(I)
&                    & SERNUM   =[M:STW]SERNUM(I)
&                    & OWNER    =[M:STW]OWNER(I)
  Endif

  [L]WFIC="STOQLYD"
  [L]WCLE=""
  [L]WQTE1=[L]WQTYPCU_QLY
  [L]WQTE2=[L]WQTYSTU_QLY
  For [QLD] QLD1
    [L]WCLE=num$([F:QLD]VCRTYP)-[F:QLD]VCRNUM-num$([F:QLD]VCRLIN)-[F:QLD]STOFCY
    [L]WCLE-=[F:QLD]ITMREF
    Readlock [QLD] QLD1 Curr
    If fstat=1
      GLOCK="$STOQLYD"-[L]WCLE
      [M:STW]ERRCOD=99 : Gosub TRT_LCK : Break
    Elsif fstat
      Call RSTA("QLD",[L]WCLE) From GLOCK
      [M:STW]ERRCOD=60 : Gosub TRT_ERR : Break
    Endif

    #--- Bug 32696
    # Si type de flux : changement d'emplacement
    If [L]WCODFONC=3
      # Si réappro zones de conso
      # ou changement d'emplacement ou défractionnement
      # ou changement de statut et nouveau statut=Q
      # Svg no ligne document origine CQAL pour ne pas le perdre
#  40793  rajout | & [M:STW]TRSTYP=8 ligne 1785/6
      If [M:STW]TRSTYP=25 |
&       ([M:STW]TRSTYP=7 & (find([M:STW]TRSTYPLIG(I),7,21) |
&                          ([M:STW]TRSTYPLIG(I)=9 & left$([M:STW]STA(I),1)="Q"))) |
&       ([M:STW]TRSTYP=8 & left$([M:STW]STA(I),1)="Q")
        [L]WVCRLINORI = [F:QLD]VCRLINORI
      Else
        Raz [L]WVCRLINORI
      Endif
    Endif
    #---

    If [L]WVCRLIN=0 & ([L]WQTE1<0 | [L]WQTE2<0) & ([F:QLD]QTYPCU>0 | [F:QLD]QTYSTU>0)
      [L]WQTYPCU_QLY=-min([F:QLD]QTYPCU,abs([L]WQTE1))
      [L]WQTYSTU_QLY=-min([F:QLD]QTYSTU,abs([L]WQTE2))
    Else
      [L]WQTYPCU_QLY=[L]WQTE1
      [L]WQTYSTU_QLY=[L]WQTE2
    Endif
    #-----
    [F:QLD]QTYPCU+=[L]WQTYPCU_QLY
    [F:QLD]QTYSTU+=[L]WQTYSTU_QLY
    [L]WQTE1-=[L]WQTYPCU_QLY
    [L]WQTE2-=[L]WQTYSTU_QLY
    #----- Suppression ou réécriture de la ligne de demande d'analyse -----#

    #--- Bug 78767
    #If [F:QLD]QTYPCU=0 & [F:QLD]QTYSTU=0 & [L]WMAJCODSTO<>"M"
    If [F:QLD]QTYSTU=0 & [L]WMAJCODSTO<>"M"
    #---
      [L]WANALIN=[F:QLD]VCRLIN
      Delete [QLD] Where VCRTYP=28 & VCRNUM=[L]WANA & VCRLIN=[L]WANALIN
      If fstat=1
        GLOCK="$STOQLYD"-[L]WCLE
        [M:STW]ERRCOD=99 : Gosub TRT_LCK : Break
      Elsif fstat
        Call FSTA("QLD") From GLOCK
        [M:STW]ERRCOD=60 : Gosub TRT_ERR : Break
      Endif
      [L]WMESSAGE=mess(175,197,1)
    Else
      Call REWQLD From STKLIB
      If fstat
        Call FSTA("QLD") From GLOCK
        [M:STW]ERRCOD=70 : Gosub TRT_ERR : Break
      Endif
      #----- Avertissement si quantité négative -----#
      If [F:QLD]QTYSTU<0 & [M:STW]TRAFLG>2
        [L]WMESSAGE="28"-[F:QLD]VCRNUM-num$([F:QLD]VCRLIN)-mess(557,197,1)
        Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
        If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
      Endif
      #-----
      [L]WMESSAGE=mess(232,197,1)
    Endif
    If [M:STW]TRAFLG>2
      Gosub TRACE_DETAILLEE From STKMAJSUP
    Endif
    #--- Bug 78767
    #If [L]WQTE1=0 & [L]WQTE2=0  Break : Endif
    If [L]WQTE2=0  Break : Endif
    #---
  Next
  Filter [QLD] : If GOK<1  Return : Endif
  #----- Création de la ligne de demande d'analyse -----#
  If [L]WCLE=""
    Gosub CRE_STOQLYD : Raz [L]WQTE1, [L]WQTE2 : If GOK<1  Return : Endif
  Endif
  #----- Prise en compte du reliquat si nécessaire -----#
  If [L]WQTE1<>0 | [L]WQTE2<>0
    Readlock [QLD] QLD1 Curr
    If fstat=1
      GLOCK="$STOQLYD"-[L]WCLE
      [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
    Elsif fstat
      Call RSTA("QLD",[L]WCLE) From GLOCK
      [M:STW]ERRCOD=60 : Gosub TRT_ERR : Return
    Endif
    [F:QLD]QTYPCU+=[L]WQTE1
    [F:QLD]QTYSTU+=[L]WQTE2
    Raz WQTE1, WQTE2
    Call REWQLD From STKLIB
    If fstat
      Call FSTA("QLD") From GLOCK
      [M:STW]ERRCOD=70 : Gosub TRT_ERR : Return
    Endif
    #----- Avertissement si quantité négative -----#
    If [F:QLD]QTYSTU<0 & [M:STW]TRAFLG>2
      [L]WMESSAGE="28"-[F:QLD]VCRNUM-num$([F:QLD]VCRLIN)-mess(557,197,1)
      Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
      If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
    Endif
    #-----
    [L]WMESSAGE=mess(232,197,1)
    If [M:STW]TRAFLG>2
      Gosub TRACE_DETAILLEE From STKMAJSUP
    Endif
  Endif

  # Si modification
  If [L]WMAJCOD="M"
    Goto MAJ_STOQLYD_SUI
  Endif
  # Si type de flux : changement d'emplacement
  If [L]WCODFONC=3
    # Si réappro zones de conso
    # ou Controle qualité  (trstyp = 8)       hcb 46221
    # ou changement d'emplacement ou défractionnement
    # ou changement de statut et nouveau statut=Q
    If [M:STW]TRSTYP=25 |
&      [M:STW]TRSTYP=8  |
&     ([M:STW]TRSTYP=7 & (find([M:STW]TRSTYPLIG(I),7,21) |
&                        ([M:STW]TRSTYPLIG(I)=9 & left$([M:STW]STA(I),1)="Q")))
       Goto MAJ_STOQLYD_SUI
    Endif
  Endif
  #----- Suppression de l'entête du contrôle qualité si plus de ligne -----#
  Filter [QLD] Where VCRTYP=28 & VCRNUM=[L]WANA
  Look [QLD] QLD0 First
  Filter [QLD]
  If fstat
    [L]WFIC="STOQLYH" : [L]WCLE="28"-[L]WANA
    Delete [QLH] Where VCRTYP=28 & VCRNUM=[L]WANA
    If fstat=1
      GLOCK="$STOQLYH"-[L]WCLE    : [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
    Elsif fstat
      Call FSTA("QLH") From GLOCK : [M:STW]ERRCOD=60 : Gosub TRT_ERR : Return
    Endif
    If [M:STW]TRAFLG>2
      [L]WMESSAGE=mess(175,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
    Endif
  Endif

  $MAJ_STOQLYD_SUI

Endif
Raz [L]WQTYPCU_QLY, [L]WQTYSTU_QLY
Return


#------------------------------------------------#
# Création enregistrement ligne contrôle qualité #
#------------------------------------------------#
$CRE_STOQLYD
Raz [F:QLD]

nolign=I+1 : [F:QLD]=[M:STW]
[F:QLD]VCRTYP   =28
[F:QLD]VCRNUM   =[L]WANA
[F:QLD]STOFCY   =[L]WFCY
[F:QLD]ITMREF   =[L]WITMREF
#--- Bug 32696
If [L]WVCRLINORI<>0
   [F:QLD]VCRLINORI=[L]WVCRLINORI
Else
   [F:QLD]VCRLINORI=[L]WVCRLIN
Endif
#[F:QLD]VCRLINORI=[L]WVCRLIN
#---
[F:QLD]QTYPCU   =[L]WQTYPCU_QLY
[F:QLD]QTYSTU   =[L]WQTYSTU_QLY
#          determination Fiche qualite           hcb V6CQ deb
If [M:STW]MISFLG = 9                # recontrole
   [F:QLD]QLYCRD   =[F:ITF]LTIQLYCRD
Else
   If [L]WVCRTYPANA  = 6            # reception
      If [M:STW]BPRNUM <> ""
         If [F:ITP]ITMREF<>[L]WITMREF | [F:ITP]BPSNUM<>[M:STW]BPRNUM
         # Positionnement dans la table ITMBPS
            If clalev([F:ITP]) = 0 Local File ITMBPS [ITP]: Endif
            Read [ITP]ITP0=[L]WITMREF;[M:STW]BPRNUM
            If fstat
               Raz [F:ITP]
            Endif
         Endif
         [F:QLD]QLYCRD   =[F:ITP]QLYCRD
      Endif
   Endif
Endif
If [F:QLD]QLYCRD = ""
   [F:QLD]QLYCRD   =[F:ITF]QLYCRD
Endif
#                                                hcb V6CQ fin
Call ECRQLD From STKLIB
If fstat
  Call FSTA("QLD") From GLOCK
  [M:STW]ERRCOD=70 : Gosub TRT_ERR : Return
Endif
If [M:STW]TRAFLG>2
  #----- Avertissement si quantité négative ! -----#
  If [F:QLD]QTYSTU<0
    [L]WMESSAGE="28"-[F:QLD]VCRNUM-num$([F:QLD]VCRLIN)-mess(557,197,1)
    Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
    If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
  Endif
  #-----
  [L]WCLE=num$([F:QLD]VCRTYP)-[F:QLD]VCRNUM-num$([F:QLD]VCRLIN)-[F:QLD]STOFCY
  [L]WCLE-=[F:QLD]ITMREF
  [L]WMESSAGE=mess(233,197,1)
  Gosub TRACE_DETAILLEE From STKMAJSUP
Endif
Return


#-----------------------------------------------------------#
# Purge du contrôle qualité lors d'une sortie en statut "Q" #
#-----------------------------------------------------------#
$PURGE_STOQLYD

GPOINT = "PURQLC"               #hcb 37703
GPE    = 0                      #hcb 37703
Gosub  ENTREE From EXEFNC       #hcb 37703
If GPE <> 0                     #hcb 37703
   Return                       #hcb 37703
Endif                           #hcb 37703

If [L]WQTYPCU_QLY=0 & [L]WQTYSTU_QLY=0  Return : Endif
#----- Reprise même demande d'analyse -----#
If [M:STW]QLYCTLDEM(I)<>""
  [L]WFIC="STOQLYD"
  [L]WCLE="28"-[M:STW]QLYCTLDEM(I)
  Read [QLH] QLH0=28;[M:STW]QLYCTLDEM(I)
  If fstat
    #----- Notifier dans la trace que l'analyse est introuvable -----#
    If [M:STW]TRAFLG>1
      [L]WMESSAGE=[L]WCLE-mess(537,197,1)
      Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
      If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
    Endif
    #-----
    Raz [L]WQTYPCU_QLY, [L]WQTYSTU_QLY : Return
  Elsif [F:QLH]STOFCY<>[L]WFCY |
&   [F:QLH]ITMREF<>[L]WITMREF  |
&   [F:QLH]VALFLG =2
    #----- Notifier dans la trace que l'analyse est validée -----#
    If [M:STW]TRAFLG>1
      [L]WMESSAGE=[L]WCLE-mess(538,197,1)
      Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
      If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
    Endif
    #-----
    Raz [L]WQTYPCU_QLY, [L]WQTYSTU_QLY : Return
  Endif
  #----- Mise à jour ligne contrôle qualité -----#
  [L]WANA=[M:STW]QLYCTLDEM(I)
  Gosub MAJ_STOQLYD
  Raz [L]WANA
Else
  Raz [L]WQTYPCU_QLY, [L]WQTYSTU_QLY
Endif
Return


#----------------------------------------------------#
# Mise à jour des cumuls article-site (table ITMMVT) #
#----------------------------------------------------#
$MAJ_ITMMVT

If [L]WITMREF<>"" & [L]WMAJITV=0
  Unlock [ITV] : # Déblocage du ReadLock sans réécriture !
  If [M:STW]TRAFLG>2
    [L]WCLE=[F:ITV]ITMREF-[F:ITV]STOFCY
    [L]WFIC="ITMMVT" : [L]WMESSAGE=mess(478,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
  Endif
Elsif [L]WITMREF<>""
  [L]WQTE1=[F:ITV]AVCBASQTY
  [F:ITV]PHYSTO   +=[L]WQTYACTINT_A
  [F:ITV]CTLSTO   +=[L]WQTYACTINT_Q
  [F:ITV]REJSTO   +=[L]WQTYACTINT_R
  [F:ITV]PLFPHYSTO+=[L]WQTYACTPLF_A
  [F:ITV]PLFCTLSTO+=[L]WQTYACTPLF_Q
  [F:ITV]PLFREJSTO+=[L]WQTYACTPLF_R
  [F:ITV]BPRPHYSTO+=[L]WQTYACTBPR_A
  [F:ITV]BPRCTLSTO+=[L]WQTYACTBPR_Q
  [F:ITV]BPRREJSTO+=[L]WQTYACTBPR_R
  [F:ITV]SCOPHYSTO+=[L]WQTYACTSCO_A
  [F:ITV]SCOCTLSTO+=[L]WQTYACTSCO_Q
  [F:ITV]SCOREJSTO+=[L]WQTYACTSCO_R
  [F:ITV]SCCLNDSTO+=[L]WQTYACTSCC
  #----- Màj des qtés allouées -----#
  [F:ITV]PHYALL   +=[L]WPHYALL
  [F:ITV]CTLALL   +=[L]WCTLALL
  [F:ITV]REJALL   +=[L]WREJALL
  [F:ITV]SCOPHYALL+=[L]WSCOPHYALL
  [F:ITV]SCOCTLALL+=[L]WSCOCTLALL
  [F:ITV]SCOREJALL+=[L]WSCOREJALL
  [F:ITV]SCCALL   +=[L]WSCCALL
  #----- Des entrées ont été effectuées -----#
  If [L]WQTYACT_RCP<>0 | [L]WAMT_RCP<>0 | [L]WCTR_RCP<>0
    #----- Mise à jour des zones PMP -----#
    [L]WQTE2=[L]WQTE1+[L]WQTYACT_RCP
    # Si pas fonction 'Modification de lot'
    If [L]WMODLOT<>1
      #----- Màj cumuls pour les entrées -----#
      [F:ITV]CUNRCPMVT+=[L]WCTR_RCP
      #----- Si création ou modif, màj dernière date, prix et infos pièce -----#
      If find("C",[M:STW]MAJCOD(0..[M:STW]NBLIG-1))
        If [M:STW]TRSTYP=3 & [M:STW]PRIPUR<>0
          If [M:STW]IPTDAT>=[F:ITV]LASPURDAT
            [F:ITV]LASPURDAT=[M:STW]IPTDAT
            [F:ITV]LASPURPRI=[M:STW]PRIPUR
          Endif
        Endif
        If [L]WLASDAT_RCP>=[F:ITV]LASRCPDAT
          [F:ITV]LASRCPDAT=[L]WLASDAT_RCP
# CCC (19/10/04) Bug 25625 : Le dernier prix doit correspondre au prix de l'ordre
#          [F:ITV]LASRCPPRI=[L]WPRIVAL
          [F:ITV]VCRTYP   =[M:STW]VCRTYP
          [F:ITV]VCRNUM   =[M:STW]VCRNUM
          [F:ITV]VCRLIN   =[M:STW]VCRLIN

          Call NEWLASPRI(1) From STKVALMAJ2

        Endif
      #----- Si annulation, recherche dernière entrée -----#
      Elsif [M:STW]IPTDAT>=[F:ITV]LASRCPDAT
        Filter [STJ] Where STOFCY=[F:ITV]STOFCY
&                        & UPDCOD=2
&                        & ITMREF=[F:ITV]ITMREF
&                        & REGFLG<>2
&                        & find(TRSTYP,1,3,5,14)<>0
&                    Order By Key STJ0         : # Bug 60863 (suppression Desc)
        Read [STJ] First
        If !fstat
          [F:ITV]LASRCPDAT=[F:STJ]IPTDAT
          [F:ITV]VCRTYP   =[F:STJ]VCRTYP
          [F:ITV]VCRNUM   =[F:STJ]VCRNUM
          [F:ITV]VCRLIN   =[F:STJ]VCRLIN
          Call NEWLASPRI(2) From STKVALMAJ2
        Endif
        Filter [STJ]
      Endif
    Endif
  Endif
  #----- Màj cumuls des sorties -----#
  [F:ITV]WAISTO+=[L]WQTYWAI_ISS : # Cumul sorties en attente
  [F:ITV]WAISTO+=[L]WQTYWAI_RCP : # Cumul entrées négatives (retours fournisseur)

  #----- Des sorties ont été effectuées -----#
  If [L]WQTYACT_ISS<>0 | [L]WAMT_ISS<>0 | [L]WCTR_ISS<>0
    #----- Mise à jour des zones PMP -----#
    [L]WQTE2=[L]WQTE1-[L]WQTYACT_ISS
    # Si pas fonction 'Modification de lot'
    If [L]WMODLOT<>1
      #----- Màj cumuls pour les sorties -----#
      [F:ITV]CUNISSMVT+=[L]WCTR_ISS
      #----- Si création ou modif, màj dernière date de sortie -----#
      If find("C",[M:STW]MAJCOD(0..[M:STW]NBLIG-1))
        If [L]WLASDAT_ISS>[F:ITV]LASISSDAT
          [F:ITV]LASISSDAT=[L]WLASDAT_ISS
        Endif
      #----- Si annulation, recherche dernière sortie -----#
      Elsif [M:STW]IPTDAT>=[F:ITV]LASISSDAT
        Filter [STJ] Where STOFCY=[F:ITV]STOFCY
&                        & UPDCOD=2
&                        & ITMREF=[F:ITV]ITMREF
&                        & REGFLG<>2
&                        & find(TRSTYP,2,4,6,14,24,29)<>0
&                    Order By Key STJ0         : # Bug 60863 (suppression Desc)
        Read [STJ] First
        If !fstat
          [F:ITV]LASISSDAT=[F:STJ]IPTDAT
        Endif
        Filter [STJ]
      Endif
    Endif
  Endif

  #----- Màj cumuls stock en transit et transféré -----#
  # Issue 91791 - 2013-08-19 by MAE : on ne met pas à jour le transféré et le transit dans le cas de la sous traitance
  #If !find([M:STW]TRSTYP,16,20)        # hcb 85992
  If !find([M:STW]TRSTYP,16,20,32,33)        #MAE 91791
     [F:ITV]TRFSTO+=[L]WQTYACT_TRF
     [F:ITV]TRASTO+=[L]WQTYACT_TRA
  #--- Bug 74371
     If [F:ITV]TRFSTO<0 [F:ITV]TRFSTO=0 Endif
     If [F:ITV]TRASTO<0 [F:ITV]TRASTO=0 Endif
  Endif                                # hcb 88512

  #---
# Issue 72471 - 2011-03-23 by CCC : La mise à jour de TRAAMT se fait dans STKVALMAJ2.MAJPMP
#    [F:ITV]TRAAMT+=[L]WAMTORD_ISS

  #----- Réécriture des cumuls article-site -----#
     Call REWITV From STKLIB
     If fstat
        Call FSTA("ITV") From GLOCK
        [M:STW]ERRCOD=70 : [L]WFIC="ITMMVT" : Gosub TRT_ERR : Return
     Endif
     If [M:STW]TRAFLG>2
        [L]WCLE=[F:ITV]ITMREF-[F:ITV]STOFCY
        [L]WFIC="ITMMVT" : [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
     Endif
Endif
#----- Mise à jour stock transit et transféré si réception transfert inter-site -----#
If [L]WQTYACT_TRF<>0 | [L]WQTYACT_TRA<>0

  [L]WFIC="ITMMVT"
  If [L]WFCY=[M:STW]STOFCY
    [L]WCLE=[L]WITMREF-[M:STW]TRFFCY
  Else
    [L]WCLE=[L]WITMREF-[M:STW]STOFCY
  Endif
  #----- Lecture cumuls article-site -----#
  If [L]WFCY=[M:STW]STOFCY
    Call LECITV([M:STW]TRFFCY,[L]WITMREF,"",[L]WRET) From STKLIB
  Else
    Call LECITV([M:STW]STOFCY,[L]WITMREF,"",[L]WRET) From STKLIB
  Endif
  If [L]WRET=2
    GLOCK="$ITMMVT"-[L]WCLE
    [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
  Elsif [L]WRET>2
    [M:STW]ERRCOD=9  : Gosub TRT_ERR : Return
  Endif
  #----- Màj cumuls stock en transit et transféré -----#
#  verification  que le site  ITV  soit bien gere en stock         # hcb  86563

  If [F:ITF1]ITMREF<>[F:ITV]ITMREF | [F:ITF1]STOFCY<>[F:ITV]STOFCY # hcb  86563
     Read [ITF1]ITF0=[F:ITV]ITMREF;[F:ITV]STOFCY                   # hcb  86563
     If fstat                                                      # hcb  86563
        Call RSTA("ITF1",[F:ITV]ITMREF-[F:ITV]STOFCY) From GLOCK   # hcb  86563
        GOK=0 : LRET=52 : Return                                   # hcb  86563
     Endif                                                         # hcb  86563
  Endif                                                            # hcb  86563

  If [F:ITF1]STOMGTCOD > 1                                         # hcb  86563
  # Issue 91791 - 2013-08-19 by MAE : On ne met pas à jour le transit et le transféré en cas de sous traitance
   #If  !find([M:STW]TRSTYP,16,20)        # hcb 88512
   If  !find([M:STW]TRSTYP,16,20,32,33)   #MAE 91791
       [F:ITV]TRFSTO+=[L]WQTYACT_TRA : # _TRA et _TRF volontairement inversé !
       [F:ITV]TRASTO+=[L]WQTYACT_TRF : # _TRA et _TRF volontairement inversé !
  #--- Bug 74371
       If [F:ITV]TRFSTO<0 [F:ITV]TRFSTO=0 Endif
       If [F:ITV]TRASTO<0 [F:ITV]TRASTO=0 Endif
   Endif                                # hcb 88512

  #---
# Issue 72471 - 2011-03-23 by CCC : La mise à jour de TRAAMT se fait dans STKVALMAJ2.MAJPMP
## CCC (08/12/05) Bug 33039
#  If [M:STW]VCRTYPORI = 4
#    Call VALVCR2([M:STW]STOFCY,[M:STW]VCRTYPORI,[M:STW]VCRNUMORI,[M:STW]VCRLINORI,WAMTTRA,WQTYTRA,WRET) From STKVAL
#    # Cela peut se produire avec les livraisons /s-trait ou livraisons de prêt qui font une sortie & une entrée
#    If WQTYTRA<>0
#      [F:ITV]TRAAMT+=[L]WAMTTRA*WQTYACT_TRA/WQTYTRA
#    Endif
#  Endif
  #----- Réécriture des cumuls article-site -----#
  Call REWITV From STKLIB
  If fstat
    Call FSTA("ITV") From GLOCK
    [M:STW]ERRCOD=70 : [L]WFIC="ITMMVT" : Gosub TRT_ERR : Return
  Endif
  If [M:STW]TRAFLG>2
    [L]WCLE=[F:ITV]ITMREF-[F:ITV]STOFCY
    [L]WFIC="ITMMVT" : [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
  Endif
  Endif                                                            # hcb  86563
Endif
#----- Mise à jour historique des cumuls article-site -----#
Gosub MAJ_ITMMVTHIS : If GOK<1  Return : Endif
#-----
Raz [L]WQTY,        [L]WQTY_A,       [L]WQTY_Q,       [L]WQTY_R
Raz [L]WQTYACT,     [L]WQTYACT_A,    [L]WQTYACT_Q,    [L]WQTYACT_R
Raz [L]WQTYACTINT,  [L]WQTYACTINT_A, [L]WQTYACTINT_Q, [L]WQTYACTINT_R
Raz [L]WQTYACTPLF,  [L]WQTYACTPLF_A, [L]WQTYACTPLF_Q, [L]WQTYACTPLF_R
Raz [L]WQTYACTBPR,  [L]WQTYACTBPR_A, [L]WQTYACTBPR_Q, [L]WQTYACTBPR_R
Raz [L]WQTYACTSCO,  [L]WQTYACTSCO_A, [L]WQTYACTSCO_Q, [L]WQTYACTSCO_R
Raz [L]WQTYACTSCC
Raz [L]WQTY_RCP,    [L]WQTYACT_RCP,  [L]WQTYWAI_RCP
Raz [L]WAMTORD_RCP, [L]WAMT_RCP,     [L]WLASDAT_RCP,  [L]WCTR_RCP
Raz [L]WQTY_ISS,    [L]WQTYACT_ISS,  [L]WQTYWAI_ISS
Raz [L]WAMTORD_ISS, [L]WAMT_ISS,     [L]WLASDAT_ISS,  [L]WCTR_ISS
Raz [L]WQTYACT_TRA, [L]WQTYACT_TRF
Raz [L]WITMREF,     [L]WSTU,         [L]WMAJITV
# Ces variables sont utilisées ensuite par la valo (ex: update amtdev)
#Raz [L]WCTR_MVTSEQ, [L]WCTR_MVTIND
#Raz [L]WMVTSEQSTR
Raz [L]WPHYALL,     [L]WCTLALL,      [L]WREJALL
Raz [L]WSCOPHYALL,  [L]WSCOCTLALL,   [L]WSCOREJALL
Raz [L]WSCCALL
Return


#-------------------------------------------------------------------#
# Mise à jour de l'historique cumuls article-site (table ITMMVTHIS) #
#-------------------------------------------------------------------#
$MAJ_ITMMVTHIS
Local Integer WCREITH : Raz WCREITH
#----- Aucun cumul entrée ou sortie à mettre à jour -----#
If [L]WQTYACT_RCP=0 & [L]WAMT_RCP=0 & [L]WCTR_RCP=0 &
&  [L]WQTYACT_ISS=0 & [L]WAMT_ISS=0 & [L]WCTR_ISS=0
  Return
Endif
#----- Pas de mise à jour si inventaire -----#
If [M:STW]TRSTYP=13  Return : Endif
#----- Pas de mise à jour si modification lot -----#
If [M:STW]VCRTYP=35  Return : Endif

# PE pour ne pas gérer l'historique cumuls article-site
GPE = 0
GPOINT = "MAJ_ITH"
Gosub ENTREE From EXEFNC
If GPE<>0  Return  Endif
#---

Call GETITH([L]WITMREF,[L]WFCY,[M:STW]IPTDAT,1,[L]WCREITH) From STKLIB
Case fstat
  When 0
    [F:ITH]UPDDAT=date$
    [F:ITH]UPDUSR=GUSER
    [F:ITH]EXPNUM=[C]EXPORT
  When 1
    GLOCK="$ITMMVTHIS"-[L]WCLE
    [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
  When Default
    If fstat
      Call FSTA("ITH") From GLOCK
      [M:STW]ERRCOD=70 : Gosub TRT_ERR : Return
    Endif
Endcase

[L]WEXERCICE = [F:PER]FIYNUM     # hcb 61118

If [L]WCREITH
    If [M:STW]TRAFLG>2
      [L]WMESSAGE=mess(233,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
    Endif
Endif
#----- Des entrées ont été effectuées -----#
If [L]WQTYACT_RCP<>0 | [L]WCTR_RCP<>0
  #----- Màj cumuls pour les entrées -----#
  [F:ITH]MONRCPQTY+=[L]WQTYACT_RCP
  [F:ITH]YEARCPQTY+=[L]WQTYACT_RCP
  # Si pas fonction 'Modification de lot'
  If [L]WMODLOT<>1
    [F:ITH]MONRCPMVT+=[L]WCTR_RCP
    [F:ITH]YEARCPMVT+=[L]WCTR_RCP
    #----- Si création ou modif, màj dernière date, prix et infos pièce -----#
    If find("C",[M:STW]MAJCOD(0..[M:STW]NBLIG-1))
      If [M:STW]TRSTYP=3 & [M:STW]PRIPUR<>0
        If [M:STW]IPTDAT>=[F:ITH]LASPURDAT
          [F:ITH]LASPURDAT=[M:STW]IPTDAT
          [F:ITH]LASPURPRI=[M:STW]PRIPUR
        Endif
      Endif
      If [L]WLASDAT_RCP>=[F:ITH]LASRCPDAT
        [F:ITH]LASRCPDAT=[L]WLASDAT_RCP
# CCC (19/10/04) Bug 25625 : Le dernier prix doit correspondre au prix de l'ordre
#        [F:ITH]LASRCPPRI=[L]WPRIVAL
        [F:ITH]LASRCPPRI=[M:SVW]PRIORD(0)
        [F:ITH]VCRTYP   =[M:STW]VCRTYP
        [F:ITH]VCRNUM   =[M:STW]VCRNUM
        [F:ITH]VCRLIN   =[M:STW]VCRLIN
      Endif
    #----- Si annulation, recherche dernière entrée -----#
    Elsif [M:STW]IPTDAT>=[F:ITH]LASRCPDAT
      Filter [STJ] Where STOFCY=[F:ITH]STOFCY
&                      & UPDCOD=2
&                      & ITMREF=[F:ITH]ITMREF
&                      & REGFLG<>2
&                      & find(TRSTYP,1,3,5,14)<>0
&                  Order By Key STJ0         : # Bug 60863 (suppression Desc)
      Columns [STJ] (IPTDAT, PRIORD, VCRTYP, VCRNUM, VCRLIN)
      Read [STJ] First
      If !fstat
        [F:ITH]LASRCPDAT=[F:STJ]IPTDAT
        [F:ITH]LASRCPPRI=[F:STJ]PRIORD
        [F:ITH]VCRTYP   =[F:STJ]VCRTYP
        [F:ITH]VCRNUM   =[F:STJ]VCRNUM
        [F:ITH]VCRLIN   =[F:STJ]VCRLIN
      Endif
      Filter [STJ]
      Columns [STJ]
    Endif
  Endif
Endif
#----- Des sorties ont été effectuées -----#
If [L]WQTYACT_ISS<>0 | [L]WAMT_ISS<>0 | [L]WCTR_ISS<>0
  #----- Màj cumuls pour les sorties -----#
  [F:ITH]MONISSQTY+=[L]WQTYACT_ISS
  [F:ITH]YEAISSQTY+=[L]WQTYACT_ISS
  # Si pas fonction 'Modification de lot'
  If [L]WMODLOT<>1
    [F:ITH]MONISSMVT+=[L]WCTR_ISS
    [F:ITH]YEAISSMVT+=[L]WCTR_ISS
    #----- Si création ou modif, màj dernière date de sortie -----#
    If find("C",[M:STW]MAJCOD(0..[M:STW]NBLIG-1))
      If [L]WLASDAT_ISS>[F:ITH]LASISSDAT
        [F:ITH]LASISSDAT=[L]WLASDAT_ISS
      Endif
    #----- Si annulation, recherche dernière sortie -----#
    Elsif [M:STW]IPTDAT>=[F:ITH]LASISSDAT
      Filter [STJ] Where STOFCY=[F:ITH]STOFCY
&                      & UPDCOD=2
&                      & ITMREF=[F:ITH]ITMREF
&                      & REGFLG<>2
&                      & find(TRSTYP,2,4,6,14,24,29)<>0
&                  Order By Key STJ0         : # Bug 60863 (suppression Desc)
      Columns [STJ] (IPTDAT)
      Read [STJ] First
      If !fstat
        [F:ITH]LASISSDAT=[F:STJ]IPTDAT
      Endif
      Filter [STJ]
      Columns [STJ]
    Endif
  Endif
Endif
#----- Réécriture de l'historique cumuls article-site -----#
Call REWITH From STKLIB
If fstat
  Call FSTA("ITH") From GLOCK
  [M:STW]ERRCOD=70 : Gosub TRT_ERR : Return
Endif

If [M:STW]TRAFLG>2
  [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
Endif
#----- Mise à jour des cumuls annuels sur périodes suivantes -----#
[L]WCLE=[L]WITMREF-[L]WFCY-num$([L]WEXERCICE)
Update [ITH] Where ITMREF=[L]WITMREF
&                & STOFCY=[L]WFCY
&                & FIYNUM=[L]WEXERCICE
&                & PERSTR>[F:PER]PERSTR
&            With  YEARCPQTY+=[L]WQTYACT_RCP,
&                  YEARCPAMT+=[L]WAMT_RCP,
&                  YEARCPMVT+=[L]WCTR_RCP,
&                  YEAISSQTY+=[L]WQTYACT_ISS,
&                  YEAISSAMT+=[L]WAMT_ISS,
&                  YEAISSMVT+=[L]WCTR_ISS
If fstat=1
  GLOCK="$ITMMVTHIS"-[L]WCLE
  [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
Elsif fstat
  Call RSTA("ITH",[L]WCLE) From GLOCK
  [M:STW]ERRCOD=60 : Gosub TRT_ERR : Return
Endif
If [M:STW]TRAFLG>2
  Filter [ITH] Where ITMREF=[L]WITMREF
&                  & STOFCY=[L]WFCY
&                  & FIYNUM=[L]WEXERCICE
&                  & PERSTR>[F:PER]PERSTR
  Look [ITH] ITH0 First
  Filter [ITH]
  If !fstat
    [L]WMESSAGE=mess(492,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
  Endif
Endif
Return


#--------------------------------------------------------------------#
# Contrôles, réajustements et valeurs par défaut sur ligne à traiter #
#--------------------------------------------------------------------#
$CTL_VALDEF_LIG
#----- Contrôles élémentaires sur ligne à traiter -----#
If [M:STW]LOCCAT(I)=2
  If !find(left$([M:STW]STA(I),1),"A","Q","R","") & [M:STW]WAIFLG(I)=0
    [M:STW]ERRCOD=10  :  [L]WZON="STA"    : Gosub TRT_ERR : Return
  Endif
  #----- Si marchandise sur le quai il faut quand même un statut par défaut -----#
  If [M:STW]STA(I)=""
    If !clalev([F:TST])  Local File  TABSTASTO  [TST] : Endif
    Filter [TST] Where left$(STASTO,1)="Q" : # Premier statut Q trouvé
    Read [TST] TST0 First : If fstat  Raz [F:TST] : Endif
    Filter [TST]
    [M:STW]STA(I)=[F:TST]STASTO
  Endif
Else
  If !find(left$([M:STW]STA(I),1),"A","Q","R") & [M:STW]WAIFLG(I)=0
    [M:STW]ERRCOD=10  :  [L]WZON="STA"    : Gosub TRT_ERR : Return
  Endif
Endif
If [M:STW]WAIFLG(I)>1
  [M:STW]ERRCOD=17  :  [L]WZON="WAIFLG" : Gosub TRT_ERR : Return
Endif
If [M:STW]MAJCOD(I)<>"C" & [M:STW]MAJCOD(I)<>"A"
  [M:STW]ERRCOD=17  :  [L]WZON="MAJCOD" : Gosub TRT_ERR : Return
Endif
#----- Contrôle supplémentaire pour une sortie -----#
If [L]WCODFONC=2 & !find([M:STW]TRSTYP,12,19)
  If [M:STW]STOCOU(I)=0 & [L]WMAJCOD="C" & [M:STW]WAIFLG(I)=0
    [M:STW]ERRCOD=17 : [L]WZON="STOCOU" : Gosub TRT_ERR : Return
  Endif
Endif
#----- Contrôles supplémentaires pour un changement d'emplacement -----#
If [L]WCODFONC=3
  If [M:STW]STOCOU(I)=0 & [L]WMAJCOD="C" & [M:STW]WAIFLG(I)=0
    [M:STW]ERRCOD=17 : [L]WZON="STOCOU" : Gosub TRT_ERR : Return
  Endif
Endif
#----- Les quantités doivent être renseignées -----#
If [M:STW]QTYSTU(I)   =0  [M:STW]QTYSTU(I)   =[M:STW]QTYSTUACT(I) : Endif
If [M:STW]QTYSTUACT(I)=0  [M:STW]QTYSTUACT(I)=[M:STW]QTYSTU(I)    : Endif
#----- Chargement du nombre de décimales de l'UC -----#
If [M:STW]WAIFLG(I)=0 | [M:STW]PCU(I)<>""
  If [F:TUN]UOM<>[M:STW]PCU(I)
    Read [TUN] TUN0=[M:STW]PCU(I)
    If fstat
      [M:STW]ERRCOD=7  : Gosub TRT_ERR : Return
    Endif
  Endif
Else : # Si mvt en attente pas forcément d'UC mais une US !
  If [F:TUN]UOM<>[M:STW]STU(I)
    Read [F:TUN] TUN0=[M:STW]STU(I)
    If fstat
      [M:STW]ERRCOD=8  : Gosub TRT_ERR : Return
    Endif
  Endif
  [M:STW]PCU(I)=[M:STW]STU(I)
  [M:STW]PCUSTUCOE(I)=1
Endif
[L]WDEC_UC=[F:TUN]UOMDEC
#----- Réajustement des décimales par sécurité -----#
If [F:TUN]UOM<>[M:STW]STU(I)
  Read [TUN] TUN0=[M:STW]STU(I)
  If fstat
    [M:STW]ERRCOD=8  : Gosub TRT_ERR : Return
  Endif
Endif
[L]WDEC_US=[F:TUN]UOMDEC
[M:STW]QTYSTU(I)   =arr([M:STW]QTYSTU(I),10^-[L]WDEC_US)
[M:STW]QTYSTUACT(I)=arr([M:STW]QTYSTUACT(I),10^-[L]WDEC_US)
#--- Bug 87661
[M:STW]QTYACTORI(I)=arr([M:STW]QTYACTORI(I),10^-[L]WDEC_US)
#----- Si UC=US récupération qté US par sécurité -----#
If [M:STW]PCU(I)=[M:STW]STU(I)
  [M:STW]QTYPCU(I)=[M:STW]QTYSTU(I)
  [M:STW]PCUSTUCOE(I)=1
Endif
#---- Si annulation, chargement LOCTYP et LOCCAT qui ne sont pas renseignés -----#
If [M:STW]MAJCOD(I)="A" | [M:STW]LOCCAT(I)=0
  If [L]WCODFONC=3  [L]WFCY=[M:STW]STOFCY : Endif
  #----- Lecture emplacement si nécessaire -----#
  If [M:STW]LOC(I)<>""
    If [F:STC]STOFCY<>[L]WFCY | [F:STC]LOC<>[M:STW]LOC(I)
      Read [STC] STC0=[L]WFCY;[M:STW]LOC(I)
      If fstat
        [L]WFIC="STOLOC"
        [L]WCLE=[L]WFCY-[M:STW]LOC(I)
        Call RSTA("STC",[L]WCLE) From GLOCK
        [M:STW]ERRCOD=60 : Gosub TRT_ERR : Return
      Endif
    Endif
    #-----
    If [M:STW]WRH(I)="" & [F:STC]WRH<>""
       [M:STW]WRH(I)=[F:STC]WRH
    Endif
    [M:STW]LOCTYP(I)=[F:STC]LOCTYP
    [M:STW]LOCCAT(I)=[F:STC]LOCCAT
  Else
    [M:STW]LOCCAT(I)=1
  Endif
Endif
#----- Effacement du no demande d'analyse si création et statut<>"Q" -----#
If [M:STW]MAJCOD(I)="C" & left$([M:STW]STA(I),1)<>"Q"
  [M:STW]QLYCTLDEM(I)=""
Endif
#----- Valeurs par défaut (par sécurité et simplification du traitement) -----#
If [M:STW]LOCCAT(I)<1    | [M:STW]LOCCAT(I)>4    [M:STW]LOCCAT(I)=1    : Endif
If [M:STW]PRINAT(I)<1    | [M:STW]PRINAT(I)>9    [M:STW]PRINAT(I)=2    : Endif
If [M:STW]QLYCTLFLG(I)<1 | [M:STW]QLYCTLFLG(I)>2 [M:STW]QLYCTLFLG(I)=1 : Endif
If [M:STW]SERNUMF(I)=""  [M:STW]SERNUMF(I)=[M:STW]SERNUM(I) : Endif
#----- Initialisation code mise à jour stock -----#
If [M:STW]WAIFLG(I)=0  [L]WUPDCOD=2 Else [L]WUPDCOD=1 : Endif
#----- Chargement du lot -----#
[L]WLOT=[M:STW]LOT(I)
Return


#--------------------------------------------------------#
# Début de mise à jour : Lecture tables et Raz variables #
#--------------------------------------------------------#
$LEC_FICHIERS
[L]WITMREF=[M:STW]ITMREFLIG(I)
[L]WSTU   =[M:STW]STU(I)
#----- Lectures article, article-site, catégorie article, site, méthode valo, us, ...
If [F:ITM]ITMREF<>[L]WITMREF
  Read [ITM]ITM0=[L]WITMREF
  If fstat
    [M:STW]ERRCOD=3  : Gosub TRT_ERR : Return
  Endif
Endif
If [F:ITF]ITMREF<>[L]WITMREF | [F:ITF]STOFCY<>[L]WFCY
  Read [ITF] ITF0=[L]WITMREF;[L]WFCY
  If fstat
    [M:STW]ERRCOD=4  : Gosub TRT_ERR : Return
  Endif
Endif
If [F:ITG]TCLCOD<>[F:ITM]TCLCOD | [F:ITG]STOFCY<>[L]WFCY
  Read [ITG] ITG1=[F:ITM]TCLCOD;[L]WFCY
  If fstat
    Read [ITG] ITG1=[F:ITM]TCLCOD;""
    If fstat
      [M:STW]ERRCOD=5  : Gosub TRT_ERR : Return
    Endif
  Endif
Endif
If [F:FCY]FCY<>[L]WFCY
  Read [FCY] FCY0=[L]WFCY
  If fstat
    [M:STW]ERRCOD=6  : Gosub TRT_ERR : Return
  Endif
Endif
#----- GETTCM se positionne sur [F:TCM]
Call GETTCM([F:ITF]ITMREF,[F:ITF]STOFCY,GBIDC1,[L]WRET) From STKVAL
If [L]WRET | fstat
  [M:STW]ERRCOD=23 : Gosub TRT_ERR : Return
Endif
If [F:TUN]UOM<>[L]WSTU
  Read [TUN] TUN0=[L]WSTU
  If fstat
    [M:STW]ERRCOD=8  : Gosub TRT_ERR : Return
  Endif
Endif
[L]WDEC_US=[F:TUN]UOMDEC
#----- Contrôle validité du compteur numéro de série -----#
If [F:ITM]SERCOU<>"" & ([F:ITM]SERMGTCOD>2 | ([F:ITM]SERMGTCOD=2 & [L]WCODFONC>1))
  Call CTRCPT ([F:ITM]SERCOU,GLONSER+10,[L]WRET) From STKLIB
  If [L]WRET<>0
    [M:STW]ERRCOD=27 : [L]WCTEUR=[F:ITM]SERCOU : Gosub TRT_ERR : Return
  Endif
Endif
If [F:ITM]SERCOU=""  [L]WSERCOU=GSTKCPT(12)  Else  [L]WSERCOU=[F:ITM]SERCOU : Endif

#--- Issue 103815
#----- Lecture cumuls article-site -----#
#Call LECITV([L]WFCY,[L]WITMREF,"",[L]WRET) From STKLIB
#If [L]WRET=2
#  GLOCK="$ITMMVT"-[L]WITMREF-[L]WFCY
#  [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
#Elsif [L]WRET>2
#  [M:STW]ERRCOD=9  : Gosub TRT_ERR : Return
#Endif
Read [ITV]ITV0=[L]WITMREF;[L]WFCY
If find(fstat,4,5)
  Raz [F:ITV]
  [F:ITV]ITMREF = [L]WITMREF
  [F:ITV]STOFCY = [L]WFCY
  Call ECRITV From STKLIB
  If fstat
    [M:STW]ERRCOD=9  : Gosub TRT_ERR : Return
  Endif
Endif
#---

#----- Si on traite les sorties le cumul article-site doit exister -----#
If [L]WCODFONC=2 & [L]WRET=1
  [L]WFIC="ITMMVT"
  [L]WCLE=[L]WITMREF-[L]WFCY
  [M:STW]ERRCOD=60 : Gosub TRT_ERR : Return
Endif
#----- Calcul quantité totale traitée pour l'article et la fonction -----#
[L]WTOTQTE=sigma(J=0,[M:STW]NBLIG-1,[M:STW]QTYSTU(J)*(1-2*([M:STW]MAJCOD(J)="A"))
&          *([M:STW]ITMREFLIG(J)=[L]WITMREF)*([M:STW]MAJTYP(J)=[L]WMAJTYP)
&          *([M:STW]WAIFLG(J)=0))
#----- Si inventaire recherche mvt bidon pour récup no séquence puis no indice -----#
If [M:STW]TRSTYP=13 & [M:STW]VCRTYP=9
  Gosub CLESTJINV : If GOK<1  Return : Endif
Endif
Return


#---------------------------------------------------------------------#
# Génération d'un mouvement de stock pour régularisation écart Mt PMP #
# - N'est pas utilisé ???                                             #
#---------------------------------------------------------------------#
$GEN_MVT_PMP
If [F:ITV]AVCBASAMT<>0
  Raz [F:STJ]
  nolign=I+1 : [F:STJ]=[M:STW]
  [F:STJ]STOFCY   =[L]WFCY
  # Si pas de propriétaire renseigné
  If [F:STJ]OWNER="" : [F:STJ]OWNER=[L]WFCY : Endif
  [F:STJ]UPDCOD   =2
  [F:STJ]ITMREF   =[L]WITMREF
  [F:STJ]REGFLG   =2
  [F:STJ]QTYPCU   =0
  [F:STJ]QTYSTU   =0
  [F:STJ]ACTQTY   =0
  [F:STJ]AMTORD   =-[F:ITV]AVCBASAMT
  [F:STJ]AMTVAL   =0
  [F:STJ]VARORD   =-[F:ITV]AVCBASAMT
  [F:STJ]VARVAL   =0
  [F:STJ]PCUORI   =[F:STJ]PCU
  [F:STJ]PCUSTUORI=[F:STJ]PCUSTUCOE
  #----- Chargement champs nécessaires à l'interface comptable -----#
  [F:STJ]FINRSPFCY=[F:FCY]FINRSPFCY
  For K=1 To GNBDIE
    [F:STJ]CCE(K-1) = evalue("[M:STW]CCE"+num$(K)+"(I)")
    [F:STJ]DIE(K-1) = GDIE(K)
  Next K
  [L]WTRSTYP=97 : Gosub ECRSTJ : If GOK<1  Return : Endif
Endif
Return


#-------------------------------------------------#
# Chargement des paramètres liés au site [L]WFCY  #
# - société, devise, ...                          #
# - globales utilisées pour l'analytique          #
#-------------------------------------------------#
$CHARG_PARAM
#----- Chargement société et arrondi pour devise société -----#
Call GETCPY([L]WFCY,"",0,"") From TRTX3CPT
If [F:TCU]CUR<>GLOCALDEV
  Read [TCU] TCU0=GLOCALDEV : If fstat  Raz [F:TCU] : [F:TCU]CURRND=0.01 : Endif
Endif
# Arrondi devise
If [L]WARRONDI=1
   [L]WRND_SOC=[F:TCU]CURRND
# Arrondi type donnée
Else
   If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
   Read [F:ATZ]CODZONE="STOJOU";"AMTORD"
   If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
   Read [ATY]CODTYP=[F:ATZ]CODTYP
   If fstat = 0
      [L]WRND_SOC= 10^-(mod([F:ATY]LNGTYP,1)*10)
   Else
      [L]WRND_SOC=0.01
   Endif
Endif

Return


#--------------------------------------------------------------------------#
# Mise à jour du mvt de stock (STOJOU) et repérage des mvts qui s'annulent #
#--------------------------------------------------------------------------#
$MAJ_STOJOU

Raz [L]WTRSTYP
#----- Repérage des mouvements qui s'annulent -----#
If [M:STW]MAJCOD(I)="A"
  [L]WFIC="STOJOU"
  [L]WCLE=[L]WFCY-num$([L]WUPDCOD)-[M:STW]ITMREFLIG(I)
  [L]WCLE-=num$([M:STW]IPTDAT)-num$([L]WMVTSEQ)-num$([L]WMVTIND)
  Readlock [STJ]STJ0=[L]WFCY;[L]WUPDCOD;[M:STW]ITMREFLIG(I);[M:STW]IPTDAT;[L]WMVTSEQ;[L]WMVTIND
  If fstat=1
    GLOCK="$STOJOU"-[L]WCLE
    [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
  Elsif fstat
    Call RSTA("STJ",[L]WCLE) From GLOCK
    [M:STW]ERRCOD=60 : Gosub TRT_ERR : Return
  Endif
  [F:STJ]REGFLG=2
  Rewrite [STJ]
  If fstat
    Call FSTA("STJ") From GLOCK
    [M:STW]ERRCOD=70 : Gosub TRT_ERR : Return
  Endif
# hcb 29983 deb
  If [F:ITM]TRKCOD = 2
     Gosub MAJ_STOTRK_REGFLG
     If GOK<1
        Return
     Endif
  Endif
# hcb 29983 fin

  [L]WREGFLG=2
  If [M:STW]TRAFLG>2 & [L]WREGFLG=2
    [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
  Endif
Else
  [L]WREGFLG=1
  If [M:STW]TRSTYP=22 & [L]WFLUX=2
    Gosub SPEC_SRG1 : If GOK<1  Return : Endif : # Spécificités plan de rangement
  Endif
Endif
#----- Ecriture du mouvement de stock -----#
[L]WTRSTYP=[M:STW]TRSTYP
# Si plan de rangement, traitement particulier de la valorisation
If [M:STW]TRSTYP=22 [L]WTRSTYP=95 Endif
Gosub ECRSTJ : If GOK<1  Return : Endif
#----- Si inventaire ou BP avec cht emplacement ou pesée avec chgt emplacement (spécifique)
#----- il ne faut pas casser MVTSEQ
If ([M:STW]TRSTYP=13 &  [M:STW]VCRTYP=9) |
&  ([M:STW]TRSTYP= 7 & ([M:STW]VCRTYP=3 | [M:STW]VCRTYP=10))
   Return
Endif

[M:STW]MVTSEQ(I)=[F:STJ]MVTSEQ
Return

# hcb 29983 -------------------------------------------- #
# - Maj à jour REGFLG de STOTRK pour les articles        #
#                        avec tracabilite détaillée      #
#--------------------------------------------------------#
$MAJ_STOTRK_REGFLG
[L]WFIC="STOTRK"
[L]WCLE=[M:STW]ITMREFLIG(I)-[F:STJ]LOT-[F:STJ]SLO
[L]WCLE-=num$([M:STW]IPTDAT)-num$([L]WMVTSEQ)-[L]WFCY
Readlock [STR]STR0=[M:STW]ITMREFLIG(I);[F:STJ]LOT;[F:STJ]SLO;[M:STW]IPTDAT;[L]WMVTSEQ;[L]WFCY
If !fstat
   [F:STR]REGFLG=2
   Rewrite [STR]
   If fstat
      Call FSTA("STR") From GLOCK
      [M:STW]ERRCOD=70
      Gosub TRT_ERR
      Return
   Endif
Endif

Return


#--------------------------------------------------------#
#          Spécificités pour plan de rangement           #
# ------------------------------------------------------ #
# - Génération des mvts pour tracabilité de la réception #
# - Positionnement indicateur sur mvts qui s'annulent    #
#--------------------------------------------------------#
$SPEC_SRG1

[L]WREGFLG=2
Raz [L]WQTYPCU, [L]WQTYSTU, [L]WQTYSTUACT
[L]WFIC="STOJOU"

#--- TS le 03.12.04 : Rajout de STA, PALNUM, CTRNUM
For [STJ] STJ1 Where STOFCY   =[L]WFCY
&                  & VCRTYP   =[M:STW]VCRTYP
&                  & VCRNUM   =[M:STW]VCRNUM
&                  & VCRLIN   =[M:STW]VCRLIN
&                  & LOT      =[L]WLOT_ISS
&                  & SLO      =[L]WSLO_ISS
&                  & BPSLOT   =[L]WBPSLOT_ISS
&                  & SERNUM   =[L]WSERNUM_ISS
&                  & LOC      =[M:STW]LOC(I)
&                  & PCU      =[F:STO]PCU
&                  & PCUSTUCOE=[F:STO]PCUSTUCOE
&                  & STA      =[L]WSTA_ISS
&                  & PALNUM   =[F:STO]PALNUM
&                  & CTRNUM   =[F:STO]CTRNUM
&                  & OWNER    =[F:STO]OWNER
&                  & REGFLG<>2
&                  & QTYSTU>0
  [L]WQTYPCU   +=[F:STJ]QTYPCU
  [L]WQTYSTU   +=[F:STJ]QTYSTU
  [L]WQTYSTUACT+=[F:STJ]ACTQTY
  [L]WCLE=[F:STJ]STOFCY-num$([F:STJ]UPDCOD)-[F:STJ]ITMREF-num$([F:STJ]IPTDAT)
  [L]WCLE-=num$([F:STJ]MVTSEQ)-num$([F:STJ]MVTIND)
  Readlock [STJ] Curr
  If fstat=1
    GLOCK="$STOJOU"-[L]WCLE
    #--- Bug 61703 : remplacement Return par Break
    [M:STW]ERRCOD=99 : Gosub TRT_LCK : Break
  Elsif fstat
    Call RSTA("STJ",[L]WCLE) From GLOCK
    #--- Bug 61703 : remplacement Return par Break
    [M:STW]ERRCOD=60 : Gosub TRT_ERR : Break
  Endif
  [F:STJ]REGFLG=2
  Rewrite [STJ]
  If fstat
    Call FSTA("STJ") From GLOCK
    #--- Bug 61703 : remplacement Return par Break
    [M:STW]ERRCOD=70 : Gosub TRT_ERR : Break
  Endif
# hcb 29983 deb
  If [F:ITM]TRKCOD = 2
     Gosub MAJ_STOTRK_REGFLG
     #--- Bug 61703 : remplacement Return par Break
     If GOK<1 Break Endif
  Endif
# hcb 29983 fin
  If [M:STW]TRAFLG>2
    [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
  Endif
  If [L]WQTYSTU>=[M:STW]QTYSTU(I)*-[L]SIGN  Break : Endif
Next
#--- Bug 61703
If GOK<1 Return Endif

#----- Particularité si déconditionnement ou rompu -----#
If find([L]WPCU_ORI,[F:ITM]PCU) & [L]WQTYSTU<[M:STW]QTYSTU(I)*-[L]SIGN
  If [F:ITM]PCURUL(find([L]WPCU_ORI,[F:ITM]PCU)-1)<>3
    # Si rangement partiel, génération de mouvements supplémentaires
    #If [M:STW]MISFLG<>1
      Gosub SPEC_SRG1_ROMPU : Return
    #Endif
  Endif
Endif

# Si rangement total, pas de génération de mouvements supplémentaires
#If [M:STW]MISFLG=1 Return Endif
#----- La quantité rangée n'a pas été entièrement retrouvée ! -----#
If [L]WQTYSTU<[M:STW]QTYSTU(I)*-[L]SIGN
  [M:STW]ERRCOD=40 : Gosub TRT_ERR : Return
Endif
#-----
If [L]WQTYSTU>[M:STW]QTYSTU(I)*-[L]SIGN
  [L]WQTYPCU   +=[M:STW]QTYSTU(I)/[F:STO]PCUSTUCOE*[L]SIGN
  Call QTEARR ([L]WQTYPCU,[F:STO]PCU) From TRTDIV
  [L]WQTYSTU   +=[M:STW]QTYSTU(I)*[L]SIGN
  [L]WQTYSTUACT+=[M:STW]QTYSTUACT(I)*[L]SIGN
  [F:STJ1]=[F:STJ]
  [F:STJ]TRSTYP=[M:STW]TRSTYP
  #----- Création du mouvement supplémentaire en plus -----#
  [F:STJ]REGFLG=1
  [F:STJ]QTYPCU=[L]WQTYPCU
  [F:STJ]QTYSTU=[L]WQTYSTU
  [F:STJ]ACTQTY=[L]WQTYSTUACT
  If [F:STJ]PCUORI=""   [F:STJ]PCUORI   =[F:STJ]PCU       : Endif
  If [F:STJ]PCUSTUORI=0 [F:STJ]PCUSTUORI=[F:STJ]PCUSTUCOE : Endif
  # Issue 77372 - 2011-10-26 by CCC
  Call SRGVAL([F:STJ]QTYSTU/[F:STJ1]QTYSTU,WRND_SOC) From STKVALMAJ     # Alim des montants et SJV
  [L]WTRSTYP=99 : Gosub ECRSTJ : If GOK<1  Return : Endif

  #----- Création du mouvement supplémentaire en moins -----#
  [F:STJ]REGFLG=2
  [F:STJ]QTYPCU=-[F:STJ]QTYPCU
  [F:STJ]QTYSTU=-[F:STJ]QTYSTU
  [F:STJ]ACTQTY=-[F:STJ]ACTQTY
  # Issue 77372 - 2011-10-26 by CCC
  [F:STJ1]=[F:STJ]
  Call SRGVAL(-1,WRND_SOC) From STKVALMAJ     # Alim des montants et SJV
  [L]WTRSTYP=99 : Gosub ECRSTJ : If GOK<1  Return : Endif
Endif
Return

#-----------------------------------------------------------#
# Génération des mvts pour tracabilité de la réception      #
# après un déconditionnement ou rompu lorsque la qté rangée #
# a été partiellement ou pas du tout retrouvée              #
#-----------------------------------------------------------#
$SPEC_SRG1_ROMPU
[L]WQTYPCU   +=([L]WQTYSTU_ORI+[M:STW]QTYSTU(I)*[L]SIGN)/[F:STO]PCUSTUCOE
Call QTEARR ([L]WQTYPCU,[F:STO]PCU) From TRTDIV
[L]WQTYSTU   +=arr([L]WQTYPCU*[F:STO]PCUSTUCOE,10^-[L]WDEC_US)
[L]WQTYSTUACT+=arr([L]WQTYPCU*[F:STO]PCUSTUCOE*[M:STW]QTYSTUACT(I)/[M:STW]QTYSTU(I)
&             ,10^-[L]WDEC_US)
Raz [F:STJ]
nolign=I+1 : [F:STJ]=[M:STW]
[F:STJ]STOFCY   =[L]WFCY
# Si pas de propriétaire renseigné
If [F:STJ]OWNER="" : [F:STJ]OWNER=[L]WFCY : Endif
[F:STJ]UPDCOD   =2
[F:STJ]ITMREF   =[L]WITMREF
[F:STJ]PCU      =[F:STO]PCU
[F:STJ]PCUSTUCOE=[F:STO]PCUSTUCOE
[F:STJ]PCUORI   =[L]WPCU_ORI
[F:STJ]PCUSTUORI=[L]WPCUSTUCOE_ORI
For K=1 To GNBDIE
  [F:STJ]CCE(K-1) = evalue("[M:STW]CCE"+num$(K)+"(I)")
  [F:STJ]DIE(K-1) = GDIE(K)
Next K
#----- Création du mouvement supplémentaire en plus -----#
[F:STJ]REGFLG=1
[F:STJ]QTYPCU=[L]WQTYPCU
[F:STJ]QTYSTU=[L]WQTYSTU
[F:STJ]ACTQTY=[L]WQTYSTUACT

# Issue 77372 - 2011-10-26 by CCC
# Recherche d'un mouvement avec montant. L'unité PCU n'a pas d'importance
Filter [STJ1] Where STOFCY   =[L]WFCY
&                  & VCRTYP   =[M:STW]VCRTYP
&                  & VCRNUM   =[M:STW]VCRNUM
&                  & VCRLIN   =[M:STW]VCRLIN
&                  & LOT      =[L]WLOT_ISS
&                  & SLO      =[L]WSLO_ISS
&                  & BPSLOT   =[L]WBPSLOT_ISS
&                  & SERNUM   =[L]WSERNUM_ISS
&                  & LOC      =[M:STW]LOC(I)
&                  & STA      =[L]WSTA_ISS
&                  & PALNUM   =[F:STO]PALNUM
&                  & CTRNUM   =[F:STO]CTRNUM
&                  & OWNER    =[F:STO]OWNER
&                  & REGFLG<>2
&                  & QTYSTU>0
Read [STJ1]STJ1 First
Filter [STJ1]
[F:STJ]PRINAT = [F:STJ1]PRINAT
If GACTVLT2
    [F:STJ]PRINAT2 = [F:STJ1]PRINAT2
Endif
Call SRGVAL([F:STJ]QTYSTU/[F:STJ1]QTYSTU,WRND_SOC) From STKVALMAJ     # Alim des montants et SJV

[L]WTRSTYP=99 : Gosub ECRSTJ : If GOK<1  Return : Endif

#----- Création du mouvement supplémentaire en moins -----#
[F:STJ]REGFLG=2
[F:STJ]QTYPCU=-[F:STJ]QTYPCU
[F:STJ]QTYSTU=-[F:STJ]QTYSTU
[F:STJ]ACTQTY=-[F:STJ]ACTQTY

# Issue 77372 - 2011-10-26 by CCC
# pas de valeur dans ce mouvement
[F:STJ1]=[F:STJ]
Call SRGVAL(-1,WRND_SOC) From STKVALMAJ     # Alim des montants et SJV

[L]WTRSTYP=99 : Gosub ECRSTJ : If GOK<1  Return : Endif
Return

#---------------------------------------------------------------#
# Spécificités pour déconditionnement dans le plan de rangement #
# ------------------------------------------------------------- #
# - Génération des mvts pour tracabilité de la réception        #
# - Positionnement indicateur sur mvts qui s'annulent           #
#---------------------------------------------------------------#
$SPEC_SRG2
Raz [L]WTRSTYP
[L]WREGFLG=2
[L]WFIC="STOJOU"

#--- TS le 03.12.04 : Rajout de STA, PALNUM, CTRNUM
For [STJ] STJ1 Where STOFCY   =[F:STO]STOFCY
&                  & VCRTYP   =[M:STW]VCRTYP
&                  & VCRNUM   =[M:STW]VCRNUM
&                  & VCRLIN   =[M:STW]VCRLIN
&                  & LOT      =[F:STO]LOT
&                  & SLO      =[F:STO]SLO
&                  & BPSLOT   =[F:STO]BPSLOT
&                  & LOC      =[F:STO]LOC
&                  & SERNUM   =[F:STO]SERNUM
&                  & PCU      =[F:STO]PCU
&                  & PCUSTUCOE=[F:STO]PCUSTUCOE
&                  & STA      =[F:STO]STA
&                  & PALNUM   =[F:STO]PALNUM
&                  & CTRNUM   =[F:STO]CTRNUM
&                  & OWNER    =[F:STO]OWNER
&                  & REGFLG  <>2
&                  & QTYSTU  >=abs([L]WQTYSTU)
  [L]WCLE=[F:STJ]STOFCY-num$([F:STJ]UPDCOD)-[F:STJ]ITMREF-num$([F:STJ]IPTDAT)
  [L]WCLE-=num$([F:STJ]MVTSEQ)-num$([F:STJ]MVTIND)
  Readlock [STJ] Curr
  If fstat=1
    GLOCK="$STOJOU"-[L]WCLE
    #--- Bug 61703 : remplacement Return par Break
    [M:STW]ERRCOD=99 : Gosub TRT_LCK : Break
  Elsif fstat
    Call RSTA("STJ",[L]WCLE) From GLOCK
    #--- Bug 61703 : remplacement Return par Break
    [M:STW]ERRCOD=60 : Gosub TRT_ERR : Break
  Endif
  [F:STJ]REGFLG=2
  Rewrite [STJ]
  If fstat
    Call FSTA("STJ") From GLOCK
    #--- Bug 61703 : remplacement Return par Break
    [M:STW]ERRCOD=70 : Gosub TRT_ERR : Break
  Endif
  If [M:STW]TRAFLG>2
    [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
  Endif
  [L]WREGFLG=1
  Break
Next
#--- Bug 61703
If GOK<1 Return Endif

#----- Le mouvement d'entrée n'a pas été trouvé ! -----#
If [L]WREGFLG=2
  [M:STW]ERRCOD=41 : Gosub TRT_ERR : Return
Endif

If [F:STJ]QTYSTU>abs([L]WQTYSTU)
  [F:STJ1]=[F:STJ]
  [F:STJ]TRSTYP=[M:STW]TRSTYP
  #----- Création du mouvement supplémentaire en plus -----#
  [F:STJ]REGFLG=1
  [F:STJ]QTYPCU+=[L]WQTYPCU
  [F:STJ]QTYSTU+=[L]WQTYSTU
  [F:STJ]ACTQTY+=[L]WQTYSTUACT
  If [F:STJ]PCUORI=""   [F:STJ]PCUORI   =[F:STJ]PCU       : Endif
  If [F:STJ]PCUSTUORI=0 [F:STJ]PCUSTUORI=[F:STJ]PCUSTUCOE : Endif
  # Issue 77372 - 2011-10-26 by CCC
  #[F:STJ]AMTORD=arr([F:STJ1]AMTORD*[F:STJ]QTYSTU/[F:STJ1]QTYSTU,WRND_SOC)
  #[F:STJ]AMTVAL=arr([F:STJ1]AMTVAL*[F:STJ]QTYSTU/[F:STJ1]QTYSTU,WRND_SOC)
  #[F:STJ]AMTDEV=0
  #[F:STJ]VARORD=0
  #[F:STJ]VARVAL=0
  # Issue 77372 - 2011-10-26 by CCC
  Call SRGVAL([F:STJ]QTYSTU/[F:STJ1]QTYSTU,WRND_SOC) From STKVALMAJ     # Alim des montants et SJV
  [L]WTRSTYP=99 : Gosub ECRSTJ : If GOK<1  Return : Endif
  #----- Création du mouvement supplémentaire en moins -----#
  [F:STJ]REGFLG=2
  [F:STJ]QTYPCU=-[F:STJ]QTYPCU
  [F:STJ]QTYSTU=-[F:STJ]QTYSTU
  [F:STJ]ACTQTY=-[F:STJ]ACTQTY
  # Issue 77372 - 2011-10-26 by CCC
  #[F:STJ]AMTORD=-[F:STJ]AMTORD
  #[F:STJ]AMTVAL=-[F:STJ]AMTVAL
  #[F:STJ]AMTDEV=-[F:STJ]AMTDEV
  #[F:STJ]VARORD=-[F:STJ]VARORD
  #[F:STJ]VARVAL=-[F:STJ]VARVAL
  [F:STJ1]=[F:STJ]
  Call SRGVAL(-1,WRND_SOC) From STKVALMAJ     # Alim des montants et SJV
  [L]WTRSTYP=99 : Gosub ECRSTJ : If GOK<1  Return : Endif
Endif
[L]WREGFLG=1
Return


#-------------------------------------------------------#
#     Chargement et écriture du mouvement de stock      #
# ----------------------------------------------------- #
# [L]WCODFONC : Code fonction (1=entrée, 2=sortie)      #
# [L]WUPDCOD  : Code màj (1=Non, mvt attente, 2=Oui)    #
# [L]WREGFLG  : Mvts annulés (1=Non, 2=Oui)             #
# [L]WTRSTYP  : Type de mvt (96=Déconditionnement)      #
#                                                       #
# Si [L]WTRSTYP=95 --> Mvts de rangements issus du plan #
#         alimentation AMTORD, AMTVAL, PRIORD et PRIVAL #
# Si [L]WTRSTYP=96 --> [L]WPCU       : UC               #
#                      [L]WPCUSTUCOE : Coef UC-US       #
#                      [L]WQTYPCU    : Qté en UC        #
#                      [L]WQTYSTU    : Qté en US        #
#                      [L]WQTYSTUACT : Qté active en US #
#                                                       #
# Si [L]WTRSTYP=97 --> Mvts supplémentaires générés par #
#       le réajustement du PMP, [F:STJ] est déjà chargé #
# Si [L]WTRSTYP=98 --> Mvts supplémentaires générés par #
#    le réajustement coût FIFO, [F:STJ] est déjà chargé #
# Si [L]WTRSTYP=99 --> Mvts supplémentaires générés par #
#         le plan de rangement, [F:STJ] est déjà chargé #
#-------------------------------------------------------#
$ECRSTJ

If [L]WTRSTYP<97
  Raz [F:STJ]
  nolign=I+1 : [F:STJ]=[M:STW]
  If find([M:STW]TRSTYP,7,9,14,21) & [M:STW]TRSTYPLIG(I)>0 & [M:STW]TRSTYPLIG(I)<96
    [F:STJ]TRSTYP=[M:STW]TRSTYPLIG(I)
  Endif
  [F:STJ]STOFCY=[L]WFCY
  # Si pas de propriétaire renseigné et mouvement pas en attente
  If [F:STJ]OWNER="" & [L]WUPDCOD>1 : [F:STJ]OWNER=[L]WFCY : Endif
  [F:STJ]UPDCOD=[L]WUPDCOD
  [F:STJ]ITMREF=[L]WITMREF
  [F:STJ]REGFLG=[L]WREGFLG
  #----- Particularité pour l'inventaire ------#
  If [M:STW]TRSTYP=13 & [M:STW]VCRTYP=9
    [F:STJ]VCRLIN=[M:STW]MVTSEQ(I)
  Endif
  #----- Particularité pour les transferts inter-sites -----#
  If [M:STW]TRSTYP=14 & [L]WFLUX=2
    For K=1 To GNBDIE
      [F:STJ]CCE(K-1) = evalue("[M:STW]CCS"+num$(K)+"(I)")
      [F:STJ]DIE(K-1) = GDIE(K)
    Next K
    # Si inter-société (et flux de sortie)
    # [M:STW]PRIORD(I) contient la valeur pour le flux d'entrée
    If [M:STW]BETCPY=2
       [F:STJ]PRIORD = [F:STJ]PRIVAL
    Endif
  #----- Cas standard : tous les autres mouvements -----#
  Else
    For K=1 To GNBDIE
      [F:STJ]CCE(K-1) = evalue("[M:STW]CCE"+num$(K)+"(I)")
      [F:STJ]DIE(K-1) = GDIE(K)
    Next K
  Endif
  #-----
  If [L]WTRSTYP=96
    # Effacement des prix si déconditionnement
    Raz [F:STJ]AMTORD, [F:STJ]AMTVAL, [F:STJ]AMTDEV
    Raz [F:STJ]VARORD, [F:STJ]VARVAL
    [F:STJ]TRSTYP   =21              : # Faut-il mettre un type mvt spécial ?
    [F:STJ]PCU      =[L]WPCU
    [F:STJ]PCUSTUCOE=[L]WPCUSTUCOE
    [F:STJ]QTYPCU   =[L]WQTYPCU
    [F:STJ]QTYSTU   =[L]WQTYSTU
    [F:STJ]ACTQTY   =[L]WQTYSTUACT
  Else
    [F:STJ]QTYPCU=[M:STW]QTYPCU(I)*[L]SIGN
    [F:STJ]QTYSTU=[M:STW]QTYSTU(I)*[L]SIGN

    # Si mvt de sortie d'un contrôle qualité avec changement de titre
    # le mvt de sortie est crée avec les qtés et titres origine
    If [M:STW]TRSTYP=8 & [L]WFLUX=2 & [M:STW]QTYACTORI(I)<>0
      [F:STJ]ACTQTY = [M:STW]QTYACTORI(I)*[L]SIGN
      [F:STJ]POT    = [M:STW]POTORI(I)
      [F:STJ]ACT    = [M:STW]ACTORI(I)
    Else
      [F:STJ]ACTQTY = [M:STW]QTYSTUACT(I)*[L]SIGN
    Endif

  Endif
  #----- Chargement champs nécessaires à l'interface comptable -----#
  [F:STJ]FINRSPFCY=[F:FCY]FINRSPFCY
  [F:STJ]PCUORI   =[L]WPCU_ORI
  [F:STJ]PCUSTUORI=[L]WPCUSTUCOE_ORI
Endif
#----- Chargement no indice si inventaire autrement indice nul -----#
If [M:STW]TRSTYP=13 & [M:STW]VCRTYP=9
  [F:STJ]MVTIND=[L]WCTR_MVTIND
Else
  Raz [F:STJ]MVTIND
Endif

#--- Mettre GPE à 1, pour ne pas agréger les mouvements
GPE=0
GPOINT="AGRSTJ"
Gosub ENTREE From EXEFNC
If GPE=1
   GPE=0 : Goto ECRSTJ_SUI
Endif

#----- Agrégation des mvts si même ligne, même pièce et mêmes caractéristiques et non interfacé -----#
If [F:STJ]SERNUM="" & [M:STW]MAJCOD(I)="C" & [M:STW]MAJTYP(I)<>"C" & [L]WMAJCOD="C"
  Raz [F:STJ1]
  Columns [STJ1] (STOFCY,UPDCOD,ITMREF,IPTDAT,MVTSEQ,MVTIND,QTYSTU,AMTORD,AMTVAL,
&                 QTYPCU,VARORD,VARVAL,ACTQTY,PRIORD,PRIVAL)
  For [STJ1] STJ1 Where STOFCY   =[F:STJ]STOFCY
&                     & VCRTYP   =[F:STJ]VCRTYP
&                     & VCRNUM   =[F:STJ]VCRNUM
&                     & VCRLIN   =[F:STJ]VCRLIN
&                     & TRSTYP   =[F:STJ]TRSTYP
&                     & UPDCOD   =[F:STJ]UPDCOD
&                     & ITMREF   =[F:STJ]ITMREF
&                     & IPTDAT   =[F:STJ]IPTDAT
&                     & LOT      =[F:STJ]LOT
&                     & SLO      =[F:STJ]SLO
&                     & BPSLOT   =[F:STJ]BPSLOT
&                     & PALNUM   =[F:STJ]PALNUM
&                     & CTRNUM   =[F:STJ]CTRNUM
&                     & STA      =[F:STJ]STA
&                     & LOC      =[F:STJ]LOC
&                     & PCU      =[F:STJ]PCU
&                     & PCUSTUCOE=[F:STJ]PCUSTUCOE
&                     & SERNUM   =[F:STJ]SERNUM
&                     & QLYCTLDEM=[F:STJ]QLYCTLDEM
&                     & OWNER    =[F:STJ]OWNER
&                     & POT      =[F:STJ]POT
&                     & ACT      =[F:STJ]ACT
&                     & REGFLG   =[F:STJ]REGFLG
&                     & AGGIFAFLG<>2
    Break
  Next
  Columns [STJ1]
  If [F:STJ1]STOFCY<>""
    Call BEFUPDSTJ(I) From STKVALMAJ

    #--- Si agrégation STJ, on ne passe pas par ECRSTJ From STKLIB
    #--> il faut gérer la traçabilité ici en créant un nouvel enregistrement
    If GSSTOTRK=2 & [F:ITM]TRKCOD>1 & [F:STJ]UPDCOD=2 & [F:STJ]TRSTYP <> 0
       [F:STJ]MVTSEQ = [F:STJ1]MVTSEQ
       Call MAJTRK(WRET) From STKLIB
    Endif

    [F:STJ1]QTYPCU=[F:STJ]QTYPCU
    [F:STJ1]QTYSTU=[F:STJ]QTYSTU
    [F:STJ1]ACTQTY=[F:STJ]ACTQTY

    [L]WFIC ="STOJOU"
    [L]WCLE =[F:STJ1]STOFCY-num$([F:STJ1]UPDCOD)-[F:STJ1]ITMREF-num$([F:STJ1]IPTDAT)
    [L]WCLE-=num$([F:STJ1]MVTSEQ)-num$([F:STJ1]MVTIND)
    Update [STJ] Where STOFCY=[F:STJ1]STOFCY
&                    & UPDCOD=[F:STJ1]UPDCOD
&                    & ITMREF=[F:STJ1]ITMREF
&                    & IPTDAT=[F:STJ1]IPTDAT
&                    & MVTSEQ=[F:STJ1]MVTSEQ
&                    & MVTIND=[F:STJ1]MVTIND
&                With QTYPCU+=[F:STJ1]QTYPCU,
&                     QTYSTU+=[F:STJ1]QTYSTU,
&                     AMTORD+=[F:STJ1]AMTORD,
&                     AMTVAL+=[F:STJ1]AMTVAL,
&                     VARORD+=[F:STJ1]VARORD,
&                     VARVAL+=[F:STJ1]VARVAL,
&                     ACTQTY+=[F:STJ1]ACTQTY,
&                     PRIORD =[F:STJ1]PRIORD,
&                     PRIVAL =[F:STJ1]PRIVAL,
&                     UPDUSR =GUSER,
&                     UPDDAT =date$
    If fstat=1
      GLOCK="$STOJOU"-[L]WCLE
      [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
    Elsif fstat
      Call RSTA("STJ",[L]WCLE) From GLOCK
      [M:STW]ERRCOD=60 : Gosub TRT_ERR : Return
    Endif
    #-----
    If [M:STW]TRAFLG>2
      [L]WMESSAGE=mess(554,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
    Endif
    Return
  Endif
Endif

$ECRSTJ_SUI
If WTRSTYP<97
    Call BEFWRISTJ(I) From STKVALMAJ
Endif

#----- Création du mouvement de stock -----#
Call ECRSTJ([L]WCTR_MVTSEQ,[L]WRET) From STKLIB
Case [L]WRET
  When 1
    Call FSTA("STJ") From GLOCK
    [M:STW]ERRCOD=70 : [L]WFIC="STOJOU" : Gosub TRT_ERR : Return
  When 2
    GLOCK="$STOTRK"-[F:STJ]ITMREF-[F:STJ]LOT-[F:STJ]STOFCY
    [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
  When 3
    Call FSTA("STR") From GLOCK
    [M:STW]ERRCOD=70 : [L]WFIC="STOTRK" : Gosub TRT_ERR : Return
  When 4
    [M:STW]ERRCOD=16 : Gosub TRT_ERR : Return
Endcase

If WTRSTYP<97
    Call AFTWRISTJ(I) From STKVALMAJ
Elsif GACTDECCST  # SJV est déjà alimenté, il ne lui manque plus que la clé
    [F:SJV]STOFCY=[F:STJ]STOFCY
    [F:SJV]UPDCOD=[F:STJ]UPDCOD
    [F:SJV]ITMREF=[F:STJ]ITMREF
    [F:SJV]IPTDAT=[F:STJ]IPTDAT
    [F:SJV]MVTSEQ=[F:STJ]MVTSEQ
    [F:SJV]MVTIND=[F:STJ]MVTIND
    Write [SJV]
    If fstat
        Call FSTA("SJV") From GLOCK
        [M:STW]ERRCOD=70 : [L]WFIC="STOJOUVAL" : Gosub TRT_ERR : Return
    Endif
Endif

#----- Prochain no d'indice ou no de séquence -----#
If [M:STW]TRSTYP=13 & [M:STW]VCRTYP=9
  #----- Si inventaire, le no de séquence est fixe et l'indice se décrémente -----#
  [L]WCTR_MVTIND=[F:STJ]MVTIND-1
Else
  If WMVTSEQSTR=0
    WMVTSEQSTR=[F:STJ]MVTSEQ    # Récupération du 1er n° de séquence utilisé
  Endif
  #----- Dans les autres cas le no de séquence se décrémente et l'indice est nul -----#
  [L]WCTR_MVTSEQ=[F:STJ]MVTSEQ-1
Endif
#-----
If [M:STW]TRAFLG>2
  [L]WCLE =[F:STJ]STOFCY-num$([F:STJ]UPDCOD)-[F:STJ]ITMREF-num$([F:STJ]IPTDAT)
  [L]WCLE-=num$([F:STJ]MVTSEQ)-num$([F:STJ]MVTIND)
  [L]WFIC ="STOJOU" : [L]WMESSAGE=mess(233,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
  [L]WCLE =[F:SJV]STOFCY-num$([F:SJV]UPDCOD)-[F:SJV]ITMREF-num$([F:SJV]IPTDAT)
  [L]WCLE-=num$([F:SJV]MVTSEQ)-num$([F:SJV]MVTIND)
  [L]WFIC ="STOJOUVAL" : [L]WMESSAGE=mess(233,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
Endif
Return


#------------------------------------#
# Ecriture de la ligne stock (STOCK) #
#------------------------------------#
$ECRSTO
[L]WFIC="STOCK"
[L]WCLE=[F:STO]STOFCY-num$([F:STO]STOCOU)
[L]WMESSAGE=mess(233,197,1)
#----- Ne pas créer de ligne de stock avec une date dernière entrée à zéro -----#
If [F:STO]LASRCPDAT=[0/0/0] & [L]WCODFONC=3
  [F:STO]LASRCPDAT=[L]WLASRCPDAT : # Changement stock, récup date ligne stock sortie
Endif
If [F:STO]LASRCPDAT=[0/0/0]
  [F:STO]LASRCPDAT=[M:STW]IPTDAT : # Par défaut ce sera la date d'imputation
Endif
#----- Ecriture de la ligne de stock -----#
If [L]WMAJCODSTO="M"
   Call ECRSTO("L",[L]WRET) From STKLIB
Else
   #--- Bug 65765
   #Call ECRSTO("",[L]WRET) From STKLIB
   Call ECRSTO(WGESLIBEMP,[L]WRET) From STKLIB
   #---
Endif
Case [L]WRET
  When 1
    [L]WFIC="STOLOC"
    [L]WCLE=[L]WFCY-[F:STO]LOC
    GLOCK="$STOLOC"-[L]WCLE
    [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
  When 2
    [L]WFIC="STOLOC"
    [L]WCLE=[L]WFCY-[F:STO]LOC
    Call FSTA("STC") From GLOCK
    [M:STW]ERRCOD=70 : Gosub TRT_ERR : Return
  When 3
    Call FSTA("STO") From GLOCK
    [M:STW]ERRCOD=70 : Gosub TRT_ERR : Return
Endcase
If [M:STW]TRAFLG>2
  [L]WCLE-=[F:STO]ITMREF-[F:STO]LOT-[F:STO]SLO : Gosub TRACE_DETAILLEE From STKMAJSUP
Endif
#----- Mise à jour plan de rangement si nécessaire -----#
If [F:STO]LOCCAT=2 & [F:STO]QTYSTUACT<>0
  [L]WQTEACT=[F:STO]QTYSTUACT
  Gosub MAJ_STOSRG From STKMAJSUP : If GOK<1  Return : Endif
Endif
Return


#-----------------------------------------------------------------------#
# Réécriture de la ligne de stock (STOCK) ou suppression si qtés à zéro #
#-----------------------------------------------------------------------#
$REWSTO
[L]WFIC="STOCK"
[L]WCLE=[L]WFCY-num$([L]WSTOCOU)
#----- La ligne de stock doit-elle être supprimée ? Oui si [L]WRET=2 -----#
Raz [L]WRET
#--- Issue 114287
#If [F:STO]QTYPCU=0 & [F:STO]QTYSTU=0 & [F:STO]QTYSTUACT=0
If ([F:STO]QTYPCU=0 & [F:STO]QTYSTU=0) | [F:STO]QTYSTUACT=0
#---
  #----- Quantité allouée ou en traitement non nulle ! -----#
  If [M:STW]TRAFLG>2 & ([F:STO]CUMALLQTY<>0 | [F:STO]CUMWIPQTY<>0)
    [L]WMESSAGE =[F:STO]STOFCY-num$([F:STO]STOCOU)-[F:STO]ITMREF-mess(588,197,1)
    Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
    If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
  Endif
  #-----
  [L]WRET=2  : # La ligne de stock doit être supprimée
  If I<[M:STW]NBLIG-1       &
&    [M:STW]MAJCOD(I)="A"   &
&    [M:STW]MAJCOD(I+1)="C" &
&    [M:STW]ITMREFLIG(I)=[M:STW]ITMREFLIG(I+1) &
&    [M:STW]LOT(I)      =[M:STW]LOT(I+1)       &
&    [M:STW]SLO(I)      =[M:STW]SLO(I+1)       &
&    [M:STW]STA(I)      =[M:STW]STA(I+1)       &
&    [M:STW]LOC(I)      =[M:STW]LOC(I+1)       &
&    [M:STW]SERNUM(I)   =[M:STW]SERNUM(I+1)    &
&    [M:STW]PALNUM(I)   =[M:STW]PALNUM(I+1)    &
&    [M:STW]CTRNUM(I)   =[M:STW]CTRNUM(I+1)    &
&    [M:STW]OWNER(I)    =[M:STW]OWNER(I+1)     &
&    [M:STW]PCU(I)      =[M:STW]PCU(I+1)       &
&    [M:STW]PCUSTUCOE(I)=[M:STW]PCUSTUCOE(I+1)
    [L]WRET=0 : # La ligne de stock doit être conservée pour la màj suivante
  Endif
Endif
#-----
If [L]WRET=2 & ([F:STO]CUNLISNUM="" | [M:STW]TRSTYP=13)
  #----- Suppression ligne de stock -----#
  If [L]WMAJCODSTO="M"
    Call DELSTO("L",[L]WRET) From STKLIB
  Else
    #--- Bug 65765
    #Call DELSTO("",[L]WRET) From STKLIB
    Call DELSTO(WGESLIBEMP,[L]WRET) From STKLIB
    #---
  Endif
  Case [L]WRET
    When 1
      [L]WFIC="STOLOC"
      [L]WCLE=[L]WFCY-[F:STO]LOC
      GLOCK="$STOLOC"-[L]WCLE
      [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
    When 2
      [L]WFIC="STOLOC"
      [L]WCLE=[L]WFCY-[F:STO]LOC
      Call FSTA("STC") From GLOCK
      [M:STW]ERRCOD=70 : Gosub TRT_ERR : Return
    When 3
      If fstat=1
        GLOCK="$STOCK"-[L]WCLE
        [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
      Elsif fstat
        Call FSTA("STO") From GLOCK
        [M:STW]ERRCOD=60 : Gosub TRT_ERR : Return
      Endif
  Endcase
  [L]WMESSAGE=mess(175,197,1)
Else
  If [M:STW]TRSTYP=13
     [F:STO]CUNLOKFLG = 1
     [F:STO]CUNLISNUM = ""
     [F:STO]LASCUNDAT = [M:STW]IPTDAT
  Endif
  #----- Réécriture ligne de stock -----#
  If [L]WMAJCODSTO="M"
    Call REWSTO("L",[L]WRET) From STKLIB
  Else
    #--- Bug 65765
    #Call REWSTO("",[L]WRET) From STKLIB
    Call REWSTO(WGESLIBEMP,[L]WRET) From STKLIB
    #---
  Endif
  Case [L]WRET
    When 1
      [L]WFIC="STOLOC"
      [L]WCLE=[L]WFCY-[F:STO]LOC
      GLOCK="$STOLOC"-[L]WCLE
      [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
    When 2
      [L]WFIC="STOLOC"
      [L]WCLE=[L]WFCY-[F:STO]LOC
      Call FSTA("STC") From GLOCK
      [M:STW]ERRCOD=70 : Gosub TRT_ERR : Return
    When 3
      Call FSTA("STO") From GLOCK
      [M:STW]ERRCOD=70 : Gosub TRT_ERR : Return
  Endcase
  [L]WMESSAGE=mess(232,197,1)
Endif
#-----
If [M:STW]TRAFLG>2
  [L]WCLE-=[F:STO]ITMREF-[F:STO]LOT-[F:STO]SLO : Gosub TRACE_DETAILLEE From STKMAJSUP
Endif
#----- Mise à jour du plan de rangement si nécessaire -----#
If [F:STO]LOCCAT=2
  Gosub MAJ_STOSRG From STKMAJSUP : If GOK<1 Return : Endif
Endif
Return


#-------------------------------------------------#
# Vérification et calcul qtés allouées à déplacer #
#-------------------------------------------------#
$VERIF_ALLOC

If [L]WCODFONC=3 : # Changement d'emplacement
  Case [L]WFLUX
    When  1      : # Entrée
      If [M:STW]MAJCOD(I)="A" : # Annulation de changement d'emplacement (entrée)
        If [F:STO]CUMALLQTY=0 & [F:STO]CUMALLQTA=0  Return : Endif
        [L]WDIFALLQTY   +=max([F:STO]CUMALLQTY-[F:STO]QTYSTU+[F:STO]CUMWIPQTY,0)
        [L]WDIFALLQTA   +=max([F:STO]CUMALLQTA-[F:STO]QTYSTUACT+[F:STO]CUMWIPQTA,0)
        [F:STO]CUMALLQTY-=max([F:STO]CUMALLQTY-[F:STO]QTYSTU+[F:STO]CUMWIPQTY,0)
        [F:STO]CUMALLQTA-=max([F:STO]CUMALLQTA-[F:STO]QTYSTUACT+[F:STO]CUMWIPQTA,0)
        [L]WSTOCOU_RCP=[F:STO]STOCOU
      Else
        [F:STO]CUMALLQTY+=[L]WDIFALLQTY
        [F:STO]CUMALLQTA+=[L]WDIFALLQTA
      Endif
    When  2      : # Sortie
      If [M:STW]MAJCOD(I)="A" : # Annulation de changement d'emplacement (sortie)
        [F:STO]CUMALLQTY+=[L]WDIFALLQTY
        [F:STO]CUMALLQTA+=[L]WDIFALLQTA
      Else
        If [F:STO]CUMALLQTY=0 & [F:STO]CUMALLQTA=0  Return : Endif
        # Si consommation qté allouée en priorité
        # Actuellement, possible en mvt interne avec chgt emp (uniqt création)
        If [M:STW]PIOQTY=3
           [L]WDIFALLQTY   +=min([F:STO]CUMALLQTY,abs([M:STW]QTYSTU(I)))
           [L]WDIFALLQTA   +=min([F:STO]CUMALLQTA,abs([M:STW]QTYSTUACT(I)))
           [F:STO]CUMALLQTY-=min([F:STO]CUMALLQTY,abs([M:STW]QTYSTU(I)))
           [F:STO]CUMALLQTA-=min([F:STO]CUMALLQTA,abs([M:STW]QTYSTUACT(I)))
        Else
           [L]WDIFALLQTY   +=max([F:STO]CUMALLQTY-[F:STO]QTYSTU+[F:STO]CUMWIPQTY,0)
           [L]WDIFALLQTA   +=max([F:STO]CUMALLQTA-[F:STO]QTYSTUACT+[F:STO]CUMWIPQTA,0)
           [F:STO]CUMALLQTY-=max([F:STO]CUMALLQTY-[F:STO]QTYSTU+[F:STO]CUMWIPQTY,0)
           [F:STO]CUMALLQTA-=max([F:STO]CUMALLQTA-[F:STO]QTYSTUACT+[F:STO]CUMWIPQTA,0)
        Endif
        [L]WSTOCOU_ISS=[F:STO]STOCOU
      Endif
 Endcase
Endif
#-----
If [M:STW]TRAFLG>2
  #----- La qté disponible est inférieure à la qté allouée -----#
  If [F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY<0 & [F:STO]CUMALLQTY<>0
    [L]WMESSAGE =[F:STO]STOFCY-num$([F:STO]STOCOU)-[F:STO]ITMREF
    [L]WMESSAGE-=mess(489,197,1)-"("+num$([F:STO]QTYSTU-[F:STO]CUMWIPQTY)
    [L]WMESSAGE+="<"+num$([F:STO]CUMALLQTY)+")"
    Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
    If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
  #----- La qté en traitement est supérieure à la qté en stock ! -----#
  Elsif [F:STO]QTYSTU<[F:STO]CUMWIPQTY
    [L]WMESSAGE =[F:STO]STOFCY-num$([F:STO]STOCOU)-[F:STO]ITMREF
    [L]WMESSAGE-=mess(586,197,1)-"("+num$([F:STO]QTYSTU)+"<"+num$([F:STO]CUMWIPQTY)+")"
    Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
    If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
  Endif
Endif
Return


#---------------------------------------------#
#        Traitement des allocations           #
# faire suivre sur la nouvelle ligne de stock #
# ------------------------------------------- #
# [L]WSTOCOU_SVG : Ancien STOCOU              #
# [L]WSTOCOU     : Nouveau STOCOU             #
# [L]WALLQTY     : Qté à traiter en US        #
# [L]WALLQTA     : Qté à traiter en US active #
#---------------------------------------------#
$TRT_ALLOCATION

If [L]WALLQTY=0  Return : Endif

Raz [L]WRET

# Si bon de préparation avec changement d'emplacement
# ou pesée avec changement d'emplacement (spécifique)
# récupération du no séquence d'allocation à faire suivre
If [M:STW]TRSTYP=7 & find([M:STW]VCRTYP,3,10)
   If [M:STW]MVTSEQ(I)<>0
      [M:STW]SEQALL = [M:STW]MVTSEQ(I)
   Else
      [M:STW]SEQALL = 0
   Endif
Endif

# Si réapprovisionnement et consommation sur une allocation particulière
# ou bon de préparation avec changement d'emplacement
# --> traitement de celle-ci
If find([M:STW]TRSTYP,7,25) & [M:STW]SEQALL<>0
  Read [STA] STA0=[L]WFCY;[L]WITMREF;[L]WSTOCOU_SVG;[M:STW]SEQALL
  If fstat
    Call RSTA("STA",[L]WFCY-[L]WITMREF-num$([L]WSTOCOU_SVG)-num$([M:STW]SEQALL)) From GLOCK
    [M:STW]ERRCOD=60 : Gosub TRT_ERR : Return
  Endif
  # L'allocation correspond exactement à la quantité
  # --> on la traite, et c'est fini
  If [F:STA]QTYSTU=[L]WALLQTY
    [L]WSEQ = [F:STA]SEQ
    Gosub MAJALL_TOTAL
    If GOK<1 : Return : Endif
    Raz [L]WALLQTY, [L]WALLQTA
    #--- Bug 84920
    #--- Si chgt emp sauvegarde nouvelle séquence allocation
    If [M:STW]TRSTYP=7 [M:STW]MVTSEQ(I)=[F:STA]SEQ Endif
    Return
  # L'allocation est supérieure à la quantité
  # --> on la traite, et c'est fini
  Elsif [F:STA]QTYSTU>[L]WALLQTY
    [L]WSEQ    = [F:STA]SEQ
    [L]WQTE    = [L]WALLQTY
    [L]WQTEACT = [L]WALLQTA
    Gosub MAJALL_PARTIEL
    If GOK<1 : Return : Endif
    Raz [L]WALLQTY, [L]WALLQTA
    #--- Bug 84920
    #--- Si chgt emp sauvegarde nouvelle séquence allocation
    If [M:STW]TRSTYP=7 [M:STW]MVTSEQ(I)=[F:STA]SEQ Endif
    Return
  # L'allocation est inférieure à la quantité
  # --> on la traite, et on poursuit avec le fonctionnement standard
  Else
    [L]WSEQ    = [F:STA]SEQ
    [L]WQTE    = [F:STA]QTYSTU
    [L]WQTEACT = [F:STA]QTYSTUACT
    [L]WALLQTY-= [F:STA]QTYSTU
    [L]WALLQTA-= [F:STA]QTYSTUACT
    Gosub MAJALL_TOTAL
    If GOK<1 : Return : Endif
    #--- Bug 84920
    #--- Si chgt emp sauvegarde nouvelle séquence allocation
    If [M:STW]TRSTYP=7 [M:STW]MVTSEQ(I)=[F:STA]SEQ Endif
  Endif
Endif

#----- Recherche d'une allocation égale à la quantité à traiter -----#
Raz [L]WRET

#--- Dem 60982
Local Char WSTACRIT(240)
GPOINT="STA_CRIT" : Gosub ENTREE From EXEFNC
If WSTACRIT="" WSTACRIT="1=1" Endif
#---
For [STA] STA0 Where STOFCY=[L]WFCY
&                  & ITMREF=[L]WITMREF
&                  & STOCOU=[L]WSTOCOU_SVG
&                  & QTYSTU=[L]WALLQTY
&                  & evalue(WSTACRIT)      : #--- Dem 60982

  [L]WSEQ=[F:STA]SEQ : [L]WRET=1 : Break
Next
If [L]WRET=1
  #----- L'allocation trouvée correspond exactement à la quantité -----#
  Gosub MAJALL_TOTAL : If GOK<1  Return : Endif
  Raz [L]WALLQTY, [L]WALLQTA
Else
  #----- Recherche d'une allocation supérieure à la quantité à traiter -----#
  For [STA] STA0 Where STOFCY=[L]WFCY
&                    & ITMREF=[L]WITMREF
&                    & STOCOU=[L]WSTOCOU_SVG
&                    & QTYSTU>[L]WALLQTY
    [L]WSEQ=[F:STA]SEQ : [L]WRET=1 : Break
  Next
  If [L]WRET=1
    #----- L'allocation trouvée est supérieure à la quantité -----#
    [L]WQTE   =[L]WALLQTY
    [L]WQTEACT=[L]WALLQTA
    Gosub MAJALL_PARTIEL : If GOK<1  Return : Endif
    Raz [L]WALLQTY, [L]WALLQTA
  Else
    #----- Prendre les allocations jusqu'à épuisement de la qté à traiter -----#
    For [STA] STA0 Where STOFCY=[L]WFCY
&                      & ITMREF=[L]WITMREF
&                      & STOCOU=[L]WSTOCOU_SVG
      [L]WSEQ=[F:STA]SEQ
      If [F:STA]QTYSTU>[L]WALLQTY
        [L]WQTE   =[L]WALLQTY
        [L]WQTEACT=[L]WALLQTA
        Raz [L]WALLQTY, [L]WALLQTA
        #--- Bug 61703 : remplacement Return par Break
        Gosub MAJALL_PARTIEL : If GOK<1  Break : Endif
      Else
        [L]WQTE    =[F:STA]QTYSTU
        [L]WQTEACT =[F:STA]QTYSTUACT
        [L]WALLQTY-=[F:STA]QTYSTU
        [L]WALLQTA-=[F:STA]QTYSTUACT
        #--- Bug 61703 : remplacement Return par Break
        Gosub MAJALL_TOTAL : If GOK<1  Break : Endif
      Endif
      If [L]WALLQTY=0  Break : Endif
    Next
    #--- Bug 61703
    If GOK<1 Return Endif
  Endif
Endif
#----- Si la qté n'a pas été entièrement traitée, écriture dans la trace -----#
If [L]WALLQTY<>0 & [M:STW]TRAFLG>2
  [L]WMESSAGE =[L]WFCY-[L]WITMREF-num$([L]WSTOCOU_SVG)
  [L]WMESSAGE-=mess(35,191,1)-mess(168,197,1)+" ("+num$([L]WALLQTY)+")"
  Call ECR_TRACE([L]WMESSAGE,0) From GESECRAN
  If dim(GPURTRACE)>0  GPURTRACE=2 : Endif
Endif
Return

#--------------------------------------#
#  Mise à jour totale de l'allocation  #
# ------------------------------------ #
# [L]WSTOCOU_SVG : Ancien STOCOU       #
# [L]WSTOCOU     : Nouveau STOCOU      #
# [L]WSEQ        : Séquence à traiter  #
#--------------------------------------#
$MAJALL_TOTAL
[L]WFIC="STOALL"
[L]WCLE=[L]WFCY-[L]WITMREF-num$([L]WSTOCOU_SVG)-num$([L]WSEQ)
#----- Suppression de l'allocation avec l'ancien STOCOU -----#
Delete [STA] Where STOFCY=[L]WFCY
&                & ITMREF=[L]WITMREF
&                & STOCOU=[L]WSTOCOU_SVG
&                & SEQ   =[L]WSEQ
If fstat
  Call FSTA("STA") From GLOCK
  [M:STW]ERRCOD=70 : Gosub TRT_ERR : Return
Endif
If [M:STW]TRAFLG>2
  [L]WMESSAGE=mess(175,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
Endif
#----- Recréation de l'allocation avec le nouveau STOCOU -----#
[F:STA]STOCOU=[L]WSTOCOU
Gosub ECRSTA : If GOK<1  Return : Endif
Return

#-------------------------------------------#
#   Mise à jour partielle de l'allocation   #
# ----------------------------------------- #
# [L]WSTOCOU_SVG : Ancien STOCOU            #
# [L]WSTOCOU     : Nouveau STOCOU           #
# [L]WSEQ        : Séquence à traiter       #
# [L]WQTE        : Qté traitée en US        #
# [L]WQTEACT     : Qté traitée en US active #
#-------------------------------------------#
$MAJALL_PARTIEL
[L]WFIC="STOALL"
[L]WCLE=[L]WFCY-[L]WITMREF-num$([L]WSTOCOU_SVG)-num$([L]WSEQ)
#----- Mise à jour allocation restante avec l'ancien STOCOU -----#
Readlock [STA] STA0=[L]WFCY;[L]WITMREF;[L]WSTOCOU_SVG;[L]WSEQ
If fstat=1
  GLOCK="$STOALL"-[L]WCLE
  [M:STW]ERRCOD=99 : Gosub TRT_LCK : Return
Elsif fstat
  Call RSTA("STA",[L]WCLE) From GLOCK
  [M:STW]ERRCOD=60 : Gosub TRT_ERR : Return
Endif
[F:STA]QTYSTU   -=[L]WQTE
[F:STA]QTYSTUACT-=[L]WQTEACT
Gosub REWSTA : If GOK<1  Return : Endif
#----- Recréation allocation traitée avec nouveau STOCOU -----#
[F:STA]STOCOU   =[L]WSTOCOU
[F:STA]QTYSTU   =[L]WQTE
[F:STA]QTYSTUACT=[L]WQTEACT
Gosub ECRSTA : If GOK<1  Return : Endif
Return

#--------------------------#
# Ecriture de l'allocation #
#--------------------------#
$ECRSTA
Filter [STA1] Where STOFCY=[F:STA]STOFCY
&                 & ITMREF=[F:STA]ITMREF
&                 & STOCOU=[F:STA]STOCOU
Read [STA1] STA0 First
If fstat [F:STA]SEQ=99999999 Else [F:STA]SEQ=[F:STA1]SEQ-1 : Endif
Filter [STA1]

# Raz du type et de l'emplacement de conso exclusive de l'allocation
# si son emplacement est cohérent avec ces contraintes
If [F:STA]DEFLOC<>"" | [F:STA]DEFLOCTYP<>""
  Read [STO1]STO0=[F:STA]STOFCY;[F:STA]STOCOU
  If fstat
    Call RSTA("STO1",[F:STA]STOFCY-num$([F:STA]STOCOU)) From GLOCK
    GOK=0 : [M:STW]ERRCOD=60 : Gosub TRT_ERR : Return
  Else
    If [F:STA]DEFLOC<>""
      If pat([F:STO1]LOC,[F:STA]DEFLOC)=1
        Raz [F:STA]DEFLOCTYP, [F:STA]DEFLOC
      Endif
    Elsif [F:STA]DEFLOCTYP<>""
      If pat([F:STO1]LOCTYP,[F:STA]DEFLOCTYP)=1
        Raz [F:STA]DEFLOCTYP, [F:STA]DEFLOC
      Endif
    Endif
  Endif
Endif

Call ECRSTA From STKLIB
If fstat
  Call FSTA("STA") From GLOCK
  [M:STW]ERRCOD=70 : Gosub TRT_ERR : Return
Endif
If [M:STW]TRAFLG>2
  [L]WFIC="STOALL"
  [L]WCLE=[F:STA]STOFCY-[F:STA]ITMREF-num$([F:STA]STOCOU)-num$([F:STA]SEQ)
  [L]WMESSAGE=mess(233,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
Endif
Return

#----------------------------#
# Réécriture de l'allocation #
#----------------------------#
$REWSTA
# Raz du type et de l'emplacement de conso exclusive de l'allocation
# si son emplacement est cohérent avec ces contraintes
If [F:STA]DEFLOC<>"" | [F:STA]DEFLOCTYP<>""
  Read [STO1]STO0=[F:STA]STOFCY;[F:STA]STOCOU
  If fstat
    Call RSTA("STO1",[F:STA]STOFCY-num$([F:STA]STOCOU)) From GLOCK
    GOK=0 : [M:STW]ERRCOD=60 : Gosub TRT_ERR : Return
  Else
    If [F:STA]DEFLOC<>""
      If pat([F:STO1]LOC,[F:STA]DEFLOC)=1
        Raz [F:STA]DEFLOCTYP, [F:STA]DEFLOC
      Endif
    Elsif [F:STA]DEFLOCTYP<>""
      If pat([F:STO1]LOCTYP,[F:STA]DEFLOCTYP)=1
        Raz [F:STA]DEFLOCTYP, [F:STA]DEFLOC
      Endif
    Endif
  Endif
Endif

Call REWSTA From STKLIB
If fstat
  Call FSTA("STA") From GLOCK
  [M:STW]ERRCOD=70 : Gosub TRT_ERR : Return
Endif
If [M:STW]TRAFLG>2
  [L]WFIC="STOALL"
  [L]WCLE=[F:STA]STOFCY-[F:STA]ITMREF-num$([F:STA]STOCOU)-num$([F:STA]SEQ)
  [L]WMESSAGE=mess(232,197,1) : Gosub TRACE_DETAILLEE From STKMAJSUP
Endif
Return

#------------------------------#
# Initialisation [L]WMAJCODSTO #
#------------------------------#
$INI_WMAJCODSTO
If [L]WMAJCOD="M"
  If [M:STW]MAJCOD(I)="A"
    If I<>dim([M:STW]ITMREFLIG)-1 & [M:STW]MAJCOD(I+1)="C"
      If [M:STW]LOT(I)      = [M:STW]LOT(I+1)
&      & [M:STW]SLO(I)      = [M:STW]SLO(I+1)
&      & [M:STW]BPSLOT(I)   = [M:STW]BPSLOT(I+1)
&      & [M:STW]PALNUM(I)   = [M:STW]PALNUM(I+1)
&      & [M:STW]CTRNUM(I)   = [M:STW]CTRNUM(I+1)
&      & [M:STW]STA(I)      = [M:STW]STA(I+1)
&      & [M:STW]LOC(I)      = [M:STW]LOC(I+1)
&      & [M:STW]PCU(I)      = [M:STW]PCU(I+1)
&      & [M:STW]PCUSTUCOE(I)= [M:STW]PCUSTUCOE(I+1)
&      & [M:STW]SERNUM(I)   = [M:STW]SERNUM(I+1)
&      & [M:STW]QLYCTLDEM(I)= [M:STW]QLYCTLDEM(I+1)
&      & [M:STW]OWNER(I)    = [M:STW]OWNER(I+1)
        [L]WMAJCODSTO="M"
      Else
        [L]WMAJCODSTO="A"
      Endif
    Else
      [L]WMAJCODSTO="A"
    Endif
  Elsif [M:STW]MAJCOD(I)="C"
    If I=0 | [M:STW]MAJCOD(I-1)<>"A" | [L]WMAJCODSTO<>"M"
      [L]WMAJCODSTO="C"
    Endif
  Else
    [L]WMAJCODSTO=[L]WMAJCOD
  Endif
Else
  [L]WMAJCODSTO=[L]WMAJCOD
Endif

Raz [L]WSPLITQTY

Return

