#<AdxTL>@(#)7.0.0.0 $Revision$
########################################################################
# SUBPTHC             Traitement des réceptions                        #
# -------------------------------------------------------------------- #
# Traitement des actions "GOSUB" de l'objet "PTH"                      #
# Les traitements sur champ "Call" se trouvent dans le SUBPTH          #
# et/ou dans les traitements TRTPSAISTT et TRTPSAISCM                  #
########################################################################
#                Traitements liés à la sous-traitance                  #
########################################################################
########################################################################
# $CHARG_WMOTEUR                (appel par CHARG_LIG_PTH(SUBPTHB))     #
# - $CHARG_WMOTEUR_OF                                                  #
# - $CHARG_WMOTEUR_EO                                                  #
# Charge la zone wmoteur pour savoir si déclaratio ou pas              #
# Charge la zone nbrwrk  pour savoir combien article a entrer          #
#----------------------------------------------------------------------#
# Subprog CHARG_STT(NOL)        (appel par CHARG_LIG_PTH(SUBPTHB))     #
# - Subprog CHARG_STT_OF(NOL)   (appel par $DEB_SAISTT(TRTPSAISTT))    #
# - Subprog CHARG_STT_EO(NOL)   (appel par $DEB_SAIPSC(TRTPSAISCM))    #
# Chargement du masque sous-traitance en apres-picking et tentative    #
# d'entrée rapide                                                      #
#----------------------------------------------------------------------#
# $CHARG_ECRSTTH (appel par CHARG_STT_OF)                              #
# $CHARG_ECRSCMH (appel par CHARG_STT_EO/CHARG_SCM_EOH)                #
# Chargement entête du masque fenêtre IPSAISTT/IPSAISCM                #
#----------------------------------------------------------------------#
# $CHARG_ECRSTTD (appel par CHARG_STT_OF)                              #
# $CHARG_ECRSCMD (appel par CHARG_STT_EO/CHARG_SCM_EOD)                #
# Chargement détails du masque fenêtre IPSAISTT/IPSAISCM               #
#----------------------------------------------------------------------#
# $CHARG_PARAM_STOENT                                                  #
# Chargt ligne de sous-traitance OF par le moteur d'entrée TRTSTOENTA  #
#----------------------------------------------------------------------#
# $CTL_STT_QTY                                                         #
# Contrôle ligne Article de sous-traitance selon CTLSTOENT(STKECR)     #
#----------------------------------------------------------------------#
# $CTL_LIG_STT                                                         #
# Contrôle ligne de sous-traitance OF par le moteur d'entrée TRTSTOENTB#
#----------------------------------------------------------------------#
# $MAJ_LIGD_STT                                                        #
# Mise à jour ligne de sous-traitance OF par moteur d'entrée TRTSTOENTA#
#----------------------------------------------------------------------#
# $ENR_PWS_STT   (MFGITM pour déclaration de production OF)            #
# $ENR_PWS_SCMH  (SCOITM pour entrée en stock EO)                      #
# $ENR_PWS_SCMD  (SCOMAT pour sortie de stock EO)                      #
# Supression puis                                                      #
# Enregistrement du fichier de travail [F:PWS] une ligne de XXX        #
#----------------------------------------------------------------------#
# $MAJ_SOUS_TRAIT  appelé en création/modif/suppression ligne [F:PTD]  #
# - $MAJ_SOUS_TRAIT_OF                                                 #
# - $MAJ_SOUS_TRAIT_EO                                                 #
# Maj du stock concernant les articles de sous-traitance               #
#----------------------------------------------------------------------#
# $MAJ_OPESTT Appel de MAJ_SBC en créa, modi, supp de la ligne [F:PTD] #
# Maj de la commande de sous-traitance (si solde de [F:POQ])           #
########################################################################

$CHARG_WMOTEUR
#-------------------------------------------------------------------------------#
# Pour la sous-traitance on vérifie que l'on doit faire une déclaration de prod #
#-------------------------------------------------------------------------------#
# Issue 89758 GA 12/2013 immediately lock WO or EO
  If [F:POQ]VCRNUMORI<>""
    If [F:POQ]VCRTYPORI=10 & !func GLOCK.LOKBYI("MFG"+[F:POQ]VCRNUMORI)
      Lock="MFG"+[F:POQ]VCRNUMORI
      If fstat
        GMESSAGE="$MFGHEAD"-[F:POQ]VCRNUMORI-mess(10,100,1)
      Endif
      #Unlock="MFG"+[F:POQ]VCRNUMORI
    Elsif [F:POQ]VCRTYPORI=36 & !func GLOCK.LOKBYI("SCO"+[F:POQ]VCRNUMORI)
      Lock="SCO"+[F:POQ]VCRNUMORI
      If fstat
        GMESSAGE="$SCOHEAD"-[F:POQ]VCRNUMORI-mess(10,100,1)
      Endif
      #Unlock="SCO"+[F:POQ]VCRNUMORI
    Endif
  Endif

If [F:POQ]VCRTYPORI = 36
# Ordre de sous-traitance
# -----------------------
  Gosub CHARG_WMOTEUR_EO
Elsif GMODU(8) = 2  : # ssi GP présente
# Ordre de fabrication
# -----------------------
  Gosub CHARG_WMOTEUR_OF
Endif
Return

$CHARG_WMOTEUR_OF
#---------------------------------------#
# Si article de sous_traitance          #
# faut-il faire une déclaration de prod #
# WRKMOTEUR=9 : opération inexistante   #
# WRKMOTEUR=1 : pas de déclaration      #
# WRKMOTEUR=2 : déclaration de prod OF  #
#---------------------------------------#
#----- Si article sous-traitance on doit ou non faire l'entrée en stock de l'article lancé
Gosub OPEN_FILES_MFG From MFGLIB
If dim([L]WPOHNUM)<=0 : Local Char     WPOHNUM(GLONREF) : Endif
If dim([L]WPOPLIN)<=0 : Local Integer  WPOPLIN          : Endif
If dim([L]WMFGNUM)<=0 : Local Char     WMFGNUM(GLONREF) : Endif
If dim([L]WMFGLIN)<=0 : Local Integer  WMFGLIN          : Endif
If dim([L]WOPENUM)<0    Local Integer  WOPENUM          : Endif   # FQ 70035 avant Shortint
If dim([L]WOPESPLNUM)<0 Local Shortint WOPESPLNUM       : Endif
Raz [F:MTS], [F:OPS], [F:SCH], [F:MFI]
#------ Alimentation du numéro inutile écrasée par le transclasse -----#
WMFGNUM   =[F:POQ]VCRNUMORI
WOPENUM   =[F:POQ]VCRLINORI : # GA v150 avant [F:OPS]OPENUM
WOPESPLNUM=[F:POQ]VCRSEQORI # Issue 84830 GA 10/2012 avant 0
WRKMOTEUR =1

# Issue 77589 - 2011-11-17 by CCC
If [F:MFG]MFGNUM<>WMFGNUM
    Read [MFG]MFG0=WMFGNUM
Endif
If  [F:MFG]MFGTRKFLG < 3 & GDOSFAB = 2
    GMESSAGE = mess(20,190,1)-"("+WMFGNUM+")"
    WRKMOTEUR=9
    Return
Endif

If [F:ITM]SCSFLG=2 | [F:POQ]LINTYP=1
# Réception sur le Service=Opération sous-traitance
#--------------------------------------------------
  WPOHNUM=[F:POQ]POHNUM
  WPOPLIN=[F:POQ]POPLIN
Elsif [F:POQ]LINTYP=2    : # Commande du Composé
# Ajout V150 - GA Mai 2006
# Réception sur un article intermédiaire
# Recherche du no opération sur ligne suivante de [F:POQ]
#--------------------------------------------------------
  WPOHNUM=[F:POQ]POHNUM
  WPOPLIN=[F:POQ]POPLIN+1000
Endif
#------ Lecture de l'opération selon réf commande -----#
Read [OPS] OPS2=WPOHNUM;WPOPLIN;1
If fstat
   Raz [F:OPS]
   # FQ 68123 & 68299 GA 10/2010 pb si on ne retrouve pas la ligne [F:OPS]
   Read [F:MFO]MFO1=WPOHNUM;WPOPLIN;1
   If !fstat
     [F:OPS] = [F:MFO]
   Endif
Endif
#------ Lecture de l'opération selon réf opération OF -----#
If [F:OPS]MFGNUM<>WMFGNUM   # Issue 97320 GA 07/2014
  If [F:OPS]OPESPLNUM=0
     Read [OPS] OPS1=WMFGNUM;WOPENUM
     If fstat  Raz [F:OPS]  : [L]WRKMOTEUR=9 : Return : Endif
  Elsif WOPESPLNUM<>0
     Read [OPS] OPS1=WMFGNUM;WOPENUM;WOPESPLNUM   # Issue 84830 GA 10/2012
     If fstat  Raz [F:OPS]  : [L]WRKMOTEUR=9 : Return : Endif
  Endif
Endif
If WOPESPLNUM=0  # Issue 84830 GA 10/2012
   WOPESPLNUM=[F:OPS]OPESPLNUM
Endif

# Issue 81433 GA 06/2012 il faut OPENUM et OPESPLNUM dans [F:PWS]
#If dim([L]WOPENUMCLE)<0 Local Integer  WOPENUMCLE       : Endif
#WOPENUMCLE = 100*WOPENUM+WOPESPLNUM

#----- Faut-il faire une déclaration de production ?
Read [MTS] MTS0=2;GMTKMTSNUM
If fstat  Raz [F:MTS] : Return : Endif
If [F:MTS]ITMTRKFLG<>2  Return : Endif
Read [SCH]SCH0=WMFGNUM;WOPENUM;WOPESPLNUM
If fstat  Raz [F:SCH] : Return : Endif
If [F:SCH]MFGMST<>2     Return : Endif

#----- Si la ligne article est soldée, on ne fait pas de déclaration de prod.
# FQ 69508 GA 03/2011 tenir compte des sous-produits pour l'entrée en stock
#For [MFI] MFI0 Where MFGNUM=[F:SCH]MFGNUM & ITMTYP<>2 & MFITRKFLG<>5
For [MFI] MFI0 Where MFGNUM=[F:SCH]MFGNUM & MFITRKFLG<>5
  [M:PTH1]NBWRK(NOL)+=1
Next
If [M:PTH1]NBWRK(NOL)>0
  [L]WRKMOTEUR=2 : # Il faudra faire la déclaration de production
Endif
Return

$CHARG_WMOTEUR_EO
#----------------------------------------#
# Si article de sous_traitance           #
# faut-il faire une déclaration de prod ?#
# WRKMOTEUR=9 : ordre ss-traitance absent#
# WRKMOTEUR=0 : entrée en stock standard #
# WRKMOTEUR=1 : pas d'entrée en stock    #
# WRKMOTEUR=3 : déclaration de prod EO   #
#----------------------------------------#
Local Char WSCONUM(GLONREF)
#----- Si article sous-traitance on doit ou non faire l'entrée en stock de l'article lancé
Gosub OPEN_FILES_SCO From SCOLIB
Raz [F:SCI], [F:SCS], [F:SCO], [F:SCM]
[L]WRKMOTEUR=9
If [F:ITM]SCPFLG=2   : # Article sous-traité
   #------ Lecture de l'article lancé -----#
   Read [SCI] SCI2=[F:POQ]POHNUM;[F:POQ]POPLIN;1
   If fstat
      Read [SCI] SCI0=[F:POQ]VCRNUMORI;[F:POQ]VCRLINORI
      If fstat  Raz [F:SCI]  : Return : Endif
   Endif
Elsif [F:ITM]SCSFLG=2 : # Article sous-traitance
   #------ Lecture du service -----#
   Read [SCS] SCS1=[F:POQ]POHNUM;[F:POQ]POPLIN;1
   If fstat
      Read [SCS] SCS0=[F:POQ]VCRNUMORI;[F:POQ]VCRLINORI;[F:POQ]VCRSEQORI
      If fstat  Raz [F:SCS]  : Return : Endif
   Endif
Endif
[L]WRKMOTEUR=1
#----- Si l'ordre de sous-traitance est absent ou clos, on ne fait pas de déclaration de prod.
Read [SCO] SCO0=[F:POQ]VCRNUMORI
If fstat : Raz [F:SCO] : Return : Endif
If [F:SCO]SCOSTA<>4
   [M:PTH1]NBWRK(NOL)+=1
Else
   If [M:PTH1]STOMGTCOD(NOL)=2  : # si article géré en stock, entrée en stock standard
      [L]WRKMOTEUR=0
   Endif
   GMESSAGE=mess(359,194,1) : # Ordre de sous-traitance clos: Mise à jour impossible !
Endif
If [M:PTH1]NBWRK(NOL)>0
   [L]WRKMOTEUR=3 : # Entrée en stock article sous-traité + backflush des matières consommées
Endif
Return


#########################################################################
# CHARG_STT : S/P de chargement du détail stock des articles lancés     #
#             issus de l'article de sous-traitance.                     #
#             Appelé depuis le chargement ligne réception               #
#                 - CHARG_LIG_PTH(dans SUBPTHB)                         #
#                 - AAPRES_NBLIG (dans SUBPTH)                          #
# --------------------------------------------------------------------- #
# Subprog CHARG_STT (NOL)                                               #
#    NOL  : Indice de la ligne de réception en cours de traitement      #
# [F:POQ] doit être chargé                                              #
#########################################################################
Subprog CHARG_STT(NOL)
Value   Integer  NOL
Local   Integer  WOK

If dim(SVGNOL)<0 :  Local Integer  SVGNOL  : Endif
SVGNOL=NOL

Raz mkstat
If [M:PTH1]VCRTYPORI(NOL) = 36 & [M:PTH1]LINTYP(NOL) = 2 # Article sous-traité
# Ordre de sous-traitance
# -----------------------
  Local Mask="PTHPSCM"  [PSCM]
  Call CHARG_STT_EO(SVGNOL)
  Raz  [M:PSCM]
  Close Local Mask [M:PSCM]
  Raz mkstat
  NOL=SVGNOL : nolign=NOL+1

# FQ 67334 GA 09/2010 suite FQ
#Elsif [M:PTH1]VCRTYPORI(NOL) = 10 & [M:PTH1]LINTYP(NOL)=3  # Service
Elsif [M:PTH1]VCRTYPORI(NOL) = 10 & find([M:PTH1]LINTYP(NOL),1,3)  # Sous-traitance OF: sans article lancé

# Ordre de fabrication
# -----------------------
  #----- Pour ouvrir le mask généré -----#
  If GVERSION>"1.6.4" # X3V6p18 Differed validations may cause some trouble here
     Call CTRL_MASK(nomap,"WE6"+GPTRNUM+"3","[PSTT]") From TRTX3   # FQ 77679 GA 11/2011
  Endif
  #Local Mask="PTHPSTT" [PSTT]
  Local Mask="WE6"+GPTRNUM+"3" [PSTT]
  Call CHARG_STT_OF(SVGNOL)
  # Issue 95496 - 2014-03-17 by CCC : WOF : WSTOSEQ initialized in CHARG_STT
  #[M:PTH1]WSTOSEQ(SVGNOL)=[M:PSTT]WSTOSEQ(0)

  # Issue 101375 - 2014-07-10 by CCC : Quantity modification
  If status<>6
&  & dim(GOLDQTY)>0 & GOLDQTY>0
&  & func QTYMOD([M:PTH1]QTYSTU(SVGNOL))<>0
    [M:PTH1]WSTOFLG(SVGNOL) = 0
  Endif
  If dim(GOLDQTY)>0
    GOLDQTY=0
  Endif

  Raz [M:PSTT]
  Close Local Mask [M:PSTT]
  Raz mkstat
  NOL=SVGNOL : nolign=NOL+1

  Raz GOUVENT  # Issue 94547 - 2014-03-06 by CCC

Endif
End

###################################################################
Funprog QTYMOD(PNEWQTY)
Value Decimal PNEWQTY

Local Shortint SRET
Local Integer LRET, NOL, WOK
Local Decimal COEFF_MFI

Raz LRET
# Ouverture des tables si nécessaire
Gosub OPEN_FILES_MFG From MFGLIB

# Check if it's possible to calculate new quantity receipted automatically
If [M:PSTT]NBLIG>1
    # It's not possible to dispatch quantity modification on each line => qty have to be entered
    LRET = 1
Else
    For NOL=0 To [M:PSTT]NBLIG-1
        If sigma(0,[M:ENTW]NBLIG-1,[M:ENTW]WSTOSEQ(indcum)=[M:PSTT]WSTOSEQ(NOL))>1
            LRET = 1
            Break
        Endif
    Next
Endif

If LRET
    If !GIMPORT # Issue 96008 GA 10/2014
        Call MESSAGE(mess(473,194,1)) From GESECRAN
    Else
        Call ECR_TRACE(mess(473,194,1),1) From GESECRAN
    Endif
    End LRET
Endif

NOL=0
Filter [PWS] Where WSTOSEQ = [M:PSTT]WSTOSEQ(NOL)
Read [F:PWS]PWS0=adxuid(1);"PTH";10;[M:PSTT]MFGNUM;[M:PSTT]MFGLIN(0);[M:PTH1]WSTOSEQ([M:PSTT]ORINOL)
Filter [PWS]
If !fstat
    If [F:MFI]MFGNUM<>[F:PWS]VCRNUM | [F:MFI]MFGLIN<>[F:PWS]VCRLIN
        Raz [F:MFI]
        Read [MFI]MFI0=[F:PWS]VCRNUM;[F:PWS]VCRLIN
    Endif

    If [F:MFO]MFGNUM<>[M:PTH1]VCRNUMORI(NOL) | [F:MFO]OPENUM<>[M:PTH1]VCRLINORI(NOL) | [F:MFO]OPESPLNUM<>[M:PTH1]VCRSEQORI(NOL)
        Raz [F:MFO]
        Read [MFO]MFO0=[M:PTH1]VCRNUMORI(NOL);[M:PTH1]VCRLINORI(NOL);[M:PTH1]VCRSEQORI
    Endif
    If [F:MFG]EXTQTY = [F:MFI]EXTQTY | [F:MFG]EXTQTY = 0
    # OF mono-article la qté totale = qté article lancé
        COEFF_MFI = 1
    Else
        COEFF_MFI = [F:MFI]EXTQTY / [F:MFG]EXTQTY
    Endif
    If [F:MFO]OPESTUCOE>0
        [M:PSTT]QTYSTU(NOL)=PNEWQTY/[F:MFO]OPESTUCOE * COEFF_MFI
        Call QTEARR([M:PSTT]QTYSTU(NOL),[F:MFI]STU) From TRTDIV
    Else
        [M:PSTT]QTYSTU(NOL)=PNEWQTY * COEFF_MFI
        Call QTEARR([M:PSTT]QTYSTU(NOL),[F:MFI]STU) From TRTDIV
    Endif
    If [F:PWS]UOM=[F:PWS]STU | [F:PWS]UOMSTUCOE=0
        [M:PSTT]QTYUOM(NOL)=[M:PSTT]QTYSTU(NOL)
    Else
        [M:PSTT]QTYUOM(NOL) = [M:PSTT]QTYSTU(NOL) / [F:PWS]UOMSTUCOE # Issue 92821 GA 10/2013 avant * [F:PWS]UOMSTUCOE
        Call QTEARR([M:PSTT]QTYUOM(NOL),[F:MFI]UOM) From TRTDIV
    Endif
    If [F:PWS]QTYSTU<>[M:PSTT]QTYSTU(NOL)
        [F:PWS]QTYSTU=[M:PSTT]QTYSTU(NOL)
        [F:PWS]QTYUOM=[M:PSTT]QTYUOM(NOL)
        Rewrite [F:PWS]
      # Issue 102243 GA 10/2014 WRET not useable (renammed SRET), it's a Shortint instead of Integer
      # Issue 101541 GA 08/2014 [F:SRU] must be read before OUVENT
        If [F:ITM]ITMREF<>[F:MFI]ITMREF
           Read [ITM]ITM0=[F:MFI]ITMREF : If fstat  Raz [F:ITM] : Endif
        Endif
        Call LECSRU([M:PTH0]PRHFCY,[F:ITM]TCLCOD, 3, "", "",WOK) From STKLIB
        Call OUVENT([M:PSTT]STOFCY,"PSTT",5,[M:PSTT]TRSCOD,[M:PSTT]BPRNUM,15,
&                   [M:PSTT]IPTDAT,NOL,[M:PSTT]NBLIG,"PTR","",SRET) From STKENT
        If SRET>1
            LRET=1
        Endif
    Endif
Endif

End LRET


#########################################################################
# CHARG_STT_OF : S/P de chargement du détail stock des articles lancés  #
#             issus de l'article de sous-traitance d'un OF              #
# --------------------------------------------------------------------- #
# Subprog CHARG_STT (NOL)                                               #
#    NOL  : Indice de la ligne de réception en cours de traitement      #
#########################################################################
Subprog CHARG_STT_OF(NOL)
Value   Integer  NOL
#----- Variables locales -----#
Local   Integer  J, WRETOUR
Local   Char     WMFGNUM(GLONREF),WMFGITM(GLONITM),WPOHNUM(GLONREF)
Local   Integer  WMFGLIN, WOPENUM, WPOPLIN
Local   Shortint WOPESPLNUM, SRET
# 04.06 demande 35403
Local   Integer  WOK
If dim(SVGNOL)<0 :  Local Integer  SVGNOL  : Endif
SVGNOL=NOL
Raz   [M:PSTT]
Actzo [M:PSTT]1-99
# Ouverture des tables si nécessaire
Gosub OPEN_FILES_MFG From MFGLIB
WMFGITM    = [M:PTH1]ITMREFORI(NOL)  # GA 03/03/2009 pour recherche de WMFGLIN
WMFGLIN    = 0
WMFGNUM    = [M:PTH1]VCRNUMORI(NOL)
WOPENUM    = [M:PTH1]VCRLINORI(NOL)
WOPESPLNUM = 0                       # OPESPLNUM n'est pas stocké sur [F:POQ]VCRSEQORI

# Issue 94547 - 2014-03-06 by CCC : WOF
Local Integer LSTOSEQ
LSTOSEQ=[M:PTH1]WSTOSEQ(NOL)
If [M:PTH1]WSTOSEQ(NOL)=0
    Local Integer LSEQ
    Call STKWSTOSEQ("PTH1",NOL, [M:PTH1]NBLIG, 0,LSEQ,WOK) From STKECR
    [M:PTH1]WSTOSEQ(NOL)=LSEQ
Endif

If [M:PTH1]LINTYP(NOL)=2    : # Commande du Composé
# FQ 55135 GA 05/2009 cde opération sur ligne suivante de [F:POQ]
  WPOHNUM=[M:PTH1]POHNUM(NOL)
  WPOPLIN=[M:PTH1]POPLIN(NOL)+1000
Else
  WPOHNUM = [M:PTH1]POHNUM(NOL)
  WPOPLIN = [M:PTH1]POPLIN(NOL)
Endif
#----- Lecture de l'opération selon réf commande -----#
Read [OPS] OPS2=WPOHNUM;WPOPLIN;1
If fstat
  # FQ 68123 & 68299 GA 10/2010 pb si on ne retrouve pas la ligne [F:OPS]
  #------ Lecture de l'opération selon réf opération OF -----#
  # Read [OPS] OPS1=WMFGNUM;WOPENUM
  # If fstat  Raz [F:OPS] : Return : Endif
   Raz [F:OPS]
   Read [F:MFO]MFO1=WPOHNUM;WPOPLIN;1
   If !fstat
     #WMFGLIN = [F:MFO]MFGLIN  # FQ 68578 GA 10/2010
     [F:OPS] = [F:MFO]
   Endif
Endif
WOPESPLNUM=[F:OPS]OPESPLNUM

# Issue 95496 - 2014-03-17 by CCC : WOF : [F:PWS]VCRSEQ = [M:PTH1]WSTOSEQ
## Issue 81433 GA 06/2012 il faut OPENUM et OPESPLNUM dans [F:PWS]
#If dim([L]WOPENUMCLE)<0 Local Integer  WOPENUMCLE       : Endif
## Issue 93977 GA 11/2013 déplacé dans CAL_WOPENUMCLE
#Local Integer WVCRSEQ : WVCRSEQ=0
#Gosub CAL_WOPENUMCLE # Issue 93977 GA 11/2013

# FQ 74274 GA 10/2011
If [F:MFO]MFGNUM<>WMFGNUM
   Read [F:MFO]MFO1=WPOHNUM;WPOPLIN;1
   If fstat Raz [F:MFO] Endif
Endif

Read [MFG] MFG0=WMFGNUM
If fstat  Raz [F:MFG] : Endif
# GA 03/03/2009 recherche de WMFGLIN
For [MFI] Where MFGNUM=WMFGNUM & ITMREF=WMFGITM & WMFGLIN=0
    WMFGLIN=[F:MFI]MFGLIN
Next
Read [SCH] SCH0=WMFGNUM;WMFGLIN;WOPENUM
If fstat  Raz [F:SCH] : Endif
#-----
Gosub CHARG_ECRSTTH : # From SUBPTHC
#If [F:POQ]LINTYP<2   # Issue 89134 GA 08/2013
If [M:PTH1]LINTYP([M:PSTT]ORINOL)<2
# 1er cas: la commande porte uniquement sur l'article sous-traitance
# ------------------------------------------------------------------

# Issue 95496 - 2014-03-17 by CCC : WOF : [F:PWS]VCRSEQ = [M:PTH1]WSTOSEQ
## FQ 68123 GA 10/2010 identifier + précisément la cde courante (remplacement VCRLIN=WMFGLIN Ko, ajout VCRSEQ)
## FQ 75839 GA 08/2011 [F:PWS] clé re-modifiée VCRLIN=WMFGLIN & VCRSEQ=WOPENUM
##&                  &  VCRNUM=WMFGNUM & VCRLIN=WOPENUM & VCRSEQ=WOPESPLNUM
## Issue 81433 GA 06/2012 il faut OPENUM et OPESPLNUM dans [F:PWS]
## Issue 89134 GA 08/2013 Filter au lieu de For avec conditions
#  Filter [F:PWS] Where PRONUM=adxuid(1) & CODFNC="PTH" & VCRTYP=10
#&                 &  VCRNUM=WMFGNUM  & VCRSEQ=WOPENUMCLE
  Filter [F:PWS] Where PRONUM=adxuid(1) & CODFNC="PTH" & VCRTYP=10
&                    &  VCRNUM=WMFGNUM  & VCRSEQ=[M:PTH1]WSTOSEQ(NOL)
  For [F:PWS]
    Read [MFI] MFI0=[F:PWS]VCRNUM;[F:PWS]VCRLIN
    If !fstat Gosub CHARG_ECRSTTD   Endif
  Next
  Filter [PWS]

  #----- Si pas trouvé on charge tout -----#
  If [M:PSTT]NBLIG=0
    # GA 04/2006 V150 réception sur article sous-traitance => tous les articles lancés de l'OF
    #----- Si la ligne article est soldée, on ne fait pas de déclaration de prod.
    # FQ 69508 GA 03/2011 tenir compte des sous-produits pour l'entrée en stock
    #For [MFI] MFI0 Where MFGNUM=WMFGNUM & ITMTYP=1 & ITMSTA<5 & MFITRKFLG<>5
    For [MFI] MFI0 Where MFGNUM=WMFGNUM & ITMSTA<5 & MFITRKFLG<>5
      Raz [F:PWS] : Gosub CHARG_ECRSTTD
    Next
  Endif
Else
# 2eme cas: la commande porte sur les articles lancés de l'OF
# ------------------------------------------------------------------
# GA 04/2006 on relit le(s) composé(s) déjà enregistré dans [F:PWS] (VCRSEQ=0)
#----- Réaffichage des articles  enregistrés dans [F:PWS] et dans STOENT
# FQ 68123 GA 10/2010 identifier + précisément la cde courante (remplacement VCRLIN=WMFGLIN Ko, ajout VCRSEQ)
# FQ 75839 GA 08/2011 [F:PWS] clé re-modifiée VCRLIN=WMFGLIN & VCRSEQ=WOPENUM
#&                  &  VCRNUM=WMFGNUM & VCRLIN=WOPENUM & VCRSEQ=WOPESPLNUM
# Issue 81433 GA 06/2012 il faut OPENUM et OPESPLNUM dans [F:PWS]
  For [PWS]PWS0 Where PRONUM=adxuid(1) & CODFNC="PTH" & VCRTYP=10
&                  &  VCRNUM=WMFGNUM & VCRLIN=WMFGLIN & VCRSEQ=WOPENUMCLE
    Read [MFI] MFI0=[F:PWS]VCRNUM;WMFGLIN    # avant [F:PWS]VCRLIN
    If !fstat  Gosub CHARG_ECRSTTD : Endif
  Next
  #----- Si pas trouvé on charge tout -----#
  If [M:PSTT]NBLIG=0
    # GA 04/2006 V150 réception sur article lancé, on ne charge que l'article courant
    #----- Si la ligne article est soldée, on ne fait pas de déclaration de prod.
    # FQ 69508 GA 03/2011 tenir compte des sous-produits pour l'entrée en stock
    #For [MFI] MFI0 Where MFGNUM=WMFGNUM & MFGLIN=WMFGLIN & ITMTYP=1 & ITMSTA<5 & MFITRKFLG<>5
    For [MFI] MFI0 Where MFGNUM=WMFGNUM & MFGLIN=WMFGLIN & ITMSTA<5 & MFITRKFLG<>5
      Raz [F:PWS] : Gosub CHARG_ECRSTTD
    Next
  Endif
Endif
#-----
# Issue 95496 - 2014-03-17 by CCC : WOF : don't call STJSTOENTW if ENTW already loaded (WSTOSEQ<>0)
If [M:PSTT]NBLIG>0 & LSTOSEQ=0
  # 04.06 demande 35403
  Raz WOK, WRETOUR
  For J=0 To [M:PSTT]NBLIG-1
    # 04.06 demande 35403
    If [M:PSTT]CALQTYSTU(J) <> [M:PSTT]QTYSTU(J)
       WOK +=1
    Endif
    If [F:ITM]ITMREF<>[M:PSTT]ITMREF(J)
      Read [ITM] ITM0=[M:PSTT]ITMREF(J) : If fstat  Raz [F:ITM] : Endif
    Endif
    # Issue 95885 GA 01/2014 charger ITF,ITG,SRU (TRSTYP=5) avant STJSTOENTW
    If [F:ITF]ITMREF<>[F:MFI]ITMREF | [F:ITF]STOFCY<>[M:PTH0]PRHFCY
      Read [ITF] ITF0=[F:MFI]ITMREF;[M:PTH0]PRHFCY : If fstat  Raz [F:ITF] : Endif
    Endif
    If [F:ITG]STOFCY<>[M:PTH0]PRHFCY | [F:ITG]TCLCOD<>[F:ITM]TCLCOD
      Read [ITG] ITG0=[M:PTH0]PRHFCY;[F:ITM]TCLCOD
      If fstat
        Read [ITG] ITG1=[F:ITM]TCLCOD;"" : If fstat  Raz [F:ITG] : Endif
      Endif
    Endif
    Call LECSRU([M:PTH0]PRHFCY,[F:ITM]TCLCOD, 5, "", "",WRETOUR) From STKLIB
    Call STJSTOENTW("PSTT",5,15,[M:PTH0]RCPDAT,J,[M:PSTT]NBLIG,"PTR",0,WRETOUR) From STKENT
    WOK = max(WOK, WRETOUR)
    If WRETOUR
      Raz [M:PTH1]WSTOFLG(SVGNOL)
    Else
      [M:PSTT]RRRQTYSTU(J)=GRRRQTY
      [M:PSTT]QQQQTYSTU(J)=GQQQQTY
    Endif
    nolign=J+1
    Gosub ENR_PWS_STT  : # From SUBPTHC : # Attention le NOL d'origine est écrasé !!
  Next
  If !find(0,[M:PSTT]WSTOFLG(0..[M:PSTT]NBLIG-1))
    [M:PTH1]WSTOFLG(SVGNOL)=2
  Else
    [M:PTH1]WSTOFLG(SVGNOL)=0
  Endif
Else
  # Issue 101375 - 2014-07-10 by CCC : WSTOFLG is managed after
  #[M:PTH1]WSTOFLG(SVGNOL)=0
Endif
# 04.06 demande 35403
If WOK : [M:PTH1]WSTOFLG(SVGNOL) = 0 : Endif
#-----
NOL=SVGNOL : nolign=NOL+1
End


#########################################################################
# CHARG_STT_EO : S/P de chargement du détail stock de l'article lancé  #
#                 issus d'un ordre de sous-traitance.                   #
# --------------------------------------------------------------------- #
# Subprog CHARG_STT_EO (NOL)                                           #
#    NOL  : Indice de la ligne de réception en cours de traitement      #
#########################################################################
Subprog CHARG_STT_EO(NOL)
Value   Integer  NOL

Local   Integer  WOK   # FQ 72505 GA 03/2011
Local   Integer  LSTOFLG   # Issue 87188 - 2013-01-16 by CCC
#If dim(SVGNOL)<0 :  Local Integer  SVGNOL  : Endif
#Local Char W_MSG(250) : Raz W_MSG # Issue 94538 GA 11/2013

# Issue 94547 - 2014-03-06 by CCC : If WSTOSEQ<>0, ENTW has been already loaded
Local Integer LSTOSEQ
LSTOSEQ=[M:PTH1]WSTOSEQ(NOL)
Local Shortint SRET

  # Ouverture des tables si nécessaire
  Gosub OPEN_FILES_SCO From SCOLIB

#  SVGNOL=NOL
#
  # Issue 95496 & 97173 - 2014-02-26 by CCC : use of WSTOSEQ to link [M:PTH1] & [F:PWS] instead of line number in [M:PTH1]
  If [M:PTH1]WSTOSEQ(NOL)=0
    Local Integer LSEQ
    Call STKWSTOSEQ("PTH1",NOL, [M:PTH1]NBLIG, 0,LSEQ,WOK) From STKECR
    [M:PTH1]WSTOSEQ(NOL)=LSEQ
  Endif

  # Issue 94547 - 2014-03-14 by CCC : load materials
  Call CHARG_SCM(NOL, LSTOFLG)
  If LSTOFLG=0
    If LSTOSEQ=0
     # FQ 72505 GA 03/2011
     # déplacé ici sinon STJSTOENT raz l'erreur dans [M:PTH1]WSTOFLG(SVGNOL)
    #  NOL=SVGNOL
      nolign=NOL+1
     # FQ 73860 GA 05/2011
      If [F:ITM]ITMREF<>[M:PTH1]ITMREF(NOL)
         Read [ITM]ITM0=[M:PTH1]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
      Endif
     # Issue 91992 GA 08/2013 ssi article géré en stock
      If [F:ITF]ITMREF<>[M:PTH1]ITMREF(NOL) | [F:ITF]STOFCY<>[M:PTH0]PRHFCY
        Read [ITF] ITF0=[M:PTH1]ITMREF(NOL);[M:PTH0]PRHFCY : If fstat  Raz [F:ITF] : Endif
      Endif
      If [F:ITF]STOMGTCOD>1                       # Issue 91992 GA 08/2013
        If [M:PTH1]CREFLG(NOL)=0                  # Issue 91110 GA 08/2013
          Call DELSTOENTW(NOL,NOL,"PTH1",1,1,[PTH0]PRHFCY,1,"") From STKENT
        Endif
        # Issue 95885 GA 01/2014 charger ITF,ITG,SRU (TRSTYP=3) avant STJSTOENTW
        If [F:ITG]STOFCY<>[M:PTH0]PRHFCY | [F:ITG]TCLCOD<>[F:ITM]TCLCOD
          Read [ITG] ITG0=[M:PTH0]PRHFCY;[F:ITM]TCLCOD
          If fstat
            Read [ITG] ITG1=[F:ITM]TCLCOD;"" : If fstat  Raz [F:ITG] : Endif
          Endif
        Endif
        Call LECSRU([M:PTH0]PRHFCY,[F:ITM]TCLCOD, 3, "", "",WOK) From STKLIB
        Call STJSTOENTW("PTH1",3,6,[M:PTH0]RCPDAT,NOL,[M:PTH1]NBLIG+1,"PTR",0,WOK) From STKENT
        LSTOFLG=max(LSTOFLG,WOK)

      # l'article lancé est inséré dans [F:PWS]
      # pour que MAJ_STK puisse prendre en charge l'entrée en stock
        Gosub ENR_PWS_SCMH
      Endif
    Else
      # Issue 102243 GA 10/2014 WRET not useable (renammed SRET), it's a Shortint instead of Integer
      # Issue 101541 GA 08/2014 [F:SRU] must be read before OUVENT
      If [F:ITM]ITMREF<>[M:PTH1]ITMREF(NOL)
         Read [ITM]ITM0=[M:PTH1]ITMREF(NOL) : If fstat  Raz [F:ITM] : Endif
      Endif
      Call LECSRU([M:PTH0]PRHFCY,[F:ITM]TCLCOD, 3, "", "",WOK) From STKLIB
      Call OUVENT([M:PTH0]PRHFCY,"PTH1",3,[M:PTH0]TRSCOD,[M:PTH0]BPSNUM,6,
&                 [M:PTH0]RCPDAT,NOL,[M:PTH1]NBLIG,"PTR","",SRET) From STKENT
    Endif
  Endif
  If LSTOFLG : [M:PTH1]WSTOFLG(NOL) = 0 : Endif
#  If LSTOFLG & W_MSG<>"" GMESSAGE=W_MSG    : Endif # Issue 94538 GA 11/2013
End

# Issue 94547 - 2014-03-14 by CCC
#**----------------------------------------------------------------<br/>
#* CHARG_SCM : Load materials for EO receipt
#**<br/>----------------------------------------------------------------<br/>
#* @param NOL : line index
#* @param LRET : Error code (0:OK ; >0:Error)
#**<br/>----------------------------------------------------------------
#*!
Subprog CHARG_SCM(NOL,LRET)
Value Integer NOL
Variable Integer LRET
Local Integer WOK

  Raz WOK,LRET # Issue 92325 GA 10/2013 sinon pb sur WSTOFLG
  Raz [M:PSCM]
  [M:PSCM]ORINOL = NOL  : # on conserve n° ligne réception pour ALI_ALP ou autres outils stocks

#
# Entête
  Call CHARG_SCM_EOH(NOL,WOK)
  LRET=max(LRET,WOK)
#
# conso des matières mises à dispo du sous-traitant
# -------------------------------------------------
  Call CHARG_SCM_EOD(NOL,WOK)
  LRET=max(LRET,WOK)
#
  If LRET    # Issue 94538 GA 11/2013
     # Erreur lors du traitement des sorties de stock.
     GMESSAGE=mess([M:PTH1]VCRTYPORI([M:PSCM]ORINOL),701,1)-[M:PTH1]VCRNUMORI([M:PSCM]ORINOL)-mess(522,182,1)
  Endif

# quand on a fini de recalculer les sorties matières, on enregistre [M:PSCM]RCPQTYSTU
  [M:PSCM]RCPQTYSTU=[M:PTH1]QTYSTU([M:PSCM]ORINOL)
  Affzo [M:PSCM]

# Issue 87188 - 2013-01-16 by CCC : l'enreg doit se faire après STJSTOENTW (en particulier pour WSTOSEQ)
## l'article lancé est inséré dans [F:PWS]
## pour que MAJ_STK puisse prendre en charge l'entrée en stock
#  Gosub ENR_PWS_SCMH
End

#########################################################################
# CHARG_SCM_EOH : S/P de chargement du détail stock de l'article lancé  #
#                 issus d'un ordre de sous-traitance.                   #
# --------------------------------------------------------------------- #
# Subprog CHARG_SCM_EOH (LLIG,LRET)                                      #
#    LLIG  : Indice de la ligne de réception en cours de traitement      #
#    LRET : Code retour 0: Ok, sinon Ko                                 #
#########################################################################
Subprog CHARG_SCM_EOH(LLIG,LRET)
Value    Integer  LLIG   # avant NOL
Variable Integer  LRET

#----- Variables locales -----#
Local   Integer  J
Local   Char     WSCONUM(GLONREF) : WSCONUM=[M:PTH1]VCRNUMORI(LLIG)
Local   Integer  WSCILIN          : WSCILIN=[M:PTH1]VCRLINORI(LLIG)
Local   Integer  WSCSLIN          : WSCSLIN=[M:PTH1]VCRSEQORI(LLIG)
#If dim(SVGNOL)<0 :  Local Integer  SVGNOL  : Endif
#SVGNOL=NOL
Raz   [M:PSCM]
Actzo [M:PSCM]1-99

# Ouverture des tables si nécessaire
#Gosub OPEN_FILES_SCO From SCOLIB # Issue 95885 remonté dans CHARG_STT_EO
Raz [F:SCI], [F:SCS], [F:SCO], [F:SCM]

#------ Lecture ordre de sous-traitance: Entête/Article lancé/Service -----#
Read [SCO] SCO0=WSCONUM
If fstat : Raz [F:SCO] : Endif
# ATTENTION: si on est sur l'article sous-traité [M:PTH1]VCRSEQORI contient 0
If WSCSLIN=0  : # Recherche sur clé partielle: une seule opération possible
   Read [SCS] SCS0(2)=WSCONUM;WSCILIN
   If fstat : Raz [F:SCS] : Endif
Else
   Read [SCS] SCS0=WSCONUM;WSCILIN;WSCSLIN
   If fstat : Raz [F:SCS] : Endif
Endif
#----- cette maj est nécessaire en cas d'annulation ou modif de la qté
#----- Si l'EO est soldé, on ne fait pas de mvt de stock.
#If [F:SCO]SCOTRKFLG=5
#   # Ordre de sous-traitance clos: Mise à jour impossible !
#   Call ECR_TRACE("CHARG_SCM_EO(SUBPTHC):"-WSCONUM-mess(359,194,1),0) From GESECRAN
#   Goto FIN_CHARG_SCM_EOH
#Endif

Raz [F:PWS]
# GA 04/2006 on relit le composé déjà enregistré dans [F:PWS] (VCRSEQ=0)
#----- Réaffichage des articles  enregistrés dans [F:PWS] et dans STOENT
Local   Integer  WSCICLE
# Issue 95496 & 97173 - 2014-02-26 by CCC : use of WSTOSEQ to link [M:PTH1] & [F:PWS] instead of line number in [M:PTH1]
#WSCICLE=LLIG+[M:PTH1]VCRLINORI(LLIG)   # Issue 90806 GA 06/2013
WSCICLE = [M:PTH1]WSTOSEQ(LLIG)+[M:PTH1]VCRLINORI(LLIG)
For [PWS]PWS0 Where PRONUM=adxuid(1) & CODFNC="PTH" & VCRTYP=36 &
&                   VCRNUM=WSCONUM & VCRLIN=WSCICLE & TRSTYP<>29 & VCRSEQ=0
  Read [SCI] SCI0=[F:PWS]VCRNUM;WSCILIN                     # avant [F:PWS]VCRLIN
  If !fstat : Break : Endif
Next
If [F:SCI]SCONUM<>WSCONUM | [F:SCI]SCILIN<>WSCILIN
   Read [SCI]SCI0=WSCONUM;WSCILIN
   If fstat Goto FIN_CHARG_SCM_EOH Endif
Endif
Gosub CHARG_ECRSCMH
$FIN_CHARG_SCM_EOH
#NOL=SVGNOL
End

#########################################################################
# CHARG_SCM_EOD : S/P de chargement du détail stock de l'article lancé  #
#                 issus d'un ordre de sous-traitance.                   #
# --------------------------------------------------------------------- #
# Subprog CHARG_SCM_EOD (LLIG,LRET)                                      #
#    LLIG  : Indice de la ligne de réception en cours de traitement      #
#    LRET : Code retour 0: Ok, sinon Ko                                 #
#########################################################################
Subprog CHARG_SCM_EOD(LLIG,LRET)
Value    Integer  LLIG   # avant NOL
Variable Integer  LRET

#----- Variables locales -----#
#If dim(SVGNOL)<0 :  Local Integer  SVGNOL  : Endif
#SVGNOL=LLIG
Local   Integer  WMAT, J
Local   Char     WSCONUM(GLONREF) : WSCONUM=[M:PTH1]VCRNUMORI(LLIG)
Local   Integer  WSCILIN          : WSCILIN=[M:PTH1]VCRLINORI(LLIG)
Local   Integer  WSCMLIN          #: WSCMLIN=[M:PTH1]VCRSEQORI(LLIG)
# pour appels GOUVSOR
Gosub INIT_TRSTYP From TRTPSAISCM
# Ouverture des tables si nécessaire
Gosub OPEN_FILES_SCO From SCOLIB

# Issue 101383 GA 08/2014
# Issue 90923 GA 08/2013 consultation des mvts de sortie
# [M:PSCM]PRHFCY et [M:PSCM]PTD* ont été chargés par CHARG_ECRSCMH
# If !find(GREP,"C","D")
If !find(GREP,"C","D") & [M:PTH1]CREFLG(LLIG)<>0
  If [M:PSCM]PTDLIN>0
    If !clalev([F:STJW]) Local File STOJOU [STJW] Endif
    Local Char WSTOFCY(GLONFCY) : WSTOFCY=[M:PSCM]PRHFCY
    If [F:SCO]BETFCY=2 & [F:SCO]MFGFCY<>"" WSTOFCY=[F:SCO]MFGFCY Endif  # intersite
   #
    Filter [STJW] Where STOFCY=WSTOFCY & VCRTYP=6 & VCRNUM=[M:PSCM]PTHNUM & VCRLIN=[M:PSCM]PTDLIN
&                     & VCRTYPORI=36 & TRSTYP=29
&              Order By Key STJ1
    For [STJW]
      Gosub CHARG_ECRSCMSTJ : # From SUBPTHC
    Next
    Filter [STJW]
  Endif
  End
Endif



# GA 04/2006 on vérifie si des matières ont déjà été enregistrées dans [F:PWS] (VCRSEQ>0)
#----- Réaffichage des qtés matières déjà enregistrées dans [F:PWS] et dans STOSORW
#For [F:PWS]PWS0 Where PRONUM=adxuid(1) & CODFNC="PTH" & VCRTYP=36 &
#&                     VCRNUM=WSCONUM & VCRLIN=WSCICLE & VCRSEQ>0          # Issue 90923 GA 08/2013
Local   Integer  WSCICLE
# Issue 95496 & 97173 - 2014-02-26 by CCC : use of WSTOSEQ to link [M:PTH1] & [F:PWS] instead of line number in [M:PTH1]
#WSCICLE=LLIG+[M:PTH1]VCRLINORI(LLIG)   # Issue 90806 GA 06/2013
WSCICLE = [M:PTH1]WSTOSEQ(LLIG)+[M:PTH1]VCRLINORI(LLIG)
Filter [F:PWS] Where PRONUM=adxuid(1) & CODFNC="PTH" & VCRTYP=36 &
&                    VCRNUM=WSCONUM & VCRLIN=WSCICLE & TRSTYP=29
&              Order By Key PWS0
For [F:PWS]
  WSCMLIN=[F:PWS]VCRSEQ
  Read [SCM] SCM0=WSCONUM;WSCILIN;WSCMLIN
  # Issue 93349 GA 10/2013 Cas des matières non prévues
  #If !fstat  Gosub CHARG_ECRSCMD : Endif
  If fstat : Raz [F:SCM] : Endif
  Gosub CHARG_ECRSCMD
Next
Filter [F:PWS]
#----- Si pas trouvé on charge tout -----#
If [M:PSCM]NBMAT=0
  #----- Liste des matières mises à dispo du sous-traitant, qui ne sont pas exclues
  For [SCM] SCM0 Where SCONUM=WSCONUM & SCILIN=WSCILIN & SCOFLG=2 & MATSTA <> 4 & CPNTYP=1
    Raz [F:PWS] : Gosub CHARG_ECRSCMD : # From SUBPTHC
  Next
Endif
#-----
For WMAT=0 To [M:PSCM]NBMAT-1
    nolign=WMAT+1
    Gosub ENR_PWS_SCMD
Next
#LLIG=SVGNOL
# tant qu'une des sorties est Ko, on oblige à ouvrir la fenêtre "détail qté sous-traitance"
# empêche la validation réception article sous-traité
#If find(0,[M:PSCM]WSTOFLG(0..[M:PSCM]NBMAT-1))
#   [M:PTH1]WSTOFLG(LLIG)=0
#Endif
End

#########################################################################
# effacement d'une ligne de réception (appel AVANT_NBLIG si suppression & DEPICK)
#########################################################################
# Issue 95496 & 97173 - 2014-02-26 by CCC : delete [F:PWS], [M:ENTW] & [M:SOW]
#**----------------------------------------------------------------<br/>
#* EFFAC_LIG : delete receipt line (call by SUBPTH.AVANT_NBLIG & SUBPTHC.DEPICKE_SCO)
#* for a subcontract receipt
#**<br/>----------------------------------------------------------------<br/>
#* @param NOL = line index in [M:PTH1]
#* @param LRET = error code ( 0=OK ; 1= Error while PWS deletion ; 2=Error while SOW deletion)
#**<br/>----------------------------------------------------------------
#*!
Subprog EFFAC_LIG(NOL,LRET)
Value Integer NOL
Variable Integer LRET

Local Integer LSAVSTOSEQ

Raz LRET

If !find([M:PTH1]WRKMOTEUR(NOL),2,3) : # Ancien code de SUBPTH
    End
Endif

Call DEBTRANS From GLOCK
Trbegin [PWS]

#Gosub EFFAC_LIG_PWS From SUBPTHC # FQ 59735 étiquette inexistante
Local Integer WRET, WVCRSEQ, WVCRLIN
Case [M:PTH1]VCRTYPORI(NOL) :
   When 10 :    # Issue 87583 GA 02/2013 cas particulier des opé d'OF
     WVCRSEQ = 0
     If dim([L]WOPENUMCLE)<0 Local Integer  WOPENUMCLE : Endif
     Filter [F:MFI] Where MFGNUM=[M:PTH1]VCRNUMORI(NOL)
     For [F:MFI]
       WVCRLIN = [F:MFI]MFGLIN

# Issue 95496 - 2014-03-17 by CCC : WOF : [F:PWS]VCRSEQ = [M:PTH1]WSTOSEQ
#      # Issue 93977 GA 11/2013 déplacé dans CAL_WOPENUMCLE
#       Gosub CAL_WOPENUMCLE
#       Call EFFACE_LIGD_PWS("PTH",[M:PTH1]VCRTYPORI(NOL),[M:PTH1]VCRNUMORI(NOL),WVCRLIN,WOPENUMCLE,WRET) From PWSLIB
       Call EFFACE_LIGD_PWS("PTH",[M:PTH1]VCRTYPORI(NOL),[M:PTH1]VCRNUMORI(NOL),WVCRLIN,[M:PTH1]WSTOSEQ(NOL),WRET) From PWSLIB
     Next
     Filter [F:MFI]
   When 36 :
    # Ordre de sous-traitance
    # -----------------------
     WVCRLIN = [M:PTH1]VCRLINORI(NOL)
     WVCRSEQ = [M:PTH1]VCRSEQORI(NOL)
     # Issue 90923 suite 90806 GA 08/2013 avant WVCRLIN
     Local   Integer  WSCICLE : WSCICLE=NOL+[M:PTH1]VCRLINORI(NOL)
    WSCICLE = [M:PTH1]WSTOSEQ(NOL)+[M:PTH1]VCRLINORI(NOL)
     Call EFFACE_LIGD_PWS("PTH",[M:PTH1]VCRTYPORI(NOL),[M:PTH1]VCRNUMORI(NOL),WSCICLE,WVCRSEQ,WRET) From PWSLIB

    If WRET
        LSAVSTOSEQ = [M:PTH1]WSTOSEQ(NOL)
        Filter [PWS] Where PRONUM=adxuid(1) & CODFNC="PTH" & VCRTYP=[M:PTH1]VCRTYPORI(NOL)
&                    & VCRNUM=[M:PTH1]VCRNUMORI(NOL) & VCRLIN=WSCICLE & TRSTYP=29
        For [PWS]
            Call EFFACE_LIGD_PWS("PTH",[M:PTH1]VCRTYPORI(NOL),[M:PTH1]VCRNUMORI(NOL),WSCICLE,[F:PWS]VCRSEQ,WRET) From PWSLIB
            If WRET
                [M:PTH1]WSTOSEQ(NOL) = [F:PWS]WSTOSEQ   # needed by DELSTOSORW
                Call DELSTOSORW(NOL, NOL,"PTH1",[PTH0]PRHFCY,LRET) From STKSOR
                [M:PTH1]WSTOSEQ(NOL) = LSAVSTOSEQ
                If LRET
                    LRET=2
                    Break
                Endif
            Else
                LRET=1
                Break
            Endif
        Next
        Filter [PWS]
    Else
        LRET=1
    Endif
Endcase
If !LRET
    Call DELSTOENTW(NOL, NOL,"PTH1",1,1,[PTH0]PRHFCY,1,"") From STKENT
Endif


If GOK<>1 & LRET=0 : LRET=1 : Endif
If GOK=1 & !LRET
    Commit
    If !sigma(0,[M:PTH1]NBLIG-1,( indcum<>NOL
&                               & [M:PTH1]LINTYP(indcum)<=2
&                               & [M:PTH1]VCRTYPORI(indcum)=[M:PTH1]VCRTYPORI(NOL)
&                               & [M:PTH1]VCRNUMORI(indcum)=[M:PTH1]VCRNUMORI(NOL)))
        Case [M:PTH1]VCRTYPORI(NOL)
             When 10 : Unlock="MFG"+[M:PTH1]VCRNUMORI(NOL)
             When 36 : Unlock="SCO"+[M:PTH1]VCRNUMORI(NOL)
        Endcase
    Endif
Else
    Rollback
Endif

End

#####################################################################################
$CAL_WOPENUMCLE                                              # Issue 93977 GA 11/2013
If clalev([M:PSTT])
    Local Shortint K : K=[M:PSTT]ORINOL
    If WVCRSEQ=0
        # Ordre de fabrication (mono ou multi-articles)
        # ---------------------------------------------
         Filter [F:MFO] Where MFGNUM=[M:PTH1]VCRNUMORI(K) & OPENUM=[M:PTH1]VCRLINORI(K) & POHNUM=[M:PTH1]POHNUM(K)  & POPLIN=[M:PTH1]POPLIN(K)
         For [F:MFO]
             WVCRSEQ = 100*[F:MFO]OPENUM+[F:MFO]OPESPLNUM
             Break
         Next
         Filter [F:MFO]
    Endif
    # Issue 90923 suite 89134 GA 08/2013 avant WVCRSEQ
    #WOPENUMCLE = 100*WOPENUM+WOPESPLNUM
    If [M:PTH1]PTDLIN(K)<>0
      WOPENUMCLE = 10*[M:PTH1]PTDLIN(K) + WVCRSEQ
    Else
      WOPENUMCLE = 10*1000*(K+1) + WVCRSEQ
    Endif
Elsif [F:PTD]PTDLIN<>0
    If WVCRSEQ=0
        # Ordre de fabrication (mono ou multi-articles)
        # ---------------------------------------------
         Filter [F:MFO] Where MFGNUM=[F:PTD]VCRNUMORI & OPENUM=[F:PTD]VCRLINORI & POHNUM=[F:PTD]POHNUM  & POPLIN=[F:PTD]POPLIN
         For [F:MFO]
             WVCRSEQ = 100*[F:MFO]OPENUM+[F:MFO]OPESPLNUM
             Break
         Next
         Filter [F:MFO]
    Endif
    WOPENUMCLE = 10*[F:PTD]PTDLIN + WVCRSEQ
Endif
Return

#####################################################################################
# Contrôle si la qté totale détaillée dans [M:ENTW] correspond à la qté réceptionnée
# Il s'agit de reproduire le CTLSTOENT(STKECR) si article non géré en stock ....
#####################################################################################
$CTL_STT_QTY
If find(2,[M:PTH1]WRKMOTEUR(0..[M:PTH1]NBLIG-1))
#-- On a au moins une ligne de sous-traitance OF avec déclaration de production
  # Issue 95496 - 2014-03-17 by CCC : WOF
  #For [PWS]PWS0 Where PRONUM=adxuid(1)
  For [F:PWS]PWS0 Where PRONUM=adxuid(1) & VCRTYP=10
    # Issue 95496 - 2014-03-17 by CCC : WOF : [F:PWS]VCRSEQ = [M:PTH1]WSTOSEQ
    ## FQ 68123 GA 10/2010 I=indice de la ligne de rcp concernée par cette entrée en stock
    #I=find([F:PWS]WSTOSEQ,[M:PTH1]WSTOSEQ(0..[M:PTH1]NBLIG-1))
    I=find([F:PWS]VCRSEQ,[M:PTH1]WSTOSEQ(0..[M:PTH1]NBLIG-1))

    #------- Contrôle des compléments lots -------------#
    If sigma (J=0,[M:ENTW]NBLIG-1,( [M:ENTW]WSTOSEQ(J)=[F:PWS]WSTOSEQ)*([M:ENTW]NUMLIGLOT(J)>0)
&           *( 2- [M:ENTW]VALIDE( [M:ENTW]NUMLIGLOT(J)*([M:ENTW]NUMLIGLOT(J)>0)  ) ) )
&          <> 0
          Call ERREUR(mess(93,100,1)+" "+num$(I)+chr$(13)+mess(28,184,1)) From GESECRAN
          Raz OK
          Break
    Endif
    #------- Contrôle de cohérence des quantité --------#
    WQTE=sigma(J=0,[M:ENTW]NBLIG-1,[M:ENTW]QTYSTU(J)*([M:ENTW]WSTOSEQ(J)=[F:PWS]WSTOSEQ))

    # FQ 74274 GA 10/2011 US article lancé <> US article sous-traitance
     If I & [M:PTH1]STU(I-1)<>[F:PWS]STU
        If I & (WQTE<>[F:PWS]QTYSTU ) ##### | WQTE<>[M:PTH1]QTYSTU(I-1))
          Call ERREUR(mess(61,100,1)-num$(I)-"(1)"-":"-mess(20,184,1)-num$(WQTE)-[F:PWS]STU-"<>"-num$([M:PTH1]QTYSTU(I-1))-[M:PTH1]STU(I-1)) From GESECRAN
          Raz OK
          Break
        Endif
    # FQ 78901 GA 12/2011 cas particulier OF
    Elsif I & [M:PTH1]VCRTYPORI(I-1)=10
       If I & (WQTE<>[F:PWS]QTYSTU ) ##### | WQTE<>[M:PTH1]QTYSTU(I-1))
          Call ERREUR(mess(61,100,1)-num$(I)-"(2)"-":"-mess(20,184,1)-num$(WQTE)-[F:PWS]STU-"<>"-num$([F:PWS]QTYSTU)-[M:PTH1]STU(I-1)) From GESECRAN
          Raz OK
          Break
        Endif
    Else
        If I & (WQTE<>[F:PWS]QTYSTU | WQTE<>[M:PTH1]QTYSTU(I-1))
          Call ERREUR(mess(61,100,1)-num$(I)-"(3)"-":"-mess(20,184,1)-num$(WQTE)-[F:PWS]STU-"<>"-num$([M:PTH1]QTYSTU(I-1))-[M:PTH1]STU(I-1)) From GESECRAN
          Raz OK
          Break
        Endif
    Endif
  Next
Endif
Return

#########################################################################
$CHARG_ECRSTTH
#-------------------#
# Chargement entête #
#-------------------#
If [M:PSTT]MFGNUM<>""  Return : Endif
[M:PSTT]MFGNUM   =[M:PTH1]VCRNUMORI(NOL)
[M:PSTT]OPENUM   =[F:OPS]OPENUM      # FQ 68123 avant [M:PTH1]VCRLINORI(NOL) (=POHNUM)
[M:PSTT]OPESPLNUM=[F:OPS]OPESPLNUM   # FQ 68123 avant [M:PTH1]VCRSEQORI(NOL) (=POPLIN)
[M:PSTT]ROUNUM   =[F:MFG]ROUNUM      # FQ 68123 avant [F:SCH]ROUNUM
[M:PSTT]ORINOL   =NOL
[M:PSTT]RCPSTU   =[M:PTH1]STU(NOL)
# FQ 68437 GA 10/2010 si [F:PWS]TRSCOD n'est pas ok (repris sur [M:PTH1]TRSCOD), prendre [F:MTS]TRSCOD
If [F:MTS]TRSCOD<>"" & [M:PTH0]TRSCOD=""
   [M:PSTT]TRSCOD = [F:MTS]TRSCOD
Else
   [M:PSTT]TRSCOD = [M:PTH0]TRSCOD
Endif
[M:PSTT]STOFCY   =[M:PTH0]PRHFCY
[M:PSTT]BPRNUM   =[M:PTH0]BPSNUM
[M:PSTT]IPTDAT   =[M:PTH0]RCPDAT
[M:PSTT]SRGLOCDEF=[M:PTH0]SRGLOCDEF
[M:PSTT]RCPQTYSTU=[M:PTH1]QTYSTU(NOL)  # Issue 93977 GA 11/2013
#-----
Gosub READ_PTRNUM
#-----
[M:PSTT]SRGWAIFLG=[F:PTR]SRGWAIFLG
Return

$CHARG_ECRSTTD
#-----------------------------------------#
# Chargement de l'écran de sous-traitance #
#-----------------------------------------#
# NOL ligne origine du tableau [M:PTH1] a été stocké dans [M:PSTT]ORINOL
If dim(S)<0         Local  Integer  S   : Endif
If [M:PSTT]NBLIG<>0
  S=[M:PSTT]NBLIG
Endif
Raz GBIDD1
[M:PSTT]MFGLIN(S)=[F:MFI]MFGLIN
[M:PSTT]ITMREF(S)=[F:MFI]ITMREF
If [F:ITP]ITMREF<>[M:PSTT]ITMREF(S) | [F:ITP]BPSNUM<>[M:PSTT]BPRNUM
  Read [ITP] ITP0=[M:PSTT]ITMREF(S);[M:PSTT]BPRNUM
  If fstat  Raz [F:ITP] : Endif
Endif
If [F:ITM]ITMREF<>[F:MFI]ITMREF
  Read [ITM]ITM0=[F:MFI]ITMREF
  If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITF]ITMREF<>[F:MFI]ITMREF | [F:ITF]STOFCY<>[M:PTH0]PRHFCY
  Read [ITF] ITF0=[F:MFI]ITMREF;[M:PTH0]PRHFCY : If fstat  Raz [F:ITF] : Endif
Endif
If [F:ITP]ITMREF<>""
  [M:PSTT]QUAFLG(S)=[F:ITP]QUAFLG
Else [M:PSTT]QUAFLG(S)=[F:ITF]QUAFLG
Endif
[M:PSTT]MAXQTYRCP(S)=[F:MFI]RMNEXTQTY
#----- Relecture BPARTNER si nécessaire -----#
If [F:BPR]BPRNUM<>[M:PTH0]BPSNUM
  Read [BPR] BPR0=[M:PTH0]BPSNUM : If fstat  Raz [F:BPR] : [F:BPR]LAN=GLANGUE : Endif
Endif
#----- Chargement des désignations article -----#
#Call CHARGE_ITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,[M:PSTT]ITMDES(S)) From TRTX3
#If [M:PSTT]ITMDES(S)="" [M:PSTT]ITMDES(S)=[F:ITM]ITMDES1 : Endif
Call CHARGE_DEFITMDES("DES1AXX",[F:BPR]LAN,[F:ITM]ITMREF,[M:PSTT]ITMDES(S), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129
#[M:PSTT]ITMDES1(S)=[F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:PSTT]ITMDES1(S), "[F:ITM]") From TRTX3   # FGR 29/06/2009 : X3SUIVI56129

If [F:ITM]STOMGTCOD>1
  # FQ 67539 GA 10/2010 si [F:PWS]TRSFAM n'est pas ok (repris sur [M:PTH1]TRSFAM(I)), prendre [F:MTS]TRSFAM
  If [F:MTS]TRSFAM<>"" & [M:PTH1]TRSFAM([M:PSTT]ORINOL)=""
     [M:PSTT]TRSFAM = [F:MTS]TRSFAM
  Else
     [M:PSTT]TRSFAM = [M:PTH1]TRSFAM([M:PSTT]ORINOL)
  Endif
Endif
If [M:PSTT]MVTDES(S)=""
   [M:PSTT]MVTDES(S)=mess(48,190,1)
Endif
If [M:PSTT]PJT(S)=""
   [M:PSTT]PJT(S)=[F:MFI]PJT   # Issue 81617
Endif
# Issue 82325 GA 06/2012
If dim([M:PSTT]WRH(S))>0 & dim([M:PTH0]WRHE)>0 & [M:PSTT]WRH(S)=""
   [M:PSTT]WRH(S)=[M:PTH0]WRHE
Endif

# Issue 95496 - 2014-03-17 by CCC : WOF
If LSTOSEQ=0
    #-- Initialisation des zones de stock - GA: maj sur écran PSTT plutôt que PTH1
    #Call INIZONENT([F:ITM]ITMREF,"PTH1",[M:PSTT]STOFCY,[M:PSTT]BPRNUM,1,"",S,5,
    Call INIZONENT([F:ITM]ITMREF,"PSTT",[M:PSTT]STOFCY,[M:PSTT]BPRNUM,1,"",S,5,
&                  [M:PSTT]TRSCOD,"",3,0) From STKECR
    If mkstat  Return : Endif
Endif

# Issue 87908 GA 04/2013 idem TRTACHSCO1
Local Decimal COEFF_MFI
If [F:MFG]EXTQTY = [F:MFI]EXTQTY | [F:MFG]EXTQTY = 0
# OF mono-article la qté totale = qté article lancé
  COEFF_MFI = 1
Else
  COEFF_MFI = [F:MFI]EXTQTY / [F:MFG]EXTQTY
Endif

# Issue 95496 - 2014-03-17 by CCC : WOF : [F:PWS]VCRSEQ = [M:PTH1]WSTOSEQ
## FQ 68123 GA 10/2010 identifier + précisément la ligne [F:PWS] (ajout VCRLIN et VCRSEQ)
##If [F:PWS]PRONUM=adxuid(1) & [F:PWS]VCRTYP=10 & [F:PWS]VCRNUM=[F:MFI]MFGNUM
## FQ 76070 suite 75839 GA 08/2011 [F:PWS] clé re-modifiée VCRLIN=WMFGLIN & VCRSEQ=WOPENUM
##Read [F:PWS]PWS0=adxuid(1);"PTH";10;[M:PSTT]MFGNUM;[M:PSTT]OPENUM;[M:PSTT]OPESPLNUM
## Issue 81433 GA 06/2012 il faut OPENUM et OPESPLNUM dans [F:PWS]
#If dim([L]WOPENUMCLE)<0 Local Integer  WOPENUMCLE       : Endif
## Issue 93977 GA 11/2013 déplacé dans CAL_WOPENUMCLE
#Local Integer WVCRSEQ : WVCRSEQ=100*WOPENUM+WOPESPLNUM
#Gosub CAL_WOPENUMCLE From SUBPTHC
#Read [F:PWS]PWS0=adxuid(1);"PTH";10;[M:PSTT]MFGNUM;[M:PSTT]MFGLIN(S);WOPENUMCLE
Read [F:PWS]PWS0=adxuid(1);"PTH";10;[M:PSTT]MFGNUM;[M:PSTT]MFGLIN(S);[M:PTH1]WSTOSEQ([M:PSTT]ORINOL)
If !fstat
  [M:PSTT]WSTOSEQ(S)  =[F:PWS]WSTOSEQ
  [M:PSTT]WLOCSEQ(S)  =[F:PWS]WLOCSEQ
  [M:PSTT]MVTDES(S)   =[F:PWS]MVTDES
  [M:PSTT]TRSFAM(S)   =[F:PWS]TRSFAM
  [M:PSTT]UOM(S)      =[F:PWS]UOM
  [M:PSTT]QTYUOM(S)   =[F:PWS]QTYUOM
  [M:PSTT]STU(S)      =[F:PWS]STU
  [M:PSTT]QTYSTU(S)   =[F:PWS]QTYSTU
  [M:PSTT]UOMSTUCOE(S)=[F:PWS]UOMSTUCOE
  [M:PSTT]RRRQTYSTU(S)=[F:PWS]RRRQTYSTU
  [M:PSTT]QQQQTYSTU(S)=[F:PWS]QQQQTYSTU
  [M:PSTT]MAXQTYRCP(S)=[F:PWS]MAXQTYRCP
  [M:PSTT]WSTOFLG(S)  =[F:PWS]WSTOFLG
# Issue 95496 - 2014-03-17 by CCC : keep what has already been entered
#  # Issue 93977 GA 11/2013 toujours recalculer
#  # FQ 74274 GA 10/2011 si cde du service en UA/US <> article lancé
#  #If [M:PTH1]STU([M:PSTT]ORINOL)<>[F:PWS]STU
#     If [M:PTH1]QTYSTU([M:PSTT]ORINOL)=[F:MFO]EXTQTY-[F:MFO]CPLQTY & [F:MFO]EXTQTY-[F:MFO]CPLQTY>0
#     # on solde la commande
#       [M:PSTT]QTYSTU(S)=[F:MFI]RMNEXTQTY
#       Call QTEARR([M:PSTT]QTYSTU(S),[F:MFI]STU) From TRTDIV
#     #Elsif [F:MFO]OPESTUCOE>0 # Issue 89134 suite GA 08/2013
#     Elsif [F:MFO]OPESTUCOE>0 # & [F:MFO]OPEUOM<>[F:PWS]STU # Issue 93977 & 92821 avant OPESTU Ko
#     # conversion ?
#       GBIDD1=[M:PTH1]QTYSTU([M:PSTT]ORINOL)/[F:MFO]OPESTUCOE * COEFF_MFI        # Issue 87908 GA 04/2013 cas multi-articles
#       Call QTEARR(GBIDD1,[F:MFI]STU) From TRTDIV
#       [M:PSTT]QTYSTU(S)=GBIDD1  # FQ 78901 il manquait l'affectation du résultat ?
#     Else
#       GBIDD1=[M:PTH1]QTYSTU([M:PSTT]ORINOL) * COEFF_MFI
#       Call QTEARR(GBIDD1,[F:MFI]STU) From TRTDIV
#       [M:PSTT]QTYSTU(S)=GBIDD1  # FQ 78901 il manquait l'affectation du résultat ?
#     Endif
#     If [F:PWS]UOM=[F:PWS]STU | [F:PWS]UOMSTUCOE=0
#        [M:PSTT]QTYUOM(S)=[M:PSTT]QTYSTU(S)
#     Else
#        GBIDD1 = [M:PSTT]QTYSTU(S) / [F:PWS]UOMSTUCOE # Issue 92821 GA 10/2013 avant * [F:PWS]UOMSTUCOE
#        Call QTEARR(GBIDD1,[F:PWS]UOM) From TRTDIV
#        [M:PSTT]QTYUOM(S)=GBIDD1
#     Endif
#  # Issue 87908 GA 02/2013 code simplifié car identique + il manquait arrondi dans le cas S=0
#  #### FQ 68578 GA 10/2010
#  ###Elsif [M:PTH1]QTYSTU([M:PSTT]ORINOL)<>[F:PWS]QTYSTU & [M:PTH1]QTYSTU([M:PSTT]ORINOL) > 0 & S=0 # Qté diminuée/augmentée
#  ###   #[M:PSTT]WSTOFLG(S)=0
#  ###   [M:PSTT]QTYSTU(S)=[M:PTH1]QTYSTU([M:PSTT]ORINOL)*COEFF_MFI # FQ 78901 coef article lancé
#  ###   If [F:PWS]UOM=[F:PWS]STU
#  ###      [M:PSTT]QTYUOM(S)=[M:PSTT]QTYSTU(S) # FQ 78901 GA 01/2012 avant [M:PTH1]QTYSTU([M:PSTT]ORINOL)
#  ###   Elsif [F:PWS]UOM=[M:PTH1]UOM([M:PSTT]ORINOL)
#  ###      [M:PSTT]QTYUOM(S)=[M:PTH1]QTYUOM([M:PSTT]ORINOL)*COEFF_MFI # FQ 78901 coef article lancé
#  ###   Endif
#  ###Elsif [M:PTH1]QTYSTU([M:PSTT]ORINOL)<>[F:MFG]EXTQTY & [M:PTH1]QTYSTU([M:PSTT]ORINOL) > 0 & S>0 # Qté diminuée/augmentée
#  # Issue 92821 GA 10/2013 pb si US différente entre article lancé et article sous-traitance
#  #Elsif [M:PTH1]QTYSTU([M:PSTT]ORINOL)<>[F:MFG]EXTQTY & [M:PTH1]QTYSTU([M:PSTT]ORINOL) > 0
#  #Elsif [M:PSTT]QTYSTU(S)<>[F:PWS]QTYSTU & [M:PSTT]QTYSTU(S) > 0
#  If [M:PSTT]QTYSTU(S)<>[F:PWS]QTYSTU & [M:PSTT]QTYSTU(S) > 0
#     # Issue 89134 suite GA 08/2013 saisie écrasée si recalcul et commande partielle/multi-articles
#     ## # Qté diminuée/augmentée ou cas particulier du sous-produit ou multi-articles lancés
#     ## [M:PSTT]QTYSTU(S)=[M:PTH1]QTYSTU([M:PSTT]ORINOL)*COEFF_MFI
#     ## Call QTEARR([M:PSTT]QTYSTU(S),[F:MFI]STU) From TRTDIV
#     If [F:PWS]UOM=[F:PWS]STU
#        [M:PSTT]QTYUOM(S)=[M:PSTT]QTYSTU(S)
#     Elsif [F:PWS]UOM=[M:PTH1]UOM([M:PSTT]ORINOL) & [F:PWS]UOMSTUCOE<>0
#        GBIDD1 = [M:PSTT]QTYSTU(S) / [F:PWS]UOMSTUCOE
#        Call QTEARR(GBIDD1,[F:PWS]UOM) From TRTDIV
#        [M:PSTT]QTYUOM(S)=GBIDD1
#     Endif
#  Endif
#  # FQ 76070 GA 09/2011 si qté recalculée, maj de [F:PWS]
#  If [F:PWS]QTYSTU<>[M:PSTT]QTYSTU(S)
#     [F:PWS]QTYSTU=[M:PSTT]QTYSTU(S)
#     [F:PWS]QTYUOM=[M:PSTT]QTYUOM(S)
#     Rewrite [F:PWS]
#  Endif

  # Issue 95496 - 2014-03-17 by CCC : WOF
  #If [M:PSTT]WSTOSEQ(S)<>0 & [M:PSTT]WSTOFLG(S)=1
  If [M:PSTT]WSTOSEQ(S)<>0
    Call LOAD_FROM_ENTW("PSTT",S,[M:PSTT]STOFCY,[M:PSTT]WSTOSEQ(S),
&                       [M:PSTT]ITMREF,0) From STKENT
  Endif
Else
  [M:PSTT]STU(S)=[F:MFI]STU
  # FQ 74274 GA 10/2011 si cde du service en UA article lancé
  #If [F:OPS]OPEUOM = [M:PTH1]PUU([M:PSTT]ORINOL) & [F:OPS]OPESTUCOE > 0
  #  GBIDD1 = [M:PTH1]QTYPUU([M:PSTT]ORINOL) / [F:OPS]OPESTUCOE
  If [F:MFI]UOM = [M:PTH1]PUU([M:PSTT]ORINOL) & [F:MFI]UOMSTUCOE > 0
    GBIDD1 = [M:PTH1]QTYPUU([M:PSTT]ORINOL) / [F:MFI]UOMSTUCOE * COEFF_MFI        # Issue 87908 GA 04/2013
    Call QTEARR(GBIDD1,[F:MFG]STU) From TRTDIV
  Elsif [F:MFI]STU <> [M:PTH1]STU([M:PSTT]ORINOL)
  # FQ 74274 GA 10/2011 si cde du service en UA/US <> article lancé
    [M:PSTT]UOM(S)=[F:MFI]UOM
    [M:PSTT]UOMSTUCOE(S)=[F:MFI]UOMSTUCOE
    If [M:PTH1]QTYSTU([M:PSTT]ORINOL)=[F:MFO]EXTQTY-[F:MFO]CPLQTY & [F:MFO]EXTQTY-[F:MFO]CPLQTY>0
    # on solde la commande
      # Issue 106094 GA 02/2015 before [F:MFI]RMNEXTQTY
      GBIDD1=([F:MFO]EXTQTY-[F:MFO]CPLQTY) * COEFF_MFI
      Call QTEARR(GBIDD1,[F:MFI]STU) From TRTDIV
    Elsif [F:MFO]OPESTUCOE>0
    # conversion ?
      GBIDD1=[M:PTH1]QTYSTU([M:PSTT]ORINOL)/[F:MFO]OPESTUCOE * COEFF_MFI        # Issue 87908 GA 04/2013
      Call QTEARR(GBIDD1,[F:MFI]STU) From TRTDIV
    Else
      # Issue 89134 suite GA 08/2013 ajout cas particulier du sous-produit ou multi-articles lancés
      GBIDD1=[M:PTH1]QTYSTU([M:PSTT]ORINOL)*COEFF_MFI
      Call QTEARR(GBIDD1,[F:MFI]STU) From TRTDIV
    Endif
  Else
    Call PCAL_QTY([M:PTH1]QTYUOM([M:PSTT]ORINOL),[M:PTH1]UOM([M:PSTT]ORINOL),GBIDD1,[F:MFG]STU,
&                 [M:PTH1]ITMREF([M:PSTT]ORINOL),[M:PTH0]BPSNUM,1,GBIDD2) From TRTACHQTE1
    Call QTEARR(GBIDD1,[F:MFG]STU) From TRTDIV
  Endif
  Gosub READ_PTRNUM
  #----- Saisie en UC ? -----#
  If [F:PTR]UOMSAIFLG<>2 | [F:MFI]UOMSTUCOE=0
    [M:PSTT]UOM(S)      =[F:MFI]STU
    If GBIDD1=[F:MFI]RMNEXTQTY  # FQ 78901 avant [F:MFG]RMNEXTQTY
      [M:PSTT]QTYUOM(S) =[M:PSTT]MAXQTYRCP(S)
    Else
      [M:PSTT]QTYUOM(S) = GBIDD1*COEFF_MFI
    Endif
    [M:PSTT]UOMSTUCOE(S)=1
  Else
    [M:PSTT]UOM(S)      =[F:MFI]UOM
    If GBIDD1=[F:MFI]RMNEXTQTY  # FQ 78901 avant [F:MFG]RMNEXTQTY
      [M:PSTT]QTYUOM(S) =[M:PSTT]MAXQTYRCP(S)/[F:MFI]UOMSTUCOE
    Else
      [M:PSTT]QTYUOM(S) =GBIDD1/[F:MFI]UOMSTUCOE # Issue 89134 GA 08/2013 (GBIDD1*COEFF_MFI)/[F:MFI]UOMSTUCOE
    Endif
    [M:PSTT]UOMSTUCOE(S)=[F:MFI]UOMSTUCOE
  Endif
  #----- Quantité en UC -----#
  Call QTEARR([M:PSTT]QTYUOM(S),[M:PSTT]UOM(S)) From TRTDIV
  #----- Quantité en US -----#
  [M:PSTT]QTYSTU(S)=[M:PSTT]QTYUOM(S)*[M:PSTT]UOMSTUCOE(S)
  Call QTEARR([M:PSTT]QTYSTU(S),[M:PSTT]STU(S)) From TRTDIV

# Issue 95496 - 2014-03-17 by CCC : WOF don't calculate QTY & LOT if PWS exists
    # 04.06 demande 35403 si multi article lancé et au moins 2 lignes non encore soldées, restreindre la qté à la qté restante
    # si multi aricle lancé mais qu'il ne reste qu'une seule ligne non encore soldée, on se retrouve dans la configuration
    # du mono article
    # reste un PB : Si il reste 2 lignes non encore soldées mais que l'une d'entre elles est un sous-produit
    # on devrait se considérer comme étant en mono article ; On ne sait pas détecter ce cas (ou il faudrait une variable de
    # travail pour calculer le nombre de lignes articles lancés hors sous-produit
    # Issue 87908 GA 04/2013 autoriser réception > qté commandée sans restreindre l'entrée en stock
    If [M:PTH1]QTYSTU([M:PSTT]ORINOL)<>[F:MFO]EXTQTY-[F:MFO]CPLQTY
       # on garde la qté calculée
    Elsif   [M:PSTT]QTYSTU(S) > [M:PSTT]MAXQTYRCP(S)  & ([F:MFG]ITMLINNBR - [F:MFG]ITMCLENBR) > 1
         If [M:PSTT]UOMSTUCOE(S)= 0 : [M:PSTT]UOMSTUCOE(S)= 1 : Endif
         [M:PSTT]QTYSTU(S) = [M:PSTT]MAXQTYRCP(S)
         Call QTEARR([M:PSTT]QTYSTU(S),[M:PSTT]STU(S)) From TRTDIV
         [M:PSTT]QTYUOM(S) = [M:PSTT]QTYSTU(S) / [M:PSTT]UOMSTUCOE(S)
         Call QTEARR([M:PSTT]QTYUOM(S),[M:PSTT]UOM(S)) From TRTDIV
    Endif
    If dim([M:PSTT]LOT)>0
        [M:PSTT]LOT(S)=[F:MFI]LOT
    Endif
Endif

[M:PSTT]CALQTYSTU(S)  = [M:PSTT]QTYSTU(S)
If dim([M:PSTT]ITMTYP)>0    # FQ 69508 GA 04/2011 tenir compte des sous-produits
    [M:PSTT]ITMTYP(S)=[F:MFI]ITMTYP
Endif
S+=1 : [M:PSTT]NBLIG=S
Return

$CHARG_ECRSCMH
If dim(LLIG)<0 | LLIG<0 | LLIG>[M:PTH1]NBLIG Return Endif
#---------------------------------------#
# Chargement entête/article réceptionné #
# [F:SCO],[F:SCI] doivent être chargés  #
#---------------------------------------#
Raz GBIDD1
If [F:SCI]SCONUM=""  Return : Endif
[M:PSCM]SCONUM   = [F:SCI]SCONUM
[M:PSCM]SCILIN   = [F:SCI]SCILIN
[M:PSCM]PRHFCY   = [F:SCI]PRHFCY
[M:PSCM]BPRNUM   = [F:SCI]BPRNUM
[M:PSCM]PTHNUM   = [M:PTH0]PTHNUM
[M:PSCM]PTDLIN   = [M:PTH1]PTDLIN(LLIG)
[M:PSCM]PJT      = [M:PTH1]PJT   (LLIG)
[M:PSCM]IPTDAT   = [M:PTH0]RCPDAT
[M:PSCM]ORINOL   = LLIG
Affzo [M:PSCM]
#----- Relecture BPARTNER si nécessaire -----#
If [F:BPR]BPRNUM<>[M:PSCM]BPRNUM
  Read [BPR] BPR0=[M:PSCM]BPRNUM : If fstat  Raz [F:BPR] : [F:BPR]LAN=GLANGUE : Endif
Endif
# quelle qté réceptionnée, pour savoir recalculer les sorties matières
Local   Integer  WSCICLE
# Issue 95496 & 97173 - 2014-02-26 by CCC : use of WSTOSEQ to link [M:PTH1] & [F:PWS] instead of line number in [M:PTH1]
#WSCICLE=LLIG+[M:PTH1]VCRLINORI(LLIG)   # Issue 90806 GA 06/2013
WSCICLE = [M:PTH1]WSTOSEQ(LLIG)+[M:PTH1]VCRLINORI(LLIG)
If [F:PWS]PRONUM=adxuid(1) & [F:PWS]VCRTYP=36 & [F:PWS]VCRNUM=[F:SCI]SCONUM &
&  [F:PWS]VCRLIN=WSCICLE & [F:PWS]VCRSEQ=0 & [F:PWS]TRSTYP<>29
  [M:PSCM]RCPQTYSTU = [F:PWS]QTYSTU
#Else             : # laisser à 0
#  [M:PSCM]RCPQTYSTU = [M:PTH1]QTYSTU(LLIG)
Endif

Return


$CHARG_ECRSCMD
#-----------------------------------------#
# Chargement des matières de l'ordre ss-tr#
# [F:SCM] doit être chargé                #
#-----------------------------------------#
If dim(WMAT)<0         Local  Integer  WMAT   : Endif
Local Shortint         WFOUND : WFOUND=1
Local Shortint         WCOMPLETED : WCOMPLETED=1 # Issue 97904 GA 12/2014
WMAT=[M:PSCM]NBMAT
# Issue 93349 GA 10/2013 Cas des matières non prévues
nolign=WMAT+1
#If [F:SCM]SCONUM=""  Return : Endif
If [F:SCM]CPNITMREF<>""
    #nolign=WMAT+1      : # pour le transclasse
    [M:PSCM] = [F:SCM] : # ecrase [M:PSCM]ITMREF(0) avec [F:SCM]ITMREF
    # pour les traitements "stock" on utilise ici ITMREF au lieu de CPNITMREF
    [M:PSCM]ITMREF   (WMAT)=[F:SCM]CPNITMREF
    [M:PSCM]PAEITMREF(WMAT)=[F:SCM]ITMREF
    [M:PSCM]STOFCY   (WMAT)=[F:SCM]STOFCY
    [M:PSCM]LOCPREF  (WMAT)=[F:SCM]LOC
    [M:PSCM]LOTPREF  (WMAT)=[F:SCM]LOT
    [M:PSCM]STAPREF  (WMAT)=[F:SCM]STA
    [M:PSCM]STU      (WMAT)=[F:SCM]STU
    # Issue 97904 GA 12/2014 required component already completed
    If [F:SCM]MATSTA=3
       [M:PSCM]CLEFLG(WMAT)=2 : Grizo [M:PSCM]CLEFLG(WMAT)
       [M:PSCM]USEQTY(WMAT)=0 : Grizo [M:PSCM]USEQTY(WMAT)
       WCOMPLETED=2
    Endif
    # Issue 97245 GA 04/2014 partial receipt with different dates
    If [M:PTH0]RCPDAT< [F:SCM]DLVDAT
       [M:PSCM]DLVDAT(WMAT)=[M:PTH0]RCPDAT
    Else
       [M:PSCM]DLVDAT(WMAT)=[F:SCM]DLVDAT
    Endif
    [M:PSCM]RETQTY   (WMAT)=[F:SCM]RETQTY
    [M:PSCM]SCMRETQTY(WMAT)=[F:SCM]RETQTY : # on garde la qté besoin
    [M:PSCM]SCMUSEQTY(WMAT)=[F:SCM]USEQTY : # on garde la qté consommée déjà enregistrée
    [M:PSCM]STOMGTCOD(WMAT) = func ITMLIB.GET_STOMGTCOD([M:PSCM]ITMREF(WMAT),[M:PSCM]STOFCY(WMAT))
    If dim([M:PSCM]LOT)>0
       [M:PSCM]LOT(WMAT)=[F:SCM]LOT
    Endif
Endif

Local   Integer  WSCICLE
# Issue 95496 & 97173 - 2014-02-26 by CCC : use of WSTOSEQ to link [M:PTH1] & [F:PWS] instead of line number in [M:PTH1]
#WSCICLE=[M:PSCM]ORINOL+[M:PTH1]VCRLINORI([M:PSCM]ORINOL)   # Issue 90806 GA 08/2013
WSCICLE = [M:PTH1]WSTOSEQ([M:PSCM]ORINOL)+[M:PTH1]VCRLINORI([M:PSCM]ORINOL)
# Issue 93349 GA 10/2013 Cas des matières non prévues
#If [F:PWS]PRONUM=adxuid(1) & [F:PWS]VCRTYP=36 & [F:PWS]VCRNUM=[F:SCM]SCONUM &
#&  [F:PWS]VCRLIN=WSCICLE   & [F:PWS]VCRSEQ=[F:SCM]SCMLIN
If [F:PWS]PRONUM=adxuid(1) & [F:PWS]VCRTYP=36 & [F:PWS]VCRNUM=[F:SCI]SCONUM & [F:PWS]VCRLIN=WSCICLE
  # Qté consommée déjà calculée ou saisie
  # --------------------------------------
  [M:PSCM]TRSCODS        =[F:PWS]TRSCOD
  [M:PSCM]WSTOSEQ(WMAT)  =[F:PWS]WSTOSEQ
  [M:PSCM]WLOCSEQ(WMAT)  =[F:PWS]WLOCSEQ
  [M:PSCM]MVTDES (WMAT)  =[F:PWS]MVTDES
  [M:PSCM]TRSFAMS(WMAT)  =[F:PWS]TRSFAM
  [M:PSCM]RETQTY (WMAT)  =[F:PWS]QTYSTU
  [M:PSCM]USEQTY (WMAT)  =[F:PWS]QTYSTU
  If dim([F:PWS]RETQTY)>0  # Issue 97904 GA 12/2014 + 2 cols RETQTY and CLEFLG
     [M:PSCM]RETQTY(WMAT)=[F:PWS]RETQTY
     [M:PSCM]CLEFLG(WMAT)=[F:PWS]CLEFLG
  Endif
  [M:PSCM]WSTOFLG(WMAT)  =[F:PWS]WSTOFLG
  [M:PSCM]CREFLG (WMAT)  = 1   # pour fonctionnement Ok de OUVSOR: indique que la ligne est déjà dans [M:SOW]

  # Issue 93349 GA 10/2013 Cas des matières non prévues
  If [M:PSCM]ITMREF(WMAT)="" & dim([F:PWS]ITMREF)>0
     [M:PSCM]ITMREF(WMAT)=[F:PWS]ITMREF
     [M:PSCM]STOFCY(WMAT)=[F:SCI]PRHFCY
     [M:PSCM]LOC   (WMAT)=[F:SCI]LOC
     [M:PSCM]BOMSEQ(WMAT)=0
     # Issue 105334 GA 01/2015
     # reopening a screen with unexpected materials SCMLIN was wrong
     [M:PSCM]SCMLIN(WMAT)=[F:PWS]VCRSEQ
  Endif
  If [M:PSCM]ITMREF(WMAT)="" Return Endif
  WFOUND=2
Endif
# Charger [F:ITF] et zones de stock
Call AM_ITMREF([M:PSCM]ITMREF(WMAT)) From TRTPSAISCM

# Issue 93349 GA 10/2013 Cas des matières non prévues: date besoin
If  [M:PSCM]BOMSEQ(WMAT)=0 &  [M:PSCM]DLVDAT(WMAT)=[0/0/0]
  Local Integer WOFS : WOFS=[F:ITF]OFS
  Local Date    WSTRDAT,WENDDAT
  If [F:SCS]OPESTR<>[0/0/0] WSTRDAT=[F:SCS]OPESTR Else WSTRDAT=[F:SCO]ORDDAT Endif
  If [F:SCS]OPEEND<>[0/0/0] WENDDAT=[F:SCS]OPEEND Else WENDDAT=[F:SCO]RETDAT Endif
  Call UPD_MAT_DAT(WSTRDAT, WENDDAT,[M:PSCM]STOFCY(WMAT),WOFS,[M:PSCM]DLVDAT(WMAT)) From SCOLIB
Endif
# Issue 93349 GA 10/2013 Cas des matières non prévues: qté disponible
If  [M:PSCM]BOMSEQ(WMAT)=0
#----- article géré en stock ?              -----#
  [M:PSCM]STOMGTCOD(WMAT) = func ITMLIB.GET_STOMGTCOD([M:PSCM]ITMREF(WMAT),[M:PSCM]STOFCY(WMAT))
  Affzo [M:PSCM]STOMGTCOD(WMAT)
  If [M:PSCM]STOMGTCOD(WMAT)=2
    # recherche stock disponible site
    If dim(WRET)<0         Local  Integer  WRET   : Endif # Issue 93349 GA 11/2013
    If dim(WDIS)<0         Local  Decimal  WDIS   : Endif
    Call LECITV2([M:PSCM]STOFCY(WMAT),[M:PSCM]ITMREF(WMAT),WRET) From MFGLIB
    If [M:PSCM]LOC(WMAT)<>""     # Issue 89901 GA 07/2013 parameter LPECINTLOC=1 except internal stock
      Call STODISALL([M:PSCM]STOFCY(WMAT),[M:PSCM]ITMREF(WMAT),36,1,1,1,2,"","",WDIS,WRET) From STKALL
    Else
      Call STODISALL([M:PSCM]STOFCY(WMAT),[M:PSCM]ITMREF(WMAT),36,1,2,1,2,"","",WDIS,WRET) From STKALL
    Endif
    [M:PSCM]AVAQTY(WMAT) = WDIS + [M:PSCM]ALLQTY(WMAT)
  Endif
Endif

If WCOMPLETED=2 # Issue 97904 GA 12/2014 component already completed

# FQ 54484 à calculer sauf si déjà renseigné, sauf si zéro forcé en saisie
Elsif ([M:PSCM]USEQTY(WMAT)=0 & WFOUND=1) | [M:PSCM]RCPQTYSTU<>[M:PTH1]QTYSTU([M:PSCM]ORINOL)
# calcul des matières consommées: indice WMAT
  Gosub CALC_PSCM_USEQTY From TRTPSAISCM

  # FQ 54484 suite pour maj [M:SOW]
  If [F:PWS]QTYSTU<>[M:PSCM]USEQTY(WMAT)
    Call AM_USEQTY([M:PSCM]USEQTY(WMAT)) From TRTPSAISCM
    # Issue 94558 GA 11/2013 maj [F:PWS] suite à changement de qté
    If WFOUND=2
       [F:PWS]QTYSTU=[M:PSCM]USEQTY(WMAT)
       [F:PWS]QTYUOM=[M:PSCM]USEQTY(WMAT)
       If dim([F:PWS]RETQTY)>0  # Issue 97904 GA 12/2014 + 2 cols RETQTY and CLEFLG
          [F:PWS]RETQTY=[M:PSCM]RETQTY(WMAT)
          [F:PWS]CLEFLG=[M:PSCM]CLEFLG(WMAT)
       Endif
       Rewrite [F:PWS]
    Endif
  Endif
Endif
#
#----- Relecture BPARTNER si nécessaire -----#
If [F:BPR]BPRNUM<>[M:PTH0]BPSNUM
  Read [BPR] BPR0=[M:PTH0]BPSNUM : If fstat  Raz [F:BPR] : [F:BPR]LAN=GLANGUE : Endif
Endif
If [M:PSCM]STOMGTCOD(WMAT)>1 & [M:PSCM]TRSFAMS(WMAT)=""
   [M:PSCM]TRSFAMS(WMAT)=[F:PTR]TRSFAMS    # suite FQ 67334 GA 09/2010 erreur [F:MTS]TRSFAMS
Endif
If [M:PSCM]MVTDES(WMAT)=""
   [M:PSCM]MVTDES(WMAT)=mess([M:PSCM]TRSTYP,704,1)
Endif

# --------------------------------------------
# Sortie de stock: Maj de [M:ALP] puis [M:SOW]
# --------------------------------------------
# indice WMAT et [M:PSCM]NBMAT utilisés par les trt Stocks - FQ 51330
[M:PSCM]NBMAT=WMAT+1
Gosub TRT_STOCKLIGNE From TRTPSAISCM
[M:PSCM]CREFLG(WMAT)     = 1   # pour fonctionnement Ok de OUVSOR: indique que la ligne est déjà dans [M:SOW]
[M:PSCM]UPDFLG(WMAT)     = 0

WMAT+=1
Return

# ------------------------------------------------
# Issue 90923 GA 08/2013
# Chargement des mvts de stock déjà pris en compte
# ------------------------------------------------
$CHARG_ECRSCMSTJ
#-----------------------------------------#
# [F:STJW] doit être chargé               #
#-----------------------------------------#
If dim(WMAT)<0  Local  Integer  WMAT   : Endif
Local Integer WSCMOK : WSCMOK=1
WMAT=[M:PSCM]NBMAT
nolign=WMAT+1      : # pour le transclasse
[M:PSCM]NBMAT+=1

#[M:PSCM] = [F:STJW] # écrase BPRNUM, ...
If [F:STJW]UPDCOD=1 # Mvt en attente (avant affichage des valeurs)
    Local Char WITALIC(15) : WITALIC="AWARNLOW"
    Chgstl  [M:PSCM]NBMAT(nolign-1) With WITALIC
Endif

If [F:ITF]ITMREF <> [F:STJW]ITMREF| [F:ITF]STOFCY <> [F:STJW]STOFCY
    Read [F:ITF]ITF0 = [F:STJW]ITMREF;[F:STJW]STOFCY
    If fstat : Call ERREUR(mess(2,196,1)-[F:STJW]ITMREF-[F:STJW]STOFCY) From GESECRAN
       mkstat = 1
       End
    Endif
Endif

# [F:STJW]VCRSEQORI ne contient pas [F:SCM]BOMSEQ
#Read [F:SCM]SCM0=[F:STJW]VCRNUMORI;[F:STJW]VCRLINORI;[F:STJW]VCRSEQORI
Filter [F:SCM] Where SCONUM=[F:STJW]VCRNUMORI & SCILIN=[F:STJW]VCRLINORI & CPNITMREF=[F:STJW]ITMREF
For [F:SCM]
    [M:PSCM] = [F:SCM] : # ecrase [M:PSCM]ITMREF(0) avec [F:SCM]ITMREF
    [M:PSCM]SCMRETQTY(WMAT)=[F:SCM]RETQTY
    [M:PSCM]SCMUSEQTY(WMAT)=[F:SCM]USEQTY
    [M:PSCM]MATSTA   (WMAT)=[F:SCM]MATSTA
    WSCMOK=2
Next
Filter [F:SCM]
If WSCMOK=1
    [M:PSCM]SCMRETQTY(WMAT)=[M:PSCM]RETQTY(WMAT)
    [M:PSCM]SCMUSEQTY(WMAT)=[M:PSCM]RETQTY(WMAT)
    [M:PSCM]MATSTA   (WMAT)=3
    [M:PSCM]CLEFLG   (WMAT)=2
Endif
[M:PSCM]PAEITMREF(WMAT)=[F:SCI]ITMREF
[M:PSCM]ITMREF   (WMAT)=[F:STJW]ITMREF
[M:PSCM]STOFCY   (WMAT)=[F:STJW]STOFCY
[M:PSCM]LOCPREF  (WMAT)=[F:STJW]LOC
[M:PSCM]LOTPREF  (WMAT)=[F:STJW]LOT
[M:PSCM]STA      (WMAT)=[F:STJW]STA      # Issue 105424 GA 01/2015
[M:PSCM]STAPREF  (WMAT)=[F:STJW]STA
If dim([M:PSCM]LOC)>0    [M:PSCM]LOC   (WMAT)=[F:STJW]LOC    Endif  # Issue 105424 GA 03/2015 code activité EMP
If dim([M:PSCM]LOT)>0    [M:PSCM]LOT   (WMAT)=[F:STJW]LOT    Endif  # Issue 105424 GA 03/2015 code activité LOT
If dim([M:PSCM]SLO)>0    [M:PSCM]SLO   (WMAT)=[F:STJW]SLO    Endif  # Issue 105424 GA 03/2015 code activité SLO
If dim([M:PSCM]SERNUM)>0 [M:PSCM]SERNUM(WMAT)=[F:STJW]SERNUM Endif  # Issue 105424 GA 03/2015 code activité SER
[M:PSCM]DLVDAT   (WMAT)=[F:STJW]IPTDAT
[M:PSCM]RETQTY   (WMAT)=[M:PSCM]SCMRETQTY(WMAT) # [F:STJW]QTYSTU * -1
[M:PSCM]USEQTY   (WMAT)=[F:STJW]QTYSTU * -1
[M:PSCM]STOMGTCOD(WMAT) = func ITMLIB.GET_STOMGTCOD([F:STJW]ITMREF,[F:STJW]STOFCY)
[M:PSCM]STU      (WMAT)=[F:ITM]STU
[M:PSCM]TRSFAMS  (WMAT)=[F:STJW]TRSFAM
[M:PSCM]STOCODL(WMAT) = [F:ITF]STOCOD
If WSCMOK=2 & [F:SCM]MATSTA=3
   [M:PSCM]CLEFLG(WMAT)=2
Else
   [M:PSCM]CLEFLG(WMAT)=1
Endif

Affzo [M:PSCM]STU,STOCODL

WMAT+=1
Return


$CTL_LIG_STT
#----------------------------------------------#
# Contrôle sur ligne de sous-traitance         #
# Appelé par CTL_LIGNE_DOCUMENT de TRTSTOENTB  #
#----------------------------------------------#
If dim(NOL)<0    :  Local Shortint NOL     : Endif
If dim(SVGNOL)<0 :  Local Integer  SVGNOL  : Endif
If dim(NEWQTY)<0 :  Local Decimal  NEWQTY  : Endif
SVGNOL=LLIGDOC : # Sauvegarde du nolign ecran stock
NOL=LLIGDOC
nolign=NOL+1
[L]NEWQTY =LQTYSTU
# Issue 96008 GA 10/2014 no question when importing data
# sr 11.02 demande 16415
# Contrôle pour les déclarations de production si qté supérieure
If !GIMPORT & [L]NEWQTY<>0 & [L]NEWQTY>[M:PSTT]MAXQTYRCP(NOL)
  OK=2 : Call AVERTIR(mess(54,190,1),OK) From GESECRAN
  If OK=1 mkstat=2 :  Endif
Endif
nolign=SVGNOL+1
Return



#########################################################################
$MAJ_LIGD_STT
#-----------------------------------------------------------------------#
# Mise à jour de la ligne de réception au retour du moteur de stock     #
# Cette étiquette est appelée depuis MAJ_LIGNE_DOCUMENT From TRTSTOENTA #
# quand VCRTYP = 15 Déclaration production                              #
#-----------------------------------------------------------------------#
If dim(NOL)<0       : Local Shortint NOL : Endif
If dim(OLDQTY)<0    : Local Decimal  OLDQTY    : Endif
If dim(OLDWCOEFF)<0 : Local Decimal  OLDWCOEFF : Endif
If dim(OLDUOM)<0    : Local Char     OLDUOM(GLONUOM) : Endif
NOL=LLIGDOC
nolign=NOL+1
#-- Sauvegarde de la quantité en US avant maj
[L]OLDQTY=[M:PSTT]QTYSTU(NOL)
[L]OLDUOM=[M:PSTT]UOM(NOL)
[L]OLDWCOEFF=[M:PSTT]UOMSTUCOE(NOL)
If LQTYSTU=0 & [M:PSTT]CREFLG(NOL)<>0
  [M:PSTT]QTYUOM(NOL)=0
  [M:PSTT]QTYSTU(NOL)=0
  Gosub ENR_PWS_STT  : # From SUBPTHC
  Return
Endif
[M:PSTT]RRRQTYSTU(NOL)=GRRRQTY
[M:PSTT]QQQQTYSTU(NOL)=GQQQQTY
If [F:ITM]ITMREF<>[M:PSTT]ITMREF(NOL)
  Read [ITM]ITM0=[M:PSTT]ITMREF(NOL)
  If fstat : Raz [F:ITM] : Endif
Endif
If LQTYSTU <> [M:PSTT]QTYSTU(NOL)    : # si qté modifiée
  #-- Si l'unité est la même et coeff unique sur toute les lg
  If LCOEF<>0
    If LPCU=[M:PSTT]UOM(NOL)
      [M:PSTT]QTYUOM(NOL) = LQTYSTU / LCOEF
      [M:PSTT]UOMSTUCOE(NOL)= LCOEF
      [M:PSTT]QTYSTU(NOL)=LQTYSTU
    # on a tout saisi en US, on reconvertit dans l'unité de réception
    # si on obtient un chiffre rond ok sinon on met tout en US
    Elsif LPCU=[M:PSTT]STU(NOL)
      [L]NEWQTY   =LQTYSTU/[M:PSTT]UOMSTUCOE(NOL)
      GBIDD1=[L]NEWQTY
      Call QTEARR(GBIDD1,[M:PSTT]UOM(NOL)) From TRTDIV
      If [L]NEWQTY=GBIDD1
        [M:PSTT]QTYUOM(NOL)= GBIDD1
      Else
        [M:PSTT]UOM(NOL)=[F:ITM]STU
        [M:PSTT]QTYUOM(NOL)= LQTYSTU
        [M:PSTT]UOMSTUCOE(NOL)=1
      Endif
      [M:PSTT]QTYSTU(NOL)=LQTYSTU
      [M:PSTT]STU(NOL)   =[F:ITM]STU
    # on a tout saisie dans une autre unité, on reconvertit dans l'unité de réception
    # si on obtient un chiffre rond ok sinon on met tout en US
    Else
      [L]NEWQTY   =LQTYSTU/[M:PSTT]UOMSTUCOE(NOL)
      GBIDD1=[L]NEWQTY
      Call QTEARR(GBIDD1,[M:PSTT]UOM(NOL)) From TRTDIV
      If [L]NEWQTY=GBIDD1
        [M:PSTT]QTYUOM(NOL)= GBIDD1
      Else
        [M:PSTT]UOM(NOL)=[F:ITM]STU
        [M:PSTT]QTYUOM(NOL)= LQTYSTU
        [M:PSTT]UOMSTUCOE(NOL)=1
      Endif
      [M:PSTT]QTYSTU(NOL)=LQTYSTU
      [M:PSTT]STU(NOL)   =[F:ITM]STU
    Endif
  Else
    #-- Sinon on met tout en US
    [M:PSTT]UOM(NOL)=[F:ITM]STU
    [M:PSTT]QTYUOM(NOL)= LQTYSTU
    [M:PSTT]UOMSTUCOE(NOL)=1
    [M:PSTT]QTYSTU(NOL)=LQTYSTU
  Endif
Endif
If [M:PSTT]UOM(NOL)=[M:PSTT]STU(NOL)
  Diszo [PSTT]UOMSTUCOE(NOL)
  [M:PSTT]WSTOSAI(NOL)=left$([M:PSTT]WSTOSAI(NOL),2)+"2"+right$([M:PSTT]WSTOSAI(NOL),4)
Endif
Gosub ENR_PWS_STT  : # From SUBPTHC
Affzo [M:PSTT]UOM(NOL), QTYUOM(NOL), QTYSTU(NOL), UOMSTUCOE(NOL)
Return


########################################################################
$ENR_PWS_STT
#-------------------------------------------#
# Efface du fichier de travail pour uneligne#
# Enregistrement du fichier de travail pour #
# la sous-traitance                         #
#-------------------------------------------#
If dim(NOL) <0 : Local Shortint NOL       : Endif
If dim(WRET)<0 : Local Integer WRET       : Endif
NOL=nolign-1
# Issue 95496 - 2014-03-17 by CCC : WOF : [F:PWS]VCRSEQ = [M:PTH1]WSTOSEQ
## Issue 87908 & 87583 GA 02/2013 clé PWS selon 81433
##Call EFFACE_LIGD_PWS("PTH",10,[M:PSTT]MFGNUM,[M:PSTT]OPENUM,[M:PSTT]OPESPLNUM,WRET) From PWSLIB
#If dim([L]WOPENUMCLE)<0 Local Integer  WOPENUMCLE       : Endif
## Issue 93977 GA 11/2013 déplacé dans CAL_WOPENUMCLE
#Local Integer WVCRSEQ : WVCRSEQ=100*[M:PSTT]OPENUM+[M:PSTT]OPESPLNUM
#Gosub CAL_WOPENUMCLE From SUBPTHC
#Call EFFACE_LIGD_PWS("PTH",10,[M:PSTT]MFGNUM,[M:PSTT]MFGLIN(NOL),WOPENUMCLE,WRET) From PWSLIB
Call EFFACE_LIGD_PWS("PTH",10,[M:PSTT]MFGNUM,[M:PSTT]MFGLIN(NOL),[M:PTH1]WSTOSEQ([M:PSTT]ORINOL),WRET) From PWSLIB
Gosub CHARG_PWS_STT      : # From SUBPTHC
Return

$CHARG_PWS_STT
#-----------------------------------------#
# Chargement du ficher des sous-traitance #
#-----------------------------------------#
If GMODU(8)<>2 : Return : Endif : # Module GP inactif
IMFI=nolign-1
[F:PWS]VCRTYP   =10                   : # GA 04/2006
[F:PWS]VCRNUM   =[M:PSTT]MFGNUM
[F:PWS]VCRLIN   =[M:PSTT]MFGLIN(IMFI)    # FQ 75839 GA 08/2011 avant OPENUM    # FQ 67334 GA 09/2010 avant MFGLIN

# Issue 95496 - 2014-03-17 by CCC : WOF : [F:PWS]VCRSEQ = [M:PTH1]WSTOSEQ
## Issue 81433 GA 06/2012 il faut OPENUM et OPESPLNUM dans [F:PWS]
##[F:PWS]VCRSEQ   =[M:PSTT]OPENUM         # FQ 75839 GA 08/2011 avant OPESPLNUM # FQ 68123 GA 10/2010 avant 0 # FQ 67334 GA 09/2010 avant OPENUM
#If dim([L]WOPENUMCLE)<0 Local Integer  WOPENUMCLE       : Endif
## Issue 93977 GA 11/2013 déplacé dans CAL_WOPENUMCLE
#Local Integer WVCRSEQ : WVCRSEQ=100*[M:PSTT]OPENUM+[M:PSTT]OPESPLNUM
#Gosub CAL_WOPENUMCLE From SUBPTHC
#[F:PWS]VCRSEQ   = WOPENUMCLE
[F:PWS]VCRSEQ   = [M:PTH1]WSTOSEQ([M:PSTT]ORINOL)
[F:PWS]WSTOSEQ  =[M:PSTT]WSTOSEQ(IMFI)
[F:PWS]WLOCSEQ  =[M:PSTT]WLOCSEQ(IMFI)
[F:PWS]MVTDES   =[M:PSTT]MVTDES(IMFI)
[F:PWS]TRSTYP   =5                    : # GA 04/2006
[F:PWS]TRSCOD   =[M:PSTT]TRSCOD         # GA 10/2010 à vérifier ...
[F:PWS]TRSFAM   =[M:PSTT]TRSFAM(IMFI)
[F:PWS]UOM      =[M:PSTT]UOM(IMFI)
[F:PWS]QTYUOM   =[M:PSTT]QTYUOM(IMFI)
[F:PWS]STU      =[M:PSTT]STU(IMFI)
[F:PWS]QTYSTU   =[M:PSTT]QTYSTU(IMFI)
[F:PWS]UOMSTUCOE=[M:PSTT]UOMSTUCOE(IMFI)
[F:PWS]RRRQTYSTU=[M:PSTT]RRRQTYSTU(IMFI)
[F:PWS]QQQQTYSTU=[M:PSTT]QQQQTYSTU(IMFI)
[F:PWS]MAXQTYRCP=[M:PSTT]MAXQTYRCP(IMFI)
If dim([F:PWS]ITMREF)>0 [F:PWS]ITMREF=[M:PSTT]ITMREF(IMFI) Endif # Issue 93349 GA 10/2013
If [M:PSTT]QTYUOM(IMFI)=0
  [F:PWS]WSTOFLG=2
Else
  [F:PWS]WSTOFLG  =[M:PSTT]WSTOFLG(IMFI)
Endif
Call WRITE_PWS("PTH") From PWSLIB
Return

$ENR_PWS_SCMH
If dim(WRET)<0    : Local Integer WRET       : Endif
#Call EFFACE_LIGD_PWS("PTH",36,[M:PSCM]SCONUM,[M:PSCM]SCILIN,0,WRET) From PWSLIB # Issue 90806 GA 06/2013
Local   Integer  WSCICLE
# Issue 95496 & 97173 - 2014-02-26 by CCC : use of WSTOSEQ to link [M:PTH1] & [F:PWS] instead of line number in [M:PTH1]
#WSCICLE=[M:PSCM]ORINOL+[M:PSCM]SCILIN                 # Issue 90806 GA 08/2013 avant 10*ORINOL ?
WSCICLE = [M:PTH1]WSTOSEQ([M:PSCM]ORINOL)+[M:PSCM]SCILIN
Call EFFACE_LIGD_PWS("PTH",36,[M:PSCM]SCONUM,WSCICLE,0,WRET) From PWSLIB
Gosub CHARG_PWS_SCMH : # From SUBPTHC
Return

$CHARG_PWS_SCMH
#-----------------------------------------#
# Chargement du ficher des sous-traitance #
#-----------------------------------------#
[F:PWS]VCRTYP   =36                   : # GA 04/2006
[F:PWS]VCRNUM   =[M:PSCM]SCONUM
Local Integer IPTD : IPTD=[M:PSCM]ORINOL
Local   Integer  WSCICLE
# Issue 95496 & 97173 - 2014-02-26 by CCC : use of WSTOSEQ to link [M:PTH1] & [F:PWS] instead of line number in [M:PTH1]
#WSCICLE=[M:PSCM]ORINOL+[M:PSCM]SCILIN              # Issue 90806 GA 08/2013
WSCICLE = [M:PTH1]WSTOSEQ([M:PSCM]ORINOL)+[M:PSCM]SCILIN
[F:PWS]VCRLIN   =WSCICLE                                                      # Issue 90806 avant [M:PSCM]SCILIN
[F:PWS]VCRSEQ   =0
[F:PWS]WSTOSEQ  =[M:PTH1]WSTOSEQ  (IPTD)
[F:PWS]WLOCSEQ  =[M:PTH1]WLOCSEQ  (IPTD)
[F:PWS]MVTDES   =[M:PTH1]MVTDES   (IPTD)
[F:PWS]TRSTYP   =3                    : # GA 04/2006 3=Réception Fournisseur
[F:PWS]TRSCOD   =[M:PTH0]TRSCOD
[F:PWS]TRSFAM   =[M:PTH1]TRSFAM   (IPTD)
[F:PWS]UOM      =[M:PTH1]UOM      (IPTD)
[F:PWS]QTYUOM   =[M:PTH1]QTYUOM   (IPTD)
[F:PWS]STU      =[M:PTH1]STU      (IPTD)
[F:PWS]QTYSTU   =[M:PTH1]QTYSTU   (IPTD)
[F:PWS]UOMSTUCOE=[M:PTH1]UOMSTUCOE(IPTD)
[F:PWS]RRRQTYSTU=[M:PTH1]RRRQTYSTU(IPTD)
[F:PWS]QQQQTYSTU=0                  : #[M:PTH1]QQQQTYSTU(IPTD) ????
[F:PWS]MAXQTYRCP=[M:PTH1]MAXQTYRCP(IPTD)
If dim([F:PWS]ITMREF)>0 [F:PWS]ITMREF=[M:PTH1]ITMREF(IPTD) Endif # Issue 93349 GA 10/2013
If [M:PTH1]QTYUOM(IPTD)=0
  [F:PWS]WSTOFLG  =2
Else
  [F:PWS]WSTOFLG  =[M:PTH1]WSTOFLG(IPTD)  # FQ 55088 avant (NOL)
Endif
Call WRITE_PWS("PTH") From PWSLIB
Return


$ENR_PWS_SCMD
If dim(WRET)<0 : Local Integer WRET       : Endif
#Call  EFFACE_LIGD_PWS("PTH",36,[M:PSCM]SCONUM,[M:PSCM]SCILIN,[M:PSCM]SCMLIN(ORINOL),WRET) From PWSLIB # Issue 90806 GA 06/2013
Local   Integer  WSCICLE
# Issue 95496 & 97173 - 2014-02-26 by CCC : use of WSTOSEQ to link [M:PTH1] & [F:PWS] instead of line number in [M:PTH1]
#WSCICLE=[M:PSCM]ORINOL+[M:PSCM]SCILIN                                       # Issue 90806 GA 08/2013
WSCICLE = [M:PTH1]WSTOSEQ([M:PSCM]ORINOL)+[M:PSCM]SCILIN
Call  EFFACE_LIGD_PWS("PTH",36,[M:PSCM]SCONUM,WSCICLE,[M:PSCM]SCMLIN(nolign-1),WRET) From PWSLIB
If [M:PSCM]USEQTY(nolign-1)=0  # Issue 97904 GA 12/2014 null qty, no issue
    Call DELSTOSORW(nolign-1,nolign-1,"PSCM",[M:PSCM]STOFCY(nolign-1),WRET) From STKSOR
Endif
Gosub CHARG_PWS_SCM     : # From SUBPTHC
Return

$CHARG_PWS_SCM
#-----------------------------------------#
# Chargement du ficher des sous-traitance #
#-----------------------------------------#
Local Integer IMAT : IMAT=nolign-1
[F:PWS]VCRTYP   =36                   : # GA 04/2006
[F:PWS]VCRNUM   =[M:PSCM]SCONUM
Local   Integer  WSCICLE
# Issue 95496 & 97173 - 2014-02-26 by CCC : use of WSTOSEQ to link [M:PTH1] & [F:PWS] instead of line number in [M:PTH1]
#WSCICLE=[M:PSCM]ORINOL+[M:PSCM]SCILIN                                       # Issue 90806 GA 08/2013
WSCICLE = [M:PTH1]WSTOSEQ([M:PSCM]ORINOL)+[M:PSCM]SCILIN
[F:PWS]VCRLIN   =WSCICLE                # Issue 90806 avant [M:PSCM]SCILIN
[F:PWS]VCRSEQ   =[M:PSCM]SCMLIN (IMAT)
[F:PWS]WSTOSEQ  =[M:PSCM]WSTOSEQ(IMAT)
[F:PWS]WLOCSEQ  =[M:PSCM]WLOCSEQ(IMAT)
[F:PWS]MVTDES   =[M:PSCM]MVTDES (IMAT)
[F:PWS]TRSTYP   =29                     # [M:PSCM]TRSTYP       : # Menu 704 29=Sortie sous-traitance
[F:PWS]TRSCOD   =[M:PSCM]TRSCODS
[F:PWS]TRSFAM   =[M:PSCM]TRSFAMS(IMAT)
[F:PWS]UOM      =[M:PSCM]STU    (IMAT)
[F:PWS]QTYUOM   =[M:PSCM]USEQTY (IMAT)
[F:PWS]STU      =[M:PSCM]STU    (IMAT)
[F:PWS]QTYSTU   =[M:PSCM]USEQTY (IMAT)
If dim([F:PWS]RETQTY)>0  # Issue 97904 GA 12/2014 + 2 cols RETQTY and CLEFLG
   [F:PWS]RETQTY=[M:PSCM]RETQTY (IMAT)
   [F:PWS]CLEFLG=[M:PSCM]CLEFLG (IMAT)
Endif
[F:PWS]UOMSTUCOE=1
[F:PWS]RRRQTYSTU=[M:PSCM]RRRQTYSTU(IMAT)
[F:PWS]QQQQTYSTU=[M:PSCM]QQQQTYSTU(IMAT)
[F:PWS]MAXQTYRCP=0
If dim([F:PWS]ITMREF)>0 [F:PWS]ITMREF=[M:PSCM]ITMREF(IMAT) Endif # Issue 93349 GA 10/2013
If [M:PSCM]USEQTY(IMAT)=0
  [F:PWS]WSTOFLG=2
Else
  [F:PWS]WSTOFLG=[M:PSCM]WSTOFLG(IMAT)
Endif
Call WRITE_PWS("PTH") From PWSLIB
Return




#-------------------------------------------#
# Appelé par CRELIG de et SUPLIG de SUBPTHA
#-------------------------------------------#
$MAJ_SOUS_TRAIT
## GH 27/03/2013 bug 88124
#If dim(NOL)<0    :  Local Integer  NOL     : NOL=nolign-1 : Endif
If dim([L]SVGLIG)<0 :  Local Integer SVGLIG  : Endif
[L]SVGLIG=nolign
If dim([L]SVGNOL)<0 :  Local Integer  SVGNOL  : Endif
If dim([L]NOL)=1 : SVGNOL=NOL : Else SVGNOL=-1 : Endif : # SVGNOL=NOL

If [F:PTD]VCRTYPORI = 36
# Ordre de sous-traitance
# -----------------------
  Gosub MAJ_SOUS_TRAIT_EO
Elsif GMODU(8) = 2 & [F:PTD]VCRTYPORI = 10 : # ssi GP présente
# Ordre de fabrication
# -----------------------
  Gosub MAJ_SOUS_TRAIT_OF
Endif
# GA 24/06/2009
#If dim([F:STO1]STOCOU)>0 : Raz [F:STO1] : Endif

#----- Ctrl des locks en cas de sous-traitance -----#
Gosub UNLOCK_SCO From SUBPTHC # Issue 89758 GA 12/2013 unlock WO or EO

If GOK=0 : mkstat=1 : Endif

#----- Repositionnement du contexte qui est cassé par MTKLIB -----#
## GH 27/03/2013 bug 88124
# NOL=SVGNOL : nolign=NOL+1
If SVGNOL<>-1 : NOL=SVGNOL : Endif
nolign=SVGLIG

Gosub DEFLIG       From SUBPTHA
Gosub LECT_FICLIG  From SUBPTHA
Return

##################################################################################
$MAJ_SOUS_TRAIT_OF

#----- Variables locales -----#
Local   Integer  WRETOUR
Raz WRETOUR
# FQ 55135 GA 05/2009 maj à faire seulement sur le service
If !find([F:PTD]LINTYP,1,3) Return Endif

#-------------------------------------------------------#
# Mise à jour concernant les articles de sous-traitance #
# pour les commandes issues d'un ordre de fabrication   #
#-------------------------------------------------------#
If SIGN=-1
  #----- Si annulation ligne de réception -----#
  Call DEL_SUIV (WRETOUR) From MTKLIB
Else
  #----- Si création ligne de réception -----#
  Call MAJ_MTK ([M:PTH1]WSTOSEQ(nolign-1),WRETOUR)  From MTKLIB
Endif
If WRETOUR<>0 : GOK=0
# FQ 63365 GA 03/2010 forcer l'affichage de la trace en cas d'erreur
# les erreurs sur les fonctions de stock (STKINT) sont uniquement visibles dans la trace :-(
  If GPURTRACE=1 : GPURTRACE=2  : Endif
Endif
#-----
Gosub READ_PTRNUM
Return

##################################################################################
# la ligne de réception [F:PTD] est renseigné
$MAJ_SOUS_TRAIT_EO

#----- Variables locales -----#
Local Integer WRETOUR : Raz WRETOUR
Local Char    WSCONUM(GLONVCR) : WSCONUM = [F:PTD]VCRNUMORI
Local Integer WSCILIN          : WSCILIN = [F:PTD]VCRLINORI
Local Char    WPTHNUM(GLONVCR) : WPTHNUM = [F:PTD]PTHNUM
Local Integer WPTDLIN          : WPTDLIN = [F:PTD]PTDLIN
Raz WRETOUR
# Issue 111647 - 2015-10-12 by MUARN : gestion déphasage PTD SCK
# GA 22/01/2009 maj à faire seulement sur l'article lancé
#If [F:PTD]LINTYP>=3 Return Endif
If [F:PTD]LINTYP>=3
  # gestion du service
  If [F:PTD]LINTYP = 3 & [M:PTH1]PTDLIN(nolign-1) <> [F:PTD]PTDLIN & [M:PTH1]CREFLG(nolign-1)=0 & GREP <> 'A'
    For [F:SCK] Where PTHNUM=[F:PTD]PTHNUM & PTDLIN=[M:PTH1]PTDLIN(nolign-1) & LINTYP=3
&                     & SCONUM=[F:PTD]VCRNUMORI
      [F:SCK]PTDLIN=[F:PTD]PTDLIN
      Rewrite [F:SCK]
      Break
    Next
  #gestion des matières fournies par sous-traitant
  Elsif [F:PTD]LINTYP = 4 & [M:PTH1]PTDLIN(nolign-1) <> [F:PTD]PTDLIN & [M:PTH1]CREFLG(nolign-1)=0 & GREP <> 'A'
    For [F:SCK] Where PTHNUM=[F:PTD]PTHNUM & PTDLIN=[M:PTH1]PTDLIN(nolign-1) & LINTYP=4 & ITMREF=[F:PTD]ITMREF
&                         & SCONUM=[F:PTD]VCRNUMORI
      [F:SCK]PTDLIN=[F:PTD]PTDLIN
      Rewrite [F:SCK]
      Break
    Next
  Endif
  Return
Endif

#-------------------------------------------------------#
# Mise à jour concernant les articles sous-traités      #
# pour les commandes issues d'un ordre de sous-traitance#
#-------------------------------------------------------#
If SIGN=-1
  #----- Si annulation ligne de réception -----#
  Call ANNULE_MAJ_STK(WPTHNUM,WPTDLIN,WSCONUM,WSCILIN,WRETOUR) From SCOSTKLIB
Else
  #----- Si création ligne de réception -----#
  Call MAJ_STK(WPTHNUM,WPTDLIN,WSCONUM,WSCILIN,WRETOUR)  From SCOSTKLIB
Endif
# FQ 79191 GA 01/2012 renvoyer toujours GOK en cas d'erreur
If WRETOUR<>0 : GOK=0
# FQ 63365 GA 03/2010 forcer l'affichage de la trace en cas d'erreur (ssi trace ouverte)
# les erreurs sur les fonctions de stock (STKINT) sont uniquement visibles dans la trace :-(
  If GPURTRACE=1 : GPURTRACE=2  : Endif
Endif
# Issue 94558 GA 11/2013
Gosub READ_PTRNUM
Return



##################################################################################
$MAJ_OPESTT
#---------------------------------------------#
# ==> Mise à jour opération de sous-traitance #
#---------------------------------------------#
Raz [M:SBCK]     # Issue 105321 GA 03/2015

# Issue 90024 GA 05/2013 appel de MAJ_SBC dans le cas d'un solde de commande par exemple
# Ordre de sous-traitance: la maj est déjà faite par MAJ_SOUS_TRAIT
# On conserve ce traitement uniquement pour le cas GPAO mais probablement aussi redondant
#If [F:POQ]VCRTYPORI=36 Return Endif

[M:SBCK]MAJCOD = "T"            : # Maj de la commande de sous-traitance
[M:SBCK]VCRNUM = [F:POQ]POHNUM  : # Réf commande
[M:SBCK]VCRLIN = [F:POQ]POPLIN
[M:SBCK]VCRSEQ = [F:POQ]POQSEQ
If dim([M:SBCK]LINTYP)>0 [M:SBCK]LINTYP = [F:POQ]LINTYP Endif  # FQ 76147 GA 09/2011
[M:SBCK]BPSNUM = [F:POH]BPSNUM            # 06.07 40364
# Issue 109088 - 2015-11-13 by BEEBE : BPAADD may not be initialized for partial received subcontracting operations [MFO]
[M:SBCK]BPAADD = [F:POH]BPAADD

[M:SBCK]VCRTYPORI = [F:POQ]VCRTYPORI
[M:SBCK]VCRNUMORI = [F:POQ]VCRNUMORI
[M:SBCK]VCRLINORI = [F:POQ]VCRLINORI
[M:SBCK]VCRSEQORI = [F:POQ]VCRSEQORI

# Mise a jour qté commandée
# -------------------------
If [F:POQ]LINCLEFLG<>2         : # si ligne cde non soldée, qté commandée = qté initiale
   [M:SBCK]ORDQTY=[F:POQ]QTYSTU
Elsif [F:POQ]RCPQTYSTU<>0      : # si ligne cde soldée, qté commandée = qté réceptionnée
   [M:SBCK]ORDQTY=[F:POQ]RCPQTYSTU
Else
   [M:SBCK]ORDQTY=0 : [M:SBCK]MAJCOD = "A"
Endif

# NB: Mise a jour qté réceptionnée
# cf MAJ_SOUS_TRAIT car maj de [F:SCI]+[F:SCS]

[M:SBCK]ORDDAT = [F:POQ]EXTRCPDAT-[F:POQ]OFS
[M:SBCK]RCPDAT = [F:POQ]EXTRCPDAT
Call CONVERT2([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&             [F:POQ]LINAMT,[M:SBCK]EXTPRI,WRETOUR) From TRTDEV
[M:SBCK]EXTPRI = arr([M:SBCK]EXTPRI/[F:POQ]QTYSTU,10^-GDECPRI)
[M:SBCK]OFS    = [F:POQ]OFS
[M:SBCK]MSGFLG = 1
[M:SBCK]CLEFLG = [F:POQ]LINCLEFLG

#-- Le maj_sbc peut solder l'opé, mais on ne solde pas la commande !
Call MAJ_SBC From SBCLIB
If [M:SBCK]CODRET<>0
  If [F:POQ]VCRTYPORI=10
     GMESSAGE=mess(96,193,1) : GERR=1 : GOK=0 : Return
  Elsif [F:POQ]VCRTYPORI=36
     GMESSAGE=mess(913,196,1) : GERR=1 : GOK=0 : Return
  Endif
Endif
Return

##################################################################################
$CTRL_ALLOCATIONS
  # FQ 54106 GA 09/04/2009 pas de ctrl ici pour autoriser une rcp partielle
  If find([F:POQ]VCRTYPORI,10,36) Return Endif
  #----- Contrôle matière bloquante si rupture -----#
  If GMODU(8)=2 & [F:POQ]VCRTYPORI=10             : # Cas d'un ordre de fabrication
    If !clalev([F:MFG])  Local File MFGHEAD  [MFG] : Endif
    Read [F:MFG]MFG0=[F:POQ]VCRNUMORI
    If fstat | !(func MFGLIB.CTRL_ALLMGT)
       GERR=1 : mkstat=2 : Return
    Endif
  Endif
  If [F:POQ]VCRTYPORI=36                          : # Cas d'un ordre de sous-traitance
    If !clalev([F:SCO])  Local File SCOHEAD  [SCO] : Endif
    Read [F:SCO]SCO0=[F:POQ]VCRNUMORI
    If fstat | !(func SCOLIB.CTRL_ALLMGT)
       GERR=1 : mkstat=2 : Return
    Endif
  Endif
  #-----
Return

##################################################################################
#----- Issue 89758 GA 12/2013 unlock WO or EO -----#
$UNLOCK_SCO
If find([F:POQ]VCRTYPORI,10,36)
  Case [F:POQ]VCRTYPORI
     When 10 : Unlock="MFG"+[F:POQ]VCRNUMORI
     When 36 : Unlock="SCO"+[F:POQ]VCRNUMORI
  Endcase
Elsif find([F:PTD]VCRTYPORI,10,36)
  Case [F:PTD]VCRTYPORI
     When 10 : Unlock="MFG"+[F:PTD]VCRNUMORI
     When 36 : Unlock="SCO"+[F:PTD]VCRNUMORI
  Endcase
Endif
Return

#########################################################################
# Issue 95496 & 97173 - 2014-02-26 by CCC
#**----------------------------------------------------------------<br/>
#* DEPICK_SCO : Unpicking a subcontract purchase order
#**<br/>----------------------------------------------------------------<br/>
#* @param POHNUM = Purchase order number
#* @param POPLIN = Purchase order line number
#* @param LRET   = Error code (0=OK ; >0=Error)
#**<br/>----------------------------------------------------------------
#*!
Subprog DEPICKE_SCO(PTYP, PNUM, PLIN, LRET)
Value Integer PTYP
Value Char PNUM
Value Integer PLIN
Variable Integer LRET

Local Integer NOL, K
Raz NOL, K
Case PTYP
    When 4 : # Delivery
             NOL = sigma(0,[M:PTH1]NBLIG-1,(indcum+1)*( [M:PTH1]POHNUM(indcum)=PNUM
&                                                     & [M:PTH1]POPLIN(WPOQ)  =PLIN
&                                                     & [M:PTH1]LINTYP(WPOQ)  =2
&                                                     & [M:PTH1]CREFLG(WPOQ)  =0
&                                                     & K=0 & sigma(K=1,-1,-1))
&                  )
    When 14 : #Purchase order
              NOL = sigma(0,[M:PTH1]NBLIG-1,(indcum+1)*( [M:PTH1]SDHNUM(indcum)=PNUM
&                                                      & [M:PTH1]SDDLIN(WPOQ)  =PLIN
&                                                      & [M:PTH1]LINTYP(WPOQ)  =2
&                                                      & [M:PTH1]CREFLG(WPOQ)  =0
&                                                      & K=0 & sigma(K=1,-1,-1))
&                  )
Endcase
If NOL>0
    Call EFFAC_LIG(NOL-1, LRET)
Endif
End

#########################################################################
# Chargement des paramètres dans masque STOENT pour saisie des entrées  #
# Cette étiquette est appelée depuis CHARG_PARAM_STOENT From TRTSTOENTA #
# quand VCRTYP = 15 Déclaration de production                           #
#########################################################################
Subprog CHARG_PARAM_STOENT(LLIG)
Value    Integer  LLIG
Local    Shortint K
#-- sous-traitance depuis un OF
If clalev([M:PSTT])>0 & [M:PSTT]MFGNUM<>""
  K=[M:PSTT]ORINOL
  [M:ENT]TRSTYP    = 5                      : # Menu 704: 5=Entrée OF
  [M:ENT]TRSCOD    = [M:PSTT]TRSCOD         : # code mouvement
  [M:ENT]STU       = [M:PSTT]STU(LLIG)
  [M:ENT]VCRNUM    = [M:PTH0]PTHNUM
  [M:ENT]VCRLIN    = [M:PTH1]PTDLIN(K)
  [M:ENT]STOFCY    = [M:PSTT]STOFCY
  [M:ENT]ITMREF    = [M:PSTT]ITMREF(LLIG)
  [M:ENT]QTYTOENT  = [M:PSTT]QTYUOM(LLIG)
  [M:ENT]PCUTOENT  = [M:PSTT]UOM(LLIG)
  [M:ENT]COETOENT  = [M:PSTT]UOMSTUCOE(LLIG)
  [M:ENT]WSTOSEQ   = [M:PSTT]WSTOSEQ(LLIG)
  [M:ENT]MVTDES    = [M:PSTT]MVTDES(LLIG)
  [M:ENT]TRSFAM    = [M:PSTT]TRSFAM(LLIG)
  [M:ENT]PRI       = [M:PTH1]CPR(K)
  [M:ENT]VCRTYPORI = 10
  [M:ENT]VCRNUMORI = [M:PSTT]MFGNUM
  [M:ENT]VCRLINORI = [M:PSTT]MFGLIN(LLIG)
  [M:ENT]VCRSEQORI = 0                        # FQ 79305 avant [M:PSTT]OPENUM
  [M:ENT]IPTDAT    = [M:PSTT]IPTDAT         : # Date imputation
  [M:ENT]QUAFLG    = [M:PSTT]QUAFLG(LLIG)   : # Code contrôle qualité (2=Q uniquement)
  [M:ENT]QUAFRE    = [M:PSTT]QUAFRE(LLIG)   : # hcb V6CQ
  [M:ENT]BPRNUM    = [M:PSTT]BPRNUM         : # Numéro de fournisseur
  [M:ENT]CUR       = [M:PTH1]NETCUR(K)      : # Devise
  Read [F:MFI]MFI0 = [M:PSTT]MFGNUM;[M:PSTT]MFGLIN(LLIG)
  If fstat : Raz [F:MFI] : Endif
  If [F:MFI]LOT <> "" : GSAIFLG = "000000020000000" : Endif
Endif
End

# Issue 94558 GA 11/2013
$READ_PTRNUM
#If !GIMPORT #----- Ne pas relire la transaction si import -----#
  If [F:PTR]PTRTYP<>6 | [F:PTR]PTRNUM<>GPTRNUM  : # Relecture transaction si nécessaire
    Read [PTR] PTR0=6;GPTRNUM : If fstat  Raz [F:PTR] : Endif
  Endif
#Endif
Return

