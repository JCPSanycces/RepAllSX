## FECHA INICIAL "1999-03-10T18:38:17Z"

$ACTION

 #   Char MOT1(30)
 #   adxifs = ':' : adxirs =  chr$(13) + chr$(10)
 #   Openo filpath('TRA','XEXPV10','txt') Using [FIC1]

 #   MOT1 = ACTION
 #   Wrseq MOT1 Using [FIC1]
 #   Wrseq date$  Using [FIC1]
 #   Wrseq time$  Using [FIC1]
   

Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "DEBUT"      : Gosub DEBUT
  When "OK"         : Gosub OK
  When "EXEC"       : Gosub EXEC
  When "AVANT_PAR"  : Gosub AVANT_PAR
  When "TERMINE"    : Gosub TERMINE
  When Default
Endcase

  #   Openo using [FIC1]

Return

$TERMINE
#  Openo using [FIC1]
Return

$OUVRE
If clalev([F:YADI])  = 0  : Local File ATABDIV [YADI]      : Endif
If clalev([F:YITM])  = 0  : Local File XV10ITM [YITM]      : Endif
If clalev([F:YSOH])  = 0  : Local File XV10SORDERTO [YSOH]      : Endif
If clalev([F:YSOP])  = 0  : Local File XV10SORDERLT [YSOP]      : Endif
If clalev([F:YPOH])  = 0  : Local File XV10PORDER [YPOH]      : Endif
If clalev([F:YPOP])  = 0  : Local File XV10PORDERL [YPOP]      : Endif
If clalev([F:YSTA])  = 0  : Local File XV10ESTADOS [YSTA]      : Endif
If clalev([F:ZSI6])  = 0  : Local File ZSORDERIP6 [ZSI6]      : Endif

Return

######################################################################################

$DEBUT
Local Char MES (2), DIA(2)
Raz [M:DIA]

[M:DIA]YSEP = ";"
# Leer la fecha/hora de captura última
Read [F:YADI]CODE=6001;'01'
If !fstat
    [M:DIA]YFECITM = [F:YADI]A2
Else
    MES = num$(month(date$))
    If len(MES) = 1 : MES = "0" + MES : Endif
    DIA = num$(day(date$))
    If len(DIA) = 1 : DIA= "0" + DIA : Endif
    [M]YFECITM = "" + num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
Endif

Read [F:YADI]CODE=6001;'02'
If !fstat
    [M:DIA]YFECSOH = [F:YADI]A2
Else
    MES = num$(month(date$))
    If len(MES) = 1 : MES = "0" + MES : Endif
    DIA = num$(day(date$))
    If len(DIA) = 1 : DIA= "0" + DIA : Endif
    [M:DIA]YFECSOH = "" + num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
Endif

Read [F:YADI]CODE=6001;'03'
If !fstat
    [M:DIA]YFECPOH = [F:YADI]A2
Else
    MES = num$(month(date$))
    If len(MES) = 1 : MES = "0" + MES : Endif
    DIA = num$(day(date$))
    If len(DIA) = 1 : DIA= "0" + DIA : Endif
    [M:DIA]YFECPOH = num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
Endif

Read [F:YADI]CODE=6001;'04'
If !fstat
    [M:DIA]YFECSTA = [F:YADI]A2
Else
    MES = num$(month(date$))
    If len(MES) = 1 : MES = "0" + MES : Endif
    DIA = num$(day(date$))
    If len(DIA) = 1 : DIA= "0" + DIA : Endif
    [M:DIA]YFECSTA = num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
Endif
Affzo [M:DIA]1-99

  ##  If !Clalev([M:DIA]) then 
  
  ##      MOT1 = "EN INTERACTIVO NO SE LLAMA ASÍ LA MASK"
  ##      Wrseq MOT1 Using [FIC1]
  ##  ELSE 
  ##      MOT1 = "EN INTERACTIVO SE LLAMA ASÍ LA MASK"
  ##      Wrseq MOT1 Using [FIC1]
  ##      Wrseq [M:DIA]YFECSTA Using [FIC1]
  ##  Endif


Return

######################################################################################

$AVANT_PAR
  
    If !Clalev([M:DIA]) then 
         Local Mask XEXPV10 [DIA] 
    Endif

Return

$EXEC


  If GSERVEUR Then
  ##  MOT1 = "GOSUB OUVRE"
  ##  Wrseq MOT1 Using [FIC1]

    Gosub OUVRE
  ##  MOT1 = "GOSUB DEBUT"
  ##  Wrseq MOT1 Using [FIC1]

    Gosub DEBUT
  ##  MOT1 = "GOSUB OK"
  ##  Wrseq MOT1 Using [FIC1]
    Gosub OK
  Endif
Return

$OK

Local Char     YCRITERE(255), MES (2), DIA(2)
Local Integer YSTAT, WCONT

If !GSERVEUR then
    Call OUINON("żDesea continuar?",[L]YSTAT) From GESECRAN
Else 
   [L]YSTAT=2
   [M:DIA]YITM = 2
   [M:DIA]YSOH = 2
   [M:DIA]YPOH = 2
   [M:DIA]YSTA = 2
Endif

If [L]YSTAT=2
    Call OUVRE_TRACE('') From LECFIC
    if GSERVEUR then
       Call ECR_TRACE('Exportación V10 en Batch:',0) From GESECRAN
    else 
       Call ECR_TRACE('Exportación V10 en línea:',0) From GESECRAN
    endif

    # Marcar la nueva fecha-hora de ejecucion
    MES = num$(month(date$))
    If len(MES) = 1 : MES = "0" + MES : Endif
    DIA = num$(day(date$))
    If len(DIA) = 1 : DIA= "0" + DIA : Endif

    If [M:DIA]YITM = 2
      Gosub EXP_ITM
 #     Readlock [F:YADI]CODE=6001;'01'
 #     If !fstat
 #         [F:YADI]A2 = num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
 #         Rewrite [F:YADI]
 #     Endif
    Endif
    If [M:DIA]YSOH = 2
      Gosub EXP_SOH
      Gosub EXP_SOP
 #     Readlock [F:YADI]CODE=6001;'02'
 #     If !fstat
 #         [F:YADI]A2 = num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
 #         Rewrite [F:YADI]
 #     Endif
    Endif
    If [M:DIA]YPOH = 2
      Gosub EXP_POH
      Gosub EXP_POP
  #    Readlock [F:YADI]CODE=6001;'03'
  #    If !fstat
  #        [F:YADI]A2 = num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
  #        Rewrite [F:YADI]
  #    Endif
    Endif
    If [M:DIA]YSTA = 2
      Gosub EXP_STA
  #    Readlock [F:YADI]CODE=6001;'04'
  #    If !fstat
  #        [F:YADI]A2 = num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
  #        Rewrite [F:YADI]
  #    Endif
    Endif

    Call FERME_TRACE From LECFIC

    If !GSERVEUR
        Call LEC_TRACE From LECFIC
        Call MESSAGE ("Exportación finalizada correctamente") From GESECRAN
    Endif

Endif
    

Return

######################################################################################

$EXP_ITM

    #-- variables diversas
    Local Char FICHERO(GDIMFIC), NOM_FICH(50), EXT(3)

    #-- variables de fichero, inicializacion

    EXT    = "txt"                   #-- extension del fichero

    NOM_FICH = "ARTICULOS" + "_" + format$("D:YYMMDDhhmmss",date$)

    FICHERO      = filpath("impexp\V10TOTAL",NOM_FICH,EXT,"","","")

    Openo FICHERO,0 Using [YFIC]
    Iomode adxifs [M:DIA]YSEP Using [YFIC]                  # SEPARACION DE CAMPOS ";"
    Iomode adxirs chr$(13)+chr$(10) Using [YFIC]    # FIN DE LINEA
    Iomode adxium 50 Using [YFIC]

    # Selección de los registros
    #YCRITERE = "UPDDATTIM >= gdatetime$([M:DIA]YFECITM)"  NO NECESARIO PORQUE LO TIENE LA VISTA
    Raz WCONT
    # Recorro los articulos
    For [F:YITM] ## Where evalue(YCRITERE) NO NECESARIO PORQUE LO TIENE LA VISTA

            Wrseq "C" ; Using [YFIC]
            Wrseq [F:YITM]CODART ; Using [YFIC]
            Wrseq [F:YITM]CODDIV ; Using [YFIC]
            Wrseq [F:YITM]CODARTDIV ; Using [YFIC]
            Wrseq [F:YITM]CODNAC ; Using [YFIC]
            Wrseq [F:YITM]DESARTC ; Using [YFIC]
            Wrseq [F:YITM]UNIDADESHOST ; Using [YFIC]
            Wrseq [F:YITM]SWTLOTE ; Using [YFIC]
            Wrseq [F:YITM]UNIDADVTA ; Using [YFIC]
            Wrseq [F:YITM]COEFUVUS ; Using [YFIC]
            Wrseq [F:YITM]CATEGART  Using [YFIC]
      #      Wrseq [F:YITM]TRETEST ; Using [YFIC]     #no exportar por indicación de Florentino
      #      Wrseq [F:YITM]UNITRTEST ; Using [YFIC]   #via email 14/03/16 16.34
      #      Wrseq [F:YITM]TCADUC ; Using [YFIC]
      #      Wrseq [F:YITM]UNICADUC Using [YFIC]
            WCONT += 1
            Call ECR_TRACE('Artículo procesado:' + [F:YITM]CODART,0) From GESECRAN
    Next
    Openo Using [YFIC]
    If WCONT = 0 : Call EFFACE(FICHERO, YSTAT) From ORDSYS : Endif
Return

######################################################################################

$EXP_SOH

    #-- variables diversas
    Local Char FICHERO(GDIMFIC), NOM_FICH(50), EXT(3)

    #-- variables de fichero, inicializacion

    EXT    = "txt"                   #-- extension del fichero
    # Selección de los registros
    #YCRITERE = "UPDDATTIM >= gdatetime$([M:DIA]YFECSOH)"  NO NECESARIO PORQUE LO TIENE LA VISTA
    Raz WCONT
    # Recorro las cabeceras de pedidos de venta
    For [F:YSOH] # Where evalue(YCRITERE)  NO NECESARIO PORQUE LO TIENE LA VISTA

        NOM_FICH = "PC" + [F:YSOH]CODPED

        FICHERO      = filpath("impexp\V10TOTAL",NOM_FICH,EXT,"","","")

        Openo FICHERO,0 Using [YFIC]
        Iomode adxifs [M:DIA]YSEP Using [YFIC]                  # SEPARACION DE CAMPOS ";"
        Iomode adxirs chr$(13)+chr$(10) Using [YFIC]    # FIN DE LINEA
        Iomode adxium 50 Using [YFIC] 

        Wrseq [F:YSOH]PLANVEN ; Using [YFIC]
        Wrseq [F:YSOH]CODDIV ; Using [YFIC]
        Wrseq [F:YSOH]ANOPED ; Using [YFIC]
        Wrseq [F:YSOH]CODPED ; Using [YFIC]
        Wrseq [F:YSOH]TIPOPEDIDO ; Using [YFIC]
        Wrseq [F:YSOH]NLINEAS ; Using [YFIC]
        Wrseq [F:YSOH]PEDIDOCLIENT ; Using [YFIC]
        Wrseq [F:YSOH]FECPEDIDOCLI ; Using [YFIC]
        Wrseq [F:YSOH]PEDIDOHOST ; Using [YFIC]
        Wrseq [F:YSOH]CODCLIENTE ; Using [YFIC]
        Wrseq [F:YSOH]DESCLIENTE ; Using [YFIC]
        Wrseq [F:YSOH]NIF ; Using [YFIC]
        Wrseq [F:YSOH]DIRECCION ; Using [YFIC]
        Wrseq [F:YSOH]DIRECCION1 ; Using [YFIC]
        Wrseq [F:YSOH]DIRECCION2 ; Using [YFIC]
        Wrseq [F:YSOH]DIRECCION3 ; Using [YFIC]
        Wrseq [F:YSOH]POBLACION ; Using [YFIC]
        Wrseq [F:YSOH]DP ; Using [YFIC]
        Wrseq [F:YSOH]CODPAIS ; Using [YFIC]
        Wrseq [F:YSOH]TELEFONO ; Using [YFIC]
        Wrseq [F:YSOH]FAX ; Using [YFIC]
        Wrseq [F:YSOH]EMAIL ; Using [YFIC]
        Wrseq [F:YSOH]MENHOST ; Using [YFIC]
        #Wrseq [F:YSOH]SWTANULAR ; Using [YFIC]
        #Wrseq [F:YSOH]SWTVALORADO ; Using [YFIC]
        #Wrseq [F:YSOH]SWTTOTALES ; Using [YFIC]
        Wrseq [F:YSOH]SWTPROFORMA ; Using [YFIC]
        #Wrseq [F:YSOH]SWTAGRUPAR ; Using [YFIC]
        #Wrseq [F:YSOH]SWTCOMUNICAR ; Using [YFIC]
        #Wrseq [F:YSOH]CODAREAEXPED ; Using [YFIC]
        Wrseq [F:YSOH]BACKORDER ; Using [YFIC]
        Wrseq [F:YSOH]MONEDA ; Using [YFIC]
        Wrseq [F:YSOH]DESCUENTO ; Using [YFIC]
        Wrseq [F:YSOH]RECARGO ; Using [YFIC]
        Wrseq [F:YSOH]CONDPAGO ; Using [YFIC]
        Wrseq [F:YSOH]URGENCIA ; Using [YFIC]
        Wrseq [F:YSOH]CODAGE ; Using [YFIC]
        #Wrseq [F:YSOH]CAMPOS ; Using [YFIC]
        Wrseq [F:YSOH]SWTFACTU ; Using [YFIC]
        Wrseq [F:YSOH]CODCLIFACTU; Using [YFIC]
        Wrseq [F:YSOH]DESCLIFACTU ; Using [YFIC]
        Wrseq [F:YSOH]NIFFACTU ; Using [YFIC]
        Wrseq [F:YSOH]DIRFACTU ; Using [YFIC]
        Wrseq [F:YSOH]DIRFACTU1 ; Using [YFIC]
        Wrseq [F:YSOH]DIRFACTU2 ; Using [YFIC]
        Wrseq [F:YSOH]DIRFACTU3 ; Using [YFIC]
        Wrseq [F:YSOH]POBFACTU ; Using [YFIC]
        Wrseq [F:YSOH]DPFACTU ; Using [YFIC]
        Wrseq [F:YSOH]CODPAISFACTU ; Using [YFIC]
        Wrseq [F:YSOH]TELFACTU ; Using [YFIC]
        Wrseq [F:YSOH]FAXFACTU ; Using [YFIC]
        Wrseq [F:YSOH]EMAILFACTU ; Using [YFIC]
        Wrseq [F:YSOH]IMPORTEPEDID ; Using [YFIC]
        Wrseq [F:YSOH]FECCAPTURA ; Using [YFIC]
        Wrseq [F:YSOH]FECSERVICIO Using [YFIC]
        WCONT += 1
        Call ECR_TRACE('Cabecera de ventas procesada:' + [F:YSOH]CODPED,0) From GESECRAN
        Openo Using [YFIC]
    Next
    If WCONT = 0 : Call EFFACE(FICHERO, YSTAT) From ORDSYS : Endif
Return

######################################################################################

$EXP_SOP

    #-- variables diversas
    Local Char FICHERO(GDIMFIC), NOM_FICH(50), EXT(3)
    Local Char PEDIDOANT(20) : PEDIDOANT=""

    #-- variables de fichero, inicializacion

    EXT    = "txt"                   #-- extension del fichero
    # Selección de los registros
    #YCRITERE = "UPDDATTIM >= gdatetime$([M:DIA]YFECSOH)"     NO NECESARIO PORQUE LO TIENE LA VISTA
    Raz WCONT
    # Recorro las líneas de pedidos de venta
    For [F:YSOP] #Where evalue(YCRITERE)                NO NECESARIO PORQUE LO TIENE LA VISTA

        If [F:YSOP]CODPED <> PEDIDOANT Then
             If PEDIDOANT<>"" Then 
                 Openo Using [YFIC]
             Endif
             NOM_FICH = "PL" + [F:YSOP]CODPED

             FICHERO      = filpath("impexp\V10TOTAL",NOM_FICH,EXT,"","","")

             Openo FICHERO,0 Using [YFIC]
             Iomode adxifs [M:DIA]YSEP Using [YFIC]                  # SEPARACION DE CAMPOS ";"
             Iomode adxirs chr$(13)+chr$(10) Using [YFIC]    # FIN DE LINEA
             Iomode adxium 50 Using [YFIC]
             PEDIDOANT = [F:YSOP]CODPED
        Endif

        Wrseq [F:YSOP]CODDIV ; Using [YFIC]
        Wrseq [F:YSOP]ANOPED ; Using [YFIC]
        Wrseq [F:YSOP]CODPED ; Using [YFIC]
        Wrseq [F:YSOP]SEQLINEA ; Using [YFIC]
        Wrseq [F:YSOP]CODART ; Using [YFIC]
        Wrseq [F:YSOP]CANTPEDIDA ; Using [YFIC]
        Wrseq [F:YSOP]UNIDADESHOST ; Using [YFIC]
        Wrseq [F:YSOP]BACKORDER ; Using [YFIC]
        Wrseq [F:YSOP]SWTPRECIO ; Using [YFIC]
        Wrseq [F:YSOP]PRECIOUNI ; Using [YFIC]
        Wrseq [F:YSOP]UNIDADESPREC ; Using [YFIC]
        Wrseq [F:YSOP]DCTO ; Using [YFIC]
        Wrseq [F:YSOP]IVA ; Using [YFIC]
        Wrseq [F:YSOP]RECARGO Using [YFIC]
        #Wrseq [F:YSOP]SWTCREAVERSION ; Using [YFIC]
        #Wrseq [F:YSOP]TIPOREDONDEO Using [YFIC]
        WCONT += 1
       
        Call ECR_TRACE('Línea de ventas procesada:' + [F:YSOP]CODPED - num$([F:YSOP]SEQLINEA),0) From GESECRAN
    Next
    If PEDIDOANT<>"" Then
      #ultima vez   
      Openo Using [YFIC]  
    Endif

    If WCONT = 0 : Call EFFACE(FICHERO, YSTAT) From ORDSYS : Endif
Return

######################################################################################

$EXP_POH

    #-- variables diversas
    Local Char FICHERO(GDIMFIC), NOM_FICH(50), EXT(3)

    #-- variables de fichero, inicializacion

    EXT    = "txt"                   #-- extension del fichero

    # Selección de los registros
    #YCRITERE = "UPDDATTIM >= gdatetime$([M:DIA]YFECPOH)"  NO NECESARIO PORQUE LO TIENE LA VISTA
    Raz WCONT
    # Recorro las cabeceras de pedidos de compra
    For [F:YPOH] # Where evalue(YCRITERE)          NO NECESARIO PORQUE LO TIENE LA VISTA

        NOM_FICH = "RC" + [F:YPOH]CODORDREC

        FICHERO      = filpath("impexp\V10TOTAL",NOM_FICH,EXT,"","","")

        Openo FICHERO,0 Using [YFIC]
        Iomode adxifs [M:DIA]YSEP Using [YFIC]                  # SEPARACION DE CAMPOS ";"
        Iomode adxirs chr$(13)+chr$(10) Using [YFIC]    # FIN DE LINEA
        Iomode adxium 50 Using [YFIC]

        Wrseq [F:YPOH]CODORDREC ; Using [YFIC]
        Wrseq [F:YPOH]CODDIV ; Using [YFIC]
        Wrseq [F:YPOH]TIPORDREC ; Using [YFIC]
        Wrseq [F:YPOH]CODPROVE ; Using [YFIC]
        Wrseq [F:YPOH]DESPROVE ; Using [YFIC]
        Wrseq [F:YPOH]FECORDREC Using [YFIC]
        WCONT += 1
        Openo Using [YFIC]
        Call ECR_TRACE('Cabecera de compras procesada:' + [F:YPOH]CODORDREC,0) From GESECRAN
    Next

    If WCONT = 0 : Call EFFACE(FICHERO, YSTAT) From ORDSYS : Endif
Return

######################################################################################

$EXP_POP

    #-- variables diversas
    Local Char FICHERO(GDIMFIC), NOM_FICH(50), EXT(3)
    Local Char PEDIDOANT(20) : PEDIDOANT=""

    #-- variables de fichero, inicializacion

    EXT    = "txt"                   #-- extension del fichero

    # Selección de los registros
    #YCRITERE = "UPDDATTIM >= gdatetime$([M:DIA]YFECPOH)"        NO NECESARIO PORQUE LO TIENE LA VISTA
    Raz WCONT
    # Recorro las líneas de pedidos de compra
    For [F:YPOP] # Where evalue(YCRITERE)                    NO NECESARIO PORQUE LO TIENE LA VISTA
        IF [F:YPOP]CODORDREC <> PEDIDOANT Then
             If PEDIDOANT<>"" Then 
                 Openo Using [YFIC]
             Endif
             NOM_FICH = "RL" + [F:YPOP]CODORDREC
             FICHERO      = filpath("impexp\V10TOTAL",NOM_FICH,EXT,"","","")

             Openo FICHERO,0 Using [YFIC]
             Iomode adxifs [M:DIA]YSEP Using [YFIC]              # SEPARACION DE CAMPOS ";"
             Iomode adxirs chr$(13)+chr$(10) Using [YFIC]    # FIN DE LINEA
             Iomode adxium 50 Using [YFIC]
             PEDIDOANT = [F:YPOP]CODORDREC 
        Endif

        Wrseq [F:YPOP]CODORDREC ; Using [YFIC]
        Wrseq [F:YPOP]CODDIV ; Using [YFIC]
        Wrseq [F:YPOP]SEQLINORD ; Using [YFIC]
        Wrseq [F:YPOP]CODART ; Using [YFIC]
        Wrseq [F:YPOP]FECRECPRE ; Using [YFIC]
        Wrseq [F:YPOP]CANTIDAD ; Using [YFIC]
        Wrseq [F:YPOP]UNIDADESHOST Using [YFIC]
        WCONT += 1
   
        Call ECR_TRACE('Línea de compras procesada:' + [F:YPOP]CODORDREC - num$([F:YPOP]SEQLINORD),0) From GESECRAN
    Next
    If PEDIDOANT<>"" Then
      #ultima vez   
      Openo Using [YFIC]  
    Endif   
    If WCONT = 0 : Call EFFACE(FICHERO, YSTAT) From ORDSYS : Endif
Return

######################################################################################

$EXP_STA

    #-- variables diversas
    Local Char FICHERO(GDIMFIC), NOM_FICH(50), EXT(3)

    #-- variables de fichero, inicializacion

    EXT    = "txt"                   #-- extension del fichero

    NOM_FICH = "ESTADOS" + "_" + format$("D:YYMMDDhhmmss",date$)

    FICHERO      = filpath("impexp\V10TOTAL",NOM_FICH,EXT,"","","")

    Openo FICHERO,0 Using [YFIC]
    Iomode adxifs [M:DIA]YSEP Using [YFIC]                  # SEPARACION DE CAMPOS ";"
    Iomode adxirs chr$(13)+chr$(10) Using [YFIC]    # FIN DE LINEA
    Iomode adxium 50 Using [YFIC]

    # Selección de los registros
    #YCRITERE = "UPDDATTIM >= gdatetime$([M:DIA]YFECITM)"  NO NECESARIO PORQUE LO TIENE LA VISTA
    Raz WCONT
    # Recorro los articulos
    Filter [F:YSTA] Order By UPDDATTIM Asc
    For [F:YSTA] ## Where evalue(YCRITERE) NO NECESARIO PORQUE LO TIENE LA VISTA

            #Wrseq "C" ; Using [YFIC]
            Wrseq [F:YSTA]DIVISION ; Using [YFIC]
            Wrseq [F:YSTA]ITMGES ; Using [YFIC]
            Wrseq [F:YSTA]LOT ; Using [YFIC]
            Wrseq [F:YSTA]BPSLOT ; Using [YFIC]
            Wrseq [F:YSTA]QTYSTU ; Using [YFIC]
            Wrseq [F:YSTA]STU ; Using [YFIC]
            Wrseq [F:YSTA]STA Using [YFIC]
            WCONT += 1
            Call ECR_TRACE('Artículo/Lote procesado:' + [F:YSTA]ITMGES+'/'+[F:YSTA]LOT,0) From GESECRAN
    Next
    Filter [F:YSTA]

    Openo Using [YFIC]
    If WCONT = 0 : Call EFFACE(FICHERO, YSTAT) From ORDSYS : Endif
Return


