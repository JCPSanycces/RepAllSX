#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "DEBUT"      : Gosub DEBUT
  When "BOUTON"     : Gosub BOUTON
  When Default
Endcase
Return

$OUVRE
  If clalev([F:XSLO])  = 0  : Local File STOLOT [XSLO]      : Endif
  If clalev([F:XITM])  = 0  : Local File XITMGES[XITM]      : Endif
  If clalev([F:XSTJ])  = 0  : Local File STOJOU [XSTJ]      : Endif

  Local Integer NOL : NOL = 0
  Local Integer SELITM : SELITM = 0
Return

$DEBUT
    Raz [M:XCOL]
    [M:XCOL]NBLIG=0

     If PARAM(2)<>"" Then
        [M:XCOL]VCRTYP=val(PARAM(1))
        [M:XCOL]VCRNUM=PARAM(2)
        [M:XCOL]VCRLIN=val(PARAM(3))
     Endif
     [M:XCOL]ITMREF=PARAM(4)
     [M:XCOL]LOTD  =PARAM(5)
     [M:XCOL]LOTH  =PARAM(5)

     Read [F:XITM]XIG0 = [M:XCOL]ITMREF
     [M:XCOL]ITMDES    = [F:XITM]ITMDES
     Affzo [M:XCOL]1-99
     NOL=0


     If [M:XCOL]LOTD="$" Then
        Filter [F:XSTJ] Where [F:XSTJ]VCRTYP=[M:XCOL]VCRTYP and [F:XSTJ]VCRNUM=[M:XCOL]VCRNUM
&        and [F:XSTJ]VCRLIN=[M:XCOL]VCRLIN and [F:XSTJ]LOT <> ""
&        Order By [F:XSTJ]LOT
        For [F:XSTJ]
          If NOL=0 or (NOL>0 and [F:XSTJ]LOT <>  [M:XCOL]LOT(NOL-1)) Then
            Filter [F:XSLO] Where [F:XSLO]ITMREF=[F:XSTJ]ITMREF and [F:XSLO]LOT=[F:XSTJ]LOT
             For [F:XSLO]
               [M:XCOL]LOT(NOL)=[F:XSLO]LOT
               [M:XCOL]XNENVASE(NOL)=[F:XSLO]XNENVASE
               [M:XCOL]XNPALET(NOL) =[F:XSLO]XNPALET
               [M:XCOL]XUNXENVASE(NOL)=[F:XSLO]XUNXENVASE
               [M:XCOL]XUNXPALET(NOL) =[F:XSLO]XUNXPALET
               [M:XCOL]XRIQUEZA(NOL)=[F:XSLO]XRIQUEZA
               [M:XCOL]XVERSION(NOL)=[F:XSLO]XVERSION
               [M:XCOL]XFECANALIS(NOL)=[F:XSLO]XFECANALIS
               NOL+=1
             Next
             Filter [F:XSLO]
           Endif
        Next
        Filter [F:XSTJ]
        [M:XCOL]NBLIG=NOL
     Else

       Filter [F:XSLO] Where [F:XSLO]ITMREF=[M:XCOL]ITMREF and [F:XSLO]LOT=[M:XCOL]LOTD
       For [F:XSLO]
         [M:XCOL]LOT(NOL)=[F:XSLO]LOT
         [M:XCOL]XNENVASE(NOL)=[F:XSLO]XNENVASE
         [M:XCOL]XNPALET(NOL) =[F:XSLO]XNPALET
         [M:XCOL]XUNXENVASE(NOL)=[F:XSLO]XUNXENVASE
         [M:XCOL]XUNXPALET(NOL) =[F:XSLO]XUNXPALET
         [M:XCOL]XRIQUEZA(NOL)=[F:XSLO]XRIQUEZA
         [M:XCOL]XVERSION(NOL)=[F:XSLO]XVERSION
         [M:XCOL]XFECANALIS(NOL)=[F:XSLO]XFECANALIS
         NOL+=1
       Next
      Filter [F:XSLO]
      [M:XCOL]NBLIG=NOL
    Endif
    Affzo [M:XCOL]1-99
Return

$BOUTON
  Case BOUT
    When "R" : Gosub REGISTRAR
  Endcase
Return

$REGISTRAR
  For NOL=0 To [M:XCOL]NBLIG-1
    Readlock [F:XSLO]STL0=[M:XCOL]ITMREF; [M:XCOL]LOT(NOL);""
    If fstat Then
      #error
      GERR=1
      GOK=0
      GMESSAGE="No se puede actualizar los datos"
      Return
    Endif
    [F:XSLO]XNENVASE=[M:XCOL]XNENVASE(NOL)
    [F:XSLO]XNPALET =[M:XCOL]XNPALET(NOL)
    [F:XSLO]XUNXENVASE=[M:XCOL]XUNXENVASE(NOL)
    [F:XSLO]XUNXPALET =[M:XCOL]XUNXPALET(NOL)
    [F:XSLO]XRIQUEZA=[M:XCOL]XRIQUEZA(NOL)
    [F:XSLO]XVERSION=[M:XCOL]XVERSION(NOL)
    [F:XSLO]XFECANALIS=[M:XCOL]XFECANALIS(NOL)
    Rewrite [F:XSLO] Curr
  Next
Return


######################################################################################
## Etiqueta ańadida por el supervisor (pantalla XCOMPLOT) 31/10/2017 09:52:05 (ADMIN)
######################################################################################
Subprog AS_XFECANALIS(VALEUR)
Variable Date    VALEUR
  If clalev([M:PTH0]) Then
    If left$([M:PTH0]PRHFCY,1) = '3' Then
      mkstat=1
    Endif
  Endif
End


######################################################################################

