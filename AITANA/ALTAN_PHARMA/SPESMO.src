#000731 - Al duplicar la fecha de imputaciÛn debe ser la del dÌa, no la de la transacciÛn original

#000731.bn
$ACTION
Case ACTION
 When "RAZDUP" : Gosub RAZDUP
 When Default
Endcase
Return

$RAZDUP
  If GREP = "D" Then
    IPTDAT=date$
    Affzo IPTDAT
  Endif
Return
