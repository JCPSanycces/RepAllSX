########################################################################################

Subprog SOHSAL(PSOHNUM, PSOQSTA, PUPDDATTIM)
Value Char PSOPNUM()
Value Integer PSOQSTA
Value Datetime PUPDDATTIM
Datetime VDATETIME

VDATETIME=datetime$

 If !clalev([F:XSOQ]) Then Local File SORDERQ [XSOQ] : Endif
 Gosub AVANT_PAR
 Gosub OUVRE
 Gosub DEBUT

    #-- variables diversas
    Local Char FICHERO(GDIMFIC), NOM_FICH(50), EXT(3)

    #-- variables de fichero, inicializacion
    EXT    = "txt"                   #-- extension del fichero
    NOM_FICH = "PVSAL" + "_" + format$("D:YYMMDDhhmmss",date$)
    FICHERO      = filpath("impexp\V10",NOM_FICH,EXT,"","","")
    Openo FICHERO,-1 Using [YFIC]
    Iomode adxifs [M:DIA]YSEP Using [YFIC]          # SEPARACION DE CAMPOS ";"
    Iomode adxirs chr$(13)+chr$(10) Using [YFIC]    # FIN DE LINEA
    Iomode adxium 50 Using [YFIC]
    #   Wrseq PSOHNUM ; Using [YFIC]
    #   Wrseq "0000" Using [YFIC]
    Filter [F:XSOQ] Where SOHNUM=PSOHNUM and UPDDATTIM=VDATETIME and SOQSTA=3
    For [F:XSOQ]
       Wrseq PSOHNUM ; Using [YFIC]
       Wrseq [F:XSOQ]SOPLIN Using [YFIC]
    Next
    Filter [F:XSOQ]
    Openo Using [YFIC]
End

Subprog SOPSAL(PSOHNUM, PSOQLIN, PSOQSTA, PUPDDATTIM)
Value Char PSOPNUM()
Value Integer PSOQLIN
Value Integer PSOQSTA
Value Datetime PUPDDATTIM
Datetime VDATETIME

VDATETIME=datetime$

 If PUPDDATTIM = VDATETIME Then
  Gosub AVANT_PAR
  Gosub OUVRE
  Gosub DEBUT
  #-- variables diversas
    Local Char FICHERO(GDIMFIC), NOM_FICH(50), EXT(3)

    #-- variables de fichero, inicializacion

    EXT    = "txt"                   #-- extension del fichero

    NOM_FICH = "PVSAL" + "_" + format$("D:YYMMDDhhmmss",date$)

    FICHERO      = filpath("impexp\V10",NOM_FICH,EXT,"","","")

    Openo FICHERO,-1 Using [YFIC]
    Iomode adxifs [M:DIA]YSEP Using [YFIC]          # SEPARACION DE CAMPOS ";"
    Iomode adxirs chr$(13)+chr$(10) Using [YFIC]    # FIN DE LINEA
    Iomode adxium 50 Using [YFIC]

    Wrseq PSOHNUM ; Using [YFIC]
    Wrseq PSOQLIN Using [YFIC]

    Openo Using [YFIC]
  Endif

End



##################################################


Subprog SOHANU(PSOHNUM, PSOQSTA, PUPDDATTIM)
Value Char PSOPNUM()
Value Integer PSOQSTA
Value Datetime PUPDDATTIM
Datetime VDATETIME

VDATETIME=datetime$

 Gosub AVANT_PAR
 Gosub OUVRE
 Gosub DEBUT

    #-- variables diversas
    Local Char FICHERO(GDIMFIC), NOM_FICH(50), EXT(3)

    #-- variables de fichero, inicializacion
    EXT    = "txt"                   #-- extension del fichero
    NOM_FICH = "PVANU" + "_" + format$("D:YYMMDDhhmmss",date$)
    FICHERO      = filpath("impexp\V10",NOM_FICH,EXT,"","","")
    Openo FICHERO,-1 Using [YFIC]
    Iomode adxifs [M:DIA]YSEP Using [YFIC]          # SEPARACION DE CAMPOS ";"
    Iomode adxirs chr$(13)+chr$(10) Using [YFIC]    # FIN DE LINEA
    Iomode adxium 50 Using [YFIC]
       Wrseq PSOHNUM ; Using [YFIC]
       Wrseq "0000" Using [YFIC]
    Openo Using [YFIC]
End


Subprog SOPANU(PSOHNUM, PSOQLIN, PSOQSTA, PUPDDATTIM)
Value Char PSOPNUM()
Value Integer PSOQLIN
Value Integer PSOQSTA
Value Datetime PUPDDATTIM
Datetime VDATETIME

VDATETIME=datetime$

 If PUPDDATTIM = VDATETIME Then
  Gosub AVANT_PAR
  Gosub OUVRE
  Gosub DEBUT
  #-- variables diversas
    Local Char FICHERO(GDIMFIC), NOM_FICH(50), EXT(3)

    #-- variables de fichero, inicializacion

    EXT    = "txt"                   #-- extension del fichero

    NOM_FICH = "PVANU" + "_" + format$("D:YYMMDDhhmmss",date$)

    FICHERO      = filpath("impexp\V10",NOM_FICH,EXT,"","","")

    Openo FICHERO,-1 Using [YFIC]
    Iomode adxifs [M:DIA]YSEP Using [YFIC]          # SEPARACION DE CAMPOS ";"
    Iomode adxirs chr$(13)+chr$(10) Using [YFIC]    # FIN DE LINEA
    Iomode adxium 50 Using [YFIC]

    Wrseq PSOHNUM ; Using [YFIC]
    Wrseq PSOQLIN Using [YFIC]

    Openo Using [YFIC]
  Endif


End

