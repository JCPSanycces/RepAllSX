## FECHA INICIAL "1999-03-10T18:38:17Z"
#@ XVT29012019 - INCUIR LOS PEDIDOS F- DE LA FUSIėN
## xvt27082019 - Marcar creadoip6 sin que se modifique UPDDATTIM

$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "DEBUT"      : Gosub DEBUT
  When "OK"         : Gosub OK
  When "EXEC"       : Gosub EXEC
  When "AVANT_PAR"  : Gosub AVANT_PAR

  When Default
Endcase

Return

$OUVRE
  If clalev([F:YADI])  = 0  : Local File ATABDIV [YADI]      : Endif
  If clalev([F:YITM])  = 0  : Local File XV10ITM [YITM]      : Endif
  If clalev([F:YSOH])  = 0  : Local File XV10SORDER [YSOH]   : Endif
  If clalev([F:YSOP])  = 0  : Local File XV10SORDERL [YSOP]  : Endif
  If clalev([F:YPOH])  = 0  : Local File XV10PORDER [YPOH]   : Endif
  If clalev([F:YPOP])  = 0  : Local File XV10PORDERL [YPOP]  : Endif
  If clalev([F:YSTA])  = 0  : Local File XV10ESTADOS [YSTA]  : Endif
  If clalev([F:ZSI6])  = 0  : Local File ZSORDERIP6 [ZSI6]   : Endif
  If clalev([F:SOH])   = 0  : Local File SORDER [SOH]      : Endif
  If clalev([F:POH])   = 0  : Local File PORDER [POH]      : Endif

Return

######################################################################################

$DEBUT
Local Char MES (2), DIA(2)
Raz [M:DIA]

[M:DIA]YSEP = ";"
# Leer la fecha/hora de captura ·ltima
Read [F:YADI]CODE=6001;'01'
If !fstat
    [M:DIA]YFECITM = [F:YADI]A2
Else
    MES = num$(month(date$))
    If len(MES) = 1 : MES = "0" + MES : Endif
    DIA = num$(day(date$))
    If len(DIA) = 1 : DIA= "0" + DIA : Endif
    [M]YFECITM = "" + num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
Endif

Read [F:YADI]CODE=6001;'02'
If !fstat
    [M:DIA]YFECSOH = [F:YADI]A2
Else
    MES = num$(month(date$))
    If len(MES) = 1 : MES = "0" + MES : Endif
    DIA = num$(day(date$))
    If len(DIA) = 1 : DIA= "0" + DIA : Endif
    [M:DIA]YFECSOH = "" + num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
Endif

Read [F:YADI]CODE=6001;'03'
If !fstat
    [M:DIA]YFECPOH = [F:YADI]A2
Else
    MES = num$(month(date$))
    If len(MES) = 1 : MES = "0" + MES : Endif
    DIA = num$(day(date$))
    If len(DIA) = 1 : DIA= "0" + DIA : Endif
    [M:DIA]YFECPOH = num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
Endif

Read [F:YADI]CODE=6001;'04'
If !fstat
    [M:DIA]YFECSTA = [F:YADI]A2
Else
    MES = num$(month(date$))
    If len(MES) = 1 : MES = "0" + MES : Endif
    DIA = num$(day(date$))
    If len(DIA) = 1 : DIA= "0" + DIA : Endif
    [M:DIA]YFECSTA = num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
Endif
Affzo [M:DIA]1-99

Return

######################################################################################

$AVANT_PAR

    If !clalev([M:DIA]) Then
         Local Mask XEXPV10 [DIA]
    Endif

Return

$EXEC
  If GSERVEUR Then
    Gosub OUVRE
    Gosub DEBUT
    Gosub OK
  Endif
Return

$OK

Local Char    YCRITERE(255),YCRITEREL(255), MES (2), DIA(2)
Local Char    FECHA_HORA(20) # MAB20180220.SN  # Ticket #000879
Local Integer YSTAT, WCONT, WCONTL

  Gosub IMP_IP6SON
  Gosub IMP_IP6POH
  Gosub IMP_IP6FPOH #XVT29012019.n
  Gosub IMP_IP6FSON #XVT29012019.n

If !GSERVEUR Then
    Call OUINON("┐Desea continuar?",[L]YSTAT) From GESECRAN
Else
   [L]YSTAT=2
   [M:DIA]YITM = 2
   [M:DIA]YSOH = 2
   [M:DIA]YPOH = 2
   [M:DIA]YSTA = 2
Endif

If [L]YSTAT=2
    Call OUVRE_TRACE('') From LECFIC
    If GSERVEUR Then
       Call ECR_TRACE('Exportaci¾n V10 en Batch:',0) From GESECRAN
    Else
       Call ECR_TRACE('Exportaci¾n V10 en lĒnea:',0) From GESECRAN
    Endif

    # Marcar la nueva fecha-hora de ejecucion
    MES = num$(month(date$))
    If len(MES) = 1 : MES = "0" + MES : Endif
    DIA = num$(day(date$))
    If len(DIA) = 1 : DIA= "0" + DIA : Endif

    If [M:DIA]YITM = 2
      # MAB20180220.SN
      # Ticket #000879
      # Capturamos la FECHA/HORA antes de empezar el proceso, para no perder los minutos/segundos que
      # tarde el proceso en ejecutarse
      FECHA_HORA = num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
      Gosub EXP_ITM
      Readlock [F:YADI]CODE=6001;'01'
      If !fstat
          # [F:YADI]A2 = num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z" # MAB20180220.OLD
          [F:YADI]A2 = FECHA_HORA # MAB20180220.NEW
          Rewrite [F:YADI]
      Endif
    Endif
    If [M:DIA]YSOH = 2
      # MAB20180220.SN
      # Ticket #000879
      # Capturamos la FECHA/HORA antes de empezar el proceso, para no perder los minutos/segundos que
      # tarde el proceso en ejecutarse
      FECHA_HORA = num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
      Gosub EXP_SOH
      #Gosub EXP_SOP   llamada por cada pedido
      Readlock [F:YADI]CODE=6001;'02'
      If !fstat
          # [F:YADI]A2 = num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z" # MAB20180220.OLD
          [F:YADI]A2 = FECHA_HORA # MAB20180220.NEW
          Rewrite [F:YADI]
      Endif
    Endif
    If [M:DIA]YPOH = 2
      # MAB20180220.SN
      # Ticket #000879
      # Capturamos la FECHA/HORA antes de empezar el proceso, para no perder los minutos/segundos que
      # tarde el proceso en ejecutarse
      FECHA_HORA = num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
      Gosub EXP_POH
      # Gosub EXP_POP
      Readlock [F:YADI]CODE=6001;'03'
      If !fstat
          # [F:YADI]A2 = num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z" # MAB20180220.OLD
          [F:YADI]A2 = FECHA_HORA # MAB20180220.NEW
          Rewrite [F:YADI]
      Endif
    Endif
    If [M:DIA]YSTA = 2
      # MAB20180220.SN
      # Ticket #000879
      # Capturamos la FECHA/HORA antes de empezar el proceso, para no perder los minutos/segundos que
      # tarde el proceso en ejecutarse
      FECHA_HORA = num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
      # MAB20180220.EN
      Gosub EXP_STA
      Readlock [F:YADI]CODE=6001;'04'
      If !fstat
          # [F:YADI]A2 = num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z" # MAB20180220.OLD
          [F:YADI]A2 = FECHA_HORA # MAB20180220.NEW
          Rewrite [F:YADI]
      Endif
    Endif

    Call FERME_TRACE From LECFIC

    If !GSERVEUR
        Call LEC_TRACE From LECFIC
        Call MESSAGE ("Exportaci¾n finalizada correctamente") From GESECRAN
    Endif

Endif


Return

######################################################################################

$EXP_ITM

    #-- variables diversas
    Local Char FICHERO(GDIMFIC), NOM_FICH(50), EXT(3)

    #-- variables de fichero, inicializacion

    EXT    = "txt"                   #-- extension del fichero

    NOM_FICH = "ARTICULOS" + "_" + format$("D:YYMMDDhhmmss",date$)

    FICHERO      = filpath("impexp\V10",NOM_FICH,EXT,"","","")

    Openo FICHERO,0 Using [YFIC]
    Iomode adxifs [M:DIA]YSEP Using [YFIC]                  # SEPARACION DE CAMPOS ";"
    Iomode adxirs chr$(13)+chr$(10) Using [YFIC]    # FIN DE LINEA
    Iomode adxium 50 Using [YFIC]

    # Selecci¾n de los registros
    #YCRITERE = "UPDDATTIM >= gdatetime$([M:DIA]YFECITM)"  NO NECESARIO PORQUE LO TIENE LA VISTA
    Raz WCONT
    # Recorro los articulos
    For [F:YITM] ## Where evalue(YCRITERE) NO NECESARIO PORQUE LO TIENE LA VISTA

            Wrseq "C" ; Using [YFIC]
            Wrseq [F:YITM]CODART ; Using [YFIC]
            Wrseq [F:YITM]CODDIV ; Using [YFIC]
            Wrseq [F:YITM]CODARTDIV ; Using [YFIC]
            Wrseq [F:YITM]CODNAC ; Using [YFIC]
            Wrseq [F:YITM]DESARTC ; Using [YFIC]
            Wrseq [F:YITM]UNIDADESHOST ; Using [YFIC]
            Wrseq [F:YITM]SWTLOTE ; Using [YFIC]
            Wrseq [F:YITM]UNIDADVTA ; Using [YFIC]
            Wrseq [F:YITM]COEFUVUS ; Using [YFIC]
            Wrseq [F:YITM]CATEGART  Using [YFIC]
      #      Wrseq [F:YITM]TRETEST ; Using [YFIC]     #no exportar por indicaci¾n de Florentino
      #      Wrseq [F:YITM]UNITRTEST ; Using [YFIC]   #via email 14/03/16 16.34
      #      Wrseq [F:YITM]TCADUC ; Using [YFIC]
      #      Wrseq [F:YITM]UNICADUC Using [YFIC]
            WCONT += 1
            Call ECR_TRACE('ArtĒculo procesado:' + [F:YITM]CODART,0) From GESECRAN
    Next
    Openo Using [YFIC]
    If WCONT = 0 : Call EFFACE(FICHERO, YSTAT) From ORDSYS : Endif
Return

######################################################################################

$EXP_SOH

    #-- variables diversas
    Local Char FICHERO(GDIMFIC), NOM_FICH(50), EXT(3)

    #-- variables de fichero, inicializacion

    EXT    = "txt"                   #-- extension del fichero
    # Selecci¾n de los registros
    #YCRITERE = "UPDDATTIM >= gdatetime$([M:DIA]YFECSOH)"  NO NECESARIO PORQUE LO TIENE LA VISTA
    Raz WCONT
    # Recorro las cabeceras de pedidos de venta
    For [F:YSOH] # Where evalue(YCRITERE)  NO NECESARIO PORQUE LO TIENE LA VISTA

        NOM_FICH = "PC" + [F:YSOH]CODPED

        FICHERO      = filpath("impexp\V10",NOM_FICH,EXT,"","","")
        # MAB.22102019. Se a±ade traza al proceso
        Call ECR_TRACE('Cabecera Pedido:' + [F:YSOH]CODPED + " Fecha Procesado: " + FECHA_HORA + " - Nombre fichero: " + NOM_FICH,0) From GESECRAN
        Call ECR_TRACE('Fecha Modificaci¾n: ' + num$([F:YSOH]UPDDATTIM) + ' - Usuario Modificaci¾n:  '  + [F:YSOH]UPDUSR, 0 ) From GESECRAN
        Openo FICHERO,0 Using [YFIC]
        Iomode adxifs [M:DIA]YSEP Using [YFIC]                  # SEPARACION DE CAMPOS ";"
        Iomode adxirs chr$(13)+chr$(10) Using [YFIC]    # FIN DE LINEA
        Iomode adxium 50 Using [YFIC]

        Wrseq [F:YSOH]PLANVEN ; Using [YFIC]
        Wrseq [F:YSOH]CODDIV ; Using [YFIC]
        Wrseq [F:YSOH]ANOPED ; Using [YFIC]
        Wrseq [F:YSOH]CODPED ; Using [YFIC]
        Wrseq [F:YSOH]TIPOPEDIDO ; Using [YFIC]
        Wrseq [F:YSOH]NLINEAS ; Using [YFIC]
        Wrseq [F:YSOH]PEDIDOCLIENT ; Using [YFIC]
        Wrseq [F:YSOH]FECPEDIDOCLI ; Using [YFIC]
        Wrseq [F:YSOH]PEDIDOHOST ; Using [YFIC]
        Wrseq [F:YSOH]CODCLIENTE ; Using [YFIC]
        Wrseq [F:YSOH]DESCLIENTE ; Using [YFIC]
        Wrseq [F:YSOH]NIF ; Using [YFIC]
        Wrseq [F:YSOH]DIRECCION ; Using [YFIC]
        Wrseq [F:YSOH]DIRECCION1 ; Using [YFIC]
        Wrseq [F:YSOH]DIRECCION2 ; Using [YFIC]
        Wrseq [F:YSOH]DIRECCION3 ; Using [YFIC]
        Wrseq [F:YSOH]POBLACION ; Using [YFIC]
        Wrseq [F:YSOH]DP ; Using [YFIC]
        Wrseq [F:YSOH]CODPAIS ; Using [YFIC]
        Wrseq [F:YSOH]TELEFONO ; Using [YFIC]
        Wrseq [F:YSOH]FAX ; Using [YFIC]
        Wrseq [F:YSOH]EMAIL ; Using [YFIC]
        Wrseq [F:YSOH]MENHOST ; Using [YFIC]
        #Wrseq [F:YSOH]SWTANULAR ; Using [YFIC]
        #Wrseq [F:YSOH]SWTVALORADO ; Using [YFIC]
        #Wrseq [F:YSOH]SWTTOTALES ; Using [YFIC]
        Wrseq [F:YSOH]SWTPROFORMA ; Using [YFIC]
        #Wrseq [F:YSOH]SWTAGRUPAR ; Using [YFIC]
        #Wrseq [F:YSOH]SWTCOMUNICAR ; Using [YFIC]
        #Wrseq [F:YSOH]CODAREAEXPED ; Using [YFIC]
        Wrseq [F:YSOH]BACKORDER ; Using [YFIC]
        Wrseq [F:YSOH]MONEDA ; Using [YFIC]
        Wrseq [F:YSOH]DESCUENTO ; Using [YFIC]
        Wrseq [F:YSOH]RECARGO ; Using [YFIC]
        Wrseq [F:YSOH]CONDPAGO ; Using [YFIC]
        Wrseq [F:YSOH]URGENCIA ; Using [YFIC]
        Wrseq [F:YSOH]CODAGE ; Using [YFIC]
        #Wrseq [F:YSOH]CAMPOS ; Using [YFIC]
        Wrseq [F:YSOH]SWTFACTU ; Using [YFIC]
        Wrseq [F:YSOH]CODCLIFACTU; Using [YFIC]
        Wrseq [F:YSOH]DESCLIFACTU ; Using [YFIC]
        Wrseq [F:YSOH]NIFFACTU ; Using [YFIC]
        Wrseq [F:YSOH]DIRFACTU ; Using [YFIC]
        Wrseq [F:YSOH]DIRFACTU1 ; Using [YFIC]
        Wrseq [F:YSOH]DIRFACTU2 ; Using [YFIC]
        Wrseq [F:YSOH]DIRFACTU3 ; Using [YFIC]
        Wrseq [F:YSOH]POBFACTU ; Using [YFIC]
        Wrseq [F:YSOH]DPFACTU ; Using [YFIC]
        Wrseq [F:YSOH]CODPAISFACTU ; Using [YFIC]
        Wrseq [F:YSOH]TELFACTU ; Using [YFIC]
        Wrseq [F:YSOH]FAXFACTU ; Using [YFIC]
        Wrseq [F:YSOH]EMAILFACTU ; Using [YFIC]
        Wrseq [F:YSOH]IMPORTEPEDID ; Using [YFIC]
        Wrseq [F:YSOH]FECCAPTURA ; Using [YFIC]
        Wrseq [F:YSOH]FECSERVICIO Using [YFIC]
        WCONT += 1

        Gosub EXP_SOP  ##export de lĒneas del pedido actual antes de cerrar el fichero de cabecera

        Openo Using [YFIC]

        #actualizar ZENVIADOIP6 de SORDER

        Trbegin [F:SOH]
        Readlock [SOH]SOH0 = [F:YSOH]CODPED
        If !fstat
            [F:SOH]ZENVIADOIP6 = 2
            Rewrite [F:SOH]
            Unlock [F:SOH]
            Commit
            Call ECR_TRACE('Cabecera de ventas procesada:' + [F:YSOH]CODPED,0) From GESECRAN
        Else
            Call ECR_TRACE('ERRLOCK: Cabecera de ventas procesada:' + [F:YSOH]CODPED,0) From GESECRAN
            Rollback
        Endif


    Next
    If WCONT = 0 : Call EFFACE(FICHERO, YSTAT) From ORDSYS : Endif
Return

######################################################################################

$EXP_SOP

    #-- variables diversas
    Local Char FICHEROL(GDIMFIC), NOM_FICHL(50)

    #-- variables de fichero, inicializacion
    NOM_FICHL = "PL" + [F:YSOH]CODPED
    FICHEROL  = filpath("impexp\V10",NOM_FICHL,EXT,"","","")
    Openo FICHEROL,0 Using [YFICL]
    Iomode adxifs [M:DIA]YSEP Using [YFICL]          # SEPARACION DE CAMPOS ";"
    Iomode adxirs chr$(13)+chr$(10) Using [YFICL]    # FIN DE LINEA
    Iomode adxium 50 Using [YFICL]

    # Selecci¾n de los registros
    YCRITEREL = "CODPED = [F:YSOH]CODPED"     ##LINEAS DEL PEDIDO EN CURSO
    Raz WCONTL
    # Recorro las lĒneas del pedido de venta en curso
    For [F:YSOP] Where evalue(YCRITEREL)
      Wrseq [F:YSOP]CODDIV ; Using [YFICL]
      Wrseq [F:YSOP]ANOPED ; Using [YFICL]
      Wrseq [F:YSOP]CODPED ; Using [YFICL]
      Wrseq [F:YSOP]SEQLINEA ; Using [YFICL]
      Wrseq [F:YSOP]CODART ; Using [YFICL]
      Wrseq [F:YSOP]CANTPEDIDA ; Using [YFICL]
      Wrseq [F:YSOP]UNIDADESHOST ; Using [YFICL]
      Wrseq [F:YSOP]BACKORDER ; Using [YFICL]
      Wrseq [F:YSOP]SWTPRECIO ; Using [YFICL]
      Wrseq [F:YSOP]PRECIOUNI ; Using [YFICL]
      Wrseq [F:YSOP]UNIDADESPREC ; Using [YFICL]
      Wrseq [F:YSOP]DCTO ; Using [YFICL]
      Wrseq [F:YSOP]IVA ; Using [YFICL]
      Wrseq [F:YSOP]RECARGO ; Using [YFICL]
      Wrseq [F:YSOP]ESTADO Using [YFICL]
      #Wrseq [F:YSOP]SWTCREAVERSION ; Using [YFIC]
      #Wrseq [F:YSOP]TIPOREDONDEO Using [YFIC]
      WCONTL += 1

      Call ECR_TRACE('LĒnea de ventas procesada:' + [F:YSOP]CODPED - num$([F:YSOP]SEQLINEA),0) From GESECRAN
    Next
    Openo Using [YFICL]

    If WCONTL = 0 : Call EFFACE(FICHEROL, YSTAT) From ORDSYS : Endif
Return

######################################################################################

$EXP_POH

    #-- variables diversas
    Local Char FICHERO(GDIMFIC), NOM_FICH(50), EXT(3)

    #-- variables de fichero, inicializacion

    EXT    = "txt"                   #-- extension del fichero

    # Selecci¾n de los registros
    #YCRITERE = "UPDDATTIM >= gdatetime$([M:DIA]YFECPOH)"  NO NECESARIO PORQUE LO TIENE LA VISTA
    Raz WCONT
    # Recorro las cabeceras de pedidos de compra
    For [F:YPOH] # Where evalue(YCRITERE)          NO NECESARIO PORQUE LO TIENE LA VISTA

        NOM_FICH = "RC" + [F:YPOH]CODORDREC

        FICHERO      = filpath("impexp\V10",NOM_FICH,EXT,"","","")

        Openo FICHERO,0 Using [YFIC]
        Iomode adxifs [M:DIA]YSEP Using [YFIC]                  # SEPARACION DE CAMPOS ";"
        Iomode adxirs chr$(13)+chr$(10) Using [YFIC]    # FIN DE LINEA
        Iomode adxium 50 Using [YFIC]

        Wrseq [F:YPOH]CODORDREC ; Using [YFIC]
        Wrseq [F:YPOH]CODDIV ; Using [YFIC]
        Wrseq [F:YPOH]TIPORDREC ; Using [YFIC]
        Wrseq [F:YPOH]CODPROVE ; Using [YFIC]
        Wrseq [F:YPOH]DESPROVE ; Using [YFIC]
        Wrseq [F:YPOH]FECORDREC Using [YFIC]
        WCONT += 1

        Gosub EXP_POP ##export de lĒneas del pedido actual antes de cerrar el fichero de cabecera

        Openo Using [YFIC]
        Call ECR_TRACE('Cabecera de compras procesada:' + [F:YPOH]CODORDREC,0) From GESECRAN

 #actualizar ZENVIADOIP6 de PORDER

        Trbegin [F:POH]
        Readlock [POH]POH0 = [F:YPOH]CODORDREC
        If !fstat
            [F:POH]ZENVIADOIP6 = 2
            Rewrite [F:POH]
            Unlock [F:POH]
            Commit
            Call ECR_TRACE('Cabecera de compras procesada:' + [F:YPOH]CODORDREC,0) From GESECRAN
        Else
            Call ECR_TRACE('ERRLOCK: Cabecera de comprass procesada:' + [F:YPOH]CODORDREC,0) From GESECRAN
            Rollback
        Endif
    Next

    If WCONT = 0 : Call EFFACE(FICHERO, YSTAT) From ORDSYS : Endif
Return

######################################################################################

$EXP_POP

    #-- variables diversas
    Local Char FICHEROL(GDIMFIC), NOM_FICHL(50), EXT(3)

    EXT    = "txt"

    #-- variables de fichero, inicializacion
    NOM_FICHL = "RL" + [F:YPOH]CODORDREC
    FICHEROL     = filpath("impexp\V10",NOM_FICHL,EXT,"","","")
    Openo FICHEROL,0 Using [YFICL]
    Iomode adxifs [M:DIA]YSEP Using [YFICL]              # SEPARACION DE CAMPOS ";"
    Iomode adxirs chr$(13)+chr$(10) Using [YFICL]    # FIN DE LINEA
    Iomode adxium 50 Using [YFICL]

    # Selecci¾n de los registros
    YCRITEREL = "CODORDREC = [F:YPOH]CODORDREC"          ##LINEAS DEL PEDIDO EN CURSO
    Raz WCONTL
    # Recorro las lĒneas de pedidos de compra
    For [F:YPOP] Where evalue(YCRITEREL)

        Wrseq [F:YPOP]CODORDREC ; Using [YFICL]
        Wrseq [F:YPOP]CODDIV ; Using [YFICL]
        Wrseq [F:YPOP]SEQLINORD ; Using [YFICL]
        Wrseq [F:YPOP]CODART ; Using [YFICL]
        Wrseq [F:YPOP]FECRECPRE ; Using [YFICL]
        Wrseq [F:YPOP]CANTIDAD ; Using [YFICL]
        Wrseq [F:YPOP]UNIDADESHOST Using [YFICL]
        WCONTL += 1

        Call ECR_TRACE('LĒnea de compras procesada:' + [F:YPOP]CODORDREC - num$([F:YPOP]SEQLINORD),0) From GESECRAN
    Next
    Openo Using [YFICL]

    If WCONTL = 0 : Call EFFACE(FICHEROL, YSTAT) From ORDSYS : Endif
Return


######################################################################################

$EXP_STA

    #-- variables diversas
    Local Char FICHERO(GDIMFIC), NOM_FICH(50), EXT(3)

    #-- variables de fichero, inicializacion

    EXT    = "txt"                   #-- extension del fichero

    NOM_FICH = "ESTADOS" + "_" + format$("D:YYMMDDhhmmss",date$)

    FICHERO      = filpath("impexp\V10",NOM_FICH,EXT,"","","")

    Openo FICHERO,0 Using [YFIC]
    Iomode adxifs [M:DIA]YSEP Using [YFIC]                  # SEPARACION DE CAMPOS ";"
    Iomode adxirs chr$(13)+chr$(10) Using [YFIC]    # FIN DE LINEA
    Iomode adxium 50 Using [YFIC]

    # Selecci¾n de los registros
    #YCRITERE = "UPDDATTIM >= gdatetime$([M:DIA]YFECITM)"  NO NECESARIO PORQUE LO TIENE LA VISTA
    Raz WCONT
    # Recorro los articulos
    Filter [F:YSTA] Order By UPDDATTIM Asc
    For [F:YSTA] ## Where evalue(YCRITERE) NO NECESARIO PORQUE LO TIENE LA VISTA

            #Wrseq "C" ; Using [YFIC]
            Wrseq [F:YSTA]DIVISION ; Using [YFIC]
            Wrseq [F:YSTA]ITMGES ; Using [YFIC]
            Wrseq [F:YSTA]LOT ; Using [YFIC]
            Wrseq [F:YSTA]BPSLOT ; Using [YFIC]
            Wrseq [F:YSTA]QTYSTU ; Using [YFIC]
            Wrseq [F:YSTA]STU ; Using [YFIC]
            Wrseq [F:YSTA]STA  Using [YFIC]
     #       Wrseq [F:YSTA]LOC Using [YFIC]
            WCONT += 1
            Call ECR_TRACE('ArtĒculo/Lote procesado:' + [F:YSTA]ITMGES+'/'+[F:YSTA]LOT,0) From GESECRAN
    Next
    Filter [F:YSTA]

    Openo Using [YFIC]
    If WCONT = 0 : Call EFFACE(FICHERO, YSTAT) From ORDSYS : Endif
Return

$IMP_IP6SON
Local Char FILELIST(GDIMFIC)(1..1000)
Local Integer LNGTH, I
Local Char V10DIR(GDIMFIC)
Local Char V10PROCESADOS(GDIMFIC)
Local Char ORDSYS(GDIMFIC)
Local Char PEDIDO(20), LINEAPEDIDO(8), RESULT(10), RES(GDIMFIC)
Local Integer  STAT

Local     Char    REQUETE(250)(0..10) #XVT27082019.n

V10DIR=filpath("","","","","", adxmac(0)) + "\IMPEXP\V10\"
V10PROCESADOS=V10DIR+"\procesados\"

ORDSYS = "dir " + V10DIR + "IP6SON*.TXT /A-D /B"
Call SYSTEME2(adxmac(0),ORDSYS,"",LNGTH,FILELIST) From ORDSYS

If left$(FILELIST(1),6)="IP6SON" Then
  For I=1 To LNGTH

      Openi V10DIR + FILELIST(I) Using [YFIC]
      Iomode adxifs ";" Using [YFIC]                  # SEPARACION DE CAMPOS ";"
      Iomode adxirs chr$(13)+chr$(10) Using [YFIC]    # FIN DE LINEA
      Iomode adxium 50 Using [YFIC]
      PEDIDO=""
      LINEAPEDIDO=""
      RESULT=""
      Rdseq PEDIDO, LINEAPEDIDO, RESULT Using [YFIC]
      Openi Using [YFIC]

      If RESULT="OK" Then
          #actualizar ZCREADOIP6 de SORDER
#          Trbegin [F:SOH]  #XVT27082019.o
#          Readlock [SOH]SOH0 = PEDIDO  #XVT27082019.o
          Read [SOH]SOH0 = PEDIDO  #XVT27082019.n
          If !fstat
            Raz REQUETE  #XVT27082019.n
            REQUETE(0) = "UPDATE SORDER SET ZCREADOIP6_0=2 WHERE SOHNUM_0='"+ PEDIDO + "'" #XVT27082019.n
            Execsql From num$([V]GTYPDBA*2+1) Sql REQUETE                                  #XVT27082019.n
#XVT27082019.Bo
#              [F:SOH]ZCREADOIP6 = 2
#              Rewrite [F:SOH]
#              Unlock [F:SOH]
#              Commit
#XVT27082019.Eo
              ORDSYS = "MOVE " + V10DIR + FILELIST(I) + " " + V10PROCESADOS + FILELIST(I)
              Call SYSTEME2(adxmac(0), ORDSYS,"",STAT,RES) From ORDSYS
          Else
#              Rollback  #XVT27082019.o
              ORDSYS =  "MOVE " + V10DIR + FILELIST(I) + " " + V10DIR + FILELIST(I) + ".err"
              Call SYSTEME2(adxmac(0), ORDSYS ,"",STAT,RES) From ORDSYS
          Endif
      Else
        ORDSYS =  "MOVE " + V10DIR + FILELIST(I) + " " + V10DIR + FILELIST(I) + ".err"
        Call SYSTEME2(adxmac(0), ORDSYS ,"",STAT,RES) From ORDSYS
      Endif

  Next
Endif
Return

#XVT29012019.bn
