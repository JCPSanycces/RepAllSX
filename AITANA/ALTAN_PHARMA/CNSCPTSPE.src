#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################
# SUPPORT-3469 - AŮadir descripciůn y refencia a consulta
$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE      # SUPPORT-3469 - A—ADIR DESCRIPCI”N Y REFENCIA A CONSULTA
  When "SETBOUT"    : Gosub SETBOUT    # SUPPORT-3469 - AŮadir descripciůn y refencia a consulta
  When Default
Endcase
Return

#############################################################
$OUVRE

  If !clalev([ZPINV]) Then : Local File PINVOICE  [ZPINV] : Endif
  If !clalev([ZPIND]) Then : Local File PINVOICED [ZPIND] : Endif
Return

#############################################################
$SETBOUT
# SUPPORT-3469 - AŮadir descripciůn y refencia a consulta
  For I = 0 To [M:CPT2]NBLIG-1
    #If [M:CPT2]NUM(I) = 'FAP50017000100' Then : Infbox "FACTURA " + [M:CPT2]NUM(I) : Endif
    Read [ZPINV]PIH0=[M:CPT2]NUM(I)
    If !fstat Then
      If vireblc([M:CPT2]BPRVCR(I),2) = "" and [M:CPT2]NUM(I) <> "" Then
          #If [M:CPT2]NUM(I) = 'FAP50017000100' Then : Infbox "ref " + [F:ZPINV]INVREF : Endif
          [M:CPT2]BPRVCR(I) = [F:ZPINV]BPRVCR
          Affzo [M:CPT2]BPRVCR(I)
      Endif
      [M:CPT2]INVREF(I) = [F:ZPINV]INVREF
      Affzo [M:CPT2]INVREF(I)
    Endif
    #If [M:CPT2]TYP(I) = "FAPRO" Then # SI EL ORIGEN ES UNA FACTURA
    Filter [ZPIND] Where NUM = [M:CPT2]NUM(I)
    Read [ZPIND] First
    If !fstat Then
       If rowcount([ZPIND]) = 1 Then
          [M:CPT2]ITMDES(I) = [F:ZPIND]ITMDES #   ITMDES1
          Affzo  [M:CPT2]ITMDES(I)
       Else
          [M:CPT2]ITMDES(I) = ""
       Endif
    Endif
    #Endif
  Next

# SUPPORT-3469 - A—ADIR DESCRIPCI”N Y REFENCIA A CONSULTA
Return
#############################################################

