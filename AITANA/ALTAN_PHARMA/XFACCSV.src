########################################################################
$REG_VENCIMIENTOS
########################################################################
    Local Char V_MODP(3)

    [F:XBID]IBAN = ''
    For [XBID] Where [XBID]BIDNUM = V_BIDNUM

      Break
    Next

    For [XVTO] Where [F:XVTO]NUM = [F:XINV]NUM

      [F:XMODP]XX02PAM=''

      For [XMODP] Where [F:XMODP]PAM = [F:XVTO]PAM
         Break

      Next
      Wrseq 'VENCIMIE;';
&        vireblc(format$("D:YYYY[]MM[]DD", [F:XVTO]DUDDAT),0)+';';
&        ctrans( vireblc(format$("N:15.2",[F:XVTO]AMTCUR),0) ,",",".")+';';
&        [F:XMODP]XX02PAM+';';
&        [XBID]IBAN ;
&        V_BIDNUM+';';
&        ';' Using [XCSV]

    Next

Return

