#<AdxTL>@(#)0.0.0.0 $Revision$ 
## FECHA INICIAL "1999-03-10T18:38:17Z"
## SR839 - Mostrar nş de albaran en lugar de nş pedido
## SR901 - Errores de redondeos
##         Sustituir cálculos por contenido de campos que ya calcula Sage
## SR901.1 - XVT27/03/2017 Total impuestos obtenerlo de cabecera factura
##         En el caso, por ejemplo, de la FAC20017002818 comprobamos que
##         el importe de impuesto de línea está truncado, no redondeado, por lo
##         que la suma no coincide con el importe en la cabecera.
## SR951  - XVT El registro IMPREPER tiene el detalle del iva repercutido total
##         Según consta en el documento de la incidencia, no hay facturas
##         con distintos tipos de IVA en la misma factura, salvo 4 excepciones
##         por lo que obtendremos el total de base imponible y cuota en el apartado
##         LINEAS
##000728   - XVT Se solicita que los abonos entren con los importes en negativo
##        para ello se multiplica los valores de importe por  * [F:XINV]SNS
##
### SUPPORT-2859 - Ańadir comentario y número de cuenta. Linea nueva CESIONARIO despues de vencimientos


$ACTION
#infbox action

Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "APRES_CHOI"      : Gosub APRES_CHOI
  When "EXEBOUT"         : Gosub EXEBOUT
  When "SETBOUT"       : Gosub SETBOUT
#  When "AVANT_PAR"  : Gosub AVANT_PAR
   When "FIN"       : Gosub FIN
  When Default
Endcase

Return

$OUVRE
Local File SINVOICE [XINV]
Local File SINVOICED [XINVD]
Local File SINVOICED [XINVD2] Order By [F:XINVD2]NUM;[F:XINVD2]RATTAXLIN
Local File BPCUSTOMER [XBPC]
Local File SINVOICEV [XINVV]
Local File BPARTNER [XPRN]
Local File BPADDRESS [XADD]
Local File COMPANY   [XCIA]
Local File GACCDUDATE [XVTO]
Local File BID [XBID]
Local File TABCOUNTRY [XPAI]
Local File CONTACT [XCNT]
Local File CONTACTCRM [XCRM]
Local File TABUNIT [XUOM]
Local File TABPAM [XMODP]
Local File SORDER [XORD]
Return

$FIN
  Close Local File [XINV],[XINVD],[XBPC], [XINVV], [XPRN], [XADD],[XCIA], [XVTO], [XBID], [XPAI], [XCNT], [XCRM], [XUOM], [XMODP], [XINVD2], [XORD]
Return

$APRES_CHOI
            Gosub CARGA
Return

$EXEBOUT
#INFBOX "OTON"-BOUT

  If BOUT = 'X'
#infbox action
    Gosub PROCESA_CARGADOS
 Effzo [M:XFAC1]
 Gosub CARGA
 Endif

Return
$SETBOUT

Return


# Gestión de la máscara XFACCSV0 (Vertical)

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla XFACCSV0) 10/11/2016 11:41:10 (ADMIN)
######################################################################################
Subprog AV_XX02CPY(VALEUR)
Variable Char    VALEUR()
End

Subprog AS_XX02FCY(VALEUR)
Variable Char    VALEUR()
End

Subprog C_XX02FCY(VALEUR)
Variable Char    VALEUR()
End

Subprog C_XX02DATFIN(VALEUR)
Variable Date    VALEUR
End


######################################################################################
$CARGA

 Local Char CONDICION(250) (2)
 Local Integer I

 #EFFZO [M:XFAC1]
 I = 0
CONDICION = ''
CONDICION(0) = "Select NUM_0, ORIMOD_0,ACCDAT_0, BPR_0, AMTATI_0,CUR_0, XX02FACTELEC_0, XX02FEMITIDA_0, XX02FFECHA_0 From SINVOICE where CPY_0 ='"+ [M:XFAC0]XX02CPY + "'"
#& "' and ACCDAT_0 >= convert(datetime,'"+ [M:XFAC0]XX02DATDEB+ "') and ACCDAT_0 <= convert(datetime,'"+[M:XFAC0]XX02DATFIN+"')"
If num$([M:XFAC0]XX02DATDEB)<>'00/00/0000' THENL
   CONDICION(0) += " and ACCDAT_0 >= CONVERT(Datetime,'"+ [M:XFAC0]XX02DATDEB+ "')"
Endif
If num$([M:XFAC0]XX02DATFIN)<>'00/00/0000' Then
   CONDICION(0) += " and ACCDAT_0 <= CONVERT(datetime,'"+[M:XFAC0]XX02DATFIN+"')"
Endif

If [M:XFAC0]XX02EMITIDAS = 2
  CONDICION(1) = CONDICION(1) + " and XX02FEMITIDA_0 = 2"
Else
   CONDICION(1) = CONDICION(1) + " and XX02FEMITIDA_0 <> 2"
Endif
If [M:XFAC0]XX02PARTNER > ''
  CONDICION(1) = CONDICION(1) + " and BPR_0 = '"+[M:XFAC0]XX02PARTNER+"'"
Endif
If [M:XFAC0]XX02FCY <> ''
  CONDICION(1) = CONDICION(1) + " and FCY_0 = '"+[M:XFAC0]XX02FCY+"'"
Endif

If [M:XFAC0]XX02FACTELEC <> ''
  # CONDICION(1) = CONDICION(1) + " and XX02FACTELEC_0 = '"+[M:XFAC0]XX02FACTELEC+"'"
  CONDICION(1) = CONDICION(1) + " AND BPR_0 IN (SELECT BPCNUM_0 FROM BPCUSTOMER WHERE XX02FORMATOE_0 = '" + [M:XFAC0]XX02FACTELEC + "')"
Endif
#Infbox CONDICION

For (Char NUMFAC(35), Integer MODULO,Date FECHA, Char CLIENTE(35), Decimal IMPORTE, Char DIVISA(5), Char FORMATO(35), Integer EMITIDA, Date FECHEMI) From "S" Sql CONDICION As [XFAC]


    [M:XFAC1]NUM(I) = [F:XFAC]NUMFAC
    [M:XFAC1]ORIMOD(I) = [F:XFAC]MODULO
    [M:XFAC1]ACCDAT(I) = [F:XFAC]FECHA
    [M:XFAC1]BPR(I) = [F:XFAC]CLIENTE
    [M:XFAC1]AMTATI(I) = [F:XFAC]IMPORTE
    [M:XFAC1]CUR(I) = [F:XFAC]DIVISA
    [M:XFAC1]XX02FACTELEC(I) = [F:XFAC]FORMATO
    [M:XFAC1]XX02FEMITIDA(I) = [F:XFAC]EMITIDA
    [M:XFAC1]XX02FFECHA(I) = [F:XFAC]FECHEMI

     If I = 499
       Break
     Endif
     I +=1
   Next
   [M:XFAC1]NBLIG = I
     Affzo [M:XFAC1]

Return
######################################################################################

$PROCESA_CARGADOS
Local Char PROC(1)
   PROC = ''
   Local Integer I

   For I = 0 To 499

      If [M:XFAC1]XX02SELEC(I) = 2 and [M:XFAC1]NUM(I) <> ''

         Gosub PROCESA_FACTURA
         PROC = '1'
      Endif
    Next I

    If PROC = '1'
        Infbox "Fin facturas procesadas"
    Endif
Return

#############################################################
$PROCESA_FACTURA
#############################################################

Local Char ABRE_FICHEROS(1), ACTUALIZA(250)

 For [XINV] Where [F:XINV]NUM = [M:XFAC1]NUM(I)

       If ABRE_FICHEROS <> '1'
          Gosub ABRE_TXT
    ABRE_FICHEROS = '1'
       Endif

       Gosub REG_CABECERA
       Gosub REG_PARTES
       Gosub REG_LINEAS
       Gosub REG_IMPUESTOS
       Gosub REG_VENCIMIENTOS
       Gosub REG_CESIONARIO # SUPPORT-2859.NEW



        ACTUALIZA = "UPDATE SINVOICE SET XX02FEMITIDA_0 = 2 , XX02FFECHA_0 = convert(datetime,'"+date$+"')  WHERE NUM_0 = '" +[M:XFAC1]NUM(I)+"'"

        Execsql From "S" Sql ACTUALIZA

      Break
 Next
   Openo  Using  [XCSV]

Return

############################################################
$ABRE_TXT
############################################################


Local Char XFICH(50),XDIR(250),XEXT(3), FICHERO(250), XBPCORD_ANT(15), XBPAADD_ANT(15)



XDIR = "BQT\Facturae"
XFICH = [F:XINV]NUM
XEXT = "csv"
FICHERO      = filpath(XDIR,XFICH,XEXT,"","","")


Openo FICHERO,0 Using [XCSV]
Iomode adxirs chr$(13)+chr$(10) Using [XCSV]

Return

##########################################################
$REG_CABECERA
##########################################################



Local Decimal TOTAL_IMPORTE_BRUTO
Local Decimal V_QTY, V_GROPI, V_AMTTAXLIN
Local Decimal V_AMTTAXCAB : V_AMTTAXCAB = 0 #SR901.1.n
Local Char V_FORMATO(35), REG(250), REG2(15)
Local Char V_TEXTO_CANARIAS(250) # SUPPORT-3131
#Local Char VL_COMENTARIOS1(250) # SUPPORT-2859 - Ańadir comentario y número de cuenta
#Local Char VL_COMENTARIOS2(250) # SUPPORT-2859 - Ańadir comentario y número de cuenta
Global Char V_BPAADD(15)
Local Char LTIPO_FAC

   V_BPAADD = ''
   [F:XINVV]INVDAT = [00/00/0000]
   [F:XINVV]CUR = ""
   For [XINVV] Where [F:XINVV]NUM = [F:XINV]NUM
     V_BPAADD = [F:XINVV]BPAADD
     Break
   Next

   [F:XBPC]XX02FORMATOE = ""
   For [XBPC] Where [F:XBPC]BPCNUM = [F:XINV]BPR


     Break
   Next
   If [F:XBPC]XX02FORMATOE = ""
      [F:XBPC]XX02FORMATOE = "FACTURAE32"
   Endif

#   # SUPPORT-2859.sn
#   If [F:XBPC]YFACT = 2 Then
#      VL_COMENTARIOS1 = 'EL CRÉDITO REPRESENTADO EN ESTA FACTURA Y SUS DERECHOS ACCESORIOS HAN SIDO CEDIDOS A BFF FINANCE IBERIA, S.A.U, NIF A-85812360, C/ LUCHANA, 23, MADRID. '
#      VL_COMENTARIOS2 = 'ROGAMOS PAGO POR TRANSFERENCIA, A BFF: CUENTA ES06 1554 0001 65 0000029728. ESTOS DATOS SOLO SON MODIFICABLES PREVIA NOTIFICACIÓN FEHACIENTE DE BFF'
#   Else
#      VL_COMENTARIOS = ''
#   Endif
#   # SUPPORT-2859.en
   V_QTY = 0:   V_GROPI = 0
   V_AMTTAXLIN = 0
   TOTAL_IMPORTE_BRUTO = 0

   For [XINVD] Where [F:XINVD]NUM = [F:XINV]NUM
      V_QTY = V_QTY + [F:XINVD]QTY
      V_GROPI = V_GROPI + [F:XINVD]GROPRI
      TOTAL_IMPORTE_BRUTO = TOTAL_IMPORTE_BRUTO + ( [F:XINVD]QTY *[F:XINVD]GROPRI)
 #SR901.1.o     V_AMTTAXLIN = V_AMTTAXLIN + [F:XINVD]AMTTAXLIN
   Next

   V_AMTTAXCAB = [F:XINV]AMTTAX(0) + [F:XINV]AMTTAX(1) + [F:XINV]AMTTAX(2)  #SR901.1.n

   # SUPPORT-3131 - Texto Canarias
   If [F:XINV]VAC = 'CAN' Then
     V_TEXTO_CANARIAS = 'Inversión del Sujeto Pasivo'
   Else
     V_TEXTO_CANARIAS = ''
   Endif
   # SUPPORT-3131 - Texto Canarias

#   Wrseq 'VERSION;10' Using [XCSV]
   Wrseq 'VERSION;12' Using [XCSV] # SUPPORT-2859

# SUSTITUIMOS ABAJO ESTA LÍNEA
#&        ctrans( vireblc(format$("N:15.2",V_AMTTAXLIN),0) ,",",".")+';';
# POR ESTA OTRA
#&        ctrans( vireblc(format$("N:15.2",V_AMTTAXCAB),0) ,",",".")+';';

   # MODIFICACIÓN REALIZADA ESPECIFICAMENTE PARA PROBAR LAS SUBIDAS A OSAKIDECHA
   # SUPPORT-3215
   LTIPO_FAC = 'FACe'
   If [F:XINV]NUM = 'FAC20018008973' Then
        LTIPO_FAC = 'OTROS'
   Endif

   Wrseq 'CABECERA;';
&        [F:XINV]NUM+';';
&        ';';
&        format$("D:YYYY[]MM[]DD", [F:XINVV]INVDAT)+';';
&        'FC;';
&        'OO;';
&        [F:XINVV]CUR+';';
&  'es;';
&        ctrans( vireblc(format$("N:15.2",[F:XINV]AMTNOT * [F:XINV]SNS ),0) ,",",".")+';';
&        ctrans( vireblc(format$("N:15.2",V_AMTTAXCAB * [F:XINV]SNS ),0) ,",",".")+';';
&        '0.00;';
&        ctrans( vireblc(format$("N:15.2",[F:XINV]AMTATIL * [F:XINV]SNS ),0) ,",",".")+';';
&        ';';
&        ';';
&        ';';
&        ';';
&        ';';
&        ';';
&        ';';
&        ctrans( vireblc(format$("N:15.2",[F:XINV]AMTATIL * [F:XINV]SNS ),0) ,",",".")+';';
&        'INV_RECEIVED;';
&        [F:XBPC]XX02FORMATOE+';' + V_TEXTO_CANARIAS + ';';
&        LTIPO_FAC+';' Using [XCSV]
# &        'FACe'+';' Using [XCSV] # SUPPORT-3215.old

#         [F:XBPC]XX02FORMATOE+';;'; # SUPPORT-3131.OLD
#&        [F:XBPC]XX02FORMATOE+';;';   # SUPPORT-2859.old
#&        [F:XBPC]XX02FORMATOE+';'+VL_COMENTARIOS1+VL_COMENTARIOS2+';';
####&        ctrans( vireblc(Format$("N:15.2",[F:XINV]AMTNOT),0) ,",",".")+';';
Return

#############################################################################
$REG_PARTES
#############################################################################
Local Char V_DIRECCION(250) , V_PAIS(10), V_CONTACTO(100)
Global Char  V_BIDNUM(30)


   [F:XCIA]CPYNAM =''
   For [F:XCIA] Where [XCIA]CPY = [F:XINV]CPY
    V_BIDNUM = [F:XCIA]BIDNUM
     # SUPPORT-2859.sn
     #If [F:XBPC]YFACT = 2 Then
     # V_BIDNUM = 'ES0615540001650000029728'
     #Endif
     # SUPPORT-2859.en
    Break
   Next
   V_CONTACTO = ''
   For [XCNT] Where [F:XCNT]BPANUM = [F:XINV]CPY
       For [XCRM] Where [F:XCRM]CNTNUM = [F:XCNT]CCNCRM
         V_CONTACTO = [F:XCRM]CNTLNA - [F:XCRM]CNTFNA
         Break
       Next
    Next

   V_DIRECCION = ''
   [F:XADD]BPAADDLIG= ''
   [F:XADD]BPAADDLIG(1)=''
   [F:XADD]BPAADDLIG(2)=''
   [F:XADD]CTY=''
   [F:XADD]SAT=''
   [F:XADD]POSCOD=''
   [F:XADD]CRY=''
   V_PAI = 'ESP'

   For [XADD] Where [F:XADD]BPANUM = [F:XCIA]CPY & [F:XADD]BPAADD = [F:XCIA]CPY
      V_DIRECCION = [F:XADD]BPAADDLIG-[F:XADD]BPAADDLIG(1)-[F:XADD]BPAADDLIG(2)

      For [XPAI] Where [F:XPAI]CRY = [F:XADD]CRY
          V_PAIS = [F:XPAI]ISOA3
          Break
      Next
      Break
   Next

    Wrseq 'EMISOR;J;R;';
&         [F:XCIA]CRN+';';
&         [F:XCIA]CPYNAM+';';
&         ';;;';
&         V_DIRECCION+';';
&         [F:XADD]CTY+';';
&         [F:XADD]SAT+';';
&         [F:XADD]POSCOD+';';
&         V_PAIS+';';
&         ';;;;;;;;;';
&         V_CONTACTO+';;;;' Using [XCSV]

   [F:XPRN]BPRNAM= ''
   [F:XPRN]XX02CENADM = 0
   For [XPRN] Where [XPRN]BPRNUM = [F:XINV]BPR

      Break
   Next
   V_DIRECCION = ''
   [F:XADD]CTY=''
   [F:XADD]SAT=''
   [F:XADD]POSCOD=''
   [F:XADD]CRY=''
   V_PAIS = 'ESP'




    For [XADD] Where [F:XADD]BPANUM = [F:XINV]BPR & [F:XADD]BPAADD = V_BPAADD
      V_DIRECCION = [F:XADD]BPAADDLIG-[F:XADD]BPAADDLIG(1)-[F:XADD]BPAADDLIG(2)

      For [XPAI] Where [F:XPAI]CRY = [F:XADD]CRY
          V_PAIS = [F:XPAI]ISOA3
          Break
      Next
      Break
    Next

    Wrseq 'RECEPTOR;J;R;';
&         [F:XPRN]CRN+';';
&         [F:XPRN]BPRNAM+';';
&         ';;;';
&         V_DIRECCION+';';
&         [F:XADD]CTY+';';
&         [F:XADD]SAT+';';
&         [F:XADD]POSCOD+';';
&         V_PAIS+';';
&         ';;;;;;;;;;;;;' Using [XCSV]

    If [F:XPRN]XX02CENADM = 2
       Gosub ADMINISTRATIVOS
    Endif
Return

#################################################################################
$ADMINISTRATIVOS
#################################################################################
Local Char V_PAIS(10)
   V_DIRECCION = ''
   For [XADD] Where [F:XADD]BPANUM = [F:XINV]BPR &  XX02TYPCOD = 1
      V_DIRECCION = [F:XADD]BPAADDLIG-[F:XADD]BPAADDLIG(1)-[F:XADD]BPAADDLIG(2)
      V_PAIS = ''
      For [XPAI] Where [F:XPAI]CRY = [F:XADD]CRY
          V_PAIS = [F:XPAI]ISOA3
          Break
      Next
      Wrseq 'CENTRO;';
&          [F:XADD]XX02CCODE+';';
&         '01;;';
&         V_DIRECCION+';';
&         [F:XADD]CTY+';';
&         [F:XADD]SAT+';';
&         [F:XADD]POSCOD+';';
&         V_PAIS+';;';
&         [F:XADD]BPADES Using [XCSV]
     Break
   Next

   V_DIRECCION = ''
   For [XADD] Where [F:XADD]BPANUM = [F:XINV]BPR &  XX02TYPCOD = 2
      V_DIRECCION = [F:XADD]BPAADDLIG-[F:XADD]BPAADDLIG(1)-[F:XADD]BPAADDLIG(2)
      V_PAIS = ''
      For [XPAI] Where [F:XPAI]CRY = [F:XADD]CRY
          V_PAIS = [F:XPAI]ISOA3
          Break
      Next
      Wrseq 'CENTRO;';
&         [F:XADD]XX02CCODE+';';
&         '02;;';
&         V_DIRECCION+';';
&         [F:XADD]CTY+';';
&         [F:XADD]SAT+';';
&         [F:XADD]POSCOD+';';
&         V_PAIS+';;';
&         [F:XADD]BPADES Using [XCSV]
     Break
   Next


   V_DIRECCION = ''
   For [XADD] Where [F:XADD]BPANUM = [F:XINV]BPR &  XX02TYPCOD = 3
      V_DIRECCION = [F:XADD]BPAADDLIG-[F:XADD]BPAADDLIG(1)-[F:XADD]BPAADDLIG(2)
      V_PAIS = ''
      For [XPAI] Where [F:XPAI]CRY = [F:XADD]CRY
          V_PAIS = [F:XPAI]ISOA3
          Break
      Next
      Wrseq 'CENTRO;';
&         [F:XADD]XX02CCODE+';';
&         '03;;';
&         V_DIRECCION+';';
&         [F:XADD]CTY+';';
&         [F:XADD]SAT+';';
&         [F:XADD]POSCOD+';';
&         V_PAIS+';;';
&         [F:XADD]BPADES Using [XCSV]
     Break
   Next

Return

########################################################################
$REG_LINEAS
########################################################################
    Local Decimal BASE_IMPONIBLE,CUOTA, TOTAL_BRUTO, DESCUENTO, DTO_TOTAL_LINEA
    Local Decimal BI_IMPREPER, CUOTA_IMPREPER, RATTAX_IMPREPER  #sr951.n
    Local Char V_UOM(3), V_NUMPED(30), V_REFPED(30)
    Local Decimal DESCUENTO1, DESCUENTO2

    BI_IMPREPER=0
    CUOTA_IMPREPER=0
    RATTAX_IMPREPER=0

    For [XINVD] Where [F:XINVD]NUM = [F:XINV]NUM

        V_NUMPED = ''
        V_REFPED = ''
        V_NUMPED = [F:XINVD]SDHNUM   #SR839.n

        For [XORD] Where [F:XORD]SOHNUM = [F:XINVD]SOHNUM
           If V_NUMPED='' Then                      #SR839.n
             V_NUMPED = [F:XINVD]SOHNUM
           Endif                                    #SR839.n
           V_REFPED = [F:XORD]CUSORDREF

           Break
        Next
#       DESARROLLO PARA NUEVO CAMPO
        # MAB. BUSCAR LA REFERENCIA SI ES BLANCO
        If V_REFPED = '' Then
            Read [XINVV]SIV0=[F:XINV]NUM
            If !fstat Then
              V_REFPED = [F:XINVV]INVREF
            Endif
        Endif
        # BUSCAR ORIGEN FACTURA PARA RECTIFICATIVAS
        # CAMPO ORIGEN DE LA RECTIFICATIVA
        If V_NUMPED = '' Then
              V_NUMPED = [F:XINV]YNUMORIGEN
        Endif



      V_UOM=''
      For [XUOM] Where [F:XUOM]UOM = [F:XINVD]SAU
        V_UOM = [F:XUOM]XX02XUNINT
        Break
      Next

#      Base_imponible = [F:XINVD]QTY * [F:XINVD]NETPRI   #SR901.o
      BASE_IMPONIBLE = [F:XINVD]BASTAXLIN                #SR901.o
      BI_IMPREPER=BI_IMPREPER+BASE_IMPONIBLE             #sr951.n
#      Cuota = Base_imponible * [F:XINVD]RATTAXLIN / 100 #SR901.o
      CUOTA = [F:XINVD]AMTTAXLIN(0)+[F:XINVD]AMTTAXLIN(1)#SR901.n
      CUOTA_IMPREPER = CUOTA_IMPREPER + CUOTA            #sr951.n
      RATTAX_IMPREPER = [F:XINVD]RATTAXLIN               #sr951.n
      TOTAL_BRUTO = [F:XINVD]GROPRI * [F:XINVD]QTY
# Nuevo cálculo del bruto

#     Dto_Total_Linea = 0
#     If [F:XINVD]DISCRGVAL1 > 0
#         Dto_Total_Linea  = [F:XINVD]GROPRI * [F:XINVD]DISCRGVAL1 / 100 * [F:XINVD]QTY
#     Endif
#     If [F:XINVD]DISCRGVAL2 > 0
#         Dto_Total_Linea = Dto_Total_Linea + ([F:XINVD]GROPRI * [F:XINVD]DISCRGVAL2 / 100 * [F:XINVD]QTY)
#     Endif
#     Total_bruto = [F:XINVD]AMTNOTLIN + Dto_Total_Linea
#



      Wrseq 'LINEA;';
&        [F:XINVD]ITMDES1+';';
&        ctrans( vireblc(format$("N:15.2",[F:XINVD]QTY),0) ,",",".")+';';
&        ctrans( vireblc(format$("N:15.4",[F:XINVD]GROPRI * [F:XINV]SNS ),0) ,",",".")+';';
&        V_UOM+';';
&        '01;';
&        ctrans( vireblc(format$("N:15.2",[F:XINVD]RATTAXLIN),0) ,",",".")+';';
&  ctrans( vireblc(format$("N:15.2",BASE_IMPONIBLE * [F:XINV]SNS ),0) ,",",".")+';';
&        ctrans( vireblc(format$("N:15.2",CUOTA * [F:XINV]SNS ),0) ,",",".")+';';
&        ';;;;;;';
&        ctrans( vireblc(format$("N:15.2",TOTAL_BRUTO * [F:XINV]SNS ),0) ,",",".")+';';
&        ctrans( vireblc(format$("N:15.2",[F:XINVD]AMTNOTLIN * [F:XINV]SNS ),0) ,",",".")+';';
&        V_NUMPED+';';
&        [F:XINVD]ITMREF+';';
&        [F:XINV]XASIGNCONT +';';
&        ';';
&        vireblc(format$("D:YYYY[]MM[]DD", [F:XINVD]STRDAT),0)+';';
&        vireblc(format$("D:YYYY[]MM[]DD", [F:XINVD]ENDDAT),0)+';';
&        ';'+V_REFPED+';';
&        [F:XINV]XASIGNCONT Using [XCSV]

     ###### DESCUENTOS #######
#SR901.bn
     DESCUENTO1=0
     DESCUENTO2=0
     If [F:XINVD]DISCRGVAL1 > 0 and [F:XINVD]DISCRGVAL2 = 0 Then
        #Descuento1 = ar2(([F:XINVD]GROPRI - [F:XINVD]NETPRI) * [F:XINVD]QTY)
        DESCUENTO1 = ([F:XINVD]GROPRI * [F:XINVD]QTY) - [F:XINVD]AMTNOTLIN
        DESCUENTO2 = 0
     Endif
     If [F:XINVD]DISCRGVAL2 > 0 and [F:XINVD]DISCRGVAL1 = 0 Then
        #Descuento1 = ar2(([F:XINVD]GROPRI - [F:XINVD]NETPRI) * [F:XINVD]QTY)
        DESCUENTO1 = ([F:XINVD]GROPRI * [F:XINVD]QTY) - [F:XINVD]AMTNOTLIN
        DESCUENTO2 = 0
     Endif
     If [F:XINVD]DISCRGVAL1 > 0 and [F:XINVD]DISCRGVAL2 > 0 Then
        DESCUENTO1 = arr(([F:XINVD]GROPRI * [F:XINVD]DISCRGVAL1 / 100),0.01)
#        Descuento2 = arr(([F:XINVD]GROPRI * [F:XINVD]DISCRGVAL2 / 100),0.01)
        DESCUENTO2 = ([F:XINVD]GROPRI * [F:XINVD]QTY) - DESCUENTO1
     Endif

     If DESCUENTO1 > 0 Then
         Wrseq 'DCTOLIN;';
&        'Dto 1;';
&        ctrans( vireblc(format$("N:15.2",[F:XINVD]DISCRGVAL1),0) ,",",".")+';';
&        ctrans( vireblc(format$("N:15.2",DESCUENTO1 * [F:XINV]SNS ),0) ,",",".")
&        Using [XCSV]
     Endif

     If DESCUENTO2 > 0 Then
         Wrseq 'DCTOLIN;';
&        'Dto 2;';
&        ctrans( vireblc(format$("N:15.4",[F:XINVD]DISCRGVAL2),0) ,",",".")+';';
&        ctrans( vireblc(format$("N:15.4",DESCUENTO2 * [F:XINV]SNS ),0) ,",",".")
&        Using [XCSV]
     Endif
#SR901.en

#SR901.bo
######     If [F:XINVD]DISCRGVAL1 > 0
######         Descuento = arr ([F:XINVD]GROPRI * [F:XINVD]DISCRGVAL1 / 100 , 0.0001)
#######         Descuento = Format$("N:15.2", [F:XINVD]GROPRI * [F:XINVD]DISCRGVAL1 / 100)
######         Descuento = ar2 ( Descuento *  [F:XINVD]QTY)
######
#######         Descuento = [F:XINVD]GROPRI * [F:XINVD]DISCRGVAL1 / 100 * [F:XINVD]QTY
######
######         WRSEQ 'DCTOLIN;';
######&        'Dto 1;';
######&        ctrans( vireblc(Format$("N:15.2",[F:XINVD]DISCRGVAL1),0) ,",",".")+';';
######&        ctrans( vireblc(Format$("N:15.2",DESCUENTO),0) ,",",".")
######&        using [XCSV]
######     Endif
######     If [F:XINVD]DISCRGVAL2 > 0
######         Descuento = arr ([F:XINVD]GROPRI * [F:XINVD]DISCRGVAL2 / 100 , 0.0001)
#######         Descuento = Format$("N:15.2", [F:XINVD]GROPRI * [F:XINVD]DISCRGVAL2 / 100)
######         Descuento = ar2 ( Descuento *  [F:XINVD]QTY)
######
#######         Descuento = [F:XINVD]GROPRI * [F:XINVD]DISCRGVAL2 / 100 * [F:XINVD]QTY
######
######         WRSEQ 'DCTOLIN;';
######&        'Dto 2;';
######&        ctrans( vireblc(Format$("N:15.4",[F:XINVD]DISCRGVAL2),0) ,",",".")+';';
######&        ctrans( vireblc(Format$("N:15.4",DESCUENTO),0) ,",",".")
######&        using [XCSV]
######     Endif
#SR901.eo

    Next

Return

