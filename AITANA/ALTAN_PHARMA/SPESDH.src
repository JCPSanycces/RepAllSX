# Gestión de la máscara SDH1 (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla SDH1) 31/10/2017 10:01:08 (ADMIN)
######################################################################################
$ACTION
Case ACTION
 When "SETBOUT"  : Gosub $SETBOUT
 When Default
Endcase
Return



######################################################################################
$SETBOUT
  Case BOUT
    When "6" Gosub $GENERA_XML
   When Default
   Endcase
Return

$GENERA_XML
  Local Integer YN : YN = 2
  Local Char LARTICULO, LLOTE
  LARTICULO = [M:SDH1]ITMREF(nolign-1)
  LLOTE = [M:SDH1]LOT(nolign-1)

  Call OUINON("¿Desea descargar ficheros XML en LOCAL?", YN) From GESECRAN
  If YN = 2 Then
    Call GENERA_FICHEROS_XML(LARTICULO, LLOTE, "", "LOCAL") From XSERIALIZACION
  Else
   Call GENERA_FICHEROS_XML(LARTICULO, LLOTE, "", "") From XSERIALIZACION
  Endif
  Infbox "Ficheros XML Generados"
Return

Subprog C_SHIDAT(VALEUR)
Variable Date    VALEUR
  If VALEUR < date$ Then
    Call MESSAGE ("La fecha de expedición ha de ser mayor o igual a la fecha actual") From GESECRAN
    mkstat = 2
  Endif
End


######################################################################################

