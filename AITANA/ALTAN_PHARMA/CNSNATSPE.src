#<AdxTL>@(#)0.0.0.0 $Revision$
#############################################################
$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "SETBOUT"    : Gosub SETBOUT
  When Default
Endcase
Return

#############################################################
$OUVRE

  If !clalev([ZPINV]) Then : Local File PINVOICE  [ZPINV] : Endif
  If !clalev([ZPIND]) Then : Local File PINVOICED [ZPIND] : Endif
Return

#############################################################
$SETBOUT

  For I = 0 To [M:NAT2]NBLIG-1
    # If [M:NAT2]NUM(I) = 'FAP10017001276' Then : Infbox "FACTURA " + [M:NAT2]NUM(I) : Endif
    Read [ZPINV]PIH0=[M:NAT2]NUM(I)
    If !fstat Then
      [M:NAT2]INVREF(I) = [F:ZPINV]INVREF
      Affzo [M:NAT2]INVREF(I)
    Endif
    #If [M:CPT2]TYP(I) = "FAPRO" Then # SI EL ORIGEN ES UNA FACTURA
    Filter [ZPIND] Where NUM = [M:NAT2]NUM(I)
    Read [ZPIND] First
    If !fstat Then
       If rowcount([ZPIND]) = 1 Then
          [M:NAT2]ITMDES(I) = [F:ZPIND]ITMDES # ITMDES1
          Affzo  [M:NAT2]ITMDES(I)
       Else
          [M:NAT2]ITMDES(I) = ""
       Endif
    Endif
    #Endif
  Next


Return
#############################################################

