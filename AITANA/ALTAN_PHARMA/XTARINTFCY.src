#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
    Case ACTION
        When "TARIFACH"    : Gosub XTARIFACH
    Endcase
Return

$XTARIFACH
#XVT03/01/2017.bn
#La siguente comprobaciˇn evita que falle la ejecuciˇn si no estß en la pantalla de ˇrdenes de compra
If !clalev([M:POH0]) Then
   Return
Endif
#XVT03/01/2017.en
If clalev([F:ITV])=0 : Local File ITMMVT [ITV] : Endif
If GABREV = "POH"
    If [M:POH0]BETFCY = 2 and [M:POH0]BETCPY = 1 #APLICA PARA INTERPLANTA Y NO PARA INTERSOCIEDAD
        Read [BPR] BPR0=[M:POH0]BPSNUM
        If !fstat
            Read [ITV] ITV0= [M:POH2]ITMREF(nolign-1); [F:BPR]FCY
            If !fstat
                MONTANT(0) = arr([F:ITV]AVC,0.0001)
            Endif
            If MONTANT(0)=0 Then
               If clalev([F:ITC])=0 : Local File ITMCOST [ITC] : Endif
               Filter [F:ITC] Where STOFCY=[F:BPR]FCY and ITMREF=[M:POH2]ITMREF(nolign-1) and ITCSTRDAT<=[M:POH0]ORDDAT and ITCENDDAT>=[M:POH0]ORDDAT
               For [F:ITC]
                  MONTANT(0)= arr([F:ITC]CSTTOT,0.0001)
               Next
               Filter [F:ITC]
            Endif
        Endif
    Endif
Endif

Return


