#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION

Case ACTION
 When "AV_AFFICHE"   : Gosub AV_AFFICHE
 When Default
Endcase
Return


Return

####################################################################
#**
#*  Ticket #001043 - AÒadir la fecha de caducidad.
#*!
$AV_AFFICHE

  If !clalev([F:ZSTO]) Then : Local File STOLOT [ZSTO] : Endif

  For I = 0 To [M:SEA2]NBLIG-1
    Read [ZSTO]STL0 = [M:SEA2]ITMREF(I);[M:SEA2]LOT(I);[M:SEA2]SLO(I)
    If !fstat Then
      [M:SEA2]ZFECHACAD(I) = [F:ZSTO]SHLDAT
    Endif
  Next
  Affzo [M:SEA2]
  Close File [ZSTO]
Return

####################################################################
# JC.14092020.STR - YSP01
# Mostrar categorÌa en la consulta de Ubicaciones
Funprog GET_TCLCOD(PITMREF)
Value Char PITMREF

Local Char LRES(100)

  If !clalev([F:ITM0]) Then : Local File ITMMASTER [F:ITM0] : Endif
  Read [F:ITM0]ITM0 = PITMREF
  If !fstat Then
    LRES = [F:ITM0]TCLCOD
  Endif
  Close Local File [ITM0]

End LRES
# JC.14092020.END - YSP01

