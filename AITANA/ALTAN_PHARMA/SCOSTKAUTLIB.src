#<AdxTL>@(#)2.0.0.0 $Revision$
#------------------------------------------------------------------------#
# **** SCOSTKAUTLIB selon MTKAUTLIB                        GA Oct 2005   #
#                                                                        #
# Bibliotheque de traitements liťs ŗ la maj automatique des stocks       #
# pour les achats de sous-traitance                                      #
#                                                                        #
# Principaux traitements :                                               #
# $LOAD_ALP                                                              #
# $LOAD_STW_ENTREE                                                       #
# $LOAD_STW_SORTIE                                                       #
# $LOAD_STW_ANNULE_ENTREE                                                #
# $LOAD_STW_ANNULE_SORTIE                                                #
#                                                                        #
# **** SCOSTKAUTLIB selon Extraits de code MTKLIB        GA Avril 2006   #
#                                                                        #
# $MAJ_STKENT_SCI  Maj qtť rťceptionnťe article lancť et entrťe en stock #
# $MAJ_STKENT_SCS  Maj qtť rťceptionnťe + prix du service                #
#                                                                        #
# $MAJ_STKSOR_SCM  Backflush composants mis ŗ dispo du sous-traitant     #
# $MAJ_STKPRI_SCM  Maj prix facturť composants fournis par le ss-traitant#
#                                                                        #
# $RAZ_STKENT_SCI  Annule entrťe en stock article lancť                  #
#                  Suppression de rťception ou Retour                    #
# $RAZ_STKENT_SCS  Annule qtť rťceptionnťe du service                    #
#                  Suppression de rťception ou Retour                    #
# $RAZ_STKSOR_SCM  Annule backflush (suppression rťception) ???          #
# $RAZ_STKPRI_SCM  Annule prix facturť composants fournis par le ss-trait#
#                                                                        #
# Subprog READ_POQW(LITMREF,LVCRNUM,LVCRLIN,LVCRSEQ,LPOHNUM,LPOPLIN,LPOQSEQ)
#                                                                        #
# NB: On suppose que l'on se trouve ŗ l'intťrieur d'une transaction      #
#------------------------------------------------------------------------#

##########################################################################
# 02/2007 dans SCOSRV CPNITMREF devient SRVITMREF                        #
##########################################################################

################################################################
# Prťparation de la sortie MatiŤre sur les composants
# mis ŗ disposition du sous-traitant (consommťs ŗ la rťception)
# les lignes [F:PTH],[F:PTD] et [F:SCM] doivent Ítre chargťes
# WUSEQTY doit contenir la qtť de matiŤre ŗ sortir
################################################################
$LOAD_ALP_SCM
Raz [M:ALP]ALLQTY,[M:ALP]ALLQTYSHT
Raz [M:ALP]DESQTY,[M:ALP]DESQTYSHT
Raz [M:ALP]ALLDAT

# GA 24/04/2009 selon SCOALL: l'allocation d'origine est rattachťe ŗ l'EO
#[M:ALP]VCRTYP     = 6              : # Type de piŤce 6=Rťception
#[M:ALP]VCRNUM     = [F:PTD]PTHNUM
#[M:ALP]VCRLIN     = [F:PTD]PTDLIN  : # bien que la rťception concerne l'article lancť, indirectement la sortie matiŤre ...
#[M:ALP]VCRSEQ     = 0
[M:ALP]STOFCY     = [F:SCM]STOFCY
[M:ALP]ITMREF     = [F:SCM]CPNITMREF
[M:ALP]QTY        = WUSEQTY
[M:ALP]TYPQTY     = 2
[M:ALP]BESDAT     = [F:PTD]RCPDAT
[M:ALP]VCRTYPORI  = 36
[M:ALP]VCRNUMORI  = [F:SCM]SCONUM
[M:ALP]VCRLINORI  = [F:SCM]SCILIN
[M:ALP]VCRSEQORI  = [F:SCM]SCMLIN
Case [F:SCM]ALLSTA
     When 1:      [M:ALP]ALLTYPORI = 0
     When 2,3:    [M:ALP]ALLTYPORI = 1    # allocation globale
     When 4,5:    [M:ALP]ALLTYPORI = 2    # allocation dťtaillťe
Endcase

# Ajout GA 24/04/2009 selon SCOALL
[M:ALP]VCRTYP    = 36
[M:ALP]VCRNUM    = [F:SCM]SCONUM
[M:ALP]VCRLIN    = [F:SCM]SCILIN
[M:ALP]VCRSEQ    = [F:SCM]SCMLIN
[M:ALP]PCU       = [F:SCM]STU
[M:ALP]PCUSTUCOE = 1
[M:ALP]DLVDAT    = [F:SCM]DLVDAT
[M:ALP]PECRER    = 1
[M:ALP]PECINTLOC = 1  # Pas d'emplacement interne pour les matiŤres sous-traitance V6 05/2008
[M:ALP]PECPLFLOC = 1  # Prise en cpte empl quai : Oui ? idem OF : Non TS 02/2009
[M:ALP]PECCUNLOK = 2  # Prise en cpte stock en cours inventaire : Oui ? idem OF
# Les champs STA, LOC et LOT sont des filtres exclusifs (pas prťfťrentiels)
[M:ALP]STA       = [F:SCM]STA
[M:ALP]LOT       = [F:SCM]LOT
[M:ALP]LOC       = [F:SCM]LOC
[M:ALP]PECSCOLOC = 2              : # Prise en compte emplacements sous-traitants
[M:ALP]PECOWNER  = [F:SCM]STOFCY  : # Site propriťtaire du stock
# Si emplacement atelier c'est celui qui se trouve sur la ligne matiŤre
[M:ALP]STOLOC    = [F:SCM]LOC     : # FQ 54076 (ligne remise)
[M:ALP]PECQLYCTL = 2
[M:ALP]BPRNUM    = [F:SCO]BPRNUM    : # Mail TS du 11/04/06
[M:ALP]BPAADD    = [F:SCI]BPAADD    : # Mail TS du 11/04/06
[M:ALP]MVTDES    = mess(29,704,1) : # "Sortie ordre de sous-traitance"

Return

################################################################
# Prťparation de la sortie MatiŤre sur les composants
# non prťvus et consommťs ŗ la rťception
# les lignes [F:PTH],[F:PTD] et [F:PWS] doivent Ítre chargťes
# WUSEQTY doit contenir la qtť de matiŤre ŗ sortir
################################################################
$LOAD_ALP_PWS
Raz [M:ALP]ALLQTY,[M:ALP]ALLQTYSHT
Raz [M:ALP]DESQTY,[M:ALP]DESQTYSHT
Raz [M:ALP]ALLDAT

[M:ALP]STOFCY     = [F:SCI]PRHFCY
[M:ALP]ITMREF     = [F:PWS]ITMREF
[M:ALP]QTY        = WUSEQTY
[M:ALP]TYPQTY     = 2
[M:ALP]BESDAT     = [F:PTD]RCPDAT
[M:ALP]VCRTYPORI  = 36
[M:ALP]VCRNUMORI  = [F:SCI]SCONUM
[M:ALP]VCRLINORI  = [F:SCI]SCILIN
[M:ALP]VCRSEQORI  = 0
[M:ALP]ALLTYPORI = 0

[M:ALP]VCRTYP    = 36
[M:ALP]VCRNUM    = [F:SCI]SCONUM
[M:ALP]VCRLIN    = [F:SCI]SCILIN
[M:ALP]VCRSEQ    = 0
[M:ALP]PCU       = [F:PWS]STU
[M:ALP]PCUSTUCOE = 1
[M:ALP]DLVDAT    = [F:PTD]RCPDAT #??? [F:SCM]DLVDAT
[M:ALP]PECRER    = 1
[M:ALP]PECINTLOC = 1  # Pas d'emplacement interne pour les matiŤres sous-traitance V6 05/2008
[M:ALP]PECPLFLOC = 1  # Prise en cpte empl quai : Oui ? idem OF : Non TS 02/2009
[M:ALP]PECCUNLOK = 2  # Prise en cpte stock en cours inventaire : Oui ? idem OF
# Les champs STA, LOC et LOT sont des filtres exclusifs (pas prťfťrentiels)
#[M:ALP]STA       = [F:SCM]STA
#[M:ALP]LOT       = [F:SCM]LOT
[M:ALP]LOC       = [F:SCI]LOC
[M:ALP]PECSCOLOC = 2              : # Prise en compte emplacements sous-traitants
[M:ALP]PECOWNER  = [F:SCI]PRHFCY  : # Site propriťtaire du stock
# Si emplacement atelier c'est celui qui se trouve sur la ligne matiŤre
[M:ALP]STOLOC    = [F:SCI]LOC
[M:ALP]PECQLYCTL = 2
[M:ALP]BPRNUM    = [F:SCO]BPRNUM    : # Mail TS du 11/04/06
[M:ALP]BPAADD    = [F:SCI]BPAADD    : # Mail TS du 11/04/06
[M:ALP]MVTDES    = mess(29,704,1) : # "Sortie ordre de sous-traitance"

Return

################################################################
# Prťparation de la sortie MatiŤre sur les composants
# mis ŗ disposition du sous-traitant (consommťs ŗ la rťception)
# les lignes [F:PTH],[F:PTD] et [F:SCM] doivent Ítre chargťes
################################################################
$LOAD_STW_SORTIE_SCM              : # selon LOAD_STW de MTKAUTLIB
Dbgaff
Raz [M:STW]
[M:STW]TRSTYP    = 29             : # Menu 701 29=Sortie ordre de sous-traitance
[M:STW]VCRTYP    = 6              : # Type de piŤce 6=Rťception
[M:STW]VCRNUM    = [F:PTD]PTHNUM
[M:STW]VCRLIN    = [F:PTD]PTDLIN  : # bien que la rťception concerne l'article lancť, indirectement la sortie matiŤre ...
[M:STW]STOFCY    = [F:SCM]STOFCY
[M:STW]ITMREF    = [F:SCM]CPNITMREF
[M:STW]CCECOD    = "STKSEO"       : # Code paramťtrage  avant STKSOF Sortie OF
[M:STW]TRSFAM    = [F:PTR]TRSFAMS : # FQ 60108 GA 11/2009 avant [F:PTD]TRSFAM
[M:STW]TRSCOD    = [F:PTR]TRSCODS : # FQ 60108 GA 11/2009 avant [F:PTH]TRSCOD
[M:STW]ENTCOD    = [F:PTR]ENTCODS : # FQ 60108 GA 11/2009 avant [F:PTH]ENTCOD !!!
[M:STW]MVTDES    = mess(29,704,1) : # "Sortie ordre de sous-traitance"
[M:STW]IPTDAT    = [F:PTD]RCPDAT
[M:STW]VCRTYPORI = 36
[M:STW]VCRNUMORI = [F:SCM]SCONUM
[M:STW]VCRLINORI = [F:SCM]SCILIN
[M:STW]VCRSEQORI = [F:SCM]SCMLIN
[M:STW]TRAFLG    = 2              : # Trace normal
[M:STW]CUR       = GLOCALDEV
[M:STW]BPRNUM    = ""
Return

################################################################
# Prťparation de la sortie MatiŤre sur les composants
# mis ŗ disposition du sous-traitant (consommťs ŗ la rťception)
# les lignes [F:PTH],[F:PTD] et [F:SCM] doivent Ítre chargťes
################################################################
$LOAD_STW_SORTIE_PWS              : # selon LOAD_STW de MTKAUTLIB
Dbgaff
Raz [M:STW]
[M:STW]TRSTYP    = 29             : # Menu 701 29=Sortie ordre de sous-traitance
[M:STW]VCRTYP    = 6              : # Type de piŤce 6=Rťception
[M:STW]VCRNUM    = [F:PTD]PTHNUM
[M:STW]VCRLIN    = [F:PTD]PTDLIN  : # bien que la rťception concerne l'article lancť, indirectement la sortie matiŤre ...
[M:STW]STOFCY    = [F:SCI]PRHFCY
[M:STW]ITMREF    = [F:PWS]ITMREF
[M:STW]CCECOD    = "STKSEO"       : # Code paramťtrage  avant STKSOF Sortie OF
[M:STW]TRSFAM    = [F:PTR]TRSFAMS : # FQ 60108 GA 11/2009 avant [F:PTD]TRSFAM
[M:STW]TRSCOD    = [F:PTR]TRSCODS : # FQ 60108 GA 11/2009 avant [F:PTH]TRSCOD
[M:STW]ENTCOD    = [F:PTR]ENTCODS : # FQ 60108 GA 11/2009 avant [F:PTH]ENTCOD !!!
[M:STW]MVTDES    = mess(29,704,1) : # "Sortie ordre de sous-traitance"
[M:STW]IPTDAT    = [F:PTD]RCPDAT
[M:STW]VCRTYPORI = 36
[M:STW]VCRNUMORI = [F:SCI]SCONUM
[M:STW]VCRLINORI = [F:SCI]SCILIN
[M:STW]VCRSEQORI = 0
[M:STW]TRAFLG    = 2              : # Trace normal
[M:STW]CUR       = GLOCALDEV
[M:STW]BPRNUM    = ""
Return
################################################################
# Prťparation de l'entrťe en stock de l'article sous-traitť
# les lignes [F:PTD] et [F:SCI] doivent Ítre chargťes
# WSTOSEQ et WMVTDES doivent Ítre renseignťs
################################################################
$LOAD_STW_ENTREE
Dbgaff
  # Maj stocks
  Raz [M:STW]
  [M:STW]STOFCY    = [F:PTD]PRHFCY            : # Site rťception
  [M:STW]TRSTYP    = 3                        : # Type mouvement (M.704) 3=Rťception fournisseur
  [M:STW]VCRTYP    = 6                        : # Type piŤce     (M.701) 6=Rťception
  [M:STW]VCRNUM    = [F:PTD]PTHNUM            : # Numťro piŤce
  [M:STW]VCRLIN    = [F:PTD]PTDLIN            : # Numero ligne
  [M:STW]ITMREF    = [F:SCI]ITMREF            : # Article lancť
  [M:STW]BPRNUM    = [F:PTD]BPSNUM            : # Tiers
  [M:STW]PJT       = [F:SCI]PJT               : # Affaire
  [M:STW]TRSFAM    = [F:PTD]TRSFAM            : # Famille mouvement
  [M:STW]IPTDAT    = [F:PTD]RCPDAT            : # Date imputation
  [M:STW]CCECOD    = "STKEEO"                 : # Code paramťtrage sections avant STKEOF Entrťe OF
  [M:STW]ENTCOD    = [F:PTR]ENTCOD              # FQ 60108 GA 11/2009 LOAD_STW_ENTREE
  [M:STW]VCRTYPORI = 36
  [M:STW]VCRNUMORI = [F:SCI]SCONUM
  [M:STW]VCRLINORI = [F:SCI]SCILIN
  [M:STW]VCRSEQORI = 0
  [M:STW]TRAFLG    = 2                        : # Trace normal
  [M:STW]CUR       = GLOCALDEV
  [M:STW]BETCPY    = [F:PTH]BETCPY              # Issue 91105 GA/TS 07/2013
  If [F:PTH]BETFCY = 2                          # Issue 91105 GA/TS 07/2013
     [M:STW]TRFFCY = [F:PTD]LINSTOFCY           # Issue 91105 GA/TS 07/2013
  Endif

  Raz [M:STW]PRIORDH, [M:VALW]
  # le prix par defaut est proposť en saisie de la ligne de rťception Mail CCC du 16/06/2006
  #[M:STW]PRIORDH= func STKVAL.DEFPRISCI(!GIMPORT*WSTOSEQ)
  [M:STW]PRIORDH = func STKVAL.DEFPRISCI(WSTOSEQ)
  #----- Alimentation du masque de travail -----#
  [M:STW]MVTDES = WMVTDES                     : # Dťsignation mouvement
Return

################################################################
# Prťparation de l'entrťe en stock de l'article sous-traitť
# les lignes [F:PTD] et [F:SCI] doivent Ítre chargťes
################################################################
$LOAD_STW_ANNULE_ENTREE   : # extrait de ANNULE_SUIVITM de SUBMTKC
Dbgaff
  # Maj stocks
    Raz [M:STW]
    [M:STW]MAJCOD   = "A"
    [M:STW]STOFCY   = [F:SCI]PRHFCY            : # Site
    [M:STW]TRSTYP   = 3                        : # Type mouvement (M.704)
    [M:STW]VCRTYP   = 6                        : # Type piŤce (M.701)
    [M:STW]VCRNUM   = [F:PTD]PTHNUM            : # Numťro piŤce
    [M:STW]VCRLIN   = [F:PTD]PTDLIN            : # Numero ligne piŤce
    [M:STW]ITMREF   = [F:PTD]ITMREF            : # Article
    [M:STW]BPRNUM   = ""                       : # Tiers
    [M:STW]PJT      = [F:SCI]PJT               : # Affaire
    [M:STW]TRSCOD   = [F:PTH]TRSCOD            :
    [M:STW]TRSFAM   = [F:PTD]TRSFAM            :
    [M:STW]IPTDAT   = GWIPTDAT                 : # Date imputation
    [M:STW]PRIORDH  = 0                        : # Prix de l'ordre
    [M:STW]TRAFLG   = 2                        : # Trace normal
    [M:STW]CCECOD   = "STKEEO"
    [M:STW]TRAFLG   = 2                        : # Trace normal
    [M:STW]CUR = GLOCALDEV
    [M:STW]BPRNUM = ""

    If !clalev([M:ENM])  Local Mask STOENTM [ENM]  : Endif
    Raz [M:ENM]
Return

################################################################
# Prťparation de l'entrťe en stock de l'article sous-traitť
# les lignes [F:PTD] et [F:SCM] doivent Ítre chargťes
################################################################
$LOAD_STW_ANNULE_SORTIE : # extrait de ANNULE_SUIVMAT de SUBMTKC
Dbgaff
# Maj stocks
Raz [M:STW]
[M:STW]MAJCOD   = "A"
[M:STW]STOFCY   = [F:SCM]STOFCY            : # Site
[M:STW]TRSTYP   = 29                       : # Type mouvement (M.704)
[M:STW]VCRTYP   = 6                        : # Type piŤce (M.701)
[M:STW]VCRNUM   = [F:PTD]PTHNUM            : # Numťro piŤce
[M:STW]VCRLIN   = [F:PTD]PTDLIN            : # Numero ligne piŤce
[M:STW]ITMREF   = [F:SCM]CPNITMREF
[M:STW]BPRNUM   = ""                       : # Tiers
[M:STW]PJT      = [F:SCI]PJT               : # Affaire
[M:STW]TRSCOD   = [F:PTH]TRSCOD            :
[M:STW]TRSFAM   = [F:PTD]TRSFAM            :
[M:STW]IPTDAT   = GWIPTDAT                 : # Date imputation
[M:STW]PRIORDH  = 0                        : # Prix de l'ordre
[M:STW]TRAFLG   = 2                        : # Trace normal
[M:STW]CCECOD   = "STKSEO"
[M:STW]VCRTYPORI = 36
[M:STW]VCRNUMORI = [F:SCM]SCONUM
[M:STW]VCRLINORI = [F:SCM]SCILIN
[M:STW]VCRSEQORI = [F:SCM]SCMLIN
[M:STW]TRAFLG   = 2                        : # Trace normal
[M:STW]CUR = GLOCALDEV
[M:STW]BPRNUM = ""

If !clalev([M:SOM])  Local Mask STOSORM [SOM]  : Endif
Raz [M:SOM]
Return

################################################################
# Prťparation de l'entrťe en stock de l'article sous-traitť
# les lignes [F:PTD] et [F:STJK] doivent Ítre chargťes
################################################################
$LOAD_STW_ANNULE_SORSTJK
Dbgaff
# Maj stocks
Raz [M:STW]
[M:STW]MAJCOD   = "A"
[M:STW]STOFCY   = [F:STJK]STOFCY            : # Site
[M:STW]TRSTYP   = 29                       : # Type mouvement (M.704)
[M:STW]VCRTYP   = 6                        : # Type piŤce (M.701)
[M:STW]VCRNUM   = [F:PTD]PTHNUM            : # Numťro piŤce
[M:STW]VCRLIN   = [F:PTD]PTDLIN            : # Numero ligne piŤce
[M:STW]ITMREF   = [F:STJK]ITMREF
[M:STW]BPRNUM   = ""                       : # Tiers
[M:STW]PJT      = [F:SCI]PJT               : # Affaire
[M:STW]TRSCOD   = [F:PTH]TRSCOD            :
[M:STW]TRSFAM   = [F:PTD]TRSFAM            :
[M:STW]IPTDAT   = GWIPTDAT                 : # Date imputation
[M:STW]PRIORDH  = 0                        : # Prix de l'ordre
[M:STW]TRAFLG   = 2                        : # Trace normal
[M:STW]CCECOD   = "STKSEO"
[M:STW]VCRTYPORI = 36
[M:STW]VCRNUMORI = [F:STJK]VCRNUM
[M:STW]VCRLINORI = [F:STJK]VCRLIN
[M:STW]VCRSEQORI = 0 # [F:STJK]VCRSEQ
[M:STW]TRAFLG   = 2                        : # Trace normal
[M:STW]CUR = GLOCALDEV
[M:STW]BPRNUM = ""

If !clalev([M:SOM])  Local Mask STOSORM [SOM]  : Endif
Raz [M:SOM]
Return

#########################################################################
# Etiquette appelťe par
# - MAJ_STK(SCOSTKLIB)
# - Ecran de rťception                          <Entrťe de l'article SCI>
# La ligne [F:SCI]est chargťe en mťmoire
#########################################################################
$MAJ_STKENT_SCI
Local Integer WITMSTA
Local Decimal LQTA,LSHT
Local Integer LNBR,LNBJ
Local Integer WSTOSEQ, J      : # GA
Local Char    WMVTDES(50)     : # GA dťsignation du mvt
Local Char    WENTCOD(GLONGAU): # GA code piece auto stock
Local Char    WTRSCOD(GLONADI): # GA code    mvt stock - table diverse 14
Local Char    WTRSFAM(GLONADI): # GA famille mvt stock - table diverse 9
Local Decimal WRCPQTY,WRRRQTY,WQQQQTY
If dim(WRET)<1 : Local Integer WRET : Endif

   #Lecture ťventuelle de article et article-site
   WRET = func ITMLIB.READ_ITM_ITF ([F:SCI]ITMREF,[F:SCI]PRHFCY)
   If WRET = 1 :  GOK = 0 : Return : Endif

  # Issue 91992 GA 08/2013 ssi article gťrť en stock
   If [F:ITF]STOMGTCOD<2 Return Endif

   If clalev([F:PWS])>0
   #----- recherche des articles  enregistrťs dans [F:PWS] et dans STOENT
      Filter [F:PWS] Where PRONUM=adxuid(1) & CODFNC="PTH" & VCRTYP=36 &
&                          VCRNUM=[F:SCI]SCONUM & VCRLIN=[F:SCI]SCILIN & VCRSEQ=0
      Read [PWS] First
      If fstat : Raz [F:PWS] : Endif
      Filter [PWS]
      WSTOSEQ = [F:PWS]WSTOSEQ
      WMVTDES = [F:PWS]MVTDES
      WENTCOD = [F:PWS]ENTCOD
      WTRSCOD = [F:PWS]TRSCOD
      WTRSFAM = [F:PWS]TRSFAM
      WRCPQTY = [F:PWS]QTYSTU     : # qtť rťceptionnťe
   Else
      Raz WSTOSEQ, WMVTDES, WENTCOD
      WTRSFAM = [F:PTD]TRSFAM
      WRCPQTY = [F:PTD]QTYSTU     : # FQ 65646 avant [F:PTD]RCPQTY
   Endif
 # rťcupťration des infos de la ligne de rťception <Entrťe de l'article SCI>
   If clalev ([M:PTH1])>0 & WSTOSEQ = 0
      WSTOSEQ = [M:PTH1]WSTOSEQ(NOL)
      WMVTDES = [M:PTH1]MVTDES(NOL)
   Endif

   # WSTOSEQ et WMVTDES doivent Ítre renseignťs
   Gosub LOAD_STW_ENTREE From SCOSTKAUTLIB

   #----- Crťation ligne ŗ entrer -----#
   Raz LQTA,LSHT,LNBR,LNBJ,WRET
   Call ALISTOWORK(2,WSTOSEQ,LQTA,LSHT,LNBR,LNBJ,WRET) From STKINT
   If WRET : GOK = 0 # GMESSAGE=mess(580,197,1)-":"-num$(WRET) :
      Return : Endif

   # sauvegarde des qtťs qui sont Raz par MAJ_STOCK
   # Issue 94690 GA 11/2013 case of multiple entries
   If dim([M:STW]NBLIG)>0 & [M:STW]NBLIG>=1
       Raz WRCPQTY : Raz WQQQQTY : Raz WRRRQTY
       For J=0 To [M:STW]NBLIG-1
             Case left$([M:STW]STA(J),1)
                When "Q" : WQQQQTY += [M:STW]QTYSTU(J)
                When "R" : WRRRQTY += [M:STW]QTYSTU(J)
             Endcase
             WRCPQTY += [M:STW]QTYSTU(J)
       Next
   Else
       WRCPQTY = [M:STW]QTYSTU # Qtť totale rťceptionnťe = [M:STW]AAAQTY + [M:STW]RRRQTY + [M:STW]QQQQTY
       WRRRQTY = [M:STW]RRRQTY
       WQQQQTY = [M:STW]QQQQTY
   Endif

   #----- Appel du sous-programme de mise ŗ jour des stocks -----#
   If [M:STW]NBLIG>0
      Call MAJ_STOCK From STKMAJ
      If GOK<1  Return : Endif
   Else
   #  Dťclaration de production : Saisie de l'entrťe en stock non effectuťe ligne :
      WMSGSUI =mess(90,193,1)+" : "+[F:SCI]SCONUM -" / "- [F:SCI]ITMREF
&                           -" / "-"=>"-num$(WRCPQTY)-[F:SCI]STU
&                           -" / "- mess([F:SCI]ITMSTA,2221,1)
      Call ECR_TRACE(WMSGSUI,0) From GESECRAN
      Return
   Endif

 # ssi la maj de stock est ok, report de la maj sur [F:SCI]
 # Maj Article lancť qtť rťceptionnťe en US
   Readlock [F:SCI]SCI0 = LSCONUM;LSCILIN
   If fstat=1  GOK=-1 : GLOCK="$SCOITM"-LSCONUM-num$(LSCILIN) : Return
   Elsif fstat GOK=0  : Call RSTA("SCI",LSCONUM-num$(LSCILIN)) From GLOCK : Return
   Endif
   [F:SCI]CPLQTY    += WRCPQTY
   If [F:SCI]CPLQTY<0 : [F:SCI]CPLQTY=0 : Endif
   Call QTEARR([F:SCI]CPLQTY,[F:SCI]STU) From TRTDIV

   [F:SCI]REJCPLQTY += WRRRQTY
   If [F:SCI]REJCPLQTY<0 : [F:SCI]REJCPLQTY=0 : Endif
   Call QTEARR([F:SCI]REJCPLQTY,[F:SCI]STU) From TRTDIV

   [F:SCI]QUACPLQTY += WQQQQTY
   If [F:SCI]QUACPLQTY<0 : [F:SCI]QUACPLQTY=0 : Endif
   Call QTEARR([F:SCI]QUACPLQTY,[F:SCI]STU) From TRTDIV

   # dťplacť dans CTRL_ITMSTA / SCI_ITMSTA_RCP / SCI_ITMSTA_CLO
   #[F:SCI]RMNEXTQTY = [F:SCI]EXTQTY - [F:SCI]CPLQTY
   #If [F:SCI]RMNEXTQTY < 0 : [F:SCI]RMNEXTQTY = 0 : Endif

   Gosub CTRL_ITMSTA From SCOLIB

   # on rťcupŤre le LOT lors de la 1ere rťception
   If [F:ITM]LOTMGTCOD > 1 & [F:SCI]LOT = ""
      [F:SCI]LOT = WLOT
   Endif

   # Rq: pas de maj de l'encours EOF qui a ťtť consommť ŗ la commande ...

   Gosub REWRITE_SCI From SCOLIB

   # Dťclaration de production sur ordre de sous-traitance :
   WMSGSUI = mess(642,197,1)+" : "+[F:SCI]SCONUM -" / "- [F:SCI]ITMREF
&                           -" / "-"=>"-num$(WRCPQTY)-[F:SCI]STU
&                           -" / "- mess([F:SCI]ITMSTA,2221,1)
   Call ECR_TRACE(WMSGSUI,0) From GESECRAN

   If clalev([F:PWS])>0 & [F:PWS]VCRNUM=[F:SCI]SCONUM
    # suppression de la ligne [F:PWS] traitťe
      Delete [F:PWS] Where PRONUM=adxuid(1) & CODFNC="PTH" & VCRTYP=36 &
&                          VCRNUM=[F:SCI]SCONUM & VCRLIN=[F:SCI]SCILIN & VCRSEQ=0
      Raz [F:PWS]
   Endif

Return

#########################################################################
# Etiquette appelťe par
# - MAJ_STK(SCOSTKLIB) Maj de la qtť rťceptionnťe sur [F:SCS]
# - Ecran de rťception                          <CPLQTY de l'article SCS>
# La ligne [F:SCS]est chargťe en mťmoire
#########################################################################
$MAJ_STKENT_SCS
Local Decimal WOPECPLQTY,WOPEREJQTY
If dim(WRET)<1 : Local Integer WRET : Endif
Raz WOPECPLQTY, WOPEREJQTY

 # la qtť d'article rťceptionnť correspond ŗ CPLQTY de [F:SCS] en unitť d'opťration [F:SCS]OPESTU
   If [F:SCS]OPESTU  = [F:PTD]STU
     WOPECPLQTY = [F:PTD]QTYSTU
     WOPEREJQTY = [F:PTD]RRRQTYSTU
   Elsif [F:SCI]STU  = [F:PTD]STU & [F:SCS]OPESTUCOE<>0 # Issue 87727 GA 02/2013
     WOPECPLQTY = [F:PTD]QTYSTU / [F:SCS]OPESTUCOE
     WOPEREJQTY = [F:PTD]RRRQTYSTU / [F:SCS]OPESTUCOE
   Else
     Call CALCUL_QTY([F:PTD]QTYSTU,[F:PTD]STU,WOPECPLQTY,[F:SCS]OPESTU,GBIDD1) From TRTX3
     Call CALCUL_QTY([F:PTD]RRRQTYSTU,[F:PTD]STU,WOPEREJQTY,[F:SCS]OPESTU,GBIDD1) From TRTX3
   Endif

 # Maj Opťration
   Readlock [F:SCS] Curr
   If fstat=1  GOK=-1 : GLOCK="$SCOOPE"-num$([F:SCS]SCSLIN) : Return
   Elsif fstat GOK=0  : Call RSTA("SCS",num$([F:SCS]SCSLIN)) From GLOCK : Return
   Endif
 # Lecture ťventuelle de article et article-site (facultatif)
   WRET = func ITMLIB.READ_ITM_ITF ([F:SCS]SRVITMREF,[F:SCS]PRHFCY)
   #If WRET = 1 :  GOK = 0 : Return : Endif

   [F:SCS]CPLQTY    += WOPECPLQTY
   If [F:SCS]CPLQTY<0 : [F:SCS]CPLQTY=0 : Endif
   Call QTEARR([F:SCS]CPLQTY,[F:SCS]OPESTU) From TRTDIV

   [F:SCS]REJCPLQTY += WOPEREJQTY
   If [F:SCS]REJCPLQTY<0 : [F:SCS]REJCPLQTY=0 : Endif
   Call QTEARR([F:SCS]REJCPLQTY,[F:SCS]OPESTU) From TRTDIV

   Gosub CAL_QTYPRI_SCS

 # pas de maj de l'encours SCF qui a ťtť consommť ŗ la commande ...
   Gosub CTRL_OPESTA From SCOLIB
   Gosub REWRITE_SCS From SCOLIB

 # Service sous-traitance
    WMSGSUI = mess(4,306,1) +" : "+[F:SCS]SCONUM
&                           -" / "-num$([F:SCS]SCILIN)-" / "-num$([F:SCS]SCSLIN)
&                           -" / "- [F:SCS]SRVITMREF-"=>"-num$(WOPECPLQTY)-[F:SCS]OPESTU
&                           -" / "- mess([F:SCS]OPESTA,2239,1)
    Call ECR_TRACE(WMSGSUI,0) From GESECRAN

Return

#####################################################
$CAL_QTYPRI_SCS
Local Decimal WCPR, WPRIX, WQTYSTU, WPRISTU, WQTYUO, WPRIUO
Local Shortint WLINSCS

#----- Calcul des ťlťments de facturation en devise sociťtť -----#
Local Decimal WPRIPUR, WMONTANT
#NOL article lancť est renseignť par dans MAJ_STK(SCOSTKLIB) avant le Gosub MAJ_STKENT_SCS, ne pas l'ťcraser !!!!
#NOL = find([F:PTD]PTDLIN,[M:PTH1]PTDLIN(0..[M:PTH1]NBLIG-1))-1
WLINSCS=NOL+1

# Issue 77436 - 2011-11-14 by GA : les elts de facturation sont sur la ligne courante LINTYP=3
##### If NOL>=0 & [M:PTH1]LINTYP(NOL)=2
If WLINSCS>0 & [M:PTH1]LINTYP(WLINSCS)=3
    # Issue 77436 - 2011-11-14 by VPO : modif calcul prix rťception
#    Call CALCUL_PRIPUR(NOL,WPRIPUR) From SUBPTHB
#    WPRIPUR = arr(WPRIPUR*[F:PTD]CPRCOE,10^-GDECPRI)
#    WMONTANT= ([F:PTD]CPR-WPRIPUR)* [F:PTD]QTYSTU
     #on rťcupŤre un montant (pas de multiplication par quantitť)
     Call CALCUL_MTELT(WLINSCS,WMONTANT) From SUBPTHB

   # Issue 77436 - 2011-11-14 by GA/VPO
   # on prend le prix de la rťception en prioritť, sinon recherche de la commande
     WPRIUO = [M:PTH1]NETPRI(WLINSCS)
     WQTYUO = [M:PTH1]QTYUOM(WLINSCS)   # Issue 90045 NETPRI exprimť en UO avant [M:PTH1]QTYSTU(WLINSCS)
   # Issue 100967 GA 06/2014
     If [M:PTH1]NETCUR(WLINSCS)<>GLOCALDEV & WPRIUO<>0
        Local Integer WSTAT
        Call CONVERT2([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,WPRIUO,WPRIUO, WSTAT) From TRTDEV
     Endif
     #If WPRIUO=0 # Issue 100995 GA 03/2015 always check if purchase already invoiced
        # FQ 53755 la ligne courante [F:POQ] pointe sur l'article lancť => on charge [F:POQW]
        Call READ_POQW([F:SCS]SRVITMREF,[F:SCS]SCONUM,[F:SCS]SCILIN,[F:SCS]SCSLIN,[F:SCS]POHNUM,[F:SCS]POPLIN,[F:SCS]POQSEQ)
        Gosub CAL_QTYPRI_POQ
     #Endif

Endif

# Ecran SDP est dťjŗ ouvert en rťception, [F:ITM] est ok
[M:SDP]QTY    = WQTYUO
[M:SDP]SCOTOT = WQTYUO * WPRIUO # Valeur du service uniquement
[M:SDP]INVDTACST = WMONTANT
[M:SDP]AMTTOT = [M:SDP]SCOTOT + [M:SDP]INVDTACST

#--- Maj de WIPCOST
Call SCEOPETRK_NEW(36,WRET) From MWIPLIB
If WRET > 0 : GOK = 0 : Return : Endif

# mise ŗ jour donnťes opťration, ssi qtť facturťe (Article lancť)
If [F:PTD]INVQTYSTU<>0
  If [F:SCS]INVQTY = 0
    # prix constatť sur cette rťception
      [F:SCS]INVQTY = WQTYUO
      [F:SCS]CPLPRI = WPRIUO
  Else
    # calcul d'un prix moyen
      If WQTYUO <> 0
        WRKQTY         = [F:SCS]INVQTY + WQTYUO
        WRKPRI         = ([F:SCS]INVQTY * [F:SCS]CPLPRI) + (WQTYUO * WPRIUO)
        [F:SCS]CPLPRI  = WRKPRI / WRKQTY
        [F:SCS]INVQTY += WQTYUO
      Else
        WRKPRI         = ([F:SCS]INVQTY * [F:SCS]CPLPRI) + WPRIUO
        [F:SCS]CPLPRI  = WRKPRI / [F:SCS]INVQTY
      Endif
  Endif
Endif

Return

#########################################################################
# Etiquette appelťe par
# - MAJ_STK(SCOSTKLIB)
# - Ecran de Rťception                          <Sortie du composant SCM>
# La ligne [F:SCM]est chargťe en mťmoire
#########################################################################
$MAJ_STKSOR_SCM
Local Decimal WCOEFFPROD
Local Decimal WUSEQTY,WALLQTY,WSHTQTY
Local Decimal WWUSEQTY,WWALLQTY,WWSHTQTY
Local Integer WNO_REAJUST
Local Decimal LQTA, LSHT, LDIS
Local Integer LNBR, LNBJ,WCUNFLG
Local Decimal WWALLQTY,WWSHTQTY
Local Integer WSTOSEQ         : # GA
Local Char    WMVTDES(50)     : # GA dťsignation du mvt
Local Char    WENTCOD(GLONGAU): # GA code piece auto stock
Local Char    WTRSCOD(GLONADI): # GA code    mvt stock - table diverse 14
Local Char    WTRSFAM(GLONADI): # GA famille mvt stock - table diverse 9
If dim(WRET)<1 : Local Integer WRET : Endif

    Raz WNO_REAJUST,WUSEQTY
  ### conso estimťe en prorata de la qtť rťceptionnťe sur article lancť
  ### WCOEFFPROD = arr([F:PTD]QTYSTU/[F:SCI]EXTQTY,0.000001)

  # Lecture ťventuelle de article et article-site
    WRET = func ITMLIB.READ_ITM_ITF ([F:SCM]CPNITMREF,[F:SCM]STOFCY)
    If WRET = 1 :  GOK = 0 : Return : Endif

  # on ne suit pas les matiŤres  si plus rien ŗ suivre
    If ([F:SCM]RETQTY - [F:SCM]USEQTY <= 0 )
       Call ECR_DEBUG("MAJ_STKSOR_SCM: Dťjŗ tout consommť pour"-[F:SCM]CPNITMREF)
       Return
    Endif

    If clalev([F:PWS])>0
   #----- recherche si le composant est dťjŗ enregistrť dans [F:PWS] et dans STOSORW
      Filter [F:PWS] Where PRONUM=adxuid(1) & CODFNC="PTH" & VCRTYP=36 &
&                          VCRNUM=[F:SCM]SCONUM & VCRLIN>=[F:SCM]SCILIN & TRSTYP=29
      #Read [PWS] First                 # Issue 90923 GA 08/2013
      #If fstat : Raz [F:PWS] : Endif   # Issue 90923 GA 08/2013
      #Filter [PWS]                     # Issue 90923 GA 08/2013
      For [PWS]
        If [F:PWS]VCRSEQ=[F:SCM]SCMLIN  # Issue 90923 GA 08/2013
          WSTOSEQ = [F:PWS]WSTOSEQ
          WMVTDES = [F:PWS]MVTDES
          WENTCOD = [F:PWS]ENTCOD
          WTRSCOD = [F:PWS]TRSCOD
          WTRSFAM = [F:PWS]TRSFAM
          WUSEQTY = [F:PWS]QTYSTU     : # qtť calculťe ou saisie par l'utilisateur
          WWUSEQTY= [F:PWS]QTYSTU     : # FQ 72505 GA 03/2011
          Break
        Endif
      Next
      Filter [PWS]
    Else
      Raz WSTOSEQ
    Endif

   #----- si le composant n'est pas enregistrť dans [F:PWS] et dans STOSORW
    If WUSEQTY = 0             # Issue 90923 GA 08/2013 sortie nulle autorisťe
        Goto SUITE_SCM
    Elsif WSTOSEQ = 0
       Return
    Endif

    # Maj masques sortie selon MAJ_MTK(MTKAUTLIB) et SUBMTKB
    Gosub LOAD_STW_SORTIE_SCM
    Gosub LOAD_ALP_SCM

    # Maj Stock
    Raz LQTA,LSHT,LNBR,LNBJ,WRET
    If [F:SCM]ALLSTA > 1
       Call MAJALLORI(WSTOSEQ,WRET) From STKALL
       If WRET : GOK = 0 : Endif
       WWALLQTY = [M:ALP]DESQTY
       WWSHTQTY = [M:ALP]DESQTYSHT
    Endif
    Call ALISTOWORK(3,WSTOSEQ,LQTA,LSHT,LNBR,LNBJ,WRET) From STKINT
    If WRET : GOK = 0 : # GMESSAGE=mess(580,197,1)-":"-num$(WRET) # le message est dans la trace
       Return : Endif

    # sauvegarde des qtťs qui sont Raz par MAJ_STOCK
    #WUSEQTY = [M:SOW]WQTYSTU(WSTOSEQ-1)  # FQ 51330 avant [M:STW]QTYSTU(WSTOSEQ-1) n'ťtait renseignťe que pour la 1ere matiŤre
    # FQ 72505 GA 03/2011 maj de WUSEQTY nťcessaire si sortie partielle
    WUSEQTY = sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTU(J)*([M:SOW]WSTOSEQ(J)=WSTOSEQ))
    #----- si aucune sortie dans STOSORW
    # If WUSEQTY = 0
    #    Call ECR_DEBUG("MAJ_STKSOR_SCM: Aucune sortie dans STOSORW ???? pour"-[F:SCM]CPNITMREF)
    # Endif

    #If [M:STW]NBLIG>0 # FQ 72505 GA 03/2011 erreur si qtť insuffisante
    #If [M:STW]NBLIG>0 & WWUSEQTY=WUSEQTY
    # Issue 89399 GA 04/2013 maj des stocks si et seulement si quantitť cohťrente
    # Issue 94538 GA 11/2013 vťrifier que WWUSEQTY=WUSEQTY !
    If WUSEQTY <> 0 & WWUSEQTY=WUSEQTY & WRET = 0
       Call MAJ_STOCK From STKMAJ
       If GOK < 1 : Return : Endif
    Else
    #  mess(177,198,1) : Mise ŗ jour du stock
    #  mess(6,306,1) : Besoin MatiŤre
       WMSGSUI =mess(7,21,1)-":"-mess(177,198,1)-mess(6,306,1)
&                           -[F:SCM]SCONUM -" / "- [F:SCM]CPNITMREF
&                           -num$(WUSEQTY)-num$(WWUSEQTY)-[F:SCI]STU
       Call ECR_TRACE(WMSGSUI,1) From GESECRAN : GOK=0
       Return
    Endif

$SUITE_SCM   # Issue 97904 GA 12/2014

  # ssi la maj de stock est ok, report de la maj sur [F:SCM]
    Readlock [F:SCM]SCM0 Curr
    If fstat=1  GOK=-1 : GLOCK="$SCOMAT"-[F:SCM]CPNITMREF : Return
    Elsif fstat GOK=0  : Call RSTA("SCM",[F:SCM]CPNITMREF) From GLOCK : Return
    Endif
    [F:SCM]USEQTY += WUSEQTY
    WWUSEQTY = WUSEQTY
    Call QTEARR([F:SCM]USEQTY,[F:SCM]STU) From TRTDIV

    #si matiŤre soldťe on rťinitialise ŗ 0 les qtťs allouťes et en rupture
    #On supprime toutes les allocs liťes ŗ cette matiŤre(si il en reste)
    #si matiŤre non soldťe , on rťajuste les qtťs allouťes et en rupture
    Raz WRET
    Call CONT_SOLDE_MAT([F:SCM]STOFCY,[F:SCM]CPNITMREF,[F:SCM]USEQTY,[F:SCM]RETQTY,WRET) From SCOLIB
    # Issue 97904 GA 12/2014 + 2 cols RETQTY and CLEFLG
    If WRET = 1 | (dim([F:PWS]CLEFLG)>0 & [F:PWS]CLEFLG=2)
       Gosub SCM_MATSTA_CLO From SCOLIB  # Soldť
       Call DELALL(36,LSCONUM,LSCILIN,[F:SCM]SCMLIN,[F:SCM]CPNITMREF,0,WALLQTY,WSHTQTY,WRET) From STKALL
       If WRET <> 0 : GOK = 0 : Return: Endif
       Raz [F:SCM]ALLQTY,[F:SCM]SHTQTY
       [F:SCM]ALLSTA=1
    Else
       Gosub CTRL_MATSTA From SCOLIB   # En-cours/Commandť/Rťceptionnť
       If [F:SCM]ALLSTA > 1
          [F:SCM]ALLQTY -= WWALLQTY
          [F:SCM]SHTQTY -= WWSHTQTY
       Endif
    Endif
    Raz WRET

  # conso de l'encours MSF
    Call UPDATE_MSX("M", 0) From SCOLIB

    # affectations
    Gosub MAJ_MTO_SCM From SCOMTOLIB

    Gosub REWRITE_SCM From SCOLIB

#$SUITE_SCM   # Issue 97904 GA 12/2014

 # Consommation matiŤre
   WMSGSUI = mess(226,190,1) +" : "+[F:SCM]SCONUM
&                           -" / "-num$([F:SCM]SCILIN)-" / "-num$([F:SCM]SCMLIN)
&                           -" / "- [F:SCM]CPNITMREF-"=>"-num$(WUSEQTY)-[F:SCM]STU
&                           -" / "- mess([F:SCM]MATSTA,2223,1)
   Call ECR_TRACE(WMSGSUI,0) From GESECRAN

   If clalev([F:PWS])>0 & [F:PWS]VCRNUM=[F:SCM]SCONUM
    # suppression de la ligne [F:PWS] traitťe
#      Delete [F:PWS] Where PRONUM=adxuid(1) & CODFNC="PTH" & VCRTYP=36 &
#&                          VCRNUM=[F:SCM]SCONUM & VCRLIN=[F:SCM]SCILIN & VCRSEQ=[F:SCM]SCMLIN
      Delete [F:PWS] Curr
      Raz [F:PWS]
   Endif

Return

# Issue 93349 GA 10/2013 Conso de matiŤre non prťvue sur un EO
#########################################################################
# Etiquette appelťe par
# - MAJ_STK(SCOSTKLIB)
# - Ecran de Rťception                    <Sortie matiŤre non prťvue PWS>
# La ligne [F:PWS] contient matiŤre ajoutťe en saisie de rťception
# Les lignes [F:SCO], [F:SCI] et [F:SCS] sont correctements chargťes
#########################################################################
$MAJ_STKSOR_PWS
Local Decimal WCOEFFPROD
Local Decimal WUSEQTY,WALLQTY,WSHTQTY
Local Decimal WWUSEQTY,WWALLQTY,WWSHTQTY
Local Integer WNO_REAJUST
Local Decimal LQTA, LSHT, LDIS
Local Integer LNBR, LNBJ,WCUNFLG
Local Decimal WWALLQTY,WWSHTQTY
Local Integer WSTOSEQ         : # GA
Local Char    WMVTDES(50)     : # GA dťsignation du mvt
Local Char    WENTCOD(GLONGAU): # GA code piece auto stock
Local Char    WTRSCOD(GLONADI): # GA code    mvt stock - table diverse 14
Local Char    WTRSFAM(GLONADI): # GA famille mvt stock - table diverse 9
If dim(WRET)<1 : Local Integer WRET : Endif

    Raz WNO_REAJUST

  # Lecture ťventuelle de article et article-site
    WRET = func ITMLIB.READ_ITM_ITF ([F:PWS]ITMREF,[F:SCI]PRHFCY)
    If WRET = 1 :  GOK = 0 : Return : Endif

    WSTOSEQ = [F:PWS]WSTOSEQ
    WMVTDES = [F:PWS]MVTDES
    WENTCOD = [F:PWS]ENTCOD
    WTRSCOD = [F:PWS]TRSCOD
    WTRSFAM = [F:PWS]TRSFAM
    WUSEQTY = [F:PWS]QTYSTU     : # qtť calculťe ou saisie par l'utilisateur
    WWUSEQTY= [F:PWS]QTYSTU

   #----- si le composant n'est pas enregistrť dans [F:PWS] et dans STOSORW
    If WUSEQTY = 0
        Goto SUITE_PWS
    Elsif WSTOSEQ = 0
       Return
    Endif

    # Maj masques sortie
    Gosub LOAD_STW_SORTIE_PWS
    Gosub LOAD_ALP_PWS

    # Maj Stock
    Raz LQTA,LSHT,LNBR,LNBJ,WRET
    # Issue 93349 GA 10/2013 pas d'allocations dans ce cas ?
    #If [M:ALP]ALLSTA > 1
    #   Call MAJALLORI(WSTOSEQ,WRET) From STKALL
    #   If WRET : GOK = 0 : Endif
    #   WWALLQTY = [M:ALP]DESQTY
    #   WWSHTQTY = [M:ALP]DESQTYSHT
    #Endif
    Call ALISTOWORK(3,WSTOSEQ,LQTA,LSHT,LNBR,LNBJ,WRET) From STKINT
    If WRET : GOK = 0 : # GMESSAGE=mess(580,197,1)-":"-num$(WRET) # le message est dans la trace
       Return : Endif

    # sauvegarde des qtťs qui sont Raz par MAJ_STOCK
    WUSEQTY = sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTU(J)*([M:SOW]WSTOSEQ(J)=WSTOSEQ))

    If WUSEQTY <> 0 & WRET = 0
       Call MAJ_STOCK From STKMAJ
       If GOK < 1 : Return : Endif
    Else
    #  mess(177,198,1) : Mise ŗ jour du stock
    #  mess(6,306,1) : Besoin MatiŤre
       WMSGSUI =mess(7,21,1)-":"-mess(177,198,1)-mess(6,306,1)
&                           -[F:SCI]SCONUM -" / "-num$([F:SCI]SCILIN)-" / "-[F:PWS]ITMREF
&                           -num$(WUSEQTY)-num$(WWUSEQTY)-[F:PWS]STU
       Call ECR_TRACE(WMSGSUI,1) From GESECRAN : GOK=0
       Return
    Endif

    # Maj affectations ?
    #Gosub MAJ_MTO_SCM From SCOMTOLIB

    Delete [F:PWS] Curr
    Raz [F:PWS]

$SUITE_PWS

 # Consommation matiŤre
   WMSGSUI = mess(226,190,1) +" : "+[F:SCI]SCONUM-" / "-num$([F:SCI]SCILIN)-" / "- [F:PWS]ITMREF-"=>"-num$(WUSEQTY)-[F:PWS]STU
   Call ECR_TRACE(WMSGSUI,0) From GESECRAN

Return



#########################################################################
# Etiquette appelťe par
# - MAJ_STK(SCOSTKLIB) Maj de la qtť facturťe sur [F:SCM] si [F:SCM]SCOFLG=3
# - Ecran de rťception                <INVQTY et CPLPRI de l'article SCM>
# [F:ITM],[F:ITP] sont chargťes pour la ligne de commande courante
# [F:POH],[F:POQ],[F:SCM] sont chargťes pour la matiŤre [F:SCM]CPNITMREF
# [F:PTD],[F:SCI]    ligne rťception de l'article lancť [F:SCS]ITMREF
#########################################################################
$MAJ_STKPRI_SCM                      : # selon MAJ_PRIX_OPE(MTKLIB)
Local Decimal WCPR, WPRIX, WQTYSTU, WPRISTU, WQTYUO, WPRIUO
Local Shortint WLINSCM

If [F:SCM]SCOFLG<>3 : Return : Endif

# ssi la maj de stock est ok, report de la maj sur [F:SCM]
Readlock [F:SCM]SCM0 Curr
If fstat=1  GOK=-1 : GLOCK="$SCOMAT"-[F:SCM]CPNITMREF : Return
Elsif fstat GOK=0  : Call RSTA("SCM",[F:SCM]CPNITMREF) From GLOCK : Return
Endif

Gosub CAL_QTYPRI_SCM

If WQTYSTU<>0
 # Maj USEQTY pour compatibilitť avec les matiŤres fournies au sous-traitant
   [F:SCM]USEQTY+=WQTYSTU
   If [F:SCM]USEQTY<0             [F:SCM]USEQTY=0             Endif
   If [F:SCM]USEQTY>[F:SCM]RETQTY [F:SCM]USEQTY=[F:SCM]RETQTY Endif
Endif

Gosub CTRL_MATSTA From SCOLIB
Gosub REWRITE_SCM From SCOLIB

Return

#####################################################
$CAL_QTYPRI_SCM
Local Decimal WCPR, WPRIX, WQTYSTU, WPRISTU, WQTYUO, WPRIUO
Local Shortint WLINSCM

#----- Calcul des ťlťments de facturation en devise sociťtť -----#
Local Decimal WPRIPUR, WMONTANT

#NOL article lancť est renseignť par dans MAJ_STK(SCOSTKLIB) avant le Gosub MAJ_STKPRI_SCM, ne pas l'ťcraser !!!!
#NOL = find([F:PTD]PTDLIN,[M:PTH1]PTDLIN(0..[M:PTH1]NBLIG-1))-1
WLINSCM=NOL+2
While WLINSCM<[M:PTH1]NBLIG & [M:PTH1]VCRSEQORI(WLINSCM)<>[F:SCM]SCMLIN
   WLINSCM+=1
Wend

# Issue 77436 - 2011-11-14 by GA : les elts de facturation sont sur la ligne courante LINTYP=4
If WLINSCM>0 & [M:PTH1]LINTYP(WLINSCM)=4 & [M:PTH1]VCRSEQORI(WLINSCM)=[F:SCM]SCMLIN

     #on rťcupŤre un montant (pas de multiplication par quantitť)
     Call CALCUL_MTELT(WLINSCM,WMONTANT) From SUBPTHB

   # on prend le prix de la rťception en prioritť, sinon recherche de la commande
     WPRIUO = [M:PTH1]NETPRI(WLINSCM)
     WQTYUO = [M:PTH1]QTYUOM(WLINSCM)   # Issue 90045 NETPRI exprimť en UO avant [M:PTH1]QTYSTU(WLINSCM)
   # Issue 100967 GA 06/2014
     If [M:PTH1]NETCUR(WLINSCM)<>GLOCALDEV & WPRIUO<>0
        Local Integer WSTAT
        Call CONVERT2([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,WPRIUO,WPRIUO, WSTAT) From TRTDEV
     Endif
     #If WPRIUO=0 # Issue 100995 GA 03/2015 always check if purchase already invoiced
        # FQ 53755 la ligne courante [F:POQ] pointe sur l'article lancť => on charge [F:POQW]
        Call READ_POQW([F:SCM]CPNITMREF,[F:SCM]SCONUM,[F:SCM]SCILIN,[F:SCM]SCMLIN,[F:SCM]POHNUM,[F:SCM]POPLIN,[F:SCM]POQSEQ)
        Gosub CAL_QTYPRI_POQ
     #Endif

Endif

# Ecran SDP est dťjŗ ouvert en rťception, [F:ITM] est ok
[M:SDP]QTY       = WQTYUO
[M:SDP]INVDTACST = WMONTANT
[M:SDP]AMTTOT    = WQTYUO * WPRIUO + [M:SDP]INVDTACST
# Issue 76138 - 2011-09-09 by CCC
[M:SDP]MATCST(max(0,[F:ITM]BRDCOD-1)) = WQTYUO * WPRIUO     # Voir ťlťments de facturation

# Issue 99332 GA 05/2014 + 2 parameters [F:PTD]PTHNUM,[F:PTD]PTDLIN
#--- Maj de WIPCOST
Call CREWIPMATSCO("M",[F:PTD]PTHNUM,[F:PTD]PTDLIN,WRET) From MWIPLIB
If WRET > 0 : GOK = 0 : Return : Endif

# mise ŗ jour donnťes matiŤre fournie par le sous-traitant, ssi qtť facturťe (Article lancť)
If [F:PTD]INVQTYSTU<>0
   If [F:SCM]INVQTY = 0
    # prix constatť sur cette rťception
      [F:SCM]INVQTY += WQTYUO
      [F:SCM]CPLPRI += WPRIUO
   Else
    # calcul d'un prix moyen
      If WQTYUO <> 0
        WRKQTY         = [F:SCM]INVQTY + WQTYUO
        WRKPRI         = ([F:SCM]INVQTY * [F:SCM]CPLPRI) + (WQTYUO * WPRIUO)
        [F:SCM]CPLPRI  = WRKPRI / WRKQTY
        [F:SCM]INVQTY += WQTYUO
      Else
        WRKPRI         = ([F:SCM]INVQTY * [F:SCM]CPLPRI) + WPRIUO
        [F:SCM]CPLPRI  = WRKPRI / [F:SCM]INVQTY
      Endif
   Endif
Endif

Return

#####################################################
$CAL_QTYPRI_POQ : # selon MAJ_PRIX_SUIVI(MTKLIB), puis adaptť ŗ sous-traitance

# [F:POQW] => Service ou MatiŤre fournie par le sous-traitant
# [F:POPW] => Service ou MatiŤre fournie par le sous-traitant
# [F:PTD] => Article lancť (qtť ŗ convertir !)
# Qtť facturťe ou rťceptionnťe et prix de revient unitaire en US
# - Facturť si on a les infos
# - selon tarif enregistrť ŗ la commande sinon
# WQTYUO  = qtť en US
# WPRIUO  = PU pour qtť en US
# WQTYSTU = qtť en US (recalculťe d'aprŤs la qtť en UA)
Local Shortint WBFOUND : WBFOUND=0   # Issue 100995 GA 03/2015
#--- recherche de la derniere ligne de facture pour la ligne de commande courante
Filter [PID] Where TYPORI = 1 and NUMORI = [F:POQW]POHNUM and LINORI = [F:POQW]POPLIN
&            and   SEQORI = [F:POQW]POQSEQ   Order By Key PID1 Desc
For [PID]
    Read [PIH]PIH0 = [F:PID]NUM
    If fstat = 0
        If [F:PIH]STA = 3
            #WCPR = [F:PID]CPR
            WBFOUND=1    # Issue 100995 GA 03/2015
            Break
        Endif
    Endif
Next
Filter [PID]

If WBFOUND
   # Issue 100995 GA 03/2015 calculate total value of invoices/additional invoices/credit note
   Local Decimal W_RCP,W_RCPFC
   W_RCP    = func SBCLIB.SUMRCP([F:POQW]VCRTYPORI,[F:POQW]VCRNUMORI,[F:POQW]POHNUM, [F:POQW]POPLIN)
   W_RCPFC  = func SBCLIB.SUMRCPFC([F:POQW]VCRTYPORI,[F:POQW]VCRNUMORI,[F:POQW]POHNUM, [F:POQW]POPLIN)
   If [F:PTD]INVQTYSTU<>0
      WQTYUO = [F:PTD]INVQTYSTU
      WCPR=(W_RCP+W_RCPFC)/[F:PTD]INVQTYSTU
   Else
      WCPR=W_RCP+W_RCPFC
   Endif
Endif


# si aucune facture validťe, et si ligne commande en mťmoire
If WCPR = 0 & [F:POH]POHNUM = [F:PTD]POHNUM
    WCPR = [F:POPW]NETPRI : # prix tarif pour l'unitť achat UOM
    If [F:ITP]CPRCOE = 0
              # prendre les frais hors prix net dans le tarif
              # qui entre dans calcul prix de valorisation
              # a faire GA ???????????????????
              # ???????????????????????
    Else WCPR *= [F:ITP]CPRCOE
    Endif
   # GA 07/2011 FQ 74682 conversion en devise locale si nťcessaire
   # => diffťrent de la sous-traitance OF qui est dťjŗ devise locale (GCUR=GLOCALDEV)  MAJ_PRIX_SUIVI(MTKLIB)
   # Call CONVERT([F:POH]CUR,GCUR,GCUR,[F:POH]CHGTYP,[F:POH]ORDDAT,WCPR,WCPR, STAT) From TRTDEV
    # Issue 75944 - 2011-08-31 by CCC : Il ne faut pas arrondir le rťsultat, c'est trop tŰt
    #Call CONVERT([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,WCPR,WCPR, STAT) From TRTDEV
    Call CONVERT2([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,WCPR,WCPR, STAT) From TRTDEV
    #--- attention ce prix est dans l'unitť de la commande UOM
    #-- il faut le transformer en prix dans l'unitť de stock STU
    If [F:POQW]UOM <> [F:POQW]STU
        If [F:POQW]UOM <> [F:POQW]PUU
            WCPR /= [F:POQW]UOMPUUCOE
        Endif
    #--- recherche coef US - UA
        GBIDD1 = 1
        GBIDD2 = 0
        Call PCAL_QTY(GBIDD1,[F:POQW]PUU,GBIDD2,[F:POQW]STU,[F:POQW]ITMREF,
&                     [F:POH]BPSNUM,1,GBIDD3) From TRTACHQTE1
        If GBIDD3 <> 0  : WCPR  /= GBIDD3 : Endif
    Endif
Endif
WPRIUO = WCPR

# on (re)lit la ligne de commande Article lancť [F:POQ1]
# pour faire une rŤgle de trois sur les qtťs
Read [F:POQ1]POQ0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
If fstat : Raz [F:POQ1] : Endif

If [F:PTD]INVQTYSTU > 0
# ------------------------------------
# Qtť article lancť facturťe en US
# => conversion en qtť Service/MatiŤre
# ------------------------------------
  If [F:POQ1]QTYSTU > 0
     WQTYPUU = [F:PTD]INVQTYPUU * ([F:POQW]QTYPUU / [F:POQ1]QTYPUU)
     WQTYSTU = [F:PTD]INVQTYSTU * ([F:POQW]QTYSTU / [F:POQ1]QTYSTU)
     Call PCAL_QTY(WQTYPUU,[F:POQW]PUU,WQTYUO,[F:POQW]STU,[F:POQW]ITMREF,
&                     [F:POH]BPSNUM,1,GBIDD3) From TRTACHQTE1
  Endif
Elsif [F:PTD]QTYSTU > 0
# ------------------------------------
# Qtť article lancť rťceptionnťe en US
# => conversion en qtť Service/MatiŤre
# ------------------------------------
  If [F:POQ1]QTYSTU > 0
     WQTYPUU = [F:PTD]QTYPUU * ([F:POQW]QTYPUU / [F:POQ1]QTYPUU)
     WQTYSTU = [F:PTD]QTYSTU * ([F:POQW]QTYSTU / [F:POQ1]QTYSTU)
     Call PCAL_QTY(WQTYPUU,[F:POQW]PUU,WQTYUO,[F:POQW]STU,[F:POQW]ITMREF,
&                     [F:POH]BPSNUM,1,GBIDD3) From TRTACHQTE1
  Endif
Endif

Return


#####################################################
$REC_LOC          : # selon REC_LOC de SUBMTKB
#si allocation dťtaillťe et article en inventaire, on vťrifie que les allocations
#portent bien sur des emplacements autorisťs
Filter [F:STA] Where VCRTYP = 36 & VCRNUM = [F:SCM]SCONUM & VCRLIN = [F:SCM]SCILIN & ITMREF = [F:SCM]CPNITMREF
&                  & VCRSEQ = [F:SCM]SCMLIN
For [F:STA]STA2                # 10.02 Performances
    Read [F:STO]STO0 = [F:STA]STOFCY;[F:STA]STOCOU
    If !fstat & [F:STO]CUNLOKFLG = 2 : WCUNFLG = 2 : Break : Endif
Next
Filter [F:STA]
Return






#########################################################################
# Etiquette appelťe par
# - ANNULE_MAJ_STK(SCOSTKLIB)
# - Ecran de Rťception (suppression) ou Retour
#                                    <Annulation Entrťe de l'article SCI>
# Les lignes [F:PTD] et [F:SCI] sont chargťes en mťmoire
#########################################################################
$RAZ_STKENT_SCI                 : # selon ANNULE_SUIVITM de SUBMTKC
Local Integer WSOLDE, I, J, SAVNOLIGN
Local Decimal WALLREJQTY,WQTE1, WQTE2
Local Decimal WQTYSTU, WRRRQTY, WQQQQTY
Local Char    WPJT(GLONPJT)
Local Integer WOK
If dim(WRET)<1 : Local Integer WRET : Endif

  # Lecture ťventuelle de article et article-site
    WRET = func ITMLIB.READ_ITM_ITF ([F:SCI]ITMREF,[F:SCI]PRHFCY)
    If WRET = 1 :  GOK = 0 : Return : Endif

  # Issue 91992 GA 08/2013 ssi article gťrť en stock
    If [F:ITF]STOMGTCOD<2 Return Endif

    Gosub LOAD_STW_ANNULE_ENTREE
    Call ALISTOWORK (4,0,WQTE1,WQTE2,GBIDI2,GBIDI3,WRET) From STKINT
    If WRET : GOK = 0 # GMESSAGE=mess(580,197,1)-":"-num$(WRET) :
       Return : Endif

    # !!! les quantitťs renvoyťes dans ce cas sont ŗ soustraire !!!
    # Issue 94690 GA 11/2013 case of multiple entries
    If dim([M:STW]NBLIG)>0 & [M:STW]NBLIG>=1
       Raz WQTYSTU : Raz WQQQQTY : Raz WRRRQTY
       For J=0 To [M:STW]NBLIG-1
           Case left$([M:STW]STA(J),1)
              When "Q" : WQQQQTY += [M:STW]QTYSTU(J)
              When "R" : WRRRQTY += [M:STW]QTYSTU(J)
           Endcase
           WQTYSTU += [M:STW]QTYSTU(J)
       Next
    Else
       WQTYSTU = [M:STW]QTYSTU # = [M:STW]AAAQTY + [M:STW]RRRQTY + [M:STW]QQQQTY
       WRRRQTY = [M:STW]RRRQTY
       WQQQQTY = [M:STW]QQQQTY
    Endif

    #----- Appel du sous-programme de mise ŗ jour des stocks -----#
    Call MAJ_STOCK From STKMAJ
    If GOK<1 : Return : Endif

  # ssi la maj de stock est ok, report de la maj sur [F:SCI]
  # Maj Article lancť qtť rťceptionnťe en US
    Readlock [F:SCI]SCI0 = LSCONUM;LSCILIN
    If fstat=1  GOK=-1 : GLOCK="$SCOITM"-LSCONUM-num$(LSCILIN) : Return
    Elsif fstat GOK=0  : Call RSTA("SCI",LSCONUM-num$(LSCILIN)) From GLOCK : Return
    Endif

    [F:SCI]CPLQTY    -= WQTYSTU
    If [F:SCI]CPLQTY<0 : [F:SCI]CPLQTY=0 : Endif
    Call QTEARR([F:SCI]CPLQTY,[F:SCI]STU) From TRTDIV

    [F:SCI]REJCPLQTY -= WRRRQTY
    If [F:SCI]REJCPLQTY<0 : [F:SCI]REJCPLQTY=0 : Endif
    Call QTEARR([F:SCI]REJCPLQTY,[F:SCI]STU) From TRTDIV

    [F:SCI]QUACPLQTY -= WQQQQTY
    If [F:SCI]QUACPLQTY<0 : [F:SCI]QUACPLQTY=0 : Endif
    Call QTEARR([F:SCI]QUACPLQTY,[F:SCI]STU) From TRTDIV

    [F:SCI]RMNEXTQTY = [F:SCI]EXTQTY - [F:SCI]CPLQTY
    If [F:SCI]RMNEXTQTY < 0 : [F:SCI]RMNEXTQTY = 0 : Endif

#--- Maj de WIPCOST -- ne pas planter en cas d'absence de Valo
   Call SCOOPETRK_DEL(36,[F:PTD]PTHNUM,[F:PTD]PTDLIN,"",WRET) From MWIPLIB       # Subcontracting Overhead
   If WRET > 0 : GOK = 0 : Return : Endif

   # pas de maj de l'encours EOF qui a ťtť consommť ŗ la commande ...

   # CTRL_ITMSTA ne dťsolde pas la ligne
   # Gosub CTRL_ITMSTA From SCOLIB
    If [F:SCI]CPLQTY>0
       Gosub SCI_ITMSTA_RCP From SCOLIB
    Else
       Gosub SCI_ITMSTA_PUR From SCOLIB
    Endif
    Gosub REWRITE_SCI From SCOLIB

   # Annulation Dťclaration de production sur ordre de sous-traitance :
    WMSGSUI = mess(46,150,1)-mess(642,197,1)+" : "+[F:SCI]SCONUM -" / "- [F:SCI]ITMREF
&                           -" / "-"=>"-num$(WQTYSTU)-[F:SCI]STU
&                           -" / "- mess([F:SCI]ITMSTA,2221,1)
    Call ECR_TRACE(WMSGSUI,0) From GESECRAN

Return


#########################################################################
# Etiquette appelťe par
# - ANNULE_MAJ_STK(SCOSTKLIB)
# - Ecran de Rťception (suppression) <Annulation Entrťe de l'article SCS>
# Les lignes [F:PTD] et [F:SCS] sont chargťes en mťmoire
# [M:STW] contient les donnťes de la dťclaration de production annulťe
#########################################################################
$RAZ_STKENT_SCS             : # selon  ANNULE_SUIVOPE de SUBMTKC

Local Decimal WOPECPLQTY,WOPEREJQTY
If dim(WRET)<1 : Local Integer WRET : Endif
Raz WOPECPLQTY, WOPEREJQTY

 # la qtť d'article rťceptionnť correspond ŗ CPLQTY de [F:SCS] en unitť d'opťration [F:SCS]OPESTU
   If [F:SCS]OPESTU  = [F:PTD]STU
     WOPECPLQTY = [F:PTD]QTYSTU
     WOPEREJQTY = [F:PTD]RRRQTYSTU
   Else
     Call CALCUL_QTY([F:PTD]QTYSTU,[F:PTD]STU,WOPECPLQTY,[F:SCS]OPESTU,GBIDD1) From TRTX3
     Call CALCUL_QTY([F:PTD]RRRQTYSTU,[F:PTD]STU,WOPEREJQTY,[F:SCS]OPESTU,GBIDD1) From TRTX3
   Endif

 # Maj Opťration
   Readlock [F:SCS] Curr
   If fstat=1  GOK=-1 : GLOCK="$SCOOPE"-num$([F:SCS]SCSLIN) : Return
   Elsif fstat GOK=0  : Call RSTA("SCS",num$([F:SCS]SCSLIN)) From GLOCK : Return
   Endif
 # Lecture ťventuelle de article et article-site (facultatif)
   WRET = func ITMLIB.READ_ITM_ITF ([F:SCS]SRVITMREF,[F:SCS]PRHFCY)
   #If WRET = 1 :  GOK = 0 : Return : Endif

   [F:SCS]CPLQTY    -= WOPECPLQTY
   If [F:SCS]CPLQTY<0 : [F:SCS]CPLQTY=0 : Endif
   Call QTEARR([F:SCS]CPLQTY,[F:SCS]OPESTU) From TRTDIV

   [F:SCS]REJCPLQTY -= WOPEREJQTY
   If [F:SCS]REJCPLQTY<0 : [F:SCS]REJCPLQTY=0 : Endif
   Call QTEARR([F:SCS]REJCPLQTY,[F:SCS]OPESTU) From TRTDIV

#--- Maj de WIPCOST -- ne pas planter en cas d'absence de Valo
   Call SCEOPETRK_DEL(36,[F:PTD]PTHNUM,[F:PTD]PTDLIN,"",WRET) From MWIPLIB
   If WRET > 0 : GOK = 0 : Return : Endif

   # pas de maj de l'encours SCF consommť/restaurť ŗ la commande ...

   # CTRL_OPESTA ne dťsolde pas la ligne
   # Gosub CTRL_OPESTA From SCOLIB
   If [F:SCS]CPLQTY>0
       Gosub SCS_OPESTA_RCP From SCOLIB
   Else
       Gosub SCS_OPESTA_PUR From SCOLIB
   Endif

   Gosub REWRITE_SCS From SCOLIB


 # Annulation Service sous-traitance
    WMSGSUI = mess(46,150,1)-mess(4,306,1) +" : "+[F:SCS]SCONUM
&                           -" / "-num$([F:SCS]SCILIN)-" / "-num$([F:SCS]SCSLIN)
&                           -" / "- [F:SCS]SRVITMREF-"=>"-num$(WOPECPLQTY)-[F:SCS]OPESTU
&                           -" / "- mess([F:SCS]OPESTA,2239,1)
    Call ECR_TRACE(WMSGSUI,0) From GESECRAN

Return


#########################################################################
# Etiquette appelťe par
# - ANNULE_MAJ_STK(SCOSTKLIB)
# - Ecran de Rťception               <Annulation Sortie du composant SCM>
# Les lignes [F:PTD] Article lancť et [F:SCM] sont chargťes en mťmoire
#########################################################################
$RAZ_STKSOR_SCM               : # selon ANNULE_SUIVMAT de SUBMTKC
Local Decimal WUSEQTY,WALLQTY,WSHTQTY
#Local Decimal WWUSEQTY,WWALLQTY,WWSHTQTY
Local Decimal WQTE1, WQTE2
Local Integer WTROUVE
If dim(WRET)<1 : Local Integer WRET : Endif

    #Lecture ťventuelle de article et article-site
    WRET = func ITMLIB.READ_ITM_ITF ([F:SCM]CPNITMREF,[F:SCM]STOFCY)
    If WRET = 1 :  GOK = 0 : Return : Endif

  # ctrl si un mvt de stock concerne ce composant et cette rťception
    WTROUVE=0
    Raz WUSEQTY
# les mvts STOJOU sont rattachťs ŗ la ligne de rcp de l'article lancť
#&                      & VCRTYP=36 & VCRNUM=[F:SCM]SCONUM & VCRLIN=[F:SCM]SCILIN
    For [STJ1]STJ1 Where STOFCY=[F:SCM]STOFCY
&                      & VCRTYP=6 & VCRNUM=[F:PTD]PTHNUM & VCRLIN=[F:PTD]PTDLIN
&                      & ITMREF=[F:SCM]CPNITMREF          & REGFLG <> 2
      WTROUVE = 1 : WUSEQTY+=[F:STJ1]QTYSTU
    Next
    If WTROUVE=0
      For [STJ1]STJ1 Where STOFCY=[F:SCM]STOFCY
&                      & VCRTYPORI=36 & VCRNUMORI=[F:SCM]SCONUM & VCRLINORI=[F:SCM]SCILIN
&                      & ITMREF=[F:SCM]CPNITMREF          & REGFLG <> 2
        WTROUVE = 1 : WUSEQTY+=[F:STJ1]QTYSTU
      Next
    Endif
    # Issue 97904 GA 12/2014 If WTROUVE=0 : Return : Endif
    If WTROUVE=0
       If [F:SCM]MATSTA=3 & [F:SCI]CPLQTY=0 # Component was completed with a null issue ?
          Goto SUITE_RAZ_SCM
       Else
          Return
       Endif
    Endif

    Gosub LOAD_STW_ANNULE_SORTIE
    Call ALISTOWORK (5,0,WQTE1,WQTE2,GBIDI2,GBIDI3,WRET) From STKINT
    If WRET : GOK = 0 # GMESSAGE=mess(580,197,1)-":"-num$(WRET)
       Return : Endif

    #----- Appel du sous-programme de mise ŗ jour des stocks -----#
    If [M:STW]NBLIG>0
       Call MAJ_STOCK From STKMAJ
       If GOK < 1 : Return : Endif
    Else
    #  Erreur lors de la suppression des consommations relatives au composant supprimť.
       WMSGSUI =mess(7,177,1)+" : "+[F:SCM]SCONUM -" / "- [F:SCM]CPNITMREF
&                           -num$(WUSEQTY)-[F:SCI]STU
       Call ECR_TRACE(WMSGSUI,0) From GESECRAN
       Return
    Endif

$SUITE_RAZ_SCM
  # ssi la maj de stock est ok, report de la maj sur [F:SCM]
    Readlock [F:SCM]SCM0 Curr
    If fstat=1  GOK=-1 : GLOCK="$SCOMAT"-[F:SCM]CPNITMREF : Return
    Elsif fstat GOK=0  : Call RSTA("SCM",[F:SCM]CPNITMREF) From GLOCK : Return
    Endif

    [F:SCM]USEQTY += WUSEQTY   # USEQTY est dťjŗ nťgatif
    If [F:SCM]USEQTY < 0 : [F:SCM]USEQTY=0 : Endif
    Call QTEARR([F:SCM]USEQTY,[F:SCM]STU) From TRTDIV

    #si matiŤre soldťe on rťinitialise ŗ 0 les qtťs allouťes et en rupture
    #si matiŤre non soldťe , on rťajuste les qtťs allouťes et en rupture
    Raz WRET
    Call CONT_SOLDE_MAT([F:SCM]STOFCY,[F:SCM]CPNITMREF,[F:SCM]USEQTY,[F:SCM]RETQTY,WRET) From SCOLIB
    If WRET = 1
        Gosub SCM_MATSTA_CLO From SCOLIB
        Raz WRET
        Call DELALL(36,LSCONUM,LSCILIN,[F:SCM]SCMLIN,[F:SCM]CPNITMREF,0,WALLQTY,WSHTQTY,WRET) From STKALL
        If WRET <> 0 : Return: Endif
        Raz [F:SCM]ALLQTY,[F:SCM]SHTQTY
    Else
        Gosub SCM_MATSTA_INI From SCOLIB
        # rťallocation automatique du stock libťrť
        If [F:SCM]ALLSTA > 1
           Call UPDATE_ALL("M") From SCOALL
        Elsif [F:PTRW]MODALL>1 # Issue 97904 before [F:PTR] # Issue 94558 GA 11/2013 ssi alloc auto prťvue sur la transaction
           Call UPDATE_ALL("C") From SCOALL
        Endif
    Endif

  # reactivation de l'encours MSF
    Call UPDATE_MSX("M", 0) From SCOLIB

    # affectations
    Gosub MAJ_MTO_SCM From SCOMTOLIB

    Gosub REWRITE_SCM From SCOLIB

 # Annulation Consommation matiŤre
    WMSGSUI = mess(46,150,1)-mess(226,190,1) +" : "+[F:SCM]SCONUM
&                           -" / "-num$([F:SCM]SCILIN)-" / "-num$([F:SCM]SCMLIN)
&                           -" / "- [F:SCM]CPNITMREF-"=>"-num$(WUSEQTY)-[F:SCM]STU
&                           -" / "- mess([F:SCM]MATSTA,2223,1)
    Call ECR_TRACE(WMSGSUI,0) From GESECRAN

Return

#########################################################################
# Etiquette appelťe par                           Issue 93349 GA 10/2013
#                                  Conso de matiŤre non prťvue sur un EO
# - ANNULE_MAJ_STK(SCOSTKLIB)
# - Ecran de Rťception               <Annulation Sortie MatiŤre ajoutťe>
# Les lignes [F:PTD] Article lancť et [F:STJK] sont chargťes en mťmoire
#########################################################################
$RAZ_STKSOR_STJK
Gosub LOAD_STW_ANNULE_SORSTJK
Call ALISTOWORK (5,0,WQTE1,WQTE2,GBIDI2,GBIDI3,WRET) From STKINT
If WRET : GOK = 0
   Return : Endif

#----- Appel du sous-programme de mise ŗ jour des stocks -----#
If [M:STW]NBLIG>0
   Call MAJ_STOCK From STKMAJ
   If GOK < 1 : Return : Endif
Endif
Return

#########################################################################
# Etiquette appelťe par
# - ANNULE_MAJ_STK(SCOSTKLIB)
# - Ecran de Rťception               <Annulation Prix du composant SCM>
# Les lignes [F:PTD] Article lancť et [F:SCM] sont chargťes en mťmoire
#########################################################################
$RAZ_STKPRI_SCM                      : # selon MAJ_PRIX_OPE(MTKLIB)
Local Decimal WCPR, WPRIX, WQTYSTU, WPRISTU, WQTYUO, WPRIUO

If [F:SCM]SCOFLG<>3 : Return : Endif

# ssi la maj de stock est ok, report de la maj sur [F:SCM]
Readlock [F:SCM]SCM0 Curr
If fstat=1  GOK=-1 : GLOCK="$SCOMAT"-[F:SCM]CPNITMREF : Return
Elsif fstat GOK=0  : Call RSTA("SCM",[F:SCM]CPNITMREF) From GLOCK : Return
Endif

# nťcessaire ?
# Gosub CAL_QTYPRI_SCM

# Issue 99332 GA 05/2014 + 2 parameters [F:PTD]PTHNUM,[F:PTD]PTDLIN
#--- Maj de WIPCOST -- ne pas planter en cas d'absence de Valo
Call CREWIPMATSCO("A",[F:PTD]PTHNUM,[F:PTD]PTDLIN,WRET) From MWIPLIB
If WRET > 0 : GOK = 0 : Return : Endif

If WQTYSTU>0
 # Maj USEQTY pour compatibilitť avec les matiŤres fournies au sous-traitant
   [F:SCM]USEQTY-=WQTYSTU
   If [F:SCM]USEQTY<0             [F:SCM]USEQTY=0             Endif
   If [F:SCM]USEQTY>[F:SCM]RETQTY [F:SCM]USEQTY=[F:SCM]RETQTY Endif
Endif

# CTRL_MATSTA ne dťsolde pas la ligne
# Gosub CTRL_MATSTA From SCOLIB
If [F:SCM]USEQTY>0
   Gosub SCM_MATSTA_RCP From SCOLIB
Else
   Gosub SCM_MATSTA_PUR From SCOLIB
Endif

Gosub REWRITE_SCM From SCOLIB

Return
################################################
Subprog READ_POQW(LITMREF,LVCRNUM,LVCRLIN,LVCRSEQ,LPOHNUM,LPOPLIN,LPOQSEQ)
Value    Char    LITMREF
Value    Char    LVCRNUM
Value    Integer LVCRLIN
Value    Integer LVCRSEQ
Variable Char    LPOHNUM
Variable Integer LPOPLIN
Variable Integer LPOQSEQ

[F:POQW]=[F:POQ]
[F:POPW]=[F:POP]

# 1er cas: on connait la rťf ligne cde
If LPOHNUM<>"" & LPOPLIN>0
  If LPOHNUM<>"" & LPOHNUM<>[F:POQW]POHNUM | LPOPLIN<>[F:POQW]POPLIN | LPOQSEQ<>[F:POQW]POQSEQ
    Read [F:POQW]POQ0=LPOHNUM;LPOPLIN;LPOQSEQ
    If fstat | [F:POQW]ITMREF<> LITMREF Raz [F:POQW] Endif
  Endif
  If LPOHNUM<>"" & LPOHNUM<>[F:POPW]POHNUM | LPOPLIN<>[F:POPW]POPLIN | LPOQSEQ<>[F:POPW]POQSEQ
    Read [F:POPW]POP0=LPOHNUM;LPOPLIN;LPOQSEQ
    If fstat | [F:POPW]ITMREF<> LITMREF Raz [F:POPW] Endif
  Endif
Endif

# 2Ťme cas: on ne connait pas la rťf ligne cde
If LPOHNUM="" | LPOPLIN=0
    Filter [POQW] Where  VCRTYPORI=36      & VCRNUMORI=LVCRNUM
&                      & VCRLINORI=LVCRLIN & VCRSEQORI=LVCRSEQ
&                      & ITMREF   =LITMREF
    Read   [POQW]POQ4 First
    Filter [POQW]
    If fstat : Raz [F:POQW] Endif
#
  # on renvoie la rťf trouvťe
    LPOHNUM=[F:POQW]POHNUM
    LPOPLIN=[F:POQW]POPLIN
    LPOQSEQ=[F:POQW]POQSEQ
#
    If LPOHNUM<>"" & LPOHNUM<>[F:POPW]POHNUM | LPOPLIN<>[F:POPW]POPLIN | LPOQSEQ<>[F:POPW]POQSEQ
       Read [F:POPW]POP0=LPOHNUM;LPOPLIN;LPOQSEQ
      If fstat | [F:POPW]ITMREF<> LITMREF Raz [F:POPW] Endif
    Endif
Endif

End
################################################

################################################
Subprog ECR_DEBUG(LMESSAGE)
Value Char LMESSAGE
If find(GUSER,"xxADMINxx","zGA")    Call ECR_TRACE(LMESSAGE,0) From GESECRAN Endif
End
