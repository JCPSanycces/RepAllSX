# Gestión de la máscara STOENT (Especifico)

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla STOENT) 01/04/2016 09:30:30 (ADMIN)
######################################################################################
$ACTION
Case ACTION
 When Default
Endcase
Return

Subprog D_XGNFNULOT(VALEUR)
Variable Char    VALEUR()
  If !clalev ([XGL]) Then Local File XGNFNULOT [XGL] : Endif

  If [M:ENT]STOFCY='200' or [M:ENT]STOFCY='210' Then
    Read [F:XGL] First
    VALEUR=[F:XGL]SIGNULOT
  Endif

End


######################################################################################
## Etiqueta ańadida por el supervisor (pantalla STOENT) 28/07/2016 11:55:55 (ADMIN)
######################################################################################
Subprog AP_LOTAFF(VALEUR)
Variable Char    VALEUR()

   If !clalev ([XSLF]) Then Local File STOLOTFCY [XSLF] : Endif
   Local Integer XNOL
If 0 Then ## DESACTIVACIÓN TEMPORAL DE CONTROL DE UBICACIÓN ## XVT24/10/2016 . 10.16
   If VALEUR<>"" Then
     If [M:ENT]STOFCY="200" or [M:ENT]STOFCY="210" or [M:ENT]STOFCY="300" or [M:ENT]STOFCY="310" Then
        If [M:ENT]STOFCY="200" or [M:ENT]STOFCY="210" Then
          Filter [F:XSLF] Where ITMREF=[M:ENT]ITMREF(nolign-1) and LOT=VALEUR and (STOFCY="200" or STOFCY="210")
        Endif
        If [M:ENT]STOFCY="300" or [M:ENT]STOFCY="310" Then
          Filter [F:XSLF] Where ITMREF=[M:ENT]ITMREF(nolign-1) and LOT=VALEUR and (STOFCY="300" or STOFCY="310")
        Endif
        For [F:XSLF]
          Call MESSAGE ("El lote " + VALEUR + " ya ha sido utilizado para el artículo") From GESECRAN
          mkstat=2
          Break
        Next
        Filter [F:XSLF]
     Endif

   If nolign-1 > 0 Then
    For XNOL=0 To nolign-2
      If [M:ENT]LOTAFF(XNOL)=VALEUR and [M:ENT]ITMREF(XNOL)=[M:ENT]ITMREF(nolign-1) Then
         Call MESSAGE ("El lote " + VALEUR + " ya ha sido utilizado") From GESECRAN
         mkstat=2
         Break
      Endif
    Next
   Endif
  Endif
Endif  ##FIN DESACTIVACIÓN TEMPORAL DE CONTROL DE UBICACIÓN ## XVT24/10/2016 . 10.16
End


######################################################################################

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla STOENT) 28/07/2016 12:05:39 (ADMIN)
######################################################################################
Subprog AP_LOC(VALEUR)
Variable Char    VALEUR()
## DESACTIVACIÓN TEMPORAL DE CONTROL DE UBICACIÓN ## XVT24/10/2016 . 10.16
If 0 Then
  If !clalev ([XSTO]) Then Local File STOCK[XSTO] : Endif

  If VALEUR<>"" and VALEUR<>"GRAL" and VALEUR<>"MUELLE" Then
    If [M:ENT]STOFCY="200" Then
       Filter [F:XSTO] Where LOC=VALEUR and STOFCY="200" and QTYSTU > 0 and LOC<>"GRAL" and LOC<>"MUELLE"
       For [F:XSTO]
        Call MESSAGE("La ubicación " + VALEUR + " ya tiene stock. Seleccione otra") From GESECRAN
        mkstat=2
        Break
       Next
       Filter [F:XSTO]
      
       If nolign-1 > 0 Then
        For XNOL=0 To nolign-2
          If [M:ENT]LOC(XNOL)=VALEUR Then
             Call MESSAGE ("La ubicación " + VALEUR + " ya ha sido utilizada. Seleccione otra") From GESECRAN
             mkstat=2
             Break
          Endif
        Next
       Endif
     Endif
  Endif
Endif  ## FIN-DESACTIVACIÓN TEMPORAL DE CONTROL DE UBICACIÓN ## XVT24/10/2016 . 10.16
End


