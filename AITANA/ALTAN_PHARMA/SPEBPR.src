# Gestión de la máscara BPRBPC (Especifico)

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla BPRBPC) 01/06/2016 16:23:34 (ADMIN)
######################################################################################
$ACTION
Case ACTION
 When Default
Endcase
Return

Subprog C_XINVADR(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>"" Then
    If !clalev ([XBPA]) Local File BPADDRESS [XBPA] : Endif
    Read [F:XBPA]BPA0=1;[M:BPC0]BPCNUM;VALEUR
    If fstat Then
       mkstat=2
       GMESSAGE="Código de dirección no válido"
    Endif
  Endif
End

