#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
    Case ACTION
        When "AP_IMPORT"  : Gosub AP_IMPORT
    Endcase
Return

$OUVRE
    Gosub OUVRE From IMPPTHS
Return

$RAZCRE
    Gosub RAZCRE From IMPPTHS
Return

$VALID
    Gosub VALID From IMPPTHS
Return

$SAIMSK
    Gosub SAIMSK From IMPPTHS
Return



$AP_IMPORT
  If IMPFIC="PTD" Then
    Gosub CORRIGELIN
  Endif
Return

$CORRIGELIN
  If !Clalev([F:POQ])  Then : Local File PORDERQ [POQ] : Endif
  If !Clalev([F:ITM])  Then : Local File ITMMASTER [ITM] : Endif

  Read [F:POQ]POQ0=[F:PTD]POHNUM;[F:PTD]POPLIN;1
  If !fstat Then
     Read [F:ITM]ITM0=[F:POQ]ITMREF
     If !fstat Then
         If [F:ITM]PUU<>[F:POQ]PUU and [F:ITM]PUU="ENV" Then
             [F:PTD]PUU=[F:ITM]STU
             [F:PTD]QTYPUU=[F:PTD]QTY*[F:ITM]PUUSTUCOE
         Endif
     Endif   
  Endif
Return


