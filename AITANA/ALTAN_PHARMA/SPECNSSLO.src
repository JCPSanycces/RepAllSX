Subprog B20_NBLIG
  Local Integer YN : YN = 2
  Local Char LARTICULO, LLOTE
  LARTICULO = [M:SLO1]ITMREF
  LLOTE = [M:SLO2]LOT(nolign-1)

  Call OUINON("¢Desea descargar ficheros XML en LOCAL?", YN) From GESECRAN
  If YN = 2 Then
    Call GENERA_FICHEROS_XML(LARTICULO, LLOTE, "", "LOCAL") From XSERIALIZACION
  Else
   Call GENERA_FICHEROS_XML(LARTICULO, LLOTE, "", "") From XSERIALIZACION
  Endif
  Infbox "Ficheros XML Generados"
End


