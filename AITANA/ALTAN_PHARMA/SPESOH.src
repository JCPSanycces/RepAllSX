#<AdxTL>@(#)0.0.0.0 $Revision$ Pedidos
$ACTION
Case ACTION
 When "VALLIG" : Gosub VALLIG
 When "APRES_MOD" : Gosub APRES_MOD
 When Default
Endcase
Return


$APRES_MOD
  XFILENAME=""
Return

$VALLIG
  If dim(XFILENAME)<0 Then
     Local Char XFILENAME(12)
     XFILENAME=format$("D:YYMMDDhhmmss",date$)
  Endif

  If TRTLIG="A" and SIGN=-1 and ([F:SOP]STOFCY="110" or [F:SOP]STOFCY="210" or [F:SOP]STOFCY="310") Then
     Call XSOPANU([M:SOH0]SOHNUM,[F:SOP]SOPLIN,XFILENAME)
  Endif

Return



Subprog XSOPANU(PSOHNUM, PSOPLIN, PFILENAME)
Value Char PSOPNUM()
Value Integer PSOPLIN
Value Char PFILENAME()

    #-- variables diversas
    Local Char FICHERO(GDIMFIC), NOM_FICH(50), EXT(3)

    #-- variables de fichero, inicializacion
    EXT    = "txt"                   #-- extension del fichero
    NOM_FICH = "PVANU" + "_" + PFILENAME
 #   NOM_FICH = "PVANU" + "_" + format$("D:YYMMDDhhmmss",date$)
 #   NOM_FICH = "PVANU" + "_" + PSOHNUM
    FICHERO      = filpath("impexp\V10",NOM_FICH,EXT,"","","")
    Openo FICHERO,-1 Using [YFIC]
    Iomode adxifs ";" Using [YFIC]          # SEPARACION DE CAMPOS ";"
    Iomode adxirs chr$(13)+chr$(10) Using [YFIC]    # FIN DE LINEA
    Iomode adxium 50 Using [YFIC]
       Wrseq PSOHNUM ; Using [YFIC]
       Wrseq num$(PSOPLIN) Using [YFIC]
    Openo Using [YFIC]
End






