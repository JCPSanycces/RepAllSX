#<AdxTL>@(#)0.0.0.0 $Revision$ 
#XVT230620 - ajustes migraciÛn V12
#XVT280820 - TICKET #112 - El pasword largo debe usar el campo password 2 de atabdiv
#CBG 03/09/2020-Se aÒade el parametro /hostkey=* para reconocer el host y no preguntar OS-592 - Buscar CBG
# MAB.13112020 - Modificaciones serializaciÛn. Se aÒade al proceso de las recepciones la tabla YICORDTMP
Subprog CONTROLSSTATUS()
  Local Char LLOTE, LARTICULO
  Local Char LSTATUS
  Local Integer LCONTADOR
  Local Char REQSTR(250)(10)
  Local Char ORIGEN_DOSSIER
  Local Char LDOSSIER(20)
  Local Char LSTALOT : LSTALOT = ''
  Local Char LPLANTA

#   Call FUNTDUCLO("3", [F:XICO]ORDERNAME) From TRTTDUCLO
#
#   Return
# MODELO PARA JOB DE CIERRE DE ORDENES:
#
  #DOSSIER=RBI
  #LAN=SPA
  #UTIL=ADMIN
  #PASSE=BAABAA
  #GRP=
  #TACHE=FUNTDUCLO
  #Date=20181115
  #HEURE=1239

 # Call OUVRE_TRACE("Control Status ”rdenes FabricaciÛn") From LECFIC
 # Call ECR_TRACE("Apertura de Tablas", 0 ) From GESECRAN


  ORIGEN_DOSSIER=filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER
  LDOSSIER = [S]nomap(0)



  Gosub ABRIR_TABLAS

  Filter [F:XICO] Where XSTATUS > 2 and XSTATUS < 9 #
  Call ECR_TRACE("Registros encontrados con Status > 2 y < 9: " + num$(rowcount([F:XICO])),0) From GESECRAN
  For [F:XICO]
   # LCONTADOR +=1
    Call ECR_TRACE("PROCESADO DE ORDEN: " + [F:XICO]ORDERNAME,0) From GESECRAN
    Call ECR_TRACE("Estatus ACTUAL de la orden: " + [F:XICO]ORDERNAME + " - " + num$([F:XICO]XSTATUS),0) From GESECRAN
    LSTATUS = num$([F:XICO]XSTATUS)
    # CIERRE DE ORDEN DE MOMENTO INACTIVO
    #If [F:XICO]XSTATUS = 10 Then
    #Endif
    # GENERACI”N DE FICHEROS XML
    # PASAR STATUS A 9
   # LSTATUS = [F:XICO]XSTATUS
    If [F:XICO]XSTATUS = 8 Then
      Call ECR_TRACE("DENTRO DE STATUS 8 : " + [F:XICO]ORDERNAME,0) From GESECRAN
      # HAY QUE REVISAR SI ES UNA OF O ES UNA RECEPCI”N

        Call ECR_TRACE("STATUS 8.BUSCAR LA OF : " + [F:XICO]ORDERNAME,0) From GESECRAN
        Read [F:MFI]MFI2 = [F:XICO]ORDERNAME # and  PLNFCY = [F:XICO]FCY
        #Read [F:MFI] First
        If !fstat Then
          Call ECR_TRACE("DENTRO DE DATOS_OF - FABRICACI”N : " + [F:XICO]ORDERNAME,0) From GESECRAN
          LLOTE = [F:MFI]LOT
          LARTICULO = [F:MFI]ITMREF
          Call ECR_TRACE("DESPUES DE DATOS OF: " + [F:XICO]ORDERNAME,0) From GESECRAN
          Call ECR_TRACE("ANTES DE GENERAR EL XML : " + [F:XICO]ORDERNAME + " - " + LARTICULO + " - "+ LLOTE,0) From GESECRAN
          Call GENERA_FICHEROS_XML(LARTICULO, LLOTE, [F:XICO]ORDERNAME ,"" )
          Call ECR_TRACE("DESPUES DE GENERAR EL XML : " + [F:XICO]ORDERNAME,0) From GESECRAN
          #[F:XICO]XSTATUS = 9
          #Rewrite [F:XICO]
    #      If !clalev([F:XAUX])  Then : Global File ICORDSTATUS  [XAUX] : Endif
    #      Trbegin [F:XAUX]
    #      Update [F:XAUX] Where [F:XAUX]ORDERNAME = [F:XICO]ORDERNAME With [F:XAUX]XSTATUS = 9
    #      Commit
    #      Close File [F:XAUX]
           Execsql From "S"  Sql "UPDATE " + LDOSSIER + ".ICORDSTATUS SET XSTATUS_0 = 9 WHERE ORDERNAME_0 = '" + [F:XICO]ORDERNAME + "'"
           LSTATUS = '9'
        Else # SI NO LO ENCONTRAMOS, ES PORQUE ES UNA RECEPCI”N
          Call ECR_TRACE("STATUS 8. - RECEPCI”N : " + [F:XICO]ORDERNAME,0) From GESECRAN
          Local Integer LNUMLIN
          Local Char LORDERNAME
          LNUMLIN = 0
          LORDERNAME = ''


          If instr(1,[F:XICO]ORDERNAME,"_") > 0 Then    # MAB.29092020.NEW
            # BUSCAMOS EN LAS RECEPCIONES EL ARTÕCULO
            LNUMLIN = val(right$([F:XICO]ORDERNAME,instr(1,[F:XICO]ORDERNAME,"_")+1)) # MAB.29092020.NEW
            LORDERNAME = left$([F:XICO]ORDERNAME,instr(1,[F:XICO]ORDERNAME,"_")-1)# MAB.29092020.NEW
            Filter [F:ZREC] Where PTHNUM = LORDERNAME and PTDLIN = LNUMLIN   # MAB.29092020.NEW
            Call ECR_TRACE("STATUS 8.Recorrer articulo de la recepciÛn - Orden:" + LORDERNAME + " - LÌnea: " + num$(LNUMLIN),0) From GESECRAN
          Else
            Filter [F:ZREC] Where PTHNUM = [F:XICO]ORDERNAME
            Call ECR_TRACE("STATUS 8.Recorrer articulo de la recepciÛn - Orden:" + [F:XICO]ORDERNAME,0) From GESECRAN
          Endif
          # PROCESAR CADA UNA DE LAS LÕNEAS DE LA RECEPCI”N
          For [F:ZREC]
            Call ECR_TRACE("STATUS 8.DENTRO DE DATOS_OF - RECEPCI”N : " + [F:XICO]ORDERNAME,0) From GESECRAN
            Filter [F:YICO] Where PTHNUM = [F:ZREC]PTHNUM and PROCESADO = 1 # and PTDLIN = [F:ZREC]PTDLIN
            For [F:YICO]
              Call ECR_TRACE("STATUS 8.Articulo recepciÛn: " + [F:ZREC]ITMREF ,0) From GESECRAN
              # Read [F:ITM]ITM0 = [F:ZREC]ITMREF
              Read [F:ITM]ITM0 = [F:YICO]ITMREF
              If fstat = 0 Then # ariculo encontrado
                If [F:ITM]XSERIALIZADO = 2 Then  # articulo es serializable
                    Call ECR_TRACE("STATUS 8.Articulo encontrado es serializable" ,0) From GESECRAN
                    LARTICULO = [F:ITM]ITMREF
                    # EL ARTICULO ES SERIALIZBLE, BUSCAMOS EL LOTE EN LA TABLA STOJOU
                    Call ECR_TRACE("STATUS 8.Articulo encontrado - Buscamos su lote " ,0) From GESECRAN
                    LLOTE = [F:YICO]LOT
                    LPLANTA = [F:YICO]FCY
                    # MAB.001.SNEW - PARA CADA LOTE Y ARTICULO BUSCAMOS SI HA CAMBIADO DE ESTADO
                    # SI ALGUNO DE LOS ESTADOS HA CAMBIADO A RD O R SE "CIERRA" LA RECEPCI”N
                    # SI ALGUNO DE LOS ESTADOS HA CMABIADO A AV O AL, SE CAMBIA EL ESTADO DE LA RECEPCI”N A AV
                    If LPLANTA <> '' Then
                      Filter [F:STO] Where ITMREF = LARTICULO and LOT = LLOTE  and STOFCY = LPLANTA # and STOFCY = [F:XICO]FCY
                    Else
                      Filter [F:STO] Where ITMREF = LARTICULO and LOT = LLOTE  # and STOFCY = LPLANTA # and STOFCY = [F:XICO]FCY
                    Endif
                    Read [F:STO] First
                    If !fstat Then
                      Call ECR_TRACE("STATUS 8. Estatus del lote de la recepciÛn: " + [F:STO]LOT + " -> " + [F:STO]STA,0) From GESECRAN
                      If [F:STO]STA = "AV" or [F:STO]STA = "AL" Then
                          #Execsql From "S"  Sql "UPDATE " + LDOSSIER + ".ICORDSTATUS SET XSTATUS_0 = 8 WHERE ORDERNAME_0 = '" + [F:XICO]ORDERNAME + "'"
                          LSTALOT = 'OK'
                      Else
                          LSTALOT = ''
                      Endif
                   Endif
                   If LSTALOT = 'OK' and LARTICULO <> '' and LLOTE <> '' Then
                      Call ECR_TRACE("ANTES DE GENERAR EL XML : " + [F:XICO]ORDERNAME + " - " + LARTICULO + " - "+ LLOTE,0) From GESECRAN
                      Call GENERA_FICHEROS_XML(LARTICULO, LLOTE, [F:XICO]ORDERNAME ,"" )
                      Call ECR_TRACE("DESPUES DE GENERAR EL XML : " + [F:XICO]ORDERNAME,0) From GESECRAN
                      Trbegin [F:YICO]
                      [F:YICO]PROCESADO = 2
                      Rewrite [F:YICO]
                      If !fstat Then
                        Commit
                      Else
                        Rollback
                      Endif


                   Else
                      Call ECR_TRACE("STATUS 8. NO GENERO XML POR EL ESTADO DEL LOTE: " + [F:STO]LOT + " -> " + [F:STO]STA,0) From GESECRAN
                   Endif
               Else
                  Call ECR_TRACE("STATUS 8.Articulo encontrado NO es serializable" ,0) From GESECRAN
               Endif
            Else
                Call ECR_TRACE("STATUS 8.Articulo NO encontrado " ,0) From GESECRAN
            Endif
          Next # for YICO - ICORDTMP
        Next # FOR ZREC - PRECEIPT
        Call ECR_TRACE("STATUS 8. REVISAR SI QUEDA ALG⁄N LOTE DE LA RECEPCI”N POR PROCESAR DENTRO DE : " + [F:XICO]ORDERNAME,0) From GESECRAN
        Filter [F:YICO] Where PTHNUM = [F:ZREC]PTHNUM and PROCESADO = 1
        If rowcount([F:YICO]) = 0 Then
          Execsql From "S"  Sql "UPDATE " + LDOSSIER + ".ICORDSTATUS SET XSTATUS_0 = 9 WHERE ORDERNAME_0 = '" + [F:XICO]ORDERNAME + "'"
           LSTATUS = '9'
        Endif

       Endif # FIN IF FSTAT

      # Gosub DATOS_OF

    Endif # FIN IF STATUS = 8




#    # SUBCONTRATACI”N -- LAS ORDENES DE SUBCONTRATACI”N ENTRAR¡N EN STATUS 7
    If [F:XICO]XSTATUS = 7 Then
    # Si el lote esta en AV pasar el status a 8 para que la proxima pasa se envien los XML
      Gosub STATUS_LOTE_REC
    Endif

    # SI EL STATUS DEL LOTE ES AV O AL, MODIFICAR EL STATUS A 6
    If [F:XICO]XSTATUS = 5 Then
      Gosub STATUS_LOTE
      # SACAR EL LOTE DE LA ORDEN
    Endif

    # GENERAR SEGUIMIENTO DE PRODUCCI”N AUTOMATICO (MODELO IMPORT MKI)
    # PASAR STATUS A 5
    If [F:XICO]XSTATUS = 3 Then
      GERRTRACE = 0
      Gosub SEGUIMIENTO_PRODUCCION
      If GERRTRACE = 0 Then
        Call ECR_TRACE("SEGUIMIENTO_PRODUCCION - RESULTADO IMPORT CORRECTO",0) From GESECRAN
        Execsql From "S"  Sql "UPDATE " + LDOSSIER + ".ICORDSTATUS SET XSTATUS_0 = 5 WHERE ORDERNAME_0 = '" + [F:XICO]ORDERNAME + "'"
        LSTATUS = '5'
      Else
        Call ECR_TRACE("SEGUIMIENTO_PRODUCCION - RESULTADO IMPORT CON ERRORES",0) From GESECRAN
      Endif
    Endif

    Call ECR_TRACE("Estatus FINAL de la orden: " + [F:XICO]ORDERNAME + " - " + LSTATUS,0) From GESECRAN
  Next

  # Call  XML_SALES_SHIPMENT("TEST_SALES")

 # Call FERME_TRACE From LECFIC
 # Call LEC_TRACE() From LECFIC
  Gosub CERRAR_TABLAS
End

##################################################################################################
$ABRIR_TABLAS

  If clalev([F:ICO])  = 0   : Local File ICORDSTATUS [XICO] : Endif   # TABLA GES
  If clalev([F:STO]) = 0    : Local File STOCK [STO]         : Endif   # TABLA STOCK
  If clalev([F:MFI]) = 0    : Local File MFGITM [MFI]        : Endif   # TABLA LINEAS ORDENES DE FABRICACI”N
  If clalev([F:ITM]) = 0    : Local File ITMMASTER [ITM]        : Endif   # TABLA ARTICULOS
  If clalev([F:ZATA]) = 0   : Local File ATABDIV [ZATA]        : Endif   # PAR¡METROS SERIALIZACI”N

  If clalev([F:ZREC]) = 0   : Local File  PRECEIPTD [ZREC]        : Endif   # DETALLE RECEPCIONES
  If clalev([F:STJ]) = 0    : Local File STOJOU [STJ]         : Endif   # TABLA STOJOU
  If clalev([F:YICO]) = 0 Then : Local File YICORDTMP [YICO] : Endif # tabla tmp icordtmp para lÌneas de recepciones MAB.001.NEW


Return

####################################################################################################
$CERRAR_TABLAS
  Close File [XICO]
  Close File [STO]
  Close File [MFI]
  Close File [ITM]
  Close File [ZATA]
  Close File [ZREC]
  Close File [STJ]
  Close File [YICO]
Return

####################################################################################################
$STATUS_LOTE
     Local Char LPLANTA(10)

      Filter [F:MFI] Where MFGNUM = [F:XICO]ORDERNAME # and  PLNFCY = [F:XICO]FCY
      Read [F:MFI] First
      If !fstat Then
        LLOTE = [F:MFI]LOT
        LARTICULO = [F:MFI]ITMREF
        LPLANTA = [F:MFI]MFGFCY
      Endif
      Filter [F:MFI]
      # Se quita el filtro por planta, para tener en cuenta los lotes liberados en todas las plantas.
      # Filter [F:STO] Where ITMREF = LARTICULO and LOT = LLOTE and STOFCY = LPLANTA # and STOFCY = [F:XICO]FCY
      Filter [F:STO] Where ITMREF = LARTICULO and LOT = LLOTE # and STOFCY = LPLANTA # and STOFCY = [F:XICO]FCY
      Read [F:STO] First
      If !fstat Then
        Call ECR_TRACE("Estatus del lote: " + [F:STO]LOT + " -> " + [F:STO]STA,0) From GESECRAN
        If [F:STO]STA = "AV" or [F:STO]STA = "AL" Then
          #[F:XICO]XSTATUS = 6
          #Rewrite [F:XICO]
#          If !clalev([F:XAUX])  Then : Global File ICORDSTATUS  [XAUX] : Endif
#            Trbegin [F:XAUX]
#            Update [F:XAUX] Where [F:XAUX]ORDERNAME = [F:XICO]ORDERNAME With [F:XAUX]XSTATUS = 6
#            Commit
#            Close File [F:XAUX]

            Execsql From "S"  Sql "UPDATE " + LDOSSIER + ".ICORDSTATUS SET XSTATUS_0 = 6 WHERE ORDERNAME_0 = '" + [F:XICO]ORDERNAME + "'"
            LSTATUS = '6'
          Endif
          # comentado a peticiÛn de Rafa, y se pasa a la parte de abajo el status R
#
#          If [F:STO]STA = "R" Then
#            Execsql From "S"  Sql "UPDATE " + LDOSSIER + ".ICORDSTATUS SET XSTATUS_0 = 10 WHERE ORDERNAME_0 = '" + [F:XICO]ORDERNAME + "'"
#            LSTATUS = '10'
#          Endif
          # STATUS RD # STATUS R
          If [F:STO]STA = "RD" or [F:STO]STA = "R" Then
            Execsql From "S"  Sql "UPDATE " + LDOSSIER + ".ICORDSTATUS SET XSTATUS_0 = 11 WHERE ORDERNAME_0 = '" + [F:XICO]ORDERNAME + "'"
            LSTATUS = '11'
          Endif
      Endif
      Filter [F:STO]
Return

####################################################################################################
$STATUS_LOTE_REC
  If !clalev([F:YICO]) Then : Local File YICORDTMP [YICO] : Endif
  Local Integer LNUMLIN
  Local Char LORDERNAME
  LNUMLIN = 0
  LORDERNAME = ''

  If instr(1,[F:XICO]ORDERNAME,"_") > 0 Then    # MAB.29092020.NEW
    # BUSCAMOS EN LAS RECEPCIONES EL ARTÕCULO
    LNUMLIN = val(right$([F:XICO]ORDERNAME,instr(1,[F:XICO]ORDERNAME,"_")+1)) # MAB.29092020.NEW
    LORDERNAME = left$([F:XICO]ORDERNAME,instr(1,[F:XICO]ORDERNAME,"_")-1) # MAB.29092020.NEW
    Filter [F:ZREC] Where PTHNUM = LORDERNAME and PTDLIN = LNUMLIN   # MAB.29092020.NEW
    Call ECR_TRACE("Recorrer articulo de la recepciÛn - Orden:" + LORDERNAME + " - Linea: " +num$(LNUMLIN),0) From GESECRAN
  Else                                  # MAB.29092020.NEW
    Filter [F:ZREC] Where PTHNUM = [F:XICO]ORDERNAME
    Call ECR_TRACE("Recorrer articulo de la recepciÛn - Orden:" + [F:XICO]ORDERNAME ,0) From GESECRAN
   Endif                                 # MAB.29092020.NEW





  LSTATUS = ''
  For [F:ZREC]
    # BUSCO ESA LÕNEA EN LA TABLA ICORTMP CON REGISTROS PENDIENTES DE PROCESAR
    Filter [F:YICO] Where PTHNUM = [F:ZREC]PTHNUM and NUMLIG = [F:ZREC]PTDLIN and PROCESADO = 1 # and PTDLIN = [F:ZREC]PTDLIN


    For [F:YICO]

      Call ECR_TRACE("Articulo recepciÛn: " + [F:ZREC]ITMREF ,0) From GESECRAN
      # Read [F:ITM]ITM0 = [F:ZREC]ITMREF
      Read [F:ITM]ITM0 = [F:YICO]ITMREF
      If fstat = 0 Then # ariculo encontrado
        If [F:ITM]XSERIALIZADO = 2 Then  # articulo es serializable
            Call ECR_TRACE("Articulo encontrado es serializable" ,0) From GESECRAN
            LARTICULO = [F:ITM]ITMREF
            # EL ARTICULO ES SERIALIZBLE, BUSCAMOS EL LOTE EN LA TABLA STOJOU
            Call ECR_TRACE("Articulo encontrado - Buscamos su lote " ,0) From GESECRAN

            #Filter  [F:STJ] Where ITMREF = LARTICULO and VCRNUM = [F:YICO]PTHNUM and VCRLIN = [F:YICO]PTDLIN # A—ADO LÕNEA EN ESTE FILTRO . MAB.29092020.NEW
            #Read  [F:STJ] First
            #If fstat = 0 Then
            #  Call ECR_TRACE("Articulo encontrado - lote encontrado: " + [F:STJ]LOT ,0) From GESECRAN
            LLOTE = [F:YICO]LOT
            #Break # articulo de la recepciÛn es serializable, por lo tanto, salir del bucle
            #Else
            #  Call ECR_TRACE("Articulo encontrado - lote NO encontrado: " ,0) From GESECRAN
            #Endif

            # MAB.001.SNEW - PARA CADA LOTE Y ARTICULO BUSCAMOS SI HA CAMBIADO DE ESTADO
            # SI ALGUNO DE LOS ESTADOS HA CAMBIADO A RD O R SE "CIERRA" LA RECEPCI”N
            # SI ALGUNO DE LOS ESTADOS HA CMABIADO A AV O AL, SE CAMBIA EL ESTADO DE LA RECEPCI”N A AV
            If LARTICULO <> '' and LLOTE <> '' Then
            Filter [F:STO] Where ITMREF = LARTICULO and LOT = LLOTE # and STOFCY = LPLANTA # and STOFCY = [F:XICO]FCY
            Read [F:STO] First
            If !fstat Then
              Call ECR_TRACE("Estatus del lote de la recepciÛn: " + [F:STO]LOT + " -> " + [F:STO]STA,0) From GESECRAN
              If [F:STO]STA = "AV" or [F:STO]STA = "AL" Then
                  Execsql From "S"  Sql "UPDATE " + LDOSSIER + ".ICORDSTATUS SET XSTATUS_0 = 8 WHERE ORDERNAME_0 = '" + [F:XICO]ORDERNAME + "'"
                  LSTATUS = '8'
                  # salimos del bucle
                  Break
                Endif
                # STATUS RD # STATUS R
                If [F:STO]STA = "RD" or [F:STO]STA = "R" Then
                  Execsql From "S"  Sql "UPDATE " + LDOSSIER + ".ICORDSTATUS SET XSTATUS_0 = 11 WHERE ORDERNAME_0 = '" + [F:XICO]ORDERNAME + "'"
                  LSTATUS = '11'
                  Break
                Endif
            Endif
            Filter [F:STO]
          Endif
        Else
          Call ECR_TRACE("Articulo encontrado es NO serializable" ,0) From GESECRAN
        Endif
       Endif
    Next
    If LSTATUS <> '' Then
      Break
    Endif
   Next
   Filter [F:ZREC]
   Filter [F:ITM]
   Filter [F:STJ]
   If LARTICULO <> '' and LLOTE <> '' Then
      Filter [F:STO] Where ITMREF = LARTICULO and LOT = LLOTE # and STOFCY = LPLANTA # and STOFCY = [F:XICO]FCY
      Read [F:STO] First
      If !fstat Then
        Call ECR_TRACE("Estatus del lote de la recepciÛn: " + [F:STO]LOT + " -> " + [F:STO]STA,0) From GESECRAN
        If [F:STO]STA = "AV" or [F:STO]STA = "AL" Then
            Execsql From "S"  Sql "UPDATE " + LDOSSIER + ".ICORDSTATUS SET XSTATUS_0 = 8 WHERE ORDERNAME_0 = '" + [F:XICO]ORDERNAME + "'"
            LSTATUS = '8'
          Endif
          # STATUS RD # STATUS R
          If [F:STO]STA = "RD" or [F:STO]STA = "R" Then
            Execsql From "S"  Sql "UPDATE " + LDOSSIER + ".ICORDSTATUS SET XSTATUS_0 = 11 WHERE ORDERNAME_0 = '" + [F:XICO]ORDERNAME + "'"
            LSTATUS = '11'
          Endif

      Endif

      Filter [F:STO]




   Endif





Return

####################################################################################################
$SEGUIMIENTO_PRODUCCION
  Local Char FICEXP(100)

  Local Char ZDATETIME(14)

  Local Char NOMBRE_FICHERO(100)
  Local Char LUOM, LUBICACION, LUBICACION, LFECHA_CADUCIDAD
  Local Char LPLANTA(10)



  ZDATETIME = time$
  ZDATETIME = mid$(ZDATETIME,1,2)+mid$(ZDATETIME,4,2)+mid$(ZDATETIME,7,2)
  ZDATETIME = date$+ZDATETIME
  Call ECR_TRACE("DENTRO DE SEGUIMIENTO_PRODUCCION ",0) From GESECRAN

  NOMBRE_FICHERO = "OF_"+[F:XICO]ORDERNAME+"_"+ZDATETIME

  Call ECR_TRACE("SEGUIMIENTO_PRODUCCION - FICHERO EXPORT: " + NOMBRE_FICHERO,0) From GESECRAN

  FICEXP = NOMBRE_FICHERO

  adxifs=';'
  adxirs = chr$(13) + chr$(10)

  Openo filpath("IMPEXP\TRC", FICEXP, "csv",nomap)

  # BUSCAR DATOS DE LA OF
  Filter [F:MFI] Where MFGNUM = [F:XICO]ORDERNAME # and  PLNFCY = [F:XICO]FCY
  Read [F:MFI] First
  If !fstat Then
    LLOTE = [F:MFI]LOT
    LARTICULO = [F:MFI]ITMREF
    LUOM = [F:MFI]UOM
    LUBICACION = [F:MFI]ZLOC
    LFECHA_CADUCIDAD = [F:MFI]ZDATEEXP
    LPLANTA = [F:MFI]MFGFCY
  Endif
  Filter [F:MFI]


  Wrseq 'M',LPLANTA, [F:XICO]ORDERNAME, LARTICULO, [F:XICO]NUMCOMITEM,LUOM ,date$ ,2,[F:XICO]NUMDECITEM

  Wrseq 'S',LUBICACION, LLOTE, 'Q', LFECHA_CADUCIDAD, [F:XICO]NUMCOMITEM,LUOM, date$

  Wrseq 'LC','CCT','PRO','PRJ','DLG','SER','','','SER'  #XVT230620.n

  Openo
  Call ECR_TRACE("SEGUIMIENTO_PRODUCCION - FICHERO EXPORT GENERADO",0) From GESECRAN
  Call IMPORTSIL('XMESMKI',filpath('IMPEXP\TRC', FICEXP,'csv',nomap) ) From GIMPOBJ
  # mover a procesados
  Call MOVEFILE(FICEXP + ".csv")

Return


####################################################################################################
Subprog MOVEFILE(PFILE)

Local Char DESTINO(250)
Local Char ORIGEN_DOSSIER(250)
Local Char ORIGEN(250)

Local Integer STAT:STAT=1

ORIGEN_DOSSIER=filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER


DESTINO = ORIGEN_DOSSIER+"\IMPEXP\TRC\Procesados\" + PFILE

ORIGEN=ORIGEN_DOSSIER+"\IMPEXP\TRC\"+PFILE

Call MOVE (ORIGEN,DESTINO,STAT) From ORDSYS

End


####################################################################################################
Subprog GENERA_FICHEROS_XML(PARTICULO, PLOTE, PORDERNAME,PTIPOGEN)
  Local Char LNOMBRE_FICHERO(100)
  Global Char GGLN_ALTAN(20)
  Gosub DATOS_SERIALIZACION

  GGLN_ALTAN = [F:ZATA]A1

#  Call ECR_TRACE("SEGUIMIENTO_PRODUCCION - GENERANDO FICHERO XML",0) From GESECRAN
#  Call ECR_TRACE("PARAMETROS DE SERIALIZACI”N - GGLN_ALTAN:"+GGLN_ALTAN,0) From GESECRAN
  Filter [ITM] Where ITMREF = PARTICULO
  Read [F:ITM] First
  If !fstat Then
    If [F:ITM]XTYPSER  = "CMO" Then

        LNOMBRE_FICHERO = ctrans(PARTICULO,"/","_") + "_" + ctrans(PLOTE,"/","_") + "_" + PORDERNAME + "_" + "SALES"
        Call ECR_TRACE("GENERANDO FICHERO XML - CMO - " + LNOMBRE_FICHERO,0) From GESECRAN
        Call  XML_SALES_SHIPMENT(LNOMBRE_FICHERO, PARTICULO, PLOTE, PTIPOGEN) From XSERIALIZACION
    Endif
    If [F:ITM]XTYPSER  = "MAH" Then

        LNOMBRE_FICHERO = ctrans(PARTICULO,"/","_") + "_" + ctrans(PLOTE,"/","_") + "_" + PORDERNAME + "_" + "PRODUCT"
        Call ECR_TRACE("GENERANDO FICHERO XML - MAH - " + LNOMBRE_FICHERO,0) From GESECRAN
        Call  XML_PRODUCT_RELEASE(LNOMBRE_FICHERO, PARTICULO, PLOTE, PTIPOGEN) From XSERIALIZACION
    Endif
  Endif
  Filter [ITM]

End

####################################################################################################
$DATOS_OF
  Call ECR_TRACE("DENTRO DE DATOS_OF : " + [F:XICO]ORDERNAME,0) From GESECRAN
  Read [F:MFI]MFI2 = [F:XICO]ORDERNAME # and  PLNFCY = [F:XICO]FCY
  #Read [F:MFI] First
  If !fstat Then
    Call ECR_TRACE("DENTRO DE DATOS_OF - FABRICACI”N : " + [F:XICO]ORDERNAME,0) From GESECRAN
    LLOTE = [F:MFI]LOT
    LARTICULO = [F:MFI]ITMREF
  Else # SI NO LO ENCONTRAMOS, ES PORQUE ES UNA RECEPCI”N
    Local Integer LNUMLIN
    Local Char LORDERNAME
    LNUMLIN = 0
    LORDERNAME = ''


    If instr(1,[F:XICO]ORDERNAME,"_") > 0 Then    # MAB.29092020.NEW
      # BUSCAMOS EN LAS RECEPCIONES EL ARTÕCULO
      LNUMLIN = val(right$([F:XICO]ORDERNAME,instr(1,[F:XICO]ORDERNAME,"_")+1)) # MAB.29092020.NEW
      LORDERNAME = left$([F:XICO]ORDERNAME,instr(1,[F:XICO]ORDERNAME,"_")-1)# MAB.29092020.NEW
      Filter [F:ZREC] Where PTHNUM = LORDERNAME and PTDLIN = LNUMLIN   # MAB.29092020.NEW
      Call ECR_TRACE("Recorrer articulo de la recepciÛn - Orden:" + LORDERNAME + " - LÌnea: " + num$(LNUMLIN),0) From GESECRAN
    Else
      Filter [F:ZREC] Where PTHNUM = [F:XICO]ORDERNAME
      Call ECR_TRACE("Recorrer articulo de la recepciÛn - Orden:" + [F:XICO]ORDERNAME,0) From GESECRAN

    Endif
    Call ECR_TRACE("DENTRO DE DATOS_OF - RECEPCI”N : " + [F:XICO]ORDERNAME,0) From GESECRAN

   # Call ECR_TRACE("DENTRO DE DATOS_OF - RECEPCI”N : " + [F:XICO]ORDERNAME,0) From GESECRAN
   # Filter [F:ZREC] Where PTHNUM = [F:XICO]ORDERNAME
    For [F:ZREC]
      Call ECR_TRACE("DENTRO DE DATOS_OF - RECEPCI”N - ARTICULO : " + [F:XICO]ORDERNAME + " - " + [F:ZREC]ITMREF,0) From GESECRAN
      Read [F:ITM]ITM0 = [F:ZREC]ITMREF
      If fstat = 0 Then # ariculo encontrado
        If [F:ITM]XSERIALIZADO = 2 Then  # articulo es serializable
            LARTICULO = [F:ITM]ITMREF
            # EL ARTICULO ES SERIALIZBLE, BUSCAMOS EL LOTE EN LA TABLA STOJOU
            # Filter  [F:STJ] Where ITMREF = LARTICULO and VCRNUM = [F:ZREC]SDHNUM # MAB.29092020.OLD
            Filter  [F:STJ] Where ITMREF = LARTICULO and VCRNUM = [F:ZREC]PTHNUM and VCRLIN = [F:ZREC]PTDLIN # A—ADO LÕNEA EN ESTE FILTRO . MAB.29092020.NEW
            Read  [F:STJ] First
            If fstat = 0 Then
              LLOTE = [F:STJ]LOT
              Call ECR_TRACE("DENTRO DE DATOS_OF - RECEPCI”N - LOTE : " + [F:XICO]ORDERNAME + " - " + LLOTE,0) From GESECRAN
              Break # articulo de la recepciÛn es serializable, por lo tanto, salir del bucle
            Endif
        Endif
      Endif
     Next
     Filter [F:ZREC]
     Filter [F:ITM]
     Filter [F:STJ]
  Endif
  Filter [F:MFI]

Return

##########################################################################################################
##########################################################################################################
##########################################################################################################
#**
#* GeneraciÛn del fichero XML Sales Shipment
#*!
Subprog XML_SALES_SHIPMENT(PNOMBRE_FICHERO, PARTICULO, PLOTE, PTIPOGEN)
  Local Char LFICXML(255)
  Local Char LCURRDATE_STR
  Local Char LCURRTIME_STR
  Local Char  LETIQUETA_SGLN, LVALOR_GLN,  LVALOR_SGLN
  Local Char LSHIPTO, LSHIPFROM, LSALESDIS

  Local Char ZDATETIME(14)
 Call ECR_TRACE("XML_SALES_SHIPMENT ",0) From GESECRAN
  ZDATETIME = time$
  ZDATETIME = mid$(ZDATETIME,1,2)+mid$(ZDATETIME,4,2)+mid$(ZDATETIME,7,2)
  ZDATETIME = date$+ZDATETIME
 # Call ECR_TRACE("1-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
  LCURRDATE_STR=  mid$(num$(date$),7,4) + '-' + mid$(num$(date$),4,2) + '-'  + mid$(num$(date$),1,2) #(  ))  format$("D:YYYY-MM-DD",datetime$)

  # LCURRTIME_STR=  mid$(time$,1,2)+ ':' +mid$(time$,4,2)+ ':' + mid$(time$,7,2) #   format$("D:hh:mm:ss",datetime$) # + "Z"
  LCURRTIME_STR=  num$(val(mid$(time$,1,2))-2)+ ':' +mid$(time$,4,2)+ ':' + mid$(time$,7,2)
 # Call ECR_TRACE("2-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
 # Infbox LCURRDATE_STR

  LFICXML = filpath("IMPEXP\TRC\XML",PNOMBRE_FICHERO + "_" + ZDATETIME,"xml")

  Openo LFICXML Using [ZXMLS]
 # Call ECR_TRACE("3-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
  # CABECERA DEL XML
  Wrseq '<?xml version="1.0" encoding="UTF-8"?>'    Using [ZXMLS]
  Wrseq '<som:SOMSalesShipmentMessage xmlns="urn:tracelink:mapper:sl:serialized_operations_manager"'    Using [ZXMLS]
  Wrseq 'xmlns:som="urn:tracelink:mapper:sl:serialized_operations_manager"'    Using [ZXMLS]
  Wrseq 'xmlns:cmn="urn:tracelink:mapper:sl:commontypes" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">' Using [ZXMLS]
  Wrseq '<som:ControlFileHeader>'    Using [ZXMLS]
  #  Call ECR_TRACE("4-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
  Wrseq '<cmn:FileSenderNumber>' + GGLN_ALTAN + '</cmn:FileSenderNumber>'    Using [ZXMLS]
 #   Call ECR_TRACE("5-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
  Wrseq '<cmn:FileReceiverNumber>' + GGLN_ALTAN + '</cmn:FileReceiverNumber>'    Using [ZXMLS]
 #   Call ECR_TRACE("6-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
  Wrseq '<cmn:FileControlNumber>' + ZDATETIME + '</cmn:FileControlNumber>'    Using [ZXMLS]
 #   Call ECR_TRACE("7-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
  Wrseq '<cmn:FileDate>' + LCURRDATE_STR + '</cmn:FileDate>'    Using [ZXMLS]
 #   Call ECR_TRACE("8-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
  Wrseq '<cmn:FileTime>' + LCURRTIME_STR + '</cmn:FileTime>'    Using [ZXMLS]
 #   Call ECR_TRACE("9-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
  Wrseq '</som:ControlFileHeader>'    Using [ZXMLS]

  Wrseq '<som:MessageBody>'    Using [ZXMLS]
 # Wrseq '<cmn:LocationId>8888882028655</cmn:LocationId>'    Using [ZXMLS]
  Wrseq '<cmn:DeliveryNumber>' + "DN_" + ZDATETIME + '</cmn:DeliveryNumber>'    Using [ZXMLS]
 #   Call ECR_TRACE("10-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
  Wrseq '<cmn:DeliveryCompleteFlag>true</cmn:DeliveryCompleteFlag>'    Using [ZXMLS]
  Wrseq '<som:OrderDetails>'    Using [ZXMLS]
  Wrseq '<cmn:TransactionIdentifier type="PO">' + "PO_" + ZDATETIME + '</cmn:TransactionIdentifier>'    Using [ZXMLS]
#    Call ECR_TRACE("11-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
 # Wrseq '<cmn:TransactionIdentifier type="ASN">D70301</cmn:TransactionIdentifier>'    Using [ZXMLS]
  Wrseq '<cmn:TransactionDate>' + LCURRDATE_STR + '</cmn:TransactionDate>'    Using [ZXMLS]  # FECHA TRANSACCI”N DE GES
 #   Call ECR_TRACE("12-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
  Wrseq '<cmn:TransactionTime>' + LCURRTIME_STR + '</cmn:TransactionTime>'    Using [ZXMLS]  # HORA TRANSACCI”N DE GES
 #   Call ECR_TRACE("13-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
 # LSHIPTO, LSHIPFROM, LSALESDIS
 If [F:ITM]XSHIPTCTYCOD = '' Then
  LSHIPTO = 'ES'
 Else
  LSHIPTO = [F:ITM]XSHIPTCTYCOD
 Endif
  Wrseq '<cmn:ShipToCountryCode>' + LSHIPTO + '</cmn:ShipToCountryCode>'    Using [ZXMLS]
  If [F:ITM]XSHIPFCTYCOD = '' Then
    LSHIPFROM = 'ES'
  Else
    LSHIPFROM = [F:ITM]XSHIPFCTYCOD
  Endif
  Wrseq '<cmn:ShipFromCountryCode>' + LSHIPFROM + '</cmn:ShipFromCountryCode>'    Using [ZXMLS]
  If [F:ITM]XSALESDISTYP = '' Then
    LSALESDIS = ''
  Else
    LSALESDIS = [F:ITM]XSALESDISTYP
  Endif
  Wrseq '<cmn:SalesDistributionType>' + LSALESDIS + '</cmn:SalesDistributionType>'    Using [ZXMLS] # INCOUNTRYTRANSFER O EXPORTTRANSFER
 # Wrseq '<cmn:OrderItemList>'    Using [ZXMLS]
 # Wrseq '<cmn:OrderItem>'    Using [ZXMLS]
 # Wrseq '<cmn:InternalMaterialCode>' + PARTICULO + '</cmn:InternalMaterialCode>'    Using [ZXMLS]
 # Wrseq '<CMN:PACKAGINGITEMCODE type="GTIN-14">00882026030229</CMN:PACKAGINGITEMCODE>'    Using [ZXMLS]
 # Wrseq '<cmn:LotNumber>' + PLOTE + '</cmn:LotNumber>'    Using [ZXMLS]
 # Wrseq '<cmn:ExpirationDate></cmn:ExpirationDate>'    Using [ZXMLS]
 # Wrseq '<cmn:Quantity>480</cmn:Quantity>'    Using [ZXMLS]
 # Wrseq '</cmn:OrderItem>'    Using [ZXMLS]
 # Wrseq '</cmn:OrderItemList>'    Using [ZXMLS]

  Wrseq '<ne:SenderInfo xmlns:ne="urn:tracelink:mapper:sl:commontypes">' Using [ZXMLS]
  Wrseq       '<ne:FromBusinessPartyLookupId type="GLN">' +   [F:ITM]XGLN  + '</ne:FromBusinessPartyLookupId>' Using [ZXMLS]
 # Call ECR_TRACE("14-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
  Wrseq       '<ne:ShipFromLocationLookupId type="SGLN">' + [F:ITM]XSGLN + '</ne:ShipFromLocationLookupId>' Using [ZXMLS]
 # Call ECR_TRACE("15-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
  Wrseq     '</ne:SenderInfo>' Using [ZXMLS]
  Wrseq     '<ne:ReceiverInfo xmlns:ne="urn:tracelink:mapper:sl:commontypes">' Using [ZXMLS]

  If [F:ITM]XTYPEGLN = 1 Then
#    LETIQUETA_SGLN = 'GLN'
    LVALOR_GLN = 'GLN'
  Else
#    LETIQUETA_SGLN = 'SGLN'
    LVALOR_GLN = 'SGLN'
  Endif
  If [F:ITM]XTYPESGLN = 1 Then
    LVALOR_SGLN = 'GLN'
  Else
    LVALOR_SGLN = 'SGLN'
  Endif


  Wrseq       '<ne:ToBusinessPartyLookupId type="' + LVALOR_GLN + '">' + [F:ITM]XTOGLN  + '</ne:ToBusinessPartyLookupId>' Using [ZXMLS]
#  Call ECR_TRACE("16-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
  Wrseq       '<ne:ShipToLocationLookupId type="' + LVALOR_SGLN + '">' + [F:ITM]XTOSGLN  + '</ne:ShipToLocationLookupId>' Using [ZXMLS]
#  Call ECR_TRACE("17-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
  Wrseq     '</ne:ReceiverInfo>' Using [ZXMLS]



  Wrseq '</som:OrderDetails>'    Using [ZXMLS]

  Wrseq '<som:AddPickedLot>'    Using [ZXMLS]
  Wrseq '<cmn:ProductLotNumbers>'    Using [ZXMLS]
  Wrseq '<cmn:InternalMaterialCode>' + PARTICULO + '</cmn:InternalMaterialCode>'    Using [ZXMLS]
#  Call ECR_TRACE("18-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
  Wrseq '<cmn:LotNumber>' + PLOTE + '</cmn:LotNumber>'    Using [ZXMLS]
#  Call ECR_TRACE("19-XML_SALES_SHIPMENT : " + [F:XICO]ORDERNAME,0) From GESECRAN
  Wrseq '</cmn:ProductLotNumbers>'    Using [ZXMLS]
  Wrseq '</som:AddPickedLot>'    Using [ZXMLS]
  Wrseq '</som:MessageBody>'    Using [ZXMLS]
  Wrseq '</som:SOMSalesShipmentMessage>'  Using [ZXMLS]

  Openo Using [ZXMLS]

# Call ECR_TRACE("PARAMETROS DE SERIALIZACI”N - PATH CMO:"+[F:ZATA]A2,0) From GESECRAN

  If PTIPOGEN = "LOCAL" Then
    Call DESCARGA_FICHERO(LFICXML)
  Else
    Call ENVIA_FICHERO(LFICXML,[F:ZATA]A2)
  Endif

End
##########################################################################################################
##########################################################################################################
##########################################################################################################
#**
#* GeneraciÛn del fichero XML Product Release
#*!
Subprog XML_PRODUCT_RELEASE(PNOMBRE_FICHERO, PARTICULO, PLOTE, PTIPOGEN)
  Local Char LFICXML(255)
  Local Char LCURRDATE_STR
  Local Char LCURRTIME_STR

  Local Char ZDATETIME(14)
#  Call ECR_TRACE("XML_SALES_PRODUCT  " ,0) From GESECRAN

  ZDATETIME = time$
  ZDATETIME = mid$(ZDATETIME,1,2)+mid$(ZDATETIME,4,2)+mid$(ZDATETIME,7,2)
  ZDATETIME = date$+ZDATETIME

  LCURRDATE_STR=  mid$(num$(date$),7,4) + '-' + mid$(num$(date$),4,2) + '-'  + mid$(num$(date$),1,2) #(  ))  format$("D:YYYY-MM-DD",datetime$)
  # LCURRTIME_STR=  mid$(time$,1,2)+ ':' +mid$(time$,4,2)+ ':' + mid$(time$,7,2) #   format$("D:hh:mm:ss",datetime$) # + "Z"
  LCURRTIME_STR=  num$(val(mid$(time$,1,2))-2)+ ':' +mid$(time$,4,2)+ ':' + mid$(time$,7,2)


  LFICXML = filpath("IMPEXP\TRC\XML",PNOMBRE_FICHERO + "_" + ZDATETIME,"xml")


  #LFICXML = filpath("IMPEXP\TRC",PNOMBRE_FICHERO + "_" + ZDATETIME,"xml")

  Openo LFICXML Using [ZXMLS]


  Wrseq '<?xml version="1.0" encoding="UTF-8"?>'  Using [ZXMLS]
  Wrseq '<SOMProductReleaseMessage xmlns="urn:tracelink:mapper:sl:serialized_operations_manager"'  Using [ZXMLS]
  Wrseq 'xmlns:cmn="urn:tracelink:mapper:sl:commontypes" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">'  Using [ZXMLS]
  Wrseq '<ControlFileHeader>'  Using [ZXMLS]
  Wrseq '<cmn:FileSenderNumber>' + GGLN_ALTAN + '</cmn:FileSenderNumber>'  Using [ZXMLS]
  Wrseq '<cmn:FileReceiverNumber>' + GGLN_ALTAN + '</cmn:FileReceiverNumber>'  Using [ZXMLS]
  Wrseq '<cmn:FileControlNumber>' + ZDATETIME + '</cmn:FileControlNumber>'  Using [ZXMLS]
  Wrseq '<cmn:FileDate>' + LCURRDATE_STR + '</cmn:FileDate>'  Using [ZXMLS]
  Wrseq '<cmn:FileTime>' + LCURRTIME_STR + '</cmn:FileTime>'  Using [ZXMLS]
  Wrseq '</ControlFileHeader>'  Using [ZXMLS]
  Wrseq '<MessageBody>'  Using [ZXMLS]
  Wrseq '<cmn:LocationId>' + [F:ITM]XSGLN + '</cmn:LocationId>'  Using [ZXMLS]
  Wrseq '<cmn:InternalMaterialCode>' + PARTICULO + '</cmn:InternalMaterialCode>'  Using [ZXMLS]
  Wrseq '<cmn:LotNumber>' + PLOTE + '</cmn:LotNumber>'  Using [ZXMLS]
  Wrseq '</MessageBody>'  Using [ZXMLS]
  Wrseq '</SOMProductReleaseMessage>'  Using [ZXMLS]


  Openo Using [ZXMLS]

  # Call ENVIA_FICHERO(LFICXML,"SOM_PRODUCT_RELEASE")
#  Call ECR_TRACE("PARAMETROS DE SERIALIZACI”N - PATH MAH:"+[F:ZATA]A3,0) From GESECRAN
  If PTIPOGEN = "LOCAL" Then
    Call DESCARGA_FICHERO(LFICXML)
  Else
    Call ENVIA_FICHERO(LFICXML,[F:ZATA]A3)
  Endif

End


#####################################################################################
#**
#* Descarga de fichero XML en local
#*
#* @param PFICHERO
#*!
Subprog DESCARGA_FICHERO(PFICHERO)
  Local Integer STAT : STAT = 0
  Local Char PATH(150), URL(250)
  PATH = ''
  PATH = PFICHERO
  Call COPCLI(PATH,PATH,STAT) From ORDSYS

End

