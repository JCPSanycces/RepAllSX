#**
#* Devuelve el n˙mero de lote de la recepciÛn de la tabla STOJOU
#* MAB.001.04/11/2020.NEW
#* @param PORDER
#* @param PLINE
#*!
Funprog GETLOTE(PORDER, PLINE, PITMREF, PSUBLOTE)
Variable Char PSUBLOTE
Value Char PORDER,  PITMREF
Value Integer PLINE
Local Char PRES
  Filter  [F:STJ] Where ITMREF = PITMREF and VCRNUM = PORDER and VCRLIN = PLINE # A—ADO LÕNEA EN ESTE FILTRO . MAB.29092020.NEW
  Read  [F:STJ] First
  If fstat = 0 Then
    LRES  = [F:STJ]LOT
    PSUBLOTE = [F:STJ]SLO
    Call ECR_TRACE("DENTRO DE DATOS_OF - RECEPCI”N - LOTE : " + [F:XICO]ORDERNAME + " - " + LLOTE,0) From GESECRAN
  Else
   LRES = ''
   PSUBLOTE = ''
  Endif

End LRES
