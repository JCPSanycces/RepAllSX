# Gestión de la máscara SMR1 (Especifico)
# Ticket #000731 - Al duplicar la fecha ha de ser la del día, no la de la transacción original.

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla SMR1) 28/07/2016 14:08:48 (ADMIN)
######################################################################################
$ACTION
Case ACTION
 When "RAZDUP" : Gosub RAZDUP     #000731.n
 When Default
Endcase
Return
#000731.bn
$RAZDUP
  If GREP = "D" Then
    IPTDAT=date$
    Affzo IPTDAT
  Endif
Return
#000731.en

Subprog C_LOC(VALEUR)
Variable Char    VALEUR()
 If !clalev ([XSTO]) Then Local File STOCK[XSTO] : Endif
 Local Integer XNOL
If 0 Then  ## DESACTIVACIÓN TEMPORAL DE CONTROL DE UBICACIÓN ## XVT24/10/2016 . 10.16
  If VALEUR<>"" and VALEUR<>"GRAL" and VALEUR<>"MUELLE" Then
    If [M:SMR0]STOFCY="200" Then
       Filter [F:XSTO] Where LOC=VALEUR and STOFCY="200" and QTYSTU > 0 and LOC<>"GRAL" and LOC<>"MUELLE"
       For [F:XSTO]
        Call MESSAGE("La ubicación " + VALEUR + " ya tiene stock. Seleccione otra") From GESECRAN
        mkstat=2
        Break
       Next
       Filter [F:XSTO]

       If nolign-1 > 0 Then
         For XNOL=0 To nolign-2
           If [M:SMR1]LOC(XNOL)=VALEUR Then
              Call MESSAGE ("La ubicación " + VALEUR + " ya ha sido utilizada. Seleccione otra") From GESECRAN
              mkstat=2
              Break
           Endif
         Next
       Endif
    Endif
  Endif
Endif ## FIN- DESACTIVACIÓN TEMPORAL DE CONTROL DE UBICACIÓN ## XVT24/10/2016 . 10.16
End

Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
 If !clalev ([XSLF]) Then Local File STOLOTFCY [XSLF] : Endif
   Local Integer XNOL
If 0 Then ## DESACTIVACIÓN TEMPORAL DE CONTROL DE UBICACIÓN ## XVT24/10/2016 . 10.16
   If VALEUR<>"" Then
     If [M:SMR0]STOFCY="200" or [M:SMR0]STOFCY="210" or [M:SMR0]STOFCY="300" or [M:SMR0]STOFCY="310" Then
        If [M:SMR0]STOFCY="200" or [M:SMR0]STOFCY="210" Then
          Filter [F:XSLF] Where [F:XSLF]ITMREF=[M:SMR1]ITMREF(nolign-1) and LOT=VALEUR and (STOFCY="200" or STOFCY="210")
        Endif
        If [M:SMR0]STOFCY="300" or [M:SMR0]STOFCY="310" Then
          Filter [F:XSLF] Where [F:XSLF]ITMREF=[M:SMR1]ITMREF(nolign-1) and LOT=VALEUR and (STOFCY="300" or STOFCY="310")
        Endif
        For [F:XSLF]
          Call MESSAGE ("El lote " + VALEUR + " ya ha sido utilizado para el artículo") From GESECRAN
          mkstat=2
          Break
        Next
        Filter [F:XSLF]
     Endif

   If nolign-1 > 0 Then
    For XNOL=0 To nolign-2
      If [M:SMR1]LOT(XNOL)=VALEUR and [M:SMR1]ITMREF(XNOL)=[M:SMR1]ITMREF(nolign-1) Then
         Call MESSAGE ("El lote " + VALEUR + " ya ha sido utilizado para el artículo") From GESECRAN
         mkstat=2
         Break
      Endif
    Next
   Endif
  Endif
Endif ## FIN DESACTIVACIÓN TEMPORAL DE CONTROL DE UBICACIÓN ## XVT24/10/2016 . 10.16

End


######################################################################################

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla SMR1) 28/01/2020 17:14:25 (ADMIN)
######################################################################################
Subprog AV_ITMREF(VALEUR)
Variable Char    VALEUR()
  If [M:SMR1]ITMREF(nolign-1) = "" and GREP = 'M' Then
#      mkstat = 2
      Grizo [M:SMR1]NBLIG(nolign-1)
  Endif
End


