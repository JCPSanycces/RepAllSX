Subprog C_SHLDAT(VALEUR)
Variable Date    VALEUR
  If VALEUR < date$ and GFONCTION<>"GESSRH" Then
    Call MESSAGE ("La fecha de caducidad ha de ser mayor o igual a la fecha actual") From GESECRAN
    mkstat = 2
  Endif
End

Subprog C_NEWLTIDAT(VALEUR)
Variable Date    VALEUR
  If VALEUR < date$ and GFONCTION<>"GESSRH" Then
    Call MESSAGE ("La fecha de recontrol ha de ser mayor o igual a la fecha actual") From GESECRAN
    mkstat = 2
  Endif

End

Subprog C_USRFLD4(VALEUR)
Variable Date    VALEUR
  If VALEUR > date$ Then
    Call MESSAGE ("La fecha de fabricaciÛn ha de ser menor o igual a la fecha actual") From GESECRAN
    mkstat = 2
  Endif
End



