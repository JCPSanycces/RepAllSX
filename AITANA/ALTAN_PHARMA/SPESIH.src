#<AdxTL>@(#)0.0.0.0 $Revision$ Facturas
### Act. XEMF1 IncorporaciÛn contraalbar·n 17/11/2016
###ModificaciÛn contra albar·n en facturas ya validadas #000292 XVT10/02/17

ACTION
#infbox action
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "LIENS_LIG"  : Gosub LIENS_LIG
  When "FIN"        : Gosub FIN
  When "SETBOUT"    : Gosub SETBOUT
  When Default
Endcase

Return

$OUVRE
Global Char V_ACTIVA(1)
Global Char PRIMERA_VEZ(1)
Local File BPCUSTOMER [XBPC]
Return

$FIN
Close Local File [XBPC]
Return

$LIENS_LIG

#infbox "LIG"
If [M:SIH2]XASIGNCONT = '' and [M:SIH1]INVSTA = 1 and PRIMERA_VEZ <> '1'
  If PRIMERA_VEZ <> '1'
   PRIMERA_VEZ = '1'
   For [XBPC] Where [F:XBPC]BPCNUM = [M:SIH0]BPCINV
      [M:SIH2]XASIGNCONT = [XBPC]XNUMASIG
      If [M:SIH2]XASIGNCONT <> ''
        V_ACTIVA = '1'
      Endif
      Break
   Next
  Endif
Endif
Return

$SETBOUT
 If V_ACTIVA = '1'
  REP +="M"
  Gosub SET_BOUT_SPE From GSAISIE
  V_ACTIVA = '0'
 Endif

 #000292.bn
 If [M:SIH1]INVSTA=3 Then
   CHMEN += "DZ"
 Else
   Call VIREBOUT(CHAINE,"DZ") From GOBJET
 Endif
 #000292.en

Return


######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla SIH0) 17/11/2016 14:51:48 (ADMIN)
######################################################################################
Subprog AM_BPCINV(VALEUR)
Variable Char    VALEUR()

 If [M:SIH2]XASIGNCONT = '' Then

   For [XBPC] Where [F:XBPC]BPCNUM = VALEUR
      [M:SIH2]XASIGNCONT = [XBPC]XNUMASIG
      Affzo [M:SIH2]XASIGNCONT
      Break
   Next
Endif

End


