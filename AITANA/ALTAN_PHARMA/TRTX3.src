#-------------------------------------------------------------#
# Conversion quantité d"une unité vers une autre avec arrondi #
# ----------------------------------------------------------- #
# WUOM1 : Unité d'origine                                     #
# WUOM2 : Unité destination                                   #
# WQTY  : Quantité ŕ convertir puis quantité convertie        #
#-------------------------------------------------------------#
Subprog CONVERT_QTY (WUOM1,WUOM2,WQTY)
Value    Char    WUOM1
Value    Char    WUOM2
Variable Decimal WQTY
#----- Conversion quantité si unités différentes -----#
If WUOM1<>WUOM2
  Local    Decimal WCOEF
  If !clalev([F:TCO])  Local File TABCOEFF [TCO] : Endif
  # Issue 74556 - 2011-07-05 by VPO : lecture ssi besoin
  If [F:TCO]UOM1=WUOM1 & [F:TCO]UOM2=WUOM2
    WCOEF=[F:TCO]COEUOM
  Else
    Read [TCO] TCO0=WUOM1;WUOM2
    If !fstat
      WCOEF=[F:TCO]COEUOM
    Else
      # Issue 74556 - 2011-07-05 by VPO : lecture ssi besoin
      If [F:TCO]UOM1=WUOM2 & [F:TCO]UOM2=WUOM1
          If [F:TCO]COEUOM<>0
          WCOEF=1/[F:TCO]COEUOM
          Else
          WCOEF=1
          Endif
      Else
        Read [TCO] TCO0=WUOM2;WUOM1
        If !fstat & [F:TCO]COEUOM<>0
          WCOEF=1/[F:TCO]COEUOM
        Else
          Raz [F:TCO]
          WCOEF=1
        Endif
      Endif
    Endif
  Endif
  WQTY*=WCOEF
Endif
#----- Arrondi de la quantité -----#
If !clalev([F:TUN])  Local File TABUNIT [TUN] : Endif
# Issue 74556 - 2011-07-05 by VPO : lecture ssi besoin
# Issue 85754 - 2012-11-08 by VPO : Erreur sur unité utilisée pour arrondi
#If [F:TUN]UOM<>WUOM2
If [F:TUN]UOM=WUOM2
    WQTY=arr(WQTY,10^-[F:TUN]UOMDEC)
Else
  Read [TUN] TUN0=WUOM2
  If !fstat
    WQTY=arr(WQTY,10^-[F:TUN]UOMDEC)
  Endif
Endif
#-----
End


#------------------------------------------#
# calcul d'une qté         cg novembre 1997#
# renvoie le coefficient- existe une action#
#------------------------------------------#
Subprog CALCUL_QTY (QTY1,UOM1,QTY2,UOM2,COEUOM)
Value Char UOM1
Value Decimal QTY1
Variable Decimal QTY2
Value Char UOM2
Variable Decimal COEUOM

QTY2 = QTY1 : COEUOM = 1
#---------------------------------------------#
# il faut  récupérer le taux de conversion    #
# on ne lit pas le taux inverse dans le cas   #
# ou l'on ne trouve pas coeff   - volontaire  #
#---------------------------------------------#
If clalev([F:TCO]) = 0 : Local File TABCOEFF [TCO] : Endif
If UOM1 <> UOM2
  # Issue 74556 - 2011-07-05 by VPO : lecture ssi besoin
  If [F:TCO]UOM1=UOM1 & [F:TCO]UOM2=UOM2
     QTY2 = QTY1 * [F:TCO]COEUOM
     COEUOM = [F:TCO]COEUOM
  Else
     Read [TCO]TCO0=UOM1;UOM2
     If fstat = 0
        QTY2 = QTY1 * [F:TCO]COEUOM
        COEUOM = [F:TCO]COEUOM
     Else Raz [F:TCO] : [F:TCO]COEUOM=1
     Endif
  Endif
Endif
#--- Arrondi du coefficient ŕ 6 décimales et de la qté suivant unité ---#
COEUOM=arr(COEUOM,0.000001)
Call QTEARR(QTY2,UOM2) From TRTDIV
End

#######################################################################
# Chargement dans GCUR de la devise de la société du site financier   #
# dont dépend le site tronc commun                                    #
#######################################################################
Subprog CHARGE_GCUR()
Local Char WLEGCPY (GLONCPY)

# Devise site alimentée par devise dossier
GCUR= GSYSCUR
# Lecture du site par défaut
If GFCYDEF (9) <> ""
   If !clalev([F:FCY]) Local File FACILITY [FCY] Endif
   Read [FCY]FCY0 = GFCYDEF(9)
   If fstat = 0
      WLEGCPY = [F:FCY]LEGCPY
   Endif
Endif
# Lecture société correspondant au site
If clalev([F:CPY]) = 0 : Local File COMPANY [CPY] : Endif
If WLEGCPY <> ""
     Read [CPY]CPY0 = WLEGCPY
     If fstat = 0 : GCUR = [F:CPY]ACCCUR : Endif
Endif
End

#######################################################################
# SAISADR : S/P de saisie en fenętre d'une adresse tiers MBT 20/11/97 #
#---------------------------------------------------------------------#
# Subprog SAISADR (NUMT,ABREV,TRAIT,MSG,CHAP)                         #
#   NUMT  : Numéro du tiers dont l'adresse est ŕ saisir               #
#   ABREV : Numéro de l'abréviation du masque de saisie               #
#           0 = masque par défaut [ADB]                               #
#           1 = masque avec abréviation [ADB7]                        #
#           2 = masque avec abréviation [ADB8]                        #
#           3 = masque avec abréviation [ADB9]                        #
#   TRAIT : Code du traitement                                        #
#           0 = Chargement de la premičre adresse si nécessaire       #
#           1 = Chargement de la premičre adresse si nécessaire       #
#               mais non conservée si non modifiée                    #
#   MSG   : Numéro du message pour titre de la fenętre                #
#           0 = Titre par défaut (4,195,1="Saisie d'adresse")         #
#   CHAP  : Numéro de chapitre du message pour titre de la fenętre    #
#           0 = Titre par défaut (4,195,1="Saisie d'adresse")         #
# ------------------------------------------------------------------- #
# En sortie chargement de la classe [M:'ABREV']                       #
#          avec ADBBPR = Numéro du tiers traité                       #
#               ADBFLG = 0 --> Aucune adresse chargée                 #
#                        1 --> Adresse chargée mais non modifiée      #
#                        2 --> Adresse chargée et modifiée            #
# ------------------------------------------------------------------- #
# En entrée Si ADBFLG  = 3 -- > Adresse chargée avec le fichier cde   #
# ------------------------------------------------------------------- #
#######################################################################
Subprog SAISADR (NUMT,ABREV,TRAIT,MSG,CHAP)
Value Char    NUMT
Value Integer ABREV
Value Integer TRAIT
Value Integer MSG
Value Integer CHAP
#----- Variables pour sauvegarde du masque -----#
Local Char    BPRNAM(35)(2)
Local Char    BPAADD(GLONADR)
Local Char    BPAADDLIG(35)(3)
Local Char    CRY(3)
Local Char    CRYNAM(30)
Local Char    SAT(30)
Local Char    POSCOD(10)
Local Char    CTY(30)
Local Shortint FLGSAI
#----------------------------------------------#
Local Integer CHOIX, ETABOU(1..GNBBOU), SAVGOBJET
#------ Contrôle validité des paramčtres ------#
If NUMT="" | ABREV>3 | TRAIT>1 : End : Endif
If MSG=0 | CHAP=0 MSG=4 : CHAP=195 : Endif
#----------------------------------------------#
SAVGOBJET=GOBJET
Call SAVBOUT From GESECRAN
GOBJET=0
ETABOU(GVALI)=1 : ETABOU(GABAN)=1 : # Ok et Abandon
If TRAIT=0
   Case ABREV
      When 0 : [M:ADB]ADBLIB =mess(27,198,1)
      When 1 : [M:ADB7]ADBLIB=mess(27,198,1)
      When 2 : [M:ADB8]ADBLIB=mess(27,198,1)
      When 3 : [M:ADB9]ADBLIB=mess(27,198,1)
   Endcase
Endif
#------ Ouverture des fichiers si besoin ------#
If clalev ([F:BPR])<=0 Local File BPARTNER   [BPR] : Endif
If clalev ([F:BPA])<=0 Local File BPADDRESS  [BPA] : Endif
If clalev ([F:TCY])<=0 Local File TABCOUNTRY [TCY] : Endif
#------ Affectation du masque par défaut et déclaration fenętre ------#
Case ABREV
   When 0 : Default Mask [ADB]
            Local Dlgbox Mask [M:ADB]  Button mess(64,123,1), mess(5,123,1)
&           With left$(mess(64,123,1),1), left$(mess(5,123,1),1)
&           Coded GSTAOK, GSTAFIN Titled mess(MSG,CHAP,1) As [SADB]
   When 1 : Default Mask [ADB7]
            Local Dlgbox Mask [M:ADB7] Button mess(64,123,1), mess(5,123,1)
&           With left$(mess(64,123,1),1), left$(mess(5,123,1),1)
&           Coded GSTAOK, GSTAFIN Titled mess(MSG,CHAP,1) As [SADB]
   When 2 : Default Mask [ADB8]
            Local Dlgbox Mask [M:ADB8] Button mess(64,123,1), mess(5,123,1)
&           With left$(mess(64,123,1),1), left$(mess(5,123,1),1)
&           Coded GSTAOK, GSTAFIN Titled mess(MSG,CHAP,1) As [SADB]
   When 3 : Default Mask [ADB9]
            Local Dlgbox Mask [M:ADB9] Button mess(64,123,1), mess(5,123,1)
&           With left$(mess(64,123,1),1), left$(mess(5,123,1),1)
&           Coded GSTAOK, GSTAFIN Titled mess(MSG,CHAP,1) As [SADB]
   When Default
Endcase
#----- Affichage fenętre de saisie -----#
Boxact [SADB]
#----- Raz masque et lecture BPARTNER si nécessaire -----#
If [M]ADBBPR<>NUMT Raz [M] : Endif
If [F:BPR]BPRNUM<>NUMT
   Read [BPR] BPR0=NUMT
   If fstat Raz [F:BPR] : Endif
Endif
[M]ADBBPR=NUMT : [M]ADBTRT=TRAIT
If TRAIT=0
   [M]ADBLIB=format$("K:20X",mess(27,198,1))+":"
   If [M]BPAADD="" [M]BPAADD=[F:BPR]BPAADD : Endif
Endif
#----- Lecture de la premičre adresse si nécessaire -----#
If [M]ADBFLG=0
  If TRAIT=0 | (TRAIT=1 & [M]BPAADD<>"")
    Read [BPA] BPA0=1;NUMT;[M]BPAADD
  Else
    Read [BPA] BPA0=1;NUMT;[F:BPR]BPAADD
  Endif
  If fstat Raz [F:BPA] : Endif
  [M]BPRNAM(0)    = [F:BPR]BPRNAM(0)
  [M]BPRNAM(1)    = [F:BPR]BPRNAM(1)
  [M]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [M]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [M]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [M]CRY          = [F:BPA]CRY
  [M]CRYNAM       = [F:BPA]CRYNAM
  [M]SAT          = [F:BPA]SAT
  [M]POSCOD       = [F:BPA]POSCOD
  [M]CTY          = [F:BPA]CTY
  [M]ADBBPR       = [F:BPR]BPRNUM
  [M]ADBFLG       = 1
Endif
#----- Sauvegarde des valeurs initiales du masque et affichage -----#
[L]=[M]
Affzo
Call SETBOUT(ETABOU) From GESECRAN
FLGSAI = 1
#----- Si modif non autorisée, désactivation de la saisie par grisage -----#
If GREP<>"C"
  GBIDC2="M" : Gosub AUTORIS_OPT From CONTX3
  If !GBIDI2 : Diszo [M]1-99 : FLGSAI = 0 : Endif
Endif
$DEBSAI
#----- Saisie de l'adresse -----#
Boxinp [SADB] Using CHOIX
#----- Si touche abandon rechargement des anciennes valeurs -----#
Case CHOIX
  When GSTAESC, GSTAFIN : [M]=[L] : Goto FINSAI
  When GSTAOK : Goto VALSAI
  When Default
Endcase
Goto DEBSAI
$VALSAI
If FLGSAI = 0 : ADBFLG = 1 : Goto FINSAI : Endif
#----- Changement adresse origine si changement code adresse -----#
If TRAIT=0 & [M]BPAADD<>[L]BPAADD
   [L]BPAADD       = [M]BPAADD
   [L]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
   [L]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
   [L]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
   [L]CRY          = [F:BPA]CRY
   [L]CRYNAM       = [F:BPA]CRYNAM
   [L]SAT          = [F:BPA]SAT
   [L]POSCOD       = [F:BPA]POSCOD
   [L]CTY          = [F:BPA]CTY
   mkstat=4
Endif
#----- Test si adresse modifiée -----#
If [M]BPRNAM(0)    <> [L]BPRNAM(0)    |
&  [M]BPRNAM(1)    <> [L]BPRNAM(1)    |
&  [M]BPAADDLIG(0) <> [L]BPAADDLIG(0) |
&  [M]BPAADDLIG(1) <> [L]BPAADDLIG(1) |
&  [M]BPAADDLIG(2) <> [L]BPAADDLIG(2) |
&  [M]CRY          <> [L]CRY          |
&  [M]CRYNAM       <> [L]CRYNAM       |
&  [M]SAT          <> [L]SAT          |
&  [M]POSCOD       <> [L]POSCOD       |
&  [M]CTY          <> [L]CTY          [M]ADBFLG=2 : mkstat=4
Elsif TRAIT=1 & [M]ADBFLG = 1
  #----- Il ne faut stocker l'adresse que si la 1čre adresse chargée a été modifiée
  Raz [M] : [M]ADBFLG=0
Endif
#----- Effacement et fermeture de la fenętre -----#
$FINSAI
Boxclr [SADB]
Call RESTBOUT From GESECRAN
GOBJET=SAVGOBJET
End

########################################################################
#  Alimentation des codes taxes                                        #
#                                                   TS - décembre 1997 #
########################################################################
Subprog ALITAXE (VACBPR,VACITM,VAT)
Value    Char   VACBPR
Value    Char   VACITM ()(0..2)
Variable Char   VAT ()(0..2)
Local    Integer I,J

If clalev([F:TVC])=0 : Local File TABVAC [TVC] : Endif
J = 0
For I = 0 To 2
   VAT(J) = ""
   If VACITM(I) <> ""
      Read [TVC]TVC1 = VACBPR;VACITM(I)
      Gosub CONTROLE_TVC              : # controle code actif et legislation
      If fstat = 0
         Case J
          When 0 : VAT(J) = [F:TVC]VAT
                   J += 1
          When 1 : If [F:TVC]VAT <> VAT(0)
                      VAT(J) = [F:TVC]VAT
                      J += 1
                   Endif
          When 2 : If !find([F:TVC]VAT,VAT(0),VAT(1))
                      VAT(J) = [F:TVC]VAT
                      J += 1
                   Endif
         Endcase
      Endif
   Endif
Next I
End

########################################################################
#  Controle validite de enregistrement détermination des taxes         #
#                                                   JL - juin 2005     #
########################################################################
$CONTROLE_TVC
If fstat  Return : Endif                : # Pas d'enregistrement lu
If [F:TVC]ENAFLG<>2                     : # Enregistrement inactif
  fstat=1 : Return
Endif
If [F:TVC]LEG<>"" & GCURLEG<>"" & [F:TVC]LEG<>GCURLEG : # Test sur législation (MBT 04/09/08)
  fstat=1 : Return
Endif
If [F:TVC]GRP<>""
  If !clalev([F:AGC])  Local File AGRPCPY [AGC] : Endif
  Look [AGC] AGC0=[F:TVC]GRP;GSOCIETE
  If fstat  Return : Endif                        : # Test sur groupe sociétés (MBT 22/10/08)
Endif
Return

########################################################################
#  Alimentation des codes taxes vente                                  #
#                                                  TS - septembre 1997 #
########################################################################
Subprog ALITAXEV(VACBPR,VACITM,VAT)
Value    Char    VACBPR
Value    Char    VACITM ()(0..2)
Variable Char    VAT ()(0..2)
Local    Integer I,J
Local    Char    CODVAT(GLONVAT)

If !clalev([F:TVC]) Local File TABVAC    [TVC] Endif
If !clalev([F:TVT]) Local File TABVAT    [TVT] Endif
If !clalev([F:TRA]) Local File TABRATVAT [TRA] Endif
# 71937 : Multilégislation
#If !clalev([F:ADI]) Local File ATABDIV   [ADI] Endif
## Issue 74556 - 2011-07-05 by VPO : lecture ssi besoin
#If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>VACBPR
#  Read [ADI]CODE=1;VACBPR
#Endif
# 71937 : Multilégislation

J = 0
For I = 0 To 2
   [L]VAT(J) = ""
   If VACITM(I) <> ""
      Read [TVC]TVC1= VACBPR;VACITM(I)
      Gosub CONTROLE_TVC              : # controle code actif et legislation
      If fstat = 0
         Case J
          When 0 : [L]VAT(J) = [F:TVC]VAT
                   J += 1
          When 1 : If [F:TVC]VAT <> [L]VAT(0)
                      [L]VAT(J) = [F:TVC]VAT
                      J += 1
                   Endif
          When 2 : If !find([F:TVC]VAT,[L]VAT(0),[L]VAT(1))
                      [L]VAT(J) = [F:TVC]VAT
                      J += 1
                   Endif
         Endcase
      Endif
   Endif
Next I

# Si le régime est intra-communautaire ( JL 10/08/05 : inutile avec flag exonéré )
#If [F:ADI]N1=4
#   Local Integer WEXO
#   Raz WEXO
#   For [TRA]TRA0 Where VAT=[L]VAT(0) & find(CPY,"",GSOCIETE)
