#&         mess([F:ITM]ITMSTA,246,1)  Titled WINT(5),
#&         [F:ITF]CUNFLG  Titled "",
#&         mess([F:ITF]CUNFLG,1,1)    Titled WINT(6)
#&  Sized(120,350)
#&  Titled mess(4,198,1)  # FGR 30/06/2009 : X3SUIVI56189 : S-P plus utilisé, il n'y a męme plus l'instruction SUBPROG
#LRET = ""
#Filter [ITF]
#Case status
#  When 0, 7 :
#     End
#  When GSTASRA :
#    Gosub SELECTION
#    Goto SELITF1
