                   Gosub DECLARE_SAT
                   WBPCORD=[F:SOH]BPCORD
                   WSTOFCY=[F:SOP]STOFCY : WBPAADD=[F:SOP]BPAADD
                   WCTY=[F:SOH]BPDCTY : WCRY=[F:SOH]BPDCRY : WSAT=[F:SOH]BPDSAT
                   Gosub CHARG_SAT
               Endif
 When "SDH1" : [F:TLK] = [M:SDH1]
               [F:TLK] = [M:SDH0]
               [F:TLK]VACBPR = [M:SDH2]VACBPR
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [M:SDH1]UNTWEI(nolign-1)
               WDAT = [M:SDH1]SHIDAT : WCUR = [M:SDH1]CUR : WCHGTYP = [M:SDH0]CHGTYP
               Gosub CHARG_RATRPT
               If dim([L]WVACITM)>0
                   [L]WVACITM(0)=[M:SDH1]VACITM1(nolign-1)
                   [L]WVACITM(1)=[M:SDH1]VACITM2(nolign-1)
                   [L]WVACITM(2)=[M:SDH1]VACITM3(nolign-1)
               Endif
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If find(TRAIT, 2,3) & func AFNC.ACTIV("PTX")
               If find(TRAIT, 2,3) & func TRTX3.ACTIV_PTX
                   Gosub DECLARE_SAT
                   WBPCORD=[M:SDH0]BPCORD
                   WSTOFCY=[M:SDH0]STOFCY : WBPAADD=[M:SDH0]BPAADD
                   If dim([M:ADB2]CTY)>0 WCTY=[M:ADB2]CTY : WCRY=[M:ADB2]CRY : WSAT=[M:ADB2]SAT Endif
                   Gosub CHARG_SAT
               Endif
 # 91606 :(04/08/14) Transportation notes (Sales part dev)
 When "TNH1" : [F:TLK] = [M:TNH1]
               [F:TLK] = [M:TNH0]
               [F:TLK]VACBPR = [M:TNH2]VACBPR
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [M:TNH1]UNTWEI(nolign-1)
               WDAT = [M:TNH1]SHIDAT : WCUR = [M:TNH1]CUR : WCHGTYP = [M:TNH0]CHGTYP
               Gosub CHARG_RATRPT
               If dim([L]WVACITM)>0
                   [L]WVACITM(0)=[M:TNH1]VACITM1(nolign-1)
                   [L]WVACITM(1)=[M:TNH1]VACITM2(nolign-1)
                   [L]WVACITM(2)=[M:TNH1]VACITM3(nolign-1)
               Endif
               #----- Chargement des provinces -----#
               If find(TRAIT, 2,3) & func TRTX3.ACTIV_PTX
                   Gosub DECLARE_SAT
                   WBPCORD=[M:TNH0]BPCORD
                   WSTOFCY=[M:TNH0]STOFCY : WBPAADD=[M:TNH0]BPAADD
                   If dim([M:ADB2]CTY)>0 WCTY=[M:ADB2]CTY : WCRY=[M:ADB2]CRY : WSAT=[M:ADB2]SAT Endif
                   Gosub CHARG_SAT
               Endif
 # 91606 :(04/08/14) Transportation notes (Sales part dev)
 When "SDD"  : [F:TLK] = [F:SDD]
               [F:TLK] = [F:SDH]
               [F:TLK]QTY = WQTY
               [F:TLK]VACBPR = [F:SDH]VACBPR
               [F:TLK]ITMWEI = [F:SDD]UNTWEI
               WDAT = [F:SDH]SHIDAT : WCUR = [F:SDH]CUR : WCHGTYP = [F:SDH]CHGTYP
               Gosub CHARG_RATRPT
               If dim([L]WVACITM)>0
                   [L]WVACITM(0)=[F:SDD]VACITM(0)
                   [L]WVACITM(1)=[F:SDD]VACITM(1)
                   [L]WVACITM(2)=[F:SDD]VACITM(2)
               Endif
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If find(TRAIT, 2,3) & func AFNC.ACTIV("PTX")
               If find(TRAIT, 2,3) & func TRTX3.ACTIV_PTX
                   Gosub DECLARE_SAT
                   WBPCORD=[F:SDH]BPCORD
                   WSTOFCY=[F:SDH]STOFCY : WBPAADD=[F:SDH]BPAADD
                   WCTY=[F:SDH]BPDCTY : WCRY=[F:SDH]BPDCRY : WSAT=[F:SDH]BPDSAT
                   Gosub CHARG_SAT
               Endif
 When "SIH4" : [F:TLK] = [M:SIH0]
               [F:TLK] = [M:SIH4]
               [F:TLK]VACBPR = [M:SIH1]VACBPR
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
#              Si factures de livraison, recherche du poids dans la livraison
               If [M:SIH4]SDHNUM(nolign-1) <> "" & [M:SIH4]SDDLIN(nolign-1) <> 0
                   If [F:SDD]SDHNUM <> [M:SIH4]SDHNUM(nolign-1) | [F:SDD]SDDLIN <> [M:SIH4]SDDLIN(nolign-1)
                      Read [SDD]SDD0 = [M:SIH4]SDHNUM(nolign-1);[M:SIH4]SDDLIN(nolign-1)
                      If fstat Raz [F:SDD] Endif
                   Endif
                   [F:TLK]ITMWEI = [F:SDD]UNTWEI
               Endif
#              RATRPT n'est pas connu dans le cas d'un recalcul tarif
#               [F:TLK]RATRPT = 1/[M:SIH2]RATRPT
               WDAT = [M:SIH0]INVDAT : WCUR = [M:SIH2]CUR : WCHGTYP = [M:SIH2]CURTYP
               Gosub CHARG_RATRPT
               If dim([L]WVACITM)>0
                   [L]WVACITM(0)=[M:SIH4]VACITM1(nolign-1)
                   [L]WVACITM(1)=[M:SIH4]VACITM2(nolign-1)
                   [L]WVACITM(2)=[M:SIH4]VACITM3(nolign-1)
               Endif
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If find(TRAIT, 2,3) & func AFNC.ACTIV("PTX")
               If find(TRAIT, 2,3) & func TRTX3.ACTIV_PTX
                   Gosub DECLARE_SAT
                   WBPCORD=[M:SIH1]BPCORD
                   # Bug 74713 : Alimentation province sortie ŕ partir du site d'expé si renseigné sinon ŕ partir du site de vente
                   #WSTOFCY=[M:SIH4]DSTOFCY(nolign-1) : WBPAADD=[M:SIH1]BPAADD
                   If [M:SIH4]DSTOFCY(nolign-1) ="" WSTOFCY=[M:SIH0]SALFCY Else WSTOFCY=[M:SIH4]DSTOFCY(nolign-1)  Endif
                   WBPAADD=[M:SIH1]BPAADD
                   # Bug 74713
                   If dim([M:ADB2]CTY)>0 WCTY=[M:ADB2]CTY : WCRY=[M:ADB2]CRY : WSAT=[M:ADB2]SAT Endif
                   Gosub CHARG_SAT
               Endif
 When "SIHV" : [F:TLK] = [M:SIH0]
               [F:TLK] = [M:SIHV]
               [F:TLK]VACBPR = [M:SIH1]VACBPR
#              RATRPT n'est pas connu dans le cas d'un recalcul tarif
#               [F:TLK]RATRPT = 1/[M:SIH2]RATRPT
               WDAT = [M:SIH0]INVDAT : WCUR = [M:SIH2]CUR : WCHGTYP = [M:SIH2]CURTYP
               Gosub CHARG_RATRPT
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If find(TRAIT, 2,3) & func AFNC.ACTIV("PTX")
               If find(TRAIT, 2,3) & func TRTX3.ACTIV_PTX
                   Gosub DECLARE_SAT
                   WBPCORD=[M:SIH1]BPCORD
                   # Bug 74713 : Alimentation province sortie ŕ partir du site d'expé si renseigné sinon ŕ partir du site de vente
                   #WSTOFCY=[M:SIH1]STOFCY : WBPAADD=[M:SIH1]BPAADD
                   If [M:SIH1]STOFCY ="" WSTOFCY=[M:SIH0]SALFCY Else WSTOFCY=[M:SIH1]STOFCY  Endif
                   WBPAADD=[M:SIH1]BPAADD
                   # Bug 74713
                   If dim([M:ADB2]CTY)>0 WCTY=[M:ADB2]CTY : WCRY=[M:ADB2]CRY : WSAT=[M:ADB2]SAT Endif
                   Gosub CHARG_SAT
               Endif
               #----- Chargement montant taxe (pour Canada) -----#
               If dim([L]ALICLCAMT_FLG)>0
                 [F:TLK]AMTNOT =sum([M:SIHV]XVNOT)                    : # Montant total HT de toutes les lignes
#                 [F:TLK]AMTTAX1=sum([M:SIHV]XVAMT)-sum([M:SIHV]XVSUP) : # Montant des taxes principales de toutes les lignes
                 # Montant des taxes principales de toutes les lignes
                 [F:TLK]AMTTAX1=sigma(I=0,[M:SIHV]NBVAT-1,[M:SIHV]XVAMT*([M:SIHV]XVTYP(I)=1))
                 [F:TLK]AMTNOTLIN=[F:TLK]AMTNOT
                 [F:TLK]AMTTAXLIN1=[F:TLK]AMTTAX1
               Endif
               #-----
 When "SIHX" : [F:TLK] = [M:SIH0]
               [F:TLK] = [M:SIHX]
               [F:TLK]VACBPR = [M:SIH1]VACBPR
#              RATRPT n'est pas connu dans le cas d'un recalcul tarif
#               [F:TLK]RATRPT = 1/[M:SIH2]RATRPT
               WDAT = [M:SIH0]INVDAT : WCUR = [M:SIH2]CUR : WCHGTYP = [M:SIH2]CURTYP
               Gosub CHARG_RATRPT
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If find(TRAIT, 2,3) & func AFNC.ACTIV("PTX")
               If find(TRAIT, 2,3) & func TRTX3.ACTIV_PTX
                   Gosub DECLARE_SAT
                   WBPCORD=[M:SIH1]BPCORD
                   # Bug 74713 : Alimentation province sortie ŕ partir du site d'expé si renseigné sinon ŕ partir du site de vente
                   #WSTOFCY=[M:SIH1]STOFCY : WBPAADD=[M:SIH1]BPAADD
                   If [M:SIH1]STOFCY ="" WSTOFCY=[M:SIH0]SALFCY Else WSTOFCY=[M:SIH1]STOFCY  Endif
                   WBPAADD=[M:SIH1]BPAADD
                   # Bug 74713
                   If dim([M:ADB2]CTY)>0 WCTY=[M:ADB2]CTY : WCRY=[M:ADB2]CRY : WSAT=[M:ADB2]SAT Endif
                   Gosub CHARG_SAT
               Endif
               #-----
 When "SID"  : [F:TLK] = [F:SIV]
               [F:TLK] = [F:SID]
               [F:TLK]QTY = WQTY
               [F:TLK]VACBPR = [F:SIH]VAC
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               WDAT = [F:SIV]INVDAT : WCUR = [F:SIV]CUR : WCHGTYP = [F:SIH]CURTYP
               Gosub CHARG_RATRPT
               If dim([L]WVACITM)>0
                   [L]WVACITM(0)=[F:SID]VACITM(0)
                   [L]WVACITM(1)=[F:SID]VACITM(1)
                   [L]WVACITM(2)=[F:SID]VACITM(2)
               Endif
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If find(TRAIT, 2,3) & func AFNC.ACTIV("PTX")
               If find(TRAIT, 2,3) & func TRTX3.ACTIV_PTX
                   Gosub DECLARE_SAT
                   WBPCORD=[F:SIV]BPCORD
                   # Bug 74713 : Alimentation province sortie ŕ partir du site d'expé si renseigné sinon ŕ partir du site de vente
                   #WSTOFCY=[F:SID]STOFCY : WBPAADD=[F:SIV]BPAADD
                   If [F:SID]STOFCY ="" WSTOFCY=[F:SID]SALFCY Else WSTOFCY=[F:SID]STOFCY  Endif
                   WBPAADD=[F:SIV]BPAADD
                   # Bug 74713
                   WCTY=[F:SIV]BPDCTY : WCRY=[F:SIV]BPDCRY : WSAT=[F:SIV]BPDSAT
                   Gosub CHARG_SAT
               Endif
 When "PSD"  : [F:TLK] = [F:PSH]
               [F:TLK] = [F:PSD]
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               [F:TLK]PURFCY = [F:PSD]PSHFCY
              #Call INIT_REGIME([F:PSD]BPSNUM,[F:TLK]PURFCY,"F",[F:TLK]VACBPR) From CPTSUB
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If func AFNC.ACTIV("PTX")
               If func TRTX3.ACTIV_PTX
                 #----- Chargement province de sortie -----#
                 If [F:BPS]BPSNUM<>[F:PSD]BPSNUM
                   Read [BPS] BPS0=[F:PSD]BPSNUM : If fstat  Raz [F:BPS] : Endif
                 Endif
                 If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:PSD]BPSNUM
&                                    | [F:BPA]BPAADD<>[F:BPS]BPAADD
                   Read [BPA] BPA0=1;[F:PSD]BPSNUM;[F:BPS]BPAADD
                   If fstat  Raz [F:BPA] : Endif
                 Endif
                 [F:TLK]SATISS=[F:BPA]SAT
                 #----- Chargement province d'entrée -----#
                 If [F:FCY]FCY<>[F:PSD]PRHFCY
                   Read [FCY] FCY0=[F:PSD]PRHFCY : If fstat  Raz [F:FCY] : Endif
                 Endif
                 If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[F:PSD]PRHFCY
&                                    | [F:BPA]BPAADD<>[F:FCY]BPAADD
                   Read [BPA] BPA0=3;[F:PSD]PRHFCY;[F:FCY]BPAADD
                   If fstat  Raz [F:BPA] : Endif
                 Endif
                 [F:TLK]SATRCP=[F:BPA]SAT
               Endif
               #-----
               WDAT=[F:PSH]PRQDAT : WCUR=[F:PSD]CUR : WCHGTYP=[F:PSD]CHGTYP
               Gosub CHARG_COMPLEMENT_ACHAT
 When "PSH1" : [F:TLK] = [M:PSH0]
               [F:TLK] = [M:PSH1]
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               [F:TLK]PURFCY = [M:PSH0]PSHFCY
              #Call INIT_REGIME([M:PSH1]BPSNUM(nolign-1),[F:TLK]PURFCY,"F",[F:TLK]VACBPR) From CPTSUB
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If func AFNC.ACTIV("PTX")
               If func TRTX3.ACTIV_PTX
                 #----- Chargement province de sortie -----#
                 If [F:BPS]BPSNUM<>[M:PSH1]BPSNUM(nolign-1)
                   Read [BPS] BPS0=[M:PSH1]BPSNUM(nolign-1) : If fstat  Raz [F:BPS] : Endif
                 Endif
                 If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[M:PSH1]BPSNUM(nolign-1)
&                                    | [F:BPA]BPAADD<>[F:BPS]BPAADD
                   Read [BPA] BPA0=1;[M:PSH1]BPSNUM(nolign-1);[F:BPS]BPAADD
                   If fstat  Raz [F:BPA] : Endif
                 Endif
                 [F:TLK]SATISS=[F:BPA]SAT
                 #----- Chargement province d'entrée -----#
                 If [F:FCY]FCY<>[M:PSH1]PRHFCY(nolign-1)
                   Read [FCY] FCY0=[M:PSH1]PRHFCY(nolign-1) : If fstat  Raz [F:FCY] : Endif
                 Endif
                 If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[M:PSH1]PRHFCY(nolign-1)
&                                    | [F:BPA]BPAADD<>[F:FCY]BPAADD
                   Read [BPA] BPA0=3;[M:PSH1]PRHFCY(nolign-1);[F:FCY]BPAADD
                   If fstat  Raz [F:BPA] : Endif
                 Endif
                 [F:TLK]SATRCP=[F:BPA]SAT
               Endif
               #-----
               WDAT=[M:PSH0]PRQDAT : WCUR=[M:PSH1]CUR(nolign-1) : WCHGTYP=[M:PSH1]CHGTYP(nolign-1)
               Gosub CHARG_COMPLEMENT_ACHAT
 When "POP"  : [F:TLK] = [F:POH]
               [F:TLK] = [F:POP]
               [F:TLK] = [F:POQ]
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               [F:TLK]PURFCY = [F:POH]POHFCY
               [F:TLK]AMTNOTLIN=[F:POQ]LINAMT
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If func AFNC.ACTIV("PTX")
               If func TRTX3.ACTIV_PTX
                 #----- Chargement province de sortie -----#
                 If [F:POH]BPOCRY<>"" | [F:POH]BPOCTY<>""
                   [F:TLK]SATISS=[F:POH]BPOSAT
                 Else
                   If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:POH]BPSNUM
&                                      | [F:BPA]BPAADD<>[F:POH]BPOADD
                     Read [BPA] BPA0=1;[F:POH]BPSNUM;[F:POH]BPOADD
                     If fstat  Raz [F:BPA] : Endif
                   Endif
                   [F:TLK]SATISS=[F:BPA]SAT
                 Endif
                 #----- Chargement province d'entrée -----#
                 If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[F:POQ]PRHFCY
&                                    | [F:BPA]BPAADD<>[F:POQ]FCYADD
                   Read [BPA] BPA0=3;[F:POQ]PRHFCY;[F:POQ]FCYADD
                   If fstat  Raz [F:BPA] : Endif
                 Endif
                 [F:TLK]SATRCP=[F:BPA]SAT
               Endif
               #----- Chargement montant taxe (pour Canada) -----#
               If dim([L]ALICLCAMT_FLG)>0
                 Local Integer WTYPREG
                 Local Decimal WMONTANT(1..3), WMONTDED(1..3)
                 Local Char    WTAXE(GLONVAT)(1..3)
                 WTAXE(1)=[F:POP]VAT(0)
                 WTAXE(2)=[F:POP]VAT(1)
                 WTAXE(3)=[F:POP]VAT(2)
                 Call CALTAXE([F:POH]CPY,[F:POH]ORDDAT,[F:POH]VACBPR,[F:POH]CUR,1,WTAXE,1,
&                             [F:POQ]LINAMT,WMONTANT,WMONTDED,WTYPREG,WSTAT) From SUBTVT
                 [F:TLK]AMTTAXLIN1=WMONTANT(1)
               Endif
               #-----
               WDAT=[F:POH]ORDDAT : WCUR=[F:POH]CUR : WCHGTYP=[F:POH]CHGTYP
               Gosub CHARG_COMPLEMENT_ACHAT
 When "POH2" : [F:TLK] = [M:POH0]
               [F:TLK] = [M:POH1]
               [F:TLK] = [M:POH2]
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               [F:TLK]PURFCY = [M:POH0]POHFCY
               [F:TLK]AMTNOTLIN=[M:POH2]LINAMT(nolign-1)
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If func AFNC.ACTIV("PTX")
               If func TRTX3.ACTIV_PTX
                 #----- Chargement province de sortie -----#
                 If [M:AD62]CRY<>"" | [M:AD62]CTY<>""
                   [F:TLK]SATISS=[M:AD62]SAT
                 Else
                   If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[M:POH0]BPSNUM
&                                      | [F:BPA]BPAADD<>[M:AD62]BPAADD
                     Read [BPA] BPA0=1;[M:POH0]BPSNUM;[M:AD62]BPAADD
                     If fstat  Raz [F:BPA] : Endif
                   Endif
                   [F:TLK]SATISS=[F:BPA]SAT
                 Endif
                 #----- Chargement province d'entrée -----#
                 If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[M:POH2]PRHFCY(nolign-1)
&                                    | [F:BPA]BPAADD<>[M:POH2]FCYADD(nolign-1)
                   Read [BPA] BPA0=3;[M:POH2]PRHFCY(nolign-1);[M:POH2]FCYADD(nolign-1)
                   If fstat  Raz [F:BPA] : Endif
                 Endif
                 [F:TLK]SATRCP=[F:BPA]SAT
               Endif
               #----- Chargement montant taxe (pour Canada) -----#
               If dim([L]ALICLCAMT_FLG)>0
                 Local Integer WTYPREG
                 Local Decimal WMONTANT(1..3), WMONTDED(1..3)
                 Local Char    WTAXE(GLONVAT)(1..3)
                 WTAXE(1)=[M:POH2]VAT1(nolign-1)
                 WTAXE(2)=[M:POH2]VAT2(nolign-1)
                 WTAXE(3)=[M:POH2]VAT3(nolign-1)
                 Call CALTAXE(GSOCIETE,[M:POH0]ORDDAT,[F:TLK]VACBPR,[M:POH1]CUR,1,WTAXE,1,
&                             [M:POH2]LINAMT(nolign-1),WMONTANT,WMONTDED,WTYPREG,WSTAT) From SUBTVT
                 [F:TLK]AMTTAXLIN1=WMONTANT(1)
               Endif
               #-----
               WDAT=[M:POH0]ORDDAT : WCUR=[M:POH1]CUR : WCHGTYP=[M:POH1]CHGTYP
               Gosub CHARG_COMPLEMENT_ACHAT
 When "POH3" : [F:TLK] = [M:POH0]
               [F:TLK] = [M:POH1]
               [F:TLK]QTY = WQTY
               [F:TLK]PURFCY = [M:POH0]POHFCY
               #-----
               WDAT=[M:POH0]ORDDAT : WCUR=[M:POH1]CUR : WCHGTYP=[M:POH1]CHGTYP
               Gosub CHARG_COMPLEMENT_ACHAT
 When "POI1" : [F:TLK] = [M:POI1]
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               If [M:POI1]ORDFCY(nolign-1)=""
                 [F:TLK]PURFCY = [M:POI1]POHFCY
               Else
                 [F:TLK]PURFCY = [M:POI1]ORDFCY(nolign-1)
               Endif
               [F:TLK]AMTNOTLIN=[M:POI1]LINAMT(nolign-1)
               Call INIT_REGIME([M:POI1]BPSNUM(nolign-1),[F:TLK]PURFCY,"F",[F:TLK]VACBPR) From CPTSUB
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If func AFNC.ACTIV("PTX")
               If func TRTX3.ACTIV_PTX
                 #----- Chargement province de sortie -----#
                 If [F:BPS]BPSNUM<>[M:POI1]BPSNUM(nolign-1)
                   Read [BPS] BPS0=[M:POI1]BPSNUM(nolign-1) : If fstat  Raz [F:BPS] : Endif
                 Endif
                 If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[M:POI1]BPSNUM(nolign-1)
&                                    | [F:BPA]BPAADD<>[F:BPS]BPAADD
                   Read [BPA] BPA0=1;[M:POI1]BPSNUM(nolign-1);[F:BPS]BPAADD
                   If fstat  Raz [F:BPA] : Endif
                 Endif
                 [F:TLK]SATISS=[F:BPA]SAT
                 #----- Chargement province d'entrée -----#
                 If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[M:POI1]PRHFCY(nolign-1)
&                                    | [F:BPA]BPAADD<>[M:POI1]FCYADD(nolign-1)
                   Read [BPA] BPA0=3;[M:POI1]PRHFCY(nolign-1);[M:POI1]FCYADD(nolign-1)
                   If fstat  Raz [F:BPA] : Endif
                 Endif
                 [F:TLK]SATRCP=[F:BPA]SAT
               Endif
               #----- Chargement montant taxe (pour Canada) -----#
               If dim([L]ALICLCAMT_FLG)>0
                 Local Integer WTYPREG
                 Local Decimal WMONTANT(1..3), WMONTDED(1..3)
                 Local Char    WTAXE(GLONVAT)(1..3)
                 WTAXE(1)=[M:POI1]VAT1(nolign-1)
                 WTAXE(2)=[M:POI1]VAT2(nolign-1)
                 WTAXE(3)=[M:POI1]VAT3(nolign-1)
                 Call CALTAXE(GSOCIETE,[M:POI1]ORDDAT,[F:TLK]VACBPR,[M:POI1]CUR(nolign-1),1,WTAXE,1,
&                             [M:POI1]LINAMT(nolign-1),WMONTANT,WMONTDED,WTYPREG,WSTAT) From SUBTVT
                 [F:TLK]AMTTAXLIN1=WMONTANT(1)
               Endif
               #-----
               WDAT=[M:POI1]ORDDAT : WCUR=[M:POI1]CUR(nolign-1) : WCHGTYP=[M:POI1]CHGTYP(nolign-1)
               Gosub CHARG_COMPLEMENT_ACHAT
 When "POC"  : [F:TLK] = [F:POH]
               [F:TLK] = [F:POC]
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               [F:TLK]PURFCY = [F:POH]POHFCY
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If func AFNC.ACTIV("PTX")
               If func TRTX3.ACTIV_PTX
                 #----- Chargement province de sortie -----#
                 If [F:POH]BPOCRY<>"" | [F:POH]BPOCTY<>""
                   [F:TLK]SATISS=[F:POH]BPOSAT
                 Else
                   If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:POH]BPSNUM
&                                      | [F:BPA]BPAADD<>[F:POH]BPOADD
                     Read [BPA] BPA0=1;[F:POH]BPSNUM;[F:POH]BPOADD
                     If fstat  Raz [F:BPA] : Endif
                   Endif
                   [F:TLK]SATISS=[F:BPA]SAT
                 Endif
                 #----- Chargement province d'entrée -----#
                 If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[F:POC]PRHFCY
&                                    | [F:BPA]BPAADD<>[F:POC]FCYADD
                   Read [BPA] BPA0=3;[F:POC]PRHFCY;[F:POC]FCYADD
                   If fstat  Raz [F:BPA] : Endif
                 Endif
                 [F:TLK]SATRCP=[F:BPA]SAT
               Endif
               #-----
               WDAT=[F:POH]ORDDAT : WCUR=[F:POH]CUR : WCHGTYP=[F:POH]CHGTYP
               Gosub CHARG_COMPLEMENT_ACHAT
 When "POC2" : [F:TLK] = [M:POC0]
               [F:TLK] = [M:POC1]
               [F:TLK] = [M:POC2]
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               [F:TLK]PURFCY = [M:POC0]POHFCY
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If func AFNC.ACTIV("PTX")
               If func TRTX3.ACTIV_PTX
                 #----- Chargement province de sortie -----#
                 If [M:AD64]CRY<>"" | [M:AD64]CTY<>""
                   [F:TLK]SATISS=[M:AD64]SAT
                 Else
                   If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[M:POC0]BPSNUM
&                                      | [F:BPA]BPAADD<>[M:AD64]BPAADD
                     Read [BPA] BPA0=1;[M:POC0]BPSNUM;[M:AD64]BPAADD
                     If fstat  Raz [F:BPA] : Endif
                   Endif
                   [F:TLK]SATISS=[F:BPA]SAT
                 Endif
                 #----- Chargement province d'entrée -----#
                 If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[M:POC2]PRHFCY
&                                    | [F:BPA]BPAADD<>[M:POC2]FCYADD
                   Read [BPA] BPA0=3;[M:POC2]PRHFCY;[M:POC2]FCYADD
                   If fstat  Raz [F:BPA] : Endif
                 Endif
                 [F:TLK]SATRCP=[F:BPA]SAT
               Endif
               #-----
               WDAT=[M:POC0]ORDDAT : WCUR=[M:POC1]CUR : WCHGTYP=[M:POC1]CHGTYP
               Gosub CHARG_COMPLEMENT_ACHAT
 When "PTD", "PWD"
               [F:TLK] = [F:PTH]
               [F:TLK] = [F:PTD]
               If ABREV="PWD"
                 [F:TLK]=[F:PWD]
                 [F:TLK]AMTNOTLIN=[F:PWD]AMTNOTLIN
               Else
                 [F:TLK]AMTNOTLIN=[F:PTD]LINAMT
               Endif
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               [F:TLK]PURFCY = [F:PTD]POHFCY
               Call INIT_REGIME([F:PTH]BPSNUM,[F:TLK]PURFCY,"F",[F:TLK]VACBPR) From CPTSUB
               #----- Chargement niveaux de taxe si inter-sociétés -----#
               If GMODU(5)=2 & [F:PTD]SDHNUM<>""
                 If [F:SDD]SDHNUM<>[F:PTD]SDHNUM |
&                   [F:SDD]SDDLIN<>[F:PTD]SDDLIN
                   Read [SDD] SDD0=[F:PTD]SDHNUM;[F:PTD]SDDLIN
                   If fstat  Raz [F:SDD] : Endif
                 Endif
                 If [F:SDD]VACITM<>""
                   [L]WVACITM(0)=[F:SDD]VACITM(0)
                   [L]WVACITM(1)=[F:SDD]VACITM(1)
                   [L]WVACITM(2)=[F:SDD]VACITM(2)
                 Endif
               Endif
               #----- Chargement province d'entrée -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If func AFNC.ACTIV("PTX")
               If func TRTX3.ACTIV_PTX
                 If [F:FCY]FCY<>[F:PTH]PRHFCY
                   Read [FCY] FCY0=[F:PTH]PRHFCY : If fstat  Raz [F:FCY] : Endif
                 Endif
                 If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[F:PTH]PRHFCY | [F:BPA]BPAADD<>[F:FCY]BPAADD
                   Read [BPA] BPA0=3;[F:PTH]PRHFCY;[F:FCY]BPAADD
                   If fstat  Raz [F:BPA] : Endif
                 Endif
                 [F:TLK]SATRCP=[F:BPA]SAT
               Endif
               #----- Chargement montant taxe (pour Canada) -----#
               If dim([L]ALICLCAMT_FLG)>0
                 Local Integer WTYPREG
                 Local Decimal WMONTANT(1..3), WMONTDED(1..3)
                 Local Char    WTAXE(GLONVAT)(1..3)
                 WTAXE(1)=[F:PTD]VAT(0)
                 WTAXE(2)=[F:PTD]VAT(1)
                 WTAXE(3)=[F:PTD]VAT(2)
                 Call CALTAXE([F:PTH]CPY,[F:PTH]RCPDAT,[F:TLK]VACBPR,[F:PTH]CUR,1,WTAXE,1,
&                             [F:TLK]AMTNOTLIN,WMONTANT,WMONTDED,WTYPREG,WSTAT) From SUBTVT
                 [F:TLK]AMTTAXLIN1=WMONTANT(1)
               Endif
               #-----
               WDAT=[F:PTH]RCPDAT : WCUR=[F:PTD]NETCUR : WCHGTYP=[F:PTH]CHGTYP
               Gosub CHARG_COMPLEMENT_ACHAT
 When "PTH1" : [F:TLK] = [M:PTH0]
               [F:TLK] = [M:PTH1]
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               [F:TLK]PURFCY = [M:PTH1]POHFCY(nolign-1)
               [F:TLK]AMTNOTLIN=[M:PTH1]LINAMT(nolign-1)
               #----- Chargement niveaux de taxe si inter-sociétés -----#
               If GMODU(5)=2 & [M:PTH1]SDHNUM(nolign-1)<>""
                 If [F:SDD]SDHNUM<>[M:PTH1]SDHNUM(nolign-1) |
&                   [F:SDD]SDDLIN<>[M:PTH1]SDDLIN(nolign-1)
                   Read [SDD] SDD0=[M:PTH1]SDHNUM(nolign-1);[M:PTH1]SDDLIN(nolign-1)
                   If fstat  Raz [F:SDD] : Endif
                 Endif
                 If [F:SDD]VACITM<>""
                   [L]WVACITM(0)=[F:SDD]VACITM(0)
                   [L]WVACITM(1)=[F:SDD]VACITM(1)
                   [L]WVACITM(2)=[F:SDD]VACITM(2)
                 Endif
               Endif
               #----- Chargement montant taxe (pour Canada) -----#
               If dim([L]ALICLCAMT_FLG)>0
                 Local Integer WTYPREG
                 Local Decimal WMONTANT(1..3), WMONTDED(1..3)
                 Local Char    WTAXE(GLONVAT)(1..3)
                 WTAXE(1)=[M:PTH1]VAT1(nolign-1)
                 WTAXE(2)=[M:PTH1]VAT2(nolign-1)
                 WTAXE(3)=[M:PTH1]VAT3(nolign-1)
                 Call CALTAXE(GSOCIETE,[M:PTH0]RCPDAT,[M:PTH0]VACBPR,[M:PTH0]CUR,1,WTAXE,1,
&                             [M:PTH1]LINAMT(nolign-1),WMONTANT,WMONTDED,WTYPREG,WSTAT) From SUBTVT
                 [F:TLK]AMTTAXLIN1=WMONTANT(1)
               Endif
               #-----
               WDAT=[M:PTH0]RCPDAT : WCUR=[M:PTH0]CUR : WCHGTYP=[M:PTH0]CHGTYP
               Gosub CHARG_COMPLEMENT_ACHAT
 When "PTH2" : [F:TLK] = [M:PTH0]
               [F:TLK] = [M:PTH1]
               [F:TLK]QTY = WQTY
               #-----
               WDAT=[M:PTH0]RCPDAT : WCUR=[M:PTH0]CUR : WCHGTYP=[M:PTH0]CHGTYP
               Gosub CHARG_COMPLEMENT_ACHAT
 When "PND","PWR"
               [F:TLK] = [F:PNH]
               [F:TLK] = [F:PND]
               If ABREV="PWR"
                 [F:TLK] = [F:PWR]
                 [F:TLK]AMTNOTLIN=[F:PWR]AMTNOTLIN
               Else
                 [F:TLK]AMTNOTLIN=[F:PND]LINAMT
               Endif
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               [F:TLK]PURFCY = [F:PND]POHFCY
               #----- Chargement province d'entrée -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If func AFNC.ACTIV("PTX")
               If func TRTX3.ACTIV_PTX
                 If [F:FCY]FCY<>[F:PNH]PNHFCY
                   Read [FCY] FCY0=[F:PNH]PNHFCY : If fstat  Raz [F:FCY] : Endif
                 Endif
                 If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>[F:PNH]PNHFCY | [F:BPA]BPAADD<>[F:FCY]BPAADD
                   Read [BPA] BPA0=3;[F:PNH]PNHFCY;[F:FCY]BPAADD
                   If fstat  Raz [F:BPA] : Endif
                 Endif
                 [F:TLK]SATRCP=[F:BPA]SAT
               Endif
               #----- Chargement montant taxe (pour Canada) -----#
               If dim([L]ALICLCAMT_FLG)>0
                 Local Integer WTYPREG
                 Local Decimal WMONTANT(1..3), WMONTDED(1..3)
                 Local Char    WTAXE(GLONVAT)(1..3)
                 WTAXE(1)=[F:PND]VAT(0)
                 WTAXE(2)=[F:PND]VAT(1)
                 WTAXE(3)=[F:PND]VAT(2)
                 Call CALTAXE([F:PNH]CPY,[F:PNH]RTNDAT,[F:PNH]VACBPR,[F:PND]NETCUR,1,WTAXE,1,
&                             [F:TLK]AMTNOTLIN,WMONTANT,WMONTDED,WTYPREG,WSTAT) From SUBTVT
                 [F:TLK]AMTTAXLIN1=WMONTANT(1)
               Endif
               #-----
               If [F:BPS]BPSNUM<>[F:PNH]BPSNUM
                 Read [BPS] BPS0=[F:PNH]BPSNUM
                 If fstat  Raz [F:BPS] : [F:BPS]CHGTYP=1 : Endif
               Endif
               WDAT=[F:PNH]RTNDAT : WCUR=[F:PND]NETCUR : WCHGTYP=[F:BPS]CHGTYP
               Gosub CHARG_COMPLEMENT_ACHAT
 When "PNH1" : [F:TLK] = [M:PNH1]
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               [F:TLK]PURFCY = [M:PNH1]POHFCY(nolign-1)
               [F:TLK]AMTNOTLIN=[M:PNH1]LINAMT(nolign-1)
               #----- Chargement montant taxe (pour Canada) -----#
               If dim([L]ALICLCAMT_FLG)>0
                 Local Integer WTYPREG
                 Local Decimal WMONTANT(1..3), WMONTDED(1..3)
                 Local Char    WTAXE(GLONVAT)(1..3)
                 WTAXE(1)=[M:PNH1]VAT1(nolign-1)
                 WTAXE(2)=[M:PNH1]VAT2(nolign-1)
                 WTAXE(3)=[M:PNH1]VAT3(nolign-1)
                 Call CALTAXE(GSOCIETE,[M:PNH1]RTNDAT,[M:PNH1]VACBPR,[M:PNH1]NETCUR(nolign-1),1,WTAXE,1,
&                             [M:PNH1]LINAMT(nolign-1),WMONTANT,WMONTDED,WTYPREG,WSTAT) From SUBTVT
                 [F:TLK]AMTTAXLIN1=WMONTANT(1)
               Endif
               #-----
               If [F:BPS]BPSNUM<>[M:PNH1]BPSNUM
                 Read [BPS] BPS0=[M:PNH1]BPSNUM
                 If fstat  Raz [F:BPS] : [F:BPS]CHGTYP=1 : Endif
               Endif
               WDAT=[M:PNH1]RTNDAT : WCUR=[M:PNH1]NETCUR(nolign-1) : WCHGTYP=[F:BPS]CHGTYP
               Gosub CHARG_COMPLEMENT_ACHAT
 When "PIH3" : [F:TLK] = [M:PIH0]
               [F:TLK] = [M:PIH1]
               [F:TLK] = [M:PIH3]
               [F:TLK]QTY = WQTY
               Call PCAL_QTY([M:PIH3]QTYPUU(nolign-1),[M:PIH3]PUU(nolign-1),[F:TLK]QTYSTU,[F:ITM]STU,
&                            [F:ITM]ITMREF,[M:PIH3]BPSNUM(nolign-1),1,GBIDD1)  From TRTACHQTE1
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               [F:TLK]PURFCY = [M:PIH3]FCYLIN(nolign-1)
               [F:TLK]VACBPR = [M:PIH1]VAC
               #----- Chargement niveaux de taxe si inter-sociétés -----#
               If GMODU(5)=2 & [M:PIH0]SIHNUM<>"" & [M:PIH3]SIDLIN(nolign-1)<>0
                 If [F:SID]NUM<>[M:PIH0]SIHNUM |
&                   [F:SID]SIDLIN<>[M:PIH3]SIDLIN(nolign-1)
                   Read [SID] SID0=[M:PIH0]SIHNUM;[M:PIH3]SIDLIN(nolign-1)
                   If fstat  Raz [F:SID] : Endif
                 Endif
                 If [F:SID]VACITM<>""
                   [L]WVACITM(0)=[F:SID]VACITM(0)
                   [L]WVACITM(1)=[F:SID]VACITM(1)
                   [L]WVACITM(2)=[F:SID]VACITM(2)
                 Endif
               Endif
               #----- Chargement montant taxe (pour Canada) -----#
               If dim([L]ALICLCAMT_FLG)>0
                 Local Integer WTYPREG
                 Local Decimal WMONTANT(1..3), WMONTDED(1..3)
                 Local Char    WTAXE(GLONVAT)(1..3)
                 WTAXE(1)=[M:PIH3]VAT1(nolign-1)
                 WTAXE(2)=[M:PIH3]VAT2(nolign-1)
                 WTAXE(3)=[M:PIH3]VAT3(nolign-1)
                 Call CALTAXE(GSOCIETE,[M:PIH0]ACCDAT,[M:PIH1]VAC,GCUR,1,WTAXE,1,
&                             [M:PIH3]AMTNOTLIN(nolign-1),WMONTANT,WMONTDED,WTYPREG,WSTAT) From SUBTVT
                 [F:TLK]AMTTAXLIN1=WMONTANT(1)
               Endif
               #-----
               WDAT=[M:PIH0]ACCDAT : WCUR=[M:PIH1]CUR : WCHGTYP=[M:PIH1]CURTYP
               Gosub CHARG_COMPLEMENT_ACHAT
 When "PIH4" : [F:TLK] = [M:PIH0]
               [F:TLK] = [M:PIH1]
               [F:TLK]QTY = WQTY
               [F:TLK]VACBPR = [M:PIH1]VAC
               #-----
               WDAT=[M:PIH0]ACCDAT : WCUR=[M:PIH1]CUR : WCHGTYP=[M:PIH1]CURTYP
               Gosub CHARG_COMPLEMENT_ACHAT
 When Default
Endcase
#----- P.E. pour intervenir sur le contenu du buffer TAXLINK
GPOINT="ALITLK" : Gosub ENTREE From EXEFNC
#-----
Return

$CHARG_COMPLEMENT_ACHAT
[F:TLK]AMTNOT =[F:TLK]AMTNOTLIN
[F:TLK]AMTTAX1=[F:TLK]AMTTAXLIN1
Gosub CHARG_RATRPT
Return

$CHARG_RATRPT
If WCUR <> GSYSCUR
    Call CONVERT(GSYSCUR,WCUR,GLOCALDEV,WCHGTYP,WDAT,1000000.00,COEFDEVISE,WSTAT) From TRTDEV
    If WSTAT=0 & COEFDEVISE<>0 COEFDEVISE=COEFDEVISE/1000000.00 Else COEFDEVISE=1 Endif
Endif
[F:TLK]RATRPT = COEFDEVISE
Return

########################################################################
# UTILISE PAR LES VENTES                                               #
#                                                                      #
# VACBPR est passé en paramčtre pr la prise en cpte du flag VATEXEFLG  #
########################################################################
#  Calcul de la taxe sur le prix unitaire                              #
#                                                   LD - décembre 1997 #
# En Entree PRIXBASE : Prix ŕ la base du calcul                        #
#           VAT      : Tableau des 3 codes taxes                       #
#           PRITYP   : Type de prix (HT/TTC)                           #
#           SOC      : Société                                         #
#           DAT      : Date de référence                               #
#           QTY      : Quantité                                        #
#           VACBPR   : Régime de taxe                                  #
#           CLCAMT1  : Base1 calcul taxe                               #
#           CLCAMT1  : Base2 calcul taxe                               #
# En sortie PRIXCALC : Prix calculé                                    #
#                                                                      #
########################################################################
Subprog CLCTAXEPRIV (PRIXBASE,VAT,PRITYP,SOC,DAT,QTY,VACBPR,CLCAMT1,CLCAMT2,PRIXCALC)
Value    Decimal PRIXBASE
Value    Char    VAT()(0..2)
Value    Integer PRITYP
Value    Char    SOC
Value    Date    DAT
Value    Decimal QTY
Value    Char    VACBPR
Value    Decimal CLCAMT1
Value    Decimal CLCAMT2
Variable Decimal PRIXCALC
#-----
Local    Libelle WTRT : WTRT=1 : # Avec 2 bases spéciales CLCAMT1 et CLCAMT2
#-----
Gosub CLC_TAXEPRI
End

########################################################################
# UTILISE PAR LES ACHATS                                               #
#                                                                      #
# VACBPR non utile (pas de prise en cpte du flag VATEXEFLG             #
########################################################################
#  Calcul de la taxe sur le prix unitaire                              #
#                                                   LD - décembre 1997 #
# En Entree PRIXBASE : Prix ŕ la base du calcul                        #
#           VAT      : Tableau des 3 codes taxes                       #
#           PRITYP   : Type de prix (HT/TTC)                           #
#           SOC      : Société                                         #
#           DAT      : Date de référence                               #
#           QTY      : Quantité                                        #
#           CLCAMT1  : Base1 calcul taxe                               #
#           CLCAMT1  : Base2 calcul taxe                               #
# En sortie PRIXCALC : Prix calculé                                    #
#                                                                      #
########################################################################
Subprog CLCTAXEPRI (PRIXBASE,VAT,PRITYP,SOC,DAT,QTY,CLCAMT1,CLCAMT2,PRIXCALC)
Value    Decimal PRIXBASE
Value    Char    VAT()(0..2)
Value    Integer PRITYP
Value    Char    SOC
Value    Date    DAT
Value    Decimal QTY
Value    Decimal CLCAMT1
Value    Decimal CLCAMT2
Variable Decimal PRIXCALC
#-----
Local    Char    VACBPR : Raz VACBPR
Local    Libelle WTRT   : WTRT=1 : # Avec 2 bases spéciales CLCAMT1 et CLCAMT2
#-----
Gosub CLC_TAXEPRI
End

########################################################################
# CLCTAXEPRI2 : Calcul de la taxe sur le prix unitaire                 #
# -------------------------------------------------------------------- #
# Utilisé par les achats (gestion des 7 bases spéciales)               #
# VACBPR inutile (pas de prise en compte du flag VATEXEFLG)            #
########################################################################
# En Entree PRIXBASE : Prix ŕ la base du calcul         MBT 10/02/2010 #
#           VAT      : Tableau des 3 codes taxes                       #
#           PRITYP   : Type de prix (HT/TTC)                           #
#           SOC      : Société                                         #
#           DAT      : Date de référence                               #
#           QTY      : Quantité                                        #
#           CLCAMT1  : Base1 calcul taxe                               #
#           CLCAMT1  : Base2 calcul taxe                               #
# En sortie PRIXCALC : Prix calculé                                    #
########################################################################
Subprog CLCTAXEPRI2(PRIXBASE,VAT,PRITYP,SOC,DAT,QTY,CLCAMT,PRIXCALC)
Value    Decimal PRIXBASE
Value    Char    VAT()(0..2)
Value    Integer PRITYP
Value    Char    SOC
Value    Date    DAT
Value    Decimal QTY
Value    Decimal CLCAMT(0..)
Variable Decimal PRIXCALC
#-----
Local    Char    VACBPR : Raz VACBPR
Local    Libelle WTRT   : WTRT=2 : # Avec 7 bases spéciales CLCAMT(0..6)
#-----
Gosub CLC_TAXEPRI
End


$CLC_TAXEPRI

#Fq74432-Gbn-Ajout PE non documenté pour permettre aux US de court-circuiter lr calcul std des taxes au profit d'AVATAX
Raz GPE : GPOINT="CLCTAXPRI" : Gosub ENTREE From EXEFNC : If GPE : Return : Endif   #CHECK IGNORE_LINE

Local    Decimal TXTVA, TXTAX
Local    Decimal TXTOT, TXTF1, TXTF2, TXTF(0..6)
Local    Char    TAX(GLONVAT)
Local    Integer STAT : STAT = 0
Local    Integer I
Local    Decimal WSVGPRIXBASE : WSVGPRIXBASE=PRIXBASE         : # 96182 : Pb Utilisation PE NEGPRI

# Issue 71937 - 2012-03-27 by SR
Local Integer  WRET
#-----
If !clalev([F:TVT])  Local File TABVAT [TVT]    : Endif
If !clalev([F:TRA])  Local File TABRATVAT [TRA] : Endif
#-----
Raz TXTOT, TXTF1, TXTF2, TXTF
For I=0 To 2
  # Issue 71937 - 2012-03-27 by SR : comment
  Call LEC_TVT_LEG(GCURLEG,VAT(I),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
#Read [TVT] TVT0=VAT(I)
#If !fstat
  If !WRET
    TAX=VAT(I) : Gosub LECTAX
    If TXTAX<>0
      #----- Si taxe avec formule de calcul et no montant renseigné -----#
      If [F:TVT]VATFOR<>"" & [F:TVT]VATBAS<>1
        #----- Utilisation bases spéciales 1-7 en fonction du rang de la taxe -----#
        If WTRT=2
          TXTF(I)+=TXTAX/100
          If I=0
            TXTVA=TXTAX
          Endif
          If [F:TVT]VATCHA=2 & I<>0
            TXTF(I)+=(TXTAX/100)*(TXTVA/100)
          Endif
        #----- Utilisation bases spéciales 1-2 en fonction du paramétrage taxe -----#
        Else
          #----- Base = montant1 -----#
          If [F:TVT]VATBAS=2
            TXTF1+=TXTAX/100
            If I=0
              TXTVA=TXTAX
            Endif
            If [F:TVT]VATCHA=2 & I<>0
              TXTF1+=(TXTAX/100)*(TXTVA/100)
            Endif
          #----- Base = montant2 -----#
          Elsif [F:TVT]VATBAS=3
            TXTF2+=TXTAX/100
            If I=0
              TXTVA=TXTAX
            Endif
            If [F:TVT]VATCHA=2 & I<>0
              TXTF2+=(TXTAX/100)*(TXTVA/100)
            Endif
          Endif
        Endif
      #----- Si taxe sans formule de calcul ou no montant non renseigné -----#
      Else
        TXTOT+=TXTAX/100
        If I=0
          TXTVA=TXTAX
        Endif
        If [F:TVT]VATCHA=2 & I<>0
          TXTOT+=(TXTAX/100)*(TXTVA/100)
        Endif
      Endif
    Endif
  Endif
Next I
#-----
TXTOT+=1
If PRITYP=1
  PRIXCALC=PRIXBASE*TXTOT
  If WTRT=2
    For I=0 To dim(CLCAMT)-1
      If TXTF(I)<>0 & QTY<>0  PRIXCALC+=CLCAMT(I)*TXTF(I)/QTY : Endif
    Next I
  Else
    If TXTF1<>0 & QTY<>0  PRIXCALC+=CLCAMT1*TXTF1/QTY : Endif
    If TXTF2<>0 & QTY<>0  PRIXCALC+=CLCAMT2*TXTF2/QTY : Endif
  Endif
  PRIXCALC=arr(PRIXCALC,10^-GDECPRI)
Else
  If WTRT=2
    For I=0 To dim(CLCAMT)-1
      If TXTF(I)<>0 & QTY<>0  PRIXBASE-=CLCAMT(I)*TXTF(I)/QTY : Endif
    Next I
  Else
    If TXTF1<>0 & QTY<>0  PRIXBASE-=CLCAMT1*TXTF1/QTY : Endif
    If TXTF2<>0 & QTY<>0  PRIXBASE-=CLCAMT2*TXTF2/QTY : Endif
  Endif
  #PRIXCALC = PRIXBASE/TXTOT           : # Bug 73097
  # 96182 : Pb Utilisation PE NEGPRI
  #PRIXCALC = max(0,PRIXBASE/TXTOT)    : # Bug 73097 : Eviter un prix négatif
  If WSVGPRIXBASE >= 0
      # Prix de base positif : Eviter un prix négatif
      PRIXCALC = max(0,PRIXBASE/TXTOT)
  Else
      # Prix de base négatif (par utilisation PE NEGPRI), c'est normal d'avoir un prix négatif
      PRIXCALC = PRIXBASE/TXTOT
  Endif
  # 96182
  PRIXCALC=arr(PRIXCALC,10^-GDECPRI)
Endif
Filter [TRA]
Return

########################################################################
# LECKUACT : Lecture des codes activites concernant les taxes USA      #
#                                                   LD - juin 2000     #
# En Entree WACT    : Code activite                                    #
# En Sortie WSTAT   : Code retour                                      #
########################################################################
Subprog LECKUACT(WACT, WSTAT)
Value    Char    WACT
Variable Integer WSTAT    :    Raz WSTAT

If !clalev([F:ACV]) Local File ACTIV      [ACV] : Endif
# Lecture du code activite
If [F:ACV]CODACT <> WACT
    Read[ACV]CODACT=WACT
    If !fstat & [F:ACV]FLACT = 2 WSTAT=1 Endif
Elsif [F:ACV]FLACT = 2 WSTAT=1
Endif
End

########################################################################
# LECACT : Lecture des codes activites                                 #
#                                                   SR - OCT 2000      #
#                                             Reprise du trt ci-dessus #
# En Entree WACT    : Code activite                                    #
# En Sortie WSTAT   : Code retour                                      #
########################################################################
Subprog LECACT(WACT, WSTAT)
Value    Char    WACT
Variable Integer WSTAT    :    Raz WSTAT

If !clalev([F:ACV]) Local File ACTIV      [ACV] : Endif
# Lecture du code activite
If [F:ACV]CODACT <> WACT
    Read[ACV]CODACT=WACT
    If !fstat & [F:ACV]FLACT = 2 WSTAT=1 Endif
Elsif [F:ACV]FLACT = 2 WSTAT=1
Endif
End

########################################################################
# UTILISE PAR LES VENTES                                               #
#                                                                      #
# VACBPR est passé en paramčtre pr la prise en cpte du flag VATEXEFLG  #
########################################################################
#  Calcul de la taxe sur le montant de la ligne                        #
#                                                   LD - décembre 1997 #
# En Entree MONTBASE : Montant ŕ la base du calcul                     #
#           VAT      : Tableau des 3 codes taxes                       #
#           PRITYP   : Type de prix (HT/TTC)                           #
#           SOC      : Société                                         #
#           DAT      : Date de référence                               #
#           VACBPR   : Régime de taxe                                  #
# En sortie CLCAMT1  : Base 1 calcul taxe                              #
#           CLCAMT2  : Base 2 calcul taxe                              #
#           MONTCALC : Montant calculé                                 #
########################################################################
Subprog CLCTAXEMNTV (MONTBASE,VAT,PRITYP,SOC,DAT,VACBPR,CLCAMT1,CLCAMT2,MONTCALC)
Value    Decimal MONTBASE
Value    Char    VAT()(0..2)
Value    Integer PRITYP
Value    Char    SOC
Value    Date    DAT
Value    Char    VACBPR   # FGR 01/02/2010 : X3SUIVI60986
Variable Decimal CLCAMT1
Variable Decimal CLCAMT2
Variable Decimal MONTCALC
#-----
Local    Libelle WTRT : WTRT=1 : # Avec 2 bases spéciales CLCAMT1 et CLCAMT2
#-----
Gosub CLC_TAXEMNT
End

########################################################################
# UTILISE PAR LES ACHATS et les VENTES ? (SUBSDHB, SUBSOHB, SUBSQHB)   #
#                                                                      #
# VACBPR non utile (pas de prise en cpte du flag VATEXEFLG             #
########################################################################
#  Calcul de la taxe sur le montant de la ligne                        #
#                                                   LD - décembre 1997 #
# En Entree MONTBASE : Montant ŕ la base du calcul                     #
#           VAT      : Tableau des 3 codes taxes                       #
#           PRITYP   : Type de prix (HT/TTC)                           #
#           SOC      : Société                                         #
#           DAT      : Date de référence                               #
# En sortie CLCAMT1  : Base 1 calcul taxe                              #
#           CLCAMT2  : Base 2 calcul taxe                              #
#           MONTCALC : Montant calculé                                 #
########################################################################
Subprog CLCTAXEMNT (MONTBASE,VAT,PRITYP,SOC,DAT,CLCAMT1,CLCAMT2,MONTCALC)
Value    Decimal MONTBASE
Value    Char    VAT()(0..2)
Value    Integer PRITYP
Value    Char    SOC
Value    Date    DAT
Variable Decimal CLCAMT1
Variable Decimal CLCAMT2
Variable Decimal MONTCALC
#-----
Local    Char    VACBPR(GLONTVB) : Raz VACBPR
Local    Libelle WTRT : WTRT=1 : # Avec 2 bases spéciales CLCAMT1 et CLCAMT2
#-----
Gosub CLC_TAXEMNT
End

########################################################################
# CLCTAXEMNT2 : Calcul de la taxe sur le montant de la ligne           #
# -------------------------------------------------------------------- #
# Utilisé par les achats (gestion des 7 bases spéciales)               #
# VACBPR inutile (pas de prise en compte du flag VATEXEFLG)            #
# -------------------------------------------------------------------- #
# En Entree MONTBASE : Montant ŕ la base du calcul      MBT 10/02/2010 #
#           VAT      : Tableau des 3 codes taxes                       #
#           PRITYP   : Type de prix (HT/TTC)                           #
#           SOC      : Société                                         #
#           DAT      : Date de référence                               #
# En sortie CLCAMT   : Bases 1 ŕ 7 calcul taxe                         #
#           MONTCALC : Montant calculé                                 #
########################################################################
Subprog CLCTAXEMNT2(MONTBASE,VAT,PRITYP,SOC,DAT,CLCAMT,MONTCALC)
Value    Decimal MONTBASE
Value    Char    VAT()(0..2)
Value    Integer PRITYP
Value    Char    SOC
Value    Date    DAT
Variable Decimal CLCAMT(0..)
Variable Decimal MONTCALC
#-----
Local    Char    VACBPR(GLONTVB) : Raz VACBPR
Local    Libelle WTRT : WTRT=2 : # Avec 7 bases spéciales CLCAMT(0..6)
#-----
Gosub CLC_TAXEMNT
End


$CLC_TAXEMNT
#Fq74432-Gbn-Ajout PE non documenté pour permettre aux US de court-circuiter lr calcul std des taxes au profit d'AVATAX
Raz GPE : GPOINT="CLCTAXMNT" : Gosub ENTREE From EXEFNC : If GPE : Return : Endif   #CHECK IGNORE_LINE

Local    Decimal TXTVA, TXTAX
Local    Decimal TXTOT
Local    Decimal TAXE1
Local    Decimal TAXE2
Local    Char    TAX(GLONVAT)
Local    Integer STAT : STAT = 0
# Issue 71937 - 2012-03-27 by SR
Local Integer  WRET
#-----
If !clalev([F:TVT])  Local File TABVAT    [TVT] : Endif
If !clalev([F:TRA])  Local File TABRATVAT [TRA] : Endif
#-----
Raz TXTOT, TAXE1, TAXE2
For I=0 To 2
  If VAT(I) <> "" Then       # FGR 24/07/2015 : X3SUIVI109796 : Optimisation
    # Issue 71937 - 2012-03-27 by SR : comment
    Call LEC_TVT_LEG(GCURLEG,VAT(I),WRET) From TRTLECLEG
    If WRET : Raz [F:TVT] : Endif
    #Read [TVT]TVT0 = VAT(I)
    #If !fstat
    If WRET=0
      TAX=VAT(I) : Gosub LECTAX
      #----- Si taux de taxe différent de 0 -----#
      If TXTAX<>0
        #----- Taxe avec formule de calcul -----#
        If [F:TVT]VATFOR<>""
          #----- Utilisation bases spéciales 1-7 en fonction du rang de la taxe -----#
          If WTRT=2
            If [F:TVT]VATBAS>1
              TAXE1  += CLCAMT(I)*(TXTAX/100)
              If [F:TVT]VATCHA = 2 & I <> 0
                TAXE1 += CLCAMT(I)*(TXTAX/100) * (TXTVA/100)
              Endif
            Endif
          #----- Utilisation bases spéciales 1-2 en fonction du paramétrage taxe -----#
          Else
            If [F:TVT]VATBAS = 2
              TAXE1  += CLCAMT1*(TXTAX/100)
              If [F:TVT]VATCHA = 2 & I <> 0
                TAXE1 += CLCAMT1*(TXTAX/100) * (TXTVA/100)
              Endif
            Endif
            If [F:TVT]VATBAS = 3
              TAXE2  += CLCAMT2*(TXTAX/100)
              If [F:TVT]VATCHA = 2 & I <> 0
                TAXE2 += CLCAMT2*(TXTAX/100) * (TXTVA/100)
              Endif
            Endif
          Endif
        #----- Taxe classique sans formule -----#
        Else
          TXTOT += TXTAX/100
          If [F:TVT]VATCHA = 2 & I <> 0
            TXTOT += (TXTAX/100) * (TXTVA/100)
          Endif
        Endif
        #----- Récupération taux TVA pour taxes secondaires sousmises ŕ TVA -----#
        If I = 0 : TXTVA = TXTAX : Endif
      Endif
    Endif
  Endif
Next I
TXTOT += 1
If PRITYP = 1
  MONTCALC = MONTBASE*TXTOT + TAXE1 + TAXE2
Else
  #MONTCALC = (MONTBASE - TAXE1 - TAXE2) / TXTOT           : # Bug 73097
  MONTCALC = max(0,(MONTBASE - TAXE1 - TAXE2) / TXTOT)     : # Bug 73097 : Eviter un montant négatif
Endif
Filter [TRA]
Return


#----------------------------------------------------------#
# Récupération du taux de taxe selon la date et la société #
#----------------------------------------------------------#
$LECTAX
TXTAX=0
# Cas particulier société ??
#--CPO 71937 TRA et multi-lčg
#Filter [TRA] Where CPY=SOC & VAT=TAX & STRDAT<=DAT
Filter [TRA] Where CPY=SOC & VAT=TAX & STRDAT<=DAT & LEG= [F:TVT]LEG
Read [TRA]TRA0 Last
If fstat>2
# sinon on se rabat sur le code dossier
 #Filter [TRA] Where CPY="" & VAT=TAX & STRDAT<=DAT
 Filter [TRA] Where CPY="" & VAT=TAX & STRDAT<=DAT & LEG= [F:TVT]LEG
 Read [TRA]TRA0 Last
 #--CPO et LD 83405 Bench GESSOH
 #If fstat>2 : STAT = 2 : Return : Endif
 If fstat>2 : STAT = 2 : Filter [F:TRA] : Return : Endif
Endif
#--/CPO

TXTAX = [F:TRA]VATRAT

If VACBPR<>""
    # 71937 : Multilégislation
    #If !clalev([F:ADI]) Local File ATABDIV   [ADI] Endif
    ## Issue 74556 - 2011-07-05 by VPO : lecture ssi besoin
    #If [F:ADI]NUMTAB<>1 | [F:ADI]CODE<>VACBPR
    #  Read [ADI]CODE=1;VACBPR
    #Endif
    #If [F:ADI]N1<>1 & dim([F:TRA]VATEXEFLG)>0 & [F:TRA]VATEXEFLG=2 : TXTAX=0 : Endif
    If !clalev([F:TVB]) Local File TABVACBPR [TVB] Endif
    Local Integer WRET
    Call LEC_TVB_LEG(GCURLEG,VACBPR,WRET) From TRTLECLEG
    If WRET Raz [F:TVB] : Endif
    If [F:TVB]REGVAC<>1 & dim([F:TRA]VATEXEFLG)>0 & [F:TRA]VATEXEFLG=2 : TXTAX=0 : Endif
    # 71937 : Multilégislation
Endif

Filter [TRA]
Return

###########################################################
#
# Selection d'une adresse
#
# En entrée
# LTYP = Type d'adresse (menu 203)
# LNUM = Numéro tiers / site / société /....
# LNAM = Nom ou raison sociale sur 2 lignes
#
# Sortie
# LADR = Adresse sélectionnée (vide si pas de sélection)
#
# La lecture des adresses se fait avec [BPA1]
###########################################################
Subprog SELADR(LTYP,LNUM,LNAM,LADR)
Variable Integer LTYP
Variable Char    LNUM
Variable Char    LNAM()
Variable Char    LADR
#-----
Local  Integer I, WREP, ETABOU(1..GNBBOU), SAVGOBJET
Local  Char    CHAINE
Local  Integer NBTEX       : NBTEX = 0
Local  Char    TEX         : TEX   = ""
Local  Char    WADR(GLONADR)
Local  Char    WTIT(30)

GSINTBID = ""
SAVGOBJET=GOBJET
Call SAVBOUT From GESECRAN
GOBJET = 0
LADR = ""
WTIT = mess(27,198,1)+" "+mess(LTYP,203,1)
#-----
If clalev([F:BPA1]) = 0 Local File BPADDRESS [BPA1] : Endif
GSINTBID = mess(LTYP,203,1)
Local Mask BPAW [BPAW]
Local Dlgbox Mask [BPAW]
&        Button mess(64,123,1), mess(5,123,1)
&        With left$(mess(64,123,1),1), left$(mess(5,123,1),1)
&        Coded GSTAOK, GSTAFIN
&        Titled WTIT As [BPAW]
Raz [M:BPAW]
Boxact [BPAW]
[M:BPAW]BPATYP    = LTYP
[M:BPAW]BPANUM    = LNUM
[M:BPAW]BPANAM(0) = LNAM(0)
[M:BPAW]BPANAM(1) = LNAM(1)
[M:BPAW]BASPAG1    = 0
Filter [BPA1] Where BPATYP = LTYP & BPANUM = LNUM
&             Order By Key BPA0
For [BPA1]
  If [M:BPAW]BASPAG1 < dim([M:BPAW]BPAADD)-1
    [M:BPAW]BPAADD([M:BPAW]BASPAG1) = [F:BPA1]BPAADD
    [M:BPAW]BPADES([M:BPAW]BASPAG1) = [F:BPA1]BPADES
    [M:BPAW]BASPAG1 += 1
  Endif
Next
Filter [BPA1]
nolign = 1

Affzo [M:BPAW]

CHAINE = "TA"
ETABOU(GVALI)=1 : ETABOU(GABAN)=1 : # Ok et Abandon
Call SETBOUT(ETABOU) From GESECRAN

$SELADR1
GTABCONS = 1
Boxinp [BPAW] Using WREP
Case WREP
  When GSTAOK,  GSTARET : LADR = [M:BPAW]BPAADD(nolign-1) : Goto SELADR2
  When GSTAESC, GSTAFIN : LADR="" : Goto SELADR2
  When Default
Endcase
Goto SELADR1

$SELADR2
GTABCONS = 0
GSINTBID = ""
Boxclr [BPAW]

Close Inpbox [BPAW]
Close Local File [BPA1]

Call RESTBOUT From GESECRAN
GOBJET=SAVGOBJET
End

###########################################################
#
# Selection d'un contact
#
# En entrée
# LTYP = Type d'adresse (menu 203)
# LNUM = Numéro tiers / site / société /....
# LNAM = Nom ou raison sociale sur 2 lignes
#
# Sortie
# LCNT = Contact sélectionné (vide si pas de sélection)
#
###########################################################
Subprog SELCNT(LTYP,LNUM,LNAM,LCNT)
Variable Integer LTYP
Variable Char    LNUM
Variable Char    LNAM
Variable Char    LCNT
#-----
Local  Integer I, WREP, ETABOU(1..GNBBOU), SAVGOBJET
Local  Char    CHAINE
Local  Char    WTIT(30)

GSINTBID = ""
SAVGOBJET=GOBJET
Call SAVBOUT From GESECRAN
GOBJET = 0
LADR = ""
WTIT = mess(183,197,1)+" "+mess(LTYP,203,1)
#-----
If clalev([F:CNT]) = 0 Local File CONTACT    [CNT] : Endif
If clalev([F:BPA]) = 0 Local File BPADDRESS  [BPA] : Endif
If clalev([F:TCY]) = 0 Local File TABCOUNTRY [TCY] : Endif
If clalev([F:AIN]) = 0 Local File CONTACTCRM [AIN] : Endif

Local Mask CNTW [CNTW]
Local Dlgbox Mask [CNTW]
&        Button mess(64,123,1), mess(5,123,1)
&        With left$(mess(64,123,1),1), left$(mess(5,123,1),1)
&        Coded GSTAOK, GSTAFIN
&        Titled WTIT As [CNTW]
Raz [M:CNTW]
Boxact [CNTW]
[M:CNTW]BPANUM    = LNUM
[M:CNTW]BPANAM(0) = LNAM(0)
#[M:CNTW]BPANAM(1) = LNAM(1)
[M:CNTW]BASPAG1    = 0
Filter [CNT] Where BPATYP = LTYP & BPANUM = LNUM
&             Order By Key CNT0
For [CNT]
  If [M:CNTW]BASPAG1 < dim([M:CNTW]CNTNAM)-1
    Read [F:AIN]AIN0=[F:CNT]CCNCRM
    [M:CNTW]CNTNAM([M:CNTW]BASPAG1) = [F:AIN]CNTLNA
    [M:CNTW]BASPAG1 += 1
  Endif
Next
Filter [CNT]
nolign = 1

Affzo [M:CNTW]

CHAINE = "TA"
ETABOU(GVALI)=1 : ETABOU(GABAN)=1 : # Ok et Abandon
Call SETBOUT(ETABOU) From GESECRAN

$SELCNT1
GTABCONS = 1
Boxinp [CNTW] Using WREP
Case WREP
  When GSTAOK,  GSTARET : LCNT = [M:CNTW]CNTNAM(nolign-1) : Goto SELCNT2
  When GSTAESC, GSTAFIN : LCNT="" : Goto SELCNT2
  When Default
Endcase
Goto SELCNT1

$SELCNT2
GTABCONS = 0
Boxclr [CNTW]

Close Inpbox [CNTW]
#Close Local File [CNT]

Call RESTBOUT From GESECRAN
GOBJET=SAVGOBJET
End

########################################################################
# CHOIXM : S/P d'affichage d'un message                   MBT 27/03/98 #
#          avec choix multiple de boutons (jusqu'ŕ 5)                  #
#----------------------------------------------------------------------#
# Subprog CHOIXM (BOUTONS,TEXTE,LISTE,XREP)                            #
#   BOUTONS  : Table des textes boutons chargée ŕ partir de l'indice 1 #
#              Attention l'indice 0 existe mais vide                   #
#   TEXTE    : Texte du message ŕ afficher                             #
#   LISTE    : Liste des valeurs associées ŕ chaque bouton             #
#   XREP     : Valeur correspondant au bouton choisi                   #
#              Sert aussi ŕ indiquer le bouton par défaut              #
########################################################################
Subprog CHOIXM(BOUTONS,TEXTE,LISTE,XREP)
Value    Char    BOUTONS()()
Value    Char    TEXTE
Value    Char    LISTE
Variable Char    XREP
#----- Variables locales -----#
Local    Integer NBCHX : NBCHX=len(LISTE)
Local    Integer WREP, ETABOU(1..GNBBOU), SAVGOBJET
#-----------------------------#
SAVGOBJET=GOBJET
Call SAVBOUT From GESECRAN
GOBJET=0
If NBCHX>2 ETABOU(GSPE2)=1 : Endif
If NBCHX>3 ETABOU(GSPE3)=1 : Endif
If NBCHX>4 ETABOU(GSPE4)=1 : Endif
#----- Déclaration et affichage de la fenętre -----#
Local Mask  CHOIX [CHX]
Case NBCHX
  When 2 : Local Mesbox Mask  [CHX]
&                  Button BOUTONS(1), BOUTONS(2)
&                  With left$(BOUTONS(1),1), left$(BOUTONS(2),1)
&                  Coded GSTAOK, GSTABOU+1
&                  Titled mess(25,198,1) As [CHX]
  When 3 : Local Mesbox Mask  [CHX]
&                  Button BOUTONS(1), BOUTONS(2), BOUTONS(3)
&                  With left$(BOUTONS(1),1), left$(BOUTONS(2),1), left$(BOUTONS(3),1)
&                  Coded GSTAOK, GSTABOU+1, GSTABOU+2
&                  Titled mess(25,198,1) As [CHX]
  When 4 : Local Mesbox Mask  [CHX]
&                  Button BOUTONS(1), BOUTONS(2), BOUTONS(3), BOUTONS(4)
&                  With left$(BOUTONS(1),1), left$(BOUTONS(2),1), left$(BOUTONS(3),1),
&                  left$(BOUTONS(4),1)
&                  Coded GSTAOK, GSTABOU+1, GSTABOU+2, GSTABOU+3
&              Titled mess(25,198,1) As [CHX]
  When 5 : Local Mesbox Mask  [CHX]
&                  Button BOUTONS(1), BOUTONS(2), BOUTONS(3), BOUTONS(4), BOUTONS(5)
&                  With left$(BOUTONS(1),1), left$(BOUTONS(2),1), left$(BOUTONS(3),1),
&                  left$(BOUTONS(4),1), left$(BOUTONS(5),1)
&                  Coded GSTAOK, GSTABOU+1, GSTABOU+2, GSTABOU+3, GSTABOU+4
&                  Titled mess(25,198,1) As [CHX]
  When Default
Endcase
Boxact [CHX]
[M:CHX]TEXTE =[L]TEXTE
Affzo [M:CHX]
ETABOU(GVALI)=1 : ETABOU(GSPE1)=1
Call SETBOUT(ETABOU) From GESECRAN
#----- Affichage des boutons et choix d'un bouton -----#
Boxinp [CHX] Using WREP
Case WREP
  When GSTAOK    : XREP =mid$(LISTE,1,1)
  When GSTABOU+1 : XREP =mid$(LISTE,2,1)
  When GSTABOU+2 : XREP =mid$(LISTE,3,1)
  When GSTABOU+3 : XREP =mid$(LISTE,4,1)
  When GSTABOU+4 : XREP =mid$(LISTE,5,1)
  When Default
Endcase
#----- Effacement et fermeture de la fenętre -----#
Boxclr [CHX]
Close Mesbox [CHX]
Close Local Mask [CHX]
Call RESTBOUT From GESECRAN
GOBJET=SAVGOBJET
End

##########################################################################
# PAVRCOLOR : S/P de test modification rubrique             MBT 21/07/99 #
#             pour mise en évidence par la colorisation                  #
# ---------------------------------------------------------------------- #
# Subprog PAVRCOLOR (ABREV,NOLIG,NOMZON)                                 #
#   ABREV  : Abréviation masque écran contenant les lignes d'avenant     #
#   NOLIG  : indice de la ligne active (nolign-1)                        #
#   NOMZON : Nom de la zone courante                                     #
#                                                                        #
# Attention : Ce S/P est appelé par une action "Avant_zone"              #
##########################################################################
Subprog PAVRCOLOR(ABREV,NOLIG,NOMZON)
Value    Char    ABREV
Value    Integer NOLIG
Value    Char    NOMZON
pcolor=GCOUL(0)   : # Noir
#--- Pas de colorisation si derničre ligne ---#
If NOLIG+1>=evalue("[M:"+ABREV+"]NBLIG") End : Endif
#--- Si valeur rubrique différente de la ligne suivante alors affichage spécial ---#
If evalue("[M:"+ABREV+"]"+NOMZON+"(NOLIG)")<>evalue("[M:"+ABREV+"]"+NOMZON+"(NOLIG+1)")
  pcolor=GCOUL(1) : # Rouge
Endif
End

##########################################################################
# REVCHGASY : S/P de modification du style d'un champs      LD 10/03/06  #
# ---------------------------------------------------------------------- #
# Subprog REVCHGASY (ABREV,NOLIG,NOMZON,STYLE)                           #
#   ABREV  : Abréviation masque écran contenant les lignes d'avenant     #
#   NOLIG  : indice de la ligne active (nolign-1)                        #
#   NOMZON : Nom de la zone courante                                     #
#   STYLE  : Style                                                       #
#                                                                        #
# Attention : Ce S/P est appelé par une action "Avant_zone"              #
#             Il est appelé en gestion des avenants vente/achat          #
##########################################################################
Subprog REVCHGASY (ABREV,NOLIG,NOMZON, STYLE)
Value    Char    ABREV
Value    Integer NOLIG
Value    Char    NOMZON
Value    Char    STYLE

#--- Pas de colorisation si derničre ligne ---#
If NOLIG+1>=evalue("[M:"+ABREV+"]NBLIG") End : Endif
#--- Si valeur rubrique différente de la ligne suivante alors affichage spécial ---#
If evalue("[M:"+ABREV+"]"+NOMZON+"(NOLIG)")<>evalue("[M:"+ABREV+"]"+NOMZON+"(NOLIG+1)")
    Chgstl ="[M:"+ABREV+"]"+NOMZON+"(NOLIG)" With STYLE
#Else
    #Chgstl ="[M:"+ABREV+"]"+NOMZON+"(NOLIG)" With ""
Endif
End
#######################################################################
# MEMO de Date : si date debut type donnée DDB                        #
#                si date fin   type donnée DDF                        #
#                                                                     #
# Subprog MEMODEB (VALEUR)  memorisation date debut                   #
# Subprog MEMOFIN (VALEUR)  memorisation date fin                     #
# Subprog INITDDEB (VALEUR)  initialisation date debut                #
# Subprog INITDFIN (VALEUR)  initialisation date fin                  #
#                                                                     #
#######################################################################

Subprog MEMODEB(VALEUR)
Variable Date VALEUR
If dim(GMEMODDEB)<0
#  Global Date GMEMODDEB
   GMEMODDEB = [0/0/0]
Endif
GMEMODDEB=VALEUR
Call MESSAGE(mess(201,100,1)) From GESECRAN
End
Subprog MEMOFIN(VALEUR)
Variable Date VALEUR
If dim(GMEMODFIN)<0
#  Global Date GMEMODFIN
   GMEMODFIN = [0/0/0]
Endif

GMEMODFIN=VALEUR
Call MESSAGE(mess(201,100,1)) From GESECRAN
End

Subprog INITDFIN(VALEUR)
Variable Date VALEUR
If dim(GMEMODFIN)>0
  VALEUR=GMEMODFIN
Endif
End
Subprog INITDDEB(VALEUR)
Variable Date VALEUR
If dim(GMEMODDEB)>0
  VALEUR=GMEMODDEB
Endif
End
