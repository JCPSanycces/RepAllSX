#         For [TRA]TRA0 Where VAT=[F:TVT]VAT & find(CPY,"",GSOCIETE)
#            If [F:TRA]VATRAT=0
#               WEXO=0
#            Else
#               WEXO=1 : Break
#            Endif
#         Next
#         If WEXO=0 Break Endif
#      Next
#      If WEXO=0
#         # Taxe ŕ taux nul trouvée
#         [L]VAT(0)=[F:TVT]VAT
#      Else
#         # Taxe exo
#         [L]VAT(0)=GEXETAX
#      Endif
#   Endif
#Endif
End


#############################################################################
# ALIVATCOD : S/P d'alimentation des codes taxes v6 (ex v150)      MBT 2005 #
# ------------------------------------------------------------------------- #
# Paramčtres en entrée :                                                    #
#   BPCBPS  : Type de tiers                                                 #
#               1 = Client                                                  #
#               2 = Fournisseur                                             #
#   TIERS   : Numéro du tiers (client ou fournisseur)                       #
#   REFART  : Référence article                                             #
#   ABREV   : Abréviation du masque ou du fichier                           #
#   NOLIG   : indice de la ligne en cours (nolign-1)                        #
#############################################################################
Subprog ALIVATCOD(BPCBPS,TIERS,REFART,ABREV,NOLIG)
Value    Integer BPCBPS
Value    Char    TIERS
Value    Char    REFART
Value    Char    ABREV
Value    Integer NOLIG
#-----
Local    Integer SAV_NOLIGN : SAV_NOLIGN=nolign
Local    Integer TRAIT
# Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
#If func AFNC.ACTIV("PTX")
If func TRTX3.ACTIV_PTX
  Local Char TAXES(GLONVAT)(7) : Raz [L]TAXES : [L]TRAIT=3
Else
  Local Char TAXES(GLONVAT)(3) : Raz [L]TAXES : [L]TRAIT=1
Endif
Gosub TRT_RECHVATCOD
Case ABREV
  When "PSH1"
    [M:PSH1]VAT1(NOLIG)=[L]TAXES(0)
    [M:PSH1]VAT2(NOLIG)=[L]TAXES(1)
    [M:PSH1]VAT3(NOLIG)=[L]TAXES(2)
    # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
    #If func AFNC.ACTIV("PTX")
    If func TRTX3.ACTIV_PTX
      If dim([M:PSH1]TAXRCP)>0  [M:PSH1]TAXRCP(NOLIG) =[L]TAXES(3) : Endif
      If dim([M:PSH1]TAXISS)>0  [M:PSH1]TAXISS(NOLIG) =[L]TAXES(4) : Endif
      If dim([M:PSH1]TAXOTH1)>0 [M:PSH1]TAXOTH1(NOLIG)=[L]TAXES(5) : Endif
      If dim([M:PSH1]TAXOTH2)>0 [M:PSH1]TAXOTH2(NOLIG)=[L]TAXES(6) : Endif
    Endif
  When "PSD"
    [F:PSD]VAT(0)=[L]TAXES(0)
    [F:PSD]VAT(1)=[L]TAXES(1)
    [F:PSD]VAT(2)=[L]TAXES(2)
    # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
    #If func AFNC.ACTIV("PTX")
    If func TRTX3.ACTIV_PTX
      [F:PSD]TAXRCP =[L]TAXES(3)
      [F:PSD]TAXISS =[L]TAXES(4)
      [F:PSD]TAXOTH1=[L]TAXES(5)
      [F:PSD]TAXOTH2=[L]TAXES(6)
    Endif
  When "POP"
    [F:POP]VAT(0)=[L]TAXES(0)
    [F:POP]VAT(1)=[L]TAXES(1)
    [F:POP]VAT(2)=[L]TAXES(2)
    # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
    #If func AFNC.ACTIV("PTX")
    If func TRTX3.ACTIV_PTX
      [F:POP]TAXRCP =[L]TAXES(3)
      [F:POP]TAXISS =[L]TAXES(4)
      [F:POP]TAXOTH1=[L]TAXES(5)
      [F:POP]TAXOTH2=[L]TAXES(6)
    Endif
  When "POI1"
    # Issue 81607 - 2012-04-19 by SR
    # Issue 91212 - 2013-07-25 by SR : Si pas gestion DA , on récupčre toujours
    If [M:POI1]VAT1(NOLIG) = "" | GFONCTION <> "GESPSH": [M:POI1]VAT1(NOLIG)=[L]TAXES(0) : Endif
    If [M:POI1]VAT2(NOLIG) = "" | GFONCTION <> "GESPSH": [M:POI1]VAT2(NOLIG)=[L]TAXES(1) : Endif
    If [M:POI1]VAT3(NOLIG) = "" | GFONCTION <> "GESPSH": [M:POI1]VAT3(NOLIG)=[L]TAXES(2) : Endif
    # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
    #If func AFNC.ACTIV("PTX")
    If func TRTX3.ACTIV_PTX
      # Issue 87670 - 2013-01-31 by MUARN : contrôle champs non renseignés
      If (dim([M:POI1]TAXRCP)>0  & [M:POI1]TAXRCP="")  [M:POI1]TAXRCP(NOLIG) =[L]TAXES(3) : Endif
      If (dim([M:POI1]TAXISS)>0  & [M:POI1]TAXISS="")  [M:POI1]TAXISS(NOLIG) =[L]TAXES(4) : Endif
      If (dim([M:POI1]TAXOTH1)>0 & [M:POI1]TAXOTH1="") [M:POI1]TAXOTH1(NOLIG)=[L]TAXES(5) : Endif
      If (dim([M:POI1]TAXOTH2)>0 & [M:POI1]TAXOTH2="") [M:POI1]TAXOTH2(NOLIG)=[L]TAXES(6) : Endif
    Endif
  When "POH2"
    [M:POH2]VAT1(NOLIG)=[L]TAXES(0)
    [M:POH2]VAT2(NOLIG)=[L]TAXES(1)
    [M:POH2]VAT3(NOLIG)=[L]TAXES(2)
    # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
    #If func AFNC.ACTIV("PTX")
    If func TRTX3.ACTIV_PTX
      If dim([M:POH2]TAXRCP)>0  [M:POH2]TAXRCP(NOLIG) =[L]TAXES(3) : Endif
      If dim([M:POH2]TAXISS)>0  [M:POH2]TAXISS(NOLIG) =[L]TAXES(4) : Endif
      If dim([M:POH2]TAXOTH1)>0 [M:POH2]TAXOTH1(NOLIG)=[L]TAXES(5) : Endif
      If dim([M:POH2]TAXOTH2)>0 [M:POH2]TAXOTH2(NOLIG)=[L]TAXES(6) : Endif
    Endif
  When "POC2"
    [M:POC2]VAT(0) =[L]TAXES(0)
    [M:POC2]VAT(1) =[L]TAXES(1)
    [M:POC2]VAT(2) =[L]TAXES(2)
    # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
    #If func AFNC.ACTIV("PTX")
    If func TRTX3.ACTIV_PTX
      If dim([M:POC2]TAXRCP)>0  [M:POC2]TAXRCP =[L]TAXES(3) : Endif
      If dim([M:POC2]TAXISS)>0  [M:POC2]TAXISS =[L]TAXES(4) : Endif
      If dim([M:POC2]TAXOTH1)>0 [M:POC2]TAXOTH1=[L]TAXES(5) : Endif
      If dim([M:POC2]TAXOTH2)>0 [M:POC2]TAXOTH2=[L]TAXES(6) : Endif
    Endif
  When "PTH1"
    [M:PTH1]VAT1(NOLIG)=[L]TAXES(0)
    [M:PTH1]VAT2(NOLIG)=[L]TAXES(1)
    [M:PTH1]VAT3(NOLIG)=[L]TAXES(2)
    # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
    #If func AFNC.ACTIV("PTX")
    If func TRTX3.ACTIV_PTX
      If dim([M:PTH1]TAXRCP)>0  [M:PTH1]TAXRCP(NOLIG) =[L]TAXES(3) : Endif
      If dim([M:PTH1]TAXISS)>0  [M:PTH1]TAXISS(NOLIG) =[L]TAXES(4) : Endif
      If dim([M:PTH1]TAXOTH1)>0 [M:PTH1]TAXOTH1(NOLIG)=[L]TAXES(5) : Endif
      If dim([M:PTH1]TAXOTH2)>0 [M:PTH1]TAXOTH2(NOLIG)=[L]TAXES(6) : Endif
    Endif
  When "PNH1"
    [M:PNH1]VAT1(NOLIG)=[L]TAXES(0)
    [M:PNH1]VAT2(NOLIG)=[L]TAXES(1)
    [M:PNH1]VAT3(NOLIG)=[L]TAXES(2)
    # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
    #If func AFNC.ACTIV("PTX")
    If func TRTX3.ACTIV_PTX
      If dim([M:PNH1]TAXRCP)>0  [M:PNH1]TAXRCP(NOLIG) =[L]TAXES(3) : Endif
      If dim([M:PNH1]TAXISS)>0  [M:PNH1]TAXISS(NOLIG) =[L]TAXES(4) : Endif
      If dim([M:PNH1]TAXOTH1)>0 [M:PNH1]TAXOTH1(NOLIG)=[L]TAXES(5) : Endif
      If dim([M:PNH1]TAXOTH2)>0 [M:PNH1]TAXOTH2(NOLIG)=[L]TAXES(6) : Endif
    Endif
  When "PIH3"
    [M:PIH3]VAT1(NOLIG)=[L]TAXES(0)
    [M:PIH3]VAT2(NOLIG)=[L]TAXES(1)
    [M:PIH3]VAT3(NOLIG)=[L]TAXES(2)
    # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
    #If func AFNC.ACTIV("PTX")
    If func TRTX3.ACTIV_PTX
      If dim([M:PIH3]TAXRCP)>0  [M:PIH3]TAXRCP(NOLIG) =[L]TAXES(3) : Endif
      If dim([M:PIH3]TAXISS)>0  [M:PIH3]TAXISS(NOLIG) =[L]TAXES(4) : Endif
      If dim([M:PIH3]TAXOTH1)>0 [M:PIH3]TAXOTH1(NOLIG)=[L]TAXES(5) : Endif
      If dim([M:PIH3]TAXOTH2)>0 [M:PIH3]TAXOTH2(NOLIG)=[L]TAXES(6) : Endif
    Endif
Endcase
nolign=SAV_NOLIGN
End

#############################################################################
# ALIVAT    : S/P de recherche d'un code taxe v6 (ex v150)       LD 2008    #
#             Appelé en modification d'un niveau de taxe dans les ventes    #
#             Si 1čre taxe, le code taxe doit ętre renseigné                #
# ------------------------------------------------------------------------- #
# Paramčtres en entrée :                                                    #
#   VACITM  : Niveau de taxe                                                #
#   TRAIT   : Code traitement                                               #
#               1 = Taxes classiques ligne (TVA + parafiscales + spéciales) #
#               11= Taxe classique ligne 1čre taxe (TVA)                    #
#               12= Taxe classique ligne 2čme taxe                          #
#               13= Taxe classique ligne 3čme taxe                          #
#               2 = Autres taxes (Provinciales + globales)                  #
#               3 = Toutes les taxes                                        #
#   BPCBPS  : Type de tiers                                                 #
#               1 = Client                                                  #
#               2 = Fournisseur                                             #
#   TIERS   : Numéro du tiers (client ou fournisseur)                       #
#   REFART  : Référence article                                             #
#   ABREV   : Abréviation du masque ou du fichier                           #
#   NOLIG   : indice de la ligne en cours (nolign-1)                        #
# ------------------------------------------------------------------------- #
# Paramčtres en sortie :                                                    #
#   VAT     : Code taxe                                                     #
#############################################################################
Subprog ALIVAT(VACITM,TRAIT,BPCBPS,TIERS,REFART,ABREV,NOLIG,VAT)
Value    Char    VACITM
Value    Integer TRAIT
Value    Integer BPCBPS
Value    Char    TIERS
Value    Char    REFART
Value    Char    ABREV
Value    Integer NOLIG
Variable Char    VAT()
#-----
# Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
#If func AFNC.ACTIV("PTX")
If func TRTX3.ACTIV_PTX
  Local Char TAXES(GLONVAT)(7) : Raz [L]TAXES
Else
  Local Char TAXES(GLONVAT)(3) : Raz [L]TAXES
Endif
Local Integer SAV_NOLIGN : SAV_NOLIGN=nolign
If NOLIG>=0
    Assign "[M:"+ABREV+"]VACITM"+num$(TRAIT-10)+"("+num$(NOLIG)+")" With [L]VACITM
Else
    Assign "[M:"+ABREV+"]VACITM"+num$(TRAIT-10) With [L]VACITM
Endif
Gosub TRT_RECHVATCOD
nolign=SAV_NOLIGN

If TAXES(TRAIT-11)="" & TRAIT=11
    # 1čre taxe obligatoire : Aucune rčgle de taxes ne s'applique
    GMESSAGE=mess(331,192,1) : mkstat=2 : End
Endif

VAT=TAXES(TRAIT-11)
End


#############################################################################
# RECHVATCOD : S/P de recherche des codes taxes v6 (ex v150)       MBT 2005 #
# ------------------------------------------------------------------------- #
# Paramčtres en entrée :                                                    #
#   TRAIT   : Code traitement                                               #
#               1 = Taxes classiques ligne (TVA + parafiscales + spéciales) #
#               11= Taxe classique ligne 1čre taxe (TVA)                    #
#               12= Taxe classique ligne 2čme taxe                          #
#               13= Taxe classique ligne 3čme taxe                          #
#               2 = Autres taxes (Provinciales + globales)                  #
#               3 = Toutes les taxes                                        #
#   BPCBPS  : Type de tiers                                                 #
#               1 = Client                                                  #
#               2 = Fournisseur                                             #
#   TIERS   : Numéro du tiers (client ou fournisseur)                       #
#   REFART  : Référence article                                             #
#   ABREV   : Abréviation du masque ou du fichier                           #
#   NOLIG   : indice de la ligne en cours (nolign-1)                        #
# ------------------------------------------------------------------------- #
# Paramčtres en sortie :                                                    #
#   TAXES(0..) : Codes taxe                                                 #
#############################################################################
Subprog RECHVATCOD(TRAIT,BPCBPS,TIERS,REFART,ABREV,NOLIG,TAXES)
Value    Integer TRAIT
Value    Integer BPCBPS
Value    Char    TIERS
Value    Char    REFART
Value    Char    ABREV
Value    Integer NOLIG
Variable Char    TAXES()(0..)
#-----
Local Integer SAV_NOLIGN : SAV_NOLIGN=nolign
Gosub TRT_RECHVATCOD
nolign=SAV_NOLIGN
End


#############################################################################
# RECHVATFOOT : S/P de recherche du code taxe de l'élément de facturation   #
# ------------------------------------------------------------------------- #
# Paramčtres en entrée :                                                    #
#   BPCBPS  : Type de tiers                                                 #
#               1 = Client                                                  #
#               2 = Fournisseur                                             #
#   TIERS   : Numéro du tiers (client ou fournisseur)                       #
#   DTANUM  : Numéro de l'élément de facturation                            #
#   ABREV   : Abréviation du masque ou du fichier                           #
# ------------------------------------------------------------------------- #
# Paramčtres en sortie :                                                    #
#   TAXES   : Code taxe                                                     #
#############################################################################
Subprog RECHVATFOOT(BPCBPS,TIERS,DTANUM,ABREV,TAXES)
Value    Integer BPCBPS
Value    Char    TIERS
Value    Integer DTANUM
Value    Char    ABREV
Variable Char    TAXES()(0..)
#-----
Local Integer SAV_NOLIGN      : SAV_NOLIGN=nolign
Local Integer TRAIT           : TRAIT=11
Local Char    REFART(GLONITM) : REFART=""
Local Integer NOLIG           : NOLIG=0
#-----
Gosub TRT_RECHVATCOD
If TAXES=""  TAXES=GEXETAX : Endif : # Code taxe exonéré par défaut !
nolign=SAV_NOLIGN
End


#---------------------------------------------------------#
# Traitement de la recherche des codes taxes v6 (ex v150) #
#---------------------------------------------------------#
$TRT_RECHVATCOD
Local Integer I
#----- Variables locales pour le S/P ALITLK -----#
Local Date    WDAT
Local Char    WCUR(GLONCUR), WVACITM(GLONTVI)(3), WSATRCP(GLONSAT), WSATISS(GLONSAT)
Local Integer WCHGTYP,       WSTAT
Local Decimal COEFDEVISE,    WQTY
Local Char    WEXPRESSION(250)
Local Char    WEXPRESSION2(250) :#--CPO 80360
#-----
If !clalev([F:CPY])  Local File COMPANY [CPY] : Endif : #
If !clalev([F:TLK])  Local File TAXLINK [TLK] : Endif : # Table Calcul base calcul taxe (link)
If !clalev([F:TVC])  Local File TABVAC  [TVC] : Endif : # Table détermination des taxes
If !clalev([F:AGC])  Local File AGRPCPY [AGC] : Endif : # Table Groupes de sociétés
If !clalev([F:TVT])  Local File TABVAT  [TVT] : Endif : # Table des taxes #--CPO 106872

Local Integer WSTAT      :#--CPO 71937 19.04.2013
Local Char WMESSA(250)   :#--CPO 71937 19.04.2013
#--CPO 106872 S'assurer que la taxe ramenée (valable dans le contexte de la soc courante)
#--est bien du type de la détermination paramétrée dans GESTVC
Local Char    WDOCCURLEG(GLONADI)
Local Integer WOK_CTX_VAT
#--/

#-- X3Suivi 74439 : Point d'entree pour détermination du code taxe --#
#-- Ce point d'entrée peut alimenter TAXES(0) ŕ TAXES(2) et dans ce cas doit retourner GPE=1 --#
#CHECK IGNORE_BEGIN
Raz GPE
GPOINT="ALIVATCOD" : Gosub ENTREE From EXEFNC
If GPE=1 : Return : Endif
#CHECK IGNORE_END BEGIN

#-----
Raz I, TAXES
COEFDEVISE=1
#----- Lecture de la société si nécessaire -----#
If [F:CPY]CPY<>GSOCIETE
  Read [CPY] CPY0=GSOCIETE : If fstat  Raz [F:CPY] : Endif
Endif
#----- Lecture du tiers si nécessaire -----#
If [F:BPR]BPRNUM<>TIERS
  Read [BPR] BPR0=TIERS    : If fstat  Raz [F:BPR] : Endif
Endif
#----- Lecture du client si nécessaire -----#
If BPCBPS=1 & [F:BPC]BPCNUM<>TIERS
  Read [BPC] BPC0=TIERS
  If !fstat
    #----- Si code multi-sociétés actif -----#
    #If func AFNC.ACTIV("MUL")
    #  Call LECTURE ("BPC",GSOCIETE) From WWCPY
    #Endif
    #-----
  Else
    Raz [F:BPC]
  Endif
Endif
#----- Lecture du fournisseur si nécessaire -----#
If BPCBPS=2 & [F:BPS]BPSNUM<>TIERS
  Read [BPS] BPS0=TIERS
  If !fstat
    #----- Si code multi-sociétés actif -----#
    #If func AFNC.ACTIV("MUL")
    #  Call LECTURE ("BPS",GSOCIETE) From WWCPY
    #Endif
    #-----
  Else
    Raz [F:BPS]
  Endif
Endif
#----- Lecture de l'article si nécessaire -----#
If REFART<>"" & [F:ITM]ITMREF<>REFART
  Read [ITM] ITM0=REFART
  If !fstat
    #----- Si code multi-sociétés actif -----#
    #If func AFNC.ACTIV("MUL")
    #  Call LECTURE ("ITM",GSOCIETE) From WWCPY
    #Endif
    #-----
  Else
    Raz [F:ITM]
  Endif
Endif
#----- Lecture de l'élément de facturation -----#
If dim(DTANUM)>0 & DTANUM<>0
  If BPCBPS=1
    If dim(GMIGRATION)>0 & dim(WNBSFI)>0        : # Dde 81811: Optimisation
       Local Integer WJ                         : # Dde 81811: Optimisation
       WJ=find(DTANUM,WSFINUM (0..WNBSFI))      : # Dde 81811: Optimisation
    Else                                        : # Dde 81811: Optimisation
        If !clalev([F:SFI])  Local File SFOOTINV [SFI] : Endif
        If [F:SFI]SFINUM<>DTANUM
          Read [SFI] SFI0=DTANUM : If fstat  Raz [F:SFI] : Endif
        Endif
    Endif                                       : # Dde 81811: Optimisation
  Elsif BPCBPS=2
    If !clalev([F:PFI])  Local File PFOOTINV [PFI] : Endif
    If [F:PFI]PFINUM<>DTANUM
      Read [PFI] PFI0=DTANUM : If fstat  Raz [F:PFI] : Endif
    Endif
  Endif
Endif
#----- Transclasses de base -----#
nolign=NOLIG+1
Raz [F:TLK]
[F:TLK]=[F:CPY]
[F:TLK]=[F:BPR]
If BPCBPS=1
  [F:TLK]MODULE=5     : # Bug 74842
  [F:TLK]=[F:BPC]
  If dim([F:BPC]AGTPCP)>0
    [F:TLK]AGTPCPBPR=[F:BPC]AGTPCP
  Else
    [F:TLK]AGTPCPBPR=2
  Endif
Endif
If BPCBPS=2
  [F:TLK]MODULE=6     : # Bug 74842
  [F:TLK]=[F:BPS]
  If dim([F:BPS]AGTPCP)>0
    [F:TLK]AGTPCPBPR=[F:BPS]AGTPCP
  Else
    [F:TLK]AGTPCPBPR=2
  Endif
Endif
If REFART<>""
  [F:TLK]=[F:ITM]
  [L]WVACITM(0)=[F:ITM]VACITM(0)
  [L]WVACITM(1)=[F:ITM]VACITM(1)
  [L]WVACITM(2)=[F:ITM]VACITM(2)
Endif
If dim(DTANUM)>0 & DTANUM<>0
  Raz [L]WVACITM
  If BPCBPS=1
    If dim(GMIGRATION)>0 & dim(WNBSFI)>0          : # Dde 81811 : Optimisation
       If WJ                                      : # Dde 81811 : Optimisation
            [L]WVACITM(0)=WSFIVACITM(WJ-1)        : # Dde 81811 : Optimisation
            [L]WVACITM(1)=WSFICLCVACITM(WJ-1)     : # Bug 82733 : Recherche code taxe lié au niveau de taxe sélection
       Else                                       : # Dde 81811 : Optimisation
            [L]WVACITM(0)=""                      : # Dde 81811 : Optimisation
            [L]WVACITM(1)=""                      : # Bug 82733 : Recherche code taxe lié au niveau de taxe sélection
       Endif                                      : # Dde 81811 : Optimisation
    Else
        [L]WVACITM(0)=[F:SFI]VACITM
        # Bug 82733 : Recherche code taxe lié au niveau de taxe sélection
        [L]WVACITM(1)=[F:SFI]CLCVACITM
    Endif                                         : # Dde 81811 : Optimisation
  Elsif BPCBPS=2
    [L]WVACITM(0)=[F:PFI]VACITM
  Endif
Endif
#-----
If dim([F:CPY]LEG)>0  [F:TLK]LEG=[F:CPY]LEG : Endif
[F:TLK]CPY      =GSOCIETE
[F:TLK]FCY      =GFINRSP
[F:TLK]AGTPCPCPY=[F:CPY]AGTPCP
#-----
[F:TLK]NBGRP=0
If dim(GMIGRATION)>0 & dim(NBAGC)>0             : # Dde 81811 : Optimisation
   Local Integer WJ                             : # Dde 81811 : Optimisation
   For WJ=0 To NBAGC-1                          : # Dde 81811 : Optimisation
      If WAGCCPY(WJ)=[F:TLK]CPY                 : # Dde 81811 : Optimisation
          [F:TLK]GRP([F:TLK]NBGRP)=WAGCGRP(WJ)  : # Dde 81811 : Optimisation
          [F:TLK]NBGRP+=1                       : # Dde 81811 : Optimisation
          If [F:TLK]NBGRP>98  Break : Endif     : # Dde 81811 : Optimisation
      Elsif WAGCCPY(WJ)>[F:TLK]CPY              : # Dde 81811 : Optimisation
           Break                                : # Dde 81811 : Optimisation
      Endif                                     : # Dde 81811 : Optimisation
   Next WJ                                      : # Dde 81811 : Optimisation
Else                                            : # Dde 81811 : Optimisation
    For [AGC] AGC1 Where CPY=[F:TLK]CPY
      [F:TLK]GRP([F:TLK]NBGRP)=[F:AGC]GRP
      [F:TLK]NBGRP+=1
      If [F:TLK]NBGRP>98  Break : Endif
    Next
Endif                                           : # Dde 81811 : Optimisation
#-----

Gosub ALITLK
[F:TLK]ITMREF=[F:ITM]ITMREF : # Peut ętre écrasé par un transclasse de ligne

# hcb 75926
Raz GPE
GPOINT="LECTVC" : Gosub ENTREE From EXEFNC
If GPE=1 : Return : Endif

If GCURLEG<>""
  WDOCCURLEG = GCURLEG
Elsif [F:CPY]LEG<>""
  WDOCCURLEG = [F:CPY]LEG
Elsif [F:TLK]LEG<>""
  WDOCCURLEG = [F:TLK]LEG
Endif
#--/CPO
#----- Alimentation codes taxes classiques ligne (TVA, parafiscales et spéciales) -----#
If find(TRAIT,1,11,12,13) | TRAIT=3
  #----- TVA -----#
  If find(TRAIT,1,11) | TRAIT=3
    I=0
    [F:TLK]VACITM=[L]WVACITM(0)
    Gosub SET_LCRITITMBPR #Fq75921-Gbn
    #--CPO 71937 19.04.2013 Déclinaison multi-lég
    #For [TVC] TVC2 Where VATTYP=1 & ENAFLG=2 & LEG<=[F:TLK]LEG & evalue(LCRITITMBPR)
    For [TVC] TVC2 Where VATTYP=1 & ENAFLG=2 & find(LEG,"",[F:TLK]LEG)>0 & evalue(LCRITITMBPR)
    #--/CPO
      #MAE, bg75444
      If [F:TVC]EXP1="" WEXPRESSION="1=1": Else WEXPRESSION=[F:TVC]EXP1 : Endif
      If [F:TVC]EXPTST=""  [F:TVC]EXPTST="1=1" : Endif #MAE, bg 75965
      #If [F:TVC]EXP2="" WEXPRESSION2="1=1": Else WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
      WEXPRESSION2="1=1"
      If dim([F:TVC]EXP2)>0 & [F:TVC]EXP2<>"" : WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
      If evalue([F:TVC]EXPTST) & evalue(WEXPRESSION) & evalue(WEXPRESSION2)       :#--CPO 80360
      #--CPO 71937 19.04.2013 Déclinaison multi-lég
      #TAXES(I)=[F:TVC]VAT : I+=1 : Break
        Call CTL_ML_CONSISTENCY("TVC", "NON", [F:TVC]COD, [F:TVC]LEG , [F:TLK]CPY, [F:TLK]FCY, [F:TLK]LEG, WSTAT, WMESSA) From TRTVENCTL
        If WSTAT=0
          #--CPO 106872
          #TAXES(I)=[F:TVC]VAT : I+=1 : Break
          WOK_CTX_VAT = [V]CST_AOK
          Gosub CTL_CTX_VAT
          If WOK_CTX_VAT=[V]CST_AOK
            TAXES(I)=[F:TVC]VAT : I+=1 : Break
          Endif
          #--/
        Endif
        #--/
      Endif
    Next
    # Bug 82733 : Recherche code taxe lié au niveau de taxe sélection
    If dim(DTANUM)>0 & DTANUM<>0 & BPCBPS=1 & [L]WVACITM(1)<>""
      I=1
      [F:TLK]VACITM=[L]WVACITM(1)
      Gosub SET_LCRITITMBPR
      #--CPO 71937 19.04.2013 Déclinaison multi-lég
      #For [TVC] TVC2 Where VATTYP=1 & ENAFLG=2 & LEG<=[F:TLK]LEG & evalue(LCRITITMBPR)
      For [TVC] TVC2 Where VATTYP=1 & ENAFLG=2 & find(LEG,"",[F:TLK]LEG)>0 & evalue(LCRITITMBPR)
        If [F:TVC]EXP1="" WEXPRESSION="1=1": Else WEXPRESSION=[F:TVC]EXP1 : Endif
        If [F:TVC]EXPTST=""  [F:TVC]EXPTST="1=1" : Endif
        WEXPRESSION2="1=1"
        If dim([F:TVC]EXP2)>0 & [F:TVC]EXP2<>"" : WEXPRESSION2=[F:TVC]EXP2 : Endif
        If evalue([F:TVC]EXPTST) & evalue(WEXPRESSION) & evalue(WEXPRESSION2)
          #--CPO 71937 19.04.2013 Déclinaison multi-lég
          #TAXES(I)=[F:TVC]VAT : I+=1 : Break
          Call CTL_ML_CONSISTENCY("TVC", "NON", [F:TVC]COD, [F:TVC]LEG , [F:TLK]CPY, [F:TLK]FCY, [F:TLK]LEG, WSTAT, WMESSA) From TRTVENCTL
          If WSTAT=0
            #--CPO 106872
            #TAXES(I)=[F:TVC]VAT : I+=1 : Break
            WOK_CTX_VAT = [V]CST_AOK
            Gosub CTL_CTX_VAT
            If WOK_CTX_VAT=[V]CST_AOK
              TAXES(I)=[F:TVC]VAT : I+=1 : Break
            Endif
            #--/
          Endif
          #--/
        Endif
      Next
    Endif
    # Bug 82733
  Endif
  #----- Parafiscale / Spéciale -----#
  If find(TRAIT,1,12) | TRAIT=3
    I=1
    [F:TLK]VACITM=[L]WVACITM(1)
    Gosub SET_LCRITITMBPR #Fq75921-Gbn
    #--CPO 71937 19.04.2013 Déclinaison multi-lég
    #For [TVC] TVC2 Where VATTYP>=2 & VATTYP<=3 & ENAFLG=2 & LEG<=[F:TLK]LEG & evalue(LCRITITMBPR)
    For [TVC] TVC2 Where VATTYP>=2 & VATTYP<=3 & ENAFLG=2 & find(LEG,"",[F:TLK]LEG)>0 & evalue(LCRITITMBPR)
      #MAE, bg 75444
      If [F:TVC]EXP1="" WEXPRESSION="1=1": Else WEXPRESSION=[F:TVC]EXP1 : Endif
      If [F:TVC]EXPTST=""  [F:TVC]EXPTST="1=1" : Endif #MAE, bg 75965
      #If [F:TVC]EXP2="" WEXPRESSION2="1=1": Else WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
      WEXPRESSION2="1=1"
      If dim([F:TVC]EXP2)>0 & [F:TVC]EXP2<>"" : WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
      If evalue([F:TVC]EXPTST) & evalue(WEXPRESSION) & evalue(WEXPRESSION2)       :#--CPO 80360
        #--CPO 71937 19.04.2013 Déclinaison multi-lég
        #TAXES(I)=[F:TVC]VAT : I+=1 : Break
        Call CTL_ML_CONSISTENCY("TVC", "NON", [F:TVC]COD, [F:TVC]LEG , [F:TLK]CPY, [F:TLK]FCY, [F:TLK]LEG, WSTAT, WMESSA) From TRTVENCTL
        If WSTAT=0
          #--CPO 106872
          #TAXES(I)=[F:TVC]VAT : I+=1 : Break
          WOK_CTX_VAT = [V]CST_AOK
          Gosub CTL_CTX_VAT
          If WOK_CTX_VAT=[V]CST_AOK
            TAXES(I)=[F:TVC]VAT : I+=1 : Break
          Endif
          #--/
        Endif
        #--/
      Endif
    Next
  Endif
  #----- Parafiscale / Spéciale -----#
  If find(TRAIT,1,13) | TRAIT=3
    I=2
    [F:TLK]VACITM=[L]WVACITM(2)
    Gosub SET_LCRITITMBPR #Fq75921-Gbn
    #--CPO 71937 19.04.2013 Déclinaison multi-lég
    #For [TVC] TVC2 Where VATTYP>=2 & VATTYP<=3 & ENAFLG=2 & LEG<=[F:TLK]LEG & evalue(LCRITITMBPR)
    For [TVC] TVC2 Where VATTYP>=2 & VATTYP<=3 & ENAFLG=2 & find(LEG,"",[F:TLK]LEG)>0 & evalue(LCRITITMBPR)
      #MAE, bg 75444
      If [F:TVC]EXP1="" WEXPRESSION="1=1": Else WEXPRESSION=[F:TVC]EXP1 : Endif
      If [F:TVC]EXPTST=""  [F:TVC]EXPTST="1=1" : Endif #MAE, bg 75965
      #If [F:TVC]EXP2="" WEXPRESSION2="1=1": Else WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
      WEXPRESSION2="1=1"
      If dim([F:TVC]EXP2)>0 & [F:TVC]EXP2<>"" : WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
      If evalue([F:TVC]EXPTST) & evalue(WEXPRESSION) & evalue(WEXPRESSION2)       :#--CPO 80360
        #--CPO 71937 19.04.2013 Déclinaison multi-lég
        #TAXES(I)=[F:TVC]VAT : I+=1 : Break
        Call CTL_ML_CONSISTENCY("TVC", "NON", [F:TVC]COD, [F:TVC]LEG , [F:TLK]CPY, [F:TLK]FCY, [F:TLK]LEG, WSTAT, WMESSA) From TRTVENCTL
        If WSTAT=0
          #--CPO 106872
          #TAXES(I)=[F:TVC]VAT : I+=1 : Break
          WOK_CTX_VAT = [V]CST_AOK
          Gosub CTL_CTX_VAT
          If WOK_CTX_VAT=[V]CST_AOK
            TAXES(I)=[F:TVC]VAT : I+=1 : Break
          Endif
          #--/
        Endif
        #--/
      Endif
    Next
  Endif
Endif
#----- Alimentation autres codes taxes (provinciales et globales) -----#
If TRAIT=2 | TRAIT=3
  [L]WSATRCP=[F:TLK]SATRCP
  [L]WSATISS=[F:TLK]SATISS
  [F:TLK]VACITM=[L]WVACITM(0)
  #----- Taxe provinciale entrée -----#
  If TRAIT=3  I=3 Else  I=0 : Endif
  [F:TLK]SATFLG=1
  [F:TLK]SATRCP=[L]WSATRCP
 #[F:TLK]SATISS=""
  Gosub SET_LCRITITMBPR #Fq75921-Gbn
  #--CPO 71937 19.04.2013 Déclinaison multi-lég
  #For [TVC] TVC2 Where VATTYP=4 & ENAFLG=2 & LEG<=[F:TLK]LEG & evalue(LCRITITMBPR)
  For [TVC] TVC2 Where VATTYP=4 & ENAFLG=2 & find(LEG,"",[F:TLK]LEG)>0 & evalue(LCRITITMBPR)
    #MAE, bg 75444
    If [F:TVC]EXP1="" WEXPRESSION="1=1": Else WEXPRESSION=[F:TVC]EXP1 : Endif
    If [F:TVC]EXPTST=""  [F:TVC]EXPTST="1=1" : Endif #MAE, bg 75965
    #If [F:TVC]EXP2="" WEXPRESSION2="1=1": Else WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
    WEXPRESSION2="1=1"
    If dim([F:TVC]EXP2)>0 & [F:TVC]EXP2<>"" : WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
    If evalue([F:TVC]EXPTST) & evalue(WEXPRESSION) & evalue(WEXPRESSION2)       :#--CPO 80360
      #--CPO 71937 19.04.2013 Déclinaison multi-lég
      #TAXES(I)=[F:TVC]VAT : I+=1 : Break
      Call CTL_ML_CONSISTENCY("TVC", "NON", [F:TVC]COD, [F:TVC]LEG , [F:TLK]CPY, [F:TLK]FCY, [F:TLK]LEG, WSTAT, WMESSA) From TRTVENCTL
      If WSTAT=0
        #--CPO 106872
        #TAXES(I)=[F:TVC]VAT : I+=1 : Break
        WOK_CTX_VAT = [V]CST_AOK
        Gosub CTL_CTX_VAT
        If WOK_CTX_VAT=[V]CST_AOK
          TAXES(I)=[F:TVC]VAT : I+=1 : Break
        Endif
        #--/
      Endif
      #--/
    Endif
  Next
  #----- Taxe provinciale sortie -----#
  If TRAIT=3  I=4 Else  I=1 : Endif
  [F:TLK]SATFLG=2
 #[F:TLK]SATRCP=""
  [F:TLK]SATISS=[L]WSATISS
  #--CPO 71937 19.04.2013 Déclinaison multi-lég
  #For [TVC] TVC2 Where VATTYP=4 & ENAFLG=2 & LEG<=[F:TLK]LEG & evalue(LCRITITMBPR)
  For [TVC] TVC2 Where VATTYP=4 & ENAFLG=2 & find(LEG,"",[F:TLK]LEG)>0 & evalue(LCRITITMBPR)
    #MAE, bg 75444
    If [F:TVC]EXP1="" WEXPRESSION="1=1": Else WEXPRESSION=[F:TVC]EXP1 : Endif
    If [F:TVC]EXPTST=""  [F:TVC]EXPTST="1=1" : Endif #MAE, bg 75965
    #If [F:TVC]EXP2="" WEXPRESSION2="1=1": Else WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
    WEXPRESSION2="1=1"
    If dim([F:TVC]EXP2)>0 & [F:TVC]EXP2<>"" : WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
    If evalue([F:TVC]EXPTST) & evalue(WEXPRESSION) & !find([F:TVC]VAT,TAXES(0..I-1)) & evalue(WEXPRESSION2) :#--CPO 80360
      #--CPO 71937 19.04.2013 Déclinaison multi-lég
      #TAXES(I)=[F:TVC]VAT : I+=1 : Break
      Call CTL_ML_CONSISTENCY("TVC", "NON", [F:TVC]COD, [F:TVC]LEG , [F:TLK]CPY, [F:TLK]FCY, [F:TLK]LEG, WSTAT, WMESSA) From TRTVENCTL
      If WSTAT=0
        #--CPO 106872
        #TAXES(I)=[F:TVC]VAT : I+=1 : Break
        WOK_CTX_VAT = [V]CST_AOK
        Gosub CTL_CTX_VAT
        If WOK_CTX_VAT=[V]CST_AOK
          TAXES(I)=[F:TVC]VAT : I+=1 : Break
        Endif
        #--/
      Endif
      #--/
    Endif
  Next
  #----- Taxes provinciales globales ou autres -----#
  If TRAIT=3  I=5 Else  I=2 : Endif
  [F:TLK]SATFLG=3
  [F:TLK]SATRCP=[L]WSATRCP
  [F:TLK]SATISS=[L]WSATISS
  Gosub SET_LCRITITMBPR #Fq75921-Gbn
  #--CPO 71937 19.04.2013 Déclinaison multi-lég
  #For [TVC] TVC2 Where VATTYP=4 & ENAFLG=2 & LEG<=[F:TLK]LEG & evalue(LCRITITMBPR)
  For [TVC] TVC2 Where VATTYP=4 & ENAFLG=2 & find(LEG,"",[F:TLK]LEG)>0 & evalue(LCRITITMBPR)
    #MAE, bg 75444
    If [F:TVC]EXP1="" WEXPRESSION="1=1": Else WEXPRESSION=[F:TVC]EXP1 : Endif
    If [F:TVC]EXPTST=""  [F:TVC]EXPTST="1=1" : Endif #MAE, bg 75965
    #If [F:TVC]EXP2="" WEXPRESSION2="1=1": Else WEXPRESSION2=[F:TVC]EXP2 : Endif :#---CPO 80360
    WEXPRESSION2="1=1"
    If dim([F:TVC]EXP2)>0 & [F:TVC]EXP2<>"" : WEXPRESSION2=[F:TVC]EXP2 : Endif :#--CPO 80360
    If evalue([F:TVC]EXPTST) & evalue(WEXPRESSION) & !find([F:TVC]VAT,TAXES(0..I-1)) & evalue(WEXPRESSION2) :#--CPO 80360
      #--CPO 71937 19.04.2013 Déclinaison multi-lég
      #TAXES(I)=[F:TVC]VAT : I+=1
      #If I>=dim(TAXES)  Break : Endif
      Call CTL_ML_CONSISTENCY("TVC", "NON", [F:TVC]COD, [F:TVC]LEG , [F:TLK]CPY, [F:TLK]FCY, [F:TLK]LEG, WSTAT, WMESSA) From TRTVENCTL
      If WSTAT=0
        #--CPO 106872
        #TAXES(I)=[F:TVC]VAT : I+=1
        #If I>=dim(TAXES)  Break : Endif
        WOK_CTX_VAT = [V]CST_AOK
        Gosub CTL_CTX_VAT
        If WOK_CTX_VAT=[V]CST_AOK
          TAXES(I)=[F:TVC]VAT : I+=1
          If I>=dim(TAXES)  Break : Endif
        Endif
        #--/
      Endif
      #--/
    Endif
  Next
Endif
Return


########################################################################
# ALICLCAMT : Alimentation des montants de base calculs de taxe        #
#----------------------------------------------------------------------#
#                                                  LD - juillet 01     #
# En Entree ART       : Référence article                              #
#           WQTY      : Quantité                                       #
#           NOLIG     : Indice de la ligne dans le tableau             #
#                       ou -1 si alim depuis [F:]                      #
#           ABREV     : Abréviation masque ou fichier                  #
#                       SQH2:devis , SOH4:cde , SDH1:liv , SIH4:fac    #
#                                    SOP :cde   SDD :liv               #
#                       SCS1:trf inter-soc                             #
# En Sortie WCLCAMT1  : Base1 calcul taxe                              #
#           WCLCAMT2  : Base2 calcul taxe                              #
########################################################################
Subprog ALICLCAMT(ART,WQTY,NOLIG,ABREV,WCLCAMT1,WCLCAMT2)
Value    Char    ART
Value    Decimal WQTY
Value    Integer NOLIG
Value    Char    ABREV
Variable Decimal WCLCAMT1
Variable Decimal WCLCAMT2
#-----
Local    Libelle WTRT : WTRT=1 : # Avec 2 bases spéciales CLCAMT1 et CLCAMT2
Gosub TRT_ALICLCAMT
End


######################################################################
# ALICLCAMT2 : Alimentation des montants de base calculs de taxe     #
#------------------------------------------------------------------- #
# En Entrée ART     : Référence article               MBT 09/02/2010 #
#           WQTY    : Quantité                                       #
#           NOLIG   : Indice de la ligne dans le tableau             #
#                     ou -1 si alim depuis [F:]                      #
#           ABREV   : Abréviation masque ou fichier                  #
#                     SQH2:devis , SOH4:cde , SDH1:liv , SIH4:fac    #
#                                  SOP :cde   SDD :liv               #
#                     SCS1:trf inter-soc                             #
# En Sortie WCLCAMT : Bases 1 ŕ 7 calcul taxe                        #
######################################################################
Subprog ALICLCAMT2(ART,WQTY,NOLIG,ABREV,WCLCAMT)
Value    Char    ART
Value    Decimal WQTY
Value    Integer NOLIG
Value    Char    ABREV
Variable Decimal WCLCAMT(0..)
#-----
Local    Libelle WTRT : WTRT=2 : # Avec 7 bases spéciales CLCAMT(0..6)
Gosub TRT_ALICLCAMT
End


#########################################################################
# Traitement de l'alimentation des montants bases spéciales calcul taxe #
#########################################################################
$TRT_ALICLCAMT
#-----
# Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
#Local  Libelle  X : X=3+4*func AFNC.ACTIV("PTX")
Local  Libelle  X : X=3+4*func TRTX3.ACTIV_PTX
#-----
Local    Libelle ALICLCAMT_FLG : # Pour test dans ALITLK (Origine du Gosub)
#-----
Local    Integer TRAIT
Local    Char    VAT(GLONVAT)(X)
Local    Integer I
Local    Decimal WTAXBAS
Local    Date    WDAT
Local    Char    WCUR(GLONCUR),  WVACITM(GLONTVI)(3)
Local    Integer WCHGTYP, WSTAT, WVATBAS
Local    Decimal COEFDEVISE    : COEFDEVISE = 1 : # coef.conv. devise
# Issue 71937 - 2012-03-27 by SR
Local Integer  WRET
#-----
If WTRT=2  Raz WCLCAMT  Else  Raz WCLCAMT1, WCLCAMT2 : Endif
#-----
If !clalev([F:TFO])  Local File TABFOR [TFO] : Endif
If !clalev([F:TVT])  Local File TABVAT [TVT] : Endif
If !clalev([F:TCU])  Local File TABCUR [TCU] : Endif
#-----
Case ABREV
  When "CRM1", "CRM2", "CRM3", "CRM4", "CRM5", "CRM6"
    VAT (0) = [M:SPSW]VAT(0)
    VAT (1) = [M:SPSW]VAT(1)
    VAT (2) = [M:SPSW]VAT(2)
  When Default
    If NOLIG >= 0
      VAT (0) = evalue("[M:"+ABREV+"]VAT1(NOLIG)")
      VAT (1) = evalue("[M:"+ABREV+"]VAT2(NOLIG)")
      VAT (2) = evalue("[M:"+ABREV+"]VAT3(NOLIG)")
      If X>3 & evalue("dim([M:"+ABREV+"]TAXRCP(NOLIG))")>0
        VAT (3) = evalue("[M:"+ABREV+"]TAXRCP (NOLIG)")
        VAT (4) = evalue("[M:"+ABREV+"]TAXISS (NOLIG)")
        VAT (5) = evalue("[M:"+ABREV+"]TAXOTH1(NOLIG)")
        VAT (6) = evalue("[M:"+ABREV+"]TAXOTH2(NOLIG)")
      Endif
    Else
      VAT (0) = evalue("[F:"+ABREV+"]VAT(0)")
      VAT (1) = evalue("[F:"+ABREV+"]VAT(1)")
      VAT (2) = evalue("[F:"+ABREV+"]VAT(2)")
      If X>3 & evalue("dim([F:"+ABREV+"]TAXRCP)")>0
        VAT (3) = evalue("[F:"+ABREV+"]TAXRCP")
        VAT (4) = evalue("[F:"+ABREV+"]TAXISS")
        VAT (5) = evalue("[F:"+ABREV+"]TAXOTH1")
        VAT (6) = evalue("[F:"+ABREV+"]TAXOTH2")
      Endif
    Endif
Endcase
#-----
For I=0 To X-1
  # Issue 71937 - 2012-03-27 by SR : comment
  Call LEC_TVT_LEG(GCURLEG,VAT(I),WRET) From TRTLECLEG
  If WRET : Raz [F:TVT] : Endif
  #Read [TVT] TVT0=VAT(I)
  #If !fstat
  If !WRET
    #----- Si taxe avec formule de calcul -----#
    If [F:TVT]VATFOR <> ""
      Read [TFO] TFO0=1;[F:TVT]VATFOR
      If !fstat
        #-----
        If !clalev([F:ITM])  Local File ITMMASTER [ITM] : Endif
        If !clalev([F:ITS])  Local File ITMSALES  [ITS] : Endif
        If !clalev([F:TLK])  Local File TAXLINK   [TLK] : Endif
        #-----
        If (instr(1,[F:TFO]FORFOR,"ITM]") | instr (1,[F:TFO]FORFOR,"ITMWEI")) & [F:ITM]ITMREF<>ART
          Read [ITM] ITM0=ART : If fstat  Raz [F:ITM] : Endif
        Endif
        If instr (1,[F:TFO]FORFOR,"ITS]") & [F:ITS]ITMREF<>ART
          Read [ITS] ITS0=ART : If fstat  Raz [F:ITS] : Endif
        Endif
        #-----
        WVATBAS=[F:TVT]VATBAS : # Attention la classe [F:TVT] peut ętre altérée par l'ALITLK
        Gosub ALITLK
        #-----
        Onerrgo ERR_FORMULE
        #----- Chargement des 7 bases spéciales en fonction du rang de la taxe -----#
        If WTRT=2
          If WVATBAS>1
            WCLCAMT(I)=evalue([F:TFO]FORFOR)
            Call ARRDEV(WCLCAMT(I),WCUR) From TRTDIV
          Endif
        #----- Chargement bases spéciales 1 et 2 en fonction du paramétrage taxe -----#
        Else
          If WVATBAS=2
            WCLCAMT1=evalue([F:TFO]FORFOR)
            Call ARRDEV(WCLCAMT1,WCUR) From TRTDIV
          Else
            WCLCAMT2=evalue([F:TFO]FORFOR)
            Call ARRDEV(WCLCAMT2,WCUR) From TRTDIV
          Endif
        Endif
        #-----
        Onerrgo
      Endif
    Endif
  Endif
Next
Return

$ERR_FORMULE
WTAXBAS = 0
Call ECR_TRACE(mess(573,197,1)-[F:TFO]FORCOD-":"-mess(253,192,1),1) From GESECRAN
Resume


########################################################################
# ALIBASTAX : Alimentation des montants de base calculs de taxe        #
#----------------------------------------------------------------------#
#                                                  LD - mai 08         #
# En Entree TRAIT     : Code traitement                                #
#          1 = Taxes classiques ligne (TVA + parafiscales + spéciales) #
#          2 = Autres taxes (Provinciales + globales)                  #
#          3 = Toutes les taxes                                        #
#           NOLIG     : Indice de la ligne dans le tableau             #
#                      ou 0                                            #
#           ABREV     : Abréviation masque ou fichier                  #
#           WVAT      : Tableau des taxes                              #
# En Sortie WBASTAX   : Tableau des bases calculées                    #
########################################################################
Subprog ALIBASTAX(TRAIT, NOLIG, ABREV, WVAT, WBASTAX)
Value    Integer TRAIT
Value    Integer NOLIG
Value    Char    ABREV
Value    Char    WVAT
Variable Decimal WBASTAX
# Issue 71937 - 2012-03-27 by SR
Local    Integer WRET

#Variable Char    WVAT () (0..)
#Variable Decimal WBASTAX (0..)

Local    Libelle ALICLCAMT_FLG : # Pour test dans ALITLK (Origine du Gosub)
Local    Integer I, J
Local    Decimal WTAXBAS
Local    Date    WDAT
Local    Char    WCUR(GLONCUR),  WVACITM(GLONTVI)(3)
Local    Integer WCHGTYP, WSTAT, WVATBAS
Local    Decimal COEFDEVISE    : COEFDEVISE = 1 : # coef.conv. devise

If clalev([F:TFO]) = 0 Local File TABFOR [TFO] Endif
If clalev([F:TVT]) = 0 Local File TABVAT [TVT] Endif
If clalev([F:TCU]) = 0 Local File TABCUR [TCU] Endif

    # Issue 71937 - 2012-03-27 by SR : comment
    Call LEC_TVT_LEG(GCURLEG,WVAT,WRET) From TRTLECLEG
    If WRET : Raz [F:TVT] : Endif
    #Read [TVT]TVT0 = WVAT
    #If fstat = 0
    If WRET = 0
        WVATBAS=[F:TVT]VATBAS : # La classe [F:TVT] peut ętre altérée par l'ALITLK
        # Si taxe avec formule de calcul et no montant renseigné
        If [F:TVT]VATFOR <> ""
            Read [TFO]TFO0=1;[F:TVT]VATFOR
            If fstat = 0
                If clalev([F:TLK]) = 0 Local File TAXLINK [TLK] Endif
                Gosub ALITLK
                Onerrgo ERR_FORMULE
                WBASTAX = evalue([F:TFO]FORFOR)
                Call ARRDEV(WBASTAX, WCUR) From TRTDIV

                Onerrgo
            Endif
        Endif
    Endif
End


########################################################################
#----------------------------------------------------------------------#
# Pour la détermination des taxes provinciales                         #
# Chargement des provinces d'entrée/sortie                             #
#                                                                      #
# Appelé par ALITLK, Utilisé par les ventes                            #
#                                                                      #
#----------------------------------------------------------------------#
#                                                  LD - mai 08         #
# [F:TLK]SATISS : Province de sortie                                   #
# [F:TLK]SATRCP : Province d'entrée                                    #
########################################################################

$DECLARE_SAT
Local Char WSTOFCY(GLONFCY), WBPCORD(GLONBPC), WBPAADD(GLONADR)
Local Char WCTY(GLONCTY), WCRY(GLONCRY), WSAT(GLONSAT)
Return

$CHARG_SAT
# A voir : Faut-il les ouvrir ds les objets
If clalev([F:BPA]) = 0 Local File BPADDRESS  [BPA] : Endif

#----- Chargement province de sortie province adresse du site -----#
If [F:FCY]FCY<>WSTOFCY
    Read [FCY]FCY0=WSTOFCY
    If fstat  Raz [F:FCY] : Endif
Endif
If [F:BPA]BPATYP<>3 | [F:BPA]BPANUM<>WSTOFCY | [F:BPA]BPAADD<>[F:FCY]BPAADD
   Read [BPA]BPA0=3;WSTOFCY;[F:FCY]BPAADD
   If fstat  Raz [F:BPA] : Endif
Endif
[F:TLK]SATISS=[F:BPA]SAT
#----- Chargement province d'entrée province adresse livraison client -----#
If WCRY<>"" | WCTY<>""
    [F:TLK]SATRCP=WSAT
Else
    If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>WBPCORD | [F:BPA]BPAADD<>WBPAADD
        Read [BPA] BPA0=1;WBPCORD;WBPAADD
        If fstat  Raz [F:BPA] : Endif
    Endif
    [F:TLK]SATRCP=[F:BPA]SAT
Endif

Return

########################################################################
# ALITLK : Alimentation du fichier lien TAXLINK                        #
#         (utilisé pour le calcul des montants de base calcul taxe)    #
#----------------------------------------------------------------------#
#   ABREV  : Abréviation masque/fichier                                #
#               SCS1 = Trf inter-soc (objet SCS)                       #
#               SQH2 = Devis (objet SQH)                               #
#               SOH4 = Cdes (objet SOH)                                #
#               SOC  = Contrat (objet SOR)                             #
#               SOI1 = Cdes ouverte (objet SOI)                        #
#               SOP  = Cdes (Conversion des commandes)                 #
#               SDH1 = Liv directe (objet SDH)                         #
#               TNH1 = Transportation notes (objet TNH)                # (04/08/14) Transportation notes (Sales part dev)
#               SDD  = Liv automatique ou bouton livraison             #
#               SIH4 = Fac directe (objet SIH)                         #
#               SIHV = Calcul facture (Taxe provinciales)              #
#               SIHX = Elément facturation (Calcul facture)            #
#               SID  = Facturation automatique                         #
#               PSD  = Génération auto de DA                           #
#               PSH1 = Demandes d'achat                                #
#               POP  = Cdes d'achat (génération auto : plans ...etc)   #
#               POH2 = Cdes standards d'achat                          #
#               POH3 = Eléments facturation commandes d'achat          #
#               POI1 = Plan de l'acheteur                              #
#               POC2 = Contrats (commandes ouvertes)                   #
#               PTH1 = Réceptions d'achat                              #
#               PTH2 = Eléments facturation réceptions d'achat         #
#               PNH1 = Retours fournisseurs                            #
#               PIH3 = Contrôle factures d'achat                       #
#               PIH4 = Eléments facturation du contrôle factures achat #
#               PWD  = Traitement des factures ŕ recevoir              #
#                                                                      #
# Attention : nolign doit ętre chargé pour les champs ligne de cde     #
########################################################################
$ALITLK
nolign=NOLIG+1
Case ABREV
 When "CRM1" : [F:TLK] = [M:SRE8]
               [F:TLK] = [M:SRE9]
               [F:TLK]VACBPR = [F:SRE]SREVACBPR
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               WDAT = [M:SRE1]CREDAT : WCUR = [M:SRE8]SRECUR : WCHGTYP = [M:SRE8]SRECHGTYP
               Gosub CHARG_RATRPT
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If find(TRAIT, 2,3) & func AFNC.ACTIV("PTX")
               If find(TRAIT, 2,3) & func TRTX3.ACTIV_PTX
                   Gosub DECLARE_SAT
                   WBPCORD=[F:SRE]SREBPC
                   # Bug 74713 : Alimentation province sortie ŕ partir du site d'expé si renseigné sinon ŕ partir du site de vente
                   #WSTOFCY=[F:SRE]STOFCY : WBPAADD=[F:SRE]SREBPAADD
                   If [F:SRE]STOFCY="" WSTOFCY=[F:SRE]SALFCY Else WSTOFCY=[F:SRE]STOFCY Endif
                   WBPAADD=[F:SRE]SREBPAADD
                   # Bug 74713
                   If dim([M:ADB2]CTY)>0 WCTY=[M:ADB2]CTY : WCRY=[M:ADB2]CRY : WSAT=[M:ADB2]SAT Endif
                   Gosub CHARG_SAT
               Endif
 When "CRM2" : [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               WDAT = [M:SRE1]CREDAT : WCUR = [M:SRE8]SRECUR : WCHGTYP = [M:SRE8]SRECHGTYP
               Gosub CHARG_RATRPT
 When "CRM3" : [F:TLK] = [F:SRE]
               [F:TLK]CUR = [F:SRE]SRECUR
               [F:TLK]VACBPR = [F:SRE]SREVACBPR
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               WDAT = [F:SRE]CREDAT : WCUR = [F:SRE]SRECUR : WCHGTYP = [F:SRE]SRECHGTYP
               Gosub CHARG_RATRPT
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If find(TRAIT, 2,3) & func AFNC.ACTIV("PTX")
               If find(TRAIT, 2,3) & func TRTX3.ACTIV_PTX
                   Gosub DECLARE_SAT
                   WBPCORD=[F:SRE]SREBPC
                   # Bug 74713 : Alimentation province sortie ŕ partir du site d'expé si renseigné sinon ŕ partir du site de vente
                   #WSTOFCY=[F:SRE]STOFCY : WBPAADD=[F:SRE]SREBPAADD
                   If [F:SRE]STOFCY="" WSTOFCY=[F:SRE]SALFCY Else WSTOFCY=[F:SRE]STOFCY Endif
                   WBPAADD=[F:SRE]SREBPAADD
                   # Bug 74713
                   If dim([M:ADB2]CTY)>0 WCTY=[M:ADB2]CTY : WCRY=[M:ADB2]CRY : WSAT=[M:ADB2]SAT Endif
                   Gosub CHARG_SAT
               Endif
 When "CRM4" : [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               WDAT = [F:SRE]CREDAT : WCUR = [F:SRE]SRECUR : WCHGTYP = [F:SRE]SRECHGTYP
               Gosub CHARG_RATRPT
 When "CRM5" : [F:TLK] = [M:ITN1]
               [F:TLK] = [M:ITN8]
               [F:TLK]VACBPR = [F:SRE]SREVACBPR
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               WDAT = [F:SRE]CREDAT : WCUR = [F:SRE]SRECUR : WCHGTYP = [F:SRE]SRECHGTYP
               Gosub CHARG_RATRPT
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If find(TRAIT, 2,3) & func AFNC.ACTIV("PTX")
               If find(TRAIT, 2,3) & func TRTX3.ACTIV_PTX
                   Gosub DECLARE_SAT
                   WBPCORD=[F:SRE]SREBPC
                   # Bug 74713 : Alimentation province sortie ŕ partir du site d'expé si renseigné sinon ŕ partir du site de vente
                   #WSTOFCY=[F:SRE]STOFCY : WBPAADD=[F:SRE]SREBPAADD
                   If [F:SRE]STOFCY="" WSTOFCY=[F:SRE]SALFCY Else WSTOFCY=[F:SRE]STOFCY Endif
                   WBPAADD=[F:SRE]SREBPAADD
                   # Bug 74713
                   If dim([M:ADB2]CTY)>0 WCTY=[M:ADB2]CTY : WCRY=[M:ADB2]CRY : WSAT=[M:ADB2]SAT Endif
                   Gosub CHARG_SAT
               Endif
 When "CRM6" : [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               WDAT = [F:SRE]CREDAT : WCUR = [F:SRE]SRECUR : WCHGTYP = [F:SRE]SRECHGTYP
               Gosub CHARG_RATRPT
 When "SCS1" : [F:TLK] = [M:SCS1]
               [F:TLK]VACBPR = [M:SCS1]VACBPR
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               WDAT = [M:SCS1]IPTDAT : WCUR = [M:SCS1]CUR : WCHGTYP = [M:SCS1]CHGTYP
               Gosub CHARG_RATRPT
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If find(TRAIT, 2,3) & func AFNC.ACTIV("PTX")
               If find(TRAIT, 2,3) & func TRTX3.ACTIV_PTX
                   Gosub DECLARE_SAT
                   WBPCORD=[M:SCS1]BPCNUM
                   WSTOFCY=[M:SCS1]STOFCY : WBPAADD=[M:SCS1]FCYADD
                   If dim([M:ADB2]CTY)>0 WCTY=[M:ADB2]CTY : WCRY=[M:ADB2]CRY : WSAT=[M:ADB2]SAT Endif
                   Gosub CHARG_SAT
               Endif
 When "SQH2" : [F:TLK] = [M:SQH0]
               [F:TLK] = [M:SQH2]
               [F:TLK]VACBPR = [M:SQH1]VACBPR
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               Call CNVQTY ([F:TLK]QTY,[M:SQH2]SAUSTUCOE(nolign-1),[M:SQH2]STU(nolign-1),[F:TLK]QTYSTU) From TRTVENQTE
               WDAT = [M:SQH0]QUODAT : WCUR = [M:SQH1]CUR : WCHGTYP = [M:SQH0]CHGTYP
               Gosub CHARG_RATRPT
               If dim([L]WVACITM)>0
                   [L]WVACITM(0)=[M:SQH2]VACITM1(nolign-1)
                   [L]WVACITM(1)=[M:SQH2]VACITM2(nolign-1)
                   [L]WVACITM(2)=[M:SQH2]VACITM3(nolign-1)
               Endif
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If find(TRAIT, 2,3) & func AFNC.ACTIV("PTX")
               If find(TRAIT, 2,3) & func TRTX3.ACTIV_PTX
                   Gosub DECLARE_SAT
                   WBPCORD=[M:SQH0]BPCORD
                   WSTOFCY=[M:SQH2]DSTOFCY(nolign-1) : WBPAADD=[M:SQH2]DBPAADD(nolign-1)
                   If dim([M:ADB2]CTY)>0 WCTY=[M:ADB2]CTY : WCRY=[M:ADB2]CRY : WSAT=[M:ADB2]SAT Endif
                   Gosub CHARG_SAT
               Endif
 When "SOH4" : [F:TLK] = [M:SOH0]
               [F:TLK] = [M:SOH4]
               [F:TLK]VACBPR = [M:SOH1]VACBPR
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               WDAT = [M:SOH0]ORDDAT : WCUR = [M:SOH1]CUR : WCHGTYP = [M:SOH0]CHGTYP
               Gosub CHARG_RATRPT
               If dim([L]WVACITM)>0
                   [L]WVACITM(0)=[M:SOH4]VACITM1(nolign-1)
                   [L]WVACITM(1)=[M:SOH4]VACITM2(nolign-1)
                   [L]WVACITM(2)=[M:SOH4]VACITM3(nolign-1)
               Endif
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If find(TRAIT, 2,3) & func AFNC.ACTIV("PTX")
               If find(TRAIT, 2,3) & func TRTX3.ACTIV_PTX
                   Gosub DECLARE_SAT
                   WBPCORD=[M:SOH0]BPCORD
                   WSTOFCY=[M:SOH4]DSTOFCY(nolign-1) : WBPAADD=[M:SOH4]DBPAADD(nolign-1)
                   If dim([M:ADB2]CTY)>0 WCTY=[M:ADB2]CTY : WCRY=[M:ADB2]CRY : WSAT=[M:ADB2]SAT Endif
                   Gosub CHARG_SAT
               Endif
 When "SOC"  : [F:TLK] = [F:SOC]
               [F:TLK] = [M:SOR1]
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               WDAT = [M:SOR1]ORDDAT : WCUR = [M:SOR1]CUR : WCHGTYP = [M:SOR1]CHGTYP
               Gosub CHARG_RATRPT
               If dim([L]WVACITM)>0
                   [L]WVACITM(0)=[F:SOC]VACITM(0)
                   [L]WVACITM(1)=[F:SOC]VACITM(1)
                   [L]WVACITM(2)=[F:SOC]VACITM(2)
               Endif
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If find(TRAIT, 2,3) & func AFNC.ACTIV("PTX")
               If find(TRAIT, 2,3) & func TRTX3.ACTIV_PTX
                   Gosub DECLARE_SAT
                   WBPCORD=[F:SOC]BPCORD
                   WSTOFCY=[F:SOC]STOFCY : WBPAADD=[F:SOC]BPAADD
                   If dim([M:ADB2]CTY)>0 WCTY=[M:ADB2]CTY : WCRY=[M:ADB2]CRY : WSAT=[M:ADB2]SAT Endif
                   Gosub CHARG_SAT
               Endif
 When "SOI1" : [F:TLK] = [M:SOI1]
               [F:TLK]QTY = WQTY
               [F:TLK]ITMWEI = [F:ITM]ITMWEI
               WDAT = [M:SOI1]ORDDAT : WCUR = [M:SOI1]XCUR : WCHGTYP = [M:SOR1]CHGTYP
               Gosub CHARG_RATRPT
               If dim([L]WVACITM)>0
                   [L]WVACITM(0)=[M:SOI1]VACITM1
                   [L]WVACITM(1)=[M:SOI1]VACITM2
                   [L]WVACITM(2)=[M:SOI1]VACITM3
               Endif
               #----- Chargement des provinces -----#
               # Issue 74556 - 2011-07-05 by VPO : lecture code activité PTX
               #If find(TRAIT, 2,3) & func AFNC.ACTIV("PTX")
               If find(TRAIT, 2,3) & func TRTX3.ACTIV_PTX
                   Gosub DECLARE_SAT
                   WBPCORD=[M:SOI1]BPCORD
                   WSTOFCY=[M:SOI1]STOFCY : WBPAADD=[M:SOI1]BPAADD
                   If dim([M:ADB2]CTY)>0 WCTY=[M:ADB2]CTY : WCRY=[M:ADB2]CRY : WSAT=[M:ADB2]SAT Endif
                   Gosub CHARG_SAT
               Endif
