#    Read [ITF]ITF0=[F:ITF]ITMREF;[F:ITF]STOFCY
#    If fstat = 0
#      Read [ITM]ITM0 = [F:ITF]ITMREF
#      If fstat = 0
#        Read [ITG]ITG0="";[F:ITM]TCLCOD
#          If fstat = 0
#            If LFCY = ""
#              Read [FCY]FCY0=[F:ITF]STOFCY
#                If fstat = 0
#                  LRET = [F:ITF]ITMREF
#                  LFCY = [F:ITF]STOFCY
#                Endif
#            Else
#              LRET = [F:ITF]ITMREF
#            Endif
#          Endif
#      Endif
#    Endif
#Endcase
#End
############################################################
$SELECTION
WFILX = ""
If LFCY = ""
  Call CRIT("[F:ITF]STOFCY",[F:ITF]STOFCY,WFILX)
Endif
Call CRIT("[F:ITF]ITMREF",[F:ITF]ITMREF,WFILX)
Call CRIT("[F:ITF]BUY",[F:ITF]BUY,WFILX)
Call CRIT("[F:ITM]ITMDES1",[F:ITM]ITMDES1,WFILX)  # FGR 30/06/2009 : X3SUIVI56189 : S-P plus utilisé, il n'y a męme plus l'instruction SUBPROG
Call CRIT("[F:ITM]TCLCOD",[F:ITM]TCLCOD,WFILX)
Call CRIT("[F:ITM]ITMSTA",num$([F:ITM]ITMSTA),WFILX)
Call CRIT("[F:ITF]CUNFLG",num$([F:ITF]CUNFLG),WFILX)
If WFILX = ""
  Call ERREUR(mess(245,199,1)) From GESECRAN
  WFILX = "1=1"
Endif
Return
############################################################
Subprog CRIT(ZONE,VALEUR,FILTRE)
Value    Char ZONE
Value    Char VALEUR
Variable Char FILTRE()
Local    Integer J
J= evalue("type("+ZONE+")")
Case J
  When 1,2,3,4,5,6,7,8,9 :
    If VALEUR <> "0"
      If FILTRE<>"" : FILTRE -= "&" : Endif
      FILTRE -= ZONE+'>='+VALEUR
    Endif
  When Default :
    If VALEUR<>""
      If FILTRE<>"" : FILTRE -= "&" : Endif
        If instr(1,VALEUR,"*") or instr(1,VALEUR,"?")
          FILTRE -= 'pat('+ZONE+',"'+VALEUR+'")'
        Else
          FILTRE -= ZONE+'>="'+VALEUR+'"'
      Endif
    Endif
Endcase
End
############################################################
Subprog TEXTPAR(LPAR,LTXT)
Value    Char LPAR
Variable Char LTXT
If clalev([F:ADP]) = 0 : Local File ADOPAR [ADP] : Endif
If clalev([F:ATX]) = 0 : Local File ATEXTE [ATX] : Endif
Read [ADP]ADP1=LPAR
  If fstat = 0
    Call TEXTE([F:ADP]NAM,LTXT) From OBJDIV
  Else
    LTXT = ""
  Endif
End
#######################################################################
# SET_FLGDEV : S/P de positionnement des indicateurs     MBT 29/08/00 #
#              servant ŕ la saisie des cours devise                   #
#    (Position des devises par rapport ŕ l'Euro ŕ une date donnée)    #
# ------------------------------------------------------------------- #
# Subprog SET_FLG (DEV,SOC,DAT)                                       #
#   DEV   : Code devise                                               #
#   SOC   : Code Société                                              #
#   DAT   : Date                                                      #
# ------------------------------------------------------------------- #
# En sortie chargement des variables globales                         #
#   GCURFLG  : Flag devise courante                                   #
#   GCPYFLG  : Flag devise société                                    #
#   GRPTFLG  : Flag devise dossier (reporting)                        #
#   GDEVORI1 : Devise origine pour calcul coefficient devise société  #
#   GDEVORI2 : Devise origine pour calcul coefficient devise dossier  #
# Valeurs possibles des 'flags'                                       #
#             0 = Devise non trouvée                                  #
#             1 = Devise 'Out'                                        #
#             2 = Devise 'In'                                         #
# Nota : Si devise 'Out' GDEVDAT(I) = 31/12/9999                      #
#######################################################################
Subprog SET_FLGDEV(DEV,SOC,DAT)
Value Char     DEV
Value Char     SOC
Value Date     DAT
#----- Variables locales -----#
Local Shortint I
#----- Ouverture fichier société si nécessaire -----#
If clalev([F:CPY])=0 Local File COMPANY [CPY] : Endif
#----- Lecture de la société si nécessaire pour récup de la devise -----#
If SOC<>[F:CPY]CPY
  Read [CPY] CPY0=SOC :  If fstat Raz [F:CPY] : Endif
Endif
#----- Valeurs par défaut des indicateurs -----#
Raz GCURFLG, GCPYFLG, GRPTFLG
#----- Devise courante -----#
I=find(DEV,GDEVISE(1..GNBDEV))
If I>0
  If GDEVDAT(I)<=DAT GCURFLG=2 Else GCURFLG=1 : Endif
Endif
#----- Devise de la société -----#
I=find([F:CPY]ACCCUR,GDEVISE(1..GNBDEV))
If I>0
  If GDEVDAT(I)<=DAT GCPYFLG=2 Else GCPYFLG=1 : Endif
Endif
#----- Devise dossier (reporting) -----#
I=find(GSYSCUR, GDEVISE(1..GNBDEV))
If I>0
  If GDEVDAT(I)<=DAT GRPTFLG=2 Else GRPTFLG=1 : Endif
Endif
#----- Chargement des devises origine pour calcul des coefficients -----#
GDEVORI1=DEV : GDEVORI2=DEV
If GCURFLG=2 & DEV<>GEURO
  If GCPYFLG=1 GDEVORI1=GEURO : Endif
  If GRPTFLG=1 GDEVORI2=GEURO : Endif
Endif
End

Subprog GRAPH
# bidon pour action modélisée (DIVGRAPH) mais pas encore gérée Web
End

###################################################################
# Fonction utilisée comme paramčtre 'TABDIV' du type de donnée ADI
# pour les familles statistiques article, client et fournisseur
###################################################################
Funprog DEPFAM(DEPZ,IZ,NUM)
Value Char    DEPZ()(0..)
Value Integer IZ
Value Integer NUM
Local Char    DEPF(GLONADI)
DEPF = ""
If IZ > 0
   If !clalev([F:ADV]) : Local File ATABTAB [ADV] : Endif
   Read [ADV]CODE=IZ+NUM
   If !fstat & [F:ADV]DEPNUM>=NUM
       DEPF = DEPZ([F:ADV]DEPNUM-NUM)
   Endif
Endif
End DEPF

################################################################################
# LECITM: S/P de lecture de l'enregistrement ITMMASTER        LD Mars 2004     #
#------------------------------------------------------------------------------#
# S/P utilisé par l'action LECITM                                              #
# LECITM est branchée sur le type de donnée ITS en contrôle                    #
#        elle permet le chargement de [F:ITM]                                  #
#        utile lors du call CONTROLE from CONTOBJ                              #
#        utile pour l'option de sélection de l'objet ITS (I:[F:ITM]STOMGTCOD>1)#
#        Actuellement, la sélection sait exploiter cette option mais           #
#                      le call CONTROLE ne sait pas faire                      #
#        Astuce de MB pour alimenter [F:ITM] avant call CONTROLE               #
################################################################################
Subprog LECITM(ITM)
Value Char    ITM
If ITM="" : End : Endif
If clalev([F:ITM])=0 Local File ITMMASTER [ITM] : Endif

If ITM<>[F:ITM]ITMREF
    Read [ITM]ITM0 = ITM
    If fstat Raz [F:ITM] Endif
Endif
End

################################################################################
# ALI_PRTMOD : Alimentation des caractéristiques du modčles d'impression       #
#              dans la classe écran                                            #
#------------------------------------------------------------------------------#
# Entrée   LABR  : Abréviation masque                                          #
#          LDOC  : Document =  1 Devis                                         #
#                              2 Commande client                               #
#                              3 Commande ouverte client                       #
#                              4 Livraison                                     #
#                              5 Facture client                                #
#                              6 Avoir client                                  #
#                                                                              #
#                              7 Appel d'offre                                 #
#                              8 Commande fournisseur                          #
#                              9 Commande ouverte fournisseur                  #
#                             10 Retour fournisseur                            #
################################################################################
Subprog ALI_PRTMOD(LABR,LDOC)
Value Char    LABR
Value Integer LDOC
#-----
If !clalev([F:TPM]) Local File TABPRTMOD Endif
#-----
Local Char WTPMCOD(GLONTPM)
#-----
If LDOC<7
    #VPO 26/05/09 55362 : ici on remet ŕ 0
    Case LDOC
    When  1      : Assign "[M:"+LABR+"]COPNBR" With 0
    When  2      : Assign "[M:"+LABR+"]COPNBR" With 0
    When  3      : Assign "[M:"+LABR+"]COPNBR" With 0
    When  4      : Assign "[M:"+LABR+"]COPNBR" With 0
    When  5      : Assign "[M:"+LABR+"]COPNBR" With 0
    When  6      : Assign "[M:"+LABR+"]COPNBE" With 0
    When Default :
    Endcase
  WTPMCOD=[F:BPC]TPMCOD
Else
  WTPMCOD=[F:BPS]TPMCOD
Endif
#-----
If WTPMCOD<>""
   Read [TPM]TPM0=WTPMCOD
   If !fstat
      Case LDOC
       When  1      : If [F:TPM]SALQUO<>""
                         Assign "[M:"+LABR+"]DOCNAM" With [F:TPM]SALQUO
                         Assign "[M:"+LABR+"]COPNBR" With [F:TPM]SALQUONBE
                      Endif
       When  2      : If [F:TPM]SALORD<>""
                         Assign "[M:"+LABR+"]DOCNAM" With [F:TPM]SALORD
                         Assign "[M:"+LABR+"]COPNBR" With [F:TPM]SALORDNBE
                      Endif
       When  3      : If [F:TPM]SALORC<>""
                         Assign "[M:"+LABR+"]DOCNAM" With [F:TPM]SALORC
                         Assign "[M:"+LABR+"]COPNBR" With [F:TPM]SALORCNBE
                      Endif
       When  4      : If [F:TPM]SALDLV<>""
                         Assign "[M:"+LABR+"]DOCNAM" With [F:TPM]SALDLV
                         Assign "[M:"+LABR+"]COPNBR" With [F:TPM]SALDLVNBE
                      Endif
       When  5      : If [F:TPM]SALINV<>""
                         Assign "[M:"+LABR+"]DOCNAM" With [F:TPM]SALINV
                         Assign "[M:"+LABR+"]COPNBR" With [F:TPM]SALINVNBE
                      Endif
       When  6      : If [F:TPM]SALCRE<>""
                         Assign "[M:"+LABR+"]DOCNAM" With [F:TPM]SALCRE
                         Assign "[M:"+LABR+"]COPNBE" With [F:TPM]SALCRENBE
                      Endif
       When  7      : If [F:TPM]PURQUO<>""
                         Assign "[M:"+LABR+"]DOCNAM(nolign-1)" With [F:TPM]PURQUO
                         Assign "[M:"+LABR+"]COPNBR(nolign-1)" With [F:TPM]PURQUONBE
                      Endif
       When  8      : If [F:TPM]PURORD<>""
                         Assign "[M:"+LABR+"]DOCNAM" With [F:TPM]PURORD
                         Assign "[M:"+LABR+"]COPNBR" With [F:TPM]PURORDNBE
                      Endif
       When  9      : If [F:TPM]PURORC<>""
                         Assign "[M:"+LABR+"]DOCNAM" With [F:TPM]PURORC
                         Assign "[M:"+LABR+"]COPNBR" With [F:TPM]PURORCNBE
                      Endif
       When 10      : If [F:TPM]PURRET<>""
                         Assign "[M:"+LABR+"]DOCNAM" With [F:TPM]PURRET
                         Assign "[M:"+LABR+"]COPNBR" With [F:TPM]PURRETNBE
                      Endif
       When Default :
      Endcase
   Endif
Endif
End

################################################################################
# ALI2_PRTMOD : Alimentation du nom de l'état (dans la globale GARP_RPTCOD)    #
#               et du nombre d'exemplaires (dans la classe [F])                #
#               du modčle d'impression                                         #
#------------------------------------------------------------------------------#
# Entrée   LABR  : Abréviation du fichier                                      #
#          LDOC  : Document =  1 Devis                                         #
#                              2 Commande client                               #
#                              3 Commande ouverte client                       #
#                              4 Livraison                                     #
#                              5 Facture client                                #
#                              6 Avoir client                                  #
#                                                                              #
#                              7 Appel d'offre                                 #
#                              8 Commande fournisseur                          #
#                              9 Commande ouverte fournisseur                  #
#                             10 Retour fournisseur                            #
################################################################################
Subprog ALI2_PRTMOD(LABR,LDOC)
Value Char    LABR
Value Integer LDOC
#-----
If !clalev([F:TPM])    Local  File TABPRTMOD            Endif
If dim(GARP_RPTCOD)<=0 Global Char GARP_RPTCOD(GLONARP) Endif
Raz GARP_RPTCOD
#-----
Local Char WTPMCOD(GLONTPM)
#-----
If LDOC<7
    #VPO 26/05/09 55362 : ici on remet ŕ 0
    #Case LDOC
    #When  1      : Assign "[F:"+LABR+"]COPNBR" With [F:TPM]SALQUONBE
    #When  2      : Assign "[F:"+LABR+"]COPNBR" With [F:TPM]SALORDNBE
    #When  3      : Assign "[F:"+LABR+"]COPNBR" With [F:TPM]SALORCNBE
    #When  4      : Assign "[F:"+LABR+"]COPNBR" With [F:TPM]SALDLVNBE
    #When  5      : Assign "[F:"+LABR+"]COPNBR" With [F:TPM]SALINVNBE
    #When  6      : Assign "[F:"+LABR+"]COPNBE" With [F:TPM]SALCRENBE
    #When Default :
    #Endcase
    # FGR 09/11/2009 : X3SUIVI57778 : pas idem que pour l'écran.
    Case LDOC
    When  1      : Assign "[F:"+LABR+"]COPNBR" With 0
    When  2      : Assign "[F:"+LABR+"]COPNBR" With 0
    When  3      : Assign "[F:"+LABR+"]COPNBR" With 0
    When  4      : Assign "[F:"+LABR+"]COPNBR" With 0
    When  5      : Assign "[F:"+LABR+"]COPNBR" With 0
    When  6      : Assign "[F:"+LABR+"]COPNBE" With 0
    When Default :
    Endcase
  WTPMCOD=[F:BPC]TPMCOD
Else
  WTPMCOD=[F:BPS]TPMCOD
Endif
#-----
If WTPMCOD<>""
   Read [TPM]TPM0=WTPMCOD
   If !fstat
      Case LDOC
       When  1      : If [F:TPM]SALQUO<>""
                         GARP_RPTCOD = [F:TPM]SALQUO
                         Assign "[F:"+LABR+"]COPNBR" With [F:TPM]SALQUONBE
                      Endif
       When  2      : If [F:TPM]SALORD<>""
                         GARP_RPTCOD = [F:TPM]SALORD
                         Assign "[F:"+LABR+"]COPNBR" With [F:TPM]SALORDNBE
                      Endif
       When  3      : If [F:TPM]SALORC<>""
                         GARP_RPTCOD = [F:TPM]SALORC
                         Assign "[F:"+LABR+"]COPNBR" With [F:TPM]SALORCNBE
                      Endif
       When  4      : If [F:TPM]SALDLV<>""
                         GARP_RPTCOD = [F:TPM]SALDLV
                         Assign "[F:"+LABR+"]COPNBR" With [F:TPM]SALDLVNBE
                      Endif
       When  5      : If [F:TPM]SALINV<>""
                         GARP_RPTCOD = [F:TPM]SALINV
                         Assign "[F:"+LABR+"]COPNBR" With [F:TPM]SALINVNBE
                      Endif
       When  6      : If [F:TPM]SALCRE<>""
                         GARP_RPTCOD = [F:TPM]SALCRE
                         Assign "[F:"+LABR+"]COPNBE" With [F:TPM]SALCRENBE
                      Endif
       When  7      : If [F:TPM]PURQUO<>""
                         GARP_RPTCOD = [F:TPM]PURQUO
                         Assign "[F:"+LABR+"]COPNBR(nolign-1)" With [F:TPM]PURQUONBE
                      Endif
       When  8      : If [F:TPM]PURORD<>""
                         GARP_RPTCOD = [F:TPM]PURORD
                         Assign "[F:"+LABR+"]COPNBR" With [F:TPM]PURORDNBE
                      Endif
       When  9      : If [F:TPM]PURORC<>""
                         GARP_RPTCOD = [F:TPM]PURORC
                         Assign "[F:"+LABR+"]COPNBR" With [F:TPM]PURORCNBE
                      Endif
       When 10      : If [F:TPM]PURRET<>""
                         GARP_RPTCOD = [F:TPM]PURRET
                         Assign "[F:"+LABR+"]COPNBR" With [F:TPM]PURRETNBE
                      Endif
       When Default :
      Endcase
   Endif
Endif
End

################################################################################
# Affectation du numéro de ligne pour les demandes de livraison   MBT 25/09/06 #
# ---------------------------------------------------------------------------- #
# Ce s/p est appelé par l'action DIVLINNUM2 utilisée dans les écrans :         #
#   - POD1  Demandes de livraison achats                                       #
#   - SOQ1  Demandes de livraison ventes                                       #
################################################################################
Subprog LINNUM(ZONLIG)
Value Char    ZONLIG
#----- Affectation normale du no ligne si autre que DL achats ou ventes -----#
If !clalev([M:POD1]) & !clalev([M:SOQ1])
  Call LINNUM(ZONLIG) From TABLEAUX : End
Endif
#----- Test du status pour voir si l'affectation doit ętre effectuée -----#
If (status=6) |
&  (status=7) |
&  (status>=27 & status<=70) |
&  (status>=72 & status<=74) |
&  (status>=76 & status<=91) |
&  (status>=94 & status<=99) |
&  (status>=1792)
  End
Endif
[M]UPDFLG(nolign-1)=1
#----- Si no ligne déjŕ affecté, c'est fini ! -----#
If evalue("[M]"+ZONLIG+"("+num$(nolign-1)+")")<>0
  End
Endif
#----- Déclaration des variables locales -----#
Local Integer SAV_NOLIGN : SAV_NOLIGN=nolign
Local Integer SAV_STATUS : SAV_STATUS=status
Local Char    WCHAMPDAT(GLONAVA+10)
Local Char    WNOMTRAIT(GLONADC)
Local Integer NOL, NOL1, NOL2
Local Integer WSTART, WSEQDEB, WSEQFIN, WSEQACT, WSUPPL, WINC
Local Integer WDELTA_JOUR, WDELTA_SEQ
Local Date    WDATDEB, WDATFIN
#-----
Gosub POINT_SEQDEMDLV : # Point d'entrée permettant d'ajuster le pas du séquencement
#----- Nom du champ contenant la date début de période -----#
If clalev([M:POD1])
  WCHAMPDAT="[M:POD1]STRRCPDAT" : # DL achats
  WNOMTRAIT="SUBPOD"
Else
  WCHAMPDAT="[M:SOQ1]DEMDLVDAT" : # DL ventes
  WNOMTRAIT="SUBSOQ"
Endif
#-----
NOL1=nolign-1 : While NOL1>0          & [M]CREFLG(NOL1-1)=0 : NOL1-=1 : Wend
NOL2=nolign-1 : While NOL2<[M]NBLIG-1 & [M]CREFLG(NOL2+1)=0 : NOL2+=1 : Wend
#----- Abandon ligne en cours de création par "Escape" ou suppresion ligne -----#
If evalue(WCHAMPDAT+"(SAV_NOLIGN-1)")=[0/0/0]
  End
Endif
#-----
If NOL1<1
  WSEQDEB=GQSEQ
  WDATDEB=evalue("min(date$-1,"+WCHAMPDAT+"(NOL1))")
Else
  WSEQDEB=evalue("[M]"+ZONLIG+"(NOL1-1)")
  WDATDEB=evalue(WCHAMPDAT+"(NOL1-1)")
Endif
#----- ŕ date égale, récupération de la 1čre séquence -----#
WSTART=WSEQDEB
WSUPPL=0
If WSEQDEB>0
  If clalev([M:POD1])
    # Issue 82047 - 2012-06-01 by SR
    Filter [F:POQ] Where POHNUM = [M:POD1]POHNUM & POPLIN = [M:POD1]POPLIN
    Read [POQ] POQ0=[M:POD1]POHNUM;[M:POD1]POPLIN;WSEQDEB
    If !fstat
      WDATDEB=[F:POQ]DEMRCPDAT
      While [F:POQ]DEMRCPDAT=WDATDEB
        Read [POQ] POQ0 Prev
        If !fstat
          If [F:POQ]DEMRCPDAT=WDATDEB  WSTART=[F:POQ]POQSEQ : Endif
        Else
          Raz [F:POQ]
        Endif
      Wend
    Endif
    # Issue 82047 - 2012-06-01 by SR
    Filter [F:POQ]
  Else
    # Issue 82047 - 2012-06-01 by SR
    Filter [F:SOQ] Where SOHNUM = [M:SOQ1]SOHNUM & SOPLIN = [M:SOQ1]SOPLIN
    Read [SOQ] SOQ0=[M:SOQ1]SOHNUM;[M:SOQ1]SOPLIN;WSEQDEB
    If !fstat
      WDATDEB=[F:SOQ]DEMDLVDAT
      While [F:SOQ]DEMDLVDAT=WDATDEB
        Read [SOQ] SOQ0 Prev
        If !fstat
          If [F:SOQ]DEMDLVDAT=WDATDEB  WSTART=[F:SOQ]SOQSEQ : Endif
        Else
          Raz [F:SOQ]
        Endif
      Wend
     Endif
    # Issue 82047 - 2012-06-01 by SR
    Filter [F:SOQ]
  Endif
Endif
#----- Aucune DL postérieure n'existait avant le traitement -----#
If NOL2>=[M]NBLIG-1
  WSEQFIN=99999999
  WDATFIN=[31/12/2110]
  Gosub SEQUENCE_EXTRA
#----- Des DL postérieures existent -----#
Else
  #----- Si la DL suivante a la męme date, il faut repousser la numérotation -----#
  If evalue(WCHAMPDAT+"(SAV_NOLIGN-1)")=evalue(WCHAMPDAT+"(NOL2+1)")
    WSUPPL=STEP2
  Endif
  #-----
  WSEQFIN=evalue("[M]"+ZONLIG+"(NOL2+1)")
  WDATFIN=evalue(WCHAMPDAT+"(NOL2+1)")
  WDELTA_JOUR=WDATFIN-WDATDEB
  WDELTA_SEQ =WSEQFIN-WSEQDEB
  #----- L'intervalle dispo n'est pas suffisant pour la numérotation des séquences -----#
  If WSEQFIN-(WSTART+WSUPPL)<WDELTA_JOUR*STEP1 | WDELTA_SEQ<STEP2*(1+(NOL2-NOL1))+1
    #----- Toutes les DL postérieures sont-elles supprimables ? -----#
    Raz mkstat
    For nolign=NOL2+2 To [M]NBLIG
      #----- Pas de suppression possible si DL ventes allouées -----#
      If clalev([M:SOQ1])
        If [M:SOQ1]ALLQTYSTU(nolign-1)>0 | [M:SOQ1]SHTQTYSTU(nolign-1)>0
          mkstat=1 : Break
        Endif
      Endif
      #-----
      status=65 : Call C_NBLIG From =WNOMTRAIT : If mkstat  Break : Endif
    Next nolign
    status=SAV_STATUS
    #----- Suppression et recréation des DL postérieures avec nouvelles séquences -----#
    If !mkstat
      For NOL=NOL2+1 To [M]NBLIG-1
        # Issue 79317 - 2012-01-16 by VPO : perte des liens prequiso par exemple
        #----- Si DA prise en compte, il faut la récupérer pour la nouvelle ligne -----#
        If clalev([M:POD1]) & [M]CREFLG(NOL)<>0
           nolign=NOL+1
           Gosub RECUP_BESOIN From SUBPOD
        Endif
        [M]CREFLG(NOL)=0
        [M]UPDFLG(NOL)=1
      Next NOL
      NOL2=[M]NBLIG-1
      Gosub SEQUENCE_EXTRA
    #------ Pas de suppression de DL possible, il faut faire avec ... -----#
    Else
      Raz mkstat, GMESSAGE
      Gosub SEQUENCE_MINIMUM
    Endif
  #----- L'intervalle dispo permet le séquencement optimisé ! -----#
  Else
    Gosub SEQUENCE_EXTRA
  Endif
Endif
#-----
nolign=SAV_NOLIGN
status=SAV_STATUS
End

#--------------------------------------#
# Numérotation optimisée des séquences #
#--------------------------------------#
$SEQUENCE_EXTRA
WSEQACT=WSEQDEB-mod(WSEQDEB,STEP2)
For NOL=NOL1 To NOL2
  WDELTA_JOUR=evalue(WCHAMPDAT+"(NOL)")-WDATDEB
  If WDELTA_JOUR>0
    WSEQACT=max(WSTART+(WDELTA_JOUR*STEP1),WSEQACT+STEP2)
    WDATDEB=evalue(WCHAMPDAT+"(NOL)")
    WSTART =WSEQACT
  Else
    WSEQACT+=STEP2
  Endif
  Assign "[M]"+ZONLIG+"(NOL)" With WSEQACT
Next NOL
Return

#-------------------------------------#
# Numérotation minimale des séquences #
#-------------------------------------#
$SEQUENCE_MINIMUM
WINC=int(WDELTA_SEQ/max(WDELTA_JOUR+1,2+(NOL2-NOL1)))
If WINC=0
  Call ERREUR (mess(122,199,1)) From GESECRAN : mkstat=1 : Return
Endif
WSTART =WSEQDEB
WSEQACT=WSEQDEB
For NOL=NOL1 To NOL2
  WDELTA_JOUR=evalue(WCHAMPDAT+"(NOL)")-WDATDEB
  If WDELTA_JOUR>0
    If WSEQACT>WSTART+(WDELTA_JOUR*WINC)
      WSTART=WSEQACT
    Endif
    WSEQACT=WSTART+(WDELTA_JOUR*WINC)
    WDATDEB=evalue(WCHAMPDAT+"(NOL)")
    WSTART =WSEQACT
  Else
    WSEQACT+=min(STEP2,WINC)
  Endif
  Assign "[M]"+ZONLIG+"(NOL)" With WSEQACT
Next NOL
Return


##############################################
# Appel du point d'entrée SEQDEMDLV depuis : #
#     - le traitement TRTX3                  #
#     - le traitement TRTACHPOD1             #
##############################################
$POINT_SEQDEMDLV
Local Integer STEP1 : STEP1=1000
Local Integer STEP2 : STEP2=50
#----------------------------------------------------------------------------#
# SEQDEMDLV Point d'entrée permettant d'ajuster le pas du séquencement de DL #
# -------------------------------------------------------------------------- #
# STEP1 : Pas entre deux dates consécutives                                  #
#         valeurs entre 1000 et 10000 (par défaut 1000)                      #
# STEP2 : Pas entre deux dates identiques                                    #
#         valeurs entre    5 et  1000 (par défaut 50)                        #
#                                                                            #
# Exemples de valeurs :                                                      #
# - avec STEP1 =  1000 : La durée du contrats est de 100 ans                 #
#     si STEP2 =     5 :  200 dates identiques et    5 réceptions partielles #
#                   10 :  100 dates identiques et   10 réceptions partielles #
#                   50 :   20 dates identiques et   50 réceptions partielles #
#                  100 :   10 dates identiques et  100 réceptions partielles #
#                  500 :    2 dates identiques et  500 réceptions partielles #
#                 1000 :    1 date  identique  et 1000 réceptions partielles #
# - avec STEP1 = 10000 : La durée du contrats est de  10 ans                 #
#     si STEP2 =     5 : 2000 dates identiques et    5 réceptions partielles #
#                   10 : 1000 dates identiques et   10 réceptions partielles #
#                   50 :  200 dates identiques et   50 réceptions partielles #
#                  100 :  100 dates identiques et  100 réceptions partielles #
#                  500 :   20 dates identiques et  500 réceptions partielles #
#                 1000 :   10 dates identiques et 1000 réceptions partielles #
#----------------------------------------------------------------------------#
GPOINT="SEQDEMDLV" : Gosub ENTREE From EXEFNC
If STEP1>10000  STEP1=10000  Elsif STEP1<1000  STEP1=1000  : Endif
If STEP2>1000   STEP2=1000   Elsif STEP2<5     STEP2=5     : Endif
Return

# SR 09.11 Demande 75817
##############################################
# Appel du point d'entrée SEQDLVSPL depuis : #
#     - le traitement SUBPTHA                #
##############################################
$POINT_SEQDLVSPL
#----------------------------------------------------------------------------#
# SEQDLVSPL Point d'entrée permettant d'ajuster le pas du séquencement de DL #
# dans le cas d'un Splittage                                                 #
# -------------------------------------------------------------------------- #
If dim(GSTEP3) < 0 : Global Integer    GSTEP3 : Endif
GSTEP3 = 4
GPOINT="SEQDLVSPL" : Gosub ENTREE From EXEFNC
If GSTEP3 = 0 : GSTEP3 = 4 : Endif
Return


