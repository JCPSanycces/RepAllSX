#######################################################################
#---------------------------------------------------------------------#
# Traitements e_commerce                                              #
#---------------------------------------------------------------------#
# ACTION                                                              #
#---------------------------------------------------------------------#
# ---------------------                                               #
# Affichages de fenętre                                               #
# ---------------------                                               #
# SAISELADR   : Sélection d'une adresse                               #
# ---------------------                                               #
# Sélection                                                           #
# ---------------------                                               #
# SELACS     : Sélection du code d'accčs                              #
# SELOBJCRIT : Sélection d'un objet avec définition de critčres       #
# SELDOC     : Sélection d'un code état Crystal Report                #
#                                                                     #
#######################################################################
#######################################################################
# Etiquettes ACTION                                                   #
#######################################################################
#--- Actions liés au type fenętre de saisie
$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "TITRE"         : Gosub TITLE
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "FINSAI"        : Gosub FIN_SAI
 When "OK"            : Gosub OK
 When "ABA"           : Gosub ABA
 When "SEL_TABLE"     : Gosub SEL_TABLE
 When "VERF_TABLE"    : Gosub VERF_TABLE
 When "VERF_PARAM"    : Gosub VERF_PARAM
Endcase
Return
#########################################################################
#    Actions liés au type fenętre de saisie                             #
#########################################################################
$OUVRE
Case GACTION
 When "SAISELADR"  : Gosub OUV_SAISELADR
 When "SAIADRBPR"  : Gosub OUV_SAIADRBPR
 When "VISUADRDLV" : Gosub OUV_VISUADRDLV
Endcase
Return

$DEBUT
Case GACTION
 When "SAISELADR"  : Gosub DEB_SAISELADR
 When "SAIADRBPR"  : Gosub DEB_SAIADRBPR
 When "VISUADRDLV" : Gosub DEB_VISUADRDLV
Endcase
Return

$TITLE
Case GACTION
 When "SAISELADR"  : Gosub TIT_SAISELADR
 When "SAIADRBPR"  : Gosub TIT_SAIADRBPR
 When "VISUADRDLV" : Gosub TIT_VISUADRDLV
Endcase
Return


$OK
Case GACTION
 When "SAISELADR"  : Gosub OK_SAISELADR
 When "SAIADRBPR"  : Gosub OK_SAIADRBPR
Endcase
Return

$ABA
Case GACTION
 When "SAISELCNT"  : Gosub ABA_SAISELADR
 When "SAIADRBPR"  : Gosub ABA_SAIADRBPR
Endcase
Return

$FIN_SAI
Case GACTION
 When "SAISELADR"  : Gosub FSA_SAISELADR
 When "SAIADRBPR"  : Gosub FSA_SAIADRBPR
 When "VISUADRDLV" : Gosub FSA_VISUADRDLV
Endcase
Return

$APRES_MODIF
Case GACTION
 When "SAIADRBPR"  : REP = "M"
Endcase
Return

#########################################################################
#    CHOIX DANS LES TABLES  Traitements e_commerce                      #
#########################################################################
$SEL_TABLE
Case TABLE
    When "SELACS"     : Gosub S_ACS
    When "SELOBJCRIT" : Gosub S_OBJCRIT
    When "SELMFG1"    : Gosub S_SELMFG1
    When "SELSCO2"    : Gosub S_SELSCO2
    When "SELDOC"     : Gosub S_SELDOC
Endcase

Case GACTION
    When "SELCPYLEG"  : Gosub S_CPYLEG
    When "SELFCYLEG"  : Gosub S_FCYLEG :#--CPO 71937 TVT Report CPO
Endcase
Return

$VERF_TABLE
Case TABLE
Endcase
Return
#########################################################################
#                                                                       #
# Subprog SELACS(VALEUR)                                                #
#      Sélection du code d'accčs                                        #
#   Action : SELACS                                HN 15/09/00          #
#                                                                       #
#########################################################################
$S_ACS
  If clalev([F:ACC])=0 : Local File ACCES   [ACC] : Endif
  If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
  If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif # FGR 07/10/2009 : X3SUIVI53694
  If clalev([F:ACS])=0 : Local File ACCCOD  [ACS] : Endif # FGR 07/10/2009 : X3SUIVI53694

  Local Char CODFIC    : CODFIC = "ACCES"
  Local Char WCTLTYP

  WCTLTYP = toupper (PARAM(1))

  # FGR 07/10/2009 : X3SUIVI53694
  Link [ACC] With [ACS]ACS0=[F:ACC]CODACC,
&                 [AXX]AXX0="ACCCOD";"DESACC";GLANGUE;[F:ACC]CODACC;""
&              As [NEW]
  #Default File [ACC]
  Default File [NEW]

  CRITERE(1) ='USR= "' +GUSER+'"'
  If WCTLTYP = "C"
    CRITERE(1)+=' & CONSUL=2'
  Elsif WCTLTYP = "M"
    CRITERE(1)+=' & MODIF=2'
  Elsif WCTLTYP = "E"
    CRITERE(1)+=' & EXEC=2'
  Endif
  CRITERE(1)+=' & left$([F:ACC]CODACC,1)<>"/"'
  CRITERE(1)+=' & CODACC<>""'

  START  = 'CODACC'
  TIT(0) = mess(12,123,1)
  SIZCOL = 160
  NBCOL  = 0
  #NBCOL += 1 : CODFIC = "ACCES"  : COL(NBCOL) = "USR"       : Gosub TEXTE
  NBCOL += 1 : CODFIC = "ACCES"  : COL(NBCOL) = "CODACC"    : Gosub TEXTE
  NBCOL += 1 : CODFIC = "ACCCOD" : COL(NBCOL) = "DESACC"    : Gosub TEXTE : COL(NBCOL) = "[F:AXX]TEXTE" # FGR 07/10/2009 : X3SUIVI53694
  CODFIC = "ACCES"
Return

#########################################################################
$TEXTE
Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return
#########################################################################
# SELOBJCRIT   : Sélection d'un objet avec définition de critčres       #
#########################################################################
$S_OBJCRIT
OBJET   = PARAM(1)
OPTIONS = PARAM(2)
SUPP    = PARAM(3)

#CRITERE(1) = PARAM(4)
#CRITERE(2) = PARAM(5)
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",PARAM(4),"&") From GOBJSUB
Call ADDCRIT(CRITERE,ICRITERE,"CRITERE",PARAM(5),"&") From GOBJSUB


Return
#########################################################################
# Détail des actions liées au type fenętre de saisie                    #
#                                                                       #
#########################################################################
#########################################################################
# SAISELADR    : Sélection d'une adresse                                #
#########################################################################
$OUV_SAISELADR
Local Integer LTYP           : LTYP  = val(PARAM(1))
Local Char    LNUM           : LNUM  = PARAM(2)
Local Char    LNAM0(GLONNAM) : LNAM0 = PARAM(3)
Local Char    LNAM1(GLONNAM) : LNAM1 = PARAM(4)

Local Char    CHAINE
Local Integer NBTEX          : NBTEX = 0
Local Char    TEX            : TEX   = ""
Local Char    WADR(GLONADR)

If clalev([F:BPA1]) = 0 Local File BPADDRESS  [BPA1] : Endif
If clalev([F:TCY])  = 0 Local File TABCOUNTRY [TCY]  : Endif

GSINTBID = mess(LTYP,203,1)

Return
#------------------------------------------------------------------------------#
$TIT_SAISELADR
TIT = mess(27,198,1)+" "+mess(LTYP,203,1)
Return
#------------------------------------------------------------------------------#
$DEB_SAISELADR
Raz [M:BPAW]
[M:BPAW]BPATYP    = LTYP
[M:BPAW]BPANUM    = LNUM
[M:BPAW]BPANAM(0) = LNAM0
[M:BPAW]BPANAM(1) = LNAM1
[M:BPAW]BASPAG1    = 0
Filter [BPA1] Where BPATYP = LTYP & BPANUM = LNUM
&             Order By Key BPA0
For [BPA1]
  If [M:BPAW]BASPAG1 < dim([M:BPAW]BPAADD)-1
    [M:BPAW]BPAADD([M:BPAW]BASPAG1) = [F:BPA1]BPAADD
    [M:BPAW]BPADES([M:BPAW]BASPAG1) = [F:BPA1]BPADES
    [M:BPAW]BPATYP([M:BPAW]BASPAG1) = LTYP
    [M:BPAW]BASPAG1 += 1
  Endif
Next
Filter [BPA1]
nolign = 1

Affzo [M:BPAW]
CHAINE = "TA"
Return
#------------------------------------------------------------------------------#
$OK_SAISELADR
VALEUR = [M:BPAW]BPAADD(nolign-1)
Return
#------------------------------------------------------------------------------#
$ABA_SAISELADR
Return
#------------------------------------------------------------------------------#
$FSA_SAISELADR
GTABCONS = 0
GSINTBID = ""
Return

#######################################################################
# SAIADRBPR    : Saisie de l'adresse                     MBT 04/05/05 #
# ------------------------------------------------------------------- #
#   NUMT  : Numéro du tiers dont l'adresse est ŕ saisir               #
#   ABREV: Abréviation du masque adresse                              #
#          "AD5x" = Masques pour module ventes                        #
#                                                                     #
#          "AD6x" = Masques pour module achats                        #
#                   AD61 Commandes - adresse fournisseur commande     #
#                   AD62 Commandes - adresse fournisseur expéditeur   #
#                   AD63 Contrats  - adresse fournisseur contrat      #
#                   AD64 Contrats  - adresse fournisseur expéditeur   #
#                   AD65 Retours   - adresse fournisseur retour       #
#                   AD66 Factures  - adresse fournisseur facturant    #
#                   AD67 Factures  - adresse fournisseur payé         #
#                   AD68 Réception - adresse fournisseur expéditeur   #
#   TRAIT : Code du traitement                                        #
#           0 = Chargement de la premičre adresse si nécessaire       #
#           1 = Chargement de la premičre adresse si nécessaire       #
#               mais non conservée si non modifiée                    #
#   MSG   : Numéro du message pour titre de la fenętre                #
#           0 = Titre par défaut (4,195,1="Saisie d'adresse")         #
#   CHAP  : Numéro de chapitre du message pour titre de la fenętre    #
#           0 = Titre par défaut (4,195,1="Saisie d'adresse")         #
# ------------------------------------------------------------------- #
# En sortie chargement de la classe [M:ADx]                           #
#          avec ADBBPR = Numéro du tiers traité                       #
#               ADBFLG = 0 --> Aucune adresse chargée                 #
#                        1 --> Adresse chargée mais non modifiée      #
#                        2 --> Adresse chargée et modifiée            #
#######################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenętre #
#--------------------------------------------------------------#
$OUV_SAIADRBPR
Local Char     NUMT  : NUMT =PARAM(1)
Local Char     ABREV : ABREV=PARAM(2)
Local Integer  TRAIT : TRAIT=val(PARAM(3))
Local Integer  MSG   : MSG  =val(PARAM(4))
Local Integer  CHAP  : CHAP =val(PARAM(5))
#----- Variables locales -----#
Local Char     SAV_DEFMSK(255) : SAV_DEFMSK=dbgstr(1)
Local Shortint FLGSAI
#----- Variables locales pour sauvegarde du masque -----#
Local Char     BPRNAM(GLONNAM)(2)
Local Char     BPAADD(GLONADR)
Local Char     BPAADDLIG(GLONADL)(3)
Local Char     CRY(GLONCRY)
Local Char     CRYNAM(GLONNCY)
Local Char     SAT(GLONSAT)
Local Char     POSCOD(GLONPOS)
Local Char     CTY(GLONCTY)
#------ Ouverture des fichiers si besoin ------#
If !clalev([F:BPR])  Local File BPARTNER   [BPR] : Endif
If !clalev([F:BPA])  Local File BPADDRESS  [BPA] : Endif
If !clalev([F:TCY])  Local File TABCOUNTRY [TCY] : Endif
#------ Contrôle validité des paramčtres ------#
If NUMT="" | ABREV="" | TRAIT>1  FIN=1 : Return : Endif
If MSG=0 | CHAP=0  MSG=4 : CHAP=195 : Endif
Return
#-------------------------------------------#
# Titre juste avant ouverture de la fenętre #
#-------------------------------------------#
$TIT_SAIADRBPR
TIT=mess(MSG,CHAP,1)
Return
#---------------------------------#
# Aprčs l'ouverture de la fenętre #
#---------------------------------#
$DEB_SAIADRBPR
Raz [M:ADB]
Default Mask "["+ABREV+"]"
[M:ADB]=[M]
#----- Raz masque et lecture BPARTNER si nécessaire -----#
If [M:ADB]ADBBPR<>NUMT  Raz [M:ADB] : Endif
If [F:BPR]BPRNUM<>NUMT
  Read [BPR] BPR0=NUMT : If fstat  Raz [F:BPR] : Endif
Endif
[M:ADB]ADBBPR=NUMT : [M:ADB]ADBTRT=TRAIT
If TRAIT=0
  [M:ADB]ADBLIB=format$("K:20X",mess(27,198,1))+":"
  If [M:ADB]BPAADD=""  [M:ADB]BPAADD=[F:BPR]BPAADD : Endif
Endif
#----- Lecture de l'adresse si nécessaire -----#
If [M:ADB]BPAADD=""  [M:ADB]BPAADD=[F:BPR]BPAADD : Endif
If [M:ADB]ADBFLG=0
  Read [BPA] BPA0=1;NUMT;[M:ADB]BPAADD
  If fstat  Raz [F:BPA] : Endif
  [M:ADB]BPRNAM(0)    = [F:BPR]BPRNAM(0)
  [M:ADB]BPRNAM(1)    = [F:BPR]BPRNAM(1)
  [M:ADB]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [M:ADB]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [M:ADB]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [M:ADB]CRY          = [F:BPA]CRY
  [M:ADB]CRYNAM       = [F:BPA]CRYNAM
  [M:ADB]SAT          = [F:BPA]SAT
  [M:ADB]POSCOD       = [F:BPA]POSCOD
  [M:ADB]CTY          = [F:BPA]CTY
  [M:ADB]ADBBPR       = [F:BPR]BPRNUM
  [M:ADB]ADBFLG       = 1
Endif
#----- Sauvegarde des valeurs initiales du masque -----#
[L]=[M:ADB]
#----- Si modif non autorisée, désactivation de la saisie par grisage -----#
FLGSAI=1
If GCONSULT>0
  Diszo [ADB]1-99 : FLGSAI=0
Elsif GREP<>"C"
  GBIDC2="M" : Gosub AUTORIS_OPT From CONTX3
  If !GBIDI2  Diszo [ADB]1-99 : FLGSAI=0 : Endif
Endif
#----- Si adresse fournisseur payé normal (non divers) pas de saisie du détail -----#
If ABREV="AD67" & FLGSAI<>0
  Filter [BPS] Where BPSTYP=1 : # Fournisseur normal
  Look [BPS] BPS0=NUMT
  Filter [BPS]
  #----- C'est un fournisseur normal --> pas de détail -----#
  If !fstat
    Diszo [ADB]CRY, CRYNAM, BPAADDLIG, SAT, POSCOD, CTY
  #----- C'est un tiers non divers --> pas de détail -----#
  Elsif [F:BPR]BPRACC<>2
    Diszo [ADB]CRY, CRYNAM, BPAADDLIG, SAT, POSCOD, CTY
  Endif
Endif
#-----
Affzo [ADB]1-99
Return
#--------------------------------#
# Aprčs l'exécution du bouton OK #
#--------------------------------#
$OK_SAIADRBPR
If FLGSAI=0  FIN=1 : Return : Endif
#----- Changement adresse origine si changement code adresse -----#
If TRAIT=0 & [M:ADB]BPAADD<>[L]BPAADD
  [L]BPAADD       = [M:ADB]BPAADD
  [L]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
  [L]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
  [L]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
  [L]CRY          = [F:BPA]CRY
  [L]CRYNAM       = [F:BPA]CRYNAM
  [L]SAT          = [F:BPA]SAT
  [L]POSCOD       = [F:BPA]POSCOD
  [L]CTY          = [F:BPA]CTY
  mkstat=4
Endif
#----- Test si adresse modifiée -----#
If [M:ADB]BPRNAM(0)    <> [L]BPRNAM(0)    |
&  [M:ADB]BPRNAM(1)    <> [L]BPRNAM(1)    |
&  [M:ADB]BPAADDLIG(0) <> [L]BPAADDLIG(0) |
&  [M:ADB]BPAADDLIG(1) <> [L]BPAADDLIG(1) |
&  [M:ADB]BPAADDLIG(2) <> [L]BPAADDLIG(2) |
&  [M:ADB]CRY          <> [L]CRY          |
&  [M:ADB]CRYNAM       <> [L]CRYNAM       |
&  [M:ADB]SAT          <> [L]SAT          |
&  [M:ADB]POSCOD       <> [L]POSCOD       |
&  [M:ADB]CTY          <> [L]CTY
  [M:ADB]ADBFLG=2 : mkstat=4

  # 101090 - Verify if changed and BOL attached to return
  If GFONCTION="GESPNH"
    Local Integer OK : OK = 2
    Call VERIF_BOLMOD(OK) From SUBPNHA
    If OK<>2 : FIN=0 : Return : Endif
  Endif

Elsif TRAIT=1 & [M:ADB]ADBFLG=1
  [M:ADB]ADBFLG=0
Endif
#----- Récupération de l'adresse modifiée dans l'écran d'adresse de l'objet -----#
If [M:ADB]ADBFLG>0
  Default Mask "["+ABREV+"]"
  [M]=[M:ADB]
Endif
Return
#-------------------------------------#
# Aprčs l'exécution du bouton ABANDON #
#-------------------------------------#
$ABA_SAIADRBPR
[M:ADB]=[L] : REP=""
Affzo [ADB]1-99
Return
#------------------------------------------#
# Avant de revenir ŕ la fenętre précédente #
#------------------------------------------#
$FSA_SAIADRBPR
Default Mask SAV_DEFMSK
Return

################################################################################
# Action VISUADRDLV : Visualisation adresse du client livré     MBT 19/12/2001 #
# ---------------------------------------------------------------------------- #
#   PARAM(1) = NUM :  Numéro de la commande de vente                           #
################################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenętre #
#--------------------------------------------------------------#
$OUV_VISUADRDLV
#----- Variables locales -----#
Local Char     WNUM(GLONPOH) : WNUM=PARAM(1)
Local Integer  SAVNOLIGN     : SAVNOLIGN=nolign
Local Libelle  OUVFICSOH     : Raz OUVFICSOH
Local Char     SAVBPRNUM(GLONBPR)
Local Char     WBPAADD(GLONADR)
If WNUM=""  FIN=1 : Return : Endif
If clalev ([F:SOH])=0  Local File SORDER    [SOH] : OUVFICSOH+=1 : Endif
If clalev ([F:SOQ])=0  Local File SORDERQ   [SOQ] : OUVFICSOH+=2 : Endif
If clalev ([F:BPD])=0  Local File BPDLVCUST [BPD] : OUVFICSOH+=4 : Endif
If clalev ([F:BPR])=0  Local File BPARTNER  [BPR] : Endif
If clalev ([F:BPA])=0  Local File BPADDRESS [BPA] : Endif
If [F:POQ]POHNUM<>[M:POH0]POHNUM | [F:POQ]POPLIN<>[M:POH2]POPLIN(SAVNOLIGN-1)
  Read [POQ] POQ0=[M:POH0]POHNUM;[M:POH2]POPLIN(SAVNOLIGN-1);1
  If fstat Raz [F:POQ] : Endif
Endif
If [F:SOH]SOHNUM<>WNUM
  Read [SOH] SOH0=WNUM : If fstat  Raz [F:SOH] : Endif
Endif
If [F:SOQ]SOHNUM<>WNUM | [F:SOQ]SOPLIN<>[F:POQ]SOPLIN | [F:SOQ]SOQSEQ<>[F:POQ]SOQSEQ
  Read [SOQ] SOQ0=WNUM;[F:POQ]SOPLIN;[F:POQ]SOQSEQ
  If fstat Raz [F:SOQ] : Endif
Endif
Return
#---------------------#
# Titre de la fenętre #
#---------------------#
$TIT_VISUADRDLV
TIT=mess(10,195,1)-[F:SOH]BPCORD
Return
#---------------------------------#
# Aprčs l'ouverture de la fenętre #
#---------------------------------#
$DEB_VISUADRDLV
Raz [M:ADC]
#----- Lecture du business partner client puis retauration du dernier lu -----#
SAVBPRNUM=[F:BPR]BPRNUM
If [F:BPR]BPRNUM<>[F:SOH]BPCORD
  Read [BPR] BPR0=[F:SOH]BPCORD : If fstat Raz  [F:BPR] : Endif
Endif
[M:ADC]BPRNAM(0)=[F:BPR]BPRNAM(0)
[M:ADC]BPRNAM(1)=[F:BPR]BPRNAM(1)
If SAVBPRNUM<>"" & [F:BPR]BPRNUM<>SAVBPRNUM
  Read [BPR] BPR0=SAVBPRNUM     : If fstat Raz  [F:BPR] : Endif
Endif
#-----
If [F:SOQ]BPAADD<>"" & [F:SOQ]BPAADD<>[F:SOH]BPAADD
  WBPAADD=[F:SOQ]BPAADD
Else
  WBPAADD=[F:SOH]BPAADD
Endif
#----- Lecture du client livré -----#
If [F:BPD]BPCNUM<>[F:SOH]BPCORD | [F:BPD]BPAADD<>WBPAADD
  Read [BPD] BPD0=[F:SOH]BPCORD;WBPAADD  : If fstat  Raz [F:BPD] : Endif
Endif
If [F:BPD]BPDNAM(0)<>""
  [M:ADC]BPRNAM(0)=[F:BPD]BPDNAM(0)
  [M:ADC]BPRNAM(1)=[F:BPD]BPDNAM(1)
Endif
#-----
[M:ADC]BPAADD=WBPAADD
[M:ADC]CNTNAM=[F:SOH]CNDNAM
If [F:SOH]BPDNAM="" | WBPAADD<>[F:SOH]BPAADD
  Read [BPA] BPA0=1;[F:SOH]BPCORD;WBPAADD : If fstat  Raz [F:BPA] : Endif
  [M:ADC]=[F:BPA]
Else
  [M:ADC]BPRNAM(0)   =[F:SOH]BPDNAM(0)
  [M:ADC]BPRNAM(1)   =[F:SOH]BPDNAM(1)
  [M:ADC]BPAADDLIG(0)=[F:SOH]BPDADDLIG(0)
  [M:ADC]BPAADDLIG(1)=[F:SOH]BPDADDLIG(1)
  [M:ADC]BPAADDLIG(2)=[F:SOH]BPDADDLIG(2)
  [M:ADC]CRY         =[F:SOH]BPDCRY
  [M:ADC]CRYNAM      =[F:SOH]BPDCRYNAM
  [M:ADC]SAT         =[F:SOH]BPDSAT
  [M:ADC]POSCOD      =[F:SOH]BPDPOSCOD
  [M:ADC]CTY         =[F:SOH]BPDCTY
Endif
Affzo [ADC]
Diszo [ADC]1-99
Return
#------------------------------------------#
# Avant de revenir ŕ la fenętre précédente #
#------------------------------------------#
$FSA_VISUADRDLV
If OUVFICSOH>3  Close Local File [BPD] : OUVFICSOH-=4  : Endif
If OUVFICSOH>1  Close Local File [SOQ] : OUVFICSOH-=2  : Endif
If OUVFICSOH>0  Close Local File [SOH] : Raz OUVFICSOH : Endif
nolign=SAVNOLIGN
Return

