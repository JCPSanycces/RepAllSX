#                                                                    #
######################################################################
Subprog DUMMY()
# Ne jamais rien mettre
End

#######################################################################
#---------------------------------------------------------------------#
# Traitements non e_commerce                                          #
#---------------------------------------------------------------------#
#######################################################################
#---------------------------------------------------------------------#
# Initialisation des codes comptables                                 #
#                                                                     #
# Initialisation d'un code comptable                                  #
# --> Ssi un seul code comptable existe pour le type de code donné    #
#                                                                     #
# Action associée : INITACCCOD                                        #
#---------------------------------------------------------------------#
Subprog INITACCCOD(VALEUR,TYPCOD)
Variable Char    VALEUR()
Value    Integer TYPCOD

Raz VALEUR
Local    Char     ACCCOD
If clalev([F:CAC])=0 : Local File GACCCODE [CAC] : Endif

Filter [CAC] Where TYP=TYPCOD
Read [CAC]CAC0 First
If !fstat
    WACCCOD = [F:CAC]ACCCOD
    Read [CAC]CAC0 Last
    If !fstat & [F:CAC]ACCCOD = WACCCOD
        VALEUR = WACCCOD
    Endif
Endif
Filter [CAC]
End

#---------------------------------------------------------------------#
# Controle du caractčre obligatoire du code comptable                 #
#                                                                     #
# La présence du module comptabilité ou le positionnement d'un        #
# paramčtre général implique de renseigner le code comptable          #
#                                                                     #
# Action associée : CONTACCCOD                                        #
#---------------------------------------------------------------------#
Subprog CONTACCCOD(VALEUR,TYPCOD)
Variable Char    VALEUR()
Value    Integer TYPCOD
Case TYPCOD
 When 1,2,3,4
    # article, client, fournisseur, représentant
    If GMODU(2) = 2 & VALEUR = ""
       mkstat = 2
       GMESSAGE = mess(10,123,1) #"valeur obligatoire"
    Endif

Endcase
End

#--------------------------------------------------------------#
# Chargement de la désignation article dans la langue du tiers #
#--------------------------------------------------------------#
Subprog CHARGE_ITMDES (LZON,LLAN,LITM,LDES)
Value    Char    LZON
Value    Char    LLAN
Value    Char    LITM
Variable Char    LDES
#-----
Raz LDES
If !clalev([F:AXX]) Local File ATEXTRA [AXX] Endif
If LZON<>"" & LLAN<>"" & LITM<>""
  Read [AXX] AXX0="ITMMASTER";LZON;LLAN;LITM;""
  If !fstat  LDES=[F:AXX]TEXTE : Endif
Endif
End

#--------------------------------------------------------------#
# Chargement de la désignation article dans la langue du tiers #
# et prend ITMDESx correspondant si non renseigné              #
#--------------------------------------------------------------#
# FGR 19/10/2015 : X3SUIVI111811 (début)
Subprog CHARGE_DEFITMDES(LZON, LLAN, LITM, LDES, LABRITM)
Value    Char    LZON
Value    Char    LLAN
Value    Char    LITM
Variable Char    LDES
Value    Char    LABRITM

Local Char LZONITMDES(GLONAVA)
Local Integer NITMSALE

  # FGR 29/06/2009 : X3SUIVI56129
  If LITM = "" Then
    LDES = ""
  Else
    Call CHARGE_ITMDES(LZON, LLAN, LITM, LDES)
    If LDES = "" Then
      # FGR 02/07/2009 : X3SUIVI56270
      NITMSALE = 0
      If evalue("dim(" + LABRITM + "SBSITM)") >= 0 or LABRITM = "" Then
        # On demande par rapport ŕ ITMSALES parce que SBSITM n'existe pas dans ITMMASTER
        # Donc on change de table pour aller chercher la désignation dans ITMMASTER.
        # C'est seulement dans le cas oů la demande se fait par rapport ŕ ITMSALES qu'on bascule
        # sur ITMMASTER. Si quelqu'un fait la demander par rapport ŕ une table métier, si la désignation
        # y figure, c'est celle-lŕ qui sera prise. Le but est de ne plus utiliser ITMSALES.ITMDES1.
        NITMSALE = 1
        Local File ITMMASTER [ITM]
        LABRITM = "[F:ITM]"
        Read [ITM]ITM0=LITM
        If !fstat Then
          Raz [F:ITM]
        Endif
       Endif
      #
      Case LZON
        When "DES1AXX"
          LZONITMDES = "ITMDES1"
        When "DES2AXX"
          LZONITMDES = "ITMDES2"
        When "DES3AXX"
          LZONITMDES = "ITMDES3"
        When Default
          LZONITMDES = "ITMDES1"
      Endcase
      If evalue("dim(" + LABRITM + LZONITMDES + ")") > 0 Then
        LDES = evalue(LABRITM + LZONITMDES)
      Endif
      If NITMSALE = 1 Then
        Close Local File [ITM]
      Endif
    Endif
  Endif
End

