##################################################
Subprog CONTCPR(VALEUR)
Variable Decimal VALEUR
# Gestion article : Si pas de fournisseur-Article, pas de contrôle
If dim([M:ITP]BPSNUM) > 0 & nolign > 0
  If([M:ITP]BPSNUM(nolign-1) = ""  & [M:ITP]XBPSNUM = "") & zoncou = "XCPRCOE"  : End : Endif
Endif
If VALEUR < 1
  GMESSAGE = mess(167,187,1) : # Le coefficient doit ętre supérieur ou égal ŕ 1.
  mkstat = 2 : End
Endif

End
##################################################
#--CPO 106872 S'assurer que la taxe ramenée (valable dans le contexte de la soc courante)
#--est bien du type de la détermination paramétrée dans GESTVC
$CTL_CTX_VAT
WOK_CTX_VAT = 0

Call LEC_TVT_LEG(WDOCCURLEG,[F:TVC]VAT,WOK_CTX_VAT) From TRTLECLEG
If WOK_CTX_VAT>0 or [F:TVC]VATTYP<>[F:TVT]VATTYP
    WOK_CTX_VAT=[V]CST_AERROR
Endif

Return

