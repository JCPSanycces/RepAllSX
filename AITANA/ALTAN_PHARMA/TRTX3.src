################################################################################
# Action SELCPYLEG : Sélection d'une société pour une législation donnée       #
# ---------------------------------------------------------------------------- #
#   zone courante AZC  : Société                                               #
#   PARAM(1) = LEG     : Législation                                           #
################################################################################
$S_CPYLEG
If PARAM(1)<>""
    Raz ICRITERE, CRITERE
    Call ADDCRIT(CRITERE,ICRITERE,"","LEG='"+PARAM(1)+"'","&") From GOBJSUB
Endif
OBJET="CPY"
Return

##################################################
Subprog CONTCPYLEG(AZC,LEG)
Variable Char    AZC()
Value    Char    LEG
If AZC="" : End : Endif
If LEG="" : End : Endif
If !clalev([F:CPY]) : Local File COMPANY [CPY] : Endif
Filter [CPY] Where CPY=AZC & LEG=[L]LEG
Look [CPY] First
Filter [CPY]
If fstat
    mkstat=2
    #GMESSAGE=mess(83,123,1)
    GMESSAGE=AZC-mess(170,187,1)-'"'+LEG-'"' :#--CPO 71937 TVT Message plus parlant
Endif
End
################################################################################
# Action SELFCYLEG : Sélection d'un site pour une législation donnée       #
# ---------------------------------------------------------------------------- #
#   zone courante AZC  : Site                                               #
#   PARAM(1) = LEG     : Législation                                           #
################################################################################
$S_FCYLEG
If PARAM(1)<>""
    Raz ICRITERE, CRITERE
    Call ADDCRIT(CRITERE,ICRITERE,"","[F:FCY]LEG='"+PARAM(1)+"'","&") From GOBJSUB
Endif
OBJET="FCY"
Return

##################################################
Subprog CONTFCYLEG(AZC,LEG)
Variable Char    AZC()
Value    Char    LEG
If AZC="" : End : Endif
If LEG="" : End : Endif
If !clalev([F:FCY]) : Local File FACILITY [FCY] : Endif
Filter [FCY] Where FCY=AZC & LEG=[L]LEG
Look [FCY] First
Filter [FCY]
If fstat
    mkstat=2
    #GMESSAGE=mess(83,123,1)
    GMESSAGE=AZC-mess(171,187,1)-'"'+LEG-'"' :#--CPO 71937 TVT Message plus parlant
Endif
End

################################################################################
# Renvoie la liste des identifiant de cession en cours
################################################################################
# Paramčtre S : PADXUID = variable dimensionnée(1..x) contenant la liste des n° de session en cours
#             : PNB     = nombre de sessions
################################################################################
Subprog UIDADX(PADXUID, PNB)
Variable Integer PADXUID()
Variable Integer PNB

Local Integer NBMAX : NBMAX=dim(PADXUID)
Local Integer I, J
Local Integer STAT
Local Char    ORDSYS(250)
Local Char    RESULT(120)(1..NBMAX+2) : # GH 14/03/2014 bug 97916 (1..NBMAX)

ORDSYS = "psadx -i -l"-GLANGUE

Call SYSTEME2(adxmac(0),ORDSYS,"",STAT,RESULT) From ORDSYS

# La 2čme ligne donne le formattage
J=instr(1,vireblc(RESULT(2),1)," ")

# Traitement des lignes utilisateurs
## GH 14/03/2014 bug 97916
#I=3
#While J & I<=STAT-1 & (I-2<dim(PADXUID))
#   If I>dim(RESULT) Break Endif
#   PADXUID(I-2)=val(vireblc(seg$(RESULT(I),1,J-1),2))
#   I+=1
#Wend
#
#PNB = I-3
##

PNB=0
If J
    For I=3 To STAT-1
        If PNB >= NBMAX : Break : Endif
        PADXUID(PNB)=val(vireblc(seg$(RESULT(I),1,J-1),2))
        PNB+=1
    Next
Endif

End

######################################################################################
# GENDATPOINT : Génčre les points intermédiaires pour créer un graphique avec acsisse temporelle
######################################################################################
# Paramčtres E : PNB  = Nombre de lignes de données
#                PDAT = Tableau des dates
#                PVAL = Tableau des valeurs (1čre dim = nb de colonnes )
#                                           (2čme dim = nb de valeurs  )
#                PECH = période de l'échantillonage (ml. 52)(jour,quinzaine,mois...)
#                PRET = Code erreur (0: Pas d'erreur                     )
#                                   (1: incohérence dans les paramčtres  )
######################################################################################
# Exemple:
# PECH = 1
# PNB = 3                  -->    PNB = 7
# PDAT        PVAL         -->    PDAT        PVAL
# ----------- -----------         ----------- -----------
# 01/01/2007    1  |  1           01/01/2007    1  |  1
# 03/01/2007    3  |  2           02/01/2007    1  |  1
# 07/01/2007    7  |  3           03/01/2007    3  |  2
#                                 04/01/2007    3  |  2
#                                 05/01/2007    3  |  2
#                                 06/01/2007    3  |  2
#                                 07/01/2007    7  |  3
######################################################################################
Subprog GENDATPOINT(PNB,PDAT,PVAL,PECH,PRET)
Variable Integer PNB
Variable Date    PDAT()
Variable Decimal PVAL(,)
Value    Integer PECH
Variable Integer PRET

Raz PRET

If PNB<2 | PDAT(0)=PDAT(PNB-1) | PNB>dim(PVAL,2) | dim(PDAT)<>dim(PVAL,2)
    PRET = 1
    End
Endif

Local Integer LNBCOL, LNBLIN
LNBCOL = dim(PVAL,1)
LNBLIN = dim(PVAL,2)

Local Integer LCOL, LLIN, LNB, LLINO
Local Date    LTABDAT(LNBLIN)
Local Decimal LTABVAL(LNBCOL,LNBLIN)
Local Date    LDAT

LNB = PNB
# On sauvegarde les valeurs passées en paramčtre
For LLIN=0 To PNB-1
    For LCOL=0 To dim(PVAL,1)-1
        LTABVAL(LCOL,LLIN) = PVAL(LCOL,LLIN)
    Next
    LTABDAT(LLIN) = PDAT(LLIN)
Next

Raz PDAT, PVAL, PNB
LDAT = LTABDAT(0)
Raz LLIN, LLINO
While LDAT<=LTABDAT(LNB-1)
    I=LLINO+1
    While I<=LNB-1 & LTABDAT(I)<=LDAT
        I+=1
    Wend
    LLINO=I-1
    PDAT(LLIN) = LDAT
    For LCOL=0 To LNBCOL-1
        PVAL(LCOL,LLIN) = LTABVAL(LCOL,LLINO)
    Next
    LLIN+=1
    Case PECH
        When 1 : LDAT += 1
        When 2 : LDAT += 7
        When 3 : LDAT += 14
        When 4 : LDAT = addmonth(LDAT,+1)
        When 5 : LDAT = addmonth(LDAT,+3)
        When 6 : LDAT = addmonth(LDAT,+12)
        When 7 : LDAT = addmonth(LDAT,+120)
        When Default : Break
    Endcase
    If LLIN>=LNBLIN
        Break
    Endif
Wend
PNB = LLIN
End


##############################################################################
# Action SELDOC : Sélection documents Crystal Report avec filtres et options #
# -------------------------------------------------------------------------- #
#   zone courante AZC  : Code état                              MBT 04/12/07 #
#   PARAM(1) = FILTRE  : Critčres pour le filtre                             #
#   PARAM(2) = OPTIONA : Options de l'objet ARP                              #
##############################################################################
$S_SELDOC
If PARAM(1)="" PARAM(1)="1=1" : Endif
CRITERE(1)=PARAM(1)
OPTIONS=PARAM(2)
OBJET="ARP" : # Classement par groupe + code état
Return


#########################################################
# Arrondi une valeur en fonction d'un type de donnée
#########################################################
# Paramčtres E : PTAB, PZON = Nom de table et de zone servant ŕ déterminer le type de donnée
#                PTYP = Type de donnée si PTAB ou PZON non renseigné
#                PVAL = Valeur ŕ arrondir
#########################################################
Funprog ARRTYP(PTAB, PZON, PTYP, PVAL)
Value Char PTAB, PZON
Value Char PTYP
Value Decimal PVAL

Local Decimal LRNDVAL

If PTAB<>"" & PZON<>""
   If !clalev([F:ATZ]) : Local File ATABZON [ATZ] : Endif
   If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
   Read [F:ATZ]CODZONE=PTAB;PZON
   Read [ATY]CODTYP=[F:ATZ]CODTYP
   If fstat = 0
      LRNDVAL=arr(PVAL,10^-(mod([F:ATY]LNGTYP,1)*10))
   Endif
Else
   If !clalev([F:ATY]) : Local File ATYPE [ATY] : Endif
   Read [ATY]CODTYP=PTYP
   If fstat = 0
      LRNDVAL=arr(PVAL,10^-(mod([F:ATY]LNGTYP,1)*10))
   Endif
Endif
End LRNDVAL


################################################################################
# INIPTE : S/P Recherche des Conditions de Paiement par Tiers  #JPGA 30/06/2008#
#     (Recherche par déclinaison société puis par tiers client ou fournisseur) #
# ---------------------------------------------------------------------------- #
# Subprog INIPTE (WBPRPAY, WBPRINV, WBPRTYP, WPTE)                             #
# ---------------------------------------------------------------------------- #
# Entrée : WBPRPAY : Client ou Fournisseur Payeur                              #
#          WBPRINV : Client ou Fournisseur Facture                             #
#          WBPRTYP : Type tiers Client ou Fournisseur ("C" ou "F")             #
# Sortie : WPTE    : Code Conditions de paiement                               #
# ---------------------------------------------------------------------------- #
# Attention : Utilisation de la variable GPAYTERM                              #
# Attention : Utilisation de la variable GSOCIETE pour recherche dans BPEXCEPT #
################################################################################
Subprog INIPTE (WBPRPAY, WBPRINV, WBPRTYP, WPTE)
Value    Char   WBPRPAY
Value    Char   WBPRINV
Value    Char   WBPRTYP
Variable Char   WPTE

Local    Char   WSVGBPR(GLONBPR)
Local    Char   WBPR(GLONBPR)

  # Test des Variables en Entrée
  If WBPRPAY = "" End Endif
  If WBPRTYP <>"C" & WBPRTYP <>"F" End Endif

  # Ouverture éventuelle fichier et Sauvegarde Tiers courant pour restauration aprčs traitement
  Case WBPRTYP
    When "C"
      If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
      [L]WSVGBPR = [F:BPC]BPCNUM
    When "F"
      If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
      [L]WSVGBPR = [F:BPS]BPSNUM
  Endcase

  # Recherche Tiers adéquat en fonction de GPAYTERM
  Case GPAYTERM
    When 1
      # Initialisation de la condition ŕ partir du Tiers payeur
      If WBPRPAY <> [L]WSVGBPR
        Case WBPRTYP
          When "C"
            Read [BPC] BPC0=WBPRPAY
          When "F"
            Read [BPS] BPS0=WBPRPAY
        Endcase
        If !fstat
          [L]WBPR = WBPRPAY
        Else
          # Tiers payeur non trouvé, Pas de condition de paiement : On prend celle du Tiers facture
          [L]WBPR = WBPRINV
        Endif
      Else
          [L]WBPR = WBPRPAY
      Endif
    When 2
      # Initialisation de la condition ŕ partir du Tiers facture
      [L]WBPR = WBPRINV
    When Default
      # Initialisation de la condition ŕ partir du Tiers facture
      [L]WBPR = WBPRINV
  Endcase

  # ACA (2009-09-04) Bug 56794 : Cde : conditions paiement initialisées par client commandé
  GPOINT="PTEBPR" : Gosub ENTREE From EXEFNC

  # Recherche Conditions de paiement par déclinaison Société
  Call INIT_CONDITIONS([L]WBPR, GSOCIETE, WBPRTYP, WPTE) From CPTSUB

  # Restauration du Tiers sauvegardé
  If [L]WSVGBPR <> ""
    Case WBPRTYP
      When "C"
        If [F:BPC]BPCNUM <> [L]WSVGBPR
          Read [BPC] BPC0=[L]WSVGBPR
          If fstat Raz [F:BPC] : Endif
        Endif
      When "F"
        If [F:BPS]BPSNUM <> [L]WSVGBPR
          Read [BPS] BPS0=[L]WSVGBPR
          If fstat Raz [F:BPS] : Endif
        Endif
    Endcase
  Endif
End

################################################################################
# Rend invisible le code législation et son intitulé si mono-législation
################################################################################
Subprog FMTLEG
If evalue("dim("+clanam([M])+"LEG)")>0
    If func AFNC.ACTIV("LEG")=0
        Chgfmt [M]LEG With "-K:"+num$(GLONADI)+"B"
        If evalue("dim("+clanam([M])+"ZLEG)")>0
            Chgfmt [M]ZLEG With "-K:"+num$(type([M]ZLEG)-10)+"X"
        Endif
    Endif
Endif
End

Subprog GLOBVAR(SITE, MODUL)
Value Char SITE  # Site (FCY)
Value Char MODUL # Module (ACH, VEN, ...)
Local Char LPARAM
    Case MODUL
      When "VEN"
          # Global Char GSALDSPVOU
          # Global Char GSALDSPWEU
          Call PARAM(SITE,"SALDSPVOU",GSALDSPVOU) From ADOVAL
          Call PARAM(SITE,"SALDSPWEU",GSALDSPWEU) From ADOVAL
          Call PARAM(SITE,"DEPMGTMOD",LPARAM) From ADOVAL : GDEPMGTMOD=val(LPARAM)
      When "ACH"
    Endcase

    Call GLOBVAR(SITE) From ="WWGLOB"+MODUL

End

################################################################################
$VERF_PARAM
Return

################################################################################
# Site par défaut Beryl V6.0                                          FQ 54361 #
################################################################################
Subprog FIND_GFCYDEF( LMODULE )
Value Integer LMODULE

Local Integer IFCY
GFCY=GFCYDEF(LMODULE)
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    If !find(GFCY,GUSRFCY(1..GNBAUZ))
       If !clalev([F:FCY])  Local File FACILITY [FCY] : Endif  # FQ 58854
       For IFCY=1 To GNBAUZ
           GFCY=GUSRFCY(IFCY) : # site autorisé
           Read [FCY]FCY0=GFCY : If fstat Raz [F:FCY] Endif
           Case LMODULE
             When 5 : # Site Vente ?
                  If [F:FCY]SALFLG=2
                     Break
                  Endif
             When 6 : # Site Achat ?
                  If [F:FCY]PURFLG=2
                     Break
                  Endif
             When 7 : # Dépot ?
                  If [F:FCY]WRHFLG=2
                     Break
                  Endif
             When 8 : # Site Production ?
                  If [F:FCY]MFGFLG=2
                     Break
                  Endif
             When 2 : # Site financier ?
                  If [F:FCY]FINFLG=2
                     Break
                  Endif
             When Default : # on prend le 1er site autorisé
                  Break
           Endcase
       Next IFCY
    Endif
Endif

End


#########################################################################
# GETFCYDEF : S/P de chargement du site par défaut         MBT 08/04/09 #
# --------------------------------------------------------------------- #
# Subprog GETFCYDEF (WSITE,WFILTRE)                                     #
#   Sous-programme appelé en principe dans les action $OUVRE et $RAZCRE #
#   des objets                                                          #
# --------------------------------------------------------------------- #
#   WSITE   : Site par défaut                                           #
#             pré-renseigné par GFCYDEF(x) ou GFINRSP                   #
#   WFILTRE : Filtre du site recherché                                  #
#             exemples  "[F:FCY]PURFLG=2"                               #
#                       "[F:FCY]SALFLG=2"                               #
#                       "[F:FCY]FINFLG=2 & [F:FCY]LEGCPY=GSOCIETE"      #
#########################################################################
Subprog GETFCYDEF(WSITE,WFILTRE)
Variable Char    WSITE
Value    Char    WFILTRE
#-----
If !clalev([F:FCY])  Local File FACILITY [FCY] : Endif
If WFILTRE=""  WFILTRE="1=1" : Endif
#----- Si le site est renseigné, on vérifie si autorisé et conforme au filtre -----#
If WSITE<>"" & (GUSRFCY(1)="\" | GNBAUZ=GNBSITE | find(WSITE,GUSRFCY(1..GNBAUZ)))
  Read [FCY] FCY0=WSITE : If fstat  Raz [F:FCY] : Endif
  If evalue(WFILTRE)  End : Endif
Endif
#----- Recherche d'un site parmi les sites autorisés -----#
Local Integer I
Raz WSITE
For I=1 To GNBAUZ
  If GUSRFCY(1)="\"
    For [FCY] FCY0 Where evalue(WFILTRE)
      WSITE=[F:FCY]FCY : Break
    Next
  Else
    Read [FCY] FCY0=GUSRFCY(I) : If fstat  Raz [F:FCY] : Endif
    If evalue(WFILTRE)  WSITE=[F:FCY]FCY : Break : Endif
  Endif
Next I
#-----
End

#########################################################################
# ACTIV_PTX : récup du code activité PTX                                #
# --------------------------------------------------------------------- #
#########################################################################
Funprog ACTIV_PTX
If dim(GACTPTX)<1
  Call SET_ACTIVPTX
Endif
End GACTPTX

#########################################################################
# SET_ACTIVPTX : S/P de chargement du code activité PTX                 #
# --------------------------------------------------------------------- #
#########################################################################
Subprog SET_ACTIVPTX
If clalev([F:ACV])=0 : Local File ACTIV [ACV] : Endif
If dim(GACTPTX)<1  Global Libelle  GACTPTX : Endif
If [F:ACV]CODACT<>"PTX"
  Read [ACV]CODACT = "PTX"
Endif
If [F:ACV]CODACT<>"PTX" or [F:ACV]FLACT<>2
 GACTPTX=0
Elsif [F:ACV]TYP=2
 GACTPTX=[F:ACV]DIME
Else
 GACTPTX=1
Endif
End

#----- Ajout d'un critčre supplémentaire sur VACBPR et VACITM #gbn-Fq76004
$SET_LCRITITMBPR
 Local Char LCRITITMBPR(255)
 If dim([F:TLK]VACITM)>0
  If [F:TLK]VACITM<>""
   LCRITITMBPR="(VACITM='"+[F:TLK]VACITM+"')"
  Endif
 Endif
 If dim([F:TLK]VACBPR)>0
  If LCRITITMBPR<>""
   LCRITITMBPR+="|(VACBPR='"+[F:TLK]VACBPR+"')"
  Else
   LCRITITMBPR="(VACBPR='"+[F:TLK]VACBPR+"')"
  Endif
 Endif
 If LCRITITMBPR=""
  LCRITITMBPR="1=1"
 Endif
Return

