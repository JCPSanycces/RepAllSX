#SR947.bn
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
If [M:BIS0]BPR <> ""
#   Alimentation flag inter-site et inter-société
    Call ALIBETCPY(5,VALEUR,[M:BIS0]BPR,GBIDC1,GBIDC2,GBIDC3,[M:BIS0]YINTER,[M:BIS0]YINTER) From TRTVENISOC
Endif
Affzo [M:BIS0]YINTER
End

Subprog AM_BPR(VALEUR)
Variable Char    VALEUR()
If [M:BIS0]FCY <> ""
#   Alimentation flag inter-site et inter-société
    Call ALIBETCPY(5,[M:BIS0]FCY,VALEUR,GBIDC1,GBIDC2,GBIDC3,[M:BIS0]YINTER,[M:BIS0]YINTER) From TRTVENISOC
Endif
Affzo [M:BIS0]YINTER
End

