# GestiÛn de la m·scara POH2 (Especifico)
# 001055 - XVT20180924 - SÛlo el usuario creaciÛn puede modificar registro
# 001165 - XVT20181008 - Usuarios con perfil funciÛn ADGF1 tambiÈn deben poder modificar
# 001263 - XVT20190207 - SÛlo el usuario creaciÛn puede modificar registro

######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla POH2) 31/10/2017 09:38:56 (ADMIN)
######################################################################################
$ACTION
Case ACTION
 When "OUVRE"     Gosub OUVRE      #001165.n
 When "AVANT_MOD" Gosub AVANT_MOD  #001055.n
 When "SETBOUT"   Gosub SETBOUT    #001055.n
 When Default
Endcase
Return

#001165.BN
$OUVRE
  If !clalev ([ZAUS]) : Local File AUTILIS[ZAUS] : Endif
  Local Integer PERMIT : PERMIT = 0
#  Gosub READUSERDATA    # 001263.o
Return

#001165.EN

#001055.bn

$AVANT_MOD
 If PERMIT : Return : Endif   #001165.N
 If [F:POH]CREUSR <> GUSER and GFLAG<>"ALL" Then
   Call MESSAGE("No permitido") From GESECRAN
   OK=0
 Endif
Return


$SETBOUT
 If PERMIT : Return : Endif   #001165.N
 If [F:POH]CREUSR <> GUSER and GFLAG<>"ALL" Then
   Call VIREBOUT(CHAINE,"AS") From GOBJET
   Call VIREBOUT(CHAINE,"2") From GOBJET
 Endif
Return

#001055.en

#001165.BN
$READUSERDATA
  Read [F:ZAUS]CODUSR=GUSER
  If !fstat Then
    If [F:ZAUS]PRFFCT="ADGF1" Then
      PERMIT=1
    Else
      PERMIT=0
    Endif
  Endif
Return
#001165.EN

Subprog C_EXTRCPDAT(VALEUR)
Variable Date    VALEUR
  If VALEUR < date$ Then
    Call MESSAGE ("La fecha de recepciÛn ha de ser mayor o igual a la fecha actual") From GESECRAN
    mkstat = 2
  Endif
End


