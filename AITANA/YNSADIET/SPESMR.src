#######################################################################################

$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "APRES_MODIF"  : Gosub APRES_MODIF
  When "FIN"          : Gosub FIN
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
  Gosub ABRIR_TABLAS
Return

##############################################################
$FIN
  Gosub CERRAR_TABLAS
Return

##############################################################
$APRES_MODIF
# YN01 - Parrilla de recepción
  If !GIMPORT Then
    Gosub ACT_ESTADO
  Endif
# YN01 - Parrilla de recepción
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ABRIR_TABLAS
# YN01 - Parrilla de recepción
  If !clalev([F:YTR0]) Then : Local File YMFGTRAZAPR [F:YTR0] : Endif
  If !clalev([F:YMP0]) Then : Local File YMFGHEADPP  [F:YMP0] : Endif
  If !clalev([F:YDP0]) Then : Local File YMFGDUPLIPP [F:YDP0] : Endif
# YN01 - Parrilla de recepción
Return

##############################################################
$CERRAR_TABLAS
# YN01 - Parrilla de recepción
  If clalev([F:YTR0])  Then : Close Local File     [F:YTR0] : Endif
  If clalev([F:YMP0])  Then : Close Local File     [F:YMP0] : Endif
  If clalev([F:YDP0])  Then : Close Local File     [F:YDP0] : Endif
# YN01 - Parrilla de recepción
Return

##############################################################
# YN01 - Parrilla de recepción
# muestra el estado para un artículo/lote si se le ha cambiado
# primero desde la parrilla de recepción, segundo desde la parrilla de producción (original y duplicado)
$ACT_ESTADO
Local Integer LNOL : Raz LNOL

  LNOL = nolign-1
# JC.28092020.SP-51.9.STR
#  Filter [F:YTR0] Where ITMREF = [M:SMR1]ITMREF(LNOL) and LOT = [M:SMR1]BPSLOT(LNOL) Order By UPDDATTIM Desc
#  Read   [F:YTR0] First
#  If !fstat Then                                            # encuentra ese artículo/lote en la tabla de trazabilidad parrilla recepción
#    [M:SMR1]STA(LNOL) = [F:YTR0]STA
#    Affzo [M:SMR1]STA(LNOL)
#  Else
#    Filter [F:YMP0] Where ITMREF = [M:SMR1]ITMREF(LNOL) and LOT = [M:SMR1]BPSLOT(LNOL) Order By UPDDATTIM Desc
#    Read   [F:YMP0] First
#    If !fstat Then                                          # encuentra ese artículo/lote en la tabla de trazabilidad parrilla producción
#      [M:SMR1]STA(LNOL) = [F:YMP0]ESTADO
#      Affzo [M:SMR1]STA(LNOL)
#    Else
#      Filter [F:YDP0] Where ITMREF = [M:SMR1]ITMREF(LNOL) and LOT = [M:SMR1]BPSLOT(LNOL) Order By UPDDATTIM Desc
#      Read   [F:YDP0] First
#      If !fstat Then                                        # encuentra ese artículo/lote en la tabla de trazabilidad parrilla producción
#        [M:SMR1]STA(LNOL) = [F:YMP0]ESTADO
#        Affzo [M:SMR1]STA(LNOL)
#      Endif
#    Endif
#  Endif
#  Filter [F:YTR0] : Filter [F:YMP0] : Filter [F:YDP0]
# JC.28092020.SP-51.9.END
  Kill LNOL

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Después del campo 'Lote'
######################################################################################
Subprog AP_LOT(VALEUR)
Variable Char    VALEUR()
# JC.28092020.SP-51.9.STR
  If !clalev([F:ITM0]) Then : Local File ITMMASTER    [F:ITM0] : Endif
  If !clalev([F:YMP0]) Then : Local File YMFGHEADPP   [F:YMP0] : Endif
  If !clalev([F:YTR0]) Then : Local File YMFGTRAZAPR  [F:YTR0] : Endif
  Read [F:ITM0]ITM0 = [M:SMR1]ITMREF(nolign-1)
  If !fstat Then
    If [M:SMR0]STOFCY = "101" and ([F:ITM0]TCLCOD = "YNPI" or [F:ITM0]TCLCOD = "YNPT") Then
      Filter [F:YMP0] Where ITMREF = [M:SMR1]ITMREF(nolign-1) and LOT = VALEUR
      Read [F:YMP0] First
      If !fstat Then
        [M:SMR1]STA(nolign-1) = [F:YMP0]ESTADO
        Affzo [M:SMR1]STA(nolign-1)
      Endif
      Filter [F:YMP0]
    Elsif [M:SMR0]STOFCY = "101" and ([F:ITM0]TCLCOD = "YNMP" or [F:ITM0]TCLCOD = "YNMA" or [F:ITM0]TCLCOD = "YNMS") Then
      Filter [F:YTR0] Where ITMREF = [M:SMR1]ITMREF(nolign-1) and LOT = VALEUR Order By UPDDATTIM Desc
      Read   [F:YTR0] First
      If !fstat Then
        [M:SMR1]STA(nolign-1) = [F:YTR0]STA
        Affzo [M:SMR1]STA(nolign-1)
      Endif
      Filter [F:YTR0]
    Endif
  Endif
  Close Local File [ITM0],[YMP0],[YTR0]
# JC.28092020.SP-51.9.END
End


##############################################################
##################    FUNCIONES PROPIAS    ###################
