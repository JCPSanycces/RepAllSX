######################################################################################
## 'Después de modificar' el campo 'Comentario 2' (USRFLD2)
######################################################################################
# YN14
Subprog AM_USRFLD2(VALEUR)
Variable Char    VALEUR()

  If !clalev([F:ITM0]) Then : Local File ITMMASTER [F:ITM0] : Endif
  Read [F:ITM0]ITM0 = [M:ENTL]ITMREF
  If !fstat Then
    If [F:ITM0]YREFERENITM <> "" and VALEUR <> [F:ITM0]YREFERENITM Then
      Call MESSAGE("Referencia no coincidente") From GESECRAN
    Endif
  Endif
  If  clalev([F:ITM0]) Then : Close Local File     [F:ITM0] : Endif

End


