#<AdxTL>@(#)0.0.0.0 $Revision$
############################################################
# obtención de la imagen adjunta a un artículo
Subprog GETIMAGE(PITM,PIMG,PRET)
Value     Char PITM
Variable  Blbfile PIMG
Variable  Integer PRET

  If !clalev([F:CBB0]) Then : Local File CBLOB [F:CBB0] : Endif
  If PITM = "" Then
    PRET = 0
    End
  Endif

  Read [F:CBB0]CBB0 = "ITM";PITM;""
  If !fstat Then
    PIMG = [F:CBB0]BLOB
    PRET = 1
  Else
    PRET = 0
  Endif
  If clalev([F:CBB0])  Then : Local File CBLOB [F:CBB0] : Endif
End

############################################################
# adición de una imagen a un artículo
Subprog SETIMAGE(PITM,PIMG,PRET)
Value     Char PITM
Value     Char PIMG
Variable  Integer PRET

  If !clalev([F:CBB0]) Then : Local File CBLOB [F:CBB0] : Endif
  If PITM = "" or PIMG = "" Then
    PRET = 0
    End
  Endif

  Read [F:CBB0]CBB0 = "ITM";PITM;""
  Trbegin [F:CBB0]
  If !fstat Then
    [F:CBB0]BLOB = PIMG
    Rewrite [F:CBB0]
  Else
    [F:CBB0]CODBLB  = "ITM"
    [F:CBB0]IDENT1  = PITM
    [F:CBB0]TYPBLB  = 3
    [F:CBB0]BLOB    = PIMB
    Rewrite [F:CBB0]
  Endif
  If !fstat Then
    PRET = 1
    Commit
  Else
    PRET = 0
    Rollback
  Endif

  If clalev([F:CBB0])  Then : Local File CBLOB [F:CBB0] : Endif

End

