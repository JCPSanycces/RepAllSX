# Gestión de la máscara VXABP (Especifico)

######################################################################################
## Después de modificar el campo Nº vale preparación
######################################################################################
Subprog AM_PRHNUM(VALEUR)
Variable Char    VALEUR()
  # se guarda el número de vale de preparación para utilizarlo en el script VXABP
  GNUMVP = VALEUR
End

