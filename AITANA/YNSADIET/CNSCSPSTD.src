#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# CNSCSPSTD : Consultation des lignes de commandes ventes               #
# ECRAN 1   : CONSCSP1                                                  #
# ECRAN 2   : CONSCSP2                                                  #
# ECRAN CRIT: CRITCSP                                                   #
#########################################################################
# YYN45: Modificaciones AITANA
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "DEB_CRIT"   : Gosub DEB_CRIT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When Default
Endcase
Return

############################################################
$AUTORIS
Return
###################################################################
# analyse paramères, initialisations, ouvertures et déclarations  #
###################################################################
$OUVRE
Local Char    WFIL(250),WFIL1(250),WFIL2(250)
Local Char    DEBNUM, FINNUM, WSOHNUM
Local Date    DEBDAT, FINDAT
Local Integer DEBLIN, FINLIN :# 69747
#MAE, on ajoute la consultation dans la pile de la navigation
NAVIG= "CONSCSP"

If clalev([F:DUD])=0 Local File GACCDUDATE [DUD] : Endif
If clalev([F:SOQ])=0 Local File SORDERQ [SOQ] : Endif
If clalev([F:TCU])=0 Local File TABCUR [TCU]  : Endif
If clalev([F:AMZ])=0 Local File AMSKZON [AMZ]  : Endif
If clalev([F:SOH])=0 Local File SORDER [SOH] : Endif
If clalev([F:SOP])=0 Local File SORDERP [SOP] : Endif

Gosub DEFCRIT

Return

# --------------------------------------------------------------------------#
# Analyse paramères, initialisations                                        #
# --------------------------------------------------------------------------#
$DEFCRIT
If [M:CSP1]SALFCY<>"" & GUSRFCY(1)<>"\" & !find([M:CSP1]SALFCY,GUSRFCY(1..GNBAUZ))
 [M:CSP1]SALFCY=""
Endif

For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre article
      If PARAM(I) <> ""
        If [F:ITM]ITMREF<>PARAM(I) Read [F:ITM]ITM0 = PARAM(I)
                                     If fstat
                                       Raz [F:ITM], PARAM(I)
                                     Endif
        Endif
        [M:CSP1]ITMREF = PARAM(I)
      Endif
    When 2 :    : # Parametre client
      If PARAM(I) <> ""
        If [F:BPC]BPCNUM<>PARAM(I) Read [F:BPC]BPC0 = PARAM(I)
                                     If fstat
                                       Raz [F:BPC], PARAM(I)
                                     Endif
        Endif
        [M:CSP1]BPCORD = PARAM(I)
      Endif

    When 3 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)    Read [F:FCY]FCY0 = PARAM(I)
                                     If fstat
                                       Raz [F:FCY], PARAM(I)
                                     Endif
        Endif
        If GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ))
           [M:CSP1]SALFCY = PARAM(I)
           If [M:CSP1]SALFCY <> ""
             Call GETDEV([M:CSP1]SALFCY) From DEVSUB
             [M:CSP1]CPY  = GSOCIETE
           Endif
        Endif
      Endif
    When 4 :    : # Parametre PJT
      # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
      If PARAM(I) <> "" Then
        [M:CSP1]PJTDEB = PARAM(I)
        [M:CSP1]PJTFIN = PARAM(I)
        If find(GNAVIG(GPILNAV-0),"GESPJM") Then   # Note FGR : '-0' is not an error. This is true in this case.
          [M:CSP1]PJTDSPALL = [V]CST_AYES
        Endif
      Endif
      # Issue Issue X3-15598 - 2017-02-23 by FGR : END
    When 5 :    : # Parametre DATBEG
      # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
      If PARAM(I) <> ""  and PARAM(I) <> "000000" Then
        [M:CSP1]ORDDATDEB = PARAM(I)
        [M:CSP1]ORDDATDEB = gdat$(01,month([M:CSP1]ORDDATDEB),year([M:CSP1]ORDDATDEB))
      Endif
      # Issue Issue X3-15598 - 2017-02-23 by FGR : END
  Endcase
Next I

If !find([M:CSP1]SOHCATNOR,1,2) : [M:CSP1]SOHCATNOR = 2 : Endif
If !find([M:CSP1]SOHCATLND,1,2) : [M:CSP1]SOHCATLND = 2 : Endif
If !find([M:CSP1]SOHCATFAC,1,2) : [M:CSP1]SOHCATFAC = 2 : Endif
If !find([M:CSP1]ORDSTAO,1,2)   : [M:CSP1]ORDSTAO = 2 : Endif
If !find([M:CSP1]ORDSTAN,1,2)   : [M:CSP1]ORDSTAN = 2 : Endif
If !find([M:CSP1]APPFLGO,1,2)   : [M:CSP1]APPFLGO= 2 : Endif
If !find([M:CSP1]APPFLGN,1,2)   : [M:CSP1]APPFLGN= 2 : Endif
If !find([M:CCSP]TRI,1,2)       : [M:CCSP]TRI = 1   : Endif
If !find([M:CCSP]FMI,11,15)     : [M:CCSP]FMI = 11  : Endif

[M:CSP1]ORDDATFIN=eomonth(date$)
# Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
#[M:CSP1]ORDDATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))
If [M:CSP1]ORDDATDEB = [0/0/0] Then
  [M:CSP1]ORDDATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))
Endif
# Issue Issue X3-15598 - 2017-02-23 by FGR : END

# -- copie de l'écran critères (CCSP) vers le masque 1 (CSP1)
Gosub CRITENT From =PROGCNS

Return

############################################################
$DEB_CRIT
#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM","GESITF")
        If find(GNAVIG(GPILNAV-1),"GESITM")
            Diszo [M:CCSP]ITMREF
        Elsif find(GNAVIG(GPILNAV-1),"GESITF")
            Diszo [M:CCSP]ITMREF
            Diszo [M:CCSP]SALFCY
            Diszo [M:CCSP]CPY
        Endif
        If dim([M:CCSP]TSICOD) > 0
          For I = 0 To dim([M:CCSP]TSICOD)-1
            Diszo [M:CCSP]TSICOD(I)
          Next I
        Endif
    Endif
    #acces depuis clients ou fournisseurs
    If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC")
        Diszo [M:CCSP]BPCORD
        #Fq74943-Gbn-On faisait référence à TSICOD au lieu de TSCCOD
        If dim([M:CCSP]TSCCOD) > 0
          For I = 0 To dim([M:CCSP]TSCCOD)-1
            Diszo [M:CCSP]TSCCOD(I)
          Next I
        Endif
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:CCSP]PJTDEB
      Diszo [M:CCSP]PJTFIN
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : END
Endif

Return

############################################################
$LECTURE
Local   Decimal  WMNTORG(0..5), WMNTDES(0..5)
Local   Integer  SPSTAT, WFIC_FIL

If GPILNAV>1
    #acces depuis article ou article site
    If find(GNAVIG(GPILNAV-1),"GESITM")
        Diszo [M:CSP1]ITMREF
    Elsif find(GNAVIG(GPILNAV-1),"GESITF")
        Diszo [M:CSP1]ITMREF
        Diszo [M:CSP1]SALFCY
        Diszo [M:CSP1]CPY
    Endif

    #acces depuis clients ou fournisseurs
    If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC")
        Diszo [M:CSP1]BPCORD
    Endif

    # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:CSP1]PJTDEB
      Diszo [M:CSP1]PJTFIN
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : END

    # GRNA 16/05/2011
    Local Char CUSSEAORI : CUSSEAORI = "CSP1"
    Gosub LECTURE From CUSSEALIB
Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif


Link [SOQ] With [SOH]SOH0=[SOQ]SOHNUM,
&               [SOP]SOP0=[SOQ]SOHNUM;[SOQ]SOPLIN;[SOQ]SOQSEQ
&          As [LNK]

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #
#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCSP]TRI
      When 1 : # tri par numéro

            Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SOQ0
      When 2 : # tri par date
            Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                        Order By Key CLE=[F:SOQ]ORDDAT;[F:SOQ]SOHNUM;[F:SOQ]SOPLIN :# 69747
#&                        Order By Key CLE=[F:SOQ]ORDDAT;[F:SOQ]SOHNUM
   Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCSP]TRI
      When 1 : # tri par numéro
            Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SOQ0 Desc
      When 2 : # tri par date
            Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                        Order By [F:SOQ]ORDDAT Desc ;[F:SOQ]SOHNUM Desc;[F:SOQ]SOPLIN Desc :# 69747
#&                        Order By [F:SOQ]ORDDAT Desc ;[F:SOQ]SOHNUM Desc
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CSP2] : Endif

#-- lecture
$BOUCLE
    For [LNK] With Nohint
      # Filtre sur la société
      If [M:CSP1]CPY <> ""
          If [F:FCY]FCY <> [F:SOQ]SALFCY Read [F:FCY]FCY0 = [F:SOQ]SALFCY
                                         If fstat  Raz [F:FCY] : Endif
                                         Endif
          If [F:FCY]LEGCPY <> [M:CSP1]CPY Goto SUIV : Endif
      Endif
      Gosub CHARGE_CNS
      If CHGPAG > 0 & NOL >= MAXLIG-1 & SUITE=2
          Break
      Elsif CHGPAG <= 0 & NOL <= 0 & RETOUR=2
          Break
      Endif
      $SUIV
    Next

Filter [LNK]

Return


############################################################
#    Chargement de l'écran de consultation                 #
############################################################
$CHARGE_CNS

If NBLU = 1
    If CHGPAG=2 | CHGPAG=-2 : Raz [M:CSP2] : Endif
    NBLU = 2
Endif
If CHGPAG > 0
#     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
    If NOL >= MAXLIG-1 : SUITE=2 : Return : Endif
    NOL    += 1
    If NOL=0
        #69747
        If CHGPAG=2
          If [F:SOQ]SOHNUM=FINNUM and [F:SOQ]SOPLIN<=FINLIN : NOL-=1 : Return : Endif
        Endif
        #fin 69747
        DEBNUM = [F:SOQ]SOHNUM
        DEBDAT = [F:SOQ]ORDDAT
        DEBLIN = [F:SOQ]SOPLIN :# 69747
    Endif
    FINNUM = [F:SOQ]SOHNUM
    FINDAT = [F:SOQ]ORDDAT
    FINLIN = [F:SOQ]SOPLIN :# 69747
Else
#     If NOL <= 0 : RETOUR=2 : Break : Endif
    If NOL <= 0 : RETOUR=2 : Return : Endif
    NOL    -= 1
    If NOL=MAXLIG-1
        #69747
        If CHGPAG=-2
          If [F:SOQ]SOHNUM=DEBNUM and [F:SOQ]SOPLIN>=DEBLIN : NOL+=1 : Return : Endif
        Endif
        #fin 69747
        FINNUM = [F:SOQ]SOHNUM
        FINDAT = [F:SOQ]ORDDAT
        FINLIN = [F:SOQ]SOPLIN :# 69747
    Endif
    DEBNUM = [F:SOQ]SOHNUM
    DEBDAT = [F:SOQ]ORDDAT
    DEBLIN = [F:SOQ]SOPLIN :# 69747
Endif

# Modifié par Dominique BOPP après discussion avec Jacky LESAGE
# Objectif : disposer d'un maximum de rubriques possibles dans l'écran de consultation des devis
  nolign = NOL+1
  [M:CSP2]=[F:SOH] : # trans classe sur SORDERH
  [M:CSP2]=[F:SOQ] : # trans classe sur SORDERQ
  [M:CSP2]=[F:SOP] : # trans classe sur SORDERP
#--CPO 82370 Il n'y a pas de montant HT et TTC sur les F des lignes (à calculer)
#--Code repris depuis SUBSOHB.CALC_ORD
Local Decimal MNTCALC
Local Char VAT(GLONVAT)(3)
VAT (0) = [F:SOP]VAT(0)
VAT (1) = [F:SOP]VAT(1)
VAT (2) = [F:SOP]VAT(2)

# 107888 : Scheduled invoices : (LD:01/04/16)
If [F:SOH]SOHCAT = 3 | [F:SOQ]DLVFLG=1
    # For Direct invoicing order
    # For Undeliverable item  (Direct order/Direct invoicing order)
    # Feed of Quantity on invoice instead of Being delivered qty
    Raz [M:CSP2]ODLQTY(NOL)
    [M:CSP2]OINQTY(NOL)=[F:SOQ]ODLQTY
Else
    Raz [M:CSP2]OINQTY(NOL)
Endif
# 107888 : Scheduled invoices : (LD:01/04/16)

If [F:SOH]PRITYP<>2
    # Montant net HT commandé de la ligne
    MNTCALC = [F:SOQ]QTY * [F:SOP]NETPRINOT
    Call ARRDEV (MNTCALC, [F:SOH]CUR) From TRTDIV
    [M:CSP2]ORDNOT(NOL) = MNTCALC
    # Montant net TTC commandé de la ligne
    Call CLCTAXEMNTV([M:CSP2]ORDNOT(NOL),VAT,[F:SOH]PRITYP,[F:SOH]CPY,[F:SOH]ORDDAT,[F:SOH]VACBPR,[F:SOP]CLCAMT1,[F:SOP]CLCAMT2,
&                   MNTCALC) From TRTX3
    Call ARRDEV (MNTCALC, [F:SOH]CUR) From TRTDIV
    [M:CSP2]ORDATI(NOL) = MNTCALC
Else
    # Montant net TTC commandé de la ligne
    MNTCALC = [F:SOQ]QTY * [F:SOP]NETPRIATI
    Call ARRDEV (MNTCALC, [F:SOH]CUR) From TRTDIV
    [M:CSP2]ORDATI(NOL) = MNTCALC
    # Montant net HT commandé de la ligne
    Call CLCTAXEMNTV([M:CSP2]ORDATI(NOL),VAT,[F:SOH]PRITYP,[F:SOH]CPY,[F:SOH]ORDDAT,[F:SOH]VACBPR,[F:SOP]CLCAMT1,[F:SOP]CLCAMT2,
&                   MNTCALC) From TRTX3
    Call ARRDEV (MNTCALC, [F:SOH]CUR) From TRTDIV
    [M:CSP2]ORDNOT(NOL) = MNTCALC
Endif
#--/CPO

Raz WMNTORG
Return

############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER
WFIL    = "1=1"
WFIL1   = "1=1"
WFIL2   = "1=1"

WFIC_FIL=0

If [M:CSP1]SALFCY <> ""
  #WFIL += "&[F:SOQ]SALFCY=[M:CSP1]SALFCY" # Issue X3-137045 - 2019-04-18 by RBA
  Call ADD_FILTER("&[F:SOQ]SALFCY=[M:CSP1]SALFCY", WFIL, WFIL1, WFIL2)
Endif
#    Autorisation site
#MAE, utilisation des habilitations des utilisateurs même si le site est vide
#If GUSRFCY(1)<>"\" & [M:CSP1]SALFCY <> "" & GNBAUZ<>GNBSITE
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
  #WFIL += "& find([F:SOQ]SALFCY,GUSRFCY(1..GNBAUZ))" # Issue X3-137045 - 2019-04-18 by RBA
  Call ADD_FILTER("& find([F:SOQ]SALFCY,GUSRFCY(1..GNBAUZ))", WFIL, WFIL1, WFIL2)
Endif

If [M:CSP1]ITMREF <> ""
  #WFIL += "&[F:SOQ]ITMREF =[M:CSP1]ITMREF" # Issue X3-137045 - 2019-04-18 by RBA
  #YYN45 Call ADD_FILTER("&[F:SOQ]ITMREF =[M:CSP1]ITMREF", WFIL, WFIL1, WFIL2)
  Call ADD_FILTER("&[F:SOQ]ITMREF >=[M:CSP1]ITMREF", WFIL, WFIL1, WFIL2)
Endif

#YYN45
If [M:CSP1]YITMREF <> ""
  #WFIL += "&[F:SOQ]ITMREF =[M:CSP1]ITMREF" # Issue X3-137045 - 2019-04-18 by RBA
  Call ADD_FILTER("&[F:SOQ]ITMREF <=[M:CSP1]YITMREF", WFIL, WFIL1, WFIL2)
Endif
#YYN45 Fin

If [M:CSP1]BPCORD <> ""
   #WFIL += "&[F:SOH]BPCORD =[M:CSP1]BPCORD" # Issue X3-137045 - 2019-04-18 by RBA
  Call ADD_FILTER("&[F:SOH]BPCORD =[M:CSP1]BPCORD", WFIL, WFIL1, WFIL2)
Endif

#WFIL += "&[F:SOQ]SOHCAT<>4"# Issue X3-137045 - 2019-04-18 by RBA
Call ADD_FILTER("&[F:SOQ]SOHCAT<>4", WFIL, WFIL1, WFIL2)

# Prise en compte des commandes normales
# --> Si 1 (Non) On exclut les commandes normales
If [M:CSP1]SOHCATNOR = 1
   #WFIL += "&[F:SOQ]SOHCAT<>1" # Issue X3-137045 - 2019-04-18 by RBA
   Call ADD_FILTER("&[F:SOQ]SOHCAT<>1", WFIL, WFIL1, WFIL2)
Endif
# Prise en compte des commandes de pret
# --> Si 1 (Non) On exclut les commandes de pret
If [M:CSP1]SOHCATLND = 1
   #WFIL += "&[F:SOQ]SOHCAT<>2" # Issue X3-137045 - 2019-04-18 by RBA
   Call ADD_FILTER("&[F:SOQ]SOHCAT<>2", WFIL, WFIL1, WFIL2)
Endif
# Prise en compte des commandes à facturation directe
# --> Si 1 (Non) On exclut les commandes de pret
If [M:CSP1]SOHCATFAC = 1
   #WFIL += "&[F:SOQ]SOHCAT<>3" # Issue X3-137045 - 2019-04-18 by RBA
   Call ADD_FILTER("&[F:SOQ]SOHCAT<>3", WFIL, WFIL1, WFIL2)
Endif

# Prise en compte des commandes soldées
# --> Si 1 (Non) On exclut les commandes soldées
If [M:CSP1]ORDSTAO = 1
   #WFIL += "&[F:SOQ]SOQSTA<>3" # Issue X3-137045 - 2019-04-18 by RBA
   Call ADD_FILTER("&[F:SOQ]SOQSTA<>3", WFIL, WFIL1, WFIL2)
Endif
# Prise en compte des commandes non soldées
# --> Si 1 (Non) On exclut les commandes non soldées
If [M:CSP1]ORDSTAN = 1
   #WFIL += "&[F:SOQ]SOQSTA=3" # Issue X3-137045 - 2019-04-18 by RBA
   Call ADD_FILTER("&[F:SOQ]SOQSTA=3", WFIL, WFIL1, WFIL2)
Endif

# Prise en compte des commandes signées
# --> Si 1 (Non) On exclut les cdes totalement signées (valeur 3), pas de gestion (valeur 4), oui automatique (valeur 5)
If [M:CSP1]APPFLGO = 1
   #WFIL += "&[F:SOH]APPFLG<3" # Issue X3-137045 - 2019-04-18 by RBA
   Call ADD_FILTER("&[F:SOH]APPFLG<3", WFIL, WFIL1, WFIL2)
Endif
# Prise en compte ou pas des devis non signés
# --> Si 1 (Non) On exclut les devis non signés (valeur 1)
If [M:CSP1]APPFLGN = 1
   #WFIL += "&[F:SOH]APPFLG<>1" # Issue X3-137045 - 2019-04-18 by RBA
   Call ADD_FILTER("&[F:SOH]APPFLG<>1", WFIL, WFIL1, WFIL2)
Endif

If [M:CCSP]SOHNUMDEB <> ""
   #WFIL += "&[F:SOQ]SOHNUM>=[M:CCSP]SOHNUMDEB" # Issue X3-137045 - 2019-04-18 by RBA
   Call ADD_FILTER("&[F:SOQ]SOHNUM>=[M:CCSP]SOHNUMDEB", WFIL, WFIL1, WFIL2)
Endif
If [M:CCSP]SOHNUMFIN <> ""
   #WFIL += "&[F:SOQ]SOHNUM<=[M:CCSP]SOHNUMFIN" # Issue X3-137045 - 2019-04-18 by RBA
   Call ADD_FILTER("&[F:SOQ]SOHNUM<=[M:CCSP]SOHNUMFIN", WFIL, WFIL1, WFIL2)
Endif

If [M:CCSP]ORDDATDEB <> [0/0/0]
   #WFIL += "&[F:SOQ]ORDDAT>=[M:CCSP]ORDDATDEB" # Issue X3-137045 - 2019-04-18 by RBA
   Call ADD_FILTER("&[F:SOQ]ORDDAT>=[M:CCSP]ORDDATDEB", WFIL, WFIL1, WFIL2)
Endif
If [M:CCSP]ORDDATFIN <> [0/0/0]
   #WFIL += "&[F:SOQ]ORDDAT<=[M:CCSP]ORDDATFIN" # Issue X3-137045 - 2019-04-18 by RBA
   Call ADD_FILTER("&[F:SOQ]ORDDAT<=[M:CCSP]ORDDATFIN", WFIL, WFIL1, WFIL2)
Endif

# Issue X3-70586 Back to back criteria in order lines inquiry by MGO Begin
  If [M:CCSP]FMINUMDEB <> ""
    #WFIL += "&[F:SOQ]FMINUM>=[M:CCSP]FMINUMDEB" # Issue X3-137045 - 2019-04-18 by RBA
    Call ADD_FILTER("&[F:SOQ]FMINUM>=[M:CCSP]FMINUMDEB", WFIL, WFIL1, WFIL2)
  Endif

  If [M:CCSP]FMINUMFIN <> ""
    #WFIL += "&[F:SOQ]FMINUM<=[M:CCSP]FMINUMFIN" # Issue X3-137045 - 2019-04-18 by RBA
    Call ADD_FILTER("&[F:SOQ]FMINUM<=[M:CCSP]FMINUMFIN", WFIL, WFIL1, WFIL2)
  Endif

  If ([M:CCSP]FMINUMDEB <> "" or [M:CCSP]FMINUMFIN <> "") # Issue X3-101913 - 2018-08-24 by USA
    Case [M:CCSP]FMI
      When 11:
        #WFIL += "&[F:SOQ]FMI=5" # Issue X3-137045 - 2019-04-18 by RBA
        Call ADD_FILTER("&[F:SOQ]FMI=5", WFIL, WFIL1, WFIL2)
      When 15:
        #WFIL += "&([F:SOQ]FMI=2 | [F:SOQ]FMI=3)" # Issue X3-137045 - 2019-04-18 by RBA
        Call ADD_FILTER("&([F:SOQ]FMI=2 | [F:SOQ]FMI=3)", WFIL, WFIL1, WFIL2)
    Endcase
  Endif
# Issue X3-70586 Back to back criteria in order lines inquiry by MGO End

If dim([M:CCSP]TSICOD) > 0
  For I = 0 To dim([M:CCSP]TSICOD)-1
    If [M:CCSP]TSICOD(I) <> ""
#      If len(WFIL) > 200
#        WFIL1 += "&[F:SOP]TSICOD("+num$(I)+")='"+[M:CCSP]TSICOD(I)+"'"
#      Else
#        WFIL += "&[F:SOP]TSICOD("+num$(I)+")='"+[M:CCSP]TSICOD(I)+"'"
#      Endif # Issue X3-137045 - 2019-04-18 by RBA
      Call ADD_FILTER("&[F:SOP]TSICOD("+num$(I)+")='"+[M:CCSP]TSICOD(I)+"'", WFIL, WFIL1, WFIL2)
    Endif
  Next I
Endif

If dim([M:CCSP]TSCCOD) > 0
  For I = 0 To dim([M:CCSP]TSCCOD)-1
    If [M:CCSP]TSCCOD(I) <> ""
#      If len(WFIL) > 200
#        WFIL1 += "&[F:SOH]TSCCOD("+num$(I)+")='"+[M:CCSP]TSCCOD(I)+"'"
#      Else
#        WFIL += "&[F:SOH]TSCCOD("+num$(I)+")='"+[M:CCSP]TSCCOD(I)+"'"
#      Endif # Issue X3-137045 - 2019-04-18 by RBA
      Call ADD_FILTER("&[F:SOH]TSCCOD("+num$(I)+")='"+[M:CCSP]TSCCOD(I)+"'", WFIL, WFIL1, WFIL2)
    Endif
  Next I
Endif

# FGR 23/02/2015 : X3SUIVI104383 (début)
If [M:CSP1]SOHTYP <> "" Then
   #WFIL1 += "&[F:SOH]SOHTYP=[M:CSP1]SOHTYP" # Issue X3-137045 - 2019-04-18 by RBA
   Call ADD_FILTER("&[F:SOH]SOHTYP=[M:CSP1]SOHTYP", WFIL, WFIL1, WFIL2)
Endif
# FGR 23/02/2015 : X3SUIVI104383 (fin)

# X3-119756 : Management of draft sales orders / X3-81823 Hide draft SO - Inquiries (JUCON 20/02/2019)
WFIL1 += "&[F:SOH]DRAFTSTATUS=0"
# X3-119756 : Management of draft sales orders / X3-81823 Hide draft SO - Inquiries (JUCON 20/02/2019)

# Issue X3-25731 - 2017-02-24 by FGR : BEGIN
## 71065 : PJT
#If [M:CSP1]PJTDEB <> ""
#   WFIL1 += "&[F:SOQ]PJT>=[M:CSP1]PJTDEB"
#Endif
#If [M:CSP1]PJTFIN <> ""
#   WFIL1 += "&[F:SOQ]PJT<=[M:CSP1]PJTFIN"
#Endif
## 71065 : PJT
If dim([M:CSP1]PJTDSPALL) >= 0 and [M:CSP1]PJTDSPALL = [V]CST_AYES and [M:CSP1]PJTDEB <> "" Then
  Local Char SPJT(GLONPIM)
  Local Char SBUDGET(GLONTAC)
  Local Char STASK(GLONPBU)
  Local Integer IRET

  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:CSP1]PJTDEB, SPJT, SBUDGET, STASK)
  #WFIL1 += "&pat([F:SOQ]PJT,'" + SPJT + "*')<>0" # Issue X3-137045 - 2019-04-18 by RBA
  Call ADD_FILTER("&pat([F:SOQ]PJT,'" + SPJT + "*')<>0", WFIL, WFIL1, WFIL2)
Else
  If [M:CSP1]PJTDEB <> ""
    #WFIL1 += "&[F:SOQ]PJT>=[M:CSP1]PJTDEB" # Issue X3-137045 - 2019-04-18 by RBA
    Call ADD_FILTER("&[F:SOQ]PJT>=[M:CSP1]PJTDEB", WFIL, WFIL1, WFIL2)
  Endif
  If [M:CSP1]PJTFIN <> ""
    #WFIL1 += "&[F:SOQ]PJT<=[M:CSP1]PJTFIN" # Issue X3-137045 - 2019-04-18 by RBA
    Call ADD_FILTER("&[F:SOQ]PJT<=[M:CSP1]PJTFIN", WFIL, WFIL1, WFIL2)
  Endif
Endif
# Issue X3-25731 - 2017-02-24 by FGR : END

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCSP]TRI
       When 1 : # tri par numéro
           #WFIL1 += "&[F:SOQ]SOHNUM>=DEBNUM" # Issue X3-137045 - 2019-04-18 by RBA
           Call ADD_FILTER("&[F:SOQ]SOHNUM>=DEBNUM", WFIL, WFIL1, WFIL2)
       When 2 : # tri par date
           #WFIL1 += "&([F:SOQ]ORDDAT>DEBDAT | ([F:SOQ]ORDDAT=DEBDAT & [F:SOQ]SOHNUM>=DEBNUM))" # Issue X3-137045 - 2019-04-18 by RBA
           Call ADD_FILTER("&([F:SOQ]ORDDAT>DEBDAT | ([F:SOQ]ORDDAT=DEBDAT & [F:SOQ]SOHNUM>=DEBNUM))", WFIL, WFIL1, WFIL2)
     Endcase
   When 2 : # suite
     Case [M:CCSP]TRI
       When 1 : # tri par numéro
           #WFIL1 += "&[F:SOQ]SOHNUM>FINNUM"
           #WFIL1 += "&[F:SOQ]SOHNUM>=FINNUM" :# 69747 # Issue X3-137045 - 2019-04-18 by RBA
           Call ADD_FILTER("&[F:SOQ]SOHNUM>=FINNUM", WFIL, WFIL1, WFIL2)
       When 2 : # tri par date
           #WFIL1 += "&([F:SOQ]ORDDAT>FINDAT | ([F:SOQ]ORDDAT=FINDAT & [F:SOQ]SOHNUM>FINNUM))"
           #WFIL1 += "&([F:SOQ]ORDDAT>FINDAT | ([F:SOQ]ORDDAT=FINDAT & [F:SOQ]SOHNUM>=FINNUM))" :# 69747 # Issue X3-137045 - 2019-04-18 by RBA
           Call ADD_FILTER("&([F:SOQ]ORDDAT>FINDAT | ([F:SOQ]ORDDAT=FINDAT & [F:SOQ]SOHNUM>=FINNUM))", WFIL, WFIL1, WFIL2)
     Endcase
   When -2 : # retour
     Case [M:CCSP]TRI
       When 1 : # tri par numéro
           #WFIL1 += "&[F:SOQ]SOHNUM<DEBNUM"
           #WFIL1 += "&[F:SOQ]SOHNUM<=DEBNUM" :# 69747 # Issue X3-137045 - 2019-04-18 by RBA
           Call ADD_FILTER("&[F:SOQ]SOHNUM<=DEBNUM", WFIL, WFIL1, WFIL2)
       When 2 : # tri par date
           #WFIL1 += "& ([F:SOQ]ORDDAT<DEBDAT | ([F:SOQ]ORDDAT=DEBDAT & [F:SOQ]SOHNUM<DEBNUM))"
           #WFIL1 += "& ([F:SOQ]ORDDAT<DEBDAT | ([F:SOQ]ORDDAT=DEBDAT & [F:SOQ]SOHNUM<=DEBNUM))" :# 69747 # Issue X3-137045 - 2019-04-18 by RBA
           Call ADD_FILTER("& ([F:SOQ]ORDDAT<DEBDAT | ([F:SOQ]ORDDAT=DEBDAT & [F:SOQ]SOHNUM<=DEBNUM))", WFIL, WFIL1, WFIL2)
     Endcase
Endcase

Return



############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT


Return

#############################################################################
##     Etiquettes masques CONSCSP1 & CONSCSP2 & CRITCSP                    ##
#############################################################################
############################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
# -- Controle autorisation sur le site
    If GUSRFCY(1)<>"\" & !find(VALEUR,GUSRFCY(1..GNBAUZ))
        GMESSAGE=VALEUR-mess(2,104,1)   : # Vous n'avez pas les droits sur ce site
        mkstat=2 : End
    Endif
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
    Affzo [M]CPY, ZCPY
Elsif [M]CPY = ""
    # Mail CH : 03/03/04
    #    GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    #    mkstat = 2
    Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif

End
########################################
Subprog IB_NBLIG

GBOUT1 = mess(191, 198,1)-[M]SOHNUM(nolign-1)
If [M:CSP2]POHNUM(nolign-1) <> ""
    GBOUT2 = mess(260,198,1)-[M]POHNUM(nolign-1)
Else
    Raz GBOUT2
Endif
End
########################################
Subprog AM_SOHNUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]SOHNUMFIN= VALEUR : Endif
End
# 71065 : PJT
######################################################################################
Subprog AM_PJTDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]PJTFIN= VALEUR : Affzo [M]PJTFIN Endif
End
# 71065 : PJT
########################################
Subprog AM_ORDDATDEB(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] : [M]ORDDATFIN= VALEUR : Endif
End

########################################
Subprog AS_FMI(VALEUR)
Variable Integer VALEUR
Local Integer JL
For JL=1 To len(mess(0,725,1))
    GMENLOC(JL)=1
Next
GMENLOC(11)=0
GMENLOC(15)=0
End
########################################

# Issue X3-70586 03-04-2018 by MGO: Back to back criteria in order lines inquiry - BEGIN
Subprog FMINUM_CHECK(VALEUR)
Variable Char    VALEUR()
Case [M:CCSP]FMI
    When 11:
      If !clalev([MFG]) : Local File MFGHEAD [MFG] : Endif
      Look [F:MFG]MFG0 = VALEUR
      If fstat
        GMESSAGE = mess(23,100,1) : mkstat = 2
      Endif
    When 15:
      If !clalev([POH]) : Local File PORDER [POH] : Endif
      Look [F:POH]POH0 = VALEUR
      If fstat
        GMESSAGE = mess(23,100,1) : mkstat = 2
      Endif
    Endcase
End
########################################

Subprog C_FMINUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  Call FMINUM_CHECK(VALEUR)
  If mkstat <> 0 Then
    End
  Endif
Endif
End
# Issue X3-70586 03-04-2018 by MGO - END

Subprog AM_FMINUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "": [M:CCSP]FMINUMFIN = VALEUR : Endif # Issue X3-70586 03-04-2018 by MGO: Back to back criteria in order lines inquiry
End
########################################
Subprog IB_FMINUMDEB
Case [M]FMI
    When 11 : Raz GBOUT2
    When 15 : Raz GBOUT1
Endcase
End
########################################

# Issue X3-70586 03-04-2018 by MGO: Back to back criteria in order lines inquiry - BEGIN
Subprog C_FMINUMFIN(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  Call FMINUM_CHECK(VALEUR)
Endif
End
# Issue X3-70586 03-04-2018 by MGO - END

Subprog IB_FMINUMFIN
Case [M]FMI
    When 11 : Raz GBOUT2
    When 15 : Raz GBOUT1
Endcase
End

