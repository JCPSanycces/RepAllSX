# Issue X3-137045 - 2019-04-18 by RBA
Subprog ADD_FILTER(WFILTER, WFIL, WFIL1, WFIL2)
Value Char WFILTER
Variable Char WFIL
Variable Char WFIL1
Variable Char WFIL2

  If len(WFIL)+len(WFILTER) > 250
    If len(WFIL1)+len(WFILTER) > 250
      WFIL2 += WFILTER
    Else
      WFIL1 += WFILTER
    Endif
  Else
    WFIL += WFILTER
  Endif
End

