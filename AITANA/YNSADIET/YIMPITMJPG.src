#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "IMPORT" : Gosub IMPORT
Endcase
Return

$IMPORT
  Case IMPFIC
    When "ITM"  :
      GIMP(1) = filpath("tmp","","") + "\IMAGES\" + [F:ITM]ITMREF + ".jpg"
      If GIMP(1) <> "" Then
        Openi GIMP(1)
        Getseq 1,[M:ITM1]IMG
        Openi
      Endif
    Endcase
Return

