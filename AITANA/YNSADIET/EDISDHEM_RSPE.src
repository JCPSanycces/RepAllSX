#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Representation EDISDHEM                                                     #
# Author : JUCON                                                              #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
If GUSER = 'AIT51' Then
    Call OUVRE_TRACE("ENTREGAS EDI") From LECFIC
    Call ECR_TRACE("EVENTS:" + [L]CURPTH,0) From GESECRAN
 Endif

Case [L]CURPTH
   When ""
    If GUSER = 'AIT51' Then
       Call OUVRE_TRACE("ENTREGAS EDI") From LECFIC
      Call ECR_TRACE("EVENTS:" + [L]AEVENT,0) From GESECRAN
   Endif
    Case [L]AEVENT
      When "AREAD_AFTER"           : Gosub AREAD_AFTER #test RBA
    Endcase
Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  If GUSER = 'AIT51' Then
     Call OUVRE_TRACE("ENTREGAS EDI") From LECFIC
     Call ECR_TRACE("METODO:" + [L]AMETHOD,0) From GESECRAN
  Endif
  Case [L]AMETHOD
    When "MET_AFTER_LOAD_REPRESENTATION" : Gosub MET_AFTER_LOAD_REPRESENTATION
  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  If GUSER = 'AIT51' Then
      Call OUVRE_TRACE("ENTREGAS EDI") From LECFIC
      Call ECR_TRACE("PROPERTIES:" + [L]CURPRO,0) From GESECRAN
   Endif
  Case [L]CURPRO

  Endcase
Return

####################################################################
$AREAD_AFTER
#  Gosub GETVALPARAMURL From TRTFUNEDI
Return


$MET_AFTER_LOAD_REPRESENTATION
    If GUSER = 'AIT51' Then : Call ECR_TRACE(" DENTRO METODO" ,0) From GESECRAN: Endif
Return

