#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara ROU1 (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ROU1) 13/04/2020 12:16:38 (AIT04)
######################################################################################
$ACTION
Case ACTION
 When "LIENS" :   Gosub LIENS
Endcase
Return

######################################################################################
$LIENS
# Muestro la descripción del CT
Gosub LIENS From SUBROUA

Local Integer I
Local Char MADES
Local Char MODES
For I=0 To [M:ROU1]NBLIG-1
  MADES = ""
  MODES = ""
  Call GET_WSTDES([M:ROU1]WST(I),[M:ROU0]FCY,MADES)
  Call GET_WSTDES([M:ROU1]LABWST(I),[M:ROU0]FCY,MODES)
  [M:ROU1]YWSTDES(I) = MADES
  [M:ROU1]YLABDES(I) = MODES
  Affzo [M:ROU1]YWSTDES(I)
  Affzo [M:ROU1]YLABDES(I)
Next

GPE = 1
Return


######################################################################################
Subprog AM_WST(VALEUR)
Variable Char    VALEUR()
# Muestro la descripción
Local Char MADES
Call GET_WSTDES(VALEUR,[M:ROU0]FCY,MADES)
[M:ROU1]YWSTDES(nolign-1) = MADES
Affzo [M:ROU1]YWSTDES(nolign-1)
End


######################################################################################
Subprog GET_WSTDES(VCT,VPL,VDES)
Value Char VCT
Value Char VPL
Variable Char VDES

If !clalev([F:PP0]) Then : Local File ATEXTRA [PP0] : Endif

Read [PP0]AXX0 = "WORKSTATIO";"WSTDESAXX";"SPA";VCT;VPL
If fstat = 0
  VDES = [PP0]TEXTE
Endif

If clalev([F:PPO])  Then : Close Local File [PP0] : Endif

End


######################################################################################
Subprog AM_LABWST(VALEUR)
Variable Char    VALEUR()
# Muestro la descripción
Local Char MODES
Call GET_WSTDES(VALEUR,[M:ROU0]FCY,MODES)
[M:ROU1]YLABDES(nolign-1) = MODES
Affzo [M:ROU1]YLABDES(nolign-1)

End


######################################################################################

