#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara BOD1 (Especifico)
$ACTION
Case ACTION
  When "LIENS"    :   Gosub LIENS
Endcase
Return


######################################################################################
$LIENS
# Lanzo la acción STD
Gosub LIENS From SUBBODA

# Muestro la descripción de los componentes
Local Integer NOL
For NOL=0 To [M:BOD1]NBLIG-1
  Read [ITM]ITM0 = [M:BOD1]CPNITMREF(NOL)
  If fstat = 0
    #[M:BOD1]YCPTEDES(NOL) = [ITM]ITMDES1
    #Affzo [M:BOD1]CPNITMREF(NOL)
  Endif
Next

# Bloqueo STD
GPE = 1
Return


######################################################################################
## Etiqueta añadida por el supervisor (pantalla BOD1) 02/03/2020 17:51:56 (AIT04)
######################################################################################
Subprog AM_CPNITMREF(VALEUR)
Variable Char    VALEUR()
# Muestro la descripción de los componentes
Read [ITM]ITM0 = VALEUR
If fstat = 0
  [M:BOD1]YCPTEDES(nolign-1) = [ITM]ITMDES1
  Affzo [M:BOD1]CPNITMREF(nolign-1)
Endif
End


######################################################################################
