#<AdxTL>@(#)0.0.0.0 $Revision$ 
####################################################################################
# Src: SPEYPP
#-------------------------------------------------------------------------------------
# Proyecto: Ynsadiet
#-------------------------------------------------------------------------------------
# Version: v12
#-------------------------------------------------------------------------------------
# YN02 - Parrilla de producción
# Fecha inicio YN02: 16/08/2019
# Desarrollador: JCH
# Código de desarrollo: YN02
# Descripción del desarrollo: Parrilla de elementos de fabricación
# Fecha: 16/08/2019
# Codigo Actividad: YYN02
#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "DEBUT"        : Gosub DEBUT
  When "SETBOUT"      : Gosub SETBOUT
  When "BOUTON"       : Gosub BOUTON
  When "FIN"          : Gosub FIN
  When "SEL_TABLE"    : Gosub SEL_TABLE
  When "VERF_TABLE"   : Gosub VERF_TABLE
  When "MEN"          : Gosub BOUTON
  When Default
Endcase

Return

###############################################################
#######################    ACCIONES    ########################
###############################################################
###############################################################
$OUVRE
  Gosub ABRIR_TABLAS
Return

##############################################################
$DEBUT
  Global Integer GFLGCHANGE : Raz GFLGCHANGE
  Global Char GPARAM1(250)(2)
  Global Integer GNOL
  Global Integer GBUSCA_STA
  [M:YPP0]STRDAT = date$ - 10
  [M:YPP0]ENDDAT = date$
  Affzo [M:YPP0]5,10
  Affzo [M:YPP1]5,10,15,20
  Grizo [M:YPP1]YTIPOREG,MFGNUM,MFGDAT,MFGITM,LOTCDG,CADUCIDAD,LIMDAT
  Gosub CARGA_ESTADOS
Return

##############################################################
$SETBOUT
  Raz CHMEN
  Case BOUT
    When "c"      : CHMEN += "gx"
    When Default
      If GBUSCA_STA = 1 Then
        CHMEN += "sbuldarc"
      Else
        CHMEN += "sbarc"
      Endif
  Endcase
Return

##############################################################
$BOUTON
  Case BOUT
    When "b"  : Gosub BUSCAR
    When "u"  : Gosub ACT_DATOS
    When "l"  : Gosub ACT_LINEAS
    When "d"  : Gosub DUPLICAR
    When "a"  : Gosub ADJ_DOCUMENTO
    When "c"  : Gosub CREAR
    When "g"  : Gosub CREA_REGISTRO
    When "x"  : Gosub CANCELA_REGISTRO
    When "s"  : Gosub SALIR
  Endcase
Return

##############################################################
$FIN
  Gosub CERRAR_TABLAS
  If dim(GFLGCHANGE)  > 0 Then : Kill GFLGCHANGE  : Endif
  If dim(GPARAM1)     > 0 Then : Kill GPARAM1     : Endif
  If dim(GNOL)        > 0 Then : Kill GNOL        : Endif
  If dim(GBUSCA_STA)  > 0 Then : Kill GBUSCA_STA  : Endif
  FIN=1
Return

##############################################################
$SEL_TABLE
  Case TABLE
    When "YSELSTKPP"   : Gosub SEL_YSELSTKPP
  Endcase
Return

##############################################################
$VERF_TABLE
  Case TABLE
    When "YSELSTKPP"   : Gosub VERF_YSELSTKPP
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$SEL_YSELSTKPP
  Link [AXX0] With [TST0]TST0=[F:AXX0]IDENT1 As [LNK0] Where CODFIC="TABSTASTO" and ZONE = "STAAXX" and LANGUE=GLANGUE
  Columns [LNK0] ([TST0]STASTO,[AXX0]TEXTE)
  Default File [LNK0]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Estados"                                                       # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "[TST0]STASTO"                                                  # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la segunda columna
  COL(NBCOL)  = "[AXX0]TEXTE"                                                   # nombre del campo a mostrar en la segunda columna
Return

##############################################################
$VERF_YSELSTKPP
Return

##############################################################
$ABRIR_TABLAS
  If !clalev([F:TST0]) Then : Local File TABSTASTO    [F:TST0] : Endif
  If !clalev([F:TST1]) Then : Local File TABSTASTO    [F:TST1] : Endif
  If !clalev([F:AXX0]) Then : Local File ATEXTRA      [F:AXX0] : Endif
  If !clalev([F:AXX1]) Then : Local File ATEXTRA      [F:AXX1] : Endif
  If !clalev([F:MFH0]) Then : Local File MFGHEAD      [F:MFH0] : Endif
  If !clalev([F:MFI0]) Then : Local File MFGITM       [F:MFI0] : Endif
  If !clalev([F:YMP0]) Then : Local File YMFGHEADPP   [F:YMP0] : Endif
  If !clalev([F:YMP1]) Then : Local File YMFGHEADPP   [F:YMP1] : Endif
  If !clalev([F:YMP2]) Then : Local File YMFGHEADPP   [F:YMP2] : Endif
  If !clalev([F:YDP0]) Then : Local File YMFGDUPLIPP  [F:YDP0] : Endif
  If !clalev([F:YDP1]) Then : Local File YMFGDUPLIPP  [F:YDP1] : Endif
  If !clalev([F:YDP2]) Then : Local File YMFGDUPLIPP  [F:YDP2] : Endif
  If !clalev([F:ITM0]) Then : Local File ITMMASTER    [F:ITM0] : Endif
  If !clalev([F:YOP0]) Then : Local File YMFGDOCPP    [F:YOP0] : Endif
Return

##############################################################
$CERRAR_TABLAS
  If clalev([F:MFH0])  Then : Close Local File        [F:MFH0] : Endif
  If clalev([F:MFI0])  Then : Close Local File        [F:MFI0] : Endif
  If clalev([F:YMP0])  Then : Close Local File        [F:YMP0] : Endif
  If clalev([F:YMP1])  Then : Close Local File        [F:YMP1] : Endif
  If clalev([F:YMP2])  Then : Close Local File        [F:YMP2] : Endif
  If clalev([F:YDP0])  Then : Close Local File        [F:YDP0] : Endif
  If clalev([F:YDP1])  Then : Close Local File        [F:YDP1] : Endif
  If clalev([F:YDP2])  Then : Close Local File        [F:YDP2] : Endif
  If clalev([F:ITM0])  Then : Close Local File        [F:ITM0] : Endif
  If clalev([F:YOP0])  Then : Close Local File        [F:YOP0] : Endif
Return

##############################################################
$BUSCAR
Local Clbfile CRITSQL(2)(0..8) : Raz CRITSQL
# JC.19022020.STR
Local Clbfile LWHERE1(2), LWHERE3(255) : Raz LWHERE1, LWHERE3
# JC.19022020.END
Local Integer LCON0, LCON10 : Raz LCON0, LCON10
Local Integer LCONTROL : Raz LCONTROL
Local Clbfile CRITSQL2(3)(0..6) : Raz CRITSQL2
Local Clbfile LWHERE2(2), LWHERE4(2), LWHERE6(2) : Raz LWHERE2, LWHERE4, LWHERE6
Local Integer LCON2, LCON3 : Raz LCON2, LCON3
Local Clbfile CRITSQL4(2)(0..5) : Raz CRITSQL4
Local Clbfile LWHERE7(2) : Raz LWHERE7
Local Clbfile LWHERE8(255) : Raz LWHERE8
Local Clbfile LWHERE12(2), LWHERE13(2) : Raz LWHERE12, LWHERE13

# lo deshabilito en esta parrilla por petición de Leticia
#  # vacío la tabla de bloqueos
#  Call UNLOCK_LCKPRR(adxuid(1),"PP") From SPEYLIB0

  Raz [M:YPP2]
  indice = 0
  [M:YPP2]NBLIG = 0

  # elimina los registros en la tabla de bloqueos de las sesiones que no existen en X3
  Call DEL_SESSIONS() From SPEYLIB0

  If [M:YPP0]DEVOLUCION <> 2 Then
    Gosub BUSCAR_MFG_ORIGINAL
    LCON2 = LCON0
    Gosub BUSCAR_MFG_DUPLICADA
    LCON3 = LCON2
    Gosub BUSCAR_DEVEXT
    [M:YPP2]NBLIG = LCON3
  Else
    Gosub BUSCAR_DEVEXT
    [M:YPP2]NBLIG = LCON3
  Endif

  Sorta [M:YPP2]NBLIG [M:YPP2]NBLIG Order By [M:YPP2]MFGNUM(indice), [M:YPP2]MFGTIPO(indice), [M:YPP2]MFGCDG(indice)

  Affzo [M:YPP2]5

  Gosub BUSCA_DOCADJ

  GBUSCA_STA = 1

  Gosub PAINT_LCKLINE
  Affzo [M:YPP2]5

Return

##############################################################
$BUSCAR_MFG_ORIGINAL
# lo deshabilito en esta parrilla por petición de Leticia
#Local Integer   LLCKUID
#Local Datetime  LLCKTIM
#Local Char      LLCKUSR(20)

  LWHERE1 = "MFGITM.MFGFCY_0='101' AND MFGITM.YTIPO_0=1 "
  If [M:YPP0]STRDAT   <> [00/00/0000]               Then : LWHERE1 += " and MFGITM.STRDAT_0>='" +[M:YPP0]STRDAT+"'"     : Endif
  If [M:YPP0]ENDDAT   <> [00/00/0000]               Then : LWHERE1 += " and MFGITM.STRDAT_0<='" +[M:YPP0]ENDDAT+"'"     : Endif
  If [M:YPP0]STRMFG   <> ""                         Then : LWHERE1 += " and MFGITM.MFGNUM_0>='"  +[M:YPP0]STRMFG+"'"    : Endif
  If [M:YPP0]ENDMFG   <> ""                         Then : LWHERE1 += " and MFGITM.MFGNUM_0<='"  +[M:YPP0]ENDMFG+"'"    : Endif
  If [M:YPP0]CONTROL  <> 0 and [M:YPP0]CONTROL <> 5 Then : LWHERE3 += " and MFGITM.MFGSTA_0="   +num$([M:YPP0]CONTROL)  : Endif
  If [M:YPP0]ITMREF   <> ""                         Then : LWHERE3 += " and MFGITM.ITMREF_0='"   +[M:YPP0]ITMREF+"'"    : Endif
  If [M:YPP0]LOT      <> ""                         Then : LWHERE3 += " and MFGITM.LOT_0 LIKE '%"+[M:YPP0]LOT+"%'"      : Endif
  Raz LCONTROL
  Local Integer LCON10, LCONTROL, LQSTA : Raz LCONTROL, LQSTA
  For LCON10 = 0 To [M:YPP0]NBSTA-1
    If [M:YPP0]SELSTA(LCON10) = 2 Then
      If LCONTROL = 0 Then
        LWHERE8 += " YMFGHEADPP.ESTADO_0='" + [M:YPP0]CDGSTA(LCON10) + "'"
        If [M:YPP0]CDGSTA(LCON10) = "Q" Then
          LWHERE8 += " or YMFGHEADPP.ESTADO_0='' or YMFGHEADPP.ESTADO_0 IS NULL"
          LQSTA = 1
        Endif
      Else
        LWHERE8 += " or YMFGHEADPP.ESTADO_0='" + [M:YPP0]CDGSTA(LCON10) + "'"
        If [M:YPP0]CDGSTA(LCON10) = "Q" Then
          LWHERE8 += " or YMFGHEADPP.ESTADO_0='' or YMFGHEADPP.ESTADO_0 IS NULL"
          LQSTA = 1
        Endif
      Endif
      LCONTROL += 1
    Endif
  Next

  CRITSQL(0) =  "SELECT MFGITM.MFGNUM_0,MFGITM.STRDAT_0,MFGITM.ITMREF_0,MFGITM.LOT_0,"
  CRITSQL(0) += "YMFGHEADPP.BLISTER_0,YMFGHEADPP.ETIQUETA_0,YMFGHEADPP.PROSPECTO_0,YMFGHEADPP.ESTUCHE_0,YMFGHEADPP.CHIP_0,YMFGHEADPP.APTO_0,"
  CRITSQL(1) =  "YMFGHEADPP.NAPTO_0,YMFGHEADPP.COMENTARIOS_0,MFGITM.YLOTEMP_0,MFGITM.YCADUCIDAD_0,MFGITM.YFLU_0,MFGITM.MFGSTA_0,YMFGHEADPP.ESTADO_0,"
  CRITSQL(1) += "MFGITM.TRKLAST_0,MFGITM.CPLQTY_0,MFGITM.TCLCOD_0,MFGITM.MFGFCY_0,MFGITM.YTIPO_0 "
  CRITSQL(2) =  "FROM "+nomap+".MFGITM "
  CRITSQL(2) += "LEFT OUTER JOIN "+nomap+".YMFGHEADPP ON "+nomap+".MFGITM.MFGNUM_0="+nomap+".YMFGHEADPP.MFGNUM_0 "
  CRITSQL(5) =  "WHERE "+LWHERE1
  CRITSQL(6) =  LWHERE3
#  CRITSQL(7)  = LWHERE5
  If LWHERE8 <> "" Then : CRITSQL(8)  = " and (" + LWHERE8 + ")" : Endif

#If GUSER="AIT07" Then
#Local Integer I
#Infbox "HEAD"
#For I=0 To 8
#  Infbox CRITSQL(I)
#Next
#Endif

  For (Char MFGNUM(250),Date STRDAT,Char ITMREF(250),Char LOT(250),Char BLISTER(250), Char ETIQUETA(250), Char PROSPECTO(250),
&      Char ESTUCHE(250), Integer CHIP, Integer APTO, Integer NAPTO, Char COMENTARIOS(250), Char YLOTEMP(250), Date YCADUCIDAD, Date YFLU, Integer CONTROL,
&      Char ESTADO(250), Date TRKLAST, Decimal CPLQTY, Char TCLCOD(250), Char MFGFCY(250), Integer YTIPO) From "5" Sql CRITSQL(0..8) As [Y00]
    # si el usuario ha filtrado por el estado Q y la categoría del producto es YNPI no debe mostrar ese registro
    If LQSTA = 1 and [F:Y00]TCLCOD = "YNPI" Then
    Else
      [M:YPP2]MFGNUM(LCON0)       = [F:Y00]MFGNUM
      [M:YPP2]MFGCDG(LCON0)       = [F:Y00]MFGNUM
      [M:YPP2]MFGTIPO(LCON0)      = 1
      [M:YPP2]STRDAT(LCON0)       = [F:Y00]STRDAT
      [M:YPP2]ITMREF(LCON0)       = [F:Y00]ITMREF
      [M:YPP2]LOTE(LCON0)         = [F:Y00]LOT
      [M:YPP2]BLISTER(LCON0)      = [F:Y00]BLISTER
      [M:YPP2]ETIQUETA(LCON0)     = [F:Y00]ETIQUETA
      [M:YPP2]PROSPECTO(LCON0)    = [F:Y00]PROSPECTO
      [M:YPP2]ESTUCHE(LCON0)      = [F:Y00]ESTUCHE
      [M:YPP2]CHIP(LCON0)         = [F:Y00]CHIP
      [M:YPP2]APTO(LCON0)         = [F:Y00]APTO
      [M:YPP2]NAPTO(LCON0)        = [F:Y00]NAPTO
      [M:YPP2]COMENTARIOS(LCON0)  = [F:Y00]COMENTARIOS
      [M:YPP2]LOTEMP(LCON0)       = [F:Y00]YLOTEMP
      [M:YPP2]CADUCIDAD(LCON0)    = [F:Y00]YCADUCIDAD
      [M:YPP2]ENDDAT(LCON0)       = [F:Y00]YFLU
      [M:YPP2]CONTROL(LCON0)      = [F:Y00]CONTROL
      [M:YPP2]ESTADO(LCON0)       = [F:Y00]ESTADO
      [M:YPP2]TRKLAST(LCON0)      = [F:Y00]TRKLAST
      [M:YPP2]CPLQTY(LCON0)       = [F:Y00]CPLQTY
      [M:YPP2]TCLCOD(LCON0)       = [F:Y00]TCLCOD
      [M:YPP2]MFGFCY(LCON0)       = [F:Y00]MFGFCY
      [M:YPP2]YTIPO(LCON0)        = [F:Y00]YTIPO
      If [F:Y00]APTO <> 2 and [F:Y00]NAPTO <> 2 Then : [M:YPP2]ESTADO(LCON0) = "Q" : Endif
      If [F:Y00]TCLCOD = "YNPI" Then
        [M:YPP2]APTO(LCON0)   = 2
        [M:YPP2]NAPTO(LCON0)  = 1
        [M:YPP2]ESTADO(LCON0) = "A1"
      Endif

# lo deshabilito en esta parrilla por petición de Leticia
#      # gestiona los bloqueos
#      GLCK = func SPEYLIB0.SEARCH_LCKPRR([F:Y00]ITMREF,[F:Y00]LOT)
#      If !GLCK Then
#        Call LOCK_LCKPRR([F:Y00]ITMREF,[F:Y00]LOT,"PP") From SPEYLIB0
#      Else
#        Raz LLCKUID,LLCKUSR,LLCKTIM
#        Call GET_IDLCK([F:Y00]ITMREF,[F:Y00]LOT,LLCKUID,LLCKUSR,LLCKTIM) From SPEYLIB0
#        [M:YPP2]LCKUSR(LCON0) = LLCKUSR
#        [M:YPP2]LCKDAT(LCON0) = num$(LLCKTIM)
#      Endif

      LCON0                       += 1
    Endif
  Next

# lo deshabilito en esta parrilla por petición de Leticia
#  If dim(LLCKUID) > 0 Then : Kill LLCKUID : Endif
#  If dim(LLCKTIM) > 0 Then : Kill LLCKTIM : Endif
#  If dim(LLCKUSR) > 0 Then : Kill LLCKUSR : Endif
Return

##############################################################
$BUSCAR_MFG_DUPLICADA
# lo deshabilito en esta parrilla por petición de Leticia
#Local Integer   LLCKUID
#Local Datetime  LLCKTIM
#Local Char      LLCKUSR(20)

  LWHERE2 = "YMFGDUPLIPP.MFGFCY_0='101' AND YMFGDUPLIPP.YTIPO_0=1 "
  If [M:YPP0]STRDAT   <> [00/00/0000]               Then : LWHERE2 += " and YMFGDUPLIPP.STRDAT_0>='"    +[M:YPP0]STRDAT+"'"     : Endif
  If [M:YPP0]ENDDAT   <> [00/00/0000]               Then : LWHERE2 += " and YMFGDUPLIPP.STRDAT_0<='"    +[M:YPP0]ENDDAT+"'"     : Endif
  If [M:YPP0]STRMFG   <> ""                         Then : LWHERE2 += " and YMFGDUPLIPP.MFGNUM_0>='"     +[M:YPP0]STRMFG+"'"     : Endif
  If [M:YPP0]ENDMFG   <> ""                         Then : LWHERE2 += " and YMFGDUPLIPP.MFGNUM_0<='"     +[M:YPP0]ENDMFG+"'"     : Endif
  If [M:YPP0]CONTROL  <> 0 and [M:YPP0]CONTROL <> 5 Then : LWHERE4 += " and YMFGDUPLIPP.CONTROL_0="     +num$([M:YPP0]CONTROL)  : Endif
  If [M:YPP0]ITMREF   <> ""                         Then : LWHERE4 += " and YMFGDUPLIPP.ITMREF_0='"     +[M:YPP0]ITMREF+"'"     : Endif
  If [M:YPP0]LOT      <> ""                         Then : LWHERE4 += " and YMFGDUPLIPP.LOT_0 LIKE '%"  +[M:YPP0]LOT+"%'"        : Endif
  Raz LCONTROL

  Local Integer LCON11, LCONTROL11 : Raz LCONTROL11
  Local Clbfile LWHERE9(255)       : Raz LWHERE9
  For LCON11 = 0 To [M:YPP0]NBSTA-1
    If [M:YPP0]SELSTA(LCON11) = 2 Then
      If LCONTROL11 = 0 Then
        LWHERE9 += " YMFGDUPLIPP.ESTADO_0='" + [M:YPP0]CDGSTA(LCON11) + "'"
      Else
        LWHERE9 += " or YMFGDUPLIPP.ESTADO_0='" + [M:YPP0]CDGSTA(LCON11) + "'"
      Endif
      LCONTROL11 += 1
    Endif
  Next
  If LCONTROL11 > 0 Then : LWHERE6 += " and " : Endif

  CRITSQL2(0) =  "SELECT YMFGDUPLIPP.MFGNUM_0,YMFGDUPLIPP.CODIGO_0,YMFGDUPLIPP.ESTADO_0,YMFGDUPLIPP.MFGTIPO_0,YMFGDUPLIPP.STRDAT_0,YMFGDUPLIPP.ITMREF_0,"
  CRITSQL2(0) += "YMFGDUPLIPP.LOT_0,YMFGDUPLIPP.CADUCIDAD_0,YMFGDUPLIPP.ENDDAT_0,YMFGDUPLIPP.LOTEMP_0,YMFGDUPLIPP.BLISTER_0,YMFGDUPLIPP.CONTROL_0,"
  CRITSQL2(1) =  "YMFGDUPLIPP.ETIQUETA_0,YMFGDUPLIPP.PROSPECTO_0,YMFGDUPLIPP.ESTUCHE_0,YMFGDUPLIPP.CHIP_0,YMFGDUPLIPP.COMENTARIOS_0,YMFGDUPLIPP.APTO_0,YMFGDUPLIPP.NAPTO_0,"
  CRITSQL2(1) += "YMFGDUPLIPP.TRKLAST_0,YMFGDUPLIPP.CPLQTY_0,YMFGDUPLIPP.TCLCOD_0,YMFGDUPLIPP.MFGFCY_0,YMFGDUPLIPP.YTIPO_0 "
  CRITSQL2(2) =  "FROM "+nomap+".YMFGDUPLIPP "
  CRITSQL2(3) =  "WHERE "+LWHERE2
  CRITSQL2(4) =  LWHERE4
  CRITSQL2(5) =  LWHERE6
  If LWHERE9 <> "" Then : CRITSQL2(6)  = "(" + LWHERE9 + ")" : Endif

#If GUSER="AIT07" Then
#Local Integer I
#Infbox "DUPLI"
#For I = 0 To 6
#  Infbox num$(CRITSQL2(I))
#Next
#Endif

  For (Char MFGNUM(250),Char CODIGO(250), Char ESTADO(250),Integer MFGTIPO,Date STRDAT,Char ITMREF(250),Char LOT,Date CADUCIDAD,Date ENDDAT,Char LOTEMP(250),Char BLISTER(250),
&      Integer CONTROL,Char ETIQUETA(250),Char PROSPECTO(250),Char ESTUCHE(250),Integer CHIP,Char COMENTARIOS(250), Integer APTO, Integer NAPTO, Date TRKLAST, Decimal CPLQTY,
&      Char TCLCOD(250), Char MFGFCY(250), Integer YTIPO) From "5" Sql CRITSQL2(0..6) As [Y02]
    [M:YPP2]MFGNUM(LCON2)       = [F:Y02]MFGNUM
    [M:YPP2]MFGCDG(LCON2)       = [F:Y02]CODIGO
    [M:YPP2]MFGTIPO(LCON2)      = [F:Y02]MFGTIPO
    [M:YPP2]STRDAT(LCON2)       = [F:Y02]STRDAT
    [M:YPP2]ITMREF(LCON2)       = [F:Y02]ITMREF
    [M:YPP2]LOTE(LCON2)         = [F:Y02]LOT
    [M:YPP2]ESTADO(LCON2)       = [F:Y02]ESTADO
    [M:YPP2]CADUCIDAD(LCON2)    = [F:Y02]CADUCIDAD
    [M:YPP2]ENDDAT(LCON2)       = [F:Y02]ENDDAT
    [M:YPP2]LOTEMP(LCON2)       = [F:Y02]LOTEMP
    [M:YPP2]BLISTER(LCON2)      = [F:Y02]BLISTER
    [M:YPP2]ETIQUETA(LCON2)     = [F:Y02]ETIQUETA
    [M:YPP2]PROSPECTO(LCON2)    = [F:Y02]PROSPECTO
    [M:YPP2]ESTUCHE(LCON2)      = [F:Y02]ESTUCHE
    [M:YPP2]CHIP(LCON2)         = [F:Y02]CHIP
    [M:YPP2]COMENTARIOS(LCON2)  = [F:Y02]COMENTARIOS
    [M:YPP2]APTO(LCON2)         = [F:Y02]APTO
    [M:YPP2]NAPTO(LCON2)        = [F:Y02]NAPTO
    [M:YPP2]ESTADO(LCON2)       = [F:Y02]ESTADO
    [M:YPP2]TRKLAST(LCON2)      = [F:Y02]TRKLAST
    [M:YPP2]CPLQTY(LCON2)       = [F:Y02]CPLQTY
    [M:YPP2]TCLCOD(LCON2)       = [F:Y02]TCLCOD
    [M:YPP2]MFGFCY(LCON2)       = [F:Y02]MFGFCY
    [M:YPP2]YTIPO(LCON2)        = [F:Y02]YTIPO
    [M:YPP2]CONTROL(LCON2)      = [F:Y02]CONTROL
    If [F:Y02]APTO <> 2 and [F:Y02]NAPTO <> 2 Then [M:YPP2]ESTADO(LCON2) = "Q" : Endif
    If [F:Y02]TCLCOD = "YNPI" Then
      [M:YPP2]APTO(LCON2)   = 2
      [M:YPP2]NAPTO(LCON2)  = 1
      [M:YPP2]ESTADO(LCON2) = "A1"
    Endif

# lo deshabilito en esta parrilla por petición de Leticia
#    # gestiona los bloqueos
#    GLCK = func SPEYLIB0.SEARCH_LCKPRR([F:Y02]ITMREF,[F:Y02]LOT)
#    If !GLCK Then
#      Call LOCK_LCKPRR([F:Y02]ITMREF,[F:Y02]LOT,"PP") From SPEYLIB0
#    Else
#      Raz LLCKUID,LLCKUSR,LLCKTIM
#      Call GET_IDLCK([F:Y02]ITMREF,[F:Y02]LOT,LLCKUID,LLCKUSR,LLCKTIM) From SPEYLIB0
#      [M:YPP2]LCKUSR(LCON2) = LLCKUSR
#      [M:YPP2]LCKDAT(LCON2) = num$(LLCKTIM)
#    Endif

    LCON2                       += 1
  Next

# lo deshabilito en esta parrilla por petición de Leticia
#  If dim(LLCKUID) > 0 Then : Kill LLCKUID : Endif
#  If dim(LLCKTIM) > 0 Then : Kill LLCKTIM : Endif
#  If dim(LLCKUSR) > 0 Then : Kill LLCKUSR : Endif
Return

##############################################################
$BUSCAR_DEVEXT
# lo deshabilito en esta parrilla por petición de Leticia
#Local Integer   LLCKUID
#Local Datetime  LLCKTIM
#Local Char      LLCKUSR(20)

  LWHERE7 = "1=1"
  If [M:YPP0]STRDAT   <> [00/00/0000]               Then : LWHERE7 += " and YMFGHEADPP.FECHAR_0>='"    +[M:YPP0]STRDAT+"'"     : Endif
  If [M:YPP0]ENDDAT   <> [00/00/0000]               Then : LWHERE7 += " and YMFGHEADPP.FECHAR_0<='"    +[M:YPP0]ENDDAT+"'"     : Endif
  If [M:YPP0]STRMFG   <> ""                         Then : LWHERE7 += " and YMFGHEADPP.MFGNUM_0>='"    +[M:YPP0]STRMFG+"'"     : Endif
  If [M:YPP0]ENDMFG   <> ""                         Then : LWHERE7 += " and YMFGHEADPP.MFGNUM_0<='"    +[M:YPP0]ENDMFG+"'"     : Endif
  If [M:YPP0]ITMREF   <> ""                         Then : LWHERE7 += " and YMFGHEADPP.ITMREF_0='"     +[M:YPP0]ITMREF+"'"     : Endif
  If [M:YPP0]LOT      <> ""                         Then : LWHERE7 += " and YMFGHEADPP.LOT_0 LIKE '%"  +[M:YPP0]LOT+"%'"       : Endif

  Local Integer LCON12, LCONTROL12 : Raz LCONTROL12
  For LCON12 = 0 To [M:YPP0]NBSTA-1
    If [M:YPP0]SELSTA(LCON12) = 2 Then
      If LCONTROL12 = 0 Then
        LWHERE12 += " YMFGHEADPP.ESTADO_0='" + [M:YPP0]CDGSTA(LCON12) + "'"
      Else
        LWHERE12 += " or YMFGHEADPP.ESTADO_0='" + [M:YPP0]CDGSTA(LCON12) + "'"
      Endif
      LCONTROL12 += 1
    Endif
  Next
  If LCONTROL12 > 0 Then : LWHERE7 += " and " : Endif

  CRITSQL4(0) = "SELECT YMFGHEADPP.MFGNUM_0,YMFGHEADPP.MFGTIPO_0,YMFGHEADPP.APTO_0,YMFGHEADPP.NAPTO_0,YMFGHEADPP.ESTADO_0,YMFGHEADPP.CONTROL_0,YMFGHEADPP.ITMREF_0,"
  CRITSQL4(1) = "YMFGHEADPP.LOT_0,YMFGHEADPP.BLISTER_0,YMFGHEADPP.ETIQUETA_0,YMFGHEADPP.PROSPECTO_0,YMFGHEADPP.ESTUCHE_0,YMFGHEADPP.CHIP_0,"
  CRITSQL4(2) =  "YMFGHEADPP.COMENTARIOS_0,YMFGHEADPP.CADUCIDAD_0,YMFGHEADPP.LIMDAT_0,YMFGHEADPP.FECHAR_0,YMFGHEADPP.TRKLAST_0,YMFGHEADPP.CPLQTY_0,YMFGHEADPP.TCLCOD_0,"
  CRITSQL4(2) += "YMFGHEADPP.MFGFCY_0,YMFGHEADPP.YTIPO_0 "
  CRITSQL4(3) =  "FROM "+nomap+".YMFGHEADPP "
  # está marcado el check 'Devolución', por tanto sólo muestra devoluciones
  If [M:YPP0]DEVOLUCION <> 2 Then
    CRITSQL4(4) =  "WHERE (left(YMFGHEADPP.MFGNUM_0,3)='DEV' or left(YMFGHEADPP.MFGNUM_0,3)='EXT') and "+LWHERE7
  Else
    CRITSQL4(4) =  "WHERE (left(YMFGHEADPP.MFGNUM_0,3)='DEV') and "+LWHERE7
  Endif
  If LWHERE12 <> "" Then : CRITSQL4(5)  = "(" + LWHERE12 + ")" : Endif

#If GUSER="AIT07" Then
#Local Integer I
#Infbox "DEVEX"
#For I=0 To 5
#  Infbox CRITSQL4(I)
#Next
#Endif

  For (Char MFGNUM(250), Integer MFGTIPO, Integer APTO, Integer NAPTO, Char ESTADO(250), Integer CONTROL, Char ITMREF(250),
&      Char LOT(250), Char BLISTER(250), Char ETIQUETA(250), Char PROSPECTO(250), Char ESTUCHE(250), Integer CHIP,
&      Char COMENTARIOS(250), Date CADUCIDAD, Date LIMDAT, Date FECHAR, Date TRKLAST, Decimal CPLQTY, Char TCLCOD(250), Char MFGFCY(250), Integer YTIPO) From "5" Sql CRITSQL4(0..5) As [Y03]
    [M:YPP2]MFGNUM(LCON3)       = [F:Y03]MFGNUM
    [M:YPP2]MFGCDG(LCON3)       = [F:Y03]MFGNUM
    [M:YPP2]MFGTIPO(LCON3)      = [F:Y03]MFGTIPO
    [M:YPP2]STRDAT(LCON3)       = [F:Y03]FECHAR
    [M:YPP2]ITMREF(LCON3)       = [F:Y03]ITMREF
    [M:YPP2]LOTE(LCON3)         = [F:Y03]LOT
    [M:YPP2]CADUCIDAD(LCON3)    = [F:Y03]CADUCIDAD
    [M:YPP2]ENDDAT(LCON3)       = [F:Y03]LIMDAT
    [M:YPP2]BLISTER(LCON3)      = [F:Y03]BLISTER
    [M:YPP2]ETIQUETA(LCON3)     = [F:Y03]ETIQUETA
    [M:YPP2]PROSPECTO(LCON3)    = [F:Y03]PROSPECTO
    [M:YPP2]ESTUCHE(LCON3)      = [F:Y03]ESTUCHE
    [M:YPP2]CHIP(LCON3)         = [F:Y03]CHIP
    [M:YPP2]APTO(LCON3)         = [F:Y03]APTO
    [M:YPP2]NAPTO(LCON3)        = [F:Y03]NAPTO
    [M:YPP2]COMENTARIOS(LCON3)  = [F:Y03]COMENTARIOS
    [M:YPP2]CADUCIDAD(LCON3)    = [F:Y03]CADUCIDAD
    [M:YPP2]CONTROL(LCON3)      = [F:Y03]CONTROL
    [M:YPP2]ESTADO(LCON3)       = [F:Y03]ESTADO
    [M:YPP2]TRKLAST(LCON3)      = [F:Y03]TRKLAST
    [M:YPP2]CPLQTY(LCON3)       = [F:Y03]CPLQTY
    [M:YPP2]TCLCOD(LCON3)       = [F:Y03]TCLCOD
    [M:YPP2]MFGFCY(LCON3)       = [F:Y03]MFGFCY
    [M:YPP2]YTIPO(LCON3)        = [F:Y03]YTIPO
    If [F:Y03]TCLCOD = "YNPI" Then
      [M:YPP2]APTO(LCON3)   = 2
      [M:YPP2]NAPTO(LCON3)  = 1
      [M:YPP2]ESTADO(LCON3) = "A1"
    Endif

# lo deshabilito en esta parrilla por petición de Leticia
#    # gestiona los bloqueos
#    GLCK = func SPEYLIB0.SEARCH_LCKPRR([F:Y03]ITMREF,[F:Y03]LOT)
#    If !GLCK Then
#      Call LOCK_LCKPRR([F:Y03]ITMREF,[F:Y03]LOT,"PP") From SPEYLIB0
#    Else
#      Raz LLCKUID,LLCKUSR,LLCKTIM
#      Call GET_IDLCK([F:Y03]ITMREF,[F:Y03]LOT,LLCKUID,LLCKUSR,LLCKTIM) From SPEYLIB0
#      [M:YPP2]LCKUSR(LCON3) = LLCKUSR
#      [M:YPP2]LCKDAT(LCON3) = num$(LLCKTIM)
#    Endif

    LCON3                       += 1
  Next

# lo deshabilito en esta parrilla por petición de Leticia
#  If dim(LLCKUID) > 0 Then : Kill LLCKUID : Endif
#  If dim(LLCKTIM) > 0 Then : Kill LLCKTIM : Endif
#  If dim(LLCKUSR) > 0 Then : Kill LLCKUSR : Endif
Return

###############################################################
$BUSCA_DOCADJ
Local Integer LCON9 : Raz LCON9
  For LCON9 = 0 To [M:YPP2]NBLIG-1
    Filter [F:YOP0] Where MFGNUM = [M:YPP2]MFGNUM(LCON9) and MFGTIPO = [M:YPP2]MFGTIPO(LCON9)
    Read   [F:YOP0] First
    If !fstat Then
      [M:YPP2]DOCUMENTO(LCON9) = 2
      Affzo [M:YPP2]DOCUMENTO(LCON9)
    Else
      [M:YPP2]DOCUMENTO(LCON9) = 1
      Affzo [M:YPP2]DOCUMENTO(LCON9)
    Endif
    Filter [F:YOP0]
  Next
If dim(LCON9) > 0  Then : Kill LCON9 : Endif
Return

##############################################################
$ACT_DATOS
# lo deshabilito en esta parrilla por petición de Leticia
#Local Char      LITMREFL(100) : LITMREFL  = [M:YPP1]MFGITM
#Local Char      LLOTEL(100)   : LLOTEL    = [M:YPP1]LOTCDG

  Case [M:YPP1]MFGTIPO
    When 1 : Gosub ACT_DATOS_ORIGINAL
    When 2 : Gosub ACT_DATOS_DUPLICADA
  Endcase
  Raz GFLGCHANGE  # se han guardado cambios
  Gosub BUSCAR
  zonsui = "[M:YPP2]MFGNUM(GNOL)"

Return

##############################################################
$ACT_DATOS_ORIGINAL
  Read [F:YMP0]YMP0 = [M:YPP1]MFGNUM;[M:YPP1]MFGTIPO
  [F:YMP0]MFGNUM      = [M:YPP1]MFGNUM
  [F:YMP0]MFGTIPO     = [M:YPP1]MFGTIPO
#  If [M:YPP1]APTOD = 2 Then
#    [F:YMP0]ESTADO = "A1"
#  Elsif [M:YPP1]NAPTOD = 2 Then
#    [F:YMP0]ESTADO = "R"
#  Endif
  If [M:YPP1]APTOD = 2 and  [M:YPP1]ESTADO <> "A" Then
    [F:YMP0]ESTADO = "A1"
  Elsif [M:YPP1]NAPTOD = 2 Then
    [F:YMP0]ESTADO = "R"
  Else
    [F:YMP0]ESTADO = [M:YPP1]ESTADO
  Endif
  [F:YMP0]APTO        = [M:YPP1]APTOD
  [F:YMP0]NAPTO       = [M:YPP1]NAPTOD
  [F:YMP0]ITMREF      = [M:YPP1]MFGITM
  [F:YMP0]LOT         = [M:YPP1]LOTCDG
  [F:YMP0]CONTROL     = [M:YPP0]CONTROL
  [F:YMP0]BLISTER     = [M:YPP1]BLISTER
  [F:YMP0]ETIQUETA    = [M:YPP1]ETIQUETA
  [F:YMP0]PROSPECTO   = [M:YPP1]PROSPECTO
  [F:YMP0]ESTUCHE     = [M:YPP1]ESTUCHE
  [F:YMP0]CHIP        = [M:YPP1]CHIP
  [F:YMP0]COMENTARIOS = [M:YPP1]COMENTARIOS
  [F:YMP0]CONTROL     = [M:YPP1]CONTROL
  [F:YMP0]TRKLAST     = [M:YPP1]TRKLAST
  [F:YMP0]CPLQTY      = [M:YPP1]CPLQTY
  [F:YMP0]TCLCOD      = [M:YPP1]TCLCOD
  [F:YMP0]MFGFCY      = [M:YPP1]MFGFCY
  [F:YMP0]YTIPO       = [M:YPP1]YTIPO
  [F:YMP0]USRMODIFSTA = GUSER
  [F:YMP0]DATMODIFSTA = date$
  Trbegin [YMP0]
  If !fstat Then
    Rewrite [F:YMP0]
    If !fstat Then
      Commit
      Call MESSAGE("Actualización realizada correctamente") From GESECRAN
    Else
      Rollback
    Endif
  Else
    Write   [F:YMP0]
    If !fstat Then
      Commit
      Call MESSAGE("Actualización realizada correctamente") From GESECRAN
    Else
      Rollback
    Endif
  Endif
Return

