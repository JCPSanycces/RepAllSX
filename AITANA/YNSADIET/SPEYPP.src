######################################################################################
## Botón 1 - Seleccionar todos los registros de grid 'Estados'
######################################################################################
Subprog B1_NBSTA
Local Integer LCON5 : Raz LCON5

  For LCON5 = 0 To [M:YPP0]NBSTA-1
    [M:YPP0]SELSTA(LCON5) = 2
    Affzo [M:YPP0]SELSTA(LCON5)
  Next
If dim(LCON5) > 0  Then : Kill LCON5 : Endif
End

######################################################################################
## Botón 2 - Desmarcar todos los registros de grid 'Estados'
######################################################################################
Subprog B2_NBSTA
Local Integer LCON5 : Raz LCON5

  For LCON5 = 0 To [M:YPP0]NBSTA-1
    [M:YPP0]SELSTA(LCON5) = 1
    Affzo [M:YPP0]SELSTA(LCON5)
  Next
If dim(LCON5) > 0  Then : Kill LCON5 : Endif
End

