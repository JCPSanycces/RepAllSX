  [F:YDP1]MFGTIPO     = [M:YPP1]MFGTIPO
  [F:YDP1]CONTROL     = [M:YPP0]CONTROL
  [F:YDP1]STRDAT      = [M:YPP1]MFGDAT
  [F:YDP1]ITMREF      = [M:YPP1]MFGITM
  [F:YDP1]LOT         = [M:YPP1]LOTCDG
  [F:YDP1]CADUCIDAD   = [M:YPP1]CADUCIDAD
  [F:YDP1]ENDDAT      = [M:YPP1]LIMDAT
  [F:YDP1]LOTEMP      = [M:YPP1]LOTEMP
  [F:YDP1]BLISTER     = [M:YPP1]BLISTER
  [F:YDP1]ETIQUETA    = [M:YPP1]ETIQUETA
  [F:YDP1]PROSPECTO   = [M:YPP1]PROSPECTO
  [F:YDP1]ESTUCHE     = [M:YPP1]ESTUCHE
  [F:YDP1]CHIP        = [M:YPP1]CHIP
  [F:YDP1]COMENTARIOS = [M:YPP1]COMENTARIOS
  [F:YDP1]CONTROL     = [M:YPP1]CONTROL
  [F:YDP1]TRKLAST     = [M:YPP1]TRKLAST
