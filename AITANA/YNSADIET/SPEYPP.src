End

######################################################################################
## Después de modificar el campo 'Caducidad'
######################################################################################
Subprog AM_CADUCIDAD(VALEUR)
Variable Date    VALEUR
  # fecha límite
  Read [F:ITM0]ITM0 = [M:YPP1]MFGITM
  If !fstat Then
    [M:YPP1]LIMDAT = VALEUR - [F:ITM0]YDIASFLU
    Affzo [M:YPP1]LIMDAT
  Endif

  GFLGCHANGE+=1
End

######################################################################################
## Antes de entra en el campo 'Fecha límite'
######################################################################################
Subprog AS_LIMDAT(VALEUR)
Variable Date    VALEUR
  Read [F:ITM0]ITM0 = [M:YPP1]MFGITM
  If !fstat Then
    VALEUR = [M:YPP1]CADUCIDAD - [F:ITM0]YDIASFLU
    Affzo [M:YPP1]LIMDAT
  Endif
End

######################################################################################
## Después del campo 'Chip'
######################################################################################
Subprog AP_CHIP(VALEUR)
Variable Integer VALEUR
End

######################################################################################
## Después de modificar el campo 'Desde número'
######################################################################################
Subprog AM_STRMFG(VALEUR)
Variable Char    VALEUR()
  If [M:YPP0]ENDMFG = "" Then
    [M:YPP0]ENDMFG = VALEUR
    Affzo [M:YPP0]ENDMFG
  Endif
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
##############################################################
#######################
#**
#* devuelve el código de la siguiente OF al duplicar
#*
#* @param PMFGCDG  > código de OF
#* @param PCODIGO  > devuelve código duplicado de la OF a duplicar
#*!
Subprog GET_CODIGO(PMFGCDG, PCODIGO)
Value     Char PMFGCDG
Variable  Char PCODIGO

Local Char DCAD(1), ICAD(25) : Raz DCAD, ICAD

  Filter [F:YDP2] Where MFGCDG = PMFGCDG Order By MFGNUM Desc
  Read   [F:YDP2] First
  DCAD = right$(PMFGCDG,len(PMFGCDG))
  ICAD = left$(PMFGCDG,(len(PMFGCDG))-1)
  PCODIGO = ICAD + num$(val(DCAD)+1)
  Filter [F:YDP2]

End
