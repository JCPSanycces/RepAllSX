##############################################################
$ACT_LINEAS
Local Integer LCON, LSTA
  For LCON = 0 To [M:YPP2]NBLIG - 1
    Case [M:YPP2]MFGTIPO(LCON)
      When 1 : Gosub ACT_LINEAS_ORIGINAL
      When 2 : Gosub ACT_LINEAS_DUPLICADA
    Endcase
  Next

  If LSTA = [M:YPP2]NBLIG Then
    Call MESSAGE("Proceso finalizado con éxito") From GESECRAN
  Endif

  Raz GFLGCHANGE  # se han guardado cambios
  Gosub BUSCAR
  zonsui = "[M:YPP2]MFGNUM(GNOL)"

  If dim(LCON) > 0 Then Kill LCON : Endif
  If dim(LSTA) > 0 Then Kill LSTA : Endif
Return

##############################################################
$ACT_LINEAS_ORIGINAL
  Read [F:YMP0]YMP0 = [M:YPP2]MFGNUM(LCON);[M:YPP2]MFGTIPO(LCON)
  [F:YMP0]MFGNUM      = [M:YPP2]MFGNUM(LCON)
  [F:YMP0]MFGTIPO     = [M:YPP2]MFGTIPO(LCON)
  If [M:YPP2]APTO(LCON) = 2 and  [M:YPP2]ESTADO(LCON) <> "A" Then
    [F:YMP0]ESTADO = "A1"
  Elsif [M:YPP2]NAPTO(LCON) = 2 Then
    [F:YMP0]ESTADO = "R"
  Else
    [F:YMP0]ESTADO = [M:YPP2]ESTADO(LCON)
  Endif
  [F:YMP0]APTO        = [M:YPP2]APTO(LCON)
  [F:YMP0]NAPTO       = [M:YPP2]NAPTO(LCON)
  [F:YMP0]ITMREF      = [M:YPP2]ITMREF(LCON)
  [F:YMP0]LOT         = [M:YPP2]LOTE(LCON)
  [F:YMP0]BLISTER     = [M:YPP2]BLISTER(LCON)
  [F:YMP0]ETIQUETA    = [M:YPP2]ETIQUETA(LCON)
  [F:YMP0]PROSPECTO   = [M:YPP2]PROSPECTO(LCON)
  [F:YMP0]ESTUCHE     = [M:YPP2]ESTUCHE(LCON)
  [F:YMP0]CHIP        = [M:YPP2]CHIP(LCON)
  [F:YMP0]COMENTARIOS = [M:YPP2]COMENTARIOS(LCON)
  [F:YMP0]CONTROL     = [M:YPP2]CONTROL(LCON)
  [F:YMP0]TRKLAST     = [M:YPP2]TRKLAST(LCON)
  [F:YMP0]CPLQTY      = [M:YPP2]CPLQTY(LCON)
  [F:YMP0]TCLCOD      = [M:YPP2]TCLCOD(LCON)
  [F:YMP0]MFGFCY      = [M:YPP2]MFGFCY(LCON)
  [F:YMP0]YTIPO       = [M:YPP2]YTIPO(LCON)
  [F:YMP0]USRMODIFSTA = GUSER
  [F:YMP0]DATMODIFSTA = date$
  Trbegin [YMP0]
  If !fstat Then
    Rewrite [F:YMP0]
    If !fstat Then
      Commit
      LSTA += 1
    Else
      Rollback
    Endif
  Else
    Write   [F:YMP0]
    If !fstat Then
      Commit
      LSTA += 1
    Else
      Rollback
    Endif
  Endif
Return

##############################################################
$ACT_LINEAS_DUPLICADA
  Read [F:YDP1]YDP0 = [M:YPP2]MFGNUM(LCON);[M:YPP2]MFGCDG(LCON);[M:YPP2]MFGTIPO(LCON)
  [F:YDP1]MFGNUM      = [M:YPP2]MFGNUM(LCON)
  If [M:YPP2]APTO(LCON) = 2 and  [M:YPP2]ESTADO(LCON) <> "A" Then
    [F:YDP1]ESTADO = "A1"
  Elsif [M:YPP2]NAPTO(LCON) = 2 Then
    [F:YDP1]ESTADO = "R"
  Else
    [F:YDP1]ESTADO = [M:YPP2]ESTADO(LCON)
  Endif
  [F:YDP1]APTO        = [M:YPP2]APTO(LCON)
  [F:YDP1]NAPTO       = [M:YPP2]NAPTO(LCON)
  [F:YDP1]MFGTIPO     = [M:YPP2]MFGTIPO(LCON)
  [F:YDP1]STRDAT      = [M:YPP2]STRDAT(LCON)
  [F:YDP1]ITMREF      = [M:YPP2]ITMREF(LCON)
  [F:YDP1]LOT         = [M:YPP2]LOTE(LCON)
  [F:YDP1]CADUCIDAD   = [M:YPP2]CADUCIDAD(LCON)
  [F:YDP1]ENDDAT      = [M:YPP2]ENDDAT(LCON)
  [F:YDP1]LOTEMP      = [M:YPP2]LOTEMP(LCON)
  [F:YDP1]BLISTER     = [M:YPP2]BLISTER(LCON)
  [F:YDP1]ETIQUETA    = [M:YPP2]ETIQUETA(LCON)
  [F:YDP1]PROSPECTO   = [M:YPP2]PROSPECTO(LCON)
  [F:YDP1]ESTUCHE     = [M:YPP2]ESTUCHE(LCON)
  [F:YDP1]CHIP        = [M:YPP2]CHIP(LCON)
  [F:YDP1]COMENTARIOS = [M:YPP2]COMENTARIOS(LCON)
  [F:YDP1]CONTROL     = [M:YPP2]CONTROL(LCON)
  [F:YDP1]TRKLAST     = [M:YPP2]TRKLAST(LCON)
  [F:YDP1]CPLQTY      = [M:YPP2]CPLQTY(LCON)
  [F:YDP1]TCLCOD      = [M:YPP2]TCLCOD(LCON)
  [F:YDP1]MFGFCY      = [M:YPP2]MFGFCY(LCON)
  [F:YDP1]YTIPO       = [M:YPP2]YTIPO(LCON)
  [F:YDP1]USRMODIFSTA = GUSER
  [F:YDP1]DATMODIFSTA = date$
  Trbegin [F:YDP1]
  If !fstat Then
    Rewrite [F:YDP1]
    If !fstat Then
      Commit
      LSTA += 1
    Else
      Rollback
    Endif
  Else
    Write   [F:YDP1]
    If !fstat Then
      Commit
      LSTA += 1
    Else
      Rollback
    Endif
  Endif
Return

##############################################################
$DUPLICAR
Local Char LCODIGO(25)
  If [M:YPP1]CONTROL = 1 Then
    Filter [F:YDP0] Where MFGNUM = [M:YPP1]MFGNUM Order By CODIGO Desc
    Read [F:YDP0] First
    If !fstat Then
      [F:YDP0]MFGNUM      = [M:YPP1]MFGNUM                                # orden
      Call GET_CODIGO([F:YDP0]CODIGO,[F:YDP0]CODIGO)
      [F:YDP0]MFGTIPO     = 2                                             # tipo; 2=duplicado
      [F:YDP0]STRDAT      = [M:YPP1]MFGDAT                                # fecha
      [F:YDP0]ITMREF      = [M:YPP1]MFGITM                                # artículo
      [F:YDP0]LOT         = [M:YPP1]LOTCDG                                # lote
      [F:YDP0]CADUCIDAD   = [M:YPP1]CADUCIDAD                             # caducidad
      [F:YDP0]ENDDAT      = [M:YPP1]LIMDAT                                # fecha límite
      [F:YDP0]LOTEMP      = [M:YPP1]LOTEMP                                # lote materia prima
      [F:YDP0]CONTROL     = [M:YPP1]CONTROL                               # control
      [F:YDP0]TRKLAST     = [M:YPP1]TRKLAST                               # fecha último seguimiento
      [F:YDP0]CPLQTY      = [M:YPP1]CPLQTY                                # cantidad realizada total
      [F:YDP0]TCLCOD      = [M:YPP1]TCLCOD                                # categoría de artículo
      [F:YDP0]MFGFCY      = [M:YPP1]MFGFCY                                # planta de producción
      [F:YDP0]YTIPO       = [M:YPP1]YTIPO                                 # tipo de of
# JC.10022021.STR
      [F:YDP0]ESTADO      = "Q"                                           # estado siempre a Q
      [F:YDP0]APTO        = 0                                             # apto siempre a 0
      [F:YDP0]NAPTO       = 0                                             # no apto siempre a 0
      [F:YDP0]BLISTER     = ""                                            # blister siempre en blanco
      [F:YDP0]ETIQUETA    = ""                                            # etiqueta siempre en blanco
      [F:YDP0]PROSPECTO   = ""                                            # prospecto siempre en blanco
      [F:YDP0]ESTUCHE     = ""                                            # estuche siempre en blanco
      [F:YDP0]CHIP        = 0                                             # chip siempre en blanco
      [F:YDP0]COMENTARIOS = ""                                            # comentarios siempre en blanco
      [F:YDP0]NOTASLIB    = ""                                            # notas liberación siempre en blanco
# JC.10022021.END
      Trbegin [YDP0]
      Write [F:YDP0]
      If !fstat Then
        Commit
        Call MESSAGE("Registro duplicado con éxito") From GESECRAN
      Else
        Rollback
      Endif
    Else
      [F:YDP0]MFGNUM      = [M:YPP1]MFGNUM                                # orden
      [F:YDP0]CODIGO      = [M:YPP1]MFGNUM + "-1"                         # código
      [F:YDP0]MFGTIPO     = 2                                             # tipo; 2=duplicado
      [F:YDP0]STRDAT      = [M:YPP1]MFGDAT                                # fecha
      [F:YDP0]ITMREF      = [M:YPP1]MFGITM                                # artículo
      [F:YDP0]LOT         = [M:YPP1]LOTCDG                                # lote
      [F:YDP0]CADUCIDAD   = [M:YPP1]CADUCIDAD                             # caducidad
      [F:YDP0]ENDDAT      = [M:YPP1]LIMDAT                                # fecha límite
      [F:YDP0]LOTEMP      = [M:YPP1]LOTEMP                                # lote materia prima
      [F:YDP0]CONTROL     = [M:YPP1]CONTROL                               # control
      [F:YDP0]TRKLAST     = [M:YPP1]TRKLAST                               # fecha último seguimiento
      [F:YDP0]CPLQTY      = [M:YPP1]CPLQTY                                # cantidad realizada total
      [F:YDP0]TCLCOD      = [M:YPP1]TCLCOD                                # categoría de artículo
      [F:YDP0]MFGFCY      = [M:YPP1]MFGFCY                                # planta de producción
      [F:YDP0]YTIPO       = [M:YPP1]YTIPO                                 # tipo de of
# JC.10022021.STR
      [F:YDP0]ESTADO      = "Q"                                           # estado siempre a Q
      [F:YDP0]APTO        = 0                                             # apto siempre a 0
      [F:YDP0]NAPTO       = 0                                             # no apto siempre a 0
      [F:YDP0]BLISTER     = ""                                            # blister siempre en blanco
      [F:YDP0]ETIQUETA    = ""                                            # etiqueta siempre en blanco
      [F:YDP0]PROSPECTO   = ""                                            # prospecto siempre en blanco
      [F:YDP0]ESTUCHE     = ""                                            # estuche siempre en blanco
      [F:YDP0]CHIP        = 0                                             # chip siempre en blanco
      [F:YDP0]COMENTARIOS = ""                                            # comentarios siempre en blanco
      [F:YDP0]NOTASLIB    = ""                                            # notas liberación siempre en blanco
# JC.10022021.END
      Trbegin [YDP0]
      Write [F:YDP0]
      If !fstat Then
        Commit
        Call MESSAGE("Registro duplicado con éxito") From GESECRAN
      Else
        Rollback
      Endif
    Endif
    Filter [F:YDP0]
    Gosub BUSCAR
  Else
    Call ERREUR("Sólo se permiten duplicar OF's con Control = Firme") From GESECRAN
    mkstat = 2
  Endif

Return

##############################################################
$MUESTRA_REGISTRO_ORIGINAL

  CRITSQL1(0) =  "SELECT MFGHEAD.MFGNUM_0,MFGHEAD.STRDAT_0,MFGITM.ITMREF_0,MFGITM.LOT_0,YMFGHEADPP.ESTADO_0,YMFGHEADPP.BLISTER_0, "
  CRITSQL1(0) += "YMFGHEADPP.ETIQUETA_0,YMFGHEADPP.PROSPECTO_0,YMFGHEADPP.ESTUCHE_0,YMFGHEADPP.CHIP_0,YMFGHEADPP.COMENTARIOS_0,YMFGHEADPP.APTO_0, "
  CRITSQL1(1) =  "YMFGHEADPP.NAPTO_0,MFGITM.YLOTEMP_0,MFGITM.YCADUCIDAD_0,MFGITM.YFLU_0,MFGHEAD.MFGSTA_0,MFGITM.TRKLAST_0,MFGITM.CPLQTY_0,MFGITM.TCLCOD_0,MFGITM.MFGFCY_0, "
  CRITSQL1(1) += "MFGITM.YTIPO_0 "
  CRITSQL1(2) =  "FROM "+nomap+".MFGHEAD LEFT OUTER JOIN "+nomap+".YMFGHEADPP ON "+nomap+".MFGHEAD.MFGNUM_0 ="+nomap+".YMFGHEADPP.MFGNUM_0 "
  CRITSQL1(3) =  "LEFT OUTER JOIN "+nomap+".MFGITM ON "+nomap+".MFGHEAD.MFGNUM_0="+nomap+".MFGITM.MFGNUM_0 "
  CRITSQL1(4) =  "WHERE MFGHEAD.MFGNUM_0='" + [M:YPP2]MFGNUM(nolign-1) + "'"

#Local Integer I
#For I=0 To 4
#Infbox CRITSQL1(I)
#Next

  For (Char MFGNUM(250),Date STRDAT,Char ITMREF(250),Char LOT(250),Char ESTADO(250),Char BLISTER(250), Char ETIQUETA(250), Char PROSPECTO(250),
&      Char ESTUCHE(250), Integer CHIP, Char COMENTARIOS(250), Integer APTO, Integer NAPTO, Char YLOTEMP(250), Date YCADUCIDAD, Date YFLU, Integer CONTROL,
&      Date TRKLAST, Decimal CPLQTY, Char TCLCOD(250), Char MFGFCY(250), Integer YTIPO) From "5" Sql CRITSQL1(0..4) As [Y01]
    [M:YPP1]MFGNUM      = [F:Y01]MFGNUM
    [M:YPP1]MFGCDG      = [F:Y01]MFGNUM
    [M:YPP1]MFGDAT      = [F:Y01]STRDAT
    [M:YPP1]MFGITM      = [F:Y01]ITMREF
    [M:YPP1]MFGTIPO     = 1
    [M:YPP1]LOTCDG      = [F:Y01]LOT
    [M:YPP1]ESTADO      = [F:Y01]ESTADO
    [M:YPP1]BLISTER     = [F:Y01]BLISTER
    [M:YPP1]ETIQUETA    = [F:Y01]ETIQUETA
    [M:YPP1]PROSPECTO   = [F:Y01]PROSPECTO
    [M:YPP1]ESTUCHE     = [F:Y01]ESTUCHE
    [M:YPP1]CHIP        = [F:Y01]CHIP
    [M:YPP1]COMENTARIOS = [F:Y01]COMENTARIOS
    [M:YPP1]APTOD        = [F:Y01]APTO
    [M:YPP1]NAPTOD       = [F:Y01]NAPTO
    [M:YPP1]LOTEMP      = [F:Y01]YLOTEMP
    [M:YPP1]CADUCIDAD   = [F:Y01]YCADUCIDAD
    [M:YPP1]LIMDAT      = [F:Y01]YFLU
    [M:YPP1]CONTROL     = [F:Y01]CONTROL
    [M:YPP1]TRKLAST     = [F:Y01]TRKLAST
    [M:YPP1]CPLQTY      = [F:Y01]CPLQTY
    [M:YPP1]TCLCOD      = [F:Y01]TCLCOD
    [M:YPP1]MFGFCY      = [F:Y01]MFGFCY
    [M:YPP1]YTIPO       = [F:Y01]YTIPO
    [M:YPP1]YTIPOREG    = 0
  Next

Return

##############################################################
$MUESTRA_REGISTRO_DUPLICADA
  CRITSQL3(0) =  "SELECT YMFGDUPLIPP.MFGNUM_0,YMFGDUPLIPP.CODIGO_0,YMFGDUPLIPP.ESTADO_0,YMFGDUPLIPP.MFGTIPO_0,YMFGDUPLIPP.STRDAT_0,YMFGDUPLIPP.ITMREF_0,"
  CRITSQL3(0) += "YMFGDUPLIPP.LOT_0,YMFGDUPLIPP.CADUCIDAD_0,YMFGDUPLIPP.ENDDAT_0,YMFGDUPLIPP.LOTEMP_0,YMFGDUPLIPP.BLISTER_0,"
  CRITSQL3(1) =  "YMFGDUPLIPP.ETIQUETA_0,YMFGDUPLIPP.PROSPECTO_0,YMFGDUPLIPP.ESTUCHE_0,YMFGDUPLIPP.CHIP_0,YMFGDUPLIPP.COMENTARIOS_0,YMFGDUPLIPP.APTO_0,YMFGDUPLIPP.NAPTO_0, "
  CRITSQL3(1) += "YMFGDUPLIPP.CONTROL_0,YMFGDUPLIPP.TRKLAST_0,YMFGDUPLIPP.CPLQTY_0,YMFGDUPLIPP.TCLCOD_0,YMFGDUPLIPP.MFGFCY_0,YMFGDUPLIPP.YTIPO_0 "
  CRITSQL3(2) =  "FROM "+nomap+".YMFGDUPLIPP "
  CRITSQL3(3) =  "WHERE YMFGDUPLIPP.CODIGO_0='" + [M:YPP2]MFGCDG(nolign-1) + "'"

#If GUSER="AIT07" Then
#Local Integer I
#For I=0 To 3
#Infbox CRITSQL3(I)
#Next
#Endif

  For (Char MFGNUM(250),Char CODIGO(250), Char ESTADO(250),Integer MFGTIPO,Date STRDAT,Char ITMREF(250),Char LOT(250),Date CADUCIDAD,Date ENDDAT,Char LOTEMP(250),Char BLISTER(250),
&      Char ETIQUETA(250),Char PROSPECTO(250),Char ESTUCHE(250),Integer CHIP,Char COMENTARIOS(250), Integer APTO, Integer NAPTO, Integer CONTROL,
&      Date TRKLAST, Decimal CPLQTY, Char TCLCOD(250), Char MFGFCY(250), Integer YTIPO) From "5" Sql CRITSQL3(0..3) As [Y03]
    [M:YPP1]MFGNUM      = [F:Y03]MFGNUM
    [M:YPP1]MFGCDG      = [F:Y03]CODIGO
    [M:YPP1]MFGDAT      = [F:Y03]STRDAT
    [M:YPP1]MFGITM      = [F:Y03]ITMREF
    [M:YPP1]MFGTIPO     = [F:Y03]MFGTIPO
    [M:YPP1]LOTCDG      = [F:Y03]LOT
    [M:YPP1]ESTADO      = [F:Y03]ESTADO
    [M:YPP1]BLISTER     = [F:Y03]BLISTER
    [M:YPP1]ETIQUETA    = [F:Y03]ETIQUETA
    [M:YPP1]PROSPECTO   = [F:Y03]PROSPECTO
    [M:YPP1]ESTUCHE     = [F:Y03]ESTUCHE
    [M:YPP1]CHIP        = [F:Y03]CHIP
    [M:YPP1]COMENTARIOS = [F:Y03]COMENTARIOS
    [M:YPP1]APTOD        = [F:Y03]APTO
    [M:YPP1]NAPTOD       = [F:Y03]NAPTO
    [M:YPP1]LOTEMP      = [F:Y03]LOTEMP
    [M:YPP1]CADUCIDAD   = [F:Y03]CADUCIDAD
    [M:YPP1]LIMDAT      = [F:Y03]ENDDAT
    [M:YPP1]CONTROL     = [F:Y03]CONTROL
    [M:YPP1]TRKLAST     = [F:Y03]TRKLAST
    [M:YPP1]CPLQTY      = [F:Y03]CPLQTY
    [M:YPP1]TCLCOD      = [F:Y03]TCLCOD
    [M:YPP1]MFGFCY      = [F:Y03]MFGFCY
    [M:YPP1]YTIPO       = [F:Y03]YTIPO
    [M:YPP1]YTIPOREG    = 0
  Next

Return

##############################################################
$MUESTRA_REGISTRO_DEVEXT
  CRITSQL5(0) = "SELECT YMFGHEADPP.MFGNUM_0,YMFGHEADPP.MFGTIPO_0,YMFGHEADPP.APTO_0,YMFGHEADPP.NAPTO_0,YMFGHEADPP.ESTADO_0,YMFGHEADPP.CONTROL_0,YMFGHEADPP.ITMREF_0,"
  CRITSQL5(1) = "YMFGHEADPP.LOT_0,YMFGHEADPP.BLISTER_0,YMFGHEADPP.ETIQUETA_0,YMFGHEADPP.PROSPECTO_0,YMFGHEADPP.ESTUCHE_0,YMFGHEADPP.CHIP_0,"
  CRITSQL5(2) =  "YMFGHEADPP.COMENTARIOS_0,YMFGHEADPP.CADUCIDAD_0,YMFGHEADPP.LIMDAT_0,YMFGHEADPP.FECHAR_0,YMFGHEADPP.TRKLAST_0,YMFGHEADPP.CPLQTY_0,YMFGHEADPP.TCLCOD_0,"
  CRITSQL5(2) += "YMFGHEADPP.MFGFCY_0,YMFGHEADPP.YTIPO_0 "
  CRITSQL5(3) =  "FROM "+nomap+".YMFGHEADPP "
  CRITSQL5(4) =  "WHERE YMFGHEADPP.MFGNUM_0='" + [M:YPP2]MFGNUM(nolign-1) + "'"

#Local Integer I
#Infbox "HEAD"
#For I=0 To 4
#  Infbox CRITSQL5(I)
#Next

  For (Char MFGNUM(250), Integer MFGTIPO, Integer APTO, Integer NAPTO, Char ESTADO(250), Integer CONTROL, Char ITMREF(250),
&      Char LOT(250), Char BLISTER(250), Char ETIQUETA(250), Char PROSPECTO(250), Char ESTUCHE(250), Integer CHIP,
&      Char COMENTARIOS(250), Date CADUCIDAD, Date LIMDAT, Date FECHAR, Date TRKLAST, Decimal CPLQTY, Char TCLCOD(250), Char MFGFCY(250), Integer YTIPO) From "5" Sql CRITSQL5(0..4) As [Y05]
    [M:YPP1]APTOD         = [F:Y05]APTO
    [M:YPP1]NAPTOD        = [F:Y05]NAPTO
    [M:YPP1]ESTADO       = [F:Y05]ESTADO
    Case left$([F:Y05]MFGNUM,3)
      When "DEV" : [M:YPP1]YTIPOREG = 1
      When "EXT" : [M:YPP1]YTIPOREG = 2
    Endcase
    [M:YPP1]MFGNUM       = [F:Y05]MFGNUM
    [M:YPP1]MFGCDG       = [F:Y05]MFGNUM
    [M:YPP1]MFGDAT       = [F:Y05]FECHAR
    [M:YPP1]MFGITM       = [F:Y05]ITMREF
    [M:YPP1]MFGTIPO      = [F:Y05]MFGTIPO
    [M:YPP1]LOTCDG       = [F:Y05]LOT
    [M:YPP1]CADUCIDAD    = [F:Y05]CADUCIDAD
    [M:YPP1]LIMDAT       = [F:Y05]LIMDAT
    [M:YPP1]COMENTARIOS  = [F:Y05]COMENTARIOS
    [M:YPP1]BLISTER      = [F:Y05]BLISTER
    [M:YPP1]ETIQUETA     = [F:Y05]ETIQUETA
    [M:YPP1]PROSPECTO    = [F:Y05]PROSPECTO
    [M:YPP1]ESTUCHE      = [F:Y05]ESTUCHE
    [M:YPP1]CHIP         = [F:Y05]CHIP
    [M:YPP1]CONTROL      = [F:Y05]CONTROL
    [M:YPP1]TRKLAST      = [F:Y05]TRKLAST
    [M:YPP1]CPLQTY       = [F:Y05]CPLQTY
    [M:YPP1]TCLCOD       = [F:Y05]TCLCOD
    [M:YPP1]MFGFCY       = [F:Y05]MFGFCY
    [M:YPP1]YTIPO        = [F:Y05]YTIPO
  Next
Return

##############################################################
$ADJ_DOCUMENTO
Local Integer LINT4

  GPARAM1(0) = [M:YPP1]MFGNUM                                                    # pase de parámetros entre pantallas
  GPARAM1(1) = num$([M:YPP1]MFGTIPO)                                             # pase de parámetros entre pantallas
  Call SAISIE_LIB(LINT4,GPARAM1,"OYOP","SPEYDP","OBJZON") From GSAISIE           # llamada a la función que abre la pantalla emregente
  Gosub BUSCAR
Return

###############################################################
$CARGA_ESTADOS
Local Integer LCON4 : Raz LCON4

  Link [AXX1] With [TST1]TST0=[F:AXX1]IDENT1 As [LNK1] Where CODFIC="TABSTASTO" and ZONE = "STAAXX" and LANGUE=GLANGUE
  Columns [LNK1] ([TST1]STASTO,[AXX1]TEXTE)

  For [LNK1]
    [M:YPP0]CDGSTA(LCON4) = [F:TST1]STASTO
    [M:YPP0]DESSTA(LCON4) = [F:AXX1]TEXTE
    LCON4 += 1
  Next
  [M:YPP0]NBSTA = LCON4
  Affzo [M:YPP0]15
Return

###############################################################
$CREAR
  Actzo [M:YPP1]YTIPOREG,MFGDAT,MFGITM,LOTCDG,CADUCIDAD,LIMDAT
  Gosub LIMPIAR_DATOS
  [M:YPP1]YTIPOREG  = 1     : Affzo [M:YPP1]YTIPOREG      # tipo registro
  [M:YPP1]MFGDAT    = date$ : Affzo [M:YPP1]MFGDAT        # fecha
  [M:YPP1]MFGTIPO   = 1     : Affzo [M:YPP1]MFGTIPO       # tipo
  [M:YPP1]CADUCIDAD = date$ : Affzo [M:YPP1]CADUCIDAD     # caducidad

  GFLGCHANGE+=1
Return

###############################################################
$LIMPIAR_DATOS
  Raz [M:YPP1]APTOD       : Raz [M:YPP1]ESTADO      : Raz [M:YPP1]NAPTOD    : Raz [M:YPP1]RECHAZADO   : Raz [M:YPP1]DOCUMENTO     : Raz [M:YPP1]YTIPOREG
  Raz [M:YPP1]MFGNUM      : Raz [M:YPP1]MFGCDG      : Raz [M:YPP1]MFGDAT    : Raz [M:YPP1]MFGITM      : Raz [M:YPP1]MFGTIPO       : Raz [M:YPP1]LOTCDG
  Raz [M:YPP1]CADUCIDAD   : Raz [M:YPP1]LIMDAT      : Raz [M:YPP1]LOTEMP    : Raz [M:YPP1]COMENTARIOS : Raz [M:YPP1]BLISTER       : Raz [M:YPP1]ETIQUETA
  Raz [M:YPP1]PROSPECTO   : Raz [M:YPP1]ESTUCHE     : Raz [M:YPP1]CHIP      : Raz [M:YPP1]CONTROL     : Raz [M:YPP1]TRKLAST       : Raz [M:YPP1]CPLQTY
  Raz [M:YPP1]TCLCOD      : Raz [M:YPP1]MFGFCY      : Raz [M:YPP1]YTIPO
  Affzo [M:YPP1]APTOD     : Affzo [M:YPP1]          : Affzo [M:YPP1]ESTADO  : Affzo [M:YPP1]NAPTOD    : Affzo [M:YPP1]RECHAZADO   : Affzo [M:YPP1]DOCUMENTO
  Affzo [M:YPP1]YTIPOREG  : Affzo [M:YPP1]MFGNUM    : Affzo [M:YPP1]MFGCDG  : Affzo [M:YPP1]MFGDAT    : Affzo [M:YPP1]MFGITM      : Affzo [M:YPP1]MFGTIPO
  Affzo [M:YPP1]LOTCDG    : Affzo [M:YPP1]CADUCIDAD : Affzo [M:YPP1]LIMDAT  : Affzo [M:YPP1]LOTEMP    : Affzo [M:YPP1]COMENTARIOS : Affzo [M:YPP1]BLISTER
  Affzo [M:YPP1]ETIQUETA  : Affzo [M:YPP1]TRKLAST   : Affzo [M:YPP1]CPLQTY  : Affzo [M:YPP1]TCLCOD    : Affzo [M:YPP1]MFGFCY      : Affzo [M:YPP1]YTIPO
Return

###############################################################
$CREA_REGISTRO
  Trbegin [F:YMP2]
  # número de orden
  Case [M:YPP1]YTIPOREG
    When 1 : Call GENNUMBER("YDEVP",date$,[F:YMP2]MFGNUM) From SPEYLIB0 : [M:YPP1]MFGNUM = [F:YMP2]MFGNUM : Affzo [M:YPP1]MFGNUM
    When 2 : Call GENNUMBER("YEXTP",date$,[F:YMP2]MFGNUM) From SPEYLIB0 : [M:YPP1]MFGNUM = [F:YMP2]MFGNUM : Affzo [M:YPP1]MFGNUM
  Endcase
  [F:YMP2]MFGTIPO     = [M:YPP1]MFGTIPO                                                   # tipo de orden
  If [M:YPP1]APTOD     = 2 Then : [F:YMP2]APTO   = 2 : Endif                              # apto
  If [M:YPP1]NAPTOD    = 2 Then : [F:YMP2]NAPTO  = 2 : Endif                              # no apto
  [F:YMP2]ESTADO      = "Q"                                                               # estado
  [F:YMP2]CONTROL     = [M:YPP1]CONTROL                                                   # control
  [F:YMP2]ITMREF      = [M:YPP1]MFGITM                                                    # artículo
  [F:YMP2]LOT         = [M:YPP1]LOTCDG                                                    # lote
  [F:YMP2]BLISTER     = [M:YPP1]BLISTER                                                   # blister
  [F:YMP2]ETIQUETA    = [M:YPP1]ETIQUETA                                                  # etiqueta
  [F:YMP2]PROSPECTO   = [M:YPP1]PROSPECTO                                                 # prospecto
  [F:YMP2]ESTUCHE     = [M:YPP1]ESTUCHE                                                   # estuche
  [F:YMP2]CHIP        = [M:YPP1]CHIP                                                      # chip
  [F:YMP2]COMENTARIOS = [M:YPP1]COMENTARIOS                                               # comentarios
  [F:YMP2]USRMODIFSTA = GUSER                                                             # usuario mod. estado
  [F:YMP2]DATMODIFSTA = date$                                                             # fecha mod. estado
  [F:YMP2]CADUCIDAD   = [M:YPP1]CADUCIDAD                                                 # caducidad
  [F:YMP2]LIMDAT      = [M:YPP1]LIMDAT                                                    # fecha límite
  [F:YMP2]FECHAR      = [M:YPP1]MFGDAT                                                    # fecha
  [F:YMP2]TCLCOD      = [M:YPP1]TCLCOD                                                    # categoría del artículo
  [F:YMP2]MFGFCY      = [M:YPP1]MFGFCY                                                    # planta de producción
  Write [F:YMP2]
  If !fstat Then
    Commit
    Call MESSAGE("Registro"-[F:YMP2]MFGNUM-"añadido") From GESECRAN
  Else
    Rollback
    Call MESSAGE("El registro no se puedo añadir") From GESECRAN
  Endif

  Raz GFLGCHANGE
  Gosub DEBUT
  Gosub BUSCAR
Return

###############################################################
$CANCELA_REGISTRO
  Raz [M:YPP1]
  Raz GFLGCHANGE        # variable que se utiliza para controlar cambios en el bloque de datos
  Gosub DEBUT
Return

##############################################################
$SALIR
Local Integer YESNO : YESNO = 1 # no
  # si no se han producido cambios o se han guardado
  If GFLGCHANGE = 0 Then
    Gosub FIN
  Else
    Call OUINONT("Se han producido cambios y no has guardado la información.\¿Realmente deseas continuar?",YESNO) From GESECRAN
    If YESNO = 2 Then
      Gosub FIN
    Endif
  Endif
Return

##############################################################
$PAINT_LCKLINE
Local Integer LCON : Raz LCON

  For LCON = 0 To [M:YPP2]NBLIG-1
    If [M:YPP2]LCKUSR(LCON) <> "" Then
      Chgstl [M:YPP2]NBLIG(LCON) With "BACKRED"
    Else
      Chgstl [M:YPP2]NBLIG(LCON) With ""
    Endif
  Next

  If dim(LCON) > 0 Then : Kill LCON : Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Antes entrada NBLIG
## Muestra información en el bloque de datos cada vez que se mueve por el bloque
## de las líneas de órdenes
######################################################################################
Subprog AS_NBLIG
Local Clbfile CRITSQL1(2)(0..4) : Raz CRITSQL1
Local Clbfile CRITSQL3(2)(0..3) : Raz CRITSQL3
Local Clbfile CRITSQL5(2)(0..4) : Raz CRITSQL5

  # comprobar si se han hecho modificaciones 0 = sin modificaciones
  If GFLGCHANGE = 0 Then
    $INICAMBIOREG
    GNOL = nolign-1
    Actzo [M:YPP1]APTOD
    Actzo [M:YPP1]NAPTOD

    # OFS
    If left$([M:YPP2]MFGNUM(GNOL),3) <> "DEV" and left$([M:YPP2]MFGNUM(GNOL),3) <> "EXT" Then
      Case [M:YPP2]MFGTIPO(GNOL)
        When 1 : Gosub MUESTRA_REGISTRO_ORIGINAL
        When 2 : Gosub MUESTRA_REGISTRO_DUPLICADA
      Endcase
    Else
    # DEVoluciones o productos EXTernos
      Gosub MUESTRA_REGISTRO_DEVEXT
    Endif

    Filter [F:YOP0] Where MFGNUM = [M:YPP1]MFGNUM
    Read   [F:YOP0] First
    If !fstat Then
      [M:YPP1]DOCUMENTO = 2
    Else
      [M:YPP1]DOCUMENTO = 1
    Endif
    Filter [F:YOP0]

    Affzo [M:YPP1]5,10,15,20,25
    Raz GFLGCHANGE              # limpia la variable que se utiliza para controlar cambios
  Else
    Local Integer YESNO : YESNO = 1 # no
    Call OUINONT("Se han producido cambios y no has guardado la información.\¿Realmente deseas continuar sin guardar?",YESNO) From GESECRAN
    If YESNO = 2 Then
      # si continúa sin guardar, se vacían los campos modificados del grid
      Raz [M:YPP2]COMENTARIOS(GNOL) : Affzo [M:YPP2]COMENTARIOS(GNOL)
      Raz [M:YPP2]BLISTER(GNOL)     : Affzo [M:YPP2]BLISTER(GNOL)
      Raz [M:YPP2]ETIQUETA(GNOL)    : Affzo [M:YPP2]ETIQUETA(GNOL)
      Raz [M:YPP2]PROSPECTO(GNOL)   : Affzo [M:YPP2]PROSPECTO(GNOL)
      Raz [M:YPP2]ESTUCHE(GNOL)     : Affzo [M:YPP2]ESTUCHE(GNOL)
      Raz [M:YPP2]CHIP(GNOL)        : Affzo [M:YPP2]CHIP(GNOL)
      Gosub INICAMBIOREG
    Endif
  Endif

End

######################################################################################
## Click en icono lupa etiqueta
######################################################################################
Subprog CL_ICOETI(VALEUR)
Variable Char    VALEUR()
Local Integer LINT1

  GPARAM1(0) = "ETIQUETA"                                                        # pase de parámetros entre pantallas
  GPARAM1(1) = [M:YPP1]MFGNUM                                                    # pase de parámetros entre pantallas
  Call SAISIE_LIB(LINT1,GPARAM1,"OYML","SPEYML","OBJZON") From GSAISIE           # llamada a la función que abre la pantalla emregente

End

