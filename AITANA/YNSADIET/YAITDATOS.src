#<AdxTL>@(#)0.0.0.0 $Revision$ 
Call ITMMVT()

End

###############################################
Subprog ITMMVT

If !clalev([X1]) : Local File ITMFACILIT [X1] : Endif
If !clalev([X2]) : Local File ITMMVT     [X2] : Endif

Trbegin [X2]
  For [X1] Where [X1]STOMGTCOD = 2
    Raz [X2]
    [X2]ITMREF  =  [X1]ITMREF
    [X2]STOFCY  =  [X1]STOFCY
    Write [X2]
  Next
Commit

Close Local File [X1],[X2]
End
