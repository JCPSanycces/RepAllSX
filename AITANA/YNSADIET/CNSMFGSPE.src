Funprog GET_COSTEPREVISTO(PNOL)
Value Integer PNOL
Local Decimal LRES
  If !clalev([F:YMFC]) Then : Local File MFGCOST [F:YMFC] : Endif
  Read [F:YMFC]MFC0 = [M:LOF2]MFGFCY(PNOL);[M:LOF2]ITMREF(PNOL);10;[M:LOF2]MFGNUM(PNOL);[M:LOF2]MFGLIN(PNOL);1;0
  If !fstat Then
    LRES = [F:YMFC]OVETOT + [F:YMFC]CSTTOT
  Endif
  Close Local File [YMFC]
End LRES

##############################################################
Funprog GET_COSTEREAL(PNOL)
Value Integer PNOL
Local Decimal LRES
  If !clalev([F:YMFC]) Then : Local File MFGCOST [F:YMFC] : Endif
  Read [F:YMFC]MFC0 = [M:LOF2]MFGFCY(PNOL);[M:LOF2]ITMREF(PNOL);10;[M:LOF2]MFGNUM(PNOL);[M:LOF2]MFGLIN(PNOL);4;0
  If !fstat Then
    LRES = [F:YMFC]OVETOT + [F:YMFC]CSTTOT
  Endif
  Close Local File [YMFC]
End LRES
