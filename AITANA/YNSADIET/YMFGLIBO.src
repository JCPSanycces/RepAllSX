#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "ROULIG"   :   Gosub ROULIG
Endcase
Return


##############################################
$ROULIG
# Muestro la descripción de los CTs de la línea de las operaciones
Local Char MADES
Local Char MODES
Call GET_WSTDES([M:MFG3]EXTWST(LIG),[M:MFG0]MFGFCY,MADES) From SPEROU
Call GET_WSTDES([M:MFG3]EXTLAB(LIG),[M:MFG0]MFGFCY,MODES) From SPEROU
[M:MFG3]YWSTDES(LIG) = MADES
[M:MFG3]YLABDES(LIG) = MODES

Return

