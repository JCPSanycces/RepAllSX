# Código de desarrollo: YN02
# Descripción del desarrollo: Parrilla de elementos de fabricación
# Fecha: 16/08/2019
# Codigo Actividad: YYN02
#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "DEBUT"      : Gosub DEBUT
  When "OK"         : Gosub OK
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$DEBUT
  Gosub BUSCA_ESCANDALLO
Return

##############################################################
$OK
  Case GPARAM2(0)
    When "ETIQUETA"   : Gosub OK_ETIQUETA
    When "PROSPECTO"  : Gosub OK_PROSPECTO
    When "ESTUCHE"    : Gosub OK_ESTUCHE
  Endcase
Return

###############################################################
#######################    ETIQUETAS    #######################
###############################################################
###############################################################
$BUSCA_ESCANDALLO
Local Integer LCON0 : Raz LCON0
Local Char CRITSQL0(255)(0..2) : Raz CRITSQL0

  CRITSQL0(0) = "SELECT MFGMAT.MFGNUM_0, MFGMAT.ITMREF_0, STOLOT.LOT_0, STOLOT.SHLDAT_0 "
  CRITSQL0(1) =  "FROM "+nomap+".MFGMAT LEFT OUTER JOIN "+nomap+".STOLOT ON "+nomap+".MFGMAT.ITMREF_0="+nomap+".STOLOT.ITMREF_0 "
  CRITSQL0(2) =  "WHERE MFGMAT.MFGNUM_0='" + GPARAM2(1) + "'"

  For (Char MFGNUM,Char ITMREF,Char LOT,Date SHLDAT) From "5" Sql CRITSQL0(0..2) As [Y00]
    [M:YLL0]ITMREF(LCON0)    = [F:Y00]ITMREF
    [M:YLL0]PROSPECTO(LCON0) = ""
    [M:YLL0]LOT(LCON0)       = [F:Y00]LOT
    [M:YLL0]INVENTA(LCON0)   = 0
    [M:YLL0]SHLDAT(LCON0)    = [F:Y00]SHLDAT
    [M:YLL0]ESTADO(LCON0)    = ""
    LCON0 += 1
  Next

  [M:YLL0]NBLIG = LCON0

  Sorta [M:YLL0]NBLIG [M:YLL0]NBLIG Order By [M:YLL0]ITMREF(indice), [M:YLL0]LOT(indice)

  Affzo [M:YLL0]5

Return

##############################################################
$OK_ETIQUETA
  [M:YPL1]ETIQUETA = [M:YLL0]ITMREF(nolign-1)
  Affzo [M:YPL1]ETIQUETA
Return

##############################################################
$OK_PROSPECTO
  [M:YPL1]PROSPECTO = [M:YLL0]ITMREF(nolign-1)
  Affzo [M:YPL1]PROSPECTO
Return

##############################################################
$OK_ESTUCHE
  [M:YPL1]ESTUCHE = [M:YLL0]ITMREF(nolign-1)
  Affzo [M:YPL1]ESTUCHE
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

