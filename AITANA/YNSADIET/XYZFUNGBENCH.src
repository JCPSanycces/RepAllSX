#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"    :   Gosub OUVRE
  When "BOUTON"   :   Gosub BOUTON
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
#############################################
$OUVRE
If clalev([F:YIAT]) = 0 : Local File YITMATRIB [YIAT]  : Endif
Return

#############################################
$BOUTON
If BOUT = "Z"
  If [M:MGB]YSIMULACION = ""
    Call ERREUR("Introduzca el códido de la simulación") From GESECRAN
  Else
    Call IMPRIME("Y-SIMULA","FUNGBENCH") From ETAT
  Endif
Endif
Return

