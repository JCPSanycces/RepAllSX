#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog CREA_CAB_ALBARAN()

If !clalev([YRES]) Then : Local File YRESSDH [YRES] : Endif
If !clalev([YSDH]) Then : Local File SDELIVERY [YSDH] : Endif
If !clalev([YSDD]) Then : Local File SDELIVERYD [YSDD] : Endif
If !clalev([YBPA]) Then : Local File BPADDRESS [YBPA] : Endif



Filter [F:YRES] # Where # SDHNUM = '2021/V0120/00001199'
For [YRES]

  Filter [YSDD] Where SDHNUM = [F:YRES]SDHNUM and SDDLIN = 1000
  Read [YSDD] First
  If !fstat Then
    Trbegin [YSDH]
    [F:YSDH]SDHNUM = [F:YSDD]SDHNUM
    [F:YSDH]CPY = [F:YSDD]CPY
    [F:YSDH]SDHCAT = 1  # NORMAL
    [F:YSDH]LND = 1 # PRESTAMO NO
    [F:YSDH]SALFCY = [F:YSDD]STOFCY
    [F:YSDH]STOFCY = [F:YSDD]STOFCY
    [F:YSDH]INVORN = 0
    [F:YSDH]BPCORD = [F:YSDD]BPCORD
    [F:YSDH]BPCINV = [F:YSDD]BPCORD
    [F:YSDH]BPCPYR = [F:YSDD]BPCORD
    [F:YSDH]BPCGRU = [F:YSDD]BPCORD
    [F:YSDH]BPAADD = [F:YSDD]BPAADD
    [F:YSDH]SHIDAT = date$
    [F:YSDH]DLVDAT = date$
    Read [YBPA]BPA0=1;[F:YSDD]BPCORD;[F:YSDD]BPAADD
    If !fstat Then
      [F:YSDH]BPDNAM = [F:YBPA]BPADES
      [F:YSDH]BPDADDLIG = [F:YBPA]BPAADDLIG
      [F:YSDH]BPDPOSCOD = [F:YBPA]POSCOD
      [F:YSDH]BPDCTY = [F:YBPA]CTY
      [F:YSDH]BPDCRY = [F:YBPA]CRY
      [F:YSDH]BPDCRYNAM = [F:YBPA]CRYNAM
      [F:YSDH]BPINAM = [F:YBPA]BPADES
      [F:YSDH]BPIADDLIG = [F:YBPA]BPAADDLIG
      [F:YSDH]BPIPOSCOD = [F:YBPA]POSCOD
      [F:YSDH]BPICTY = [F:YBPA]CTY
      [F:YSDH]BPICRY = [F:YBPA]CRY
      [F:YSDH]BPICRYNAM = [F:YBPA]CRYNAM
    Endif
    [F:YSDH]BPAINV = [F:YSDD]BPAADD
    [F:YSDH]CUR = 'EUR'
    [F:YSDH]CHGTYP = 1
    [F:YSDH]CHGRAT = 1
    [F:YSDH]LAN = 'SPA'
    [F:YSDH]VACBPR = 'VEN'
    [F:YSDH]PTE = 'CON'
    [F:YSDH]DRN = 1
    [F:YSDH]INVPER = 2
    [F:YSDH]DUDCLC = 1
    [F:YSDH]IME = 5
    [F:YSDH]NTRFLG = 1
    [F:YSDH]NPRFLG = 2
    [F:YSDH]NDEFLG = 2
    [F:YSDH]PRNNPR = 1
    [F:YSDH]PRNNDE = 1
    [F:YSDH]COPNBR = 1
    [F:YSDH]CFMFLG = 1
    [F:YSDH]INVFLG = 1
    [F:YSDH]BETFCY = 1
    [F:YSDH]BETCPY = 1
    [F:YSDH]INVDTATYP(0) = 3
    [F:YSDH]INVDTATYP(1) = 3
    [F:YSDH]INVDTATYP(2) = 1
    [F:YSDH]INVDTATYP(3) = 2
    [F:YSDH]INVDTATYP(4) = 2
    [F:YSDH]INVDTA(0) = 1
    [F:YSDH]INVDTA(1) = 7
    [F:YSDH]INVDTA(2) = 8
    [F:YSDH]INVDTA(3) = 9
    [F:YSDH]INVDTA(4) = 10
    [F:YSDH]DLVNOT = [F:YRES]DLVNOT
    [F:YSDH]DLVATI = [F:YRES]DLVATI
    [F:YSDH]DLVNOTL = [F:YRES]DLVNOT
    [F:YSDH]DLVATIL = [F:YRES]DLVATI
    [F:YSDH]DLVINVNOT = [F:YRES]DLVNOT
    [F:YSDH]DLVINVATI = [F:YRES]DLVATI
    [F:YSDH]DLVINVNOTL = [F:YRES]DLVNOT
    [F:YSDH]DLVINVATIL = [F:YRES]DLVATI
    [F:YSDH]DISCRGTYP(0) = 3
    [F:YSDH]DISCRGTYP(1) = 3
    [F:YSDH]DISCRGTYP(2) = 3
    [F:YSDH]DISCRGTYP(3) = 3
    [F:YSDH]DISCRGTYP(4) = 1
    [F:YSDH]DISCRGTYP(5) = 3
    [F:YSDH]DISCRGTYP(5) = 3
    [F:YSDH]DISCRGTYP(6) = 3
    [F:YSDH]INVDTALIN(0) = 0
    [F:YSDH]INVDTALIN(1) = 0
    [F:YSDH]INVDTALIN(2) = 0
    [F:YSDH]INVDTALIN(3) = 0
    [F:YSDH]INVDTALIN(4) = 8
    [F:YSDH]LINNBR = [F:YRES]LINNBR
    [F:YSDH]RTNLINNBR = 0
    [F:YSDH]RTNSTA = 1
    [F:YSDH]PACNBR = 0
    [F:YSDH]PACFLG = 1
    [F:YSDH]EECNAT = 'SP11'
    [F:YSDH]EECSCH = 'SP21'
    [F:YSDH]EECLOC = 1
    [F:YSDH]EECTRN = 1
    [F:YSDH]EECNUMDEB = 0
    [F:YSDH]AMTTAX = 0
    [F:YSDH]BASTAX = 0
    [F:YSDH]ENTCOD = 'STKSD'
    [F:YSDH]DIE(0) = 'PLN'
    [F:YSDH]DIE(1) = 'ZGO'
    [F:YSDH]DIE(2) = 'LIN'
    [F:YSDH]DIE(3) = 'EMP'
    [F:YSDH]DIE(4) = 'MAR'
    [F:YSDH]DIE(5) = 'PRO'
    [F:YSDH]DIE(6) = 'CLI'
    [F:YSDH]DSPTOTQTY  = [F:YRES]LINNBR
    [F:YSDH]DSPTOTQTY = 0
    [F:YSDH]DSPTOTVOL = 0
    [F:YSDH]DSPWEU = 'KG'
    [F:YSDH]WEU = 'KG'
    [F:YSDH]DSPVOU = 'L'
    [F:YSDH]EXPNUM = 0
    [F:YSDH]SCO = 1
    [F:YSDH]SDHTYP = 'TPV'
    [F:YSDH]ADRVAL = 1
    Write [YSDH]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif


Next



End
