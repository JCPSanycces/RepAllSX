#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "DEBUT"      : Gosub DEBUT
  When "BOUTON"     : Gosub BOUTON
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$DEBUT
  Gosub CARGA_BLOQUEOS
Return

##############################################################
$BOUTON
  Case BOUT
    When "t" Then : Gosub DESBLOQUEA
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$CARGA_BLOQUEOS
Local Integer LCON
Local Char    LWHERE(250) : LWHERE = "1=1"

  Raz [M:YGLP]
  [M:YGLP]NBLIG = 0
  Affzo [M:YGLP]

  If [M:YFLP]ITMINI <> "" Then : LWHERE += " AND LCKITM >= [M:YFLP]ITMINI" : Endif
  If [M:YFLP]ITMFIN <> "" Then : LWHERE += " AND LCKITM <= [M:YFLP]ITMFIN" : Endif
  If [M:YFLP]LOTINI <> "" Then : LWHERE += " AND LCKLOT >= [M:YFLP]LOTINI" : Endif
  If [M:YFLP]LOTFIN <> "" Then : LWHERE += " AND LCKLOT >= [M:YFLP]LOTFIN" : Endif

  If !clalev([F:LKP0]) Then : Local File YLCKPRR [F:LKP0] : Endif
  Filter [F:LKP0] Where evalue(LWHERE)
  For [LKP0]
    [M:YGLP]LCKITM(LCON) = [F:LKP0]LCKITM
    [M:YGLP]LCKLOT(LCON) = [F:LKP0]LCKLOT
    [M:YGLP]LCKUSR(LCON) = [F:LKP0]UPDUSR
    [M:YGLP]LCKDAT(LCON) = num$([F:LKP0]LCKDATIM)
    Case [F:LKP0]LCKMSK
      When "PR" : [M:YGLP]LCKMSK(LCON) = "RECEPCIÓN"
      When "PP" : [M:YGLP]LCKMSK(LCON) = "PRODUCCIÓN"
      When "PL" : [M:YGLP]LCKMSK(LCON) = "LIBERACIÓN"
    Endcase
    [M:YGLP]LCKUID(LCON) = [F:LKP0]LCKUID
    LCON += 1
  Next
  Filter [F:LKP0]

  [M:YGLP]NBLIG = LCON
  Sorta [M:YGLP]NBLIG [M:YGLP]NBLIG Order By [M:YGLP]LCKMSK(indice), [M:YGLP]LCKITM(indice), [M:YGLP]LCKLOT(indice)

  Affzo [M:YGLP]
  Close Local File [LKP0]
  If dim(LCON)    > 0 Then : Kill LCON    : Endif
  If dim(LWHERE)  > 0 Then : Kill LWHERE  : Endif
Return

##############################################################
$DESBLOQUEA
Local Integer OKCAN : OKCAN = 1 # cancel
  Call AVERTIR("Se van a desbloquear todos los registros.\¿Realmente deseas continuar?",OKCAN) From GESECRAN
  If OKCAN = 2 Then
    Execsql From "5" Sql "Truncate table" - nomap + ".YLCKPRR"
    Call MESSAGE("Proceso finalizado") From GESECRAN
    Gosub CARGA_BLOQUEOS
  Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Botón 1 - Desbloqueo (pantalla YGESLCKPRR) 15/02/2021 10:09:00 (AIT07)
######################################################################################
Subprog B1_NBLIG
Local Integer LUID      : LUID = [M:YGLP]LCKUID(nolign-1)
Local Char    LITM(100) : LITM = [M:YGLP]LCKITM(nolign-1)
Local Char    LLOT(100) : LLOT = [M:YGLP]LCKLOT(nolign-1)
Local Char    LMSK(15)

  Case [M:YGLP]LCKMSK(nolign-1)
    When "RECEPCIÓN"  : LMSK = "PR"
    When "PRODUCCIÓN" : LMSK = "PP"
    When "LIBERACIÓN" : LMSK = "PL"
  Endcase

  If !clalev([F:LKP1]) Then : Local File YLCKPRR [F:LKP1] : Endif
  Trbegin [F:LKP1]
  Delete [F:LKP1]YLKP0 = LUID;LMSK;LITM;LLOT
  If !fstat Then
    Commit
    Call MESSAGE("Proceso finalizado") From GESECRAN
    Gosub CARGA_BLOQUEOS
  Else
    Rollback
  Endif
  Close Local File [LKP1]
End

######################################################################################
## Después de modificar el campo 'Artículo inicial' (pantalla YFILLCKPRR) 16/02/2021 11:26:28 (AIT07)
######################################################################################
Subprog AM_ITMINI(VALEUR)
Variable Char    VALEUR()
  [M:YFLP]ITMINI = VALEUR
  Affzo [M:YFLP]ITMINI
  Gosub CARGA_BLOQUEOS
End

######################################################################################
## Después de modificar el campo 'Artículo final' (pantalla YFILLCKPRR) 16/02/2021 11:26:28 (AIT07)
######################################################################################
Subprog AM_ITMFIN(VALEUR)
Variable Char    VALEUR()
  [M:YFLP]ITMFIN = VALEUR
  Affzo [M:YFLP]ITMFIN
  Gosub CARGA_BLOQUEOS
End

######################################################################################
