#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "DEB_CRIT"     : Gosub DEB_CRIT
  When "FILTRE"       : Gosub FILTRE
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$DEB_CRIT
  # marca por defecto el flag 'Interno'
  Gosub ACTION From CNSSMVSTD
  [M:CSMV]MISFLG = 2
  Affzo [M:CSMV]MISFLG
  GPE = 1
Return

##############################################################
$FILTRE
# JC 30/06/2020 - YN35 - STR
  If [M:SMV1]YSTRDAT <> [00/00/0000] and [M:SMV1]YENDDAT <> [00/00/0000] Then
    WFILSPE += "&[F:STJ]IPTDAT>=[M:SMV1]YSTRDAT&[F:STJ]IPTDAT<=[M:SMV1]YENDDAT"
  Elsif [M:SMV1]YSTRDAT <> [00/00/0000] and [M:SMV1]YENDDAT = [00/00/0000] Then
    WFILSPE += "&[F:STJ]IPTDAT>=[M:SMV1]YSTRDAT"
  Elsif [M:SMV1]YSTRDAT = [00/00/0000] and [M:SMV1]YENDDAT <> [00/00/0000] Then
    WFILSPE += "&[F:STJ]IPTDAT<=[M:SMV1]YENDDAT"
  Endif
# JC 30/06/2020 - YN35 - END
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################

