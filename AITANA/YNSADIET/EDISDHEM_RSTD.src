#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Representation EDISDHEM                                                     #
# Author : JUCON                                                              #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
Case [L]CURPTH
   When ""
    Case [L]AEVENT
      When "AREAD_AFTER"           : Gosub AREAD_AFTER #test RBA
    Endcase
Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_AFTER_LOAD_REPRESENTATION" : Gosub MET_AFTER_LOAD_REPRESENTATION
  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
  Endcase
Return

####################################################################
$AREAD_AFTER
#  Gosub GETVALPARAMURL From TRTFUNEDI
Return


#********************************************************************
# Method MET_AFTER_LOAD_REPRESENTATION
#********************************************************************
#
#*
#* @param WCATACT
#* @param WCATCOD
#* @param WPARCOD
#* @param WDUPLICATE
#* @param WTEST
#* @param WSEPDEC #114721
#* @param WERR
#* @return [V]CST_AOK/[V]CST_AERROR
#*!
$MET_AFTER_LOAD_REPRESENTATION
  Local Integer I, J
#110811_US9 SITE AUTHORIZATION
  Local Integer WOK, WOKK : WOK     = [V]CST_AOK
  Local Integer WSTATUS    : WSTATUS = [V]CST_AERROR

  WOKK=func EDIRUN_CSTD.CHECK_AUTHORIZATION_SITE(this.ACTX.USER,WCATCOD,this.SDH.SALFCY,WCATACT)

  If WOKK=0
    WSTATUS = [V]CST_AERROR
    WERR=mess(63,133,1) #Site not authorized
  Else
    Case WCATACT
      When 1 :
        Case WPARCOD
          When "EDICOM" : Gosub EDICOM_ISSUE
          When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
        Endcase
      When 2 :
        Case WPARCOD
          When "EDICOM" : Gosub EDICOM_RECEIPT
          When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
        Endcase
    Endcase
  Endif
#/110811_US9
  ARET_VALUE = WSTATUS
Return



################################################################################
$EDICOM_ISSUE
  Local Char WCODE(20), WREP(20), WPROP(25) # 114721
  Local Char LNUMSDH # AITANA.NEW - 25012021
  Local Char LSDHNUMAUX # AIT51.NEW.17022021
  WREP=right$(this.AINF.NAMCLA,3)

  #Formating EDISDHNUM property
  Local Char EDINUM(20)
  EDINUM=space$(20-len(this.SDH.SDHNUM))+this.SDH.SDHNUM
  # this.EDISDHNUM =right$(EDINUM,11)

  this.EDISDHNUM= this.SDH.SDHNUM+space$(10-len(this.SDH.SDHNUM))
  LSDHNUMAUX = this.SDH.SDHNUM # AIT51.NEW.17022021 - PARA USARLA EN LAS BUSQUEDAS STD
  If this.SDH.BPCORD = '004833' Then
      #Infbox right$(this.SDH.SDHNUM,2)+space$(10-len(right$(this.SDH.SDHNUM,2)))
      this.EDISDHNUM = right$(this.SDH.SDHNUM,2)
      LNUMSDH = right$(this.SDH.SDHNUM,2)
      LSDHNUMAUX = this.SDH.SDHNUM # AIT51.NEW.17022021 - PARA USARLA EN LAS BUSQUEDAS STD
      this.SDH.SDHNUM = LNUMSDH   # AIT51.NEW.17022021
  Else
    LNUMSDH = this.SDH.SDHNUM
  Endif

  #Filling EDISDHTYP property
  this.EDISDHTYP="351"

  #Filling EDISDHFUN property
  this.EDISDHFUN="9"

  #Formating EDISHIDAT property
  this.EDISHIDAT=format$("D:YYYYMMDD",this.SDH.SHIDAT)

  #Formating EDIDLVDAT property
  this.EDIDLVDAT=format$("D:YYYYMMDD",this.SDH.DLVDAT)

  #Filling Especial condition property
  If this.SDH.LND=2: this.EDILND="82E": Endif

  #AITANA: Departamento - SOLO SE INDICA EL DPTO PARA ECI
  If this.SDH.BPCORD = '004833' Then
    this.EDIYDPTO=this.SDH.YDPTO
    this.EDIYDPTO= space$(17-len(this.SDH.YDPTO))+this.SDH.YDPTO
  Endif

  #Searching EDIORDNUM property
  Local Char WSOHNUM(20)
  Local Date WSOHDAT
  If this.SDH.SOHNUM<>"": WSOHNUM=this.SDH.SOHNUM: Endif

  If WSOHNUM=""
    For I=1 To maxtab(this.SDH.SDD)
      If this.SDH.SDD(I).SOHNUM<>"": WSOHNUM=this.SDH.SDD(I).SOHNUM: Break: Endif
    Next
  Endif

  If WSOHNUM<>""
    this.EDIORDNUM= func TRTFUNEDI.SDH_ORDNUM(WSOHNUM,1)
    this.EDIORDDAT= func TRTFUNEDI.SDH_ORDNUM(WSOHNUM,2)
  Endif
  If !clalev([YSDH]) Then : Local File SDELIVERY [YSDH] : Endif
   # AITANA.SNEW
  If this.EDIORDNUM = '' Then
    # Read [F:YSDH]SDH0=this.SDH.SDHNUM AIT51.NEW.17022021
    Read [F:YSDH]SDH0=LSDHNUMAUX # AIT51.NEW.17022021
    If !fstat Then
      this.EDIORDNUM = [F:YSDH]YPEDIDO
    Endif
  Endif
  # Close Local File [YSDH]
   # If we don´t have order number, we feed this mandatory field
  If this.EDIORDNUM="": this.EDIORDNUM="ORD1": Endif

  # AITANA.ENES

  #Searching EDIPRHNUM property
  Local Char WPRHNUM(20)

  For I=1 To maxtab(this.SDH.SDD)
    If this.SDH.SDD(I).PRHNUM<>"": WPRHNUM=this.SDH.SDD(I).PRHNUM: Break: Endif
  Next
  this.EDIPRHNUM=WPRHNUM
  this.EDIPRHDAT=func TRTFUNEDI.SDH_PRHDAT(WPRHNUM)


  #Searching EDICPY code

  Local File EDICPYPAR [ECP]

  Read [ECP]ECP0=this.SDH.CPY;WPARCOD
  If fstat=[V]CST_AOK
    this.EDICPY=[F:ECP]EXCEDICOD
  Endif
  LogicClose File [ECP]

  #Searching Seller EDI code (Message Emisor Code) # 110811_US8 : EDI code researsh algo
  Local Char WCODE(20) # 110811_US8
  WCODE=func TRTFUNEDI.INV_EDICODE_SE(this.SDH.SALFCY,this.SDH.CPY,WPARCOD,this.SDH.BPCORD) # 110811_US8
  this.IDSELLER=left$(WCODE,17)# 110811_US8

  # Searching EDICOM code from finantial site (EDIFCYPAY)
  Local Char WFFCY(5)
  Local File FACILITY [FCY]

  Read [FCY]FCY0=this.SDH.SALFCY
  If fstat=[V]CST_AOK
    WFFCY=[F:FCY]FINRSPFCY
  Endif
  If WFFCY<>""
    WCODE=func TRTFUNEDI.INV_EDICODE_FCY(WFFCY,WPARCOD)
    this.EDIFCYPAY=left$(WCODE,17)
  Endif

  LogicClose File [FCY]
  # Searching EDIBPCCOD / IDBUYER property
  Local File EDIBPRPAR [EBP]
  Read [EBP]EBP0=1;this.SDH.BPCORD;this.SDH.BPAADD;WPARCOD
  If fstat=[V]CST_AOK
    this.EDIBPCCOD=[F:EBP]EXCEDICOD
    this.EDIYRECEP = [F:EBP]EXCEDICOD
    this.IDBUYER=[F:EBP]EXCEDICOD # 110811_US8
    If this.SDH.YDPTO = '207' and this.SDH.BPCORD = '004833' Then
        this.IDBUYER = '8422416000504'  # CÓD OPERACIONAL PARA GC DE ECI
    Else
      this.IDBUYER = [F:EBP]EDIORDCOD  # AIT51.NEW
    Endif

  Endif
  Filter [EBP] Where BPANUM=this.SDH.BPTNUM and PARCOD=WPARCOD
  Read First
  If fstat=[V]CST_AOK
    this.EDIBPTCOD=[F:EBP]EXCEDICOD
  Endif
  # AITANA.SNEW - 18122020
  If !clalev([YSDH]) Then : Local File SDELIVERY [YSDH] : Endif
  Read [F:YSDH]SDH0 = LSDHNUMAUX      # JC.09042021
  If [F:YSDH]YDESTINO <> "" Then
    Filter [EBP]
    Read [EBP]EBP0=1;this.SDH.BPCORD;[F:YSDH]YDESTINO;WPARCOD
    If !fstat Then
      # CODIGO EDI COMPRADOR - POS 273
      this.IDBUYER = [F:EBP]EDIINVCOD #  EDIORDCOD # MAB.2812020 - CAMBIO SOLICITADO POR IVAN
      If this.SDH.YDPTO = '207' and this.SDH.BPCORD = '004833' Then
        this.IDBUYER = '8422416000504'  # CÓD OPERACIONAL PARA GC DE ECI
      Endif
      # CODIGO EDI DESTINATARIO FINAL
      # this.EDIBPCCOD = [F:EBP]EXCEDICOD # POSICION 341 # MAB.28122020 - COMENTO SOLICITADO POR IVAN
      this.EDIYRECEP = [F:EBP]EXCEDICOD # POSICION 341
    Endif
  Endif
  # AITANA.ENEW
#  If this.SDH.BPCORD = '004942' Then # EROSKI
#      this.IDBUYER = ''
#  Endif

  #Close Local File [YSDH]
  LogicClose File [EBP]

  # Searching EDICOM code from shipment site (EDISTOFCY)
  WCODE=func TRTFUNEDI.INV_EDICODE_FCY(this.SDH.STOFCY,WPARCOD)
  this.EDISTOFCY=left$(WCODE,17)

  #Searching Open order sequence
  Local Shortint WNB

  If this.EDIORDNUM <> '' Then # AIT51.NEW
    WNB=func TRTFUNEDI.SDH_OPENUM(this.EDIORDNUM,this.SDH.DLVDAT)
    If WNB <> 0 Then  # AITANA.MAB.28122020.NEW
      this.EDIOPENUM=num$(WNB)
    Endif
  Endif # AIT51.NEW
              # AITANA.MAB.28122020.NEW

 #Filling CPYNAME & CPYCRN properties
  Local File COMPANY [CPY]

  Read [CPY]CPY0=this.SDH.CPY
  If fstat=[V]CST_AOK
    this.CPYNAME=[F:CPY]CPYNAM
    this.CPYCRN=[F:CPY]CRN

  Endif
  LogicClose File [CPY]


  #Converting LANDCOST property
  Local File BPCUSTOMER [BPC]
  Read [BPC]BPC0=this.SDH.BPCINV
  If fstat=[V]CST_AOK and [F:BPC]FREINV=2
    this.LANDCOST="PP"
  Else
    this.LANDCOST="CC"
  Endif

  # AIT51.NEW  - Nº prov cliente - Solo para ALCAMPO
  If this.SDH.BPCORD = '001901' Then
    Local File BPCUSTOMER [YBPC0]
    Read [YBPC0]BPC0=this.SDH.BPCINV
    If fstat=[V]CST_AOK Then
        this.EDIYBPCBPSNU = [F:YBPC0]BPCBPSNUM
    Endif
    Close Local File [YBPC0]
  Endif
  # AIT51.NEW  - Nº prov cliente - Solo para ALCAMPO

  # Transcoding EDIMDL property (in STD table 231)
  Local File ASHWPAR [ASWP]
  Filter [ASWP] Where CODREP=WREP and CODLNK="EDIMDL"
  Read First
  If fstat=[V]CST_AOK
    Local Char WNODE(20), WTYP(5)
    Local Integer WTAB
    Local File TABMODELIV [TMD]
    If this.SDH.EECTRN<>0
      Filter [TMD] Where EECTRN=this.SDH.EECTRN and EECLOC=this.SDH.EECLOC and EECICT=this.SDH.EECICT
      Read First
      If fstat=[V]CST_AOK: WTYP= [F:TMD]MDL :Endif
      Filter [TMD]
    Endif
    If WTYP="":  WTYP=this.SDH.MDL: Endif
    WTAB=val([F:ASWP]VALEUR)
    WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
    this.EDIMDL= left$(WNODE,3)

    LogicClose File [TMD]
  Endif

  LogicClose File [ASWP]

  #Calculating EDITOTQTY property
  If toupper(this.SDH.WEU)<>"KG"
    Local File TABCOEFF [TCO]
    Read [TCO]TCO0="KG";this.SDH.WEU
    If fstat=[V]CST_AOK: this.EDITOTQTY=ar2(this.SDH.NETWEI*[F:TCO]COEUOM): Endif
    LogicClose File [TCO]
  Else
    this.EDITOTQTY=this.SDH.NETWEI
  Endif

  #Filling IDENTIF property
  this.IDENTIF="X6"   ## Default value

  #Filling EDIBPCNAME property
  If maxtab(this.SDH.C_BPDNAM)>0
    If this.SDH.C_BPDNAM(1).BPDNAM<>""
      this.EDIBPCNAME=this.SDH.C_BPDNAM(1).BPDNAM
    Endif
  Endif
  If this.EDIBPCNAME=""
    Local File BPDLVCUST [BPD]
    Read [BPD]BPD0=this.SDH.BPCORD;this.SDH.BPAADD
    If fstat=[V]CST_AOK
      this.EDIBPCNAME=[F:BPD]BPDNAM(0)
    Endif
    LogicClose File [BPD]
  Endif

  #Filling EDIBPCCRN and EDIORDNAME properties
  Local File BPARTNER [BPR]
  Read [BPR]BPR0= this.SDH.BPCORD
  If fstat=[V]CST_AOK
    this.EDIBPCCRN=[F:BPR]CRN
    this.EDIORDNAME=[F:BPR]BPRNAM(0)
  Endif
  LogicClose File [BPR]

  #Searching BPTNAME property
  Local File BPCARRIER [BPT]

  Read [BPT]BPT0=this.SDH.BPTNUM
  If fstat=[V]CST_AOK
    this.BPTNAME=[F:BPT]BPTNAM
  Endif

  LogicClose File [BPT]

  #Filling Address properties
  Local File BPADDRESS [BPA]
  #company
  Filter [BPA] Where BPATYP=2 and BPANUM=this.SDH.CPY and BPAADDFLG=2
  Read First
  If fstat=[V]CST_AOK
      this.CPYSAT     =[F:BPA]SAT
      this.CPYCITY    =[F:BPA]CTY
      this.CPYPOSCOD  =[F:BPA]POSCOD
      this.CPYADDLIG  =[F:BPA]BPAADDLIG(0)
  Endif
  Filter [BPA]

  # delivery
  If maxtab(this.SDH.C_BPDADDLIG)>0
    this.EDIBPDSAT    =this.SDH.BPDSAT
    this.EDIBPDCITY   =this.SDH.BPDCTY
    this.EDIBPDPOSCOD =this.SDH.BPDPOSCOD
    this.EDIBPDADDLIG =this.SDH.C_BPDADDLIG(1).BPDADDLIG
  Else
    Read [BPA]BPA0=1;this.SDH.BPCORD;this.SDH.BPAADD
    If fstat=[V]CST_AOK
      this.EDIBPDSAT    =[F:BPA]SAT
      this.EDIBPDCITY   =[F:BPA]CTY
      this.EDIBPDPOSCOD =[F:BPA]POSCOD
      this.EDIBPDADDLIG =[F:BPA]BPAADDLIG(0)
    Endif
  Endif

  #invoice
  If maxtab(this.SDH.C_BPIADDLIG)>0
    this.EDIBPISAT    =this.SDH.BPISAT
    this.EDIBPICITY   =this.SDH.BPICTY
    this.EDIBPIPOSCOD =this.SDH.BPIPOSCOD
    this.EDIBPIADDLIG =this.SDH.C_BPIADDLIG(1).BPIADDLIG
  Else
    Read [BPA]BPA0=1;this.SDH.BPCINV;this.SDH.BPAINV
    If fstat=[V]CST_AOK
      this.EDIBPISAT    =[F:BPA]SAT
      this.EDIBPICITY   =[F:BPA]CTY
      this.EDIBPIPOSCOD =[F:BPA]POSCOD
      this.EDIBPIADDLIG =[F:BPA]BPAADDLIG(0)
    Endif
  Endif
  LogicClose File [BPA]


  # AITANA.NEW.28122020
  If !clalev([YBPR]) Then : Local File BPADDRESS [YBPR] : Endif

  If [F:YSDH]YDESTINO <> "" Then

    Read [YBPR]BPA0=1;this.SDH.BPCORD;[F:YSDH]YDESTINO
    If !fstat Then

      this.EDIBPISAT    = [F:YBPR]SAT
      this.EDIBPICITY   = [F:YBPR]CTY
      this.EDIBPIPOSCOD = [F:YBPR]POSCOD
      this.EDIBPIADDLIG = [F:YBPR]BPAADDLIG(0)
    Endif
  Else
    Read [YBPR]BPA0=1;this.SDH.BPCORD;this.SDH.BPAADD
    If !fstat Then

      this.EDIBPISAT    = [F:YBPR]SAT
      this.EDIBPICITY   = [F:YBPR]CTY
      this.EDIBPIPOSCOD = [F:YBPR]POSCOD
      this.EDIBPIADDLIG = [F:YBPR]BPAADDLIG(0)
    Endif
  Endif


  Close Local File [YBPR]
  Close Local File [YSDH]
  # AITANA.NEW.28122020



  If this.SDH.SHIHOU=""
    this.DATIME=format$("D:DDMMYY",this.SDH.SHIDAT)+"T0000"
  Else
    this.DATIME=format$("D:DDMMYY",this.SDH.SHIDAT)+"T"+this.SDH.SHIHOU
  Endif

# issue 114721 Decimal separator in generated file
  #Formating decimal fields from the properties:
  WPROP=format$("N0:11.3#",this.SDH.DLVINVNOT)
  this.EDIDLVINVNOT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
  WPROP=format$("N0:11.3#",this.SDH.DLVINVATI)
  this.EDIDLVINVATI=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
#      this.EDITOTQTY   =format$("N0:11.3#",this.SDH.NETWEI)
  #/ 114721

  # AIT51. ELIMINAMOS DATOS FISCALES PARA EROSKI. SOLICITADO POR SERES
  # If this.SDH.BPCORD = '004942' or this.SDH.BPCORD = '004944' Then # EROSKI
  If this.SDH.BPCORD = '004942' or
&             this.SDH.BPCORD = '004944' or
&             this.SDH.BPCORD = '004868' or
&             this.SDH.BPCORD = '004379' or
&             this.SDH.BPCORD = '004842' or
&             this.SDH.BPCORD = '004863'
    this.CPYNAME=""  # POSICION 635
    this.CPYCRN     = ""    # POSICION 705
    this.EDIBPCNAME = ""  # POSICION 722
    this.EDIBPCCRN  = "" # POSICION 792
    this.EDIORDNAME = "" # POSICION 809
    this.CPYSAT     = "" # 1310
    this.CPYCITY    = "" # 1275
    this.CPYPOSCOD  = "" # 1345
    this.CPYADDLIG  = "" # 1205
    this.EDIBPISAT    = "" # 1485
    this.EDIBPICITY   = "" # 1450
    this.EDIBPIPOSCOD = "" # 1520
    this.EDIBPIADDLIG = "" # 1380
    this.EDIBPDSAT    = "" # 2080
    this.EDIBPDCITY   = "" # 2045
    this.EDIBPDPOSCOD = "" # 2115
    this.EDIBPDADDLIG = "" # 1975
  Endif


#####################################
#####          EMBALB         #######
#####################################
  this.IDPACK="1"
  this.LEVELPACK="1"



#####################################
#####          LINES          #######
#####################################
  #Filling R_SDD collection
  Local Integer WSEQ
  Local File STOJOU [STJ]

  For I=1 To maxtab(this.SDH.SDD)
    # Filter [STJ] Where STOFCY=this.SDH.SDD(I).STOFCY and VCRTYP=4 and VCRNUM=this.SDH.SDHNUM and VCRLIN=this.SDH.SDD(I).SDDLIN # AIT51.NEW.17022021
    Filter [STJ] Where STOFCY=this.SDH.SDD(I).STOFCY and VCRTYP=4 and VCRNUM=LSDHNUMAUX and VCRLIN=this.SDH.SDD(I).SDDLIN # AIT51.NEW.17022021
    For [STJ]
      WSEQ= fmet this.ADDLINE('R_SDD',[V]CST_ALASTPOS)
      # ITMTYP property (constant in the lines)
      this.R_SDD(WSEQ).ITMTYP="CU"
      this.R_SDD(WSEQ).BLANKLIN=this.BLANK
      #this.R_SDD(WSEQ).SDHNUMLIN=SDHNUMLIN property
      # AITANA
      #this.R_SDD(WSEQ).SDHNUMLIN=vireblc(this.SDH.SDHNUM,2) # right$(EDINUM,11) # AIT51.NEW.17022021
      this.R_SDD(WSEQ).SDHNUMLIN=num$(this.SDH.SDD(I).SDDLIN) # right$(EDINUM,11) # AIT51.NEW.17022021

      # this.R_SDD(WSEQ).EDISDHLIN=WSEQ             # EDISDHLIN property
      this.R_SDD(WSEQ).EDISDHLIN=this.SDH.SDD(I).SDDLIN

      this.R_SDD(WSEQ).DLVDATLIN=this.EDIDLVDAT
      this.R_SDD(WSEQ).BPCCODLIN=this.EDIBPCCOD
      this.R_SDD(WSEQ).FCYPAYLIN=this.EDIFCYPAY

      Local File ITMMASTER [ITM]
      Read [ITM]ITM0=this.SDH.SDD(I).ITMREF
      If fstat= [V]CST_AOK

        this.R_SDD(WSEQ).EANCOD=[F:ITM]EANCOD                           ####R_SDD.EANCOD # MAB.23022021.OLD
        this.R_SDD(WSEQ).REFITMBPC=func TRTFUNEDI.INV_REFCLI(this.SDH.BPCORD, this.SDH.SDD(I).ITMREF) ####R_SDD.REFITMBPC
      Endif
      LogicClose File [ITM]

 # issue 114721 Decimal separator in generated file
      # Filling QTYFREE property
      # WPROP=format$("N0:11.3#",func TRTFUNEDI.SDH_QTYFREE(this.SDH.SDHNUM,this.SDH.SDD(I).SDDLIN)) # AIT51.NEW.17022021
      WPROP=format$("N0:11.3#",func TRTFUNEDI.SDH_QTYFREE(LSDHNUMAUX,this.SDH.SDD(I).SDDLIN)) # AIT51.NEW.17022021
      this.R_SDD(WSEQ).QTYFREE=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

      #Filling SOHDAT property
      this.R_SDD(WSEQ).SOHDAT=func TRTFUNEDI.SDH_SOHDAT(this.SDH.SDD(I).SOHNUM)

      #Filling SOHQTY property
      WPROP=format$("N0:11.3#",func TRTFUNEDI.SDH_SOHQTY(this.SDH.SDD(I).SOHNUM,this.SDH.SDD(I).SOPLIN,this.SDH.SDD(I).SOQSEQ))
      this.R_SDD(WSEQ).SOHQTY=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
#/ 114721

      #Filling SOHSAU property
      this.R_SDD(WSEQ).SOHSAU=func TRTFUNEDI.SDH_SOHSAU(this.SDH.SDD(I).SOHNUM,this.SDH.SDD(I).SOPLIN,this.SDH.SDD(I).SOQSEQ)

      #Filling stock details
      If format$("D:YYYYMMDD",[F:STJ]SHLDAT)<> "29991231"
        this.R_SDD(WSEQ).STOSHLDAT = format$("D:YYYYMMDD",[F:STJ]SHLDAT)
      Else
        this.R_SDD(WSEQ).STOSHLDAT ="00000000"
      Endif
      this.R_SDD(WSEQ).STOQTY = abs([F:STJ]QTYSTU)
      this.R_SDD(WSEQ).STOSAU = [F:STJ]STU
      this.R_SDD(WSEQ).STOLOT = [F:STJ]LOT
      this.R_SDD(WSEQ).STOSER = [F:STJ]SERNUM

      #Calculating LINWEI property
      Local Decimal WLINWEI
      If toupper(this.SDH.SDD(I).WEU)<>"KG"
        Local File TABCOEFF [TCO]
        Read [TCO]TCO0="KG";this.SDH.SDD(I).WEU
        If fstat=[V]CST_AOK:
          WLINWEI=ar2((this.SDH.SDD(I).UNTWEI*[F:TCO]COEUOM)*this.R_SDD(WSEQ).STOQTY)
#          WLINWEI=ar2((this.SDH.SDD(I).UNTWEI*[F:TCO]COEUOM)*this.SDH.SDD(I).QTY)
        Endif
        LogicClose File [TCO]
      Else
        WLINWEI=ar2(this.SDH.SDD(I).UNTWEI*this.R_SDD(WSEQ).STOQTY)
#        WLINWEI=ar2(this.SDH.SDD(I).UNTWEI*this.SDH.SDD(I).QTY)
      Endif

      #Filling GROWEILIN property
      Local Decimal WPACKWEI
      Local Shortint WNBPACK
      Local File TABPACKAGE [TPA]

      If this.SDH.SDD(I).PCKCAP<>0
         WNBPACK=this.R_SDD(WSEQ).STOQTY/this.SDH.SDD(I).PCKCAP
#        WNBPACK=this.SDH.SDD(I).QTY/this.SDH.SDD(I).PCKCAP
      Else
        WNBPACK=1
      Endif

      If this.SDH.SDD(I).PCK<>"" and WNBPACK<>0
        Read [TPA]TPA0=this.SDH.SDD(I).PCK
        If toupper([F:TPA]WEU)="KG"
          WPACKWEI=[F:TPA]PCKWEI*WNBPACK
        Else
          Local File TABCOEFF [TCO]
          Read [TCO]TCO0="KG";[F:TPA]WEU
          If fstat=[V]CST_AOK
            WPACKWEI = ar2(([F:TPA]PCKWEI*[F:TCO]COEUOM)*WNBPACK)
          Endif
          LogicClose File [TCO]
        Endif
      Endif
      this.R_SDD(WSEQ).GROLINWEI=WLINWEI+WPACKWEI

      LogicClose File [TPA]

# issue 114721 Decimal separator in generated file
      #Formating decimal fields from the properties:
      WPROP= format$("N0:11.3#",this.SDH.SDD(I).QTY)
      this.R_SDD(WSEQ).SDDQTY =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      WPROP=format$("N0:11.3#",WLINWEI)
      this.R_SDD(WSEQ).LINWEI =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
#/ 114721



      #############################
      ##  NOTES lines            ##
      #############################
      #Filling text of line
      Local Char WTEXLIN (70)(5)
      Local Integer WOK, L

      # WOK=func TRTFUNEDI.SDH_NUMOBSL(this.SDH.SDHNUM,this.SDH.SDD(I).SDDLIN,WTEXLIN()) # AIT51.NEW.17022021
      WOK=func TRTFUNEDI.SDH_NUMOBSL(LSDHNUMAUX,this.SDH.SDD(I).SDDLIN,WTEXLIN()) # AIT51.NEW.17022021
      If WOK=1
        For L=0 To 4
          If WTEXLIN(L)<>""
            Assign ("this.R_SDD("+num$(WSEQ)+").NOTE"+num$(L+1)) With WTEXLIN(L)
          Endif
        Next
      Endif

    Next  STJ

# COMENTO TODA LA PARTE DE EMBALAJES, Y LA CREAMOS NOSOTROS DESDE NUESTRO SUB
# MAB.17122020.SOLD

#       # AITANA
#      # Numero expediente
#      If !clalev([YPAD]) Then : Local File SPACKD [YPAD] : Endif
#      Read [YPAD]SPD0=4;this.SDH.SDHNUM;this.SDH.SDD(I).SDDLIN
#      If !fstat Then
#        this.R_SDD(WSEQ).EDIYNUMEXP = [F:YPAD]PACNUM
#        # Tipo embalaje
#        # Transcoding NODE property (in STD table 232)
#        Local Char LNODE
#        LNODE = func TRTFUNEDI.TRANSCODE([F:YPAD]PCK ,232,1)
#        If LNODE <> '' Then
#          this.R_SDD(WSEQ).EDIYTIPEMB = LNODE
#        Else
#          this.R_SDD(WSEQ).EDIYTIPEMB = [F:YPAD]PCK
#        Endif
#        Local Char LPACNUM(40)
#        LPACNUM = [F:YPAD]PACNUM
#        Filter [F:YPAD] Where PACNUM = LPACNUM
#        # Paquetes dentro de la unidad - SUMA DE REGISTROS CON EL MISMO PACNUM
#        this.R_SDD(WSEQ).EDIYCANTEMB = rowcount([F:YPAD])
#        # Unidad Expedición
#        If !clalev([YPAH]) Then : Local File SPACK [YPAH] : Endif
#        Read [YPAH]SPH0=4;this.SDH.SDHNUM;LPACNUM
#
#        If !fstat Then
#          this.R_SDD(WSEQ).EDIYSSCC1 = [F:YPAH]SCCCOD
#        Endif
#        Close Local File [YPAH]
#
#        Endif
#        Close Local File [YPAD]

# MAB.17122020.EOLD

      # AITANA
      # Paquetes dentro de la unidad
      # this.R_SDD(WSEQ).EDIYCANTEMB = I
      # Nivel jerarquico
      # this.EDIYCPSPADRE = "AAA" # ESTE ES EL CAMPO LEVELPACK
      # AITANA

      # AITANA

  Next
  LogicClose File [STJ]
  WSTATUS = [V]CST_AOK

  # AITANA.SNEW

  Gosub GEN_FILE_EMBA

  # AITANA.ENEW
Return

################################################################################
$EDICOM_RECEIPT
Return


################################################################################

# AITANA.SNEW
 $GEN_FILE_EMBA

    # AITANA
    # Unidad Expedición
    Gosub OPEN_FILE_W

    #WSEQ= fmet this.ADDLINE('R_SDD',[V]CST_ALASTPOS)
    If !clalev([YPAH]) Then : Local File SPACK [YPAH] : Endif
    If !clalev([YPAD]) Then : Local File SPACKD [YPAD] : Endif
    If !clalev([YSDD]) Then : Local File SDELIVERYD [YSDD] : Endif

    If !clalev([YVPD]) Then : Local File YVSAPCKD [YVPD] : Endif

    #If !clalev([YPAD2]) Then : Local File SPACKD [YPAD2] : Endif
    Local Integer Z : Z = 1
    Local Decimal LCANTIDAD : LCANTIDAD = 0

    #For [YPAH] Where VCRNUM = this.SDH.SDHNUM # this.SDH.SDHNUM # AIT51.NEW.17022021
    For [YPAH] Where VCRNUM = LSDHNUMAUX # this.SDH.SDHNUM # AIT51.NEW.17022021
      # this.R_SDD(I).EDIYSSCC1 = [F:YPAH]SCCCOD

      # GENERAR 2 LÍNEAs PARA EL PALET INICIAL
      If Z = 1 Then



      Wrseq LNUMSDH + space$(10-len(LNUMSDH)) +
&        num$(Z)+space$(10-len(num$(Z)))    +
&        num$(format$("KV0:12X",num$(Z)))+space$(12-len(format$("KV0:12X",num$(Z))))  +
&        format$("KV0:12X",' ') +
&        num$(1)+space$(18-len(num$(1))) +
&        format$("KV0:3X",'') +
&        format$("KV0:3X","201") +
&        format$("KV0:220X",'') +
&        format$("KV0:19X",'') +
&        format$("KV0:35X",'') +
&        format$("KV0:1X",'')  Using [ZEMB_W]

      If (this.SDH.YDPTO <> '207' and this.SDH.BPCORD <> '004833') or (this.SDH.YDPTO <> '207' and this.SDH.BPCORD = '004833') Then
        Wrseq LNUMSDH + space$(10-len(LNUMSDH)) +
&        num$(Z+1)+space$(10-len(num$(Z+1)))    +
&        num$(format$("KV0:12X",num$(Z+1)))+space$(12-len(format$("KV0:12X",num$(Z+1))))  +
&        format$("KV0:12X",'1') +
&        num$(1)+space$(18-len(num$(1))) +
&        format$("KV0:3X",'') +
&        format$("KV0:3X","BE") +
&        format$("KV0:220X",'') +
&        format$("KV0:19X",'') +
&        format$("KV0:35X",'') +
&        format$("KV0:170X",'') +
&        format$("KV0:3X","CT") +
&        format$("KV0:14X",num$(rowcount([F:YPAH])))   Using [ZEMB_W]
         Z = 2
       Endif

      Endif

      Local Char LNODE
      LNODE = func TRTFUNEDI.TRANSCODE([F:YPAH]PCK,232,1)
      Local Char LPACNUM(40)
      Local Integer LNUNLIN
      Local Char LEANCOD(35), LEANCOD2(35)
      Local Char LDESC(50)
      Local Char LFECHACAD, LDUN14(35) # MAB.25012021.NEW
      Local Char LUNIXCAJA
      Local Float LYLOGUDCAJ
      Local Float LTOTALUDCAJ
      Local Char LQTY2(20)
      LPACNUM = [F:YPAH]SCCCOD
      LTOTALUDCAJ  = 0
      # Filter [F:YVPD] Where VCRNUM = this.SDH.SDHNUM and PACNUM = [F:YPAH]PACNUM # AIT51.NEW.17022021
      Filter [F:YVPD] Where VCRNUM = LSDHNUMAUX and PACNUM = [F:YPAH]PACNUM # AIT51.NEW.17022021
      LCANTIDAD = 0

      # POR CADA LÍNEA DE EMBALAJE HAY QUE GENERAR UNA LÍNEA EN EL FICHERO LINALB.TXT
      For [YVPD]
        LCANTIDAD = [F:YVPD]QTY
        LNUMLIN = [F:YVPD]VCRLIN
        # Read [F:YSDD]SDD0=this.SDH.SDHNUM;LNUMLIN # AIT51.NEW.17022021
        Read [F:YSDD]SDD0=LSDHNUMAUX;LNUMLIN # AIT51.NEW.17022021
        If !fstat Then
          LDUN14 = ''
          Local File ITMMASTER [ITM]
          Read [ITM]ITM0=[F:YSDD]ITMREF
          If fstat= [V]CST_AOK
            LEANCOD=[F:ITM]EANCOD
            LEANCOD2=[F:ITM]EANCOD                         ####R_SDD.EANCOD
            If LNODE = '201' Then # PALET                   # MAB.25012021.NEW
              LDUN14 = [F:ITM]YDUN14PALE                    # MAB.25012021.NEW
            Else                                            # MAB.25012021.NEW
              LDUN14 = [F:ITM]YDUN14                        # MAB.25012021.NEW
            Endif                                           # MAB.25012021.NEW
             LUNIXCAJA = num$([F:ITM]YUDCAJA)               # MAB.25012021.NEW
             If [F:ITM]YLOGUDCAJ <> 0 Then
              LYLOGUDCAJ = [F:ITM]YLOGUDCAJ
             Else
              LYLOGUDCAJ = 1
             Endif
          Endif
          LogicClose File [ITM]
          LDESC = [F:YSDD]ITMDES

          # AIT51.NEW.09032021
          If !clalev([YITC]) Then : Local File ITMBPC [YITC] : Endif
          Read [YITC]ITU0=[F:YSDD]ITMREF;this.SDH.BPCORD
          If !fstat Then
              LYLOGUDCAJ = [F:YITC]PCUSAUCOE1
              LUNIXCAJA  = num$([F:YITC]PCUSAUCOE1)
          Endif
          Close Local File [YITC]
          # AIT51.NEW.09032021

          LTOTALUDCAJ  = LTOTALUDCAJ + ar2(LCANTIDAD / LYLOGUDCAJ)         # unidades por caja para cada PACNUM
          Local Char LSAU, LSTOLOT, LSTOQTY, LQTY
          LSAU = [F:YSDD]SAU
          LQTY = num$(format$("N0:11.3#",LCANTIDAD))

          Filter [STJ] Where STOFCY= [F:YSDD]STOFCY and VCRTYP=4 and VCRNUM=  [F:YSDD]SDHNUM and VCRLIN=[F:YSDD]SDDLIN
          For [STJ]
            LSTOQTY = num$(format$("N0:11.3#",abs([F:STJ]QTYSTU)))
            #this.R_SDD(WSEQ).STOSAU = [F:STJ]STU
            LSTOLOT = [F:STJ]LOT
            LFECHACAD = format$("D:YYYYMMDD",[F:STJ]SHLDAT)   # MAB.25012021.NEW
            #this.R_SDD(WSEQ).STOSER = [F:STJ]SERNUM

          Next
          Filter [STJ]

        Endif

        Local Char LLINWEI , LLUMLIN2
        LLINWEI = num$(format$("N0:11.3#",0))
        LNUMLIN2 = num$(LNUMLIN)
        Local Char LEDIBPCCOD, LEDIFCYPAY, LQTYLOT, LQTYUNIXCAJA
        Local Char LEDIDLVDAT
        Local Char LAUX, LAUX2 # para espacios en blanco
        LAUX = '0'
        LAUX2 = '0.000'
        LQTY2 = LQTY # IGUALAMOS VARIABLE PARA PODER BORRARLA SOLO PARA EL CORTE INGLES
  #      If this.SDH.BPCORD = '004942' or this.SDH.BPCORD = '004944' or this.SDH.BPCORD = '004868' Then # EROSKI
        If this.SDH.BPCORD = '004942' or
&             this.SDH.BPCORD = '004944' or
&             this.SDH.BPCORD = '004868' or
&             this.SDH.BPCORD = '004379' or
&             this.SDH.BPCORD = '004842' or
&             this.SDH.BPCORD = '004863'
          LEDIBPCCOD = format$("KV0:17X",'') # POSICION 1013 - QUITAMOS PARA EROSKI
          LEDIFCYPAY = format$("KV0:35X",'')
          LQTYLOT = format$("KV0:15X",'')    # POSICIÓN 998   - QUITAMOS PARA EROSKI
          LQTYUNIXCAJA = ctrans(format$("N0:11.3#",LUNIXCAJA),',','.') #  format$("KV0:15X",ctrans(LUNIXCAJA,',','.')) # POSICION 326
          LEDIDLVDAT = format$("KV0:12X",'') # POSICIÓN 1030 - QUITAMOS PARA EROSKI
        Elsif this.SDH.BPCORD = '004833'  Then # ECI
          LEANCOD2 = '' # POSICIÓN 2189 QUITAR - PIA+1:ACU
          LEDIBPCCOD = format$("KV0:17X",'') # POSICION 1013 - QUITAMOS PARA ECI
          LQTYLOT = format$("KV0:15X",'')    # POSICIÓN 998   - QUITAMOS PARA ECI
          LQTY2 = '' # POSICIÓN 1042 - QUITAR - QTY+11
          LQTYUNIXCAJA = ctrans(format$("N0:11.3#",LUNIXCAJA),',','.') # POSICION 326  - AÑADIR QTY-59
        Elsif this.SDH.BPCORD = '001901' Then # ALCAMPO
          LQTYUNIXCAJA = ctrans(format$("N0:11.3#",LUNIXCAJA),',','.') # POSICION 326  - AÑADIR QTY-59
          LNUMLIN2 = ''
#          LFECHACAD = ''   # JC.11052021
          LEDIFCYPAY = format$("KV0:35X",'')
          LEANCOD2 = ''
          LAUX = ''
          LAUX2 = ''
          # JC.11052021.STR
          LQTYLOT = format$("KV0:15X",'')
          LEDIBPCCOD = format$("KV0:17X",'')
          LEDIDLVDAT = format$("KV0:12X",'')
          # JC.11052021.END
        Else
          LEDIBPCCOD = format$("KV0:17X",this.EDIBPCCOD)  # POSICIÓN 1013 - LOC+7
          LEDIFCYPAY = format$("KV0:35X",this.EDIFCYPAY)
          LQTYLOT = format$("KV0:15X",ctrans(LQTY,',','.'))
          LQTYUNIXCAJA = format$("KV0:15X",'')
          LEDIDLVDAT = format$("KV0:12X",this.EDIDLVDAT)
        Endif

# &        space$(6-len(num$(LNUMLIN)))+format$("KV0:6X",num$(LNUMLIN)) +
        Wrseq LNUMSDH + space$(10-len(LNUMSDH)) +
&        num$(Z+1)+space$(10-len(num$(Z+1)))    +
&        space$(10-len(num$(LNUMLIN)))+num$(LNUMLIN)  +
&        format$("KV0:35X",LEANCOD)+space$(35-len(LEANCOD)) +
&        format$("KV0:85X",'') +
&        LDUN14  +  space$(35-len(LDUN14)) +
&        format$("KV0:70X",LDESC) +
&        format$("KV0:3X",'CU') +
&        format$("KV0:15X",ctrans(LQTY,',','.')) +
&        format$("KV0:30X",'') +
&        LQTYUNIXCAJA +
&        format$("KV0:3X",LSAU) +
&        format$("KV0:254X",'') +
&        format$("KV0:254X",'') +
&        format$("KV0:111X",'') +
&        format$("KV0:35X",ctrans(LSTOLOT,',','.')) +
&        LQTYLOT +
&        LEDIBPCCOD +
&        LEDIDLVDAT +
&        format$("KV0:15X",ctrans(LQTY2,',','.')) +
&        format$("KV0:117X",'') +
&        format$("KV0:12X",this.EDIDLVDAT) +
&        format$("KV0:6X",'') +
&        format$("KV0:6X",num$(LNUMLIN2)) +
&        format$("KV0:113X",'') +
&        LFECHACAD +
&        format$("KV0:133X",'') +
&        format$("KV0:254X",'') +
&        format$("KV0:254X",'') +
&        format$("KV0:161",'') +
&        LEDIFCYPAY +
&        format$("KV0:33X",'') +
&        format$("KV0:5X",'') +
&        format$("KV0:35X",LEANCOD2)+
&        format$("KV0:15",LAUX) +
&        format$("KV0:81",'') +
&        format$("KV0:15X",LAUX2)
&           Using [ZLIN_W]


       Next

      If this.SDH.YDPTO = '207' and this.SDH.BPCORD = '004833' Then # ECI GC
          LNODE = 'CT'
      Endif
      Local Char LJERARQUIA
      If this.SDH.YDPTO = '207' and this.SDH.BPCORD = '004833' Then
        LJERARQUIA = '1'
      Else
        LJERARQUIA = '2'
      Endif

      If this.SDH.BPCORD <> '004833' Then
        LFECHACAD = ''
      Endif



      Wrseq LNUMSDH + space$(10-len(LNUMSDH)) +
&        num$(Z+1)+space$(10-len(num$(Z+1)))    +
&        num$(format$("KV0:12X",num$(Z+1)))+space$(12-len(format$("KV0:12X",num$(Z+1))))  +
&        format$("KV0:12X",LJERARQUIA) +
&        ctrans(format$("N0:11.3#",num$(arr(LTOTALUDCAJ,1))),',','.') +
&        format$("KV0:6X",'') +
&        format$("KV0:3X",LNODE) +
&        format$("KV0:220X",'') +
&        format$("KV0:19X",'') +
&        format$("KV0:35X",LPACNUM) +
&        format$("KV0:1X",'') +
&        format$("KV0:206X",'') +
&        LFECHACAD    Using [ZEMB_W]



      LTOTALUDCAJ = 0
      Z += 1
    Next

    # ################################################################################################
    # SI NO TENEMOS EMBALAJES, HAY QUE GENERAR SOLO EL FICHERO DE LÍNEAS, 1 LÍNEA POR LÍNEA DE ALBARAN
    If Z = 1 Then
       Gosub GEN_LINALB_SINEMB
       Infbox "No se ha realizado el empaquetado del albarán."
    Endif
    # ################################################################################################
    Close Local File [YPAD]
    Close Local File [YPAH]

    Gosub $CLOSE_FILE_W

Return
########################################################
$GEN_LINALB_SINEMB

        Local Char LSOHNUM(35)
        Local Char LSOHDAT(12)
        Local Decimal LUNTWEI
        Local Char LWEU, LFECHACAD, LNUMLIN2
        If !clalev([YSD0]) Then : Local File SDELIVERYD [YSD0] : Endif
        # For [F:YSD0] Where SDHNUM = this.SDH.SDHNUM # AIT51.NEW.17022021
        For [F:YSD0] Where SDHNUM = LSDHNUMAUX # AIT51.NEW.17022021
            Local Char LSAU, LSTOLOT, LSTOQTY, LQTY
            LSAU = [F:YSD0]SAU
            LQTY = num$(format$("N0:11.3#",[F:YSD0]QTY))
            Filter [STJ] Where STOFCY= [F:YSD0]STOFCY and VCRTYP=4 and VCRNUM=  [F:YSD0]SDHNUM and VCRLIN=[F:YSD0]SDDLIN
            For [STJ]
              LSTOQTY = num$(format$("N0:11.3#",abs([F:STJ]QTYSTU)))
              #this.R_SDD(WSEQ).STOSAU = [F:STJ]STU
              LSTOLOT = [F:STJ]LOT
              LFECHACAD = format$("D:YYYYMMDD",[F:STJ]SHLDAT) # MAB.25012021.NEW
              #this.R_SDD(WSEQ).STOSER = [F:STJ]SERNUM

            Next
            Filter [STJ]


            LSOHNUM = [F:YSD0]SOHNUM
            LSOHDAT =func TRTFUNEDI.SDH_SOHDAT([F:YSD0]SOHNUM)
            LUNTWEI = [F:YSD0]UNTWEI
            LWEU = [F:YSD0]WEU
            If [F:YSD0]PCKCAP<>0
               WNBPACK= LSTOQTY/[F:YSD0]PCKCAP
      #        WNBPACK=this.SDH.SDD(I).QTY/this.SDH.SDD(I).PCKCAP
            Else
              WNBPACK=1
            Endif

#            Local Decimal LGROLINWEI
#            Local File TABPACKAGE [TPA]
#            If [F:YSD0]PCK<>"" and WNBPACK<>0
#              Read [TPA]TPA0=[F:YSD0]PCK.PCK
#              If toupper([F:TPA]WEU)="KG"
#                WPACKWEI=[F:TPA]PCKWEI*WNBPACK
#              Else
#                Local File TABCOEFF [TCO]
#                Read [TCO]TCO0="KG";[F:TPA]WEU
#                If fstat=[V]CST_AOK
#                  WPACKWEI = ar2(([F:TPA]PCKWEI*[F:TCO]COEUOM)*WNBPACK)
#                Endif
#                LogicClose File [TCO]
#              Endif
#            Endif
#            LGROLINWEI=WLINWEI+WPACKWEI
#
#            LogicClose File [TPA]
#
#
#
#          Local Char LLINWEI
#          LLINWEI = num$(format$("N0:11.3#",0))

          # AITANA.SNEW  POSICION 326
          Local File ITMMASTER [ITM]
          Local Char EDIYUNIXCAJA
          Local Char LUNIXCAJA
          Read [ITM]ITM0=[F:YSD0]ITMREF
          If fstat= [V]CST_AOK
              #WPROP = format$("N0:11.3#",[F:ITM]YUNIXCAJA)
              LEANCOD=[F:ITM]EANCOD
              LUNIXCAJA = num$([F:ITM]YUDCAJA)
              WPROP = format$("N0:11.3#",[F:ITM]YUDCAJA)
          Endif
          LogicClose File [ITM]
          EDIYUNIXCAJA =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
          # AITANA.ENEW
          LDESC = [F:YSD0]ITMDES


          Local Char LEDIBPCCOD, LEDIFCYPAY, LQTYLOT, LQTYUNIXCAJA
          Local Char LEDIDLVDAT
          If this.SDH.BPCORD = '004942' or
&             this.SDH.BPCORD = '004944' or
&             this.SDH.BPCORD = '004868' or
&             this.SDH.BPCORD = '004379' or
&             this.SDH.BPCORD = '004842' or
&             this.SDH.BPCORD = '004863' Then # EROSKI
            LEDIBPCCOD = format$("KV0:17X",'') # POSICION 1013 - QUITAMOS PARA EROSKI
            LEDIFCYPAY = format$("KV0:35X",'')
            LQTYLOT = format$("KV0:15X",'')
            LQTYUNIXCAJA = ctrans(format$("N0:11.3#",LUNIXCAJA),',','.')
            LEDIDLVDAT = format$("KV0:12X",'')
          Else
            LEDIBPCCOD = format$("KV0:17X",this.EDIBPCCOD)
            LEDIFCYPAY = format$("KV0:35X",this.EDIFCYPAY)
            LQTYLOT = format$("KV0:15X",ctrans(LQTY,',','.'))
            LQTYUNIXCAJA = format$("KV0:15X",'')
            LEDIDLVDAT = format$("KV0:12X",this.EDIDLVDAT)
          Endif


      Wrseq LNUMSDH + space$(10-len(LNUMSDH)) +
&        num$(Z+1)+space$(10-len(num$(Z+1)))    +
&        space$(10-len(num$([F:YSD0]SDDLIN)))+num$([F:YSD0]SDDLIN)  +
&        format$("KV0:35X",LEANCOD)+space$(35-len(LEANCOD)) +
&        format$("KV0:120X",'') +
&        format$("KV0:70X",LDESC) +
&        format$("KV0:3X",'CU') +
&        format$("KV0:15X",ctrans(LQTY,',','.')) +
&        format$("KV0:30X",'') +
&        LQTYUNIXCAJA +
&        format$("KV0:3X",LSAU) +
&        format$("KV0:254X",'') +
&        format$("KV0:254X",'') +
&        format$("KV0:111X",'') +
&        format$("KV0:35X",ctrans(LSTOLOT,',','.')) +
&        LQTYLOT +
&        LEDIBPCCOD +
&        format$("KV0:12X",this.EDIDLVDAT) +
&        format$("KV0:15X",ctrans(LQTY,',','.')) +
&        format$("KV0:117X",'') +
&        LEDIDLVDAT +
&        format$("KV0:6X",'') +
&        format$("KV0:6X",num$([F:YSD0]SDDLIN)) +
&        format$("KV0:113X",'') +
&        LFECHACAD +
&        format$("KV0:133X",'') +
&        format$("KV0:254X",'') +
&        format$("KV0:254X",'') +
&        format$("KV0:161",'') +
&        LEDIFCYPAY +
&        format$("KV0:33X",'') +
&        format$("KV0:5X",'') +
&        format$("KV0:35X",LEANCOD)+
&        format$("KV0:15",'0') +
&        format$("KV0:81",'') +
&        format$("KV0:15X",'0.000')
&          Using [ZLIN_W]


         Z += 1

       Next

Return
########################################################
$OPEN_FILE_W
  Local Char LDIRMPORT(250) : LDIRIMPORT = filpath("","","",[S]nomap(0),"") + "\EDI\ISSUEEDICOM"
  Local Char LDIRARCHIVE(250)
  Local Char LFILE_W(200)
  Local Integer LFOUND, LSTAT

  If clalev([EIS0]) Then
      If [M:EIS0]TESTFLG = 2 Then
         LDIRIMPORT = filpath("","","",[S]nomap(0),"") + "\EDI\ISSUETEST"
      # Else
          # SI NO ESTAMOS EN TEST COPIARÁ EL FICHERO TAMBIEN EN ARCHIVE, YA QUE LO HACE EL ESTANDAR Y
          # AL GENERAR NOSOTROS LOS FICHEROS NO LO HACE
         LDIRARCHIVE = filpath("","","",[S]nomap(0),"") + "\EDI\ARCHIVE"
      Endif
  Endif

  adxifs = " "
  adxirs = chr$(13)+chr$(10)
  # CONTROLAR SI EL FICHERO EXISTE PARA BORRARLO
  #LFOUND=filexist("", "", LDIRIMPORT + '\EMBALB.txt')

  #If LFOUND=1 Then
  Call SYSTEME (adxmac(1), "ae_rm "+LDIRIMPORT + '\EMBALB.txt'," ", LSTAT) From ORDSYS
  Call SYSTEME (adxmac(1), "ae_rm "+LDIRIMPORT + '\LINALB.txt'," ", LSTAT) From ORDSYS
  #Endif
  Openo LDIRIMPORT + '\EMBALB.txt'  Using [ZEMB_W]
  Openo LDIRIMPORT + '\LINALB.txt'  Using [ZLIN_W]
  #Openo  'E:\SAGE\SAGEEMPONS\FOLDERS\PONS\EDI\ISSUETEST\EMBALB2.txt' Using [ZIMP_W]
Return
########################################################
$CLOSE_FILE_W
  Openo Using [ZEMB_W]
  Openo Using [ZLIN_W]

Return


