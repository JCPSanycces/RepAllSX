#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
  When "SETBOUT"    :   Gosub SETBOUT
Endcase
Return

##############################################
$SETBOUT
# Pongo por defecto la etiqueta asociada al cliente-entrega
If [M:PKE1]LBLNAM  = ""
  Local Char TBPAR(15)(1..50),TBVAL(30)(1..50)
  Read [BPD]BPD0 = [M:PKP1]BPCORD;[M:PKP1]BPAADD
  If fstat = 0
    [M:PKE1]LBLNAM = [BPD]YETIQUETA
    Affzo [M:PKE1]LBLNAM

    # Recherche de l'imprimante par défaut
    Call AIMDEF([M]LBLDEN,[M:PKE1]LBLNAM,TBPAR,TBVAL) From IMPRIME

    For I=0 To [M]NBLIG-1
        [M:PKE1]LBLFMT(I) = [M:PKE1]LBLNAM
        [M:PKE1]DEFDEN(I) = [M]LBLDEN
    Next
    Affzo [M:PKE1]10

  Endif
Endif
Return
