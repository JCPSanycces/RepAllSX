###############################################################################
# Classe EDISTRISS                                                            #
# Author : RBA                                                                #
###############################################################################

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When "EMSG"
      Case [L]AEVENT
        When "ADDLINE_AFTER"          : Gosub EMSG_ADDLINE_AFTER
      Endcase
    When "EINS"
      Case [L]AEVENT
        When "ADDLINE_AFTER"          : Gosub EINS_ADDLINE_AFTER
      Endcase
    When "EMUX"
      Case [L]AEVENT
        When "ADDLINE_AFTER"          : Gosub EMUX_ADDLINE_AFTER
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
  Case [L]AMETHOD
    When "MET_ISSUE_INIT"             : Gosub MET_ISSUE_INIT
    When "MET_ISSUE_CREATE_QUERY"     : Gosub MET_ISSUE_CREATE_QUERY
    When "MET_ISSUE_CONTROLS"         : Gosub MET_ISSUE_CONTROLS
    When "MET_ISSUE_STACK_CREATE"     : Gosub MET_ISSUE_STACK_CREATE
    When "MET_ISSUE_PROCESS"          : Gosub MET_ISSUE_PROCESS
    When "MET_ISSUE_PROCESS_BY_FLOW"  : Gosub MET_ISSUE_PROCESS_BY_FLOW
    When "MET_ISSUE_GENERATE_DOC"     : Gosub MET_ISSUE_GENERATE_DOC
    When "MET_ISSUE_LOG_RESUME"       : Gosub MET_ISSUE_LOG_RESUME
    When "MET_ISSUE_GET_FILENAMES"    : Gosub MET_ISSUE_GET_FILENAMES
    When "MET_ISSUE_GENERATE_FILES"   : Gosub MET_ISSUE_GENERATE_FILES
  Endcase
Return

#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#  Case [L]AOPERATION
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "FLOCOD" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub FLOCOD_PROPAGATE
      Endcase
    When "FLOREL" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub FLOREL_PROPAGATE
      Endcase
    When "PTCCOD" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub PTCCOD_PROPAGATE
      Endcase
    When "EMSG.MSGCOD" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub EMSG_MSGCOD_PROPAGATE
      Endcase
    When "EMSG.MSGREL" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub EMSG_MSGREL_PROPAGATE
      Endcase
    When "EMSG.MSGFILNOR" :
      Case [L]ARULE
        When "PROPAGATE" : Gosub EMSG_MSGFILNOR_PROPAGATE
      Endcase
  Endcase
Return


###################################################################
$FLOCOD_PROPAGATE
  If this.FLOCOD <> "" and this.FLOREL <> ""
    Gosub GET_FLOW_PROPERTIES
  Endif
Return

###################################################################
$FLOREL_PROPAGATE
  If this.FLOCOD <> "" and this.FLOREL <> ""
    Gosub GET_FLOW_PROPERTIES
  Endif
Return

###################################################################
$PTCCOD_PROPAGATE
  If this.PTCCOD <> ""
    Local File EDIPTC [EPT]
    Read [F:EPT]EPT0 = this.PTCCOD
    If !fstat
      this.PTC_UUID = [EPT]CACHEUUID
    Else
      this.PTC_UUID = NullUuid()
    Endif
    LogicClose File [EPT]
  Endif
Return

###################################################################
$EMSG_MSGCOD_PROPAGATE
  If this.MSGCOD <> "" and this.MSGREL <> "" and this.MSGFILNOR <> ""
    Gosub GET_MSG_PROPERTIES
  Endif
Return

###################################################################
$EMSG_MSGREL_PROPAGATE
  If this.MSGCOD <> "" and this.MSGREL <> "" and this.MSGFILNOR <> ""
    Gosub GET_MSG_PROPERTIES
  Endif
Return

###################################################################
$EMSG_MSGFILNOR_PROPAGATE
  If this.MSGCOD <> "" and this.MSGREL <> "" and this.MSGFILNOR <> ""
    Gosub GET_MSG_PROPERTIES
  Endif
Return

###################################################################
$GET_FLOW_PROPERTIES
#flow properties

  Local File EDIFLO [EFL]
  Read [F:EFL]EFL0 = this.FLOCOD;this.FLOREL
  If !fstat
    this.FLO_UUID = [EFL]CACHEUUID
    this.PTCCOD   = [EFL]PTCCOD
  Else
    this.FLO_UUID = NullUuid()
    this.PTCCOD   = ""
  Endif
  LogicClose File [EFL]

  Call DELETELINES(this, "EMSG") From EDILIBA
  Local Integer WPOS
  Local File EDIFLOD [EFLD]
  Filter [EFLD] Where FLOCOD =  this.FLOCOD and FLOREL = this.FLOREL and MSGTYP=1 ## Query type
  Read [EFLD]EFLD0 First   ### only one line
#  For [EFLD]
  If fstat=[V]CST_AOK and maxtab(this.EMSG)=0   #JCC
    WPOS = fmet this.ADDLINE("EMSG", [V]CST_ALASTPOS)
    this.EMSG(WPOS).MSGCOD    = [EFLD]MSGCOD
    this.EMSG(WPOS).MSGREL    = [EFLD]MSGREL
    this.EMSG(WPOS).MSGFILNOR = [EFLD]MSGFILNOR
    ## INI 112148
    this.EMSG(WPOS).MSGFOR    = [EFLD]MSGFOR

    ## X3-41976 XML signature (JUCON 17/02/2017)
    this.EMSG(WPOS).SIGNATURE = [EFLD]SIGNATURE
    this.EMSG(WPOS).SIGNAEXT  = [EFLD]SIGNAEXT
    ## X3-41976 XML signature (JUCON 17/02/2017)
    this.EMSG(WPOS).VALXML    = [EFLD]VALXML #X3-112926 EDI : Add a flow parameter to select the validation of XML

    If this.EMSG(WPOS).MSGFOR=1
      Local File EDISEQFIL [ESF]
      Read [F:ESF]ESF0 = this.EMSG(WPOS).MSGCOD;this.EMSG(WPOS).MSGREL;this.EMSG(WPOS).MSGFILNOR
      If !fstat
        this.EMSG(WPOS).SEQ_UUID = [ESF]CACHEUUID
      Else
        this.EMSG(WPOS).SEQ_UUID = NullUuid()
      Endif
      LogicClose File [ESF]
    Else
      Local File EDIXMLFIL [EXF]
      Read [F:EXF]EXF0 = this.EMSG(WPOS).MSGCOD;this.EMSG(WPOS).MSGREL;this.EMSG(WPOS).MSGFILNOR
      If !fstat
        this.EMSG(WPOS).SEQ_UUID = [EXF]CACHEUUID
       # this.EMSG(WPOS).SEQ_UUID = [EXF]UUIDXMLTYP
      Else
        this.EMSG(WPOS).SEQ_UUID = NullUuid()
      Endif
      LogicClose File [EXF]
    Endif
    ## END 112148
  Endif   #JCC
#  Next #JCC
  LogicClose File [EFLD]
Return

###################################################################
$GET_MSG_PROPERTIES
  Local File EDIMSG [EMS]
  Read [F:EMS]EMS0 = this.MSGCOD;this.MSGREL
  If !fstat
    this.MSG_UUID = [EMS]CACHEUUID
    this.MSGTYP   = [EMS]MSGTYP
  Else
    this.MSG_UUID = NullUuid()
  Endif
  LogicClose File [EMS]

# INI 112148
#  Local File EDISEQFIL [ESF]
#  Read [F:ESF]ESF0 = this.MSGCOD;this.MSGREL;this.MSGFILNOR
#  If !fstat
#    this.SEQ_UUID = [ESF]CACHEUUID
#  Else
#    this.SEQ_UUID = NullUuid()
#  Endif
#  LogicClose File [ESF]
# END 112148

Return


###################################################################

$EMSG_ADDLINE_AFTER
  this.NUMBATCH  = this.APARENT.NUMBATCH
  this.FLO_UUID  = this.APARENT.FLO_UUID
Return

$EINS_ADDLINE_AFTER
  this.NUMBATCH  = this.APARENT.NUMBATCH
  this.FLO_UUID  = this.APARENT.FLO_UUID
Return

$EMUX_ADDLINE_AFTER
  this.NUMBATCH = this.APARENT.NUMBATCH
Return



#********************************************************************
# Method MET_ISSUE_INIT
#********************************************************************
#
#* @param WNUMBATCH
#* @param WEDIRUN
#* @return WOK
#*!
$MET_ISSUE_INIT
  this.NUMBATCH  = WNUMBATCH
  this.X3FOLDER  = [S]nomap
  this.CATTYP    = fmet WEDIRUN.ACTX.ACACHE.ECA.AGETVALNUM(WEDIRUN.CATCOD,"CATTYP")
  this.CATTRGTAB = fmet WEDIRUN.ACTX.ACACHE.ECA.AGETVALCHAR(WEDIRUN.CATCOD,"CATTRGTAB")
  this.PARCOD    = WEDIRUN.PARCOD
  this.CATCOD    = WEDIRUN.CATCOD
  this.ALLFLO    = WEDIRUN.ALLFLO
  this.FLOCOD    = WEDIRUN.FLOCOD #can be empty if ALLFLO checked
  this.FLOREL    = WEDIRUN.FLOREL #can be empty if ALLFLO checked

  Local Integer WPOS
  Local File EDICATK [ECK]
  Filter [ECK] Where [ECK]CATCOD = WEDIRUN.CATCOD
  For [ECK]
    Case [ECK]CODE #rev RBA
      When "FCY"    : WPOS = fmet this.ADDLINE("EKEY", [V]CST_ALASTPOS) : this.EKEY(WPOS).KEY_COD = "FCY"    : this.EKEY(WPOS).KEY_FLD = [ECK]FLD
      When "BPANUM" : WPOS = fmet this.ADDLINE("EKEY", [V]CST_ALASTPOS) : this.EKEY(WPOS).KEY_COD = "BPANUM" : this.EKEY(WPOS).KEY_FLD = [ECK]FLD
      When "BPAADD" : WPOS = fmet this.ADDLINE("EKEY", [V]CST_ALASTPOS) : this.EKEY(WPOS).KEY_COD = "BPAADD" : this.EKEY(WPOS).KEY_FLD = [ECK]FLD
      When "CPY"    : WPOS = fmet this.ADDLINE("EKEY", [V]CST_ALASTPOS) : this.EKEY(WPOS).KEY_COD = "CPY"    : this.EKEY(WPOS).KEY_FLD = [ECK]FLD #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat
    Endcase
  Next
  Filter [ECK]
  LogicClose File [ECK]

  Local File EDICAT [ECA]
  Read [ECA]ECA0 = WEDIRUN.CATCOD
  If !fstat
    this.FLD_DOCID  = [ECA]DESCRIPT
  Endif
  LogicClose File [ECA]

  ARET_VALUE = [V]CST_AOK
Return


#********************************************************************
# Method MET_ISSUE_CREATE_QUERY
#********************************************************************
#
#*
#* @param WEDIRUN
#* @param WMYLOG
#* @return WOK
#*!
$MET_ISSUE_CREATE_QUERY
#Issue 110811 US9
  Local Integer WOKK, WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WERR(250)
  Local Integer WOK, I, J

  WOKK=func EDIRUN_CSTD.CHECK_AUTHORIZATION(this.ACTX.USER,this.CATCOD)

  If WOKK=0
    WERR = mess(74,100,1)    #Unauthorized Function
    Call ADDDIAGNOSE(WEDIRUN.ACTX,WERR,[V]CST_AERROR) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
    WRET_VALUE = [V]CST_AERROR

  Else  #Issue 110811 US9
    If WEDIRUN.CATACT = 1
      Local Integer WNBDOC_QRY : WNBDOC_QRY = 0
      #INI 112149
      Local File EDITMPDOC [ETC]
      Trbegin [ETC]
        Delete [ETC] Where CREUSR=this.ACTX.USER
      Commit
      LogicClose File [ETC]

      Local File EDITMPLOG [EDL]
      Trbegin [EDL]
        Delete [EDL] Where CREUSR=this.ACTX.USER
      Commit
      LogicClose File [EDL]
      #END 112149

    #$ISSUE_GET_FILTERS
      Local Char WSTR(250)(1..)
      Local Char WA(100), WB(100), WX(100)
      Local Char WMYFILTERS(250)  : WMYFILTERS = "1=1"
      Local Integer WFLG_FILTER    : WFLG_FILTER = [V]CST_ANO

      For I = 1 To maxtab(WEDIRUN.EDRD())
        If WEDIRUN.EDRD(I).FLDVAL1 <> ""
          WFLG_FILTER = [V]CST_AYES
          WX = WEDIRUN.EDRD(I).FLD
          ## INI 112148
          If WEDIRUN.CATTYP=2 & WEDIRUN.PARCOD="FACTURAE" #Facturae specificities
            Case WX
              When "DOCID"      : WX="NUM"
              When "BPRNUM"     : WX="BPCINV"
              When "DOCDAT"     : WX="INVDAT"
              When "FLGVALIDDOC": WX="INVSTA"
            Endcase
          Endif
          ## END 112148
          Case WEDIRUN.EDRD(I).OPERATOR
            When 1 :
              Call FORMAT_FILTER_LINE(WEDIRUN.EDRD(I).FLDVAL1, WEDIRUN.EDRD(I).FLDTYPTYP, WA) From EDISTRISS_CSTD
              Call FORMAT_FILTER_LINE(WEDIRUN.EDRD(I).FLDVAL2, WEDIRUN.EDRD(I).FLDTYPTYP, WB) From EDISTRISS_CSTD
              WSTR(I) = WX-">="-WA-"and"-WX-"<="-WB
            When 2 :
              Call FORMAT_FILTER_LINE(WEDIRUN.EDRD(I).FLDVAL1, WEDIRUN.EDRD(I).FLDTYPTYP, WA) From EDISTRISS_CSTD
              WSTR(I) = WX-"="-WA
            When 3 :
              Call FORMAT_FILTER_LINE(WEDIRUN.EDRD(I).FLDVAL1, WEDIRUN.EDRD(I).FLDTYPTYP, WA) From EDISTRISS_CSTD
              WSTR(I) = WX-">="-WA
            When 4 :
              Call FORMAT_FILTER_LINE(WEDIRUN.EDRD(I).FLDVAL1, WEDIRUN.EDRD(I).FLDTYPTYP, WA) From EDISTRISS_CSTD
              WSTR(I) = WX-">="-WA
          Endcase
          WMYFILTERS = WMYFILTERS-"and"-WSTR(I)
        Endif
      Next I

    Call ASYNCTRACK(WEDIRUN.ACTX, "(1)", mess(15,134,1), 10) From ASYRASYNC

    If WFLG_FILTER = [V]CST_ANO
      WOK = fmet WMYLOG.APUTLINE(mess(19,2007,1),[V]CST_AWARNING) #"No filter defined"
      Call ADDDIAGNOSE(WEDIRUN.ACTX,mess(19,2007,1),[V]CST_AWARNING) From ASYRASYNC
      WOK = fmet WMYLOG.APUTLINE("",[V]CST_AINFO)
      WRET_VALUE = [V]CST_AERROR

    Else
      #on continue
      WERR = mess(37,2007,1)+"..." #"Generating the document list to process..."
#      ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AINFO)
      Call ADDDIAGNOSE(WEDIRUN.ACTX,WERR,[V]CST_AINFO) From ASYRASYNC
      WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)

      #Get keys from table index
      Local Char WTAB_INDEX_KEYS(20)(1..)
      Local Integer WPOS #, I, K

      Local Char WFLD_DOCID(100)
      If WEDIRUN.CATTYP=2 & WEDIRUN.PARCOD="FACTURAE" #Facturae specificities #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
        WFLD_DOCID = "NUM"
      Else
        WFLD_DOCID = this.FLD_DOCID
      Endif

      J = 1
      For I = 1 To len(WFLD_DOCID)
        WPOS = instr(I, WFLD_DOCID, "+")
        If WPOS > 0
          WTAB_INDEX_KEYS(J) = left$(WFLD_DOCID, WPOS-1)
          J = J +1
          WFLD_DOCID = right$(WFLD_DOCID, WPOS+1)
        Endif
      Next I
      If WPOS <= 0
        WTAB_INDEX_KEYS(J) = WFLD_DOCID
      Endif

      Local Char WSTR_INDEX(250)
      Local File EDITMPDOC [ETC]

      If WEDIRUN.CATTYP=2 & WEDIRUN.PARCOD="FACTURAE" ## INI 112148 #Facturae specificities
        Local File SINVOICEV [TRG]
      Else
        Local File =this.CATTRGTAB [TRG]
      Endif

      Filter [TRG] Where evalue(WMYFILTERS)
      #loop on each document corresponding to WMYFILTERS
      For [TRG]
        WNBDOC_QRY = WNBDOC_QRY + 1

        Trbegin [ETC]
        [F:ETC]NUMBATCH  = this.NUMBATCH
        [F:ETC]CATTRGTAB = this.CATTRGTAB
        [F:ETC]CATACT = 1 #issue

        #assign keys from index
        If WFLD_DOCID <> ""
          ## 112148
#          If WEDIRUN.CATTYP=2 & WEDIRUN.PARCOD="FACTURAE" #Facturae specificities
##            WSTR_INDEX=[TRG]NUM
#            WSTR_INDEX = num$(evalue("[TRG]"+"NUM")) #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
##            Assign ("[F:ETC]DOCID")  With WSTR_INDEX #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
#          Else  ## 112148
            WSTR_INDEX = num$(evalue("[TRG]"+WTAB_INDEX_KEYS(1)))
            If maxtab(WTAB_INDEX_KEYS) > 1
              For I = 2 To maxtab(WTAB_INDEX_KEYS)
                If WTAB_INDEX_KEYS(I) <> ""
#                  WSTR_INDEX = WSTR_INDEX + "~"  + num$(evalue("[TRG]"+WTAB_INDEX_KEYS(I)))
                  WSTR_INDEX = WSTR_INDEX + "!"  + num$(evalue("[TRG]"+WTAB_INDEX_KEYS(I))) #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
                Endif
              Next
            Endif
#            Assign ("[F:ETC]DOCID")  With WSTR_INDEX #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
#          Endif
          Assign ("[F:ETC]DOCID")  With WSTR_INDEX #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
        Else
          [F:ETC]DOCID     = ""
        Endif
        WSTR_INDEX = ""

        #assign all EDI reference authorizations from Category
        #ATTENTION: Now only used the control group 1. Any control about different values is done.
        Local Integer WPOS
        For WPOS = 1 To maxtab(this.EKEY)
 #         If this.EKEY(WPOS).KEY_COD = "CPY"    : If this.EKEY(WPOS).KEY_FLD <> "" : Assign ("[F:ETC]CPY")    With evalue("[TRG]"+this.EKEY(WPOS).KEY_FLD) : Else [F:ETC]CPY     = "" : Endif : Endif
          Assign ("[F:ETC]CPY")    With evalue("[TRG]"+"CPY") #110811_US11
          ## INI 112148
          If WEDIRUN.CATTYP=2 & WEDIRUN.PARCOD="FACTURAE" #Facturae specificities
#            If this.EKEY(WPOS).KEY_COD = "CPY"    : If this.EKEY(WPOS).KEY_FLD <> "" : Assign ("[F:ETC]CPY")    With evalue("[TRG]CPY")    : Else [F:ETC]CPY     = "" : Endif : Endif #Issue US
# X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
#            If this.EKEY(WPOS).KEY_COD = "CPY"    : this.EKEY(WPOS).KEY_FLD = "CPY"    : Assign ("[F:ETC]CPY")    With evalue("[TRG]"+this.EKEY(WPOS).KEY_FLD) : Else [F:ETC]CPY     = "" : Endif
# X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
            If this.EKEY(WPOS).KEY_COD = "FCY"    : If this.EKEY(WPOS).KEY_FLD <> "" : Assign ("[F:ETC]FCY")    With evalue("[TRG]SALFCY") : Else [F:ETC]FCY     = "" : Endif : Endif
            If this.EKEY(WPOS).KEY_COD = "BPANUM" : If this.EKEY(WPOS).KEY_FLD <> "" : Assign ("[F:ETC]BPRNUM") With evalue("[TRG]BPCINV") : Else [F:ETC]BPRNUM  = "" : Endif : Endif
            If this.EKEY(WPOS).KEY_COD = "BPAADD" : If this.EKEY(WPOS).KEY_FLD <> "" : Assign ("[F:ETC]BPAADD") With evalue("[TRG]BPAADD") : Else [F:ETC]BPAADD  = "" : Endif : Endif
          Else ## END 112148
#            If this.EKEY(WPOS).KEY_COD = "CPY"    : If this.EKEY(WPOS).KEY_FLD <> "" : Assign ("[F:ETC]CPY")    With evalue("[TRG]"+this.EKEY(WPOS).KEY_FLD) : Else [F:ETC]CPY     = "" : Endif : Endif
            If this.EKEY(WPOS).KEY_COD = "FCY"    : If this.EKEY(WPOS).KEY_FLD <> "" : Assign ("[F:ETC]FCY")    With evalue("[TRG]"+this.EKEY(WPOS).KEY_FLD) : Else [F:ETC]FCY     = "" : Endif : Endif
            If this.EKEY(WPOS).KEY_COD = "BPANUM" : If this.EKEY(WPOS).KEY_FLD <> "" : Assign ("[F:ETC]BPRNUM") With evalue("[TRG]"+this.EKEY(WPOS).KEY_FLD) : Else [F:ETC]BPRNUM  = "" : Endif : Endif
            If this.EKEY(WPOS).KEY_COD = "BPAADD" : If this.EKEY(WPOS).KEY_FLD <> "" : Assign ("[F:ETC]BPAADD") With evalue("[TRG]"+this.EKEY(WPOS).KEY_FLD) : Else [F:ETC]BPAADD  = "" : Endif : Endif
          Endif
        Next WPOS

        # Ini X3-210378 Error sending a sales invoice by EDI - CIUS-PT (JUCON 2020-08-31)
        Local File FACILITY [FCY]
        Read [FCY]FCY0=[F:ETC]FCY
        If fstat=[V]CST_AOK
          Local Char PLEG(3)
          PLEG=[F:FCY]LEG
        Endif
        LogicClose File [FCY]
        # End X3-210378 Error sending a sales invoice by EDI - CIUS-PT (JUCON 2020-08-31)

        # Ini X3-186460 Incorrect character in main key (JUCON 2020-03-11)
        # ckecking invalid characters
        Local Integer POS
        Raz WERR
        # Ini X3-210378 Error sending a sales invoice by EDI - CIUS-PT (JUCON 2020-08-31)
        If PLEG<>"POR"
          POS=instr(1,[F:ETC]DOCID,"/")
          If POS>0: WERR=[F:ETC]DOCID+":"-mess(1,127,1)+". '/'"-mess(113,123,1): Endif # Invalid character
        Endif
        # End X3-210378 Error sending a sales invoice by EDI - CIUS-PT (JUCON 2020-08-31)
        POS=instr(1,[F:ETC]DOCID,"\")
        If POS>0: WERR=[F:ETC]DOCID+":"-mess(1,127,1)+". '\'"-mess(113,123,1): Endif # Invalid character
        POS=instr(1,[F:ETC]DOCID,"*")
        If POS>0: WERR=[F:ETC]DOCID+":"-mess(1,127,1)+". '*'"-mess(113,123,1): Endif # Invalid character
        POS=instr(1,[F:ETC]DOCID,"?")
        If POS>0: WERR=[F:ETC]DOCID+":"-mess(1,127,1)+". '?'"-mess(113,123,1): Endif # Invalid character
        POS=instr(1,[F:ETC]DOCID,":")
        If POS>0: WERR=[F:ETC]DOCID+":"-mess(1,127,1)+". ':'"-mess(113,123,1): Endif # Invalid character
        POS=instr(1,[F:ETC]DOCID,"<")
        If POS>0: WERR=[F:ETC]DOCID+":"-mess(1,127,1)+". '<"-mess(113,123,1): Endif # Invalid character
        POS=instr(1,[F:ETC]DOCID,">")
        If POS>0: WERR=[F:ETC]DOCID+":"-mess(1,127,1)+". '>'"-mess(113,123,1): Endif # Invalid character
        If WERR<>""
          Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AERROR) From ASYRASYNC
          WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
        Endif
        # End X3-186460 Incorrect character in main key (JUCON 2020-03-11)

         # INI SAM 110812 XML Signature
        If WEDIRUN.PROBATCH=[V]CST_AYES
          Local Char WSFLOW(20)
          Local Char WSVER (10)
          If [F:ETC]FCY<>"" and [F:ETC]CPY=""
            Local File FACILITY [FCY]
            Read [FCY]FCY0=[F:ETC]FCY
            If fstat=[V]CST_AOK
              [F:ETC]CPY=[F:FCY]LEGCPY
            Endif
            LogicClose File [FCY]
            # Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
#            Call GET_EDIBPRCPYD_FLOW([F:ETC]BPRNUM,[F:ETC]CPY,WEDIRUN.PARCOD,WEDIRUN.CATTYP,WEDIRUN.CATACT,WSFLOW,WSVER) From EDIRUN_CSTD
            Local Integer WCATOPE : WCATOPE = 2 #by default Create
            Call GET_EDIBPRCPYD_FLOW([F:ETC]BPRNUM,[F:ETC]CPY,WEDIRUN.PARCOD,WEDIRUN.CATTYP,WEDIRUN.CATACT,WCATOPE,WSFLOW,WSVER) From EDIRUN_CSTD
            #/ Issue US X3-7673 - 2018-03-30 by RBA : EDI improvements
            If WSFLOW <>"" and WSVER <>""
              WEDIRUN.FLOCOD = WSFLOW
              WEDIRUN.FLOREL = WSVER
              WOK = func EDIRUN_CSTD.TEST_SIGNED_EDIFLO(WSFLOW, WSVER, WERR)
            Else
              WERR=mess(32,2006,1)   # Flow not found
            Endif
          Endif
          If WERR<>""
            Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AERROR) From ASYRASYNC
            WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
          Endif
        Endif
        ## END SAM 110812 XML Signature
        [F:ETC]FLGEDIBPR    = [V]CST_AERROR #default value
        [F:ETC]FLGEDICPY    = [V]CST_AERROR #default value
        [F:ETC]FLGEDIFCY    = [V]CST_AERROR #default value
        [F:ETC]FLGEDIBPRCPY = [V]CST_AERROR #default value
        [F:ETC]FLGVALIDFLO  = [V]CST_AERROR #default value
        [F:ETC]FLOCOD       = WEDIRUN.FLOCOD   #can be empty if ALLFLO checked
        [F:ETC]FLOREL       = WEDIRUN.FLOREL   #can be empty if ALLFLO checked
        [F:ETC]CREUSR       = this.ACTX.USER   ## 112148
        #write record on temporary table
        Write [ETC]
        If !fstat
          Commit
        Else
          #"Generation of the document list : failed"
          WERR = format$("4X","")+format$("60X",mess(37,2007,1))+" : "+mess(9,2007,1)
#          ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AERROR)
          Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AERROR) From ASYRASYNC
          #Init 112149
          WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
          WERR = [F:ETC]DOCID+"."-mess(197,133,1)-"(EDITMPDOC)"  #Record already exists!
          Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AERROR) From ASYRASYNC
          WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
          Rollback
          #End 112149
        Endif
      Next
      Filter [TRG]
      LogicClose File [TRG]
      LogicClose File [ETC]

      #"Number of documents to check found by the query
      this.NBDOC_QRY = WNBDOC_QRY
      WERR = format$("4X","")+format$("60X",mess(51,2007,1))+" : "+num$(WNBDOC_QRY)
      If WNBDOC_QRY = 0
#        ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AWARNING)
        Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AWARNING) From ASYRASYNC
        WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AWARNING)
      Else
#        ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AINFO)
        Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
        WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
      Endif
      WRET_VALUE = [V]CST_AOK
    Endif
   Else
     WRET_VALUE = [V]CST_AERROR
   Endif
  Endif
  ARET_VALUE = WRET_VALUE
Return


#********************************************************************
# Method MET_ISSUE_CONTROLS
#********************************************************************
#
#*
#* @param WEDIRUN
#* @param WMYLOG
#* @return WOK
#*!
$MET_ISSUE_CONTROLS
  Local Char WERR(250)
  Local Integer WOK, I, J, WRET_VALUE : WRET_VALUE = [V]CST_AOK

  Local Char WFLOCOD(20)
  Local Char WFLOREL(5)
  Local Char WMSGCOD(20)
  Local Char WMSGREL(5)
  Local Char WMSGFILNOR(20)
  Local Char WPTC (20)
  Local Integer WFLGMUX
  Local Integer WFLG

  Local Integer WPARTYP #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
  WPARTYP = fmet GACTX.ACACHE.EPR.AGETVALNUM(this.PARCOD,"PARTYP") #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)

  Call ASYNCTRACK(WEDIRUN.ACTX, "(2)", mess(30,2007,1), 20) From ASYRASYNC
  #1 - Controls existence of autorisations fields
  Local Integer WPOS
  For WPOS = 1 To maxtab(this.EKEY)
    If this.EKEY(WPOS).KEY_COD = "CPY"    and this.EKEY(WPOS).KEY_FLD = "" : WRET_VALUE = [V]CST_AERROR : WERR = mess(15,2006,1) : Endif #"Company must be defined"  #110811  #Issue US X3-93866 -
# 2018-06-18 by RBA : Intrastat (evolutions)
    If this.EKEY(WPOS).KEY_COD = "FCY"    and this.EKEY(WPOS).KEY_FLD = "" : WRET_VALUE = [V]CST_AERROR : WERR = mess(25,2006,1) : Endif #"Site code must be defined"
    If this.EKEY(WPOS).KEY_COD = "BPRNUM" and this.EKEY(WPOS).KEY_FLD = "" : WRET_VALUE = [V]CST_AERROR : WERR = mess(5,2006,1)  : Endif #"Business partner must be defined"
    If this.EKEY(WPOS).KEY_COD = "BPAADD" and this.EKEY(WPOS).KEY_FLD = "" : WRET_VALUE = [V]CST_AERROR : WERR = mess(4,2006,1)  : Endif #"Business partner address code must be defined"
  Next WPOS
  If WRET_VALUE <> [V]CST_AOK
    WOK = fmet WMYLOG.APUTLINE("Category : "+WERR,[V]CST_AERROR)
  Else #Issue US X3-93866 - 2018-06-18 by RBA : Intrastat (evolutions)
  #refactored
    Local File EDITMPDOC [ETC]
  #  WPARTYP = 3 # AIT51
    Case WPARTYP
      When 1 : #CPY controls
        Gosub CONTROL_CPYPAR
        Gosub CONTROL_GET_FLOW_CPY
      When 2 : #CPY + BP controls
        Gosub CONTROL_CPYPAR
        Gosub CONTROL_FCYPAR
        Gosub CONTROL_BPRPAR # ait51
        Gosub CONTROL_GET_FLOW_BPRCPY # ait51
      When 3 : #no controls
        Gosub CONTROL_GET_FLOW
    Endcase

    Gosub CONTROL_FLOW_SETUP # AIT51

    #5 - Number of checked documents ok/nok
    WERR = format$("4X","")+format$("50X",mess(42,2007,1))+format$("10X",mess(157,100,1))+" : "+num$(WNBDOC_FLO_OK)+"/"+num$(WNBDOC_FLO)

    If WNBDOC_FLO_OK = 0
#      ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AWARNING)
      Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AWARNING) From ASYRASYNC
      WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AWARNING)
    Else
#      ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AINFO)
      Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
      WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
    Endif
    WERR = format$("4X","")+format$("50X",mess(42,2007,1))+format$("10X",mess(7,21,1))   +" : "+num$(WNBDOC_FLO_KO)+"/"+num$(WNBDOC_FLO)
#    ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AINFO)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
    LogicClose File [ETC]
  Endif

  #6 - Log Resume
  ###########################################
  Local Char WDOCID_TAB(60)(1..)
  I = 0
  If WNBDOC_FLO_OK = 0
    Local File EDITMPDOC [ETC]
    Filter [ETC] Where [ETC]NUMBATCH = this.NUMBATCH
    For [ETC]
      #flush log when all is finished
      I = I + 1
      WDOCID_TAB(I) = [ETC]DOCID
    Next
    LogicClose File [ETC]
    WOK = fmet this.MET_ISSUE_LOG_RESUME(WDOCID_TAB, WEDIRUN, WMYLOG)
  Endif
  ###########################################

  ARET_VALUE = WRET_VALUE
Return

$CONTROL_CPYPAR
  #2-1 Controls autorizations fields : Company CPY
  Filter [ETC] Where [ETC]NUMBATCH = this.NUMBATCH Order By Key ETC1
  For [ETC]
    Trbegin [ETC]
    [ETC]FLGEDICPY = func EDIRUN_CSTD.TEST_EDICPYPAR([ETC]CPY, this.PARCOD)
    Rewrite [ETC]
    If !fstat
      Commit
#        WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 4, [ETC]FLGEDICPY, 1, [ETC]CPY, WMYLOG)
       WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 4, [V]CST_AINFO, 1, [ETC]CPY, WMYLOG) # 112149
    Else
      Rollback
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 4, [V]CST_AERROR, 1, [ETC]CPY, WMYLOG)
    Endif
  Next
  Filter [ETC]
Return

$CONTROL_FCYPAR
    #2-2 Controls autorizations fields : Site FCY
#    Filter [ETC] Where [ETC]NUMBATCH = this.NUMBATCH and [ETC]FLGEDICPY = [V]CST_AINFO Order By Key ETC1
  Filter [ETC] Where [ETC]NUMBATCH = this.NUMBATCH Order By Key ETC1    # 112149
  For [ETC]
    Trbegin [ETC]
    [ETC]FLGEDIFCY = func EDIRUN_CSTD.TEST_EDIFCYPAR([ETC]FCY, this.PARCOD)
#      If [ETC]FLGEDIFCY=3 and [ETC]FLGEDICPY=3: [ETC]FLGEDIFCY=4: Endif  #SAM 114061
    If [ETC]FLGEDIFCY<>[V]CST_AINFO and [ETC]FLGEDICPY<>[V]CST_AINFO: [ETC]FLGEDIFCY=[V]CST_AERROR: Endif # 112149
    Rewrite [ETC]
    If !fstat
      Commit
#        WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 5, [ETC]FLGEDIFCY, 2, [ETC]FCY, WMYLOG)
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 5, [V]CST_AINFO, 2, [ETC]FCY, WMYLOG)  # 112149
    Else
      Rollback
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 5, [V]CST_AERROR, 2, [ETC]FCY, WMYLOG)
    Endif
    Next
  Filter [ETC]
Return

$CONTROL_BPRPAR
    #2-3 Controls autorizations fields : BP/Address BPANUM+BPAADD
#    Filter [ETC] Where [ETC]NUMBATCH = this.NUMBATCH and [ETC]FLGEDIFCY = [V]CST_AINFO Order By Key ETC1 # 112149
  Filter [ETC] Where [ETC]NUMBATCH = this.NUMBATCH and ([ETC]FLGEDIFCY = [V]CST_AINFO or [ETC]FLGEDICPY = [V]CST_AINFO) Order By Key ETC1
  For [ETC]
    Trbegin [ETC]
    [ETC]FLGEDIBPR = func EDIRUN_CSTD.TEST_EDIBPRPAR([ETC]BPRNUM, [ETC]BPAADD, this.PARCOD)
    Rewrite [ETC]
    If !fstat
      Commit
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 6, [ETC]FLGEDIBPR, 3, [ETC]BPRNUM+"~"+[ETC]BPAADD, WMYLOG)
    Else
      Rollback
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 6, [V]CST_AERROR, 3, [ETC]BPRNUM+"~"+[ETC]BPAADD, WMYLOG)
    Endif
  Next
  Filter [ETC]
Return

$CONTROL_GET_FLOW_BPRCPY
  #3 - Controls Flow association with BP/Company
  WFLG = [V]CST_AERROR
  Filter [ETC] Where [ETC]NUMBATCH = this.NUMBATCH and [ETC]FLGEDIBPR = [V]CST_AINFO Order By Key ETC1
  For [ETC]
    WFLG = func EDIRUN_CSTD.TEST_EDIBPRCPY([ETC]BPRNUM, [ETC]CPY, this.PARCOD, this.CATCOD, WFLOCOD, WFLOREL)
    #compare flow id in case of ALLFLO not checked
    If this.ALLFLO = 1 and (WFLOCOD <> this.FLOCOD or WFLOREL <> this.FLOREL)
      WFLOCOD = this.FLOCOD #au cas où il n'existe pas d'association
      WFLOREL = this.FLOREL #au cas où il n'existe pas d'association
      WFLG = [V]CST_AERROR
    #Ini SAM 122567 (JUCON 17/04/2017)
    Else
      If WFLOCOD<>"" and WFLOREL<>""
        this.FLOCOD=WFLOCOD
        this.FLOREL=WFLOREL
      Else
        WFLG = [V]CST_AERROR
      Endif
      #End SAM 122567 (JUCON 17/04/2017)
    Endif
    If WFLG = [V]CST_AINFO
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 7, WFLG, 4, [ETC]BPRNUM+"~"+[ETC]CPY - WFLOCOD+"~"+WFLOREL, WMYLOG)
      If this.EMSG(1).MSGFOR=1  # Ini SAM 110699  Only one line by flow
        WOK = func EDIRUN_CSTD.GET_EDISEQFIL_FROM_EDIFLO(WFLOCOD, WFLOREL, this.CATCOD, WMSGCOD, WMSGREL, WMSGFILNOR, WFLGMUX, WPTC)
      Else
        WOK = func EDIRUN_CSTD.GET_EDIXMLFIL_FROM_EDIFLO(WFLOCOD, WFLOREL, this.CATCOD, WMSGCOD, WMSGREL, WMSGFILNOR, WFLGMUX, WPTC)
      Endif   # End SAM 110699

      If WOK = [V]CST_AOK
        Trbegin [ETC]
        [ETC]FLOCOD       = WFLOCOD
        [ETC]FLOREL       = WFLOREL
        [ETC]MSGCOD       = WMSGCOD
        [ETC]MSGREL       = WMSGREL
        [ETC]MSGFILNOR    = WMSGFILNOR
        [ETC]FLGMUX       = WFLGMUX
        [ETC]PTCCOD       = WPTC
        [ETC]FLGEDIBPRCPY = [V]CST_AINFO
        WERR = ""
        #WERR = "Recovering Flow information"
        Rewrite [ETC]
        If !fstat
          Commit
          WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 8, [V]CST_AINFO, 5, WFLOCOD+"~"+WFLOREL, WMYLOG)
        Else
          Rollback
          WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 8, [V]CST_AERROR, 5, WFLOCOD+"~"+WFLOREL, WMYLOG)
        Endif
      Else
        WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 8, [V]CST_AERROR, 5, mess(9,2007,1), WMYLOG)
      Endif

    Else
      #err
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 7, WFLG, 4, [ETC]BPRNUM+"~"+[ETC]CPY - WFLOCOD+"~"+WFLOREL, WMYLOG)
    Endif
  Next
  Filter [ETC]
Return

$CONTROL_GET_FLOW_CPY
  #3 - Controls Flow association with Company
  WFLG = [V]CST_AERROR
  Filter [ETC] Where [ETC]NUMBATCH = this.NUMBATCH and [ETC]FLGEDICPY = [V]CST_AINFO Order By Key ETC1
  For [ETC]
    WFLG = func TEST_EDICPY([ETC]CPY, this.PARCOD, this.CATCOD, WFLOCOD, WFLOREL)

    If this.ALLFLO = 1 and (WFLOCOD <> this.FLOCOD or WFLOREL <> this.FLOREL)
      WFLOCOD = this.FLOCOD #au cas où il n'existe pas d'association
      WFLOREL = this.FLOREL #au cas où il n'existe pas d'association
      WFLG = [V]CST_AERROR
    #Ini SAM 122567 (JUCON 17/04/2017)
    Else
      If WFLOCOD<>"" and WFLOREL<>""
        this.FLOCOD=WFLOCOD
        this.FLOREL=WFLOREL
      Else
        WFLG = [V]CST_AERROR
      Endif
      #End SAM 122567 (JUCON 17/04/2017)
    Endif

    If WFLG = [V]CST_AINFO
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 7, WFLG, 4, [ETC]CPY - WFLOCOD+"~"+WFLOREL, WMYLOG)
      If this.EMSG(1).MSGFOR=1  # Ini SAM 110699  Only one line by flow
        WOK = func EDIRUN_CSTD.GET_EDISEQFIL_FROM_EDIFLO(WFLOCOD, WFLOREL, this.CATCOD, WMSGCOD, WMSGREL, WMSGFILNOR, WFLGMUX, WPTC)
      Else
        WOK = func EDIRUN_CSTD.GET_EDIXMLFIL_FROM_EDIFLO(WFLOCOD, WFLOREL, this.CATCOD, WMSGCOD, WMSGREL, WMSGFILNOR, WFLGMUX, WPTC)
      Endif   # End SAM 110699
      If WOK = [V]CST_AOK
        Trbegin [ETC]

        [ETC]FLGEDIFCY = [V]CST_AINFO
        [ETC]FLGEDIBPR = [V]CST_AINFO

        [ETC]FLOCOD       = WFLOCOD
        [ETC]FLOREL       = WFLOREL
        [ETC]MSGCOD       = WMSGCOD
        [ETC]MSGREL       = WMSGREL
        [ETC]MSGFILNOR    = WMSGFILNOR
        [ETC]FLGMUX       = WFLGMUX
        [ETC]PTCCOD       = WPTC
        [ETC]FLGEDIBPRCPY = [V]CST_AINFO
        WERR = ""
        #WERR = "Recovering Flow information"
        Rewrite [ETC]
        If !fstat
          Commit
          WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 8, [V]CST_AINFO, 5, WFLOCOD+"~"+WFLOREL, WMYLOG)
        Else
          Rollback
          WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 8, [V]CST_AERROR, 5, WFLOCOD+"~"+WFLOREL, WMYLOG)
        Endif
      Else
        WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 8, [V]CST_AERROR, 5, mess(9,2007,1), WMYLOG)
      Endif
    Else
      #err
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 7, WFLG, 4, [ETC]CPY - WFLOCOD+"~"+WFLOREL, WMYLOG)
    Endif

  Next
  Filter [ETC]
Return

$CONTROL_GET_FLOW
  # A developper : No CPY and BPR controls, le flux doit être obligatoirement saisi dans le launching process this.ALLFLO = 1
  # NOT TESTED !
  #3 - No Controls on Flow associations
  WFLG = [V]CST_AERROR
  Filter [ETC] Where [ETC]NUMBATCH = this.NUMBATCH Order By Key ETC1
  For [ETC]
    If this.FLOCOD = "" and this.FLOREL = ""
      WFLG = [V]CST_AERROR
    Else
      WFLOCOD = this.FLOCOD
      WFLOREL = this.FLOREL
    Endif

    If WFLG = [V]CST_AINFO
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 7, WFLG, 4, [ETC]CPY - WFLOCOD+"~"+WFLOREL, WMYLOG)
      If this.EMSG(1).MSGFOR=1  # Ini SAM 110699  Only one line by flow
        WOK = func EDIRUN_CSTD.GET_EDISEQFIL_FROM_EDIFLO(WFLOCOD, WFLOREL, this.CATCOD, WMSGCOD, WMSGREL, WMSGFILNOR, WFLGMUX, WPTC)
      Else
        WOK = func EDIRUN_CSTD.GET_EDIXMLFIL_FROM_EDIFLO(WFLOCOD, WFLOREL, this.CATCOD, WMSGCOD, WMSGREL, WMSGFILNOR, WFLGMUX, WPTC)
      Endif   # End SAM 110699
      If WOK = [V]CST_AOK
        Trbegin [ETC]
        [ETC]FLGEDICPY = [V]CST_AINFO
        [ETC]FLGEDIFCY = [V]CST_AINFO
        [ETC]FLGEDIBPR = [V]CST_AINFO
        [ETC]FLGEDIBPRCPY = [V]CST_AINFO

        [ETC]FLOCOD       = WFLOCOD
        [ETC]FLOREL       = WFLOREL
        [ETC]MSGCOD       = WMSGCOD
        [ETC]MSGREL       = WMSGREL
        [ETC]MSGFILNOR    = WMSGFILNOR
        [ETC]FLGMUX       = WFLGMUX
        [ETC]PTCCOD       = WPTC
        WERR = ""
        #WERR = "Recovering Flow information"
        Rewrite [ETC]
        If !fstat
          Commit
          WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 8, [V]CST_AINFO, 5, WFLOCOD+"~"+WFLOREL, WMYLOG)
        Else
          Rollback
          WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 8, [V]CST_AERROR, 5, WFLOCOD+"~"+WFLOREL, WMYLOG)
        Endif
      Else
        WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 8, [V]CST_AERROR, 5, mess(9,2007,1), WMYLOG)
      Endif
    Else
      #err
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 7, WFLG, 4, [ETC]CPY - WFLOCOD+"~"+WFLOREL, WMYLOG)
    Endif

  Next
  Filter [ETC]
Return

$CONTROL_FLOW_SETUP
  #4 - Controls Flow setup
  Local Integer WNBDOC_FLO    : WNBDOC_FLO = 0
  Local Integer WNBDOC_FLO_OK : WNBDOC_FLO_OK = 0
  Local Integer WNBDOC_FLO_KO : WNBDOC_FLO_KO = 0
  WNBDOC_FLO = 0
  Filter [ETC] Where [ETC]NUMBATCH = this.NUMBATCH and [ETC]FLOCOD <> "" and [ETC]FLOREL <> "" Order By Key ETC1
  For [ETC]
    Trbegin [ETC]
    If [ETC]FLGEDIBPRCPY = [V]CST_AINFO
      [ETC]FLGVALIDFLO  = func EDIRUN_CSTD.TEST_EDIFLO([ETC]FLOCOD, [ETC]FLOREL)
    Else
      [ETC]FLGVALIDFLO  = [V]CST_AERROR
    Endif
    [ETC]FLGVALIDFLO = [V]CST_AINFO # AIT51
    Rewrite [ETC]
    If !fstat
      Commit
      WNBDOC_FLO    = WNBDOC_FLO + 1
      Case [ETC]FLGVALIDFLO
         When [V]CST_AINFO    : WNBDOC_FLO_OK = WNBDOC_FLO_OK + 1
                                WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 9, [V]CST_AINFO, 6, mess(7,2007,1), WMYLOG)
         When [V]CST_AWARNING : WNBDOC_FLO_KO = WNBDOC_FLO_KO + 1
                                WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 9, [V]CST_AWARNING, 6, mess(9,2007,1), WMYLOG)
         When [V]CST_AERROR   : WNBDOC_FLO_KO = WNBDOC_FLO_KO + 1
                                WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 9, [V]CST_AERROR, 6, mess(9,2007,1), WMYLOG)
      Endcase
    Else
      Rollback
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 9, [V]CST_AERROR, 6, mess(9,2007,1), WMYLOG)
    Endif
  Next
  Filter [ETC]

  this.NBDOC_FLO     = WNBDOC_FLO
  this.NBDOC_FLO_OK  = WNBDOC_FLO_OK
  this.NBDOC_FLO_KO  = WNBDOC_FLO_KO

Return

Funprog TEST_EDICPY(WCPY, WPARCOD, WCATCOD, WFLOCOD, WFLOREL)
Value Char WCPY
Value Char WPARCOD
Value Char WCATCOD
Variable Char WFLOCOD
Variable Char WFLOREL

  Local Integer WOK : WOK = [V]CST_AERROR
  Local Integer WFOUND_FLO : WFOUND_FLO = [V]CST_AERROR
  Local Char WFOUND_FLOCOD(20)
  Local Char WFOUND_FLOREL(5)

  If clalev ([F:ECPX])     = 0 : Local File EDICPYPAR [ECPX]       : Endif
  If clalev ([F:ECPXDFX])   = 0 : Local File EDICPYPARFLO [ECPXDFX]  : Endif
  Link [ECPXDFX] With [ECPX]ECP0 ~= [ECPXDFX]CPY; [ECPXDFX]PARCOD As [MYREQ]
&     Where [ECPXDFX]CATCOD = WCATCOD
&         and [ECPX]PARCOD  = WPARCOD
&         and [ECPX]CPY     = WCPY
  For [MYREQ]
    WFLOCOD = [MYREQ]FLOCOD
    WFLOREL = [MYREQ]FLOREL
    WOK = [V]CST_AINFO
    Break
  Next
  Close File [ECPXDFX]
  Close File [ECPX]

End WOK

#********************************************************************
# Method MET_ISSUE_STACK_CREATE
#********************************************************************
#
#*
#* @param WEDIRUN
#* @param WMYLOG
#* @return WOK
#*!
$MET_ISSUE_STACK_CREATE
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK

  Call ASYNCTRACK(WEDIRUN.ACTX, "(3)", mess(37,2007,1), 30) From ASYRASYNC
  #"Number of documents to process
#  WERR = mess(52,2007,1)-":"-num$(this.NBDOC_FLO_OK)
  WERR = format$("4X","")+format$("60X",mess(52,2007,1))+" : "+num$(this.NBDOC_FLO_OK)
  If this.NBDOC_FLO_OK = 0
#    ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AWARNING)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AWARNING) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AWARNING)
  Else
#    ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AINFO)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
  Endif

  Local File EDITMPDOC [ETC]
  If this.ALLFLO <> 2 #Flow restriction this.FLOCOD+this.FLOREL
    Filter [ETC] Where [ETC]NUMBATCH = this.NUMBATCH and [ETC]FLGVALIDFLO = [V]CST_AINFO and [ETC]FLOCOD = this.FLOCOD and [ETC]FLOREL = this.FLOREL Order By Key ETC1 #WNUMBATCH+CPY+FCY+BPRNUM+BPAADD
    #sort by FLOCOD+MSGCOD
  Else #"No flow restriction"
    Filter [ETC] Where [ETC]NUMBATCH = this.NUMBATCH and [ETC]FLGVALIDFLO = [V]CST_AINFO Order By Key ETC1 #WNUMBATCH+CPY+FCY+BPRNUM+BPAADD
  Endif

  Local Integer WNUMLIN
#  Local Integer WCNTFLODOC
  Local Integer WFLG_DUPLICATE
  Local Char WLEG(20)
  Local Integer WFLG_DUPLICATE_AUTHORIZATION
  Local Integer WFLG_DUPLICATE_CASE_OF_NOT_AUTHORIZED
  Local Integer WSTA
  WSTA = 0
  I = 0
  this.NBDOC_STACK = 0


  #WERR = "Processing document"
  For [ETC]
    If func EDIRUN_CSTD.TEST_DUPLICATE([ETC]DOCID, this.CATTYP) = [V]CST_ATRUE
  #    WLEG = func EDILIBA.GET_CPY_LEG([ETC]CPY)
      WLEG = func EDILIBB.GET_FCY_LEG([ETC]CPY, [ETC]FCY)   ### 114061
      WFLG_DUPLICATE = [V]CST_AYES
      Case func EDICAT_CSTD.GET_DUPLICATE_FLG(this.CATCOD, WLEG)
        When 1 #Authorized
          WFLG_DUPLICATE_AUTHORIZATION = [V]CST_AYES
          WFLG_DUPLICATE_CASE_OF_NOT_AUTHORIZED = 0
        When 2 #Not authorized
          WFLG_DUPLICATE_AUTHORIZATION = [V]CST_ANO
          WFLG_DUPLICATE_CASE_OF_NOT_AUTHORIZED = 1
      Endcase
    Else
      WFLG_DUPLICATE = [V]CST_ANO
      WFLG_DUPLICATE_AUTHORIZATION = [V]CST_AYES #on s'en fiche
      WFLG_DUPLICATE_CASE_OF_NOT_AUTHORIZED = 2 #not a duplicate
    Endif

    WNUMLIN = func EDIRUN_CSTD.GET_EDITRKDOC_NUMLIN([ETC]DOCID, this.CATTYP)
    Local File EDITRKDOC [EDK]
    Trbegin [EDK]
    [EDK]DOCID     = [ETC]DOCID
    [EDK]NUMBATCH  = [ETC]NUMBATCH
    [EDK]NUMLIN    = WNUMLIN
    [EDK]FLOCOD    = [ETC]FLOCOD
    [EDK]FLOREL    = [ETC]FLOREL
    [EDK]DUPLICATE = WFLG_DUPLICATE
    [EDK]DUPLICATEAUT = WFLG_DUPLICATE_AUTHORIZATION
    [EDK]DUPLICATEERR = WFLG_DUPLICATE_CASE_OF_NOT_AUTHORIZED
    [EDK]FLGMUX    = [ETC]FLGMUX
    [EDK]CPY       = [ETC]CPY
    [EDK]FCY       = [ETC]FCY
    [EDK]BPRNUM    = [ETC]BPRNUM
    [EDK]BPAADD    = [ETC]BPAADD
    [EDK]PTCCOD    = [ETC]PTCCOD
    [EDK]CATTYP    = this.CATTYP
    [EDK]NUM       = WEDIRUN.NUM
    [EDK]CATACT    = WEDIRUN.CATACT
    [EDK]CATCOD    = this.CATCOD
    [EDK]RUNDATE   = WEDIRUN.LASRUNDAT
    [EDK]TESTFLG   = WEDIRUN.TESTFLG
    [EDK]TRKSTA    = 1 #Pending
    [EDK]FLGUPD    = 2
    Write [EDK]
    If !fstat
      Commit
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 10, [V]CST_AINFO, 7, [ETC]DOCID, WMYLOG)
      this.NBDOC_STACK = this.NBDOC_STACK + 1
    Elsif fstat = 3 #duplicated key
      Rollback
      WERR = ""
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, [ETC]DOCID, this.CATTYP, 10, [V]CST_AWARNING, 7, [ETC]DOCID, WMYLOG)
      #tester le statut, si erreur on peut le relancer :
      #supprimer la ligne
      #puis recrer
      WSTA = 0
      Local File EDITRKDOC [TMPEDK]
      Read [TMPEDK]EDK0 = [EDK]DOCID; [EDK]CATTYP; WNUMLIN
      If !fstat
        WSTA = [TMPEDK]TRKSTA
      Else
        #erreur enregistrement doublon non trouvé
        WSTA = 0
      Endif

      WERR = ""
      #WERR = "Document status"
      Case WSTA
        When 0 : #error duplicate SAS not found
            WOK = fmet WEDIRUN.MET_LOG_MSG([EDK]NUMBATCH, [ETC]DOCID, [EDK]CATTYP, 10, [V]CST_AWARNING, 8, mess(16,149,1), WMYLOG)  # Unknown   ## 112148
        When 2 : #2 - En cours #error
            WOK = fmet WEDIRUN.MET_LOG_MSG([EDK]NUMBATCH, [ETC]DOCID, [EDK]CATTYP, 10, [V]CST_AWARNING, 8, mess(65,2007,1), WMYLOG) # Document already in progress ## 112148
        When 3 : #3 - Terminé #error
            WOK = fmet WEDIRUN.MET_LOG_MSG([EDK]NUMBATCH, [ETC]DOCID, [EDK]CATTYP, 10, [V]CST_AWARNING, 8, mess(66,2007,1), WMYLOG) # Document already processed ## 112148
            #4 - Erreur #delete
            # and create again
            Delete
            If !fstat
              #tout est supprimé, on peut creer à nouveau
              Trbegin [EDK]
              Write [EDK]
              If !fstat
                Commit
                WNBDOC = WNBDOC + 1
                WOK = fmet WEDIRUN.MET_LOG_MSG([EDK]NUMBATCH, [ETC]DOCID, [EDK]CATTYP, 10, [V]CST_AINFO, 9, [ETC]DOCID, WMYLOG)
              Else
                Rollback
                #error
                WOK = fmet WEDIRUN.MET_LOG_MSG([EDK]NUMBATCH, [ETC]DOCID, [EDK]CATTYP, 10, [V]CST_AERROR, 9, [ETC]DOCID, WMYLOG)
              Endif
            Endif
      Endcase

      LogicClose File [TMPEDK]
    Else
      Rollback
      #WERR = "Processing document"
      WOK = fmet WEDIRUN.MET_LOG_MSG([EDK]NUMBATCH, [ETC]DOCID, [EDK]CATTYP, 10, [V]CST_AERROR, 7, [ETC]DOCID, WMYLOG)
      WRET_VALUE = [V]CST_AERROR
    Endif
    LogicClose File [EDK]
  Next
  Filter [ETC]
  LogicClose File [ETC]
  ARET_VALUE = WRET_VALUE
Return



#********************************************************************
# Method MET_ISSUE_PROCESS
#********************************************************************
#
#* Create a filter flow list from EDITRKDOC and run process by flow
#* @param WEDIRUN
#* @param WMYLOG
#* @return WOK
#*!
$MET_ISSUE_PROCESS

  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WFLOCOD_TAB(20)(1..) #distinct FLOCOD list
  Local Char WFLOREL_TAB(5)(1..)  #distinct FLOREL list
  Local Integer WFLGMUX_TAB(1..)  #FLGMUX flag of each flow

  Local Integer WNBFLOW      : WNBFLOW = 1 #distinct flow counter
  Local Integer WOK, I

  Global Char GININAME(250), GENDNAME(250)
  Global Integer GUSEKEY

  WOK = fmet WMYLOG.APUTLINE("", [V]CST_AINFO)

  If this.NBDOC_STACK > 0
    Local File EDITRKDOC [EDK]
    # get a flow list extracted from the trk table
    Filter [EDK] Where [EDK]NUMBATCH = this.NUMBATCH Order By Key EDK1 #FLOCOD+FLOREL+CPY+FCY+BPRNUM+BPAADD
    For [EDK]
      If WNBFLOW = 1
        WFLOCOD_TAB(WNBFLOW) = [EDK]FLOCOD
        WFLOREL_TAB(WNBFLOW) = [EDK]FLOREL
        WFLGMUX_TAB(WNBFLOW) = [EDK]FLGMUX
        WNBFLOW = WNBFLOW + 1
      Elsif WNBFLOW > 1 #(suivant)
        If WFLOCOD_TAB(WNBFLOW-1) <> [EDK]FLOCOD or WFLOREL_TAB(WNBFLOW-1) <> [EDK]FLOREL
          #on stocke le nouveau flux
          WFLOCOD_TAB(WNBFLOW) = [EDK]FLOCOD
          WFLOREL_TAB(WNBFLOW) = [EDK]FLOREL
          WFLGMUX_TAB(WNBFLOW) = [EDK]FLGMUX
          WNBFLOW = WNBFLOW + 1
        Endif
      Endif
    Next
    Filter [EDK]
    LogicClose File [EDK]
    #for each distinct flow, process
    Local Char WDOCID_TAB(60)(1..)
    Local Char WDOCID_TAB_RESUME(60)(1..)
    Local Integer WNB_DOC_RESUME : WNB_DOC_RESUME = 0
    For I = 1 To maxtab(WFLOCOD_TAB())
      WOK = fmet this.MET_ISSUE_PROCESS_BY_FLOW(WFLOCOD_TAB(I), WFLOREL_TAB(I), WFLGMUX_TAB(I), WDOCID_TAB, WEDIRUN, WMYLOG)
      If WOK = [V]CST_AERROR
        WRET_VALUE = [V]CST_AERROR
      Endif
      #flush log when all is finished
      For J = 1 To maxtab(WDOCID_TAB)
        WNB_DOC_RESUME = WNB_DOC_RESUME + 1
        WDOCID_TAB_RESUME(WNB_DOC_RESUME) = WDOCID_TAB(J)
      Next J
      Raz WDOCID_TAB
    Next I
    WOK = fmet this.MET_ISSUE_LOG_RESUME(WDOCID_TAB_RESUME, WEDIRUN, WMYLOG)

  Else
    #no flow to process
    WRET_VALUE = [V]CST_AERROR
  Endif
  ARET_VALUE = WRET_VALUE #[V]CST_AOK
Return


#********************************************************************
# Method MET_ISSUE_PROCESS_BY_FLOW
#********************************************************************
#
#*
#* @param WFLOCOD
#* @param WFLOREL
#* @param WFLGMUX
#* @param WDOCID_TAB
#* @param WEDIRUN
#* @param WMYLOG
#* @return WOK
#*!
$MET_ISSUE_PROCESS_BY_FLOW
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Integer WOK, I, J
  Local Char WERR(250)
  Local Char WDOCID_TO_PROCESS_TAB(60)(1..)
  Local Char WDOCID_TAB_CUR(60)(1..1)
  Local Integer WFLG_IS_AUTORIZED_TO_PROCESS : WFLG_IS_AUTORIZED_TO_PROCESS = [V]CST_ANO

  this.FLOCOD = WFLOCOD
  this.FLOREL = WFLOREL
  I = 0
  J = 0
  #filter on all docs with the same flow
  Local File EDITRKDOC [EDK]
  Filter [EDK] Where [EDK]NUMBATCH = this.NUMBATCH and [EDK]FLOCOD = this.FLOCOD and [EDK]FLOREL = this.FLOREL Order By Key EDK3
  For [EDK]
    J = J + 1
    WDOCID_TAB(J) = [EDK]DOCID
    Call ASYNCTRACK(WEDIRUN.ACTX, "(4)", mess(59,2007,1)-WDOCID_TAB(J), 40) From ASYRASYNC
    If WEDIRUN.DUPLICATEFLG = [V]CST_AYES
      If [EDK]DUPLICATEAUT = [V]CST_AYES
        WFLG_IS_AUTORIZED_TO_PROCESS = [V]CST_AYES
      Else
        WFLG_IS_AUTORIZED_TO_PROCESS = [V]CST_ANO
      Endif
    Else
      If [EDK]DUPLICATEERR = 2
        WFLG_IS_AUTORIZED_TO_PROCESS = [V]CST_AYES
      Else
        WFLG_IS_AUTORIZED_TO_PROCESS = [V]CST_ANO
      Endif
    Endif

    If WFLG_IS_AUTORIZED_TO_PROCESS = [V]CST_AYES
      Local Instance WMYEDISTO Using C_EDISTO
      WMYEDISTO = NewInstance C_EDISTO AllocGroup null
      WOK = fmet WMYEDISTO.AINIT()
      WMYEDISTO.NUMBATCH = [EDK]NUMBATCH
      WMYEDISTO.KEYDOC   = [EDK]DOCID
      WMYEDISTO.FLOCOD   = [EDK]FLOCOD
      WMYEDISTO.FLOREL   = [EDK]FLOREL
      WMYEDISTO.PTCCOD   = [EDK]PTCCOD
      WMYEDISTO.TESTFLG  = WEDIRUN.TESTFLG #[EDK]TESTFLG

      WOK = fmet WMYEDISTO.AINSERT()
      I = I + 1
      If WOK = [V]CST_AOK
        WOK = fmet WEDIRUN.MET_LOG_MSG([EDK]NUMBATCH, [EDK]DOCID, [EDK]CATTYP, 11, [V]CST_AINFO, 10, mess(7,2007,1), WMYLOG)
        this.NBSAS       = this.NBSAS + 1
        WDOCID_TO_PROCESS_TAB(I)    = [EDK]DOCID
        #"Processing document
        WMYEDISTO.STA = 2 #2-In progress
        WOK = fmet WMYEDISTO.AUPDATE()
        #WERR = "SAS update status"
        If WOK = [V]CST_AOK
          WOK = fmet WEDIRUN.MET_LOG_MSG([EDK]NUMBATCH, [EDK]DOCID, [EDK]CATTYP, 12, [V]CST_AINFO, 11, mess(25,2007,1), WMYLOG)
          Call ADDDIAGNOSE(WEDIRUN.ACTX,mess(59,2007,1)-[EDK]DOCID,[V]CST_AINFO) From ASYRASYNC
          If [EDK]FLGMUX = [V]CST_ANO
            WFLGMUX = [V]CST_ANO
            #Run process for the current SAS only
            WDOCID_TAB_CUR(1) = WDOCID_TO_PROCESS_TAB(I)
            WRET_VALUE = fmet this.MET_ISSUE_GENERATE_DOC(WDOCID_TAB_CUR, WEDIRUN, WMYLOG)
          Endif
        Else
          #error
          WOK = fmet WEDIRUN.MET_LOG_MSG([EDK]NUMBATCH, [EDK]DOCID, [EDK]CATTYP, 12, [V]CST_AERROR, 11, "", WMYLOG)
          Call ADDDIAGNOSE(WEDIRUN.ACTX,mess(59,2007,1)-[EDK]DOCID,[V]CST_AERROR) From ASYRASYNC
          WRET_VALUE = [V]CST_AERROR
        Endif
      Else
        #error
        WOK = fmet WEDIRUN.MET_LOG_MSG([EDK]NUMBATCH, [EDK]DOCID, [EDK]CATTYP, 11, [V]CST_AERROR, 10, mess(9,2007,1), WMYLOG)
        Call ADDDIAGNOSE(WEDIRUN.ACTX,mess(59,2007,1)-[EDK]DOCID,[V]CST_AERROR) From ASYRASYNC
        WRET_VALUE = [V]CST_AERROR
      Endif
      FreeGroup WMYEDISTO : WMYEDISTO = null
    Else #WFLG_IS_AUTORIZED_TO_PROCESS = [V]CST_ANO
      Case [EDK]DUPLICATEERR
        When 0 : WOK = fmet WEDIRUN.MET_LOG_MSG([EDK]NUMBATCH, [EDK]DOCID, [EDK]CATTYP, 11, [V]CST_AERROR, 10, mess(29,2017,1), WMYLOG)
                 Delete #PO doesn't want to keep this information in TRK
        When 1 : WOK = fmet WEDIRUN.MET_LOG_MSG([EDK]NUMBATCH, [EDK]DOCID, [EDK]CATTYP, 11, [V]CST_AERROR, 10, mess(30,2017,1), WMYLOG)
                 Delete #PO doesn't want to keep this information in TRK
        When 2 : #not a duplicate
      Endcase
    Endif
  Next #next doc corresponding in the flow sub list
  Filter [EDK]
  LogicClose File [EDK]

  If WFLGMUX = [V]CST_AYES
    #Run process for all SAS
    WRET_VALUE = fmet this.MET_ISSUE_GENERATE_DOC(WDOCID_TO_PROCESS_TAB, WEDIRUN, WMYLOG)
  Endif
  ARET_VALUE = WRET_VALUE
Return


#********************************************************************
# Method MET_ISSUE_GENERATE_DOC
#********************************************************************
#
#*
#* @param WDOCID_TAB
#* @param WEDIRUN
#* @param WMYLOG
#* @return WOK
#*!
$MET_ISSUE_GENERATE_DOC
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Integer WOK, I, J, K, WPOS
  Local Integer WFLG_SET_PARAM : WFLG_SET_PARAM = [V]CST_AFALSE
  Local Clbfile WPROTOTYPE_JSON         #to send the JSON prototype of the instance
  Local Char WERR(250)
  Local Char WINS_UUID_TAB(36)(1..)     #to send the UUID list of JSON OF repcod1
  Local Integer WFLG_ERROR_ON_PROTO : WFLG_ERROR_ON_PROTO = [V]CST_AOK
  Call DELETELINES(this, "EINS") From EDILIBA
  Local Integer WLINENUM : WLINENUM = 0
  Local Char WSEPDEC(1): WSEPDEC="."  # 114721 Decimal separator in generated file

  #MANAGEMENT OF QUERY TYPE
  # for ALL document, read SAS, instanciate and save the uuid in SAS, update SAS
  # for the 1st one, generate the prototype which is common to all SAS
  Local Instance WMYEDISTO Using C_EDISTO
  WMYEDISTO = NewInstance C_EDISTO AllocGroup null
  K = 1

  For I = 1 To maxtab(WDOCID_TAB)
    For J = 1 To maxtab(this.EMSG)
#     #JUCON Issue sequential file finishs in progress if criteria is wrong
#     If this.EMSG(J)<>null and find(this.EMSG(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and this.EMSG(J).MSGTYP = 1 #query, only 1 line
      If this.EMSG(J).MSGTYP = 1 #query, only 1 line    ##JUCON Issue sequential file finishs in progress if criteria is wrong
        WLINENUM = WLINENUM + 1
        WPOS = fmet this.ADDLINE("EINS", [V]CST_ALASTPOS)
        this.EINS(WPOS).MSGCOD    = this.EMSG(J).MSGCOD
        this.EINS(WPOS).MSGREL    = this.EMSG(J).MSGREL
        this.EINS(WPOS).MSGFILNOR = this.EMSG(J).MSGFILNOR
        this.EINS(WPOS).MSGTYP    = this.EMSG(J).MSGTYP = 1 #query, only 1 line
        this.EINS(WPOS).DOCID     = WDOCID_TAB(I)
        this.EINS(WPOS).MSGFOR    = this.EMSG(J).MSGFOR   ## 112148
# issue 114721 Decimal separator in generated file
        If this.EINS(WPOS).MSGFOR=1  ## 112148
          Local File EDISEQFIL [ESF]
          Read [ESF]ESF0=this.EINS(WPOS).MSGCOD;this.EINS(WPOS).MSGREL;this.EINS(WPOS).MSGFILNOR
          If fstat=[V]CST_AOK
            If [F:ESF]SEPDEC<>"": WSEPDEC=[F:ESF]SEPDEC: Endif
          Endif
          LogicClose File [ESF]  #### SAM 121735 (JUCON 27/02/2017)
        Endif       ## 112148
#/ 114721
        #WERR = "SAS accessibility"
        WOK = fmet WMYEDISTO.AREAD(this.NUMBATCH, this.EINS(WPOS).DOCID)
        If WOK = [V]CST_AOK
          WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(WPOS).DOCID, this.CATTYP, 13, [V]CST_AINFO, 12, mess(7,2007,1), WMYLOG)
          #WERR = "Instantiation of SAS representation"
          WINFO = ""
          WINFO1 = ""
# issue 114721 Decimal separator in generated file
          #WOK = fmet WMYEDISTO.MET_INSTANCIATE_REP(WLINENUM, WINFO, WINFO1, WEDIRUN.DUPLICATEFLG, WEDIRUN.TESTFLG)
          WOK = fmet WMYEDISTO.MET_INSTANCIATE_REP(WLINENUM, WINFO, WINFO1, WEDIRUN.DUPLICATEFLG, WEDIRUN.TESTFLG, WSEPDEC, this)
#/ 114721
          If WOK = [V]CST_AOK
            WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(WPOS).DOCID, this.CATTYP, 14, [V]CST_AINFO, 13, mess(7,2007,1), WMYLOG)
            this.NBINS_OK = this.NBINS_OK + 1

            #"SAS update UUID of instance"
            WOK = fmet WMYEDISTO.AUPDATE()
            If WOK = [V]CST_AOK
              WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(WPOS).DOCID, this.CATTYP, 15, [V]CST_AINFO, 14, WINFO1, WMYLOG)
              #on prepare les parametres avec ce SAS qui est correct puis on continue pour le reste de la list
              If WFLG_SET_PARAM = [V]CST_AFALSE
                this.EMSG(J).REPCOD = func EDISTO_CSTD.GET_DOCCLASS("REPCOD"+num$(1), WMYEDISTO) #in V1, only 1 line !
                Local Instance WMYREP Using ="R_"+this.EMSG(J).REPCOD
                WMYREP = NewInstance With ="R_"+this.EMSG(J).REPCOD
                this.EINS(WPOS).REPCOD    = this.EMSG(J).REPCOD
                WOK = func ASYREIP.EXPORT_PROTOTYPE(WMYREP,[V]CST_AFAC_DETAILS,WPROTOTYPE_JSON,WERR)
                If WOK <> [V]CST_AOK
                  #"Generating prototype : failed"
                  WFLG_ERROR_ON_PROTO = [V]CST_AERROR
                  WERR = mess(36,2007,1)-":"-mess(9,2007,1)-"["+WERR+"]"
#                  ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AWARNING)
                  Call ADDDIAGNOSE(WEDIRUN.ACTX,WERR,[V]CST_AWARNING) From ASYRASYNC
                  WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AWARNING)
                  WRET_VALUE = [V]CST_AERROR
                Endif
#                FreeInstance WMYREP : WMYREP = null
                FreeGroup WMYREP : WMYREP = null
                WFLG_SET_PARAM = [V]CST_ATRUE
               Endif
               If WFLG_ERROR_ON_PROTO = [V]CST_AOK
                 WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(WPOS).DOCID, this.CATTYP, 16, [V]CST_AINFO, 31, mess(7,2007,1), WMYLOG)
               Else
                 WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(WPOS).DOCID, this.CATTYP, 16, [V]CST_AERROR, 31, mess(9,2007,1), WMYLOG)
                 WRET_VALUE = [V]CST_AERROR
               Endif
            Else
              #error
              WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(WPOS).DOCID, this.CATTYP, 15, [V]CST_AERROR, 14, WINFO1, WMYLOG)
              WRET_VALUE = [V]CST_AERROR
            Endif
          Else #error MET_INSTANCIATE_REP failed
            WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(WPOS).DOCID, this.CATTYP, 14, [V]CST_AERROR, 13, WINFO1, WMYLOG)
            this.NBINS_KO = this.NBINS_KO + 1
            WRET_VALUE = [V]CST_AERROR
          Endif
        Else #error AREAD failed
          WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, this.EINS(WPOS).DOCID, this.CATTYP, 13, [V]CST_AERROR, 12, mess(9,2007,1), WMYLOG)
          WRET_VALUE = [V]CST_AERROR
        Endif

        #SAS & TRK update status = 4 - Error
        If WRET_VALUE = [V]CST_AERROR
          WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, this.EINS(WPOS).DOCID, this.CATTYP, 19, 4, WMYLOG)
        Endif

        this.EINS(WPOS).INS_UUID = toUuid(func EDISTO_CSTD.GET_UUID("REPCOD"+num$(1), WMYEDISTO))
        WINS_UUID_TAB(I) = num$(this.EINS(WPOS).INS_UUID)
      Endif
    Next J
    WLINENUM = 0
  Next I
  FreeGroup WMYEDISTO : WMYEDISTO = null

  #generate EDI files from all SAS rep using the same prototype
  If WFLG_SET_PARAM = [V]CST_ATRUE
    Local Char WMERGEKEY_TAB(50)(1..)
    Local Char WRET_FILENAMES_TAB(250)(1..)
    Local Char WRET_FILECODES_TAB(30)(1..)

    #trier dans l'ordre du merge key le WDOCID_TAB et à chaque rupture faire un generate files
    K = 0
    Local Integer WNBDOC : WNBDOC = 0
    Local Integer WNBFILE : WNBFILE = 0


    Call DELETELINES(this, "EMUX") From EDILIBA
    #Ini X3-201432
#    WOK = fmet this.MET_ISSUE_GET_FILENAMES(WMERGEKEY_TAB, WRET_FILENAMES_TAB, WRET_FILECODES_TAB)
    Local Integer DIMDOC: DIMDOC=maxtab(this.EINS)
    If maxtab(this.EINS)=1 or maxtab(WMERGEKEY_TAB) > 0 or this.EINS(DIMDOC).MSGFOR = 1
      WOK = fmet this.MET_ISSUE_GET_FILENAMES(WMERGEKEY_TAB, WRET_FILENAMES_TAB, WRET_FILECODES_TAB)
    Elsif GUSEKEY=1
      WRET_FILENAMES_TAB(1)=GININAME+this.EINS(DIMDOC).DOCID+GENDNAME
    Endif
   #End X3-201432

    If maxtab(WMERGEKEY_TAB) > 0 #ie si le paramterage du seqfil pour ces DOCID est merged
      Local Char WMERGED_DOCID_TAB(50)(1..)
      Local Char WMERGED_INS_UUID_TAB(36)(1..)
      Local Char WMERGED_RET_FILENAMES_TAB(250)(1..)
      Local Char WMERGED_RET_FILECODES_TAB(30)(1..)
      Local Integer WFLG_NAMES_SET : WFLG_NAMES_SET = [V]CST_ANO
      For I = 1 To maxtab(WMERGEKEY_TAB)
        WNBDOC = 0
        WNBFILE = 0
        For J = 1 To maxtab(this.EINS)
          ##JUCON Issue sequential file finishs in progress if criteria is wrong
#          If this.EINS(J)<>null and find(this.EINS(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and this.EINS(J).MSGTYP = 1 #query, only 1 line
          If this.EINS(J).MSGTYP = 1 #query, only 1 line ##JUCON Issue sequential file finishs in progress if criteria is wrong
            If this.EINS(J).MERGEKEY = WMERGEKEY_TAB(I)
              WNBDOC = WNBDOC + 1
              WMERGED_DOCID_TAB(WNBDOC) = this.EINS(J).DOCID
              WMERGED_INS_UUID_TAB(WNBDOC) = num$(this.EINS(J).INS_UUID)
              If WFLG_NAMES_SET = [V]CST_ANO
                For K = 1 To maxtab(this.EMUX)
#                  If this.EMUX(K)<>null and find(this.EMUX(K).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0  #jcc
                    If this.EMUX(K).MERGEKEY = WMERGEKEY_TAB(I)
                      WNBFILE = WNBFILE + 1
                      WMERGED_RET_FILENAMES_TAB(WNBFILE) = this.EMUX(K).MSG_FILENAME
                      WMERGED_RET_FILECODES_TAB(WNBFILE) = this.EMUX(K).MSG_FILECODE
                    Endif
#                  Endif        #jcc
                Next K
                WFLG_NAMES_SET = [V]CST_AYES
              Endif
            Endif
          Endif
        Next J
        #generate EDI files for each msg of the flow
        For J = 1 To maxtab(this.EMSG) #only 1 in V1
          ##JUCON Issue sequential file finishs in progress if criteria is wrong
#          If this.EMSG(J)<>null and find(this.EMSG(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and this.EMSG(J).MSGTYP = 1 #query, only 1 line
          If  this.EMSG(J).MSGTYP = 1 #query, only 1 line  ##JUCON Issue sequential file finishs in progress if criteria is wrong
            WOK = fmet this.MET_ISSUE_GENERATE_FILES(J, WMERGED_RET_FILENAMES_TAB, WMERGED_RET_FILECODES_TAB, WMERGED_DOCID_TAB, WMERGED_INS_UUID_TAB, WPROTOTYPE_JSON, WEDIRUN, WMYLOG)
            If WOK = [V]CST_AERROR
              WRET_VALUE = [V]CST_AERROR
            Endif
          Endif
        Next J
        Raz WMERGED_RET_FILENAMES_TAB()
        Raz WMERGED_RET_FILECODES_TAB()
        Raz WMERGED_DOCID_TAB()
        Raz WMERGED_INS_UUID_TAB()

        WFLG_NAMES_SET = [V]CST_ANO
      Next I
    Else
      For J = 1 To maxtab(this.EMSG) #only 1 in V1
  #     #JUCON Issue sequential file finishs in progress if criteria is wrong
  #     If this.EMSG(J)<>null and find(this.EMSG(J).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and this.EMSG(J).MSGTYP = 1 #query, only 1 line
        If this.EMSG(J).MSGTYP = 1 #query, only 1 line    ##JUCON Issue sequential file finishs in progress if criteria is wrong
          WOK = fmet this.MET_ISSUE_GENERATE_FILES(J, WRET_FILENAMES_TAB, WRET_FILECODES_TAB, WDOCID_TAB, WINS_UUID_TAB, WPROTOTYPE_JSON, WEDIRUN, WMYLOG)
          If WOK = [V]CST_AERROR
            WRET_VALUE = [V]CST_AERROR
          Endif
        Endif
      Next J
    Endif

    # Ini X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file
    If WRET_VALUE<>[V]CST_AERROR
      Local Char WERR(250)
      Local File EDIPTC [EPT]
      Read [EPT]EPT0=this.PTCCOD
      If fstat=[V]CST_AOK
        If [F:EPT]PTCTYP<>1: WOK=1: Endif
      Endif
      LogicClose File [EPT]
      If WOK=0
        If WEDIRUN.TESTFLG=2
          WMESS=mess(213,2006,1) #"Email protocol is not managed in test mode "
          Call ADDDIAGNOSE(WEDIRUN.ACTX,WMESS,[V]CST_AINFO) From ASYRASYNC
          WRET_VALUE = [V]CST_AOK
        Else
          ##### Check to send attachments
          Local Integer WATTXML, XMLSGN, PDFSGN,WATTPDF, WATT, WNBATT, WNBFILES, WPOS, I:     WNBFILES=maxtab(WRET_FILENAMES_TAB())
          Local Char ATTXMLNAM(250)(1..WNBFILES), ATTPDFNAM(250), ATTFIXNAM(250)(1..3)
          Local Char ATTXMLVOL(250)(1..WNBFILES), ATTPDFVOL(250), ATTFIXVOL(250)(1..3)

          Call ATTACHMENT(WEDIRUN.FLOCOD,WEDIRUN.FLOREL,WATTXML,ATTPDFNAM, ATTPDFVOL,ATTFIXNAM,ATTFIXVOL,WATT,XMLSGN,WATTPDF) From EDILIBPDF

          If  WATTXML=0
            For I=1 To WNBFILES
              ATTXMLNAM(I)=WRET_FILENAMES_TAB(I)
            Next
          Endif
          If WATT>0
            If ATTPDFNAM="" and WATTPDF=1
              ATTPDFNAM=WDOCID_TAB+".pdf"
            Endif
            If  WATTXML=0:    WATT=WATT+WNBFILES: Endif
            # Read protocol and send mail if not errors
          Endif

          WOK=func EDILIBPDF.PROTOCOL(this.PTCCOD,ATTXMLNAM,ATTPDFNAM,ATTPDFVOL,ATTFIXNAM,ATTFIXVOL,WATT,XMLSGN,WATTXML,WATTPDF,WERR)

          If WOK<>100 # X3-205443 EDI: Send XML by mail without attachment (JUCON 2020-07-07)
            If WOK=[V]CST_AOK
              WERR=mess(214,2006,1)#"Mail succesfully send"
              WRET_VALUE = [V]CST_AOK
            Else
              WERR+="."-mess(215,2006,1)#"Mail unsuccesfully send"
              WRET_VALUE = [V]CST_AINFO
              #error in email
            Endif
            Call ADDDIAGNOSE(WEDIRUN.ACTX,WERR,[V]CST_AINFO) From ASYRASYNC
            WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
          Endif
        Endif
      Endif
     # End X3-68869_Sending_of_attachments_linked_to_the_EDI_xml_file
    Endif

  Endif

  WPROTOTYPE_JSON = ""
  ARET_VALUE = WRET_VALUE #[V]CST_AOK
Return




#********************************************************************
# Method MET_ISSUE_GET_FILENAMES
#********************************************************************
#
#* @param WMERGEKEY_TAB
#* @param WRET_FILENAMES_TAB
#* @param WRET_FILECODES_TAB
#* @return WOK
#*!
$MET_ISSUE_GET_FILENAMES
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Integer WCOMTYP_TAB(1..)
  Local Char WCOMVAL_TAB(20)(1..)
  Local Char WSTR(250), WTOTSTR(250) # X3-124490
  Local Integer NBK : NBK = 0 #nb of distinct merge key
  Local Integer WPOS
  Local Integer I, J, WOK

  Local Integer WNB: WNB=maxtab(this.EINS)
  Local Integer LKEY #X3-201432

  #determination of filenames
  For I = 1 To maxtab(this.EINS)
#  For I = WNB To maxtab(this.EINS)
#   JUCON Issue sequential file finishs in progress if criteria is wrong
#    If this.EINS(I)<>null and find(this.EINS(I).ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0 and this.EINS(I).MSGTYP = 1 #query, only 1 line
    If this.EINS(I).MSGTYP = 1 #query, only 1 line
      If this.EINS(I).MSGFOR = 1  ## 112148 Sequential file type
        If I=WNB  # X3-97369 performance JUCON 12/07/2018
          Local Instance WMYEDISEQFIL Using C_EDISEQFIL
          WMYEDISEQFIL = NewInstance C_EDISEQFIL AllocGroup null
          WOK = fmet WMYEDISEQFIL.AREAD(this.EINS(I).MSGCOD, this.EINS(I).MSGREL, this.EINS(I).MSGFILNOR)
          If WOK = [V]CST_AOK
            For J = 1 To maxtab(WMYEDISEQFIL.ESFF)
              WRET_FILENAMES_TAB(J) = ""
              WRET_FILECODES_TAB(J) = WMYEDISEQFIL.ESFF(J).FILCOD
              For K = 1 To maxtab(WMYEDISEQFIL.ESFN)
                WCOMTYP_TAB(K) = WMYEDISEQFIL.ESFN(K).COMTYP
                WCOMVAL_TAB(K) = WMYEDISEQFIL.ESFN(K).COMVAL #on rÃƒÂ©cupÃƒÂ¨re l'alias et on va rechercher la propriÃƒÂ©tÃƒÂ© liÃƒÂ©e ÃƒÂ  l'alias
                If WCOMVAL_TAB(K) <> ""
                  Local File ASHWEXPPRO [ASWR]
                  Read [ASWR]ASWR0 = WMYEDISEQFIL.REPCOD;WCOMVAL_TAB(K) #COMVAL doit ÃƒÂªtre ALIAS
                  If !fstat
                    WCOMVAL_TAB(K) = [ASWR]CODPRO
                  Endif
                  LogicClose File [ASWR]
                Endif
                Case WCOMTYP_TAB(K)
                  When 1 : #evalue File name
                    WSTR = WMYEDISEQFIL.ESFF(J).FILNAM
                  When 2 : #evalue Key
                    WSTR = this.EINS(I).DOCID
                  When 3 : #evalue Merge key
                    Local Instance WMYEDISTO Using C_EDISTO
                    WMYEDISTO = NewInstance C_EDISTO AllocGroup null
                    WOK = fmet WMYEDISTO.AREAD(this.NUMBATCH, this.EINS(I).DOCID)
                    If WOK = [V]CST_AOK
                      WOK = fmet WMYEDISTO.MET_INS_GET_VALUE(WCOMVAL_TAB(K), WSTR)
                      this.EINS(I).MERGEKEY = WSTR
                    Else
                      #ERR
                    Endif
                    FreeGroup WMYEDISTO : WMYEDISTO = null
                  When 4 : #evalue Date same as BatchNumber date EDI-141128-133914988
                  #local menu 2015
                    Local Char WMY_YEAR(4)
                    Local Char WMY_MONTH(2)
                    Local Char WMY_DAY(2)
                    WMY_YEAR  = "20"+mid$(this.NUMBATCH, 5, 2) #14 --> "2014"
                    WMY_MONTH = mid$(this.NUMBATCH, 7, 2)      #11
                    WMY_DAY   = mid$(this.NUMBATCH, 9, 2)      #28
                    Case val(WCOMVAL_TAB(K)) #111188
                      When 1       : WSTR = WMY_YEAR + WMY_MONTH + WMY_DAY
                      When 2       : WSTR = right$(WMY_YEAR,2) + WMY_MONTH + WMY_DAY
                      When 3       : WSTR = WMY_DAY + WMY_MONTH + WMY_YEAR
                      When 4       : WSTR = WMY_DAY + WMY_MONTH + right$(WMY_YEAR,2)
                      When 5       : WSTR = WMY_YEAR + "-" + WMY_MONTH + "-" + WMY_DAY
                      When 6       : WSTR = right$(WMY_YEAR,2) + "-" + WMY_MONTH + "-" + WMY_DAY
                      When 7       : WSTR = WMY_DAY + "-" + WMY_MONTH + "-" + WMY_YEAR
                      When 8       : WSTR = WMY_DAY + "-" + WMY_MONTH + "-" + right$(WMY_YEAR,2)
                      When 9       : WSTR = WMY_MONTH + "-" + WMY_DAY + "-" + WMY_YEAR
                      When 10      : WSTR = WMY_MONTH + "-" + WMY_DAY + "-" + right$(WMY_YEAR,2)
                      When 11      : WSTR = WMY_MONTH + "-" + WMY_DAY + "-" + WMY_YEAR
                      When 12      : WSTR = WMY_MONTH + "-" + WMY_DAY + "-" + right$(WMY_YEAR,2)
                      When Default : WSTR = WMY_YEAR + WMY_MONTH + WMY_DAY
                    Endcase
                  When 5 : #evalue Time
                    #local menu 2016
                    Local Char WMY_HOUR(2)
                    Local Char WMY_MINUTE(2)
                    Local Char WMY_SEC(2)
                    Local Char WMY_MILSEC(3)
                    WMY_HOUR   = mid$(this.NUMBATCH, 12, 2) #13
                    WMY_MINUTE = mid$(this.NUMBATCH, 14, 2) #39
                    WMY_SEC    = mid$(this.NUMBATCH, 16, 2) #14
                    WMY_MILSEC = mid$(this.NUMBATCH, 18, 3) #988
                    Case val(WCOMVAL_TAB(K)) #111188
                      When 1       : WSTR = WMY_HOUR + WMY_MINUTE
                      When 2       : WSTR = WMY_HOUR + WMY_MINUTE + WMY_SEC
                      When 3       : WSTR = WMY_HOUR + "-" + WMY_MINUTE
                      When 4       : WSTR = WMY_HOUR + "-" + WMY_MINUTE + "-" + WMY_SEC
                      When Default : WSTR = WMY_HOUR + WMY_MINUTE + WMY_SEC
                    Endcase
                  When 6 : #evalue Constant
                    WSTR = WCOMVAL_TAB(K)
                  When 7 : #evalue Batch number
                    WSTR = this.NUMBATCH
                  When 8 : #evalue Extension
                    WSTR = "." + WCOMVAL_TAB(K)
                Endcase
                WRET_FILENAMES_TAB(J) = WRET_FILENAMES_TAB(J) + WSTR
                If K>1 and J=1:   WTOTSTR+=WSTR : Endif # X3-124490
                # ini X3-97369 performance JUCON 12/07/2018
                If WCOMTYP_TAB>2  # X3-124490
                  Local Integer WSEQ
                  WSEQ = fmet this.ADDLINE('ECOM',[V]CST_ALASTPOS)
                  this.ECOM(WSEQ).COMTYP=WCOMTYP_TAB(K)
                  this.ECOM(WSEQ).COMVAL=WCOMVAL_TAB(K)
                  this.ECOM(WSEQ).COMSTR=WSTR
                Endif
               # end X3-97369 performance JUCON 12/07/2018
              Next K
            Next J
          Else
            #err
            WRET_VALUE = [V]CST_AERROR
          Endif
          FreeGroup WMYEDISEQFIL : WMYEDISEQFIL = null
        Else   # ini X3-97369 performance JUCON 12/07/2018
          If WCOMTYP_TAB=2  # X3-124490
            For J=1 To maxtab(WRET_FILENAMES_TAB)
               WRET_FILENAMES_TAB(J)=""
               WRET_FILENAMES_TAB(J) = this.EINS(I).DOCID+WTOTSTR
            Next
          Elsif WCOMTYP_TAB=3
            For J=1 To maxtab(this.ECOM)
              WRET_FILENAMES_TAB(J)=""
              this.EINS(I).MERGEKEY=  this.ECOM(J).COMSTR
              WRET_FILENAMES_TAB(J) = WRET_FILENAMES_TAB(J) + this.ECOM(J).COMSTR
             Next
          Endif
        Endif   # end X3-97369 performance JUCON 12/07/2018
      Else      ## 112148 XML file type
        If I=WNB  # X3-97369 performance JUCON 12/07/2018
          Local Instance WMYEDIXMLFIL Using C_EDIXMLFIL
          WMYEDIXMLFIL = NewInstance C_EDIXMLFIL AllocGroup null
          WOK = fmet WMYEDIXMLFIL.AREAD(this.EINS(I).MSGCOD, this.EINS(I).MSGREL, this.EINS(I).MSGFILNOR)
          If WOK = [V]CST_AOK
            For J = 1 To maxtab(WMYEDIXMLFIL.EXFF)
              WRET_FILENAMES_TAB(J) = ""
              WRET_FILECODES_TAB(J) = ""
              #Ini X3-201432
              LKEY=maxtab(WMYEDIXMLFIL.EXFN)
              WNB=LKEY
              #End X3-201432
              For K = 1 To maxtab(WMYEDIXMLFIL.EXFN)
                WCOMTYP_TAB(K) = WMYEDIXMLFIL.EXFN(K).COMTYP
                WCOMVAL_TAB(K) = WMYEDIXMLFIL.EXFN(K).COMVAL # Recovering the property linked to the ALIAS
                If WCOMVAL_TAB(K) <> ""
                  Local File ASHWEXPPRO [ASWR]
                  Read [ASWR]ASWR0 = WMYEDIXMLFIL.REPCOD;WCOMVAL_TAB(K) #COMVAL must be ALIAS
                  If !fstat
                    WCOMVAL_TAB(K) = [ASWR]CODPRO
                  Endif
                  LogicClose File [ASWR]
                Endif
                Case WCOMTYP_TAB(K)
                  When 1 : #evalue File name
                    WSTR = WMYEDIXMLFIL.EXFF(J).FILNAM
                  When 2 : #evalue Key
                    WSTR = this.EINS(I).DOCID
                  When 3 : #evalue Merge key
                    Local Instance WMYEDISTO Using C_EDISTO
                    WMYEDISTO = NewInstance C_EDISTO AllocGroup null
                    WOK = fmet WMYEDISTO.AREAD(this.NUMBATCH, this.EINS(I).DOCID)
                    If WOK = [V]CST_AOK
                      WOK = fmet WMYEDISTO.MET_INS_GET_VALUE(WCOMVAL_TAB(K), WSTR)
                      this.EINS(I).MERGEKEY = WSTR
                    Else
                      #ERR
                    Endif
                    FreeGroup WMYEDISTO : WMYEDISTO = null
                  When 4 : #evalue Date same as BatchNumber date EDI-141128-133914988
                  #local menu 2015
                    Local Char WMY_YEAR(4)
                    Local Char WMY_MONTH(2)
                    Local Char WMY_DAY(2)
                    WMY_YEAR  = "20"+mid$(this.NUMBATCH, 5, 2) #14 --> "2014"
                    WMY_MONTH = mid$(this.NUMBATCH, 7, 2)      #11
                    WMY_DAY   = mid$(this.NUMBATCH, 9, 2)      #28
                    Case val(WCOMVAL_TAB(K)) #111188
                      When 1       : WSTR = WMY_YEAR + WMY_MONTH + WMY_DAY
                      When 2       : WSTR = right$(WMY_YEAR,2) + WMY_MONTH + WMY_DAY
                      When 3       : WSTR = WMY_DAY + WMY_MONTH + WMY_YEAR
                      When 4       : WSTR = WMY_DAY + WMY_MONTH + right$(WMY_YEAR,2)
                      When 5       : WSTR = WMY_YEAR + "-" + WMY_MONTH + "-" + WMY_DAY
                      When 6       : WSTR = right$(WMY_YEAR,2) + "-" + WMY_MONTH + "-" + WMY_DAY
                      When 7       : WSTR = WMY_DAY + "-" + WMY_MONTH + "-" + WMY_YEAR
                      When 8       : WSTR = WMY_DAY + "-" + WMY_MONTH + "-" + right$(WMY_YEAR,2)
                      When 9       : WSTR = WMY_MONTH + "-" + WMY_DAY + "-" + WMY_YEAR
                      When 10      : WSTR = WMY_MONTH + "-" + WMY_DAY + "-" + right$(WMY_YEAR,2)
                      When 11      : WSTR = WMY_MONTH + "-" + WMY_DAY + "-" + WMY_YEAR
                      When 12      : WSTR = WMY_MONTH + "-" + WMY_DAY + "-" + right$(WMY_YEAR,2)
                      When Default : WSTR = WMY_YEAR + WMY_MONTH + WMY_DAY
                    Endcase
                  When 5 : #evalue Time
                  #local menu 2016
                    Local Char WMY_HOUR(2)
                    Local Char WMY_MINUTE(2)
                    Local Char WMY_SEC(2)
                    Local Char WMY_MILSEC(3)
                    WMY_HOUR   = mid$(this.NUMBATCH, 12, 2) #13
                    WMY_MINUTE = mid$(this.NUMBATCH, 14, 2) #39
                    WMY_SEC    = mid$(this.NUMBATCH, 16, 2) #14
                    WMY_MILSEC = mid$(this.NUMBATCH, 18, 3) #988
                    Case val(WCOMVAL_TAB(K)) #111188
                      When 1       : WSTR = WMY_HOUR + WMY_MINUTE
                      When 2       : WSTR = WMY_HOUR + WMY_MINUTE + WMY_SEC
                      When 3       : WSTR = WMY_HOUR + "-" + WMY_MINUTE
                      When 4       : WSTR = WMY_HOUR + "-" + WMY_MINUTE + "-" + WMY_SEC
                      When Default : WSTR = WMY_HOUR + WMY_MINUTE + WMY_SEC
                    Endcase
                  When 6 : #evalue Constant
                    WSTR = WCOMVAL_TAB(K)
                  When 7 : #evalue Batch number
                    WSTR = this.NUMBATCH
                  When 8 : #evalue Extension
                    WSTR = "." + WCOMVAL_TAB(K)
                Endcase
                WRET_FILENAMES_TAB(J) = WRET_FILENAMES_TAB(J) + WSTR
                If K>1 and J=1:   WTOTSTR+=WSTR : Endif # X3-124490
                #Ini X3-201432
                If WCOMTYP_TAB(K)=2: LKEY=K: GUSEKEY=1: Endif
                If K<LKEY: GININAME+=WSTR: Endif
                If K>LKEY: GENDNAME+=WSTR: Endif
                #End X3-201432
                # ini X3-97369 performance JUCON 12/07/2018
                If WCOMTYP_TAB(K)>2  #JCC
                  Local Integer WSEQ
                  WSEQ = fmet this.ADDLINE('ECOM',[V]CST_ALASTPOS)
                  this.ECOM(WSEQ).COMTYP=WCOMTYP_TAB(K)
                  this.ECOM(WSEQ).COMVAL=WCOMVAL_TAB(K)
                  this.ECOM(WSEQ).COMSTR=WSTR
                Endif
                # end X3-97369 performance JUCON 12/07/2018
              Next K
            Next J
          Else
            #err
            WRET_VALUE = [V]CST_AERROR
          Endif
          FreeGroup WMYEDIXMLFIL : WMYEDIXMLFIL = null
        Endif   # end X3-97369 performance JUCON 12/07/2018
      Endif
    Endif

    Call ADD_MERGE_KEY(this, WMERGEKEY_TAB, this.EINS(I).MERGEKEY, WRET_FILECODES_TAB, WRET_FILENAMES_TAB)
  Next I

  ARET_VALUE = WRET_VALUE
Return



#********************************************************************
# Method MET_ISSUE_GENERATE_FILES
#********************************************************************
#
#* @param WMSG
#* @param WRET_FILENAMES_TAB
#* @param WRET_FILECODES_TAB
#* @param WDOCID_TAB
#* @param WINS_UUID_TAB
#* @param WPROTOTYPE_JSON
#* @param WEDIRUN
#* @param WMYLOG
#* @return WOK
#*!
$MET_ISSUE_GENERATE_FILES
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Integer WOK
  Local Integer I
  Local Char WMESS(250)
  Local Char WSIGCPY(5)
  Local Char WCERNAM(80)
  Local Integer WSIGOK
  Local Clbfile WRESHEADCERT
  Local Clbfile WRESBODYCERT
  Local Clbfile WRESHEAD
  Local Clbfile WRESBODY
  Local Clbfile WSIGNATURE
  Local Clbfile WARGUMENTS(4)
  Local Clbfile WOPTION(4)
  Local Clbfile WOPTIONSIG(4)
  Local Integer WSTATUSCODE
  Local Clbfile WDEF_JSON_UUID_LIST #tableau char 36 JSON
  Local Clbfile WDEF_FILENAME_LIST #tableau char 36 JSON

  If this.EMSG(WMSG).SIGNATURE=0 :this.EMSG(WMSG).SIGNATURE=1: Endif  #X3-69433 Unexpected token function:generateEdiFiles (JUCON:21/12/17)
  #X3-112926 EDI : Add a flow parameter to select the validation of XML (JUCON 17/10/18)
  Local Char WVALXML (10), WWRIREF (10)
#  If this.PARCOD="CHORUS": WWRIREF="true" : Else : WWRIREF="false": Endif  #X3-188472 (JUCON 2020-03-24)
  If this.PARCOD="FACTURAE": WWRIREF="false" : Else : WWRIREF="true": Endif
  If this.EMSG(WMSG).VALXML=0 : this.EMSG(WMSG).VALXML=1   : Endif
  If this.EMSG(WMSG).VALXML=2 : WVALXML= "true" : Else  WVALXML= "false": Endif
  #X3-112926 EDI : Add a flow parameter to select the validation of XML (JUCON 17/10/18)

  For I = 1 To maxtab(WINS_UUID_TAB())-1
    WDEF_JSON_UUID_LIST    = WDEF_JSON_UUID_LIST    + '"'+WINS_UUID_TAB(I)    +'",'
  Next I
  WDEF_JSON_UUID_LIST    = WDEF_JSON_UUID_LIST    + '"'+WINS_UUID_TAB(I)    +'"'
  WDEF_JSON_UUID_LIST    = '['+WDEF_JSON_UUID_LIST+']'

  If this.EMSG(WMSG).MSGFOR=1   ## 112148
    For I = 1 To maxtab(WRET_FILENAMES_TAB())-1
      WRET_FILECODES_TAB(I) = '"'+WRET_FILECODES_TAB(I)+'" : '
      WDEF_FILENAME_LIST = WDEF_FILENAME_LIST + WRET_FILECODES_TAB(I) + '"'+WRET_FILENAMES_TAB(I)+'",'
    Next I
    WRET_FILECODES_TAB(I) = '"'+WRET_FILECODES_TAB(I)+'" : '
    WDEF_FILENAME_LIST = WDEF_FILENAME_LIST + WRET_FILECODES_TAB(I) + '"'+WRET_FILENAMES_TAB(I)+'"'
    WDEF_FILENAME_LIST = '{'+WDEF_FILENAME_LIST+'}'
  Else                    ## INI 112148
    WDEF_FILENAME_LIST = WRET_FILENAMES_TAB(1) #on en attend qu'un seul nom de fichier en emission xml!!
    WDEF_FILENAME_LIST = '"'+WDEF_FILENAME_LIST+'"'
  Endif

  Local Char WTEST(5)
  Case WEDIRUN.TESTFLG
    When [V]CST_AYES : WTEST = "true"
    When [V]CST_ANO  : WTEST = "false"
    When Default : WTEST = "false"
  Endcase

### USER can sign only when certificated is ok (EDICPYPAR)

## X3-23861 XML certificate and signature (JUCON 17/02/2017)
 If this.EMSG(WMSG).SIGNATURE >1
    Local Integer WSIGOK

    Local File =this.CATTRGTAB [WETC]
    Read [WETC]ETC0=this.NUMBATCH;this.EINS.DOCID
    If fstat=[V]CST_AOK
      WSIGCPY=[F:WETC]CPY
    Endif

    LogicClose File [WETC]
    Local File EDICPYPARD [EDCPD]
    Local Char WOPTION1(40)
    Filter [EDCPD] Where CPY=WSIGCPY & PARCOD=this.PARCOD and USER=this.ACTX.USER
    Read First
    If fstat=[V]CST_AOK

      ### check certificate exists
      WOPTION ='"'+[F:EDCPD]CERTIFICATE+'"'
      WOPTION1='"true"'
      WARGUMENTS = WOPTION+','+'"true"'
      WCERNAM=[F:EDCPD]CERTIFICATE

      WSTATUSCODE = func ASYRWEBSER.EXEC_JS("syracuse-xml/lib/helpers", "certificateExists", "wait", WARGUMENTS, "0,0", 0, "", "0", WRESHEADCERT, WRESBODYCERT)
      If WSTATUSCODE=200
        J=instr(1,WRESBODYCERT,"notAfter")
        If J>0
          Local Datetime WDATECER
          WDATECER=gdatetime$(mid$(WRESBODYCERT,14,26))
          If func SUBADC.DAT_DATETIME(WDATECER)>=date$
            WMESS=mess(1857,200,1)-[F:EDCPD]CERTIFICATE-"OK"
            Call ADDDIAGNOSE(WEDIRUN.ACTX,WMESS,[V]CST_AINFO) From ASYRASYNC
            WRET_VALUE = [V]CST_AOK
          Else
            WSIGOK=1
          Endif
        Elsif WRESBODYCERT=""
          WSIGOK=2
        Endif
      Else WSIGOK=2
      Endif
    Else
      ### error message without signature authorization
      WSIGOK=2
    Endif
    LogicClose File [EDCPD]
  Endif

  If WSIGOK>0
    Case WSIGOK
      When 1: WMESS=mess(1857,200,1)-[F:EDCPD]CERTIFICATE-mess(194,2006,1)  # Validity date expired
      When 2: WMESS=mess(1857,200,1)-WCERNAM- mess(42,9003,1) # Certificate not found
    Endcase
    Call ADDDIAGNOSE(WEDIRUN.ACTX,WMESS,[V]CST_AERROR) From ASYRASYNC
    WRET_VALUE = [V]CST_AERROR
    Return
  Endif
## End X3-23861 XML certificate and signature (JUCON 17/02/2017)
  If this.EMSG(WMSG).MSGFOR=1   ## 112148
    WOPTION ='{'+
&             '  "messageMapping" : "'+num$(this.EMSG(WMSG).MSG_UUID)+'",'+
&             '  "sequentialFile" : "'+num$(this.EMSG(WMSG).SEQ_UUID)+'",'+
&             '  "protocol" : "'+num$(this.PTC_UUID)+'",'+
&             '  "flow" : "'+num$(this.FLO_UUID)+'",'+
&             '  "prototype" : '+WPROTOTYPE_JSON+','+
&             '  "repName" : "'+this.EMSG(WMSG).REPCOD+'",'+
&             '  "folder" : "'+this.X3FOLDER+'",'+
&             '  "uuid" : '+WDEF_JSON_UUID_LIST+','+
&             '  "fileNames" : '+WDEF_FILENAME_LIST+','+
&             '  "keepCache" : true,'+
&             '  "test" : '+WTEST+
&             '}'
  Endif

 ###### Ini X3-23861 XML certificate and signature (JUCON 17/02/2017)
  If this.EMSG(WMSG).SIGNATURE =2
    Local Char WPATH(255): WPATH=""
    Local Char WIDENT(110): WIDENT="http://www.facturae.es/politica_de_firma_formato_facturae/politica_de_firma_formato_facturae_v3_1.pdf"
    Local Char WHASH(50)  : WHASH="Ohixl6upD6av8N7pEvDABhEL6hM="
    #Signature with xades:
    ###  Example:  xades:{ identifier: "XYZ", document: "ABCDE", claimedRoles: ["A","B","C"], certifiedRoles: "D"} }
    WXADES='{'+
&         ' "identifier": "'+WIDENT+'",'+
&         ' "description": "'+"facturae31"+'",'+
&         ' "hash": "'+WHASH+'",'+
&         ' "claimedRoles" : ["emisor"]'+
&        '}'

# Filling options to json :
    Local Char WEMPTY(10)  : WEMPTY = ""
    Local Char WFOLDER(10) : WFOLDER= this.X3FOLDER
    Local Char WSIGALG(100): WSIGALG= "RSA-SHA1"
    Local Char WALGOR(100) : WALGOR=  "http://www.w3.org/TR/2001/REC-xml-c14n-20010315"

    WOPTIONSIG ='{'+
&             '  "certificate" : "'+WCERNAM+'",'+
&             '  "path" : "'+WPATH+'",'+
&             '  "signatureAlgorithm" : "'+WSIGALG+'",'+
&             '  "includeKeyInfo" : true,'+
&             '  "prefix": "ds",'+
&             '  "xades" :'+WXADES+
&             '}'
  Endif

 If this.EMSG(WMSG).SIGNATURE =1 and this.EMSG(WMSG).MSGFOR=2 #X3-70757 : XML path without identifiant in sequential file saving (CJ:08/01/2018)
    #X3-69433 Unexpected token function:generateEdiFiles (JUCON:21/12/17)
    #X3-112926 EDI : Add a flow parameter to select the validation of XML (JUCON 17/10/18)
     WOPTION ='{'+
&             '  "messageMapping" : "'+num$(this.EMSG(WMSG).MSG_UUID)+'",'+
&             '  "xmlFile" : "'+num$(this.EMSG(WMSG).SEQ_UUID)+'",'+
&             '  "xmlSettings" : '+
&             '  { "xmlIncludeXsdReferences" :'+ WWRIREF+',' +
&             '    "xmlValidate" :'+WVALXML+
&             '  },'+
&             '  "protocol" : "'+num$(this.PTC_UUID)+'",'+
&             '  "flow" : "'+num$(this.FLO_UUID)+'",'+
&             '  "prototype" : '+WPROTOTYPE_JSON+','+
&             '  "repName" : "'+this.EMSG(WMSG).REPCOD+'",'+
&             '  "folder" : "'+this.X3FOLDER+'",'+
&             '  "uuid" : '+WDEF_JSON_UUID_LIST+','+
&             '  "encoding" : "utf8",'+
&             '  "fileNames" : '+WDEF_FILENAME_LIST+','+
&             '  "keepCache" : true,'+
&             '  "test" : '+WTEST+
&             '}'


Elsif this.EMSG(WMSG).SIGNATURE >1
# X3-41976 Extension of XML signed file (JUCON 25/05/2017)
  If this.EMSG(WMSG).SIGNAEXT<>""
    Local Integer WPOINT
    WPOINT=instr(1,WDEF_FILENAME_LIST,".")
    If WPOINT<>0
      WDEF_FILENAME_LIST=left$(WDEF_FILENAME_LIST,WPOINT-1)+"."+this.EMSG(WMSG).SIGNAEXT+'"'
    Endif
  Endif
# X3-41976 Extension of XML signed file (JUCON 25/05/2017)
# X3-112926 EDI : Add a flow parameter to select the validation of XML (JUCON 17/10/18)
       WOPTION ='{'+
&             '  "messageMapping" : "'+num$(this.EMSG(WMSG).MSG_UUID)+'",'+
&             '  "xmlFile" : "'+num$(this.EMSG(WMSG).SEQ_UUID)+'",'+
&             '  "xmlSettings" : '+
&             '  { "xmlIncludeXsdReferences" :'+ WWRIREF+',' +
&             '    "xmlValidate" :'+WVALXML+
&             '  },'+
&             '  "protocol" : "'+num$(this.PTC_UUID)+'",'+
&             '  "flow" : "'+num$(this.FLO_UUID)+'",'+
&             '  "prototype" : '+WPROTOTYPE_JSON+','+
&             '  "repName" : "'+this.EMSG(WMSG).REPCOD+'",'+
&             '  "folder" : "'+this.X3FOLDER+'",'+
&             '  "uuid" : '+WDEF_JSON_UUID_LIST+','+
&             '  "encoding" : "utf8",'+
&             '  "fileNames" : '+WDEF_FILENAME_LIST+','+
&             '  "keepCache" : true,'+
&             '  "test" : '+WTEST+','+
&             '  "signature":' + WOPTIONSIG+
&             '}'

  Endif           ## END 112148
###  End X3-23861 XML certificate and signature (JUCON 17/02/2017)

  WARGUMENTS = '"'+this.NUMBATCH+'",'+WOPTION

  Call ASYNCTRACK(WEDIRUN.ACTX, "(5)", mess(15,2017,1), 60) From ASYRASYNC
#Issue 112455 - 2015-11-12 by RBA - renaming JS module
  WSTATUSCODE = func ASYRWEBSER.EXEC_JS("syracuse-edi/lib/edi_Process", "generateEdiFiles", "wait", WARGUMENTS, "0,0", 0, "", "0", WRESHEAD, WRESBODY)
#/Issue 112455

  Local Integer WLIMIT : WLIMIT = 10
  Local Char    WRES_FILENAME_TAB(250)(1..,1..WLIMIT)           # to recover the filenames created of each documents
  Local Integer WRES_STA_TAB(1..maxtab(WDOCID_TAB()))           # to recover the status list created
  Local Char    WRES_DIAG_SEVERITY_TAB(250)(1..,1..WLIMIT)      # to recover the severity (error) of each failed document
  Local Char    WRES_DIAG_MESSAGE_TAB(250)(1..,1..WLIMIT)       # to recover the error message of each failed document

  WOK = func EDILIBB.PARSE_JS_GENERATE_EDI_FILES(WSTATUSCODE, WRESHEAD, WRESBODY, this.NUMBATCH, WDOCID_TAB, WINS_UUID_TAB, WRES_FILENAME_TAB, WRES_STA_TAB, WRES_DIAG_SEVERITY_TAB,
& WRES_DIAG_MESSAGE_TAB, WMYLOG)

  If WOK = [V]CST_AOK #no parser problem => 200 or 500
    Call ADDDIAGNOSE(WEDIRUN.ACTX,mess(61,7711,1),[V]CST_AINFO) From ASYRASYNC
    For J = 1 To maxtab(WDOCID_TAB())
      If WRES_STA_TAB(J) = [V]CST_AOK
        this.NBGEN_OK = this.NBGEN_OK + 1
        #WERR = "Files generation"
        WREC_NB_FILE = 0
        WFLG_SENT = [V]CST_AFALSE
        For K = 1 To WLIMIT
          #WERR = "Files issue"
          If WRES_FILENAME_TAB(J,K) <> ""
            WREC_NB_FILE = WREC_NB_FILE + 1
            WFLG_SENT    = [V]CST_ATRUE
            WOK = func EDISTO_CSTD.SET_DOCKEY(this.NUMBATCH, WDOCID_TAB(J),"PHYFILE"+num$(WREC_NB_FILE), WRES_FILENAME_TAB(J,K))
            WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, WDOCID_TAB(J), this.CATTYP, 17, [V]CST_AINFO, 15, WRES_FILENAME_TAB(J,K), WMYLOG)
          Endif
        Next K
        If WFLG_SENT = [V]CST_ATRUE
          this.NBSENT_OK = this.NBSENT_OK + 1
          WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, WDOCID_TAB(J), this.CATTYP, 18, [V]CST_AINFO, 16, mess(7,2007,1), WMYLOG)
          Call ADDDIAGNOSE(WEDIRUN.ACTX,mess(29,10703,1)-WDOCID_TAB(J),[V]CST_AINFO) From ASYRASYNC
        Else
          this.NBSENT_KO = this.NBSENT_KO + 1
          WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, WDOCID_TAB(J), this.CATTYP, 18, [V]CST_AERROR, 16, mess(9,2007,1), WMYLOG)
          Call ADDDIAGNOSE(WEDIRUN.ACTX,mess(6,10715,1)-WDOCID_TAB(J),[V]CST_AERROR) From ASYRASYNC
          WRET_VALUE = [V]CST_AERROR
        Endif
        #SAS & TRK update status = 3 - Terminated
        WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, WDOCID_TAB(J), this.CATTYP, 19, 3, WMYLOG)
      Else
        this.NBGEN_KO  = this.NBGEN_KO + 1
        this.NBSENT_KO = this.NBSENT_KO + 1
#        Gosub GENERATE_FILES_ERROR
        #WERR = "Files generation"
        For K = 1 To WLIMIT
          If WRES_DIAG_SEVERITY_TAB(J,K) <> ""
            WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, WDOCID_TAB(J), this.CATTYP, 17, [V]CST_AERROR, 15, WRES_DIAG_MESSAGE_TAB(J,K), WMYLOG)
            WOK = func EDISTO_CSTD.SET_DOCKEY(this.NUMBATCH, WDOCID_TAB(J),"PHYFILE"+num$(K), "JS"-WRES_DIAG_SEVERITY_TAB(J,K))
          Endif
        Next K
        #WERR = "Files issue"
        WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, WDOCID_TAB(J), this.CATTYP, 18, [V]CST_AERROR, 16, mess(9,2007,1), WMYLOG)
         Call ADDDIAGNOSE(WEDIRUN.ACTX,mess(6,10715,1)-WDOCID_TAB(J),[V]CST_AERROR) From ASYRASYNC
        #SAS & TRK update status = 4 - Error
        WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, WDOCID_TAB(J), this.CATTYP, 19, 4, WMYLOG)
        WRET_VALUE = [V]CST_AERROR
      Endif
    Next J
  Else #error
    Call ADDDIAGNOSE(WEDIRUN.ACTX,mess(324,117,1),[V]CST_AERROR) From ASYRASYNC
    For J = 1 To maxtab(WDOCID_TAB())
      this.NBGEN_KO  = this.NBGEN_KO + 1
      this.NBSENT_KO = this.NBSENT_KO + 1
#      Gosub GENERATE_FILES_ERROR
      #WERR = "Files generation"
      For K = 1 To WLIMIT
        If WRES_DIAG_SEVERITY_TAB(J,K) <> ""
          WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, WDOCID_TAB(J), this.CATTYP, 17, [V]CST_AERROR, 15, WRES_DIAG_MESSAGE_TAB(J,K), WMYLOG)
          WOK = func EDISTO_CSTD.SET_DOCKEY(this.NUMBATCH, WDOCID_TAB(J),"PHYFILE"+num$(K), "JS"-WRES_DIAG_SEVERITY_TAB(J,K))
        Endif
      Next K
      #WERR = "Files issue"
      WOK = fmet WEDIRUN.MET_LOG_MSG(this.NUMBATCH, WDOCID_TAB(J), this.CATTYP, 18, [V]CST_AERROR, 16, mess(9,2007,1), WMYLOG)
      #SAS & TRK update status = 4 - Error
      WOK = fmet WEDIRUN.MET_UPDATE_STA(this.NUMBATCH, WDOCID_TAB(J), this.CATTYP, 19, 4, WMYLOG)
    Next J

    WRET_VALUE = [V]CST_AERROR
  Endif

  ARET_VALUE = WRET_VALUE #[V]CST_AOK

Return

################################################
#********************************************************************
# Method MET_ISSUE_LOG_RESUME
#********************************************************************
#
#*
#* @param WDOCID_TAB
#* @param WEDIRUN
#* @param WMYLOG
#* @return WOK
#*!
$MET_ISSUE_LOG_RESUME
  Local Integer WRET_VALUE : WRET_VALUE = [V]CST_AOK
  Local Char WERR(250)
  Local Integer WOK
  Local Integer WNBLEFT
  Local Integer WNBRIGHT

  Call ASYNCTRACK(WEDIRUN.ACTX, "(6)", mess(50,2006,1), 80) From ASYRASYNC

  WERR = " "+mess(28,2007,1)+" " #Processing the document list
  WNBLEFT = abs((115-len(WERR))/2)
  WNBRIGHT = 115-len(WERR)-WNBLEFT
  WOK = fmet WMYLOG.APUTLINE(string$(WNBLEFT,"-")+WERR+string$(WNBRIGHT,"-"),[V]CST_AINFO)

  WOK = fmet WEDIRUN.MET_LOG_DUMP(this.NUMBATCH, WDOCID_TAB(), WMYLOG)

  WERR = " "+mess(27,2007,1)+" " #Summary of global process
  WNBLEFT = abs((115-len(WERR))/2)
  WNBRIGHT = 115-len(WERR)-WNBLEFT
  WOK = fmet WMYLOG.APUTLINE(string$(WNBLEFT,"-")+WERR+string$(WNBRIGHT,"-"),[V]CST_AINFO)
  WOK = fmet WMYLOG.APUTLINE("", [V]CST_AINFO)


  #"Number of document successfully saved in mongo :"
  WERR = format$("4X","")+format$("60X",mess(48,2007,1))+" : "+num$(this.NBSAS)+"/"+num$(this.NBDOC_STACK)
  If this.NBSAS = 0
#    ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AERROR)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AERROR) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
  Else
#    ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AINFO)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
  Endif

  #"Number of document successfully instanciated :"
  If this.NBINS_OK + this.NBINS_KO = 0
    WERR = format$("4X","")+format$("60X",mess(45,2007,1))+" : "+num$(0)
#    ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AINFO)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
  Elsif this.NBINS_OK = 0 and this.NBINS_KO <> 0
    WERR = format$("4X","")+format$("60X",mess(45,2007,1))+" : "+num$(this.NBINS_OK)+"/"+num$(this.NBINS_OK + this.NBINS_KO)
#    ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AERROR)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AERROR) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
  Elsif this.NBINS_OK <> 0 and this.NBINS_KO = 0
    WERR = format$("4X","")+format$("60X",mess(45,2007,1))+" : "+num$(this.NBINS_OK)+"/"+num$(this.NBINS_OK + this.NBINS_KO)
#    ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AINFO)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
  Else
    WERR = format$("4X","")+format$("60X",mess(45,2007,1))+" : "+num$(this.NBINS_OK)+"/"+num$(this.NBINS_OK + this.NBINS_KO)
#    ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AWARNING)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AWARNING) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AWARNING)
  Endif

  #"Number of document successfully generated :"
  If this.NBGEN_OK + this.NBGEN_KO = 0
    WERR = format$("4X","")+format$("60X",mess(43,2007,1))+" : "+num$(0)
#    ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AINFO)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
  Elsif this.NBGEN_OK = 0 and this.NBGEN_KO <> 0
    WERR = format$("4X","")+format$("60X",mess(43,2007,1))+" : "+num$(this.NBGEN_OK)+"/"+num$(this.NBGEN_OK + this.NBGEN_KO)
#    ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AERROR)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AERROR) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
  Elsif this.NBGEN_OK <> 0 and this.NBGEN_KO = 0
    WERR = format$("4X","")+format$("60X",mess(43,2007,1))+" : "+num$(this.NBGEN_OK)+"/"+num$(this.NBGEN_OK + this.NBGEN_KO)
#    ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AINFO)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
  Else
    WERR = format$("4X","")+format$("60X",mess(43,2007,1))+" : "+num$(this.NBGEN_OK)+"/"+num$(this.NBGEN_OK + this.NBGEN_KO)
#    ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AWARNING)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AWARNING) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AWARNING)
  Endif

  #"Number of document successfully sent :"
  If this.NBSENT_OK + this.NBSENT_KO = 0
    WERR = format$("4X","")+format$("60X",mess(50,2007,1))+" : "+num$(0)
#    ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AINFO)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AINFO) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
  Elsif this.NBSENT_OK = 0 and this.NBSENT_KO <> 0
    WERR = format$("4X","")+format$("60X",mess(50,2007,1))+" : "+num$(this.NBSENT_OK)+"/"+num$(this.NBSENT_OK + this.NBSENT_KO)
#    ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AERROR)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AERROR) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AERROR)
  Elsif this.NBSENT_OK <> 0 and this.NBSENT_KO = 0
    WERR = format$("4X","")+format$("60X",mess(50,2007,1))+" : "+num$(this.NBSENT_OK)+"/"+num$(this.NBSENT_OK + this.NBSENT_KO)
#    ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AINFO)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_ASUCCESS) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AINFO)
  Else
    WERR = format$("4X","")+format$("60X",mess(50,2007,1))+" : "+num$(this.NBSENT_OK)+"/"+num$(this.NBSENT_OK + this.NBSENT_KO)
#    ASTATUS = fmet WEDIRUN.ASETERROR("", WERR, [V]CST_AWARNING)
    Call ADDDIAGNOSE(WEDIRUN.ACTX,vireblc(WERR,2),[V]CST_AWARNING) From ASYRASYNC
    WOK = fmet WMYLOG.APUTLINE(WERR,[V]CST_AWARNING)
  Endif

  If (dim(GININAME))>=0
    Kill GININAME, GENDNAME, GUSEKEY
  Endif

  ARET_VALUE = WRET_VALUE
Return



#********************************************************************
# Subprog ADD_MERGE_KEY
#********************************************************************
#*
#*
#*
#********************************************************************
# @param WEDIRUNISS
# @param WMERGEKEY_TAB
# @param WSTR
# @param WFILECODES_TAB
# @param WFILENAMES_TAB
#*!
Subprog ADD_MERGE_KEY(WEDIRUNISS, WMERGEKEY_TAB, WSTR, WFILECODES_TAB, WFILENAMES_TAB)
Variable Instance WEDIRUNISS Using OBJECT
Variable Char WMERGEKEY_TAB()(1..)
Value Char WSTR()
Value Char WFILECODES_TAB()(1..)
Value Char WFILENAMES_TAB()(1..)

  Local Integer I, WPOS
  Local Integer WFOUND : WFOUND = [V]CST_ANO
  If WSTR <> ""
    For I = 1 To maxtab(WMERGEKEY_TAB)
      If WMERGEKEY_TAB(I) = WSTR
        WFOUND = [V]CST_AYES
        Break
      Endif
    Next I
    If WFOUND = [V]CST_ANO
      WMERGEKEY_TAB(maxtab(WMERGEKEY_TAB)+1) = WSTR
      For I = 1 To maxtab(WFILECODES_TAB)
        WPOS = fmet WEDIRUNISS.ADDLINE("EMUX", [V]CST_ALASTPOS)
        WEDIRUNISS.EMUX(WPOS).MERGEKEY     = WSTR
        WEDIRUNISS.EMUX(WPOS).MSG_FILECODE = WFILECODES_TAB(I)
        WEDIRUNISS.EMUX(WPOS).MSG_FILENAME = WFILENAMES_TAB(I)
      Next I
    Endif
  Endif
End


#********************************************************************
# Subprog FORMAT_FILTER_LINE
#********************************************************************
#*
#*
#*
#********************************************************************
# @param WVALINI
# @param WTYP
# @param WTYP
#*!
Subprog FORMAT_FILTER_LINE(WVALINI, WTYP, WVALFIN)
Value Char WVALINI
Value Integer WTYP
Variable Char WVALFIN

    Case WTYP
      When 1,2,3,4,5,6: WVALFIN = WVALINI
      When 7:           WVALFIN = "'"+WVALINI+"'"
      When 8: # WVALFIN = "["+mid$(WVALINI,1,6)+"20"+mid$(WVALINI,7,8)+"]"      #INI SAM 111252
#                Case mid$(adxfmt2,3,1)   # Building the correct date for the filter depending on format date of the connection
#                  When "M": WVALFIN = "["+mid$(WVALINI,4,3)+mid$(WVALINI,1,3)+mid$(WVALINI,7,4)+"]"
#                  When "Y": WVALFIN = "["+mid$(WVALINI,9,2)+mid$(WVALINI,5,4)+mid$(WVALINI,1,4)+"]"
#                  When Default: WVALFIN = "["+WVALINI+"]"
#                Endcase       #END SAM 111252
#                WVALFIN = "["+WVALINI+"]"
            WVALFIN = "["+num$(func FORMAT_DATE_UNIVERSAL_TO_DATE(WVALINI))+"]"
    Endcase

End

#********************************************************************
#* funprog FORMAT_DATE_UNIVERSAL_TO_DATE
#*
#*
#********************************************************************
#@param WDATESTR
#@param WDATEFMT
#@return WDATE
#*!
Funprog FORMAT_DATE_UNIVERSAL_TO_DATE(WDATESTR)
Value Char WDATESTR

  Local Date WDATE

  Local Char WYYYY(4)
  Local Char WMM(2)
  Local Char WDD(2)

  If WDATESTR <> ""
    WYYYY = left$(WDATESTR, 4)
    WMM   = mid$(WDATESTR, 5, 2)
    WDD   = right$(WDATESTR, 7)
    WDATE = gdat$(val(WDD),val(WMM),val(WYYYY))
  Endif

End WDATE
