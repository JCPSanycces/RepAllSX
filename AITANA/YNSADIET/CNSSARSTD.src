#<AdxTL>@(#)0.0.0.0 $Revision$ Stocks artículos
#####################################################################################
# Src: CNSSARSTD
#-------------------------------------------------------------------------------------
# Proyecto: YNSADIET
#-------------------------------------------------------------------------------------
# Version: v12
#-------------------------------------------------------------------------------------
# YN31 - Filtrar por atributo en consulta Stocks por artículo
# Fecha inicio YN31: 06/05/2020
# Desarrollador: JCH
# Código de desarrollo: YN31
# Descripción del desarrollo: Filtrar por atributo en consulta Stocks por artículo
# Fecha: 06/05/2020
# Codigo Actividad: YYN31
#######################################################################################


#############################################################
$ACTION
# If GUSER="AIT51" Then : Infbox "2"-ACTION : Endif
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "FERME"      : Gosub FERME
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "DEB_CRIT"   : [M:CSAR]    = [M:SAR1]
  When "FIN_CRIT"   : [M:SAR1]FLG = 0
                      [M:SAR1]    = [M:CSAR]
  When Default
Endcase
Return
############################################################
$AUTORIS
If clalev([F:FCY]) = 0 : Local File FACILITY   [FCY] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:STL]) = 0 : Local File STOLOT     [STL] : Endif
If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:TFO]) = 0 : Local File TABFOR     [TFO] : Endif
#MAE, bg56487
If clalev([F:ITG]) = 0 : Local File ITMCATEG   [ITG] : Endif

Return
############################################################
$OUVRE
Local  Char    WPAR
Local  Char    WFILITM1(250)
Local  Char    WFILITM2(250)
Local  Char    WFILITM3(250)
Local  Char    WFILITF (250)
Local  Char    WFILS   (250)
Local  Char    WFILFOR (250)
Local  Char    WFILSPE (250)
Local  Char    WFILITV (250)
Local  Integer WFSTAT, WREAD, WSKIP, WLIG
Local  Integer WGCONSULT : WGCONSULT = GCONSULT
Global Char    GSCOLDES(20)(05)
GSCOLDES(0) = mess(1,206,1)
GSCOLDES(1) = mess(2,206,1)
GSCOLDES(2) = mess(3,206,1)
GSCOLDES(3) = mess(4,206,1)
GSCOLDES(4) = mess(5,206,1)
#
Local Integer I, J, L, M
#MAE, bg56487
Local Integer WSTA
Local Decimal WDISPO

Gosub LOAD_SCREEN
NAVIG="CONSSAR"
SUITE  = 1
RETOUR = 1
nolign = 1
Return
############################################################
$LOAD_SCREEN
For I = 1 To dim(PARAM)
  Case I
    When 1 :
      GCONSULT = val(PARAM(I))
    When 2 :
      If PARAM(I) <> ""
        Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
        If !fstat
          [M:SAR1]FCY = PARAM(I)
        Endif
      Endif
    When 3 :
      If PARAM(I) = ""
        WFILS = "1=1"
      Else
        WFILS = evalue(PARAM(I))
      Endif
  Endcase
Next I

[M:SAR1]SRTKEY = 1  # HCB 60470
If dim([M:SAR1]QTYTYP) > 0 # HCB 61502
   [M:SAR1]QTYTYP = 1
Endif
If clalev([M:CSAR]) <> 0 & [M:CSAR]MEMO = "STD"
  [M:SAR1] = [M:CSAR]
Endif
[M:SAR1]FLG = 0     # HCB 60470
Return
############################################################
$FERME
If dim(WGCONSULT) > 0 : GCONSULT = WGCONSULT : Endif
Return
############################################################
$LECTURE
Local Integer POK : POK = 0 ### YYN31 - STR
If [M:SAR1]FCY = ""
  NBLU = 0
  Return
Endif
Gosub TRT_FILTER
SUITE  = 0
RETOUR = 0
NBLU   = 1
Case CHGPAG
  When 1 :
    nolign = 1
    WPAGE  = 0
    For [LNK]
      If nolign <= MAXLIG
        ### YYN31 - STR
#        Call VERIF_LINE(POK, [F:ITF]ITMREF) From CNSSARSPE
#        If POK = 2
        ### YYN31 - END
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        ### YYN31 - STR
#        Endif
        ### YYN31 - END
      Else
        Break
      Endif
    Next
    WPAGE += 1
    RETOUR = 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When 2 :
    Effzo [M:SAR2] # Issue X3-81239 MGO - CONSSAR: Description 1 is not refreshed
    nolign = 1
    WSKIP = WPAGE * MAXLIG
    WLIG  = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
        ### YYN31 - STR
        #Call VERIF_LINE(POK, [F:ITF]ITMREF) From CNSSARSPE
        #If POK = 2
        ### YYN31 - END
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    += 1
        ### YYN31 - STR
        #Endif
        ### YYN31 - END
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    WPAGE += 1
    If nolign < MAXLIG
      SUITE = 1
    Endif
  When -1 :
    Effzo [M:SAR2]
    WLIG = 0
    For [LNK]
      WLIG += 1
    Next
    If mod(WLIG,MAXLIG) = 0
      WPAGE = int(WLIG/MAXLIG)
    Else
      WPAGE = int(WLIG/MAXLIG)+1
    Endif
    WSKIP  = (WPAGE-1) * MAXLIG
    nolign = (MAXLIG+1)-(WLIG-WSKIP)
    WLIG   = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
        ### YYN31 - STR
        #Call VERIF_LINE(POK, [F:ITF]ITMREF) From CNSSARSPE
        #If POK = 2
        ### YYN31 - END
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
          NOL    -= 1
        ### YYN31 - STR
        #Endif
        ### YYN31 - END
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    SUITE  = 1
  When -2 :
    Effzo [M:SAR2] # Issue X3-81239 MGO - CONSSAR: Description 1 is not refreshed
    nolign = 1
    WPAGE -= 1
    WSKIP  = (WPAGE-1) * MAXLIG
    WLIG   = 0
    For [LNK]
      If WLIG >= WSKIP
        If nolign <= MAXLIG
        ### YYN31 - STR
        #Call VERIF_LINE(POK, [F:ITF]ITMREF) From CNSSARSPE
        #If POK = 2
        ### YYN31 - END
          Gosub LOA_LIGNE
          NBLU    = 2
          nolign += 1
        ### YYN31 - STR
        #Endif
        ### YYN31 - END
        Else
          Break
        Endif
      Else
        WLIG += 1
      Endif
    Next
    If WPAGE = 1
      RETOUR = 1
    Endif
    NOL    = 0
    nolign = MAXLIG
Endcase
$LECTURE_FIN
Return
############################################################
$TRT_FILTER



If [M:SAR1]FLG = 0
  [M:SAR1]FLG = 1
  Raz [M:SAR2]
  Gosub LOAD_FILTER

###----YN31
If !clalev([F:ZIAT]): Local File ZITMATRIB [F:ZIAT]: Endif
If !clalev([F:YIAT]): Local File YITMATRIB [F:YIAT]: Endif
Trbegin [F:ZIAT]
Delete [F:ZIAT] Where USER=GUSER

If [M:SAR1]YCDGGRUPO <> "" or [M:SAR1]YCDGATRIBUTO <> ""
  If  [M:SAR1]YCDGGRUPO <> "" and [M:SAR1]YCDGATRIBUTO <> ""
    Filter [F:YIAT] Where YGATRIBUTO=[M:SAR1]YCDGGRUPO and ATRIBUTO=[M:SAR1]YCDGATRIBUTO
  Else
    Filter [F:YIAT] Where YGATRIBUTO=[M:SAR1]YCDGGRUPO
  Endif
    For [F:YIAT]
      [F:ZIAT]ARTICULO= [F:YIAT]ARTICULO
      [F:ZIAT]USER   = GUSER
      Write [F:ZIAT]
    Next
Else
WFILXXX="1=1"
If [M:SAR1]ITMREFSTR <> "" | [M:SAR1]ITMREFEND <> ""
  WFILXXX -= "&[F:ITM]ITMREF>=[M:SAR1]ITMREFSTR&[F:ITM]ITMREF<=[M:SAR1]ITMREFEND"
Endif
  For [F:ITM] Where  evalue(WFILITM1)                &
&                    evalue(WFILITM2)                &
&                    evalue(WFILITM3)                &
&                    evalue(WFILXXX)
      [F:ZIAT]ARTICULO= [F:ITM]ITMREF
      [F:ZIAT]USER   = GUSER
      Write [F:ZIAT]
  Next
Endif
Commit

###----YN31


  WFILSPE="1=1"
  If PROGSPE<>""
    ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  WFILSPE+="&[F:ZIAT]ARTICULO<>''"
#MAE, bg86887, ajout dans le link de la table ITV
  Case [M:SAR1]SRTKEY
    When 1 :
      Onerrgo ERR_FORM1
      ###----YN31
      Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF, [ITV]ITV0=[ITF]ITMREF;[ITF]STOFCY,[F:ZIAT]ZAIT0=[ITF]ITMREF;GUSER
&              As    [LNK]
&              Where evalue(WFILITF)                 &
&                    evalue(WFILFOR)                 &
&                    evalue(WFILITM1)                &
&                    evalue(WFILITM2)                &
&                    evalue(WFILITM3)                &
&                    evalue(WFILSPE)                 &
&                    evalue(WFILITV)
&              Order By Key ITF1
      Onerrgo
    When 2 :
      Onerrgo ERR_FORM2
#      Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF
#&              As    [LNK]
#&              Where evalue(WFILITF)                 &
#&                    evalue(WFILFOR)                 &
#&                    evalue(WFILITM1)                &
#&                    evalue(WFILITM2)                &
#&                    evalue(WFILITM3)                &
#&                    evalue(WFILSPE)
#&              Order By [F:ITM]ITMDES1
      If clalev ([F:AXX])=0  : Local File ATEXTRA   [AXX]  : Endif # FGR 30/06/2009 : X3SUIVI56189
      Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF,
&                     [AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;[F:ITF]ITMREF;"",
&                     [ITV]ITV0=[ITF]ITMREF;[ITF]STOFCY,
&                     [F:ZIAT]ZAIT0=[ITF]ITMREF;GUSER
&              As    [LNK]
&              Where evalue(WFILITF)                 &
&                    evalue(WFILFOR)                 &
&                    evalue(WFILITM1)                &
&                    evalue(WFILITM2)                &
&                    evalue(WFILITM3)                &
&                    evalue(WFILSPE)                 &
&                    evalue(WFILITV)
&              Order By [F:AXX]TEXTE                               # FGR 30/06/2009 : X3SUIVI56189
      Onerrgo
    When 3 :
      Onerrgo ERR_FORM3
      Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF, [ITV]ITV0=[ITF]ITMREF;[ITF]STOFCY,[F:ZIAT]ZAIT0=[ITF]ITMREF;GUSER
&              As    [LNK]
&              Where evalue(WFILITF)                 &
&                    evalue(WFILFOR)                 &
&                    evalue(WFILITM1)                &
&                    evalue(WFILITM2)                &
&                    evalue(WFILITM3)                &
&                    evalue(WFILSPE)                 &
&                    evalue(WFILITV)
&              Order By [F:ITM]SEAKEY;[F:ITM]ITMREF
      Onerrgo
    When 4 :
      Onerrgo ERR_FORM4
      Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF, [ITV]ITV0=[ITF]ITMREF;[ITF]STOFCY,[F:ZIAT]ZAIT0=[ITF]ITMREF;GUSER
&              As    [LNK]
&              Where evalue(WFILITF)                 &
&                    evalue(WFILFOR)                 &
&                    evalue(WFILITM1)                &
&                    evalue(WFILITM2)                &
&                    evalue(WFILITM3)                &
&                    evalue(WFILSPE)                 &
&                    evalue(WFILITV)
&              Order By [F:ITM]CFGLIN;[F:ITM]ITMREF
      Onerrgo
  Endcase
Endif
Return
############################################################
$ERR_FORM1
Call MESSAGE (mess(65,106,1)) From GESECRAN
Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF, [ITV]ITV0=[ITF]ITMREF;[ITF]STOFCY
&              As    [LNK]
&              Where evalue(WFILITF)                 &
&                    evalue(WFILITM1)                &
&                    evalue(WFILITM2)                &
&                    evalue(WFILITM3)                &
&                    evalue(WFILITV)
&              Order By Key ITF1
Resume

$ERR_FORM2
Call MESSAGE (mess(65,106,1)) From GESECRAN
#Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF
#&              As    [LNK]
#&              Where evalue(WFILITF)                 &
#&                    evalue(WFILITM1)                &
#&                    evalue(WFILITM2)                &
#&                    evalue(WFILITM3)
#&              Order By [F:ITM]ITMDES1
If clalev ([F:AXX])=0  : Local File ATEXTRA   [AXX]  : Endif # FGR 30/06/2009 : X3SUIVI56189
Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF,
&               [AXX]AXX0="ITMMASTER";"DES1AXX";GLANGUE;[F:ITF]ITMREF;"",
&               [ITV]ITV0=[ITF]ITMREF;[ITF]STOFCY
&              As    [LNK]
&              Where evalue(WFILITF)                 &
&                    evalue(WFILITM1)                &
&                    evalue(WFILITM2)                &
&                    evalue(WFILITM3)                &
&                    evalue(WFILITV)
&              Order By [F:AXX]TEXTE                         # FGR 30/06/2009 : X3SUIVI56189
Resume

$ERR_FORM3
Call MESSAGE (mess(65,106,1)) From GESECRAN
Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF, [ITV]ITV0=[ITF]ITMREF;[ITF]STOFCY
&              As    [LNK]
&              Where evalue(WFILITF)                 &
&                    evalue(WFILITM1)                &
&                    evalue(WFILITM2)                &
&                    evalue(WFILITM3)                &
&                    evalue(WFILITV)
&              Order By [F:ITM]SEAKEY;[F:ITM]ITMREF
Resume

$ERR_FORM4
Call MESSAGE (mess(65,106,1)) From GESECRAN
Link [ITF] With [ITM]ITM0=[F:ITF]ITMREF, [ITV]ITV0=[ITF]ITMREF;[ITF]STOFCY
&              As    [LNK]
&              Where evalue(WFILITF)                 &
&                    evalue(WFILITM1)                &
&                    evalue(WFILITM2)                &
&                    evalue(WFILITM3)                &
&                    evalue(WFILITV)
&              Order By [F:ITM]CFGLIN;[F:ITM]ITMREF
Resume

############################################################
$LOA_LIGNE
#MAE, bg 86687, la gestion du flag "ignorer stock nul" et la lecture de ITV est déplacé dans le link
#Read [ITV]ITV0=[F:ITF]ITMREF;[F:ITF]STOFCY
#If fstat
#  Raz [F:ITV]
#  [F:ITV]STOFCY = [F:ITF]STOFCY
#  [F:ITV]ITMREF = [F:ITF]ITMREF
#Endif
#MAE, bg 58015
#If [M:SAR1]ZERFLG = 2 & sum([F:ITV]PHYSTO,[F:ITV]CTLSTO,[F:ITV]REJSTO) = 0
#If [M:SAR1]ZERFLG = 2 & sum([F:ITV]PHYSTO,[F:ITV]CTLSTO,[F:ITV]REJSTO,[F:ITV]PLFPHYSTO,[F:ITV]PLFCTLSTO,[F:ITV]PLFREJSTO,
#& [F:ITV]BPRPHYSTO,[F:ITV]BPRCTLSTO,[F:ITV]BPRREJSTO,[F:ITV]SCOPHYSTO,[F:ITV]SCOCTLSTO,[F:ITV]SCOREJSTO) = 0
# nolign -= WINCR : # eb 03.10.03
# NOL    -= WINCR
#  nolign -= 1
#  NOL    -= 1
#  Goto LOA_LIGNE_FIN
#Endif
#MAE, bg56487

Read [ITG]ITG1=[F:ITM]TCLCOD;[F:ITV]STOFCY
If fstat
   Read [ITG]ITG1=[F:ITM]TCLCOD;""
   If fstat Raz [F:ITG] Endif
Endif
WSTA=0
WDISPO=0
If [F:ITG]GLOAAAFLG = 2   WSTA += 1  Endif
If [F:ITG]GLOQQQFLG = 2   WSTA += 2  Endif
If [F:ITG]GLORRRFLG = 2   WSTA += 4  Endif
#--- TS 106217
#Call STODISPO("",[F:ITF]STOFCY,[F:ITF]ITMREF,"*","*",1,WSTA,"","","",WDISPO) From STKLIB
Call STODISPO("",[F:ITF]STOFCY,[F:ITF]ITMREF,"*","*",1,WSTA,"","","","",WDISPO) From STKLIB
#---
#--- Issue 99815
#[M:SAR2]AVASTO(nolign-1)  = WDISPO
[M:SAR2]AVASTO(nolign-1)  = max(WDISPO,0)
#---

If dim([M:SAR2]QTYTYP) > 0
  [M:SAR2]QTYTYP(nolign-1) = 1
Endif
If dim([M:SAR1]QTYTYP) > 0 & [M:SAR1]QTYTYP = 2
  Case [F:ITF]STOMGTCOD
    When 3, 4 :
      [M:SAR2]UOM(nolign-1) = "0"
      If dim([M:SAR2]QTYTYP) > 0
        [M:SAR2]QTYTYP(nolign-1) = 2
      Endif
    When Default :
      [M:SAR2]UOM(nolign-1) = [F:ITM]STU
  Endcase
Else
  [M:SAR2]UOM(nolign-1) = [F:ITM]STU
Endif
#
[M:SAR2]STOFCY(nolign-1)  = [F:ITF]STOFCY
[M:SAR2]                  = [F:ITM]
# Lecture des stocks si article géré entitre ou ui et quantité physique


If dim([M:SAR2]QTYTYP) > 0 & [M:SAR2]QTYTYP(nolign-1) = 1 & find([F:ITF]STOMGTCOD,3,4)
  Raz [M:SAR2]PHYSTO(nolign-1),[M:SAR2]PHYALL(nolign-1)
  Raz [M:SAR2]CTLSTO(nolign-1),[M:SAR2]CTLALL(nolign-1)
  Raz [M:SAR2]REJSTO(nolign-1),[M:SAR2]REJALL(nolign-1)
  Raz [M:SAR2]PLFPHYSTO(nolign-1),[M:SAR2]PLFCTLSTO(nolign-1),[M:SAR2]PLFREJSTO(nolign-1)
  Raz [M:SAR2]BPRPHYSTO(nolign-1),[M:SAR2]BPRCTLSTO(nolign-1),[M:SAR2]BPRREJSTO(nolign-1)
  Raz [M:SAR2]SCOPHYSTO(nolign-1),[M:SAR2]SCOPHYALL(nolign-1)
  Raz [M:SAR2]SCOCTLSTO(nolign-1),[M:SAR2]SCOCTLALL(nolign-1)
  Raz [M:SAR2]SCOREJSTO(nolign-1),[M:SAR2]SCOREJALL(nolign-1)
  Filter [STO] Where STOFCY = [M:SAR2]STOFCY(nolign-1) &
&                    ITMREF = [M:SAR2]ITMREF(nolign-1)
&              Order By Key STO3
  For [STO]
    Case [F:STO]LOCCAT
      When 0, 1 :
        Case left$([F:STO]STA,1)
          When "A" :
            [M:SAR2]PHYSTO(nolign-1) += [F:STO]QTYSTU
            [M:SAR2]PHYALL(nolign-1) += [F:STO]CUMALLQTY
          When "Q" :
            [M:SAR2]CTLSTO(nolign-1) += [F:STO]QTYSTU
            [M:SAR2]CTLALL(nolign-1) += [F:STO]CUMALLQTY
          When "R" :
            [M:SAR2]REJSTO(nolign-1) += [F:STO]QTYSTU
            [M:SAR2]REJALL(nolign-1) += [F:STO]CUMALLQTY
        Endcase

      When 2 :
        Case left$([F:STO]STA,1)
          When "A" :
            [M:SAR2]PLFPHYSTO(nolign-1) += [F:STO]QTYSTU
          When "Q" :
            [M:SAR2]PLFCTLSTO(nolign-1) += [F:STO]QTYSTU
          When "R" :
            [M:SAR2]PLFREJSTO(nolign-1) += [F:STO]QTYSTU
        Endcase
      When 3 :
        Case left$([F:STO]STA,1)
          When "A" :
            [M:SAR2]BPRPHYSTO(nolign-1) += [F:STO]QTYSTU
          When "Q" :
            [M:SAR2]BPRCTLSTO(nolign-1) += [F:STO]QTYSTU
          When "R" :
            [M:SAR2]BPRREJSTO(nolign-1) += [F:STO]QTYSTU
        Endcase
      When 4 :
        Case left$([F:STO]STA,1)
          When "A" :
            [M:SAR2]SCOPHYSTO(nolign-1) += [F:STO]QTYSTU
            [M:SAR2]SCOPHYALL(nolign-1) += [F:STO]CUMALLQTY
          When "Q" :
            [M:SAR2]SCOCTLSTO(nolign-1) += [F:STO]QTYSTU
            [M:SAR2]SCOCTLALL(nolign-1) += [F:STO]CUMALLQTY
          When "R" :
            [M:SAR2]SCOREJSTO(nolign-1) += [F:STO]QTYSTU
            [M:SAR2]SCOREJALL(nolign-1) += [F:STO]CUMALLQTY
        Endcase
    Endcase
   [M:SAR2]TOTSTO(nolign-1)  = [M:SAR2]PHYSTO   (nolign-1) +
&                              [M:SAR2]CTLSTO   (nolign-1) +
&                              [M:SAR2]REJSTO   (nolign-1)
   [M:SAR2]PLFSTO(nolign-1)  = [M:SAR2]PLFPHYSTO(nolign-1) +
&                              [M:SAR2]PLFCTLSTO(nolign-1) +
&                              [M:SAR2]PLFREJSTO(nolign-1)
   [M:SAR2]BPRSTO(nolign-1)  = [M:SAR2]BPRPHYSTO(nolign-1) +
&                              [M:SAR2]BPRCTLSTO(nolign-1) +
&                              [M:SAR2]BPRREJSTO(nolign-1)
   [M:SAR2]SCOSTO(nolign-1)  = [M:SAR2]SCOPHYSTO(nolign-1) +
&                              [M:SAR2]SCOCTLSTO(nolign-1) +
&                              [M:SAR2]SCOREJSTO(nolign-1)
   [M:SAR2]ALLSTO(nolign-1)  = [M:SAR2]PHYALL   (nolign-1) +
&                              [M:SAR2]CTLALL   (nolign-1) +
&                              [M:SAR2]REJALL   (nolign-1) +
&                              [M:SAR2]SCOPHYALL(nolign-1) +
&                              [M:SAR2]SCOCTLALL(nolign-1) +
&                              [M:SAR2]SCOREJALL

  Next
  Filter [STO]
Else
  [M:SAR2]                  = [F:ITV]
  [M:SAR2]TOTSTO(nolign-1)  = [F:ITV]PHYSTO    + [F:ITV]CTLSTO       + [F:ITV]REJSTO
  [M:SAR2]PLFSTO(nolign-1)  = [F:ITV]PLFPHYSTO + [F:ITV]PLFCTLSTO    + [F:ITV]PLFREJSTO
  [M:SAR2]BPRSTO(nolign-1)  = [F:ITV]BPRPHYSTO + [F:ITV]BPRCTLSTO    + [F:ITV]BPRREJSTO
  [M:SAR2]SCOSTO(nolign-1)  = [F:ITV]SCOPHYSTO + [F:ITV]SCOCTLSTO    + [F:ITV]SCOREJSTO
  [M:SAR2]ALLSTO(nolign-1)  = [F:ITV]PHYALL    + [F:ITV]CTLALL       + [F:ITV]REJALL    +
&                             [F:ITV]SCOPHYALL + [F:ITV]SCOCTLALL    + [F:ITV]SCOREJALL
Endif
#--- Issue 95234
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SAR2]ITMDES1(nolign-1), "[F:ITM]") From TRTX3

If dim([F:ITM]TSICOD) > 0
  [M:SAR2]TSICOD1(nolign-1) = [F:ITM]TSICOD(0)
Endif
If dim([F:ITM]TSICOD) > 1
  [M:SAR2]TSICOD2(nolign-1) = [F:ITM]TSICOD(1)
Endif
If dim([F:ITM]TSICOD) > 2
  [M:SAR2]TSICOD3(nolign-1) = [F:ITM]TSICOD(2)
Endif
If dim([F:ITM]TSICOD) > 3
  [M:SAR2]TSICOD4(nolign-1) = [F:ITM]TSICOD(3)
Endif
If dim([F:ITM]TSICOD) > 4
  [M:SAR2]TSICOD5(nolign-1) = [F:ITM]TSICOD(4)
Endif

$LOA_LIGNE_FIN
Return
############################################################
$LOAD_FILTER
# Préparation filtre [ITF]
WFILITF = "[F:ITF]STOFCY=[M:SAR1]FCY&[F:ITF]STOMGTCOD>1"
If [M:SAR1]ITMREFSTR <> "" | [M:SAR1]ITMREFEND <> ""
  WFILITF = WFILITF+"&[F:ITF]ITMREF>=[M:SAR1]ITMREFSTR&[F:ITF]ITMREF<=[M:SAR1]ITMREFEND"
Endif
If [M:SAR1]BUYSTR <> "" | [M:SAR1]BUYEND <> ""
  WFILITF = WFILITF+"&[F:ITF]BUY>=[M:SAR1]BUYSTR&[F:ITF]BUY<=[M:SAR1]BUYEND"
Endif
# Préparation filtre [ITM]
WFILITM1 = "1=1"
WFILITM2 = "1=1"
WFILITM3 = "1=1"

If [M:SAR1]TCLCODSTR <> "" | [M:SAR1]TCLCODEND <> ""
  WFILITM1 += "&[F:ITM]TCLCOD>=[M:SAR1]TCLCODSTR&[F:ITM]TCLCOD<=[M:SAR1]TCLCODEND"
Endif
If [M:SAR1]CFGLINSTR <> "" | [M:SAR1]CFGLINEND <> ""
  WFILITM1 += "&[F:ITM]CFGLIN>=[M:SAR1]CFGLINSTR&[F:ITM]CFGLIN<=[M:SAR1]CFGLINEND"
Endif
#
If dim([M:SAR1]TSICODSTR) > 0
  For I = 0 To dim([M:SAR1]TSICODSTR)-1
    If [M:SAR1]TSICODSTR(I) <> "" | [M:SAR1]TSICODEND(I) <> ""
      If len(WFILITM1) > 200
        WFILITM2 += "&[F:ITM]TSICOD("+num$(I)+")>='"+[M:SAR1]TSICODSTR(I)+
&                "'&[F:ITM]TSICOD("+num$(I)+")<='"+[M:SAR1]TSICODEND(I)+"'"
      Else
        WFILITM1 += "&[F:ITM]TSICOD("+num$(I)+")>='"+[M:SAR1]TSICODSTR(I)+
&                "'&[F:ITM]TSICOD("+num$(I)+")<='"+[M:SAR1]TSICODEND(I)+"'"
      Endif
    Endif
  Next I
Endif
#
If [M:SAR1]SEAKEYSTR <> "" | [M:SAR1]SEAKEYEND <> ""
  WFILITM3 += "&[F:ITM]SEAKEY>=[M:SAR1]SEAKEYSTR&[F:ITM]SEAKEY<=[M:SAR1]SEAKEYEND"
Endif
If [M:SAR1]EANCODSTR <> "" | [M:SAR1]EANCODEND <> ""
  WFILITM3 += "&[F:ITM]EANCOD>=[M:SAR1]EANCODSTR&[F:ITM]EANCOD<=[M:SAR1]EANCODEND"
Endif
# Filtre formule
If [M:SAR1]SELFOR <> ""
  Read [TFO]TFO0=11;[M:SAR1]SELFOR
  If fstat = 0
    If WFILS = "1=1"
      WFILFOR = [F:TFO]FORFOR
    Else
      WFILFOR = WFILS+"&"+[F:TFO]FORFOR
    Endif
  Endif
Endif
#MAE, bg 86687
If [M:SAR1]ZERFLG = 2
    WFILITV="sum([F:ITV]PHYSTO,[F:ITV]CTLSTO,[F:ITV]REJSTO,[F:ITV]PLFPHYSTO,[F:ITV]PLFCTLSTO,[F:ITV]PLFREJSTO,"
    WFILITV+="[F:ITV]BPRPHYSTO,[F:ITV]BPRCTLSTO,[F:ITV]BPRREJSTO,[F:ITV]SCOPHYSTO,[F:ITV]SCOCTLSTO,[F:ITV]SCOREJSTO)<> 0"
Else
    WFILITV = ""
Endif
#
If WFILFOR= ""
  WFILFOR = "1=1"
Endif
If WFILITF  = ""
  WFILITF  = "1=1"
Endif
If WFILITM1 = ""
  WFILITM1 = "1=1"
Endif
If WFILITM2 = ""
  WFILITM2 = "1=1"
Endif
If WFILITM3 = ""
  WFILITM3 = "1=1"
Endif
If WFILITV = ""
  WFILITV = "1=1"
Endif
Return
############################################################
$SETBOUT
If [M:SAR1]FCY <> "" & [M:SAR2]NBLIG > 0
  CHMEN = "1"
  Gosub SET_BOUT_SPE From GSAISIE
Endif
Return
############################################################
$EXEBOUT
Return
############################################################
Subprog IB_NBLIG
If nolign > 0
  If [M]ALLSTO(nolign-1) = 0 & GFONC1<> "GESPNH" : Raz GBOUT4 : Endif
  If [M]GLOALL(nolign-1) = 0 : Raz GBOUT5 : Endif
  If [M]DETSHT(nolign-1) = 0 & [M]GLOSHT(nolign-1) = 0  : Raz GBOUT6 : Endif
  If [M]TRFSTO(nolign-1) = 0 : Raz GBOUT7 : Endif
  If [M]TRASTO(nolign-1) = 0 : Raz GBOUT8 : Endif
  If [M]BPRSTO(nolign-1) = 0 : Raz GBOUT9 : Endif
Endif
End
