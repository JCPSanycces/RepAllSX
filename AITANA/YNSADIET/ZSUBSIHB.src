#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "ALISIVTYP": Gosub ALISIVTYP
Endcase
Return

$ALISIVTYP
If dim([M:SDH0]SDHTYP)>0
 If !clalev([ZTSD]): Local File TABSDHTYP[ZTSD]: Endif
 Read [ZTSD]TSD0=[M:SDH0]SDHTYP;""
 If !fstat
  If [F:ZTSD]ZSIVTYP<>""
    WKFILSUP="[TSV]SIVTYP='"+[F:ZTSD]ZSIVTYP+"'"
   [M:SIH0]SIVTYP=""
  Endif
 Endif
Endif
Return
