#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

Case ACTION
  When "DEBUT"        : Gosub DEBUT
  When "BOUTON"       : Gosub BOUTON
  When "FIN"          : Gosub FIN
Endcase
Return


##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$DEBUT
# Limpio y cargo pantalla
Raz [M:YSCR]
[M:YSCR]PIE = 0

Local Integer LINE

  If !clalev([F:POQ0]) Then : Local File PORDERQ [F:POQ0] : Endif
  Filter [F:POQ0] Where POHNUM = [M:PSH1]YPEDIDO
  For [POQ0]
    [M:YSCR]LINEA(LINE)     = [F:POQ0]POPLIN
    [M:YSCR]ARTICULO(LINE)  = [F:POQ0]ITMREF
    [M:YSCR]UNIDAD(LINE)    = [F:POQ0]PUU
    [M:YSCR]CTDPEDIDA(LINE) = [F:POQ0]QTYPUU
    [M:YSCR]CTDRECEP(LINE)  = [F:POQ0]QTYPUU
    [M:YSCR]LOTEPROV(LINE)  = ""
    [M:YSCR]LOTE(LINE)      = ""
    LINE += 1
  Next
  Filter [F:POQ0]
  Close Local File [POQ0]

[M:YSCR]PIE = LINE
Affzo [M:YSCR]
Return

############################################################
$BOUTON
Case BOUT
  When "Y"
  # Controlo que al menos hay una línea
  If [M:YSCR]ARTICULO(0) = "" or [M:YSCR]PIE = 0
    Errbox "Proceso imposible. Al menos debe haber una línea"
    Return
  Endif

  # Controlo que todas las líneas tengan cantidad para recepcionar
  Local Integer I, ERROR
  For I=0 To [M:YSCR]PIE-1
    If [M:YSCR]CTDRECEP(I) = 0
      Errbox "Proceso imposible. Falta introducir la cantidad recepcionada del artículo " +  [M:YSCR]ARTICULO(I)
      Return
    Endif
  Next

  # Controlo que todas las líneas tengan el lote
  Local Integer I
  For I=0 To [M:YSCR]PIE-1
    Local Integer L_OBLIGA
    Call CKEC_LOTE([M:YSCR]ARTICULO(I),L_OBLIGA)
    If L_OBLIGA = 2 and [M:YSCR]LOTE(I) = ""
      Errbox "Proceso imposible. Falta introducir el lote para el artículo " +  [M:YSCR]ARTICULO(I)
      Return
    Endif
  Next

  # Controlo que todas las líneas tengan la fecha de caducidad
  If 1=2
  Local Integer I
  For I=0 To [M:YSCR]PIE-1
    Local Integer L_OBLIGA
    Call CKEC_CAD([M:YSCR]ARTICULO(I),L_OBLIGA)
    If L_OBLIGA = 2 and [M:YSCR]FCADUCIDAD(I) = ""
      Errbox "Proceso imposible. Falta introducir la fecha de caducidad para el artículo " +  [M:YSCR]ARTICULO(I)
      Return
    Endif
  Next
  Endif

  # Si todo OK pregunto confirmación antes de genenerar la recepción
  Local Integer OK9
  Call OUINON("¿Desea generar la recepción?",OK9) From GESECRAN
  If OK9=2
    Gosub GENERA_RECEPCION
    Gosub FIN
  Endif

Endcase
Return

##############################################################
$FIN
  If dim(GPTHNUMCRE) > 0 Then : Kill GPTHNUMCRE : Endif
  FIN = 1
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$GENERA_RECEPCION
Local   Char    LDIRIMPORT(250)  : LDIRIMPORT = filpath("IMPORT_EXPORT\SOLICITUD_COMPRA\Mov_PSH","","")
Global  Char    LFILE(250)
Local   Char    LFECHA(10), LHORA(10) : Raz LFECHA, LHORA
Local   Char    LPATHDESE(255)   : LPATHDESE = filpath("IMPORT_EXPORT\SOLICITUD_COMPRA\Error_PSH","","")    # ruta de la carpeta con errores
Local   Char    LPATHDESS(255)   : LPATHDESS = filpath("IMPORT_EXPORT\SOLICITUD_COMPRA\Success_PSH","","")  # ruta de la carpeta de finalizados con éxito
Local   Integer LCON
Local   Integer STAT

  Call OUVRE_TRACE("Recepción desde solicitud de compra") From LECFIC

  LFECHA    = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
  LHORA     = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

  Raz LFILE
  LFILE     = LDIRIMPORT + "\PSH_" + [M:PSH0]PSHFCY + "_" + [M:PSH0]PSHNUM + "_" + LFECHA + LHORA + ".txt"

  # borramos el fichero si existe...
  If filinfo(LFILE, 7) > 0 Then
    System "ae_rm " + LFILE
  Endif

  mkstat = 0 : fstat = 0 : GERRTRACE = 0

  # abrir el fichero para escritura
  Gosub OPEN_FILE

  Wrseq "E" + ";" + [M:PSH0]PSHFCY + ";" + ctrans(num$([M:PSH0]PRQDAT),"/","") + ";" + ";" + [M:PSH0]YBPSNUM Using [YIMP]

  For LCON = 0 To [M:YSCR]PIE-1
    Wrseq "L" + ";" + [M:PSH1]YPEDIDO + ";" + num$([M:YSCR]LINEA(LCON)) + ";" + [M:YSCR]ARTICULO(LCON) + ";" + [M:YSCR]UNIDAD(LCON) + ";" +
&   num$([M:YSCR]CTDRECEP(LCON)) Using [YIMP]
    Wrseq "S" + ";" + "A" + ";" + [M:YSCR]UNIDAD(LCON) + ";" + num$([M:YSCR]CTDRECEP(LCON)) + ";" + "001" + ";" + [M:YSCR]LOTE(LCON) + ";" +
&   [M:YSCR]LOTEPROV(LCON) + ";" + ctrans(num$([M:YSCR]FCADUCIDAD(LCON)),"/","") Using [YIMP]
  Next

  Gosub CLOSE_FILE

  Call IMPORTSIL("YPTH",LFILE) From GIMPOBJ                                     # lanza la importación de entrega

  If (fstat <> 0 and fstat <> 4) or GERRTRACE <> 0 Then                         # si se produce error de importación...
    Call MOVE(LFILE+".err",LPATHDESE,STAT) From ORDSYS                          # mueve el fichero .err con errores en la importación
    System "ae_rm " + LFILE                                                     # borra el fichero .txt que ha dado errores
  Else
    Call MOVE(LFILE,LPATHDESS,STAT) From ORDSYS                                 # mueve el fichero .txt con importación exitosa
    If !clalev([F:YPSH]) Then : Local File PREQUIS [F:YPSH] : Endif
    Read [F:YPSH]PSH0 = [M:PSH0]PSHNUM
    If !fstat Then
      Trbegin [F:YPSH]
      [F:YPSH]YRECEPCION  = GPTHNUMCRE
      [F:YPSH]YRECEPCIONF = date$
      [M:PSH1]YRECEPCION  = GPTHNUMCRE
      [M:PSH1]YRECEPCIONF = date$
      Affzo [M:PSH1]YRECEPCION
      Affzo [M:PSH1]YRECEPCIONF
      Rewrite [F:YPSH]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Endif
    Close Local File [YPSH]
  Endif

  Call FERME_TRACE From LECFIC
  If !GSERVEUR Then
    Call LEC_TRACE() From LECFIC
  Endif

  If dim(LCON) > 0 Then : Kill LCON : Endif

  mkstat = 0 : fstat = 0 : GOK = 1 : GERRTRACE = 0

Return

########################################################
$OPEN_FILE

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE Using [YIMP]

Return

########################################################
$CLOSE_FILE

Openo Using [YIMP]

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
##############################################################
Subprog AS_LOTE(VALEUR)
Variable Char    VALEUR()
Local Integer L_OBLIGA
Call CKEC_LOTE([M:YSCR]ARTICULO(nolign-1),L_OBLIGA)
If L_OBLIGA <> 2
  mkstat = 2
Else
  # Por defecto propongo el mismo valor que el lote proveedor
  If VALEUR = ""
    VALEUR = [M:YSCR]LOTEPROV(nolign-1)
  Endif
Endif
End


######################################################################################
Subprog AS_LOTEPROV(VALEUR)
Variable Char    VALEUR()
Local Integer L_OBLIGA
Call CKEC_LOTE([M:YSCR]ARTICULO(nolign-1),L_OBLIGA)
If L_OBLIGA <> 2
  mkstat = 2
Endif
End


######################################################################################
Subprog AS_FCADUCIDAD(VALEUR)
Variable Date    VALEUR
Local Integer C_OBLIGA
Call CKEC_CAD([M:YSCR]ARTICULO(nolign-1),C_OBLIGA)
If C_OBLIGA <> 2
  mkstat = 2
Endif
End


######################################################################################
Subprog CKEC_LOTE(VART,VOBL)
Value Char VART
Variable Integer VOBL
If !clalev([PP1]) : Local File ITMMASTER [PP1] : Endif

Read [PP1]ITM0 = VART
If fstat = 0
  If [PP1]LOTMGTCOD = 3
    VOBL = 2
  Endif
Endif

Close Local File [PP1]

End


######################################################################################
Subprog CKEC_CAD(VART,VOBL)
Value Char VART
Variable Integer VOBL
If !clalev([PP1]) : Local File ITMMASTER [PP1] : Endif

Read [PP1]ITM0 = VART
If fstat = 0
  If [PP1]EXYMGTCOD > 1
    VOBL = 2
  Endif
Endif

Close Local File [PP1]

End
