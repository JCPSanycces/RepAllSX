###################################################################################
#################################   WEB SERVICES  #################################
###################################################################################
############################################################
# obtención de la imagen adjunta a un artículo
Subprog GETIMAGE(PITM,PIMG,PRET)
Value     Char PITM()
Variable  Blbfile PIMG()
Variable  Integer PRET()

  If PITM = "" Then
    PRET = 0
    End
  Endif

  If !clalev([F:CBB0]) Then : Local File CBLOB [F:CBB0] : Endif
  Read [F:CBB0]CBB0 = "ITM";PITM;""
  If !fstat Then
    PIMG = [F:CBB0]BLOB
    PRET = 1
  Else
    PRET = 0
  Endif

  If clalev([F:CBB0])  Then : Close Local File [F:CBB0] : Endif
End

############################################################
# adición de una imagen a un artículo
Subprog SETIMAGE(PITM,PIMG,PRET)
Value     Char    PITM()(1..2)
Value     Blbfile PIMG()(1..2)
Variable  Integer PRET(1..2)

  # averigua la cantidad de OF's que se pretenden importar
  Local Integer J, CONT : Raz J, CONT
  For J=1 To maxtab(PITM)
    If PITM(J) <> "" Then : CONT +=1 : Endif
  Next

  If !clalev([F:CBB0]) Then : Local File CBLOB [F:CBB0] : Endif

  # inserta las imágenes
  Local Integer I
  For I = 1 To CONT
    # controla que exista código de artículo e imagen
    If PITM(I) = "" or PIMG(I) = "" Then
      PRET(I) = 0
      Break
    Endif

    Read [F:CBB0]CBB0 = "ITM";PITM(I);""
    Trbegin [F:CBB0]
    If !fstat Then                        # el artículo existe
      [F:CBB0]BLOB = PIMG(I)
      Rewrite [F:CBB0]
    Else                                  # el artículo no existe
      [F:CBB0]CODBLB  = "ITM"
      [F:CBB0]IDENT1  = PITM(I)
      [F:CBB0]TYPBLB  = 3
      [F:CBB0]BLOB    = PIMB(I)
      Rewrite [F:CBB0]
    Endif
    If !fstat Then
      PRET(I) = 1
      Commit
    Else
      PRET(I) = 0
      Rollback
    Endif
  Next
#Call MESSAGE(CONT) From GESECRAN
  If clalev([F:CBB0])  Then : Close Local File [F:CBB0] : Endif

End

############################################################
# obtención de los campos de artículo para el e-commerce
Subprog GET_ITM(PEXIST,PORIGEN,PITM,PLAN,PITMDES1,PYDESWEBC,PYDESWEBL,PTSICOD0,PTSICOD0DES,PTSICOD1,PYPRESWEB1,PYPRESWEB2,PYINGWEB,PYPROWEB,PYMODWEB,PYCINWEB,PYPRECWEB,
&               PEANCOD,PYALGWEB,PYWEBPRI,PYREBPRI,PYPROASO,PYIMGITM,PYPVP,PYPVT101,PYPVT201,PYPVT110,PYIVAWEB,PYSTDISWEB,PYTARPRI,PYB2BFLG,PYB2CFLG,PYDTOMARCA,PYNOMWEB,
&               PYSTDISWEB101,PYSTDISWEB201,PYSTDISOUTLET)

  # parámetros de entrada
  Value     Char    PORIGEN()(1..100)                   #1        valores: 'LVN' = la ventana natural ; 'PDM' = producciones dietéticas la mancha
  Value     Char    PITM()(1..100)                      #2
  Value     Char    PLAN()(1..100)                      #3

  # parámetros de salida
  Variable  Integer PEXIST(1..100)                      #4
  Variable  Char    PITMDES1()(1..100)                  #5
  Variable  Clbfile PYDESWEBC()(1..100)                 #6
  Variable  Clbfile PYDESWEBL()(1..100)                 #7
  Variable  Char    PTSICOD0()(1..100)                  #8
  Variable  Char    PTSICOD0DES()(1..100)               #9
  Variable  Char    PTSICOD1()(1..100)                  #10
  Variable  Clbfile PYPRESWEB1()(1..100)                #11
  Variable  Clbfile PYPRESWEB2()(1..100)                #12
  Variable  Clbfile PYINGWEB()(1..100)                  #13
  Variable  Clbfile PYPROWEB()(1..100)                  #14
  Variable  Clbfile PYMODWEB()(1..100)                  #15
  Variable  Clbfile PYCINWEB()(1..100)                  #16
  Variable  Clbfile PYPRECWEB()(1..100)                 #17
  Variable  Char    PEANCOD()(1..100)                   #18
  Variable  Clbfile PYALGWEB()(1..100)                  #19
  Variable  Decimal PYWEBPRI(1..100)                    #20
  Variable  Decimal PYREBPRI(1..100)                    #21
  Variable  Char    PYPROASO()(1..100)                  #22
  Variable  Blbfile PYIMGITM()(1..100)                  #23
  Variable  Decimal PYPVP(1..100)                       #24
  Variable  Decimal PYPVT101(1..100)                    #25
  Variable  Decimal PYPVT201(1..100)                    #26
  Variable  Decimal PYPVT110(1..100)                    #27
  Variable  Decimal PYIVAWEB(1..100)                    #28
  Variable  Decimal PYSTDISWEB(1..100)                  #29
  Variable  Decimal PYTARPRI(1..100)                    #30
  Variable  Decimal PYB2BFLG(1..100)                    #31
  Variable  Decimal PYB2CFLG(1..100)                    #32
  Variable  Decimal PYDTOMARCA(1..100)                  #33
  Variable  Char    PYNOMWEB()(1..100)                  #34
  Variable  Decimal PYSTDISWEB101(1..100)               #35
  Variable  Decimal PYSTDISWEB201(1..100)               #36
  Variable  Decimal PYSTDISOUTLET(1..100)               #37

#  # declaración de variables locales
  Local Integer CONT                  : Raz CONT
  Local Integer I, J                  : Raz I, J

  # averigua la cantidad de OF's que se pretenden importar
  For I=1 To maxtab(PITM)
    If PITM(I) <> "" Then : CONT +=1 : Endif
  Next

  If !clalev([F:YVW0]) Then : Local File YVISITMWEB [F:YVW0] : Endif
  If !clalev([F:CBB0]) Then : Local File CBLOB      [F:CBB0] : Endif
  If !clalev([F:ITV0]) Then : Local File ITMMVT     [F:ITV0] : Endif
  If !clalev([F:SPL0]) Then : Local File SPRICLIST  [F:SPL0] : Endif
  If !clalev([F:SPL1]) Then : Local File SPRICLIST  [F:SPL1] : Endif
  If !clalev([F:SPL2]) Then : Local File SPRICLIST  [F:SPL2] : Endif
  If !clalev([F:SPL3]) Then : Local File SPRICLIST  [F:SPL3] : Endif
  If !clalev([F:ITM0]) Then : Local File ITMMASTER  [F:ITM0] : Endif
  If !clalev([F:ITM1]) Then : Local File ITMMASTER  [F:ITM1] : Endif
  If !clalev([F:STO0]) Then : Local File STOCK      [F:STO0] : Endif
  If !clalev([F:AXX0]) Then : Local File ATEXTRA    [F:AXX0] : Endif
  For J = 1 To CONT
    # si no es castellano, busca en la tabla de traducciones
    If PLAN(J) <> "SPA" Then
    Else
      Filter [F:ITM0] Where ITMREF = PITM(J) and [F:ITM0]YWEBFLG = 2
      Read [F:ITM0] First
      If !fstat Then
        PEXIST(J)     = 1
        PITMDES1(J)   = [F:ITM0]ITMDES1
        PYDESWEBC(J)  = "<![CDATA[" + [F:ITM0]YDESWEBCS + "]]>"
        PYDESWEBL(J)  = "<![CDATA[" + [F:ITM0]YDESWEBLS + "]]>"
        PTSICOD0(J)   = [F:ITM0]TSICOD(0)
        Filter [F:AXX0] Where CODFIC = "ATABDIV" and ZONE = "LNGDES" and LANGUE = GLANGUE and IDENT1 = "20" and IDENT2 = [F:ITM0]TSICOD(0)
        Read [F:AXX0] First
        If !fstat Then
          PTSICOD0DES(J) = [F:AXX0]TEXTE
        Endif
        Filter [F:AXX0]
        PTSICOD1(J)   = [F:ITM0]TSICOD(1)
        PYPRESWEB1(J) = "<![CDATA[" + [F:ITM0]YPRESENTAS + "]]>"
        PYPRESWEB2(J) = "<![CDATA[" + [F:ITM0]YPRESWEBS + "]]>"
        PYINGWEB(J)   = "<![CDATA[" + [F:ITM0]YINGWEBS + "]]>"
        PYPROWEB(J)   = "<![CDATA[" + [F:ITM0]YPROWEBS + "]]>"
        PYMODWEB(J)   = "<![CDATA[" + [F:ITM0]YMODWEBS + "]]>"
        PYCINWEB(J)   = "<![CDATA[" + [F:ITM0]YCINWEBS + "]]>"
        PYPRECWEB(J)  = "<![CDATA[" + [F:ITM0]YPRECWEBS + "]]>"
        PEANCOD(J)    = [F:ITM0]EANCOD
        PYALGWEB(J)   = "<![CDATA[" + [F:ITM0]YALGWEBS + "]]>"
        PYWEBPRI(J)   = [F:ITM0]YWEBPRI
        PYREBPRI(J)   = [F:ITM0]YREBPRI
        PYPROASO(J)   = [F:ITM0]YPROASO
        PYB2BFLG(J)   = [F:ITM0]YB2BFLG
        PYB2CFLG(J)   = [F:ITM0]YB2CFLG
        PYDTOMARCA(J) = [F:ITM0]YDTOMARCA
        PYNOMWEB(J)   = [F:ITM0]YNOMWEBS
        # lee el campo de la imagen
        Read [F:CBB0]CBB0 = "ITM";PITM(J);""
        If !fstat Then
          PYIMGITM(J) = [F:CBB0]BLOB
        Endif

        # IVA de la web
        Case [F:ITM0]VACITM
          When "EXO"  : PYIVAWEB(J) = 0
          When "NOR"  : PYIVAWEB(J) = 21
          When "RED"  : PYIVAWEB(J) = 10
          When "SIV"  : PYIVAWEB(J) = 0
          When "SRD"  : PYIVAWEB(J) = 4
        Endcase

        Local Decimal LSTOCK,LSTOCKASIG : Raz LSTOCK,LSTOCKASIG
        # stock del artículo para La Ventana Natural
        PYSTDISWEB101(J) = 0
        Filter [F:STO0] Where STOFCY = "101" and ITMREF = PITM(J) and STA = "A" and (LOCTYP = "PIC" or LOCTYP = "ALM1" or LOCTYP = "ALM2" or LOCTYP = "INV")
        For [STO0]
          LSTOCK += [F:STO0]QTYPCU
        Next
        Read [F:ITV0]ITV0 = PITM(J);"101"
        If !fstat Then
          LSTOCKASIG = [F:ITV0]PHYALL + [F:ITV0]GLOALL
        Endif
        If (LSTOCK - LSTOCKASIG) > 10 Then
          PYSTDISWEB101(J) = LSTOCK - LSTOCKASIG
        Endif
        Filter [F:STO0]
        # stock del artículo para Producciones Dietéticas La Mancha
        Raz LSTOCK,LSTOCKASIG
        PYSTDISWEB201(J) = 0
        Filter [F:STO0] Where STOFCY = "201" and ITMREF = PITM(J) and STA = "A" and (LOCTYP = "PIC" or LOCTYP = "ALM1" or LOCTYP = "INV")
        For [STO0]
          LSTOCK += [F:STO0]QTYPCU
        Next
        Read [F:ITV0]ITV0 = PITM(J);"201"
        If !fstat Then
          LSTOCKASIG = [F:ITV0]PHYALL + [F:ITV0]GLOALL
        Endif
#        If (LSTOCK - LSTOCKASIG) > 10 Then
          PYSTDISWEB201(J) = LSTOCK - LSTOCKASIG
#        Endif
        Filter [F:STO0]
        # stock de artículo outlet
        Raz LSTOCK,LSTOCKASIG
        PYSTDISOUTLET(J) = 0
        Filter [F:STO0] Where STOFCY = "201" and ITMREF = PITM(J) and STA = "A" and LOCTYP = "98"
        For [STO0]
          LSTOCK += [F:STO0]QTYPCU
        Next
        Read [F:ITV0]ITV0 = PITM(J);"201"
        If !fstat Then
          LSTOCKASIG = [F:ITV0]PHYALL + [F:ITV0]GLOALL
        Endif
        If (LSTOCK - LSTOCKASIG) > 10 Then
          PYSTDISOUTLET(J) = LSTOCK - LSTOCKASIG
        Endif
        Filter [F:STO0]

        # calcula el PVT para la planta 101 (La Ventana Natural)
        Filter [F:SPL0] Where PLI = "VN50" and PLICRI2 = PITM(J) and PLISTRDAT <= date$ and PLIENDDAT >= date$
        Read   [F:SPL0] First
        If !fstat Then
          PYPVT101(J) = [F:SPL0]PRI
        Else
          Filter [F:SPL3] Where PLI = "LM50" and PLICRI1 = PITM(J) and PLISTRDAT <= date$ and PLIENDDAT >= date$
          Read   [F:SPL3] First
          If !fstat Then
            PYPVT101(J) = [F:SPL3]PRI
          Endif
          Filter [F:SPL3]
        Endif
        Filter [F:SPL0]
        # calcula el PVT para la planta 201 (Producciones Dietéticas La Mancha)
        Filter [F:SPL0] Where PLI = "LM30" and PLICRI1 = "002" and PLICRI2 = PITM(J) and PLISTRDAT <= date$ and PLIENDDAT >= date$
        Read   [F:SPL0] First
        If !fstat Then
          PYPVT201(J) = [F:SPL0]PRI
        Endif
        Filter [F:SPL0]

        # calcula el PVP
        Filter [F:SPL0] Where PLI = "LM50" and PLICRI1 = PITM(J) and PLISTRDAT <= date$ and PLIENDDAT >= date$
        Read   [F:SPL0] First
        If !fstat Then
          PYPVP(J)    = [F:SPL0]PRI
        Endif
        Filter [F:SPL0]

        # calcula el decuento por artículo
        Filter [F:SPL0] Where PLI = "LM10" and PLICRI2 = PITM(J) and PLISTRDAT <= date$ and PLIENDDAT >= date$
        Read   [F:SPL0] First
        If !fstat Then
          PYPVT110(J) = [F:SPL0]DCGVAL(2)
        Endif
        Filter [F:SPL0]

      Else
        Call MESSAGE("El artículo"-PITM(J)-"no es gestionable en la web") From GESECRAN
        PEXIST(J)     = 0
      Endif
      Filter [F:ITM0]
    Endif
  Next J

  If clalev([F:YVW0])  Then : Close Local File      [F:YVW0] : Endif
  If clalev([F:CBB0])  Then : Close Local File      [F:CBB0] : Endif
  If clalev([F:ITV0])  Then : Close Local File      [F:ITV0] : Endif
  If clalev([F:SPL0])  Then : Close Local File      [F:SPL0] : Endif
  If clalev([F:SPL1])  Then : Close Local File      [F:SPL1] : Endif
  If clalev([F:SPL2])  Then : Close Local File      [F:SPL2] : Endif
  If clalev([F:SPL3])  Then : Close Local File      [F:SPL3] : Endif
  If clalev([F:ITM0])  Then : Close Local File      [F:ITM0] : Endif
  If clalev([F:ITM1])  Then : Close Local File      [F:ITM1] : Endif
  If clalev([F:STO0])  Then : Close Local File      [F:STO0] : Endif
  If clalev([F:AXX0])  Then : Close Local File      [F:AXX0] : Endif

End

############################################################
# obtención del listado de artículo entre fechas para el e-commerce
Subprog GET_ITM_BTWDAT(PINIDAT,PENDDAT,PITMREF,PITMDES1)

# parámetros de entrada
Value     Char    PINIDAT()
Value     Char    PENDDAT()

## parámetros de salida
Variable  Char    PITMREF()(1..10000)
Variable  Char    PITMDES1()(1..10000)

Local Date FECHAINI : FECHAINI = gdat$(val(left$(PINIDAT,2)),val(mid$(PINIDAT,3,2)),val(mid$(PINIDAT,5,4)))
Local Date FECHAFIN : FECHAFIN = gdat$(val(left$(PENDDAT,2)),val(mid$(PENDDAT,3,2)),val(mid$(PENDDAT,5,4)))

# declaración de variables locales
Local Integer J : J = 1

  If !clalev([F:YVIBD]) Then : Local File YVITMBTD  [F:YVIBD] : Endif
  Filter [F:YVIBD] Where FECHAINI <= UPDDAT and FECHAFIN >= UPDDAT
  For [F:YVIBD]
    PITMREF(J)  = [F:YVIBD]ITMREF
    PITMDES1(J) = [F:YVIBD]ITMDES1
    J            += 1
#      If J=1001 Then : Break : Endif
  Next

  If J = 1 Then
    Call MESSAGE("No se han encontrado resultados") From GESECRAN
  Endif

  Filter [F:YVIBD]
  Close Local File [YVIBD]
End

############################################################
# devuelve información de clientes buscados por su referencia web
Subprog GET_BPC_WEBREF(PYREFWEB,PBPCNUM,PBPCNAM,PCRN,PIME)

# parámetros de entrada
Value     Char    PYREFWEB()

# parámetros de salida
Variable  Char    PBPCNUM()
Variable  Char    PBPCNAM()
Variable  Char    PCRN()
Variable  Integer PIME

  If !clalev([F:BPC0]) Then : Local File BPCUSTOMER  [F:BPC0] : Endif
  If !clalev([F:BPR0]) Then : Local File BPARTNER    [F:BPR0] : Endif
  Filter [F:BPC0] Where BPCSTA = 2 and YREFWEB = PYREFWEB
  Read   [F:BPC0] First
  If !fstat Then
    PBPCNUM   = [F:BPC0]BPCNUM
    PBPCNAM   = [F:BPC0]BPCNAM
    PIME      = [F:BPC0]IME
    Read [F:BPR0]BPR0 = [F:BPC0]BPCNUM
    If !fstat Then
      PCRN    = [F:BPR0]CRN
    Endif
  Endif
  Filter [F:BPC0]
  If clalev([F:BPC0])  Then : Close Local File      [F:BPC0] : Endif
  If clalev([F:BPR0])  Then : Close Local File      [F:BPR0] : Endif

End

#############################################################
# obtención de los nutrientes
Subprog GET_NUTRIENTE(PITM,PLAN,PYCOMNUT1,PCODART,PVMA,PPOR100GR,PPORRACION)
  # parámetros de entrada
  Value     Char    PITM()(1..100)
  Value     Char    PLAN()(1..100)

  # parámetros de salida
  Variable  Char    PCODART()(1..100)
  Variable  Char    PVMA()(1..100)
  Variable  Char    PPOR100GR()(1..100)
  Variable  Char    PPORRACION()(1..100)
  Variable  Char    PYCOMNUT1()(1..100)

  # declaración de variables locales
  Local Integer CONT                  : Raz CONT
  Local Integer I, J, K               : Raz I, J, K

  If !clalev([F:ITM0]) Then : Local File ITMMASTER    [F:ITM0] : Endif
  If !clalev([F:NUT0]) Then : Local File YNUTRIENTES  [F:NUT0] : Endif

  # averigua la cantidad de OF's que se pretenden importar
  For I=1 To maxtab(PITM)
    If PITM(I) <> "" Then : CONT +=1 : Endif
  Next

  For J = 1 To CONT
    # devuelve la información del campo *
    Read [F:ITM0]ITM0 = PITM(J)
    If !fstat Then
      PYCOMNUT1(J) = [F:ITM0]YCOMNUT1
    Endif

    Filter [F:NUT0] Where ITMREF = PITM(J) and LANGUE = PLAN(J) Order By NUMLIN
    K = 1
    For [NUT0]
      PCODART(K)    = [F:NUT0]ITMREF
      PVMA(K)       = [F:NUT0]VMA
      PPOR100GR(K)  = [F:NUT0]POR100GR
      PPORRACION(K) = [F:NUT0]PORRACION
      K += 1
    Next
    Filter [F:NUT0]
  Next

  Close Local File [NUT0],[ITM0]
End

#############################################################
# obtención de los ingredientes
Subprog GET_INGREDIENTE(PITM,PLAN,PYCOMING1,PYCOMING2,PCODART,PNOI,PCANTIDAD,PVRN)
  # parámetros de entrada
  Value     Char    PITM()(1..100)
  Value     Char    PLAN()(1..100)

  # parámetros de salida
  Variable  Char    PCODART()(1..100)
  Variable  Char    PNOI()(1..100)
  Variable  Char    PCANTIDAD()(1..100)
  Variable  Char    PVRN()(1..100)
  Variable  Char    PYCOMING1()(1..100)
  Variable  Char    PYCOMING2()(1..100)

  # declaración de variables locales
  Local Integer CONT                  : Raz CONT
  Local Integer I, J, K               : Raz I, J, K

  If !clalev([F:ING0]) Then : Local File YINGREDIENTE [F:ING0] : Endif
  If !clalev([F:ITM0]) Then : Local File ITMMASTER    [F:ITM0] : Endif

  # averigua la cantidad de OF's que se pretenden importar
  For I=1 To maxtab(PITM)
    If PITM(I) <> "" Then : CONT +=1 : Endif
  Next

  For J = 1 To CONT
    # devuelve la información de los campos *, **
    Read [F:ITM0]ITM0 = PITM(J)
    If !fstat Then
      PYCOMING1(J) = [F:ITM0]YCOMING1
      PYCOMING2(J) = [F:ITM0]YCOMING2
    Endif

    Filter [F:ING0] Where ITMREF = PITM(J) and LANGUEI = PLAN(J) Order By NUMLIN
    K = 1
    For [ING0]
      PCODART(K)    = [F:ING0]ITMREF
      PNOI(K)       = [F:ING0]NOI
      PCANTIDAD(K)  = [F:ING0]CANTIDAD
      PVRN(K)       = [F:ING0]VRN
      K += 1
    Next
    Filter [F:ING0]
  Next

  Close Local File [ING0],[ITM0]
End

#############################################################
# obtención de los índices y subíndices
Subprog GET_INDICES(PITM,PCODART,PYINDREF,PYINDDES,PYSUBREF,PYSUBDES)
  # parámetros de entrada
  Value     Char    PITM()(1..100)

  # parámetros de salida
  Variable  Char    PCODART()(1..100)
  Variable  Char    PYINDREF()(1..100)
  Variable  Char    PYINDDES()(1..100)
  Variable  Char    PYSUBREF()(1..100)
  Variable  Char    PYSUBDES()(1..100)

  # declaración de variables locales
  Local Integer CONT                  : Raz CONT
  Local Integer I, J, K               : Raz I, J, K

  If !clalev([F:YII0]) Then : Local File YINDITM  [F:YII0] : Endif
  If !clalev([F:YIS0]) Then : Local File YINDICES [F:YIS0] : Endif

  # averigua la cantidad de OF's que se pretenden importar
  For I=1 To maxtab(PITM)
    If PITM(I) <> "" Then : CONT +=1 : Endif
  Next

  For J = 1 To CONT
    Filter [F:YII0] Where ITMREF = PITM(J) Order By Key YII0 Asc
    K = 1
    For [YII0]
      Read [F:YIS0]YIS0 = [F:YII0]YINDREF;[F:YII0]YSUBREF
      PCODART(K)    = [F:YII0]ITMREF
      PYINDREF(K)   = [F:YII0]YINDREF
      PYINDDES(K)   = [F:YIS0]YINDDES
      PYSUBREF(K)   = [F:YII0]YSUBREF
      PYSUBDES(K)   = [F:YIS0]YSUBDES
      K += 1
    Next
    Filter [F:YII0]
  Next

  Close Local File [YII0],[YIS0]
End

#############################################################
# obtención de los ingredientes
Subprog GET_ITMLM(PITM,PYPRIT31,PYPRIT70,PSTOCK201)
  # parámetros de entrada
  Value     Char    PITM()(1..100)

  # parámetros de salida
  Variable  Decimal PYPRIT31(1..100)
  Variable  Decimal PYPRIT70(1..100)
  Variable  Decimal PSTOCK201(1..100)

  # declaración de variables locales
  Local Integer CONT                  : Raz CONT
  Local Integer I, J, K               : Raz I, J, K

  If !clalev([F:SPL0]) Then : Local File SPRICLIST  [F:SPL0] : Endif
  If !clalev([F:SPL1]) Then : Local File SPRICLIST  [F:SPL1] : Endif
  If !clalev([F:ITM0]) Then : Local File ITMMASTER  [F:ITM0] : Endif
  If !clalev([F:ITV0]) Then : Local File ITMMVT     [F:ITV0] : Endif

  # averigua la cantidad de OF's que se pretenden importar
  For I=1 To maxtab(PITM)
    If PITM(I) <> "" Then : CONT +=1 : Endif
  Next

  For J = 1 To CONT
    # devuelve el precio de la tarifa LM30
    Filter [F:SPL0] Where PLI = "LM30" and PLICRI1 = "002" and PLICRI2 = PITM(J) and PLISTRDAT <= date$ and PLIENDDAT >= date$
    Read   [F:SPL0] First
    If !fstat Then
      PYPVT201(J) = [F:SPL0]PRI
    Endif
    Filter [F:SPL0]

    # devuelve el precio de la tarifa T70
    Read [F:ITM0]ITM0 = PITM(J)
    Filter [F:SPL1] Where PLI = "T70" and PLICRI1 = "002" and PLICRI3 = [F:ITM0]TSICOD(2) and PLISTRDAT <= date$ and PLIENDDAT >= date$
    Read   [F:SPL1] First
    If !fstat Then
      PYPRIT70(J) = [F:SPL1]DCGVAL(1)
    Endif
    Filter [F:SPL1]

    # devuelve el stock disponible (Stock en A + Stock en Q - Stock asignado en A - Stock asignado en Q) en la planta 201
    Read [F:ITV0]ITV0 = PITM(J);"201"
    If !fstat Then
      PSTOCK201(J) = [F:ITV0]PHYSTO + [F:ITV0]CTLSTO - [F:ITV0]PHYALL - [F:ITV0]CTLALL
    Endif
  Next

  Close Local File [SPL0],[SPL1],[ITM0],[ITV0]
End



#####################################
############################################################
# obtención del listado de artículo entre fechas para el e-commerce
Subprog GET222(PINIDAT,PENDDAT,PITMREF,PITMDES1)

# parámetros de entrada
Value     Char    PINIDAT()
Value     Char    PENDDAT()

## parámetros de salida
Variable  Char    PITMREF()(1..10000)
Variable  Char    PITMDES1()(1..10000)

Local Date FECHAINI : FECHAINI = gdat$(val(left$(PINIDAT,2)),val(mid$(PINIDAT,3,2)),val(mid$(PINIDAT,5,4)))
Local Date FECHAFIN : FECHAFIN = gdat$(val(left$(PENDDAT,2)),val(mid$(PENDDAT,3,2)),val(mid$(PENDDAT,5,4)))

# declaración de variables locales
Local Integer J : J = 1

  If !clalev([F:ITM0]) Then : Local File ITMMASTER  [F:ITM0] : Endif
  Filter [F:ITM0] Where FECHAINI <= UPDDAT and FECHAFIN >= UPDDAT and ([F:ITM0]YB2BFLG = 2 or [F:ITM0]YB2CFLG = 2)
  Read   [F:ITM0] First
  If !fstat Then
    For [F:ITM0]
      PITMREF(J)  = [F:ITM0]ITMREF
      PITMDES1(J) = [F:ITM0]ITMDES1
      J            += 1
#      If J=1001 Then : Break : Endif
    Next
  Else
    Call MESSAGE("No se han encontrado resultados") From GESECRAN
  Endif
  Filter [F:ITM0]
  Close Local File [F:ITM0]
End

############################################################
# obtención de los campos de artículo para el e-commerce
Subprog GET_ITMSTOCK(PEXIST,PORIGEN,PITM,PLAN,PYSTDISWEB101,PYSTDISWEB201,PYSTDISOUTLET)

  # parámetros de entrada
  Value     Char    PORIGEN()(1..100)                   #1        valores: 'LVN' = la ventana natural ; 'PDM' = producciones dietéticas la mancha
  Value     Char    PITM()(1..100)                      #2
  Value     Char    PLAN()(1..100)                      #3

  # parámetros de salida
  Variable  Integer PEXIST(1..100)                      #4
  Variable  Decimal PYSTDISWEB101(1..100)               #5
  Variable  Decimal PYSTDISWEB201(1..100)               #6
  Variable  Decimal PYSTDISOUTLET(1..100)               #7

#  # declaración de variables locales
  Local Integer CONT                  : Raz CONT
  Local Integer I, J                  : Raz I, J

  # averigua la cantidad de OF's que se pretenden importar
  For I=1 To maxtab(PITM)
    If PITM(I) <> "" Then : CONT +=1 : Endif
  Next

  If !clalev([F:ITV0]) Then : Local File ITMMVT     [F:ITV0] : Endif
  If !clalev([F:ITM0]) Then : Local File ITMMASTER  [F:ITM0] : Endif
  If !clalev([F:STO0]) Then : Local File STOCK      [F:STO0] : Endif
  For J = 1 To CONT
    # si no es castellano, busca en la tabla de traducciones
    If PLAN(J) <> "SPA" Then
    Else
      Filter [F:ITM0] Where ITMREF = PITM(J) and [F:ITM0]YWEBFLG = 2
      Read [F:ITM0] First
      If !fstat Then
        Local Decimal LSTOCK,LSTOCKASIG : Raz LSTOCK,LSTOCKASIG
        # stock del artículo para La Ventana Natural
        PYSTDISWEB101(J) = 0
        Filter [F:STO0] Where STOFCY = "101" and ITMREF = PITM(J) and STA = "A" and (LOCTYP = "PIC" or LOCTYP = "ALM1" or LOCTYP = "ALM2" or LOCTYP = "INV")
        For [STO0]
          LSTOCK += [F:STO0]QTYPCU
        Next
        Read [F:ITV0]ITV0 = PITM(J);"101"
        If !fstat Then
          LSTOCKASIG = [F:ITV0]PHYALL + [F:ITV0]GLOALL
        Endif
        If (LSTOCK - LSTOCKASIG) > 10 Then
          PYSTDISWEB101(J) = LSTOCK - LSTOCKASIG
        Endif
        Filter [F:STO0]
        # stock del artículo para Producciones Dietéticas La Mancha
        Raz LSTOCK,LSTOCKASIG
        PYSTDISWEB201(J) = 0
        Filter [F:STO0] Where STOFCY = "201" and ITMREF = PITM(J) and STA = "A" and (LOCTYP = "PIC" or LOCTYP = "ALM1" or LOCTYP = "INV")
        For [STO0]
          LSTOCK += [F:STO0]QTYPCU
        Next
        Read [F:ITV0]ITV0 = PITM(J);"201"
        If !fstat Then
          LSTOCKASIG = [F:ITV0]PHYALL + [F:ITV0]GLOALL
        Endif
        PYSTDISWEB201(J) = LSTOCK - LSTOCKASIG
        Filter [F:STO0]
        # stock de artículo outlet
        Raz LSTOCK,LSTOCKASIG
        PYSTDISOUTLET(J) = 0
        Filter [F:STO0] Where STOFCY = "201" and ITMREF = PITM(J) and STA = "A" and LOCTYP = "98"
        For [STO0]
          LSTOCK += [F:STO0]QTYPCU
        Next
        Read [F:ITV0]ITV0 = PITM(J);"201"
        If !fstat Then
          LSTOCKASIG = [F:ITV0]PHYALL + [F:ITV0]GLOALL
        Endif
        If (LSTOCK - LSTOCKASIG) > 10 Then
          PYSTDISOUTLET(J) = LSTOCK - LSTOCKASIG
        Endif
        Filter [F:STO0]
      Else
        Call MESSAGE("El artículo"-PITM(J)-"no es gestionable en la web") From GESECRAN
        PEXIST(J)     = 0
      Endif
      Filter [F:ITM0]
    Endif
  Next J

  If clalev([F:ITV0])  Then : Close Local File      [F:ITV0] : Endif
  If clalev([F:ITM0])  Then : Close Local File      [F:ITM0] : Endif
  If clalev([F:STO0])  Then : Close Local File      [F:STO0] : Endif

End
