######################################################################################
## Después de modificar el campo 'Cantidad'
######################################################################################
Subprog AM_QTYUOM(VALEUR)
Variable Decimal VALEUR

# JC - 02/07/2020 - YN40 - STR
  # acción PAMVATFLG
  Local Char PARMSK(250)(1..20), SAVACT(20)
  SAVACT = GACTION : GACTION = "PAMVATFLG"
  PARMSK(1) = "PTH1"
  PARMSK(2) = num$(nolign-1)
  PARMSK(3) = "QTYUOM"
  Call S_AFF_NUM(VALEUR,PARMSK,"PAMVATFLG","TRTACHFAC1","") From GACTION
  GACTION   = SAVACT
#Infbox "3"-num$(mkstat)
  If mkstat : GERR = 1 : GZONE = "QTYUOM" : GZNUM = 2541 : Endif

#  Local Integer LCON : LCON = nolign-1
#  [M:PTH1]QTYUOM(LCON) = VALEUR
#  Gosub SET_TARIFAS

End

######################################################################################
## Antes de entrada al campo 'Tipo Ubicación'
######################################################################################
Subprog AS_LOCTYP(VALEUR)
Variable Char    VALEUR()
# YN01 - Parrilla de recepción
  If [M:PTH1]LOT(nolign-1) <> "" Then
    Gosub ACT_ESTADO
  Endif
# YN01 - Parrilla de recepción
End

