######################################################################################
## Después de modificar el campo 'Descuento 1 tar. prov'
######################################################################################
Subprog AM_YD1TP(VALEUR)
Variable Decimal VALEUR

  # actualiza el precio bruto en la pantalla
  [M:PTH1]DISCRGVAL1(nolign-1) = VALEUR
  Affzo [M:PTH1]DISCRGVAL1(nolign-1)

  # acción AM_QTYUOM
  Call AM_QTYUOM([M:PTH1]QTYUOM(nolign-1)) From SUBPTH

  # cálculo de la tasa de IVA
  Local Decimal PORIVA  : Raz PORIVA
  Local Decimal TAXIVA  : Raz TAXIVA
  If !clalev([F:TRA0]) Then : Local File TABRATVAT [F:TRA0] : Endif
  Filter [F:TRA0] Where VAT = [M:PTH1]VAT1(nolign-1) and LEG = GCURLEG and STRDAT <= [M:PTH0]RCPDAT Order By STRDAT Desc
  Read [F:TRA0] First
  If !fstat Then
    PORIVA = [F:TRA0]VATRAT
  Endif
  Filter [F:TRA0]
  Close Local File [TRA0]
  TAXIVA = ar2(([M:PTH1]NETPRI(nolign-1) * PORIVA) / 100)
  [M:PTH1]LINATIAMT(nolign-1) = [M:PTH1]QTYUOM(nolign-1) * ([M:PTH1]NETPRI(nolign-1) + TAXIVA)
  Affzo [M:PTH1]LINATIAMT(nolign-1)
  [M:PTH1]AMTTAXLIN1(nolign-1) = [M:PTH1]QTYUOM(nolign-1) * TAXIVA
  Affzo [M:PTH1]AMTTAXLIN1(nolign-1)
  [M:PTH1]DEDTAXLIN1(nolign-1) = [M:PTH1]QTYUOM(nolign-1) * TAXIVA
  Affzo [M:PTH1]DEDTAXLIN1(nolign-1)

End

