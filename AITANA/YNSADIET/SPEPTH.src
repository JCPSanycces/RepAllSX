$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "DEBUT"        : Gosub DEBUT
  When "SETBOUT"      : Gosub SETBOUT
  When "LIENS_LIG"    : Gosub LIENS_LIG
  When "APRES_CRE"    : Gosub APRES_CRE
  When "APRES_MOD"    : Gosub APRES_MOD
  When "FIN"          : Gosub FIN
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
#  Global Integer GNUMLIN
  Gosub ABRIR_TABLAS
Return

##############################################################
$DEBUT
# JC - 02/07/2020 - YN40 - STR
  Local Integer LCON : Raz LCON
  For LCON = 0 To [M:PTH1]NBLIG-1
    Gosub SET_TARIFAS
  Next
  Kill LCON
# JC - 02/07/2020 - YN40 - END
Return

##############################################################
$SETBOUT
# JC - 02/07/2020 - YN40 - STR
  Local Integer LCON : Raz LCON
  For LCON = 0 To [M:PTH1]NBLIG-1
    Gosub SET_TARIFAS
  Next
  Kill LCON
# JC - 02/07/2020 - YN40 - END
Return
##############################################################
$LIENS_LIG

# JC - 02/07/2020 - YN40 - STR
#  Gosub LIENS_LIG From SUBPTHA                 # COMENTO LAS 3 LÍNEAS PORQUE DA ERROR AL ENTRAR EN LA PANTALLA DE RECEPCIONES
#  Gosub SET_TARIFAS                            # PENDIENTE DE REVISAR CON MARIO
#  GPE = 1                                      # !!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!!
# JC - 02/07/2020 - YN40 - END

Return

##############################################################
$APRES_CRE
## JC - 02/07/2020 - YN40 - STR
#  # actualiza las tarifas T35, T40 y T31
#  Gosub ACT_TARIFAS
#
#  # actualiza PVP
#  Gosub ACT_PVP
#
## JC - 02/07/2020 - YN40 - END

Return

##############################################################
$APRES_MOD
# JC - 02/07/2020 - YN40 - STR
  # actualiza las tarifas T35, T40 y T31
  Gosub ACT_TARIFAS

  # actualiza PVP
  Gosub ACT_PVP

# JC - 02/07/2020 - YN40 - END

Return

##############################################################
$FIN
  Gosub CERRAR_TABLAS
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ABRIR_TABLAS
# YN01 - Parrilla de recepción
  If !clalev([F:YTR0]) Then : Local File YMFGTRAZAPR [F:YTR0] : Endif
# YN01 - Parrilla de recepción
Return

##############################################################
$CERRAR_TABLAS
# YN01 - Parrilla de recepción
  If clalev([F:YTR0])  Then : Close Local File     [F:YTR0] : Endif
# YN01 - Parrilla de recepción
Return

##############################################################
# YN01 - Parrilla de recepción
# muestra el estado para un artículo/lote si se le ha cambiado
# desde la parrilla de recepción
$ACT_ESTADO
#If GUSER="AIT07" Then : Infbox [M:PTH1]LOT(nolign-1) : Endif
  Filter [F:YTR0] Where ITMREF = [M:PTH1]ITMREF(nolign-1) and LOT = [M:PTH1]LOT(nolign-1) Order By UPDDATTIM Desc
  Read   [F:YTR0] First
  If !fstat Then
    [M:PTH1]STA(nolign-1) = [F:YTR0]STA
    Affzo [M:PTH1]STA(nolign-1)
  Endif
  Filter [F:YTR0]

Return

##############################################################
$SET_TARIFAS

  If !clalev([F:PPL0]) Then : Local File PPRICLIST [F:PPL0] : Endif
  If !clalev([F:SPL0]) Then : Local File SPRICLIST [F:SPL0] : Endif
  If !clalev([F:SPL1]) Then : Local File SPRICLIST [F:SPL1] : Endif
  If !clalev([F:ITM0]) Then : Local File ITMMASTER [F:ITM0] : Endif

  # busca precio tarifa proveedor y descuento 1 en T35
  Filter [F:PPL0] Where PLI = "T35" and [M:PTH0]RCPDAT >= PLISTRDAT and [M:PTH0]RCPDAT <= PLIENDDAT and PLICRI1 = "002" and PLICRI2 = [M:PTH0]BPSNUM and
& PLICRI3 = [M:PTH1]ITMREF(LCON) and [M:PTH1]QTYUOM(LCON) >= MINQTY and [M:PTH1]QTYUOM(LCON) <= MAXQTY
  Read [F:PPL0] First
  If !fstat Then
    [M:PTH1]YPTP(LCON)    = [F:PPL0]PRI
    [M:PTH1]YD1TP(LCON)   = [F:PPL0]DCGVAL
    Affzo [M:PTH1]YPTP(LCON)
    Affzo [M:PTH1]YD1TP(LCON)
  Endif
  Filter [F:PPL0]

  # busca precio tarifa venta LM50
  Filter [F:SPL0] Where PLI = "LM50" and [M:PTH0]RCPDAT >= PLISTRDAT and [M:PTH0]RCPDAT <= PLIENDDAT and PLICRI1 = [M:PTH1]ITMREF(LCON) and
& [M:PTH1]QTYUOM(LCON) >= MINQTY and [M:PTH1]QTYUOM(LCON) <= MAXQTY
  Read [F:SPL0] First
  If !fstat Then
    [M:PTH1]YPTV999(LCON) = [F:SPL0]PRI
    Affzo [M:PTH1]YPTV999(LCON)
  Endif
  Filter [F:SPL0]

  # busca precio tariva venta LM30
  Filter [F:SPL1] Where PLI = "LM30" and [M:PTH0]RCPDAT >= PLISTRDAT and [M:PTH0]RCPDAT <= PLIENDDAT and PLICRI1 = "002" and PLICRI2 = [M:PTH1]ITMREF(LCON) and
& [M:PTH1]QTYUOM(LCON) >= MINQTY and [M:PTH1]QTYUOM(LCON) <= MAXQTY
  Read [F:SPL1] First
  If !fstat Then
    [M:PTH1]YPTVLMC(LCON) = [F:SPL1]PRI
    Affzo [M:PTH1]YPTVLMC(LCON)
  Endif
  Filter [F:SPL1]

  # busca PVP
  Read [F:ITM0]ITM0 = [M:PTH1]ITMREF(LCON)
  If !fstat Then
    [M:PTH1]YPVP(LCON)    = [F:ITM0]YPVP
    Affzo [M:PTH1]YPVP(LCON)
  Endif

  Close Local File [PPL0],[SPL0],[SPL1],[ITM0]

Return

##############################################################
$ACT_TARIFAS

# JC - 02/07/2020 - YN40 - STR
Local Integer I
If !clalev([F:PPL0]) Then : Local File PPRICLIST [F:PPL0] : Endif
If !clalev([F:SPL0]) Then : Local File SPRICLIST [F:SPL0] : Endif
If !clalev([F:SPL1]) Then : Local File SPRICLIST [F:SPL1] : Endif

  For I = 0 To [M:PTH1]NBLIG-1
    # actualiza la tarifa T35
    Filter [F:PPL0] Where PLI = "T35" and [M:PTH0]RCPDAT >= PLISTRDAT and [M:PTH0]RCPDAT <= PLIENDDAT and PLICRI1 = "002" and PLICRI2 = [M:PTH0]BPSNUM and
&   PLICRI3 = [M:PTH1]ITMREF(I) and [M:PTH1]QTYUOM(I) >= MINQTY and [M:PTH1]QTYUOM(I) <= MAXQTY
    For [F:PPL0]
      Trbegin [F:PPL0]
      If [M:PTH1]YPTP(I)  > 0 Then : [F:PPL0]PRI     = [M:PTH1]YPTP(I)  : Endif
      If [M:PTH1]YD1TP(I) > 0 Then : [F:PPL0]DCGVAL  = [M:PTH1]YD1TP(I) : Endif
      Rewrite [F:PPL0]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Next
    Filter [F:PPL0]

    # actualiza la tarifa LM50
    Filter [F:SPL0] Where PLI = "LM50" and [M:PTH0]RCPDAT >= PLISTRDAT and [M:PTH0]RCPDAT <= PLIENDDAT and PLICRI1 = [M:PTH1]ITMREF(I) and
&   [M:PTH1]QTYUOM(I) >= MINQTY and [M:PTH1]QTYUOM(I) <= MAXQTY
    For [F:SPL0]
      Trbegin [F:SPL0]
      If [M:PTH1]YPTV999(I) > 0  Then : [F:SPL0]PRI   = [M:PTH1]YPTV999(I) : Endif
      Rewrite [F:SPL0]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Next
    Filter [F:SPL0]

    # actualiza la tarifa LM30
    Filter [F:SPL1] Where PLI = "LM30" and [M:PTH0]RCPDAT >= PLISTRDAT and [M:PTH0]RCPDAT <= PLIENDDAT and PLICRI1 = "002" and PLICRI2 = [M:PTH1]ITMREF(I) and
&   [M:PTH1]QTYUOM(I) >= MINQTY and [M:PTH1]QTYUOM(I) <= MAXQTY
    For [F:SPL1]
      Trbegin [SPL1]
      If [M:PTH1]YPTVLMC(I) > 0 Then : [F:SPL1]PRI   = [M:PTH1]YPTVLMC(I) : Endif
      Rewrite [F:SPL1]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Next
    Filter [F:SPL1]

  Next

Kill I
Close Local File [PPL0],[SPL0],[SPL1]
# JC - 02/07/2020 - YN40 - END

Return

##############################################################
$ACT_PVP

# JC - 02/07/2020 - YN40 - STR
Local Integer I
If !clalev([F:ITM0]) Then : Local File ITMMASTER [F:ITM0] : Endif

  For I = 0 To [M:PTH1]NBLIG-1
    Read [F:ITM0]ITM0 = [M:PTH1]ITMREF(I)
    If !fstat Then
      Trbegin [F:ITM0]
      [F:ITM0]YPVP    = [M:PTH1]YPVP(I)
      Rewrite [F:ITM0]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Endif
  Next

Kill I
Close Local File [ITM0]
# JC - 02/07/2020 - YN40 - END

Return
##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Después de modificar el campo 'Lote proveedor'
######################################################################################
Subprog AM_BPSLOT(VALEUR)
Variable Char    VALEUR()
  [M:PTH1]YLOT(nolign-1) = VALEUR
  Affzo [M:PTH1]YLOT(nolign-1)
  [M:PTH1]LOT(nolign-1) = VALEUR
  Affzo [M:PTH1]LOT(nolign-1)
  If VALEUR <> "" Then
    Gosub ACT_ESTADO
  Endif
End

