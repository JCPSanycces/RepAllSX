#If GUSER="AIT07" Then : Infbox ACTION : Endif
#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog VERIF_GMAO(VOF)
Value Char VOF

If !clalev([YY3]) : Local File MFGHEAD    [YY3] : Endif
If !clalev([YY4]) : Local File TABROUALT  [YY4] : Endif

Read [YY3]MFG0 = VOF
If fstat = 0
  Read [YY4]TRO0 = [YY3]ROUALT
    If [YY4]YPREVGMAO = 2 Then
      [YY3]YMNTOTYP = 3
      Rewrite [YY3]

      # Si es una OF de preventivo, actualizo la fecha en la Gama
      If !clalev([YY0]) : Local File WORKSTATIO [YY0] : Endif
      If !clalev([YY1]) : Local File YGAMAD     [YY1] : Endif

      Read [YY0]WST0 = [YY3]ROUNUM;[YY3]MFGFCY
      If fstat = 0
        Read [YY1]YGD1 = [YY0]YGAMA;[YY3]ROUALT
        If fstat = 0
           [YY1]FECHAULT = [YY3]STRDAT
           Rewrite [YY1]
        Endif
      Endif

      Close Local File [YY0],[YY1],[YY3],[YY4]

    Endif
Endif
End

##############################################################
$AITMWS_ABRIR_TABLAS
  If !clalev([F:YMP0]) Then : Local File YMNTOCT    [F:YMP0] : Endif
  If !clalev([F:YMP1]) Then : Local File YMNTOCT    [F:YMP1] : Endif
  If !clalev([F:YMP2]) Then : Local File YMNTOCT    [F:YMP2] : Endif
  If !clalev([F:YMP3]) Then : Local File YMNTOCT    [F:YMP3] : Endif
  If !clalev([F:MFO0]) Then : Local File MFGOPE     [F:MFO0] : Endif
  If !clalev([F:MFH0]) Then : Local File MFGHEAD    [F:MFH0] : Endif
  If !clalev([F:YGC0]) Then : Local File YGAMAC     [F:YGC0] : Endif
Return

##############################################################
$AITMWS_CERRAR_TABLAS
  Close Local File [YMP0],[YMP1],[YMP2],[YMP3],[MFO0],[MFH0],[YGC0]
Return

##############################################################
$AITMWS_SETBOUT
  If [M:YMP1]YGESFLG <> 2 Then
    Grizo [M:YMP1]YUDCRTL, YCANTIDAD, YUNIDAD, YBLKLN
  Else
    Actzo [M:YMP1]YUDCRTL, YCANTIDAD, YUNIDAD, YBLKLN
  Endif
Return

##############################################################
$AITMWS_LIENS
  Read [F:YMP3]YMP0 = [M:MWS0]WST;[M:MWS0]WCRFCY
  If !fstat Then
    [M:YMP1] = [F:YMP3]
    Affzo [M:YMP1]
  Endif
Return


##############################################################
$AITMWS_MODIF
  Gosub MODIF From SUBMWS
  Gosub MODIF From SUBMWS2
  Gosub MODIF From SUBMWS3
  Read [F:YMP0]YMP0 = [M:MWS0]WST;[M:MWS0]WCRFCY
  If !fstat Then
    [F:YMP0] = [M:MWS0]
    [F:YMP0] = [M:YMP1]
    Rewrite [F:YMP0]                                                    # actualización del registro
  Else
    [F:YMP0] = [M:MWS0]
    [F:YMP0] = [M:YMP1]
    Write [F:YMP0]                                                      # creación del registro
  Endif
  GPE=1
Return

##############################################################
$AITMWS_CREATION
  Gosub CREATION From SUBMWS
  Gosub CREATION From SUBMWS2
  Gosub CREATION From SUBMWS3
  [F:YMP1] = [M:MWS0]
  [F:YMP1] = [M:YMP1]
  Write [F:YMP1]
  GPE=1
Return


##############################################################
$AITMWS_ANNULE
  Gosub ANNULE From SUBMWS
  Gosub ANNULE From SUBMWS2
  Gosub ANNULE From SUBMWS3
  Delete [F:YMP2] Where [F:YMP2]WST = [M:MWS0]WST and [F:YMP2]WCRFCY = [M:MWS0]WCRFCY and [F:YMP2]WCR = [M:MWS0]WCR
  GPE=1
Return

##############################################################
$AITMWS_SEL_YSELBOMITM
  If !clalev([F:YVB0]) Then : Local File YVISBOMITM [F:YVB0] : Endif
  Default File [YVB0]
  Filter [F:YVB0] Where LANGUE = GLANGUE                                    # filtra sólo las de producción
  NBCOL       = 0                                                           # número de la columna
  TIT(NBCOL)  = "Selección estructuras"                                     # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Cód. artículo"                                             # título de la segunda columna
  COL(NBCOL)  = "ITMREF"                                                    # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                               # título de la tercera columna
  COL(NBCOL)  = "TEXTE"                                                     # nombre del campo a mostrar en la tercera columna
Return


##############################################################
$AITMWS_VERF_YSELBOMITM
Return

##############################################################
Subprog AITMWS_AM_YGESFLG(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    Actzo [M:YMP1]YUDCRTL, YCANTIDAD, YUNIDAD, YBLKLN
  Else
    Grizo [M:YMP1]YUDCRTL, YCANTIDAD, YUNIDAD, YBLKLN
  Endif
End

##############################################################
Subprog AITMWS_AM_YUNIDAD(VALEUR)
Variable Integer VALEUR
  Raz GMENLOC
  Case [M:YMP1]YUDCRTL
    When 1 : GMENLOC(2)=1 : GMENLOC(3)=1 : GMENLOC(4)=1 : GMENLOC(5)=1
    When 2 : GMENLOC(1)=1 : GMENLOC(5)=1
    When 3 : GMENLOC(1)=1 : GMENLOC(2)=1 : GMENLOC(3)=1 : GMENLOC(4)=1
  Endcase
End

##############################################################
Subprog AITMWS_AS_YUDUSO(VALEUR)
Variable Integer VALEUR
  Raz GMENLOC
  GMENLOC(1)=1 : GMENLOC(5)=1
End


##############################################################
Subprog AITMWS_CL_YICOINFO(VALEUR)
Variable Integer VALEUR

Call AITMWS_MUESTRA_HISTORICO_OFS([M:MWS0]WST)

Local Char    CTPREACT(50)
Local Decimal SUMCPLQTY, SUMCPLTIM
Local Date    LASTMFG
  Call GET_WSTSINMNTO([M:YMWS2]YCTPREACTOR,[M:MWS0]WCRFCY,CTPREACT) From SPEYLIB0     # devuelve el CT sin mantenimiento ligado al CT de Preactor
  #Call GET_LASTMFG([M:MWS0]WST,LASTMFG) From SPEYLIB0                                 # devuelve la fecha de la última OF del CT que lanza el proceso
  # La fecha del último mantenimiento la busco directamente de la pantalla de centros de trabajo
  If [M:YMP1]FECHAULTIMOM <> [00/00/0000]
   LASTMFG = [M:YMP1]FECHAULTIMOM
  Else
   LASTMFG = [01/01/1753]
  Endif

  Call GET_CPLQTY(CTPREACT,LASTMFG,SUMCPLQTY,SUMCPLTIM) From SPEYLIB0                 # devuelve cantidad y tiempo desde la última OF del CT
  [M:YMP1]YHORASUSO = SUMCPLTIM
  Case [M:YMP1]YUDUSO
    When 2 : [M:YMP1]YTNUSO = arr((SUMCPLTIM / 24),0.001)                             # tiempo en días
    When 3 : [M:YMP1]YTNUSO = arr(((SUMCPLTIM / 24) / 7),0.001)                       # tiempo en semanas
    When 4 : [M:YMP1]YTNUSO = arr((((SUMCPLTIM / 24) / 7) / 30),0.001)                # tiempo en meses
  Endcase
  [M:YMP1]YCTDUSO   = SUMCPLQTY
  Affzo [M:YMP1]YHORASUSO,YTNUSO,YCTDUSO
End

##############################################################
Subprog AITMWS_AM_YUDCRTL(VALEUR)
Variable Integer VALEUR
  [M:YMP1]YUNIDAD = 6
  Affzo [M:YMP1]YUNIDAD
End

######################################################################################
Subprog AITMWS_AM_YUDUSO(VALEUR)
Variable Integer VALEUR
  Case VALEUR
    When 2 : [M:YMP1]YTNUSO = arr(([M:YMP1]YHORASUSO / 24),0.001)
    When 3 : [M:YMP1]YTNUSO = arr((([M:YMP1]YHORASUSO / 24) / 7),0.001)
    When 4 : [M:YMP1]YTNUSO = arr(((([M:YMP1]YHORASUSO / 24) / 7) / 30),0.001)
  Endcase
  Affzo [M:YMP1]YTNUSO
End


######################################################################################
Subprog AITMWS_AM_YGAMA(VALEUR)
Variable Char    VALEUR()
  Read [F:YGC0]YGC0 = VALEUR
  If !fstat Then
    [M:YMP1]YGAMADES = [F:YGC0]DESGAMA
    Affzo [M:YMP1]YGAMADES
  Endif
End

#**
#* muestra histórico de OF's
#*
#* @param PWST      > centro de trabajo
#*!
Subprog AITMWS_MUESTRA_HISTORICO_OFS(PWST)
Value     Char    PWST

Local Integer LCON0 : Raz LCON0

  # Saco la línea a la que está asociado el CT de mantenimiento
  Local Char LINE : LINE = [M:YMWS2]YCTPREACTOR    # CT de mantenimiento
  Local Char CT_LINE                  # CT que define la línea asociada al CT de mantenimiento
  If LINE <> ""

  If !clalev([F:YX01]) Then : Local File WORKSTATIO   [F:YX01] : Endif
  If !clalev([F:YX02]) Then : Local File YMNTOCT      [F:YX02] : Endif

  For [YX01] Where [YX01]WCRFCY = [M:MWS0]WCRFCY and [YX01]YCTPREACTOR = LINE
#Infbox num$([YX01]WST)
#Infbox num$([YX01]WCRFCY)
      Read [YX02]YMP0 = [YX01]WST;[YX01]WCRFCY
    If (fstat = 0 and [YX02]YGESFLG <> 2) or fstat <> 0
    CT_LINE = [YX01]WST
    Break
    Endif
  Next
#Infbox num$(CT_LINE)
  Close Local File [YX01],[YX02]
  Endif
  Link [MFO0] With [MFH0]MFG0=[F:MFO0]MFGNUM As [LNK] Where [F:MFO0]EXTWST = CT_LINE and [F:MFH0]STRDAT >= [M:YMP1]FECHAULTIMOM Order By [F:MFH0]STRDAT Asc
  Columns [LNK] ([MFH0]MFGNUM,[MFH0]STRDAT,[MFO0])                      # muestro sólo aquellos campos que me hacen falta
  For [LNK]
    [M:YMP1]MFGNUM(LCON0) = [F:MFH0]MFGNUM
    [M:YMP1]STRDAT(LCON0) = [F:MFH0]STRDAT
    LCON0 += 1
  Next
  [M:YMP1]NBOFM = LCON0
  Affzo [M:YMP1]20

End


##############################################################
$AITMFG_INICRE
If GFLAG = "YNS99"
    Local Char    LNUM
    Local Integer LSTAT
    Local Char    LCONTMFG(15)

    Read [F:FCY0]FCY0 = [M:MFG0]MFGFCY
    If !fstat Then
     If [M:MFG0]YMNTOTYP = 3 Then
        LCONTMFG = [F:FCY0]YCONTOFP         # contador
      Elsif [M:MFG0]YMNTOTYP = 4
        LCONTMFG  = [F:FCY0]YCONTOFC        # contador
      Endif
    Endif
    Call NUMERO(LCONTMFG, [M:MFG0]MFGFCY, [M:MFG1]STRDAT, "", LNUM, LSTAT)  From SUBANM
#    Call NUMERO("YOFGM", [M:MFG0]MFGFCY, [M:MFG1]STRDAT, "", LNUM, LSTAT)  From SUBANM
    If GOK=0 | LSTAT<>0
        GOK=0 : GERR=1 : GMESSAGE=GCODNUM-mess(60,199,1)
    Endif

    If GOK = 0 or LSTAT <> 0 Then
        Return
    Elsif LNUM = "" Then
        GOK = 0: GERR = 1
        Return
    Endif

    #Actualizamos el campo.
    [M:MFG0]MFGNUM  = LNUM
    [F:MFG]MFGNUM   = LNUM
    Affzo [M:MFG0]MFGNUM

Endif
Return


##############################################################
$AITMFG_OUVRE
  If !clalev([F:FCY0]) Then : Local File FACILITY [F:FCY0] : Endif
Return

##############################################################
$AITMFG_FIN
  Close Local File [FCY0]
Return


######################################################################################
# con este código controlamos que si se accede a la pantalla desde una opción diferente
# a un modelo de importación, no se pueda modificar el campo
Subprog AITMFG_AS_YMNTOTYP(VALEUR)
Variable Integer VALEUR
# Si estoy en transacción de GMAO propongo valor. Sino lo pongo vacío y no dejo entrar
If !GIMPORT
  If (GFLAG = "YNS99") and GREP = "C" and VALEUR < 2
    VALEUR =  4  # Correctivo
  Endif
Endif
End


######################################################################################
Subprog AITMFG_AM_YMNTOTYP(VALEUR)
Variable Integer VALEUR
If !GIMPORT
  If VALEUR < 3 and GFLAG = "YNS99"
    Infbox "Debe seleccionar Orden de Mto. Mantenimiento Correctivo o Preventivo"
    VALEUR =  4  # Correctivo
  Else
    If GFLAG <> "YNS99" and VALEUR > 2
     Infbox "Orden de Fabricación"
     VALEUR = 1
    Endif
  Endif
Endif
End


######################################################################################
Subprog AITMFG_AS_YTIPOM(VALEUR)
Variable Integer VALEUR

  If [M:MFG0]YMNTOTYP = 1 or [M:MFG0]YMNTOTYP = 2 Then
    VALEUR = 1
    mkstat = 2
  Else
    VALEUR = 2
  Endif

End


######################################################################################
Subprog AITMFG_AM_ITMREF(VALEUR)
Variable Char    VALEUR()
  If [M:MFG0]YMNTOTYP >= 2
    Read [F:FCY0]FCY0 = [M:MFG0]MFGFCY
    If !fstat Then
      [M:MFG1]BOMALT(nolign-1) = [F:FCY0]YBOMALT
      Affzo [M:MFG1]BOMALT(nolign-1)
    Endif
  Endif
End

