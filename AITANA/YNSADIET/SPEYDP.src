# YN02 - Parrilla de producción
# Fecha inicio YN02: 16/08/2019
# Desarrollador: JCH
# Código de desarrollo: YN02
# Descripción del desarrollo: Parrilla de elementos de fabricación
# Fecha: 16/08/2019
# Codigo Actividad: YYN02
#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "DEBUT"      : Gosub DEBUT
  When "BOUTON"     : Gosub BOUTON
  When "FIN"        : Gosub FIN
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
  Gosub ABRIR_TABLAS
Return

##############################################################
$DEBUT
  Gosub MUESTRA_DOCUMENTOS
  [M:YOP0]FECHA   = date$
  [M:YOP0]USUARIO = GUSER
  Affzo [M:YOP0]FECHA,USUARIO
Return

##############################################################
$BOUTON
  Case BOUT
    When "a"  : Gosub AGREGAR_DOC
    When "e"  : Gosub ELIMINAR_DOC
  Endcase
Return

##############################################################
$FIN
  Gosub CERRAR_TABLAS
  Raz [M:YOP0]
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ABRIR_TABLAS
  If !clalev([F:YOP0]) Then : Local File YMFGDOCPP  [F:YOP0] : Endif
  If !clalev([F:YOP1]) Then : Local File YMFGDOCPP  [F:YOP1] : Endif
  If !clalev([F:YOP2]) Then : Local File YMFGDOCPP  [F:YOP2] : Endif
  If !clalev([F:YOP3]) Then : Local File YMFGDOCPP  [F:YOP3] : Endif
  If !clalev([F:YOP4]) Then : Local File YMFGDOCPP  [F:YOP4] : Endif
Return

##############################################################
$CERRAR_TABLAS
  If clalev([F:YOP0])  Then : Close Local File      [F:YOP0] : Endif
  If clalev([F:YOP1])  Then : Close Local File      [F:YOP1] : Endif
  If clalev([F:YOP2])  Then : Close Local File      [F:YOP2] : Endif
  If clalev([F:YOP3])  Then : Close Local File      [F:YOP3] : Endif
  If clalev([F:YOP4])  Then : Close Local File      [F:YOP4] : Endif
Return

##############################################################
$MUESTRA_DOCUMENTOS
Local Integer LCON0 : Raz LCON0
  Filter [F:YOP0] Where MFGNUM = GPARAM1(0) and MFGTIPO = val(GPARAM1(1))
  For [YOP0]
    [M:YOP0]IDDOCL(LCON0)    = [F:YOP0]IDDOC
    [M:YOP0]FECHAL(LCON0)    = [F:YOP0]FECHA
    [M:YOP0]USUARIOL(LCON0)  = [F:YOP0]USUARIO
    [M:YOP0]DOCNAML(LCON0)   = [F:YOP0]DOCNAM
    [M:YOP0]DOCPATHL(LCON0)  = [F:YOP0]DOCPATH
    [M:YOP0]OBSERVAL(LCON0)  = [F:YOP0]OBSERVA
    LCON0 += 1
  Next
  Filter [F:YOP0]
  [M:YOP0]NBLIG = LCON0
  Affzo [M:YOP0]10
Return

##############################################################
$AGREGAR_DOC
Local Integer NUMDOC : Raz NUMDOC

  Filter [F:YOP2] Where MFGNUM = GPARAM1(0) and MFGTIPO = val(GPARAM1(1)) Order By IDDOC Desc
  Read [F:YOP2] First
  If !fstat Then
    NUMDOC = [F:YOP2]IDDOC + 1
  Endif
  Filter [F:YOP2]

  Filter [F:YOP3] Where MFGNUM = GPARAM1(0) and MFGTIPO = val(GPARAM1(1)) and DOCNAM = [M:YOP0]DOCNAM and DOCPATH = [M:YOP0]DOCPATH Order By IDDOC Desc
  Read [F:YOP3] Last
  If !fstat Then
    Call ERREURT("El documento ya existe",1) From GESECRAN
  Else
    Trbegin [F:YOP3]
    [F:YOP3] = [M:YOP0]
    [F:YOP3]MFGNUM  = GPARAM1(0)
    [F:YOP3]MFGTIPO = val(GPARAM1(1))
    [F:YOP3]IDDOC   = NUMDOC
    [F:YOP3]USUARIO = GUSER
    [F:YOP3]OBSERVA = [M:YOP0]OBSERVA
    Write [F:YOP3]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif
  Filter [F:YOP3]

  Gosub MUESTRA_DOCUMENTOS

Return

##############################################################
$ELIMINAR_DOC
  Trbegin [F:YOP4]
  Delete [YOP4] Where MFGNUM = GPARAM1(0) and MFGTIPO = val(GPARAM1(1)) and DOCNAM = [M:YOP0]DOCNAM and DOCPATH = [M:YOP0]DOCPATH
  If !fstat Then
    Commit
    Raz [M:YOP0]DOCNAM,OBSERVA
    Affzo [M:YOP0]DOCNAM,OBSERVA
    Call MESSAGE("Documento eliminado") From GESECRAN
  Else
    Rollback
    Call ERREURT("El documento no existe",1) From GESECRAN
  Endif

  Gosub MUESTRA_DOCUMENTOS

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Antes entrada NBLIG
## Muestra información en el bloque de datos cada vez que se mueve por el bloque
## de las líneas de documentos
######################################################################################
Subprog AS_NBLIG
  Read [F:YOP1]YOP0 = GPARAM1(0);val(GPARAM1(1));[M:YOP0]IDDOCL(nolign-1)
  If !fstat Then
    [M:YOP0] = [F:YOP1]
    Affzo [M:YOP0]5
  Endif
End

######################################################################################
## Botón 1 en NBLIG
## Visualiza el documento
######################################################################################
Subprog B1_NBLIG
Local Char LRUTA(250) : LRUTA = [M:YOP0]DOCNAML(nolign-1)

  If !GWEBSERV & LRUTA<>""
   Local Char SAVVAL(20)
   SAVVAL = LRUTA
    ## Action ASYRVISU
    Local Char    PARMSK(250)(1..20) , SAVACT(20)
    SAVACT = GACTION : GACTION = "ASYRVISU"
    PARMSK(1) = LRUTA
    VALEUR = LRUTA
    Call TRAITE_CHAR(LRUTA,PARMSK,"","ASYRVISU","",1,"") From GTRAITE
    GACTION = SAVACT
   LRUTA = SAVVAL
  Endif
End

######################################################################################
## Después de modificar el campo 'Observaciones'
######################################################################################
Subprog AM_OBSERVA(VALEUR)
Variable Clbfile VALEUR
  zonsui = "[M:YOP0]DOCNAM"
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

