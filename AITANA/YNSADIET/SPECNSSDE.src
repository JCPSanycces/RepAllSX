# YYN13 - Ajustes en el campo 'Comentario 3' del artículo-lote
# Fecha inicio YYN13: 12/02/2020
# Desarrollador: JCH
# Codigo Actividad: YYN13
#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox "1"-ACTION : Endif
Case ACTION
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ABRIR_TABLAS
  If !clalev([F:SLH0]) Then : Local File SLOTMH [F:SLH0] : Endif
  If !clalev([F:STO0]) Then : Local File STOCK  [F:STO0] : Endif
  If !clalev([F:STJ0]) Then : Local File STOJOU [F:STJ0] : Endif
  If !clalev([F:STL0]) Then : Local File STOLOT [F:STL0] : Endif
Return

##############################################################
$CERRAR_TABLAS
  If clalev([F:SLH0])  Then : Close Local File  [F:SLH0] : Endif
  If clalev([F:STO0])  Then : Close Local File  [F:STO0] : Endif
  If clalev([F:STJ0])  Then : Close Local File  [F:STJ0] : Endif
  If clalev([F:STL0])  Then : Close Local File  [F:STL0] : Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## 'Después de modificar' el campo 'Comentario 3'
######################################################################################
Subprog AM_YUSRFLD3(VALEUR)
Variable Char    VALEUR()

Local Char FILTRO(250)

  Gosub ABRIR_TABLAS

# opción de filtro 1 (artículo, lote)
  FILTRO =  "ITMREF = [M:SDE1]ITMREF and LOT = [M:SDE2]LOT(nolign-1)"

# opción de filtro 2 (artículo, lote, comentario 1, comentario 2, comentario 3)
#  FILTRO =  "ITMREF = [M:SDE1]ITMREF and LOT = [M:SDE2]LOT(nolign-1) and USRFLD1 = [M:SDE2]USRFLD1(nolign-1) and USRFLD2 = [M:SDE2]USRFLD2(nolign-1) and "
#  FILTRO += "YUSRFLD3 = [M:SDE2]YUSRFLD3(nolign-1)"

# opción de filtro 3 (artículo, lote, comentario 1, comentario 2, comentario 3, estado)
#  FILTRO =  "ITMREF = [M:SDE1]ITMREF and LOT = [M:SDE2]LOT(nolign-1) and USRFLD1 = [M:SDE2]USRFLD1(nolign-1) and USRFLD2 = [M:SDE2]USRFLD2(nolign-1) and "
#  FILTRO += "YUSRFLD3 = [M:SDE2]YUSRFLD3(nolign-1) and STA = [M:SDE2]STA(nolign-1)"

# opción de filtro 4 (artículo, lote, comentario 1, comentario 2, comentario 3, estado, ubicación)
#  FILTRO =  "ITMREF = [M:SDE1]ITMREF and LOT = [M:SDE2]LOT(nolign-1) and USRFLD1 = [M:SDE2]USRFLD1(nolign-1) and USRFLD2 = [M:SDE2]USRFLD2(nolign-1) and "
#  FILTRO += "YUSRFLD3 = [M:SDE2]YUSRFLD3(nolign-1) and STA = [M:SDE2]STA(nolign-1) and LOC = [M:SDE2]LOC(nolign-1)"

#  # actualiza 'Comentario 3' en la tablas SLOTMH
#  Filter [F:SLH0] Where ITMREF = [M:SDE1]ITMREF and LOT = [M:SDE2]LOT(nolign-1) and USRFLD1 = [M:SDE2]USRFLD1(nolign-1) and
#& USRFLD2 = [M:SDE2]USRFLD2(nolign-1) and YUSRFLD3 = [M:SDE2]YUSRFLD3(nolign-1)
#  For [SLH0]
#    Trbegin [SLH0]
#    [F:SLH0]YUSRFLD3 = VALEUR
#    Rewrite [F:SLH0]
#    If !fstat Then
#      Commit
#    Else
#      Rollback
#    Endif
#  Next
#  Filter [F:SLH0]

  # actualiza 'Comentario 3' en la tablas STOCK
  Filter [F:STO0] Where evalue(FILTRO)
  For [STO0]
    Trbegin [STO0]
    [F:STO0]YUSRFLD3 = VALEUR
    Rewrite [F:STO0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next
  Filter [F:STO0]

  # actualiza 'Comentario 3' en la tablas STOJOU
  Filter [F:STJ0] Where evalue(FILTRO)
  For [STJ0]
    Trbegin [STJ0]
    [F:STJ0]YUSRFLD3 = VALEUR
    Rewrite [F:STJ0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next
  Filter [F:STJ0]

  # actualiza 'Comentario 3' en la tablas STOLOT
  Filter [F:STL0] Where evalue(FILTRO)
  For [STL0]
    Trbegin [F:STL0]
    [F:STL0]YUSRFLD3 = VALEUR
    Rewrite [F:STL0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next
  Filter [F:STL0]

  Gosub CERRAR_TABLAS

Kill FILTRO

End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

