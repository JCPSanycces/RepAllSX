#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION

#If GUSER="AIT07" Then : Infbox "2"-ACTION : Endif
Case ACTION
  When "UOVRE"      : Gosub OUVRE
  When "DEBUT"      : Gosub DEBUT
  When "SETBOUT"    : Gosub SETBOUT
  When "LECTURE"    : Gosub LECTURE
  When "SEL_TABLE"  : Gosub SEL_TABLE
  When "VERF_TABLE" : Gosub VERF_TABLE
  When "CLECUR"     : Gosub CLECUR # MAB.20052020. Completar nuevos campos.
  When "DEB_CRIT"   : Gosub DEB_CRIT # JC.23062020. Pasar fam. est. 1 a la pantalla de criterios
  When "FIN_CRIT"   : Gosub FIN_CRIT # JC.23062020. Pasar fam. est. 1 a la pantalla de búsqueda
  When "FILTRE"     : Gosub FILTRE
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
############################################
$OUVRE
  Grizo [M:SAR1]YCDGATRIBUTO
Return

##############################################################
$DEBUT
  [M:SAR1]FLG = 0
Return

############################################
$SETBOUT
  If [M:SAR1]YCDGGRUPO <> "" Then
    Actzo [M:SAR1]YCDGATRIBUTO
  Else
    [M:SAR1]YDESGRUPO = ""
    Affzo [M:SAR1]YDESGRUPO
    [M:SAR1]YCDGATRIBUTO = ""
    Affzo [M:SAR1]YCDGATRIBUTO
    Grizo [M:SAR1]YCDGATRIBUTO
    [M:SAR1]YDESATRIBUTO = ""
    Affzo [M:SAR1]YDESATRIBUTO
  Endif
Return

############################################
$LECTURE
#  CRITERE = "[F:ITF]STOFCY=[M:SAR1]FCY&[F:ITF]STOMGTCOD>1"

Return

############################################
$SEL_TABLE
  Case TABLE
    When "YSELCDGGRS"   : Gosub SEL_YSELCDGGRS
    When "YSELCDGATS"   : Gosub SEL_YSELCDGATS
  Endcase
Return

############################################
$VERF_TABLE
  Case TABLE
    When "YSELCDGGRS"   : Gosub VERF_YSELCDGGRS
    When "YSELCDGATS"   : Gosub VERF_YSELCDGATS
  Endcase
Return

############################################
$CLECUR

  If !clalev([YRO])   Then : Local File YVRESOF   [YRO]   : Endif
  If !clalev([ZITM])  Then : Local File ITMMASTER [ZITM]  : Endif

  For I = 0 To [M:SAR2]NBLIG-1
    # RESERVADOR OF
    [M:SAR2]YRESERVADOOF(I) = func GET_RESERVAOF([M:SAR2]STOFCY,  [M:SAR2]ITMREF(I))
    [M:SAR2]YUDCAJA(I)      = func GET_UDCAJA([M:SAR2]ITMREF(I))
    [M:SAR2]YUDPALET(I)     = func GET_UDPALET([M:SAR2]ITMREF(I))
    [M:SAR2]YCOMPRAA(I)     = func GET_COMPRAA([M:SAR2]STOFCY,[M:SAR2]ITMREF(I) )

    [M:SAR2]YCOMPRAAA(I)    = func GET_COMPRAAA([M:SAR2]STOFCY,[M:SAR2]ITMREF(I))
    [M:SAR2]YVENTAM(I)      = func GET_YVENTAM([M:SAR2]STOFCY,[M:SAR2]ITMREF(I))
    [M:SAR2]YVENTAMA(I)     = func GET_YVENTAMA([M:SAR2]STOFCY,[M:SAR2]ITMREF(I))
    [M:SAR2]YVENTAA(I)      = func GET_YVENTAA([M:SAR2]STOFCY,[M:SAR2]ITMREF(I))
    [M:SAR2]YVENTAAA(I)     = func GET_YVENTAAA([M:SAR2]STOFCY,[M:SAR2]ITMREF(I))
    [M:SAR2]YINFPRO(I)      = func GET_INFPRO([M:SAR2]ITMREF(I))

    [M:SAR2]YVENTA15A(I)    = func GET_YVENTA15A([M:SAR2]STOFCY,[M:SAR2]ITMREF(I))
    [M:SAR2]YVENTAMM(I)     = func GET_YVENTAMM([M:SAR2]STOFCY,[M:SAR2]ITMREF(I))
  Next
  Affzo [M:SAR2]

Return

############################################
$DEB_CRIT
  # JC.23062020. Pasar fam. est. 1 a la pantalla de criterios
  [M:CSAR]    = [M:SAR1]
  If [M:SAR1]YTSICODSTR1 <> "" Then
    [M:CSAR]TSICODSTR(0) = [M:SAR1]YTSICODSTR1
    Affzo [M:CSAR]TSICODSTR(0)
  Endif

  If [M:SAR1]YTSICODEND1 <> "" Then
    [M:CSAR]TSICODEND(0) = [M:SAR1]YTSICODEND1
    Affzo [M:CSAR]TSICODEND(0)
  Endif
  GPE=1

Return

############################################
$FIN_CRIT
  # JC.23062020. Pasar fam. est. 1 a la pantalla de búsqueda
  If [M:CSAR]TSICODSTR(0) <> "" Then
    [M:SAR1]YTSICODSTR1 = [M:CSAR]TSICODSTR(0)
    Affzo [M:SAR1]YTSICODSTR1
  Endif

  If [M:CSAR]TSICODEND(0) <> "" Then
    [M:SAR1]YTSICODEND1 = [M:CSAR]TSICODEND(0)
    Affzo [M:SAR1]YTSICODEND1
  Endif

[M:SAR1]FLG = 0
Return

############################################
$FILTRE
  # JC.23062020. Buscar sólo artículos activos
  WFILSPE += "&[F:ITM]ITMSTA=1"
Return

############################################
$SEL_YSELCDGGRS
  If !clalev([F:YVG1]) Then : Local File YVISGRATRIB [F:YVG1] : Endif
  Default File [YVG1]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Grupos"                                                        # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "CDGGRUPO"                                                      # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la primera columna
  COL(NBCOL)  = "DESGRUPO"                                                      # nombre del campo a mostrar en la primera columna

  SENS        = 1
  DEFPAG      = 5
  SIZCOL      = 100
  SIZLIG      = 100
  GSELFAC     = 1

Return

############################################
$VERF_YSELCDGGRS
  [M:SAR1]YDESGRUPO = [F:YVG1]DESGRUPO
  Affzo [M:SAR1]YDESGRUPO
Return

############################################
$SEL_YSELCDGATS
  CRITERE = "1=1"

  If !clalev([F:YVA1]) Then : Local File YVISATRIBUTO [F:YVA1] : Endif
  Default File [YVA1]
#  Filter [F:YVA1] Where CDGGRUPO = [M:SAR1]YCDGGRUPO
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Atributos"                                                     # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "CDGATRIBUTO"                                                   # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la primera columna
  COL(NBCOL)  = "DESATRIBUTO"                                                   # nombre del campo a mostrar en la primera columna

  CRITERE     = "CDGGRUPO ='" + [M:SAR1]YCDGGRUPO + "'"
  SENS        = 1
  DEFPAG      = 5
  SIZCOL      = 100
  SIZLIG      = 100
  GSELFAC     = 1

Return

############################################
$VERF_YSELCDGATS
  [M:SAR1]YDESATRIBUTO = [F:YVA1]DESATRIBUTO
  Affzo [M:SAR1]YDESATRIBUTO
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
##############################################################
# Subprog VERIF_LINE(POK)       # AIT51.OLD
Subprog VERIF_LINE(POK, PITMREF) # AIT51.NEW -- HAY QUE COMPARAR CON EL ARTICULO QUE ESTAMOS LEYENDO, NO CON LOS FILTROS DE PANTALLA
Variable Integer POK
Variable Char PITMREF

### YYN31
If [M:SAR1]YCDGGRUPO <> "" or [M:SAR1]YCDGATRIBUTO <> ""
    Local Char LCRIT(255)   : LCRIT = "1=1"
    # If [M:SAR1]ITMREFSTR <> ""    Then  : LCRIT -= "AND ARTICULO>=[M:SAR1]ITMREFSTR"    : Endif
    # If [M:SAR1]ITMREFEND <> ""    Then  : LCRIT -= "AND ARTICULO<=[M:SAR1]ITMREFEND"    : Endif
    If PITMREF <> ""    Then  : LCRIT -= "AND ARTICULO>=PITMREF"    : Endif
    If PITMREF <> ""    Then  : LCRIT -= "AND ARTICULO<=PITMREF"    : Endif
    If [M:SAR1]YCDGGRUPO <> ""    Then  : LCRIT -= "AND YGATRIBUTO=[M:SAR1]YCDGGRUPO"   : Endif
    If [M:SAR1]YCDGATRIBUTO <> "" Then  : LCRIT -= "AND ATRIBUTO=[M:SAR1]YCDGATRIBUTO"  : Endif
    If !clalev([F:IAT0]) Then : Local File YITMATRIB [F:IAT0] : Endif
    Filter [F:IAT0] Where evalue(LCRIT)
    Read [F:IAT0] First
    If fstat = 0 Then
      POK = 2
    Else        # AIT51
      POK = 0   # AIT51
    Endif
    Filter [F:IAT0]
    If  clalev([F:IAT0]) Then : Close Local File     [F:IAT0] : Endif
#   If !clalev([F:IAT0]) Then : Local File YITMATRIB [F:IAT0] : Endif
#   If [M:SAR1]YCDGGRUPO <> "" and [M:SAR1]YCDGATRIBUTO <> ""
#     Read [F:IAT0]YAIT0 = PITMREF;[M:SAR1]YCDGATRIBUTO;[M:SAR1]YCDGGRUPO
#     If !fstat
#       POK=2
#     Else
#       POK=0
#     Endif
#   Else
#     POK=2
#   Endif
Else
  POK = 2
Endif
### YYN31

End

##############################################################
#**
#* Función que nos devuelve la cantidad de Reservado en OF en firme del componente
#*
#* @param PFCY
#* @param PITMREF
#*!

Funprog GET_RESERVAOF(PFCY, PITMREF)
  Local Decimal LRES

  Read [YRO]IDX0=PFCY;PITMREF
  If !fstat Then
    LRES = [F:YRO]QTYRESOF
  Else
    LRES = 0
  Endif

End LRES

##############################################################
#**
#* Funcion que devuelve la unidad caja del articulo
#*
#* @param PFCY
#* @param PITMREF
#*!
Funprog GET_UDCAJA( PITMREF)
  Local Integer LRES

  Read [ZITM]ITM0=PITMREF
  If !fstat Then
    LRES = [F:ZITM]YUDCAJA
  Else
    LRES = 0
  Endif

End LRES

##############################################################
#**
#* #* Funcion que devuelve la unidad palet del articulo
#*
#* @param PFCY
#* @param PITMREF
#*!
Funprog GET_UDPALET(PITMREF)
  Local Integer LRES

  Read [ZITM]ITM0=PITMREF
  If !fstat Then
    LRES = [F:ZITM]YUDPALET
  Else
    LRES = 0
  Endif

End LRES


##############################################################
#**
#* #* Funcion que devuelve la información articulo
#*
#* @param PFCY
#* @param PITMREF
#*!
Funprog GET_INFPRO(PITMREF)
  Local Char LRES(150)

  Read [ZITM]ITM0=PITMREF
  If !fstat Then
    LRES = [F:ZITM]YTEXTOPROD
  Else
    LRES = ""
  Endif

End LRES

##############################################################
#**
#* Esta función nos devuelve las recepciones - las devoluciones
#* del año actual hasta hoy, del articulo del parámetro
#*
#* @param PITMREF
#*!
Funprog GET_COMPRAA(PFCY, PITMREF)
  Local Decimal LRES
  Local Char REQUEST(255)(1..10)

  LRES = 0



  REQUEST(1)="SELECT ( SELECT ISNULL(sum(REC.QTYUOM_0),0) "
  REQUEST(2)=" From PRECEIPTD REC"
  REQUEST(3)=" Where REC.ITMREF_0 = '" + PITMREF + "' AND PRHFCY_0 = '" + PFCY + "'"
  REQUEST(4)=" and REC.RCPDAT_0 >= DATEADD(yy, DATEDIFF(yy, 0, GETDATE()), 0) "
  REQUEST(5)=" and REC.RCPDAT_0 <= SYSDATETIME()   "
  REQUEST(6)=" )-("
  REQUEST(7)=" SELECT ISNULL(sum(RET.QTYUOM_0),0) From  PRETURND RET  "
  REQUEST(8)=" Where  RET.ITMREF_0 = '" + PITMREF + "' AND POHFCY_0 = '" + PFCY + "'"
  REQUEST(9)=" and RET.RTNDAT_0 >= DATEADD(yy, DATEDIFF(yy, 0, GETDATE()), 0) "
  REQUEST(10)=" and RET.RTNDAT_0 <= SYSDATETIME()  )"



  For (Decimal RESULTADO) From "5" Sql REQUEST(1..10) As [ZREC]
    LRES =[F:ZREC]RESULTADO
  Next


End LRES

##############################################################
#**
#* Esta función nos devuelve las recepciones - las devoluciones
#* del año anterior , del articulo del parámetro
#*
#* @param PITMREF
#*!
Funprog GET_COMPRAAA(PFCY, PITMREF)
  Local Decimal LRES
  Local Char REQUEST(255)(1..10)

  LRES = 0

  REQUEST(1)="SELECT ( SELECT ISNULL(sum(REC.QTYUOM_0),0) "
  REQUEST(2)=" From PRECEIPTD REC"
  REQUEST(3)=" Where REC.ITMREF_0 = '" + PITMREF + "' AND PRHFCY_0 = '" + PFCY + "'"
  REQUEST(4)=" and REC.RCPDAT_0 >= DATEADD(YY, DATEDIFF(YY, 0, GETDATE())-1, 0)  "
  REQUEST(5)=" and REC.RCPDAT_0 <= DATEADD(YY, DATEDIFF(YY, 0, GETDATE())-1 + 1, -1)  "
  REQUEST(6)=" )-("
  REQUEST(7)=" SELECT ISNULL(sum(RET.QTYUOM_0),0) From  PRETURND RET  "
  REQUEST(8)=" Where  RET.ITMREF_0 = '" + PITMREF + "' AND POHFCY_0 = '" + PFCY + "'"
  REQUEST(9)=" and RET.RTNDAT_0 >= DATEADD(YY, DATEDIFF(YY, 0, GETDATE())-1, 0) "
  REQUEST(10)=" and RET.RTNDAT_0 <= DATEADD(YY, DATEDIFF(YY, 0, GETDATE())-1 + 1, -1) )"

  For (Decimal RESULTADO) From "5" Sql REQUEST(1..10) As [ZREC]
    LRES =[F:ZREC]RESULTADO
  Next


End LRES

##############################################################
#**
#* Esta función nos devuelve La media de las entregas menos las devoluciones de cliente de los meses completos del año en curso.
#*
#* @param PITMREF
#*!
Funprog GET_YVENTAM(PFCY, PITMREF)
  Local Decimal LRES
  Local Char REQUEST(255)(1..10)

  LRES = 0

  REQUEST(1)="SELECT ((SELECT ISNULL(SUM(SRE.QTY_0),0) "
  REQUEST(2)=" FROM SDELIVERYD SRE "
  REQUEST(3)=" WHERE ITMREF_0 = '" + PITMREF + "' AND STOFCY_0 = '" + PFCY + "'"
  REQUEST(4)=" AND SRE.SHIDAT_0 >=  DATEADD(yy, DATEDIFF(yy, 0, GETDATE()), 0) "
  REQUEST(5)=" AND SRE.SHIDAT_0 <= SYSDATETIME()) "
  REQUEST(6)=" - "
  REQUEST(7)=" (SELECT ISNULL(SUM(SRE.QTY_0),0) FROM SRETURND SRE "
  REQUEST(8)=" WHERE ITMREF_0 = '" + PITMREF + "' AND STOFCY_0 = '" + PFCY + "'"
  REQUEST(9)=" and SRE.RTNDAT_0 >= DATEADD(YY, DATEDIFF(YY, 0, GETDATE()), 0) "
  REQUEST(10)="  and SRE.RTNDAT_0 <= SYSDATETIME() )) /(month(SYSDATETIME())) RESULTADO_0"  # Quito -1. línea original está debajo
  ##  REQUEST(10)="  and SRE.RTNDAT_0 <= SYSDATETIME() )) /(month(SYSDATETIME())-1) RESULTADO_0"

  For (Decimal RESULTADO) From "5" Sql REQUEST(1..10) As [ZREC]
    LRES =[F:ZREC]RESULTADO
  Next


End LRES

##############################################################
#**
#* Esta función nos devuelve las ventas del mes anterior al actual.
#*
#* @param PITMREF
#*!
Funprog GET_YVENTAMA(PFCY, PITMREF)
  Local Decimal LRES
  Local Char REQUEST(255)(1..10)

  LRES = 0

  REQUEST(1)="SELECT ( (SELECT ISNULL(SUM(SRE.QTY_0),0) "
  REQUEST(2)=" FROM SDELIVERYD SRE "
  REQUEST(3)=" WHERE ITMREF_0 = '" + PITMREF + "' AND STOFCY_0 = '" + PFCY + "'"
  REQUEST(4)=" AND SRE.SHIDAT_0 >=  DATEADD(MONTH, DATEDIFF(MONTH, 0, GETDATE()) - 1, 0) "
  REQUEST(5)=" AND SRE.SHIDAT_0 <= DATEADD(MONTH, DATEDIFF(MONTH, -1, GETDATE())-1, -1) ) "
  REQUEST(6)=" - "
  REQUEST(7)=" (SELECT ISNULL(SUM(SRE.QTY_0),0) FROM SRETURND SRE "
  REQUEST(8)=" WHERE ITMREF_0 = '" + PITMREF + "' AND STOFCY_0 = '" + PFCY + "'"
  REQUEST(9)=" and SRE.RTNDAT_0 >= DATEADD(MONTH, DATEDIFF(MONTH, 0, GETDATE()) - 1, 0) "
  REQUEST(10)="  and SRE.RTNDAT_0 <= DATEADD(MONTH, DATEDIFF(MONTH, -1, GETDATE())-1, -1) ))  RESULTADO_0"

  For (Decimal RESULTADO) From "5" Sql REQUEST(1..10) As [ZREC]
    LRES =[F:ZREC]RESULTADO
  Next


End LRES

##############################################################
#**
#* Esta función nos devuelve las ventas de los últimos 15 días.
#*
#* @param PITMREF
#*!
Funprog GET_YVENTA15A(PFCY, PITMREF)
  Local Decimal LRES
  Local Char REQUEST(255)(1..10)

  LRES = 0

  REQUEST(1)="SELECT ( (SELECT ISNULL(SUM(SRE.QTY_0),0) "
  REQUEST(2)=" FROM SDELIVERYD SRE "
  REQUEST(3)=" WHERE ITMREF_0 = '" + PITMREF + "' AND STOFCY_0 = '" + PFCY + "'"
  REQUEST(4)=" AND SRE.SHIDAT_0 >=  DATEADD(day, -15,SYSDATETIME()) "
  REQUEST(5)=" AND SRE.SHIDAT_0 <= SYSDATETIME() ) "
  REQUEST(6)=" - "
  REQUEST(7)=" (SELECT ISNULL(SUM(SRE.QTY_0),0) FROM SRETURND SRE "
  REQUEST(8)=" WHERE ITMREF_0 = '" + PITMREF + "' AND STOFCY_0 = '" + PFCY + "'"
  REQUEST(9)=" and SRE.RTNDAT_0 >= DATEADD(day, -15,SYSDATETIME()) "
  REQUEST(10)="  and SRE.RTNDAT_0 <= SYSDATETIME() ))  RESULTADO_0"

  For (Decimal RESULTADO) From "5" Sql REQUEST(1..10) As [ZREC]
    LRES =[F:ZREC]RESULTADO
  Next


End LRES

##############################################################
#**
#* Esta función nos devuelve La media de las ventas de cliente de los meses completos del año en curso.
#*
#* @param PITMREF
#*!
Funprog GET_YVENTAMM(PFCY, PITMREF)
  Local Decimal LRES
  Local Char REQUEST(255)(1..10)

  LRES = 0

  REQUEST(1)="SELECT ( (SELECT ISNULL(SUM(SRE.QTY_0),0) "
  REQUEST(2)=" FROM SDELIVERYD SRE "
  REQUEST(3)=" WHERE ITMREF_0 = '" + PITMREF + "' AND STOFCY_0 = '" + PFCY + "'"
  REQUEST(4)=" AND SRE.SHIDAT_0 >=  DATEADD(yy, DATEDIFF(yy, 0, GETDATE()), 0) "
  REQUEST(5)=" AND SRE.SHIDAT_0 <= DATEADD(MONTH, DATEDIFF(MONTH, -1, GETDATE())-1, -1)  ) "
  REQUEST(6)=" - "
  REQUEST(7)=" (SELECT ISNULL(SUM(SRE.QTY_0),0) FROM SRETURND SRE "
  REQUEST(8)=" WHERE ITMREF_0 = '" + PITMREF + "' AND STOFCY_0 = '" + PFCY + "'"
  REQUEST(9)=" and SRE.RTNDAT_0 >= DATEADD(yy, DATEDIFF(yy, 0, GETDATE()), 0) "
  REQUEST(10)="  and SRE.RTNDAT_0 <= DATEADD(MONTH, DATEDIFF(MONTH, -1, GETDATE())-1, -1)  ))/(month(SYSDATETIME()))  RESULTADO_0" #quito el -1; línea original abajo
  #REQUEST(10)="  and SRE.RTNDAT_0 <= DATEADD(MONTH, DATEDIFF(MONTH, -1, GETDATE())-1, -1)  ))/(month(SYSDATETIME())-1)  RESULTADO_0"



  For (Decimal RESULTADO) From "5" Sql REQUEST(1..10) As [ZREC]
    LRES =[F:ZREC]RESULTADO
  Next


End LRES


