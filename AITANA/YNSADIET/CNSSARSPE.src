##############################################################
#**
#* #* Funcion que devuelve la familia estadística del articulo
#*
#* @param PITMREF
#*!
Funprog GET_TSICOD(PITMREF)
Value Char PITMREF

  Local Char LRES(150)

  Read [ZITM]ITM0=PITMREF
  If !fstat Then
    LRES = [F:ZITM]TSICOD(0)
  Else
    LRES = ""
  Endif

End LRES
