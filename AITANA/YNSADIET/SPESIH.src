# Gestión de la máscara SIH0 (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla SIH0) 05/03/2020 17:45:37 (AIT04)
######################################################################################
$ACTION
Case ACTION
 When "APRES_CRE"   :  Gosub APRES_CRE
Endcase
Return


############################################
$APRES_CRE
# Pongo valor al campo Departamento
Read [SIV]SIV0 = [M:SIH0]NUM
If fstat = 0
  Read [BPC]BPC0 = [SIV]BPCINV
  If fstat = 0
    [SIV]YDPTO = [BPC]YDPTOC
    Rewrite [SIV]
  Endif
Endif
Return



######################################################################################
Subprog AM_BPCINV(VALEUR)
Variable Char    VALEUR()
# Pongo valor al campo departamento
[M:SIH0]YDPTO = [F:BPC]YDPTOC
Affzo [M:SIH0]YDPTO
End

######################################################################################
## Etiqueta añadida por el supervisor (pantalla SIH0) 22/04/2021 16:58:19 (AIT50)
