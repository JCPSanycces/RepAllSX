# YYN13 - Ajustes en el campo 'Comentario 3' del artículo-lote
# Fecha inicio YYN13: 12/02/2020
# Desarrollador: JCH
# Codigo Actividad: YYN13
#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "FIN"        : Gosub FIN
  When "APRES_CRE"  : Gosub APRES_CRE
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
  Gosub ABRIR_TABLAS
Return

##############################################################
$FIN
  Gosub CERRAR_TABLAS
Return

##############################################################
$APRES_CRE
  Gosub APRES_CRE From SUBSMXA
  Gosub UPD_YUSRFLD3
  GPE=1
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ABRIR_TABLAS
  If !clalev([F:STO0]) Then : Local File STOCK  [F:STO0] : Endif
  If !clalev([F:STJ0]) Then : Local File STOJOU [F:STJ0] : Endif
  If !clalev([F:STL0]) Then : Local File STOLOT [F:STL0] : Endif
Return

##############################################################
$CERRAR_TABLAS
  If clalev([F:STO0])  Then : Close Local File  [F:STO0] : Endif
  If clalev([F:STJ0])  Then : Close Local File  [F:STJ0] : Endif
  If clalev([F:STL0])  Then : Close Local File  [F:STL0] : Endif
Return

##############################################################
# actualiza la información del campo 'Comentario 3' en las tablas de stock
$UPD_YUSRFLD3

  If [M:SMX1]YUSRFLD3 <> "" Then
    # actualiza el campo 'Comentario 3' en la tabla STOCK
    Filter [F:STO0] Where STOFCY = [M:SMX0]STOFCY and ITMREF = [M:SMX0]ITMREF and LOT = [M:SMX0]LOT and USRFLD1 = [M:SMX1]USRFLD1 and USRFLD2 = [M:SMX1]USRFLD2
    For [F:STO0]
      Trbegin [F:STO0]
      [F:STO0]YUSRFLD3 = [M:SMX1]YUSRFLD3
      Rewrite [F:STO0]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Next
    Filter [F:STO0]

    # actualiza el campo 'Comentario 3' en la tabla STOJOU
    Filter [F:STJ0] Where STOFCY = [M:SMX0]STOFCY and ITMREF = [M:SMX0]ITMREF and LOT = [M:SMX0]LOT and USRFLD1 = [M:SMX1]USRFLD1 and USRFLD2 = [M:SMX1]USRFLD2
    For [F:STJ0]
      Trbegin [F:STJ0]
      [F:STJ0]YUSRFLD3 = [M:SMX1]YUSRFLD3
      Rewrite [F:STJ0]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Next
    Filter [F:STJ0]

    # actualiza el campo 'Comentario 3' en la tabla STOLOT
    Filter [F:STL0] Where ITMREF = [M:SMX0]ITMREF and LOT = [M:SMX0]LOT and USRFLD1 = [M:SMX1]USRFLD1 and USRFLD2 = [M:SMX1]USRFLD2
    For [F:STL0]
      Trbegin [F:STL0]
      [F:STL0]YUSRFLD3 = [M:SMX1]YUSRFLD3
      Rewrite [F:STL0]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Next
    Filter [F:STL0]

  Endif

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

