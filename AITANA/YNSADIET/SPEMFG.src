#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
#If GUSER = 'AIT50' : Infbox ACTION  : Endif

# MS - MEJORAS A AÑADIR
# ESTABLECER COMO PARAMETRO LA TRANSACCION A UTILIZAR CON EL GMAO YNS99
# arreglar el AITMFG_AS_YMNTOTYP
# arreglar el AITMFG_AM_YMNTOTYP



Case ACTION
  When "FILTRE"    :   Gosub FILTRE
  When "INICRE"    :   Gosub INICRE
  When "RAZCRE"    :   Gosub RAZCRE
  When "APRES_CRE" :   Gosub APRES_CRE
  When "LIENS"     :   Gosub LIENS
  When "OUVRE"     :   Gosub OUVRE
  When "FIN"       :   Gosub FIN
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$FILTRE
# Visualización de las OFs en función de la transacción
Gosub FILTRE From SUBMFGA

Default File [MFG]

If FILTSUP = "" : FILTSUP = "1=1" : Endif
Case GFLAG
  When "YNS01"  : FILTSUP += " & YTIPO = 1"
  When "YNS02"  : FILTSUP += " & YTIPO = 2"
  When "YNS99"  : FILTSUP += " & YTIPO = 3"
Endcase

GPE = 1
Return


##############################################################
$INICRE

Gosub AITMFG_INICRE From YAITGMAO

#SI ESTOY EN UNA SIMULACIÓN PROPONGO CONTADOR DE SIMULACIONES
If [M:MFG0]YTIPO = 2
  Local Char LNUM
  Local Integer STAT
  Call NUMERO("YSIM",[M:MFG0]MFGFCY,date$,"",LNUM,STAT) From SUBANM
  [M:MFG0]MFGNUM = LNUM
  [F:MFG]MFGNUM  = LNUM
  Affzo [M:MFG0]MFGNUM
Endif

Return


##############################################################
$RAZCRE
# Pongo valor al campo de tipo de orden en función de la transacción
Case GFLAG
  When "YNS01"    :   [M:MFG0]YTIPO = 1
  When "YNS02"    :   [M:MFG0]YTIPO = 2
  When "YNS99"    :   [M:MFG0]YTIPO = 3
Endcase
Affzo [M:MFG0]YTIPO
Return

##############################################################
$APRES_CRE

If GUSER = 'AIT51' : Infbox "apres_cre"  : Endif

  Gosub APRES_CRE From SUBMFGA
  # copia el campo YTIPO de la cabecera a la tabla de artículos enlazados MFGITM
  Filter [F:MFI] Where MFGNUM = [F:MFG]MFGNUM
  For [MFI]
    Trbegin [F:MFI]
    [F:MFI]YTIPO = [F:MFG]YTIPO
    Rewrite [F:MFI]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next
  Filter [F:MFI]
  GPE = 1
Return

##############################################################
$LIENS
# Visualización las descripciones de los CT en la pestaña de operaciones
Gosub LIENS From SUBMFGA

Local Integer I
Local Char MADES
Local Char MODES
For I=0 To [M:MFG3]NBLIG-1
  MADES = ""
  MODES = ""
  Call GET_WSTDES([M:MFG3]EXTWST(I),[M:MFG0]MFGFCY,MADES) From SPEROU
  Call GET_WSTDES([M:MFG3]EXTLAB(I),[M:MFG0]MFGFCY,MODES) From SPEROU
  [M:MFG3]YWSTDES(I) = MADES
  [M:MFG3]YLABDES(I) = MODES
  Affzo [M:MFG3]YWSTDES(I)
  Affzo [M:MFG3]YLABDES(I)

Next

GPE = 1
Return

##############################################################
$OUVRE
  Gosub AITMFG_OUVRE From YAITGMAO
  If !clalev([F:FCY0]) Then : Local File FACILITY [F:FCY0] : Endif
Return

##############################################################
$FIN
  Gosub AITMFG_FIN From YAITGMAO
 # Close Local File [FCY0]
Return


######################################################################################
# con este código controlamos que si se accede a la pantalla desde una opción diferente
# a un modelo de importación, no se pueda modificar el campo
# MS - HAY QUE MEJORAR ESTO, BLOQUEO Y VALORES PREDETERMINDADO DE CAMPOS GMAO
Subprog AS_YMNTOTYP(VALEUR)
Variable Integer VALEUR
  Call AITMFG_AS_YMNTOTYP(VALEUR) From YAITGMAO
End


######################################################################################
Subprog AM_YCADUCIDAD(VALEUR)
Variable Date    VALEUR
# Propongo la fecha límite como caducidad menos los días límite indicados en la ficha del artículo
Read [ITM]ITM0 = [M:MFG1]ITMREF(nolign-1)
If fstat = 0
  [M:MFG1]YFLU(nolign-1) = VALEUR - [ITM]YDIASFLU
  Affzo [M:MFG1]YFLU(nolign-1)
Endif
End

######################################################################################
## Antes_entrada del campo 'Fecha inicial'
######################################################################################
Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
  VALEUR = date$
End

######################################################################################
## Antes de entrada en el campo 'Tipo'
######################################################################################
Subprog AS_YTIPOM(VALEUR)
Variable Integer VALEUR
  Call AITMFG_AS_YTIPOM(VALEUR) From YAITGMAO
End

######################################################################################
## Después de modificar el campo 'Tipo'
######################################################################################
Subprog AM_YTIPOM(VALEUR)
Variable Integer VALEUR

End

######################################################################################
## Después de modificar el campo 'Artículo'
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
  Call AITMFG_AM_ITMREF(VALEUR) From YAITGMAO
End


######################################################################################
Subprog AM_YMNTOTYP(VALEUR)
Variable Integer VALEUR
  Call AITMFG_AM_YMNTOTYP(VALEUR) From YAITGMAO
End


######################################################################################
