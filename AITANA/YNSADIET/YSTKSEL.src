#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)4.0.0.0 $Revision$

#########################################################################
# Actions de type sélection table
#------------------------------------------------------------------------
# STKSELSTOT  : Sélection ligne de stock pour terminaux portables
#########################################################################

$ACTION
#If GUSER = 'AIT51' Then : Infbox ACTION : Endif
Case ACTION
  When "SEL_TABLE"      : Gosub SEL_TABLE
  When "SEL_LISTE"      : Gosub SEL_LISTE
  #When "VERF_TABLE"     : Gosub VERF_TABLE
  #When "FIN_TABLE"      : Gosub FIN_TABLE
Endcase
Return



#########################################################################
$SEL_TABLE
#If GUSER = 'AIT51' Then : Infbox TABLE : Endif
Case TABLE
  When "STKSELSTOT"    : Gosub STKSELSTOT
Endcase
Return

#########################################################################
$SEL_LISTE
#If GUSER = 'AIT51' Then : Infbox LISTE : Endif
Case LISTE
  When "STKSELLOCT"    : Gosub STKSELLOCT
Endcase
Return


#########################################################################
# STKSELSTOT : Sélection ligne de stock pour terminaux portables
#########################################################################
$STKSELSTOT
Local Char    LFIC(10)        : LFIC = "STOCK"
Local Char    LFCY(GLONFCY)   : LFCY = PARAM(1)
Local Char    LITM(GLONITM)   : LITM = PARAM(2)
Local Char    LLOT(GLONLOT)   : LLOT = PARAM(3)
Local Char    LSLO(GLONSLO)   : LSLO = PARAM(4)
Local Char    LLOC(GLONLOC)   : LLOC = PARAM(5)
Local Char    LSTA(GLONSTA)   : LSTA = PARAM(6)
Local Char    LABR            : LABR = PARAM(7)

If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif

If [F:ITM]ITMREF<>LITM
   Read [ITM]ITM0=LITM
Endif
If [F:ITF]ITMREF<>LITM | [F:ITF]STOFCY<>LFCY
   Read [ITF]ITF0=LITM;LFCY
Endif



TIT(0) = mess(145,198,1)

CRITERE = "[F:STO]STOFCY=LFCY&[F:STO]ITMREF=LITM"

Case zoncou
 When "LOT"       : If [F:ITM]SERMGTCOD=3
                       NBCOL += 1 : COL(NBCOL) = "SERNUM"
                       Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
                    Endif
                   NBCOL += 1 : COL(NBCOL) = "LOT"
                    Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
                    If [F:ITM]LOTMGTCOD = 4
                       NBCOL += 1 : COL(NBCOL) = "SLO"
                       Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
                    Endif
 When "SLO"       : If LLOT<>""
                       CRITERE += "&[F:STO]LOT=LLOT"
                    Endif
                    If [F:ITM]SERMGTCOD=3
                       NBCOL += 1 : COL(NBCOL) = "SERNUM"
                       Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
                    Endif
                    NBCOL += 1 : COL(NBCOL) = "LOT"
                    Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
                    NBCOL += 1 : COL(NBCOL) = "SLO"
                    Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
 When "SERNUM"    : NBCOL += 1 : COL(NBCOL) = "SERNUM"
                    Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
                    If LLOT<>""
                       CRITERE += "&[F:STO]LOT=LLOT"
                       If [F:ITM]LOTMGTCOD=4 & LSLO<>""
                          CRITERE += "&[F:STO]SLO=LSLO"
                       Endif
                    Else
                       NBCOL += 1 : COL(NBCOL) = "LOT"
                       Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
                       If [F:ITM]LOTMGTCOD = 4
                          NBCOL += 1 : COL(NBCOL) = "SLO"
                          Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
                       Endif
                    Endif
Endcase

If LSTA<>""
   CRITERE += "&[F:STO]STA=LSTA"
Else
   NBCOL += 1 : COL(NBCOL) = "STA"
   Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
Endif

If [F:ITF]LOCMGTCOD=2
   If LLOC<>""
      CRITERE += "&[F:STO]LOC=LLOC"
   Else
      NBCOL += 1 : COL(NBCOL) = "LOC"
      Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
   Endif
Endif

NBCOL += 1 : COL(NBCOL) = "LOCTYP"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV

CRITERE += "&[F:STO]CUNLOKFLG<>2&([F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY)>0"
Local Integer LLOCNUM1, LLOCNUM2, LLOCNUM3
Local Char LTYPUBI1, LTYPUBI2, LTYPUBI3
Local Char LCRITERE2(250)
# 1. BUSCAR TIPOS DE UBICACIÓN PARAMETRIZADAS
If !clalev([YTUB]) Then : Local File TABSTORUL [YTUB] : Endif
Read [YTUB]SRU0=[F:ITM]TCLCOD;[F:ITF]STOFCY;4
If !fstat Then
  LLOCNUM1 = [F:YTUB]LOCNUM
  LLOCNUM2 = [F:YTUB]LOCNUM2
  LLOCNUM3 = [F:YTUB]LOCNUM3
Endif

# 1. BUSCAR EN LA CATEGORIA LOS TIPO DE UBICACIÓN
#If !clalev([YCAT]) Then : Local File ITMCATEG [YCAT] : Endif
#Infbox  "Planta:" + [F:ITF]STOFCY + "cat:"  + [F:ITM]TCLCOD
#Read [YCAT]ITG0=[F:ITF]STOFCY;[F:ITM]TCLCOD
#If !fstat Then
  For I = 0 To 9
    # Si algun tipo de ubicación de la categoria corresponde a las ubicaciones parametrizadas.
    # Infbox "a:"+num$(LLOCNUM1) +  " - " + "b:"+num$(LLOCNUM2) +  " - " + "c:"+num$(LLOCNUM3) + " - " + num$([F:YCAT]LOCDES(I))  + " - " + [F:YCAT]DEFLOCTYP(I)
    If ([F:ITF]LOCNUM(I) = LLOCNUM1 or [F:ITF]LOCNUM(I) = LLOCNUM2 or [F:ITF]LOCNUM(I) = LLOCNUM3) and [F:ITF]LOCNUM(I) <> 0 Then
      If LTYPUBI1 = '' Then
        # Infbox "1." + num$([F:ITF]LOCNUM(I)) + " - " + [F:ITF]DEFLOCTYP(I)
        LTYPUBI1 = [F:ITF]DEFLOCTYP(I)
      Elsif LTYPUBI2 = '' Then
        # Infbox "2." + num$([F:ITF]LOCNUM(I)) + " - " + [F:ITF]DEFLOCTYP(I)
        LTYPUBI2 = [F:ITF]DEFLOCTYP(I)
      Elsif LTYPUBI3 = '' Then
        # Infbox "3." + num$([F:ITF]LOCNUM(I)) + " - " + [F:ITF]DEFLOCTYP(I)
        LTYPUBI3 = [F:ITF]DEFLOCTYP(I)
      Else
        Break
      Endif
    Endif
  Next I
  If LTYPUBI1 <> '' Then
    LCRITERE2 = "[F:STO]LOCTYP='" + LTYPUBI1 + "'"
  Endif
  If LTYPUBI2 <> '' Then
    If LCRITERE2 <> '' Then : LCRITERE2 += ' or ' : Endif
    LCRITERE2 = "[F:STO]LOCTYP='" + LTYPUBI2 + "'"
  Endif
  If LTYPUBI3 <> '' Then
    If LCRITERE2 <> '' Then : LCRITERE2 += ' or ' : Endif
    LCRITERE2 = "[F:STO]LOCTYP='" + LTYPUBI3 + "'"
  Endif
#  If LCRITERE2 <> '' Then
#   CRITERE += "&(" + LCRITERE2 + ")"
#  Endif
#Endif
# Infbox CRITERE

START  = zoncou
ORDRE  = "STOCOU"
SIZLIG = 100
SIZCOL = 100
Default File [STO]
Return



########################################################################
# STKSELLOCT : Sélection emplacement pour terminaux portables
#########################################################################
# Paramètres E : LFCY = Site
#                LITM = Article
#                PARAM(3) = Catégories emplacement autorisées
#
# Prérequis    : Ces tables doivent être ouvertes   STOCK
#
#########################################################################
$STKSELLOCT
Local Char  LFCY : LFCY = PARAM(1)
Local Char  LITM : LITM = PARAM(2)

Local Char     CRITERE(240)
Local Char     WLOC(GLONLOC)
Local Char     WTABLOC(GLONLOC)(1..50)
Local Integer  I,J,WCAT

If !clalev([F:STC]) Local File STOLOC [STC] Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ATZ]) = 0 : Local File ATABZON    [ATZ] : Endif
If clalev([F:STO]) = 0 : Local File STOCK      [STO] : Endif




If PARAM(3)="" PARAM(3)="1234" Endif

CRITERE  = "[F:STO]ITMREF=LITM&[F:STO]STOFCY=LFCY"
CRITERE += "&[F:STO]CUNLOKFLG<>2"
CRITERE += "&([F:STO]QTYSTU-[F:STO]CUMALLQTY-[F:STO]CUMWIPQTY)>0"
If len(PARAM(3)) > 0
  CRITERE += "&find([F:STO]LOCCAT"
  For WCAT = 1 To len(PARAM(3))
    CRITERE += ","
    CRITERE += mid$(PARAM(3),WCAT,1)
  Next WCAT
  CRITERE += ")"
Endif

Local Integer LLOCNUM1, LLOCNUM2, LLOCNUM3
Local Char LTYPUBI1, LTYPUBI2, LTYPUBI3
Local Char LCRITERE2(250)
# 1. BUSCAR TIPOS DE UBICACIÓN PARAMETRIZADAS
If !clalev([YTUB]) Then : Local File TABSTORUL [YTUB] : Endif
# Infbox [F:ITM]TCLCOD + " - " + LFCY
Read [YTUB]SRU0=[F:ITM]TCLCOD;LFCY;4
# Infbox num$([F:YTUB]LOCNUM3)
If !fstat Then
  LLOCNUM1 = func GET_LOC([F:YTUB]LOCNUM)
  LLOCNUM2 = func GET_LOC([F:YTUB]LOCNUM2)
  LLOCNUM3 = func GET_LOC([F:YTUB]LOCNUM3)
Endif



# 1. BUSCAR EN LA CATEGORIA LOS TIPO DE UBICACIÓN
#If !clalev([YCAT]) Then : Local File ITMCATEG [YCAT] : Endif
#Infbox  "Planta:" + [F:ITF]STOFCY + "cat:"  + [F:ITM]TCLCOD
#Read [YCAT]ITG0=[F:ITF]STOFCY;[F:ITM]TCLCOD
#If !fstat Then
  For I = 0 To 9
    # Si algun tipo de ubicación de la categoria corresponde a las ubicaciones parametrizadas.
    # Infbox "a:"+num$(LLOCNUM1) +  " - " + "b:"+num$(LLOCNUM2) +  " - " + "c:"+num$(LLOCNUM3) + " - " # + num$([F:YCAT]LOCDES(I))  + " - " + [F:YCAT]DEFLOCTYP(I)
    If ([F:ITF]LOCNUM(I) = LLOCNUM1 or [F:ITF]LOCNUM(I) = LLOCNUM2 or [F:ITF]LOCNUM(I) = LLOCNUM3) and [F:ITF]LOCNUM(I) <> 0 Then
      If LTYPUBI1 = '' Then
        # Infbox "1." + num$([F:ITF]LOCNUM(I)) + " - " + [F:ITF]DEFLOCTYP(I)
        LTYPUBI1 = [F:ITF]DEFLOCTYP(I)
      Elsif LTYPUBI2 = '' Then
        # Infbox "2." + num$([F:ITF]LOCNUM(I)) + " - " + [F:ITF]DEFLOCTYP(I)
        LTYPUBI2 = [F:ITF]DEFLOCTYP(I)
      Elsif LTYPUBI3 = '' Then
        # Infbox "3." + num$([F:ITF]LOCNUM(I)) + " - " + [F:ITF]DEFLOCTYP(I)
        LTYPUBI3 = [F:ITF]DEFLOCTYP(I)
      Else
        Break
      Endif
    Endif
  Next I
  If LTYPUBI1 <> '' Then
    LCRITERE2 = "[F:STO]LOCTYP='" + LTYPUBI1 + "'"
  Endif
  If LTYPUBI2 <> '' Then
    If LCRITERE2 <> '' Then : LCRITERE2 += ' or ' : Endif
    LCRITERE2 += "[F:STO]LOCTYP='" + LTYPUBI2 + "'"
  Endif
  If LTYPUBI3 <> '' Then
    If LCRITERE2 <> '' Then : LCRITERE2 += ' or ' : Endif
    LCRITERE2 += "[F:STO]LOCTYP='" + LTYPUBI3 + "'"
  Endif
  If LCRITERE2 <> '' Then
   # Infbox LCRITERE2
   CRITERE += "&(" + LCRITERE2 + ")"
   # Infbox CRITERE
  Endif
#Endif
# Infbox CRITERE



For [STO]STO4 Hint Key STO3 Where evalue(CRITERE)
   WLOC = [F:STO]LOC
   Gosub LOA_LOC
Next

TIT(0) = mess(22,123,1)

Return

#########################################################################
$LOA_LOC

If WLOC<>"" & J<dim(WTABLOC)
   If J=0 | !find(WLOC,WTABLOC(1..J))
      Read [STC]STC0=[F:STO]STOFCY;[F:STO]LOC
      If !fstat
         J += 1
         WTABLOC(J) = WLOC
         NBTEX +=1
         TEX(NBTEX) = WLOC
         TEXTE(NBTEX) = format$("K:10X",TEX(NBTEX))-format$("K:3X",[F:STC]LOCTYP)-mess([F:STC]LOCCAT,2710,1)
      Endif
   Endif
Endif

Return



#**
#* Obtener el código de ubicación de la tabla varia 2707
#*
#*
#* @param PLOCNUM
#*!
Funprog  GET_LOC(PLOCNUM)
Value Integer PLOCNUM
Value Integer LRES
Local Char LOCDES(50)

If !clalev([YAST0]) Then : Local File APLSTD [YAST0] : Endif
If !clalev([YAST1]) Then : Local File APLSTD [YAST1] : Endif
Read [YAST0]LAN='SPA';2713;PLOCNUM
If !fstat Then
  LOCDES = [F:YAST0]LANMES

  Filter [F:YAST1] Where LANCHP = 2707 and LAN = 'SPA' and LANMES = LOCDES
  Read [F:YAST1] First
  If !fstat Then
    LRES = [F:YAST1]LANNUM
  Else
    LRES = 0
  Endif
  Filter [F:YAST1]
  Close Local File [YAST1]
Endif

Close Local File [YAST0]



End LRES

