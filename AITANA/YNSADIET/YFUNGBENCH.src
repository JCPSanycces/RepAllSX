#####################################################################################
# Src: YFUNGBENCH
#-------------------------------------------------------------------------------------
# (FUNMPICK - PUNTO DE ENTRADA)
#-------------------------------------------------------------------------------------
# Proyecto: YNSADIET
#-------------------------------------------------------------------------------------
# Version: V12
#-------------------------------------------------------------------------------------
# Fecha:12-11-2019
#-------------------------------------------------------------------------------------
# Desarrollador: DSAL
# Codigo Actividad: YPO06
#######################################################################################

$ACTION
Case ACTION
  When "CHECKORD"   : Gosub CHECKORD # Compruebo valor seleccionado por STD para saltarlo o no en función de los atributos
  When "ADDLIN"     : Gosub ADDLIN   # Pongo valor a los campos SPE en la transacción de YSIM - Simulaciones
  When "CUSSELFLT"  : Gosub CUSSELFLT # Añado criterios suplementarios
Endcase
Return

###################################################
$CHECKORD
If clalev([F:XX1]) <= 0 : Local File YITMATRIB [XX1]  : Endif
If [M:MGB]YATRIBUTO1 <> "" or [M:MGB]YATRIBUTO2 <> "" or [M:MGB]YATRIBUTO3 <> ""
  Read [XX1]YAIT0 = [F:ORD]ITMREF;[M:MGB]YATRIBUTO1
  If fstat <> 0
    If [M:MGB]YATRIBUTO2 <> ""
      Read [XX1]YAIT0 = [F:ORD]ITMREF;[M:MGB]YATRIBUTO2
      If fstat <> 0
        If [M:MGB]YATRIBUTO3 <> ""
          Read [XX1]YAIT0 = [F:ORD]ITMREF;[M:MGB]YATRIBUTO3
          If fstat <> 0
            GPE= 1
          Endif
        Else
          GPE = 1
        Endif
      Endif
    Else
      GPE = 1
    Endif
  Endif
Endif
Close Local File [XX1]
Return


###################################################
$ADDLIN
# Solamente para la transacción de las simulaciones
If [F:BTS]BTSNUM = "YSIM"
  If clalev ([F:YIT]) <= 0 : Local File ITMMVT     [YIT]    : Endif
  If clalev ([F:YIM]) <= 0 : Local File ITMMASTER  [YIM]    : Endif
  If clalev ([F:YSL]) <= 0 : Local File STOLOT     [YSL]    : Endif
  If clalev ([F:YPQ]) <= 0 : Local File PORDERQ    [YPQ]    : Endif
  If clalev ([F:YBP]) <= 0 : Local File BPARTNER   [YBP]    : Endif
  If clalev ([F:YPP]) <= 0 : Local File PORDERP    [YPP]    : Endif
  If clalev ([F:YIS]) <= 0 : Local File ITMBPS     [YIS]    : Endif
  If clalev ([F:Y01]) <= 0 : Local File MFGMAT     [Y01]    : Endif
  If clalev ([F:Y02]) <= 0 : Local File MFGHEAD    [Y02]    : Endif

  Local Char CODPROV

  Read [YIT]ITV0 = [M:MGB]ITMREF(nolign-1);[M:MGB]STOFCY
  If fstat = 0
    [M:MGB]YSTOCK(nolign-1)     = [YIT]PHYSTO   # Stock físico actual en A
    [M:MGB]YSTOCKQ(nolign-1)    = [YIT]CTLSTO   # Stock físico actual en Q
    [M:MGB]YCTDPTEREC(nolign-1) = [YIT]ORDSTO   # Cantidad pendiente de recibir
  Endif

  Read [YIM]ITM0 = [M:MGB]ITMREF(nolign-1)
  If fstat = 0
    [M:MGB]YINFOART(nolign-1)   = [YIM]YTEXTOPROD   # Información artículo
  Endif

  Filter [YSL] Where [YSL]ITMREF = [M:MGB]ITMREF(nolign-1) Order By [YSL]SHLDAT Desc
  Read [YSL] First
  If fstat = 0
    [M:MGB]YCADUCIDAD(nolign-1)   = [YSL]SHLDAT   # Fecha de caducidad más alta
  Endif

  Filter [YPQ] Where [YPQ]POHFCY = [M:MGB]STOFCY and [YPQ]ITMREF = [M:MGB]ITMREF(nolign-1) Order By [YPQ]POHNUM Desc
  Read [YPQ] First
  If fstat = 0
    If CODPROV = "" : CODPROV = [YPQ]BPSNUM : Endif
    [M:MGB]YCTDULTPED(nolign-1) = [YPQ]QTYPUU   # Cantidad último pedido
    Read [YBP]BPR0 = [YPQ]BPSNUM
    If fstat = 0
      [M:MGB]YULTPROV(nolign-1) = [YBP]BPRNAM
    Endif
  Endif
  Filter [YPQ]

#  Filter [YPQ] Where [YPQ]POHFCY = [M:MGB]STOFCY and [YPQ]ITMREF = [M:MGB]ITMREF(nolign-1) Order By [YPQ]EXTRCPDAT Asc #JC03052021
  Filter [YPQ] Where [YPQ]POHFCY = [M:MGB]STOFCY and [YPQ]ITMREF = [M:MGB]ITMREF(nolign-1) and LINCLEFLG <> 2 Order By [YPQ]EXTRCPDAT Asc
  Read [YPQ] First
  If fstat = 0
    [M:MGB]YENTULTPED(nolign-1) = [YPQ]EXTRCPDAT   # Fecha de recepción más cercana
    [M:MGB]YNUMPED(nolign-1)    = [YPQ]POHNUM      # Nº de pedido con la fecha de recepción más cercana  #JC.03052021
    Read [YPP]POP0 = [YPQ]POHNUM;[YPQ]POPLIN;[YPQ]POQSEQ
    If fstat = 0
      [M:MGB]NETPRI(nolign-1)    = [YPP]GROPRI      # Precio del pedido con la fecha de recepción más cercana
    Endif
  Endif
  Filter [YPQ]

  Read [YIS]ITP0 = [M:MGB]ITMREF(nolign-1);CODPROV
  If fstat = 0
    [M:MGB]YCTDMINCOM(nolign-1)  = [YIS]PURMINQTY
    [M:MGB]YPLAZOENTRE(nolign-1) = [YIS]YPLAZOENTRE
  Endif

  # Saco el valor del campo Reservado
  Local Decimal QTY_RES
  For [Y01] Where [Y01]MFGFCY = [M:MGB]FCY and [Y01]ITMREF = [M:MGB]ITMREF(nolign-1) and [Y01]MFGSTA = 1 and [Y01]MATSTA < 4  # OF en Firme y el material no Excluido
    Read [Y02]MFG0 = [Y01]MFGNUM
    If fstat = 0 and [Y02]MFGTRKFLG < 6   # La OF tiene que estar como mucho Saldada
      QTY_RES += [Y01]RETQTY - [Y01]USEQTY
    Else
      Goto SUIVI_OF
    Endif
    $SUIVI_OF
  Next
 [M:MGB]YRESERVADO(nolign-1) = QTY_RES

#  #JC.03052021.STR
#  If [F:ORD]VCRTYP = 14 Then
#    [M:MGB]YNUMPED(nolign-1) = [F:ORD]VCRNUM
#  Else
#    [M:MGB]YNUMPED(nolign-1) = [F:ORD]VCRNUM
#  Endif
#  #JC.03052021.END

  Close Local File [YIT],[YIM],[YSL],[YPQ],[YBP],[YPP],[YIS],[Y01],[Y02]
Endif
Return


###################################################
$CUSSELFLT
# Filtro por código de la simulación
If [M:MGB]YSIMULACION <> ""
  If CUSFLT = "" : CUSFLT = "1=1" : Endif
  CUSFLT += '& VCRNUM = [M:MGB]YSIMULACION'
Endif
Return
