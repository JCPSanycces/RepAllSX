#<AdxTL>@(#)0.0.0.0 $Revision$ 
########################################################
# Préparation d'expéditions
########################################################
# VXABP et VXABP are the VT screen
########################################################

########################################################
$ACTION

#Infbox ACTION

#--- Actions liées à la fenêtre de saisie
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "DEBUT"         : Gosub DEBUT
 When "SETBOUT"       : Gosub SETBOUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "AVANT_OK"      : Gosub AVANT_OK
 When "OK"            : Gosub OK
 When "AVANT_BOUTON"  : Gosub AVANT_BOUTON
 When "BOUTON"        : Gosub BOUTON
 When "END"           : Gosub CHECK
 When "FIN"           : Gosub FIN
Endcase

Return

########################################################
$OUVRE

GVTMOD=1
# Initialisation du site de stock
Gosub INIT_STOFCY From ENVADC
Gosub OUVRE       From TRTPREPA
If !clalev([F:STO1])  Local File STOCK   [STO1]  Endif
If !clalev([F:STL1])  Local File STOLOT  [STL1]  Endif
If !clalev([M:PREP])  Local Mask PREPLAN [PREP]  Endif

Return

########################################################
$DEBUT
Local Integer WOK, WRET, WCPT, WRETADC, WSRETADC
Local Integer NOL, NOW, NBALL
Local Integer WTYP, WMAJ, WSTOSEQ
Local Integer I, J, W1, W2
Local Char    WSERNUM(GLONSER), WSER(GLONSER)
Local Char    WSERNUMF(GLONSER)
Local Char    WLOT(GLONLOT)
Local Char    WSLO(GLONSLO)
Local Char    WLOC(GLONLOC)
Local Char    WSTA(GLONSTA)
Local Char    WPALNUM(GLONPAL)
Local Char    WCTRNUM(GLONCTR)
Local Char    WCRIT(240), WCRITLOT(240), WCRITSTO(240)
Local Decimal WPCUDIS, WSTUDIS, WSTUACTDIS
Local Decimal WQTY, WQTYSTU, WQTYSTUACT
Local Decimal WXAB1QTYSTUACT
Local Decimal LSTOCOU
Local Decimal LWIPQTY, LWIPQTA, WALPQTY
Local Decimal LQTA, LSHT
Local Integer LNBR, LNBJ
Local Integer WNBSERIE
Local Integer WWSTA, WWLOC
Local Char    WNIVERR(10)
Local Date    WDAT
#--- Lot V01
Local Integer WIMPBPR
#DLUBPC
Local Char NBDAY(10)
Raz NBDAY

# GFLAG contains the BP transaction
GFLAG = func ENVADC.SETTRANS(6)

Gosub INIT_SCREEN

# verify that the ADC site is set
If GXAFCY=""
   Call ERREUR(mess(16,7750,1)) From GESECRAN : FIN = 1 : Return
Endif

# JC.23092020.YN46.STR
  Global Char     GNUMVP(50)
  Global Integer  GNUMBULTOS
# JC.23092020.YN46.END

Return

########################################################
$INIT_SCREEN

Raz [M:XABP]
Raz [M:XAB1]

[M:XABP]STOFCY = GXAFCY
[M:XABP]SRTNUM = GFLAG

#MAE, le 21/09/2010, bg 67390
If dim([M:XABP]LOCDES)>0
   If [F:SRT]FLGLOCDES=1
      Grizo [M:XABP]LOCDES
   Else
      Actzo [M:XABP]LOCDES
   Endif
Endif


Affzo [M:XABP]1-99
Affzo [M:XAB1]1-99

Return

########################################################
$SETBOUT

If !find("O",CHBOU) CHBOU+="O" Endif
If !find("2",CHBOU) CHBOU+="2" Endif
If !find("3",CHBOU) CHBOU+="3" Endif
Gosub SET_BOUT_SPE From GSAISIE
Return

########################################################
$APRES_MODIF

# Apres modification 'liste preparation'
If COUZON="PRLNUM"
   Raz [M:PREP]
   [M:PREP]STOFCY    = [F:PRL]STOFCY
   [M:PREP]PREUSR    = [F:PRL]PREUSR
   [M:PREP]ALLTYPFLG = 2
   # Nettoyage de STOSORW
   Call RAZSTOSORW From STKSOR

   If CZ<>""
      [M:PREP]PRLNUM = CZ
      # Chargement liste preparation
      Gosub LOAD_PRLNUM From TRTPREPA
      If dim([M:XABP]LOCDES)>0
         [M:XABP]LOCDES = [M:PREP]LOCDESH
         #--- Bug 72230
         [M:XABP]LOCTYPDES = [M:PREP]LOCTYPDESH
      Endif
      # Les bons de prepa ne sont pas generes
      If sum([M:PREP]PRHNUM)=""
         Call ERREUR(mess(321,184,1)) From GESECRAN
         zonsui = zoncou
         Return
      # Ils sont déjà livrables ou livrés
      Elsif !find(1,[M:PREP]DLVFLG(0..[M:PREP]NBLIG-1))
      #Elsif [M:PREP]NBLIG>0 & sum([M:PREP]DLVFLG)>[M:PREP]NBLIG
         Call ERREUR(mess(322,184,1)) From GESECRAN
         zonsui = zoncou
         Return
      Endif
      #--- PE pour trier l'écran PREPLAN (Le tri doit toujours être fait par BP)
      # Exemple pour trier selon No Bon Préparation / Emplacement
      #Sorta [M:PREP]NBLIG [M:PREP]NBLIG Order By [M:PREP]PRHNUM(indice),[M:PREP]LOC(indice)
      GPOINT="SORT_PREP"
      Gosub ENTREE From EXEFNC
      #---
      nolign = 1
      NOL    = nolign-1
      [M:XABP]PRHNUM    = [M:PREP]PRHNUM(NOL)
      Diszo [M:XABP]PRHNUM
      Affzo [M:XABP]PRHNUM
      # Chargement d'une ligne de préparation
      Gosub CHARGE_PRE_XAB1
      If FIN=1 Return Endif
      If dim([M:XABP]LOCDES)>0 & varmode([M:XABP]LOCDES)=0
        zonsui="LOCDES"
      Else
        zonsui="QTYPCU"
      Endif

   Else
      Raz [M:XABP]PRHNUM
      Raz [M:XAB1]PRHNUMAFF
      Actzo [M:XABP]PRHNUM
      Affzo [M:XABP]PRHNUM
   Endif
# Apres modification 'bon preparation'
Elsif COUZON="PRHNUM"
   Raz [M:PREP]
   [M:PREP]STOFCY    = [F:PRH]STOFCY
   [M:PREP]PREUSR    = [F:PRH]PREUSR
   [M:PREP]TRSCOD    = [F:PRH]TRSCOD
   [M:PREP]ALLTYPFLG = 2
   # Nettoyage de STOSORW
   Call RAZSTOSORW From STKSOR
   If CZ<>""
      # Chargement bon de préparation
      Gosub LOAD_PRHNUM
      If dim([M:XABP]LOCDES)>0
         [M:XABP]LOCDES = [M:PREP]LOCDESH
         #--- Bug 72230
         [M:XABP]LOCTYPDES = [M:PREP]LOCTYPDESH
      Endif
      #--- PE pour trier l'écran PREPLAN (Le tri doit toujours être fait par BP)
      # Exemple pour trier selon No Bon Préparation / Emplacement
      #Sorta [M:PREP]NBLIG [M:PREP]NBLIG Order By [M:PREP]PRHNUM(indice),[M:PREP]LOC(indice)
      GPOINT="SORT_PREP"
      Gosub ENTREE From EXEFNC
      #---
      nolign = 1
      NOL    = nolign-1
      Diszo [M:XABP]PRLNUM
      Affzo [M:XABP]PRLNUM
      # Chargement d'une ligne de préparation
      Gosub CHARGE_PRE_XAB1
      If FIN=1 Return Endif
      If dim([M:XABP]LOCDES)>0 & varmode([M:XABP]LOCDES)=0
        zonsui="LOCDES"
      Else
        zonsui="QTYPCU"
      Endif
   Endif
Endif

Return

########################################################
$LOAD_PRHNUM

For [PRE]PRE0 Where PRHNUM=[F:PRH]PRHNUM

   If [M:PREP]NBLIG>=dim([M:PREP]COCHAGE)-1
      Call ERREUR(mess(53,184,1)-mess(232,184,1)) From GESECRAN
      Break
   Endif

   # Ouverture de la ligne
   nolign = [M:PREP]NBLIG
   Insa nolign,1,[M:PREP]NBLIG [M:PREP]NBLIG
   [M:PREP]NBLIG += 1
   nolign = [M:PREP]NBLIG
   NOL = nolign-1
   status = 0

   [M:PREP] = [F:PRE]

   [M:PREP]COCHAGE(NOL) = 2

   Case [F:PRE]ORITYP
    When 1,2 : Read [F:SOQ]SOQ0=[F:PRE]ORINUM;[F:PRE]ORILIN;[F:PRE]ORISEQ
               If fstat
                  # Ligne commande non trouvee --> pas de chargement
                  Goto NEXT_PRE
               Else
                  [M:PREP]LOTFIL   (NOL) = [F:SOQ]LOT
                  [M:PREP]LOCFIL   (NOL) = [F:SOQ]LOC
                  [M:PREP]STAFIL   (NOL) = [F:SOQ]STA
                  [M:PREP]QTYSTUMAX(NOL) = [F:SOQ]QTYSTU-[F:SOQ]LPRQTYSTU
&                                                       -[F:SOQ]OPRQTYSTU
&                                                       -[F:SOQ]PREQTYSTU
&                                                       -[F:SOQ]ODLQTYSTU
&                                                       -[F:SOQ]DLVQTYSTU
&                                                       +[F:PRE]QTYSTU
                  [M:PREP]STOMGTCOD(NOL) = [F:SOQ]STOMGTCOD
               Endif
    When 3,4 : Raz [M:PREP]LOTFIL(NOL)
               Raz [M:PREP]LOCFIL(NOL)
               Raz [M:PREP]STAFIL(NOL)
               [M:PREP]QTYSTUMAX(NOL) = [M:PREP]QTYSTU(NOL)
               Read [ITM]ITM0=[F:PRE]ITMREF
               If fstat
                  # Article non trouve --> pas de chargement
                  Goto NEXT_PRE
               Else
                  [M:PREP]STOMGTCOD(NOL)=[F:ITM]STOMGTCOD
                  If [F:ITM]STOMGTCOD>1
                     If [F:ITF]STOFCY<>[F:PRH]STOFCY | [F:ITF]ITMREF<>[F:PRE]ITMREF
                        Read [ITF]ITF0=[F:PRE]ITMREF;[F:PRH]STOFCY
                        If !fstat
                           [M:PREP]STOMGTCOD(NOL)=[F:ITF]STOMGTCOD
                        Endif
                     Endif
                  Endif
               Endif
   Endcase

   [M:PREP]ALLTYP(NOL) = [M:PREP]ALLTYPFLG
   Raz [M:PREP]ALLQTY(NOL)
   Raz [M:PREP]SHTQTY(NOL)
   #Raz [M:PREP]WSTOSEQ(NOL)
   [M:PREP]WSTOSEQ(NOL) = 1
   Raz [M:PREP]UPDFLG(NOL)
   [M:PREP]CREFLG(NOL) = nolign
   [M:PREP]DLVFLG(NOL) = [F:PRE]FLGVT+1
   [M:PREP]BESDAT(NOL) = [F:PRH]SHIDAT
   [M:PREP]DLVDAT(NOL) = [F:PRH]DLVDAT
   #Dlu Client
   [M:PREP]BPCORD(NOL) = [F:PRH]BPCORD

   # Alimentation zone stock
   Call RECSTOSOR(2,"PREP",NOL,[F:PRH]STOFCY,[F:PRE]ITMREF,
&                    3,[F:PRE]PRHNUM,[F:PRE]PRELIN,"",WRET) From STKECR

   [M:PREP]ALLTYP(NOL)    = [F:PRE]ALLTYP
   [M:PREP]ALLQTY(NOL)    = [F:PRE]ALLQTY
   [M:PREP]SHTQTY(NOL)    = [F:PRE]SHTQTY
   If dim([M:PREP]LOCDES)>0
      [M:PREP]LOCDES(NOL)    = [F:PRE]LOCDES
      [M:PREP]LOCTYPDES(NOL) = [F:PRE]LOCTYPDES
      # Alimentation emplacement destination entête
      If [M:PREP]LOCDESH=""
         [M:PREP]LOCDESH    = [M:PREP]LOCDES(NOL)
         [M:PREP]LOCTYPDESH = [M:PREP]LOCTYPDES(NOL)
      Elsif [M:PREP]LOCDESH<>[M:PREP]LOCDES(NOL)
         [M:PREP]LOCDESH    = "$"
         [M:PREP]LOCTYPDESH = ""
      Endif
   Endif
$NEXT_PRE
Next

Return

########################################################
$CHARGE_PRE_XAB1
# Recherche de la prochaine ligne de préparation à traiter
While NOL<[M:PREP]NBLIG & ([M:PREP]DLVFLG(NOL)>=2 | [M:PREP]FLGANN(NOL)=1)
   NOL+=1
Wend

If NOL>=[M:PREP]NBLIG
   # Toutes les lignes du bon ou de la liste sont-elles préparées
   W1=sigma(J=0,[M:PREP]NBLIG-1,[M:PREP]DLVFLG(J)*([M:PREP]FLGANN(J)=0))
   W2=sigma(J=0,[M:PREP]NBLIG-1,[M:PREP]FLGANN(J)=0)*2
   WOK=2
   # Toutes les lignes ne sont pas préparées
   If W1<W2
      If [M:XABP]PRLNUM<>""
         Call OUINON(mess(365,184,1),WOK) From GESECRAN
      Else
         Call OUINON(mess(360,184,1),WOK) From GESECRAN
      Endif
   Endif
   # Toutes les lignes de préparation ont été traitées
   # ou certaines ne l'ont pas été, mais on arrête
   If WOK=2
      If [M:XABP]PRLNUM<>""
         zonsui = "PRLNUM"
      Else
         #--- Bug 81380
         # Déblocage logique du BP
         If [M:XABP]PRHNUM<>""
            Unlock="PRH"+[M:XABP]PRHNUM
         Endif
         #---
         zonsui = "PRHNUM"
      Endif
      Raz [M:XAB1]PRHNUMAFF
      Raz [M:XABP]PRLNUM
      Raz [M:XABP]PRHNUM
      Actzo [M:XABP]PRLNUM
      Actzo [M:XABP]PRHNUM
      Affzo [M:XABP]PRLNUM
      Affzo [M:XABP]PRHNUM
      If W1>=W2 Call ERREUR(mess(71,197,1)) From GESECRAN Endif
      FIN=1
      Return
   # On reboucle pour traiter les lignes restantes
   Else
      NOL=0
      #--- Bug 82815
      Goto CHARGE_PRE_XAB1
   Endif
Endif
[M:XABP]PRHNUM = [M:PREP]PRHNUM(NOL)
Affzo [M:XABP]PRHNUM    # hcb 116170


# Toutes les lignes de préparation ont été traitées
#If NOL>=[M:PREP]NBLIG
#   FIN=1 : Return
#Endif

# Chargement d'une ligne de préparation
Read [ITM]ITM0=[M:PREP]ITMREF(NOL)
#--- Bug 81698
[M:XAB1]STOMGTCOD = [M:PREP]STOMGTCOD(NOL)
[M:XAB1]PRHNUMAFF = [M:PREP]PRHNUM(NOL)
[M:XAB1]ITMREF    = [M:PREP]ITMREF(NOL)
[M:XAB1]QTYORI    = [M:PREP]QTYSTU(NOL)
[M:XAB1]QTYTRT    = 0
[M:XAB1]BESDAT    = [M:PREP]BESDAT(NOL)
[M:XAB1]ORITYP    = [M:PREP]ORITYP(NOL)
# Chargement des allocations de la ligne de préparation
Gosub CHARGE_ALL_XAB1

# Lecture de la règle de gestion pour le mouvement à traiter
Call LECSRU([M:ALP]STOFCY,[F:ITM]TCLCOD,[M:ALP]TRSTYP,[M:ALP]TRSCOD,"",WRET) From STKLIB
If WRET<>0
   WRET=1 : FIN=1
Endif

Raz [M:XABP]INPNUM

Return

########################################################
$CHARGE_ALL_XAB1
# Chargement des allocations d'une ligne de préparation
Case [M:PREP]ORITYP(NOL)
 When 1   : [M:ALP]TRSTYP= 4
 When 2   : [M:ALP]TRSTYP=17
 When 3,4 : [M:ALP]TRSTYP=20
Endcase
[M:ALP]STOFCY    = [M:PREP]STOFCY
[M:ALP]TRSCOD    = [M:PREP]TRSCOD
[M:ALP]VCRTYP    = 3
[M:ALP]VCRNUM    = [M:PREP]PRHNUM(NOL)
[M:ALP]VCRLIN    = [M:PREP]PRELIN(NOL)
[M:ALP]VCRSEQ    = 0
[M:ALP]ITMREF    = [M:PREP]ITMREF(NOL)
[M:ALP]TYPQTY    = 2
[M:ALP]QTY       = [M:PREP]QTYSTU(NOL)
[M:ALP]STA       = [M:PREP]STAFIL(NOL)
[M:ALP]BESDAT    = [M:PREP]BESDAT(NOL)
[M:ALP]DLVDAT    = [M:PREP]DLVDAT(NOL)
[M:ALP]PECSCOLOC = 1
If dim([M:PREP]WRH)>0 [M:ALP]WRH=[M:PREP]WRH(NOL) Endif
#DLU client
[M:ALP]BPRNUM    = [M:PREP]BPCORD(NOL)
# Chargement STOSORW à partir des allocations
Call ALLSTOSORW("PREP",NOL,0,0,1,0,WRET) From STKSOR

# Pas d'allocation détaillée
If [M:SOW]NBLIG<=0
   NOW=0
   NBALL=0
   # Affichage pour saisie du stock
   Gosub AFF0_XAB1
Else
   NOW=0
   NBALL=[M:SOW]NBLIG
   # Affichage de la première ligne de stock à traiter
   Gosub AFF_XAB1
Endif

Return

########################################################
$AFF_XAB1
[M:XAB1]STU = [F:ITM]STU
# Affichage de la ligne de stock à préparer
Read[STO]STO0=[M:PREP]STOFCY;[M:SOW]WSTOCOU(NOW)
If !fstat
   [M:XAB1] = [F:STO]
   [M:XAB1]STOCOU = [M:SOW]WSTOCOU(NOW)
   [M:XAB1]QTYSTU = [M:SOW]WQTYSTU(NOW)
   [M:XAB1]ALLSTU = [M:SOW]WALLSTU(NOW)
   [M:XAB1]QTYPCU = [M:XAB1]QTYSTU/[M:XAB1]PCUSTUCOE
   Call QTEARR([M:XAB1]QTYPCU,[M:XAB1]PCU) From TRTDIV
   # Quantité traitée
   #[M:XAB1]QTYTRT += [M:XAB1]QTYSTU
Endif
Diszo [M:XAB1]PCU, PCUSTUCOE, STA
If dim([M:XAB1]LOC)>0
   If [F:ITF]LOCMGTCOD=2
      Diszo [M:XAB1]LOC
   Else
      Grizo [M:XAB1]LOC
   Endif
Endif
If dim([M:XAB1]LOT)>0
   If [F:ITM]LOTMGTCOD>1
      Diszo [M:XAB1]LOT
   Else
      Grizo [M:XAB1]LOT
   Endif
Endif
If dim([M:XAB1]SLO)>0
   If [F:ITM]LOTMGTCOD=4
      Diszo [M:XAB1]SLO
   Else
      Grizo [M:XAB1]SLO
   Endif
Endif
If dim([M:XAB1]SERNUM)>0
   If [F:ITM]SERMGTCOD>2
      Diszo [M:XAB1]SERNUM
   Else
      Grizo [M:XAB1]SERNUM
   Endif
Endif
Chgstl [M:XAB1]QTYPCU With ""
Affzo [M:XAB1]10
Return

########################################################
$AFF0_XAB1
# Affichage de la ligne à préparer (stock non connu)
If dim([M:XAB1]LOC)>0    Raz [M:XAB1]LOC    Endif
If dim([M:XAB1]LOT)>0    Raz [M:XAB1]LOT    Endif
If dim([M:XAB1]SLO)>0    Raz [M:XAB1]SLO    Endif
If dim([M:XAB1]SERNUM)>0 Raz [M:XAB1]SERNUM Endif
Raz [M:XAB1]STA, STOCOU, ALLSTU
#--- Issue 108476 by TS
Raz [M:XAB1]PALNUM, [M:XAB1]CTRNUM
#---
[M:XAB1]PCU       = [F:ITM]STU
[M:XAB1]PCUSTUCOE = 1
[M:XAB1]QTYSTU    = [M:XAB1]QTYORI-[M:XAB1]QTYTRT
[M:XAB1]QTYPCU    = [M:XAB1]QTYSTU

#--- Bug 81698
If [M:XAB1]STOMGTCOD=1
  If dim([M:XAB1]LOC)>0    Diszo [M:XAB1]LOC    Endif
  If dim([M:XAB1]LOT)>0    Diszo [M:XAB1]LOT    Endif
  If dim([M:XAB1]SLO)>0    Diszo [M:XAB1]SLO    Endif
  If dim([M:XAB1]SERNUM)>0 Diszo [M:XAB1]SERNUM Endif
  Actzo [M:XAB1]PCU, PCUSTUCOE
  Diszo [M:XAB1]STA
Else
#---
  If dim([M:XAB1]LOC)>0    Actzo [M:XAB1]LOC    Endif
  If dim([M:XAB1]LOT)>0    Actzo [M:XAB1]LOT    Endif
  If dim([M:XAB1]SLO)>0    Actzo [M:XAB1]SLO    Endif
  If dim([M:XAB1]SERNUM)>0 Actzo [M:XAB1]SERNUM Endif
  Actzo [M:XAB1]PCU, PCUSTUCOE, STA
  If dim([M:XAB1]LOC)>0
    If [F:ITF]LOCMGTCOD=2
      Call STKINIEMPS([M]LOC) From STKLOC
    Else
      Grizo [M:XAB1]LOC
    Endif
  Endif
  If dim([M:XAB1]LOT)>0
    If [F:ITM]LOTMGTCOD<2
      Grizo [M:XAB1]LOT
    Else
      Actzo [M:XAB1]LOT
    Endif
  Endif
  If dim([M:XAB1]SLO)>0
    If [F:ITM]LOTMGTCOD<2 | [F:ITM]LOTMGTCOD<>4
      Grizo [M:XAB1]SLO
    Else
      Actzo [M:XAB1]SLO
    Endif
  Endif
  If dim([M:XAB1]SERNUM)>0
    If [F:ITM]SERMGTCOD<3
      Grizo [M:XAB1]SERNUM
    Else
      Actzo [M:XAB1]SERNUM
    Endif
  Endif
#--- Bug 81698
Endif

Chgstl [M:XAB1]QTYPCU With "AWARNLOW"
Affzo [M:XAB1]10
Return

########################################################
$AVANT_OK
FIN=0

# Il n'y a rien à traiter
If [M:XAB1]PRHNUMAFF=""
   FOK=0 : Return
Endif

#--- Bug 81698
If [M:XAB1]STOMGTCOD=1 Return Endif

# Si la ligne est issue d'une allocation, on ne fait rien
If [M:XAB1]STOCOU<>0 Return Endif

# Stock non connu et pas de quantité saisie
#If [M:XAB1]QTYPCU=0
#   WOK=2
#   # Abandon de la préparation de la ligne ?
#   Call OUINON(mess(362,184,1),WOK) From GESECRAN
#   If WOK=1
#      # On retourne en saisie de la quantité
#      FOK=0 : zonsui="QTYPCU" : Return
#   Else
#     # Abandon de la préparation de la ligne
#      Call RAZSTOSORW From STKSOR
#      # Chargement ligne de préparation suivante
#      NOL+=1
#      Gosub CHARGE_PRE_XAB1
#      FOK=0 : zonsui="QTYPCU" : Return
#   Endif
#Endif

# JC.17092020.YN46.STR
If GBORRAR = 1 Then
      # On retourne en saisie de la quantité
      FOK=0
Else
# JC.17092020.YN46.END
# Stock non connu et pas de quantité saisie
If [M:XAB1]QTYPCU=0
   WOK=2
   # Génération d'une rupture ?
   Call OUINON(mess(451,196,1),WOK) From GESECRAN
   If WOK=1
      # On retourne en saisie de la quantité
      FOK=0 : zonsui="QTYPCU" : Return
   Else
      If NOW>=dim([M:SOW]WSTOSEQ)
         Call ERREUR(mess(352,199,1)) From GESECRAN
         WRET=2 : Goto AVANT_OK_SUITE
      Endif
      # Génération d'une rupture
      [M:SOW]WSTOSEQ(NOW)    = 1
      [M:SOW]WSTOCOU(NOW)    = 0
      [M:SOW]WQTYSTU(NOW)    = [M:XAB1]QTYORI-[M:XAB1]QTYTRT
      [M:SOW]WQTYSTUACT(NOW) = [M:SOW]WQTYSTU(NOW)
      [M:SOW]WALLSTU(NOW)    = 0
      [M:SOW]WALLSTUACT(NOW) = 0
      [M:SOW]NBLIG  += 1
      [M:XAB1]QTYTRT = [M:XAB1]QTYORI
      Return
   Endif
Endif

#Raz GOUVSOR
# Alimentation de [M:ALP]
Gosub ALI_ALP From TRTPREP
[M:ALP]QTY = [M:XAB1]QTYSTU
# Détermination du stock à sortir (automatisme, saisie)
Raz WRET
#Call OUVSOR("PREP",NOL,[M:PREP]NBLIG,[M:PREP]WSTOSEQ(NOL),1,WRET)
#&           From STKSOR
Gosub RECH_STOCK

$AVANT_OK_SUITE
#If GOUVSOR>=1
If WRET>0
   WNIVERR=""
   If WRETADC>=512 : WNIVERR+="1" : WRETADC-=512 : Endif : # Quantité
   If WRETADC>=256 : WNIVERR+="2" : WRETADC-=256 : Endif : # Emplacement
   If WRETADC>=128 : WNIVERR+="3" : WRETADC-=128 : Endif : # Dem analyse
   If WRETADC>= 64 : WNIVERR+="4" : WRETADC-= 64 : Endif : # Statut
   If WRETADC>= 32 : WNIVERR+="5" : WRETADC-= 32 : Endif : # Inventaire
   If WRETADC>= 16 : WNIVERR+="6" : WRETADC-= 16 : Endif : # Lot périmé
   If WRETADC>=  8 : WNIVERR+="7" : WRETADC-=  8 : Endif : # Sous-lot
   If WRETADC>=  4 : WNIVERR+="8" : WRETADC-=  4 : Endif : # Lot
   If WRETADC>=  2 : WNIVERR+="9" : WRETADC-=  2 : Endif : # Série
   If WRETADC =  1 : WNIVERR+="0" : WRETADC-=  1 : Endif : # Pas de stock
   If find("1",WNIVERR)
      GMESSAGE=mess(20,7750,1)
   Elsif find("9",WNIVERR)
      GMESSAGE=mess(4,7750,1)
   Elsif find("8",WNIVERR)
      GMESSAGE=mess(2,7750,1)
   Elsif find("7",WNIVERR)
      GMESSAGE=mess(3,7750,1)
   Elsif find("2",WNIVERR)
      GMESSAGE=mess(5,7750,1)
   Elsif find("3",WNIVERR)
      GMESSAGE=mess(19,7750,1)
   Elsif find("6",WNIVERR)
      GMESSAGE=mess(398,199,1)
   Elsif find("5",WNIVERR)
      GMESSAGE=mess(126,184,1)
   Elsif find("4",WNIVERR)
      GMESSAGE=mess(6,7750,1)
   Elsif find("0",WNIVERR)
      GMESSAGE=mess(21,7750,1)
   Else
      GMESSAGE=mess(12,7750,1)
   Endif
   GERR=1 : FOK=0 : zonsui="[M:XAB1]QTYPCU" : Return
Endif

# JC.17092020.YN46.STR
Endif
# JC.17092020.YN46.END
Return

########################################################
$OK
# Si caractéristiques stock saisies,
# le traitement du OK a été fait en AVANT_OK
If [M:XAB1]STOCOU=0 : Goto OK_SUITE2 : Endif

#--- Maj de STOSORW
Trbegin [STO]

Readlock [STO]STO0=[M:XABP]STOFCY;[M:XAB1]STOCOU
If fstat
   Call RSTA("STO",[M:XABP]STOFCY-num$([M:XAB1]STOCOU)) From GLOCK
   GERR=1 : Goto OK_SUITE
Endif
LSTOCOU = [F:STO]STOCOU

# Calcul de la quantité saisie en UA
WXAB1QTYSTUACT = ([M:XAB1]QTYSTU*[F:STO]QTYSTUACT)/[F:STO]QTYSTU

# Il n'y avait pas de SOW --> Alimentation du SOW
If NOW>=[M:SOW]NBLIG
   #[M:SOW]WSTOSEQ(NOW)     = 0
   [M:SOW]WSTOSEQ(NOW)     = 1
   [M:SOW]WSTOCOU(NOW)     = LSTOCOU
   [M:SOW]WQTYSTU(NOW)    = [M:XAB1]QTYSTU
   [M:SOW]WQTYSTUACT(NOW) = WXAB1QTYSTUACT
   Call QTEARR([M:SOW]WQTYSTUACT(NOW),[F:ITM]STU) From TRTDIV
   [M:SOW]WALLSTU(NOW)    = 0
   [M:SOW]WALLSTUACT(NOW) = 0
   [M:SOW]NBLIG += 1

   # Création quantité en cours de traitement
   LWIPQTY = [M:SOW]WQTYSTU(NOW)
   LWIPQTA = [M:SOW]WQTYSTUACT(NOW)
   [F:STO]CUMWIPQTY += LWIPQTY
   [F:STO]CUMWIPQTA += LWIPQTA
   Call CRE_STOWIPW(LSTOCOU,LWIPQTY,LWIPQTA) From STKLIB
   Rewrite [STO]
   If fstat
      Call FSTA("STO") From GLOCK
      GERR=1 : Goto OK_SUITE
   Endif
# Il avait un SOW dont la quantité a augmentée --> Maj
Elsif [M:XAB1]QTYSTU>[M:SOW]WQTYSTU(NOW)
   # La quantité était <= à la qté allouée
   If [M:SOW]WQTYSTU(NOW)<=[M:SOW]WALLSTU(NOW)
      # La nouvelle quantité est > à la qté allouée
      If [M:XAB1]QTYSTU>[M:SOW]WALLSTU(NOW)
         # Création quantité en cours de traitement
         LWIPQTY = [M:XAB1]QTYSTU-[M:SOW]WALLSTU(NOW)
         LWIPQTA = WXAB1QTYSTUACT-[M:SOW]WALLSTUACT(NOW)
         [F:STO]CUMWIPQTY += LWIPQTY
         [F:STO]CUMWIPQTA += LWIPQTA
         Call CRE_STOWIPW(LSTOCOU,LWIPQTY,LWIPQTA) From STKLIB
         Rewrite [STO]
         If fstat
            Call FSTA("STO") From GLOCK
            GERR=1 : Goto OK_SUITE
         Endif
      Endif
   # La quantité était > à la qté allouée
   Else
      # Augmentation quantité en cours de traitement
      LINIQTA = [M:SOW]WQTYSTUACT(NOW)-[M:SOW]WALLSTUACT(NOW)
      LWIPQTY = [M:XAB1]QTYSTU-[M:SOW]WQTYSTU(NOW)
      LWIPQTA = WXAB1QTYSTUACT-[M:SOW]WQTYSTUACT(NOW)
      [F:STO]CUMWIPQTY += LWIPQTY
      [F:STO]CUMWIPQTA += LWIPQTA
      Call ADD_STOWIPW(LSTOCOU,LINIQTA,LWIPQTY,LWIPQTA) From STKLIB
      Rewrite [STO]
      If fstat
         Call FSTA("STO") From GLOCK
         GERR=1 : Goto OK_SUITE
      Endif
   Endif
   #--- Maj des quantités dans SOW
   [M:SOW]WQTYSTU(NOW)    = [M:XAB1]QTYSTU
   [M:SOW]WQTYSTUACT(NOW) = WXAB1QTYSTUACT
# Il avait un SOW dont la quantité a diminuée --> Maj
Elsif [M:XAB1]QTYSTU<[M:SOW]WQTYSTU(NOW)
   # La quantité était > à la qté allouée
   If [M:SOW]WQTYSTU(NOW)>[M:SOW]WALLSTU(NOW)
      # La nouvelle quantité est <= à la qté allouée
      If [M:XAB1]QTYSTU<=[M:SOW]WALLSTU(NOW)
         # Suppression de la quantité en cours de traitement
         LWIPQTY = [M:SOW]WQTYSTU(NOW)-[M:SOW]WALLSTU(NOW)
         LWIPQTA = [M:SOW]WQTYSTUACT(NOW)-[M:SOW]WALLSTUACT(NOW)
         [F:STO]CUMWIPQTY -= LWIPQTY
         [F:STO]CUMWIPQTA -= LWIPQTA
         Call DEL_STOWIPW(LSTOCOU,LWIPQTY) From STKLIB
         Rewrite [STO]
         If fstat
            Call FSTA("STO") From GLOCK
            GERR=1 : Goto OK_SUITE
         Endif
         # La qté allouée était nulle, la nouvelle quantité aussi
         # --> raz du STOCOU de STOSORW pour ignorer la ligne
         If [M:SOW]WALLSTU(NOW)=0 [M:SOW]WSTOCOU(NOW)=0 Endif
      # La nouvelle quantité est > à la qté allouée
      Else
         # Diminution de la quantité en cours de traitement
         LWIPQTY = [M:SOW]WQTYSTU(NOW)-[M:XAB1]QTYSTU
         LWIPQTA = (LWIPQTY*[M:SOW]WQTYSTUACT(NOW))/[M:SOW]WQTYSTU(NOW)
         [F:STO]CUMWIPQTY -= LWIPQTY
         [F:STO]CUMWIPQTA -= LWIPQTA
         Call DIM_STOWIPW(LSTOCOU,LWIPQTY,LWIPQTA) From STKLIB
         Rewrite [STO]
         If fstat
            Call FSTA("STO") From GLOCK
            GERR=1 : Goto OK_SUITE
         Endif
      Endif
   Endif
   #--- Maj des quantités dans SOW
   If [M:XAB1]QTYSTU=0
      # Raz de SOW
      Raz [M:SOW]WSTOSEQ(NOW),[M:SOW]WSTOCOU(NOW)
      Raz [M:SOW]WLOT(NOW),[M:SOW]WSLO(NOW),[M:SOW]WLOC(NOW),[M:SOW]WWRH(NOW)
      Raz [M:SOW]WSTA(NOW),[M:SOW]WSERNUM(NOW),[M:SOW]WPLFSTO(NOW)
      Raz [M:SOW]WQTYSTU(NOW),[M:SOW]WQTYSTUACT(NOW)
      Raz [M:SOW]WALLSTU(NOW),[M:SOW]WALLSTUACT(NOW)
   Else
      # Maj de SOW
      [M:SOW]WQTYSTU(NOW)    = [M:XAB1]QTYSTU
      [M:SOW]WQTYSTUACT(NOW) = WXAB1QTYSTUACT
      If [M:XAB1]QTYSTU < [M:SOW]WALLSTU(NOW)
         [M:SOW]WALLSTU(NOW)    = [M:XAB1]QTYSTU
         [M:SOW]WALLSTUACT(NOW) = WXAB1QTYSTUACT
      Endif
   Endif
Endif

$OK_SUITE
If GERR=1
   Rollback : Return
Else
   Commit
Endif

$OK_SUITE2
[M:XABP]INPNUM=[M:XABP]PRHNUM
NOW+=1
# Incrémentation quantité traitée
[M:XAB1]QTYTRT += [M:XAB1]QTYSTU
# Tous les STOSORW pré-alimentés ont été traités
If NOW>=NBALL
   # Quantité à préparer traitée --> maj de la ligne de préparation
   If [M:XAB1]QTYTRT=[M:XAB1]QTYORI
      # Maj ligne de préparation
      Gosub OK_BP
   # Quantité traitée < qté à préparer
   Elsif [M:XAB1]QTYTRT<[M:XAB1]QTYORI
      # --> on continue la saisie
      Gosub AFF0_XAB1
      zonsui = "QTYPCU"
   # Quantité traitée > qté à préparer
   Else
      # Ne doit pas arriver
   Endif
# Il en reste à traiter, passage au STOSORW suivant
Else
   If [M:SOW]WSTOCOU(NOW)<>0
      Gosub AFF_XAB1
      zonsui="QTYPCU"
   Else
      Goto OK_SUITE2
   Endif
Endif
FIN=0
Return

########################################################
$OK_BP

# Maj ligne de préparation
Gosub MAJ_LIG_PRE

Call RAZSTOSORW From STKSOR

NOL+=1
# Toutes les lignes de préparation ont été traitées
If NOL>=[M:PREP]NBLIG

   # Toutes les lignes du bon de préparation sont-elles préparées
   W1=sigma(J=0,[M:PREP]NBLIG-1,[M:PREP]DLVFLG(J)*([M:PREP]FLGANN(J)=0))
   W2=sigma(J=0,[M:PREP]NBLIG-1,[M:PREP]FLGANN(J)=0)*2
   WOK=2
   # Toutes les lignes ne sont pas préparées
   If W1<W2
      If [M:XABP]PRLNUM<>""
         Call OUINON(mess(365,184,1),WOK) From GESECRAN
      Else
         Call OUINON(mess(360,184,1),WOK) From GESECRAN
      Endif
   Endif
   # Toutes les lignes de préparation ont été traitées
   # ou certaines ne l'ont pas été, mais on arrête
   If WOK=2
      If [M:XABP]PRLNUM<>""
         zonsui = "PRLNUM"
      Else
         #--- Bug 81380
         # Déblocage logique du BP
         If [M:XABP]PRHNUM<>""
            Unlock="PRH"+[M:XABP]PRHNUM
         Endif
         #---
         zonsui = "PRHNUM"
      Endif
      Raz [M:XAB1]PRHNUMAFF
      Raz [M:XABP]PRLNUM
      Raz [M:XABP]PRHNUM
      Affzo [M:XABP]PRLNUM    # hcb 116170
      Affzo [M:XABP]PRHNUM    # hcb 116170
      Actzo [M:XABP]PRLNUM
      Actzo [M:XABP]PRHNUM
      Return
   # On reboucle pour traiter les lignes restantes
   Else
      NOL=0
   Endif
Endif
[M:XABP]PRHNUM = [M:PREP]PRHNUM(NOL)
Affzo [M:XABP]PRHNUM    # hcb 116170
# Chargement ligne de préparation suivante
Gosub CHARGE_PRE_XAB1
If FIN=1 Return Endif
zonsui="QTYPCU"

Return

########################################################
$MAJ_LIG_PRE

Call DEBTRANS From GLOCK
Trbegin [PRE]
WMAJ=0
Readlock [PRE]PRE0=[M:PREP]PRHNUM(NOL);[M:PREP]PRELIN(NOL)
If !fstat
   Read [PRH]PRH0=[M:PREP]PRHNUM(NOL)
   If !fstat
      Raz [M:ALP]ALLQTY,[M:ALP]ALLQTYSHT
      Raz [M:ALP]DESQTY,[M:ALP]DESQTYSHT
      [M:ALP]MVTDES = [M:PREP]MVTDES(NOL)
      WDELTAQTY = [M:PREP]QTYSTU(NOL)-[F:PRE]QTYSTU
      # Article géré en stock
      If [M:PREP]STOMGTCOD(NOL) <> 1
         [L]WSTOSEQ = [M:PREP]WSTOSEQ(NOL)
         [M:ALP]QTY    = [F:PRE]QTYSTU
         Gosub GESALL From TRTPREPA
         If GOK<=0
            # On remet les quantités à leur valeur initiale
            #[M:PREP]QTYSTU(NOL) = [F:PRE]QTYSTU
            #[M:PREP]ALLQTY(NOL) = [F:PRE]ALLQTY
            #[M:PREP]SHTQTY(NOL) = [F:PRE]SHTQTY
            #[M:PREP]ALLTYP(NOL) = [F:PRE]ALLTYP
            Goto MAJ_LIG_PRE_FIN
         Else
            [M:PREP]ALLQTY(NOL) = [M:ALP]ALLQTY
            [M:PREP]SHTQTY(NOL) = [M:ALP]ALLQTYSHT
            [M:PREP]ALLTYP(NOL) = 2
         Endif
      Endif
      [F:PRE]QTYSTU    = [M:PREP]QTYSTU(NOL)
      [F:PRE]ALLQTY    = [M:PREP]ALLQTY(NOL)
      [F:PRE]SHTQTY    = [M:PREP]SHTQTY(NOL)
      [F:PRE]ALLTYP    = [M:PREP]ALLTYP(NOL)
      If dim([M:PREP]LOCDES)>0
         #--- Bug 72230
         If !find([M:XABP]LOCDES,"","$")
            [M:PREP]LOCDES(NOL)    = [M:XABP]LOCDES
            [M:PREP]LOCTYPDES(NOL) = [M:XABP]LOCTYPDES
         Endif
         #---
         [F:PRE]LOCDES    = [M:PREP]LOCDES(NOL)
         [F:PRE]LOCTYPDES = [M:PREP]LOCTYPDES(NOL)
      Endif
      [F:PRE]PCK       = [M:PREP]PCK(NOL)
      [F:PRE]PCKCAP    = [M:PREP]PCKCAP(NOL)
      [F:PRE]PCKFLG    = [M:PREP]PCKFLG(NOL)
      [F:PRE]FLGVT     = 1
      Rewrite [PRE]
      If fstat
         GOK=0 : Call FSTA("PRE") From GLOCK
         Goto MAJ_LIG_PRE_FIN
      Endif
      # Si liste de préparation
      If [M:PREP]PRLNUM<>""
         Readlock [PRL]PRL0=[M:PREP]PRLNUM;[M:PREP]PRLSEQ(NOL)
         If !fstat
            [F:PRL]QTYSTU += WDELTAQTY
            [F:PRL]PCK     = [M:PREP]PCK   (NOL)               # hcb 110673
            [F:PRL]PCKCAP  = [M:PREP]PCKCAP(NOL)               # hcb 110673
            [F:PRL]PCKFLG  = [M:PREP]PCKFLG(NOL)               # hcb 110673
            Rewrite [PRL]
            If fstat
               GOK=0 : Call FSTA("PRL") From GLOCK
               Goto MAJ_LIG_PRE_FIN
            Endif
         Endif
      Endif
      If WDELTAQTY<>0
         Case [M:PREP]ORITYP(NOL)
          When 1,2 : If [M:PREP]DLVFLG(NOL)=2
                        WTYP=5
                     Elsif [M:PREP]DLVFLG(NOL)<2
                        WTYP=4
                     Endif
                     Call MAJ_SOQ (WTYP,[M:PREP]ORINUM(NOL),[M:PREP]ORILIN(NOL),
&                                 [M:PREP]ORISEQ(NOL),[M:PREP]PCU(NOL),
&                                 [M:PREP]PCUSTUCOE(NOL),WDELTAQTY) From STKPREPA
          When 3   : Call MAJ_REO (WMAJ,[M:PREP]STOFCY,[M:PREP]ITMREF(NOL),
&                                 [M:PREP]REOLOC(NOL),WDELTAQTY) From STKPREPA
          When 4   : Call MAJ_STA (WMAJ,[M:PREP]STOFCY,[M:PREP]ITMREF(NOL),
&                                 [M:PREP]SEQ(NOL),WDELTAQTY) From STKPREPA
         Endcase
         If GOK<=0  Goto MAJ_LIG_PRE_FIN Endif
      Endif
   Else
      GOK=0 : Call RSTA("PRH",[M:PREP]PRHNUM(NOL)) From GLOCK
   Endif
Else
   GOK=0 : Call RSTA("PRE",[M:PREP]PRHNUM(NOL)-num$([M:PREP]PRELIN(NOL))) From GLOCK
Endif

$MAJ_LIG_PRE_FIN
#--- Lot V01
WIMPBPR=0
If GOK=1
   # Ligne de préparation traitée
   [M:PREP]DLVFLG(NOL)=2

   # Toutes les lignes du bon de préparation sont-elles préparées
   W1=sigma(J=0,[M:PREP]NBLIG-1,[M:PREP]DLVFLG(J)*([M:PREP]PRHNUM(J)=[F:PRH]PRHNUM&[M:PREP]FLGANN(J)=0))
   W2=sigma(J=0,[M:PREP]NBLIG-1,[M:PREP]PRHNUM(J)=[F:PRH]PRHNUM&[M:PREP]FLGANN(J)=0)*2
   # Si oui, le bon de préparation est-il livrable ?
   If W1=W2
      WOK=2
      # Stock négatif interdit
      For I=0 To [M:PREP]NBLIG-1
         # La ligne n'est pas annulée
         If [M:PREP]FLGANN(I)=0
            # Il y a des ruptures
            If [M:PREP]SHTQTY(I)<>0
               # Changement d'emplacement, préparation non livrable
               If [M:PREP]LOCDES(I)<>""
                  WOK=1 : Break
               Else
                  # Stock négatif interdit, préparation non livrable
                  Read [ITM]ITM0=[M:PREP]ITMREF(I)
                  If [F:ITM]NEGSTO<>2
                     WOK=1 : Break
                  Endif
               Endif
            Endif
         Endif
      Next I
      # Le bon est livrable
      If WOK=2 : Gosub LIV_BP : Endif
      #--- Bug 77297
      If dim([M:XABP]LOCDES)>0  & [M:XABP]PRLNUM = ""              # hcb 116170
         Raz [M:XABP]LOCDES                                        # hcb 116170
      Endif                                                        # hcb 116170

   Endif
Endif

Raz [M:XABP]INPNUM
#--- Bug 72230 puis Bug 77297 (ajout puis suppression)
#If dim([M:XABP]LOCDES)>0 Raz [M:XABP]LOCDES Endif

If GOK=1
   Commit
Else
   Rollback
Endif

#--- Lot V01
#----- Impression bon de préparation -----#
If GOK=1 & WIMPBPR=1
  If [F:SRT]DOCFLG=2
    If [F:SRT]DOCNAM<>""
      Local Char LPTR
      Call ALIM_PRNDOC([F:SRT]DOCNAM,LPTR) From STKADC
      If LPTR<>""
        Call TEMPON(mess(144,100,1)) From GESECRAN   : # Bug 67929
        Local Char TBPAR(10)(1..50), TBVAL(30)(1..50)
        Call ETAT([F:SRT]DOCNAM,LPTR,GLANGUE,0,"",TBPAR,TBVAL) From AIMP3
        Sleep 3                                      : # Bug 67929
        Call TEMPOFF     From GESECRAN               : # Bug 67929
      Else
        Call ERREUR(mess(501,9137,1)) From GESECRAN  : # Bug 67929
      Endif
    Else
      Call ERREUR(mess(100,187,1)) From GESECRAN  : # Bug 67929
    Endif
  Endif
Endif
#---

Return

########################################################
$LIV_BP
WOK=2
Call OUINON(mess(361,184,1),WOK) From GESECRAN
If WOK=1 Return Endif

#--- Lot V01
WIMPBPR=1
#--- Passage du BP à l'état livrable
Readlock [PRH]PRH0=[M:XABP]INPNUM
If fstat
   GOK=0 : Call RSTA("PRH",[M:XABP]INPNUM) From GLOCK
   Return
Endif
[F:PRH]DLVFLG=2
Rewrite [PRH]
If fstat
   GOK=0 : Call FSTA("PRH") From GLOCK
   Return
Endif

For [PRE]PRE0 Where PRHNUM=[M:XABP]INPNUM
   # Si la ligne est annulée
   If [F:PRE]FLGANN<>0 Goto NEXT_PRE2 Endif

   If [F:PRE]SHTQTY<>0
      If [F:PRE]LOCDES<>""
         Call ERREUR([M:PRE]PRHNUM-[M:PRE]ITMREF-":"-mess(323,184,1))
&             From GESECRAN
         GOK=0 : Break
      Else
         # Stock négatif interdit, préparation non livrable
         Read [ITM]ITM0=[M:PREP]ITMREF(I)
         If [F:ITM]NEGSTO<>2
            Call ERREUR([M:PRE]PRHNUM-[M:PREP]ITMREF-":"-mess(269,184,1))
&                From GESECRAN
            GOK=0 : Break
         Endif
      Endif
   Endif
   # Traitement des changements d'emplacements
   #--- Bug 89968
   #If [F:PRE]LOCDES<>""
   If [F:PRE]LOCDES<>"" & [F:PRE]STOMGTCOD>1
   #---
      Raz [M:STW]
      [M:STW]STOFCY  = [F:PRH]STOFCY
      [M:STW]TRSTYP  = 7
      [M:STW]ITMREF  = [F:PRE]ITMREF
      [M:STW]LOCENT  = [F:PRE]LOCDES
      [M:STW]MVTDES  = ""
      [M:STW]CUR     = GLOCALDEV
      [M:STW]ENTCOD  = ""
      [M:STW]PJT     = ""
      [M:STW]BPRNUM  = ""
      [M:STW]IPTDAT  = date$
      [M:STW]PRIORDH = 0
      [M:STW]PIOQTY  = 3
      [M:STW]VCRTYP  = 3               : # Bon de préparation
      [M:STW]VCRNUM  = [F:PRE]PRHNUM
      [M:STW]VCRLIN  = [F:PRE]PRELIN
      Call ALISTOWORK( 1,0,LQTA,LSHT,LNBR,LNBJ,WRET) From STKINT
      # Mise à jour des stock
      If WRET=0
         Call MAJ_STOCK From STKMAJ
      Endif
      If WRET<>0 | GOK<1
         GOK=0 : Break
      Endif
   Endif

   # Maj de la quantité préparée
   If find([F:PRE]ORITYP,1,2)
      # Maj des qtés en prépa et préparées de la commande
      WTYP=3
      Call MAJ_SOQ (WTYP,[F:PRE]ORINUM,[F:PRE]ORILIN,[F:PRE]ORISEQ,[F:PRE]PCU,
&                   [F:PRE]PCUSTUCOE,[F:PRE]QTYSTU) From STKPREPA
      If GOK=0 Break Endif
   Endif
   $NEXT_PRE2
Next
Return

########################################################
$AVANT_BOUTON
# Bouton suite
If BOUT="2"
   # Ligne prépa en cours de traitement
   If [M:XABP]INPNUM<>""
      Call ERREUR("1"-mess(359,184,1)) From GESECRAN
      zonsui=zoncou
      FOK=0
   Endif
Endif
Return

########################################################
$BOUTON
# Bouton suite
If BOUT="2"

# JC.17092020.YN46.STR
Local Integer YESNO : YESNO = 2 # Sí
  If !clalev([F:YPRE]) Then : Local File STOPRED [F:YPRE] : Endif
  If !clalev([F:YPRH]) Then : Local File STOPREH [F:YPRH] : Endif
  If !clalev([F:YSTA]) Then : Local File STOALL  [F:YSTA] : Endif
  If !clalev([F:YSOQ]) Then : Local File SORDERQ [F:YSOQ] : Endif

  If [M:XAB1]QTYSTU < [M:XAB1]QTYORI and [M:XAB1]QTYSTU > 0 Then
    Call OUINON("¿Modificar cantidad?",YESNO) From GESECRAN
    If YESNO = 2 Then   # sí modifica cantidad
      Trbegin [F:YPRE]
      Update [F:YPRE] Where PRHNUM = [M:PREP]PRHNUM(NOL) and PRELIN = [M:PREP]PRELIN(NOL) With QTYSTU = [M:XAB1]QTYSTU,ALLQTY = [M:XAB1]QTYSTU#,PCK = [M:XAB1]PCK
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Else
      Call OUINON("¿Crear ruptura?",YESNO) From GESECRAN
      If YESNO = 2 Then   # sí ruptura
        Trbegin [F:YPRE]
        Update [F:YPRE] Where PRHNUM = [M:PREP]PRHNUM(NOL) and PRELIN = [M:PREP]PRELIN(NOL) With ALLQTY = [M:XAB1]QTYSTU,SHTQTY = ([M:XAB1]QTYORI - [M:XAB1]QTYSTU)#,PCK = [M:XAB1]PCK
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
      Endif
    Endif
  Endif

  # cantidad introducida es cero
  If [M:XAB1]QTYSTU = 0 Then
    YESNO = 2
    Global Integer GBORRAR : GBORRAR = 0
    Call OUINON("¿Borrar?",YESNO) From GESECRAN
    If YESNO = 2 Then
      Trbegin [F:YPRE]
      Read [F:YPRE]PRE0 = [M:PREP]PRHNUM(NOL);[M:PREP]PRELIN(NOL)
      If !fstat Then
        Local Char    LORINUM(50)  : LORINUM = [F:YPRE]ORINUM
        Local Integer LORILIN      : LORILIN = [F:YPRE]ORILIN
        Local Integer LORISEQ      : LORISEQ = [F:YPRE]ORISEQ
      Endif
      Delete [F:YPRE] Where PRHNUM = [M:PREP]PRHNUM(NOL) and PRELIN = [M:PREP]PRELIN(NOL)
      If !fstat Then
        Commit
        GBORRAR = 1
        Read [F:YSOQ]SOQ0 = LORINUM;LORILIN;LORISEQ
        If !fstat Then
          Trbegin [F:YSOQ]
          [F:YSOQ]OPRQTY    = 0
          [F:YSOQ]OPRQTYSTU = 0
          Rewrite [F:YSOQ]
          If !fstat Then
            Commit
          Else
            Rollback
          Endif
        Endif
      Else
        Rollback
      Endif
      Filter [F:YPRE] Where PRHNUM = [M:PREP]PRHNUM(NOL)
      Read [F:YPRE] First
      If fstat <> 0 Then
        Trbegin [F:YPRH]
        Delete [F:YPRH] Where PRHNUM = [M:PREP]PRHNUM(NOL)
        If !fstat Then
          Commit
          [M:PREP]NBLIG = 0
        Else
          Rollback
        Endif
      Endif
      Trbegin [F:YSTA]
      Delete [F:YSTA] Where VCRNUM = [M:PREP]PRHNUM(NOL) and VCRLIN = [M:PREP]PRELIN(NOL)
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
      Gosub AVANT_OK
    Endif
    NOL+=1
    Gosub CHARGE_PRE_XAB1
    If FIN=1 Return Endif
    zonsui="QTYPCU"
  Else
# JC.17092020.YN46.END

    Call RAZSTOSORW From STKSOR

# EMPAQUETADO:
# JC.23092020.YN46.STR
    Gosub CREA_BULTO
# JC.23092020.YN46.END

    NOL+=1
    #If NOL>=[M:PREP]NBLIG
    #   # Toutes les lignes du bon ou de la liste sont-elles préparées
    #   W1=sigma(J=0,[M:PREP]NBLIG-1,[M:PREP]DLVFLG(J)*([M:PREP]FLGANN(J)=0))
    #   W2=sigma(J=0,[M:PREP]NBLIG-1,[M:PREP]FLGANN(J)=0)*2
    #   WOK=2
    #   # Toutes les lignes ne sont pas préparées
    #   If W1<W2
    #      If [M:XABP]PRLNUM<>""
    #         Call OUINON(mess(365,184,1),WOK) From GESECRAN
    #      Else
    #         Call OUINON(mess(360,184,1),WOK) From GESECRAN
    #      Endif
    #   Endif
    #   # Toutes les lignes de préparation ont été traitées
    #   # ou certaines ne l'ont pas été, mais on arrête
    #   If WOK=2
    #      If [M:XABP]PRLNUM<>""
    #         zonsui = "PRLNUM"
    #      Else
    #         zonsui = "PRHNUM"
    #      Endif
    #      Raz [M:XAB1]PRHNUMAFF
    #      Raz [M:XABP]PRLNUM
    #      Raz [M:XABP]PRHNUM
    #      Actzo [M:XABP]PRLNUM
    #      Actzo [M:XABP]PRHNUM
    #      Return
    #   # On reboucle pour traiter les lignes restantes
    #   Else
    #      NOL=0
    #   Endif
    #Endif
    #[M:XABP]PRHNUM = [M:PREP]PRHNUM(NOL)
    # Chargement ligne de préparation suivante
    Gosub CHARGE_PRE_XAB1
    If FIN=1 Return Endif
    zonsui="QTYPCU"

  Endif

  Close Local File [YPRE],[YPRH],[YSTA],[YSOQ]

Endif

Return

########################################################
$CHECK
If [M:XABP]INPNUM<>""
   #--- Bug 89879
   Call ERREUR("2"-mess(359,184,1)) From GESECRAN
   FIN=0
   #WOK=2
   #Call OUINON(mess(359,184,1),WOK) From GESECRAN
   #FIN=0
   #If WOK=1 FIN=1 Endif
   #---
Elsif [M:XABP]PRLNUM<>"" | [M:XABP]PRHNUM<>""
   W1=sigma(J=0,[M:PREP]NBLIG-1,[M:PREP]DLVFLG(J)*([M:PREP]FLGANN(J)=0))
   W2=sigma(J=0,[M:PREP]NBLIG-1,[M:PREP]FLGANN(J)=0)*2
   # Toutes les lignes ne sont pas préparées
   If W1<W2
      WOK=2
      If [M:XABP]PRLNUM<>""
         Call OUINON(mess(365,184,1),WOK) From GESECRAN
      Else
         Call OUINON(mess(360,184,1),WOK) From GESECRAN
      Endif
      If WOK=1 FIN=0 Endif
   Endif
Endif
If FIN=0 zonsui=zoncou Endif
Return

########################################################
$FIN
# JC.17092020.YN46.STR
  Local Integer LCUENTA1, LCUENTA2
  If !clalev([F:PRE1]) Then : Local File STOPRED [F:PRE1] : Endif
  If !clalev([F:PRE2]) Then : Local File STOPRED [F:PRE2] : Endif
  If !clalev([F:PRH1]) Then : Local File STOPREH [F:PRH1] : Endif
  Filter [F:PRE1] Where PRHNUM = GNUMVP
  LCUENTA1 = rowcount([F:PRE1])
  Filter [F:PRE1]
  Filter [F:PRE2] Where PRHNUM = GNUMVP and ALLTYP = 2 and FLGVT = 1
  LCUENTA2 = rowcount([F:PRE2])
  Filter [F:PRE2]
  If LCUENTA1 = LCUENTA2 Then
    # modifica el vale de preparación para que quede como empaquetado
    Read [F:PRH1]PRH0 = GNUMVP
    If !fstat Then
      Trbegin [F:PRH1]
      [F:PRH1]DLVFLG = 3
      [F:PRH1]PACNBR = GNUMBULTOS
      [F:PRH1]PACFLG = 1
      Rewrite [F:PRH1]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Endif
  Endif

  Close Local File [PRE1],[PRE2]
  If dim(GNUMVP)      > 0  Then : Kill GNUMVP     : Endif
  If dim(GNUMBULTOS)  > 0  Then : Kill GNUMBULTOS : Endif
#  If dim(GPACNUM)       > 0  Then : Kill GPACNUM      : Endif
#  If dim(GSCCCOD)       > 0  Then : Kill GSCCCOD      : Endif
# JC.17092020.YN46.END

#--- Bug 81380
# Déblocage logique du BP
If [M:XABP]PRHNUM<>""
   Unlock="PRH"+[M:XABP]PRHNUM
Endif
#---
GVTMOD=0
Raz [M:PREP]

Return


##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
# JC.17092020.YN46.STR
$CREA_BULTO

Local Char    LPACNUM(50),LSCCCOD(50)
Local Integer LRET

  If !clalev([F:SPH0]) Then : Local File SPACK      [F:SPH0] : Endif
  If !clalev([F:SPD0]) Then : Local File SPACKD     [F:SPD0] : Endif
  If !clalev([F:TPA0]) Then : Local File TABPACKAGE [F:TPA0] : Endif
  If !clalev([F:PRH0]) Then : Local File STOPREH    [F:PRH0] : Endif
  If !clalev([F:PRE0]) Then : Local File STOPRED    [F:PRE0] : Endif
  Read [F:PRH0]PRH0 = [M:PREP]PRHNUM(NOL)
  Read [F:PRE0]PRE0 = [M:PREP]PRHNUM(NOL);[M:PREP]PRELIN(NOL)

  Filter [F:SPD0] Where VCRTYP = 3 and VCRNUM = [M:PREP]PRHNUM(NOL) and PCK = [M:XAB1]PCK and PACSEQ = [M:XAB1]PACSEQ
  Read [F:SPD0] First
  # no existe ningún registro en la tabla de empaquetado
  If fstat <> 0 Then
    #   nº de bulto
    Call NUMERO("COL",[F:PRH0]STOFCY,date$,"",LPACNUM,LRET) From SUBANM
    # nº SSCC
    Call NUMERO("SSC",[F:PRH0]STOFCY,date$,[F:PRE0]ITMREF,LSCCCOD,LRET) From SUBANM
    # crea el registro en la tabla de cabecera de empaquetado SPACK
    Trbegin [F:SPH0]
    [F:SPH0]STOFCY    = [F:PRH0]STOFCY
    [F:SPH0]CPY       = [F:PRH0]CPY
    [F:SPH0]VCRTYP    = 3
    [F:SPH0]VCRNUM    = [F:PRH0]PRHNUM
    [F:SPH0]PACSEQ    = [M:XAB1]PACSEQ
    [F:SPH0]PACNUM    = LPACNUM
    [F:SPH0]PCK       = [M:XAB1]PCK
    Read [F:TPA0]TPA0 = [M:XAB1]PCK
    If !fstat Then
      [F:SPH0]PCKWEI  = [F:TPA0]PCKWEI
      [F:SPH0]NETWEI  = 0
      [F:SPH0]VOL     = [F:TPA0]VOL
      [F:SPH0]WEU     = [F:TPA0]WEU
      [F:SPH0]VOU     = [F:TPA0]VOU
    Endif
    [F:SPH0]ONEITMFLG = 2
    [F:SPH0]CHGTYP    = 1
    [F:SPH0]CUR       = "EUR"
    [F:SPH0]PKGTYP    = 1
    [F:SPH0]SCCCOD    = LSCCCOD
    [F:SPH0]BPCORD    = [F:PRH0]BPCORD
    [F:SPH0]EXPNUM    = [F:PRH0]EXPNUM
    Write [F:SPH0]
    If !fstat Then
      GNUMBULTOS += 1
      Commit
    Else
      Rollback
    Endif
    # crea el registro en la tabla de detalle de empaquetado SPACKD
    Trbegin [F:SPD0]
    [F:SPD0]STOFCY    = [F:PRH0]STOFCY
    [F:SPD0]CPY       = [F:PRH0]CPY
    [F:SPD0]VCRTYP    = 3
    [F:SPD0]VCRNUM    = [F:PRH0]PRHNUM
    [F:SPD0]VCRLIN    = [M:PREP]PRELIN(NOL)
    [F:SPD0]VCRSEQ    = 0
    [F:SPD0]PACSEQ    = [M:XAB1]PACSEQ
    [F:SPD0]PACNUM    = LPACNUM
    [F:SPD0]PACIND    = 1
    [F:SPD0]PCK       = [M:XAB1]PCK
    [F:SPD0]ITMREF    = [F:PRE0]ITMREF
    [F:SPD0]ITMDES1    = [F:PRE0]ITMDES1
    [F:SPD0]QTY       = [F:PRE0]ALLQTY
    [F:SPD0]SAU       = [F:PRE0]STU
    [F:SPD0]QTYPCU    = [F:PRE0]ALLQTY
    [F:SPD0]PCU       = [F:PRE0]STU
    [F:SPD0]PCUSTUCOE = 1
    [F:SPD0]LOT       = [M:XAB1]LOT
    [F:SPD0]NETWEI    = 0
    [F:SPD0]WEU       = ""
    [F:SPD0]ITMWEI    = 0
    [F:SPD0]WSTOCOU   = 2
    [F:SPD0]PCKSTKFLG = 2
    [F:SPD0]EXPNUM    = [F:PRH0]EXPNUM
    Write [F:SPD0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
    Filter [F:SPD0]
  Else
    # sí que existe algún registro en la tabla de empaquetado
    LPACNUM = [F:SPD0]PACNUM
    Read [F:SPH0]SPH0 = [F:SPD0]VCRTYP;[F:SPD0]VCRNUM;[F:SPD0]PACNUM;[F:SPD0]PACSEQ
    LSCCCOD = [F:SPH0]SCCCOD
    # crea el registro en la tabla de detalle de empaquetado SPACKD
    Trbegin [F:SPD0]
    [F:SPD0]STOFCY    = [F:PRH0]STOFCY
    [F:SPD0]CPY       = [F:PRH0]CPY
    [F:SPD0]VCRTYP    = 3
    [F:SPD0]VCRNUM    = [F:PRH0]PRHNUM
    [F:SPD0]VCRLIN    = [M:PREP]PRELIN(NOL)
    [F:SPD0]VCRSEQ    = 0
    [F:SPD0]PACSEQ    = [M:XAB1]PACSEQ
    [F:SPD0]PACNUM    = LPACNUM
    [F:SPD0]PACIND    = 1
    [F:SPD0]PCK       = [M:XAB1]PCK
    [F:SPD0]ITMREF    = [F:PRE0]ITMREF
    [F:SPD0]ITMDES1    = [F:PRE0]ITMDES1
    [F:SPD0]QTY       = [F:PRE0]ALLQTY
    [F:SPD0]SAU       = [F:PRE0]STU
    [F:SPD0]QTYPCU    = [F:PRE0]ALLQTY
    [F:SPD0]PCU       = [F:PRE0]STU
    [F:SPD0]PCUSTUCOE = 1
    [F:SPD0]LOT       = [M:XAB1]LOT
    [F:SPD0]NETWEI    = 0
    [F:SPD0]WEU       = ""
    [F:SPD0]ITMWEI    = 0
    [F:SPD0]WSTOCOU   = 2
    [F:SPD0]PCKSTKFLG = 2
    [F:SPD0]EXPNUM    = [F:PRH0]EXPNUM
    Write [F:SPD0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
    Filter [F:SPD0]
  Endif

  # modifica la línea del vale de preparación para que quede como empaquetada
  Trbegin [F:PRE0]
  [F:PRE0]ALLTYP = 2
  [F:PRE0]FLGVT  = 1
  Rewrite [F:PRE0]
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  Close Local File [SPH0],[SPD0],[TPA0],[PRH0],[PRE0]

Return
# JC.17092020.YN46.END

##############################################################
# JC.23092020.YN46.STR
$INSERT_YPACTELNET
#  Trbegin [F:PTN0]
#  [F:PTN0]PRHNUM  = [M:PREP]PRHNUM(NOL)
#  [F:PTN0]PRELIN  = [M:PREP]PRELIN(NOL)
#  [F:PTN0]PCK     = [M:XAB1]PCK
#  [F:PTN0]PACSEQ  = [M:XAB1]PACSEQ
#  Write [F:PTN0]
#  If !fstat Then
#    Commit
#  Else
#    Rollback
#  Endif
Return
# JC.23092020.YN46.END

########################################################
# Gestion du masque VXABP                              #
########################################################

########################################################
Subprog AM_SRTNUM(VALEUR)
Variable Char    VALEUR()

GFLAG = VALEUR
If dim([M:XABP]LOCDES)>0
#MAE, le 21/09/2010, bg67390, test dans le mauvais sens
#   If [F:SRT]FLGLOCDES=2
   If [F:SRT]FLGLOCDES=1
      Grizo [M]LOCDES
   Else
      Actzo [M]LOCDES
   Endif

   Affzo [M]LOCDES
Endif
End

########################################################
Subprog AS_PRLNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer WOK, W1, W2

If VALEUR="" : End : Endif
If [M:XABP]INPNUM<>""
   Call ERREUR(mess(359,184,1)) From GESECRAN
   mkstat=2
Else
   W1=sigma(J=0,[M:PREP]NBLIG-1,[M:PREP]DLVFLG(J)*([M:PREP]FLGANN(J)=0))
   W2=sigma(J=0,[M:PREP]NBLIG-1,[M:PREP]FLGANN(J)=0)*2
   # Toutes les lignes du bon ne sont pas préparées
   If W1<W2
      WOK=2
      Call OUINON(mess(365,184,1),WOK) From GESECRAN
      If WOK=1 mkstat=2 : zonsui="QTYPCU" Endif
   Endif
Endif
End

Subprog C_PRLNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer I

If VALEUR ="" End Endif
# Cette liste contient-elle des BP à traiter
Raz I
For [PRH]PRH2 Where STOFCY=[M]STOFCY & PRLNUM=VALEUR & DLVFLG<2
   I=1 : Break
Next
# Aucun BP à traiter
If I=0
   mkstat=2 : Call ERREUR(mess(300,184,1)) From GESECRAN
Endif
End

########################################################
Subprog AS_PRHNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer WOK, W1, W2

If VALEUR=""  : End : Endif
If [M:XABP]INPNUM<>""
   Call ERREUR(mess(359,184,1)) From GESECRAN
   mkstat=2
Else
   W1=sigma(J=0,[M:PREP]NBLIG-1,[M:PREP]DLVFLG(J)*([M:PREP]FLGANN(J)=0))
   W2=sigma(J=0,[M:PREP]NBLIG-1,[M:PREP]FLGANN(J)=0)*2
   # Toutes les lignes du bon ne sont pas préparées
   If W1<W2
      WOK=2
      Call OUINON(mess(360,184,1),WOK) From GESECRAN
      #--- Bug 82815
      #If WOK=1 mkstat=2 : zonsui="QTYPCU" Endif
      If WOK=1
         mkstat=2 : zonsui="QTYPCU"
      Elsif WOK=2 & [M:XABP]PRHNUM<>""
         # Déblocage logique du BP
         Unlock="PRH"+[M:XABP]PRHNUM
      Endif
      #---
   Endif
Endif
End

Subprog C_PRHNUM(VALEUR)
Variable Char    VALEUR()

If VALEUR ="" End Endif
If [F:PRH]STOFCY<>[M]STOFCY
   Call ERREUR(mess(353,184,1)-":"-[M]STOFCY) From GESECRAN
   mkstat=2 : End
Endif
If [F:PRH]DLVFLG>1
   Call ERREUR(mess(322,184,1)) From GESECRAN
   mkstat=2 : End
Endif
#--- Bug 81380
# Blocage logique du BP
Lock="PRH"+VALEUR
If fstat
   Call ERREUR("$STOPREH"-VALEUR-mess(12,110,1)) From GESECRAN
   mkstat=2 : End
Endif
#---
End

########################################################
Subprog C_LOCDES(VALEUR)
Variable Char    VALEUR()

VALEUR = toupper(VALEUR)
#--- Bug 89870
#If !find(VALEUR,"","$",[M]LOCDES) | VALEUR<>[F:STC]LOC  #MAE, 23/09/2010, bg67468, STC est relut si la VALEUR <>[F:STC]LOC
If !find(VALEUR,"","$",[M]LOCDES) & VALEUR<>[F:STC]LOC
#---
   Read [STC]STC0=[M]STOFCY;VALEUR
   If fstat
      GMESSAGE = mess(125,184,1)
      mkstat=2 : End
   Endif
Endif

If !find(VALEUR,"","$")
   # Catégories non internes non autorisées
   If [F:STC]LOCCAT<>1
      GMESSAGE = mess(399,199,1)-":"-mess([F:STC]LOCCAT,2710,1)
      mkstat=2 : End
   Elsif [F:STC]LOKSTA=2 | [F:STC]CUNLOKFLG=2
      # Emplacement non disponible
      GMESSAGE=mess(18,196,1)
      mkstat=2 : End
   Endif
   #--- Bug 72230
   #[M]LOCTYPDES = [F:STC]LOCTYP
   [M]LOCTYPDES = [F:STC]LOCTYP
   #---
Endif
zonsui="QTYPCU"
End

########################################################
Subprog D_PCU(VALEUR)
Variable Char    VALEUR()
VALEUR=[F:ITM]STU
End

########################################################
Subprog AM_PCU(VALEUR)
Variable Char    VALEUR()
Local    Integer LMODIF
Call CTLUOM([M:XAB1]ITMREF,3,"",VALEUR,[M:XAB1]PCUSTUCOE,GBIDC1,GBIDC2,LMODIF) From STKACT
If mkstat=2 End Endif
Call QTEARR([M:XAB1]QTYPCU,VALEUR) From TRTDIV
[M:XAB1]QTYSTU = [M:XAB1]QTYPCU*[M:XAB1]PCUSTUCOE
Call QTEARR([M:XAB1]QTYSTU,[F:ITM]STU) From TRTDIV
# Si UC <> US, le coef est saisissable
If VALEUR<>[F:ITM]STU
   Actzo [M:XAB1]PCUSTUCOE
Else
   Diszo [M:XAB1]PCUSTUCOE
Endif
Affzo [M:XAB1]PCUSTUCOE
End

########################################################
Subprog AM_PCUSTUCOE(VALEUR)
Variable Decimal VALEUR
[M:XAB1]QTYSTU= [M:XAB1]QTYPCU*VALEUR
Call QTEARR([M:XAB1]QTYSTU,[F:ITM]STU) From TRTDIV
End

########################################################
Subprog AS_QTYPCU(VALEUR)
Variable Decimal VALEUR
# Décrémentation quantité traitée
#[M:XAB1]QTYTRT -= [M:XAB1]QTYSTU
End

########################################################
Subprog C_QTYPCU(VALEUR)
Variable Decimal VALEUR
Local    Char    LSUP
Local    Decimal LPCUDIS, LSTUDIS, LSTUACTDIS

#--- Bug 82815
# Calcul de la quantité en US
#[M:XAB1]QTYSTU= VALEUR*[M:XAB1]PCUSTUCOE
#Call QTEARR([M:XAB1]QTYSTU,[F:ITM]STU) From TRTDIV
If [M:XAB1]PCUSTUCOE=0 [M:XAB1]PCUSTUCOE=1 Endif
# If VALEUR<>[M:XAB1]QTYPCU                               # hcb 92489
   [M:XAB1]QTYSTU= VALEUR*[M:XAB1]PCUSTUCOE
   Call QTEARR([M:XAB1]QTYSTU,[F:ITM]STU) From TRTDIV
#Endif                                                    # hcb 92489
#---

# La quantité totale est supérieure à la quantité à préparer
If [M:XAB1]QTYTRT+[M:XAB1]QTYSTU>[M:XAB1]QTYORI
   GMESSAGE = mess(47,198,1)-num$([M:XAB1]QTYTRT+[M:XAB1]QTYSTU)-">"-mess(363,184,1)-num$([M:XAB1]QTYORI)
   mkstat=2 : End
Endif

If [M:XAB1]STOCOU<>0
   # Calcul du stock disponible
   Call STODISSOR("","",LSUP,LPCUDIS,LSTUDIS,LSTUACTDIS) From STKLIB
   LSTUDIS += [M:XAB1]ALLSTU
   # Quantité supérieure au disponible
   If [M:XAB1]QTYSTU > LSTUDIS
      GMESSAGE = mess(148,199,1)-":"-num$(LSTUDIS)
      mkstat=2 : End
   Endif
Endif

# Incrémentation quantité traitée
#[M:XAB1]QTYTRT += [M:XAB1]QTYSTU
End

########################################################
Subprog IB_LOC
If varmode([M]LOC)<>0 Raz GBOUT1 Endif
End

Subprog IB_LOT
If varmode([M]LOT)<>0 Raz GBOUT1 Endif
End

Subprog IB_SLO
If varmode([M]SLO)<>0 Raz GBOUT1 Endif
End

Subprog IB_SERNUM
If varmode([M]SERNUM)<>0 Raz GBOUT1 Endif
End

########################################################
Subprog C_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Char    LSERF(GLONSER)
Local    Decimal LQTYF

If VALEUR="" End Endif

If [M:XAB1]QTYSTU=1
   Read [STO]STO5=[M:XAB1]ITMREF;VALEUR
   If fstat
      mkstat=2 : End
   Else
      If dim([M:XAB1]LOT)>0  [M:XAB1]LOT=[F:STO]LOT  Endif
      If dim([M:XAB1]SLO)>0  [M:XAB1]SLO=[F:STO]SLO  Endif
      If dim([M:XAB1]LOC)>0  [M:XAB1]LOC=[F:STO]LOC  Endif
      [M:XAB1]STA = [F:STO]STA
      Affzo [M:XAB1]10
   Endif
Endif

If VALEUR<>""
   Raz [M:ALP]
   Case [M:XAB1]ORITYP
    When 1   : [M:ALP]TRSTYP =  4
    When 2   : [M:ALP]TRSTYP = 17
    When 3,4 : [M:ALP]TRSTYP = 20
   Endcase
   [M:ALP]TRSCOD     = [M:PREP]TRSCOD
   [M:ALP]STOFCY     = [M:PREP]STOFCY
   [M:ALP]ITMREF     = [M:XAB1]ITMREF
   [M:ALP]BESDAT     = [M:PREP]BESDAT
   [M:ALP]DLVDAT     = [M:PREP]DLVDAT
   [M:ALP]PECINTLOC  = 2
   [M:ALP]PECSCOLOC  = 1
   [M:ALP]PECPLFLOC  = 2
   [M:ALP]PECCUNLOK  = 1
   [M:ALP]STA        = "*"
   #DLU client
   [M:ALP]BPRNUM     = [M:PREP]BPCORD(nolign-1)
      # Détermination no série fin
   Call CTLSORSER("PREP",0,VALEUR,[M:XAB1]QTYSTU,LSERF,LQTYF) From STKSOR
   If LQTYF=0
      Raz VALEUR, [M:XAB1]SERNUMF
   Else
      [M:XAB1]SERNUMF=LSERF
   Endif
Else
   Raz [M:XAB1]SERNUMF
Endif

End

########################################################
$RECH_STOCK
#--- Issue 99824
If [F:ITV]ITMREF<>[F:ITM]ITMREF | [F:ITV]STOFCY<>[M:ALP]STOFCY
  Read [ITV]ITV0=[F:ITM]ITMREF;[M:ALP]STOFCY
Endif
#---
#DLUBPC
#lecture ITMBPC  pour recuperer DLUBPC
If [M:ALP]BPRNUM <> ""
   Read [ITU]ITU0 = [F:ITM]ITMREF;[M:ALP]BPRNUM
   If fstat
      Raz [F:ITU]
   Endif
Endif
#DLU Client, calcul du nbre de jours à retrancher à la DLU article
If [F:ITU]DLUBPC <> 0
  Call CALNBDAYCLI([F:ITM]EXYMGTCOD,[F:ITM]SHL,[F:ITM]SHLUOM,[F:ITF]DLU,[F:ITU]DLUBPC,NBDAY) From STKLIB
Endif
#Fin DLUBPC

# Lecture de la règle de gestion pour le mouvement à traiter
Call LECSRU([M:ALP]STOFCY,[F:ITM]TCLCOD,[M:ALP]TRSTYP,[M:ALP]TRSCOD,"",WRET) From STKLIB
If WRET<>0 : WRET=1 : Return : Endif

# Stockage dans WCRITSTO des statuts/sous-statuts autorisés
Call CTRL_STATUT("[F:STO1]",[M:ALP]STA,WCRITSTO) From STKALL

Raz WWSTA, WWLOC, WSTUACTDIS
# Statuts autorisés par la règle de gestion
If find([F:SRU]AUZSTA,1,3,5,7) WWSTA+=1 Endif
If find([F:SRU]AUZSTA,2,3,6,7) WWSTA+=2 Endif
If find([F:SRU]AUZSTA,4,5,6,7) WWSTA+=4 Endif
# Prise en compte emplacement en attente de rangement
If [M:ALP]PECPLFLOC=2 WWLOC+=1 Endif
# Prise en compte emplacement sous-traitant
If [M:ALP]PECSCOLOC=2 WWLOC+=4 Endif
# Si pas d'emplacements internes
If [M:ALP]PECINTLOC=1 WWLOC=WWLOC*(-1) Endif
# Calcul stock disponible
Call STODISTOT("",WWLOC,WWSTA,"",WSTUACTDIS) From STKLIB

# On ajoute la quantité allouée de la ligne de prépa
WSTUACTDIS += [M:PREP]ALLQTY(NOL)    # hcb 80687

If WSTUACTDIS<[M:ALP]QTY
   WRET=1 : WRETADC+=512 : Return
Endif

# Si pas de transaction en cours
If adxlog<>1
   Trbegin [STO1]
   WTRBEGIN=1
Endif

I=[M:SOW]NBLIG
Raz WQTY
WDAT=[M:ALP]DLVDAT

# No séries en E/S
If [F:ITM]SERMGTCOD=3
   # Si pas de no série dans l'écran
   If dim([M:XAB1]SERNUM)<0 | dim([M:XAB1]SERNUMF)<0
      WRET=1 : Goto RECH_STOCK_SUI
   Endif
   WSERNUM  = [M:XAB1]SERNUM
   WSERNUMF = [M:XAB1]SERNUMF
   # Si pas de no série saisi
   If WSERNUM=""
      WRET=1 : Goto RECH_STOCK_SUI
   Endif
   # Contrôle du nb de no série par rapport à la quantité
   WNBSERIE = val(ctrans(WSERNUMF,sigma(J=1,47,chr$(J))+sigma(J=58,255,chr$(J)),""))
&            -val(ctrans(WSERNUM ,sigma(J=1,47,chr$(J))+sigma(J=58,255,chr$(J)),""))
&            +1
   If WNBSERIE>[M:ALP]QTY
      WRET=1 : Goto RECH_STOCK_SUI
   Endif

   If I+WNBSERIE>dim([M:SOW]WSTOSEQ)
      Call ERREUR(mess(352,199,1)) From GESECRAN
      WRET=2 : Goto RECH_STOCK_SUI
   Endif

   While WSERNUM<=WSERNUMF
      Readlock [STO1]STO5=[M:ALP]ITMREF;WSERNUM
      If fstat
         WRET=1 : Break
      Endif
      # Stock disponible ?
      Call STODISSOR("[F:STO1]","","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
      If [L]WSTUACTDIS < 1
         WRET=1 : Break
      Endif
      # Inventaire en cours
      If [F:STO1]CUNLOKFLG=2
         WRET=1 : Break
      Endif
      # Stock avec demande d'analyse
      If [M:ALP]PECQLYCTL<>2 & [F:STO1]QLYCTLDEM<>""
         WRET=1 : Break
      Endif
      # Contrôle de la péremption
      If [F:SRU]SHLLOT<>3        # hcb V6dlu nouvelle valeur
         If [F:STO1]LOT<>[F:STL1]LOT & [F:STO1]SLO<>[F:STL1]SLO
            Read [STL1]STL0=[F:STO1]ITMREF;[F:STO1]LOT;[F:STO1]SLO
            If fstat
               WRET=1 : Break
            Elsif ([F:SRU]SHLLOT=2 & [F:STL1]DLUDAT<>[0/0/0] & [F:STL1]DLUDAT+val(NBDAY)<WDAT) | ([F:SRU]SHLLOT=1 & [F:STL1]SHLDAT<>[0/0/0] & [F:STL1]SHLDAT<WDAT)
               WRET=1 : Break
            Endif
         Endif
      Endif
      # Contrôle des statuts/sous-statuts autorisés
      If !evalue(WCRITSTO)
         WRET=1 : Break
      Endif
      # Contrôle de l'emplacement
      If [F:STO1]LOCCAT=3
&      |([F:STO1]LOCCAT=1 & [M:ALP]PECINTLOC=1)
&      |([F:STO1]LOCCAT=2 & [M:ALP]PECPLFLOC<>2)
&      |([F:STO1]LOCCAT=4 & [M:ALP]PECSCOLOC<>2)
         WRET=1 : Break
      Endif
      # Contrôle dépôt
      If GWRHACT=2 & [M:ALP]WRH<>""
         If [F:STO1]WRH<>[M:ALP]WRH
            WRET=1 : Break
         Endif
      Endif
      # Création quantité en cours de traitement
      [L]LSTOCOU = [F:STO1]STOCOU
      [L]LWIPQTY = [L]WSTUDIS
      [L]LWIPQTA = [L]WSTUACTDIS
      Call CRE_STOWIPW(LSTOCOU,LWIPQTY,LWIPQTA) From STKLIB
      [F:STO1]CUMWIPQTY += [L]LWIPQTY
      [F:STO1]CUMWIPQTA += [L]LWIPQTA

      Rewrite [STO1]
      If fstat
         Call FSTA("STO1") From GLOCK
         WRET=1 : Break
      Endif

      # Alimentation STOSORW
      #[M:SOW]WSTOSEQ(I)    = 0
      [M:SOW]WSTOSEQ(I)    = 1
      [M:SOW]WSTOCOU(I)    = [F:STO1]STOCOU
      [M:SOW]WQTYSTU(I)    = WSTUDIS
      [M:SOW]WQTYSTUACT(I) = WSTUACTDIS
      [M:SOW]WALLSTU(I)    = 0
      [M:SOW]WALLSTUACT(I) = 0
      Raz [M:SOW]WLOT(I), [M:SOW]WSLO(I), [M:SOW]WLOC(I), [M:SOW]WWRH(I)
      Raz [M:SOW]WSTA(I), [M:SOW]WSERNUM(I), [M:SOW]WPLFSTO(I)

      # Transfert zones de la ligne de document vers l'écran STOSORW
      GPOINT="DOC_SOW" : Gosub ENTREE From EXEFNC

      Call PLUS_UN(WSERNUM,WSER,WRET) From STKLIB
      If WRET<>0 Break Endif
      WSERNUM = WSER
      WQTY += 1
      I    += 1
   Wend
Else
   #--- L'UC et le coeff UC/US ne font pas partie des critères
   #--- de détermination du stock : A voir / A faire ?
   Raz WCRIT, WCRITLOT
   WCRITLOT='[F:STL1]ITMREF=[M:ALP]ITMREF'
   # L'article est géré par lot
   If [F:ITM]LOTMGTCOD<>1
      If dim([M:XAB1]LOT)<0
         WRET=1 : Goto RECH_STOCK_SUI
      Endif
      If [M:XAB1]LOT=""
         WRET=1 : WRETADC+=4 : Goto RECH_STOCK_SUI
      Else
         WLOT=[M:XAB1]LOT
         WCRITLOT+='&[F:STL1]LOT=WLOT'
      Endif
      # L'article est géré par sous-lot
      If [F:ITM]LOTMGTCOD=4
         If dim([M:XAB1]SLO)<0
            WRET=1 : Goto RECH_STOCK_SUI
         Endif
         If [M:XAB1]SLO=""
            WRET=1 : WRETADC+=8 : Goto RECH_STOCK_SUI
         Else
            WSLO=[M:XAB1]SLO
            WCRITLOT+='&[F:STL1]SLO=WSLO'
         Endif
      Endif
      # Contrôle de la péremption
      If [F:SRU]SHLLOT<>3   # hcb V6dlu nouvelle gestion
         If [F:SRU]SHLLOT=2
            WCRITLOT+='&([F:STL1]DLUDAT=[0/0/0]|[F:STL1]DLUDAT'+NBDAY+'>=WDAT)'
         Else
            WCRITLOT+='&([F:STL1]SHLDAT=[0/0/0]|[F:STL1]SHLDAT>=WDAT)'
         Endif
      Endif
   Endif

   WCRIT='[F:STO1]CUNLOKFLG<>2'

   # L'article est géré avec emplacement
   If [F:ITF]LOCMGTCOD=2
      # L'article est géré par lot
      If [F:ITM]LOTMGTCOD<>1
         # Pec de l'emplacement s'il est renseigné
         If dim([M:XAB1]LOC)>0
            If [M:XAB1]LOC<>""
               WLOC=[M:XAB1]LOC
               WCRIT+='&[F:STO1]LOC=WLOC'
            Endif
         Endif
      # L'article n'est pas géré par lot
      # L'emplacement ou PALNUM ou CTRNUM est obligatoire
      Else
         If dim([M:XAB1]LOC)<0
            If dim([M:XAB1]PALNUM)<0
               If dim([M:XAB1]CTRNUM)<0
                  WRET=1 : Goto RECH_STOCK_SUI
               Elsif [M:XAB1]CTRNUM=""
                  WRET=1 : Goto RECH_STOCK_SUI
               Endif                                : # CTRNUM est renseigné
            Elsif [M:XAB1]PALNUM=""
               If dim([M:XAB1]CTRNUM)<0
                  WRET=1 : Goto RECH_STOCK_SUI
               Elsif [M:XAB1]CTRNUM=""
                  WRET=1 : Goto RECH_STOCK_SUI
               Endif                                : # CTRNUM est renseigné
            Endif                                   : # PALNUM est renseigné
         Elsif [M:XAB1]LOC=""
            If dim([M:XAB1]PALNUM)<0
               If dim([M:XAB1]CTRNUM)<0
                  WRET=1 : Goto RECH_STOCK_SUI
               Elsif [M:XAB1]CTRNUM=""
                  WRET=1 : Goto RECH_STOCK_SUI
               Endif                                : # CTRNUM est renseigné
            Elsif [M:XAB1]PALNUM=""
               If dim([M:XAB1]CTRNUM)<0
                  WRET=1 : Goto RECH_STOCK_SUI
               Elsif [M:XAB1]CTRNUM=""
                  WRET=1 : Goto RECH_STOCK_SUI
               Endif                                : # CTRNUM est renseigné
            Endif                                   : # PALNUM est renseigné
         # Prise en compte de l'emplacement
         Else
            WLOC=[M:XAB1]LOC
            WCRIT+='&[F:STO1]LOC=WLOC'
         Endif
      Endif
   Endif

   Raz J
   # Prise en compte du dépôt s'il est renseigné
   If GWRHACT=2 & [M:ALP]WRH<>""
      WCRIT+='&[F:STO1]WRH=[M:ALP]WRH'
   Endif
   # Prise en compte du statut s'il est renseigné
   If dim([M:XAB1]STA)>0
      If [M:XAB1]STA<>""
         WSTA=[M:XAB1]STA
         WCRIT+='&[F:STO1]STA=WSTA'
         J=1
      Endif
   Endif
   # Prise en compte de PALNUM s'il est renseigné
   If dim([M:XAB1]PALNUM)>0
      If [M:XAB1]PALNUM<>""
         WPALNUM=[M:XAB1]PALNUM
         WCRIT+='&[F:STO1]PALNUM=WPALNUM'
         J=1
      Endif
   Endif
   # Prise en compte de CTRNUM s'il est renseigné
   If dim([M:XAB1]CTRNUM)>0
      If [M:XAB1]CTRNUM<>""
         WCTRNUM=[M:XAB1]CTRNUM
         WCRIT+='&[F:STO1]CTRNUM=WCTRNUM'
         J=1
      Endif
   Endif
   # Prise en compte du OWNER
   If [M:ALP]PECOWNER=""
      WCRIT+='&[F:STO1]OWNER=[F:STO1]STOFCY'
   Else
      WCRIT+='&find([F:STO1]OWNER,[F:STO1]STOFCY,[M:ALP]PECOWNER)'
   Endif

   # Si ni gestion série,ni lot,ni emplacement et statut
   # ou PALNUM ou CTRNUM non renseigné
   # on a pas les éléments nécessaires pour déterminer le stock à sortir
   If [F:ITM]LOTMGTCOD=1 & [F:ITF]LOCMGTCOD<>2 & J<>1
      WRET  = 1
      Goto RECH_STOCK_SUI
   Endif

   WALPQTY = [M:ALP]QTY

   # Lecture des lots
   For [STL1]STL0 Where evalue(WCRITLOT)
      For [STO1]STO3 Where ITMREF=[M:ALP]ITMREF & STOFCY=[M:ALP]STOFCY &
&                          LOT=[F:STL1]LOT & SLO=[F:STL1]SLO &
&                          evalue(WCRIT) & evalue(WCRITSTO)

         # Stock avec demande d'analyse
         If [M:ALP]PECQLYCTL<>2 & [F:STO1]QLYCTLDEM<>""
            WSRETADC = WRETADC
            If WSRETADC>=512 WSRETADC-=512 Endif
            If WSRETADC>=256 WSRETADC-=256 Endif
            If WSRETADC <128  WRETADC+=128 Endif
            Goto STO1_SUIV
         Endif

         # Contrôle de l'emplacement
         If [F:STO1]LOCCAT=3
&         |([F:STO1]LOCCAT=1 & [M:ALP]PECINTLOC=1)
&         |([F:STO1]LOCCAT=2 & [M:ALP]PECPLFLOC<>2)
&         |([F:STO1]LOCCAT=4 & [M:ALP]PECSCOLOC<>2)
           WSRETADC = WRETADC
           If WSRETADC>=512 WSRETADC-=512 Endif
           If WSRETADC <256  WRETADC+=256 Endif
            Goto STO1_SUIV
         Endif
         # Contrôle du disponible
         Call STODISSOR("[F:STO1]","[F:ITM]","",WPCUDIS,WSTUDIS,WSTUACTDIS) From STKLIB
         If [L]WSTUACTDIS<=0
            If WRETADC<512 WRETADC+=512 Endif
            Goto STO1_SUIV
         Endif

         Readlock [STO1]Curr
         If fstat Goto STO1_SUIV Endif

         If [M:ALP]TYPQTY=1
            [L]WQTYSTU    = min([L]WALPQTY,[L]WSTUDIS)
            [L]WQTY      += [L]WQTYSTU
            [L]WALPQTY   -= [L]WQTYSTU

            [L]WQTYSTUACT = [L]WQTYSTU
            # Si gestion en titres ou UI, calcul quantité en UA
            Case [F:ITF]STOMGTCOD
             When 3 : If [F:STL1]POT<>0
                         [L]WQTYSTUACT=[L]WQTYSTU*([F:STL1]POT/100)
                         Call QTEARR([L]WQTYSTUACT,[F:ITM]STU) From TRTDIV
                      Endif
             When 4 : If [F:STL1]ACT<>0
                         [L]WQTYSTUACT=[L]WQTYSTU* [F:STL1]ACT
                         Call QTEARR([L]WQTYSTUACT,[F:ITM]STU) From TRTDIV
                      Endif
            Endcase
         Else
            [L]WQTYSTUACT = min(WALPQTY,WSTUACTDIS)
            [L]WQTY      += [L]WQTYSTUACT
            WALPQTY      -= [L]WQTYSTUACT

            [L]WQTYSTU    = [L]WQTYSTUACT
            # Si gestion en titres ou UI, calcul quantité en US
            Case [F:ITF]STOMGTCOD
             When 3 : If [F:STL1]POT<>0
                         [L]WQTYSTU=[L]WQTYSTUACT/([F:STL1]POT/100)
                         Call QTEARR([L]WQTYSTU,[F:ITM]STU) From TRTDIV
                      Endif
             When 4 : If [F:STL1]ACT<>0
                         [L]WQTYSTU=[L]WQTYSTUACT/ [F:STL1]ACT
                         Call QTEARR([L]WQTYSTU,[F:ITM]STU) From TRTDIV
                      Endif
            Endcase
         Endif

         If I>=dim([M:SOW]WSTOSEQ)
            Call ERREUR(mess(352,199,1)) From GESECRAN
            WRET=2 : Break 2
         Endif
         # Création quantité en cours de traitement
         [L]LSTOCOU = [F:STO1]STOCOU
         [L]LWIPQTY = [L]WQTYSTU
         [L]LWIPQTA = [L]WQTYSTUACT
         Call CRE_STOWIPW(LSTOCOU,LWIPQTY,LWIPQTA) From STKLIB
         [F:STO1]CUMWIPQTY += [L]LWIPQTY
         [F:STO1]CUMWIPQTA += [L]LWIPQTA

         Rewrite [STO1]
         If fstat Goto STO1_SUIV Endif

         # Alimentation STOSORW
         #[M:SOW]WSTOSEQ(I)    = 0
         [M:SOW]WSTOSEQ(I)    = 1
         [M:SOW]WSTOCOU(I)    = [F:STO1]STOCOU
         [M:SOW]WQTYSTU(I)    = [L]WQTYSTU
         [M:SOW]WQTYSTUACT(I) = [L]WQTYSTUACT
         [M:SOW]WALLSTU(I)    = 0
         [M:SOW]WALLSTUACT(I) = 0
         Raz [M:SOW]WLOT(I), [M:SOW]WSLO(I), [M:SOW]WLOC(I), [M:SOW]WWRH(I)
         Raz [M:SOW]WSTA(I), [M:SOW]WSERNUM(I), [M:SOW]WPLFSTO(I)

         # Transfert zones de la ligne de document vers l'écran STOSORW
         GPOINT="DOC_SOW" : Gosub ENTREE From EXEFNC

         I += 1
         If [L]WQTY>=[M:ALP]QTY Break 2 Endif

      $STO1_SUIV
      Next
   Next
Endif

[M:SOW]NBLIG=I

# La quantité n'a pas été entièrement traitée
If [L]WQTY<[M:ALP]QTY

   #--- Bug 90204
   If [L]WQTY>0
      [M:XAB1]QTYSTU=[L]WQTY
      # Calcul de la quantité en UC
      If [M:XAB1]PCUSTUCOE=0 [M:XAB1]PCUSTUCOE=1 Endif
      [M:XAB1]QTYPCU=[M:XAB1]QTYSTU/[M:XAB1]PCUSTUCOE
      Call QTEARR([M:XAB1]QTYPCU,[M:XAB1]PCU) From TRTDIV
   Else
   #---
      WRET=1
      # Nettoyage écran de travail pour cette ligne
      #--- Issue 103824
      #Call RAZSTOSORW From STKSOR
      If [L]WQTY=0 & WRETADC=0
         WRETADC=1
      Else
         WRETADC+=512
      Endif
   #--- Bug 90204
   Endif

Endif

$RECH_STOCK_SUI

# Si on a ouvert une transaction
If WTRBEGIN=1
   If WRET=0
      Commit
   Else
      Rollback
   Endif
   Raz WTRBEGIN
Endif

Return

#--- Bug 82815
######################################################################################
## Etiquette ajoutée par le superviseur (écran VXABP1) 19/07/2012 11:24:13 (TS)
######################################################################################
Subprog AS_QTYSTU(VALEUR)
Variable Decimal VALEUR
#If [M:XAB1]QTYPCU<>0 mkstat=2 Endif
End

Subprog C_QTYSTU(VALEUR)
Variable Decimal VALEUR
Local    Char    LSUP
Local    Decimal LPCUDIS, LSTUDIS, LSTUACTDIS

If VALEUR=[M:XAB1]QTYSTU End Endif

# Calcul de la quantité en UC
If [M:XAB1]PCUSTUCOE=0 [M:XAB1]PCUSTUCOE=1 Endif
[M:XAB1]QTYPCU= VALEUR/[M:XAB1]PCUSTUCOE
Call QTEARR([M:XAB1]QTYPCU,[M:XAB1]PCU) From TRTDIV

# La quantité totale est supérieure à la quantité à préparer
If [M:XAB1]QTYTRT+VALEUR>[M:XAB1]QTYORI
   GMESSAGE = mess(47,198,1)-num$([M:XAB1]QTYTRT+VALEUR)-">"-mess(363,184,1)-num$([M:XAB1]QTYORI)
   mkstat=2 : End
Endif

If [M:XAB1]STOCOU<>0
   # Calcul du stock disponible
   Call STODISSOR("","",LSUP,LPCUDIS,LSTUDIS,LSTUACTDIS) From STKLIB
   LSTUDIS += [M:XAB1]ALLSTU
   # Quantité supérieure au disponible
   If VALEUR > LSTUDIS
      GMESSAGE = mess(148,199,1)-":"-num$(LSTUDIS)
      mkstat=2 : End
   Endif
Endif

Affzo [M:XAB1]QTYPCU

# Incrémentation quantité traitée
#[M:XAB1]QTYTRT += VALEUR

End

######################################################################################

