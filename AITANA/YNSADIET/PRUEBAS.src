#######################################################
Funprog ICLIENTESLDIR(PCLIENTE)
Value Char PCLIENTE

Local Integer RETVAL

# No additional parameter nor additional header value are given here (only the values given in ORDER definition are used)
Local Char PCOD(100)(1..10),PVAL(100)(1..10),HCOD(100)(1..10),HVAL(100)(1..10)

# Contains the result header and body
Local Clbfile RESHEAD(0),RESBODY(0),CDATA(0)

Local Integer I

  # Add a parameter
  #PCOD(1)="USERID"
  #PVAL(1)='"'+GACTX.LOGIN+'"'

  # Add two header parameters (it would probably be better to define them in the web service definition)
  #HCOD(1)   =  "Authorization"
  #HVAL(1)    = '"X3User:inacatalogapi2"'
  #HVAL(1)    = '"X3User:AIT51"'
  #HCOD(2)="Content-Type"
  #HVAL(1)='"fr, en-gb;q=0.8, en;q=0.7"'
  HCOD(1)="content-type"
  HVAL(1)='"application/json; charset=utf-8"'

  #HCOD(3)="Content-Length"
  #HVAL(3)="87"

  If !clalev([YBPA]) Then : Local File BPADDRESS  [YBPA] : Endif
  If !clalev([YBPR]) Then : Local File BPARTNER   [YBPR] : Endif
  If PCLIENTE <> "" Then
    Filter [F:YBPR] Where BPRSHO = PCLIENTE
    Read   [F:YBPR] First
    Filter [F:YBPA] Where BPATYP = 1 and BPANUM = [F:YBPR]BPRNUM
  Endif
  For [YBPA]
    # planta 101
    CDATA='{'
    CDATA+='"codEmpresa":'                  + num$(101)                 + ','
    CDATA+='"codCliente": "'                + [F:YBPA]BPANUM            + '",'
    CDATA+='"linDirCli": '                  + num$(val([F:YBPA]BPAADD)+1) + ','
    CDATA+='"nomDirCli": "'                 + [F:YBPA]BPADES            + '",'
    CDATA+='"rsoDirCli": "'                 + [F:YBPA]BPADES            + '",'
    CDATA+='"datCalleDirCli": "'            + [F:YBPA]BPAADDLIG(0) - [F:YBPA]BPAADDLIG(1) + '",'
    CDATA+='"codPostalDirCli": "'           + [F:YBPA]POSCOD            + '",'
    CDATA+='"datPoblacionDirCli": "'        + [F:YBPA]CTY               + '",'
    CDATA+='"datProvinciaDirCli": "'        + [F:YBPA]SAT               + '",'
    CDATA+='"datPaisDirCli": "'             + 'ESPAÑA'                  + '",'   # [F:YBPA]CRYNAM
    CDATA+='"datContactoDirCli": "'         + ''                        + '",'
    CDATA+='"datTelefonoDirCli": "'         + [F:YBPA]TEL(0)            + '",'
    CDATA+='"datFaxDirCli": "'              + [F:YBPA]FAX               + '",'
    CDATA+='"datEmailDirCli": "'            + [F:YBPA]WEB(0)            + '",'
    CDATA+='"hipWebDirCli": "'              + [F:YBPA]FCYWEB            + '",'
    CDATA+='"codSuDirCli": "'               + 'FI'                      + '",'
    CDATA+='"valLatitud": '                 + num$(0)                   + ','
    CDATA+='"valLongitud": '                + num$(0)                   + ','
    CDATA+='"datTelMovilDirCli: "'          + num$(0)                   + '",'
    CDATA+='"codAgente": "'                 + 'YNS70'                   + '",'
    CDATA+='"flaNvoDirCli":'                + num$(0)                   + ''
    CDATA+='}'

Local Char CCDATA(250)(1..)
Local Integer J
CCDATA(1)='{'
CCDATA(2)='"codEmpresa":'                  + num$(101)                 + ','
CCDATA(3)='"codCliente": "'                + [F:YBPA]BPANUM            + '",'
CCDATA(4)='"linDirCli": '                  + num$(val([F:YBPA]BPAADD)+1) + ','
CCDATA(5)='"nomDirCli": "'                 + [F:YBPA]BPADES            + '",'
CCDATA(6)='"rsoDirCli": "'                 + [F:YBPA]BPADES            + '",'
CCDATA(7)='"datCalleDirCli": "'            + [F:YBPA]BPAADDLIG(0) - [F:YBPA]BPAADDLIG(1) + '",'
CCDATA(8)='"codPostalDirCli": "'           + [F:YBPA]POSCOD            + '",'
CCDATA(9)='"datPoblacionDirCli": "'        + [F:YBPA]CTY               + '",'
CCDATA(10)='"datProvinciaDirCli": "'        + [F:YBPA]SAT               + '",'
CCDATA(11)='"datPaisDirCli": "'             + 'ESPAÑA'                  + '",'   # [F:YBPA]CRYNAM
CCDATA(12)='"datContactoDirCli": "'         + ''                        + '",'
CCDATA(13)='"datTelefonoDirCli": "'         + [F:YBPA]TEL(0)            + '",'
CCDATA(14)='"datFaxDirCli": "'              + [F:YBPA]FAX               + '",'
CCDATA(15)='"datEmailDirCli": "'            + [F:YBPA]WEB(0)            + '",'
CCDATA(16)='"hipWebDirCli": "'              + [F:YBPA]FCYWEB            + '",'
CCDATA(17)='"codSuDirCli": "'               + 'FI'                      + '",'
CCDATA(18)='"valLatitud": '                 + num$(0)                   + ','
CCDATA(19)='"valLongitud": '                + num$(0)                   + ','
CCDATA(20)='"datTelMovilDirCli: "'          + ''                        + '",'
CCDATA(21)='"codAgente": "'                 + 'YNS70'                   + '",'
CCDATA(22)='"flaNvoDirCli":'                + num$(0)                   + ''
CCDATA(23)='}'
For J=1 To 23
  Infbox CCDATA(J)
Next

Infbox "antes get101"
    # busca la dirección
    RETVAL=func ASYRRESTCLI.EXEC_REST_WS("INATEST","GET","/api/iClientesLDirs?empresa=101&codcliente="+PCLIENTE+"&lindircli="+num$(val([F:YBPA]BPAADD)),PCOD,PVAL,HCOD,HVAL,CDATA,0,'',RESHEAD,RESBODY)
Infbox "despues get101"-num$(RETVAL)

    # la dirección existe
    If RETVAL=200 Then
Infbox "antes put101"-num$(RETVAL)
      # se actualiza la dirección
      RETVAL=func ASYRRESTCLI.EXEC_REST_WS("INATEST","PUT","/api/iClientesLDirs?empresa=101&codcliente="+PCLIENTE+"&lindircli="+num$(val([F:YBPA]BPAADD)),PCOD,PVAL,HCOD,HVAL,CDATA,0 ,'',RESHEAD,
& RESBODY)
      Call WRITE_LOG("CLIENTESDIR", "UPDATE", num$(RETVAL), "1", PCLIENTE, [F:YBPA]BPAADD, "")
Infbox "despues put101"-num$(RETVAL)
    # la dirección no existe
    Else
Infbox "antes post101"
      # se crea la dirección
      RETVAL=func ASYRRESTCLI.EXEC_REST_WS("INATEST","POST","/api/iClientesLDirs",PCOD,PVAL,HCOD,HVAL,CDATA,0 ,'',RESHEAD, RESBODY)
      Call WRITE_LOG("CLIENTESDIR", "INSERT", num$(RETVAL), "1", PCLIENTE, [F:YBPA]BPAADD, "")
Infbox "despues post101"-num$(RETVAL)
    Endif

    # Manage the errors
    # 200 - OK
    # 201 - OK
    # 409 - Conflicto porque ya existe el registro
    # 204 - Despues de un PUT, si es correcta la actualización da 204
    # 404 - Registro no encontrao
    If RETVAL<>200 and RETVAL<>201 and RETVAL<>409 and RETVAL<>204
      Infbox "Error inserción: " +num$(RETVAL)
      Infbox RESHEAD
      Infbox RESBODY
      Break
    Else
#      Infbox "INSERTADO CORRECTAMENTE"
    Endif

#    # planta 201
#    CDATA='{'
#    CDATA+='"codEmpresa":'                  + num$(201)                 + ','
#    CDATA+='"codCliente": "'                + [F:YBPA]BPANUM            + '",'
#    CDATA+='"linDirCli": '                  + num$(val([F:YBPA]BPAADD)+1) + ','
#    CDATA+='"nomDirCli": "'                 + [F:YBPA]BPADES            + '",'
#    CDATA+='"rsoDirCli": "'                 + [F:YBPA]BPADES            + '",'
#    CDATA+='"datCalleDirCli": "'            + [F:YBPA]BPAADDLIG(0) - [F:YBPA]BPAADDLIG(1) + '",'
#    CDATA+='"codPostalDirCli": "'           + [F:YBPA]POSCOD            + '",'
#    CDATA+='"datPoblacionDirCli": "'        + [F:YBPA]CTY               + '",'
#    CDATA+='"datProvinciaDirCli": "'        + [F:YBPA]SAT               + '",'
#    CDATA+='"datPaisDirCli": "'             + 'ESPAÑA'                  + '",'   # [F:YBPA]CRYNAM
#    CDATA+='"datContactoDirCli": "'         + ''                        + '",'
#    CDATA+='"datTelefonoDirCli": "'         + [F:YBPA]TEL(0)            + '",'
#    CDATA+='"datFaxDirCli": "'              + [F:YBPA]FAX               + '",'
#    CDATA+='"datEmailDirCli": "'            + [F:YBPA]WEB(0)            + '",'
#    CDATA+='"hipWebDirCli": "'              + [F:YBPA]FCYWEB            + '",'
#    CDATA+='"codSuDirCli": "'               + 'FI'                      + '",'
#    CDATA+='"valLatitud": '                 + num$(0)                   + ','
#    CDATA+='"valLongitud": '                + num$(0)                   + ','
#    CDATA+='"datTelMovilDirCli: "'          + '0'                       + '",'
#    CDATA+='"codAgente": "'                 + '95'                      + '",'
#    CDATA+='"flaNvoDirCli":'                + num$(0)                   + ''
#    CDATA+='}'
#
#    RETVAL=func ASYRRESTCLI.EXEC_REST_WS("INATEST","GET","/api/iClientesLDirs?empresa=201&codcliente="+PCLIENTE+"&lindircli="+num$(val([F:YBPA]BPAADD)),PCOD,PVAL,HCOD,HVAL,CDATA,0
# ,'',RESHEAD,RESBODY)
#
#    If RETVAL=200 Then
#      RETVAL=func ASYRRESTCLI.EXEC_REST_WS("INATEST","PUT","/api/iClientesLDirs?empresa=201&codcliente="+PCLIENTE +"&lindircli="+num$(val([F:YBPA]BPAADD)),PCOD,PVAL,HCOD,HVAL,CDATA,0 ,'',RESHEAD,
#& RESBODY)
#      Call WRITE_LOG("CLIENTESDIR","UPDATE",num$(RETVAL),num$(201),PCLIENTE,[F:YBPA]BPAADD,"")
#    Else
#      RETVAL=func ASYRRESTCLI.EXEC_REST_WS("INATEST","POST","/api/iClientesLDirs",PCOD,PVAL,HCOD,HVAL,CDATA,0 ,'',RESHEAD, RESBODY)
#      Call WRITE_LOG("CLIENTESDIR","CREATE",num$(RETVAL),num$(201),PCLIENTE,[F:YBPA]BPAADD,"")
#    Endif
#    # Manage the errors
#    # 200 - OK
#    # 201 - OK
#    # 409 - Conflicto porque ya existe el registro
#    # 204 - Despues de un PUT, si es correcta la actualización da 204
#    If RETVAL<>200 and RETVAL<>201 and RETVAL<>409 and RETVAL<>204
#      Infbox "Error inserción: " +num$(RETVAL)
#      Infbox RESHEAD
#      Infbox RESBODY
#    Else
##      Infbox "INSERTADO CORRECTAMENTE"
#    Endif
  Next
  Close Local File [YBPA],[YBPR]

  Kill RESHEAD,RESBODY,CDATA,PCOD,PVAL,HCOD,HVAL
End RETVAL

################################################################
################################################################
#**
#* Log de llamadas al WebServices y resultados
#*
#* @param PTABLA - Tabla a la que llamamos
#* @param PMODO  - INSERT - UPDATE
#* @param PRESULTADO - RESULTADO DEL WS
#* @param PCAMPO1 - Campos por los que filtramos el Ws
#* @param PCAMPO2 - Campos por los que filtramos el Ws
#* @param PCAMPO3 - Campos por los que filtramos el Ws
#* @param PCAMPO4 - Campos por los que filtramos el Ws
#*!
Subprog WRITE_LOG(PTABLA, PMODO, PRESULTADO, PCAMPO1, PCAMPO2, PCAMPO3, PCAMPO4)
Value Char PTABLA, PMODO, PRESULTADO, PCAMPO1, PCAMPO2, PCAMPO3, PCAMPO4

  If !clalev([YLWS]) Then : Local File YLOGWS [YLWS] : Endif

  Trbegin [F:YLWS]
  [F:YLWS]TABLA = PTABLA
  [F:YLWS]MODO  = PMODO
  [F:YLWS]RESULTADO = PRESULTADO
  [F:YLWS]CAMPO1 = PCAMPO1
  [F:YLWS]CAMPO2 = PCAMPO2
  [F:YLWS]CAMPO3 = PCAMPO3
  [F:YLWS]CAMPO4 = PCAMPO4
  Write [F:YLWS]
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  Close Local File [YLWS]

End
