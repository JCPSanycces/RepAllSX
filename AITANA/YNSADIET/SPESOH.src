######################################################################################
## Etiqueta añadida por el supervisor (pantalla SOH0) 23/03/2020 10:09:40 (AIT04)
######################################################################################
$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
 When "DEBUT"       :   Gosub DEBUT
 When "SETBOUT"     :   Gosub SETBOUT
 When "RAZCRE"      :   Gosub RAZCRE
 When "FILTRE"      :   Gosub FILTRE
 When "SEL_TABLE"   :   Gosub SEL_TABLE
 When "VERF_TABLE"  :   Gosub VERF_TABLE
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$DEBUT
## JC.30092020.SP-57.STR
#  Grizo [M:SOH0]YSOHTYP
## JC.30092020.SP-57.END
Return

##############################################################
$SETBOUT
## JC.30092020.SP-57.STR
#  If GREP = "C" or GREP = "M" Then
#    Actzo [M:SOH0]YSOHTYP
#  Else
#    Grizo [M:SOH0]YSOHTYP
#  Endif
## JC.30092020.SP-57.END
Return

######################################################################################
$RAZCRE

If GWEBSERV<>1  and 1=2 Then
  # Pongo por defecto el tipo de pedido en función de la transacción
  Gosub RAZCRE From SUBSOHA1

  Case GFLAG
    When "YEC"  : [M:SOH0]SALFCY = "101" : [M:SOH0]SOHTYP = "ECO"
    When "YLM"  : [M:SOH0]SALFCY = "201" : [M:SOH0]SOHTYP = "PLM"
    When "YNS"  : [M:SOH0]SALFCY = "101" : [M:SOH0]SOHTYP = "PPV"
    When "YNC"  : [M:SOH0]SALFCY = "102" : [M:SOH0]SOHTYP = "PCV"
    When "YCR"  : [M:SOH0]SALFCY = "101" : [M:SOH0]SOHTYP = "CRM"
    When "XJA"  : [M:SOH0]SALFCY = "101" : [M:SOH0]SOHTYP = "CRM"
    When "YTO"  : [M:SOH0]SALFCY = "101" : [M:SOH0]SOHTYP = "PPV"
  Endcase

  Affzo [M:SOH0]SALFCY
  Affzo [M:SOH0]SOHTYP

  zonsui  ="[M:SOH0]CUSORDREF"
  GPE = 1
Endif


Return

######################################################################################
$FILTRE
# Visualización de pedidos en función de la transacción
Gosub FILTRE From SUBSOHA1

Default File [SOH]

Case GFLAG
  When "YEC"  : FILTSUP += " & SOHTYP = 'ECO'"
  When "YLM"  : FILTSUP += " & SOHTYP = 'PLM'"
  When "YNS"  : FILTSUP += " & SOHTYP = 'PPV'"
  When "YNC"  : FILTSUP += " & SOHTYP = 'PCV'"
  When "YCR"  : FILTSUP += " & SOHTYP = 'CRM'"
  When "XJA"  : FILTSUP += " & SOHTYP = 'CRM'"
Endcase

GPE = 1
Return

##############################################################
$SEL_TABLE
  Case TABLE
    When "YSELSOHTYP"   : Gosub SEL_YSELSOHTYP          # JC.30092020.SP-57
    When "YSELITMSOH"   : Gosub SEL_YSELITMSOH          # JC.04022021.YN52
  Endcase
Return

##############################################################
$VERF_TABLE
  Case TABLE
    When "YSELSOHTYP"   : Gosub VERF_YSELSOHTYP         # JC.30092020.SP-57
    When "YSELITMSOH"   : Gosub VERF_YSELITMSOH         # JC.04022021.YN52
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
# JC.30092020.SP-57.STR
$SEL_YSELSOHTYP
Local Char LCRIT(250)
  If GFLAG ="XJA" Then LCRIT = "[TSO0]SOHTYP='CRM'"
  Elsif GFLAG ="YNC" Then LCRIT = "[TSO0]SOHTYP='PCV'"
  Elsif GFLAG ="YNS" Then LCRIT = "[TSO0]SOHTYP='PPV' OR [TSO0]SOHTYP='CRM' OR [TSO0]SOHTYP='WEB' OR [TSO0]SOHTYP='DIR'"
  Elsif GFLAG ="YLM" Then LCRIT = "[TSO0]SOHTYP='PLM' OR [TSO0]SOHTYP='WEBLM'"
  Else LCRIT = "1=1"
  Endif

  If !clalev([F:TSO0]) Then : Local File TABSOHTYP [F:TSO0] : Endif
  If !clalev([F:AXX0]) Then : Local File ATEXTRA   [F:AXX0] : Endif
  Link [AXX0] With [TSO0]TSO1=[F:AXX0]IDENT1 As [LNK0] Where CODFIC="TABSOHTYP" and ZONE = "DESAXX" and LANGUE=GLANGUE
  Columns [LNK0] ([TSO0]SOHTYP,[AXX0]TEXTE)
  Default File [LNK0]
  Filter [LNK0] Where evalue(LCRIT)
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Seleción Tabla tipos pedidos"                                  # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Tipo de pedido"                                                # título de la segunda columna
  COL(NBCOL)  = "[TSO0]SOHTYP"                                                  # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la segunda columna
  COL(NBCOL)  = "[AXX0]TEXTE"                                                   # nombre del campo a mostrar en la segunda columna

Return
# JC.30092020.SP-57.END

##############################################################
# JC.30092020.SP-57.STR
VERF_YSELSOHTYP
  [M:SOH0]SOHTYP = [TSO0]SOHTYP
  Affzo [M:SOH0]SOHTYP
Return
# JC.30092020.SP-57.END

##############################################################
# JC.04022021.YN52.STR
$SEL_YSELITMSOH
  If [M:SOH0]SALFCY = "201" Then
    CRITERE = "1=1"
    If !clalev([F:YVIS]) Then : Local File YVFILITMSOH [F:YVIS] : Endif
    Default File [YVIS]
    NBCOL       = 0                                                               # número de la columna
    TIT(NBCOL)  = "Artículos"                                                     # título de la ventana
    NBCOL       += 1
    TIT(NBCOL)  = "Artículo"                                                      # título de la segunda columna
    COL(NBCOL)  = "[YVIS]ITMREF"                                                  # nombre del campo a mostrar en la segunda columna
    NBCOL       += 1
    TIT(NBCOL)  = "EAN"                                                           # título de la segunda columna
    COL(NBCOL)  = "[YVIS]EANCOD"                                                  # nombre del campo a mostrar en la segunda columna
    NBCOL       += 1
    TIT(NBCOL)  = "Descripción"                                                   # título de la segunda columna
    COL(NBCOL)  = "[YVIS]ITMDES1"                                                 # nombre del campo a mostrar en la segunda columna
    NBCOL       += 1
    TIT(NBCOL)  = "Stock disponible"                                              # título de la segunda columna
    COL(NBCOL)  = "[YVIS]PHYSTO"                                                  # nombre del campo a mostrar en la segunda columna
    NBCOL       += 1
    TIT(NBCOL)  = "PVT"                                                           # título de la segunda columna
    COL(NBCOL)  = "[YVIS]PVT"                                                     # nombre del campo a mostrar en la segunda columna
    NBCOL       += 1
    TIT(NBCOL)  = "PVP"                                                           # título de la segunda columna
    COL(NBCOL)  = "[YVIS]PVP"                                                     # nombre del campo a mostrar en la segunda columna
    NBCOL       += 1
    TIT(NBCOL)  = "Familia"                                                       # título de la segunda columna
    COL(NBCOL)  = "[YVIS]TSICOD2"                                                 # nombre del campo a mostrar en la segunda columna
    NBCOL       += 1
    TIT(NBCOL)  = "Desc. familia"                                                 # título de la segunda columna
    COL(NBCOL)  = "[YVIS]DESTSICOD2"                                              # nombre del campo a mostrar en la segunda columna

    ORDRE       = '[YVIS]ITMREF'
    SENS        = 1
    DEFPAG      = 5
    SIZCOL      = 100
    SIZLIG      = 100
    GSELFAC     = 1
  Else
    Gosub S_ITV         # etiqueta copiada del estándar
  Endif
Return
# JC.04022021.YN52.END

#########################################################################
# JC.04022021.YN52.STR
# he copiado la etiqueta que se lanza en el estándar SELITV
$S_ITV
  If clalev([F:ITS])=0 : Local File ITMSALES  : Endif
  If clalev([F:ITM])=0 : Local File ITMMASTER : Endif
  If clalev([F:ATZ])=0 : Local File ATABZON   : Endif
  Local Char CODFIC    : CODFIC = "ITMSALES"

  Link [ITS] With [ITM]ITM0=[ITS]ITMREF As [KITS]
  Default File [KITS]

  ORDRE   = 'ITMREF'
  START   = 'ITMREF'

  CRITERE='[F:ITM]ITMSTA=1 & [F:ITM]ITMREF>="'+VALEUR+'"'
  OBJET="ITS"
Return
# JC.04022021.YN52.END

##############################################################
# JC.04022021.YN52.STR
VERF_YSELITMSOH
  If [M:SOH0]SALFCY = "201" Then
    [M:SOH4]ITMREF(nolign-1)    = [F:YVIS]ITMREF
    [M:SOH4]ITMDES(nolign-1)    = [F:YVIS]ITMDES1
    [M:SOH4]ITMDES1(nolign-1)   = [F:YVIS]ITMDES1
    [M:SOH4]SAU(nolign-1)       = [F:YVIS]SAU
    [M:SOH4]SAUSTUCOE(nolign-1) = [F:YVIS]SAUSTUCOE
    [M:SOH4]DLVFLG(nolign-1)    = 2
    [M:SOH4]VACITM1(nolign-1)   = [F:YVIS]VACITM1
    [M:SOH4]VACITM2(nolign-1)   = [F:YVIS]VACITM2
    [M:SOH4]VACITM3(nolign-1)   = [F:YVIS]VACITM3

    Affzo [M:SOH4]ITMREF(nolign-1)
    Affzo [M:SOH4]ITMDES(nolign-1)
    Affzo [M:SOH4]ITMDES1(nolign-1)
    Affzo [M:SOH4]SAU(nolign-1)
    Affzo [M:SOH4]SAUSTUCOE(nolign-1)
    Affzo [M:SOH4]DLVFLG(nolign-1)
    Affzo [M:SOH4]VACITM1(nolign-1)
    Affzo [M:SOH4]VACITM2(nolign-1)
    Affzo [M:SOH4]VACITM3(nolign-1)

    zonsui = "[M:SOH4]SAU(nolign-1)"
  Endif
Return
# JC.04022021.YN52.END

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
Subprog C_SOHTYP(VALEUR)
Variable Char    VALEUR()
# Controlo el tipo de pedido en función de la transacción
If 1=2
If GFLAG = "YEC" and VALEUR <>"ECO"
    mkstat =2
    GMESSAGE="El tipo de pedido debe ser ECO"
Elsif GFLAG ="YLM" and VALEUR <>"PLM"
    mkstat =2
    GMESSAGE="El tipo de pedido debe ser PLM"
Elsif GFLAG ="YNS" and VALEUR <> "PPV"
    mkstat =2
    GMESSAGE="El tipo de pedido debe ser PPV"
Elsif GFLAG ="YNC" and VALEUR <> "PCV"
    mkstat =2
    GMESSAGE="El tipo de pedido debe ser PCV"
Elsif GFLAG ="YCR" and VALEUR <>"CRM"
    mkstat =2
    GMESSAGE="El tipo de pedido debe serCRM"
Elsif GFLAG ="XJA" and VALEUR <>"CRM"
    mkstat =2
    GMESSAGE="El tipo de pedido debe ser CRM"
Endif
Endif
End


######################################################################################
## Después del campo 'Artículo'
######################################################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
  If !clalev([F:ITM0]) Then : Local File ITMMASTER [F:ITM0] : Endif
  Read [F:ITM0]ITM0 = VALEUR
  If !fstat Then
    [M:SOH4]YPVP(nolign-1) = [F:ITM0]YPVP
    Affzo [M:SOH4]YPVP(nolign-1)
  Endif
  If  clalev([F:ITM0]) Then : Close Local File     [F:ITM0] : Endif
End

