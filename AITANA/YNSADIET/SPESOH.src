##################    FUNCIONES PROPIAS    ###################
##############################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla SOH2) 07/12/2020 16:23:35 (AIT04)
######################################################################################
Subprog AM_YDESTINO(VALEUR)
Variable Char    VALEUR()
Read [BPD]BPD0=[M:SOH0]BPCORD;VALEUR
If fstat = 0
  [M:SOH2]YEMPRESA  = [BPD]YEMPRESA
  [M:SOH2]YSUCURSAL = [BPD]YSUCURSAL
  Affzo [M:SOH2]YEMPRESA
  Affzo [M:SOH2]YSUCURSAL
Endif
End
