#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara PSH1 (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla PSH1) 10/02/2021 07:39:32 (AIT04)
######################################################################################
$ACTION
Case ACTION
 When "LIENS"       :   Gosub LIENS
Endcase
Return

######################################################################################
$LIENS
# Muestro el número del pedido
Gosub LIENS From SUBPSH1

If [M:PSH1]XORDFLG = 2
  If !clalev([PP1]) : Local File PREQUISO [PP1] : Endif
  If !clalev([PP2]) : Local File PORDER   [PP2] : Endif
#Infbox "entro"
  Filter [PP1] Where [PP1]PSHNUM = [M:PSH0]PSHNUM
  Read [PP1] First
  If fstat = 0
    [M:PSH1]YPEDIDO   =  [PP1]POHNUM
#Infbox [PP1]POHNUM
    Read [PP2]POH0 =  [PP1]POHNUM
    If fstat=0
      [M:PSH1]YPEDIDOF   =  [PP2]ORDDAT
    Endif
  Endif
  Filter [PP1]

  Affzo [M:PSH1]YPEDIDO
  Affzo [M:PSH1]YPEDIDOF

  Close Local File [PP1],[PP2]
Endif

GPE = 1

Return


######################################################################################
Subprog AS_BPSNUM(VALEUR)
Variable Char    VALEUR()
# Pongo el proveedor de cabecera
If [M:PSH0]YBPSNUM <> ''
  VALEUR = [M:PSH0]YBPSNUM
  GPE = 1
Endif
End



######################################################################################
Subprog AP_BPSNUM(VALEUR)
Variable Char    VALEUR()
# Lanzo la acción de después de modificar (me traigo el STD para impedir el mensaje de artículo-proveedor)
#Call AM_BPSNUM(VALEUR)
End
