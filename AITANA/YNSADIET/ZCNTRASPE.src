$ACTION
Case ACTION
    When "AUTORIS"    : Gosub AUTORIS From ZCNTRASTD
    When "OUVRE"      : Gosub OUVRE From ZCNTRASTD
    When "LECTURE"    : Gosub LECTURE From ZCNTRASTD
    When "DEB_CRIT"   : Gosub DEB_CRIT From ZCNTRASTD
    When "FIN_CRIT"   : Gosub FIN_CRIT From ZCNTRASTD
    When Default
Endcase

Return

################################################################################
Subprog AM_FECHADEB(VALEUR)
  Variable Date    VALEUR

  If VALEUR <> [0/0/0] : [M]FECHAFIN= VALEUR : Endif

End

######################################################################################
Subprog IB_NBLIG
  Local Integer NOL : NOL = nolign-1

End

