#<AdxTL>@(#)0.0.0.0 $Revision$ 
#####################################################################################
# Src: SPEYPR
#-------------------------------------------------------------------------------------
# Proyecto: Estándar
#-------------------------------------------------------------------------------------
# Version: v12
#-------------------------------------------------------------------------------------
# YN01 - Parrilla de recepción
# Fecha inicio YN01: 14/08/2019
# Desarrollador: JCH
# Código de desarrollo: YN01
# Descripción del desarrollo: Parrilla de recepción de material
# Fecha: 14/08/2019
# Codigo Actividad: YYN01
#######################################################################################

$ACTION

Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "DEBUT"        : Gosub DEBUT
  When "BOUTON"       : Gosub BOUTON
  When "SETBOUT"      : Gosub SETBOUT
  When "FIN"          : Gosub FIN
  When "SEL_TABLE"    : Gosub SEL_TABLE
  When "VERF_TABLE"   : Gosub VERF_TABLE
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$SEL_TABLE
  Case TABLE
    When "YSELSTKPR"   : Gosub SEL_YSELSTKPR
  Endcase
Return

##############################################################
$VERF_TABLE
  Case TABLE
    When "YSELSTKPR"   : Gosub VERF_YSELSTKPR
  Endcase
Return

##############################################################
$OUVRE
  Gosub ABRIR_TABLAS
Return

##############################################################
$DEBUT
Global Integer GLCK
  [M:YPR0]STRDAT = date$ - 10
  [M:YPR0]ENDDAT = date$
  Affzo [M:YPR0]5,10,15
  Gosub CARGA_ESTADOS
Return

##############################################################
$BOUTON
  Case BOUT
    When "b"  : Gosub BUSCAR
    When "s"  : Gosub FIN
  Endcase
Return

##############################################################
$SETBOUT
  Raz CHMEN
  Case BOUT
    When "O" : CHMEN += "bsu"
    When "b" : CHMEN += "bsu"
    When "U" : CHMEN += "bsu"
    When Default : CHMEN += "bsu"
  Endcase
Return

##############################################################
$FIN
  Gosub CERRAR_TABLAS
  Call UNLOCK_LCKPRR(adxuid(1),"PR") From SPEYLIB0

  If dim(LFILE_W1)  > 0 Then : Kill LFILE_W1  : Endif
  If dim(LFILE_W2)  > 0 Then : Kill LFILE_W2  : Endif
  If dim(GLCK)      > 0 Then : Kill GLCK      : Endif
  FIN=1
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ABRIR_TABLAS
  If !clalev([F:TST0]) Then : Local File TABSTASTO    [F:TST0] : Endif
  If !clalev([F:TST1]) Then : Local File TABSTASTO    [F:TST1] : Endif
  If !clalev([F:AXX0]) Then : Local File ATEXTRA      [F:AXX0] : Endif
  If !clalev([F:AXX1]) Then : Local File ATEXTRA      [F:AXX1] : Endif
  If !clalev([F:STJ0]) Then : Local File STOJOU       [F:STJ0] : Endif
  If !clalev([F:STJ1]) Then : Local File STOJOU       [F:STJ1] : Endif
  If !clalev([F:STL0]) Then : Local File STOLOT       [F:STL0] : Endif
  If !clalev([F:STO0]) Then : Local File STOCK        [F:STO0] : Endif
  If !clalev([F:ITF0]) Then : Local File ITMFACILIT   [F:ITF0] : Endif
  If !clalev([F:ACB0]) Then : Local File ACLOB        [F:ACB0] : Endif
  If !clalev([F:YTR0]) Then : Local File YMFGTRAZAPR  [F:YTR0] : Endif
Return

##############################################################
$CERRAR_TABLAS
  If clalev([F:ITF0])  Then : Close Local File        [F:ITF0] : Endif
  If clalev([F:STJ1])  Then : Close Local File        [F:STJ1] : Endif
  If clalev([F:STL0])  Then : Close Local File        [F:STL0] : Endif
  If clalev([F:STO0])  Then : Close Local File        [F:STO0] : Endif
  If clalev([F:ACB0])  Then : Close Local File        [F:ACB0] : Endif
  If clalev([F:YTR0])  Then : Close Local File        [F:YTR0] : Endif
Return

##############################################################
$SEL_YSELSTKPR
  Link [AXX0] With [TST0]TST0=[F:AXX0]IDENT1 As [LNK0] Where CODFIC="TABSTASTO" and ZONE = "STAAXX" and LANGUE=GLANGUE
  Columns [LNK0] ([TST0]STASTO,[AXX0]TEXTE)
  Default File [LNK0]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Estados"                                                       # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "[TST0]STASTO"                                                  # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la segunda columna
  COL(NBCOL)  = "[AXX0]TEXTE"                                                   # nombre del campo a mostrar en la segunda columna
Return

##############################################################
$VERF_YSELSTKPR
Return

##############################################################
$BUSCAR
Local Clbfile   CRITSQL(2)(0..16) : Raz CRITSQL
Local Clbfile   LWHERE1(2), LWHERE2(2) : Raz LWHERE1, LWHERE2
Local Clbfile   LWHERE3(2) : Raz LWHERE3
Local Integer   LCON0, LCON10 : Raz LCON0, LCON10
Local Integer   LCONTROL : Raz LCONTROL
Local Integer   LLCKUID
Local Datetime  LLCKTIM
Local Char      LLCKUSR(20)

  # vacío la tabla de bloqueos
  Call UNLOCK_LCKPRR(adxuid(1),"PR") From SPEYLIB0

  # limpio el grid
  Effzo [M:YPR0]25
  indice = 0
  [M:YPR0]NBLIG = 0

  # elimina los registros en la tabla de bloqueos de las sesiones que no existen en X3
  Call DEL_SESSIONS() From SPEYLIB0

  LWHERE1 = "STOJOU.VCRTYP_0=6"
  If [M:YPR0]STRDAT <> [00/00/0000] Then : LWHERE1 += " and PRECEIPTD.RCPDAT_0>='"   +[M:YPR0]STRDAT+"'"       : Endif
  If [M:YPR0]ENDDAT <> [00/00/0000] Then : LWHERE1 += " and PRECEIPTD.RCPDAT_0<='"   +[M:YPR0]ENDDAT+"'"       : Endif
  If [M:YPR0]LOTMGTCOD <> 0         Then : LWHERE1 += " and ITMMASTER.LOTMGTCOD_0="  +num$([M:YPR0]LOTMGTCOD)  : Endif
  If [M:YPR0]STRBPS <> ""           Then : LWHERE1 += " and PRECEIPTD.BPSNUM_0>='"   +[M:YPR0]STRBPS+"'"       : Endif
  If [M:YPR0]ENDBPS <> ""           Then : LWHERE1 += " and PRECEIPTD.BPSNUM_0<='"   +[M:YPR0]ENDBPS+"'"       : Endif
  If [M:YPR0]ITMREF <> ""           Then : LWHERE2 += " and PRECEIPTD.ITMREF_0='"    +[M:YPR0]ITMREF+"'"       : Endif
  If [M:YPR0]STOFCY <> ""           Then : LWHERE2 += " and STOJOU.STOFCY_0='"       +[M:YPR0]STOFCY+"'"       : Endif
  If [M:YPR0]LOT <> ""              Then : LWHERE2 += " and STOJOU.LOT_0 LIKE'%"     +[M:YPR0]LOT+"%'"         : Endif
  For LCON10 = 0 To [M:YPR0]NBSTA-1
    If [M:YPR0]SELSTA(LCON10) = 2 Then
      If LCONTROL = 0 Then
        LWHERE3 += "CASE WHEN YMFGTRAZAPR.STA_0<>'' THEN YMFGTRAZAPR.STA_0 ELSE STOJOU.STA_0 END='" + [M:YPR0]CDGSTA(LCON10) + "'"
      Else
        LWHERE3 += " or CASE WHEN YMFGTRAZAPR.STA_0<>'' THEN YMFGTRAZAPR.STA_0 ELSE STOJOU.STA_0 END='" + [M:YPR0]CDGSTA(LCON10) + "'"
      Endif
      LCONTROL += 1
    Endif
  Next

  CRITSQL(0)  = "SELECT STOJOU.LOT_0,STOJOU.BPSLOT_0,PRECEIPTD.ITMREF_0,PRECEIPTD.BPSNUM_0,PRECEIPTD.RCPDAT_0,PRECEIPTD.PTHNUM_0,PRECEIPTD.QTYUOM_0,"
  CRITSQL(1)  = "STOJOU.SHLDAT_0,TEXCLOB.TEXTE_0,PRECEIPTD.POHFCY_0,PRECEIPTD.ITMDES_0,STOJOU.LOC_0,PRECEIPTD.UOM_0,"
  CRITSQL(2)  = "STOJOU.USRFLD1_0,STOJOU.USRFLD2_0,STOJOU.YUSRFLD3_0,ITMMASTER.YREQPROV_0,PRECEIPTD.YOBSRECEP_0,PRECEIPTD.PTDLIN_0,"
  CRITSQL(3)  = "CASE WHEN YMFGTRAZAPR.STA_0 <> '' THEN YMFGTRAZAPR.STA_0 ELSE STOJOU.STA_0 END AS ESTADO "
  CRITSQL(4)  = "FROM "+nomap+".PRECEIPTD "
  CRITSQL(5)  = "INNER JOIN "+nomap+".ITMMASTER ON PRECEIPTD.ITMREF_0 = ITMMASTER.ITMREF_0 "
  CRITSQL(7)  = "INNER JOIN "+nomap+".STOJOU ON PRECEIPTD.ITMREF_0 = STOJOU.ITMREF_0 AND PRECEIPTD.PTHNUM_0 = STOJOU.VCRNUM_0 AND PRECEIPTD.PTDLIN_0 = STOJOU.VCRLIN_0 "
  CRITSQL(8)  = "LEFT JOIN "+nomap+".TEXCLOB ON PRECEIPTD.LINTEX_0 = TEXCLOB.CODE_0 "
  CRITSQL(9)  = "LEFT JOIN "+nomap+
& ".YMFGTRAZAPR ON PRECEIPTD.PTHNUM_0=YMFGTRAZAPR.PTHNUM_0 AND PRECEIPTD.PTDLIN_0=YMFGTRAZAPR.PTDLIN_0 AND PRECEIPTD.ITMREF_0=YMFGTRAZAPR.ITMREF_0 AND YMFGTRAZAPR.LOT_0 = STOJOU.LOT_0 "
  CRITSQL(10) = "WHERE STOJOU.REGFLG_0=1 AND " + LWHERE1
  CRITSQL(11) = LWHERE2
  If LWHERE3 <> "" Then : CRITSQL(12)  = " and (" + LWHERE3 + ")" : Endif
  CRITSQL(13) = " GROUP BY STOJOU.LOT_0,STOJOU.BPSLOT_0,PRECEIPTD.ITMREF_0,PRECEIPTD.BPSNUM_0,PRECEIPTD.RCPDAT_0,PRECEIPTD.PTHNUM_0,PRECEIPTD.QTYUOM_0,"
  CRITSQL(14) = "STOJOU.SHLDAT_0,TEXCLOB.TEXTE_0,PRECEIPTD.POHFCY_0,PRECEIPTD.ITMDES_0,STOJOU.LOC_0,PRECEIPTD.UOM_0,"
  CRITSQL(15) = "STOJOU.USRFLD1_0,STOJOU.USRFLD2_0,ITMMASTER.YREQPROV_0,PRECEIPTD.YOBSRECEP_0,PRECEIPTD.PTDLIN_0,"
  CRITSQL(16) = "CASE WHEN YMFGTRAZAPR.STA_0 <> '' THEN YMFGTRAZAPR.STA_0 ELSE STOJOU.STA_0 END,STOJOU.USRFLD1_0,STOJOU.USRFLD2_0,STOJOU.YUSRFLD3_0"

#If GUSER="AIT07" Then
#  Local Integer I
#  For I=0 To 16
#  Infbox num$(I)+"-"+CRITSQL(I)
#  Next
#  Kill I
#Endif

  For (Char LOT(250),Char BPSLOT(250),Char ITMREF(250),Char BPSNUM(250),Date RCPDAT,Char PTHNUM(250),Decimal QTYUOM,Date SHLDAT,Char TEXTE(250),Char POHFCY(250),
& Char ITMDES(250),Char LOC(250),Char UOM(250),Char USRFLD1(250), Char USRFLD2(250),Char YUSRFLD3(250), Char YREQPROV(250), Char YOBSRECEP(250), Integer PTDLIN, Char ESTADO(250))
& From "5" Sql CRITSQL(0..16) As [Y00]

    If [F:Y00]ESTADO = "A" Then
      [M:YPR0]STAL(LCON0) = 2
      Grizo [M:YPR0]STAL(LCON0), STNAL(LCON0)
    Elsif [F:Y00]ESTADO = "R"
      [M:YPR0]STNAL(LCON0) = 2
      Grizo [M:YPR0]STAL(LCON0), STNAL(LCON0)
    Else
      [M:YPR0]STNAL(LCON0) = 1
      Actzo [M:YPR0]STAL(LCON0), STNAL(LCON0)
    Endif
    [M:YPR0]LOTEL(LCON0)      = [F:Y00]LOT
    [M:YPR0]BPSLOTEL(LCON0)   = [F:Y00]BPSLOT
    [M:YPR0]SHLDAT(LCON0)     = [F:Y00]SHLDAT
    [M:YPR0]ITMREFL(LCON0)    = [F:Y00]ITMREF
    [M:YPR0]BPSNUM(LCON0)     = [F:Y00]BPSNUM
    [M:YPR0]ENTDAT(LCON0)     = [F:Y00]RCPDAT
    [M:YPR0]DOCUMENTO(LCON0)  = "Albarán Compras: " + [F:Y00]PTHNUM
    [M:YPR0]PTHNUM(LCON0)     = [F:Y00]PTHNUM
    [M:YPR0]PTDLIN(LCON0)     = [F:Y00]PTDLIN
    [M:YPR0]QTY(LCON0)        = [F:Y00]QTYUOM
    [M:YPR0]OBSERVA(LCON0)    = [F:Y00]USRFLD1
    [M:YPR0]REFERENCIA(LCON0) = [F:Y00]USRFLD2
    [M:YPR0]REQUISITOS(LCON0) = [F:Y00]YREQPROV
    [M:YPR0]ESTADO(LCON0)     = [F:Y00]ESTADO
    [M:YPR0]OBSRECEP(LCON0)   = [F:Y00]YOBSRECEP
    [M:YPR0]PCUL(LCON0)       = [F:Y00]UOM
    [M:YPR0]POHFCY(LCON0)     = [F:Y00]POHFCY
    [M:YPR0]ITMDESL(LCON0)    = [F:Y00]ITMDES
    [M:YPR0]LOCL(LCON0)       = [F:Y00]LOC

    # gestiona los bloqueos
    GLCK = func SPEYLIB0.SEARCH_LCKPRR([F:Y00]ITMREF,[F:Y00]LOT)
    If !GLCK Then
      Call LOCK_LCKPRR([F:Y00]ITMREF,[F:Y00]LOT,"PR") From SPEYLIB0
    Else
      Raz LLCKUID,LLCKUSR,LLCKTIM
      Call GET_IDLCK([F:Y00]ITMREF,[F:Y00]LOT,LLCKUID,LLCKUSR,LLCKTIM) From SPEYLIB0
      [M:YPR0]LCKUSR(LCON0) = LLCKUSR
      [M:YPR0]LCKDAT(LCON0) = num$(LLCKTIM)
    Endif

    LCON0                     += 1
  Next
  [M:YPR0]NBLIG = LCON0
  Affzo [M:YPR0]25

  Gosub PAINT_LCKLINE
  Affzo [M:YPR0]25

  If dim(LLCKUID) > 0 Then : Kill LLCKUID : Endif
  If dim(LLCKTIM) > 0 Then : Kill LLCKTIM : Endif
  If dim(LLCKUSR) > 0 Then : Kill LLCKUSR : Endif

Return

##############################################################
$BUSCA_WSTJQTY
Local Integer LCON2 : Raz LCON2

  For LCON2 = 0 To [M:YPR0]NBLIG-1
    Filter [F:STJ0] Where ITMREF = [M:YPR0]ITMREFL(LCON2) and LOT = [M:YPR0]LOTEL(LCON2) and STOFCY = [M:YPR0]POHFCY(LCON2)
    Read [F:STJ0] First
    If !fstat Then
      [M:YPR0]WSTJQTY(LCON2)  = [F:STJ0]QTYPCU
      [M:YPR0]PCUL(LCON2)     = [F:STJ0]PCU
    Endif
    Filter [F:STJ0]
  Next

Return

##############################################################
$BUSCA_QLYCRD
Local Integer LCON3 : Raz LCON3

  For LCON3 = 0 To [M:YPR0]NBLIG-1
    Read [F:ITF0]ITF0 = [M:YPR0]ITMREFL;POHFCY
    If !fstat Then
      [M:YPR0]QLYCRD(LCON3) = [F:ITF0]QLYCRD
    Endif
  Next

Return

##############################################################
$PINTA_LINEAS_APTO
Local Integer LCON1 : Raz LCON1

  For LCON1 = 0 To [M:YPR0]NBLIG
    If [M:YPR0]STAL(LCON1) = 2 Then
      Chgstl [M:YPR0]NBLIG(LCON1) With "BACKRED"
    Else
      Chgstl [M:YPR0]NBLIG(LCON1) With ""
    Endif
  Next

Return

########################################################
$OPEN_FILE_W1

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE_W1 Using [ZIMP_W1]

Return

########################################################
$CLOSE_FILE_W1

Openo Using [ZIMP_W1]

Return

########################################################
$OPEN_FILE_W2

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE_W2 Using [ZIMP_W2]

Return

########################################################
$CLOSE_FILE_W2

Openo Using [ZIMP_W2]

Return

###############################################################
$CARGA_ESTADOS
Local Integer LCON4 : Raz LCON4

  Link [AXX1] With [TST1]TST0=[F:AXX1]IDENT1 As [LNK1] Where CODFIC="TABSTASTO" and ZONE = "STAAXX" and LANGUE=GLANGUE
  Columns [LNK1] ([TST1]STASTO,[AXX1]TEXTE)

  For [LNK1]
    [M:YPR0]CDGSTA(LCON4) = [F:TST1]STASTO
    [M:YPR0]DESSTA(LCON4) = [F:AXX1]TEXTE
    LCON4 += 1
  Next
  [M:YPR0]NBSTA = LCON4
  Affzo [M:YPR0]20
Return

###############################################################
# genera un registro nuevo en la tabla de trazabilidad YMFGTRAZAPR
# con los datos del movimiento al pulsar 'Apto/No apto'
$GENERA_TRAZA
  Trbegin [F:YTR0]
  [F:YTR0]IDREG       = getUuid
  [F:YTR0]ITMREF      = [M:YPR0]ITMREFL(LNOL)
  [F:YTR0]LOT         = [M:YPR0]LOTEL(LNOL)
  [F:YTR0]STA         = LSTA
  [F:YTR0]SHLDAT      = [M:YPR0]SHLDAT(LNOL)
  [F:YTR0]BPSNUM      = [M:YPR0]BPSNUM(LNOL)
  [F:YTR0]ENTDAT      = [M:YPR0]ENTDAT(LNOL)
  [F:YTR0]DOCUMENTO   = [M:YPR0]DOCUMENTO(LNOL)
  [F:YTR0]PTHNUM      = [M:YPR0]PTHNUM(LNOL)
  [F:YTR0]PTDLIN      = [M:YPR0]PTDLIN(LNOL)
  [F:YTR0]QTY         = [M:YPR0]QTY(LNOL)
  [F:YTR0]APTO        = [M:YPR0]APTO(LNOL)
  [F:YTR0]PENDIENTE   = [M:YPR0]PENDIENTE(LNOL)
  [F:YTR0]OBSERVA     = [M:YPR0]OBSERVA(LNOL)
  [F:YTR0]NOTAS       = [M:YPR0]NOTAS(LNOL)
  [F:YTR0]REFERENCIA  = [M:YPR0]REFERENCIA(LNOL)
  [F:YTR0]REQUISITOS  = [M:YPR0]REQUISITOS(LNOL)
  [F:YTR0]CDGSOL      = [M:YPR0]CDGSOL(LNOL)
  [F:YTR0]ESTADO      = [M:YPR0]ESTADO(LNOL)
  [F:YTR0]OBSRECEP    = [M:YPR0]OBSRECEP(LNOL)
  [F:YTR0]WSTJQTY     = [M:YPR0]WSTJQTY(LNOL)
  [F:YTR0]PCU         = [M:YPR0]PCUL(LNOL)
  [F:YTR0]POHFCY      = [M:YPR0]POHFCY(LNOL)
  [F:YTR0]QLYCRD      = [M:YPR0]QLYCRD(LNOL)
  [F:YTR0]ITMDES      = [M:YPR0]ITMDESL(LNOL)
  [F:YTR0]LOC         = [M:YPR0]LOCL(LNOL)
  [F:YTR0]UPDDATTIM   = datetime$
  Write [F:YTR0]
  If !fstat Then
    Commit
  Else
    Rollback
  Endif
Return

##############################################################
$PAINT_LCKLINE
Local Integer LCON : Raz LCON

  For LCON = 0 To [M:YPR0]NBLIG-1
    If [M:YPR0]LCKUSR(LCON) <> "" Then
      Chgstl [M:YPR0]NBLIG(LCON) With "BACKRED"
    Else
      Chgstl [M:YPR0]NBLIG(LCON) With ""
    Endif
  Next

  If dim(LCON) > 0 Then : Kill LCON : Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Antes de entrada "Tipo artículo"
######################################################################################
Subprog AS_LOTMGTCOD(VALEUR)
Variable Integer VALEUR
  Raz GMENLOC
#  GMENLOC(2) = 1
  GMENLOC(4) = 1
End

######################################################################################
## Control "Apto"
######################################################################################
Subprog C_STAL(VALEUR)
Variable Integer VALEUR

Local Integer   LNOL
Local Integer   RESULTADO1
Local Char      LSTA(5)
Local Char      LITMREFL(100) : LITMREFL  = [M:YPR0]ITMREFL(nolign-1)
Local Char      LLOTEL(100)   : LLOTEL    = [M:YPR0]LOTEL(nolign-1)
Local Integer   LLCKUID
Local Datetime  LLCKTIM
Local Char      LLCKUSR(20)

  GLCK = func SPEYLIB0.SEARCH_LCKPRR(LITMREFL,LLOTEL)
  If !GLCK Then
    If VALEUR = 2 Then
      LNOL = nolign-1
      [M:YPR0]STNAL(LNOL) = 1
      Call GENERA_FICHSALIDA(LNOL,RESULTADO1)
      Call GENERA_FICHENTRADA("A",LNOL,RESULTADO1)
      LSTA = "A"
      Gosub GENERA_TRAZA
    Endif
    Gosub BUSCAR
  Else
    Call GET_IDLCK(LITMREFL,LLOTEL,LLCKUID,LLCKUSR,LLCKTIM) From SPEYLIB0
    If num$(LLCKUID) <> "" Then
      Local Char LERRTIT(50)  : LERRTIT = "Registro bloqueado"
      Local Char LERRTEX(150) : LERRTEX = "Artículo:"-LITMREFL+"\Lote:"-LLOTEL+"\Usuario bloqueo:"-toupper(LLCKUSR)+"\Fecha bloqueo:"-num$(LLCKTIM)
      Call ERRTIT(LERRTEX,LERRTIT) From GESECRAN
      VALEUR = 0
      mkstat = 2
    Endif
  Endif

  If dim(LNOL)        > 0  Then : Kill LNOL         : Endif
  If dim(LRESULTADO1) > 0  Then : Kill LRESULTADO1  : Endif
  If dim(LSTA)        > 0  Then : Kill LSTA         : Endif
  If dim(LITMREFL)    > 0  Then : Kill LITMREFL     : Endif
  If dim(LLOTEL)      > 0  Then : Kill LLOTEL       : Endif
  If dim(LLCKUID)     > 0  Then : Kill LLCKUID      : Endif
  If dim(LLCKTIM)     > 0  Then : Kill LLCKTIM      : Endif
  If dim(LLCKUSR)     > 0  Then : Kill LLCKUSR      : Endif

End

######################################################################################
## Control "No Apto"
######################################################################################
Subprog C_STNAL(VALEUR)
Variable Integer VALEUR

Local Integer   RESULTADO2
Local Char      LSTA(5)
Local Integer   LNOL          : LNOL      = nolign-1
Local Char      LITMREFL(100) : LITMREFL  = [M:YPR0]ITMREFL(nolign-1)
Local Char      LLOTEL(100)   : LLOTEL    = [M:YPR0]LOTEL(nolign-1)
Local Integer   LLCKUID
Local Datetime  LLCKTIM
Local Char      LLCKUSR(20)

  GLCK = func SPEYLIB0.SEARCH_LCKPRR(LITMREFL,LLOTEL)
  If !GLCK Then
    If VALEUR = 2 Then
      [M:YPR0]STAL(nolign-1) = 1
      Call GENERA_FICHSALIDA(LNOL,RESULTADO2)
      Call GENERA_FICHENTRADA("R",LNOL,RESULTADO2)
      LSTA = "R"
      Gosub GENERA_TRAZA
    Endif
    Gosub BUSCAR
  Else
    Call GET_IDLCK(LITMREFL,LLOTEL,LLCKUID,LLCKUSR,LLCKTIM) From SPEYLIB0
    If num$(LLCKUID) <> "" Then
      Local Char LERRTIT(50)  : LERRTIT = "Registro bloqueado"
      Local Char LERRTEX(150) : LERRTEX = "Artículo:"-LITMREFL+"\Lote:"-LLOTEL+"\Usuario bloqueo:"-toupper(LLCKUSR)+"\Fecha bloqueo:"-num$(LLCKTIM)
      Call ERRTIT(LERRTEX,LERRTIT) From GESECRAN
      VALEUR = 0
      mkstat = 2
    Endif
  Endif

  If dim(LNOL)        > 0  Then : Kill LNOL         : Endif
  If dim(LRESULTADO2) > 0  Then : Kill LRESULTADO2  : Endif
  If dim(LSTA)        > 0  Then : Kill LSTA         : Endif
  If dim(LITMREFL)    > 0  Then : Kill LITMREFL     : Endif
  If dim(LLOTEL)      > 0  Then : Kill LLOTEL       : Endif
  If dim(LLCKUID)     > 0  Then : Kill LLCKUID      : Endif
  If dim(LLCKTIM)     > 0  Then : Kill LLCKTIM      : Endif
  If dim(LLCKUSR)     > 0  Then : Kill LLCKUSR      : Endif

End

######################################################################################
## Botón 1 - Seleccionar todos los registros de grid 'Estados'
######################################################################################
Subprog B1_NBSTA
Local Integer LCON5 : Raz LCON5

  For LCON5 = 0 To [M:YPR0]NBSTA-1
    [M:YPR0]SELSTA(LCON5) = 2
    Affzo [M:YPR0]SELSTA(LCON5)
  Next
If dim(LCON5) > 0  Then : Kill LCON5 : Endif
End

######################################################################################
## Botón 2 - Desmarcar todos los registros de grid 'Estados'
######################################################################################
Subprog B2_NBSTA
Local Integer LCON5 : Raz LCON5

  For LCON5 = 0 To [M:YPR0]NBSTA-1
    [M:YPR0]SELSTA(LCON5) = 1
    Affzo [M:YPR0]SELSTA(LCON5)
  Next
If dim(LCON5) > 0  Then : Kill LCON5 : Endif
End


######################################################################################
## Después de modificar 'Observaciones'
######################################################################################
Subprog AM_OBSERVA(VALEUR)
Variable Char    VALEUR()
  # inserta las observaciones en el campo de la tabla STOLOT
  Filter [F:STL0] Where ITMREF = [M:YPR0]ITMREFL(nolign-1) and LOT = [M:YPR0]LOTEL(nolign-1)
  For [F:STL0]
    Trbegin [STL0]
    [F:STL0]USRFLD1 = VALEUR
    Rewrite [F:STL0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next
  Filter [F:STL0]

  # inserta las observaciones en el campo de la tabla STOJOU
  Filter [F:STJ1] Where ITMREF = [M:YPR0]ITMREFL(nolign-1) and LOT = [M:YPR0]LOTEL(nolign-1)
  For [F:STJ1]
    Trbegin [STJ1]
    [F:STJ1]USRFLD1 = VALEUR
    Rewrite [F:STJ1]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next
  Filter [F:STJ1]

  # inserta las observaciones en el campo de la tabla STOCK
  Filter [F:STO0] Where ITMREF = [M:YPR0]ITMREFL(nolign-1) and LOT = [M:YPR0]LOTEL(nolign-1)
  For [F:STO0]
    Trbegin [STO0]
    [F:STO0]USRFLD1 = VALEUR
    Rewrite [F:STO0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next
  Filter [F:STO0]

End

######################################################################################
## Después de modificar 'Notas'
######################################################################################
Subprog AM_NOTAS(VALEUR)
Variable Char    VALEUR()

  # inserta las notas en el campo de la tabla STOLOT
  Filter [F:STL0] Where ITMREF = [M:YPR0]ITMREFL(nolign-1) and LOT = [M:YPR0]LOTEL(nolign-1)
  Read   [F:STL0] First
  If !fstat Then
    Trbegin [STL0]
    [F:STL0]USRFLD2 = VALEUR
    Rewrite [F:STL0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif
  Filter [F:STL0]

  # inserta las notas en el campo de la tabla STOJOU
  Filter [F:STJ1] Where ITMREF = [M:YPR0]ITMREFL(nolign-1) and LOT = [M:YPR0]LOTEL(nolign-1)
  Read   [F:STJ1] First
  If !fstat Then
    Trbegin [STJ1]
    [F:STJ1]USRFLD2 = VALEUR
    Rewrite [F:STJ1]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif
  Filter [F:STJ1]

End

######################################################################################
## Después de modificar 'Observaciones recepción'
######################################################################################
Subprog AM_OBSRECEP(VALEUR)
Variable Char    VALEUR()

  Filter [F:ACB0] Where CODBLB = "CO_PTH" and IDENT1 = [M:YPR0]PTHNUM(nolign-1)
  Read   [F:ACB0] First
  If !fstat Then
    Trbegin [ACB0]
    [F:ACB0]CLOB = "{\rtf1\ansi{\fonttbl{\f0 MS Sans Serif;}}\uc0\pard\fs24 " + VALEUR + "\fs24\par}"
    Rewrite [F:ACB0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif
  Filter [F:ACB0]

End

######################################################################################
## Después de modificar el campo 'Desde proveedor'
######################################################################################
Subprog AM_STRBPS(VALEUR)
Variable Char    VALEUR()
  If [M:YPR0]ENDBPS = "" Then
    [M:YPR0]ENDBPS = VALEUR
    Affzo [M:YPR0]ENDBPS
  Endif
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
###############################################################
#######################
#**
#* genera el fichero y realiza la importación de salida de stock
#*
#* @param PERROR1  > devuelve el estado de la importación  PERROR1=1 -> éxito ; PERROR1<>1 -> error
#*!
Subprog GENERA_FICHSALIDA(YNOL, PERROR1)
Value     Integer YNOL
Variable  Integer PERROR1

Local Char LDIRIMPORT1(250) : LDIRMPORT1 = filpath("IMPORT_EXPORT\PARRILLAS\Mov_Parrillas","","")
Global Char LFILE_W1(200) : LFILE_W1 = "\CambioStockSalidaPR"
Local Char LDATCAB1(100)(9), LDATLINL1(100)(8), LDATLINS1(100)(12)
Local Char LFECHA1(10), LHORA1(10) : Raz LFECHA1, LHORA1
Local Char LSEP1(1) : LSEP1 = ";"  # separador

  LFECHA1 = vireblc(num$(date$),4) : LFECHA1 = mid$(LFECHA1,1,2)+mid$(LFECHA1,4,2)+mid$(LFECHA1,7,4)
  LHORA1  = vireblc(num$(time$),4) : LHORA1  = mid$(LHORA1,1,2)+mid$(LHORA1,4,2)+mid$(LHORA1,7,2)

  LFILE_W1 = LDIRMPORT1 + LFILE_W1 + "_" + LFECHA1 + LHORA1 + ".txt"

  # borramos el fichero si existe...
  If filinfo(LFILE_W1, 7) > 0 Then
    System "ae_rm " + LFILE_W1
  Endif

#  Sleep 1

  # abrir el fichero para escritura
  Gosub OPEN_FILE_W1

  # datos de cabecera movimiento
  Raz LDATCAB1
  LDATCAB1(0)  = "E"                                           # Inidicador
  LDATCAB1(1)  = num$(20)                                      # Tipo de asiento
  LDATCAB1(2)  = ""                                            # Número de asiento
  LDATCAB1(3)  = [M:YPR0]POHFCY(YNOL)                          # Planta stock
  LDATCAB1(4)  = [M:YPR0]ENTDAT(YNOL)                          # Fecha imputación
  LDATCAB1(5)  = "CAMBIO STOCK Q->A DESDE PR"                  # Descripción
  LDATCAB1(6)  = ""                                            # Proyecto
  LDATCAB1(7)  = ""                                            # Código movimiento
  LDATCAB1(8)  = "030"                                         # Código familia

  # datos de línea movimiento
  Raz LDATLINL1
  LDATLINL1(0) = "L"                                           # Indicador
  LDATLINL1(1) = num$(1000)                                    # Número de línea de asiento
  LDATLINL1(2) = [M:YPR0]ITMREFL(YNOL)                         # Código de artículo
  LDATLINL1(3) = [M:YPR0]ITMDESL(YNOL)                         # Descripción 1
  LDATLINL1(4) = [M:YPR0]PCUL(YNOL)                            # Unidad
  LDATLINL1(5) = num$([M:YPR0]QTY(YNOL))                       # Cantidad
  LDATLINL1(6) = [M:YPR0]PCUL(YNOL)                            # Unidad Stock
  LDATLINL1(7) = num$([M:YPR0]QTY(YNOL))                       # Cantidad US

  # datos stock
  Raz LDATLINS1
  LDATLINS1(0) = "S"                                           # Indicador
  LDATLINS1(1) = [M:YPR0]PCUL(YNOL)                            # Unidad
  LDATLINS1(2) = num$([M:YPR0]QTY(YNOL) * -1)                  # Cantidad
  LDATLINS1(3) = [M:YPR0]LOTEL(YNOL)                           # Lote
  LDATLINS1(4) = ""                                            # S/Lote
  LDATLINS1(5) = ""                                            # Número contenedor
  LDATLINS1(6) = [M:YPR0]LOCL(YNOL)                            # Ubicación
  LDATLINS1(7) = [M:YPR0]ESTADO(YNOL)                          # Estado
  LDATLINS1(8) = ""                                            # Serie
  LDATLINS1(9) = [M:YPR0]OBSERVA(YNOL)                         # Observaciones
  LDATLINS1(10)= [M:YPR0]REFERENCIA(YNOL)                      # Referencia
  LDATLINS1(11)= [M:YPR0]SHLDAT(YNOL)                          # Caducidad

  # datos de cabecera movimiento
    Wrseq LDATCAB1(0) + LSEP1 + LDATCAB1(1) + LSEP1 + LDATCAB1(2) + LSEP1 + LDATCAB1(3) + LSEP1 + LDATCAB1(4) + LSEP1 +
&         LDATCAB1(5) + LSEP1 + LDATCAB1(6) + LSEP1 + LDATCAB1(7) + LSEP1 + LDATCAB1(8) Using [ZIMP_W1]

  # datos de línea movimiento
    Wrseq LDATLINL1(0) + LSEP1 + LDATLINL1(1) + LSEP1 + LDATLINL1(2) + LSEP1 + LDATLINL1(3) + LSEP1 + LDATLINL1(4) + LSEP1 + LDATLINL1(5) + LSEP1 +
&   LDATLINL1(6) + LSEP1 + LDATLINL1(7) Using [ZIMP_W1]

  # datos stock
    Wrseq LDATLINS1(0) + LSEP1 + LDATLINS1(1) + LSEP1 + LDATLINS1(2) + LSEP1 + LDATLINS1(3) + LSEP1 + LDATLINS1(4) + LSEP1 + LDATLINS1(5) + LSEP1 +
&   LDATLINS1(6) + LSEP1 + LDATLINS1(7) + LSEP1 + LDATLINS1(8) + LSEP1 + LDATLINS1(9) + LSEP1 + LDATLINS1(10) + LSEP1 + LDATLINS1(11) Using [ZIMP_W1]

  Gosub CLOSE_FILE_W1

End

###############################################################
#######################
#**
#* genera el fichero y realiza la importación de entrada de stock (A o R según parámetro de entrada)
#*
#* @param PESTADO  > tipo de estado final (A o R)
#* @param PERROR2  > devuelve el estado de la importación  PERROR2=1 -> éxito ; PERROR2<>1 -> error
#*!
Subprog GENERA_FICHENTRADA(PESTADO, YNOL, PERROR2)
Value     Char PESTADO
Value     Integer YNOL
Variable  Integer PERROR2

Local Char LDIRMPORT2(250) : LDIRMPORT2 = filpath("IMPORT_EXPORT\PARRILLAS\Mov_Parrillas","","")
Global Char LFILE_W2(200) : LFILE_W2 = "\CambioStockEntradaPR"
Local Char LDATCAB2(100)(9), LDATLINL2(100)(9), LDATLINS2(100)(14)
Local Char LFECHA2(10), LHORA2(10) : Raz LFECHA2, LHORA2
Local Char LSEP2(1) : LSEP2 = ";"  # separador

  LFECHA2 = vireblc(num$(date$),4) : LFECHA2 = mid$(LFECHA2,1,2)+mid$(LFECHA2,4,2)+mid$(LFECHA2,7,4)
  LHORA2  = vireblc(num$(time$),4) : LHORA2  = mid$(LHORA2,1,2)+mid$(LHORA2,4,2)+mid$(LHORA2,7,2)

  LFILE_W2 = LDIRMPORT2 + LFILE_W2 + "_" + LFECHA2 + LHORA2 + ".txt"

  # borramos el fichero si existe...
  If filinfo(LFILE_W2, 7) > 0 Then
    System "ae_rm " + LFILE_W2
  Endif

#  Sleep 1

  # abrir el fichero para escritura
  Gosub OPEN_FILE_W2

  # datos de cabecera movimiento
  Raz LDATCAB2
  LDATCAB2(0)  = "E"                                           # Inidicador
  LDATCAB2(1)  = num$(19)                                      # Tipo de asiento
  LDATCAB2(2)  = ""                                            # Número de asiento
  LDATCAB2(3)  = [M:YPR0]POHFCY(YNOL)                          # Planta stock
  LDATCAB2(4)  = [M:YPR0]ENTDAT(YNOL)                          # Fecha imputación
  If PESTADO = "A" Then
    LDATCAB2(5)  = "CAMBIO STOCK Q->A DESDE PR"                # Descripción
  Elsif PESTADO = "R" Then
    LDATCAB2(5)  = "CAMBIO STOCK Q->R DESDE PR"                # Descripción
  Endif
  LDATCAB2(6)  = ""                                            # Proyecto
  LDATCAB2(7)  = ""                                            # Código movimiento
  LDATCAB2(8)  = "030"                                         # Código familia

  # datos de línea movimiento
  Raz LDATLINL2
  LDATLINL2(0) = "L"                                           # Indicador
  LDATLINL2(1) = num$(1000)                                    # Número de línea de asiento
  LDATLINL2(2) = [M:YPR0]ITMREFL(YNOL)                         # Código de artículo
  LDATLINL2(3) = [M:YPR0]ITMDESL(YNOL)                         # Descripción 1
  LDATLINL2(4) = [M:YPR0]PCUL(YNOL)                            # Unidad
  LDATLINL2(5) = num$([M:YPR0]QTY(YNOL))                       # Cantidad
  LDATLINL2(6) = [M:YPR0]PCUL(YNOL)                            # Unidad Stock
  LDATLINL2(7) = num$([M:YPR0]QTY(YNOL))                       # Cantidad US
  LDATLINL2(8) = num$(0)                                       # Precio pedido

  # datos stock
  Raz LDATLINS2
  LDATLINS2(0) = "S"                                           # Indicador
  LDATLINS2(1) = [M:YPR0]PCUL(YNOL)                            # Unidad
  LDATLINS2(2) = num$([M:YPR0]QTY(YNOL))                       # Cantidad
  LDATLINS2(3) = [M:YPR0]BPSLOTEL(YNOL)                        # Lote proveedor
  LDATLINS2(4) = [M:YPR0]LOTEL(YNOL)                           # Lote
  LDATLINS2(5) = ""                                            # S/Lote
  LDATLINS2(6) = ""                                            # Número contenedor
  LDATLINS2(7) = [M:YPR0]LOCL(YNOL)                            # Ubicación
  LDATLINS2(8) = PESTADO                                       # Estado
  LDATLINS2(9) = ""                                            # Serie
  LDATLINS2(10)= [M:YPR0]OBSERVA(YNOL)                         # Observaciones
  LDATLINS2(11)= [M:YPR0]REFERENCIA(YNOL)                      # Referencia
  LDATLINS2(12)= [M:YPR0]SHLDAT(YNOL)                          # Caducidad
  LDATLINS2(13)= "Q->A DESDE PR "                              # Descripción mvto.

  # datos de cabecera movimiento
    Wrseq LDATCAB2(0) + LSEP2 + LDATCAB2(1) + LSEP2 + LDATCAB2(2) + LSEP2 + LDATCAB2(3) + LSEP2 + LDATCAB2(4) + LSEP2 +
&         LDATCAB2(5) + LSEP2 + LDATCAB2(6) + LSEP2 + LDATCAB2(7) + LSEP2 + LDATCAB2(8) Using [ZIMP_W2]

  # datos de línea movimiento
    Wrseq LDATLINL2(0) + LSEP2 + LDATLINL2(1) + LSEP2 + LDATLINL2(2) + LSEP2 + LDATLINL2(3) + LSEP2 + LDATLINL2(4) + LSEP2 + LDATLINL2(5) + LSEP2 +
&   LDATLINL2(6) + LSEP2 + LDATLINL2(7) + LSEP2 + LDATLINL2(8) Using [ZIMP_W2]

  # datos stock
    Wrseq LDATLINS2(0) + LSEP2 + LDATLINS2(1) + LSEP2 + LDATLINS2(2) + LSEP2 + LDATLINS2(3) + LSEP2 + LDATLINS2(4) + LSEP2 + LDATLINS2(5) + LSEP2 +
&   LDATLINS2(6) + LSEP2 + LDATLINS2(7) + LSEP2 + LDATLINS2(8) + LSEP2 + LDATLINS2(9) + LSEP2 + LDATLINS2(10) + LSEP2 + LDATLINS2(11) + LSEP2 + LDATLINS2(12)
&   + LSEP2 + LDATLINS2(13) Using [ZIMP_W2]

  Gosub CLOSE_FILE_W2

End
