#<AdxTL>@(#)0.0.0.0 $Revision$ 
########################################################
### Entregas: asignar stock proveniente de XSGA.	####
### LALL = tipo de asignación (2-->detallada)
### LFCY = planta
### LITM = artículo
### LCHR = crono stock (STOCOU)
### LDAT = fecha fin de reserva
### LQTY = cantidad en unidades de stock
### LQTA = cantidad activa
### LTYP = tipo de documento (2--> pedido venta /4--> entrega)
### LNUM = nº documento
### LLIN = nº línea del documento
### LSEQ = nº secuencia del documento
### LPRE = nº preparación
### LDTE = fecha de necesidad
### LLOT = lote
### LSLO = sublote
### LSTA = estado
### LLOC = ubicación
### LSER = nº serie
### LDTE = depósito
### LALLQTY = ctdad.asignada en unidades de stock
### LALLQTA = ctdad. activa asignada
### LDEFLOC = ubicación de consumo
### LDEFLOCTYP = tipo de ubicación de consumo
### LBPR = tercero (si hay subcontratación)
### LADD = dirección de entrega (si hay subcontratación)
### LSCO = subcontratación
### LECC = versión principal (si hay ruptura)
### LRET = Code retour (0=OK / 1=Erreur)
########################################################
Subprog ASIGNARSTOCK(TIPASIG,PLANTA,ARTICULO,STOCOU,CTDAD,TIPASIENTO,PEDIDO,LINEA,SECUENCIA,LOTE,ESTADO,UBICACION,LRET)
	Value Integer TIPASIG
	Value Char PLANTA     
	Value Char ARTICULO
	Value Decimal STOCOU
	Value Decimal CTDAD
	Value Integer TIPASIENTO
	Value Char PEDIDO
	Value Integer LINEA
	Value Integer SECUENCIA
	Value Char LOTE
	Value Char ESTADO
	Value Char UBICACION
	
	Variable Integer  LRET

	Local Date LDAT : LDAT = [0/0/0]
	Local Decimal LQTA : LQTA  = CTDAD
	Local Char LPRE : LPRE = "" 
	Local Date LDTE : LDTE = [0/0/0]  
	Local Char LSLO : LSLO = "" 
	Local Char LSER : LSER = "" 
	Local Char LWRH : LWRH = "" 
	Local Decimal LALLQTY : LALLQTY = CTDAD
	Local Decimal LALLQTA : LALLQTY = CTDAD
	Local Char LDEFLOC : LDEFLOC = "" 
	Local Char LDEFLOCTYP : LDEFLOCTYP = "" 
	Local Char LBPR : LBPR = "" 
	Local Char LADD : LADD = "" 
	Local Integer LSCO : LSCO = 0 
	Local Char LECC : LECC = "" 

Call CREALL(TIPASIG,PLANTA,ARTICULO,STOCOU,LDAT,CTDAD,LQTA,TIPASIENTO,PEDIDO,LINEA,SECUENCIA,
&              LPRE,LDTE,LOTE,LSLO,ESTADO,UBICACION,LSER,LWRH,LALLQTY,LALLQTA,
&              LDEFLOC,LDEFLOCTYP,LBPR,LADD,LSCO,LECC,LRET) From STKALL

End

#######################################################################################
#### Modificar una asignación de stock.						#######
#######################################################################################
Subprog DESASIGSTOCK(PLANTA,ARTICULO,STOCOU,NUMSEQ,CTDAD,LRET)
	Value Char PLANTA     
	Value Char ARTICULO
	Value Decimal STOCOU
	Value Integer NUMSEQ
	Value Decimal CTDAD
	
	Variable Integer  LRET
	
	Call MODALL(PLANTA,ARTICULO,STOCOU,NUMSEQ,CTDAD,LRET) From STKALL

End

######################################################################################
#### Eliminar una asignación de stock sin detalle.				######	
#### LOPT=0--> elimina rupturas y asignaciones.	1--> elimina sólo rupturas	######
######################################################################################
Subprog DELASIG(TIPDOC,PEDIDO,LINEA,SECUENCIA,ARTICULO,CTDAD,LQTA,LSHT,LRET)
	Value Integer TIPDOC
	Value Char PEDIDO
	Value Integer LINEA
	Value Integer SECUENCIA
	Value Char ARTICULO
	Value Decimal CTDAD
	
	Local Integer LOPT : LOPT = 0
	
	Variable Decimal LQTA		#total asignado a restar	
	Variable Decimal LSHT		#total en ruptura a restar
	Variable Integer LRET
	
	Call DIMALL(TIPDOC,PEDIDO,LINEA,SECUENCIA,ARTICULO,LOPT,CTDAD,LQTA,LSHT,LRET) From STKALL
	
End










