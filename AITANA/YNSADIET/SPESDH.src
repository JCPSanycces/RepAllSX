#<AdxTL>@(#)0.0.0.0 $Revision$ Entregas
# Gestión de la máscara SDH2 (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla SDH2) 07/12/2020 16:32:28 (AIT04)
######################################################################################
$ACTION
Case ACTION
 When "FILTRE"		: Gosub FILTRE
 When "APRES_CRE"   : Gosub APRES_CRE
Endcase
Return

#####################################
$FILTRE
# Muestro entregas en función de la transacción
Local Char NEW_FILT(200) : NEW_FILT = "1=1"
Gosub FILTRE From SUBSDHA

Case GFLAG
  When "LM01"  :  NEW_FILT += " & [F:SDH]SDHTYP='AMV'"      # La Mancha
  When "YN01"  :  NEW_FILT += " & [F:SDH]SDHTYP='APV'"      # Ynsadiet
  When "YN02"  :  NEW_FILT += " & 1=1"                      # Logística (todas)
  When "YN03"  :  NEW_FILT += " & [F:SDH]SDHTYP='ACV'"      # Canarias
  When "YN04"  :  NEW_FILT += " & left$([F:SDH]SDHTYP,3)='TPV'"      # Comerzzia
Endcase

FILTSUP = NEW_FILT + " & (" + FILTSUP + ")"

GPE = 1
Return

#############################################################################
$APRES_CRE
	#Borrar los registros de las tablas temporales de la pda.
	Gosub APRES_CRE From SUBSDHA
	GPE=1
	
	If !clalev([F:ZLP])  Local File ZLINPEDTMP  [ZLP] : Endif
	If !clalev([F:ZEC])  Local File ZTMPENTREGAC  [ZEC] : Endif
	If !clalev([F:ZED])  Local File ZTMPENTREGAD  [ZED] : Endif
	
	If [M:SDH0]SOHNUM <> ''
		Delete [ZLP] Where SOHNUM = [M:SDH0]SOHNUM
		Delete [ZED] Where SOHNUM = [M:SDH0]SOHNUM
		Delete [ZEC] Where SOHNUM = [M:SDH0]SOHNUM
	Endif
	
Return

######################################################################################
Subprog AM_YDESTINO(VALEUR)
Variable Char    VALEUR()
Read [BPD]BPD0=[M:SDH0]BPCORD;VALEUR
If fstat = 0
  [M:SDH2]YEMPRESA  = [BPD]YEMPRESA
  [M:SDH2]YSUCURSAL = [BPD]YSUCURSAL
  Affzo [M:SDH2]YEMPRESA
  Affzo [M:SDH2]YSUCURSAL
Endif
End
