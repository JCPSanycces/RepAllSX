#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION

#If GUSER="AIT07" Then : Infbox "2"-ACTION : Endif
Case ACTION
  When "CLECUR"     Gosub CLECUR
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$CLECUR
Local Integer I

  For I = 0 To [M:SDE2]NBLIG-1
    [M:SDE2]YUSRFLD3(I) = func GET_YUSRFLD3([M:SDE1]ITMREF,[M:SDE2]STOCOU(I),[M:SDE2]LOT(I))
  Next
  Affzo [M:SDE2]5

Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ABRIR_TABLAS
#  If !clalev([F:SLH0]) Then : Local File SLOTMH [F:SLH0] : Endif
  If !clalev([F:STO0]) Then : Local File STOCK  [F:STO0] : Endif
#  If !clalev([F:STJ0]) Then : Local File STOJOU [F:STJ0] : Endif
#  If !clalev([F:STL0]) Then : Local File STOLOT [F:STL0] : Endif
Return

##############################################################
$CERRAR_TABLAS
#  If clalev([F:SLH0])  Then : Close Local File  [F:SLH0] : Endif
  If clalev([F:STO0])  Then : Close Local File  [F:STO0] : Endif
#  If clalev([F:STJ0])  Then : Close Local File  [F:STJ0] : Endif
#  If clalev([F:STL0])  Then : Close Local File  [F:STL0] : Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

Funprog GET_YUSRFLD3(PITMREF,PSTOCOU,PLOT)
Value Char    PITMREF
Value Decimal PSTOCOU
Value Char    PLOT

Local Char  FILTRO(250)
Local Char  LRES(250)

  Gosub ABRIR_TABLAS

# opción de filtro 1 (artículo, lote)
  FILTRO =  "ITMREF=PITMREF and LOT=PLOT and STOFCY=[M:SDE1]FCY and STOCOU=PSTOCOU"

  # muestra el campo 'Comentario 3' de la tablas STOCK
  Filter [F:STO0] Where evalue(FILTRO)
  Read [F:STO0] First
  If !fstat Then
    LRES = [F:STO0]YUSRFLD3
  Endif
  Filter [F:STO0]

  Gosub CERRAR_TABLAS

#  Call AM_YUSRFLD3(LRES) From SPECNSSDE

Kill FILTRO

End LRES
