#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# CNSCSDSTD : Consultation des livraisons ventes                        #
# ECRAN 1   : CONSCSD1                                                  #
# ECRAN 2   : CONSCSD2                                                  #
# ECRAN CRIT: CRITCSD                                                   #
#########################################################################
#YYN45: MODIFICACIONES YNSADIET
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "FIN_CRIT"   : Gosub FIN_CRIT
 When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$SETBOUT
# ------------------------------------------------------------------------------------- #
# Activation/Désactivation des menus                                                    #
# ------------------------------------------------------------------------------------- #
# B : HT/Catégorie             : Actif                                                  #
# C : HT Facturé               : Actif                                                  #
# D : HT Retourné              : Actif                                                  #
# E : Répartition Motif retour : Actif                                                  #
# ------------------------------------------------------------------------------------- #

If [M:CSD2]NBLIG>0 CHMEN += "BCDE" Endif

Return
###########################################################################################
#    Après execution des menus                                                            #
###########################################################################################
$EXEBOUT

Case BOUT
    When "B", "C", "D", "E" :
#        OK=1 : CHANGE=1 : # Pour déclencher un réaffichage de la consultation
        [M:CSD1]DLVDATDEB=[M:CCSD]DLVDATDEB : # Pour restituer les critères de date de départ
        [M:CSD1]DLVDATFIN=[M:CCSD]DLVDATFIN
Endcase

Return
###################################################################
# analyse paramères, initialisations, ouvertures et déclarations  #
###################################################################
$OUVRE
Local Char    WFIL(250),WFIL1(250),WFIL2(250)
Local Char    DEBNUM, FINNUM
Local Date    DEBDAT, FINDAT

NAVIG="CONSCSD"

Gosub DEFCRIT
[M:CSD1]CURD=GSYSCUR
Return
# --------------------------------------------------------------------------#
# Analyse paramères, initialisations                                        #
# --------------------------------------------------------------------------#
$DEFCRIT

If [M:CSD1]STOFCY<>"" & GUSRFCY(1)<>"\" & !find([M:CSD1]STOFCY,GUSRFCY(1..GNBAUZ))
 [M:CSD1]STOFCY=""
Endif

For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre Client
      If PARAM(I) <> ""
        If [F:BPC]BPCNUM<>PARAM(I) Read [F:BPC]BPC0=PARAM(I)
                                     If fstat
                                        Raz [F:BPC], PARAM(I)
                                     Endif
        Endif
        [M:CSD1]BPCORD = PARAM(I)
      Endif
    When 2 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)    Read [F:FCY]FCY0 = PARAM(I)
                                     If fstat
                                       Raz [F:FCY], PARAM(I)
                                     Endif
        Endif
        If GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ))
           [M:CSD1]STOFCY = PARAM(I)
           If [M:CSD1]STOFCY <> ""
             Call GETDEV([M:CSD1]STOFCY) From DEVSUB
             [M:CSD1]CPY  = GSOCIETE
             [M:CSD1]CURS = GLOCALDEV
           Endif
        Endif
      Endif
  Endcase
Next I

If !find([M:CSD1]LNDO,1,2)    : [M:CSD1]LNDO = 2 : Endif
If !find([M:CSD1]LNDN,1,2)    : [M:CSD1]LNDN = 2 : Endif
If !find([M:CSD1]SCOFLG,1,2)  : [M:CSD1]SCOFLG = 2  : Endif  :#--CPO 75115
If !find([M:CSD1]NONINV,1,2)  : [M:CSD1]NONINV = 2  : Endif  :# X3-1152 : Non invoiceable deliveries
If !find([M:CSD1]CFMFLGO,1,2) : [M:CSD1]CFMFLGO = 2 : Endif
If !find([M:CSD1]CFMFLGN,1,2) : [M:CSD1]CFMFLGN = 2 : Endif
If !find([M:CCSD]INVFLGO,1,2) : [M:CCSD]INVFLGO = 2 : Endif
If !find([M:CCSD]INVFLGN,1,2) : [M:CCSD]INVFLGN = 2 : Endif
If !find([M:CCSD]RTNFLGO,1,2) : [M:CCSD]RTNFLGO = 2 : Endif
If !find([M:CCSD]RTNFLGN,1,2) : [M:CCSD]RTNFLGN = 2 : Endif
If !find([M:CCSD]TRI,1,2)     : [M:CCSD]TRI = 1   : Endif

[M:CSD1]DLVDATFIN=eomonth(date$)
[M:CSD1]DLVDATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))

# -- copie de l'écran critères (CCSD) vers le masque 1 (CSD1)
Gosub CRITENT From =PROGCNS

Return

############################################################
$LECTURE
Local   Decimal  WMNTORG(0..5), WMNTDES(0..5)
Local   Integer  SPSTAT

# Mail CH : 03/03/04
#If [M:CSD1]CPY="" & [M:CSD1]STOFCY=""
# NBLU=0 : Return
#Endif

  # FGR 21/10/2009 : X3SUIVI56101
  If GPILNAV > 1 Then
    #acces depuis clients ou tiers
    If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC") Then
      Diszo [M:CSD1]BPCORD
    Endif

    # GRNA 16/05/2011
    Local Char CUSSEAORI : CUSSEAORI = "CSD1"
    Gosub LECTURE From CUSSEALIB
  Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif
#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #
#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCSD]TRI
      When 1 : # tri par numéro
        Filter [SDH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SDH0
      When 2 : # tri par date
        Filter [SDH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                    Order By Key SDH2
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCSD]TRI
      When 1 : # tri par numéro
        Filter [SDH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SDH0 Desc
      When 2 : # tri par date
        Filter [SDH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                    Order By Key SDH2 Desc
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CSD2] : Endif
#-- lecture
$BOUCLE
For [SDH] With Nohint

      #YYN45. Si tengo marcado Facturacion mensual, compruebo si el cliente lo tiene así parametrizado
      If [M:CSD1]YMENSUAL = 2
        Read [BPC]BPC0 = [F:SDH]BPCINV
        If fstat = 0
          If [BPC]IME = 5 and [BPC]INVPER = 6

          Else
            Goto SUIV
          Endif
        Endif
      Endif
      #YYN45 FIN

# Filtre sur la société
  If [M:CSD1]CPY <> ""
      If [F:FCY]FCY <> [F:SDH]STOFCY Read [F:FCY]FCY0 = [F:SDH]STOFCY
                                     If fstat  Raz [F:FCY] : Endif
                                     Endif
      If [F:FCY]LEGCPY <> [M:CSD1]CPY Goto SUIV : Endif
  Endif

  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:CSD2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
     NOL    += 1
     If NOL=0
         DEBNUM = [F:SDH]SDHNUM
         DEBDAT = [F:SDH]DLVDAT
     Endif
     FINNUM = [F:SDH]SDHNUM
     FINDAT = [F:SDH]DLVDAT
  Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
     NOL    -= 1
     If NOL=MAXLIG-1
         FINNUM = [F:SDH]SDHNUM
         FINDAT = [F:SDH]DLVDAT
     Endif
     DEBNUM = [F:SDH]SDHNUM
     DEBDAT = [F:SDH]DLVDAT
  Endif



Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCSD]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:SDH]SDHNUM>=DEBNUM"
       When 2 : # tri par date
           WFIL += "&[F:SDH]DLVDAT>=DEBDAT"
     Endcase
   When 2 : # suite
     Case [M:CCSD]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:SDH]SDHNUM>FINNUM"
       When 2 : # tri par date
           WFIL += "&[F:SDH]DLVDAT>=FINDAT & [F:SDH]SDHNUM>FINNUM"
     Endcase
   When -2 : # retour
     Case [M:CCSD]TRI
       When 1 : # tri par numéro
           WFIL += "&[F:SDH]SDHNUM<DEBNUM"
       When 2 : # tri par date
           WFIL += "&[F:SDH]DLVDAT<DEBDAT"
     Endcase
Endcase

  nolign = NOL+1
  [M:CSD2] = [F:SDH] : # Bug 63729
  [M:CSD2]SDHNUM(nolign-1)     = [F:SDH]SDHNUM
  [M:CSD2]BPCORD(nolign-1)     = [F:SDH]BPCORD
  [M:CSD2]SHIDAT(nolign-1)     = [F:SDH]SHIDAT
  [M:CSD2]DLVDAT(nolign-1)     = [F:SDH]DLVDAT
  [M:CSD2]CFMFLG(nolign-1)     = [F:SDH]CFMFLG
  [M:CSD2]INVFLG(nolign-1)     = [F:SDH]INVFLG
  [M:CSD2]LND(nolign-1)        = [F:SDH]LND
  [M:CSD2]DLVATI(nolign-1)     = [F:SDH]DLVATI
  [M:CSD2]CUR(nolign-1)        = [F:SDH]CUR
  Raz WMNTORG
#    Calcul des montants en devise société
  WMNTORG (0) = [F:SDH]DLVATI
  Call CONVERT([F:SDH]CUR, [M:CSD1]CURS, [M:CSD1]CURS, [F:SDH]CHGTYP, datesyst, WMNTORG(0), WMNTDES(0),SPSTAT) From TRTDEV
  [M:CSD2]DLVATISOC(nolign-1)  = WMNTDES (0)
#    Calcul des montants en devise dossier
  WMNTORG (0) = [F:SDH]DLVATI
  Call CONVERT([F:SDH]CUR, [M:CSD1]CURD, [M:CSD1]CURS, [F:SDH]CHGTYP, datesyst, WMNTORG(0), WMNTDES(0),SPSTAT) From TRTDEV
  [M:CSD2]DLVATIDOS(nolign-1)  = WMNTDES (0)
  [M:CSD2]BPTNUM(nolign-1)     = [F:SDH]BPTNUM
  [M:CSD2]MDL(nolign-1)        = [F:SDH]MDL
  [M:CSD2]RTNSTA(nolign-1)     = [F:SDH]RTNSTA
  If [M:CSD2]RTNSTA(nolign-1) = 0 [M:CSD2]RTNSTA(nolign-1) = 1 : Endif

  # 40127 : Return status management
  ## bug 20583 : L'état retour n'est pas géré pour les livraisons normales : on remet le champs à blanc
  #If [M:CSD2]LND(nolign-1)<>2 [M:CSD2]RTNSTA(nolign-1)=0 : Endif
  # 40127

#  If [M:CSD2]LND(nolign-1)<>2
#      Affzo [M:CSD2]RTNSTA(nolign-1)
#      Grizo [M:CSD2]RTNSTA(nolign-1)
#      Affzo [M:CSD2]RTNSTA(nolign-1)
#  Endif
  [M:CSD2]PRNNPR(nolign-1)     = [F:SDH]PRNNPR
  [M:CSD2]PRNNDE(nolign-1)     = [F:SDH]PRNNDE
  [M:CSD2]SALFCY(nolign-1)     = [F:SDH]SALFCY
  [M:CSD2]STOFCY(nolign-1)     = [F:SDH]STOFCY

  # X3-1152 : Non invoiceable deliveries
  If [F:SDH]SDHCAT=4
    [M:CSD2]NONINV(nolign-1)=2
  Else
    [M:CSD2]NONINV(nolign-1)=1
  Endif
  # X3-1152 : Non invoiceable deliveries

  $SUIV
Next
Filter [SDH]

Return
############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"

If [M:CSD1]STOFCY <> ""
    WFIL += "&[F:SDH]STOFCY=[M:CSD1]STOFCY"
Endif
#    Autorisation site
# 86749 : Ctrl Autorisation site ssi aucun site saisi (si site saisi, le ctrl a été fait à la saisie)
#If GUSRFCY(1)<>"\" & [M:CSD1]STOFCY <> "" & GNBAUZ<>GNBSITE
If GUSRFCY(1)<>"\" & [M:CSD1]STOFCY = "" & GNBAUZ<>GNBSITE
# 86749
    WFIL += "& find([F:SDH]STOFCY,GUSRFCY(1..GNBAUZ))"
Endif

If [M:CSD1]BPCORD <> ""
   WFIL += "&[F:SDH]BPCORD =[M:CSD1]BPCORD"
Endif
#--CPO 75115 Changement du filtre car nouvelle case à cocher "Sous-traitance"
#WFIL += "&[F:SDH]SCO<>2"
## Prise en compte des livraisons normales
## --> Si 1 (Non) On exclut les livraisons normales
#If [M:CSD1]LNDN = 1
#   WFIL += "&[F:SDH]LND<>1"
#Endif
## Prise en compte des livraisons de pret
## --> Si 1 (Non) On exclut les livraisons de pret
#If [M:CSD1]LNDO = 1
#   WFIL += "&[F:SDH]LND=1"
#Endif
################################################################
# catégorie de liv : normale, prêt, sous-traitance
If [M:CSD1]LNDN = 2 Then              # Normal = Oui
  If [M:CSD1]LNDO = 2 Then            # Prêt = Oui
    If [M:CSD1]SCOFLG = 2 Then        # Sous-traitance = Oui
                                      # Pas de filtre supplémentaire
      # X3-1152 : Non invoiceable deliveries
      If [M:CSD1]NONINV = 2 Then      # Nonbillable = Yes

      Else
        WFIL += "&[F:SDH]SDHCAT<>4"
      Endif
      # X3-1152 : Non invoiceable deliveries
    Else
      # X3-1152 : Non invoiceable deliveries
                                      # Sous-traitance = Non
#      WFIL += "&[F:SDH]SCO<>2"
      If [M:CSD1]NONINV = 2 Then                   # Nonbillable = Yes
         WFIL += "&[F:SDH]SCO<>2"
      Else                                         # Nonbillable = Yes
         WFIL += "&[F:SDH]SCO<>2&[F:SDH]SDHCAT<>4" # Nonbillable = Yes
      Endif
      # X3-1152 : Non invoiceable deliveries
    Endif
  Else                                # Prêt = Non
    If [M:CSD1]SCOFLG = 2 Then        # Sous-traitance = Oui
      # X3-1152 : Non invoiceable deliveries
#      WFIL += "&[F:SDH]LND<>2"
       If [M:CSD1]NONINV = 2 Then                  # Nonbillable = Yes
         WFIL += "&[F:SDH]LND<>2"
       Else                                        # Nonbillable = Yes
         WFIL += "&[F:SDH]LND<>2&[F:SDH]SDHCAT<>4" # Nonbillable = no
       Endif
      # X3-1152 : Non invoiceable deliveries
    Else                              # Sous-traitance = Non
      # X3-1152 : Non invoiceable deliveries
#     WFIL += "&[F:SDH]LND<>2&[F:SDH]SCO<>2"
      If [M:CSD1]NONINV = 2 Then                   # Nonbillable = Yes
         WFIL += "&[F:SDH]LND<>2&[F:SDH]SCO<>2"
      Else
         WFIL += "&[F:SDH]LND<>2&[F:SDH]SCO<>2&[F:SDH]SDHCAT<>4"  # Nonbillable = No
      Endif
      # X3-1152 : Non invoiceable deliveries
    Endif
  Endif
Else                                  # Normal = Non
  If [M:CSD1]LNDO = 2 Then            # Prêt = Oui
    If [M:CSD1]SCOFLG = 2 Then        # Sous-traitance = Oui
      # X3-1152 : Non invoiceable deliveries
#     WFIL += "&([F:SDH]LND=2|[F:SDH]SCO=2)"
      If [M:CSD1]NONINV = 2 Then                   # Nonbillable = Yes
        WFIL += "&([F:SDH]LND=2|[F:SDH]SCO=2|[F:SDH]SDHCAT=4)"
      Else
        WFIL += "&([F:SDH]LND=2|[F:SDH]SCO=2)"
      Endif
      # X3-1152 : Non invoiceable deliveries
    Else                              # Sous-traitance = Non
      # X3-1152 : Non invoiceable deliveries
#      WFIL += "&[F:SDH]LND=2"
       If [M:CSD1]NONINV = 2 Then     # Nonbillable = Yes
        WFIL += "&([F:SDH]LND=2|[F:SDH]SDHCAT=4)"
      Else
        WFIL += "&[F:SDH]LND=2"
      Endif
      # X3-1152 : Non invoiceable deliveries
    Endif
  Else                                # Prêt = Non
    If [M:CSD1]SCOFLG = 2 Then        # Sous-traitance = Oui
      # X3-1152 : Non invoiceable deliveries
#       WFIL += "&[F:SDH]SCO=2"
        If [M:CSD1]NONINV = 2 Then                 # Nonbillable = Yes
          WFIL += "&([F:SDH]SCO=2|[F:SDH]SDHCAT=4)"
        Else
          WFIL += "&[F:SDH]SCO=2"
        Endif
      # X3-1152 : Non invoiceable deliveries
    Else                              # Sous-traitance = Non
      # X3-1152 : Non invoiceable deliveries
#      WFIL += "&1=2"
       If [M:CSD1]NONINV = 2 Then                  # Nonbillable = Yes
          WFIL += "&[F:SDH]SDHCAT=4"
       Else
          WFIL += "&1=2"
       Endif
      # X3-1152 : Non invoiceable deliveries
    Endif
  Endif
Endif
################################################################
# Prise en compte des livraisons validées
# --> Si 1 (Non) On exclut les livraisons validées
If [M:CSD1]CFMFLGO = 1
   WFIL += "&[F:SDH]CFMFLG<>2"
Endif
# Prise en compte des livraisons non validées
# --> Si 1 (Non) On exclut les livraisons non validées
If [M:CSD1]CFMFLGN = 1
   WFIL += "&[F:SDH]CFMFLG<>1"
Endif
# Prise en compte des livraisons facturées
# --> Si 1 (Non) On exclut les livraisons facturées
If [M:CCSD]INVFLGO = 1
   WFIL += "&[F:SDH]INVFLG<>2"
Endif
# Prise en compte des livraisons non facturées
# --> Si 1 (Non) On exclut les livraisons non facturées
If [M:CCSD]INVFLGN = 1
   WFIL += "&[F:SDH]INVFLG<>1"
Endif
# Prise en compte des livraisons retournées
# --> Si 1 (Non) On exclut les livraisons retournées
If [M:CCSD]RTNFLGO = 1
   WFIL += "&[F:SDH]RTNSTA<=1"
Endif

# 40127 : Return status management
## Prise en compte des livraisons non retournées
## --> Si 1 (Non) On exclut les livraisons non retournées mais uniquement pour les liv. de prêt
##                l'état retour n'est pas géré pour les livraisons normales (tjs non retournées)
#If [M:CCSD]RTNFLGN = 1
#   WFIL += "& ([F:SDH]LND=1 | ([F:SDH]LND=2 & [F:SDH]RTNSTA>1))"
#Endif
# Prise en compte des livraisons non retournées
# --> Si 1 (Non) On exclut les livraisons non retournées
If [M:CCSD]RTNFLGN = 1
   WFIL += "& [F:SDH]RTNSTA>1"
Endif
# 40127

If [M:CCSD]SDHNUMDEB <> ""
   WFIL1 += "&[F:SDH]SDHNUM>=[M:CCSD]SDHNUMDEB"                                                    # FGR 07/07/2015 : X3SUIVI109402 : pas WFIL
Endif
If [M:CCSD]SDHNUMFIN <> ""
   WFIL1 += "&[F:SDH]SDHNUM<=[M:CCSD]SDHNUMFIN"                                                    # FGR 07/07/2015 : X3SUIVI109402 : pas WFIL
Endif

If [M:CCSD]DLVDATDEB <> [0/0/0]
   WFIL1 += "&[F:SDH]DLVDAT>=[M:CCSD]DLVDATDEB"                                                    # FGR 07/07/2015 : X3SUIVI109402 : pas WFIL
Endif
If [M:CCSD]DLVDATFIN <> [0/0/0]
   WFIL1 += "&[F:SDH]DLVDAT<=[M:CCSD]DLVDATFIN"                                                    # FGR 07/07/2015 : X3SUIVI109402 : pas WFIL
Endif

#Gbn-Fq75851
If GFONCTION<>"CONSCSD" :#--CPO Complément 75851 (critères non saisissables pour CONSCSD)
  If [M:CCSD]BETFCYFLG<>2
   WFIL1 += "&[F:SDH]BETFCY<>2"                                                                    # FGR 07/07/2015 : X3SUIVI109402 : pas WFIL
  Endif
#--CPO 75115
#  If [M:CCSD]SDHCATFLG<>2
#   WFIL += "&[F:SDH]SDHCAT<>2"
#  Endif
Endif

#--CPO 75115 Prise en compte du "Type de livraison"
#---Livraisons normalles
If [M:CSD1]LNDN=2
  If [M:CSD1]DLVTYPNOR<>"" : WFIL1 += "&(([F:SDH]SDHCAT=1 & [F:SDH]SDHTYP=[M:CSD1]DLVTYPNOR)|[F:SDH]SDHCAT<>1)" : Endif
Endif
#---Livraisons de prêt
If [M:CSD1]LNDO=2
  If [M:CSD1]DLVTYPLND<>"" : WFIL1 += "&(([F:SDH]SDHCAT=2 & [F:SDH]SDHTYP=[M:CSD1]DLVTYPLND)|[F:SDH]SDHCAT<>2)" : Endif
Endif
#---Livraison pour sous-traitance
If [M:CSD1]SCOFLG=2
  If [M:CSD1]DLVTYPSCO<>"" : WFIL1 += "&(([F:SDH]SDHCAT=3 & [F:SDH]SDHTYP=[M:CSD1]DLVTYPSCO)|[F:SDH]SDHCAT<>3)" : Endif
Endif
# X3-1152 : Non invoiceable deliveries
If [M:CSD1]NONINV=2
  If [M:CSD1]DLVTYPNIN<>"" : WFIL1 += "&(([F:SDH]SDHCAT=4 & [F:SDH]SDHTYP=[M:CSD1]DLVTYPNIN)|[F:SDH]SDHCAT<>4)" : Endif
Endif
# X3-1152 : Non invoiceable deliveries
#--/CPO

# 71065 : PJT
If [M:CSD1]PJTDEB <> ""
   WFIL1 += "&[F:SDH]PJT>=[M:CSD1]PJTDEB"
Endif
If [M:CSD1]PJTFIN <> ""
   WFIL1 += "&[F:SDH]PJT<=[M:CSD1]PJTFIN"
Endif
# 71065 : PJT

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCSD]TRI
       When 1 : # tri par numéro
           WFIL2 += "&[F:SDH]SDHNUM>=DEBNUM"                                                       # FGR 07/07/2015 : X3SUIVI109402 : pas WFIL
       When 2 : # tri par date
           WFIL2 += "&([F:SDH]DLVDAT>DEBDAT | ([F:SDH]DLVDAT=DEBDAT  & [F:SDH]SDHNUM>=DEBNUM))"    # FGR 07/07/2015 : X3SUIVI109402 : pas WFIL
     Endcase
   When 2 : # suite
     Case [M:CCSD]TRI
       When 1 : # tri par numéro
           WFIL2 += "&[F:SDH]SDHNUM>FINNUM"                                                        # FGR 07/07/2015 : X3SUIVI109402 : pas WFIL
       When 2 : # tri par date
           WFIL2 += "&([F:SDH]DLVDAT>FINDAT | ([F:SDH]DLVDAT=FINDAT  & [F:SDH]SDHNUM>FINNUM))"     # FGR 07/07/2015 : X3SUIVI109402 : pas WFIL
     Endcase
   When -2 : # retour
     Case [M:CCSD]TRI
       When 1 : # tri par numéro
           WFIL2 += "&[F:SDH]SDHNUM<DEBNUM"                                                        # FGR 07/07/2015 : X3SUIVI109402 : pas WFIL
       When 2 : # tri par date
           WFIL2 += "& ([F:SDH]DLVDAT<DEBDAT | ([F:SDH]DLVDAT=DEBDAT & [F:SDH]SDHNUM<DEBNUM))"     # FGR 07/07/2015 : X3SUIVI109402 : pas WFIL
     Endcase
Endcase

Return

############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT


Return

#############################################################################
##     Etiquettes masques CONSCSD1 & CONSCSD2 & CRITCSD                    ##
#############################################################################
############################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  [M]CURS = [F:CPY]ACCCUR : GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]STOFCY = ""
# Mail CH : 03/03/04
#  GERR=2 : GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
#  Raz [M]CURS
  [M]CURS=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
Endif
Affzo [M]CURS
End
############################################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
# -- Controle autorisation sur le site
    If GUSRFCY(1)<>"\" & !find(VALEUR,GUSRFCY(1..GNBAUZ))
        GMESSAGE=VALEUR-mess(2,104,1)   : # Vous n'avez pas les droits sur ce site
        mkstat=2 : End
    Endif
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
    [M]CURS = GLOCALDEV
    Affzo [M]CPY, ZCPY, CURS
Elsif [M]CPY = ""
    # Mail CH : 03/03/04
    #    GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    #    mkstat = 2
    [M]CURS=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif

End
########################################
Subprog IB_NBLIG
GBOUT1 = mess(54, 198,1)-[M]SDHNUM(nolign-1)
End
