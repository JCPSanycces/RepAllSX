######################################################################################
######################################################################################
Subprog SHOWHIDE(P_CPY)
Value Char P_CPY

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Local Char SHOWSIGN(1),V_FIELD(4),V_LEG(20)
[L]SHOWSIGN = ""
[L]V_FIELD  = "LA:1"

Call GETLEG(P_CPY,"",[L]V_LEG) From TRTLECLEG

If func AFNC.ACTIV("INVCA") = 1
  If func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
    Call SHOWHIDE_FIELDS(1,[M:CSI1]INVTYPFAC)
    Call SHOWHIDE_FIELDS(2,[M:CSI1]INVTYPAVO)
  Else
    [L]SHOWSIGN = "-"
    Chgfmt [M:CSI1]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
    Chgfmt [M:CSI1]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
    [M:CSI1]INVCANCAT = 1
    [M:CSI1]INVCANSTA = 1
    Chgfmt [M:CCSI]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
    Chgfmt [M:CCSI]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
    [M:CCSI]INVCANCAT = 1
    [M:CCSI]INVCANSTA = 1
  Endif

  Affzo [M:CSI1]INVCANCAT
  Affzo [M:CSI1]INVCANSTA
  Affzo [M:CCSI]INVCANCAT
  Affzo [M:CCSI]INVCANSTA
Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - END

End
######################################################################################
######################################################################################
$SETDEFAULT_VALUES

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Raz [L]V_LEG
Call GETLEG([M:CCSI]CPY,"",[L]V_LEG) From TRTLECLEG

If [L]INVCA_ON = 1 & func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
  If !find([M:CCSI]INVCANCAT,1,2) : [M:CCSI]INVCANCAT = 1 : Endif
  If !find([M:CCSI]INVCANSTA,1,2) : [M:CCSI]INVCANSTA = 1 : Endif
Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - END

Return
######################################################################################

