Subprog SHOWHIDE_FIELDS(P_DOCTYP,P_VALEUR)
Value Integer P_DOCTYP, P_VALEUR

Local Char SHOWSIGN(1),V_FIELD(4)
[L]SHOWSIGN = ""
[L]V_FIELD  = "LA:1"

# Invoice     : P_DOCTYP = 1
# Credit Memo : P_DOCTYP = 2
Case P_DOCTYP
  When 1 :
      If P_VALEUR = 1 & [M:CSI1]INVTYPAVO = 1
        [L]SHOWSIGN = "-"
        Chgfmt [M:CSI1]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
        Chgfmt [M:CSI1]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
      Elsif P_VALEUR = 2 & [M:CSI1]INVTYPAVO = 1
        Chgfmt [M:CSI1]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
        [L]SHOWSIGN = "-"
        Chgfmt [M:CSI1]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
      Elsif P_VALEUR = 1 & [M:CSI1]INVTYPAVO = 2
        Chgfmt [M:CSI1]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
        [L]SHOWSIGN = "-"
        Chgfmt [M:CSI1]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
      Else
        Chgfmt [M:CSI1]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
        Chgfmt [M:CSI1]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
      Endif

      # Issue 110582 - 2015-08-27 by BRBAN : Problem on showing the flags on the criteria window
      [L]SHOWSIGN = ""

      If P_VALEUR = 1 & [M:CCSI]INVTYPAVO = 1
        [L]SHOWSIGN = "-"
        Chgfmt [M:CCSI]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
        Chgfmt [M:CCSI]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
      Elsif P_VALEUR = 2 & [M:CCSI]INVTYPAVO = 1
        [L]SHOWSIGN = "-"
        Chgfmt [M:CCSI]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
        Chgfmt [M:CCSI]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
      Elsif P_VALEUR = 1 & [M:CCSI]INVTYPAVO = 2
        Chgfmt [M:CCSI]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
        [L]SHOWSIGN = "-"
        Chgfmt [M:CCSI]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
      Else
        Chgfmt [M:CCSI]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
        Chgfmt [M:CCSI]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
      Endif
  When 2 :
      If P_VALEUR = 1 & [M:CSI1]INVTYPFAC = 1
        [L]SHOWSIGN = "-"
        Chgfmt [M:CSI1]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
        Chgfmt [M:CSI1]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
      Elsif P_VALEUR = 2 & [M:CSI1]INVTYPFAC = 1
        Chgfmt [M:CSI1]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
        [L]SHOWSIGN = "-"
        Chgfmt [M:CSI1]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
      Elsif P_VALEUR = 1 & [M:CSI1]INVTYPFAC = 2
        Chgfmt [M:CSI1]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
        [L]SHOWSIGN = "-"
        Chgfmt [M:CSI1]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
      Else
        Chgfmt [M:CSI1]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
        Chgfmt [M:CSI1]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
      Endif

      # Issue 110582 - 2015-08-27 by BRBAN : Problem on showing the flags on the criteria window
      [L]SHOWSIGN = ""

      If P_VALEUR = 1 & [M:CCSI]INVTYPFAC = 1
        [L]SHOWSIGN = "-"
        Chgfmt [M:CCSI]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
        Chgfmt [M:CCSI]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
      Elsif P_VALEUR = 2 & [M:CCSI]INVTYPFAC = 1
        Chgfmt [M:CCSI]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
        [L]SHOWSIGN = "-"
        Chgfmt [M:CCSI]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
      Elsif P_VALEUR = 1 & [M:CCSI]INVTYPFAC = 2
        Chgfmt [M:CCSI]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
        [L]SHOWSIGN = "-"
        Chgfmt [M:CCSI]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
      Else
        Chgfmt [M:CCSI]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
        Chgfmt [M:CCSI]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
      Endif
Endcase
End
#105200 RICAR 2015/05/25 - Inv Cancelation - END
