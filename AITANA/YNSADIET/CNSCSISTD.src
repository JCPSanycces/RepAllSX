#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# CNSCSISTD : Consultation des factures ventes                          #
# ECRAN 1   : CONSCSI1                                                  #
# ECRAN 2   : CONSCSI2                                                  #
# ECRAN CRIT: CRITCSI                                                   #
#########################################################################
#YYN45: MODIFICACIONES YNSADIET
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "DEB_CRIT"   : Gosub DEB_CRIT
 When Default
Endcase
Return

############################################################
$AUTORIS
Return
###########################################################################################
#    Après execution des menus                                                            #
###########################################################################################
$EXEBOUT

Case BOUT
    When "B", "C", "D", "E", "F" :
#        OK=1 : CHANGE=1 : # Pour déclencher un réaffichage de la consultation
        [M:CSI1]INVDATDEB=[M:CCSI]INVDATDEB : # Pour restituer les critères de date de départ
        [M:CSI1]INVDATFIN=[M:CCSI]INVDATFIN
Endcase
Return
############################################################
$SETBOUT
# ------------------------------------------------------------------------------------- #
# Activation/Désactivation des menus                                                    #
# ------------------------------------------------------------------------------------- #
# B : HT/Catégorie          : Actif                                                     #
# C : HT réglé              : Actif                                                     #
# D : HT/représentant       : Actif si représentant présent                             #
# E : Palmarès Client       : Actif                                                     #
# F : Palmarès Représentant : Actif si représentant présent                             #
# G : Palmarès Tiers payeur : Actif                                                     #
# ------------------------------------------------------------------------------------- #

If [F:AMZ]CODMSK<>GBOITE | [F:AMZ]CODZON<>"REP1"
    Read [F:AMZ]CODE = GBOITE;"REP1"
    If fstat Raz [F:AMZ] : Endif
Endif
If [M:CSI2]NBLIG>0 CHMEN += "BCEG" Endif
If [M:CSI2]NBLIG>0 & [F:AMZ]SAIAFF= 2 CHMEN += "DF" Endif
#If [M:CSI2]NBLIG>0 & [M:CSI1]BPCINV=""  CHMEN += "EG" Endif
#If [M:CSI2]NBLIG>0 & [M:CSI1]BPCINV="" & [F:AMZ]SAIAFF= 2 CHMEN += "F" Endif

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Raz [L]V_LEG
Call GETLEG([M:CSI1]CPY,"",[L]V_LEG) From TRTLECLEG

If ([M:CSI2]NBLIG>0 & [L]INVCA_ON = 1)
  If func AFNC.PARAM("INVCAN",[L]V_LEG) <> "2"
    Chgfmt [M:CSI2]INVCAN With "-LA:1"
  Else
    Chgfmt [M:CSI2]INVCAN With "+LA:1"
  Endif
Endif

Affzo [M:CSI2]
Affzo [M:CCSI]
Affzo [M:CSI1]
#105200 RICAR 2015/05/25 - Inv Cancelation - END

Return

###################################################################
# analyse paramères, initialisations, ouvertures et déclarations  #
###################################################################
$OUVRE
Local Char    WFIL(250),WFIL1(250),WFIL2(250)
Local Char    DEBNUM, FINNUM
Local Date    DEBDAT, FINDAT
#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Local Integer INVCA_ON
Local Char    V_LEG(20)
#105200 RICAR 2015/05/25 - Inv Cancelation - END

If clalev([F:DUD])=0 Local File GACCDUDATE [DUD] : Endif
If clalev([F:TCU])=0 Local File TABCUR     [TCU] : Endif
If clalev([F:AMZ])=0 Local File AMSKZON    [AMZ] : Endif

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
[L]INVCA_ON = 0
If func AFNC.ACTIV("INVCA") = 1 : [L]INVCA_ON = 1 : Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - END

NAVIG="CONSCSI"

Gosub DEFCRIT
[M:CSI1]CURD=GSYSCUR
Return

# --------------------------------------------------------------------------#
# Analyse paramères, initialisations                                        #
# --------------------------------------------------------------------------#
$DEFCRIT
If [M:CSI1]SALFCY<>"" & GUSRFCY(1)<>"\" & !find([M:CSI1]SALFCY,GUSRFCY(1..GNBAUZ))
 [M:CSI1]SALFCY=""
Endif

For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre Client
      If PARAM(I) <> ""
        If [F:BPC]BPCNUM<>PARAM(I) Read [F:BPC]BPC0 = PARAM(I)
                                     If fstat
                                        Raz [F:BPC], PARAM(I)
                                     Endif
        Endif
        [M:CSI1]BPCINV = PARAM(I)
      Endif
    When 2 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)    Read [F:FCY]FCY0 = PARAM(I)
                                     If fstat
                                       Raz [F:FCY], PARAM(I)
                                     Endif
        Endif
        If GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ))
           [M:CSI1]SALFCY = PARAM(I)
           If [M:CSI1]SALFCY <> ""
             Call GETDEV([M:CSI1]SALFCY) From DEVSUB
             [M:CSI1]CPY  = GSOCIETE
             [M:CSI1]CURS = GLOCALDEV
           Endif
        Endif
      Endif
  Endcase
Next I

If !find([M:CSI1]INVTYPFAC,1,2) : [M:CSI1]INVTYPFAC = 2 : Endif
If !find([M:CSI1]INVTYPAVO,1,2) : [M:CSI1]INVTYPAVO = 2 : Endif
If !find([M:CSI1]INVTYPPRF,1,2) : [M:CSI1]INVTYPPRF = 2 : Endif
If !find([M:CSI1]INVSTAO,1,2)   : [M:CSI1]INVSTAO = 2 : Endif
If !find([M:CSI1]INVSTAN,1,2)   : [M:CSI1]INVSTAN = 2 : Endif

If !find([M:CCSI]ORIMODVEN,1,2) : [M:CCSI]ORIMODVEN = 2 : Endif
If !find([M:CCSI]ORIMODTIE,1,2) & clalev([M:BPC0])
    [M:CCSI]ORIMODTIE = 2
Else
    [M:CCSI]ORIMODTIE = 1
Endif
If !find([M:CCSI]TRI,1,2)       : [M:CCSI]TRI = 1  : Endif

[M:CSI1]INVDATFIN=eomonth(date$)
[M:CSI1]INVDATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2)))
#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Gosub SETDEFAULT_VALUES
#105200 RICAR 2015/05/25 - Inv Cancelation - END
# -- copie de l'écran critères (CCSI) vers le masque 1 (CSI1)
Gosub CRITENT From =PROGCNS

Return

############################################################
$LECTURE
Local   Decimal  WMNTORG(0..5), WMNTDES(0..5), WRAT
Local   Integer  SPSTAT, WI
Local   Char     L0BPINAM(GLONNAM), L1BPINAM(GLONNAM) :#65847
Local   Char     L0BPDNAM(GLONNAM), L1BPDNAM(GLONNAM) :#65847
Local   Char     L0BPYNAM(GLONNAM), L1BPYNAM(GLONNAM) :#65847
Local   Char     L0BPRNAM(GLONNAM), L1BPRNAM(GLONNAM) :#65847

# Mail CH : 03/03/04
#If [M:CSI1]CPY="" & [M:CSI1]SALFCY=""
# NBLU=0 : Return
#Endif

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Call SHOWHIDE([M:CSI1]CPY)
#105200 RICAR 2015/05/25 - Inv Cancelation - END

  # FGR 21/10/2009 : X3SUIVI56101
  If GPILNAV > 1 Then
    #acces depuis clients ou tiers
    If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC") Then
      Diszo [M:CSI1]BPCINV
    Endif

    # GRNA 16/05/2011
    Local Char CUSSEAORI : CUSSEAORI = "CSI1"
    Gosub LECTURE From CUSSEALIB
  Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

# Issue X3-110726 - 2018-10-06 by FGR : BEGIN
#Link [F:SIH] With [F:SIV]SIV0=[F:SIH]NUM As [LSIHV] Order By Key SIH0=[F:SIH]NUM   # FGR 24/02/2015 : X3SUIVI104383
Link [F:SIH] With [F:SIV]SIV0=[F:SIH]NUM As [LSIHV]
# Issue X3-110726 - 2018-10-06 by FGR : END

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCSI]TRI
      When 1 : # tri par numéro
        #Filter [SIH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SIH0         # FGR 24/02/2015 : X3SUIVI104383
        Filter [LSIHV] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SIH0        # FGR 24/02/2015 : X3SUIVI104383
      When 2 : # tri par date
#        Filter [SIH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
#&                    Order By Key CLE=[F:SIH]BPRDAT;[F:SIH]NUM                                    # FGR 24/02/2015 : X3SUIVI104383
        Filter [LSIHV] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                    Order By Key CLE=[F:SIH]BPRDAT;[F:SIH]NUM    :                                # FGR 24/02/2015 : X3SUIVI104383
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCSI]TRI
      When 1 : # tri par numéro
        #Filter [SIH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SIH0 Desc    # FGR 24/02/2015 : X3SUIVI104383
        Filter [LSIHV] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SIH0 Desc   # FGR 24/02/2015 : X3SUIVI104383
      When 2 : # tri par date
#        Filter [SIH] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
#&                    Order By [F:SIH]BPRDAT Desc ;[F:SIH]NUM Desc                                 # FGR 24/02/2015 : X3SUIVI104383
        Filter [LSIHV] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                    Order By [F:SIH]BPRDAT Desc ;[F:SIH]NUM Desc                                  # FGR 24/02/2015 : X3SUIVI104383
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CSI2] : Endif

#-- lecture
$BOUCLE
Raz L0BPINAM, L1BPINAM :#65847
Raz L0BPDNAM, L1BPDNAM :#65847
Raz L0BPYNAM, L1BPYNAM :#65847
Raz L0BPRNAM, L1BPRNAM :#65847

#For [SIH] With Nohint                                                                             # FGR 24/02/2015 : X3SUIVI104383
For [LSIHV] With Nohint                                                                            # FGR 24/02/2015 : X3SUIVI104383
#Read [SIV] SIV0=[F:SIH]NUM                                                                        # FGR 24/02/2015 : X3SUIVI104383
#If fstat & [F:SIH]ORIMOD=5 Goto SUIV : Endif                                                      # FGR 24/02/2015 : X3SUIVI104383

# FGR 24/02/2015 : X3SUIVI104383 : mis dans le FILTER
## Filtre sur la société
#  If [M:CSI1]CPY <> "" & ([M:CSI1]CPY <> [F:SIH]CPY) Goto SUIV : Endif

  #YYN45. Si tengo marcado Facturacion mensual, compruebo si el cliente lo tiene así parametrizado
  If [M:CSI1]YFMENSUAL = 2
    Read [BPC]BPC0 = [F:SIH]BPR
    If fstat = 0
      If [BPC]IME = 5 and [BPC]INVPER = 6

      Else
        Goto SUIV
      Endif
    Endif
  Endif
  #YYN45 FIN

  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:CSI2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
     NOL    += 1
     If NOL=0
         DEBNUM = [F:SIH]NUM
         DEBDAT = [F:SIH]BPRDAT
     Endif
     FINNUM = [F:SIH]NUM
     FINDAT = [F:SIH]BPRDAT
  Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
     NOL    -= 1
     If NOL=MAXLIG-1
         FINNUM = [F:SIH]NUM
         FINDAT = [F:SIH]BPRDAT
     Endif
     DEBNUM = [F:SIH]NUM
     DEBDAT = [F:SIH]BPRDAT
  Endif

  nolign = NOL+1
  [M:CSI2] = [F:SIH]                            : # Bug 63729
  #Fiche 65847
  #If [F:SIH]ORIMOD=5 [M:CSI2] = [F:SIV] : Endif : # Bug 63729
  #Cas particulier, car les champs BPYNAM et BPRNAM de SIH sont dimensionnés
  If dim([M:CSI2]BPYNAM)>0
    If nolign-1>1
      [M:CSI2]BPYNAM(0)=L0BPYNAM
      [M:CSI2]BPYNAM(1)=L1BPYNAM
    Elsif nolign-1=0
      L0BPYNAM = [F:SIH]BPYNAM(0)
    Elsif nolign-1=1
      [M:CSI2]BPYNAM(0)=L0BPYNAM
      L1BPYNAM = [F:SIH]BPYNAM(0)
    Endif
    [M:CSI2]BPYNAM(nolign-1)=[F:SIH]BPYNAM(0)
  Endif
  If dim([M:CSI2]BPRNAM)>0
    If nolign-1>1
      [M:CSI2]BPRNAM(0)=L0BPRNAM
      [M:CSI2]BPRNAM(1)=L1BPRNAM
    Elsif nolign-1=0
      L0BPRNAM = [F:SIH]BPRNAM(0)
    Elsif nolign-1=1
      [M:CSI2]BPRNAM(0)=L0BPRNAM
      L1BPRNAM = [F:SIH]BPRNAM(0)
    Endif
    [M:CSI2]BPRNAM(nolign-1)=[F:SIH]BPRNAM(0)
  Endif
  If [F:SIH]ORIMOD=5
    [M:CSI2] = [F:SIV] :# Bug 63729
    #Cas particulier, car les champs BPINAM et BPDNAM de SIV sont dimensionnés
    If dim([M:CSI2]BPINAM)>0
      If nolign-1>1
        [M:CSI2]BPINAM(0)=L0BPINAM
        [M:CSI2]BPINAM(1)=L1BPINAM
      Elsif nolign-1=0
        L0BPINAM = [F:SIV]BPINAM(0)
      Elsif nolign-1=1
        [M:CSI2]BPINAM(0)=L0BPINAM
        L1BPINAM = [F:SIV]BPINAM(0)
      Endif
      [M:CSI2]BPINAM(nolign-1)=[F:SIV]BPINAM(0)
    Endif
    If dim([M:CSI2]BPDNAM)>0
      If nolign-1>1
        [M:CSI2]BPDNAM(0)=L0BPDNAM
        [M:CSI2]BPDNAM(1)=L1BPDNAM
      Elsif nolign-1=0
        L0BPDNAM = [F:SIV]BPDNAM(0)
      Elsif nolign-1=1
        [M:CSI2]BPDNAM(0)=L0BPDNAM
        L1BPDNAM = [F:SIV]BPDNAM(0)
      Endif
      [M:CSI2]BPDNAM(nolign-1)=[F:SIV]BPDNAM(0)
    Endif
  Endif
  #Fin 65847

  [M:CSI2]ORIMOD(nolign-1)     = [F:SIH]ORIMOD
  [M:CSI2]NUM(nolign-1)        = [F:SIH]NUM
  [M:CSI2]BPCINV(nolign-1)     = [F:SIH]BPR
  [M:CSI2]INVDAT(nolign-1)     = [F:SIH]BPRDAT
  [M:CSI2]INVTYP(nolign-1)     = [F:SIH]INVTYP
  [M:CSI2]INVSTA(nolign-1)     = [F:SIH]STA
  [M:CSI2]AMTATI(nolign-1)     = [F:SIH]AMTATI
  [M:CSI2]CUR(nolign-1)        = [F:SIH]CUR

  Raz WMNTORG
  WMNTORG (0) = [F:SIH]AMTATI
#    Recherche du montant réglé
  For [DUD]DUD0 Where TYP=[F:SIH]GTE & NUM=[F:SIH]NUM & ACCNUM=[F:SIH]ACCNUM
#      WMNTORG (1) += [F:DUD]PAYCUR
      WMNTORG (1) += ([F:DUD]PAYCUR+[F:DUD]TMPCUR)
  Next
  [M:CSI2]AMTPAY(nolign-1)    = WMNTORG (1)
#    Calcul des montants en devise société
  If [F:SIH]CUR <> [M:CSI1]CURS
#    If [F:SIH]RATCUR=0
#      Call CONVERT2([F:SIH]CUR,[M:CSI1]CURS,[M:CSI1]CURS,[F:SIH]CURTYP,datesyst,WMNTORG(0),WMNTDES(0),SPSTAT) From TRTDEV
#      Call CONVERT2([F:SIH]CUR,[M:CSI1]CURS,[M:CSI1]CURS,[F:SIH]CURTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
#    Else
#      WMNTDES(0) = WMNTORG(0) * [F:SIH]RATCUR
#      WMNTDES(1) = WMNTORG(1) * [F:SIH]RATCUR
#    Endif
    WI=find(GLOCALDEV,[F:SIH]CURLED)
    If WI & [F:SIH]RATDIV(WI-1)<>0
      WRAT=[F:SIH]RATMLT(WI-1)/[F:SIH]RATDIV(WI-1)
    Else
      WRAT=0
    Endif
    If WRAT=0
      Call CONVERT2([F:SIH]CUR,[M:CSI1]CURS,[M:CSI1]CURS,[F:SIH]CURTYP,datesyst,WMNTORG(0),WMNTDES(0),SPSTAT) From TRTDEV
      Call CONVERT2([F:SIH]CUR,[M:CSI1]CURS,[M:CSI1]CURS,[F:SIH]CURTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
    Else
      WMNTDES(0) = WMNTORG(0) * WRAT
      WMNTDES(1) = WMNTORG(1) * WRAT
    Endif
    If [F:TCU]CUR <> [M:CSI1]CURS
      Read [F:TCU]TCU0 = [M:CSI1]CURS
      If fstat Raz [F:TCU] : Endif
    Endif
    [M:CSI2]AMTATISOC(nolign-1)  = arr(WMNTDES(0),[F:TCU]CURRND)
    [M:CSI2]AMTPAYSOC(nolign-1)  = arr(WMNTDES(1),[F:TCU]CURRND)
  Else
    [M:CSI2]AMTATISOC(nolign-1)  = WMNTORG (0)
    [M:CSI2]AMTPAYSOC(nolign-1)  = WMNTORG (1)
  Endif
#    Calcul des montants en devise dossier
  If [F:SIH]CUR <> [M:CSI1]CURD
#    If [F:SIH]RATRPT=0
#      Call CONVERT2([F:SIH]CUR,[M:CSI1]CURD,[M:CSI1]CURS,[F:SIH]CURTYP,datesyst,WMNTORG(0),WMNTDES(0),SPSTAT) From TRTDEV
#      Call CONVERT2([F:SIH]CUR,[M:CSI1]CURD,[M:CSI1]CURS,[F:SIH]CURTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
#    Else
#      WMNTDES(0) = WMNTORG(0) * [F:SIH]RATRPT
#      WMNTDES(1) = WMNTORG(1) * [F:SIH]RATRPT
#    Endif
    WI=find(GSYSCUR,[F:SIH]CURLED)
    If WI & [F:SIH]RATDIV(WI-1)<>0
      WRAT=[F:SIH]RATMLT(WI-1)/[F:SIH]RATDIV(WI-1)
    Else
      WRAT=0
    Endif
    If WRAT=0
      Call CONVERT2([F:SIH]CUR,[M:CSI1]CURD,[M:CSI1]CURS,[F:SIH]CURTYP,datesyst,WMNTORG(0),WMNTDES(0),SPSTAT) From TRTDEV
      Call CONVERT2([F:SIH]CUR,[M:CSI1]CURD,[M:CSI1]CURS,[F:SIH]CURTYP,datesyst,WMNTORG(1),WMNTDES(1),SPSTAT) From TRTDEV
    Else
      WMNTDES(0) = WMNTORG(0) * WRAT
      WMNTDES(1) = WMNTORG(1) * WRAT
    Endif
    If [F:TCU]CUR <> [M:CSI1]CURD
      Read [F:TCU]TCU0 = [M:CSI1]CURD
      If fstat Raz [F:TCU] : Endif
    Endif
    [M:CSI2]AMTATIDOS(nolign-1)  = arr(WMNTDES(0),[F:TCU]CURRND)
    [M:CSI2]AMTPAYDOS(nolign-1)  = arr(WMNTDES(1),[F:TCU]CURRND)
  Else
    [M:CSI2]AMTATIDOS(nolign-1)  = WMNTORG (0)
    [M:CSI2]AMTPAYDOS(nolign-1)  = WMNTORG (1)
  Endif
  If [F:SIH]ORIMOD = 5 [M:CSI2]BPCGRU(nolign-1) = [F:SIV]BPCGRU Endif
  [M:CSI2]BPRPAY(nolign-1)    = [F:SIH]BPRPAY
  [M:CSI2]PTE(nolign-1)       = [F:SIH]PTE
  [M:CSI2]STRDUDDAT(nolign-1) = [F:SIH]STRDUDDAT
  If dim([M:CSI2]REP1)>=nolign
      [M:CSI2]REP1(nolign-1)       = [F:SIV]REP(0)
      If dim([M:CSI2]REP2)>=nolign
          [M:CSI2]REP2(nolign-1)   = [F:SIV]REP(1)
      Endif
  Endif
  [M:CSI2]SALFCY(nolign-1)    = [F:SIH]FCY

  #105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
  Raz [L]V_LEG
  Call GETLEG([M:CCSI]CPY,"",[L]V_LEG) From TRTLECLEG
  If [L]INVCA_ON = 1 & func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
    Case [F:SIH]REVCANSTA
      When 0: [M:CSI2]INVCAN(nolign-1) = 3
      When 1: [M:CSI2]INVCAN(nolign-1) = 1
      When 2: [M:CSI2]INVCAN(nolign-1) = 2
    Endcase
  Endif
  #105200 RICAR 2015/05/25 - Inv Cancelation - END

  $SUIV
Next
#Filter [SIH]                                                                                      # FGR 24/02/2015 : X3SUIVI104383
Filter [LSIHV]                                                                                     # FGR 24/02/2015 : X3SUIVI104383
Return

############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"

#gbn-82650 : critère WFIL trop court. Report de plusieurs critères dans WFIL1 : SALFCY, GUSRFCY, INVTYPFAC, NUMDEB, NUMFIN

# FGR 24/02/2015 : X3SUIVI104383 (début)
If [M:CSI1]CPY <> ""
  WFIL1 += "&[F:SIH]CPY=[M:CSI1]CPY"
Endif
# FGR 24/02/2015 : X3SUIVI104383 (fin)

If [M:CSI1]SALFCY <> ""
    WFIL1 += "&[F:SIH]FCY=[M:CSI1]SALFCY" #gbn-82650
Endif
#    Autorisation site
# 86749 : Ctrl Autorisation site ssi aucun site saisi (si site saisi, le ctrl a été fait à la saisie)
#If GUSRFCY(1)<>"\" & [M:CSI1]SALFCY <> "" & GNBAUZ<>GNBSITE
#If GUSRFCY(1)<>"\" & [M:CSI1]SALFCY = "" & GNBAUZ<>GNBSITE
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE             # FGR 25/06/2014 : X3SUIVI101014 : Le site ne doit pas être testé ici.
# 86749
 WFIL1 += "&find([F:SIH]FCY,GUSRFCY(1..GNBAUZ))" #gbn-82650
Endif

If [M:CSI1]BPCINV <> ""
   WFIL1 += "&[F:SIH]BPR=[M:CSI1]BPCINV" #gbn-82650
Endif
WFIL += "&[F:SIH]INVTYP<>3 & [F:SIH]INVTYP<>4"
# Prise en compte des factures
# --> Si 1 (Non) On exclut les factures
If [M:CSI1]INVTYPFAC = 1
   WFIL += "&[F:SIH]INVTYP<>1"
Endif
# Prise en compte des avoirs
# --> Si 1 (Non) On exclut les avoirs
If [M:CSI1]INVTYPAVO = 1
   WFIL += "&[F:SIH]INVTYP<>2"
Endif
# Prise en compte des proformas
# --> Si 1 (Non) On exclut les proformas
If [M:CSI1]INVTYPPRF = 1
   WFIL += "&[F:SIH]INVTYP<>5"
Endif
# Prise en compte des factures validées
# --> Si 1 (Non) On exclut les factures validées
If [M:CSI1]INVSTAO = 1
   WFIL += "&[F:SIH]STA<>3"
Endif
# Prise en compte des factures non validées
# --> Si 1 (Non) On exclut les factures non validées
If [M:CSI1]INVSTAN = 1
   WFIL += "&[F:SIH]STA>2"
Endif
# Prise en compte des factures vente
# --> Si 1 (Non) On exclut les factures vente
If [M:CCSI]ORIMODVEN = 1
   WFIL += "&[F:SIH]ORIMOD<>5"
Endif
# Prise en compte des factures tiers
# --> Si 1 (Non) On exclut les factures tiers
If [M:CCSI]ORIMODTIE = 1
   WFIL += "&[F:SIH]ORIMOD<>3"
Endif

If [M:CCSI]NUMDEB <> ""
   WFIL1 += "&[F:SIH]NUM>=[M:CCSI]NUMDEB" #gbn-82650
Endif
If [M:CCSI]NUMFIN <> ""
   WFIL1 += "&[F:SIH]NUM<=[M:CCSI]NUMFIN" #gbn-82650
Endif

If [M:CCSI]INVDATDEB <> [0/0/0]
   WFIL += "&[F:SIH]BPRDAT>=[M:CCSI]INVDATDEB"
Endif
If [M:CCSI]INVDATFIN <> [0/0/0]
   WFIL += "&[F:SIH]BPRDAT<=[M:CCSI]INVDATFIN"
Endif

# FGR 23/02/2015 : X3SUIVI104383 (début)
If [M:CSI1]SIVTYP <> "" Then
  WFIL1 += "&[F:SIV]SIVTYP=[M:CSI1]SIVTYP"
Endif
# FGR 23/02/2015 : X3SUIVI104383 (fin)

# 71065 : PJT
If [M:CSI1]PJTDEB <> ""
   WFIL1 += "&[F:SIV]PJT>=[M:CSI1]PJTDEB"
Endif
If [M:CSI1]PJTFIN <> ""
   WFIL1 += "&[F:SIV]PJT<=[M:CSI1]PJTFIN"
Endif
# 71065 : PJT

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCSI]TRI
       When 1 : # tri par numéro
           WFIL1 += "&[F:SIH]NUM>=DEBNUM"
       When 2 : # tri par date
           WFIL1 += "&([F:SIH]BPRDAT>DEBDAT | ([F:SIH]BPRDAT=DEBDAT & [F:SIH]NUM>=DEBNUM))"
     Endcase
   When 2 : # suite
     Case [M:CCSI]TRI
       When 1 : # tri par numéro
           WFIL1 += "&[F:SIH]NUM>FINNUM"
       When 2 : # tri par date
           WFIL1 += "&([F:SIH]BPRDAT>FINDAT | ([F:SIH]BPRDAT=FINDAT & [F:SIH]NUM>FINNUM))"
     Endcase
   When -2 : # retour
     Case [M:CCSI]TRI
       When 1 : # tri par numéro
           WFIL1 += "&[F:SIH]NUM<DEBNUM"
       When 2 : # tri par date
           WFIL1 += "& ([F:SIH]BPRDAT<DEBDAT | ([F:SIH]BPRDAT=DEBDAT & [F:SIH]NUM<DEBNUM))"
     Endcase
Endcase

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Raz [L]V_LEG
Call GETLEG([M:CSI1]CPY,"",[L]V_LEG) From TRTLECLEG

If [L]INVCA_ON = 1  & func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
  WFIL1 += "& find([F:SIH]REVCANSTA,0"
  If [M:CSI1]INVCANSTA = 2
    WFIL1 += ",1"
  Endif
  If [M:CSI1]INVCANCAT = 2
    WFIL1 += ",2"
  Endif
  WFIL1 +=")>0"
Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - END

Return

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
$DEB_CRIT

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Call SHOWHIDE([M:CSI1]CPY)
#105200 RICAR 2015/05/25 - Inv Cancelation - END

Return
#105200 RICAR 2015/05/25 - Inv Cancelation - END

############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT


Return

#############################################################################
##     Etiquettes masques CONSCSI1 & CONSCSI2 & CRITCSI                    ##
#############################################################################
############################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  [M]CURS = [F:CPY]ACCCUR : GLOCALDEV=[F:CPY]ACCCUR
Elsif [M]SALFCY = ""
  # Mail CH : 03/03/04
  #  GERR=2 : GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
  #  Raz [M]CURS
  [M]CURS=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
Endif
Affzo [M]CURS
End
############################################################
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
# -- Controle autorisation sur le site
    If GUSRFCY(1)<>"\" & !find(VALEUR,GUSRFCY(1..GNBAUZ))
        GMESSAGE=VALEUR-mess(2,104,1)   : # Vous n'avez pas les droits sur ce site
        mkstat=2 : End
    Endif
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
    [M]CURS = GLOCALDEV
    Affzo [M]CPY, ZCPY, CURS
Elsif [M]CPY = ""
    # Mail CH : 03/03/04
    #    GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    #    mkstat = 2
    [M]CURS=GSYSCUR : GSOCIETE="" : GLOCALDEV=""
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif

End
########################################
Subprog IB_NBLIG

If [M]ORIMOD(nolign-1)=5
    GBOUT1 = mess(193, 198,1)-[M]NUM(nolign-1) : Raz GBOUT2
Else
    GBOUT2 = mess(193, 198,1)-[M]NUM(nolign-1) : Raz GBOUT1
Endif

# SYMEU 27/11/2008 : branchement appel traçabilité pièce vente
If [M]INVTYP(nolign-1)>2
   Raz GBOUT3
Endif

End
########################################
Subprog AM_NUMDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]NUMFIN= VALEUR : Endif
End
# 71065 : PJT
######################################################################################
Subprog AM_PJTDEB(VALEUR)
Variable Char    VALEUR()
If VALEUR <> "" : [M]PJTFIN= VALEUR : Affzo [M]PJTFIN Endif
End
# 71065 : PJT
########################################
Subprog AM_INVDATDEB(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] : [M]INVDATFIN= VALEUR : Endif
End

