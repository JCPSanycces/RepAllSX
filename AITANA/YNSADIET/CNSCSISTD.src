#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Local Char V_LEG(20)
Call GETLEG([M:CSI1]CPY,"",[L]V_LEG) From TRTLECLEG

# 1/[M:CSI1] Screen
If func AFNC.ACTIV("INVCA") = 1 & func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
  Call SHOWHIDE_FIELDS_CSI1(1,VALEUR)
  If VALEUR = 1
    [M:CSI1]INVCANSTA = 1
  Endif

  Affzo [M:CSI1]INVCANSTA
Endif

[L]V_LEG=''
Call GETLEG([M:CCSI]CPY,"",[L]V_LEG) From TRTLECLEG

# 2/[M:CCSI] Screen
If func AFNC.ACTIV("INVCA") = 1 & func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
  Call SHOWHIDE_FIELDS_CCSI(1,VALEUR)
  If VALEUR = 1
    [M:CCSI]INVCANSTA = 1
  Endif

  Affzo [M:CCSI]INVCANSTA
Endif
# -
End
