#<AdxTL>@(#)0.0.0.0 $Revision$ 
Call GET_COB_COMERZZIA()

End


#####################################################################
#**
#* Recuperación Cobros y Arqueos Ventanas Comerzzia
#*
#*!
Subprog GET_COB_COMERZZIA()

Global Char   GTYPE(10)

Local Char    LFILE(255), NAMEFILE(200)
Local Char    LDIRIMPORT(255) : LDIRIMPORT = filpath("IMPORT_EXPORT\COMERZZIA\Mov_Comerzzia\","","")
Local Char    LDIRERROR(255)  : LDIRERROR  = filpath("IMPORT_EXPORT\COMERZZIA\Error_Comerzzia\","","")
Local Char    LDIROK(255)     : LDIROK     = filpath("IMPORT_EXPORT\COMERZZIA\Success_Comerzzia\","","")
Local Integer LIN

Local Char LDATCAB(250)(10),LDATLIN0(250)(15)
Local Char LFECHA(10), LHORA(10), LFECHACJ(10)


  Gosub SET_COB_COMERZZIA
  Gosub SET_ARC_COMERZZIA

End


#####################################################################
#**
#* Recuperación Cobros Ventanas Comerzzia
#*
#*!
$SET_COB_COMERZZIA

  GTYPE = "COBROS"

  If !clalev([ZVCCJ0]) : Local File YVCZZCAJCOB0 [ZVCCJ0] : Endif
#  Filter [F:ZVCCJ0] Where UI_DIR_CAJA = "00d3f3df-f804-42f3-a1b5-2b38d191abc6"    ###################################123
#  Filter [F:ZVCCJ0] Where CODTIENDA = "V26"    ###################################123
#  Filter [F:ZVCCJ0] Where CODTIENDA = "V26" or CODTIENDA = 'V03' or CODTIENDA = 'V08' or CODTIENDA = 'V25'    ###################################123

  For [ZVCCJ0]
    LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
    LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)
    LFCHACJ= mid$(num$([ZVCCJ0]F_CIERRE),1,2)+mid$(num$([ZVCCJ0]F_CIERRE),4,2)+mid$(num$([ZVCCJ0]F_CIERRE),9,2)

    LFILE     = "CobrosCZZ_"+[ZVCCJ0]CODTIENDA+"_"+LFCHACJ+"_"

    NAMEFILE  = LFILE + "_" + LFECHA + LHORA + ".txt"
    LFILE     = LDIRIMPORT + LFILE + "_" + LFECHA + LHORA + ".txt"

    Gosub OPEN_FILE_W_CAJ

    LDATCAB(1) = "COB"
    LDATCAB(2) = ""
    LDATCAB(3) = "101"
    LDATCAB(4) = [ZVCCJ0]JOU
    LDATCAB(5) = ctrans(num$([ZVCCJ0]F_CIERRE),"/","")
    LDATCAB(6) = "Cobros Ventana " + [ZVCCJ0]CODTIENDA + " del " + num$([ZVCCJ0]F_CIERRE)
    LDATCAB(7) = "EUR"
    LDATCAB(8) = "STDCO"

    Wrseq 'G' + ';' + LDATCAB(1) + ';' + LDATCAB(2) + ';' + LDATCAB(3) + ';' + LDATCAB(4) + ';' +
&                     LDATCAB(5) + ';' + LDATCAB(6) + ';' + LDATCAB(7) + ';' + LDATCAB(8) + ';' Using [YIMP]

    LIN = 1
    Raz  LDATLIN0
    # Línea asto. del cliente
      LDATLIN0(1) = num$(LIN)
      LDATLIN0(2) = "1"
      LDATLIN0(3) = num$(LIN)
      LDATLIN0(4) = "101"
      LDATLIN0(5) = "C300"
      LDATLIN0(6) = "4300000000"
#      LDATLIN0(7) = [ZVCCJ0]BPRNUM
      LDATLIN0(7) = func SPEYLIB0.GET_CLICZZ([ZVCCJ0]BPRNUM)
      LDATLIN0(8) = "Cobros Vtna " + [ZVCCJ0]CODTIENDA + " del " + num$([ZVCCJ0]F_CIERRE)
      LDATLIN0(9) = "-1"
      LDATLIN0(10) = num$([ZVCCJ0]IMP_TEORICO0)
      LDATLIN0(11) = "EUR"
      LDATLIN0(12) = ""

      Wrseq 'D' + ';' + LDATLIN0(1)  + ';' + LDATLIN0(2) + ';' + LDATLIN0(3) + ';' + LDATLIN0(4) + ';' + LDATLIN0(5)  + ';'
&                     + LDATLIN0(6)  + ';' + LDATLIN0(7) + ';' + LDATLIN0(8) + ';' + LDATLIN0(9) + ';' + LDATLIN0(10) + ';'
&                     + LDATLIN0(11) + ';' + LDATLIN0(12)+ ';' Using [YIMP]


    If !clalev([ZVCCJ1]) : Local File YVCZZCAJCOB1 [ZVCCJ1] : Endif
    Filter [ZVCCJ1] Where UI_DIR_CAJA = [ZVCCJ0]UI_DIR_CAJA

    Raz  LDATLIN0
    For [ZVCCJ1]
      LIN += 1
      LDATLIN0(1) = num$(LIN)
      LDATLIN0(2) = "1"
      LDATLIN0(3) = num$(LIN)
      LDATLIN0(4) = "101"
      LDATLIN0(5) = ""
      LDATLIN0(6) = [ZVCCJ1]ACCCOBRO
      LDATLIN0(7) = ""
      LDATLIN0(8) = "Cobros Vtna " + [ZVCCJ0]CODTIENDA + " del " + num$([ZVCCJ0]F_CIERRE)
      LDATLIN0(9) = "1"
      LDATLIN0(10) = num$([ZVCCJ1]IMP_TEORICO1)
      LDATLIN0(11) = "EUR"
      LDATLIN0(12) = ""


      Wrseq 'D' + ';' + LDATLIN0(1)  + ';' + LDATLIN0(2) + ';' + LDATLIN0(3) + ';' + LDATLIN0(4) + ';' + LDATLIN0(5)  + ';'
&                     + LDATLIN0(6)  + ';' + LDATLIN0(7) + ';' + LDATLIN0(8) + ';' + LDATLIN0(9) + ';' + LDATLIN0(10) + ';'
&                     + LDATLIN0(11) + ';' + LDATLIN0(12)+ ';' Using [YIMP]
    Next

  Gosub CLOSE_FILE_W_CAJ
  Gosub IMP_ASTOCOB

  Next

  Close Local File [ZVCCJ0], [ZVCCJ1]

Return

#####################################################################
#**
#* Recuperación Arqueos Ventanas Comerzzia
#*
#*!
$SET_ARC_COMERZZIA

  GTYPE = "DESCUADRE"

  If !clalev([ZVACJ0]) : Local File YVCZZCAJARC0 [ZVACJ0] : Endif
#  Filter [ZVACJ0] Where UI_DIR_CAJA = '00d3f3df-f804-42f3-a1b5-2b38d191abc6'    ###########################################123
#  Filter [ZVACJ0] Where CODTIENDA = 'V26'    ###########################################123
#  Filter [F:ZVCCJ0] Where CODTIENDA = "V26" or CODTIENDA = 'V03' or CODTIENDA = 'V08' or CODTIENDA = 'V25'    ###################################123

  For [ZVACJ0]
    LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
    LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)
    LFCHACJ= mid$(num$([ZVACJ0]F_DESCUADRE),1,2)+mid$(num$([ZVACJ0]F_DESCUADRE),4,2)+mid$(num$([ZVACJ0]F_DESCUADRE),9,2)

    LFILE     = "DescuadreCZZ_"+[ZVACJ0]CODTIENDA+"_"+LFCHACJ+"_"

    NAMEFILE  = LFILE + "_" + LFECHA + LHORA + ".txt"
    LFILE     = LDIRIMPORT + LFILE + "_" + LFECHA + LHORA + ".txt"

    Gosub OPEN_FILE_W_CAJ

    LDATCAB(1) = "DIFCO"
    LDATCAB(2) = ""
    LDATCAB(3) = "101"
    LDATCAB(4) = [ZVACJ0]JOU
    LDATCAB(5) = ctrans(num$([ZVACJ0]F_DESCUADRE),"/","")
    LDATCAB(6) = "Arqueo Vtna " + [ZVACJ0]CODTIENDA + " " + num$([ZVACJ0]F_DESCUADRE)
    LDATCAB(7) = "EUR"
    LDATCAB(8) = "STDCO"

    Wrseq 'G' + ';' + LDATCAB(1) + ';' + LDATCAB(2) + ';' + LDATCAB(3) + ';' + LDATCAB(4) + ';' +
&                     LDATCAB(5) + ';' + LDATCAB(6) + ';' + LDATCAB(7) + ';' + LDATCAB(8) + ';' Using [YIMP]

    LIN = 1
    Raz  LDATLIN0
    # Línea asto. del banco
      LDATLIN0(1) = num$(LIN)
      LDATLIN0(2) = "1"
      LDATLIN0(3) = num$(LIN)
      LDATLIN0(4) = "101"
      LDATLIN0(5) = ""
      LDATLIN0(6) = [ZVACJ0]CTA_CAJA
      LDATLIN0(7) = ""
      LDATLIN0(8) = "Arqueo Vtna " + [ZVACJ0]CODTIENDA + " " + num$([ZVACJ0]F_DESCUADRE)
      If [ZVACJ0]IMP_DECUADRE > 1
        LDATLIN0(9) = "-1"
      Else
        LDATLIN0(9) = "1"
      Endif
      LDATLIN0(10) = num$(abs([ZVACJ0]IMP_DECUADRE))
      LDATLIN0(11) = "EUR"
      LDATLIN0(12) = ""

      Wrseq 'D' + ';' + LDATLIN0(1)  + ';' + LDATLIN0(2) + ';' + LDATLIN0(3) + ';' + LDATLIN0(4) + ';' + LDATLIN0(5)  + ';'
&                     + LDATLIN0(6)  + ';' + LDATLIN0(7) + ';' + LDATLIN0(8) + ';' + LDATLIN0(9) + ';' + LDATLIN0(10) + ';'
&                     + LDATLIN0(11) + ';' + LDATLIN0(12)+ ';' Using [YIMP]


    Raz  LDATLIN0
      LIN += 1
      LDATLIN0(1) = num$(LIN)
      LDATLIN0(2) = "1"
      LDATLIN0(3) = num$(LIN)
      LDATLIN0(4) = "101"
      LDATLIN0(5) = ""
      If [ZVACJ0]IMP_DECUADRE > 1
        LDATLIN0(6) = [ZVACJ0]CTA_DIFPOS #  "7780000000"
      Else
        LDATLIN0(6) = [ZVACJ0]CTA_DIFNEG # "6590000000"
      Endif
      LDATLIN0(7) = ""
      LDATLIN0(8) = "Arqueo Vtna " + [ZVACJ0]CODTIENDA + " " + num$([ZVACJ0]F_DESCUADRE)
      If [ZVACJ0]IMP_DECUADRE > 1
        LDATLIN0(9) = "-1"
      Else
        LDATLIN0(9) = "1"
      Endif
      LDATLIN0(10) = num$(abs([ZVACJ0]IMP_DECUADRE))
      LDATLIN0(11) = "EUR"
      LDATLIN0(12) = ""


      Wrseq 'D' + ';' + LDATLIN0(1)  + ';' + LDATLIN0(2) + ';' + LDATLIN0(3) + ';' + LDATLIN0(4) + ';' + LDATLIN0(5)  + ';'
&                     + LDATLIN0(6)  + ';' + LDATLIN0(7) + ';' + LDATLIN0(8) + ';' + LDATLIN0(9) + ';' + LDATLIN0(10) + ';'
&                     + LDATLIN0(11) + ';' + LDATLIN0(12)+ ';' Using [YIMP]

  Gosub CLOSE_FILE_W_CAJ
  Gosub IMP_ASTOCOB

  Next

  Close Local File [ZVACJ0]

Return

#####################################################################
#**
#* Importación fichero Asto. Cobro Ventana
#*
#*!
$IMP_ASTOCOB

Local Char    UPDCAJMOV(250)
Local Integer STAT

  mkstat = 0 : fstat = 0 : GERRTRACE = 0

  Call OUVRE_TRACE("Creación Asientos Contables de Cobros Caja") From LECFIC
  Call IMPORTSIL("YGASCOBCAJ", LFILE) From GIMPOBJ
  Call FERME_TRACE From LECFIC

#  Call LEC_TRACE From LECFIC   #si se quiere mostrar traza

  If !clalev([F:YEI0]) Then : Local File YERRIMPORT [F:YEI0] : Endif

  If (fstat <> 0 and fstat <> 4) or GERRTRACE <> 0 Then                           # si se produce error de importación...
    Trbegin [F:YEI0]                                                              # ...se añade un registro en la tabla YERRIMPORT...
    [F:YEI0]ID =  getUuid  # MS - PODRÍA SER UN ALFA Y CARGAR NUM([ZVCCJ0]UI_DIR_CAJA                                # ...con la información del archivo...
    [F:YEI0]GENERADO  = "COBROS/ARQUEOS VENTANAS COMERZZIA"                       # ...para que, a través de un peticionario...
    [F:YEI0]FECHA     = datetime$                                                 # ...se muestre un proceso visual con los resultados...
    [F:YEI0]FICHERO   = LDIRERROR + NAMEFILE + ".err"                             # ...en la landing page
    Write [F:YEI0]
    If !fstat Then
      Commit
      Call MOVE(LFILE+".err",LDIRERROR,STAT) From ORDSYS                          # mueve el fichero .err con errores en la importación
      System "ae_rm " + LFILE                                                     # borra el fichero .txt que ha dado errores
      If GTYPE = "COBROS"
        UPDCAJMOV = "UPDATE integra.integra.INT_CAJA_MOVIMIENTOS_TBL SET PROCESADO='E',FECHA_PROCESADO='"+date$+"',MENSAJE_PROCESADO='ERROR IMPORTACION' WHERE UID_DIARIO_CAJA='"+[ZVCCJ0]
&       UI_DIR_CAJA+"'"
      Elsif GTYPE = "DESCUADRE"
        UPDCAJMOV = "UPDATE integra.integra.INT_CAJA_RECUENTO_TBL SET PROCESADO='E',FECHA_PROCESADO='"+date$+"',MENSAJE_PROCESADO='ERROR IMPORTACION' WHERE UID_DIARIO_CAJA='"+[ZVACJ0]
&       UI_DIR_CAJA+"'"
      Endif
      Execsql From "5" Sql UPDCAJMOV
    Else
      Rollback
    Endif
  Else
    Call MOVE(LFILE,LDIROK,STAT) From ORDSYS                              # mueve el fichero .txt con importación exitosa
    If GTYPE = "COBROS"
      UPDCAJMOV = "UPDATE integra.integra.INT_CAJA_MOVIMIENTOS_TBL SET PROCESADO='S',FECHA_PROCESADO='"+date$+"' WHERE UID_DIARIO_CAJA='"+[ZVCCJ0]UI_DIR_CAJA+"'"
    Elsif GTYPE = "DESCUADRE"
      UPDCAJMOV = "UPDATE integra.integra.INT_CAJA_RECUENTO_TBL SET PROCESADO='S',FECHA_PROCESADO='"+date$+"' WHERE UID_DIARIO_CAJA='"+[ZVACJ0]UI_DIR_CAJA+"'"
    Endif
    Execsql From "5" Sql UPDCAJMOV
  Endif
  mkstat = 0 : fstat = 0 : GOK = 1 : GERRTRACE = 0
  Close Local File [F:YEI0]

Return


########################################################
$OPEN_FILE_W_CAJ

  adxifs = ";"
  adxirs = chr$(13)+chr$(10)
  Openo LFILE Using [YIMP]

Return


########################################################
$CLOSE_FILE_W_CAJ

  Openo Using [YIMP]

Return
