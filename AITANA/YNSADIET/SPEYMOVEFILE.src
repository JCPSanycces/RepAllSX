#<AdxTL>@(#)0.0.0.0 $Revision$ 
Subprog MOVEFILE()
Local Char LPATHORIF(255) : LPATHORIF = filpath("IMPORT_EXPORT\FINALIZADO","","")
Local Char LPATHDESF(255) : LPATHDESF = filpath("IMPORT_EXPORT\Movimientos_Parrillas\FINALIZADO","","")
Local Char LPATHORIE(255) : LPATHORIE = filpath("IMPORT_EXPORT\ERRORES","","")
Local Char LPATHDESE(255) : LPATHDESE = filpath("IMPORT_EXPORT\Movimientos_Parrillas\ERRORES","","")

Local Char LPATHFICH(255), FILELIST(255)(1..100)

Local Integer STAT,LNGTH, I

  # mueve los archivos finalizados con éxito
  Raz LPATHFICH,LNGTH,FILELIST
  Call SYSTEME2(adxmac(0), "lsadx"-LPATHORIF,"",LNGTH,FILELIST) From ORDSYS         # función que devuelve la lista de archivos en un directorio
  For I=3 To LNGTH
    LPATHFICH = left$(FILELIST(I),11)
    If LPATHFICH = "CambioStock" Then
      LPATHFICH = LPATHORIF + "\" + FILELIST(I)
      Call MOVE(LPATHFICH,LPATHDESF,STAT) From ORDSYS                               # mueve los ficheros
    Endif
  Next

  # mueve los archivos finalizados con error
  Raz LPATHFICH,LNGTH,FILELIST
  Call SYSTEME2(adxmac(0), "lsadx"-LPATHORIE,"",LNGTH,FILELIST) From ORDSYS         # función que devuelve la lista de archivos en un directorio
  For I=3 To LNGTH
    LPATHFICH = left$(FILELIST(I),11)
    If LPATHFICH = "CambioStock" Then
      LPATHFICH = LPATHORIE + "\" + FILELIST(I)
      Call MOVE(LPATHFICH,LPATHDESE,STAT) From ORDSYS                               # mueve los ficheros
    Endif
  Next

End

