#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
# YN01 - Parrilla de recepción
# muestra el estado para un artículo/lote si se le ha cambiado
# desde la parrilla de recepción
$ACT_ESTADO

  If !clalev([F:YTR0]) Then : Local File YMFGTRAZAPR [F:YTR0] : Endif
  Filter [F:YTR0] Where ITMREF = [M:APR1]ITMREF and LOT = VALEUR Order By UPDDATTIM Desc
  Read   [F:YTR0] First
  If !fstat Then
    [M:APR1]STA = [F:YTR0]STA
    Affzo [M:APR1]STA
  Endif
  Filter [F:YTR0]

  If clalev([F:YTR0])  Then : Close Local File     [F:YTR0] : Endif

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Después de modificar el campo 'BLot'
######################################################################################
Subprog AM_BPSLOT(VALEUR)
Variable Char    VALEUR()
  Gosub ACT_ESTADO
End

######################################################################################
## Después de modificar el campo 'Lot'
######################################################################################
Subprog AM_LOT(VALEUR)
Variable Char    VALEUR()
  Gosub ACT_ESTADO
End

