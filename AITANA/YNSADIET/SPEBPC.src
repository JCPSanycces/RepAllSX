######################################################################################
Subprog AM_XYEMPRESA(VALEUR)
Variable Char    VALEUR()
[M]YEMPRESA([M]XNUMLIG) = VALEUR
[M:BPC4]FLMOD([M]XNUMLIG) = 1
End

######################################################################################
Subprog AM_XYSUCURSAL(VALEUR)
Variable Char    VALEUR()
[M]YSUCURSAL([M]XNUMLIG) = VALEUR
[M:BPC4]FLMOD([M]XNUMLIG) = 1
End

