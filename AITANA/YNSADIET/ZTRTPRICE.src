#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "ALIPLK" : Gosub ALIPLK
  When "AVRECHTAR": Gosub AVRECHTAR
Endcase
Return

$ALIPLK
Case GALIPLK
When "CRM"  : Gosub TRT_PRICE
When "SQH"  : Gosub TRT_PRICE
When "SOH"  : Gosub TRT_PRICE
When "SOI"  : Gosub TRT_PRICE
When "SDH"  : Gosub TRT_PRICE
When "TNH"  : Gosub TRT_PRICE
When "SDD"  : Gosub TRT_PRICE
When "SDD1" : Gosub TRT_PRICE
When "SIH"  : Gosub TRT_PRICE
When "SPSI" : Gosub TRT_PRICE
When "SCS"  : Gosub TRT_PRICE
Endcase
Return

$TRT_PRICE
If !clalev([F:ZFCY]): Local File FACILITY [F:ZFCY]: Endif
If [F:SPK]SALFCY<>""
   Read [F:ZFCY]FCY0=[F:SPK]SALFCY
Else
   Read [F:ZFCY]FCY0=[F:SPK]STOFCY
Endif
[F:SPK]YTIPOP=[F:ZFCY]YTIPOP

Return


$AVRECHTAR
If MODULE<>5: Return: Endif
## YTIPOP=1 YNSA  2 Ventana
Local Char WCPY(GLONCPY)
Local Char WFCY(GLONFCY)
Local Integer WTIPO
Case TRAIT
   When "SQH": WFCY=[M:PSH0]PSHFCY
   When "SOH": WFCY=[M:SOH0]SALFCY
   When "SOI": WFCY=[M:SOH0]SALFCY
   When "SDH": WFCY=[M:SDH0]SALFCY
   When "SIH": WFCY=[M:SIH0]SALFCY
Endcase

If !clalev([ZFCY]): Local File FACILITY [ZFCY]: Endif
Read [ZFCY]FCY0=WFCY
If [F:ZFCY]LEGCPY<>"001": Return: Endif
Case [F:ZFCY]YTIPOP
   When 1
     For X=0 To GPLINBR-1
       If left$(GPLI(X),1)<>"Y"
          GPLITYP(X)=9
       Endif
     Next
   When 2
     For X=0 To GPLINBR-1
       If left$(GPLI(X),1)<>"V"
          GPLITYP(X)=9
       Endif
     Next
Endcase
Return
