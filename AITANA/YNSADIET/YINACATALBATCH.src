# creada tarea batch y ejecutada
Global Integer GDIAS : GDIAS = 15 # DIAS de revisión de datos (fecha actual - gdias)
Local Integer  I, Z
Local Integer  LCON
Local Char REQSTR(250)(10)

Z = 0     # lanzamiento manual = 1 ; lanzamiento tarea batch = 0

#    I = func YINACATAL.BORRADOTABLAS()       # OK
#    # I = func YINACATAL.IEMPRESAS("")       # OK - NO ES NECESARIO LANZARLO DIARIAMENTE
