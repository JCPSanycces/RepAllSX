    I = func YINACATAL.IFAMILIAS("")         # OK
    I = func YINACATAL.IARTICULOS("")        # OK
    I = func YINACATAL.ITARIFASLINS("")      # OK
    I = func YINACATAL.ITIPOSCLIENTE("")     # OK
    # I = func YINACATAL.ICATALOGOS("")      # OK - NO ES NECESARIO LANZARLO DIARIAMENTE
    I = func YINACATAL.ICLIENTES("")         # OK
    I = func YINACATAL.IPRECIOSESPLIN()      # OK
    I = func YINACATAL.IPLANTILLACOMERCIAL() # OK
    I = func YINACATAL.IESTADISTICAS("")     # OK

  Execsql From "S"  Sql "UPDATE [CATALOGODIGITAL\TOTAL].inaSam.dbo.InaTareasProgramacion SET Activada = 1 "

  Endif

End
