 REQSTR(0) = "SELECT SUM(Ultima_ejecucion_resultado) as RES FROM [CATALOGODIGITAL\TOTAL].inaSam.dbo.InaTareasProgramacion"

 For (Integer LRES) From '5' Sql REQSTR As [YSEM]
   LCON = LRES
 Next

 If LCON = 0 and Z = 0 Then

    Execsql From "5"  Sql "UPDATE [CATALOGODIGITAL\TOTAL].inaSam.dbo.InaTareasProgramacion SET Activada = 0 "

    I = func YINACATAL.BORRADOTABLAS()       # OK
    # I = func YINACATAL.IEMPRESAS("")       # OK - NO ES NECESARIO LANZARLO DIARIAMENTE
    I = func YINACATAL.IFORMASDEPAGO("")     # OK
    I = func YINACATAL.IZONAS("")            # OK
    I = func YINACATAL.IAGENTES("")          # OK
    I = func YINACATAL.IAGENTESLCAT("")      # OK
    I = func YINACATAL.IAGENTESLTARS("","")  # OK
    # I = func YINACATAL.IMONEDAS("")        # OK - NO ES NECESARIO LANZARLO DIARIAMENTE
