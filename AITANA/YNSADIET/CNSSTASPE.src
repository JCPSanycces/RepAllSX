######################################################################################
Subprog S_YFILTROC(VALEUR)
Variable Char    VALEUR()
If [M:STA1]COD = 'YVE01'
  If [M:STA1]NIVAFF = 1
    Call SELECT("REP","",VALEUR,"") From SELOBJ
  Elsif [M:STA1]NIVAFF = 2
    If !clalev([ADI]) : Local File ATABDIV [ADI] : Endif
    Filter [ADI] Where [ADI]NUMTAB = 20
      Call SELECT("ADI","",VALEUR,"") From SELOBJ
    Filter [ADI]
    Close Local File [ADI]
  Elsif [M:STA1]NIVAFF = 3
    Call SELECT("ITM","",VALEUR,"") From SELOBJ
  Elsif [M:STA1]NIVAFF = 4
    If !clalev([ADI]) : Local File ATABDIV [ADI] : Endif
    Filter [ADI] Where [ADI]NUMTAB = 30
      Call SELECT("ADI","",VALEUR,"") From SELOBJ
    Filter [ADI]
    Close Local File [ADI]
  Elsif [M:STA1]NIVAFF = 5
    Call SELECT("BPC","",VALEUR,"") From SELOBJ
  Endif
Elsif [M:STA1]COD = 'YVE02'
  If [M:STA1]NIVAFF = 1
    Call SELECT("REP","",VALEUR,"") From SELOBJ
  Elsif [M:STA1]NIVAFF = 2
    Call SELECT("BPC","",VALEUR,"") From SELOBJ
  Elsif [M:STA1]NIVAFF = 3
    Call SELECT("ITM","",VALEUR,"") From SELOBJ
  Endif
Elsif [M:STA1]COD = 'YVE03'
  If [M:STA1]NIVAFF = 1
    If !clalev([ADI]) : Local File ATABDIV [ADI] : Endif
    Filter [ADI] Where [ADI]NUMTAB = 20
      Call SELECT("ADI","",VALEUR,"") From SELOBJ
    Filter [ADI]
    Close Local File [ADI]
  Elsif [M:STA1]NIVAFF = 2
    Call SELECT("ITM","",VALEUR,"") From SELOBJ
  Elsif [M:STA1]NIVAFF = 3
    Call SELECT("BPC","",VALEUR,"") From SELOBJ
  Endif
Elsif [M:STA1]COD = 'YVE04'
  If [M:STA1]NIVAFF = 1
    Call SELECT("BPC","",VALEUR,"") From SELOBJ
  Elsif [M:STA1]NIVAFF = 2
    Call SELECT("ITM","",VALEUR,"") From SELOBJ
  Endif
Elsif [M:STA1]COD = 'YVE05'
  If [M:STA1]NIVAFF = 1
    Call SELECT("ITM","",VALEUR,"") From SELOBJ
  Elsif [M:STA1]NIVAFF = 2
    Call SELECT("BPC","",VALEUR,"") From SELOBJ
  Endif
Elsif [M:STA1]COD = 'YVE06'
  If [M:STA1]NIVAFF = 1
    Call SELECT("BPC","",VALEUR,"") From SELOBJ
  Elsif [M:STA1]NIVAFF = 2
    If !clalev([ADI]) : Local File ATABDIV [ADI] : Endif
    Filter [ADI] Where [ADI]NUMTAB = 20
      Call SELECT("ADI","",VALEUR,"") From SELOBJ
    Filter [ADI]
    Close Local File [ADI]
  Elsif [M:STA1]NIVAFF = 3
    Call SELECT("ITM","",VALEUR,"") From SELOBJ
  Endif
Endif
End

