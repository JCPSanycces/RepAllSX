    If fstat = 0
       [M:STA1]YFILTROD = [ITM]ITMDES1
       Affzo [M:STA1]YFILTROD
    Endif
    Close Local File [ITM]
  Endif
Elsif [M:STA1]COD = 'YVE03'
  If [M:STA1]NIVAFF = 1
    If !clalev([ATE]) : Local File ATEXTRA [ATE] : Endif
    Read [ATE]AXX0 = "ATABDIV";"LNGDES";"SPA";"20";VALEUR
    If fstat = 0
       [M:STA1]YFILTROD = [ATE]TEXTE
       Affzo [M:STA1]YFILTROD
    Endif
    Close Local File [ATE]
  Elsif [M:STA1]NIVAFF = 2
