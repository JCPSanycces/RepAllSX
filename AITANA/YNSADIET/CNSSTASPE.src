#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara CONSSTA1 (Especifico)
$ACTION
Case ACTION
  When "FILTRE"   :  Infbox "ENTRO"
Endcase
Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla CONSSTA1) 07/09/2020 12:37:35 (AIT04)
######################################################################################
Subprog AM_YFILTROC(VALEUR)
Variable Char    VALEUR()
If [M:STA1]COD = 'YVE01'
  If [M:STA1]NIVAFF = 1
    If !clalev([REP]) : Local File SALESREP [REP] : Endif
    Read [REP]REP0 = VALEUR
    If fstat = 0
       [M:STA1]YFILTROD = [REP]REPNAM
       Affzo [M:STA1]YFILTROD
    Endif
    Close Local File [REP]
  Elsif [M:STA1]NIVAFF = 2
    If !clalev([ATE]) : Local File ATEXTRA [ATE] : Endif
    Read [ATE]AXX0 = "ATABDIV";"LNGDES";"SPA";"20";VALEUR
    If fstat = 0
       [M:STA1]YFILTROD = [ATE]TEXTE
       Affzo [M:STA1]YFILTROD
    Endif
    Close Local File [ATE]
  Elsif [M:STA1]NIVAFF = 3
    If !clalev([ITM]) : Local File ITMMASTER [ITM] : Endif
    Read [ITM]ITM0 = VALEUR
    If fstat = 0
       [M:STA1]YFILTROD = [ITM]ITMDES1
       Affzo [M:STA1]YFILTROD
    Endif
    Close Local File [ITM]
  Elsif [M:STA1]NIVAFF = 4
    If !clalev([ATE]) : Local File ATEXTRA [ATE] : Endif
    Read [ATE]AXX0 = "ATABDIV";"LNGDES";"SPA";"30";VALEUR
    If fstat = 0
       [M:STA1]YFILTROD = [ATE]TEXTE
       Affzo [M:STA1]YFILTROD
    Endif
    Close Local File [ATE]
  Elsif [M:STA1]NIVAFF = 5
    If !clalev([BPC]) : Local File BPCUSTOMER [BPC] : Endif
    Read [BPC]BPC0 = VALEUR
    If fstat = 0
       [M:STA1]YFILTROD = [BPC]BPCNAM
       Affzo [M:STA1]YFILTROD
    Endif
    Close Local File [BPC]
  Endif
Elsif [M:STA1]COD = 'YVE02'
  If [M:STA1]NIVAFF = 1
    If !clalev([REP]) : Local File SALESREP [REP] : Endif
    Read [REP]REP0 = VALEUR
    If fstat = 0
       [M:STA1]YFILTROD = [REP]REPNAM
