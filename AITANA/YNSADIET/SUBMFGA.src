#<AdxTL>@(#)7.0.0.0 $Revision$
# SUBMFGA : Gestion des ordres de fabrication             LLC 1998     #
# Traitement des actions "GOSUB" de l'objet "MFG"                      #
# Issue X3-28791 - 2017-08-30 by BAKHA : add global variables for WO opertaions critical changes
# Issue X3-55431 - 2017-09-15 by BAKHA : reset global message flag GREVMESSC after rewrite or abandon
# Issue X3-167553 - 2019-12-02 by BAKHA : lot sequence name > 3 characters

########################################################################
# Issue X3-55832 - 2017-09-13 by BAKHA : before checking versioning fields, make sure Versioning is in use
# Issue 162110 GH 24/09/2019 - to not generate [F:MFI]WIPNUM and ORDERS record for by-product not managed in stock

$FILTRE
Return

####################################################################
$DEFTRANS
#--------------------------------------------------------#
# Avant lecture des transactions de saisie disponibles : #
# Si GFLAG est renseigné la transaction est déja choisie #
# par le menu. Vérifier si elle est valide               #
#--------------------------------------------------------#
Local Shortint OUVFICFLG
Local Char SAVGFLAG(GLONTRS)    #X3-38574 JOBRO
If clalev ([F:MTS])=0 Local File MFGTRS [MTS] : Endif
If GFLAG<>""
  Read [MTS] MTS0=1;GFLAG
  If fstat | [F:MTS]ENAFLG=1 | [F:MTS]TRSAUTO = 2 : Raz GFLAG : Goto FIN_DEFTRANS : Endif
  If [F:MTS]ACSCOD<>"" & GPROFIL<>GSUPER
    If clalev ([F:ACC])=0 Local File ACCES  [ACC] : OUVFICFLG=1 : Endif
    Read [ACC] CODACC=GUSER;[F:MTS]ACSCOD
    If fstat | [F:ACC]EXEC<>2 Raz GFLAG : Goto FIN_DEFTRANS : Endif
  Endif
  SAVGFLAG = GFLAG              #X3-38574 JOBRO
Endif

$FIN_DEFTRANS
If OUVFICFLG=1 Close File [ACC] : Raz OUVFICFLG : Endif
Return

$VARIANTE
#---------------------------------------#
# Après lecture de chaque transaction : #
# La transaction est-elle valide ?      #
# VARCOD contient le code transaction.  #
# Mettre OK à zéro si non valide.       #
#---------------------------------------#
Read [MTS] MTS0=1;VARCOD
If fstat | [F:MTS]ENAFLG=1 | [F:MTS]TRSAUTO = 2 : OK=0 : Endif
Return

$SETTRANS
#-------------------------------------#
# Après sélection de la transaction : #
# GFLAG = code transaction choisie    #
#-------------------------------------#
If clalev ([F:MTS])=0 Local File MFGTRS [MTS] : Endif
Read [MTS] MTS0=1;GFLAG : If fstat Raz [F:MTS] : Endif
SAVGFLAG=GFLAG          #X3-38574 JOBRO
#MAE, le 30/01/08, evol GRP_SITE
GGRPFCY = [F:MTS]GFY
Return

########################################################################
$OUVRE
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
Local Char CODE(3)
Local Integer RETOUR, WRET
Local  Char   SYMBOL2(30)        # 41682 mm 07.07
#----- Variables globales
# point d'entrée MFMCRE (9307)
Global Char     GMFMORI(15) : GMFMORI = "GESMFG"
Global Char     GMTSNUM(GLONTRS) : GMTSNUM = [F:MTS]MTSNUM
Global Integer  GMEMSTA
Global Integer  GSCDFLG
Global Integer  GJALFLG     : GJALFLG     = 0
Global Integer  GLOADFLG    : GLOADFLG    = 0
Global Decimal  GEXTQTY
Global Integer  GMFGLIN
Global Integer  GFLGMAT     : GFLGMAT     = 0
Global Integer  GMODMAT     : GMODMAT     = 0
Global Integer  GMODOPE     : GMODOPE     = 0
Global Integer  GROUTING    : GROUTING    = 0
Global Integer  GSORT       : GSORT       = 0
Global Char     GGREP(1)
Global Integer  GALL
Global Integer  GMODLCT
Global Integer  GCONSLCT
Global Integer  GFLGMOD
Global Integer  IMODIF
Global Integer  GASW        : GASW        = 0
Global Integer  GMODSTAT    : GMODSTAT    = 0      # 35458 mm 09.06
Global Integer  GWOPJMMSG   : GWOPJMMSG   = 1      # X3-129690 JAMCC 03.19
Global Char     GWOPLNFCY(GLONFCY)                 # X3-129690 JAMCC 03.19

# Issue X3-138234 - 2019-05-13 by JAMCC : Track WO components - Critical Changes for non-versioned products
Global Integer  GTRACKMATWO : GTRACKMATWO = 1   # Track a WO component change YES(2) or NO(1)

#----- Variables globales
Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218

# Issue X3-25054 - 2017-07-07 by JUSYN : Global variable for user permission to do critical changes on components for versioned products
Global Integer GWOCRICHG      : GWOCRICHG = 0
# Global variable to save information whether information message about to do critical changes has already been displayed (Message only one time).
Global Integer GREVMESSC    : GREVMESSC = 0

Call CTRECCWCO From ECCLIB ## is user permitted to make critical changes

# Issue X3-25054 - 2017-07-07 by JUSYN : END
# Issue X3-48941 - 2017-08-17 by JUSYN : Global array to save MFGLIN of versioned products its version have been changed.
Global Integer GMFGLINVCH(dim([M:MFG1]NOLIG))
Raz GMFGLINVCH
# Issue X3-48941 - 2017-08-17 by JUSYN : END

# Issue X3-28791 - global variables for WO opertions critical changes
# Global variable for user permission to do critical changes on operations for versioned route
Global Integer GOPECRICHG      : GOPECRICHG = 0
# Global variable to save whether information message about doing critical changes to operations has already been displayed
# Global Integer GOPEREVMES    : GOPEREVMES = 0
Call CTRECCWOOPE From RVMLIB
# End issue X3-28791
Global Integer GMFGROPE      : GMFGROPE = 0
# Issue X3-55362 - 2017-09-11 by JUSYN :
Global Char GTRACKOPEWO(30) # Issue X3-138239 - 2019-05-13 by JUSYN : Parameter for operation traceability/revision for non-versioned products

# Store the status of scheduler activity codes POPS & GFS in
# array SCHEDULER_STATUS()
Call SET_SCHEDULER_STATUS(0,1) From MFGLIB

Raz GSOC_ACTIVE
Gosub CHARG_PARAM
#----- masque encours
Local Mask ORDK [ORDK]
Local Mask ORCK [ORCK]

# V6 Affectations
Gosub OPEN_MTO From MTOLINKLIB

# 09.04
If GMODU(5) = 2
    If clalev ([F:SOQ])<=0  : Local File SORDERQ     [SOQ] : Endif
Endif
If clalev ([F:MTK])<=0  : Local File MFGHEADTRK  [MTK] : Endif

If GMODU(2)=2 : # Si module compta actif
  If !clalev([F:GCM])   Local File GACM       [GCM] : Endif
Endif

If func AFNC.ACTIV("CCM")
    If !clalev([F:CCMCR]) : Local File CCMCHGREQ [CCMCR] : Endif
Endif

# ouverture forcée de l'encours
Local File ORDERS [ORD]

GORITITCOL = 1
#-----------------------------------------------#
# Déclaration des variables pour Tableau lignes #
#-----------------------------------------------#
Gosub OUVRE   From SUBMFG1    # FQ 50547 avant From TABLEAUX
Gosub OUVRE   From SUBMFG2    # pour gestion onglet matières
Gosub OUVRE   From SUBMFG3    # pour gestion onglet opérations
Gosub OUVRE   From SUBMFG4    # pour gestion onglet impression

If [F:MTS]MFGMODC = 2 : GMODLCT += 1 : Endif
If [F:MTS]MFGMODM = 2 : GMODLCT += 2 : Endif
If [F:MTS]MFGMODO = 2 : GMODLCT += 4 : Endif
#
If [F:MTS]TYPMODM = 2 | [F:MTS]TYPMODO = 2 : GFLGMOD = 1 : Else : GFLGMOD = 2 : Endif
#
GCONSLCT = GCONSULT
Return

###########################################################
$SETBOUT
# ------------------------------------------------------------------------------------- #
# Activation/Désactivation des menus                                                    #
# ------------------------------------------------------------------------------------- #
#    AX : Texte entête       : Actif si OF en ligne ou création                         #
#    BT : Transaction        : Actif                                                    #
#    BI : Dispo prév.        : Actif si OF en ligne                                     #
#    BP : Coût prév.         : Actif si OF en ligne en visu                             #
#    BO : cout revient indus : Actif si OF valorisé                                     #
#    BC : Cons. prix revient : Actif si OF en ligne en visu    FQ 64658                 #
#    BD : Cons. cout previ.  : Actif si OF en ligne en visu    FQ 64658                 #
#    BV : Situation art lancé: Actif si OF avec opé sous-traitée - Issue 100671 12/2014 #
#    BS : Suspension OF      : Actif si OF en ligne en visu                             #
#    BR : Clôture/solde OF   : Actif si OF en ligne en visu    FQ 64658                 #
#    CF : Dossier            : Actif si OF en ligne (ferme, non soldé et état alloc ok) #
#    CQ : Etiquettes         : Actif si                                                 #
# ------------------------------------------------------------------------------------- #
Local Integer OMWIP

# FQ 65904 GA 07/2010
#If (find(GREP,"C","D") | CLECUR) & [F:MFG]MFGSTA <> 4
If (find(GREP,"C","D") | CLECUR)
    # Issue 101696 - 2014-10-27 by JUSYN : Single letter for menu item. Call to Production Cost displayed no data.
    # CHMEN += "AX"
    CHMEN += "X"
Endif
# Issue 101696 - 2014-10-27 by JUSYN : Single letter for menu item
# CHMEN += "BT"
CHMEN += "T"
If CLECUR
    #CHMEN += "BI"
    CHMEN += "I"
Endif
If GREP = "" &
&  CLECUR
    # Issue 101696 - 2014-10-27 by JUSYN : Excluding BC respectively C for Production cost inquiry; single letter for menu item
    # CHMEN += "BP"
    # CHMEN += "P"#X3-38247.O
#    If [F:MFG]MFGSTA<4    # CCC (07/04/08) Bug 46601
    If [M:MFG0]MFGSTA<4 #X3-38247.N MJH 10/5/2017 [F:MFG] gets changed when searching in the left list.
        CHMEN += "P" #X3-38247.N MJH 10/5/2017 only allow provisional cost calculation when work order is not closed
        #CHMEN += "BS"
        #CHMEN += "BC"     # FQ 64658
        #CHMEN += "BD"     # FQ 64658
        #CHMEN += "BR"     # FQ 64658
        CHMEN += "S"
        CHMEN += "D"     # FQ 64658
        If !(func MFGLIB.CHKMFGLOCK([M:MFG0]MFGNUM,0)) # Issue 109749 - 2015-12-11 by BEEBE : if WO is not locked by another user
            CHMEN += "R"     # FQ 64658
        Endif
    Endif
    If [F:MFG]MFGSTA=4 & [F:MFG]MFGTRKFLG=6
        # Issue 101696 - 2014-10-27 by JUSYN : Single letter for menu item
        # CHMEN += "BC"
        CHMEN += "C"
    Endif
    # Issue 100671 GA 12/2014 V8 Display synthesis when subcontracted operation
    If [F:MFG]MFGSTA=1 & find(3,[M:MFG3]WSTTYP(0..[M:MFG3]NBLIG-1)) & GVERSION>="1.8.0"
       CHMEN += "V"
    Endif
Endif
If !find(GREP,"C","D") &
&  [M:MFG0]MFGNUM <> "" &
&  [M:MFG0]MFGSTA = 1 &
&  [M:MFG1]MFGTRKFLG < 5 &
&  (find([M:MFG1]ALLSTA,3,5) | [M:MFG0]MFGMOD = 3 | GMTKALLMGT = 1) &
&  [M:MFG0]FLGMOD = 1
    If !(func MFGLIB.CHKMFGLOCK([M:MFG0]MFGNUM,0))    # 82059 mm 08.2012
        # Issue 101696 - 2014-10-27 by JUSYN : Single letter for menu item
        # CHMEN += "CF"
        CHMEN += "F"
    Endif
Endif
If !clalev([F:MWIP]): Local File MFGWIP [MWIP]:OMWIP=1:Endif
Look [F:MWIP]MWH0=10;[M]MFGNUM
If fstat = 0
  CHMEN+= "O"
Endif
If !find(GREP,"C","D") &
&  [M:MFG4]LBEMOD = 1
      # Issue 101696 - 2014-10-27 by JUSYN : Single letter for menu item
      # CHMEN += "CQ"
      CHMEN += "Q"
Endif

# ------------------------------------------------------------------------------------- #
# Boutons bas d'écrans                                                                  #
# ------------------------------------------------------------------------------------- #
#     1 : Allocation                                                                    #
#     2 : Jalonnement                                                                   #
#     3 : Situation                                                                     #
# ------------------------------------------------------------------------------------- #
GCONSLCT = GCONSULT
# uniquement visu si GCONSULT=1 (tunnel)
If GCONSLCT=1
    Call VIREBOUT(CHAINE,"MADH12") From GOBJET
Else
    If  CLECUR & GMODLCT = 2 & [M:MFG0]MFGMOD <> 2         # si matières seules
        Call VIREBOUT(CHAINE,"MADH12") From GOBJET
        GCONSLCT = 1
    Endif
    If  CLECUR & GMODLCT = 4 & [M:MFG0]MFGMOD <> 3         # si opérations seules
        Call VIREBOUT(CHAINE,"MADH12") From GOBJET
        GCONSLCT = 1
    Endif
    If CLECUR & [F:MTS]MFGSTA = 1 & [M:MFG0]MFGSTA = 1     # si planifié uniquement
        Call VIREBOUT(CHAINE,"MADH12") From GOBJET
        GCONSLCT = 1
    Endif
    If CLECUR & [F:MTS]MFGSTA = 2 & [M:MFG0]MFGSTA = 2     # si ferme uniquement
        Call VIREBOUT(CHAINE,"MADH12") From GOBJET
        GCONSLCT = 1
    Endif
Endif
# 05.05 30050
# Also disallow editing if work order is optimised (SCDFLG = 4)
If [M:MFG1]MFGTRKFLG = 2 | [M:MFG1]SCDFLG = 4
# Issue X3-25863 - 2017-02-21 by ALSHE : Enable Scheduling in WO if it is in Status "Being optimized" or "Optimized" (Schedul, De-schedul, To reschedule is disabled)
#   Call VIREBOUT(CHAINE,"MADH2") From GOBJET
# Issue X3-30339 - 2017-04-07 by ALSHE : Release WO managed by PS - allow modification "M"
#    Call VIREBOUT(CHAINE,"MADH") From GOBJET
    Call VIREBOUT(CHAINE,"ADH") From GOBJET
Endif

# pas de duplication
Call VIREBOUT(CHAINE,"H") From GOBJET

# pas d'allocation si pas de matières ou statut <> ferme
If !CLECUR | GREP <> "" | [M:MFG2]NBLIG = 0 | [M:MFG0]MFGMOD = 3 | [M:MFG0]MFGSTA <> 1 | [M:MFG1]MFGTRKFLG > 4
    Call VIREBOUT(CHAINE,"1") From GOBJET
Endif

# FQ 60159 GA 01/2010
# autorisation fonctionnelle sur le bouton d'allocation
GBIDC2="A": GFCY=[M:MFG0]MFGFCY : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2 : Call VIREBOUT(CHAINE,"1") From GOBJET : Endif

# pas de jalonnement si pas d'opérations
If !CLECUR | GREP <> "" | [M:MFG3]NBLIG = 0 | [M:MFG0]MFGMOD = 2 | [M:MFG0]MFGSTA = 4 | [M:MFG1]MFGTRKFLG > 4
    Call VIREBOUT(CHAINE,"2") From GOBJET
Endif

# autorisation jalonnement 09.05 31996
GBIDC2="J": GFCY=[M:MFG0]MFGFCY : Gosub AUTORIS_OPT From CONTX3

# Issue 137951 - 2019-05-21 by STLIG : disable production scheduler (as well as x3 scheduling) buttons..
If (!GBIDI2)
  Call VIREBOUT(CHAINE,"256") From GOBJET
Endif

# pas de situation si statut incorrect ou situation déjà ouverte
If !CLECUR | GREP <> "" | !find([M:MFG0]MFGSTA,1,4) | clalev ([M:MFS0]) > 0
    Call VIREBOUT(CHAINE,"3") From GOBJET
Endif

# pas de suppression si statut en cours ou supérieur
If [M:MFG1]MFGTRKFLG > 3
    Call VIREBOUT(CHAINE,"A") From GOBJET
Else
    # Issue 87289 GA 01/2013
    # pas de suppression si opé de sous-traitance commandée/en cours
    Local Integer WRET
    Call OPE_COMMANDE(WRET)
    If WRET=1
        Call VIREBOUT(CHAINE,"A") From GOBJET
    Endif
Endif

# FQ 71382 GA 02/2011 pas de modif/suppression si OF Clos
# pas de modification/suppression si statut soldé + PRF
If [M:MFG1]MFGTRKFLG > 5 | [M:MFG0]MFGSTA=4
    Call VIREBOUT(CHAINE,"MA") From GOBJET
Endif

# pas de modification/suppression si statut soldé + PRF
If [M:MFG1]MFGTRKFLG < 4
    Call VIREBOUT(CHAINE,"4") From GOBJET
Endif
# si pas au moins en cours, pas de bouton suivi

# 82059 mm 08.2012 - Si l'OF est verrouillé par un autre utilisateur, pas d'édition du dossier de fab
If (func MFGLIB.CHKMFGLOCK([M:MFG0]MFGNUM,0))
    Call VIREBOUT(CHAINE,"E") From GOBJET
    # Issue 84502 - 2012-10-16 by CCC : l'objet est locké par le superviseur => ne pas délocker
    #Unlock ="MFG"+[M:MFG0]MFGNUM   # on débloque tout de suite sinon on risque de sortir sans débloquer
Endif

    # Disable Optimization/De-optimization buttons

    # Disable button "Remove"
    # - If OPTFLG=2
    # - If WO is optimized
    # - If status is "Being optimized"

    If [F:MFG]OPTFLG <> 2 & [M:MFG1]SCDFLG <> 4 & [M:MFG1]MFGTRKFLG <> 2 | GREP <> ""
        Call VIREBOUT(CHAINE,"6") From GOBJET
    Endif

    # Disable button "Submit"
    #  - If it has already been submitted
    #  - WO is finished
    #  - WO is not scheduled
    If [F:MFG]OPTFLG=2 | [M:MFG1]MFGTRKFLG>4  | [M:MFG1]SCDFLG <> 2 | GREP <> ""
        Call VIREBOUT(CHAINE,"5") From GOBJET
    Endif

# ------------------------------------------------------------------------------------- #
# Autres activations/désactivation                                                      #
# ------------------------------------------------------------------------------------- #
If !GIMPORT
    Diszo [M:MFG0]FLGMOD
    Diszo [M:MFG1]MFGEXTQTY
    Diszo [M:MFG1]MFGSTU
    If [F:MTS]ROUSAI = 1 : Diszo [M:MFG1]25 : Endif
    Diszo [M:MFG1]XALLSTA
    Diszo [M:MFG1]XTRKFLG
    Diszo [M:MFG2]5
    Diszo [M:MFG3]5
    Diszo [M:MFG1]SCDMOD
    # ISSUE X3-30339 - 2017-04-07 By ALSHE : Release WO managed by PS - block all fields except MFGSTA
    # If !find([F:MTS]SCDMODSAI,1,2)
    If !find([F:MTS]SCDMODSAI,1,2) & !(([F:MFG]SCDFLG=4 | [F:MFG]OPTFLG = 2) & G_SCHEDULER_STATUS(0))
        Actzo [M:MFG1]SCDMOD
    Endif
Endif
GGREP = GREP
Return

###########################################################################################
$STATUT
Case BOUT
  When "X"      : If mkstat=4 & GREP=""                                    # texte entête OF
                       #GREP="M" : REP="M"
                       #Gosub SETBOUT From GOBJSUB
                       #Grizo [M:MFG0]MFGNUM
                       #MAE, bg 50938
                       Gosub ENTRE_MODIF From GOBJSUB
                  Endif
                  If [M:MFG0]MFGTEX <> "" & !GIMPORT
                        Call SET_IMAGE (4) From GESECRAN
                  Elsif !GIMPORT
                        Call RESET_IMAGE (4) From GESECRAN
                  Endif
  When "T"      : # transaction
  When "I"      : # disponibilité prévisionelle
  When "P"      : # prix de revient prévisionnel
  When "R"      : # Clôture / Solde OF
                  If !GIMPORT : Gosub RELIT From GOBJSUB : Endif          # mm 97778 06.2016
  When "S"      : # suspension
                  Gosub SUSPEND
  When "F"      : # édition du dossier de fabrication
                  If !GIMPORT : Gosub RELIT From GOBJSUB : Endif          # 09.05
  When "Q"      : # édition étiquettes
Endcase
#X3-38574 JOBRO
If SAVGFLAG<>"" and (SAVGFLAG<>[F:MTS]MTSNUM or [F:MTS]MTSTYP<>1)
  Read [F:MTS]MTS0=1;SAVGFLAG
  If !fstat : GFLAG=SAVGFLAG : Endif
Endif
#X3-38574
Return

###########################################################################################
$AVANTBOUT
Local Integer DOSOK
DOSOK = 0
Case BOUT
  When "1"      : # allocation
  When "2"      : # jalonnement
                  OJAL = 0
  When "3"      : # situation
                  GMFGCLOSE = "1"            # GH 13/10/2014 bug 103308
  When "F"      : # édition du dossier de fabrication                    # 09.05
                  Gosub DOS_FAB
                  If !DOSOK : OK = 0 : Endif
  When "R"      : # Issue 111882 - 2015-12-09 by GH : Check autorizations for the function
                  Call DROITSITEF("FUNMCLOSE",[M:MFG0]MFGFCY,GMESSAGE,OK) From CPTSUB
                  If !OK : GMESSAGE=mess(175,123,1) : Return : Endif
                  GMESSAGE=""
                  GMFGCLOSE = "3"            # 81756
Endcase
Return

###########################################################################################
$EXEBOUT
Case BOUT
  When "1"      : # allocation
                  If GALL <> 0 & !GIMPORT
                      Gosub RELIT From GOBJSUB
                  Endif
  When "2"      : # jalonnement
#                 # 78489
                  If OJAL <> 0 & !GIMPORT
                     Gosub RELIT From GOBJSUB
                  Endif
  When "3"      : # situation
  When "F"      : # édition du dossier de fabrication
  When "5"      : # Submit for scheduling
                  Gosub SUBMITWO From MFGOPT
                  # Issue X3-30339 - 2017-04-07 by ALSHE : Release WO managed by PS
                  Gosub RELIT From GOBJET   # MFG has been updated and need to be reloaded
  When "6"      : # Remove from scheduling
                  Gosub REMOVEWO From MFGOPT
                  # Reset the lock
                  Gosub RELIT From GOBJET
Endcase
Return

###########################################################################################
$FIN_ACTION
Case BOUT
    When "R" : If [M:MFG0]MFGSTA<>[F:MFG]MFGSTA | [M:MFG0]MFGNUM<>[F:MFG]MFGNUM
                   Gosub RELIT From GOBJSUB
               Endif
Endcase
Return

###########################################################################################
$AP_IMPRIME
#---------------------------------------------------------------#
# Après une impression il faut être sur d'être sur le bon enreg #
#---------------------------------------------------------------#
If !GIMPORT : Gosub RELIT From GOBJSUB : Endif
Return

########################################################################
$DOS_FAB
Call TEST_DOSSIER(DOSOK)
If DOSOK = 1
#Il faut se positionner sur les bons enregistrements ITM et ITF
    If [F:ITM]ITMREF <> [M:MFG1]ROUNUM
       Read [F:ITM]ITM0 = [M:MFG1]ROUNUM
       If fstat : Raz [F:ITM] : Endif
    Endif
    If [F:ITF]ITMREF <> [M:MFG1]ROUNUM | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
       Read [F:ITF]ITF0 = [M:MFG1]ROUNUM;[M:MFG0]MFGFCY
       If fstat : Raz [F:ITF] : Endif
    Endif
#    Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
#    Gosub SET_CLE From GOBJSUB : CLECUR=1
#    Call ETAT("DOSFAB","GESMFG",TBPAR,TBVAL) From ETAT
#    If !GIMPORT : Gosub RELIT From GOBJSUB : Endif
Endif
Return

########################################################################
#Suspension de l'OF
$SUSPEND
If [M:MFG0]SUSFLG <> 2
    [M:MFG0]SUSFLG = 2
    [M:MFG1]LABEL = mess(179,190,1)
Else
    [M:MFG0]SUSFLG = 1
    [M:MFG1]LABEL = ""
Endif
Affzo [M:MFG1]LABEL
REP = "M"
Return

########################################################################
$DEFLIG
#----------------------------------#
# Définition du fichier des lignes #
# -------------------------------- #
# Critère lecture     (CRIT)       #
# Nom du fichier      (FICLIG)     #
# Abréviation fichier (ABLIG)      #
# Zone numéro de ligne(ZONLIG)     #
#----------------------------------#
Default Mask [MFG1]
Default File [MFI]
CRIT   = 'MFGNUM="'+[M:MFG0]MFGNUM+'"'
FICLIG = "MFGITM"
ABLIG  = "MFI"
ZONLIG = "MFGLIN"

Return


########################################
$APRES_MODIF
# Issue 48563 03/08/2017 by GEBIL : Error: [F:ROH] : Class Non-existent + Error: [F:BOH] : Class Non-existent
If GUSER="AIT51" : Dbgaff : Endif

If clalev([F:ROH])=0
   Local File ROUTING [ROH] : OK=0
Endif
If clalev([F:BOH])=0
   Local File BOM [BOH] : OK=0
Endif
If OK=0 : Return : Endif


IMODIF = 2
Call ITMUPDFLG From SUBMFGB
Return

########################################
$TEST_MOD
Local    Integer WRET
Local    Integer OK

#---------------------------------------------------------------#
# Test pour modification d'une ligne article lancé              #
#---------------------------------------------------------------#
Case [M:MFG0]MFGSTA
    When 4         : mkstat = 2     # clôs
                     Return
    When Default   : # rien
Endcase
If [M:MFG1]ITMSTA(nolign-1) > 2 : mkstat = 2 : Return : Endif
If !find([M:MFG1]MFGTRKFLG,0,1,3,4) : mkstat = 2 : Return : Endif

Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : Return : Endif

If [M:MFG1]FMI(nolign-1)=5
    OK=1
    Call OUINON(mess(88,190,1),OK) From GESECRAN
    If OK <> 2 : mkstat=2 : Return : Endif
Endif

Return

########################################
$TEST_ANU
Local Integer WRET, I, J, OK
Local Integer WAUDIT : WAUDIT = 0          # Issue X3-48941 - 2017-08-23 by JUSYN : Display info message
#----------------------------------------------------#
# Test pour annulation de la ligne                   #
#----------------------------------------------------#
#
If [M:MFG1]FMI(nolign-1)=5
    mkstat = 2
    Return
Endif
Case [M:MFG0]MFGSTA
    When 4         : mkstat = 2     # clôs
                     Return
    When Default   : # rien
Endcase

If !find([M:MFG1]MFGTRKFLG,0,1,3,4) : mkstat = 2 : Return : Endif

# suppression sous-produit interdite
#If [M:MFG1]ITMTYP(nolign-1) = 2 : mkstat = 2 : End : Endif : # GH 20/01/2014 dm 95509
If [M:MFG1]ITMTYP(nolign-1) = 2
   GMESSAGE = mess(2,2301,1)-":"-mess(184,193,1) : # Sous-produit : Suppression interdite
   mkstat=2
   Return
Endif

# nombre de produit = 1 ?
J = 0
For I = 0 To [M:MFG1]NBLIG-1
    If [M:MFG1]ITMTYP(I) = 1 : J += 1 :  Endif
Next I
If J = 1 : mkstat = 2 : Return : Endif

# matières en cours ?
If [M:MFG2]NBLIG <> 0
    J = 0
    For I = 0 To [M:MFG2]NBLIG
        If [M:MFG2]MFGLIN(I) = [M:MFG1]MFGLIN(nolign-1) & find([M:MFG2]MATSTA(I),2,3) : J = 1 : Break: Endif
    Next I
    If J = 1 : mkstat = 2 : Return : Endif
Endif
# opérations en cours ?
If [M:MFG3]NBLIG <> 0
    J = 0
    For I = 0 To [M:MFG3]NBLIG
        If find([M:MFG3]OPESTA(I),4,5,7) : J = 1 : Break: Endif
    Next I
    If J = 1 : mkstat = 2 : Return : Endif
Endif

If [M:MFG1]NBLIG > 1
    Call CONT_MAT_CUM(WRET) From MFGLIBM
    If WRET <> 0
        Call MESSAGE(mess(55,190,1)) From GESECRAN
    Endif
Endif
Case [M:MFG1]ITMSTA(nolign-1)
    When 2,3,4   : mkstat = 2 : Return    # en cours ou soldé
    When Default   : # rien
Endcase
# si OF jalonné, message
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : Return : Endif

# V6 Affectations
Gosub TEST_ANU_LIG From MFGMTOLIB

# Issue X3-48941 - 2017-08-23 by JUSYN : Display info message when to delete a versioned product in a multi-product
#                                        and audit records are available for this product.
If dim([M:MFG1]ECCVALMAJ) > 0 # Issue X3-55832
  If (GMFGREV = 2 and [M:MFG1]ITMTYP(nolign-1) = 1)
    # Display warning message if there is audit
    If [M:MFG1]ECCVALMAJ(nolign-1) <> ""
        WAUDIT = func ECCLIB.CHECKWOAUDIT()
        If (WAUDIT = 1)
            Call MESSAGE(mess(404,193,1)) From GESECRAN
        Endif
    Endif
  Endif
Endif  # Issue X3-55832
# Issue X3-48941 - 2017-08-23 by JUSYN - End

Return

########################################
$TEST_INSERT
Local Integer WRET

#---------------------------------#
# Test pour insertion d'une ligne #
#---------------------------------#
If [F:MTS]ITMMULT = 1 & [M:MFG1]NBLIG <> 0
    mkstat = 2
    GMODIF = 1  # pour bug moteur
    Return
Endif
Case [M:MFG0]MFGSTA
    When 4         : mkstat = 2     # clôs
    When Default   : # rien
Endcase
If !find([M:MFG1]MFGTRKFLG,0,1,3,4) : mkstat = 2 : Return : Endif
If mkstat : Return : Endif
# si OF jalonné, message
Call TST_JAL(WRET) From MFGLIBO
If WRET = 1 : mkstat = 2 : Return : Endif
Return

########################################
$TEST_VALID
#--------------------------------------------------------------#
# Test pour validation article(s) lancé(s)                     #
#--------------------------------------------------------------#
Return

########################################################################
$LIENS_LIG
Local Integer LIG : LIG=nolign-1
Local Char LUSCAV(5)
Local Char LFMT(10)
Local Integer LMODIF

#----- Chargement sections analytiques -----#
Call CHARG_ACCCCE(LIG,"","","[M:MFG1]CCE","MFI",0,[F:MFI]MFGNUM,[F:MFI]MFGLIN,0,"") From TRTX3CPT


If dim([M:MFG1]TSICOD1(LIG))>0 [M:MFG1]TSICOD1(LIG)=[F:MFI]TSICOD(0) : Endif
If dim([M:MFG1]TSICOD2(LIG))>0 [M:MFG1]TSICOD2(LIG)=[F:MFI]TSICOD(1) : Endif
If dim([M:MFG1]TSICOD3(LIG))>0 [M:MFG1]TSICOD3(LIG)=[F:MFI]TSICOD(2) : Endif
If dim([M:MFG1]TSICOD4(LIG))>0 [M:MFG1]TSICOD4(LIG)=[F:MFI]TSICOD(3) : Endif
If dim([M:MFG1]TSICOD5(LIG))>0 [M:MFG1]TSICOD5(LIG)=[F:MFI]TSICOD(4) : Endif
Case [F:MFI]ITMTYP
    When 2 :      [M:MFG1]XMFGLIN(LIG) = [F:MFI]ITMLIN     # sous-produit
    When Default: [M:MFG1]XMFGLIN(LIG) = [F:MFI]MFGLIN
Endcase

If [F:MFI]FMI = 5
    [M:MFG1]XFMI(LIG) = 2
Else
    [M:MFG1]XFMI(LIG) = 1
Endif
Case [F:MFI]ITMTYP
    When 2:          # récupération identification pièce origine sous-produit
                     Read [ORD]ORD0=9;[F:MFI]WIPNUM;[F:MFI]ITMREF
    When Default:    # récupération identification pièce origine
                     Read [ORD]ORD0=5;[F:MFI]WIPNUM;[F:MFI]ITMREF
Endcase
If !fstat:
    [M:MFG1]VCRTYPORI(LIG) = [F:ORD]VCRTYPORI
    [M:MFG1]VCRNUMORI(LIG) = [F:ORD]VCRNUMORI
Endif

Read [ITM]ITM0=[F:MFI]ITMREF
#If !fstat : [M:MFG1]ITMDES1(LIG)=[F:ITM]ITMDES1 : Endif
If !fstat
  Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MFG1]ITMDES1(LIG), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
Endif

Read [ITF]ITF0=[F:MFI]ITMREF;[F:MFI]MFGFCY
If !fstat : [M:MFG1]SHR(LIG)=[F:ITF]SHR : Endif

# V6 Règle affectation
[M:MFG1]PTOCOD(LIG) = func ITMLIB.GET_PTOCOD([M:MFG1]ITMREF(LIG),[M:MFG0]MFGFCY)

Read [TBO]TBO0=2;[F:MFI]BOMALT
# FGR 16/09/2009 : X3SUIVI57824
#If !fstat : [M:MFG1]TBOSHO(LIG)=[F:TBO]TBOSHO : Endif
If !fstat Then
  Call LECTEXTRA([M:MFG1]TBOSHO(LIG),"TABBOMALT","TBOSHOAXX",num$([F:TBO]BOMALTTYP),num$([F:TBO]BOMALT)) From ATEXTRA
Endif

Case [F:MFI]BPCTYPDEN
    When 1: Read [FCY]FCY0=[F:MFI]BPCNUM
            If !fstat : [M:MFG1]BPCDES(nolign-1)=[F:FCY]FCYSHO : Endif
    When 2: Read [BPC]BPC0=[F:MFI]BPCNUM
            If !fstat : [M:MFG1]BPCDES(nolign-1)=[F:BPC]BPCSHO : Endif
Endcase


# 12.07 mm 43353 - ne pas recharger la valeur du coeff avec celui de la fiche article
Local Decimal LCOE
Call CTLUOM ([M:MFG1]ITMREF(LIG), 3, "", [M:MFG1]UOM(LIG), LCOE , LUSCAV, LFMT, LMODIF) From STKACT
If find(LUSCAV,"S","C")
    If LUSCAV = "S" : LMODIF = 1 : Endif
    If LMODIF=2 : Actzo [M:MFG1]UOMSTUCOE(LIG) : Else : Diszo [M:MFG1]UOMSTUCOE(LIG) : Endif
Endif

# Issue 110957 - 2015-09-17 by CCC
If dim([M:MFG1]CRID)>0 & varmode([M:MFG1]CRID(LIG))<>3
    [M:MFG1]CRID(LIG) = func TRTX3FNC.CCMID([M:MFG1]ITMREF(LIG),
&                                           func TRTX3FNC.VALFLD_C("[M:MFG1]ECCVALMAJ("+num$(LIG)+")"),
&                                           func TRTX3FNC.VALFLD_C("[M:MFG1]ECCVALMIN("+num$(LIG)+")"))
    If dim([M:MFG1]CRFLG)>0 & varmode([M:MFG1]CRFLG(LIG))<>3
        [M:MFG1]CRFLG(LIG) = string$([M:MFG1]CRID(LIG)<>"","151")
    Endif
Endif

Return

########################################################################
$INICRE_LIG
#----------------------------#
# Avant le Write de la ligne #
#----------------------------#
Local Integer LIG  : LIG=nolign-1
Local Integer WRET : WRET=0
Local Integer WCPT : WCPT = 9
Local Integer WRET
Local Char    WMESS(255)
Local Char    WLOTCOU(GLONANM)

Call LECT_FICLIG(LIG) From SUBMFGB
Gosub CHARGLIGNE
[F:MFI]MFGNUM=[M:MFG0]MFGNUM

If [F:ITF]STOMGTCOD > 1 : # Issue 162110 GH 24/09/2019
  # récupération compteur encours
  #Call NUMERO(GWIP,[F:MFI]MFGFCY,[M:MFG1]STRDAT,"",[F:MFI]WIPNUM,STAT) From SUBANM
  Call NUMERO(7,8,GWIP,[F:MFI]MFGFCY,[M:MFG1]STRDAT,"",[F:MFI]WIPNUM,STAT) From TRTX3TCA
  If GOK < 0 : Return : Endif
  If STAT <> 0
      GMESSAGE = "WIP"-GMESSAGE  # pour import
      OK = 0 : GERR = 1
      Return
  Endif
Endif

# 10.05 32769
If ([F:ITM]LOTMGTCOD > 1 & ([F:MFI]MFGSTA = 1 & find(GLOTMGT,2,3)) | ([F:MFI]MFGSTA = 2 & GLOTMGT = 2))
    If [M:MFG1]LOT(LIG) = "" | [M:MFG1]LOT(LIG) = mess(62,193,1)
        Case [M:MFG1]GESLOT(LIG)
            When "C" :
            #Issue X3-74333 - 2018-03-19 by YARAM : Generate LOT when geslot = C, LOT = Calculated or "", LOTAFF = 1 or 2 or 3 and LOTMGT = 2 or 3
            #If [M:MFG1]GESLOT(LIG) = "C" | ([M:MFG1]GESLOT(LIG) = "" & [F:MTS]LOTAFF > 1)
                              # X3-167553 - use GSTKCPT(7) instead of GLOT
                              If [F:ITM]LOTCOU <> "" : WLOTCOU = [F:ITM]LOTCOU : Else : WLOTCOU = GSTKCPT(7) : Endif
                              Call NUMERO(WLOTCOU,[M:MFG0]MFGFCY,[M:MFG1]STRDAT, [F:ITM]ITMREF, [F:MFI]LOT,WRET) From SUBANM
                              If WRET
                                  Case WRET
                                      When 1  : GMESSAGE = WLOTCOU-":"-mess(12,114,1)  : # Compteur inexistant
                                      When 2  : GMESSAGE = WLOTCOU-":"-mess(13,114,1)  : # Dépassement de compteur
                                      When 3  : GMESSAGE = WLOTCOU-":"-mess(20,101,1)  : # Exercice non ouvert
                                      When 4  : GMESSAGE = WLOTCOU-":"-mess(111,123,1) : # Longueur incorrecte
                                      When 99 : GMESSAGE = WLOTCOU-":"-mess(135,133,1) : # Compteur verrouillé
                                  Endcase
                                  GERR=1 : GOK=0 : Return
                              Endif
            When "V" : [F:MFI]LOT = [F:MFG]MFGNUM
        Endcase
    Endif
# 01.06 33394
Else
    If [M:MFG1]LOT(LIG) = mess(62,193,1) : [F:MFI]LOT = "" : Endif
Endif

# point d'entrée  pour mise à jour de zones supplémentaires sur [MFI]
GPOINT = "MFIMAJ" : Gosub ENTREE From EXEFNC
#

Return

########################################################################
$INIMOD_LIG
Local Integer WRET : WRET=0
Local Char    WMSGA(80)
Local Char    WMSGB(80)

#------------------------------#
# Avant le Rewrite de la ligne #
#------------------------------#
Gosub CHARGLIGNE
Call LECT_FICLIG(LIG) From SUBMFGB

# Issue 162110 GH 24/09/2019
Local Char W162110(GLONVCR)
If [F:ITF]STOMGTCOD < 2
   W162110=[F:MFI]WIPNUM : [F:MFI]WIPNUM = ""
Endif

#If ([F:ITM]LOTMGTCOD > 1 & ([F:MFI]MFGSTA = 1 & find(GLOTMGT,2,3)) & [F:MFI]LOT = "")
# Issue 112524 - 2015-12-08 by BEEBE : value of a not calculated Lot could be "(Calculated)" too (instead of "")
If ([F:ITM]LOTMGTCOD > 1 & ([F:MFI]MFGSTA = 1 & find(GLOTMGT,2,3)) & ([F:MFI]LOT = "" | [F:MFI]LOT = mess(62,193,1)))
    Case [M:MFG1]GESLOT(LIG)
        When "C" :
        #Issue X3-74333 - 2018-03-19 by YARAM : Generate LOT when geslot = C, LOT = Calculated or "", LOTAFF = 1 or 2 or 3 and LOTMGT = 2 or 3
        #When "C","" : If [M:MFG1]GESLOT(LIG) = "C" | ([M:MFG1]GESLOT(LIG) = "" & [F:MTS]LOTAFF > 1)    # 39141 mm 01.07
                    # X3-167553 - use GSTKCPT(7) instead of GLOT
                    If [F:ITM]LOTCOU <> "" : WLOTCOU = [F:ITM]LOTCOU : Else : WLOTCOU = GSTKCPT(7) : Endif
                       Call NUMERO(WLOTCOU,[M:MFG0]MFGFCY,[M:MFG1]STRDAT, [F:ITM]ITMREF, [F:MFI]LOT,WRET) From SUBANM
                       If WRET
                           Case WRET
                               When 1  : GMESSAGE = WLOTCOU-":"-mess(12,114,1)  : # Compteur inexistant
                               When 2  : GMESSAGE = WLOTCOU-":"-mess(13,114,1)  : # Dépassement de compteur
                               When 3  : GMESSAGE = WLOTCOU-":"-mess(20,101,1)  : # Exercice non ouvert
                               When 4  : GMESSAGE = WLOTCOU-":"-mess(111,123,1) : # Longueur incorrecte
                               When 99 : GMESSAGE = WLOTCOU-":"-mess(135,133,1) : # Compteur verrouillé
                           Endcase
                           GERR=1 : GOK=0 : Return
                       Endif
        When "V" : [F:MFI]LOT = [F:MFG]MFGNUM
    Endcase
Endif
Return

########################################################################
$VALLIG
#---------------------------------------------------#
# Traitements complementaires effectués à la ligne  #
# SIGN   vaut +1 en création / modification         #
#             -1 en annulation                      #
# TRTLIG vaut "C","M","A" en créa, modif, annule    #
# l'enregistrement "ligne" est en ligne             #
#---------------------------------------------------#
Local Char    TRTORD(1)
#
If SIGN = 1
#----- Ecriture des sections de la ligne article lancé -----#
     Gosub MAJMFI_CPTANALIN
     If GOK<1
         Return
     Endif
Else
    If TRTLIG = "A"
    #----- Suppression des sections de la ligne article lancé -----#
        #Delete [CAL] Where ABRFIC="MFI" & VCRNUM=[F:MFI]MFGNUM & VCRLIN=[F:MFI]MFGLIN
        # Issue 119469 GH 04/11/16 - performance enhancement
        Delete [CAL] Where ABRFIC="MFI" & VCRNUM=[F:MFI]MFGNUM & VCRLIN=[F:MFI]MFGLIN & VCRTYP=0
        If fstat=1
          GOK=-1 : GLOCK="$CPTANALIN MFI 0"-[F:MFI]MFGNUM-num$([F:MFI]MFGLIN) : Return
        Endif
    Endif
Endif

Gosub UPDATE_MAT
Gosub UPDATE_ORDERS
#----- Mise à jour statistiques ligne article lancé -----#
Call VALSTA("MFI",SIGN) From SUBPS2
#
Return

########################################################################
$RAZCRE

Call RAZ_CLOB From ACLOB
Call FIND_GFCYDEF(8) From TRTX3  # FQ 54218

Raz [M:MFG0]MFGTEX
Raz [M:MFG3]MFOTEX
Raz [M:MFG2]MFMTEX
Gosub CHARG_PARAM
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL


Case [F:MTS]SCDMODSAI
    When 1:        [M:MFG1]SCDMOD = 1
    When 2:        [M:MFG1]SCDMOD = 2
    When Default:  [M:MFG1]SCDMOD = 1
Endcase
GEXTQTY = 0
GFLGMAT  = 0

[M:MFG1]SCDFLG = 1
[M:MFG1]ALLSTA = 1
[M:MFG1]MFGTRKFLG = 1
[M:MFG1]DALLSTA = 1

# 10.08
[M:MFG1]DOVRALLNBR = 0
[M:MFG1]DDETALLNBR = 0
[M:MFG1]DSHTMATNBR = 0
[M:MFG1]DMATCLENBR = 0
[M:MFG1]DOPECLENBR = 0

[M:MFG3]SCDFLG = 1
[M:MFG3]SCDMOD = [M:MFG1]SCDMOD
[M:MFG1]XALLSTA = mess(1,336,1)
[M:MFG1]XSCDFLG = mess(1,335,1)
[M:MFG1]XTRKFLG = mess(1,339,1)
[M:MFG4]PICLISFLG = 1
[M:MFG4]ROUSHEFLG = 1
[M:MFG4]LABTIKFLG = 1
[M:MFG4]MFGTIKFLG = 1
[M:MFG4]TECCRDFLG = 1
[M:MFG4]MFGFDRFLG = 1
If !GIMPORT
    Call RESET_IMAGE (4) From GESECRAN
    Diszo [M:MFG4]PICLISFLG
    Diszo [M:MFG4]ROUSHEFLG
    Diszo [M:MFG4]LABTIKFLG
    Diszo [M:MFG4]MFGTIKFLG
    Diszo [M:MFG4]TECCRDFLG
    Diszo [M:MFG4]LBEMAN
    Diszo [M:MFG4]LBEAUT
    # Issue 110957 - 2015-09-17 by CCC
    If dim([M:MFG1]CRID)>0 : Diszo [MFG1]CRID : Endif
    If dim([M:MFG2]CRID)>0 : Diszo [MFG2]CRID : Endif
Endif
GOK = 1
Return

############################################################mf############
$RAZDUP
Local Integer WRET
Local Integer WZERO

Call RAZ_CLOB From ACLOB

If GMANCOU <> 2 : [M:MFG0]MFGNUM = "" : Endif

Case [F:MTS]SCDMODSAI
    When 1:        [M:MFG1]SCDMOD = 1
    When 2:        [M:MFG1]SCDMOD = 2
    When Default:  [M:MFG1]SCDMOD = 1
Endcase
GEXTQTY = 0
GFLGMAT  = 0

If [M:MFG0]MFGSTA>2 [M:MFG0]MFGSTA = 2 Endif # FQ 71606 Duplication OF Clos
[M:MFG1]SCDFLG = 1
[M:MFG1]ALLSTA = 1
[M:MFG1]MFGTRKFLG = 1
[M:MFG1]DALLSTA = 1
[M:MFG0]OBJDAT = [M:MFG1]ENDDAT : # Issue 119988 GH 12/01/2017 - Resetting of the objective date

# 10.08
[M:MFG1]DOVRALLNBR = 0
[M:MFG1]DDETALLNBR = 0
[M:MFG1]DSHTMATNBR = 0
[M:MFG1]DMATCLENBR = 0
[M:MFG1]DOPECLENBR = 0

[M:MFG3]SCDFLG = 1
[M:MFG3]SCDMOD = [M:MFG1]SCDMOD
[M:MFG1]XALLSTA = mess(1,336,1)
[M:MFG1]XSCDFLG = mess(1,335,1)
[M:MFG1]XTRKFLG = mess(1,339,1)
[M:MFG1]MFGCPLQTY  = 0
[M:MFG4]PICLISFLG = 1
[M:MFG4]ROUSHEFLG = 1
[M:MFG4]LABTIKFLG = 1
[M:MFG4]MFGTIKFLG = 1
[M:MFG4]TECCRDFLG = 1
[M:MFG4]MFGFDRFLG = 1

If left$([M:MFG0]MFGTEX,3)="MFG"
  Call DUP_CLOB("MFG",[M:MFG0]MFGTEX,WRET) From TRTX3TEX
  If WRET < 1 : Raz [M:MFG0]MFGTEX : Endif
Endif

# raz articles lancés
For I = 0 To [M:MFG1]NBLIG - 1
    [M:MFG1]MFITRKFLG(I) = 1
    [M:MFG1]CPLQTY(I)    = 0
    [M:MFG1]QUACPLQTY(I) = 0   # Issue 78069 - 2011-11-25 by CCC
    [M:MFG1]REJCPLQTY(I) = 0   # Issue 78069 - 2011-11-25 by CCC
    [M:MFG1]ITMSTA(I)    = 1
    [M:MFG1]GESLOT(I)    = ""  # Issue 83305 GA 07/2012
    [M:MFG1]LOT(I)       = ""
    [M:MFG1]BPCTYPDEN(I) = 1
    [M:MFG1]BPCNUM(I)    = [M:MFG0]MFGFCY
    Call LECTURE("FCY", [M:MFG0]MFGFCY, "") From CONTOBJ
    [M:MFG1]BPCDES(I) = [F:FCY]FCYSHO

    Call LECTURE("ITM", [M:MFG1]ITMREF(I), "") From CONTOBJ
    # si pas de gestion de lot, on sort
    If [F:ITM]LOTMGTCOD > 1
        If clalev([F:SRU])<=0 : Local File TABSTORUL  [SRU] : Endif
        # Lecture de la règle de gestion à utiliser
        Call LECSRU([M:MFG0]MFGFCY,[F:ITM]TCLCOD, 5, "", "", WRET)
&           From STKLIB
        # gestion lot
        If [F:ITM]LOTCOU = ""
           If !WRET & [F:SRU]LOTSUPINH=3
              [M:MFG1]GESLOT(I)    = "V"
           Else
             # Issue 83305 GA 07/2012 If [F:ITM]LOTMGTCOD > 1
              If [F:SRU]LOTSUPINH > 1
                 [M:MFG1]GESLOT(I) = "C"
              Endif
           Endif
        Else
           [M:MFG1]GESLOT(I)       = "C"
        Endif
        If [F:MTS]LOTAFF > 1 | find([M:MFG1]GESLOT(I),"C","V"): [M:MFG1]LOT(I) = mess(62,193,1) : Endif
    Endif

    [M:MFG1]VCRTYPORI(I) = 0
    [M:MFG1]VCRNUMORI(I) = ""
    [M:MFG1]VCRLINORI(I) = 0
    [M:MFG1]VCRSEQORI(I) = 0
    [M:MFG1]FMI(I)       = 1
Next I

# raz composants
For I = 0 To [M:MFG2]NBLIG - 1
    [M:MFG2]MFMTRKFLG(I) = 1
    [M:MFG2]ALLSTA(I) = 1
    [M:MFG2]USEQTY(I) = 0
    [M:MFG2]ALLQTY(I) = 0
    [M:MFG2]SHTQTY(I) = 0
    [M:MFG2]WIPNUM(I) = ""
    [M:MFG2]PRPSTA(I) = 1
    [M:MFG2]MATSTA(I)    = 1
    [M:MFG2]XMATSTA(I) = mess([M:MFG2]MATSTA(I),363,1)

    If left$([M:MFG2]MFMTEX(I),3)="MFM"
      Call DUP_CLOB("MFM",[M:MFG2]MFMTEX(I),WRET) From TRTX3TEX
      If WRET < 1 : Raz [M:MFG2]MFMTEX(I) : Endif
    Endif

Next I
# si opérations de sous-traitance au moins commandée (donc en fraction > 0), il faut remettre
# toute la quantité en attente sur une fraction 0
WZERO = -1
For I = 0 To [M:MFG3]NBLIG - 1
    If WZERO <> -1
        If [M:MFG3]OPENUM(I) <> [M:MFG3]OPENUM(WZERO) : WZERO = -1 : Endif
    Endif
    If [M:MFG3]WSTTYP(I) = 3
        If [M:MFG3]OPESPLNUM(I) = 0 : WZERO = I : Endif
        If [M:MFG3]OPESPLNUM(I) > 0
            If WZERO = -1 : WZERO = I : [M:MFG3]OPESPLNUM(I) = 0 : Endif
            If I <> WZERO
                # incrémentation qté
                [M:MFG3]EXTQTY(WZERO) += [M:MFG3]EXTQTY(I)
                Call QTEARR([M:MFG3]EXTQTY(WZERO),[M:MFG3]OPEUOM(WZERO)) From TRTDIV
                Call UPD_OPE_UNI(2, "MFG3", 0, [M:MFG3]EXTQTY(WZERO)) From MFGLIBO
                [M:MFG3]EXTSTUQTY(I) = [M:MFG3]EXTQTY(WZERO) / [M:MFG3]OPESTUCOE(WZERO)
                Call QTEARR([M:MFG3]EXTSTUQTY(WZERO),[M:MFG1]MFGSTU) From TRTDIV
                [M:MFG3]EXTSTRQTY(WZERO) =  [M:MFG3]EXTQTY(WZERO) * [M:MFG3]OPESTRCOE(WZERO)
            Endif
        Endif
    Endif
Next I

# on enlève les fractions > 0
For I = 0 To [M:MFG3]NBLIG - 1
    If [M:MFG3]WSTTYP(I) = 3 & [M:MFG3]OPESPLNUM(I) > 0 : Dela I,1 [M:MFG3]NBLIG : I -= 1 : [M:MFG3]NBLIG -= 1 : Endif
Next I

# raz opérations
For I = 0 To [M:MFG3]NBLIG - 1
    [M:MFG3]MFOTRKFLG(I) = 1
    [M:MFG3]OPSNUM(I) = ""
    [M:MFG3]WIPNUM(I) = ""
    [M:MFG3]CPLQTY(I) = 0
    [M:MFG3]REJCPLQTY(I) = 0
    [M:MFG3]QUACPLQTY(I) = 0
    [M:MFG3]CPLSETTIM(I) = 0
    [M:MFG3]CPLOPETIM(I) = 0
    [M:MFG3]POHNUM(I) = ""
    [M:MFG3]POPLIN(I) = 0
    [M:MFG3]POPSEQ(I) = 0
    [M:MFG3]OPESTA(I)    = 1

    If left$([M:MFG3]MFOTEX(I),3)="MFO"
      Call DUP_CLOB("MFO",[M:MFG3]MFOTEX(I),WRET) From TRTX3TEX
      If WRET < 1 : Raz [M:MFG3]MFOTEX(I) : Endif
    Endif
Next I

If !GIMPORT
    Call RESET_IMAGE (4) From GESECRAN
    Diszo [M:MFG4]PICLISFLG
    Diszo [M:MFG4]ROUSHEFLG
    Diszo [M:MFG4]LABTIKFLG
    Diszo [M:MFG4]MFGTIKFLG
    Diszo [M:MFG4]TECCRDFLG
    Diszo [M:MFG4]LBEMAN
    Diszo [M:MFG4]LBEAUT
Endif
Affzo [M:MFG0]
Affzo [M:MFG1]
Affzo [M:MFG2]
Affzo [M:MFG3]
Affzo [M:MFG4]
Return

########################################################################
$LIENS
# Issue X3-30339 - 2017-04-07 by ALSHE : Release WO managed by PS - block all fields except MFGSTA
If ([F:MFG]SCDFLG=4 | [F:MFG]OPTFLG = 2) & G_SCHEDULER_STATUS(0)
    Diszo [M:MFG1]5 - 25
    Diszo [M:MFG2]5 - 10
    Diszo [M:MFG3]5 - 10
    Diszo [M:MFG4]5 - 10
Else
    Actzo [M:MFG1]5 - 25
    Actzo [M:MFG2]5 - 10
    Actzo [M:MFG3]5 - 10
    Actzo [M:MFG4]5 - 10
Endif

Call RAZ_CLOB From ACLOB

#  le site de planification n'est pas modifiable, par contre le site de prod
#  peut être modifié

#If GFCY<>[F:MFG]PLNFCY : GFCY=[F:MFG]PLNFCY : Gosub CHARG_PARAM : # GH 19/11/13 bug 94573
If GFCY<>[F:MFG]MFGFCY : GFCY=[F:MFG]MFGFCY : Gosub CHARG_PARAM
Else Call ACTUALIS_FMTDIE([F:MFG]MFGFCY,"MTS",1,GMTSNUM)From TRTX3CPT
Endif
#
#----- Affichage entêtes de colonne variables -----#
Gosub AFF_TITCOL

GMEMSTA = [F:MFG]MFGSTA
GSCDFLG = [F:MFG]SCDFLG
GJALFLG = 0
GLOADFLG = 0

# (pour faciliter la migration)
If [F:MFG]OBJDAT <> [0/0/0]
    [M:MFG0]OBJDAT = [F:MFG]OBJDAT
Else
    [M:MFG0]OBJDAT = [F:MFG]ENDDAT
Endif
If find([F:MFG]MFGMOD,1,3)
    Read [ROH]ROH0=[F:MFG]ROUNUM;[F:MFG]ROUALT;[F:MFG]MFGFCY : # Beryl Site en fin de clé primaire
    If !fstat : [M:MFG1]WORTYP = [F:ROH]WORTYP : Endif
Else
    [M:MFG1]WORTYP = GDEFWORTYP            # 11.07
Endif
#
If !GIMPORT
    Diszo [M:MFG1]MFGEXTQTY
    Diszo [M:MFG1]MFGSTU
    Diszo [M:MFG1]XALLSTA
    Diszo [M:MFG1]XTRKFLG
    # Issue 110957 - 2015-09-17 by CCC
    If dim([M:MFG1]CRID)>0 : Diszo [MFG1]CRID : Endif
    If dim([M:MFG2]CRID)>0 : Diszo [MFG2]CRID : Endif
Endif
[M:MFG0]XMFGMOD       =[F:MFG]MFGMOD
Case [F:MFG]TYPMOD
    When 1:    [M:MFG0]FLGMOD = 2
    When 2:    [M:MFG0]FLGMOD = 1
Endcase
If !GIMPORT
# Issue X3-30339 - 2017-04-07 by ALSHE : Release WO managed by PS - block all fields except MFGSTA
#    If find([F:MFG]MFGMOD,1,3)
    If find([F:MFG]MFGMOD,1,3) & !(([F:MFG]SCDFLG=4 | [F:MFG]OPTFLG = 2) & G_SCHEDULER_STATUS(0))
        Actzo [M:MFG1]25
    Else
        Grizo [M:MFG1]25
    Endif
Endif
[M:MFG1]STRDAT        =[F:MFG]STRDAT
[M:MFG1]ENDDAT        =[F:MFG]ENDDAT
[M:MFG1]MFGEXTQTY     =[F:MFG]EXTQTY
[M:MFG1]MFGCPLQTY     =[F:MFG]CPLQTY
[M:MFG1]MFGSTU        =[F:MFG]STU
[M:MFG1]DALLSTA       =[F:MFG]ALLSTA
[M:MFG1]DMATNBR       =[F:MFG]MATLINNBR
[M:MFG1]DOPENBR       =[F:MFG]OPELINNBR
[M:MFG1]DOVRALLNBR    =[F:MFG]OVRALLNBR
[M:MFG1]DDETALLNBR    =[F:MFG]DETALLNBR
[M:MFG1]DSHTMATNBR    =[F:MFG]SHTMATNBR
[M:MFG1]DMATCLENBR    =[F:MFG]MATCLENBR
[M:MFG1]DOPECLENBR    =[F:MFG]OPECLENBR
[M:MFG2]MFGEXTQTY     =[F:MFG]EXTQTY
[M:MFG2]MFGSTU        =[F:MFG]STU
[M:MFG1]SCDFLG        =[F:MFG]SCDFLG
[M:MFG1]ALLSTA        =[F:MFG]ALLSTA
[M:MFG1]MFGTRKFLG     =[F:MFG]MFGTRKFLG
[M:MFG1]XALLSTA = mess([M:MFG1]ALLSTA,336,1)
[M:MFG1]XSCDFLG = mess([M:MFG1]SCDFLG,335,1)
[M:MFG1]XTRKFLG = mess([M:MFG1]MFGTRKFLG,339,1)

# en cours d'optimisation
If [F:MFG]OPTFLG = 2
    [M:MFG1]MFGTRKFLG = 2
    [M:MFG1]XTRKFLG = mess([M:MFG1]MFGTRKFLG,339,1)                # 05.05 30050
Endif

If [M:MFG0]MFGMOD = 2 : [M:MFG1]ROUNUM = "" : Endif

# article(s) lancé(s)
Gosub LIENS From SUBMFG1 # FQ 50547 avant From TABLEAUX
# liste des matières
Gosub LIENS From SUBMFG2
# liste des opérations
Gosub LIENS From SUBMFG3
# impression
Gosub LIENS From SUBMFG4
#
GASW=0 # Issue 95046 GA 12/2013 réinit pour que le 1er appel à TST_JAL renvoie un message
#
[M:MFG1]MFGPIO        = [F:MFG]MFGPIO
[M:MFG1]STRDAT        = [F:MFG]STRDAT
[M:MFG1]ENDDAT        = [F:MFG]ENDDAT

#------------------------#
# affichage icone texte  #
#------------------------#
If !GIMPORT
    If [M:MFG0]MFGTEX <> ""
        Call SET_IMAGE (4) From GESECRAN
    Else
        Call RESET_IMAGE (4) From GESECRAN
    Endif
Endif

# Pour visu des textes si OF clos - FQ 65904 GA 07/2010
If [F:MFG]MFGSTA=4
   GCONSDIA=2
Else
   GCONSDIA=0
Endif
Return

########################################################################
# Issue 119469 GH 04/11/16 - performance enhancement
$STYLE
Call HIGHLIGHT("MFG1",-2) From ECCLIB
Call HIGHLIGHT("MFG2",-2) From ECCLIB
Return

########################################################################
$VERIF_CRE
Gosub VERIF
Return

########################################################################
$VERIF_MOD
Gosub VERIF
Return

########################################################################
$VERIF
# Issue 101042 GH 04/11/2019 - WO should have one released product at least
If [M:MFG1]NBLIG=0
    GMESSAGE = mess(43,193,1)
    OK = 0
    Return
Endif
If find([M:MFG0]MFGMOD,1,3) & [M:MFG1]ROUALT = 0
    GMESSAGE = mess(74,193,1)
    OK = 0
    Return
Endif
# nouveaux controles 09.01
If [M:MFG1]STRDAT = [0/0/0]
    GMESSAGE = mess(170,193,1)
    OK = 0
    Return
Endif
If [M:MFG1]ENDDAT = [0/0/0]
    GMESSAGE = mess(171,193,1)
    OK = 0
    Return
Endif
# 03.06 35117
Local Integer WALT
If find([M:MFG0]MFGMOD,1,2)
    For I = 0 To [M:MFG1]NBLIG - 1
        If [M:MFG1]ITMTYP(I) = 1
            WALT = [M:MFG1]BOMALT(I)

            # 03.06 + 36825 mm 07.06
            Read [TBO]TBO0=2;WALT
            If fstat
               GMESSAGE = mess(154,193,1)
               OK=0 : Break
            Endif

            Read [BOH]BOH0=[M:MFG1]ITMREF(I);WALT;2
            If fstat
                GMESSAGE = mess(95,193,1)
                OK = 0 : Break
            Endif
            Call CONTMFGNOM([M:MFG0]MFGFCY, WALT, [M:MFG1]STRDAT, 1) From MFGLIB
            If WALT = 0 : OK = 0 : Break : Endif
        Endif
    Next I
Endif
If !OK : Return : Endif

# 107513
For I = 0 To [M:MFG1]NBLIG - 1
    If [M:MFG1]ITMERRCOD(I)=4
&    | [M:MFG1]ITMERRCOD(I)=1 & [M:MFG1]ITMTYP(I)=1
&    | [M:MFG1]ECCERRCOD(I)=4
&    | [M:MFG1]ECCERRCOD(I)=1 & [M:MFG1]ITMTYP(I)=1
        GMESSAGE = mess(68,190,1)-mess(93,100,1)-num$(I+1)
        OK=0 : Break
    Endif
Next
If !OK : Return : Endif

For I = 0 To [M:MFG2]NBLIG - 1
    If [M:MFG2]ITMERRCOD(I)=4
&      | [M:MFG2]ECCERRCOD(I)=4
        GMESSAGE = mess(11,2324,1)-mess(93,100,1)-num$(I+1)
        OK=0 : Break
    Endif
Next
If !OK : Return : Endif

Return

########################################################################
$INICRE
Local Integer I, J, K, STAT, OK

# 19371 10.03 MM
# vérification absence composant non utilisable
If [M:MFG0]CMPUSBFLG=2
    Call ERREUR (mess(218,193,1)) From GESECRAN     #Un composant non utilisable interdit la création de cet OF
    GOK=0 : Return
Endif

# vérification présence de composants et opérations
If [M:MFG2]NBLIG = 0 & [M:MFG0]MFGMOD = 1
    OK=1
    Call OUINON(mess(109,190,1),OK) From GESECRAN
    If OK <> 2 : GOK = 0 : Return : Endif
Endif

If [M:MFG3]NBLIG = 0  & [M:MFG0]MFGMOD = 1
    OK=1
    Call OUINON(mess(110,190,1),OK) From GESECRAN
    If OK <> 2 : GOK = 0 : Return : Endif
Endif

# vérification de la cohérence des liens entre composants et opérations
If [M:MFG2]NBLIG <> 0 & [M:MFG0]MFGMOD = 1
    K = 0
    For I = 0 To [M:MFG2]NBLIG - 1
        If [M:MFG2]BOMOPE(I) <> 0 & [M:MFG2]MATSTA(I) <> 4
            If [M:MFG3]NBLIG = 0
                OK=1
                Call OUINON(mess(146,193,1),OK) From GESECRAN
                If OK <> 2 : GOK = 0 : Return : Endif
                Break
            Else
                If !find([M:MFG2]BOMOPE(I),[M:MFG3]OPENUM(0..[M:MFG3]NBLIG - 1))
                    OK=1
                    Call OUINON(mess(146,193,1),OK) From GESECRAN
                    If OK <> 2 : GOK = 0 : Return : Endif
                    Break
                Endif
                For J = 0 To [M:MFG3]NBLIG - 1
                    If [M:MFG3]OPENUM(J) = [M:MFG2]BOMOPE(I)
                        If [M:MFG3]OPESTA(J) = 6
                            OK=1
                            Call OUINON(mess(146,193,1),OK) From GESECRAN
                            If OK <> 2 : GOK = 0 : Return : Endif
                            K = 1
                            Break
                        Endif
                    Endif
                Next J
                If K : Break : Endif
            Endif
        Endif
    Next I
Endif
# point d'entrée  pour surcharger le numéro d'OF
GPOINT = "RECUP_NOF" : Gosub ENTREE From EXEFNC

If GMANCOU <> 2 | (GMANCOU = 2 & vireblc([M:MFG0]MFGNUM,2) = "")
   #Call NUMERO(GCODNUM,GFCY,[M:MFG1]STRDAT,"",[M:MFG0]MFGNUM,STAT) From SUBANM
   Call NUMERO(8,0,GCODNUM,GFCY,[M:MFG1]STRDAT,"",[M:MFG0]MFGNUM,STAT) From TRTX3TCA
   If GOK < 0 : Return : Endif
   If STAT <> 0
       GMESSAGE = GCODNUM-mess(60,199,1) # pour import
       GOK=0
       Goto ERR_CREATION
    Endif
Endif
[F:MFG]MFGNUM=[M:MFG0]MFGNUM
Gosub CHARGENTETE
If    [M:MFG0]MFGTEX <> ""
          [F:MFG]MFGTEX  = [M:MFG0]MFGTEX
           If left$([F:MFG]MFGTEX,3)="MFG"
                  Call CRE_CLOB([F:MFG]MFGTEX,GOK) From TRTX3TEX
                  If GOK<1 Return Endif
           Elsif !find(left$([F:MFG]MFGTEX,3),"ITM","ROH")
                  Call DUP_CLOB("MFG",[F:MFG]MFGTEX,GOK) From TRTX3TEX
                  If GOK<1 Return Endif
           Endif
Endif

# FQ 50547 GA 06/2009
# trier les articles lancés/sous-produits
Gosub TRI_MFGITM
Return

#########################################################
# tri du tableau des articles lancés (avant renumérotation par $CREATION)
$TRI_MFGITM
Sorta [M:MFG1]NBLIG [M:MFG1]NBLIG Order By [M:MFG1]MFGLIN(indice), [M:MFG1]ITMREF(indice)
Return

########################################################################
$CREATION
Gosub CREATION From SUBMFG1    # FQ 50547 avant From TABLEAUX
If GOK<1 : Goto ERR_CREATION : Endif
Gosub CREATION From SUBMFG2    # pour gestion onglet matières
Gosub CREATION From SUBMFG3    # pour gestion onglet opérations
Gosub CREATION From SUBMFG4    # pour gestion onglet impression

Gosub MAJMFGHEAD From MFGLIB   # FQ 73330 GA 04/2011 maj de l'entete (si alloc auto par exemple)
Rewrite [MFG]                  # FQ 73330 GA 04/2011 le Write est déjà fait

#----- Mise à jour statistiques entête d'OF -----#
Call VALSTA("MFG",1) From SUBPS2
If GOK < 1 : Goto ERR_CREATION : Endif
Return

$ERR_CREATION
Raz [M:MFG0]MFGNUM
Return

#######################################################################
$AB_CREATION
#Abandon création suite à une erreur
Return

########################################################################
$AVANT_MOD
# 35458 mm 09.06

If [M:MFG1]MFGTRKFLG=3 & GMODSTAT = 1
    OK = 0
    GMODSTAT = 0
Endif
Return

# Before a button is pressed (Save, Create)
$AVANTACT
# Issue X3-30931 - 2017-05-03 by CCC : If the WO has been modified by PS, display an error message to avoid the record of modifications
If BOUT="E" & ([F:MFG]SCDFLG=4 | [F:MFG]OPTFLG = 2) & G_SCHEDULER_STATUS(0) & dim([L]AUPDTICK)>0 & dim([F]updTick)>0
    Filter [MFG] Where MFGNUM=[M:MFG0]MFGNUM & [F:MFG]updTick=[L]AUPDTICK
    Look [F:MFG] First
    Filter [MFG]
    If fstat
        # This WO has been modified in parallel by Production Scheduler. Please cancel and modify again
        Call ERREUR(mess(389,193,1)) From GESECRAN
        OK=0
    Endif
Endif
Return

########################################################################
$AVANT_MODFIC
Local Integer I
Local Integer WRET

# on a viré le texte
If [M:MFG0]MFGTEX="" & [F:MFG]MFGTEX <> "" & left$([F:MFG]MFGTEX,3) = "MFG"
   Call SUP_CLOB([F:MFG]MFGTEX,WRET) From TRTX3TEX
Endif

# V6 Affectations
Gosub AVANT_MODFIC From MFGMTOLIB

Return

########################################################################
$INIMOD
Local Integer I, J, K, OK
Local Integer WALT

# 32286 09.05 MM
# vérification absence composant non utilisable
If [M:MFG0]CMPUSBFLG=2
    Call ERREUR (mess(251,193,1)) From GESECRAN     #Un composant non utilisable interdit le lancement de cet OF
    GOK = 0  : Return
Endif

If [M:MFG0]MFGMOD <> 2           # pas de controle si matières seules
    # vérification de la cohérence de la quantité lancée et la gamme
    #    Lecture ROUTING
    If [F:TRO]ROUALT <> [M:MFG1]ROUALT
        Read [TRO]TRO0=VALEUR
        If fstat : Raz [TRO] : Endif
    Endif
    If [F:ROH]ITMREF <> [M:MFG1]ROUNUM | [F:ROH]ROUALT <> [M:MFG1]ROUALT |[F:ROH]FCY <> [M:MFG0]MFGFCY
        Read [ROH]ROH0=[M:MFG1]ROUNUM;VALEUR;[M:MFG0]MFGFCY    : # Beryl Site en fin de clé primaire
        If fstat : Raz [ROH] : Endif
    Endif

    Call CONTMFGGAMMOD([M:MFG0]MFGFCY,WALT,[M:MFG1]STRDAT,[M:MFG1]MFGEXTQTY, [M:MFG1]MFGSTU, 1) From MFGLIB
    If WALT=0 : GOK = 0 : Return : Endif
Endif

# vérification de la cohérence des liens entre composants et opérations
If [M:MFG2]NBLIG <> 0
    K = 0
    For I = 0 To [M:MFG2]NBLIG - 1
        If [M:MFG2]BOMOPE(I) <> 0 & [M:MFG2]MATSTA(I) <> 4
            If [M:MFG3]NBLIG = 0
                OK=1
                Call OUINON(mess(146,193,1),OK) From GESECRAN
                If OK <> 2 : GOK = 0 : Return : Endif
                Break
            Else
                If !find([M:MFG2]BOMOPE(I),[M:MFG3]OPENUM(0..[M:MFG3]NBLIG - 1))
                    OK=1
                    Call OUINON(mess(146,193,1),OK) From GESECRAN
                    If OK <> 2 : GOK = 0 : Return : Endif
                    Break
                Endif
                For J = 0 To [M:MFG3]NBLIG - 1
                    If [M:MFG3]OPENUM(J) = [M:MFG2]BOMOPE(I)
                        If [M:MFG3]OPESTA(J) = 6
                            OK=1
                            Call OUINON(mess(146,193,1),OK) From GESECRAN
                            If OK <> 2 : GOK = 0 : Return : Endif
                            K = 1
                            Break
                        Endif
                    Endif
                Next J
                If K : Break : Endif
            Endif
        Endif
    Next I
Endif

# Issue 104504 GA 03/2015 idem JALLIBA when optimized WO: avoid to unload scheduling
GPE=0
If GSCDFLG=4 : GPOINT="OPTSCDRAZ" : Gosub ENTREE From EXEFNC : Endif
If !GPE
  #-----------------------------#
  # Chargement avant le Rewrite #
  #-----------------------------#
  If [M:MFG3]NBLIG <> 0 &
&   (([F:MTS]MODJAL = 2 & find([M:MFG3]SCDFLG,1,3)) |
&    (GSCDFLG <> [M:MFG3]SCDFLG & find(GSCDFLG,2,4) & !G_SCHEDULER_STATUS(0)) |
&     (GSCDFLG <> [M:MFG3]SCDFLG & find(GSCDFLG,2) & [F:MFG]OPTFLG <> 2 & G_SCHEDULER_STATUS(0)))
# Issue X3-30339 - 2017-04-07 by ALSHE : Release WO managed by PS
#&    (GSCDFLG <> [M:MFG3]SCDFLG & find(GSCDFLG,2,4)))
      GJALFLG = 1
      [M:JALK]CODORI = 1
      [M:JALK]CODMAJ = 0
      [M:JALK]CODTRS = 0
      [M:JALK]MFGFCY = [M:MFG0]MFGFCY
      [M:JALK]MFGNUM = [M:MFG0]MFGNUM
      [M:JALK]MFGSTA = GMEMSTA  # [M:JALK]MFGSTA = [M:MFG0]MFGSTA # Issue 38602 GH 24/04/2018
      Call DEJALONNE From JALLIBA
      # Issue 96561 GA 02/2014 rectification message avant: Call ERREUR(mess(78,193,1))
      If [M:JALK]CODRET <> 0 : Call ERREUR(mess(79,193,1)) From GESECRAN : Return : Endif
      Call FLDUPD(ABFIC) From OBJDIV : # Issue 118125 GH 28/11/16 - to reset fields such as [F:MFG]EXPNUM
  Elsif [M:MFG0]MFGSTA <> GMEMSTA & find(GSCDFLG,2,4)
      Call WORKUNLOAD([F:MFG]MFGFCY, [F:MFG]MFGNUM, [F:MFG]SCDFLG) From JALLIBB
      GLOADFLG = 1
  Endif
Endif

Gosub CHARGENTETE
If GMODSTAT = 2 : Gosub RET_PENDING : Endif    # 35458 mm 09.06
If    [M:MFG0]MFGTEX <> ""
          [F:MFG]MFGTEX  = [M:MFG0]MFGTEX
           If left$([F:MFG]MFGTEX,3)="MFG"
                  Call CRE_CLOB([F:MFG]MFGTEX,GOK) From TRTX3TEX
                  If GOK<1 Return Endif
           Elsif !find(left$([F:MFG]MFGTEX,3),"ITM","ROH")
                  Call DUP_CLOB("MFG",[F:MFG]MFGTEX,GOK) From TRTX3TEX
                  If GOK<1 Return Endif
           Endif
Endif
# Issue 66316 - 2010-08-24 by CCC : Mise à jour de ALLSTA
#      avant une éventuelle mise à jour lors de l'enregistrement des matières
# FQ 70409 GA 01/2011 performances: à faire en fin de validation uniquement
#Gosub MAJSTATUT From MFGLIBM
#[F:MFG]ALLSTA = [M:MFG1]ALLSTA
Return

########################################################################
$MODIF
Gosub MODIF From SUBMFG1     # FQ 50547 avant From TABLEAUX
If GOK<1 : Return : Endif
Gosub MODIF From SUBMFG2     # pour gestion onglet matières
Gosub MODIF From SUBMFG3     # pour gestion onglet opérations
Gosub MODIF From SUBMFG4     # pour gestion onglet impression
# FQ 70409 GA 01/2011 selon Issue 66316 - 2010-08-24 by CCC
Gosub MAJMFGHEAD From MFGLIB
Rewrite [MFG]                # FQ 73330 GA 04/2011 le Rewrite est déjà fait
# Issue X3-55431 - Reset of message flag
If dim([M:MFG1]ROUECCMAJ) > 0
  GREVMESSC = 0
Endif

Return

########################################################################
$VERROU
# 86709 mm 01.2013 - vérifier que l'OF n'est pas en cours de pesée avant de permettre de la modifier + 93179
If dim([F:MFG]WGGFLG)>0
   Read [MFG]MFG0 = [M:MFG0]MFGNUM
   If !fstat & find([F:MFG]WGGFLG,4,8)
      # modification en cours sur un autre poste
      GMESSAGE=[M:MFG0]MFGNUM-":"-mess(62,2324,1) : Return
   Endif
Endif

# ici seul [M:MFG1] n'est pas encore chargé, l'action LIENS n'a pas encore été effectuée
# 41682 mm 07.07 - si c'est un OF de contremarque, on verrouille la cmde associée
#If [M:MFG1]VCRNUMORI(0)<>""
#    SYMBOL2 = "SOH"+[M:MFG1]VCRNUMORI(0)
#    Lock = SYMBOL2 With lockwait = 0
#    OK = 1
#    If fstat
#        GMESSAGE = mess(269,193,1)-[M:MFG1]VCRNUMORI(0)- mess(270,193,1)
#        Call ECR_TRACE(GMESSAGE,1) From GESECRAN
#        Raz GMESSAGE
#        OK = 0
#        fstat = 0
#    Endif
#Endif
## GH 19/03/2013 bug 88447
Read [MFI]MFI0(1) = [M:MFG0]MFGNUM
# If !fstat & [F:MFI]VCRNUMORI<>""  : # GH 27/02/2014 bug 96537
If !fstat & [F:MFI]VCRNUMORI<>"" & [F:MFI]VCRTYPORI=2 & [F:MFI]FMI=5
    SYMBOL2 = "SOH"+[F:MFI]VCRNUMORI
    If TUNNEL & func GLOCK.LOKBYI(SYMBOL2) : # c'est moi qui locke la cde de vente en amont
       SYMBOL2 = ""
    Else
       Lock = SYMBOL2 With lockwait = 0
       If fstat
           If find(REPONSE,GSTACLK+3,GSTACLK+11,GSTAANU)
              GLOCK="%"+SYMBOL2 : # GH 26/11/2014 bug 103230
              OK=0 : # pour ne pas avoir 2 messages d'erreur
           Else
              GMESSAGE = mess(269,193,1)-[F:MFI]VCRNUMORI-mess(270,193,1)
          Endif
          Return
       Endif
    Endif
Endif

Return

########################################################################
$DEVERROU
# GH 19/03/2013 bug 88447 je ne délocke que si j'ai locké dans la fonction courante
#If [M:MFG1]VCRNUMORI(0)<>""
#    SYMBOL2 = "SOH"+[M:MFG1]VCRNUMORI(0)
#    Unlock=SYMBOL2
#Endif

If SYMBOL2<>""
    Unlock=SYMBOL2
    SYMBOL2 = ""
Endif
Return

########################################################################
$VERF_ANU
Local Integer I, WRET

# Issue 87289 GA 01/2013
# pas de suppression si opé de sous-traitance commandée/en cours
Call OPE_COMMANDE(WRET)
If WRET=1
    Call MESSAGE(mess(244,193,1)) From GESECRAN
    OK = 0 : Return
Endif

If [F:MFG]MFGTRKFLG > 3
    Call MESSAGE(mess(244,193,1)) From GESECRAN
    OK = 0 : Return
Endif

# 41682 mm 07.07 - si c'est un OF de contremarque
#If [M:MFG1]VCRNUMORI(0)<>""
#    Gosub VERROU
#    If OK = 0 : Return :  Endif
#Endif
# GH 19/03/2013 bug 88447 : # GH 27/02/2014 bug 96537 ajout test sur [M:MFG1]FMI(0) par sécurité
#If [M:MFG1]VCRNUMORI(0)<>"" & dim([M:SOH0]SOHNUM)=1 & [M:SOH0]SOHNUM=[M:MFG1]VCRNUMORI(0) & [M:MFG1]FMI(0)=5
#   Call MESSAGE(mess(269,193,1)-[M:MFG1]VCRNUMORI(0)-mess(270,193,1)) From GESECRAN
#   OK =0  : Return
#Endif
# GH 26/11/2014 bug 103230 on peut supprimer l'OF si on vient d'un tunnel depuis la cde client en CTM

# 47981 mm 07.08 -  si OF déjà pris en compte dans le plan de pesée + 49287
If dim([F:MFG]WGGFLG) > 0 & find([F:MFG]WGGFLG,3,4)
    Call MESSAGE(mess(235,190,1)) From GESECRAN
    OK = 0 : Return
Endif

# CCC (2009-10-28) Bug 57995 : Si des en-cours ont été comptabilisés, on ne permet pas la suppression
If !clalev([F:MWI]) : Local File WIPCOST [MWI] : Endif
Filter [MWI] Where VCRTYP=10 & VCRNUM=[F:MFG]MFGNUM & GLPSTA=2
Look [MWI] First
Filter [MWI]
If !fstat
    Call MESSAGE(mess(759,197,1)) From GESECRAN
    OK=0 : Return
Endif

# Issue 161124 GH 16/01/2020 - Don't delete a WO to which a delivery line refers
If !clalev([F:SDD]) : Local File SDELIVERYD [SDD] : Endif
Filter [SDD] Where VCRTYPORI=10 & VCRNUMORI=[F:MFG]MFGNUM
Read [SDD] First
Filter [SDD]
If !fstat
    Call MESSAGE(mess(792,197,1)+"\("+mess(129,197,1)-[F:SDD]SDHNUM+")") From GESECRAN
    OK=0 : Return
Endif

# Issue 161124 GH 16/01/2020 - Material on picking ticket
If clalev([F:STA])=0 : Local File STOALL     [STA] : Endif
For [MFM]MFM0 Where MFGNUM=[F:MFG]MFGNUM
  For [STA]STA1 Where VCRTYP=10 & VCRNUM=[F:MFM]MFGNUM & VCRLIN=[F:MFM]MFGLIN & VCRSEQ=[F:MFM]BOMSEQ & STOCOU=0
    If [F:STA]SRGQTYSTU > 0 : OK=0 : Break : Endif
  Next
Next I
If !OK
  Call MESSAGE(mess(914,197,1)) From GESECRAN
  Return
Endif

# si OF alloué
If [F:MFG]ALLSTA <> 1
    OK = 1
    Call OUINON(mess(32,190,1),OK) From GESECRAN
    If OK = 1 : OK = 0 : Return : Endif
Endif

# si OF édité
If  [F:MFG]MFGTRKFLG > 2
    OK = 1
    Call OUINON(mess(65,190,1),OK) From GESECRAN
    If OK = 1 : OK = 0 : Return : Endif
Endif

## GH 18/06/2014 bug 97023
If sigma(0,[M:MFG1]NBLIG-1,[M:MFG1]VCRNUMORI(indcum)<>"" & [M:MFG1]FMI(indcum)=5)
   OK=2 : Call AVERTIR(mess(299,193,1)+"\"+mess(53,123,1)-"?",OK) From GESECRAN : # OF de contremarque / Suppression ?
   If OK<>2 : OK=0 : Return : Endif
Endif

# V6 Affectations
Gosub VERF_ANU From MFGMTOLIB

Return

########################################################################
$AV_ANNULE
# V6 Affectations
Gosub SUP_MTO_AV_ALL From MFGMTOLIB
Return

########################################################################
$ANNULE
Local Integer WRET
#------------------------------------#
# supression des textes associées    #
#------------------------------------#
If [F:MFG]MFGTEX <> "" & left$([F:MFG]MFGTEX,3) = "MFG"
    Call SUP_CLOB([F:MFG]MFGTEX,WRET) From TRTX3TEX
Endif

Gosub ANNULE From SUBMFG1 # FQ 50547 avant From TABLEAUX
If GOK<1 : Return : Endif
# annulation des enregistrements matières
Gosub ANNULE From SUBMFG2
# annulation des enregistrements opérations
Gosub ANNULE From SUBMFG3
# annulation de l'enregistrement impression
Gosub ANNULE From SUBMFG4
# annulation des prix de revient si aucun suivi
Gosub ANNULE From SUBMCCA
Return

########################################################################
$ABANDON
# raz variables globales
GEXTQTY = 0
GFLGMAT  = 0
If !CLECUR : Actzo [M:MFG1]25 :Endif
GASW = 0
GMODSTAT = 0    # 35458 mm 09.06
# Issue X3-55431 - Reset of message flag
If dim([M:MFG1]ROUECCMAJ) > 0
  GREVMESSC = 0
Endif
Return

########################################################################
$APRES_CRE
Local Integer DOSOK

#-----------------------------------------------#
# Rechargement des indicateurs UPDFLG et CREFLG #
#-----------------------------------------------#
Gosub MAJ_GAMME              # mise à jour gamme

# V6 Affectations
Gosub MAJ_MTO_AP_ALL From MFGMTOLIB        # mise à jour des affectations

If [F:MTS]MODDOS = 2
    DOSOK = 0
    Call TEST_DOSSIER(DOSOK)
    If DOSOK = 1
#Il faut se positionner sur les bons enregistrements ITM et ITF
        If [F:ITM]ITMREF <> [M:MFG1]ROUNUM
           Read [F:ITM]ITM0 = [M:MFG1]ROUNUM
           If fstat : Raz [F:ITM] : Endif
        Endif
        If [F:ITF]ITMREF <> [M:MFG1]ROUNUM | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
           Read [F:ITF]ITF0 = [M:MFG1]ROUNUM;[M:MFG0]MFGFCY
           If fstat : Raz [F:ITF] : Endif
        Endif
        Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
        Gosub SET_CLE From GOBJSUB : CLECUR=1 : # SET_CLE parce que création
        Call ETAT("DOSFAB","GESMFG",TBPAR,TBVAL) From ETAT
#        Call ETAT("DOSFAB","","",1,"",TBPAR,TBVAL) From AIMP3
    Endif
Endif

If [F:MTS]MODJAL = 2 | [F:MTS]MODALL > 1 | [F:MTS]MODDOS = 2
    Gosub SET_CLE From GOBJSUB
    CLECUR=1
#    If !GIMPORT : Gosub RELIT From GOBJSUB : Endif
#Else
#    If !GIMPORT
#        Gosub RELIT From GOBJSUB    # CCC (09/06/08) Bug 47770 RELIT au lieu de LIENS pour que les masques soient effacés
#        Affzo [M:MFG0]
#        Affzo [M:MFG1]
#        Affzo [M:MFG2]
#        Affzo [M:MFG3]
#    Endif
Endif
# Issue 119469 GH 04/11/16 - performance enhancement
If !GIMPORT : Gosub RELIT From GOBJSUB : Endif

#--------------------------------------------------#
# v 140 Calcul automatique des coûts prévisionnels # (CPT et CPL)
#--------------------------------------------------#

If GCLCWOCAUT > 1
    # appel direct possible car la boite de dlg ne s'ouvre pas
    # charger les paramètres.   # FQ 47987 avant PARAM, VALEUR
    Local Char PARAM_CLC(250)(1..14) , VAL_CLC(250)
    PARAM_CLC(1)  = [M:MFG0]MFGFCY
    PARAM_CLC(2)  = [M:MFG0]MFGNUM
    PARAM_CLC(4)  = "1"
    PARAM_CLC(5)  = "4"
    Case [F:MTS]MCCIMPMOD
         When 1     : PARAM_CLC(9)  = "1"    # Pas d'impression
                      PARAM_CLC(13) = "1"    # pas de trace

         When 2     : PARAM_CLC(9)  = "2"    # Impression détaillée
                      PARAM_CLC(13) = "1"    # pas de trace

         When 3     : PARAM_CLC(9)  = "1"    # Pas d'impression
                      PARAM_CLC(13) = "2"    # Trace

         When 4     : PARAM_CLC(9)  = "2"    # Impression détaillée
                      PARAM_CLC(13) = "2"    # Trace
    Endcase
    PARAM_CLC(14) = "10"
    Call TRAITE_CHAR(VAL_CLC,PARAM_CLC,"","SUBMCC","",3,"") From GTRAITE
Endif
Return

########################################################################
Subprog TEST_DOSSIER(LDOSOK)
Variable Integer LDOSOK

# statut = ferme
If [F:MFG]MFGSTA <> 1 : End : Endif
# l'ordre est-il alloué au moins en global(si OF non opé seules et selon GMTKALLMGT)
If GMTKALLMGT = 2 & !find([F:MFG]ALLSTA,3,5) & [F:MFG]MATLINNBR <> 0 : End : Endif
#
# boucle d'analyse des matières bloquantes si rupture
LDOSOK = 1
For [MFM] Where MFGNUM = [F:MFG]MFGNUM
    If [F:MFM]SHTQTY <> 0
        Read [ITF]ITF0=[F:MFM]ITMREF;[F:MFM]MFGFCY
        If fstat : Break : Endif             # FQ 69909 Ctrl des sources avant End
        If [F:ITF]MFGSHTCOD = 1
            Call MESSAGE(mess(97,193,1)+" ("+[F:MFM]ITMREF+")") From GESECRAN
            LDOSOK = 0                       # GH 26/07/13 bug 91402
            Break                            # FQ 69909 Ctrl des sources avant End
        Endif
    Endif
Next
End

########################################################################
$APRES_MOD
Local Integer DOSOK

#-----------------------------------------------#
# Rechargement des indicateurs UPDFLG et CREFLG #
#-----------------------------------------------#
Gosub MAJ_GAMME             # mise à jour gamme

# V6 Affectations
If [F:MFG]MFGSTA = 1 | GMEMSTA = 2 : Gosub MAJ_MTO_AP_ALL From MFGMTOLIB : Endif

If [F:MTS]MODDOS = 2 & [F:MFG]MFGSTA = 1  & GMEMSTA =  2
    DOSOK = 0
    Call TEST_DOSSIER(DOSOK)
    If DOSOK = 1
#Il faut se positionner sur les bons enregistrements ITM et ITF
        If [F:ITM]ITMREF <> [M:MFG1]ROUNUM
           Read [F:ITM]ITM0 = [M:MFG1]ROUNUM
           If fstat : Raz [F:ITM] : Endif
        Endif
        If [F:ITF]ITMREF <> [M:MFG1]ROUNUM | [F:ITF]STOFCY <> [M:MFG0]MFGFCY
           Read [F:ITF]ITF0 = [M:MFG1]ROUNUM;[M:MFG0]MFGFCY
           If fstat : Raz [F:ITF] : Endif
        Endif
        Local Char TBPAR(10)(1..50),TBVAL(30)(1..50)
        Gosub SET_CLE From GOBJSUB : CLECUR=1 : # SET_CLE parce que création
        Call ETAT("DOSFAB","GESMFG",TBPAR,TBVAL) From ETAT
#        Call ETAT("DOSFAB","","",1,"",TBPAR,TBVAL) From AIMP3
    Endif
Endif

If [F:MTS]MODJAL = 2 | [F:MTS]MODALL = 2 | [F:MTS]MODDOS = 2 | GJALFLG = 1 | GSCDFLG <> [M:MFG3]SCDFLG
    Gosub SET_CLE From GOBJSUB
    CLECUR=1
#   If !GIMPORT : Gosub RELIT From GOBJSUB : Endif
#Else
#    Gosub LIENS
#    If !GIMPORT
#        Affzo [M:MFG0]
#        Affzo [M:MFG1]
#        Affzo [M:MFG2]
#        Affzo [M:MFG3]
#        Affzo [M:MFG4]    # 35458 mm 09.06
#    Endif
Endif
# Issue 119469 GH 04/11/16 - performance enhancement
If !GIMPORT : Gosub RELIT From GOBJSUB : Endif
GASW = 0

#--------------------------------------------------#
# v 140 Calcul automatique des coûts prévisionnels # (CPT et CPL)
#--------------------------------------------------#
If GCLCWOCAUT = 3
    # appel direct possible car la boite de dlg ne s'ouvre pas
    # charger les paramètres.   # FQ 47987 avant PARAM, VALEUR
    Local Char PARAM_CLC(250)(1..14) , VAL_CLC(250)
    PARAM_CLC(1) = [M:MFG0]MFGFCY
    PARAM_CLC(2) = [M:MFG0]MFGNUM
    PARAM_CLC(4) = "1"
    PARAM_CLC(5) = "4"
    Case [F:MTS]MCCIMPMOD
         When 1     : PARAM_CLC(9)  = "1"    # Pas d'impression
                      PARAM_CLC(13) = "1"    # pas de trace

         When 2     : PARAM_CLC(9)  = "2"    # Impression détaillée
                      PARAM_CLC(13) = "1"    # pas de trace

         When 3     : PARAM_CLC(9)  = "1"    # Pas d'impression
                      PARAM_CLC(13) = "2"    # Trace

         When 4     : PARAM_CLC(9)  = "2"    # Impression détaillée
                      PARAM_CLC(13) = "2"    # Trace
    Endcase
    PARAM_CLC(14) = "10"
    Call TRAITE_CHAR(VAL_CLC,PARAM_CLC,"","SUBMCC","",3,"") From GTRAITE
Endif
Return

########################################################################
$FIN_MOD
Return

########################################################################
$FERME

# Issue 113364 by BEEBE : Subprog for initializing handling of multiple reading MFG
Gosub KILL_RECOVERED_AUPDTICK From SUBMFGA

Raz GORITITCOL
#-- effacement icone texte
If !GIMPORT : Call RESET_IMAGE (4) From GESECRAN : Endif
Gosub FERME From SUBMFG2    # pour gestion onglet matières
Gosub FERME From SUBMFG3    # pour gestion onglet opérations
Gosub FERME From SUBMFG4    # impressions
#----- Restitution variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#-----
If GFONC1="GESMFG" : Raz GFONC1 : Endif

Close Local Mask [ORDK]
Close Local Mask [ORCK]           # 03.05 29228
Close Local File [ORD]            # 03.05 29228
Call IMPSCR From ATRTX3

# GH 26/11/2014 bug 103230 pour rafraichir la cde client d'où on vient en amont
If GFONC1 = "GESSOH" : mkstat=GSTALIT : Endif

# JAMCC - X3-138234 Track WO components - Critical Changes for non versioned products
Kill GTRACKMATWO
Return

########################################################################
$CHARGENTETE
Local Integer I,J,WWIP,WCLE, WPKC        # centrales de pesée
Local Integer WCLENBR
Local Integer WCFMFLG

#-----------------------------------------------#
# Chargement entête avant le Write ou le Rewrite #
#-----------------------------------------------#
Case [M:MFG0]FLGMOD
    When 1:    [F:MFG]TYPMOD = 2
    When 2:    [F:MFG]TYPMOD = 1
Endcase
[F:MFG]OBJDAT        =[M:MFG0]OBJDAT
[F:MFG]MFGSTA        =[M:MFG0]MFGSTA
[F:MFG]MFGMOD        =[M:MFG0]MFGMOD
[F:MFG]MFGFCY        =[M:MFG0]MFGFCY
[F:MFG]STRDAT        =[M:MFG1]STRDAT
[F:MFG]ENDDAT        =[M:MFG1]ENDDAT
[F:MFG]MFGPIO        =[M:MFG1]MFGPIO
[F:MFG]SCDMOD        =[M:MFG1]SCDMOD
[F:MFG]SCDFLG        =[M:MFG3]SCDFLG
[F:MFG]AVAMFGQTY     =[M:MFG2]AVAMFGQTY    # llc 06.04
[F:MFG]LTIREDCOE     =[M:MFG1]LTIREDCOE
[F:MFG]ROUNUM        =[M:MFG1]ROUNUM
# Issue 111414 - 2016-01-07 by CCC : Route version management
If dim([M:MFG1]ROUECCMAJ)=1
   [F:MFG]ROUECCMAJ  =[M:MFG1]ROUECCMAJ
Endif
If dim([M:MFG1]ROUECCMIN)=1
   [F:MFG]ROUECCMIN  =[M:MFG1]ROUECCMIN
Endif
# si matières seules, ROUNUM = premier article lancé
If [F:MFG]MFGMOD = 2 : [F:MFG]ROUNUM = [M:MFG1]ITMREF(0) : Endif
[F:MFG]ROUALT        =[M:MFG1]ROUALT
[F:MFG]STU           =[M:MFG1]MFGSTU
[F:MFG]EXTQTY        =[M:MFG1]MFGEXTQTY
[F:MFG]CPLQTY        =[M:MFG1]MFGCPLQTY
[F:MFG]QUACPLQTY     =[M:MFG1]QUACPLQTY   # Issue 68648 - 2011-03-21 by CCC : La zone a été écrasée par la valeur dans [M:MFG3]
[F:MFG]REJCPLQTY     =[M:MFG1]REJCPLQTY   # Issue 68648 - 2011-03-21 by CCC : La zone a été écrasée par la valeur dans [M:MFG3]
[F:MFG]RMNEXTQTY     =[F:MFG]EXTQTY - [F:MFG]CPLQTY
If [F:MFG]RMNEXTQTY < 0
                      [F:MFG]RMNEXTQTY = 0
Endif
[F:MFG]INFCAPSTR     =[M:MFG1]STRDAT
[F:MFG]INFCAPEND     =[M:MFG1]ENDDAT
# en création, initialisation menus locaux
[F:MFG]ALLSTA        = 1
[F:MFG]PRPSTA        = 1
# 48582 mm 07.08 - FQ 55715 GA 06/2009 création ou duplication pour la V6
If find(GREP,"C","D")
    If dim([F:MFG]WGGFLG) > 0
        [F:MFG]WGGFLG        = 1
    Endif
    If dim([F:MFG]WGGSTA) > 0
        [F:MFG]WGGSTA        = 1
    Endif
Endif
[F:MFG]ALLSTA        = [M:MFG1]DALLSTA
[F:MFG]ITMLINNBR     = [M:MFG1]NBLIG
[F:MFG]MATLINNBR     = [M:MFG1]DMATNBR
[F:MFG]OVRALLNBR     = [M:MFG1]DOVRALLNBR
[F:MFG]DETALLNBR     = [M:MFG1]DDETALLNBR
[F:MFG]SHTMATNBR     = [M:MFG1]DSHTMATNBR
[F:MFG]OPELINNBR     = [M:MFG1]DOPENBR
[F:MFG]SUSFLG        = [M:MFG0]SUSFLG                # 02.07 39366
If [F:MFG]OBJDAT = [0/0/0] & [F:MTS]MODJAL = 1 : [F:MFG]OBJDAT = [F:MFG]ENDDAT : Endif   # 10.07 43437

# analyse de l'état d'avancement OF
WCLE = 1
WWIP = 0
If [M:MFG1]NBLIG <> 0
    For I = 0 To [M:MFG1]NBLIG - 1
        If [M:MFG1]ITMSTA(I) < 3 : WCLE = 0 : Endif
        If [M:MFG1]ITMSTA(I) > 1 : WWIP = 1 : Endif
    Next I
Endif

# centrales de pesée
WPKC = 1
WCLENBR = 0
If [M:MFG2]NBLIG <> 0
    For I = 0 To [M:MFG2]NBLIG - 1
        If [M:MFG2]MATSTA(I) = 3 : WCLENBR += 1 : Endif
        If [M:MFG2]MATSTA(I) < 3 : WCLE = 0 : Endif
        If [M:MFG2]MATSTA(I) > 1 & [M:MFG2]MATSTA(I) <> 4: WWIP = 1 : Endif
        # centrales de pesée
        If dim([M:MFG2]PKC(I)) > 0
            If [M:MFG2]PKC(I) > 1  &  WPKC <> 3
               WPKC = 2
               # mm 94481 01.2014 pour distinguer une matière non prévue d'une prévue
               If [M:MFG2]BOMSEQ(I) = 0  & [M:MFG2]MATSTA(I) = 1
                WPKC = 3
               Endif
            Endif
        Endif
    Next I
    # 58701 mm 10.09 - si aucune matière à peser, exclure l'OF du plan de pesée
    If GREP="M" & WPKC=1
        If dim([F:MFG]WGGFLG) > 0 : [F:MFG]WGGFLG = 1 : Endif
        If dim([F:MFG]WGGSTA) > 0 : [F:MFG]WGGSTA = 1 : Endif
    Endif
Endif
[F:MFG]MATCLENBR = WCLENBR
WCLENBR = 0
WCFMFLG = 1
If [M:MFG3]NBLIG <> 0
    For I = 0 To [M:MFG3]NBLIG - 1
        If [M:MFG3]OPESTA(I) = 5 : WCLENBR += 1 : Endif
        If !find([M:MFG3]OPESTA(I),5,6) : WCLE = 0 : Endif
        # Issue number 103516 - 2015-04-07 by JUSYN : Operation status "ordered" from subcontracting is not to change WO status to "in progress"
        # If [M:MFG3]OPESTA(I) > 1 & [M:MFG3]OPESTA(I) <> 6 : WWIP = 1 : Endif
        If [M:MFG3]OPESTA(I) > 3 & !find([M:MFG3]OPESTA(I),6,7) : WWIP = 1 : Endif
        If [M:MFG3]MFGMST(I) = 2 : WCFMFLG = 2 : Endif
    Next I
Endif
# attention aux suivis sur matières ajoutées (au suivi)
For [MTK]MTK1 Where MFGNUM = [F:MFG]MFGNUM
    WWIP = 1
    Break
Next

[F:MFG]CFMFLG    = WCFMFLG
[F:MFG]OPECLENBR = WCLENBR
If WCLE             : [F:MFG]MFGTRKFLG = 5 : Endif
If !WCLE & WWIP     : [F:MFG]MFGTRKFLG = 4 : Endif
If !WCLE & !WWIP    : [F:MFG]MFGTRKFLG = 1 : Endif
If [M:MFG4]MFGFDRFLG = 2 & !WWIP & !WCLE : [F:MFG]MFGTRKFLG = 3 : Endif

# centrales de pesée
# FQ 55715 GA 06/2009 seulement en création/duplication: en modif on ne bouge pas [F:MFG]WGGFLG  selon 48582 mm 07.08
If find(GREP,"C","D")
  If dim([F:MFG]WGGFLG) > 0
    If [F:MFG]WGGFLG < 4 : [F:MFG]WGGFLG = WPKC : Endif
    # sr 07.05 Of directement dans le plan de pesée
    If dim([F:MTS]MWLFLG) > 0 &  [F:MTS]MWLFLG = 2 & [F:MFG]WGGFLG  = 2 : [F:MFG]WGGFLG = 3 : Endif
    # mm  94481 01.2014 - si WPKC=3, l'OF va être coché dans le plan de pesée
    If dim([F:MTS]MWLFLG) > 0 &  [F:MTS]MWLFLG = 1 & [F:MFG]WGGFLG  = 3 : [F:MFG]WGGFLG = 2 : Endif
  Endif
Endif
# mm 94481 01.2014 - exception : si ajout d'une matière non prévue à peser,[F:MFG]WGGFLG=2
If GREP="M" & WPKC = 3
 If dim([F:MFG]WGGFLG) > 0
   If [F:MFG]WGGFLG < 4 :[F:MFG]WGGFLG = 2 : Endif
     #  Of mis directement dans le plan de pesée selon paramétrage transaction
     If dim([F:MTS]MWLFLG) > 0 &  [F:MTS]MWLFLG = 2 & [F:MFG]WGGFLG  = 2 : [F:MFG]WGGFLG = 3: Endif
 Endif
Endif

Return

########################################################################
$CHARGLIGNE
Local Integer LIG : LIG=nolign-1

# si sous-produit, mémo ligne OF origine + données
If [M:MFG1]ITMTYP(LIG) = 2
    [F:MFI]ITMLIN        = [M:MFG1]XMFGLIN(LIG)
    [F:MFI]ITMTYP        = [M:MFG1]ITMTYP(LIG)
    [F:MFI]CSTFLG        = [M:MFG1]CSTFLG(LIG)
    # FQ 67438 GA 10/2010 pb en maj date de fin sous-produit ...
    Gosub CTL_SOUSPROD
    [F:MFI]ENDDAT        = [M:MFG1]SPDAT(LIG)
    [F:MFI]BOMOPE        = [M:MFG1]SPOPE(LIG)
    [F:MFI]BOMOFS        = [M:MFG1]SPOFS(LIG)
Else
    [F:MFI]ITMTYP        = 1
    [F:MFI]CSTFLG        = 1
    [F:MFI]ENDDAT        =[M:MFG1]ENDDAT
Endif
[F:MFI]MFGSTA        =[M:MFG0]MFGSTA
[F:MFI]MFGFCY        =[M:MFG0]MFGFCY
[F:MFI]PLNFCY        =[M:MFG0]PLNFCY
[F:MFI]STRDAT        =[M:MFG1]STRDAT
[F:MFI]MFGPIO        =[M:MFG1]MFGPIO


# chargement données article
If dim([M:MFG1]TSICOD1(LIG))>0 [F:MFI]TSICOD(0)=[M:MFG1]TSICOD1(LIG) : Endif
If dim([M:MFG1]TSICOD2(LIG))>0 [F:MFI]TSICOD(1)=[M:MFG1]TSICOD2(LIG) : Endif
If dim([M:MFG1]TSICOD3(LIG))>0 [F:MFI]TSICOD(2)=[M:MFG1]TSICOD3(LIG) : Endif
If dim([M:MFG1]TSICOD4(LIG))>0 [F:MFI]TSICOD(3)=[M:MFG1]TSICOD4(LIG) : Endif
If dim([M:MFG1]TSICOD5(LIG))>0 [F:MFI]TSICOD(4)=[M:MFG1]TSICOD5(LIG) : Endif

#
[F:MFI]RMNEXTQTY     =[F:MFI]EXTQTY - [F:MFI]CPLQTY
If [F:MFI]RMNEXTQTY < 0 : [F:MFI]RMNEXTQTY = 0 : Endif

# en création, initialisation menus locaux
If [F:MFI]MFITRKFLG = 0 : [F:MFI]MFITRKFLG     = 1 : Endif            # 01.06 34100
# pour compenser un bug moteur
If [F:MFI]VCRNUMORI = "" : [F:MFI]VCRTYPORI = 0 : Endif
#
Return

########################################################################
# FQ 67438 GA 10/2010 pb en maj date de fin sous-produit ...
#                     (selon DISPLAY_SOUSPROD de MFGLIBM)
########################################################################
$CTL_SOUSPROD
Local Date    WORIDAT
Local Char    WORIFCY(GLONFCY)
Local Integer WLTI
Local Date    WDSTDAT

# application du délai par rapport à date début OF si les opérations
# n'ont pas encore été générées ni jalonnées ou si no opé = 0
# sinon date besoin = date opération correspondante
# llc 12.01 11561 propagation en traversée fantôme

If [M:MFG1]SPOPE(LIG) = 0 & [M:MFG1]SPOFS(LIG) = 0
    [M:MFG1]SPDAT(LIG) = [M:MFG1]ENDDAT
Else
    WORIDAT    = [M:MFG1]STRDAT
    WORIFCY    = [M:MFG0]MFGFCY
    WLTI       = [M:MFG1]SPOFS(LIG)
    If [M:MFG3]NBLIG <> 0 & [M:MFG3]SCDFLG > 1 & [M:MFG1]SPOPE(LIG) <> 0
        For  I=0 To [M:MFG3]NBLIG-1
            If [M:MFG3]OPENUM(I) = [M:MFG1]SPOPE(LIG)
                WORIDAT = [M:MFG3]OPESTR(I)
                Break
            Endif
        Next I
    Endif

    # révision calendriers (llc 06.00)
    Call CALCUL_DATE_PLN(WORIDAT, WLTI, WORIFCY, 0, WDSTDAT) From MFGLIB

    [M:MFG1]SPDAT(LIG)  = WDSTDAT
Endif
Return

########################################################################
$CHARG_PARAM
If dim(OK)  < 1    : Local Integer OK     : Endif
If dim(RETOUR) < 1 : Local Integer RETOUR : Endif

Gosub CHARG_SOC
#----- Variables globales stock
Call GETCPY(GFCY,"MTS",1,GMTSNUM) From TRTX3CPT
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA

Case GPLNFLT
    When 2: [M:MFG0]ITMFILTER = 'PLANNER=GUSER|PLANNER=""'
    When 3: [M:MFG0]ITMFILTER = 'PLANNER=GUSER'
Endcase

#----- Récupération compteur OF
If clalev ([F:TCA])<=0 Local File TABCOUAFF [TCA] : Endif
Call LECTCA(8,OK) From SUBTCA
If OK=0
    GMESSAGE = mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)    # pour import
    GERR = 1
    OK=0
    Return
Endif

GCODNUM    = [F:TCA]CODNUM(0)   # compteur OF
GMANCOU    = [F:TCA]MANCOU(0)   # compteur OF manuel ?        04.05 10247
GOPS       = [F:TCA]CODNUM(4)   # compteur encours opérations

# compteur module stock
Call LECTCA(7,OK) From SUBTCA
If OK=0
    GMESSAGE=mess(58,105,1)-mess(7,14,1)-mess(250,199,1)
    GERR=1 : OK=0
    Return
Endif
GSTKCPT(8)   =[F:TCA]CODNUM(8)
# controle compteur encours
Call CTRCPT(GSTKCPT(8),type([M:MFG0]MFGNUM), RETOUR) From STKLIB
If RETOUR <> 0
    GMESSAGE = mess(222,199,1)                                    # 06.05 30844
    GERR = 1
    GOK  = 0
    Return
Endif

# Issue X3-138239 - 2019-05-06 by JUSYN : Read parameter for operation traceability/revision for non-versioned products
Call PARAM(GFCY,"TRACKOPEWO", GTRACKOPEWO) From ADOVAL
# End issue X3-138239
# JAMCC - X3-138234 Track WO components - Critical Changes for non versioned products
Local Char WTRACKMATWO(3)
Call PARAML (GFCY , "TRACKMATWO", WTRACKMATWO) From ADOVAL
GTRACKMATWO = val(WTRACKMATWO)
Kill WTRACKMATWO


Return

########################################################################
$CHARG_SOC
If clalev([F:FCY]) = 0 : Local File FACILITY [FCY] : Endif
Read [FCY]FCY0=GFCY
GSOCIETE = [F:FCY]LEGCPY
Return

#########################################################################
# Traitement des Gosub hors actions standard
#########################################################################
$UPDATE_MAT
Local Integer LIG : LIG=nolign-1
Local Integer WRET

# si sous-produit , pas de mise à jour
# en suppression il faut tester la classe [F] et pas la classe [M] demande 14879
If TRTLIG = "A" & SIGN = -1
   If  [F:MFI]ITMTYP = 2 : Return : Endif
Else
    If [M:MFG1]ITMTYP(LIG) = 2 : Return : Endif
Endif
#-------------------------------#
# Maj des matières              #
#-------------------------------#
#
If (TRTLIG = "C" & SIGN = +1)
    Call UPD_MAT_SEQ(LIG) From MFGLIBM
Endif
# purge des matières
If SIGN = -1 & TRTLIG = "A"
    For [MFM]MFM0 Where MFGNUM=[M:MFG0]MFGNUM & MFGLIN=[F:MFI]MFGLIN With Lock
        Call UPDATE_MFX("A", "", 0, 1) From MFGLIBM
        If [F:MFM]MFMTEX <> "" & left$([F:MFM]MFMTEX,3) = "MFM"
           Call SUP_CLOB([F:MFM]MFMTEX,WRET) From TRTX3TEX
        Endif
        Delete [MFM]
        #----- Suppression des sections de la ligne matière -----#
#        Delete [CAL] Where ABRFIC="MFM" & VCRNUM=[F:MFM]MFGNUM & VCRLIN=[F:MFM]MFGLIN &
#&                    VCRSEQ = [F:MFM]BOMSEQ & CPLCLE = [F:MFM]ITMREF
        # Issue 119469 GH 04/11/16 - performance enhancement
        Delete [CAL] Where ABRFIC="MFM" & VCRNUM=[F:MFM]MFGNUM & VCRLIN=[F:MFM]MFGLIN
&                        & VCRSEQ=[F:MFM]BOMSEQ & CPLCLE=[F:MFM]ITMREF & VCRTYP=0
        If fstat=1
          GOK=-1 : GLOCK="$CPTANALIN MFM 0"-[F:MFM]MFGNUM-num$([F:MFM]MFGLIN)-num$([F:MFM]BOMSEQ)-[F:MFM]ITMREF
          Break # FQ 69909 Ctrl des sources avant Return
        Endif
    Next
Endif
Return

####################################################################
$UPDATE_ORDERS
Local Integer WRET
Local Decimal WQTY
Local Decimal WTOTPEC, WECART, WECART2, WTOTCOV, WTOTWOP, WTOTWOPC
Local Integer WTYPORI, WLINORI, WSEQORI    # 10.04 26006
Local Char    WNUMORI(GLONVCR)             # 10.04 26006

#-------------------------------#
# Maj de l'en-cours dans ORDERS #
#-------------------------------#
Raz [M:ORDK]
If TRTLIG = "M"

    #CATUA X3-44522.sn
    #Prevent adding records to WIP table (ORDERS) if line status field is 'Completed'
    Case [F:MFI]ITMTYP
      When 2:        [M:ORDK]WIPTYP     = 9    # sous-produit
      When Default:  [M:ORDK]WIPTYP     = 5
    Endcase

    [M:ORDK]ITMREF     = [F:MFI]ITMREF
    [M:ORDK]WIPNUM     = [F:MFI]WIPNUM

    If [F:MFI]ITMSTA=3
      Look [ORD]ORD0 = [M:ORDK]WIPTYP; [M:ORDK]WIPNUM;[M:ORDK]ITMREF
      If fstat : Return : Endif
    Endif
    #CATUA X3-44522.en

#  Maj si modification ligne
    Raz TRTORD
    If SIGN = -1
        If [F:MFG]MFGSTA = 1  & GMEMSTA =  2 : Return : Endif
        If [F:MFG]MFGSTA <> 1 & GMEMSTA <> 1 : Return : Endif
        Gosub MAJ_ITMMVT
        Return
    Endif
    If SIGN = +1
        # Issue 146313 GH 08/08/2019 - Order for a completed line was recreated when its achievement was partial
        # TRTORD = "M"
        # Issue 162110 GH 24/09/2019
        # If [F:MFI]ITMSTA=3 : TRTORD="A" : Else TRTORD = "M" : Endif
        If [F:MFI]ITMSTA=3 | W162110<>"" : TRTORD="A"
        Elsif [F:MFI]WIPNUM <> ""        : TRTORD="M"
        Endif
        If [F:MFI]MFGSTA = 1 & GMEMSTA = 2
            # passage de WOP à WOF, creation historique
            Raz [M:ORCK]
            [M:ORCK]MAJCOD = "C"
            [M:ORCK]WIPNUM = [F:MFI]WIPNUM
            [M:ORCK]WIPTYP = 5
            [M:ORCK]ITMREF = [F:MFI]ITMREF
            [M:ORCK]COVQTY = [F:MFI]EXTQTY
            [M:ORCK]VCRTYPDST = 10
            [M:ORCK]VCRNUMDST = [F:MFI]MFGNUM
            [M:ORCK]VCRLINDST = [F:MFI]MFGLIN
            [M:ORCK]VCRSEQDST = 0
            [M:ORCK]WIPSTADST = [F:MFI]MFGSTA
            [M:ORCK]WIPTYPDST = 5
            [M:ORCK]ROUNUM = [F:MFG]ROUNUM
            [M:ORCK]ROUALT = [F:MFG]ROUALT
            Call COVER From TRTWIP
        Else
            # recherche total PEC
            Call CUM_PEC(10, [F:MFI]MFGNUM, [F:MFI]MFGLIN, 0, GMEMSTA, WTOTPEC, WTOTWOP,
&                        WTOTWOPC) From TRTWIP
            Call CUM_COV(10, [F:MFI]MFGNUM, [F:MFI]MFGLIN, 0, GMEMSTA, WTOTCOV)
&                From TRTWIP
            WTOTCOV += [F:MFI]EXTQTY
            WTOTCOV += WTOTWOPC
            If WTOTCOV < WTOTPEC
                WECART = WTOTPEC - WTOTCOV
            Else
                WECART = 0
            Endif
            If [F:MFI]EXTQTY >= WTOTWOP
                WECART2 = 0
            Else
                WECART2 = WTOTWOP - [F:MFI]EXTQTY
            Endif
            # maj besoin initial
            Call MOD_PEC(1, 10, [F:MFI]MFGNUM, [F:MFI]MFGLIN, 0, GMEMSTA, [F:MFI]MFGSTA, WECART,
&                        WECART2) From TRTWIP
        Endif
    Endif
    If TRTORD <> ""
        [M:ORDK]MAJCOD     = TRTORD

        #CATUA X3-44522.so
        #Case [F:MFI]ITMTYP
        #    When 2:        [M:ORDK]WIPTYP     = 9    # sous-produit
        #                   [M:ORDK]BOMOPE     = [F:MFI]BOMOPE
        #    When Default:  [M:ORDK]WIPTYP     = 5
        #Endcase
        #
        #[M:ORDK]WIPNUM     = [F:MFI]WIPNUM
        #[M:ORDK]ITMREF     = [F:MFI]ITMREF
        #CATUA X3-44522.so

        If W162110<>"" : # Issue 162110 GH 24/09/2019
          [M:ORDK]WIPNUM   = W162110
        Else
          [M:ORDK]WIPNUM   = [F:MFI]WIPNUM
        Endif
        [M:ORDK]WIPSTA     = [F:MFI]MFGSTA
        [M:ORDK]ORIFCY     = [F:MFI]PLNFCY
        [M:ORDK]STOFCY     = [F:MFI]MFGFCY
        [M:ORDK]PJT        = [F:MFI]PJT
        [M:ORDK]STRDAT     = [F:MFI]STRDAT
        [M:ORDK]ENDDAT     = [F:MFI]ENDDAT
        [M:ORDK]VCRTYP     = 10
        [M:ORDK]VCRNUM     = [F:MFI]MFGNUM
        [M:ORDK]VCRLIN     = [F:MFI]MFGLIN
        [M:ORDK]VCRSEQ     = 0
        [M:ORDK]EXTQTY     = [F:MFI]EXTQTY
        [M:ORDK]CPLQTY     = [F:MFI]CPLQTY
        [M:ORDK]ALLQTY     = 0
        [M:ORDK]SHTQTY     = 0
        [M:ORDK]FMI        = [F:MFI]FMI
        [M:ORDK]MRPMES     = 1
        [M:ORDK]MRPQTY     = 0
        [M:ORDK]MRPDAT     = [0/0/0]
        [M:ORDK]VCRTYPORI  = [F:MFI]VCRTYPORI
        [M:ORDK]VCRNUMORI  = [F:MFI]VCRNUMORI
        [M:ORDK]VCRLINORI  = [F:MFI]VCRLINORI
        [M:ORDK]VCRSEQORI  = [F:MFI]VCRSEQORI
        # sous-produit
        Case [F:MFI]ITMTYP
            When 2:          [M:ORDK]BOMOPE = [F:MFI]BOMOPE #CATUA X3-44522.n
                             Call RECH_ITMORI(2, [M:ORDK]MAJCOD, [M:ORDK]ITMREFORI, [M:ORDK]BPRNUM, WTYPORI,
&                                             WNUMORI, WLINORI, WSEQORI, WRET)
&                            From MFGLIBM
            When Default:  [M:ORDK]ITMREFORI = ""
        Endcase
        [M:ORDK]BPRNUM     = [F:MFI]BPCNUM    # Issue 127271 GH 26/02/2019 - moved after RECH_ITMORI to set ORDERS with same value as MFGITM for by-products
        [M:ORDK]BOMALT     = [F:MFI]BOMALT
        [M:ORDK]BOMALTTYP  = 2                # V6
        [M:ORDK]ORI        = 4
        [M:ORDK]ABBFIL     = "MFI"
        [M:ORDK]PIO        = [F:MFG]MFGPIO
# Issue 107513 - 2015-04-29 by JUSYN : ECC versions into ORDERS
        [M:ORDK]ECCVALMAJ  = [F:MFI]ECCVALMAJ
        [M:ORDK]ECCVALMIN  = [F:MFI]ECCVALMIN
        Call WIP From TRTWIP

        # Issue 151850 - 2019-09-20 by STLIG : MFGSTA = Firm and GMEMSTA = Planned?
        # If modification then update sales order's back-to-back work order ref (see creation)..
        If [F:MFI]FMI = 5
#        If [F:MFI]MFGSTA = 1 & GMEMSTA = 2 & [F:MFI]FMI = 5

            Call MAJFMISOQ([F:MFI]VCRNUMORI, [F:MFI]VCRLINORI, [F:MFI]VCRSEQORI,
&                          [F:MFI]MFGNUM, [F:MFI]MFGLIN, 0, 1, WRET) From TRTVENMAJ
            # X3-69678 - STWIL - This sub-routine now creates an assignment between all type of demands and a work order
            Gosub CRE_MTO_SO_WO_MFI  From MFGMTOLIB
        Endif
    Endif
#  Maj si création ou suppression ligne
Else
   If SIGN = -1
        [M:ORDK]MAJCOD     = "A"
        Case [F:MFI]ITMTYP
            When 2:        [M:ORDK]WIPTYP     = 9    # sous-produit
            When Default:  [M:ORDK]WIPTYP     = 5
        Endcase
        [M:ORDK]WIPNUM     = [F:MFI]WIPNUM
        [M:ORDK]ITMREF     = [F:MFI]ITMREF
        Call WIP From TRTWIP
        # annulation PEC
        Call SUP_PEC(1, 10, [F:MFI]MFGNUM, [F:MFI]MFGLIN, 0, [F:MFI]MFGSTA) From TRTWIP
        # Issue 117570 (point 4) GH 05/03/2019 - WO deletion not erases WO ref on sales order line
        #                                        when B2B is created by assignment with no ORDCOV is between WO and SO
        If [F:MFI]FMI=5 &  [F:MFI]ITMTYP=1
            Call MAJFMISOQ([F:MFI]VCRNUMORI, [F:MFI]VCRLINORI, [F:MFI]VCRSEQORI,
&                          [F:MFI]MFGNUM, [F:MFI]MFGLIN, 0, 2, WRET) From TRTVENMAJ
        Endif

        If [F:MFG]MFGSTA = 1  & GMEMSTA =  2 : Return : Endif
        If [F:MFG]MFGSTA <> 1 & GMEMSTA <> 1 : Return : Endif
        Gosub MAJ_ITMMVT
        Return
   Elsif SIGN = +1 & [F:MFI]WIPNUM<>"" : # Issue 162110 GH 24/09/2019 - condition on [MFI]WIPNUM added
        [M:ORDK]MAJCOD     = "C"
        Case [F:MFI]ITMTYP
            When 2:        [M:ORDK]WIPTYP     = 9    # sous-produit
                           [M:ORDK]BOMOPE     = [F:MFI]BOMOPE
            When Default:  [M:ORDK]WIPTYP     = 5
        Endcase
        [M:ORDK]WIPSTA     = [F:MFI]MFGSTA
        [M:ORDK]WIPNUM     = [F:MFI]WIPNUM
        [M:ORDK]ITMREF     = [F:MFI]ITMREF
        [M:ORDK]ORIFCY     = [F:MFI]PLNFCY
        [M:ORDK]STOFCY     = [F:MFI]MFGFCY
        [M:ORDK]PJT        = [F:MFI]PJT
        [M:ORDK]STRDAT     = [F:MFI]STRDAT
        [M:ORDK]ENDDAT     = [F:MFI]ENDDAT
        [M:ORDK]VCRTYP     = 10
        [M:ORDK]VCRNUM     = [F:MFI]MFGNUM
        [M:ORDK]VCRLIN     = [F:MFI]MFGLIN
        [M:ORDK]VCRSEQ     = 0
        [M:ORDK]EXTQTY     = [F:MFI]EXTQTY
        [M:ORDK]CPLQTY     = 0
        [M:ORDK]ALLQTY     = 0
        [M:ORDK]SHTQTY     = 0
        [M:ORDK]FMI        = [F:MFI]FMI
        [M:ORDK]MRPMES     = 1
        [M:ORDK]VCRTYPORI  = [F:MFI]VCRTYPORI
        [M:ORDK]VCRNUMORI  = [F:MFI]VCRNUMORI
        [M:ORDK]VCRLINORI  = [F:MFI]VCRLINORI
        [M:ORDK]VCRSEQORI  = [F:MFI]VCRSEQORI
        # sous-produit
        Case [F:MFI]ITMTYP
            When 2:        Call RECH_ITMORI(2, [M:ORDK]MAJCOD, [M:ORDK]ITMREFORI, [M:ORDK]BPRNUM, WTYPORI,
&                                             WNUMORI, WLINORI, WSEQORI, WRET)
&                                From MFGLIBM
            When Default:  [M:ORDK]ITMREFORI = ""
        Endcase
        [M:ORDK]BPRNUM     = [F:MFI]BPCNUM    # Issue 127271 GH 26/02/2019 - moved after RECH_ITMORI to set ORDERS with same value as MFGITM for by-products
        [M:ORDK]BOMALT     = [F:MFI]BOMALT
        [M:ORDK]BOMALTTYP  = 2                # V6
        [M:ORDK]ORI        = 4
        [M:ORDK]ABBFIL     = "MFI"
        [M:ORDK]PIO        = [F:MFG]MFGPIO
# Issue 107513 - 2015-04-29 by JUSYN : ECC versions into ORDERS
        [M:ORDK]ECCVALMAJ  = [F:MFI]ECCVALMAJ
        [M:ORDK]ECCVALMIN  = [F:MFI]ECCVALMIN

        Call WIP From TRTWIP

        If [F:MFI]FMI = 5
            Call MAJFMISOQ([F:MFI]VCRNUMORI, [F:MFI]VCRLINORI, [F:MFI]VCRSEQORI,
&                          [F:MFI]MFGNUM, [F:MFI]MFGLIN, 0, 1, WRET) From TRTVENMAJ
        Endif
        # X3-69678 - STWIL - This sub-routine now creates an assignment between all type of demands and a work order
        If [F:MFI]MFGSTA = 1 : Gosub CRE_MTO_SO_WO_MFI  From MFGMTOLIB : Endif

        # maj besoin initial (SOF/TWF)
        If find([F:MFI]VCRTYPORI,2,7) & [F:MFI]ITMTYP=1 : # Issue 127271 GH 19/02/2019 - Don't create a cover record between a sale order and a by-product
            # lecture encours
            For [ORD]ORD3 Where STOFCY = [F:MFI]MFGFCY &    VCRTYP = [F:MFI]VCRTYPORI & VCRNUM = [F:MFI]VCRNUMORI &
&                               VCRLIN = [F:MFI]VCRLINORI & VCRSEQ = [F:MFI]VCRSEQORI
                Raz [M:ORCK]
                [M:ORCK]MAJCOD = "C"
                [M:ORCK]WIPNUM = [F:ORD]WIPNUM
                [M:ORCK]WIPTYP = [F:ORD]WIPTYP
                [M:ORCK]ITMREF = [F:ORD]ITMREF
                [M:ORCK]COVQTY = [F:MFI]EXTQTY
                [M:ORCK]VCRTYPDST = 10
                [M:ORCK]VCRNUMDST = [F:MFI]MFGNUM
                [M:ORCK]VCRLINDST = [F:MFI]MFGLIN
                [M:ORCK]VCRSEQDST = 0
                [M:ORCK]WIPSTADST = [F:MFI]MFGSTA
                [M:ORCK]WIPTYPDST = 5
                Call COVER From TRTWIP
            Next
        Endif
   Endif
Endif
# mise à jour quantité en commande article
If [F:MFG]MFGSTA <> 1 : Return : Endif
Gosub MAJ_ITMMVT
Return

###########################################################
$MAJ_ITMMVT
# Issue 162110 GH 24/09/2019 - For by-product not managed in stock, don't update [ITV]
If [F:ITF]ITMREF<>[F:MFI]ITMREF | [F:ITF]STOFCY<>[F:MFI]MFGFCY
   Read [ITF]ITF0=[F:MFI]ITMREF;[F:MFI]MFGFCY
Endif
If [F:ITF]STOMGTCOD<2
   Return
Endif

#--------------------------------------------------------------------#
# Mise à jour de la quantité commandée de l'article/site             #
# (uniquement si statut=ferme)
#--------------------------------------------------------------------#
Local Integer STA : STA=0
Local Char    WFCY(GLONFCY)

Call LECITV([F:MFI]MFGFCY, [F:MFI]ITMREF, "",STA) From STKLIB
If GOK <> 1 : Return : Endif
#
If (STA=0 | SIGN=1) :  [F:ITV]ORDSTO += [F:MFI]RMNEXTQTY * SIGN : Endif
Rewrite [ITV] : If fstat GOK=0 : Call FSTA("ITV") From GLOCK : Endif
#
Return

#########################################################################
$COEFFICIENT
Local Integer I
#--------------------------------#
# determination des coefficients #
# en fonction de l'unité saisie  #
#--------------------------------#
If instr(1,dbgstr(1),"MFIW")
    Case [M:MFIW]UOM
        When [F:ITM]STU: [M:MFIW]UOMSTUCOE = 1
        When [F:ITM]PUU: [M:MFIW]UOMSTUCOE = [F:ITM]PUUSTUCOE
        When [F:ITM]SAU: [M:MFIW]UOMSTUCOE = [F:ITM]SAUSTUCOE
        When Default:    For I = 0 To dim([F:ITM]PCU)-1
                             If [M:MFIW]UOM = [F:ITM]PCU(I)
                                 [M:MFIW]UOMSTUCOE = [F:ITM]PCUSTUCOE(I)
                             Endif
                         Next I
    Endcase
Else
    Case [M:MFG1]UOM(nolign-1)
        When [F:ITM]STU: [M:MFG1]UOMSTUCOE(nolign-1) = 1
        When [F:ITM]PUU: [M:MFG1]UOMSTUCOE(nolign-1) = [F:ITM]PUUSTUCOE
        When [F:ITM]SAU: [M:MFG1]UOMSTUCOE(nolign-1) = [F:ITM]SAUSTUCOE
        When Default:    For I = 0 To dim([F:ITM]PCU)-1
                             If [M:MFG1]UOM(nolign-1) = [F:ITM]PCU(I)
                                 [M:MFG1]UOMSTUCOE(nolign-1) = [F:ITM]PCUSTUCOE(I)
                             Endif
                         Next I
    Endcase
Endif
Return

#########################################################################
$RECH_NOM
#--------------------------------#
# Recherche alternative valide   #
# pour proposition auto.         #
#--------------------------------#
Local Char    WFCY(GLONFCY)
Local Integer WALT
Local Date    WDAT
Local Integer WMSG

If [M:MFG1]STRDAT=[0/0/0]
    WDAT=date$
Else
    WDAT=[M:MFG1]STRDAT
Endif
WMSG=0
WFCY=[M:MFG0]MFGFCY
#    Lecture BOM
For [BOH] Where [F:BOH]ITMREF=[F:ITM]ITMREF  & BOMALTTYP = 2
    Read [TBO]TBO0=2;[F:BOH]BOMALT
    If !fstat
        Call CONTMFGNOM(WFCY,WALT,WDAT,WMSG) From MFGLIB
        If WALT <> 0
            If instr(1,dbgstr(1),"MFIW")
                [M:MFIW]BOMALT = WALT
                # FGR 16/09/2009 : X3SUIVI57824
                #[M:MFIW]TBOSHO = [F:TBO]TBOSHO
                Call LECTEXTRA([M:MFIW]TBOSHO,"TABBOMALT","TBOSHOAXX",num$([F:TBO]BOMALTTYP),num$([F:TBO]BOMALT)) From ATEXTRA
                Break
            Else
                [M:MFG1]BOMALT(nolign-1) = WALT
                # FGR 16/09/2009 : X3SUIVI57824
                #[M:MFG1]TBOSHO(nolign-1) = [F:TBO]TBOSHO
                Call LECTEXTRA([M:MFG1]TBOSHO(nolign-1),"TABBOMALT","TBOSHOAXX",num$([F:TBO]BOMALTTYP),num$([F:TBO]BOMALT)) From ATEXTRA
                Break
            Endif
        Endif
    Endif
Next
Return

#########################################################################
$MAJ_GAMME
Read [ROH]ROH0=[F:MFG]ROUNUM;[F:MFG]ROUALT;[F:MFG]MFGFCY  : # Beryl Site en fin de clé primaire
If fstat : Return : Endif
If [F:MFG]STRDAT < [F:ROH]LASWORDAT : Return : Endif


# maj ROUTING
Call DEBTRANS From GLOCK
$TR_MAJROH
GOK=1
Trbegin [ROH]
Readlock [ROH]ROH0=[F:MFG]ROUNUM;[F:MFG]ROUALT;[F:MFG]MFGFCY : # Beryl Site en fin de clé primaire
If fstat=1  GOK=-1 : OK=0 : Rollback : Return
Elsif fstat GOK=0  : OK=0 : Rollback : Return
Endif
[F:ROH]LASWORDAT = [F:MFG]STRDAT
[F:ROH]LASWORQTY = [F:MFG]EXTQTY
#point d'entrée  pour récup infos supplémentaires avant ré-écriture de l'entête de gamme - 33818 mm 01.06
GPOINT = "ROHMAJ": Gosub ENTREE From EXEFNC
#
Rewrite [ROH]
Commit
#
Return

####################################################################
$VERROU_MFG
#--------------------------------------------------#
# Verrouillage de la commande pour bouton          #
#--------------------------------------------------#
SYMBOLE2 = "MFG"+[M:MFG0]MFGNUM
Lock = SYMBOLE2
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[M:MFG0]MFGNUM-":"-mess(10,100,1)
Endif
Return

#########################################################################
# affichage entêtes colonnes variables ( sections analytiques)
$AFF_TITCOL
If GSOC_UPDFLG & !GIMPORT
  Local Char BASPAG(10)
  If (dim([M:MFG1]CCE1)>0)
      BASPAG="NBLIG" : Gosub TIT_COL From ="W1WR1"+GMTSNUM+"1"
  Endif
  If (dim([M:MFG2]CCE1)>0)
      BASPAG="NBLIG" : Gosub TIT_COL From ="W1WR1"+GMTSNUM+"2"
      If [M:MFG2]NBLIG = 0 : [M:MFG2]NBLIG = 1 : Affzo [M:MFG2]10 : Effzo [M:MFG2]10 : Endif
  Endif
  If (dim([M:MFG3]CCE1)>0)
      BASPAG="NBLIG" : Gosub TIT_COL From ="W1WR1"+GMTSNUM+"3"
      If [M:MFG3]NBLIG = 0 : [M:MFG3]NBLIG = 1 : Affzo [M:MFG3]10 : Effzo [M:MFG3]10 : Endif
  Endif
Endif
Raz GSOC_UPDFLG
Return


#########################################################################
# écriture des sections de la ligne articles lancés
$MAJMFI_CPTANALIN
# Issue 104346 GA 02/2015 always check existence sending code "M" to ENREG_ACCCE
#If TRTLIG="M"
    Call ENREG_ACCCCE(nolign-1,"","","[M:MFG1]CCE","MFI",0,[F:MFI]MFGNUM,[F:MFI]MFGLIN,0,"","M") From TRTX3CPT
#Else
#    Call ENREG_ACCCCE(nolign-1,"","","[M:MFG1]CCE","MFI",0,[F:MFI]MFGNUM,[F:MFI]MFGLIN,0,"","C") From TRTX3CPT
#Endif
Return

########################################
# 35458 mm 07.06
$RET_PENDING
Local Integer WWRK
Local Integer WPICLIS
Local Integer WROUSHE
Local Integer WLABTIK
Local Integer WMFGTIK
Local Integer WTECCRD


# réinitialisation de [M:MFG4]
[M:MFG4]PICLISFLG = 1
[M:MFG4]ROUSHEFLG = 1
[M:MFG4]LABTIKFLG = 1
[M:MFG4]MFGTIKFLG = 1
[M:MFG4]TECCRDFLG = 1
[M:MFG4]MFGFDRFLG = 1

Read [MFP]MFP0=[M:MFG0]MFGNUM
If fstat : GOK=0  : OK=0 : Rollback  : Endif
#

# réinitialisation de [F:MFP]
[F:MFP]PICLISFLG        = [M:MFG4]PICLISFLG
[F:MFP]ROUSHEFLG        = [M:MFG4]ROUSHEFLG
[F:MFP]LABTIKFLG        = [M:MFG4]LABTIKFLG
[F:MFP]MFGTIKFLG        = [M:MFG4]MFGTIKFLG
[F:MFP]TECCRDFLG        = [M:MFG4]TECCRDFLG
[F:MFP]LBEMOD           = [M:MFG4]LBEMOD
[F:MFP]MFGFDRFLG        = [M:MFG4]MFGFDRFLG
#

[F:MFP]EXTMFGFDR = 0
If [F:MTS]PICLIS = 2 : [F:MFP]EXTMFGFDR += 1  : Endif
If [F:MTS]ROUSHE = 2 : [F:MFP]EXTMFGFDR += 2  : Endif
If [F:MTS]LABTIK = 2 : [F:MFP]EXTMFGFDR += 4  : Endif
If [F:MTS]MFGTIK = 2 : [F:MFP]EXTMFGFDR += 8  : Endif
If [F:MTS]TECCRD = 2 : [F:MFP]EXTMFGFDR += 16 : Endif
#
[F:MFP]UPDDAT = date$
[F:MFP]UPDUSR = GUSER
[F:MFP]EXPNUM = [C]EXPORT
Rewrite [MFP]
If fstat GOK=0 :  Call RSTA("MFGPRN",[F:MFP]MFGNUM) From GLOCK : Rollback : Endif

# Passage de édité à en attente
[M:MFG1]MFGTRKFLG =1
[M:MFG1]XTRKFLG = mess([M:MFG1]MFGTRKFLG , 339,1)

# MAJ de MFGHEAD
[F:MFG]MFGTRKFLG = [M:MFG1]MFGTRKFLG
[F:MFG]UPDDAT = date$
[F:MFG]UPDUSR = GUSER
[F:MFG]EXPNUM = [C]EXPORT


Return

# ---------------------------------------------------------------------------
# Issue 87289 GA 01/2013 Contrôler si opé sous-traitance commandée/non soldée
# ---------------------------------------------------------------------------
Subprog OPE_COMMANDE(LRET)
Variable Integer LRET
LRET=0
If [M:MFG3]NBLIG <> 0
  If clalev ([F:OPSW]) <= 0 : Local File OPERATIONS [OPSW] : Endif
  If clalev ([F:POQW]) <= 0 : Local File PORDERQ    [POQW] : Endif
  For I = 0 To [M:MFG3]NBLIG - 1
    If [M:MFG3]OPESTA(I) = 6 : Goto N1 : Endif    # si opération exclue
#S'agit-il d'une opération de sous-traitance
    # Issue 87289 GA 02/2013
    #Read [F:MWS]WST0 = [F:MFO]EXTWST;[F:MFO]MFGFCY
    Read [F:MWS]WST0 = [M:MFG3]EXTWST(I);[M:MFG0]MFGFCY
    If !fstat
       If [F:MWS]WSTTYP=3
          If    [M:MFG3]OPESTA(I) = 7
                LRET = 1 : Break
          Elsif [M:MFG3]OPESTA(I) = 4
                Read [F:OPSW]OPS1 = [M:MFG0]MFGNUM;[M:MFG3]OPENUM(I);[M:MFG3]OPESPLNUM(I)
                If fstat : Raz [F:OPSW] : Endif
                If [F:OPSW]POHNUM<>""
                   Read [F:POQW]POQ0 = [F:OPSW]POHNUM;[F:OPSW]POPLIN;[F:OPSW]POPSEQ
                   If fstat : Raz [F:POQW] : Endif
                   If [F:POQW]LINCLEFLG <> 2 : LRET = 1 : Break : Endif
                Endif
          Endif
       Endif
    Endif
$N1
  Next I
Endif

End

###################################################################################
# Issue 113364 - 2016-01-07 by BEEBE : avoid transaction error when F:MFG opened twice
#                => define Subprog for handling F:MFG after calling "manual allocation"
#                   of components
###################################################################################
$RECOVERED_AUPDTICK
    Read [MFG]=
    If dim([L]AUPDTICK) > 0 and dim([F]updTick) > 0 Then
        [L]AUPDTICK = [F:MFG]updTick
    Endif
    Gosub KILL_RECOVERED_AUPDTICK
Return

#########################################################################
$FORCE_RECOVERED_AUPDTICK
    If dim(GSOHFRCAUPDTICK) < 0 Then
        Global Integer GSOHFRCAUPDTICK
    Endif
Return

#########################################################################
$KILL_RECOVERED_AUPDTICK
    If dim(GSOHFRCAUPDTICK) >= 0 Then
        Kill GSOHFRCAUPDTICK
    Endif
Return
