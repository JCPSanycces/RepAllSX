#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "DEBUT"      : Gosub DEBUT
  When "OK"         : Gosub OK
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$DEBUT
#Local Mask YMFGLOT [YML0]
  Gosub BUSCA_ESCANDALLO
Return

##############################################################
$OK
  Case GPARAM1(0)
    When "ETIQUETA"   : Gosub OK_ETIQUETA
    When "PROSPECTO"  : Gosub OK_PROSPECTO
    When "ESTUCHE"    : Gosub OK_ESTUCHE
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$BUSCA_ESCANDALLO
Local Integer LCON0 : Raz LCON0
Local Char CRITSQL0(255)(0..4) : Raz CRITSQL0

#  CRITSQL0(0) = "SELECT MFGMAT.MFGNUM_0, MFGMAT.ITMREF_0, STOJOU.LOT_0, STOJOU.SHLDAT_0 "
#  CRITSQL0(1) =  "FROM "+nomap+".MFGMAT LEFT OUTER JOIN "+nomap+".STOJOU ON "+nomap+".MFGMAT.ITMREF_0="+nomap+".STOJOU.ITMREF_0 "
#  CRITSQL0(1) += "AND "+nomap+".MFGMAT.MFGFCY_0="+nomap+".STOJOU.STOFCY_0  "
#  CRITSQL0(2) =  "WHERE MFGMAT.MFGNUM_0='" + GPARAM1(1) + "'"

#  CRITSQL0(0) = "SELECT MFGMAT.MFGNUM_0,MFGMAT.ITMREF_0,STOLOT.LOT_0,STOLOT.SHLDAT_0,STOLOT.USRFLD2_0 "
#  CRITSQL0(1) =  "FROM "+nomap+".MFGMAT LEFT OUTER JOIN "+nomap+".STOLOT ON "+nomap+".MFGMAT.ITMREF_0="+nomap+".STOLOT.ITMREF_0 "
##  CRITSQL0(1) += "AND "+nomap+".MFGMAT.MFGFCY_0="+nomap+".STOJOU.STOFCY_0  "
#  CRITSQL0(2) =  "WHERE MFGMAT.MFGNUM_0='" + GPARAM1(1) + "' AND MFGMAT.ITMREF_0<>''"
  CRITSQL0(0) = "SELECT MFGMAT.MFGNUM_0,MFGMAT.ITMREF_0,STOLOT.LOT_0,STOLOT.SHLDAT_0,STOLOT.USRFLD2_0,STOCK.QTYPCU_0,STOCK.STA_0 "
  CRITSQL0(1) = "FROM "+nomap+".STOCK "
  CRITSQL0(2) = "INNER JOIN "+nomap+".STOLOT ON "+nomap+".STOCK.ITMREF_0 = "+nomap+".STOLOT.ITMREF_0 AND "+nomap+".STOCK.LOT_0 = "+nomap+".STOLOT.LOT_0 "
  CRITSQL0(3) = "RIGHT OUTER JOIN "+nomap+".MFGMAT ON "+nomap+".STOLOT.ITMREF_0 = "+nomap+".MFGMAT.ITMREF_0 "
  CRITSQL0(4) =  "WHERE MFGMAT.MFGNUM_0='" + GPARAM1(1) + "' AND MFGMAT.ITMREF_0<>''"

#Local Integer I
#For I=0 To 2
#  Infbox CRITSQL0(I)
#Next

  For (Char MFGNUM,Char ITMREF,Char LOT,Date SHLDAT,Char REFERENCIA, Decimal INVENTA, Char ESTADO) From "5" Sql CRITSQL0(0..4) As [Y00]
    [M:YML0]ITMREF(LCON0)    = [F:Y00]ITMREF
    [M:YML0]PROSPECTO(LCON0) = [F:Y00]REFERENCIA
    [M:YML0]LOT(LCON0)       = [F:Y00]LOT
    [M:YML0]INVENTA(LCON0)   = 0
    [M:YML0]SHLDAT(LCON0)    = [F:Y00]SHLDAT
    [M:YML0]INVENTA(LCON0)   = [F:Y00]INVENTA
    [M:YML0]ESTADO(LCON0)    = [F:Y00]ESTADO
    LCON0 += 1
  Next

  [M:YML0]NBLIG = LCON0

  Sorta [M:YML0]NBLIG [M:YML0]NBLIG Order By [M:YML0]ITMREF(indice), [M:YML0]LOT(indice)

  Affzo [M:YML0]5


Return

##############################################################
$OK_ETIQUETA
  [M:YPP1]ETIQUETA = [M:YML0]PROSPECTO(nolign-1)
  Affzo [M:YPP1]ETIQUETA
  [M:YPP2]ETIQUETA(GNOL) = [M:YPP1]ETIQUETA
  Affzo [M:YPP2]ETIQUETA(GNOL)
Return

##############################################################
$OK_PROSPECTO
  [M:YPP1]PROSPECTO = [M:YML0]PROSPECTO(nolign-1)
  Affzo [M:YPP1]PROSPECTO
  [M:YPP2]PROSPECTO(GNOL) = [M:YPP1]PROSPECTO
  Affzo [M:YPP2]PROSPECTO(GNOL)
Return

##############################################################
$OK_ESTUCHE
  [M:YPP1]ESTUCHE = [M:YML0]PROSPECTO(nolign-1)
  Affzo [M:YPP1]ESTUCHE
  [M:YPP2]ESTUCHE(GNOL) = [M:YPP1]ESTUCHE
  Affzo [M:YPP2]ESTUCHE(GNOL)
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

