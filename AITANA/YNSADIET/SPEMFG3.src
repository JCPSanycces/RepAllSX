# Gestión de la máscara MFG3 (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla MFG3) 13/04/2020 12:36:52 (AIT04)
######################################################################################
Subprog AM_EXTWST(VALEUR)
Variable Char    VALEUR()
# Muestro la descripción
Local Char MADES
Call GET_WSTDES(VALEUR,[M:MFG0]MFGFCY,MADES) From SPEROU
[M:MFG3]YWSTDES(nolign-1) = MADES
Affzo [M:MFG3]YWSTDES(nolign-1)
End


######################################################################################
Subprog AM_EXTLAB(VALEUR)
Variable Char    VALEUR()
# Muestro la descripción
Local Char MODES
Call GET_WSTDES(VALEUR,[M:MFG0]MFGFCY,MODES) From SPEROU
[M:MFG3]YLABDES(nolign-1) = MODES
Affzo [M:MFG3]YLABDES(nolign-1)
End

