#<AdxTL>@(#)0.0.0.0 $Revision$
Local Integer I

Call GET_PEDIDOS()


End

#######################################################
#######################################################
#**
#* Subprog que extrae pedidos de inacatalog
#* desde la vista YVINAIPEDIDO.
#* El criterio es el siguiente
#*      FLAEXPEDIDO = 0 AND DATESTADOPED = 'Traspasar'
#*!
Subprog GET_PEDIDOS()
Local Integer LSOHIMPORTADOS, LSOHTOTAL : Raz LSOHIMPORTADOS, LSOHTOTAL

  If !GSERVEUR Then
    Call OUVRE_TRACE("Importación de pedidos desde Inacatalog") From LECFIC
    Call ECR_TRACE("INICIO", 0) From GESECRAN
  Endif

  Gosub OPEN_TABLES
  # SOLO SE IMPORTAN LOS PEDIDOS CON EL FLAG = 0, ESTADO = Traspasar Y PARA LAS EMPRESAS 101 Y 201
  # SE AÑADE A LA VISTA LA CONDICIÓN QUE LOS PEDIDOS DE TIPO CRM EN X3, Y QUE TENGAN LA MISMA REFERENCIA QUE EN
  # INACATALOG, NO SALGAN EN LA VISTA, ES DECIR
  # CUSORDREF <> NOMIPAD+'-'+CODPEDIDO
  Filter [F:YIPC] Where FLAEXPPEDID = 0 and DATESTADOPED = 'Traspasar' and (CODEMPRESA = 101 or CODEMPRESA = 201)
  LSOHTOTAL = rowcount([YIPC])
  For [F:YIPC]
    Gosub IMPORTA_PEDIDO
  Next
  Filter [F:YIPC]

  Gosub $CLOSE_TABLES

  If !GSERVEUR Then
    Call ECR_TRACE(" ", 0) From GESECRAN
    Call ECR_TRACE("########################################################", 0)     From GESECRAN
    Call ECR_TRACE("########################################################", 0)     From GESECRAN
    Call ECR_TRACE("## RESUMEN DEL PROCESO:", 0)                                      From GESECRAN
    Call ECR_TRACE("## Pedidos encontrados para importar:" - num$(LSOHTOTAL), 0)      From GESECRAN
    Call ECR_TRACE("## Pedidos importados correctamente:" - num$(LSOHIMPORTADOS), 0)  From GESECRAN
    Call ECR_TRACE("########################################################", 0)     From GESECRAN
    Call ECR_TRACE("########################################################", 0)     From GESECRAN
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE() From LECFIC
  Endif

End
#######################################################
#######################################################
$IMPORTA_PEDIDO
Local Char    LDIRMPORT(250)        : LDIRIMPORT = filpath("","","",[S]nomap(0),"") + "\IMPORT_EXPORT\INACATALOG\Mov_Inacatalog\"
Local Char    LFILE_W(250)          : Raz LFILE_W
Local Char    LSEP(1)               : LSEP = ";"  # LSEParador
Local Char    LFECHA(10), LHORA(10) : Raz LFECHA, LHORA
Local Char    LPATHDESE(255)        : LPATHDESE = filpath("IMPORT_EXPORT\INACATALOG\Error_Inacatalog","","")    # ruta de la carpeta con errores
Local Char    LPATHDESS(255)        : LPATHDESS = filpath("IMPORT_EXPORT\INACATALOG\Success_Inacatalog","","")  # ruta de la carpeta de finalizados con éxito
Local Integer STAT                  : Raz STAT

  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
  LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)
  LFILE_W = LDIRIMPORT + "PV_" + [F:YIPC]NOMIPAD + "-" + num$([F:YIPC]CODPEDIDO) + "_" + LFECHA + LHORA + ".txt"
  GERRTRACE = 0
  mkstat = 0 : fstat = 0 : GERRTRACE = 0

  Gosub GENERA_FICHERO
  Gosub IMPORTA_FICHERO
  If (fstat <> 0 and fstat <> 4) or GERRTRACE <> 0 Then                           # si se produce error de importación...
    Call MOVE(LFILE_W+".err",LPATHDESE,STAT) From ORDSYS                          # mueve el fichero .err con errores en la importación
    System "ae_rm " + LFILE_W                                                     # borra el fichero .txt que ha dado errores
    Goto ERROR_IMPORTAPEDIDO                                                      # pasa al final del proceso sin actualizar el flag en la tabla de Inacatalog
  Else                                                                            # si no hay errores, actualiza el flag
    # actualización del flag Exp. pedido
    Local Integer RETVAL

    RETVAL = val(func YINACATAL.ACTUALIZA_PEDIDO(num$([F:YIPC]CODEMPRESA), [F:YIPC]NOMIPAD, num$([F:YIPC]CODPEDIDO)))


    # No additional parameter nor additional header value are given here (only the values given in ORDER definition are used)
    Local Char PCOD(100)(1..10),PVAL(100)(1..10),HCOD(100)(1..10),HVAL(100)(1..10)

    # Contains the result header and body
    Local Clbfile RESHEAD(0),RESBODY(0),CDATA(0)

    HCOD(1)="content-type"
    HVAL(1)='"application/json; charset=utf-8"'

    CDATA='{'
    CDATA+='"codEmpresa":'                  + num$([F:YIPC]CODEMPRESA)  + ','
    CDATA+='"nomIPad": "'                   + [F:YIPC]NOMIPAD           + '",'
    CDATA+='"codPedido": '                  + num$([F:YIPC]CODPEDIDO)   + ','
    CDATA+='"fecPedido": "'                 + num$([F:YIPC]FECPEDIDO)   + '",'
    CDATA+='"codCliente": "'                + [F:YIPC]CODCLIENTE        + '",'
    CDATA+='"linDirCli": '                  + num$([F:YIPC]LINDIRCLI)   + ','
    CDATA+='"codAgente": "'                 + [F:YIPC]CODAGENTE         + '",'
    CDATA+='"codFormaPago": "'              + [F:YIPC]CODFORMAPAGO      + '",'
    CDATA+='"tpcDto01": '                   + num$([F:YIPC]TPCDTO01)    + ','
    CDATA+='"tpcDto02": '                   + num$([F:YIPC]TPCDTO02)    + ','
    CDATA+='"tpcDtoPp": '                   + num$([F:YIPC]TPCDTOPP)    + ','
    CDATA+='"tpcDto03": '                   + num$([F:YIPC]TPCDTO03)    + ','
    CDATA+='"codMoneda": "'                 + [F:YIPC]CODMONEDA         + '",'
    CDATA+='"codIncoterm": "'               + [F:YIPC]CODINCOTERM       + '",'
    CDATA+='"totBrutoPed": '                + num$([F:YIPC]TOTBRUTOPED) + ','
    CDATA+='"totDto1Ped": '                 + num$([F:YIPC]TOTDTO1PED)  + ','
    CDATA+='"totDto2Ped": '                 + num$([F:YIPC]TOTDTO2PED)  + ','
    CDATA+='"totDto3Ped": '                 + num$([F:YIPC]TOTDTO3PED)  + ','
    CDATA+='"totNetoPed": '                 + num$([F:YIPC]TOTNETOPED)  + ','
    CDATA+='"totDtoPPPed": '                + num$([F:YIPC]TOTDTOPPPED) + ','
    CDATA+='"totBaseImponiblePed": '        + num$([F:YIPC]TOTBASEIMP)  + ','
    CDATA+='"totIVAPed": '                  + num$([F:YIPC]TOTIVAPED)   + ','
    CDATA+='"totREPed": '                   + num$([F:YIPC]TOTREPED)    + ','
    CDATA+='"totPed": '                     + num$([F:YIPC]TOTPED)      + ','
    CDATA+='"datFechaEntrega": "'           + [F:YIPC]DATFECHAENT       + '",'
    CDATA+='"obsPedido": "'                 + [F:YIPC]OBSPEDIDO         + '",'
    CDATA+='"flaExpPedido": '               + num$(1)                   + ','
    CDATA+='"datEstadoPedido": "'           + [F:YIPC]DATESTADOPED      + '",'
    CDATA+='"flaIVAIncluido": '             + num$([F:YIPC]FLAIVAINCLUI)+ ','
    CDATA+='"codTipoVenta": "'              + [F:YIPC]CODTIPOVENTA      + '",'
    CDATA+='"codOrigenVenta": "'            + [F:YIPC]CODORIGENVEN      + '",'
    CDATA+='"totPuntosPedido": '            + num$([F:YIPC]TOTPUNTOSPED)+ ','
    CDATA+='"codFactorPuntos": "'           + [F:YIPC]CODFACTORPUN      + '",'
    CDATA+='"datFactorPuntos": '            + num$([F:YIPC]DATFACTORPUN)+ ','
    CDATA+='"totPuntosTotales": '           + num$([F:YIPC]TOTPUNTOSTOT)+ ','
    CDATA+='"totPuntosConsumidos": '        + num$([F:YIPC]TOTPUNTOSCON)+ ','
    CDATA+='"flaRecibidoMS": '              + num$([F:YIPC]FLARECIBIDOM)+ ','
    CDATA+='"Custom1": "'                   + [F:YIPC]CUSTOM1           + '",'
    CDATA+='"Custom2": "'                   + [F:YIPC]CUSTOM2           + '",'
    CDATA+='"Custom3": "'                   + [F:YIPC]CUSTOM3           + '"'
    CDATA+='}'

    # busca el pedido
    RETVAL=func ASYRRESTCLI.EXEC_REST_WS("INACATALOG","GET","/api/iPedidos?empresa="+num$([F:YIPC]CODEMPRESA)+"&nomipad="+[F:YIPC]NOMIPAD+"&codpedido="+num$([F:YIPC]CODPEDIDO),PCOD,PVAL,HCOD,HVAL,'{}'
& ,0
& ,'',RESHEAD, RESBODY)
    # el pedido existe
    If RETVAL=200 Then
      # se actualiza el cliente
      RETVAL=func ASYRRESTCLI.EXEC_REST_WS("INACATALOG","PUT","/api/iPedidos?empresa="+num$([F:YIPC]CODEMPRESA)+"&nomipad="+[F:YIPC]NOMIPAD+"&codpedido="+num$([F:YIPC]CODPEDIDO)+"&flaexppedido=1",PCOD
& ,
& PVAL,HCOD,HVAL,CDATA,0 ,'',RESHEAD, RESBODY)
      Call WRITE_LOG("PEDIDOS","UPDATE",num$(RETVAL),num$([F:YIPC]CODEMPRESA),[F:YIPC]NOMIPAD,num$([F:YIPC]CODPEDIDO),"flaexppedido=1")
    Endif
    Call MOVE(LFILE_W,LPATHDESS,STAT) From ORDSYS                                  # mueve el fichero .txt con importación exitosa
    LSOHIMPORTADOS += 1
  Endif

  $ERROR_IMPORTAPEDIDO

  mkstat = 0 : fstat = 0 : GOK = 1 : GERRTRACE = 0

Return

#######################################################
#######################################################
$GENERA_FICHERO

  Local Char LCODCLI(100)
  If !clalev([F:YBPR]) Then : Local File BPARTNER   [F:YBPR] : Endif
  Filter [F:YBPR] Where BPRSHO = [F:YIPC]CODCLIENTE
  Read [F:YBPR] First
  If !fstat Then
    LCODCLI = [F:YBPR]BPRNUM
  Endif
  Filter [F:YBPR]
  Close Local File [YBPR]

  Gosub $OPEN_FILE_W
  Wrseq "E" + LSEP + num$([F:YIPC]CODEMPRESA) + LSEP + "CRM" + LSEP + "" + LSEP + LCODCLI + LSEP + LFECHA  + LSEP + [F:YIPC]NOMIPAD + "-" + num$([F:YIPC]CODPEDIDO)  + LSEP + num$([F:YIPC]
& CODEMPRESA) + LSEP +   [F:YIPC]CODMONEDA  + LSEP + "" + LSEP +  num$([F:YIPC]TPCDTOPP)  + LSEP +  ""    Using [ZIMP_W]
  Filter [F:YIPL] Where CODEMPRESA = [F:YIPC]CODEMPRESA and NOMIPAD = [F:YIPC]NOMIPAD and CODPEDIDO = [F:YIPC]CODPEDIDO
  For [F:YIPL]
    If [F:YIPL]CODARTICULO <> "Portes" Then
      Wrseq "L" + LSEP + [F:YIPL]CODARTICULO + LSEP + [F:YIPL]DESLINPED + LSEP + ctrans(num$([F:YIPL]CANLINPED),',','.') + LSEP + ctrans(num$([F:YIPL]PRELINPED),',','.') + LSEP +  ctrans(num$([F:YIPL]
& TPCDTO01),',','.')  + LSEP + ctrans(num$([F:YIPL]TPCDTO02),',','.') +
& LSEP   + "0" + LSEP   + "0" + LSEP   + "0" + LSEP   + "0" + LSEP   + "0" Using [ZIMP_W]
    Endif
  Next

  Gosub $CLOSE_FILE_W

Return

#######################################################
#######################################################
$IMPORTA_FICHERO
  Call IMPORTSIL('YSOHINA',LFILE_W) From GIMPOBJ
Return

#######################################################
########################################################
$CLOSE_FILE_W
  Openo Using [ZIMP_W]
Return

#######################################################
########################################################
$OPEN_FILE_W
  adxifs = ";"
  adxirs = chr$(13)+chr$(10)
  Openo LFILE_W  Using [ZIMP_W]
Return

#######################################################
#######################################################
$OPEN_TABLES
  If !clalev([YIPC]) Then : Local File YVINAIPEDIDO [YIPC] : Endif
  If !clalev([YIPL]) Then : Local File YVINAIPEDLIN [YIPL] : Endif
  If !clalev([YIPI]) Then : Local File YVINAIPEDIVA [YIPI] : Endif


Return

#######################################################
######################################################
$CLOSE_TABLES
  Close Local File [YIPC]
  Close Local File [YIPL]
  Close Local File [YIPI]

Return

################################################################
################################################################
#**
#* Log de llamadas al WebServices y resultados
#*
#* @param PTABLA - Tabla a la que llamamos
#* @param PMODO  - INSERT - UPDATE
#* @param PRESULTADO - RESULTADO DEL WS
#* @param PCAMPO1 - Campos por los que filtramos el Ws
#* @param PCAMPO2 - Campos por los que filtramos el Ws
#* @param PCAMPO3 - Campos por los que filtramos el Ws
#* @param PCAMPO4 - Campos por los que filtramos el Ws
#*!
Subprog WRITE_LOG(PTABLA, PMODO, PRESULTADO, PCAMPO1, PCAMPO2, PCAMPO3, PCAMPO4)
Value Char PTABLA, PMODO, PRESULTADO, PCAMPO1, PCAMPO2, PCAMPO3, PCAMPO4

  If !clalev([YLWS]) Then : Local File YLOGWS [YLWS] : Endif

  Trbegin [F:YLWS]
  [F:YLWS]TABLA = PTABLA
  [F:YLWS]MODO  = PMODO
  [F:YLWS]RESULTADO = PRESULTADO
  [F:YLWS]CAMPO1 = PCAMPO1
  [F:YLWS]CAMPO2 = PCAMPO2
  [F:YLWS]CAMPO3 = PCAMPO3
  [F:YLWS]CAMPO4 = PCAMPO4
  Write [F:YLWS]
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  Close Local File [YLWS]

End
