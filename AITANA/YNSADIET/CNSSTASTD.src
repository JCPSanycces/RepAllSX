#<AdxTL>@(#)5.0.0.0 $Revision$
#YYN44  MODIFICACIONES AITANA
Goto TEST
Local Char PARAM(10)(1..7)
PARAM(1) = "DOM"
PARAM(2) = ""
PARAM(3) = ""
PARAM(4) = ""
PARAM(5) = ""
PARAM(6) = ""
PARAM(7) = ""

Raz GNBMASKOUV
GCONSULT = 0

Call GCONSULT("STA","",PARAM) From GCONSULT
End

$TEST
Local Date    DAT1, DAT2, DAT3, DAT4
Local Integer DECAL
DAT1 = [01/02/2013]
DAT3 = [01/02/2012]
DAT2 = [28/02/2013]

Call DECAL("",4,DAT1,DAT3,DECAL)
Call RECAL("",4,DAT2,DAT4,-DECAL)

Infbox num$(DAT4)

End

################################################################
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "LECTURE"    : Gosub LECTURE
 When "AV_AFFICHE" : Gosub AV_AFFICHE
 When "SETBOUT"    : Gosub SETBOUT
 When "EXEBOUT"    : Gosub EXEBOUT
 When "FERME"      : Gosub FERME
 When "DEB_CRIT"   : Gosub DEB_CRIT
 When "LISTE1"     : Gosub LISTE
 When "AB1_NBLIG"  : Gosub AB1_NBLIG
 When "BB1_NBLIG"  : Gosub BB1_NBLIG
 When "APRES_MODIF": Gosub APRES_MODIF
 When "APRES_CHOI" : Gosub APRES_CHOI
Endcase
Return

################################################################
Subprog PATCH(APPLI)
Value Char APPLI
Call GENTRT(APPLI,"STA") From ACNTRT : # Validation de la consultation
Call VALGTC(APPLI,"STA") From SUBGTC : # Validation de tous les écrans rattachés ŕ la consultation
End

################################################################
$APRES_CHOI
If REPONSE = CODPREM
 [M:STA1]FILTRE = ""
Endif
Return

################################################################
$OUVRE
If clalev([F:SAT])=0  : Local File STAT     [SAT]  : Endif
If clalev([F:SAT2])=0 : Local File STAT     [SAT2] : Endif
If clalev([F:SAP])=0  : Local File STATPRV  [SAP]  : Endif
If clalev([F:AXX])=0  : Local File ATEXTRA  [AXX]  : Endif
If clalev([F:AGC])=0  : Local File AGRPCPY  [AGC]  : Endif
If clalev([F:FGR])=0  : Local File FACGROUP [FGR]  : Endif

#X3-44466
Local Char STACUR(GLONPS2), CRITSUITE(250), CRITPER(250), OLD(30)
Local Clbfile CRITCLB(2)
#end X3-44466
Local Char    PARCLE(GLONAVA)(1..16), EXPCLE(250), SEP(2)
Local Char    CHAMP(40), ZVAL(40), CLEZD(50), CLEZF(50), VALPAR(10)
Local Date    DAT1, DAT2, DAT3, DAT4
Local Integer I, J, K, N, OK, ISOC, ISITE, NOMBRE, INTERR, NBPARCLE, ZOOMCUR, STAT
Local Libelle PLEIN, CATAUT
Local Integer DIMSTA : DIMSTA = dim([F:SAT]AMT)
Local Integer MAXCRI : MAXCRI = dim([F:PS2]TBL)
Local Decimal MONTANT(1..DIMSTA)
Local Char    ABREV(GLONABR)(1..MAXCRI), VALCLE(30)(1..MAXCRI)
Local Char    CLEDEB(50)(1..MAXCRI), CLEFIN(50)(1..MAXCRI)
Local Char    SOCIETE(GLONCPY) , SITE(GLONFCY) , FONCTION(GLONAFC)

Local Integer GRP , NBSITE , NBSOC
Local Char    TSITE(GLONFCY)(1..max(1,GNBSITE)) , TSOC(GLONCPY)(1..max(1,GNBSITE))

Local Char    WLIBCLE(40), WCLE(40)
Local Decimal WAMT1, WAMT2, WAMT3, WAMT4, WAMT5, WAMT6, WAMT7, WAMT8, WAMT9, WAMT10
Local Decimal WSTA1, WSTA2, WSTA3, WSTA4, WSTA5, WSTA6, WSTA7, WSTA8, WSTA9, WSTA10
Local Decimal WBUD1, WBUD2, WBUD3, WBUD4, WBUD5, WBUD6, WBUD7, WBUD8, WBUD9, WBUD10
Local Decimal WWAMT1, WWAMT2, WWAMT3, WWAMT4, WWAMT5, WWAMT6, WWAMT7, WWAMT8, WWAMT9, WWAMT10
Local Decimal WWSTA1, WWSTA2, WWSTA3, WWSTA4, WWSTA5, WWSTA6, WWSTA7, WWSTA8, WWAMT9, WWAMT10
Local Decimal WWBUD1, WWBUD2, WWBUD3, WWBUD4, WWBUD5, WWBUD6, WWBUD7, WWBUD8, WWBUD9, WWBUD10
Local Decimal MINTOP
Local Decimal RESULT , CUMRES
Local Integer X , CA(1..5) , NIVDEB , OKNIV
Local Char    SITE(GLONFCY)
Local Integer DECAL , FLBUD , FLPER
Local Char    FORMULE(250)
Local Decimal TOTAL(1..10)
Local Char    SCRCUR(GLONGTC)
Local Char    INFO(80)
Local Char    TABDEC(GLONATB)

Local Integer TR(1..8)
For I=1 To 8
 TR(I) = I
Next I
If [M:CSTA]TRI(0)=0
 Gosub CRIT_TRI
Endif

Local Char    FMTSTA(10)
Call PARAM("","FMTSTA",FMTSTA) From ADOVAL
If val(FMTSTA)=0 : FMTSTA = "12#" : Endif

Gosub DEFCRIT
If [M:STA1]COD<>""
 Gosub SET_ECRAN
Endif
Return

################################################################
$FERME
Inftxt "" At 2
Return

##############################
$SET_ECRAN
Call LECTURE("PS2",[M:STA1]COD,"") From CONTOBJ
If CECRAN=""
 If [F:PS2]SCRDEF<>SCRCUR
  [M:CSTA]ECRAN = [F:PS2]SCRDEF
  SCRCUR = [F:PS2]SCRDEF
 Endif
Endif
Return

#############################################################
$DEFFLG
# Est-ce qu'on a besoin des budgets et/ou de la période prec
FLPER = 0
FLBUD = 0
For I=1 To [F:PS2]NBRFRM
 FORMULE = vireblc(format$("KT:250X",[F:PS2]AMTFRM(I-1)),2)
 If instr(1,FORMULE,"PP")
  FLPER = 1 : FLBUD = 1
 Endif
 If instr(1,FORMULE,"CC")
  FLPER = 1
 Endif
 If instr(1,FORMULE,"P")
  FLBUD = 1
 Endif
Next I

If FLPER
 If [M:STA1]DATDEB2=[0/0/0] & [M:STA1]DATDEB<>[0/0/0]
  [M:STA1]DATDEB2 = gdat$(day([M:STA1]DATDEB),month([M:STA1]DATDEB),year([M:STA1]DATDEB)-1)
 Endif
Else
 [M:STA1]DATDEB2 = [0/0/0]
 [M:STA1]DATFIN2 = [0/0/0]
Endif
Return

##############################################################################
$DEFCRIT
# Paramčtres
# Il faut faire attention ŕ ce que les paramčtres restent cohérents entre eux
NIVDEB = 1
If [M:STA1]FCY<>"" & GUSRFCY(1)<>"\" & !find([M:STA1]FCY,GUSRFCY(1..GNBAUZ))
 [M:STA1]FCY=""
Endif

If [M:STA1]DATDEB=[0/0/0] & [M:STA1]DATFIN=[0/0/0] : # mb 2.7.3 demande 18795
 [M:STA1]DATDEB = GDATSTADEB
 [M:STA1]DATFIN = GDATSTAFIN
Endif

DAT1 = [M:STA1]DATDEB
DAT2 = [M:STA1]DATFIN
DAT3 = [M:STA1]DATDEB2
DAT4 = [M:STA1]DATFIN2

For I=1 To dim(PARAM)
 Case I
  When 1 : # Code statistique
   If PARAM(I)<>""
    Call LECTURE("PS2",PARAM(I),"") From CONTOBJ
    If !fstat : [M:STA1]COD = PARAM(I) : Endif
   Endif
  When 2 : # Site
   If PARAM(I)="*"
    PARAM(3)=""
   Elsif PARAM(I)<>""
    Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
    If !fstat & (GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ)))
     [M:STA1]FCY = PARAM(I)
     [M:STA1]CPY = [F:FCY]LEGCPY
     PARAM(3)=""
    Endif
   Endif
  When 3 : # Société
   If PARAM(I)<>""
    Call LECTURE("CPY",PARAM(I),"") From CONTOBJ
    If !fstat
     [M:STA1]CPY = PARAM(I)
     If [M:STA1]FCY<>""
      Call LECTURE("FCY",[M:STA1]FCY,"") From CONTOBJ
      If [F:FCY]LEGCPY<>[M:STA1]CPY : [M:STA1]FCY="" : Endif
     Endif
    Endif
   Endif
  When 4 : # Date début 1
   If instr(1,PARAM(I),"/")
    [M:STA1]DATDEB = "["+PARAM(I)+"]"
   Elsif PARAM(I)<>""
    [M:STA1]DATDEB = PARAM(I)
   Endif
  When 5 : # Date fin 1
   If instr(1,PARAM(I),"/")
    [M:STA1]DATFIN = "["+PARAM(I)+"]"
   Elsif PARAM(I)<>""
    [M:STA1]DATFIN = PARAM(I)
   Endif
  When 6 : # Date début 2
   If instr(1,PARAM(I),"/")
    [M:STA1]DATDEB2 = "["+PARAM(I)+"]"
   Elsif PARAM(I)<>""
    [M:STA1]DATDEB2 = PARAM(I)
   Endif
  When Default : # N Premičres parties de clé
   If sum(PARAM(I..dim(PARAM)))<>""
    Case NIVDEB
     When 1
      [M:STA1]CLE1    = PARAM(I)
      [M:STA1]LIBCLE1 = PARAM(I)
      Filter [SAT] Where COD=[M:STA1]COD & CPY=[M:STA1]CPY & FCY=[M:STA1]FCY & CRI1=PARAM(I)
      Read [SAT]SAT0 First
      If !fstat
       [M:STA1]LIBCLE1 -= [F:SAT]DES1
      Endif
     When 2
      [M:STA1]CLE2    = PARAM(I)
      [M:STA1]LIBCLE2 = PARAM(I)
      Filter [SAT] Where COD=[M:STA1]COD & CPY=[M:STA1]CPY & FCY=[M:STA1]FCY & CRI1=PARAM(I-1) & CRI2=PARAM(I)
      Read [SAT]SAT0 First
      If !fstat
       [M:STA1]LIBCLE2 -= [F:SAT]DES2
      Endif
     When 3
      [M:STA1]CLE3    = PARAM(I)
      [M:STA1]LIBCLE3 = PARAM(I)
      Filter [SAT] Where COD=[M:STA1]COD & CPY=[M:STA1]CPY & FCY=[M:STA1]FCY & CRI1=PARAM(I-2)
&                      & CRI2=PARAM(I-1) & CRI3=PARAM(I)
      Read [SAT]SAT0 First
      If !fstat
       [M:STA1]LIBCLE3 -= [F:SAT]DES3
      Endif
     When 4
      [M:STA1]CLE4    = PARAM(I)
      [M:STA1]LIBCLE4 = PARAM(I)
      Filter [SAT] Where COD=[M:STA1]COD & CPY=[M:STA1]CPY & FCY=[M:STA1]FCY & CRI1=PARAM(I-3)
&                      & CRI2=PARAM(I-2) & CRI3=PARAM(I-1) & CRI4=PARAM(I)
      Read [SAT]SAT0 First
      If !fstat
       [M:STA1]LIBCLE4 -= [F:SAT]DES4
      Endif
     When 5
      [M:STA1]CLE5    = PARAM(I)
      [M:STA1]LIBCLE5 = PARAM(I)
      Filter [SAT] Where COD=[M:STA1]COD & CPY=[M:STA1]CPY & FCY=[M:STA1]FCY & CRI1=PARAM(I-4)
&                      & CRI2=PARAM(I-3) & CRI3=PARAM(I-2) & CRI4=PARAM(I-1) & CRI5=PARAM(I)
      Read [SAT]SAT0 First
      If !fstat
       [M:STA1]LIBCLE5 -= [F:SAT]DES5
      Endif
     When 6
      [M:STA1]CLE6    = PARAM(I)
      [M:STA1]LIBCLE6 = PARAM(I)
      Filter [SAT] Where COD=[M:STA1]COD & CPY=[M:STA1]CPY & FCY=[M:STA1]FCY & CRI1=PARAM(I-5)
&                      & CRI2=PARAM(I-4) & CRI3=PARAM(I-3) & CRI4=PARAM(I-2) & CRI5=PARAM(I-1)
&                      & CRI6=PARAM(I)
      Read [SAT]SAT0 First
      If !fstat
       [M:STA1]LIBCLE6 -= [F:SAT]DES6
      Endif
     When 7
      [M:STA1]CLE7    = PARAM(I)
      [M:STA1]LIBCLE7 = PARAM(I)
      Filter [SAT] Where COD=[M:STA1]COD & CPY=[M:STA1]CPY & FCY=[M:STA1]FCY & CRI1=PARAM(I-6)
&                      & CRI2=PARAM(I-5) & CRI3=PARAM(I-4) & CRI4=PARAM(I-3) & CRI5=PARAM(I-2)
&                      & CRI6=PARAM(I-1) & CRI7=PARAM(I)
      Read [SAT]SAT0 First
      If !fstat
       [M:STA1]LIBCLE7 -= [F:SAT]DES7
      Endif
     When 8
      [M:STA1]CLE8    = PARAM(I)
      [M:STA1]LIBCLE8 = PARAM(I)
      Filter [SAT] Where COD=[M:STA1]COD & CPY=[M:STA1]CPY & FCY=[M:STA1]FCY & CRI1=PARAM(I-7)
&                      & CRI2=PARAM(I-6) & CRI3=PARAM(I-5) & CRI4=PARAM(I-4) & CRI5=PARAM(I-3)
&                      & CRI6=PARAM(I-2) & CRI7=PARAM(I-1) & CRI8=PARAM(I)
      Read [SAT]SAT0 First
      If !fstat
       [M:STA1]LIBCLE8 -= [F:SAT]DES8
      Endif
    Endcase
    If [F:PS2]NBRFLD>NIVDEB
     NIVDEB  += 1
    Endif
   Endif
 Endcase
Next I
Gosub DEFFLG
If [M:STA1]DATFIN<[M:STA1]DATDEB
 [M:STA1]DATDEB = DAT1
 [M:STA1]DATFIN = DAT2
Endif
If FLPER & [M:STA1]DATDEB2>[M:STA1]DATDEB
 [M:STA1]DATDEB2 = [M:STA1]DATDEB
Endif
Raz DAT1, DAT2, DAT3, DAT4

# Valeurs par défaut
If PARAM(2)="*"
 [M:STA1]FCY="" : [M:STA1]CPY=""
Elsif [M:STA1]FCY="" & [M:STA1]CPY="" & [F:PS2]UPDLEV>1
 mkstat = 0
 Call INIFCY([M:STA1]FCY,[M:STA1]CPY) From EXEFNC
 Call LECTURE("FCY",GFCYDEF,"") From CONTOBJ
 [M:STA1]CPY = [F:FCY]LEGCPY
 If [F:PS2]UPDLEV<3 : [M:STA1]FCY = "" : Endif : # Dossier ou société
 If [F:PS2]UPDLEV<2 : [M:STA1]CPY = "" : Endif : # Dossier
Endif

If [M:STA1]DATDEB=[0/0/0]
 If [M:STA1]DATFIN=[0/0/0] : [M:STA1]DATDEB=gdat$(1,1,year(datesyst))
 Else                      : [M:STA1]DATDEB=gdat$(1,1,year([M:STA1]DATFIN))
 Endif
Endif
If [M:STA1]DATFIN=[0/0/0] : [M:STA1]DATFIN=gdat$(31,12,year([M:STA1]DATDEB)) : Endif

If FLPER & [M:STA1]DATDEB2=[0/0/0]
 [M:STA1]DATDEB2 = gdat$(day([M:STA1]DATDEB),month([M:STA1]DATDEB),year([M:STA1]DATDEB)-1)
Endif

Default Mask [STA1]
If FLPER
 Call C_DATDEB2([M:STA1]DATDEB2)
Endif

Default Mask [CSTA]

Gosub CRITENT From =PROGCNS
Return

##################################################################
$CRIT_TRI
Call LECTURE("PS2",[M:STA1]COD,"") From CONTOBJ
For I=1 To [F:PS2]NBRFLD
 Actzo [CSTA]TRI(I-1)
 Call LECTEXTRA([M:CSTA]CRIT(I-1),"PARSTA2","FLDINTIT",[F:PS2]COD,num$(I)) From ATEXTRA
 [M:CSTA]TRI(I-1)  = I
Next I
For I=[F:PS2]NBRFLD+1 To dim([M:CSTA]TRI)
 [M:CSTA]CRIT(I-1) = ""
 [M:CSTA]TRI(I-1)  = 0
 Grizo [CSTA]TRI(I-1)
Next I
Return

######################################################
$APRES_MODIF
Case zoncou
 When "NBLIG"
  Case status
   When 136
    Gosub PAG_PREM From GCONSULT
   When Default
    Gosub ZOOM_PERIODE
  Endcase
 When Default
  Gosub CRIT_TRI
Endcase
Return

######################################################
$VERIF_AUTORIS
If dim(NIVDEB)<=0
Local Integer NIVDEB , OKNIV
Endif
# Autorisations pour l'option "N"
#If dim([F:PS2]FONCTION)>0 & [F:PS2]FONCTION<>""
If dim([F:PS2]FONCTION)>0
 Call AUTORIS From EXEFNC : # Pour restaurer les droits de la fonction courante
Endif

# Droit de remonter les niveaux
OKNIV = 1
If NIVDEB>1
 mkstat = 0
 Call CONTAUZ([M:STA1]CPY,[M:STA1]FCY,"N")
 If mkstat : OKNIV = 0 : Endif
Endif

# mb 27.9.1 bug 10422 Il ne faut pas autoriser l'accés au niveau 1 si l'utilisateur n'a pas l'option N
If NIVDEB=1 & [F:PS2]NBRFLD>1
 mkstat = 0
 Call CONTAUZ([M:STA1]CPY,[M:STA1]FCY,"N")
 If mkstat : [M]NBLIG = 0 : Return : Endif
Endif

# Autorisations
If dim([F:PS2]FONCTION)>0 & [F:PS2]FONCTION<>""
 OFONCTION = GFONCTION
 GFONCTION = [F:PS2]FONCTION
 Call AUTORIS From EXEFNC
 GFONCTION = OFONCTION
Endif
Return

######################################################
$LECTURE
# Changement d'écran ?
Gosub SET_ECRAN
Gosub CHANGE_MSK From GCONSULT
Gosub DEFFLG
If [M:STA1]PER=1 : FLPER = 0 : Endif
If FLPER
 Actzo [STA1]DATDEB2
Else
 Affzo [STA1]DATDEB2,DATFIN2
 Grizo [STA1]DATDEB2,DATFIN2
Endif

# Changement de critčres ?
CHGTRI = 0
For I=1 To [F:PS2]NBRFLD
 If I<=dim([M:CSTA]TRI) & [M:CSTA]TRI(I-1)<=dim(TR) & [M:CSTA]TRI(I-1)>0 & TR([M:CSTA]TRI(I-1))<>I
  TR([M:CSTA]TRI(I-1)) = I
  CHGTRI = 1
 Endif
Next I

# Intitulé de code statistique
If [M:STA1]COD<>""
 Call LECTURE("PS2",[M:STA1]COD,"") From CONTOBJ
 If fstat : NBLU=0 : Return : Endif
 [M:STA1]NBRAMT = 0
 For [PSL] Where COD=[F:PS2]COD
  [M:STA1]NBRAMT += 1
 Next
Endif
If [M:STA1]COD="" or [M:STA1]DATDEB=[0/0/0] or [M:STA1]DATFIN=[0/0/0] : NBLU=0 : Return : Endif

Gosub VERIF_AUTORIS
If mkstat & [M]NBLIG=0 : Return : Endif

If [F:PS2]UPDLEV<3 : [M:STA1]FCY="" : Endif : # GH 28/12/99

If [M:STA1]COD<>STACUR or CHGTRI
 For I=1 To [F:PS2]NBRFRM
  Assign "[M:STA1]LIBAMT"+num$(I) With func AFNC.TEXTRA("PARSTA2","INTITFRM",[M:STA1]COD,num$(I))
  If [F:PS2]CUMFRM(I-1)>2
   [M:STA1]FMT(I) = "3.2#"
  Elsif [F:PS2]FMTFRM(I-1)<>0
   [M:STA1]FMT(I) = num$([F:PS2]FMTFRM(I-1))+"#"
  Else
   [M:STA1]FMT(I) = FMTSTA
  Endif
  Case I
   When 1  : Chgfmt [M:STA2]AMT1  With "NzP3:"+[M:STA1]FMT(I)
   When 2  : Chgfmt [M:STA2]AMT2  With "NzP3:"+[M:STA1]FMT(I)
   When 3  : Chgfmt [M:STA2]AMT3  With "NzP3:"+[M:STA1]FMT(I)
   When 4  : Chgfmt [M:STA2]AMT4  With "NzP3:"+[M:STA1]FMT(I)
   When 5  : Chgfmt [M:STA2]AMT5  With "NzP3:"+[M:STA1]FMT(I)
   When 6  : Chgfmt [M:STA2]AMT6  With "NzP3:"+[M:STA1]FMT(I)
   When 7  : Chgfmt [M:STA2]AMT7  With "NzP3:"+[M:STA1]FMT(I)
   When 8  : Chgfmt [M:STA2]AMT8  With "NzP3:"+[M:STA1]FMT(I)
   When 9  : Chgfmt [M:STA2]AMT9  With "NzP3:"+[M:STA1]FMT(I)
   When 10 : Chgfmt [M:STA2]AMT10 With "NzP3:"+[M:STA1]FMT(I)
  Endcase
 Next I
 For  I=[F:PS2]NBRFRM+1 To 10
  Assign "[M:STA1]LIBAMT"+num$(I) With ""
  [M:STA1]FMT(I) = FMTSTA
  Case I
   When 1  : Chgfmt [M:STA2]AMT1  With "-NzP3:"+[M:STA1]FMT(I)
   When 2  : Chgfmt [M:STA2]AMT2  With "-NzP3:"+[M:STA1]FMT(I)
   When 3  : Chgfmt [M:STA2]AMT3  With "-NzP3:"+[M:STA1]FMT(I)
   When 4  : Chgfmt [M:STA2]AMT4  With "-NzP3:"+[M:STA1]FMT(I)
   When 5  : Chgfmt [M:STA2]AMT5  With "-NzP3:"+[M:STA1]FMT(I)
   When 6  : Chgfmt [M:STA2]AMT6  With "-NzP3:"+[M:STA1]FMT(I)
   When 7  : Chgfmt [M:STA2]AMT7  With "-NzP3:"+[M:STA1]FMT(I)
   When 8  : Chgfmt [M:STA2]AMT8  With "-NzP3:"+[M:STA1]FMT(I)
   When 9  : Chgfmt [M:STA2]AMT9  With "-NzP3:"+[M:STA1]FMT(I)
   When 10 : Chgfmt [M:STA2]AMT10 With "-NzP3:"+[M:STA1]FMT(I)
  Endcase
 Next I
 [M:STA1]NIVEAU  = NIVDEB
 Raz [M:STA1]ZOOM, [M:STA1]PER, [M:STA1]OBJ, [M:STA1]INTIT, [M:STA1]ABR, [M:STA1]TBL
 Raz [M:STA1]CLEOBJ, [M:STA1]LIBOBJ
 For I=1 To [F:PS2]NBRFLD
  Read [ATZ]CODZONE = [F:PS2]TBL(I-1);[F:PS2]FLDNAM(I-1)
  Read [ATY]CODTYP  = [F:ATZ]CODTYP
  If [F:ATY]FICLIEN<>""
   Read [ATB]CODFIC = [F:ATY]FICLIEN
   If [F:ATB]INTIT<>""
    [M:STA1]OBJ(I-1)   = [F:ATY]OBJLIEN
    [M:STA1]TBL(I-1)   = [F:ATY]FICLIEN
    [M:STA1]INTIT(I-1) = [F:ATB]INTIT
    [M:STA1]ABR(I-1)   = [F:ATB]ABRFIC
   Endif
  Endif
 Next I

 # Objets associés
 If [F:PS2]OBJ<>""
  Read [AOB]ABREV = [F:PS2]OBJ
  If fstat=0
   If [F:AOB]LIBEL<>0
    Call TEXTE([F:AOB]LIBEL,[M:STA1]LIBOBJ) From OBJDIV
   Else [M:STA1]LIBOBJ=mess(33,115,1)-[F:PS2]OBJ : # Objet
   Endif
   Read [ATI]NUMLIG(2) = [F:AOB]NOMFIC;1
   [M:STA1]CLEOBJ = 0
   EXPCLE = [F:ATI]DESCRIPT
   While EXPCLE<>""
    [M:STA1]CLEOBJ += 1
    I = instr(1,EXPCLE,"+")
    J = instr(1,EXPCLE,"-")
    If    I & J  : I = min(I,J)
    Elsif J & !I : I = J
    Endif
    If I : EXPCLE = right$(EXPCLE,I+1)
    Else : EXPCLE = ""
    Endif
   Wend
  Endif
 Endif

 # Init pour zoom
 Read [PS1]PS10=[F:PS2]RLG
 Read [ATB]CODFIC = [F:PS1]RLGTBL
 If [F:ATB]INTIT<>""
  Read [ATZ]CODZONE = [F:PS1]RLGTBL;[F:ATB]INTIT
  [M:STA1]RGLTBLTYP = [F:ATZ]CODTYP
  [M:STA1]RGLTBLDES = [F:ATB]INTIT
 Else
  Raz [M:STA1]RGLTBLTYP
  # jira X3-68042
  Raz [M:STA1]RGLTBLDES
 Endif
 Read [ATI]NUMLIG(2) = [F:PS1]RLGTBL;1
 NBPARCLE = 0
 EXPCLE = [F:ATI]DESCRIPT
 While EXPCLE<>""
  NBPARCLE += 1
  I = instr(1,EXPCLE,"+")
  J = instr(1,EXPCLE,"-")
  If    I & J  : I = min(I,J)
  Elsif J & !I : I = J
  Endif
  If I
   PARCLE(NBPARCLE) = left$(EXPCLE,I-1) : EXPCLE = right$(EXPCLE,I+1)
  Else
   PARCLE(NBPARCLE) = EXPCLE : EXPCLE = ""
  Endif
 Wend

Endif

If [M:STA1]ZOOM
 # Ouverture des tables liées
 Gosub PREFIXE From SUBPS2
 Gosub OUVRE From ="W"+LETTRE+PFIX2+[F:PS2]COD
 # Abréviation des tables pour les champs
 For I=1 To [F:PS2]NBRFLD
  If [F:PS2]TBLABR(I-1)<>""
   ABREV(I) = [F:PS2]TBLABR(I-1)
  Else
   Read [ATB]CODFIC = [F:PS2]TBL(I-1)
   ABREV(I) = [F:ATB]ABRFIC
  Endif
 Next I
Endif

# Ouverture de la table déclenchante
Read [ATB]CODFIC = [F:PS1]RLGTBL
If !fstat
 If evalue("clalev([F:"+[F:ATB]ABRFIC+"])")=0 : # mb cause web
  Local File =[F:PS1]RLGTBL
 Endif
 TABDEC = "["+[F:ATB]ABRFIC+"]"
 Default File TABDEC
Endif

Gosub INIT

If FLPER
 DAT1 = min([M:STA1]DATDEB,[M:STA1]DATDEB2)
 DAT2 = max([M:STA1]DATFIN,[M:STA1]DATFIN2)
Else
 DAT1 = [M:STA1]DATDEB
 DAT2 = [M:STA1]DATFIN
Endif

If [M:STA1]ZOOM : [M:STA1]NIVAFF = [F:PS2]NBRFLD+1 : Else : [M:STA1]NIVAFF = [M:STA1]NIVEAU : Endif
[M:STA1]NIVMAX = [F:PS2]NBRFLD+1

Raz [L]CRITCLB :#X3-44466
If [M:STA1]ZOOM
 Append [L]CRITCLB, '1=1' :#X3-44466
 If [F:PS1]CPYFLD<>"" & [M:STA1]CPY<>"" & !GRP
  Append [L]CRITCLB, ' &'-[F:PS1]CPYFLD+'="'+[M:STA1]CPY+'"' :#X3-44466
 Endif
 If [M:STA1]FCY<>""
  Append [L]CRITCLB, ' &'-[F:PS1]FCYFLD+'="'+[M:STA1]FCY+'"' :#X3-44466
 Elsif GRP
  If NBSITE>0
   Append [L]CRITCLB, ' &'-'find('+[F:PS1]FCYFLD+',TSITE(1..NBSITE))' :#X3-44466
  Elsif NBSOC
   If [F:PS1]CPYFLD<>""
    Append [L]CRITCLB, ' &'-'find('+[F:PS1]CPYFLD+',TSOC(1..NBSOC))' :#X3-44466
   Elsif [F:PS1]FCYFLD<>""
    Append [L]CRITCLB, ' &'-'find('+[F:PS1]FCYFLD+',GUSRFCY(1..GNBAUZ))' :#X3-44466
   Endif
  Endif
 Endif
 # Autorisation site
 If GUSRFCY(1)<>"\" & ([M:STA1]FCY<>"" or (GRP & !NBSOC)) & GNBAUZ<>GNBSITE
  Append [L]CRITCLB, ' &'-'find('+[F:PS1]FCYFLD+',GUSRFCY(1..GNBAUZ))' :#X3-44466
 Endif

 If DAT1<>[0/0/0]
  Append [L]CRITCLB, ' &'-[F:PS1]DATFLD+'>=['+format$(GFMD,DAT1)+']' :#X3-44466
 Endif
 If DAT2<>[0/0/0]
  Append [L]CRITCLB, ' &'-[F:PS1]DATFLD+'<=['+format$(GFMD,DAT2)+']' :#X3-44466
 Endif

 If [M:STA1]PER : J = [M:STA1]NIVEAU-1 : Else : J = [F:PS2]NBRFLD : Endif
 For I=1 To J : # (BY) [F:PS2]NBRFLD
  If [F:PS2]TBL(TR(I)-1)=[F:PS1]RLGTBL
   If [F:PS2]FLDTYP(TR(I)-1) < 9 : Append [L]CRITCLB, ' & ' : Endif :#X3-44466
   Case [F:PS2]FLDTYP(TR(I)-1)
    When 1,2,3,4,5,6
     Append [L]CRITCLB, [F:PS2]FLDNAM(TR(I)-1)+'('+num$([F:PS2]FLDIND(TR(I)-1))+')=' :#X3-44466
     Append [L]CRITCLB, VALCLE(I) :#X3-44466
    When 7
     If [F:PS2]FLDPOS(TR(I)-1)=1 & [F:PS2]FLDLON(TR(I)-1)=[F:PS2]FLDLNG(TR(I)-1)
      Append [L]CRITCLB, [F:PS2]FLDNAM(TR(I)-1)+'('+num$([F:PS2]FLDIND(TR(I)-1))+')=' :#X3-44466
     Else
      Append [L]CRITCLB, 'mid$('+[F:PS2]FLDNAM(TR(I)-1)+'('+num$([F:PS2]FLDIND(TR(I)-1))+'),' :#X3-44466
      Append [L]CRITCLB, num$([F:PS2]FLDPOS(TR(I)-1))+','+num$([F:PS2]FLDLON(TR(I)-1))+')=' :#X3-44466
     Endif
     Append [L]CRITCLB, '"'+VALCLE(I)+'"' :#X3-44466
    When 8
     Append [L]CRITCLB, [F:PS2]FLDNAM(TR(I)-1)+'('+num$([F:PS2]FLDIND(TR(I)-1))+')=' :#X3-44466
     Append [L]CRITCLB, '['+format$(GFMD,gdat$(VALCLE(I)))+']' :#X3-44466
   Endcase
  Endif
 Next I

 CRITSUITE = "" : # mb 26.2.2 bug 13156
 If STACUR=[M:STA1]COD & find(CHGPAG,2,-2,3)
  J=1 : EXPCLE=""
  If CHGPAG>0 : SEP=">" : Else SEP="<" : Endif
  For I=1 To NBPARCLE
   If CHGPAG=3 or CHGPAG=-2 : # Rafraichissement ou Retour
    K=instr(J,CLEZD,"~")
    ZVAL = seg$(CLEZD,J,K-1)
   Else : # Suite
    K=instr(J,CLEZF,"~")
    ZVAL = seg$(CLEZF,J,K-1)
   Endif
   J=K+1
   If I=1 : CRITSUITE = "(" : Else : CRITSUITE -= "|" : Endif
   K = evalue("type([F]"+PARCLE(I)+")")
   If K>=10
    CRITSUITE -= '('+PARCLE(I)+SEP+'"'+ZVAL+'"'-EXPCLE+')'
    EXPCLE  -= '& '+PARCLE(I)+'="'+ZVAL+'"'
   Elsif K=3
    CRITSUITE -= '('+PARCLE(I)+SEP+'['+ZVAL+']'-EXPCLE+')'
    EXPCLE  -= '& '+PARCLE(I)+'=['+ZVAL+']'
   Else
    CRITSUITE -= '('+PARCLE(I)+SEP+ZVAL-EXPCLE+')'
    EXPCLE  -= '& '+PARCLE(I)+'='+ZVAL
   Endif
   If I=NBPARCLE : CRITSUITE+=")" : Endif
  Next I
 Endif
 If CRITSUITE="" : CRITSUITE = "1=1" : Endif

 EXPCLE=""
 For I=1 To NBPARCLE
  EXPCLE +=PARCLE(I)
  If CHGPAG<0 : EXPCLE -= " Desc" : Endif
  If I<>NBPARCLE : EXPCLE += "; " : Endif
 Next I

 Filter [F] Where evalue([L]CRITCLB) & evalue(CRITSUITE) Order With EXPCLE :#X3-44466

Else : # Pas zoom
 Append [L]CRITCLB, 'COD="'+[F:PS2]UPDCOD+'"' :#X3-44466
 If [M:STA1]CPY<>"" & !GRP
  Append [L]CRITCLB, ' & CPY="'+[M:STA1]CPY+'"' :#X3-44466
 Endif
 If [M:STA1]FCY<>""
  Append [L]CRITCLB, ' & FCY="'+[M:STA1]FCY+'"' :#X3-44466
 Elsif GRP
  If NBSITE>0
   Append [L]CRITCLB, ' & find(FCY,TSITE(1..NBSITE))' :#X3-44466
  Else
   Append [L]CRITCLB, ' & find(CPY,TSOC(1..NBSOC))' :#X3-44466
  Endif
 Endif
 # Autorisation site
 If GUSRFCY(1)<>"\" & ([M:STA1]FCY<>"" or (GRP & !NBSOC)) & GNBAUZ<>GNBSITE
  Append [L]CRITCLB, ' & find(FCY,GUSRFCY(1..GNBAUZ))' :#X3-44466
 Endif

#{SAM 115284
# If DAT1<>[0/0/0]
#  CRITERE -= '& DAT>= ['+format$(GFMD,DAT1)+']'
# Endif
# If DAT2<>[0/0/0]
#  CRITERE -= '& DAT<= ['+format$(GFMD,DAT2)+']'
# Endif
 If FLPER
  If [M:STA1]DATDEB <> [0/0/0] & [M:STA1]DATDEB2 <> [0/0/0]
   Append [L]CRITCLB, ' & (((DAT>= ['+format$(GFMD,[M:STA1]DATDEB)+']) & (DAT <= ['+format$(GFMD,[M:STA1]DATFIN)+']))' :#X3-44466
   Append [L]CRITCLB, ' | ((DAT>= ['+format$(GFMD,[M:STA1]DATDEB2)+']) & (DAT <= ['+format$(GFMD,[M:STA1]DATFIN2)+'])))' :#X3-44466
  Endif
 Else
  If [M:STA1]DATDEB<>[0/0/0]
   Append [L]CRITCLB, ' & DAT>= ['+format$(GFMD,[M:STA1]DATDEB)+']' :#X3-44466
  Endif
  If [M:STA1]DATFIN<>[0/0/0]
   Append [L]CRITCLB, ' & DAT<= ['+format$(GFMD,[M:STA1]DATFIN)+']' :#X3-44466
  Endif
 Endif
 If DAT2<>[0/0/0]
  Append [L]CRITCLB, ' & DAT<= ['+format$(GFMD,DAT2)+']' :#X3-44466
 Endif

 If STACUR=[M:STA1]COD
  Case CHGPAG
   When 3 : # Rafraichissement
    Append [L]CRITCLB, ' & CRI'+num$(TR([M:STA1]NIVEAU))+'>="'+CLEDEB([M:STA1]NIVEAU)+'"' :#X3-44466
   When 2 : # Suite
    Append [L]CRITCLB, ' & CRI'+num$(TR([M:STA1]NIVEAU))+'>"'+CLEFIN([M:STA1]NIVEAU)+'"' :#X3-44466
   When -2 : # Retour
    Append [L]CRITCLB, ' & CRI'+num$(TR([M:STA1]NIVEAU))+'<"'+CLEDEB([M:STA1]NIVEAU)+'"' :#X3-44466
  Endcase
 Endif
 For I=1 To [M:STA1]NIVEAU-1
  Append [L]CRITCLB, ' & CRI'+num$(TR(I))+'="'+VALCLE(I)+'"' :#X3-44466
 Next I
 If sigma(1,[M:STA1]NIVEAU,(TR(indcum)=indcum))=[M:STA1]NIVEAU
  For I=[M:STA1]NIVEAU+1 To [F:PS2]NBRFLD
   Append [L]CRITCLB, ' & CRI'+num$(I)+'="$$$"' :#X3-44466
  Next I
  Append [L]CRITCLB, ' & CRI'+num$([M:STA1]NIVEAU)+'<>"$$$"' :#X3-44466
 Else
  For I=2 To [F:PS2]NBRFLD
   Append [L]CRITCLB, ' & CRI'+num$(I)+'<>"$$$"' :#X3-44466
  Next I
 Endif
 If [M:STA1]FILTRE <> ""
  Append [L]CRITCLB, ' &  pat(CRI'+num$([M:STA1]NIVEAU)+',"'+[M:STA1]FILTRE+'")' :#X3-44466
 Endif
Endif

If [M:STA1]ZOOM
 [M:STA1]LIBCRIT = [M:STA1]LIBOBJ
Else
 Call LECTEXTRA([M:STA1]LIBCRIT,"PARSTA2","FLDINTIT",[F:PS2]COD,num$(TR([M:STA1]NIVEAU))) From ATEXTRA
Endif

########################################
## Remplissage de l'onglet période
########################################

If CHGPAG=1 or CHGPAG=3 : # Sauf sur changement de page
 CRITPER = 'COD="'+[F:PS2]UPDCOD+'"'
 If [M:STA1]CPY<>"" & !GRP
  CRITPER -= '& CPY="'+[M:STA1]CPY+'"'
 Endif
 If [M:STA1]FCY<>""
  CRITPER -= '& FCY="'+[M:STA1]FCY+'"'
 Elsif GRP
  If NBSITE>0
   CRITPER -= '& find(FCY,TSITE(1..NBSITE))'
  Else
   CRITPER -= '& find(CPY,TSOC(1..NBSOC))'
  Endif
 Endif
 If GUSRFCY(1)<>"\" & ([M:STA1]FCY<>"" or (GRP & !NBSOC)) & GNBAUZ<>GNBSITE
  CRITPER -= '& find(FCY,GUSRFCY(1..GNBAUZ))'
 Endif
 For I=1 To [M:STA1]NIVEAU-1
  CRITPER -= '& CRI'+num$(TR(I))+'="'+VALCLE(I)+'"'
 Next I
 If sigma(1,[M:STA1]NIVEAU,(TR(indcum)=indcum))=[M:STA1]NIVEAU
  For I=[M:STA1]NIVEAU+1 To [F:PS2]NBRFLD
   CRITPER -= '& CRI'+num$(I)+'="$$$"'
  Next I
  CRITPER -= '& CRI'+num$([M:STA1]NIVEAU)+'<>"$$$"' : # mb 17.12.7 bug 44174
 Else
  For I=2 To [F:PS2]NBRFLD
   CRITPER -= '& CRI'+num$(I)+'<>"$$$"'
  Next I
 Endif
 If [M:STA1]ZOOM & ![M:STA1]PER
  CRITPER -= '& CRI'+num$(TR([F:PS2]NBRFLD))+'="'+VALCLE([F:PS2]NBRFLD)+'"'
 Endif

 SAVNOL = NOL
 #YYN44. Bloqueo STD y ańado criterios según Filtro
# Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
 Case [M:STA1]COD
  When "YVE01"  :
    If [M:STA1]NIVAFF = 1
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI1=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Elsif [M:STA1]NIVAFF = 2
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI2=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Elsif [M:STA1]NIVAFF = 3
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI3=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Elsif [M:STA1]NIVAFF = 4
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI4=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Elsif [M:STA1]NIVAFF = 5
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI5=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Endif
  When "YVE02"  :
    If [M:STA1]NIVAFF = 1
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI1=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Elsif [M:STA1]NIVAFF = 2
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI2=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Elsif [M:STA1]NIVAFF = 3
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI3=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Endif
  When "YVE03"  :
    If [M:STA1]NIVAFF = 1
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI1=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Elsif [M:STA1]NIVAFF = 2
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI2=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Elsif [M:STA1]NIVAFF = 3
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI3=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Endif

  When "YVE04"  :
    If [M:STA1]NIVAFF = 1
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI1=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Elsif [M:STA1]NIVAFF = 2
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI2=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Endif

  When "YVE05"  :
    If [M:STA1]NIVAFF = 1
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI1=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Elsif [M:STA1]NIVAFF = 2
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI2=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Endif

  When "YVE06"  :
    If [M:STA1]NIVAFF = 1
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI1=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Elsif [M:STA1]NIVAFF = 2
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI2=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Elsif [M:STA1]NIVAFF = 3
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue(CRITPER) and [SAT]CRI3=[M:STA1]YFILTROC Order By Key CLE = DAT
      Else
        Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
      Endif
    Endif

  When Default
    Filter [SAT] Where evalue(CRITPER) Order By Key CLE = DAT
 Endcase
 #YYN44 fin

 Filter [SAP] Where evalue(CRITPER) Order By Key CLE = DAT
 CRITBUD = ""
 For I=1 To [M:STA1]NIVEAU-1
  If CRITBUD<>"" : CRITBUD -= "&" : Endif
  CRITBUD -= "CRI"+num$(TR(I))+"=[F:SAT]CRI"+num$(TR(I))
 Next I
 If CRITBUD<>"" : CRITBUD -= "&" : Endif
 CRITBUD -= "DAT=[F:SAT]DAT"
 MA = 3
 NOL = -1
 Raz [M:STA3]
 PLEIN = 0
 PASSE = 1
 For [SAT]CLE(1) Where DAT>=[M:STA1]DATDEB & DAT<=[M:STA1]DATFIN
  Gosub REMPLIT
  If PLEIN : Break : Endif
  If FLBUD : Gosub REMPBUD : Endif
  Gosub CALCUL
 Next STA
 If FLPER
  PASSE = 2
  For [SAT]CLE(1) Where DAT>=[M:STA1]DATDEB2 & DAT<=[M:STA1]DATFIN2
   Gosub REMPLIT
   If PLEIN : Break : Endif
   If FLBUD : Gosub REMPBUD : Endif
   Gosub CALCUL
  Next STA
 Endif
 NOL = SAVNOL
 If [M:STA3]NBLIG=0
  Affzo [STA3]
 Endif
Endif

########################################
## Remplissage de l'onglet détail
########################################

If CHGPAG>0
 SUITE = 1
 If CHGPAG=1 : RETOUR=1 : Elsif CHGPAG=2 : RETOUR=2 : Endif
Else
 RETOUR = 1
 If CHGPAG=-1 : SUITE=1 : Else SUITE=2 : Endif
Endif
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:STA2]  : Endif
PLEIN=0

If [M:STA1]ZOOM
 NOMBRE = nbrecord([F])
 Call OUVRE_BOITE("",NOMBRE) From GESECRAN
 NOMBRE = 0
 For [F]
  NOMBRE += 1
  Call AFF_BOITE("",NOMBRE,INTERR) From GESECRAN
  # Liens vers autres tables
  If [F:PS1]CPYFLD<>""
   SOCIETE = evalue("[F]"+[F:PS1]CPYFLD)
  Elsif [F:PS1]FCYFLD<>""
   SITE = evalue("[F]"+[F:PS1]FCYFLD)
   I = find(SITE,GSITE(1..GNBSITE))
   If I : SOCIETE = GSOCSITE(I) : Endif
  Endif
  Gosub LIENS From ="WMSTA"+[F:PS2]COD
  # Criteres sur champ courant
  WDAT = evalue([F:PS1]DATFLD)
  OK = (WDAT>=[M:STA1]DATDEB & WDAT<=[M:STA1]DATFIN) | (WDAT>=[M:STA1]DATDEB2 & WDAT<=[M:STA1]DATFIN2)
  If OK
   If [M:STA1]PER : J = [M:STA1]NIVEAU-1 : Else : J = [F:PS2]NBRFLD : Endif
   For I=1 To J : # (BY) [F:PS2]NBRFLD
    If [F:PS2]TBL(TR(I)-1)<>[F:PS1]RLGTBL
     CHAMP = "[F:"+ABREV(TR(I))+"]"+[F:PS2]FLDNAM(TR(I)-1)+"("+num$([F:PS2]FLDIND(TR(I)-1))+")"
     Case [F:PS2]FLDTYP(TR(I)-1)
      When 1,2,3,4,5,6
       ZVAL = num$(evalue(CHAMP))
      When 7
       ZVAL = mid$(evalue(CHAMP),[F:PS2]FLDPOS(TR(I)-1),[F:PS2]FLDLON(TR(I)-1))
      When 8
       ZVAL= format$("D:YYYYMMDD",evalue(CHAMP))
     Endcase
     If ZVAL<>VALCLE(I) : OK = 0 : Break : Endif
    Endif
   Next I
  Endif
  # Problčme zone société
  If OK & [F:PS1]CPYFLD="" & [M:STA1]CPY<>""
   Call LECTURE("FCY",evalue("[F]"+[F:PS1]FCYFLD),"") From CONTOBJ
   If [F:FCY]LEGCPY<>[M:STA1]CPY
    OK = 0
   Endif
  Endif
  # Autres conditions
  If OK
   For I=1 To [F:PS1]NBRCRI
    If [F:PS1]CRI(I-1)<>"" & !evalue([F:PS1]CRI(I-1))
     OK = 0 : Break
    Endif
   Next I
  Endif
  If OK
   For I=1 To dim([F:PS2]CRI)
    If [F:PS2]CRI(I-1)<>"" & !evalue([F:PS2]CRI(I-1))
     OK = 0 : Break
    Endif
   Next I
  Endif
  # Chargement
  If OK
   MA = 2
   Gosub REMPLIT
   If PLEIN : Break : Endif
   Gosub CALCUL
  Endif
 Next
 Call FERME_BOITE From GESECRAN

