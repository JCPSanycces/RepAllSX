 Endif
Next : # [SAP]
Return

################################################################
$LIRE
If MA=2 & [M:STA1]ZOOM
 WLIBCLE = ""
 For I=1 To NBPARCLE
  ZVAL = num$(evalue("[F]"+PARCLE(I)))
  If CHGPAG>0
   If NOL=0
    If I=1 : CLEZD="" : Endif
    CLEZD += ZVAL+"~"
   Endif
   If I=1 : CLEZF="" : Endif
   CLEZF += ZVAL+"~"
  Else
   If NOL=MAXLIG-1
    If I=1 : CLEZF="" : Endif
    CLEZF += ZVAL+"~"
   Endif
   If I=1 : CLEZD="" : Endif
   CLEZD += ZVAL+"~"
  Endif
  WLIBCLE -= ZVAL
  Case I
   When 1 : WCLE = ZVAL
   When 2 : WCLE += "~"+ZVAL
  Endcase
 Next I
 If [M:STA1]RGLTBLDES<>""
  Case [M:STA1]RGLTBLTYP
   When "ATX"
    Call TEXTE(evalue("[F]"+[M:STA1]RGLTBLDES),ZVAL) From OBJDIV
    WLIBCLE -= ZVAL
   When "AXX","AX1","AX2","AX3"
    If NBPARCLE=1
     Call LECTEXTRA(ZVAL,[F:PS1]RLGTBL,[M:STA1]RGLTBLDES,WCLE,"") From ATEXTRA
    Else
     K = instr(1,WCLE,"~")
     Call LECTEXTRA(ZVAL,[F:PS1]RLGTBL,[M:STA1]RGLTBLDES,left$(WCLE,K-1),right$(WCLE,K+1)) From ATEXTRA
    Endif
    WLIBCLE -= ZVAL
   When Default
    If evalue("dim([F]"+[M:STA1]RGLTBLDES+")")>0
     WLIBCLE -= evalue("[F]"+[M:STA1]RGLTBLDES)
    Endif
  Endcase
 Else
  WLIBCLE -= format$("D:"+GFMDAT4,evalue("[F]"+[F:PS1]DATFLD))
 Endif
 For I=1 To [M:STA1]NBRAMT
  Read [PSL]PSL0 = [F:PS2]COD ; I
  If !fstat & [F:PSL]AMTFOR<>""
   MONTANT(I) = evalue([F:PSL]AMTFOR)
  Endif
 Next I
 Gosub CONV_DEVISE
 Raz WWAMT1, WWAMT2, WWAMT3, WWAMT4, WWAMT5, WWAMT6, WWAMT7, WWAMT8, WWAMT9, WWAMT10
 Raz WAMT1, WAMT2, WAMT3, WAMT4, WAMT5, WAMT6, WAMT7, WAMT8, WAMT9, WAMT10
 For I=1 To [M:STA1]NBRAMT
  DAT1 = evalue("[F]"+[F:PS1]DATFLD)
  If DAT1>=[M:STA1]DATDEB & DAT1<=[M:STA1]DATFIN
   Case I
    When 1 : WAMT1 = MONTANT(1)
    When 2 : WAMT2 = MONTANT(2)
    When 3 : WAMT3 = MONTANT(3)
    When 4 : WAMT4 = MONTANT(4)
    When 5 : WAMT5 = MONTANT(5)
    When 6 : WAMT6 = MONTANT(6)
    When 7 : WAMT7 = MONTANT(7)
    When 8 : WAMT8 = MONTANT(8)
    When 9 : WAMT9 = MONTANT(9)
    When 10: WAMT10= MONTANT(10)
   Endcase
  Endif
  If DAT1>=[M:STA1]DATDEB2 & DAT1<=[M:STA1]DATFIN2
   Case I
    When 1 : WWAMT1 = MONTANT(1)
    When 2 : WWAMT2 = MONTANT(2)
    When 3 : WWAMT3 = MONTANT(3)
    When 4 : WWAMT4 = MONTANT(4)
    When 5 : WWAMT5 = MONTANT(5)
    When 6 : WWAMT6 = MONTANT(6)
    When 7 : WWAMT7 = MONTANT(7)
    When 8 : WWAMT8 = MONTANT(8)
    When 9 : WWAMT9 = MONTANT(9)
    When 10: WWAMT10= MONTANT(10)
   Endcase
  Endif
 Next I
Else
 If MA=3
  If PASSE=1
   DAT1 = [F:SAT]DAT
  Else
   Call RECAL([F:PS2]PERPRG,[F:PS2]PERTYP,[F:SAT]DAT,DAT1,DECAL)
  Endif
  Call BORNES([F:PS2]PERPRG,[F:PS2]PERTYP,DAT1,DAT2,WLIBCLE)
  WCLE = DAT1+"~"+DAT2
  NOL = find(WCLE,[M:STA3]CLE(0..[M:STA3]NBLIG-1))-1
  If NOL<0
   If [M:STA3]NBLIG<dim([M:STA3]CLE)-1
    [M:STA3]NBLIG += 1
    NOL = [M:STA3]NBLIG-1
    [M:STA3]CLE(NOL)    = WCLE
    [M:STA3]LIBCLE(NOL) = WLIBCLE
   Else
    NOL = 0 : # Trop de périodes
   Endif
  Endif
 Else
  WCLE = evalue("[F:SAT]CRI"+num$(TR([M:STA1]NIVEAU)))
  WLIBCLE = WCLE-evalue("[F:SAT]DES"+num$(TR([M:STA1]NIVEAU)))
  If CHGPAG>0
   If NOL=0 : CLEDEB([M:STA1]NIVEAU) = WCLE: Endif
   CLEFIN([M:STA1]NIVEAU) = WCLE
  Else
   If NOL=MAXLIG-1 : CLEFIN([M:STA1]NIVEAU) = WCLE : Endif
   CLEDEB([M:STA1]NIVEAU) = WCLE
  Endif
 Endif
Endif
If !([M:STA1]ZOOM & MA=2)
 Raz WAMT1, WAMT2, WAMT3, WAMT4, WAMT5, WAMT6, WAMT7, WAMT8, WAMT9, WAMT10
 Raz WWAMT1, WWAMT2, WWAMT3, WWAMT4, WWAMT5, WWAMT6, WWAMT7, WWAMT8, WWAMT9, WWAMT10
 For [SAT]CLE
  For I=1 To [M:STA1]NBRAMT
   If [F:SAT]DAT>=[M:STA1]DATDEB & [F:SAT]DAT<=[M:STA1]DATFIN
    Case I
     When 1 : WAMT1 += [F:SAT]AMT(0)
     When 2 : WAMT2 += [F:SAT]AMT(1)
     When 3 : WAMT3 += [F:SAT]AMT(2)
     When 4 : WAMT4 += [F:SAT]AMT(3)
     When 5 : WAMT5 += [F:SAT]AMT(4)
     When 6 : WAMT6 += [F:SAT]AMT(5)
     When 7 : WAMT7 += [F:SAT]AMT(6)
     When 8 : WAMT8 += [F:SAT]AMT(7)
     When 9 : WAMT9 += [F:SAT]AMT(8)
     When 10: WAMT10+= [F:SAT]AMT(9)
    Endcase
   Endif
   If [F:SAT]DAT>=[M:STA1]DATDEB2 & [F:SAT]DAT<=[M:STA1]DATFIN2
    Case I
     When 1 : WWAMT1 += [F:SAT]AMT(0)
     When 2 : WWAMT2 += [F:SAT]AMT(1)
     When 3 : WWAMT3 += [F:SAT]AMT(2)
     When 4 : WWAMT4 += [F:SAT]AMT(3)
     When 5 : WWAMT5 += [F:SAT]AMT(4)
     When 6 : WWAMT6 += [F:SAT]AMT(5)
     When 7 : WWAMT7 += [F:SAT]AMT(6)
     When 8 : WWAMT8 += [F:SAT]AMT(7)
     When 9 : WWAMT9 += [F:SAT]AMT(8)
     When 10: WWAMT10+= [F:SAT]AMT(9)
    Endcase
   Endif
  Next I
 Next SAT
Endif
Return

################################################################
$INSTOP
Raz WBUD1, WBUD2, WBUD3, WBUD4, WBUD5, WBUD6, WBUD7, WBUD8, WBUD9, WBUD10
Raz WWBUD1, WWBUD2, WWBUD3, WWBUD4, WWBUD5, WWBUD6, WWBUD7, WWBUD8, WWBUD9, WWBUD10
If FLBUD
 For [SAP]CLE Where evalue(CRITBUD)
  If [F:SAP]DAT>=[M:STA1]DATDEB & [F:SAP]DAT<=[M:STA1]DATFIN
   WBUD1 += [F:SAP]AMT(0)
   WBUD2 += [F:SAP]AMT(1)
   WBUD3 += [F:SAP]AMT(2)
   WBUD4 += [F:SAP]AMT(3)
   WBUD5 += [F:SAP]AMT(4)
   WBUD6 += [F:SAP]AMT(5)
   WBUD7 += [F:SAP]AMT(6)
   WBUD8 += [F:SAP]AMT(4)
   WBUD9 += [F:SAP]AMT(8)
   WBUD10+= [F:SAP]AMT(9)
  Endif
  If [F:SAP]DAT>=[M:STA1]DATDEB2 & [F:SAP]DAT<=[M:STA1]DATFIN2
   WWBUD1 += [F:SAP]AMT(0)
   WWBUD2 += [F:SAP]AMT(1)
   WWBUD3 += [F:SAP]AMT(2)
   WWBUD4 += [F:SAP]AMT(3)
   WWBUD5 += [F:SAP]AMT(4)
   WWBUD6 += [F:SAP]AMT(5)
   WWBUD7 += [F:SAP]AMT(6)
   WWBUD8 += [F:SAP]AMT(7)
   WWBUD9 += [F:SAP]AMT(8)
   WWBUD10+= [F:SAP]AMT(9)
  Endif
 Next
Endif
WSTA1 = WAMT1
WSTA2 = WAMT2
WSTA3 = WAMT3
WSTA4 = WAMT4
WSTA5 = WAMT5
WSTA6 = WAMT6
WSTA7 = WAMT7
WSTA8 = WAMT8
WSTA9 = WAMT9
WSTA10= WAMT10
WWSTA1 = WWAMT1
WWSTA2 = WWAMT2
WWSTA3 = WWAMT3
WWSTA4 = WWAMT4
WWSTA5 = WWAMT5
WWSTA6 = WWAMT6
WWSTA7 = WWAMT7
WWSTA8 = WWAMT8
WWSTA9 = WWAMT9
WWSTA10= WWAMT10
For I=1 To [F:PS2]NBRFRM
 If [F:PS2]CUMFRM(I-1)<>2
  Call FORMU([F:PS2]AMTFRM(I-1),RESULT
&           ,WSTA1,WSTA2,WSTA3,WSTA4,WSTA5,WSTA6,WSTA7,WSTA8,WSTA9,WSTA10
&           ,WBUD1,WBUD2,WBUD3,WBUD4,WBUD5,WBUD6,WBUD7,WBUD8,WBUD9,WBUD10
&           ,WWSTA1,WWSTA2,WWSTA3,WWSTA4,WWSTA5,WWSTA6,WWSTA7,WWSTA8,WWSTA9,WWSTA10
&           ,WWBUD1,WWBUD2,WWBUD3,WWBUD4,WWBUD5,WWBUD6,WWBUD7,WWBUD8,WWBUD9,WWBUD10)
  Case I
   When 1  : WAMT1  = RESULT
   When 2  : WAMT2  = RESULT
   When 3  : WAMT3  = RESULT
   When 4  : WAMT4  = RESULT
   When 5  : WAMT5  = RESULT
   When 6  : WAMT6  = RESULT
   When 7  : WAMT7  = RESULT
   When 8  : WAMT8  = RESULT
   When 9  : WAMT9  = RESULT
   When 10 : WAMT10 = RESULT
  Endcase
 Endif
Next I
If NOL<MAXLIG
 I = NOL
Else
 I = 0
 Case [M:CSTA]COLTOT
  When 1  : If WAMT1>MINTOP  : I = find(MINTOP,[M:STA2]AMT1(0..NOL-1))  : Endif
  When 2  : If WAMT2>MINTOP  : I = find(MINTOP,[M:STA2]AMT2(0..NOL-1))  : Endif
  When 3  : If WAMT3>MINTOP  : I = find(MINTOP,[M:STA2]AMT3(0..NOL-1))  : Endif
  When 4  : If WAMT4>MINTOP  : I = find(MINTOP,[M:STA2]AMT4(0..NOL-1))  : Endif
  When 5  : If WAMT5>MINTOP  : I = find(MINTOP,[M:STA2]AMT5(0..NOL-1))  : Endif
  When 6  : If WAMT6>MINTOP  : I = find(MINTOP,[M:STA2]AMT6(0..NOL-1))  : Endif
  When 7  : If WAMT7>MINTOP  : I = find(MINTOP,[M:STA2]AMT7(0..NOL-1))  : Endif
  When 8  : If WAMT8>MINTOP  : I = find(MINTOP,[M:STA2]AMT8(0..NOL-1))  : Endif
  When 9  : If WAMT9>MINTOP  : I = find(MINTOP,[M:STA2]AMT9(0..NOL-1))  : Endif
  When 10 : If WAMT10>MINTOP : I = find(MINTOP,[M:STA2]AMT10(0..NOL-1)) : Endif
 Endcase
Endif
If I
 [M:STA2]CLE(I-1)    = WCLE
 [M:STA2]LIBCLE(I-1) = WLIBCLE
 [M:STA2]AMT1(I-1)   = WAMT1
 [M:STA2]AMT2(I-1)   = WAMT2
 [M:STA2]AMT3(I-1)   = WAMT3
 [M:STA2]AMT4(I-1)   = WAMT4
 [M:STA2]AMT5(I-1)   = WAMT5
 [M:STA2]AMT6(I-1)   = WAMT6
 [M:STA2]AMT7(I-1)   = WAMT7
 [M:STA2]AMT8(I-1)   = WAMT8
 [M:STA2]AMT9(I-1)   = WAMT9
 [M:STA2]AMT10(I-1)  = WAMT10
 [M:STA2]STA1(I-1)   = WSTA1
 [M:STA2]STA2(I-1)   = WSTA2
 [M:STA2]STA3(I-1)   = WSTA3
 [M:STA2]STA4(I-1)   = WSTA4
 [M:STA2]STA5(I-1)   = WSTA5
 [M:STA2]STA6(I-1)   = WSTA6
 [M:STA2]STA7(I-1)   = WSTA7
 [M:STA2]STA8(I-1)   = WSTA8
 [M:STA2]STA9(I-1)   = WSTA9
 [M:STA2]STA10(I-1)  = WSTA10
 [M:STA2]STB1(I-1)   = WWSTA1
 [M:STA2]STB2(I-1)   = WWSTA2
 [M:STA2]STB3(I-1)   = WWSTA3
 [M:STA2]STB4(I-1)   = WWSTA4
 [M:STA2]STB5(I-1)   = WWSTA5
 [M:STA2]STB6(I-1)   = WWSTA6
 [M:STA2]STB7(I-1)   = WWSTA7
 [M:STA2]STB8(I-1)   = WWSTA8
 [M:STA2]STB9(I-1)   = WWSTA9
 [M:STA2]STB10(I-1)  = WWSTA10
 [M:STA2]PRV1(I-1)   = WBUD1
 [M:STA2]PRV2(I-1)   = WBUD2
 [M:STA2]PRV3(I-1)   = WBUD3
 [M:STA2]PRV4(I-1)   = WBUD4
 [M:STA2]PRV5(I-1)   = WBUD5
 [M:STA2]PRV6(I-1)   = WBUD6
 [M:STA2]PRV7(I-1)   = WBUD7
 [M:STA2]PRV8(I-1)   = WBUD8
 [M:STA2]PRV9(I-1)   = WBUD9
 [M:STA2]PRV10(I-1)  = WBUD10
 [M:STA2]PRB1(I-1)   = WWBUD1
 [M:STA2]PRB2(I-1)   = WWBUD2
 [M:STA2]PRB3(I-1)   = WWBUD3
 [M:STA2]PRB4(I-1)   = WWBUD4
 [M:STA2]PRB5(I-1)   = WWBUD5
 [M:STA2]PRB6(I-1)   = WWBUD6
 [M:STA2]PRB7(I-1)   = WWBUD7
 [M:STA2]PRB8(I-1)   = WWBUD8
 [M:STA2]PRB9(I-1)   = WWBUD9
 [M:STA2]PRB10(I-1)  = WWBUD10
 Case [M:CSTA]COLTOT
  When 1  : MINTOP = min([M:STA2]AMT1(0..NOL-1))
  When 2  : MINTOP = min([M:STA2]AMT2(0..NOL-1))
  When 3  : MINTOP = min([M:STA2]AMT3(0..NOL-1))
  When 4  : MINTOP = min([M:STA2]AMT4(0..NOL-1))
  When 5  : MINTOP = min([M:STA2]AMT5(0..NOL-1))
  When 6  : MINTOP = min([M:STA2]AMT6(0..NOL-1))
  When 7  : MINTOP = min([M:STA2]AMT7(0..NOL-1))
  When 8  : MINTOP = min([M:STA2]AMT8(0..NOL-1))
  When 9  : MINTOP = min([M:STA2]AMT9(0..NOL-1))
  When 10 : MINTOP = min([M:STA2]AMT10(0..NOL-1))
 Endcase
Endif
If NOL>=MAXLIG : NOL -= 1 : Endif
Return

################################################################
$TRITOP
[M:STA2]NBLIG = NOL+1
Case [M:CSTA]COLTOT
 When 1  : Sorta [M:STA2]NBLIG [M:STA2]NBLIG Order By [M:STA2]AMT1(indice) Desc
 When 2  : Sorta [M:STA2]NBLIG [M:STA2]NBLIG Order By [M:STA2]AMT2(indice) Desc
 When 3  : Sorta [M:STA2]NBLIG [M:STA2]NBLIG Order By [M:STA2]AMT3(indice) Desc
 When 4  : Sorta [M:STA2]NBLIG [M:STA2]NBLIG Order By [M:STA2]AMT4(indice) Desc
 When 5  : Sorta [M:STA2]NBLIG [M:STA2]NBLIG Order By [M:STA2]AMT5(indice) Desc
 When 6  : Sorta [M:STA2]NBLIG [M:STA2]NBLIG Order By [M:STA2]AMT6(indice) Desc
 When 7  : Sorta [M:STA2]NBLIG [M:STA2]NBLIG Order By [M:STA2]AMT7(indice) Desc
 When 8  : Sorta [M:STA2]NBLIG [M:STA2]NBLIG Order By [M:STA2]AMT8(indice) Desc
 When 9  : Sorta [M:STA2]NBLIG [M:STA2]NBLIG Order By [M:STA2]AMT9(indice) Desc
 When 10 : Sorta [M:STA2]NBLIG [M:STA2]NBLIG Order By [M:STA2]AMT10(indice) Desc
Endcase
Return


################################################################
Subprog CONTAUZ(CPY,FCY,FLAG)
Value Char CPY , FCY , FLAG
Local Integer I , J , K , NBSOC
Local Char    TSOC(GLONCPY)(1..GNBSITE)
If CPY<>"" or FCY<>""
 Call CONTAUZ(CPY,FCY,FLAG) From EXEFNC
 End
Endif
If [F:PS2]UPDLEV=2
 NBSOC = 0
 For I=1 To GNBAUZ
  K = find(GUSRFCY(I),GSITE(1..GNBSITE))
  If K & !find(GSOCSITE(K),TSOC(1..NBSOC))
   For J=1 To GNBSITE
    If GSOCSITE(J)=GSOCSITE(K) & !find(GSITE(J),GUSRFCY(1..GNBAUZ))
     K = 0 : Break
    Endif
   Next J
   If K
    NBSOC += 1
    TSOC(NBSOC) = GSOCSITE(K)
    Call CONTAUZ(TSOC(NBSOC),FCY,FLAG) From EXEFNC
    If mkstat : Break : Endif
   Endif
  Endif
 Next I
Endif
End

################################################################
$INIT
# 1) Cadrage des dates de début et 1čre date de fin
DAT1 = [M:STA1]DATDEB
Call CADRE([F:PS2]PERPRG,[F:PS2]PERTYP,DAT1)
[M:STA1]DATDEB = DAT1

DAT2 = [M:STA1]DATFIN
Call DATFIN([F:PS2]PERPRG,[F:PS2]PERTYP,DAT1,DAT2)
[M:STA1]DATFIN = DAT2

If FLPER
 DAT3 = [M:STA1]DATDEB2
 Call CADRE([F:PS2]PERPRG,[F:PS2]PERTYP,DAT3)
 [M:STA1]DATDEB2 = DAT3

# 2) Calcul décalage entre périodes

 Call DECAL([F:PS2]PERPRG,[F:PS2]PERTYP,DAT1,DAT3,DECAL)

# 3) Calcul date de fin

 Call RECAL([F:PS2]PERPRG,[F:PS2]PERTYP,DAT2,DAT4,-DECAL)
 [M:STA1]DATFIN2 = DAT4

Endif

# Init groupe de site/société

Call GRPSITSOC([M:STA1]CPY,[F:PS2]UPDLEV,GRP,NBSITE,TSITE,NBSOC,TSOC)

# Autres inits
For I=1 To dim(VALCLE)
 VALCLE(I) = evalue("[M:STA1]CLE"+num$(I))
Next I
Return

################################################################
Subprog GRPSITSOC(CPY,UPDLEV,GRP,NBSITE,TSITE,NBSOC,TSOC)
Value Char CPY
Value Integer UPDLEV
Variable Integer GRP , NBSITE
Variable Char TSITE()(1..)
Variable Integer NBSOC
Variable Char TSOC()(1..)

Local Integer I , J , K

If clalev([F:CPY])=0 : Local File COMPANY  [CPY] : Endif
If clalev([F:AGC])=0 : Local File AGRPCPY  [AGC] : Endif
If clalev([F:FGR])=0 : Local File FACGROUP [FGR] : Endif

# Groupement de sites
If [L]CPY<>""
 Call LECTURE("CPY",[L]CPY,"") From CONTOBJ
 GRP = ([F:CPY]CPYLEGFLG=1)
 If GRP
  NBSITE = 0
  For [FGR]FGR0 Where CPY=[L]CPY
   NBSITE += 1
   TSITE(NBSITE) = [F:FGR]FCY
  Next FGR
 Endif
Endif

# Groupement de sociétés
If [L]UPDLEV=2
 NBSOC = 0
 If [L]CPY<>""
  Call LECTURE("CPY",[L]CPY,"") From CONTOBJ
  If [F:CPY]CPYLEGFLG=1
   GRP = 1
   For [AGC]AGC0 Where CPY=[L]CPY
    If !find([F:AGC]CPY,TSOC(1..NBSOC))
     NBSOC += 1
     TSOC(NBSOC) = [F:AGC]CPY
    Endif
   Next AGC
  Endif
 Else
  For I=1 To GNBAUZ
   K = find(GUSRFCY(I),GSITE(1..GNBSITE))
   If K & !find(GSOCSITE(K),TSOC(1..NBSOC))
    For J=1 To GNBSITE
     If GSOCSITE(J)=GSOCSITE(K) & !find(GSITE(J),GUSRFCY(1..GNBAUZ))
      K = 0 : Break
     Endif
    Next J
    If K
     NBSOC += 1
     TSOC(NBSOC) = GSOCSITE(K)
    Endif
    GRP = 1
   Endif
  Next I
 Endif
Endif
End

################################################################
$CONV_DEVISE
If [F:PS1]CPYFLD<>"" & evalue("[F]"+[F:PS1]CPYFLD) <> ""
 ISOC    = find(evalue("[F]"+[F:PS1]CPYFLD),GSOC(1..GNBSOC))
 SITE    = GSOC(ISOC)
Elsif [F:PS1]FCYFLD<>"" & evalue("[F]"+[F:PS1]FCYFLD) <> ""
 ISITE   = find(evalue("[F]"+[F:PS1]FCYFLD),GSITE(1..GNBSITE))
 SITE    = GSITE(ISITE)
 ISOC    = find(GSOCSITE(ISITE),GSOC(1..GNBSOC))
Else Return
Endif
Gosub CONV_DEVISE From ="WMSTA"+[F:PS2]COD
Return

#################################################
## Evaluation des formules
#################################################
$CALCUL
# On calcule en temps réel les formules non cumulées (ŕ cause du top n)
Case MA
 When 2
  For I=1 To [F:PS2]NBRFRM
   If [F:PS2]CUMFRM(I-1)<>2
    Call FORMU([F:PS2]AMTFRM(I-1),RESULT
&            ,[M:STA2]STA1(NOL),[M:STA2]STA2(NOL),[M:STA2]STA3(NOL),[M:STA2]STA4(NOL),[M:STA2]STA5(NOL)
&            ,[M:STA2]STA6(NOL),[M:STA2]STA7(NOL),[M:STA2]STA8(NOL),[M:STA2]STA9(NOL),[M:STA2]STA10(NOL)
&            ,[M:STA2]PRV1(NOL),[M:STA2]PRV2(NOL),[M:STA2]PRV3(NOL),[M:STA2]PRV4(NOL),[M:STA2]PRV5(NOL)
&            ,[M:STA2]PRV6(NOL),[M:STA2]PRV7(NOL),[M:STA2]PRV8(NOL),[M:STA2]PRV9(NOL),[M:STA2]PRV10(NOL)
&            ,[M:STA2]STB1(NOL),[M:STA2]STB2(NOL),[M:STA2]STB3(NOL),[M:STA2]STB4(NOL),[M:STA2]STB5(NOL)
&            ,[M:STA2]STB6(NOL),[M:STA2]STB7(NOL),[M:STA2]STB8(NOL),[M:STA2]STB9(NOL),[M:STA2]STB10(NOL)
&            ,[M:STA2]PRB1(NOL),[M:STA2]PRB2(NOL),[M:STA2]PRB3(NOL),[M:STA2]PRB4(NOL),[M:STA2]PRB5(NOL)
&            ,[M:STA2]PRB6(NOL),[M:STA2]PRB7(NOL),[M:STA2]PRB8(NOL),[M:STA2]PRB9(NOL),[M:STA2]PRB10(NOL))
    Assign "[M:STA2]AMT"+num$(I)+"("+num$(NOL)+")" With RESULT
   Endif
  Next I
 When 3
  If CHGPAG=1 or CHGPAG=3
   For I=1 To [F:PS2]NBRFRM
    If [F:PS2]CUMFRM(I-1)<>2
     Call FORMU([F:PS2]AMTFRM(I-1),RESULT
&              ,[M:STA3]STA1(NOL),[M:STA3]STA2(NOL),[M:STA3]STA3(NOL),[M:STA3]STA4(NOL),[M:STA3]STA5(NOL)
&              ,[M:STA3]STA6(NOL),[M:STA3]STA7(NOL),[M:STA3]STA8(NOL),[M:STA3]STA9(NOL),[M:STA3]STA10(NOL)
&              ,[M:STA3]PRV1(NOL),[M:STA3]PRV2(NOL),[M:STA3]PRV3(NOL),[M:STA3]PRV4(NOL),[M:STA3]PRV5(NOL)
&              ,[M:STA3]PRV6(NOL),[M:STA3]PRV7(NOL),[M:STA3]PRV8(NOL),[M:STA3]PRV9(NOL),[M:STA3]PRV10(NOL)
&              ,[M:STA3]STB1(NOL),[M:STA3]STB2(NOL),[M:STA3]STB3(NOL),[M:STA3]STB4(NOL),[M:STA3]STB5(NOL)
&              ,[M:STA3]STB6(NOL),[M:STA3]STB7(NOL),[M:STA3]STB8(NOL),[M:STA3]STB9(NOL),[M:STA3]STB10(NOL)
&              ,[M:STA3]PRB1(NOL),[M:STA3]PRB2(NOL),[M:STA3]PRB3(NOL),[M:STA3]PRB4(NOL),[M:STA3]PRB5(NOL)
&              ,[M:STA3]PRB6(NOL),[M:STA3]PRB7(NOL),[M:STA3]PRB8(NOL),[M:STA3]PRB9(NOL),[M:STA3]PRB10(NOL))
     Assign "[M:STA3]AMT"+num$(I)+"("+num$(NOL)+")" With RESULT
    Endif
   Next I
  Endif
Endcase
Return

################################################################
$AV_AFFICHE
# Ajout des périodes non mouvementées
# Tri pour les périodes
If CHGPAG=1 or CHGPAG=3
 If find([F:PS2]PERTYP,4,5,6) or [F:PS2]PERPRG<>""
  DAT1 = [M:STA1]DATDEB
  While DAT1<[M:STA1]DATFIN
   Call BORNES([F:PS2]PERPRG,[F:PS2]PERTYP,DAT1,DAT2,WLIBCLE)
   WCLE = DAT1+"~"+DAT2
   If !find(WCLE,[M:STA3]CLE(0..[M:STA3]NBLIG-1)) & [M:STA3]NBLIG<dim([M:STA3]CLE)-1
    [M:STA3]NBLIG += 1
    NOL = [M:STA3]NBLIG-1
    [M:STA3]CLE(NOL)    = WCLE
    [M:STA3]LIBCLE(NOL) = WLIBCLE
   Endif
   DAT1 = DAT2+1
  Wend
 Endif
 Sorta [M:STA3]NBLIG [M:STA3]NBLIG Order By [M:STA3]CLE(indice)
Endif

# Evaluation des formules cumulées
For I=1 To [F:PS2]NBRFRM
 If [F:PS2]CUMFRM(I-1)>1
  CUMRES = 0
  For NOL=0 To [M:STA2]NBLIG-1
   Call FORMU([F:PS2]AMTFRM(I-1),RESULT
&            ,[M:STA2]STA1(NOL),[M:STA2]STA2(NOL),[M:STA2]STA3(NOL),[M:STA2]STA4(NOL),[M:STA2]STA5(NOL)
&            ,[M:STA2]STA6(NOL),[M:STA2]STA7(NOL),[M:STA2]STA8(NOL),[M:STA2]STA9(NOL),[M:STA2]STA10(NOL)
&            ,[M:STA2]PRV1(NOL),[M:STA2]PRV2(NOL),[M:STA2]PRV3(NOL),[M:STA2]PRV4(NOL),[M:STA2]PRV5(NOL)
&            ,[M:STA2]PRV6(NOL),[M:STA2]PRV7(NOL),[M:STA2]PRV8(NOL),[M:STA2]PRV9(NOL),[M:STA2]PRV10(NOL)
&            ,[M:STA2]STB1(NOL),[M:STA2]STB2(NOL),[M:STA2]STB3(NOL),[M:STA2]STB4(NOL),[M:STA2]STB5(NOL)
&            ,[M:STA2]STB6(NOL),[M:STA2]STB7(NOL),[M:STA2]STB8(NOL),[M:STA2]STB9(NOL),[M:STA2]STB10(NOL)
&            ,[M:STA2]PRB1(NOL),[M:STA2]PRB2(NOL),[M:STA2]PRB3(NOL),[M:STA2]PRB4(NOL),[M:STA2]PRB5(NOL)
&            ,[M:STA2]PRB6(NOL),[M:STA2]PRB7(NOL),[M:STA2]PRB8(NOL),[M:STA2]PRB9(NOL),[M:STA2]PRB10(NOL))
   CUMRES += RESULT
   If [F:PS2]CUMFRM(I-1)=2 or [F:PS2]CUMFRM(I-1)=4
    Assign "[M:STA2]AMT"+num$(I)+"("+num$(NOL)+")" With CUMRES
   Else
    Assign "[M:STA2]AMT"+num$(I)+"("+num$(NOL)+")" With RESULT
   Endif
  Next NOL
  If CHGPAG=1 or CHGPAG=3
   CUMRES = 0
   For NOL=0 To [M:STA3]NBLIG-1
    Call FORMU([F:PS2]AMTFRM(I-1),RESULT
&             ,[M:STA3]STA1(NOL),[M:STA3]STA2(NOL),[M:STA3]STA3(NOL),[M:STA3]STA4(NOL),[M:STA3]STA5(NOL)
&             ,[M:STA3]STA6(NOL),[M:STA3]STA7(NOL),[M:STA3]STA8(NOL),[M:STA3]STA9(NOL),[M:STA3]STA10(NOL)
&             ,[M:STA3]PRV1(NOL),[M:STA3]PRV2(NOL),[M:STA3]PRV3(NOL),[M:STA3]PRV4(NOL),[M:STA3]PRV5(NOL)
&             ,[M:STA3]PRV6(NOL),[M:STA3]PRV7(NOL),[M:STA3]PRV8(NOL),[M:STA3]PRV9(NOL),[M:STA3]PRV10(NOL)
&             ,[M:STA3]STB1(NOL),[M:STA3]STB2(NOL),[M:STA3]STB3(NOL),[M:STA3]STB4(NOL),[M:STA3]STB5(NOL)
&             ,[M:STA3]STB6(NOL),[M:STA3]STB7(NOL),[M:STA3]STB8(NOL),[M:STA3]STB9(NOL),[M:STA3]STB10(NOL)
&             ,[M:STA3]PRB1(NOL),[M:STA3]PRB2(NOL),[M:STA3]PRB3(NOL),[M:STA3]PRB4(NOL),[M:STA3]PRB5(NOL)
&             ,[M:STA3]PRB6(NOL),[M:STA3]PRB7(NOL),[M:STA3]PRB8(NOL),[M:STA3]PRB9(NOL),[M:STA3]PRB10(NOL))
    CUMRES += RESULT
    If [F:PS2]CUMFRM(I-1)=2 or [F:PS2]CUMFRM(I-1)=4
     Assign "[M:STA3]AMT"+num$(I)+"("+num$(NOL)+")" With CUMRES
    Else
     Assign "[M:STA3]AMT"+num$(I)+"("+num$(NOL)+")" With RESULT
    Endif
   Next NOL
  Endif
 Endif
Next I

# Calcul du total général
If CHGPAG=1 or CHGPAG=3
 For I=1 To [F:PS2]NBRFRM
  If [F:PS2]CUMFRM(I-1)=2 or [F:PS2]CUMFRM(I-1)=4 & [M:STA3]NBLIG>0
   TOTAL(I) = evalue("[M:STA3]AMT"+num$(I)+"("+num$([M:STA3]NBLIG-1)+")")
  Else
   Call FORMU([F:PS2]AMTFRM(I-1),TOTAL(I)
&            ,sum([M:STA3]STA1),sum([M:STA3]STA2),sum([M:STA3]STA3),sum([M:STA3]STA4),sum([M:STA3]STA5)
&            ,sum([M:STA3]STA6),sum([M:STA3]STA7),sum([M:STA3]STA8),sum([M:STA3]STA9),sum([M:STA3]STA10)
&            ,sum([M:STA3]PRV1),sum([M:STA3]PRV2),sum([M:STA3]PRV3),sum([M:STA3]PRV4),sum([M:STA3]PRV5)
&            ,sum([M:STA3]PRV6),sum([M:STA3]PRV7),sum([M:STA3]PRV8),sum([M:STA3]PRV9),sum([M:STA3]PRV10)
&            ,sum([M:STA3]STB1),sum([M:STA3]STB2),sum([M:STA3]STB3),sum([M:STA3]STB4),sum([M:STA3]STB5)
&            ,sum([M:STA3]STB6),sum([M:STA3]STB7),sum([M:STA3]STB8),sum([M:STA3]STB9),sum([M:STA3]STB10)
&            ,sum([M:STA3]PRB1),sum([M:STA3]PRB2),sum([M:STA3]PRB3),sum([M:STA3]PRB4),sum([M:STA3]PRB5)
&            ,sum([M:STA3]PRB6),sum([M:STA3]PRB7),sum([M:STA3]PRB8),sum([M:STA3]PRB9),sum([M:STA3]PRB10))
  Endif
 Next I
Endif

# Calcul des pourcentages
For I=1 To [F:PS2]NBRFRM
 If [F:PS2]CUMFRM(I-1)>2 & TOTAL(I)<>0
  For NOL=0 To [M:STA2]NBLIG-1
   Assign "[M:STA2]AMT"+num$(I)+"("+num$(NOL)+")" With
&    ar2(100*evalue("[M:STA2]AMT"+num$(I)+"("+num$(NOL)+")")/TOTAL(I))
  Next NOL
  If CHGPAG=1 or CHGPAG=3
   For NOL=0 To [M:STA3]NBLIG-1
    Assign "[M:STA3]AMT"+num$(I)+"("+num$(NOL)+")" With
&     ar2(100*evalue("[M:STA3]AMT"+num$(I)+"("+num$(NOL)+")")/TOTAL(I))
   Next NOL
  Endif
 Endif
Next I

# Ajout du total sur l'onglet période
If (CHGPAG=1 or CHGPAG=3) & [M:STA3]NBLIG<dim([M:STA3]AMT1)-3
 Insa 0,2,[M:STA3]NBLIG+1 [M:STA3]NBLIG
 [M:STA3]NBLIG += 2
 NOL = 0
 If dim([M:STA3]NONAFF)>0
  [M:STA3]NONAFF(NOL)   = "X"
  [M:STA3]NONAFF(NOL+1) = "X"
 Endif
 [M:STA3]LIBCLE(NOL) = mess(151,115,1) : # Total
 For I=1 To [F:PS2]NBRFRM
  If [F:PS2]CUMFRM(I-1)=2
   If [M:STA3]NBLIG>2
    Assign "[M:STA3]AMT"+num$(I)+"("+num$(NOL)+")"
&   With evalue("[M:STA3]AMT"+num$(I)+"("+num$([M:STA3]NBLIG-1)+")")
   Endif
  Elsif [F:PS2]CUMFRM(I-1)>2
   Assign "[M:STA3]AMT"+num$(I)+"("+num$(NOL)+")" With 100
  Else
   Assign "[M:STA3]AMT"+num$(I)+"("+num$(NOL)+")" With TOTAL(I)
  Endif
 Next I
Endif
For MA=0 To 2 : Gosub SETMASK From =PROGCNS : Next MA
Affzo [STA3]
Return

################################################################################################
Subprog FORMU(EXPR,RESULT
& ,C1,C2,C3,C4,C5,C6,C7,C8,C9,C10
& ,P1,P2,P3,P4,P5,P6,P7,P8,P9,P10
& ,CC1,CC2,CC3,CC4,CC5,CC6,CC7,CC8,CC9,CC10
& ,PP1,PP2,PP3,PP4,PP5,PP6,PP7,PP8,PP9,PP10)
Value    Char    EXPR
Variable Decimal RESULT
Value    Decimal C1
Value    Decimal C2
Value    Decimal C3
Value    Decimal C4
Value    Decimal C5
Value    Decimal C6
Value    Decimal C7
Value    Decimal C8
Value    Decimal C9
Value    Decimal C10
Value    Decimal P1
Value    Decimal P2
Value    Decimal P3
Value    Decimal P4
Value    Decimal P5
Value    Decimal P6
Value    Decimal P7
Value    Decimal P8
Value    Decimal P9
Value    Decimal P10
Value    Decimal CC1
Value    Decimal CC2
Value    Decimal CC3
Value    Decimal CC4
Value    Decimal CC5
Value    Decimal CC6
Value    Decimal CC7
Value    Decimal CC8
Value    Decimal CC9
Value    Decimal CC10
Value    Decimal PP1
Value    Decimal PP2
Value    Decimal PP3
Value    Decimal PP4
Value    Decimal PP5
Value    Decimal PP6
Value    Decimal PP7
Value    Decimal PP8
Value    Decimal PP9
Value    Decimal PP10
Local    Integer ER
Onerrgo RIEN
RESULT = evalue(EXPR)
Onerrgo
If ER
 RESULT = 0
Endif
End

$RIEN
ER = errn
Resume

##################################################
## Bornes de dates d'une période + libellé
##################################################
Subprog BORNES(PERPRG,PERTYP,DAT1,DAT2,LIBCLE)
Value    Char    PERPRG
Value    Integer PERTYP
Value    Date    DAT1
Variable Date    DAT2
Variable Char    LIBCLE
If PERPRG<>""
 Call BORNES(DAT1,DAT2,LIBCLE) From =PERPRG
Else
 Case PERTYP
  When 1 : # Jour
   DAT2 = DAT1
   LIBCLE = format$("D:"+GFMDAT4,DAT1)
  When 2 : # Semaine
   DAT2 = DAT1+6
   LIBCLE = format$("N0:2#",week(DAT1))+"  :  "+format$("D:"+GFMDAT4,DAT1)+"  -  "+format$("D:"+GFMDAT4,DAT2)
  When 3 : # Quinzaine
   If day(DAT1)=1
    DAT2 = DAT1+14
   Else
    DAT2 = eomonth(DAT1)
   Endif
   LIBCLE = format$("D:"+GFMDAT4,DAT1)+"  -  " + format$("D:"+GFMDAT4,DAT2)
  When 4 : # Mois
   DAT2   = eomonth(DAT1)
   LIBCLE = month$(DAT1)-num$(year(DAT1))
  When 5 : # Trimestre
   DAT2 = eomonth(addmonth(DAT1,2))
   LIBCLE = num$(year(DAT1))-mess(5,52,1)-num$((month(DAT1)+2)/3)
  When 6 : # Année
   DAT2 = gdat$(31,12,year(DAT1))
   LIBCLE = num$(year(DAT1))
  When 7 : # Décade
   If day(DAT1)>20
    DAT2 = eomonth(DAT1)
   Elsif day(DAT1)>10
    DAT2 = gdat$(20,month(DAT1),year(DAT1))
   Else
    DAT2 = gdat$(10,month(DAT1),year(DAT1))
   Endif
   LIBCLE = format$("D:"+GFMDAT4,DAT1)+"  -  " + format$("D:"+GFMDAT4,DAT2)
 Endcase
Endif
End

##########################################################################################
# Recadrage de la date de début sur le début d'une période
##########################################################################################
Subprog CADRE(PERPRG,PERTYP,DAT1)
Value    Char    PERPRG
Value    Integer PERTYP
Variable Date    DAT1
If PERPRG<>""
 Call CADRE(DAT1) From =PERPRG
Else
 Local Integer WMON
 WMON=month(DAT1)
 If WMON=0 : WMON=1 : Endif
 Case PERTYP
  When 2 : # Semaine
   DAT1 = aweek(week(DAT1),year(DAT1))
  When 3 : # Quizaine
   If day(DAT1)>15
    DAT1 = gdat$(16,WMON,year(DAT1))
   Else
    DAT1 = gdat$(1,WMON,year(DAT1))
   Endif
  When 4 : # Mois
   DAT1 = gdat$(1,WMON,year(DAT1))
  When 5 : # Trimestre
   DAT1 = gdat$(1,3*int((WMON-1)/3)+1,year(DAT1))
  When 6 : # Année
   DAT1 = gdat$(1,1,year(DAT1))
  When 7 : # Décade
   If day(DAT1)>20
    DAT1 = gdat$(21,WMON,year(DAT1))
   Elsif day(DAT1)>10
    DAT1 = gdat$(11,WMON,year(DAT1))
   Else
    DAT1 = gdat$(01,WMON,year(DAT1))
   Endif
 Endcase
Endif
End

##########################################################################################
# Renvoie la date de fin de période en fonction du début
##########################################################################################
Subprog DATFIN(PERPRG,PERTYP,DAT1,DAT2)
Value    Char    PERPRG
Value    Integer PERTYP
Value    Date    DAT1
Variable Date    DAT2
If PERPRG<>""
 Call DATFIN(DAT1,DAT2) From =PERPRG
Else
 Local Date DAT3
 DAT3 = DAT1
 Repeat
  Case PERTYP
   When 1 : # Jour
    DAT3 += 1
   When 2 : # Semaine
    DAT3 += 7
   When 3 : # Quizaine
    If day(DAT3)>15
     DAT3 = eomonth(DAT3)+1
    Else
     DAT3 = gdat$(16,month(DAT3),year(DAT3))
    Endif
   When 4 : # Mois
    DAT3 = addmonth(DAT3,1)
   When 5 : # Trimestre
    DAT3 = addmonth(DAT3,3)
   When 6 : # Année
    DAT3 = addmonth(DAT3,12)
   When 7 : # Décade
    If day(DAT3)>20
     DAT3 = eomonth(DAT3)+1
    Elsif day(DAT3)>10
     DAT3 = gdat$(21,month(DAT3),year(DAT3))
    Else
     DAT3 = gdat$(11,month(DAT3),year(DAT3))
    Endif
  Endcase
 Until DAT3>DAT2
 DAT2 = DAT3-1
Endif
End

##########################################################################################
# Renvoie le nombre de périodes qui séparent 2 dates
##########################################################################################
# Calcul du décalage entre les 2 périodes
Subprog DECAL(PERPRG,PERTYP,DAT1,DAT3,DECAL)
Value    Char    PERPRG
Value    Integer PERTYP
Value    Date    DAT1
Value    Date    DAT3
Variable Integer DECAL
If PERPRG<>""
 Call DECAL(DAT1,DAT3,DECAL) From =PERPRG
Else
 Case PERTYP
  When 1 : # Jour
   DECAL = DAT1-DAT3
  When 2 : # Semaine
   DECAL = (DAT1-DAT3)/7
  When 3 : # Quinzaine
   DECAL = 24*(year(DAT1)-year(DAT3))+2*(month(DAT1)-month(DAT3))+(day(DAT3)<day(DAT1))-(day(DAT3)>day(DAT1))
  When 4 : # Mois
   DECAL = 12*(year(DAT1)-year(DAT3))+(month(DAT1)-month(DAT3))
  When 5 : # Trimestre
   DECAL = 4*(year(DAT1)-year(DAT3))+(month(DAT1)-month(DAT3))/3
  When 6 : # Année
   DECAL = year(DAT1)-year(DAT3)
  When 7 : # Décade
   DECAL = 36*(year(DAT1)-year(DAT3))+3*(month(DAT1)-month(DAT3))
   DECAL += min(2,int((day(DAT1)-1)/10))-min(2,int((day(DAT3)-1)/10))
 Endcase
Endif
End

##########################################################################################
# Ajoute un nombre de période ŕ une date de fin
##########################################################################################
Subprog RECAL(PERPRG,PERTYP,DAT1,DAT2,DECAL)
Value    Char    PERPRG
Value    Integer PERTYP
Value    Date    DAT1
Variable Date    DAT2
Value    Integer DECAL
If PERPRG<>""
 Call RECAL(DAT1,DAT2,DECAL) From =PERPRG
Else
 Case PERTYP
  When 1 : # Jour
   DAT2 = DAT1+DECAL
  When 2 : # Semaine
   DAT2 = DAT1+7*DECAL
  When 3 : # Quinzaine
   DAT2 = addmonth(DAT1,fix(DECAL/2))
   If day(DAT2)>15
    DAT2 = eomonth(DAT2)
   Endif
   Case mod(DECAL,2)
    When 1
     If day(DAT2)<16
      DAT2 = eomonth(DAT2)
     Else
      DAT2 = eomonth(DAT2)+15
     Endif
    When -1
     If DAT2=eomonth(DAT2)
      DAT2 = gdat$(15,month(DAT2),year(DAT2))
     Else
      DAT2 = eomonth(addmonth(DAT2,-1))
     Endif
   Endcase
  When 4 : # Mois
   DAT2 = addmonth(DAT1,DECAL)
  When 5 : # Trimestre
   DAT2 = addmonth(DAT1,3*DECAL)
  When 6 : # Année
   DAT2 = addmonth(DAT1,12*DECAL)
  When 7 : # Décade
   DAT2 = addmonth(DAT1,fix(DECAL/3))
   Case mod(DECAL,3)
    When 0
    When 1
     Case day(DAT2)
      When 10      : DAT2 = gdat$(20,month(DAT2)+1,year(DAT2))
      When 20      : DAT2 = eomonth(DAT2)
      When Default : DAT2 = gdat$(10,month(DAT2)+1,year(DAT2))
     Endcase
    When -1
     Case day(DAT2)
      When 10      : DAT2 = eomonth(addmonth(DAT2,-1))
      When 20      : DAT2 = gdat$(10,month(DAT2),year(DAT2))
      When Default : DAT2 = gdat$(20,month(DAT2),year(DAT2))
     Endcase
    When 2
     Case day(DAT2)
      When 10      : DAT2 = eomonth(DAT2)
      When 20      : DAT2 = gdat$(10,month(DAT2)+1,year(DAT2))
      When Default : DAT2 = gdat$(20,month(DAT2)+1,year(DAT2))
     Endcase
    When -2
     Case day(DAT2)
      When 10      : DAT2 = gdat$(20,month(DAT2)-1,year(DAT2))
      When 20      : DAT2 = eomonth(addmonth(DAT2,-1))
      When Default : DAT2 = gdat$(10,month(DAT2),year(DAT2))
     Endcase
   Endcase
 Endcase
Endif
If month(DAT2)=2 & day(DAT2)=28 : # Gestion année bissextille
 DAT2 = gdat$(29,month(DAT2),year(DAT2))
 If month(DAT2)<>2
  DAT2 = gdat$(28,2,year(DAT2))
 Endif
Endif
End

#############################################################"
$SETBOUT
If [M:STA1]COD=""
 Call VIREBOUT(CHAINE,"IJRC+-D") From GCONSULT
Endif
If ([M:STA1]NIVEAU<2 & ![M:STA1]ZOOM) or (!OKNIV & ![M:STA1]ZOOM & [M:STA1]NIVEAU<=NIVDEB)
 Call VIREBOUT(CHAINE,"I") From GCONSULT
 INFO = ""
Elsif [M:STA1]ZOOM
 INFO = "-"-mess(7,100,1) : # - Zoom
Else
 # Passage niveau -1
 INFO = "-"-func AFNC.TEXTRA("PARSTA2","FLDINTIT",[F:PS2]COD,num$(TR([M:STA1]NIVEAU-1)))
Endif
If [M:STA1]ZOOM | [F:PS2]NBRFLD<[M:STA1]NIVEAU
 Call VIREBOUT(CHAINE,"J") From GCONSULT
Else
 If INFO<>"" : INFO -= "/" : Endif
 If [F:PS2]NBRFLD>[M:STA1]NIVEAU
  # Passage niveau +1
  INFO -= "+"- func AFNC.TEXTRA("PARSTA2","FLDINTIT",[F:PS2]COD,num$(TR([M:STA1]NIVEAU+1)))
 Else
  INFO -= "+"-mess(7,100,1) : # + Zoom
 Endif
Endif
Inftxt INFO At 2
Return

################################################################
$EXEBOUT
Case BOUT
 When "J" : Gosub NIV_PLUS
 When "I" : Gosub NIV_MOINS
Endcase
Return

################################################################
$DEB_CRIT
If ![M:STA1]ZOOM
 Actzo COLTOT
 Actzo TOP
Else
 Grizo COLTOT
 Grizo TOP
Endif
Return

################################################################
$NIV_PLUS
[M:STA1]FILTRE = ""
If nolign<1 or nolign>[M:STA2]NBLIG : Return : Endif
NOL = nolign-1
If [F:PS2]NBRFLD>[M:STA1]NIVEAU : # Passage niveau +1
 If NOL<0 : Return : Endif
 Assign "[M:STA1]CLE"+num$([M:STA1]NIVEAU)    With [M:STA2]CLE(NOL)
 Assign "[M:STA1]LIBCLE"+num$([M:STA1]NIVEAU) With [M:STA2]LIBCLE(NOL)
 [M:STA1]NIVEAU += 1
 If [M:CSTA]COLTOT<>0
  [M:STA1]TOTAL([M:STA1]NIVEAU) = evalue("[M:STA2]AMT"+num$([M:CSTA]COLTOT)+"("+num$(NOL)+")")
 Endif
Elsif [F:PS2]NBRFLD=[M:STA1]NIVEAU : # Zoom
 Assign "[M:STA1]CLE"+num$([M:STA1]NIVEAU)    With [M:STA2]CLE(NOL)
 Assign "[M:STA1]LIBCLE"+num$([M:STA1]NIVEAU) With [M:STA2]LIBCLE(NOL)
 If [M:CSTA]COLTOT<>0
  [M:STA1]TOTAL(0) = evalue("[M:STA2]AMT"+num$([M:CSTA]COLTOT)+"("+num$(NOL)+")")
 Endif
 [M:STA1]ZOOM = 1
Endif
Gosub PAG_PREM From GCONSULT
Gosub SETBOUT From GCONSULT
OK = 0 : ZONS = "NBLIG(0)"
Return

################################################################
$NIV_MOINS
[M:STA1]FILTRE = ""
NOL = nolign-1
If [M:STA1]ZOOM : # Retour de zoom
 [M:STA1]ZOOM = 0
Else : # Passage au niveau -1
 [M:STA1]NIVEAU -= 1
Endif
If [M:STA1]PER=1
 [M:STA1]DATDEB = [M:STA1]PDAT1
 [M:STA1]DATFIN = [M:STA1]PDAT2
 Raz [M:STA1]PDAT1
 Raz [M:STA1]PDAT2
 Affzo [STA1]DATDEB , DATFIN
 [M:STA1]PER = 0
Endif
Gosub PAG_CUR From GCONSULT
Gosub SETBOUT From GCONSULT
OLD = evalue("[M:STA1]CLE"+num$([M:STA1]NIVEAU))
K = find(OLD,[M:STA2]CLE(0..[M:STA2]NBLIG-1))
If K : NOL = K-1 : Else NOL = 0 : Endif
OK = 0 : ZONS = "NBLIG("+num$(NOL)+")"
Return

################################################################
$LISTE
If [F:PS2]RPT<>""
 RPTCOD = [F:PS2]RPT
Endif
Return

######################################
Subprog LIBCLE(NBL,OBJ,FICH,ABR,INTIT)
######################################
Value Integer NBL
Value Char    OBJ(), FICH(), ABR(), INTIT()
Local Integer NOL

Local File =FICH
For NOL=0 To NBL-1
 Call LECTURE(OBJ,[M:STA2]CLE(NOL),"") From CONTOBJ
 If !fstat
  [M:STA2]LIBCLE(NOL) -= evalue("[F:"+ABR+"]"+INTIT)
 Endif
Next I
End

########################################################
##     Etiquettes des écrans CONSSTA1 & CRITSTA       ##
########################################################

Subprog C_COD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("PS2",VALEUR,"") From CONTOBJ
  If [F:PS2]UPDLEV<2 : # Dossier
  If GNBAUZ<>GNBSITE
   GMESSAGE = mess(4,104,1) : # Vous n'avez pas les droits pour ce code
   mkstat = 2 : End
  Endif
 Endif
 [M]NBRAMT = 0
 For [PSL] Where COD=[F:PS2]COD
  [M]NBRAMT += 1
 Next
Endif
End

Subprog AM_COD(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
 Call LECTURE("PS2",VALEUR,"") From CONTOBJ
 # Issue 84634 - 2012-10-08 by VPO : initialiser FCY sur chgt de code
 If [F:PS2]UPDLEV>1 & [M:STA1]FCY="" & [M:STA1]CPY=""
   mkstat = 0
   Call INIFCY([M:STA1]FCY,[M:STA1]CPY) From EXEFNC
   Call LECTURE("FCY",GFCYDEF,"") From CONTOBJ
   [M:STA1]CPY = [F:FCY]LEGCPY
   If [F:PS2]UPDLEV<3 : [M:STA1]FCY = "" : Endif : # Dossier ou société
 # Issue 84634 - End
 Elsif [F:PS2]UPDLEV>1 & [M]CPY=""
  Call INICPY([M]CPY) From EXEFNC
 Endif
 # Issue 84634 - 2012-10-08 by VPO : verifier autorisation
 Gosub VERIF_AUTORIS
Endif
End

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
If [M:STA1]COD<>""
 Call LECTURE("PS2",[M:STA1]COD,"") From CONTOBJ
 If [F:PS2]UPDLEV<2 : mkstat = 1 : End : Endif
Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
#If [F:PS2]UPDLEV=2
If [F:PS2]UPDLEV>1
 If VALEUR<>""
  Call CONTALLFCY(VALEUR) From EXEFNC
 Endif
Endif
End

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If [M:STA1]COD<>""
 Call LECTURE("PS2",[M:STA1]COD,"") From CONTOBJ
 If [F:PS2]UPDLEV<3 : mkstat = 1 : End : Endif
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
If VALEUR="" & [M]CPY=""
 If GNBAUZ<>GNBSITE
  GMESSAGE = mess(21,104,1) : # Société ou site inexistant
  mkstat = 2 : End
 Endif
Endif
End

Subprog C_DATDEB(VALEUR)
Variable Date    VALEUR
Call CADRE([F:PS2]PERPRG,[F:PS2]PERTYP,VALEUR)
End

Subprog C_DATFIN(VALEUR)
Variable Date VALEUR
Local Integer FLPER , I
Local Char    FORMULE(250)
Call DATFIN([F:PS2]PERPRG,[F:PS2]PERTYP,[M]DATDEB,VALEUR)
FLPER = 0
For I=1 To [F:PS2]NBRFRM
 FORMULE = vireblc(format$("KT:250X",[F:PS2]AMTFRM(I-1)),2)
 If instr(1,FORMULE,"PP") or instr(1,FORMULE,"CC")
  FLPER = 1 : Break
 Endif
Next I
If FLPER
 Actzo DATDEB2
 If [M]DATDEB2=[0/0/0] & [M]DATDEB<>[0/0/0]
  [M]DATDEB2=gdat$(day([M]DATDEB),month([M]DATDEB),year([M]DATDEB)-1)
 Endif
Else
 [M]DATDEB2 = [0/0/0]
 [M]DATFIN2 = [0/0/0]
 Affzo DATDEB2, DATFIN2
 Grizo DATDEB2
Endif
End

Subprog C_DATDEB2(VALEUR)
Variable Date    VALEUR
If VALEUR>=[M]DATDEB
 GERR = 1 : GMESSAGE  = mess(1,104,1) : # Date incorrecte
 mkstat = 2 : End
Endif
Call CADRE([F:PS2]PERPRG,[F:PS2]PERTYP,VALEUR)
Local Date    DAT1, DAT2, DAT3, DAT4
Local Integer DECAL
DAT1 = [M]DATDEB
DAT3 = VALEUR
DAT2 = [M]DATFIN
Call DECAL([F:PS2]PERPRG,[F:PS2]PERTYP,DAT1,DAT3,DECAL)
Call RECAL([F:PS2]PERPRG,[F:PS2]PERTYP,DAT2,DAT4,-DECAL)
[M]DATFIN2 = DAT4
End

########################################################
##     Etiquettes écran CRITSTA                       ##
########################################################
Subprog AS_COLTOT(VALEUR)
Variable Decimal VALEUR
If [M]TOP<>2 : mkstat = 1 : End : Endif
If VALEUR=0 : VALEUR = 1 : Endif
End

Subprog C_COLTOT(VALEUR)
Variable Decimal    VALEUR
If VALEUR<1 | VALEUR>[F:PS2]NBRFRM | [F:PS2]CUMFRM(VALEUR-1)>1 : mkstat = 2 : Endif
End

Subprog AS_TRI(VALEUR)
Variable Decimal VALEUR
If indice+1>[F:PS2]NBRFLD
 mkstat = 1 : End
Endif
If [F:PS2]NBRFLD<5 : Raz GBOUT5 : Endif
If [F:PS2]NBRFLD<4 : Raz GBOUT4 : Endif
If [F:PS2]NBRFLD<3 : Raz GBOUT3 : Endif
If [F:PS2]NBRFLD<2 : Raz GBOUT2 : Endif
End

Subprog C_TRI(VALEUR)
Variable Decimal VALEUR
Local Integer NOL , I
NOL = indice+1
If VALEUR<1 or VALEUR>[F:PS2]NBRFLD
 GMESSAGE = mess(83,123,1) : # Valeur incorrecte
 mkstat = 2 : End
Endif
For I=1 To [F:PS2]NBRFLD
 If I<>NOL & [M]TRI(I-1)=VALEUR
  [M]TRI(I-1) = [M]TRI(NOL-1)
  Affzo TRI(I-1)
 Endif
Next I
End

Subprog B1_TRI(VALEUR)
Variable Decimal VALEUR
VALEUR = 1
End

Subprog B2_TRI(VALEUR)
Variable Decimal VALEUR
VALEUR = 2
End

Subprog B3_TRI(VALEUR)
Variable Decimal VALEUR
VALEUR = 3
End

Subprog B4_TRI(VALEUR)
Variable Decimal VALEUR
VALEUR = 4
End

Subprog B5_TRI(VALEUR)
Variable Decimal VALEUR
VALEUR = 5
End

############################################################
##     Etiquettes écran CONSSTA2/CONSSTA3                 ##
############################################################
Subprog IB_NBLIG
Local Integer I , K
Local Char    ABRMSK(GLONABR)
For I=1 To 10
 If masknam(I)=maskcou
  K = I : Break
 Endif
Next I
If K
 ABRMSK = maskabr(K)
Endif
If [M:STA1]ZOOM
 Raz GBOUT8
Endif
Case ABRMSK
 When "STA3"
  If nolign<3 or nolign>[M:STA3]NBLIG or [M:STA1]PER<>0 or [M:STA1]ZOOM<>0
   GBOUT10 = ""
  Endif
 When Default
  Raz GBOUT1, GBOUT7
  If ![M:STA1]ZOOM
   Gosub ZOOM From ="WMSTA"+[M:STA1]COD
  Elsif [F:PS2]OBJ<>""
   GBOUT1 = [M:STA1]LIBOBJ : # Tunnel
  Endif
Endcase
End

$AB1_NBLIG
Local Integer I, SAVCONS, NOL
Local Char    CLE1(30) , CLE2(30), CLE(30)
NOL = nolign-1
CLE = [M:STA2]CLE(NOL)
I = instr(1,CLE,"~")
If I
 CLE1 = left$(CLE,I-1) : CLE = right$(CLE,I+1)
 If [M:STA1]CLEOBJ>1
  CLE2 = CLE1
  I = instr(1,CLE,"~")
  If I : CLE1 = left$(CLE,I-1)
  Else : CLE1 = CLE
  Endif
 Endif
Else
 CLE1 = CLE
Endif
SAVCONS  = GCONSULT
GCONSULT = 1
Case [F:PS2]OBJ
 When "GAS"
  If clalev([F:HAE])=0 : Local File GACCENTRY [HAE] : Endif
  Read [HAE]HAE0 = CLE1;CLE2
  If !fstat
   GFLAG  = [F:HAE]DACDIA
   #GBIDI1 = [F:HAE]ANA
  Endif
 When Default
Endcase
Return

$BB1_NBLIG
GCONSULT = SAVCONS
zonsui = "NBLIG("+num$(NOL)+")"
Return

#####################################################################
Subprog STA(OBJET,CLECUR)
Value Char OBJET
Value Char CLECUR
Local Integer I , OK , NBTEX , CHOI
Local Char    STA(GLONPS2)(1..50) , TEX(50)(1..50,1..2) , TIT(GLONDES)(0..2)
Local Integer TYP(50)
Local Char    PARAM(250)(1..10)
Local Date    DATDEB , DATFIN
If clalev([F:PS2])=0 : Local File PARSTA2 [PS2] : Endif
If clalev([F:AOB])=0 : Local File AOBJET  [AOB] : Endif
If clalev([F:AOT])=0 : Local File AOBJTAB [AOT] : Endif
If clalev([F:ATB])=0 : Local File ATABLE  [ATB] : Endif
If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif
If clalev([F:ATY])=0 : Local File ATYPE   [ATY] : Endif
If clalev([F:ACC])=0 : Local File ACCES   [ACC] : Endif
Read [AOB]ABREV = OBJET
If fstat : End : Endif
For [PS2]PS20 Where ENAFLG=2
 mkstat=0
 If [F:PS2]ACS<>"" : Call ACCES2([F:PS2]ACS) From OBJDIV : Endif
 If !mkstat
  OK = 0
  If [F:PS2]TBL(0)=[F:AOB]NOMFIC
   OK = 1
  Else
   Read [AOT]TABFIC(2) = OBJET;[F:PS2]TBL(0)
   If !fstat & [F:AOT]TABLIEN<>""
    OK = 1
   Else
    Read [ATZ]CODZONE = [F:PS2]TBL(0);[F:PS2]FLDNAM(0)
    Read [ATY]CODTYP  = [F:ATZ]CODTYP
    If [F:ATY]OBJLIEN=OBJET
     OK = 2
    Endif
   Endif
  Endif
  If OK
   NBTEX += 1
   TEX(NBTEX,1) = [F:PS2]COD
   TEX(NBTEX,2) = func AFNC.TEXTRA("PARSTA2","INTIT",[F:PS2]COD,"")
   STA(NBTEX)   = [F:PS2]COD
   TYP(NBTEX)   = OK
   If NBTEX>=dim(TEX)-1 : Break : Endif
  Endif
 Endif
Next PS2
If NBTEX=1
 CHOI = 1
Elsif NBTEX>1
 TIT(0) = mess(141,124,1)-OBJET
 TIT(1) = mess(63,126,1) : # Code stat
 TIT(2) = mess(30,109,1) : # Intitulé
 Call SAITEX(NBTEX,TEX,CHOI,TIT) From GESECRAN : # Consultations statistiques
Else
 Call MESSAGE(mess(65,126,1)) From GESECRAN
 End
Endif
If CHOI<>0 & status<>7
 Read [PS2]PS20 = STA(CHOI)
 Raz PARAM
 PARAM(1) = STA(CHOI)
 If [F:PS2]UPDLEV>1
  PARAM(3) = GDEFSOC
  If [F:PS2]UPDLEV>2
   PARAM(2) = GFCYDEF
  Endif
 Endif
 If GDATSTAFIN<>[0/0/0]
  DATFIN = GDATSTAFIN
 Else
  DATFIN = gdat$(31,12,year(datesyst))
 Endif
 If GDATSTADEB<>[0/0/0]
  DATDEB = GDATSTADEB
 Else
  DATDEB = format$("YYYYMMDD",gdat$(1,1,year(GDATSTAFIN)))
 Endif
 PARAM(4) = format$("YYYYMMDD",DATDEB)
 PARAM(5) = format$("YYYYMMDD",DATFIN)
 PARAM(6) = format$("YYYYMMDD",addmonth(DATDEB,-12))
 Gosub LIENS From ="WO"+OBJET
 K = 0
 For I=0 To [F:PS2]NBRFLD-1
  Read [AOT]TABFIC(2) = OBJET;[F:PS2]TBL(I)
  If !fstat | [F:PS2]TBL(I)=[F:AOB]NOMFIC
   Read [ATB]CODFIC = [F:PS2]TBL(I)
   PARAM(7+K) = num$(evalue("[F:"+[F:ATB]ABRFIC+"]"+[F:PS2]FLDNAM(I)+"("+num$([F:PS2]FLDIND(I))+")"))
   If [F:PS2]FLDPOS(I)<>0
    PARAM(7+K) = mid$(PARAM(7+K),[F:PS2]FLDPOS(I),[F:PS2]FLDLON(I))
   Endif
   K += 1
  Else
   Read [ATZ]CODZONE = [F:PS2]TBL(I);[F:PS2]FLDNAM(I)
   Read [ATY]CODTYP  = [F:ATZ]CODTYP
   If [F:ATY]OBJLIEN=OBJET
    PARAM(7+K) = CLECUR
    K += 1
   Else
    Break
   Endif
  Endif
 Next I
 Call GCONSULT("STA","",PARAM) From GCONSULT
Endif
End

########################################
$ZOOM_PERIODE
Onerrgo ERRPER
ERR = 0
[M:STA1]PDAT1 = [M:STA1]DATDEB
[M:STA1]PDAT2 = [M:STA1]DATFIN
[M:STA1]DATDEB = gdat$(left$([M:STA3]CLE(nolign-1),8))
[M:STA1]DATFIN = gdat$(right$([M:STA3]CLE(nolign-1),10))
Affzo [STA1]DATDEB , DATFIN
Onerrgo
If ERR
 [M:STA1]DATDEB = [M:STA1]PDAT1
 [M:STA1]DATFIN = [M:STA1]PDAT2
 Raz [M:STA1]PDAT1
 Raz [M:STA1]PDAT2
 Affzo [STA1]DATDEB , DATFIN
 Return
Endif
[M:STA1]ZOOM = 1
[M:STA1]PER  = 1
Gosub PAG_PREM From GCONSULT
Gosub SETBOUT From GCONSULT
OK = 0 : zonsui = "[M:STA2]NBLIG(0)"
Return

$ERRPER
ERR = 1
Resume

########################################
Subprog B8_NBLIG
Local Integer CHOIX
If [M:STA2]OBJBOU <> ""
 Call SAICAR([M:STA1]FILTRE,mess(15,109,1),[M]LIBCRIT,[M:STA2]OBJBOU,0,80,[M:STA2]OBJSEC,CHOIX) From GESECRAN
Else
 Call SAICAR([M:STA1]FILTRE,mess(15,109,1),[M]LIBCRIT,"A",0,80,"",CHOIX) From GESECRAN
Endif
If CHOIX = 2
 mkstat = 4
Endif
End

Subprog B10_NBLIG
 mkstat = 4
End

