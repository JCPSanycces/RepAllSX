   [M:STA2]STB1(NOL)   = WWAMT1
   [M:STA2]STB2(NOL)   = WWAMT2
   [M:STA2]STB3(NOL)   = WWAMT3
   [M:STA2]STB4(NOL)   = WWAMT4
   [M:STA2]STB5(NOL)   = WWAMT5
   [M:STA2]STB6(NOL)   = WWAMT6
   [M:STA2]STB7(NOL)   = WWAMT7
   [M:STA2]STB8(NOL)   = WWAMT8
   [M:STA2]STB9(NOL)   = WWAMT9
   [M:STA2]STB10(NOL)  = WWAMT10
  When 3
   [M:STA3]CLE(NOL)    = WCLE
   If PASSE=1
    [M:STA3]LIBCLE(NOL) = WLIBCLE
    [M:STA3]STA1(NOL)   = WAMT1
    [M:STA3]STA2(NOL)   = WAMT2
    [M:STA3]STA3(NOL)   = WAMT3
    [M:STA3]STA4(NOL)   = WAMT4
    [M:STA3]STA5(NOL)   = WAMT5
    [M:STA3]STA6(NOL)   = WAMT6
    [M:STA3]STA7(NOL)   = WAMT7
    [M:STA3]STA8(NOL)   = WAMT8
    [M:STA3]STA9(NOL)   = WAMT9
    [M:STA3]STA10(NOL)  = WAMT10
   Else
    [M:STA3]STB1(NOL)   = WWAMT1
    [M:STA3]STB2(NOL)   = WWAMT2
    [M:STA3]STB3(NOL)   = WWAMT3
    [M:STA3]STB4(NOL)   = WWAMT4
    [M:STA3]STB5(NOL)   = WWAMT5
    [M:STA3]STB6(NOL)   = WWAMT6
    [M:STA3]STB7(NOL)   = WWAMT7
    [M:STA3]STB8(NOL)   = WWAMT8
    [M:STA3]STB9(NOL)   = WWAMT9
    [M:STA3]STB10(NOL)  = WWAMT10
   Endif
 Endcase
Endif
Return

