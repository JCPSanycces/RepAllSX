 Else
  #YYN44 Ańado filtro
  #Filter [SAT] Where evalue([L]CRITCLB) Order By Key CLE = evalue("CRI"+num$(TR([M:STA1]NIVEAU))) Desc
   Case [M:STA1]COD
    When "YVE01"  :
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue([L]CRITCLB) and [SAT]CRI1=[M:STA1]YFILTROC Order By Key CLE = evalue("CRI"+num$(TR([M:STA1]NIVEAU))) Desc
      Else
        Filter [SAT] Where evalue([L]CRITCLB) Order By Key CLE = evalue("CRI"+num$(TR([M:STA1]NIVEAU))) Desc
      Endif
    When "YVE02"  :
      If [M:STA1]YFILTROC<> ""
        Filter [SAT] Where evalue([L]CRITCLB) and [SAT]CRI1=[M:STA1]YFILTROC Order By Key CLE = evalue("CRI"+num$(TR([M:STA1]NIVEAU))) Desc
      Else
        Filter [SAT] Where evalue([L]CRITCLB) Order By Key CLE = evalue("CRI"+num$(TR([M:STA1]NIVEAU))) Desc
      Endif
    When Default
      Filter [SAP] Where evalue([L]CRITCLB) Order By Key CLE = evalue("CRI"+num$(TR([M:STA1]NIVEAU))) Desc
   Endcase
   #YYN44 fin

  Filter [SAP] Where evalue([L]CRITCLB) Order By Key CLE = evalue("CRI"+num$(TR([M:STA1]NIVEAU))) Desc
 Endif
 #end X3-44466
 CRITBUD = "CRI"+num$(TR([M:STA1]NIVEAU))+"=[F:SAT]CRI"+num$(TR([M:STA1]NIVEAU))
 MA = 2

 For [SAT]CLE(1)
  Gosub REMPLIT
  If PLEIN : Break : Endif
  If !([M:CSTA]TOP=2 & [M:CSTA]COLTOT>0)
   If FLBUD : Gosub REMPBUD : Endif
   Gosub CALCUL
  Endif
 Next SAT
 If [M:CSTA]TOP=2 & [M:CSTA]COLTOT>0
  If NOL>0 & NOL<dim([M]CLE)-1 : NOL -= 1 : Endif : # mb 4.2.3 bug 17260
  Gosub TRITOP
 Endif

Endif

J = !([M:STA1]ZOOM)
[M:STA1]LIBEL=""
For I=1+J To [M:STA1]NIVEAU
 If I=1+J : [M:STA1]LIBEL = [M:STA1]LIBCLE1
 Else     : [M:STA1]LIBEL -="/"-evalue("[M:STA1]LIBCLE"+num$(I-J))
 Endif
Next I
If [M:STA1]ZOOM
 [M:STA1]LIBEL-= "/"-[M:STA1]LIBPER
Endif

If [M:STA1]ZOOM
# On ferme tout et on ré-ouvre tout pour se débarraser des tables de zoom
#
 Local Char NOMTRT(GLONADC)
 Gosub PREFIXE From SUBPS2
 NOMTRT = "W"+[L]LETTRE+[L]PFIX2+[M:STA1]COD
 Gosub FERME From = NOMTRT : # mb 28.5.1 bug 9275
 Gosub OUVRE From = PROGCNS
 If evalue("clalev([F:"+ABFIC+"])")=0
  Gosub OUVFIC From =PROGCNS
 Endif
 If clalev([F:SAT])=0  : Local File STAT    [SAT]  : Endif
 If clalev([F:SAT2])=0 : Local File STAT    [SAT2] : Endif
 If clalev([F:SAP])=0  : Local File STATPRV [SAP]  : Endif
 Call LECTURE("PS2",[M:STA1]COD,"") From CONTOBJ
 Call LECTURE("PS1",[F:PS2]RLG,"") From CONTOBJ
Endif

STACUR  = [M:STA1]COD
ZOOMCUR = [M:STA1]ZOOM
Return

################################################################
$REMPLIT
If NBLU=1
 If CHGPAG=2 or CHGPAG=-2
  Case MA
   When 2 : Raz [M:STA2]
   When 3 : Raz [M:STA3]
  Endcase
 Endif
 NBLU=2
Endif
If ![M:STA1]ZOOM & [M:CSTA]TOP=2 & [M:CSTA]COLTOT>0 & MA=2
 If NOL<=0 : NOL = 0 : Endif
 NOL += 1
 Gosub LIRE
 Gosub INSTOP : # Pour ne garder que les top n
Else
 If CHGPAG>0
  If MA=2
   If NOL>=MAXLIG-1 : SUITE=2 : PLEIN=1 : Return : Endif
   NOL += 1
  Endif
 Else
  If NOL<=0 : RETOUR = 2 : PLEIN=1 : Return : Endif
  NOL -= 1
 Endif
 Gosub LIRE
 Case MA
  When 2
   [M:STA2]CLE(NOL)    = WCLE
   [M:STA2]LIBCLE(NOL) = WLIBCLE
   [M:STA2]STA1(NOL)   = WAMT1
   [M:STA2]STA2(NOL)   = WAMT2
   [M:STA2]STA3(NOL)   = WAMT3
   [M:STA2]STA4(NOL)   = WAMT4
   [M:STA2]STA5(NOL)   = WAMT5
