#<AdxTL>@(#)0.0.0.0 $Revision$ Artículos
$ACTION
# If GUSER="AIT51" Then : Infbox ACTION : Endif
Case ACTION
    When "OUVRE"      :   Gosub OUVRE
    When "FILTRE"     :   Gosub FILTRE
    When "LIENS"      :   Gosub LIENS
    When "SETBOUT"    :   Gosub SETBOUT
    When "CREATION"   :   Gosub MODIF
    When "MODIF"      :   Gosub MODIF
    When "ANNULE"     :   Gosub ANNULE
    When "AP_ANNULE"  :   Gosub AP_ANNULE
    When "SEL_TABLE"  :   Gosub SEL_TABLE
    When "VERF_TABLE" :   Gosub VERF_TABLE
    When "APRES_CRE"  :   Gosub APRES_CRE
    When "APRES_MOD"  :   Gosub APRES_MOD
    When "FIN"        :   Gosub FIN
Endcase
Return

############################################
$OUVRE
If !GWEBSERV
  If !clalev([F:NUT0]) Then : Local File YNUTRIENTES  [F:NUT0] : Endif
  If !clalev([F:NUT1]) Then : Local File YNUTRIENTES  [F:NUT1] : Endif
  If !clalev([F:ING0]) Then : Local File YINGREDIENTE [F:ING0] : Endif
  If !clalev([F:ING1]) Then : Local File YINGREDIENTE [F:ING1] : Endif
  If !clalev([F:YII0]) Then : Local File YINDITM      [F:YII0] : Endif    # YYN43
  If !clalev([F:YIS0]) Then : Local File YINDICES     [F:YIS0] : Endif    # YYN43
Endif

If GWEBSERV
  Global Char GAPP(50) : GAPP = "APP"
Endif

Return

############################################
$FILTRE
  If GWEBSERV
    GPE=1
    FILTSUP = "SEAKEY = GAPP"
  Endif
Return

############################################
$LIENS
  If !GWEBSERV

    # Muestro registros bloque de atributos (pestaña Ynsadiet)
    Local Integer LCON0
    If !clalev([F:YAI1]) Then : Local File YATRIBITM [F:YAI1] : Endif
    Filter [YIAT] Where [YIAT]ARTICULO = [M:ITM0]ITMREF Order By ATRIBUTO Asc
        For [YIAT]
            Read [F:YAI1]YAI0 = [YIAT]YGATRIBUTO;[YIAT]ATRIBUTO
            [M:YITM6]CDGGRUPO(LCON0)    = [YIAT]YGATRIBUTO
            [M:YITM6]DESGRUPO(LCON0)    = func AFNC.TEXTRA("ATABDIV","LNGDES","2501",[YIAT]YGATRIBUTO) # [YAI1]DESGRUPO
            Affzo [M:YITM6]DESGRUPO(LCON0)
            [M:YITM6]CDGATRIBUTO(LCON0) = [YIAT]ATRIBUTO
            [M:YITM6]DESATRIBUTO(LCON0) = func AFNC.TEXTRA("ATABDIV","LNGDES","2500",[YIAT]ATRIBUTO) # [YAI1]DESATRIBUTO
            Affzo [M:YITM6]DESATRIBUTO(LCON0)
            LCON0 += 1
        Next
    Filter [YIAT]
    [M:YITM6]NBATRI = LCON0
    If clalev([F:YAI1]) Then : Close Local File [F:YAI1] : Endif

    # Muestro registros bloque de nutrientes (pestaña E-commerce)
    Raz LCON0
    Filter [F:NUT1] Where ITMREF = [M:ITM0]ITMREF Order By NUMLIN Asc
    For [NUT1]
      [M:YITM8]LANGUE(LCON0)      = [F:NUT1]LANGUE
      [M:YITM8]VMA(LCON0)         = [F:NUT1]VMA
      [M:YITM8]POR100GR(LCON0)    = [F:NUT1]POR100GR
      [M:YITM8]PORRACION(LCON0)   = [F:NUT1]PORRACION
      LCON0 += 1
    Next
    Filter [F:NUT1]
    [M:YITM8]NBLIG = LCON0

    # Muestro registros bloque de ingredientes (pestaña E-commerce)
    Raz LCON0
    Filter [F:ING1] Where ITMREF = [M:ITM0]ITMREF Order By NUMLIN Asc
    For [ING1]
      [M:YITM8]LANGUEI(LCON0)     = [F:ING1]LANGUEI
      [M:YITM8]NOI(LCON0)         = [F:ING1]NOI
      [M:YITM8]CANTIDAD(LCON0)    = [F:ING1]CANTIDAD
      [M:YITM8]VRN(LCON0)         = [F:ING1]VRN
      LCON0 += 1
    Next
    Filter [F:ING1]
    [M:YITM8]NBING = LCON0

    # Muestro registros bloque de índices (pestaña Ynsadiet) YYN43
    Raz LCON0
    Filter [F:YII0] Where ITMREF = [M:ITM0]ITMREF Order By Key YII0 Asc
    For [YII0]
      Read [F:YIS0]YIS0 = [F:YII0]YINDREF;[F:YII0]YSUBREF
      [M:YITM8]YINDREF(LCON0) = [F:YII0]YINDREF
      [M:YITM8]YINDDES(LCON0) = [F:YIS0]YINDDES
      [M:YITM8]YSUBREF(LCON0) = [F:YII0]YSUBREF
      [M:YITM8]YSUBDES(LCON0) = [F:YIS0]YSUBDES
      LCON0 += 1
    Next
    Filter [F:YII0]
    [M:YITM8]NBINDICE = LCON0

    Affzo [M:YITM8]
    Affzo [M:YITM6]

  Endif

Return

############################################
$SETBOUT
# JC - 20/06/2020 - YN36 - STR
  CHMEN += "s"
# JC - 20/06/2020 - YN36 - END
Return

############################################
$MODIF
  If !GWEBSERV
    # Almaceno registros tabla de atributos (pestaña Ynsadiet)
    For [YIAT] Where [YIAT]ARTICULO = [M:ITM0]ITMREF
        Delete [YIAT] Curr
    Next

    For nolign = 1 To [M:YITM6]NBATRI
        Raz [YIAT]
        If [M:YITM6]CDGGRUPO(nolign-1) <> '' Then
          [YIAT]ARTICULO   = [M:ITM0]ITMREF
          [YIAT]ATRIBUTO   = [M:YITM6]CDGATRIBUTO(nolign-1)
          [YIAT]YGATRIBUTO = [M:YITM6]CDGGRUPO(nolign-1)
          Write [YIAT]
        Endif
    Next

    # relleno la tabla de nutrientes
    Read [ITM]ITM0 = [M:ITM0]ITMREF
    Local Integer LCON1
    If [ITM]YWEBFLG = 2 Then
      Delete [F:NUT0]  Where [F:NUT0]ITMREF = [M:ITM0]ITMREF
      For LCON1 = 0 To [M:YITM8]NBLIG-1
        [F:NUT0]ITMREF      = [M:ITM0]ITMREF
        [F:NUT0]LANGUE      = [M:YITM8]LANGUE(LCON1)
        [F:NUT0]VMA         = [M:YITM8]VMA(LCON1)
        [F:NUT0]POR100GR    = [M:YITM8]POR100GR(LCON1)
        [F:NUT0]PORRACION   = [M:YITM8]PORRACION(LCON1)
        [F:NUT0]NUMLIN      = LCON1
        Write [F:NUT0]
      Next
      Raz LCON1
    Endif

    # relleno la tabla de ingredientes
    Delete [F:ING0]  Where [F:ING0]ITMREF = [M:ITM0]ITMREF
    Raz LCON1
    For LCON1 = 0 To [M:YITM8]NBING-1
      [F:ING0]ITMREF      = [M:ITM0]ITMREF
      [F:ING0]LANGUEI     = [M:YITM8]LANGUEI(LCON1)
      [F:ING0]NOI         = [M:YITM8]NOI(LCON1)
      [F:ING0]CANTIDAD    = [M:YITM8]CANTIDAD(LCON1)
      [F:ING0]VRN         = [M:YITM8]VRN(LCON1)
      [F:ING0]NUMLIN      = LCON1
      Write [F:ING0]
    Next

    # relleno la tabla de índices YYN43
    Delete [F:YII0]  Where [F:YII0]ITMREF = [M:ITM0]ITMREF
    Raz LCON1
    For LCON1 = 0 To [M:YITM8]NBINDICE-1
      [F:YII0]ITMREF      = [M:ITM0]ITMREF
      [F:YII0]YINDREF     = [M:YITM8]YINDREF(LCON1)
      [F:YII0]YSUBREF     = [M:YITM8]YSUBREF(LCON1)
      Write [F:YII0]
    Next

    Kill LCON1

  Endif
Return


############################################
$ANNULE
  If !GWEBSERV
    # Borro registros tabla de atributos (pestaña Ynsadiet)
    Delete [YIAT]  Where [YIAT]ARTICULO = [ITM0]ITMREF

    # Borro registros tabla de nutrientes (pestaña E-commerce)
    Delete [F:NUT0]  Where [F:NUT0]ITMREF = [M:ITM0]ITMREF

    # Borro registros tabla de ingredientes (pestaña E-commerce)
    Delete [F:ING0]  Where [F:ING0]ITMREF = [M:ITM0]ITMREF

    # Borro registros tabla de índices (pestaña Ynsadiet) YYN43
    Delete [F:YII0]  Where [F:YII0]ITMREF = [M:ITM0]ITMREF
  Endif

  # Desactiva el artículo en Comerzzia
  If GWEBSERV <> 2 Then
    If [M:ITM0]YTPVFLG = 2 Then
      Call SET_ITM_INACT_COMERZZIA([M:ITM0]ITMREF) From SPEYLIB0
    Endif
  Endif

Return

############################################
$AP_ANNULE
  Call DESACTIVAARTICULO([F:ITM]ITMREF) From YINACATAL
Return

############################################
$FIN
If !GWEBSERV
  Close Local File [NUT0],[NUT1],[ING0],[ING1],[YII0]
Endif
Return

############################################
$SEL_TABLE
  Case TABLE
    When "YSELCDGGR"   : Gosub SEL_YSELCDGGR    # YN17
    When "YSELCDGAT"   : Gosub SEL_YSELCDGAT    # YN17
    When "YSELINDICE"  : Gosub SEL_YSELINDICE   # YN43
    When "YSELSUBIND"  : Gosub SEL_YSELSUBIND   # YN43
  Endcase
Return

############################################
$VERF_TABLE
  Case TABLE
    When "YSELCDGGR"   : Gosub VERF_YSELCDGGR   # YN17
    When "YSELCDGAT"   : Gosub VERF_YSELCDGAT   # YN17
    When "YSELINDICE"  : Gosub VERF_YSELINDICE  # YN43
    When "YSELSUBIND"  : Gosub VERF_YSELSUBIND  # YN43
  Endcase
Return

############################################
# YN17
$SEL_YSELCDGGR
  If !clalev([F:YVG1]) Then : Local File YVISGRATRIB [F:YVG1] : Endif
  Default File [YVG1]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Grupos"                                                        # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "CDGGRUPO"                                                      # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la primera columna
  COL(NBCOL)  = "DESGRUPO"                                                      # nombre del campo a mostrar en la primera columna
Return

############################################
# YN17
$VERF_YSELCDGGR
  [M:YITM6]DESGRUPO(nolign-1) = [F:YVG1]DESGRUPO # func AFNC.TEXTRA("ATABDIV","LNGDES","2501",[M:YITM6]CDGGRUPO(nolign-1)) #
  #Infbox [M:YITM6]DESGRUPO(nolign-1)
  Affzo [M:YITM6]DESGRUPO(nolign-1)
Return

############################################
$SEL_YSELCDGAT
  If !clalev([F:YVA1]) Then : Local File YVISATRIBUTO [F:YVA1] : Endif
  Default File [YVA1]
  Filter [F:YVA1] Where CDGGRUPO = [M:YITM6]CDGGRUPO(nolign-1)
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Atributos"                                                     # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "CDGATRIBUTO"                                                   # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la primera columna
  COL(NBCOL)  = "DESATRIBUTO"                                                   # nombre del campo a mostrar en la primera columna
Return

############################################
$VERF_YSELCDGAT
  [M:YITM6]DESATRIBUTO(nolign-1) = [F:YVA1]DESATRIBUTO
  Affzo [M:YITM6]DESATRIBUTO(nolign-1)
Return

############################################
# YN43
$SEL_YSELINDICE
  If !clalev([F:YVI1]) Then : Local File YVISINDICES [F:YVI1] : Endif
  Default File [YVI1]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Índices"                                                       # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "YINDREF"                                                       # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la primera columna
  COL(NBCOL)  = "YINDDES"                                                       # nombre del campo a mostrar en la primera columna
Return

############################################
# YN43
$VERF_YSELINDICE
  [M:YITM8]YINDDES(nolign-1) = [F:YVI1]YINDDES
  Affzo [M:YITM8]YINDDES(nolign-1)
Return

############################################
# YN43
$SEL_YSELSUBIND
  If !clalev([F:YVS1]) Then : Local File YVISSUBIND [F:YVS1] : Endif
  Default File [YVS1]
  Filter [F:YVS1] Where YINDREF = [M:YITM8]YINDREF(nolign-1)
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Súbíndices"                                                    # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "YSUBREF"                                                       # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la primera columna
  COL(NBCOL)  = "YSUBDES"                                                       # nombre del campo a mostrar en la primera columna
Return

############################################
# YN43
$VERF_YSELSUBIND
  [M:YITM8]YSUBDES(nolign-1) = [F:YVS1]YSUBDES
  Affzo [M:YITM8]YSUBDES(nolign-1)
Return

############################################
$APRES_CRE
If GWEBSERV <> 2 Then
  If [M:ITM0]YTPVFLG = 2 Then
    Call SET_ITM_COMERZZIA([M:ITM0]ITMREF) From SPEYLIB0
  Endif
Endif
Return

############################################
$APRES_MOD
If GWEBSERV <> 2 Then
  If [M:ITM0]YTPVFLG = 2 Then
    Call SET_ITM_COMERZZIA([M:ITM0]ITMREF) From SPEYLIB0
  Endif
Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
Subprog C_ATRIBUTO(VALEUR)
Variable Char    VALEUR()
# Controlo que el registro no se haya introducido en líneas anteriores
#Call UNICITE(VALEUR,[M:YITM6]ATRIBUTO(0..[M:YITM6]PIE_AT-1)) From OBJDIV
End

######################################################################################
## Etiqueta añadida por el supervisor (pantalla YITM6) 07/02/2020 10:45:30 (AIT07)
######################################################################################
Subprog C_YGATRIBUTO(VALEUR)
Variable Char    VALEUR()
End

######################################################################################
## Después de modificar el campo 'Artículo web'
######################################################################################
Subprog AM_YWEBFLG(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    [M:ITM0]YB2BFLG = 2
    [M:ITM0]YB2CFLG = 1
    Affzo [M:ITM0]YB2BFLG
    Affzo [M:ITM0]YB2CFLG
  Else
    [M:ITM0]YB2BFLG = 1
    [M:ITM0]YB2CFLG = 1
    Affzo [M:ITM0]YB2BFLG
    Affzo [M:ITM0]YB2CFLG
  Endif
End

##############################################################
