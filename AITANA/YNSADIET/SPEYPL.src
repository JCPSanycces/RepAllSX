######################################################################################
## Botón 1 - Seleccionar todos los registros de grid 'Estados'
######################################################################################
Subprog B1_NBSTA
Local Integer LCON5 : Raz LCON5

  For LCON5 = 0 To [M:YPL0]NBSTA-1
    [M:YPL0]SELSTA(LCON5) = 2
    Affzo [M:YPL0]SELSTA(LCON5)
  Next
If dim(LCON5) > 0  Then : Kill LCON5 : Endif
End

######################################################################################
## Botón 1 - Seleccionar todos los registros de grid 'Estados'
######################################################################################
Subprog B2_NBSTA
Local Integer LCON5 : Raz LCON5

  For LCON5 = 0 To [M:YPL0]NBSTA-1
    [M:YPL0]SELSTA(LCON5) = 1
    Affzo [M:YPL0]SELSTA(LCON5)
  Next
If dim(LCON5) > 0  Then : Kill LCON5 : Endif
End

######################################################################################
## Después del campo 'Liberación'
######################################################################################
Subprog AP_LIBERACION(VALEUR)
Variable Date    VALEUR
#  zonsui = "[M:YPL1]NOTASLIB"
End

######################################################################################
## Después de modificar el campo 'Liberación' del bloque de datos
######################################################################################
Subprog AM_LIBERACION(VALEUR)
Variable Date    VALEUR

Global Date GLIBERACION_ANT : GLIBERACION_ANT = [M:YPL2]LIBERACION(GNOL)

  [M:YPL2]LIBERACION(GNOL) = VALEUR
  Affzo [M:YPL2]LIBERACION(GNOL)
  GFLGCHANGE+=1
  zonsui = "[M:YPL1]NOTASLIB"

  If [M:YPL1]APTO <> 2 Then
    VALEUR = [M:YPL1]LIBERACION
  Endif

End

######################################################################################
## Antes de campo 'Liberación'
######################################################################################
Subprog AS_LIBERACION(VALEUR)
Variable Date    VALEUR
End

######################################################################################
## Después de modificar el campo 'Apto' en pantalla de datos
######################################################################################
Subprog AM_APTO(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    Actzo [M:YPL1]LIBERACION
    If [M:YPL1]LIBERACION = [00/00/0000] Then
      [M:YPL1]LIBERACION = date$
      Affzo [M:YPL1]LIBERACION
    Endif
  Endif
End

######################################################################################
## Después de modificar el campo 'Desde liberación'
######################################################################################
Subprog AM_STRLIB(VALEUR)
Variable Date    VALEUR
  If [M:YPL0]ENDLIB = [00/00/0000] Then
    [M:YPL0]ENDLIB = VALEUR
    Affzo [M:YPL0]ENDLIB
  Endif
End

######################################################################################
## Después de modificar el campo 'Desde Número'
######################################################################################
Subprog AM_STRMFG(VALEUR)
Variable Char    VALEUR()
  If [M:YPL0]ENDMFG = "" Then
    [M:YPL0]ENDMFG = VALEUR
    Affzo [M:YPL0]ENDMFG
  Endif
End

######################################################################################
## Después del campo 'Notas liberación'
######################################################################################
Subprog AP_NOTASLIB(VALEUR)
Variable Clbfile VALEUR
End

######################################################################################
## Etiqueta añadida por el supervisor (pantalla YPL1) 20/07/2020 11:57:03 (AIT07)
######################################################################################
Subprog AM_NOTASLIB(VALEUR)
Variable Clbfile VALEUR

Global Clbfile GNOTASLIB_ANT(2) : GNOTASLIB_ANT = [M:YPL2]NOTASLIB(GNOL)

  [M:YPL2]NOTASLIB(GNOL) = VALEUR
  Affzo [M:YPL2]NOTASLIB(GNOL)
  GFLGCHANGE+=1
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
###############################################################
#######################
#**
#* genera el fichero y realiza la importación de salida de stock
#*
#* @param PERROR1  > devuelve el estado de la importación  PERROR1=1 -> éxito ; PERROR1<>1 -> error
#*!
Subprog GENERA_FICHSALIDA(PERROR1)
Variable Integer PERROR1
Local   Char LDIRIMPORT1(250) : LDIRIMPORT1 = filpath("IMPORT_EXPORT\PARRILLAS\Mov_Parrillas","","")
Global  Char LFILE_W1(200) : LFILE_W1 = "\CambioStockSalidaPL"
Local   Char LDATCAB1(100)(9), LDATLINL1(100)(8), LDATLINS1(100)(13)
Local   Char LFECHA1(10), LHORA1(10) : Raz LFECHA1, LHORA1
Local   Char LSEP1(1) : LSEP1 = ";"  # separador

  LFECHA1 = vireblc(num$(date$),4) : LFECHA1 = mid$(LFECHA1,1,2)+mid$(LFECHA1,4,2)+mid$(LFECHA1,7,4)
  LHORA1  = vireblc(num$(time$),4) : LHORA1  = mid$(LHORA1,1,2)+mid$(LHORA1,4,2)+mid$(LHORA1,7,2)

  LFILE_W1 = LDIRIMPORT1 + LFILE_W1 + "_" + LFECHA1 + LHORA1 + ".txt"

  # borramos el fichero si existe...
  If filinfo(LFILE_W1, 7) > 0 Then
    System "ae_rm " + LFILE_W1
  Endif

  # abrir el fichero para escritura
  Gosub OPEN_FILE_W1

  # datos de cabecera movimiento
  Raz LDATCAB1
  LDATCAB1(0)  = "E"                                            # Inidicador
  LDATCAB1(1)  = num$(19)                                       # Tipo de asiento
  LDATCAB1(2)  = ""                                             # Número de asiento
  LDATCAB1(3)  = [M:YPL1]MFGFCY                                 # Planta stock
  LDATCAB1(4)  = [M:YPL1]TRKLAST                                # Fecha imputación
  LDATCAB1(5)  = "CAMBIO STOCK A1->A DESDE PL"                  # Descripción
  LDATCAB1(6)  = ""                                             # Proyecto
  LDATCAB1(7)  = ""                                             # Código movimiento
  LDATCAB1(8)  = "030"                                          # Código familia

  # datos de línea movimiento
  Raz LDATLINL1
  LDATLINL1(0) = "L"                                            # Indicador
  LDATLINL1(1) = num$(1000)                                     # Número de línea de asiento
  LDATLINL1(2) = [M:YPL1]ITMREF                                 # Código de artículo
#  LDATLINL1(3) = [M:YPL1]ITMDESL(nolign-1)                      # Descripción 1
  LDATLINL1(4) = [M:YPL1]UOM                                    # Unidad
  LDATLINL1(5) = num$([M:YPL1]CPLQTY)                           # Cantidad
  LDATLINL1(6) = [M:YPL1]UOM                                    # Unidad Stock
  LDATLINL1(7) = num$([M:YPL1]CPLQTY)                           # Cantidad US

  # datos stock
  Raz LDATLINS1
  LDATLINS1(0) = "S"                                            # Indicador
  LDATLINS1(1) = [M:YPL1]UOM                                    # Unidad
  LDATLINS1(2) = num$([M:YPL1]CPLQTY * -1)                      # Cantidad
  LDATLINS1(3) = [M:YPL1]LOTE                                   # Lote
  LDATLINS1(4) = ""                                             # S/Lote
  LDATLINS1(5) = ""                                             # Número contenedor
  LDATLINS1(6) = "SSA010101"                                    # Ubicación    (siempre SSA010101 por indicación de Marta en la tarjeta de planner)
  LDATLINS1(7) = [M:YPL1]ESTADO                                 # Estado
  LDATLINS1(8) = ""                                             # Serie
  LDATLINS1(9) = ""                                             # Observaciones
  LDATLINS1(10)= ""                                             # Referencia
  LDATLINS1(11)= [M:YPL1]CADUCIDAD                              # Caducidad
  LDATLINS1(12)= "A1->A DESDE PL -"-[M:YPL1]MFGNUM              # Descripción mvto.

  # datos de cabecera movimiento
    Wrseq LDATCAB1(0) + LSEP1 + LDATCAB1(1) + LSEP1 + LDATCAB1(2) + LSEP1 + LDATCAB1(3) + LSEP1 + LDATCAB1(4) + LSEP1 +
&         LDATCAB1(5) + LSEP1 + LDATCAB1(6) + LSEP1 + LDATCAB1(7) + LSEP1 + LDATCAB1(8) Using [ZIMP_W1]

  # datos de línea movimiento
    Wrseq LDATLINL1(0) + LSEP1 + LDATLINL1(1) + LSEP1 + LDATLINL1(2) + LSEP1 + LDATLINL1(3) + LSEP1 + LDATLINL1(4) + LSEP1 + LDATLINL1(5) + LSEP1 +
&   LDATLINL1(6) + LSEP1 + LDATLINL1(7) Using [ZIMP_W1]

  # datos stock
    Wrseq LDATLINS1(0) + LSEP1 + LDATLINS1(1) + LSEP1 + LDATLINS1(2) + LSEP1 + LDATLINS1(3) + LSEP1 + LDATLINS1(4) + LSEP1 + LDATLINS1(5) + LSEP1 +
&   LDATLINS1(6) + LSEP1 + LDATLINS1(7) + LSEP1 + LDATLINS1(8) + LSEP1 + LDATLINS1(9) + LSEP1 + LDATLINS1(10) + LSEP1 + LDATLINS1(11) + LSEP1 + LDATLINS1(12) Using [ZIMP_W1]

  Gosub CLOSE_FILE_W1

  PERROR1 = GOK
End

###############################################################
#######################
#**
#* genera el fichero y realiza la importación de entrada de stock (A o R según parámetro de entrada)
#*
#* @param PERROR2  > devuelve el estado de la importación  PERROR2=1 -> éxito ; PERROR2<>1 -> error
#*!
Subprog GENERA_FICHENTRADA(PERROR2)
Variable  Integer PERROR2
Local   Char LDIRIMPORT2(250) : LDIRIMPORT2 = filpath("IMPORT_EXPORT\PARRILLAS\Mov_Parrillas","","")
Global  Char LFILE_W2(200) : LFILE_W2 = "\CambioStockEntradaPL"
Local   Char LDATCAB2(100)(9), LDATLINL2(100)(9), LDATLINS2(100)(14)
Local   Char LFECHA2(10), LHORA2(10) : Raz LFECHA2, LHORA2
Local   Char LSEP2(1) : LSEP2 = ";"  # separador

  LFECHA2 = vireblc(num$(date$),4) : LFECHA2 = mid$(LFECHA2,1,2)+mid$(LFECHA2,4,2)+mid$(LFECHA2,7,4)
  LHORA2  = vireblc(num$(time$),4) : LHORA2  = mid$(LHORA2,1,2)+mid$(LHORA2,4,2)+mid$(LHORA2,7,2)

  LFILE_W2 = LDIRIMPORT2 + LFILE_W2 + "_" + LFECHA2 + LHORA2 + ".txt"

  # borramos el fichero si existe...
  If filinfo(LFILE_W2, 7) > 0 Then
    System "ae_rm " + LFILE_W2
  Endif

  # abrir el fichero para escritura  Gosub OPEN_FILE_W2
  Gosub OPEN_FILE_W2

  # datos de cabecera movimiento
  Raz LDATCAB2
  LDATCAB2(0)  = "E"                                           # Inidicador
  LDATCAB2(1)  = num$(19)                                      # Tipo de asiento
  LDATCAB2(2)  = ""                                            # Número de asiento
  LDATCAB2(3)  = [M:YPL1]MFGFCY                                # Planta stock
  LDATCAB2(4)  = [M:YPL1]TRKLAST                               # Fecha imputación
  LDATCAB2(5)  = "CAMBIO STOCK A1->A DESDE PL"                 # Descripción
  LDATCAB2(6)  = ""                                            # Proyecto
  LDATCAB2(7)  = ""                                            # Código movimiento
  LDATCAB2(8)  = "030"                                         # Código familia

  # datos de línea movimiento
  Raz LDATLINL2
  LDATLINL2(0) = "L"                                           # Indicador
  LDATLINL2(1) = num$(1000)                                    # Número de línea de asiento
  LDATLINL2(2) = [M:YPL1]ITMREF                                # Código de artículo
#  LDATLINL2(3) = [M:YPL1]ITMDESL(nolign-1)                     # Descripción 1
  LDATLINL2(4) = [M:YPL1]UOM                                   # Unidad
  LDATLINL2(5) = num$([M:YPL1]CPLQTY)                          # Cantidad
  LDATLINL2(6) = [M:YPL1]UOM                                   # Unidad Stock
  LDATLINL2(7) = num$([M:YPL1]CPLQTY)                          # Cantidad US
  LDATLINL2(8) = num$(0)                                       # Precio pedido (PREGUNTAR A DANIEL SI PONEMOS CERO O EL PRECIO QUE VIENE DE PEDIDO)

  # datos stock
  Raz LDATLINS2
  LDATLINS2(0) = "S"                                           # Indicador
  LDATLINS2(1) = [M:YPL1]UOM                                   # Unidad
  LDATLINS2(2) = num$([M:YPL1]CPLQTY)                          # Cantidad
  LDATLINS2(3) = ""                                            # Lote proveedor
  LDATLINS2(4) = [M:YPL1]LOTE                                  # Lote
  LDATLINS2(5) = ""                                            # S/Lote
  LDATLINS2(6) = ""                                            # Número contenedor
  LDATLINS2(7) = "SSA010101"                                   # Ubicación    (siempre SSA010101 por indicación de Marta en la tarjeta de planner)
  LDATLINS2(8) = "A"                                           # Estado
  LDATLINS2(9) = ""                                            # Serie
  LDATLINS2(10)= ""                                            # Observaciones
  LDATLINS2(11)= ""                                            # Referencia
  LDATLINS2(12)= [M:YPL1]CADUCIDAD                             # Caducidad
  LDATLINS2(13)= "A1->A DESDE PL -"-[M:YPL1]MFGNUM             # Descripción mvto.

  # datos de cabecera movimiento
    Wrseq LDATCAB2(0) + LSEP2 + LDATCAB2(1) + LSEP2 + LDATCAB2(2) + LSEP2 + LDATCAB2(3) + LSEP2 + LDATCAB2(4) + LSEP2 +
&         LDATCAB2(5) + LSEP2 + LDATCAB2(6) + LSEP2 + LDATCAB2(7) + LSEP2 + LDATCAB2(8) Using [ZIMP_W2]

  # datos de línea movimiento
    Wrseq LDATLINL2(0) + LSEP2 + LDATLINL2(1) + LSEP2 + LDATLINL2(2) + LSEP2 + LDATLINL2(3) + LSEP2 + LDATLINL2(4) + LSEP2 + LDATLINL2(5) + LSEP2 +
&   LDATLINL2(6) + LSEP2 + LDATLINL2(7) + LSEP2 + LDATLINL2(8) Using [ZIMP_W2]

  # datos stock
    Wrseq LDATLINS2(0) + LSEP2 + LDATLINS2(1) + LSEP2 + LDATLINS2(2) + LSEP2 + LDATLINS2(3) + LSEP2 + LDATLINS2(4) + LSEP2 + LDATLINS2(5) + LSEP2 +
&   LDATLINS2(6) + LSEP2 + LDATLINS2(7) + LSEP2 + LDATLINS2(8) + LSEP2 + LDATLINS2(9) + LSEP2 + LDATLINS2(10) + LSEP2 + LDATLINS2(11) + LSEP2 + LDATLINS2(12) +
&   LSEP2 + LDATLINS2(13) Using [ZIMP_W2]

  Gosub CLOSE_FILE_W2

  PERROR2 = GOK
End

########################################################
$OPEN_FILE_W1

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE_W1 Using [ZIMP_W1]

Return

########################################################
$CLOSE_FILE_W1

Openo Using [ZIMP_W1]

Return

########################################################
$OPEN_FILE_W2

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE_W2 Using [ZIMP_W2]

Return

########################################################
$CLOSE_FILE_W2

Openo Using [ZIMP_W2]

Return
