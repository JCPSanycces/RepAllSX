#<AdxTL>@(#)0.0.0.0 $Revision$ 
#####################################################################################
# Src: SPEYPL
#-------------------------------------------------------------------------------------
# Proyecto: Estándar
#-------------------------------------------------------------------------------------
# Version: v12
#-------------------------------------------------------------------------------------
# YN03 - Parrilla de liberación
# Fecha inicio YN03: 16/08/2019
# Desarrollador: JCH
# Código de desarrollo: YN03
# Descripción del desarrollo: Parrilla para la liberación del producto final
# Fecha: 16/08/2019
# Codigo Actividad: YYN03
#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "DEBUT"        : Gosub DEBUT
  When "SETBOUT"      : Gosub SETBOUT
  When "BOUTON"       : Gosub BOUTON
  When "FIN"          : Gosub FIN
  When "SEL_TABLE"    : Gosub SEL_TABLE
  When "VERF_TABLE"   : Gosub VERF_TABLE
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
##############################################################
$OUVRE
  Global Char GPARAM2(250)(2)
  Gosub ABRIR_TABLAS
Return

##############################################################
$DEBUT
Global Integer GFLGCHANGE : Raz GFLGCHANGE
Global Integer GNOL
Global Integer GLCK

  [M:YPL0]STRDAT = date$ - 10
  [M:YPL0]ENDDAT      = date$
  [M:YPL1]LIBERACION  = date$
  Affzo [M:YPL0]5,10
  Affzo [M:YPL1]5,10,15,20
  Grizo [M:YPL1]APTO

  Gosub CARGA_ESTADOS
Return

##############################################################
$SETBOUT
  Raz CHMEN
  Case BOUT
    When "O"        : CHMEN += "bs"
    When "b"        : CHMEN += "budas"
    When "u"        : CHMEN += "budas"
    When "d"        : CHMEN += "budas"
    When "a"        : CHMEN += "budas"
    When Default    : CHMEN += "bs"
  Endcase
Return

##############################################################
$BOUTON
  Case BOUT
    When "b"  : Gosub BUSCAR
    When "u"  : Gosub ACT_DATOS
    When "d"  : # duplicar registro
    When "a"  : # adjuntar documento
    When "s"  : Gosub SALIR
  Endcase
Return

##############################################################
$FIN
  Gosub CERRAR_TABLAS
  Call UNLOCK_LCKPRR(adxuid(1),"PL") From SPEYLIB0

  If dim(GPARAM2)         > 0 Then : Kill GPARAM2         : Endif
  If dim(GFLGCHANGE)      > 0 Then : Kill GFLGCHANGE      : Endif
  If dim(GNOL)            > 0 Then : Kill GNOL            : Endif
  If dim(GLIBERACION_ANT) > 0 Then : Kill GLIBERACION_ANT : Endif
  If dim(GNOTASLIB_ANT)   > 0 Then : Kill GNOTASLIB_ANT   : Endif
  If dim(LFILE_W1)        > 0 Then : Kill LFILE_W1        : Endif
  If dim(LFILE_W2)        > 0 Then : Kill LFILE_W2        : Endif
  If dim(GLCK)            > 0 Then : Kill GLCK            : Endif
  FIN=1
Return

##############################################################
$SEL_TABLE
  Case TABLE
    When "YSELSTKPL"   : Gosub SEL_YSELSTKPL
  Endcase
Return

##############################################################
$VERF_TABLE
  Case TABLE
    When "YSELSTKPL"   : Gosub VERF_YSELSTKPL
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$SEL_YSELSTKPL
  Link [AXX0] With [TST0]TST0=[F:AXX0]IDENT1 As [LNK0] Where CODFIC="TABSTASTO" and ZONE = "STAAXX" and LANGUE=GLANGUE
  Columns [LNK0] ([TST0]STASTO,[AXX0]TEXTE)
  Default File [LNK0]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Estados"                                                       # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "[TST0]STASTO"                                                  # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la segunda columna
  COL(NBCOL)  = "[AXX0]TEXTE"                                                   # nombre del campo a mostrar en la segunda columna
Return

##############################################################
$VERF_YSELSTKPL
Return

##############################################################
$ABRIR_TABLAS
  If !clalev([F:TST0]) Then : Local File TABSTASTO    [F:TST0] : Endif
  If !clalev([F:AXX0]) Then : Local File ATEXTRA      [F:AXX0] : Endif
  If !clalev([F:TST1]) Then : Local File TABSTASTO    [F:TST1] : Endif
  If !clalev([F:AXX1]) Then : Local File ATEXTRA      [F:AXX1] : Endif
  If !clalev([F:MFH0]) Then : Local File MFGHEAD      [F:MFH0] : Endif
  If !clalev([F:MFI0]) Then : Local File MFGITM       [F:MFI0] : Endif
  If !clalev([F:YML0]) Then : Local File YMFGHEADPL   [F:YML0] : Endif
  If !clalev([F:YMP0]) Then : Local File YMFGHEADPP   [F:YMP0] : Endif
  If !clalev([F:YMD0]) Then : Local File YMFGDUPLIPP  [F:YMD0] : Endif
Return

##############################################################
$CERRAR_TABLAS
  If clalev([F:MFH0])  Then : Close Local File        [F:MFH0] : Endif
  If clalev([F:MFI0])  Then : Close Local File        [F:MFI0] : Endif
  If clalev([F:YML0])  Then : Close Local File        [F:YML0] : Endif
  If clalev([F:YMP0])  Then : Close Local File        [F:YMP0] : Endif
  If clalev([F:YMD0])  Then : Close Local File        [F:YMD0] : Endif
Return

##############################################################
$BUSCAR
Local Clbfile CRITSQL(2)(0..7) : Raz CRITSQL
Local Clbfile LWHERE1(2), LWHERE3(2), LWHERE5(2) : Raz LWHERE1, LWHERE3, LWHERE5
Local Integer LCON0, LCON10 : Raz LCON0, LCON10
Local Integer LCONTROL : Raz LCONTROL
Local Clbfile CRITSQL2(2)(0..10) : Raz CRITSQL2
Local Clbfile LWHERE2(2), LWHERE4(2), LWHERE6(2) : Raz LWHERE2, LWHERE4, LWHERE6
Local Integer LCON2, LCON3 : Raz LCON2, LCON3
Local Clbfile CRITSQL4(2)(0..6) : Raz CRITSQL4
Local Clbfile LWHERE7(2), LWHERE8(2) : Raz LWHERE7, LWHERE8

  # vacío la tabla de bloqueos
  Call UNLOCK_LCKPRR(adxuid(1),"PL") From SPEYLIB0

  Raz [M:YPL2]
  indice = 0
  [M:YPL2]NBLIG = 0

  # elimina los registros en la tabla de bloqueos de las sesiones que no existen en X3
  Call DEL_SESSIONS() From SPEYLIB0

  Gosub BUSCAR_MFG_ORIGINAL
  LCON2 = LCON0
  Gosub BUSCAR_MFG_DUPLICADA
#If GUSER="AIT07" Then
  LCON3 = LCON2
  Gosub BUSCAR_DEVEXT
#Endif

#  [M:YPL2]NBLIG = LCON2
  [M:YPL2]NBLIG = LCON3
  Sorta [M:YPL2]NBLIG [M:YPL2]NBLIG Order By [M:YPL2]MFGNUM(indice), [M:YPL2]MFGTIPO(indice), [M:YPL2]MFGCDG(indice)
  Affzo [M:YPL2]5

  Gosub PAINT_LCKLINE
  Affzo [M:YPL2]5
Return

##############################################################
$BUSCAR_MFG_ORIGINAL
Local Integer   LLCKUID
Local Datetime  LLCKTIM
Local Char      LLCKUSR(20)

  LWHERE1 = "MFGITM.MFGFCY_0='101' AND MFGITM.YTIPO_0=1 AND MFGITM.TCLCOD_0='YNPT' "
  If [M:YPL0]STRDAT   <> [00/00/0000]               Then : LWHERE1 += " and MFGITM.STRDAT_0>='"     +[M:YPL0]STRDAT+"'"     : Endif
  If [M:YPL0]ENDDAT   <> [00/00/0000]               Then : LWHERE1 += " and MFGITM.STRDAT_0<='"     +[M:YPL0]ENDDAT+"'"     : Endif
  If [M:YPL0]STRLIB   <> [00/00/0000]               Then : LWHERE1 += " and YMFGHEADPP.LIBDAT_0>='" +[M:YPL0]STRLIB+"'"     : Endif
  If [M:YPL0]ENDLIB   <> [00/00/0000]               Then : LWHERE1 += " and YMFGHEADPP.LIBDAT_0<='" +[M:YPL0]ENDLIB+"'"     : Endif
  If [M:YPL0]STRMFG   <> ""                         Then : LWHERE1 += " and MFGITM.MFGNUM_0>='"     +[M:YPL0]STRMFG+"'"     : Endif
  If [M:YPL0]ENDMFG   <> ""                         Then : LWHERE1 += " and MFGITM.MFGNUM_0<='"     +[M:YPL0]ENDMFG+"'"     : Endif
  If [M:YPL0]CONTROL  <> 0 and [M:YPL0]CONTROL <> 5 Then : LWHERE3 += " and MFGITM.MFGSTA_0="       +num$([M:YPL0]CONTROL)  : Endif
  If [M:YPL0]ITMREF   <> ""                         Then : LWHERE3 += " and MFGITM.ITMREF_0='"      +[M:YPL0]ITMREF+"'"     : Endif
  If [M:YPL0]LOT      <> ""                         Then : LWHERE3 += " and MFGITM.LOT_0 LIKE '%"   +[M:YPL0]LOT+"%'"       : Endif
  Raz LCONTROL

  Local Integer LQSTA : Raz LQSTA
  For LCON10 = 0 To [M:YPL0]NBSTA-1
    If [M:YPL0]SELSTA(LCON10) = 2 Then
      If LCONTROL = 0 Then
        LWHERE8 += " YMFGHEADPP.ESTADO_0='" + [M:YPL0]CDGSTA(LCON10) + "'"
        If [M:YPL0]CDGSTA(LCON10) = "Q" Then
          LWHERE8 += " or YMFGHEADPP.ESTADO_0=''"
          LQSTA = 1
        Endif
      Else
        LWHERE8 += " or YMFGHEADPP.ESTADO_0='" + [M:YPL0]CDGSTA(LCON10) + "'"
        If [M:YPL0]CDGSTA(LCON10) = "Q" Then
          LWHERE8 += " or YMFGHEADPP.ESTADO_0=''"
          LQSTA = 1
        Endif
      Endif
      LCONTROL += 1
    Endif
  Next
  If LCONTROL > 0 Then : LWHERE3 += " and " : Endif

  CRITSQL(0) =  "SELECT MFGITM.MFGNUM_0,MFGITM.STRDAT_0,MFGITM.ITMREF_0,MFGITM.LOT_0,YMFGHEADPP.ESTADO_0,"
  CRITSQL(0) += "YMFGHEADPP.BLISTER_0,YMFGHEADPP.ETIQUETA_0,YMFGHEADPP.PROSPECTO_0,YMFGHEADPP.ESTUCHE_0,YMFGHEADPP.CHIP_0,YMFGHEADPP.APTO_0,"
  CRITSQL(1) =  "YMFGHEADPP.NAPTO_0,YMFGHEADPP.COMENTARIOS_0,MFGITM.YLOTEMP_0,MFGITM.YCADUCIDAD_0,MFGITM.YFLU_0,YMFGHEADPP.LIBDAT_0,YMFGHEADPP.NOTASLIB_0,"
  CRITSQL(1) += "MFGITM.MFGFCY_0,MFGITM.UOM_0,MFGITM.UOMEXTQTY_0,MFGITM.CPLQTY_0,MFGITM.MFGSTA_0,MFGITM.TRKLAST_0,MFGITM.TCLCOD_0 "
  CRITSQL(2) =  "FROM "+nomap+".MFGITM "
  CRITSQL(2) += "LEFT OUTER JOIN "+nomap+".YMFGHEADPP ON "+nomap+".MFGITM.MFGNUM_0="+nomap+".YMFGHEADPP.MFGNUM_0 "
  CRITSQL(5) =  "WHERE "+LWHERE1
  CRITSQL(6) =  LWHERE3
  If LWHERE8 <> "" Then : CRITSQL(7)  = "(" + LWHERE8 + ")" : Endif

#If GUSER="AIT07" Then
#Local Integer I
#For I=0 To 7
#Infbox num$(CRITSQL(I))
#Next
#Endif

  For (Char MFGNUM(250),Date STRDAT,Char ITMREF(250),Char LOT(250),Char ESTADO(250), Char BLISTER(250), Char ETIQUETA(250), Char PROSPECTO(250),
&      Char ESTUCHE(250), Integer CHIP, Integer APTO, Integer NAPTO, Char COMENTARIOS(250), Char YLOTEMP(250), Date YCADUCIDAD, Date YFLU,
&      Date LIBDAT, Char NOTASLIB(250), Char MFGFCY, Char UNIDAD(250), Decimal UOMEXTQTY, Decimal CPLQTY, Integer CONTROL, Date TRKLAST, Char TCLCOD(250)) From "5" Sql CRITSQL(0..7) As [Y00]
    # si el usuario ha filtrado por el estado Q y la categoría del producto es YNPI no debe mostrar ese registro
    If LQSTA = 1 and [F:Y00]TCLCOD = "YNPI" Then
    Else
      [M:YPL2]MFGNUM(LCON0)       = [F:Y00]MFGNUM
      [M:YPL2]MFGCDG(LCON0)       = [F:Y00]MFGNUM
      [M:YPL2]MFGTIPO(LCON0)      = 1
      If [F:Y00]ESTADO = "A" Then
        [M:YPL2]LIBERACION(LCON0) = [F:Y00]LIBDAT
      Endif
      [M:YPL2]ITMREF(LCON0)       = [F:Y00]ITMREF
      [M:YPL2]LOTE(LCON0)         = [F:Y00]LOT
      [M:YPL2]BLISTER(LCON0)      = [F:Y00]BLISTER
      [M:YPL2]ETIQUETA(LCON0)     = [F:Y00]ETIQUETA
      [M:YPL2]PROSPECTO(LCON0)    = [F:Y00]PROSPECTO
      [M:YPL2]ESTUCHE(LCON0)      = [F:Y00]ESTUCHE
      [M:YPL2]CHIP(LCON0)         = [F:Y00]CHIP
      If [F:Y00]ESTADO = "A" Then
        [M:YPL2]APTO(LCON0)       = 2
      Else
        [M:YPL2]APTO(LCON0)       = 0
      Endif
      [M:YPL2]COMENTARIOS(LCON0)  = [F:Y00]COMENTARIOS
      [M:YPL2]LOTEMP(LCON0)       = [F:Y00]YLOTEMP
      [M:YPL2]CADUCIDAD(LCON0)    = [F:Y00]YCADUCIDAD
      [M:YPL2]LIMDAT(LCON0)       = [F:Y00]YFLU
      [M:YPL2]NOTASLIB(LCON0)     = [F:Y00]NOTASLIB
      [M:YPL2]MFGFCY(LCON0)       = [F:Y00]MFGFCY
      [M:YPL2]UOM(LCON0)          = [F:Y00]UNIDAD
      [M:YPL2]UOMEXTQTY(LCON0)    = [F:Y00]UOMEXTQTY
      [M:YPL2]CPLQTY(LCON0)       = [F:Y00]CPLQTY
      [M:YPL2]CONTROL(LCON0)      = [F:Y00]CONTROL
      [M:YPL2]TRKLAST(LCON0)      = [F:Y00]TRKLAST
      If [F:Y00]ESTADO <> "" Then
        [M:YPL2]ESTADO(LCON0)     = [F:Y00]ESTADO
      Else
        [M:YPL2]ESTADO(LCON0)     = "Q"
      Endif
      If !clalev([F:AXX0]) Then : Local File ATEXTRA [F:AXX0] : Endif
      Filter [F:AXX0] Where CODFIC = "ITMMASTER" and ZONE = "DES1AXX" and LANGUE = GLANGUE and IDENT1 = [F:Y00]ITMREF
      Read [F:AXX0] First
      If !fstat Then
        [M:YPL2]ITMDES(LCON0) = [F:AXX0]TEXTE
      Endif
      Filter [F:AXX0]
      Close Local File [AXX0]

      # gestiona los bloqueos
      GLCK = func SPEYLIB0.SEARCH_LCKPRR([F:Y00]ITMREF,[F:Y00]LOT)
      If !GLCK Then
        Call LOCK_LCKPRR([F:Y00]ITMREF,[F:Y00]LOT,"PL") From SPEYLIB0
      Else
        Raz LLCKUID,LLCKUSR,LLCKTIM
        Call GET_IDLCK([F:Y00]ITMREF,[F:Y00]LOT,LLCKUID,LLCKUSR,LLCKTIM) From SPEYLIB0
        [M:YPL2]LCKUSR(LCON0) = LLCKUSR
        [M:YPL2]LCKDAT(LCON0) = num$(LLCKTIM)
      Endif

      LCON0                       += 1
    Endif

  Next

  If dim(LLCKUID) > 0 Then : Kill LLCKUID : Endif
  If dim(LLCKTIM) > 0 Then : Kill LLCKTIM : Endif
  If dim(LLCKUSR) > 0 Then : Kill LLCKUSR : Endif
Return

##############################################################
$BUSCAR_MFG_DUPLICADA
Local Integer   LLCKUID
Local Datetime  LLCKTIM
Local Char      LLCKUSR(20)

  LWHERE2 = "YMFGDUPLIPP.MFGFCY_0='101' AND YMFGDUPLIPP.YTIPO_0=1 "
  If [M:YPL0]STRDAT   <> [00/00/0000]               Then : LWHERE4 += " and YMFGDUPLIPP.STRDAT_0>='"    +[M:YPL0]STRDAT+"'"     : Endif
  If [M:YPL0]ENDDAT   <> [00/00/0000]               Then : LWHERE4 += " and YMFGDUPLIPP.STRDAT_0<='"    +[M:YPL0]ENDDAT+"'"     : Endif
  If [M:YPL0]STRLIB   <> [00/00/0000]               Then : LWHERE4 += " and YMFGDUPLIPP.LIBDAT_0>='"    +[M:YPL0]STRLIB+"'"     : Endif
  If [M:YPL0]ENDLIB   <> [00/00/0000]               Then : LWHERE4 += " and YMFGDUPLIPP.LIBDAT_0<='"    +[M:YPL0]ENDLIB+"'"     : Endif
  If [M:YPL0]STRMFG   <> ""                         Then : LWHERE4 += " and YMFGDUPLIPP.MFGNUM_0>='"    +[M:YPL0]STRMFG+"'"     : Endif
  If [M:YPL0]ENDMFG   <> ""                         Then : LWHERE6 += " and YMFGDUPLIPP.MFGNUM_0<='"    +[M:YPL0]ENDMFG+"'"     : Endif
  If [M:YPL0]CONTROL  <> 0 and [M:YPL0]CONTROL <> 5 Then : LWHERE6 += " and YMFGDUPLIPP.CONTROL_0="     +num$([M:YPL0]CONTROL)  : Endif
  If [M:YPL0]ITMREF   <> ""                         Then : LWHERE6 += " and YMFGDUPLIPP.ITMREF_0='"     +[M:YPL0]ITMREF+"'"     : Endif
  If [M:YPL0]LOT      <> ""                         Then : LWHERE6 += " and YMFGDUPLIPP.LOT_0 LIKE '%"  +[M:YPL0]LOT+"%'"        : Endif
  Raz LCONTROL

  Local Integer LCON11, LCONTROL11 : Raz LCONTROL11
  Local Char    LWHERE9(255)       : Raz LWHERE9
  For LCON11 = 0 To [M:YPL0]NBSTA-1
    If [M:YPL0]SELSTA(LCON11) = 2 Then
      If LCONTROL11 = 0 Then
        LWHERE9 += " YMFGDUPLIPP.ESTADO_0='" + [M:YPL0]CDGSTA(LCON11) + "'"
      Else
        LWHERE9 += " or YMFGDUPLIPP.ESTADO_0='" + [M:YPL0]CDGSTA(LCON11) + "'"
      Endif
      LCONTROL11 += 1
    Endif
  Next
  If LCONTROL11 > 0 Then : LWHERE6 += " and " : Endif

  CRITSQL2(0) =  "SELECT YMFGDUPLIPP.MFGNUM_0,YMFGDUPLIPP.CODIGO_0,YMFGDUPLIPP.ESTADO_0,YMFGDUPLIPP.MFGTIPO_0,YMFGDUPLIPP.STRDAT_0,YMFGDUPLIPP.ITMREF_0,"
  CRITSQL2(1) =  "YMFGDUPLIPP.LOT_0,YMFGDUPLIPP.CADUCIDAD_0,YMFGDUPLIPP.ENDDAT_0,YMFGDUPLIPP.LOTEMP_0,YMFGDUPLIPP.BLISTER_0,"
  CRITSQL2(2) =  "YMFGDUPLIPP.ETIQUETA_0,YMFGDUPLIPP.PROSPECTO_0,YMFGDUPLIPP.ESTUCHE_0,YMFGDUPLIPP.CHIP_0,YMFGDUPLIPP.COMENTARIOS_0,YMFGDUPLIPP.APTO_0,YMFGDUPLIPP.NAPTO_0,"
  CRITSQL2(3) =  "YMFGDUPLIPP.LIBDAT_0,YMFGDUPLIPP.NOTASLIB_0,MFGITM.MFGFCY_0,MFGITM.UOM_0,"
  CRITSQL2(4) =  "MFGITM.UOMEXTQTY_0,YMFGDUPLIPP.CONTROL_0,YMFGDUPLIPP.TRKLAST_0,YMFGDUPLIPP.CPLQTY_0 "
  CRITSQL2(5) =  "FROM "+nomap+".YMFGDUPLIPP "
  CRITSQL2(6) = "LEFT OUTER JOIN "+nomap+".MFGITM ON "+nomap+".YMFGDUPLIPP.MFGNUM_0 = "+nomap+".MFGITM.MFGNUM_0 "
  CRITSQL2(7) =  "WHERE "+LWHERE2
  CRITSQL2(8) =  LWHERE4
  CRITSQL2(9) =  LWHERE6
  If LWHERE9 <> "" Then : CRITSQL2(10)  = "(" + LWHERE9 + ")" : Endif

#If GUSER="AIT07" Then
#Local Integer I
#For I=0 To 9
#  Infbox CRITSQL2(I)
#Next
#Endif

  For (Char MFGNUM(250),Char CODIGO(250), Char ESTADO(250),Integer MFGTIPO,Date STRDAT,Char ITMREF(250),Char LOT(250),Date CADUCIDAD,Date ENDDAT,Char LOTEMP(250), Char BLISTER(250),
&      Char ETIQUETA(250),Char PROSPECTO(250),Char ESTUCHE(250),Integer CHIP,Char COMENTARIOS(250), Integer APTO, Integer NAPTO,Date LIBDAT, Char NOTASLIB(250), Char MFGFCY(250),
&      Char UNIDAD(250), Decimal UOMEXTQTY, Integer CONTROL, Date TRKLAST, Decimal CPLQTY) From "5" Sql CRITSQL2(0..10) As [Y02]
    [M:YPL2]MFGNUM(LCON2)       = [F:Y02]MFGNUM
    [M:YPL2]MFGCDG(LCON2)       = [F:Y02]CODIGO
    If [F:Y02]ESTADO <> "" Then
      [M:YPL2]ESTADO(LCON2)     = [F:Y02]ESTADO
    Else
      [M:YPL2]ESTADO(LCON2)     = "Q"
    Endif
    [M:YPL2]MFGTIPO(LCON2)      = [F:Y02]MFGTIPO
    [M:YPL2]ITMREF(LCON2)       = [F:Y02]ITMREF
    [M:YPL2]LOTE(LCON2)         = [F:Y02]LOT
    [M:YPL2]CADUCIDAD(LCON2)    = [F:Y02]CADUCIDAD
    [M:YPL2]LIMDAT(LCON2)       = [F:Y02]ENDDAT
    [M:YPL2]BLISTER(LCON2)      = [F:Y02]BLISTER
    [M:YPL2]ETIQUETA(LCON2)     = [F:Y02]ETIQUETA
    [M:YPL2]PROSPECTO(LCON2)    = [F:Y02]PROSPECTO
    [M:YPL2]ESTUCHE(LCON2)      = [F:Y02]ESTUCHE
    [M:YPL2]CHIP(LCON2)         = [F:Y02]CHIP
    [M:YPL2]APTO(LCON2)         = [F:Y02]APTO
    [M:YPL2]COMENTARIOS(LCON2)  = [F:Y02]COMENTARIOS
    If [F:Y02]ESTADO = "A" Then
      [M:YPL2]LIBERACION(LCON2) = [F:Y02]LIBDAT
    Endif
    [M:YPL2]NOTASLIB(LCON2)     = [F:Y02]NOTASLIB
    [M:YPL2]MFGFCY(LCON2)       = [F:Y02]MFGFCY
    [M:YPL2]UOM(LCON2)          = [F:Y02]UNIDAD
    [M:YPL2]UOMEXTQTY(LCON2)    = [F:Y02]UOMEXTQTY
    [M:YPL2]CPLQTY(LCON2)       = [F:Y02]CPLQTY
    [M:YPL2]CONTROL(LCON2)      = [F:Y02]CONTROL
    [M:YPL2]TRKLAST(LCON2)      = [F:Y02]TRKLAST
    If [F:Y02]ESTADO = "A" Then
      [M:YPL2]APTO(LCON2)       = 2
    Else
      [M:YPL2]APTO(LCON2)       = 0
    Endif
    If !clalev([F:AXX0]) Then : Local File ATEXTRA [F:AXX0] : Endif
    Filter [F:AXX0] Where CODFIC = "ITMMASTER" and ZONE = "DES1AXX" and LANGUE = GLANGUE and IDENT1 = [F:Y02]ITMREF
    Read [F:AXX0] First
    If !fstat Then
      [M:YPL2]ITMDES(LCON2) = [F:AXX0]TEXTE
    Endif
    Filter [F:AXX0]
    Close Local File [AXX0]

    # gestiona los bloqueos
    GLCK = func SPEYLIB0.SEARCH_LCKPRR([F:Y02]ITMREF,[F:Y02]LOT)
    If !GLCK Then
      Call LOCK_LCKPRR([F:Y02]ITMREF,[F:Y02]LOT,"PL") From SPEYLIB0
    Else
      Raz LLCKUID,LLCKUSR,LLCKTIM
      Call GET_IDLCK([F:Y02]ITMREF,[F:Y02]LOT,LLCKUID,LLCKUSR,LLCKTIM) From SPEYLIB0
      [M:YPL2]LCKUSR(LCON2) = LLCKUSR
      [M:YPL2]LCKDAT(LCON2) = num$(LLCKTIM)
    Endif

    LCON2                       += 1
  Next

  If dim(LLCKUID) > 0 Then : Kill LLCKUID : Endif
  If dim(LLCKTIM) > 0 Then : Kill LLCKTIM : Endif
  If dim(LLCKUSR) > 0 Then : Kill LLCKUSR : Endif
Return

##############################################################
$BUSCAR_DEVEXT
Local Integer   LLCKUID
Local Datetime  LLCKTIM
Local Char      LLCKUSR(20)

  LWHERE7 = "1=1"
  If [M:YPL0]STRDAT   <> [00/00/0000]               Then : LWHERE7 += " and YMFGHEADPP.FECHAR_0>='"    +[M:YPL0]STRDAT+"'"     : Endif
  If [M:YPL0]ENDDAT   <> [00/00/0000]               Then : LWHERE7 += " and YMFGHEADPP.FECHAR_0<='"    +[M:YPL0]ENDDAT+"'"     : Endif
  If [M:YPL0]STRLIB   <> [00/00/0000]               Then : LWHERE7 += " and YMFGHEADPP.LIBDAT_0>='"    +[M:YPL0]STRLIB+"'"     : Endif
  If [M:YPL0]ENDLIB   <> [00/00/0000]               Then : LWHERE7 += " and YMFGHEADPP.LIBDAT_0<='"    +[M:YPL0]ENDLIB+"'"     : Endif
  If [M:YPL0]STRMFG   <> ""                         Then : LWHERE7 += " and YMFGHEADPP.MFGNUM_0>='"    +[M:YPL0]STRMFG+"'"     : Endif
  If [M:YPL0]ENDMFG   <> ""                         Then : LWHERE7 += " and YMFGHEADPP.MFGNUM_0<='"    +[M:YPL0]ENDMFG+"'"     : Endif
  If [M:YPL0]ITMREF   <> ""                         Then : LWHERE7 += " and YMFGHEADPP.ITMREF_0='"     +[M:YPL0]ITMREF+"'"     : Endif
  If [M:YPL0]LOT      <> ""                         Then : LWHERE7 += " and YMFGHEADPP.LOT_0 LIKE '%"  +[M:YPL0]LOT+"%'"       : Endif

  Local Integer LCON12, LCONTROL12 : Raz LCONTROL12
  Local Char    LWHERE12(255)      : Raz LWHERE9
  For LCON12 = 0 To [M:YPL0]NBSTA-1
    If [M:YPL0]SELSTA(LCON12) = 2 Then
      If LCONTROL12 = 0 Then
        LWHERE12 += " YMFGHEADPP.ESTADO_0='" + [M:YPL0]CDGSTA(LCON12) + "'"
      Else
        LWHERE12 += " or YMFGHEADPP.ESTADO_0='" + [M:YPL0]CDGSTA(LCON12) + "'"
      Endif
      LCONTROL12 += 1
    Endif
  Next
  If LCONTROL12 > 0 Then : LWHERE7 += " and " : Endif

  CRITSQL4(0) = "SELECT YMFGHEADPP.MFGNUM_0,YMFGHEADPP.MFGTIPO_0,YMFGHEADPP.APTO_0,YMFGHEADPP.NAPTO_0,YMFGHEADPP.ESTADO_0,YMFGHEADPP.CONTROL_0,YMFGHEADPP.ITMREF_0,"
  CRITSQL4(1) = "YMFGHEADPP.LOT_0,YMFGHEADPP.BLISTER_0,YMFGHEADPP.ETIQUETA_0,YMFGHEADPP.PROSPECTO_0,YMFGHEADPP.ESTUCHE_0,YMFGHEADPP.CHIP_0,"
  CRITSQL4(2) =  "YMFGHEADPP.COMENTARIOS_0,YMFGHEADPP.CADUCIDAD_0,YMFGHEADPP.LIMDAT_0,YMFGHEADPP.FECHAR_0,YMFGHEADPP.LIBDAT_0,YMFGHEADPP.TRKLAST_0,YMFGHEADPP.CPLQTY_0 "
  CRITSQL4(3) =  "FROM "+nomap+".YMFGHEADPP "
  CRITSQL4(4) =  "WHERE (left(YMFGHEADPP.MFGNUM_0,3)='DEV' or left(YMFGHEADPP.MFGNUM_0,3)='EXT') "
  If LWHERE7 <> "" Then : CRITSQL4(5) =  "and " + LWHERE7 : Endif
  If LWHERE12 <> "" Then : CRITSQL4(6)  = "(" + LWHERE12 + ")" : Endif

#Local Integer I
#For I=0 To 6
#  Infbox CRITSQL4(I)
#Next

  For (Char MFGNUM(250), Integer MFGTIPO, Integer APTO, Integer NAPTO, Char ESTADO(250), Integer CONTROL, Char ITMREF(250),
&      Char LOT(250), Char BLISTER(250), Char ETIQUETA(250), Char PROSPECTO(250), Char ESTUCHE(250), Integer CHIP,
&      Char COMENTARIOS(250), Date CADUCIDAD, Date LIMDAT, Date FECHAR, Date LIBDAT, Date TRKLAST, Decimal CPLQTY) From "5" Sql CRITSQL4(0..6) As [Y03]
    [M:YPL2]MFGNUM(LCON3)       = [F:Y03]MFGNUM
    [M:YPL2]MFGCDG(LCON3)       = [F:Y03]MFGNUM
    [M:YPL2]MFGTIPO(LCON3)      = [F:Y03]MFGTIPO
    [M:YPL2]APTO(LCON3)         = [F:Y03]APTO
    If [F:Y03]ESTADO <> "" Then
      [M:YPL2]ESTADO(LCON3)     = [F:Y03]ESTADO
    Else
      [M:YPL2]ESTADO(LCON3)     = "Q"
    Endif
    [M:YPL2]CONTROL(LCON3)      = [F:Y03]CONTROL
    [M:YPL2]ITMREF(LCON3)       = [F:Y03]ITMREF
    [M:YPL2]LOTE(LCON3)         = [F:Y03]LOT
    [M:YPL2]CADUCIDAD(LCON3)    = [F:Y03]CADUCIDAD
    [M:YPL2]LIMDAT(LCON3)       = [F:Y03]LIMDAT
    [M:YPL2]BLISTER(LCON3)      = [F:Y03]BLISTER
    [M:YPL2]ETIQUETA(LCON3)     = [F:Y03]ETIQUETA
    [M:YPL2]PROSPECTO(LCON3)    = [F:Y03]PROSPECTO
    [M:YPL2]ESTUCHE(LCON3)      = [F:Y03]ESTUCHE
    [M:YPL2]CHIP(LCON3)         = [F:Y03]CHIP
    If [F:Y03]ESTADO = "A" Then
      [M:YPL2]LIBERACION(LCON3) = [F:Y03]LIBDAT
    Endif
    [M:YPL2]TRKLAST(LCON3)      = [F:Y03]TRKLAST
    [M:YPL2]CPLQTY(LCON3)       = [F:Y03]CPLQTY
    If !clalev([F:AXX0]) Then : Local File ATEXTRA [F:AXX0] : Endif
    Filter [F:AXX0] Where CODFIC = "ITMMASTER" and ZONE = "DES1AXX" and LANGUE = GLANGUE and IDENT1 = [F:Y03]ITMREF
    Read [F:AXX0] First
    If !fstat Then
      [M:YPL2]ITMDES(LCON3) = [F:AXX0]TEXTE
    Endif
    Filter [F:AXX0]
    Close Local File [AXX0]

    # gestiona los bloqueos
    GLCK = func SPEYLIB0.SEARCH_LCKPRR([F:Y03]ITMREF,[F:Y03]LOT)
    If !GLCK Then
      Call LOCK_LCKPRR([F:Y03]ITMREF,[F:Y03]LOT,"PL") From SPEYLIB0
    Else
      Raz LLCKUID,LLCKUSR,LLCKTIM
      Call GET_IDLCK([F:Y03]ITMREF,[F:Y03]LOT,LLCKUID,LLCKUSR,LLCKTIM) From SPEYLIB0
      [M:YPL2]LCKUSR(LCON3) = LLCKUSR
      [M:YPL2]LCKDAT(LCON3) = num$(LLCKTIM)
    Endif

    LCON3                       += 1
  Next

  If dim(LLCKUID) > 0 Then : Kill LLCKUID : Endif
  If dim(LLCKTIM) > 0 Then : Kill LLCKTIM : Endif
  If dim(LLCKUSR) > 0 Then : Kill LLCKUSR : Endif
Return

##############################################################
$ACT_DATOS
Local Integer   RESULTADO1
Local Char      LITMREFL(100) : LITMREFL  = [M:YPL1]ITMREF
Local Char      LLOTEL(100)   : LLOTEL    = [M:YPL1]LOTE
Local Integer   LLCKUID
Local Datetime  LLCKTIM
Local Char      LLCKUSR(20)

  GLCK = func SPEYLIB0.SEARCH_LCKPRR(LITMREFL,LLOTEL)
  If !GLCK Then
    Case [M:YPL1]MFGTIPO
      When 1 :    Gosub ACT_DATOS_ORIGINAL
      When 2 :    Gosub ACT_DATOS_DUPLICADA
    Endcase
    If left$([M:YPL1]MFGNUM,3) <> "DEV" and left$([M:YPL1]MFGNUM,3) <> "EXT" and [M:YPL1]MFGTIPO <> 2 Then
      If [M:YPL1]CPLQTY <> 0 and [M:YPL1]APTO = 2 Then
        Call GENERA_FICHENTRADA(RESULTADO1)
        Call GENERA_FICHSALIDA(RESULTADO1)
        Call MESSAGE("Actualización realizada correctamente") From GESECRAN
      Endif
    Endif
    Raz GFLGCHANGE  # se han guardado cambios
    Gosub BUSCAR
  Else
#    If !clalev([F:VUA0]) Then : Local File YVUSERADXUID [F:VUA0] : Endif
#    Call GET_IDLCK(LITMREFL,LLOTEL,LLCKUID,LLCKTIM) From SPEYLIB0
#    Filter [F:VUA0] Where SESSIONID = LLCKUID
#    Read [F:VUA0] First
#    If !fstat Then
#      Local Char LERRTIT(50)  : LERRTIT = "Registro bloqueado"
#      Local Char LERRTEX(150) : LERRTEX = "Artículo:"-LITMREFL+"\Lote:"-LLOTEL+"\Usuario bloqueo:"-toupper([F:VUA0]ALOGIN)+"\Fecha bloqueo:"-num$(LLCKTIM)
#      Call ERRTIT(LERRTEX,LERRTIT) From GESECRAN
#      [M:YPL1]APTO        = 0
#      [M:YPL1]LIBERACION  = [00/00/0000]
#      Affzo [M:YPL1]APTO
#      Affzo [M:YPL1]LIBERACION
#      mkstat = 2
#    Endif
#    Filter [F:VUA0]
#    Close Local File [VUA0]
    Call GET_IDLCK(LITMREFL,LLOTEL,LLCKUID,LLCKUSR,LLCKTIM) From SPEYLIB0
    If num$(LLCKUID) <> "" Then
      Local Char LERRTIT(50)  : LERRTIT = "Registro bloqueado"
      Local Char LERRTEX(150) : LERRTEX = "Artículo:"-LITMREFL+"\Lote:"-LLOTEL+"\Usuario bloqueo:"-toupper(LLCKUSR)+"\Fecha bloqueo:"-num$(LLCKTIM)
      Call ERRTIT(LERRTEX,LERRTIT) From GESECRAN
      [M:YPL1]APTO        = 0
      [M:YPL1]LIBERACION  = [00/00/0000]
      Affzo [M:YPL1]APTO
      Affzo [M:YPL1]LIBERACION
      mkstat = 2
    Endif
  Endif

  If dim(LFILE_W1)    > 0  Then : Kill LFILE_W1     : Endif
  If dim(LFILE_W2)    > 0  Then : Kill LFILE_W2     : Endif
  If dim(LRESULTADO1) > 0  Then : Kill LRESULTADO1  : Endif
  If dim(LITMREFL)    > 0  Then : Kill LITMREFL     : Endif
  If dim(LLOTEL)      > 0  Then : Kill LLOTEL       : Endif
  If dim(LLCKUID)     > 0  Then : Kill LLCKUID      : Endif
  If dim(LLCKTIM)     > 0  Then : Kill LLCKTIM      : Endif
  If dim(LLCKUSR)     > 0  Then : Kill LLCKUSR      : Endif
Return

##############################################################
$ACT_DATOS_ORIGINAL

  Read [F:YMP0]YMP0 = [M:YPL1]MFGNUM;[M:YPL1]MFGTIPO
  If [M:YPL1]APTO = 2 Then : [F:YMP0]ESTADO = "A" : Endif
  [F:YMP0]APTO        = [M:YPL1]APTO
  [F:YMP0]NOTASLIB    = [M:YPL1]NOTASLIB
  If [M:YPL1]APTO = 2 Then
    [F:YMP0]LIBDAT      = [M:YPL1]LIBERACION
  Endif
  [F:YMP0]TRKLAST     = [M:YPL1]TRKLAST
  [F:YMP0]CPLQTY      = [M:YPL1]CPLQTY
  [F:YMP0]USRMODIFSTA = GUSER
  [F:YMP0]DATMODIFSTA = date$
  Trbegin [YMP0]
  If !fstat Then
    Rewrite [F:YMP0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Else
    Write   [F:YMP0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif

Return

##############################################################
$ACT_DATOS_DUPLICADA
  Read [F:YMD0]YDP0 = [M:YPL1]MFGNUM;[M:YPL1]MFGCDG;[M:YPL1]MFGTIPO
  If [M:YPL1]APTO = 2 Then : [F:YMD0]ESTADO = "A" : Endif
  [F:YMD0]APTO        = [M:YPL1]APTO
  [F:YMD0]NOTASLIB    = [M:YPL1]NOTASLIB
  If [M:YPL1]APTO = 2 Then
    [F:YMD0]LIBDAT      = [M:YPL1]LIBERACION
  Endif
  [F:YMD0]TRKLAST     = [M:YPL1]TRKLAST
  [F:YMD0]CPLQTY      = [M:YPL1]CPLQTY
  [F:YMD0]USRMODIFSTA = GUSER
  [F:YMD0]DATMODIFSTA = date$
  Trbegin [F:YMD0]
  If !fstat Then
    Rewrite [F:YMD0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Else
    Write   [F:YMD0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif
Return

##############################################################
$MUESTRA_REGISTRO_ORIGINAL

  CRITSQL1(0) =  "SELECT MFGHEAD.MFGNUM_0,MFGHEAD.STRDAT_0,MFGITM.ITMREF_0,MFGITM.LOT_0,YMFGHEADPP.ESTADO_0,YMFGHEADPP.BLISTER_0, "
  CRITSQL1(0) += "YMFGHEADPP.ETIQUETA_0,YMFGHEADPP.PROSPECTO_0,YMFGHEADPP.ESTUCHE_0,YMFGHEADPP.CHIP_0,YMFGHEADPP.COMENTARIOS_0,YMFGHEADPP.APTO_0, "
  CRITSQL1(1) =  "YMFGHEADPP.NAPTO_0,MFGITM.YLOTEMP_0,MFGITM.YCADUCIDAD_0,MFGITM.YFLU_0,YMFGHEADPP.LIBDAT_0,YMFGHEADPP.NOTASLIB_0,MFGHEAD.MFGSTA_0,MFGITM.TRKLAST_0,MFGITM.CPLQTY_0 "
  CRITSQL1(2) =  "FROM "+nomap+".MFGHEAD LEFT OUTER JOIN "+nomap+".YMFGHEADPP ON "+nomap+".MFGHEAD.MFGNUM_0 ="+nomap+".YMFGHEADPP.MFGNUM_0 "
  CRITSQL1(3) =  "LEFT OUTER JOIN "+nomap+".MFGITM ON "+nomap+".MFGHEAD.MFGNUM_0="+nomap+".MFGITM.MFGNUM_0 "
  CRITSQL1(4) =  "WHERE MFGHEAD.MFGNUM_0='" + [M:YPL2]MFGNUM(nolign-1) + "'"

#If GUSER="AIT07" Then
#Local Integer I
#For I=0 To 4
#  Infbox CRITSQL1(I)
#Next
#Endif

  For (Char MFGNUM(250),Date STRDAT,Char ITMREF(250),Char LOT(250),Char ESTADO(250),Char BLISTER(250), Char ETIQUETA(250), Char PROSPECTO(250),
&      Char ESTUCHE(250), Integer CHIP, Char COMENTARIOS(250), Integer APTO, Integer NAPTO, Char YLOTEMP(250), Date YCADUCIDAD, Date YFLU, Date LIBDAT,
&      Char NOTASLIB(250), Integer CONTROL, Date TRKLAST, Decimal CPLQTY) From "5" Sql CRITSQL1(0..4) As [Y01]
    [M:YPL1]MFGNUM      = [F:Y01]MFGNUM
    [M:YPL1]MFGCDG      = [F:Y01]MFGNUM
    [M:YPL1]MFGTIPO     = 1
    [M:YPL1]ITMREF      = [F:Y01]ITMREF
    [M:YPL1]LOTE        = [F:Y01]LOT
    [M:YPL1]CADUCIDAD   = [F:Y01]YCADUCIDAD
    [M:YPL1]LIMDAT      = [F:Y01]YFLU
    [M:YPL1]BLISTER     = [F:Y01]BLISTER
    [M:YPL1]ETIQUETA    = [F:Y01]ETIQUETA
    [M:YPL1]PROSPECTO   = [F:Y01]PROSPECTO
    [M:YPL1]ESTUCHE     = [F:Y01]ESTUCHE
    [M:YPL1]CHIP        = [F:Y01]CHIP
    [M:YPL1]LOTEMP      = [F:Y01]YLOTEMP
    [M:YPL1]COMENTARIOS = [F:Y01]COMENTARIOS
    [M:YPL1]NOTASLIB    = [F:Y01]NOTASLIB
    [M:YPL1]LIBERACION  = [F:Y01]LIBDAT
    [M:YPL1]CONTROL     = [F:Y01]CONTROL
    [M:YPL1]TRKLAST     = [F:Y01]TRKLAST
    [M:YPL1]CPLQTY      = [F:Y01]CPLQTY
    [M:YPL1]ESTADO      = [F:Y01]ESTADO
    If [F:Y01]ESTADO = "A" Then
      [M:YPL1]APTO       = 2
      Grizo [M:YPL1]APTO
      Actzo [M:YPL1]LIBERACION
    Elsif [F:Y01]ESTADO <> "A1"
      [M:YPL1]APTO       = 0
      Grizo [M:YPL1]APTO
#      Grizo [M:YPL1]LIBERACION
    Else
      [M:YPL1]APTO       = 0
      Actzo [M:YPL1]APTO
#      Grizo [M:YPL1]LIBERACION
    Endif
  Next
  [M:YPL1]MFGFCY        = [M:YPL2]MFGFCY(nolign-1)
  [M:YPL1]UOM           = [M:YPL2]UOM(nolign-1)
  [M:YPL1]UOMEXTQTY     = [M:YPL2]UOMEXTQTY(nolign-1)
#  [M:YPL1]CPLQTY        = [M:YPL2]CPLQTY(nolign-1)
  [M:YPL1]LOC           = [M:YPL2]LOC(nolign-1)

Return

##############################################################
$MUESTRA_REGISTRO_DUPLICADA
  CRITSQL3(0) =  "SELECT YMFGDUPLIPP.MFGNUM_0,YMFGDUPLIPP.CODIGO_0,YMFGDUPLIPP.ESTADO_0,YMFGDUPLIPP.MFGTIPO_0,YMFGDUPLIPP.STRDAT_0,YMFGDUPLIPP.ITMREF_0,"
  CRITSQL3(0) += "YMFGDUPLIPP.LOT_0,YMFGDUPLIPP.CADUCIDAD_0,YMFGDUPLIPP.ENDDAT_0,YMFGDUPLIPP.LOTEMP_0,YMFGDUPLIPP.BLISTER_0,"
  CRITSQL3(1) =  "YMFGDUPLIPP.ETIQUETA_0,YMFGDUPLIPP.PROSPECTO_0,YMFGDUPLIPP.ESTUCHE_0,YMFGDUPLIPP.CHIP_0,YMFGDUPLIPP.COMENTARIOS_0,YMFGDUPLIPP.APTO_0,YMFGDUPLIPP.NAPTO_0,"
  CRITSQL3(1) += "YMFGDUPLIPP.LIBDAT_0,YMFGDUPLIPP.NOTASLIB_0,YMFGDUPLIPP.CONTROL_0,YMFGDUPLIPP.TRKLAST_0,YMFGDUPLIPP.CPLQTY_0 "
  CRITSQL3(2) =  "FROM "+nomap+".YMFGDUPLIPP "
  CRITSQL3(3) =  "WHERE YMFGDUPLIPP.MFGNUM_0='" + [M:YPL2]MFGNUM(nolign-1) + "' and YMFGDUPLIPP.CODIGO_0='" + [M:YPL2]MFGCDG(nolign-1) + "'"

#If GUSER="AIT07" Then
#Local Integer I
#For I=0 To 3
#  Infbox CRITSQL3(I)
#Next
#Endif

  For (Char MFGNUM(250),Char CODIGO(250), Char ESTADO(250),Integer MFGTIPO,Date STRDAT,Char ITMREF(250),Char LOT(250),Date CADUCIDAD,Date ENDDAT,Char LOTEMP(250),Char BLISTER(250),
&      Char ETIQUETA(250),Char PROSPECTO(250),Char ESTUCHE,Integer CHIP,Char COMENTARIOS(250), Integer APTO, Integer NAPTO, Date LIBDAT,
&      Char NOTASLIB(250), Integer CONTROL, Date TRKLAST, Decimal CPLQTY) From "5" Sql CRITSQL3(0..3) As [Y03]
    [M:YPL1]MFGNUM      = [F:Y03]MFGNUM
    [M:YPL1]MFGCDG      = [F:Y03]CODIGO
    [M:YPL1]MFGTIPO     = [F:Y03]MFGTIPO
    [M:YPL1]ITMREF      = [F:Y03]ITMREF
    [M:YPL1]LOTE        = [F:Y03]LOT
    [M:YPL1]CADUCIDAD   = [F:Y03]CADUCIDAD
    [M:YPL1]LIMDAT      = [F:Y03]ENDDAT
    [M:YPL1]BLISTER     = [F:Y03]BLISTER
    [M:YPL1]ETIQUETA    = [F:Y03]ETIQUETA
    [M:YPL1]PROSPECTO   = [F:Y03]PROSPECTO
    [M:YPL1]ESTUCHE     = [F:Y03]ESTUCHE
    [M:YPL1]CHIP        = [F:Y03]CHIP
    [M:YPL1]LOTEMP      = [F:Y03]LOTEMP
    [M:YPL1]COMENTARIOS = [F:Y03]COMENTARIOS
    [M:YPL1]NOTASLIB    = [F:Y03]NOTASLIB
    [M:YPL1]LIBERACION  = [F:Y03]LIBDAT
    [M:YPL1]CONTROL     = [F:Y03]CONTROL
    [M:YPL1]TRKLAST     = [F:Y03]TRKLAST
    [M:YPL1]CPLQTY      = [F:Y03]CPLQTY
    [M:YPL1]ESTADO      = [F:Y03]ESTADO
    If [F:Y03]ESTADO = "A" Then
      [M:YPL1]APTO       = 2
      Grizo [M:YPL1]APTO
      Actzo [M:YPL1]LIBERACION
    Elsif [F:Y03]ESTADO <> "A1"
      [M:YPL1]APTO       = 0
      Grizo [M:YPL1]APTO
    Else
      [M:YPL1]APTO       = 0
      Actzo [M:YPL1]APTO
    Endif
  Next
  [M:YPL1]MFGFCY        = [M:YPL2]MFGFCY(nolign-1)
  [M:YPL1]UOM           = [M:YPL2]UOM(nolign-1)
  [M:YPL1]UOMEXTQTY     = [M:YPL2]UOMEXTQTY(nolign-1)
#  [M:YPL1]CPLQTY        = [M:YPL2]CPLQTY(nolign-1)
  [M:YPL1]LOC           = [M:YPL2]LOC(nolign-1)

Return

##############################################################
$MUESTRA_REGISTRO_DEVEXT
  CRITSQL5(0) = "SELECT YMFGHEADPP.MFGNUM_0,YMFGHEADPP.MFGTIPO_0,YMFGHEADPP.APTO_0,YMFGHEADPP.NAPTO_0,YMFGHEADPP.ESTADO_0,YMFGHEADPP.CONTROL_0,YMFGHEADPP.ITMREF_0,"
  CRITSQL5(1) = "YMFGHEADPP.LOT_0,YMFGHEADPP.BLISTER_0,YMFGHEADPP.ETIQUETA_0,YMFGHEADPP.PROSPECTO_0,YMFGHEADPP.ESTUCHE_0,YMFGHEADPP.CHIP_0,"
  CRITSQL5(2) =  "YMFGHEADPP.COMENTARIOS_0,YMFGHEADPP.CADUCIDAD_0,YMFGHEADPP.LIMDAT_0,YMFGHEADPP.FECHAR_0,YMFGHEADPP.LIBDAT_0,YMFGHEADPP.TRKLAST_0,YMFGHEADPP.CPLQTY_0 "
  CRITSQL5(3) =  "FROM "+nomap+".YMFGHEADPP "
  CRITSQL5(4) =  "WHERE YMFGHEADPP.MFGNUM_0='" + [M:YPL2]MFGNUM(nolign-1) + "'"

#Local Integer I
#Infbox "HEAD"
#For I=0 To 4
#  Infbox CRITSQL5(I)
#Next

  For (Char MFGNUM(250), Integer MFGTIPO, Integer APTO, Integer NAPTO, Char ESTADO(250), Integer CONTROL, Char ITMREF(250),
&      Char LOT(250), Char BLISTER(250), Char ETIQUETA(250), Char PROSPECTO(250), Char ESTUCHE(250), Integer CHIP,
&      Char COMENTARIOS(250), Date CADUCIDAD, Date LIMDAT, Date FECHAR, Date LIBDAT, Date TRKLAST, Decimal CPLQTY) From "5" Sql CRITSQL5(0..4) As [Y05]
    [M:YPL1]ESTADO       = [F:Y05]ESTADO
    [M:YPL1]MFGNUM       = [F:Y05]MFGNUM
    [M:YPL1]MFGCDG       = [F:Y05]MFGNUM
    [M:YPL1]ITMREF       = [F:Y05]ITMREF
    [M:YPL1]MFGTIPO      = [F:Y05]MFGTIPO
    [M:YPL1]LOTE         = [F:Y05]LOT
    [M:YPL1]CADUCIDAD    = [F:Y05]CADUCIDAD
    [M:YPL1]LIMDAT       = [F:Y05]LIMDAT
    [M:YPL1]LIBERACION   = [F:Y05]LIBDAT
    [M:YPL1]COMENTARIOS  = [F:Y05]COMENTARIOS
    [M:YPL1]BLISTER      = [F:Y05]BLISTER
    [M:YPL1]ETIQUETA     = [F:Y05]ETIQUETA
    [M:YPL1]PROSPECTO    = [F:Y05]PROSPECTO
    [M:YPL1]ESTUCHE      = [F:Y05]ESTUCHE
    [M:YPL1]CHIP         = [F:Y05]CHIP
    [M:YPL1]CONTROL      = [F:Y05]CONTROL
    [M:YPL1]ESTADO       = [F:Y05]ESTADO
    If [F:Y05]ESTADO = "A" Then
      [M:YPL1]APTO       = 2
      Grizo [M:YPL1]APTO
      Actzo [M:YPL1]LIBERACION
    Elsif [F:Y05]ESTADO <> "A1"
      [M:YPL1]APTO       = 0
      Grizo [M:YPL1]APTO
    Else
      [M:YPL1]APTO       = 0
      Actzo [M:YPL1]APTO
    Endif
  Next

Return

###############################################################
$CARGA_ESTADOS
Local Integer LCON4 : Raz LCON4

  Link [AXX1] With [TST1]TST0=[F:AXX1]IDENT1 As [LNK1] Where CODFIC="TABSTASTO" and ZONE = "STAAXX" and LANGUE=GLANGUE
  Columns [LNK1] ([TST1]STASTO,[AXX1]TEXTE)

  For [LNK1]
    [M:YPL0]CDGSTA(LCON4) = [F:TST1]STASTO
    [M:YPL0]DESSTA(LCON4) = [F:AXX1]TEXTE
    LCON4 += 1
  Next
  [M:YPL0]NBSTA = LCON4
  Affzo [M:YPL0]15
Return

##############################################################
$SALIR
Local Integer YESNO : YESNO = 1 # no
  # si no se han producido cambios o se han guardado
  If GFLGCHANGE = 0 Then
    Gosub FIN
  Else
    Call OUINONT("Se han producido cambios y no has guardado la información.\¿Realmente deseas continuar?",YESNO) From GESECRAN
    If YESNO = 2 Then
      Gosub FIN
    Endif
  Endif
Return

##############################################################
$PAINT_LCKLINE
Local Integer LCON : Raz LCON

  For LCON = 0 To [M:YPL2]NBLIG-1
    If [M:YPL2]LCKUSR(LCON) <> "" Then
      Chgstl [M:YPL2]NBLIG(LCON) With "BACKRED"
    Else
      Chgstl [M:YPL2]NBLIG(LCON) With ""
    Endif
  Next

  If dim(LCON) > 0 Then : Kill LCON : Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Antes entrada NBLIG
## Muestra información en el bloque de datos cada vez que se mueve por el bloque
## de las líneas de órdenes
######################################################################################
Subprog AS_NBLIG
Local Clbfile CRITSQL1(2)(0..4) : Raz CRITSQL1
Local Clbfile CRITSQL3(2)(0..3) : Raz CRITSQL3
Local Clbfile CRITSQL5(2)(0..4) : Raz CRITSQL5

  # comprobar si se han hecho modificaciones 0 = sin modificaciones
  If GFLGCHANGE = 0 Then
    $INICAMBIOREG
    GNOL = nolign-1

    # OFS
    If left$([M:YPL2]MFGNUM(GNOL),3) <> "DEV" and left$([M:YPL2]MFGNUM(GNOL),3) <> "EXT" Then
      Case [M:YPL2]MFGTIPO(GNOL)
        When 1 : Gosub MUESTRA_REGISTRO_ORIGINAL
        When 2 : Gosub MUESTRA_REGISTRO_DUPLICADA
      Endcase
    Else
    # DEVoluciones o productos EXTernos
      Case [M:YPL2]MFGTIPO(GNOL)
        When 1 : Gosub MUESTRA_REGISTRO_DEVEXT
        When 2 : Gosub MUESTRA_REGISTRO_DUPLICADA
      Endcase
    Endif
    Affzo [M:YPL1]5,10,15,20
    Raz GFLGCHANGE              # limpia la variable que se utiliza para controlar cambios
    If [M:YPL1]APTO <> 2 Then
      Raz [M:YPL1]LIBERACION
      Affzo [M:YPL1]LIBERACION
    Endif
  Else
    Local Integer YESNO : YESNO = 1 # no
    Call OUINONT("Se han producido cambios y no has guardado la información.\¿Realmente deseas continuar sin guardar?",YESNO) From GESECRAN
    If YESNO = 2 Then
      # si continúa sin guardar, se vacían los campos modificados del grid
      [M:YPL2]LIBERACION(GNOL) = GLIBERACION_ANT : Affzo [M:YPL2]LIBERACION(GNOL) : [M:YPL2]NOTASLIB(GNOL) = GNOTASLIB_ANT : Affzo [M:YPL2]NOTASLIB(GNOL)
      Gosub INICAMBIOREG
    Else
      zonsui = "[M:YPL1]LIBERACION"
    Endif
  Endif

End

