#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT51" Then : Infbox ACTION : Endif
Case ACTION
  When "AUTINVDREG"     : Gosub AUTINVDREG        # punto de entrada para agrupar los albaranes por cabecera
  When "AUTINVDFIL"     : Gosub AUTINVDFIL        # punto de entrada para añadir filtros en la selección de albaranes
  When "AUTINVDSEL"     : Gosub AUTINVDSEL        # JC.05022021.YN54
  When "INIT"           : Gosub INIT
  When Default
Endcase

Return


##############################################################
$INIT
Gosub INIT_TRTAUTINVD From FUNAUTINVD

[M:DIA]YSHIDAT = date$
Affzo [M:DIA]YSHIDAT

GPE = 1
Return


##############################################################
######################    ACCIONES    ########################
##############################################################

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$AUTINVDREG

  If !clalev([F:YBPC]) Then : Local File BPCUSTOMER [F:YBPC] : Endif
  Read [F:YBPC]BPC0 = [F:SDH]BPCORD
  If !fstat Then
    # agrupa por dirección de faturación
    If [F:YBPC]YFACDIRENT = 2 Then
      If [F:SDH]BPAADD <> "" Then
        [F:SWI]SWIKEY1 += "~"+[F:SDH]BPAADD
      Endif
    Endif
#    # agrupa por familia estadística
#    If [F:YBPC]YFACTSICOD0 = 2 Then
#      If [F:SDD]TSICOD(0) <> "" Then
#        [F:SWI]SWIKEY1 += "~"+[F:SDD]TSICOD(0)
#      Endif
#    Endif
  Endif
  Close Local File [YBPC]

  # agrupa por condición de pago
  If [M:DIA]YPTE <> "" Then
    [F:SWI]SWIKEY1 += "~"+[M:DIA]YPTE
  Endif

#If GUSER="AIT51" Then
#  Infbox "hola"
#  Infbox "SWIKEY:"  -num$([F:SWI]SWIKEY)
#  Infbox "SWIKEY1:" -num$([F:SWI]SWIKEY1)
#  Infbox "SWIDATA:" -num$([F:SWI]SWIDATA)
#  Infbox "SWIKEYD:" -num$([F:SWI1]SWIKEYD)
#  Infbox "BPCORD:"  -num$([F:SDD]BPCORD)
#  Infbox "TSICOD0:" -num$([F:SDD]TSICOD(0))
#  Infbox "SALFCY:" -num$([M:DIA]SALFCY)
#Endif
Return

##############################################################
$AUTINVDFIL

  # filtra por la Condición de pago indicada en la pantalla SAUTINVD
  If [M:DIA]YPTE <> "" Then
    FILSUP -= "AND PTE=[M:DIA]YPTE"
  Endif

  # filtra por la fecha inicial de la entrega en la pantalla SAUTINVD
  If [M:DIA]YSHIDAT <> "000000" Then
    FILSUP -= "AND [F:SDH]SHIDAT>=[M:DIA]YSHIDAT"
  Endif

  # si hay marcado algún check marcado en periodicidad sólo facturas aquellos con Modo de facturación = 1fª/periodo (5)
  If [M:DIA]INVPERJ = 2 or [M:DIA]INVPERS = 2 or [M:DIA]INVPERC = 2 or [M:DIA]INVPERQ = 2 or [M:DIA]INVPERM = 2 Then
    Local Integer LIME : LIME = 5
    FILSUP -= "AND IME=LIME"
  Endif
#  If GUSER="AIT51" Then : Infbox FILSUP : Endif


Return

##############################################################
# JC.05022021.YN54
$AUTINVDSEL
  If !clalev([F:BPC0]) Then : Local File BPCUSTOMER [F:BPC0] : Endif
  Read [F:BPC0]BPC0 = [F:SDH]BPCORD
  If !fstat Then
    If [M:DIA]YINVCND <> [F:BPC0]INVCND Then
      OK = 1 : Return
    Endif
  Endif

  Close Local File [BPC0]
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
