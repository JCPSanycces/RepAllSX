#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "SEL_TABLE"    : Gosub SEL_TABLE
  When "VERF_TABLE"   : Gosub VERF_TABLE
  When "BOUTON"       : Gosub BOUTON
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$SEL_TABLE
  Case TABLE
    When "YSELITM"    : Gosub SEL_YSELITM
  Endcase
Return

##############################################################
$VERF_TABLE
  Case TABLE
    When "YSELITM"    : Gosub VERF_YSELITM
  Endcase
Return

##############################################################
$BOUTON
Local Clbfile LCRIT(2)  : LCRIT = "1=1"
Local Integer LCONT     : Raz LCONT

  Case BOUT
    When "b"
      If [M:YMP0]YITMSTR <> ""            Then LCRIT -= "AND ITMREF >= [M:YMP0]YITMSTR" : Endif
      If [M:YMP0]YITMEND <> ""            Then LCRIT -= "AND ITMREF <= [M:YMP0]YITMEND" : Endif
      If [M:YMP0]YDATSTR <> [00/00/0000]  Then LCRIT -= "AND ACCDAT >= [M:YMP0]YDATSTR" : Endif
      If [M:YMP0]YDATEND <> [00/00/0000]  Then LCRIT -= "AND ACCDAT <= [M:YMP0]YDATEND" : Endif

      If !clalev([F:VMP0]) Then : Local File YVISUCMATPRI [F:VMP0] : Endif
      Filter [F:VMP0] Where evalue(LCRIT)
      For [F:VMP0]
        [M:YMP1]YITMREF(LCONT)  = [F:VMP0]ITMREF
        [M:YMP1]YITMDES(LCONT)  = [F:VMP0]ITMDES1
        [M:YMP1]YBPR(LCONT)     = [F:VMP0]BPR
        [M:YMP1]YBPSNAM(LCONT)  = [F:VMP0]BPSNAM
        [M:YMP1]YQTYUOM(LCONT)  = [F:VMP0]QTYUOM
        [M:YMP1]YNETPRI(LCONT)  = [F:VMP0]NETPRI
        [M:YMP1]YSTOCK(LCONT)   = [F:VMP0]STOCK
        LCONT += 1
      Next
      Filter [F:VMP0]
      Close Local File [VMP0]
      [M:YMP1]NBLIG = LCONT
      Affzo [M:YMP1]
    When "s"
      FIN = 1
  Endcase

If dim(LCRIT) > 0 Then : Kill LCRIT : Endif
If dim(LCONT) > 0 Then : Kill LCONT : Endif

Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$SEL_YSELITM
  CRITERE = "1=1"

  If !clalev([F:ITM0]) Then : Local File ITMMASTER [F:ITM0] : Endif
  Default File [ITM0]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Artículos"                                                     # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Artículo"                                                      # título de la segunda columna
  COL(NBCOL)  = "ITMREF"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la primera columna
  COL(NBCOL)  = "ITMDES1"                                                       # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Categoría"                                                     # título de la primera columna
  COL(NBCOL)  = "TCLCOD"                                                        # nombre del campo a mostrar en la primera columna

  CRITERE     = " TCLCOD ='YNMP' AND ITMSTA = 1 "
  SENS        = 1
  DEFPAG      = 5
  SIZCOL      = 100
  SIZLIG      = 100
  GSELFAC     = 1

Return

##############################################################
$VERF_YSELITM
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Después de modificar el campo 'Artículo desde'
######################################################################################
Subprog AM_YITMSTR(VALEUR)
Variable Char    VALEUR()
  If VALEUR <> "" Then
    If !clalev([F:ITM1]) Then : Local File ITMMASTER [F:ITM1] : Endif
    Read [F:ITM1]ITM0 = VALEUR
    If !fstat Then
      [M:YMP0]YITMDESSTR = [F:ITM1]ITMDES1
      Affzo [M:YMP0]YITMDESSTR
      [M:YMP0]YITMDESEND = [F:ITM1]ITMDES1
      Affzo [M:YMP0]YITMDESEND
    Endif
    Close Local File [F:ITM1]

    If [M:YMP0]YITMEND = "" Then
      [M:YMP0]YITMEND = VALEUR
      Affzo [M:YMP0]YITMEND
    Endif
  Endif
End

######################################################################################
## Después de modificar el campo 'Artículo hasta'
######################################################################################
Subprog AM_YITMEND(VALEUR)
Variable Char    VALEUR()
  If VALEUR <> "" Then
    If !clalev([F:ITM1]) Then : Local File ITMMASTER [F:ITM1] : Endif
    Read [F:ITM1]ITM0 = VALEUR
    If !fstat Then
      [M:YMP0]YITMDESEND = [F:ITM1]ITMDES1
      Affzo [M:YMP0]YITMDESEND
    Endif
    Close Local File [F:ITM1]
  Endif
End

######################################################################################
## Después de modificar el campo 'Fecha desde'
######################################################################################
Subprog AM_YDATSTR(VALEUR)
Variable Date    VALEUR
  If [M:YMP0]YDATEND = [00/00/0000] Then
    [M:YMP0]YDATEND = VALEUR
    Affzo [M:YMP0]YDATEND
  Endif
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

