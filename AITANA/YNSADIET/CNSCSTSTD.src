######################################################################################
######################################################################################
Subprog SHOWHIDE(P_CPY)
Value Char P_CPY

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Local Char SHOWSIGN(1),V_FIELD(4),V_LEG(20)
[L]SHOWSIGN = ""
[L]V_FIELD  = "LA:1"

Call GETLEG(P_CPY,"",[L]V_LEG) From TRTLECLEG

If func AFNC.ACTIV("INVCA") = 1
  If func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
    Call SHOWHIDE_FIELDS(1,[M:CST1]INVTYPFAC)
    Call SHOWHIDE_FIELDS(2,[M:CST1]INVTYPAVO)
  Else
    [L]SHOWSIGN = "-"
    Chgfmt [M:CST1]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
    Chgfmt [M:CST1]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
    [M:CST1]INVCANCAT = 1
    [M:CST1]INVCANSTA = 1
    Chgfmt [M:CCST]INVCANCAT With [L]SHOWSIGN+[L]V_FIELD
    Chgfmt [M:CCST]INVCANSTA With [L]SHOWSIGN+[L]V_FIELD
    [M:CCST]INVCANCAT = 1
    [M:CCST]INVCANSTA = 1
  Endif

  Affzo [M:CST1]INVCANCAT
  Affzo [M:CST1]INVCANSTA
  Affzo [M:CCST]INVCANCAT
  Affzo [M:CCST]INVCANSTA
Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - END

End
######################################################################################
######################################################################################
$SETDEFAULT_VALUES

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Raz [L]V_LEG
Call GETLEG([M:CCST]CPY,"",[L]V_LEG) From TRTLECLEG

If [L]INVCA_ON = 1 & func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
  If !find([M:CCST]INVCANCAT,1,2) : [M:CCST]INVCANCAT = 1 : Endif
  If !find([M:CCST]INVCANSTA,1,2) : [M:CCST]INVCANSTA = 1 : Endif
Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - END

Return
######################################################################################

