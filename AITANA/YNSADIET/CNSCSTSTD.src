#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
# CNSCSTSTD : Consultation des lignes de factures ventes                #
# ECRAN 1   : CONSCST1                                                  #
# ECRAN 2   : CONSCST2                                                  #
# ECRAN CRIT: CRITCST                                                   #
#########################################################################
#YYN45: MODIFICACIONES YNSADIET
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "DEB_CRIT"   : Gosub DEB_CRIT
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "AB3_NBLIG"  : Gosub AB3_NBLIG
  When "SETBOUT"     : Gosub SETBOUT
 When Default
Endcase
Return

############################################################
$AUTORIS
Return

$SETBOUT

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Raz [L]V_LEG
Call GETLEG([M:CST1]CPY,"",[L]V_LEG) From TRTLECLEG

If ([M:CST2]NBLIG>0 & [L]INVCA_ON = 1)
  If func AFNC.PARAM("INVCAN",[L]V_LEG) <> "2"
    Chgfmt [M:CST2]INVCAN With "-LA:1"
  Else
    Chgfmt [M:CST2]INVCAN With "+LA:1"
  Endif
Endif

Affzo [M:CST2]
Affzo [M:CCST]
Affzo [M:CST1]
#105200 RICAR 2015/05/25 - Inv Cancelation - END

Return

###################################################################
# analyse paramères, initialisations, ouvertures et déclarations  #
###################################################################
$OUVRE
Local Char    WFIL(250),WFIL1(250),WFIL2(250)
Local Char    DEBNUM, FINNUM
Local Date    DEBDAT, FINDAT
Local Integer DEBLIN, FINLIN :# 69747
#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Local Integer INVCA_ON
Local Char    V_LEG(20)

[L]INVCA_ON = 0
If func AFNC.ACTIV("INVCA") = 1 : [L]INVCA_ON = 1 : Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - END

#MAE, on ajoute la consultation dans la pile de la navigation
NAVIG="CONSCST"

If clalev([F:DUD])=0 Local File GACCDUDATE [DUD] : Endif
If clalev([F:TCU])=0 Local File TABCUR     [TCU] : Endif
If clalev([F:AMZ])=0 Local File AMSKZON    [AMZ] : Endif

Gosub DEFCRIT
Return

# --------------------------------------------------------------------------#
# Analyse paramères, initialisations                                        #
# --------------------------------------------------------------------------#
$DEFCRIT
If [M:CST1]SALFCY<>"" & GUSRFCY(1)<>"\" & !find([M:CST1]SALFCY,GUSRFCY(1..GNBAUZ))
 [M:CST1]SALFCY=""
Endif

For I = 1 To dim(PARAM)
  Case I
    When 1 :    : # Parametre article
      If PARAM(I) <> ""
        If [F:ITM]ITMREF<>PARAM(I) Read [F:ITM]ITM0 = PARAM(I)
                                     If fstat
                                        Raz [F:ITM], PARAM(I)
                                     Endif
        Endif
        [M:CST1]ITMREF = PARAM(I)
      Endif

    When 2 :    : # Parametre Client
      If PARAM(I) <> ""
        If [F:BPC]BPCNUM<>PARAM(I) Read [F:BPC]BPC0 = PARAM(I)
                                     If fstat
                                        Raz [F:BPC], PARAM(I)
                                     Endif
        Endif
        [M:CST1]BPCINV = PARAM(I)
      Endif
    When 3 :    : # Parametre Site
      If PARAM(I) <> ""
        If [F:FCY]FCY <> PARAM(I)    Read [F:FCY]FCY0 = PARAM(I)
                                     If fstat
                                       Raz [F:FCY], PARAM(I)
                                     Endif
        Endif
        If GUSRFCY(1)="\" | find(PARAM(I),GUSRFCY(1..GNBAUZ))
           [M:CST1]SALFCY = PARAM(I)
           If [M:CST1]SALFCY <> ""
             Call GETDEV([M:CST1]SALFCY) From DEVSUB
             [M:CST1]CPY  = GSOCIETE
           Endif
        Endif
      Endif
    When 4 :    : # Parametre PJT
      # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
      If PARAM(I) <> "" Then
        [M:CST1]PJTDEB = PARAM(I)
        [M:CST1]PJTFIN = PARAM(I)
        If find(GNAVIG(GPILNAV-0),"GESPJM") Then   # Note FGR : '-0' is not an error. This is true in this case.
          [M:CST1]PJTDSPALL = [V]CST_AYES
        Endif
      Endif
      # Issue Issue X3-15598 - 2017-02-23 by FGR : END
    When 5 :    : # Parametre DATBEG
      # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
      If PARAM(I) <> ""  and PARAM(I) <> "000000" Then
        [M:CST1]INVDATDEB = PARAM(I)
        [M:CST1]INVDATDEB = gdat$(01,month([M:CST1]INVDATDEB),year([M:CST1]INVDATDEB))
      Endif
      # Issue Issue X3-15598 - 2017-02-23 by FGR : END
  Endcase
Next I

If !find([M:CST1]INVTYPFAC,1,2) : [M:CST1]INVTYPFAC = 2 : Endif
If !find([M:CST1]INVTYPAVO,1,2) : [M:CST1]INVTYPAVO = 2 : Endif
If !find([M:CST1]INVTYPPRF,1,2) : [M:CST1]INVTYPPRF = 2 : Endif
If !find([M:CST1]INVSTAO,1,2)   : [M:CST1]INVSTAO = 2 : Endif
If !find([M:CST1]INVSTAN,1,2)   : [M:CST1]INVSTAN = 2 : Endif

If !find([M:CCST]ORIMODVEN,1,2) : [M:CCST]ORIMODVEN = 2 : Endif
If !find([M:CCST]ORIMODTIE,1,2) & clalev([M:BPC0])
    [M:CCST]ORIMODTIE = 2
Else
    [M:CCST]ORIMODTIE = 1
Endif
If !find([M:CCST]TRI,1,2)       : [M:CCST]TRI = 1  : Endif

#Gbn-Fq75968-Pas d'init des dates si déjà alimentées par le mémo STD
If [M:CST1]INVDATFIN=[0/0/0] : [M:CST1]INVDATFIN=eomonth(date$) : Endif
If [M:CST1]INVDATDEB=[0/0/0] : [M:CST1]INVDATDEB=gdat$(01,month(addmonth(date$,-2)),year(addmonth(date$,-2))) : Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Gosub SETDEFAULT_VALUES
#105200 RICAR 2015/05/25 - Inv Cancelation - END
# -- copie de l'écran critères (CCST) vers le masque 1 (CST1)
Gosub CRITENT From =PROGCNS

Return
############################################################
$DEB_CRIT
#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Call SHOWHIDE([M:CST1]CPY)
#105200 RICAR 2015/05/25 - Inv Cancelation - END

#acces depuis article ou article site
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM","GESITF")
        If find(GNAVIG(GPILNAV-1),"GESITM")
            Diszo [M:CCST]ITMREF
        Elsif find(GNAVIG(GPILNAV-1),"GESITF")
            Diszo [M:CCST]ITMREF
            Diszo [M:CCST]SALFCY
            Diszo [M:CCST]CPY
        Endif
        If dim([M:CCST]TSICOD) > 0
          For I = 0 To dim([M:CCST]TSICOD)-1
            Diszo [M:CCST]TSICOD(I)
          Next I
        Endif
    Endif
    #acces depuis clients ou fournisseurs
    If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC")
        Diszo [M:CCST]BPCINV
        If dim([M:CCST]TSCCOD) > 0
          For I = 0 To dim([M:CCST]TSCCOD)-1
            Diszo [M:CCST]TSCCOD(I)
          Next I
        Endif
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:CCST]PJTDEB
      Diszo [M:CCST]PJTFIN
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : END
Endif
Return


############################################################
$LECTURE
Local   Decimal  WMNTORG(0..5), WMNTDES(0..5), WRAT
Local   Integer  SPSTAT, WI

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Call SHOWHIDE([M:CST1]CPY)
#105200 RICAR 2015/05/25 - Inv Cancelation - END

#MAE, est ce qu'on vient de article ou article site ?
If GPILNAV>1
    If find(GNAVIG(GPILNAV-1),"GESITM")
        Diszo [M:CST1]ITMREF
    Elsif find(GNAVIG(GPILNAV-1),"GESITF")
        Diszo [M:CST1]ITMREF
        Diszo [M:CST1]SALFCY
        Diszo [M:CST1]CPY
    Endif

    #acces depuis clients ou fournisseurs
    If find(GNAVIG(GPILNAV-1),"GESBPS","GESBPC")
        Diszo [M:CST1]BPCINV
    Endif

    # Issue Issue X3-15598 - 2017-02-23 by FGR : BEGIN
    If find(GNAVIG(GPILNAV-1),"GESPJM","PJMACTBUD", "PJMACTTAS") Then
      Diszo [M:CST1]PJTDEB
      Diszo [M:CST1]PJTFIN
    Endif
    # Issue Issue X3-15598 - 2017-02-23 by FGR : END

    # GRNA 16/05/2011
    Local Char CUSSEAORI : CUSSEAORI = "CST1"
    Gosub LECTURE From CUSSEALIB
Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

Link [SID] With [SIH]SIH0=[SID]NUM,
&               [SIV]SIV0=[SID]NUM
&          As [LNK]


# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #

#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CCST]TRI
      When 1 : # tri par numéro
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SID0
      When 2 : # tri par date
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                    Order By Key CLE=[F:SIH]BPRDAT;[F:SIH]NUM;[F:SID]SIDLIN :# 69747
#&                    Order By Key CLE=[F:SIH]BPRDAT;[F:SIH]NUM
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CCST]TRI
      When 1 : # tri par numéro
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key SID0 Desc
      When 2 : # tri par date
        Filter [LNK] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2)
&                    Order By [F:SIH]BPRDAT Desc ;[F:SIH]NUM Desc;[F:SID]SIDLIN Desc :# 69747
#&                    Order By [F:SIH]BPRDAT Desc ;[F:SIH]NUM Desc
    Endcase
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:CST2] : Endif

#-- lecture
$BOUCLE
For [LNK] With Nohint

# FGR 24/02/2015 : X3SUIVI104383 : mis dans le FILTER
#If fstat & [F:SIH]ORIMOD=5 Goto SUIV : Endif
## Filtre sur la société
#  If [M:CST1]CPY <> "" & ([M:CST1]CPY <> [F:SIH]CPY) Goto SUIV : Endif

  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:CST2] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
     NOL    += 1
     If NOL=0
         #69747
         If CHGPAG=2
           If [F:SID]NUM=FINNUM and [F:SID]SIDLIN<=FINLIN : NOL-=1 : Goto SUIV : Endif
         Endif
         #fin 69747
         DEBNUM = [F:SIH]NUM
         DEBDAT = [F:SIH]BPRDAT
         DEBLIN = [F:SID]SIDLIN :# 69747
     Endif
     FINNUM = [F:SIH]NUM
     FINDAT = [F:SIH]BPRDAT
     FINLIN = [F:SID]SIDLIN :# 69747
  Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
     NOL    -= 1
     If NOL=MAXLIG-1
         #69747
         If CHGPAG=-2
           If [F:SID]NUM=DEBNUM and [F:SID]SIDLIN>=DEBLIN : NOL+=1 : Goto SUIV : Endif
         Endif
         #fin 69747
         FINNUM = [F:SIH]NUM
         FINDAT = [F:SIH]BPRDAT
         FINLIN = [F:SID]SIDLIN :# 69747
     Endif
     DEBNUM = [F:SIH]NUM
     DEBDAT = [F:SIH]BPRDAT
     DEBLIN = [F:SID]SIDLIN :# 69747
  Endif

  nolign = NOL+1
  [M:CST2]=[F:SIH] : # trans classe sur SINVOICE
  # 71065 : PJT
  #[M:CST2]=[F:SID] : # trans classe sur SINVOICED
  [M:CST2]=[F:SIV] : # trans classe sur SINVOICEV
  [M:CST2]=[F:SID] : # trans classe sur SINVOICED
  # 71065 : PJT

  #105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
  Raz [L]V_LEG
  Call GETLEG([M:CCST]CPY,"",[L]V_LEG) From TRTLECLEG

  If [L]INVCA_ON = 1 & func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
    Case [F:SIH]REVCANSTA
      When 0: [M:CST2]INVCAN(nolign-1) = 3
      When 1: [M:CST2]INVCAN(nolign-1) = 1
      When 2: [M:CST2]INVCAN(nolign-1) = 2
    Endcase
  Endif
  #105200 RICAR 2015/05/25 - Inv Cancelation - END

  $SUIV
Next
Filter [LNK]

Return
############################################################
#    Préparation du filtre                                 #
############################################################
$LOAD_FILTER
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"

# FGR 24/02/2015 : X3SUIVI104383 (début)
If [M:CST1]CPY <> ""
  WFIL += "&[F:SIH]CPY=[M:CST1]CPY"
Endif
# FGR 24/02/2015 : X3SUIVI104383 (fin)

If [M:CST1]SALFCY <> ""
    WFIL += "&[F:SIH]FCY=[M:CST1]SALFCY"
Endif
#    Autorisation site
#utilisation des habilitations utilisateurs même si les site est vide
#If GUSRFCY(1)<>"\" & [M:CST1]SALFCY <> "" & GNBAUZ<>GNBSITE
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
 WFIL += "& find([F:SIH]FCY,GUSRFCY(1..GNBAUZ))"
Endif

If [M:CST1]ITMREF <> ""
   #WFIL += "&[F:SID]ITMREF =[M:CST1]ITMREF"  #YYN45
   WFIL += "&[F:SID]ITMREF >=[M:CST1]ITMREF"  #YYN45
Endif

If [M:CST1]YITMREF <> ""
   WFIL += "&[F:SID]ITMREF <=[M:CST1]YITMREF"  #YYN45
Endif

If [M:CST1]BPCINV <> ""
   WFIL += "&[F:SIH]BPR =[M:CST1]BPCINV"
Endif
WFIL += "&[F:SIH]INVTYP<>3 & [F:SIH]INVTYP<>4"
# Prise en compte des factures
# --> Si 1 (Non) On exclut les factures
If [M:CST1]INVTYPFAC = 1
   WFIL += "&[F:SIH]INVTYP<>1"
Endif
# Prise en compte des avoirs
# --> Si 1 (Non) On exclut les avoirs
If [M:CST1]INVTYPAVO = 1
   WFIL += "&[F:SIH]INVTYP<>2"
Endif
# Prise en compte des proformas
# --> Si 1 (Non) On exclut les proformas
If [M:CST1]INVTYPPRF = 1
   WFIL += "&[F:SIH]INVTYP<>5"
Endif
# Prise en compte des factures validées
# --> Si 1 (Non) On exclut les factures validées
If [M:CST1]INVSTAO = 1
   WFIL += "&[F:SIH]STA<>3"
Endif
# Prise en compte des factures non validées
# --> Si 1 (Non) On exclut les factures non validées
If [M:CST1]INVSTAN = 1
   WFIL += "&[F:SIH]STA>2"
Endif
# Prise en compte des factures vente
# --> Si 1 (Non) On exclut les factures vente
If [M:CCST]ORIMODVEN = 1
   WFIL += "&[F:SIH]ORIMOD<>5"
Endif
# Prise en compte des factures tiers
# --> Si 1 (Non) On exclut les factures tiers
If [M:CCST]ORIMODTIE = 1
   WFIL += "&[F:SIH]ORIMOD<>3"
Endif

If [M:CCST]NUMDEB <> ""
   WFIL1 += "&[F:SIH]NUM>=[M:CCST]NUMDEB"
Endif
If [M:CCST]NUMFIN <> ""
   WFIL1 += "&[F:SIH]NUM<=[M:CCST]NUMFIN"
Endif

If [M:CCST]INVDATDEB <> [0/0/0]
   WFIL1 += "&[F:SIH]BPRDAT>=[M:CCST]INVDATDEB"
Endif
If [M:CCST]INVDATFIN <> [0/0/0]
   WFIL1 += "&[F:SIH]BPRDAT<=[M:CCST]INVDATFIN"
Endif

If dim([M:CCST]TSICOD) > 0
  For I = 0 To dim([M:CCST]TSICOD)-1
    If [M:CCST]TSICOD(I) <> ""
      If len(WFIL1) > 200
        WFIL2 += "&[F:SID]TSICOD("+num$(I)+")='"+[M:CCST]TSICOD(I)+"'"
      Else
        WFIL1 += "&[F:SID]TSICOD("+num$(I)+")='"+[M:CCST]TSICOD(I)+"'"
      Endif
    Endif
  Next I
Endif

If dim([M:CCST]TSCCOD) > 0
  For I = 0 To dim([M:CCST]TSCCOD)-1
    If [M:CCST]TSCCOD(I) <> ""
      If len(WFIL1) > 200
        WFIL2 += "&[F:SIV]TSCCOD("+num$(I)+")='"+[M:CCST]TSCCOD(I)+"'"
      Else
        WFIL += "&[F:SIV]TSCCOD("+num$(I)+")='"+[M:CCST]TSCCOD(I)+"'"
      Endif
    Endif
  Next I
Endif

# FGR 23/02/2015 : X3SUIVI104383 (début)
If [M:CST1]SIVTYP <> "" Then
  WFIL2 += "&[F:SIV]SIVTYP=[M:CST1]SIVTYP"
Endif
# FGR 23/02/2015 : X3SUIVI104383 (fin)

# Issue X3-25731 - 2017-02-24 by FGR : BEGIN
## 71065 : PJT
#If [M:CST1]PJTDEB <> ""
#   WFIL2 += "&[F:SID]PJT>=[M:CST1]PJTDEB"
#Endif
#If [M:CST1]PJTFIN <> ""
#   WFIL2 += "&[F:SID]PJT<=[M:CST1]PJTFIN"
#Endif
## 71065 : PJT
If dim([M:CST1]PJTDSPALL) >= 0 and [M:CST1]PJTDSPALL = [V]CST_AYES and [M:CST1]PJTDEB <> "" Then
  Local Char SPJT(GLONPIM)
  Local Char SBUDGET(GLONTAC)
  Local Char STASK(GLONPBU)
  Local Integer IRET

  IRET = func PIMPL_CSTD_PROGS.PJM_KEY_SPLIT(GACTX, [M:CST1]PJTDEB, SPJT, SBUDGET, STASK)
  WFIL1 += "&pat([F:SID]PJT,'" + SPJT + "*')<>0"
Else
  If [M:CST1]PJTDEB <> ""
     WFIL2 += "&[F:SID]PJT>=[M:CST1]PJTDEB"
  Endif
  If [M:CST1]PJTFIN <> ""
     WFIL2 += "&[F:SID]PJT<=[M:CST1]PJTFIN"
  Endif
Endif
# Issue X3-25731 - 2017-02-24 by FGR : END

Case CHGPAG
   When 3 : # rafraichissement
     Case [M:CCST]TRI
       When 1 : # tri par numéro
           WFIL2 += "&[F:SIH]NUM>=DEBNUM"
       When 2 : # tri par date
           WFIL2 += "&([F:SIH]BPRDAT>DEBDAT | ([F:SIH]BPRDAT=DEBDAT & [F:SIH]NUM>=DEBNUM))"
     Endcase
   When 2 : # suite
     Case [M:CCST]TRI
       When 1 : # tri par numéro
           #WFIL2 += "&[F:SIH]NUM>FINNUM"
           WFIL2 += "&[F:SIH]NUM>=FINNUM" :# 69747
       When 2 : # tri par date
           #WFIL2 += "&([F:SIH]BPRDAT>FINDAT | ([F:SIH]BPRDAT=FINDAT & [F:SIH]NUM>FINNUM))"
           WFIL2 += "&([F:SIH]BPRDAT>FINDAT | ([F:SIH]BPRDAT=FINDAT & [F:SIH]NUM>=FINNUM))" :# 69747
     Endcase
   When -2 : # retour
     Case [M:CCST]TRI
       When 1 : # tri par numéro
           #WFIL2 += "&[F:SIH]NUM<DEBNUM"
           WFIL2 += "&[F:SIH]NUM<=DEBNUM" :# 69747
       When 2 : # tri par date
           #WFIL2 += "& ([F:SIH]BPRDAT<DEBDAT | ([F:SIH]BPRDAT=DEBDAT & [F:SIH]NUM<DEBNUM))"
           WFIL2 += "& ([F:SIH]BPRDAT<DEBDAT | ([F:SIH]BPRDAT=DEBDAT & [F:SIH]NUM<=DEBNUM))" :# 69747
     Endcase
Endcase

#105200 RICAR 2015/05/25 - Inv Cancelation - BEGIN
Raz [L]V_LEG
Call GETLEG([M:CST1]CPY,"",[L]V_LEG) From TRTLECLEG

If [L]INVCA_ON = 1  & func AFNC.PARAM("INVCAN",[L]V_LEG) = "2"
  WFIL1 += "& find([F:SIH]REVCANSTA,0"
  If [M:CST1]INVCANSTA = 2
    WFIL1 += ",1"
  Endif
  If [M:CST1]INVCANCAT = 2
    WFIL1 += ",2"
  Endif
  WFIL1 +=")>0"
Endif
#105200 RICAR 2015/05/25 - Inv Cancelation - END

Return

############################################################################
#    Avant de fermer la fenetre critère et de revenir à fenetre principale #
############################################################################
$FIN_CRIT


Return

############################################################

$AB3_NBLIG
Local Char    WOBJET(GLONAOB)
If [M:CST2]SOPLIN(nolign-1) = [M:CST2]SOQSEQ(nolign-1)
    WOBJET= "SOH"
Else
    WOBJET= "SOR"
Endif

Return


#############################################################################
##     Etiquettes masques CONSCSI1 & CONSCSI2 & CRITCSI                    ##
#############################################################################
############################################################
Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
End
############################################################
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
# -- Controle autorisation sur le site
    If GUSRFCY(1)<>"\" & !find(VALEUR,GUSRFCY(1..GNBAUZ))
        GMESSAGE=VALEUR-mess(2,104,1)   : # Vous n'avez pas les droits sur ce site
        mkstat=2 : End
    Endif
#-----------------------------------#
# Alimentation site fin.(GFINRSP)   #
#              soc. (GSOCIETE)      #
#              dev.soc. (GLOCALDEV) #
#-----------------------------------#
    Call GETDEV(VALEUR) From DEVSUB
    [M]CPY = GSOCIETE
    Affzo [M]CPY, ZCPY
Elsif [M]CPY = ""
    # Mail CH : 03/03/04
    #    GMESSAGE = mess(9,109,1)            : # Vous devez saisir une société ou un site
    #    mkstat = 2
    GSOCIETE="" : GLOCALDEV=""
Else
    Call CONTALLFCY([M]CPY) From CPTSUB : # Accès à tous les sites de la société ?
Endif

End
########################################
Subprog IB_NBLIG

If [M:CST2]ORIMOD(nolign-1)=5
    GBOUT1 = mess(193, 198,1)-[M]NUM(nolign-1) : Raz GBOUT2
Else
    GBOUT2 = mess(193, 198,1)-[M]NUM(nolign-1) : Raz GBOUT1
Endif
If [M:CST2]SOHNUM(nolign-1) <> ""
    If [M:CST2]SOPLIN(nolign-1) = [M:CST2]SOQSEQ(nolign-1)
        GBOUT3 = mess(1,306,1)-[M]SOHNUM(nolign-1)
    Else
        GBOUT3 = mess(92,198,1)-[M]SOHNUM(nolign-1)
    Endif
Else
    Raz GBOUT3
Endif

If [M:CST2]SDHNUM(nolign-1) <> ""
    GBOUT4 = mess(54,198,1)-[M]SDHNUM(nolign-1)
Else
    Raz GBOUT4
Endif

# SYMEU 27/11/2008 : branchement appel traçabilité pièce vente
If [M]INVTYP(nolign-1)>2
   Raz GBOUT5
Endif


End
