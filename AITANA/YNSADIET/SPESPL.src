#<AdxTL>@(#)0.0.0.0 $Revision$ Entrada de tarifas
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "APRES_CRE"  :   Gosub APRES_CRE         # YN16
  When "APRES_MOD"  :   Gosub APRES_MOD         # YN16
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$APRES_CRE
  If [M:SPLW]PLIENDDAT >= date$ and ([M:SPLW]PLI = "VN20" or [M:SPLW]PLI = "VN50" or [M:SPLW]PLI = "VN60" or [M:SPLW]PLI = "LM50") Then
    Gosub ADD_TAR_COMERZZIA
  Endif
Return

##############################################################
$APRES_MOD
  If [M:SPLW]PLIENDDAT >= date$ and ([M:SPLW]PLI = "VN20" or [M:SPLW]PLI = "VN50" or [M:SPLW]PLI = "VN60" or [M:SPLW]PLI = "LM50") Then
    Gosub ADD_TAR_COMERZZIA
  Endif
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ADD_TAR_COMERZZIA
Local Char    LCODTAR(11),LDESTAR(45),LCODART(25),LDESGLOSE1(15),LDESGLOSE2(15),LPROCESADO(1)
Local Integer LID_TRAT_IMPUESTOS
Local Date    LFECHA_INICIO_VIGENCIA,LFECHA_ALTA_REGISTRO
Local Decimal LPPRECIO_COSTO,LFACTOR_MARCAJE,LPRECIO_VENTA,LPRECIO_TOTAL

  If !clalev([F:SPL0]) Then : Local File SPRICLIST [F:SPL0] : Endif
  If !clalev([F:FCY0]) Then : Local File FACILITY  [F:FCY0] : Endif
  Filter [F:SPL0] Where PLI = [M:SPLW]PLI and PLICRD = [M:SPLW]PLICRD
  For [SPL0]
    Raz LCODTAR,LDESTAR,LCODART,LDESGLOSE1,LDESGLOSE2,LPROCESADO,LID_TRAT_IMPUESTOS,LFECHA_INICIO_VIGENCIA
    Raz LFECHA_ALTA_REGISTRO,LPPRECIO_COSTO,LFACTOR_MARCAJE,LPRECIO_VENTA,LPRECIO_TOTAL
#    If [F:SPL0]PLI    = "T40" Then
#      LCODTAR               = "GENERAL"
#      LDESTAR               = [F:SPL0]PLICRD
#      LCODART               = [F:SPL0]PLICRI1
#    Elsif [F:SPL0]PLI = "T45"
#      LCODTAR               = [F:SPL0]PLICRI1
#      Read [F:FCY0]FCY0 = [F:SPL0]PLICRI1
#      If !fstat Then
#        LDESTAR             = [F:FCY0]FCYNAM
#      Endif
#      LCODART               = [F:SPL0]PLICRI2
#    Endif
    If [F:SPL0]PLI    = "VN20" Then
      LCODTAR               = [F:SPL0]PLICRI1
      LDESTAR               = "PRECIOS ESPECIALES VENTANAS"
      LCODART               = [F:SPL0]PLICRI2
    Elsif [F:SPL0]PLI = "VN50"
      LCODTAR               = "GENERAL"
      LDESTAR               = "VENTANAS YNSADIET"
      LCODART               = [F:SPL0]PLICRI2
    Elsif [F:SPL0]PLI = "VN60"
      LCODTAR               = "GENERAL"
      LDESTAR               = "VENTANAS TERCEROS PROVEEDORES"
      LCODART               = [F:SPL0]PLICRI1
    Elsif [F:SPL0]PLI = "LM50"
      LCODTAR               = "GENERAL"
      LDESTAR               = "VENTANAS LA MANCHA"
      LCODART               = [F:SPL0]PLICRI1
    Endif
    LID_TRAT_IMPUESTOS      = 1
    LDESGLOSE1              = "*"
    LDESGLOSE2              = "*"
    LPRECIO_COSTO           = 0
    LFACTOR_MARCAJE         = 0
    LPRECIO_VENTA           = [F:SPL0]PRI
    LPRECIO_TOTAL           = [F:SPL0]PRI - (([F:SPL0]PRI*[F:SPL0]DCGVAL(3)) / 100)
    LFECHA_INICIO_VIGENCIA  = [F:SPL0]PLISTRDAT #gdat$(01,01,year(date$))#
    LFECHA_ALTA_REGISTRO    = date$
    LPROCESADO              = "N"


    Call SET_TRF_COMERZZIA(LCODTAR,LDESTAR,LID_TRAT_IMPUESTOS,LCODART,LDESGLOSE1,LDESGLOSE2,LPRECIO_COSTO,LFACTOR_MARCAJE,
&                          LPRECIO_VENTA,LPRECIO_TOTAL,LFECHA_INICIO_VIGENCIA,LFECHA_ALTA_REGISTRO,LPROCESADO) From SPEYLIB0

  Next

  Filter [F:SPL0]
  If  clalev([F:SPL0]) Then : Close Local File     [F:SPL0] : Endif
  If  clalev([F:FCY0]) Then : Close Local File     [F:FCY0] : Endif

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
##############################################################
