## Después de modificar el campo 'Lote proveedor'
######################################################################################
Subprog AM_BPSLOTAFF(VALEUR)
Variable Char    VALEUR()

# JC - 07/07/2020 - YYN01 - STR
  If !clalev([F:YTR0]) Then : Local File YMFGTRAZAPR [F:YTR0] : Endif
  Read [F:YTR0]YTR1 = [M:ENM]ITMREF;VALEUR;[M:ENM]VCRNUM
  If !fstat Then
    [M:ENM]STA(nolign-1) = [F:YTR0]STA
    Affzo [M:ENM]STA(nolign-1)
  Else
    [M:ENM]STA(nolign-1) = "Q"
    Affzo [M:ENM]STA(nolign-1)
  Endif
  Close Local File [YTR0]
# JC - 07/07/2020 - YYN01 - END

End

