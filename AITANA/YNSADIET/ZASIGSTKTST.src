#<AdxTL>@(#)0.0.0.0 $Revision$ 
$MAIN
   Value Integer TIPASIG
   Value Char PLANTA     
   Value Char ARTICULO
   Value Decimal STOCOU
   Value Decimal CTDAD
   Value Integer TIPASIENTO
   Value Char PEDIDO
   Value Integer LINEA
   Value Integer SECUENCIA
   Value Char LOTE
   Value Char ESTADO
   Value Char UBICACION
   Local Integer WRET
   Raz WRET
   
   TIPASIG=2
   PLANTA='101'
   ARTICULO='6400C180'
   STOCOU=20685
   CTDAD=90
   TIPASIENTO=2
   PEDIDO='EDI1012100088'
   LINEA=1000
   SECUENCIA=1000
   LOTE='410026'
   ESTADO='A'
   UBICACION='ALM01'
   

   call ASIGNARSTOCK(TIPASIG,PLANTA,ARTICULO,STOCOU,CTDAD,TIPASIENTO,PEDIDO,LINEA,SECUENCIA,LOTE,ESTADO,UBICACION,WRET) FROM ZASIGSTKTST

End

Subprog ASIGNARSTOCK(TIPASIG,PLANTA,ARTICULO,STOCOU,CTDAD,TIPASIENTO,PEDIDO,LINEA,SECUENCIA,LOTE,ESTADO,UBICACION,LRET)
	Value Integer TIPASIG
	Value Char PLANTA     
	Value Char ARTICULO
	Value Decimal STOCOU
	Value Decimal CTDAD
	Value Integer TIPASIENTO
	Value Char PEDIDO
	Value Integer LINEA
	Value Integer SECUENCIA
	Value Char LOTE
	Value Char ESTADO
	Value Char UBICACION
	
	Variable Integer  LRET

	Local Date LDAT : LDAT = [0/0/0]
	Local Decimal LQTA : LQTA  = CTDAD
	Local Char LPRE : LPRE = "" 
	Local Date LDTE : LDTE = [0/0/0]  
	Local Char LSLO : LSLO = "" 
	Local Char LSER : LSER = "" 
	Local Char LWRH : LWRH = "" 
	Local Decimal LALLQTY : LALLQTY = CTDAD
	Local Decimal LALLQTA : LALLQTY = CTDAD
	Local Char LDEFLOC : LDEFLOC = "" 
	Local Char LDEFLOCTYP : LDEFLOCTYP = "" 
	Local Char LBPR : LBPR = "" 
	Local Char LADD : LADD = "" 
	Local Integer LSCO : LSCO = 0 
	Local Char LECC : LECC = "" 

Call CREALL(TIPASIG,PLANTA,ARTICULO,STOCOU,LDAT,CTDAD,LQTA,TIPASIENTO,PEDIDO,LINEA,SECUENCIA,
&              LPRE,LDTE,LOTE,LSLO,ESTADO,UBICACION,LSER,LWRH,LALLQTY,LALLQTA,
&              LDEFLOC,LDEFLOCTYP,LBPR,LADD,LSCO,LECC,LRET) From STKALL

End