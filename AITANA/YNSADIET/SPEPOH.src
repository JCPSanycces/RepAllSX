######################################################################################
## Etiqueta añadida por el supervisor (pantalla POH2) 27/02/2020 18:57:53 (AIT07)
######################################################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
#Infbox num$(VALEUR)
  If !clalev([F:ITM0]) Then : Local File ITMMASTER [F:ITM0] : Endif
  Read [F:ITM0]ITM0 = VALEUR
  If !fstat Then
    [M:POH2]YTEXTOPROD(nolign-1) = [F:ITM0]YTEXTOPROD
    Affzo [M:POH2]YTEXTOPROD(nolign-1)
  Endif
#Infbox num$([M:POH2]YTEXTOPROD(nolign-1))
  If clalev([F:ITM0])  Then : Close Local File     [F:ITM0] : Endif
End


