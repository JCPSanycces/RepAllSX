$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
#If GUSER = "AIT51" Then : Infbox ACTION : Endif
Case ACTION
  When "LIENS_LIG"  : Gosub LIENS_LIG
  When Default
Endcase

Return

