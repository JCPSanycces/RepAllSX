#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "AVANT_OK"  : Gosub AVANT_OK
Endcase
Return

#####################################################
$AVANT_OK
# Copio la rutina del STD para ajustarlo y luego bloqueo la llamada al STD
Global Integer DEL_LIGNE # 2 = estoy borrando línea
FIN=0

# Il n'y a rien à traiter
If [M:XAB1]PRHNUMAFF=""
   FOK=0 : GPE = 1: Return
Endif

#--- Bug 81698
If [M:XAB1]STOMGTCOD=1 : GPE = 1: Return Endif

# Si la ligne est issue d'une allocation, on ne fait rien
If [M:XAB1]STOCOU<>0 : GPE = 1 : Return Endif

# Stock non connu et pas de quantité saisie
If [M:XAB1]QTYPCU=0
   Local Integer OK9
   Call OUINON('Desea borrar la linea?',OK9) From GESECRAN
   If OK9 = 2
    Local Char XPRE     :   XPRE = [M:PREP]PRHNUM(NOL)
    Local Integer XLIN  :   XLIN = [M:PREP]PRELIN(NOL)
    DEL_LIGNE = 2

    # Paso a siguiente registro
     Call RAZSTOSORW From STKSOR
     NOL+=1
     Gosub CHARGE_PRE_XAB1 From VXABP
     If FIN=1 Return Endif
     zonsui="QTYPCU"

      # Borro línea del vale de preparación
      Call DEL_LIGNE(XPRE,XLIN)

      # Actualizo línea del pedido de venta

      # Bloqueo el STD
      GPE = 1
      Return
   Else

     WOK=2
     # Génération d'une rupture ?
     Call OUINON(mess(451,196,1),WOK) From GESECRAN
     If WOK=1
        # On retourne en saisie de la quantité
        FOK=0 : zonsui="QTYPCU" : GPE = 1 : Return
     Else
        If NOW>=dim([M:SOW]WSTOSEQ)
           Call ERREUR(mess(352,199,1)) From GESECRAN
           WRET=2 : Goto AVANT_OK_SUITE
        Endif
        # Génération d'une rupture
        [M:SOW]WSTOSEQ(NOW)    = 1
        [M:SOW]WSTOCOU(NOW)    = 0
        [M:SOW]WQTYSTU(NOW)    = [M:XAB1]QTYORI-[M:XAB1]QTYTRT
        [M:SOW]WQTYSTUACT(NOW) = [M:SOW]WQTYSTU(NOW)
        [M:SOW]WALLSTU(NOW)    = 0
        [M:SOW]WALLSTUACT(NOW) = 0
        [M:SOW]NBLIG  += 1
        [M:XAB1]QTYTRT = [M:XAB1]QTYORI
        GPE = 1
        Return
     Endif
  Endif
Endif

#Raz GOUVSOR
# Alimentation de [M:ALP]
Gosub ALI_ALP From TRTPREP
[M:ALP]QTY = [M:XAB1]QTYSTU
# Détermination du stock à sortir (automatisme, saisie)
Raz WRET
Gosub RECH_STOCK From VXABP

$AVANT_OK_SUITE
#If GOUVSOR>=1
If WRET>0
   WNIVERR=""
   If WRETADC>=512 : WNIVERR+="1" : WRETADC-=512 : Endif : # Quantité
   If WRETADC>=256 : WNIVERR+="2" : WRETADC-=256 : Endif : # Emplacement
   If WRETADC>=128 : WNIVERR+="3" : WRETADC-=128 : Endif : # Dem analyse
   If WRETADC>= 64 : WNIVERR+="4" : WRETADC-= 64 : Endif : # Statut
   If WRETADC>= 32 : WNIVERR+="5" : WRETADC-= 32 : Endif : # Inventaire
   If WRETADC>= 16 : WNIVERR+="6" : WRETADC-= 16 : Endif : # Lot périmé
   If WRETADC>=  8 : WNIVERR+="7" : WRETADC-=  8 : Endif : # Sous-lot
   If WRETADC>=  4 : WNIVERR+="8" : WRETADC-=  4 : Endif : # Lot
   If WRETADC>=  2 : WNIVERR+="9" : WRETADC-=  2 : Endif : # Série
   If WRETADC =  1 : WNIVERR+="0" : WRETADC-=  1 : Endif : # Pas de stock
   If find("1",WNIVERR)
      GMESSAGE=mess(20,7750,1)
   Elsif find("9",WNIVERR)
      GMESSAGE=mess(4,7750,1)
   Elsif find("8",WNIVERR)
      GMESSAGE=mess(2,7750,1)
   Elsif find("7",WNIVERR)
      GMESSAGE=mess(3,7750,1)
   Elsif find("2",WNIVERR)
      GMESSAGE=mess(5,7750,1)
   Elsif find("3",WNIVERR)
      GMESSAGE=mess(19,7750,1)
   Elsif find("6",WNIVERR)
      GMESSAGE=mess(398,199,1)
   Elsif find("5",WNIVERR)
      GMESSAGE=mess(126,184,1)
   Elsif find("4",WNIVERR)
      GMESSAGE=mess(6,7750,1)
   Elsif find("0",WNIVERR)
      GMESSAGE=mess(21,7750,1)
   Else
      GMESSAGE=mess(12,7750,1)
   Endif
   GERR=1 : FOK=0 : zonsui="[M:XAB1]QTYPCU" : GPE = 1: Return
Endif


GPE = 1
Return




############################################################
Subprog DEL_LIGNE(VVAL,VLIN)
Value Char VVAL
Value Integer VLIN

If !clalev([F:X01]) : Local File STOPRED  [X01]  : Endif

Trbegin [X01]
  Read [X01]PRE0 = VVAL;VLIN
  If fstat = 0
    Delete [X01] Curr
  Endif
Commit

Close Local File [X01]

End

