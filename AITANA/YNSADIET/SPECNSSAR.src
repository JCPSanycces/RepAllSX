##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Después de modificar el campo 'Código grupo'
######################################################################################
Subprog AM_YCDGGRUPO(VALEUR)
Variable Char    VALEUR()
  If !clalev([F:YVG1]) Then : Local File YVISGRATRIB [F:YVG1] : Endif
  Filter [F:YVG1] Where CDGGRUPO = VALEUR
  Read [F:YVG1] First
  If !fstat Then
    [M:SAR1]YDESGRUPO = [F:YVG1]DESGRUPO
    Affzo [M:SAR1]YDESGRUPO
  Endif
  Filter [F:YVG1]
  If  clalev([F:YVG1]) Then : Close Local File       [F:YVG1] : Endif

  [M:SAR1]FLG = 0

End

######################################################################################
## Después de modificar el campo 'Código atributo'
######################################################################################
Subprog AM_YCDGATRIBUTO(VALEUR)
Variable Char    VALEUR()
  If !clalev([F:YVA1]) Then : Local File YVISATRIBUTO [F:YVA1] : Endif
  Filter [F:YVA1] Where CDGGRUPO = [M:SAR1]YCDGGRUPO and CDGATRIBUTO = VALEUR
  Read [F:YVA1] First
  If !fstat Then
    [M:SAR1]YDESATRIBUTO = [F:YVA1]DESATRIBUTO
    Affzo [M:SAR1]YDESATRIBUTO
  Endif
  Filter [F:YVA1]
  If  clalev([F:YVA1]) Then : Close Local File        [F:YVA1] : Endif

  [M:SAR1]FLG = 0

End

######################################################################################
## Después de modificar el campo 'Fam. est. 1 inicial'
######################################################################################
Subprog AM_YTSICODSTR1(VALEUR)
Variable Char    VALEUR()
  [M:SAR1]YTSICODEND1 = VALEUR
  Affzo [M:SAR1]YTSICODEND1
  [M:SAR1]TSICODSTR(0) = VALEUR
  Affzo [M:SAR1]TSICODSTR(0)
  [M:SAR1]TSICODEND(0) = VALEUR
  Affzo [M:SAR1]TSICODEND(0)

  [M:SAR1]FLG = 0

End

######################################################################################
## Después de modificar el campo 'Fam. est. 1 final'
######################################################################################
Subprog AM_YTSICODEND1(VALEUR)
Variable Char    VALEUR()
  [M:SAR1]TSICODEND(0) = VALEUR
  Affzo [M:SAR1]TSICODEND(0)

  [M:SAR1]FLG = 0

End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla CONSSAR1) 18/05/2020 18:06:26 (AIT51)
######################################################################################
Subprog AM_TSICODSTR(VALEUR)
Variable Char    VALEUR()
#  [M:CSAR]TSICODSTR = [M:SAR1]TSICODSTR
  [M]FLG = 0
  [M:SAR1]TSICODEND(0) = VALEUR
  Affzo [M:SAR1]TSICODEND(0)
End

Subprog AM_TSICODEND(VALEUR)
Variable Char    VALEUR()
[M]FLG = 0
End

