# YN07 - Dar operativa a la parrilla de producción
# Fecha inicio YN07: 08/10/2019
# Desarrollador: JCH
# Código de desarrollo: YYN02
# Descripción del desarrollo: Modifica el campo 'Estado' en la pantalla de producción en función de la información que venga de la parrilla de producción
# Fecha: 08/10/2019
# Codigo Actividad: YYN02
#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "APRES_MODIF"  : Gosub APRES_MODIF
  When "FIN"          : Gosub FIN
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
  Gosub ABRIR_TABLAS
Return

##############################################################
$APRES_MODIF
  Gosub ESTADO_PARRILLA
Return

##############################################################
$FIN
  Gosub CERRAR_TABLAS
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ABRIR_TABLAS
  If !clalev([F:YMP0]) Then : Local File YMFGHEADPP   [F:YMP0] : Endif
  If !clalev([F:YDP0]) Then : Local File YMFGDUPLIPP  [F:YDP0] : Endif
Return

##############################################################
$CERRAR_TABLAS
  If clalev([F:YMP0])  Then : Close Local File        [F:YMP0] : Endif
  If clalev([F:YDP0])  Then : Close Local File        [F:YDP0] : Endif
Return

##############################################################
$ESTADO_PARRILLA
Local Integer LCON0

  If !clalev([F:ITM0]) Then : Local File ITMMASTER [F:ITM0] : Endif

  For LCON = 0 To [M:MTK1]NBOPE-1
    If [M:MTK2]STA(LCON0) <> "" Then
      Filter [F:YMP0] Where MFGNUM = [M:MTK0]MFGNUM and ITMREF = [M:MTK2]ITMREF(LCON0)
      Read   [F:YMP0] First
      If !fstat Then
        If [F:YMP0]TCLCOD <> "YNPI" Then
          If [F:YMP0]ESTADO <> "" Then
            [M:MTK2]STA(LCON0) = [F:YMP0]ESTADO
            Affzo [M:MTK2]STA(LCON0)
            Grizo [M:MTK2]STA(LCON0)
          Else
            [M:MTK2]STA(LCON0) = "Q"
            Affzo [M:MTK2]STA(LCON0)
            Grizo [M:MTK2]STA(LCON0)
          Endif
        Else
          [M:MTK2]STA(LCON0) = "A1"
          Affzo [M:MTK2]STA(LCON0)
          Grizo [M:MTK2]STA(LCON0)
        Endif
      Else
        Read [F:ITM0]ITM0 = [M:MTK2]ITMREF(LCON0)
        If !fstat Then
          If [F:ITM0]TCLCOD = "YNPI" Then
            [M:MTK2]STA(LCON0) = "A1"
            Affzo [M:MTK2]STA(LCON0)
            Grizo [M:MTK2]STA(LCON0)
          Else
            [M:MTK2]STA(LCON0) = "Q"
            Affzo [M:MTK2]STA(LCON0)
            Grizo [M:MTK2]STA(LCON0)
          Endif
        Endif
      Endif
      Filter [F:YMP0]
    Endif
  Next
Return

