Close Local File [X1],[X2],[X4]
End

#####################################################
Subprog VALIDA_SDH()
If !clalev([X1]) : Local File SDELIVERYD  [X1] : Endif
If !clalev([X2]) : Local File SDELIVERY   [X2] : Endif

Local Integer CONT

  Filter [X2] Where [X2]YCONTROL = 2
  For [X2]
    Trbegin [X2]
    [X2]CFMFLG    = 2
    [X2]YCONTROL  = 0
    Rewrite [X2]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif

    Filter [X1] Where SDHNUM = [X2]SDHNUM
    For [X1]
      Trbegin [X1]
      [X1]LINCFMFLG = 2
      Rewrite [X1]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Next
    Filter [X1]
  Next
Close Local File [X1],[X2]
End
