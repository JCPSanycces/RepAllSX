# Actualizar impuestos en SDD
#Call ACTUALIZA_SDD()

# localiza entregas con la base de cabecera diferente en más de 5€ con respecto a la suma de las líneas
Call LOCALIZA_SDH_BASES_MAL()

# desvalida albaranes con descuadre
#Call DESVALIDA_SDH_DESCUADREBI()

# desvalida albaranes para corregir problemas con artículos VIP
#Call DESVALIDA_SDH_VIP()

# valida albaranes
#Call VALIDA_SDH()
End


#####################################################
Subprog ACTUALIZA_SDD()
If !clalev([X1]) : Local File SDELIVERYD [X1] : Endif
If !clalev([X2]) : Local File ITMMASTER  [X2] : Endif
If !clalev([X3]) : Local File TABVAC     [X3] : Endif
If !clalev([X4]) : Local File SDELIVERY  [X4] : Endif

Local Integer CONT
For [X1] Where left$([X1]BPCORD,2) = "VC" and left$([X1]BPCORD,1) = "V" and [X1]SHIDAT=gdat$(17,02,2021) and [X1]VACITM <> ' '
  Read [X2]ITM0 = [X1]ITMREF
  If fstat = 0 and [X1]VACITM <> [X2]VACITM
    Read [X4]SDH0 = [X1]SDHNUM
    If fstat = 0
      Filter [X3] Where [X3]VACBPR = [X4]VACBPR and [X3]VACITM = [X1]VACITM
      Read [X3] First
      If fstat = 0
        Trbegin [X1]
          [X1]VACITM = [X2]VACITM
          [X1]VAT    = [X3]VAT
          Rewrite [X1]
          CONT+=1
        Commit
      Endif
    Endif
  Endif
Next
Infbox num$(CONT)
Close Local File [X1],[X2],[X3],[X4]
End

#####################################################
Subprog LOCALIZA_SDH_BASES_MAL()
Local Decimal IMPORTE_CAB, IMPORTE_LINS

If !clalev([F:YSDH]) Then : Local File SDELIVERY  [F:YSDH] : Endif
If !clalev([F:YSDD]) Then : Local File SDELIVERYD [F:YSDD] : Endif
If !clalev([F:YTMD]) Then : Local File YTMPDATOS  [F:YTMD] : Endif

Execsql From "5"  Sql "truncate table " + nomap + ".YTMPDATOS"

#Filter [F:YSDH] Where SDHTYP = "TPV" and CFMFLG <> 2 and SALFCY <> "V03" and SALFCY <> "V08" and SALFCY <> "V25" and SALFCY <> "V26"
#Filter [F:YSDH] Where SDHTYP = "TPV" and CFMFLG <> 2 and (SALFCY = "V03" or SALFCY = "V08" or SALFCY = "V25" or SALFCY = "V26")
Filter [F:YSDH] Where SDHTYP = "TPV"
For [F:YSDH]
  Raz IMPORTE_CAB
  IMPORTE_CAB = [F:YSDH]DLVNOT
  Raz IMPORTE_LINS
  Filter [F:YSDD] Where SDHNUM = [F:YSDH]SDHNUM
  For [F:YSDD]
    IMPORTE_LINS += ([F:YSDD]QTY * [F:YSDD]GROPRI) - (([F:YSDD]QTY * [F:YSDD]GROPRI * [F:YSDD]DISCRGVAL1) / 100)
  Next
  Filter [F:YSDD]
  If abs(IMPORTE_CAB - IMPORTE_LINS) > 5 Then
    Trbegin [F:YTMD]
    [F:YTMD]SDHNUM      = [F:YSDH]SDHNUM
    [F:YTMD]DIFERENCIA  = abs(IMPORTE_CAB - IMPORTE_LINS)
    Write [F:YTMD]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
#    Break
  Endif
Next
Filter [F:YSDH]

Call MESSAGE("Fin del proceso") From GESECRAN

Close Local File [YSDH],[YSDD],[YTMD]

End

#####################################################
Subprog DESVALIDA_SDH_DESCUADREBI()
If !clalev([X1]) : Local File SDELIVERYD  [X1] : Endif
If !clalev([X2]) : Local File SDELIVERY   [X2] : Endif
If !clalev([X4]) : Local File YTMPDATOS   [X4] : Endif

Local Integer CONT

For [X4]
  Read [X2]SDH0 = [X4]SDHNUM
  If !fstat Then
    If [X2]CFMFLG = 2
      Trbegin [X2]
      [X2]CFMFLG    = 0
      [X2]YCONTROL  = 2
      Rewrite [X2]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif

      Filter [X1] Where SDHNUM = [X2]SDHNUM
      For [X1]
        Trbegin [X1]
        [X1]LINCFMFLG = 0
        Rewrite [X1]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
      Next
      Filter [X1]
    Endif
#    CONT+=1
  Endif
Next
#Infbox num$(CONT)
Close Local File [X1],[X2],[X4]
End

#####################################################
Subprog DESVALIDA_SDH_VIP()
