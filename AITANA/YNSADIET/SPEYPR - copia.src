######################################################################################
## Antes de entrada "Tipo artículo"
######################################################################################
Subprog AS_LOTMGTCOD(VALEUR)
Variable Integer VALEUR
  Raz GMENLOC
  GMENLOC(2) = 1
  GMENLOC(4) = 1
End

######################################################################################
## Antes de entrada "NBLIG" para que coloree las líneas
######################################################################################
#Subprog AS_NBLIG
##  Gosub PINTA_LINEAS_APTO
#End

######################################################################################
## Control "Apto"
######################################################################################
Subprog C_STAL(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    [M:YPR0]STNAL(nolign-1) = 1
    Affzo [M:YPR0]STNAL(nolign-1)
  Endif
End

######################################################################################
## Control "No Apto"
######################################################################################
Subprog C_STNAL(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    [M:YPR0]STAL(nolign-1) = 1
    Affzo [M:YPR0]STAL(nolign-1)
  Endif
End


