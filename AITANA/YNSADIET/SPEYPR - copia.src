#######################################################################################

$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "DEBUT"        : Gosub DEBUT
  When "BOUTON"       : Gosub BOUTON
  When "SETBOUT"      : Gosub SETBOUT
  When "AV_CHOIX"     : Gosub AV_CHOIX
  When "FIN"          : Gosub FIN
  When "SEL_TABLE"    : Gosub SEL_TABLE
  When "VERF_TABLE"   : Gosub VERF_TABLE
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$SEL_TABLE
  Case TABLE
    When "YSELSTKPR"   : Gosub SEL_YSELSTKPR
  Endcase
Return

##############################################################
$VERF_TABLE
  Case TABLE
    When "YSELSTKPR"   : Gosub VERF_YSELSTKPR
  Endcase
Return

##############################################################
$OUVRE
  Gosub ABRIR_TABLAS
Return

##############################################################
$DEBUT
#  [M:YPR0]STRDAT = date$
  [M:YPR0]STRDAT = [01/08/2019]
  [M:YPR0]ENDDAT = date$
  Affzo [M:YPR0]5,10,15
Return

##############################################################
$BOUTON
  Case BOUT
    When "b"  : Gosub BUSCAR
  Endcase
Return

##############################################################
$SETBOUT
#  Gosub PINTA_LINEAS_APTO
Return

##############################################################
$AV_CHOIX
Return

##############################################################
$FIN
  Gosub CERRAR_TABLAS
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ABRIR_TABLAS
  If !clalev([F:TST0]) Then : Local File TABSTASTO [F:TST0] : Endif
  If !clalev([F:AXX0]) Then : Local File ATEXTRA   [F:AXX0] : Endif
  If !clalev([F:STJ0]) Then : Local File STOJOU     [F:STJ0] : Endif
  If !clalev([F:ITF0]) Then : Local File ITMFACILIT [F:ITF0] : Endif
Return

##############################################################
$CERRAR_TABLAS
  If clalev([F:ITF0])  Then : Close Local File      [F:ITF0] : Endif
Return

##############################################################
$SEL_YSELSTKPR
  Link [AXX0] With [TST0]TST0=[F:AXX0]IDENT1 As [LNK0] Where CODFIC="TABSTASTO" and ZONE = "STAAXX" and LANGUE=GLANGUE
  Columns [LNK0] ([TST0]STASTO,[AXX0]TEXTE)
  Default File [LNK0]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Estados"                                                       # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "[TST0]STASTO"                                                  # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la segunda columna
  COL(NBCOL)  = "[AXX0]TEXTE"                                                   # nombre del campo a mostrar en la segunda columna
Return

##############################################################
$VERF_YSELSTKPR
Return

##############################################################
$BUSCAR
Local Char CRITSQL(255)(0..5) : Raz CRITSQL
Local Char LWHERE(255) : Raz LWHERE
Local Integer LCON0 : Raz LCON0

  Effzo [M:YPR0]20

  LWHERE = "STOJOU.VCRTYP_0=6"
  If [M:YPR0]STRDAT <> [00/00/0000] Then : LWHERE += " and PRECEIPTD.RCPDAT_0>='"   +[M:YPR0]STRDAT+"'"       : Endif
  If [M:YPR0]ENDDAT <> [00/00/0000] Then : LWHERE += " and PRECEIPTD.RCPDAT_0<='"   +[M:YPR0]ENDDAT+"'"       : Endif
  If [M:YPR0]LOTMGTCOD <> 0         Then : LWHERE += " and ITMMASTER.LOTMGTCOD_0="  +num$([M:YPR0]LOTMGTCOD)  : Endif
  If [M:YPR0]STRBPS <> ""           Then : LWHERE += " and PRECEIPTD.BPSNUM_0>='"   +[M:YPR0]STRBPS+"'"       : Endif
  If [M:YPR0]ENDBPS <> ""           Then : LWHERE += " and PRECEIPTD.BPSNUM_0<='"   +[M:YPR0]ENDBPS+"'"       : Endif
  If [M:YPR0]ITMREF <> ""           Then : LWHERE += " and PRECEIPTD.ITMREF_0='"    +[M:YPR0]ITMREF+"'"       : Endif
#  If [M:YPR0]STOFCY <> ""           Then : LWHERE += " and STOJOU.STOFCY_0='"       +[M:YPR0]STOFCY+"'"       : Endif
#  If [M:YPR0]LOT <> ""              Then : LWHERE += " and STOJOU.LOT_0='"          +[M:YPR0]LOT+"'"          : Endif
#  If [M:YPR0]STA <> ""              Then : LWHERE += " and STOJOU.LOT_0='"          +[M:YPR0]LOT+"'"          : Endif
#  If [M:YPR0]STOFCY <> ""           Then : LWHERE += " and STOQLYD.STOFCY_0='"      +[M:YPR0]STOFCY+"'"       : Endif
#  If [M:YPR0]LOT <> ""              Then : LWHERE += " and STOQLYD.LOT_0='"         +[M:YPR0]LOT+"'"          : Endif
#  If [M:YPR0]STA <> ""              Then : LWHERE += " and STOQLYD.STA_0='"         +[M:YPR0]STA+"'"          : Endif
  If [M:YPR0]STOFCY <> ""           Then : LWHERE += " and STOJOU.STOFCY_0='"       +[M:YPR0]STOFCY+"'"       : Endif
  If [M:YPR0]LOT <> ""              Then : LWHERE += " and STOJOU.LOT_0='"          +[M:YPR0]LOT+"'"          : Endif
  If [M:YPR0]STA <> ""              Then : LWHERE += " and STOCK.STA_0='"           +[M:YPR0]STA+"'"          : Endif

##  CRITSQL(0) =  "SELECT "+nomap+".STOJOU.LOT_0,"+nomap+".STOJOU.ITMREF_0,"+nomap+".PRECEIPTD.BPSNUM_0,"+nomap+".PRECEIPTD.RCPDAT_0,"
##  CRITSQL(0) += nomap+".PRECEIPTD.PTHNUM_0,"+nomap+".PRECEIPTD.QTYUOM_0,"+nomap+".STOJOU.QLYCTLDEM_0 "
##  CRITSQL(1) =  "FROM "+nomap+".PRECEIPTD INNER JOIN "+nomap+".ITMMASTER ON "+nomap+".PRECEIPTD.ITMREF_0 = "+nomap
##  CRITSQL(1) += ".ITMMASTER.ITMREF_0 INNER JOIN "+nomap+".STOJOU ON "+nomap+".ITMMASTER.ITMREF_0 = "+nomap
##  CRITSQL(1) += ".STOJOU.ITMREF_0 and "+nomap+".PRECEIPTD.PTHNUM_0 = "+nomap+".STOJOU.VCRNUM_0 "
##  CRITSQL(2) =  "WHERE "+LWHERE
#  CRITSQL(0)  = "SELECT STOQLYD.LOT_0,STOQLYD.ITMREF_0,PRECEIPTD.BPSNUM_0,PRECEIPTD.RCPDAT_0,PRECEIPTD.PTHNUM_0,PRECEIPTD.QTYUOM_0,STOQLYH.VCRNUM_0,STOQLYD.STA_0 "
#  CRITSQL(1)  = "FROM "+nomap+".PRECEIPTD INNER JOIN "+nomap+".ITMMASTER ON "+nomap+".PRECEIPTD.ITMREF_0="+nomap+".ITMMASTER.ITMREF_0 INNER JOIN "+nomap
#  CRITSQL(1) += ".STOQLYH ON "+nomap+".PRECEIPTD.PTHNUM_0="+nomap+".STOQLYH.VCRNUMORI_0 INNER JOIN "+nomap+".STOQLYD ON "+nomap+".STOQLYH.VCRNUM_0="
#  CRITSQL(2)  = nomap+".STOQLYD.VCRNUM_0 AND "+nomap+".PRECEIPTD.ITMREF_0="+nomap+".STOQLYD.ITMREF_0 AND "+nomap+".PRECEIPTD.QTYUOM_0="+nomap+".STOQLYD.QTYPCU_0 "
#  CRITSQL(3)  = "WHERE "+LWHERE
  CRITSQL(0)  = "SELECT STOJOU.LOT_0,PRECEIPTD.ITMREF_0,PRECEIPTD.BPSNUM_0,PRECEIPTD.RCPDAT_0,PRECEIPTD.PTHNUM_0,PRECEIPTD.QTYUOM_0,STOJOU.QLYCTLDEM_0,STOCK.STA_0,"
  CRITSQL(0) += "STOJOU.SHLDAT_0,TEXCLOB.TEXTE_0,PRECEIPTD.POHFCY_0,PRECEIPTD.ITMDES_0,STOJOU.LOC_0 "
  CRITSQL(1)  = "FROM "+nomap+".PRECEIPTD INNER JOIN "+nomap+".STOJOU ON "+nomap+".PRECEIPTD.PTHNUM_0="+nomap+".STOJOU.VCRNUM_0 AND "+nomap
  CRITSQL(1) += ".PRECEIPTD.PTDLIN_0="+nomap+".STOJOU.VCRLIN_0 "
  CRITSQL(2)  = "AND "+nomap+".PRECEIPTD.ITMREF_0="+nomap+".STOJOU.ITMREF_0 AND "+nomap+".PRECEIPTD.POHFCY_0="+nomap+".STOJOU.STOFCY_0 "
  CRITSQL(2) += "INNER JOIN "+nomap+".ITMMASTER ON "+nomap+".PRECEIPTD.ITMREF_0="+nomap+".ITMMASTER.ITMREF_0 "
  CRITSQL(3)  = "INNER JOIN "+nomap+".STOCK ON "+nomap+".STOJOU.ITMREF_0="+nomap+".STOCK.ITMREF_0 AND "+nomap+".STOJOU.STOFCY_0="+nomap+".STOCK.STOFCY_0 AND "+nomap+".STOJOU.LOT_0="
  CRITSQL(3) += nomap+".STOCK.LOT_0 "
  CRITSQL(4)  = "LEFT OUTER JOIN "+nomap+".TEXCLOB ON "+nomap+".PRECEIPTD.LINTEX_0="+nomap+".TEXCLOB.CODE_0 "
  CRITSQL(5)  = "WHERE " + LWHERE

#  For (Char LOT, Char ITMREF, Char BPSNUM, Date RCPDAT, Char PTHNUM, Decimal QTYUOM, Char QLYCTLDEM) From "5" Sql CRITSQL(0..2) As [Y00]
  For (Char LOT,Char ITMREF,Char BPSNUM,Date RCPDAT,Char PTHNUM,Decimal QTYUOM,Char QLYCTLDEM,Char STA,Date SHLDAT,Char TEXTE,Char POHFCY,
& Char ITMDES, Char LOC) From "5" Sql CRITSQL(0..5) As [Y00]
    If [F:Y00]STA = "A" Then
      [M:YPR0]STAL(LCON0) = 2
      Grizo [M:YPR0]STAL(LCON0), STNAL(LCON0)
    Elsif [F:Y00]STA = "R"
      [M:YPR0]STNAL(LCON0) = 2
      Grizo [M:YPR0]STAL(LCON0), STNAL(LCON0)
    Else
      [M:YPR0]STNAL(LCON0) = 1
      Actzo [M:YPR0]STAL(LCON0), STNAL(LCON0)
    Endif
    [M:YPR0]LOTEL(LCON0)      = [F:Y00]LOT
    [M:YPR0]ITMREFL(LCON0)    = [F:Y00]ITMREF
    [M:YPR0]BPSNUM(LCON0)     = [F:Y00]BPSNUM
    [M:YPR0]ENTDAT(LCON0)     = [F:Y00]RCPDAT
    [M:YPR0]DOCUMENTO(LCON0)  = "Albarán Compras: " + [F:Y00]PTHNUM
    [M:YPR0]QTY(LCON0)        = [F:Y00]QTYUOM
#    [M:YPR0]CDGSOL(LCON0)     = [F:Y00]QLYCTLDEM
    [M:YPR0]CDGSOL(LCON0)     = [F:Y00]QLYCTLDEM
    [M:YPR0]ESTADO(LCON0)     = [F:Y00]STA
    [M:YPR0]SHLDAT(LCON0)     = [F:Y00]SHLDAT
    [M:YPR0]OBSRECEP(LCON0)   = [F:Y00]TEXTE
    [M:YPR0]POHFCY(LCON0)     = [F:Y00]POHFCY
    [M:YPR0]ITMDESL(LCON0)    = [F:Y00]ITMDES
    [M:YPR0]LOCL(LCON0)       = [F:Y00]LOC
    LCON0                     += 1
  Next

  [M:YPR0]NBLIG = LCON0
  Affzo [M:YPR0]20
Return

##############################################################
$BUSCA_WSTJQTY
Local Integer LCON2 : Raz LCON2

  For LCON2 = 0 To [M:YPR0]NBLIG-1
    Filter [F:STJ0] Where ITMREF = [M:YPR0]ITMREFL(LCON2) and LOT = [M:YPR0]LOTEL(LCON2) and STOFCY = [M:YPR0]POHFCY(LCON2)
    Read [F:STJ0] First
    If !fstat Then
      [M:YPR0]WSTJQTY(LCON2)  = [F:STJ0]QTYPCU
      [M:YPR0]PCU(LCON2)      = [F:STJ0]PCU
    Endif
    Filter [F:STJ0]
  Next

Return

##############################################################
$BUSCA_QLYCRD
Local Integer LCON3 : Raz LCON3

  For LCON3 = 0 To [M:YPR0]NBLIG-1
    Read [F:ITF0]ITF0 = [M:YPR0]ITMREFL;POHFCY
    If !fstat Then
      [M:YPR0]QLYCRD(LCON3) = [F:ITF0]QLYCRD
    Endif
  Next

Return

##############################################################
$PINTA_LINEAS_APTO
Local Integer LCON1 : Raz LCON1

  For LCON1 = 0 To [M:YPR0]NBLIG
    If [M:YPR0]STAL(LCON1) = 2 Then
      Chgstl [M:YPR0]NBLIG(LCON1) With "BACKRED"
    Else
      Chgstl [M:YPR0]NBLIG(LCON1) With ""
    Endif
  Next

Return

##############################################################
$IMPORT_YSMO
Return

##############################################################
$IMPORT_YSMR
Return

