#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
  When "APRES_MOD"    :   Gosub APRES_MOD
Endcase
Return

############################################
$APRES_MOD
# Actualizo el valor del campo Orden
If GFONCTION = "GESPRH"
Local Integer I
  For I=0 To [M:PRH1]NBLIG-1
    Read [PRE]PRE0 = [M:PRH0]PRHNUM;[M:PRH1]PRELIN(I)
    If fstat = 0
      If [M:PRH1]YORDEN(I) = 0
        [PRE]YORDEN = I + 1
      Else
        [PRE]YORDEN = [M:PRH1]YORDEN(I)
      Endif
    Endif
    Rewrite [PRE]
  Next
Endif
Return

