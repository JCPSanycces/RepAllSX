Subprog AM_XYPLAZOENTRE(VALEUR)
Variable Decimal VALEUR
[M:ITP]YPLAZOENTRE([M]XNUMLIG) = VALEUR
[M:ITP]UPDDAT    ([M]XNUMLIG)  = date$                #hcb 030505 29658
[M:ITP]UPDUSR    ([M]XNUMLIG)  = GUSER                #hcb 030505 29658
[M:ITP]FLMOD([M:ITP]XNUMLIG)   = 1         # FGR 03/02/2011 : X3SUIVI70453
End


