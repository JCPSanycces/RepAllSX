#<AdxTL>@(#)0.0.0.0 $Revision$ 

$ACTION
  Case ACTION
    When "OUVRE"    : Gosub OUVRE
    When "CREATION" : Gosub CREATION
    When "LIENS"    : Gosub LIENS
    When "MODIF"    : Gosub MODIF
    When "ANNULE"   : Gosub ANNULE
  Endcase
Return

#------------------------------------------------------------------------------#

$OUVRE
  If clalev([F:YBPDF])=0 : Local File YBPRPDF   [YBPDF] : Endif
  If clalev([F:YSPDF])=0 : Local File YSETUPPDF [YSPDF] : Endif
Return

#------------------------------------------------------------------------------#

$CREATION
  Gosub CRE_YBPDF
  If GOK<1 : GPE = 1 : Endif
Return

#-----------------------------------------------------------------------------#

$LIENS
  Gosub LOAD_YPDFS
Return

#-----------------------------------------------------------------------------#

$MODIF
  Gosub DEL_YBPDF
  If GOK : Gosub CRE_YBPDF : :Endif
  If GOK<1 : GPE = 1 : Endif
Return

#-----------------------------------------------------------------------------#

$ANNULE
  Gosub DEL_YBPDF
  If GOK<1 : GPE = 1 : Endif
Return

#-----------------------------------------------------------------------------#

$LOAD_YPDFS
  nolign = 0
  For [F:YBPDF]YBPDF0 Where BPRTYP=2 and BPRNUM=[M:BPS0]BPSNUM
    If nolign>=dim([M:YPDFS]CODE)
      Call ERREUR(mess(26,100,1)) From GESECRAN : Break
    Endif

    nolign += 1
    [M:YPDFS] = [F:YBPDF]
    [M:YPDFS]MAILCC1(nolign-1) = [F:YBPDF]MAILCC(0)
    [M:YPDFS]MAILCC2(nolign-1) = [F:YBPDF]MAILCC(1)
    [M:YPDFS]MAILCC3(nolign-1) = [F:YBPDF]MAILCC(2)
    [M:YPDFS]MAILCC4(nolign-1) = [F:YBPDF]MAILCC(3)
    [M:YPDFS]MAILCC5(nolign-1) = [F:YBPDF]MAILCC(4)
  Next
  [M:YPDFS]NBLIG = nolign
  Affzo [M:YPDFS]
Return

#-----------------------------------------------------------------------------#

$CRE_YBPDF
  For nolign=1 To [M:YPDFS]NBLIG
    [F:YBPDF] = [M:YPDFS]
    [F:YBPDF]BPRTYP = 2
    [F:YBPDF]BPRNUM = [M:BPS0]BPSNUM
    [F:YBPDF]MAILCC(0) = [M:YPDFS]MAILCC1(nolign-1)
    [F:YBPDF]MAILCC(1) = [M:YPDFS]MAILCC2(nolign-1)
    [F:YBPDF]MAILCC(2) = [M:YPDFS]MAILCC3(nolign-1)
    [F:YBPDF]MAILCC(3) = [M:YPDFS]MAILCC4(nolign-1)
    [F:YBPDF]MAILCC(4) = [M:YPDFS]MAILCC5(nolign-1)
    Write [F:YBPDF]
    If fstat
      GOK = 0 : Call FSTA("YBPDF") From GLOCK : Break
    Endif
  Next nolign
Return

#-----------------------------------------------------------------------------#

$DEL_YBPDF
  Delete [F:YBPDF] Where BPRTYP=2 and BPRNUM=[M:BPS0]BPSNUM
  If fstat=1
    GOK = -1
    GLOCK = "$YBPRPDF" - [M:BPS0]BPSNUM
  Endif
Return

#-----------------------------------------------------------------------------#







