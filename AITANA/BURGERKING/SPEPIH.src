$ACTION
Case ACTION
 When "PICKE"     : Gosub PICKE        From YSPEPIH
 When "SETBOUT"   : Gosub SETBOUT      From YSPEPIH
 When "LIENS"     : Gosub LIENS        From YSPEPIH
 When "VERIF_CRE"  : Gosub VERIF_CRE   From YSPEPIH
 When Default
Endcase
Return

Subprog AS_NBLIG
#Call AS_NBLIG From YSPEPIH
End


