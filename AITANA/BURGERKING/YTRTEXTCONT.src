#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# YTRTEXTCONT : Extracción de asientos para integración en dossier de consolidación
#               Código de actividad Y002
######################################################################################
ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "DEBUT"      : Gosub DEBUT
 When "EXEC"       : Gosub EXEC
 When "CONTROLE"   : Gosub CONTROLE
 When "END"        : Gosub FIN
 When "TERMINE"    : Gosub TERMINE
 When "SORTIE"     : Gosub SORTIE
 When Default
Endcase
Return
######################################################################################
$INIT
If GSERVEUR
    Onerrgo ERRBATCH
Endif
Gosub OUVRE

Local Mask YTRTEXTCONT [DIA]

Raz [M:DIA]

SYMBOLE ="YTRTEXTCONT"
Lock =SYMBOLE
If fstat <> 0
  Call ERREUR("Ya existe un proceso en curso") From GESECRAN
  GOK=0 :FIN=1
Endif

Return
#####################################################################
$DEBUT

Affzo [DIA]1-99

Return
######################################################################
$OUVRE
Local Char     TIT(50)

TIT = "Extracción asientos contables para integración en dossier consolidación"

Local Char SAVIFS(10), SAVIRS(10)

Local Char WDIR  : WDIR = "IMP\YGASCONS"
Local Char WFIC  : WFIC = GUSER+"-"
Local Char WEXT  : WEXT = "txt"

Local Char SYMBOLE(50)


# Tablas a utilizar
If clalev( [F:YGAC] )  = 0 : Local File GACCOUNT    [YGAC]  : Endif

If clalev( [F:YHAE] )  = 0 : Local File GACCENTRY   [YHAE]  : Endif
If clalev( [F:YDAE] )  = 0 : Local File GACCENTRYD  [YDAE]  : Endif


Return
######################################################################################
$EXEC

#Traza
If !GSERVEUR
  Call OUVRE_TRACE(TIT) From LECFIC
  Call ECR_TRACE(" ",0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call PRTSCR("YTRTEXTCONT","DIA","",0,1) From ATRTX3
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(" ",0) From GESECRAN
Endif
If GSERVEUR
  Call ECR_TRACE(" ",0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(TIT + " " + date$ + " " + time$,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(" ",0) From GESECRAN
Endif

Call DEBTRANS From GLOCK

Gosub TRATAMIENTO

Return
#########################################################################
$TRATAMIENTO
#Declaración de variables

Local Integer WCONTADOR
Local Char CRITERE(250)

#Inicialización de variables
Raz WCONTADOR
CRITERE = "1=1"

#Sociedad
If [M:DIA]CPY <>""
 CRITERE -= '& [F:YHAE]CPY="'+[M:DIA]CPY+'"'
Endif

#número de asiento

If [M:DIA]NUMDEB <>""
 CRITERE -= '& [F:YHAE]NUM>="'+[M:DIA]NUMDEB+'"'
Endif
If [M:DIA]NUMFIN <>""
 CRITERE -= '& [F:YHAE]NUM<="'+[M:DIA]NUMFIN+'"'
Endif


#Fecha asiento

CRITERE -= '& [F:YHAE]ACCDAT>=[M:DIA]STRDAT'
CRITERE -= '& [F:YHAE]ACCDAT<=[M:DIA]ENDDAT'


#
Filter [YHAE] Where evalue(CRITERE)
For [YHAE]HAE0

  If WCONTADOR = 0
   Openo filpath(WDIR,WFIC,WEXT),0 Using [FI1]
  Endif

  WCONTADOR += 1
  Call ECR_TRACE("Asiento:  " + [F:YHAE]NUM,0) From GESECRAN

  Gosub GRABAR_CABECERA From YTRTEXTCONT1

  Filter [YDAE] Where [F:YDAE]NUM=[F:YHAE]NUM and [F:YDAE]LEDTYP=1
  For [YDAE]DAE0
    Gosub GRABAR_LINEA From YTRTEXTCONT1
  Next
  Filter [YDAE]

Next
Filter[YHAE] #Cancelar filtro

#
Call ECR_TRACE("Se han tratado " + format$("Nz:3",WCONTADOR) + " asientos ",0) From GESECRAN
#

If WCONTADOR >0
  Openo Using [FI1]
Endif

Return
#########################################################################
$CONTROLE

If GOK<1 FIN=1 Endif

Return
#########################################################################
$SORTIE

If clalev([M:DIA])>0 Close Mask [M:DIA] Endif

Return
#########################################################################
$TERMINE

If !GSERVEUR
# --> fermeture trace
    If WCONTADOR = 0
      Call ECR_TRACE("Ningún asiento a tratar",0) From GESECRAN
    Endif

    Call FERME_TRACE From LECFIC

# --> aucune commande ŕ traiter ou lecture trace
    If WCONTADOR = 0
       GERR=2 : GMESSAGE="Ningún asiento a tratar"
    Endif
    TRA=1
Endif

Return
#########################################################################
$FIN

GOK=0 :  FIN=1

SYMBOLE ="YTRTEXTCONT"
Unlock =SYMBOLE

Return
#####################################################################
$ERRBATCH
#####################################################################
Call ECR_TRACE(errmes$(errn)-num$(errl)-ERR,1) From GESECRAN

End
######################################################################################
Subprog AM_YBPSNUMDEB(VALEUR)
Variable Char    VALEUR()

[M:DIA]YBPSNUMFIN = VALEUR
Affzo [M:DIA]YBPSNUMFIN

End
######################################################################################
Subprog AM_YDEPTDEB(VALEUR)
Variable Char    VALEUR()

[M:DIA]YDEPTFIN = VALEUR
Affzo [M:DIA]YDEPTFIN

End
######################################################################################
Subprog AM_YCONNUMDEB(VALEUR)
Variable Char    VALEUR()

[M:DIA]YCONNUMFIN = VALEUR
Affzo [M:DIA]YCONNUMFIN

End


######################################################################################
Subprog C_YLIMDAT(VALEUR)
Variable Date    VALEUR

If VALEUR > date$
  GMESSAGE = "Error. Fecha superior a la actual"
  mkstat =2
Endif

End


######################################################################################

