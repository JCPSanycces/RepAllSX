#<AdxTL>@(#)0.0.0.0 $Revision$ 
#29/07/20 control grabar
#Control de error en fichero log.
#Fecha: 09/01/2020
#Prog: ALIVE
#Marca: <ALI02>
#
#Y013   Grabar fichero de traza ZEXPFIC
#
################################################################################################################
Subprog EXPORT_CONCILIACION()
  Global Char EXISTEN_REGISTROS
  Local Char ZDATETIME(14)
  Local Char ZMKIFIT(200)  #ZMKIFIT = ZPATH+"MKI_"+[M:ZCMT]MFGNUM+"_"+ZDATETIME+".txt"
  Local Char ZMKSFIT(200)
  Local Char NOMBRE_FICHERO_TIM
  Local Char NOMBRE_FICHERO_BKS
  #Y013
  Global Integer YCONTADOR : Raz YCONTADOR
  #Y013


  ZDATETIME = time$
  ZDATETIME = mid$(ZDATETIME,1,2)+mid$(ZDATETIME,4,2)+mid$(ZDATETIME,7,2)
  ZDATETIME = date$+ZDATETIME
  # Call OUVRE_TRACE ("Envio fichero conciliación XRT") From LECFIC

  #
  # Si ha habido algún error de comunicación o algún corte en la tarea, se quedan asientos marcados como enviados
  # pero realmente no se han enviado.
  # Se puede lanzar una vista, para ver los que están marcados, pero no existen en la tabla de enviados
  # Todos los registros que estén en esta vista, habrá que volverlos a marcar para reenvialos.
  # Habría que actualizar los registros en la GACCENTRY, GACCENTRYD y GACCENTRYA
  #
  # Ańadimos código para que ejecute esta parte solo 4 veces al día, ya que parece que la vista de errores
  # carga la base de datos.
  # Se saca el proceso a la tarea ZCONCILPEN, que ejecuta el script ZCONCILPEN.
  #  Call REVISAR_VISTA_ERRORES()

#<ALI03>
  Local Integer WERROR_TAREA
  Gosub COMPROBAR_TAREA_EN_EJECUCION
  If WERROR_TAREA = 1
    End
  Endif
#Fin <ALI03>

  NOMBRE_FICHERO_TIM = "CONCIL_"+ZDATETIME+"_TIM"

#
  #Y013
  Raz YCONTADOR
  #Y013
  #29/07/20
  EXISTEN_REGISTROS = '0'
  #29/07/20
  Call GENERA_FICHERO_TIM("TIM", NOMBRE_FICHERO_TIM)

  If EXISTEN_REGISTROS = '1' Then
    Call ECR_TRACE ("Fichero TIM:" + NOMBRE_FICHERO_TIM,0)  From GESECRAN
    Call ENVIA_FICHERO(NOMBRE_FICHERO_TIM)
    #Y013
    Local Char NOMBRE_FICHERO : NOMBRE_FICHERO = NOMBRE_FICHERO_TIM
    Local Char SOCIEDAD       : SOCIEDAD       = 'TIM'
    Gosub GRABAR_ZEXPFIC
    #Y013
    EXISTEN_REGISTROS = '0'
  Endif

  NOMBRE_FICHERO_BKS = "CONCIL_"+ZDATETIME+"_BKS"
  #Y013
  Raz YCONTADOR
  #Y013
  #29/07/20
  EXISTEN_REGISTROS = '0'
  #29/07/20
  Call GENERA_FICHERO_BKS("BKS", NOMBRE_FICHERO_BKS)
  If EXISTEN_REGISTROS = '1' Then
    Call ECR_TRACE ("Fichero BKS:" + NOMBRE_FICHERO_BKS,0)  From GESECRAN
    Call ENVIA_FICHERO(NOMBRE_FICHERO_BKS)
    #Y013
    Local Char NOMBRE_FICHERO : NOMBRE_FICHERO = NOMBRE_FICHERO_BKS
    Local Char SOCIEDAD       : SOCIEDAD       = 'BKS'
    Gosub GRABAR_ZEXPFIC
    #Y013
    EXISTEN_REGISTROS = '0'
  Endif
  NOMBRE_FICHERO_POP = "CONCIL_"+ZDATETIME+"_POP"
  #Y013
  Raz YCONTADOR
  #Y013
  #29/07/20
  EXISTEN_REGISTROS = '0'
  #29/07/20
  Call GENERA_FICHERO_POP("POP", NOMBRE_FICHERO_POP)
  If EXISTEN_REGISTROS = '1' Then
    Call ECR_TRACE ("Fichero POP:" + NOMBRE_FICHERO_POP,0)  From GESECRAN
    Call ENVIA_FICHERO(NOMBRE_FICHERO_POP)
    #Y013
    Local Char NOMBRE_FICHERO : NOMBRE_FICHERO = NOMBRE_FICHERO_POP
    Local Char SOCIEDAD       : SOCIEDAD       = 'POP'
    Gosub GRABAR_ZEXPFIC
    #Y013
    EXISTEN_REGISTROS = '0'
  Endif
#
#  Call FERME_TRACE From LECFIC
#  Call LEC_TRACE() From LECFIC

End


#**
#* GENERACION FICHERO BKS
#*!
Subprog GENERA_FICHERO_BKS(PCPY, PNOMBRE_FICHERO)
  Local Char LCRITERIA(250)
  Local Char   LFECHA
  Local Char ZPATH(200)  #ZPATH = "E:\SAGE\X3MAFESA\folders\PROTO\IMPORT\OF\"
  Local Integer   CONTADOR
  Local Char LSENTIDO
  Local Char LTIPO
  Local Char YPAM(5)


  If clalev([ZCONB]) = 0 : Local File ZYCONCILBKS   [ZCONB]  : Endif

  If clalev([ZSEN]) = 0 : Local File ZCONCILSEND [ZSEN]  : Endif

  If !clalev([F:HAEAUX])  Then : Global File GACCENTRY [HAEAUX] : Endif
  If !clalev([F:HADAUX])  Then : Global File GACCENTRYD [HADAUX] : Endif
  If !clalev([F:HAAAUX])  Then : Global File GACCENTRYA [HAAAUX] : Endif
  If !clalev([F:YPYH])  Then : Local File PAYMENTH [YPYH] : Endif

 # Infbox "Dentro de export: " + PCPY
  LFECHA =  "30/04/2018"
  LCRITERIA = "CPY = PCPY "

  Call ECR_TRACE ("Generando fichero:" + PNOMBRE_FICHERO,0)  From GESECRAN
  CONTADOR = 1
  adxifs = ';' : adxirs = chr$(13)+chr$(10)

  LFICIMP = filpath("IMP",PNOMBRE_FICHERO,"csv")
  LFICIMP2 = filpath("IMP",PNOMBRE_FICHERO,"bak") # copia de los asientos enviados

  Filter [F:ZCONB]  # Where evalue(LCRITERIA)
  #Infbox num$(rowcount([F:ZCONB]))
  If (rowcount([F:ZCONB])) > 0 Then
  Call ECR_TRACE ("Registros encontrados en " + PCPY + ": " + num$(rowcount([F:ZCONB])),0)  From GESECRAN
  #29/07/20
  #  EXISTEN_REGISTROS = '1'
  #29/07/20

    # Si existen registros los vuelvo en una tabla temporal


    Openo LFICIMP Using [ZCONBCIL]

    Openo LFICIMP2 Using [ZCONBCI2]

    For [F:ZCONB]
         #BUSCO LA FORMA DE PAGO
         YPAM=''
         For [F:HAEAUX] Where NUM=[F:ZCONB]NUM
          For [F:YPYH] Where NUM=[F:HAEAUX]BPRVCR
            YPAM=[F:YPYH]PAM
          Next
         Next
         If YPAM='PAG'
          If [F:ZCONB]DUDAT>date$ #Si no ha llegado la fecha de vencimiento, no se trata
            Call ECR_TRACE("Pagaré aún no vencido:"-[F:ZCONB]NUM,0) From GESECRAN
            Goto SIG_PAG_BKS
          Endif
         Endif
         Call ECR_TRACE ("Asiento que voy a escribir en el fichero: " + [F:ZCONB]NUM + " - " + num$([F:ZCONB]LINEA) + " - " + [F:ZCONB]ACC + " - " + [F:ZCONB]DES + YPAM ,0)  From GESECRAN

         #29/07/20
         EXISTEN_REGISTROS = '1'
         #29/07/20
         Wrseq [F:ZCONB]CPY,[F:ZCONB]NUM,num$([F:ZCONB]LINEA) Using [ZCONBCI2]
#04/12/2019 Introduzco al final un nuevo campo: [F:ZCONB]TYP+[F:ZCONB]NATURALEZA
         If [F:ZCONB]SNS=-1
          LSENTIDO='H'
         Else
          LSENTIDO='D'
         Endif
#02/03/2020 Introduzco que si un asiento ponga AGR en vez de AGRE : LTIPO+[F:ZCONP]NATURALEZA
        If [F:ZCONB]TYP="AGRE"
          LTIPO='AGR'
          If YPAM='PAG' #SI LA FORMA DE PAGO ES PAGARE, ENVÍO LA FECHA DE VENCIMIENTO, NO LA CONTABLE

              Wrseq [F:ZCONB]TYP,[F:ZCONB]ORIMOD,[F:ZCONB]CPY
&             ,[F:ZCONB]NUM,[F:ZCONB]ACC,[F:ZCONB]DES,ctrans(vireblc(num$(format$("N:9.2",[F:ZCONB]AMTCUR)),2),".",","),[F:ZCONB]DES2,[F:ZCONB]CUR,num$([F:ZCONB]SNS)
&             ,[F:ZCONB]NATURALEZA,[F:ZCONB]CCE,[F:ZCONB]DES_CCE,[F:ZCONB]FREREF,[F:ZCONB]BPR, [F:ZCONB]XIDE,LTIPO+[F:ZCONB]NATURALEZA
&             ,num$(format$("D:YYYYMMDD",[F:ZCONB]DUDAT)),num$(format$("D:YYYYMMDD",[F:ZCONB]DUDAT))    Using [ZCONBCIL]

          Else
            Wrseq [F:ZCONB]TYP,[F:ZCONB]ORIMOD,[F:ZCONB]CPY
&         ,[F:ZCONB]NUM,[F:ZCONB]ACC,[F:ZCONB]DES,ctrans(vireblc(num$(format$("N:9.2",[F:ZCONB]AMTCUR)),2),".",","),[F:ZCONB]DES2,[F:ZCONB]CUR,num$([F:ZCONB]SNS)
&         ,[F:ZCONB]NATURALEZA,[F:ZCONB]CCE,[F:ZCONB]DES_CCE,[F:ZCONB]FREREF,[F:ZCONB]BPR, [F:ZCONB]XIDE,LTIPO+[F:ZCONB]NATURALEZA
&         ,num$(format$("D:YYYYMMDD",[F:ZCONB]ACCDAT)),num$(format$("D:YYYYMMDD",[F:ZCONB]DUDAT))    Using [ZCONBCIL]
          Endif
        Else
          If YPAM='PAG' or [F:ZCONB]TYP='PDAT'
              Wrseq [F:ZCONB]TYP,[F:ZCONB]ORIMOD,[F:ZCONB]CPY
&             ,[F:ZCONB]NUM,[F:ZCONB]ACC,[F:ZCONB]DES,ctrans(vireblc(num$(format$("N:9.2",[F:ZCONB]AMTCUR)),2),".",","),[F:ZCONB]DES2,[F:ZCONB]CUR,num$([F:ZCONB]SNS)
&             ,[F:ZCONB]NATURALEZA,[F:ZCONB]CCE,[F:ZCONB]DES_CCE,[F:ZCONB]FREREF,[F:ZCONB]BPR, [F:ZCONB]XIDE,[F:ZCONB]TYP+[F:ZCONB]NATURALEZA
&             ,num$(format$("D:YYYYMMDD",[F:ZCONB]DUDAT)),num$(format$("D:YYYYMMDD",[F:ZCONB]DUDAT))    Using [ZCONBCIL]
          Else
            Wrseq [F:ZCONB]TYP,[F:ZCONB]ORIMOD,[F:ZCONB]CPY
&         ,[F:ZCONB]NUM,[F:ZCONB]ACC,[F:ZCONB]DES,ctrans(vireblc(num$(format$("N:9.2",[F:ZCONB]AMTCUR)),2),".",","),[F:ZCONB]DES2,[F:ZCONB]CUR,num$([F:ZCONB]SNS)
&         ,[F:ZCONB]NATURALEZA,[F:ZCONB]CCE,[F:ZCONB]DES_CCE,[F:ZCONB]FREREF,[F:ZCONB]BPR, [F:ZCONB]XIDE,[F:ZCONB]TYP+[F:ZCONB]NATURALEZA
&         ,num$(format$("D:YYYYMMDD",[F:ZCONB]ACCDAT)),num$(format$("D:YYYYMMDD",[F:ZCONB]DUDAT))    Using [ZCONBCIL]
          Endif
        Endif


#([F:ZCONB]ACCDAT),([F:ZCONB]DUDAT)    Using [ZCONBCIL]



        Call ECR_TRACE ("Asiento escrito en el fichero: " + [F:ZCONB]NUM + " - " + num$([F:ZCONB]LINEA) + " - " + [F:ZCONB]ACC + " - " + [F:ZCONB]DES ,0)  From GESECRAN

         If [F:ZCONB]CPY = 'BKS' Then
            Call ECR_TRACE ("Inserción en tabla : " + [F:ZCONB]NUM + " - " + [F:ZCONB]ACC + " - " + [F:ZCONB]DES ,0)  From GESECRAN
            Trbegin [F:ZSEN]
            [F:ZSEN]TYP = [F:ZCONB]TYP
            [F:ZSEN]ORIMOD = [F:ZCONB]ORIMOD
            [F:ZSEN]CPY = [F:ZCONB]CPY
            [F:ZSEN]NUM  = [F:ZCONB]NUM
            [F:ZSEN]ACC = [F:ZCONB]ACC
            [F:ZSEN]DES = [F:ZCONB]DES
            [F:ZSEN]AMTCUR= [F:ZCONB]AMTCUR
            [F:ZSEN]DES2= [F:ZCONB]DES2
            [F:ZSEN]CUR= [F:ZCONB]CUR
            [F:ZSEN]SNS= [F:ZCONB]SNS
            [F:ZSEN]NATURALEZA= [F:ZCONB]NATURALEZA
            [F:ZSEN]DES3= [F:ZCONB]DES3
            [F:ZSEN]CCE= [F:ZCONB]CCE
            [F:ZSEN]FREREF= [F:ZCONB]FREREF
            [F:ZSEN]DES_CCE = [F:ZCONB]DES_CCE
            [F:ZSEN]ACCDAT= [F:ZCONB]ACCDAT
            [F:ZSEN]DUDAT= [F:ZCONB]DUDAT
            [F:ZSEN]BPR = [F:ZCONB]BPR
            [F:ZSEN]XIDE = [F:ZCONB]XIDE
            Write [ZSEN]
            Commit
            #Y013
            YCONTADOR +=1
            #Y013
            Call ECR_TRACE ("Grabado de tabla: " + [F:ZCONB]NUM + " - " + [F:ZCONB]ACC + " - " + [F:ZCONB]DES + " - Status: " + num$(fstat),0)  From GESECRAN
            # ACTUALIZAR GACCENTRY/GACCENTRYD/GACCENTRYA
            Trbegin [F:HAEAUX]
            # GACCENTRY
            Update [F:HAEAUX] Where NUM=[F:ZCONB]NUM and ACCDAT = [F:ZCONB]ACCDAT and TYP=[F:ZCONB]TYP and CPY=[F:ZCONB]CPY With ZSNDXRT = 2
            Commit
            Call ECR_TRACE ("UPDATE TABLA GACCENTRY: " + [F:ZCONB]NUM + " - " + [F:ZCONB]ACC + " - " + [F:ZCONB]DES + " - Status: " + num$(fstat),0)  From GESECRAN
            #GACCENTRYD
            Trbegin [F:HADAUX]
            Update [F:HADAUX] Where NUM=[F:ZCONB]NUM and ACCNUM = [F:ZCONB]ACCNUM and ACC = [F:ZCONB]ACC and ACCDAT = [F:ZCONB]ACCDAT and LIN = [F:
& ZCONB]LINEA and TYP=[F:ZCONB] TYP and CPY=[F:ZCONB]CPY and LED = [F:ZCONB]LED With ZSNDXRT = 2
            Commit
            Call ECR_TRACE ("UPDATE TABLA GACCENTRYD: " + [F:ZCONB]NUM + " - " + [F:ZCONB]ACC + " - " + [F:ZCONB]DES + " - Status: " + num$(fstat),0)  From GESECRAN
            #GACCENTRYA
            Trbegin [F:HAAAUX]
            Update [F:HAAAUX] Where NUM=[F:ZCONB]NUM and  ACCNUM = [F:ZCONB]ACCNUM and  ACC = [F:ZCONB]ACC and ACCDAT = [F:ZCONB]ACCDAT and  LIN = [F:
& ZCONB]LINEA and  TYP=[F:ZCONB] TYP and CPY=[F:ZCONB]CPY and LED = [F:ZCONB]LED With ZSNDXRT = 2
            Commit
                        Call ECR_TRACE ("UPDATE TABLA GACCENTRYA: " + [F:ZCONB]NUM + " - " + [F:ZCONB]ACC + " - " + [F:ZCONB]DES + " - Status: " + num$(fstat),0)  From GESECRAN
                 # Infbox "Record modificador:" -num$(adxuprec)

          Endif

          Call ECR_TRACE ("Asiento enviado " + [F:ZCONB]NUM + " - " + [F:ZCONB]ACC + " - " + [F:ZCONB]DES ,0)  From GESECRAN

          CONTADOR +=1
$SIG_PAG_BKS
    Next
    Close File [HAEAUX]
    Close File [HADAUX]
    Close File [HAAAUX]
    Openo Using [ZCONBCIL]
    Openo Using [ZCONBCI2]
    Close File [ZCONB]
    Close File [ZSEN]
    Call ECR_TRACE ("Registros enviados en " + PCPY + ": " + num$(CONTADOR-1),0)  From GESECRAN
#    EXISTEN_REGISTROS = '1'
  Else
    EXISTEN_REGISTROS = '0'
  Endif

End

#**
#* GENERACION FICHETIM
#*
#*
#*!
Subprog GENERA_FICHERO_TIM(PCPY, PNOMBRE_FICHERO)
  Local Char LCRITERIA(250)
  Local Char   LFECHA
  Local Char ZPATH(200)  #ZPATH = "E:\SAGE\X3MAFESA\folders\PROTO\IMPORT\OF\"
  Local Integer   CONTADOR
  Local Char LSENTIDO
  Local Char LTIPO
  Local Char YPAM(5)

  If clalev([ZCONT]) = 0 : Local File ZYCONCILTIM   [ZCONT]  : Endif

  If clalev([ZSEN]) = 0 : Local File ZCONCILSEND [ZSEN]  : Endif

  If !clalev([F:HAEAUX])  Then : Global File GACCENTRY [HAEAUX] : Endif
  If !clalev([F:HADAUX])  Then : Global File GACCENTRYD [HADAUX] : Endif
  If !clalev([F:HAAAUX])  Then : Global File GACCENTRYA [HAAAUX] : Endif
  If !clalev([F:YPYH])  Then : Local File PAYMENTH [YPYH] : Endif
 # Infbox "Dentro de export: " + PCPY
  LFECHA =  "30/04/2018"
  LCRITERIA = "CPY = PCPY "

  Call ECR_TRACE ("Generando fichero:" + PNOMBRE_FICHERO,0)  From GESECRAN
  CONTADOR = 1
  adxifs = ';' : adxirs = chr$(13)+chr$(10)

  LFICIMP = filpath("IMP",PNOMBRE_FICHERO,"csv")

  LFICIMP2 = filpath("IMP",PNOMBRE_FICHERO,"bak")


  Filter [F:ZCONT]  # Where evalue(LCRITERIA)

  If (rowcount([F:ZCONT])) > 0 Then
  Call ECR_TRACE ("Registros encontrados en " + PCPY + ": " + num$(rowcount([F:ZCONT])),0)  From GESECRAN
    #29/07/20
    #EXISTEN_REGISTROS = '1'
    #29/07/20

    # Si existen registros los vuelvo en una tabla temporal


    Openo LFICIMP Using [ZCONTCIL]
    For [F:ZCONT]  With Stability
#BUSCO LA FORMA DE PAGO
         YPAM=''
         For [F:HAEAUX] Where NUM=[F:ZCONT]NUM
          For [F:YPYH] Where NUM=[F:HAEAUX]BPRVCR
            YPAM=[F:YPYH]PAM
          Next
         Next
         If YPAM ='PAG'
          If [F:ZCONT]DUDAT>date$ #02/01/2020 Solo se envía si ha llegado la fecha de vencimiento
            Call ECR_TRACE("Pagaré aún no vencido:"-[F:ZCONT]NUM,0) From GESECRAN
            Goto SIG_PAG_TIM
          Endif
         Endif
        Call ECR_TRACE ("Asiento que voy a escribir en el fichero: " + [F:ZCONT]NUM + " - " + num$([F:ZCONT]LINEA) + " - " + [F:ZCONT]ACC + " - " + [F:ZCONT]DES + YPAM ,0)  From GESECRAN

         #29/07/20
         EXISTEN_REGISTROS = '1'
         #29/07/20

         Openo LFICIMP2 Using [ZCONTCI2]
         Wrseq [F:ZCONT]CPY,[F:ZCONT]NUM,num$([F:ZCONT]LINEA) Using [ZCONTCI2]
         Openo Using [ZCONTCI2]
#04/12/2019 Introduzco al final un nuevo campo: [F:ZCONT]TYP+[F:ZCONT]NATURALEZA
         If [F:ZCONT]SNS=-1
          LSENTIDO='H'
         Else
          LSENTIDO='D'
         Endif
#02/03/2020 Introduzco que si un asiento ponga AGR en vez de AGRE : LTIPO+[F:ZCONP]NATURALEZA
         If [F:ZCONT]TYP="AGRE"
            LTIPO='AGR'
            If YPAM='PAG' #SI LA FORMA DE PAGO ES PAG, TOMO LA FECHA DE VENCIMIENTO EN VEZ DE LA CONTABLE

                Wrseq [F:ZCONT]TYP,[F:ZCONT]ORIMOD,[F:ZCONT]CPY
&               ,[F:ZCONT]NUM,[F:ZCONT]ACC,[F:ZCONT]DES,ctrans(vireblc(num$(format$("N:9.2",[F:ZCONT]AMTCUR)),2),".",","),[F:ZCONT]DES2,[F:ZCONT]CUR,num$([F:ZCONT]SNS)
&               ,[F:ZCONT]NATURALEZA,[F:ZCONT]CCE,[F:ZCONT]DES_CCE,[F:ZCONT]FREREF,[F:ZCONT]BPR, [F:ZCONT]XIDE,LTIPO+[F:ZCONT]NATURALEZA
&               ,num$(format$("D:YYYYMMDD",[F:ZCONT]DUDAT)),num$(format$("D:YYYYMMDD",[F:ZCONT]DUDAT))  Using [ZCONTCIL]

            Else
              If YPAM='PAG' or [F:ZCONT]TYP='PDAT'
                  Wrseq [F:ZCONT]TYP,[F:ZCONT]ORIMOD,[F:ZCONT]CPY
&                 ,[F:ZCONT]NUM,[F:ZCONT]ACC,[F:ZCONT]DES,ctrans(vireblc(num$(format$("N:9.2",[F:ZCONT]AMTCUR)),2),".",","),[F:ZCONT]DES2,[F:ZCONT]CUR,num$([F:ZCONT]SNS)
&                 ,[F:ZCONT]NATURALEZA,[F:ZCONT]CCE,[F:ZCONT]DES_CCE,[F:ZCONT]FREREF,[F:ZCONT]BPR, [F:ZCONT]XIDE,LTIPO+[F:ZCONT]NATURALEZA
&                 ,num$(format$("D:YYYYMMDD",[F:ZCONT]DUDAT)),num$(format$("D:YYYYMMDD",[F:ZCONT]DUDAT))  Using [ZCONTCIL]

              Else
                Wrseq [F:ZCONT]TYP,[F:ZCONT]ORIMOD,[F:ZCONT]CPY
&         ,[F:ZCONT]NUM,[F:ZCONT]ACC,[F:ZCONT]DES,ctrans(vireblc(num$(format$("N:9.2",[F:ZCONT]AMTCUR)),2),".",","),[F:ZCONT]DES2,[F:ZCONT]CUR,num$([F:ZCONT]SNS)
&         ,[F:ZCONT]NATURALEZA,[F:ZCONT]CCE,[F:ZCONT]DES_CCE,[F:ZCONT]FREREF,[F:ZCONT]BPR, [F:ZCONT]XIDE,LTIPO+[F:ZCONT]NATURALEZA
&         ,num$(format$("D:YYYYMMDD",[F:ZCONT]ACCDAT)),num$(format$("D:YYYYMMDD",[F:ZCONT]DUDAT))  Using [ZCONTCIL]
              Endif
            Endif
         Else
          Wrseq [F:ZCONT]TYP,[F:ZCONT]ORIMOD,[F:ZCONT]CPY
&           ,[F:ZCONT]NUM,[F:ZCONT]ACC,[F:ZCONT]DES,ctrans(vireblc(num$(format$("N:9.2",[F:ZCONT]AMTCUR)),2),".",","),[F:ZCONT]DES2,[F:ZCONT]CUR,num$([F:ZCONT]SNS)
&           ,[F:ZCONT]NATURALEZA,[F:ZCONT]CCE,[F:ZCONT]DES_CCE,[F:ZCONT]FREREF,[F:ZCONT]BPR, [F:ZCONT]XIDE,[F:ZCONT]TYP+[F:ZCONT]NATURALEZA
&           ,num$(format$("D:YYYYMMDD",[F:ZCONT]ACCDAT)),num$(format$("D:YYYYMMDD",[F:ZCONT]DUDAT))  Using [ZCONTCIL]
         Endif

     # ([F:ZCONT]ACCDAT),([F:ZCONT]DUDAT)    Using [ZCONTCIL]

        Call ECR_TRACE ("Asiento escrito en el fichero: " + [F:ZCONT]NUM + " - " +  num$([F:ZCONT]LINEA) + " - " + [F:ZCONT]ACC + " - " + [F:ZCONT]DES ,0)  From GESECRAN
        # TEMPORAL
         If [F:ZCONT]CPY = 'TIM' Then
            Trbegin [F:ZSEN]
            [F:ZSEN]TYP = [F:ZCONT]TYP
            [F:ZSEN]ORIMOD = [F:ZCONT]ORIMOD
            [F:ZSEN]CPY = [F:ZCONT]CPY
            [F:ZSEN]NUM  = [F:ZCONT]NUM
            [F:ZSEN]ACC = [F:ZCONT]ACC
            [F:ZSEN]DES = [F:ZCONT]DES
            [F:ZSEN]AMTCUR= [F:ZCONT]AMTCUR
            [F:ZSEN]DES2= [F:ZCONT]DES2
            [F:ZSEN]CUR= [F:ZCONT]CUR
            [F:ZSEN]SNS= [F:ZCONT]SNS
            [F:ZSEN]NATURALEZA= [F:ZCONT]NATURALEZA
            [F:ZSEN]DES3= [F:ZCONT]DES3
            [F:ZSEN]CCE= [F:ZCONT]CCE
            [F:ZSEN]FREREF= [F:ZCONT]FREREF
            [F:ZSEN]DES_CCE = [F:ZCONT]DES_CCE
            [F:ZSEN]ACCDAT= [F:ZCONT]ACCDAT
            [F:ZSEN]DUDAT= [F:ZCONT]DUDAT
            [F:ZSEN]BPR = [F:ZCONT]BPR
            [F:ZSEN]XIDE = [F:ZCONT]XIDE
            [F:ZSEN]LINEA = [F:ZCONT]LINEA
            Write [ZSEN]
            Commit
            #Y013
            YCONTADOR +=1
            #Y013
            Call ECR_TRACE ("Grabado de tabla: " + [F:ZCONT]NUM + " - " + [F:ZCONT]ACC + " - " + [F:ZCONT]DES + " - Status: " + num$(fstat),0)  From GESECRAN
            # ACTUALIZAR GACCENTRY/GACCENTRYD/GACCENTRYA
            Trbegin [F:HAEAUX]
            # GACCENTRY
            Update [F:HAEAUX] Where NUM=[F:ZCONT]NUM and ACCDAT = [F:ZCONT]ACCDAT and TYP=[F:ZCONT]TYP and CPY=[F:ZCONT]CPY With ZSNDXRT = 2
            Commit
            Call ECR_TRACE ("UPDATE GACCENTRY: " + [F:ZCONT]NUM + " - " + [F:ZCONT]ACC + " - " + [F:ZCONT]DES + " - Status: " + num$(fstat),0)  From GESECRAN
            #GACCENTRYD
            Trbegin [F:HADAUX]
            Update [F:HADAUX] Where NUM=[F:ZCONT]NUM and ACCNUM = [F:ZCONT]ACCNUM and ACC = [F:ZCONT]ACC and LIN = [F:ZCONT]LINEA and ACCDAT = [F:
& ZCONT]ACCDAT and TYP=[F:ZCONT]TYP and CPY=[F:ZCONT]CPY and LED = [F:ZCONT]LED With ZSNDXRT = 2
            Commit
            Call ECR_TRACE ("UPDATE GACCENTRYD: " + [F:ZCONT]NUM + " - " + [F:ZCONT]ACC + " - " + [F:ZCONT]DES + " - Status: " + num$(fstat),0)  From GESECRAN
            #GACCENTRYA
            Trbegin [F:HAAAUX]
            Update [F:HAAAUX] Where NUM=[F:ZCONT]NUM and ACCNUM = [F:ZCONT]ACCNUM and  [F:HAAAUX]ACC = [F:ZCONT]ACC and LIN = [F:ZCONT]LINEA and  ACCDAT = [F:
& ZCONT]ACCDAT and TYP=[F:ZCONT]TYP and CPY=[F:ZCONT]CPY and LED = [F:ZCONT]LED With ZSNDXRT = 2
            Commit
            Call ECR_TRACE ("UPDATE GACCENTRYA: " + [F:ZCONT]NUM + " - " + [F:ZCONT]ACC + " - " + [F:ZCONT]DES + " - Status: " + num$(fstat),0)  From GESECRAN
                 # Infbox "Record modificador:" -num$(adxuprec)

          Endif # FIN TEMPORAL SOLO REGISTROS DE TIM

          Call ECR_TRACE ("Asiento enviado " + [F:ZCONT]NUM + " - " + [F:ZCONT]ACC + " - " + [F:ZCONT]DES ,0)  From GESECRAN

          CONTADOR +=1
$SIG_PAG_TIM
    Next
    Close File [HAEAUX]
    Close File [HADAUX]
    Close File [HAAAUX]

    Openo Using [ZCONTCIL]


    Close File [ZCONT]
    Call ECR_TRACE ("Registros enviados en " + PCPY + ": " + num$(CONTADOR-1),0)  From GESECRAN
#    EXISTEN_REGISTROS = '1'
  Else
    EXISTEN_REGISTROS = '0'
  Endif


End

#**
#* GENERACION FICHEPOP
#*
#*
#*!
Subprog GENERA_FICHERO_POP(PCPY, PNOMBRE_FICHERO)
  Local Char LCRITERIA(250)
  Local Char   LFECHA
  Local Char ZPATH(200)  #ZPATH = "E:\SAGE\X3MAFESA\folders\PROTO\IMPORT\OF\"
  Local Integer   CONTADOR
  Local Char LSENTIDO
  Local Char LTIPO
  Local Char YPAM(5)

  If clalev([ZCONP]) = 0 : Local File ZYCONCILPOP  [ZCONP]  : Endif

  If clalev([ZSEN]) = 0 : Local File ZCONCILSEND [ZSEN]  : Endif

  If !clalev([F:HAEAUX])  Then : Global File GACCENTRY [HAEAUX] : Endif
  If !clalev([F:HADAUX])  Then : Global File GACCENTRYD [HADAUX] : Endif
  If !clalev([F:HAAAUX])  Then : Global File GACCENTRYA [HAAAUX] : Endif
  If !clalev([F:YPYH])  Then : Local File PAYMENTH [YPYH] : Endif
 # Infbox "Dentro de export: " + PCPY
  LFECHA =  "30/04/2018"
  LCRITERIA = "CPY = PCPY "

  Call ECR_TRACE ("Generando fichero:" + PNOMBRE_FICHERO,0)  From GESECRAN
  CONTADOR = 1
  adxifs = ';' : adxirs = chr$(13)+chr$(10)

  LFICIMP = filpath("IMP",PNOMBRE_FICHERO,"csv")

  LFICIMP2 = filpath("IMP",PNOMBRE_FICHERO,"bak")


  Filter [F:ZCONP]  # Where evalue(LCRITERIA)

  If (rowcount([F:ZCONP])) > 0 Then
  Call ECR_TRACE ("Registros encontrados en " + PCPY + ": " + num$(rowcount([F:ZCONP])),0)  From GESECRAN
    #29/07/20
    #EXISTEN_REGISTROS = '1'
    #29/07/20

    # Si existen registros los vuelvo en una tabla temporal


    Openo LFICIMP Using [ZCONPCIL]
    For [F:ZCONP]  With Stability
#BUSCO LA FORMA DE PAGO
         YPAM=''
         For [F:HAEAUX] Where NUM=[F:ZCONP]NUM
          For [F:YPYH] Where NUM=[F:HAEAUX]BPRVCR
            YPAM=[F:YPYH]PAM
          Next
         Next
        If YPAM='PAG'
          Call ECR_TRACE("Pagaré:"-[F:ZCONP]NUM-[F:ZCONP]DUDAT-date$,0) From GESECRAN
          If [F:ZCONP]DUDAT>date$ #02/01/2020 Solo se envía si ha llegado la fecha de vencimiento
            Call ECR_TRACE("Pagaré aún no vencido:"-[F:ZCONP]NUM,0) From GESECRAN
            Goto SIG_PAG_POP
          Endif
        Endif
        #29/07/20
         EXISTEN_REGISTROS = '1'
        #29/07/20
        Call ECR_TRACE ("Asiento que voy a escribir en el fichero: " + [F:ZCONP]NUM + " - " + num$([F:ZCONP]LINEA) + " - " + [F:ZCONP]ACC + " - " + [F:ZCONP]DES + YPAM ,0)  From GESECRAN

         Openo LFICIMP2 Using [ZCONPCI2]
         Wrseq [F:ZCONP]CPY,[F:ZCONP]NUM,num$([F:ZCONP]LINEA) Using [ZCONPCI2]
         Openo Using [ZCONPCI2]
#04/12/2019 Introduzco al final un nuevo campo: [F:ZCONP]TYP+[F:ZCONP]NATURALEZA
         If [F:ZCONP]SNS=-1
          LSENTIDO='H'
         Else
          LSENTIDO='D'
         Endif

#25/01/2020 Introduzco que si un cobro ponga COB en vez de COBP : LTIPO+[F:ZCONP]NATURALEZA
        If [F:ZCONP]TYP="COBP"
          LTIPO='COB'
          If YPAM='PAG' #SI ES PAG, TOMO LA FECHA DE VENCIMIENTO EN VEZ DE LA CONTABLE
              Wrseq [F:ZCONP]TYP,[F:ZCONP]ORIMOD,[F:ZCONP]CPY
&             ,[F:ZCONP]NUM,[F:ZCONP]ACC,[F:ZCONP]DES,ctrans(vireblc(num$(format$("N:9.2",[F:ZCONP]AMTCUR)),2),".",","),[F:ZCONP]DES2,[F:ZCONP]CUR,num$([F:ZCONP]SNS)
&             ,[F:ZCONP]NATURALEZA,[F:ZCONP]CCE,[F:ZCONP]DES_CCE,[F:ZCONP]FREREF,[F:ZCONP]BPR, [F:ZCONP]XIDE,LTIPO+[F:ZCONP]NATURALEZA
&             ,num$(format$("D:YYYYMMDD",[F:ZCONP]DUDAT)),num$(format$("D:YYYYMMDD",[F:ZCONP]DUDAT))    Using [ZCONPCIL]
          Else
            Wrseq [F:ZCONP]TYP,[F:ZCONP]ORIMOD,[F:ZCONP]CPY
&         ,[F:ZCONP]NUM,[F:ZCONP]ACC,[F:ZCONP]DES,ctrans(vireblc(num$(format$("N:9.2",[F:ZCONP]AMTCUR)),2),".",","),[F:ZCONP]DES2,[F:ZCONP]CUR,num$([F:ZCONP]SNS)
&         ,[F:ZCONP]NATURALEZA,[F:ZCONP]CCE,[F:ZCONP]DES_CCE,[F:ZCONP]FREREF,[F:ZCONP]BPR, [F:ZCONP]XIDE,LTIPO+[F:ZCONP]NATURALEZA
&         ,num$(format$("D:YYYYMMDD",[F:ZCONP]ACCDAT)),num$(format$("D:YYYYMMDD",[F:ZCONP]DUDAT))    Using [ZCONPCIL]
          Endif
        Else
#02/03/2020 Introduzco que si un asiento ponga AGR en vez de AGRE : LTIPO+[F:ZCONP]NATURALEZA
          If [F:ZCONP]TYP="AGRE"
            LTIPO='AGR'
            If YPAM='PAG'
                Wrseq [F:ZCONP]TYP,[F:ZCONP]ORIMOD,[F:ZCONP]CPY
&               ,[F:ZCONP]NUM,[F:ZCONP]ACC,[F:ZCONP]DES,ctrans(vireblc(num$(format$("N:9.2",[F:ZCONP]AMTCUR)),2),".",","),[F:ZCONP]DES2,[F:ZCONP]CUR,num$([F:ZCONP]SNS)
&               ,[F:ZCONP]NATURALEZA,[F:ZCONP]CCE,[F:ZCONP]DES_CCE,[F:ZCONP]FREREF,[F:ZCONP]BPR, [F:ZCONP]XIDE,LTIPO+[F:ZCONP]NATURALEZA
&               ,num$(format$("D:YYYYMMDD",[F:ZCONP]DUDAT)),num$(format$("D:YYYYMMDD",[F:ZCONP]DUDAT))    Using [ZCONPCIL]
            Else
              Wrseq [F:ZCONP]TYP,[F:ZCONP]ORIMOD,[F:ZCONP]CPY
&           ,[F:ZCONP]NUM,[F:ZCONP]ACC,[F:ZCONP]DES,ctrans(vireblc(num$(format$("N:9.2",[F:ZCONP]AMTCUR)),2),".",","),[F:ZCONP]DES2,[F:ZCONP]CUR,num$([F:ZCONP]SNS)
&           ,[F:ZCONP]NATURALEZA,[F:ZCONP]CCE,[F:ZCONP]DES_CCE,[F:ZCONP]FREREF,[F:ZCONP]BPR, [F:ZCONP]XIDE,LTIPO+[F:ZCONP]NATURALEZA
&           ,num$(format$("D:YYYYMMDD",[F:ZCONP]ACCDAT)),num$(format$("D:YYYYMMDD",[F:ZCONP]DUDAT))    Using [ZCONPCIL]
            Endif
          Else
            If YPAM='PAG' or  [F:ZCONP]TYP='PDAT'
                         Wrseq [F:ZCONP]TYP,[F:ZCONP]ORIMOD,[F:ZCONP]CPY
&           ,[F:ZCONP]NUM,[F:ZCONP]ACC,[F:ZCONP]DES,ctrans(vireblc(num$(format$("N:9.2",[F:ZCONP]AMTCUR)),2),".",","),[F:ZCONP]DES2,[F:ZCONP]CUR,num$([F:ZCONP]SNS)
&           ,[F:ZCONP]NATURALEZA,[F:ZCONP]CCE,[F:ZCONP]DES_CCE,[F:ZCONP]FREREF,[F:ZCONP]BPR, [F:ZCONP]XIDE,LTIPO+[F:ZCONP]NATURALEZA
&           ,num$(format$("D:YYYYMMDD",[F:ZCONP]DUDAT)),num$(format$("D:YYYYMMDD",[F:ZCONP]DUDAT))    Using [ZCONPCIL]
            Else
             Wrseq [F:ZCONP]TYP,[F:ZCONP]ORIMOD,[F:ZCONP]CPY
&           ,[F:ZCONP]NUM,[F:ZCONP]ACC,[F:ZCONP]DES,ctrans(vireblc(num$(format$("N:9.2",[F:ZCONP]AMTCUR)),2),".",","),[F:ZCONP]DES2,[F:ZCONP]CUR,num$([F:ZCONP]SNS)
&           ,[F:ZCONP]NATURALEZA,[F:ZCONP]CCE,[F:ZCONP]DES_CCE,[F:ZCONP]FREREF,[F:ZCONP]BPR, [F:ZCONP]XIDE,LTIPO+[F:ZCONP]NATURALEZA
&           ,num$(format$("D:YYYYMMDD",[F:ZCONP]ACCDAT)),num$(format$("D:YYYYMMDD",[F:ZCONP]DUDAT))    Using [ZCONPCIL]
            Endif
          Endif
         Endif


     # ([F:ZCONT]ACCDAT),([F:ZCONT]DUDAT)    Using [ZCONTCIL]

        Call ECR_TRACE ("Asiento escrito en el fichero: " + [F:ZCONP]NUM + " - " +  num$([F:ZCONP]LINEA) + " - " + [F:ZCONP]ACC + " - " + [F:ZCONP]DES ,0)  From GESECRAN
        # TEMPORAL
         If [F:ZCONP]CPY = 'POP' Then
            Trbegin [F:ZSEN]
            [F:ZSEN]TYP = [F:ZCONP]TYP
            [F:ZSEN]ORIMOD = [F:ZCONP]ORIMOD
            [F:ZSEN]CPY = [F:ZCONP]CPY
            [F:ZSEN]NUM  = [F:ZCONP]NUM
            [F:ZSEN]ACC = [F:ZCONP]ACC
            [F:ZSEN]DES = [F:ZCONP]DES
            [F:ZSEN]AMTCUR= [F:ZCONP]AMTCUR
            [F:ZSEN]DES2= [F:ZCONP]DES2
            [F:ZSEN]CUR= [F:ZCONP]CUR
            [F:ZSEN]SNS= [F:ZCONP]SNS
            [F:ZSEN]NATURALEZA= [F:ZCONP]NATURALEZA
            [F:ZSEN]DES3= [F:ZCONP]DES3
            [F:ZSEN]CCE= [F:ZCONP]CCE
            [F:ZSEN]FREREF= [F:ZCONP]FREREF
            [F:ZSEN]DES_CCE = [F:ZCONP]DES_CCE
            [F:ZSEN]ACCDAT= [F:ZCONP]ACCDAT
            [F:ZSEN]DUDAT= [F:ZCONP]DUDAT
            [F:ZSEN]BPR = [F:ZCONP]BPR
            [F:ZSEN]XIDE = [F:ZCONP]XIDE
            [F:ZSEN]LINEA = [F:ZCONP]LINEA
            Write [ZSEN]
            Commit
            #Y013
            YCONTADOR +=1
            #Y013
            Call ECR_TRACE ("Grabado de tabla: " + [F:ZCONP]NUM + " - " + [F:ZCONP]ACC + " - " + [F:ZCONP]DES + " - Status: " + num$(fstat),0)  From GESECRAN
            # ACTUALIZAR GACCENTRY/GACCENTRYD/GACCENTRYA
            Trbegin [F:HAEAUX]
            # GACCENTRY
            Update [F:HAEAUX] Where NUM=[F:ZCONP]NUM and ACCDAT = [F:ZCONP]ACCDAT and TYP=[F:ZCONP]TYP and CPY=[F:ZCONP]CPY With ZSNDXRT = 2
            Commit
            Call ECR_TRACE ("UPDATE GACCENTRY: " + [F:ZCONP]NUM + " - " + [F:ZCONP]ACC + " - " + [F:ZCONP]DES + " - Status: " + num$(fstat),0)  From GESECRAN
            #GACCENTRYD
            Trbegin [F:HADAUX]
            Update [F:HADAUX] Where NUM=[F:ZCONP]NUM and ACCNUM = [F:ZCONP]ACCNUM and ACC = [F:ZCONP]ACC and LIN = [F:ZCONP]LINEA and ACCDAT = [F:
& ZCONP]ACCDAT and TYP=[F:ZCONP]TYP and CPY=[F:ZCONP]CPY and LED = [F:ZCONP]LED With ZSNDXRT = 2
            Commit
            Call ECR_TRACE ("UPDATE GACCENTRYD: " + [F:ZCONP]NUM + " - " + [F:ZCONP]ACC + " - " + [F:ZCONP]DES + " - Status: " + num$(fstat),0)  From GESECRAN
            #GACCENTRYA
            Trbegin [F:HAAAUX]
            Update [F:HAAAUX] Where NUM=[F:ZCONP]NUM and ACCNUM = [F:ZCONP]ACCNUM and  [F:HAAAUX]ACC = [F:ZCONP]ACC and LIN = [F:ZCONP]LINEA and  ACCDAT = [F:
& ZCONP]ACCDAT and TYP=[F:ZCONP]TYP and CPY=[F:ZCONP]CPY and LED = [F:ZCONP]LED With ZSNDXRT = 2
            Commit
            Call ECR_TRACE ("UPDATE GACCENTRYA: " + [F:ZCONP]NUM + " - " + [F:ZCONP]ACC + " - " + [F:ZCONP]DES + " - Status: " + num$(fstat),0)  From GESECRAN
                 # Infbox "Record modificador:" -num$(adxuprec)

          Endif # FIN TEMPORAL SOLO REGISTROS DE TIM

          Call ECR_TRACE ("Asiento enviado " + [F:ZCONP]NUM + " - " + [F:ZCONP]ACC + " - " + [F:ZCONP]DES ,0)  From GESECRAN

          CONTADOR +=1
$SIG_PAG_POP
    Next
    Close File [HAEAUX]
    Close File [HADAUX]
    Close File [HAAAUX]

    Openo Using [ZCONPCIL]


    Close File [ZCONP]
    Call ECR_TRACE ("Registros enviados en " + PCPY + ": " + num$(CONTADOR-1),0)  From GESECRAN
#    EXISTEN_REGISTROS = '1'
  Else
    EXISTEN_REGISTROS = '0'
  Endif

End
