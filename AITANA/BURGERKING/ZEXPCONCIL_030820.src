################################################################################
#<ALI02>
$COMPROBAR_ERRORES_FTP
#comprobamos que el fichero log generado se haya pasado a Enviados
#si da error tarda un poco en pasar a enviados por lo que miramos durante 5 minutos
#si el fichero log tiene algún error se mueven los ficheros al directorio IMP\Enviados\ERRORESFTP
#y se envia mail
Local Integer WI
Local Integer WENCONTRADO
Local Integer WERROR
Local Char    WLINEA(250)

#Esperamos 5 segundos para que se muevan los ficheros
Sleep 5
#
Raz WENCONTRADO
Raz WERROR
#Si no se ha creado fichero csv no se genera tampoco fichero log
ORIGEN = ORIGEN_DOSSIER+"\IMP\Enviados\" + PFICHERO+".csv"
If filinfo(ORIGEN,7) < 0
  Return
Endif

ORIGEN = ORIGEN_DOSSIER+"\IMP\Enviados\" + PFICHERO+".log"
#Buscamos el fichero log en enviados
#Si ha dado error de ftp tarda en pasar de IMP a Enviados por lo que hacemos un bucle de unos 5 minutos
#Si en este tiempo no se ha generado el log enviamos los ficheros a un directorio de errores
Raz WI
##For WI = 1 To 100   #esperamos 5 minutos para comprobar si se ha pasado el fichero log
For WI = 1 To 5
  If filinfo(ORIGEN,7) >= 0  #-20 fichero no encontrado, -27 acceso denegado
    WENCONTRADO = 1
    WI = 100
  Endif
  If WENCONTRADO <> 1
    Sleep 3
  Endif
Next WI
#
#Comprobamos si en el log hay algún error
If WENCONTRADO = 1
  Openi ORIGEN Using [WFICHERO]
  Rdseq WLINEA Using [WFICHERO] #leer líneas
    While fstat=0
      If instr(0,WLINEA,"error")<>0 or instr(0,WLINEA,"Error")<>0
        WENCONTRADO = 3
      Endif
      Rdseq WLINEA Using [WFICHERO]
    Wend
  Openi Using [WFICHERO]
Endif
#
#Hay que mover los ficheros tanto si se ha encontrado la palabra error en el fichero log (WENCONTRADO = 3)
#como si no se ha encontrado fichero log (WENCONTRADO = 0)
If WENCONTRADO <> 1
  ORIGEN = ORIGEN_DOSSIER+"\IMP\Enviados\" + PFICHERO+".csv"
  DESTINO= ORIGEN_DOSSIER+"\IMP\Enviados\ERRORESFTP\"+PFICHERO+".csv"
  If filinfo(ORIGEN,7) >= 0
    Call MOVE (ORIGEN,DESTINO,STAT) From ORDSYS
  Else
    WERROR = 1
  Endif
#
  ORIGEN = ORIGEN_DOSSIER+"\IMP\Enviados\" + PFICHERO+".bat"
  DESTINO= ORIGEN_DOSSIER+"\IMP\Enviados\ERRORESFTP\"+PFICHERO+".bat"
  If filinfo(ORIGEN,7) >= 0
    Call MOVE (ORIGEN,DESTINO,STAT) From ORDSYS
  Else
    WERROR = 1
  Endif
#
  ORIGEN = ORIGEN_DOSSIER+"\IMP\Enviados\" + PFICHERO+".bak"
  DESTINO= ORIGEN_DOSSIER+"\IMP\Enviados\ERRORESFTP\"+PFICHERO+".bak"
  If filinfo(ORIGEN,7) >= 0
    Call MOVE (ORIGEN,DESTINO,STAT) From ORDSYS
  Else
    WERROR = 1
  Endif
#
  ORIGEN = ORIGEN_DOSSIER+"\IMP\Enviados\" + PFICHERO+".log"
  DESTINO= ORIGEN_DOSSIER+"\IMP\Enviados\ERRORESFTP\"+PFICHERO+".log"
  If filinfo(ORIGEN,7) >= 0
    Call MOVE (ORIGEN,DESTINO,STAT) From ORDSYS
  Else
    WERROR = 1
  Endif
#
  If WERROR = 1
    Call ECR_TRACE ("No se ha encontrado alguno de los ficheros en \IMP\Enviados\ al pasarlos a \IMP\Enviados\ERRORESFTP\",0)  From GESECRAN
  Endif
#
#Enviar mail si hay algún error
  Local Integer  WSTA
  Local Integer  WTRACE
  Local Char     FIC_TRACE(250)
  Local Char     ISSUERMAIL(250)
  Local Char     A_USER(250)(1..)
  Local Char     CC_USER(250)(1..)
  Local Char     HEADER(250)
  Local Clbfile  BODY(0)
  Local Char     ATTACHMENTS(250)(1..)
  A_USER(1)="cristian.perez@rbiberia.com"
  CC_USER(1)="arancha.dolico@rbiberia.com"
  HEADER="ZEXPCONCIL error en ftp fichero  " + PFICHERO
  ISSUERMAIL="comunicaciones.administracion@rbiberia.com"
  TRACE = 2

  Append BODY , 'Fichero log ' + ORIGEN_DOSSIER +"\IMP\Enviados\ERRORESFTP\"+PFICHERO+".log" +chr$(10)
  WSTA =func ASYRMAIL.ASEND_MAIL(GACTX,ISSUERMAIL,A_USER,CC_USER,HEADER,BODY,ATTACHMENTS,WTRACE)
  If WSTA <> CST_AOK Then
    Call ECR_TRACE ("Error envio mail errores fichero log " + PFICHERO,0)  From GESECRAN
  Else
    Call ECR_TRACE ("Enviado mail errores fichero log " + PFICHERO,0)  From GESECRAN
  Endif

Endif
Call ECR_TRACE ("Fin comprobar errores fichero log " + PFICHERO,0)  From GESECRAN
Return
#Fin <ALI02>
################################################################################
#<ALI03>
#A veces ha ocurrido que se lanza dos veces el proceso. Comprobamos si hay otra tarea en ejecución
#en caso afirmativo finaliza proceso y enviamos mail
$COMPROBAR_TAREA_EN_EJECUCION
If !clalev([F:YABR])   : Local File ABATRQT [YABR] : Endif
Raz WERROR_TAREA
#
Call ECR_TRACE ("Comprobar tareas duplicadas en ejecución",0)  From GESECRAN
Filter [F:YABR] Where [F:YABR]TACHE = 'ZSNDCONCIL' and [F:YABR]ETAT = 'ZEXPCONCIL'
&                 and [F:YABR]DOSSIER = 'RBI'      and [F:YABR]CODABT = 'ZSNDCONRBI'
&                 and [F:YABR]FLAG = 2
If rowcount([F:YABR]) > 1
  Call ECR_TRACE ("Existen tareas ZSNDCONCIL duplicadas en ejecución",0)  From GESECRAN
  WERROR_TAREA = 1
Endif
Filter [YABR]
#
If WERROR_TAREA = 1
##Enviar mail si hay error
  Local Integer  WSTA
  Local Integer  WTRACE
  Local Char     FIC_TRACE(250)
  Local Char     ISSUERMAIL(250)
  Local Char     A_USER(250)(1..)
  Local Char     CC_USER(250)(1..)
  Local Char     HEADER(250)
  Local Clbfile  BODY(0)
  Local Char     ATTACHMENTS(250)(1..)
  A_USER(1)="cristian.perez@rbiberia.com"
  CC_USER(1)="arancha.dolico@rbiberia.com"
  HEADER="ZEXPCONCIL error tareas duplicadas en servidor batch  " + PFICHERO
  ISSUERMAIL="comunicaciones.administracion@rbiberia.com"
  TRACE = 2

  WSTA =func ASYRMAIL.ASEND_MAIL(GACTX,ISSUERMAIL,A_USER,CC_USER,HEADER,BODY,ATTACHMENTS,WTRACE)
  If WSTA <> CST_AOK Then
    Call ECR_TRACE ("Error envio mail tareas duplicadas ZSNDCONCIL ",0)  From GESECRAN
  Else
    Call ECR_TRACE ("Enviado mail tareas duplicadas ZSNDCONCIL ",0)  From GESECRAN
  Endif
Endif

Return
#Fin <ALI03>
################################################################################

#**
#* Este proceso revisa la vista ZYCONCILERR
#* En esta vista visualizamos los registros que están marcados como enviados
#* pero no se encuuentran en la tabla de enviado.
#* Si encontramos algún registros, lo volveremos a marcar como pendiente de enviar.
#* De esta manera en la siguiente ejecución del proceso se enviarán a XRT
#*!
Subprog REVISAR_VISTA_ERRORES()
  Call ECR_TRACE ("REVISAR_VISTA_ERRORES",0)  From GESECRAN
  Infbox "DENTRO"
  If clalev([ZYERR]) = 0 : Local File ZYCONCILERR [ZYERR]  : Endif

  # Filter [ZYERR]
  Call ECR_TRACE ("REVISAR_VISTA_ERRORES - Registros:" + num$(rowcount([ZYERR])),0)  From GESECRAN
  #Infbox "REGISTRO ENCONTRADOS: " + num$(rowcount([ZYERR]))
  If rowcount([ZYERR]) > 0 Then
    If !clalev([F:GACC])  Then : Local File GACCENTRY [GACC] : Endif
    If !clalev([F:GACD])  Then : Local File GACCENTRYD [GACD] : Endif
    If !clalev([F:FACA])  Then : Local File GACCENTRYA [GACA] : Endif

    For [F:ZYERR]  With Nohint # With Stability
       #Infbox [F:ZYERR]NUM
       Trbegin [F:GACC]
            # GACCENTRY
            Update [F:GACC] Where NUM=[F:ZYERR]NUM and TYP=[F:ZYERR]TYP and CPY=[F:ZYERR]CPY and ZSNDXRT = 2 With ZSNDXRT = 1
            Commit
            #GACCENTRYD
            Trbegin [F:GACD]
            Update [F:GACD] Where NUM=[F:ZYERR]NUM and TYP=[F:ZYERR]TYP and CPY=[F:ZYERR]CPY and ZSNDXRT = 2 With ZSNDXRT = 1
            Commit
            #GACCENTRYA
            Trbegin [F:GACA]
            Update [F:GACA] Where NUM=[F:ZYERR]NUM and TYP=[F:ZYERR]TYP and CPY=[F:ZYERR]CPY and ZSNDXRT = 2 With ZSNDXRT = 1
            Commit
    Next


    Close File [GACC]
    Close File [GACD]
    Close File [GACA]
  Endif
  Call ECR_TRACE ("REVISAR_VISTA_ERRORES - Fin revisión",0)  From GESECRAN
  Close File [ZYERR]
End
