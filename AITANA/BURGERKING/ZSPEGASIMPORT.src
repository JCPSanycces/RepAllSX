#<AdxTL>@(#)0.0.0.0 $Revision$ 
######################################################################################
$ACTION

#  If !clalev([F:PTR])  Then : Global File PURTRS [PTR] : Endif
#  If !clalev([F:PTH])  Then : Global File PRECEIPT [PTH] : Endif
#  If !clalev([F:ATB])  Then : Global File ATABLE [ATB] : Endif
#  Global  Integer  COUNTERFOUND : COUNTERFOUND=0
#  YGAS/YVAR/YTRA/YDES/YALB/


  Case ACTION
    When "IMP_AVANT_OUVRE"  : Gosub $IMP_AVANT_OUVRE
    When "AP_IMPORT"        : Gosub $AP_IMPORT
    When "IMP_FERME"       : Gosub $IMP_FERME # Cuando termina el proceso de import

    #  When "IMP_INICRE" : Gosub IMP_INICRE


    When Default
  Endcase
  Return

$OUVRE
    Gosub OUVRE From GASIMPORT
  Return

$RAZCRE
    Gosub RAZCRE From GASIMPORT
  Return

$VALID
    Local Char FICHERO_INVERSION(200)
    Local Date LFECHA_INVERSION
    Local Char FICHERO_INVERSION(200)
    Local Char ASIENTO_ORIGEN, TYPE_ORIGEN, FCY_ORIGEN, ASIENTO_CREADO
    Local Char LPROV_AUX
    Local Char LFECHA(10), LHORA(10) : Raz LFECHA, LHORA

    Gosub VALID From GASIMPORT
    # MAB20190213.NEW
    # Ańadimos al nombre del fichero de inversión la fecha hora
    LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
    LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)



    #      Infbox "Destro de VALID: ASIENTO: " + [F:HAE]NUM + " - " + [F:DAA]CCE(0)
    # COMPROBACIÓN DE QUE EL ASIENTO SE HA CREADO
      GCENTRO_COSTE =  [F:DAA]CCE(0)
      If [F:HAE]NUM <> "" Then
      #  Infbox "Asiento creado: " + [F:HAE]NUM
      #  Infbox "Sección análitica: " + [F:DAA]CCE(0)

          If [M:DIA]MODIMP = "YVAR" or [M:DIA]MODIMP = "Y2VAR"  Then

           # MARCAR ASIENTO IMPORTADO EN EL FICHERO COMO IMPORTADO. ESTO SE QUITA A PETICIÓN DE JOSE ZAMARRA

           If !clalev([F:HAEAUX])  Then : Global File GACCENTRY [HAEAUX] : Endif
            Trbegin [F:HAEAUX]
            # ACTUALIZAMOS ASIENTO COMO IMPORTADO, Y A INVERTIR A FECHA CONTABLE + 1
            If [M:DIA]MODIMP = "YVAR"   Then
              Update [F:HAEAUX] Where [F:HAEAUX]NUM=[F:HAE]NUM and [F:HAEAUX]TYP=[F:HAE]TYP and [F:HAEAUX]CPY=[F:HAE]CPY With [F:HAEAUX]ZCCE = GCENTRO_COSTE, [F:HAEAUX]RVS = 2, [F:HAEAUX]RVSDAT=[F:HAE
& ]ACCDAT+1 #, [F:HAEAUX]ZSTAIMP = "1" # MAB13022019.OLD SE QUITA LA MARCA DE IMPORTACION
      # Cada quincena se ejecuta el modelo Y2VAR, y no el modelo YVA.
      # Cuando se cargan los asientos de Y2VAR, no se marcan como importados, y ese día
      # no se ejecuta el modelo YVAR, por lo tanto, al día siguiente que se ejecute
      # el modelo YVAR fallaria la importación.
            Endif
            If [M:DIA]MODIMP = "Y2VAR"  Then
              Update [F:HAEAUX] Where [F:HAEAUX]NUM=[F:HAE]NUM and [F:HAEAUX]TYP=[F:HAE]TYP and [F:HAEAUX]CPY=[F:HAE]CPY With [F:HAEAUX]ZCCE = GCENTRO_COSTE, [F:HAEAUX]RVS = 2, [F:HAEAUX]RVSDAT=[F:HAE
& ]ACCDAT+1
            Endif
            If fstat = 0 Then
               Commit
               # Infbox "Record modificador:" -num$(adxuprec)
            Else
               Rollback
            Endif
            Close File [HAEAUX]
        Endif

          # Si es un asiento de modificación, DEBE DE TENER LA REFERENCIA DE TIM HORTON, crear un asiento de reversión
          If [F:HAE]REF <> '' and [M:DIA]MODIMP <> "YVAR" and [M:DIA]MODIMP <> "Y2VAR"  Then
            #Infbox "referencia:" + [F:HAE]REF
            ASIENTO_ORIGEN = [F:HAE]REF # REFERENCIA DE TIM HORTON
            TYPE_ORIGEN = [F:HAE]TYP
            FCY_ORIGEN = [F:HAE]FCY
            ASIENTO_CREADO = [F:HAE]NUM
            #Infbox "ASIENTO ORIGEN:" + ASIENTO_ORIGEN + " - TIPO: " + TYPE_ORIGEN + " PLANTA: " + FCY_ORIGEN
            #If [F:HAE]DESVCR = 'SI' Then # Esto lo sustituiré por el campo Modificación SI/NO # MAB.BURKING22.old
              FICHERO_INVERSION = "INV" + [M:DIA]MODIMP + "_" + ASIENTO_ORIGEN + "_" + TYPE_ORIGEN + "_" + FCY_ORIGEN + "_" + LFECHA + "_" + LHORA
              [F:HAE]NUM="" # ASIENTO NUEVO EN BLANCO
              FICHERO_INVERSION = ctrans(FICHERO_INVERSION,'/','_')
              # Crear el fichero de import de la reversión
                #Infbox FICHERO_INVERSION
               # Infbox "Llamada a crear inversion: Fichero:" + FICHERO_INVERSION
                Call CREAR_INVERSION(ASIENTO_ORIGEN, ASIENTO_CREADO, TYPE_ORIGEN,FCY_ORIGEN,FICHERO_INVERSION, [M:DIA]MODIMP, [F:HAE]ACCDAT,GCENTRO_COSTE)
                # Call IMPORT_INVERSION(FICHERO_INVERSION)

            # Endif MAB.BURKING22.old
           Endif

      Endif

  Return

$SAIMSK
    Gosub SAIMSK From GASIMPORT
     Return

$IMP_FERME
  # Infbox NOMBRE_AUX
  #GSILENCE=1
  #Call IMPORTSIL("YGASINV", NOMBRE_AUX)  From GIMPOBJ
  Return

#######################################################################################
#$IMPORT
#
#  Return

#######################################################################################Ç
$IMP_AVANT_OUVRE
    Global Integer LREG_IMPOR_HOY
    Global Integer LREG_IMPOR_AYER
    Global  Integer  COUNTERFOUND : COUNTERFOUND=0
    Global  Integer  COUNTERYVAR : COUNTERYVAR=0
    # Si el tipo de importación es YVAR, hacer un tratamiento especial
    If [M:DIA]MODIMP = "YVAR" or [M:DIA]MODIMP = "Y2VAR"  Then
      # Buscar fecha de ultimo asiento VAR de la planta en la que estoy
      # Invertir todos los asientos a la fecha que encontremos.
      #Infbox "RESETEO - COUNTERYVAR = 1"
      COUNTERYVAR = 1
    Endif
Return

#######################################################################################
#**
#*
#*!
$AP_IMPORT
  # MAB.BURKING22. Se revisarán todos los asientos por la referencia
  #                Si el asiento perteneciente a la referencia, existe, se realizará la reversión.

  # MAB.BURKING22. Asientos de tipo YVAR. Generar asientos de inversión, para los asientos sin revertir
  #                y que la fecha de asiento sea igual a la fecha máxima de los asientos encontrados
  #                sin revertir.
  Local Char FICHERO_INVERSION(200)
  Local Char ASIENTO_ORIGEN, TYPE_ORIGEN, FCY_ORIGEN
  Local Char LPROV_AUX
  Local Integer CONT
  Local Date LFECHA

#  CURRDATETIME_STR=format$("D:YYYYMMDDhhmmss",datetime$)
#  FICHERO= "EV" + num$(CURRDATETIME_STR)



  Case [L]IMPFIC
    When "HAE"

      If [F:HAE]REF <> '' and [M:DIA]MODIMP <> "YVAR" and [M:DIA]MODIMP <> "Y2VAR"  Then
          [F:HAE]NUM="" # ASIENTO NUEVO EN BLANCO
      Endif

            If !COUNTERFOUND Then
                COUNTERFOUND = 1
            Endif
             # VERIFICAR QUE EXISTE ASIENTOS SIN INVERTIR A FECHA-1
             # SI EXISTE ALGUN ASIENTO IMPORTADO A FECHA-1 QUIERE DECIR QUE YA SE HA LANZADO
             # LA IMPORTACION PARA ESE DÍA, POR LO TANTO NO HAY QUE REALIZAR LA INVERSIÓN
#             Infbox " busco registros a fecha del fichero -1: " + num$([F:HAE]ACCDAT-1)
#             # MAB13022019.001.SOLD
#             # SE QUITA EL CONTROL DE ENTRADA DE LOS ASIENTOS VAR A PETICIÓN DE JOSE ZAMARRA
#
#             If COUNTERYVAR = 1 and  [M:DIA]MODIMP = "YVAR"  Then
##             [F:HAE]RVS = 2
##             [F:HAE]RVSDAT = [F:HAE]ACCDAT+1
#               LFECHA = [F:HAE]ACCDAT-1
#               If !clalev([F:ZHAE3])  Then : Local File GACCENTRY [ZHAE3] : Endif
#              # Filter [ZHAE3] Where  ZSTAIMP = "1" and (ACCDAT = [F:HAE]ACCDAT) # MAB25092018.OLD
#              #  Filter [ZHAE3] Where  ZSTAIMP = "1" and (ACCDAT = [F:HAE]ACCDAT) and FCY = [F:HAE]FCY and TYP = 'VAR'  # MAB13022019.OLD
#                # MAB13022019.NEW.001
#                Filter [ZHAE3] Where  (ACCDAT = [F:HAE]ACCDAT) and FCY = [F:HAE]FCY and TYP = 'VAR' # MAB13022019.NEW
#                LREG_IMPOR_HOY = rowcount([F:ZHAE3])
#                # Filter [ZHAE3] Where  ZSTAIMP = "1" and ACCDAT = [F:HAE]ACCDAT-1 # MAB25092018.OLD
#                # Filter [ZHAE3] Where  ZSTAIMP = "1" and ACCDAT = [F:HAE]ACCDAT-1 and FCY = [F:HAE]FCY and TYP = 'VAR' # MAB13022019.OLD
#                # MAB13022019.NEW.001
#                Filter [ZHAE3] Where ACCDAT = [F:HAE]ACCDAT-1 and FCY = [F:HAE]FCY and TYP = 'VAR'
#                LREG_IMPOR_AYER = rowcount([F:ZHAE3])
#                #Infbox "REGISTROS ENCONTRADOS YA INVERTIDOS HOY: " + num$(LREG_IMPOR_HOY )
#                #Infbox "REGISTROS ENCONTRADOS YA INVERTIDOS AYER: " + num$(LREG_IMPOR_AYER )
#                If LREG_IMPOR_HOY > 0 or LREG_IMPOR_AYER = 0 Then # EXISTE YA UNA IMPORTACION O NO SE HIZO LA IMPORTACION AYER, CANCELAR IMPORT
#                    [F:HAE]TYP = "999" # Esto hará que el asiento no se genere
#                    [F:HAE]NUM = ""
#                    # Infbox "DENTRO DE LIMPIEZA"
#                Endif
#                Close File [ZHAE3]
#                COUNTERYVAR = 2
#            Endif
#            # COMPRUEBA LOS CONTADORES DE REGISTROS PARA TODAS LAS CABECERAS DE ASIENTOS
#            If [M:DIA]MODIMP = "YVAR"  Then
#              If LREG_IMPOR_HOY > 0 or LREG_IMPOR_AYER = 0 Then # EXISTE YA UNA IMPORTACION O NO SE HIZO LA IMPORTACION AYER, CANCELAR IMPORT
#                    [F:HAE]TYP = "999" # Esto hará que el asiento no se genere
#                    [F:HAE]NUM = ""
#                    # Infbox "DENTRO DE LIMPIEZA"
#              Endif
#            Endif
#            # MAB13022019.001.EOLD

    When "DAE"
      If [M:DIA]MODIMP = "YALB" or [M:DIA]MODIMP = "XBIS" Then
        #Infbox "Busca proveedor:" + [M:DIA]MODIMP + " - fcy" +  [F:HAE]FCY + " - bpr:" +[F:DAE]BPR
        LPROV_AUX = (func ZSPEGASIMPORT.BUSCAR_PROVEEDOR_SAGE([M:DIA]MODIMP, [F:HAE]FCY, [F:DAE]BPR))
        If LPROV_AUX <> "" Then
          [F:DAE]BPR = LPROV_AUX
        Endif
      Endif

      If [M:DIA]MODIMP = "YALB" Then
          If [F:DAE]ACC = "402000" and [F:DAE]LEDTYP = 1 Then
            [F:DAE]TAX = "SPALB"
          Endif
      Endif
    When "DAA"
    When Default
  Endcase


  Return

