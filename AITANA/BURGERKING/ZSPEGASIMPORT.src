#**
#*
#* 1 - Buscar fecha de ultimo asiento VAR de la planta en la que estoy
#* 2 - Invertir todos los asientos a la fecha que encontremos.
#*
#*!
Subprog INVERSION_ASIENTO_VAR(PTYP, PFCY, PFEC_INVERSION, PCENTRO_COSTE)
  Local Char FICHERO_INVERSION(200)
  Local Char LDOSSIER
  Local Date LFECHA
  Local Date LFECHA_INVERSION
  Local Char REQSTR(250)(10)

Local Char REQSTR2(250)(10)

  LDOSSIER = [S]nomap(0)
  # Infbox "Dentro de inversión YVAR:" + LDOSSIER + " - CCE: " + [F:DAA]CCE(0)
   #If !clalev([F:HAE1])  Then : Local File GACCENTRY [HAE1] : Endif
  #Filter [HAE] Where TYP=PTYP and FCY=PFCY and RVS = 2 Order By Key HAE4 Desc
  #  For (Date LMAX_FECHA) From num$((GTYPDBA*2)+1) Sql "SELECT MAX(ACCDAT_0) AS LMAX_FECHA FROM GACCENTRY " +
#& " WHERE RVSORITYP_0 = '' AND RVSORINUM_0 = '' AND FCY_0 = " + PFCY + " AND RVS_0 = 1 AND TYP_0 = '" + PTYP + "'" As [GAC]

#  REQSTR(0) = "SELECT MAX(ACCDAT_0) AS LMAX_FECHA FROM GACCENTRY " +
#& " WHERE RVSORITYP_0 = '' AND RVSORINUM_0 = '' AND FCY_0 = " + PFCY + " AND RVS_0 = 1 AND TYP_0 = '" + PTYP + "'"
#
#  For (Date LMAX_FECHA) From num$((GTYPDBA*2)+1) Sql REQSTR(0..9) As [GAC]
##& " AND B.TYP_0 = A.TYP_0 AND B.NUM_0 = A.NUM_0 AND B.CPY_0 = A.CPY_0 AND B.FCYLIN_0 = A.FCY_0 AND B.CCE_0 = '6803'"   As [GAC]
#    LFECHA = [GAC]LMAX_FECHA
#  Next
  #Infbox "CENTRO DE COSTE: " + [F:DAA]CCE(0)
  #Infbox "FECHA ENCONTRADA A REVERTIR:" + num$(LFECHA)

  #Infbox "FECHA: " + num$(LFECHA) + " - Centro de coste: " + PCENTRO_COSTE
  LFECHA = PFEC_INVERSION-1
  If !clalev([F:ZHAE1])  Then : Local File GACCENTRY [ZHAE1] : Endif
  Filter [ZHAE1] Where RVSORITYP = "" and RVSORINUM = "" and  TYP=PTYP and FCY=PFCY and RVS = 1  and ACCDAT = LFECHA and ZCCE = PCENTRO_COSTE Order By Key HAE4 Desc #
  Infbox "Registros encontrados DENTRO DE YVAR:" + num$(rowcount([ZHAE1]))
  For [ZHAE1]
      #Infbox [F:HAE1]NUM + [F:HAE1]FCY
      FICHERO_INVERSION = "INV" + [M:DIA]MODIMP + "_" + [F:ZHAE1]NUM + "_" + [F:ZHAE1]TYP + "_" + num$([F:ZHAE1]FCY)
      FICHERO_INVERSION = ctrans(FICHERO_INVERSION,'/','_')
      LFECHA_INVERSION = PFEC_INVERSION
      Call CREAR_INVERSION([F:ZHAE1]NUM,[F:ZHAE1]NUM, [F:ZHAE1]TYP, [F:ZHAE1]FCY, FICHERO_INVERSION, [M:DIA]MODIMP, LFECHA_INVERSION, PCENTRO_COSTE)
  Next
  Filter [ZHAE1]




End
#######################################################################################
#**
#* @param PTYP
#* @param PFCY
#* @param PFEC_INVERSION
#*!
Subprog INVERSION_ASIENTO_Y2VAR(PTYP, PFCY, PFEC_INVERSION, PCENTRO_COSTE)
  Local Char FICHERO_INVERSION(200)
  Local Char LDOSSIER
  Local Date LFECHA
  Local Date LFECHA_INVERSION
  LDOSSIER = [S]nomap(0)
  # BUSCAR ASIENTO A FECHA DEL ASIENTO QUE ESTOY INSERTANDO...
  #Infbox "FECHA ENCONTRADA A REVERTIR:" + num$(LFECHA)
  If !clalev([F:ZHAE1])  Then : Local File GACCENTRY [ZHAE1] : Endif
  Filter [ZHAE1] Where RVSORITYP = "" and RVSORINUM = "" and TYP=PTYP and FCY=PFCY and RVS = 1 and ACCDAT = PFEC_INVERSION Order By Key HAE4 Desc
  #Infbox "Registros encontrados:" + num$(rowcount([HAE1]))
  # SI ENCUENTRO, CREAR INVERSIÓN A FECHA Y CUENTA DE ASIENTO ENCONTRADO
  For [ZHAE1]
      #Infbox [F:HAE1]NUM + [F:HAE1]FCY
      FICHERO_INVERSION = "INV" + [M:DIA]MODIMP + "_" + [F:ZHAE1]NUM + "_" + [F:ZHAE1]TYP + "_" + num$([F:ZHAE1]FCY)
      FICHERO_INVERSION = ctrans(FICHERO_INVERSION,'/','_')
      LFECHA_INVERSION = [F:ZHAE1]ACCDAT
      Call CREAR_INVERSION([F:ZHAE1]NUM,[F:ZHAE1]NUM, [F:ZHAE1]TYP, [F:ZHAE1]FCY, FICHERO_INVERSION, [M:DIA]MODIMP, LFECHA_INVERSION, PCENTRO_COSTE)
  Next
  Filter [ZHAE1]

  # PASO 3. BUSCAR ASIENTO INVERTIDO DEL DIA SIGUIENTE A LA FECHA QUE ME VIENE EN EL FICHERO INICIAL
  Filter [ZHAE1] Where RVSORITYP = "" and RVSORINUM = "" and TYP=PTYP and FCY=PFCY and RVS = 3 and ACCDAT = PFEC_INVERSION + 1 Order By Key HAE4 Desc
  #Infbox "Registros encontrados:" + num$(rowcount([HAE1]))
  #
  For [ZHAE1]
      #Infbox [F:HAE1]NUM + [F:HAE1]FCY
      FICHERO_INVERSION = "INV" + [M:DIA]MODIMP + "_NORMAL_" + [F:ZHAE1]NUM + "_" + [F:ZHAE1]TYP + "_" + num$([F:ZHAE1]FCY)
      FICHERO_INVERSION = ctrans(FICHERO_INVERSION,'/','_')
      LFECHA_INVERSION = [F:ZHAE1]ACCDAT
      # Paso 3.1. Crear asiento NORMAL
      Call CREAR_ASIENTO_NORMAL([F:ZHAE1]NUM, [F:ZHAE1]TYP, [F:ZHAE1]FCY, FICHERO_INVERSION, [M:DIA]MODIMP, LFECHA_INVERSION)
      # Paso 3.2. Crear asiento de INVERSIÓN CON FECHA DEL DÍA SIGUIENTE, CON LOS DATOS QUE ME VIENEN
      #           EN EL FICHERO
      # Esto se ejecuta al finalizar la importación de cada asiento
      # Call CREAR_INVERSION_Y2VAR("", PTYP, PFCY, FICHERO_INVERSION, [M:DIA]MODIMP, LFECHA_INVERSION + 1)

  Next
  Filter [ZHAE1]





End




#**
#*
#*
#* @param PNUM Referencia de Tim Horton
#* @param PTYP Tipo de asiento
#* @param PFCY Planta
#* @param PFICHERO_INVERSION Fichero que se generará para la inversión
#* @param PMODELO_IMPORT     Modelo de importación
#*!
Subprog CREAR_INVERSION(PNUM, PASIENTO_CREADO, PTYP, PFCY, PFICHERO_INVERSION, PMODELO_IMPORT, PFECHA_INVERSION, PCENTRO_COSTE)
  Local Char FICEXP(200)
  Local Char LNUM, LTYP, LFCY
  Local Date LACCDAT
  Local Char LPROV

  FICEXP = PFICHERO_INVERSION
  LNUM = PNUM
  LTYP = PTYP
  LFCY = PFCY
  #Creacion de fichero BAT
  #Infbox "Crear fichero"

#   Infbox "CREAR_InVERSIÓN:ref " + PNUM + " - MODELO :" + PMODELO_IMPORT + " - pasiento_creado: "  + PASIENTO_CREADO
#   Infbox "ltyp:" + LTYP + " - FCY: " + LFCY
  adxifs=';'
  adxirs = chr$(13) + chr$(10)
#Infbox "1"
  # leer la cabecera del asiento
  If !clalev([F:ZHAE2])  Then : Local File GACCENTRY [ZHAE2] : Endif
  #If !clalev([F:ZHAA2])  Then : Local File GACCENTRYA [ZHAA2] : Endif
#Infbox "2"
  # CAMBIAR LOS VALORES FIJOS POR LOS VALORES QUE LEAMOS EN EL FICHERO IMPORT
  # EN EL CAMPO REF TENEMOS LA REFERENCIA DE TIM HORTONS
  # HAY QUE COGER EL ASIENTO MÁS ACTUAL
  If PMODELO_IMPORT = 'YVAR' or PMODELO_IMPORT = 'Y2VAR'  Then # Realizar la búsqueda por numero de asiento de X3
    Filter [ZHAE2]  Where NUM=LNUM and TYP=LTYP and FCY=LFCY and RVS = 1 and RVSORINUM = "" and NUM <> [F:HAE]NUM Order By NUM Desc
  Else
  #  Infbox "3"
    Filter [ZHAE2] Where REF=LNUM and NUM <> PASIENTO_CREADO and TYP=LTYP and FCY=LFCY and RVS = 1 and RVSORINUM = "" and NUM <> [F:HAE]NUM Order By NUM Desc
  #  Infbox "4"
  Endif
  # Infbox "Registros encontrados REF: " + LNUM + " --> " + num$(rowcount([ZHAE2]))
  If rowcount([ZHAE2]) > 0 Then
     Read [ZHAE2] First
     # Infbox "busco registros EN GACCENTRYA NUM - " + [F:ZHAE2]NUM + "- FCYLIN:"  + [F:ZHAE2]FCY + " - CPY " + [F:ZHAE2]CPY + " - " + PCENTRO_COSTE
     #Filter [ZHAA2] Where NUM = [F:ZHAE2]NUM and FCYLIN = [F:ZHAE2]FCY and CPY = [F:ZHAE2]CPY #and CCE(0) = PCENTRO_COSTE
     # Infbox "Registros encontrados del centro: " + PCENTRO_COSTE + " -> "+ num$(rowcount([ZHAA2]))
     #If rowcount([ZHAA2]) > 0 Then
        Openo filpath("IMP", FICEXP, "csv",nomap)
        For [ZHAE2] #Where REF=LNUM and TYP=LTYP and FCY=LFCY Order
            #Infbox "Dentro for HAE"
            #Buscar detalle del asiento y comprobar el la sección analitica es igual a la del asiento creado

           # Infbox "registro encontrado + " + [F:ZHAA2]NUM
            LTYP = [F:ZHAE2]TYP
            LNUM = [F:ZHAE2]NUM
            LFCY = [F:ZHAE2]FCY
            If PMODELO_IMPORT = 'YVAR'  Then
               # LACCDAT = date$          # MAB20180706.OLD
               LACCDAT = PFECHA_INVERSION # MAB20180706.NEW - MODIFICACION SOLICITADA POR ROBERTO. INVERSIÓN A FECHA DEL ASIENDO ORIGINAL A IMPORTAR
            Else
               LACCDAT = [F:ZHAE2]ACCDAT # Fecha del asiento encontrado
            Endif
            # Wrseq 'G',[F:HAE]TYP,"",[F:HAE]FCY,[F:HAE]JOU,[F:HAE]ACCDAT,[F:HAE]REF,[F:HAE]CUR,[F:HAE]DACDIA,1,"",[F:HAE]TYP,[F:HAE]NUM, LTYP + " " + LNUM + " Invertido"
            Wrseq 'G',[F:ZHAE2]TYP,"",[F:ZHAE2]FCY,[F:ZHAE2]JOU,LACCDAT,[F:ZHAE2]REF,[F:ZHAE2]CUR,[F:ZHAE2]DACDIA,1,"",[F:ZHAE2]TYP,[F:ZHAE2]NUM, LTYP + " " + LNUM + " Invertido"

            #Infbox "Actulizo asiento:" + LNUM
             # Actulizar el asiento para indicar que es un asiento revertivo --> CAMPO RVS = 3
            If !clalev([F:HAEAUX])  Then : Global File GACCENTRY [HAEAUX] : Endif
            Trbegin [F:HAEAUX]

            Update [F:HAEAUX] Where [F:HAEAUX]NUM=LNUM and [F:HAEAUX]TYP=LTYP and [F:HAEAUX]FCY=LFCY With [F:HAEAUX]RVS=3, [F:HAEAUX]RVSDAT=datetime$
            If fstat = 0 Then
               Commit
               # Infbox "Record modificador:" -num$(adxuprec)
            Else
               Rollback
            Endif

          #Filter [ZHAA2]
         Break # solo leemos el primer registro, que se supone que es el último generado
        Next

          #Infbox LTYP
          #Infbox LNUM
          #Infbox LFCY

          If !clalev([F:ZDAE2])  Then : Local File GACCENTRYD [ZDAE2] : Endif
          # CAMBIAR LOS VALORES FIJOS POR LOS VALORES QUE LEAMOS EN EL FICHERO IMPORT
          Filter [ZDAE2] Where NUM=LNUM and TYP=LTYP and FCYLIN = LFCY
          For [ZDAE2]
            #Infbox "Dentro de DAE"
            # Para el modelo YALB buscar el proveedor correspondiente
            #If [M:DIA]MODIMP = "YALB" Then
               # LPROV = (func ZSPEGASIMPORT.BUSCAR_PROVEEDOR_SAGE(PMODELO_IMPORT, PFCY, [F:ZDAE2]BPR))
            #   LPROV = [F:ZDAE2]BPR
            #Else
               LPROV = [F:ZDAE2]BPR
            #Endif
            Wrseq 'D',[F:ZDAE2]LIN,[F:ZDAE2]LEDTYP,[F:ZDAE2]IDTLIN,[F:ZDAE2]FCYLIN,[F:ZDAE2]SAC,[F:ZDAE2]ACC,LPROV,LTYP + " " + LNUM + " Invertido",[F:ZDAE2]SNS*-1,[F:ZDAE2]AMTCUR,[F:ZDAE2]CUR

            If !clalev([F:ZDAA])  Then : Local File GACCENTRYA [ZDAA] : Endif
            # CAMBIAR LOS VALORES FIJOS POR LOS VALORES QUE LEAMOS EN EL FICHERO IMPORT
            Filter [ZDAA] Where NUM=[F:ZDAE2]NUM and TYP=[F:ZDAE2]TYP and FCYLIN=[F:ZDAE2]FCYLIN and LIN=[F:ZDAE2]LIN and LEDTYP=[F:ZDAE2]LEDTYP
            For [ZDAA]
              #Infbox "Dentro de DAA"
              Wrseq 'A',[F:ZDAA]ANALIN,[F:ZDAA]DIE(0),[F:ZDAA]CCE(0),[F:ZDAA]DIE(1),[F:ZDAA]CCE(1),[F:ZDAA]DIE(2),[F:ZDAA]CCE(2),[F:ZDAA]DIE(3),[F:ZDAA]CCE(3),[F:ZDAA]DIE(4),[F:ZDAA]CCE(4),[F:ZDAA]
& AMTCUR
            Next
            Filter [ZDAA]
          Next
          Filter [ZDAE2]
        Openo

      Endif

    #Endif

  # Infbox "FIN INVERSION"
  # Call CREAR_JOB(FICEXP)

End


#**
#* CREAR_JOB(PFICHERO)
#*
#* @param PFICHERO
#*!
Subprog CREAR_JOB(PFICHERO)
  Global Char NOMBRE_AUX(250)


  NOMBRE_AUX = filpath("IMP", PFICHERO, "csv",nomap)

  Openo filpath("IMP/BATCH/JOB", PFICHERO, "job",nomap)
  Wrseq 'DOSSIER=PRODBAK'
  Wrseq 'LAN=SPA'
  Wrseq 'UTIL=ADMIN'
  Wrseq 'PASSE=BAABAA'
  Wrseq 'GRP='
  Wrseq 'TACHE=IMPORT'
  Wrseq 'DATE=20180101'
  Wrseq 'HEURE=0001'
  Wrseq 'MODIMP=YGASINV'
  Wrseq 'NOMIMP=' + NOMBRE_AUX
  Wrseq 'TYPEXP=2'
  Wrseq 'VOLFIL=[IMP]/' + PFICHERO + '.csv'
  Wrseq 'ZMODIMP=Import desde JOB'
  Openo

End

#**
#*
#*
#* @param PNUM Referencia de Tim Horton
#* @param PTYP Tipo de asiento
#* @param PFCY Planta
#* @param PFICHERO_INVERSION Fichero que se generará para la inversión
#* @param PMODELO_IMPORT     Modelo de importación
#*!
Subprog CREAR_ASIENTO_NORMAL(PNUM, PTYP, PFCY, PFICHERO_INVERSION, PMODELO_IMPORT, PFECHA_INVERSION)
  Local Char FICEXP(200)
  Local Char LNUM, LTYP, LFCY
  Local Date LACCDAT
  Local Char LPROV
  FICEXP = PFICHERO_INVERSION
  LNUM = PNUM
  LTYP = PTYP
  LFCY = PFCY
  #Creacion de fichero BAT
  #Infbox "Crear fichero"

  # Infbox "CREAR_IVERSIÓN:ref " + PNUM + " - MODELO :" + PMODELO_IMPORT
  # Infbox "ltyp:" + LTYP + " - FCY: " + LFCY
  adxifs=';'
  adxirs = chr$(13) + chr$(10)

  # leer la cabecera del asiento
  If !clalev([F:ZHAE2])  Then : Local File GACCENTRY [ZHAE2] : Endif
  # BUSCAR EL ASIENTO INVERTIDO
  If PMODELO_IMPORT = 'Y2VAR' Then # Realizar la búsqueda por numero de asiento de X3
    Filter [ZHAE2]  Where NUM=LNUM and TYP=LTYP and FCY=LFCY and RVS = 3 and RVSORINUM <> "" Order By NUM Desc
#  Else
#    Filter [ZHAE2] Where REF=LNUM and TYP=LTYP and FCY=LFCY and RVS = 1 and RVSORINUM = "" Order By NUM Desc
  Endif
  # Infbox "Registros encontrados REF: " + LNUM + " --> " + num$(rowcount([ZHAE2]))
  If rowcount([ZHAE2]) > 0 Then
    Openo filpath("IMP", FICEXP, "csv",nomap)
    For [ZHAE2] #Where REF=LNUM and TYP=LTYP and FCY=LFCY Order
      #Infbox "Dentro for HAE"
      LTYP = [F:ZHAE2]TYP
      LNUM = [F:ZHAE2]NUM
      LFCY = [F:ZHAE2]FCY
      If PMODELO_IMPORT = 'YVAR'  Then
         # LACCDAT = date$          # MAB20180706.OLD
         LACCDAT = PFECHA_INVERSION # MAB20180706.NEW - MODIFICACION SOLICITADA POR ROBERTO. INVERSIÓN A FECHA DEL ASIENDO ORIGINAL A IMPORTAR
      Else
         LACCDAT = [F:ZHAE2]ACCDAT # Fecha del asiento encontrado
      Endif
      # Wrseq 'G',[F:HAE]TYP,"",[F:HAE]FCY,[F:HAE]JOU,[F:HAE]ACCDAT,[F:HAE]REF,[F:HAE]CUR,[F:HAE]DACDIA,1,"",[F:HAE]TYP,[F:HAE]NUM, LTYP + " " + LNUM + " Invertido"
      Wrseq 'G',[F:ZHAE2]TYP,"",[F:ZHAE2]FCY,[F:ZHAE2]JOU,LACCDAT,[F:ZHAE2]REF,[F:ZHAE2]CUR,[F:ZHAE2]DACDIA,1,"",[F:ZHAE2]TYP,[F:ZHAE2]NUM, LTYP + " " + LNUM + " Invertido"

      #Infbox "Actulizo asiento:" + LNUM
       # Actulizar el asiento para indicar que es un asiento revertivo --> CAMPO RVS = 3
      If !clalev([F:HAEAUX])  Then : Global File GACCENTRY [HAEAUX] : Endif
      Trbegin [F:HAEAUX]

      Update [F:HAEAUX] Where [F:HAEAUX]NUM=LNUM and [F:HAEAUX]TYP=LTYP and [F:HAEAUX]FCY=LFCY With [F:HAEAUX]RVS=3, [F:HAEAUX]RVSDAT=datetime$
      If fstat = 0 Then
         Commit
         # Infbox "Record modificador:" -num$(adxuprec)
      Else
         Rollback
      Endif
     Break # solo leemos el primer registro, que se supone que es el último generado
    Next

      If !clalev([F:ZDAE2])  Then : Local File GACCENTRYD [ZDAE2] : Endif
      # CAMBIAR LOS VALORES FIJOS POR LOS VALORES QUE LEAMOS EN EL FICHERO IMPORT
      Filter [ZDAE2] Where NUM=LNUM and TYP=LTYP and FCYLIN = LFCY
      For [ZDAE2]
        #Infbox "Dentro de DAE"
        # Para el modelo YALB buscar el proveedor correspondiente
        #If [M:DIA]MODIMP = "YALB" Then
           # LPROV = (func ZSPEGASIMPORT.BUSCAR_PROVEEDOR_SAGE(PMODELO_IMPORT, PFCY, [F:ZDAE2]BPR))
        #   LPROV = [F:ZDAE2]BPR
        #Else
           LPROV = [F:ZDAE2]BPR
        #Endif
        Wrseq 'D',[F:ZDAE2]LIN,[F:ZDAE2]LEDTYP,[F:ZDAE2]IDTLIN,[F:ZDAE2]FCYLIN,[F:ZDAE2]SAC,[F:ZDAE2]ACC,LPROV,LTYP + " " + LNUM + " Normal",[F:ZDAE2]SNS*-1,[F:ZDAE2]AMTCUR,[F:ZDAE2]CUR

        If !clalev([F:ZDAA])  Then : Local File GACCENTRYA [ZDAA] : Endif
        # CAMBIAR LOS VALORES FIJOS POR LOS VALORES QUE LEAMOS EN EL FICHERO IMPORT
        Filter [ZDAA] Where NUM=[F:ZDAE2]NUM and TYP=[F:ZDAE2]TYP and FCYLIN=[F:ZDAE2]FCYLIN and LIN=[F:ZDAE2]LIN and LEDTYP=[F:ZDAE2]LEDTYP
        For [ZDAA]
          #Infbox "Dentro de DAA"
          Wrseq 'A',[F:ZDAA]ANALIN,[F:ZDAA]DIE(0),[F:ZDAA]CCE(0),[F:ZDAA]DIE(1),[F:ZDAA]CCE(1),[F:ZDAA]DIE(2),[F:ZDAA]CCE(2),[F:ZDAA]DIE(3),[F:ZDAA]CCE(3),[F:ZDAA]DIE(4),[F:ZDAA]CCE(4),[F:ZDAA]AMTCUR
        Next
        Filter [ZDAA]
      Next
      Filter [ZDAE2]
    Openo
  Endif
  # Infbox "FIN INVERSION"
End


#**
#* Crear INVERSION de Asiento que viene en el fichero
#*
#* @param PNUM Referencia de Tim Horton
#* @param PTYP Tipo de asiento
#* @param PFCY Planta
#* @param PFICHERO_INVERSION Fichero que se generará para la inversión
#* @param PMODELO_IMPORT     Modelo de importación
#*!
Subprog CREAR_INVERSION_Y2VAR(PNUM, PTYP, PFCY, PFICHERO_INVERSION, PMODELO_IMPORT, PFECHA_INVERSION)
  Local Char FICEXP(200)
  Local Char LNUM, LTYP, LFCY
  Local Date LACCDAT
  Local Char LPROV
  FICEXP = PFICHERO_INVERSION
  LNUM = PNUM
  LTYP = PTYP
  LFCY = PFCY
  #Creacion de fichero BAT
  #Infbox "Crear fichero"

  # Infbox "CREAR_IVERSIÓN:ref " + PNUM + " - MODELO :" + PMODELO_IMPORT
  # Infbox "ltyp:" + LTYP + " - FCY: " + LFCY
  adxifs=';'
  adxirs = chr$(13) + chr$(10)

  # leer la cabecera del asiento
  If !clalev([F:ZHAE2])  Then : Local File GACCENTRY [ZHAE2] : Endif

  # CAMBIAR LOS VALORES FIJOS POR LOS VALORES QUE LEAMOS EN EL FICHERO IMPORT
  # EN EL CAMPO REF TENEMOS LA REFERENCIA DE TIM HORTONS
  # HAY QUE COGER EL ASIENTO MÁS ACTUAL
  If PMODELO_IMPORT = 'YVAR' or PMODELO_IMPORT = 'Y2VAR'  Then # Realizar la búsqueda por numero de asiento de X3
    Filter [ZHAE2]  Where NUM=LNUM and TYP=LTYP and FCY=LFCY and RVS = 1 and RVSORINUM = "" Order By NUM Desc
  Else
    Filter [ZHAE2] Where REF=LNUM and TYP=LTYP and FCY=LFCY and RVS = 1 and RVSORINUM = "" Order By NUM Desc
  Endif
  # Infbox "Registros encontrados REF: " + LNUM + " --> " + num$(rowcount([ZHAE2]))
  If rowcount([ZHAE2]) > 0 Then
    Openo filpath("IMP", FICEXP, "csv",nomap)
    For [ZHAE2] #Where REF=LNUM and TYP=LTYP and FCY=LFCY Order
      #Infbox "Dentro for HAE"
      LTYP = [F:ZHAE2]TYP
      LNUM = [F:ZHAE2]NUM
      LFCY = [F:ZHAE2]FCY
      If PMODELO_IMPORT = 'YVAR'  Then
         # LACCDAT = date$          # MAB20180706.OLD
         LACCDAT = PFECHA_INVERSION # MAB20180706.NEW - MODIFICACION SOLICITADA POR ROBERTO. INVERSIÓN A FECHA DEL ASIENDO ORIGINAL A IMPORTAR
      Else
         LACCDAT = [F:ZHAE2]ACCDAT # Fecha del asiento encontrado
      Endif
      # Wrseq 'G',[F:HAE]TYP,"",[F:HAE]FCY,[F:HAE]JOU,[F:HAE]ACCDAT,[F:HAE]REF,[F:HAE]CUR,[F:HAE]DACDIA,1,"",[F:HAE]TYP,[F:HAE]NUM, LTYP + " " + LNUM + " Invertido"
      Wrseq 'G',[F:ZHAE2]TYP,"",[F:ZHAE2]FCY,[F:ZHAE2]JOU,LACCDAT,[F:ZHAE2]REF,[F:ZHAE2]CUR,[F:ZHAE2]DACDIA,1,"",[F:ZHAE2]TYP,[F:ZHAE2]NUM, LTYP + " " + LNUM + " Invertido"

      #Infbox "Actulizo asiento:" + LNUM
       # Actulizar el asiento para indicar que es un asiento revertivo --> CAMPO RVS = 3
      If !clalev([F:HAEAUX])  Then : Global File GACCENTRY [HAEAUX] : Endif
      Trbegin [F:HAEAUX]

      Update [F:HAEAUX] Where [F:HAEAUX]NUM=LNUM and [F:HAEAUX]TYP=LTYP and [F:HAEAUX]FCY=LFCY With [F:HAEAUX]RVS=3, [F:HAEAUX]RVSDAT=datetime$
      If fstat = 0 Then
         Commit
         # Infbox "Record modificador:" -num$(adxuprec)
      Else
         Rollback
      Endif
     Break # solo leemos el primer registro, que se supone que es el último generado
    Next

      #Infbox LTYP
      #Infbox LNUM
      #Infbox LFCY

      If !clalev([F:ZDAE2])  Then : Local File GACCENTRYD [ZDAE2] : Endif
      # CAMBIAR LOS VALORES FIJOS POR LOS VALORES QUE LEAMOS EN EL FICHERO IMPORT
      Filter [ZDAE2] Where NUM=LNUM and TYP=LTYP and FCYLIN = LFCY
      For [ZDAE2]
        #Infbox "Dentro de DAE"
        # Para el modelo YALB buscar el proveedor correspondiente
        #If [M:DIA]MODIMP = "YALB" Then
           # LPROV = (func ZSPEGASIMPORT.BUSCAR_PROVEEDOR_SAGE(PMODELO_IMPORT, PFCY, [F:ZDAE2]BPR))
        #   LPROV = [F:ZDAE2]BPR
        #Else
           LPROV = [F:ZDAE2]BPR
        #Endif
        Wrseq 'D',[F:ZDAE2]LIN,[F:ZDAE2]LEDTYP,[F:ZDAE2]IDTLIN,[F:ZDAE2]FCYLIN,[F:ZDAE2]SAC,[F:ZDAE2]ACC,LPROV,LTYP + " " + LNUM + " Invertido",[F:ZDAE2]SNS*-1,[F:ZDAE2]AMTCUR,[F:ZDAE2]CUR

        If !clalev([F:ZDAA])  Then : Local File GACCENTRYA [ZDAA] : Endif
        # CAMBIAR LOS VALORES FIJOS POR LOS VALORES QUE LEAMOS EN EL FICHERO IMPORT
        Filter [ZDAA] Where NUM=[F:ZDAE2]NUM and TYP=[F:ZDAE2]TYP and FCYLIN=[F:ZDAE2]FCYLIN and LIN=[F:ZDAE2]LIN and LEDTYP=[F:ZDAE2]LEDTYP
        For [ZDAA]
          #Infbox "Dentro de DAA"
          Wrseq 'A',[F:ZDAA]ANALIN,[F:ZDAA]DIE(0),[F:ZDAA]CCE(0),[F:ZDAA]DIE(1),[F:ZDAA]CCE(1),[F:ZDAA]DIE(2),[F:ZDAA]CCE(2),[F:ZDAA]DIE(3),[F:ZDAA]CCE(3),[F:ZDAA]DIE(4),[F:ZDAA]CCE(4),[F:ZDAA]AMTCUR
        Next
        Filter [ZDAA]
      Next
      Filter [ZDAE2]
    Openo
  Endif
  # Infbox "FIN INVERSION"
End

#**
#* Import modo silencioso
#*
#* @param PFICHERO_INVERSION
#*!
Subprog IMPORT_INVERSION(PFICHERO_INVERSION)

  Local Char FICEXP

  FICEXP = PFICHERO_INVERSION
  # lanzar IMPORTSIL
  If !GSERVEUR
    Call OUVRE_TRACE("Trace_YGASINV") From LECFIC
  Endif

#  Infbox "Llamada a IMPORSIL 2"

  Call IMPORTSIL("YGASINV",filpath("IMP", FICEXP, "csv")) From GIMPOBJ
  #"E:\Sage\X3V11BK\folders\PRODBAK\IMP\test_reversion999004.csv")

  If !GSERVEUR
      Call FERME_TRACE From LECFIC
  Endif

  #Call ERR_IMPORT([M:IMP2]STAT,MESSAGE) From GIMPOBJ

End

#**
#*
#* Sustituir proveedor TIM o BKS por proveedor SAGE
#*
#* @param PMODELO
#* @param LSOCIEDAD # 1000 TIM 2000 BKS
#*!
Funprog BUSCAR_PROVEEDOR_SAGE(PMODELO, PSOCIEDAD, PPROVEEDOR)
  Local Char LPROV
  Local Char LTIM
  Local Char LBKS

  LTIM = "1000"
  LBKS = "2000"

  If !clalev([F:ZBPR])  Then : Global File BPARTNER [ZBPR] : Endif
  # Si el modelo es YALB, sustituir el proveedor BK/TIM por el de Sage
  #

  LPROV = ""
  # Infbox "VOY A BUSCAR EL PROVEEDOR :" + PPROVEEDOR + " - PSociedad: " + PSOCIEDAD
  If PMODELO = "YALB" and PPROVEEDOR <> "" Then
    If PSOCIEDAD = LTIM Then
      # Infbox "Dentro de busqueda de TIM"
      Filter [ZBPR] Where XTIM = PPROVEEDOR

      # Infbox "Registros encontrados: " + num$(rowcount([ZBPR]))
      If rowcount([ZBPR]) = 1 Then
        Read [ZBPR] First
        LPROV = [F:ZBPR]BPRNUM
      Else
        LPROV = ""
      Endif
      Filter [ZBPR]
    Elsif PSOCIEDAD = LBKS Then
      # Infbox "Dentro de busqueda de BKS"
      Filter [ZBPR] Where XBKS = PPROVEEDOR
      If rowcount([ZBPR]) = 1 Then
        Read [ZBPR] First
        LPROV = [F:ZBPR]BPRNUM
      Else
        LPROV = ""
      Endif
      Filter [ZBPR]
    Endif
  Endif
   # Infbox "PROVEEDOR ENCONTRADO:" + LPROV

End LPROV

