#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
  Case ACTION
    When "IMP_AVANT_OUVRE"  : Gosub $IMP_AVANT_OUVRE
    When "AP_IMPORT"        : Gosub $AP_IMPORT
    When "IMP_FERME"       : Gosub $IMP_FERME # Cuando termina el proceso de import

    #  When "IMP_INICRE" : Gosub IMP_INICRE

    When Default
  Endcase
  Return

$IMP_AVANT_OUVRE
    Gosub ABRIR_TABLAS
#    # Si el tipo de importación es YVAR, hacer un tratamiento especial
#    If [M:DIA]MODIMP = "YVAR" or [M:DIA]MODIMP = "Y2VAR" Then
#      # Buscar fecha de ultimo asiento VAR de la planta en la que estoy
#      # Invertir todos los asientos a la fecha que encontremos.
#      #Infbox "RESETEO - COUNTERYVAR = 1"
#      COUNTERYVAR = 1
#    Endif
Return

$OUVRE


    Gosub OUVRE From GASIMPORT
  Return

$RAZCRE
    Gosub RAZCRE From GASIMPORT
  Return

Return



$AP_IMPORT

  Case [L]IMPFIC
    When "HAE"
      If [F:HAE]FREREF <> '' Then

        Filter [F:ZYCO] Where [F:ZYCO]IDMOVEMENT = [F:HAE]FREREF
        For [F:ZYCO]
            Filter [F:ZGACD] Where ACCNUM = [F:ZYCO]ACCNUM
            Read [F:ZGACD] First
            [F:ZGACD]FREREF = [F:ZYCO]IDCONTEO
            Rewrite
        Next

      Endif

 When Default
  Endcase




Return

$SAIMSK
    Gosub SAIMSK From GASIMPORT
     Return

$IMP_FERME
  # Infbox NOMBRE_AUX
  #GSILENCE=1
  #Call IMPORTSIL("YGASINV", NOMBRE_AUX)  From GIMPOBJ
  Return

$ABRIR_TABLAS
  If !clalev([F:ZYCO])  Then : Local File ZYCOMCONTEO [ZYCO] : Endif
  If !clalev([F:ZGACD])  Then : Local File GACCENTRYD [ZGACD] : Endif

Return


$CERRAR_TABLAS
  Close File [F:ZYCO]
  Close File [F:ZGACD]
Return

