#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog IMPORTA_DATAFONOS()
Local Integer CONTADOR

If !clalev([F:ZDAT])  Then : Global File ZDATAFONOS [ZDAT] : Endif
If !clalev([F:ZEXT])  Then : Global File ZFCYEXT [ZEXT] : Endif

  CONTADOR = 1
  adxifs = ';' : adxirs = chr$(13)+chr$(10)




    # Si existen registros los vuelvo en una tabla temporal


    # Openo LFICIMP Using [ZCONBCIL]

    For [ZDAT]  Where FCY = '806803DDDDDDDDDDDD' # PONGO ESTO PARA QUE NO FUNCIONE, POR SI SE EJECUTA POR ERROR
        Filter [F:ZEXT] Where ZFINRSPFCY = [F:ZDAT]SOCIEDAD and ZFCY = [F:ZDAT]FCY
        If (rowcount([F:ZEXT])) > 0 Then
          For [F:ZEXT]
            If [F:ZEXT]ZCODDATA1 = "" Then
                [F:ZEXT]ZCODDATA1 = [F:ZDAT]CODDATA
                CONTADOR += 1
            Elsif [F:ZEXT]ZCODDATA2 = "" Then
                [F:ZEXT]ZCODDATA2 = [F:ZDAT]CODDATA
                CONTADOR += 1
            Elsif [F:ZEXT]ZCODDATA3 = "" Then
                [F:ZEXT]ZCODDATA3 = [F:ZDAT]CODDATA
                CONTADOR += 1
            Endif

            Rewrite [ZEXT]
            #Commit
            # ACTUALIZAR GACCENTRY/GACCENTRYD/GACCENTRYA
          Next
       Endif # FIN TEMPORAL SOLO REGISTROS DE TIM
    Next

    Infbox "CONTADOR: "  + num$(CONTADOR)


End

