######################################################################################
Subprog AM_ZINVNUMSIMP(VALEUR)
Variable Char    VALEUR()
    [M:BIC1]INVNUM = VALEUR
    Affzo [M:BIC1]INVNUM
   # Infbox [M:BIC1]ZINVNUMSIMP
End


