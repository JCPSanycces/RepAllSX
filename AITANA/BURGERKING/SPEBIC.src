######################################################################################
## Etiqueta adida por el supervisor (pantalla BIC1) 01/10/2018 13:07:58 (ADMIN)
######################################################################################
Subprog C_ZINVNUMSIMP(VALEUR)
Variable Char    VALEUR()
  If VALEUR <> "" and   [M:BIC0]SIVTYP = "CAN" Then
    mkstat = 4
    [M:BIC1]INVNUM = VALEUR
    Affzo [M:BIC1]INVNUM
  Endif
End


