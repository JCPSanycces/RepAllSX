######################################################################################
$ACTION

  Case ACTION
    When "OUVRE" :  Gosub OUVRE
    When "LIENS" :  Gosub LIENS

   # When "ANNULE" : Gosub ANNULE
    When Default
  Endcase
Return


######################################################################################
$OUVRE
  If !clalev([F:ZSINV])  : Local File SINVOICE [ZSINV] : Endif # Tabla Facturas

Return

######################################################################################
$LIENS
 If [M:BIC0]SIVTYP = "CAN" and [M:BIC1]ZTCKINI <> "" and [M:BIC1]ZINVNUMSIMP = "" Then
    [M:BIC1]ZINVNUMSIMP = [M:BIC1]INVNUM
 Endif

Return






######################################################################################
## Etiqueta adida por el supervisor (pantalla BIC1) 17/07/2018 18:34:55 (ADMIN)
######################################################################################
Subprog C_ZTCKINI(VALEUR)
Variable Char    VALEUR()

Local Integer LCONT

If VALEUR <> "" and [M:BIC0]SIVTYP = "CAN" Then
   # Filter [ZSINV] Where ZTCKINI <= VALEUR and ZTCKEND >= VALEUR and SIVTYP = 'FAC'
  Filter [ZSINV] Where VALEUR >= ZTCKINI and VALEUR <= ZTCKEND and SIVTYP = 'FAC' and CPY = [M:BIC0]CPY
  LCONT = rowcount([ZSINV])
  If  LCONT = 1 Then
        Read [ZSINV] First
        [M:BIC1]INVNUM = [F:ZSINV]NUM
        [M:BIC1]ZINVNUMSIMP = [F:ZSINV]NUM
  Else
     If LCONT > 1 Then
      Infbox "Se han encontrado varias facturas para este ticket. Seleccione la b俍queda desde el campo Nｺ factura simplificada."
     Else
        [M:BIC1]INVNUM = ""
        [M:BIC1]ZINVNUMSIMP = ""
     Endif
  Endif
  Filter [ZSINV]

  Affzo [M:BIC1]INVNUM
  Affzo [M:BIC1]ZINVNUMSIMP
  mkstat = 4

Else
  [M:BIC1]INVNUM = ""
  [M:BIC1]ZINVNUMSIMP = ""
Endif

End


