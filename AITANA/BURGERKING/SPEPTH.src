$ACTION
Case ACTION
 When "INICRE_LIG"   : Gosub INICRE_LIG   From YSPEPTH
 When "INIMOD_LIG"   : Gosub INIMOD_LIG   From YSPEPTH
 When "PICKE"        : Gosub PICKE        From YSPEPTH
 When Default
Endcase
Return
