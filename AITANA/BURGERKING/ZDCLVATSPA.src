#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "BEFWRIDVS" : Gosub MOD_DCLVATSPA
 When Default
Endcase
Return


###############################################################################
$MOD_DCLVATSPA
  Call INSERTAR_TICKET()
  Call DATOS_EXTRA_GEN()
  Call SET_SIISEND()

#ALIVE retención repercutida RET5 la cambio a SP999, para que no aparezca, solo la soportada
If [F:DVS]TAXTYP='R' and [F:DVS]VAT='RET5'
 [F:DVS]VAT='SP999'
Endif
#ALIVE
Return
###############################################################################
#** Inserta tickets en la tabla de impuestos
#*
#*!
Subprog INSERTAR_TICKET()
  If [F:DVS]ORIMOD=3 # Se cambia a 3 en lugar de 5 a petición de Nacho
   If dim([F:SIH]ZTCKINI)>0: [F:DVS]TCKINI =vireblc([F:SIH]ZTCKINI,2): Endif
   If dim([F:SIH]ZTCKEND)>0: [F:DVS]TCKEND =vireblc([F:SIH]ZTCKEND,2): Endif
   If dim([F:SIH]ZTCKNUM)>0: [F:DVS]TCKNUM =[F:SIH]ZTCKNUM : Endif
   If dim([F:SIH]INVNUM)>0: [F:DVS]INVNUM =vireblc([F:SIH]INVNUM,2): Endif

  Endif

End

###############################################################################
#**
#* Inserta datos extra de GENERICOS
#*!
Subprog DATOS_EXTRA_GEN()
  # PARA LAS FACTURAS QUE VIENEN DE NOTAS DE GASTO, RECUPERAR EL CIF Y LA RAZON SOCIAL
  # AŃADO LOS TIPOS DE FACTURA ANG Y FAS # 09/01/2019 # POR ELIANA DE EY

  If [F:DVS]TYP = 'FNG' or [F:DVS]TYP = 'ANG' or [F:DVS]TYP = 'FAS' or [F:DVS]TYP = 'FAP' Then

    If [F:PIH]ZCIF<>'' : [F:DVS]CRN = [F:PIH]ZCIF : Endif
    If [F:PIH]ZRAZONSOCIAL<>'' : [F:DVS]BPRNAM = [F:PIH]ZRAZONSOCIAL  : Endif

  Endif

  # SUPPORT-1774.snew
  # MAB.01042019
  # SI ES UNA FACTURA DE VENTAS

#Infbox('[F:SIH]BPR'-[F:SIH]BPR-'[F:DVS]BPRNUM'-[F:DVS]BPRNUM)

  If [F:SIH]BPR = 'GEN' and [F:DVS]BPRNUM = 'GEN'
&    or ([F:SIH]BPR = 'CANJENAC' and [F:DVS]BPRNUM = 'CANJENAC')
&    or ([F:SIH]BPR = 'CANJEIPSIC' and [F:DVS]BPRNUM = 'CANJEIPSIC')
&    or ([F:SIH]BPR = 'CANJEIPSIM' and [F:DVS]BPRNUM = 'CANJEIPSIM')
&    or ([F:SIH]BPR = 'CANJEUE' and [F:DVS]BPRNUM = 'CANJEUE')
&    or ([F:SIH]BPR = 'CANJEXT' and [F:DVS]BPRNUM = 'CANJEXT')
&    or ([F:SIH]BPR = 'CANJEMEL' and [F:DVS]BPRNUM = 'CANJEMEL')
&    or ([F:SIH]BPR = 'CANJECAN' and [F:DVS]BPRNUM = 'CANJECAN')
&    or ([F:SIH]BPR = 'CANJECEU' and [F:DVS]BPRNUM = 'CANJECEU') Then
    #Infbox [F:SIH]BPR

    #Infbox('[F:SIH]ZCIF'-[F:SIH]ZCIF-'[F:SIH]ZRAZONSOCIAL'-[F:SIH]ZRAZONSOCIAL)

    If dim([F:SIH]ZCIF)>0: [F:DVS]CRN = [F:SIH]ZCIF :  Endif
    If dim([F:SIH]ZRAZONSOCIAL)>0: [F:DVS]BPRNAM  = [F:SIH]ZRAZONSOCIAL : Endif
    #Y019
    If [F:SIH]YDOCTYP > 0 : [F:DVS]DOCTYP = [F:SIH]YDOCTYP  : Endif
    If [F:SIH]YCRY <> '' : [F:DVS]CRY = [F:SIH]YCRY  : Endif
    #Y019

  Endif
  # SUPPORT-1774.enew

End



###############################################################################
#** 25/01/2019 - MS - BURKING-140
#*  Determina si una factura se ha de presentar en Canarias o es Nacional
#*
#*!
Subprog SET_SIISEND()

Local Char ZLISTVACBPR(5)(1..10)
Local Char ZLISTVAT(5)(1..20)

  ZLISTVACBPR(1) = 'CAN'
  ZLISTVACBPR(2) = 'CACAN'
  ZLISTVACBPR(3) = 'CANAG'
  ZLISTVACBPR(4) = 'CANF2'
  ZLISTVACBPR(5) = 'ISPCA'

  ZLISTVAT(1) = 'SP036'
  ZLISTVAT(2) = 'SP03X'
  ZLISTVAT(3) = 'SP03Y'
  ZLISTVAT(4) = 'SP03Z'
  ZLISTVAT(5) = 'SP040'
  ZLISTVAT(6) = 'SP041'
  ZLISTVAT(7) = 'SP052'
  ZLISTVAT(8) = 'SP053'
  ZLISTVAT(9) = 'SP054'
  ZLISTVAT(10) = 'SP055'
  ZLISTVAT(11) = 'SP056'
  ZLISTVAT(12) = 'SP057'
  ZLISTVAT(13) = 'SP058'
  ZLISTVAT(14) = 'SP059'
  ZLISTVAT(15) = 'CJ041'
  ZLISTVAT(16) = 'SP072'




If !clalev ([ZSIH])   : Local File SINVOICE     [ZSIH]    : Endif
If !clalev ([ZPIH])   : Local File PINVOICE     [ZPIH]    : Endif

If [F:DVS]ZSIISEND='' and [F:DVS]CPY = 'BKS' Then
  # Facturas de venta
  Read [ZSIH]SIH0=[F:DVS]NUM

  If !fstat Then
    If find([F:ZSIH]VAC,ZLISTVACBPR(1..5))>= 1 and find([F:ZSIH]TAX,ZLISTVAT(1..16))>=1 Then
      [F:DVS]ZSIISEND = 'CAN'
    Else
      [F:DVS]ZSIISEND = 'NAC'
    Endif
  Endif
  # Facturas de compra
  Read [ZPIH]PIH0=[F:DVS]NUM
  If !fstat Then
    If find([F:ZPIH]VAC,ZLISTVACBPR(1..5))>= 1 and find([F:ZPIH]TAX,ZLISTVAT(1..15))>=1 Then
      [F:DVS]ZSIISEND = 'CAN'
    Else
      [F:DVS]ZSIISEND = 'NAC'
    Endif
  Endif
Endif

Close Local File [ZSIH]
Close Local File [ZPIH]

End

