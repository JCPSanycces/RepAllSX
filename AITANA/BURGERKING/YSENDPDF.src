#------------------------------------------------------------------------------#

Subprog GEN_PDF(WYSPDF, WVCRNUM, WRPT, WCODAIM, STAT, WMSG)
Value    Char    WYSPDF
Value    Char    WVCRNUM
Value    Char    WRPT
Value    Char    WCODAIM
Variable Integer STAT
Variable Char    WMSG

  Local Char    WFONCTION(GLONAFC), TBPAR(15)(1..100), TBVAL(30)(1..100),
&               AUXCHAR(250), WPARAM(50), WVOL(GLONAVL), WNAMVOL(255),
&               PATH_FILE(255), DIRSEP(1), WOBJET(GLONAOB), SUFIX(30)
  Local Integer I, WGENPDFTO, WPWFLG
  Local Date    WDAT

  If clalev([F:YSPDF])=0 : Local File YSETUPPDF [YSPDF] : Endif
  If clalev([F:ARP])=0   : Local File AREPORT     [ARP] : Endif
  If clalev([F:ACV])=0   : Local File ACTIV       [ACV] : Endif
  If clalev([F:AOB])=0   : Local File AOBJET      [AOB] : Endif
  If clalev([F:AIM])=0   : Local File APRINTER    [AIM] : Endif
  If clalev([F:ARV])=0   : Local File AREPORTV    [ARV] : Endif
  If clalev([F:ARD])=0   : Local File AREPORTD    [ARD] : Endif
  If clalev([F:ATY])=0   : Local File ATYPE       [ATY] : Endif
  If clalev([F:AVL])=0   : Local File AVOLUME     [AVL] : Endif
  If clalev([F:AOX])=0   : Local File AOBJTXT     [AOX] : Endif

  WFONCTION = "YSENDPDF"

  Gosub CHK_PARAMS
  If STAT : End : Endif

  Gosub OPEN_OBJ
  If STAT : End : Endif

  Raz I
  Filter [F:ARV] Where FONCTION=WFONCTION and TYPCOD=1 and ETAT=WRPT
  For [F:ARV]ARV0
    Read [F:ARD]ARD1=[F:ARV]PARAM;[F:ARV]ETAT
    If !fstat
      WPARAM = [F:ARD]PARCOD
      I += 1
      Read [F:ATY]CODTYP=[F:ARD]PARTYP
      If fstat : Raz [F:ATY] : Endif
      WYPT = [F:ATY]TYPTYP
      Call EVALE([F:ARV]VALDEF1, AUXCHAR, WYPT) From AIMP1
      Gosub ADD_PAR
      If find(tolower(right$(WPARAM, len(WPARAM)-2)), "deb", "str") and [F:ARD]PARSTREND=2
        I += 1
        AUXCHAR = ""
        Case right$(WPARAM,len(WPARAM)-2)
          When "deb" : SUFIX = "fin"
          When "str" : SUFIX = "end"
          When "DEB" : SUFIX = "FIN"
          When "STR" : SUFIX = "END"
        Endcase
        WPARAM = left$(WPARAM, len(WPARAM)-3) + SUFIX
        Call EVALE([F:ARV]VALDEF2, AUXCHAR, WYPT) From AIMP1
        Gosub ADD_PAR
      Endif
    Endif
  Next
  Filter [F:ARV]

  If I=0
    Filter [F:ARD] Where RPTCOD=WRPT and PARSAI=2
    If rowcount([F:ARD])>0
      STAT = 1 : WMSG = func AFNC.MES2(mess(13,6002,1), WRPT, WFONCTION)
    Endif
    Filter [F:ARD]
  Endif
  If STAT : End : Endif

  If dim([V]GYWNOMFIC)>0 : Kill [V]GYWNOMFIC : Endif
  Global Char GYWNOMFIC(255)
  If func AFNC.PARAM("YISSAMESER", "")="2"
    # Servicio de impresión y servicio de procesos en el mismo host
    [V]GYWNOMFIC = filpath("tmp","","")
  Else
    # Servicio de impresión y servicio de procesos en distinto host
    [V]GYWNOMFIC = func AFNC.PARAM("YPATHPDF", "")
  Endif
  If [V]GYWNOMFIC=""
    [V]GYWNOMFIC = filpath("tmp", "", "")
  Endif
  If right$([V]GYWNOMFIC, len([V]GYWNOMFIC))<>DIRSEP
    [V]GYWNOMFIC += DIRSEP
  Endif

  [V]GYWNOMFIC += PATH_FILE

  If GOS(1)="dos"
    Call BORRAR([V]GYWNOMFIC, I)
  Else
    Call BORRAR_UX([V]GYWNOMFIC, I)
  Endif
  Raz WPWFLG
  If [V]GTEMPON=0 and !GSERVEUR
    WPWFLG = 1
    Call TEMPON("R") From GESECRAN
  Endif
  Call ETAT(WRPT, WCODAIM, GLANGUE, 0, "", TBPAR, TBVAL) From AIMP3

  Sleep WGENPDFTO
  Infbox('1')
  If WPWFLG=1
    Call TEMPOFF From GESECRAN
  Endif

  If GOS(1)="dos"
    I = func CHECK_FILE([V]GYWNOMFIC)
  Else
    I = func CHECK_FILE_UX([V]GYWNOMFIC)
  Endif
  If I=0
    STAT = 1 : WMSG = mess(7,6002,1) + "\" + mess(14,6002,1)
  Endif

  If !STAT
    Gosub INSERT_ADJ
  Endif
End

#------------------------------------------------------------------------------#

$CHK_PARAMS
  Raz STAT
  If WYSPDF=""
    STAT = 1 : WMSG = mess(1,6002,1)
  Else
    Read [F:YSPDF]YSPDF0=WYSPDF
    If fstat
      STAT = 1 : WMSG = WYSPDF + ":" - mess(23,100,1)
    Else
      Read [F:AOB]ABREV=[F:YSPDF]AOBCOD
      If fstat
        STAT = 1 : WMSG = mess(33,115,1) - [F:YSPDF]AOBCOD + ":" - mess(23,100,1)
      Endif
    Endif
  Endif
  If STAT : Return : Endif

  If WVCRNUM=""
    STAT = 1 : WMSG = mess(2,6002,1) : Return
  Endif

  If WRPT="" : WRPT = [F:YSPDF]RPTCOD : Endif
  Call CONT_RPTCOD(WRPT, WMSG, STAT)
  If STAT>0 : STAT = 1 : Endif
  If STAT : Return : Endif

  If WCODAIM=""
    WCODAIM = func AFNC.PARAM("YAIMPDF", "")
  Endif
  If WCODAIM=""
    STAT = 1 : WMSG = mess(4,6002,1)
  Else
    Read [F:AIM]AIM0=WCODAIM
    If fstat
      STAT = 1 : WMSG = WCODAIM + ":" - mess(23,100,1)
    Elsif [F:AIM]ENAFLG<>2
      STAT = 1 : WMSG = WCODAIM + ":" - mess(2,126,1)
    Elsif [F:AIM]PRT<>4
      STAT = 1 : WMSG = WCODAIM + ":" - mess(6,6002,1)
    Endif
  Endif
  If STAT : Return : Endif

  Case GOS(1)
    When "dos"   : DIRSEP = "\"
    When Default : DIRSEP = "/"
  Endcase

  WGENPDFTO = max(1, val(func AFNC.PARAM("YGENPDFTO", "")))
Return

#------------------------------------------------------------------------------#

$OPEN_OBJ
  WOBJET = [F:YSPDF]AOBCOD
  Call EXISTE_ADX("", nomap, "WO" + WOBJET, I) From ORDSYS
  If I
    Gosub OUVFIC From = "WO" + WOBJET
    Gosub DEFAUT From = "WO" + WOBJET
    Call LECTURE(WOBJET, WVCRNUM, "") From CONTOBJ
    If fstat
      WMSG = WVCRNUM + ":" - mess(23,100,1)
      STAT = 1 : Return
    Endif
    PATH_FILE = toupper(WVCRNUM) + ".pdf"
  Else
    WMSG = func AFNC.MES1(mess(22,6002,1), "WO" + WOBJET)
    STAT = 1 : Return
  Endif
Return

#------------------------------------------------------------------------------#

$ADD_PAR
  Case WYPT
    When 1
      If val(AUXCHAR)=0
        AUXCHAR = "1"
      Endif
    When 2,3,4,5,6
      If AUXCHAR=""
        AUXCHAR = "0"
      Endif
    When 8
      WDAT = gdat$(left$(AUXCHAR + "00000000", 8))
      If WDAT=[0/0/0] : WDAT += 1 : Endif
      AUXCHAR = format$("D:YYYYMMDD", WDAT)
  Endcase
  TBPAR(I) = WPARAM : TBVAL(I) = AUXCHAR
Return

#------------------------------------------------------------------------------#

$INSERT_ADJ
  WVOL = func AFNC.PARAM("YVOLJOINT", "")
  If WVOL="" : Return : Endif
  Read [F:AVL]CODE=WVOL
  If fstat : Return : Endif

  WNAMVOL = WYSPDF + "/" + func GET_FILENAME([V]GYWNOMFIC)
  AUXCHAR = func ASYRSTO.GETFULLPATH(WVOL, WNAMVOL)

  If GOS(1)="dos"
    Call COPIAR([V]GYWNOMFIC, AUXCHAR, I)
  Else
    Call COPIAR_UX([V]GYWNOMFIC, AUXCHAR, I)
  Endif
  WNAMVOL = "[" + WVOL + "]/" + WNAMVOL
  Trbegin [F:AOX]
  Filter [F:AOX] Where ABREV=WOBJET and IDENT1=WVCRNUM and pat(NAM,"*" + WVCRNUM + "*")
  Read [F:AOX]AOX0 First
  If fstat
    Filter [F:AOX] Where ABREV=WOBJET and IDENT1=WVCRNUM
    Read [F:AOX]AOX0 Last
    If fstat
      Raz [F:AOX]
      [F:AOX]ABREV = WOBJET
      [F:AOX]IDENT1 = WVCRNUM
    Endif
    [F:AOX]IDENT3 = format$("N0:3#", val([F:AOX]IDENT3)+1)
    [F:AOX]CAT = 1
    [F:AOX]NAM = WNAMVOL
    [F:AOX]TYPDOC = "PDF"

    Write [F:AOX]
  Else
    [F:AOX]CAT = 1
    [F:AOX]NAM = WNAMVOL
    [F:AOX]TYPDOC = "PDF"

    Rewrite [F:AOX]
  Endif
  Filter [F:AOX]
  If fstat
    Rollback
  Else
    Commit
  Endif
Return

#------------------------------------------------------------------------------#
# MS-DOS mode (no sandbox)
Funprog CHECK_FILE(PATH_FILE)
Value    Char    PATH_FILE

  Local Char    ORDSYS(255), WFILE(90)
  Local Integer I, COUNT
  #
  Raz COUNT
  ORDSYS = 'dir /a:-d /b "' + PATH_FILE + '"'  # Excluir los directorios
  Call SYSTEME2(adxmac(0), ORDSYS, "", I, WFILE) From ORDSYS
  If pat(PATH_FILE, "*" + WFILE + "*")
    COUNT = 1
  Else
    COUNT = 0
  Endif
  #
End COUNT

#------------------------------------------------------------------------------#
# unix-linux mode (no sandbox)
Funprog CHECK_FILE_UX(PATH_FILE)
Value    Char    PATH_FILE

  Local Char    ORDSYS(250), CHKFIL(250)(1..200)
  Local Integer NBRFIL, I, COUNT
  #
  Raz COUNT
  ORDSYS = "ls" - PATH_FILE
  Call SYSTEME2(adxmac(0), ORDSYS, "", NBRFIL, CHKFIL) From ORDSYS
  NBRFIL = min(NBRFIL, dim(CHKFIL))
  For I=1 To NBRFIL
    If CHKFIL(I)=PATH_FILE
      COUNT = 1
      Break
    Endif
  Next I
  #
End COUNT

#------------------------------------------------------------------------------#

Funprog REMOVE_FILENAME_CHARS(WNOMDIR,WREPLACE)
Value Char    WNOMDIR
Value Char    WREPLACE
Local Char    WCHAR(255), SPE_CHAR(20)
Local Integer I
  SPE_CHAR = '\/:*?"<>|'
  WCHAR = WNOMDIR
  WCHAR = ctrans(WCHAR)
  For I=1 To len(SPE_CHAR)
    WCHAR = ctrans(WCHAR, mid$(SPE_CHAR,I,1), WREPLACE)
  Next I
End WCHAR

#------------------------------------------------------------------------------#

Funprog GET_FILENAME(WFILE)
Value Char    WFILE()
Local Char    WFILENAME(250)
Local Integer I

  For I=len(WFILE) To 1 Step -1
    If mid$(WFILE, I, 1)="/" or mid$(WFILE, I, 1)="\"
      WFILENAME = right$(WFILE, I+1)
      Break
    Endif
  Next I
End WFILENAME

#------------------------------------------------------------------------------#
# MS-DOS mode (no sandbox)
Subprog COPIAR(FICORI, FICDES, STAT)
Value    Char    FICORI
Value    Char    FICDES
Variable Integer STAT

Local    Char    ORDSYS(255)

  ORDSYS = 'COPY "' + FICORI + '" "' + FICDES + '"'
  Call SYSTEME(adxmac(0), ORDSYS, "", STAT) From ORDSYS
  Call EXISTE(FICDES, STAT) From ORDSYS # sandbox OK (Volumen X3)
  If STAT=1 : STAT = 0 : Endif
End

#------------------------------------------------------------------------------#
# MS-DOS mode (no sandbox)
Subprog COPIAR_UX(FICORI, FICDES, STAT)
Value    Char    FICORI
Value    Char    FICDES
Variable Integer STAT

Local    Char    ORDSYS(255)

  ORDSYS = 'cp ' + FICORI + ' ' + FICDES
  Call SYSTEME(adxmac(0), ORDSYS, "", STAT) From ORDSYS
  Call EXISTE(FICDES, STAT) From ORDSYS # sandbox OK (Volumen X3)
  If STAT=1 : STAT = 0 : Endif
End

#------------------------------------------------------------------------------#
# MS-DOS mode (no sandbox)
Subprog BORRAR(FICHERO, STAT)
Value Char       FICHERO
Variable Integer STAT

Local    Char    ORDSYS(255)

  ORDSYS = 'DEL /Q "' + FICHERO + '"'
  Call SYSTEME(adxmac(0), ORDSYS, "", STAT) From ORDSYS
End

#------------------------------------------------------------------------------#
# unix-linux mode (no sandbox)
Subprog BORRAR_UX(FICHERO, STAT)
Value Char       FICHERO
Variable Integer STAT

Local    Char    ORDSYS(255)

  ORDSYS = 'rm' - FICHERO
  Call SYSTEME(adxmac(0), ORDSYS, "", STAT) From ORDSYS
End

#------------------------------------------------------------------------------#

Subprog CONT_RPTCOD(VALEUR,MESSAGE,STAT)
Value    Char    VALEUR
Variable Char    MESSAGE
Variable Integer STAT

  Raz STAT , MESSAGE
  Read [ARP]ARP0 = VALEUR
  If fstat
    MESSAGE = mess(6,135,1) : # Informe inexistente
    STAT = 2 : End
  Elsif [F:ARP]ENAFLG<>2
    MESSAGE = mess(17,135,1) - VALEUR + "\" + mess(2,126,1) : # Informe x\Ficha inactiva
    STAT = 2 : End
  Else
    Local Integer OK
    OK = 1
    If [F:ARP]CODACT<>""
      Read [ACV]CODACT=[F:ARP]CODACT
      If fstat or [F:ACV]FLACT<>2
        OK = 0
      Endif
    Endif
  Endif
End

#------------------------------------------------------------------------------#

Subprog PDFCTLOBJ(CODE)
Value Char CODE

  If dim([M]AOBCOD)<1 : End : Endif
  If dim([M]CODE)<1   : End : Endif

  If clalev([F:YSPDF])=0 : Local File YSETUPPDF [YSPDF] : Endif
  Local Integer I, NOL

  Read [F:YSPDF]YSPDF0=CODE
  If fstat
    GMESSAGE = CODE + ":" - mess(23,100,1)
    GERR = 1 : mkstat = 2
  Else
    NOL = nolign-1
    I = find([F:YSPDF]AOBCOD, [M]AOBCOD(0..NOL-1), [M]AOBCOD(NOL+1..[M]NBLIG-1))
    If I
      If I>NOL : I += 1 : Endif
      GMESSAGE = func AFNC.MES3(mess(18,6002,1), [F:YSPDF]AOBCOD, [M]CODE(I-1), num$(I))
      GERR = 1 : mkstat = 2
    Else
      [M]AOBCOD(NOL) = [F:YSPDF]AOBCOD
    Endif
  Endif
End

#------------------------------------------------------------------------------#

Subprog SENDWRKPDF(WCODE, WVCRNUM)
Value Char WCODE
Value Char WVCRNUM

  If clalev([F:YSPDF])=0 : Local File YSETUPPDF [YSPDF] : Endif
  If clalev([F:AOB])=0   : Local File AOBJET      [AOB] : Endif

  Local Char WOBJET(GLONAOB), WGRPDEB(GLONVCR), SAVOBJET(GLONAOB),
&            SAVFONCTION(GLONAFC)

  Read [F:YSPDF]YSPDF0=WCODE
  If fstat : Raz [F:YSPDF] : Endif

  WOBJET = [F:YSPDF]AOBCOD
  If WOBJET<>""
    Read [F:AOB]ABREV=WOBJET
    If !fstat
      Gosub OUVFIC From = "WO" + WOBJET
      Gosub DEFAUT From = "WO" + WOBJET
      Call LECTURE(WOBJET, WVCRNUM, "") From CONTOBJ
      If !fstat
        SAVOBJET = GABREV
        SAVFONCTION = GFONCTION
        GABREV = WOBJET
        GFONCTION = "GES" + GABREV
        Call WORKPLUS(2, [F:YSPDF]AOBCOD, "W", WVCRNUM, [F:YSPDF]CODWRK, 0, 0, 0, WGRPDEB) From AWRK
        GABREV = SAVOBJET
        GFONCTION = SAVFONCTION
      Endif
    Endif
  Endif
End

#------------------------------------------------------------------------------#

Subprog UPD_YSEND(WABREV, WVCRNUM, WCHRONO)
Value Char WABREV
Value Char WVCRNUM
Value Char WCHRONO

  If clalev([F:YSEND])=0 : Local File YSENTDOCS [YSEND] : Endif

  If WABREV=""  : End : Endif
  If WVCRNUM="" : End : Endif

  If !adxlog
    Call DEBTRANS From GLOCK
    Gosub TR_YSEND
  Else
    Gosub MAJ_YSEND
  Endif
End

#------------------------------------------------------------------------------#

$TR_YSEND
  Trbegin [YSEND]
  Gosub MAJ_YSEND
  If GOK<0
    Goto ROLL_YSEND
  Elsif GOK<1
    Goto AB_YSEND
  Endif
  Commit

  If func COME_FROM_TRT("YDOCPDF")=0
    Call MESSAGE(mess(26,6002,1)) From GESECRAN
  Endif
Return

#------------------------------------------------------------------------------#

$ROLL_YSEND
  Rollback
  Call ROLL From GLOCK
  If GROLL
    Return
  Else
    Goto TR_YSEND
  Endif
Return

#------------------------------------------------------------------------------#

$AB_YSEND
  Rollback
Return

#------------------------------------------------------------------------------#

$MAJ_YSEND
  Readlock [F:YSEND]YSEND0=WABREV;WVCRNUM
  If fstat=1
    GOK = -1 : Call FSTA("YSEND") From GLOCK : Return
  Elsif fstat
    Raz [F:YSEND]
    [F:YSEND]AOBCOD = WABREV
    [F:YSEND]VCRNUM = WVCRNUM
    [F:YSEND]NBRSENT = 1
    [F:YSEND]LASTCHRONO = WCHRONO
    [F:YSEND]LASTDATE = date$
    [F:YSEND]LASTTIME = time$
    Write [F:YSEND]
  Else
    [F:YSEND]NBRSENT += 1
    [F:YSEND]LASTCHRONO = WCHRONO
    [F:YSEND]LASTDATE = date$
    [F:YSEND]LASTTIME = time$
    Rewrite [F:YSEND]
  Endif
  If fstat
    GOK=0 : Call FSTA("YSEND") From GLOCK
  Endif
Return

#------------------------------------------------------------------------------#

Funprog GET_MAIN_EMAIL(WABREV, WBPR)
Value Char WABREV
Value Char WBPR

  Local File YBPRPDF [YBPDF]
  Local Char WMAIL(GLONMAI)

  Raz WMAIL
  If WABREV<>"" and WBPR<>""
    Read [F:YBPDF]YBPDF1=WABREV;WBPR
    If fstat : Raz [F:YBPDF] : Endif
    WMAIL = [F:YBPDF]MAILTO
  Endif
  Close Local File [YBPDF]
End WMAIL

#------------------------------------------------------------------------------#

Funprog GET_CC_EMAIL(WABREV, WBPR, NBRMAIL)
Value Char    WABREV
Value Char    WBPR
Value Integer NBRMAIL

  Local File YBPRPDF [YBPDF]
  Local Char WMAIL(GLONMAI)

  Raz WMAIL
  If NBRMAIL>0 and NBRMAIL<=dim([F:YBPDF]MAILCC)
    Read [F:YBPDF]YBPDF1=WABREV;WBPR
    If fstat : Raz [F:YBPDF] : Endif
    WMAIL = [F:YBPDF]MAILCC(NBRMAIL-1)
  Endif
  Close Local File [YBPDF]
End WMAIL

#------------------------------------------------------------------------------#

Subprog YCHECKATT(WABREV, WVCRNUM, WBPR, WMSGFLG)
Value    Char    WABREV
Value    Char    WVCRNUM
Value    Char    WBPR
Value    Integer WMSGFLG

  If func COME_FROM_TRT("YDOCPDF")=1 : End : Endif

  If clalev([F:AOX])=0   : Local File AOBJTXT     [AOX] : Endif
  If clalev([F:YBPDF])=0 : Local File YBPRPDF   [YBPDF] : Endif
  If clalev([F:YSPDF])=0 : Local File YSETUPPDF [YSPDF] : Endif

  Local Char    WCODE(GLONYSPDF), WCODAIM(GLONAIM), WMSG(250)
  Local Integer I, STAT

  Filter [F:AOX] Where ABREV=WABREV and IDENT1=WVCRNUM and pat(NAM,"*" + WVCRNUM + "*")
  Read [F:AOX]AOX0 First
  Filter [F:AOX]
  If fstat
    Raz WCODE
    Read [F:YBPDF]YBPDF1=WABREV;WBPR
    If !fstat
      WCODE = [F:YBPDF]CODE
    Else
#      Filter [F:YSPDF] Where AOBCOD=WABREV
#      I = rowcount([F:YSPDF])
#      Filter [F:YSPDF]
#      If I=0
#        GOK = 0 : WMSG = mess(23,6002,1) - WABREV
#        Gosub TRT_ERR : End
#      Else
#        If I=1
#          For [F:YSPDF] Where AOBCOD=WABREV
#            WCODE = [F:YSPDF]CODE
#          Next
#        Else
#          # Ventana de selección de códigos filtrada por objeto
#          Local Char    PARMSK(250)(1..20) , SAVACT(20)
#          SAVACT = GACTION : GACTION = "SELOBJCRI1"
#          PARMSK(1) = "YSPDF"
#          PARMSK(2) = ""
#          PARMSK(3) = ""
#          PARMSK(4) = 'AOBCOD="' + WABREV + '"'
#          PARMSK(5) = ""
#          Call S_TAB_CHAR(WCODE, PARMSK, "SELOBJCRIT", "TRTX3", "") From GACTION
#          GACTION = SAVACT
#        Endif
#      Endif
       GOK = 0 : WMSG = mess(23,6002,1)
       Gosub TRT_ERR : End
    Endif
    If WCODE<>""
      Read [F:YSPDF]YSPDF0=WCODE
      If fstat
        GOK = 0 : WMSG = WCODE + ":" - mess(25,6002,1)
        Gosub TRT_ERR
      Else
        WCODAIM = func AFNC.PARAM("YAIMPDF", "")
        Call GEN_PDF(WCODE, WVCRNUM, [F:YSPDF]RPTCOD, WCODAIM, STAT, WMSG) From YSENDPDF
        If STAT
          GOK = 0
          Gosub TRT_ERR
        Endif
      Endif
    Else
      GOK = 0 : WMSG = mess(24,6002,1)
      Gosub TRT_ERR
    Endif
  Endif
End

$TRT_ERR
  Case [L]WMSGFLG
    When 1
      If GOK=1
        Call MESSAGE([L]WMSG) From GESECRAN
      Else
        Call ERREUR([L]WMSG) From GESECRAN
      Endif
    When 2
      GMESSAGE = [L]WMSG
      If GOK=1
        GERR = 2
      Else
        GERR = 1
      Endif
    When 3
      If GOK=1
        Call ECR_TRACE([L]WMSG, 0) From GESECRAN
      Else
        Call ECR_TRACE([L]WMSG, 1) From GESECRAN
      Endif
  Endcase
Return

#------------------------------------------------------------------------------#

Funprog COME_FROM_TRT(WTRT)
Value Char WTRT

  Local Integer WYIX, WFOUND, WLO, NAMTRT_INI, NAMTRT_FIN
  Local Char    NAMTRT(GLONADC)

  Raz WYIX, WFOUND
  If WTRT<>""
    While adxpno(WYIX)<>""
      # adxpno(n): @X3.TRT/SUBSDHC$adx
      WLO = len(adxpno(WYIX))
      While WLO>0
        If seg$(adxpno(WYIX), WLO, WLO)="/"  : NAMTRT_INI = WLO : Endif
        If seg$(adxpno(WYIX), WLO, WLO)="$"  : NAMTRT_FIN = WLO : Endif
        WLO -= 1
      Wend
      NAMTRT = seg$(adxpno(WYIX), NAMTRT_INI+1, NAMTRT_FIN-1)
      If NAMTRT = WTRT
        WFOUND = 1 : Break
      Endif
      WYIX += 1
    Wend
  Endif
End WFOUND

