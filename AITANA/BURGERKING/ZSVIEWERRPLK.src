Subprog SENDMAIL2()
Local Char    L_EMAIL(100)
Local Char    L_EXPMAIL(250), LPCE(200), L_ASUNTO(50), LFICPDF(30)
Local Integer L_ENVOI(1..1) , L_SUIVI(1..1)
Local Char    L_CUERPO(255)

L_EXPMAIL   = adxmac(-1)
L_EMAIL     = "malarcon@sistel.es"
L_ENVOI     = 2
L_CUERPO    = "Hola, el proceso de actualización de artículos de Telematel se ha realizado correctamente."
&           +" Saludos!"
L_ASUNTO   = "Actualización de precios - Telematel"
LFICPDF  = ""
LPCE=filpath("TRA","","tra")

    Call ENVOI_MAIL(2,          1,          0,        GUSER,
&                   L_EXPMAIL,  "",         "",       num$(adxuid(1)),    0,
&                   L_EMAIL,    L_ENVOI,    L_SUIVI,  1,
&                   L_CUERPO,   L_ASUNTO,   LPCE,
&                   1,          "",         0,        "") From AWRKMEL


End

