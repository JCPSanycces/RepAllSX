Subprog Z_SENDMAIL()


Local Char DIR(GDIMFIC), FILELIST(GDIMFIC)(1..500)
Local Integer LNGTH
Local Integer COUNT
Local Char EFICHERO(200)
DIR =filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER
DIR = DIR + "\IMP\PLK"

If !clalev([F:ATA]) : Local File ATABDIV [ATA] : Endif
COUNT = 0
Filter [ATA] Where [F:ATA]NUMTAB = 6000 # Tabla Varia de lista de correos
Local Char EDESTINO(200)(rowcount([ATA]))
For [ATA]
  EDESTINO(COUNT) = [ATA]A1 # Campo correo
  #Infbox EDESTINO(COUNT)
  COUNT += 1
Next


#EDESTINO="ignacio.garcia.yanes@es.ey.com"

Call SYSTEME2(adxmac(0), "lsadx"-DIR,"",LNGTH,FILELIST) From ORDSYS

#if filinfo(DIR,7) > 0
#   Infbox "Fichero Existe"
#Endif

For I=3 To LNGTH

  If len(FILELIST(I)) > 3 Then
  #Infbox mid$(FILELIST(I),len(FILELIST(I))-3,4)
     #  Buscamos los ficheros con extensión .err
     If mid$(FILELIST(I),len(FILELIST(I))-3,4) = ".err" Then
        #Infbox FILELIST(I)
        #call sendmail2()
        For A=0 To COUNT-1
          Call SENDEMAILCMD(EDESTINO(A), FILELIST(I))
        Next
        Call MOVEFILE(FILELIST(I))

     Endif
  Endif
Next


End

########################################################################
########################################################################

Subprog MOVEFILE(PFILE)


Local Char DESTINO(250)
Local Char ORIGEN_DOSSIER(250)
Local Char ORIGEN(250)

Local Integer STAT:STAT=1

ORIGEN_DOSSIER=filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER


DESTINO = ORIGEN_DOSSIER+"\IMP\Errores\" + PFILE

ORIGEN=ORIGEN_DOSSIER+"\IMP\PLK\"+PFILE

Call MOVE (ORIGEN,DESTINO,STAT) From ORDSYS

End

########################################################################
########################################################################

Subprog SENDEMAILCMD(PEDESTINO, PFICHERO)

Local Char ORIGEN_DOSSIER(250)
Local Char FICHERO
Local Char CURRDATETIME_STR

ORIGEN_DOSSIER=filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER



CURRDATETIME_STR=format$("D:YYYYMMDDhhmmss",datetime$)

FICHERO= "EV" + num$(CURRDATETIME_STR)


#•YYYY: 4 DIGIT year
#•MM: 2 DIGIT month (01-12)
#•DD: 2 DIGIT day OF THE month (01-31)
#•HH: 2 DIGIT HOUR (00-23)
#•MM: 2 DIGIT MINUTE (00-59)
#•SS: 2 DIGIT SECOND (00-59)


#Creacion de fichero BAT
Openo filpath("IMP\PLK",FICHERO, "bat",nomap)
adxifs=';'
adxirs = chr$(13) + chr$(10)

Wrseq 'E:\SENDEMAIL\sendemail.exe -f comunicaciones.administracion@rbiberia.com -t ' + PEDESTINO +
& ' -u "Error en Import '  + PFICHERO  + '" -m "Error al procesar el fichero ' + PFICHERO +
& '" -s smtp.office365.com:587 -xu comunicaciones.administracion@rbiberia.com -xp CAd6993@ -o tls=yes'

Openo

#Ejecución de fichero BAT
System CHAINE= ORIGEN_DOSSIER + "\IMP\PLK\" + FICHERO + ".bat"

# borrado de fichero
Local Integer RETURN_STATUS
RETURN_STATUS=Delfile(ORIGEN_DOSSIER + "\IMP\PLK\" + FICHERO + ".bat")

End


