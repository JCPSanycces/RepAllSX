#<AdxTL>@(#)0.0.0.0 $Revision$
#####################################################################################
# Ptos de entrada Facturas a recibir
# Y004
####################################################################################
$PTHPWRK
Local Char WCLAVE

If clalev([F:YCAL])=0  : Local File CPTANALIN   [YCAL] : Endif
If [F:PTH]PTHNUM <> ''
  Filter [F:PWD] Where [F:PWD]PRONUM = adxuid(1) and [F:PWD]PTHNUM = [F:PTH]PTHNUM
  For [PWD]

    Read [YCAL]CAL0="PTD";0;[F:PTH]PTHNUM;[F:PWD]PTDLIN;0;"";1
    If fstat<>0: Raz [YCAL]: Endif
    If [F:YCAL]DSP <> ''

      [F:PWD]DSP = [F:YCAL]DSP
      Rewrite [F:PWD]
      If fstat

        GOK=0 : Call FSTA("PWD") From GLOCK
        Raz WCLAVE
        WCALVE=num$([F:PWD]PRONUM)-[F:PWD]PTHNUM-num$([F:PWD]PTDLIN)
        WMSG="Error al grabar Distribuciˇn en PWRKPTD"-WCLAVE
        Gosub AB_TRANSACTION_MSG From FUNPTH
        Return
      Endif
    Endif
  Next
  Filter [PWD]
Endif
Return
#####################################################################################

