#####################################################################################
#-
######################################################################################
$ACTION
  Case ACTION
    When "OUVRE" :  Gosub OUVRE
    When "LIENS" :  Gosub LIENS
    When "APRES_MODIF": Gosub APRES_MODIF
    When "MODIF" :  Gosub MODIF
   # When "ANNULE" : Gosub ANNULE
    When Default
  Endcase
Return


######################################################################################
$OUVRE
  If !clalev([F:ZFCYE])  : Local File ZFCYEXT [ZFCYE] : Endif # Tabla datos extendidos BK



Return
######################################################################################
$LIENS
  Gosub CARGAR_DATOS_EXTENDIDOS

Return

######################################################################################
#**
#*  Cargar datos extendidos Planta
#*!
$CARGAR_DATOS_EXTENDIDOS

  Read [ZFCYE]ZFCY0 = [M:FCY0]FCY;[M:FCY1]LEGCPY
  If !fstat Then # Existe el registros
   [M:ZFCY6]ZLIMCJ = [F:ZFCYE]ZLIMCJ
   [M:ZFCY6]ZTCOMP = [F:ZFCYE]ZTCOMP
   [M:ZFCY6]ZTVEN = [F:ZFCYE]ZTVEN
   [M:ZFCY6]ZTPVHOME = [F:ZFCYE]ZTPVHOME
   [M:ZFCY6]ZNUMTPV = [F:ZFCYE]ZNUMTPV
   [M:ZFCY6]ZCLAV = [F:ZFCYE]ZCLAV
   [M:ZFCY6]ZTYPE = [F:ZFCYE]ZTYPE
   [M:ZFCY6]ZFIRMDIG = [F:ZFCYE]ZFIRMDIG
   [M:ZFCY6]ZCODCON = [F:ZFCYE]ZCODCON
   [M:ZFCY6]ZCODECI = [F:ZFCYE]ZCODECI
   [M:ZFCY6]ZNUMIP = [F:ZFCYE]ZNUMIP
   [M:ZFCY6]ZCODCONBAL = [F:ZFCYE]ZCODCONBAL
   [M:ZFCY6]ZSOFT = [F:ZFCYE]ZSOFT
   [M:ZFCY6]ZTVIEWER = [F:ZFCYE]ZTVIEWER
   [M:ZFCY6]ZCOTIZ = [F:ZFCYE]ZCOTIZ
   [M:ZFCY6]ZIDREPLEGAL = [F:ZFCYE]ZIDREPLEGAL
   [M:ZFCY6]ZEDENRED = [F:ZFCYE]ZEDENRED
   [M:ZFCY6]ZGOURMET = [F:ZFCYE]ZGOURMET
   [M:ZFCY6]ZSODEXO = [F:ZFCYE]ZSODEXO
   [M:ZFCY6]ZCODDATA1 = [F:ZFCYE]ZCODDATA1
   [M:ZFCY6]ZCODDATA2= [F:ZFCYE]ZCODDATA2
   [M:ZFCY6]ZCODDATA3 = [F:ZFCYE]ZCODDATA3

   [M:ZFCY6]ZSTATUSTOV1 = [F:ZFCYE]ZSTATUSTOV1
   [M:ZFCY6]ZHOMEDEL1 = [F:ZFCYE]ZHOMEDEL1
   [M:ZFCY6]ZBANKTPV1 = [F:ZFCYE]ZBANKTPV1

   [M:ZFCY6]ZSTATUSTOV2 = [F:ZFCYE]ZSTATUSTOV2
   [M:ZFCY6]ZHOMEDEL2 = [F:ZFCYE]ZHOMEDEL2
   [M:ZFCY6]ZBANKTPV2 = [F:ZFCYE]ZBANKTPV2

   [M:ZFCY6]ZSTATUSTOV3 = [F:ZFCYE]ZSTATUSTOV3
   [M:ZFCY6]ZHOMEDEL3 = [F:ZFCYE]ZHOMEDEL3
   [M:ZFCY6]ZBANKTPV3 = [F:ZFCYE]ZBANKTPV3

   [M:ZFCY6]ZFCY = [M:FCY0]FCY
   [M:ZFCY6]ZFINRSPFCY = [M:FCY1]LEGCPY
   # nuevos campos
   [M:ZFCY6]ZRESACTIVO = [F:ZFCYE]ZRESACTIVO
   [M:ZFCY6]ZHOMEDELI = [F:ZFCYE]ZHOMEDELI
   [M:ZFCY6]ZOPEN24 = [F:ZFCYE]ZOPEN24
   [M:ZFCY6]ZPROSEGUR = [F:ZFCYE]ZPROSEGUR
   [M:ZFCY6]ZFIRMADIGITA = [F:ZFCYE]ZFIRMADIGITA
   [M:ZFCY6]ZOFICENTRAL = [F:ZFCYE]ZOFICENTRAL
   [M:ZFCY6]ZTERRAZA = [F:ZFCYE]ZTERRAZA
   [M:ZFCY6]ZMAQBEBIDA = [F:ZFCYE]ZMAQBEBIDA



    Affzo [M:ZFCY6]
  Endif
Return

######################################################################################
$APRES_MODIF

Return

######################################################################################
$MODIF

  Gosub  GRABAR_DATOS_EXTENDIDOS


Return

######################################################################################
#**
#*
#*!
$GRABAR_DATOS_EXTENDIDOS
  Local Integer I
  Local Integer ID

  # Trbegin ZGRAPHICO2 [ZGP2B]
  Delete [ZFCYE] Where ZFCY = [M:FCY0]FCY and ZFINRSPFCY = [M:FCY1]LEGCPY

  If fstat = 1 Then
    Rollback
  Else
   [F:ZFCYE]ZLIMCJ = [M:ZFCY6]ZLIMCJ
   [F:ZFCYE]ZTCOMP = [M:ZFCY6]ZTCOMP
   [F:ZFCYE]ZTVEN = [M:ZFCY6]ZTVEN
   [F:ZFCYE]ZTPVHOME = [M:ZFCY6]ZTPVHOME
   [F:ZFCYE]ZNUMTPV = [M:ZFCY6]ZNUMTPV
   [F:ZFCYE]ZCLAV = [M:ZFCY6]ZCLAV
   [F:ZFCYE]ZTYPE = [M:ZFCY6]ZTYPE
   [F:ZFCYE]ZFIRMDIG = [M:ZFCY6]ZFIRMDIG
   [F:ZFCYE]ZCODCON = [M:ZFCY6]ZCODCON
   [F:ZFCYE]ZCODECI = [M:ZFCY6]ZCODECI
   [F:ZFCYE]ZNUMIP = [M:ZFCY6]ZNUMIP
   [F:ZFCYE]ZCODCONBAL = [M:ZFCY6]ZCODCONBAL
   [F:ZFCYE]ZSOFT = [M:ZFCY6]ZSOFT
   [F:ZFCYE]ZTVIEWER = [M:ZFCY6]ZTVIEWER
   [F:ZFCYE]ZCOTIZ = [M:ZFCY6]ZCOTIZ
   [F:ZFCYE]ZIDREPLEGAL = [M:ZFCY6]ZIDREPLEGAL
   [F:ZFCYE]ZEDENRED = [M:ZFCY6]ZEDENRED
   [F:ZFCYE]ZGOURMET = [M:ZFCY6]ZGOURMET
   [F:ZFCYE]ZSODEXO = [M:ZFCY6]ZSODEXO
   [F:ZFCYE]ZCODDATA1 = [M:ZFCY6]ZCODDATA1
   [F:ZFCYE]ZCODDATA2 = [M:ZFCY6]ZCODDATA2
   [F:ZFCYE]ZCODDATA3 = [M:ZFCY6]ZCODDATA3

   [F:ZFCYE]ZSTATUSTOV1 = [M:ZFCY6]ZSTATUSTOV1
   [F:ZFCYE]ZHOMEDEL1 = [M:ZFCY6]ZHOMEDEL1
   [F:ZFCYE]ZBANKTPV1 = [M:ZFCY6]ZBANKTPV1

   [F:ZFCYE]ZSTATUSTOV2 = [M:ZFCY6]ZSTATUSTOV2
   [F:ZFCYE]ZHOMEDEL2 = [M:ZFCY6]ZHOMEDEL2
   [F:ZFCYE]ZBANKTPV2 = [M:ZFCY6]ZBANKTPV2

   [F:ZFCYE]ZSTATUSTOV3 = [M:ZFCY6]ZSTATUSTOV3
   [F:ZFCYE]ZHOMEDEL3 = [M:ZFCY6]ZHOMEDEL3
   [F:ZFCYE]ZBANKTPV3 = [M:ZFCY6]ZBANKTPV3

   [F:ZFCYE]ZFCY = [M:FCY0]FCY
   [F:ZFCYE]ZFINRSPFCY = [M:FCY1]LEGCPY

    # nuevos campos
   [F:ZFCYE]ZRESACTIVO = [M:ZFCY6]ZRESACTIVO
   [F:ZFCYE]ZHOMEDELI = [M:ZFCY6]ZHOMEDELI
   [F:ZFCYE]ZOPEN24 = [M:ZFCY6]ZOPEN24
   [F:ZFCYE]ZPROSEGUR = [M:ZFCY6]ZPROSEGUR
   [F:ZFCYE]ZFIRMADIGITA = [M:ZFCY6]ZFIRMADIGITA
   [F:ZFCYE]ZOFICENTRAL = [M:ZFCY6]ZOFICENTRAL
   [F:ZFCYE]ZTERRAZA = [M:ZFCY6]ZTERRAZA
   [F:ZFCYE]ZMAQBEBIDA = [M:ZFCY6]ZMAQBEBIDA

   Write [ZFCYE]
#    If fstat = 0 Then
#      Commit
#    Else
#      Rollback
#    Endif
  Endif

  # COMPROBAR ZONA
  # Si la zona intruducida es nueva, grabar registro en la tabla de histórico de Zonas
  If !clalev([F:ZFCYZO])  : Local File ZFCYZONA [ZFCYZO] : Endif # Tabla datos extendidos BK
  If [M:FCY1]XZONA <> "" Then

    Filter [F:ZFCYZO] Where ZFCY = [M:FCY0]FCY and ZFINRSPFCY = [M:FCY1]LEGCPY  Order By ZID Desc
    Read [F:ZFCYZO] First
      If rowcount([ZFCYZO]) > 0 Then
       LID = [F:ZFCYZO]ZID

       If [F:ZFCYZO]ZZONA <> [M:FCY1]XZONA Then

         #Update [ZFCYZO]  Where ZFCY = [M:FCY0]FCY and ZFINRSPFCY = [M:FCY1]LEGCPY and XZONA = [F:ZFCYZO]ZZONA  With ZFECHAFIN = date$
         [F:ZFCYZO]ZFECHAFIN = date$
         #[F:ZFCYZO]ZZONA = [M:FCY1]XZONA
          Rewrite
          Gosub GRABAR_NUEVA_ZONA
       Endif
    Else
      LID = 0
      Gosub GRABAR_NUEVA_ZONA
    Endif
   Endif
Return


$GRABAR_NUEVA_ZONA
     If !clalev([F:ZFCYZO2])  : Local File ZFCYZONA [ZFCYZO2] : Endif # Tabla datos extendidos BK
     [F:ZFCYZO2]ZID = LID + 1
     [F:ZFCYZO2]ZFCY = [M:FCY0]FCY
     [F:ZFCYZO2]ZFINRSPFCY = [M:FCY1]LEGCPY
     [F:ZFCYZO2]ZZONA = [M:FCY1]XZONA
     [F:ZFCYZO2]ZFECHAINI = date$

     Write [F:ZFCYZO2]


Return

