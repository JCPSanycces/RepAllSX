$ACTION

  If !clalev([F:BPA2])  Then : Global File BPADDRESS [BPA2] : Endif
  If !clalev([F:ZFCY2])  Then : Global File ZFCYEXT [ZFCY2] : Endif
  If !clalev([F:ZCAC])   Then : Global File CACCE [ZCAC]    : Endif # SECCIONES ANALITICAS
  If !clalev([F:ZATE])   Then : Global File ATEXTRA [ZATE]    : Endif # TRADUCIONES
  If !clalev([F:ZATE2])   Then : Global File ATEXTRA [ZATE2]    : Endif # TRADUCIONES
  If !clalev([F:ZCDI])   Then : Global File CDIADSP [ZCDI]    : Endif # DISTRIB. A PRIORI


#  If !clalev([F:PTH])  Then : Global File PRECEIPT [PTH] : Endif
#  If !clalev([F:ATB])  Then : Global File ATABLE [ATB] : Endif
#  Global  Integer  COUNTERFOUND : COUNTERFOUND=0
#  YGAS/YVAR/YTRA/YDES/YALB/

  Case ACTION
    When "IMP_AVANT_OUVRE"  : Gosub $IMP_AVANT_OUVRE
    When "AP_IMPORT"        : Gosub $AP_IMPORT
    # When "IMP_FERME"       : Gosub $IMP_FERME # Cuando termina el proceso de import

    #  When "IMP_INICRE" : Gosub IMP_INICRE

    When Default
  Endcase
  Return

$OUVRE
    Gosub OUVRE From GASIMPORT
  Return

$RAZCRE
    Gosub RAZCRE From GASIMPORT
  Return

$VALID
    Gosub VALID From GASIMPORT
  Return

$SAIMSK
    Gosub SAIMSK From GASIMPORT
    Return

$IMP_FERME
    #Infbox "$IMP_FERME"
    Return

#######################################################################################
#$IMPORT
#
#  Return

#######################################################################################Ç
$IMP_AVANT_OUVRE
    Global  Integer  COUNTERFOUND : COUNTERFOUND=0
    Global  Integer  COUNTERYVAR : COUNTERYVAR=0
    # Si el tipo de importación es YVAR, hacer un tratamiento especial



#######################################################################################
#**
#*
#*!
$AP_IMPORT
  # MAB.BURKING22. Se revisarán todos los asientos por la referencia
  #                Si el asiento perteneciente a la referencia, existe, se realizará la reversión.

  # MAB.BURKING22. Asientos de tipo YVAR. Generar asientos de inversión, para los asientos sin revertir
  #                y que la fecha de asiento sea igual a la fecha máxima de los asientos encontrados
  #                sin revertir.
  Local Char FICHERO_INVERSION(200)
  Local Char ASIENTO_ORIGEN, TYPE_ORIGEN, FCY_ORIGEN
  Local Char LAUX
#  CURRDATETIME_STR=format$("D:YYYYMMDDhhmmss",datetime$)
#  FICHERO= "EV" + num$(CURRDATETIME_STR)


  Case [L]IMPFIC
    When "FCY"
      # CREACIÓN DE SECCIONES ANÁLITICAS
      Call CREACION_SECCION()
      # CREACIÓN DE DISTRIBUCIONES A POSTERIORI
      If [F:FCY]XCODPROV <> "" Then
        # Call CREAR_ASIGNACION()
        Call ECR_TRACE("FCY - Creación de asignación 2", 0) From GESECRAN
        Call CREAR_ASIGNACION2()
      Endif

    When "BPA"
       # Trbegin [BPA2]
        Call ECR_TRACE("BPA - Creación de Dirección", 0) From GESECRAN
        Call CREAR_DIRECCION()

         # CREAR DIRECCIÓN PARA BK
        If [F:FCY]LEGCPY = 'BKS' Then
          Call ECR_TRACE("BPA - Creación de Dirección BKS", 0) From GESECRAN
          Call CREAR_DIRECCION_BKS()
        Endif
      When "ZFCYEXT"
        Call ECR_TRACE("BPA - Creación de dATOS eXTERNOS", 0) From GESECRAN
        Call CREAR_DATOS_EXTERNOS()
    When Default
  Endcase

  Return

Subprog CREACION_SECCION

     Trbegin [ZCAC]

      Filter [ZCAC] Where DIE  = 'CCT' and CCE = [F:FCY]FCY and FCY = [F:FCY]LEGCPY
    #  Infbox "Secciones encontradas de: " + [F:FCY]FCY + "- LEGCPY:" + [F:FCY]LEGCPY  + " --> " + num$(rowcount([ZCAC]))
         If (rowcount([ZCAC])) > 0 Then
           Read [ZCAC] First
       #    Infbox [F:ZCAC]FCY
         Endif


     [F:ZCAC]DIE = 'CCT' # SIEMPRE AL EJE CCT
     [F:ZCAC]CCE = [F:FCY]FCY
     [F:ZCAC]DES = [F:FCY]FCYNAM
     [F:ZCAC]ENAFLG = 2
     [F:ZCAC]FCY = [F:FCY]LEGCPY
     [F:ZCAC]ZZONA = [F:FCY]XZONA
     [F:ZCAC]ZDESZONA = [F:FCY]XDESZONA
     [F:ZCAC]ZAREA = [F:FCY]XAREA
     [F:ZCAC]ZDESAREA  = [F:FCY]XDESAREA
     [F:ZCAC]BUDTRK = 2
     [F:ZCAC]IPT = 2

      If (rowcount([ZCAC])) > 0 Then
        Rewrite [ZCAC]
      Else
        Write [ZCAC]
      Endif

      If !fstat Then
        Commit
        Call ECR_TRACE("Creación de seccion - Registros encontrados: " + num$(rowcount([ZCAC])) + " - commit " + num$(fstat), 0) From GESECRAN
      Else
        Rollback
        Call ECR_TRACE("Creación de seccion - Registros encontrados: " + num$(rowcount([ZCAC]))+ " - rollback " + num$(fstat), 0) From GESECRAN
      Endif

      # Traducciones de la sección, si no se inserta en esta tabla
      # no se muestra la descripción por pantalla.
      Filter [ZATE] Where CODFIC = 'CACCE' and ZONE = 'DESTRA' and LANGUE = 'SPA' and IDENT1 = 'CCT' and IDENT2 = [F:FCY]FCY
      If rowcount([ZATE]) > 0 Then
     #     Infbox num$(rowcount([ZATE])) + " - destra" + " - " + [F:FCY]FCY
         Read [ZATE] First
      Endif
      Trbegin [ZATE]
      [F:ZATE]CODFIC = 'CACCE'
      [F:ZATE]ZONE = 'DESTRA'
      [F:ZATE]LANGUE = 'SPA'
      [F:ZATE]IDENT1 = 'CCT'
      [F:ZATE]IDENT2 = [F:FCY]FCY
      [F:ZATE]TEXTE = [F:FCY]FCYNAM
   #   Infbox [F:FCY]FCYNAM + " - DESTRA"
      If rowcount([ZATE]) > 0 Then
          Rewrite [ZATE]
      Else
          Write [ZATE]
      Endif

      If !fstat Then
        Commit
        Call ECR_TRACE("Creación de atextra DESTRA - Registros encontrados: " + num$(rowcount([ZATE]))+ " - commit " + num$(fstat), 0) From GESECRAN
      Else
        Rollback
        Call ECR_TRACE("Creación de atextra DESTRA - Registros encontrados: " + num$(rowcount([ZATE]))+ " - rollback " + num$(fstat), 0) From GESECRAN
      Endif

      Filter [ZATE2] Where CODFIC = 'CACCE' and ZONE = 'SHOTRA' and LANGUE = 'SPA' and IDENT1 = 'CCT' and IDENT2 = [F:FCY]FCY
   #    Infbox num$(rowcount([ZATE2])) + " - SHOTRA" + " - " + [F:FCY]FCY
      Read [ZATE2] First
      Trbegin [ZATE2]
      [F:ZATE2]CODFIC = 'CACCE'
      [F:ZATE2]ZONE = 'SHOTRA'
      [F:ZATE2]LANGUE = 'SPA'
      [F:ZATE2]IDENT1 = 'CCT'
      [F:ZATE2]IDENT2 = [F:FCY]FCY
      [F:ZATE2]TEXTE = [F:FCY]FCYNAM
    #  Infbox [F:FCY]FCYNAM + " - CORTA"
      If rowcount([ZATE2]) > 0 Then
          Rewrite [ZATE2]
      Else
          Write [ZATE2]
      Endif

      If !fstat Then
        Commit
               Call ECR_TRACE("Creación de atextra SHOTRA - Registros encontrados: " + num$(rowcount([ZATE2]))+ " - commit " + num$(fstat), 0) From GESECRAN
      Else
        Rollback
                       Call ECR_TRACE("Creación de atextra SHOTRA - Registros encontrados: " + num$(rowcount([ZATE2]))+ " - rollback " + num$(fstat), 0) From GESECRAN
      Endif


End


Subprog CREAR_ASIGNACION
  Local Char ZPATH(200)  #ZPATH = "E:\SAGE\X3MAFESA\folders\PROTO\IMPORT\OF\"
  Local Char ZDATETIME(14)
  Local Char ZMKIFIT(200)  #ZMKIFIT = ZPATH+"MKI_"+[M:ZCMT]MFGNUM+"_"+ZDATETIME+".txt"
  Local Char ZMKSFIT(200)



  ZDATETIME = time$
  ZDATETIME = mid$(ZDATETIME,1,2)+mid$(ZDATETIME,4,2)+mid$(ZDATETIME,7,2)
  ZDATETIME = date$+ZDATETIME

   adxifs = ';' : adxirs = chr$(13)+chr$(10)

  LFICIMP = filpath("IMP","DISTRI_"+[F:FCY]FCY+"_"+[F:FCY]XCODPROV+"_"+ZDATETIME,"csv")
  #Openo filpath("IMP", LFICIMP, "csv",nomap)

  Openo LFICIMP Using [ZDIS]

  # SORDERC - Pedidos de venta - Acum. A/R -
  # SOHNUM - SOPLIN - EARQTYCUS - EARDATCUS - PJT (PROYECTO)
  Wrseq "PGA",[F:FCY]FCY,"1",[F:FCY]FCY + ZDATETIME,[F:FCY]FCY + ZDATETIME,[F:FCY]FCY + ZDATETIME,"","","","1","CCT",[F:FCY]FCY,"PGA","","100","","","",[F:FCY]XCODPROV,"",""      Using [
& ZDIS]
  Openo Using [ZDIS]


End

Subprog CREAR_ASIGNACION2()
  Local Char LLED


  If [F:FCY]LEGCPY = 'BKS' Then
      LLED = 'PBA'
  Else
      LLED = 'PGA'
  Endif

  Trbegin [ZCDI]
      Filter [ZCDI] Where LED  = LLED and COD = [F:FCY]FCY and LIN = 1 and DES = [F:FCY]FCY and DIE = 'CCT'
         If (rowcount([ZCDI])) > 0 Then
           Read [ZCDI] First
         Endif
      Call ECR_TRACE("FCY - Creación de asignación 2 - Registros encontrados: " + num$(rowcount([ZCDI])), 0) From GESECRAN

      [F:ZCDI]LED = LLED
      [F:ZCDI]COD = [F:FCY]FCY
      [F:ZCDI]LIN = 1
      [F:ZCDI]DES = [F:FCY]FCY
      [F:ZCDI]DIE = 'CCT'
      [F:ZCDI]TYP = 1
      [F:ZCDI]CCEREF = [F:FCY]XCODPROV
      [F:ZCDI]COA = LLED
      [F:ZCDI]PRC = 100
      [F:ZCDI]CCERCP = [F:FCY]FCY
      If (rowcount([ZCDI])) > 0 Then
         Rewrite [ZCDI]
      Else
         Write [ZCDI]
      Endif
      Call ECR_TRACE("Creación de asignación 2 - Registros encontrados: " + num$(rowcount([ZCDI]))+ " - estado grabación:" + num$(fstat), 0) From GESECRAN
      If !fstat Then
          Commit
      Else
          Rollback
      Endif


End

Subprog CREAR_DIRECCION()
        Filter [BPA2] Where BPANUM = [F:FCY]FCY and BPATYP = 3 and BPAADD = [F:FCY]BPAADD
         If (rowcount([BPA2])) > 0 Then
           Read [BPA2] First
         Endif
         Call ECR_TRACE("Creación de DIRECCIÓN - Registros encontrados: " + num$(rowcount([BPA2])), 0) From GESECRAN

        [F:BPA2]BPANUM = [F:FCY]FCY
        [F:BPA2]BPAADD = [F:FCY]BPAADD
        [F:BPA2]BPATYP = 3
        [F:BPA2]BPADES = [F:FCY]FCYNAM
        [F:BPA2]BPAADDLIG = [F:BPA]BPAADDLIG
        [F:BPA2]CRY = [F:BPA]CRY
        [F:BPA2]CRYNAM = [F:BPA]CRYNAM
        [F:BPA2]POSCOD = [F:BPA]POSCOD
        [F:BPA2]CTY = [F:BPA]CTY
        [F:BPA2]SAT = [F:BPA]SAT
        [F:BPA2]TEL = [F:BPA]TEL
        [F:BPA2]FAX = [F:BPA]FAX
        [F:BPA2]WEB = [F:BPA]WEB
        [F:BPA2]EXTNUM = [F:BPA]EXTNUM # MAB20180716. SOLICITADO POR ELIANA (EY)
        [F:BPA2]BPAADDFLG = 2
        If (rowcount([BPA2])) > 0 Then
           Rewrite [BPA2]
        Else
           Write [BPA2]
        Endif

End


Subprog CREAR_DIRECCION_BKS()

        Filter [BPA2] Where BPAADD = [F:FCY]FCY and BPATYP = 1
         If (rowcount([BPA2])) > 0 Then
           Read [BPA2] First
         Endif
         Call ECR_TRACE("Creación de DIRECCIÓN BKS - Registros encontrados: " + num$(rowcount([BPA2])), 0) From GESECRAN

        [F:BPA2]BPANUM = "F11808"
        [F:BPA2]BPAADD = [F:FCY]FCY
        [F:BPA2]BPATYP = 1
        [F:BPA2]BPADES = [F:FCY]FCYNAM
        [F:BPA2]BPAADDLIG = [F:BPA]BPAADDLIG
        [F:BPA2]CRY = [F:BPA]CRY
        [F:BPA2]CRYNAM = [F:BPA]CRYNAM
        [F:BPA2]POSCOD = [F:BPA]POSCOD
        [F:BPA2]CTY = [F:BPA]CTY
        [F:BPA2]SAT = [F:BPA]SAT
        [F:BPA2]TEL = [F:BPA]TEL
        [F:BPA2]FAX = [F:BPA]FAX
        [F:BPA2]WEB = [F:BPA]WEB
        # [F:BPA2]EXTNUM = [F:BPA]EXTNUM # MAB20180716. SOLICITADO POR ELIANA (EY)
        [F:BPA2]BPAADDFLG = 1
        If (rowcount([BPA2])) > 0 Then
          Rewrite [BPA2]
        Else
          Write [BPA2]
        Endif

End

Subprog CREAR_DATOS_EXTERNOS()

         Filter [ZFCY2] Where ZFCY = [F:FCY]FCY
         If (rowcount([ZFCY2])) > 0 Then
           Read [ZFCY2] First
         Endif

         Trbegin [ZFCY2]
         LAUX =  [F:ZFCYEXT]ZCLAV # 1

         [F:ZFCY2]ZCLAV  = LAUX
         [F:ZFCY2]ZFCY  = [F:FCY]FCY
         [F:ZFCY2]ZFINRSPFCY  = [F:FCY]LEGCPY
         [F:ZFCY2]ZLIMCJ  = [F:ZFCYEXT]ZLIMCJ
         [F:ZFCY2]ZTVEN  = [F:ZFCYEXT]ZTVEN
         [F:ZFCY2]ZTPVHOME  = [F:ZFCYEXT]ZTPVHOME
         [F:ZFCY2]ZNUMTPV  = [F:ZFCYEXT]ZNUMTPV
         [F:ZFCY2]ZTYPE  = [F:ZFCYEXT]ZTYPE
         [F:ZFCY2]ZFIRMDIG  = [F:ZFCYEXT]ZFIRMDIG
        # Infbox [F:ZFCYEXT]ZCODCON
         [F:ZFCY2]ZCODCON  = [F:ZFCYEXT]ZCODCON
         [F:ZFCY2]ZCODECI  = [F:ZFCYEXT]ZCODECI
        # Infbox [F:ZFCY2]ZCODCON
         [F:ZFCY2]ZNUMIP  = [F:ZFCYEXT]ZNUMIP
         [F:ZFCY2]ZCODCONBAL  = [F:ZFCYEXT]ZCODCONBAL
         [F:ZFCY2]ZSOFT  = [F:ZFCYEXT]ZSOFT
         [F:ZFCY2]ZTVIEWER  = [F:ZFCYEXT]ZTVIEWER
         [F:ZFCY2]ZIDREPLEGAL  = [F:ZFCYEXT]ZIDREPLEGAL
         [F:ZFCY2]ZEDENRED  = [F:ZFCYEXT]ZEDENRED
         [F:ZFCY2]ZGOURMET  = [F:ZFCYEXT]ZGOURMET
         [F:ZFCY2]ZSODEXO  = [F:ZFCYEXT]ZSODEXO
         [F:ZFCY2]ZCODDATA1  = [F:ZFCYEXT]ZCODDATA1
         [F:ZFCY2]ZCODDATA2  = [F:ZFCYEXT]ZCODDATA2
         [F:ZFCY2]ZCODDATA3  = [F:ZFCYEXT]ZCODDATA3
         [F:ZFCY2]ZSTATUSTOV1  = [F:ZFCYEXT]ZSTATUSTOV1
         [F:ZFCY2]ZHOMEDEL1  = [F:ZFCYEXT]ZHOMEDEL1
         [F:ZFCY2]ZBANKTPV1  = [F:ZFCYEXT]ZBANKTPV1
         [F:ZFCY2]ZSTATUSTOV2  = [F:ZFCYEXT]ZSTATUSTOV2
         [F:ZFCY2]ZSTATUSTOV3  = [F:ZFCYEXT]ZSTATUSTOV3
         [F:ZFCY2]ZBANKTPV2  = [F:ZFCYEXT]ZBANKTPV2
         [F:ZFCY2]ZBANKTPV3  = [F:ZFCYEXT]ZBANKTPV3
         [F:ZFCY2]ZHOMEDEL2  = [F:ZFCYEXT]ZHOMEDEL2
         [F:ZFCY2]ZHOMEDEL3  = [F:ZFCYEXT]ZHOMEDEL3
         [F:ZFCY2]ZTCOMP = [F:ZFCYEXT]ZTCOMP
         #  nuevos campos
         [F:ZFCY2]ZRESACTIVO = [F:ZFCYEXT]ZRESACTIVO
         [F:ZFCY2]ZHOMEDELI = [F:ZFCYEXT]ZHOMEDELI
         [F:ZFCY2]ZOPEN24 = [F:ZFCYEXT]ZOPEN24
         [F:ZFCY2]ZPROSEGUR = [F:ZFCYEXT]ZPROSEGUR
         [F:ZFCY2]ZFIRMADIGITA = [F:ZFCYEXT]ZFIRMADIGITA
         [F:ZFCY2]ZOFICENTRAL = [F:ZFCYEXT]ZOFICENTRAL
         [F:ZFCY2]ZTERRAZA = [F:ZFCYEXT]ZTERRAZA
