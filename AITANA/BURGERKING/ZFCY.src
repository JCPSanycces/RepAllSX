          If (rowcount([ZFCY2])) > 0 Then
            Rewrite [ZFCY2]
          Else
            Write [ZFCY2]
          Endif
           Call ECR_TRACE("Creación de DATOS EXTERNOS - Registros encontrados: " + num$(rowcount([ZFCY2]))+ " - estado grabación:" + num$(fstat), 0) From GESECRAN
          If !fstat Then
            Commit
          Else
            Rollback
          Endif
End

