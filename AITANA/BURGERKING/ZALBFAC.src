#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION



 Case ACTION
    When "IMP_OUVRE"  : Gosub $IMP_OUVRE
    When "AP_IMPORT"        : Gosub $AP_IMPORT

    When Default
  Endcase
  Return


$IMP_OUVRE

    If !clalev([F:ZGAC])  : Local File GACCENTRY [ZGAC] : Endif
    If !clalev([F:ZGACD])  : Local File GACCENTRYD [ZGACD] : Endif

    Gosub OUVRE From GASIMPORT
  Return

$RAZCRE
    Gosub RAZCRE From GASIMPORT
  Return

$VALID

    Gosub VALID From GASIMPORT
  Return

$SAIMSK
    Gosub SAIMSK From GASIMPORT
    Return

$IMP_FERME
  Return


#######################################################################################Ç
$IMP_AVANT_OUVRE
    Global  Integer  COUNTERFOUND : COUNTERFOUND=0
    Global  Integer  COUNTERYVAR : COUNTERYVAR=0

#    If !clalev([F:ZALFA])  : Local File ZALBFAC [ZALFA] : Endif

    # Si el tipo de importación es YVAR, hacer un tratamiento especial

Return


#######################################################################################
#**
#* STATUS
#* 1 -- Procesado ok
#* 2 -- Asiento con DES <> ''
#* 3 -- MTC Informado
#* 4 -- NUM FACTURA sin informar en el fichero
#*!
$AP_IMPORT
  Local Char ZDATETIME
  Local Char LNOMBRE_FICHERO
  Global Char LNOMBRE_FICHERO_TMP(255)(255)
  Global Integer LIND


  Case [L]IMPFIC
    When "ZALFA"
      LIND + = 1
      If [F:ZALFA]VCRNUM <> '' Then

        Filter [ZGAC] Where REF = [F:ZALFA]SDHNUM  and FCY = [F:ZALFA]FCY
        Call ECR_TRACE("Asientos encontrados: " + [F:ZALFA]SDHNUM + " - " + [F:ZALFA]FCY + " - " + num$(rowcount([ZGAC])),0) From GESECRAN
        If rowcount([ZGAC]) > 0 Then
          Read [ZGAC] First
          Filter [ZGACD] Where NUM=[F:ZGAC]NUM and FCYLIN = [F:ZGAC]FCY
          Call ECR_TRACE("Asientos encontrados D: " + [F:ZGAC]NUM + " - " + num$(rowcount([ZGACD])),0) From GESECRAN
          If rowcount([ZGACD]) > 0 Then
            Read [ZGACD] First
            If [F:ZGACD]MTC <> '' Then
                [F:ZALFA]ZSTATUS = '3' # MARCAJE informado
                Call ECR_TRACE("Asiento con MTC informado: " + [F:ZGACD]NUM, 0) From GESECRAN
            Else
                If [F:ZGACD]DES <> '' Then
                   [F:ZALFA]ZSTATUS = '2' # MARCAJE SIN INFORMAR
                   Call ECR_TRACE("Asiento con DES informado: " + [F:ZGACD]NUM, 0) From GESECRAN
                Else # ASIENTO CORRECTO PARA MARCA, ES DECIR, MTC = '' Y DES = ''
                   [F:ZALFA]ZSTATUS = '1'
                   [F:ZALFA]NUM = [F:ZGACD]NUM
                   For [ZGACD]
                       If !clalev([F:HAEAUX])  Then : Global File GACCENTRYD [HAEAUX] : Endif
                       Trbegin [F:HAEAUX]
                       Update [F:HAEAUX] Where [F:HAEAUX]ACCNUM= [F:ZGACD]ACCNUM and [F:HAEAUX]NUM=[F:ZGACD]NUM With [F:HAEAUX]DES=[F:ZALFA]VCRNUM
                        If fstat = 0 Then
                           Commit
                           # Infbox "Record modificador:" -num$(adxuprec)
                        Else
                           Rollback
                        Endif
                       Close File [HAEAUX]
                      # Infbox "Asiento actualizado: " + [F:GACD]NUM
                      Call ECR_TRACE("Asiento actualizado: " + [F:ZGACD]NUM, 0) From GESECRAN
                   Next
                Endif
            Endif
          Endif
          Filter [ZGACD]
        Endif

        Filter [ZGAC]
      Else
        [F:ZALFA]ZSTATUS = '4'
      Endif

    When Default
  Endcase



Return

