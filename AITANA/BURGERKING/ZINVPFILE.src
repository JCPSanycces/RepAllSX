#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog PROCESAR_FIC_FACTURAS()
  Global Integer GNIVEL
  Local Char DIR(250), FILELIST(250)(1..5000)
  Local Char PDIR(250)
  Local Integer LNGTH
  Local Integer COUNT
  Local Char EFICHERO(250)

  Gosub ABRIR_TABLAS
  # DIR =filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER
  DIR = "M:\SageX3"

  #Call OUVRE_TRACE("Inicio escaneado de directorios: " + DIR) From LECFIC
  #Call ECR_TRACE("INICIO",0) From GESECRAN



  GNIVEL = 0


  Call SYSTEME2(adxmac(0), "lsadx"-DIR,"",LNGTH,FILELIST) From ORDSYS

  For I=3 To LNGTH

    If len(FILELIST(I)) > 2 Then
       If filinfo(DIR + '\' + FILELIST(I),7) = 0 and filinfo(DIR + '\' + FILELIST(I), 0) = 16895 Then # es un directorio
          GNIVEL = 1
          EFICHERO = DIR + '\' + FILELIST(I)
        #  Call ECR_TRACE(num$(I) + '<-- I.DIRECTORIO:' + EFICHERO,0) From GESECRAN
          If FILELIST(I) = 'BKS' or FILELIST(I) = 'TIM' Then
            If FILELIST(I) = 'BKS' Then
               LPLANTA = 'BKS'
            Elsif FILELIST(I) = 'TIM' Then
               LPLANTA = 'TIM'
            Endif
            Call ECR_TRACE("***********************   PROCCESANDO :" + LPLANTA ,0) From GESECRAN
            EFICHERO = DIR + '\' + FILELIST(I)
            #Call ECR_TRACE(num$(I) + " - BKS-->" + EFICHERO,0) From GESECRAN
            Call PROCESAR_DIRECTORIO(EFICHERO,FILELIST(I), LPLANTA)
          Endif
       Endif
    Endif
  Next

  #  Call FERME_TRACE From LECFIC
  #  Call LEC_TRACE() From LECFIC

    Gosub CERRAR_TABLAS

End
#**
#* PROCESAR_DIRECTORIO(PDIRA, PDIRECTORIO, PPLANTA)
#* Subprograma que solo busca la ruta de directorios pendientes
#* Una vez encontrada la ruta, llama a PROCESAR_DIRECTORIO_FAC para ir procesando cada uno de los subdirectorios
#*
#* @param PDIRA
#*!
Subprog PROCESAR_DIRECTORIO(PDIRA, PDIRECTORIO, PPLANTA)
  Local Char PDIR(250), SUB_FILELIST(250)(1..5000)
  Local Char EFICHERO(250)
  Local Integer LNGTHB
  Local Char LBPRVCR(50), LBPR
  Local Char LDIRECTORIO(250)

  PDIR = PDIRA

  # Call ECR_TRACE("*****   PROCCESANDO DIRECTORIO:" + PDIRECTORIO ,0) From GESECRAN

  Call SYSTEME2(adxmac(0), "lsadx"-PDIR,"",LNGTHB,SUB_FILELIST) From ORDSYS

  For I2=3 To LNGTHB

      # Call ECR_TRACE("I2:" + num$(I2) + " - " + SUB_FILELIST(I2) ,0) From GESECRAN

      If len(SUB_FILELIST(I2)) > 2 Then
         EFICHERO = PDIR + "\" + SUB_FILELIST(I2)
         If filinfo(EFICHERO,7) = 0 and filinfo(EFICHERO, 0) = 16895 Then # es un directorio
              LDIRECTORIO = SUB_FILELIST(I2)
           # Call ECR_TRACE("DIRECTORIO ENCONTRADO: " + LDIRECTORIO ,0) From GESECRAN

           # Infbox "PROCESAR DIRECTORIO: " + PDIR + "\" + SUB_FILELIST(I2)
           # Llegamos al nivel de las facturas pendientes
           If instr(1,LDIRECTORIO,"Procesadas") = 0  Then
               # Call ECR_TRACE("ES UN DIRECTORIO, VOY A PROCESARLO: " + EFICHERO ,0) From GESECRAN
               Call PROCESAR_DIRECTORIO(EFICHERO, LDIRECTORIO, PPLANTA)
           Else
              # Si llegamos al nivel de las facturas procesadas, hay que saltarse ese directorio
              # Call ECR_TRACE("DIRECTORIO: " + SUB_FILELIST(I2) ,1) From GESECRAN
              Break
           Endif
            #Else
            #    Infbox "Procesar directorio de pendientes: " + PDIR + "\" + SUB_FILELIST(I)
            #    Call PROCESAR_DIRECTORIO(PDIR + "\" + SUB_FILELIST(I))
            #    Break
            #Endif
         Else
            # MOVER FICHERO
            # Infbox "FICHERO ENCONTRADO: " + SUB_FILELIST(I2)
            # Call ECR_TRACE("FICHERO ENCONTRADO: " + SUB_FILELIST(I2) ,0) From GESECRAN
            If len(PDIRECTORIO) > 2 Then
              #    Call ECR_TRACE("Posición guión: " + num$(instr(1,PDIRECTORIO,'_')) ,0) From GESECRAN
                  If instr(1,PDIRECTORIO,'_') > 0 Then
                    LBPR = mid$(PDIRECTORIO,1,instr(1,PDIRECTORIO,'_')-1)
                  Endif
            Endif

            # Call ECR_TRACE("Posición .pdf: " + num$(instr(1,SUB_FILELIST(I2),'.pdf')) ,0) From GESECRAN

            If instr(1,toupper(SUB_FILELIST(I2)),'.PDF') > 0 Then
                LBPRVCR = mid$(SUB_FILELIST(I2),1,instr(1,toupper(SUB_FILELIST(I2)),'.PDF')-1)
            #Infbox LBPRVCR
            Endif
            # Call ECR_TRACE('PDF: ' + LBRPVCR + ' -  proveedor: ' + LBPR ,0) From GESECRAN
            #If LBPR <> '' and LBPRVCR <> '' Then
            #    Call ECR_TRACE("---------- PROCESAR FICHERO ------------" ,0) From GESECRAN
                Call PROCESAR_FICHERO(SUB_FILELIST(I2), LBPR, LBPRVCR, PPLANTA, EFICHERO,PDIRECTORIO )
            #Endif

         Endif
    Endif
  Next I2

End


#**
#* PROCESAR_FICHERO(PFICHERO, PBPR, PBPRVCR, PPLANTA, PDIR_ORIGEN, PDIR)
#* Busca factura para montar nombre de fichero destino, adjunta documento a factura y llama
#* a MOVER_FICHERO para llevarlo al destino
#*
#* @param PFICHERO - Ruta parcial del fichero encontrado
#* @param PBPR - Proveedor
#* @param PBPRVCR - Documento Origen
#* @param PPLANTA - Planta
#* @param PDIR_ORIGEN - Ruta completa del fichero encontrado
#* @param PDIR - Carpeta del proveedor (Solo carpeta sin ruta)
#*!
Subprog PROCESAR_FICHERO(PFICHERO, PBPR, PBPRVCR, PPLANTA, PDIR_ORIGEN, PDIR)
  Local Char LNUMFAC(50)
  Local Char LNOMBRE_FICHERO(200)
  #Read [ZIP]PIH1=
  # Call ECR_TRACE('Doc: ' + PBPRVCR + ' - Proveedor: ' + PBPR ,0) From GESECRAN
  If PBPR <> '' and PBPRVCR <> '' Then
#     If !clalev([F:ZIP]) Then : Local File PINVOICE [ZIP] : Endif
     Read [ZIP]PIH0=PBPR;PBPRVCR
     If !fstat Then
        LNUMFAC = [F:ZIP]NUM
        LPLANTA = [F:ZIP]FCY

        LNOMBRE_FICHERO = LPLANTA + "_" + PBPR + "_" + LNUMFAC + "_" + PBPRVCR
        Call ECR_TRACE('Fichero generado: ' + LNOMBRE_FICHERO ,0) From GESECRAN
        Call MOVEFILE(PDIR_ORIGEN,LNOMBRE_FICHERO, [F:ZIP]CPY, PBPR, PDIR )
         Call ADJUNTAR_DOCUMENTO(LNUMFAC,[F:ZIP]CPY,PDIR,LNOMBRE_FICHERO+'.pdf')
    Else
        Call ECR_TRACE('Documento origen no encontrado: ' + PBPRVCR + " - Proveedor: " + PBPR ,1) From GESECRAN
    Endif
  Endif

#  Close File [ZIP]

End

#**
#* ADJUNTAR_DOCUMENTO(PFACTURA, PPLANTA, PDIR, PFICHERO)
#*  Proceso que se encarga de adjuntar el documento a la factura
#* @param PFACTURA
#* @param PPLANTA
#* @param PDIR
#* @param PFICHERO
#*!
Subprog ADJUNTAR_DOCUMENTO(PFACTURA, PPLANTA, PDIR, PFICHERO)


    Trbegin [ZAOX]

    [F:ZAOX]ABREV = 'BIS'
    [F:ZAOX]IDENT1 = PFACTURA
    [F:ZAOX]IDENT3 = '009'
    [F:ZAOX]TYPDOC = 'PDF'
    [F:ZAOX]NAM = '[PDF]/' + PPLANTA + '/1.Facturas/Procesadas/' + PDIR + '/' + PFICHERO
    [F:ZAOX]CAT = 1
    Write [ZAOX]
    If !fstat Then
      Commit
      Call ECR_TRACE("Se adjunta documento : " + PFICHERO  , 0) From GESECRAN
    Else
      Call ECR_TRACE("Error al adjuntar documento : " + PFICHERO + ". Revisar factura y adjuntar manualmente." , 0) From GESECRAN
      Rollback
    Endif


End

########################################################################
########################################################################
#**
#* MOVEFILE(PORIGEN, PFILE, PPLANTA, PBPR, PDIR)
#* Mover fichero encontrado a destino final
#*
#* @param PORIGEN
#* @param PFILE
#* @param PPLANTA
#* @param PBPR
#* @param PDIR
#*!
Subprog MOVEFILE(PORIGEN, PFILE, PPLANTA, PBPR, PDIR)


Local Char DESTINO(250)
Local Char ORIGEN_DOSSIER(250)
Local Char ORIGEN(250)

Local Integer STAT:STAT=1

ORIGEN_DOSSIER=filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER


# DESTINO = ORIGEN_DOSSIER+"\IMP\Errores\" + PFILE
DESTINO = 'M:\SageX3\' + PPLANTA + '\1.Facturas\Procesadas\' + PDIR + '\' + PFILE + '.pdf'

# Infbox DESTINO

# ORIGEN=ORIGEN_DOSSIER+"\IMP\"+PFILE
ORIGEN = PORIGEN

# Infbox ORIGEN

Call MOVE (ORIGEN,DESTINO,STAT) From ORDSYS

End


$ABRIR_TABLAS
  If !clalev([ZIP])  : Local File ZVPINVOICE  [ZIP] : Endif  # TABLA FACTURA
  If !clalev([ZAOX]) : Local File AOBJTXT  [ZAOX] : Endif # tabla de datos

Return


$CERRAR_TABLAS
  Close File [ZIP]
  Close File [ZAOX]

Return

