#####################################################################################
# tarifa de compra
# Y018
#####################################################################################
$ACTION

Case ACTION
  When "TARIFACH"      : Gosub TARIFACH
Endcase

Return
#####################################################################################
$TARIFACH

#llamado desde TRTACHTAR1-TARPOH

#ponemos el valor obtenido en la tarifa en la cantidad y el precio lo ponemos a 1

If !GIMPORT
  If TRAIT = 'POH'
    If MONTANT(0)> 0
      If [M:POH2]QTYUOM(nolign-1) = 0
        [M:POH2]QTYUOM(nolign-1)=MONTANT(0)
        [M:POH2]QTYSTU(nolign-1)=MONTANT(0)
        Affzo [M:POH2]QTYUOM(nolign-1)
        MONTANT(0)=1
      Else
 #      si hay un importe en cantidad (lo han metido a mano) no buscamos tarifa
        MONTANT(0)=[M:POH2]GROPRI(nolign-1)
      Endif
    Endif
  Endif
Endif

Return
#####################################################################################

