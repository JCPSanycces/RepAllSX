#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# YIMPXRTU :  Y016 importaciˇn ficheros XRT
#
######################################################################################
ACTION
Case ACTION
 When "INIT"       : Gosub INIT
 When "DEBUT"      : Gosub DEBUT
 When "EXEC"       : Gosub EXEC
 When "CONTROLE"   : Gosub CONTROLE
 When "END"        : Gosub FIN
 When "TERMINE"    : Gosub TERMINE
 When "SORTIE"     : Gosub SORTIE
 When Default
Endcase
Return
######################################################################################
$INIT
If GSERVEUR
    Onerrgo ERRBATCH
Endif
Gosub OUVRE

Local Mask YIMPXRTU [DIA]

Raz [M:DIA]


[M:DIA]YDOWNLOAD = 2
[M:DIA]YINTTEMP  = 2
[M:DIA]YINTX3    = 2
#

Return
#####################################################################
$DEBUT

Affzo [DIA]1-99

Return
######################################################################
$OUVRE
Local Char     TIT(50)

TIT = "Importaciˇn de ficheros de XRT"

Return
######################################################################################
$EXEC

#Traza
If !GSERVEUR
  Call OUVRE_TRACE(TIT) From LECFIC
  Call ECR_TRACE(" ",0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call PRTSCR("YIMPXRTU","DIA","",0,1) From ATRTX3
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(" ",0) From GESECRAN
Endif
If GSERVEUR
  Call ECR_TRACE(" ",0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(TIT + " " + date$ + " " + time$,0) From GESECRAN
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
  Call ECR_TRACE(" ",0) From GESECRAN
Endif

Call DEBTRANS From GLOCK


Gosub TRATAMIENTO


Return
#########################################################################
$TRATAMIENTO



#Tipo de fichero : parametrizaciˇn
If !clalev ([F:YTP]) : Local File YTIPOFICHERO [YTP] : Endif

Read [F:YTP]YTP0 = "BKS";[M:DIA]YCODFICHERO

If [M:DIA]YDOWNLOAD = 2
  Call DOWNLOADFILE() From ZIMPXRTU
Endif

If [M:DIA]YINTTEMP  = 2
  Call INSERT_XRT_X3() From ZIMPXRTU
Endif

If [M:DIA]YINTX3    = 2
  Call IMPORTAR_DATOS_XRT() From ZIMPXRTU
Endif

Return
####################################################################
$CONTROLE

If GOK<1 FIN=1 Endif

Return
#########################################################################
$SORTIE



Return
#########################################################################
$TERMINE

If !GSERVEUR
  Call FERME_TRACE From LECFIC
  TRA=1
Endif


Return
#########################################################################
$FIN

GOK=0 :  FIN=1

Return
#####################################################################
$ERRBATCH
#####################################################################
Call ECR_TRACE(errmes$(errn)-num$(errl)-ERR,1) From GESECRAN

End

