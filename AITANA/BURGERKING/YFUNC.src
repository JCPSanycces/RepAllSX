#<AdxTL>@(#)0.0.0.0 $Revision$
Funprog RELFACT(PAGO)
  Variable Char PAGO

  Local Char SRETURN(140)
  Raz SRETURN

  If [F:PYH]EPARENPAY<>""
    SRETURN=[F:PYH]EPARENPAY
  Else
    #Infbox  [F:PYH]NUM
    If !clalev([F:YXPYD]) : Local File PAYMENTD [F:YXPYD] : Endif
    If !clalev([F:YXPIH]) : Local File PINVOICE [F:YXPIH] : Endif
    For [F:YXPYD] Where NUM = [F:PYH]NUM
      #Infbox [F:YXPYD]VCRNUM
      For [F:YXPIH] Where NUM=[F:YXPYD]VCRNUM
        If len(SRETURN-[F:YXPIH]BPRVCR) >140
          SRETURN= mid$(SRETURN-[F:YXPIH]BPRVCR,1,140)
        Else
          SRETURN=SRETURN-[F:YXPIH]BPRVCR
        Endif
      Next
    Next
  Endif

End SRETURN

