#######################################################################################Ç
$IMP_AVANT_OUVRE
    Global  Integer  COUNTERFOUND : COUNTERFOUND=0
    Global  Integer  COUNTERYVAR : COUNTERYVAR=0
    # Si el tipo de importación es YVAR, hacer un tratamiento especial

Return


#######################################################################################
#**
#*
#*!
$AP_IMPORT
  Local Char ZDATETIME
  Local Char LNOMBRE_FICHERO
  Global Char LNOMBRE_FICHERO_TMP(255)(255)
  Global Integer LIND


  Case [L]IMPFIC
    When "EXS"
      LIND + = 1
      ZDATETIME = time$
      ZDATETIME = mid$(ZDATETIME,1,2)+mid$(ZDATETIME,4,2)+mid$(ZDATETIME,7,2)
      ZDATETIME = date$+ZDATETIME
      # Infbox ZDATETIME
      LNOMBRE_FICHERO = "FICNG_"+ZDATETIME
      [F:EXS]ZCIF = "~" + [F:EXS]ZCIF
      #Infbox LNOMBRE_FICHERO
      #Call CREAR_FACTURA(LNOMBRE_FICHERO)
      #LNOMBRE_FICHERO_TMP(LIND) = LNOMBRE_FICHERO + ".tmp"
      #Call CREAR_JOB(LNOMBRE_FICHERO)
    When Default
  Endcase



Return


#**
#*
#*
#* @param PNUM Referencia de Tim Horton
#* @param PTYP Tipo de asiento
#* @param PFCY Planta
#* @param PFICHERO_INVERSION Fichero que se generará para la inversión
#* @param PMODELO_IMPORT     Modelo de importación
#*!
Subprog CREAR_FACTURA(PFICHERO_FACTURA)
  Local Char FICEXP
  Local Char LCUENTA
  Local Char LCUENTA_ANALITICA
  Local Char PLAN1, PLAN2
  Local Char LTIPO_FACTURA
  Local Char LZCIF
  Local Char LREGIMEN

    If clalev([F:CAC]) = 0 : Local File GACCCODE [F:CAC]  : Endif
    If clalev([F:CAC2]) = 0 : Local File GACCCODE [F:CAC2]  : Endif
    If clalev([F:TES]) = 0 : Local File TABEXPENS [F:TES]  : Endif
    If clalev([F:ZATA]) = 0 : Local File ATABDIV [F:ZATA] :Endif

  FICEXP = PFICHERO_FACTURA
  # Creacion de fichero BAT
  # Infbox "Crear fichero"

  # Infbox "CREAR_InVERSIÓN:ref " + PNUM + " - MODELO :" + PMODELO_IMPORT
  # Infbox "ltyp:" + LTYP + " - FCY: " + LFCY
  adxifs=';'
  adxirs = chr$(13) + chr$(10)
    If [F:EXS]AMTATI < 0 Then
    LTIPO_FACTURA = 'ANG'
  Else
    LTIPO_FACTURA = 'FNG'
  Endif

  If mid$([F:EXS]ZCIF,1,1) = "~" Then
    LZCIF = mid$([F:EXS]ZCIF,2,len([F:EXS]ZCIF))
  Else
    LZCIF = [F:EXS]ZCIF
  Endif

  Filter [F:ZATA] Where NUMTAB = 6007 and CODE = [F:EXS]VAT
  Read [F:ZATA] First
  If !fstat Then
    LREGIMEN = [F:ZATA]A1
  Endif
  Close File [ZATA]

  Openo filpath("IMP", FICEXP, "csv",nomap)
  # Infbox "DOC ORIGEN:" + [F:EXS]ZDOCORIGEN
  Wrseq 'T',LTIPO_FACTURA,'','NGEN',[F:EXS]CPY,[F:EXS]FCY,[F:EXS]DATEXS,[F:EXS]ZDOCORIGEN,[F:EXS]ZACCDAT,[F:EXS]CUR, [F:EXS]TYPRAT,[F:EXS]RATDAT,'NGEN',[F:EXS]ZACCDAT,LREGIMEN,ctrans(num$(abs([F:EXS]
& AMTPAY)),".",",")
& ,
& ctrans(num$(abs([F:EXS]AMTATI)),".",","), LZCIF, [F:EXS]ZRAZONSOCIAL

# Eliana(EY) me dice que ponga esta cuenta directamente (22/11/2018)
# por lo tanto comento toda esta parte que es la que se ocupa de buscar las cuentas.

#   If [F:EXS]CODEXP <> "" Then
#
#    # PRIMERO SACAR EL TIPO DE GASTO
#    Filter [F:TES] Where CODEXP = [F:EXS]CODEXP
#   # Infbox num$(rowcount([TES]))
#    If rowcount([TES]) = 1 Then
#      If [F:EXS]CPY = 'BKS' Then
#        Filter [F:CAC] Where ACCCOD = [F:TES]ACCCOD and COA = 'PBC'
#        Filter [F:CAC2] Where ACCCOD = [F:TES]ACCCOD and COA = 'PBA'
#      Else
#        Filter [F:CAC] Where ACCCOD = [F:TES]ACCCOD and COD = 'PGC'
#        Filter [F:CAC2] Where ACCCOD = [F:TES]ACCCOD and COD = 'PGA'
#      Endif
#        If rowcount([CAC]) = 1 Then
#            LCUENTA = [F:CAC]ACC(0)
#        Endif
#        If rowcount([CAC2]) = 1 Then
#            LCUENTA_ANALITICA = [F:CAC2]ACC(0)
#        Endif
#        Filter [F:CAC]
#
#
#    Endif
#    Filter [F:TES]
#
#
#  Endif

  LCUENTA = "555001"            # Eliana(EY) me dice que ponga esta cuenta directamente (22/11/2018)
  LCUANTA_ANALITICA = "555001"  # Eliana(EY) me dice que ponga esta cuenta directamente (22/11/2018)

   If [F:EXS]FCY = "2000" Then
     PLAN1 = "PBC"
     PLAN2 = "PBA"
   Else
      PLAN1 = "PGC"
      PLAN2 = "PGA"
   Endif

  Wrseq 'L','1',[F:EXS]FCY,PLAN1,PLAN2,'COM','USG',LCUENTA,LCUENTA_ANALITICA,'','','NGEN','',ctrans(num$(abs([F:EXS]AMTPAY)),".",","),[F:EXS]VAT,'','','',''

  Wrseq 'A','1','CCT','ARS','FAM','DEP','CDV','','','','','','','',ctrans(num$(abs([F:EXS]AMTPAY)),".",","),''

  # [F:EXS]TYPRAT

  Openo

End


#**
#*
#*
#* @param PNUM Referencia de Tim Horton
#* @param PTYP Tipo de asiento
#* @param PFCY Planta
#* @param PFICHERO_INVERSION Fichero que se generará para la inversión
#* @param PMODELO_IMPORT     Modelo de importación
#*!
Subprog CREAR_PAGO_FACTURA(PFICHERO_PAGO_FACTURA)
  Local Char FICEXP
  Local Char LCUENTA
  Local Char LCUENTA_ANALITICA
  Local Char PLAN1, PLAN2
  Local Char LTIPO_FACTURA
  Local Char LZCIF

  If clalev([F:CAC]) = 0 : Local File GACCCODE [F:CAC]  : Endif
  If clalev([F:CAC2]) = 0 : Local File GACCCODE [F:CAC2]  : Endif
  If clalev([F:TES]) = 0 : Local File TABEXPENS [F:TES]  : Endif

  FICEXP = PFICHERO_FACTURA
  adxifs=';'
  adxirs = chr$(13) + chr$(10)
  If [F:EXS]AMTATI < 0 Then
    LTIPO_FACTURA = 'ANG'
  Else
    LTIPO_FACTURA = 'FNG'
  Endif

  If mid$([F:EXS]ZCIF,1,1) = "~" Then
    LZCIF = mid$([F:EXS]ZCIF,2,len([F:EXS]ZCIF))
  Else
    LZCIF = [F:EXS]ZCIF
  Endif

  Openo filpath("IMP", FICEXP, "csv",nomap)
  # Infbox "DOC ORIGEN:" + [F:EXS]ZDOCORIGEN
  Wrseq 'T',LTIPO_FACTURA,'','NGEN',[F:EXS]CPY,[F:EXS]FCY,[F:EXS]DATEXS,[F:EXS]ZDOCORIGEN,[F:EXS]ZACCDAT,[F:EXS]CUR, [F:EXS]TYPRAT,[F:EXS]ZACCDAT,'NGEN',[F:EXS]ZACCDAT,'NAC',ctrans(num$(abs([F:EXS]
& AMTPAY))
& ,".",","
& )
& ,
& ctrans(num$(abs([F:EXS]AMTATI)),".",","), LZCIF, [F:EXS]ZRAZONSOCIAL

# Eliana(EY) me dice que ponga esta cuenta directamente (22/11/2018)
# por lo tanto comento toda esta parte que es la que se ocupa de buscar las cuentas.

#   If [F:EXS]CODEXP <> "" Then
#
#    # PRIMERO SACAR EL TIPO DE GASTO
#    Filter [F:TES] Where CODEXP = [F:EXS]CODEXP
#   # Infbox num$(rowcount([TES]))
#    If rowcount([TES]) = 1 Then
#      If [F:EXS]CPY = 'BKS' Then
#        Filter [F:CAC] Where ACCCOD = [F:TES]ACCCOD and COA = 'PBC'
#        Filter [F:CAC2] Where ACCCOD = [F:TES]ACCCOD and COA = 'PBA'
#      Else
#        Filter [F:CAC] Where ACCCOD = [F:TES]ACCCOD and COD = 'PGC'
#        Filter [F:CAC2] Where ACCCOD = [F:TES]ACCCOD and COD = 'PGA'
#      Endif
#        If rowcount([CAC]) = 1 Then
#            LCUENTA = [F:CAC]ACC(0)
#        Endif
#        If rowcount([CAC2]) = 1 Then
#            LCUENTA_ANALITICA = [F:CAC2]ACC(0)
#        Endif
#        Filter [F:CAC]
#
#
#    Endif
#    Filter [F:TES]
#
#
#  Endif

  LCUENTA = "555001"            # Eliana(EY) me dice que ponga esta cuenta directamente (22/11/2018)
  LCUANTA_ANALITICA = "555001"  # Eliana(EY) me dice que ponga esta cuenta directamente (22/11/2018)

   If [F:EXS]FCY = "2000" Then
     PLAN1 = "PBC"
     PLAN2 = "PBA"
   Else
      PLAN1 = "PGC"
      PLAN2 = "PGA"
   Endif

  Wrseq 'L','1',[F:EXS]FCY,PLAN1,PLAN2,'COM','USG',LCUENTA,LCUENTA_ANALITICA,'','','NGEN','',ctrans(num$(abs([F:EXS]AMTPAY)),".",","),[F:EXS]VAT,'','','',''

  Wrseq 'A','1','CCT','ARS','FAM','DEP','CDV','','','','','','','',ctrans(num$(abs([F:EXS]AMTPAY)),".",","),''

  # [F:EXS]TYPRAT

  Openo

End



#**
#* CREAR_JOB(PFICHERO)
#*
#* @param PFICHERO
#*!
Subprog CREAR_JOB(PFICHERO, PMODELO)
  Global Char NOMBRE_AUX(250)


  NOMBRE_AUX = filpath("IMP", PFICHERO, "csv",nomap)
  # Infbox "CREAR_JOB" + NOMBRE_AUX
  # Openo filpath("IMP/BATCH/JOB", PFICHERO, "job",nomap)
  Openo filpath("E:/SAGE/X3V11BK/FOLDERS/RBI/IMP/BATCH/JOB", PFICHERO, "job",nomap)

  Wrseq 'DOSSIER='+[S]nomap(0)
  Wrseq 'LAN=SPA'
  Wrseq 'UTIL=ADMIN'
  Wrseq 'PASSE=BAABAA'
  Wrseq 'GRP='
  Wrseq 'TACHE=IMPORT'
  Wrseq 'DATE=20180101'
  Wrseq 'HEURE=0001'
  Wrseq 'MODIMP=' + PMODELO
  Wrseq 'NOMIMP=' + NOMBRE_AUX
  Wrseq 'TYPEXP=2'
  Wrseq 'VOLFIL=[IMP]/' + PFICHERO + '.csv'
  Wrseq 'ZMODIMP=Import desde JOB'
  Openo

End

