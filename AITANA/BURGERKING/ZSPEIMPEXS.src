$ACTION

 Case ACTION
    When "IMP_AVANT_OUVRE"  : Gosub $IMP_AVANT_OUVRE
    When "AP_IMPORT"        : Gosub $AP_IMPORT
    When "IMP_APRES_MOD"    : Gosub $IMP_APRES_MOD


  #  When "IMP_FERME"        : Gosub $IMP_FERME

    When Default
  Endcase
  Return



$OUVRE
    Gosub OUVRE From GASIMPORT
  Return

$RAZCRE
    Gosub RAZCRE From GASIMPORT
  Return

$VALID

    Gosub VALID From GASIMPORT
  Return

$SAIMSK
    Gosub SAIMSK From GASIMPORT
    Return

$IMP_FERME
  Return



$IMP_APRES_MOD

Return





