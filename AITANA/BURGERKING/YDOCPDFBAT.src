#<AdxTL>@(#)0.0.0.0 $Revision$ 

$ACTION
  Case ACTION
    When "INIT"        : Gosub INIT         # GTRAITE
    When "OUVRE_BATCH" : Gosub OUVRE_BATCH  # GTRAITE, GBATCH=1
    When "EXEC"        : Gosub EXEC
    When Default
      If [V]GBATCH and func YSENDPDF.COME_FROM_TRT("GSAISIE")=1
        Gosub ACTION From YDOCPDF
      Endif
  Endcase
Return

#------------------------------------------------------------------------------#

$INIT
  Gosub OUVRE From YDOCPDF
  If [V]GSERVEUR
    If clalev([M:YDPDF])=0 : Local Mask YDOCPDF [YDPDF] : Endif
  Endif
Return

#------------------------------------------------------------------------------#

$OUVRE_BATCH
  Gosub OUVRE From YDOCPDF
Return

#------------------------------------------------------------------------------#

$EXEC
  If [M:YDPDF]NBLIG=0
    Gosub SEARCH From YDOCPDF
  Endif
  Gosub GENERATE From YDOCPDF
Return

#------------------------------------------------------------------------------#







