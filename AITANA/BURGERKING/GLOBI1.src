#########################################################
Subprog CALCUL_CONTEXTES_PREPARE (PTABCNT)
#
# - Objet  : Préparer le calcul du contexte d'un bien de la société.
#
#              Pour chaque Contextes ŕ calculer
#                Charger les plans des contextes dans les masques dédiés
#
#
# - Entrée :
#            Tableau des contextes ŕ calculer
#
#
# - Sortie : Code Erreur
#                 0 = Calcul société OK
#
#
#
Value    Integer PTABCNT()

  Raz [M:DIV]SORREG
  Raz [M:DIV]SORREGT
  Raz [M:DIV]SORREGI

  # Chargement du plan de production ( ŕ rupture premičre sur plan de production)

  #- 1 -------------------------
  # FQ74844
  If ( [M:DIV]CNXUO <> 0 and find([M:DIV]CNXUO, PTABCNT) <> 0  and [F:WFAS]PROPLN <> "") Then
    If ( [F:WFAS]PROPLN <> [M:DIV]PROPLN ) Then

      Local Char LABR
      Case [M:DIV]CNXUO
        When G300CPFI : LABR = "[M:EGCF]"
        When G300IAS  : LABR = "[M:EIAS]"
        When G300TEC  : LABR = "[M:ETEC]"
        When G300RET  : LABR = "[M:ERET]"
        When G300SUB  : LABR = "[M:ESUB]"
        When G300LIB  : LABR = "[M:ELI1]"
        When G300SU1  : LABR = "[M:ELI2]"
        When G300SU2  : LABR = "[M:ELI3]"
        When G300SU3  : LABR = "[M:ELI4]"
        When G300SU4  : LABR = "[M:ELI5]"
        When G300SU5  : LABR = "[M:ELI6]"
      Endcase

      [M:DIV]LVLLIB = "0.CAL_LEC_PROPLN" : Gosub CAL_ADDLVL  From =G_GLOB0
      Call CAL_LEC_PROPLN ( LABR, [F:WFAS]PROPLN ) From =G_GLOB0
      # Sauvegarde référence du dernier plan de production lu
      [M:DIV]PROPLN = [F:WFAS]PROPLN
    Endif
  Endif
  #- 1 -------------------------

  #--
  # Chargement des plans des contextes ŕ calculer dans les masques dédiés

  # >>>>>>>>>>>>>>>>>
  # Ouverture des masques de travail des plans rattachés aux contextes ŕ calculer
  Local Integer J_CNT
  Local Integer D_CNT
  Local Integer J_PLN
  J_CNT = 0
  While ( PTABCNT(J_CNT) <> 0 )
    D_CNT = find( PTABCNT(J_CNT), [M:DIV]PLNCNT )
    For J_PLN = D_CNT To [M:DIV]NB_PLN
      If ( [M:DIV]PLNCNT (J_PLN-1) <> PTABCNT(J_CNT) ) Then : Break : Endif

      [M:DIV]LVLLIB="0.CAL_LEC_DEPREC"-mess([M:DIV]PLNCAA(J_PLN-1),GML_NPLAN,1): Gosub CAL_ADDLVL From =G_GLOB0
      Call CAL_LEC_DEPREC ([M:DIV]BCO, [M:DIV]PLNCAA(J_PLN-1), PTABCNT(J_CNT)  ) From =G_GLOB0

      Case [M:DIV]PLNCAA(J_PLN-1)
        When  G301CPT
          If ( [M:PCPT]NB_DEP > [M:DEP]NB_DEP ) Then : Raz [M:PCPT] : Endif : Transmask [M:DEP] To [M:PCPT]
        When  G301FIS
          If ( [M:PFIS]NB_DEP > [M:DEP]NB_DEP ) Then : Raz [M:PFIS] : Endif : Transmask [M:DEP] To [M:PFIS]
        When  G301MIN
          If ( [M:PMIN]NB_DEP > [M:DEP]NB_DEP ) Then : Raz [M:PMIN] : Endif : Transmask [M:DEP] To [M:PMIN]
        When  G301ORI
          If ( [M:PORI]NB_DEP > [M:DEP]NB_DEP ) Then : Raz [M:PORI] : Endif : Transmask [M:DEP] To [M:PORI]
        When  G301R76
          If ( [M:PR76]NB_DEP > [M:DEP]NB_DEP ) Then : Raz [M:PR76] : Endif : Transmask [M:DEP] To [M:PR76]
        When  G301IAS
          If ( [M:PIAS]NB_DEP > [M:DEP]NB_DEP ) Then : Raz [M:PIAS] : Endif : Transmask [M:DEP] To [M:PIAS]
        When  G301TEC
          If ( [M:PTEC]NB_DEP > [M:DEP]NB_DEP ) Then : Raz [M:PTEC] : Endif : Transmask [M:DEP] To [M:PTEC]
        When  G301RET
          If ( [M:PRET]NB_DEP > [M:DEP]NB_DEP ) Then : Raz [M:PRET] : Endif : Transmask [M:DEP] To [M:PRET]
        When  G301SUB
          If ( [M:PSUB]NB_DEP > [M:DEP]NB_DEP ) Then : Raz [M:PSUB] : Endif : Transmask [M:DEP] To [M:PSUB]
        When  G301LI1
          If ( [M:PLI1]NB_DEP > [M:DEP]NB_DEP ) Then : Raz [M:PLI1] : Endif : Transmask [M:DEP] To [M:PLI1]
        When  G301LI2
          If ( [M:PLI2]NB_DEP > [M:DEP]NB_DEP ) Then : Raz [M:PLI2] : Endif : Transmask [M:DEP] To [M:PLI2]
        When  G301LI3
          If ( [M:PLI3]NB_DEP > [M:DEP]NB_DEP ) Then : Raz [M:PLI3] : Endif : Transmask [M:DEP] To [M:PLI3]
        When  G301LI4
          If ( [M:PLI4]NB_DEP > [M:DEP]NB_DEP ) Then : Raz [M:PLI4] : Endif : Transmask [M:DEP] To [M:PLI4]
        When  G301LI5
          If ( [M:PLI5]NB_DEP > [M:DEP]NB_DEP ) Then : Raz [M:PLI5] : Endif : Transmask [M:DEP] To [M:PLI5]
        When  G301LI6
          If ( [M:PLI6]NB_DEP > [M:DEP]NB_DEP ) Then : Raz [M:PLI6] : Endif : Transmask [M:DEP] To [M:PLI6]
        When  Default
      Endcase
    Next J_PLN
    J_CNT +=1
  Wend
  # <<<<<<<<<<<<<<<<

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    BEFCLC                  E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
  If ( G_ETP_GLOBI1 ) Then : # FQ114113
    GPOINT = "BEFCLC"
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9000 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite ŕ erreur logique
    Endif
  Endif
#CHECK IGNORE_END
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE


  # FQ54343
  If ( [M:DIV]BACTCCN and [F:WFAS]OWNTYP = GVML_TDCONCE and [M:DIV]CCNMOD = GVML_GCRNW ) Then
    #--
    # Chargement des provisions ŕ calculer dans le masque dédié
    Local Date WDTFNEXE
    WFINEXE = [M:EGCF]DATENDFIY(find( GVML_TECOURA, [M:EGCF]STAFIY ) - 1)
    Call CCN_LEC_CCNRPR ([M:DIV]BCO, WFINEXE  ) From  =G_GLOB0
    If ( [M:PRPR]NB_RPR > [M:RPR]NB_RPR ) Then : Raz [M:PRPR] : Endif : Transmask [M:RPR] To [M:PRPR]


    # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
    # E   Point d'entrée    BEFCCN                  E
    # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
    If ( G_ETP_GLOBI1 ) Then : # FQ114113
      GPOINT = "BEFCCN"
      Gosub ENTREE From EXEFNC
      If !(GOK) Then
        [M:DIV]ERRID = 9000 : End
      Endif
    Endif
#CHECK IGNORE_END
    # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

End


#########################################################
Subprog CALCUL_CONTEXTE (PCNT)
#
# - Objet  : Calculer un contexte d'un bien.
#
#              Pour tous les plans du contexte
#                Charger le masque DEP ŕ partir du masque dédié au plan concerné
#                Calculer le plan (CALCUL_PLAN)
#                Décharger le masque DEP les champs de WFAS ( avec positionnement de code action)

Value    Integer PCNT


Local Integer DEB, N_P

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #--
  Call ECR_FICH ( "FS1", 3, "::::::::::::::::::::::::::::::::::::::::::::::::" ) From =G_GLOB0
  Call ECR_FICH ( "FS1", 3, "CALCUL_CONTEXTE - "-mess(PCNT,GML_NCONTEXT,1)  ) From =G_GLOB0

  #-- Affectation masques  [M:FIY]Exercice / Périodes du contexte
  Case PCNT
    When G300CPFI
      If ( [M:FIY]NB_EXE > [M:EGCF]NB_EXE ) Then : Raz [M:FIY] : Endif : Transmask [M:EGCF] To [M:FIY]
    When G300IAS
      If ( [M:FIY]NB_EXE > [M:EIAS]NB_EXE ) Then : Raz [M:FIY] : Endif : Transmask [M:EIAS] To [M:FIY]
    When G300TEC
      If ( [M:FIY]NB_EXE > [M:ETEC]NB_EXE ) Then : Raz [M:FIY] : Endif : Transmask [M:ETEC] To [M:FIY]
    When G300RET
      If ( [M:FIY]NB_EXE > [M:ERET]NB_EXE ) Then : Raz [M:FIY] : Endif : Transmask [M:ERET] To [M:FIY]
    When G300SUB
      If ( [M:FIY]NB_EXE > [M:ESUB]NB_EXE ) Then : Raz [M:FIY] : Endif : Transmask [M:ESUB] To [M:FIY]
    When G300LIB
      If ( [M:FIY]NB_EXE > [M:ELI1]NB_EXE ) Then : Raz [M:FIY] : Endif : Transmask [M:ELI1] To [M:FIY]
    When G300SU1
      If ( [M:FIY]NB_EXE > [M:ELI2]NB_EXE ) Then : Raz [M:FIY] : Endif : Transmask [M:ELI2] To [M:FIY]
    When G300SU2
      If ( [M:FIY]NB_EXE > [M:ELI3]NB_EXE ) Then : Raz [M:FIY] : Endif : Transmask [M:ELI3] To [M:FIY]
    When G300SU3
      If ( [M:FIY]NB_EXE > [M:ELI4]NB_EXE ) Then : Raz [M:FIY] : Endif : Transmask [M:ELI4] To [M:FIY]
    When G300SU4
      If ( [M:FIY]NB_EXE > [M:ELI5]NB_EXE ) Then : Raz [M:FIY] : Endif : Transmask [M:ELI5] To [M:FIY]
    When G300SU5
      If ( [M:FIY]NB_EXE > [M:ELI6]NB_EXE ) Then : Raz [M:FIY] : Endif : Transmask [M:ELI6] To [M:FIY]
  Endcase

  #-- Affectation masque  [M:DIV] relatif au contexte
  # Contexte ŕ calculer
  [M:DIV]CNT = PCNT
  # Indice exercice courant
  [M:DIV]FEC = find( GVML_TECOURA, [M:FIY]STAFIY )
  # Indice de la période courante de l'exercice courant
  [M:DIV]FPC = [M:FIY]INDDEBPER ([M:DIV]FEC-1) + [M:FIY]INDCURPER ([M:DIV]FEC-1) - 1
  # Devise du contexte ŕ calculer
  [M:DIV]CUR = [M:CNX]CUR (find ([M:DIV]CNT,  [M:CNX]CNX) - 1)
  # Format d'édition de la devise du contexte ŕ calculer
  [M:DIV]CURFMT = "N3:"+GDEVFMT1 (find([M:DIV]CUR, GDEVISE))

 #========================================================

  # Préséance niveau 0 Plan subvention
  Local Integer L_PLNSUB : L_PLNSUB = 0
  #-1 ---------------
  If ( PCNT = G300CPFI and [M:DIV]BACTCCN and [M:DIV]CCNFLG = G_OUI ) Then
    # Concessions gérées
    If ( [M:DIV]CCNMOD = GVML_GCFIR and [M:DIV]PLNSUB            ) Then : L_PLNSUB = G301SUB          : Endif
    If ( [M:DIV]CCNMOD = GVML_GCRNW and [M:DIV]CCNGRTFLG = G_OUI ) Then : L_PLNSUB = [M:DIV]CCNGRTPLN : Endif
    #-2 ---------------
    If ( L_PLNSUB ) Then
      #-- Affectation masque "Plan amort" dans [M:DEP]
      Case L_PLNSUB
        When G301FIS
          If ( [M:DEP]NB_DEP  > [M:PFIS]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PFIS] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PFIS]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PFIS] To [M:WDEP]
        When G301ORI
          If ( [M:DEP]NB_DEP  > [M:PORI]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PORI] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PORI]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PORI] To [M:WDEP]
        When G301R76
          If ( [M:DEP]NB_DEP  > [M:PR76]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PR76] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PR76]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PR76] To [M:WDEP]
        When G301IAS
          If ( [M:DEP]NB_DEP  > [M:PIAS]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PIAS] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PIAS]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PIAS] To [M:WDEP]
        When G301TEC
          If ( [M:DEP]NB_DEP  > [M:PTEC]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PTEC] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PTEC]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PTEC] To [M:WDEP]
        When G301RET
          If ( [M:DEP]NB_DEP  > [M:PRET]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PRET] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PRET]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PRET] To [M:WDEP]
        When G301SUB
          If ( [M:DEP]NB_DEP  > [M:PSUB]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PSUB] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PSUB]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PSUB] To [M:WDEP]
        When G301LI1
          If ( [M:DEP]NB_DEP  > [M:PLI1]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI1] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI1]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI1] To [M:WDEP]
        When G301LI2
          If ( [M:DEP]NB_DEP  > [M:PLI2]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI2] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI2]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI2] To [M:WDEP]
        When G301LI3
          If ( [M:DEP]NB_DEP  > [M:PLI3]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI3] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI3]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI3] To [M:WDEP]
        When G301LI4
          If ( [M:DEP]NB_DEP  > [M:PLI4]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI4] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI4]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI4] To [M:WDEP]
        When G301LI5
          If ( [M:DEP]NB_DEP  > [M:PLI5]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI5] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI5]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI5] To [M:WDEP]
        When G301LI6
          If ( [M:DEP]NB_DEP  > [M:PLI6]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI6] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI6]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI6] To [M:WDEP]
        When G301MIN
          If ( [M:DEP]NB_DEP  > [M:PMIN]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PMIN] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PMIN]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PMIN] To [M:WDEP]
        When G301CPT
          If ( [M:DEP]NB_DEP  > [M:PCPT]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PCPT] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PCPT]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PCPT] To [M:WDEP]
      Endcase
      Call ECR_FICH ( "FS1", 4, "----------------------------------------------------------" ) From =G_GLOB0
      Call ECR_FICH ( "FS1", 4, "CALCUL_PLAN - Plan"- mess(L_PLNSUB,GML_NPLAN,1) )              From =G_GLOB0

      If (G_CLCSTD) Then
        # Le plan est calculé ŕ partir du standard
        [M:DIV]LVLLIB= "1.CALCUL_PLAN"- mess(L_PLNSUB,GML_NPLAN,1) : Gosub CAL_ADDLVL From =G_GLOB0
        Call CALCUL_PLAN  From =G_GLOB1
        # ERRFND effectué hors boucle
        If ([M:DIV]ERROR) Then : End : Endif
      Endif

      #-- Affectation [M:DEP] dans masque "Plan amort"
      [M:DIV]LVLLIB = "0.CAL_EVALUE_ACTION_DEP" : Gosub CAL_ADDLVL From =G_GLOB0
      Case L_PLNSUB
        When G301FIS
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PFIS]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PFIS] : Endif : Transmask [M:DEP] To [M:PFIS]
        When G301ORI
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PORI]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PORI] : Endif : Transmask [M:DEP] To [M:PORI]
        When G301R76
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PR76]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PR76] : Endif : Transmask [M:DEP] To [M:PR76]
        When G301IAS
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PIAS]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PIAS] : Endif : Transmask [M:DEP] To [M:PIAS]
        When G301TEC
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PTEC]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PTEC] : Endif : Transmask [M:DEP] To [M:PTEC]
        When G301RET
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PRET]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PRET] : Endif : Transmask [M:DEP] To [M:PRET]
        When G301SUB
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PSUB]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PSUB] : Endif : Transmask [M:DEP] To [M:PSUB]
        When G301LI1
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PLI1]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI1] : Endif : Transmask [M:DEP] To [M:PLI1]
        When G301LI2
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PLI2]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI2] : Endif : Transmask [M:DEP] To [M:PLI2]
        When G301LI3
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PLI3]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI3] : Endif : Transmask [M:DEP] To [M:PLI3]
        When G301LI4
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PLI4]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI4] : Endif : Transmask [M:DEP] To [M:PLI4]
        When G301LI5
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PLI5]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI5] : Endif : Transmask [M:DEP] To [M:PLI5]
        When G301LI6
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PLI6]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI6] : Endif : Transmask [M:DEP] To [M:PLI6]
        When G301MIN
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PMIN]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PMIN] : Endif : Transmask [M:DEP] To [M:PMIN]
        When G301CPT
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PCPT]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PCPT] : Endif : Transmask [M:DEP] To [M:PCPT]
        When Default
      Endcase
    Endif
    #-2 ---------------
  Endif
  #-1 ---------------

  # Préséance niveau 1 Plan minimum
  If ( PCNT = G300CPFI and [M:DIV]PLNMIN ) Then
    If ( [M:DEP]NB_DEP  > [M:PMIN]NB_DEP )  Then : Raz [M:DEP]  : Endif :  Transmask [M:PMIN] To [M:DEP]
    If ( [M:WDEP]NB_DEP > [M:PMIN]NB_DEP )  Then : Raz [M:WDEP] : Endif :  Transmask [M:PMIN] To [M:WDEP]
    Call ECR_FICH ( "FS1", 4, "----------------------------------------------------------" ) From =G_GLOB0
    Call ECR_FICH ( "FS1", 4, "CALCUL_PLAN - Plan"- mess(G301MIN,GML_NPLAN,1) )              From =G_GLOB0
    If (G_CLCSTD) Then
      [M:DIV]LVLLIB = "1.CALCUL_PLAN"- mess(G301MIN,GML_NPLAN,1) : Gosub CAL_ADDLVL  From =G_GLOB0
      Call CALCUL_PLAN  From =G_GLOB1
      If ([M:DIV]ERROR) Then : Call ERRFND From =G_GLOB0 : End : Endif : # FQ114113
    Endif

    [M:DIV]LVLLIB = "0.CAL_EVALUE_ACTION_DEP" : Gosub CAL_ADDLVL From =G_GLOB0
    Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
    If ( [M:DIV]ERROR ) Then :  End : Endif

    If ( [M:PMIN]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PMIN] : Endif
    Transmask [M:DEP]  To [M:PMIN]
  Endif

  # Préséance niveau 2 Plan comptable
  If ( PCNT = G300CPFI and [M:DIV]PLNCPT ) Then
    If ( [M:DEP]NB_DEP  > [M:PCPT]NB_DEP )  Then : Raz [M:DEP]  : Endif :  Transmask [M:PCPT] To [M:DEP]
    If ( [M:WDEP]NB_DEP > [M:PCPT]NB_DEP )  Then : Raz [M:WDEP] : Endif :  Transmask [M:PCPT] To [M:WDEP]
    Call ECR_FICH ( "FS1", 4, "----------------------------------------------------------" ) From =G_GLOB0
    Call ECR_FICH ( "FS1", 4, "CALCUL_PLAN - Plan"- mess(G301CPT,GML_NPLAN,1) )              From =G_GLOB0
    If (G_CLCSTD) Then
      [M:DIV]LVLLIB = "1.CALCUL_PLAN"- mess(G301CPT,GML_NPLAN,1) : Gosub CAL_ADDLVL  From =G_GLOB0
      Call CALCUL_PLAN  From =G_GLOB1
      If ([M:DIV]ERROR) Then : Call ERRFND From =G_GLOB0 : End : Endif : # FQ114113
    Endif
    [M:DIV]LVLLIB = "0.CAL_EVALUE_ACTION_DEP" : Gosub CAL_ADDLVL From =G_GLOB0
    Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
    If ( [M:DIV]ERROR ) Then : End : Endif
    If ( [M:PCPT]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PCPT] : Endif
    Transmask [M:DEP]  To [M:PCPT]
  Endif

 #========================================================

  # Préséance niveau 3 Plan prioritaire  - FQ103931
  Local Integer L_PLNPIO : L_PLNPIO = 0

  #-1 ---------------
  If ( PCNT = G300CPFI and
&     [M:DIV2]DPRPLNPIO <> G301MIN  and [M:DIV2]DPRPLNPIO <> G301CPT and
&     [M:DIV2]DPRPLNPIO <> L_PLNSUB and [M:DIV2]DPRPLNPIO <> G301AUC     ) Then

    L_PLNPIO = [M:DIV2]DPRPLNPIO
    #-2 ---------------
    If ( L_PLNPIO ) Then
      #-- Affectation masque "Plan amort" dans [M:DEP]
      Case L_PLNPIO
        When G301FIS
          If ( [M:DEP]NB_DEP  > [M:PFIS]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PFIS] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PFIS]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PFIS] To [M:WDEP]
        When G301ORI
          If ( [M:DEP]NB_DEP  > [M:PORI]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PORI] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PORI]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PORI] To [M:WDEP]
        When G301R76
          If ( [M:DEP]NB_DEP  > [M:PR76]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PR76] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PR76]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PR76] To [M:WDEP]
        When G301IAS
          If ( [M:DEP]NB_DEP  > [M:PIAS]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PIAS] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PIAS]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PIAS] To [M:WDEP]
        When G301TEC
          If ( [M:DEP]NB_DEP  > [M:PTEC]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PTEC] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PTEC]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PTEC] To [M:WDEP]
        When G301RET
          If ( [M:DEP]NB_DEP  > [M:PRET]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PRET] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PRET]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PRET] To [M:WDEP]
        When G301SUB
          If ( [M:DEP]NB_DEP  > [M:PSUB]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PSUB] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PSUB]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PSUB] To [M:WDEP]
        When G301LI1
          If ( [M:DEP]NB_DEP  > [M:PLI1]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI1] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI1]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI1] To [M:WDEP]
        When G301LI2
          If ( [M:DEP]NB_DEP  > [M:PLI2]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI2] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI2]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI2] To [M:WDEP]
        When G301LI3
          If ( [M:DEP]NB_DEP  > [M:PLI3]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI3] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI3]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI3] To [M:WDEP]
        When G301LI4
          If ( [M:DEP]NB_DEP  > [M:PLI4]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI4] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI4]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI4] To [M:WDEP]
        When G301LI5
          If ( [M:DEP]NB_DEP  > [M:PLI5]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI5] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI5]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI5] To [M:WDEP]
        When G301LI6
          If ( [M:DEP]NB_DEP  > [M:PLI6]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI6] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI6]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI6] To [M:WDEP]
        When G301MIN
          If ( [M:DEP]NB_DEP  > [M:PMIN]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PMIN] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PMIN]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PMIN] To [M:WDEP]
        When G301CPT
          If ( [M:DEP]NB_DEP  > [M:PCPT]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PCPT] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PCPT]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PCPT] To [M:WDEP]
      Endcase
      Call ECR_FICH ( "FS1", 4, "----------------------------------------------------------" ) From =G_GLOB0
      Call ECR_FICH ( "FS1", 4, "CALCUL_PLAN - Plan"- mess(L_PLNPIO,GML_NPLAN,1) )              From =G_GLOB0

      If (G_CLCSTD) Then
        # Le plan est calculé ŕ partir du standard
        [M:DIV]LVLLIB= "1.CALCUL_PLAN"- mess(L_PLNPIO,GML_NPLAN,1) : Gosub CAL_ADDLVL From =G_GLOB0
        Call CALCUL_PLAN  From =G_GLOB1
        # ERRFND effectué hors boucle
        If ([M:DIV]ERROR) Then : End : Endif  : # FQ114113
      Endif

      #-- Affectation [M:DEP] dans masque "Plan amort"
      [M:DIV]LVLLIB = "0.CAL_EVALUE_ACTION_DEP" : Gosub CAL_ADDLVL From =G_GLOB0
      Case L_PLNPIO
        When G301FIS
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PFIS]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PFIS] : Endif : Transmask [M:DEP] To [M:PFIS]
        When G301ORI
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PORI]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PORI] : Endif : Transmask [M:DEP] To [M:PORI]
        When G301R76
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PR76]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PR76] : Endif : Transmask [M:DEP] To [M:PR76]
        When G301IAS
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PIAS]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PIAS] : Endif : Transmask [M:DEP] To [M:PIAS]
        When G301TEC
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PTEC]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PTEC] : Endif : Transmask [M:DEP] To [M:PTEC]
        When G301RET
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PRET]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PRET] : Endif : Transmask [M:DEP] To [M:PRET]
        When G301SUB
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PSUB]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PSUB] : Endif : Transmask [M:DEP] To [M:PSUB]
        When G301LI1
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PLI1]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI1] : Endif : Transmask [M:DEP] To [M:PLI1]
        When G301LI2
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PLI2]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI2] : Endif : Transmask [M:DEP] To [M:PLI2]
        When G301LI3
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PLI3]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI3] : Endif : Transmask [M:DEP] To [M:PLI3]
        When G301LI4
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PLI4]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI4] : Endif : Transmask [M:DEP] To [M:PLI4]
        When G301LI5
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PLI5]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI5] : Endif : Transmask [M:DEP] To [M:PLI5]
        When G301LI6
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PLI6]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI6] : Endif : Transmask [M:DEP] To [M:PLI6]
        When G301MIN
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PMIN]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PMIN] : Endif : Transmask [M:DEP] To [M:PMIN]
        When G301CPT
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : End : Endif
          If ( [M:PCPT]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PCPT] : Endif : Transmask [M:DEP] To [M:PCPT]
        When Default
      Endcase
    Endif
    #-2 ---------------
  Endif
  #-1 ---------------



  DEB = find(PCNT, [M:DIV]PLNCNT)
  # >>>>>>>>>>>>
  # Pour chaque plan d'amortissement rattaché au contexte
  For N_P = DEB To [M:DIV]NB_PLN
    # Si le plan d'amortissement n'appartient plus au contexte en cours de calcul
    If ( [M:DIV]PLNCNT (N_P-1) <> PCNT )  Then : Break : Endif

    #-1 ---------------
    If ( [M:DIV]PLNCAA(N_P-1) <> G301MIN  and [M:DIV]PLNCAA(N_P-1) <> G301CPT  and
&        [M:DIV]PLNCAA(N_P-1) <> L_PLNSUB and [M:DIV]PLNCAA(N_P-1) <> L_PLNPIO      ) Then
      # Les plans minimum, comptable et éventuellement subvention ou plan prioritaire sont déjŕ calculés FQ103931

      Raz [M:DEP]: Raz [M:WDEP]
      #-- Affectation masque "Plan amort" dans [M:DEP]
      Case [M:DIV]PLNCAA(N_P-1)
        When G301FIS
          If ( [M:DEP]NB_DEP  > [M:PFIS]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PFIS] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PFIS]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PFIS] To [M:WDEP]
        When G301ORI
          If ( [M:DEP]NB_DEP  > [M:PORI]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PORI] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PORI]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PORI] To [M:WDEP]
        When G301R76
          If ( [M:DEP]NB_DEP  > [M:PR76]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PR76] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PR76]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PR76] To [M:WDEP]
        When G301IAS
          If ( [M:DEP]NB_DEP  > [M:PIAS]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PIAS] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PIAS]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PIAS] To [M:WDEP]
        When G301TEC
          If ( [M:DEP]NB_DEP  > [M:PTEC]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PTEC] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PTEC]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PTEC] To [M:WDEP]
        When G301RET
          If ( [M:DEP]NB_DEP  > [M:PRET]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PRET] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PRET]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PRET] To [M:WDEP]
        When G301SUB
          If ( [M:DEP]NB_DEP  > [M:PSUB]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PSUB] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PSUB]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PSUB] To [M:WDEP]
        When G301LI1
          If ( [M:DEP]NB_DEP  > [M:PLI1]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI1] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI1]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI1] To [M:WDEP]
        When G301LI2
          If ( [M:DEP]NB_DEP  > [M:PLI2]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI2] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI2]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI2] To [M:WDEP]
        When G301LI3
          If ( [M:DEP]NB_DEP  > [M:PLI3]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI3] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI3]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI3] To [M:WDEP]
        When G301LI4
          If ( [M:DEP]NB_DEP  > [M:PLI4]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI4] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI4]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI4] To [M:WDEP]
        When G301LI5
          If ( [M:DEP]NB_DEP  > [M:PLI5]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI5] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI5]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI5] To [M:WDEP]
        When G301LI6
          If ( [M:DEP]NB_DEP  > [M:PLI6]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PLI6] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PLI6]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PLI6] To [M:WDEP]
        When G301MIN
          If ( [M:DEP]NB_DEP  > [M:PMIN]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PMIN] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PMIN]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PMIN] To [M:WDEP]
        When G301CPT
          If ( [M:DEP]NB_DEP  > [M:PCPT]NB_DEP ) Then : Raz [M:DEP]  : Endif : Transmask [M:PCPT] To [M:DEP]
          If ( [M:WDEP]NB_DEP > [M:PCPT]NB_DEP ) Then : Raz [M:WDEP] : Endif : Transmask [M:PCPT] To [M:WDEP]
      Endcase

      Call ECR_FICH ( "FS1", 4, "----------------------------------------------------------" ) From =G_GLOB0
      Call ECR_FICH ( "FS1", 4, "CALCUL_PLAN - Plan"- mess([M:DIV]PLNCAA(N_P-1),GML_NPLAN,1) ) From =G_GLOB0

      #    ***********
      If (G_CLCSTD) Then
        # Le plan est calculé ŕ partir du standard
        [M:DIV]LVLLIB= "1.CALCUL_PLAN"- mess([M:DIV]PLNCAA(N_P-1),GML_NPLAN,1) : Gosub CAL_ADDLVL From =G_GLOB0
        Call CALCUL_PLAN  From =G_GLOB1
        # ERRFND effectué hors boucle
        If ([M:DIV]ERROR) Then  : Break : Endif  : # FQ114113
      Endif
      #    ***********

      #-- Affectation [M:DEP] dans masque "Plan amort"
      [M:DIV]LVLLIB = "0.CAL_EVALUE_ACTION_DEP" : Gosub CAL_ADDLVL From =G_GLOB0
      Case [M:DIV]PLNCAA(N_P-1)
        When G301FIS
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : Break : Endif
          If ( [M:PFIS]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PFIS] : Endif : Transmask [M:DEP] To [M:PFIS]
        When G301ORI
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : Break : Endif
          If ( [M:PORI]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PORI] : Endif : Transmask [M:DEP] To [M:PORI]
        When G301R76
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : Break : Endif
          If ( [M:PR76]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PR76] : Endif : Transmask [M:DEP] To [M:PR76]
        When G301IAS
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : Break : Endif
          If ( [M:PIAS]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PIAS] : Endif : Transmask [M:DEP] To [M:PIAS]
        When G301TEC
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : Break : Endif
          If ( [M:PTEC]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PTEC] : Endif : Transmask [M:DEP] To [M:PTEC]
        When G301RET
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : Break : Endif
          If ( [M:PRET]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PRET] : Endif : Transmask [M:DEP] To [M:PRET]
        When G301SUB
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : Break : Endif
          If ( [M:PSUB]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PSUB] : Endif : Transmask [M:DEP] To [M:PSUB]
        When G301LI1
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : Break : Endif
          If ( [M:PLI1]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI1] : Endif : Transmask [M:DEP] To [M:PLI1]
        When G301LI2
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : Break : Endif
          If ( [M:PLI2]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI2] : Endif : Transmask [M:DEP] To [M:PLI2]
        When G301LI3
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : Break : Endif
          If ( [M:PLI3]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI3] : Endif : Transmask [M:DEP] To [M:PLI3]
        When G301LI4
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : Break : Endif
          If ( [M:PLI4]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI4] : Endif : Transmask [M:DEP] To [M:PLI4]
        When G301LI5
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : Break : Endif
          If ( [M:PLI5]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI5] : Endif : Transmask [M:DEP] To [M:PLI5]
        When G301LI6
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : Break : Endif
          If ( [M:PLI6]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI6] : Endif : Transmask [M:DEP] To [M:PLI6]
        When G301MIN
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : Break : Endif
          If ( [M:PMIN]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PMIN] : Endif : Transmask [M:DEP] To [M:PMIN]
        When G301CPT
          Call CAL_EVALUE_ACTION_DEP([M:DIV]TDFN,[M:DIV]NBF) From =G_GLOB0
          If ( [M:DIV]ERROR ) Then : Break : Endif
          If ( [M:PCPT]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PCPT] : Endif : Transmask [M:DEP] To [M:PCPT]
        When Default
          # Gestion des erreurs (CAL_EVALUE_ACTION_DEP)
          Gosub CAL_RMVLVL From =G_GLOB0
      Endcase
    Endif
    #-1 ---------------
  Next N_P
  # <<<<<<<<<<<<

  # FQ54343
  # Traitements complémentaires aprčs le calcul d'un contexte
  [M:DIV]LVLLIB = "1.APRES_CALCUL_CONTEXTE" : Gosub CAL_ADDLVL From =G_GLOB0
  Call APRES_CALCUL_CONTEXTE (PCNT)  From =G_GLOB1

  If ([M:DIV]ERROR) Then
    Call ERRFND From =G_GLOB0 : End : # Dépilement suite ŕ erreur logique
  Endif

# ========================================================

  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    BEFLNK                  E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
  If ( G_ETP_GLOBI1 ) Then : # FQ114113
    GPOINT = "BEFLNK"
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9001 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite ŕ erreur logique
    Endif
  Endif
#CHECK IGNORE_END
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

  #----------------------
  If (G_CLCSTD) Then
    # Gestion des liens génériques entre plans d'un męme contexte
    # Gestion du dérogatoire et de la réintégration fiscale
    [M:DIV]LVLLIB = "2.CALCUL_PLAN_LIENS" : Gosub CAL_ADDLVL From =G_GLOB0
    Gosub CALCUL_PLAN_LIENS From =G_GLOB2
  Endif
  #----------------------

  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    AFTLNK                  E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
  If ( G_ETP_GLOBI1 ) Then : # FQ114113
    GPOINT = "AFTLNK"
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9002 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite ŕ erreur logique
    Endif
  Endif
#CHECK IGNORE_END
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

  # Gestion des erreurs (CALCUL_CONTEXTE)
  Gosub CAL_RMVLVL From =G_GLOB0

End

#===============================================
$EVALUE_BFINI

  # Contôle de la limite du masque DEP
  If ([M:DIV]DL = [M:DIV]DEPMAX ) Then
    # La limite du masque DEP a été atteinte
    [M:DIV]ERRID = 27 : Call ERRFND From =G_GLOB0 : Return : # Dépilement suite ŕ erreur logique
  Else
    # Sortie de boucle selon conditions dépendant du traitement demandé
    Case [M:DIV]TRTDEM
      When "CALSOC", "CALBCO", "CALVNC", "CALDPS"
        # -- Calcul société / Calcul d'un bien  FQ79856
        # Arręt lorsque l'horizon exercice ŕ calculer est atteint
        If ( INDEXECAL > [M:CNX]HRZEXE(find([M:DIV]CNT, [M:CNX]CNX)-1) ) Then : BFINI = 1 : Endif : # FQ74517 FQ78670
      When "CALSIM"
        # -- Simulation Calcul d'un bien
        # Pour le mode "SA" -- Arręt lorsque l'horizon exercice ŕ calculer est atteint
        If ( [F:DEPC]DPM =  G_DPMSA and INDEXECAL > [M:CNX]HRZEXE(find([M:DIV]CNT, [M:CNX]CNX)-1) ) Then : # FQ74517 FQ78670
          BFINI = 1
        Endif
        If ( [F:DEPC]DPM =  G_DPMLV and INDEXECAL > [M:CNX]HRZEXE(find([M:DIV]CNT, [M:CNX]CNX)-1) ) Then : # FQ74517 FQ78670
          [M:DIV]DL -=1
          BFINI = 1
        Endif
        # Pour un bien en concession -- Arręt ŕ fin de concession
        If ( [F:WFAS]OWNTYP = GVML_TDCONCE and
&            ( [F:DEPC]DPM = G_DPMCA or [F:DEPC]DPM = G_DPMRA ) and
&            [F:WFAS]CCNETRTYP = GVML_NA1ERBC and [F:DEPC]FIYSTRDAT > [M:DIV]DTFNCON ) Then
          BFINI = 1
        Endif
        If ( [F:DEPC]DPM <> G_DPMLV and [F:DEPC]DPM <> G_DPMSA and [M:DIV]BSTPCLC ) Then
          # Cas général -- Arręt lorsque la valeur nette est égale ŕ la valeur résiduelle
          [M:DIV]DL -=1
          BFINI = 1
        Endif
        #FQ59941
        If ( find([F:DEPC]PERENDDAT, [M:FIY]DATENDPER) >= [M:FIY]NB_PER )  Then
          # Sécurité
          [M:DIV]DL -=1
          BFINI = 1
        Endif
      When Default
        BFINI = 1
    Endcase
    If (BFINI = 1) Then
      # Actualisation du nombre de lignes dans le masque DEP
      [M:DEP]NB_DEP = [M:DIV]DL
    Endif
  Endif

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

Return

#*********************************************************************
Subprog  CALCUL_PLAN
#
# - Objet  : Calcul d'un plan
#
#
#
# - Entrée : [M:DEP]
#
# - Sortie :
#


Local Integer RTRN

#
#   Boite noire
#
  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # --
  # Indice de la période/exercice "courant" dans [M:DEP]
  [M:DIV]DPC = find( [M:FIY]DATSTRPER ([M:DIV]FPC-1), [M:DEP]PERSTRDAT )

  # Si le bien a été sorti dans un exercice antérieur ŕ l'exercice courant on ne calcule pas le plan
  #FQ54343
  If ( [F:WFAS]ISSDAT <> [0/0/0] and [F:WFAS]ISSDAT < [M:FIY]DATSTRFIY([M:DIV]FEC-1) and
&      (not ([M:DIV]BACTCCN) or ([M:DIV]BACTCCN and [F:WFAS]CCNETRTYP <> GVML_NA1ERBC )) ) Then
    Call ECR_FICH ( "FS1", 3, "CALCUL_CONTEXTE - "-"Aucun calcul amortissement bien sorti dans un exercice antérieur"  ) From =G_GLOB0
    Goto FIN_CALCUL_PLAN
  Endif

  # En simulation et anomalie sur DEPREC on arręte et on boucle sur la société suivante FQ79813a
  If ([M:DIV]TRTDEM = "CALDPS" and ([M:DEP]NB_DEP = 0 or [M:DIV]DPC > [M:DEP]NB_DEP) ) Then : [M:DIV]ERROR = 18 : End : Endif

  # Si le plan pour la période courante  n'est pas ŕ calculer on ne va pas plus loin
  [M:DIV]PLNSTA(find([M:DEP]DPRPLN([M:DIV]DPC-1),[M:DIV]PLNCAA)-1) = [M:DEP]DEPSTA([M:DIV]DPC-1)
  # FQ72065
  #If ( ([M:DEP]DEPSTA([M:DIV]DPC-1) = GVML_SCCAL and [F:WFAS]FLGCNXCLC([M:DEP]CNX([M:DIV]DPC-1)-1) <> GVML_RCCLO)  and
  #&     [M:DIV]TRTDEM <> "CALBCO" and [M:DIV]TRTDEM <> "CALSIM" and [M:DIV]TRTDEM <> "CALVNC" ) Then
  #  End
  #Endif
  If ( [F:WFAS]FLGCNXCLC([M:DEP]CNX([M:DIV]DPC-1)-1) = GVML_RCNON and [M:DIV]TRTDEM = "CALSOC" ) Then
    End
  Endif

  # UO -  Plan de production (UO pour le plan en fonction de la détention)
  [M:DIV]BCALPPL = 1
  # Poids de détention cumulées pour les périodes d'un exercice du plan
  [M:DIV]BCALPDS = 1

  # Affichage informations  avant calcul
  PKTPOINTTRT=G_GLOB1 : PBKPOINTNAM="BEFCALCURPLN" :  PDBGMSK = "CURPLN" : PDBGPLAN=[M:DEP]DPRPLN(0)
  Gosub DEBUG_VISU_MSK From GCALDEBUG

  # --
  # Buffer pour calcul & clôture
  #If clalev([F:DEPC])  =0  : Local File DEPREC     [DEPC]   :  Endif        : # DEPREC FQ79813
  #If clalev([F:DEPS])  =0  : Local File DEPREC     [DEPS]   :  Endif        : # DEPREC FQ79813

  # --

  [M:DIV]NBDEPSV = [M:DEP]NB_DEP
  [M:DEP]NB_DEP  = [M:DIV]DPC

  # ---------------------------------------------
  # - CALCUL
  # ---------------------------------------------

  Local Integer IP         : IP = 0               : # Indice n° période ŕ calculer
  Local Integer ID         : ID = 0               : # Indice départ n° période ŕ calculer
  Local Integer INDEXECAL  : INDEXECAL = 1        : # Indice de l'exercice ŕ calculer

  [M:DIV]FE = [M:DIV]FEC   : # Initialisation avec indice exercice "courant"         dans [M:FIY]
  [M:DIV]FP = [M:DIV]FPC   : # Initialisation avec indice période  "courante"        dans [M:FIY]
  [M:DIV]DL = [M:DIV]DPC   : # Initialisation avec indice période/exercice "courant" dans [M:DEP]

  # Initialisation DEPC avec période/exercice "courant"
  nolign = [M:DIV]DL  : [F:DEPC] = [M:DEP]


  # Evaluation de la déduction fiscale "Déduction 40% [15avr15 - 14avr16]"
  If ( [M:DIV]LEGSOC = "FRA" and [F:DEPC]DPRPLN = G301FIS  and  [F:DEPC]ALWCOD = GVML_RPDED40 ) Then
    # Evaluation de la déduction globale de 40% (Rčgle part."Déduction 40% [15avr15 - 14avr16]") FQ107988
    Call CAL_DED40_GLOBALE_SELON_LOF ( [M:DIV2]GLODED40 )  From =G_GLOB7
  Else
    [M:DIV2]GLODED40 = 0.
  Endif

  # Russe - Bonus 30 % détecté - FQ59941
  If ( [F:DEPC]ALWCOD = GVML_RPBONUS and [F:DEPC]DPRPLN = G301FIS ) Then : [M:DIV]BBONUS = 1 : Else : [M:DIV]BBONUS = 0 : Endif

  # Pologne - Faut-il tenir compte de la modernisation FQ67577
  [M:DIV]BMDR=0
  # FQ112798
  # Evaluation du [M:DIV2]BMDR.
  # Il est ŕ 1, s'il faut tenir compte d'une modernisation depuis sa période d'application jusqu'ŕ la fin de l'exercice
  # En rčgle générale si une date de modernisation existe et qu'elle est <= ŕ la période courante il faut en tenir compte
  # Si une date est > ŕ la période courante il peut s'agir soit d'une 1ere modernisation ŕ appliquer sur la période P+1
  # S'il s'agit d'une ničme modernisation il faut tenir compte de l'avant derničre modernisation depuis sa pérode d'application.
  # Il faut donc récupérer la date de derničre modernisation "effective" [M:DIV2]LSTMDRDAT
  [M:DIV2]LSTMDRDAT = [0/0/0]
  If ([M:DIV]BACTKPL) Then
    If ([F:DEPC]KMDRDAT <> [0/0/0]) Then
      If ([F:DEPC]KMDRDAT <= [F:DEPC]PERSTRDAT) Then
        [M:DIV]BMDR=1
      Endif
      # FQ116077
      #If ([F:DEPC]KMDRDAT > [F:DEPC]PERSTRDAT and [F:DEPC]PERSTRDAT <> [F:DEPC]FIYSTRDAT ) Then
      If ([F:DEPC]KMDRDAT > [F:DEPC]PERSTRDAT and [F:DEPC]PERSTRDAT <> [F:DEPC]FIYSTRDAT and [M:DIV]DL > 1 ) Then
        # Récupération de la date de la derničre modernisation effectuée  dans l'exercice
        [M:DIV2]LSTMDRDAT = [M:DEP]KMDRDAT([M:DIV]DL-2)
        If ([M:DIV2]LSTMDRDAT <> [0/0/0])
          # Si une modernisation existe déjŕ dans l'exercice
          [M:DIV]BMDR=1
        Endif
      Endif
    Endif
  Endif

  # -- Initialisation ŕ 0 de la +/- value pour le plan
  [F:WFAS]GAL      ([F:DEPC]DPRPLN-1) = 0
  [F:WFAS]SHOGAL   ([F:DEPC]DPRPLN-1) = 0
  [F:WFAS]LNGGAL   ([F:DEPC]DPRPLN-1) = 0
  [F:WFAS]IMLRVEISS([F:DEPC]DPRPLN-1) = 0

  # -------------
  # Dépréciation  (Evaluation [M:DIV]BIML)
  # -------------
  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  If ( [M:DIV]TRTDEM = "CALVNC" and [M:DIV]FLGTIAIML = G_NON ) Then
    [F:DEPC]NBV += [F:DEPC]IML : [F:DEPC]IML = 0
  Endif
  [M:DIV]LVLLIB = "2.CALCUL_DEPRECIATION" : Gosub CAL_ADDLVL From =G_GLOB0
  Call CALCUL_DEPRECIATION  From =G_GLOB2
       #******************
  If ([M:DIV]ERROR) Then : End : Endif

  # -------------
  # Réévaluation Fin Exercice (Evaluation [M:DIV]BRFE FQ79819
  # -------------
  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  [M:DIV]LVLLIB = "2.CALCUL_REEV_FIN_EXE" : Gosub CAL_ADDLVL From =G_GLOB0
  Call CALCUL_REEV_FIN_EXE  From =G_GLOB2
       #******************
  If ([M:DIV]ERROR) Then : End : Endif


  # Synchronisation dates DEP selon FIY
  [M:DIV]LVLLIB = "2.CAL_DATES_DEP" : Gosub CAL_ADDLVL From =G_GLOB0
  Call CAL_DATES_DEP ("C", [F:DEPC]FIYSTRDAT, [F:DEPC]PERSTRDAT, "[F:DEPC]" ) From =G_GLOB2
  If ([M:DIV]ERROR) Then : End : Endif

  # Evaluation Cumul E-1 ( Reconstitution, Ecart E-1, Actualisation )
  [M:DIV]LVLLIB = "2.CALCUL_CUMUL_E_1" : Gosub CAL_ADDLVL From =G_GLOB0
  Call CALCUL_CUMUL_E_1  From =G_GLOB2
       #***************
  If ([M:DIV]ERROR) Then : End : Endif

  # Indice de la période ŕ calculer ( DEP courant - Début exercice + 1)
  ID = ( [M:DIV]FPC - [M:FIY]INDDEBPER([M:DIV]FEC-1) ) + 1
  If ( [M:DIV]BIML or [M:DIV]BRFE) Then
    # FQ79819
    ID += 1
    If ( ID > [M:FIY]NBRPER ([M:DIV]FE-1) ) Then
      # La dépréciation ou la réévaluation fin exe. a eu lieu sur la derničre période de l'exe.
      # l'exercice a donc été clos => positionnement sur la 1čre période de l'exercice suivant
      ID          =1
      INDEXECAL  +=1
      [M:DIV]FE  +=1
      [M:DIV]FP  +=1
    Endif
  Endif

  # Arręt boucle calcul ŕ faux
  Local Integer BFINI :  BFINI = 0
  # Arręt calcul ŕ faux
  [M:DIV]BSTPCLC = 0
  # Clôture période effectuée = Faux
  [M:DIV]BCLOPER = 0

  # ------------------
  # Sortie Rétroactive (Evaluation [M:DIV]BSOR [M:DIV]DSR [M:DIV]BSRA [M:DIV]BSTPCLC)
  # ------------------
  [M:DIV]LVLLIB = "2.CALCUL_SORTIE_RETROACTIVE" : Gosub CAL_ADDLVL From =G_GLOB0
  Gosub  CALCUL_SORTIE_RETROACTIVE   From =G_GLOB2
         #************************
  If ( [M:DIV]ERROR) Then : End : Endif

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # 1 >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
  # Tant que l'horizon exercice n'est pas atteint
  While !(BFINI)


    #--
    If !([M:DIV]BSRA) Then : # Dot. Exe. calculée ŕ priori si Sortie Rétro. & [F:DEPC] déjŕ actualisé
      #********************
      [M:DIV]LVLLIB = "2.CALCUL_EXERCICE" : Gosub CAL_ADDLVL From =G_GLOB0
      Call CALCUL_EXERCICE  From =G_GLOB2
      If ( [M:DIV]ERROR) Then : Break : Endif
      #********************
      # Mise ŕ jour [M:DEP]
      nolign = [M:DIV]DL : [M:DEP] = [F:DEPC]
    Endif

    # Exercice découpé en périodes /  Avant calcul de la dotation de la période
    [M:DIV]DEBCLCPER = 1
    # 2 >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
    # Périodes de l'exercice
    For  IP = ID To [M:FIY]NBRPER ([M:DIV]FE-1)
      #--
      # FQ57136
      # If ( !([M:DIV]BSRA) or IP <> ID ) Then
      If ( !([M:DIV]BSRA) or IP <> ID or INDEXECAL = 2 ) Then
        #********************
        [M:DIV]LVLLIB = "2.CALCUL_PERIODE" : Gosub CAL_ADDLVL From =G_GLOB0
        Call CALCUL_PERIODE  From =G_GLOB2
        If ( [M:DIV]ERROR) Then : Break 2 : Endif
        #********************
        # Mise ŕ jour [M:DEP]
        nolign = [M:DIV]DL : [M:DEP] = [F:DEPC]
      Endif
      #-3 ---------------------------------
      # Cloture période - Pas de clôture période sur la derničre période du dernier exercice FQ74517 FQ78670
      If ( ( INDEXECAL < [M:CNX]HRZEXE(find([M:DIV]CNT, [M:CNX]CNX)-1) )                                       or
&          ( INDEXECAL = [M:CNX]HRZEXE(find([M:DIV]CNT, [M:CNX]CNX)-1) and IP < [M:FIY]NBRPER ([M:DIV]FE-1))   or
&          ( [M:DIV]TRTDEM = "CALSIM"  ) ) Then
        # Ce n'est pas la derničre période du dernier exercice
        # Arręt prématuré de l'alimentation du masque [M:DEP]
        [M:DIV]LVLLIB = "2.CAL_ARRETER_ALIM_DEP (Période)" : Gosub CAL_ADDLVL From =G_GLOB0
        Call CAL_ARRETER_ALIM_DEP (RTRN) From =G_GLOB2
        If ( RTRN ) Then : Break 2 : Endif
        #--
        If !([M:DIV]BSTPCLC) Then
         # Contrôle si le calcul est nécessaire
        [M:DIV]LVLLIB = "2.CAL_ARRETER_CALCUL (Période)" : Gosub CAL_ADDLVL From =G_GLOB0
         Call CAL_ARRETER_CALCUL([M:DIV]BSTPCLC) From =G_GLOB2
        Endif
        #--
        ###If  ( [M:DIV]TRTDEM <> "CALSIM" or ( [M:DIV]TRTDEM = "CALSIM" and !([M:DIV]BSTPCLC)) ) Then
          # On clot la période si on n'est pas  en simulation (cas standard)
          #               OU   si on est en simulation et que l'on n'est pas en fin de calcul
          #********************
          [M:DIV]LVLLIB = "2.CLOTURE_PERIODE" : Gosub CAL_ADDLVL From =G_GLOB0
          Call CLOTURE_PERIODE  From =G_GLOB2
          If ([M:DIV]ERROR) Then : Break 2 : Endif
          #********************
        ###Endif
      Endif
      #-3 -------------------------------------

      #-- actualisation Indice Période en cours de calcul
      If ( IP < [M:FIY]NBRPER ([M:DIV]FE-1)) Then :  [M:DIV]FP += 1 : Endif

    Next IP
    # 2 <<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<

    # Cloture exercice - Pas de clôture exercice sur le dernier exercice FQ74517 FQ78670
    If ( INDEXECAL < [M:CNX]HRZEXE(find([M:DIV]CNT, [M:CNX]CNX)-1) or [M:DIV]TRTDEM = "CALSIM" ) Then
      # Ce n'est pas sur le dernier exercice ŕ calculer
      # Arręt prématuré de l'alimentation du masque [M:DEP]
      [M:DIV]LVLLIB = "2.CAL_ARRETER_ALIM_DEP (Exercice)" : Gosub CAL_ADDLVL From =G_GLOB0
      Call CAL_ARRETER_ALIM_DEP (RTRN) From =G_GLOB2
      If ( RTRN ) Then :  Break : Endif
      #--
      If !([M:DIV]BSTPCLC) Then
        # Contrôle si le calcul est nécessaire
        [M:DIV]LVLLIB = "2.CAL_ARRETER_CALCUL (Exercice)" : Gosub CAL_ADDLVL From =G_GLOB0
        Call CAL_ARRETER_CALCUL([M:DIV]BSTPCLC) From =G_GLOB2
      Endif
      #--
      ####If  ( [M:DIV]TRTDEM <> "CALSIM" or ( [M:DIV]TRTDEM = "CALSIM" and !([M:DIV]BSTPCLC)) ) Then
        # On clot toujours l'exercice sauf pour la simulation si l'on est en fin de calcul
        #********************
        [M:DIV]LVLLIB = "2.CLOTURE_EXERCICE" : Gosub CAL_ADDLVL From =G_GLOB0
        Call CLOTURE_EXERCICE From =G_GLOB2
        If ([M:DIV]ERROR) Then : Break : Endif
        #********************
      ####Endif
    Endif

    ID = 1          : # A ce niveau, la période de départ est toujours la 1čre
    [M:DIV]BIML =0  : # A ce niveau, il n'y aura plus la notion de dépréciation ŕ gérer
    [M:DIV]BRFE =0  : # A ce niveau, il n'y aura plus la notion de reev. fin exe. ŕ gérer
    INDEXECAL  +=1  : # Actualisation du nombre d'exercices calculés
    [M:DIV]FE  +=1  : # Actualisation du pointeur FIY exercice
    # Actualisation du pointeur FIY période
    If ( [M:DIV]FE <= [M:FIY]NB_EXE  ) Then
      [M:DIV]FP = [M:FIY]INDDEBPER ([M:DIV]FE-1) + [M:FIY]INDCURPER ([M:DIV]FE-1) - 1
    Endif
    # Clôture période effectuée = Faux
    [M:DIV]BCLOPER = 0

    # Evaluation fin de boucle
    [M:DIV]LVLLIB = "1.EVALUE_BFINI" : Gosub CAL_ADDLVL From =G_GLOB0
    Gosub EVALUE_BFINI From =G_GLOB1
    If ( [M:DIV]ERROR ) Then : Break : Endif

  Wend
  # < 1 <<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<

  If ( [M:DIV]ERROR ) Then : End : Endif

  # Affichage informations  aprčs calcul
  PKTPOINTTRT=G_GLOB1 : PBKPOINTNAM="AFTCALCURPLN" :  PDBGMSK = "CURPLN" : PDBGPLAN=[M:DEP]DPRPLN(0)
  Gosub DEBUG_VISU_MSK From GCALDEBUG

$FIN_CALCUL_PLAN
  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0



End


#*********************************************************************
Subprog  APRES_CALCUL_CONTEXTE (PCNT)
#
# - Objet  : Traitements complémentaires au calcul d'un contexte
#
#
#
# - Entrée : [M:DEP]
#
# - Sortie :
#
#   FQ54343
#
#CHECK MASK_DECLARE CALDEP [CAD]
Value    Integer PCNT  : # Contexte

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # ================================
  # Gestion des Concessions FQ54343
  # ================================
  #
  #- 1 ------------------
  If ( [M:DIV]BACTCCN and PCNT = G300CPFI ) Then
    #- 2 ------------------
    If ( [F:WFAS]OWNTYP = GVML_TDCONCE and [M:DIV]CCNMOD = GVML_GCRNW ) Then

      Call ECR_FICH ( "FS1", 4, "APRES_CALCUL_CONTEXTE - Détermination Prélčvement de Caducité" ) From =G_GLOB0

      #-- Affectation masque "Plan de caducité" dans [M:CAD]
      Case [M:DIV]CCNCADPLN
        When G301FIS
          If ( [M:DEP]NB_DEP  > [M:PFIS]NB_DEP ) Then : Raz [M:CAD]  : Endif : Transmask [M:PFIS] To [M:CAD]
        When G301ORI
          If ( [M:DEP]NB_DEP  > [M:PORI]NB_DEP ) Then : Raz [M:CAD]  : Endif : Transmask [M:PORI] To [M:CAD]
        When G301R76
          If ( [M:DEP]NB_DEP  > [M:PR76]NB_DEP ) Then : Raz [M:CAD]  : Endif : Transmask [M:PR76] To [M:CAD]
        When G301IAS
          If ( [M:DEP]NB_DEP  > [M:PIAS]NB_DEP ) Then : Raz [M:CAD]  : Endif : Transmask [M:PIAS] To [M:CAD]
        When G301TEC
          If ( [M:DEP]NB_DEP  > [M:PTEC]NB_DEP ) Then : Raz [M:CAD]  : Endif : Transmask [M:PTEC] To [M:CAD]
        When G301RET
          If ( [M:DEP]NB_DEP  > [M:PRET]NB_DEP ) Then : Raz [M:CAD]  : Endif : Transmask [M:PRET] To [M:CAD]
        When G301SUB
          If ( [M:DEP]NB_DEP  > [M:PSUB]NB_DEP ) Then : Raz [M:CAD]  : Endif : Transmask [M:PSUB] To [M:CAD]
        When G301LI1
          If ( [M:DEP]NB_DEP  > [M:PLI1]NB_DEP ) Then : Raz [M:CAD]  : Endif : Transmask [M:PLI1] To [M:CAD]
        When G301LI2
          If ( [M:DEP]NB_DEP  > [M:PLI2]NB_DEP ) Then : Raz [M:CAD]  : Endif : Transmask [M:PLI2] To [M:CAD]
        When G301LI3
          If ( [M:DEP]NB_DEP  > [M:PLI3]NB_DEP ) Then : Raz [M:CAD]  : Endif : Transmask [M:PLI3] To [M:CAD]
        When G301LI4
          If ( [M:DEP]NB_DEP  > [M:PLI4]NB_DEP ) Then : Raz [M:CAD]  : Endif : Transmask [M:PLI4] To [M:CAD]
        When G301LI5
          If ( [M:DEP]NB_DEP  > [M:PLI5]NB_DEP ) Then : Raz [M:CAD]  : Endif : Transmask [M:PLI5] To [M:CAD]
        When G301LI6
          If ( [M:DEP]NB_DEP  > [M:PLI6]NB_DEP ) Then : Raz [M:CAD]  : Endif : Transmask [M:PLI6] To [M:CAD]
        When G301MIN
          If ( [M:DEP]NB_DEP  > [M:PMIN]NB_DEP ) Then : Raz [M:CAD]  : Endif : Transmask [M:PMIN] To [M:CAD]
        When G301CPT
          If ( [M:DEP]NB_DEP  > [M:PCPT]NB_DEP ) Then : Raz [M:CAD]  : Endif : Transmask [M:PCPT] To [M:CAD]
      Endcase
      #-- Affectation masque "Plan d'amortissmeent industriel" dans [M:AMI]
      Case [M:DIV]CCNINDPLN
        When G301FIS
          If ( [M:DEP]NB_DEP  > [M:PFIS]NB_DEP ) Then : Raz [M:AMI]  : Endif : Transmask [M:PFIS] To [M:AMI]
        When G301ORI
          If ( [M:DEP]NB_DEP  > [M:PORI]NB_DEP ) Then : Raz [M:AMI]  : Endif : Transmask [M:PORI] To [M:AMI]
        When G301R76
          If ( [M:DEP]NB_DEP  > [M:PR76]NB_DEP ) Then : Raz [M:AMI]  : Endif : Transmask [M:PR76] To [M:AMI]
        When G301IAS
          If ( [M:DEP]NB_DEP  > [M:PIAS]NB_DEP ) Then : Raz [M:AMI]  : Endif : Transmask [M:PIAS] To [M:AMI]
        When G301TEC
          If ( [M:DEP]NB_DEP  > [M:PTEC]NB_DEP ) Then : Raz [M:AMI]  : Endif : Transmask [M:PTEC] To [M:AMI]
        When G301RET
          If ( [M:DEP]NB_DEP  > [M:PRET]NB_DEP ) Then : Raz [M:AMI]  : Endif : Transmask [M:PRET] To [M:AMI]
        When G301SUB
          If ( [M:DEP]NB_DEP  > [M:PSUB]NB_DEP ) Then : Raz [M:AMI]  : Endif : Transmask [M:PSUB] To [M:AMI]
        When G301LI1
          If ( [M:DEP]NB_DEP  > [M:PLI1]NB_DEP ) Then : Raz [M:AMI]  : Endif : Transmask [M:PLI1] To [M:AMI]
        When G301LI2
          If ( [M:DEP]NB_DEP  > [M:PLI2]NB_DEP ) Then : Raz [M:AMI]  : Endif : Transmask [M:PLI2] To [M:AMI]
        When G301LI3
          If ( [M:DEP]NB_DEP  > [M:PLI3]NB_DEP ) Then : Raz [M:AMI]  : Endif : Transmask [M:PLI3] To [M:AMI]
        When G301LI4
          If ( [M:DEP]NB_DEP  > [M:PLI4]NB_DEP ) Then : Raz [M:AMI]  : Endif : Transmask [M:PLI4] To [M:AMI]
        When G301LI5
          If ( [M:DEP]NB_DEP  > [M:PLI5]NB_DEP ) Then : Raz [M:AMI]  : Endif : Transmask [M:PLI5] To [M:AMI]
        When G301LI6
          If ( [M:DEP]NB_DEP  > [M:PLI6]NB_DEP ) Then : Raz [M:AMI]  : Endif : Transmask [M:PLI6] To [M:AMI]
        When G301MIN
          If ( [M:DEP]NB_DEP  > [M:PMIN]NB_DEP ) Then : Raz [M:AMI]  : Endif : Transmask [M:PMIN] To [M:AMI]
        When G301CPT
          If ( [M:DEP]NB_DEP  > [M:PCPT]NB_DEP ) Then : Raz [M:AMI]  : Endif : Transmask [M:PCPT] To [M:AMI]
      Endcase
      #-- Affectation masque "Plan de subvention" dans [M:SUB]
      If ( [M:DIV]CCNGRTPLN <> 0 ) Then
        Case [M:DIV]CCNGRTPLN
          When G301FIS
            If ( [M:DEP]NB_DEP  > [M:PFIS]NB_DEP ) Then : Raz [M:SUB]  : Endif : Transmask [M:PFIS] To [M:SUB]
          When G301ORI
            If ( [M:DEP]NB_DEP  > [M:PORI]NB_DEP ) Then : Raz [M:SUB]  : Endif : Transmask [M:PORI] To [M:SUB]
          When G301R76
            If ( [M:DEP]NB_DEP  > [M:PR76]NB_DEP ) Then : Raz [M:SUB]  : Endif : Transmask [M:PR76] To [M:SUB]
          When G301IAS
            If ( [M:DEP]NB_DEP  > [M:PIAS]NB_DEP ) Then : Raz [M:SUB]  : Endif : Transmask [M:PIAS] To [M:SUB]
          When G301TEC
            If ( [M:DEP]NB_DEP  > [M:PTEC]NB_DEP ) Then : Raz [M:SUB]  : Endif : Transmask [M:PTEC] To [M:SUB]
          When G301RET
            If ( [M:DEP]NB_DEP  > [M:PRET]NB_DEP ) Then : Raz [M:SUB]  : Endif : Transmask [M:PRET] To [M:SUB]
          When G301SUB
            If ( [M:DEP]NB_DEP  > [M:PSUB]NB_DEP ) Then : Raz [M:SUB]  : Endif : Transmask [M:PSUB] To [M:SUB]
          When G301LI1
            If ( [M:DEP]NB_DEP  > [M:PLI1]NB_DEP ) Then : Raz [M:SUB]  : Endif : Transmask [M:PLI1] To [M:SUB]
          When G301LI2
            If ( [M:DEP]NB_DEP  > [M:PLI2]NB_DEP ) Then : Raz [M:SUB]  : Endif : Transmask [M:PLI2] To [M:SUB]
          When G301LI3
            If ( [M:DEP]NB_DEP  > [M:PLI3]NB_DEP ) Then : Raz [M:SUB]  : Endif : Transmask [M:PLI3] To [M:SUB]
          When G301LI4
            If ( [M:DEP]NB_DEP  > [M:PLI4]NB_DEP ) Then : Raz [M:SUB]  : Endif : Transmask [M:PLI4] To [M:SUB]
          When G301LI5
            If ( [M:DEP]NB_DEP  > [M:PLI5]NB_DEP ) Then : Raz [M:SUB]  : Endif : Transmask [M:PLI5] To [M:SUB]
          When G301LI6
            If ( [M:DEP]NB_DEP  > [M:PLI6]NB_DEP ) Then : Raz [M:SUB]  : Endif : Transmask [M:PLI6] To [M:SUB]
          When G301MIN
            If ( [M:DEP]NB_DEP  > [M:PMIN]NB_DEP ) Then : Raz [M:SUB]  : Endif : Transmask [M:PMIN] To [M:SUB]
          When G301CPT
            If ( [M:DEP]NB_DEP  > [M:PCPT]NB_DEP ) Then : Raz [M:SUB]  : Endif : Transmask [M:PCPT] To [M:SUB]
        Endcase
      Endif

      # --
      # Indice de la période/exercice "courant" dans [M:CAD]
      [M:DIV]DPC = find( [M:FIY]DATSTRPER ([M:DIV]FPC-1), [M:CAD]PERSTRDAT )

      # Détermination du flag OER
      # ----------------------------------------
      Local Integer LOERFLG
      #  si fin d'amortissement industriel [M:AMI]ENDDPRDAT([M:DIV]DPC-1),LOERFLG)  From =G_GLOB7
      Call CAL_DETERM_FLAG_OER ("CALCUL",
&          [F:WFAS]OWNTYP, [M:DIV]CCNMOD, [F:WFAS]OBYRNWCON, [F:WFAS]TPAFLG, [M:DIV]DTFNCON, [F:WFAS]RNWDAT, LOERFLG)  From =G_GLOB7
      [F:WFAS]RNWFLG = LOERFLG


      # Détermination du prélčvement de caducité
      # ----------------------------------------
      If ( [F:WFAS]CCNETRNAT = GVML_NECONCS and [F:WFAS]RNWFLG = G_NON and [F:WFAS]TPAFLG = G_NON ) Then
        # Prélčvement de caducité uniquement si apport = Concessionnaire et indicateur OER = Non et Remis contre indemnités = Non
        # >>>>>>>>>>>>>
        For ID = [M:DIV]DPC To [M:CAD]NB_DEP
          # Prélévement de caducité est égal ŕ la différence entre Amortissement Industriel et Amortissement Subvention
          If ( [M:DIV]CCNGRTPLN <> 0 ) Then
            [M:CAD]PERCADCRB(ID-1) = [M:AMI]PERENDDPE(ID-1) - [M:SUB]PERENDDPE(ID-1)
          Else
            [M:CAD]PERCADCRB(ID-1) = [M:AMI]PERENDDPE(ID-1)
          Endif
          # A comptabiliser
          [M:CAD]CADCRBDEV(ID-1) = [M:CAD]PERCADCRB(ID-1) - [M:CAD]PSTCADCRB(ID-1)
        Next ID
        # <<<<<<<<<<<<<
      Else
        # Pas de prélčvement de caducité dans ce cas
        # >>>>>>>>>>>>>
        For ID = [M:DIV]DPC To [M:CAD]NB_DEP
          [M:CAD]PERCADCRB(ID-1) = 0
          # A comptabiliser
          [M:CAD]CADCRBDEV(ID-1) = [M:CAD]PERCADCRB(ID-1) - [M:CAD]PSTCADCRB(ID-1)
        Next ID
        # <<<<<<<<<<<<<
      Endif

      # >>>>>>>
      For ID = [M:DIV]DPC To [M:CAD]NB_DEP

       #If ( GUSER = "MWA" and [M:DIV]BDEBUG and [M:CAD]PERENDDAT(ID-1) = [31/12/2013] ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

       # Détermination du fonds de caducité
        [M:CAD]TRFCADCUM(ID-1) = [M:DIV]TRFCADCUM
        [M:DIV]TRFCADCUM = [M:DIV]TRFCADCUM  - [M:CAD]PERCADCRB(ID-1) + [M:CAD]PERENDDPE(ID-1)

        # Entretien du cumul P-1 prélčvement de caducité
        If ( [M:CAD]FIYSTRDAT(ID-1) = [M:CAD]PERSTRDAT(ID-1) ) Then
          # Début exercice
          [M:CAD]P_1CADCRB(ID-1) = 0
        Else
          If ( ID > 1 ) Then
            # Entretien du cumul si on est pas début d'exercice et que l'on est pas sur la 1čre ligne
            [M:CAD]P_1CADCRB(ID-1) = [M:CAD]P_1CADCRB(ID-2)  + [M:CAD]PERCADCRB(ID-2)
          Endif
        Endif
      Next ID
      # <<<<<<<<<<<<<

      #-- Affectation [M:CAD] dans masque "Plan Caducité"
      # ----------------------------------------
      Case [M:DIV]CCNCADPLN
        When G301FIS
          If ( [M:PFIS]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PFIS] : Endif : Transmask [M:CAD] To [M:PFIS]
        When G301ORI
          If ( [M:PORI]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PORI] : Endif : Transmask [M:CAD] To [M:PORI]
        When G301R76
          If ( [M:PR76]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PR76] : Endif : Transmask [M:CAD] To [M:PR76]
        When G301IAS
          If ( [M:PIAS]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PIAS] : Endif : Transmask [M:CAD] To [M:PIAS]
        When G301TEC
          If ( [M:PTEC]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PTEC] : Endif : Transmask [M:CAD] To [M:PTEC]
        When G301RET
          If ( [M:PRET]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PRET] : Endif : Transmask [M:CAD] To [M:PRET]
        When G301SUB
          If ( [M:PSUB]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PSUB] : Endif : Transmask [M:CAD] To [M:PSUB]
        When G301LI1
          If ( [M:PLI1]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI1] : Endif : Transmask [M:CAD] To [M:PLI1]
        When G301LI2
          If ( [M:PLI2]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI2] : Endif : Transmask [M:CAD] To [M:PLI2]
        When G301LI3
          If ( [M:PLI3]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI3] : Endif : Transmask [M:CAD] To [M:PLI3]
        When G301LI4
          If ( [M:PLI4]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI4] : Endif : Transmask [M:CAD] To [M:PLI4]
        When G301LI5
          If ( [M:PLI5]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI5] : Endif : Transmask [M:CAD] To [M:PLI5]
        When G301LI6
          If ( [M:PLI6]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PLI6] : Endif : Transmask [M:CAD] To [M:PLI6]
        When G301MIN
          If ( [M:PMIN]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PMIN] : Endif : Transmask [M:CAD] To [M:PMIN]
        When G301CPT
          If ( [M:PCPT]NB_DEP > [M:DEP]NB_DEP )  Then : Raz [M:PCPT] : Endif : Transmask [M:CAD] To [M:PCPT]
      Endcase


      # ======================
      If ( find ([M:DIV]TRTDEM, "CALSOC", "CALBCO", "CALVNC") <> 0 ) Then
        #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
        #--
        # Cette fonction utilise les masque [M:AMI] et [M:CAD]
        If ( [F:WFAS]FLGRPRCLC= G_OUI or [F:WFAS]FLGCNXCLC(G300CPFI-1)= GVML_RCCLO or [M:DIV]TRTDEM= "CALBCO" or [M:DIV]TRTDEM= "CALVNC" ) Then

          Call ECR_FICH ( "FS1", 4, " "                                                            ) From =G_GLOB0
          Call ECR_FICH ( "FS1", 4, "CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC" ) From =G_GLOB0
          Call ECR_FICH ( "FS1", 4, "CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC" ) From =G_GLOB0
          Call ECR_FICH ( "FS1", 4, "************************************************************" ) From =G_GLOB0
          Call ECR_FICH ( "FS1", 4, "*--        CONCESSIONS - CALCUL PROVISIONS               --*" ) From =G_GLOB0
          Call ECR_FICH ( "FS1", 4, "************************************************************" ) From =G_GLOB0
          Call ECR_FICH ( "FS1", 4, "CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC" ) From =G_GLOB0
          Call ECR_FICH ( "FS1", 4, "CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC" ) From =G_GLOB0

          Call CCN_CALCUL_PROVISIONS (G300CPFI) From  =G_GLOB1

          Call ECR_FICH ( "FS1", 4, "CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC" ) From =G_GLOB0
          Call ECR_FICH ( "FS1", 4, "CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC" ) From =G_GLOB0
          Call ECR_FICH ( "FS1", 4, "                RETOUR A CALCUL STANDARD                    " ) From =G_GLOB0
          Call ECR_FICH ( "FS1", 4, "CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC" ) From =G_GLOB0
          Call ECR_FICH ( "FS1", 4, "CCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCCC" ) From =G_GLOB0
        Endif
        #--
      Endif
      # ======================

    #- 2 ------------------
    Endif
  Endif
  #- 1 ------------------
  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0
End

#
#########################################################
$CAL_LEC_PARAMETRES
#
# - Objet  : Lecture des paramčtres utilisés par le calcul
#
# - Entrée : Référence
#
#
# - Sortie :
#   Boite noire
#

  Local Char LPARAM
  Call ECR_FICH("FS1", 2, "") From =G_GLOB0
  Call ECR_FICH("FS1", 2, "CAL_LEC_PARAMETRES   - Acquisition - Paramčtres") From =G_GLOB0
  Local Char  L_PARAM(32), L_VALPARM(5), L_LIGNE(50)
  Local Char  L_SEP : L_SEP = "!"
  Call ECR_TRACE(mess(137,7774,1)+"\",0) From =G_GLOB0 # "PARAMETRES du calcul"
  Call ECR_TRACE(string$(50,"*"),0) From =G_GLOB0

  # Niveau de trace
  L_PARAM=mess(47,7774,1) : L_VALPARM=num$([M:DIV]NIVDET)
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From =G_GLOB0
  Call ECR_FICH("FS1", 9,"Niveau de trace ............................ : "+num$([M:DIV]NIVDET)) From =G_GLOB0

  # Nombre de biens par Commit  (Valeur du champ "Dimension Ecran" de la transaction "Code activité")
  [M:DIV]NBBCOTRA = func AFNC.ACTIV("BPC")
  If !([M:DIV]NBBCOTRA) Then
    [M:DIV]NBBCOTRA = 9999
  Endif
  L_PARAM=mess(147,7774,1) : L_VALPARM=num$([M:DIV]NBBCOTRA)
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From =G_GLOB0
  Call ECR_FICH("FS1", 9, "Nombre de biens par commit ................. : "+num$([M:DIV]NBBCOTRA)) From =G_GLOB0

  # Nombre de biens avant UNDO (Valeur du champ "Dimension Ecran" de la transaction "Code activité") FQ79813
  Call PARAM([M:DIV]SOC,"CALNBUNDO",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV]NBBCOUDO  = 25000
  Else
    [M:DIV]NBBCOUDO  = val(LPARAM)
  Endif
  Local Char L_VALPARM2(6)
  L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("CALNBUNDO") : L_VALPARM2=num$(val(LPARAM))
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(3)+left$(L_VALPARM2,6)+space$(8-len(left$(L_VALPARM2,6)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From =G_GLOB0
  Call ECR_FICH("FS1", 9, "Nombre de biens avant undo ................. : "+num$([M:DIV]NBBCOUDO)) From =G_GLOB0

  # Temps limite du calcul (en minutes)
  Call PARAM([M:DIV]SOC,"NBMINCLC",LPARAM) From ADOVAL
  If (LPARAM = "") Then
    [M:DIV]ERRID = 17 : Call ERRFND From =G_GLOB0 : Return
  Endif
  G_TIMLIM = val(LPARAM)
  If (G_TIMLIM > 86400 or  G_TIMLIM <= 0 ) Then : G_TIMLIM = 14400 : Endif : # (4 heures par défaut)
  L_PARAM=mess(146,7774,1) : L_VALPARM=num$(arr(G_TIMLIM/60, 0.01))
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From =G_GLOB0
  Call ECR_FICH("FS1", 9, "Temps limite en minutes  ................... : "+num$(G_TIMLIM)) From =G_GLOB0
  # Temps limite de minute en secondes
  G_TIMLIM = G_TIMLIM * 60

  # Indicateur "Prise en compte de la TVA pour le calcul de la +/- value"
  Call PARAM([M:DIV]SOC,"PCOTVAPMV",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV]ERRID = 3 : Call ERRFND From =G_GLOB0 : Return : # Dépilement suite ŕ erreur logique
  Endif
  [M:DIV]FLGTVAPMV  = val(LPARAM)
  L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("PCOTVAPMV") : L_VALPARM=mess(val(LPARAM),1,1)
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From =G_GLOB0
  Call ECR_FICH("FS1", 9, "Prise en compte de la TVA pour +/- Value ... : "+mess(val(LPARAM),1,1)) From =G_GLOB0

  # Indicateur "Reprise de dépréciation en cas de sortie"
  Call PARAM([M:DIV]SOC, "IMLRVEISS", LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV]ERRID = 4 : Call ERRFND From =G_GLOB0 : Return : # Dépilement suite ŕ erreur logique
  Endif
  [M:DIV]FLGISSIML = val(LPARAM)
  L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("IMLRVEISS") : L_VALPARM=mess(val(LPARAM),1,1)
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From =G_GLOB0
  Call ECR_FICH("FS1", 9, "Reprise de Dépréciation en cas de sortie ... : "+mess(val(LPARAM),1,1)) From =G_GLOB0

  # Dégogatoire sur Immo en cours
  Call PARAM([M:DIV]SOC,"DEROENCOUR",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV]ERRID = 21 : Call ERRFND From =G_GLOB0 : Return
  Endif
  [M:DIV]FLGDERBEC = val(LPARAM)
  L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("DEROENCOUR") : L_VALPARM=mess(val(LPARAM),1,1)
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From =G_GLOB0
  Call ECR_FICH("FS1", 9, "Dérogatoire sur les immos En cours ......... : "+mess(val(LPARAM),1,1)) From =G_GLOB0

  # Remise en cause de la situation antérieure
  Call PARAM([M:DIV]SOC,"PRVSITUPD",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV]ERRID = 17 : Call ERRFND From =G_GLOB0 : Return
  Endif
  [M:DIV]FLGPRVSIT = val(LPARAM)
  L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("PRVSITUPD") : L_VALPARM=mess(val(LPARAM),1,1)
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From =G_GLOB0
  Call ECR_FICH("FS1", 9, "Remise en cause de la situation antérieure.. : "+mess(val(LPARAM),1,1)) From =G_GLOB0

  # Changement méthode d'arrondi (LP/DF)  FQ62812
  Call PARAM([M:DIV]SOC,"RNDCHGLPDF",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV]FLGRNDCHG = G_NON
     LPARAM = "1"
  Else
    [M:DIV]FLGRNDCHG = val(LPARAM)
  Endif
  L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("RNDCHGLPDF") : L_VALPARM=mess(val(LPARAM),1,1)
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From =G_GLOB0
  Call ECR_FICH("FS1", 9, "Changement méthode d'arrondi pour LP & DF .. : "+mess(val(LPARAM),1,1)) From =G_GLOB0

  # Plan prioritaire  FQ103931
  Call PARAM([M:DIV]SOC,"DPRPLNPIO",LPARAM) From ADOVAL
  If (LPARAM = "" or val(LPARAM) = 0) Then
    # Par défaut - Comptable
    [M:DIV2]DPRPLNPIO = G301CPT
    LPARAM = "1"
  Else
    # Le plan prioritaire doit appartenir au contexte fiscal et comptable
    If !clalev([F:CNXW]) : Local File CONTEXT [CNXW] : Endif
    Read [CNXW]CNX0=[M:DIV]SOC;G300CPFI
    If ( find([M:DIV2]DPRPLNPIO, [F:CNXW]PLNCAA) <> 0 ) Then
      [M:DIV2]DPRPLNPIO = val(LPARAM)
    Else
      [M:DIV]ERRID = 49 : Call ERRFND From =G_GLOB0 : Return
    Endif
    Close Local File [CNXW]
  Endif
  If ( [M:DIV2]DPRPLNPIO <> G301AUC ) Then
  L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("DPRPLNPIO") : L_VALPARM=mess(val(LPARAM),3101,1)
  L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&           L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
  Call ECR_TRACE(L_LIGNE,0) From =G_GLOB0
  Endif

  Call ECR_FICH("FS1", 9, "Plan prioritaire...                          : "+mess(val(LPARAM),3101,1)) From =G_GLOB0



  # FQ67577
  If ([M:DIV]BACTKPL) Then
    # Valeur de l'amortissement minimum porté par une période
    Call PARAM([M:DIV]SOC,"MINPERDEP",LPARAM) From ADOVAL
    If (LPARAM = "" or val(LPARAM) = 0) Then
      [M:DIV]DOTPERMIN = 0.50
       LPARAM = "0.50"
    Else
      [M:DIV]DOTPERMIN = val(LPARAM)
    Endif
    L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("MINPERDEP") : L_VALPARM=num$([M:DIV]DOTPERMIN)
    L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&             L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
    Call ECR_TRACE(L_LIGNE,0) From =G_GLOB0
    Call ECR_FICH("FS1", 9, "Amortissement minimum pour une période ..... : "+num$([M:DIV]DOTPERMIN)) From =G_GLOB0

    # Modernisation prend effet sur période courante (plan comptable)
    Call PARAM([M:DIV]SOC,"MDRCURPER",LPARAM) From ADOVAL
    If (LPARAM = "" ) Then
      [M:DIV]MDRCURPER = G_NON
       LPARAM = "1"
    Else
      [M:DIV]MDRCURPER = val(LPARAM)
    Endif
    L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("MDRCURPER") : L_VALPARM=mess(val(LPARAM),1,1)
    L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&             L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
    Call ECR_TRACE(L_LIGNE,0) From =G_GLOB0
    Call ECR_FICH("FS1", 9, "Modernisation comptable sur période courante : "+mess(val(LPARAM),1,1)) From =G_GLOB0
  Endif

  # FQ84283 Dotation exercice minimum
  Call PARAM([M:DIV]SOC,"MINFIYDEP",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV]DOTEXEMIN = 0.00
  Else
    [M:DIV]DOTEXEMIN = val(LPARAM)
    L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("MINFIYDEP") : L_VALPARM=num$([M:DIV]DOTEXEMIN)
    L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&             L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
    Call ECR_TRACE(L_LIGNE,0) From =G_GLOB0
    Call ECR_FICH("FS1", 9, "Amortissement minimum pour un exercice ..... : "+num$([M:DIV]DOTEXEMIN)) From =G_GLOB0
  Endif

  # FQ84281 Valeur nette minimum
  Call PARAM([M:DIV]SOC,"NETVALWRO",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV]ENDNVLWRO = 0.00
  Else
    [M:DIV]ENDNVLWRO = val(LPARAM)
    L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("NETVALWRO") : L_VALPARM=num$([M:DIV]ENDNVLWRO)
    L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&             L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
    Call ECR_TRACE(L_LIGNE,0) From =G_GLOB0
    Call ECR_FICH("FS1", 9, "Valeur nette fin minimum pour un exercice .. : "+num$([M:DIV]ENDNVLWRO)) From =G_GLOB0
  Endif

  # FQ100336 répartition long terme court terme de la +/- value selon régime d'imposition
  Call PARAM([M:DIV]SOC,"CPYTAXRUL",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV2]TAXRUL = 1
  Else
    [M:DIV2]TAXRUL = val(LPARAM)
    L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("CPYTAXRUL") : L_VALPARM=num$([M:DIV2]TAXRUL)
    L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&             L_SEP+space$(4)+left$(L_VALPARM,5)+space$(7-len(left$(L_VALPARM,5)))+L_SEP
    Call ECR_TRACE(L_LIGNE,0) From =G_GLOB0
    Call ECR_FICH("FS1", 9, "Régime de taxation .. : "+mess(val(LPARAM),3188,1)) From =G_GLOB0
  Endif

  # FQ90048(2) Premier jour de la semaine
  Call PARAM([M:DIV]SOC,"WEESTR",LPARAM) From ADOVAL
  If (LPARAM = "" ) Then
    [M:DIV2]WEESTRDAY = 1
  Else
    [M:DIV2]WEESTRDAY = val(LPARAM)
    If ([M:DIV2]WEESTRDAY <> 1) Then
      Local Char L_VALPARM3(8)
      L_PARAM=func GLOBIENS.GET_LIBELLE_PARAM("WEESTR") : L_VALPARM3=mess(val(LPARAM),9833,1)
      L_LIGNE = L_SEP+space$(1)+left$(L_PARAM,32)+space$(35-len(left$(L_PARAM,32)))+
&               L_SEP+space$(1)+left$(L_VALPARM3,8)+space$(10-len(left$(L_VALPARM3,8)))+L_SEP
      Call ECR_TRACE(L_LIGNE,0) From =G_GLOB0
      Call ECR_FICH("FS1", 9, "Premier jour de la semaine   ............... : "+mess(val(LPARAM),9833,1)) From =G_GLOB0
    Endif
  Endif

  Call ECR_TRACE(string$(50,"*")+"\",0) From =G_GLOB0

  # Nombre de lignes maximum du masque CALDEP
  [M:DIV]DEPMAX = func AFNC.ACTIV("DEP")
  [M:DIV]PPLMAX = func AFNC.ACTIV("NPPL")
  Call ECR_FICH("FS1", 9, "Nombre maximum de lignes dans CALDEP ....... : "+num$([M:DIV]DEPMAX)) From =G_GLOB0
  Call ECR_FICH("FS1", 9, "Nombre maximum de lignes dans CALFIY ....... : "+num$(func AFNC.ACTIV("NFIY"))) From =G_GLOB0
  Call ECR_FICH("FS1", 9, "Nombre maximum de lignes dans CALPLN ....... : "+num$([M:DIV]PPLMAX)) From =G_GLOB0

  # Calendrier persan FQ77529
  Call PARAM([M:DIV]SOC,"CALPERSAN",LPARAM) From ADOVAL
  [M:DIV]CALPERSAN = val(LPARAM)

  # Réévaluation 96 FQ82075
  Call PARAM("","REEV96",LPARAM) From ADOVAL
  [M:DIV2]FLGR96 = val(LPARAM)

  # Gestion des erreurs
  Gosub CAL_RMVLVL From =G_GLOB0

Return
#
#
#*****************************************************************************************************
#*****************************************************************************************************
#*****************************************************************************************************
#    C O N C E S S I O N S      -     P R O V I S I O N S     R E N O U V E L L E M E N T
#*****************************************************************************************************
#*****************************************************************************************************
#*****************************************************************************************************
#
# FQ54343

#########################################################
Subprog CCN_CALCUL_PROVISIONS (PCNT)
#
# - Objet  : Calculer les provisions pour renouvellement du bien.
#
#           Charger le masque DEP ŕ partir du masque dédié au plan industriel
#           Charger le masque RPR ŕ partir du masque dédié de l'image avant calcul provisions
#           Calculer les provisions (CALCUL_PPROVISIONS)
#           Décharger le masque RPR ( avec positionnement de code action)

Value    Integer PCNT

Local Integer DEB, N_P, J_PLN

  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #--
  If ( [M:FIY]NB_EXE > [M:EGCF]NB_EXE ) Then : Raz [M:FIY] : Endif : Transmask [M:EGCF] To [M:FIY]

  #-- Affectation masque  [M:DIV] relatif au contexte
  # Contexte ŕ calculer
  [M:DIV]CNT = PCNT
  # Indice exercice courant
  [M:DIV]FEC = find( GVML_TECOURA, [M:FIY]STAFIY )
  # Indice de la période courante de l'exercice courant
  [M:DIV]FPC = [M:FIY]INDDEBPER ([M:DIV]FEC-1) + [M:FIY]INDCURPER ([M:DIV]FEC-1) - 1
  # Devise du contexte ŕ calculer
  [M:DIV]CUR = [M:CNX]CUR (find ([M:DIV]CNT,  [M:CNX]CNX) - 1)
  # Format d'édition de la devise du contexte ŕ calculer
  [M:DIV]CURFMT = "N3:"+GDEVFMT1 (find([M:DIV]CUR, GDEVISE))

  # Initialisation valeur de remplacement forcée
  If ( [F:WFAS]RNWVALFLG = G_OUI ) Then
    [M:DIV]RNWVALFRC = [F:WFAS]RNWVAL
  Else
    [M:DIV]RNWVALFRC = 0
  Endif


 #========================================================

  If ( [M:DEP]NB_DEP  > [M:AMI]NB_DEP )   Then : Raz [M:DEP]  : Endif :  Transmask [M:AMI]  To [M:DEP]
  If ( [M:RPR]NB_RPR  > [M:PRPR]NB_RPR )  Then : Raz [M:RPR]  : Endif :  Transmask [M:PRPR] To [M:RPR]
  If ( [M:WRPR]NB_RPR > [M:PRPR]NB_RPR )  Then : Raz [M:WRPR] : Endif :  Transmask [M:PRPR] To [M:WRPR]

  #    ***********
  If (G_CCNCLCSTD) Then
    # Les provisions sont calculées ŕ partir du traitement standard
    Call CALCUL_PROVISIONS  From =G_GLOB1
    # ERRFND effectué hors boucle
    If ([M:DIV]ERROR) Then : End : Endif : # FQ114113
  Endif
  #    ***********


  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
  # E   Point d'entrée    AFTCCN                  E
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE
#CHECK IGNORE_BEGIN
  If ( G_ETP_GLOBI1 ) Then : # FQ114113
    GPOINT = "AFTCCN"
    Gosub ENTREE From EXEFNC
    If !(GOK) Then
      [M:DIV]ERRID = 9003 : Call ERRFND From =G_GLOB0 : End : # Dépilement suite ŕ erreur logique
    Endif
  Endif
#CHECK IGNORE_END
  # EEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEEE

  #-- Affectation [M:RPR] dans masque "Provisions"
  Call CCN_EVALUE_ACTION_RPR([M:DIV]TDFNCCN,[M:DIV]NBFCCN) From =G_GLOB0
  If ([M:DIV]ERROR) Then : Call ERRFND From =G_GLOB0 : End  :  Endif
  # [M:PRPR] Classe utilisée par EXPLOITER_
  If ( [M:PRPR]NB_RPR > [M:RPR]NB_RPR )  Then : Raz [M:PRPR] : Endif : Transmask [M:RPR] To [M:PRPR]

 #========================================================


End

#===============================================
$EVALUE_CCN_BFINI

  # Contôle de la limite du masque DEP
  If ([M:DIV]DL = [M:DIV]DEPMAX ) Then
    # La limite du masque DEP a été atteinte
    [M:DIV]ERRID = 27 : Call ERRFND From =G_GLOB0 : Return : # Dépilement suite ŕ erreur logique
  Else
    # Sortie de boucle selon conditions dépendant du traitement demandé
    Case [M:DIV]TRTDEM
      When "CALSOC", "CALBCO", "CALVNC", "CALDPS"
        # -- Calcul société / Calcul d'un bien FQ79856
        # Arręt lorsque l'horizon exercice ŕ calculer est atteint FQ74517 FQ78670
        If ( INDEXECAL > [M:CNX]HRZEXE(find([M:DIV]CNT, [M:CNX]CNX)-1) ) Then : BFINI = 1 : Endif
      When Default
        BFINI = 1
    Endcase
    If (BFINI = 1) Then
      # Actualisation du nombre de lignes dans le masque DEP
      [M:RPR]NB_RPR = [M:DIV]DL
    Endif
  Endif

Return

#*********************************************************************
Subprog  CALCUL_PROVISIONS
#
# - Objet  : Calcul des prosions d'un bien
#
#
#
# - Entrée : [M:RPR]
#
# - Sortie :
#


Local Integer RTRN

#
#   Boite noire
#
  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif
  #If ( [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # --
  # Indice de la période/exercice "courant" dans [M:DEP]
  [M:DIV]DPC = find( [M:FIY]DATSTRPER ([M:DIV]FPC-1), [M:DEP]PERSTRDAT )

  # Si le bien a été sorti dans un exercice antérieur ŕ l'exercice courant on ne calcule plus les provisions
  If ( [F:WFAS]ISSDAT <> [0/0/0] and [F:WFAS]ISSDAT < [M:FIY]DATSTRFIY([M:DIV]FEC-1) and
&      (not ([M:DIV]BACTCCN) or ([M:DIV]BACTCCN and [F:WFAS]CCNETRTYP <> GVML_NA1ERBC )) ) Then
    Call ECR_FICH ( "FS1", 3, "CALCUL_PROVISION - "-"Aucun calcul provision bien sorti dans un exercice antérieur"  ) From =G_GLOB0
    #***
    End
  Endif

  # Poids de détention cumulées pour les périodes d'un exercice du plan
  [M:DIV]BCALPDS = 1

  # --
  # Buffer pour calcul & clôture
  #If clalev([F:RPRC])  =0  : Local File CCNRPR     [RPRC]   :  Endif        : # CCNRPR FQ79813
  #If clalev([F:RPRS])  =0  : Local File CCNRPR     [RPRS]   :  Endif        : # CCNRPR FQ79813
  # Buffer pour gestion amortissement industriel via [M:DEP]
  #If clalev([F:DEPC])  =0  : Local File DEPREC     [DEPC]   :  Endif        : # DEPREC FQ79813
  # --

  [M:DIV]NBRPRSV = [M:RPR]NB_RPR
  [M:RPR]NB_RPR  = [M:DIV]DPC

  # ---------------------------------------------
  # - CALCUL PROVISIONS
  # ---------------------------------------------

  Local Integer IP         : IP = 0               : # Indice n° période ŕ calculer
  Local Integer ID         : ID = 0               : # Indice départ n° période ŕ calculer
  Local Integer INDEXECAL  : INDEXECAL = 1        : # Indice de l'exercice ŕ calculer

  [M:DIV]FE = [M:DIV]FEC   : # Initialisation avec indice exercice "courant"         dans [M:FIY]
  [M:DIV]FP = [M:DIV]FPC   : # Initialisation avec indice période  "courante"        dans [M:FIY]
  [M:DIV]DL = [M:DIV]DPC   : # Initialisation avec indice période/exercice "courant" dans [M:DEP]

  # Initialisation RPRC avec période/exercice "courant"
  nolign = [M:DIV]DL  : [F:RPRC] = [M:RPR]

  # Initialisation DEPC avec période/exercice "courant"
  nolign = [M:DIV]DL  : [F:DEPC] = [M:DEP]

  #If ( [M:DIV]BDEBUG  ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  # Synchronisation dates DEP selon FIY
  Call CAL_DATES_DEP ("C", [F:DEPC]FIYSTRDAT, [F:DEPC]PERSTRDAT, "[F:DEPC]" ) From =G_GLOB2
  If ([M:DIV]ERROR) Then : End : Endif

  # Indice de la période ŕ calculer ( DEP courant - Début exercice + 1)
  ID = ( [M:DIV]FPC - [M:FIY]INDDEBPER([M:DIV]FEC-1) ) + 1

  # Arręt boucle calcul ŕ faux
  Local Integer BFINI :  BFINI = 0
  # Arręt calcul ŕ faux
  [M:DIV]BSTPCLC = 0
  # Clôture période effectuée = Faux
  [M:DIV]BCLOPER = 0


  # ------------------
  # Sortie Rétroactive (Evaluation [M:DIV]BSOR [M:DIV]DSR [M:DIV]BSRA [M:DIV]BSTPCLC)
  # ------------------

  # If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  [M:DIV]LVLLIB = "2.CCN_SORTIE_RETROACTIVE" : Gosub CAL_ADDLVL From =G_GLOB0
  #************************
  Gosub  CCN_SORTIE_RETROACTIVE   From =G_GLOB2
  If ( [M:DIV]ERROR) Then : End : Endif
  #************************

  # If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif


  # 1 >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
  # Tant que l'horizon exercice n'est pas atteint
  While !(BFINI)

    #--
    If !([M:DIV]BSRA) Then : # Dot. Exe. calculée ŕ priori si Sortie Rétro. & [F:DEPC] déjŕ actualisé
      #********************
      Call CALCUL_PROVISION_EXERCICE  From =G_GLOB2
      If ( [M:DIV]ERROR) Then : Break : Endif
      #********************
      # Mise ŕ jour [M:DEP]
      nolign = [M:DIV]DL : [M:RPR] = [F:RPRC]
    Endif

    # Exercice découpé en périodes /  Avant calcul de la dotation de la période
    [M:DIV]DEBCLCPER = 1
    # 2 >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>
    # Périodes de l'exercice
    For  IP = ID To [M:FIY]NBRPER ([M:DIV]FE-1)
      #--
      # FQ57136
      # If ( !([M:DIV]BSRA) or IP <> ID ) Then
      If ( !([M:DIV]BSRA) or IP <> ID or INDEXECAL = 2 ) Then
        #********************
        Call CALCUL_PROVISION_PERIODE  From =G_GLOB2
        If ( [M:DIV]ERROR) Then : Break 2 : Endif
        #********************
        # Mise ŕ jour [M:RPR]
        nolign = [M:DIV]DL : [M:RPR] = [F:RPRC]
      Endif
      #-3 ---------------------------------
      # Cloture période - Pas de clôture période sur la derničre période du dernier exercice FQ74517 FQ78670
      If ( ( INDEXECAL < [M:CNX]HRZEXE(find([M:DIV]CNT, [M:CNX]CNX)-1) )   or
&          ( INDEXECAL = [M:CNX]HRZEXE(find([M:DIV]CNT, [M:CNX]CNX)-1) and IP < [M:FIY]NBRPER ([M:DIV]FE-1))    ) Then
        # Ce n'est pas la derničre période du dernier exercice
        # Arręt prématuré de l'alimentation du masque [M:DEP]
        Call CCN_ARRETER_ALIM_RPR (RTRN) From =G_GLOB2
        If ( RTRN ) Then : Break 2 : Endif
        #--
        If !([M:DIV]BSTPCLC) Then
         # Contrôle si le calcul est nécessaire
         Call CCN_ARRETER_CALCUL([M:DIV]BSTPCLC) From =G_GLOB2
        Endif
        #--
        # On clot la période si on n'est pas  en simulation (cas standard)
        #               OU   si on est en simulation et que l'on n'est pas en fin de calcul
        #********************
        Call CCN_CLOTURE_PERIODE  From =G_GLOB2
        If ([M:DIV]ERROR) Then : Break 2 : Endif
        #********************
      Endif
      #-3 -------------------------------------

      #-- actualisation Indice Période en cours de calcul
      If ( IP < [M:FIY]NBRPER ([M:DIV]FE-1)) Then :  [M:DIV]FP += 1 : Endif

    Next IP
    # 2 <<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<

    # Cloture exercice - Pas de clôture exercice sur le dernier exercice FQ74517 FQ78670
    If ( INDEXECAL < [M:CNX]HRZEXE(find([M:DIV]CNT, [M:CNX]CNX)-1) ) Then
      # Ce n'est pas sur le dernier exercice ŕ calculer
      # Arręt prématuré de l'alimentation du masque [M:RPR]
      Call CCN_ARRETER_ALIM_RPR (RTRN) From =G_GLOB2
      If ( RTRN ) Then :  Break : Endif
      #--
      If !([M:DIV]BSTPCLC) Then
        # Contrôle si le calcul est nécessaire
        Call CCN_ARRETER_CALCUL([M:DIV]BSTPCLC) From =G_GLOB2
      Endif
      #--
      # On clot toujours l'exercice sauf pour la simulation si l'on est en fin de calcul
      #********************
      Call CCN_CLOTURE_EXERCICE From =G_GLOB2
      If ([M:DIV]ERROR) Then : Break : Endif
      #********************

    Endif

    ID = 1          : # A ce niveau, la période de départ est toujours la 1čre
    [M:DIV]BIML =0  : # A ce niveau, il n'y aura plus la notion de dépréciation ŕ gérer
    [M:DIV]BRFE =0  : # A ce niveau, il n'y aura plus la notion de réév. fin exe. ŕ gérer
    INDEXECAL  +=1  : # Actualisation du nombre d'exercices calculés
    [M:DIV]FE  +=1  : # Actualisation du pointeur FIY exercice
    # Actualisation du pointeur FIY période
    If ( [M:DIV]FE <= [M:FIY]NB_EXE  ) Then
      [M:DIV]FP = [M:FIY]INDDEBPER ([M:DIV]FE-1) + [M:FIY]INDCURPER ([M:DIV]FE-1) - 1
    Endif
    # Clôture période effectuée = Faux
    [M:DIV]BCLOPER = 0
    # Evaluation fin de boucle
    Gosub EVALUE_CCN_BFINI From =G_GLOB1
    If ( [M:DIV]ERROR ) Then : Break : Endif

  Wend
  # < 1 <<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<<

  If ( [M:DIV]ERROR ) Then : End : Endif

$FIN_CALCUL_PROVISIONS


End


#########################################################
Subprog  CCN_LEC_COEACT (PSOC, PCODACT,  RCOEACT )
#
# - Objet  : Lecture dans la table des codes actualisations
#            et récupération du code actualisation de l'exercice courant
#            ( s'il n'existe pas le coef d'actualisation est renvoyé ŕ 0)
#
#
# - Entrée : Société
#            Code actualisation
#
# - Sortie : Coefficient d'actualisation
#
# FQ54343
#

Value Char       PSOC
Value Char       PCODACT
Variable Decimal RCOEACT

Local Integer INDRPR


  #If ( GUSER = "MWA" and [M:DIV]BDEBUG ) Then : [M:DIV]BDEBUG -=1 : Dbgaff : Endif

  #------------------------------------
  If clalev([F:WCOE]) =0 : Local File CCNCOE    [WCOE]  : Endif        : # Actualisation
  #------------------------------------

  RCOEACT = 0.
  Read [WCOE]COE0=PSOC;PCODACT
  If (fstat) Then
    If ( PSOC <> "" ) Then
      Read [WCOE]COE0="";PCODACT
      If (!fstat) Then
        RCOEACT = [F:WCOE]CCNACTCOE
      Endif
    Endif
  Else
    RCOEACT = [F:WCOE]CCNACTCOE
  Endif


End

