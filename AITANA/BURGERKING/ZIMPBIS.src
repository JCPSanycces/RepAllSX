###################################################################################
$ACTION
#Infbox ACTION
  Case ACTION
    When "IMP_AVANT_OUVRE"  : Gosub $IMP_AVANT_OUVRE
    When "AP_IMPORT"        : Gosub $AP_IMPORT
    When "IMPORT"           : Gosub $IMPORT
    When Default
  Endcase
  Return

$OUVRE
    Gosub OUVRE From GASIMPORT
  Return

$RAZCRE
    Gosub RAZCRE From GASIMPORT
  Return

$VALID
    Gosub VALID From GASIMPORT
  Return

$SAIMSK
    Gosub SAIMSK From GASIMPORT
    Return

$IMP_FERME
  Return

#MRR01 ini
#######################################################################################
$IMPORT
  Case [L]SEPNUM
    When 1: Gosub $IMPORT0
    When 2: Gosub $IMPORT1
    When 3: Gosub $IMPORT2
    When 4: Gosub $IMPORT3
    When Default
  Endcase

  Return

