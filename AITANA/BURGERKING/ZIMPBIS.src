#######################################################################################
$IMP_AVANT_OUVRE
    Global  Integer  COUNTERFOUND : COUNTERFOUND=0
    Global  Integer  COUNTERYVAR : COUNTERYVAR=0
    # Si el tipo de importaciµn es YVAR, hacer un tratamiento especial

#######################################################################################
$AP_IMPORT
#  Infbox 'AP_IMPORT BPR ' + [F:PIH]BPR

  Local Char FICHERO_INVERSION(200)
  Local Char ASIENTO_ORIGEN, TYPE_ORIGEN, FCY_ORIGEN
  Local Char LAUX
  Local Char LPROV_AUX
  Local Char LPLANTA
  Local Char GLPLANTA

  # Infbox [L]IMPFIC

  Case [L]IMPFIC
    When "PIH"  # PINVOICE

        If  [M:DIA]MODIMP = "XBIS" Then
          [F:PIH]NUM = "P" + [F:PIH]NUM
        Endif

        If  [M:DIA]MODIMP = "XBIS" or [M:DIA]MODIMP = "XBISACREED" Then
          LPROV_AUX = ""
          #Infbox "Busca proveedor:" + [M:DIA]MODIMP + " - fcy" +  [F:HAE]FCY + " - bpr:" +[F:DAE]BPR
          LPROV_AUX = (func ZIMPBIS.BUSCAR_PROVEEDOR_SAGE([M:DIA]MODIMP, [F:PIH]FCY, [F:PIH]BPR))
          LPLANTA = [F:PIH]FCY
          If LPROV_AUX <> "" Then
            [F:PIH]BPR = LPROV_AUX
          Endif

          LPROV_AUX = ""
          #Infbox "Busca proveedor:" + [M:DIA]MODIMP + " - fcy" +  [F:HAE]FCY + " - bpr:" +[F:DAE]BPR
          LPROV_AUX = (func ZIMPBIS.BUSCAR_PROVEEDOR_SAGE([M:DIA]MODIMP, [F:PIH]FCY, [F:PIH]BPRPAY))
          If LPROV_AUX <> "" Then
            [F:PIH]BPRPAY = LPROV_AUX
          Endif
      Endif
    When "PIL"  # BPSINVLIG
        If  [M:DIA]MODIMP = "XBIS" or [M:DIA]MODIMP = "XBISACREED" Then
          LPROV_AUX = ""
          #Infbox "Busca proveedor:" + [M:DIA]MODIMP + " - fcy" +  [F:HAE]FCY + " - bpr:" +[F:DAE]BPR
          LPROV_AUX = (func ZIMPBIS.BUSCAR_PROVEEDOR_SAGE([M:DIA]MODIMP, [F:PIL]FCYLIN, [F:PIL]BPRLIN))
          If LPROV_AUX <> "" Then
            [F:PIL]BPRLIN = LPROV_AUX
          Endif
          If [F:PIL]TAX1 = "NO" Then
            [F:PIL]TAX1 = ""
          Endif
      Endif
    When "DUD"  # GACCDUDATE
       If  [M:DIA]MODIMP = "XBIS" or [M:DIA]MODIMP = "XBISACREED" Then
        #Infbox "Busca proveedor:" + [M:DIA]MODIMP + " - fcy" +  [F:HAE]FCY + " - bpr:" +[F:DAE]BPR
          LPROV_AUX = ""
          LPROV_AUX = (func ZIMPBIS.BUSCAR_PROVEEDOR_SAGE([M:DIA]MODIMP, LPLANTA, [F:DUD]BPRPAY))
          If LPROV_AUX <> "" Then
            [F:DUD]BPRPAY = LPROV_AUX
          Endif
      Endif

     When "PYH"  #
       If  [M:DIA]MODIMP = "ZPAY"  Then
        # Infbox "Busca proveedor:" + [M:DIA]MODIMP + " - fcy" +  [F:PYH]FCY + " - bpr:" +[F:PYH]BPR
          LPROV_AUX = ""
          LPLANTA = [F:PYH]FCY
          GLPLANTA = LPLANTA
          LPROV_AUX = (func ZIMPBIS.BUSCAR_PROVEEDOR_SAGE([M:DIA]MODIMP, LPLANTA, [F:PYH]BPR))
          If LPROV_AUX <> "" Then
            [F:PYH]BPR = LPROV_AUX
          Endif
        #  Infbox "PYH-RES: " + LPROV_AUX
      Endif

       When "PYD"  #PAYMENTD
       If  [M:DIA]MODIMP = "ZPAY"  Then
       # Infbox "Busca proveedor:" + [M:DIA]MODIMP + " - fcy" +  [F:HAE]FCY + " - bprLIN:" +[F:PYD]BPRLIN
          LPROV_AUX = ""
#          Infbox "GPLANTA: " + GLPLANTA + " -> CABECERA: " + [F:PYH]FCY
#          Infbox "BPRLIN: " + [F:PYD]BPRLIN
          LPROV_AUX = (func ZIMPBIS.BUSCAR_PROVEEDOR_SAGE([M:DIA]MODIMP, [F:PYH]FCY, [F:PYD]BPRLIN))
          If LPROV_AUX <> "" Then
            [F:PYD]BPRLIN = LPROV_AUX
          Endif
        #  Infbox "PYD-RES: " + LPROV_AUX
      Endif

    When Default
  Endcase

  Return

#############################################################################
Funprog BUSCAR_PROVEEDOR_SAGE(PMODELO, PSOCIEDAD, PPROVEEDOR)
  Local Char LPROV
  Local Char LTIM
  Local Char LBKS

  LTIM = "1000"
  LBKS = "2000"

  If !clalev([F:ZBPR])  Then : Global File BPARTNER [ZBPR] : Endif

  # Si el modelo es YALB, sustituir el proveedor BK/TIM por el de Sage
  #

  LPROV = ""
  # Infbox "VOY A BUSCAR EL PROVEEDOR :" + PPROVEEDOR + " - PSociedad: " + PSOCIEDAD
  If (PMODELO = "XBIS" or [M:DIA]MODIMP = "XBISACREED" or [M:DIA]MODIMP = "ZPAY") and PPROVEEDOR <> "" Then
    If PSOCIEDAD = LTIM Then
      # Infbox "Dentro de busqueda de TIM"
      Filter [ZBPR] Where XTIM = PPROVEEDOR

      # Infbox "Registros encontrados: " + num$(rowcount([ZBPR]))
      If rowcount([ZBPR]) = 1 Then
        Read [ZBPR] First
        LPROV = [F:ZBPR]BPRNUM
      Else
        LPROV = ""
      Endif
      Filter [ZBPR]
    Elsif PSOCIEDAD = LBKS Then
      # Infbox "Dentro de busqueda de BKS"
      Filter [ZBPR] Where XBKS = PPROVEEDOR
      If rowcount([ZBPR]) = 1 Then
        Read [ZBPR] First
        LPROV = [F:ZBPR]BPRNUM
      Else
        LPROV = ""
      Endif
      Filter [ZBPR]
    Endif
  Endif

   # Infbox "PROVEEDOR ENCONTRADO:" + LPROV

End LPROV

#MRR01 ini
###############################################################################
Subprog LIMPIA_STR(STR)
Value Char    STR
Global Char CLEANSTR(250)

Raz CLEANSTR

STR=ctrans(STR,"Ã" ,"a") : STR=ctrans(STR,"Á" ,"a") : STR=ctrans(STR,"ð" ,"a")
STR=ctrans(STR,"ã" ,"a") : STR=ctrans(STR,"ˆ" ,"a") : STR=ctrans(STR,"ê" ,"A")
STR=ctrans(STR,"â" ,"A") : STR=ctrans(STR,"ô" ,"A") : STR=ctrans(STR,"á" ,"A")
STR=ctrans(STR,"Õ" ,"e") : STR=ctrans(STR,"Ò" ,"e") : STR=ctrans(STR,"Š" ,"e")
STR=ctrans(STR,"õ" ,"e") : STR=ctrans(STR,"è" ,"E") : STR=ctrans(STR,"à" ,"E")
STR=ctrans(STR,"ò" ,"E") : STR=ctrans(STR,"ù" ,"E") : STR=ctrans(STR,"Ú" ,"i")
STR=ctrans(STR,"š" ,"i") : STR=ctrans(STR,"ÿ" ,"i") : STR=ctrans(STR,"Ÿ" ,"i")
STR=ctrans(STR,"ë" ,"I") : STR=ctrans(STR,"ä" ,"I") : STR=ctrans(STR,"ü" ,"I")
STR=ctrans(STR,"ö" ,"I") : STR=ctrans(STR,"µ" ,"o") : STR=ctrans(STR,"·" ,"o")
STR=ctrans(STR,"—" ,"o") : STR=ctrans(STR,"¶" ,"o") : STR=ctrans(STR,"Æ" ,"O")
STR=ctrans(STR,"Ø" ,"O") : STR=ctrans(STR,"ø" ,"O") : STR=ctrans(STR,"å" ,"O")
STR=ctrans(STR,"º" ,"u") : STR=ctrans(STR,"ª" ,"u") : STR=ctrans(STR,"■" ,"u")
STR=ctrans(STR,"«" ,"u") : STR=ctrans(STR,"Ö" ,"U") : STR=ctrans(STR,"ì" ,"U")
STR=ctrans(STR,"Ü" ,"U") : STR=ctrans(STR,"É" ,"U") : STR=ctrans(STR,"þ" ,"n")
STR=ctrans(STR,"î" ,"N") : STR=ctrans(STR,"Ó" ,"c") : STR=ctrans(STR,"ú" ,"C")
STR=ctrans(STR,"\" ,"-")  : STR=ctrans(STR,"´" ,"")  : STR=ctrans(STR,"¤" ,"")
STR=ctrans(STR,"~" ,"")  : STR=ctrans(STR,"#" ,"")  : STR=ctrans(STR,"@" ,"")
STR=ctrans(STR,"|" ,"")  : STR=ctrans(STR,"!" ,"")  : STR=ctrans(STR,'"' ,"")
STR=ctrans(STR,"*" ,"")  : STR=ctrans(STR,"ñ" ,"")  : STR=ctrans(STR,"$" ,"")
STR=ctrans(STR,"%" ,"")  : STR=ctrans(STR,"&" ,"")  : STR=ctrans(STR,"(" ,"")
STR=ctrans(STR,")" ,"")  : STR=ctrans(STR,"?" ,"")  : STR=ctrans(STR,"'" ,"")
STR=ctrans(STR,"À" ,"")  : STR=ctrans(STR,"¢" ,"")  : STR=ctrans(STR,"[" ,"")
STR=ctrans(STR,"^" ,"")  : STR=ctrans(STR,"<" ,"")  : STR=ctrans(STR,">" ,"")
STR=ctrans(STR,"]" ,"")  : STR=ctrans(STR,"+" ,"")  : STR=ctrans(STR,"}" ,"")
STR=ctrans(STR,"{" ,"")  : STR=ctrans(STR,"Ç" ,"")  : STR=ctrans(STR,";" ,"")
#STR=ctrans(STR," " ,"")
STR=ctrans(STR,":" ,"")  : STR=ctrans(STR,"/" ,"-")
#STR=ctrans(STR,chr$(13),"") # retorno carro
STR=ctrans(STR,chr$(10),"") # nueva linea


CLEANSTR = STR
#Infbox CLEANSTR

End
#MRR01 fin
