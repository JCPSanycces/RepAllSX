#<AdxTL>@(#)0.0.0.0 $Revision$ 

$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "SETBOUT"      : Gosub SETBOUT
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "BOUTON"       : Gosub BOUTON
    When "FIN"          : Gosub FIN
  Endcase
Return

#------------------------------------------------------------------------------#

$OUVRE
  If clalev([F:SIV])=0 : Local File SINVOICEV  [SIV] : Endif
  If clalev([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif
  If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
  If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
  If clalev([F:AIM])=0 : Local File APRINTER   [AIM] : Endif
  If clalev([F:AVL])=0 : Local File AVOLUME    [AVL] : Endif

  Local  Char    CRITERE(250), WRPTCOD(GLONARP), WCODAIM(GLONAIM), WYPATHPDF(250),
&                AUXCHAR(250), NOMFIC(250), WMSG(250), PATH_FILE(255), WVOL(GLONAVL)
  Local  Integer IS_FULL_TABLE, YSTA, WSEC, NBRFIC, STAT, NOL, AUXINT, NBERR
  Global Char    GYWNOMFIC(250)

  WRPTCOD = func AFNC.PARAM("YSIHRPTCOD", "")
  If WRPTCOD=""
    GMESSAGE = "YSIHRPTCOD:" - mess(141,105,1)
    GERR = 1 : FIN = 1 : Return
  Endif

  # Destino de impresi鏮 igual a fichero con formato de exportaci鏮 PDF
  Filter [F:AIM] Where PRT=4 and PRTFMT=29 and ENAFLG=2
  Read [F:AIM]AIM0 First
  Filter [F:AIM]
  If fstat
    GMESSAGE  = mess(6,6002,1)
    GERR = 1 : FIN = 1 : Return
  Else
    WCODAIM = [F:AIM]COD
  Endif

  # Volumen facturas documentos adjuntos
  WVOL = func AFNC.PARAM("YVOLJOINT", "")
  If WVOL=""
    GMESSAGE  = "YVOLJOINT:" - mess(141,105,1)
    GERR = 1 : FIN = 1 : Return
  Endif
  Read [F:AVL]CODE=WVOL
  If fstat
    GMESSAGE  = WVOL + ":" - mess(47,149,1)
    GERR = 1 : FIN = 1 : Return
  Endif
  WYPATHPDF = func ASYRSTO.GETFULLPATH(WVOL, "")
  If right$(WYPATHPDF, len(WYPATHPDF))<>"\"
    WYPATHPDF += "\"
  Endif
Return

#------------------------------------------------------------------------------#

$DEBUT
  If [V]GBATCH : Return : Endif

  [M:YSIP]ALLCPY = 2
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE : [M:YSIP]ALLCPY = 1 : Endif
  If [M:YSIP]ALLCPY = 1
    Call INICPY([M:YSIP]WCPY) From CPTSUB
  Endif
  If [M:YSIP]ALLCPY=2
    Diszo [M:YSIP]WCPY
  Else
    Actzo [M:YSIP]WCPY
  Endif

  [M:YSIP]ALLFCY = 2
  If [M:YSIP]ALLCPY = 1
    Call INIALLFCY([M:YSIP]ALLFCY,[M:YSIP]WCPY) From CPTTRT
  Endif
  If [M:YSIP]ALLFCY = 1
    Call INIFCY([M:YSIP]WFCY,[M:YSIP]WCPY) From CPTSUB
  Endif
  If [M:YSIP]ALLFCY=2
    Diszo [M:YSIP]WFCY
  Else
    Actzo [M:YSIP]WFCY
  Endif

  [M:YSIP]ALLTYP = 2 : Diszo [M:YSIP]WINVTYP

  [M:YSIP]YPATHPDF = [L]WYPATHPDF
  Affzo [M:YSIP]
Return

#------------------------------------------------------------------------------#

$SETBOUT
  If [V]GBATCH
    Call VIREBOUT(CHMEN, "2345") From GOBJET
    Gosub SET_BOUT_SPE From GSAISIE
  Else
    If [M:YSIP]NBLIG=0
      Call VIREBOUT(CHMEN, "2345") From GOBJET
      Gosub SET_BOUT_SPE From GSAISIE
    Endif
  Endif
Return

#------------------------------------------------------------------------------#

$AVANT_BOUTON
  Case BOUT
    When "5" : Raz  GADIFDAT, GADIFTIM
  Endcase
Return

#------------------------------------------------------------------------------#

$BOUTON
  Case BOUT
    When "1"
      If [V]GBATCH
        FIN = 1
      Else
        Gosub SEARCH
      Endif
    When "2" : Gosub INCLUDE_ALL
    When "3" : Gosub EXCLUDE_ALL
    When "4" : Gosub GENERATE
    When "5" : Gosub GEN_BATCH
  Endcase
Return

#------------------------------------------------------------------------------#

$FIN
  If dim([V]GYWNOMFIC)>0 : Kill [V]GYWNOMFIC : Endif
Return

#------------------------------------------------------------------------------#

$SEARCH
  Effzo [M:YSIP]15
  CRITERE = "1=1"
  If [M:YSIP]ALLCPY<>2
    CRITERE -= '& CPY="' + [M:YSIP]WCPY + '"'
  Endif
  If [M:YSIP]ALLFCY<>2
    CRITERE -= '& SALFCY="' + [M:YSIP]WFCY + '"'
  Endif
  If [M:YSIP]ALLTYP<>2
    CRITERE -= '& INVTYP=' + num$([M:YSIP]WINVTYP)
  Endif
  If [M:YSIP]STRDAT<>[0/0/0]
    CRITERE -= "& INVDAT>=[" + format$(GFMD, [M:YSIP]STRDAT) + "]"
  Endif
  If [M:YSIP]ENDDAT<>[0/0/0]
    CRITERE -= "& INVDAT<=[" + format$(GFMD, [M:YSIP]ENDDAT) + "]"
  Endif
  If [M:YSIP]VCRDEB<>""
    CRITERE -= '& NUM>="' + [M:YSIP]VCRDEB + '"'
  Endif
  If [M:YSIP]VCRFIN<>""
    CRITERE -= '& NUM<="' + [M:YSIP]VCRFIN + '"'
  Endif
  If [M:YSIP]BPCINVDEB<>""
    CRITERE -= '& BPCINV>="' + [M:YSIP]BPCINVDEB + '"'
  Endif
  If [M:YSIP]BPCINVFIN<>""
    CRITERE -= '& BPCINV<="' + [M:YSIP]BPCINVFIN + '"'
  Endif
  # <GON> Excluyo a pelo la planta 002
  CRITERE -= '& SALFCY<>"002"'
  # </GON>
  If ![V]GSERVEUR : Call TEMPON("R") From GESECRAN : Endif
  Raz IS_FULL_TABLE
  Raz nolign
  For [F:SIV]SIV0 Where evalue(CRITERE)
    If nolign>=dim([M:YSIP]NUM)
      IS_FULL_TABLE = 1 : Break
    Endif
    nolign += 1
    NOL = nolign-1
    Read [F:SIH]SIH0=[F:SIV]NUM
    If fstat : Raz [F:SIH] : Endif
    [M:YSIP] = [F:SIH]
    [M:YSIP] = [F:SIV]
    Read [F:BPR]BPR0=[F:SIH]BPR
    If fstat : Raz [F:BPR] : Endif
    [M:YSIP]WBPRNAM(NOL) = [F:BPR]BPRNAM(0)

    Gosub GET_NOMFIC

    # <GON> No incluir la empresa en la ruta
    ##AUXCHAR = [M:YSIP]YPATHPDF + [F:SIV]CPY + "\" + NOMFIC
    AUXCHAR = [M:YSIP]YPATHPDF + NOMFIC
    # </GON>

    Call EXISTE(AUXCHAR, YSTA) From ORDSYS
    If YSTA=1
      [M:YSIP]PDFEXIST(NOL) = 2
    Else
      [M:YSIP]PDFEXIST(NOL) = 1
    Endif
    If [V]GSERVEUR #and [M:YSIP]YINVSENT(NOL)<>2
      [M:YSIP]CHKCREPDF(NOL) = 2
    Endif
  Next
  [M:YSIP]NBLIG = nolign
  Affzo [M:YSIP]15
  If ![V]GSERVEUR : Call TEMPOFF From GESECRAN : Endif
  If IS_FULL_TABLE
    GMESSAGE = mess(26,100,1) : GERR = 2
  Endif
Return

#------------------------------------------------------------------------------#

$INCLUDE_ALL
  If [M:YSIP]NBLIG>0 : Call SELECT_ALL(2,0) : Endif
Return

#------------------------------------------------------------------------------#

$EXCLUDE_ALL
  If [M:YSIP]NBLIG>0 : Call SELECT_ALL(1,0) : Endif
Return

#------------------------------------------------------------------------------#

$GENERATE
  If find(2, [M:YSIP]CHKCREPDF(0..[M:YSIP]NBLIG-1))=0 : Return : Endif
  Raz NBERR

  Local Char TBPAR(10)(1..50), TBVAL(30)(1..50)
  Raz NBRFIC

  If !GSERVEUR : Call TEMPON("R") From GESECRAN : Endif
  If !GSERVEUR : Call OUVRE_TRACE(mess(10,6002,1)) From LECFIC : Endif
  For I=0 To [M:YSIP]NBLIG-1
    If [M:YSIP]CHKCREPDF(I)=2
      Read [F:SIV]SIV0=[M:YSIP]NUM(I)
      If fstat : Raz [F:SIV] : Endif

      Read [F:BPC]BPC0=[F:SIV]BPCINV
      If fstat : Raz [F:BPC] : Endif

      K = 0
      If [F:BPC]YSENDINVOICE=2 and [F:SIV]YINVSENT<>2
        K = 1
      Elsif [F:BPC]YSENDINVOICE<>2 and [M:YSIP]PDFEXIST(I)<>2
        K = 1
      Endif
      If K
        Gosub IMPRIME
      Endif
    Endif
  Next I
  If !GSERVEUR : Call FERME_TRACE From LECFIC : Endif

  # Bucle para marcar el check de "PDF generado"
  If NBRFIC>0 and !GSERVEUR
    For NOL=0 To [M:YSIP]NBLIG-1
      If [M:YSIP]CHKCREPDF(NOL)=2
        Raz WSEC

        Gosub GET_NOMFIC
        # <GON> No incluyo la empresa en la ruta
        ##AUXCHAR = [M:YSIP]YPATHPDF + [M:YSIP]CPY(NOL) + "\" + NOMFIC
        AUXCHAR = [M:YSIP]YPATHPDF + NOMFIC
        # </GON>
        Repeat
          Call EXISTE(AUXCHAR, YSTA) From ORDSYS
          If YSTA<>1
            Sleep 1
            WSEC += 1
          Endif
        Until YSTA=1 or WSEC>5
        If YSTA=1
          [M:YSIP]PDFEXIST(NOL) = 2
          [M:YSIP]CHKCREPDF(NOL) = 1
        Else
          [M:YSIP]PDFEXIST(NOL) = 1
        Endif
        Affzo [M:YSIP]PDFEXIST(NOL)
        Affzo [M:YSIP]CHKCREPDF(NOL)
      Endif
    Next NOL
  Endif

  If !GSERVEUR : Call TEMPOFF From GESECRAN : Endif

  If NBERR>0 and !GSERVEUR
    Call LEC_TRACE From LECFIC
  Endif
Return

#------------------------------------------------------------------------------#

$GEN_BATCH
  If GADIFDAT<>[0/0/0] & GADIFTIM<>""
    Call REQUETE(GADIFDAT, GADIFTIM, GBOITE) From ADIFFERE
    Raz GADIFDAT, GADIFTIM
  Endif
Return

#------------------------------------------------------------------------------#

$IMPRIME
  Call GEN_PDF("SIH", [F:SIV]NUM, WRPTCOD, WCODAIM, STAT, WMSG) From YSENDPDF
  If STAT
    Call ECR_TRACE(mess(55,198,1) - [F:SIV]NUM + ":" - mess(6,123,1) - WMSG, 1) From GESECRAN
    NBERR += 1
  Else
    Call ECR_TRACE(mess(55,198,1) - [F:SIV]NUM + ":" - mess(11,6002,1), 0) From GESECRAN
    NBRFIC += 1
    If [F:BPC]YSENDINVOICE=2
      AUXINT = [F:SIV]YNBRINVSENT
      Call WORKFLOW(1,"YED","","") From AWRK
      Read [F:SIV]SIV0=[M:YSIP]NUM(I)
      If fstat : Raz [F:SIV] : Endif
      If [F:SIV]YNBRINVSENT<=AUXINT
        WMSG  = mess(8,6002,1) + "\"
        WMSG += mess(9,6002,1)
        Call ECR_TRACE(WMSG, 1) From GESECRAN
        NBERR += 1
      Endif
    Endif
  Endif
Return

#------------------------------------------------------------------------------#

$GET_NOMFIC
  NOMFIC = toupper([M:YSIP]NUM(NOL))
  # <GON> Elimino la Raz鏮 Social del Nombre
  ##If [M:YSIP]WBPRNAM(NOL)<>""
  ##  NOMFIC +=  "_" + func YSENDPDF.REMOVE_FILENAME_CHARS([M:YSIP]WBPRNAM(NOL), "")
  ##  If right$(NOMFIC, len(NOMFIC))<>"."
      NOMFIC += "."
  ##  Endif
    NOMFIC += "pdf"
  ##Endif
  # </GON>
Return

#------------------------------------------------------------------------------#

Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    VALEUR = 1 : mkstat = 1
  Endif
End

#------------------------------------------------------------------------------#

Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR
  Raz [M:YSIP]WCPY
  If VALEUR=2
    Diszo [M:YSIP]WCPY
  Else
    Actzo [M:YSIP]WCPY
  Endif
  Affzo [M:YSIP]WCPY
End

#------------------------------------------------------------------------------#

Subprog AS_WCPY(VALEUR)
Variable Char    VALEUR()
  If [M:YSIP]ALLCPY=2
    VALEUR = 1 : mkstat = 1
  Endif
End

#------------------------------------------------------------------------------#

Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
  If [M:YSIP]ALLCPY=2
    VALEUR = 2
  Else
    Call INIALLFCY(VALEUR, [M:YSIP]WCPY) From CPTTRT
  Endif
  If VALEUR=2
    Raz [M:YSIP]WFCY
    Diszo [M:YSIP]WFCY
  Else
    Actzo [M:YSIP]WFCY
  Endif
  Affzo [M:YSIP]WFCY
End

#------------------------------------------------------------------------------#

Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR
  Raz [M:YSIP]WFCY
  If VALEUR=2
    Diszo [M:YSIP]WFCY
  Else
    Actzo [M:YSIP]WFCY
  Endif
  Affzo [M:YSIP]WFCY
End

#------------------------------------------------------------------------------#

Subprog AS_WFCY(VALEUR)
Variable Char    VALEUR()
  If [M:YSIP]ALLFCY=2
    VALEUR = 1 : mkstat = 1
  Endif
End

#------------------------------------------------------------------------------#

Subprog AM_ALLTYP(VALEUR)
Variable Integer VALEUR
  Raz [M:YSIP]WINVTYP
  If VALEUR=2
    Diszo [M:YSIP]WINVTYP
  Else
    Actzo [M:YSIP]WINVTYP
  Endif
  Affzo [M:YSIP]WINVTYP
End

#------------------------------------------------------------------------------#

Subprog AS_WINVTYP(VALEUR)
Variable Integer VALEUR
  If [M:YSIP]ALLTYP=2
    VALEUR = 1 : mkstat = 1
  Endif
End

#------------------------------------------------------------------------------#

Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
  If VALEUR<>[0/0/0] : [M:YSIP]ENDDAT = VALEUR : Endif
End

#------------------------------------------------------------------------------#

Subprog AM_VCRDEB(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>"" : [M:YSIP]VCRFIN = VALEUR : Endif
End

#------------------------------------------------------------------------------#

Subprog AM_BPCINVDEB(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>"" : [M:YSIP]BPCINVFIN = VALEUR : Endif
End

#------------------------------------------------------------------------------#

Subprog SELECT_ALL(PON, DESDE)
Value Integer PON
Value Integer DESDE
Local Integer I

  For I=DESDE To [M:YSIP]NBLIG-1
    If PON=2
      [M:YSIP]CHKCREPDF(I) = 2
    Else
      [M:YSIP]CHKCREPDF(I) = 1
    Endif
  Next I
  Affzo [M:YSIP]CHKCREPDF
End

#------------------------------------------------------------------------------#

Subprog IB_NBLIG
  GBOUT4 = mess(193, 198,1)-[M:YSIP]NUM(nolign-1)
End

#------------------------------------------------------------------------------#

Subprog B1_NBLIG
  Call SELECT_ALL(2,nolign-1)
End

#------------------------------------------------------------------------------#

Subprog B2_NBLIG
  Call SELECT_ALL(1,nolign-1)
End

#------------------------------------------------------------------------------#

Subprog GET_PDF_SIH(WNUM, WCPY, WBPRNAM, WYPATHPDF)
Value Char WNUM
Value Char WCPY
Value Char WBPRNAM
Value Char WYPATHPDF

  If WNUM="" : End : Endif

  Local Char    WDIR(255), NOMFIC(250), ORDSYS(255), TEMPFILE(255), URL(255)
  Local Integer STAT

  # <GON> Elimino la Raz鏮 Social del Nombre y la sociedad de la ruta
  ##WDIR = WYPATHPDF + WCPY + "\"
  WDIR = WYPATHPDF
  ##NOMFIC = toupper(WNUM + "_" + func YSENDPDF.REMOVE_FILENAME_CHARS(WBPRNAM, ""))
  NOMFIC = toupper(WNUM) ## + "_" + func YSENDPDF.REMOVE_FILENAME_CHARS(WBPRNAM, ""))
  ##If right$(NOMFIC, len(NOMFIC))<>"."
    NOMFIC += "."
  ##Endif
  # </GON>
  NOMFIC += "pdf"
  TEMPFILE = filpath(nomap + "/TMP/" + NOMFIC, "", "", "X3_PUB")
  ORDSYS = 'COPY "' + WDIR + NOMFIC + '" "' + TEMPFILE + '"'
  Call SYSTEME(adxmac(0), ORDSYS, "", STAT) From ORDSYS
  Call EXISTE(TEMPFILE, STAT) From ORDSYS
  If STAT=1
    URL = func AFNC.PARAM("YDIRPUBPDF", "")
    If URL="" : URL = GVIRTDIR : Endif
    If right$(URL, len(URL))<>"/"
      URL += "/"
    Endif
    URL += nomap + "/TMP/" + NOMFIC

    Callui RETOUR="" With "UIAction="    + chr$(1) + "OpenFile",
&                         "UILocalDir="  + chr$(1) + "HTTP",
&                         "UILocalFile=" + chr$(1) + URL
  Else
    GMESSAGE = "|" + WDIR + NOMFIC + "|.\"
    GMESSAGE+= mess(12,6002,1)
    Call ERREUR(GMESSAGE) From GESECRAN
    Raz GMESSAGE
  Endif
End

#------------------------------------------------------------------------------#

