#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
# Gesti¾n de la mßscara YPEDIDOS
# APL(10/07/17) Nuevo
######################################################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "FERME"      : Gosub FERME
  When "FIN_CRIT"   : Gosub FIN_CRIT
 When Default
Endcase
Return
############################################################
$AUTORIS
Return
############################################################
$FERME
Gosub ELIMINAR_SELECCION
Return
###################################################################
# analyse paramĶres, initialisations, ouvertures et dķclarations  #
###################################################################
$OUVRE
Local Char    WFIL(250),WFIL1(250),WFIL2(250)
Local Char    WCRITPED1(250), WCRITPED2(250), WCRITEBIT(250)
Local Integer DEBNUM, FINNUM

Local Integer WSECUENCIA

Gosub DEFCRIT

If clalev ([F:AUS])= 0  : Local File AUTILIS       [AUS]: Endif
If clalev ([F:POH])= 0  : Local File PORDER        [POH]: Endif
If clalev ([F:BPS])= 0  : Local File BPSUPPLIER    [BPS]: Endif
If clalev ([F:AWS])= 0  : Local File AWRKHISSUI    [AWS]: Endif

If clalev ([F:YPED]) = 0 : Local File YPEDIDO   [YPED]: Endif
If clalev ([F:YPEB]) = 0 : Local File YPEDEBIT  [YPEB]: Endif

Return
#[YPED]#######################################################
$DEFCRIT

[M:YPED0]YPOHFCY  = ""

[M:YPED0]YBPSNUMDEB = ""
[M:YPED0]YBPSNUMFIN = ""

[M:YPED0]YPOHNUMDEB = ""
[M:YPED0]YPOHNUMFIN = ""

[M:YPED0]YORDDATDEB = [0/0/0]
[M:YPED0]YORDDATFIN = [0/0/0]

[M:YPED0]YCUR       = ""
[M:YPED0]YREV       = 0
[M:YPED0]YRECH      = 0
[M:YPED0]YCONT      = 0
[M:YPED0]YPAGA      = 0
[M:YPED0]YRETEN     = 0
[M:YPED0]YAPPFLGO   = 2
[M:YPED0]YAPPFLGN   = 2
[M:YPED0]YRCPFLG    = 2
[M:YPED0]YRCPFLGN   = 2
[M:YPED0]YCLEFLGO   = 0
[M:YPED0]YFACT      = 2
[M:YPED0]YFACTN     = 2

# -- copie de l'ķcran critĶres vers le masque 1
Gosub CRITENT From =PROGCNS

Return
############################################################
$LECTURE
Local   Decimal  WMNTORG(0..5), WMNTDES(0..5)
Local   Integer  SPSTAT

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif
#-- Positionnement des Filtres
Gosub LOAD_FILTER
If PROGSPE<>""
 ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif
#Como no podemos obtener los datos cińon un Link generamos antes un fichero
If CHGPAG = 1
  Gosub ELIMINAR_SELECCION
  Gosub CREAR_INTERMEDIO
Endif
#
# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page prķcķdente)             #
# ------------------------------------------------------- #
#-- Application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Filter [YPED] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key WKEY0=[F:YPED]YSECUENCIA Asc
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Filter [YPED] Where evalue(WFIL) & evalue(WFIL1) & evalue(WFIL2) Order By Key WKEY0=[F:YPED]YSECUENCIA Desc
Endif
#-- raz du masque
If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:YPED1] : Endif
#-- lecture
$BOUCLE
For [YPED]
  If NBLU = 1
     If CHGPAG=2 | CHGPAG=-2 : Raz [M:YPED1] : Endif
     NBLU = 2
  Endif
  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
     NOL    += 1
     If NOL=0
         DEBNUM = [F:YPED]YSECUENCIA
     Endif
     FINNUM = [F:YPED]YSECUENCIA
  Else
     If NOL <= 0 : RETOUR=2 : Break : Endif
     NOL    -= 1
     If NOL=MAXLIG-1
         FINNUM = [F:YPED]YSECUENCIA
     Endif
     DEBNUM = [F:YPED]YSECUENCIA
  Endif

  Case CHGPAG
      When 3 : # rafraichissement
          WFIL += "&([F:YPED]YSECUENCIA>=DEBNUM))"
      When 2 : # suite
          WFIL += "&([F:YPED]YSECUENCIA>FINNUM)"
      When -2 : # retour
          WFIL += "(&[F:YPED]YSECUENCIA<DEBNUM)"
  Endcase

  nolign = NOL+1

  [M:YPED1]YPOHNUM(nolign-1)   = [F:YPED]YPOHNUM
  [M:YPED1]YPOHFCY(nolign-1)   = [F:YPED]YPOHFCY
  [M:YPED1]YBPSNUM(nolign-1)   = [F:YPED]YBPSNUM
  [M:YPED1]YBPSNAM(nolign-1)   = [F:YPED]YBPSNAM
  [M:YPED1]YORDDAT(nolign-1)   = [F:YPED]YORDDAT
  [M:YPED1]YTOTORD(nolign-1)   = [F:YPED]YTOTORD
  [M:YPED1]YTTVORD(nolign-1)   = [F:YPED]YTTVORD
  [M:YPED1]YCUR(nolign-1)      = [F:YPED]YCUR
  [M:YPED1]YAPPFLG(nolign-1)   = [F:YPED]YAPPFLG
  [M:YPED1]YPRNFLG(nolign-1)   = [F:YPED]YPRNFLG
  [M:YPED1]YRCPFLG(nolign-1)   = [F:YPED]YRCPFLG
  [M:YPED1]YCLEFLG(nolign-1)   = [F:YPED]YCLEFLG
  [M:YPED1]YINVFLG(nolign-1)   = [F:YPED]YINVFLG
  [M:YPED1]YPTE(nolign-1)      = [F:YPED]YPTE
  [M:YPED1]CREUSR(nolign-1)    = [F:YPED]CREUSR
  [M:YPED1]YNOMUSR(nolign-1)   = [F:YPED]YNOMUSR
  [M:YPED1]YFIRM1(nolign-1)    = [F:YPED]YFIRM1
  [M:YPED1]YFIRM2(nolign-1)    = [F:YPED]YFIRM2
  [M:YPED1]YFIRM3(nolign-1)    = [F:YPED]YFIRM3

  Filter [F:YPEB]
  If rowcount([YPEB])=0 Then
    [M:YPED1]YESTEBIT(nolign-1)= "Sin factura"
  Elsif rowcount([YPEB])=1 Then
    [M:YPED1]YESTEBIT(nolign-1)= [F:YPEB]ESTADO_0
  Else
    [M:YPED1]YESTEBIT(nolign-1)= "Consultar Detalle"
  Endif
  Filter [F:YPEB]
  $SUIV
Next

Return
############################################################
#    Prķparation du filtre                                 #
############################################################
$LOAD_FILTER
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"

WFIL += "&[F:YPED]USR=GUSER"

Case CHGPAG
  When 3 : # rafraichissement
      WFIL += "&([F:POH]POHNUM>=DEBNUM)"
  When 2 : # suite
      WFIL += "&([F:POH]POHNUM>FINNUM)"
  When -2 : # retour
      WFIL += "(&[F:POH]POHNUM<DEBNUM )"
Endcase

Return

############################################################################
#    Avant de fermer la fenetre critĶre et de revenir Ó fenetre principale #
############################################################################
$FIN_CRIT


Return
#############################################################################
#############################################################################
$CREAR_INTERMEDIO
#Criterios de POH
WCRITPED1  = "1=1"

If [M:YPED0]YPOHFCY <> ""
    WCRITPED1 += "&[F:POH]POHFCY=[M:YPED0]YPOHFCY"
Endif
If [M:YPED0]YBPSNUMDEB <> ""
    WCRITPED1 += "&[F:POH]BPSNUM>=[M:YPED0]YBPSNUMDEB"
Endif
If [M:YPED0]YBPSNUMFIN <> ""
    WCRITPED1 += "&[F:POH]BPSNUM<=[M:YPED0]YBPSNUMFIN"
Endif
If [M:YPED0]YPOHNUMDEB <> ""
    WCRITPED1 += "&[F:POH]POHNUM>=[M:YPED0]YPOHNUMDEB"
Endif
If [M:YPED0]YPOHNUMFIN <> ""
    WCRITPED1 += "&[F:POH]POHNUM<=[M:YPED0]YPOHNUMFIN"
Endif
If [M:YPED0]YORDDATDEB <> [0/0/0]
   WCRITPED1 += "&[F:POH]ORDDAT>=[M:YPED0]YORDDATDEB"
Endif
If [M:YPED0]YORDDATFIN <> [0/0/0]
   WCRITPED1 += "&[F:POH]ORDDAT<=[M:YPED0]YORDDATFIN"
Endif
If [M:YPED0]YCUR <> ""
    WCRITPED1 += "&[F:POH]CUR=[M:YPED0]YCUR"
Endif
#
WCRITPED2 = "1=1"
If [M:YPED0]YAPPFLGO = 1
   WCRITPED2 += "&[F:POH]APPFLG<3"
Endif
If [M:YPED0]YAPPFLGN = 1
   WCRITPED2 += "&[F:POH]APPFLG>2"
Endif
If [M:YPED0]YRCPFLG = 1
   WCRITPED2 += "&[F:POH]RCPFLG<3"
Endif
If [M:YPED0]YRCPFLGN = 1
   WCRITPED2 += "&[F:POH]RCPFLG>2"
Endif
If [M:YPED0]YCLEFLGO = 2
   WCRITPED2 += "&[F:POH]CLEFLG=2"
Endif
If [M:YPED0]YFACT = 1
   WCRITPED2 += "&[F:POH]INVFLG<3"
Endif
If [M:YPED0]YFACTN = 1
   WCRITPED2 += "&[F:POH]INVFLG>2"
Endif
#
WCRITEBIT = ""
If [M:YPED0]YREV = 2
   If len(WCRITEBIT)=0 Then
    WCRITEBIT = "[F:YPEB]ESTADO=En revisi¾n"
   Else
    WCRITEBIT += " OR [F:YPEB]ESTADO=En revisi¾n"
   Endif
Endif
If [M:YPED0]YRECH = 2
   If len(WCRITEBIT)=0 Then
    WCRITEBIT = "[F:YPEB]ESTADO=Rechazada"
   Else
    WCRITEBIT += " OR [F:YPEB]ESTADO=Rechazada"
   Endif
Endif
If [M:YPED0]YCONT = 2
   If len(WCRITEBIT)=0 Then
    WCRITEBIT += "[F:YPEB]ESTADO=En contabilidad"
   Else
    WCRITEBIT += " OR [F:YPEB]ESTADO=En contabilidad"
   Endif
Endif
If [M:YPED0]YRETEN = 1
   If len(WCRITEBIT)=0 Then
    WCRITEBIT += "[F:YPEB]ESTADO=Retenida"
   Else
    WCRITEBIT += " OR [F:YPEB]ESTADO=Retenida"
   Endif
Endif

If len(WCRITEBIT)=0 Then
  WCRITEBIT = "1=1"
Endif

If len(WCRITEBIT)>3 Then
  WCRITEBIT = right$(WCRITEBIT, 4)
Endif
Filter [F:POH] Where evalue(WCRITPED1) and evalue(WCRITPED2)
For [POH]

  If [M:YPED0]YPAGA = 2
    If func COMPROBAR_PAGADO([F:POH]POHNUM) = 2 and [F:POH]INVFLG > 2
      #Filter [F:YPEB] Where (evalue(WCRITEBIT))
      Filter [F:YPEB]
      #If rowcount([YPEB])>0 Then
        Gosub GRABAR_INTERMEDIO
      #Endif
      Filter [F:YPEB]
    Endif
  Else
    #Filter [F:YPEB] Where (evalue(WCRITEBIT))
    Filter [F:YPEB]
    #If rowcount([YPEB])>0 Then
      Gosub GRABAR_INTERMEDIO
    #Endif
    Filter [F:YPEB]

  Endif
Next
Filter [POH]
#
#A±adimos n║ de secuencia para poder ordenar por lo que quieren y simplificar la paginacion
Raz WSECUENCIA
Filter [F:YPED] Where [F:YPED]USR=GUSER
&               Order By Key WKEY1=[F:YPED]YPOHNUM
For [YPED]WKEY1
  WSECUENCIA += 1
  [F:YPED]YSECUENCIA = WSECUENCIA
  Rewrite [F:YPED]
Next
Filter [F:YPED]
Return
########################################
$GRABAR_INTERMEDIO
#
Raz [F:YPED]
#
[F:YPED]USR        = GUSER
[F:YPED]YSECUENCIA = 0
#
Read [AUS]LOGIN  = [F:POH]CREUSR
Read [BPS]BPS0   = [F:POH]BPSNUM
#
[F:YPED]YPOHNUM  = [F:POH]POHNUM
[F:YPED]YPOHFCY  = [F:POH]POHFCY
[F:YPED]YBPSNUM  = [F:POH]BPSNUM
[F:YPED]YBPSNAM  = [F:BPS]BPSNAM
[F:YPED]YORDDAT  = [F:POH]ORDDAT
[F:YPED]YTOTORD  = [F:POH]TOTORD
[F:YPED]YTTVORD  = [F:POH]TTVORD
[F:YPED]YCUR     = [F:POH]CUR
[F:YPED]YAPPFLG  = [F:POH]APPFLG
[F:YPED]YPRNFLG  = [F:POH]PRNFLG
[F:YPED]YRCPFLG  = [F:POH]RCPFLG
[F:YPED]YCLEFLG  = [F:POH]CLEFLG
[F:YPED]YINVFLG  = [F:POH]INVFLG
[F:YPED]YPTE     = [F:POH]PTE
[F:YPED]CREUSR   = [F:POH]CREUSR
[F:YPED]YNOMUSR  = [F:AUS]NOMUSR
#
Filter [F:AWS] Where [F:AWS]CLEOBJ=[F:POH]POHNUM and [F:AWS]USRSIG <> '' and [F:AWS]FLGSIG = 5 Order By Key WKEY0 = [F:AWS]DATSIG Desc
For [AWS]WKEY0
  Read [AUS]LOGIN  = [F:AWS]USRSIG
  If [F:YPED]YFIRM1 = ''
    [F:YPED]YFIRMCOD1 = [F:AWS]USRSIG
    [F:YPED]YFIRM1 = [F:AUS]NOMUSR
  Elsif [F:YPED]YFIRM2 = ''
    If [F:YPED]YFIRMCOD1 <> [F:AWS]USRSIG Then
      [F:YPED]YFIRMCOD2 = [F:AWS]USRSIG
      [F:YPED]YFIRM2 = [F:AUS]NOMUSR
    Endif
  Elsif [F:YPED]YFIRM3 = ''
    If [F:YPED]YFIRMCOD1 <> [F:AWS]USRSIG and [F:YPED]YFIRMCOD2 <> [F:AWS]USRSIG Then
      [F:YPED]YFIRMCOD3 = [F:AWS]USRSIG
      [F:YPED]YFIRM3 = [F:AUS]NOMUSR
      Break
    Endif
  Endif
  Filter [AUS]
Next
Filter [F:AWS]
#
Write [F:YPED]

Return
##################################################
$ELIMINAR_SELECCION
Delete [F:YPED] Where USR=GUSER
Return
##################################################
#Comprobar si el pedido esta totalmente pagado
Funprog COMPROBAR_PAGADO(PEDIDO)
Value Char PEDIDO

Local Integer RESPUESTA : RESPUESTA = 2

If clalev ([F:PTD1])= 0  : Local File PRECEIPTD    [PTD1]: Endif : Filter [PTD1]
If clalev ([F:PID1])= 0  : Local File PINVOICED   [PID1]: Endif : Filter [PID1]
If clalev ([F:DUD1])= 0  : Local File GACCDUDATE  [DUD1]: Endif : Filter [DUD1]


Link [PID1] With [PTD1]PTD0=NUMORI;LINORI As [PID2]

# Si el campo FLGCLE no es 2 significa que el vencimiento esta pendiente y por tanto, el pedido no estß pagado
Filter [PID1] Where POHNUM = PEDIDO and PTDLIN = 1000
For [PID1]
  Filter [DUD1] Where NUM = [PID1]NUM & FLGCLE <> 2
  If rowcount([DUD1])>0 Then
    RESPUESTA = 1
    Break
  Endif
Next

End RESPUESTA
########
######################################################################################
######################################################################################
######################################################################################
######################################################################################

######################################################################################
## Etiqueta a±adida por el supervisor (pantalla YCONSPED0) 28/05/2020 14:46:29 (ZZD03)
######################################################################################
Subprog AM_YFACTN(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    [M:YPED0]YPAGA = 1
    Affzo [M:YPED0]YPAGA
  Endif
End

Subprog AM_YPAGA(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2
    [M:YPED0]YFACTN = 1
    Affzo [M:YPED0]YFACTN
  Endif
End


######################################################################################

