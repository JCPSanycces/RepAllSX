#<AdxTL>@(#)0.0.0.0 $Revision$ 
SUBPROG TEST()

Local   Char    SOCIETE    : # Code société ŕ clôturer
local Date    DAT_DEB      : # Date début période ŕ clôturer
local    Date    DAT_FIN      : # Date fin   période ŕ clôturer
local    Integer EXERCICE     : # No exercice ŕ clôturer
local    Integer PERIODE      : # No période de l'exercice ŕ clôturer
local    Integer TYPLED       : # Type référentiel
local    Libelle DER_PER      : # Derničre période de l'exercice NON/OUI
Variable Integer OK           : # Statut retour, 1=OK 0=Pas bon

Local Integer OK2, ERR
Local Libelle NIV_VALID       : # Niveau de validation requis pour rčglement
Local Libelle NIV_VALID2      : # Niv. de valid "supérieur" (gčre les modifs faites sur 1 transac)
Local Libelle NIV_VALID3      : # Niveau de validation "supérieur"
Local Integer NB_ANOM         : # Nbre anomalie ctl balance
Local Libelle TYPTRC          : # =2 : Trace exhaustive, <>2 trace réduite
Local Libelle OTRACE          : # =1 si trace déjŕ ouverte
Local Integer CAS

Local Char    DEVLED : # Devise référentiel
Local Char    COALED : # Code plan
Local Char    CODLED : # Code plan
Local Integer CPTGEN          : # Cpta géné NON/OUI
Local Integer CPTANA          : # Cpta ana  NON/OUI
Local Integer CPTEQL          : # Equilibre NON/OUI
Local Integer FLGAUT          : # Référentiel automatique NON/OUI
Local Libelle LEDTYPGEN       : # Type de référentiel du Référentiel général principal
Local Libelle LEDTYPANA       : # Type de référentiel du Référentiel analytique principal

If clalev([F:CPY])=0  : Local File COMPANY    [CPY]  : Endif
If clalev([F:GCM])=0  : Local File GACM       [GCM]  : Endif
If clalev([F:LED])=0  : Local File GLED       [LED]  : Endif
If clalev([F:COA])=0  : Local File GCOA       [COA]  : Endif

#Call LECLED(SOCIETE,TYPLED,CODLED,DEVLED) From CPTDIV
#Call LECTURE("LED",CODLED,"") From CONTOBJ
#Call LEDTYPAUT(SOCIETE,TYPLED,FLGAUT) From CPTDIV
#Call SETMAINREF(SOCIETE,LEDTYPGEN,LEDTYPANA) From CPTDIV

COALED = [F:LED]COA
CPTGEN = [F:LED]GEN
CPTANA = [F:LED]ANA
CPTEQL = [F:LED]BAL
CPTECH = (TYPLED=LEDTYPGEN)

TYPTRC=OK
OTRACE=(GTRACE<>"")
OK = 1

If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
Call LECTURE("CPY",SOCIETE,"") From CONTOBJ

#INFBOX mid$("~A1234567890",2,20)
If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif
If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif

Call LECTURE("CPY",SOCIETE,"") From CONTOBJ
SOCIETE='BKS'
Link [DAE] With [GAC]GAC0 = [F:DAE]ACC As [LNK]
Filter [LNK] Where [F:GAC]CUR<>"" & [F:GAC]CUR<>DEVLED & [F:DAE]CUR<>[F:GAC]CUR
& & [F:DAE]ACCDAT>=DAT_DEB & [F:DAE]ACCDAT<=DAT_FIN
& & [F:DAE]CPY=SOCIETE & [F:DAE]LEDTYP=TYPLED
INFBOX "ANTES DE ENTRAR AL FOR"
For [LNK]
  INFBOX [F:DAE]NUM
 # Devise de pičce, devise du compte
 Call ECR_TRACE("$CUR"-[F:DAE]TYP-[F:DAE]NUM-num$([F:DAE]LIN)-mess(86,115,1)+":"-[F:DAE]CUR-","
& -[F:GAC]ACC-mess(13,106,1)-[F:GAC]CUR,0) From GESECRAN
Next

Close Local File [DAE], [GAC]


END








