################################################################################
#**
#* Conexión al servidor FTP y descarga de fichero de XRT
#*!
Subprog DOWNLOADFILE()
  Local Char CURRDATETIME_STR
  Local Char FICHERO_BAT, FICHERO_CFG
  Local Char FILESOU(255), DESPATH(255)
  Local Integer SUCCESS
  ORIGEN_DOSSIER=filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER



  CURRDATETIME_STR=format$("D:YYYYMMDDhhmmss",datetime$)

  FICHERO_BAT= "IMPORTXRT_" + CURRDATETIME_STR
  #FICHERO_CFG = PFICHERO

  #YALIVE path fichero entrada

  #Creacion de fichero BAT
  Openo filpath([F:YTP]YPATHENTRADA,FICHERO_BAT, "bat",nomap)

  adxifs=';'
  adxirs = chr$(13) + chr$(10)

  Wrseq 'WinSCP.com /command "open ftps://5091:9qwrcPU9@sif.sagetreasurysaas.es:990 -implicit"  "get ""/'+[F:YTP]YBUZONFTP+'/*'+[F:YTP]YPREFIJOFTP+'*"" ""' + ORIGEN_DOSSIER + '\'+[F:YTP]YPATHENTRADA+
& '\*.*_XRT" "exit"'
  Openo

  System CHAINE= ORIGEN_DOSSIER + "\"+[F:YTP]YPATHENTRADA+"\" + FICHERO_BAT + ".bat"

  FILESOU = ORIGEN_DOSSIER + "\"+[F:YTP]YPATHENTRADA+"\" + FICHERO_BAT + ".bat"
  DESPATH = ORIGEN_DOSSIER + "\"+[F:YTP]YPATHPROCES+"\"

  Sleep 5

  #mover fichero .bat a la carpeta enviados
  ORIGEN = FILESOU
  DESTINO=DESPATH
  Call MOVE (ORIGEN,DESTINO,SUCCESS) From ORDSYS

  # traza

  Call ECR_TRACE("Ficheros "+[F:YTP]YCODFICHERO+" descargados de FTP en "+[F:YTP]YPATHENTRADA, 0) From GESECRAN

End

###############################################################################################
#**
#* Inserción de los registros de XRT en la tabla de X3
#*!
Subprog INSERT_XRT_X3()

  Local Char DIR(GDIMFIC), FILELIST(GDIMFIC)(1..100)
  Local Integer LNGTH
  Local Integer COUNT
  Local Char EFICHERO(200)
  DIR =filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER
  DIR = DIR + "\"+[F:YTP]YPATHENTRADA

  If !clalev([F:ATA]) : Local File ATABDIV [ATA] : Endif
  COUNT = 0

  Call SYSTEME2(adxmac(0), "lsadx"-DIR,"",LNGTH,FILELIST) From ORDSYS

  For I=3 To LNGTH
     #  Buscamos los ficheros con extensión .err
     If mid$(FILELIST(I),len(FILELIST(I))-3,4) = "_XRT" Then
        # Infbox "Fichero:" + FILELIST(I)
        # call sendmail2()
        #For A=0 To COUNT-1
          Call LEER_FICHERO_XRT(DIR , FILELIST(I))
        #Next
     Endif

  Next

End
#####################################################################################################
#**
#* Lectura fichero XRT
#*
#* @param PDIRECTORIO
#* @param PFICHERO
#*!
Subprog LEER_FICHERO_XRT(PDIRECTORIO, PFICHERO)

Local Char LDIRMPORT(250) : LDIRIMPORT = PDIRECTORIO
Local Char LFILE_R(200)   : LFILE_R = PDIRECTORIO + "\" + PFICHERO
#Infbox LFILE_R
#Local Char LFILE_R(200)   : LFILE_R = LDIRIMPORT + "ImportXRT.txt"  # para pruebas
Local Char CUENTA(10),FLUJO(6),IMPORTE(8),FECHAOPE(9),FECHAVAL(9),DESCRIPCION(35),REFERENCIA(11),CONTRAPAR(5)
#<ALI01> Nueva variable LID para recoger el id único enviado por XRT
Local Char LYIDXRT(100)
#<\ALI01>
Local Char PLANTA(3)
Local Char SENTIDO(2)
Local Clbfile INFO_ADICIONAL(1)
Local Integer LNUMEXP, LECOK, SUCCESS : Raz LNUMEXP, LECOK, SUCCESS
Local Char LFECHA(10), LHORA(10), DESPATH(200) : Raz LFECHA, LHORA
Local Char LAUX(255) # MAB
# si se lanza la tarea batch
#If !GSERVEUR Then
#  Call TEMPON("Proceso rellenado tabla") From GESECRAN
#  Call OUVRE_TRACE("Proceso rellenado tabla") From LECFIC
#Endif
# abrir tabla intermedia
Gosub ABRIR_TBL
# abrir fichero para lectura
Gosub OPEN_FILE_R
# si el fichero existe y contiene información
If filinfo(LFILE_R, 7) > 0 Then
  LECOK = 1
  Repeat
    # leer el archivo
    # Infbox "LEER ARCHIVO"
    # Rdseq CUENTA,FLUJO,IMPORTE,FECHAOPE,FECHAVAL,REFERENCIA,CONTRAPARTIDA,SENTIDO,DESCRIPCION Using [ZIMP_R]
    #<ALI01>
    #Rdseq CUENTA, FLUJO, IMPORTE, FECHAOPE, FECHAVAL, REFERENCIA, PLANTA, CONTRAPAR,SENTIDO,DESCRIPCION Using [ZIMP_R]
    Rdseq CUENTA, FLUJO, IMPORTE, FECHAOPE, FECHAVAL, REFERENCIA, PLANTA, CONTRAPAR,SENTIDO,DESCRIPCION, LYIDXRT Using [ZIMP_R]
    #<\ALI01>
#     Infbox "importe:" + vireblc(IMPORTE,2)
#     Infbox "fechaope:" + vireblc(FECHAOPE,2)
#     Infbox "fechaval:" + vireblc(FECHAVAL,2)
#     Infbox "referencia:" + vireblc(REFERENCIA,2)
#     Infbox "planta:" + vireblc(PLANTA,2)
#     Infbox "contrapar:"  +vireblc(CONTRAPAR,2)
#     Infbox "sentido:"  +vireblc(SENTIDO,2)
#     Infbox "DESCRIPCIÓN:"  +vireblc(DESCRIPCION,2)
#  Call ECR_TRACE("FICHERO:" + LFILE_R, 0) From GESECRAN
    If fstat = 0 Then
      If len(vireblc(CUENTA,0)) > 0 & len(vireblc(FLUJO,0)) > 0 & len(vireblc(IMPORTE,0)) > 0 & len(vireblc(PLANTA,0)) > 0 Then
        LNUMEXP += 1
        LECOK = 1
        [ZX]FCY         = vireblc(PLANTA,2)       # planta
        [ZX]CUENTA      = vireblc(CUENTA,2)       # cuenta XRT
        [ZX]FLUJO       = vireblc(FLUJO,2)        # flujo
        Call ECR_TRACE("Importe"-IMPORTE, 0) From GESECRAN
        [ZX]IMPORTE     = val(ctrans(IMPORTE,",","."))            # importe del movimiento
        [ZX]FECHAOPE    = vireblc(FECHAOPE,2)     # fecha operacion
        [ZX]FECHAVAL    = vireblc(FECHAVAL,2)     # fecha vaLor
        [ZX]REFERENCIA  = vireblc(REFERENCIA,2)   # referencia XRT
        [ZX]CONTRAPAR   = vireblc(CONTRAPAR,2)    # contrapartida
        [ZX]SENTIDO     = vireblc(SENTIDO,2)      # debe/haber
        #YALIVE eliminamos carácteres extrańos descripción
        Local Char TEXTO(50)
        TEXTO= vireblc(DESCRIPCION,2)
        Gosub FORMATO_TEXTO
        [ZX]DESCRIPCION = TEXTO
        #
        [ZX]STAXRT      = "1"                     # estado del registro (1=pendiente de procesar)
        #<ALI01>
        [ZX]YIDXRT      = vireblc(LYIDXRT,2)      # Id unico enviado por XRT
        [ZX]YFICH = LFILE_R                       # Fichero y ruta importada
        [ZX]YTRAZA = GTRACE                       # Fichero de traza, si está abierta
        #<\ALI01>
        Write [ZX]
      Endif
    Else
      LECOK = 0
    Endif
  Until LECOK = 0
Endif

Gosub CERRAR_TBL

Gosub CLOSE_FILE_R

# mueve el archivo a la carpeta de históricos
If filinfo(LFILE_R,7) > 0 Then
  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
  LHORA = vireblc(num$(time$),4) : LHORA = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)
  DESPATH = LDIRIMPORT+"\Procesados\" + PFICHERO + "_" + LFECHA+LHORA + ".csv"

  SUCCESS = renameFile(LFILE_R,DESPATH)

  Gosub ESCRIBIR_ZIMPFIC

Endif

# traza
Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
Call ECR_TRACE("Fichero: "+PFICHERO+" "+num$(LNUMEXP) + " registros guardados en tabla", 0) From GESECRAN
Call ECR_TRACE("-------------------------------------", 0) From GESECRAN

End
########################################################
$ESCRIBIR_ZIMPFIC


If !clalev([F:ZIF]) : Local File ZIMPFIC [ZIF] : Endif


Read [F:ZIF]ZIF0 = "X"+ LFECHA+LHORA
If fstat <> 0
  Raz [F:ZIF]
  [F:ZIF]ZIDGES   = "X"+ LFECHA+LHORA
  [F:ZIF]ZFECPROD = date$
#  [F:ZIF]ZMODELO  = "YCOM"
  [F:ZIF]ZMODELO  = [F:YTP]YCODFICHERO
  [F:ZIF]ZPATH    = LDIRIMPORT+ PFICHERO + "_" + LFECHA+LHORA + ".csv"
  [F:ZIF]ZNOMFIC  = PFICHERO
  [F:ZIF]ZNUMREG  = LNUMEXP

  Write [F:ZIF]
Endif


Return
#####################################################################################################
#**
#* Crear ficheros de Importación e importar
#* Lanza el IMPORT del TXT generado
#*!
Subprog IMPORTAR_DATOS_XRT()

#YALIVE 18-06-20
#Local Char LDIRMPORT(250) : LDIRIMPORT = "\IMP\XRT"
Local Char LDIRMPORT(250) : LDIRIMPORT = [F:YTP]YPATHENTRADA

Local Char LFILE_W(200) : LFILE_W = "generaMov_"+[F:YTP]YCODFICHERO
Local Char LDATLIN(50)(20)
Local Char LFECHA(10), LHORA(10) : Raz LFECHA, LHORA
Local Char LSEP(1) : LSEP = ";"  # LSEParador
Local Char LCRY(5), LFCY(15), LCTACTBLE(25), LCONTRAP(25), LCPY(10)
Local Char LTYP,LBLANCO,LPLANTA,LCRY,LCUR,LTRANSA
Local Char LCUENTA1,LCUENTA2,LCCT,LARS,LFAM,LDEP,LCDV
Local Char LCUENTA3,LCUENTA4,LCUENTA5,LCUENTA6, LFECHAOPE
Local Char LFCY
#<ALI01>
Local Integer LREP
If !clalev([F:YHAE]) : Local File GACCENTRY [YHAE] : Endif
#<\ALI01>


#> MA 22/06/2018 - cambiamos la forma de sacar la fecha
# LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
#
# LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,4)+mid$(LFECHA,5,2)+mid$(LFECHA,7,2)

#> MS 24/08/2018 - volvemos a calcular la fecha como originariamente, sino ponía LSEParadores
LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)

#< MA 22/06/2018
LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

#> MA 22/06/2018
#LFILE_W = LDIRIMPORT + LFILE_W + "_" + LFECHA+ LHORA + ".txt"
LFILE_W = LFILE_W + "_" + LFECHA + "_"+ LHORA
#< MA 22/06/2018

# si se lanza la tarea batch
#If !GSERVEUR Then
#  Call TEMPON("Proceso generación fichero importación") From GESECRAN
#  Call OUVRE_TRACE("Proceso generación fichero importación") From LECFIC
#Endif

######
# Estados del proceso
###
# 1 -> Pendiente
# 2 -> Listo para enviar
# 3 -> Importado
# 4 -> Error
######

## borramos el fichero si existe...
#If filinfo(LFILE_W, 7) > 0 Then
#  System "ae_rm " + LFILE
#Endif

# Sleep 3




# abrir la tabla para lectura
Gosub ABRIR_TBL
Filter [ZX] Where [ZX]STAXRT = "1"  and [ZX]FLUJO=[F:YTP]YFLUJO
#Read [ZX] First
# Infbox  num$(rowcount([ZX]))
If rowcount([ZX]) > 0 Then
  # abrir el fichero para escritura
  Gosub $OPEN_FILE_W
  For [ZX]
    Raz  LDATLIN
    # Call GET_CRY([ZX]CTAXRT,LCRY)
    # Call GET_FCY([ZX]CTAXRT,[ZX]REFXRT,[ZX]TXTXRT,LCRY,LFCY)
    # Call GET_CPY(LFCY,LCPY)
    #If LCRY = "SPA" Then : LDATLIN(1) = "ODGEN" : Else LDATLIN(1) = "ODG" : Endif
    LTYP =  [F:YTP]YTIPOASIENTO
    LBLANCO  = ""

    Gosub ACCESO_TIPOARCHIVO_SOCIEDAD
    LFCY    = [F:YTPS]YFCY
    #sección analítica
    Local Char YSECCION : Raz YSECCION
    Gosub OBTENER_SECCION
    #

    LFECHAOPE =   mid$(num$([ZX]FECHAOPE),7,4)+mid$(num$([ZX]FECHAOPE),4,2)+mid$(num$([ZX]FECHAOPE),1,2) # AAAAMMDD
    LCRY = "SPA"
    LDATLIN(6) = "" # CUENTA # right$([ZX]CUENTA,12)
    LCUR  = "EUR" # [ZX]DIVISA
    LTRANSA  = "STDCO"

    LCUENTA1 = [F:YTPS]YCUENTAFINAN
    LCUENTA2 = [F:YTPS]YCUENTAANAL

    If [ZX]FCY = "BKS" or [ZX]FCY="TIM"
      LCCT = "CCT"
      LARS = "ARS"
      LFAM = "FAM"
      LDEP = "DEP"
      LCDV = "CDV"
    Else
      LCCT = "CCT"
      LARS = "FAM"
      LFAM = ""
      LDEP = ""
      LCDV = ""
    Endif

    LCUENTA3 = [F:YTPS]YCUENTA3
    LCUENTA4 = [F:YTPS]YCUENTA4

    LCUENTA5 = "" # "191200"
    LCUENTA6 = "" # "111200"

    If LPLANTA = ""
       Call ECR_TRACE("ERROR - Registro sin Sección analítica", 1) From GESECRAN
    Endif

    Raz LREP

    If [F:YTPS]YIDUNICO = 2
      If vireblc([ZX]YIDXRT,2) <>'' and LPLANTA <>''
        Filter [F:YHAE] Where YIDXRT = [ZX]YIDXRT
        For [F:YHAE]
          LREP=1
          Call ECR_TRACE("ERROR - Registro ya integrado desde XRT. ID:" + [ZX]YIDXRT , 1) From GESECRAN
          Break
         Next
         Filter [F:YHAE]
      Endif
    Endif

    If LPLANTA <> "" and LREP = 0
      [ZX]STAXRT = "3"
      Call ECR_TRACE("Asiento generado en el fichero de importación",0 ) From GESECRAN
      Rewrite [ZX]
    Endif

    If LPLANTA <> ""  and LREP = 0 Then

# LINEA 1
#<ALI01>
#    Wrseq "G" + LSEP +
#&         LTYP + LSEP + LBLANCO + LSEP + LFCY + LSEP + LTYP + LSEP +
#&         LFECHAOPE + LSEP + LBLANCO + LSEP + LCUR + LSEP + LTRANSA + LSEP + [ZX]DESCRIPCION  Using [ZIMP_W]
    Wrseq "G" + LSEP +
&         LTYP + LSEP + LBLANCO + LSEP + LFCY + LSEP + LTYP + LSEP +
&         LFECHAOPE + LSEP + LBLANCO + LSEP + LCUR + LSEP + LTRANSA + LSEP + [ZX]DESCRIPCION + LSEP + [ZX]YIDXRT + LSEP + "2"  Using [ZIMP_W]

#<\ALI01>
#


   Gosub ESCRIBIR_LINEAS_DETALLE

   Endif # Control LPLANTA

  Next
  Gosub CLOSE_FILE_W

  If !GSERVEUR Then
#    Call TEMPOFF() From GESECRAN
    # fin de traza
    Call ECR_TRACE("Fichero " + ctrans(LFILE_W,"\","/") + " generado", 0) From GESECRAN
    Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
#    Call FERME_TRACE From LECFIC
    # lectura
#    Call LEC_TRACE From LECFIC
  Endif

Call EJECUTAR_IMPORT(filpath("IMP", LFILE_W, "txt",nomap))

Endif


Filter [ZX]
Gosub CERRAR_TBL

End
###########################################################
$ACCESO_TIPOARCHIVO_SOCIEDAD

#En el fichero que viene de XRT la sociedad POP la llaman PLK

If !clalev ([F:YTPS]) : Local File YTIPOFICHERO [YTPS] : Endif

Local Char YCPY : Raz YCPY

If [F:ZX]FCY = 'PLK'
  YCPY = 'POP'
Else
  YCPY = [F:ZX]FCY
Endif

Read [F:YTPS]YTP0 = YCPY;[F:YTP]YCODFICHERO


Return
###########################################################
$OBTENER_SECCION

If [F:YTP]YCODFICHERO='PDAT'
  Gosub BUSCAR_RESTAURANTE
Else
  Gosub OBT_SECCION
  LPLANTA = YSECCION
Endif


Return
###########################################################
$OBT_SECCION


#Si es ajuste la sección viene en la descripción, sino lo cogemos del fichero de
#parametrización
#Ajuste 6 primeros caracteres de la descripción a veces no ponen el cero o P delante

If !clalev ([F:YCCE]) : Local File CACCE [YCCE] : Endif

If [F:YTP]YCODFICHERO='PAJU'
  If mid$([F:ZX]DESCRIPCION,6,1)=''
    Local Char YCARACT : Raz YCARACT
    If [F:YTPS]YCPY = 'BKS'
      YCARACT = "0"
    Elsif [F:YTPS]YCPY = 'POP'
      YCARACT = "P"
    Elsif [F:YTPS]YCPY = 'TIM'
      YCARACT = "0"
    Endif

    Read [F:YCCE]CCE0 = 'CCT';YCARACT+mid$([F:ZX]DESCRIPCION,1,5)
    If fstat = 0
      YSECCION = [F:YCCE]CCE
    Endif
  Else
   Read [F:YCCE]CCE0 = 'CCT';mid$([F:ZX]DESCRIPCION,1,6)
    If fstat = 0
      YSECCION = [F:YCCE]CCE
    Endif
  Endif
Else
  YSECCION = [F:YTPS]YSECCION
Endif

Return
###########################################################
$ABRIR_TBL
If clalev([ZX]) = 0 : Local File ZXRT   [ZX] : Endif # tabla intermedia para conversión
Return

#########################################################
$CERRAR_TBL
Close Local File [ZX]
Return

########################################################
$OPEN_FILE_W

adxifs = ";"
adxirs = chr$(13)+chr$(10)
# Cambio carpeta a IMP, para que si se genera un Error, el proceso de Gestión de errores
# envie un correo.
# Openo filpath("IMP\XRT", LFILE_W, "txt",nomap) Using [ZIMP_W]

Openo filpath("IMP", LFILE_W, "txt",nomap) Using [ZIMP_W]
Return

########################################################
$CLOSE_FILE_W

Openo Using [ZIMP_W]

Return

########################################################
$OPEN_FILE_R

adxifs = "" # MAB. Se descomenta esta línea porque no se estaban leyendo los ficheros PACMAR-214
adxirs = chr$(13)+chr$(10)

#evitar errores por caracteres especiales, 50 ASCII, por defecto UTF8
adxium=50

Openi LFILE_R Using [ZIMP_R]

Return

########################################################
$CLOSE_FILE_R

Openi Using [ZIMP_R]

Return


########################################################
$ESCRIBIR_LINEAS_DETALLE

# LINEA 2
    Wrseq "D" + LSEP + "1" + LSEP + "1" + LSEP + "1" + LSEP +
&         LFCY + LSEP + LBLANCO + LSEP + LCUENTA1 + LSEP + LBLANCO + LSEP + [ZX]DESCRIPCION + LSEP +
&         "1" + LSEP + num$([ZX]IMPORTE) + LSEP + LCUR + LSEP + LBLANCO Using [ZIMP_W]
#LINEA 3
    Wrseq "D" + LSEP + "1" + LSEP + "2" + LSEP + "1" + LSEP +
&         LFCY + LSEP + LBLANCO + LSEP + LCUENTA2 + LSEP + LBLANCO + LSEP + [ZX]DESCRIPCION + LSEP +
&         "1" + LSEP + num$([ZX]IMPORTE) + LSEP + LCUR + LSEP + LBLANCO Using [ZIMP_W]
# LINEA 4
    Wrseq "A" + LSEP + "1" + LSEP + LCCT + LSEP + LPLANTA + LSEP +
&         LARS + LSEP + LBLANCO + LSEP + LFAM + LSEP + LBLANCO + LSEP +
&         LDEP + LSEP + LBLANCO + LSEP + LCDV + LSEP + LBLANCO + LSEP + num$([ZX]IMPORTE) Using [ZIMP_W]
# LINEA 5
    Wrseq "D" + LSEP + "1" + LSEP + "4" + LSEP + "1" + LSEP +
&         LFCY + LSEP + LBLANCO + LSEP + LCUENTA3 + LSEP + LBLANCO + LSEP + [ZX]DESCRIPCION + LSEP +
&         "1" + LSEP + num$([ZX]IMPORTE) + LSEP + LCUR + LSEP + LBLANCO Using [ZIMP_W]
# LINEA 6
    Wrseq "D" + LSEP + "1" + LSEP + "5" + LSEP + "1" + LSEP +
&         LFCY + LSEP + LBLANCO + LSEP + LCUENTA4 + LSEP + LBLANCO + LSEP + [ZX]DESCRIPCION + LSEP +
&         "1" + LSEP + num$([ZX]IMPORTE) + LSEP + LCUR + LSEP + LBLANCO Using [ZIMP_W]
# LINEA 7
    Wrseq "D" + LSEP + "2" + LSEP + "1" + LSEP + "2" + LSEP +
&         LFCY + LSEP + LBLANCO + LSEP + [ZX]CUENTA + LSEP + LBLANCO + LSEP + [ZX]DESCRIPCION + LSEP +
&         "-1" + LSEP + num$([ZX]IMPORTE) + LSEP + LCUR + LSEP + [ZX]REFERENCIA Using [ZIMP_W]
# LINEA 8

#En POP la cuenta 572 no tiene analítica
Local Char YCUENTA_AN : Raz YCUENTA_AN
If [F:YTPS]YCPY<> 'POP'
  YCUENTA_AN = [ZX]CUENTA
Endif


    Wrseq "D" + LSEP + "2" + LSEP + "2" + LSEP + "2" + LSEP +
&         LFCY + LSEP + LBLANCO + LSEP + YCUENTA_AN + LSEP + LBLANCO + LSEP + [ZX]DESCRIPCION + LSEP +
&         "-1" + LSEP + num$([ZX]IMPORTE) + LSEP + LCUR + LSEP + [ZX]REFERENCIA Using [ZIMP_W]
# LINEA 9
    Wrseq "A" + LSEP + "1" + LSEP + LCCT + LSEP + LPLANTA + LSEP +
&         LARS + LSEP + LBLANCO + LSEP + LFAM + LSEP + LBLANCO + LSEP +
&         LDEP + LSEP + LBLANCO + LSEP + LCDV + LSEP + LBLANCO + LSEP + num$([ZX]IMPORTE) Using [ZIMP_W]
# LINEA 10
    Wrseq "D" + LSEP + "2" + LSEP + "4" + LSEP + "2" + LSEP +
&         LFCY + LSEP + LBLANCO + LSEP + LCUENTA5 + LSEP + LBLANCO + LSEP + [ZX]DESCRIPCION + LSEP +
&         "-1" + LSEP + num$([ZX]IMPORTE) + LSEP + LCUR + LSEP + [ZX]REFERENCIA Using [ZIMP_W]
# LINEA 11
    Wrseq "D" + LSEP + "2" + LSEP + "5" + LSEP + "2" + LSEP +
&         LFCY + LSEP + LBLANCO + LSEP + LCUENTA6 + LSEP + LBLANCO + LSEP + [ZX]DESCRIPCION + LSEP +
&         "-1" + LSEP + num$([ZX]IMPORTE) + LSEP + LCUR + LSEP + [ZX]REFERENCIA Using [ZIMP_W]


Return
############################################################################################################################
#**
#* Buscar en la tabla FCYEXT por el codigo de datafono, a que restaurante pertenece el registro
#*!
$BUSCAR_RESTAURANTE
  If !clalev([F:ZEXT])  Then : Global File ZFCYEXT [ZEXT] : Endif
  Filter [F:ZEXT] Where  [F:ZEXT]ZFINRSPFCY = [ZX]FCY  and ([F:ZEXT]ZCODDATA1 =  [ZX]REFERENCIA  or [F:ZEXT]ZCODDATA2 = [ZX]REFERENCIA  or [F:ZEXT]ZCODDATA3 = [ZX]REFERENCIA)
  Read [F:ZEXT] First
  If !fstat Then
    LPLANTA = [F:ZEXT]ZFCY
  Else
    LPLANTA = ""
  Endif
  Filter [F:ZEXT]


Return

######################################################
$FORMATO_TEXTO
######################################################
#### CAMBIO DE LOS CARACTERES NO PERMITIDOS
######################################################
TEXTO=ctrans(TEXTO,"?","e")
TEXTO=ctrans(TEXTO,"Ą","Ń")
TEXTO=ctrans(TEXTO,"¤","ń")
TEXTO=ctrans(TEXTO,"Ş","a")
TEXTO=ctrans(TEXTO,"ş","o")
TEXTO=ctrans(TEXTO,"§","o")
TEXTO=ctrans(TEXTO,"¦","a")
TEXTO=ctrans(TEXTO,"ˇ","i")
TEXTO=ctrans(TEXTO,"˘","o")
TEXTO=ctrans(TEXTO,"Ł","u")
TEXTO=ctrans(TEXTO,"'"," ")
TEXTO=ctrans(TEXTO,"á","a")
TEXTO=ctrans(TEXTO,"é","e")
TEXTO=ctrans(TEXTO,"í","i")
TEXTO=ctrans(TEXTO,"ó","o")
TEXTO=ctrans(TEXTO,"ú","u")
TEXTO=ctrans(TEXTO,"Á","A")
TEXTO=ctrans(TEXTO,"É","E")
TEXTO=ctrans(TEXTO,"Í","I")
TEXTO=ctrans(TEXTO,"Ó","O")
TEXTO=ctrans(TEXTO,"Ú","U")
TEXTO=ctrans(TEXTO,"("," ")
TEXTO=ctrans(TEXTO,")"," ")

Return
##############################################################################################################################
#**
#*
#*!
Subprog EJECUTAR_IMPORT(PFILE)

Local Char PARAM(15)(1..4) , VALEUR(15)

Local Char FICHERO(100)  : FICHERO = PFILE

If clalev([M:IMP2])=0 : Local Mask IMPOBJ2 [IMP2] : Endif
[M:IMP2]MODIMP = "YCOM" #Modelo de importación
[M:IMP2]TYPEXP = 2          #El archivo está en el servidor

Call IMPORTSIL([M:IMP2]MODIMP,FICHERO) From GIMPOBJ

End

