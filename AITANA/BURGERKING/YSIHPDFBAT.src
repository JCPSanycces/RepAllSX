#<AdxTL>@(#)0.0.0.0 $Revision$ 

$ACTION
  Case ACTION
    When "INIT"        : Gosub INIT         # GTRAITE
    When "OUVRE_BATCH" : Gosub OUVRE_BATCH  # GTRAITE, GBATCH=1
    When "EXEC"        : Gosub EXEC
    When Default
      If [V]GBATCH and func COME_FROM_TRT("GSAISIE")=1
        Gosub ACTION From YSIHPDF
      Endif
  Endcase
Return

#------------------------------------------------------------------------------#

$INIT
  Gosub OUVRE From YSIHPDF
  If [V]GSERVEUR
    If clalev([M:YSIP])=0 : Local Mask YSIHPDF [YSIP] : Endif
  Endif
Return

#------------------------------------------------------------------------------#

$OUVRE_BATCH
  Gosub OUVRE From YSIHPDF
Return

#------------------------------------------------------------------------------#

$EXEC
  If [M:YSIP]NBLIG=0
    Gosub SEARCH From YSIHPDF
  Endif
  Gosub GENERATE From YSIHPDF
Return

#------------------------------------------------------------------------------#

Funprog COME_FROM_TRT(WTRT)
Value Char WTRT

  Local Integer WYIX, WFOUND, WLO, NAMTRT_INI, NAMTRT_FIN
  Local Char    NAMTRT(GLONADC)

  Raz WYIX, WFOUND
  If WTRT<>""
    While adxpno(WYIX)<>""
      # adxpno(n): @X3.TRT/SUBSDHC$adx
      WLO = len(adxpno(WYIX))
      While WLO>0
        If seg$(adxpno(WYIX), WLO, WLO)="/"  : NAMTRT_INI = WLO : Endif
        If seg$(adxpno(WYIX), WLO, WLO)="$"  : NAMTRT_FIN = WLO : Endif
        WLO -= 1
      Wend
      NAMTRT = seg$(adxpno(WYIX), NAMTRT_INI+1, NAMTRT_FIN-1)
      If NAMTRT = WTRT
        WFOUND = 1 : Break
      Endif
      WYIX += 1
    Wend
  Endif
End WFOUND

#------------------------------------------------------------------------------#




