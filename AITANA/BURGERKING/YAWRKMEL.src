#####################################################################################
# Fuente: YAWRKMEL : Punto de Entrada Mails Workflow
#------------------------------------------------------------------------------------
#
# <Y0000> Modificaciˇn 'From' en mails workflow
#####################################################################################
$ACTION
  Case ACTION
    When "EMAIL"  : Gosub EMAIL
  Endcase
Return
#####################################################################################
$EMAIL



Local Char YMAIL
Local Char YTEXOBJ(250)
If instr(1,TEXOBJ,"###") <> 0
  YMAIL = right$(TEXOBJ,instr(1,TEXOBJ,"###")+3)
  YTEXOBJ = left$(TEXOBJ,instr(1,TEXOBJ,"###")-1)
  TEXOBJ = YTEXOBJ
  EXP_MAIL = YMAIL
Endif
Return

