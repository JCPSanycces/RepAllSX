#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION

Case ACTION

  When "APRES_MOD" : Gosub APRES_MOD
  When "APRES_MODIF" : Gosub APRES_MODIF
  When "VERIF_CRE"  : Gosub VERIF_CRE
  When "AB_CREATION"  : Gosub AB_CREATION
  When Default
Endcase
Return

$APRES_MODIF
  Global Integer ZGNUMLIN
  # Infbox "Linea importe:"  + num$([M:BIS3]AMTNOTLIN(nolign-1))

  If COUZON = "NBLIG" Then
    ZGNUMLIN = nolign # Linea en la que estamos situados
    #Infbox num$([M:BIS3]NBLIG(nolign-1))
    # Infbox "Regs: " + num$(nolign) + " - Linea: " + num$(COUIND) + " Campo actual: " +COUZON + " - Valor: " + num$(CZ)
#    If nolign > NBLIG Then
#       # REGISTRO NUEVO
#       Gosub FAMILIAS_CAPEX
#    Endif
  Else
    ZGNUMLIN = -1
  Endif

Return

$APRES_MOD
# Recorrer todas la l璯eas, no solo en la que estamos
  Local Integer LINEA_ACTUAL

    #Infbox "APRES_MOD"
    If clalev([F:BPSL]) = 0 : Local File BPSINVLIGA [F:BPSL]  : Endif
    If clalev([F:ZBPSI]) = 0 : Local File ZBPSINVLIGA [F:ZBPSI]  : Endif

  LINEA_ACTUAL = 0
  For LINEA_ACTUAL = 0 To NBLIG-1
    # Buscar Distribuci鏮 personalizada en Tabla Z y si existe, actualizar la estandar
    #Infbox "Buscando" + [M:BIS0]NUM + " - " + [M:BIS0]FCY + " -> " + num$(LINEA_ACTUAL+1)
    Filter [ZBPSI] Where NUM = [M:BIS0]NUM and LIG = LINEA_ACTUAL+1
    #Read [ZBPSI]
    # Si existe - borrar la distribuci鏮 estandar y volver a grabarla
    # Infbox "Encontados: " + num$(rowcount([ZBPSI]))
    If rowcount([ZBPSI]) > 0 Then
      Trbegin BPSINVLIGA [BPSI]
      Delete [BPSI] Where NUM = [M:BIS0]NUM  and LIG = LINEA_ACTUAL+1
      #Infbox "Limpiados: " + num$(rowcount([BPSI]))
      If fstat = 0 Then
        For [ZBPSI]
          [F:BPSI] = [F:ZBPSI] # Inserto registro de Tabla Zxxx en Tabla estandar

          Write [BPSI]
          #Infbox "Grabado" + [M:BIS0]NUM + " - " + num$(LINEA_ACTUAL+1)
        Next
        If fstat = 0 Then
          Commit
        Else
          Rollback
          #Infbox "Rollbak:" + num$(fstat)
        Endif
      Else
        Rollback
      Endif
#    Else
#      Trbegin BPSINVLIGA [BPSI2]
#      Delete [BPSI2] Where NUM = [M:BIS0]NUM  and LIG = LINEA_ACTUAL+1
#      #Infbox "Limpiados: " + num$(rowcount([BPSI2]))
#      If fstat = 0 Then
#          Commit
#        Else
#          Rollback
#      Endif
    Endif
  Next
Return

######################################################################################
$VERIF_CRE

If !GIMPORT
  Gosub ACTION From SUBBIS

  If clalev([F:PIHB])   =0 Local File PINVOICE [F:PIHB] : Endif

  Local Integer ENCONTRADO : Raz ENCONTRADO

  Filter [F:PIHB] Where [F:PIHB]BPR= [M:BIS0]BPR and [F:PIHB]BPRDAT=[M:BIS1]BPRDAT and
&                     [F:PIHB]AMTATI=[M:BIS3]TOTATI
  For [F:PIHB]
     ENCONTRADO = 1
     Break 1
  Next
  Filter [F:PIHB]
  If ENCONTRADO = 1
    Local Integer WOK  : Raz WOK
    Local Char TEXTOERR(200)
    TEXTOERR ="Factura: "+[F:PIHB]NUM+" del mismo proveedor en misma fecha e importe"
    Call AVERTIR (TEXTOERR, WOK)From GESECRAN
    If WOK=1 OK=0 : GERR=1 : Return : Endif
  Endif

  GPE=1

Else
  Gosub VALIDAR_EXISTE_IMPORT

Endif

Return


######################################################################################
$VALIDAR_EXISTE_IMPORT
#
# validamos si existe la referencia de factura para ese proveedor y a隳 de fecha factura

Gosub ACTION From SUBBIS

If clalev([F:PIHB])   =0 Local File PINVOICE [F:PIHB] : Endif

Local Integer ENCONTRADO : Raz ENCONTRADO

Filter [F:PIHB] Where [F:PIHB]BPR= [M:BIS0]BPR and [F:PIHB]BPRVCR=[M:BIS1]BPRVCR and
&                     [F:PIHB]NUM<>[M]NUM
For [F:PIHB]
  If year([M:BIS1]BPRDAT) = year([F:PIHB]BPRDAT)
    ENCONTRADO = 1
    Break 1
  Endif
Next
Filter [F:PIHB]

If ENCONTRADO = 1
  GMESSAGE=mess(6,119,1)-[F:PIHB]NUM
  OK=0 : GERR=1 : Return
Endif

GPE=1

Return
######################################################################################
## Etiqueta a鎙dida por el supervisor (pantalla BIS3) 08/08/2018 13:07:11 (ADMIN)
######################################################################################
Subprog C_CCE1(VALEUR)
Variable Char    VALEUR()
  If VALEUR <> "" Then
    Call FAMILIAS_CAPEX(VALEUR)
  Endif

End


######################################################################################
Subprog FAMILIAS_CAPEX(PCENTRO)
  If clalev([F:ZEST]) = 0 : Local File ZESTSEC [F:ZEST]  : Endif
  Filter [F:ZEST] Where ZDIE = 'CCT' and ZCCE = PCENTRO and ZSOC = [M:BIS0]CPY Order By CREDATTIM Desc
  # Infbox num$(rowcount([F:ZEST]))
  Read [F:ZEST] First
  If !fstat Then
    [M:BIS3]CCE3(nolign-1) = [F:ZEST]ZESTSEC # EFE FAM
     If [F:ZEST]ZESTSEC = "APE" Then
       [M:BIS3]CCE6(nolign-1) = "MAN" # EJE FCT
       Affzo [M:BIS3]CCE6(nolign-1)
     Endif
  Endif
  Filter [F:ZEST]
  Close Local File [F:ZEST]
End


######################################################################################
$AB_CREATION
If clalev([F:PIH])=0 Local File PINVOICE [PIH] : Endif
If clalev([F:DUD])=0 Local File PINVOICE [DUD] : Endif

Read [PIH]PIH0 = [M:BIS0]NUM
Filter [DUD] Where NUM = [M:BIS0]NUM

For [DUD]
  [F:DUD]FLGPAZ = [F:PIH]PAZ
  Rewrite [F:DUD]
Next
Filter [DUD]

Return

