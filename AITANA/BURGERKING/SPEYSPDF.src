#------------------------------------------------------------------------------#

Subprog C_CODWRK(VALEUR)
Variable Char    VALEUR()
  If clalev([F:AWA])=0 : Local File AWRKPAR [AWA] : Endif

  Raz GERR, GMESSAGE
  Read [F:AWA]AWA0=VALEUR
  If fstat
    GMESSAGE = mess(107,75,1)
  Elsif [F:AWA]ENAFLG<>2
    GMESSAGE = VALEUR + ":" - mess(2,126,1)
  Elsif [F:AWA]TYPEVT<>2
    GMESSAGE = mess(15,6002,1)
  Elsif [F:AWA]CODEVT<>[M:YSPDF1]AOBCOD
    GMESSAGE = mess(16,6002,1) + "(" + [F:AWA]CODEVT + "<>" + [M:YSPDF1]AOBCOD + ")"
  Elsif instr(1,[F:AWA]OPERATION,"W")=0
    GMESSAGE = mess(17,6002,1)
  Elsif ([F:AWA]ENAMES<>2 and [F:AWA]ENASUI=2 and [F:AWA]ENAACT=2)

  Endif
  If GMESSAGE<>""
    GERR = 1 : mkstat = 2
  Endif
End

#------------------------------------------------------------------------------#

Subprog C_FILTRE(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>""
    Local Integer I , K , ER
    Local Char    CHAINE(80)

    Local File =[M:YSPDF1]TABFIL

    Default [F] , [V] , [L] , [S]
    Onerrgo ERREXP
    ER = 0
    K = evalue([L]VALEUR)
    Onerrgo
    If ER
      mkstat = 2 : End
    Endif
  Endif
End

$ERREXP
  # Expresión incorrecta
  ER = errn
  GMESSAGE = mess(37,124,1) + "\" + errmes$(ER) + "\" + errm
  ER=1
Resume

#------------------------------------------------------------------------------#

$CHK_FLD
  Onerrgo ERR_FILE
  Local File =[M:YSPDF1]TABFIL
  If !GERR
    If evalue("dim([F:" + [M:YSPDF1]ABRFIL + "]" + VALEUR + ")")<0
      GMESSAGE = VALEUR + ":" - mess(121,75,1)
      GERR = 1 : mkstat = 2
    Endif
  Endif
  Onerrgo
Return

$ERR_FILE
  GMESSAGE = errmes$(errn)+ "." - errm
  GERR = 1 : mkstat = 2
Resume

#------------------------------------------------------------------------------#

Subprog VERF_PARAM(PPARAM, PVAL, POK)
Value    Char    PPARAM
Value    Char    PVAL
Variable Integer POK

  Case PPARAM
    When "YAIMPDF"
      If PVAL<>""
        If clalev([F:AIM])=0 : Local File APRINTER [AIM] : Endif

        Read [F:AIM]AIM0=PVAL
        If fstat
          POK = 0 : GMESSAGE = PVAL + ":" - mess(23,100,1)
        Elsif [F:AIM]ENAFLG<>2
          POK = 0 : GMESSAGE = PVAL + ":" - mess(2,126,1)
        Elsif [F:AIM]PRT<>4
          POK = 0 : GMESSAGE = PVAL + ":" - mess(6,6002,1)
        Elsif [F:AIM]PRTFMT<>29
          POK = 0 : GMESSAGE =PVAL + ":" - mess(6,6002,1)
        Endif
      Endif
  Endcase
End




