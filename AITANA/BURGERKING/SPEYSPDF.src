#<AdxTL>@(#)0.0.0.0 $Revision$ Parametrización documentos PDF

$ACTION
  Case ACTION
    When "OUVRE"    : Gosub OUVRE
    When "CREATION" : Gosub CREATION
    When "MODIF"    : Gosub MODIF
  Endcase
Return

#------------------------------------------------------------------------------#

$OUVRE
  If clalev([F:AOB])=0 : Local File AOBJET [AOB] : Endif
  If clalev([F:ATB])=0 : Local File ATABLE [ATB] : Endif
  If clalev([F:ACV])=0 : Local File ACTIV  [ACV] : Endif
Return

#------------------------------------------------------------------------------#

$CREATION
  Gosub CREATE_FOLDER
Return

#------------------------------------------------------------------------------#

$MODIF
  Gosub CREATE_FOLDER
Return

#------------------------------------------------------------------------------#

$CREATE_FOLDER
  Local Char WVOL(GLONAVL), WYPATHPDF(255), DIRSEP(1)
  If clalev([F:AVL])=0 : Local File AVOLUME [AVL] : Endif

  # Volumen documentos adjuntos
  WVOL = func AFNC.PARAM("YVOLJOINT", "")
  If WVOL="" : Return : Endif
  Read [F:AVL]CODE=WVOL
  If fstat : Return : Endif

  Case GOS(1)
    When "dos"   : DIRSEP = "\"
    When Default : DIRSEP = "/"
  Endcase
  WYPATHPDF = func ASYRSTO.GETFULLPATH(WVOL, "")
  If right$(WYPATHPDF, len(WYPATHPDF))<>DIRSEP
    WYPATHPDF += DIRSEP
  Endif

  WYPATHPDF += [F:YSPDF]CODE
  If filinfo(WYPATHPDF,0)<0
    Call SYSTEME(adxmac(0), 'ae_mkdir "' + WYPATHPDF + '"', "", I) From ORDSYS
  Endif
Return

#------------------------------------------------------------------------------#

Subprog AM_AOBCOD(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>""
    Read [F:AOB]ABREV = VALEUR
    If fstat
      GMESSAGE = VALEUR + ":" - mess(16,123,1)
      GERR = 1 : mkstat = 2
    Elsif [F:AOB]CODACT<>""
      Read [F:ACV]CODACT = [F:AOB]CODACT
      If fstat or [F:ACV]FLACT<>2
        GMESSAGE = VALEUR + ":" - mess(125,133,1) - "(" + [F:AOB]CODACT + ")"
        GERR = 1 : mkstat = 2
      Endif
    Endif
    If !mkstat
      Read [F:ATB]CODFIC = [F:AOB]NOMFIC
      If fstat
        GMESSAGE = [F:AOB]NOMFIC + ":" - mess(17,123,1)
        GERR = 1 : mkstat = 2
      Elsif [F:ATB]CODACT<>""
        Read [F:ACV]CODACT = [F:ATB]CODACT
        If fstat or [F:ACV]FLACT<>2
          GMESSAGE = [F:AOB]NOMFIC + ":" - mess(126,133,1) - "(" + [F:ATB]CODACT + ")"
          GERR = 1 : mkstat = 2
        Endif
      Endif
    Endif
    If !mkstat
      [M:YSPDF1]TABFIL = [F:ATB]CODFIC
      [M:YSPDF1]ABRFIL = [F:ATB]ABRFIC
      Case [F:AOB]MODULE
        When 5       : [M:YSPDF1]BPRTYP = 1
        When 6       : [M:YSPDF1]BPRTYP = 2
        When Default : [M:YSPDF1]BPRTYP = 1
      Endcase
      Affzo [M:YSPDF1]BPRTYP
    Endif
  Endif
End

#------------------------------------------------------------------------------#

