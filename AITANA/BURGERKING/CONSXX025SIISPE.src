$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif

Infbox (ACTION)

Case ACTION
 When Default
Endcase
Return


######################################################################################
Subprog AM_ZCANARIAS(VALEUR)    # 28/01/2019 - MS - BURKING-140
Variable Integer VALEUR
Local Integer LCON

# con esta instrucciÛn coseguimos que limpie la selecciÛn
Call AM_AFTMODCPYFCY([M]CPY) From XX025TRTSII

######################################################################################
# provisional hasta solucinar el filtrado de pantalla de registros de Canarias
# -MS- 30/01/2019
If VALEUR = 2 Then
  [M:XSII]VCRSTA = 1  : Grizo [M:XSII]VCRSTA
  [M:XSII]STAALL = 1  : Grizo [M:XSII]STAALL
Endif
######################################################################################

End
######################################################################################


######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla XX025SII) 30/01/2019 13:55:39 (ADMIN)
######################################################################################
Subprog AM_VCRSTA(VALEUR)
Variable Integer VALEUR

# con esta instrucciÛn coseguimos que limpie la selecciÛn
Call AM_AFTMODCPYFCY([M]CPY) From XX025TRTSII

If VALEUR > 1 Then
  [M:XSII]ZCANARIAS = 1
  Affzo [M:XSII]ZCANARIAS

  #CHMEN -= "E"

      If 1 = 2 Then
       If !clalev ([ZDVS])   : Local File DCLVATSPA    [ZDVS]    : Endif
          Local Integer LCON
          #Facturas Emitidas
          For LCON = 0 To [M:XSIIE]NBLIG-1
            Filter [F:ZDVS] Where NUM = [M:XSIIE]VCRNUM(LCON)
            If [F:ZDVS]ZSIISEND = "CAN"
              Infbox("DENTRO")
              Grizo [M:XSIIE]NBLIG(LCON)
            Endif
            Filter [F:ZDVS]
          Next
     Endif

Endif
End

######################################################################################

