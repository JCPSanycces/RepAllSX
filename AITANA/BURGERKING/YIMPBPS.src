######################################################################
# IMPBPS : Import / Export des Fournisseurs                          #
######################################################################

$ACTION
Case ACTION
 When "IMP_OUVRE"     : Gosub OUVRE
 When "IMPORT"        : Gosub IMPORT
 When "IMP_ZONE"      : Gosub IMP_ZONE
 When "IMP_TAB"       : Gosub IMP_ZONE
 When "IMP_CREATION"  : Gosub CREATION
 When "IMP_RAZCRE"    : Gosub IMP_RAZCRE  # FGR 20/04/2010 : X3SUIVI64097
 When "IMP_MODIF"     : Gosub MODIF
 When "EXP_OUVRE"     : Gosub EXP_OUVRE
 When "EXPORT"        : Gosub EXPORT
 When "EXP_ZONE"      : Gosub EXP_ZONE    # FGR 10/02/2010 : X3SUIVI59669
 When "IMP_FERME"     : Gosub IMP_FERME   # FGR 15/11/2010 : X3SUIVI68928
 When "AP_IMPORT"     : Gosub AP_IMPORT   # FGR 15/11/2010 : X3SUIVI68928
Endcase
Return

#######################################################################
#                        IMPORT
#######################################################################

$OUVRE
If !clalev([F:BPR2])  Local File BPARTNER [BPR2]  : Endif  # FGR 17/12/2010 : X3SUIVI69959

Global Char GSTBFIC(GLONABR)(dim([M:IMP2]ABREV))   # FGR 15/11/2010 : X3SUIVI68928
Global Char GLASTFLGREC(10)                        # FGR 15/11/2010 : X3SUIVI68928

Local Char CORFIC (10)
CORFIC="BPADDRESS" : Gosub IMP_CORRESP From TRTX3IMP
CORFIC="CONTACT"   : Gosub IMP_CORRESP From TRTX3IMP

Gosub OUVRE_TEXTE

Return

#######################################################################
$IMP_FERME
  # FGR 15/11/2010 : X3SUIVI68928 (début)
  If dim(GSTBFIC) > 0 Then
    Kill GSTBFIC
  Endif
  If dim(GLASTFLGREC) > 0 Then
    Kill GLASTFLGREC
  Endif
  # FGR 15/11/2010 : X3SUIVI68928 (fin)
Return

#######################################################################
$AP_IMPORT
  # FGR 15/11/2010 : X3SUIVI68928 (début)
  Case IMPFIC
    When "BPR", "BPS"
      Local Integer I
      Local Integer K

      If SEPNUM > 0 Then
        #MAE, bg 76694
        #If GLASTFLGREC <> [M:AOE1]FLGREC(SEPNUM-1) Then
        #  GLASTFLGREC = [M:AOE1]FLGREC(SEPNUM-1) # Optimisation pour ne le refaire que si nécessaire
        #  Raz GSTBFIC
          K = 0
          For I = 0 To [M:IMP2]NBFIC-1
            If [M:IMP2]FLG(I) = [M:AOE1]FLGREC(SEPNUM-1) Then
            If !find([M:IMP2]ABREV(I),GSTBFIC(0..dim(GSTBFIC)-1))
              GSTBFIC(K) = [M:IMP2]ABREV(I)
            Endif
              If GSTBFIC(K) = "BPR" Then
                # FGR 17/12/2010 : X3SUIVI69959 : On planque la classe [F:BPR]
               [F:BPR2] = [F:BPR]
              Endif
              K += 1
            Endif
          Next I
        Endif
      #Endif
    When Default
  Endcase
  # FGR 15/11/2010 : X3SUIVI68928 (fin)
Return

#---------------------------------------------------------------------
$OUVRE_TEXTE

Gosub DECLARE_TEXTE From TRTX3IMP

Case ACTION
  When "IMP_OUVRE"    : G_IMPORT=1
  When "EXP_OUVRE"    : G_EXPORT=1
Endcase

#   textes BPSUPPLIER : fournisseurs         ( texte ent cde *71 ŕ *78   texte retour *81 ŕ *88 )
TSTCHAMP(31)="BPS*71" : TSTCHAMP(32)="BPS*72" : TSTCHAMP(33)="BPS*73" : TSTCHAMP(34)="BPS*74"
TSTCHAMP(35)="BPS*75" : TSTCHAMP(36)="BPS*76" : TSTCHAMP(37)="BPS*77" : TSTCHAMP(38)="BPS*78"
TSTCHAMP(41)="BPS*81" : TSTCHAMP(42)="BPS*82" : TSTCHAMP(43)="BPS*83" : TSTCHAMP(44)="BPS*84"
TSTCHAMP(45)="BPS*85" : TSTCHAMP(46)="BPS*86" : TSTCHAMP(47)="BPS*87" : TSTCHAMP(58)="BPS*88"

Gosub OUVRE_TEXTE From TRTX3IMP

Return

#######################################################################
$CREATION
Return

#######################################################################
$MODIF
Return

#######################################################################
$IMP_RAZCRE

  # FGR 20/04/2010 : X3SUIVI64097
  Raz [F:BPS]
  Raz [F:BPR]
Return

#######################################################################
#--- Lecture d'un enregistrement
$IMPORT

Local Integer NOL
Gosub IMP_DECLARE From TRTX3IMP

Case IMPFIC
    When "BPS" :
# ---------------------------------------------------#
#     Fournisseur                                    #
# ---------------------------------------------------#
        Local Integer WNBELEMENT,OKCHAMP, I
        Local Char    NOMCHAMP(30)

        For I=0 To dim([F:BPS]INVDTA)-1
            NOMCHAMP = "INVDTA("+num$(I)+")"
            Call TST_CHAMP("BPS",NOMCHAMP,OKCHAMP) From SUBIMPOBJ
            If OKCHAMP & evalue("[F:BPS]"+NOMCHAMP) <> 0
#               La ligne a été paramétrée
                WNBELEMENT +=1
            Elsif [M:BPS1]INVDTA(I) <> 0
                WNBELEMENT +=1
            Endif
        Next
        [M:BPS1]NBELEMENT = WNBELEMENT

        [M:BPS0]YLOGPROV = [F:BPS]YLOGPROV
        [M:YBPS6]YRESTAURAN = [F:BPS]YRESTAURAN
        [M:YBPS6]YSUPTYP = [F:BPS]YSUPTYP
        [M:YBPS6]YCCT = [F:BPS]YCCT

        #CARGAR DEPARTAMENTOS
        If dim([F:BPS]YDEPTBK)>0 Then
          For I=0 To dim([F:BPS]YDEPTBK)-1
            If [F:BPS]YDEPTBK(I) <> '' Then
              [M:YBPS6]YDEPTBK(I) = [F:BPS]YDEPTBK(I)
            Endif
          Next
        Endif

        #CARGAR ZONAS
        If dim([F:BPS]YZONA)>0 Then
          For I=0 To dim([F:BPS]YZONA)-1
            If [F:BPS]YZONA(I) <> '' Then
              [M:YBPS6]YZONA(I) = [F:BPS]YZONA(I)
            Endif
          Next
        Endif
    When "BPA" :
# ---------------------------------------------------#
#     Adresse                                        #
# ---------------------------------------------------#
#        Default Mask [BPAS]
        #MAE/FGR, bg 71813
        Call NEW_TEL_EMAIL("[F:BPA]") From IMPBPC
        ICLEPRIM (0) = "[F:BPA]BPAADD"
        TPRIM (0) = "CODADR"
        NBASTAB = "NBADR"
        Gosub RECHERCHE_LIGNE From TRTX3IMP
#       C'est une nouvelle ligne
        If nolign=0
            NOL=[M]NBADR
            [M]XNUMLIG = NOL
            nolign=NOL+1
            [M]NBADR+=1
        Else
            [M]XNUMLIG=nolign-1
        Endif
    When "CNT" :
# ---------------------------------------------------#
#     Contact                                        #
# ---------------------------------------------------#
#        Default Mask [CNTS]
#LSE 09/09/2005
#        ICLEPRIM (0) = "CCRCRM"
        ICLEPRIM (0) = "CCNCRM"
        NBASTAB = "NBCNT"
        Gosub RECHERCHE_LIGNE From TRTX3IMP
#       C'est une nouvelle ligne
        If nolign=0
            NOL=[M]NBCNT
            [M]KNOLIG = NOL
            nolign = NOL + 1
            [M]NBCNT+=1
        Else
            [M]KNOLIG=nolign-1
        Endif
    When "BID" :
# ---------------------------------------------------#
#     Rib                                            #
# ---------------------------------------------------#
#        Default Mask [BIDS]
#        ICLEPRIM (0) = "BIDNUM"
#        ICLESEC (0)  = "BPAADD"  # FGR 27/08/2010 : X3SUIVI66884
        #MAE, le 08/10/2010, bg66884
        ICLEPRIM (0) = "[F:BID]BIDNUM"
        ICLESEC (0)  = "[F:BID]BPAADD"  # FGR 27/08/2010 : X3SUIVI66884
        TPRIM (0) = "BIDNUM"
        TSEC (0) = "BIDBPAADD"          # FGR 27/08/2010 : X3SUIVI66884
        NBASTAB = "NBRIB"

        Gosub RECHERCHE_LIGNE From TRTX3IMP
Endcase

Gosub IMPORT_TEXTE

Return

#---------------------------------------------------------------------
$IMPORT_TEXTE
Case IMPFIC
     When "BPS"
          If G_TX11     : # --- Texte commande ---
             Gosub IMP_T1 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
             If G_CLE_CLOB<>"" : [M:BPS1]ORDTEX=G_CLE_CLOB : [M:BPS1]WORDTEX=2 : Endif
          Endif
          If G_TX12     : # --- Texte retour facture ---
             Gosub IMP_T2 From TRTX3IMP : Gosub ECR_TEXTE From TRTX3IMP
             If G_CLE_CLOB<>"" : [M:BPS1]RTNTEX=G_CLE_CLOB : [M:BPS1]WRTNTEX=2 : Endif
          Endif
Endcase
Return

#######################################################################
$IMP_ZONE
Local Char     IMPZONFIC(30) : IMPZONFIC =""
Local Char     IMPZONMSK(30) : IMPZONMSK =""
Local Integer  IINDICE       : IINDICE=0
Local Integer  IXZ

Case IMPFIC
    When "BPS","BPR" :
# ---------------------------------------------------#
#     Fournisseur et Tiers                           #
# ---------------------------------------------------#
# ---------------------------------------------------#
#     Deux fichiers sont concernés [BPS] et [BPR]    #
#     Il faut rechercher l'abréviation fichier       #
# ---------------------------------------------------#
# ---   Masque identité : Fichier BPARTNER
        # FGR 11/02/2010 : X3SUIVI59669 : Seul le commentaire a été ajouté ici
        # Note FGR : si on veut que dans l'import l'écran BPRBPC y figure, il faut
        # Modifier l'objet BPS pour ajouter dans import "BPCUSTOMER / BPRBPS".
        # FGR 15/11/2010 : X3SUIVI68928 (début)
        #If IMPMSK = "BPRBPS"
        #    IMPFIC = "BPR"
        #Else
        #    IMPFIC = "BPS"
        #Endif
        Gosub TRT_IMP_ZONE
        # FGR 15/11/2010 : X3SUIVI68928 (fin)
        Case IMPZON
            When "WORDMINAMT","WOSTAUZAMT" :
#                Montants a convertir dans la devise dossier
                IMPZONFIC = mid$(IMPZON,2,19)
                IMPZONMSK=IMPZON
        Endcase
    When "BPA" :
# ---------------------------------------------------#
#     Adresse                                        #
# ---------------------------------------------------#
        Gosub IMP_ZON_BPA From TRTX3IMP
    When "CNT","AIN" :
# ---------------------------------------------------#
#     Contact                                        #
# ---------------------------------------------------#
        Gosub IMP_ZON_CNT From TRTX3IMP
   When "BID" :
# ---------------------------------------------------#
#     Rib                                            #
# ---------------------------------------------------#
        Gosub IMP_ZON_BID From TRTX3IMP
Endcase

If IMPZONFIC <> "" & IMPZONMSK <> ""
#       On recherche si la zone est paramétrée
        If IINDICE <> 0
#           Zone indicée
            I = find(IMPFIC-IMPZONFIC+"("+num$(indice)+")",[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
            If I <> 0 IMPZONFIC = IMPZONFIC + "("+num$(indice)+")" : Endif
        Endif
        If IINDICE = 0 | IINDICE = 1 & I = 0
#           Zone non indicée ou zone indicée de 0 non trouvée
            I = find(IMPFIC-IMPZONFIC,[M:AOE2]ZONE(0..[M:AOE2]NBRLIG-1))
        Endif

        If I <> 0
#           On charge la classe [M]
#           Cas spécial : Ecran adresse et contact                                      #
#           Il faut passer systématiquement en AM_ pour charger le tableau invisible    #
#           męme si la zone n'a pas changée                                             #
            If find(IMPFIC, "BPA", "CNT") IMPMOD = 1 Endif
            # FGR 23/10/2009 : X3SUIVI56028(début)
            If IMPFIC = "BPA" and IMPZONFIC = "CTY" Then
              If evalue (IMPZONMSK) <> evalue ("[F:"+IMPFIC+"]"+IMPZONFIC) and evalue ("[F:"+IMPFIC+"]"+IMPZONFIC) <> "" Then
                IMPMOD=1
                Assign IMPZONMSK With evalue ("[F:"+IMPFIC+"]"+IMPZONFIC)
              Endif
            Else
              If evalue (IMPZONMSK) <> evalue ("[F:"+IMPFIC+"]"+IMPZONFIC)
                IMPMOD=1
                Assign IMPZONMSK With evalue ("[F:"+IMPFIC+"]"+IMPZONFIC)
              Endif
            Endif
            # FGR 23/10/2009 : X3SUIVI56028 (fin)
        Else #MAE/FGR, bg 71813
          Gosub IMP_ZONE_TELMAIL From IMPBPC
        Endif
        OK=0
Endif

Return

#------------------------------------------------------------------
# Traitements de IMP_ZONE et IMP_TAB
#------------------------------------------------------------------
# FGR 15/11/2010 : X3SUIVI68928 (début)
$TRT_IMP_ZONE
  Case IMPFIC
    When "BPR", "BPS"
      #----------------------------------------------------------#
      # Entęte facture : Déterminer la bonne abréviation fichier #
      #----------------------------------------------------------#
      Local Integer I
      Local Char SZSIHFIC(50)

      If find("BPR", GSTBFIC(0..dim(GSTBFIC)-1)) <> 0 Then
        # FGR 17/12/2010 : X3SUIVI69959 : Si BPR est dans le bloc, on restaure la classe [F:BPR]
        [F:BPR] = [F:BPR2]
      Endif
      I = find(IMPZON,[M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
      If I = 0 Then
        I = find(IMPZON+"(0)",[M:AOE2]FLD(0..[M:AOE2]NBRLIG-1))
      Endif
      If I <> 0 Then
        SZSIHFIC = left$([M:AOE2]ZONE(I-1),3)
        If find(SZSIHFIC, GSTBFIC(0..dim(GSTBFIC)-1)) <> 0 and find(SZSIHFIC, "BPR", "BPS") <> 0 Then
          IMPFIC = SZSIHFIC
        Else
          If IMPFIC = SZSIHFIC and find(SZSIHFIC, "BPR", "BPS") <> 0 Then
            # Si la zone détectée est sur un fichier et qu'il ne fait pas parti de ce qui est importé,
            # on passe sur l'autre pour éviter des erreurs.
            If IMPFIC = "BPR" Then
              IMPFIC = "BPS"
            Else
              IMPFIC = "BPR"
            Endif
          Endif
        Endif
      Endif
  Endcase
Return
# FGR 15/11/2010 : X3SUIVI68928 (fin)

#######################################################################
#                        EXPORT
#######################################################################

$EXP_OUVRE
Gosub OUVRE_TEXTE
Return

#######################################################################

$EXPORT
Raz G_CLE_CLOB, G_ZON_CLOB

Case EXPFIC

  When "BPS"
    If G_TX11
       Gosub EXP_RAZ_T1 From TRTX3IMP
       If dim([F:BPS]ORDTEX)>0 & [F:BPS]ORDTEX<>""
          G_CLE_CLOB=[F:BPS]ORDTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T1 From TRTX3IMP
       Endif
    Endif
    If G_TX12
       Gosub EXP_RAZ_T2 From TRTX3IMP
       If dim([F:BPS]RTNTEX)>0 & [F:BPS]RTNTEX<>""
          G_CLE_CLOB=[F:BPS]RTNTEX : Gosub EXP_TEXTE From TRTX3IMP : Gosub EXP_T2 From TRTX3IMP
       Endif
    Endif

Endcase

Return

#######################################################################
$EXP_ZONE
Local Char SZABREXPZON(10)

  # FGR 10/02/2010 : X3SUIVI59669
  Case EXPFIC
    When "BPS"
      SZABREXPZON = left$(EXPZON, 7)  # [F:BPS]
      #MAE, bug 100060, si export d'une zone BPR, relecture du fichier BPR pour ętre sure d'ętre sur le bon
      If SZABREXPZON = "[F:BPS]" or SZABREXPZON = "[F:BPR]" Then
        If [F:BPS]BPSNUM <> [F:BPR]BPRNUM Then
          Read [BPR]BPR0=[F:BPS]BPSNUM
          If fstat Then
            Raz [F:BPR]
          Endif
        Endif
      Endif
    When Default
  Endcase
Return

#######################################################################
# Utilisation de l'instruction setmode --> suppression affichage
# avant le call SAIMSK et SAI_NBLIG
# pour afficher des infbox dans IMP_ZONE et IMP_TAB
# utiliser Setmode_off Setmode_on
# ( pour afficher : Gosub SETMODE_OFF en debut de IMP_ZONE ou IMP_TAB )
#######################################################################
$SETMODE_OFF
Setmode
Return

$SETMODE_ON
Setmode GNBAFF, GAFFCOD, GAFFMASK, GAFFCHP, GAFFIND, GAFFTXT, GAFFRANG, GAFFOPT1, GAFFOPT2
Return
#######################################################################







