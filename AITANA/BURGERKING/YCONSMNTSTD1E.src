#<AdxTL>@(#)0.0.0.0 $Revision$
####################################################################################
$CARGAR_ENTRADAS



Filter [F:YZIF] Where evalue(WFIL3) and evalue(WFIL4)
For [F:YZIF]ZIF1
  Raz [F:YTMO]
  NUMREG             += 1
  [F:YTMO]PRONUM      = adxuid(1)
  [F:YTMO]YNUMREG     = NUMREG
  [F:YTMO]YCPY        = "BKS"

  Local Char YTIPOFICHERO : Raz YTIPOFICHERO
  Gosub OBTENER_TIPO_FICHERO
  [F:YTMO]YTIPOFICHERO= YTIPOFICHERO

  [F:YTMO]YNOMFICX3   = [F:YZIF]ZNOMFIC
  [F:YTMO]YNOMFICEXT  = [F:YZIF]ZNOMFIC
  [F:YTMO]YFECHAOP    = [F:YZIF]ZFECPROD
  [F:YTMO]YHORAOP     = mid$([F:YZIF]ZIDGES,10,6)
  [F:YTMO]YNUMLINX3   = [F:YZIF]ZNUMREG
  [F:YTMO]YNUMLINEXT  = [F:YZIF]ZNUMREG

  Local Integer YSTATUS : Raz YSTATUS
  Local Char YPATH(100) : Raz YPATH

  Gosub OBTENER_YSTATUS_ENTRADAS
  [F:YTMO]YSTATUS  = YSTATUS
  [F:YTMO]YPATH    = YPATH

  If YTIPOFICHERO >= [M:YCMNT0]YTIPOINI and YTIPOFICHERO <= [M:YCMNT0]YTIPOFIN
    If YSTATUS >= [M:YCMNT0]YSTATUSINI and YSTATUS <= [M:YCMNT0]YSTATUSFIN
      Write [F:YTMO]
    Endif
  Endif
Next
Filter [F:YZIF]

Return
####################################################################################
$OBTENER_YSTATUS_ENTRADAS
#1 tratado     en carpeta procesado
#2 pendiente   en carpeta imp
#3 error       en carpeta error
#4 no tratado  no estį en ninguna carpeta

#Tipo de fichero : donde estįn los paths
If !clalev ([F:YTP]) : Local File YTIPOFICHERO [YTP] : Endif

Read [F:YTP]YTP0 = [F:YTMO]YCPY;[F:YTMO]YTIPOFICHERO

Local Char ORIGEN_DOSSIER(250)
ORIGEN_DOSSIER=filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER

Local Char NOMBRE_FICHERO(250)
NOMBRE_FICHERO = [F:YZIF]ZNOMFIC+ ".csv"

Local Char PATH_PROCESADO(250)
PATH_PROCESADO=  ORIGEN_DOSSIER+"\"+[F:YTP]YPATHPROCES

Local Char PATH_ERROR(250)
PATH_ERROR=  ORIGEN_DOSSIER +"\"+ [F:YTP]YPATHERRORES

Local Char PATH_PENDIENTE(250)
PATH_PENDIENTE=  ORIGEN_DOSSIER+ "\"+[F:YTP]YPATHENTRADA

#inicializamos como no tratado
YSTATUS = 4

#comprobamos si estį en la carpeta procesado

If filinfo(PATH_PROCESADO+"\"+NOMBRE_FICHERO,7) >=0
  YSTATUS=1
  YPATH=PATH_PROCESADO
Endif

#comprobamos si estį pendiente

If filinfo(PATH_PENDIENTE+"\"+NOMBRE_FICHERO,7) >=0
  YSTATUS=2
  YPATH=PATH_PENDIENTE
Endif

#comprobamos si estį en error

If filinfo(PATH_ERROR+"\"+NOMBRE_FICHERO,7) >=0
  YSTATUS=3
  YPATH=PATH_ERROR
Endif

Return
####################################################################################
$OBTENER_TIPO_FICHERO

#Comisión datįfono modelo import 'YCOM'

If  [F:YZIF]ZMODELO = 'YCOM'
  YTIPOFICHERO= 'PDAT'
Endif

Return

