#<AdxTL>@(#)0.0.0.0 $Revision$ Extractos de gastos
$ACTION
# NOTAS DE GASTO
#  Infbox ACTION
  Case ACTION
    When "FIN_MOD1" : Gosub $FIN_MOD
    When "TERMINE1" : Gosub $TERMINE
    When "VERIF_MOD1" : Gosub $VERIF_MOD
    When Default
  Endcase
  Return


$TERMINE

   Local Char ZDATETIME
   Local Char LNOMBRE_FICHERO

  Infbox "DENTRO DE TERMINE"

   If clalev([F:EXS]) = 0 : Local File EXPENSES [F:EXS]  : Endif

   Filter [F:EXS] Where instr(1,ZCIF, "~") = 1

   For [F:EXS]
      ZDATETIME = time$
      ZDATETIME = mid$(ZDATETIME,1,2)+mid$(ZDATETIME,4,2)+mid$(ZDATETIME,7,2)
      ZDATETIME = date$+ZDATETIME
      LNOMBRE_FICHERO = "FICNG_"+ZDATETIME
      Call CREAR_FACTURA(LNOMBRE_FICHERO) From ZSPEIMPEXS
      Call CREAR_JOB(LNOMBRE_FICHERO, 'XBIS2') From ZSPEIMPEXS
      #Call IMPORTSIL("XBIS2", filpath("IMP", LNOMBRE_FICHERO, "csv",nomap)) From GIMPOBJ
   Next

   Update [F:EXS] Where instr(1,ZCIF, "~") = 1 With ZSTATUS = '1', ZCIF = mid$(ZCIF,2,len(ZCIF))


   Close File [EXS]


Return

$VERIF_MOD
  Infbox "VERIF_MOD"
  If clalev([F:ZEXS1]) = 0 : Local File EXPENSES [F:ZEXS1]  : Endif
  Filter [F:ZEXS1] Where CLB = [M:EXS0]CLB and ZSTATUS <> '1'

  Infbox num$(rowcount([ZEXS1]))

  Gosub PROCESO_CREACION_FACTURAS
  Close File [ZEXS1]
Return

$FIN_MOD
  Infbox "FIN_MOD"
  If clalev([F:ZEXS2]) = 0 : Local File EXPENSES [F:ZEXS2]  : Endif
  Filter [F:ZEXS2] Where CLB = [M:EXS0]CLB and ZSTATUS <> '1'

  Infbox num$(rowcount([ZEXS2]))


  Gosub PROCESO_CREACION_FACTURAS
  Close File [ZEXS2]

Return

