#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
$GRABAR_CABECERA


Gosub PON_SALTO


Wrseq 'G';                                               Using [FI1]
Wrseq ";";                                               Using [FI1]

#tipo asiento
Wrseq [F:YHAE]TYP;                                       Using [FI1]
Wrseq ";";                                               Using [FI1]

#numero asiento
Wrseq [F:YHAE]NUM;                                       Using [FI1]
Wrseq ";";                                               Using [FI1]

#planta
Wrseq mid$([F:ZHAE]FCY,1,3);                             Using [FI1]
Wrseq ";";                                               Using [FI1]

#diario
Wrseq [F:YHAE]JOU;                                       Using [FI1]
Wrseq ";";                                               Using [FI1]

#fecha
Wrseq [F:YHAE]ACCDAT;                                    Using [FI1]
Wrseq ";";                                               Using [FI1]

#referencia
Wrseq [F:YHAE]REF;                                       Using [FI1]
Wrseq ";";                                               Using [FI1]

#divisa
Wrseq [F:YHAE]CUR;                                       Using [FI1]
Wrseq ";";                                               Using [FI1]

#transacción
Wrseq [F:YHAE]DACDIA;                                    Using [FI1]
Wrseq ";";                                               Using [FI1]

#descripción
Wrseq [F:YHAE]DESVCR;                                    Using [FI1]
Wrseq ";";                                               Using [FI1]

#documento origen
Wrseq [F:YHAE]BPRVCR;                                    Using [FI1]
Wrseq ";";                                               Using [FI1]

#fecha documento
Wrseq [F:YHAE]BPRDATVCR;                                 Using [FI1]
Wrseq ";";                                               Using [FI1]

#tipo cambio
Wrseq [F:YHAE]TYPRAT;                                    Using [FI1]
Wrseq ";";                                               Using [FI1]

#cambio multiplicador
Wrseq [F:YHAE]RATMLT;                                    Using [FI1]
Wrseq ";"                                                Using [FI1]


Gosub QUITA_SALTO

Return
#########################################################################
$GRABAR_LINEA

Gosub PON_SALTO

#Línea
Wrseq [F:YDAE]LIN;                                       Using [FI1]
Wrseq ";";                                               Using [FI1]

#tipo de referencial
Wrseq [F:YDAE]LEDTYP;                                    Using [FI1]
Wrseq ";";                                               Using [FI1]

#identificador
Wrseq [F:YDAE]IDTLIN;                                    Using [FI1]
Wrseq ";";                                               Using [FI1]

#Planta
Wrseq mid$([F:YHAE]FCY,1,3);                             Using [FI1]
Wrseq ";";                                               Using [FI1]

#cuenta

Read [F:YGAC]GAC0=[F:YDAE]COA;[F:YDAE]ACC
If fstat = 0
  If [F:YGAC]YINTERCO=2
    Wrseq "9999";                                        Using [FI1]
    Wrseq ";";                                           Using [FI1]
  Else
    Wrseq mid$([F:YDAE]ACC,1,4);                         Using [FI1]
    Wrseq ";";                                           Using [FI1]
  Endif
Endif

#descripción
Wrseq [F:YDAE]DES;                                       Using [FI1]
Wrseq ";";                                               Using [FI1]

#sentido
Wrseq [F:YDAE]SNS;                                       Using [FI1]
Wrseq ";";                                               Using [FI1]

#importe
Wrseq [F:YDAE]AMTCUR;                                    Using [FI1]
Wrseq ";";                                               Using [FI1]

#divisa
Wrseq [F:YDAE]CUR;                                       Using [FI1]
Wrseq ";";                                               Using [FI1]

#referencia libre
Wrseq [F:YDAE]FREREF;                                    Using [FI1]
Wrseq ";"                                                Using [FI1]


Gosub QUITA_SALTO

Return
#####################################################################
$PON_SALTO
#####################################################################
SAVIFS=adxifs
SAVIRS=adxirs

adxifs=""
adxirs=chr$(13)+chr$(10)

Return
#####################################################################
$QUITA_SALTO
#####################################################################
adxifs = SAVIFS
adxirs = SAVIRS

Return

