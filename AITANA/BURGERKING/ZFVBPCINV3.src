#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#  Y019 Generaciˇn de pdf para facturas de canje
#########################################################################
$ACTION
  Case ACTION
    When "TRT_DIV"    : Gosub TRT_DIV
    When "FICHIER"    :    Gosub FICHIER
    When Default
  Endcase
Return

#########################################################################
$TRT_DIV
  Case GACTION
    When "ZFVBPCINV3"  :
      Call IMPRIMIR_ZFVBPCINV3([F:SIH]NUM)
  Endcase
Return
#########################################################################
$FICHIER
FICHIER = filpath("CANJE",[F:SIH]NUM+'_'+[F:SIV]INVREF,"pdf")
Return
#########################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()
End
#########################################################################
Subprog IMPRIMIR_ZFVBPCINV3(WSIHNUM)
Value Char     WSIHNUM

Gosub IMPRIMIR_FACTURA

End
#########################################################################
$IMPRIMIR_FACTURA
Local Char    TBPAR(30)(1..50),TBVAL(30)(1..50)

TBPAR(1)  = "sitedeb"          : TBVAL(1)  = [F:SIH]FCY
TBPAR(2)  = "sitefin"          : TBVAL(2)  = [F:SIH]FCY

TBPAR(3)  = "facturedeb"       : TBVAL(3)  = [F:SIH]NUM
TBPAR(4)  = "facturefin"       : TBVAL(4)  = [F:SIH]NUM

TBPAR(5)  = "typedeb"          : TBVAL(5)  = num$(1)
TBPAR(6)  = "typefin"          : TBVAL(6)  = num$(5)

TBPAR(7)  = "clientdeb"        : TBVAL(7)  = [F:SIH]BPR
TBPAR(8)  = "clientfin"        : TBVAL(8)  = [F:SIH]BPR

TBPAR(9)  = "datedeb"          : TBVAL(9)  = [F:SIH]ACCDAT
TBPAR(10) = "datefin"          : TBVAL(10) = [F:SIH]ACCDAT

TBPAR(11) = "devdeb"           : TBVAL(11) = [F:SIH]CUR
TBPAR(12) = "devfin"           : TBVAL(12) = [F:SIH]CUR

TBPAR(13) = "impselections"    : TBVAL(13) = num$(1)
TBPAR(14) = "codimp"           : TBVAL(14) = num$(1)

TBPAR(15) = "usr"              : TBVAL(15) = GUSER

TBPAR(16) = "etat"             : TBVAL(16) = "ZFVBPCINV2"
TBPAR(17) = "numedt"           : TBVAL(17) = ""
TBPAR(18) = "seqedt"           : TBVAL(18) = num$(0)
TBPAR(19) = "euro"             : TBVAL(19) = GEURO
TBPAR(20) = "NBMAXTARIF"       : TBVAL(20) = num$(1)

TBPAR(21) = "traitauto"        : TBVAL(21) = num$(0)

TBPAR(22) = "codact"           : TBVAL(22) = ""

TBPAR(23) = "tauxagios"        : TBVAL(23) = num$(0)

TBPAR(24) = "tauxescompte"     : TBVAL(24) = num$(0)

TBPAR(25) = "logosoc"          : TBVAL(25) = num$(2)
TBPAR(26) = "infosoc"          : TBVAL(26) = num$(2)
TBPAR(27) = "adrdesgau"        : TBVAL(27) = "DE,GB,US"
TBPAR(28) = "insertcoordexp"   : TBVAL(28) = "DE"


TBPAR(29) = "mention"          : TBVAL(29) = num$(1)
TBPAR(30) = "duplicata"        : TBVAL(30) = num$(2)
TBPAR(31) = "mentionpays"      : TBVAL(31) = "FR"

TBPAR(32) = "mentionmontant"      : TBVAL(32) = "40"
TBPAR(33) = "paramsddprn"      : TBVAL(33) = num$(1)


Call ETAT("ZFVBPCINV3", "YPDFDOC", 'SPA', 0, '', TBPAR, TBVAL) From AIMP3


Return
#########################################################################

