#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION


  Case ACTION

    When "AP_IMPORT"        : Gosub $AP_IMPORT

    When Default
  Endcase
  Return

$OUVRE
    Gosub OUVRE From GASIMPORT
  Return

$RAZCRE
    Gosub RAZCRE From GASIMPORT
  Return

$VALID
    Gosub VALID From GASIMPORT
  Return

$SAIMSK
    Gosub SAIMSK From GASIMPORT
    Return

$IMP_FERME
  Return


#######################################################################################
#**
#*
#*!
$AP_IMPORT
  Local Char LIMPORTE
Infbox [L]IMPFIC
  Case [L]IMPFIC
    When "ZPN"  # ZPAGOSNOM
      Infbox num$([F:ZPN]ZIMPORTE)
      LIMPORTE = ctrans([F:ZPN]ZIMPORTE, ',', '')
      Infbox LIMPORTE
      [F:ZPN]ZIMPORTE = val(LIMPORTE)
    When Default
  Endcase

  Return

