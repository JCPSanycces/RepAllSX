######################################################################################

$AVANT_MOD
  Affzo [M:SIH4]NETPRI
Return

######################################################################################

$SETBOUT
  # <YDPDF>: Generación y envío de documentos PDF
  If GREP<>"" or !CLECUR
    Call VIREBOUT(CHAINE, "z") From GOBJET
  Endif
  # </YDPDF>
Return

######################################################################################

$EXEBOUT
  Case BOUT
    When "z"
      # <YDPDF>: Generación y envío de documentos PDF
      Gosub RELIT From GOBJSUB
  Endcase
Return

######################################################################################

$RAZDUP
  # <YDPDF>: Generación y envío de documentos PDF
  [M:SIH1]YINVSENT = 1
  Affzo [M:SIH1]YINVSENT
Return

