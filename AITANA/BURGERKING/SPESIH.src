$APRES_CRE
If [F:SIH]SIVTYP = 'CAN'
  # Las facturas de tipo canje se guardan como pdf automáticamente.
  Local Char VALBOUT(250) , PARBOUT(250)(1..20)
  FLGEXE = 1
  GACTION = "ZFVBPCINV3"
  Call S_AFF_CHAR(VALBOUT,PARBOUT,"","ZFVBPCINV3","") From GACTION

Endif
Return
