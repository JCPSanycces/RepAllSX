$ACTION
#If GUSER='LIVDV':
#If ACTION = "INICRE_LIG": Dbgaff : Endif
#Infbox(ACTION)
#Endif
  Case ACTION
    When "LIENS"       : Gosub LIENS
    When "VERIF_CRE"   : Gosub VERIF_CRE
    When "AVANT_MOD"   : Gosub AVANT_MOD   ### GT_RM_30Aug18 : To refresh Net price field in saving mod
    When "AVANT_ACT"   : Gosub AVANT_MOD
    When "APRES_MODIF" : Gosub AVANT_MOD
    When "INICRE_LIG"  : Gosub INICRE_LIG
    When "FILGAUCHE"   : Gosub FILGAUCHE
    When "SETBOUT"     : Gosub SETBOUT
    When "EXEBOUT"     : Gosub EXEBOUT
    When "APRES_CRE"   : Gosub APRES_CRE

  Endcase
#  Gosub ACTION From YSPESIH
Return

