#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char STR
#STR = 'Holß, pr³eb¬ caracter$s rarįs/ '
STR = ''
Call LIMPIA_STR(STR)
End

###############################################################################
# Limpia los caracteres extra±os de una cadena
#
# STR Cadena a limpiar
# CLEANSTR Cadena limpia
###############################################################################
Subprog LIMPIA_STR(STR)
Value Char    STR
Global Char CLEANSTR(250)

Raz CLEANSTR

Local File NOTE

#es el comentario de la factura
Filter [F:NTS] Where NTSCOD = 'PRUEBA' and BPCNUM = '2009'
Read  [F:NTS] First
If !fstat Then
  STR = [F:NTS]NOTE
Endif

Infbox STR

STR=ctrans(STR,"ß" ,"a") : STR=ctrans(STR,"Ó" ,"a") : STR=ctrans(STR,"õ" ,"a")
STR=ctrans(STR,"Ō" ,"a") : STR=ctrans(STR,"¬" ,"a") : STR=ctrans(STR,"┴" ,"A")
STR=ctrans(STR,"└" ,"A") : STR=ctrans(STR,"┬" ,"A") : STR=ctrans(STR,"─" ,"A")
STR=ctrans(STR,"ķ" ,"e") : STR=ctrans(STR,"Ķ" ,"e") : STR=ctrans(STR,"ļ" ,"e")
STR=ctrans(STR,"Ļ" ,"e") : STR=ctrans(STR,"╔" ,"E") : STR=ctrans(STR,"╚" ,"E")
STR=ctrans(STR,"╩" ,"E") : STR=ctrans(STR,"╦" ,"E") : STR=ctrans(STR,"Ē" ,"i")
STR=ctrans(STR,"ņ" ,"i") : STR=ctrans(STR,"’" ,"i") : STR=ctrans(STR,"Ņ" ,"i")
STR=ctrans(STR,"═" ,"I") : STR=ctrans(STR,"╠" ,"I") : STR=ctrans(STR,"Ž" ,"I")
STR=ctrans(STR,"╬" ,"I") : STR=ctrans(STR,"¾" ,"o") : STR=ctrans(STR,"“" ,"o")
STR=ctrans(STR,"÷" ,"o") : STR=ctrans(STR,"¶" ,"o") : STR=ctrans(STR,"ė" ,"O")
STR=ctrans(STR,"ę" ,"O") : STR=ctrans(STR,"ų" ,"O") : STR=ctrans(STR,"į" ,"O")
STR=ctrans(STR,"·" ,"u") : STR=ctrans(STR,"∙" ,"u") : STR=ctrans(STR,"³" ,"u")
STR=ctrans(STR,"¹" ,"u") : STR=ctrans(STR,"┌" ,"U") : STR=ctrans(STR,"┘" ,"U")
STR=ctrans(STR,"█" ,"U") : STR=ctrans(STR,"▄" ,"U") : STR=ctrans(STR,"±" ,"n")
STR=ctrans(STR,"č" ,"N") : STR=ctrans(STR,"ń" ,"c") : STR=ctrans(STR,"Ū" ,"C")
STR=ctrans(STR,"\" ,"")  : STR=ctrans(STR,"©" ,"")  : STR=ctrans(STR,"║" ,"")
STR=ctrans(STR,"~" ,"")  : STR=ctrans(STR,"#" ,"")  : STR=ctrans(STR,"@" ,"")
STR=ctrans(STR,"|" ,"")  : STR=ctrans(STR,"!" ,"")  : STR=ctrans(STR,'"' ,"")
STR=ctrans(STR,"*" ,"")  : STR=ctrans(STR,"Ę" ,"")  : STR=ctrans(STR,"$" ,"")
STR=ctrans(STR,"%" ,"")  : STR=ctrans(STR,"&" ,"")  : STR=ctrans(STR,"(" ,"")
STR=ctrans(STR,")" ,"")  : STR=ctrans(STR,"?" ,"")  : STR=ctrans(STR,"'" ,"")
STR=ctrans(STR,"Ī" ,"")  : STR=ctrans(STR,"┐" ,"")  : STR=ctrans(STR,"[" ,"")
STR=ctrans(STR,"^" ,"")  : STR=ctrans(STR,"<" ,"")  : STR=ctrans(STR,">" ,"")
STR=ctrans(STR,"]" ,"")  : STR=ctrans(STR,"+" ,"")  : STR=ctrans(STR,"}" ,"")
STR=ctrans(STR,"{" ,"")  : STR=ctrans(STR,"┤" ,"")  : STR=ctrans(STR,";" ,"")
STR=ctrans(STR," " ,"")  : STR=ctrans(STR,":" ,"")  : STR=ctrans(STR,"/" ,"")
STR=ctrans(STR,chr$(13),"") # retorno carro
STR=ctrans(STR,chr$(10),"") # nueva linea

CLEANSTR = STR

Infbox CLEANSTR

End
#MRR01 fin
