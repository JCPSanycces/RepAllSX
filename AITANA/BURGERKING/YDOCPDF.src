#<AdxTL>@(#)0.0.0.0 $Revision$ 

$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "DEBUT"        : Gosub DEBUT
    When "SETBOUT"      : Gosub SETBOUT
    When "AVANT_BOUTON" : Gosub AVANT_BOUTON
    When "BOUTON"       : Gosub BOUTON
    When "FIN"          : Gosub FIN
  Endcase
Return

#------------------------------------------------------------------------------#

$OUVRE
  If clalev([F:YSPDF])=0 : Local File YSETUPPDF [YSPDF] : Endif
  If clalev([F:YSEND])=0 : Local File YSENTDOCS [YSEND] : Endif
  If clalev([F:YBPDF])=0 : Local File YBPRPDF   [YBPDF] : Endif
  If clalev([F:AVL])=0   : Local File AVOLUME     [AVL] : Endif
  If clalev([F:ATZ])=0   : Local File ATABZON     [ATZ] : Endif
  If clalev([F:ATY])=0   : Local File ATYPE       [ATY] : Endif

  Local  Char    CRITERE(250), WCODAIM(GLONAIM), WYPATHPDF(250), AUXCHAR(250),
&                NOMFIC(250), WMSG(250), WVOL(GLONAVL), DIRSEP(1)
  Local  Integer I, IS_FULL_TABLE, YSTA, WSEC, NBRFIC, STAT, NOL, AUXINT, NBERR
  Global Char    GYWNOMFIC(250)

  WCODAIM = func AFNC.PARAM("YAIMPDF", "")
  If WCODAIM=""
    GMESSAGE  = "YAIMPDF:" - mess(141,105,1)
    GERR = 1 : FIN = 1 : Return
  Endif

  Case GOS(1)
    When "dos"   : DIRSEP = "\"
    When Default : DIRSEP = "/"
  Endcase

  # Volumen facturas documentos adjuntos
  WVOL = func AFNC.PARAM("YVOLJOINT", "")
  If WVOL=""
    GMESSAGE  = "YVOLJOINT:" - mess(141,105,1)
    GERR = 1 : FIN = 1 : Return
  Endif
  Read [F:AVL]CODE=WVOL
  If fstat
    GMESSAGE  = WVOL + ":" - mess(47,149,1)
    GERR = 1 : FIN = 1 : Return
  Endif
  WYPATHPDF = func ASYRSTO.GETFULLPATH(WVOL, "")
  If right$(WYPATHPDF, len(WYPATHPDF))<>DIRSEP
    WYPATHPDF += DIRSEP
  Endif
Return

#------------------------------------------------------------------------------#

$DEBUT
  If [V]GBATCH : Return : Endif
  [M:YDPDF]YPATHPDF = WYPATHPDF
  [M:YDPDF]WDIRSEP = DIRSEP
  Raz [M:YDPDF]WDOCPDF
  Diszo [M:YDPDF]10-15
Return

#------------------------------------------------------------------------------#

$SETBOUT
  If [V]GBATCH
    Call VIREBOUT(CHMEN, "2345") From GOBJET
    Gosub SET_BOUT_SPE From GSAISIE
  Else
    If [M:YDPDF]NBLIG=0
      Call VIREBOUT(CHMEN, "2345") From GOBJET
      Gosub SET_BOUT_SPE From GSAISIE
    Endif
  Endif
  #STADEF = GSTABOU+1
Return

#------------------------------------------------------------------------------#

$AVANT_BOUTON
  Case BOUT
    When "5" : Raz  GADIFDAT, GADIFTIM
  Endcase
Return

#------------------------------------------------------------------------------#

$BOUTON
  Case BOUT
    When "1"
      If [V]GBATCH
        FIN = 1
      Else
        Gosub SEARCH
      Endif
    When "2" : Gosub INCLUDE_ALL
    When "3" : Gosub EXCLUDE_ALL
    When "4" : Gosub GENERATE
    When "5" : Gosub GEN_BATCH
  Endcase
Return

#------------------------------------------------------------------------------#

$FIN
  If dim([V]GYWNOMFIC)>0 : Kill [V]GYWNOMFIC : Endif
Return

#------------------------------------------------------------------------------#

$SEARCH
  If [M:YDPDF]WDOCPDF="" : Return : Endif

  Onerrgo ERR_FILE
  If clalev([F:YDOCPDF])>0 : Close Local File [F:YDOCPDF] : Endif
  Local File =[M:YDPDF]WTABFIL [YDOCPDF]
  Onerrgo
  If GERR : Return : Endif

  Effzo [M:YDPDF]20

  Raz CRITERE
  Gosub EXCEPTIONS
  If CRITERE = "" : CRITERE = "1=1" : Endif
  If [M:YDPDF]ALLCPY<>2
    CRITERE -= '&' - [M:YDPDF]WCPYFLD + '="' + [M:YDPDF]WCPY + '"'
  Endif
  If [M:YDPDF]ALLFCY<>2
    CRITERE -= '&' - [M:YDPDF]WFCYFLD + '="' + [M:YDPDF]WFCY + '"'
  Endif
  If [M:YDPDF]ALLTYP<>2
    CRITERE -= '&' - [M:YDPDF]WTYPFLD + '="' + [M:YDPDF]WTYP + '"'
  Endif
  If [M:YDPDF]STRDAT<>[0/0/0]
    CRITERE -= "&" - [M:YDPDF]WDATFLD + ">=[" + format$(GFMD, [M:YDPDF]STRDAT) + "]"
  Endif
  If [M:YDPDF]ENDDAT<>[0/0/0]
    CRITERE -= "&" - [M:YDPDF]WDATFLD + "<=[" + format$(GFMD, [M:YDPDF]ENDDAT) + "]"
  Endif
  If [M:YDPDF]VCRDEB<>""
    CRITERE -= '&' - [M:YDPDF]WVCRFLD + '>="' + [M:YDPDF]VCRDEB + '"'
  Endif
  If [M:YDPDF]VCRFIN<>""
    CRITERE -= '&' - [M:YDPDF]WVCRFLD + '<="' + [M:YDPDF]VCRFIN + '"'
  Endif
  If [M:YDPDF]BPRDEB<>""
    CRITERE -= '&' - [M:YDPDF]WBPRFLD + '>="' + [M:YDPDF]BPRDEB + '"'
  Endif
  If [M:YDPDF]BPRFIN<>""
    CRITERE -= '&' - [M:YDPDF]WBPRFLD + '<="' + [M:YDPDF]BPRFIN + '"'
  Endif

  If ![V]GSERVEUR : Call TEMPON("R") From GESECRAN : Endif
  Raz IS_FULL_TABLE
  Raz I
  For [F:YDOCPDF] Where evalue(CRITERE) and evalue([M:YDPDF]WFILTRE) With Nohint
    If I>=dim([M:YDPDF]VCRNUM)
      IS_FULL_TABLE = 1 : Break
    Endif
    I += 1
    NOL = I-1
    # <GON> Subida desde TEST 03/09/2019
    ##[M:YDPDF]CPY(NOL) = evalue("[F:YDOCPDF]" + [M:YDPDF]WCPYFLD)
    ##[M:YDPDF]FCY(NOL) = evalue("[F:YDOCPDF]" + [M:YDPDF]WFCYFLD)
    ##[M:YDPDF]VCRNUM(NOL) = evalue("[F:YDOCPDF]" + [M:YDPDF]WVCRFLD)
    ##[M:YDPDF]DOCDAT(NOL) = evalue("[F:YDOCPDF]" + [M:YDPDF]WDATFLD)
    ##[M:YDPDF]BPRNUM(NOL) = evalue("[F:YDOCPDF]" + [M:YDPDF]WBPRFLD)
    # </GON>
    If [M:YDPDF]WCPYFLD<>""
      [M:YDPDF]CPY(NOL) = evalue("[F:YDOCPDF]" + [M:YDPDF]WCPYFLD)
    Endif
    If [M:YDPDF]WFCYFLD<>""
      [M:YDPDF]FCY(NOL) = evalue("[F:YDOCPDF]" + [M:YDPDF]WFCYFLD)
    Endif
    If [M:YDPDF]WVCRFLD<>""
      [M:YDPDF]VCRNUM(NOL) = evalue("[F:YDOCPDF]" + [M:YDPDF]WVCRFLD)
    Endif
    If [M:YDPDF]WDATFLD<>""
      [M:YDPDF]DOCDAT(NOL) = evalue("[F:YDOCPDF]" + [M:YDPDF]WDATFLD)
    Endif
    If [M:YDPDF]WBPRFLD<>""
      [M:YDPDF]BPRNUM(NOL) = evalue("[F:YDOCPDF]" + [M:YDPDF]WBPRFLD)
    Endif
    If [M:YDPDF]WTYPFLD<>""
      If evalue("dim([F:YDOCPDF]" + [M:YDPDF]WTYPFLD + ")")>0
        [M:YDPDF]VCRTYP(NOL) = evalue("[F:YDOCPDF]" + [M:YDPDF]WTYPFLD)
      Endif
    Endif
    Gosub GET_NOMFIC
    AUXCHAR = [M:YDPDF]YPATHPDF + [M:YDPDF]WDOCPDF + [M:YDPDF]WDIRSEP + NOMFIC
    Call EXISTE(AUXCHAR, YSTA) From ORDSYS
    If YSTA=1
      [M:YDPDF]PDFEXIST(NOL) = 2
    Else
      [M:YDPDF]PDFEXIST(NOL) = 1
    Endif
    Read [F:YSEND]YSEND0 = [M:YDPDF]WAOBCOD;[M:YDPDF]VCRNUM(NOL)
    If !fstat
      [M:YDPDF]YDOCSENT(NOL) = 2
    Else
      [M:YDPDF]YDOCSENT(NOL) = 1
    Endif

    If [V]GSERVEUR and [M:YDPDF]YDOCSENT(NOL)<>2
      [M:YDPDF]CHKCREPDF(NOL) = 2
    Endif
  Next
  [M:YDPDF]NBLIG = I
  Sorta [M:YDPDF]NBLIG [M:YDPDF]NBLIG Order By [M:YDPDF]DOCDAT(indice), [M:YDPDF]VCRNUM(indice)
  Affzo [M:YDPDF]20
  If ![V]GSERVEUR : Call TEMPOFF From GESECRAN : Endif
  If IS_FULL_TABLE
    GMESSAGE = mess(26,100,1) : GERR = 2
  Endif
Return

$ERR_FILE
  GMESSAGE = errmes$(errn)+ "." - errm
  GERR = 1
Resume

#------------------------------------------------------------------------------#

$EXCEPTIONS
  Case [M:YDPDF]WOBJTYP
    When "SOH" : CRITERE = "SOHCAT<4"
    When "POH" : CRITERE = "POHTYP=1"
  Endcase
Return

#------------------------------------------------------------------------------#

$INCLUDE_ALL
  If [M:YDPDF]NBLIG>0 : Call SELECT_ALL(2,0) : Endif
Return

#------------------------------------------------------------------------------#

$EXCLUDE_ALL
  If [M:YDPDF]NBLIG>0 : Call SELECT_ALL(1,0) : Endif
Return

#------------------------------------------------------------------------------#

$GENERATE
  If find(2, [M:YDPDF]CHKCREPDF(0..[M:YDPDF]NBLIG-1))=0 : Return : Endif
  Raz NBERR

  Local Char TBPAR(10)(1..50), TBVAL(30)(1..50)
  Raz NBRFIC

  If !GSERVEUR : Call TEMPON("R") From GESECRAN : Endif
  If !GSERVEUR : Call OUVRE_TRACE(mess(10,6002,1)) From LECFIC : Endif

  Read [F:YSPDF]YSPDF0=[M:YDPDF]WDOCPDF
  If fstat : Raz [F:YSPDF] : Endif

  For I=0 To [M:YDPDF]NBLIG-1
    If [M:YDPDF]CHKCREPDF(I)=2
      Gosub IMPRIME
    Endif
  Next I
  If !GSERVEUR : Call FERME_TRACE From LECFIC : Endif

  # Bucle para marcar el check de "PDF generado"
  If NBRFIC>0 and !GSERVEUR
    For NOL=0 To [M:YDPDF]NBLIG-1
      If [M:YDPDF]CHKCREPDF(NOL)=2
        Raz WSEC
        Gosub GET_NOMFIC
        AUXCHAR = [M:YDPDF]YPATHPDF + [M:YDPDF]WDOCPDF + [M:YDPDF]WDIRSEP + NOMFIC
        Call EXISTE(AUXCHAR, YSTA) From ORDSYS
        If YSTA=1
          [M:YDPDF]PDFEXIST(NOL) = 2
          [M:YDPDF]CHKCREPDF(NOL) = 1
        Else
          [M:YDPDF]PDFEXIST(NOL) = 1
        Endif
        Read [F:YSEND]YSEND0 = [M:YDPDF]WAOBCOD;[M:YDPDF]VCRNUM(NOL)
        If !fstat
          [M:YDPDF]YDOCSENT(NOL) = 2
        Else
          [M:YDPDF]YDOCSENT(NOL) = 1
        Endif

        Affzo [M:YDPDF]PDFEXIST(NOL)
        Affzo [M:YDPDF]CHKCREPDF(NOL)
        Affzo [M:YDPDF]YDOCSENT(NOL)
      Endif
    Next NOL
  Endif

  If !GSERVEUR : Call TEMPOFF From GESECRAN : Endif

  If NBERR>0 and !GSERVEUR
    Call LEC_TRACE From LECFIC
  Endif
Return

#------------------------------------------------------------------------------#

$GEN_BATCH
  If GADIFDAT<>[0/0/0] & GADIFTIM<>""
    Call REQUETE(GADIFDAT, GADIFTIM, GBOITE) From ADIFFERE
    Raz GADIFDAT, GADIFTIM
  Endif
Return

#------------------------------------------------------------------------------#

$IMPRIME
  Call GEN_PDF([M:YDPDF]WDOCPDF, [M:YDPDF]VCRNUM(I), [M:YDPDF]WRPTCOD, WCODAIM, STAT, WMSG) From YSENDPDF
  If STAT
    Call ECR_TRACE(mess(19,6002,1) - [M:YDPDF]VCRNUM(I) + ":" - mess(6,123,1) - WMSG, 1) From GESECRAN
    NBERR += 1
  Else
    Call ECR_TRACE(mess(19,6002,1) - [M:YDPDF]VCRNUM(I) + ":" - mess(11,6002,1), 0) From GESECRAN
    NBRFIC += 1

    If [F:YSPDF]CODE<>[M:YDPDF]WDOCPDF
      Read [F:YSPDF]YSPDF0=[M:YDPDF]WDOCPDF
      If fstat : Raz [F:YSPDF] : Endif
    Endif
    If [F:YSPDF]CODE=[M:YDPDF]WDOCPDF and [F:YSPDF]CODWRK<>""
      Read [F:YBPDF]YBPDF0 = [F:YSPDF]BPRTYP;[M:YDPDF]BPRNUM(I);[F:YSPDF]CODE
      If !fstat
        Read [F:YSEND]YSEND0=[M:YDPDF]WAOBCOD;[M:YDPDF]VCRNUM(I)
        If fstat : Raz [F:YSEND] : Endif
        AUXINT = [F:YSEND]NBRSENT

        Call SENDWRKPDF([F:YSPDF]CODE, [M:YDPDF]VCRNUM(I)) From YSENDPDF

        Read [F:YSEND]YSEND0=[M:YDPDF]WAOBCOD;[M:YDPDF]VCRNUM(I)
        If fstat : Raz [F:YSEND] : Endif

        If [F:YSEND]NBRSENT<=AUXINT
          WMSG  = mess(8,6002,1) + "\"
          WMSG += mess(9,6002,1)
          Call ECR_TRACE(WMSG, 1) From GESECRAN
          NBERR += 1
        Endif
      Endif
    Elsif [F:YSPDF]CODWRK=""
      WMSG  = func AFNC.MES1(mess(20,6002,1), [F:YSPDF]CODE)
      Call ECR_TRACE(WMSG, 1) From GESECRAN
      NBERR += 1
    Endif
  Endif
Return

#------------------------------------------------------------------------------#

$GET_NOMFIC
  NOMFIC = toupper([M:YDPDF]VCRNUM(NOL))
  NOMFIC += "."
  NOMFIC += "pdf"
Return

#------------------------------------------------------------------------------#

Subprog AM_WDOCPDF(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>""
    Local Integer I
    Local Char    AUXCHAR(250)

    Read [F:YSPDF]YSPDF0=VALEUR
    If fstat : Raz [F:YSPDF] : Endif
    Raz [M:YDPDF]WAOBCOD, WTABFIL, WABRFIL, WCPYFLD, WFCYFLD, WTYPFLD, WDATFLD,
&                WBPRFLD, WVCRFLD, WRPTCOD

    [M:YDPDF]WAOBCOD = [F:YSPDF]AOBCOD
    [M:YDPDF]WTABFIL = [F:YSPDF]TABFIL
    [M:YDPDF]WABRFIL = [F:YSPDF]ABRFIL
    [M:YDPDF]WCPYFLD = [F:YSPDF]CPYFLD
    [M:YDPDF]WFCYFLD = [F:YSPDF]FCYFLD
    [M:YDPDF]WTYPFLD = [F:YSPDF]TYPFLD
    [M:YDPDF]WDATFLD = [F:YSPDF]DATFLD
    [M:YDPDF]WBPRFLD = [F:YSPDF]BPRFLD
    [M:YDPDF]WVCRFLD = [F:YSPDF]VCRFLD
    [M:YDPDF]WRPTCOD = [F:YSPDF]RPTCOD
    [M:YDPDF]WBPRTYP = [F:YSPDF]BPRTYP
    [M:YDPDF]WFILTRE = func GET_FILTER([F:YSPDF]FILTRE)
    If [M:YDPDF]WFILTRE="" : [M:YDPDF]WFILTRE = "1=1" : Endif

    If [M:YDPDF]WTYPFLD<>"" and [M:YDPDF]WTABFIL<>""
      Read [F:ATZ]CODZONE = [M:YDPDF]WTABFIL;[M:YDPDF]WTYPFLD
      If !fstat
        Read [F:ATY]CODTYP=[F:ATZ]CODTYP
        If !fstat
          [M:YDPDF]WOBJTYP = [F:ATY]OBJLIEN
        Endif
      Endif
    Endif

    Effzo [M:YDPDF]10-15
    Diszo [M:YDPDF]10-15

    # Sociedad
    Actzo [M:YDPDF]ALLCPY, WCPY
    If [M:YDPDF]WCPYFLD=""
      [M:YDPDF]ALLCPY = 2
      Diszo [M:YDPDF]ALLCPY, WCPY
    Else
      [M:YDPDF]ALLCPY = 2
      If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE : [M:YDPDF]ALLCPY = 1 : Endif
      If [M:YDPDF]ALLCPY = 1
        Call INICPY([M:YDPDF]WCPY) From CPTSUB
      Endif
      If [M:YDPDF]ALLCPY=2
        Diszo [M:YDPDF]WCPY
      Else
        Actzo [M:YDPDF]WCPY
      Endif
    Endif

    # Planta
    Actzo [M:YDPDF]ALLFCY, WFCY
    If [M:YDPDF]WFCYFLD=""
      [M:YDPDF]ALLFCY = 2
      Diszo [M:YDPDF]ALLFCY, WFCY
    Else
      [M:YDPDF]ALLFCY = 2
      If [M:YDPDF]ALLCPY = 1
        Call INIALLFCY([M:YDPDF]ALLFCY,[M:YDPDF]WCPY) From CPTTRT
      Endif
      If [M:YDPDF]ALLFCY = 1
        Call INIFCY([M:YDPDF]WFCY,[M:YDPDF]WCPY) From CPTSUB
      Endif
      If [M:YDPDF]ALLFCY=2
        Diszo [M:YDPDF]WFCY
      Else
        Actzo [M:YDPDF]WFCY
      Endif
    Endif

    # Tipo documento
    Actzo [M:YDPDF]ALLTYP, WTYP
    [M:YDPDF]ALLTYP = 2
    Diszo [M:YDPDF]WTYP
    If [M:YDPDF]WTYPFLD=""
      Diszo [M:YDPDF]ALLTYP
    Endif

    # Rango fechas
    Actzo [M:YDPDF]STRDAT, ENDDAT
    If [M:YDPDF]WDATFLD=""
      Diszo [M:YDPDF]STRDAT, ENDDAT
    Endif

    # Rango documentos
    Actzo [M:YDPDF]VCRDEB, VCRFIN
    If [M:YDPDF]WVCRFLD=""
      Diszo [M:YDPDF]VCRDEB, VCRFIN
    Endif

    # Rango terceros
    Actzo [M:YDPDF]BPRDEB, BPRFIN
    If [M:YDPDF]WBPRFLD=""
      Diszo [M:YDPDF]BPRDEB, BPRFIN
    Endif

    Affzo [M:YDPDF]10-15
  Endif
End

#------------------------------------------------------------------------------#

Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
  If [M:YDPDF]WCPYFLD=""
    Raz [M:YDPDF]WCPY : Diszo [M:YDPDF]WCPY
    VALEUR = 2 : mkstat = 1
  Elsif GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    VALEUR = 1 : mkstat = 1
  Endif
End

#------------------------------------------------------------------------------#

Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR
  Raz [M:YDPDF]WCPY
  If VALEUR=2
    Diszo [M:YDPDF]WCPY
  Else
    Actzo [M:YDPDF]WCPY
  Endif
  Affzo [M:YDPDF]WCPY
End

#------------------------------------------------------------------------------#

Subprog AS_WCPY(VALEUR)
Variable Char    VALEUR()
  If [M:YDPDF]ALLCPY=2
    VALEUR = "" : mkstat = 1
  Endif
End

#------------------------------------------------------------------------------#

Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
  If [M:YDPDF]WFCYFLD=""
    VALEUR = 2 : mkstat = 2 : End
  Elsif [M:YDPDF]ALLCPY=2
    VALEUR = 2 : mkstat = 2 : End
  Else
    Call INIALLFCY(VALEUR, [M:YDPDF]WCPY) From CPTTRT
  Endif
  If VALEUR=2
    Raz [M:YDPDF]WFCY
    Diszo [M:YDPDF]WFCY
  Else
    Actzo [M:YDPDF]WFCY
  Endif
  Affzo [M:YDPDF]WFCY
End

#------------------------------------------------------------------------------#

Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR
  Raz [M:YDPDF]WFCY
  If VALEUR=2
    Diszo [M:YDPDF]WFCY
  Else
    Actzo [M:YDPDF]WFCY
  Endif
  Affzo [M:YDPDF]WFCY
End

#------------------------------------------------------------------------------#

Subprog AS_WFCY(VALEUR)
Variable Char    VALEUR()
  If [M:YDPDF]ALLFCY=2
    VALEUR = "" : mkstat = 1
  Endif
End

#------------------------------------------------------------------------------#

Subprog AM_ALLTYP(VALEUR)
Variable Integer VALEUR
  Raz [M:YDPDF]WTYP
  If VALEUR=2
    Diszo [M:YDPDF]WTYP
  Else
    Actzo [M:YDPDF]WTYP
  Endif
  Affzo [M:YDPDF]WTYP
End

#------------------------------------------------------------------------------#

Subprog AS_WTYP(VALEUR)
Variable Char VALEUR
  If [M:YDPDF]ALLTYP=2
    VALEUR = "" : mkstat = 1
  Endif
End

#------------------------------------------------------------------------------#

Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
  If VALEUR<>[0/0/0] : [M:YDPDF]ENDDAT = VALEUR : Endif
End

#------------------------------------------------------------------------------#

Subprog AM_VCRDEB(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>"" : [M:YDPDF]VCRFIN = VALEUR : Endif
End

#------------------------------------------------------------------------------#

Subprog AM_BPRDEB(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>"" : [M:YDPDF]BPRFIN = VALEUR : Endif
End

#------------------------------------------------------------------------------#

Subprog SELECT_ALL(PON, DESDE)
Value Integer PON
Value Integer DESDE
Local Integer I

  For I=DESDE To [M:YDPDF]NBLIG-1
    If PON=2
      If func CHECK_GEN_SEND([M:YDPDF]VCRNUM(I), [M:YDPDF]BPRNUM(I), I)=1
        [M:YDPDF]CHKCREPDF(I) = 2
      Else
        [M:YDPDF]CHKCREPDF(I) = 1
      Endif
    Else
      [M:YDPDF]CHKCREPDF(I) = 1
    Endif
  Next I
  Affzo [M:YDPDF]CHKCREPDF
End

#------------------------------------------------------------------------------#

Subprog IB_NBLIG
  GBOUT4 = [M:YDPDF]VCRNUM(nolign-1)
End

#------------------------------------------------------------------------------#

Subprog B1_NBLIG
  Call SELECT_ALL(2,nolign-1)
End

#------------------------------------------------------------------------------#

Subprog B2_NBLIG
  Call SELECT_ALL(1,nolign-1)
End

#------------------------------------------------------------------------------#

Subprog C_CHKCREPDF(VALEUR)
Variable Integer VALEUR

  If VALEUR=2
    Local Integer K
    K = func CHECK_GEN_SEND([M:YDPDF]VCRNUM(nolign-1), [M:YDPDF]BPRNUM(nolign-1), nolign-1)
    If K=0
      K = 1
      Call OUINON(mess(21,6002,1) + "\" + mess(205,100,1), K) From GESECRAN
      VALEUR = K
    Endif
  Endif
End

#------------------------------------------------------------------------------#

Funprog CHECK_GEN_SEND(WVCRNUM, WBPRNUM, I)
Value Char    WVCRNUM
Value Char    WBPRNUM
Value Integer I
Local Integer OK

  OK = 1
  If WVCRNUM<>"" and WBPRNUM<>""
    Read [F:YSEND]YSEND0=[M:YDPDF]WAOBCOD;WVCRNUM
    If fstat : Raz [F:YSEND] : Endif

    Read [F:YBPDF]YBPDF0 = [M:YDPDF]WBPRTYP;WBPRNUM;[M:YDPDF]WDOCPDF
    If fstat : Raz [F:YBPDF] : Endif

    OK = 0
    If [F:YBPDF]BPRNUM=WBPRNUM and [F:YSEND]VCRNUM<>WVCRNUM
      OK = 1
    Elsif [F:YBPDF]BPRNUM="" and [M:YDPDF]PDFEXIST(I)<>2
      OK = 1
    Endif
  Endif
End OK

#------------------------------------------------------------------------------#

Subprog GET_PDF_SIH(WNUM, WCPY, WBPRNAM, WYPATHPDF)
Value Char WNUM
Value Char WCPY
Value Char WBPRNAM
Value Char WYPATHPDF

  If WNUM="" : End : Endif

  Local Char    WDIR(255), NOMFIC(250), ORDSYS(255), TEMPFILE(255), URL(255)
  Local Integer STAT

  # <GON> Elimino la Razón Social del Nombre y la sociedad de la ruta
  ##WDIR = WYPATHPDF + WCPY + "\"
  WDIR = WYPATHPDF
  ##NOMFIC = toupper(WNUM + "_" + func YSENDPDF.REMOVE_FILENAME_CHARS(WBPRNAM, ""))
  NOMFIC = toupper(WNUM) ## + "_" + func YSENDPDF.REMOVE_FILENAME_CHARS(WBPRNAM, ""))
  ##If right$(NOMFIC, len(NOMFIC))<>"."
    NOMFIC += "."
  ##Endif
  # </GON>
  NOMFIC += "pdf"
  TEMPFILE = filpath(nomap + "/TMP/" + NOMFIC, "", "", "X3_PUB")
  ORDSYS = 'COPY "' + WDIR + NOMFIC + '" "' + TEMPFILE + '"'
  Call SYSTEME(adxmac(0), ORDSYS, "", STAT) From ORDSYS
  Call EXISTE(TEMPFILE, STAT) From ORDSYS
  If STAT=1
    URL = func AFNC.PARAM("YDIRPUBPDF", "")
    If URL="" : URL = GVIRTDIR : Endif
    If right$(URL, len(URL))<>"/"
      URL += "/"
    Endif
    URL += nomap + "/TMP/" + NOMFIC

    Callui RETOUR="" With "UIAction="    + chr$(1) + "OpenFile",
&                         "UILocalDir="  + chr$(1) + "HTTP",
&                         "UILocalFile=" + chr$(1) + URL
  Else
    GMESSAGE = "|" + WDIR + NOMFIC + "|.\"
    GMESSAGE+= mess(12,6002,1)
    Call ERREUR(GMESSAGE) From GESECRAN
    Raz GMESSAGE
  Endif
End

#------------------------------------------------------------------------------#

Funprog GET_FILTER(WCRIT)
Value Char    WCRIT

Local Char    NEWCRIT(250)
Local Integer I, J

  NEWCRIT = WCRIT

  I = instr(1, NEWCRIT, "[")
  While I
    J = instr(I+1, NEWCRIT, "]")
    If !J : Break : Endif
    NEWCRIT = left$(NEWCRIT, I-1) + right$(NEWCRIT, J+1)
    I = instr(J+1, NEWCRIT, "[")
  Wend

End NEWCRIT




