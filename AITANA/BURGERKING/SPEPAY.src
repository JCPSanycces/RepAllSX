#####################################################################################
#- BK65. Filtrar Pagos <> P422 (MAB08082016)
######################################################################################
$ACTION

  Case ACTION
    When "FILGAUCHE" : Gosub FILGAUCHE # BK65.NEW
    When "OUVRE" :  Gosub OUVRE
    When "LIENS" :  Gosub LIENS
    When "APRES_MODIF": Gosub APRES_MODIF
    When "APRES_CHOI" : Gosub APRES_CHOI
    When "MODIF" :  Gosub MODIF
    #When "SETTRANS" : Gosub SETTRANS

   # When "ANNULE" : Gosub ANNULE
    When Default
  Endcase
Return

#$SETTRANS
#  Infbox GFLAG
#Return
######################################################################################
$OUVRE
  If !clalev([F:PIH])  : Local File PINVOICE [PIH] : Endif # Tabla Facturas



Return
######################################################################################
$LIENS
  Gosub CARGAR_DATOS_FACTURAS

Return

######################################################################################
#**
#*  Cargar datos extendidos Planta
#*!
$CARGAR_DATOS_FACTURAS

Return

######################################################################################
$APRES_MODIF

Return

$APRES_CHOI
    Case REPONSE
      When GSTACRE: Gosub GSTACRE

    Endcase
Return
######################################################################################
$GSTACRE
    Gosub  GRABAR_DATOS_FACTURAS

Return
######################################################################################
$MODIF

  Gosub  GRABAR_DATOS_FACTURAS

Return

######################################################################################
#**
#*
#*!
$GRABAR_DATOS_FACTURAS
  Local Integer I
  Local Integer ID

If GFLAG <> "SETRA" and GFLAG <> "SCTRA" and GFLAG <> 'SPCOB' Then # and GFLAG <> 'SPPAG' Then

  For I = 0 To [M:PAY1]NBLIG-1
    # Infbox [M:PAY1]VCRNUM(I) + " - " + [M:PAY1]FCY(I) + " - " + [M:PAY1]VCRTYP(I)
    #Filter [PIH] Where NUM = [M:PAY1]VCRNUM(I) and FCY = [M:PAY1]FCY(0) # and GTE = [M:PAY1]VCRTYP(I)
    Filter [PIH] Where NUM = [M:PAY1]VCRNUM(I) and FCY = [M:PAY1]FCY(0) and GTE = [M:PAY1]VCRTYP(I)

    Read [PIH] First

    If fstat = 0 Then

        [M:PAY1]ZBPRVCR(I) = [F:PIH]BPRVCR
    Endif

  Next
 Affzo [M:PAY1]

Elsif GFLAG = "SETRA" or GFLAG = 'SPCOB' Then

  For I = 0 To [M:PAY2]NBLIG-1
      # Infbox [M:PAY1]VCRNUM(I) + " - " + [M:PAY1]FCY(I) + " - " + [M:PAY1]VCRTYP(I)
      #Filter [PIH] Where NUM = [M:PAY1]VCRNUM(I) and FCY = [M:PAY1]FCY(0) # and GTE = [M:PAY1]VCRTYP(I)
      Filter [PIH] Where NUM = [M:PAY2]VCRNUM(I) and FCY = [M:PAY2]FCYLIN(I) and GTE = [M:PAY2]VCRTYP(I)

      Read [PIH] First

      If fstat = 0 Then

          [M:PAY2]ZBPRVCR(I) = [F:PIH]BPRVCR
      Endif

    Next
   Affzo [M:PAY2]


Endif
Return

# BK65.NEW
$FILGAUCHE
  # Infbox GABREV # NOMBRE DE OBJETO
  # Infbox GBOITE # NOMBRE DE VENTANA
  # Infbox GFLAG  # NOMBRE DE TRANSACCI粍
  FILGAUSUP='SAC <> "P422" AND SAC <> "P419"'


Return



