Subprog PROCESAR_NOTAS_GASTOS()
  Call OUVRE_TRACE("Proceso rellenado de tabla auxiliar") From LECFIC
  Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
  Call ECR_TRACE("Proceso de creación de Facturas", 0) From GESECRAN
  Call GENERAR_FACTURAS_NOTAS_GASTO()
 # Call ECR_TRACE("Proceso de creación de Pagos de Facturas de Notas de gasto", 0) From GESECRAN
 # Call GENERAR_PAGOS_FAC_FNG()
 # Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
 # Call ECR_TRACE("Fin del proceso de importación de Pagos nóminas", 0) From GESECRAN
  Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE() From LECFIC
End


#**
#* Creación de facturas de notas de gasto
#*!
Subprog GENERAR_FACTURAS_NOTAS_GASTO()

   Local Char ZDATETIME
   Local Char LNOMBRE_FICHERO(70)
   Local Integer SUCCESS # 1 = failed, 2 = successful
   Local Char MESSAGE # error message, if failed
   Local Integer STAT
   Local Integer CONTADOR
   SUCCESS= 1
   CONTADOR = 0
   # Controlar que no existe una factura creada con el mismo zcif y mismo ZDocumentoOrigen
   # Si ya existe, no crear la factura
   # If clalev([F:ZPINV]) = 0 : Local File PINVOICE [F:ZPINV]  : Endif


  If clalev([F:ZEXS3]) = 0 : Local File EXPENSES [F:ZEXS3]  : Endif

  Filter [ZEXS3] Where ZSTATUS <> '1' and [ZEXS3]ZCIF <> '' and [ZEXS3]ZRAZONSOCIAL <> '' and [ZEXS3]ZDOCORIGEN <> '' and [F:ZEXS3]VAT <> ''

  Call ECR_TRACE("Proceso de creación de Facturas - Facturas a crear: " + num$(rowcount([ZEXS3])), 0) From GESECRAN
#  Infbox num$(rowcount([ZEXS3]))

  For [F:ZEXS3]

    If  [F:ZEXS3]ZCIF <> '' and [F:ZEXS3]ZRAZONSOCIAL <> '' and [F:ZEXS3]ZDOCORIGEN <> '' and num$([F:ZEXS3]ZACCDAT) <> '00000000'  Then

       Call ECR_TRACE("Proceso de creación de Facturas - Factura a crear: " + num$(CONTADOR), 0) From GESECRAN
#      Filter [F:ZPINV] Where ZCIF = [M:EXS0]ZCIF(I) and BPRVCR = [M:EXS0]ZDOCORIGEN(I) and FCY = [M:EXS0]FCY(I) and CPY = [M:EXS0]CPY(I)
      # No existen facturas creadas iguales, por lo tanto se puede generar una nueva
      # Infbox "Factura a crear: " + [M:EXS0]ZDOCORIGEN(I) + " Registros encontrados: " + num$(rowcount([ZPINV]))
#      If rowcount([ZPINV]) = 0 Then

        ZDATETIME = time$
        ZDATETIME = mid$(ZDATETIME,1,2)+mid$(ZDATETIME,4,2)+mid$(ZDATETIME,7,2)
        ZDATETIME = date$+ZDATETIME

        If [F:ZEXS3]AMTATI < 0 Then
          LNOMBRE_FICHERO = "FICANG_"+ZDATETIME+"_"+num$(CONTADOR)
        Else
          LNOMBRE_FICHERO = "FICFNG_"+ZDATETIME+"_"+num$(CONTADOR)
        Endif

        #Infbox "DENTRO DE CREACION DE FICHERO " + LNOMBRE_FICHERO
        # Call CREAR_FACTURA(LNOMBRE_FICHERO) From ZSPEIMPEXS
        # Call CREAR_FACTURA(LNOMBRE_FICHERO, I)

       # GSERVEUR=1
        Call ECR_TRACE("Proceso de creación de Facturas - Creación fichero import: " + LNOMBRE_FICHERO, 0) From GESECRAN

        Gosub CREAR_FACTURA

        Call ECR_TRACE("Proceso de creación de Facturas - Nota de gasto procesada. Llamada a IMPORT", 0) From GESECRAN
#        Infbox "REGISTRO GRABADO"

        GERRTRACE = 0
        Call IMPORTSIL("XBIS2", filpath("IMP", LNOMBRE_FICHERO, "csv",nomap)) From GIMPOBJ
        Call ECR_TRACE("Proceso de creación de Facturas - Import lanzado", 0) From GESECRAN
        Call ECR_TRACE("Proceso de creación de Facturas - Nota de gasto procesada. ERRORES IMPORT: " + num$(GERRTRACE), 0) From GESECRAN


        #Call ERR_IMPORT(STAT, MESSAGE) From GIMPOBJ
        #Infbox num$(STAT)
        #Infbox MESSAGE
        #If STAT or GOK < 1 Then
        #  Call ECR_TRACE("Proceso de creación de Facturas - Error - Factura no creada", 0) From GESECRAN
        #Else
        If GERRTRACE = 0 Then
            Call ECR_TRACE("Proceso de creación de Facturas - FACTURA CREADA", 0) From GESECRAN
            Trbegin [F:ZEXS3]
            Readlock [ZEXS3]
            [F:ZEXS3]ZSTATUS = '1'
            Rewrite
            Commit
       Else
          Call ECR_TRACE("Proceso de creación de Facturas - SIN CREACIÓN DE FACTURA", 0) From GESECRAN
       Endif


        CONTADOR+=1

     Endif


  Next
  #If clalev([F:ZEXS4]) = 0 : Local File EXPENSES [F:ZEXS4]  : Endif
  #Update [F:ZEXS4] Where CLB = [M:EXS0]CLB With ZSTATUS = '1', ZCIF = mid$(ZCIF,2,len(ZCIF))
  Close File [ZEXS3]
  #Close File [ZEXS4]

  Call ECR_TRACE("Fin Proceso de creación de Facturas", 0) From GESECRAN
End


$CREAR_FACTURA
  Local Char FICEXP
  Local Char LCUENTA
  Local Char LCUENTA_ANALITICA
  Local Char PLAN1, PLAN2
  Local Char LTIPO_FACTURA
  Local Char LZCIF, LREGIMEN

  # If clalev([F:CAC]) = 0 : Local File GACCCODE [F:CAC]  : Endif
  # If clalev([F:CAC2]) = 0 : Local File GACCCODE [F:CAC2]  : Endif
  # If clalev([F:TES]) = 0 : Local File TABEXPENS [F:TES]  : Endif

  FICEXP = LNOMBRE_FICHERO
  # Creacion de fichero BAT
  # Infbox "Crear fichero"

  # Infbox "CREAR_InVERSIÓN:ref " + PNUM + " - MODELO :" + PMODELO_IMPORT
  # Infbox "ltyp:" + LTYP + " - FCY: " + LFCY
  adxifs=';'
  adxirs = chr$(13) + chr$(10)

  If [F:ZEXS3]AMTATI < 0 Then
    LTIPO_FACTURA = 'ANG'
  Else
    LTIPO_FACTURA = 'FNG'
  Endif

  If clalev([F:ZATA]) = 0 : Local File ATABDIV [F:ZATA] :Endif
  Filter [F:ZATA] Where NUMTAB = 6007 and CODE = [F:ZEXS3]VAT
  Read [F:ZATA] First
  If !fstat Then
    LREGIMEN = [F:ZATA]A1
  Endif
  Close File [ZATA]

  If mid$([F:ZEXS3]ZCIF,1,1) = "~" Then
    LZCIF = mid$([F:ZEXS3]ZCIF,2,len([F:ZEXS3]ZCIF))
  Else
    LZCIF = [F:ZEXS3]ZCIF
  Endif

  Openo filpath("IMP", FICEXP, "csv",nomap)
  # Infbox "DOC ORIGEN:" + [F:EXS]ZDOCORIGEN
  Wrseq 'T',LTIPO_FACTURA,'','NGEN',[F:ZEXS3]CPY,[F:ZEXS3]FCY,[F:ZEXS3]DATEXS,[F:ZEXS3]ZDOCORIGEN,[F:ZEXS3]ZACCDAT,[F:ZEXS3]CUR, [F:ZEXS3]TYPRAT,[F:ZEXS3]RATDAT
& ,'NGEN',[F:ZEXS3]ZACCDAT,LREGIMEN,ctrans(num$(abs([F:ZEXS3]AMTPAY)),".",","),
& ctrans(num$(abs([F:ZEXS3]AMTATI)),".",","), LZCIF, [F:ZEXS3]ZRAZONSOCIAL

  LCUENTA = "555001"            # Eliana(EY) me dice que ponga esta cuenta directamente (22/11/2018)
  LCUANTA_ANALITICA = "555001"  # Eliana(EY) me dice que ponga esta cuenta directamente (22/11/2018)

   If [F:ZEXS3]FCY = "2000" Then
     PLAN1 = "PBC"
     PLAN2 = "PBA"
   Else
      PLAN1 = "PGC"
      PLAN2 = "PGA"
   Endif

  Wrseq 'L','1',[F:ZEXS3]FCY,PLAN1,PLAN2,'COM','USG',LCUENTA,LCUENTA_ANALITICA,'','','NGEN','',ctrans(num$(abs([F:ZEXS3]AMTPAY)),".",","),[F:ZEXS3]VAT,'','','',''

  Wrseq 'A','1','CCT','ARS','FAM','DEP','CDV','','','','','','','',ctrans(num$(abs([F:ZEXS3]AMTPAY)),".",","),''

  # [F:EXS]TYPRAT

  Openo
  Call ECR_TRACE("Proceso de creación de Facturas - Fichero creado: " + LNOMBRE_FICHERO, 0) From GESECRAN
Return



#**
#* Proceso de creación de los pagos de las facturas FNG
#* generadas desde las notas de gasto
#*!
Subprog GENERAR_PAGOS_FAC_FNG()
  Local Char ZDATETIME
  Local Char LNOMBRE_FICHERO

      ZDATETIME = time$
      ZDATETIME = mid$(ZDATETIME,1,2)+mid$(ZDATETIME,4,2)+mid$(ZDATETIME,7,2)
      ZDATETIME = date$+ZDATETIME
      # Infbox ZDATETIME
      #LNOMBRE_FICHERO = "FICPFNG_"+ZDATETIME
    # ABRIR FACTURAS DE COMPRA
    If clalev([F:ZPINV]) = 0 : Local File PINVOICE [F:ZPINV]  : Endif


    # Buscar las facturas Validadas, SIN PROCESAR, de tipo FNG, y del ngen
    Filter [ZPINV] Where STA = 3 and ZSTATUSPAY = '' and (PIVTYP = 'FNG' or PIVTYP = 'ANG') and BPR = 'NGEN'
    For [ZPINV]
      If [ZPINV]PIVTYP = 'FNG' Then
        LNOMBRE_FICHERO = "FICPFNG_"+ZDATETIME
      Else
        LNOMBRE_FICHERO = "FICPANG_"+ZDATETIME
      Endif

      Call GENERA_PAGO([ZPINV]NUM, [ZPINV]PIVTYP,  [ZPINV]FCY, [ZPINV]AMTATI, [ZPINV]ACCDAT, [ZPINV]LED(0), LNOMBRE_FICHERO)
      #Call CREAR_JOB(LNOMBRE_FICHERO, 'ZPAY') From ZSPEIMPEXS
      Call IMPORTSIL("ZPAY", filpath("IMP", LNOMBRE_FICHERO, "csv",nomap)) From GIMPOBJ
      [ZPINV]ZSTATUSPAY = '2'
      Rewrite
    Next
    Close File [ZPINV]

End

#**
#* Creación del fichero import
#*
#* @param PNUM
#* @param PFCY
#* @param PAMTATI
#* @param PACCDAT
#* @param PLED
#*!
Subprog GENERA_PAGO(PNUM, PTYPVCR, PFCY, PAMTATI, PACCDAT, PLED, PNOMBRE_FICHERO)
 Local Char FICEXP
 Local Char LTIPO_TRAN
 Local Char LTIP
 Local Char LTYPFIC, LTIPMOV, LCAJA

  FICEXP = PNOMBRE_FICHERO
  # Creacion de fichero BAT
  # Infbox "Crear fichero"

  # Infbox "CREAR_InVERSIÓN:ref " + PNUM + " - MODELO :" + PMODELO_IMPORT
  # Infbox "ltyp:" + LTYP + " - FCY: " + LFCY
  adxifs=';'
  adxirs = chr$(13) + chr$(10)

  Openo filpath("IMP", FICEXP, "csv",nomap)

  If PTYPVCR = "ANG" Then

    LTIP = 'SCCH'
    LTIPO_TRAN = 'COBRO'
    LTYPFIC = 'ANG'
    If PFCY = '2000' Then
       LCAJA = 'SPCH'
    Else
       LCAJA = 'SPCHT'
    Endif
    LTIPMOV = '2'
  Else
    LTIPMOV = '1'
    LTIP = 'SPCH'
    LTIPO_TRAN = 'PAGO'
    LTYPFIC = 'FNG'
    If PFCY = '2000' Then
       LCAJA = 'SPCH'
    Else
       LCAJA = 'SPCHT'
    Endif

  Endif


  Wrseq 'P','',LTIP,'','NGEN',PLED,'410100','','CH',PFCY,LCAJA,LTIPMOV,'EUR',ctrans(num$(abs(PAMTATI)),".",","), PACCDAT
  Wrseq 'D',LTIPO_TRAN,PLED,'410100','NGEN',LTYPFIC,PNUM,'EUR',ctrans(num$(abs(PAMTATI)),".",",")

  Openo

End

Subprog EJECUTAR_IMPORT(PFILE, PMODELO)

  Local Char PARAM(15)(1..4) , VALEUR(15)

  Gosub INIT From GIMPOBJ

  Gosub DEBUT From GIMPOBJ
  Gosub OK_SAI From GIMPOBJ
  Gosub CONTROLE From GIMPOBJ

  [M:IMP2]MODIMP = PMODELO
  [M:IMP2]NOMIMP = PFILE

  Gosub EXEC From GIMPOBJ
  Gosub TERMINE From GIMPOBJ

  If GERRTRACE = 1 and GERRTRACE = 3 Then
    Errbox "Errores en la generación de los asientos. Revise la traza", "Revisar la traza " + GTRACE Titled "Import YCOM"
    Call LECFIC("TRA",GTRACE,"tra") From LECFIC
  Endif
End

