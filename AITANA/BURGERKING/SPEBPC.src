$ACTION
#addon Envio documentos PDF
If func AFNC.ACTIV("YDPDF") : Gosub ACTION From YDPDFSPEBPC : Endif
  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "LIENS"        : Gosub LIENS
    When "STYLE"        : Gosub STYLE
    When "MODIF"        : Gosub MODIF
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "SETBOUT"      : Gosub SETBOUT
    When "APRES_CRE"  : Gosub APRES_CRE
    When Default
  Endcase
Return


######################################################################################
$SETBOUT
  #Y0007
#  Gosub SETBOUT  From SPECNTC
  #fin Y0007
Return

######################################################################################
$OUVRE
Return

######################################################################################
$LIENS
  #Y0007
#  Gosub INICIALIZA_MEDIOS  From SPECNTC
  #fin Y0007
Return

######################################################################################
$STYLE
  #Y0007
#  LINEA_CONTACTO = 1
#  Gosub MUESTRA_MEDIOS_LINEA_CONTACTOS From SPECNTC
  #fin Y0007
Return

######################################################################################
$APRES_MODIF
  #Y0007
#  Gosub ACTUALIZA_BUFFER_MEDIOS From SPECNTC
  #fin Y0007
  Gosub ACTUALIZA_DOCTYP
Return

######################################################################################
$MODIF
  #Y0007
#  Gosub SALVAR_BUFFER_MEDIOS From SPECNTC
  #fin Y0007
Return
######################################################################################
$APRES_CRE
  Gosub ACTUALIZA_DOCTYP
Return
######################################################################################
$ACTUALIZA_DOCTYP
  If !clalev([F:YBPR]) : Local File BPARTNER [YBPR] : Endif
  If !clalev([F:YTCY]) : Local File TABCOUNTRY [YTCY] : Endif
  Read [F:YBPR]BPR0=[M:BPC0]BPCNUM
  If !fstat
    If [F:YBPR]DOCTYP=0
      Infbox "PASA"
      If [M:BPRC]CRY ='ES'
        [F:YBPR]DOCTYP=1
        Rewrite [F:YBPR]
      Else
        Read [F:YTCY]TCY0=[M:BPRC]CRY
        If !fstat
          If [F:YTCY]EECFLG = 2 and [F:YBPR]EECNUM<>''
            [F:YBPR]DOCTYP=2
            Rewrite [F:YBPR]
          Endif
          If [F:YTCY]EECFLG = 2 and [F:YBPR]EECNUM=''
            [F:YBPR]DOCTYP=6
            Rewrite [F:YBPR]
          Endif
          If [F:YTCY]EECFLG <> 2
            [F:YBPR]DOCTYP=6
            Rewrite [F:YBPR]
          Endif
        Endif
      Endif
    Endif
  Endif
  Close Local File [YBPR]
  Close Local File [YTCY]
Return

