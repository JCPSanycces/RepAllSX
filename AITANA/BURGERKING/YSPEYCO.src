#<AdxTL>@(#)0.0.0.0 $Revision$
########################################
$RAZCRE

#inicializamos la planta con la planta por defecto de compra
If GFCYDEF(6)<> ''
  [M:YCO0]YFCY = GFCYDEF(6)
  Affzo [M:YCO0]YFCY
Endif

#inicializamos el departamento con el indicado en la ficha del usuario
If clalev([F:AUS])=0 Local File AUTILIS [AUS] : Endif

Read [AUS]CODUSR = GUSER
If fstat = 0
  [M:YCO0]YDEPT = [F:AUS]YDEPT
  [M:YCO0]YSUBDEPT = [F:AUS]YSUBDEPT
  Affzo [M:YCO0]YDEPT
  Affzo [M:YCO0]YSUBDEPT
Endif


#Inicializamos campo firma
[M:YCO0]YAPPFLG=1
Affzo [M:YCO0]YAPPFLG

#Inicializamos campo estado
[M:YCO0]YESTADO=1
Affzo [M:YCO0]YESTADO


Return
########################################
$RAZDUP

#inicializamos la fecha de próximo pedido con la fecha de pedido
[M:YCO3]YNEXPOHDAT = [M:YCO2]YFECPED
Affzo [M:YCO3]YNEXPOHDAT

#Inicializamos campo firma
[M:YCO0]YAPPFLG=1
Affzo [M:YCO0]YAPPFLG

#Inicializamos campo estado
[M:YCO0]YESTADO=1
Affzo [M:YCO0]YESTADO

Return
########################################
$VERIF_CRE

#Controlamos que fecha de pedido se encuentre en un periodo abierto

If clalev([F:FCY])=0 Local File FACILITY   [FCY] : Endif
If clalev([F:FIY])=0 Local File FISCALYEAR [FIY] : Endif
If clalev([F:PER])=0 Local File PERIOD     [PER] : Endif


Local Decimal EXERCICE , PERIODE

Read [F:FCY]FCY0 = [M:YCO0]YFCY

Call GETPERSOC([F:FCY]LEGCPY,1,[M:YCO2]YFECPED,EXERCICE,PERIODE) From CPTSUB

#-------Fecha incorrecta------#
If EXERCICE=0 | PERIODE=0 GERR=1: GMESSAGE=mess(1,104,1)  :  OK=0 : Endif
Read [FIY] FIY0=[F:FCY]LEGCPY;1;EXERCICE : If fstat Raz [F:FIY] : Endif
Read [PER]PER0=[F:FCY]LEGCPY;1;EXERCICE;PERIODE : If fstat Raz [F:PER] : Endif
#----- Ejercicio no abierto
If [F:FIY]FIYSTA<>2       GERR=1: GMESSAGE='Ejercicio Fecha pedido cerrado' : OK=0 : Endif
#-----Periodo no abierto
If [F:PER]PERSTA<2        GERR=1 :GMESSAGE='Periodo Fecha pedido no abierto': OK=0 : Endif
#------- Periodo cerrado
If [F:PER]PERSTA>2        GERR=1 :GMESSAGE='Periodo Fecha pedido cerrado'   : OK=0 : Endif

#Validar cohererencia de régimen impuesto del documento con los de las secciones

Gosub VALIDAR_REGIMEN

Return
########################################
$LIENS

#visualizar pedidos de ese contrato

Local Decimal YTOTALINC : Raz YTOTALINC

If !clalev([F:YPOH])   Local File PORDER [YPOH] : Endif

Local Integer INBPOH : Raz INBPOH

Filter [YPOH] Where [F:YPOH]YCONNUM=[M:YCO0]YCONNUM Order By [F:YPOH]ORDDAT Asc
  For [YPOH]
    If INBPOH >= dim([M:YCO3]YPOHNUM)-1 Then
      Break
    Endif
    [M:YCO3]YPOHNUM(INBPOH) = [F:YPOH]POHNUM
    [M:YCO3]ORDDAT(INBPOH)  = [F:YPOH]ORDDAT
    [M:YCO3]TTVORDL(INBPOH) = [F:YPOH]TTVORDL
    [M:YCO3]TOTORDL(INBPOH) = [F:YPOH]TOTORDL
    INBPOH    +=1
    YTOTALINC += [F:YPOH]TOTORDL
  Next
Filter [YPOH]

[M:YCO3]NBPOH = INBPOH

#mostramos total incurrido
[M:YCO3]YTOTALINC = YTOTALINC

Affzo [M:YCO3]


Return
########################################
$SETBOUT

#Si está en definitivo no lo dejamos borrar
If  [M:YCO0]YESTADO = 2
  Call VIREBOUT (CHAINE, "A") From GOBJET
Endif

#Grisear período si el contrato no es recurrente
If [M:YCO0]YESTADO = 1
  If [M:YCO0]YRECUR = 1
    Diszo [M:YCO0]YPERIODO
  Else
    Actzo [M:YCO0]YPERIODO
  Endif
Endif

#Si está en definitivo deshabilitamos todo menos el importe AI de las líneas
#o parcialmente firmado

If [M:YCO0]YESTADO = 2 or [M:YCO0]YAPPFLG>1
# la YCO1 en pantalla con condición de entrada, quieren poder meter cantidad
  Diszo [M:YCO0] : Diszo [M:YCO2] : Diszo [M:YCO3]
  Actzo [M:YCO0]YCONNUM
Else
  Actzo [M:YCO0] : Actzo [M:YCO1] : Actzo [M:YCO2] : Actzo [M:YCO3]
Endif


Return
######################################################################################
Subprog AS_LINDSP(VALEUR)
Variable Char    VALEUR()


End
##############################################
Subprog AM_LINDSP(VALEUR)
Variable Char    VALEUR()

#Si introducen la distribucción borramos contenido secciones

If VALEUR <> ''
  [M:YCO1]CCE1(nolign-1) = ''
  [M:YCO1]CCE3(nolign-1) = ''
  Affzo [M:YCO1]CCE1(nolign-1)
  Affzo [M:YCO1]CCE3(nolign-1)
Endif

End

######################################################################################
Subprog AM_YFECPED(VALEUR)
Variable Date    VALEUR

# la fecha de pedido inicializa la fecha de próximo pedido
[M:YCO3]YNEXPOHDAT = VALEUR
Affzo [M:YCO3]YNEXPOHDAT

End

######################################################################################
Subprog AM_YFECIVIG(VALEUR)
Variable Date    VALEUR

#la fecha de inicio de vigencia inicializa
#fecha de pedido
#fecha de puesta en servicio
#fecha de próximo pedido

[M:YCO2]YFECPED    = VALEUR
[M:YCO2]YFECSERV   = VALEUR
[M:YCO3]YNEXPOHDAT = VALEUR
Affzo [M:YCO2]YFECPED
Affzo [M:YCO2]YFECSERV
Affzo [M:YCO3]YNEXPOHDAT

End
######################################################################################
Subprog AM_YFECFVIG(VALEUR)
Variable Date    VALEUR

If VALEUR >= addmonth([M:YCO2]YFECIVIG,12)
  GMESSAGE = "Fec F. Vig. no puede ser 12 meses superior a F. I. Vig." : mkstat=2
  End
Endif

[M:YCO2]YFECPRE    = addmonth(VALEUR,-2)
Affzo [M:YCO2]YFECPRE

[M:YCO2]YFECFSERV  = VALEUR
Affzo [M:YCO2]YFECFSERV

End

######################################################################################
Subprog AM_YRECUR(VALEUR)
Variable Integer VALEUR

If VALEUR = 1
  [M:YCO0]YPERIODO = 0
Endif

End
######################################################################################
Subprog AM_YBPSNUM(VALEUR)
Variable Char    VALEUR()


If clalev([F:YBPS])=0 Local File BPSUPPLIER [YBPS] : Endif

Read [F:YBPS]BPS0 = VALEUR
If fstat = 0
  [M:YCO2]VACBPR = [F:YBPS]VACBPR
  [M:YCO2]CUR    = [F:YBPS]CUR
  [M:YCO2]PTE    = [F:YBPS]PTE
  Affzo [M:YCO2]VACBPR
  Affzo [M:YCO2]CUR
  Affzo [M:YCO2]PTE
Endif

End
######################################################################################
Subprog AM_YITMREF(VALEUR)
Variable Char    VALEUR()

If clalev([F:YITM])=0 Local File ITMMASTER [YITM] : Endif

Read [F:YITM]ITM0 = VALEUR
If fstat = 0
  Local Char  YVAT (GLONVAT) (0..2)

  Call ALITAXE([M:YCO2]VACBPR,[F:YITM]VACITM,YVAT)From TRTX3

  [M:YCO1]VAT1(nolign-1)= YVAT(0)
  [M:YCO1]VAT2(nolign-1)= YVAT(1)

  Affzo [M:YCO1]VAT1(nolign-1)
  Affzo [M:YCO1]VAT2(nolign-1)
Endif

End

######################################################################################
Subprog AM_LINAMT(VALEUR)
Variable Decimal VALEUR

If clalev([F:YAWS])=0 Local File AWRKHISSUI     [YAWS] : Endif

Filter [F:YAWS] Where [F:YAWS]CLEOBJ = [M:YCO0]YCONNUM
For [YAWS]
  If GUSER = [F:YAWS]USRSIG1 or
&    GUSER = [F:YAWS]USRSIG2 or
&    GUSER = [F:YAWS]USRSIG3 or
&    GUSER = [F:YAWS]USRSIG4 or
&    GUSER = [F:YAWS]USRSIG5 or
&    GUSER = [F:YAWS]USRSIG6 or
&    GUSER = [F:YAWS]USRSIG7 or
&    GUSER = [F:YAWS]USRSIG8 or
&    GUSER = [F:YAWS]USRSIG9
    Break 1
  Else
    GMESSAGE = "Usuario no puede modificar al no ser uno de los firmantes" : mkstat=2
    Break 1
  Endif
Next
Filter [F:YAWS]


End

########################################
$VALIDAR_REGIMEN

#comprobamos coherencia del régimen del documento con los de las provincias de los
#grupos de secciones de la sección de las línea y de las secciones de la distribucción

If clalev([F:YRTP])=0   Local File YREGTERPROH   [YRTP] : Endif
If clalev([F:YCRY])=0   Local File GCCEGRUPYM    [YCRY] : Endif
If clalev([F:YDSP])=0   Local File CADSP         [YDSP] : Endif

Read [F:YRTP]YRTP0=[M:YCO2]VACBPR
If fstat = 0
  For I=0 To [M:YCO1]NBLIG-1
    If [M:YCO1]CCE1(I) <>''
      Local Char YSECCION
      YSECCION=[M:YCO1]CCE1(I)

      Gosub VALIDAR_SECCION
    Endif
    If [M:YCO1]LINDSP(I)<>''
      Gosub VALIDAR_DISTRIBUCCION
    Endif
  Next I
Endif

Return

########################################
$VALIDAR_SECCION

Filter [F:YCRY] Where [F:YCRY]PYM='PROV' and [F:YCRY]CCE=YSECCION
For [F:YCRY]CRY0

  If [F:YCRY]YVACBPR=[F:YRTP]VACBPR1 or
&    [F:YCRY]YVACBPR=[F:YRTP]VACBPR2 or
&    [F:YCRY]YVACBPR=[F:YRTP]VACBPR3
    GERR=1 :GMESSAGE='Régimen documento '+[M:YCO2]VACBPR+' no es coherente con el de la sección '+YSECCION   : OK=0
    Break 1
  Endif

Next
Filter [YCRY]

Return
########################################
$VALIDAR_DISTRIBUCCION

Filter [F:YDSP] Where [F:YDSP]DSP=[M:YCO1]LINDSP(I)
For [F:YDSP]DSP0
  If [F:YDSP]DIE(0)='CCT'
    If [F:YDSP]CCE1<>''
      Local Char YSECCION
      YSECCION=[F:YDSP]CCE1

      Gosub VALIDAR_SECCION
    Endif
  Endif
Next
Filter [YDSP]

Return

