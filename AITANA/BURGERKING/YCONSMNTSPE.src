######################################################################################
Subprog AM_YDATINI(VALEUR)
Variable Date    VALEUR

[M:YCMNT0]YDATFIN = VALEUR
Affzo [M:YCMNT0]YDATFIN

End
######################################################################################
Subprog AM_YTIPOINI(VALEUR)
Variable Char VALEUR

[M:YCMNT0]YTIPOFIN = VALEUR
Affzo [M:YCMNT0]YTIPOFIN

End
######################################################################################
Subprog AM_YSTATUSINI(VALEUR)
Variable Integer VALEUR


[M:YCMNT0]YSTATUSFIN= VALEUR
Affzo [M:YCMNT0]YSTATUSFIN


End
######################################################################################
Subprog AM_YHORINI(VALEUR)
Variable Char    VALEUR()

[M:YCMNT0]YHORFIN= VALEUR
Affzo [M:YCMNT0]YHORFIN

End
#####################################################################################
Subprog C_YTIPOFIN(VALEUR)
Variable Char VALEUR

If VALEUR < [M:YCMNT0]YTIPOINI
 GMESSAGE = "Tipo fin inferior a inicio": mkstat = 2
Endif

End

######################################################################################
Subprog C_YSTATUSFIN(VALEUR)
Variable Integer VALEUR


If VALEUR < [M:YCMNT0]YSTATUSINI
 GMESSAGE = "Status fin inferior a inicio": mkstat = 2
Endif
End

######################################################################################
Subprog C_YDATFIN(VALEUR)
Variable Date    VALEUR

If VALEUR < [M:YCMNT0]YDATINI
 GMESSAGE = "Fecha fin inferior a inicio": mkstat = 2
Endif


End


######################################################################################
Subprog C_YHORFIN(VALEUR)
Variable Char    VALEUR()

If VALEUR < [M:YCMNT0]YHORINI
 GMESSAGE = "Hora fin inferior a inicio": mkstat = 2
Endif

End

######################################################################################
Subprog B2_NBLIG

Gosub BAJAR_ARCHIVO From YCONSMNTSPEA

End

######################################################################################
Subprog B3_NBLIG

Gosub REEMPLAZAR_ARCHIVO From YCONSMNTSPEA

End


######################################################################################
Subprog B4_NBLIG

Gosub REPROCESAR_ARCHIVO From YCONSMNTSPEA

End
