#<AdxTL>@(#)0.0.0.0 $Revision$
Call YPRUEBAERRORFTP
Infbox('Acaba prueba')
End
################################################################################################################
Subprog YPRUEBAERRORFTP
Local Char ORIGEN_DOSSIER(250)
ORIGEN_DOSSIER=filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER
Local Char ORIGEN(250)
Local Char PFICHERO(250)
Local Integer STAT

Infbox(ORIGEN_DOSSIER)
PFICHERO = "CONCIL_20190701084130_BKS"
#
Gosub COMPROBAR_ERRORES_FTP
#
End
################################################################################################################
$COMPROBAR_ERRORES_FTP
#comprobamos que el fichero log generado se haya pasado a Enviados
#si da error tarda un poco en pasar a enviados por lo que miramos durante 5 minutos
Local Integer WI
Local Integer WENCONTRADO
Local Integer WERROR
Local Char    WLINEA(250)

#Esperamos 5 segundos para que se muevan los ficheros
Sleep 5
#
Raz WENCONTRADO
Raz WERROR
#Si no se ha creado fichero csv no se genera tampoco fichero log
ORIGEN = ORIGEN_DOSSIER+"\IMP\Enviados\" + PFICHERO+".csv"
If filinfo(ORIGEN,7) < 0
  Return
Endif

ORIGEN = ORIGEN_DOSSIER+"\IMP\Enviados\" + PFICHERO+".log"
#Buscamos el fichero log en enviados
#Si ha dado error de ftp tarda en pasar de IMP a Enviados por lo que hacemos un bucle de unos 5 minutos
#Si en este tiempo no se ha generado el log enviamos los ficheros a un directorio de errores
Raz WI
##For WI = 1 To 100   #esperamos 5 minutos para comprobar si se ha pasado el fichero log
For WI = 1 To 5
  If filinfo(ORIGEN,7) >= 0  #-20 fichero no encontrado, -27 acceso denegado
    WENCONTRADO = 1
    WI = 100
  Endif
  If WENCONTRADO <> 1
    Sleep 3
  Endif
Next WI
#
#Comprobamos si en el log hay algún error
If WENCONTRADO = 1
  Openi ORIGEN Using [WFICHERO]
  Rdseq WLINEA Using [WFICHERO] #leer líneas
    While fstat=0
      If instr(0,WLINEA,"error")<>0 or instr(0,WLINEA,"Error")<>0
        WENCONTRADO = 3
      Endif
      Rdseq WLINEA Using [WFICHERO]
    Wend
  Openi Using [WFICHERO]
Endif
#
#Hay que mover los ficheros tanto si se ha encontrado la palabra error en el fichero log (WENCONTRADO = 3)
#como si no se ha encontrado fichero log (WENCONTRADO = 0)
If WENCONTRADO <> 1
  ORIGEN = ORIGEN_DOSSIER+"\IMP\Enviados\" + PFICHERO+".csv"
  DESTINO= ORIGEN_DOSSIER+"\IMP\Enviados\ERRORESFTP\"+PFICHERO+".csv"
  If filinfo(ORIGEN,7) >= 0
    Call MOVE (ORIGEN,DESTINO,STAT) From ORDSYS
  Else
    WERROR = 1
  Endif
#
  ORIGEN = ORIGEN_DOSSIER+"\IMP\Enviados\" + PFICHERO+".bat"
  DESTINO= ORIGEN_DOSSIER+"\IMP\Enviados\ERRORESFTP\"+PFICHERO+".bat"
  If filinfo(ORIGEN,7) >= 0
    Call MOVE (ORIGEN,DESTINO,STAT) From ORDSYS
  Else
    WERROR = 1
  Endif
#
  ORIGEN = ORIGEN_DOSSIER+"\IMP\Enviados\" + PFICHERO+".bak"
  DESTINO= ORIGEN_DOSSIER+"\IMP\Enviados\ERRORESFTP\"+PFICHERO+".bak"
  If filinfo(ORIGEN,7) >= 0
    Call MOVE (ORIGEN,DESTINO,STAT) From ORDSYS
  Else
    WERROR = 1
  Endif
#
  ORIGEN = ORIGEN_DOSSIER+"\IMP\Enviados\" + PFICHERO+".log"
  DESTINO= ORIGEN_DOSSIER+"\IMP\Enviados\ERRORESFTP\"+PFICHERO+".log"
  If filinfo(ORIGEN,7) >= 0
    Call MOVE (ORIGEN,DESTINO,STAT) From ORDSYS
  Else
    WERROR = 1
  Endif
#
  If WERROR = 1
    Call ECR_TRACE ("No se ha encontrado alguno de los ficheros en \IMP\Enviados\ al pasarlos a \IMP\Enviados\ERRORESFTP\",0)  From GESECRAN
  Endif
#
#Enviar mail si hay algún error
  Local Integer  WSTA
  Local Integer  WTRACE
  Local Char     FIC_TRACE(250)
  Local Char     ISSUERMAIL(250)
  Local Char     A_USER(250)(1..)
  Local Char     CC_USER(250)(1..)
  Local Char     HEADER(250)
  Local Clbfile  BODY(0)
  Local Char     ATTACHMENTS(250)(1..)
  A_USER(1)="mariajesus.bengoa@alivebc.com"
  CC_USER(1)="jon.erkoreka@alivebc.com"
  CC_USER(2)="asier.garcia@alivebc.com"
  HEADER="ZEXPCONCIL error en ftp fichero  " + PFICHERO
  ISSUERMAIL="comunicaciones.administracion@rbiberia.com"
  TRACE = 2

  Append BODY , 'Fichero log ' + ORIGEN_DOSSIER +"\IMP\Enviados\ERRORESFTP\"+PFICHERO+".log" +chr$(10)
  WSTA =func ASYRMAIL.ASEND_MAIL(GACTX,ISSUERMAIL,A_USER,CC_USER,HEADER,BODY,ATTACHMENTS,WTRACE)
  If WSTA <> CST_AOK Then
    Call ECR_TRACE ("Error envio mail errores fichero log " + PFICHERO,0)  From GESECRAN
  Else
    Call ECR_TRACE ("Enviado mail errores fichero log " + PFICHERO,0)  From GESECRAN
  Endif

Endif
Call ECR_TRACE ("Fin comprobar errores fichero log " + PFICHERO,0)  From GESECRAN
Return

