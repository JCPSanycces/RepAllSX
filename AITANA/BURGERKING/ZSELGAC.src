#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

  Case ACTION
    When "SEL_TABLE"  : Gosub $SEL_TABLE
    When "FIN_TABLE"  : Gosub $FIN_TABLE
    When Default
  Endcase
  Return


$SEL_TABLE
  If !clalev([ZACCPR]) Then : Local File ZACCPROV [ZACCPR] : Endif

  Local Char CRITERE1(255)

  Filter [F:ZACCPR] Where ZBPSNUM = [M:BIS0]BPR
  If rowcount([F:ZACCPR]) > 0 Then
  CRITERE1 = ""
  For [F:ZACCPR]
    If CRITERE1 <> "" Then
      CRITERE1 += " OR "
    Endif
    CRITERE1 = CRITERE1 + " ACC = '" + [F:ZACCPR]ZACC + "'" # AND [F:GAC]COA = '" + [F:ZACCPR]ZCOA + "') " # "[F:GAC]ACC in [F:ZGACP]GAC"
  Next
  Filter [F:ZACCPR]

  #Infbox CRITERE1

  Filter [F:GAC] Where evalue(CRITERE1)
  Endif


Return


$FIN_TABLE
  Filter [F:GAC]
  Return

