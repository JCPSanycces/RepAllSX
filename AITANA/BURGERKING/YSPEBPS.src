######################################################################################
$CARGAR_DEPARTAMENTO_ZONA
  #Y003
  Local Char CRITERE(255)

  [M:YBPS6]YNBLIG = 0
#  [M:YBPS6]YNBLIG2 = 0

  CRITERE = "BPSNUM = [M:BPS0]BPSNUM"

  ##Diszo [M:YBPS6]

  Filter [F:BPS] Where evalue(CRITERE)

  For [F:BPS]
    #CARGAR DEPARTAMENTOS
    If dim([F:BPS]YDEPTBK)>0 Then
      For I=0 To dim([F:BPS]YDEPTBK)-1
        If [F:BPS]YDEPTBK(I) <> '' Then
          [M:YBPS6]YNBLIG += 1
        Endif
      Next
    Endif

    #CARGAR ZONAS
#    If dim([F:BPS]YZONA)>0 Then
#      For I=0 To dim([F:BPS]YZONA)-1
#        If [F:BPS]YZONA(I) <> '' Then
#          [M:YBPS6]YNBLIG2 += 1
#        Endif
#      Next
#    Endif
  Next

  Filter [F:BPS]

  Affzo [M:YBPS6]
  #Fin Y003
Return

