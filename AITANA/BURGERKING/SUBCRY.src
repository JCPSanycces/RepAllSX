#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
#Y012 tomado de X3
#Y012 régimen de impuesto en grupo de sección
######################################################################################
# Gestion du Fenetre OCRY
Raz GPILOBJ
Raz GBIDC1, GBIDC2
Call OBJET("CRY",GBIDC1,GBIDC2) From GOBJET
End

######################################################################################
$ACTION
Case ACTION
 When "OUVRE"         : Gosub OUVRE
 When "OUVRE_BOITE"   : Gosub OUVRE_BOITE
 When "FIN"           : Gosub FIN

 When "LIENS2"        : Gosub LIENS2
 When "AVANT_ACT"     : Gosub AVANT_ACT
 When "CREATION"      : Gosub CREATION
 When "MODIF"         : Gosub MODIF
 When "AP_CHANGE"     : Gosub AP_CHANGE
 When "ANNULE"        : Gosub ANNULE

 When "GRISE"         : Gosub GRISE
 When "DEGRISE"       : Gosub DEGRISE
 When "EFFMASK"       : Gosub EFFMASK
 When "FILGAUCHE"     : Gosub FILGAUCHE
 When "FILTRE"        : Gosub FILTRE
 When "EXEBOUT"       : Gosub EXEBOUT
 When "STATUT"        : Gosub STATUT
 When "RAZCRE"        : Gosub RAZCRE
 When "RAZDUP"        : Gosub RAZDUP
 When "INICRE"        : Gosub INICRE
 When "INIMOD"        : Gosub INIMOD
 When "SETBOUT"       : Gosub SETBOUT
 When "AVANTBOUT"     : Gosub AVANTBOUT
 When "APRES_MODIF"   : Gosub APRES_MODIF
 When "FIN_ACTION"    : Gosub FIN_ACTION

 When "TIROIR"        : Gosub TIROIR
 When "PICKE"         : Gosub PICKE
 When "DEPICK"        : Gosub DEPICK

 When "SEL_TABLE"     : Gosub SEL_TABLE
Endcase
Return

#########################################################################
$OUVRE
Local Integer NGRU , NCCE , LIN , FLMODIF
Local Integer SAVGAUCHE , LEVPICK

If clalev([F:CRY0])=0 : Local File GCCEGRUPYM  [CRY0] : Endif :   # Groupes sections
If clalev([F:CRY2])=0 : Local File GCCEGRUPYM  [CRY2] : Endif :   # Groupes sections
If clalev([F:CYM])=0  : Local File GCCEPYM     [CYM]  : Endif :   # Pyramides sections
If clalev([F:CCE])=0  : Local File CACCE       [CCE]  : Endif :   # Sections
If clalev([F:DIE])=0  : Local File GDIE        [DIE]  : Endif :   # Axes
If clalev([F:CYK])=0  : Local File GCCEPYMLIK  [CYK]  : Endif :   # Liens Pyramides sections l
If clalev([F:CYP])=0  : Local File GCCEPYMPRT  [CYP]  : Endif :   # Liens Pyramides sections 2

Local Mask GRUPIK [PIK]
Default Mask [CRY1]

If !GIMPORT
 If CLE2<>""
  Read [CYM]CYM0 = CLE2
  If fstat
   CLE2 = ""
  Endif
 Endif
 If CLE2=""
  Read [CYM]CYM0 First
  CLE2 = [F:CYM]PYM
 Endif
 GBIDC1 = CLE2
 GBIDC2 = [F:CYM]DIE
 If CLE1=""
  Filter [CRY] Where PYM=CLE2
  Read [CRY]CRY0 First
  Filter [CRY]
  If !fstat
   CLE1 = [F:CRY]GRU
  Endif
 Endif
Endif
FLMODIF = 0
Return

#########################################################################
$CREATION
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$TEXTRA
If GREP="D"
 ## En duplication, on veut récupérer tous les intitulés traduisibles...
 Call DUPTEXTRA("GCCEGRUPYM","DESTRA",CLECUR2,CLECUR1,"GCCEGRUPYM","DESTRA",[M]PYM,[M]GRU)  From ATEXTRA
 Call DUPTEXTRA("GCCEGRUPYM","SHOTRA",CLECUR2,CLECUR1,"GCCEGRUPYM","SHOTRA",[M]PYM,[M]GRU)  From ATEXTRA
Endif
Call MAJTEXTRA([M]DESTRA,"GCCEGRUPYM","DESTRA",[M]PYM,[M]GRU) From ATEXTRA
Call MAJTEXTRA([M]SHOTRA,"GCCEGRUPYM","SHOTRA",[M]PYM,[M]GRU) From ATEXTRA
Return

#########################################################################
$OUVRE_BOITE
Local Integer BROWACC , BROWGRC
BROWACC = find("CCE",OBJLIS)-1
BROWGRC = find("PGR",OBJLIS)-1
[M:PIK]BOXACC  = "GAU_CHE"+num$(BROWACC)
[M:PIK]BOXGRC  = "GAU_CHE"+num$(BROWGRC)
Return

#########################################################################
$GRISE
Grizo VGRU
Return

$DEGRISE
Actzo VGRU
Return

$EFFMASK
If MA=0 | MA=1
 [M]VPYM = GBIDC1
 [M]VDIE = GBIDC2
 Affzo VPYM,VDIE
Endif
Return

$RAZCRE
[M]VPYM = GBIDC1
[M]VDIE = GBIDC2
Gosub LOAD_DIE
Gosub SETPICK
Return

$RAZDUP
Effzo 30,35
Gosub SETPICK
Return

$INICRE
$INIMOD
If dim([F:CRY]DES)>0
 [F:CRY]DES = [M:CRY1]DESTRA
Endif
Return

$LOAD_DIE
Call LECTURE("DIE",GBIDC2,"") From CONTOBJ
Return

$FILTRE
If GFONCTION="GESCRY" & zoncou<>"VCCE" & zoncou<>"VSBBGRU" & dim(CRITERE)>0
 If CRITERE<>"" : CRITERE += " & " : Endif
 CRITERE += '[F:CRY]PYM="'+GBIDC1+'"'
Endif
Return

$SETBOUT
CHMEN = ""
If GREP<>"" or TUNNEL or !instr(1,GUSRAUZ(1),"1")
 Call VIREBOUT(CHAINE,"1") From GOBJET
Endif
If GBIDC1="" or GBIDC2=""
 Call VIREBOUT(CHAINE,"AC") From GOBJET
Else
 If CLECUR & REP="" & VERROU
  CHAINE += "AH"
 Endif
Endif
#
Call LECTURE("DIE",[M:CRY1]VDIE,"") From CONTOBJ
If [F:DIE]ENV=2 | [F:DIE]ENT=2
 Call VIREBOUT(CHAINE,"M") From GOBJET :# No Modification Possible
Endif
#
If REP=""
 If instr(1,GUSRAUZ(1),"2") & ([F:DIE]ENV<>2 & [F:DIE]ENT<>2)
  CHMEN += "2"
 Endif
 If instr(1,GUSRAUZ(1),"3") & ([F:DIE]ENV<>2 & [F:DIE]ENT<>2)
  CHMEN += "3"
 Endif
 CHMEN += "4"
Endif
Return

$APRES_MODIF
If COUZON = "VGRU"
 COUZON = "GRU"
 [M]PYM = GBIDC1
 [M]GRU = [M]VGRU
Endif
Return

$AVANTBOUT
If BOUT = "3" : # Génération auto
 Filter [CRY] Where [F:CRY]PYM=[M]PYM
 Read [CRY]CRY0 First
 Filter [CRY]
 If !fstat
  # Groupes existants  pour cette pyramide
  OK = 2 : Call AVERTIR(mess(97,102,1),OK) From GESECRAN
  If OK<>2 : OK = 0 : Endif
 Endif
Endif
Return

$FIN
Gosub MAJ_LIENS
Return

$MAJ_LIENS
If FLMODIF & GBIDC1<>""
 Call TEMPON("V") From GESECRAN
 Call PYRAMPRT(GBIDC1,GBIDC2,nomap) From LIENPYRCCE
 Call PYRAMLIK(GBIDC1,GBIDC2,nomap) From LIENPYRCCE
 Call TEMPOFF From GESECRAN
 FLMODIF = 0
Endif
Return

$FIN_ACTION
If find(REPONSE,GSTAANU,GSTACHG)
 FLMODIF = 1
Endif
Return

#########################################################################
## Transfert Tableau invisible => Tableaux visibles  (lecture)
#########################################################################
$LIENS2
Call LECTURE("CYM",[M]PYM,"") From CONTOBJ
[M]PYM  = [F:CYM]PYM
[M]VPYM = [F:CYM]PYM
[M]DIE  = [F:CYM]DIE
[M]VDIE = [F:CYM]DIE
Call LECTURE("DIE",[M]DIE,"") From CONTOBJ
NGRU = -1
NCCE = -1
[M]VGRU    = [M]GRU(0)
Call LECTEXTRA([M]DESTRA(0),"GCCEGRUPYM","DESTRA",[M]PYM(0),[M]GRU(0)) From ATEXTRA
Call LECTEXTRA([M]SHOTRA(0),"GCCEGRUPYM","SHOTRA",[M]PYM(0),[M]GRU(0)) From ATEXTRA
[M]VDESTRA = [M]DESTRA(0)
[M]VSHOTRA = [M]SHOTRA(0)
[M]VLEV    = [M]LEV(0)
[M]VPRNROW = [M]PRNROW(0)
[M]VBUDTRK = [M]BUDTRK(0)
#Y012
[M]VYVACBPR = [M]YVACBPR
#Y012
For  I=0 To [M]LIN-1
 If [M]SBBGRU(I) = ""
  NCCE += 1
  [M]VCCE(NCCE) = [M]CCE(I)
  Read [CCE]CCE0 = [M]DIE;[M]CCE(I)
  If !fstat
   Call LECTEXTRA([M]VDESCCE(NCCE),"CACCE","DESTRA",[M]DIE,[M]CCE(I)) From ATEXTRA
  Endif
 Else
  NGRU += 1
  [M]VSBBGRU(NGRU) = [M]SBBGRU(I)
  Read [CRY0]CRY0(2) = [M]PYM;[M]SBBGRU(I)
  If !fstat
   Call LECTEXTRA([M]VDESGRU(NGRU),"GCCEGRUPYM","DESTRA",[M]PYM,[M]SBBGRU(I)) From ATEXTRA
  Endif
 Endif
Next I
[M]VNBRGRU = NGRU+1
[M]VNBRCCE = NCCE+1
Read [CRY]CRY2(2) = [M]PYM;[M]VGRU
If !fstat
 [M]VPERE = [F:CRY]GRU
 Call LECTEXTRA([M]VPDES,"GCCEGRUPYM","DESTRA",[M]PYM,[F:CRY]GRU) From ATEXTRA
Else
 [M]VPERE = ""
 [M]VPDES = ""
Endif
Read [CRY]CRY0(2) = [M]PYM;[M]VGRU
If currbox=[M:PIK]BOXGRC & [M]VLEV<>LEVPICK
 Gosub TIROIR
Else
 Gosub SETPICK
Endif
Return

#########################################################################
## Transfert Tableaux visibles => Tableau invisible  (écriture)
#########################################################################
$AVANT_ACT
Case BOUT
 When "E", "C" : # Enregistrer, créer
  If ([M]VNBRCCE=0 and [M]VNBRGRU=0)
   Call MESSAGE(mess(178,123,1)) From GESECRAN  : # Il doit y avoir au moins une ligne
   OK = 0
  Else
   Gosub UPDATE_INVISIBLE
   FLMODIF = 1
  Endif
Endcase
Return

$UPDATE_INVISIBLE
LIN = -1
Raz [M]PYM,GRU,SHOTRA,DESTRA,LEV,BUDTRK,CCE,SBBGRU
For I=0 To [M]VNBRGRU-1
 LIN += 1
 Gosub FILLCOLUMNS
 [M]SBBGRU(LIN) = [M]VSBBGRU(I)
 [M]CCE(LIN)    = ""
Next I
For I=0 To [M]VNBRCCE -1
 LIN += 1
 Gosub FILLCOLUMNS
 [M]CCE(LIN)    = [M]VCCE(I)
 [M]SBBGRU(LIN) = ""
Next I
[M]LIN = LIN+1
Return

$FILLCOLUMNS
[M]PYM(LIN)    = [M]VPYM
[M]GRU(LIN)    = [M]VGRU
[M]SHOTRA(LIN) = [M]VSHOTRA
[M]DESTRA(LIN) = [M]VDESTRA
Call MAJTEXTRA([M]DESTRA(LIN),"GCCEGRUPYM","DESTRA",[M]PYM(LIN),[M]GRU(LIN)) From ATEXTRA
Call MAJTEXTRA([M]SHOTRA(LIN),"GCCEGRUPYM","SHOTRA",[M]PYM(LIN),[M]GRU(LIN)) From ATEXTRA
[M]LEV(LIN)    = [M]VLEV
[M]BUDTRK(LIN) = [M]VBUDTRK
[M]PRNROW(LIN) = [M]VPRNROW

#Y012
[M]YVACBPR(LIN) = [M]VYVACBPR
#Y012
Return

#########################################################################
## Suppression des lignes déplacées
#########################################################################
$MODIF
Local Integer NBLIN
Local Char    GRPLIN(GLONCYR)
For I=0 To [M]VNBRCCE-1
 If [M]VCCE(I)<>""
  For [CRY0]CRY5 Where PYM=[M]VPYM & CCE=[M]VCCE(I) & GRU<>[M]VGRU
   Gosub VIRE
   If GOK<1 : Break 2 : Endif
  Next
 Endif
Next I
If GOK<1 : Return : Endif
For I=0 To [M]VNBRGRU-1
 For [CRY0]CRY2 Where PYM=[M]VPYM & SBBGRU=[M]VSBBGRU(I) & GRU<>[M]VGRU
  If [M]VSBBGRU(I)<>""
   Gosub VIRE
   If GOK<1 : Break 2 : Endif
  Endif
 Next
Next I
If GOK<1 : Return : Endif
Gosub TEXTRA
If GOK<1 : Return : Endif
Return

$VIRE
GRPLIN = [F:CRY0]GRU
NBLIN  = 0
For [CRY2]CRY0 Where PYM=[M]VPYM & GRU=GRPLIN
 NBLIN += 1
Next
If NBLIN=1
 [F:CRY0]SBBGRU = ""
 [F:CRY0]CCE    = ""
 [F:CRY0]LIN    = 1
 Rewrite [CRY0]
 If fstat
  GOK = 0 : Call FSTA("CRY0") From GLOCK : Return
 Endif
Else
 Delete [CRY0]
 If fstat=1
  GOK = -1 : GLOCK = "$GCCEGRUPYM"-[F:CRY0]PYM-[F:CRY0]GRU : Return
 Endif
 NBLIN = 0
 For [CRY2]CRY0 Where PYM=[M]VPYM & GRU=GRPLIN
  NBLIN += 1
  [F:CRY2]LIN = NBLIN
  Rewrite [CRY2]
  If fstat
   GOK = 0 : Call FSTA("CRY2") From GLOCK : Break
  Endif
 Next
Endif
Return

#########################################################################
## Annulation / Changement de clé
#########################################################################
$AP_CHANGE
Call DEBTRANS From GLOCK
Gosub TR_CHANGE
#Class[M] ŕ éviter car $AP_CHANGE peut ętre appelé d'un utilitaire externe ACHANGE
#Call CHGTEXTRA("GCCEGRUPYM","DESTRA",[M]PYM,[M]GRU,[M]PYM,NCODE) From ATEXTRA
#Call CHGTEXTRA("GCCEGRUPYM","SHOTRA",[M]PYM,[M]GRU,[M]PYM,NCODE) From ATEXTRA
Call CHGTEXTRA("GCCEGRUPYM","DESTRA",SUPP,OCODE,SUPP,NCODE) From ATEXTRA
Call CHGTEXTRA("GCCEGRUPYM","SHOTRA",SUPP,OCODE,SUPP,NCODE) From ATEXTRA
Return

$TR_CHANGE
GOK = 1
Trbegin [CRY]
 For [CRY2]CRY2 Where PYM=GBIDC1 & SBBGRU=OCODE
  [F:CRY2]SBBGRU = NCODE
  Rewrite [CRY2]
  If fstat
   GOK = 0 : Call FSTA("CRY2") From GLOCK : Break
  Endif
 Next
Commit
[M]LIN = 1
Return

$ANNULE
Call SUPTEXTRA("GCCEGRUPYM","DESTRA",[M]PYM,[M]GRU) From ATEXTRA
Call SUPTEXTRA("GCCEGRUPYM","SHOTRA",[M]PYM,[M]GRU) From ATEXTRA
Return

#########################################################################
## Gestion des listes de gauche
#########################################################################
$TIROIR
[M:PIK]NBPIK = 0
Case currbox
 When [M:PIK]BOXACC , [M:PIK]BOXGRC
  ILIS = val(right$(currbox,8))
  SAVGAUCHE = GNBGAUCHE
  GNBGAUCHE = 9999
  Gosub REMP_LISGAU From GOBJSUB
  GNBGAUCHE = SAVGAUCHE
  Gosub SETPICK
 When Default
  Gosub REMPLIT From GOBJSUB
Endcase
Return

$FILGAUCHE
If ILIS
 Case ILIS
  When BROWACC   : # selezione conti
   FILGAUSUP = 'DIE="'+[M]VDIE+'" & ENAFLG=2'
  When BROWGRC   : # selezione gruppi
   LEVPICK = [M]VLEV
   FILGAUSUP = 'PYM="'+[M]PYM+'" & LIN=1 & LEV>'+num$(LEVPICK)
 Endcase
Else
 FILGAUCHE = '[F:CRY]PYM="'+[M]VPYM+'"'
Endif
Return

#########################################################################
## Gestion du picking
#########################################################################
$PICKE
Call LECTURE("DIE",[M:CRY1]VDIE,"") From CONTOBJ
If [F:DIE]ENV=2 | [F:DIE]ENT=2
 #Picking inopérant pour les budgets opérationnels
 Call MESSAGE(mess(267,108,1)) From GESECRAN
 Return
Endif
Case currbox
 When [M:PIK]BOXACC
  nolign = [M]VNBRCCE+1
  Call C_VCCE([F:CCE]CCE)
  If !mkstat
   [M]VCCE(nolign-1)    = [F:CCE]CCE
   Call LECTEXTRA(VDESCCE(nolign-1),"CACCE","DESTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
   [M]VNBRCCE += 1
   Affzo VCCE(nolign-1),VDESCCE(nolign-1)
   [M:PIK]NBPIK +=1
   [M:PIK]TBPIK([M:PIK]NBPIK) = [F:CCE]CCE
  Endif
 When [M:PIK]BOXGRC
  nolign = [M]VNBRGRU+1
  Call CONT_VSBBGRU([F:CRY]GRU)
  If !mkstat
   [M]VSBBGRU(nolign-1) = [F:CRY]GRU
   Call LECTEXTRA(VDESGRU(nolign-1),"GCCEGRUPYM","DESTRA",[F:CRY]PYM,[F:CRY]GRU) From ATEXTRA
   [M]VNBRGRU += 1
   Affzo VSBBGRU(nolign-1),VDESGRU(nolign-1)
   [M:PIK]NBPIK +=1
   [M:PIK]TBPIK([M:PIK]NBPIK) = [F:CRY]GRU
   [M:PIK]LVPIK([M:PIK]NBPIK) = [F:CRY]LEV
  Endif
Endcase
Return

$DEPICK
Call LECTURE("DIE",[M:CRY1]VDIE,"") From CONTOBJ
If [F:DIE]ENV=2 | [F:DIE]ENT=2
 #Picking inopérant pour les budgets opérationnels
 Call MESSAGE(mess(267,108,1)) From GESECRAN
 Return
Endif
Case currbox
 When [M:PIK]BOXACC
  K = find([F:CCE]CCE,[M]VCCE(0..[M]VNBRCCE-1))
  If K
   Dela K-1,1 [M]VNBRCCE
   [M]VNBRCCE -= 1
   Affzo VNBRCCE,VCCE,VDESCCE
  Endif
  K = find([F:CCE]CCE,[M:PIK]TBPIK(1..[M:PIK]NBPIK))
  If K
   Dela K,1 [M:PIK]TBPIK
   [M:PIK]NBPIK -= 1
  Endif
 When [M:PIK]BOXGRC
  K = find([F:CRY]GRU,[M]VSBBGRU(0..[M]VNBRGRU-1))
  If K
   Dela K-1,1 [M]VNBRGRU
   [M]VNBRGRU -= 1
   Affzo VNBRGRU,VSBBGRU,VDESGRU
  Endif
  K = find([F:CRY]GRU,[M:PIK]TBPIK(1..[M:PIK]NBPIK))
  If K
   Dela K,1 [M:PIK]TBPIK
   [M:PIK]NBPIK -= 1
  Endif
Endcase
Return

$SETPICK
Case currbox
 When [M:PIK]BOXACC
  For K=1 To [M:PIK]NBPIK
   [F:CCE]DIE = GBIDC2
   [F:CCE]CCE = [M:PIK]TBPIK(K)
   Gosub DEPICK From =WINPROG
  Next K
  [M:PIK]NBPIK = 0
  For K=0 To [M]VNBRCCE-1
   If !instr(1,[M]VCCE(K),"*") & !instr(1,[M]VCCE(K),"?")
&   & !instr(1,[M]VCCE(K),"!") & !instr(1,[M]VCCE(K),"#")
    [M:PIK]NBPIK += 1
    [M:PIK]TBPIK([M:PIK]NBPIK) = [M]VCCE(K)
    [F:CCE]DIE = GBIDC2
    [F:CCE]CCE = [M:PIK]TBPIK([M:PIK]NBPIK)
    Gosub REPICK From =WINPROG
   Endif
  Next K
 When [M:PIK]BOXGRC
  For K=1 To [M:PIK]NBPIK
   [F:CRY]PYM = GBIDC1
   [F:CRY]GRU = [M:PIK]TBPIK(K)
   [F:CRY]LEV = [M:PIK]LVPIK(K)
   [F:CRY]LIN = 1
   Gosub DEPICK From =WINPROG
  Next K
  [M:PIK]NBPIK = 0
  For K=0 To [M]VNBRGRU-1
   If !instr(1,[M]VSBBGRU(K),"*") & !instr(1,[M]VSBBGRU(K),"?")
&   & !instr(1,[M]VSBBGRU(K),"!") & !instr(1,[M]VSBBGRU(K),"#")
    Read [CRY2]CRY0(2) = GBIDC1;[M]VSBBGRU(K)
    [M:PIK]NBPIK += 1
    [M:PIK]TBPIK([M:PIK]NBPIK) = [M]VSBBGRU(K)
    [M:PIK]LVPIK([M:PIK]NBPIK) = [F:CRY2]LEV
    [F:CRY]PYM = GBIDC1
    [F:CRY]GRU = [M:PIK]TBPIK([M:PIK]NBPIK)
    [F:CRY]LEV = [M:PIK]LVPIK([M:PIK]NBPIK)
    [F:CRY]LIN = 1
    Gosub REPICK From =WINPROG
   Endif
  Next K
  [F:CRY]GRU = [M]VGRU
  [F:CRY]LEV = [M]VLEV
Endcase
Return

#########################################################################
## Gestion des boutons
#########################################################################
$EXEBOUT
Case REP
 When "1" : # Changement de pyramide
  Gosub CHGPYR
Endcase
Return

$STATUT
Case BOUT
 When "2" : # Duplication
  If GBIDC3<>""
   GBIDC1 = GBIDC3
   FLMODIF = 0
   Gosub RAFFICHE
  Endif
 When "3" : # Génération auto
  FLMODIF = 0
  Gosub RAFFICHE
Endcase
Return

$RAFFICHE
Read [CYM]CYM0 = GBIDC1
[M]PYM  = GBIDC1
[M]VPYM = GBIDC1
[M]DIE  = [F:CYM]DIE
[M]VDIE = [F:CYM]DIE
Affzo PYM,VPYM,DIE,VDIE
GBIDC1  = [M]PYM
CLECUR2 = GBIDC1
GBIDC2  = [M]DIE
Filter [CRY] Where PYM=GBIDC1
Read [CRY]CRY0 First
Filter [CRY]
If fstat<=2
 CLECUR     = 1
 CLECUR1    = [F:CRY]GRU
 CLECUR2(1) = "1"
Else
 CLECUR = 0
 [M]GRU = ""
Endif
Gosub RELIT From GOBJSUB
Gosub SETBOUT
Gosub LOAD_DIE
Gosub TIROIR
[M:PIK]NBPIK = 0
Gosub SETPICK
Return

#########################################################################
## Changement de pyramide
#########################################################################
$CHGPYR
If (VALBOUT="") : Return : Endif
Gosub MAJ_LIENS
Gosub DEVERROU From GOBJET
Raz [M]
Effzo
GBIDC1  = VALBOUT
Gosub RAFFICHE
Return

#########################################################################
## Action SELSBBGRU2, sélection de sous-groupe
#########################################################################
$SEL_TABLE
Case TABLE
 When "SELSBBGRU"
  If clalev([F:CRY1])=0 : Local File GCCEGRUPYM [CRY1] : Endif
  Link [CRY1] With [AXX]AXX0="GCCEGRUPYM";"DESTRA";GLANGUE;[F:CRY1]PYM;[F:CRY1]GRU As [LNK]
  Default File [LNK]
  CRITERE = 'PYM="'+[M]VPYM+'" & GRU<>"'+[M]VGRU+'" & LEV>'+num$([M]VLEV)+' & LIN=1'
  ORDRE = "LEV;GRU"
  NBCOL = 0
  NBCOL += 1 : COL(NBCOL) = "GRU"  : TIT(NBCOL) = mess(28,113,1) : # Groupe section
  NBCOL += 1 : COL(NBCOL) = "PYM"  : TIT(NBCOL) = mess(29,113,1) : # Pyramide section
  NBCOL += 1 : COL(NBCOL) = "[F:AXX]TEXTE"  : TIT(NBCOL) = mess(3,113,1)  : # Intitulé
  NBCOL += 1 : COL(NBCOL) = "LEV"  : TIT(NBCOL) = mess(31,113,1) : # Groupe de niveau
  TIT(0) = mess(18,100,1)-mess(28,113,1) : # Sélection groupe de section
Endcase
Return

######################################################################################
## ECRAN CRY1
######################################################################################
Subprog C_VLEV(VALEUR)
Variable Decimal VALEUR
Local Decimal LIVELLO
LIVELLO = VALEUR
If clalev([F:CRY2])=0 : Local File GCCEGRUPYM [CRY2] : Endif
If clalev([F:CRY3])=0 : Local File GCCEGRUPYM [CRY3] : Endif
Filter [CRY2] Where PYM=[M]VPYM and SBBGRU=[M]VGRU and LEV>=LIVELLO
Read [F:CRY2] First
If !fstat & [F:CRY2]GRU<>""
 GMESSAGE = (mess(32,113,1)-[F:CRY2]GRU-">"-num$([F:CRY2]LEV)) : # Regroupé dans
 mkstat = 2 :  End
Endif
Filter [CRY2]
For [CRY2]CRY0 Where PYM=[M]VPYM & GRU=[M]VGRU & CCE=""
 Filter [CRY3] Where PYM=[M]VPYM and GRU=[F:CRY2]SBBGRU
 Read   [CRY3]  First
 If !fstat
  If   LIVELLO>=[F:CRY3]LEV
   GMESSAGE = mess(40,113,1)-"(>"-num$([F:CRY3]LEV)-")" : # Niveau incompatible avec le groupe ...
   mkstat=2 : Break
  Endif
 Endif
 Filter [CRY3]
Next
End

############################################################################
## Groupes de comptes
############################################################################
Subprog C_VNBRGRU
If status=65 & currbox=[M:PIK]BOXGRC
 Local Integer K
 Gosub SETWIN
 K = find([M]VSBBGRU(nolign-1),[M:PIK]TBPIK(1..[M:PIK]NBPIK))
 If K
  [F:CRY]PYM = GBIDC1
  [F:CRY]GRU = [M:PIK]TBPIK(K)
  [F:CRY]LEV = [M:PIK]LVPIK(K)
  [F:CRY]LIN = 1
  Gosub DEPICK From =WINPROG
  Dela K,1 [M:PIK]TBPIK
  [M:PIK]NBPIK -= 1
 Endif
 [F:CRY]GRU = [M]VGRU
 [F:CRY]LEV = [M]VLEV
Endif
End

$SETWIN
Local Char    WINPROG(GLONADC)
WINPROG = "WGOCRY"
Return

Subprog C_VSBBGRU(VALEUR)
Variable Char    VALEUR()
Call CONT_VSBBGRU(VALEUR)
If mkstat : End : Endif
Call LECTEXTRA(VDESGRU(nolign-1),"GCCEGRUPYM","DESTRA",[F:CRY0]PYM,[F:CRY0]GRU) From ATEXTRA
If VALEUR<>[M]VSBBGRU(nolign-1) & currbox=[M:PIK]BOXGRC
 Local Integer K
 Gosub SETWIN
 K = find([M]VSBBGRU(nolign-1),[M:PIK]TBPIK(1..[M:PIK]NBPIK))
 If K
  [F:CRY]PYM = GBIDC1
  [F:CRY]GRU = [M:PIK]TBPIK(K)
  [F:CRY]LEV = [M:PIK]LVPIK(K)
  [F:CRY]LIN = 1
  Gosub DEPICK From =WINPROG
 Else
  [M:PIK]NBPIK += 1
  K = [M:PIK]NBPIK
 Endif
 [M:PIK]TBPIK(K)  = VALEUR
 [M:PIK]LVPIK(K)  = [F:CRY0]LEV
 [F:CRY]PYM = GBIDC1
 [F:CRY]GRU = [M:PIK]TBPIK(K)
 [F:CRY]LEV = [M:PIK]LVPIK(K)
 [F:CRY]LIN = 1
 Gosub REPICK From =WINPROG
 [F:CRY]GRU = [M]VGRU
 [F:CRY]LEV = [M]VLEV
Endif
End

Subprog CONT_VSBBGRU(VALEUR)
Variable Char    VALEUR()
Call UNICITE(VALEUR,[M]VSBBGRU) From OBJDIV
If mkstat : End : Endif
Read [CRY0]CRY0(2) = [M]VPYM;VALEUR
If [F:CRY0]LEV<=[M]VLEV
 GMESSAGE = mess(31,113,1)-num$([F:CRY0]LEV) : # Groupe de niveau ...
 mkstat = 2 : End
Endif
End

############################################################################
## Sections
############################################################################
Subprog C_VNBRCCE
If status=65 & currbox=[M:PIK]BOXACC
 Local Integer K
 Gosub SETWIN
 K = find([M]VCCE(nolign-1),[M:PIK]TBPIK(1..[M:PIK]NBPIK))
 If K
  [F:CCE]DIE = GBIDC2
  [F:CCE]CCE = [M:PIK]TBPIK(K)
  Gosub DEPICK From =WINPROG
  Dela K,1 [M:PIK]TBPIK
  [M:PIK]NBPIK -= 1
 Endif
Endif
End

Subprog C_VCCE(VALEUR)
Variable Char    VALEUR()
Local Integer I , JOKER

  VALEUR = toupper(VALEUR)
  Call UNICITE(VALEUR,[M]VCCE(0..[M]VNBRCCE-1)) From OBJDIV
  If mkstat : End : Endif
  If VALEUR<>""
  JOKER  = 0
  For I=1 To len(VALEUR)
    If instr(1,"!#?*",mid$(VALEUR,I,1))
     JOKER = 1 : Break
    Endif
  Next I
  If !JOKER
    Call CONTROLE("CCE","",VALEUR,[M]VDIE,mkstat) From CONTOBJ
    Call LECTEXTRA(VDESCCE(nolign-1),"CACCE","DESTRA",[F:CCE]DIE,[F:CCE]CCE) From ATEXTRA
  Else
    [M]VDESCCE(nolign-1) = ""
  Endif
  Endif
  If VALEUR<>[M]VCCE(nolign-1) & currbox=[M:PIK]BOXACC
  Local Integer K
  Gosub SETWIN
  K = find([M]VCCE(nolign-1),[M:PIK]TBPIK(1..[M:PIK]NBPIK))
  If K
    [F:CCE]DIE = GBIDC2
    [F:CCE]CCE = [M:PIK]TBPIK(K)
    Gosub DEPICK From =WINPROG
  Else
    [M:PIK]NBPIK += 1
    K = [M:PIK]NBPIK
  Endif
  [M:PIK]TBPIK(K)  = VALEUR
  [F:CCE]DIE = GBIDC2
  [F:CCE]CCE = [M:PIK]TBPIK(K)
  Gosub REPICK From =WINPROG
  Endif

End

