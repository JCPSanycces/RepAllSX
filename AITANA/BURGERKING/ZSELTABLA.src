#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION

  Case ACTION
    When "SEL_TABLE"  : Gosub $SEL_TABLE
    When "FIN_TABLE"  : Gosub $FIN_TABLE
    When Default
  Endcase
  Return


$SEL_TABLE

  Case TABLE
    When "SELFACSIM"  : Gosub S_FACSIM # BUSQUEDAS DE FACTURAS SIMPLIFICADAS
  Endcase

 Return


$S_FACSIM

If clalev([F:ZSINV3]) = 0 : Local File SINVOICE [F:ZSINV3]  : Endif

Local Char WZSALCPY: WZSALCPY= PARAM(1)
Local Char WZTCKINI: WZTCKINI= PARAM(2)


Default File [ZSINV3]


ORDRE = "NUM"
START = "NUM"
SENS =1
DEFPAG = 5

SIZCOL = 100
SIZLIG = 150



 CRITERE = "ZTCKINI <=  '" + WZTCKINI  +"' and ZTCKEND >= '" + WZTCKINI + "' and SIVTYP = 'FAC' and CPY = '" + WZSALCPY + "'"
#CRITERE = "SIVTYP = 'FAC' and CPY = '" + [M:BIC0]CPY + "'"
#CRITERE = "1=1"


TIT(0) = "Selecciˇn Facturas con ticket " + WZTCKINI

NBCOL = 0
NBCOL +=1 : COL(NBCOL) = "NUM" : TIT(NBCOL)="Factura"
NBCOL +=1 : COL(NBCOL) = "ACCDAT" : TIT(NBCOL)="Fecha"
#NBCOL +=1 : COL(NBCOL) = "ZSALFCY" : TIT(NBCOL)="Site"

If [F:ZSINV3]NUM <> "" Then
      Raz [M:BIC1]INVNUM
      [M:BIC1]INVNUM = [F:ZSINV3]NUM
      Affzo [M:BIC1]INVNUM
      [M:BIC1]ZINVNUMSIMP = [F:ZSINV3]NUM
      Affzo [M:BIC1]ZINVNUMSIMP

Endif



Return



$S_ZZONA

If clalev([F:ZZON])=0 : Local File ZZONAS [ZZON]: Endif

Local Char WZSALFCY: WZSALFCY= PARAM(1)

Default File [ZZON]

ORDRE = "ZONA"
START = "ZONA"
SENS =1
DEFPAG = 5
CRITERE = "DIE = 'CCT'"

SIZCOL = 100
SIZLIG = 150

If WZSALFCY<>""
CRITERE = "FCY='"+WZSALFCY+"'"
Endif

TIT(0) = "Selecciˇn zonas"

NBCOL = 0
NBCOL +=1 : COL(NBCOL) = "ZONA" : TIT(NBCOL)="Zona"
NBCOL +=1 : COL(NBCOL) = "ZDESZONA" : TIT(NBCOL)="Descripciˇn"
#NBCOL +=1 : COL(NBCOL) = "ZSALFCY" : TIT(NBCOL)="Site"


Return


$S_ZAREA

If clalev([F:ZARE])=0 : Local File ZAREAS [ZARE]: Endif

Local Char WZSALFCY: WZSALFCY= PARAM(1)

Default File [ZARE]

ORDRE = "AREA"
START = "ARE"
SENS =1
DEFPAG = 5
CRITERE = "DIE = 'CCT'"

SIZCOL = 100
SIZLIG = 150

If WZSALFCY<>""
CRITERE = "FCY='"+WZSALFCY+"'"
Endif

TIT(0) = "Selecciˇn AREAS"

NBCOL = 0
NBCOL +=1 : COL(NBCOL) = "AREA" : TIT(NBCOL)="Area"
NBCOL +=1 : COL(NBCOL) = "ZDESAREA" : TIT(NBCOL)="Descripciˇn"
#NBCOL +=1 : COL(NBCOL) = "ZSALFCY" : TIT(NBCOL)="Site"



Return



$FIN_TABLE

  Return

