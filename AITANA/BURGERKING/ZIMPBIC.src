$ACTION

  Case ACTION

    When "AP_IMPORT"        : Gosub $AP_IMPORT
   # When "IMP_AVANT_OUVRE"  : Gosub $IMP_AVANT_OUVRE
   # When "AP_IMPORT"        : Gosub $AP_IMPORT
    When Default
  Endcase
  Return

$OUVRE
    Gosub OUVRE From GASIMPORT
  Return

$RAZCRE
    Gosub RAZCRE From GASIMPORT
  Return

$VALID
    Gosub VALID From GASIMPORT
  Return

$SAIMSK
    Gosub SAIMSK From GASIMPORT
    Return

$IMP_FERME
  Return

#######################################################################################
#$IMPORT
#
#  Return

#######################################################################################ă
$IMP_AVANT_OUVRE
    Global  Integer  COUNTERFOUND : COUNTERFOUND=0
    Global  Integer  COUNTERYVAR : COUNTERYVAR=0
    # Si el tipo de importaciˇn es YVAR, hacer un tratamiento especial



#######################################################################################
#**
#*
#*!
$AP_IMPORT

  Local Char FICHERO_INVERSION(200)
  Local Char ASIENTO_ORIGEN, TYPE_ORIGEN, FCY_ORIGEN
  Local Char LAUX
  Local Char LPROV_AUX
  Local Char LPLANTA
  Local Char GLPLANTA

  # Infbox [L]IMPFIC
  If !clalev([F:ZSIH])  Then : Global File SINVOICE [ZSIH] : Endif

  Case [L]IMPFIC
    When "SIH"  # SINVOICE
        If [M:DIA]MODIMP = "YBICROY" Then

            Filter [F:ZSIH] Where BPRVCR = [F:SIH]BPRVCR and BPR = [F:SIH]BPR and ACCDAT = [F:SIH]ACCDAT and (SIVTYP = 'AF' or SIVTYP = 'AFBK' or SIVTYP = 'RY')
            Read [F:ZSIH] First
            # Si encuentro una factura, asignamos el n˙mero de factura para que la actualice.
            If !fstat Then
                [F:SIH]NUM = [F:ZSIH]NUM
            Endif
            Filter [F:ZSIH]

        Endif
        If [M:DIA]MODIMP = "YBIC" Then
            If [F:SIH]ZTCKINI = [F:SIH]ZTCKEND Then
            #If [F:SIH]VAC = 'NACF2' Then # TICKET 202 #
              [F:SIH]ZTCKINI = '' # MAB13022019.OLD
              # Si los tiicket son iguales, solo borraremos el ticket final
              # En el monitor SII, se verß la factura como F4,  pero realmente
              # a Hacienda se enviara como F2.
              # Esta modificacion se realiza en el script ZXX02TRTSENDSII, linea 89
              [F:SIH]ZTCKEND = ''  # MAB13022019.OLD
              [F:SIH]ZTCKNUM = 0
            Endif
        Endif
    When Default
  Endcase
  Close File [ZSIH]

  Return

