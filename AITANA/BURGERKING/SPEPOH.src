#Y004  Analitica en pedidos y recepciones compra
#Y005 Objeto de contrato, cuando se borre un pedido con contrato
#Y005 actualizar fecha próximo pedido del contrato
######################################################################################
# Gestión de la máscara POH2 (Especifico)
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla POH2) 17/04/2020 10:21:10 (ZZD01)
######################################################################################
$ACTION
Case ACTION
  When "RAZCRE"       : Gosub RAZCRE       From YSPEPOH
  When "RAZDUP"       : Gosub RAZDUP       From YSPEPOH
  When "ANNULE"       : Gosub ANNULE       From YSPEPOH
  When "VERF_ANU"     : Gosub VERF_ANU     From YSPEPOH
  When "LIENS"        : Gosub LIENS        From YSPEPOH
  When "INICRE_LIG"   : Gosub INICRE_LIG   From YSPEPOH
  When "INIMOD_LIG"   : Gosub INIMOD_LIG   From YSPEPOH
  When "VERIF_CRE"    : Gosub VERIF_CRE    From YSPEPOH
  When "VERIF_MOD"    : Gosub VERIF_CRE    From YSPEPOH
  When Default
Endcase
Return
######################################################################################
######################################################################################
######################################################################################
Subprog AS_LINDSP(VALEUR)
Variable Char    VALEUR()
Call AS_LINDSP(VALEUR) From YSPEPOH
End
##############################################
Subprog AM_LINDSP(VALEUR)
Variable Char    VALEUR()
Call AM_LINDSP(VALEUR) From YSPEPOH
End
