#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION
 When "AFTDEFCRI" : Gosub AFTDEFCRI
 When "BEFWRISII" : Gosub BEFWRISII
 When Default
Endcase
Return

###############################################################################
$BEFWRISII
#Y019
#Infbox('BEFWRISII')

#Infbox('left$([F:X025SI]BPR,5)'-left$([F:X025SI]BPR,5))
If left$([F:X025SI]BPR,5) = 'CANJE'
  If !clalev ([YDVS])   : Local File DCLVATSPA    [YDVS]    : Endif
  Filter [YDVS] Where [YDVS]NUM = [F:X025SI]VCRNUM
  Read [YDVS]DVS0 First
  If fstat = 0
    #Infbox('[F:YDVS]CRY'-[F:YDVS]CRY)
    [F:X025SI]CRY = [F:YDVS]CRY
  Endif
#  Filter [YDVS]
Endif
Return

###############################################################################
$AFTDEFCRI

If clalev([M:XSIBAT]) <> 0 Then # SI EST¡ ABIERTA LA PANTALLA DE MONITOR SII BATCH
  Call ECR_TRACE("EjuciÛn en modo BATCH", 0) From GESECRAN
  If [M:XSIBAT]ZCANARIAS = 2 Then  # SI ESTAMOS EJECUTANDO EL BATCH PARA ENVIAR A CANARIAS
    Call ECR_TRACE("EjuciÛn en modo BATCH - CANARIAS", 0) From GESECRAN
    [M:XSII]ZCANARIAS = 2
  Else
    Call ECR_TRACE("EjuciÛn en modo BATCH - NACIONAL", 0) From GESECRAN
  Endif
#Else
#  [M:XSII]ZCANARIAS = 2
Endif


Trbegin XX025SII [X025SI]
Delete [X025SI] Where VCRSTA = 1 and DATOPE >= [01/10/2018]
If !fstat Then
  Commit
Endif

If [M:XSII]ZCANARIAS = 2 Then
  CRITERE += ' & [F:DVS]ZSIISEND = "CAN"'
  #Infbox(CRITERE)
Else
  CRITERE += ' & [F:DVS]ZSIISEND = "NAC"'
  #Infbox(CRITERE)
Endif

Return

