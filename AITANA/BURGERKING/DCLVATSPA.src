#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)6.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#                                                                       #
#     SPANISH TAX PROCESS                                               #
#                                                                       #
#     - Process     : DCLVATSPA                                         #
#     - Description : Load of registers into DCLVATSPA table            #
#                     for VAT declaration                               #
#  90370 - Cash VAT  #JUCON                                             #
#  99434-101547- Improves into Spanish VAT management                   #
# 104188 -Purchase type in Cash-VAT                                     #
#         and flag some record for Murano Interface                     #
# 107180 -Free samples invoices in Spanish VAT                          #
# 107490 -If rate entry in account core model different to multiplier   #
# 108201 -Source date and source document if credit memo                #
# 109178 - Credit memo with several invoices                            #
# 111926 - Improves into Spanish VAT management                         #
# 114568 - Control in D347FLG for 347 in Sage Impresos Oficiales        #
#########################################################################


$ACTION
    Case ACTION
        When "INIT"        : Gosub OUVRE
        When "OUVRE_BATCH" : Gosub OUVRE
        When "INIT_DIA"    : Gosub INIT_DIA
        When "CONTROLE"    : Gosub CONTROLE
        When "EXEC"        : Gosub EXEC
        When "TERMINE"     : Gosub TERMINE
        When "SORTIE"      : Gosub SORTIE
    Endcase
Return

#------------------------------------------------------------------------------#
$SORTIE
Kill GEXENTOFLG
Return

$OUVRE
    If GSERVEUR : Onerrgo ERRBATCH : Endif
    If GSERVEUR=1
       Local Mask DCLVATSPA [DIA]
    Endif
    # Variables Declaration
    Local Char    CRITERE(250)           # Selection criteria
    Local Char    MENSAJE(250)           # Log Message
    Local Char    BLOQUEO(30)            # Logic lock
    Local Char    NOMDCLDAT(10)          # Field for declaración date
    Local Char    WTIPOIVA(1)            # VAT Type: "R" - Collected | "S" - Deductible
    Local Char    WTYP(GLONGTE)          # Entry type
    Local Char    VCRNUM(GLONVCR)        # Entry code
    Local Char    WCPY(GLONCPY)          # Company
    Local Char    WFCY(GLONFCY)          # Site
    Local Char    WBPRNUM(GLONBPR)       # BP code
    Local Char    WBPRNAM(GLONNAM)(2)    # Company name
    Local Char    WCRN(GLONCRN)          # Site tax ID Number
    Local Char    CODIVA(GLONVAT)(1..10) # VAT code
    Local Char    WCODIVA(GLONVAT)       # VAT code
    Local Char    WVAC(10)               # Tax rule
    Local Char    PLAN(GLONCOA)
    Local Char    WBPRVCR(20)            # Source document
    Local Char    WCRY(GLONCRY)          # Country
    Local Char    WEECNUM(20)            # EEC identification
    Local Char    WABONUM(GLONVCR)       # Invoice number
    Local Char    WCUR(GLONCUR)          # Currency
    Local Char    WPOSCOD(GLONPOS)       # Postal code
    Local Char    WCODBAN(GLONBAN)       # bank code
    Local Char    WTEMPIVA(15)(1..20)
    Local Char    AUXCHR(15)
    Local Char    WCODTAX(2+GLONVAT)(1..10)
    Local Char    TIPOTER(1)
    Local Char    WREGDEF(3)             # Default tax rule
    Local Char    FNCLEG(3)
    Global Integer GEXENTOFLG
    Local Integer OKK,I,J,STAT,AUXINT,SWCEE,OK
    Local Integer NBTYPIVA               # No. of records of type VAT entry Collected/Deductible
    Local Integer NUMIVAS                # No. of different VAT type on invoice
    Local Integer NUMFACCOM              # Purchase invoice number
    Local Integer NUMFACVEN              # Sales invoice number
    Local Integer NUMLINGAS              # No. of entry lines
    Local Integer NUMREGMETAL            # No. of Cash payment record
    Local Integer WINVTYP                # Invoice categorie (Invoice,credit note,...)
    Local Integer WTRIMESTRE             # Quarter
    Local Integer WCEEFLG                # EEC Invoice flag
    Local Char    WCODOPE(1)             # Operation code
    Local Integer WLIBFLG                # VAT books flag
    Local Integer WD347FLG               # 347 declaration flag
    Local Integer WD349FLG               # 349 declaration flag
    Local Integer WSERV349               # 349 services VAT flag
    Local Integer WDIGICFLG              # IGIC declaration flag
    Local Integer WVATTYP(1..10)         # VAT type
    Local Integer WREGTYP(1..10)         # Purchase type (Purchase|Fix assets|Services) / Sales type (Mechandise|Services)
    Local Integer WSNS                   # Sense
    Local Integer WORIMOD                # Source module
    Local Integer WESFACTURA             # Invoice (Yes/No)
    Local Integer WGASTRATFLG            # Process Flag (Yes/No)

    Local Decimal WEJERCICIO             # Fiscal year
    Local Decimal WPERIODO               # Period
    Local Decimal WAMTATICUR             # Amount incl taxe in currencies
    Local Decimal WVATRAT(1..10)         # Tax rate
    Local Decimal WDEDRAT(1..10)         # Deductible rate
    Local Decimal WBASECUR(1..10)        # Inv amount excl tax in currencies
    Local Integer WIVAIMPORT(1..10)      # Import tax
    Local Decimal WIVACUR(1..10)         # VAT amount in currencies
    Local Decimal WBASELOC(1..10)        # Amount excl tax (in company currency)
    Local Decimal WIVALOC(1..10)         # VAT amount (in company currency)
    Local Decimal XRATMLT(0..10)         # Rate type
    Local Decimal XRATDIV(0..10)         # Dividing rate 107490
    Local Decimal WISPVENTA              # Sales Reverse Charge
    Local Decimal WDOCTYP                # Document Type
    Local Char    WDUA(40)               # SCD reference
    Local Date    WACCDAT                # Accounting date
    Local Date    WDCLDAT                # Declaration date
    Local Date    WBPRDAT                # Source date
    Local Date    MAXACCDAT              # Max accounting date
    Local Integer XISP                   # Sales reverse charge

    # 90370 - Cash VAT
    Local Integer WCSHVAT
    Local Date    WENFDAT
    Local Decimal WPAYCUR
    Local Decimal WDECCUR
    Local Integer WTOTALPAY
    # 90370 - Cash VAT

    # 108201
    Local Date WINVNUMDAT
    Local Integer WINVUPDFLG

    # Tables declaration
    If clalev([F:CPY])=0 : Local File COMPANY    [CPY] : Endif # Companies
    If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif # Sites
    If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif # Fiscal years
    If clalev([F:PER])=0 : Local File PERIOD     [PER] : Endif # Periods
    If clalev([F:GTE])=0 : Local File GTYPACCENT [GTE] : Endif # Entry types
    If clalev([F:DVS])=0 : Local File DCLVATSPA  [DVS] : Endif # Spanish Tax declaration working table
    If clalev([F:HTS])=0 : Local File HISTAXSPA  [HTS] : Endif # History tax extraction
    If clalev([F:ADI])=0 : Local File ATABDIV    [ADI] : Endif # Miscellaneous tables
    If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif # BPs
    If clalev([F:BPA])=0 : Local File BPADDRESS  [BPA] : Endif # Addresses
    If clalev([F:TVT])=0 : Local File TABVAT     [TVT] : Endif # Tax code
    If clalev([F:TRA])=0 : Local File TABRATVAT  [TRA] : Endif # Tax rates
    If clalev([F:TVB])=0 : Local File TABVACBPR  [TVB] : Endif # BP tax rules
    If clalev([F:TCU])=0 : Local File TABCUR     [TCU] : Endif # Currencies
    If clalev([F:TCY])=0 : Local File TABCOUNTRY [TCY] : Endif # Countries
    If GMODU(5)=2
     If clalev([F:SIV])=0 : Local File SINVOICEV  [SIV] : Endif # Costing sales invoice
     If clalev([F:SID])=0 : Local File SINVOICED  [SID] : Endif # Detail sales invoice
    Endif
    If GMODU(6)=2
     If clalev([F:PIV])=0 : Local File PINVOICEV  [PIV] : Endif # Costing purchase invoice
     If clalev([F:PID])=0 : Local File PINVOICED  [PID] : Endif # Detail purchase invoice
    Endif
    If clalev([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif # Sales invoice
    If clalev([F:SIL])=0 : Local File BPCINVLIG  [SIL] : Endif # Customer invoice lines
    If clalev([F:PIH])=0 : Local File PINVOICE   [PIH] : Endif # Purchase invoice
    If clalev([F:PIL])=0 : Local File BPSINVLIG  [PIL] : Endif # Supplier invoice lines
    If clalev([F:HAE])=0 : Local File GACCENTRY  [HAE] : Endif # Accounting entries
    If clalev([F:DAE])=0 : Local File GACCENTRYD [DAE] : Endif # Accounting entries lines
    If clalev([F:GAC])=0 : Local File GACCOUNT   [GAC] : Endif # Accounts
    If clalev([F:TPV])=0 : Local File TABPIVTYP  [TPV] : Endif # Supplier invoice type table
    If clalev([F:TSV])=0 : Local File TABSIVTYP  [TSV] : Endif # Cusromer invoice type table
    If clalev([F:GAU])=0 : Local File GAUTACE    [GAU] : Endif # Automatic journals
    If clalev([F:BAN])=0 : Local File BANK       [BAN] : Endif # Bank accounts
    If clalev([F:PFI])=0 : Local File PFOOTINV   [PFI] : Endif # Purchase invoicing elements
    If clalev([F:PVF])=0 : Local File PVCRFOOT   [PVF] : Endif # Purchase documents - footer elements
    If clalev([F:CPS])=0 : Local File CASHPAYSPA [CPS] : Endif # Cash payment for interface "Impresos Oficiales"
    If clalev([F:XDVS])=0: Local File DCLVATSPA [XDVS] : Endif
    If clalev([F:CPSX])=0: Local File CASHPAYSPA [CPSX]: Endif
    If clalev([F:TPY])=0 : Local File TABPAYTYP  [TPY] : Endif
    If clalev([F:PYH])=0 : Local File PAYMENTH   [PYH] : Endif
    If clalev([F:PYD])=0 : Local File PAYMENTD   [PYD] : Endif
    If clalev([F:PAN])=0 : Local File PAYACCNUM  [PAN] : Endif

    AUXINT=nbrecord([F:GTE])
    If AUXINT=0
        GMESSAGE= mess(235,107,1)  # Non existent document type
        GERR=1 : FIN=1 : Return
    Endif
    Local Char TYPIVA(GLONGTE)(1..AUXINT)    # VAT entry type Collected/Deductible
Return

#------------------------------------------------------------------------------#

$INIT_DIA

    Raz [M:DIA]

    [M:DIA]YEA=year(date$)
    If GUSRFCY(1)="\" or GNBAUZ=GNBSITE
        [M:DIA]ALLCPY=2
        [M:DIA]ALLFCY=2
        Diszo [M:DIA]ALLFCY,CPY,FCY
    Else
        Diszo [M:DIA]ALLCPY
        Call INICPY([M:DIA]CPY) From SUPCPT
        Call INIFCY([M:DIA]FCY,[M:DIA]CPY) From SUPCPT
    Endif

    Call CHG_LASTDAT("YEA",num$([M:DIA]YEA))
    Affzo [M:DIA]ALLCPY,ALLFCY,CPY,FCY

Return

#------------------------------------------------------------------------------#

$CONTROLE
    # VAT entry type entries
    #Gosub LECPARAM
    #If !OKK : GERR=1 : FIN=1 : Return : Endif
    If [M:DIA]CPY=""
      BLOQUEO="DCLVATSPA~"+""+"~"+ num$([M:DIA]YEA)
      Lock =BLOQUEO With lockwait=0
      If fstat
        GMESSAGE= mess(30,100,1)   # The record is used by an other user
        GERR=2 : FIN=1 : Return
      Endif
    Else
      BLOQUEO="DCLVATSPA~"+""+"~"+ num$([M:DIA]YEA)
      Lock =BLOQUEO With lockwait=0
      If fstat
        GMESSAGE= mess(30,100,1)   # The record is used by an other user
        GERR=2 : FIN=1 : Return
      Else
        Unlock =BLOQUEO
        BLOQUEO="DCLVATSPA~"+[M:DIA]CPY+"~"+ num$([M:DIA]YEA)
        Lock =BLOQUEO With lockwait=0
        If fstat
         GMESSAGE= mess(30,100,1)   # The record is used by an other user
         GERR=2 : FIN=1 : Return
        Endif
      Endif
    Endif
    If [M:DIA]STRDAT=[0/0/0] : [M:DIA]STRDAT=gdat$(1,1,[M:DIA]YEA)   : Endif
    If [M:DIA]ENDDAT=[0/0/0] : [M:DIA]ENDDAT=gdat$(31,12,[M:DIA]YEA) : Endif

    TIT= mess(236,107,1) # Updating tax table
    TMP=1
Return

#------------------------------------------------------------------------------#

$LECPARAM
    # Entry types:
    #    - AUZLED(0)>=2    : --> Social ledger
    #    - VAT=2    : Deductable VAT
    #    - VATPAI=2 : Collected VAT
    #    - LEG="SPA" o " " : Spanish or general legislation

    #OKK=1
    Raz NBTYPIVA, TYPIVA
    Filter [GTE] Where AUZLED(0)>=2 and (VAT=2 or VATPAI=2)and (LEG=[F:CPY]LEG  | LEG="") Order By Key CLE=TYP Asc ; LEG Desc
    For [GTE]CLE(1)
        NBTYPIVA+=1
        TYPIVA(NBTYPIVA)=[F:GTE]TYP
    Next

    If NBTYPIVA=0
        Call ECR_TRACE([F:CPY]CPY- mess(237,107,1),0) From GESECRAN  # Non existent document type managed with tax
    Endif
Return

#------------------------------------------------------------------------------#

$EXEC
    If !GSERVEUR
        Call OUVRE_TRACE(mess(236,107,1)) From LECFIC
    Endif
    Call ECR_TRACE(mess(236,107,1),0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("DCLVATSPA","DIA","",0,1) From ATRTX3

    # Deleting existing Cash paymenth records (REGTYP>10)
    Gosub DEL_CVAT  #X3-62304 (JUCON 31/10/2017)
    If GOK<1
      GERR=1 : FIN=1 : Return
    Endif

    # Delete records from selection
    If [M:DIA]RESINCRONI=2
        Call DEBTRANS From GLOCK
        Gosub TR_DEL
        If GOK<1
   #         GMESSAGE= mess(238,107,1) :  # Blocking problems in the tax table
            GERR=1 : FIN=1 : Return
        Endif
    Endif

    # Delete cash payment records
      If [M:DIA]CASH=2
        Call DEBTRANS From GLOCK
        Gosub TR_DEL_METAL
        If GOK<1
   #         GMESSAGE= mess(238,107,1)
            GERR=1 : FIN=1 : Return
        Endif
        Gosub CALMET
      Endif
    Gosub PRINCIPAL
    Filter [DVS]
    Gosub CASH_VAT  # 90370 - Cash VAT

    Gosub UPD_HISTORY
    If !GSERVEUR : Call FERME_TRACE From LECFIC : Endif
Return

#------------------------------------------------------------------------------#

$PRINCIPAL
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

    Raz CRITERE, MAXACCDAT, NUMFACCOM, NUMFACVEN, NUMLINGAS

    # Default tax rule
    Filter [ADI] Where NUMTAB=1 & DEFVAL=2
    Read [ADI]CODE First
    WREGDEF=""
    If !fstat
       WREGDEF=[F:ADI]CODE
    Endif
    Filter [ADI]

    # SPA Social ledger entries (AUZLED(0)=2) and "Real" categories (CAT=1)
    CRITERE = '[F:HAE]LED(0)<>"" & [F:HAE]CAT=1 '

    If [M:DIA]ALLFCY<>2
        CRITERE -= '& [F:HAE]FCY="'+[M:DIA]FCY+'"'
    Endif

    CRITERE -= '& [F:HAE]ACCDAT>=['+format$(GFMD,[M:DIA]STRDAT)+']'
    CRITERE -= '& [F:HAE]ACCDAT<=['+format$(GFMD,[M:DIA]ENDDAT)+']'
    FNCLEG="SPA"



    For [CPY]CPY0 Where ([M:DIA]ALLCPY=2 | CPY=[M:DIA]CPY) & CPYLEGFLG=2

    Call CTLLEGVAT([F:CPY]CPY,FNCLEG,OK) From DCLVATSTD
    If OK=1
      Gosub LECPARAM

      Link [HAE] With [SIH]SIH2=[F:HAE]TYP;[F:HAE]NUM As [LNK] Where evalue(CRITERE) and find([F:HAE]TYP,TYPIVA(1..NBTYPIVA)) and CPY=[F:CPY]CPY

      For [F:LNK]HAE0
            Raz WTIPOIVA

            If [F:SIH]SIVTYP<>""
                WTIPOIVA="R"
            Else
                Read [F:PIH]PIH2 = [F:HAE]TYP;[F:HAE]NUM
                If !fstat : WTIPOIVA="S" : Endif
            Endif
    # Yet existent in DCLVATSPA, it's not resynchronization
        Filter [DVS] Where NUM=[F:HAE]NUM
            Read [DVS]DVS0 First
            If !fstat and [M:DIA]RESINCRONI=1 : WVAT=[F:DVS]VAT: OKK=2: Goto NOWRITE: Endif
        Filter [DVS]

            If WTIPOIVA="R"
                Gosub IVAREP
            Elsif WTIPOIVA="S"
                Gosub IVASOP
            Else
                Gosub LINGAS
            Endif

       $NOWRITE
               If [M:DIA]RESINCRONI=1 and OKK=2 and WVAT<>""
                   If WTIPOIVA="R": NUMFACVEN+=1   : Endif
                   If WTIPOIVA="S": NUMFACCOM+=1   : Endif
                   If WTIPOIVA="" : NUMLINGAS+=1 : Endif
               OKK=1
           Endif
    #  $NOTLEG
      Next
    Endif
    Next   #cpy

    Call ECR_TRACE(" ",0) From GESECRAN   # Number of purchase invoices
    Call ECR_TRACE(mess(239,107,1)+":" - num$(NUMFACCOM),0) From GESECRAN

    Call ECR_TRACE(" ",0) From GESECRAN   # Number of sales invoices
    Call ECR_TRACE(mess(240,107,1)+":" - num$(NUMFACVEN),0) From GESECRAN

    If [M:DIA]RESINCRONI=2
        Call ECR_TRACE(" ",0) From GESECRAN   # Number of entry lines
        Call ECR_TRACE(mess(132,105,1)+":" - num$(NUMLINGAS),0) From GESECRAN
    Else
        Call ECR_TRACE(" ",0) From GESECRAN   # Number of entries
        Call ECR_TRACE(mess(267,107,1)+":" - num$(NUMLINGAS),0) From GESECRAN
    Endif

    Call ECR_TRACE(" ",0) From GESECRAN   # Number of records in cash
    Call ECR_TRACE(mess(241,107,1)+":" - num$(NUMREGMETAL),0) From GESECRAN

Return

$CASH_VAT   # 90370 - Cash VAT
   Local Decimal UNPAID
   Local Decimal TOTCOB
   Local Decimal TOTVAT
   ## 99434
   Local Decimal TOTRET, TOTFAC, TOTFACVAT, WRET
   Local Shortint WPAY
   ## 101547
   Local Shortint EFEC, NOPAYBAN
   Local Date PAYDAT
   Local Integer NUMPAY
   Local Shortint WEXTRACT # 103540
   Local Char WMTC(3)  # 103540

   If !clalev([DAX]): Local File GACCENTRYD [DAX]: Endif
   If !clalev([DCX]): Local File DCLVATSPA  [DCX]: Endif
   If !clalev([DCY]): Local File DCLVATSPA  [DCY]: Endif
   If !clalev([PYH]): Local File PAYMENTH   [PYH]: Endif
   If !clalev([TPY]): Local File TABPAYTYP  [TPY]: Endif
   If !clalev([BAX]): Local File BANK       [BAX]: Endif
   If !clalev([PYD]): Local File PAYMENTD   [PYD]: Endif  ## 99434
  ## 101547
   If clalev([F:PAN])=0 : Local File PAYACCNUM  [PAN] : Endif
   If clalev([F:DUD])=0 : Local File GACCDUDATE [DUD] : Endif

### First, we treat payments of invoices with special cash vat
 #  CRITERE='[F:DVS]CSHVAT=2 & [F:DVS]TOTALPAY<>2 & [F:DVS]REGTYP<11'
 CRITERE='[F:DVS]CSHVAT=2 & [F:DVS]TOTALPAY<>2 & [F:DVS]REGTYP<11 & [F:DVS]REGTYP<>4' ##99434
   If [M:DIA]ALLCPY<>2
     CRITERE -='& [F:DVS]CPY="'+[M:DIA]CPY+'" '
   Endif
   If [M:DIA]ALLFCY<>2
     CRITERE -= '& [F:DVS]FCY="'+[M:DIA]FCY+'"'
   Endif
   CRITERE -= '& [F:DVS]ACCDAT<=['+format$(GFMD,[M:DIA]ENDDAT)+']'
   For [DVS]DVS0 Where evalue(CRITERE)
     # Withholdins?   ## 99434
     Filter [DCX] Where NUM=[F:DVS]NUM and REGTYP=4
     Read [DCX]DVS0 First
     If !fstat:  WRET=abs([F:DCX]VATRAT/100): Else: Raz WRET: Endif
     Filter [DCX] ## 99434
     Raz TOTCOB, TOTVAT

     # credit notes for this invoice?  ##104188
      Local Decimal ABOTODES
      Filter [DCX] Where INVNUM=[F:DVS]NUM
      For [DCX]
        ABOTODES+=[F:DCX]AMTNOTL
      Next
      Filter [DCX]

      If ABOTODES=[F:DVS]AMTNOTL
        Trbegin [DVS]
          [F:DVS]TOTALPAY=2
          Rewrite [DVS]
        Commit
      Endif                 ##104188

     If [F:DVS]TAXTYP="R"
       Read [SIH]SIH0=[F:DVS]NUM
     Elsif [F:DVS]TAXTYP="S"
       Read [PIH]PIH0=[F:DVS]NUM
     Endif

     If !fstat   # 101547
       ## Searching paymenths with draft management
       Link [PYD] With [PYH]PYH0=[F:PYD]NUM, [TPY]TPY0=[F:PYH]PAYTYP As [PYHX] Order By Key KEY1=[PYD]NUM

       Filter [PYHX] Where [F:PYD]VCRNUM=[F:DVS]NUM and [F:PYD]VCRTYP=[F:DVS]TYP #and [F:TPY]STA3=2
       Raz  TOTFAC, TOTFACVAT
       For [PYHX]KEY1
         Raz EFEC, NOPAYBAN
         Raz WPAY, WEXTRACT # 103540
         If [F:TPY]ACETYP91=2 or [F:TPY]ACETYP92=2: WEXTRACT=1: Endif
         If  [F:TPY]STA3=2
           If [F:TPY]UPDBIL>1 or [F:TPY]STA5=2: EFEC=1: Else : Break : Endif  #X3-62304 (JUCON 31/10/2017)
         Endif
         If EFEC=1 and [F:PYH]STAFLG(8)=2    # Is it in bank?
           Filter [PAN] Where NUM=[F:PYD]NUM and STA=9 and CPTBAN=2 and RVSACCNUM=0
           Read [PAN]First
           If !fstat:
             NUMPAY=[F:PAN]ACCNUM
              # Reading the treasury line in the payment
              Read [DAE]DAE2=NUMPAY
              If !fstat: PAYDAT=[F:DAE]ACCDAT: WPAY=1: Endif
              Filter [PAN]
            Else
              NOPAYBAN=1
            Endif

            If PAYDAT=[0/0/0] or PAYDAT<[M:DIA]STRDAT or PAYDAT>[M:DIA]ENDDAT
              NOPAYBAN=1
            Endif

            If NOPAYBAN=0
              TOTFAC+=[F:PYD]PAYCURLIN
              TOTFACVAT+=ar2([F:PYD]PAYCURLIN*[F:DVS]VATRAT/100)
              UNPAID=TOTFAC

              If [F:TPY]SPACSH=2
                [F:DCY]BIDNUM=mess(20,127,1)           #"Others"
                [F:DCY]PAM="O"
              Elsif [F:TPY]DACCHQNUM<3
                [F:DCY]BIDNUM=[F:PYH]CHQNUM
                [F:DCY]PAM="T"
              Elsif [F:TPY]DACBID<3 and [F:DCY]BIDNUM=""
                Read [BAX]BAN0=[F:PYH]BAN
                If !fstat
                  [F:DCY]BIDNUM=[F:BAX]BIDNUM
                  [F:DCY]PAM="C"
                Endif
              Endif
            Endif
          Else
            NOPAYBAN=1
          Endif

          If UNPAID>0 and NOPAYBAN=0: Gosub ESC_PAGOS :Endif
        Next

        If EFEC=0
          If [F:DVS]TAXTYP="R"
            Read [DAE]DAE2=[F:SIH]ACCNUM
          Elsif [F:DVS]TAXTYP="S"
            Read [DAE]DAE2=[F:PIH]ACCNUM
          Endif

          If !fstat
            If [F:DAE]MTC<>""
              WMTC=[F:DAE]MTC # 103540
              Filter [DAX] Where LEDTYP=[F:DAE]LEDTYP and ACC=[F:DAE]ACC and BPR=[F:DAE]BPR and MTC=[F:DAE]MTC and ACCNUM<>[F:DAE]ACCNUM and
&             ACCDAT<=[M:DIA]ENDDAT and FCYLIN=[F:DAE]FCYLIN and REFINTLIN<>"" ##104188
#&             ACCDAT<=[M:DIA]ENDDAT and FCYLIN=[F:DAE]FCYLIN

              For [DAX]DAE0
                Raz UNPAID
                Filter [DCX] Where NUM=[F:DVS]NUM and REGTYP<>4
                Read [F:DCX]DVS7=[F:DAX]ACCNUM

                If fstat: OK=1 # 103540
                Else: If [F:DVS]NUM=[F:DCX]NUM & [F:DVS]VATRAT<>[F:DCX]VATRAT: OK=1: Endif
                Endif
                If OK=1
                  If [F:DAE]SNS<>[F:DAX]SNS or ([F:DAE]REFINTLIN<>"" and WEXTRACT=1) ##104188
                    UNPAID+=[F:DAX]AMTLED
                  Else
                    UNPAID-=[F:DAX]AMTLED
                  Endif
                Endif

#                If UNPAID>0
                If UNPAID <> 0  ##104188
                  NUMPAY=[F:DAX]ACCNUM
                  PAYDAT=[F:DAX]ACCDAT
                  Gosub ESC_PAGOS
                Endif

                Filter [DAE]
              Next ## NEXT DAX

            Endif
          Endif
        Endif
     Endif
   Next  ## NEXT DVS

   #### Repeat with the invoices with ENFDAT less of today
   Filter [DVS]

  # CRITERE='[F:DVS]CSHVAT=2 & [F:DVS]TOTALPAY<>2 & [F:DVS]REGTYP<11'
   CRITERE='[F:DVS]CSHVAT=2 & [F:DVS]TOTALPAY<>2 & [F:DVS]REGTYP<11 & [F:DVS]REGTYP<>4' #99434
   If [M:DIA]ALLCPY<>2
      CRITERE -='& [F:DVS]CPY="'+[M:DIA]CPY+'" '
   Endif
   If [M:DIA]ALLFCY<>2
      CRITERE -= '& [F:DVS]FCY="'+[M:DIA]FCY+'"'
   Endif

   CRITERE -= '& [F:DVS]ENFDAT<=['+format$(GFMD,[M:DIA]ENDDAT)+'] '
   CRITERE -= '& [F:DVS]ENFDAT<=['+format$(GFMD,date$)+']'

   For [DVS]DVS0 Where evalue(CRITERE)
     Raz TOTCOB, TOTVAT, WRET
     ##99434   ## Withholdins?
     Filter [DCX] Where NUM=[F:DVS]NUM and REGTYP=4
     Read [DCX]DVS0 First
     If !fstat:  WRET=abs([F:DCX]VATRAT/100): Else: Raz WRET: Endif
     Filter [DCX]

     If WRET=0
       UNPAID=[F:DVS]AMTNOTL+[F:DVS]AMTTAXL-[F:DVS]PAYCUR
     Else
       UNPAID=[F:DVS]AMTATIL-[F:DVS]PAYCUR
     Endif
     ## 99434

     If UNPAID>0
       Trbegin [DCY]
         [F:DCY]=[F:DVS]
         [F:DCY]REGTYP=99
         [F:DCY]DCLDAT=[F:DVS]ENFDAT
         [F:DCY]ACCDAT=[F:DVS]ENFDAT
         #Init 113910. Evolution request to write the ACCNUM from the invoice
          Case[F:DVS]ORIMOD
           When 5
             Read[SIH]SIH0=[F:DVS]NUM
             If !fstat: [F:DCY]ACCNUM=[F:SIH]ACCNUM: Endif
           When 6
             Read[PIH]PIH0=[F:DVS]NUM
             If !fstat: [F:DCY]ACCNUM=[F:PIH]ACCNUM: Endif
           When 3
            If [F:DVS]TAXTYP="R"
              Read[SIH]SIH0=[F:DVS]NUM
              If !fstat: [F:DCY]ACCNUM=[F:SIH]ACCNUM: Endif
            Else
             Read[PIH]PIH0=[F:DVS]NUM
             If !fstat: [F:DCY]ACCNUM=[F:PIH]ACCNUM: Endif
            Endif
         Endcase
#         [F:DCY]ACCNUM=[F:DAX]ACCNUM
         #End 113910
         ## 99434
         If WRET=0
           [F:DCY]AMTNOTL=ar2(UNPAID*[F:DVS]AMTNOTL/([F:DVS]AMTNOTL+[F:DVS]AMTTAXL))
           [F:DCY]AMTTAXL=ar2(UNPAID*[F:DVS]AMTTAXL/([F:DVS]AMTNOTL+[F:DVS]AMTTAXL))
           [F:DCY]AMTNOT=ar2(UNPAID*[F:DVS]AMTNOT/([F:DVS]AMTNOTL+[F:DVS]AMTTAXL))
           [F:DCY]AMTTAX=ar2(UNPAID*[F:DVS]AMTTAX/([F:DVS]AMTNOTL+[F:DVS]AMTTAXL))
         Else
 #          [F:DCY]AMTNOTL=ar2(UNPAID/((1-WRET)*(1+([F:DVS]VATRAT/100))))  # 103540
           [F:DCY]AMTNOTL=ar2(UNPAID/((1-WRET)+([F:DVS]VATRAT/100)))
           [F:DCY]AMTTAXL=ar2(AMTNOTL*([F:DVS]VATRAT/100))
           [F:DCY]AMTNOT=[F:DCY]AMTNOTL
           [F:DCY]AMTTAX=[F:DCY]AMTNOT
         Endif
         ## 99434
         [F:DCY]DEDAMT=[F:DCY]AMTTAX
         [F:DCY]DEDAMTL=[F:DCY]AMTTAXL
         [F:DCY]AMTATI=[F:DCY]AMTNOT+[F:DCY]AMTTAX
         [F:DCY]AMTATIL=[F:DCY]AMTNOTL+[F:DCY]AMTTAXL
         #[F:DCY]D347FLG=1                # SAM 114568
          [F:DCY]D347FLG=[F:DVS]D347FLG   # SAM 114568
         [F:DCY]PAM="O"
         [F:DCY]BIDNUM="Devengo a 31/12"
         Raz [F:DCY]ENFDAT, [F:DCY]TOTALPAY, [F:DCY]DECCUR, [F:DCY]PAYCUR
         [F:DCY]INDLNK=[F:DCY]TAXTYP+[F:DCY]TYP+[F:DCY]NUM+[F:DCY]VAT+num$([F:DCY]REGTYP)
         Write [DCY]
       Commit
       ## 99434
       Trbegin [DVS]
         [F:DVS]PAYCUR+=[F:DVS]AMTATIL
         [F:DVS]DECCUR+=[F:DVS]AMTTAXL
         [F:DVS]TOTALPAY=2
       ## 99434
         Rewrite [DVS]
         If fstat : GOK=0 : Call FSTA("DVS") From GLOCK : Break : Endif
       Commit
     Endif
   Next  ## NEXT DVS
Return

$ESC_PAGOS    ##101547
  Trbegin [DCY]
    [F:DCY]=[F:DVS]
    #[F:DCY]REGTYP=11 ### 104188 need to know the purchase type
    Case [F:DVS]REGTYP
      When 1: [F:DCY]REGTYP=11        # purchase
      When 2: [F:DCY]REGTYP=50        # Inmo
      When 3: [F:DCY]REGTYP=75        # services
    Endcase
    [F:DCY]ACCNUM=NUMPAY
    [F:DCY]DCLDAT=PAYDAT
    [F:DCY]ACCDAT=PAYDAT

    If EFEC=0
      Raz WPAY
#      Filter [DAE] Where TYP=[F:DAX]TYP and NUM=[F:DAX]NUM and ACC=[F:DAX]OFFACC
      If WEXTRACT=1
        Filter [DAE] Where TYP=[F:DAX]TYP and NUM=[F:DAX]NUM and MTC=WMTC # 103540
        Read [DAE]DAE0 First
        If !fstat
          Filter [PYH] Where NUM=right$([F:DAX]REFINTLIN,5)
        Endif
      Else
        Filter [DAE] Where TYP=[F:DAX]TYP and NUM=[F:DAX]NUM and ACC=[F:DAX]OFFACC
        Read [DAE]DAE0 First
        If !fstat
          Filter [PYH] Where find([F:DAE]ACCNUM, ACCNUMTRE())
        Endif
      Endif
      Read [PYH]PYH0 First
      If !fstat
        WPAY=1
        Read [TPY]TPY0=[F:PYH]PAYTYP
        If !fstat
          If [F:TPY]SPACSH=2
            [F:DCY]BIDNUM=mess(20,127,1)           #"Others"
            [F:DCY]PAM="O"
          Elsif [F:TPY]DACCHQNUM<3
            [F:DCY]BIDNUM=[F:PYH]CHQNUM
            [F:DCY]PAM="T"
          Endif
        Else
          Read [BAX]BAN0=[F:PYH]BAN
          If !fstat
            [F:DCY]BIDNUM=[F:BAX]BIDNUM
            [F:DCY]PAM="C"
          Endif
        Endif
      Endif
    Endif  ###jucon

    If [F:DCY]PAM=""
      [F:DCY]BIDNUM="Otros"
      [F:DCY]PAM="O"
    Endif

   # Filtering [PYD]
   If WPAY=1 and EFEC=0
     Raz TOTFAC, TOTFACVAT
     Filter [PYD] Where NUM=[F:PYH]NUM and VCRNUM=[F:DVS]NUM
     For [PYD]PYD0
       TOTFAC+=[F:PYD]PAYCURLIN
       TOTFACVAT+=ar2([F:PYD]PAYCURLIN*[F:DVS]VATRAT/100)
     Next
     Filter [PYD]
     UNPAID=TOTFAC
   Endif
   If UNPAID=0 : Commit: Return: Endif

#   If WRET=0   # SAM 111926
     [F:DCY]AMTNOTL=ar2(UNPAID*[F:DVS]AMTNOTL/[F:DVS]AMTATIL)
     [F:DCY]AMTTAXL=ar2(UNPAID*[F:DVS]AMTTAXL/[F:DVS]AMTATIL)
     [F:DCY]AMTNOT=ar2(UNPAID*[F:DVS]AMTNOT/[F:DVS]AMTATIL)
     [F:DCY]AMTTAX=ar2(UNPAID*[F:DVS]AMTTAX/[F:DVS]AMTATIL)
#   Else    # SAM 111926
#     # Init 103540
#     Local Decimal TOTFAR, PAYPER , TOTAMTVAT
#
#     If [F:DCY]ORIMOD=6
#       Read [PIV]PIV0=[F:PIH]NUM
#       If !fstat
#         TOTFAR=[F:PIV]TOTLINAMT+[F:PIV]TOTTAXAMT
#         PAYPER=([F:DVS]AMTNOTL+[F:DVS]AMTTAXL)/TOTFAR
#       Endif
#     Elsif [F:DCY]ORIMOD=3
#       For X=0 To dim([F:PIH]AMTTAX)-1
#         If [F:PIH]AMTTAX(X)>0 : TOTAMTVAT+=[F:PIH]AMTTAX(X): Endif
#       Next
#       TOTFAR=[F:PIH]AMTNOT +TOTAMTVAT
#       PAYPER=([F:DVS]AMTNOTL+[F:DVS]AMTTAXL)/TOTFAR
#     Endif
#     If UNPAID<[F:PIH]AMTATI: TOTCOB=UNPAID: Endif
#
#     If PAYPER=0: PAYPER=1: Endif # Salesżż??
#
#     [F:DVS]AMTNOTL=ar2(UNPAID*PAYPER)

#     [F:DCY]AMTNOTL=ar2(UNPAID/((1-WRET)*(1+([F:DVS]VATRAT/100))))
#     [F:DCY]AMTNOTL=ar2(UNPAID/((1-WRET)+([F:DVS]VATRAT/100)))
#     [F:DCY]AMTTAXL=ar2([F:DCY]AMTNOTL*([F:DVS]VATRAT/100))
#     [F:DCY]AMTNOT= [F:DCY]AMTNOTL
#     [F:DCY]AMTTAX= [F:DCY]AMTTAXL
# End  103540
#   Endif   # SAM 111926
   [F:DCY]DEDAMT= [F:DCY]AMTTAX
   [F:DCY]DEDAMTL=[F:DCY]AMTTAXL
   [F:DCY]AMTATI= [F:DCY]AMTNOT+[F:DCY]AMTTAX
   [F:DCY]AMTATIL=[F:DCY]AMTNOTL+[F:DCY]AMTTAXL
    #[F:DCY]D347FLG=1                # SAM 114568
   [F:DCY]D347FLG=[F:DVS]D347FLG     # SAM 114568

     ##jcc caja
   Raz [F:DCY]ENFDAT, [F:DCY]TOTALPAY, [F:DCY]PAYCUR,[F:DCY]DECCUR

   [F:DCY]INDLNK=[F:DCY]TAXTYP+[F:DCY]TYP+[F:DCY]NUM+[F:DCY]VAT+num$([F:DCY]REGTYP)

   $ESC_COBRO
     Write [DCY]
     If fstat: [F:DCY]REGTYP+=1: Goto ESC_COBRO: Endif
   Commit

 #  If WRET=0  # 103540    # SAM 111926
    TOTCOB=[F:DCY]AMTNOTL
    TOTVAT=[F:DCY]AMTTAXL
#   Else    # SAM 111926
#    If TOTCOB=0: TOTCOB=ar2(TOTFAR*PAYPER): Endif
#    TOTIVA=ar2(TOTCOB*([DVS]VATRAT/100))
#   Endif

   Raz TOTRET #, WRET    # SAM 111926
   If [F:DCY]ORIMOD=3 #103540
     For J=0 To dim([F:PIH]AMTTAX)-1
       If [F:PIH]AMTTAX(J)<0
         TOTRET+=abs([F:PIH]AMTTAX(J))
       Endif
     Next
   Endif

   If [F:DCY]ORIMOD=6  #103540
     For J=0 To dim([F:PIH]BASTAX)-1
       If [F:PIH]BASTAX(J)<0
         TOTRET+=abs([F:PIH]BASTAX(J))
       Endif
     Next
   Endif

   Trbegin [DVS]
     [F:DVS]PAYCUR+=TOTCOB
     [F:DVS]DECCUR+=TOTVAT

     If [F:DVS]PAYCUR>[F:DVS]AMTNOTL+[F:DVS]AMTTAXL
       [F:DVS]PAYCUR=[F:DVS]AMTNOTL+[F:DVS]AMTTAXL
     Endif
     If [F:DVS]DECCUR>[F:DVS]AMTTAXL
       [F:DVS]DECCUR=[F:DVS]AMTTAXL
     Endif
     If [F:DVS]PAYCUR+TOTRET>=[F:DVS]AMTNOTL+[F:DVS]AMTTAXL
       [F:DVS]TOTALPAY=2
     Else
       [F:DVS]TOTALPAY=1    #103540
     Endif
     Rewrite [DVS]
   Commit

Return    ## 101547

#------------------------------------------------------------------------------#
# Collected VAT on Sales invoice                                               #
#------------------------------------------------------------------------------#
$IVAREP
    # Init of variables
    Raz VCRNUM, WTYP, CODIVA, WREGTYP, WCPY, WFCY, WVATTYP, WINVTYP, WACCDAT, WDCLDAT
    Raz WEJERCICIO, WPERIODO, WTRIMESTRE, WBPRNUM, WBPRNAM, WCRN, WCRY, WEECNUM, WPOSCOD
    Raz WVAC, WBPRVCR, WABONUM, WVATRAT, WDEDRAT, WCUR, WBASECUR, WIVACUR, WAMTATICUR, WIVAIMPORT
    Raz WSNS, WCEEFLG, WLIBFLG, WD347FLG, WD349FLG, WDIGICFLG, WBPRDAT, WCODOPE
    Raz WISPVENTA, WDUA, WDOCTYP
    Raz WCSHVAT, WENFDAT, WPAYCUR, WDECCUR, WTOTALPAY  # 90370 - Cash VAT
    Raz WINVNUMDAT, WINVUPDFLG   # 108201
    Raz SWCEE  #117599

    # Sale Invoice number
    VCRNUM=[F:HAE]NUM
    # Document type number
    WTYP=[F:HAE]TYP
    # Entry to process
    WGASTRATFLG=2
    WORIMOD=[F:HAE]ORIMOD
    WESFACTURA=2
    Gosub VERIF_REP

    If OKK
        # Company
        WCPY=[F:HAE]CPY
        # Site
        WFCY=[F:HAE]FCY
        # Accounting date
        WACCDAT=[F:HAE]ACCDAT
        If WDCLDAT=[0/0/0] : WDCLDAT=WACCDAT : Endif
        # Source date
        WBPRDAT=[F:SIH]BPRDAT
        If WBPRDAT=[0/0/0] : WBPRDAT=WACCDAT : Endif
        # Fiscal year
        WEJERCICIO=[F:HAE]FIY
        # Period
        WPERIODO=[F:HAE]PER
        # Quarter
        WTRIMESTRE=int(month(WDCLDAT)/3) + (mod(month(WDCLDAT),3) > 0)
        # Invoice category
        WINVTYP=[F:SIH]INVTYP
        # Credit number
#        If WINVTYP=2 or WINVTYP=4 : WABONUM=[F:SIH]INVNUM : Endif   # 108201
        # 108201 ini  #109178
        If WINVTYP=2 or WINVTYP=4
          Local Integer WMOD
          If [F:SIH]INVNUM<>""
            WINVUPDFLG=1
            If [F:SIH]ORIMOD=3 : WABONUM=[F:SIH]INVNUM
              Local File SINVOICE [SIX]
              Read [SIX]SIH0=WABONUM
              If !fstat
                WINVNUMDAT=[F:SIX]ACCDAT
              Else
                WINVUPDFLG=2
              Endif
              Close File [SIX]
            Else
              If [F:SIV]SIHORI=4
                WABONUM=  [F:SIV]SIHORINUM
                WINVNUMDAT=[F:SIV]SIHORIDAT
              Else: WINVUPDFLG=2
              Endif
            Endif
          Else
            Local Date WDATINV
            WINVUPDFLG=2
            If [F:SIH]ORIMOD=5
              WMOD=1
              Local File SINVOICED [XSID]
              For [XSID] Where NUM=[F:SIH]NUM
                If [F:XSID]SIHORINUM<>""
                  Local File SINVOICE [XSIH]
                  Read [XSIH]SIH0=[F:XSID]SIHORINUM
                  If !fstat and [F:XSIH]ACCDAT>WDATINV
                    WABONUM=[F:XSID]SIHORINUM
                    WDATINV=[F:XSIH]ACCDAT
                  Endif
                  Close File [XSIH]
                Endif
              Next
              Close File [XSID]
            Endif
            If WDATINV<>[0/0/0] and WABONUM<>"": WINVNUMDAT=WDATINV: WINVUPDFLG=1: Endif
          Endif
          If WABONUM="" or WINVUPDFLG=2
            Local File INVNUMSPA [ISPX]
            Read [ISPX]ISP0=[F:SIH]NUM
            If fstat or (!fstat and [F:ISPX]INVNUM="")
              If WMOD=1
                MENSAJE=mess(5,14,1)+":"-[F:SIH]NUM -"."-mess(9,119,1)
              Else
                MENSAJE=mess(5,14,1)+"_"+mess(3,14,1)+":"-[F:SIH]NUM -"."-mess(9,119,1)
              Endif
              Call ECR_TRACE(MENSAJE,1) From GESECRAN
            Endif
            Close File [ISPX]
          Endif

        Endif                                        #108201 end #109178

        # Source document of sale invoice
        WBPRVCR=[F:SIH]NUM
        # BP name
        WBPRNAM(0)=[F:BPR]BPRNAM(0)
        WBPRNAM(1)=[F:BPR]BPRNAM(1)
        # CRN
        If [F:BPR]CRN <> ""
             WCRN=[F:BPR]CRN
             WEECNUM=[F:BPR]EECNUM
        Else
             WCRN=[F:BPR]EECNUM
        Endif
        # Country code
        If vireblc([F:SIH]CRY,2)<>""
            WCRY=[F:SIH]CRY
        Else
            WCRY=[F:BPR]CRY
        Endif
        # CRN for miscellaneous BP
        If GMODU(5)=2
            Read [SIV]SIV0=[F:SIH]NUM
            If fstat : Raz [F:SIV] : Endif
            If dim([F:SIV]BPIEECNUM)>0 and vireblc([F:SIV]BPIEECNUM,2)<>""
            #    If WEECNUM<>"" and WEECNUM<>[F:SIV]BPIEECNUM   #99434
                If WEECNUM<>[F:SIV]BPIEECNUM
                    WEECNUM=[F:SIV]BPIEECNUM
                    WCRN=WEECNUM
                Endif
            Endif
            If [F:SIV]BPDCRY<>"": WCRY=[F:SIV]BPDCRY: Endif
        Endif
        # Flag EEC
        If [F:TCY]CRY <> WCRY
            Read [F:TCY]TCY0=WCRY
            If fstat : Raz [F:TCY] : Endif
        Endif
        WCEEFLG=1
        If WCRY<>"ES" : WCEEFLG = [F:TCY]EECFLG : Endif
        # Type of identification document
        WDOCTYP=[F:BPR]DOCTYP #X3-62304 (JUCON 31/10/2017)
        If WDOCTYP=0
          If WDOCTYP=1 and [F:SIH]CRY="ES"
            WCRY="ES"
          Endif
          If [F:BPR]CRY="ES" and ([F:SIH]CRY="ES" or [F:SIH]CRY="")
            WDOCTYP=1
          Else
            If [F:TCY]EECFLG=2
               WDOCTYP=2
            Else
               WDOCTYP=6
            Endif
          Endif
        Endif
        If WDOCTYP=0: WDOCTYP=1: Endif
        # ZIP code
        WPOSCOD=[F:SIH]POSCOD
        If WPOSCOD=""
            Read [F:BPA]BPA0=1;WBPRNUM;[F:SIH]BPAINV
            If !fstat
                WPOSCOD=[F:BPA]POSCOD
            Else
                Read [F:BPA]BPA0=1;WBPRNUM;[F:BPR]BPAADD
                If !fstat : WPOSCOD=[F:BPA]POSCOD : Endif
            Endif
        Endif
        # VAC
        WVAC=[F:SIH]VAC
        WCSHVAT=[F:SIH]CSHVAT     #  90370 - Cash VAT
        WLIBFLG = 2 : WD349FLG = 1 : WD347FLG = 1 : WDIGICFLG=1

        Call LEC_TVB([F:CPY]LEG,WVAC) From CPTLEC
        If fstat : Raz [F:TVB] : Endif

        # EEC
        If [F:TVB]REGVAC=4 and [F:TVB]SPAOPE340<>"I"
            WCEEFLG=2
        Else
            WCEEFLG=1
        Endif
        If [F:TVB]SPAOPE340="I": WISPVENTA=2: Endif
        If [F:TVB]SPAEXEOPE=2 : WISPVENTA=2: Endif

        # Book flag
        If [F:TVB]SPAJOUDCL=2 : WLIBFLG=1  : Else : WLIBFLG=2  : Endif
        # 347 model flag
        If [F:TVB]SPADCL347=2 : WD347FLG=2 : Else : WD347FLG=1 : Endif
        # 349 model flag
        If WCEEFLG = 2
            If [F:TVB]SPADCL349=2 : WD349FLG=2 : Else : WD349FLG=1 : Endif
        Endif
        # Canarian flag
        If [F:TVB]SPAIGIC=2 : WDIGICFLG=2 : Else : WDIGICFLG=1 : Endif
        # Identify EEC. Country if non existent EECNUM and REGVAC=4
        If WEECNUM="" and WCEEFLG=2
           If left$(WCRN,2)= [F:TCY]CRYVATNUM
                WEECNUM = WCRN
           Elsif WCRN <> ""
                WEECNUM= [F:TCY]CRYVATNUM + WCRN
           Endif
        Endif
        ## Services flag
        WSERV349=[F:TVB]SPAEURSRV
        # Operation code
        If [F:TVB]SPAOPE340<>"": WCODOPE=[F:TVB]SPAOPE340: Endif
        # Currency
        WCUR=[F:HAE]CUR
        # Sense
        WSNS=[F:SIH]SNS
        If WSNS=-1 and WCODOPE="": WCODOPE="D": Endif
        # ATI amount
        WAMTATICUR=[F:SIH]AMTATI

        #  90370 - Cash VAT
        If WCSHVAT=2
           WENFDAT = gdat$(31,12, year([F:SIH]ACCDAT)+1)
        Else
           Raz WENFDAT
        Endif
        WPAYCUR =0
        WDECCUR = 0
        WTOTALPAY = 1
        #  90370 - Cash VAT

        Call IVA_FACTURA_VENTA(VCRNUM,NUMIVAS,CODIVA,WBASECUR,WIVACUR,WVATRAT,WDEDRAT,WREGTYP,WVATTYP)

        If NUMIVAS>0
            NUMFACVEN+=1
            Call DEBTRANS From GLOCK
            Gosub TR1
            MAXACCDAT=max(MAXACCDAT,[F:HAE]ACCDAT)
        Endif
    Else
        Call ECR_TRACE(MENSAJE,1) From GESECRAN
    Endif
Return

#------------------------------------------------------------------------------#

$VERIF_REP
    OKK=1
    # BP
    WBPRNUM=[F:SIH]BPR
    Read [F:BPR]BPR0=WBPRNUM
    If fstat
        MENSAJE=WBPRNUM + ":"- mess(242,107,1)- VCRNUM
        OKK=0 : Return
    Endif
    If GMODU(5)=2
        Raz [SIV]
        # Sales invoice
        If [F:SIH]ORIMOD=5
            Read [F:SIV]SIV0=VCRNUM
            If fstat
                MENSAJE= VCRNUM+":"-mess(243,107,1)-"SINVOICEV"
                OKK=0 : Return
            Endif
        Endif
    Endif

    XRATDIV(0)=[F:SIH]RATDIV(0)   # 107490
    If [F:SIH]RATMLT(0)<>0
        XRATMLT(0)=[F:SIH]RATMLT(0)
    Else
        If [F:SIH]CUR=GEURO
            XRATMLT(0)=1
            XRATDIV(0)=1      #107490
        Else
            Call CONVERT([F:SIH]CUR,GEURO,GEURO,[F:SIH]CURTYP,[F:SIH]ACCDAT,
&                        10^(GDECRCU+1),XRATMLT(0),STAT) From TRTDEV
            If STAT
                MENSAJE =mess(55,198,1) - [F:SIH]NUM -":"
                MENSAJE-=mess(16,114,1)-[F:SIH]CUR-"->"-GEURO-"("+format$("D:"+GFMDAT,[F:SIH]ACCDAT)-")"
                OKK=0 : Return
            Endif
            XRATMLT(0)=arr(XRATMLT(0)/10^(GDECRCU+1),10^-GDECRCU)
        Endif
    Endif
Return

#------------------------------------------------------------------------------#

Subprog IVA_FACTURA_VENTA(NUMFAC,NUMIVAS,CODIVA,BASECUR,IVACUR,VATRAT,DEDRAT,REGTYP,VATTYP)
Value    Char    NUMFAC()
Variable Integer NUMIVAS
Variable Char    CODIVA()(1..)
Variable Decimal BASECUR(1..)
Variable Decimal IVACUR(1..)
Variable Decimal VATRAT(1..)
Variable Decimal DEDRAT(1..)
Variable Integer REGTYP(1..)
Variable Integer VATTYP(1..)

# Variables declaration
Local    Integer I, J
Local    Char    WTEMPIVA(7)(1..10), AUX(7)
Local    Decimal WAMT

# Tables declaration
If clalev([F:SIH])=0 : Local File SINVOICE  [SIH] : Endif
If clalev([F:SIL])=0 : Local File BPCINVLIG [SIL] : Endif
If clalev([F:TVT])=0 : Local File TABVAT    [TVT] : Endif
If clalev([F:TRA])=0 : Local File TABRATVAT [TRA] : Endif
If clalev([F:SIT])=0 : Local File BPCINVVAT [SIT] : Endif

    Raz NUMIVAS,CODIVA,BASECUR,IVACUR,VATRAT,DEDRAT,REGTYP,WTEMPIVA

    If [F:SIH]NUM<>NUMFAC
        Read [F:SIH]SIH0=NUMFAC
        If fstat : End : Endif
    Endif

    If [F:SIH]ORIMOD=5
        For I=0 To dim([F:SIH]TAX)-1
            If vireblc([F:SIH]TAX(I),2)="" : Break : Endif

            Call LEC_TVT_LEG([F:CPY]LEG, [F:SIH]TAX(I)) From CPTLEC
            If fstat : Raz [F:TVT] : Endif
            If [F:TVT]VATTYP<>3
                NUMIVAS+=1
                VATTYP(NUMIVAS)=max(1,[F:TVT]VATTYP)
                CODIVA(NUMIVAS)=[F:SIH]TAX(I)
                BASECUR(NUMIVAS)=[F:SIH]BASTAX(I)
                IVACUR(NUMIVAS)=[F:SIH]AMTTAX(I)
                REGTYP(NUMIVAS)=1
                If GMODU(5)=2
                  Read [SIT]SIT0=[F:SIH]NUM
                  If !fstat : VATRAT(NUMIVAS)=[F:SIT]TAUX(I): Endif
                Endif

                Call GET_TASA(CODIVA(NUMIVAS),[F:SIH]CPY,[F:SIH]ACCDAT,VATRAT(NUMIVAS),DEDRAT(NUMIVAS))

                If GEXENTOFLG=2 : VATRAT(NUMIVAS)=0: Endif
            Endif
        Next
    Else
        For [F:SIL]SIL0 Where NUM=NUMFAC
            If vireblc([F:SIL]VAT,2)<>""
                AUX=[F:SIL]VAT+"~"
                CIVA=[F:SIL]VAT
#                If dim([F:SIL]SALTYP)>0 : AUX+=num$([F:SIL]SALTYP) : Endif # X3-89764
                WAMT=[F:SIL]AMTVAT
                Gosub LIN_BIC
            Endif
            If vireblc([F:SIL]TAX1,2)<>""
                AUX=[F:SIL]TAX1+"~"
                CIVA=[F:SIL]TAX1
#                If dim([F:SIL]SALTYP)>0 : AUX+=num$([F:SIL]SALTYP) : Endif # X3-89764
                WAMT=[F:SIL]AMTTAX1
                Gosub LIN_BIC
            Endif
            If vireblc([F:SIL]TAX2,2)<>""
                AUX=[F:SIL]TAX2+"~"
                CIVA=[F:SIL]TAX2
#                If dim([F:SIL]SALTYP)>0 : AUX+=num$([F:SIL]SALTYP) : Endif # X3-89764
                WAMT=[F:SIL]AMTTAX2
                Gosub LIN_BIC
            Endif
        Next
    Endif
End

#------------------------------------------------------------------------------#

$LIN_BIC
  Call LEC_TVT_LEG([F:CPY]LEG, CIVA) From CPTLEC

  If [F:TVT]VATTYP=3: Return: Endif

  Local Date VATSIHDAT: VATSIHDAT= [F:SIH]ACCDAT  # SAM 119935

  J = find(AUX,WTEMPIVA)
  If J=0
    NUMIVAS+=1
    J=NUMIVAS
    WTEMPIVA(J)=AUX
    CODIVA(J)=left$(AUX,instr(1,AUX,"~")-1)
    If CODIVA(J)<>[F:TVT]VAT
      Call LEC_TVT_LEG([F:CPY]LEG, CODIVA(J)) From CPTLEC
      If fstat : Raz [F:TVT] : Endif
    Endif
    VATTYP(J)=max(1,[F:TVT]VATTYP)
    If dim([F:SIL]SALTYP)>0
      REGTYP(J)=1
#      REGTYP(J)=max([F:SIL]SALTYP,1)   # without use in this moment
    Else
      REGTYP(J)=1
    Endif

    ## Ini SAM 119935 we use the tax rate from the original invoice
    If ([SIH]INVTYP=2 or  [SIH]INVTYP=4) and [F:SIH]INVNUM<>""
      Local File SINVOICE [MYSIH]
      Read [MYSIH]SIH0=[F:SIH]INVNUM
      If !fstat: VATSIHDAT=[F:MYSIH]ACCDAT: Endif
      Close File [MYSIH]
    Endif
#    Call GET_TASA(CODIVA(J),[F:SIH]CPY,[F:SIH]ACCDAT,VATRAT(J),DEDRAT(J))
    Call GET_TASA(CODIVA(J),[F:SIH]CPY,VATSIHDAT,VATRAT(J),DEDRAT(J))
    ## End SAM 119935 we use the tax rate from the original invoice

    If GEXENTOFLG=2 : VATRAT(J)=0: Endif
  Endif
  BASECUR(J)+=[F:SIL]AMTNOTLIN
  IVACUR(J)+=WAMT

  ## Ini SAM 119935 we use the tax rate from the original invoice and we write an advice in the log
  If ([SIH]INVTYP=2 or  [SIH]INVTYP=4) and [F:SIH]INVNUM<>"" and BASECUR(J)<>0 #X3-81977 JUCON (08/03/2018)
    If int(VATRAT(J))<>int(arr(IVACUR(J)/BASECUR(J),0.005)*100)
      MENSAJE=mess(2,267,1)-[F:SIH]NUM+"."-mess(364,199,1)- mess(43,109,1)-[F:SIH]INVNUM +"."
      Call ECR_TRACE(MENSAJE,1) From GESECRAN
    Endif
  Endif
  ## End SAM 119935 we use the tax rate from the original invoice and we write an advice in the log

# Ini SAM 119935
#    If [SIH]INVTYP=2 or  [SIH]INVTYP=4
#      If [F:TVT]VATTYP<>2
#         If VATRAT(J)<>0 and BASECUR(J)<>0 and BASECUR(J)>=1
#           If int(VATRAT(J))=VATRAT(J) and VATRAT(J)<>ar2(IVACUR(J)/BASECUR(J))*100
#              VATRAT(J)=ar2(IVACUR(J)/BASECUR(J))*100
#           Elsif int(VATRAT(J))<>VATRAT(J) and VATRAT(J)<>arr(IVACUR(J)/BASECUR(J),0.005)*100
#               VATRAT(J)=arr(IVACUR(J)/BASECUR(J),0.005)*100
#           Endif
#         Endif
#     Endif
#    Endif
# End SAM 119935
  Return

#------------------------------------------------------------------------------#
# Deductible VAT on Purchase invoice                                           #
#------------------------------------------------------------------------------#
$IVASOP
    # Init of variables
    Raz VCRNUM, WTYP, CODIVA, WREGTYP, WCPY, WFCY, WVATTYP, WINVTYP, WACCDAT, WDCLDAT
    Raz WEJERCICIO, WPERIODO, WTRIMESTRE, WBPRNUM, WBPRNAM, WCRN, WCRY, WEECNUM, WPOSCOD
    Raz WVAC, WBPRVCR, WABONUM, WVATRAT, WDEDRAT, WCUR, WBASECUR, WIVACUR, WAMTATICUR, WIVAIMPORT
    Raz WSNS, WCEEFLG, WLIBFLG, WD347FLG, WD349FLG, WDIGICFLG, WBPRDAT, WCODOPE
    Raz WISPVENTA, WDUA, WDOCTYP, SWCEE
    Raz WCSHVAT, WENFDAT, WPAYCUR, WDECCUR, WTOTALPAY  # 90370 - Cash VAT
    Raz WINVNUMDAT, WINVUPDFLG   #108201

    # Purchase invoice number
    VCRNUM=[F:HAE]NUM
    # Document type
    WTYP=[F:HAE]TYP
    # Entry to process
    WGASTRATFLG=2
    WORIMOD=[F:HAE]ORIMOD
    WESFACTURA=2

    Gosub VERIF_SOP

    If OKK
        # Company
        WCPY=[F:HAE]CPY
        # Site
        WFCY=[F:HAE]FCY
        # Accounting date
        WACCDAT=[F:HAE]ACCDAT
        If WDCLDAT=[0/0/0] : WDCLDAT=WACCDAT : Endif
        # Source date
        WBPRDAT=[F:PIH]BPRDAT
        If WBPRDAT=[0/0/0] : WBPRDAT=WDCLDAT : Endif
        # Fiscal year
        WEJERCICIO=[F:HAE]FIY
        # Period
        WPERIODO=[F:HAE]PER
        # Quarter
        WTRIMESTRE=int(month(WDCLDAT)/3) + (mod(month(WDCLDAT),3) > 0)
        # Invoice category
        WINVTYP=[F:PIH]INVTYP
        # Credit number
        If WINVTYP=2 or WINVTYP=4
#            WABONUM=[F:PIH]INVNUM   #108201 ini #109178
          Local Integer WMOD
          Local Date WDAT
          Local File PINVOICE [PIHX]
          If [F:PIH]INVNUM<>""
            WABONUM=[F:PIH]INVNUM
            Read [PIHX]PIH0=WABONUM
            If !fstat
              WINVNUMDAT=[F:PIHX]ACCDAT
              WINVUPDFLG=1
            Else
              Raz WABONUM
              WINVUPDFLG=2
            Endif
          Else
            WINVUPDFLG=2
            If [F:PIH]ORIMOD=6
              WMOD=1
              Local File PINVOICED [PIDX]
              For [PIDX] Where NUM=[F:PIH]NUM
                If [F:PIDX]INVNUM<>""
                  Read [PIHX]PIH0=[F:PIDX]INVNUM
                  If !fstat and [F:PIHX]ACCDAT>WDAT
                    WDAT=[F:PIHX]ACCDAT
                    WABONUM= [F:PIDX]INVNUM
                  Endif
                Endif
              Next
              Close File [PIDX]
            Endif
            If WDAT<>[0/0/0] and WABONUM<>"": WINVNUMDAT=WDAT: WINVUPDFLG=1: Endif
            If WABONUM="" or WINVUPDFLG=2
              Local File INVNUMSPA [ISPX]
              Read [ISPX]ISP0=[F:PIH]NUM
              If fstat or (!fstat and [F:ISPX]INVNUM="")
                If WMOD=1
                  MENSAJE=mess(6,14,1)+":"-[F:PIH]NUM -"."-mess(9,119,1)
                Else
                  MENSAJE=mess(6,14,1)+"_"+mess(3,14,1)+":"-[F:PIH]NUM -"."-mess(9,119,1)
                Endif
                Call ECR_TRACE(MENSAJE,1) From GESECRAN
              Endif
              Close File [ISPX]
            Endif
          Endif
          Close File [PIHX]
        Endif               # 108201 end   #109178

        # Source Document
        WBPRVCR=[F:PIH]BPRVCR
        # BP name
        WBPRNAM(0)=[F:BPR]BPRNAM(0)
        WBPRNAM(1)=[F:BPR]BPRNAM(1)
        # CRN
        If dim([F:PIH]CRN)>0 and vireblc([F:PIH]CRN,2)<>""
            WCRN=[F:PIH]CRN
        Else
            If [F:BPR]CRN <> ""
                WCRN=[F:BPR]CRN
            Else
                WCRN=[F:BPR]EECNUM
            Endif
        Endif
        # Country code
        If vireblc([F:PIH]CRY,2)<>""
            WCRY=[F:PIH]CRY
        Else
            WCRY=[F:BPR]CRY
        Endif
        # EEC flag
        If [F:TCY]CRY <> WCRY
            Read [F:TCY]TCY0=WCRY
            If fstat : Raz [F:TCY] : Endif
        Endif
        # Identify document
        WDOCTYP=[F:BPR]DOCTYP #X3-62304 (JUCON 31/10/2017)
          If WDOCTYP=0
            If [F:BPR]CRY="ES"
               WDOCTYP=1
            Else
              If [F:TCY]EECFLG=2
                WDOCTYP=2
              Else
                WDOCTYP=6
              Endif
            Endif
          Endif
        # ZIP code
        WPOSCOD=[F:PIH]POSCOD
        If WPOSCOD=""
            Read [F:BPA]BPA0=1;WBPRNUM;[F:PIH]BPAINV
            If !fstat
                WPOSCOD=[F:BPA]POSCOD
            Else
                Read [F:BPA]BPA0=1;WBPRNUM;[F:BPR]BPAADD
                If !fstat : WPOSCOD=[F:BPA]POSCOD : Endif
            Endif
        Endif
        # VAC
        WVAC=[F:PIH]VAC
        #  90370 - Cash VAT
        WCSHVAT=[F:PIH]CSHVAT
        If WCSHVAT=2
          WENFDAT = gdat$(31,12, year([F:PIH]ACCDAT)+1)
        Else
          Raz WENFDAT
        Endif
        #  90370 - Cash VAT

        WLIBFLG = 2 : WD349FLG = 1 : WD347FLG = 1 : WDIGICFLG=1
        Call LEC_TVB([F:CPY]LEG, WVAC) From CPTLEC
        If fstat : Raz [F:TVB] : Endif

        # EEC
        If [F:TVB]REGVAC=4 and [F:TVB]SPAOPE340<>"I"
            WCEEFLG=2
        Else
            WCEEFLG=1
        Endif
        If [F:TVB]SPAOPE340="I": WISPVENTA=3: Endif
        # Book flag
        If [F:TVB]SPAJOUDCL=2 : WLIBFLG=1  : Else : WLIBFLG=2  : Endif
        # 347 model flag
        If [F:TVB]SPADCL347=2 : WD347FLG=2 : Else : WD347FLG=1 : Endif
        # 349 model flag
        If [F:TVB]SPADCL349=2 : WD349FLG=2 : Else : WD349FLG=1 : Endif
        # Canarian flag
        If [F:TVB]SPAIGIC=2 : WDIGICFLG=2 : Else : WDIGICFLG=1 : Endif
        # EECNUM
        WEECNUM=[F:BPR]EECNUM
        If vireblc(WEECNUM,2)="" and WCEEFLG=2
            WEECNUM = [F:TCY]CRYVATNUM + WCRN
        Endif
        ## Services flag
        WSERV349=[F:TVB]SPAEURSRV
        # Operation code
        If [F:TVB]SPAOPE340<>"": WCODOPE=[F:TVB]SPAOPE340 : Endif
        # Currency
        WCUR=[F:HAE]CUR
        # Sense
        WSNS=[F:PIH]SNS
        If WSNS=-1 and WCODOPE="": WCODOPE="D": Endif
        # ATI amount
        WAMTATICUR=[F:PIH]AMTATI

        Call IVA_FACTURA_COMPRA(VCRNUM,NUMIVAS,CODIVA,WBASECUR,WIVACUR,WVATRAT,WDEDRAT,WREGTYP,WVATTYP,WIVAIMPORT,WDUA) ##0210, 0309-1

        If WCEEFLG=2 and WREGTYP<>3 and WSNS>0  : WCODOPE="P" : Endif  # ESCODOPE services

        If NUMIVAS>0
            NUMFACCOM+=1
            Call DEBTRANS From GLOCK
            Gosub TR1
            MAXACCDAT=max(MAXACCDAT,[F:HAE]ACCDAT)

            # EEC Invoices need two records (dedutible and collected)

            If [L]WCEEFLG=2 or [F:TVB]SPAISP=2
                SWCEE=0: XISP=0
                For I=1 To NUMIVAS
                    If WVATRAT(I)<>0 : SWCEE=1 : Break : Endif
                Next
                If SWCEE=1
                    WD349FLG=1 : WD347FLG=1
                    WTIPOIVA="R"   # Tax collected type
                    Call DEBTRANS From GLOCK
                    XISP=1
                    Gosub TR1
                    XISP=0
                    WTIPOIVA="S"   # Tax deductible type
                Endif
            Endif
        Endif
    Else
        Call ECR_TRACE(MENSAJE,1) From GESECRAN
    Endif
Return

#------------------------------------------------------------------------------#

$VERIF_SOP
    OKK=1
    # BP
    WBPRNUM=[F:PIH]BPR
    Read [F:BPR]BPR0=WBPRNUM
    If fstat
        MENSAJE=WBPRNUM+":" - mess(242,107,1) - VCRNUM
        OKK=0 : Return
    Endif
    # Purchase invoice
    If [F:PIH]ORIMOD=6
        Read [F:PIV]PIV0=VCRNUM
        If fstat
            MENSAJE=VCRNUM+":" - mess(243,107,1)-"PINVOICEV"
            OKK=0 : Return
        Endif
    Endif

    XRATDIV(0)=[F:PIH]RATDIV(0)   #107490
    If [F:PIH]RATMLT(0)<>0
        XRATMLT(0)=[F:PIH]RATMLT(0)
    Else
        If [F:PIH]CUR=GEURO
            XRATMLT(0)=1
            XRATDIV(0)=1          # 107490
        Else
            Call CONVERT([F:PIH]CUR,GEURO,GEURO,[F:PIH]CURTYP,[F:PIH]ACCDAT,
&                        10^(GDECRCU+1),XRATMLT(0),STAT) From TRTDEV
            If STAT
                MENSAJE =mess(55,198,1) - [F:PIH]NUM -":"
                MENSAJE=mess(16,114,1)-[F:PIH]CUR-"->"-GEURO-"("+format$("D:"+GFMDAT,[F:PIH]ACCDAT)-")"
                OKK=0 : Return
            Endif
            XRATMLT(0)=arr(XRATMLT(0)/10^(GDECRCU+1),10^-GDECRCU)
        Endif
    Endif
Return

#------------------------------------------------------------------------------#

Subprog IVA_FACTURA_COMPRA(NUMFAC,NUMIVAS,CODIVA,BASECUR,IVACUR,VATRAT,DEDRAT,REGTYP,VATTYP,IVAIMPORT,WDUA) ## 0210, 0309-1
Value    Char    NUMFAC()
Variable Integer NUMIVAS
Variable Char    CODIVA()(1..)
Variable Decimal BASECUR(1..)
Variable Decimal IVACUR(1..)
Variable Decimal VATRAT(1..)
Variable Decimal DEDRAT(1..)
Variable Integer REGTYP(1..)
Variable Integer VATTYP(1..)
Variable Integer IVAIMPORT(1..)
Variable Char WDUA()

# Variables declaration
Local    Integer I, J
Local    Char    WTEMPIVA(7)(1..10), AUX(7)
Local    Decimal WAMT

# Table declaration
If clalev([F:PIH])=0 : Local File PINVOICE  [PIH] : Endif
If clalev([F:PIL])=0 : Local File BPSINVLIG [PIL] : Endif
If clalev([F:TVT])=0 : Local File TABVAT    [TVT] : Endif
If clalev([F:TRA])=0 : Local File TABRATVAT [TRA] : Endif

    Raz NUMIVAS,CODIVA,BASECUR,IVACUR,VATRAT,DEDRAT,REGTYP,WTEMPIVA,IVAIMPORT

    If [F:PIH]NUM<>NUMFAC
        Read [F:PIH]PIH0=NUMFAC
        If fstat : End : Endif
    Endif
    #### SCD (Single Custom Declaration) management
    WDUA=[F:PIH]SPACUS
    If [F:PIH]ORIMOD=6 or [F:PIH]ORIMOD>15

        For I=0 To dim([F:PIH]TAX)-1
            If vireblc([F:PIH]TAX(I),2)="" : Break : Endif
            Call LEC_TVT_LEG([F:CPY]LEG, [F:PIH]TAX(I)) From CPTLEC

            If !fstat
                NUMIVAS+=1
                VATTYP(NUMIVAS)=max(1,[F:TVT]VATTYP)
                CODIVA(NUMIVAS)=[F:PIH]TAX(I)
                BASECUR(NUMIVAS)=[F:PIH]BASTAX(I)
                IVACUR(NUMIVAS)=[F:PIH]AMTTAX(I)
                REGTYP(NUMIVAS)=[F:PIH]PURTYP(I)
                If [F:TVT]VATTYP=3 : REGTYP(NUMIVAS)=4: Endif
                Call GET_TASA(CODIVA(NUMIVAS),[F:PIH]CPY,[F:PIH]ACCDAT,VATRAT(NUMIVAS),DEDRAT(NUMIVAS))

                ## Ini SAM 119935 We take the tax rate from "Purchase documents - taxes" table
                If VATRAT(NUMIVAS)<>0 and BASECUR(NUMIVAS)<>0
                  If clalev([F:PVV])=0 : Local File PVCRVAT  [PVV] : Endif
                  Filter [PVV] Where VCRNUM=[F:PIH]NUM and VCRTYP=8 and TAX=CODIVA(NUMIVAS)
                  Read [PVV]PVV0 First
                  If !fstat: VATRAT(NUMIVAS)=[F:PVV]VATRAT: Endif
                Endif
                # End SAM 119935 We take the tax rate from "Purchase documents - taxes" table

                ### Customs management
                If [F:TVT]SPAIMPVAT=2
                   IVAIMPORT(NUMIVAS)=2
                   IVACUR(NUMIVAS)=BASECUR(NUMIVAS)
                   If VATRAT(NUMIVAS)<>0
                       BASECUR(NUMIVAS)=ar2((BASECUR(NUMIVAS)*100)/VATRAT(NUMIVAS))
                   Endif
                Endif

# Ini SAM 119935 We take the tax rate from "Purchase documents - taxes" table
#                If VATRAT(NUMIVAS)<>0 and BASECUR(NUMIVAS)<>0  and BASECUR(NUMIVAS)>=1
#                  #Ini SAM 114814
#                  If int(VATRAT(NUMIVAS))=VATRAT(NUMIVAS) and VATRAT(NUMIVAS)<>ar2(IVACUR(NUMIVAS)/BASECUR(NUMIVAS))*100
#                      VATRAT(NUMIVAS)=ar2(IVACUR(NUMIVAS)/BASECUR(NUMIVAS))*100
#                   Elsif int(VATRAT(NUMIVAS))<>VATRAT(NUMIVAS) and VATRAT(NUMIVAS)<>arr(IVACUR(NUMIVAS)/BASECUR(NUMIVAS),0.005)*100
#                      VATRAT(NUMIVAS)=arr(IVACUR(NUMIVAS)/BASECUR(NUMIVAS),0.005)*100
#                   Endif

#                  If VATRAT(NUMIVAS)<>arr(IVACUR(NUMIVAS)/BASECUR(NUMIVAS),0.001)*100
#                        VATRAT(NUMIVAS)=arr(IVACUR(NUMIVAS)/BASECUR(NUMIVAS),0.001)*100
#                    Endif
                #End SAM 114814
#                Endif
# End SAM 119935 We take the tax rate from "Purchase documents - taxes" table

                # Footer elements type retention VATTYP=3
                If [F:TVT]VATTYP=3
                    Local Shortint WFOOT    ## 99434
                    For [F:PVF]PVF0 Where VCRNUM=NUMFAC and INVDTAVAT=CODIVA(NUMIVAS)
                        If !fstat:  XXX=find([F:PVF]INVDTAVAT, CODIVA(1..NUMIVAS))
                            If XXX=0: NUMIVAS+=1: Else NUMIVAS=XXX: Endif
                                VATTYP(NUMIVAS)= 3
                                If [F:PVF]INVDTAAMT<>0: WFOOT=1: Endif   ## 99434
                                Read [PFI]PFI0=[F:PVF]INVDTA
                                If !fstat: VATRAT(NUMIVAS)=[F:PFI]DEFVAL: IVACUR(NUMIVAS)+=[F:PVF]INVDTAAMT
                                Else VATRAT(NUMIVAS)=0: Endif
                                REGTYP(NUMIVAS)=4
                        Endif
                    Next
                   If VATRAT(NUMIVAS)> 0
                       # BASECUR(NUMIVAS)=-ar2((IVACUR(NUMIVAS)*100)/VATRAT(NUMIVAS))    # 99434
                        If WFOOT=1 :  BASECUR(NUMIVAS)=[F:PIH]AMTNOT+(IVACUR(NUMIVAS)*-1)
                        Else: #BASECUR(NUMIVAS)=[F:PIH]AMTNOT: Endif                      # 99434
                          BASECUR(NUMIVAS)=[F:PIH]BASTAX(NUMIVAS-1)
                        Endif
                        VATRAT(NUMIVAS)=(VATRAT(NUMIVAS)*-1)
                    Endif
                Endif

            Endif
        Next


    Else
        For [F:PIL]PIL0 Where NUM=NUMFAC
            If vireblc([F:PIL]VAT,2)<>""
                AUX=[F:PIL]VAT+"~"+num$([F:PIL]PURTYP)
                WAMT=[F:PIL]AMTVAT
                WDED=[F:PIL]DEDVAT
                Gosub LIN_BIS
            Endif
            If vireblc([F:PIL]TAX1,2)<>""
                AUX=[F:PIL]TAX1+"~"+num$([F:PIL]PURTYP)
                WAMT=[F:PIL]AMTTAX1
                WDED=[F:PIL]DEDTAX1
                Gosub LIN_BIS
            Endif
            If vireblc([F:PIL]TAX2,2)<>""
                AUX=[F:PIL]TAX2+"~"+num$([F:PIL]PURTYP)
                WAMT=[F:PIL]AMTTAX2
                WDED=[F:PIL]DEDTAX2
                Gosub LIN_BIS
            Endif
        Next
    Endif
End

#------------------------------------------------------------------------------#

$LIN_BIS
    J = find(AUX,WTEMPIVA)
    If J=0
        NUMIVAS+=1
        J=NUMIVAS

        WTEMPIVA(J)=AUX
        CODIVA(J)=left$(AUX,instr(1,AUX,"~")-1)
        If CODIVA(J)<>[F:TVT]VAT
            Call LEC_TVT_LEG([F:CPY]LEG, CODIVA(J)) From CPTLEC
            If fstat : Raz [F:TVT] : Endif
        Endif
        VATTYP(J)=max(1,[F:TVT]VATTYP)
        REGTYP(J)=[F:PIL]PURTYP
        If VATTYP(J)=3: REGTYP(J)=4: Endif
        Call GET_TASA(CODIVA(J),[F:PIH]CPY,[F:PIH]ACCDAT,VATRAT(J),DEDRAT(J))

        If WAMT<>0
            If abs(DEDRAT(J)-(100*WDED/WAMT))>0.1
              DEDRAT(J)=100*WDED/WAMT
            Endif
        Endif
    Endif
    #### Custom VAT (custom agency)
    Call LEC_TVT_LEG([F:CPY]LEG, CODIVA(J)) From CPTLEC
    If fstat : Raz [F:TVT] : Endif
    If [F:TVT]SPAIMPVAT<>2
        BASECUR(J)+=[F:PIL]AMTNOTLIN
        IVACUR(J)+=WAMT
    Else
       IVAIMPORT(J)=2
       IVACUR(J)+=[F:PIL]AMTNOTLIN
       If VATRAT(J)<>0
          BASECUR(J)+=ar2(([F:PIL]AMTNOTLIN*100)/VATRAT(J))
       Endif
    Endif

# Ini SAM 119935 We use the tax rate without rounding
#    If VATRAT(J)<>0 and BASECUR(J)<>0 and BASECUR(J)>=1
#      If int(VATRAT(J))=VATRAT(J) and VATRAT(J)<>ar2(IVACUR(J)/BASECUR(J))*100
#        VATRAT(J)=ar2(IVACUR(J)/BASECUR(J))*100
#      Elsif int(VATRAT(J))<>VATRAT(J) and VATRAT(J)<>arr(IVACUR(J)/BASECUR(J),0.005)*100
#        VATRAT(J)=arr(IVACUR(J)/BASECUR(J),0.005)*100
#      Endif
#    Endif
# End SAM 119935 We use the tax rate without rounding
Return

#------------------------------------------------------------------------------#

$TR1
    GOK = 1 : OKK=1
    Trbegin [F:DVS]

    For I=1 To NUMIVAS
        AUXINT=1
        If WTIPOIVA="R" and WCODOPE="I" and WREGTYP(I)=4: AUXINT=0: Endif
        If [L]WTIPOIVA="R" and SWCEE=1 and WVATRAT(I)=0 : AUXINT=0 : Endif
        If AUXINT=1
            Read [F:DVS]DVS0=WTIPOIVA;WTYP;VCRNUM;CODIVA(I);WREGTYP(I)
            If fstat or WREGTYP(I)=4  # second line of retention
                Raz fstat
                Raz [F:DVS]
                [F:DVS]TAXTYP=WTIPOIVA
                [F:DVS]TYP=WTYP
                [F:DVS]NUM=VCRNUM
                [F:DVS]VAT=CODIVA(I)

                Call LEC_TVT_LEG([F:CPY]LEG, [F:DVS]VAT) From CPTLEC
                If !fstat and [TVT]VATTYP=3
                    [F:DVS]NRS=[F:TVT]SPANRS
                Endif
                [F:DVS]RNT=[F:TVT]SPARNT
                [F:DVS]INR=[F:TVT]SPAINR
                [F:DVS]VACAGR=[F:TVT]SPAAGRVAT
                [F:DVS]REGTYP=WREGTYP(I)
                [F:DVS]CPY=WCPY
                [F:DVS]FCY=WFCY
                [F:DVS]VATTYP=WVATTYP(I)
                [F:DVS]INVTYP=WINVTYP
                [F:DVS]ACCDAT=WACCDAT
                [F:DVS]DCLDAT=WDCLDAT
                [F:DVS]FIY=WEJERCICIO
                [F:DVS]PER=WPERIODO
                [F:DVS]QUARTER=WTRIMESTRE
                [F:DVS]BPRNUM=WBPRNUM
                [F:DVS]BPRNAM(0)=WBPRNAM(0)
                [F:DVS]BPRNAM(1)=WBPRNAM(1)
                [F:DVS]CRN=WCRN
                [F:DVS]DOCTYP=WDOCTYP
                [F:DVS]CRY=WCRY
                [F:DVS]EECNUM=WEECNUM
                [F:DVS]POSCOD=WPOSCOD
                [F:DVS]VAC=WVAC
                [F:DVS]BPRVCR=WBPRVCR
                [F:DVS]INVNUM=WABONUM
                [F:DVS]VATRAT=WVATRAT(I)
                [F:DVS]CUR=WCUR
                [F:DVS]IMPORT=WIVAIMPORT(I)
                [F:DVS]SCDREF=WDUA
                [F:DVS]AMTNOT=WBASECUR(I)
                #[F:DVS]AMTNOTL=arr(WBASECUR(I) * XRATMLT(0),0.01)      # 107490
                [F:DVS]AMTNOTL=arr((WBASECUR(I) * XRATMLT(0))/XRATDIV(0),0.01)
                [F:DVS]AMTTAX=WIVACUR(I)
                #[F:DVS]AMTTAXL=arr(WIVACUR(I) * XRATMLT(0),0.01)       # 107490
                [F:DVS]AMTTAXL=arr((WIVACUR(I) * XRATMLT(0))/XRATDIV(0),0.01)
                [F:DVS]AMTATI=WAMTATICUR
                #[F:DVS]AMTATIL=arr(WAMTATICUR  * XRATMLT(0),0.01)      #107490
                [F:DVS]AMTATIL=arr((WAMTATICUR  * XRATMLT(0))/XRATDIV(0),0.01)
                ##99434 Apply % deductible only in deductible lines
                If WTIPOIVA="S"
                  [F:DVS]DEDAMT=arr([F:DVS]AMTTAX * WDEDRAT(I)/100,0.01)
                  [F:DVS]DEDAMTL=arr([F:DVS]AMTTAXL * WDEDRAT(I)/100,0.01)
                Else
                  [F:DVS]DEDAMT=arr([F:DVS]AMTTAX,0.01)
                  [F:DVS]DEDAMTL=arr([F:DVS]AMTTAXL,0.01)
                Endif
                ##99434
                [F:DVS]DEDRAT=ar2(WDEDRAT(I))
                [F:DVS]SNS=WSNS
                [F:DVS]CEEFLG=WCEEFLG
                If[F:DVS]CEEFLG=2  and [F:DVS]CRN<>""  # EEC identify
                    [F:DVS]CRN=[F:DVS]EECNUM
                Endif
                [F:DVS]CODOPE=WCODOPE

                # 108201
                 If dim([F:DVS]INVNUMDAT)>0
                   [F:DVS]INVNUMDAT=WINVNUMDAT
                   [F:DVS]INVUPDFLG=WINVUPDFLG
                 Endif


                # Tickets management
                If [F:DVS]TCKNUM<>0: [F:DVS]CODOPE="J": Endif

                [F:DVS]BOOKFLG=WLIBFLG
                [F:DVS]D347FLG=WD347FLG
#                If [F:DVS]CODOPE="I": [F:DVS]D347FLG=1: Endif    # 111926

                # Building location management
                If [M:DIA]RESINCRONI=2 and [F:DVS]CODOPE="R"
                    If clalev([F:BLS])=0: Local File BUILOCSPA [BLS]: Endif
                    Read [BLS]BLS0=[F:DVS]NUM
                    If !fstat:
                        [F:DVS]BUILOC=[F:BLS]BUILOC
                        [F:DVS]CDRREF=[F:BLS]CDRREF
                    Endif
                Endif

                # 108201
                If dim([F:DVS]INVNUMDAT)>0
                  If [M:DIA]RESINCRONI=2 and [F:DVS]INVUPDFLG=2
 #                   If dim([F:ISP]NUM)>0     # 110993
                      If clalev([F:ISP])=0: Local File INVNUMSPA [ISP]: Endif
                      Read [ISP]ISP0=[F:DVS]NUM
                      If !fstat:
                        [F:DVS]INVNUMDAT=[F:ISP]INVNUMDAT
                        [F:DVS]INVNUM   =[F:ISP]INVNUM
                      Endif
#                    Endif
                  Endif
                Endif
                # 108201

                # COD347 initialization
                If [F:DVS]TAXTYP="S": [F:DVS]COD347 = "A" : Elsif [F:DVS]TAXTYP="R": [F:DVS]COD347 = "B": Endif
                If [F:DVS]CODOPE="S"
                    If [F:DVS]TAXTYP="S": [F:DVS]COD347 = "E" : Elsif [F:DVS]TAXTYP="R": [F:DVS]COD347 = "B": Endif
                Endif
                If [F:DVS]CODOPE="T": [F:DVS]COD347 = "C": Endif
                If [F:DVS]CODOPE="U"
                     If [F:DVS]TAXTYP="S": [F:DVS]COD347 = "A" : Elsif [F:DVS]TAXTYP="R": [F:DVS]COD347 = "B": Endif
                Endif
                If [F:DVS]CODOPE="V": [F:DVS]COD347 = "G": Endif
                If [F:DVS]CODOPE="W": [F:DVS]COD347 = "B": Endif
                If [F:DVS]CODOPE="X": [F:DVS]COD347 = "A": Endif
                If [F:DVS]CODOPE="N": [F:DVS]COD347 = "F": Endif
                If [F:DVS]CODOPE="F": [F:DVS]COD347 = "A": Endif

                [F:DVS]D349FLG=WD349FLG
                [F:DVS]EURSRV=WSERV349
                [F:DVS]IGICFLG=WDIGICFLG
                [F:DVS]BPRDAT=WBPRDAT
                If [F:DVS]VAT=GEXETAX
                    [F:DVS]D349FLG=1
                    [F:DVS]BOOKFLG=1
                Endif
                [F:DVS]ORIMOD=WORIMOD
                [F:DVS]PROFLG=WGASTRATFLG
                [F:DVS]INVFLG=WESFACTURA
                [F:DVS]REVSAL=WISPVENTA
                # XDILNK: Use for tax inquiry
                [F:DVS]INDLNK=[F:DVS]TAXTYP+[F:DVS]TYP+[F:DVS]NUM+[F:DVS]VAT+num$([F:DVS]REGTYP)

                # Travel agency
                If [F:TVT]SPAPURTAG=2
                    [F:DVS]TAG=[F:TVT]SPAPURTAG
                    [F:DVS]VATRAT=0
                    [F:DVS]DEDRAT=0
                    [F:DVS]AMTNOT=[F:DVS]AMTNOT+[F:DVS]DEDAMT
                    [F:DVS]AMTNOTL=[F:DVS]AMTNOTL+[F:DVS]DEDAMTL
                Endif

                # SCD Reference management
                If [F:DVS]IMPORT=2 and [F:DVS]SCDREF<>"" and dim([F:PIH]SPACUSBPR)>0
                  Local Shortint WCONT
                  Local Char WFACUS(GLONVCR)  #X3-62304 (JUCON 31/10/2017)
                  Read [F:BPR]BPR0=[F:PIH]SPACUSBPR
                  If !fstat
                     WFACUS=[DVS]NUM  #X3-62304 (JUCON 31/10/2017)
#                     WDUA=vireblc(WDUA,4)
#                     H=instr(1,WDUA,"ES")
#                     If H>0 and len(WDUA)>GLONVCR+4: WDUA=right$(WDUA,4): Endif
#                     If len(WDUA)>GLONVCR : WDUA=left$(WDUA,GLONVCR): Endif
                     [F:DVS]NUM=WDUA                    ##140414  número DUA
 #                    [F:YDI]TYP=[F:PIH]PIVTYP          #### 200415 para búsqueda de Murano por tipo de factura en aduanas
                     If !clalev([F:DCX]): Local File DCLVATSPA [DCX]: Endif
                     $READ_DUA
                     Read [F:DCX]DVS0=[F:DVS]TAXTYP;[F:DVS]TYP;[F:DVS]NUM;[F:DVS]VAT;[F:DVS]REGTYP
                     If !fstat
                       J=instr(1,[F:DVS]NUM,"/")
                        If J>0
                          If J<GLONVCR  #X3-62304 (JUCON 31/10/2017)
                            WCONT=val(right$([F:DVS]NUM,J+1))
                            [F:DVS]NUM=left$([F:DVS]NUM,J)+num$(WCONT+1)
                          Else
                            [F:DVS]VAT=GEXETAX
                            Call ECR_TRACE(mess(55,198,1)-WFACUS+": SCDREF:"-[F:DVS]NUM-mess(2,124,1),1) From GESECRAN   # Campo demasiado largo
                          Endif
                        Else
                          If len ([F:DVS]NUM+"/1")<=GLONVCR
                            [F:DVS]NUM= [F:DVS]NUM+"/1"
                          Else
                            [F:DVS]VAT=GEXETAX
                            Call ECR_TRACE(mess(55,198,1)-WFACUS+": DUA:"-[F:DVS]NUM-mess(2,124,1),1) From GESECRAN   # Campo demasiado largo
                          Endif
                        Endif
                        Goto READ_DUA
                      Endif
                      ##99434 SCDREF is the document number for the second line
                      [F:DVS]BPRNUM=[F:PIH]SPACUSBPR
                      [F:DVS]BPRNAM(0)=[F:BPR]BPRNAM(0)
                      [F:DVS]BPRNAM(1)=[F:BPR]BPRNAM(1)
                      [F:DVS]DCLDAT=[F:PIH]SPACUSDAT
                      [F:DVS]CRY=[F:BPR]CRY
                      If dim([F:BPR]DOCTYP)>0
                        [F:DVS]DOCTYP=[F:BPR]DOCTYP
                      Endif
                      If [F:BPR]CRN <> ""
                        [F:DVS]CRN=[F:BPR]CRN
                      Else
                        [F:DVS]CRN=[F:BPR]EECNUM
                      Endif
                      [F:DVS]D347FLG=1
                      [F:DVS]IMPORT=1
                      Close Local File [DCX] ## 99434
                    Else
                        Call ECR_TRACE(mess(55,198,1)-[F:DVS]NUM-mess(244,107,1),0) From GESECRAN
                    Endif
                Endif
                #If [F:DVS]AMTNOT=0 and [F:DVS]AMTTAX=0: [F:DVS]VAT=GEXETAX: Endif # 107180

                If [F:DVS]TAXTYP="S" and [F:DVS]CRY<>"ES" and [F:DVS]CEEFLG<>2 and [F:DVS]CODOPE<>"I" and [F:DVS]SCDREF="" and [F:DVS]REGTYP<>3 and [F:TVT]SPASPETAX<>2
                    [F:DVS]VAT=GEXETAX
                Endif

                #  90370 - Cash VAT
                [F:DVS]CSHVAT=WCSHVAT
                [F:DVS]ENFDAT=WENFDAT
                [F:DVS]PAYCUR=WPAYCUR
                [F:DVS]DECCUR=WDECCUR
                [F:DVS]TOTALPAY=WTOTALPAY
                #  90370 - Cash VAT
                If [F:DVS]INVNUM<>"": [F:DVS]TOTALPAY=2: Endif ## 104188

                GPOINT = "BEFWRIDVS":  Gosub ENTREE From EXEFNC

                If [F:DVS]VAT<>GEXETAX and [F:TVT]SPAEXEVAT<>2
                     Write [F:DVS]

                     # Second retention line
                     If fstat and [F:DVS]REGTYP=4

                        Read [XDVS]DVS0=[F:DVS]TAXTYP;[F:DVS]TYP;[F:DVS]NUM;[F:DVS]VAT;[F:DVS]REGTYP
                        If !fstat
                           [F:XDVS]AMTNOT +=[F:DVS]AMTNOT
                           [F:XDVS]AMTNOTL+=[F:DVS]AMTNOTL
                           [F:XDVS]AMTTAX +=[F:DVS]AMTTAX
                           [F:XDVS]AMTTAXL+=[F:DVS]AMTTAXL
                           Rewrite [XDVS]
                        Endif
                     Endif
                     If fstat : GOK=0 : Call FSTA("DVS") From GLOCK : Break : Endif
                Endif
              Endif
        Endif
   Next

    If GOK<0   : Goto ROLL_TR1
    Elsif !GOK : Goto AB_TR1
    Endif
    Commit
    Raz [F:SIH], [F:PIH], [F:DVS]
Return

$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif

Return

#------------------------------------------------------------------------------#

$TR_DEL
    If clalev([F:DYY])=0 : Local File DCLVATSPA [DYY]: Endif
    CRITERE = "REGTYP<11"
#    CRITERE = "1=1"      ##104188
    If [M:DIA]ALLCPY<>2
        CRITERE -= '& CPY="'+[M:DIA]CPY+'"'
    Endif
    If [M:DIA]ALLFCY<>2
        CRITERE -= '& FCY="'+[M:DIA]FCY+'"'
    Endif
    If [M:DIA]STRDAT<>[0/0/0]
        CRITERE -= '& ACCDAT>=['+format$(GFMD,[M:DIA]STRDAT)+']'
    Endif
    If [M:DIA]ENDDAT<>[0/0/0]
        CRITERE -= '& ACCDAT<=['+format$(GFMD,[M:DIA]ENDDAT)+']'
    Endif

    GOK=1
    Trbegin [DVS]
#    Delete [F:DVS] Where evalue(CRITERE)
    For [DVS] Where evalue (CRITERE)
      Delete [F:DVS] Curr
      Delete [DYY] Where NUM=[F:DVS]NUM
      If fstat=1
        GOK = -1
        GLOCK = "$DCLVATSPA"
        Goto ROLL_TR_DEL
      Endif
    Next
    Commit
    Close Local File [DYY]
Return

$ROLL_TR_DEL
    Rollback
    Call ROLL From GLOCK
    If GROLL : Return : Else : Goto TR_DEL : Endif

#------------------------------------------------------------------------------#
# Cash payment for interface with "Impresos Oficiales"

$TR_DEL_METAL
    ## 99434  Filter by site to delete records of CASHPAYSPA table
    If !clalev ([F:DAE]): Local File GACCENTRYD [DAE]: Endif
    Local Shortint DOK

    CRITERE = "1=1"

    If [M:DIA]STRDAT<>[0/0/0]
        CRITERE -= '& [F:CPS]DATGAS>=['+format$(GFMD,[M:DIA]STRDAT)+']'
    Endif
    If [M:DIA]ENDDAT<>[0/0/0]
        CRITERE -= '& [F:CPS]DATGAS<=['+format$(GFMD,[M:DIA]ENDDAT)+']'
    Endif

    GOK=1

    Trbegin [CPS]
    If [M:DIA]ALLCPY=2
       Delete [F:CPS] Where evalue(CRITERE)
       If fstat : GOK=0: Endif
    Else
       Filter [F:CPS] Where evalue(CRITERE)
       For [F:CPS]
           Read [DAE]DAE2=[F:CPS]ACCNUM
           If !fstat
              Raz DOK
              If [M:DIA]ALLFCY=2
                If [F:DAE]CPY=[M:DIA]CPY: DOK=1: Endif
              Else
                If [F:DAE]CPY=[M:DIA]CPY and [F:DAE]FCYLIN=[M:DIA]FCY: DOK=1: Endif
              Endif
              If DOK=1
                 Delete [F:CPS] Curr
                 If fstat=1
                   GOK = -1
                   GLOCK = "$CASHPAYSPA"
                   Goto ROLL_TR_DEL_METAL
                 Endif
              Endif
           Endif
       Next
    Endif

    If fstat=1
        GOK = -1
        GLOCK = "$CASHPAYSPA"
        Goto ROLL_TR_DEL_METAL
    Endif

    Commit
Return

$ROLL_TR_DEL_METAL
    Rollback
    Call ROLL From GLOCK
    If GROLL : Return : Else : Goto TR_DEL_METAL : Endif

#------------------------------------------------------------------------------#


$LINGAS
    # Entry number
    VCRNUM=[F:HAE]NUM
    # document type
    WTYP=[F:HAE]TYP

    # Entry to process
    WGASTRATFLG=1
    WORIMOD=[F:HAE]ORIMOD
    WESFACTURA=1

    Raz WBPRNUM, NUMIVAS, WCODTAX, WBASECUR, WIVACUR, WVATRAT, WDEDRAT, XRATMLT(0), WCPY,
&       WFCY, WACCDAT, WDCLDAT, WBPRDAT, WEJERCICIO, WPERIODO, WTRIMESTRE,
&       WBPRNAM, WCRN, WCRY, WCEEFLG, WEECNUM, WPOSCOD, WCUR, WSNS, WVAC, WLIBFLG,
&       WD349FLG, WD347FLG, WDIGICFLG, WINVTYP, WABONUM, WBPRVCR, WAMTATICUR,
&       WBASELOC, WIVALOC, WCODBAN, WCODOPE, WDOCTYP

    Raz WCSHVAT, WENFDAT, WPAYCUR, WDECCUR, WTOTALPAY  # 90370 - Cash VAT
    Raz WREGTYP ## 101547

    # Company
    WCPY=[F:HAE]CPY
    # Site
    WFCY=[F:HAE]FCY
    # Accounting date
    WACCDAT=[F:HAE]ACCDAT
    # Declaration date
    WDCLDAT=WACCDAT
    # Source date
    WBPRDAT=[F:HAE]BPRDATVCR
    If WBPRDAT=[0/0/0] : WBPRDAT=WACCDAT : Endif
    # Fiscal year
    WEJERCICIO=[F:HAE]FIY
    # Period
    WPERIODO=[F:HAE]PER
    # Quarter
    WTRIMESTRE=int(month(WDCLDAT)/3) + (mod(month(WDCLDAT),3) > 0)
    # Currency
    WCUR=[F:HAE]CUR
    WBPRVCR=[F:HAE]BPRVCR #X3-62304 (JUCON 31/10/2017)
    For [F:DAE]DAE0 Where TYP=[F:HAE]TYP and NUM=[F:HAE]NUM and LEDTYP=1
        OKK=1
        Call LECPLAN([F:CPY]CPY,1, PLAN) From CPTDIV
        Call LEC_GAC([F:DAE]ACC, PLAN ) From CPTLEC
        If fstat : Raz OKK : Endif
        If OKK
            If [F:GAC]FLGVAT<>3
                # Propagate the first BP that we find in the lines
                If [F:DAE]BPR<>"" and WBPRNUM=""
                    WBPRNUM=[F:DAE]BPR
                Endif
                 If WBPRNUM="" and WCODBAN=""
                    Filter [BAN] Where BANACC=[F:DAE]ACC
                    Read [F:BAN]BAN0 First
                    Filter [BAN]
                    If !fstat : WCODBAN=[F:BAN]BAN:
                       If [F:BAN]BANBPR<>""
                           WBPRNUM=[F:BAN]BANBPR
                       Else
                           WBPRNUM=[F:BAN]BAN
                       Endif
                    Endif
                Endif
            Elsif [F:DAE]TAX<>""

                Call LEC_TVT_LEG([F:CPY]LEG, [F:DAE]TAX) From CPTLEC
                If !fstat and [F:TVT]SPAEXEVAT<>2
                    Case [F:GAC]VATIPT
                        When 1,2     : AUXCHR="R~" + [F:DAE]TAX
                        When 3       : AUXCHR="S~" + [F:DAE]TAX
                                       If WREGTYP=0: WREGTYP=1: Endif    # 101547
                        When 4       : AUXCHR="S~" + [F:DAE]TAX          # 101547
                                       If WREGTYP=0: WREGTYP=2 Endif     # 101547
                        When Default : AUXCHR="R~" + [F:DAE]TAX
                    Endcase
                    I=find(AUXCHR,WCODTAX)
                    If I=0
                        I=find("",WCODTAX)
                        If I<>0
                            WCODTAX(I)=AUXCHR
                            NUMIVAS+=1
                        Endif
                    Endif
                    If I>0
                        WREGTYP(I)=WREGTYP    # 101547
                        WVATTYP(I)=max(1,[F:TVT]VATTYP)
                        WIVACUR(I)+=[F:DAE]AMTCUR * [F:DAE]SNS
                        WIVALOC(I)+=[F:DAE]AMTLED * [F:DAE]SNS
                        Call GET_TASA([F:DAE]TAX,[F:HAE]CPY,[F:HAE]ACCDAT,WVATRAT(I),WDEDRAT(I))
                        If WVATRAT(I)<>0
                            WBASECUR(I)+=ar2(([F:DAE]AMTCUR*100)/WVATRAT(I) * [F:DAE]SNS)
                            WBASELOC(I)+=ar2(([F:DAE]AMTLED*100)/WVATRAT(I) * [F:DAE]SNS)
                        Else
                            WBASECUR(I)+=0
                            WBASELOC(I)+=0
                        Endif
                    Endif
                Endif
            Endif

            # Basis without quota

            If [F:GAC]FLGVAT=2 and [F:DAE]TAX<>""
                Call LEC_TVT_LEG([F:CPY]LEG,[F:DAE]TAX) From CPTLEC
                If !fstat and [F:TVT]SPAEXEVAT<>2
                    Case [F:GAC]VATIPT
                        When 1,2     : AUXCHR="R~" + [F:DAE]TAX
                        When 3       : AUXCHR="S~" + [F:DAE]TAX
                                       If WREGTYP=0: WREGTYP=1: Endif   # 101547
                        When 4       : AUXCHR="S~" + [F:DAE]TAX         # 101547
                                       If WREGTYP=0: WREGTYP=2: Endif   # 101547
                        When Default : AUXCHR="R~" + [F:DAE]TAX
                    Endcase
                    I=find(AUXCHR,WCODTAX)
                    If I=0
                        I=find("",WCODTAX)
                        If I<>0
                            WCODTAX(I)=AUXCHR
                            NUMIVAS+=1
                        Endif
                    Endif
                    If I>0
                        Call GET_TASA([F:DAE]TAX,[F:HAE]CPY,[F:HAE]ACCDAT,WVATRAT(I),WDEDRAT(I))
                        If WVATRAT(I)=0
                            WREGTYP(I)=WREGTYP      # 101547
                            WVATTYP(I)=max(1,[F:TVT]VATTYP)
                            WIVACUR(I)+=0
                            WIVALOC(I)+=0
                            WBASECUR(I)+=[F:DAE]AMTCUR * [F:DAE]SNS
                            WBASELOC(I)+=[F:DAE]AMTLED * [F:DAE]SNS
                        Endif
                    Endif
                Endif
            Endif
        Endif
    Next


    If NUMIVAS>0
        If WCODBAN<>"" and WBPRNUM=WCODBAN and [F:BAN]CRN="" and [F:BAN]BANBPR=""
           MENSAJE=mess(453,200,1)+":"-[F:BAN]BAN- mess(245,107,1) - [F:HAE]TYP + "/" + [F:HAE]NUM
           Call ECR_TRACE(MENSAJE,1) From GESECRAN : Return
        Endif

        If WBPRNUM=""
            If WCODBAN=""
                MENSAJE=mess(246,107,1) - [F:HAE]TYP + "/" + [F:HAE]NUM
                Call ECR_TRACE(MENSAJE,1) From GESECRAN : Return
            Else
                MENSAJE=mess(247,107,1) - [F:HAE]TYP + "/" + [F:HAE]NUM
                Call ECR_TRACE(MENSAJE,1) From GESECRAN : Return
            Endif
        Endif

        Read [F:BPR]BPR0=WBPRNUM
        If fstat and [F:BAN]CRN=""
            MENSAJE=mess(246,107,1) - [F:HAE]TYP + "/" + [F:HAE]NUM
            Call ECR_TRACE(MENSAJE,1) From GESECRAN : Return
        Endif

        If WCODBAN<>"" and [F:BAN]BANBPR=""
          WBPRNAM(0)=[F:BAN]PAB1
          # CRN
          WCRN=[F:BAN]CRN
          # Country code
          WCRY=[F:BAN]CRY
          # ZIP code
          WPOSCOD=[F:BAN]POSCOD
          WDOCTYP=1
        Else
          WBPRNAM(0)=[F:BPR]BPRNAM(0)
          WBPRNAM(1)=[F:BPR]BPRNAM(1)
          # CRN
          WCRN=[F:BPR]CRN
          # Country code
          WCRY=[F:BPR]CRY
          WDOCTYP=[F:BPR]DOCTYP #X3-62304 (JUCON 31/10/2017)
          # ZIP code
          Read [F:BPA]BPA0=1;WBPRNUM;[F:BPR]BPAADD
          If !fstat : WPOSCOD=[F:BPA]POSCOD : Endif

          # Type of document identify
          If WDOCTYP=0
            If [F:BPR]CRY="ES"
               WDOCTYP=1
            Else
              If [F:TCY]EECFLG=2
                WDOCTYP=2
              Else
                WDOCTYP=6
              Endif
            Endif
          Endif
        Endif
        # EEC Flag
        If [F:TCY]CRY <> WCRY
            Read [F:TCY]TCY0=WCRY
            If fstat : Raz [F:TCY] : Endif
        Endif

        # ZIP code
        Read [F:BPA]BPA0=1;WBPRNUM;[F:BPR]BPAADD
        If !fstat : WPOSCOD=[F:BPA]POSCOD : Endif

        For I=1 To NUMIVAS
            WTIPOIVA=left$(WCODTAX(I),1)
            WCODIVA=seg$(WCODTAX(I),3,2+GLONVAT)
            If WTIPOIVA="R"
                TIPOTER="C"
                If sgn(WBASECUR(I)) = -1
                    WSNS = +1
                Else
                    WSNS = -1
                Endif
            Else
                TIPOTER="F"
                If sgn(WBASECUR(I)) = +1
                    WSNS = +1
                Else
                    WSNS = -1
                Endif

            Endif
            If WVATRAT(I)>0
              WIVACUR(I)=abs(WIVACUR(I))
              WIVALOC(I)=abs(WIVALOC(I))
            Endif
            WBASECUR(I)=abs(WBASECUR(I))
            WBASELOC(I)=abs(WBASELOC(I))

            # Tax rule
            Call INIT_REGIME(WBPRNUM,WFCY,TIPOTER,WVAC) From CPTSUB

            If WVAC="": WVAC=WREGDEF: Endif
            WLIBFLG = 2 : WD349FLG = 1 : WD347FLG = 1 : WDIGICFLG=1
            Call LEC_TVB([F:CPY]LEG,WVAC)From CPTLEC
            If fstat : Raz [F:TVB] : Endif

            WCEEFLG=1
            If WCRY<>"ES"
                If [F:TVB]REGVAC=4
                  WCEEFLG = 2
                Else
                  WCEEFLG = 1
                Endif
                WCODOPE=[F:TVB]SPAOPE340
            Endif
            # EEC identify
            WEECNUM=[F:BPR]EECNUM
            If vireblc(WEECNUM,2)="" and WCEEFLG=2
              WEECNUM = [F:TCY]CRYVATNUM + WCRN
            Endif
            # Book flag
            If [F:TVB]SPAJOUDCL=2 : WLIBFLG=1  : Else : WLIBFLG=2  : Endif
            # 347 model flag
            If [F:TVB]SPADCL347=2 : WD347FLG=2 : Else : WD347FLG=1 : Endif
            # 349 model flag
            If WCEEFLG = 2
              If [F:TVB]SPADCL349=2 : WD349FLG=2 : Else : WD349FLG=1 : Endif
            Endif
            # Services flag
            WSERV349=[F:TVB]SPAEURSRV
            # Canarian flag
            If [F:TVB]SPAIGIC=2 : WDIGICFLG=2 : Else : WDIGICFLG=1 : Endif
            # Operation code
            If [F:TVB]SPAOPE340<>"" : WCODOPE=[F:TVB]SPAOPE340 : Endif
            # Invoice Category
            If WSNS = -1 : WINVTYP=2 : Else : WINVTYP=1 : Endif
            Read [F:DVS]DVS0=WTIPOIVA;WTYP;VCRNUM;WCODIVA;1
            If fstat
              Call DEBTRANS From GLOCK
              Gosub TR2
            Endif
        Next
     Endif
Return

#------------------------------------------------------------------------------#

$TR2
    GOK = 1
    Trbegin [F:DVS]

    [F:DVS]TAXTYP=WTIPOIVA
    [F:DVS]TYP=WTYP
    [F:DVS]NUM=VCRNUM
    [F:DVS]VAT=WCODIVA
    If WREGTYP(I)<>0        # 101547
      [F:DVS]REGTYP=WREGTYP
    Else
      [F:DVS]REGTYP=1
    Endif                   # 101547

    Call LEC_TVT_LEG([F:CPY]LEG, [F:DVS]VAT) From CPTLEC
    If !fstat and [TVT]VATTYP=3
       [F:DVS]NRS=[F:TVT]SPANRS
       [F:DVS]RNT=[F:TVT]SPARNT
       [F:DVS]INR=[F:TVT]SPAINR
       WVATRAT(I)=abs(WVATRAT(I))*-1
       [F:DVS]REGTYP=4
    Endif
    [F:DVS]VACAGR=[F:TVT]SPAAGRVAT
    [F:DVS]CPY=WCPY
    [F:DVS]FCY=WFCY
    [F:DVS]VATTYP=WVATTYP(I)
    [F:DVS]INVTYP=WINVTYP
    [F:DVS]ACCDAT=WACCDAT
    [F:DVS]DCLDAT=WDCLDAT
    [F:DVS]FIY=WEJERCICIO
    [F:DVS]PER=WPERIODO
    [F:DVS]QUARTER=WTRIMESTRE
    [F:DVS]BPRNUM=WBPRNUM
    [F:DVS]BPRNAM(0)=WBPRNAM(0)
    [F:DVS]BPRNAM(1)=WBPRNAM(1)
    [F:DVS]CRN=WCRN
    [F:DVS]DOCTYP=WDOCTYP
    [F:DVS]CRY=WCRY
    [F:DVS]EECNUM=WEECNUM
    [F:DVS]POSCOD=WPOSCOD
    [F:DVS]VAC=WVAC
    [F:DVS]BPRVCR=WBPRVCR
    [F:DVS]INVNUM=WABONUM
    [F:DVS]VATRAT=WVATRAT(I)
    [F:DVS]DEDRAT=WDEDRAT(I)
    [F:DVS]CUR=WCUR
    [F:DVS]AMTNOT=WBASECUR(I)
    [F:DVS]AMTNOTL=WBASELOC(I)
    [F:DVS]AMTTAX=WIVACUR(I)
    [F:DVS]AMTTAXL=WIVALOC(I)
    If WTIPOIVA="S"   ##99434 Apply % deductible only in deductible lines
      [F:DVS]DEDAMT=arr([F:DVS]AMTTAX * ([F:DVS]DEDRAT/100),0.01)
      [F:DVS]DEDAMTL=arr([F:DVS]AMTTAXL * ([F:DVS]DEDRAT/100),0.01)
    Else
      [F:DVS]DEDAMT=arr([F:DVS]AMTTAX,0.01)
      [F:DVS]DEDAMTL=arr([F:DVS]AMTTAXL,0.01)
    Endif     ##99434
    [F:DVS]AMTATI=0
    [F:DVS]AMTATIL=0
    [F:DVS]SNS=WSNS
    [F:DVS]CEEFLG=WCEEFLG
    [F:DVS]CODOPE=WCODOPE

    # Catastre data
    If [M:DIA]RESINCRONI=2 and [F:DVS]CODOPE="R"
        If clalev([F:BLS])=0: Local File BUILOCSPA [BLS]: Endif
        Read [BLS]BLS0=[F:DVS]NUM
        If !fstat:
            [F:DVS]BUILOC=[F:BLS]BUILOC
            [F:DVS]CDRREF=[F:BLS]CDRREF
        Endif
     Endif

     # 108201
     If dim([F:DVS]INVNUMDAT)>0
       If [M:DIA]RESINCRONI=2 and [F:DVS]INVUPDFLG=2
         If dim([F:ISP]NUM)>0
           If clalev([F:ISP])=0: Local File INVNUMSPA [ISP]: Endif
           Read [ISP]ISP0=[F:DVS]NUM
           If !fstat:
             [F:DVS]INVNUMDAT=[F:ISP]INVNUMDAT
             [F:DVS]INVNUM   =[F:ISP]INVNUM
           Endif
         Endif
       Endif
     Endif
     # 108201

     # Code347 initialization
     If [F:DVS]TAXTYP="S": [F:DVS]COD347 = "A" : Elsif [F:DVS]TAXTYP="R": [F:DVS]COD347 = "B": Endif
     If [F:DVS]CODOPE="S"
         If [F:DVS]TAXTYP="S": [F:DVS]COD347 = "E" : Elsif [F:DVS]TAXTYP="R": [F:DVS]COD347 = "B": Endif
     Endif
     If [F:DVS]CODOPE="T": [F:DVS]COD347 = "C": Endif
     If [F:DVS]CODOPE="U"
         If [F:DVS]TAXTYP="S": [F:DVS]COD347 = "A" : Elsif [F:DVS]TAXTYP="R": [F:DVS]COD347 = "B": Endif
     Endif
     If [F:DVS]CODOPE="V": [F:DVS]COD347 = "G": Endif
     If [F:DVS]CODOPE="W": [F:DVS]COD347 = "B": Endif
     If [F:DVS]CODOPE="X": [F:DVS]COD347 = "A": Endif
     If [F:DVS]CODOPE="N": [F:DVS]COD347 = "F": Endif
     If [F:DVS]CODOPE="F": [F:DVS]COD347 = "A": Endif

    [F:DVS]BOOKFLG=WLIBFLG
    [F:DVS]D347FLG=WD347FLG
    [F:DVS]D349FLG=WD349FLG
    [F:DVS]EURSRV=WSERV349
    [F:DVS]BPRDAT=WBPRDAT
    [F:DVS]ORIMOD=WORIMOD
    [F:DVS]PROFLG=WGASTRATFLG
    [F:DVS]INVFLG=WESFACTURA
    # INDLNK: used for tax inquiry
    [F:DVS]INDLNK=[F:DVS]TAXTYP+[F:DVS]TYP+[F:DVS]NUM+[F:DVS]VAT+num$([F:DVS]REGTYP)

    #If [F:DVS]AMTNOT=0 and [F:DVS]AMTTAX=0: [F:DVS]VAT=GEXETAX: Endif  # 107180

    GPOINT = "BEFWRIDVS":  Gosub ENTREE From EXEFNC

    If [F:DVS]VAT<>GEXETAX and [F:TVT]SPAEXEVAT<>2
       Write [F:DVS]
       If fstat
         GOK=0
         Call FSTA("DVS") From GLOCK
         Goto AB_TR2
      Endif
      NUMLINGAS+=1
    Endif
    Commit
    Raz [F:DVS]
Return

$AB_TR2
Rollback
Return

#------------------------------------------------------------------------------#

$TERMINE

    Unlock =BLOQUEO
    If !GSERVEUR
        TRA=1
    Else
        TRA=0
    Endif
Return

#------------------------------------------------------------------------------#

Subprog GET_TASA(CODIVA,SOC,ACCDAT,VATRAT,DEDRAT)
Value    Char CODIVA()
Value    Char SOC()
Value    Date ACCDAT
Variable Decimal VATRAT
Variable Decimal DEDRAT

   Raz GEXENTOFLG
   Raz DEDRAT

    Call LEC_TVT_LEG([F:CPY]LEG,CODIVA) From CPTLEC
    Filter [TRA] Where VAT=CODIVA & CPY=SOC & STRDAT<=ACCDAT & LEG=[F:TVT]LEG
    Read [TRA]TRA0 Last

    If !fstat
      If VATRAT=0: VATRAT = [F:TRA]VATRAT: Endif
      DEDRAT = [F:TRA]DEDRAT
      GEXENTOFLG=[F:TRA]VATEXEFLG   # Tax=0 if exemption flag
    Else
      Filter [F:TRA] Where VAT=CODIVA & CPY="" & STRDAT<=ACCDAT & LEG=[F:TVT]LEG
      Read [TRA]TRA0 Last
      If !fstat
         If VATRAT=0: VATRAT = [F:TRA]VATRAT: Endif
         DEDRAT = [F:TRA]DEDRAT
         GEXENTOFLG=[F:TRA]VATEXEFLG   # Tax=0 if exemption flag
      Endif
    Endif
    Filter [F:TRA]
End

#------------------------------------------------------------------------------#

$UPD_HISTORY
    Trbegin [F:HTS]
    Readlock [F:HTS]HTS0=[M:DIA]YEA;[M:DIA]CPY;[M:DIA]FCY
    If fstat =1
      GOK=-1: GLOCK="$HISTAXSPA"-[M:DIA]YEA-[M:DIA]CPY-[M:DIA]FCY
    Elsif !fstat
        [F:HTS]LASTUPDDAT = MAXACCDAT
        [F:HTS]UPDDAT     = date$
        Rewrite [HTS]
         If fstat
          GOK=0: Call FSTA("HTS") From GLOCK
        Endif
    Else
        Raz [F:HTS]
        [F:HTS]YEA        = [M:DIA]YEA
        [F:HTS]CPY        = [M:DIA]CPY
        [F:HTS]FCY        = [M:DIA]FCY
        [F:HTS]LASTUPDDAT = MAXACCDAT
        [F:HTS]UPDDAT     = date$
        Write [HTS]
        If fstat
          GOK=0: Call FSTA("HTS") From GLOCK
        Endif
    Endif
    If GOK<0 : Goto ROLL_TRHTS
    Elsif !GOK: Goto AB_TRHTS
    Endif
   Commit
Return
$ROLL_TRHTS
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto UPD_HISTORY : Endif
Return

$AB_TRHTS
Rollback
Return


#------------------------------------------------------------------------------#
$CALMET        # Cash payment interface for "Impresos Oficiales"

Local Char CRITMET (255)
Local Integer LINMET
Raz NUMREGMETAL
CRITMET="1=1"

If ALLCPY<>2: CRITMET-='& [F:PYH]CPY= [M:DIA]CPY': Endif
If ALLFCY<>2: CRITMET-='& [F:PYH]FCY= [M:DIA]FCY': Endif

CRITMET -= '& [F:PYH]ACCDAT>=['+format$(GFMD,[M:DIA]STRDAT)+']'
CRITMET -= '& [F:PYH]ACCDAT<=['+format$(GFMD,[M:DIA]ENDDAT)+']'

# Search for cash payment

Link [PYD] With [PYH]PYH0=[F:PYD]NUM, [TPY]TPY0=[F:PYH]PAYTYP As [PYHX] Order By Key KEY1=[PYD]NUM

Filter [PYHX] Where year([F:PYH]ACCDAT)=[M:DIA]YEA & [F:PYH]SNS=2 & [F:TPY]SPACSH=2 & evalue (CRITMET)

Raz LINMET

For [PYHX]KEY1
        Raz [F:CPS]
        Trbegin [CPS]
        Filter [PAN] Where TYPNUM=3 and STA=3 and NUM=[F:PYHX]NUM and RVSACCNUM=0
        Read [PAN]PAN0 First
        Filter [PAN]
        If !fstat
          Read [CPS]CPS1=[F:PAN]ACCNUM    #X3-65251 (JUCON 21/11/2017)
          If fstat
            [F:CPS]ACCNUM=[F:PAN]ACCNUM
          Else
            [F:CPS]ACCNUM=[F:PYHX]DUDNUM
          Endif
          Read [DAE]DAE2=[F:PAN]ACCNUM
            If !fstat:
                If dim([F:CPS]CPY)>0    #X3-62304 (JUCON 31/10/2017)
                  [F:CPS]CPY=[F:DAE]CPY
                  [F:CPS]FCY=[F:DAE]FCYLIN
                Endif
                [F:CPS]TYP=[F:DAE]TYP
                [F:CPS]NUM=[F:DAE]NUM
                [F:CPS]DATGAS=[F:DAE]ACCDAT
                [F:CPS]LIN=LINMET+1
                [F:CPS]INVNUM=[F:PYHX]VCRNUM
                If [F:PYHX]VCRNUM<>""
                   [F:CPS]BPRNUM=[F:PYHX]BPRINV
                   [F:CPS]AMOUNT=[F:PYHX]PAYLOCLIN
               Else
                   [F:CPS]BPRNUM=[F:PYHX]BPRLIN
                   [F:CPS]AMOUNT=[F:PYHX]AMTLIN2
               Endif

               If [F:CPS]BPRNUM="":[F:CPS]BPRNUM=[F:PYH]BPR : Endif
               If [F:PYHX]VCRNUM<>""
                  Read [SIH]SIH0= [F:PYHX]VCRNUM
                  If !fstat: [F:CPS]INVDAT=[F:SIH]ACCDAT: Else: [F:CPS]INVDAT=[F:PYH]ACCDAT: Endif
               Else
                  [F:CPS]INVDAT=[F:PYH]ACCDAT
               Endif
               NUMREGMETAL+=1
               Read [CPSX]CPS0=[F:CPS]TYP;[F:CPS]NUM;[F:CPS]LIN
               If !fstat
                  Filter [CPSX] Where TYP=[F:CPS]TYP and NUM=[F:CPS]NUM
                  Read [CPSX]CPS0 Last
                  Filter [CPSX]
                  If !fstat
                     [F:CPS]LIN=[F:CPSX]LIN+1
                     ## 99434 Entry point for cash payment
                     GPOINT = "BEFWRICPS" : Gosub  ENTREE From EXEFNC
                     Write [CPS]
                  Endif
               Else
                 ## 99434 Entry point for cash payment
                 GPOINT = "BEFWRICPS" : Gosub  ENTREE From EXEFNC
                 Write [CPS]
               Endif
            Endif
         Endif
        Commit
        LINMET+=1
 Next

Return
#------------------------------------------------------------------------------#

Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
    If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
        Grizo ALLCPY
        Actzo CPY
        mkstat = 1 : End
    Endif
End

#------------------------------------------------------------------------------#

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
    If VALEUR=2
        Effzo [M]CPY,FCY : Diszo [M]CPY,FCY
        [M]ALLFCY=2 : Affzo ALLFCY : Diszo ALLFCY
    Else
        Actzo CPY,ALLFCY
    Endif
End

#------------------------------------------------------------------------------#

Subprog AS_CPY(VALEUR)
Variable Char    VALEUR()
    If [M]ALLCPY=2 : mkstat = 1 : Endif
End

#------------------------------------------------------------------------------#

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
    If [M]ALLCPY<>2 and VALEUR="" : mkstat=1 : Endif
    Call CTLCPYLEGVAT(VALEUR,"SPA") From DCLVATSTD
End

#------------------------------------------------------------------------------#

Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
    Call INIALLFCY(VALEUR,[M]CPY) From CPTTRT
    If [M]ALLCPY=2 : VALEUR = 2 : Endif
    If VALEUR=2
        Effzo FCY : Grizo FCY
    Else
        Actzo FCY
    Endif
End

#------------------------------------------------------------------------------#

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
    If VALEUR=2 : Effzo FCY : Diszo FCY : Else : Actzo FCY : Endif
End

#------------------------------------------------------------------------------#

Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
    If [M]ALLFCY=2 : mkstat = 1 : Endif
End

#------------------------------------------------------------------------------#

Subprog AS_STRDAT(VALEUR)
Variable Date    VALEUR
End

#------------------------------------------------------------------------------#

Subprog C_STRDAT(VALEUR)
Variable Date    VALEUR
    If VALEUR=[0/0/0] : End : Endif

    If year(VALEUR)<>[M:DIA]YEA
        GMESSAGE=mess(248,107,1) - num$([M:DIA]YEA)
        mkstat=2
    Endif
End

#------------------------------------------------------------------------------#

Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
    If VALEUR=[0/0/0] and [M:DIA]STRDAT=[0/0/0] : End : Endif

    If year(VALEUR)<>[M:DIA]YEA
        GMESSAGE=mess(248,107,1) - num$([M:DIA]YEA)
        mkstat=2
    Endif
End

#------------------------------------------------------------------------------#

Subprog AM_YEA(VALEUR)
Variable Decimal VALEUR
    Call CHG_LASTDAT("YEA",num$(VALEUR))
End

#------------------------------------------------------------------------------#

Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR
    Call CHG_LASTDAT("ALLCPY",num$(VALEUR))
End

#------------------------------------------------------------------------------#

Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()
    Call CHG_LASTDAT("CPY",VALEUR)
End

#------------------------------------------------------------------------------#

Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR
    Call CHG_LASTDAT("ALLFCY",num$(VALEUR))
End

#------------------------------------------------------------------------------#

Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
    Call CHG_LASTDAT("FCY",VALEUR)
End

#------------------------------------------------------------------------------#

Subprog CHG_LASTDAT(NOMCAMPO,VALOR)
Value Char    NOMCAMPO()
Value Char    VALOR()
Local Date    LASTUPDDAT,AUXDATE1,AUXDATE2,AUXDATE3,UPD1,UPD2,UPD3
Local Char    AUXCPY(GLONCPY),AUXFCY(GLONFCY)
Local Integer K,AUXANYO,AUXALLCPY,AUXALLFCY

    If find(NOMCAMPO,"YEA","ALLCPY","CPY","ALLFCY","FCY")
        If NOMCAMPO="YEA" : AUXANYO=val(VALOR) : Else : AUXANYO=[M:DIA]YEA : Endif
        If NOMCAMPO="CPY" : AUXCPY=VALOR       : Else : AUXCPY=[M:DIA]CPY  : Endif
        If NOMCAMPO="FCY" : AUXFCY=VALOR       : Else : AUXFCY=[M:DIA]FCY  : Endif
        If NOMCAMPO="ALLCPY"
            AUXALLCPY=val(VALOR)
            AUXCPY=""
        Else
            AUXALLCPY=[M:DIA]ALLCPY
        Endif
        If NOMCAMPO="ALLFCY"
            AUXALLFCY=val(VALOR)
            AUXFCY=""
        Else
            AUXALLFCY=[M:DIA]ALLFCY
        Endif

        Gosub CH_LASTUPDDAT
        [M:DIA]LASUPDDAT=LASTUPDDAT : Affzo [M:DIA]LASUPDDAT
    Endif
End

#------------------------------------------------------------------------------#

$CH_LASTUPDDAT
    Raz AUXDATE1,AUXDATE2,AUXDATE3
    Raz UPD1,UPD2,UPD3

    # 1ş. : All companies
    Read [F:HTS]HTS0=AUXANYO;"";""
    If !fstat
        AUXDATE1=[F:HTS]LASTUPDDAT
        UPD1=[F:HTS]UPDDAT
    Endif

    # 2ş. : All sites
    If AUXALLCPY<>2
        Read [F:HTS]HTS0=AUXANYO;AUXCPY;""
        If !fstat
            AUXDATE2=[F:HTS]LASTUPDDAT
            UPD2=[F:HTS]UPDDAT
        Endif
    Endif

#------------------------------------------------------------------------------#
    # 3ş. : Company and site
    If AUXALLFCY<>2
        Read [F:HTS]HTS0=AUXANYO;AUXCPY;AUXFCY
        If !fstat
            AUXDATE3=[F:HTS]LASTUPDDAT
            UPD3=[F:HTS]UPDDAT
        Endif
    Endif

    K=find(max(UPD1,UPD2,UPD3),UPD1,UPD2,UPD3)

    Case K
        When 1 : LASTUPDDAT=AUXDATE1
        When 2 : LASTUPDDAT=AUXDATE2
        When 3 : LASTUPDDAT=AUXDATE3
    Endcase
Return



#------------------------------------------------------------------------------#

$ERRBATCH
   Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

