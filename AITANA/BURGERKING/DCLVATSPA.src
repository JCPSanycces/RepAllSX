###################################################
#### Convert of non allowed characters         ####
###################################################
Subprog FORMATO_TEXTO(TEXTO)
Variable Char TEXTO()
TEXTO=ctrans(TEXTO,"?","e")
TEXTO=ctrans(TEXTO,"Ą","Ń")
TEXTO=ctrans(TEXTO,"¤","ń")
TEXTO=ctrans(TEXTO,"Ş","a")
TEXTO=ctrans(TEXTO,"ş","o")
TEXTO=ctrans(TEXTO,"§","o")
TEXTO=ctrans(TEXTO,"¦","a")
TEXTO=ctrans(TEXTO,"ˇ","i")
TEXTO=ctrans(TEXTO,"˘","o")
TEXTO=ctrans(TEXTO,"Ł","u")
TEXTO=ctrans(TEXTO,"'"," ")
TEXTO=ctrans(TEXTO,"á","a")
TEXTO=ctrans(TEXTO,"é","e")
TEXTO=ctrans(TEXTO,"í","i")
TEXTO=ctrans(TEXTO,"ó","o")
TEXTO=ctrans(TEXTO,"ú","u")
TEXTO=ctrans(TEXTO,"Á","A")
TEXTO=ctrans(TEXTO,"Ŕ","A")
TEXTO=ctrans(TEXTO,"É","E")
TEXTO=ctrans(TEXTO,"Č","E")
TEXTO=ctrans(TEXTO,"Í","I")
TEXTO=ctrans(TEXTO,"Ě","I")
TEXTO=ctrans(TEXTO,"Ó","O")
TEXTO=ctrans(TEXTO,"Ň","O")
TEXTO=ctrans(TEXTO,"Ú","U")
TEXTO=ctrans(TEXTO,"Ů","U")
TEXTO=ctrans(TEXTO,'"'," ")
TEXTO=ctrans(TEXTO,"+"," ")
TEXTO=ctrans(TEXTO,"("," ")
TEXTO=ctrans(TEXTO,")"," ")
TEXTO=ctrans(TEXTO,"-"," ")
TEXTO=ctrans(TEXTO,"&","Y")

End

#####################################################
## Invoice creation   -     90370 - Cash VAT
#####################################################
Subprog CSHVATBPC(ACCDAT,CRY,VAC,CPY,TAX,CSHVAT)
Value Date ACCDAT
Value Char CRY
Value Char VAC
Value Char CPY
Value Char TAX()
Variable Integer CSHVAT

Local Integer X
Local Char SPACSHDAT(8)

#THE invoice date is lower than 01/01/2014
If ACCDAT<[01/01/2014]: CSHVAT=1: End: Endif
#
##It is an export/canarias
#If CRY<>"ES": CSHVAT=1: End: Endif

If !clalev([TVB]): Local File TABVACBPR: Endif
Call LEC_TVB(GCURLEG,VAC) From CPTLEC
If fstat: CSHVAT=1: End: Endif

#It is not an EEC operation
If [F:TVB]REGVAC=4: CSHVAT=1: End: Endif

#It is an canarias
If [F:TVB]SPAIGIC=2: CSHVAT=1: End: Endif

#It is an operation of reverse charge
If [F:TVB]SPAISP=2: CSHVAT=1: End: Endif


Call PARAML(CPY,"SPACSHDAT",SPACSHDAT) From ADOVAL
If val(SPACSHDAT)<>0
   If ACCDAT>gdat$(val(mid$(SPACSHDAT,7,2)),val(mid$(SPACSHDAT,5,2)),val(mid$(SPACSHDAT,1,4)))
      CSHVAT=1: End
   Endif
Endif

CSHVAT=2

If !clalev([TVTX]): Local File TABVAT [TVTX]: Endif

#It is not an operation with a special agricultural tax RULE or "equivalence surcharge"
For X=0 To dim([F:SIH]TAX)-1
If TAX(X)="": Break: Endif
Read [TVTX]TVT0=TAX(X)
If !fstat
  If [F:TVTX]SPAAGRVAT=2 or [F:TVTX]VATTYP=2: CSHVAT=1: Break: Endif
Endif
Next X

End

Subprog CSHVATBPS(ACCDAT,CRY,VAC,CPY,TAX,DATCSHVAT,CSHVATBPS,CSHVAT)
Value Date ACCDAT
Value Char CRY
Value Char VAC
Value Char CPY
Value Char TAX()
Value Date DATCSHVAT
Value Integer CSHVATBPS
Variable Integer CSHVAT

Local Integer X
Local Char SPACSHDAT(8), VATSTA(2)

CSHVAT=2

#THE invoice date is lower than 01/01/2014
If ACCDAT<[01/01/2014]: CSHVAT=1: End: Endif

##It is an export/canarias
#If CRY<>"ES": CSHVAT=1: End: Endif

If !clalev([TVB]): Local File TABVACBPR [TVB]: Endif
Call LEC_TVB([F:CPY]LEG,VAC) From CPTLEC
If fstat: CSHVAT=1: End: Endif

#It is not an EEC operation
If [F:TVB]REGVAC=4: CSHVAT=1: End: Endif

#It is an canarias
If [F:TVB]SPAIGIC=2: CSHVAT=1: End: Endif

#It is an operation of reverse charge
If [F:TVB]SPAISP=2: CSHVAT=1: End: Endif


If CSHVATBPS=2
   If  (ACCDAT<DATCSHVAT or DATCSHVAT=[0/0/0])
        CSHVAT=2
   Else
        CSHVAT=1
   Endif
Endif

Call PARAML(CPY,"SPACSHVAT",VATSTA) From ADOVAL
If VATSTA="2"
  CSHVAT=2
  Call PARAML(CPY,"SPACSHDAT",SPACSHDAT) From ADOVAL
  If val(SPACSHDAT)<>0
    If ACCDAT>gdat$(val(mid$(SPACSHDAT,7,2)),val(mid$(SPACSHDAT,5,2)),val(mid$(SPACSHDAT,1,4)))
      CSHVAT=1: End
    Endif
  Endif
Endif

If !clalev([TVTX]): Local File TABVAT [TVTX]: Endif

#It is not an operation with a special agricultural tax RULE
If CSHVAT=2
  For X=0 To dim([F:PIH]TAX)-1
    If TAX(X)="": Break: Endif
    Read [TVTX]TVT0=TAX(X)
    If !fstat
      If [F:TVTX]SPAAGRVAT=2: CSHVAT=1: Break: Endif
    Endif
  Next X
Endif

End


#  90370 - Cash VAT - Control for the changes in SPACSHVAT and SPACSHDAT parameters
Subprog VERF_PARAM(PARAM,VALEUR,OK)
Value Char PARAM()
Value Char VALEUR()
Variable Integer OK

Global Shortint GCSHVATSPA
Local Integer NOL
NOL=nolign-1

If [M:ADWP]VALEUR(NOL)<>VALEUR
    If [M:ADWP]PARAM(NOL)= "SPACSHVAT" or [M:ADWP]PARAM(NOL)= "SPACSHDAT"
      GCSHVATSPA=1
    Endif
Endif


End

#  90370 - Cash VAT - Update values of intercompany suppliers
Subprog CSHVATSPA(SOC,PARVAL1,PARVAL2)
Value Char SOC
Value Char PARVAL1
Value Char PARVAL2

  Local Date DATVAL
  Local Shortint OKK, NUMVAL, WDAY, WMOT

  If !clalev([F:BPR]): Local File BPARTNER   [BPR]: Endif
  If !clalev([F:FCY]): Local File FACILITY   [FCY]: Endif
  If !clalev([F:BPS]): Local File BPSUPPLIER [BPS]: Endif

  If PARVAL1=mess(2,1,1): NUMVAL=2: Else: NUMVAL=1: Endif
  If left$(GFMDAT,2)="DD"
    WDAY=val(left$(PARVAL2,2))
    WMOT=val(mid$(PARVAL2,4,2))
  Elsif left$(GFMDAT,2)="MM"
    WMOT=val(left$(PARVAL2,2))
    WDAY=val(mid$(PARVAL2,4,2))
  Endif

  If WDAY<>0
    DATVAL=gdat$(WDAY,WMOT,val(right$(PARVAL2,7)))
  Else
    DATVAL=[00/00/00]
  Endif

  Link [BPS] With [BPR]BPR0=[F:BPS]BPSNUM, [FCY]FCY0=[F:BPR]FCY As [BPSX]
& Where [BPR]ENAFLG=2 & [BPR]BETFCY=2 & [F:FCY]LEGCPY=SOC

  Trbegin [BPSX]

  For [BPSX]
    [F:BPSX]CSHVAT= NUMVAL
    [F:BPSX]CSHDAT= DATVAL
    Rewrite [BPSX]
    If fstat>0:    GOK=0 : Call FSTA("BPR") From GLOCK : Break: Endif
  Next
  If GOK=0   : Goto ROLL_BPSX:  Endif
  Commit

  Filter [BPSX]

End

$ROLL_BPSX
  Rollback
Return


$DEL_CVAT   #X3-62304 (JUCON 31/10/2017)
  Local Char CRITVAT(250)
  Local File DCLVATSPA [DYY]
  Local Integer WCASH
  Local Date WCSHDAT: WCSHDAT=[M:DIA]STRDAT

  GOK=1

  CRITVAT='[F:DYY]REGTYP>10' ##99434
  If [M:DIA]ALLCPY<>2
    CRITVAT -= '& CPY="'+[M:DIA]CPY+'"'
  Endif
  If [M:DIA]ALLFCY<>2
    CRITVAT -= '& FCY="'+[M:DIA]FCY+'"'
  Endif
  If [M:DIA]STRDAT<>[0/0/0]
    CRITVAT -= '& ACCDAT>=['+format$(GFMD,[M:DIA]STRDAT)+']'
  Endif
  If [M:DIA]ENDDAT<>[0/0/0]
    CRITVAT -= '& ACCDAT<=['+format$(GFMD,[M:DIA]ENDDAT)+']'
  Endif

  Raz WCASH
  Filter [DYY] Where evalue(CRITVAT)
  If rowcount([DYY])>0:    WCASH=1: Endif

  If WCASH >0
    For [DYY]
      Filter [DVS] Where NUM=[DYY]NUM and REGTYP<11 and CPY=[DYY]CPY and FCY=[DYY]FCY and year([DYY]ACCDAT)=[M:DIA]YEA
      For [DVS]
        If [DVS]ACCDAT<WCSHDAT: WCSHDAT=[DVS]ACCDAT: WCASH=3:Endif
      Next
      Filter [DVS]
    Next
    Filter  [DYY]
    [M:DIA]STRDAT=WCSHDAT
    If [M:DIA]RESINCRONI=1
      Trbegin [DYY]
        Delete [DYY] Where evalue(CRITVAT)
        If fstat=1
          GOK = -1
          GLOCK = "$DCLVATSPA"
          Goto ROLL_CVAT
        Else [M:DIA]RESINCRONI=2
        Endif
      Commit
    Endif
  Endif
  Close Local File [DYY]
Return

$ROLL_CVAT  #X3-62304 (JUCON 31/10/2017)
    Rollback
    Call ROLL From GLOCK
    If GROLL : Return : Else : Goto DEL_CVAT : Endif

