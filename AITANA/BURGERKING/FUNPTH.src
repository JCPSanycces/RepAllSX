If clalev([F:POP])=0  : Local File PORDERP     [POP] : Endif
If clalev([F:CMD])=0  : Local File GCOMMITD    [CMD] : Endif
# Issue 117271 - 2016-06-28 by SR :
If clalev([F:TVB])=0  : Local File TABVACBPR   [TVB] : Endif
# Issue 112595 - 2015-11-23 by SR : Prise en compte des avoirs
If clalev([F:PIH2])=0 : Local File PINVOICE   [PIH2] : Endif
If clalev([F:PID2])=0 : Local File PINVOICED  [PID2] : Endif
# Issue 91906 - 2013-08-20 by MUARN : test module vente
If GMODU(5)=2
  # Issue 78604 - 2011-12-13 by MUARN : classe inexistante
  If clalev ([F:SDD])=0 : Local File SDELIVERYD [SDD] : Endif
Endif
#----- Fichiers temporaires pour faciliter le traitement -----#
If clalev([F:PWH])=0  : Local File PWRKPTH     [PWH] : Endif
If clalev([F:PWD])=0  : Local File PWRKPTD     [PWD] : Endif
If clalev([F:PWQ])=0  : Local File PWRKPOQ     [PWQ] : Endif
#----- Fichier pour pičces automatiques de comptabilité -----#
Local File PORDER    [TB0]
Local File PORDERQ   [TB1]
Local File CPTANALIN [TB2]
#----- Récupération du nombre maximum de lignes d'écriture par pičce -----#
Local File ACTIV   [ACV]
Read [ACV] CODACT="GAS" : If fstat  Raz [F:ACV] : Endif
MAXI=max([F:ACV]DIME-20,10) : # Pour extension future
Close Local File   [ACV]

# Issue 110950 - 2015-09-17 by SR : Pb Legislation "Invoices receivables" function
Raz GSOC_ACTIVE : GFCY=GFCYDEF(6) : Gosub CHARG_PARAM
Return


#--------------------------------------#
# Initialisation de la date d'extourne #
#--------------------------------------#
$DATE_EXTOURNE
If dim(SOCIETE) <0 Local  Char    SOCIETE(GLONCPY) : Endif
If dim(DAT)     <0 Local  Date    DAT              : Endif
If dim(EXERCICE)<0 Local  Decimal EXERCICE         : Endif
If dim(PERIODE) <0 Local  Decimal PERIODE          : Endif
If dim(SITE)    <0 Local  Char    SITE(GLONFCY)    : Endif
If dim(VALPAR)  <0 Local  Char    VALPAR(30)       : Endif
If [M:DIA]XFCYFLG=1
  SITE=[M:DIA]RCPFCY
  Call GETSOC(SITE) From DEVSUB : SOCIETE=GSOCIETE
Elsif [M:DIA]XCPYFLG=1
  Read [CPY] CPY0=[M:DIA]CPY
  SITE=[F:CPY]MAIFCY
  SOCIETE=[M:DIA]CPY
  # Issue 110950 - 2015-09-22 by SR : inutile et Pb si pas de site par défaut
  #Call GETSOC(SITE) From DEVSUB
Else
  SITE=GFCYDEF(2)
  Call GETSOC(SITE) From DEVSUB : SOCIETE=GSOCIETE
Endif
DAT=[M:DIA]ACCDAT
Call GETPERSOC(SOCIETE,GTYPGEN,DAT,EXERCICE,PERIODE) From CPTSUB
# Issue X3-126309 : Date must not be assigned in INIT action
If dim(ACTION)<0
  [M:DIA]EXTOURNE=[F:PER]PEREND+1
  If [M:DIA]EXTOURNE<=[M:DIA]ACCDAT
    [M:DIA]EXTOURNE=addmonth(gdat$(1,month([M:DIA]ACCDAT),year([M:DIA]ACCDAT)),1)
  Endif
Endif
Return


#----------------------------------------------------------#
# Trace détaillée des paramčtres du Call MAJENG si WTEST=1 #
# GBIDI2 : 1 = Désengagement                               #
#          2 = Extourne du désengagement                   #
#----------------------------------------------------------#
$TRACE_MAJENG
Call ECR_TRACE("-- Call MAJENG  From CPTENG",0)            From GESECRAN
If GBIDI2=1
  Call ECR_TRACE("   ACCDAT    ="-num$([M:DIA]ACCDAT),0)   From GESECRAN
Else
  Call ECR_TRACE("   EXTOURNE  ="-num$([M:DIA]EXTOURNE),0) From GESECRAN
Endif
Call ECR_TRACE("   GFINRSP   ="-GFINRSP,0)                 From GESECRAN
Call ECR_TRACE("   CUR       ="-[F:PWD]CUR,0)              From GESECRAN
Call ECR_TRACE("   AMTCUR    ="-num$([F:PWD]AMTCUR),0)     From GESECRAN
Call ECR_TRACE("   RATDIV    ="-num$([F:PWD]RATDIV),0)     From GESECRAN
Call ECR_TRACE("   RATMLT    ="-num$([F:PWD]RATMLT),0)     From GESECRAN
Call ECR_TRACE("   QTYBUDLIN ="-num$([F:PWD]QTYBUDLIN),0)  From GESECRAN
Call ECR_TRACE("   LINACC    ="-[F:PWD]LINACC,0)           From GESECRAN
Call ECR_TRACE("   LED       ="-[F:PWD]LED,0)              From GESECRAN
Call ECR_TRACE("   BPSNUM    ="-[F:PWH]BPSNUM,0)           From GESECRAN
Call ECR_TRACE("   TBDIE     ="-TBDIE,0)                   From GESECRAN
Call ECR_TRACE("   TBCCE     ="-TBCCE,0)                   From GESECRAN
If GBIDI2=1
  Call ECR_TRACE("   WCMMNUM1  ="-WCMMNUM1,0)              From GESECRAN
Else
  Call ECR_TRACE("   WCMMNUM2  ="-WCMMNUM2,0)              From GESECRAN
Endif
Call ECR_TRACE("   WDOCUMENT ="-WDOCUMENT,0)               From GESECRAN
Call ECR_TRACE("   WMOTIF    ="-num$(WMOTIF),0)            From GESECRAN
Call ECR_TRACE("   ID2(1)    ="-ID2(1),0)                  From GESECRAN
Call ECR_TRACE("   ID2(2)    ="-ID2(2),0)                  From GESECRAN
Call ECR_TRACE("   ID2(3)    ="-ID2(3),0)                  From GESECRAN
Call ECR_TRACE("   TYPORG    ="-num$(TYPORG),0)            From GESECRAN
Call ECR_TRACE("   CHGTYP    ="-num$([F:PWH]CHGTYP),0)     From GESECRAN
Call ECR_TRACE("----------------------------",0)           From GESECRAN
Return


###########################################################
# Sous-Programmes des actions sur champ de l'écran PTHPST #
###########################################################

Subprog AV_XCPYFLG(VALEUR)
#------------------------------------#
# Avant zone du flag toutes sociétés #
# ---------------------------------- #
# Complément de l'initialisation des #
# champs faite dans INIT_DIA et      #
# grisage des champs                 #
#------------------------------------#
Variable Integer  VALEUR
If !GHISTO
  Actzo [M]
  If varinit([M]XCPYFLG) & [M]XCPYFLG<>0
    If func AFNC.ACTIV("LEG") | ([M]XCPYFLG=1 & GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE)
       # 71937 : Multilégislation
       #Grizo XCPYFLG
    Endif
    If [M]XCPYFLG=2 & [M]XFCYFLG=2  Grizo XFCYFLG : Endif
    If [M]XFCYFLG=1
      Call INIALLFCY([M]XFCYFLG,[M]CPY) From FUNPTH
      If mkstat  Grizo XFCYFLG : Raz mkstat : Endif
    Endif
    If [M]XCPYFLG=2  Diszo CPY      : Endif
    If [M]XFCYFLG=2  Diszo RCPFCY   : Endif
    If [M]TYP<>1     Grizo EXTOURNE : Endif

    If [M:DIA]CPY<>"" : Diszo [M:DIA]LEG : Endif :   # 71937 : Multilégislation

    End
  Endif
Endif
#----- Traitement des champs société -----#
[M]XCPYFLG=1 : VALEUR=1
If func AFNC.ACTIV("LEG") | (GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE)
  Grizo XCPYFLG
Endif
Call INICPY([M]CPY) From CPTSUB
Affzo CPY : If dim([M]ZCPY)>0  Affzo ZCPY : Endif
If GNBAUZ=1 Diszo CPY : Endif
#----- Traitement des champs site -----#
Call INIALLFCY([M]XFCYFLG,[M]CPY) From FUNPTH
If mkstat
  [M]XFCYFLG=1
  Grizo XFCYFLG : Raz mkstat
Endif
If [M]XFCYFLG=1
  Call INIFCY([M]RCPFCY,[M]CPY) From CPTSUB
  Affzo RCPFCY : If dim([M]ZRCPFCY)>0  Affzo ZRCPFCY : Endif
Endif
If GNBAUZ=1 | [M]XFCYFLG=2 Diszo RCPFCY : Endif
#----- Traitement champ état des écritures -----#
If [M]TYP<>1 Grizo STA : Endif
#----- Initialisation type pičce et journal -----#
Gosub INIT_TYPPCEJOU
#----- Traitement date d'extourne -----#
If [M]TYP<>1
  Effzo EXTOURNE : Grizo EXTOURNE
Else
  Actzo EXTOURNE
Endif
End


Subprog AM_XCPYFLG(VALEUR)
#-------------------------------------#
# Aprčs modif du flag toutes sociétés #
#-------------------------------------#
Variable Integer  VALEUR
If VALEUR=1
  Actzo CPY
  Call INICPY([M:DIA]CPY) From CPTSUB
  Affzo [DIA]CPY : If dim([M:DIA]ZCPY)>0  Affzo [DIA]ZCPY : Endif
  If GNBAUZ=1 Diszo [DIA]CPY : Endif
  Call INIALLFCY([M:DIA]XFCYFLG,[M:DIA]CPY) From FUNPTH
  If mkstat
    Grizo [DIA]XFCYFLG : Actzo [DIA]RCPFCY : Raz mkstat
    Call INIFCY([M:DIA]RCPFCY,[M:DIA]CPY) From CPTSUB
    Affzo [DIA]RCPFCY : If dim([M:DIA]ZRCPFCY)>0  Affzo [DIA]ZRCPFCY : Endif
    If GNBAUZ=1 Diszo [DIA]RCPFCY : Endif
  Else
    Actzo [DIA]XFCYFLG
    If [M:DIA]XFCYFLG=1
      Call INIFCY([M:DIA]RCPFCY,[M:DIA]CPY) From CPTSUB
      Affzo [DIA]RCPFCY : If dim([M:DIA]ZRCPFCY)>0  Affzo [DIA]ZRCPFCY : Endif
    Endif
  Endif
Else
  [M:DIA]XFCYFLG=2 : Affzo [DIA]XFCYFLG : Grizo [DIA]XFCYFLG
  Effzo [DIA]CPY, RCPFCY
  # Issue 110950 - 2015-09-17 by SR : Pb Legislation "Invoices receivables" function
  Raz GSOCIETE, GCURLEG, GFCY, GCURFCY
  # 71937 : Multilégislation
  Effzo [M:DIA]LEG
  If dim([M:DIA]ZLEG)>0     Effzo [DIA]ZLEG    : Endif
  # 71937

  If dim([M:DIA]ZCPY)>0     Effzo [DIA]ZCPY    : Endif
  If dim([M:DIA]ZRCPFCY)>0  Effzo [DIA]ZRCPFCY : Endif
  Diszo [DIA]CPY, RCPFCY
  If [M:DIA]TYP=1 : Actzo STA : Endif
Endif
#----- Initialisation type pičce et journal -----#
Gosub INIT_TYPPCEJOU

# 71937 : Multilégislation
[M]XCPYFLG=VALEUR : Gosub GRILEG
Affzo [M:DIA]LEG
# 71937

If !GIMPORT  Affzo [DIA]TYPPCE, JOURNAL : Endif
#-----
End


Subprog C_CPY(VALEUR)
#------------------------------------------------------------------#
# Contrôle société : Obligatoire si flag toutes sociétés non coché #
#------------------------------------------------------------------#
Variable Char    VALEUR()
If [M]XCPYFLG<>2 & VALEUR="" mkstat=1 : End : Endif
End


Subprog AM_CPY(VALEUR)
#---------------------------#
# Aprčs modif de la société #
#---------------------------#
Variable Char    VALEUR()
Call INIALLFCY([M:DIA]XFCYFLG,VALEUR) From FUNPTH
If mkstat
  Grizo [DIA]XFCYFLG : Actzo [DIA]RCPFCY : Raz mkstat
  Call INIFCY([M:DIA]RCPFCY,VALEUR) From CPTSUB
  Affzo [DIA]RCPFCY : If dim([M:DIA]ZRCPFCY)>0  Affzo [DIA]ZRCPFCY : Endif
  If GNBAUZ=1 Diszo [DIA]RCPFCY : Endif
Else
  Actzo [DIA]XFCYFLG
  If [M:DIA]XFCYFLG=1
    Raz [M:DIA]RCPFCY       : # 71937 : Multilégislation
    Call INIFCY([M:DIA]RCPFCY,VALEUR) From CPTSUB
    Affzo [DIA]RCPFCY : If dim([M:DIA]ZRCPFCY)>0  Affzo [DIA]ZRCPFCY : Endif
  Endif
Endif
If  [M:DIA]TYP=1
 If func AFNC.PARAM("FRADGI",VALEUR)="2" : # Paramčtre ŕ Oui
  [M:DIA]STA = 2 : Grizo STA
  Affzo STA
 Else
  Actzo STA
 Endif
Endif
#----- Initialisation type pičce et journal -----#
[M:DIA]CPY=VALEUR
Gosub INIT_TYPPCEJOU
If !GIMPORT  Affzo [DIA]TYPPCE, JOURNAL : Endif
#-----

# 71937 : Multilégislation
Gosub GRILEG
Affzo [M:DIA]LEG
# 71937

# Issue 110950- 2015-09-17 by SR : Pb Legislation "Invoices receivables" function
If [F:FCY]LEGCPY<>VALEUR
  Filter [F:FCY] Where LEGCPY=VALEUR
  Read [F:FCY] First
  If fstat : Raz [F:FCY] : Endif
  Filter [F:FCY]
Endif
If [F:FCY]FCY<>""
  Raz GSOC_ACTIVE : GFCY=[F:FCY]FCY : Gosub CHARG_PARAM
Endif
# End issue 110950
End

# 71937 : Multilégislation
# ---------------------------- Législation -----------------------------
Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
GCURLEG=VALEUR
End

# 71937 : Multilégislation
Subprog AM_LEG(VALEUR)
Variable Char    VALEUR()

# test sr
[M:DIA]LEG = VALEUR

Gosub INIT_TYPPCEJOU
Affzo [DIA]TYPPCE, JOURNAL

End

Subprog AM_XFCYFLG(VALEUR)
#--------------------------------#
# Aprčs modif du flag tous sites #
#--------------------------------#
Variable Integer VALEUR
If VALEUR=1
  Actzo [DIA]RCPFCY
  Call INIFCY([M:DIA]RCPFCY,[M:DIA]CPY) From CPTSUB
  Affzo [DIA]RCPFCY : If dim([M:DIA]ZRCPFCY)>0  Affzo [DIA]ZRCPFCY : Endif
  If GNBAUZ=1 Diszo [DIA]RCPFCY : Endif
Else
  Effzo [DIA]RCPFCY : If dim([M:DIA]ZRCPFCY)>0  Effzo [DIA]ZRCPFCY : Endif
  Diszo [DIA]RCPFCY
Endif
#----- Initialisation type pičce et journal -----#
Gosub INIT_TYPPCEJOU
If !GIMPORT  Affzo [DIA]TYPPCE, JOURNAL : Endif
#-----

# 71937 : Multilégislation
Gosub GRILEG
Affzo [M:DIA]LEG
# 71937

End


Subprog C_RCPFCY(VALEUR)
#----------------------------------------------#
# Contrôle que le site est un site de stockage #
#----------------------------------------------#
Variable Char     VALEUR
If [M]XFCYFLG<>2 & VALEUR=""
  mkstat=1 : End : # Obligatoire si flag tous sites non coché
Endif
If [F:FCY]WRHFLG<>2
  mkstat=1 : GMESSAGE=mess(58,199,1) : End : # Ce site n'est pas un dépôt
Endif
End


Subprog AM_RCPFCY(VALEUR)
#---------------------#
# Aprčs modif du site #
#---------------------#
Variable Char    VALEUR()
#----- Initialisation type pičce et journal -----#
[M:DIA]RCPFCY=VALEUR
Gosub INIT_TYPPCEJOU
If !GIMPORT  Affzo [DIA]TYPPCE, JOURNAL : Endif
#-----

# 71937 : Multilégislation
Gosub GRILEG
Affzo [M:DIA]LEG
# 71937

# Issue 110950 - 2015-09-17 by SR : Pb Legislation "Invoices receivables" function
If VALEUR<>""
  Raz GSOC_ACTIVE : GFCY=VALEUR : Gosub CHARG_PARAM
Endif
# End issue 110950

End


Subprog AS_BPSEND(VALEUR)
#------------------------------#
# Avant-saisie fournisseur fin #
#------------------------------#
Variable Char    VALEUR()
If VALEUR="" | VALEUR<[M]BPSSTR : VALEUR=[M]BPSSTR : Endif
End


Subprog C_BPSEND(VALEUR)
#--------------------------#
# Contrôle fournisseur fin #
#--------------------------#
Variable Char    VALEUR()
If VALEUR<>"" & VALEUR<[M]BPSSTR
 GMESSAGE = mess(44,199,1) :# La borne fin est inferieure a la borne debut
 mkstat = 1
Endif
End


Subprog AM_TYP(VALEUR)
#-----------------------------------#
# Aprčs modif du type de génération #
#-----------------------------------#
Variable Integer VALEUR
If VALEUR<>1 Grizo [DIA]STA Else Actzo [DIA]STA : Endif
If VALEUR = 1
 If [M]CPY<>""
  If func AFNC.PARAM("FRADGI",[M]CPY)="2" : # Paramčtre ŕ Oui
   [M]STA = 2 : Grizo STA
  Else : Actzo STA
  Endif
 Else : Actzo STA
 Endif
Endif
#----- Traitement date d'extourne -----#
If VALEUR<>1
  Effzo [DIA]EXTOURNE : Grizo [DIA]EXTOURNE
Else
  Gosub DATE_EXTOURNE
  Actzo [DIA]EXTOURNE
Endif
#----- Initialisation type pičce et journal -----#
[M:DIA]TYP=VALEUR
Gosub INIT_TYPPCEJOU
#----- Affichage type de pčce et journal et date d'extourne -----#
If !GIMPORT  Affzo [DIA]TYPPCE, JOURNAL, EXTOURNE : Endif
End


Subprog C_TYPPCE(VALEUR)
#------------------------#
# Contrôle type de pičce #
#------------------------#
Variable Char    VALEUR()

# 71937 : Multilégislation
#Call LECTURE("GTE",VALEUR,"") From CONTOBJ
Local Integer WRET
Call LEC_GTE_LEG(GCURLEG,VALEUR,WRET) From TRTLECLEG

Call CONTEXE([F:GTE]ACS)      From CPTSUB
If mkstat  End : Endif
If [M:DIA]TYP=1 & [F:GTE]VCRREA<>2
  #----- Type de pičce interdit en réel -----#
  GMESSAGE=mess(33,107,1) : mkstat=2 : End
Elsif [M:DIA]TYP>=2 & [F:GTE]VCRSIM<>2
  #----- Type de pičce interdit en simulation -----#
  GMESSAGE=mess(32,107,1) : mkstat=2 : End
Endif
End


Subprog C_JOURNAL(VALEUR)
#---------------------#
# Contrôle du journal #
#---------------------#
Variable Char    VALEUR()
Call CONTEXE([F:JOU]ACS) From CPTSUB
If mkstat  GMESSAGE=VALEUR-GMESSAGE : Return : Endif
If [M:DIA]CPY<>"" & [M:DIA]RCPFCY<>""
  Call VERSOC([F:JOU]FCY,[M:DIA]CPY,[M:DIA]RCPFCY,VALEUR) From CFYSUB
  If mkstat  End : Endif
Endif

# 71937 : Multilégislation
#Call LECTURE("GTE",[M:DIA]TYPPCE,"") From CONTOBJ
Local Integer WRET
Call LEC_GTE_LEG(GCURLEG,[M:DIA]TYPPCE,WRET) From TRTLECLEG

If [F:GTE]AUZJOU([F:JOU]TYP-1)<>2
  GMESSAGE=[F:JOU]JOU-mess(8,106,1) : # Journal non autorisé sur ce type de pičce
  mkstat=2 : End
Endif
End

# Issue 110950 - 2015-09-17 by SR : Pb Legislation "Invoices receivables" function
#######################################################################
#--------------------------------------------------------------------------#
# Chargement des paramčtres avec GFCY = Site de la facture                 #
# ------------------------------------------------------------------------ #
# Chargement des globales référenciels, comptes et sections de la société  #
# Chargement des paramčtres de localisation                                #
# ------------------------------------------------------------------------ #
$CHARG_PARAM
Local  Char     PARAM2(10)
# --- Chargement GSOCIETE GFINRSP GCURLEG GCURFCY (GETSOC) GLOCALDEV (GETDEV)
# --- Chargement des globales référenciels, comptes et sections de la société
Call GETCPY(GFCY,"",0,"") From TRTX3CPT
Return
# End issue 110950

#-----------------------------------------------#
# Initialisation du type de pičce et du journal #
#-----------------------------------------------#
$INIT_TYPPCEJOU
#-----
Local Integer WSTAT
Local Char    WPCEAUTO(GLONGAU)
#----- Chargement du site financier -----#
If [M:DIA]CPY="" & [M:DIA]RCPFCY=""
  [M:DIA]FCY=""
Elsif [M:DIA]CPY=""
  Call GETSOC([M:DIA]RCPFCY) From DEVSUB
  [M:DIA]FCY=GFINRSP
Else
  Read [CPY] CPY0=[M:DIA]CPY
  If [F:CPY]MAIFCY=""                                 : # 71937
    GCURLEG=[F:CPY]LEG                                : # 71937
  Else                                                : # 71937
    Call GETSOC([F:CPY]MAIFCY) From DEVSUB
    [M:DIA]FCY=GFINRSP
  Endif                                               : # 71937
Endif
#----- Recherche code de la pičce auto ----#
If [M]FCY<>""
  Call PARAM([M:DIA]FCY,"GAUPTH",WPCEAUTO) From ADOVAL
Elsif [M]CPY<>""
  Call PARAM([M:DIA]CPY,"GAUPTH",WPCEAUTO) From ADOVAL
Else
  Call PARAM("","GAUPTH",WPCEAUTO) From ADOVAL
Endif
If WPCEAUTO=""  WPCEAUTO="PTH" : Endif
#----- Traitement type de pičce -----#
If [M:DIA]TYP<>1
  #----- Paramčtre TYPACC : type de pičce utilisé en simulation -----#
  If [M:DIA]FCY<>""
    Call PARAM([M:DIA]FCY,"TYPACC",[M:DIA]TYPPCE) From ADOVAL
  Elsif [M:DIA]CPY<>""
    Call PARAM([M:DIA]CPY,"TYPACC",[M:DIA]TYPPCE) From ADOVAL
  Else
    Call PARAM("","TYPACC",[M:DIA]TYPPCE) From ADOVAL
  Endif
Else
  #----- Pičce auto PTH : Factures ŕ recevoir -----#
  Call LECTURE("GAU",WPCEAUTO,"") From CONTOBJ
  If !clalev([F:TB0]) : Local File =[F:GAU]TBL [TB0] : Endif
  Gosub OUVRE From ="WMGAU"+[F:GAU]COD
  Gosub LIENS From ="WMGAU"+[F:GAU]COD
  Call EVAL_CHAR([M:DIA]TYPPCE,"GTE",1,0,"",WSTAT) From CPTAUTO
Endif
#----- Traitement du journal -----#
Raz [M:DIA]JOURNAL
If [M:DIA]TYP=1
  Call LECTURE("GAU",WPCEAUTO,"") From CONTOBJ
  Call EVAL_CHAR([M:DIA]JOURNAL,"JOU",1,0,"",WSTAT) From CPTAUTO
Endif
If [M:DIA]JOURNAL=""

  # 71937 : Multilégislation
  #Call LECTURE("GTE",[M:DIA]TYPPCE,"") From CONTOBJ
  Local Integer WRET
  Call LEC_GTE_LEG(GCURLEG,[M:DIA]TYPPCE,WRET) From TRTLECLEG

  [M:DIA]JOURNAL=[F:GTE]DEFJOU
Endif
#-----

If [M:DIA]CPY<>"" : [M]LEG=GCURLEG : Diszo [M:DIA]LEG : Endif :   # 71937 : Multilégislation

Return


Subprog C_ACCDAT(VALEUR)
#------------------------#
# Contrôle date de pičce #
#------------------------#
Variable Date    VALEUR
If VALEUR<[M:DIA]BORNE
  GMESSAGE=mess(564,199,1) : mkstat=1 : End
Endif
End


Subprog C_EXTOURNE(VALEUR)
#--------------------------#
# Contrôle date d'extourne #
#--------------------------#
Variable Date    VALEUR
#-----
If VALEUR<=[M:DIA]ACCDAT
  GMESSAGE=mess(565,199,1) : mkstat=1 : End
Endif
#-----
Local  Char    SOCIETE(GLONCPY)
Local  Decimal EXERCICE
Local  Decimal PERIODE
Local  Char    SITE(GLONFCY)
#-----
If [M:DIA]XFCYFLG=1
  SITE=[M:DIA]RCPFCY
  Call GETSOC(SITE) From DEVSUB : SOCIETE=GSOCIETE
Elsif [M:DIA]XCPYFLG=1
  Read [CPY] CPY0=[M:DIA]CPY
  SITE=[F:CPY]MAIFCY
  SOCIETE=[M:DIA]CPY
  Call GETSOC(SITE) From DEVSUB
Else
  SITE=GFCYDEF(2)
  Call GETSOC(SITE) From DEVSUB : SOCIETE=GSOCIETE
Endif
#----- Permet d'alimenter la classe [F:PER] -----#
Call GETPERSOC(SOCIETE,GTYPGEN,[M:DIA]ACCDAT,EXERCICE,PERIODE) From CPTSUB
#-----
If VALEUR<=[F:PER]PEREND
  GMESSAGE=mess(565,199,1) : mkstat=1 : End
Endif
#-----
End


#############################################
# Contrôle si tous les sites sont autorisés #
#############################################
Subprog INIALLFCY(VALEUR,SOC)
Variable Integer  VALEUR
Value    Char     SOC
Local    Integer  I, OK
If GUSRFCY(1)="\"  End : Endif
If GNBAUZ=GNBSITE  End : Endif

If clalev([F:FGR])=0  Local File FACGROUP [FGR] : Endif
If clalev([F:CPY])=0  Local File COMPANY  [CPY] : Endif
If [L]SOC<>""
  OK=1
  Call LECTURE("CPY",[L]SOC,"") From CONTOBJ
  If [F:CPY]CPYLEGFLG=2  : # Société juridique
    For I=1 To GNBSITE
      If [L]SOC=GSOCSITE(I) & !find(GSITE(I),GUSRFCY(1..GNBAUZ))
        OK=0 : Break
      Endif
    Next I
  Else
    For [FGR]FGR0 Where CPY=[L]SOC
      If !find([F:FGR]FCY,GUSRFCY(1..GNBAUZ))
        OK=0 : Break
      Endif
    Next
  Endif
Endif
If !OK
  VALEUR=1 : mkstat=2 : End : # Tous les sites de la société ne sont pas accessibles
Endif
End


###################
# Si erreur Batch #
###################
$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

