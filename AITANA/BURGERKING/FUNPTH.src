#<AdxTL>@(#)0.0.0.0 $Revision$
#Y015 tomado fuente de X3
# Y015 la fecha de inicio de servicio es mayor que la fecha de provisión
# Y015 SALIDA : importe completo
# Y015 la fecha de inicio de servicio es menor que la fecha de provisión
# YP15 SALIDA: importe=importe*(Fecha provisión-fecha ini. servicio)/Fecha fin. ser-Fec. ini.servicio)
########################################################################
# FUNPTH          GESTION DES FACTURES ŕ RECEVOIR         cg Aout 1998 #
#                                               modifié MBT 28/06/2002 #
# -------------------------------------------------------------------- #
# Sous-programme FUNPTH remplacé par l'action TRTFUNPTH !              #
# GLOCALDEV = devise societe         GSYSCUR = devise dossier          #
# GFINRSP   = site financier                                           #
# -------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)               #
#   - TRTFUNPTH : Fonction de gestion des factures ŕ recevoir          #
########################################################################
# Issue X3-126309 - 2019-04-25 by UB : Credits to receive default value of Reversal date

$ACTION
#----------------------------------------------------------#
# Actions sur le traitement standard (GTRAITE)             #
# TRTFUNPTH  : Fonction de gestion des factures ŕ recevoir #
#----------------------------------------------------------#
Case ACTION
 When "OUVRE_BATCH" : Gosub OUVRE
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "OK"          : FIN=1 : GOK=1
 When "END"         : FIN=1 : GOK=0
 #When "DEBUT"       : Affzo [DIA]1-99        : # 71937 : Multilégislation
 When "DEBUT"       : Gosub DEBUT_FUNPTH      : # 71937 : Multilégislation
 When "SORTIE"      : Gosub SORTIE
 When "BOUTON"      : Gosub BOUTON            # Issue X3-57740 - 2017-11-08 by MUARN : Memo et globales
Endcase
Return

#################################################
# Initialisations avant exécution du traitement #
#################################################
$INIT
# 71937 : Multilégislation
Local Char      SAVGFCYDEF(GLONFCY)

If GSERVEUR
  Onerrgo ERRBATCH  : # En batch, il vaut mieux mettre onerrgo
Endif
Gosub OUVRE         : # Ouverture fichiers et déclaration variables locales
Local Mask PTHPST [DIA]
Raz [M:DIA]

# ----- chargement de l'écran en fonction des habilitations
# 71937 : Multilégislation
SAVGFCYDEF=GFCYDEF(0)
# Issue 110950 - 2015-09-22 by SR : GFCYDEF(6) au lieu de GFCYDEF(5)
GFCYDEF(0)=GFCYDEF(6)
# 71937

[M:DIA]XCPYFLG=1
If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE : [M:DIA]XCPYFLG = 1 : Endif
If [M:DIA]XCPYFLG = 1
    Call INICPY([M:DIA]CPY) From CPTSUB
Endif
GFCYDEF(0)=SAVGFCYDEF : : # 71937 : Multilégislation
[M:DIA]XFCYFLG=2
If [M:DIA]XCPYFLG=1
    Call INIALLFCY([M:DIA]XFCYFLG,[M:DIA]CPY) From CPTTRT
Endif
If [M:DIA]XFCYFLG = 1
    Call INIFCY([M:DIA]RCPFCY,[M:DIA]CPY) From CPTSUB
Endif

[M:DIA]XFCYFLG  =2
[M:DIA]BORNE    =datesyst
[M:DIA]TYP      =2
[M:DIA]ACCDAT   =datesyst
[M:DIA]ITMSTOFLG=3
Gosub DATE_EXTOURNE
[M:DIA]TRACE    =2
Call LECMEMO("STD","[M:DIA]","cp3") From GMEMO
TIT=mess(121,197,1) : # Titre de la boite de dialogue et message de temporisation
TMP=1               : # Affichage d'un message de temporisation

# 71937 : Multilégislation
Gosub INIT_TYPPCEJOU         : # Init. de la pičce auto, du type de pičce et du code journal
Return

# 71937 : Multilégislation
#########################################################################
## $DEBUT_FUNPTH
#########################################################################
$DEBUT_FUNPTH
Call FMTLEG From TRTX3 : # Pour rendre invisible si nécessaire le champ "Législation"
Gosub GRILEG
Affzo [DIA]1-99
Return

######################################################################
## $GRILEG
######################################################################
$GRILEG
If func AFNC.ACTIV("LEG")=0 : # Dossier mono-législation
  Diszo [M:DIA]LEG
  [M:DIA]LEG=GDOSLEG(1)
  Affzo [M:DIA]LEG
Elsif [M:DIA]XCPYFLG=1
  Diszo [M:DIA]LEG
Else
  Actzo [M:DIA]LEG
Endif
Return
# 71937


##########################################
# Contrôle avant exécution du traitement #
##########################################
$CONTROLE
If GOK<1  FIN=1 Else TMP=1 : Endif

## Demande de modif 56230 - Lot CE5
If FIN : Return : Endif
Call AVERTDGI([M:DIA]XCPYFLG,[M:DIA]CPY,[M:DIA]TYP,SAI) From CPTDIV2
If SAI : Return : Endif
## Fin demande 56230
Return


###########################
# Exécution du traitement #
###########################
$EXEC
#----- Variables locales pour création pičces FAR et extourne FAR -----#
If [M:DIA]TYP=1 : # Génération réelle
  Local Char WZONE (GLONAVA)(1..8)
  Local Char WVALZONE (20)(1..8)
Else            : # Génération simulée
  Local Char WZONE (GLONAVA)(1..7)
  Local Char WVALZONE (20)(1..7)
Endif
Local Integer RET
# Issue 91510 - 2013-08-01 by SR
Local Char WFAR
#-----
WNBPCE=1
GOK=1
# Issue X3-132528 - 2019-04-18 by SR : Raz mkstat avant l'excéxution
# car mkstat peut ętre  ętre resté ŕ la valeur 2 en batch
Raz mkstat
#-
#----- Début de la trace si nécessaire -----#
If !GSERVEUR & [M:DIA]TRACE=2
  #----- Ouverture fichier trace et écriture des sélections -----#
  Call OUVRE_TRACE(mess(121,197,1))  From LECFIC
  Call ECR_TRACE(" ",0)              From GESECRAN
  Call ECR_TRACE(string$(88,"-"),0)  From GESECRAN
  Call PRTSCR("PTHPST","DIA","",0,1) From ATRTX3
  Call ECR_TRACE(" ",0)              From GESECRAN
  Call ECR_TRACE(mess(594,197,1)-mess([M:DIA]ITMSTOFLG,563,1),0) From GESECRAN
  Call ECR_TRACE(string$(88,"-"),0)  From GESECRAN
Endif
# Issue 115551 - 2016-04-07 by SR : lock société
Call LOCKCPYAFC([M:DIA]CPY,"FUNPTH",WOKLOCK) From TRTX3
If !WOKLOCK
  Call ECR_TRACE(GMESSAGE,1) From GESECRAN
  Raz GMESSAGE
  Goto FIN_EXEC_TRA
Endif
#----- Effacement des fichiers de travail temporaires par sécurité -----#
Gosub DEL_PWRK : If GOK<1  Goto FIN_EXEC_TRA : Endif

#----- Constitution du filtre sur les réceptions -----#
WCRIT="(PSTFLG<>2 | PSTDAT<["+format$(GFMD,[M:DIA]ACCDAT)+"])"
WCRIT+="& (BETFCY<>2 | (BETFCY=2 & BETCPY=2))"
If [M:DIA]BPSSTR <> ""
  WCRIT+=' & BPSNUM>="'+[M:DIA]BPSSTR+'"'
Endif
If [M:DIA]BPSEND<>""
  WCRIT+=' & BPSNUM<="'+[M:DIA]BPSEND+'"'
Endif
If [M:DIA]XCPYFLG<>2
  WCRIT+=' & CPY="'+[M:DIA]CPY+'"'
Endif
If [M:DIA]XFCYFLG<>2
  WCRIT+=' & PRHFCY="'+[M:DIA]RCPFCY+'"'
Endif
If [M:DIA]BORNE<>[0/0/0]
  WCRIT+=' & RCPDAT<=['+format$(GFMD,[M:DIA]BORNE)+']'
Endif
# Issue X3-83998 - 2018-04-16 by SR :
If [M:DIA]LEG<> ""
   WCRIT+= '& [F:CPY]LEG ="'+[M:DIA]LEG+'"'
Endif

#----- Constitution du filtre sur les lignes de réception -----#
If [M:DIA]ITMSTOFLG=1
  WCRIT2="STOMGTCOD>1"
Elsif [M:DIA]ITMSTOFLG=2
  WCRIT2="STOMGTCOD<2"
Else
  WCRIT2="1=1"
Endif

#---------------------------------------------------------------------------#
# Point d'entrée PTHFILTRE pour ajouter un filtre supplémentaire            #
# ------------------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                               #
#                                                                           #
# WCRIT     : Filtre constitué par le traitement ŕ partir de l'écran PTHPST #
# PTHFILTRE : Filtre supplémentaire sur l'entęte de réception               #
#---------------------------------------------------------------------------#
Raz PTHFILTRE
SAV_WCRIT=WCRIT
# Issue 116409 - 2016-05-09 by SR :
SAV_WCRIT2=WCRIT2
GPOINT="PTHFILTRE" : Gosub ENTREE From EXEFNC
If WCRIT<>SAV_WCRIT
  WMSG="WCRIT"-mess(382,197,1)-WCRIT
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
If PTHFILTRE<>""
  WMSG="PTHFILTRE"-mess(382,197,1)-PTHFILTRE
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
# Issue 116409 - 2016-05-09 by SR
If WCRIT2<>SAV_WCRIT2
  WMSG="WCRIT2"-mess(382,197,1)-WCRIT2
  Call ECR_TRACE(WMSG,0) From GESECRAN
Endif
# Issue 116409 - 2016-05-09 by SR : Ajout test de WCRIT2
If WCRIT<>SAV_WCRIT | PTHFILTRE<>"" | WCRIT2<>SAV_WCRIT2
  Call ECR_TRACE(" ",0)             From GESECRAN
  Call ECR_TRACE(string$(88,"-"),0) From GESECRAN
  Call ECR_TRACE(" ",0)             From GESECRAN
Endif
If WCRIT=""     WCRIT    ="1=1" : Endif
If PTHFILTRE="" PTHFILTRE="1=1" : Endif
#-----
If parse(WCRIT)
  Call ECR_TRACE("Filter error WCRIT",1)     From GESECRAN : Goto FIN_EXEC
Endif
If parse(PTHFILTRE)
  Call ECR_TRACE("Filter error PTHFILTRE",1) From GESECRAN : Goto FIN_EXEC
Endif

#-------------------------------------------------#
# Remplissage des fichiers de travail temporaires #
#-------------------------------------------------#
Raz GSOCIETE, WNBPCE
# Issue X3-83998 - 2018-04-16 by SR :
#For [PTH] Where evalue(WCRIT) & evalue(PTHFILTRE) With Nohint
Link [PTH] With [CPY]CPY0=[F:PTH]CPY As [KPTH]
For [KPTH] Where evalue(WCRIT) & evalue(PTHFILTRE) With Nohint
  #----- Récupération société (GSOCIETE) et devise société (GLOCALDEV) -----#
  If GSOCIETE<>[F:PTH]CPY
    Call GETDEV([F:PTH]PRHFCY) From DEVSUB
    Call LECLED(GSOCIETE,GTYPGEN,WLEDGEN,WDEVLED) From CPTDIV
    Call LECLED(GSOCIETE,GTYPANA,WLEDANA,WDEVLED) From CPTDIV
    #----- Liste des types de référentiel de la société -----#
    Call LSTLEDTYP(GSOCIETE,0,TBTYPLED,I) From CPTDIV
  Endif
  #-----
  Gosub TRTPTD : If GOK<1  Break : Endif
  #-----
Next
If GOK<1 Goto FIN_EXEC : Endif

#-----------------------------------------#
# Suppression des écritures de simulation #
#-----------------------------------------#
Gosub DEL_SIMULATION : If GOK<1 Goto FIN_EXEC : Endif

#-------------------------------------------------------------#
# Génération des écritures FAR, engagements et mŕj réceptions #
#-------------------------------------------------------------#
If clalev([F:PWH1])=0  Local File PWRKPTH  [PWH1] : Endif
# Issue X3-122734 - 2019-04-29 by SR :
If clalev([F:PWH2])=0  Local File PWRKPTH  [PWH2] : Endif

Raz GWCPY, GWPRHFCY, GWBPSINV, GWCUR, J, WMONTHT, WMONTTTC
NB_PWH=6
#-----
For [PWH1] PWH1 Where PRONUM=adxuid(1)
  If NB_PWH=6
&  | [F:PWH1]CPY   <>GWCPY
&  | [F:PWH1]PRHFCY<>GWPRHFCY
&  | [F:PWH1]BPSINV<>GWBPSINV
&  | [F:PWH1]CUR   <>GWCUR
    If GWCPY<>[F:PWH1]CPY | GWPRHFCY<>[F:PWH1]PRHFCY
      # Issue X3-122734 - 2019-04-26 by SR :
      # SIVNULL : lignes ŕ 0 interdites -Lines set to 0 prohibited : 1 = NO, 2 = YES
      # if SIVNULL = 2 (YES), No Invoices to receive generated
      If [F:PWH1]PRHFCY <> GWPRHFCY
        Call PARAML([F:PWH1]PRHFCY,"SIVNULL",WPARAM) From ADOVAL
        GSIVNULL=val(WPARAM)
      Endif
      # End issue X3-122734
      If GWCPY<>[F:PWH1]CPY
        Call GETDEV([F:PWH1]PRHFCY) From DEVSUB
        #----- Recherche code pičce auto -----#
        Call PARAM(GFINRSP,"GAUPTH",WPCEAUTO) From ADOVAL
        If WPCEAUTO=""  WPCEAUTO="PTH" : Endif
        #----- Lecture pičce auto PTH pour savoir si traitement ligne ŕ ligne -----#
        Read [GAU] GAU0=WPCEAUTO : If fstat  Raz [F:GAU] : Endif
        If [F:GAU]GRPFLG=1
          NB_PWH=6
        Else
          NB_PWH=5
        Endif
        #----- Recherche type de cours -----#
        Read [GAG] GAG0=WPCEAUTO;0;"TCR"
        If fstat  Raz [F:GAG] : Endif
        If [F:GAG]FORCLC<>""
          WCHGTYPA=[F:GAG]FORCLC         : # Type de cours de la pičce auto
        Else
          #Read [GTE] GTE0=[M:DIA]TYPPCE
          Local Integer WRET
          Call LEC_GTE_LEG(GCURLEG,[M:DIA]TYPPCE,WRET) From TRTLECLEG
          If WRET : Raz [F:GTE] : Endif
          If [F:GTE]TYPRAT<>0
            WCHGTYPA=num$([F:GTE]TYPRAT) : # Type de cours du type de pičce
          Else
            WCHGTYPA="[F:PWH]CHGTYP"     : # Type de cours de la réception
          Endif
        Endif
        #------
      Endif
      If GWCPY<>""  Gosub CUMUL_RECAP : Endif
      If [M:DIA]TRACE=2
        Call ECR_TRACE (" ",0)  From GESECRAN
       # Issue 76190 - 2011-09-13 by SR : Remplacer les tirets par des underscores
        WMSG ="_____ "+mess(2,45,1)-[F:PWH1]CPY+space$(16-len([F:PWH1]CPY))
        WMSG+=mess(3,45,1)-[F:PWH1]PRHFCY
        Call ECR_TRACE (WMSG,0) From GESECRAN
      Endif
      Raz GWBPSINV, GWCUR
    Endif
    If GWBPSINV<>[F:PWH1]BPSINV | GWCUR<>[F:PWH1]CUR
      If [M:DIA]TRACE=2
        If [F:BPS]BPSNUM<>[F:PWH1]BPSINV
          Read [BPS] BPS0=[F:PWH1]BPSINV : If fstat Raz [F:BPS] : Endif
        Endif
        WMSG ="_____"-mess(73,198,1)-[F:PWH1]BPSINV+space$(GLONBPS+2-len([F:PWH1]BPSINV))
        WMSG+=[F:BPS]BPSNAM+space$(GLONNAM+1-len([F:BPS]BPSNAM))+[F:PWH1]CUR
        Call ECR_TRACE (WMSG,0) From GESECRAN
      Endif
    Endif
    GWCPY   =[F:PWH1]CPY
    GWPRHFCY=[F:PWH1]PRHFCY
    GWBPSINV=[F:PWH1]BPSINV
    GWCUR   =[F:PWH1]CUR
    GWPTHNUM=[F:PWH1]PTHNUM
    Call DEBTRANS From GLOCK
    Gosub TR1
  Endif
Next
If GWCPY<>""  Raz [F:PWH1] : Gosub CUMUL_RECAP : Endif
#----- Ecriture de la récapitulation dans la trace -----#
If [M:DIA]TRACE=2 & J>0
  Call ECR_TRACE(string$(88,"-"),0)  From GESECRAN
  For I=0 To J-1
    If len(CPYFCY(I))<GLONCPY+1
      Call GETDEV(vireblc(mid$(CPYFCY(I+1),GLONCPY+1,GLONFCY),1)) From DEVSUB
      WMSG =mess(2,45,1)-CPYFCY(I)+space$(GLONFCY+1)+GLOCALDEV+" "
      WMSG+=format$("N3*:"+[F:TCU]CURFMT1,CUMULHT (I))-mess(1,243,1)+" "
      WMSG+=format$("N3*:"+[F:TCU]CURFMT1,CUMULTTC(I))-mess(2,243,1)
      Call ECR_TRACE (WMSG,0) From GESECRAN
    Else
      WMSG =space$(1+len(mess(2,45,1)))+mess(3,45,1)+" "
      WMSG+=right$(CPYFCY(I),GLONCPY+1)+" "+GLOCALDEV+" "
      WMSG+=format$("N3:"+[F:TCU]CURFMT1,CUMULHT (I))-mess(1,243,1)+" "
      WMSG+=format$("N3:"+[F:TCU]CURFMT1,CUMULTTC(I))-mess(2,243,1)
      Call ECR_TRACE (WMSG,0) From GESECRAN
    Endif
  Next I
  Call ECR_TRACE(string$(88,"-"),0)  From GESECRAN
Endif

#-------------------#
# Fin du traitement #
#-------------------#
$FIN_EXEC
If [M:DIA]TYP=1      : # Si génération réelle,
  Gosub DEVERROU_PTH : # suppression locks logiques sur PTH par sécurité
Endif
Gosub DEL_PWRK       : # Effacement fichiers de travail temporaires

#----- Fin de la trace éventuelle avec fermeture -----#
$FIN_EXEC_TRA
## Issue 115551 - 2016-04-07 by SR : Lock société
Call UNLOCKCPYAFC([M:DIA]CPY,"FUNPTH") From TRTX3

If !GSERVEUR & [M:DIA]TRACE=2
  If WNBPCE=0
    Call ECR_TRACE(mess(8,107,1),0) From GESECRAN : # Aucune pičce ŕ traiter !
  Endif
  Call FERME_TRACE From LECFIC
Endif
Return


#####################################
# Fin aprčs exécution du traitement #
#####################################
$TERMINE
Kill GWCPY, GWPTHNUM
Raz GWBPSINV, GWCUR, GWPRHFCY
If !GSERVEUR & [M:DIA]TRACE=2  TRA=1 Else TRA=0 : Endif

Return


$SORTIE
Return

# Issue X3-57740 - 2017-11-08 by MUARN : memeo et globales
$BOUTON
Case BOUT
  When "R"
    If [M:DIA]CPY <> ""
      Raz GSOC_ACTIVE
      If [M:DIA]RCPFCY <> ""
        If [F:FCY]FCY <> [M:DIA]RCPFCY
          Read [FCY] FCY0=[M:DIA]RCPFCY : If fstat Raz [F:FCY] : Endif
        Endif
      Else
        Filter [F:FCY] Where LEGCPY=[M:DIA]CPY
        Read [F:FCY] First
        If fstat : Raz [F:FCY] : Endif
        Filter [F:FCY]
      Endif
      GFCY=[F:FCY]FCY
      Gosub CHARG_PARAM
    Else
      Raz GSOCIETE, GCURLEG, GFCY, GCURFCY
      GCURLEG=[M:DIA]LEG
    Endif
Endcase
Return
# End issue X3-57740

#--------------------------------#
# Effacement fichiers de travail #
#--------------------------------#
$DEL_PWRK
Call DEBTRANS From GLOCK
$TR_DEL_PWRK
GOK=1
Trbegin [PWH], [PWD]
  #----- Suppression des entętes réceptions dans fichier temporaire -----#
  WMSG=mess(155,197,1)-"PWRKPTH"-num$(adxuid(1))
  Delete [PWH] Where PRONUM=adxuid(1)
  If fstat=1
    GOK=-1 : GLOCK="$PWRKPTH"-num$(adxuid(1))            : Goto ROLL_PWRK
  Elsif fstat
    GOK=0  : Call RSTA("PWH",num$(adxuid(1))) From GLOCK : Goto AB_PWRK
  Endif
  #----- Suppression des lignes réception dans fichier temporaire -----#
  WMSG=mess(155,197,1)-"PWRKPTD"-num$(adxuid(1))
  Delete [PWD] Where PRONUM=adxuid(1)
  If fstat=1
    GOK=-1 : GLOCK="$PWRKPTD"-num$(adxuid(1))            : Goto ROLL_PWRK
   Elsif fstat
    GOK=0  : Call RSTA("PWD",num$(adxuid(1))) From GLOCK : Goto AB_PWRK
  Endif
  #----- Suppression détail qtés engagement commande dans fichier temporaire -----#
  WMSG=mess(155,197,1)-"PWRKPOQ"
  Delete [PWQ] Where TYPORI=0 & EXTOURNE<=[M:DIA]ACCDAT
  If fstat=1
    GOK=-1 : GLOCK="$PWRKPOQ"               : Goto ROLL_PWRK
  Elsif fstat
    GOK=0  : Call RSTA("PWQ","") From GLOCK : Goto AB_PWRK
  Endif
  #----- Effacement des quantités temporaires -----#
  Update [PWQ] Where TYPORI=0 & TMPQTYPUU<>0  With TMPQTYPUU=0
  If fstat
    GOK=0  : Call FSTA("PWQ") From GLOCK    : Goto AB_PWRK
  Endif
  #-----
Commit
Return
#----- Abandon -----#
$AB_PWRK
Rollback
Gosub AB_TRANSACTION_MSG
Return
#----- Nouvel essai ou abandon si conflit d'accčs -----#
$ROLL_PWRK
Rollback
Call ROLL From GLOCK
If !GROLL
  Goto TR_DEL_PWRK
Else
  Gosub AB_TRANSACTION_MSG
Endif
Return


#---------------------------------------------------------------------------#
# Remplissage fichier de travail et blocage logique des réceptions traitées #
#---------------------------------------------------------------------------#
$TRTPTD
Raz WMONTHT, WMONTTTC, WQUANTITY, WECRITURE
If [F:TCU]CUR<>[F:PTH]CUR
  Read [TCU] TCU0=[F:PTH]CUR : If fstat Raz [F:TCU] : Endif
Endif
Trbegin [PWH], [PWD]
# Issue X3-122734 - 2019-04-26 by SR
#  For [PTD] PTD0 Where PTHNUM=[F:PTH]PTHNUM & NETPRIPUU<>0 & evalue(WCRIT2)
  For [PTD] PTD0 Where PTHNUM=[F:PTH]PTHNUM  & evalue(WCRIT2)
    If [F:PTD]LINPSTFLG<>2 | [F:PTD]LINPSTDAT<[M:DIA]ACCDAT
      # Issue 116481 - 2016-07-01 by MUARN : pour facture hors date
      WTROUVE = 1
      For [PID] PID1 Where TYPORI=2
&                        & NUMORI=[F:PTD]PTHNUM
&                        & LINORI=[F:PTD]PTDLIN
&                        & SEQORI=0
&                        & PIHTYP = 1
        If [F:PID]ACCDAT > [M:DIA]BORNE
          WTROUVE = 2
          Break
        Else
          For [PID2] PID1 Where TYPORI=4
&                        & NUMORI=[F:PID]NUM
&                        & LINORI=[F:PID]PIDLIN
&                        & SEQORI=0
&                        & ACCDAT > [M:DIA]BORNE
&                        & PIHTYP =3
            WTROUVE = 2
            Break 2
          Next
        Endif
      Next
      If WTROUVE = 1
        For [PID] PID1 Where TYPORI=1
&                        & NUMORI=[F:PTD]POHNUM
&                        & LINORI=[F:PTD]POPLIN
&                        & SEQORI=[F:PTD]POQSEQ
&                        & PIHTYP = 1
          If [F:PID]ACCDAT > [M:DIA]BORNE
            WTROUVE = 2
            Break
          Else
            For [PID2] PID1 Where TYPORI=4
&                        & NUMORI=[F:PID]NUM
&                        & LINORI=[F:PID]PIDLIN
&                        & SEQORI=0
&                        & ACCDAT > [M:DIA]BORNE
&                        & PIHTYP =3
              WTROUVE = 2
              Break 2
            Next
          Endif
        Next
      Endif
      If WTROUVE = 2
        Goto SUITE_TRTPTD
      Endif
      # End issue 116481 pour facture hors date
      # Issue X3-101250 - 2018-07-31 by SR :
      #Si pas de facture hors borne et réception totalement facturée, il n'y a rien ŕ faire
      If WTROUVE = 1 & [F:PTD]LININVFLG= 2 : Goto NEXT_PTD : Endif
      #---------------------------------#
      # On charge le fichier temporaire #
      #---------------------------------#
      If [F:PTD]INVQTYPUU=0
        If [F:PTD]LININVFLG<>2 : # Si ligne soldée, ne rien faire !
          WQUANTITY=[F:PTD]QTYPUU
          #-----
          Gosub AJUST_QTE : # Ajustement de la quantité par rapport aux retours éventuels
          #-----
          If WQUANTITY>0
            #--------------------------------------------------#
            # On pose verrou sur PTH                           #
            # si locké logiquement, on passe ŕ autre réception #
            #--------------------------------------------------#
            If WECRITURE=0 & [M:DIA]TYP=1  Gosub VERROU_PTH : Endif
            If !mkstat
              Gosub ECRIT_PWD
              If GOK<1  Break : Endif
            Else
              Break
            Endif
          Endif
        Endif
      Else
# Issue 116481 - 2016-07-01 by MUARN : pour facture hors date
$SUITE_TRTPTD
        # Issue X3-117436 - 2019-01-09 by MUARN : si pas de facture hors borne et réception non totalement facturée
        If WTROUVE = 1 & [F:PTD]LININVFLG= 1
          WQUANTITY = [F:PTD]QTYPUU - [F:PTD]INVQTYPUU
          Gosub AJUST_QTE : # Ajustement de la quantité par rapport aux retours éventuels
          Goto ECRITURE_DIRECTE
        Endif
        # End issue X3-117436
        # Issue 116481 - 2016-07-01 by MUARN : pour facture hors date
#       #WQTEFAC1=min([F:PTD]INVQTYPUU,[F:PTD]QTYPUU)
        If WTROUVE = 1
          WQTEFAC1=min([F:PTD]INVQTYPUU,[F:PTD]QTYPUU)
        Else
          WQTEFAC1 = [F:PTD]QTYPUU
        Endif
        # End issue 116481 pour facture hors date

        # Issue 116481 - 2016-07-01 by MUARN : quantité non facturée
        WQTENONFAC = [F:PTD]QTYPUU
        WPRTFLG = 1

        WQTE    =0
        # Issue X3-111966 - 2018-10-29 by SR : clean start situation
        Raz [F:PID], [F:PID2]
        #----------------------------------------------------------#
        # On lit toutes les factures pour cette ligne de réception #
        #----------------------------------------------------------#
        # Issue 80363 - 2012-03-07 by MUARN : FAR prise en compte des factures en fonction de la date
#        For [PID] PID1 Where TYPORI=2
#&                          & NUMORI=[F:PTD]PTHNUM
#&                          & LINORI=[F:PTD]PTDLIN
#&                          & SEQORI=0
        For [PID] PID1 Where TYPORI=2
&                          & NUMORI=[F:PTD]PTHNUM
&                          & LINORI=[F:PTD]PTDLIN
&                          & SEQORI=0
&                          & ACCDAT <= [M:DIA]BORNE
&                          & PIHTYP = 1 # Issue 112595 - 2015-11-23 by SR :Facture normale
          If [F:PIH]NUM<>[F:PID]NUM
            Read [PIH] PIH0=[F:PID]NUM : If fstat  Raz [F:PIH] : Endif
          Endif
          If [F:PIH]ACCDAT>[M:DIA]BORNE
            If [F:PID]PRTFLG=1
              WQTEFAC1 =0
            Else
              WQTEFAC1-=min([F:PID]QTYPUU,[F:PID]ORIQTYPUU)*(3-(2*[F:PIH]INVTYP))
            Endif
          Else
            If [F:PID]PRTFLG=1
              # Issue X3-63654 - 2017-12-08 by MUARN : facture/avoir n+1 puis facture n
              #WQTEFAC1 =0
              If WQTEFAC1 = 0
                WQTEFAC1-=min([F:PID]QTYPUU,[F:PID]ORIQTYPUU)*(3-(2*[F:PIH]INVTYP))
              Else
                WQTEFAC1 = 0
              Endif

              # Issue 116481 - 2016-06-30 by MUARN : qunatité non facturée
              WQTENONFAC -= [F:PID]QTYPUU
              # Issue 120703- 2017-01-11 by MUARN : ajustement flag
              #WPRTFLG = 2
              If [F:PID]QTYPUU <> [F:PID]QTYBUDLIN
                WPRTFLG=2
              Endif

              # Issue 116481 - 2016-06-29 by MUARN : sur-facturation
              #WQTE     =[F:PTD]QTYPUU
              If [F:PID]QTYPUU > [F:PID]ORIQTYPUU & WQTE=0
                WQTE = [F:PID]QTYPUU
              Else
                WQTE = [F:PTD]QTYPUU
                # Issue X3-63654 - 2017-12-11 by MUARN : facture/avoir n+1 puis facture n
                If WQTENONFAC < 0
                  WQTE -= WQTENONFAC
                Endif
                # Issue X3-86493 - 2018-05-29 by MUARN : ne pas faire si QTYBUDLIN=0
                # Issue X3-52966 - 2018-01-03 by MUARN : sur facturation et suppression facture
                If [F:PID]PRTFLG = 1 & [F:PID]QTYBUDLIN < [F:PID]ORIQTYPUU & [F:PID]QTYBUDLIN<>0
                  WQTE = [F:PID]QTYPUU
                  WPRTFLG=1
                Endif
              Endif
            Else
              WQTEFAC1-=min([F:PID]QTYPUU,[F:PID]ORIQTYPUU)*(3-(2*[F:PIH]INVTYP))
              WQTE    +=min([F:PID]QTYPUU,[F:PID]ORIQTYPUU)*(3-(2*[F:PIH]INVTYP))
            Endif
          Endif
# Issue 116191 - 2016-04-28 by SR : ŕ faire facture par facture et non  aprčs toutes les factures
          For [PID2] PID1 Where TYPORI=4
&                          & NUMORI=[F:PID]NUM
&                          & LINORI=[F:PID]PIDLIN
&                          & SEQORI=0
&                          & ACCDAT <= [M:DIA]BORNE
&                          & PIHTYP =3
           # seulement avoir en quantité ou avoir total
           If ([F:PID2]QTYPUU <> 0 & [F:PID2]QTYPUU<>[F:PID2]ORIQTYPUU)
&           | ([F:PID2]QTYPUU=[F:PID2]ORIQTYPUU & [F:PID2]NETPRI=[F:PID2]ORINETPRI)
             If [F:PIH2]NUM<>[F:PID2]NUM
                Read [PIH2] PIH0=[F:PID2]NUM : If fstat  Raz [F:PIH2] : Endif
              Endif
              # Issue 119413 - 2016-10-27 by SR : Alimenter aussi WQTEFAC1 car sert ensuite pour lire
              # ou non les factures sur commande
              WQTEFAC1-=min([F:PID2]QTYPUU,[F:PID2]ORIQTYPUU)*(3-(2*[F:PIH2]INVTYP))
              WQTE    +=min([F:PID2]QTYPUU,[F:PID2]ORIQTYPUU)*(3-(2*[F:PIH2]INVTYP))
           Endif
          Next
# End issue 116191
        Next
# Issue 116191 - 2016-04-28 by SR : déplacé plus haut
#        # Issue 112595 - 2015-11-23 by SR : Avoirs sur ces factures ?
#        For [PID] PID1 Where TYPORI=2
#&                          & NUMORI=[F:PTD]PTHNUM
#&                          & LINORI=[F:PTD]PTDLIN
#&                          & SEQORI=0
#&                          & PIHTYP = 1  # Issue 112595 - 2015-11-23 by SR :Facture normale
#          For [PID2] PID1 Where TYPORI=4
#&                          & NUMORI=[F:PID]NUM
#&                          & LINORI=[F:PID]PIDLIN
#&                          & SEQORI=0
#&                          & ACCDAT <= [M:DIA]BORNE
#&                          & PIHTYP =3
#           # seulement avoir en quantité ou avoir total
#           If ([F:PID2]QTYPUU <> 0 & [F:PID2]QTYPUU<>[F:PID2]ORIQTYPUU)
#&           | ([F:PID2]QTYPUU=[F:PID2]ORIQTYPUU & [F:PID2]NETPRI=[F:PID2]ORINETPRI)
#             If [F:PIH2]NUM<>[F:PID2]NUM
#                Read [PIH2] PIH0=[F:PID2]NUM : If fstat  Raz [F:PIH2] : Endif
#              Endif
#              WQTE    +=min([F:PID2]QTYPUU,[F:PID2]ORIQTYPUU)*(3-(2*[F:PIH2]INVTYP))
#           Endif
#          Next
#          # End issue 112595
#        Next
# End issue 116191
        #-----
        WQUANTITY=[F:PTD]QTYPUU-WQTE
        #-------------------------------------------------------------------#
        # Exploitation des factures associées ŕ la commande de la réception #
        #-------------------------------------------------------------------#
        # Issue 116481 - 2016-07-01 by MUARN : quantité non facturée
        #If [F:PTD]POHNUM<>"" & WQTEFAC1>0
        If ([F:PTD]POHNUM<>"" & WQTEFAC1>0) | ([F:PTD]POHNUM<>"" & WQTENONFAC>0)
          #----- On lit toutes les factures pour cette ligne de commande -----#
          If WPOHNUM<>[F:PTD]POHNUM |
&            WPOPLIN<>[F:PTD]POPLIN |
&            WPOQSEQ<>[F:PTD]POQSEQ
            Raz WQTECDEFAC
            For [PID] PID1 Where TYPORI=1
&                              & NUMORI=[F:PTD]POHNUM
&                              & LINORI=[F:PTD]POPLIN
&                              & SEQORI=[F:PTD]POQSEQ
&                              & PIHTYP = 1 # Issue 112595 - 2015-11-23 by SR :Facture normale
              If [F:PIH]NUM<>[F:PID]NUM
                Read [PIH] PIH0=[F:PID]NUM : If fstat  Raz [F:PIH] : Endif
              Endif
              # Issue 112595 - 2015-11-23 by SR : réajuster la quantité par rapport  aux éventuels avoirs
              For [PID2] PID1 Where TYPORI=4
&                     & NUMORI=[F:PID]NUM
&                     & LINORI=[F:PID]PIDLIN
&                     & SEQORI=0
&                     & ACCDAT <= [M:DIA]BORNE
&                     & PIHTYP = 3
              # seulement avoir en quantité ou avoir total
              If ([F:PID2]QTYPUU <> 0 & [F:PID2]QTYPUU<>[F:PID2]ORIQTYPUU)
&              | ([F:PID2]QTYPUU=[F:PID2]ORIQTYPUU & [F:PID2]NETPRI=[F:PID2]ORINETPRI)
                  [F:PID]QTYPUU-=[F:PID2]QTYPUU
               Endif
              Next
              If [F:PIH]ACCDAT<=[M:DIA]BORNE & [F:PID]QTYPUU > 0            # End issue 112595
                If [F:PID]PRTFLG=1
                  # Issue 116481 - 2016-07-01 by MUARN : sous facturation
                  If [F:PID]QTYPUU < [F:PTD]QTYPUU
                    WQTECDEFAC+=[F:PID]QTYPUU*(3-(2*[F:PIH]INVTYP))
                  Else
                    # Issue 101054 - 2014-08-21 by MUARN : sur facturation de commande
                    #WQTECDEFAC+=max([F:PID]ORIQTYPUU,[F:PTD]QTYPUU)*(3-(2*[F:PIH]INVTYP))
                    WQTECDEFAC+=max([F:PID]QTYPUU,[F:PTD]QTYPUU)*(3-(2*[F:PIH]INVTYP))
                  Endif
                Else
                  WQTECDEFAC+=min([F:PID]QTYPUU,max([F:PID]ORIQTYPUU,[F:PTD]QTYPUU))*(3-(2*[F:PIH]INVTYP))
                Endif
              Endif
            Next
            WPOHNUM=[F:PTD]POHNUM
            WPOPLIN=[F:PTD]POPLIN
            WPOQSEQ=[F:PTD]POQSEQ
          Endif
          #----- On lit toutes les réceptions de cette ligne de commande -----#
          If WQTECDEFAC>0
            WQTE=WQTECDEFAC
            For [PTD2] PTD2 Where POHNUM=[F:PTD]POHNUM
&                               & POPLIN=[F:PTD]POPLIN
&                               & POQSEQ=[F:PTD]POQSEQ
              #----- C'est la réception en cours de traitement -----#
              If [F:PTD2]PTHNUM=[F:PTD]PTHNUM &
&                [F:PTD2]POPLIN=[F:PTD]POPLIN &
&                [F:PTD2]POQSEQ=[F:PTD]POQSEQ
                GBIDD1=min(WQTEFAC1,WQTE)
                WQUANTITY-=GBIDD1
                WQTEFAC1 -=GBIDD1
                Break
              Endif
              #-----
              WQTEFAC2=min([F:PTD2]INVQTYPUU,[F:PTD2]QTYPUU)
              For [PID] PID1 Where TYPORI=2
&                                & NUMORI=[F:PTD2]PTHNUM
&                                & LINORI=[F:PTD2]PTDLIN
&                                & SEQORI=0
&                                & PIHTYP = 1   # Issue 112595 - 2015-11-23 by SR :Avoir
                 # Issue 112595 - 2015-11-23 by SR : réajuster la quantité par rapport  aux éventuels avoirs
                 For [PID2] PID1 Where TYPORI=4
&                     & NUMORI=[F:PID]NUM
&                     & LINORI=[F:PID]PIDLIN
&                     & SEQORI=0
&                     & ACCDAT <= [M:DIA]BORNE
&                     & PIHTYP = 3
                      # seulement avoir en quantité ou avoir total
                      If ([F:PID2]QTYPUU <> 0 & [F:PID2]QTYPUU<>[F:PID2]ORIQTYPUU)
&                      | ([F:PID2]QTYPUU=[F:PID2]ORIQTYPUU & [F:PID2]NETPRI=[F:PID2]ORINETPRI)
                        [F:PID]QTYPUU-=[F:PID2]QTYPUU
                     Endif
                Next
                If [F:PID]QTYPUU < 0  : [F:PID]QTYPUU = 0 : Endif
                # End issue 112595
                If [F:PID]PRTFLG=1
                  WQTEFAC2=0
                Else
                  WQTEFAC2-=min([F:PID]QTYPUU,[F:PID]ORIQTYPUU)*(3-(2*[F:PIH]INVTYP))
                Endif
              Next
              If WQTEFAC2>0
                WQTE-=min(WQTEFAC2,WQTE)
                If WQTE<=0  Break : Endif
              Endif
            Next
          Endif
          #----- Prise en compte de la surfacturation de réceptions -----#
          # Issue X3-52966 - 2017-12-29 by MUARN : ajout WQTENONFAC
          #If WQTEFAC1>0
          If WQTEFAC1>0 | WQTENONFAC >0
            For [PTD2] PTD2 Where POHNUM=[F:PTD]POHNUM
&                               & POPLIN=[F:PTD]POPLIN
&                               & POQSEQ=[F:PTD]POQSEQ
&                               & (PTHNUM<>[F:PTD]PTHNUM | PTDLIN<>[F:PTD]PTDLIN)
              For [PID] PID1 Where TYPORI=2
&                                & NUMORI=[F:PTD2]PTHNUM
&                                & LINORI=[F:PTD2]PTDLIN
&                                & SEQORI=0
                If [F:PIH]NUM<>[F:PID]NUM
                  Read [PIH] PIH0=[F:PID]NUM : If fstat  Raz [F:PIH] : Endif
                Endif
                # Issue 112595 - 2015-11-23 by SR : réajuster la quantité par rapport  aux éventuels avoirs
                For [PID2] PID1 Where TYPORI=4
&                     & NUMORI=[F:PID]NUM
&                     & LINORI=[F:PID]PIDLIN
&                     & SEQORI=0
&                     & ACCDAT <= [M:DIA]BORNE
&                     & PIHTYP = 3
                      # seulement avoir en quantité ou avoir total
                     If ([F:PID2]QTYPUU <> 0 & [F:PID2]QTYPUU<>[F:PID2]ORIQTYPUU)
&                     | ([F:PID2]QTYPUU=[F:PID2]ORIQTYPUU & [F:PID2]NETPRI=[F:PID2]ORINETPRI)
                        [F:PID]QTYPUU-=[F:PID2]QTYPUU
                     Endif
                Next
                If [F:PID]QTYPUU < 0  : [F:PID]QTYPUU = 0 : Endif
                # End issue 112595
                If [F:PIH]ACCDAT<=[M:DIA]BORNE & [F:PID]QTYPUU>[F:PID]ORIQTYPUU
                  GBIDD1=[F:PID]QTYPUU-[F:PID]ORIQTYPUU
                  If GBIDD1<WQTEFAC1
                    WQUANTITY-=GBIDD1
                    WQTEFAC1 -=GBIDD1
                  Else
                    # Issue X3-52966 - 2017-12-29 by MUARN : ajout cas différents de WQTEFAC <=0
                    If WQTEFAC1 > 0
                      WQUANTITY-=WQTEFAC1
                      Raz WQTEFAC1
                      Break 2
                    Else
                      WQUANTITY  -=GBIDD1
                      WQTENONFAC -=GBIDD1
                    Endif
                  Endif
                Endif
              Next
            Next
          Endif
          #----- Lecture des réceptions facturées avec retour pour la ligne cde -----#
          If WQUANTITY>0 & WQTEFAC1>0
            Raz WQTEFAC2
            For [PTD2] PTD2 Where POHNUM=[F:PTD]POHNUM
&                               & POPLIN=[F:PTD]POPLIN
&                               & POQSEQ=[F:PTD]POQSEQ
&                               & (PTHNUM<>[F:PTD]PTHNUM | PTDLIN<>[F:PTD]PTDLIN)
&                               & INVQTYPUU<>0
&                               & RTNQTYPUU<>0
              #-------------------------------------------------#
              # Boucle sur retours validés sans attente d'avoir #
              #  avec réintégration en commande sur męme ligne  #
              #-------------------------------------------------#
              Raz WQTE
              Columns [PNH] (PNHNUM, CFMFLG)
              Columns [PND] (PNHNUM, PNDLIN, PTHNUM, PTDLIN, LININVFLG, QTYPUU, INVQTYPUU)
              For [PND] PND1 Where PTHNUM=[F:PTD2]PTHNUM & PTDLIN=[F:PTD2]PTDLIN
&                                & ORDFLG=2 & LININVFLG=2 & INVQTYPUU=0
                Read [PNH] PNH0=[F:PND]PNHNUM : If fstat Raz [F:PNH] : Endif
                If [F:PNH]CFMFLG=2
                  WQTE+=[F:PND]QTYPUU
                Endif
              Next
              Columns [PNH]
              Columns [PND]
              #-----
              WQTEFAC2+=min([F:PTD2]INVQTYPUU,WQTE)
              If WQTEFAC2>=WQTEFAC1  Break : Endif
            Next
            GBIDD1=min(WQTEFAC1,WQTEFAC2)
            WQUANTITY-=GBIDD1
            WQTEFAC1 -=GBIDD1
          Endif
          #-----
        Endif
        #----- Si ligne soldée manuellement, il faut enlever le reliquat soldé -----#
        If WQUANTITY>0 & [F:PTD]LININVFLG=2 & [F:PTD]QTYPUU-[F:PTD]INVQTYPUU>0
          WQUANTITY-=([F:PTD]QTYPUU-[F:PTD]INVQTYPUU)
        Endif
        #-----
        Gosub AJUST_QTE : # Ajustement de la quantité par rapport aux retours éventuels

        # Issue 116481 - 2016-07-04 by MUARN : Si réception soldée et aucune facture hors date raz WQTENONFAC
        WTROUVE = 1
        If WQTENONFAC > 0 & [F:PTD]LININVFLG = 2
          For [PID] PID1 Where TYPORI=2
&                          & NUMORI=[F:PTD]PTHNUM
&                          & LINORI=[F:PTD]PTDLIN
&                          & SEQORI=0
&                          & ACCDAT > [M:DIA]BORNE
&                          & PIHTYP = 1
            WTROUVE = 2
            Break
          Next
          If WQTENONFAC > 0 & [F:PTD]POHNUM<>"" & WTROUVE =1
            For [PID] PID1 Where TYPORI=1
&                              & NUMORI=[F:PTD]POHNUM
&                              & LINORI=[F:PTD]POPLIN
&                              & SEQORI=[F:PTD]POQSEQ
&                              & ACCDAT > [M:DIA]BORNE
&                              & PIHTYP = 1
              WTROUVE = 2
              Break
            Next
          Endif
          If WTROUVE = 1
            Raz WQTENONFAC
          Endif
        Endif
        # End issue 116481 pour raz WQTENONFAC
        # Issue 116481 - 2016-07-01 by MUARN : ajustement quantité non facturée
        If WQTENONFAC > 0 & WPRTFLG = 2 #WQUANTITY >= 0 &
          If WQTECDEFAC > 0
            WQUANTITY += WQTENONFAC - WQTE
          Else
            WQUANTITY += WQTENONFAC
          Endif
        # Issue X3-117436 - 2019-01-09 by MUARN : PID2 doit exister
        # Issue X3-111966 - 2018-10-29 by SR :
        # si la derničre facture exploitée est la facture "Totale" de la ligne de réception en cours et pas d'avoir sur celle-ci et
        # ligne Réception non totalement facturée  et il reste une quantité non facturée
        # on doit tenir compte de la qté non facturée
        Elsif  [F:PID]NUM <> "" & [F:PID]TYPORI = 2 & [F:PID]NUMORI = [F:PTD]PTHNUM & [F:PID]LINORI = [F:PTD]PTDLIN &
&              [F:PID]PRTFLG = 1 & ([F:PID2]NUMORI <>[F:PID]NUM | [F:PID2]LINORI <> [F:PID]PIDLIN) &
&              [F:PTD]LININVFLG <> 2 & WQTENONFAC > 0 & [F:PID2]NUM <> ""
          WQUANTITY += WQTENONFAC
        # End issue X3-111966
        Endif
# Issue X3-117436 - 2019-01-09 by MUARN : si pas de facture hors borne et réception non totalement facturée
$ECRITURE_DIRECTE
        #-----
        If WQUANTITY>0
          #--------------------------------------------------#
          # On pose verrou sur PTH                           #
          # si locké logiquement, on passe ŕ autre réception #
          #--------------------------------------------------#
          If WECRITURE=0 & [M:DIA]TYP=1  Gosub VERROU_PTH : Endif
          If !mkstat
            Gosub ECRIT_PWD
            If GOK<1  Break : Endif
          Else
            Break
          Endif
        Endif
      Endif
    Endif
  # Issue X3-101250 - 2018-07-31 by SR :
  $NEXT_PTD
  Next
  #----- Ecriture fichier de travail entęte -----#
  If WECRITURE<>0 & GOK=1
    [F:PWH]PRONUM=adxuid(1)
    [F:PWH]=[F:PTH]
    #----- Relecture devise si nécessaire -----#
    If [F:TCU]CUR<>[F:PTH]CUR
      Read [TCU] TCU0=[F:PTH]CUR : If fstat Raz [F:TCU] : Endif
    Endif
    #-----
    If [F:TCU]EURFLG=2 & [M:DIA]ACCDAT>[F:TCU]CURENDDAT
      [F:PWH]CUR =GEURO
    Else
      [F:PWH]CUR =[F:PTH]CUR
    Endif
    [F:PWH]CURLEDANA=WDEVLED
    [F:PWH]CPY=GSOCIETE
    #----- Montant TTC et montant HT -----#
    [F:PWH]AMTNOT=WMONTHT
    [F:PWH]AMTATI=WMONTTTC

    ###################################################################
    # Intervenir sur la classe [F:PWH] champs DIE et CCE dimensionnés # JHA
    ###################################################################
    #----- Cas des FAR Apres report sur enveloppe annuelle -----#
    Call BUOENV_SWITCH(1,[F:PWH]CPY,[F:PWH]RCPDAT,[F:PWH]DIE,[F:PWH]CCE,[M:DIA]TRACE) From TRTGDD
    #----- Fin intervention Comptabilité - Cas des FAR - JHA 20/10/10 -----#

    CLEFIC=num$([F:PWH]PRONUM)-[F:PWH]PTHNUM
    WMSG=mess(13,100,1)-"PWRKPTH"-CLEFIC : # Erreur d'écriture sur le fichier ...
    Write [PWH]
    If fstat
      GOK=0 : Call FSTA("PWH") From GLOCK
      Gosub AB_TRANSACTION_MSG
    Endif
    WNBPCE=1
  Endif
  #----- Déblocage logique si incident ou aucune ligne réception traitée ----#
  If GOK<1 | WECRITURE=0
    SYMBOL2="PTH"+[F:PTH]PTHNUM
    Unlock=SYMBOL2
  Endif
  If GOK<1  Rollback : Return : Endif
  #----- Point d'entrée permettant d'intervenir sur les tables de travail -----#
  # Table de travail PWRKPTH clé PWH0=adxuid(1)+[F:PTH]PTHNUM                  #
  #                  Contient l'entęte de réception en cours de traitement     #
  #                                                                            #
  # Table de travail PWRKPTD clé PWD0(2)=adxuid(1)+[F:PTH]PTHNUM               #
  #                  Contient toutes les lignes de la réception en cours       #
  #                                                                            #
  # Nota : La classe [F:PTH] est significative (réception en cours)            #
  #        Il y a une transaction en cours                                     #
  #----------------------------------------------------------------------------#
  If WECRITURE<>0
    GPOINT="PTHPWRK" : Gosub ENTREE From EXEFNC
    If GOK<1  Rollback : Return : Endif
  Endif
  #-----
Commit
Return


#--------------------------------------------------------------------------------#
# Ajustement de la quantité en fonction des retours validés sans attente d'avoir #
#--------------------------------------------------------------------------------#
$AJUST_QTE
#----- Recherche si des retours validés sans avoir, existent -----#
If [F:PTD]RTNQTYPUU<>0
  Columns [PNH] (PNHNUM, CFMFLG)
  Columns [PND] (PNHNUM, PNDLIN, PTHNUM, PTDLIN, LININVFLG, QTYPUU, INVQTYPUU)
  For [PND] PND1 Where PTHNUM=[F:PTD]PTHNUM & PTDLIN=[F:PTD]PTDLIN
&                    & LININVFLG=2 & INVQTYPUU=0
&                    & RTNDAT <= [M:DIA]BORNE # Issue X3-136544 - 2019-05-02 by SR
    Read [PNH] PNH0=[F:PND]PNHNUM : If fstat Raz [F:PNH] : Endif
    If [F:PNH]CFMFLG=2  WQUANTITY-=[F:PND]QTYPUU : Endif
  Next
  Columns [PNH]
  Columns [PND]
Endif
#-----
Return


#-----------------------------------------#
# Blocage logique des réceptions traitées #
#-----------------------------------------#
$VERROU_PTH
Raz WMSG, mkstat
SYMBOL2="PTH"+[F:PTH]PTHNUM
Lock=SYMBOL2 With lockwait=0
If fstat
  If [M:DIA]TRACE=2
    WMSG=mess(117,198,1)-[F:PTH]PTHNUM-mess(10,100,1)
    Call ECR_TRACE(WMSG,1) From GESECRAN
  Endif
  mkstat=2
Endif
Return


#-------------------------------------------------#
# Déverrou locks logiques sur réceptions traitées #
#-------------------------------------------------#
$DEVERROU_PTH
For [PWH]
  SYMBOL2="PTH"+[F:PWH]PTHNUM : Unlock=SYMBOL2
Next
Return


#-----------------------------#
# Ecriture fichier de travail #
#-----------------------------#
$ECRIT_PWD
Raz [F:PWD]
[F:PWD]PRONUM=adxuid(1)
[F:PWD]      =[F:PTD]
[F:PWD]BPSINV=[F:PTH]BPSINV
#----- Récupération des comptes et sections analytiques -----#
Read [CAL] CAL0="PTD";0;[F:PTD]PTHNUM;[F:PTD]PTDLIN;0;"";1
If !fstat
  For I=0 To dim([F:CAL]COA)-1
    [F:PWD]LED(I)   =[F:CAL]LED(I)
    [F:PWD]COA(I)   =[F:CAL]COA(I)
    [F:PWD]LINACC(I)=[F:CAL]ACC(I)
  Next I
  For I=0 To dim([F:CAL]DIE)-1
    [F:PWD]DIE(I)   =[F:CAL]DIE(I)
    [F:PWD]CCE(I)   =[F:CAL]CCE(I)
  Next I
Else
  Raz [F:CAL]
Endif
#----- Relecture devise si nécessaire -----#
If [F:TCU]CUR<>[F:PTH]CUR
  Read [TCU] TCU0=[F:PTH]CUR : If fstat Raz [F:TCU] : Endif
Endif
#-----
If [F:TCU]EURFLG=2 & [M:DIA]ACCDAT>[F:TCU]CURENDDAT
  [F:PWD]CUR =GEURO
Else
  [F:PWD]CUR =[F:PTH]CUR
Endif
[F:PWD]CURLEDANA=WDEVLED
#-----------------------------------------------------------#
# Point d'entrée PTHQTY pour modifier la quantité de la FAR #
# --------------------------------------------------------- #
# Variables utilisables par le point d'entrée               #
#                                                           #
# WQUANTITY     : Quantité de la FAR exprimée en UA         #
#                 Cette quantité est modifiable             #
# [F:PTD]PUU    : Unité d'achat de la quantité              #
# [F:PTD]PTHNUM : No de réception en cours de traitement    #
# [F:PTD]PTDLIN : Ligne réception en cours de traitement    #
#-----------------------------------------------------------#
GPOINT="PTHQTY" : Gosub ENTREE From EXEFNC
If WQUANTITY<=0  Return : Endif
#-----
[F:PWD]QTYPUU=WQUANTITY
#----- Recalcul unité stock -----#
Call PCAL_QTY([F:PWD]QTYPUU,[F:PWD]PUU,[F:PWD]QTYSTU,[F:PWD]STU,[F:PWD]ITMREF,
&             [F:PTH]BPSNUM,1,GBIDD3) From TRTACHQTE1
#----- Conversion du prix net en devise entęte -----#
WPRIX=0
If [F:PWD]NETCUR<>[F:PWD]CUR
  Call CONVERT2([F:PWD]NETCUR,[F:PWD]CUR,GLOCALDEV,[F:PTH]CHGTYP,[M:DIA]ACCDAT,
&               [F:PWD]NETPRIPUU,GBIDD3,STAT) From TRTDEV
  WPRIX=arr(GBIDD3,10^-GDECPRI)
Else
  WPRIX=[F:PWD]NETPRIPUU
Endif
#----- On calcul le montant ht ligne et 3 montants taxe ligne -----#
[F:PWD]AMTNOTLIN=[F:PWD]QTYPUU*WPRIX

#Y015
[F:PWD]AMTNOTLIN=func YFUNINISERV.IMPORTE([F:PWD]PTHNUM,[F:PWD]AMTNOTLIN)
#Y015
#-----------------------------------------------------------------#
# Point d'entrée PTHAMTLIN pour modifier le mt HT ligne de la FAR #
# --------------------------------------------------------------- #
# Variables utilisables par le point d'entrée                     #
#                                                                 #
# [F:PWD]QTYPUU   : Quantité de la FAR exprimée en UA             #
# [F:PTD]PUU      : Unité d'achat de la quantité                  #
# [F:PTD]PTHNUM   : No de réception en cours de traitement        #
# [F:PTD]PTDLIN   : Ligne réception en cours de traitement        #
# [F:PWD]NETPRIPUU: Prix unitaire d'une UA en devise d'achat      #
# [F:PWD]NETCUR   : Devise du [F:PWD]NETPRIPUU                    #
#  WPRIX          : Prix unitaire d'une UA en devise de la FAR    #
# [F:PWD]CUR      : Devise du WPRIX et du [F:PWD]AMTNOLIN         #
# [F:PWD]AMTNOTLIN: Montant ligne HT calculé non encore arrondi   #
#                   Ce montant est modifiable et sera arrondi en  #
#                          fonction de la devise [F:PWD]CUR       #
#-----------------------------------------------------------------#
GPOINT="PTHAMTLIN" : Gosub ENTREE From EXEFNC
#-----
Call ARRDEV([F:PWD]AMTNOTLIN,[F:PWD]CUR) From TRTDIV
WMONTHT +=[F:PWD]AMTNOTLIN
WMONTTTC+=[F:PWD]AMTNOTLIN
#-----------------------------#
# Calcul des montants de taxe #
#-----------------------------#
If [F:BPS]BPSNUM<>[F:PTH]BPSNUM
  Read [BPS] BPS0=[F:PTH]BPSNUM : If fstat  Raz [F:BPS] : Endif
Endif
#----- Chargement du régime de taxe du fournisseur -----#
Raz WVACBPR
If [F:PTD]POHNUM<>""
  If [F:POH]POHNUM<>[F:PTD]POHNUM
    Read [POH] POH0=[F:PTD]POHNUM : If fstat  Raz [F:POH] : Endif
  Endif
  WVACBPR=[F:POH]VACBPR
Endif
If WVACBPR=""
  Call INIT_REGIME([F:PTH]BPSNUM,[F:PTH]PRHFCY,"F",WVACBPR) From CPTSUB
Endif
#------------------------------#
# Récuperation du type de taxe #
#------------------------------#
# Issue 117271 - 2016-06-28 by SR :
#Read [ADI] CODE=1;WVACBPR
#If fstat  Raz [F:ADI] : Endif
#If [F:ADI]N1=4
#  [F:PWD]CEEFLG=2
#Else
#  [F:PWD]CEEFLG=1
#Endif
Raz WRETOUR
Call LEC_TVB_LEG(GCURLEG,WVACBPR,WRETOUR) From TRTLECLEG
If WRETOUR Raz [F:TVB] : Endif
If [F:TVB]REGVAC=4
  [F:PWD]CEEFLG=2
Else
  [F:PWD]CEEFLG=1
Endif
# End issue 117271
#-----
Call ALICLCAMT2([F:PWD]ITMREF,[F:PWD]QTYPUU,-1,"PWD",WCLCAMT) From TRTX3
#-----
For I=1 To WNBTAXE
  Case I
    When 1 : WTAXE(1)=[F:PWD]VAT(0)
    When 2 : WTAXE(2)=[F:PWD]VAT(1)
    When 3 : WTAXE(3)=[F:PWD]VAT(2)
    When 4 : WTAXE(4)=[F:PWD]TAXRCP
    When 5 : WTAXE(5)=[F:PWD]TAXISS
    When 6 : WTAXE(6)=[F:PWD]TAXOTH1
    When 7 : WTAXE(7)=[F:PWD]TAXOTH2
  Endcase
Next I
#-----
Call CALTAXE2([F:PWD]PRHFCY,[F:PWD]RCPDAT,WVACBPR,[F:PWD]CUR,WNBTAXE,WTAXE,1,[F:PWD]AMTNOTLIN,
&             WCLCAMT,WMONTTAX,WMONTTAXDED,WTYPREG,WRETOUR) From SUBTVT
#-----
For I=1 To WNBTAXE
  Case I
    When 1 : [F:PWD]CLCAMT1   =WCLCAMT(1)
             [F:PWD]AMTTAXLIN1=WMONTTAX(1)
             [F:PWD]DEDTAXLIN1=WMONTTAXDED(1)
             If [F:PWD]CEEFLG<>2  WMONTTTC+=[F:PWD]AMTTAXLIN1 : Endif
    When 2 : [F:PWD]CLCAMT2   =WCLCAMT(2)
             [F:PWD]AMTTAXLIN2=WMONTTAX(2)
             [F:PWD]DEDTAXLIN2=WMONTTAXDED(2)
             If [F:PWD]CEEFLG<>2  WMONTTTC+=[F:PWD]AMTTAXLIN2 : Endif
    When 3 : [F:PWD]CLCAMT3   =WCLCAMT(3)
             [F:PWD]AMTTAXLIN3=WMONTTAX(3)
             [F:PWD]DEDTAXLIN3=WMONTTAXDED(3)
             If [F:PWD]CEEFLG<>2  WMONTTTC+=[F:PWD]AMTTAXLIN3 : Endif
    When 4 : [F:PWD]CLCAMT4   =WCLCAMT(4)
             [F:PWD]AMTTAXRCP =WMONTTAX(4)
             [F:PWD]DEDTAXRCP =WMONTTAXDED(4)
             If [F:PWD]CEEFLG<>2  WMONTTTC+=[F:PWD]AMTTAXRCP  : Endif
    When 5 : [F:PWD]CLCAMT5   =WCLCAMT(5)
             [F:PWD]AMTTAXISS =WMONTTAX(5)
             [F:PWD]DEDTAXRCP =WMONTTAXDED(5)
             If [F:PWD]CEEFLG<>2  WMONTTTC+=[F:PWD]AMTTAXISS  : Endif
    When 6 : [F:PWD]CLCAMT6   =WCLCAMT(6)
             [F:PWD]AMTTAXOTH1=WMONTTAX(6)
             [F:PWD]DEDTAXOTH1=WMONTTAXDED(6)
             If [F:PWD]CEEFLG<>2  WMONTTTC+=[F:PWD]AMTTAXOTH1 : Endif
    When 7 : [F:PWD]CLCAMT7   =WCLCAMT(7)
             [F:PWD]AMTTAXOTH2=WMONTTAX(7)
             [F:PWD]DEDTAXOTH2=WMONTTAXDED(7)
             If [F:PWD]CEEFLG<>2  WMONTTTC+=[F:PWD]AMTTAXOTH2 : Endif
  Endcase
Next I
#----- Recherche compte général -----#
Raz WCOMPTE
I=find(WLEDGEN,[F:CAL]LED(0..9))
If I
  WCOMPTE=[F:CAL]ACC(I-1)
Endif
#----- Recherche compte analytique -----#
Raz WCPTANA
I=find(WLEDANA,[F:CAL]LED(0..9))
If I
  WCPTANA=[F:CAL]ACC(I-1)
  WCOA   =[F:CAL]COA(I-1)
Endif
#----- Recherche des comptes si nécessaire -----#
If WCOMPTE="" & WCPTANA=""
  If [F:PTD]POHNUM<>""
    ID1(1)=[F:PTD]POHNUM
    ID2(1)=[F:PTD]POHNUM
    ID2(2)=num$([F:PTD]POPLIN)
    ID2(3)=num$([F:PTD]POQSEQ)
    Read [TB0] POH0=[F:PTD]POHNUM
    If fstat  Raz [F:TB0] : Endif
    Read [TB1] POQ0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
    If fstat  Raz [F:TB1] : Endif
    Read [TB2] CAL0="POP";0;[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ;"";1
    If fstat  Raz [F:TB2] : Endif
  Else
    Raz ID1, ID2
    [F:TB0]=[F:PTH]
    If !find([F:PTH]PRHFCY,GSITE(1..GNBSITE))
      [F:TB0]INVFCY=[F:PTH]PRHFCY
    Else
      [F:TB0]INVFCY=GFINSITE(find([F:PTH]PRHFCY,GSITE(1..GNBSITE)))
    Endif
    [F:TB1]=[F:PTD]
    Read [TB2] CAL0="PTD";0;[F:PTD]PTHNUM;[F:PTD]PTDLIN;0;"";1
    If fstat  Raz [F:TB2] : Endif
  Endif
  Call SETREF(GSOCIETE,I,[F:PWD]LED) From CPTDIV
  Call COMPTE ("PORD",1,ID1,ID2,TPLAN,TCOMPTE,STAT,WMSG) From TRTACHCDE1
  If STAT
    Raz TPLAN, TCOMPTE
  Else
    For I=1 To 10
      If TPLAN(I)<>""
        J=find([F:GAD]LEDTYP(I-1),TBTYPLED(1..10))
        If J
          # Issue 79874 - 2012-03-12 by MUARN : FAR réception sans compte décalage pour remplir [f:pwd]
#          [F:PWD]COA   (J)=TPLAN  (I)
#          [F:PWD]LINACC(J)=TCOMPTE(I)
          [F:PWD]COA   (J-1)=TPLAN  (I)
          [F:PWD]LINACC(J-1)=TCOMPTE(I)
        Endif
      Endif
    Next I
  Endif
  #----- Récupération compte général -----#
  Call LECPLAN(GSOCIETE,GTYPGEN,WCOA) From CPTDIV
  I=find(WCOA,TPLAN(1..10))
  If I  WCOMPTE=TCOMPTE(I) : Endif
  #----- Récupération compte analytique -----#
  Call LECPLAN(GSOCIETE,GTYPANA,WCOA) From CPTDIV
  I=find(WCOA,TPLAN(1..10))
  If I  WCPTANA=TCOMPTE(I) : Endif
Endif
#-----
[F:PWD]COAANA=WCOA
[F:PWD]ACCANA=WCPTANA
#----- Recherche de l'unité d'oeuvre (WGLU) -----#
If [F:GAC]COA<>WCOA | [F:GAC]ACC<>WCPTANA
  Read [GAC] GAC0=WCOA;WCPTANA : If fstat  Raz [F:GAC] : Endif
Endif
WGLU=[F:GAC]UOM
If WGLU<>""
  #----- Calcul qté en unité d'oeuvre (WQTYGLU) -----#
  Call PCAL_QTY([F:PWD]QTYPUU,[F:PWD]PUU,WQTYGLU,WGLU,
&               [F:PWD]ITMREF,[F:PTH]BPSNUM,1,GBIDD1) From TRTACHQTE1
  If [F:TCO]UOM1=""
    Call PCAL_QTY([F:PWD]QTYSTU,[F:PWD]STU,WQTYGLU,WGLU,
&               [F:PWD]ITMREF,[F:PTH]BPSNUM,1,GBIDD1) From TRTACHQTE1
    #----- Coefficient de convertion introuvable ! -----#
    If [F:TCO]UOM1="" & [M:DIA]TRACE=2
      Call ECR_TRACE ([F:PWD]STU-"->"-WGLU-mess(473,199,1),0) From GESECRAN
    Endif
  Endif
  #-----
  [F:PWD]QTYPUU=WQTYGLU
  [F:PWD]PUU   =WGLU
  [F:PWD]QTYSTU=WQTYGLU
  [F:PWD]STU   =WGLU
  [F:PWD]GLU   =WGLU
Else
  [F:PWD]GLU   =[F:PWD]STU
Endif
#----- Chargement zones pour engagement -----#
#If [M:DIA]TYP=1 & [F:PTD]POHNUM<>"" & GOPTCANA>0 & [F:PWD]ACCANA<>""
#-----
WCRIT_CHARGPWD="[M:DIA]TYP=1 & [F:PTD]POHNUM<>'' & GOPTCANA>0 & [F:PWD]ACCANA<>''"
GPOINT="PWDCRIT" : Gosub ENTREE From EXEFNC
If parse(WCRIT_CHARGPWD)
  Call ECR_TRACE("Filter error WCRIT_CHARGPWD",1) From GESECRAN
  WCRIT_CHARGPWD="[M:DIA]TYP=1 & [F:PTD]POHNUM<>'' & GOPTCANA>0 & [F:PWD]ACCANA<>''"
Endif
#-----
If evalue(WCRIT_CHARGPWD)
  If [F:TB1]POHNUM<>[F:PTD]POHNUM |
&    [F:TB1]POPLIN<>[F:PTD]POPLIN |
&    [F:TB1]POQSEQ<>[F:PTD]POQSEQ
    Read [TB1] POQ0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
    If fstat  Raz [F:TB1] : Endif
  Endif
  #-----
  If [F:TB1]CMMNUM<>"" & ([F:TB1]LINCLEFLG<>2 | [F:TB1]RCPCLEFLG=2)
    If [F:PTD]POHTYP<>2
      Read [POP] POP0=[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
      If fstat Raz [F:POP] : Return : Endif
    Else
      Filter [POP] Where POHNUM =[F:PTD]POHNUM
&                      & POPLIN =[F:PTD]POPLIN
&                      & POPDAT>=[F:TB1]DEMRCPDAT
      Read [POP] POP1 First
      Filter [POP]
      If fstat Raz [F:POP] : Return : Endif
    Endif
    # Issue 84173 - 2012-08-31 by SR
    [F:PWD]POPSEQ = [F:POP]POPSEQ
    #----- Calcul de la qté UA ŕ désengager -----#
    CREFLG=0
    CLEFIC=[F:PTD]POHNUM-num$([F:PTD]POPLIN)-num$([F:PTD]POQSEQ)
    WMSG=mess(12,100,1)-"PWRKPOQ"-CLEFIC : # Erreur d'accčs sur le fichier ...
    #----- Lecture fichier de travail détail qtés engagement par commande -----#
    Readlock [PWQ] PWQ0=0;[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
    If fstat=1
      GOK=0 : Gosub AB_TRANSACTION_MSG : Return
    Elsif fstat
      Raz [F:PWQ]
      [F:PWQ]TYPORI  =0              : # Origine FAR
      [F:PWQ]POHNUM  =[F:PTD]POHNUM
      [F:PWQ]POPLIN  =[F:PTD]POPLIN
      [F:PWQ]POQSEQ  =[F:PTD]POQSEQ
      [F:PWQ]EXTOURNE=[M:DIA]EXTOURNE
      CREFLG=1
    Elsif [M:DIA]ACCDAT>=[F:PWQ]EXTOURNE
      Raz [F:PWQ]TMPQTYPUU,[F:PWQ]CMMQTYPUU : [F:PWQ]EXTOURNE=[M:DIA]EXTOURNE : # Par sécurité !
    Endif
    GBIDD1 =[F:TB1]QTYPUU-[F:TB1]INVQTYPUU
    GBIDD1-=([F:PWQ]CMMQTYPUU+[F:PWQ]TMPQTYPUU)
    If [F:TB1]RCPCLEFLG=2 : # Ligne cde soldée par réception
      [F:PWD]QTYBUDLIN=GBIDD1
    Elsif [F:PTD]QTYPUU-[F:PTD]INVQTYPUU<GBIDD1
      [F:PWD]QTYBUDLIN=[F:PTD]QTYPUU-[F:PTD]INVQTYPUU
    Else
      [F:PWD]QTYBUDLIN=GBIDD1
    Endif
    #----- Ajout des qtés facturées postérieures ŕ la date de borne -----#
    [F:PWD]QTYBUDLIN+=(WQUANTITY-([F:PTD]QTYPUU-[F:PTD]INVQTYPUU))
    #-----
    If [F:PWD]QTYBUDLIN<0  Raz [F:PWD]QTYBUDLIN : Endif
    [F:PWQ]TMPQTYPUU+=[F:PWD]QTYBUDLIN
    CLEFIC=[F:PTD]POHNUM-num$([F:PTD]POPLIN)-num$([F:PTD]POQSEQ)
    WMSG=mess(13,100,1)-"PWRKPOQ"-CLEFIC : # Erreur d'écriture sur le fichier ...
    If CREFLG=1  Write [PWQ] Else Rewrite [PWQ] : Endif
    If fstat
      GOK=0 : Call FSTA("PWQ") From GLOCK
      Gosub AB_TRANSACTION_MSG
      Return
    Endif
    If [F:PWD]QTYBUDLIN<>0
      #----- Calcul du montant ŕ désengager -----#
      Case [F:TB1]CMMTAX
        When 2       : #----- Engagement HT + taxes non déductibles
          [F:PWD]AMTCUR=[F:TB1]LINAMT
          # Issue 84911 - 2012-10-03 by MUARN : FAR et TVA non déductible sur achat intracom
          If [F:PTH]VACTYP <> 4
            If [F:TB1]LINATIAMT>[F:TB1]LINAMT
              [F:PWD]AMTCUR+=([F:TB1]AMTTAXLIN1-[F:TB1]DEDTAXLIN1)
              [F:PWD]AMTCUR+=([F:TB1]AMTTAXLIN2-[F:TB1]DEDTAXLIN2)
              [F:PWD]AMTCUR+=([F:TB1]AMTTAXLIN3-[F:TB1]DEDTAXLIN3)
              [F:PWD]AMTCUR+=([F:TB1]AMTTAXRCP -[F:TB1]DEDTAXRCP )
              [F:PWD]AMTCUR+=([F:TB1]AMTTAXISS -[F:TB1]DEDTAXISS )
              [F:PWD]AMTCUR+=([F:TB1]AMTTAXOTH1-[F:TB1]DEDTAXOTH1)
              [F:PWD]AMTCUR+=([F:TB1]AMTTAXOTH2-[F:TB1]DEDTAXOTH2)
            Endif
          Else
            [F:PWD]AMTCUR+=([F:TB1]AMTTAXLIN1-[F:TB1]DEDTAXLIN1)
            [F:PWD]AMTCUR+=([F:TB1]AMTTAXLIN2-[F:TB1]DEDTAXLIN2)
            [F:PWD]AMTCUR+=([F:TB1]AMTTAXLIN3-[F:TB1]DEDTAXLIN3)
            [F:PWD]AMTCUR+=([F:TB1]AMTTAXRCP -[F:TB1]DEDTAXRCP )
            [F:PWD]AMTCUR+=([F:TB1]AMTTAXISS -[F:TB1]DEDTAXISS )
            [F:PWD]AMTCUR+=([F:TB1]AMTTAXOTH1-[F:TB1]DEDTAXOTH1)
            [F:PWD]AMTCUR+=([F:TB1]AMTTAXOTH2-[F:TB1]DEDTAXOTH2)
          Endif
          If [F:TB1]QTYPUU=0 [F:TB1]QTYPUU=1 : Endif
          [F:PWD]AMTCUR=[F:PWD]AMTCUR*[F:PWD]QTYBUDLIN/[F:TB1]QTYPUU
        When 3       : #----- Engagement TTC
          If [F:TB1]QTYPUU=0 [F:TB1]QTYPUU=1 : Endif
          [F:PWD]AMTCUR=[F:TB1]LINATIAMT*[F:PWD]QTYBUDLIN/[F:TB1]QTYPUU
        When Default : #----- Engagement HT
          If [F:TB1]UOMPUUCOE=0  [F:TB1]UOMPUUCOE=1 : Endif
          [F:PWD]AMTCUR=[F:PWD]QTYBUDLIN*[F:POP]NETPRI/[F:TB1]UOMPUUCOE
      Endcase
      Call ARRDEV([F:PWD]AMTCUR,[F:PWD]CUR) From TRTDIV
      #-----
      Raz WMT1
      If [F:TB1]CMMNUM<>""
        #----- Recherche des engagements pour en déduire le taux de conversion -----#
        Raz WMT1, WMT2
        For [CMD] CMD0 Where NUM=[F:TB1]CMMNUM
          WMT1+=[F:CMD]AMTCUR
          WMT2+=[F:CMD]AMTLED
        Next
        If WMT1<>0
          If WMT1<>[F:PWD]AMTCUR
            [F:PWD]AMTLED=[F:PWD]AMTCUR*(WMT2/WMT1)
            Call ARRDEV([F:PWD]AMTLED,WDEVLED) From TRTDIV
          Else
            [F:PWD]AMTLED=WMT2
          Endif
        Endif
      Endif
      If WMT1=0
        #----- Lecture entęte commande si nécessaire -----#
        If [F:TB0]POHNUM<>[F:PTD]POHNUM
          Read [TB0] POH0=[F:PTD]POHNUM
          If fstat  Raz [F:TB0] : Endif
        Endif
        #----- Engagements non trouvés : Conversion avec taux devise -----#
        If WDEVLED<>[F:PWD]CUR
          Call CONVERT([F:PWD]CUR,WDEVLED,GLOCALDEV,[F:TB0]CHGTYP,[F:TB0]ORDDAT,
&                      [F:PWD]AMTCUR,[F:PWD]AMTLED,STAT) From TRTDEV
        Else
          [F:PWD]AMTLED=[F:PWD]AMTCUR
        Endif
      Endif
      If [F:TB1]PUU<>[F:PWD]GLU
        Call PCAL_QTY([F:PWD]QTYBUDLIN,[F:TB1]PUU,WQTYGLU,[F:PWD]GLU,
&                     [F:PTD]ITMREF,[F:PTD]BPSNUM,1,GBIDD1) From TRTACHQTE1
        If [F:TCO]UOM1=""
          Call PCAL_QTY([F:PWD]QTYBUDLIN,[F:TB1]PUU,WQTYGLU,[F:TB1]STU,
&                       [F:PTD]ITMREF,[F:PTD]BPSNUM,1,GBIDD1) From TRTACHQTE1
          If [F:TB1]STU<>[F:PWD]GLU
            Call PCAL_QTY(WQTYGLU,[F:TB1]STU,[F:PWD]QTYBUDLIN,[F:PWD]GLU,
&                         [F:PTD]ITMREF,[F:PTD]BPSNUM,1,GBIDD1) From TRTACHQTE1
            #----- Coefficient de convertion introuvable ! -----#
            If [F:TCO]UOM1="" & [M:DIA]TRACE=2
              Call ECR_TRACE ([F:TB1]STU-"->"-[F:PWD]GLU-mess(473,199,1),0) From GESECRAN
            Endif
          Else
            [F:PWD]QTYBUDLIN=WQTYGLU
          Endif
        Else
          [F:PWD]QTYBUDLIN=WQTYGLU
        Endif
      Endif
    Endif
  Endif
Endif
#----- Ecriture fichier de travail ligne -----#

###################################################################
# Intervenir sur la classe [F:PWD] champs DIE et CCE dimensionnés # JHA
###################################################################
#----- Comptabilité: Cas des FAR Apres report sur enveloppe annuelle -----#
Call BUOENV_SWITCH(1,[F:PTH]CPY,[F:PWD]RCPDAT,[F:PWD]DIE,[F:PWD]CCE,[M:DIA]TRACE) From TRTGDD
#----- Fin intervention Comptabilité - Cas des FAR - JHA 20/10/10 -----#

CLEFIC=num$([F:PWD]PRONUM)-[F:PWD]PTHNUM-num$([F:PWD]PTDLIN)
WMSG=mess(13,100,1)-"PWRKPTD"-CLEFIC : # Erreur d'écriture sur le fichier ...
Write [PWD]
If fstat
  GOK=0 : Call FSTA("PWD") From GLOCK
  Gosub AB_TRANSACTION_MSG
Else
  WECRITURE=1
Endif
Return


#-----------------------------------------#
# Suppression des écritures de simulation #
#-----------------------------------------#
$DEL_SIMULATION
GOK=1 : # Le Call DELPCE est une transaction ŕ part entičre (Trbegin-Commit)
Raz WFLAG
If [M:DIA]XCPYFLG=2
  Filter [HAE1] Where REFSIM="FAR-SS"
Elsif [M:DIA]XFCYFLG=2
  Filter [HAE1] Where REFSIM="FAR-SS" & CPY=[M:DIA]CPY
Else
  If dim([L]WFCY)<1  Local Char WFCY(GLONFCY) : Endif
  [L]WFCY=[M:DIA]RCPFCY
  Read [FCY] FCY0=[M:DIA]RCPFCY : If fstat  Raz [F:FCY] : Endif
  If [F:FCY]FINRSPFCY<>""  [L]WFCY=[F:FCY]FINRSPFCY : Endif
  Filter [HAE1] Where REFSIM="FAR-SS" & CPY=[M:DIA]CPY & FCY=[L]WFCY
Endif
For [HAE1] HAE2
  If [M:DIA]TRACE=2 & WFLAG=0
    Call ECR_TRACE(mess(3,107,1),0) From GESECRAN
  Endif
  WFLAG=1
  CLEFIC=num$([F:HAE1]TYP)-[F:HAE1]NUM
  WMSG=mess(12,100,1)-"GACCENTRY"-CLEFIC : # Erreur d'accčs sur le fichier ...
  Call DELPCE([F:HAE1]TYP,[F:HAE1]NUM) From CPTBATCH
  If GOK<1  Break : Endif
  If [M:DIA]TRACE=2
    Call ECR_TRACE(mess(41,107,1)-[F:HAE1]TYP-[F:HAE1]NUM,0) From GESECRAN
  Endif
  # Issue 64338
  Call DEL_JOURNAL_ENTRY_FR0M_BUDPURAUD([F:HAE1]TYP,[F:HAE1]NUM) From CPTBUD
  If GOK<1
    If [M:DIA]TRACE=2
      Call ECR_TRACE("BUDPURAUD"-mess(1,115,1)-"8"-[F:HAE1]TYP-[F:HAE1]NUM,0) From GESECRAN
    Endif
    Break
  Endif
  # End issue 64338
Next
Filter [HAE1]
If GOK<1 Gosub AB_TRANSACTION_MSG : Endif
If [M:DIA]TRACE=2 & WFLAG<>0
  Call ECR_TRACE(string$(88,"-"),0)  From GESECRAN
Endif
Return


##############################################
#                 Traitement                 #
#  ----------------------------------------  #
#  - Création pičces FAR et extourne FAR     #
#  - Création pičce désengagement            #
#  - Création pičce réengagement             #
#  - Mŕj date et indicateur ligne  réception #
#  - Mŕj date et indicateur entęte réception #
##############################################
$TR1
GOK=1
Trbegin [PTH], [PTD], [PWQ]
  #-------------------------------------#
  # Création pičces FAR et extourne FAR #
  #-------------------------------------#
  COMPTA_CRIT ="PRONUM=adxuid(1)"
  COMPTA_CRIT-="& CPY=GWCPY & PRHFCY=GWPRHFCY & BPSINV=GWBPSINV & CUR=GWCUR"
  If NB_PWH=6
    COMPTA_CRIT-="& PTHNUM=GWPTHNUM"
  Endif
  # Issue X3-122734 - 2019-04-29 by SR : une pičce par ligne ou pičce groupé : aura-t-on un montant ?
  Filter [F:PWH2] Where evalue(COMPTA_CRIT) & AMTNOT > 0
  Read [F:PWH2] PWH0 First
  If !fstat WAMTNOT = [F:PWH2]AMTNOT
  Else Raz WAMTNOT
  Endif
  Filter [F:PWH2]
  # End issue X3-122734
  #----- Chargement des zones pour création pičces FAR et extourne FAR -----#
  WZONE   (1) = "JOU"
  WVALZONE(1) = num$([M:DIA]JOURNAL)
  WZONE   (2) = "ACCDAT"
  WVALZONE(2) = num$(val([M:DIA]ACCDAT))
  WZONE   (3) = "CAT"
  WVALZONE(3) = num$([M:DIA]TYP)
  WZONE   (4) = "TYP"
  WVALZONE(4) = [M:DIA]TYPPCE
  WZONE   (5) = "STA"
  WVALZONE(5) = num$([M:DIA]STA)
  ## Demande de modif 56231
  If [M:DIA]TYP = 1 & func AFNC.PARAM("FRADGI",GWCPY)="2"
   WZONE(5) = "STA" : WVALZONE(5) = num$(2)
  Elsif [M:DIA]TYP <> 1
   WZONE(5) = "STA" : WVALZONE(5) = num$(1)
  Endif
  ## Fin demande 56231

  # DBA le 06/03/03 : type d'échéance (2=facture)
  WZONE   (6) = "TYPDUD"
  WVALZONE(6) = "2"
  If [M:DIA]TYP=1
    #----- Génération réelle -----#
    WZONE   (7) = "RVSDAT"
    WVALZONE(7) = num$(val([M:DIA]EXTOURNE))
    WZONE   (8) = "RVS"
    WVALZONE(8) = "2"
   Else
    #----- Génération simulée (active ou non active) -----#
    WZONE   (7) = "REFSIM"
    WVALZONE(7) = "FAR-SS"
  Endif
# Issue X3-122734 - 2019-04-26 by SR : Si pičce a 0 autorisée, ou si non autorisé mais si montant(groupé ou ligne) <> 0
# SR : Remplacer WSIVNULL par GSIVNULL quand la finance aura résolu le JIRA X3-130908
# SR : A supprimer quand la finance aura résolu le JIRA X3-130908
  WSIVNULL=2
  If WSIVNULL = 1 |  (WSIVNULL = 2 & WAMTNOT <> 0)
    #----- Création pičces FAR et extourne FAR -----#
    GFCYDEF(0)=GFCYDEF(2)
    Raz WMESSAGE
    Call VALPCE4(WPCEAUTO,COMPTA_CRIT,WRETOUR,WMESSAGE,WZONE,WVALZONE) From CPTAUTO
    GFCYDEF(0)=GFCYDEF(6)
    WMSG=" "
    If NB_PWH=6  WMSG+=mess(117,198,1)-GWPTHNUM+" " : Endif
    If WMESSAGE=""
      If [F:PWH1]AMTNOT=0
        WMSG+=mess(62,194,1)-format$("N3:9.2",[F:PWH1]AMTNOT)
      Else
        #----- Pičce automatique xxxxx : Montant 999999,99 non traité -----#
        WMSG-=mess(88,105,1)-WPCEAUTO-":"
        WMSG-=mess(157,154,1)-format$("N3:9.2",[F:PWH1]AMTNOT)-mess(414,177,1)
      Endif
    Else
      WMSG+=WMESSAGE
    Endif
    If WRETOUR | GOK=0 | WMESSAGE=""
      #----- Erreur ŕ la création des pičces (Abandon) -----#
      GOK=0
      Goto AB_TR1
    Elsif GOK=-1
      #----- Conflit d'accčs ŕ la création des pičces (Nouvel essai) -----#
      Goto ROLL_TR1
    Else
      #----- Les pičces ont été créées correctement ! -----#
      If [M:DIA]TRACE=2
        WMSG=mess(16,853,1)+"  : "+ctrans(WMESSAGE,"\"," ")
        Call ECR_TRACE(WMSG,0) From GESECRAN
      Endif
    Endif
    # Issue 91510 - 2013-08-01 by SR
    WFAR = WMESSAGE
  # End issue X3-122734
  Endif
  #-----
  Raz WCMMNUM1, WCMMNUM2, WPSTLINNBR, WFLAG, WPOHFCY, WPARAM
  For [PWH] PWH1 Where evalue(COMPTA_CRIT)
    For [PWD] PWD0 Where PRONUM=adxuid(1) & PTHNUM=[F:PWH]PTHNUM
      # Issue X3-122734 - 2019-04-26 by SR :
      # SR : Remplacer WSIVNULL par GSIVNULL quand la finance aura résolu le JIRA X3-130908
      If WSIVNULL = 1 | [F:PWD]AMTNOTLIN<>0
        #-------------------------------------------------------------#
        # Création pičces désengagement et réengagement si nécessaire #
        #-------------------------------------------------------------#
        If WPOHFCY="" | WPOHFCY<>[F:PWD]POHFCY
          Call PARAM([F:PWD]POHFCY,"PURCMM",WPARAM) From ADOVAL
          WPOHFCY=[F:PWD]POHFCY
        Endif
        If ([F:PWD]QTYBUDLIN<>0 | [F:PWD]AMTCUR<>0) & val(WPARAM)=2
          Call GETDEV([F:PWD]POHFCY) From DEVSUB
          If GFINRSP="" GFINRSP=[F:PWD]POHFCY : Endif
          #----- Chargement codes axes et sections analytiques -----#
          For I=1 To GOPTCANA
            TBDIE(I)=[F:PWD]DIE(I-1)
            TBCCE(I)=[F:PWD]CCE(I-1)
          Next I
          #----- Filtrage des codes et sections analytiques sur référentiel analytique -----#
          #             On ne filtre plus ŕ partir de la version Béryl 6.1 !                #
          #---------------------------------------------------------------------------------#
          #Call SETCCEAXE(GSOCIETE,GTYPANA,TBDIE,TBCCE,TBDIE2,TBCCE2) From CPTDIV
          #-----
          ID2(1)=[F:PWD]POHNUM       : WDOCUMENT(1)=[F:PWD]POHNUM
          ID2(2)=num$([F:PWD]POPLIN) : WDOCUMENT(2)=num$([F:PWD]POPLIN)
          # Issue 84173 - 2012-08-31 by SR
  #        ID2(3)=num$([F:PWD]POQSEQ) : WDOCUMENT(3)=num$([F:PWD]POQSEQ)
          ID2(3)=num$([F:PWD]POPSEQ) : WDOCUMENT(3)=num$([F:PWD]POPSEQ)
          # Issue 84939 - 2013-02-01 by MUARN : ajout n° seq commande
          ID2(4)=num$([F:PWD]POQSEQ) : WDOCUMENT(4)=num$([F:PWD]POQSEQ)

          If [F:TB1]POHNUM<>[F:PWD]POHNUM |
&          [F:TB1]POPLIN<>[F:PWD]POPLIN |
&          [F:TB1]POQSEQ<>[F:PWD]POQSEQ
            Read [TB1] POQ0=[F:PWD]POHNUM;[F:PWD]POPLIN;[F:PWD]POQSEQ
            If fstat Raz [F:TB1] : Endif
          Endif
          If [F:PWD]POHTYP=2  TYPORG=2 Else  TYPORG=1 : Endif
          #----- Récupération du numéro d'engagement de la ligne de commande -----#
          WCMMNUM1=[F:TB1]CMMNUM
          WCMMNUM2=[F:TB1]CMMNUM
          #----- Chargement des motifs -----#
          WMOTIF(1)=1 : # Création
          WMOTIF(2)=4 : # FAR
          #----- Création pičce de désengagement ŕ date comptable -----#
          WOK_MAJENG=1 : WTYPMAJ=1 : Gosub POINT_MAJENG From TRTACHCDE1
          #-----
          If WOK_MAJENG
  #         Call MAJENGOLD([M:DIA]ACCDAT,GFINRSP,[F:PWD]CUR,[F:PWD]AMTCUR,[F:PWD]CURLEDANA,
  #&                    [F:PWD]AMTLED,[F:PWD]QTYBUDLIN,[F:PWD]ACCANA,[F:PWH]BPSNUM,
  #&                    TBDIE2,TBCCE2,1,-1,2,0,WCMMNUM1,[F:PWD]POHNUM,
  #&                    OK,WMESSAGE,"PORD",ID2,"","",TYPORG,[F:PWH]CHGTYP) From CPTENG
            #-----
            If WTEST  GBIDI2=1 : Gosub TRACE_MAJENG : Endif
            #----- Nouvel appel Béryl 6.1 -----#
            Call MAJENG([M:DIA]ACCDAT,GFINRSP,[F:PWD]CUR,[F:PWD]AMTCUR,[F:PWD]RATDIV,
&                     [F:PWD]RATMLT,[F:PWD]QTYBUDLIN,[F:PWD]LINACC,[F:PWD]LED,[F:PWH]BPSNUM,
&                     TBDIE,TBCCE,1,-1,2,0,WCMMNUM1,WDOCUMENT,WMOTIF,
&                     OK,WMESSAGE,"PORD",ID2,"","",TYPORG,[F:PWH]CHGTYP) From CPTENG
            WMSG=mess(117,198,1)-GWPTHNUM-num$([F:PWD]PTDLIN)-WMESSAGE
            If OK<>1 | GOK=0
              #----- Erreur ŕ la création du désengagement (Abandon) -----#
              GOK=0 : Break 2
            Elsif GOK=-1
              #----- Conflit d'accčs ŕ la création du désengagement (Nouvel essai) -----#
              Break 2
            Endif
          Endif
          #----- Chargement des motifs -----#
          WMOTIF(1)=5 : # Extourne
          WMOTIF(2)=4 : # FAR
          #----- Création pičce de réengagement ŕ date d'extourne -----#
          WOK_MAJENG=1 : WTYPMAJ=2 : Gosub POINT_MAJENG From TRTACHCDE1
          #-----
          If WOK_MAJENG
  #         Call MAJENG([M:DIA]EXTOURNE,GFINRSP,[F:PWD]CUR,[F:PWD]AMTCUR,[F:PWD]CURLEDANA,
  #&                    [F:PWD]AMTLED,[F:PWD]QTYBUDLIN,[F:PWD]ACCANA,[F:PWH]BPSNUM,
  #&                    TBDIE2,TBCCE2,1,+1,2,0,WCMMNUM2,[F:PWD]POHNUM,
  #&                    OK,WMESSAGE,"PORD",ID2,"","",TYPORG,[F:PWH]CHGTYP) From CPTENG
            #-----
            If WTEST  GBIDI2=2 : Gosub TRACE_MAJENG : Endif
            #----- Nouvel appel Béryl 6.1 -----#
            Call MAJENG([M:DIA]EXTOURNE,GFINRSP,[F:PWD]CUR,[F:PWD]AMTCUR,[F:PWD]RATDIV,
&                     [F:PWD]RATMLT,[F:PWD]QTYBUDLIN,[F:PWD]LINACC,[F:PWD]LED,[F:PWH]BPSNUM,
&                     TBDIE,TBCCE,1,+1,2,0,WCMMNUM2,WDOCUMENT,WMOTIF,
&                     OK,WMESSAGE,"PORD",ID2,"","",TYPORG,[F:PWH]CHGTYP) From CPTENG
            WMSG=mess(117,198,1)-GWPTHNUM-num$([F:PWD]PTDLIN)-WMESSAGE
            If OK<>1 | GOK=0
              #----- Erreur ŕ la création du réengagement (Abandon) -----#
              GOK=0 : Break 2
            Elsif GOK=-1
              #----- Conflit d'accčs ŕ la création du réengagement (Nouvel essai) -----#
              Break 2
            Endif
          Endif
          #----- Ecriture trace désengagement/réengagement -----#
          # Issue X3-122734 - 2019-05-15 by SR : why only for the first line ?
          #If [M:DIA]TRACE=2 & WFLAG=0 & (WCMMNUM1<>"" | WCMMNUM2<>"")
          If [M:DIA]TRACE=2 & (WCMMNUM1<>"" | WCMMNUM2<>"")
            WMSG=""
            If WCMMNUM1<>""  WMSG+=mess(64,106,1)-mess(2,631,1)-":"-WCMMNUM1 : Endif
            If WCMMNUM2<>""  WMSG+=" "+mess(461,197,1)+"    : "+WCMMNUM2     : Endif
            Call ECR_TRACE(WMSG,0) From GESECRAN
          Endif
          # Issue X3-122734 - 2019-05-15 by SR : No needed
          #WFLAG=1
        Endif
        #----- Ecriture de la trace ligne réception traitée -----#
        # Issue X3-122734 - 2019-05-03 by SR : comment
        #If [M:DIA]TRACE=2 & (WMESSAGE<>"" | [F:PWD]AMTNOTLIN<>0)
        If [M:DIA]TRACE=2
          If [F:TCU]CUR<>[F:PWD]CUR
            Read [TCU] TCU0=[F:PWD]CUR
            If fstat [F:TCU]CURFMT1="9.2" : Endif
          Endif
          WMSG ="  "+mess(117,198,1)-[F:PWD]PTHNUM+space$(GLONPTH+1-len([F:PWD]PTHNUM))
          WMSG+=mess(80,197,1)-[F:PWD]ITMREF+space$(GLONITM+1-len([F:PWD]ITMREF))
          WMSG+=[F:PWD]CUR+space$(GLONCUR+1-len([F:PWD]CUR))
          WMSG+=format$("N3:"+[F:TCU]CURFMT1,[F:PWD]AMTNOTLIN)-mess(1,243,1)
          Call ECR_TRACE(WMSG,0) From GESECRAN

          # Issue 83148 - 2012-08-23 by MUARN : ajout quantité et prix unitaire dans la trace
          #---------------------------------------------------------#
          # Point d'entrée ADDTRAFAR                                #
          # ------------------------------------------------------- #
          # ------------------------------------------------------- #
          # Variables utilisables par le point d'entrée :           #
          # aucune                                                  #
          # ------------------------------------------------------- #
          # Variable modifiable par le point d'entrée :             #
          # WMSG pour ecriture dans la trace                        #
          #---------------------------------------------------------#
          Raz WMSG
          [V]GPOINT="ADDTRAFAR" : Gosub ENTREE From EXEFNC
          If GOK<1  Break 2 : Endif

        Endif
      # Issue X3-122734 - 2019-04-26 by SR
      Else
        #----- Ecriture de la trace ligne réception prix = 0 considérée comme comptabilisée -----#
        If [M:DIA]TRACE=2
          If [F:TCU]CUR<>[F:PWD]CUR
            Read [TCU] TCU0=[F:PWD]CUR
            If fstat [F:TCU]CURFMT1="9.2" : Endif
          Endif
          WMSG ="  "+mess(117,198,1)-[F:PWD]PTHNUM+space$(GLONPTH+1-len([F:PWD]PTHNUM))
          WMSG+=mess(80,197,1)-[F:PWD]ITMREF+space$(GLONITM+1-len([F:PWD]ITMREF))
          WMSG+=[F:PWD]CUR+space$(GLONCUR+1-len([F:PWD]CUR))
          WMSG+=format$("N3:"+[F:TCU]CURFMT1,[F:PWD]AMTNOTLIN)-mess(1,243,1)
          Call ECR_TRACE(WMSG,0) From GESECRAN
          WMSG="  "+mess(912,197,1)
          Call ECR_TRACE(WMSG,0) From GESECRAN
        Endif
      Endif
      # End issue X3-122734
      #--------------------------------------------------#
      # Mise ŕ jour ligne réception si génération réelle #
      #--------------------------------------------------#
      If [M:DIA]TYP=1
        CLEFIC=[F:PWD]PTHNUM-num$([F:PWD]PTDLIN)
        WMSG=mess(12,100,1)-"PRECEIPTD"-CLEFIC : # Erreur d'accčs sur le fichier ...
        Readlock [PTD] PTD0=[F:PWD]PTHNUM;[F:PWD]PTDLIN
        If fstat=1
          GOK=-1 : GLOCK="$PRECEIPTD"-CLEFIC          : Break 2
        Elsif fstat
          GOK=0  : Call RSTA("PTD",CLEFIC) From GLOCK : Break 2
        Endif
        If [F:PTD]LINPSTFLG<>2  WPSTLINNBR+=1 : Endif
        [F:PTD]LINPSTFLG=2
        [F:PTD]LINPSTDAT=[M:DIA]EXTOURNE
        # Issue 91510 - 2013-08-01 by SR : Point d'entrée permettant de mettre ŕ jour des zones spécifiques
        #------------------------------------------------------------------#
        # Point d'entrée MAJPTD pour alimentation de zones spécifiques     #
        # ---------------------------------------------------------------- #
        # Variables utilisables par le point d'entrée                      #
        # Les classes [F:PWD], [F:PTD] sont disponibles                    #
        # La variable WFAR contient le numéro de FAR                       #
        # La  classe  [F:PTD] est modifiable avant le Write                #
        #------------------------------------------------------------------#
        [V]GPOINT="MAJPTD" : Gosub ENTREE From EXEFNC
        If GOK<1  Break 2 : Endif
        #
        Rewrite [PTD]
        If fstat  GOK=0 : Call FSTA("PTD") From GLOCK : Break 2 : Endif
        #----- Mise ŕ jour fichier de travail détail qtés engagement par commande -----#
        If [F:PTD]POHNUM<>""
          CLEFIC="0"-[F:PTD]POHNUM-num$([F:PTD]POPLIN)-num$([F:PTD]POQSEQ)
          WMSG=mess(12,100,1)-"PWRKPOQ"-CLEFIC : # Erreur d'accčs sur le fichier ...
          Readlock [PWQ] PWQ0=0;[F:PTD]POHNUM;[F:PTD]POPLIN;[F:PTD]POQSEQ
          If !fstat
            [F:PWQ]TMPQTYPUU-=[F:PWD]QTYBUDLIN
            [F:PWQ]CMMQTYPUU+=[F:PWD]QTYBUDLIN
            Rewrite [PWQ]
            If fstat  GOK=0 : Call FSTA("PWQ") From GLOCK : Break 2 : Endif
          Endif
        Endif
        #-----
      Endif
    Next
    #----- Cumul des montants HT et TTC en devise société -----#
    If GLOCALDEV<>[F:PWD]CUR
      Call CONVERT([F:PWH]CUR,GLOCALDEV,GLOCALDEV,evalue(WCHGTYPA),[M:DIA]ACCDAT,
&                  [F:PWH]AMTNOT,GBIDD1,STAT) From TRTDEV
      WMONTHT +=GBIDD1
      Call CONVERT([F:PWH]CUR,GLOCALDEV,GLOCALDEV,evalue(WCHGTYPA),[M:DIA]ACCDAT,
&                  [F:PWH]AMTATI,GBIDD1,STAT) From TRTDEV
      WMONTTTC+=GBIDD1
    Else
      WMONTHT +=[F:PWH]AMTNOT
      WMONTTTC+=[F:PWH]AMTATI
    Endif
    #---------------------------------------------------#
    # Mise ŕ jour entęte réception si génération réelle #
    #---------------------------------------------------#
    If [M:DIA]TYP=1
      CLEFIC=[F:PWH]PTHNUM
      WMSG=mess(12,100,1)-"PRECEIPT"-CLEFIC : # Erreur d'accčs sur le fichier ...
      Readlock [PTH] PTH0=[F:PWH]PTHNUM
      If fstat=1
        GOK=-1 : GLOCK="$PRECEIPT"-CLEFIC           : Break
      Elsif fstat
        GOK=0  : Call RSTA("PTH",CLEFIC) From GLOCK : Break
      Endif
      [F:PTH]PSTLINNBR+=WPSTLINNBR : Raz WPSTLINNBR
      If [F:PTH]PSTLINNBR>=[F:PTH]LINNBR
        [F:PTH]PSTFLG=2 : [F:PTH]PSTDAT=[M:DIA]EXTOURNE
      Endif
      Rewrite [PTH]
      #----- Déverrou réception -----#
      SYMBOL2="PTH"+[F:PTH]PTHNUM
      Unlock=SYMBOL2
      #-----
      If fstat  GOK=0 : Call FSTA("PTH") From GLOCK : Break : Endif
    Endif
  Next
  If GOK=-1 Goto ROLL_TR1 : Endif
  If GOK=0  Goto AB_TR1   : Endif
Commit
Return

#------------------------------------------------------#
# Nouvel essai de transaction ou abandon suivant GROLL #
#------------------------------------------------------#
$ROLL_TR1
Rollback
Call ROLL From GLOCK
If !GROLL
  Goto TR1
Else
  Gosub AB_TRANSACTION_MSG
  Return
Endif

#---------------------------#
# Abandon de la transaction #
#---------------------------#
$AB_TR1
Rollback
Gosub AB_TRANSACTION_MSG
Return


#---------------------------------------------#
# Messages en cas d'abandon de la transaction #
#---------------------------------------------#
$AB_TRANSACTION_MSG
If [M:DIA]TRACE=2
  If WMSG<>"" Call ECR_TRACE(WMSG,1) From GESECRAN : Endif
Endif
Raz WMSG
Return


#--------------------------------------------------#
# Cumul des montants HT et TTC par société et site #
#--------------------------------------------------#
$CUMUL_RECAP
If J=0 CPYFCY(J)=GWCPY+space$(GLONCPY-len(GWCPY)) : J+=1 : Endif
If J<dim(CPYFCY)
  CPYFCY  (J) =GWCPY+space$(GLONCPY-len(GWCPY))+GWPRHFCY+space$(GLONFCY-len(GWPRHFCY))
  CUMULHT (J) =WMONTHT
  CUMULTTC(J) =WMONTTTC
  I=find(GWCPY+space$(GLONCPY-len(GWCPY)),CPYFCY(0..J-1))-1
  CUMULHT (I)+=WMONTHT
  CUMULTTC(I)+=WMONTTTC
  J+=1
  If GWCPY<>[F:PWH1]CPY & [F:PWH1]CPY<>"" & J<dim(CPYFCY)
    CPYFCY(J)=[F:PWH1]CPY+space$(GLONCPY-len([F:PWH1]CPY)) : J+=1
  Endif
Endif
Raz WMONTHT, WMONTTTC
Return


#---------------------------------------------------------#
# Ouverture des fichiers et déclaration variables locales #
#---------------------------------------------------------#
$OUVRE
#----- Variables locales -----#
Local  Libelle  WTEST : WTEST=0 : # Mettre WTEST=1 pour trace détaillée du Call MAJENG
Local  Char     WVACBPR(GLONTVB)
