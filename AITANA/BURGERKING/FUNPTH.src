Local  Date     DAT
Local  Decimal  EXERCICE, PERIODE, WMT1, WMT2, WMT3
Local  Char     WCMMNUM1(GLONVCR), WCMMNUM2(GLONVCR)
Local  Shortint WPSTLINNBR
Local  Char     CPYFCY(GLONCPY+GLONFCY)(300)
Local  Decimal  CUMULHT  (300)
Local  Decimal  CUMULTTC (300)
Local  Shortint J
Local  Char     WCHGTYPA(80)
Local  Char     WPCEAUTO(GLONGAU)
Local  Char     WPOHFCY(GLONFCY), WPARAM(10)
Local  Decimal  WCLCAMT(1..7)
# Issue 84939 - 2013-02-01 by MUARN : ajout n° seq commande
Local  Char     WDOCUMENT(GLONPOH)(1..4)
Local  Libelle  WMOTIF(1..2)
# Issue 115551 - 2016-04-07 by SR : Lock société
Local  Integer     WOKLOCK
Global Char     GWCPY(GLONCPY), GWPTHNUM(GLONPTH)
# Issue X3-122734 - 2019-04-26 by SR
Local  Decimal  WAMTNOT
# SR : A supprimer quand la finance aura résolu le JIRA X3-130908
Local  Integer  WSIVNULL
# End issue X3-122734
#----- Ouverture des fichiers -----#
If clalev([F:BPS])=0  : Local File BPSUPPLIER  [BPS] : Endif
If clalev([F:BPR])=0  : Local File BPARTNER    [BPR] : Endif
