#<AdxTL>@(#)0.0.0.0 $Revision$
#Y017 monitor de operaciones de E/S con ficheros con XRT
#Y017 ficheros de salida leemos de ZEXPFIC (graba el ZEXPCONCIL)
#Y017 ficheros de entrada
#########################################################################
Local Char PARAM(20)(1..2)
Call GCONSULT("YMNT","",PARAM) From GCONSULT
End
#############################################################
$ACTION
Case ACTION
  When "AUTORIS"    : Gosub AUTORIS
  When "OUVRE"      : Gosub OUVRE
  When "LECTURE"    : Gosub LECTURE
  When "FERME"      : Gosub FERME
  When "FIN_CRIT"   : Gosub FIN_CRIT
  When "TRT_DIV"    : Gosub TRT_DIV
 When Default
Endcase
Return
#############################################################
$AUTORIS
Gosub AUTORIS From YCONSMNTSTD1
Return
#############################################################
$FERME
Gosub FERME   From YCONSMNTSTD1
Return
####################################################################
$OUVRE

Gosub OUVRE   From YCONSMNTSTD1

Return

#############################################################
$LECTURE
Gosub LECTURE From YCONSMNTSTD1
#POSIBILIDA DE AčADIR FILTRO EN ACION "FILTER" DESDE EL TRT ESPECIFICO
Return

############################################################################################
$TRT_DIV
Gosub TRT_DIV From YCONSMNTSTD1

Return
############################################################################################
$FIN_CRIT
Gosub FIN_CRIT From YCONSMNTSTD1
Return

