#<AdxTL>@(#)0.0.0.0 $Revision$
If !clalev([F:TB1]) : Local File BPSINVLIG [TB1] : Endif
If !clalev([F:TB0]) : Local File PINVOICE [TB0] : Endif
Local Decimal AMTSVC
Local Integer STAT
Local Date FECHA
Read [F:TB0]PIH0='FAS200020-036412'
Filter [F:TB1] Where NUM='FAS200020-036412'
FECHA = [30/09/2020]
For [F:TB1]
Call AMTSVC(FECHA,1,0,AMTSVC,STAT)
Infbox num$(AMTSVC)
Next
End

Subprog AMTSVC(DAT,TYPAMT,LEDTYP,AMTSVC,STAT)
Value    Date    DAT()
Value    Integer TYPAMT
Value    Integer LEDTYP
Variable Decimal AMTSVC
Variable Integer STAT
Local Char    CODLED(GLONLED), DEVLED(GLONCUR)
Local Decimal AMTLIN, BASE
Local Decimal COURS, ARRODEV
Raz AMTLIN
If clalev([F:TCU])=0  : Local File TABCUR  [TCU]  : Endif : # Cours devises
If clalev([F:CPY])=0  : Local File COMPANY [CPY]  : Endif : # Sociťtťs
Call LECTURE("TCU",[F:TB0]CUR,"") From CONTOBJ
ARRODEV = [F:TCU]CURRND

# Demande de prise en compte de la TVA non dťductible
If dim([F:TB1]AMTVAT)>0 & dim([F:TB1]DEDVAT)>0 : # Factures tiers Fournisseurs
 [L]BASE = [F:TB1]AMTNOTLIN+([F:TB1]AMTVAT-[F:TB1]DEDVAT)
Elsif dim([F:TB1]AMTTAXLIN1)>0 & dim([F:TB1]DEDTAXLIN1)>0 : # Factures d'achats
 [L]BASE = [F:TB1]AMTNOTLIN+[F:TB1]AMTTAXLIN1-[F:TB1]DEDTAXLIN1
Else
 [L]BASE = [F:TB1]AMTNOTLIN
Endif
#

Call LECTURE("CPY",[F:TB0]CPY,"") From CONTOBJ
Case TYPAMT
 When 1
  [L]AMTLIN = [L]BASE
 When 2
  Call LECLED([F:TB0]CPY,LEDTYP,CODLED,DEVLED) From CPTDIV
  If CODLED<>"" & [F:TB0]CUR<>[L]CODLED
   If [F:TB0]RATDIV(LEDTYP-1)=1
    COURS  = [F:TB0]RATMLT(LEDTYP-1)
   Else
    COURS  = [F:TB0]RATMLT(LEDTYP-1)/[F:TB0]RATDIV(LEDTYP-1)
   Endif
   If COURS<>0
    Call CONVERT3([F:TB0]CUR,DEVLED,DEVLED,[F:TB0]CURTYP,[F:TB0]ACCDAT,[L]BASE,[L]AMTLIN,[L]COURS,STAT) From CPTSUB
    If STAT : End : Endif
   Endif
  Endif
Endcase
If AMTLIN<>0
 If [L]DAT<[F:TB1]STRDAT
  AMTSVC = [L]AMTLIN
 Elsif [L]DAT>=[F:TB1]STRDAT & [L]DAT<=[F:TB1]ENDDAT
  AMTSVC = arr(([L]AMTLIN*([L]DAT-[F:TB1]ENDDAT))/([F:TB1]ENDDAT-[F:TB1]STRDAT+1),ARRODEV)
 Endif
 AMTSVC = abs(AMTSVC)*sgn(AMTLIN)
Endif
End

