#<AdxTL>@(#)0.0.0.0 $Revision$
################################################################################################################
# Y015 Recepciones que vienen de pedido
# Y015 pedido tiene un contrato
# Y015 contrato es periódico y no es mensual
# Y015 y que la fecha de inicio de servicio sea mayor que la fecha de provisión
# Y015 SALIDA: devuelve 1
################################################################################################################

Funprog INISERVMAYOR(PTHNUM)
Value Char PTHNUM

Local Integer INISERVMAYOR : Raz INISERVMAYOR

If clalev([F:YPOH])=0 Local File PORDER    [YPOH] : Endif
If clalev([F:YPTH])=0 Local File PRECEIPT  [YPTH] : Endif
If clalev([F:YPTD])=0 Local File PRECEIPTD [YPTD] : Endif
If clalev([F:YCO])=0  Local File YCONTRATO [YCO]  : Endif

Read [F:YPTH]PTH0 = PTHNUM


Filter [F:YPTD] Where [F:YPTD]PTHNUM = [F:YPTH]PTHNUM
For [F:YPTD]
  Break 1
Next
Filter [F:YPTD]

If [F:YPTD]POHNUM<> ''
  Read [F:YPOH]POH0 = [F:YPTD]POHNUM
  If fstat = 0
    If [F:YPOH]YCONNUM<> ''
      Read [F:YCO]YCO0 = [F:YPOH]YCONNUM
      If fstat = 0
        If [F:YCO]YRECUR = 2 and [F:YCO]YPERIODO <> 1
          If [F:YPTH]STRDATSVC > [M:DIA]ACCDAT
            INISERVMAYOR=1
          Endif
        Endif
      Endif
    Endif
  Endif
Endif


End INISERVMAYOR

###############################################################################################################
# Y015 Recepciones que vienen de pedido
# Y015 pedido tiene un contrato
# Y015 contrato es periódico y no es mensual
# Y015
# Y015 la fecha de inicio de servicio es mayor que la fecha de provisión
# Y015 SALIDA : importe completo
# Y015 la fecha de inicio de servicio es menor que la fecha de provisión
# YP15 SALIDA: importe=importe*(Fecha provisión-fecha ini. servicio)/Fecha fin. ser-Fec. ini.servicio)
################################################################################################################

Funprog IMPORTE (PTHNUM,AMTNOTLIN)
Value Char    PTHNUM
Value Decimal AMTNOTLIN

Local Decimal IMPORTE : IMPORTE=AMTNOTLIN

If clalev([F:YPOH])=0 Local File PORDER    [YPOH] : Endif
If clalev([F:YPTH])=0 Local File PRECEIPT  [YPTH] : Endif
If clalev([F:YPTD])=0 Local File PRECEIPTD [YPTD] : Endif
If clalev([F:YCO])=0  Local File YCONTRATO [YCO]  : Endif

Read [F:YPTH]PTH0 = PTHNUM


Filter [F:YPTD] Where [F:YPTD]PTHNUM = [F:YPTH]PTHNUM
For [F:YPTD]
  Break 1
Next
Filter [F:YPTD]

If [F:YPTD]POHNUM<> ''
  Read [F:YPOH]POH0 = [F:YPTD]POHNUM
  If fstat = 0
    If [F:YPOH]YCONNUM<> ''
      Read [F:YCO]YCO0 = [F:YPOH]YCONNUM
      If fstat = 0
        If [F:YCO]YRECUR = 2 and [F:YCO]YPERIODO <> 1
          If [F:YPTH]STRDATSVC > [M:DIA]ACCDAT
            IMPORTE = AMTNOTLIN
          Else
            If ([F:YPTH]ENDDATSVC-[F:YPTH]STRDATSVC)>0
              IMPORTE = ar2(AMTNOTLIN*([M:DIA]ACCDAT-[F:YPTH]STRDATSVC)/([F:YPTH]ENDDATSVC-[F:YPTH]STRDATSVC))
              If IMPORTE > AMTNOTLIN
                IMPORTE = AMTNOTLIN
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif
Endif

End IMPORTE

