#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
Endcase
Return
#############################################################
$AUTORIS
Return
#############################################################
$FERME
Return
####################################################################
## analyse paramŤres, initialisations, ouvertures et dťclarations  #
####################################################################
$OUVRE

#Tabla temporal de monitor
If !clalev ([F:YTMO]) : Local File YTMPMONITOR [YTMO] : Endif

#Tabla de movimientos de conciliaciůn
If !clalev ([F:YZEF])  : Local File ZEXPFIC    [YZEF] : Endif

#Tabla de movimientos de entrada

If !clalev ([F:YZIF])  : Local File ZIMPFIC    [YZIF] : Endif



Local Char    WFIL(250),WFIL1(250),WFIL2(250)
Local Char    WFIL3(250),WFIL4(250),WFIL5(250)
Local Char    WFIL6(250),WFIL7(250),WFIL8(250)
Local Integer WSEGUNDA : Raz WSEGUNDA


Gosub DEFCRIT

Return
#########################################################
$DEFCRIT

[M:YCMNT0]YCPY  = GDEFSOC
[M:YCMNT0]YTIPOINI = 'CONC'
[M:YCMNT0]YTIPOFIN = 'PDOM'
[M:YCMNT0]YSTATUSINI = 1
[M:YCMNT0]YSTATUSFIN = 4
[M:YCMNT0]YDATINI= date$
[M:YCMNT0]YDATFIN= date$


# -- copie de l'ťcran critŤres vers le masque 1
#Gosub CRITENT From =PROGCNS


Return
#############################################################
$LECTURE
Local   Decimal  WMNTORG(0..5), WMNTDES(0..5)
Local   Integer  SPSTAT



If WSEGUNDA >0
  Gosub CHANGE_MSK From GCONSULT
  If CHGPAG<0 : NOL = MAXLIG : Endif
  #-- Positionnement des Filtres
  Gosub LOAD_FILTER
  If PROGSPE<>""
   ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
  Endif
  Gosub BORRAR_INTERMEDIA
  Gosub CARGA_TABLA_INTERMEDIA


  If CHGPAG > 0
      SUITE=1
      If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
      Filter [F:YTMO] Where [F:YTMO]PRONUM = adxuid(1)  Order By [F:YTMO]YFECHAOP;[F:YTMO]YHORAOP
  Else
      RETOUR=1
      If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
      Filter [F:YTMO] Where [F:YTMO]PRONUM = adxuid(1)  Order By  [F:YTMO]YFECHAOP;[F:YTMO]YHORAOP
  Endif

  If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:YCMNT1] : Endif
  $BOUCLE

    For [F:YTMO]
      If NBLU = 1
         If CHGPAG=2 | CHGPAG=-2 : Raz [M:YCMNT1] : Endif
         NBLU = 2
      Endif
      If CHGPAG > 0
         If NOL >= MAXLIG-1 : SUITE=2 : Break : Endif
         NOL    += 1
         If NOL=0
             DEBNUM = [F:YTMO]YNUMREG
         Endif
         FINNUM = [F:YTMO]YNUMREG
      Else
         If NOL <= 0 : RETOUR=2 : Break : Endif
         NOL    -= 1
         If NOL=MAXLIG-1
             FINNUM = [F:YTMO]YNUMREG
         Endif
         DEBNUM = [F:YTMO]YNUMREG
      Endif
      Case CHGPAG
          When 3 : # rafraichissement
              WFIL += "&([F:YTMO]YNUMREG>=DEBNUM))"
          When 2 : # suite
              WFIL += "&([F:YTMO]YNUMREG>FINNUM)"
          When -2 : # retour
              WFIL += "(&[F:YTMO]YNUMREG<DEBNUM)"
      Endcase
      nolign = NOL+1
      #CAMPOS
      [M:YCMNT1]YNUMREG(nolign-1)       = [F:YTMO]YNUMREG
      [M:YCMNT1]YFECHAOP(nolign-1)      = [F:YTMO]YFECHAOP
      [M:YCMNT1]YHORAOP(nolign-1)       = [F:YTMO]YHORAOP
      [M:YCMNT1]YTIPOFICHERO(nolign-1)  = [F:YTMO]YTIPOFICHERO
      [M:YCMNT1]YNOMFICX3(nolign-1)     = [F:YTMO]YNOMFICX3
      [M:YCMNT1]YNUMLINX3(nolign-1)     = [F:YTMO]YNUMLINX3
      [M:YCMNT1]YNUMLINEXT(nolign-1)    = [F:YTMO]YNUMLINEXT
      [M:YCMNT1]YSTATUS(nolign-1)       = [F:YTMO]YSTATUS
      [M:YCMNT1]YPATH(nolign-1)         = [F:YTMO]YPATH
    Next
    Filter [F:YTMO]
Endif


WSEGUNDA = 1


Return
####################################################################################
$BORRAR_INTERMEDIA

#Borramos toda la informaciůn temporal que sea de ese usuario y de otro proceso
Trbegin [F:YTMO]
   Delete [F:YTMO] Where [F:YTMO]CREUSR= GUSER
Commit

Raz [M:YCMNT1]
Return

####################################################################################
$CARGA_TABLA_INTERMEDIA


Local Integer NUMREG : Raz NUMREG

Trbegin [F:YTMO]

Gosub CARGAR_SALIDAS From YCONSMNTSTD1S

Gosub CARGAR_ENTRADAS From YCONSMNTSTD1E


Commit


Return
####################################################################################
$LOAD_FILTER
WFIL  = "1=1"
WFIL1 = "1=1"
WFIL2 = "1=1"
WFIL3 = "1=1"
WFIL4 = "1=1"

#Salidas

#Sociedad
If [M:YCMNT0]YCPY<> ""
  WFIL1 +="&[F:YZEF]ZCPY=[M:YCMNT0]YCPY"
Endif


#Tipo de fichero
If [M:YCMNT0]YTIPOINI<> ''
  WFIL1 +="&[F:YZEF]YTIPOFICHERO>=[M:YCMNT0]YTIPOINI"
Endif

If [M:YCMNT0]YTIPOFIN <> ''
  WFIL1 += "&[F:YZEF]YTIPOFICHERO<=[M:YCMNT0]YTIPOFIN"
Endif

#Fecha operaciůn
If [M:YCMNT0]YDATINI <> [0/0/0]
   WFIL1 += "&[F:YZEF]ZFECPROD>=[M:YCMNT0]YDATINI"
Endif
If [M:YCMNT0]YDATFIN <> [0/0/0]
   WFIL1 += "&[F:YZEF]ZFECPROD<=[M:YCMNT0]YDATFIN"
Endif

If [M:YCMNT0]YHORINI <> ""
   WFIL2 += "&[F:YZEF]ZHORPROD>=[M:YCMNT0]YHORINI"
Endif
If [M:YCMNT0]YHORFIN <> ""
   WFIL2 += "&[F:YZEF]ZHORPROD<=[M:YCMNT0]YHORFIN"
Endif

#Entradas

If [M:YCMNT0]YDATINI <> [0/0/0]
   WFIL3 += "&[F:YZIF]ZFECPROD>=[M:YCMNT0]YDATINI"
Endif
If [M:YCMNT0]YDATFIN <> [0/0/0]
   WFIL3 += "&[F:YZIF]ZFECPROD<=[M:YCMNT0]YDATFIN"
Endif

If [M:YCMNT0]YHORINI <> ""
   WFIL4 += "& mid$([F:YZIF]ZIDGES,10,6)>=[M:YCMNT0]YHORINI"
Endif
If [M:YCMNT0]YHORFIN <> ""
   WFIL4 += "& mid$([F:YZIF]ZIDGES,10,6)<=[M:YCMNT0]YHORFIN"
Endif

Return
############################################################################################
$TRT_DIV
Case TRAIT

Endcase
Return
############################################################################################

$FIN_CRIT

Return

