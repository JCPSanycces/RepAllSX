#<AdxTL>@(#)0.0.0.0 $Revision$
#####################################################################################
#Acciones a realizar desde la línea
# Bajar archivo : bajar archivo a puesto cliente para que lo puedan modificar
# Reemplazar archivo: subir archivo a servidor
# Reprocesar archivo: si el archivo está en estado 'Tratado' o 'Error' lo movemos a la
# bandeja de entrada asociada a su tipo de archivo
#####################################################################################
$BAJAR_ARCHIVO

Local Char PATHSRV(100),PATHCLI(100)
Local Integer STAT : Raz STAT
Local Char EXT     : Raz EXT

EXT= '.csv'

If [M:YCMNT1]YPATH(nolign-1) = "" or [M:YCMNT1]YNOMFICX3(nolign-1) = ""
  Infbox  "Path o nombre de fichero en blanco"
Else
  PATHCLI=""
  PATHSRV=[M:YCMNT1]YPATH(nolign-1)+'\'+[M:YCMNT1]YNOMFICX3(nolign-1)
  PATHSRV+= EXT
  Call COPCLI(PATHSRV,PATHCLI,STAT) From ORDSYS
Endif

Return

#####################################################################################
$REEMPLAZAR_ARCHIVO

Local Char PATHSRV(100),PATHCLI(100)
Local Integer STAT : Raz STAT
Local Char EXT     : Raz EXT

EXT= '.csv'

If [M:YCMNT1]YPATH(nolign-1) = "" or [M:YCMNT1]YNOMFICX3(nolign-1) = ""
  Infbox  "Path o nombre de fichero en blanco"
Else
  Local Integer OK : OK=1
  Call AVERTIR("Desea reemplazar en el servidor el archivo "+[M:YCMNT1]YNOMFICX3(nolign-1),OK) From GESECRAN
  If OK=2
    Gosub REEMP
  Endif
Endif

Return
#####################################################################################
$REEMP

PATHCLI=""
PATHSRV=[M:YCMNT1]YPATH(nolign-1)+'\'+[M:YCMNT1]YNOMFICX3(nolign-1)
PATHSRV+= EXT

Call COPSRV(PATHCLI,PATHSRV,STAT) From ORDSYS

If STAT = 0
  Infbox "Fichero "+[M:YCMNT1]YNOMFICX3(nolign-1)+" reemplazado correctamente"
Endif

Return

#####################################################################################
$REPROCESAR_ARCHIVO


Local Char PATHORI(100),PATHDEST(100)
Local Integer STAT : Raz STAT
Local Char EXT     : Raz EXT

EXT= '.csv'

If [M:YCMNT1]YSTATUS(nolign-1)<>1 and [M:YCMNT1]YSTATUS(nolign-1)<>3
 Infbox "El fichero a reprocesar no se encuenta en status tratado o en error"
Else
  #Tipo de fichero : donde están los paths
  If !clalev ([F:YTP]) : Local File YTIPOFICHERO [YTP] : Endif
  Read [F:YTP]YTP0 = [M:YCMNT0]YCPY;[M:YCMNT1]YTIPOFICHERO(nolign-1)
  If fstat =0
    Gosub REPROC
  Endif
Endif

Return

#####################################################################################
$REPROC

Local Char ORIGEN_DOSSIER(250)
ORIGEN_DOSSIER=filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER

PATHORI=[M:YCMNT1]YPATH(nolign-1)+'\'+[M:YCMNT1]YNOMFICX3(nolign-1)
PATHORI+= EXT
PATHDES= ORIGEN_DOSSIER+"\"+[F:YTP]YPATHENTRADA+"\"+[M:YCMNT1]YNOMFICX3(nolign-1)
PATHDES+= EXT

Call MOVE(PATHORI,PATHDES,STAT) From ORDSYS

If STAT = 0
  Infbox "Fichero "+[M:YCMNT1]YNOMFICX3(nolign-1)+" movido correctamente"
Endif

Return

