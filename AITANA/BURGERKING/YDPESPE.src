#<AdxTL>@(#)0.0.0.0 $Revision$
#Y008  Consulta de pedidos
######################################################################################
# Gestiˇn de la mßscara YDPE
######################################################################################
$ACTION
Case ACTION
  When "DEBUT" : Gosub DEBUT
  When Default
Endcase
Return
##############################################

$DEBUT

# Clear previous text if mask is still in memory
Raz [M:YDPE]
Affzo [M:YDPE]

Local Integer NOL : NOL=0
If clalev ([F:YPEB]) = 0 : Local File YPEDEBIT  [YPEB]: Endif
Filter [F:YPEB] Where PEDIDO = PARAM(1)
#Filter [F:YPEB]

For [YPEB]

  nolign = NOL+1

  [M:YDPE]YFACTURA(nolign-1) = [F:YPEB]FACTURA
  [M:YDPE]YESTADO(nolign-1)  = [F:YPEB]ESTADO
  [M:YDPE]YIMPORTE(nolign-1) = [F:YPEB]IMPORTE
  NOL += 1
  [M:YDPE]NBLIG = NOL
Next

Affzo [M:YDPE]

Return

##############################################

