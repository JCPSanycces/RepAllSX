#####################################################################################
#-
######################################################################################
$ACTION
  #addon envio documentos
  If func AFNC.ACTIV("YDPDF") : Gosub ACTION From YDPDFSPEBPS : Endif

  Case ACTION
    When "OUVRE" :  Gosub OUVRE
    When "LIENS" :  Gosub LIENS
   # When "APRES_MODIF": Gosub APRES_MODIF
    When "MODIF" :  Gosub MODIF
    When Default
  Endcase
Return



######################################################################################
$OUVRE

  If !clalev([F:ZACCPR])  : Local File ZACCPROV     [ZACCPR] : Endif # Tabla datos Cuentas proveedores
  If !clalev([F:YBPS])    : Local File BPSUPPLIER   [F:YBPS]  : Endif

Return
######################################################################################
$LIENS

  Gosub CARGAR_CUENTAS_PROVEEDOR
  Gosub LIENS From YSPEBPS

Return


######################################################################################
$MODIF

  Gosub  GRABAR_CUENTAS_PROVEEDOR
  Return
######################################################################################
$CARGAR_CUENTAS_PROVEEDOR

  Local Integer LINEA
  Local Char CRITERE(255)
  Local Char CRITERE1(255)
  Local Char CRITERE2(255)



  LINEA = 0


  [M:ZACCPROV]ZNBLIG = 0
  nolign = 1

  CRITERE = "ZBPSNUM = [M:BPS0]BPSNUM"

  Effzo [M:ZACCPROV] # limpieza del bloque 2

  Filter [F:ZACCPR] Where evalue(CRITERE)

  For [F:ZACCPR]
    [M:ZACCPROV]ZBPSNUM(nolign-1) = [F:ZACCPR]ZBPSNUM
    [M:ZACCPROV]ZCOA(nolign-1) = [F:ZACCPR]ZCOA
    [M:ZACCPROV]ZACC(nolign-1) = [F:ZACCPR]ZACC
    [M:ZACCPROV]ZNBLIG += 1
    nolign += 1
  Next
  Filter [F:ZACCPR]
  Affzo [M:ZACCPROV]

  Return

######################################################################################

$GRABAR_CUENTAS_PROVEEDOR
  Local Integer I
  Local Integer ID
  Local Integer NLIN

        If !clalev([F:ZACCPR2])  : Local File ZACCPROV [ZACCPR2] : Endif # Tabla datos Cuentas proveedores
        #PRIMERO BORRAR TODOS LOS REGISTROS ASOCIADOS AL PROVEEDOR
        Delete [ZACCPR2] Where ZBPSNUM = [M:BPS0]BPSNUM

        For NLIN = 0 To [M:ZACCPROV]ZNBLIG-1
            # Buscamos la línea de factura tercero proveedor
            #Infbox "Dentro: " + [M:ZDISTRI]ZCCT(NLIN) + " - " + num$([M:BIS3]NUMLIG(NOL_SOURCE))
            #Infbox "importe linea: " + num$([F:ZBPSL]AMTNOTLIN(NOL_SOURCE))
            [ZACCPR2]ZBPSNUM = [M:BPS0]BPSNUM #
            [ZACCPR2]ZCOA = [M:ZACCPROV]ZCOA(NLIN)
            [ZACCPR2]ZACC = [M:ZACCPROV]ZACC(NLIN)
            Write [ZACCPR2]
        Next

Return

