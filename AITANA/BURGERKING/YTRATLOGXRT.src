##########################################################################################
#Y014 XRT deja ficheros de log en LOGCONTABLE, los bajamos, tratamos
#Y014 y actualizamos la tabla de envÌos hacia XRT ZEXPFIC
##########################################################################################
$YTRALOGXRT

#descargar los ficheros

Gosub DOWNLOAD_FILE

# LECTURA DEL FICHERO XRT
# INSERCION FICHERO XRT EN TABLA X3

Gosub INSERT_XRT_X3

End
##########################################################################################
$DOWNLOAD_FILE


Local Char CURRDATETIME_STR
Local Char FICHERO_BAT, FICHERO_CFG
Local Char FILESOU(255), DESPATH(255)
Local Integer SUCCESS
ORIGEN_DOSSIER=filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER



CURRDATETIME_STR=format$("D:YYYYMMDDhhmmss",datetime$)

FICHERO_BAT= "IMPORTLOG_" + CURRDATETIME_STR



#Creacion de fichero BAT
Openo filpath("LOGXRT",FICHERO_BAT, "bat",nomap)

adxifs=';'
adxirs = chr$(13) + chr$(10)

Wrseq 'WinSCP.com /command "open ftps://5091:9qwrcPU9@sif.sagetreasurysaas.es:990 -implicit"  "get ""/LOGCONTA/*"" ""' + ORIGEN_DOSSIER + '\LOGXRT\*.*_XRT" "exit"'
Openo

# Ejecutar fichero BAT
System CHAINE= ORIGEN_DOSSIER + "\LOGXRT\" + FICHERO_BAT + ".bat"

FILESOU = ORIGEN_DOSSIER + "\LOGXRT\" + FICHERO_BAT + ".bat"
DESPATH = ORIGEN_DOSSIER + "\LOGXRT\"+"Procesados\"

Sleep 5

#mover fichero a la carpeta enviados
ORIGEN = FILESOU
DESTINO=DESPATH
Call MOVE (ORIGEN,DESTINO,SUCCESS) From ORDSYS

Return
##########################################################################################
$INSERT_XRT_X3

Local Char DIR(GDIMFIC), FILELIST(GDIMFIC)(1..100)
Local Integer LNGTH
Local Integer COUNT
Local Char EFICHERO(200)
DIR =filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER
DIR = DIR + "\LOGXRT"

If !clalev([F:ATA]) : Local File ATABDIV [ATA] : Endif
COUNT = 0

Call SYSTEME2(adxmac(0), "lsadx"-DIR,"",LNGTH,FILELIST) From ORDSYS

For I=3 To LNGTH
     #  Buscamos los ficheros con extensiÛn _XRT (ficheros a tratar)
  If mid$(FILELIST(I),len(FILELIST(I))-3,4) = "_XRT" Then
    Call LEER_FICHERO_XRT(DIR , FILELIST(I))
  Endif

Next

Return
#####################################################################################################
#**
#* Lectura fichero XRT
#*
#* @param PDIRECTORIO
#* @param PFICHERO
#*!
Subprog LEER_FICHERO_XRT(PDIRECTORIO, PFICHERO)

Local Char LDIRMPORT(250) : LDIRIMPORT = PDIRECTORIO
Local Char LFILE_R(200)   : LFILE_R = PDIRECTORIO + "\" + PFICHERO

Local Char CUENTA(10),FLUJO(6),IMPORTE(8),FECHAOPE(9),FECHAVAL(9),DESCRIPCION(35),REFERENCIA(11),CONTRAPAR(5)
#<ALI01> Nueva variable LID para recoger el id ˙nico enviado por XRT
Local Char LYIDXRT(100)
#<\ALI01>
Local Char PLANTA(3)
Local Char SENTIDO(2)
Local Clbfile INFO_ADICIONAL(1)
Local Integer LNUMEXP, LECOK, SUCCESS : Raz LNUMEXP, LECOK, SUCCESS
Local Char LFECHA(10), LHORA(10), DESPATH(200) : Raz LFECHA, LHORA
Local Char LAUX(255) # MAB
# si se lanza la tarea batch
If !GSERVEUR Then
  Call TEMPON("Proceso rellenado tabla") From GESECRAN
  Call OUVRE_TRACE("Proceso rellenado tabla") From LECFIC
Endif
# abrir tabla intermedia
Gosub ABRIR_TBL
# abrir fichero para lectura
Gosub OPEN_FILE_R
# si el fichero existe y contiene informaciÛn
If filinfo(LFILE_R, 7) > 0 Then
  LECOK = 1
  Repeat
    # leer el archivo
    Local Char NOMBRE_XRT,FECHA,HORA,NUMREG
    Rdseq NOMBRE_XRT, FECHA, HORA, NUMREG Using [ZIMP_R]
    If fstat = 0 Then
      If len(vireblc(NOMBRE_XRT,0)) > 0 Then
        LNUMEXP += 1
        LECOK = 1
        [F:YLC]ZNOMFICX3      = NOMBRE_XRT
        [F:YLC]ZNOMFICXRT     = NOMBRE_XRT
        [F:YLC]ZFECPROD       = gdat$(val(mid$(FECHA,1,2)),val(mid$(FECHA,3,2)),val(mid$(FECHA,5,4)))
        [F:YLC]ZHORPROD       = format$("N0:2",mid$(HORA,1,2))+":"+format$("N0:2",mid$(HORA,3,2))+":"+format$("N0:2",mid$(HORA,5,2))
        [F:YLC]ZNUMREGXRT     = val(NUMREG)
        [F:YLC]ZCPY           = mid$(NOMBRE_XRT,23,3)
        Write [F:YLC]
        If !GSERVEUR Then
          Call TEMPON("LÌnea " + num$(LNUMEXP) + " del archivo procesada.") From GESECRAN
        Endif
        Gosub ACTUALIZAR_ZEXPFIC
      Endif
    Else
      LECOK = 0
    Endif
  Until LECOK = 0
Endif

Gosub CERRAR_TBL

Gosub CLOSE_FILE_R

# mueve el archivo a la carpeta de histÛricos
If filinfo(LFILE_R,7) > 0 Then
  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
  LHORA = vireblc(num$(time$),4) : LHORA = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)
  DESPATH = LDIRIMPORT+"\Procesados\" + PFICHERO + "_" + LFECHA+LHORA + ".csv"

  SUCCESS = renameFile(LFILE_R,DESPATH)

Endif

# traza
If !GSERVEUR Then
  Call TEMPOFF() From GESECRAN
  Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
  Call ECR_TRACE(num$(LNUMEXP) + " registros guardados en tabla", 0) From GESECRAN
  Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
Endif


End
###########################################################
$ABRIR_TBL
If clalev([YLC]) = 0 : Local File YLOGCONTABLE   [YLC] : Endif # tabla intermedia para conversiÛn
Return

########################################################
$CERRAR_TBL
Close Local File [YLC]
Return

########################################################
########################################################
$OPEN_FILE_R

#adxifs = ""
#adxirs = chr$(13)+chr$(10)

Local Char SAVIFS(10), SAVIRS(10)

SAVIFS = adxifs
SAVIRS = adxirs

adxifs = ";"
adxirs = chr$(13)+chr$(10)

Openi LFILE_R Using [ZIMP_R]

Return

########################################################
$CLOSE_FILE_R

Openi Using [ZIMP_R]

adxifs = SAVIFS
adxirs = SAVIRS

Return

########################################################
$ACTUALIZAR_ZEXPFIC

If !clalev([F:ZZEF]) : Local File ZEXPFIC [ZZEF] : Endif

Read [F:ZZEF]ZEF0 = [F:YLC]ZCPY;[F:YLC]ZNOMFICX3
If fstat = 0
  [F:ZZEF]ZNUMREGXRT=[F:YLC]ZNUMREGXRT
  [F:ZZEF]ZNOMFICXRT=[F:YLC]ZNOMFICX3
  Rewrite [F:ZZEF]
Endif

Return

