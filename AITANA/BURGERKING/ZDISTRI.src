######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZDISTRI) 25/10/2018 13:07:16 (ADMIN)
######################################################################################
Subprog AM_ZFIZFLAG(VALEUR)
  Variable Integer VALEUR

  [M:ZDISTRI]ZFIZFLAG(nolign-1) = VALEUR
  Call MOSTRAR_REGISTROS(2)
  Call RECALCULAR_IMPORTES()

End

Subprog AM_ZFIAFLAG(VALEUR)
  Variable Integer VALEUR

  [M:ZDISTRI]ZFIAFLAG(nolign-1) = VALEUR
  Call MOSTRAR_REGISTROS(2)
  Call RECALCULAR_IMPORTES()

End


