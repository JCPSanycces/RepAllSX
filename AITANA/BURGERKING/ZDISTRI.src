#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Gestión de la máscara ZDISTRI(Especifico)
$ACTION

Case ACTION

  When "OUVRE"  : Gosub OUVRE
  When "DEBUT"  : Gosub DEBUT
  When "OK"     : Gosub OK
  When "BOUTON" : Gosub BOUTON
  When Default
Endcase
Return

######################################################################################
$OUVRE
  Global Integer NOL_SOURCE
  Global Double  GIMPORTE


  NOL_SOURCE = val(PARAM(1))+1 # Numero de Linea original
#  Infbox num$(NOL)
  GIMPORTE = [M:BIS3]AMTNOTLIN(NOL_SOURCE-1)



  If clalev([F:ZCAC]) = 0 : Local File CACCE [F:ZCAC]  : Endif
  If clalev([F:ZPINV]) = 0 : Local File PINVOICE [F:ZPINV]  : Endif


  If [M:BIS0]NUM = '' Then
    Infbox "Para acceder a la distribución primero debe crear la factura."
    Gosub FIN From GSAISIE
  Else
    Filter [ZPINV] Where NUM = [M:BIS0]NUM
    Read [ZPINV] First
      If fstat <> 0 Then
        Infbox "Para acceder a la distribución primero debe Crear la factura."
        Gosub FIN From GSAISIE
      Endif
    Filter [ZPINV]
  Endif

Return


########################################################################
$BOUTON
Case BOUT
    When "Z"  Gosub UPDATE_FILTRE    # pulsa el botón de actualizar
    When "T"  Gosub SELECCIONAR_TODOS
    When "N"  Gosub DESELECCIONAR_TODOS
    When "O"  Gosub OK
Endcase
Return
######################################################################################

$UPDATE_FILTRE

   Call MOSTRAR_REGISTROS(1)
Return

######################################################################################

$SELECCIONAR_TODOS

   Call SELECCIONAR_REGISTROS(1)
Return

######################################################################################

$DESELECCIONAR_TODOS

   Call SELECCIONAR_REGISTROS(0)
Return

######################################################################################
$DEBUT
    Raz [M:ZDISTRI]
    [M:ZDISTRI]ZTOTALFACTUR = GIMPORTE
    Affzo [M:ZDISTRI]ZTOTALFACTUR
    Call MOSTRAR_ZONAS()
    Call MOSTRAR_AREAS()
    Call MOSTRAR_REGISTROS(0)
Return



######################################################################################
$OK
  Local Integer LOK


  Local Integer LCONT # Contador registro seleccionados
  Local Integer LLINEAS_CON_IMPORTE
  Local Integer LNUMLIN, LLINEA_SELECCIONADA
  Local Decimal LIMPORTE_ACUMULADO
  Local Integer OKCAN: OKCAN = 2
  Raz LOK

# Primero recorrer la pantalla, para saber cuantos centros de coste hemos seleccionado
# Habrá que dividir el importe de la línea porcetualmente al los CCT seleccionados.

  #Infbox num$([M:ZDISTRI]ZNLIG-1)


  If clalev([F:ZBPSL]) = 0 : Local File BPSINVLIG [F:ZBPSL]  : Endif
  #If clalev([F:ZCAC]) = 0 : Local File CACCE [F:ZCAC]  : Endif

  LTOTAL_LINEAS = 0
  LLINEAS_CON_IMPORTE = 0

  For NLIN = 0 To [M:ZDISTRI]ZNLIG-1
    If [M:ZDISTRI]ZSELFLG(NLIN) = 2 Then # Registro seleccionado
      LCONT += 1
      LTOTAL_LINEAS = LTOTAL_LINEAS + [M:ZDISTRI]ZIMPORTE(NLIN) # ACUMULAMOS EL IMPORTE QUE SE HA INTRODUCIDO EN CADA LÍNEA
      # Controlamos que si hay importes introducidos, todas las líneas tengan importe introducido
      If [M:ZDISTRI]ZIMPORTE(NLIN) > 0 Then
        LLINEAS_CON_IMPORTE += 1
      Endif
    Endif
  Next
  #Infbox "LINEAS CON IMPORTE:" + num$(LCONT)
  #Infbox "IMPORTE TOTAL: " + num$(LTOTAL_LINEAS)

  If LCONT > 0 Then
    # Controlamos que la suma de los importes sea correcta, y si todas las líneas tienen importe.
    If (LTOTAL_LINEAS <> 0 and LTOTAL_LINEAS <> GIMPORTE) or (LLINEAS_CON_IMPORTE > 0 and LLINEAS_CON_IMPORTE <> LCONT) Then
      #Errbox ("La suma de los importes introducidos debe ser igual al importe de la línea (" + num$(GIMPORTE) + ")")
      Call AVERTIR("La suma de los importes introducidos debe ser igual al importe de la línea (" + num$(GIMPORTE) + ")",OKCAN) From GESECRAN
      If OKCAN = 1 Then
          Return
      Endif
    Else

      Trbegin ZBPSINVLIGA [ZBPSI]
      #PRIMERO BORRAR TODOS LOS REGISTROS ASOCIADOS A ESA FACTURA TERCERO PROVEEDOR
      #Infbox "borrado de" + [M:BIS0]NUM + " - " + num$(NOL_SOURCE)
      Delete [ZBPSI] Where NUM = [M:BIS0]NUM and LIG = NOL_SOURCE
      If fstat = 1 Then
        Rollback
      Else

        LNUMLIN = 0
        For NLIN = 0 To [M:ZDISTRI]ZNLIG-1
          If [M:ZDISTRI]ZSELFLG(NLIN) = 2 Then # Registro seleccionado
            LNUMLIN += 1
            # Buscamos la línea de factura tercero proveedor
            #Infbox "Dentro: " + [M:ZDISTRI]ZCCT(NLIN) + " - " + num$([M:BIS3]NUMLIG(NOL_SOURCE))
            #Infbox "importe linea: " + num$([F:ZBPSL]AMTNOTLIN(NOL_SOURCE))
            Filter [ZBPSL] Where NUM = [M:BIS0]NUM and FCYLIN = [M:BIS0]FCY and LIG = NOL_SOURCE
            Read [ZBPSL] First
            If fstat = 0 Then
              [F:ZBPSI]INVTYP = [F:ZBPSL]INVTYP
              [F:ZBPSI]NUM = [F:ZBPSL]NUM
              [F:ZBPSI]LIG = [F:ZBPSL]LIG
              [F:ZBPSI]ANALIG = LNUMLIN

              [F:ZBPSI]CCE(0) = [M:ZDISTRI]ZCCT(NLIN) # Centro de Coste[M:BIS3]AMTNOTLIN(NOL)

              If LTOTAL_LINEAS = 0 Then # Si no se ha introducido ningún importe en las lineas, lo calculará solo
                # REDONDEO DE ULTIMA CANTIDAD # MAB19092018
                # Infbox num$(LNUMLIN) + " = " + num$(LCONT)
                If LNUMLIN = LCONT Then
                  [F:ZBPSI]AMT = ar2([F:ZBPSL]AMTNOTLIN - LIMPORTE_ACUMULADO)
                  # Infbox "total ultima cantidad:" + num$([F:ZBPSI]AMT)
                Else
                   [F:ZBPSI]AMT = ar2([F:ZBPSL]AMTNOTLIN/LCONT)
                   LIMPORTE_ACUMULADO += ar2([F:ZBPSI]AMT)
                   LLINEA_SELECCIONADA += 1
                   # Infbox num$(LIMPORTE_ACUMULADO)
                Endif
              Else
                [F:ZBPSI]AMT = [M:ZDISTRI]ZIMPORTE(NLIN)
              Endif
              [F:ZBPSI]CCE(1) = [M:ZDISTRI]ZCCE1
              [F:ZBPSI]CCE(2) = [M:ZDISTRI]ZCCE2
              [F:ZBPSI]CCE(3) = [M:ZDISTRI]ZCCE3
  #            [F:ZBPSI]CCE(4) = [M:BIS3]CCE4

              [F:ZBPSI]COA(0) = [F:ZBPSL]COA(0)
              [F:ZBPSI]COA(1) = [F:ZBPSL]COA(1)
              [F:ZBPSI]COA(2) = [F:ZBPSL]COA(2)
              [F:ZBPSI]COA(3) = [F:ZBPSL]COA(3)
              [F:ZBPSI]COA(4) = [F:ZBPSL]COA(4)
              [F:ZBPSI]COA(5) = [F:ZBPSL]COA(5)
              [F:ZBPSI]COA(6) = [F:ZBPSL]COA(6)
              [F:ZBPSI]COA(7) = [F:ZBPSL]COA(7)
              [F:ZBPSI]COA(8) = [F:ZBPSL]COA(8)
              [F:ZBPSI]COA(9) = [F:ZBPSL]COA(9)

              [F:ZBPSI]ACC(0) = [F:ZBPSL]ACC(0)
              [F:ZBPSI]ACC(1) = [F:ZBPSL]ACC(1)
              [F:ZBPSI]ACC(2) = [F:ZBPSL]ACC(2)
              [F:ZBPSI]ACC(3) = [F:ZBPSL]ACC(3)
              [F:ZBPSI]ACC(4) = [F:ZBPSL]ACC(4)
              [F:ZBPSI]ACC(5) = [F:ZBPSL]ACC(5)
              [F:ZBPSI]ACC(6) = [F:ZBPSL]ACC(6)
              [F:ZBPSI]ACC(7) = [F:ZBPSL]ACC(7)
              [F:ZBPSI]ACC(8) = [F:ZBPSL]ACC(8)
              [F:ZBPSI]ACC(9) = [F:ZBPSL]ACC(9)

  #            [F:ZBPSI]DIE(0) = [M:BIS1]NBRCCE(0)
  #            [F:ZBPSI]DIE(1) = [M:BIS1]NBRCCE(1)
  #            [F:ZBPSI]DIE(2) = [M:BIS1]NBRCCE(2)
  #            [F:ZBPSI]DIE(3) = [M:BIS1]NBRCCE(3)
  #            [F:ZBPSI]DIE(4) = [M:BIS1]NBRCCE(4)

              [F:ZBPSI]DIE(0) = 'CCT'
              [F:ZBPSI]DIE(1) = 'ARS'
              [F:ZBPSI]DIE(2) = 'FAM'
              [F:ZBPSI]DIE(3) = 'DEP'
              [F:ZBPSI]DIE(4) = 'CDV'
              Write [ZBPSI]
            Endif
            Filter [ZBPSL]
          Endif
        Next
        If fstat = 0 Then
          Commit
        Else
          Rollback
        Endif

      Endif
    Endif
   Else # MAB18092018.NO HAN SELECCIONADO NINGUN CENTRO DE COSTE. BORRAR LA DISTRIBUCIÓN
       # MAB18092018.NO HAN SELECCIONADO NINGUN CENTRO DE COSTE. BORRAR LA DISTRIBUCIÓN
      Trbegin ZBPSINVLIGA [ZBPSI]
      #PRIMERO BORRAR TODOS LOS REGISTROS ASOCIADOS A ESA FACTURA TERCERO PROVEEDOR
      #Infbox "borrado de" + [M:BIS0]NUM + " - " + num$(NOL_SOURCE)
      Delete [ZBPSI] Where NUM = [M:BIS0]NUM and LIG = NOL_SOURCE
      If fstat = 1 Then
        Rollback
      Else
        Commit
      Endif
   Endif

   Gosub FIN From GSAISIE
#      [F:ZTRAMD]MFGNUM = [M:ZTRM]ZMFGNUM
#      [F:ZTRAMD]ITMREF = [M:ZTRM]ITMREF(I)
#      [F:ZTRAMD]LOT    = [M:ZTRM]LOT(I)
#      Write [ZTRAMD]
#    Next
#    If fstat = 0 Then
#      Commit
#    Else
#      If fstat = 3 Then
#            GMESSAGE = "No se permiten registros duplicados"
#      Endif
#      Rollback
#    Endif
#  Endif

#[M:BIS3]DSP = "$"
#Affzo [M:BIS3]DSP
Return




######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZDISTRI) 19/06/2018 09:39:28 (ADMIN)
######################################################################################
Subprog S_ZZONA(VALEUR)
 Variable Char    VALEUR()

  If clalev([F:ZCAC2]) = 0 : Local File ZZONAS [F:ZCAC2]  : Endif

  Choose [ZCAC2]
& Where ([F:ZCAC2]DIE =  'CCT') and [F:ZCAC2]FCY = [M:BIS0]CPY
& Using [F:ZCAC2]ZONA Titled "Zona",
&       [F:ZCAC2]ZDESZONA Titled "Des. Zona"
& Sized(25, 100)
& Titled "Selección Zonas Centros de Coste"

  If fstat = 0 Then
    If [ZCAC2]ZONA <> "" Then
      VALEUR = [ZCAC2]ZONA
    Endif
  Endif
  Close Local File [F:ZCAC2]
End


#**
#*
#*!
Subprog MOSTRAR_ZONAS()
  Local Integer I : I = 0
  If clalev([F:ZCAC2]) = 0 : Local File ZZONAS [F:ZCAC2]  : Endif
  For [F:ZCAC2] Where DIE = 'CCT' and FCY = [M:BIS0]CPY
    [M:ZDISTRI]ZFIZZONA(I) = [F:ZCAC2]ZONA
    [M:ZDISTRI]ZFIZDES(I) = [F:ZCAC2]ZDESZONA
    I+=1

  Next
  [M:ZDISTRI]ZZOLIG = I
  Affzo [M:ZDISTRI]
  Close File [ZCAC2]

End

#**
#*
#*!
Subprog MOSTRAR_AREAS()
  Local Integer I : I = 0
  If clalev([F:ZAREA]) = 0 : Local File ZAREAS [F:ZAREA]  : Endif
  For [F:ZAREA] Where DIE = 'CCT' and FCY = [M:BIS0]CPY
    [M:ZDISTRI]ZFIAAREA(I) = [F:ZAREA]AREA
    [M:ZDISTRI]ZFIADES(I) = [F:ZAREA]ZDESAREA
    I+=1

  Next
  [M:ZDISTRI]ZARLIG = I
  Affzo [M:ZDISTRI]
  Close File [ZAREA]

End

######################################################################################

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZDISTRI) 19/06/2018 09:52:11 (ADMIN)
######################################################################################
Subprog S_ZAREA(VALEUR)
  Variable Char    VALEUR()

  If clalev([F:ZCAC2]) = 0 : Local File ZAREAS [F:ZCAC2]  : Endif
  Choose [ZCAC2]
& Where ([F:ZCAC2]DIE =  'CCT') and [F:ZCAC2]FCY = [M:BIS0]CPY
& Using [F:ZCAC2]AREA Titled "Área",
&       [F:ZCAC2]ZDESAREA Titled "Des. Área"
& Sized(25, 100)
& Titled "Selección Áreas Centros de Coste"

  If fstat = 0 Then
    If [ZCAC2]AREA <> "" Then
      VALEUR = [ZCAC2]AREA
    Endif
  Endif
  Close Local File [F:ZCAC2]
End


######################################################################################
#**
#* Muestra los registros en pantalla
#*   @param PTIPOSEL -- Si recibe 1, habrá que marcar todos los registros
#*!

Subprog MOSTRAR_REGISTROS(PTIPOSEL)


  Local Integer LINEA
  Local Char CRITERE(255)
  Local Char CRITERE1(255)
  Local Char CRITERE2(255)
  Local Char CRITERE3(255)
  Local Char CRITERE4(255)
  Local Decimal LIMPORTE_ACUMULADO
  Local Char LLISTA(255)
  Local Char LLISTAZONAS(255)
  Local Char LAREA(20)
  Local Char LZONA(20)

  If clalev([F:ZBPI]) = 0 : Local File ZBPSINVLIGA [F:ZBPI]  : Endif

  LINEA = 0


  [M:ZDISTRI]ZNLIG = 0
  nolign = 1

  # CRITERE = "DIE = 'CCT'  AND FCY = '" + [M:BIS0]CPY + "' AND ZZONA <> '' AND ZAREA <> '' "
  # SUPPORT-1749.new 21/03/2019 - MAB -  SE FILTRAN SOLO LAS SECCIONES ACTIVAS
  CRITERE = "DIE = 'CCT' and ENAFLG = 2 AND FCY = '" + [M:BIS0]CPY + "' AND ZZONA <> '' AND ZAREA <> '' "


  # FILTRO ZONAS

  For I = 0 To  [M:ZDISTRI]ZZOLIG
      If [M:ZDISTRI]ZFIZFLAG(I) = 2 Then
        If LLISTAZONAS <> "" Then
          LLISTAZONAS += " OR "
        Endif
        LLISTAZONAS += " ZZONA = '" + [M:ZDISTRI]ZFIZZONA(I) + "' "

      Endif
  Next
 # Infbox LLISTAZONAS
  If LLISTAZONAS <> "" Then
    LLISTAZONAS = "(" + LLISTAZONAS + ")"
  Endif
 # Infbox "Lista zonas: " +LLISTAZONAS
  CRITERE4 = LLISTAZONAS

  # FILTRO AREAS
 # Infbox num$([M:ZDISTRI]ZARLIG)
  For I = 0 To  [M:ZDISTRI]ZARLIG
  If [M:ZDISTRI]ZFIAFLAG(I) = 2 Then
        If LLISTA <> "" Then
          LLISTA += " OR "
        Endif
        LLISTA += " ZAREA = '" + [M:ZDISTRI]ZFIAAREA(I) + "' "
      Endif
  Next
 # Infbox LLISTA
  If LLISTA <> "" Then
    LLISTA = "(" + LLISTA + ")"
  Endif
  CRITERE3 = LLISTA
 # Infbox "Lista AREAS: " +LLISTA

  If CRITERE3 <> "" and CRITERE4 <> "" Then
     CRITERE3 = " AND ( " + CRITERE3
     CRITERE4 = " AND " + CRITERE4 + ") "
  Elsif CRITERE3 <> "" and CRITERE4 = "" Then
     CRITERE3 = " AND ( " + CRITERE3 + " )"
  Elsif CRITERE3 = "" and CRITERE4 <> "" Then
     CRITERE4 = " AND ("  + CRITERE4 + " ) "
  Endif


#  If [M:ZDISTRI]ZLISTAAREAS <> "" Then
#    For I = 1 To len([M:ZDISTRI]ZLISTAAREAS)
#      If mid$([M:ZDISTRI]ZLISTAAREAS,I,1) <> "," and I < len([M:ZDISTRI]ZLISTAAREAS) Then
#        LAREA += mid$([M:ZDISTRI]ZLISTAAREAS,I,1)
#      Else
#        If LLISTA <> "" Then
#          LLISTA += " OR "
#        Endif
#        If mid$([M:ZDISTRI]ZLISTAAREAS,I,1) <> "," Then
#           LAREA += mid$([M:ZDISTRI]ZLISTAAREAS,I,1)
#        Endif
#
#        LLISTA += " ZAREA = '" + LAREA + "'"
#        LAREA = ""
#      Endif
#    Next
#  Endif
#  If LLISTA <> "" Then
#    LLISTA = "(" + LLISTA + ")"
#  Endif
#  If LLISTA <> "" and CRITERE2 <> "" Then
#    LLISTA = " OR " + LLISTA + ")"
#  Endif
#  CRITERE3 =  LLISTA


#  If [M:ZDISTRI]ZAREA <> ""  Then
#    If CRITERE3 <> "" Then
#       CRITERE2 =  " AND (ZAREA = [M:ZDISTRI]ZAREA OR"
#       CRITERE3 =  CRITERE3 + ")"
#    Else
#       CRITERE2 = " AND ZAREA = [M:ZDISTRI]ZAREA "
#    Endif
#  Endif
#  If CRITERE2 = "" and CRITERE3 <> "" Then
#    CRITERE3 = "AND " +  CRITERE3
#  Endif

#  # FILTRO ZONAS
#  If [M:ZDISTRI]ZLISTAZONAS <> "" Then
#    For I = 1 To len([M:ZDISTRI]ZLISTAZONAS)
#      If mid$([M:ZDISTRI]ZLISTAZONAS,I,1) <> "," and I < len([M:ZDISTRI]ZLISTAZONAS) Then
#        LZONA += mid$([M:ZDISTRI]ZLISTAZONAS,I,1)
#      Else
#        If LLISTAZONAS <> "" Then
#          LLISTAZONAS += " OR "
#        Endif
#        If mid$([M:ZDISTRI]ZLISTAZONAS,I,1) <> "," Then
#           LZONA += mid$([M:ZDISTRI]ZLISTAZONAS,I,1)
#        Endif
#
#        LLISTAZONAS += " ZZONA = '" + LZONA + "'"
#        LZONA = ""
#      Endif
#    Next
#  Endif
#  If LLISTAZONAS <> "" Then
#    LLISTAZONAS = "(" + LLISTAZONAS + ")"
#  Endif
#  If LLISTAZONAS <> "" and CRITERE1 <> "" Then
#    LLISTAZONAS = " OR " + LLISTAZONAS + ")"
#  Endif
#  CRITERE4 =  LLISTAZONAS


#  If [M:ZDISTRI]ZZONA <> ""  Then
#    If CRITERE4 <> "" Then
#       CRITERE1 =  " AND (ZZONA = [M:ZDISTRI]ZZONA OR"
#       CRITERE4 =  CRITERE4 + ")"
#    Else
#       CRITERE1 = " AND ZZONA = [M:ZDISTRI]ZZONA "
#    Endif
#  Endif
#  If CRITERE1 = "" and CRITERE4 <> "" Then
#    CRITERE4 = "AND " +  CRITERE4
#  Endif




#  Infbox (CRITERE + CRITERE3 + CRITERE4)
  #Effzo [M:ZDISTRI]6 # limpieza del bloque 5




#  If CRITERE3 = "" and CRITERE1 = "" Then
#    Filter [F:ZCAC] Where evalue(CRITERE + CRITERE1 + CRITERE2)
#  Else
#    Filter [F:ZCAC] Where evalue(CRITERE + CRITERE1 + CRITERE4 + CRITERE2 + CRITERE3)
#  Endif
 #Infbox CRITERE + CRITERE3 + CRITERE4

  Filter [F:ZCAC] Where evalue(CRITERE + CRITERE3 + CRITERE4 )

  #Filter [F:ZCAC] Where evalue(CRITERE3)
  [M:ZDISTRI]ZTOTALDISTRI = 0
  For [F:ZCAC]
    [M:ZDISTRI]ZCCT(nolign-1) = [F:ZCAC]CCE
    [M:ZDISTRI]ZCCTDES(nolign-1) = [F:ZCAC]DES
    Filter [ZBPI] Where NUM = [M:BIS0]NUM and FCYLIN = [M:BIS0]FCY and LIG = NOL_SOURCE and CCE(0) = [F:ZCAC]CCE
    Read [ZBPI] First
    If fstat = 0 Then # Encontrado!!
      [M:ZDISTRI]ZSELFLG(nolign-1) = 2
      # Nacho solicita que se vean estos otros 3 ejes en pantalla y que el usuario pueda introducirlos
      # Siempre van a ir al 100% y solo van a ser estos 3 ejes
      [M:ZDISTRI]ZCCE1 = [F:ZBPI]CCE(1) # ARS
      [M:ZDISTRI]ZCCE2 = [F:ZBPI]CCE(2) # FAM
      [M:ZDISTRI]ZCCE3 = [F:ZBPI]CCE(3) # DEP

      [M:ZDISTRI]ZIMPORTE(nolign-1) = [F:ZBPI]AMT
      [M:ZDISTRI]ZTOTALDISTRI +=  [M:ZDISTRI]ZIMPORTE(nolign-1)
    Endif

    [M:ZDISTRI]ZZONA2(nolign-1) = [F:ZCAC]ZZONA
    [M:ZDISTRI]ZDESZONA(nolign-1) = [F:ZCAC]ZDESZONA
    [M:ZDISTRI]ZAREA2(nolign-1) = [F:ZCAC]ZAREA
    [M:ZDISTRI]ZDESAREA(nolign-1) = [F:ZCAC]ZDESAREA


    Filter [ZBPI]
    # Si vengo de un filtro, habrá que marcar todos lo registros que aparezcan con el filtro
    If PTIPOSEL = 1 Then
        [M:ZDISTRI]ZSELFLG(nolign-1) = 2
    Endif
    [M:ZDISTRI]ZNLIG += 1
    nolign += 1
  Next
  Filter [F:ZCAC]
  LIMPORTE_ACUMULADO = 0
  # Si vengo de un filtro, pondré el importe automaticamente en todos los registros
  If PTIPOSEL = 1 and [M:ZDISTRI]ZNLIG > 0 Then
    For NLIN = 0 To [M:ZDISTRI]ZNLIG-1
      # si estoy en la última línea # MAB19092018
       If [M:ZDISTRI]ZNLIG-1 = NLIN Then
        [M:ZDISTRI]ZIMPORTE(NLIN) = ar2(GIMPORTE - LIMPORTE_ACUMULADO)
        [M:ZDISTRI]ZTOTALDISTRI += [M:ZDISTRI]ZIMPORTE(NLIN)
        # Infbox "total ultima cantidad AUTOCALCULADA:" + num$([M:ZDISTRI]ZIMPORTE(NLIN))
       Else
        [M:ZDISTRI]ZIMPORTE(NLIN) = ar2(GIMPORTE/[M:ZDISTRI]ZNLIG)
        [M:ZDISTRI]ZTOTALDISTRI += [M:ZDISTRI]ZIMPORTE(NLIN)
        LIMPORTE_ACUMULADO += ar2([M:ZDISTRI]ZIMPORTE(NLIN))
       Endif

    Next
    Affzo [M:ZDISTRI]ZIMPORTE
  Endif

  Affzo [M:ZDISTRI]



End

#**
#* Con esta funcion marcaremos y desmarcaremos todos los registros que tengamos en pantalla
#*
#* @param PTIPOSEL
#*            - 1 - SELECCIONAR TODOS
#*            - 0 - DESELECCIONAR TODOS
#*!
Subprog SELECCIONAR_REGISTROS(PTIPOSEL)
  Local Integer VSEL
  Local Decimal LIMPORTE_ACUMULADO


  If PTIPOSEL = 1 Then
        VSEL = 2
  Else
        VSEL = 1
  Endif
  LIMPORTE_ACUMULADO = 0
  For I = 0 To ZNLIG
    [M:ZDISTRI]ZSELFLG(I) = VSEL
    If VSEL = 2 Then
       #[M:ZDISTRI]ZIMPORTE(I) = GIMPORTE/ZNLIG
       # ULTIMA LINEA
       If ZNLIG = I  Then
        [M:ZDISTRI]ZIMPORTE(I) = ar2(GIMPORTE - LIMPORTE_ACUMULADO)
        [M:ZDISTRI]ZTOTALDISTRI +=  [M:ZDISTRI]ZIMPORTE(I)
        # Infbox "total ultima cantidad AUTOCALCULADA:" + num$(GIMPORTE) + " - " + num$(LIMPORTE_ACUMULADO) + " = " + num$([M:ZDISTRI]ZIMPORTE(NLIN))
       Else
        [M:ZDISTRI]ZIMPORTE(I) = ar2(GIMPORTE/ZNLIG)
        LIMPORTE_ACUMULADO += ar2([M:ZDISTRI]ZIMPORTE(I))
        [M:ZDISTRI]ZTOTALDISTRI +=  [M:ZDISTRI]ZIMPORTE(I)
        # Infbox "IMPORTE ACUMULADO : " + num$(LIMPORTE_ACUMULADO)
       Endif

    Else
        [M:ZDISTRI]ZIMPORTE(I) = 0
    Endif
    Affzo [M:ZDISTRI]ZSELFLG(I)
    Affzo [M:ZDISTRI]ZIMPORTE(I)
  Next

End

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZDISTRI) 07/08/2018 15:06:08 (ADMIN)
######################################################################################
Subprog C_ZSELFLG(VALEUR)
Variable Integer VALEUR

#  If VALEUR = 1 Then
#      [M:ZDISTRI]ZTOTALDISTRI -=  [M:ZDISTRI]ZIMPORTE(nolign-1)
#      [M:ZDISTRI]ZIMPORTE(nolign-1) = 0
#      Affzo [M:ZDISTRI]ZTOTALDISTRI
#
#  Endif
      [M:ZDISTRI]ZSELFLG(nolign-1) = VALEUR

      Call RECALCULAR_IMPORTES()


End


######################################################################################

Subprog RECALCULAR_IMPORTES()
 Local Integer CSELECCIONADOS
 Local Float LIMPORTE_TOTAL
 Local Float LIMPORTE_ACUMULADO
 Local Integer LSEL_ACTUALIZADO
 # CONTAR LO REGISTROS SELECCIONADOS
 If [M:ZDISTRI]ZRECALCULAR = 2 Then


     For NLIN = 0 To [M:ZDISTRI]ZNLIG-1
      If [M:ZDISTRI]ZSELFLG(NLIN) = 2 Then
          CSELECCIONADOS += 1
      Endif
     Next

     LSEL_ACTUALIZADO = CSELECCIONADOS

     LIMPORTE_TOTAL = GIMPORTE
     [M:ZDISTRI]ZTOTALDISTRI = 0

     For NLIN = 0 To [M:ZDISTRI]ZNLIG-1
           If [M:ZDISTRI]ZSELFLG(NLIN) = 2 Then
             # Si estoy en el último seleccionado, redondeo el importe para que cuadre con el total de la linea
             If LSEL_ACTUALIZADO <= 1 Then
              [M:ZDISTRI]ZIMPORTE(NLIN) = ar2(LIMPORTE_TOTAL - LIMPORTE_ACUMULADO)
              [M:ZDISTRI]ZTOTALDISTRI += [M:ZDISTRI]ZIMPORTE(NLIN)
              # Infbox "total ultima cantidad AUTOCALCULADA:" + num$([M:ZDISTRI]ZIMPORTE(NLIN))
             Else
              [M:ZDISTRI]ZIMPORTE(NLIN) = ar2(LIMPORTE_TOTAL/CSELECCIONADOS)
              [M:ZDISTRI]ZTOTALDISTRI += [M:ZDISTRI]ZIMPORTE(NLIN)
              LIMPORTE_ACUMULADO += ar2([M:ZDISTRI]ZIMPORTE(NLIN))
              LSEL_ACTUALIZADO -=1
             Endif
           Else
            Effzo [M:ZDISTRI]ZIMPORTE(NLIN)
           Endif

        Next
        Affzo [M:ZDISTRI]ZIMPORTE
        Affzo [M:ZDISTRI]ZTOTALDISTRI
    Endif
End




######################################################################################

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla ZDISTRI) 24/09/2018 18:05:48 (ADMIN)
######################################################################################
Subprog AM_ZIMPORTE(VALEUR)
Variable Decimal VALEUR
   If VALEUR <> [M:ZDISTRI]ZIMPORTE(nolign-1) Then
      [M:ZDISTRI]ZTOTALDISTRI =  [M:ZDISTRI]ZTOTALDISTRI - [M:ZDISTRI]ZIMPORTE(nolign-1) + VALEUR

      Affzo [M:ZDISTRI]ZTOTALDISTRI
      If VALEUR <> 0 Then
        [M:ZDISTRI]ZSELFLG(nolign-1) = 2
        Affzo [M:ZDISTRI]ZSELFLG(nolign-1)
      Endif


  Endif

End


