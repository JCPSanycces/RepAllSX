#<AdxTL>@(#)0.0.0.0 $Revision$ 
#RBI
$ACTION

Case ACTION
  When "WSIIFILE": Gosub FICHERO
  When "WVARPOST" : Gosub WVARPOST
  When "WSIIRESP": Gosub RESPUESTA

Endcase
Return

####################################################

$RESPUESTA
  Local Char CURRDATETIME_STR2

  CURRDATETIME_STR2=format$("D:YYYYMMDDhhmmss",datetime$)
  Openo filpath ("BQT","RESPU_"+"SII_"+CURRDATETIME_STR2 ,"XML"), 0 Using [YYY]
  Wrseq RESULTADO Using [YYY]
  Openo Using [YYY]
Return

#################################################################################
$FICHERO
  Local Char CURRDATETIME_STR

  CURRDATETIME_STR=format$("D:YYYYMMDDhhmmss",datetime$)
  # ańado al nombre del fichero la fecha hora de generación para tener una traza del mismo.
  # MAB15032019.NEW
  Openo filpath("BQT", "ENV_SII_" + CURRDATETIME_STR,  "XML"), 0 Using [XXX]
  Wrseq DATAXML Using [XXX]
  Openo Using [XXX]
Return
###################################################################################
# Modificación de variables antes de generar el fichero XML
$WVARPOST
  Local Char LFACTURA(30)
  Local Char LFACTURA_FIN(30)
  Local Char LNUM(30)
  Local Integer POS_G, POS_G2

###############################################################################
# Estas tres líneas nos permiten presentar la factura a Canarias              #
###############################################################################
# WTERR = 6
# ENDPOINT = Asignar endpoint pruebas/real
# WIDVERSION = '1.0'
###############################################################################

Local Char ZPRUEBAS(1)
Call PARAM(GFCY,"XX02PRUEBA",ZPRUEBAS) From ADOVAL # recuperamos el valor del parámetro en Pruebas

Local Char ENDPOINT_FE(100), ENDPOINT_FR(100)
Local Char ENDPOINT_OCEE(100), ENDPOINT_INM(100), ENDPOINT_CCC(100)
Local Char ENDPOINT_PCC(100), ENDPOINT_OA(100)

If [M:XSII]ZCANARIAS = 2 Then
  Call ECR_TRACE("PREPARACIÓN XML PARA CANARIAS", 0) From GESECRAN
  WTERR = 6
  WIDVERSION = '1.0'
  If  ZPRUEBAS = '2' Then
    ENDPOINT_FE   = 'https://sede.gobcan.es/tributos/middlewarecaut/services/sii/SiiFactFEV1SOAP'
    ENDPOINT_FR   = 'https://sede.gobcan.es/tributos/middlewarecaut/services/sii/SiiFactFRV1SOAP'
    #ENDPOINT_OCEE = ''
    ENDPOINT_INM  = 'https://sede.gobcan.es/tributos/middlewarecaut/services/sii/SiiFactBIV1SOAP'
    ENDPOINT_CCC  = 'https://sede.gobcan.es/tributos/middlewarecaut/services/sii/SiiFactCOBV1SOAP'
    ENDPOINT_PCC  = 'https://sede.gobcan.es/tributos/middlewarecaut/services/sii/SiiFactPAGV1SOAP'
    ENDPOINT_OA   = 'https://sede.gobcan.es/tributos/middlewarecaut/services/sii/SiiFactCMV1SOAP'
  Else
    ENDPOINT_FE   = 'https://sede.gobcan.es/tributos/middleware/services/sii/SiiFactFEV1SOAP'
    ENDPOINT_FR   = 'https://sede.gobcan.es/tributos/middleware/services/sii/SiiFactFRV1SOAP'
    #ENDPOINT_OCEE = ''
    ENDPOINT_INM  = 'https://sede.gobcan.es/tributos/middleware/services/sii/SiiFactBIV1SOAP'
    ENDPOINT_CCC  = 'https://sede.gobcan.es/tributos/middleware/services/sii/SiiFactCOBV1SOAP'
    ENDPOINT_PCC  = 'https://sede.gobcan.es/tributos/middleware/services/sii/SiiFactPAGV1SOAP'
    ENDPOINT_OA   = 'https://sede.gobcan.es/tributos/middleware/services/sii/SiiFactCMV1SOAP'
  Endif
Else
  Call ECR_TRACE("GENERACIÓN XML PARA NACIONAL", 0) From GESECRAN
Endif


If WLIBRO = 1 Then
      If [M:XSII]ZCANARIAS = 2 Then
        ENDPOINT = ENDPOINT_FE
      Endif

      If !clalev([SIH]) :Local File SINVOICE: Endif
      If !clalev([ZBPC]) Then : Local File BPCINVLIG [ZBPC] : Endif

      For WIND = 0 To IND
        If [M:XSII]ZCANARIAS = 2 Then       # Clave Régimen
          WCLAREGESP(WIND) = '01'
        Endif


        # SUPPORT-2005 - Modificar el campo descripción con lo que exista en la tabla BPCINVLIG

        Filter [F:ZBPC] Where NUM = WNUMFACID(WIND)
        Read [F:ZBPC] First
        If !fstat Then
          If [F:ZBPC]DES <> '' Then
              WDESCROPE(WIND) = [F:ZBPC]DES
          Endif
        Endif


          # SOLICITADO EN EL SUPPORT- SUPPORT-1761. MAB.24042019.SNEW<<
          # SOLICITADO EN EL SUPPORT- SUPPORT-1761. MAB.24042019.SNEW<<
          # PARA LAS FACTURAS DE TIPO ABONO (ABC) QUE SEAN F4, BORRAR EL CAMPO
          # TIPORECT Y MONTAR EL NUMERO DE FACTURA INICO Y FIN COMO SE HACE EN LAS DE
          # TIPO FAC
          If WTYPFAC(WIND) = 'F4' and WTIPORECT(WIND) <> '' and WGTE(WIND) = 'ABC' Then

            WTIPORECT(WIND) = '' # MOD MAB 23042019

            LNUM = WNUMFACID(WIND)
            #LFACTURA = mid$(LNUM,1,instr(1,LNUM,"-")-1) + "-" + num$([F:SIH]ZTCKNUM) + "-" + [F:SIH]ZTCKINI
            POS_G = instr(1,LNUM,"-")
            #Infbox num$(POS_G)
            POS_G2 = instr(POS_G+1,LNUM,"-")
            #Infbox num$(POS_G2)
            If vireblc([F:SIH]ZTCKINI,2) <> '' and POS_G <> 0 and POS_G2 <> 0 Then
              LFACTURA = mid$(LNUM,1,POS_G-1) + "-" + mid$(LNUM,POS_G+1, (POS_G2-1)-(POS_G)) + "-" + vireblc([F:SIH]ZTCKINI,2)
            Else # SI NO TENEMOS TICKET INICIO, NO SE PUEDE COMPONER EL NUMERO DE FACTURA POR LO QUE ENVIAMOS EL NÚMERO TAL Y COMO ESTÁ EN SAGE X3
               LFACTURA = LNUM
            Endif
            If vireblc([F:SIH]ZTCKEND,2) <> ""  and POS_G <> 0 and POS_G2 <> 0 Then
              LFACTURA_FIN = mid$(LNUM,1,POS_G-1) + "-" + mid$(LNUM,POS_G+1, (POS_G2-1)-(POS_G)) + "-" + vireblc([F:SIH]ZTCKEND,2)
              WFACTURARESUMEN(WIND) = LFACTURA_FIN
            Endif
            WNUMFACID(WIND) =  LFACTURA
            #Infbox WNUMFACID(WIND)
            WFACTURAEMISOR(WIND) = LFACTURA


          Endif
          # SOLICITADO EN EL SUPPORT- SUPPORT-1761. MAB.24042019.ENEW
          #Infbox WNUMFACID(WIND)
          If WGTE(WIND) = "FAC" Then
            #Infbox mid$(WNUMFACID(WIND),1,instr(1,WNUMFACID(WIND),"-")-1)
            Read [SIH]SIH0=WNUMFACID(WIND)
            If !fstat
              LNUM = WNUMFACID(WIND)
              #LFACTURA = mid$(LNUM,1,instr(1,LNUM,"-")-1) + "-" + num$([F:SIH]ZTCKNUM) + "-" + [F:SIH]ZTCKINI
              POS_G = instr(1,LNUM,"-")
              #Infbox num$(POS_G)
              POS_G2 = instr(POS_G+1,LNUM,"-")
              #Infbox num$(POS_G2)
              If vireblc([F:SIH]ZTCKINI,2) <> ''  and POS_G <> 0 and POS_G2 <> 0  Then
                LFACTURA = mid$(LNUM,1,POS_G-1) + "-" + mid$(LNUM,POS_G+1, (POS_G2-1)-(POS_G)) + "-" + vireblc([F:SIH]ZTCKINI,2)
              Else # SI NO TENEMOS TICKET INICIO, NO SE PUEDE COMPONER EL NUMERO DE FACTURA POR LO QUE ENVIAMOS EL NÚMERO TAL Y COMO ESTÁ EN SAGE X3
                 LFACTURA = LNUM
              Endif

              # MAB13022019.NEW
              # Para las facturas que tengan informado solo el ticket de inicio,
              # las enviaremos a Hacienda como F2.
              # Este cambio es necesario, ya que Sage las toma como F4.
              # El ciente confirma que deben de pasar como F2.
              If vireblc([F:SIH]ZTCKEND,2) = "" and vireblc([F:SIH]ZTCKINI,2) <> "" Then
                WTYPFAC(WIND) = 'F2'
              Endif

              #Infbox LFACTURA
              If vireblc([F:SIH]ZTCKEND,2) <> ""  and POS_G <> 0 and POS_G2 <> 0 Then
                LFACTURA_FIN = mid$(LNUM,1,POS_G-1) + "-" + mid$(LNUM,POS_G+1, (POS_G2-1)-(POS_G)) + "-" + vireblc([F:SIH]ZTCKEND,2)
                WFACTURARESUMEN(WIND) = LFACTURA_FIN
                WTYPFAC(WIND) = 'F4'         # 12/02/2019 - MS - Fuerzo que el tipo de factura sea Asto. Resum. Fact.
                                            # ya que tiene ticket fin

              Endif
              WNUMFACID(WIND) =  LFACTURA
              #Infbox WNUMFACID(WIND)
              WFACTURAEMISOR(WIND) = LFACTURA

              If POS_G <> 0 and POS_G2 <> 0 Then
                WDESCROPE(WIND)= "Ventas del restaurante " + mid$(LNUM,1,instr(1,LNUM,"-")-1) + " y caja  " + mid$(LNUM,POS_G+1, (POS_G2-1)-(POS_G)) + " a fecha " + num$([F:SIH]ACCDAT)
              Else
                WDESCROPE(WIND)= "Ventas del restaurante " + mid$(LNUM,1,instr(1,LNUM,"-")-1) + " y caja  " + LNUM + " a fecha " + num$([F:SIH]ACCDAT)
              Endif
            Endif
          Endif
      Next
Endif

If WLIBRO = 2 Then
  If !clalev([ZBPS]) Then : Local File BPSINVLIG [ZBPS] : Endif
  If [M:XSII]ZCANARIAS = 2 Then
    ENDPOINT = ENDPOINT_FR
  Endif
  For WIND = 0 To IND
    If [M:XSII]ZCANARIAS = 2 Then       # Clave Régimen
      WCLAREGESP(WIND) = '01'
    Endif
    # SUPPORT-2005 - Modificar el campo descripción con lo que exista en la tabla BPSINVLIG
    Filter [F:ZBPS] Where NUM = WNUMFACID(WIND)
    Read [F:ZBPS] First
    If !fstat Then
      If [F:ZBPS]DES <> '' Then
          WDESCROPE(WIND) = [F:ZBPS]DES
      Endif
    Endif
  Next
Endif

#If WLIBRO = 3 Then
#  If [M:XSII]ZCANARIAS = 2 Then
#  ENDPOINT = ENDPOINT_OCEE
#  Endif
#Endif

If WLIBRO = 4 Then
  If [M:XSII]ZCANARIAS = 2 Then
    ENDPOINT = ENDPOINT_INM
  Endif
Endif

If WLIBRO = 5 Then
  If [M:XSII]ZCANARIAS = 2 Then
    ENDPOINT = ENDPOINT_CCC
  Endif
Endif

If WLIBRO = 6 Then
  If [M:XSII]ZCANARIAS = 2 Then
    ENDPOINT = ENDPOINT_PCC
  Endif
Endif

If WLIBRO = 7 Then
  If [M:XSII]ZCANARIAS = 2 Then
    ENDPOINT = ENDPOINT_OA
  Endif
Endif

Return

