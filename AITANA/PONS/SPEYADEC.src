$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "INIT"     : Gosub INIT
  When "OUVRE"    : Gosub OUVRE
  When "OK"       : Gosub OK
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
##############################################################
$INIT
Local    Integer  OK
Global Integer    GNIV, GORD
Global Decimal    GQTY
Local    Char     SBOITE(GLONFEN)                 # 08.06 37275
#Local    Char     BOITE(GLONFEN)                 # 08.06 37275
Local    Char     ERR(80), ERR_TRA(132)
If clalev([F:BOD]) = 0 : Local File BOMD       [BOD] : Endif
If clalev([F:BOH]) = 0 : Local File BOM        [BOH] : Endif
If clalev([F:ITM]) = 0 : Local File ITMMASTER  [ITM] : Endif
If clalev([F:ITC]) = 0 : Local File ITMCOST    [ITC] : Endif
If clalev([F:ITV]) = 0 : Local File ITMMVT     [ITV] : Endif
If clalev([F:ITF]) = 0 : Local File ITMFACILIT [ITF] : Endif
If clalev([F:ITB]) = 0 : Local File ITMBOM     [ITB] : Endif
If clalev([F:SRU]) = 0 : Local File TABSTORUL  [SRU] : Endif     : # FQ 44655 GA 12/2007
#If clalev([F:TEC]) = 0 : Local File YTMPEC     [TEC] : Endif
Global   Integer  WSTA,WA,WQ,WR,WRET   # Local ne fonctionne pas : # FQ 44655 GA 12/2007
Return

##############################################################
$OK
  Gosub RELLENA_BOMRET
  Gosub BUSCA_ESCANDALLO
  Gosub RELLENA_COSTES
  Gosub CALCULA_TOTALES
  Gosub ORDENA_REGISTROS
  Gosub COLOREA_REGISTROS
FIN=0
Return

##############################################################
$OUVRE
# 40728 mm 04.07
Local    Char     RESOL(10)
Local    Integer  TYL
Local    Char     TITANO(GLONDES)
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$RELLENA_BOMRET
Global Integer GORDENBOM : Raz GORDENBOM
Call OUVRE_TRACE(mess(170,195,1)) From LECFIC

#If [M:DIA]NBLIG = 0
#  SAI = 1 : Return
#Endif

# GH 14/09/2015 bug 109434
OK=2
#For I=0 To  [M:DIA]NBLIG-1
   Look [ITF]ITF0 = [M:YEC0]ITMREF;[M:YEC0]STOFCY
   If fstat
      Call AVERTIR([M:YEC0]ITMREF-[M:YEC0]STOFCY-":"-mess(139,197,1),OK) From GESECRAN
#      If OK<>2 : Break : Endif
   Endif
#Next
#If OK<>2
#   SAI=1 : Return
#Endif

#Raz [M:LEC2]
## ouvert localement puis refermé car il sera
## réouvert pour l'affichage avec des ordres de tri différents
Local File BOMRET     [BMR]

# effacer les anciens enregistrements ... Refonte du traitement : 03/01/02
Trbegin [BMR]
Delete [BMR] Where CREUSR = GUSER     : # & BMRUID = adxuid
#Infbox "después de vaciar BOMRET"
If fstat=1  # au lieu de If fstat     21/05/03
    Rollback
#   "Problčme ŕ l'effacement du fichier temporaire"
    ERR_TRA = mess(155,197,1)
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
#    [M:LEC2]LIGNE([M:LEC2]NBLIG) = ERR_TRA
#    [M:LEC2]NBLIG += 1
Else
    Commit
Endif

Raz GORD, GNIV : OK=1
#For nolign=1 To [M:DIA]NBLIG
#  If [M:DIA]PRNFLG = 2
    Trbegin [BMR]
    Gosub HEAD
    If OK = 0
        Rollback
#        Break
    Else
        Commit
    Endif
#  Endif

  GQTY = [M:YEC0]CLCQTY
  # Traitement : Premier niveau, Dernier niv ou Multi niv (Menu Local 256)

#  # Issue 85197 - 2018-05-22 by STLIG : Pass % scrap to every level (1 + % / 100) ..
#  Case [M:DIA]TRT
#     When 1 :     Call TRAITPREM([M:DIA]ITMREF(nolign-1),OK,1)
#     When 2 :     Call TRAITDER([M:DIA]ITMREF(nolign-1),OK,1)
#     When 3 :     Call TRAITMUL([M:DIA]ITMREF(nolign-1),OK,1)
#     When 4 :     Call TRAITMUL([M:DIA]ITMREF(nolign-1),OK,1)
#  Endcase
#  If OK = 0 : Break : Endif
#Next
Call TRAITMUL([M:YEC0]ITMREF,OK,1)

If OK = 0 #| [M:DIA]SCRFLG < 2  # pas d'affichage (04/01/02)
   # 08.06 37275
   SBOITE = BOITE
   BOITE = ""
   # positionner BOITE ŕ vide pour sauter la saisie de fenętre
   # et aller en TERMINE (trace avec erreur bloquante)
Else
   If BOITE = "" : BOITE = SBOITE : Endif            # 08.06 37275
Endif

# Effacer les lignes de fantômes traversés (pour 1er niveau) (09/01/02) 12130
#If [M:DIA]AVATST = 1
  Trbegin [BMR]
  Delete [BMR] Where BMRUID = adxuid(1) & PHAFLG=2 & RETQTY > AVAQTY
  If fstat=1  # au lieu de If fstat     21/05/03
        Rollback
  Else
        Commit
  Endif
#Endif


Close Local File [BMR]
Return

##############################################################
$HEAD
# enregistrement d'entęte (composés sélectionnés) pour l'édition (NIV=0)
Raz [BMR]
[F:BMR]STOFCY = [M:YEC0]STOFCY
[F:BMR]DATREF = [M:YEC0]DATREF
[F:BMR]BOMALT = [M:YEC0]BOMALT
#[F:BMR]BOMALTTYP = [M:DIA]BOMALTTYP               # FQ 49980 GA 10/2008
[F:BMR]ITMREF = [M:YEC0]ITMREF
#[F:BMR]RETQTY = [M:DIA]CLCQTY(nolign-1)
[F:BMR]STU    = [M:YEC0]STU
#[F:BMR]TRTCOD = [M:DIA]TRT
[F:BMR]CREUSR = GUSER
[F:BMR]CREDAT = date$
[F:BMR]BMRUID = adxuid(1)
[F:BMR]YORDEN = GORDENBOM
Write [BMR]
If fstat
    OK=0
    ERR_TRA = mess(34,197,1)-[M:YEC0]ITMREF : # "Composé ..."
    ERR_TRA -= mess(13,100,1)-"BOMRET"
    Call ECR_TRACE(ERR_TRA,1) From GESECRAN
#    [M:LEC2]LIGNE([M:LEC2]NBLIG) = ERR_TRA
#    [M:LEC2]NBLIG += 1
Else
  GORDENBOM += 1
Endif
#Infbox " en head"
Return

##############################################################
$BUSCA_ESCANDALLO
# charger différemment selon le type de traitement (ordre...)
Local File BOMRET [BMR] Where CREUSR=GUSER & BMRUID=adxuid(1) & NIV > 0 Order By NIV;ITMREF
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif

# 40728 mm 04.07
Call PARAM("","ECRRESOL",RESOL) From ADOVAL
Case RESOL
 When "1"     : TYL = 100 : # Basse résolution
 When Default : TYL = 115 : # Nombre de caractčres dans une ligne en haute résolution
Endcase
#[M:LEC2]FORMAT = "K:"+num$(TYL)+"X"
##

## chargement des écrans :
#[M:BRH] = [M:DIA]
#
#Raz [M:LECF]
#
## Issue X3-36381
##For nolign=1 To [M:LEC2]NBLIG
##  [M:LECF] = [M:LEC2]
##Next
#Transmask [M:LEC2] To [M:LECF]
#
Raz [M:YEC1]
nolign = 0

#Execsql From "5"  Sql "truncate table " + nomap + ".YTMPEC"

For [BMR]
  # test de la capacité du tableau (bug 7561)  17/01/01
  If nolign = dim([M:YEC1]ITMREF)
     GMESSAGE = mess(26,100,1)    # "tableau plein"
     GERR = 2
     Break
  Endif

  nolign += 1
  [M:YEC1] = [F:BMR]
#  [F:TEC] = [F:BMR]
#  Write [F:TEC]
  If [M:YEC1]LTI(nolign-1)=0 [M:YEC1]LTIUOM(nolign-1) = 0 Endif
Next

[M:YEC1]NBBOM = nolign

Close Local File [BMR]

#Affzo [BRH] : Diszo [BRH]
#If [M:DIA]TRT > 2
#  If [M:DIA]SRTCOD = 1
#    Sorta [M:YEC1]NBBOM [M:YEC1]NBBOM Order By [M:YEC1]ITMREF(indice)
#  Else
#    Sorta [M:YEC1]NBBOM [M:YEC1]NBBOM Order By [M:YEC1]ITMCMP(indice), [M:YEC1]NIV(indice)
#  Endif
#Endif
Affzo [YEC1]
#Affzo [LECF]

#If [M:LECF]NBLIG>0 : # GH 14/09/2015 bug 109434
#   I = find("LECF",ABMSK(1,NBMASK))
#   If I
#       If clalev([F:AWI])=0 : Local File AWINDOW [AWI] : Endif
#       If [F:AWI]WIN<>GBOITE
#          Read [AWI]AWI0 = GBOITE
#       Else
#          fstat=0
#       Endif
#       If !fstat
#          Call TEXTE([F:AWI]INTMSK(I-1),TITANO) From OBJDIV
#          Chgtfd [M:LECF] TITANO-"("+num$([M:LECF]NBLIG)+")"
#       Endif
#   Endif
#Endif
Return

##############################################################
$ECR_BMRMUL
Call DEBTRANS From GLOCK
Trbegin [BMR]

#---------
# 08.06 37159 PE lecture sur clé spécifique
# PE si GPE = 1
GPE = 0
#GPOINT = "BMRUSRKEY"
Gosub  ENTREE From EXEFNC
#---------

If !GPE : Read [BMR]BMR0 = adxuid(1);[F:BOD]CPNITMREF;GNIV : Endif
If !fstat
# 06.05 30724
#      [F:BMR]RETQTY += GQTY
      If [F:BOH]BOMALTTYP = 1
          [F:BMR]RETQTY += GQTY * [F:ITM]SAUSTUCOE
      Else
          [F:BMR]RETQTY += GQTY
      Endif
      If [F:BMR]RETQTY >= [F:BMR]AVAQTY
         [F:BMR]SHTQTY = [F:BMR]RETQTY - [F:BMR]AVAQTY : # qté manquante  mŕj
         Gosub DELAI
      Endif
      # 40295 mm 03.07
      [F:BMR]ITMCMP =  "*"
      [F:BMR]USESTA =  0
      #
      CRE=0
      Rewrite [BMR]
Else
#      Call LECITV2([M:YEC0]STOFCY,[F:BOD]CPNITMREF,ITV_OK) From MFGLIB
      # GA 08/2007 FQ 42632 stock dispo au lieu d'afficher le stock total
      # Call STODISTOT("[F:ITV]",7,7,"",QTDIS) From STKLIB
      # GA 12/2007 FQ 44655 selon rčgle de gestion "Sortie OF"
      # Call STODISTOT("[F:ITV]",7,1,"",QTDIS) From STKLIB
      #Gosub  CALC_QTDIS : # GH 14/09/2015 bug 109434
      If ITV_OK=0 : Gosub  CALC_QTDIS : Else QTDIS=0 : Endif
      Raz [F:BMR]
      [F:BMR]STOFCY = [M:YEC0]STOFCY
      [F:BMR]DATREF = [M:YEC0]DATREF
      [F:BMR]BMRUID = adxuid(1)
      [F:BMR]NIV    = GNIV
      [F:BMR]IMULT  = GORD     : # ordre de parcours
      [F:BMR]TRTCOD = 3
      [F:BMR]BOMALT = [M:YEC0]BOMALT
#      [F:BMR]BOMALTTYP = [M:DIA]BOMALTTYP               # FQ 49980 GA 10/2008
      [F:BMR]ITMREF = [F:BOD]CPNITMREF
      [F:BMR]STU    = [F:ITM]STU
      [F:BMR]PURFLG = [F:ITM]PURFLG
      [F:BMR]MFGFLG = [F:ITM]MFGFLG
      [F:BMR]SCPFLG = [F:ITM]SCPFLG
      [F:BMR]SCSFLG = [F:ITM]SCSFLG
      [F:BMR]PHAFLG = [F:ITM]PHAFLG
      [F:BMR]GENFLG = [F:ITM]GENFLG
      [F:BMR]TOOFLG = [F:ITM]TOOFLG
      [F:BMR]DLVFLG = [F:ITM]DLVFLG
      [F:BMR]SALFLG = [F:ITM]SALFLG
      [F:BMR]INTFLG = [F:ITM]INTFLG
      [F:BMR]TCLCOD = [F:ITM]TCLCOD
      [F:BMR]YORDEN = GORDENBOM
# 06.05 30724
#      [F:BMR]RETQTY = GQTY
      If [F:BOH]BOMALTTYP = 1
          [F:BMR]RETQTY = GQTY * [F:ITM]SAUSTUCOE
      Else
          [F:BMR]RETQTY = GQTY
      Endif
 #     écrire aussi la qté dispo dans la table pour éviter de relire ITV
      [F:BMR]AVAQTY = QTDIS
      If [F:BMR]RETQTY >= QTDIS
           [F:BMR]SHTQTY = [F:BMR]RETQTY - QTDIS : # qté manquante
           Gosub DELAI
      Endif
      # 40295 mm 03.07
      [F:BMR]ITMSTA = [F:ITM]ITMSTA
      [F:BMR]ITMCMP = [F:BOH]ITMREF
      [F:BMR]USESTA = [F:BOH]USESTA
      #
      [F:BMR]CREUSR = GUSER
      [F:BMR]CREDAT = date$
      #---------
      # Issue 119035 GH 23/02/2017 - This entry point was missing for multi-level calculation mode
#      GPOINT = "BMRUSRDATA"
      Gosub  ENTREE From EXEFNC
      #---------
      CRE=1
      Write [BMR]
#Infbox " en ECR_BMRMUL"
Endif
If fstat
   OK=0
   Rollback
   ERR_TRA = mess(35,197,1)-[F:BOD]CPNITMREF : # "Composant ..."
   ERR_TRA -= mess(13,100,1)-"BOMRET"
   Call ECR_TRACE(ERR_TRA,1) From GESECRAN
#   [M:LEC2]LIGNE([M:LEC2]NBLIG) = ERR_TRA
#   [M:LEC2]NBLIG += 1
Else
   Commit
   GORDENBOM += 1
   Gosub ANO_ITF
Endif
Return

##############################################################
$DELAI
# rajout du délai    TB  23/03/2000
# art ni fabriqué,ni fabriqué/acheté ni fantôme : délai OFS si non nul
If [F:BMR]LTI = 0
    Read [ITF]ITF0 = [F:BMR]ITMREF;[F:BMR]STOFCY
    If !fstat
      # FQ 44871 pb si OFS est nul sur [F:ITM] mais pas sur [F:ITF]
      # If [F:BMR]MFGFLG <> 2 & [F:BMR]PHAFLG <> 2 & [F:ITM]OFS <> 0
      #    [F:BMR]LTI    = [F:ITF]OFS : # délai d'achat
      If [F:BMR]MFGFLG <> 2 & [F:BMR]PHAFLG <> 2 & ([F:ITF]OFS>0 | [F:ITM]OFS>0)
       If [F:ITF]OFS>0
          [F:BMR]LTI    = [F:ITF]OFS : # délai d'achat (du site)
       Else
          [F:BMR]LTI    = [F:ITM]OFS : # délai d'achat (général)
       Endif
       [F:BMR]LTIUOM = 1 # jours calendaires
      Else
       [F:BMR]LTI    = [F:ITF]MFGLTI :# délai de fabrication
       [F:BMR]LTIUOM = 2 # jours ouvrés
      Endif
      #Si LTI est tjrs vide on prend le max des 3 (?) !! unité ?
      If [F:BMR]LTI = 0 [F:BMR]LTI = max([F:ITF]MFGLTI,[F:ITF]OFS,[F:ITM]OFS) Endif
    Endif
Endif
Return

##############################################################
$ANO_ITF
If CRE
   Look [ITF]ITF0 = [F:BMR]ITMREF;[F:BMR]STOFCY
   If fstat
      ERR_TRA=[F:BMR]ITMREF-[F:BMR]STOFCY-":"-mess(139,197,1)
#      If !find(ERR_TRA,[M:LEC2]LIGNE(0..[M:LEC2]NBLIG-1))
#        #Call ECR_TRACE(ERR_TRA,1) From GESECRAN
#        [M:LEC2]LIGNE([M:LEC2]NBLIG) = ERR_TRA
#        [M:LEC2]NBLIG += 1
#      Endif
   Endif
Endif
Return

##############################################################
########################################
# Calcul de la qté disponible
# FQ 44655 GA 12/2007
########################################
$CALC_QTDIS
Local Integer WTYPLOC : WTYPLOC = 5

  # Lecture de la rčgle de gestion
  If [F:BOH]BOMALTTYP=1 : # Nomenclature commerciale   TRSTYP=4 Livraison client
     Call LECSRU([M:YEC0]STOFCY,[F:ITM]TCLCOD,4,"","",WRET) From STKLIB
  Elsif [F:BOH]BOMALTTYP=2 : # Nomenclature production TRSTYP=6 Sortie OF
     Call LECSRU([M:YEC0]STOFCY,[F:ITM]TCLCOD,6,"","",WRET) From STKLIB
  Endif
  If WSTA=0 : WSTA=7 : Endif
  Raz WA,WQ,WR # Issue 102216 - 2014-11-12 by ALSHE
  # Statuts autorisés par la rčgle de gestion
  If find([F:SRU]AUZSTA,1,3,5,7) WA=1  Endif
  If find([F:SRU]AUZSTA,2,3,6,7) WQ=1  Endif
  If find([F:SRU]AUZSTA,4,5,6,7) WR=1  Endif
  WSTA = WA+2*WQ+4*WR
  # FQ 59443 ne pas tenir compte des emplacements Clients (stock en pręt)
  #Call STODISTOT("[F:ITV]",7,WSTA,"",QTDIS) From STKLIB
#  Call STODISTOT("[F:ITV]",WTYPLOC,WSTA,"",QTDIS) From STKLIB
Return

##############################################################
$RELLENA_COSTES
Local Integer LCON0 : Raz LCON0

For LCON0=0 To [M:YEC1]NBBOM-1
  # precio medio ponderado
  Raz [F:ITV]
  Read [ITV]ITV0 = [M:YEC1]ITMREF(LCON0);[M:YEC0]STOFCY
  If !fstat Then
    [M:YEC1]AVC(LCON0) = [F:ITV]AVC * [M:YEC1]RETQTY(LCON0)
    Affzo [M:YEC1]AVC(LCON0)
  Endif

  # coste estándar
  Raz [F:ITC]
  Filter [ITC] Where ITMREF=[M:YEC1]ITMREF(LCON0)
&                  & STOFCY=[M:YEC0]STOFCY
&                  & CSTTYP=1
&                  & ITCSTRDAT<=[M:YEC0]DATREF
&                  & ITCENDDAT>=[M:YEC0]DATREF
&                  & UID = 0
  Read [ITC]ITC0 First
  If !fstat Then
    [M:YEC1]ITCSTD(LCON0) = [F:ITC]VLTTOT * [M:YEC1]RETQTY(LCON0)
    Affzo [M:YEC1]ITCSTD(LCON0)
  Endif
  Filter [ITC]

  # coste estándar actualizado
  Raz [F:ITC]
  Filter [ITC] Where ITMREF=[M:YEC1]ITMREF(LCON0)
&                  & STOFCY=[M:YEC0]STOFCY
&                  & CSTTYP=2
&                  & ITCSTRDAT<=[M:YEC0]DATREF
&                  & ITCENDDAT>=[M:YEC0]DATREF
&                  & UID = 0
  Read [ITC]ITC0 First
  If !fstat Then
    [M:YEC1]ITCACT(LCON0) = [F:ITC]VLTTOT * [M:YEC1]RETQTY(LCON0)
    Affzo [M:YEC1]ITCACT(LCON0)
  Endif
  Filter [ITC]
Next
Return

##############################################################
$CALCULA_TOTALES
  [M:YEC1]AVCTOT     = sum([M:YEC1]AVC(0..[M:YEC1]NBBOM-1))
  [M:YEC1]ITCSTDTOT  = sum([M:YEC1]ITCSTD(0..[M:YEC1]NBBOM-1))
  [M:YEC1]ITCACTTOT  = sum([M:YEC1]ITCACT(0..[M:YEC1]NBBOM-1))
  Affzo [M:YEC1]AVCTOT,ITCSTDTOT,ITCACTTOT
Return

##############################################################
$ORDENA_REGISTROS
#Local Char ART : ART = "FIN006"
#Local Integer I : I = 1
  Gosub MODIFICA_COMPUESTO
#  Call ORDENACION(ART,I)
Return

##############################################################
$MODIFICA_COMPUESTO
Local Integer LCON1 : Raz LCON1

For LCON1=0 To [M:YEC1]NBBOM-1
  If [M:YEC1]NIV(LCON1) = 1 Then
    [M:YEC1]ITMCMP(LCON1) = [M:YEC1]ITMREF(LCON1)
    Affzo [M:YEC1]ITMCMP(LCON1)
  Endif
Next

#Sorta [M:YEC1]NBBOM [M:YEC1]NBBOM Order By [M:YEC1]ITMCMP(indice), [M:YEC1]NIV(indice)
Sorta [M:YEC1]NBBOM [M:YEC1]NBBOM Order By [M:YEC1]YORDEN(indice)
Affzo [YEC1]

Return

##############################################################
Subprog ORDENACION(ITM,OK)
Value Char       ITM
Variable Integer OK
Global Integer GINIV, GORD

If clalev([F:TEC1]) = 0 : Local File YTMPEC    [TEC1] : Endif
If clalev([F:TEC2]) = 0 : Local File YTMPEC2   [TEC2] : Endif
Execsql From "5"  Sql "truncate table " + nomap + ".YTMPEC2"
Read [F:TEC1] First
While !fstat
#    SAVQTY   = GQTY : # GH 03/132/2013 bug 94890

#    Read [BOH1]BOH0 = [F:BOD]ITMREF;[F:BOD]BOMALT;[F:BOD]BOMALTTYP
#    If fstat  : Goto NW : Endif

    #SAVQTY   = GQTY : # GH 03/132/2013 bug 94890

    # 41258 Gestion des liens forfait 08.07
    # Il faut tenir compte du code quantité de lien
    # Menu local 226
    # 1 Proportionnel
    # 2 Au Forfait
    # If [F:BOD]LIKQTYCOD = 1
    #  GQTY  = GQTY * [F:BOD]LIKQTY * (1 + [F:BOD]SCA/100) / [F:BOH]BASQTY
    # Else
    #  GQTY  = [F:BOD]LIKQTY
    # Endif

    # GH 09/11/11 bug 77219
#    If [F:ITM1]ITMREF <> [F:BOD]CPNITMREF
#       Read [ITM1]ITM0=[F:BOD]CPNITMREF
#       If fstat : Raz [F:ITM1] : Endif
#    Endif

#    Call LIKQTY(GQTY,[F:ITM1]STU,[F:BOH1]BASQTY,[F:BOD]LIKQTYCOD,
#&              [F:BOD]LIKQTY,[F:BOD]QTYRND,[F:BOD]SCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
#    If LQTNA=0 : # GH 19/12/12 Bug 85968 si la qté avec arrondi rend 0, on refait le calcul sans arrondi
#       GCLE=""
#       Call LIKQTY(GQTY,GCLE,[F:BOH1]BASQTY,[F:BOD]LIKQTYCOD,
#&                 [F:BOD]LIKQTY,[F:BOD]QTYRND,[F:BOD]SCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
#    Endif
#    GQTY = LQTNA
#
    GORD += 1                     # séquence de parcours
    Gosub ECRBOPMUL
    If OK = 0 : Break : Endif

#    Read [ITB]ITB0 = [F:BOD]CPNITMREF;[F:BOD]BOMALT;WLLCTYP
#    If !fstat & [F:ITB]BOMEXIFLG = 2 & [F:BOD]CPNTYP <> 4
#      If [M:BOP0]STOFCY<>""
#         # GH 05/02/2013 bug 85993 prise en ompte du type de suggestion de l'article-site
#         If [F:ITF]ITMREF <> [F:BOD]CPNITMREF | [F:ITF]STOFCY <> [M:BOP0]STOFCY
#            Read [ITF]ITF0=[F:BOD]CPNITMREF;[M:BOP0]STOFCY
#            If fstat : Raz [F:ITF] : Endif
#         Endif
#         Case [F:ITF]REOCOD
#           When 3  : LBOMALTTYP=2                      : # Production
#           When 5  : LBOMALTTYP=3                      : # Sous-traitance
#           When Default : LBOMALTTYP=[F:BOD]BOMALTTYP  : # Pas de suggestion
#         Endcase
#         If [F:ITM1]PHAFLG <> 2 & !find([F:ITF]REOCOD,1,3,5) : Goto NW : Endif
#      Else
#         LBOMALTTYP=[F:BOD]BOMALTTYP
#      Endif
      Call ORDENACION([F:TEC1]ITMREF,OK)
      #Call TRAITMUL([F:BOD]CPNITMREF,[F:BOD]BOMALT,[F:BOD]BOMALTTYP,OK)
#      If OK = 0 : Break : Endif
#    Endif
    #GQTY = SAVQTY : # GH 03/132/2013 bug 94890
$NW
#    GQTY = SAVQTY : # GH 03/132/2013 bug 94890

    Read [TEC1]YTEC0 Next
Wend
Return

###############################################################################
$ECRBOPMUL
GOK=1 : OK=1
Trbegin [TEC2]
Raz [F:TEC2]
[F:TEC]BOPUID    = adxuid(1)
[F:TEC2]         = [F:TEC1]
#[F:BOP]ITMREF    = [F:ITM]ITMREF        # le composé (sommet) pour rupture
#[F:BOP]STOFCY    = [M:BOP0]STOFCY       # GH 05/02/2013 bug 85993
[F:TEC2]CREUSR    = GUSER
[F:TEC2]CREDATTIM = date$
[F:TEC2]NIV       = GINIV                # niveau dans l'arborescence
[F:TEC2]LIG       = GORD                 # ordre de parcours

#Infbox "ANTES ESCRIBIR"
Write [TEC2]
#Infbox "en ECRBOPMUL"
#Infbox "DESPUES ESCRIBIR"
#Infbox num$(fstat)
If fstat : GOK=0 : Rollback : OK=0 : Return : Endif
Commit
Return

##############################################################
$COLOREA_REGISTROS
Local Integer LCON2
  For LCON2 = 0 To [M:YEC1]NBBOM-1
    Case [M:YEC1]NIV(LCON2)
      When 1        : Chgstl [M:YEC1]NBBOM(LCON2) With "BACKRED"
      When 2        : Chgstl [M:YEC1]NBBOM(LCON2) With "BACKGREEN"
      When 3        : Chgstl [M:YEC1]NBBOM(LCON2) With "BACKYELLOW"
      When 4        : Chgstl [M:YEC1]NBBOM(LCON2) With "BACKORANGE"
      When Default  : Chgstl [M:YEC1]NBBOM(LCON2) With ""
    Endcase
  Next
  Affzo [M:YEC1]5
Return


##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
##############################################################
# Issue 85197 - 2018-05-22 by STLIG : Pass % scrap to every level (1 + % / 100) ..
Subprog TRAITMUL(ITM,OK,SCA)
Value    Char    ITM
Variable Integer OK
Value Decimal SCA

Local Integer I, ITV_OK
Local Decimal LQTN, LQTNA, LQTB, LQTBA, WPRIX
Local Decimal QTDIS : # qté disponible
Local Decimal SQTY : # pour sauvegarder les qtés aux noeuds de l'arborescence
Local Char    ERR_TRA(132)
Local Integer WLLCTYP
Local Integer CRE
Local Integer LSCATIA       # Issue 104942 - 2015-01-06 by CCC

Local Decimal LSCA  # Issue 85197 - 2018-05-22 by STLIG : Convert % scrap parameter (SCA) to % to use in LIKQTY.

Read [ITF]ITF0=ITM;[M:YEC0]STOFCY
#LSCATIA = ([F:ITF]RELSCATIA=2) : # GH 14/09/2015 bug 109434
LSCATIA = (!fstat & [F:ITF]RELSCATIA=2)

# Issue 85980 GA 11/2012 ignore also CPNTYP=7
#&                           BOMSTRDAT <= [M:DIA]DATREF &
#&                          (BOMENDDAT >= [M:DIA]DATREF | BOMENDDAT = [0/0/0]) &
#&                           !find(CPNTYP,4,5,6) # (04.00 sous-produit)

Local File BOMD [BOD] Where ITMREF    = ITM &
&                           BOMALT    = [M:YEC0]BOMALT &
&                           (BOMSTRDAT = [0/0/0] | (BOMSTRDAT <> [0/0/0] & BOMSTRDAT <= [M:YEC0]DATREF)) &
&                           (BOMENDDAT = [0/0/0] | (BOMENDDAT <> [0/0/0] & BOMENDDAT >= [M:YEC0]DATREF)) &
&                           CPNTYP<4

For [BOD]
    I += 1
    If I = 1 GNIV += 1 Endif
    GORD += 1
    SQTY = GQTY

    Read [ITM]ITM0 = [F:BOD]CPNITMREF
    # Point d'entrée pour permettre de ne pas prendre en compte les matičres en élaboration -
    # 37368 mm 03.07
    GPE = 0
    If find("SUBBMR",GENTSTD(1..GNBENTREE))
#        GPOINT = "CHECK_ITMSTA"
        Gosub ENTREE From EXEFNC
    Endif
    If GPE : Goto NXTMUL : Endif

    Read [BOH]BOH0 = [F:BOD]ITMREF;[F:BOD]BOMALT;[F:BOD]BOMALTTYP
    # Point d'entrée pour permettre de ne pas prendre en compte les nomenclatures en élaboration -
    # 37368 mm 03.07
    GPE = 0
    If find("SUBBMR",GENTSTD(1..GNBENTREE))
#        GPOINT = "CHECK_BOHSTA"
        Gosub ENTREE From EXEFNC
    Endif
    If GPE : Break : Endif

    If [F:BOD]LIKQTY <> 0 & GQTY <> 0

      # Issue 85197 - 2018-05-22 by STLIG : If second+ level and "Fixed" component then
      #                                     combine % scrap parameter (SCA) with this component's % scrap and convert to %
      #                                     otherwise merely use this component's % scrap ..
      If (SCA > 1 & [F:BOD]LIKQTYCOD = 2)
        LSCA = SCA * (1 + [F:BOD]SCA / 100)
        LSCA = (LSCA - 1) * 100
      Else
        LSCA = [F:BOD]SCA
      Endif

      # !!!!!!!!!!!!!!!!!!***********************//////////////////////##########################################################################################
      # ESTA FUNCIÓN ES LA QUE CALCULA EL VALOR DEL CAMPO 'CANTIDAD NECESARIA' (RETQTY)##########################################################################
      Call LIKQTY(GQTY,[F:ITM]STU,[F:BOH]BASQTY,[F:BOD]LIKQTYCOD,
&           [F:BOD]LIKQTY,[F:BOD]QTYRND,LSCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
#      Call LIKQTY(GQTY,[F:ITM]STU,[F:BOH]BASQTY,[F:BOD]LIKQTYCOD,
#&           [F:BOD]LIKQTY,[F:BOD]QTYRND,[F:BOD]SCA,LQTN,LQTNA,LQTB,LQTBA) From MFGLIB
# Issue 104942 - 2015-01-05 by CCC : type of quantity has to be chosen according to [ITF]RELSCATIA
#        If dim(GSCAMAJ)>0 & GSCAMAJ = 1 GQTY = LQTNA Else GQTY = LQTBA Endif # Issue 88918
        If LSCATIA
            GQTY = LQTBA
        Else
            GQTY = LQTNA
        Endif
    Else
        GQTY = 0
    Endif

#    If [M:DIA]TRT = 3  # EN NUESTRO CASO VA A SER SIEMPRE = 3 = MULTINIVEL
      Gosub ECR_BMRMUL
#    Else
#      Gosub ECR_BMR  # multi niveau cumulé : 1 enreg /article
#    Endif
    If OK = 0 : Break : Endif
    WLLCTYP = func LLCLIB.LLCTYP([F:BOD]BOMALTTYP)
    Read [ITB]ITB0 = [F:BOD]CPNITMREF;[F:BOD]BOMALT;WLLCTYP
    # on descend la nomenclature que s'il y a du manquant

    If [F:ITB]BOMEXIFLG = 2 & ([F:BMR]RETQTY > [F:BMR]AVAQTY)
#       If [M:DIA]AVATST = 2    # que si l'on teste le stock intermédiaire !
#         If [F:BMR]SHTQTY < GQTY # Corr Bug 17273 (07/02/03)
#           GQTY = [F:BMR]SHTQTY  # affecter la Qté avec le manquant (12130) 03/01/02
#         Endif
#       Endif

       # Issue 85197 - 2018-05-22 by STLIG : Combine % scrap parameter (SCA) with this component's % scrap
       #                                     and pass to next level ..
       SCA = (1 + ([F:BOD]SCA / 100)) * SCA
       Call TRAITMUL([F:BOD]CPNITMREF,OK,SCA)

       If OK = 0 : Break : Endif
    Endif
    GQTY = SQTY
$NXTMUL
Next
If I > 0
    GNIV -=  1
Else
    # "Aucun lien de nomenclature valide " (indicatif, non bloquant)
    ERR_TRA = ITM -":"-mess(140,197,1)     # comme pour dernier niv (09/01/02)
    Call ECR_TRACE(ERR_TRA,0) From GESECRAN
#    [M:LEC2]LIGNE([M:LEC2]NBLIG) = ERR_TRA
#    [M:LEC2]NBLIG += 1
Endif
End

