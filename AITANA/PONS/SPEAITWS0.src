#####################################################################################
# Src: SPEAITWS0
#-------------------------------------------------------------------------------------
# Proyecto: Pons
#-------------------------------------------------------------------------------------
# Version: v12
#-------------------------------------------------------------------------------------
# PO19 - Creaci¾n OF's desde Preactor
# Fecha inicio YAPMP: 27/11/2019
# Desarrollador: JCH
# C¾digo de desarrollo: YPO19
# Descripci¾n del desarrollo: Importaci¾n de ¾rdenes de fabricaci¾n desde Preactor
# Fecha: 27/11/2019
# Codigo Actividad: YPO19
#######################################################################################

##############################################################
######################    ETIQUETAS    #######################
##############################################################
$GENFICH

Local Char    LDIRIMPORT(250) : LDIRIMPORT = filpath("IMPORT_EXPORT","","")
Local Char    LFILE_W(200) : LFILE_W = "OFPreactor"
Local Char    LDATCAB(100)(0..11)
Local Char    LFECHA(10), LHORA(10) : Raz LFECHA, LHORA
Local Char    LSEP(1) : LSEP = ";"  # separador

  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
  LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

  LDIRIMPORT += "\"
  LFILE_W = LDIRIMPORT + LFILE_W + "_" + LFECHA + LHORA + ".txt"

  mkstat = 0 : fstat = 0 : GERRTRACE = 0
  # si se lanza la tarea batch
  If !GSERVEUR Then
    Call TEMPON("Proceso actualizaci¾n de pedidos") From GESECRAN
    Call OUVRE_TRACE ("Proceso actualizaci¾n de pedidos") From LECFIC
  Endif

  # borramos el fichero si existe...
  If filinfo(LFILE_W, 7) > 0 Then
    System "ae_rm " + LFILE_W
  Endif

  Sleep 1

  # abrir el fichero para escritura
  Gosub OPEN_FILE_W

  If !clalev([F:OFP0]) Then : Local File YOFPREACTOR  [F:OFP0] : Endif
  Filter [F:OFP0] Where YIMPMFGFLG <> 2
  Raz LDATCAB
  For [OFP0]
    LDATCAB(1)  = [F:OFP0]MFGFCY                                                           # Planta
    LDATCAB(2)  = num$([F:OFP0]BOMALT)                                                     # Alternativa estruct.
    LDATCAB(3)  = [F:OFP0]ITMREF                                                           # ArtĒculo
    LDATCAB(4)  = [F:OFP0]STRDAT                                                           # Fecha inicial
    LDATCAB(5)  = [F:OFP0]ENDDAT                                                           # Fecha final
    LDATCAB(6)  = num$([F:OFP0]EXTQTY)                                                     # Cantidad prevista
    LDATCAB(7)  = [F:OFP0]MFGNUM                                                           # N·mero de OF
    LDATCAB(8)  = [F:OFP0]ROUNUM                                                           # Ruta lanzada
    LDATCAB(9)  = num$([F:OFP0]ROUALT)                                                     # Alternativa de ruta
    LDATCAB(10) = num$([F:OFP0]YCODACT)                                                    # C¾digo actualizaci¾n
    LDATCAB(11) = num$([F:OFP0]MFGSTA)                                                     # Estado de la OF

    Wrseq LDATCAB(1) + LSEP + LDATCAB(2) + LSEP + LDATCAB(3) + LSEP + LDATCAB(4) + LSEP + LDATCAB(5) + LSEP +
&   LDATCAB(6) + LSEP + LDATCAB(7) + LSEP + LDATCAB(8) + LSEP + LDATCAB(9) + LSEP + LDATCAB(10) + LSEP + LDATCAB(11) Using [ZIMP_W]
  Next
#    # datos de cabecera
##    LDATCAB(0)  = "E"                                                                      # Inidicador
#    LDATCAB(1)  = [F:OFP0]MFGFCY                                                           # Planta
#    LDATCAB(2)  = [F:OFP0]MFGNUM                                                           # N·mero de OF
#    LDATCAB(3)  = [F:OFP0]STRDAT                                                           # Fecha inicial
#    LDATCAB(4)  = [F:OFP0]ENDDAT                                                           # Fecha final
#    LDATCAB(5)  = [F:OFP0]ROUNUM                                                           # Ruta lanzada
#    LDATCAB(6)  = num$([F:OFP0]ROUALT)                                                     # Alternativa de ruta
#    LDATCAB(7)  = num$([F:OFP0]MFGSTA)                                                     # Estado de la OF
##    LDATCAB(8)  = [F:OFP0]YCTPREACTOR                                                      # ?????????????????????????????????
#    LDATCAB(8)  = num$([F:OFP0]MFGMOD)                                                     # Modo lanzamiento
#    LDATCAB(9)  = num$([F:OFP0]BOMALT)                                                     # Alternativa estruct.
#    LDATCAB(10)  = [F:OFP0]ITMREF                                                           # ArtĒculo
#    LDATCAB(11) = num$([F:OFP0]EXTQTY)                                                     # Cantidad prevista
#
#    # datos de lĒnea
#    Wrseq LDATCAB(1) + LSEP + LDATCAB(2) + LSEP + LDATCAB(3) + LSEP + LDATCAB(4) + LSEP + LDATCAB(5) + LSEP +
#&   LDATCAB(6) + LSEP + LDATCAB(7) + LSEP + LDATCAB(8) + LSEP + LDATCAB(9) + LSEP + LDATCAB(10) + LSEP + LDATCAB(11) Using [ZIMP_W]
#  Next

  Gosub CLOSE_FILE_W
Infbox LFILE_W
  Call IMPORTSIL("YPREMFG",LFILE_W) From GIMPOBJ                      # lanza la imporaci¾n de presupuesto de venta

  [F:OFP0]YIMPMFGFLG = 2
  Rewrite [F:OFP0]

  Filter [F:OFP0]

  If clalev([F:OFP0])  Then : Close Local File        [F:OFP0] : Endif

  If !GSERVEUR Then
    Call TEMPOFF() From GESECRAN
    # fin de traza
    Call ECR_TRACE("Fichero " + ctrans(LFILE_W,"\","/") + " generado", 0) From GESECRAN
    Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
    Call FERME_TRACE From LECFIC

    # lectura
    Call LEC_TRACE From LECFIC

    mkstat = 0 : fstat = 0 : GERRTRACE = 0 : GOK = 1
  Endif

Return

########################################################
$OPEN_FILE_W

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE_W Using [ZIMP_W]

Return

########################################################
$CLOSE_FILE_W

Openo Using [ZIMP_W]

Return

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
#####################################################################
# *******************************************************************
#####################################################################
# YPO19
#**
#* Genera nuevas OF's
#*
#* @param PITMREF       > artĒculo
#* @param PSTRDAT       > fecha inicial
#* @param PENDDAT       > fecha final
#* @param PEXTQTY       > cantidad prevista
#* @param PROUNUM       > ruta
#* @param PROUALT       > alternativa
#* @param PYCTPREACTOR  > CT Preactor
#* @param PSTAT1        > error
#* @param PSTAT2        > OF creada
#*!
Subprog SET_MFGPREACTOR(PITMREF,PSTRDAT,PENDDAT,PEXTQTY,PROUNUM,PROUALT,PYCTPREACTOR,PCODACT,PMFGNUM,PSTAT1,PSTAT2)
#Value     Char    PITMREF()
#Value     Date    PSTRDAT
#Value     Date    PENDDAT
#Value     Decimal PEXTQTY
#Value     Char    PROUNUM()
#Value     Integer PROUALT
#Value     Char    PYCTPREACTOR()
#Value     Char    PCODACT()
#Value     Char    PMFGNUM()
#Variable  Char    PSTAT1()
#Variable  Char    PSTAT2()
Value     Char    PITMREF()(1..100)
Value     Date    PSTRDAT(1..100)
Value     Date    PENDDAT(1..100)
Value     Decimal PEXTQTY(1..100)
Value     Char    PROUNUM()(1..100)
Value     Integer PROUALT(1..100)
Value     Char    PYCTPREACTOR()(1..100)
Value     Char    PCODACT()(1..100)
Value     Char    PMFGNUM()(1..100)
Variable  Char    PSTAT1()(1..100)
Variable  Char    PSTAT2()(1..100)

Local     Char    LSEQCODE(20)
Local     Integer LSTAT
Local     Integer J, I, CONT

#  If !clalev([F:OFP0]) Then : Local File YOFPREACTOR  [F:OFP0] : Endif
#  # inserta en la tabla temporal las OF's
#    Call NUMERO("YOFP",nomap,date$,"null",LSEQCODE,LSTAT) From SUBANM
#    Trbegin [F:OFP0]
#    If PCODACT = "C" Then
#      [F:OFP0]MFGNUM      = LSEQCODE
#    Else
#      [F:OFP0]MFGNUM      = PMFGNUM
#    Endif
#Infbox num$([F:OFP0]MFGNUM)
#    [F:OFP0]MFGFCY        = "101"
#    [F:OFP0]BOMALT        = 10
#    [F:OFP0]ITMREF        = PITMREF
#    [F:OFP0]STRDAT        = PSTRDAT
#    [F:OFP0]ENDDAT        = PENDDAT
#    [F:OFP0]EXTQTY        = PEXTQTY
#    [F:OFP0]ROUNUM        = PROUNUM
#    [F:OFP0]ROUALT        = PROUALT
#    [F:OFP0]MFGSTA        = 1
#    [F:OFP0]YCTPREACTOR   = PYCTPREACTOR
#    [F:OFP0]YCODACT      = PCODACT
#    [F:OFP0]MFGMOD        = 1
#    Write [F:OFP0]
#    If !fstat Then
#      Commit
#      PSTAT1(I) = "OK"
#      PSTAT2(I) = LSEQCODE
#    Else
#      Rollback
#      PSTAT1(I) = "FAILURE"
#      PSTAT2(I) = "No se ha podido crear la orden de fabricaci¾n"
#    Endif
#
#  Gosub GENFICH

  # averigua la cantidad de OF's que se pretenden importar
  For J=1 To maxtab(PITMREF)
    If PITMREF(J) <> "" Then : CONT +=1 : Endif
  Next

  # inserta en la tabla temporal las OF's
  For I=1 To CONT
    Trbegin [F:OFP0]
    [F:OFP0]IDPROCESO     = getUuid
    If PCODACT = "C" Then
      Call NUMERO("YOFP",nomap,date$,"null",LSEQCODE,LSTAT) From SUBANM
      [F:OFP0]MFGNUM      = LSEQCODE
    Else
      [F:OFP0]MFGNUM      = PMFGNUM
    Endif
    [F:OFP0]MFGFCY        = "101"
  #  [F:OFP0]BOMALT        = PITMREF
    [F:OFP0]ITMREF        = PITMREF(I)
    [F:OFP0]STRDAT        = PSTRDAT(I)
    [F:OFP0]ENDDAT        = PENDDAT(I)
    [F:OFP0]EXTQTY        = PEXTQTY(I)
    [F:OFP0]ROUNUM        = PROUNUM(I)
    [F:OFP0]ROUALT        = PROUALT(I)
    [F:OFP0]MFGSTA        = 2
    [F:OFP0]YCTPREACTOR   = PYCTPREACTOR(I)
    [F:OFP0]YCODACT       = PCODACT(I)
    [F:OFP0]MFGMOD        = 1
    Write [F:OFP0]
    If !fstat Then
      Commit
      PSTAT1(I) = "OK"
      PSTAT2(I) = LSEQCODE
    Else
      Rollback
      PSTAT1(I) = "FAILURE"
      PSTAT2(I) = "No se ha podido crear la orden de fabricaci¾n"
    Endif
  Next

  Gosub GENFICH
Call MESSAGE(LSEQCODE) From GESECRAN
  If clalev([F:OFP0])  Then : Close Local File        [F:OFP0] : Endif
End

