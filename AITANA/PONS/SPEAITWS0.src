Local Char LSTAT1(200)(1..100), LSTAT2(200)(1..100)
Local Char P1(10)(1..100) : P1(1) = "26063"
Local Char P2(10)(1..100) : P2(1) = "20191210"
Local Char P3(10)(1..100) : P3(1) = "20191217"
Local Integer P4(1..100) : P4(1) = 15
Local Char P5(20)(1..100) : P5(1) = "RU036"
Local Integer P6(1..100) : P6(1) = 7
Local Char P7(10)(1..100) : P7(1) = "L1"
Local Char P8(2)(1..100) : P8(1) = "C"
Local Char P9(25)(1..100) : P9(1) = ""
Infbox P1(1)
Infbox P1(2)
Call SET_MFGPREACTOR(P1(1),P2(1),P3(1),P4(1),P5(1),P6(1),P7(1),P8(1),P9(1),LSTAT1,LSTAT2)
End
