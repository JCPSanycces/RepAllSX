#  Direct EDI Issue  # 112138 US2               ##
##################################################
#pour tests :
#commande de vente :
#CDE-2015-5015 -> Send & receive
#CDE-2015-5010 -> Receive
#CDE-2015-5014 -> Pas d'echange EDI

$ACTION
  Case ACTION
    When "DEBUT"      : Gosub DEBUT
    When "AP_CHOIX" : Gosub AP_CHOIX
    When "BOUTON" : Gosub BOUTON
    When "FIN"      : Gosub FIN
    When Default
  Endcase
Return



$DEBUT
  If PARAM(1) = "" and PARAM(2) = "" and PARAM(3) = ""
    PARAM(1) = "FCSPA0114VEN00000060" #"FCSPA0114VEN00000060" #"FJM1101404VEN0015" # "YMO40110O0000000001"
    PARAM(2) = "2"
    PARAM(3) = "1"
  Endif

  If PARAM(1) <> "" and PARAM(2) <> "" and PARAM(3) <> ""
    [M:EIS0]DOCID     = PARAM(1)
    [M:EIS0]CATTYP    = val(PARAM(2))
    [M:EIS0]CATACT    = val(PARAM(3))
#    [M:EIS0]PARCOD    = "EDICOM" #pour le test
  Endif
  [M:EIS0]TESTFLG      = 1
  [M:EIS0]DUPLICATEFLG = 1

  ANOWRITE = 1
  Global Instance MYEXECEDIRUN Using C_EDIRUN
Return

$AP_CHOIX
  Local Integer I
  I=find(REPONSE,LBOUT)
  If I<1 : Return : Endif
  Case CBOUT(I-1)
      When "A"
        Gosub EXECUTE_EDI
  Endcase
Return


$EXECUTE_EDI
  #rechercher toutes les catťgories valides qui contient le CATTYP et le CATACT = send
  #recuperer les identifiants des champs BPANUM et CPY
  Local Integer I : I = 0
  Local Char WTAB_CATCOD(30)(1..)
  Local Char WTAB_BPANUM(30)(1..)
  Local Char WTAB_CPY(30)(1..)
  Local Char WTAB_CATTRGTAB(30)(1..)
  Local Char WTAB_KEY(30)(1..)

  Gosub GET_CATEGORIES_AND_FIELDS

  #Pour chaque catťgorie trouvťe
  Local Char WBPANUM(30)   : WBPANUM    = ""
  Local Char WCPY(30)      : WCPY       = ""
  Local Integer WERROR_FLG : WERROR_FLG = [V]CST_AYES

  For I = 1 To maxtab(WTAB_CATCOD)
    WBPANUM = ""
    WCPY    = ""
    Gosub GET_FIELDS_VALUES_FOR_CATEGORY

    #Si on a bien recuperť les valeurs, on cherche une correspondance dans EDIBPRCPY
    If WERROR_FLG = [V]CST_ANO
      Local Integer WFOUND : WFOUND = 1
      Local Integer WRUN   : WRUN = 0
      If clalev ([F:EBC]) = 0 : Local File EDIBPRCPY [EBC] : Endif
      If clalev ([F:EBCD]) = 0 : Local File EDIBPRCPYD [EBCD] : Endif

      Link [EBCD] With [EBC]EBC0 ~= [EBCD]BPRNUM; [EBCD]CPY; [EBCD]PARCOD As [MYEBC] Where [EBCD]CATACT = [M:EIS0]CATACT
&       and [EBCD]CATTYP = [M:EIS0]CATTYP
&       and [EBCD]CATCOD = WTAB_CATCOD(I)
&       and [EBC]PARCOD  = [M:EIS0]PARCOD
&       and [EBC]BPRNUM  = WBPANUM
&       and [EBC]CPY     = WCPY
      For [MYEBC]
        #verifier si un EDIRUN existe, si oui -> l'utiliser, sinon -> le creer
        WFOUND = 1
        WRUN = 0
        Local Integer WFLG_NEW : WFLG_NEW = [V]CST_AYES
        Gosub GET_EDIRUN

        #on crťe un nouveau process s'il n'en existe pas
        If WFOUND = 1 # and WRUN = 0 #not found
          Gosub CREATE_EDIRUN
        Endif

        #on execute le process trouvť ou celui tout juste crťť
        If WFOUND = 2 # and WRUN <> 0
          Gosub EXEC_EDIRUN
          Break 2 #on ne recherche pas de ligne de EDIBPRCPY suivante (il ne doit y en avoir qu'une au max)
        Endif

      Next #next EDIBPRCPY
      Close File [EBCD]
      Close File [EBC]
    Else #on a pas trouvť de valeurs pour les categories
      WERROR_FLG = [V]CST_AYES
    Endif

  Next I #next category

  If WFOUND = 1
    WERROR_FLG = [V]CST_AYES
  Endif
  If WERROR_FLG = [V]CST_AYES
#    GMESSAGE = "EDI flow with adequate setup not found"
    GMESSAGE = mess(161,2006,1) #Flow unvailable
    GOK = 0 : GERR = 1
  Endif

Return



$GET_CATEGORIES_AND_FIELDS
  If clalev ([F:ECA]) = 0 : Local File EDICAT [ECA] : Endif
  If clalev ([F:ECAK]) = 0 : Local File EDICATK [ECAK] : Endif
  Local Char WCATCOD_OLD(30) : WCATCOD_OLD = ""
  Link [ECAK] With [ECA]ECA0 = [ECAK]CATCOD As [MYCAT] Where [ECA]VALID = 2
&   and [ECA]CATTYP = [M:EIS0]CATTYP
&   and [ECA]CATACT = [M:EIS0]CATACT
&   Order By [ECA]CATCOD
  For [MYCAT]
    If [ECA]CATCOD <> WCATCOD_OLD
      I = I + 1
      WTAB_CATCOD(I)    = [ECA]CATCOD
      WCATCOD_OLD       = [ECA]CATCOD
      WTAB_CATTRGTAB(I) = [ECA]CATTRGTAB
      WTAB_KEY(I)       = [ECA]DESCRIPT
    Endif
    Case [ECAK]CODE
      When "BPANUM" : WTAB_BPANUM(I) = [ECAK]FLD
      When "CPY"    : WTAB_CPY(I)    = [ECAK]FLD
    Endcase
  Next
  Close File [ECAK]
  Close File [ECA]
Return

$GET_FIELDS_VALUES_FOR_CATEGORY
    #rťcuperer les valeurs des champs utilisťs pour BPANUM et CPY dans la table correspondante du document
    Case [M:EIS0]CATTYP
      When 1       : #Purchase invoice
        If clalev ([F:PIH]) = 0 : Local File PINVOICE [PIH] : Endif
        Read [PIH]PIH0 = [M:EIS0]DOCID
        If !fstat
          WBPANUM = evalue("[PIH]"+WTAB_BPANUM(I))
          WCPY    = evalue("[PIH]"+WTAB_CPY(I))
          WERROR_FLG = [V]CST_ANO
        Else
          #erreur
          WERROR_FLG = [V]CST_AYES
        Endif
#        Close File [PIH]
      When 2       : #Sales invoice
        If clalev ([F:SIV]) = 0 : Local File SINVOICEV [SIV] : Endif
        Read [SIV]SIV0 = [M:EIS0]DOCID
        If !fstat
          WBPANUM = evalue("[SIV]"+WTAB_BPANUM(I))
          WCPY    = evalue("[SIV]"+WTAB_CPY(I))
          WERROR_FLG = [V]CST_ANO
        Else
          #erreur
          WERROR_FLG = [V]CST_AYES
        Endif
#        Close File [SIVX]
      When 3       : #Purchase order
        If clalev ([F:POH]) = 0 : Local File PORDER [POH] : Endif
        Read [POH]POH0 = [M:EIS0]DOCID
        If !fstat
          WBPANUM = evalue("[POH]"+WTAB_BPANUM(I))
          WCPY    = evalue("[POH]"+WTAB_CPY(I))
          WERROR_FLG = [V]CST_ANO
        Else
          #erreur
          WERROR_FLG = [V]CST_AYES
        Endif
#        Close File [POH]
      When 4       : #Sales order
        If clalev ([F:SOH]) = 0 : Local File SORDER [SOH] : Endif
        Read [SOH]SOH0 = [M:EIS0]DOCID
        If !fstat
          WBPANUM = evalue("[SOH]"+WTAB_BPANUM(I))
          WCPY    = evalue("[SOH]"+WTAB_CPY(I))
          WERROR_FLG = [V]CST_ANO
        Else
          #erreur
          WERROR_FLG = [V]CST_AYES
        Endif
#        Close File [SOH]
      When 5       : #Sales delivery
        If clalev ([F:SDH]) = 0 : Local File SDELIVERY [SDH] : Endif
        Read [SDH]SDH0 = [M:EIS0]DOCID
        If !fstat
          WBPANUM = evalue("[SDH]"+WTAB_BPANUM(I))
          WCPY    = evalue("[SDH]"+WTAB_CPY(I))
          WERROR_FLG = [V]CST_ANO
        Else
          #erreur
          WERROR_FLG = [V]CST_AYES
        Endif
#        Close File [SDH]
      When Default : WERROR_FLG = [V]CST_AYES
    Endcase
Return

$GET_EDIRUN
  If clalev ([F:EDR]) = 0 : Local File EDIRUN [EDR] : Endif
  Filter [EDR] Where [EDR]DIRECTFLG = 2
&         and [EDR]FLOCOD = [EBCD]FLOCOD
&         and [EDR]FLOREL = [EBCD]FLOREL
&         and [EDR]CATCOD = WTAB_CATCOD(I)
&         and [EDR]CATTYP = [M:EIS0]CATTYP
&         and [EDR]PARCOD = [M:EIS0]PARCOD
&         and [EDR]TESTFLG = [M:EIS0]TESTFLG
&         and [EDR]DUPLICATEFLG = [M:EIS0]DUPLICATEFLG

  For [EDR]
    WFOUND = 2
    WFLG_NEW = [V]CST_ANO
    WRUN = [EDR]NUM
#    Infbox "Process found, using the direct process #"+num$(WRUN)
    Break
  Next
  Filter [EDR]
  Close File [EDR]
Return

$CREATE_EDIRUN
  #creation d'un nouveau process
  Local Integer WOK, WPOS, J, K
  Local Instance MYEDIRUN Using C_EDIRUN
  MYEDIRUN = NewInstance C_EDIRUN AllocGroup null
  WOK = fmet MYEDIRUN.AINIT()
  MYEDIRUN.CATACT = 1
  MYEDIRUN.DIRECTFLG = 2
  MYEDIRUN.RUNDES = "Direct"-[EBCD]FLOCOD+"~"+[EBCD]FLOREL
  MYEDIRUN.PARCOD = [M:EIS0]PARCOD
  MYEDIRUN.CATCOD = WTAB_CATCOD(I)
  MYEDIRUN.FLOCOD = [EBCD]FLOCOD
  MYEDIRUN.FLOREL = [EBCD]FLOREL
  MYEDIRUN.DUPLICATEFLG = [M:EIS0]DUPLICATEFLG
  MYEDIRUN.TESTFLG = [M:EIS0]TESTFLG


  Local Char WTAB_KEY_SPLITTED(30)(1..)
  Call GETKEYS(WTAB_KEY(I), WTAB_KEY_SPLITTED) #ready for multi keys, but must treat the DOCIID !

  If clalev ([F:ATZ]) = 0 : Local File ATABZON [ATZ] : Endif
  If clalev ([F:ATY]) = 0 : Local File ATYPE [ATY] : Endif
  If clalev ([F:ATX]) = 0 : Local File ATEXTE [ATX] : Endif

  Call DELETELINES(MYEDIRUN, "EDRD") From EDILIBA
  For K = 1 To maxtab(WTAB_KEY_SPLITTED())
    #      #Ajoute les lignes
    WPOS = fmet MYEDIRUN.ADDLINE('EDRD', [V]CST_ALASTPOS)
    MYEDIRUN.EDRD(WPOS).FLD            = WTAB_KEY_SPLITTED(K) #"NUM"
    MYEDIRUN.EDRD(WPOS).MANDATORY      = 2
    MYEDIRUN.EDRD(WPOS).OPERATOR       = 2
    MYEDIRUN.EDRD(WPOS).FLDVAL1        = [M:EIS0]DOCID
    MYEDIRUN.EDRD(WPOS).FLDVAL2        = ""
#        this.EDRD(WPOS).UPDFLG    = MY_EDICAT.ECAD(I).UPDFLG

    #check zone
    Read [ATZ]CODZONE = WTAB_CATTRGTAB(I);WTAB_KEY_SPLITTED(K) #"NUM"
    If fstat
      #Nonexistent Field
#          ASTATUS = fmet this.ASETERROR("FLD",mess(8,124,1),[V]CST_AERROR)
    Else
      #get type
      Read [ATY]CODTYP = [F:ATZ]CODTYP
      If fstat
        #Incorrect Field Type
#            ASTATUS = fmet this.ASETERROR("FLDTYP",mess(10,124,1),[V]CST_AERROR)
      Else
        MYEDIRUN.EDRD(WPOS).FLDTYPTYP = [F:ATY]TYPTYP
        MYEDIRUN.EDRD(WPOS).FLDCODTYP = [F:ATZ]CODTYP
        MYEDIRUN.EDRD(WPOS).FLDNOLIB  = [F:ATZ]NOLIB
      Endif
    Endif
  Next K

#      LogicClose File [ATZ]
#      LogicClose File [ATY]
#      LogicClose File [ATX]



  WOK = fmet MYEDIRUN.AINSERT()
  FreeGroup MYEDIRUN

  #rťcuperer l'id du process crťť
  If clalev ([F:EDR]) = 0 : Local File EDIRUN [EDR] : Endif
  Filter [EDR] Where [EDR]DIRECTFLG = 2 and [EDR]FLOCOD = [EBCD]FLOCOD and [EDR]FLOREL = [EBCD]FLOREL and [EDR]CATCOD = WTAB_CATCOD(I) and [EDR]CATTYP = [M:EIS0]CATTYP
& and [EDR]PARCOD = [M:EIS0]PARCOD
& and [EDR]NUM <> WRUN
  For [EDR]
    WFOUND = 2
    WRUN = [EDR]NUM
#    Infbox "Process not found, creating and using the direct process #"+num$(WRUN)
    Break
  Next
  Filter [EDR]
  Close File [EDR]
Return

$EXEC_EDIRUN
  #utilisation de WRUN
  If (MYEXECEDIRUN <> null) : FreeGroup MYEXECEDIRUN : Endif
  MYEXECEDIRUN = NewInstance C_EDIRUN AllocGroup null
  Local Integer MY_STATUS
  [L]MY_STATUS = fmet MYEXECEDIRUN.AREAD(WRUN)
  If WFLG_NEW = [V]CST_ANO
    MYEXECEDIRUN.EDRD(1).FLDVAL1        = [M:EIS0]DOCID
    WOK = fmet MYEXECEDIRUN.AUPDATE()
  Endif
  Local Char WNUMBATCH(50)
  [L]MY_STATUS = fmet MYEXECEDIRUN.MET_RUN_PROCESS_DIRECT(WNUMBATCH)
  If WNUMBATCH <> ""
    If [L]MY_STATUS <> [V]CST_AOK
#      Errbox("EDI processing failed : log file is"-WNUMBATCH+".tra")
      Errbox(mess(7,2017,1)-":"-mess(9,2007,1)+"/"-mess(50,2006,1)-":"-WNUMBATCH+".tra") #failed / log file
    Else
      Infbox(mess(7,2017,1)-":"-mess(7,2007,1)+"/"-mess(50,2006,1)-":"-WNUMBATCH+".tra") #suceed / log file
    Endif
#        Call LECFIC("/home1/adonix/GX3APP/TRA",WNUMBATCH,"tra") From LECFIC
    Call LECFIC(filpath("","","","","")+"/"+"TRA",WNUMBATCH,"tra") From LECFIC
  Else
    If [L]MY_STATUS <> [V]CST_AOK
      Infbox(mess(7,2017,1)-":"-mess(9,2007,1)+"/"-mess(114,116,1)) #failed / no log file
    Else
      Infbox(mess(7,2017,1)-":"-mess(7,2007,1)+"/"-mess(114,116,1)) #success / no log file
    Endif
  Endif
Return



Subprog GETKEYS(WSTR, WTAB_KEY_SPLITTED)
Value Char WSTR
Variable Char WTAB_KEY_SPLITTED()(1..)
#  Local Char WSTR(100) #: WSTR = "ABC+DEFG+HIJKL+MNO" #WTAB_KEY(I)
  Local Char WTAB_KEY_SPLITTED(30)(1..)
  Local Integer K, L
  L = 0
  For K = 1 To len(WSTR)
    If mid$(WSTR, K, 1) = "+"
      L = L + 1
      WTAB_KEY_SPLITTED(L) = left$(WSTR, K-1)
      WSTR = right$(WSTR, K+1)
    Endif
  Next K
  L = L + 1
  WTAB_KEY_SPLITTED(L) = WSTR
End

Subprog GETKEYVALUES(WSTR, WTAB_KEY_SPLITTED)
Value Char WSTR
Variable Char WTAB_KEY_SPLITTED()(1..)
#  Local Char WSTR(100) #: WSTR = "ABC+DEFG+HIJKL+MNO" #WTAB_KEY(I)
  Local Char WTAB_KEY_SPLITTED(30)(1..)
  Local Integer K, L
  L = 0
  For K = 1 To len(WSTR)
    If mid$(WSTR, K, 1) = "~"
      L = L + 1
      WTAB_KEY_SPLITTED(L) = left$(WSTR, K-1)
      WSTR = right$(WSTR, K+1)
    Endif
  Next K
  L = L + 1
  WTAB_KEY_SPLITTED(L) = WSTR
End


$BOUTON
  If BOUT = "A"
    FIN=1
  Endif
Return


$FIN
  If (MYEXECEDIRUN <> null) : FreeGroup MYEXECEDIRUN : Endif
  Kill MYEXECEDIRUN
Return

