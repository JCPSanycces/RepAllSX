#####################################################################################
# Src: SPEAUTINVD
#-------------------------------------------------------------------------------------
# Proyecto: Estándar
#-------------------------------------------------------------------------------------
# Version: v12
#-------------------------------------------------------------------------------------
# YAVIF - Impresión masiva de facturas
# Fecha inicio YAPMP: 11/09/2019
# Desarrollador: JCH
# Código de desarrollo: YAVIF
# Descripción del desarrollo: Impresión masiva de facturas según la opción de cliente (mail, impresora, EDI)
# Fecha: 111/09/2019
# Codigo Actividad: YAVIF
#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "EXEC"       : Gosub EXEC
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
  Global Char   GCORREO(100)
Return

##############################################################
$EXEC
  Gosub EXEC_TRTAUTINVD From FUNAUTINVD
  Gosub AUTOFACT
  GPE=1

Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
##############################################################
$AUTOFACT
Local Clbfile LWHERE(1) : Raz LWHERE

  LWHERE = "YENVIOBPC <> 2"                                                                                             # la factura todavía no se ha enviado
  If [M:DIA]CPY       <> ""           Then : LWHERE += " and CPY = [M:DIA]CPY"              : Endif                     # sociedad
  If [M:DIA]SALFCY    <> ""           Then : LWHERE += " and SALFCY = [M:DIA]SALFCY"        : Endif                     # planta venta
  If [M:DIA]INVDAT    <> [00/00/0000] Then : LWHERE += " and INVDAT = [M:DIA]INVDAT"        : Endif                     # fecha factura
  If [M:DIA]SIVTYP    <> ""           Then : LWHERE += " and SIVTYP = [M:DIA]SIVTYP"        : Endif                     # tipo factura
  If [M:DIA]SHIDAT    <> [00/00/0000] Then : LWHERE += " and SIHORIDAT <= [M:DIA]SHIDAT"    : Endif                     # fecha albarán
  If [M:DIA]BPCINVDEB <> ""           Then : LWHERE += " and BPCINV >= [M:DIA]BPCINVDEB"    : Endif                     # cliente inicio
  If [M:DIA]BPCINVFIN <> ""           Then : LWHERE += " and BPCINV <= [M:DIA]BPCINVFIN"    : Endif                     # cliente fin
  If [M:DIA]SDHNUMDEB <> ""           Then : LWHERE += " and SIHORINUM >= [M:DIA]SDHNUMDEB" : Endif                     # albaran inicio
  If [M:DIA]SDHNUMFIN <> ""           Then : LWHERE += " and SIHORINUM <= [M:DIA]SDHNUMFIN" : Endif                     # albaran fin

  If !clalev([F:YS0]) Then : Local File SINVOICEV  [F:YS0] : Endif
  If !clalev([F:YB0]) Then : Local File BPCUSTOMER [F:YB0] : Endif
  Filter [F:YS0] Where evalue(LWHERE)
  For [YS0]
    Read [YB0]BPC0 = [F:YS0]BPCINV
    If !fstat Then
      GCORREO = [F:YB0]YMAIENVFRA
      Case [F:YB0]YTIPENVFRA
        When 1        : Call ENVMAIL_SIH([F:YS0]NUM,"Y-FACVENMAS","ENVIOPDF") From SPEYLIB0                                # envía correo
        When 2        : Call ENVDEST_SIH([F:YS0]NUM,"Y-FACVENNOL","IMPRESORA") From SPEYLIB0                               # envía impresora
#        When 3        : Call EXECUTE_EDI([F:YS0]NUM) From SPEYLIB0                                                      # envía EDI
#        When Default  : Call ENVDEST_SIH([F:YS0]NUM,"Y-FACVEN","VISTA") From SPEYLIB0                                   # vista previa
      Endcase
    Endif
    Trbegin [YS0]
    [F:YS0]YENVIOBPC = 2
    Rewrite [F:YS0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next
  If clalev([F:YS0])  Then : Close Local File      [F:YS0] : Endif
  If clalev([F:YB0])  Then : Close Local File      [F:YB0] : Endif

Return

