## After change action of the work order search field
######################################################################################
Subprog AM_MFGNUMF(VALEUR)
Variable Char    VALEUR()
# AITANA.OLD
#  # Passing work order value to filter the grid data
#  Call VALIDATE_REPOPULATE_GRID ([M:SFTL1]FCY,VALEUR,[M:SFTL1]OPENUMF,
#&                            [M:SFTL1]WCRF,[M:SFTL1]WSTF,[M:SFTL1]LSD)
