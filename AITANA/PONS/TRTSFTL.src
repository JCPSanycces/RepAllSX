&                            [M:SFTL1]WCRF,[M:SFTL1]WSTF,[M:SFTL1]LSD,[M:SFTL1]YFECHAFIN, [M:SFTL1]YMANTE)

End
######################################################################################
Subprog C_NUMMAC(VALEUR)
Variable Decimal VALEUR
  If VALEUR<> 0 & func VERIFY_PRIOR_OPERATION = [V]CST_ANO
    VALEUR = 0
  Endif
End
######################################################################################
Subprog AM_NUMMAC(VALEUR)
Variable Decimal VALEUR

  If VALEUR = 0 & [M:SFTL1]WSTTYP(nolign-1) = 1 & [M:SFTL1]CPLLAB(nolign-1) = AVOID.ACHAR
    Call ERREUR(mess(30,2422,1)) From GESECRAN
    VALEUR = 0
    mkstat = 1
    End
  Endif

  If VALEUR <> [M:SFTL1]NUMMAC(nolign-1) : Call SELECTLINE(1) : Endif

End
