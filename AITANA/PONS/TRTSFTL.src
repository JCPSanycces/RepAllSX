End
######################################################################################
Subprog C_CPLWST(VALEUR)
Variable Char    VALEUR()

  Read [MWS]WST0 = VALEUR; [M:SFTL1]FCY
  If fstat
    Call ERREUR(mess(196,193,1)) From GESECRAN
    mkstat = 1
    End
  Else
    If [F:MWS]WSTTYP <> [M:SFTL1]WSTTYP(nolign-1)
       #CT-1797.sn
       #GMESSAGE = VALEUR - mess(47,2422,1) : mkstat=2 : End
       Call ERREUR(func AFNC.MES1(mess(47,2422,1), VALEUR)) From GESECRAN
       mkstat = 2
       End
       #CT-1797.en
    Endif
  Endif

End
######################################################################################
## After change on the Work center
######################################################################################
Subprog AM_CPLWST(VALEUR)
Variable Char    VALEUR()

  Read [MWS]WST0 = VALEUR; [M:SFTL1]FCY
  If fstat
    Call ERREUR(mess(196,193,1)) From GESECRAN
    mkstat = 1
    End
  Endif

  # Get work center group value from work center table filtering by work center and site.
  [M:SFTL1]LWCG(nolign-1) = func SFTLIB.GET_CENTER_GROUP(VALEUR, [M:SFTL1]FCY)
  Affzo [M:SFTL1]LWCG(nolign-1)

  If VALEUR <> [M:SFTL1]CPLWST(nolign-1) : Call SELECTLINE(1) : Endif

End
######################################################################################
Subprog C_CPLLAB(VALEUR)
Variable Char    VALEUR()

  If VALEUR = AVOID.ACHAR & [M:SFTL1]CPLLAB(nolign-1) <> AVOID.ACHAR
    GMESSAGE = mess(48,2422,1) : mkstat=2 : End
  Endif

  If VALEUR <> AVOID.ACHAR & [M:SFTL1]CPLLAB(nolign-1) <> AVOID.ACHAR
   If VALEUR = [M:SFTL1]CPLWST(nolign-1) : GMESSAGE=mess(26,193,1) : mkstat=2 : End : Endif
    Read [MWS]WST0 = VALEUR; [M:SFTL1]FCY
    If fstat
      GMESSAGE = VALEUR - tolower(mess(44,2422,1))
      mkstat=2
      End
    Else
      If [F:MWS]WSTTYP <> 2
         GMESSAGE = VALEUR - mess(4,193,1) : mkstat=2 : End
      Endif
    Endif
  Endif
End
######################################################################################
Subprog AM_CPLLAB(VALEUR)
Variable Char    VALEUR()

  If VALEUR <> [M:SFTL1]CPLLAB(nolign-1) : Call SELECTLINE(1) : Endif

End

######################################################################################
Subprog AS_WONOTE(VALEUR)
Variable Char    VALEUR()

  #Read the correct record into MFG table for the text to display
  Call RAZ_CLOB From ACLOB
  Read [MFG]MFG0=[M:SFTL1]MFGNUM(nolign-1)

End

######################################################################################
Subprog AS_OPNOTE(VALEUR)
Variable Char    VALEUR()

  #Read the correct record into MFO table for the text to display
  Call RAZ_CLOB From ACLOB
  Read [MFO]MFO0=[M:SFTL1]MFGNUM(nolign-1);[M:SFTL1]OPENUM(nolign-1)

End

######################################################################################
Subprog SELECTLINE(I)
Value Decimal I
  If I<>0 & [M:SFTL1]FLGL(nolign-1)<>[V]CST_AYES
    [M:SFTL1]FLGL(nolign-1)=[V]CST_AYES
    Affzo [M:SFTL1]FLGL(nolign-1)
  Endif
End
######################################################################################
#Subprog VALIDATE_REPOPULATE_GRID(FCY, WO, OPENUM, WC, WCG, STRDAT) # AITANA.OLD
Subprog VALIDATE_REPOPULATE_GRID(FCY, WO, OPENUM, WC, WCG, STRDAT, ENDDAT, MANTE) # AITANA.NEW

Value Char FCY
Value Char WO
Value Integer OPENUM
Value Char WC
Value Char WCG
Value Date STRDAT
Value Date ENDDAT
Value Integer MANTE

Local Integer   YESNO : YESNO = [V]CST_AYES

  If find([V]CST_AYES, [M:SFTL1]FLGL)
    Call OUINON(mess(68,2422,1), YESNO) From GESECRAN
    If YESNO <> 2    # No
      mkstat = 2
      End
    Endif
  Endif

  # Passing operation value to filter the grid data
  Call POPULATE_WORK_ORDERS (FCY, WO, OPENUM, WC, WCG, STRDAT, ENDDAT, MANTE)

End
######################################################################################
## Sub program to populate work orders bases on search fields
######################################################################################
#Subprog POPULATE_WORK_ORDERS(STE, WO, OPE, WCG, WC, STARTDATE) # AITANA.OLD 13/10/2020
Subprog POPULATE_WORK_ORDERS(STE, WO, OPE, WCG, WC, STARTDATE, ENDDATE, PMANT) # AITANA.NEW 13/10/2020

Value Char    STE
Value Char    WO
Value Char    WCG
Value Char    WC
Value Integer OPE
Value Date    STARTDATE
Value Date    ENDDATE # AITANA.NEW
Value Integer PMANT   # AITANA.NEW 16/11/2020. Se ańade el parámetro al subp

  Local Char    WCENTERGRP(5), WCENTER(8), LCENTER(8), CRIT(250)
  Local Integer OPERPREC, I, NUMMAC

  Local Integer WMAX
  WMAX = dim([M:SFTL1]MFGNUM)  # Max lines to be displayed

  # Initialize grid
  Raz [M:SFTL1]NBLIG
  Effzo 15

  # Build the criteria for the search
  CRIT = "[MFO]OPESTA<5 & [MFG]MFGSTA=1 & [MFG]SUSFLG=1"
  If STE <> AVOID.ACHAR
    CRIT += " & [MFO]MFGFCY='"+STE+"'"
  Endif
  If WO <> AVOID.ACHAR
    CRIT += " & [MFO]MFGNUM='"+WO+"'"
  Endif
  If OPE <> AVOID.AINT
    CRIT += " & [MFO]OPENUM="+num$(OPE)
  Endif
  If STARTDATE <> AVOID.ADATE
    # CRIT += " & [MFO]OPESTR<=[" + format$(GFMD,STARTDATE) + "]" # AITANA.OLD
    CRIT += " & [MFO]OPESTR<=[" + format$(GFMD,STARTDATE) + "]" # AITANA.NEW
  Endif
  # AITANA.SNEW
  If ENDDATE <> AVOID.ADATE
    CRIT += " & [MFO]OPEEND>=[" + format$(GFMD,ENDDATE) + "]" # AITANA.NEW
  Endif
  If PMANT <> 2  Then
    CRIT += " & [MFG]YMNTOTYP<=2" #
  Else
    CRIT += " & [MFG]YMNTOTYP>2"   # preventivo o correctivo
  Endif
  # AITANA.ENEW
  If GMTKALLMGT = [V]CST_AYES   # Allocation required
    CRIT += " & find([MFG]ALLSTA,3,5)"
  Endif
  If GDOSFAB = [V]CST_AYES      # Printing required
    CRIT += " & [MFG]MFGTRKFLG >=3"
  Endif

  Link [MFO] With [MFG]MFG0~=[MFO]MFGNUM As [SFTMFO]
& Where evalue(CRIT)
& Order By Key KEY1=[MFO]MFGNUM;[MFO]OPENUM

  For [SFTMFO]KEY1
    If I >= WMAX
        Call ERREUR(func AFNC.MES1(mess(37,2422,1),num$(WMAX))) From GESECRAN
        Break
    Endif
    #-----------------------------------------------------------------------------
    # Subcontracting operation is concurrently not supported in our SFT project
    #-----------------------------------------------------------------------------
    Read [F:MWS]WST0 = [F:MFO]EXTWST;[M:SFTL1]FCY
    If [F:MWS]WSTTYP = 3 : Goto NEXT_WO : Endif

    #-------------------------------------------------------------
    # Check if the operation is completed. If yes, do not display
    #-------------------------------------------------------------
    Filter [F:SFTX] Where [F:SFTX]VCRNUM = [SFTMFO]MFGNUM &
&                         [F:SFTX]OPENUM = [SFTMFO]OPENUM &
&                         [F:SFTX]CLEFLG = [V]CST_AYES
    Look [F:SFTX] First
    Filter [F:SFTX]
    If fstat = 0 : Goto NEXT_WO : Endif   # Found

    #-------------------------------------------------------------
    # Tracking WO based on the CTLOPEPRE parameter
    #-------------------------------------------------------------
    If GCTLOPEPRE > 1
      [L]OPERPREC = 0
      # Find the prior operation number
      Filter [SCH] Where MFGNUM = [SFTMFO]MFGNUM & NEXOPENUM = [SFTMFO]OPENUM
      Read [SCH]SCH0 First
      Filter [SCH]
      If !fstat : [L]OPERPREC = [F:SCH]OPENUM : Endif
      If [L]OPERPREC<>0 & [V]GCTLOPEPRE = 3
        # Check if prior marked complete in MFG Operations table
        Filter [MFOP] Where MFGNUM = [SFTMFO]MFGNUM & OPENUM = [L]OPERPREC
        Read [MFOP]MFO0 First
        Filter [MFOP]
        If !fstat & [F:MFOP]OPESTA < 5
          # This operation is not closed in the MFG tables - see if closed in SFTTXN tables
          Filter [F:SFTX] Where [F:SFTX]VCRNUM = [SFTMFO]MFGNUM &
&                               [F:SFTX]OPENUM = [L]OPERPREC &
&                               [F:SFTX]CLEFLG = [V]CST_AYES
          Read [F:SFTX]SFT0 First
          Filter [F:SFTX]
          If fstat <> 0 : Goto NEXT_WO : Endif
        Endif
      Endif
    Endif

    #-------------------------------------------------------------
    # Don't display the WO that is running (SFTTYP=5)
    #-------------------------------------------------------------
    Local Integer T_EMPNUM
    T_EMPNUM = [M:SFTL1]EMPNUM
    If func SFTLIB.ISTEAM(EMPNUM) = [V]CST_AYES
      Local Integer EMPLOYEELIST(1..)
      Call TEAM_LIST (EMPNUM, 'A', EMPLOYEELIST) From SFTLIB
      T_EMPNUM = EMPLOYEELIST(1)
    Endif
    Filter [F:SFTX] Where [F:SFTX]EMPNUM = T_EMPNUM &
&                         [F:SFTX]VCRNUM = [SFTMFO]MFGNUM &
&                         [F:SFTX]OPENUM = [SFTMFO]OPENUM &
&                         [F:SFTX]SFTTYP = 5 &
&                         [F:SFTX]UTCENDDATTIM = AVOID.ADATTIM

    Read [F:SFTX]SFT0 First
    Filter [F:SFTX]
    If fstat = 0 : Goto NEXT_WO : Endif

    #-------------------------------------------------------------
    # Check for Work center and Work center group for filter
    # Need to run even if no filter - need the values for display
    #-------------------------------------------------------------
    # Get the Work Centers from MFG table, overwrite from SFTTXN if found
    [L]WCENTER = [SFTMFO]EXTWST
    [L]LCENTER = [SFTMFO]EXTLAB

    Call GET_SFT_WC_LC([SFTMFO]MFGNUM, [SFTMFO]OPENUM, [F:MWS]WSTTYP, [SFTMFO]EXTWST,
&                      [SFTMFO]EXTLAB, WCENTER, LCENTER) From SFTLIB
    If WC<>AVOID.ACHAR & WC<>[L]WCENTER
      Goto NEXT_WO
    Endif

    #---------------------------------------------------------------
    # If someone else has this operation running at same Workstation
    # Default NUMMAC to 0
    #---------------------------------------------------------------
    NUMMAC=[SFTMFO]EXTWSTNBR
    If [F:MWS]WSTTYP=1 & [SFTMFO]EXTWSTNBR<>0
      Filter [F:SFTX] Where [F:SFTX]VCRNUM = [SFTMFO]MFGNUM & [F:SFTX]OPENUM = [SFTMFO]OPENUM &
&                           [F:SFTX]WCENTER = WCENTER & [F:SFTX]SFTTYP = 5  &
&                           [F:SFTX]UTCENDDATTIM = AVOID.ADATTIM & [F:SFTX]NUMMAC > 0 &
&                           [F:SFTX]EMPNUM  <> T_EMPNUM & [F:SFTX]TEAMNUM <> [M:SFTL1]EMPNUM
      Look [F:SFTX]SFT0 First
      Filter [F:SFTX]
      If !fstat : NUMMAC=0 : Endif
    Endif

    # Get work center group
    If [F:MWS]WST<>[L]WCENTER | [F:MWS]WCRFCY<>[M:SFTL1]FCY
      Read [F:MWS]WST0=[L]WCENTER;[M:SFTL1]FCY
    Endif
    [L]WCENTERGRP = [F:MWS]WCR

    # If the primary labor center is not a machine type, NUMMAC needs to be 0
    If [F:MWS]WSTTYP <> 1 : [L]NUMMAC = 0 : Endif

    If WCG<>AVOID.ACHAR & WCG<>[L]WCENTERGRP
      Goto NEXT_WO
    Endif

    [M:SFTL1]FLGL(I)      = 0
    [M:SFTL1]MFGNUM(I)    = [SFTMFO]MFGNUM
    [M:SFTL1]OPENUM(I)    = [SFTMFO]OPENUM
    [M:SFTL1]OPERPREC(I)  = [L]OPERPREC
    [M:SFTL1]OPEUOM(I)    = [SFTMFO]OPEUOM
    [M:SFTL1]NUMMAC(I)    = [L]NUMMAC
    [M:SFTL1]OPESTR(I)    = [SFTMFO]OPESTR
    [M:SFTL1]OPEEND(I)    = [SFTMFO]OPEEND
    [M:SFTL1]OPESTA(I)    = [SFTMFO]OPESTA
    [M:SFTL1]CPLWST(I)    = [L]WCENTER
    [M:SFTL1]CPLLAB(I)    = [L]LCENTER
    [M:SFTL1]LWCG(I)      = [L]WCENTERGRP
    [M:SFTL1]WSTTYP(I)    = [F:MWS]WSTTYP

    #If no notes - clear out the button
    If [F:MFG]MFGTEX="" : [M:SFTL1]WONOTE(I)=AVOID.ACHAR : Endif
    If [F:MFO]MFOTEX="" : [M:SFTL1]OPNOTE(I)=AVOID.ACHAR : Endif
    I += 1

NEXT_WO:

  Next

  [M:SFTL1]NBLIG = I
  Affzo 15    # Refresh the grid
End
######################################################################################
Funprog VERIFY_PRIOR_OPERATION
Local Integer ALLOW_IT, NOL, I, OPERPREC
Local Char    MFGNUM(50)

  # No check needed
  If [V]GCTLOPEPRE = 1 : End [V]CST_AYES : Endif

  ALLOW_IT    = [V]CST_ANO
  NOL         = nolign-1
  [L]OPERPREC = [M:SFTL1]OPERPREC(NOL)
  [L]MFGNUM   = [M:SFTL1]MFGNUM(NOL)

  # Already checked this line once and is OK
  If [M:SFTL1]PRIOROK(NOL) = [V]CST_AYES : End [V]CST_AYES : Goto FINALIZE : Endif

  # No prior operation
  If [L]OPERPREC=0 : End [V]CST_AYES : Endif

  # Check if prior marked complete in MFG Operations table
  Filter [MFOP] Where MFGNUM=[L]MFGNUM & OPENUM=[L]OPERPREC & [F:MFOP]OPESTA>=5
  Read [MFOP]MFO0 First
  Filter [MFOP]
  If !fstat : ALLOW_IT = [V]CST_AYES : Goto FINALIZE : Endif

  # Check for prior marked complete in SFT tables
  Filter [F:SFTX] Where [F:SFTX]VCRNUM=[L]MFGNUM & [F:SFTX]OPENUM=[L]OPERPREC & [F:SFTX]CLEFLG=[V]CST_AYES
  Read [F:SFTX]SFT0 First
  Filter [F:SFTX]
  If !fstat : ALLOW_IT = [V]CST_AYES : Goto FINALIZE : Endif

  # Prior is not closed anywhere. If Warn, ask before blocking
  Call AVERTIR(mess(22,190,1)-num$([L]OPERPREC),ALLOW_IT) From GESECRAN

FINALIZE:

  If ALLOW_IT = [V]CST_AYES
    #115429 - Enable machine bases on WC type
    If [M:SFTL1]WSTTYP(NOL) <> 2
      Actzo [M:SFTL1]NUMMAC(NOL)
    Endif

    Actzo [M:SFTL1]CPLWST(NOL)
    If [M:SFTL1]CPLLAB(NOL) <> AVOID.ACHAR
      Actzo [M:SFTL1]CPLLAB(NOL)
    Endif

    # We either passed validation or the user selected OK.
    # Set the flag so we don't check again
    [M:SFTL1]PRIOROK(NOL) = [V]CST_AYES
  Else
    Raz [M:SFTL1]FLGL(NOL)
    [M:SFTL1]PRIOROK(NOL) = [V]CST_ANO

    Grizo [M:SFTL1]NUMMAC(NOL)
    Grizo [M:SFTL1]CPLWST(NOL)
    Grizo [M:SFTL1]CPLLAB(NOL)

    Affzo 15
  Endif
End ALLOW_IT
####################################################################################
# Start the setup and/run operations
####################################################################################
Subprog START (SETUP_RUN, EMPTYP)

  Value Char      SETUP_RUN
  Value Integer   EMPTYP
  Local Char      START_WONUM(20)(1..), START_WCENTER(8)(1..), START_LCENTER(8)(1..), START_OPEUOM(3)(1..)
  Local Integer   I, START_COUNT, START_OPENUM(1..), START_NUMMAC(1..), NUM_JOBS, RESTART_COUNT
  Local Integer   OPTYPE, ISETUP_STOP, ISTOP, ICOUNT, ISKIP
  Local Datetime  IDATETIM
  Local Integer   YESNO : YESNO = [V]CST_AYES
  Local Char      ERRMSG(125)
  Local Integer   ERRNUM, MY_STATUS
  Local Integer   EMPTEAMNUM

 # Set operation type (Setup/Run)
  Case SETUP_RUN
    When "s" : OPTYPE = 4 # Setup start
    When "r" : OPTYPE = 5 # Run start
  Endcase

  # Initialization
  START_COUNT   = 0
  ICOUNT        = 0
  RESTART_COUNT = 0
  ISTOP         = [V]CST_ANO
  IDATETIM      = datetime$

  If !clalev([SFTXNS]) : Local File SFTTXN [SFTXNS] : Endif

  # Check if employee is in a team and if he has any team activities running
  Call EMP_TEAM_NUM ([M:SFTL1]EMPNUM, EMPTEAMNUM) From SFTLIB
  If EMPTEAMNUM <> 0   # Employee is part of the team
    Filter [F:SFTXNS] Where (EMPNUM = [M:SFTL1]EMPNUM & TEAMNUM = EMPTEAMNUM) &
&                            SFTTYP <> 1 & UTCENDDATTIM = AVOID.ADATTIM
    Look [F:SFTXNS] First
    If fstat = 0    # Found open team activities...
      Call OUINON(mess(107,2422,1), YESNO) From GESECRAN    # Employee has open activities on a team. Do you want to stop all of the employee’s activities?
      If YESNO <> [V]CST_AYES    # No
        mkstat = 2
        End
      Endif

      # Stop open activities...
      Call STOP_OPEN_ACTIVITIES(EMPTEAMNUM, [M:SFTL1]EMPNUM, ERRNUM, ERRMSG) From SFTLIB
      If ERRNUM
        GERR=1 : GMESSAGE = ERRMSG
        mkstat = 2
        End
      Endif
    Endif
  Endif

  Trbegin [F:SFTXNS]

  # Loop through the activity grid and start the setup/run operation
  For I = 0 To [M:SFTL1]NBLIG-1
    If [M:SFTL1]FLGL(I) = 2   # Selected

      ISKIP       = [V]CST_ANO
      ISETUP_STOP = 0

      # Check if setup operation is currently running
      Gosub CHECK_SETUPS

    Endif
  Next

  # Clear out the Setupstop field if there was no operation
  If START_COUNT = 0 & [L]ERRNUM <> [V]CST_AERROR
    Update [SFTXNS] Where EMPNUM = [M:SFTL1]EMPNUM and SFTTYP <> 1 and SETUPSTOP <> 0 With SETUPSTOP = 0
    If fstat <> 0
      [L]ERRMSG =  mess(68,111,1) # Rewrite field problem
      [L]ERRNUM = [V]CST_AERROR
    Endif
  Endif

  If [L]ERRNUM = [V]CST_AERROR
    Rollback
    Call ERREUR([L]ERRMSG) From GESECRAN
    End
  Else
    Commit
  Endif

  # Start the operations
  If START_COUNT > 0
    Local Instance SFTTXN Using C_SFTTXN
    SFTTXN = NewInstance C_SFTTXN AllocGroup null
    MY_STATUS = fmet SFTTXN.OPERATION_START([M:SFTL1]EMPNUM, [M:SFTL1]FCY, EMPTYP, OPTYPE, IDATETIM,
&                                             START_WONUM, START_OPENUM, START_NUMMAC, START_WCENTER, START_LCENTER,
&                                             START_OPEUOM, ISTOP, START_COUNT, RESTART_COUNT)
  Endif

  LogicClose File [SFTXNS]

End

####################################################################################
$CHECK_SETUPS
  Local Integer TEAMNUM
  Local Integer ERRNUM
  Local Char    ERRMSG(255)

  If func SFTLIB.EMPTYP(EMPNUM) <> 1
    TEAMNUM = [M:SFTL1]EMPNUM
  Endif

  Filter [F:SFTXNS] Where (EMPNUM = [M:SFTL1]EMPNUM | TEAMNUM = [L]TEAMNUM & [L]TEAMNUM <> 0) & SFTTYP = 4 & VCRNUM = [M:SFTL1]MFGNUM(I) &
&                          OPENUM = [M:SFTL1]OPENUM(I) & UTCENDDATTIM = AVOID.ADATTIM
    For [F:SFTXNS]
      If fstat = 0      # Record is existed
        # When the operation is Run start. the message only need to display once
        If OPTYPE = 5  # Run start
          If ICOUNT = 0
            Call OUINON(mess(7,2422,1), YESNO) From GESECRAN    # Selected operation(s) has an active setup.  Do you want to stop the setup to start run activity?
            If YESNO = 2    # Yes
              ISETUP_STOP   = [V]CST_AYES
              ISTOP   = [V]CST_AYES
            Endif
            ICOUNT = 1
          Else
            If  ISTOP = [V]CST_AYES : ISETUP_STOP = [V]CST_AYES : Endif
          Endif
        Else    # Operation is setup start and it is already running
          ISKIP = [V]CST_AYES       # Skip adding this setup record
          ISETUP_STOP = [V]CST_ANO  # Do not stop this setup record
        Endif

        # Update the SETUPSTOP field to check later for restart operation
        [F:SFTXNS]SETUPSTOP = ISETUP_STOP

        # Update the record
        Rewrite[F:SFTXNS]
        If fstat <> 0
          [L]ERRMSG =  mess(68,111,1) # Rewrite field problem
          [L]ERRNUM = [V]CST_AERROR
          Break
        Endif
      Endif
    Next

  If ISKIP = [V]CST_ANO
    # Add the record to a collection
    START_COUNT += 1
    START_WONUM(START_COUNT)    = [M:SFTL1]MFGNUM(I)
    START_OPENUM(START_COUNT)   = [M:SFTL1]OPENUM(I)
    START_NUMMAC(START_COUNT)   = [M:SFTL1]NUMMAC(I)
    START_WCENTER(START_COUNT)  = [M:SFTL1]CPLWST(I)
    START_LCENTER(START_COUNT)  = [M:SFTL1]CPLLAB(I)
    START_OPEUOM(START_COUNT)   = [M:SFTL1]OPEUOM(I)
    # Skip machine only operation but include machine/labor, labor only and labor and labor operations to increase # of activities.
    If [M:SFTL1]CPLLAB(I) <> "" or [M:SFTL1]NUMMAC(I) = 0
      RESTART_COUNT += 1
    Endif
  Endif

Return
#######################################################################################
# AITANA.NEW
Subprog C_MFGNUMF(VALEUR)
Variable Char VALEUR
  #If VALEUR<> 0 & func VERIFY_PRIOR_OPERATION = [V]CST_ANO
  #  VALEUR = 0
  #Endif
End
