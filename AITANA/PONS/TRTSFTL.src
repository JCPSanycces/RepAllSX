# AITANA.OLD
#  # Passing operation value to filter the grid data
#  Call VALIDATE_REPOPULATE_GRID ([M:SFTL1]FCY,[M:SFTL1]MFGNUMF,VALEUR,
#&                            [M:SFTL1]WCRF,[M:SFTL1]WSTF,[M:SFTL1]LSD)

# AITANA.NEW
  # Passing operation value to filter the grid data
