######################################################################################
## After change action of the Start date search field
######################################################################################
Subprog AM_LSD(VALEUR)
Variable Date    VALEUR

#  # Passing start date value
#  Call VALIDATE_REPOPULATE_GRID ([M:SFTL1]FCY,[M:SFTL1]MFGNUMF,[M:SFTL1]OPENUMF,
#&                            [M:SFTL1]WCRF,[M:SFTL1]WSTF,VALEUR)

  # AITANA.NEW
