#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
# Mask Management SFTL1
# AITANA.13/10/2020. Se ańade descripción de campos y filtro nuevo en la busqueda
######################################################################################
$ACTION

  Case ACTION
    When "OUVRE"        : Gosub OUVRE
    When "BOUTON"       : Gosub EXEBOUT
    When "DEBUT"        : Gosub DEBUT
    When "SETBOUT"      : Gosub SETBOUT
    When "FERME"        : Gosub FERME
    When Default
  Endcase
Return

######################################################################################
## After entry window has been displayed (Initialization)
######################################################################################
$DEBUT

  # Clear the Labor screen
  Effzo [M:SFTL1]

  #Assign the Employee ID and Site values passing on from the SFT portal screen
  [M:SFTL1]EMPNUM = val(PARAM(1))
  [M:SFTL1]FCY = PARAM(2)
# Default work center and work center group from the employee table
  #Get the employee default site (if it exists)
  If !clalev([F:TMA]) : Local File TABMAT [TMA] : Endif

  Read [F:TMA]TMA0=[M:SFTL1]EMPNUM

  # Check to see if this is the employee's default site
  # If not, can't use defaults and don't grab default work center and group
  If [F:TMA]DEFFCY <> "" & [F:TMA]DEFFCY = [M:SFTL1]FCY
    [L]DEFAULTSITE  = [V]CST_AYES
    [M:SFTL1]WSTF   = [F:TMA]DEFWST
    [M:SFTL1]WCRF   = [F:TMA]DEFWCR
  Else
    If [F:TMA]DEFWCR <> AVOID.ACHAR | [F:TMA]DEFWST <> AVOID.ACHAR
      # Verify if we can use the default site and group
      If func SFTLIB.VALIDATE_WORK_CENTER([M:SFTL1]FCY, [F:TMA]DEFWCR, [F:TMA]DEFWST) = [V]CST_AYES
        [M:SFTL1]WSTF = [F:TMA]DEFWST
        [M:SFTL1]WCRF = [F:TMA]DEFWCR
      Endif
    Endif
  Endif

  [L]EMPLOYEETYPE = [F:TMA]EMPTYP

  LogicClose File [TMA]

  #Default start date to today date
  [M:SFTL1]LSD = date$

  Affzo [M:SFTL1] # Refresh the Labor screen

# AITANA.SOLD
#  # Populate the grid bases on site passing in from the SFT main screen
#  Call POPULATE_WORK_ORDERS ([M:SFTL1]FCY,[M:SFTL1]MFGNUMF,[M:SFTL1]OPENUMF,
#&                         [M:SFTL1]WCRF,[M:SFTL1]WSTF,[M:SFTL1]LSD)
# AITANA.EOLD
# AITANA.NEW
  Call POPULATE_WORK_ORDERS ([M:SFTL1]FCY,[M:SFTL1]MFGNUMF,[M:SFTL1]OPENUMF,
&                         [M:SFTL1]WCRF,[M:SFTL1]WSTF,[M:SFTL1]LSD, [M:SFTL1]YFECHAFIN, [M:SFTL1]YMANTE)
# AITANA.ENEW
Return
######################################################################################
$SETBOUT
  Raz CHMEN

  CHMEN +="c"
  If find([V]CST_AYES, [M:SFTL1]FLGL) : CHMEN += "rs" : Endif
  If [L]DEFAULTSITE=[V]CST_AYES & !find([V]CST_AYES, [M:SFTL1]FLGL) : CHMEN += "d" : Endif

# AITANA.NEW
  If GSETBOUTSTA = 0 Then
    For I = 0 To [M:SFTL1]NBLIG-1
      Call LECTEXTRA([M:SFTL1]WSTDESAXX(I),"WORKSTATIO","WSTDESAXX",[M:SFTL1]CPLWST(I),[M:SFTL1]FCY ) From ATEXTRA
      Affzo [M:SFTL1]WSTDESAXX(I)
      Call LECTEXTRA([M:SFTL1]WCPLESAXX(I),"WORKSTATIO","WSTDESAXX",[M:SFTL1]CPLLAB(I),[M:SFTL1]FCY ) From ATEXTRA
      Affzo [M:SFTL1]WCPLESAXX(I)
      Read [YMFO]MFO0 = [M:SFTL1]MFGNUM(I);[M:SFTL1]OPENUM(I)
      If !fstat Then
        [M:SFTL1]ROODES(I) = [F:YMFO]ROODES
        Affzo [M:SFTL1]ROODES(I)
        #Affzo [M:SFTL1]ROODES(I)
      Endif
    Next I
    GSETBOUTSTA = 1
  Endif
# AITANA.NEW

Return
######################################################################################
$OUVRE
  Local Integer DEFAULTSITE, EMPLOYEETYPE

  If !clalev([SFTX])  : Local File SFTTXN     [SFTX]  : Endif
  If !clalev([SFTH])  : Local File SFTTXNH    [SFTH]  : Endif
  If !clalev([MFG])   : Local File MFGHEAD    [MFG]   : Endif
  If !clalev([MFO])   : Local File MFGOPE     [MFO]   : Endif
  If !clalev([MFOP])  : Local File MFGOPE     [MFOP]  : Endif
  If !clalev([SCH])   : Local File SCHEDULING [SCH]   : Endif
  If !clalev([MWS])   : Local File WORKSTATIO [MWS]   : Endif

  If !clalev([YMFO]) Then : Local File MFGOPE [YMFO] : Endif

# AITANA.NEW
  Global Integer GSETBOUTSTA : Raz GSETBOUTSTA
# AITANA.NEW
Return
######################################################################################
##  Button or menu item execution
######################################################################################
$EXEBOUT

  Case BOUT
    When "c"      : Gosub RELOAD_FORM
    When "d"      : Gosub DEFAULT_RETURN
    When Default  : Gosub LABORSTART
  Endcase

Return

######################################################################################
## When window, screens and tables are closed.
## Free the instance.
######################################################################################
$FERME

  LogicClose File [SFTX], [SFTH], [MFG], [MFO], [MWS], [MFOP], [SCH], [YMFO]

# AITANA.NEW
  If dim(GSETBOUTSTA) > 0 Then : Kill GSETBOUTSTA : Endif
# AITANA.NEW
Return
######################################################################################
$RELOAD_FORM
# AITANA.OLD
#  # Re-populate the grid
#  Call POPULATE_WORK_ORDERS ([M:SFTL1]FCY,[M:SFTL1]MFGNUMF,[M:SFTL1]OPENUMF,
#&                         [M:SFTL1]WCRF,[M:SFTL1]WSTF,[M:SFTL1]LSD)

# AITANA.NEW
  # Re-populate the grid
  Call POPULATE_WORK_ORDERS ([M:SFTL1]FCY,[M:SFTL1]MFGNUMF,[M:SFTL1]OPENUMF,
&                         [M:SFTL1]WCRF,[M:SFTL1]WSTF,[M:SFTL1]LSD, [M:SFTL1]YFECHAFIN, [M:SFTL1]YMANTE)

Return
######################################################################################
## Return from setting defaults - refresh screen if defaults changed
######################################################################################
$DEFAULT_RETURN

  If !clalev([TMAD]) : Local File TABMAT [TMAD] : Endif

  Read [TMAD]TMA0=[M:SFTL1]EMPNUM

  # The default work center or work center group were updated - re-load the screen
  If ([M:SFTL1]WCRF<>[F:TMAD]DEFWCR) | ([M:SFTL1]WSTF<>[F:TMAD]DEFWST)
    [M:SFTL1]WCRF = [F:TMAD]DEFWCR
    [M:SFTL1]WSTF = [F:TMAD]DEFWST

    Affzo [M:SFTL1]
# AITANA.OLD
#    # Populate the grid bases on site passing in from the SFT main screen
#    Call POPULATE_WORK_ORDERS ([M:SFTL1]FCY,[M:SFTL1]MFGNUMF,[M:SFTL1]OPENUMF,
#&                              [M:SFTL1]WCRF,[M:SFTL1]WSTF,[M:SFTL1]LSD)

# AITANA.NEW
   # Populate the grid bases on site passing in from the SFT main screen
    Call POPULATE_WORK_ORDERS ([M:SFTL1]FCY,[M:SFTL1]MFGNUMF,[M:SFTL1]OPENUMF,
&                              [M:SFTL1]WCRF,[M:SFTL1]WSTF,[M:SFTL1]LSD,[M:SFTL1]YFECHAFIN, [M:SFTL1]YMANTE)

  Endif

  LogicClose File [TMAD]

Return

######################################################################################
## Start run or setup task(s)
######################################################################################
$LABORSTART

  Local Integer EMPLOYEELIST(1..)

  # Make sure at least one line was selected on the grid. If not, display a message.
  If !find([V]CST_AYES, [M:SFTL1]FLGL)
    GERR=1 : GMESSAGE = mess(187,7900,1)   # No line selected
    Return
  Endif

  #  Action not allowed if employee active on an exclusive indirect
  If func SFTLIB.EMPLOYEE_ON_BREAK(EMPNUM) = [V]CST_AYES
    #Call ERREUR(mess(18,2422,1)) From GESECRAN
    #CT-1797.sn
    Case [L]EMPLOYEETYPE
      When 1  # Employee
        Call ERREUR(mess(18,2422,1)) From GESECRAN
      When 2  # Detailed Team
        Call ERREUR(mess(122,2422,1)) From GESECRAN
      When 3  # Summary team
        Call ERREUR(mess(121,2422,1)) From GESECRAN
    Endcase
    #CT-1797.en
    Goto EXIT
  Endif

  Call START (BOUT, [L]EMPLOYEETYPE)

EXIT:
  Gosub FERME   # close files

  # Close the Labor page
  FIN=1

Return
######################################################################################
Subprog AVANT_NBLIG

  If [M:SFTL1]CPLLAB(nolign-1) = AVOID.ACHAR
    Grizo [M:SFTL1]CPLLAB(nolign-1)
  Else
    Actzo [M:SFTL1]CPLLAB(nolign-1)
  Endif

# 115429-Enable/disable Machines field bases on primary WC type
  If [M:SFTL1]WSTTYP(nolign-1) = 2  # Labor type
    # Raz was setting NUMMAC to 1 instead of 0 for some reason and that needed to be changed.
    [M:SFTL1]NUMMAC(nolign-1) = AVOID.AINT
    Grizo [M:SFTL1]NUMMAC(nolign-1)
  Else
    Actzo [M:SFTL1]NUMMAC(nolign-1)
  Endif

  If [M:SFTL1]WONOTE(nolign-1) = AVOID.ACHAR
    Grizo [M:SFTL1]WONOTE(nolign-1)
  Endif

  If [M:SFTL1]OPNOTE(nolign-1) = AVOID.ACHAR
    Grizo [M:SFTL1]OPNOTE(nolign-1)
  Endif

  Affzo [M:SFTL1]CPLLAB(nolign-1), NUMMAC(nolign-1)

End
######################################################################################
Subprog C_FLGL(VALEUR)
Variable Integer VALEUR
  If VALEUR=[V]CST_AYES & func VERIFY_PRIOR_OPERATION = [V]CST_ANO
    VALEUR = [V]CST_ANO
  Endif

  If VALEUR=[V]CST_AYES & [M:SFTL1]NUMMAC(nolign-1) = 0 & [M:SFTL1]WSTTYP(nolign-1) = 1 & [M:SFTL1]CPLLAB(nolign-1) = AVOID.ACHAR
    Call ERREUR(mess(30,2422,1)) From GESECRAN
    VALEUR = 0
    mkstat = 1
    End
  Endif

  [M:SFTL1]FLGL(nolign-1) = VALEUR
End
######################################################################################
## After change action of the site field
######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
# AITANA.OLD
#  # Passing site value to filter the grid data
#  Call VALIDATE_REPOPULATE_GRID (VALEUR,[M:SFTL1]MFGNUMF,[M:SFTL1]OPENUMF,
#&                               [M:SFTL1]WCRF,[M:SFTL1]WSTF,[M:SFTL1]LSD)

# AITANA.NEW
  # Passing site value to filter the grid data
  Call VALIDATE_REPOPULATE_GRID (VALEUR,[M:SFTL1]MFGNUMF,[M:SFTL1]OPENUMF,
&                               [M:SFTL1]WCRF,[M:SFTL1]WSTF,[M:SFTL1]LSD, [M:SFTL1]YFECHAFIN , [M:SFTL1]YMANTE)

End
