# PO19 - Creaciµn OF's desde Preactor
# Fecha inicio YAPMP: 27/11/2019
# Desarrollador: JCH
# Cµdigo de desarrollo: YPO19
# Descripciµn del desarrollo: Importaciµn de µrdenes de fabricaciµn desde Preactor
# Fecha: 27/11/2019
# Codigo Actividad: YPO19
#######################################################################################

##############################################################
######################    ETIQUETAS    #######################
##############################################################
$GENFICH

Local Char    LDIRIMPORT(250) : LDIRIMPORT = filpath("IMPORT_EXPORT","","")
Local Char    LFILE_W(200) : LFILE_W = "\OFPreactor"
Local Char    LDATCAB(100)(0..11)
Local Char    LFECHA(10), LHORA(10) : Raz LFECHA, LHORA
Local Char    LSEP(1) : LSEP = ";"  # separador
Local Integer LCON0   : LCON0 = CONT

  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
  LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

  LDIRIMPORT += "\"
  LFILE_W = LDIRIMPORT + LFILE_W + "_" + LFECHA + LHORA + ".txt"

#  mkstat = 0 : fstat = 0 : GERRTRACE = 0
  # si se lanza la tarea batch
  If !GSERVEUR Then
    Call TEMPON("Proceso actualizaciµn de pedidos") From GESECRAN
    Call OUVRE_TRACE ("Proceso actualizaciµn de pedidos") From LECFIC
  Endif

  # borramos el fichero si existe...
  If filinfo(LFILE_W, 7) > 0 Then
    System "ae_rm " + LFILE_W
  Endif

  # abrir el fichero para escritura
  Gosub OPEN_FILE_W

  If !clalev([F:OFP0]) Then : Local File YOFPREACTOR  [F:OFP0] : Endif
  Filter [F:OFP0] Where YIMPMFGFLG <> 2
  Raz LDATCAB
  For [OFP0]
    If [F:OFP0]MFGNUM <> "" Then
      LDATCAB(1)  = [F:OFP0]MFGFCY                                                           # Planta
      LDATCAB(2)  = num$([F:OFP0]BOMALT)                                                     # Alternativa estruct.
      LDATCAB(3)  = [F:OFP0]ITMREF                                                           # ArtÚculo
      LDATCAB(4)  = [F:OFP0]STRDAT                                                           # Fecha inicial
      LDATCAB(5)  = [F:OFP0]ENDDAT                                                           # Fecha final
      LDATCAB(6)  = num$([F:OFP0]EXTQTY)                                                     # Cantidad prevista
      LDATCAB(7)  = [F:OFP0]MFGNUM                                                           # Nºmero de OF
      LDATCAB(8)  = [F:OFP0]ROUNUM                                                           # Ruta lanzada
      LDATCAB(9)  = num$([F:OFP0]ROUALT)                                                     # Alternativa de ruta
      LDATCAB(10) = num$([F:OFP0]YCODACT)                                                    # Cµdigo actualizaciµn
      LDATCAB(11) = num$([F:OFP0]MFGSTA)                                                     # Estado de la OF
#      LDATCAB(12) = num$([F:OFP0]MFGMOD)                                                     # Modo lanzamiento
#      LDATCAB(13) = num$([F:OFP0]YOFPREACTOR)                                                # OF Preactor

      Wrseq LDATCAB(1) + LSEP + LDATCAB(2) + LSEP + LDATCAB(3) + LSEP + LDATCAB(4) + LSEP + LDATCAB(5) + LSEP + LDATCAB(6) + LSEP +
&     LDATCAB(7) + LSEP + LDATCAB(8) + LSEP + LDATCAB(9) + LSEP + LDATCAB(10) + LSEP + LDATCAB(11) Using [ZIMP_W]

      Trbegin [OFP0]
      [F:OFP0]YIMPMFGFLG = 2
      Rewrite [F:OFP0]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Else
      Call MESSAGE("El registro n¤ " + num$(LCON0) + " no estÃ bien informado") From GESECRAN
    Endif
    LCON0 -= 1
  Next

  Gosub CLOSE_FILE_W

  Call IMPORTSIL("YPREMFG",LFILE_W) From GIMPOBJ                      # lanza la imporaciµn de presupuesto de venta

  Filter [F:OFP0]
  If clalev([F:OFP0])  Then : Close Local File        [F:OFP0] : Endif

  If !GSERVEUR Then
    Call TEMPOFF() From GESECRAN
    # fin de traza
    Call ECR_TRACE("Fichero " + ctrans(LFILE_W,"\","/") + " generado", 0) From GESECRAN
    Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
    Call FERME_TRACE From LECFIC

#    mkstat = 0 : fstat = 0 : GERRTRACE = 0 : GOK = 1
  Endif

Return

########################################################
$OPEN_FILE_W

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE_W Using [ZIMP_W]

Return

########################################################
$CLOSE_FILE_W

Openo Using [ZIMP_W]

Return

########################################################
$LIMPIA_TABLA
  If !clalev([F:OFP1]) Then : Local File YOFPREACTOR  [F:OFP1] : Endif
  Delete [OFP1] Where MFGNUM = ""
  If clalev([F:OFP1])  Then : Close Local File        [F:OFP1] : Endif
Return

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
#####################################################################
# *******************************************************************
#####################################################################
# YPO19
#**
#* Genera nuevas OF's
#*
#* @param PMFGNUM       > nºmero de OF
#* @param PITMREF       > artÚculo
#* @param PSTRDAT       > fecha inicial
#* @param PSTRTIM       > hora inicial
#* @param PENDDAT       > fecha final
#* @param PENDTIM       > hora final
#* @param PEXTQTY       > cantidad prevista
#* @param PROUNUM       > ruta
#* @param PROUALT       > alternativa
#* @param PYOFPREACTOR  > id. interno de la OF preactor
#* @param PSTAT1        > error
#* @param PSTAT2        > OF creada
#*!
Subprog SET_MFGPREACTOR(PMFGNUM,PITMREF,PSTRDAT,PSTRTIM,PENDDAT,PENDTIM,PEXTQTY,PROUNUM,PROUALT,PYOFPREACTOR,PCODACT,PSTAT1,PSTAT2)
Value     Char    PMFGNUM()(1..100)
Value     Char    PITMREF()(1..100)
Value     Date    PSTRDAT(1..100)
Value     Char    PSTRTIM()(1..100)
Value     Date    PENDDAT(1..100)
Value     Char    PENDTIM()(1..100)
Value     Decimal PEXTQTY(1..100)
Value     Char    PROUNUM()(1..100)
Value     Integer PROUALT(1..100)
Value     Char    PYOFPREACTOR()(1..100)
Value     Char    PCODACT()(1..100)
Variable  Char    PSTAT1()(1..100)
Variable  Char    PSTAT2()(1..100)

Local     Char    LSEQCODE(20)
Local     Integer LSTAT         : Raz LSTAT
Local     Integer J, I, CONT    : Raz J, I, CONT
Local     Integer GENIMPORTSIL  : Raz GENIMPORTSIL

Local Integer M : M = 1
Local Char    LNUMOFCRE(50)(1..)
Local Integer N : N = 1
Local Char    LNUMOFMOD(50)(1..)

  Gosub LIMPIA_TABLA

  If !clalev([F:OFP0]) Then : Local File YOFPREACTOR  [F:OFP0] : Endif

  # averigua la cantidad de OF's que se pretenden importar
  For J=1 To maxtab(PITMREF)
    If PITMREF(J) <> "" Then : CONT +=1 : Endif
  Next

  # inserta en la tabla temporal todas las OF's
  For I=1 To CONT
    # comprueba que si es anulaciµn o modificaciµn, se estÕ pasando el nºmero de OF
    If (PCODACT(I) = "C") or (PCODACT(I) = "A" and PMFGNUM(I) <> "") or (PCODACT(I) = "M" and PMFGNUM(I) <> "") Then
      Trbegin [F:OFP0]
      [F:OFP0]IDPROCESO     = getUuid                                           # cµdigo ºnico
      If PCODACT(I) = "C" Then
        Call NUMERO("YOF","101",date$,"null",LSEQCODE,LSTAT) From SUBANM       # si es creaciµn, se genera un nºmero de OF nuevo
        [F:OFP0]MFGNUM      = LSEQCODE
      Else
        [F:OFP0]MFGNUM      = PMFGNUM(I)                                        # sino se guarda en tabla el que nos pasan
      Endif
      [F:OFP0]MFGFCY        = "101"                                             # planta
      [F:OFP0]BOMALT        = 10                                                # alternativa estruc.
      [F:OFP0]ITMREF        = PITMREF(I)                                        # artÚculo principal
      [F:OFP0]STRDAT        = PSTRDAT(I)                                        # fecha inicial
      [F:OFP0]STRTIM        = PSTRTIM(I)                                        # hora inicial
      [F:OFP0]ENDDAT        = PENDDAT(I)                                        # fecha final
      [F:OFP0]ENDTIM        = PENDTIM(I)                                        # hora final
      [F:OFP0]EXTQTY        = PEXTQTY(I)                                        # cantidad prevista
      [F:OFP0]ROUNUM        = PROUNUM(I)                                        # ruta
      [F:OFP0]ROUALT        = PROUALT(I)                                        # alternativa
      [F:OFP0]MFGSTA        = 2                                                 # estado de la orden
      [F:OFP0]YOFPREACTOR   = PYOFPREACTOR(I)                                   # OF Preactor
      [F:OFP0]YCODACT       = PCODACT(I)                                        # cµdigo actualizaciµn
      [F:OFP0]MFGMOD        = 1                                                 # modo lanzamiento
      Write [F:OFP0]
      If !fstat Then
        Commit
        PSTAT1(I) = "OK"
        If PCODACT(I) = "C" Then
          PSTAT2(I) = LSEQCODE
        Else
          PSTAT2(I) = PMFGNUM(I)
        Endif
        GENIMPORTSIL += 1
      Else
        Rollback
        PSTAT1(I) = "FAILURE"
        PSTAT2(I) = "Error en la operaciµn"
      Endif
    Elsif (PCODACT(I) = "A" and PMFGNUM(I) = "") Then
      PSTAT1(I) = "FAILURE"
      PSTAT2(I) = "Para borrar tienes que indicar un nºmero de OF"
    Elsif (PCODACT(I) = "M" and PMFGNUM(I) = "") Then
      PSTAT1(I) = "FAILURE"
      PSTAT2(I) = "Para modificar tienes que indicar un nºmero de OF"
    Endif

    # guarda el nºmero de OF para creaciµn y modificaciµn
    # se usa a posteriori para aþadir las horas de inicio y fin a las fechas
    If PCODACT(I) = "C" Then
      LNUMOFCRE(M) = [F:OFP0]MFGNUM
      M += 1
    Endif

    If PCODACT(I) = "M" Then
      LNUMOFMOD(N) = [F:OFP0]MFGNUM
      N += 1
    Endif

  Next

  Gosub GENFICH

  If clalev([F:OFP0])  Then : Close Local File        [F:OFP0] : Endif

  # actualiza las fechas STRDAT y ENDDAT con las horas de inicio y fin en creaciµn
  Local Integer P
  For P = 1 To M-1
    Call SET_MFGTIMECRE(LNUMOFCRE(P))
  Next

  # actualiza las fechas STRDAT y ENDDAT con las horas de inicio y fin en modificaciµn
  For P = 1 To N-1
    Call SET_MFGTIMEMOD(LNUMOFMOD(P))
  Next

  Gosub LIMPIA_TABLA

End

#####################################################################
# YPO19
#**
#* Aþade la hora inicial y final a las OF's creadas
#*
#* @param PMFGNUM       > nºmero de OF
#*!
Subprog SET_MFGTIMECRE(PMFGNUM)
Value     Char PMFGNUM()

Local Char HORAINI(9), HORAFIN(9), FECHAINI(8), FECHAFIN(8) : Raz HORAINI, HORAFIN, FECHAINI, FECHAFIN

  If !clalev([F:OFP1]) Then : Local File YOFPREACTOR  [F:OFP1] : Endif
  If !clalev([F:MFC1]) Then : Local File MFGCOST      [F:MFC1] : Endif
  If !clalev([F:MFP1]) Then : Local File MFGPRN       [F:MFP1] : Endif
  If !clalev([F:MFO1]) Then : Local File MFGOPE       [F:MFO1] : Endif
  If !clalev([F:MFG1]) Then : Local File MFGHEAD      [F:MFG1] : Endif
  If !clalev([F:MFI1]) Then : Local File MFGITM       [F:MFI1] : Endif
  If !clalev([F:MFM1]) Then : Local File MFGMAT       [F:MFM1] : Endif
  If !clalev([F:OPS1]) Then : Local File OPERATIONS   [F:OPS1] : Endif
  If !clalev([F:ORD1]) Then : Local File ORDERS       [F:ORD1] : Endif

#Call MESSAGE(PMFGNUM) From GESECRAN

  # obtiene la hora
  Filter [F:OFP1] Where MFGNUM = PMFGNUM Order By CREDATTIM Desc
  Read   [F:OFP1] First
  If !fstat Then
    HORAINI   = [F:OFP1]STRTIM
    HORAFIN   = [F:OFP1]ENDTIM
    FECHAINI  = [F:OFP1]STRDAT
    FECHAFIN  = [F:OFP1]ENDDAT
  Endif

  FECHAINI = left$(FECHAINI,10)
  FECHAFIN = left$(FECHAFIN,10)

  # modifica MFGCOST
  Trbegin [F:MFC1]
  Update  [F:MFC1] Where VCRNUM = PMFGNUM With MFCDAT = FECHAINI + " " + HORAINI
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  # modifica MFGPRN
  Trbegin [F:MFP1]
  Update  [F:MFP1] Where MFGNUM = PMFGNUM With STRDAT = FECHAINI + " " + HORAINI, ENDDAT = FECHAFIN + " " + HORAFIN
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  # modifica MFGOPE
  Trbegin [F:MFO1]
  Update  [F:MFO1] Where MFGNUM = PMFGNUM With INFCAPSTR = FECHAINI + " " + HORAINI, INFCAPEND = FECHAFIN + " " + HORAFIN, OPESTR = FECHAINI + " " + HORAINI,
& OPEEND = FECHAFIN + " " + HORAFIN
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  # modifica MFGHEAD
  Trbegin [F:MFG1]
  Update  [F:MFG1] Where MFGNUM = PMFGNUM With INFCAPSTR = FECHAINI + " " + HORAINI, INFCAPEND = FECHAFIN + " " + HORAFIN, STRDAT = FECHAINI + " " + HORAINI,
& ENDDAT = FECHAFIN + " " + HORAFIN, OBJDAT = FECHAINI + " " + HORAINI, YOFPREACTOR = [F:OFP1]YOFPREACTOR, MFGMOD = [F:OFP1]MFGMOD
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  # modifica MFGITM
  Trbegin [F:MFI1]
  Update  [F:MFI1] Where MFGNUM = PMFGNUM With STRDAT = FECHAINI + " " + HORAINI, ENDDAT = FECHAFIN + " " + HORAFIN
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  # modifica MFGMAT
  Trbegin [F:MFM1]
  Update  [F:MFM1] Where MFGNUM = PMFGNUM With RETDAT = FECHAINI + " " + HORAINI
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  # modifica OPERATIONS
  Trbegin [F:OPS1]
  Update  [F:OPS1] Where MFGNUM = PMFGNUM With INFCAPSTR = FECHAINI + " " + HORAINI, INFCAPEND = FECHAFIN + " " + HORAFIN, OPESTR = FECHAINI + " " + HORAINI,
& OPEEND = FECHAFIN + " " + HORAFIN
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  # modifica ORDERS
  Trbegin [F:ORD1]
  Update  [F:ORD1] Where VCRNUM = PMFGNUM With STRDAT = FECHAINI + " " + HORAINI, ENDDAT = FECHAFIN + " " + HORAFIN
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  If clalev([F:OFP1])  Then : Close Local File        [F:OFP1] : Endif
  If clalev([F:MFC1])  Then : Close Local File        [F:MFC1] : Endif
  If clalev([F:MFP1])  Then : Close Local File        [F:MFP1] : Endif
  If clalev([F:MFO1])  Then : Close Local File        [F:MFO1] : Endif
  If clalev([F:MFG1])  Then : Close Local File        [F:MFG1] : Endif
  If clalev([F:MFI1])  Then : Close Local File        [F:MFI1] : Endif
  If clalev([F:MFM1])  Then : Close Local File        [F:MFM1] : Endif
  If clalev([F:OPS1])  Then : Close Local File        [F:OPS1] : Endif
  If clalev([F:ORD1])  Then : Close Local File        [F:ORD1] : Endif

  Kill HORAINI, HORAFIN, FECHAINI, FECHAFIN

End

#####################################################################
# YPO19
#**
#* Aþade la hora inicial y final a las OF's modificadas
#*
#* @param PMFGNUM       > nºmero de OF
#*!
Subprog SET_MFGTIMEMOD(PMFGNUM)
Value     Char PMFGNUM()

Local Char HORAINI(9), HORAFIN(9), FECHAINI(8), FECHAFIN(8) : Raz HORAINI, HORAFIN, FECHAINI, FECHAFIN

  If !clalev([F:OFP2]) Then : Local File YOFPREACTOR  [F:OFP2] : Endif
  If !clalev([F:MFO2]) Then : Local File MFGOPE       [F:MFO2] : Endif
  If !clalev([F:MFG2]) Then : Local File MFGHEAD      [F:MFG2] : Endif
  If !clalev([F:MFI2]) Then : Local File MFGITM       [F:MFI2] : Endif
  If !clalev([F:MFM2]) Then : Local File MFGMAT       [F:MFM2] : Endif
  If !clalev([F:OPS2]) Then : Local File OPERATIONS   [F:OPS2] : Endif
  If !clalev([F:ORD2]) Then : Local File ORDERS       [F:ORD2] : Endif

  # obtiene la hora
  Filter [F:OFP2] Where MFGNUM = PMFGNUM Order By CREDATTIM Desc
  Read   [F:OFP2] First
  If !fstat Then
    HORAINI   = [F:OFP2]STRTIM
    HORAFIN   = [F:OFP2]ENDTIM
    FECHAINI  = [F:OFP2]STRDAT
    FECHAFIN  = [F:OFP2]ENDDAT
  Endif

  FECHAINI = left$(FECHAINI,10)
  FECHAFIN = left$(FECHAFIN,10)

  # modifica MFGOPE
  Trbegin [F:MFO2]
  Update  [F:MFO2] Where MFGNUM = PMFGNUM With INFCAPSTR = FECHAINI + " " + HORAINI, INFCAPEND = FECHAFIN + " " + HORAFIN, OPESTR = FECHAINI + " " + HORAINI,
& OPEEND = FECHAFIN + " " + HORAFIN
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  # modifica MFGHEAD
  Trbegin [F:MFG2]
  Update  [F:MFG2] Where MFGNUM = PMFGNUM With INFCAPSTR = FECHAINI + " " + HORAINI, INFCAPEND = FECHAFIN + " " + HORAFIN, STRDAT = FECHAINI + " " + HORAINI,
& ENDDAT = FECHAFIN + " " + HORAFIN, OBJDAT = FECHAINI + " " + HORAINI, YOFPREACTOR = [F:OFP2]YOFPREACTOR, MFGMOD = [F:OFP2]MFGMOD
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  # modifica MFGITM
  Trbegin [F:MFI2]
  Update  [F:MFI2] Where MFGNUM = PMFGNUM With STRDAT = FECHAINI + " " + HORAINI, ENDDAT = FECHAFIN + " " + HORAFIN
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  # modifica MFGMAT
  Trbegin [F:MFM2]
  Update  [F:MFM2] Where MFGNUM = PMFGNUM With RETDAT = FECHAINI + " " + HORAINI
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  # modifica OPERATIONS
  Trbegin [F:OPS2]
  Update  [F:OPS2] Where MFGNUM = PMFGNUM With INFCAPSTR = FECHAINI + " " + HORAINI, INFCAPEND = FECHAFIN + " " + HORAFIN, OPESTR = FECHAINI + " " + HORAINI,
& OPEEND = FECHAFIN + " " + HORAFIN
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  # modifica ORDERS
  Trbegin [F:ORD2]
  Update  [F:ORD2] Where VCRNUM = PMFGNUM With STRDAT = FECHAINI + " " + HORAINI, ENDDAT = FECHAFIN + " " + HORAFIN
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  If clalev([F:OFP2])  Then : Close Local File        [F:OFP2] : Endif
  If clalev([F:MFO2])  Then : Close Local File        [F:MFO2] : Endif
  If clalev([F:MFG2])  Then : Close Local File        [F:MFG2] : Endif
  If clalev([F:MFI2])  Then : Close Local File        [F:MFI2] : Endif
  If clalev([F:MFM2])  Then : Close Local File        [F:MFM2] : Endif
  If clalev([F:OPS2])  Then : Close Local File        [F:OPS2] : Endif
  If clalev([F:ORD2])  Then : Close Local File        [F:ORD2] : Endif

  Kill HORAINI, HORAFIN, FECHAINI, FECHAFIN

End

