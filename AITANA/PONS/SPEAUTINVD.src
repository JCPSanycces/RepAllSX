######################################################################################
## Etiqueta ańadida por el supervisor (pantalla SAUTINVD) 02/01/2020 12:45:32 (AIT04)
######################################################################################
Subprog C_INVDAT(VALEUR)
Variable Date    VALEUR
# Si la fecha es posterior a hoy, error
If VALEUR > date$
  Errbox "La fecha de facturación no puede ser superior a la fecha actual"
  mkstat = 2
Elsif VALEUR < date$
  # Si la fecha es inferior a hoy, no puede ser anterior a la última factura
  If !clalev([PP1]) : Local File SINVOICE [PP1] : Endif
  Local Date ULTIMA

  Filter [PP1] Where [PP1]INVTYP = 1 and [PP1]FCY = [M]SALFCY Order By [PP1]ACCDAT Desc
  Read [PP1] First
  If fstat = 0
    Errbox "La fecha de facturación no puede ser inferior a la fecha de la factura " + [PP1]NUM + " de fecha " + format$("DZ:DD[/]MM[/]YY",[PP1]ACCDAT)
    mkstat = 2
  Endif
  Filter [PP1]

  Close Local File [PP1]
Endif
End


