##############################################################
$FIN
Local Char LWHERE(250) : Raz LWHERE

  LWHERE = "YENVIOBPC <> 2"                                                                                          # la factura todavía no se ha enviado
  If [M:DIA]CPY       <> ""           Then : LWHERE += " and CPY = [M:DIA]CPY"           : Endif                     # sociedad
  If [M:DIA]SALFCY    <> ""           Then : LWHERE += " and SALFCY = [M:DIA]SALFCY"     : Endif                     # planta venta
  If [M:DIA]INVDAT    <> ""           Then : LWHERE += " and INVDAT = [M:DIA]SALFCY"     : Endif                     # fecha factura
  If [M:DIA]SIVTYP    <> ""           Then : LWHERE += " and SIVTYP = [M:DIA]SIVTYP"     : Endif                     # tipo factura
  If [M:DIA]SIHDAT    <> [00/00/0000] Then : LWHERE += " and SIHORIDAT <= [M:DIA]SIHDAT" : Endif                     # fecha albarán
  If [M:DIA]BPCINVDEB <> ""           Then : LWHERE += " and BPCINV >= [M:DIA]BPCINVDEB" : Endif                     # cliente inicio
  If [M:DIA]BPCINVFIN <> ""           Then : LWHERE += " and BPCINV <= [M:DIA]BPCINVFIN" : Endif                     # cliente fin
  If [M:DIA]SDHNUMDEB <> ""           Then : LWHERE += " and SIHORI >= [M:DIA]SDHNUMDEB" : Endif                     # albaran inicio
  If [M:DIA]SDHNUMFIN <> ""           Then : LWHERE += " and SIHORI >= [M:DIA]SDHNUMFIN" : Endif                     # albaran fin

  If !clalev([F:YS0]) Then : Local File SINVOICEV  [F:YS0] : Endif
  If !clalev([F:YB0]) Then : Local File BPCUSTOMER [F:YB0] : Endif
  Filter [F:YS0] Where evalue(LWHERE)
  For [YS0]
    Read [YB0]BPC0 = [F:YS0]BPCINV
    If !fstat Then
      Case [F:YB0]YTIPENVFRA
        When 1 : Gosub ENVIO_MAIL
        When 2 : Gosub ENVIO_IMP
        When 3 : Gosub ENVIO_EDI
      Endcase
    Endif
    Trbegin [YS0]
    [F:YS0]YENVIOBPC = 2
    Write [F:YS0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next
  If clalev([F:YS0])  Then : Close Local File      [F:YS0] : Endif
  If clalev([F:YB0])  Then : Close Local File      [F:YB0] : Endif

Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ENVIO_MAIL
Global Char GCORREO(100)
Local Integer LOKFAC

#  # ELEGIR UNA DE LAS DOS OPCIONES, LA OTRA HAY QUE COMENTARLA
#  # opción 1: si la dirección de correo se obtiene de las direcciones del cliente:
#  Call GET_EMAIL([F:YSIV]BPCINV,[F:YSIV]BPAADD,GCORREO) From SPEYLIB0                                      # dirección de correo del cliente
#  # opción 2: si la dirección de correo se obtiene del campo específico en la tabla BPCUSTOMER
  GCORREO = [F:YB0]YMAIENVFRA
  Call GEN_PDFSIH([F:YS0]NUM,"Y-FACVEN","ENVIOPDF",LOKFAC) From SPEYLIB0                                     # imprime factura

Return

##############################################################
$ENVIO_IMP
Local Integer LOKFAC

  Call GEN_PDFSIH([F:YS0]NUM,"Y-FACVEN","IMPRESORA",LOKFAC) From SPEYLIB0                                     # imprime factura

Return

##############################################################
$ENVIO_EDI
Return

