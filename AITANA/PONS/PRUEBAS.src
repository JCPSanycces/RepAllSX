#<AdxTL>@(#)0.0.0.0 $Revision$ 
If !clalev([F:YPOF]) Then : Local File YOFPREACTOR [F:YPOF] : Endif
Filter [F:YPOF] Where YIMPMFGFLG = 0


Local Integer M : M = 1

For [F:YPOF]
Local Char    LNUMOFCRE(50)(1..100)
  LNUMOFCRE(M) = [F:YPOF]MFGNUM
  M += 1
Next

Filter [F:YPOF]
If clalev([F:YPOF]) Then : Close Local File [F:YPOF] : Endif

  Local Integer P
  For P = 1 To M-1
    Call MESSAGE(LNUMOFCRE(P)) From GESECRAN
  Next

End

