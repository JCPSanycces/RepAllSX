Infbox "INICIO"


#Call ACT_CLIENTCAN_Y_CLIENTEXP()
#Infbox "1"
Call ACT_CLIENTASOE()
#Infbox "2"
#Call ACT_101056_Y_102106()
Infbox "TEMINADO"
End

#######################
#**
#* regulariza apuntes para cuentas con código contable CLIENTEXP y CLIENTCAN desde 01/01/2020 al 08/06/2020
#*
Subprog ACT_CLIENTCAN_Y_CLIENTEXP()
If !clalev([F:DAE0]) Then : Local File GACCENTRYD [F:DAE0] : Endif
If !clalev([F:DAE1]) Then : Local File GACCENTRYD [F:DAE1] : Endif
If !clalev([F:DAA0]) Then : Local File GACCENTRYA [F:DAA0] : Endif
If !clalev([F:BPC0]) Then : Local File BPCUSTOMER [F:BPC0] : Endif

If !clalev([F:YVR3]) Then : Local File YVISREG3   [F:YVR3] : Endif

Local Char    LBPR(30)  : Raz LBPR
Local Char    X(50)     : Raz X
#For X="FVCN-1032000002","FVCN-1032000003","FVCN-1032000004","FVCN-1032000005","FVCN-1032000006","FVCN-1032000007"
#Infbox X
  For [YVR3]
#    Filter [F:DAE0] Where NUM = [F:YVR3]NUM and ACC = '43000000'
    Filter [F:DAE0] Where NUM = [F:YVR3]NUM and ACC = '43000001'
#    Filter [F:DAE0] Where NUM = X and ACC = '43000000'
    Read [F:DAE0] First
    If !fstat Then
      LBPR = [F:DAE0]BPR
      Read [F:BPC0]BPC0 = LBPR
      If !fstat Then

        # cliente CANARIAS
        If [F:BPC0]ACCCOD = "CLIENTCAN"
          # actualiza la CONTRAPARTIDA en GACCENTRYD
          Trbegin [F:DAE0]
          [F:DAE0]OFFACC = '70000003'
          Rewrite [F:DAE0]
          If !fstat Then
            Commit
          Else
            Rollback
          Endif

          # actualiza las cuentas 70000000 a 70000003 en GACCENTRYD
          Filter [F:DAE1] Where NUM = [F:YVR3]NUM and ACC = '70000000'
#          Filter [F:DAE1] Where NUM = X and ACC = '70000000'
          For [DAE1]
            Trbegin [F:DAE1]
            [F:DAE1]ACC = '70000003'
            Rewrite [F:DAE1]
            If !fstat Then
              Commit
            Else
              Rollback
            Endif
          Next
          Filter [F:DAE1]

          # actualiza las cuentas 70000000 a 70000003 en GACCENTRYD
          Filter [F:DAA0] Where NUM = [F:YVR3]NUM
#          Filter [F:DAA0] Where NUM = X
          Read [F:DAA0] First
          If !fstat Then
            Trbegin [F:DAA0]
            [F:DAA0]ACC = '70000003'
            Rewrite [F:DAA0]
            If !fstat Then
              Commit
            Else
              Rollback
            Endif
          Endif
          Filter [F:DAA0]

        # cliente EXPORTACIÓN
        Elsif [F:BPC0]ACCCOD = "CLIENTEXP"
          # actualiza la CONTRAPARTIDA en GACCENTRYD
          Trbegin [F:DAE0]
          [F:DAE0]OFFACC = '70000001'
          Rewrite [F:DAE0]
          If !fstat Then
            Commit
          Else
            Rollback
          Endif

          # actualiza las cuentas 70000000 a 70000003 en GACCENTRYD
          Filter [F:DAE1] Where NUM = [F:YVR3]NUM and ACC = '70000000'
#          Filter [F:DAE1] Where NUM = X and ACC = '70000000'
          For [DAE1]
            Trbegin [F:DAE1]
            [F:DAE1]ACC = '70000001'
            Rewrite [F:DAE1]
            If !fstat Then
              Commit
            Else
              Rollback
            Endif
          Next
          Filter [F:DAE1]

          # actualiza las cuentas 70000000 a 70000003 en GACCENTRYD
          Filter [F:DAA0] Where NUM = [F:YVR3]NUM
#          Filter [F:DAA0] Where NUM = X
          Read [F:DAA0] First
          If !fstat Then
            Trbegin [F:DAA0]
            [F:DAA0]ACC = '70000001'
            Rewrite [F:DAA0]
            If !fstat Then
              Commit
            Else
              Rollback
            Endif
          Endif
          Filter [F:DAA0]


        Endif
      Endif
    Endif
    Filter [F:DAE0]

  Next
#Next

Close Local File [DAE0],[DAE1],[DAA0],[BPC0],[YVR3]
End


#######################
#**
#* regulariza apuntes para cuentas con código contable CLIENTASOE desde 01/01/2020 al 12/06/2020
#*
Subprog ACT_CLIENTASOE()
If !clalev([F:DAE0]) Then : Local File GACCENTRYD [F:DAE0] : Endif
If !clalev([F:DAE1]) Then : Local File GACCENTRYD [F:DAE1] : Endif
If !clalev([F:DAA0]) Then : Local File GACCENTRYA [F:DAA0] : Endif
If !clalev([F:BPC0]) Then : Local File BPCUSTOMER [F:BPC0] : Endif

If !clalev([F:YVR4]) Then : Local File YVISREG4   [F:YVR4] : Endif

Local Integer I         : Raz I
Local Char    LBPR(30)  : Raz LBPR

#  Filter [F:YVR4] Where NUM = 'FVCN-1032000002'
  For [YVR4]
    Filter [F:DAE0] Where NUM = [F:YVR4]NUM and ACC = '43000000'
    Read [F:DAE0] First
    If !fstat Then
      LBPR = [F:DAE0]BPR
      Read [F:BPC0]BPC0 = LBPR
      If !fstat Then

        # cliente CLIENTASOE
        If [F:BPC0]ACCCOD = "CLIENTASOE"
          # actualiza la CONTRAPARTIDA en GACCENTRYD
          Trbegin [F:DAE0]
          [F:DAE0]OFFACC = '70000001'
          Rewrite [F:DAE0]
          If !fstat Then
            Commit
          Else
            Rollback
          Endif

          # actualiza las cuentas 70000000 a 70000003 en GACCENTRYD
          Filter [F:DAE1] Where NUM = [F:YVR4]NUM and ACC = '70000000'
          For [DAE1]
            Trbegin [F:DAE1]
            [F:DAE1]ACC = '70000001'
            Rewrite [F:DAE1]
            If !fstat Then
              Commit
            Else
              Rollback
            Endif
          Next
          Filter [F:DAE1]

          # actualiza las cuentas 70000000 a 70000003 en GACCENTRYD
          Filter [F:DAA0] Where NUM = [F:YVR4]NUM
          Read [F:DAA0] First
          If !fstat Then
            Trbegin [F:DAA0]
            [F:DAA0]ACC = '70000001'
            Rewrite [F:DAA0]
            If !fstat Then
              Commit
            Else
              Rollback
            Endif
          Endif
          Filter [F:DAA0]
        Endif

      Endif
    Endif
    Filter [F:DAE0]

  Next
  Filter [F:YVR4]

Close Local File [DAE0],[DAE1],[DAA0],[BPC0],[YVR4]
End


#######################
#**
#* regulariza apuntes para cuentas de los terceros 101056 y 102106 desde 01/01/2020 al 12/06/2020
#*
Subprog ACT_101056_Y_102106()
If !clalev([F:DAE0]) Then : Local File GACCENTRYD [F:DAE0] : Endif
If !clalev([F:YVR5]) Then : Local File YVISREG5   [F:YVR5] : Endif

  For [YVR5]
    If [F:YVR5]ACC = '43000000' Then
      #Trbegin [F:YVR5]
      #[F:YVR5]ACC = '43400000'
      #Rewrite [F:YVR5]
      #If !fstat Then
      #  Commit
      #Else
      #  Rollback
      #Endif
      Filter [F:DAE0] Where NUM = [F:YVR5]NUM and ACC = '43000000'
          For [DAE0]
            Trbegin [F:DAE0]
            [F:DAE0]ACC = '43400000'
            Rewrite [F:DAE0]
            If !fstat Then
              Commit
            Else
              Rollback
            Endif
          Next
          Filter [F:DAE0]
    Endif
  Next

Close Local File [DAE0],[YVR5]

End

