#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "FILGAUCHE"      : Gosub FILGAUCHE
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$FILGAUCHE
#  Gosub CARGAR_DATOS_DOCORIGEN
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$CARGAR_DATOS_DOCORIGEN
Local Integer I
  If GFLAG <> "SPSEP" and GFLAG <> "SPTRF" and GFLAG <> "STRFC" and GFLAG <> "SPEFC"  Then
  If !clalev([F:HAE0]) Then : Local File GACCENTRY [F:HAE0] : Endif
    For I = 0 To [M:PAY1]NBLIG-1
      Read [HAE0]HAE0 = [M:PAY1]VCRTYP(I);[M:PAY1]VCRNUM(I) #  First
      If fstat=0  Then
          [M:PAY1]YBPRVCR(I) = [F:HAE0]BPRVCR
      Endif
    Next
    Affzo [M:PAY1]
  Elsif GFLAG = "SPSEP" or GFLAG = "SPTRF" or GFLAG = "STRFC" or GFLAG = "SPEFC" Then
    For I = 0 To [M:PAY2]NBLIG-1
        Read [HAE0]HAE0 = [M:PAY2]VCRTYP(I);[M:PAY2]VCRNUM(I) #  First
        If fstat = 0 Then
            [M:PAY2]YBPRVCR(I) = [F:HAE0]BPRVCR
        Endif

      Next
     Affzo [M:PAY2]
  If  clalev([F:HAE0]) Then : Close Local File    [F:HAE0] : Endif
  Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

