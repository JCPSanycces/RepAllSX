# Cˇdigo de desarrollo: PO01
# Descripciˇn del desarrollo: Campos coste STD en estructuras
# Fecha: 08/05/2019
# Codigo Actividad: YPO01
#######################################################################################


$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
    When "LIENS"    : Gosub LIENS
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
$LIENS
# PO01
Local Integer LCON0 : Raz LCON0
Local Integer EJERNUM : Raz EJERNUM
Local Decimal COSSTD  : Raz COSSTD
Local Char    LLEGCPY(50) : Raz LLEGCPY
  Gosub LIENS From SUBBODA
  For LCON0 = 0 To [M:BOD1]NBLIG-1
    Call GET_LEGCPY([M:BOH0]STOFCY,LLEGCPY) From YAITLIB
    Call GET_EJERCICIO(LLEGCPY,1,[M:BOH0]DATREF,EJERNUM) From YAITLIB                        # obtiene el ejercicio para la "Fecha referencia"
    If EJERNUM <> -1 Then
      # llama a la funciˇn que devuelve el coste estßndar del artÝculo
      Call GET_VLTTOT([M:BOD1]CPNITMREF(LCON0),[M:BOH0]STOFCY,[M:BOD1]ECCVALMAJ(LCON0),[M:BOD1]ECCVALMIN(LCON0),EJERNUM,COSSTD) From YAITLIB
      If COSSTD <> -123456789 Then
        [M:BOD1]VLTTOT(LCON0) = COSSTD                                                              # asigna el coste estßndar al campo
        Affzo [M:BOD1]VLTTOT(LCON0)
      Endif
    Endif
  Next
  GPE=1
# PO01
Return

##############################################################
######################    ETIQUETAS    #######################
