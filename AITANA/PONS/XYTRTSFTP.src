#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
######################################################################################
$ACTION
#If GUSER = 'AIT51' Then : Infbox ACTION : Endif
Case ACTION
 When "APRES_MODIF"   :  Gosub APRES_MODIF
 When "AVANT_BOUTON"  :  Gosub AVANT_BOUTON
 When "SETBOUT"       :  Gosub SETBOUT
Endcase
Return


############################################
$SETBOUT
Gosub SETBOUT From TRTSFTP
CHMEN+="M"
Gosub SET_BOUT_SPE From GSAISIE

GPE=1


  If !clalev([YMFO]) Then : Local File MFGOPE [YMFO] : Endif

  For I = 0 To [M:SFTP0]NBLIG
    Read [YMFO]MFO0 = [M:SFTP0]VCRNUM(I);[M:SFTP0]OPENUM(I)

    If !fstat Then
      [M:SFTP0]EXTWST(I) =  [F:YMFO]EXTWST
      Affzo [M:SFTP0]EXTWST(I)
      Call LECTEXTRA([M:SFTP0]EXTWSTSHO(I) ,"WORKSTATIO","WSTDESAXX",[F:YMFO]EXTWST,[M:SFTP0]FCY) From ATEXTRA
      Affzo [M:SFTP0]EXTWSTSHO(I)
      [M:SFTP0]EXTLAB(I) = [F:YMFO]EXTLAB
      Affzo [M:SFTP0]EXTLAB(I)
      Call LECTEXTRA([M:SFTP0]EXTLABSHO(I),"WORKSTATIO","WSTDESAXX",[F:YMFO]EXTLAB,[M:SFTP0]FCY) From ATEXTRA
      Affzo [M:SFTP0]EXTLABSHO(I)
      [M:SFTP0]ROODES(I) = [F:YMFO]ROODES
      Affzo [M:SFTP0]ROODES(I)
    Endif
  Next

Return

############################################
$APRES_MODIF

  If !clalev([YMFO]) Then : Local File MFGOPE [YMFO] : Endif

  For I = 0 To [M:SFTP0]NBLIG
    Read [YMFO]MFO0 = [M:SFTP0]VCRNUM(I);[M:SFTP0]OPENUM(I)

    If !fstat Then
      [M:SFTP0]EXTWST(I) =  [F:YMFO]EXTWST
      Affzo [M:SFTP0]EXTWST(I)
      Call LECTEXTRA([M:SFTP0]EXTWSTSHO(I) ,"WORKSTATIO","WSTDESAXX",[F:YMFO]EXTWST,[M:SFTP0]FCY) From ATEXTRA
      [M:SFTP0]EXTLAB(I) = [F:YMFO]EXTLAB
      Call LECTEXTRA([M:SFTP0]EXTLABSHO(I),"WORKSTATIO","WSTDESAXX",[F:YMFO]EXTLAB,[M:SFTP0]FCY) From ATEXTRA
      Affzo [M:SFTP0]EXTWSTSHO(I)
      Affzo [M:SFTP0]EXTLABSHO(I)
      #Affzo [M:SFTP0]EXTWSTSHO(I)
      #Affzo [M:SFTP0]EXTLABSHO(I)
      [M:SFTP0]ROODES(I) = [F:YMFO]ROODES
      Affzo [M:SFTP0]ROODES(I)


    Endif
  Next

Return

############################################
$AVANT_BOUTON
 If  BOUT = "M" Then : GFLAG = 'PO2' : Endif
Return

######################################################################################
## Etiqueta a鎙dida por el supervisor (pantalla SFTPORTAL) 06/10/2020 15:52:04 (AIT51)
######################################################################################
Subprog AM_EMPNUM(VALEUR)
Variable Decimal VALEUR


End


######################################################################################

######################################################################################
## Etiqueta a鎙dida por el supervisor (pantalla SFTPORTAL) 07/10/2020 09:25:46 (AIT51)
######################################################################################
Subprog AM_EXTWST(VALEUR)
Variable Char    VALEUR()
Call LECTEXTRA([M:SFTP0]EXTWSTSHO(nolign-1) ,"WORKSTATIO","WSTDESAXX",VALEUR,[M:SFTP0]FCY) From ATEXTRA

End

Subprog AM_EXTLAB(VALEUR)
Variable Char    VALEUR()
Call LECTEXTRA([M:SFTP0]EXTLABSHO(nolign-1),"WORKSTATIO","WSTDESAXX",VALEUR,[M:SFTP0]FCY) From ATEXTRA
End


######################################################################################
