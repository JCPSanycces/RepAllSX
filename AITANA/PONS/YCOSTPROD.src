#<AdxTL>@(#)0.0.0.0 $Revision$ 
# ACTUALIZACION DE LOS COSTES DE PRODUCCION
Subprog YCOSTPROD

# Apertura de tablas
If !clalev([PP1]) : Local File YPMVITM    [PP1] : Endif
If !clalev([PP2]) : Local File COMPANY    [PP2] : Endif
If !clalev([PP3]) : Local File ITMCOST    [PP3] : Endif
If !clalev([PP4]) : Local File BOM        [PP4] : Endif
If !clalev([PP5]) : Local File BOMD       [PP5] : Endif
If !clalev([PP6]) : Local File ITMMASTER  [PP6] : Endif
If !clalev([PP7]) : Local File STOCK      [PP7] : Endif
If !clalev([PP8]) : Local File STOJOU     [PP8] : Endif
If !clalev([PP9]) : Local File ITMFACILIT [PP9] : Endif
If !clalev([P10]) : Local File PRECEIPTD  [P10] : Endif
If !clalev([P11]) : Local File PINVOICED  [P11] : Endif

# Declaro variables
Local Decimal COST_PORC   # Porcentaje de incremento definido por sociedad
Local Decimal COST_CP     # Coste producción artículos CP-
Local Char PLANTA   : PLANTA = '101'
Local Char SOCIEDAD : SOCIEDAD = '001'
Local Decimal EXE         # Ejercicio
Local Decimal COST_MP     # Coste producción artículos materia prima
Local Decimal COST_SE     # Coste producción artículos semielaborados
Local Decimal COST_PT     # Coste producción productos terminados


# Llamadas a rutinas
# 1- Saco el % de incremento indicado en la sociedad 001
Read [PP2]CPY0 = SOCIEDAD
If fstat = 0
  COST_PORC = [PP2]YPORCCP
Endif

# 2- Saco el ejercicio actual
Call GETEXE(SOCIEDAD,1,date$,EXE) From CPTSUB

# 3- Para cada artículo de coste, busco su precio medio * porcentaje, y actualizo su coste STD
For [PP6] Where [PP6]TCLCOD = '80000' and left$([F:PP6]ITMREF,3)='CP-' and [PP6]ITMSTA = 1
  # 3.1 Busco el precio medio de venta e incremento el porcentaje definido por sociedad
  COST_CP = 0
  Call GET_COSTE_CP([PP6]ITMREF,COST_PORC,COST_CP)

  # 3.2 Actualizo el coste STD de este artículo CP, de momento solo para la planta 101
  If COST_CP > 0
    Call GET_MAJ_STD([PP6]ITMREF,PLANTA,EXE,COST_CP)

  Endif
Next

# 4 - Actualizo ahora el coste de las materias primas. Sobre las cantidades que tengo en stock, multiplico por el precio de entrada de cada una de ellas
# Gestiono también los envases/embalajes que NO tengan alternativa de ruta en el artículo planta
For [PP6] Where ([PP6]TCLCOD = '31000' or [PP6]TCLCOD = '32700' or [PP6]TCLCOD = '32600') and [PP6]ITMSTA = 1
  # 4.1 Descarto los artículos que sí tengan ruta de fabricación en el artículo planta
  Read [PP9]ITF0 = [PP6]ITMREF;PLANTA
  If fstat = 0
    If [PP9]MFGROUALT <> 0 : Goto NEXT_PP6 : Endif
  Endif

  # 4.2 Calculo el coste de la MP a partir del stock que tengo ahora y del precio del movimiento
  COST_MP = 0
  Call GET_COSTE_MP([PP6]ITMREF,PLANTA,COST_MP)

  # 4.3 Actualizo el coste STD de este artículo, de momento solo para la planta 101
  If COST_MP > 0
    Call GET_MAJ_STD([PP6]ITMREF,PLANTA,EXE,COST_MP)
  Endif

  $NEXT_PP6
Next


# 5 - Gestiono ahora los envases/embalajes que SI tienen alternativa de ruta en el artículo planta como si fueran Semielaborados
# Actualizo ahora el coste de estos artículos a partir de los costes STD de los componentes de las estructuras
For [PP6] Where ([PP6]TCLCOD = '32700' or [PP6]TCLCOD = '32600') and [PP6]ITMSTA = 1
  # 5.1 Descarto los artículos que no tengan ruta de fabricación en el artículo planta
  Read [PP9]ITF0 = [PP6]ITMREF;PLANTA
  If fstat = 0
    If [PP9]MFGROUALT = 0 : Goto NEXT_EEN : Endif
  Endif

  # 5.2 Recorro estructura de alternativa 10 y calculo coste como PxQ de los componentes
  COST_SE = 0
  Call GET_COSTE_BOM([PP6]ITMREF,10,EXE,PLANTA,COST_SE)

  # 5.3 Actualizo el coste STD de este artículo, de momento solo para la planta 101
  If COST_SE > 0
    Call GET_MAJ_STD([PP6]ITMREF,PLANTA,EXE,COST_SE)
  Endif

  $NEXT_EEN
Next


# 6 - Actualizo ahora el coste de los semielaborados a partir de los costes STD de los componentes de las estructuras
For [PP6] Where [PP6]TCLCOD = '34000' and [PP6]ITMSTA = 1
  # 6.1 Recorro estructura de alternativa 10 y calculo coste como PxQ de los componentes
  COST_SE = 0
  Call GET_COSTE_BOM([PP6]ITMREF,10,EXE,PLANTA,COST_SE)

  # 6.2 Actualizo el coste STD de este artículo, de momento solo para la planta 101
  If COST_SE > 0
    Call GET_MAJ_STD([PP6]ITMREF,PLANTA,EXE,COST_SE)
  Endif
Next


# 7 - Actualizo ahora el coste de los PT a partir de los costes STD de los componentes de las estructuras
For [PP6] Where [PP6]TCLCOD = '35000' and [PP6]ITMSTA = 1
  # 7.1 Recorro estructura de alternativa 10 y calculo coste como PxQ de los componentes
  COST_PT = 0
  Call GET_COSTE_BOM([PP6]ITMREF,10,EXE,PLANTA,COST_PT)

  # 7.2 Actualizo el coste STD de este artículo, de momento solo para la planta 101
  If COST_PT > 0
    Call GET_MAJ_STD([PP6]ITMREF,PLANTA,EXE,COST_PT)
  Endif
Next


# Cierre de tablas
Close Local File [PP1],[PP2],[PP3],[PP4],[PP5],[PP6],[PP7],[PP8],[PP9],[P10],[P11]

# Fin
End


############################################################
Subprog GET_COSTE_CP(CP_ITM,CP_PORC,CP_COST)
Value Char CP_ITM
Value Decimal CP_PORC
Variable Decimal CP_COST

Read [PP1]YPMIT0 = CP_ITM
If fstat = 0
  CP_COST = arr(([PP1]PRECIO * CP_PORC / 100),0.0001)
Endif

End


############################################################
Subprog GET_MAJ_STD(MJ_ITM,MJ_FCY,MJ_EXE,MJ_COST)
Value Char MJ_ITM
Value Char MJ_FCY
Value Decimal MJ_EXE
Value Decimal MJ_COST

Filter [PP3] Where [PP3]ITMREF = MJ_ITM and [PP3]STOFCY = MJ_FCY and [PP3]CSTTYP = 1 and [PP3]FIYNUM = MJ_EXE
Read [PP3] Last
If fstat = 0
  [PP3]MATCST(0)    = MJ_COST
  [PP3]MATLEVCST(0) = MJ_COST
  [PP3]MATTOT       = MJ_COST
  [PP3]CSTTOT       = (MJ_COST * [PP3]CLCQTY)
  [PP3]VLTTOT       = (MJ_COST * [PP3]CLCQTY)
  Trbegin [PP3]
    Rewrite [PP3]
  Commit

Endif
Filter [PP3]

End



############################################################
Subprog GET_COSTE_MP(MP_ITM,MP_FCY,MP_COST)
Value Char MP_ITM
Value Char MP_FCY
Variable Decimal MP_COST

Local Decimal SUM_CANT
Local Decimal COST_NUME

# 19/02/20 Cambio modo de cálculo. No vamos a la STOJOU, vamos directamente a las líneas de las recepciones
If 1=2
  For [PP7] Where [PP7]ITMREF = MP_ITM and [PP7]STOFCY = MP_FCY and [PP7]QTYSTU <> 0
    If [PP7]ITMREF = '7540' and [PP7]LOT = 'L201082' : Goto NEXT_MP : Endif
    If [PP7]ITMREF = '5070' and [PP7]LOT = 'L201552' : Goto NEXT_MP : Endif
    Filter [PP8] Where [PP8]ITMREF = [PP7]ITMREF and [PP8]STOFCY = [PP7]STOFCY and [PP8]LOT = [PP7]LOT and ([PP8]VCRTYP = 6 or [PP8]VCRTYP = 19)
    Read [PP8] First
    If fstat = 0
      COST_NUME += [PP8]PRIVAL * [PP7]QTYSTU
      SUM_CANT  += [PP7]QTYSTU
    Endif
    Filter [PP8]
    $NEXT_MP
  Next
Else
  For [P10] Where [P10]ITMREF = MP_ITM and [P10]PRHFCY = MP_FCY and [P10]QTYSTU <> 0
    If [P10]ITMREF = '7540' and [P10]PTHNUM = 'RC1012000002' : Goto NEXT_MP2 : Endif
    If [P10]ITMREF = '5070' and [P10]PTHNUM = 'RC1012000121' : Goto NEXT_MP2 : Endif
    If [P10]ITMREF = '7550' and [P10]PTHNUM = 'RC1012000001' : Goto NEXT_MP2 : Endif
    If [P10]ITMREF = '4333' and [P10]PTHNUM = 'RC1012000373' and [P10]PTDLIN = 2000 : Goto NEXT_MP2 : Endif
    If [P10]ITMREF = '6530' and [P10]PTHNUM = 'RC1012000084' : Goto NEXT_MP2 : Endif
    If [P10]ITMREF = '6530' and [P10]PTHNUM = 'RC1012000298' : Goto NEXT_MP2 : Endif

    # Si la recepción está facturada, voy a la línea de la factura a coger el precio. Sino lo tomo directamente de la línea de la recepción
    Local Decimal PRICE
    If [P10]LININVFLG = 2
      Filter [P11] Where [P11]NUMORI = [P10]PTHNUM and [P11]LINORI = [P10]PTDLIN
      Read [P11] First
      If fstat = 0
        PRICE = [P11]CSTPUR
      Else
        PRICE = [P10]CPR
      Endif
      Filter [P11]
    Else
      PRICE = [P10]CPR
    Endif

    COST_NUME += PRICE * [P10]QTYSTU
    SUM_CANT  += [P10]QTYSTU
    $NEXT_MP2
  Next
Endif

If SUM_CANT <> 0
  MP_COST = arr((COST_NUME / SUM_CANT),0.0001)
Endif
End



############################################################
Subprog GET_COSTE_BOM(SE_ITM,SE_ALT,SE_EXE,SE_PLANTA,SE_COST)
Value Char SE_ITM
Value Integer SE_ALT
Value Decimal SE_EXE
Value Char SE_PLANTA
Variable Decimal SE_COST

Local Decimal CTD_BASE

Read [PP4]BOH0 = SE_ITM;SE_ALT;2
If fstat = 0 and [PP4]USESTA = 2
  For [PP5] Where [PP5]ITMREF = SE_ITM and [PP5]BOMALT = SE_ALT and [PP5]BOMALTTYP = 2
    # Control del ciclo de vida de los componentes
    If [PP5]BOMSTRDAT = [00/00/0000] and [PP5]BOMENDDAT = [00/00/0000]
      # Sigo, componente OK
    Elsif [PP5]BOMSTRDAT <> [00/00/0000] and [PP5]BOMENDDAT <> [00/00/0000]
      If [PP5]BOMSTRDAT <= date$ and [PP5]BOMENDDAT >= date$
        # Sigo, componente OK
      Else
        Goto $NEXT_BOM
      Endif
    Elsif [PP5]BOMSTRDAT <> [00/00/0000] and [PP5]BOMENDDAT = [00/00/0000]
      If [PP5]BOMSTRDAT <= date$
        # Sigo, componente OK
      Else
        Goto $NEXT_BOM
      Endif
    Elsif [PP5]BOMSTRDAT = [00/00/0000] and [PP5]BOMENDDAT <> [00/00/0000]
      If [PP5]BOMENDDAT >= date$
        # Sigo, componente OK
      Else
        Goto $NEXT_BOM
      Endif
    Endif


    Filter [PP3] Where [PP3]ITMREF = [PP5]CPNITMREF and [PP3]STOFCY = SE_PLANTA and [PP3]CSTTYP = 1 and [PP3]FIYNUM = SE_EXE
    Read [PP3] Last
    If fstat = 0
      SE_COST += arr((([PP3]CSTTOT / [PP3]CLCQTY) * ([PP5]LIKQTY / [PP4]BASQTY)),0.0001)
    Endif
    Filter [PP5]

    $NEXT_BOM
  Next
Endif

End

