# PO30 - Env甐 facturas PDF desde espec璗ico
# Fecha inicio YPO30: 17/02/2020
# Desarrollador: JCH
# C鏚igo de desarrollo: YPO30
# Descripci鏮 del desarrollo: Env甐 de facturas PDF desde pantalla espec璗ica
# Fecha: 17/02/2020
# Codigo Actividad: YPO30
#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"    : Gosub OUVRE
  When "OK"       : Gosub OK
  When "FIN"      : Gosub FIN
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
  Global Char   GCORREO(100)
Return

##############################################################
$OK
  Gosub ENVIO_SIH
Return

##############################################################
$FIN
  Kill GCORREO
Return


##############################################################
######################    ETIQUETAS    #######################
##############################################################
$ENVIO_SIH
Local Char LWHERE(250) : Raz LWHERE

  If !clalev([F:SIV0]) Then : Local File SINVOICEV  [F:SIV0] : Endif
  If !clalev([F:BPC0]) Then : Local File BPCUSTOMER [F:BPC0] : Endif

  LWHERE = "1=1"
  If [M:YEF0]NUMINVDEB <> "" Then : LWHERE += " and NUM >= [M:YEF0]NUMINVDEB" : Endif
  If [M:YEF0]NUMINVFIN <> "" Then : LWHERE += " and NUM <= [M:YEF0]NUMINVFIN" : Endif
  If [M:YEF0]BPCINVDEB <> "" Then : LWHERE += " and NUM >= [M:YEF0]BPCINVDEB" : Endif
  If [M:YEF0]BPCINVFIN <> "" Then : LWHERE += " and NUM <= [M:YEF0]BPCINVFIN" : Endif

  If !GSERVEUR Then
    Call TEMPON("Env甐 de facturas") From GESECRAN
    Call OUVRE_TRACE ("Env甐 de facturas") From LECFIC
  Endif

  Filter [F:SIV0] Where evalue(LWHERE)
  For [SIV0]
    Read [BPC0]BPC0 = [F:SIV0]BPCINV
    If !fstat Then
      GCORREO = [F:BPC0]YMAIENVFRA
      If [F:BPC0]YTIPENVFRA = 1 Then
        Call TEMPON("Env甐 de la factura "+[F:SIV0]NUM+" a "+GCORREO) From GESECRAN
        Call ENVMAIL_SIH([F:SIV0]NUM,"Y-FACVENMAS","ENVIOPDF") From SPEYLIB0
      Endif
    Endif
  Next

  If !GSERVEUR Then
    Call TEMPOFF() From GESECRAN
    Call FERME_TRACE From LECFIC
  Endif

  If clalev([F:SIV0])  Then : Close Local File    [F:SIV0] : Endif
  If clalev([F:BPC0])  Then : Close Local File    [F:BPC0] : Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

