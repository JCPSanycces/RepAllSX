#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "EXEC"     : Gosub EXEC
  When Default
Endcase

Return
############################################################
$EXEC

  Global Char GCORREO(100)
  Local Integer LOKFAC

  #  # ELEGIR UNA DE LAS DOS OPCIONES, LA OTRA HAY QUE COMENTARLA
  #  # opción 1: si la dirección de correo se obtiene de las direcciones del cliente:
  #  Call GET_EMAIL([F:YSIV]BPCINV,[F:YSIV]BPAADD,GCORREO) From SPEYLIB0                                      # dirección de correo del cliente
  #  # opción 2: si la dirección de correo se obtiene del campo específico en la tabla BPCUSTOMER

  If !clalev([F:YB0]) Then : Local File BPCUSTOMER [F:YB0] : Endif
  Read [YB0]BPC0 = [M:SIH0]BPCINV
  If !fstat Then
    GCORREO = [F:YB0]YMAIENVFRA
    #Call GEN_PDFSIH([M:SIH0]NUM,"Y-FACVEN","ENVIOPDF",LOKFAC) From SPEYLIB0
    Call ENVMAIL_SIH([M:SIH0]NUM, "Y-FACVENMAS", "ENVIOPDF") From SPEYLIB0
  Endif
  Close File [YB0]

Return

Subprog ENVIAR_FACTURA()
  Global Char   GCORREO(100)

 If !clalev([F:YB0]) Then : Local File BPCUSTOMER [F:YB0] : Endif
  Read [YB0]BPC0 = [M:SIH0]BPCINV
  If !fstat Then
    GCORREO = [F:YB0]YMAIENVFRA
    #Call GEN_PDFSIH([M:SIH0]NUM,"Y-FACVEN","ENVIOPDF",LOKFAC) From SPEYLIB0
    Call ENVMAIL_SIH([M:SIH0]NUM, "Y-FACVENMAS", "ENVIOPDF") From SPEYLIB0
  Endif
  Close File [YB0]

  #If GUSER = 'AIT50'  : Infbox "EN ENVI2" : Endif

End

