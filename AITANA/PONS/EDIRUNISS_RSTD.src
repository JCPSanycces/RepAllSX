#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
# Representation Class EDIRUN                                                 #
#                                                                             #
###############################################################################
#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When "" : # If CURPTH is empty, we are on the main representation
      Case [L]AEVENT
        When "AQUERY_TRANS_AFTER"    : Gosub AQUERY_TRANS_AFTER
        When Default
      Endcase
    When "EDR" :
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub EDR_AREAD_AFTER
        When Default
      Endcase
    When "EDR.EDRD" :
      Case [L]AEVENT
        When "AREAD_AFTER"           : Gosub EDR_EDRD_AREAD_AFTER
        When Default
      Endcase
  Endcase
Return

#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
#  Case [L]AMETHOD
#  Endcase
Return

#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  Case [L]CURPRO
    When "EDR.PARCOD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDR_PARCOD_PROPAGATE
      Endcase
    When "EDR.PARTYP"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDR_PARTYP_PROPAGATE
      Endcase
    When "EDR.CATCOD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDR_CATCOD_PROPAGATE
      Endcase
    When "EDR.ALLFLO"
      Case [L]ARULE
        When "INIT"      : Gosub EDR_ALLFLO_INIT
        When "PROPAGATE" : Gosub EDR_ALLFLO_PROPAGATE
      Endcase
    When "EDR.CATTYP"
      Case [L]ARULE
        When "INIT"      : Gosub EDR_CATTYP_INIT
        When "PROPAGATE" : Gosub EDR_CATTYP_PROPAGATE
      Endcase
    When "EDR.CATACT"
      Case [L]ARULE
        When "INIT"      : Gosub EDR_CATACT_INIT
        When "PROPAGATE" : Gosub EDR_CATACT_PROPAGATE
      Endcase
    When "EDR.EDRD.FLD"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDR_EDRD_FLD_PROPAGATE
      Endcase
    When "EDR.EDRD.OPERATOR"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDR_EDRD_OPERATOR_PROPAGATE
      Endcase
    When "EDR.EDRD.UPDFLG"
      Case [L]ARULE
        When "PROPAGATE" : Gosub EDR_EDRD_UPDFLG_PROPAGATE
      Endcase
    When Default
  Endcase
Return



###################################################################

$EDR_PARCOD_PROPAGATE
  Call EDR_DISPLAY(this)
Return

###################################################################

$EDR_PARTYP_PROPAGATE
  Call EDR_DISPLAY(this)
Return

###################################################################

$EDR_CATCOD_PROPAGATE
  Call EDR_DISPLAY(this)
Return

###################################################################

$EDR_ALLFLO_INIT
  If this.PARTYP = 1
    WOK = fmet this.ASETATTRIBUTE('ALLFLO', '$isDisabled', 'true')
  Endif
Return

$EDR_ALLFLO_PROPAGATE
  Local Integer WOK
  If this.ALLFLO=2
    WOK = fmet this.ASETATTRIBUTE('FLOCOD', '$isDisabled', 'true')
    WOK = fmet this.ASETATTRIBUTE('FLOREL', '$isDisabled', 'true')
  Else
    WOK = fmet this.ASETATTRIBUTE('FLOCOD', '$isDisabled', 'false')
    WOK = fmet this.ASETATTRIBUTE('FLOREL', '$isDisabled', 'false')
  Endif
Return

###################################################################

$EDR_CATTYP_INIT
  this.CATTYP = 1
Return

$EDR_CATTYP_PROPAGATE
  Call EDR_DISPLAY(this)
Return

###################################################################

$EDR_CATACT_INIT
  this.CATACT = 1
Return

$EDR_CATACT_PROPAGATE
# we don't need this control, it's done in the class
#  If this.CATACT <> 1 #ENVOYER
#    ASTATUS = fmet this.ASETERROR("CATCOD","Erreur type de catégorie interdit",[V]CST_AERROR)
#  Endif
Return

###################################################################

$EDR_EDRD_FLD_PROPAGATE
  Gosub SET_FLDNAM
Return

####################################################################

$EDR_EDRD_OPERATOR_PROPAGATE
  Call EDR_EDRD_DISPLAY(this)
Return

####################################################################

$EDR_EDRD_UPDFLG_PROPAGATE
  Call EDR_EDRD_DISPLAY(this)
Return

#####################################################################
# STANDARD METHODS
#####################################################################

#********************************************************************
# Method AQUERY_TRANS_AFTER
#********************************************************************
#*
#*!
$AQUERY_TRANS_AFTER
  this.EDR.CATDES = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.EDR.CATCOD,"CATDES")
  this.EDR.PARDES = fmet this.ACTX.ACACHE.EPR.AGETVALCHAR(this.EDR.PARCOD,"PARDES")
Return

#********************************************************************
# Method AREAD_AFTER
#********************************************************************
#* Switch the display
#*!

$EDR_AREAD_AFTER
  Call EDR_DISPLAY(this)
Return

$EDR_EDRD_AREAD_AFTER
  Call EDR_EDRD_DISPLAY(this)
  Gosub SET_FLDNAM
Return

$SET_FLDNAM
  Local File ATABZON [ATZ]
  Local File ATEXTE [ATX]
  Read [ATZ]CODZONE = fmet this.ACTX.ACACHE.ECA.AGETVALCHAR(this.APARENT.CATCOD,"CATTRGTAB");this.FLD
  If !fstat
    Read [ATX]NUMERO = this.ACTX.LAN;[F:ATZ]NOCOURT
    If !fstat
      this.FLDNAM = [F:ATX]TEXTE
    Endif
  Endif
  LogicClose File [ATX]
  LogicClose File [ATZ]
Return

#####################################################################
# USEFULL SUBS
#####################################################################

#********************************************************************
# Subprog EDR_DISPLAY
#********************************************************************
#
#* Switch the display according to CATTYP
#* @param WOBJECT --> OBJECT
#*!
Subprog EDR_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT

  Local Integer WOK
  Local Char WPROP(15)
  WPROP = "$isDisabled"

  If WOBJECT.CATTYP >= 1 and WOBJECT.CATTYP <= 5
    If WOBJECT.PARTYP = 1 #"SAGE"
      WOK = fmet WOBJECT.ASETATTRIBUTE('ALLFLO', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLOCOD', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLOREL', WPROP, 'true')
    Else # "EDICOM" or "Misc"
      WOK = fmet WOBJECT.ASETATTRIBUTE('ALLFLO', WPROP, 'false')
      If WOBJECT.ALLFLO = 2
        WOK = fmet WOBJECT.ASETATTRIBUTE('FLOCOD', WPROP, 'true')
        WOK = fmet WOBJECT.ASETATTRIBUTE('FLOREL', WPROP, 'true')
      Else
        WOK = fmet WOBJECT.ASETATTRIBUTE('FLOCOD', WPROP, 'false')
        WOK = fmet WOBJECT.ASETATTRIBUTE('FLOREL', WPROP, 'false')
      Endif
    Endif

  Else #documents
    WOK = fmet WOBJECT.ASETATTRIBUTE('ALLFLO', WPROP, 'false')
    If WOBJECT.ALLFLO = 2
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLOCOD', WPROP, 'true')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLOREL', WPROP, 'true')
    Else
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLOCOD', WPROP, 'false')
      WOK = fmet WOBJECT.ASETATTRIBUTE('FLOREL', WPROP, 'false')
    Endif
  Endif
End

#********************************************************************
# Subprog EDR_EDRD_DISPLAY
#********************************************************************
#
#* Switch the line display
#* @param WOBJECT
#*!
Subprog EDR_EDRD_DISPLAY(WOBJECT)
Variable Instance WOBJECT Using OBJECT
  Local Integer WOK
  Local Char WPROP(15)
  WPROP = "$isDisabled"

  If WOBJECT.UPDFLG = [V]CST_AYES
    WOK = fmet WOBJECT.ASETATTRIBUTE('REPFLDVAL1', WPROP, 'false')
    Case WOBJECT.OPERATOR
      When 1 :
        WOK = fmet WOBJECT.ASETATTRIBUTE('REPFLDVAL2', WPROP, 'false')
      When 2, 3, 4 :
        WOK = fmet WOBJECT.ASETATTRIBUTE('REPFLDVAL2', WPROP, 'true')
    Endcase
  Else
    WOK = fmet WOBJECT.ASETATTRIBUTE('REPFLDVAL1', WPROP, 'true')
    WOK = fmet WOBJECT.ASETATTRIBUTE('REPFLDVAL2', WPROP, 'true')
  Endif
End

