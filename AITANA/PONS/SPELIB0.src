#####################################################################
#**
#* Genera el pdf de una factura de venta..
#*
#* @param PFACVEN   > nºmero de la factura de venta
#* @param PINFNAM   > nombre del informe
#* @param PDESTINO  > nombre del destino
#* @param POKFAC    > devuelve el estado de la creaciµn del pdf
#*!
Subprog GEN_PDFSIH(PFACVEN, PINFNAM, PDESTINO, POKFAC)
Variable  Integer POKFAC
Value     Char    PINFNAM
Value     Char    PFACVEN
Value     Char    PDESTINO

  POKFAC = 1 # no

  If !clalev([F:YSIV0]) : Local File SINVOICEV   [F:YSIV0] : Endif
  If !clalev([F:YTSV0]) : Local File TABSIVTYP   [F:YTSV0] : Endif

  Local Char    TBPAR(20)(1..15)
  Local Char    TBVAL(20)(1..15)
  Local Char    LFILE(200)
  Local Char    LDIRIMPORT(250) : LDIRIMPORT = "G:\Sage\X3AITANA\folders\DEVELOP\SIH_SEND\" #LDIRIMPORT = "C:\temp\Sage\"
  Local Integer LESTADO
    # 1 -> a procesar
    # 2 -> pdf creado
    # 3 -> error, no se ha creado el pdf
    # 4 -> pdf enviado
  Local Integer LINTENT # intentos para comprobar si se ha creado un pdf..
  Local Integer LIMPFAC # estado impresiµn factura

  Raz TBPAR, TBVAL, LFILE, LIMPFAC

  # que exista la factura..
  Read [F:YSIV0]SIV0 = PFACVEN
  If !fstat Then
    # solo se lanza cuando son facturas.. (no abonos)
    Filter [F:YTSV0] Where [F:YTSV0]SIVTYP = [F:YSIV0]SIVTYP
    Read [F:YTSV0]TSV1 First
    If !fstat Then
      # solo facturas..
      If [F:YTSV0]INVTYP = 1 Then
        # tipo de impresiµn a aplicar al informe..
        If [F:YSIV0]STARPT <> 0
          LIMPFAC = [F:YSIV0]STARPT
        Else
          LIMPFAC = 1
        Endif

        If LESTADO <> 4 Then
          # parÃmetros del informe YSBONFACP
          TBPAR(1)  = "sitedeb"         : TBVAL(1)  = [F:YSIV0]SALFCY
          TBPAR(2)  = "sitefin"         : TBVAL(2)  = [F:YSIV0]SALFCY
          TBPAR(3)  = "facturedeb"      : TBVAL(3)  = [F:YSIV0]NUM
          TBPAR(4)  = "facturefin"      : TBVAL(4)  = [F:YSIV0]NUM
          TBPAR(5)  = "typedeb"         : TBVAL(5)  = "1" # factura
          TBPAR(6)  = "typefin"         : TBVAL(6)  = "1" # facura
          TBPAR(7)  = "clientdeb"       : TBVAL(7)  = [F:YSIV0]BPCINV
          TBPAR(8)  = "clientfin"       : TBVAL(8)  = [F:YSIV0]BPCINV
          TBPAR(9)  = "datedeb"         : TBVAL(9)  = [F:YSIV0]INVDAT
          TBPAR(10) = "datefin"         : TBVAL(10) = [F:YSIV0]INVDAT
          TBPAR(11) = "codimp"          : TBVAL(11) = num$(LIMPFAC) # re-impresiµn [SIV]STARPT
          TBPAR(12) = "impselections"   : TBVAL(12) = "1" # no
          TBPAR(13) = "duplicata"       : TBVAL(13) = "1" # no

          # borra la factura si existe..
          LFILE = LDIRIMPORT + [F:YSIV0]NUM + ".pdf"
          If filinfo(LFILE, 7) > 0 : System "ae_rm " + LFILE : Endif

          # lanza el informe..
          Call ETAT(PINFNAM, PDESTINO, "SPA", 0, "", TBPAR, TBVAL) From AIMP3

          # intentos para comprobar la creaciµn del pdf..
          LINTENT = 1
          While LINTENT < 10
#            Sleep 10

            # comprobar si existe la factura
            If filinfo(LFILE, 7) > 0 Then
              LINTENT = 10 # fin
              LESTADO = 2  # pdf creado..
            Else
              LESTADO = 3  # pdf error..
              LINTENT += 1 # un intento mÃs..
            Endif
          Wend

        Endif
      Endif
    Endif
  Endif

  # devuelve el estado..
  POKFAC = LESTADO

  Close Local File [F:YSIV0],[F:YTSV0]

End


#####################################################################
#**
#* EnvÚa a destino una factura de venta
#*
#* @param PFACVEN   > nºmero de la factura de venta
#* @param PINFNAM   > nombre del informe
#* @param PDESTINO  > nombre del destino
#* @param POKFAC    > devuelve el estado de la creaciµn del pdf
#*!
Subprog ENVDEST_SIH(PFACVEN, PINFNAM, PDESTINO, POKFAC)
Variable  Integer POKFAC
Value     Char    PINFNAM
Value     Char    PFACVEN
Value     Char    PDESTINO

  POKFAC = 1 # no

  If !clalev([F:YSIV0]) : Local File SINVOICEV   [F:YSIV0] : Endif
  If !clalev([F:YTSV0]) : Local File TABSIVTYP   [F:YTSV0] : Endif

  Local Char    TBPAR(20)(1..15)
  Local Char    TBVAL(20)(1..15)
  Local Integer LIMPFAC # estado impresiµn factura

  Raz TBPAR, TBVAL, LIMPFAC

  # que exista la factura..
  Read [F:YSIV0]SIV0 = PFACVEN
  If !fstat Then
    # solo se lanza cuando son facturas.. (no abonos)
    Filter [F:YTSV0] Where [F:YTSV0]SIVTYP = [F:YSIV0]SIVTYP
    Read [F:YTSV0]TSV1 First
    If !fstat Then
      # solo facturas..
      If [F:YTSV0]INVTYP = 1 Then
        # tipo de impresiµn a aplicar al informe..
        If [F:YSIV0]STARPT <> 0
          LIMPFAC = [F:YSIV0]STARPT
        Else
          LIMPFAC = 1
        Endif

        # parÃmetros del informe YSBONFACP
        TBPAR(1)  = "sitedeb"         : TBVAL(1)  = [F:YSIV0]SALFCY
        TBPAR(2)  = "sitefin"         : TBVAL(2)  = [F:YSIV0]SALFCY
        TBPAR(3)  = "facturedeb"      : TBVAL(3)  = [F:YSIV0]NUM
        TBPAR(4)  = "facturefin"      : TBVAL(4)  = [F:YSIV0]NUM
        TBPAR(5)  = "typedeb"         : TBVAL(5)  = "1" # factura
        TBPAR(6)  = "typefin"         : TBVAL(6)  = "1" # facura
        TBPAR(7)  = "clientdeb"       : TBVAL(7)  = [F:YSIV0]BPCINV
        TBPAR(8)  = "clientfin"       : TBVAL(8)  = [F:YSIV0]BPCINV
        TBPAR(9)  = "datedeb"         : TBVAL(9)  = [F:YSIV0]INVDAT
        TBPAR(10) = "datefin"         : TBVAL(10) = [F:YSIV0]INVDAT
        TBPAR(11) = "codimp"          : TBVAL(11) = num$(LIMPFAC) # re-impresiµn [SIV]STARPT
        TBPAR(12) = "impselections"   : TBVAL(12) = "1" # no
        TBPAR(13) = "duplicata"       : TBVAL(13) = "1" # no

        # lanza el informe..
        Call ETAT(PINFNAM, PDESTINO, "SPA", 0, "", TBPAR, TBVAL) From AIMP3

      Endif
    Endif
  Endif

  Close Local File [F:YSIV0],[F:YTSV0]

End

