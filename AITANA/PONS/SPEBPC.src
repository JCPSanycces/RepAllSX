######################################################################################
## Control en el campo Tipo envío factura
######################################################################################
Subprog C_YTIPENVFRA(VALEUR)
Variable Integer VALEUR
  If VALEUR = 1 Then
    Actzo [M:BPC2]YMAIENVFRA
  Else
    Grizo [M:BPC2]YMAIENVFRA
  Endif
End


