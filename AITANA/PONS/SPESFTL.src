######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla SFTL1) 07/10/2020 12:08:56 (AIT51)
######################################################################################
Subprog AM_CPLLAB(VALEUR)
Variable Char    VALEUR()
  Call LECTEXTRA([M:SFTL1]WCPLESAXX(nolign-1),"WORKSTATIO","WSTDESAXX",VALEUR,[M:SFTL1]FCY ) From ATEXTRA
End





######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla SFTL1) 13/10/2020 13:37:22 (AIT51)
######################################################################################
Subprog AM_YFECHAFIN(VALEUR)
Variable Date    VALEUR
  # AITANA.NEW
  # Passing start date value

  Call VALIDATE_REPOPULATE_GRID ([M:SFTL1]FCY,[M:SFTL1]MFGNUMF,[M:SFTL1]OPENUMF,
&                            [M:SFTL1]WCRF,[M:SFTL1]WSTF,[M:SFTL1]LSD, VALEUR) From TRTSFTL

End


