######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla SFTL1) 07/10/2020 12:07:58 (AIT51)
######################################################################################
Subprog AM_CPLWST(VALEUR)
Variable Char    VALEUR()
  Call LECTEXTRA([M:SFTL1]WSTDESAXX(nolign-1),"WORKSTATIO","WSTDESAXX",VALEUR,[M:SFTL1]FCY ) From ATEXTRA
End


