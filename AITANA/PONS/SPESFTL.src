Subprog AM_YMANTE(VALEUR)
Variable Integer VALEUR
  Call VALIDATE_REPOPULATE_GRID ([M:SFTL1]FCY,[M:SFTL1]MFGNUMF,[M:SFTL1]OPENUMF,
&                            [M:SFTL1]WCRF,[M:SFTL1]WSTF,[M:SFTL1]LSD, [M:SFTL1]YFECHAFIN, VALEUR) From TRTSFTL
End


