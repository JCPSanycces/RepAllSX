#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER = "AIT04" : Infbox ACTION : Endif
Case ACTION
  When "AV_AFFICHE"   : Gosub AV_AFFICHE
Endcase
Return

###################################################
$AV_AFFICHE
# Actualizo el valor del En Curso en el caso de tener alguna factura vencida
Local Integer I
If !clalev([PP1]) : Local File GACCDUDATE [PP1]   : Endif
If !clalev([PP2]) : Local File SORDER     [PP2]   : Endif
If !clalev([ZBPC]): Local File BPCUSTOMER [ZBPC]  : Endif

For I=0 To [M:CSO2]NBLIG-1
  Read [ZBPC]BPC0 = [M:CSO2]BPCORD(I)
  If [ZBPC]OSTCTL = 2          # control en curso Libre
      [M:CSO2]CDTSTA(I) = 0
      Affzo [M:CSO2]CDTSTA(I)
  Else
      If [M:CSO2]ORDSTA(I) = 2     # 1 No saldado / 2 Saldado
        [M:CSO2]CDTSTA(I) = 0
        Affzo [M:CSO2]CDTSTA(I)
      Else
        If [ZBPC]OSTCTL = 3         # control en curso Bloqueado
            [M:CSO2]CDTSTA(I) = 2
            Affzo [M:CSO2]CDTSTA(I)
            # MAB.10072020.ENEW -   #46653  - 20072020. Subido a producción
            Read [PP2]SOH0 = [M:CSO2]SOHNUM(I)
            If fstat = 0 and [PP2]UNL = 2 # si el pedido está desbloqueado manualmente
              If [PP2]CDTSTA = 2 Then
                 [M:CSO2]CDTSTA(I) = 2
                 Affzo [M:CSO2]CDTSTA(I)
              Else
                 [M:CSO2]CDTSTA(I) = 1
                 Affzo [M:CSO2]CDTSTA(I)
              Endif
            Endif
            # MAB.10072020.ENEW - #46653  - 20072020. Subido a producción
        Else                        # control en curso
            Read [PP2]SOH0 = [M:CSO2]SOHNUM(I)
            If fstat = 0 and [PP2]UNL <> 2  # Solamente compruebo vencimientos si el pedido no se ha desbloqueado manualmente
              #If GUSER = "AIT04" and [M:CSO1]BPCORD='103327': Infbox "ENTRO" + num$([M:CSO2]CDTSTA(I)) : Endif
              # MAB.10072020.SNEW - #46653 - Cuando el pedido no tiene vencimientos pendientes, pero está marcado "Estado Credito = bloqueado", mostrarmos
              #                              estado Bloqueado, si no OK
              If [PP2]CDTSTA = 2 Then
                 [M:CSO2]CDTSTA(I) = 2
                 Affzo [M:CSO2]CDTSTA(I)
              Else
                 [M:CSO2]CDTSTA(I) = 1
                 Affzo [M:CSO2]CDTSTA(I)
              Endif
              # MAB.10072020.ENEW - #46653

              For [PP1] Where [PP1]BPRPAY = [M:CSO2]BPCINV(I) and [PP1]DUDDAT < date$ and [PP1]BPRTYP = 1 and [PP1]PAYCUR < [PP1]AMTCUR
                [M:CSO2]CDTSTA(I) = 2
                Affzo [M:CSO2]CDTSTA(I)
                Break
              Next
            Endif
        Endif
      Endif
  Endif
Next

Close Local File [PP1],[PP2]
Return



##################################################################
Subprog ES_BLOQUEADO(CLIPED,PED,CLIFAC,BLOQ)
Value Char CLIPED
Value Char PED
Value Char CLIFAC
Variable Integer BLOQ

If !clalev([YY1]) : Local File GACCDUDATE [YY1]   : Endif
If !clalev([YY2]) : Local File SORDER     [YY2]   : Endif
If !clalev([YY3]) : Local File BPCUSTOMER [YY3]  : Endif

Read [YY3]BPC0 = CLIPED
If [YY3]OSTCTL = 2          # control en curso Libre
  BLOQ = 1
Else
  If [YY3]OSTCTL = 3         # control en curso Bloqueado
    BLOQ = 2
    # MAB.10072020.ENEW -   #46653 - 20072020. Subido a producción
    Read [YY2]SOH0 = PED
    If fstat = 0 and [YY2]UNL = 2 # si el pedido está desbloqueado manualmente
      If [YY2]CDTSTA = 2 Then
         BLOQ = 2
      Else
         BLOQ = 1
      Endif
    Endif
    # MAB.10072020.ENEW - #46653  - 20072020. Subido a producción
  Else                        # control en curso
      Read [YY2]SOH0 = PED
      If fstat = 0 and [YY2]UNL <> 2  # Solamente compruebo vencimientos si el pedido no se ha desbloqueado manualmente
          For [YY1] Where [YY1]BPRPAY = CLIFAC and [YY1]DUDDAT < date$ and [YY1]BPRTYP = 1 and [YY1]PAYCUR < [YY1]AMTCUR
            BLOQ = 2
            Break
          Next
      Endif
      # MAB.10072020.SNEW - #46653
      If [YY2]CDTSTA = 2 Then
        BLOQ = 2
      Endif
      # MAB.10072020.SNEW - #46653
  Endif
Endif

Close Local File [YY1],[YY2],[YY3]
End

