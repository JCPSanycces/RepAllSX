#**
#* Asigna un cˇdigo identificativo de la sociedad por cada entidad bancaria
#*
#* @param PBANK  > entidad bancaria
#*!
# La llamada a la funciˇn se harÝa de la forma SPETFB.ID_X_BANK(<entidad bancaria>)
Funprog IDXBANK(PBANK)
Value Char PBANK

Local Char LID(30)
  Case PBANK
    When "9000" : LID = "ES98000B03725173"
    When "9002" : LID = "ES98ZZZB03725173"
    When "9003" : LID = "ES98001B03725173"
  Endcase

End LID

