$ACTION
Case ACTION
 When "FIN_PICK"    :   Gosub FIN_PICK
Endcase
Return


######################################################################################
$FIN_PICK
# Por defecto propongo estado A
Local Integer I
For I=0 To [M:SRH1]NBLIG-1
  [M:SRH1]STA(I) = "A"
  Affzo [M:SRH1]STA(I)
  [M:SRH1]RTNCNOFLG(I) = 2
  Affzo [M:SRH1]RTNCNOFLG(I)
Next
Return


######################################################################################
Subprog AS_STA(VALEUR)
Variable Char    VALEUR()
# Por defecto propongo estado A
VALEUR = "A"
End

######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla SRH1) 13/10/2020 16:30:17 (AIT07)
