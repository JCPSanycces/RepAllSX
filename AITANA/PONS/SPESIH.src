#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara SIH0 (Especifico)

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla SIH0) 23/12/2019 13:37:20 (AIT04)
######################################################################################
$ACTION
Case ACTION
 When "APRES_CRE"   :  Gosub APRES_CRE
Endcase
Return


############################################
$APRES_CRE
# Pongo valor al campo Departamento
Read [SIV]SIV0 = [M:SIH0]NUM
If fstat = 0
  Read [BPC]BPC0 = [SIV]BPCINV
  If fstat = 0
    [SIV]YDPTO = [BPC]YDPTOC
    Rewrite [SIV]
  Endif
Endif

# SOLO PARA PROFORMAS
# ENVIO AUTOMATICO DE FACTURA POR CORREO ELECTRÓNICO
If GFLAG = 'PO2' Then
  If [M:SIH0]SIVTYP = 'PRF' Then
    Call ENVIAR_FACTURA() From SPEYMAILFAC
  Endif
Endif
Return


Return

############################################
Subprog AM_BPCINV(VALEUR)
Variable Char    VALEUR()
# Pongo valor al campo departamento
[M:SIH1]YDPTO = [F:BPC]YDPTOC
Affzo [M:SIH1]YDPTO
End

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla SIH0) 02/01/2020 16:34:24 (AIT04)
######################################################################################
Subprog C_INVDAT(VALEUR)
Variable Date    VALEUR
## Si la fecha es posterior a hoy, error
If VALEUR > date$
  Errbox "La fecha de facturación no puede ser superior a la fecha actual"
  mkstat = 2
Elsif VALEUR < date$
  # Si la fecha es inferior a hoy, no puede ser anterior a la última factura
  If !clalev([PP1]) : Local File SINVOICE [PP1] : Endif
  Local Date ULTIMA

##### MODIFICACIÓN JC 20/03/2020 ####1
##  Filter [PP1] Where [PP1]INVTYP = 1 and [PP1]FCY = [M:SIH0]SALFCY and [PP1]SIVTYP = "FAC" Order By [PP1]ACCDAT Desc
#  Filter [PP1] Where [PP1]INVTYP = 1 and [PP1]FCY = [M:SIH0]SALFCY and [PP1]SIVTYP = [M:SIH0]SIVTYP Order By [PP1]ACCDAT Desc
##### MODIFICACIÓN JC 20/03/2020 ####1

  #- 06042020 - MS - Debe controlara la fecha en cualquier tipo de factura -----
  Filter [PP1] Where [PP1]FCY = [M:SIH0]SALFCY and [PP1]SIVTYP = [M:SIH0]SIVTYP Order By [PP1]ACCDAT Desc
  # ----------------------------------------------------------------------------

  Read [PP1] First
  If fstat = 0 and VALEUR < [PP1]ACCDAT
    Errbox "La fecha de facturación no puede ser inferior a la fecha de la factura " + [PP1]NUM + " de fecha " + format$("DZ:DD[/]MM[/]YY",[PP1]ACCDAT)
    mkstat = 2
  Endif
  Filter [PP1]

  Close Local File [PP1]
Endif
End


######################################################################################

