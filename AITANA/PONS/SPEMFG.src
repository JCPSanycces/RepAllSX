## Antes de entrada en el campo "Mantenimiento"
######################################################################################
# con este código controlamos que si se accede a la pantalla desde una opción diferente
# a un modelo de importación, no se pueda modificar el campo
Subprog AS_YMNTOTYP(VALEUR)
Variable Integer VALEUR
# YAPMP
  If VALEUR <> 0 Then
    mkstat = 2
  Endif
# YAPMP
End

