#<AdxTL>@(#)0.0.0.0 $Revision$ Pedidos
$ACTION
Case ACTION
  When "LIENS_LIG"    :   Gosub LIENS_LIG
  When "EXEBOUT"      :   Gosub EXEBOUT
  When "LIENS"        :   Gosub LIENS
  When "SETBOUT"      :   Gosub SETBOUT
Endcase
Return


#################################################
SETBOUT
# Lanzo el STD y luego controlo si estÃ el pedido revisado para poder habilitar el botµn de Preparaciµn
Gosub SETBOUT From SUBSOHA1

If [M:SOH0]YREVISADO <> 2
  Call VIREBOUT(CHAINE,"6") From GOBJET
Endif

GPE = 1
Return


#################################################
LIENS_LIG
# Lanzo el STD y pongo valor a las cajas
Gosub LIENS_LIG From SUBSOHA
If [F:ITM]YUNIXCAJA>0
  [M:SOH4]YCAJAS(NOL) = int([M:SOH4]QTY(NOL) / [F:ITM]YUNIXCAJA)
  Affzo [M:SOH4]YCAJAS(NOL)
Endif
GPE = 1
Return


#############################################
$EXEBOUT
# Cuando lanzo la preparaciµn, marco el campo de Revisado
If 1=2
  Case BOUT
    When "6"
      [M:SOH0]YREVISADO = 2
      Affzo [M:SOH0]YREVISADO

      Read [SOH]SOH0 = [M:SOH0]SOHNUM
      If fstat = 0
        [SOH]YREVISADO = 2
        Rewrite [SOH]
      Endif
  Endcase
Endif
Return


#############################################
$LIENS
# Muestro la clasificaciµn del cliente
Read [BPC]BPC0 = [M:SOH0]BPCORD
If fstat = 0
  [M:SOH3]YTSCCOD = [BPC]TSCCOD(1)
  Affzo [M:SOH3]YTSCCOD
Endif
Return

######################################################################################
## Etiqueta aþadida por el supervisor (pantalla SOH4) 16/04/2020 09:16:58 (AIT51)
######################################################################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR
# MAB.15042020.T11.SNEW
If [M:SOH4]NETPRI(nolign-1)>0 Then
   [M:SOH4]YMARGEN(nolign-1) = [M:SOH4]PFM(nolign-1)/[M:SOH4]NETPRI(nolign-1)*100
   Affzo [M:SOH4]YMARGEN(nolign-1)
Endif
# MAB.15042020.T11.SNEW
End

