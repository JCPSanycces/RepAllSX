#<AdxTL>@(#)0.0.0.0 $Revision$
Call OUVRE_TRACE("Inicio Descarga Cambio") From LECFIC
Call ECR_TRACE(" Llamada a la descarga ", 0) From GESECRAN
Call OBTENERCAMBIO()

Return



Subprog OBTENERCAMBIO()
  Local Char CAMBIO
  Local Decimal RES



  RES = func DESCARGAR_CAMBIO()

    Call FERME_TRACE From LECFIC
End



Funprog DESCARGAR_CAMBIO()
Variable Char CURRENCY()
Local Integer RETVAL,I, FUTURE : Local Decimal RATE

# No additional parameter nor aditional header value are given here (only the values given in EXTERNAL definition are used)
Local Char PCOD(100)(1..10),PVAL(100)(1..10),HCOD(100)(1..10),HVAL(100)(1..10)
Local Clbfile DATA_SENT(0)
Local Char UID(200)
Local Char FECHA_CAMBIO

# Contains the result header and body
Local Clbfile RESHEAD(0),RESBODY(0)

 Call ECR_TRACE( "Llamada al webservice EUROCHANGE",0) From GESECRAN

  DATA_SENT="{}" : # No data is sent
  FUTURE=0       : # We wait for the answer

# Call the web service now
  RETVAL=func ASYRRESTCLI.EXEC_REST_WS("EUROCHANGE","GET","",PCOD, PVAL, HCOD, HVAL, DATA_SENT, FUTURE,"",RESHEAD, RESBODY)

  Call ECR_TRACE( "Resultado:" + num$(RETVAL),0) From GESECRAN

# The service returns { "currency" : CURRENCY_CODE, "rate" : RATE_VALUE } by default
# As we sent "rate" in the request, only the rate value is returned
# The web service is successful if return status is 200

  # RESBODY=vireblc(RESBODY,4) : # Suppress leading / trailing spaces

 # Infbox "RESBODY" + num$(RESBODY)
  # Infbox "CURRENCY:" + num$(CURRENCY)


  If RETVAL=200
    RATE=val(RESBODY)
    Local Char SUFFIX (5)
    SUFFIX = sigma(1, 1+int(rnd(20)), chr$(int(rnd(25)+ascii("A"))))
    #Store file here: ..\folders\SEED\tmp

    Openo filpath('tmp', 'MYSELF_RESULT_' + SUFFIX, 'XML') Using [ZREST]
    Call ECR_TRACE( "Creación de fichero:" + '\TMP\MYSELF_RESULT_' + SUFFIX + '.XML',0) From GESECRAN
    Wrseq RESBODY Using [ZREST]
    Openo Using [ZREST]
    # busqueda de fecha
    Local Char SEARCH_WORD : SEARCH_WORD = "Cube time='"
    Local Char LMONEDA, LTEMP, LRATE
    #Variable Clbfile TEXT()
    Local Integer OCCURRENCES,I,K
    K=len(SEARCH_WORD)
    I = 1-K
    OCCURRENCES = -1
    Repeat
      I = instr(I+K, RESBODY, SEARCH_WORD)
    #  Infbox num$(I) + "<-i - K->" + num$(K)
      OCCURRENCES += 1
      # Infbox num$(instr(I+K, RESBODY, SEARCH_WORD))
      If I > 0 Then
          FECHA_CAMBIO = mid$(RESBODY, I+len(SEARCH_WORD),10)
          # Infbox FECHA_CAMBIO
      #Else
      #    FECHA_CAMBIO = ''
      Endif
    Until I = 0
    # Infbox "ENCONTRADOS fechas:" +FECHA_CAMBIO
    # abrimos tabla de divisas
    If FECHA_CAMBIO <> '' Then
      If !clalev([F:ZDIV]) : Local File YDIVISAS [ZDIV] : Endif

      #Infbox num$(gdat$(mid$(FECHA_CAMBIO,9,2),mid$(FECHA_CAMBIO,6,2), mid$(FECHA_CAMBIO,1,4)))
      Filter [F:ZDIV] Where FECHA = gdat$(val(mid$(FECHA_CAMBIO,9,2)),val(mid$(FECHA_CAMBIO,6,2)), val(mid$(FECHA_CAMBIO,1,4)))

      If rowcount([ZDIV]) = 0 Then
        # Infbox num$(rowcount([ZDIV]))

        # busqueda de monedas y cambio
        Local Char SEARCH_WORD : SEARCH_WORD = "Cube currency='"
        #Variable Clbfile TEXT()
        Local Integer OCCURRENCES,I,K,PINI, PFIN
        K=len(SEARCH_WORD)
        I = 1-K
        OCCURRENCES = -1
        Repeat
          I = instr(I+K, RESBODY, SEARCH_WORD)
          OCCURRENCES += 1
          If I > 0 Then
           # Infbox num$(instr(I+K, RESBODY, SEARCH_WORD))
           # Infbox mid$(RESBODY, I+len(SEARCH_WORD),35)
           LMONEDA = mid$(RESBODY, I+len(SEARCH_WORD), 3 )
           LTEMP = mid$(RESBODY, I+len(SEARCH_WORD), 28 )
           # POSICIÓN DE INICIO DE RATE Y FIN
           PINI = len("rate='") + instr(1, LTEMP, "rate='")
           PFIN = instr(1, LTEMP, "'/>")
           # COJO EL RATE
           LRATE = mid$(LTEMP, PINI, PFIN-PINI)
           # Infbox LRATE
           If LMONEDA <> '' and LRATE <> '' Then
              Trbegin [ZDIV]
              [F:ZDIV]FECHA = gdat$(val(mid$(FECHA_CAMBIO,9,2)),val(mid$(FECHA_CAMBIO,6,2)), val(mid$(FECHA_CAMBIO,1,4)))
              [F:ZDIV]CUR = LMONEDA
              [F:ZDIV]RATE = val(LRATE)
              Write [ZDIV]
              If !fstat Then
                Commit
                Call CREAR_TIPO_CAMBIO([F:ZDIV]CUR, [F:ZDIV]FECHA, [F:ZDIV]RATE)
              Endif
           Endif
          Endif
        Until I = 0
      Endif
      Close File [ZDIV]
    Endif
  Else
    RATE=1
    Call ECR_TRACE( 'Error en la llamada al WebService',1) From GESECRAN
  Endif

End RATE




#**
#* Inserción de los cambios de divisa
#*
#* @param PCUR
#* @param PRATDAT
#* @param PRATDIV
#*!
Subprog CREAR_TIPO_CAMBIO(PCUR, PRATDAT, PRATDIV)
  If !clalev([F:TCH])  Then : Global File TABCHANGE [TCH] : Endif
  If !clalev([F:TCH2])  Then : Global File TABCHANGE [TCH2] : Endif
    #Infbox "creación tipo cambio:" + PCUR + " - " + num$(PRATDAT)+" - " + num$(PRATDIV)

    Trbegin [F:TCH2]
    #Infbox "BORRADO 1"
    Delete [F:TCH2] Where CURDEN = PCUR and CUR = "EUR" and CHGSTRDAT = PRATDAT
    Delete [F:TCH2] Where CURDEN = "EUR" and CUR = PCUR and CHGSTRDAT = PRATDAT
    Commit

    Trbegin [F:TCH]


    #Commit
    [F:TCH]CHGTYP = 1
    [F:TCH]CURDEN = PCUR
    [F:TCH]CUR = "EUR"

    [F:TCH]REVCOURS = 1/PRATDIV
    [F:TCH]CHGSTRDAT = PRATDAT
    [F:TCH]CHGDIV = 1
    [F:TCH]CHGRAT = PRATDIV
    #Infbox PCUR + " a EUR:" + num$([F:TCH]CHGRAT)
    Write [F:TCH]

    [F:TCH]CHGTYP = 1
    [F:TCH]CURDEN = "EUR"
    [F:TCH]CUR = PCUR
    [F:TCH]REVCOURS = PRATDIV
    [F:TCH]CHGSTRDAT = PRATDAT
    [F:TCH]CHGDIV = 1
    [F:TCH]CHGRAT = 1/PRATDIV
    #Infbox "EUR a " + PCUR + ":" + num$([F:TCH]CHGRAT)
    Write [F:TCH]
    Commit

  Close File [F:TCH]
  Close File [F:TCH2]
End

