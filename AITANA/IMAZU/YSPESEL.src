$ACTION

Case ACTION
 When "SEL_TABLE"     : Gosub SEL_TABLE
 #When "SEL_LISTE"     : Gosub SEL_LISTE
 When Default
Endcase
Return


##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################


$SEL_TABLE
Case TABLE
    When "SELMATIMA"    : Gosub S_SELMATIMA

Endcase
Return

$S_SELMATIMA

#If clalev([F:ZTA])=0 : Local File ATABDIV  [ZTA]  : Endif
#If clalev([F:ZATE])=0 : Local File ATEXTRA  [ZATE]  : Endif
If clalev([F:YVMP])=0 : Local File YVMATPRE [YVMP] : Endif


# Link [ZTA] With [ZATE]AXX0='ATABDIV';'LNGDES';'SPA';'2502';CODE As [ZMAT]  Where NUMTAB = 2502 # and CODFIC = 'ATABDIV' and ZONE = 'LNGDES' and LANGUE = 'SPA' and IDENT1 = [ZTA]NUMTAB and
# [ZTA]A3 = 'Es'

# TIPO DE IMPRESIÓN
If PARAM(1) = '01' Then # ESTAMPACIÓN
  Filter [F:YVMP] Where  A3 = '01' or (A3 = '')
Else # SUBLIMACIÓN
  If PARAM(2) = '01' Then # Iz --> 01 -- imazu
    Filter [F:YVMP] Where  (A3 = '02' or (A3 = '' )) and A4 = '01'
  Elsif PARAM(2) = '02' Then # Im 02 --> importación
    Filter [F:YVMP] Where  (A3 = '02' or (A3 = '' )) and A4 = '02'
  Endif
Endif

#CODFIC+ZONE+LANGUE+IDENT1+IDENT2

Default File [YVMP]
START   = 'CODE'
ORDRE   = 'CODE'
#If SELTYP=1
#    START   = 'ITMREF'
#Else
#    START   = 'ITMREFBPC'
#Endif
TIT(0) = "Materiales"

NBCOL = 0
NBCOL += 1 : COL(NBCOL) = "CODE" : TIT(NBCOL) = "Código"
NBCOL += 1 : COL(NBCOL) = "TEXTE" : TIT(NBCOL) = "Descripción"
NBCOL += 1 : COL(NBCOL) = "A1" : TIT(NBCOL) = "Peso"
NBCOL += 1 : COL(NBCOL) = "A2" : TIT(NBCOL) = "Unid x caja"
#NBCOL += 1 : COL(NBCOL) = "BPCNUM"    : Gosub TEXTE
#NBCOL += 1 : COL(NBCOL) = "ITMREF"    : Gosub TEXTE
#If ART = ""
#    CRITERE = '[F:ITU]BPCNUM="'+CLI+'" & [F:ITM]ITMSTA=1'
#Else
#    CRITERE = '[F:ITU]BPCNUM="'+CLI+'" & [F:ITU]ITMREFBPC>="'+ART+'" & [F:ITM]ITMSTA=1'
#Endif
COLTYP(NBCOL) = 20
DEFPAG=1
Return


Return





$TEXTE
Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return

