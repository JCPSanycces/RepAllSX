  [M:SQH2]YPALPL10010(val(GPARAM1(1)))   = [M:YWQ2]YPALPL10010 : Affzo [M:SQH2]YPALPL10010(val(GPARAM1(1)))
  [M:SQH2]YPALPL12012(val(GPARAM1(1)))   = [M:YWQ2]YPALPL12012 : Affzo [M:SQH2]YPALPL12012(val(GPARAM1(1)))
  [M:SQH2]YPALMA408(val(GPARAM1(1)))     = [M:YWQ2]YPALMA408   : Affzo [M:SQH2]YPALMA408(val(GPARAM1(1)))
  [M:SQH2]YPALMA608(val(GPARAM1(1)))     = [M:YWQ2]YPALMA608   : Affzo [M:SQH2]YPALMA608(val(GPARAM1(1)))
  [M:SQH2]YPALMA100(val(GPARAM1(1)))     = [M:YWQ2]YPALMA100   : Affzo [M:SQH2]YPALMA100(val(GPARAM1(1)))
  [M:SQH2]YPALMA150(val(GPARAM1(1)))     = [M:YWQ2]YPALMA150   : Affzo [M:SQH2]YPALMA150(val(GPARAM1(1)))
  [M:SQH2]YMASTIL44(val(GPARAM1(1)))     = [M:YWQ2]YMASTIL44   : Affzo [M:SQH2]YMASTIL44(val(GPARAM1(1)))
  [M:SQH2]YMASTIL50(val(GPARAM1(1)))     = [M:YWQ2]YMASTIL50   : Affzo [M:SQH2]YMASTIL50(val(GPARAM1(1)))
  [M:SQH2]YEMBOLSADO(val(GPARAM1(1)))    = [M:YWQ2]YEMBOLSADO  : Affzo [M:SQH2]YEMBOLSADO(val(GPARAM1(1)))
  [M:SQH2]YVELCRO(val(GPARAM1(1)))       = [M:YWQ2]YVELCRO     : Affzo [M:SQH2]YVELCRO(val(GPARAM1(1)))
  [M:SQH2]YVELCROAR(val(GPARAM1(1)))     = [M:YWQ2]YVELCROAR   : Affzo [M:SQH2]YVELCROAR(val(GPARAM1(1)))
  [M:SQH2]YVELCROAB(val(GPARAM1(1)))     = [M:YWQ2]YVELCROAB   : Affzo [M:SQH2]YVELCROAB(val(GPARAM1(1)))
  [M:SQH2]YVELCROIZ(val(GPARAM1(1)))     = [M:YWQ2]YVELCROIZ   : Affzo [M:SQH2]YVELCROIZ(val(GPARAM1(1)))
  [M:SQH2]YVELCRODE(val(GPARAM1(1)))     = [M:YWQ2]YVELCRODE   : Affzo [M:SQH2]YVELCRODE(val(GPARAM1(1)))
  [M:SQH2]YSILICON(val(GPARAM1(1)))      = [M:YWQ2]YSILICON    : Affzo [M:SQH2]YSILICON(val(GPARAM1(1)))
  [M:SQH2]YSILICONAR(val(GPARAM1(1)))    = [M:YWQ2]YSILICONAR  : Affzo [M:SQH2]YSILICONAR(val(GPARAM1(1)))
  [M:SQH2]YSILICONAB(val(GPARAM1(1)))    = [M:YWQ2]YSILICONAB  : Affzo [M:SQH2]YSILICONAB(val(GPARAM1(1)))
  [M:SQH2]YSILICONIZ(val(GPARAM1(1)))    = [M:YWQ2]YSILICONIZ  : Affzo [M:SQH2]YSILICONIZ(val(GPARAM1(1)))
  [M:SQH2]YSILICONDE(val(GPARAM1(1)))    = [M:YWQ2]YSILICONDE  : Affzo [M:SQH2]YSILICONDE(val(GPARAM1(1)))
  [M:SQH2]YOLLADOSLONA(val(GPARAM1(1)))  = [M:YWQ2]YOLLADOSLONA: Affzo [M:SQH2]YOLLADOSLONA(val(GPARAM1(1)))
  [M:SQH2]YREFLONA(val(GPARAM1(1)))      = [M:YWQ2]YREFLONA    : Affzo [M:SQH2]YREFLONA(val(GPARAM1(1)))
  [M:SQH2]YREFLONAAR(val(GPARAM1(1)))    = [M:YWQ2]YREFLONAAR  : Affzo [M:SQH2]YREFLONAAR(val(GPARAM1(1)))
  [M:SQH2]YREFLONAAB(val(GPARAM1(1)))    = [M:YWQ2]YREFLONAAB  : Affzo [M:SQH2]YREFLONAAB(val(GPARAM1(1)))
  [M:SQH2]YREFLONAIZ(val(GPARAM1(1)))    = [M:YWQ2]YREFLONAIZ  : Affzo [M:SQH2]YREFLONAIZ(val(GPARAM1(1)))
  [M:SQH2]YREFLONADE(val(GPARAM1(1)))    = [M:YWQ2]YREFLONADE  : Affzo [M:SQH2]YREFLONADE(val(GPARAM1(1)))

  Grizo [M:SQH2]YASISTENTE(val(GPARAM1(1))),YASISTENTE(val(GPARAM1(1))),YCALCULAPB(val(GPARAM1(1))),YCREAITM(val(GPARAM1(1)))





  Kill GALTOANCHO, GDESCBANDERA
  Gosub CERRAR_TABLAS
  zonsui = "[M:SQH2]QTY(val(GPARAM1(1)))" # MAB.09062020.NEW, AÑADO CANTIDAD A PANTALLA DE PRESUPUESTOS.
  #Call  AM_QTY([M:SQH2]QTY(nolign-1)) From SPESQH
  # Infbox num$([M:SQH2]QTY(nolign-1))


Return

##############################################################
$FIN

Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ABRIR_TABLAS
  If !clalev([F:AXX0]) Then : Local File ATEXTRA    [F:AXX0] : Endif
  If !clalev([F:ITM1]) Then : Local File ITMMASTER  [F:ITM1] : Endif
Return

##############################################################
$CERRAR_TABLAS
  If  clalev([F:AXX0]) Then : Close Local File  [F:AXX0] : Endif
  If  clalev([F:ITM1]) Then : Close Local File  [F:ITM1] : Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Después de modificar 'Rango'
######################################################################################
Subprog AM_RANGO(VALEUR)
Variable Char    VALEUR()
  Filter [F:AXX0] Where CODFIC = "ATABDIV" and ZONE = "LNGDES" and LANGUE = GLANGUE and IDENT1 = "2500" and IDENT2 = VALEUR
  Read [F:AXX0] First
  If !fstat Then
    GRANGO = '' # [F:AXX0]TEXTE+"," # Joan nos comenta que el rango no lo quiere ver en la descripción
  Endif
  # COMPROBAR SI EL ALTOXANCHO ESTA INSERTADO Y BORRARLO
  If [M:YWQ1]ALTO <> "" Then
    [M:YWQ1]ALTO = ""
    Affzo [M:YWQ1]ALTO
  Endif
  If [M:YWQ1]ANCHO <> "" Then
    [M:YWQ1]ANCHO = ""
    Affzo [M:YWQ1]ANCHO
  Endif
  # If mkstat <> 2 Then : Grizo [M:YWQ1]RANGO : Endif # MAB.03062020.OLD
  Filter [F:AXX0]
End

######################################################################################
## Después de modificar 'Tipo de impresión'
######################################################################################
Subprog AM_TIPOIMP(VALEUR)
Variable Char    VALEUR()
  Filter [F:AXX0] Where CODFIC = "ATABDIV" and ZONE = "LNGDES" and LANGUE = GLANGUE and IDENT1 = "2501" and IDENT2 = VALEUR
  Read [F:AXX0] First
  If !fstat Then
    [M:YWQ1]DTIPOIMP = [F:AXX0]TEXTE # +","
    Affzo [M:YWQ1]DTIPOIMP
  Endif
  Filter [F:AXX0]
  If VALEUR = "01" Then
    Grizo [M:YWQ1]FABRICADA
    [M:YWQ1]FABRICADA   = ""
    [M:YWQ1]DFABRICADA  = ""
    Affzo [M:YWQ1]DFABRICADA
    Affzo [M:YWQ1]FABRICADA
    Actzo [M:YWQ1]NUMCOLORES
    Actzo [M:YWQ1]RANGO
    Chgfmt  [M:YWQ1]PRECIOEUR With "D:"+GFMDAT  #show field
    Affzo [M:YWQ1]PRECIOEUR
  Else
    Actzo [M:YWQ1]FABRICADA
    Grizo [M:YWQ1]NUMCOLORES
    [M:YWQ1]NUMCOLORES  = ""
    [M:YWQ1]DNUMCOLORES = ""
    Affzo [M:YWQ1]DNUMCOLORES
    Affzo [M:YWQ1]NUMCOLORES
    # Grizo [M:YWQ1]RANGO # DEJO ACTIVADO EL RANGO HASTA QUE INTRODUZCAN FABRICACIÓN
    [M:YWQ1]RANGO = ""
    Affzo [M:YWQ1]RANGO
    Chgfmt  [M:YWQ1]PRECIOEUR With "-N:"+GFMDAT #hide field
    Affzo [M:YWQ1]PRECIOEUR
  Endif
  [M:YWQ1]TIPOIMP = VALEUR
  Affzo [M:YWQ1]TIPOIMP

  # If mkstat <> 2 Then : Grizo [M:YWQ1]TIPOIMP : Endif # MAB.03062020.OLD
End

######################################################################################
## Después de modificar 'Material'
######################################################################################
Subprog AM_MATERIAL(VALEUR)
Variable Char    VALEUR()
  Filter [F:AXX0] Where CODFIC = "ATABDIV" and ZONE = "LNGDES" and LANGUE = GLANGUE and IDENT1 = "2502" and IDENT2 = VALEUR
  Read [F:AXX0] First
  If !fstat Then
    [M:YWQ1]DMATERIAL = [F:AXX0]TEXTE # +","
    Affzo [M:YWQ1]DMATERIAL
  Endif
  Filter [F:AXX0]
  # If mkstat <> 2 Then : Grizo [M:YWQ1]MATERIAL : Endif # MAB.03062020.OLD
End

######################################################################################
## Después de modificar 'Fabricada'
######################################################################################
Subprog AM_FABRICADA(VALEUR)
Variable Char    VALEUR()
  Filter [F:AXX0] Where CODFIC = "ATABDIV" and ZONE = "LNGDES" and LANGUE = GLANGUE and IDENT1 = "2503" and IDENT2 = VALEUR
  Read [F:AXX0] First
  If !fstat Then
    [M:YWQ1]DFABRICADA = [F:AXX0]TEXTE # +","
    Affzo [M:YWQ1]DFABRICADA
  Endif
  Filter [F:AXX0]
  If VALEUR = '01' Then # IMAZU
    Grizo [M:YWQ1]RANGO # DESACTIVO EL RANGO
    [M:YWQ1]RANGO = ""
    Affzo [M:YWQ1]RANGO
  Else
    Actzo [M:YWQ1]RANGO # ACTIVO EL RANGO PARA IMPORTADAS
  Endif
  # If mkstat <> 2 Then : Grizo [M:YWQ1]FABRICADA : Endif # MAB.03062020.OLD
End

######################################################################################
## Después de modificar 'Alto'
######################################################################################
Subprog AM_ALTO(VALEUR)
Variable Char    VALEUR()
Local Decimal LAREA

  LAREA = arr(((val([M:YWQ1]ANCHO) * 0.01) * (val(VALEUR) * 0.01)),0.01)
  If [M:YWQ1]RANGO = "01" Then
    If LAREA > 1 Then
      If [M:YWQ1]TIPOIMP = "01" Then
        Call MESSAGE("Alto x Base debe ser menor a 1m2") From GESECRAN
        Actzo [M:YWQ1]ALTO
        mkstat = 2
      Endif
    Else
      [M:YWQ1]DALTO = VALEUR
      Affzo [M:YWQ1]DALTO
    Endif
  Else
    If (LAREA < 1) and (LAREA <> 0) Then
      If [M:YWQ1]TIPOIMP = "01" Then
        Call MESSAGE("Alto x Base debe ser mayor a 1m2") From GESECRAN
        Actzo [M:YWQ1]ALTO
        mkstat = 2
      Endif
    Else
      [M:YWQ1]DALTO = VALEUR
      Affzo [M:YWQ1]DALTO
    Endif
  Endif
  GALTOANCHO += 1
End

######################################################################################
## Después de modificar 'Ancho'
######################################################################################
Subprog AM_ANCHO(VALEUR)
Variable Char    VALEUR()
  [M:YWQ2]YCINTAREFTAM = VALEUR+"cm"+[M:YWQ1]DALTO+"cm x "
  Affzo [M:YWQ2]YCINTAREFTAM
  [M:YWQ2]YMNGVAINATAM = VALEUR+"cm"+[M:YWQ1]DALTO+"cm x "
  Affzo [M:YWQ2]YMNGVAINATAM
  [M:YWQ2]YCINTASILTAM = VALEUR+"cm"+[M:YWQ1]DALTO+"cm x "
  Affzo [M:YWQ2]YCINTASILTAM
  [M:YWQ2]YVELCROTAM   = VALEUR+"cm"+[M:YWQ1]DALTO+"cm x "
  Affzo [M:YWQ2]YVELCROTAM
  [M:YWQ2]YSILICONTAM  = +VALEUR+"cm"+[M:YWQ1]DALTO+"cm x "
  Affzo [M:YWQ2]YSILICONTAM
  [M:YWQ2]YREFLONATAM  = VALEUR+"cm"+[M:YWQ1]DALTO+"cm x "
  Affzo [M:YWQ2]YREFLONATAM
  GALTOANCHO += 1
  [M:YWQ1]DANCHO = VALEUR
  Affzo [M:YWQ1]DANCHO
 # Grizo [M:YWQ1]ANCHO # MAB.03062020.OLD
 # Grizo [M:YWQ1]ALTO # MAB.03062020.OLD
End

######################################################################################
## Después de campo 'Ancho'
######################################################################################
Subprog C_ANCHO(VALEUR)
Variable Char    VALEUR()
Local Decimal LAREA
  LAREA = arr(((val([M:YWQ1]ALTO) * 0.01) * (val(VALEUR) * 0.01)),0.0001)
  If [M:YWQ1]RANGO = "01" Then
    If [M:YWQ1]TIPOIMP = "01" Then
      If LAREA > 1 Then
        Call ERREUR("Alto x Base debe ser menor a 1m2") From GESECRAN
        mkstat = 2
      Endif
    Endif
  Else
    If [M:YWQ1]TIPOIMP = "01" Then
      If (LAREA < 1) and (LAREA <> 0) Then
        Call ERREUR("Alto x Base debe ser mayor a 1m2") From GESECRAN
        mkstat = 2
      Endif
    Endif
  Endif
End

######################################################################################
## Después de modificar 'Número de colores'
######################################################################################
Subprog AM_NUMCOLORES(VALEUR)
Variable Char    VALEUR()
  If [M:YWQ1]TIPOIMP = "01" Then
    If [M:YWQ1]RANGO = "01" Then
      If VALEUR="03" or VALEUR="04" or VALEUR="05" or VALEUR="06" or VALEUR="07" or VALEUR="08" or VALEUR="09" Then
        VALEUR = ""
        [M:YWQ1]DNUMCOLORES = ""
        Affzo [M:YWQ1]DNUMCOLORES
        Affzo [M:YWQ1]NUMCOLORES
        Call MESSAGE("Debes elegir uno de los dos primeros valores de la lista") From GESECRAN
        mkstat = 2
      Endif
    Else
      If VALEUR="01" or VALEUR="02" Then
        VALEUR = ""
        [M:YWQ1]DNUMCOLORES = ""
        Affzo [M:YWQ1]DNUMCOLORES
        Affzo [M:YWQ1]NUMCOLORES
        Call MESSAGE("Debes elegir 1,2,3,4,5,6,7,8 colores") From GESECRAN
        mkstat = 2
      Endif
    Endif
  Endif

  Filter [F:AXX0] Where CODFIC = "ATABDIV" and ZONE = "SHODES" and LANGUE = GLANGUE and IDENT1 = "2505" and IDENT2 = VALEUR
  Read [F:AXX0] First
  If !fstat Then
    [M:YWQ1]DNUMCOLORES = [F:AXX0]TEXTE # +","
    Affzo [M:YWQ1]DNUMCOLORES
  Endif
  Filter [F:AXX0]

 # If mkstat <> 2 Then : Grizo [M:YWQ1]NUMCOLORES : Endif # MAB.03062020.OLD
End

######################################################################################
## Después del campo 'Número de colores'
######################################################################################
Subprog AS_NUMCOLORES(VALEUR)
Variable Char    VALEUR()
  Raz GMENLOC
  If [M:YWQ1]TIPOIMP = "01" Then
    If [M:YWQ1]RANGO = "01" Then
      GMENLOC(3)  = 1
      GMENLOC(4)  = 1
      GMENLOC(5)  = 1
      GMENLOC(6)  = 1
      GMENLOC(7)  = 1
      GMENLOC(8)  = 1
      GMENLOC(9)  = 1
      GMENLOC(10) = 1
    Else
      GMENLOC(1)  = 1
      GMENLOC(2)  = 1
    Endif
  Endif
End

######################################################################################
## Después de modificar 'Pespunte'
######################################################################################
Subprog AM_PESPUNTE(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    [M:YWQ1]DPESPUNTE   = ", con Pespunte perimetral"
    Affzo [M:YWQ1]DPESPUNTE
    [M:YWQ1]CONFNORMAL  = 1
    [M:YWQ1]DCONFNORMAL = ""
    [M:YWQ1]CONFFLY     = 1
    [M:YWQ1]DCONFFLY    = ""
    Grizo [M:YWQ1]CONFNORMAL
    Affzo [M:YWQ1]DCONFNORMAL
    Grizo [M:YWQ1]CONFFLY
    Affzo [M:YWQ1]DCONFFLY
#    Grizo [M:YWQ1]CONFFLYITM
#    Affzo [M:YWQ1]CONFFLYITM
#    Grizo [M:YWQ1]CONFNORMALD
#    Affzo [M:YWQ1]CONFNORMALD
    # JC.09092020.STR
    Actzo [M:YWQ1]QTY
    # JC.09092020.END
  Else
    [M:YWQ1]DPESPUNTE = ""
    Affzo [M:YWQ1]DPESPUNTE
    [M:YWQ1]CONFNORMAL  = 1
    [M:YWQ1]DCONFNORMAL = ""
    [M:YWQ1]CONFFLY     = 1
    [M:YWQ1]DCONFFLY    = ""
    Actzo [M:YWQ1]CONFNORMAL
    Affzo [M:YWQ1]DCONFNORMAL
    Actzo [M:YWQ1]CONFFLY
    Affzo [M:YWQ1]DCONFFLY
#    Actzo [M:YWQ1]CONFFLYITM
#    Affzo [M:YWQ1]CONFFLYITM
#    Actzo [M:YWQ1]CONFNORMALD
#    Affzo [M:YWQ1]CONFNORMALD
    # JC.09092020.STR
    [M:YWQ1]QTY       = 0
    #Grizo [M:YWQ1]QTY
    # JC.09092020.END
  Endif

  # JC.09092020.STR
  [M:YWQ1]CONFNORMALD = ""
  [M:YWQ1]CONFFLYITM  = ""
  Grizo [M:YWQ1]CONFNORMALD,CONFFLYITM
  # JC.09092020.END
End

