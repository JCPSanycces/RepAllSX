  [M:YWQ1]REFERENCIA = VALEUR
  Affzo [M:YWQ1]REFERENCIA
  # If mkstat <> 2 Then : Grizo [M:YWQ1]REFERENCIA : Endif
End

######################################################################################
## Después de modificar 'Cinta de refuerzo'
######################################################################################
Subprog AM_YCINTAREF(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    Actzo [M:YWQ2]YCINTAREFAR
    Actzo [M:YWQ2]YCINTAREFAB
    Actzo [M:YWQ2]YCINTAREFIZ
    Actzo [M:YWQ2]YCINTAREFDE
#    GCINTAREF = "con Cinta de Refuerzo"
#    GDESCEXTRA -= GCINTAREF
  Elsif VALEUR = 1 Then
    [M:YWQ2]YCINTAREFAR = 1
    [M:YWQ2]YCINTAREFAB = 1
    [M:YWQ2]YCINTAREFIZ = 1
    [M:YWQ2]YCINTAREFDE = 1
    Grizo [M:YWQ2]YCINTAREFAR
    Grizo [M:YWQ2]YCINTAREFAB
    Grizo [M:YWQ2]YCINTAREFIZ
    Grizo [M:YWQ2]YCINTAREFDE
#    GCINTAREF = ""
    GCINTAREFCONT = 0
