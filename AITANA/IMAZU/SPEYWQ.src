#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT51" Then : Infbox ACTION : Endif
Case ACTION
  When "DEBUT"      : Gosub DEBUT
  When "SETBOUT"    : Gosub SETBOUT
  When "OK"         : Gosub OK
  When "FIN"        : Gosub FIN
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$DEBUT

  Global Char    GRANGO(50)       : Raz GRANGO
  Global Integer GALTOANCHO       : Raz GALTOANCHO
  Global Clbfile GDESCBANDERA(1)
  Global Clbfile GDESCEXTRA(2)    : Raz GDESCEXTRA
  Global Clbfile GDESCOMPLETA(3)  : Raz GDESCOMPLETA

  Global Char GYCODLIN(30)         : Raz GYCODLIN
  # IDENTIFICACIÓN DE LA LÍNEA DE PRESUPUESTO QUE ESTAMOS CREANDO
  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
  LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)
  GYCODLIN = LFECHA + LHORA

  # campos pantalla Extra
  Global Char GCINTAREF(50),GCINTAREFAR(20),GCINTAREFAB(20),GCINTAREFIZ(20),GCINTAREFDE(20) : Raz GCINTAREF,GCINTAREFAR,GCINTAREFAB,GCINTAREFIZ,GCINTAREFDE
  Global Integer GCINTAREFCONT : Raz GCINTAREFCONT
  Global Char GOLLADOS(50) : Raz GOLLADOS
  Global Char GANILLAS(50) : Raz GANILLAS
  Global Char GCINTAATAR(50),GLARGO(20) : Raz GCINTAATAR,GLARGO
  Global Char GMNGVAINA(50),GMNGVAINAAR(20),GMNGVAINAAB(20),GMNGVAINAIZ(20),GMNGVAINADE(20) : Raz GMNGVAINA,GMNGVAINAAR,GMNGVAINAAB,GMNGVAINAIZ,GMNGVAINADE
  Global Integer GMNGVAINACONT : Raz GMNGVAINACONT
  Global Char GCNTMSTL(50),GCNTMSTLQTY(20) : Raz GCNTMSTL,GCNTMSTLQTY
  Global Char GABRPVC(50),YABRPVCQTY(20) : Raz YABRPVC,YABRPVCQTY
  Global Char GCINTASIL(50),GCINTASILAR(20),GCINTASILAB(20),GCINTASILIZ(20),GCINTASILDE(20) : Raz GCINTASIL,GCINTASILAR,GCINTASILAB,GCINTASILIZ,GCINTASILDE
  Global Integer GCINTASILCONT : Raz GCINTASILCONT
  Global Char GPALPL256(50),GPALPL306(50),GPALPL406(50),GPALPL408(50),GPALPL608(50),GPALPL10010(50),GPALPL12012(50) : Raz GPALPL256,GPALPL306,GPALPL406,GPALPL408,GPALPL608,GPALPL10010,GPALPL12012
  Global Char GPALMA408(50),GPALMA608(50),GPALMA100(50),GPALMA150(50) : Raz GPALMA408,GPALMA608,GPALMA100,GPALMA150
  Global Char GMASTIL44(50),GMASTIL50(50) : Raz GMASTIL44,GMASTIL50
  Global Char GEMBOLSADO(50) : Raz GEMBOLSADO
  Global Char GVELCRO(50),GVELCROAR(50),GVELCROAB(50),GVELCROIZ(50),GVELCRODE(50) : Raz GVELCRO,GVELCROAR,GVELCROAB,GVELCROIZ,GVELCRODE
  Global Integer GVELCROCONT : Raz GVELCROCONT
  Global Char GSILICON(50),GSILICONAR(50),GSILICONAB(50),GSILICONIZ(50),GSILICONDE(50) : Raz GSILICON,GSILICONAR,GSILICONAB,GSILICONIZ,GSILICONDE
  Global Integer GSILICONCONT : Raz GSILICONCONT
  Global Char GOLLADOSLONA(50) : Raz GOLLADOSLONA
  Global Char GREFLONA(50),GREFLONAAR(50),GREFLONAAB(50),GREFLONAIZ(50),GREFLONADE(50) : Raz GREFLONA,GREFLONAAR,GREFLONAAB,GREFLONAIZ,GREFLONADE
  Global Integer GREFLONACONT : Raz GREFLONACONT

  Raz [M:YWQ0]
  Raz [M:YWQ1]
  Raz [M:YWQ2]
  zonsui = "[M:YWQ1]TIPOIMP"
  Gosub ABRIR_TABLAS
  Grizo [M:YWQ2]YCINTAREFAR,YCINTAREFAB,YCINTAREFIZ,YCINTAREFDE
  Grizo [M:YWQ2]YMNGVAINAAR,YMNGVAINAAB,YMNGVAINAIZ,YMNGVAINADE
  Grizo [M:YWQ2]YCINTASILAR,YCINTASILAB,YCINTASILIZ,YCINTASILDE
  Grizo [M:YWQ2]YVELCROAR,YVELCROAB,YVELCROIZ,YVELCRODE
  Grizo [M:YWQ2]YSILICONAR,YSILICONAB,YSILICONIZ,YSILICONDE
  Grizo [M:YWQ2]YREFLONAAR,YREFLONAAB,YREFLONAIZ,YREFLONADE
  Grizo [M:YWQ2]YLARGO,YCNTMSTLQTY,YABRPVCQTY
  # JC.09092020.STR
  Grizo [M:YWQ1]CONFNORMALD,CONFFLYITM # ,QTY
  # JC.09092020.END
  # ABRIMOS TRAZA NUEVA Y NOS GUARDAMOS EL NOMBRE DE LA TRAZA EN LA LINEA PARA ASÍ ABRIRLA CUANDO EL USUARIO QUIERA
  Local Char ZTMP
  [L]ZTMP = GTRACE
  #GTRACE = "F4279"
  Call OUVRE_TRACE("Traza Precio") From LECFIC
  #Infbox GTRACE
  #Call ECR_TRACE("Calculo de precio", 0 ) From GESECRAN
  #Call FERME_TRACE From LECFIC
  #Call LEC_TRACE From LECFIC   ##### to display the trace/log file
  #GTRACE = [L]ZTMP


  # Infbox "TEXTO:" + [M:SQH2]SQDTEX(nolign-1)

  #Infbox LRESTEXT

  Affzo   [M:YWQ0]TEXTO

Return

##############################################################
$SETBOUT
  Call SHOW_DESC()
Return

##############################################################
$OK
Local Char    LITMREF(100)  : Raz LITMREF
Local Integer YESNO01       : YESNO01 = 2     # sí
Local Char    LDETALLESOK(250)(1..)
Local Char    LEXTRASOK(250)(1..)
Local Char    LFECHA(10), LHORA(10) : Raz LFECHA, LHORA





  LDETALLESOK(1)  = "YBP"                             : LDETALLESOK(2)  = ""                                : LDETALLESOK(3)  = ""
  LDETALLESOK(4)  = ""                                : LDETALLESOK(5)  = ""                                : LDETALLESOK(6)  = num$([M:YWQ1]TIPOIMP)
  LDETALLESOK(7)  = num$([M:YWQ1]MATERIAL)            : LDETALLESOK(8)  = [M:YWQ1]ALTO                      : LDETALLESOK(9)  = [M:YWQ1]ANCHO
  LDETALLESOK(10) = [M:YWQ1]NUMCOLORES                : LDETALLESOK(11) = num$([M:YWQ1]PESPUNTE)            : LDETALLESOK(12) = num$([M:YWQ1]CONFNORMAL)
  LDETALLESOK(13) = num$([M:YWQ1]CONFFLY)             : LDETALLESOK(14) = num$([M:YWQ1]FABRICADA)           : LDETALLESOK(15) = [M:YWQ1]REFERENCIA
  LDETALLESOK(16) = num$([M:YWQ1]RANGO)               : LDETALLESOK(17) = ""

  LDETALLESOK(18) = num$([M:YWQ1]QTY) # MAB.09062020.NEW, AÑADO CANTIDAD A PANTALLA DE PRESUPUESTOS.

  # JC.09092020.STR
  LDETALLESOK(19) = num$([M:YWQ1]CONFNORMALD)         : LDETALLESOK(20) = num$([M:YWQ1]CONFFLYITM)
  # JC.09092020.END

  LEXTRASOK(1)    = num$([M:YWQ2]YCINTAREF)           : LEXTRASOK(2)    = num$([M:YWQ2]YCINTAREFAR)         : LEXTRASOK(3)    = num$([M:YWQ2]YCINTAREFAB)
  LEXTRASOK(4)    = num$([M:YWQ2]YCINTAREFIZ)         : LEXTRASOK(5)    = num$([M:YWQ2]YCINTAREFDE)         : LEXTRASOK(6)    = num$([M:YWQ2]YOLLADOS)
  LEXTRASOK(7)    = num$([M:YWQ2]YANILLAS)            : LEXTRASOK(8)    = num$([M:YWQ2]YCINTAATAR)          : LEXTRASOK(9)    = num$([M:YWQ2]YLARGO)
  LEXTRASOK(10)   = num$([M:YWQ2]YMNGVAINA)           : LEXTRASOK(11)   = num$([M:YWQ2]YMNGVAINAAR)         : LEXTRASOK(12)   = num$([M:YWQ2]YMNGVAINAAB)
  LEXTRASOK(13)   = num$([M:YWQ2]YMNGVAINAIZ)         : LEXTRASOK(14)   = num$([M:YWQ2]YMNGVAINADE)         : LEXTRASOK(15)   = num$([M:YWQ2]YCNTMSTL)
  LEXTRASOK(16)   = num$([M:YWQ2]YCNTMSTLQTY)         : LEXTRASOK(17)   = num$([M:YWQ2]YABRPVC)             : LEXTRASOK(18)   = num$([M:YWQ2]YABRPVCQTY)
  LEXTRASOK(19)   = num$([M:YWQ2]YCINTASIL)           : LEXTRASOK(20)   = num$([M:YWQ2]YCINTASILAR)         : LEXTRASOK(21)   = num$([M:YWQ2]YCINTASILAB)
  LEXTRASOK(22)   = num$([M:YWQ2]YCINTASILIZ)         : LEXTRASOK(23)   = num$([M:YWQ2]YCINTASILDE)         : LEXTRASOK(24)   = num$([M:YWQ2]YPALPL256)
  LEXTRASOK(25)   = num$([M:YWQ2]YPALPL306)           : LEXTRASOK(26)   = num$([M:YWQ2]YPALPL406)           : LEXTRASOK(27)   = num$([M:YWQ2]YPALPL408)
  LEXTRASOK(28)   = num$([M:YWQ2]YPALPL608)           : LEXTRASOK(29)   = num$([M:YWQ2]YPALPL10010)         : LEXTRASOK(30)   = num$([M:YWQ2]YPALPL12012)
  LEXTRASOK(31)   = num$([M:YWQ2]YPALMA408)           : LEXTRASOK(32)   = num$([M:YWQ2]YPALMA608)           : LEXTRASOK(33)   = num$([M:YWQ2]YPALMA100)
  LEXTRASOK(34)   = num$([M:YWQ2]YPALMA150)           : LEXTRASOK(35)   = num$([M:YWQ2]YMASTIL44)           : LEXTRASOK(36)   = num$([M:YWQ2]YMASTIL50)
  LEXTRASOK(37)   = num$([M:YWQ2]YEMBOLSADO)          : LEXTRASOK(38)   = num$([M:YWQ2]YVELCRO)             : LEXTRASOK(39)   = num$([M:YWQ2]YVELCROAR)
  LEXTRASOK(40)   = num$([M:YWQ2]YVELCROAB)           : LEXTRASOK(41)   = num$([M:YWQ2]YVELCROIZ)           : LEXTRASOK(42)   = num$([M:YWQ2]YVELCRODE)
  LEXTRASOK(43)   = num$([M:YWQ2]YSILICON)            : LEXTRASOK(44)   = num$([M:YWQ2]YSILICONAR)          : LEXTRASOK(45)   = num$([M:YWQ2]YSILICONAB)
  LEXTRASOK(46)   = num$([M:YWQ2]YSILICONIZ)          : LEXTRASOK(47)   = num$([M:YWQ2]YSILICONDE)          : LEXTRASOK(48)   = num$([M:YWQ2]YOLLADOSLONA)
  LEXTRASOK(49)   = num$([M:YWQ2]YREFLONA)            : LEXTRASOK(50)   = num$([M:YWQ2]YREFLONAAR)          : LEXTRASOK(51)   = num$([M:YWQ2]YREFLONAAB)
  LEXTRASOK(52)   = num$([M:YWQ2]YREFLONAIZ)          : LEXTRASOK(53)   = num$([M:YWQ2]YREFLONADE)


  #IDENTIFICACIÓN DE LA LÍNEA EN EL PRESUPUESTO
  [M:SQH2]YCODLIN(val(GPARAM1(1)))       = GYCODLIN
  Affzo [M:SQH2]YCODLIN(val(GPARAM1(1)))
  # pantalla DETALLE
  [M:SQH2]ITMDES(val(GPARAM1(1)))        = GDESCBANDERA        : Affzo [M:SQH2]ITMDES(val(GPARAM1(1)))
  [M:SQH2]YDESCITM(val(GPARAM1(1)))      = GDESCBANDERA        : Affzo [M:SQH2]YDESCITM(val(GPARAM1(1)))
  [M:SQH2]SAU(val(GPARAM1(1)))           = "UN"                : Affzo [M:SQH2]SAU(val(GPARAM1(1)))
  [M:SQH2]STU(val(GPARAM1(1)))           = "UN"                : Affzo [M:SQH2]STU(val(GPARAM1(1)))
  [M:SQH2]YRANGO(val(GPARAM1(1)))        = [M:YWQ1]RANGO       : Affzo [M:SQH2]YRANGO(val(GPARAM1(1)))
  [M:SQH2]YTIPOIMP(val(GPARAM1(1)))      = [M:YWQ1]TIPOIMP     : Affzo [M:SQH2]YTIPOIMP(val(GPARAM1(1)))
  [M:SQH2]YMATERIAL(val(GPARAM1(1)))     = [M:YWQ1]MATERIAL    : Affzo [M:SQH2]YMATERIAL(val(GPARAM1(1)))
  [M:SQH2]YALTO(val(GPARAM1(1)))         = [M:YWQ1]ALTO        : Affzo [M:SQH2]YALTO(val(GPARAM1(1)))
  [M:SQH2]YANCHO(val(GPARAM1(1)))        = [M:YWQ1]ANCHO       : Affzo [M:SQH2]YANCHO(val(GPARAM1(1)))
  [M:SQH2]YNUMCOLORES(val(GPARAM1(1)))   = [M:YWQ1]NUMCOLORES  : Affzo [M:SQH2]YNUMCOLORES(val(GPARAM1(1)))
  [M:SQH2]YPESPUNTE(val(GPARAM1(1)))     = [M:YWQ1]PESPUNTE    : Affzo [M:SQH2]YPESPUNTE(val(GPARAM1(1)))
  [M:SQH2]YCONFNORMAL(val(GPARAM1(1)))   = [M:YWQ1]CONFNORMAL  : Affzo [M:SQH2]YCONFNORMAL(val(GPARAM1(1)))
  [M:SQH2]YCONFFLY(val(GPARAM1(1)))      = [M:YWQ1]CONFFLY     : Affzo [M:SQH2]YCONFFLY(val(GPARAM1(1)))
  [M:SQH2]YFABRICADA(val(GPARAM1(1)))    = [M:YWQ1]FABRICADA   : Affzo [M:SQH2]YFABRICADA(val(GPARAM1(1)))
  [M:SQH2]YREFERENCIA(val(GPARAM1(1)))   = [M:YWQ1]REFERENCIA  : Affzo [M:SQH2]YREFERENCIA(val(GPARAM1(1)))
  [M:SQH2]QTY(val(GPARAM1(1)))           = [M:YWQ1]QTY         : Affzo [M:SQH2]QTY(val(GPARAM1(1)))  # MAB.09062020.NEW, AÑADO CANTIDAD A PANTALLA DE PRESUPUESTOS.

  # JC.09092020.STR
  [M:SQH2]YCONFNORMALD(val(GPARAM1(1)))  = [M:YWQ1]CONFNORMALD : Affzo [M:SQH2]YCONFNORMALD(val(GPARAM1(1)))
  [M:SQH2]YCONFFLYITM(val(GPARAM1(1)))   = [M:YWQ1]CONFFLYITM  : Affzo [M:SQH2]YCONFFLYITM(val(GPARAM1(1)))
  # JC.09092020.END


  Global Char LRESTEXT
  LRESTEXT = func SPEYLIB0.F_CRELOB("SQD",[M:YWQ0]TEXTO)
  [M:SQH2]YSQDTEX(val(GPARAM1(1))) = LRESTEXT
  Affzo [M:SQH2]YSQDTEX(val(GPARAM1(1)))



   If !clalev([ZYTE]) Then : Local File YTEXTPRE [ZYTE] : Endif
   # grabamos los componentes de la línea de presupuesto en la tabla de extras
   # y lo relacionamos con la línea de presupuesto mediante el YCODLIN
  Trbegin [ZYTE]
   For I = 0 To [M:YWQ2]YNBLIG
    If [M:YWQ2]YEXTCOD(I) <> "" Then
      [F:ZYTE]YCODLIN = [M:SQH2]YCODLIN(val(GPARAM1(1)))
      [F:ZYTE]YEXTCOD = [M:YWQ2]YEXTCOD(I)
      [F:ZYTE]YEXTCANT = [M:YWQ2]YEXTCANT(I)
      [F:ZYTE]YEXTABA = [M:YWQ2]YEXTABA(I)
      [F:ZYTE]YEXTARR = [M:YWQ2]YEXTARR(I)
      [F:ZYTE]YEXTIZQ = [M:YWQ2]YEXTIZQ(I)
      [F:ZYTE]YEXTDER = [M:YWQ2]YEXTDER(I)
      [F:ZYTE]YEXTLARGO = [M:YWQ2]YEXTLARGO(I)
      [F:ZYTE]YTRAPRE = GTRACE
      Write [F:ZYTE]
    Endif
    #[M:SQH2]YEXTQTY(I) = [M:YWQ2]YEXTQTY(I)
   Next I
   Commit
   # GRABAR TRAZA

  Call FERME_TRACE From LECFIC




