  # If mkstat <> 2 Then : Grizo [M:YWQ2]YSILICONIZ : Endif # MAB.04062020
End

######################################################################################
## Después de modificar 'Silicon Derecha'
######################################################################################
Subprog AM_YSILICONDE(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    GSILICONDE = "Derecha(S)"
    GSILICONCONT += 1
  Else
    GSILICONDE = ""
    GSILICONCONT -= 1
  Endif
  If GSILICONCONT = 1 Then
    GDESCEXTRA -= "Posición"-GSILICONDE
  Else
      GDESCEXTRA -= GSILICONDE
  Endif
  # SI DESACTIVAMOS EL CHECK
  If VALEUR = 1 Then
   If vireblc(GDESCEXTRA,2) <> "" Then
      If GSILICONCONT = 1 Then
        LRES = func REPLACESTR(GDESCEXTRA, "Posición Derecha(S)", "")
      Else
        LRES = func REPLACESTR(GDESCEXTRA, "Derecha(S)", "")
      Endif
      GDESCEXTRA = LRES
    Endif
  Endif


  [M:YWQ2]YSILICONDE = VALEUR
  Affzo [M:YWQ2]YSILICONDE
  # If mkstat <> 2 Then : Grizo [M:YWQ2]YSILICONDE : Endif # MAB.04062020
End

