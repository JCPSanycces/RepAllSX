Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR
Local Decimal LPRECIO
Local Integer LTIPOITM
Local Decimal LPRECIOUNIDAD, LPRECIOUNIDADEUR

  # BORRAMOS TRAZA SI EXISTE ...
   Call TRAZA_PRECIO(GYCODLIN , "", "" ,"") From SPEYLIB0

  If VALEUR <> 0 Then

#      If [M:YWQ1]TIPOIMP = "01" and [M:YWQ1]RANGO = "01" Then         # bandera estampada menor 1m2
#        LTIPOITM = 1 # obtención del valor unitario en la tarifa de banderas estampadas - 1m2
#      Elsif [M:YWQ1]TIPOIMP = "01" and [M:YWQ1]RANGO = "02" Then      # bandera estampada mayor 1m2
#        LTIPOITM = 2 # obtención de fotolito y valor unitario en la tarifa de banderas estampadas + 1m2
#      Elsif [M:YWQ1]TIPOIMP = "02" and [M:YWQ1]FABRICADA = "01" Then  # bandera digital fabricada ¿
#        LTIPOITM = 3 # obtención del valor unitario en la tarifa de banderas digitales fabricadas
#      Elsif [M:YWQ1]TIPOIMP = "02" and [M:YWQ1]FABRICADA = "02" Then  # bandera digital subcontratada
#        LTIPOITM = 4 # obtención del valor unitario en la tarifa de banderas digitales SUBCONTRATADA
#      Endif
      LTIPOITM = func GET_TIPO_ITM()
      Call SP_PRECIOUNIDAD(GYCODLIN, LPRECIOUNIDAD, LPRECIOUNIDADEUR, date$, [M:YWQ1]ALTO, [M:YWQ1]ANCHO, [M:YWQ1]MATERIAL , [M:YWQ1]NUMCOLORES , VALEUR,  LTIPOITM, "") From SPEYLIB0
      [M:YWQ1]PRECIO = LPRECIOUNIDAD
      Affzo [M:YWQ1]PRECIO
      [M:YWQ1]PRECIOEUR = LPRECIOUNIDADEUR
      Affzo [M:YWQ1]PRECIOEUR
  Endif

End


