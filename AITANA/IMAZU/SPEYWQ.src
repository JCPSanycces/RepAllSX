    [M:YWQ1]DCONFFLY    = ""
    Grizo [M:YWQ1]PESPUNTE
    Affzo [M:YWQ1]DPESPUNTE
    Grizo [M:YWQ1]CONFFLY
    Affzo [M:YWQ1]DCONFFLY
    Grizo [M:YWQ1]CONFFLYITM
    Affzo [M:YWQ1]CONFFLYITM
    # JC.09092020.STR
    Actzo [M:YWQ1]CONFNORMALD,QTY
    # JC.09092020.END
  Else
    [M:YWQ1]DCONFNORMAL = ""
    Affzo [M:YWQ1]DCONFNORMAL
    [M:YWQ1]PESPUNTE    = 1
    [M:YWQ1]DPESPUNTE   = ""
    [M:YWQ1]CONFFLY     = 1
    [M:YWQ1]DCONFFLY    = ""
    Actzo [M:YWQ1]PESPUNTE
    Affzo [M:YWQ1]DPESPUNTE
    Actzo [M:YWQ1]CONFFLY
    Affzo [M:YWQ1]DCONFFLY
