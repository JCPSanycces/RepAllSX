#**
#* Activa o descactiva campos en función de la parametria de la tabla varia 2506
#*
#* @param VALEUR
#*!
Subprog ACTIVAR_CAMPOS(PCAMPO)
  Value Char PCAMPO

  If !clalev([ZATA]) Then : Local File ATABDIV [ZATA] : Endif

  Read [ZATA]CODE=2506;PCAMPO
  If !fstat Then
    # activar las caracteristicas del componente extra
    # CANTIDAD
    If [F:ZATA]N1 = 1 Then
      Diszo [M:YWQ2]YEXTCANT(nolign-1)
    Else
      Actzo [M:YWQ2]YEXTCANT(nolign-1)
    Endif
    # ARRIBA
    If [F:ZATA]N2 = 1 Then
      Diszo [M:YWQ2]YEXTARR(nolign-1)
    Else
      Actzo [M:YWQ2]YEXTARR(nolign-1)
    Endif
    # ABAJO
    If [F:ZATA]N3 = 1 Then
      Diszo [M:YWQ2]YEXTABA(nolign-1)
    Else
      Actzo [M:YWQ2]YEXTABA(nolign-1)
    Endif
    # IZQUIERDA
    If [F:ZATA]N4 = 1 Then
      Diszo [M:YWQ2]YEXTIZQ(nolign-1)
    Else
      Actzo [M:YWQ2]YEXTIZQ(nolign-1)
    Endif

    # DERECHA
    If [F:ZATA]N5 = 1 Then
      Diszo [M:YWQ2]YEXTDER(nolign-1)
    Else
      Actzo [M:YWQ2]YEXTDER(nolign-1)
    Endif

     # LARGO EN CM
    If  [F:ZATA]N6 = 1 Then
      Diszo [M:YWQ2]YEXTLARGO(nolign-1)
    Else
      Actzo [M:YWQ2]YEXTLARGO(nolign-1)
      # [M:YWQ2]YEXTLARGO(nolign-1)
    Endif

  Endif


End

