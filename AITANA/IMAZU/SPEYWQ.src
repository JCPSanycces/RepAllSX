   [M:YWQ2]YOLLADOSLONA = VALEUR
  Affzo [M:YWQ2]YOLLADOSLONA
  # buscar etiqueta para eliminarla
  # If instr(1,GDESCEXTRA," ,"+[M:YWQ2]YOLLADOSLONA+"Ollados para lonas") > 0 Then
#  If vireblc(GDESCEXTRA,2) <> "" Then
#      LRES = func REPLACESTR(GDESCEXTRA, " ,"+num$([M:YWQ2]YOLLADOSLONA)-"Ollados para lonas", GOLLADOSLONA)
#      GDESCEXTRA = LRES
#  Else
#      GDESCEXTRA -= GOLLADOSLONA
#  Endif
  # Endif


  # If mkstat <> 2 Then : Grizo [M:YWQ2]YOLLADOSLONA : Endif # MAB.04062020
