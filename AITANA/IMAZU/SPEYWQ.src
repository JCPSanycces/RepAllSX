Subprog C_YEXTCOD(VALEUR)
Variable Char    VALEUR()

  # COMPROBAR QUE EL EXTRA NO EXISTE EN LA GRID.
  Call ACTIVAR_CAMPOS(VALEUR)

  Call UNICITE(VALEUR,[M:YWQ2]YEXTCOD(0..[M:YWQ2]YNBLIG-1)) From OBJDIV
  If mkstat = 2 Then
    VALEUR = ""
  Endif


End

