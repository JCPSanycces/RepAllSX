######################################################################################


Funprog GET_TIPO_ITM()
Local Integer LRES


  If [M:YWQ1]TIPOIMP = "01" and [M:YWQ1]RANGO = "01" Then         # bandera estampada menor 1m2
        LRES = 1 # obtención del valor unitario en la tarifa de banderas estampadas - 1m2
      Elsif [M:YWQ1]TIPOIMP = "01" and [M:YWQ1]RANGO = "02" Then      # bandera estampada mayor 1m2
        LRES = 2 # obtención de fotolito y valor unitario en la tarifa de banderas estampadas + 1m2
      Elsif [M:YWQ1]TIPOIMP = "02" and [M:YWQ1]FABRICADA = "01" Then  # bandera digital fabricada ¿
        LRES = 3 # obtención del valor unitario en la tarifa de banderas digitales fabricadas
      Elsif [M:YWQ1]TIPOIMP = "02" and [M:YWQ1]FABRICADA = "02" Then  # bandera digital subcontratada
        LRES = 4 # obtención del valor unitario en la tarifa de banderas digitales SUBCONTRATADA
  Endif

End LRES




