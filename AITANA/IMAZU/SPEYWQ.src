    # JC.09092020.STR
    [M:YWQ1]CONFNORMALD = ""
    [M:YWQ1]QTY         = 0
    Grizo [M:YWQ1]CONFNORMALD,CONFFLYITM #,QTY
    # JC.09092020.END
  Endif
End

