######################################################################################
## Después de modificar 'Silicon Arriba'
######################################################################################
Subprog AM_YSILICONAR(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    GSILICONAR = "Arriba(S)"
    GSILICONCONT += 1
  Else
    GSILICONAR = ""
    GSILICONCONT -= 1
  Endif

  If GSILICONCONT = 1 Then
    GDESCEXTRA -= "Posición"-GSILICONAR
  Else
    GDESCEXTRA -= GSILICONAR
  Endif

 # SI DESACTIVAMOS EL CHECK
  If VALEUR = 1 Then
   If vireblc(GDESCEXTRA,2) <> "" Then
      If GSILICONCONT = 1 Then
        LRES = func REPLACESTR(GDESCEXTRA, "Posición Arriba(S)", "")
      Else
        LRES = func REPLACESTR(GDESCEXTRA, "Arriba(S)", "")
      Endif
      GDESCEXTRA = LRES
    Endif
  Endif

  [M:YWQ2]YSILICONAR = VALEUR
  Affzo [M:YWQ2]YSILICONAR
  # If mkstat <> 2 Then : Grizo [M:YWQ2]YSILICONAR : Endif # MAB.04062020
End

