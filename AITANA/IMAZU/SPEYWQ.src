      #If LTIPOITM <> 3 Then
          #Call TRAZA_PRECIO(GYCODLIN , "",   "2.DENTRO CALCULO EXTRA. : " + num$(LVALORUNITARIOLOCALEXTRAS),"1") From SPEYLIB0
      #    Call CONVERTDIV("CNY","EUR",LVALORUNITARIOEXTRAS,1,LVALORUNITARIOLOCALEXTRAS) From SPEYLIB0
      #Endif
       [M:YWQ2]PRECIO(nolign-1) = LVALORUNITARIOEXTRAS
       [M:YWQ2]PRECIOEUR(nolign-1) = LVALORUNITARIOLOCALEXTRAS
       Affzo [M:YWQ2]PRECIO(nolign-1)
