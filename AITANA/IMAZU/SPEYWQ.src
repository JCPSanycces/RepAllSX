######################################################################################
## Después de modificar 'Refuerzo para Lonas'
######################################################################################
Subprog AM_YREFLONA(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    Actzo [M:YWQ2]YREFLONAAR
    Actzo [M:YWQ2]YREFLONAAB
    Actzo [M:YWQ2]YREFLONAIZ
    Actzo [M:YWQ2]YREFLONADE
  #  GREFLONA = " ,Refuerzos para Lonas"
  Else
    [M:YWQ2]YREFLONAAR = 1
    [M:YWQ2]YREFLONAAB = 1
    [M:YWQ2]YREFLONAIZ = 1
    [M:YWQ2]YREFLONADE = 1
    Grizo [M:YWQ2]YREFLONAAR
    Grizo [M:YWQ2]YREFLONAAB
    Grizo [M:YWQ2]YREFLONAIZ
    Grizo [M:YWQ2]YREFLONADE
  #  GREFLONA = ""
  Endif
  [M:YWQ2]YREFLONA = VALEUR
  Affzo [M:YWQ2]YREFLONA
  # If mkstat <> 2 Then : Grizo [M:YWQ2]YREFLONA : Endif # MAB.04062020
End

