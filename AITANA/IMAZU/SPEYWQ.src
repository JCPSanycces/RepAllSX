#**
#* compone la descripción
#*
#* @param PDATO  > dato del campo que hace la llamada
#*!
Subprog SHOW_DESC()

  Raz [M:YWQ0]COMPDES
  Raz GDESCBANDERA
  If [M:YWQ1]REFERENCIA <> "" Then
    GDESCBANDERA = [M:YWQ1]REFERENCIA+" "
  Else
    GDESCBANDERA = [M:YWQ1]REFERENCIA
  Endif

  If GALTOANCHO >= 2 Then
    GDESCBANDERA -= [M:YWQ1]DTIPOIMP-GRANGO-[M:YWQ1]DFABRICADA-[M:YWQ1]DMATERIAL-"("+[M:YWQ1]DANCHO+"x"+[M:YWQ1]DALTO+")cm"-[M:YWQ1]DNUMCOLORES-
&   [M:YWQ1]DPESPUNTE-[M:YWQ1]DCONFNORMAL-[M:YWQ1]DCONFFLY
  Else
    GDESCBANDERA -= [M:YWQ1]DTIPOIMP-GRANGO-[M:YWQ1]DFABRICADA-[M:YWQ1]DMATERIAL-[M:YWQ1]DANCHO+[M:YWQ1]DALTO-[M:YWQ1]DNUMCOLORES-
&   [M:YWQ1]DPESPUNTE-[M:YWQ1]DCONFNORMAL-[M:YWQ1]DCONFFLY
  Endif

  Call MONTAR_DESCRIPCION_EXTRA()

  GDESCOMPLETA = GDESCBANDERA-GDESCEXTRA
  [M:YWQ0]COMPDES = vireblc(GDESCOMPLETA,2)
  Affzo [M:YWQ0]COMPDES

End
##############################################################
#**
#* Subprograma que monta la descripción de los Extras
#*!
Subprog MONTAR_DESCRIPCION_EXTRA()
  Raz GDESCEXTRA
  Local Char LDESCTMP(250)

  For I = 0 To [M:YWQ2]YNBLIG

    If [M:YWQ2]YEXTCOD(I) = '' Then : Break : Endif
    # Infbox "DENTRO " + num$([M:YWQ2]YEXTARR(I))
    If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif
    # CANTIDAD
    If [M:YWQ2]YEXTCANT(I) > 0 Then
      GDESCEXTRA-=num$([M:YWQ2]YEXTCANT(I))
    Endif
    GDESCEXTRA -= func AFNC.TEXTRALAN("SPA","ATABDIV","LNGDES","2506", [M:YWQ2]YEXTCOD(I))
    LDESCTMP = ''
    Affzo [M:YWQ2]YEXTARR(I)
    If [M:YWQ2]YEXTARR(I) = 2 Then
      # Infbox "ARRIBA:" + num$([M:YWQ2]YEXTARR(I))
      If instr(1,LDESCTMP, "Posición") > 0 Then : LDESCTMP-="Arriba" Else : LDESCTMP-="Posición Arriba" : Endif
    Endif
    Affzo [M:YWQ2]YEXTABA(I)
    If [M:YWQ2]YEXTABA(I) = 2 Then
      # Infbox "ABAJO:" + num$([M:YWQ2]YEXTARR(I))
      If instr(1,LDESCTMP, "Posición") > 0 Then : LDESCTMP-="Abajo" Else : LDESCTMP-="Posición Abajo" : Endif
    Endif
    Affzo [M:YWQ2]YEXTIZQ(I)
    If [M:YWQ2]YEXTIZQ(I) = 2 Then
      # Infbox "IZQUIERDA:" + num$([M:YWQ2]YEXTARR(I))
      If instr(1,LDESCTMP, "Posición") > 0 Then : LDESCTMP-="Izquierda" Else : LDESCTMP-="Posición Izquierda" : Endif
    Endif
    Affzo [M:YWQ2]YEXTDER(I)
    If [M:YWQ2]YEXTDER(I) = 2 Then
      # Infbox "DERECHA:" + num$([M:YWQ2]YEXTARR(I))
      If instr(1,LDESCTMP, "Posición") > 0 Then : LDESCTMP-="Derecha" Else : LDESCTMP-="Posición Derecha" : Endif
    Endif
    If [M:YWQ2]YEXTLARGO(I) > 0 Then
      # Infbox "DERECHA:" + num$([M:YWQ2]YEXTARR(I))
      GDESCEXTRA -= "Largo " + num$([M:YWQ2]YEXTLARGO(I)) + " cm."
    Endif

    #If GDESCEXTRA <> "" and LDESCTMP <> '' Then : GDESCEXTRA-="," : Endif
    GDESCEXTRA-=LDESCTMP
    LDESCTMP = ''

  Next I


  If [M:YWQ2]YCINTAREF = 2 Then
    If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con Cinta de Refuerzo"
  Endif
  If [M:YWQ2]YCINTAREFAR = 2 Then
    If instr(1,GDESCEXTRA, "Refuerzo Posición") > 0 Then : GDESCEXTRA-="Arriba" Else : GDESCEXTRA-="Posición Arriba" : Endif
  Endif
  If [M:YWQ2]YCINTAREFAB = 2 Then
   If instr(1,GDESCEXTRA, "Refuerzo Posición") > 0 Then : GDESCEXTRA-="Abajo" Else : GDESCEXTRA-="Posición Abajo" : Endif
  Endif
  If [M:YWQ2]YCINTAREFIZ = 2 Then
    If instr(1,GDESCEXTRA, "Refuerzo Posición") > 0 Then : GDESCEXTRA-="Izquierda" Else : GDESCEXTRA-="Posición Izquierda" : Endif
  Endif
  If [M:YWQ2]YCINTAREFDE = 2 Then
   If instr(1,GDESCEXTRA, "Refuerzo Posición") > 0 Then : GDESCEXTRA-="Derecha" Else : GDESCEXTRA-="Posición Derecha" : Endif
  Endif

  If [M:YWQ2]YOLLADOS > 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-=num$([M:YWQ2]YOLLADOS)-"Ollados"
  Endif

  If [M:YWQ2]YANILLAS > 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-=" " : Endif  : GDESCEXTRA-=num$([M:YWQ2]YANILLAS)-"Anillas"
  Endif

  If [M:YWQ2]YCINTAATAR <> 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-=num$([M:YWQ2]YCINTAATAR)-"Cintas de Atar"
  Endif

  If [M:YWQ2]YLARGO <> 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="de"-num$([M:YWQ2]YLARGO)-"cms"
  Endif

  If [M:YWQ2]YMNGVAINA = 2 Then
    If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con Manga o Vaina"
  Endif
  If [M:YWQ2]YMNGVAINAAR = 2 Then
    If instr(1,GDESCEXTRA, "Vaina Posición") > 0 Then : GDESCEXTRA-="Arriba" Else : GDESCEXTRA-="Posición Arriba" : Endif
  Endif
  If [M:YWQ2]YMNGVAINAAB = 2 Then
    If instr(1,GDESCEXTRA, "Vaina Posición") > 0 Then : GDESCEXTRA-="Abajo" Else : GDESCEXTRA-="Posición Abajo" : Endif
  Endif
  If [M:YWQ2]YMNGVAINAIZ = 2 Then
    If instr(1,GDESCEXTRA, "Vaina Posición") > 0 Then : GDESCEXTRA-="Izquierda" Else : GDESCEXTRA-="Posición Izquierda" : Endif
  Endif
  If [M:YWQ2]YMNGVAINADE = 2 Then
    If instr(1,GDESCEXTRA, "Vaina Posición") > 0 Then : GDESCEXTRA-="Derecha" Else : GDESCEXTRA-="Posición Derecha" : Endif
  Endif

  If [M:YWQ2]YCNTMSTL = 2 and [M:YWQ2]YCNTMSTLQTY > 0  Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-=num$([M:YWQ2]YCNTMSTLQTY)-"Cintas para Mástil"
  Endif

  If [M:YWQ2]YABRPVC = 2 and [M:YWQ2]YABRPVCQTY > 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-=num$([M:YWQ2]YABRPVCQTY)-"Abrazaderas PVC"
  Endif

  If [M:YWQ2]YCINTASIL = 2 Then
    If GDESCEXTRA <> "" Then GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con Cinta de Silicon"
  Endif
  If [M:YWQ2]YCINTASILAR = 2 Then
    If instr(1,GDESCEXTRA, "Silicon Posición") > 0 Then : GDESCEXTRA-="Arriba" : Else : GDESCEXTRA-="Posición Arriba" : Endif
  Endif
  If [M:YWQ2]YCINTASILAB = 2 Then
    If instr(1,GDESCEXTRA, "Silicon Posición") > 0 Then : GDESCEXTRA-="Abajo" : Else : GDESCEXTRA-="Posición Abajo" : Endif
  Endif
  If [M:YWQ2]YCINTASILIZ = 2 Then
   If instr(1,GDESCEXTRA, "Silicon Posición") > 0 Then : GDESCEXTRA-="Izquierda" : Else : GDESCEXTRA-="Posición Izquierda" : Endif
  Endif
  If [M:YWQ2]YCINTASILDE = 2 Then
    If instr(1,GDESCEXTRA, "Silicon Posición") > 0 Then : GDESCEXTRA-="Derecha" : Else : GDESCEXTRA-="Posición Derecha" : Endif
  Endif

  If [M:YWQ2]YPALPL256 <> 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con"-num$([M:YWQ2]YPALPL256)-"Palitos Plástico de 25x6mm"
  Endif

  If [M:YWQ2]YPALPL306 <> 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con"-num$([M:YWQ2]YPALPL306)-"Palitos Plástico de 30X6mm"
  Endif

  If [M:YWQ2]YPALPL406 <> 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con"-num$([M:YWQ2]YPALPL406)-"Palitos Plástico de 40x6mm"
  Endif

  If [M:YWQ2]YPALPL408 <> 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con"-num$([M:YWQ2]YPALPL408)-"Palitos Plástico de 40x8mm"
  Endif

  If [M:YWQ2]YPALPL608 <> 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con"-num$([M:YWQ2]YPALPL608)-"Palitos Plástico de 60x8mm"
  Endif

  If [M:YWQ2]YPALPL10010 <> 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con"-num$([M:YWQ2]YPALPL10010)-"Palitos Plástico de 100x10mm"
  Endif

  If [M:YWQ2]YPALPL12012 <> 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con"-num$([M:YWQ2]YPALPL12012)-"Palitos Plástico de 120x12mm"
  Endif

  If [M:YWQ2]YPALMA408 <> 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con"-num$([M:YWQ2]YPALMA408)-"Palitos Madera de 40x8mm"
  Endif

  If [M:YWQ2]YPALMA608 <> 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con"-num$([M:YWQ2]YPALMA608)-"Palitos Madera de 60x8mm"
  Endif

  If [M:YWQ2]YPALMA100 <> 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con"-num$([M:YWQ2]YPALMA100)-"Palitos Madera de 100cms"
  Endif

  If [M:YWQ2]YPALMA150 <> 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con"-num$([M:YWQ2]YPALMA150)-"Palitos Madera de 150cms"
  Endif

  If [M:YWQ2]YMASTIL44 <> 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con"-num$([M:YWQ2]YMASTIL44)-"Mástiles de 44cms para coche"
  Endif

  If [M:YWQ2]YMASTIL50 <> 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con"-num$([M:YWQ2]YMASTIL50)-"Mástiles de 50cms para coche"
  Endif

  If [M:YWQ2]YEMBOLSADO = 2 Then : GDESCEXTRA-="Embolsado individual" Endif

  If [M:YWQ2]YVELCRO = 2 Then
    If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con Velcro Hembra 5cms"
  Endif
  If [M:YWQ2]YVELCROAR = 2 Then
    If instr(1,GDESCEXTRA, "5cms Posición") > 0 Then : GDESCEXTRA-="Arriba" : Else : GDESCEXTRA-="Posición Arriba" : Endif
  Endif
  If [M:YWQ2]YVELCROAB = 2 Then
    If instr(1,GDESCEXTRA, "5cms Posición") > 0 Then : GDESCEXTRA-="Abajo" : Else : GDESCEXTRA-="Posición Abajo" : Endif
  Endif
  If [M:YWQ2]YVELCROIZ = 2 Then
    If instr(1,GDESCEXTRA, "5cms Posición") > 0 Then : GDESCEXTRA-="Izquierda" : Else : GDESCEXTRA-="Posición Izquierda" : Endif
  Endif
  If [M:YWQ2]YVELCRODE = 2 Then
    If instr(1,GDESCEXTRA, "5cms Posición") > 0 Then : GDESCEXTRA-="Derecha" : Else : GDESCEXTRA-="Posición Derecha" : Endif
  Endif

  If [M:YWQ2]YSILICON = 2 Then
    If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="con Silicon 14mm Perfil"
  Endif
  If [M:YWQ2]YSILICONAR = 2 Then
   If instr(1,GDESCEXTRA, "Perfil Posición") > 0 Then : GDESCEXTRA-="Arriba" : Else : GDESCEXTRA-="Posición Arriba" : Endif
  Endif
  If [M:YWQ2]YSILICONAB = 2 Then
    If instr(1,GDESCEXTRA, "Perfil Posición") > 0 Then : GDESCEXTRA-="Abajo" : Else : GDESCEXTRA-="Posición Abajo" : Endif
  Endif
  If [M:YWQ2]YSILICONIZ = 2 Then
    If instr(1,GDESCEXTRA, "Perfil Posición") > 0 Then : GDESCEXTRA-="Izquierda" : Else : GDESCEXTRA-="Posición Izquierda" : Endif
  Endif
  If [M:YWQ2]YSILICONDE = 2 Then
    If instr(1,GDESCEXTRA, "Perfil Posición") > 0 Then : GDESCEXTRA-="Derecha" : Else : GDESCEXTRA-="Posición Derecha" :Endif
  Endif

  If [M:YWQ2]YOLLADOSLONA > 0 Then
     If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-=""-num$([M:YWQ2]YOLLADOSLONA)-"Ollados para lonas"
  Endif

  If [M:YWQ2]YREFLONA = 2 Then
    If GDESCEXTRA <> "" Then : GDESCEXTRA-="," : Endif  : GDESCEXTRA-="Refuerzos para Lonas"
  Endif
  If [M:YWQ2]YREFLONAAR = 2 Then
    If instr(1,GDESCEXTRA, "Lonas Posición") > 0 Then : GDESCEXTRA-="Arriba" : Else : GDESCEXTRA-="Posición Arriba" : Endif
  Endif
  If [M:YWQ2]YREFLONAAB = 2 Then
    If instr(1,GDESCEXTRA, "Lonas Posición") > 0 Then : GDESCEXTRA-="Abajo" : Else : GDESCEXTRA-="Posición Abajo" : Endif
  Endif
  If [M:YWQ2]YREFLONAIZ = 2 Then
    If instr(1,GDESCEXTRA, "Lonas Posición") > 0 Then : GDESCEXTRA-="Izquierda" : Else : GDESCEXTRA-="Posición Izquierda" : Endif
  Endif
  If [M:YWQ2]YREFLONADE = 2 Then
    If instr(1,GDESCEXTRA, "Lonas Posición") > 0 Then : GDESCEXTRA-="Derecha" : Else : GDESCEXTRA-="Posición Derecha" : Endif
  Endif




End
##############################################################

#############################################################################
# Author: SageDev.it
# It substitutes all occurrences of OLD with NEW
# STR is a clob
#############################################################################
Funprog REPLACE(STR, OLD, NEW)
    Value Clbfile STR()
    Value Char OLD()
    Value Char NEW()
    Local Integer LENOLD
    Local Integer LENNEW

    #length of string to substitute
    LENOLD= len(OLD)
    #length of string that will substitute OLD string
    LENNEW= len(NEW)

    If LENOLD<=0 or LENOLD>len(STR)
        #the string to substitute is empty or it is longer than initial string, so we do nothing
        End STR
    Endif

    Local Integer INDEX
    Local Integer INDEXSTART

    #We search the string to substitute
    INDEX=instr(1,STR,OLD)

    While INDEX>0
        #INDEX>0 this means that we have found an occurrence of OLD
        #We substitute OLD occurrence with the NEW string
        STR =left$(STR, INDEX-1) + NEW + right$(STR, INDEX+LENOLD)

        #We calc the index to which the NEW string just inserted ends
        INDEXSTART=INDEX+LENNEW

        #We search the string to substitute starting from the end of last found occurrence
        INDEX=instr(INDEXSTART,STR,OLD)
    Wend
End STR
#############################################################################

#############################################################################
# Author: SageDev.it
# Wrapper of REPLACE(STR, OLD, NEW)
# It substitutes all OLD occurrence with NEW
# the STR parameter is a CHAR(), not a clob
#############################################################################
Funprog REPLACESTR(STR, OLD, NEW)
    Value Clbfile STR()
    Value Char OLD()
    Value Char NEW()
    Local Char RET(250)
    Local Clbfile STRCLB(1)

    STRCLB = STR
    RET = func REPLACE(STRCLB, OLD, NEW)
End RET
