#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "FILTRE"     : Gosub FILTRE
  When "LIENS"      : Gosub LIENS
  When "CREATION"   : Gosub CREATION
  When "MODIF"      : Gosub MODIF
  When "ANNULE"     : Gosub ANNULE
  When "APRES_CRE"  : Gosub APRES_CRE
  When "APRES_MOD"  : Gosub APRES_MOD
  When "INICRE_LIG" : Gosub INICRE_LIG
  When "DEFLIG"     : Gosub DEFLIG
  When "DEBUT"      : Gosub DEBUT
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
################################################################
$OUVRE
  Gosub DECLARE From TABLEAUX
Return

################################################################
$FILTRE
  Default File [YELC]
Return

################################################################
$LIENS
  Gosub LIENS From TABLEAUX
Return

################################################################
$CREATION
  Gosub CREATION From TABLEAUX
Return

################################################################
$MODIF
  Gosub MODIF From TABLEAUX
Return

################################################################
$ANNULE
  Gosub ANNULE From TABLEAUX
Return

################################################################
$APRES_CRE
  Gosub LIENS From TABLEAUX
Return

################################################################
$APRES_MOD
  Gosub LIENS From TABLEAUX
Return

################################################################
$INICRE_LIG
  [F:YELD]CODTAR = [M:YEL0]CODTAR
Return

################################################################
$DEFLIG
  Default Mask [YEL1]   # pantalla de las líneas
  Default File [YELD]   # abreviatura de la tabla de las líneas

  # criterios de filtrado
  CRIT    = 'CODTAR="'+[M:YEL0]CODTAR+'"'      # campo común de las tablas + pantalla cabecera (con el campo común)
  FICLIG  = "YTBEM1LD"                         # nombre de la tabla de detalle
  ABLIG   = "YELD"                             # abreviatura de la tabla de detalle
  ZONLIG  = "LINTAR"                           # campo contador de línea en la tabla detalle
Return

################################################################
$DEBUT
  zonsui = "[M:YEL0]CODTAR"
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Después de modificar el campo 'Fecha inicio validez'
######################################################################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
  If [M:YEL0]ENDDAT <> [00/00/0000] and VALEUR > [M:YEL0]ENDDAT Then
    Call ERREUR("Fecha inicio no puede ser posterior a Fecha fin") From GESECRAN
    mkstat = 2
  Endif
End

######################################################################################
## Después de modificar el campo 'Fecha fin validez'
######################################################################################
Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
  If [M:YEL0]STRDAT <> [00/00/0000] and VALEUR < [M:YEL0]STRDAT Then
    Call ERREUR("Fecha inicio no puede ser posterior a Fecha fin") From GESECRAN
    mkstat = 2
  Endif
End

######################################################################################
## Després de modificar el campo 'Área mínima'
######################################################################################
Subprog AM_MINAREA(VALEUR)
Variable Decimal VALEUR
  If [M:YEL1]MAXAREA(nolign-1) <> 0 and VALEUR > [M:YEL1]MAXAREA(nolign-1) Then
    Call ERREUR("Área mínima no puede ser superior a Área máxima") From GESECRAN
    mkstat = 2
  Endif
End

######################################################################################
## Després de modificar el campo 'Área máxima'
######################################################################################
Subprog AM_MAXAREA(VALEUR)
Variable Decimal VALEUR
  If [M:YEL1]MINAREA(nolign-1) <> 0 and VALEUR < [M:YEL1]MINAREA(nolign-1) Then
    Call ERREUR("Área mínima no puede ser superior a Área máxima") From GESECRAN
    mkstat = 2
  Endif
End

######################################################################################
## Després de modificar el campo 'Cantidad mínima'
######################################################################################
Subprog AM_MINQTY(VALEUR)
Variable Decimal VALEUR
  If [M:YEL1]MAXQTY(nolign-1) <> 0 and VALEUR > [M:YEL1]MAXQTY(nolign-1) Then
    Call ERREUR("Cantidad mínima no puede ser superior a Cantidad máxima") From GESECRAN
    mkstat = 2
  Endif
End

######################################################################################
## Després de modificar el campo 'Cantidad máxima'
######################################################################################
Subprog AM_MAXQTY(VALEUR)
Variable Decimal VALEUR
  If [M:YEL1]MINQTY(nolign-1) <> 0 and VALEUR < [M:YEL1]MINQTY(nolign-1) Then
    Call ERREUR("Cantidad mínima no puede ser superior a Cantidad máxima") From GESECRAN
    mkstat = 2
  Endif
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

