##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
######################################################################################


#**
#* Activa o descactiva campos en función de la parametria de la tabla varia 2506
#*
#* @param VALEUR
#*!
Subprog ACTIVAR_CAMPOS(PCAMPO, PNOL)
  Value Char PCAMPO
  Value Integer PNOL

  If !clalev([ZATA]) Then : Local File ATABDIV [ZATA] : Endif

  Read [ZATA]CODE=2506;PCAMPO
  If !fstat Then
    # activar las caracteristicas del componente extra
    # CANTIDAD
    If [F:ZATA]N1 = 1 Then
      Diszo [M:YITM1]YEXTCANT(PNOL)
      Grizo [M:YITM1]YEXTCANT(PNOL)
    Else
      Actzo [M:YITM1]YEXTCANT(PNOL)
    Endif
    # ARRIBA
    If [F:ZATA]N2 = 1 Then
      Diszo [M:YITM1]YEXTARR(PNOL)
      Grizo [M:YITM1]YEXTARR(PNOL)
    Else
      Actzo [M:YITM1]YEXTARR(PNOL)
    Endif
    # ABAJO
    If [F:ZATA]N3 = 1 Then
      Diszo [M:YITM1]YEXTABA(PNOL)
      Grizo [M:YITM1]YEXTABA(PNOL)
    Else
      Actzo [M:YITM1]YEXTABA(PNOL)
    Endif
    # IZQUIERDA
    If [F:ZATA]N4 = 1 Then
      Diszo [M:YITM1]YEXTIZQ(PNOL)
      Grizo [M:YITM1]YEXTIZQ(PNOL)
    Else
      Actzo [M:YITM1]YEXTIZQ(PNOL)
    Endif

    # DERECHA
    If [F:ZATA]N5 = 1 Then
      Diszo [M:YITM1]YEXTDER(PNOL)
      Grizo [M:YITM1]YEXTDER(PNOL)
    Else
      Actzo [M:YITM1]YEXTDER(PNOL)
    Endif

    # LARGO
    If  [F:ZATA]N6 = 1 Then
      Diszo [M:YITM1]YEXTLARGO(PNOL)
      Grizo  [M:YITM1]YEXTLARGO(PNOL)
    Else
      Actzo [M:YITM1]YEXTLARGO(PNOL)
    Endif
  Endif

End

