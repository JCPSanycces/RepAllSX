#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "LIENS"      : Gosub LIENS
  When "APRES_CRE"  : Gosub APRES_CRE
  When "APRES_MOD"  : Gosub APRES_MOD
  When "AP_ANNULE"  : Gosub AP_ANNULE
  When "FIN"        : Gosub FIN
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
Return

##############################################################
$LIENS
  Gosub MUESTRA_EXTRAS
Return

##############################################################
$APRES_CRE
  Gosub ACTUALIZA_YTEXTART
Return

##############################################################
$APRES_MOD
  Gosub ACTUALIZA_YTEXTART
Return

##############################################################
$AP_ANNULE
  Gosub ACTUALIZA_YTEXTART
Return

##############################################################
$FIN
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ACTUALIZA_YTEXTART
Local Integer LCON : Raz LCON

  If !clalev([F:TEA0]) Then : Local File YTEXTART [F:TEA0] : Endif
  Delete [F:TEA0] Where YITMREF = [M:ITM0]ITMREF
  For LCON = 0 To [M:YITM1]YNBLIG-1
    [F:TEA0]YITMREF   = [M:ITM0]ITMREF
    [F:TEA0]YEXTCOD   = [M:YITM1]YEXTCOD(LCON)
    [F:TEA0]YEXTCANT  = [M:YITM1]YEXTCANT(LCON)
    [F:TEA0]YEXTARR   = [M:YITM1]YEXTARR(LCON)
    [F:TEA0]YEXTABA   = [M:YITM1]YEXTABA(LCON)
    [F:TEA0]YEXTDER   = [M:YITM1]YEXTDER(LCON)
    [F:TEA0]YEXTIZQ   = [M:YITM1]YEXTIZQ(LCON)
    [F:TEA0]YEXTLARGO   = [M:YITM1]YEXTLARGO(LCON)
    Trbegin [F:TEA0]
    Write [F:TEA0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next
  Close Local File [TEA0]

Kill LCON
Return

##############################################################
$MUESTRA_EXTRAS
Local Integer LCON : Raz LCON
  If !clalev([F:TEA0]) Then : Local File YTEXTART [F:TEA0] : Endif
  Filter [TEA0] Where YITMREF = [M:ITM0]ITMREF Order By YEXTCOD Asc
  For [F:TEA0]
    [M:YITM1]YITMREF(LCON)  = [F:TEA0]YITMREF
    [M:YITM1]YEXTCOD(LCON)  = [F:TEA0]YEXTCOD
    [M:YITM1]YEXTCANT(LCON) = [F:TEA0]YEXTCANT
    [M:YITM1]YEXTARR(LCON)  = [F:TEA0]YEXTARR
    [M:YITM1]YEXTABA(LCON)  = [F:TEA0]YEXTABA
    [M:YITM1]YEXTIZQ(LCON)  = [F:TEA0]YEXTIZQ
    [M:YITM1]YEXTDER(LCON)  = [F:TEA0]YEXTDER
    [M:YITM1]YEXTLARGO(LCON)  = [F:TEA0]YEXTLARGO
    Call ACTIVAR_CAMPOS([F:TEA0]YEXTCOD, LCON)
    nolign = LCON
    LCON += 1

  Next
  Filter [TEA0]
  [M:YITM1]YNBLIG = LCON
  Close Local File [TEA0]

  Affzo [M:YITM1]2
  Kill LCON
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Control en el campo 'Componente' del grid de extras
######################################################################################
Subprog C_YEXTCOD(VALEUR)
Variable Char    VALEUR()

  # comprueba que el extra no existe en el grid
  Call UNICITE(VALEUR,[M:YITM1]YEXTCOD(0..[M:YITM1]YNBLIG-1)) From OBJDIV
  If mkstat = 2 Then
    VALEUR = ""
  Endif

  # controla si se pueden insertar cantidades y posiciones
  Call ACTIVAR_CAMPOS(VALEUR, nolign-1)

End

