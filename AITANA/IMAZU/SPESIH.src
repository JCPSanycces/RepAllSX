# YA032
$EXEBOUT
Local Integer   LSTAT     : Raz LSTAT
Global Integer  GIMPRESO  : Raz GIMPRESO
  Case BOUT
    When "s"  : Call ENVMAIL_SIH([M:SIH0]NUM,"Y-FACVEN","ENVIOPDF",LSTAT) From SPEYLIB0
  Endcase
Kill GIMPRESO
Return


