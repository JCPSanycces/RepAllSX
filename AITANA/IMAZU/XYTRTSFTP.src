#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara SFTPORTAL (Especifico)
$ACTION
#If GUSER="AIT50" Then : Infbox ACTION : Endif
Case ACTION
 When "SETBOUT"    :   Gosub SETBOUT
 When Default
Endcase
Return


#############################################
$SETBOUT
Local Integer LCON

If !clalev([YVOQ])  Then : Local File YVOPQTY [YVOQ]  : Endif
If !clalev([YVIOT]) Then : Local File YITMOF  [YVIOT] : Endif

For LCON = 0 To [M:SFTP0]NBLIG
  Read [YVOQ]OPQY0 = [M:SFTP0]VCRNUM(LCON);[M:SFTP0]OPENUM(LCON)
  If !fstat Then
    [M:SFTP0]ROODES(LCON)  = [YVOQ]ROODES
    [M:SFTP0]YEXTQTY(LCON) = [YVOQ]EXTQTY
  Endif

  Read   [YVIOT]YIOF0 = [M:SFTP0]VCRNUM(LCON)
  If !fstat Then
    [M:SFTP0]YBPCNAM(LCON)  = [YVIOT]BPCNAM
    [M:SFTP0]YITMDES1(LCON) = [YVIOT]ITMDES1
  Endif
Affzo [M:SFTP0]ROODES, YEXTQTY, YBPCNAM, YITMDES1
#Affzo [M:SFTP0]ROODES, CPLQTY, YEXTQTY, YBPCNAM, YITMDES1
Next

#Infbox num$([M:SFTP0]SELLIN(LCON))
#Affzo [M:SFTP0]

Local File [YVOQ]
Local File [YVIOT]

Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla SFTPORTAL) 10/11/2020 14:09:34 (AIT50)
######################################################################################
Subprog AM_SELLIN(VALEUR)
Variable Integer VALEUR

If !clalev([YVIOT]) Then : Local File YITMOF  [YVIOT] : Endif

Read   [YVIOT]YIOF0 = [M:SFTP0]VCRNUM(nolign-1)

If !fstat Then
  [M:SFTP0]CPLQTY(nolign-1)  = [YVIOT]UOMEXTQTY
  Call AM_CPLQTY([YVIOT]UOMEXTQTY) From TRTSFTP
Endif

End


######################################################################################

