#  [M:SQH2]SQDPSONUM(NOL)    = [M:SQH2]SQDPSONUM(NOL-1)    : [M:SQH2]SQDSEQNUM(NOL)    = [M:SQH2]SQDSEQNUM(NOL-1)
#  [M:SQH2]LINREVNUM(NOL)    = [M:SQH2]LINREVNUM(NOL-1)    : [M:SQH2]YRANGO(NOL)       = [M:SQH2]YRANGO(NOL-1)
#  [M:SQH2]YTIPOIMP(NOL)     = [M:SQH2]YTIPOIMP(NOL-1)     : [M:SQH2]YMATERIAL(NOL)    = [M:SQH2]YMATERIAL(NOL-1)
#  [M:SQH2]YALTO(NOL)        = [M:SQH2]YALTO(NOL-1)        : [M:SQH2]YANCHO(NOL)       = [M:SQH2]YANCHO(NOL-1)
#  [M:SQH2]YNUMCOLORES(NOL)  = [M:SQH2]YNUMCOLORES(NOL-1)  : [M:SQH2]YPESPUNTE(NOL)    = [M:SQH2]YPESPUNTE(NOL-1)
#  [M:SQH2]YCONFNORMAL(NOL)  = [M:SQH2]YCONFNORMAL(NOL-1)  : [M:SQH2]YCONFFLY(NOL)     = [M:SQH2]YCONFFLY(NOL-1)
#  [M:SQH2]YFABRICADA(NOL)   = [M:SQH2]YFABRICADA(NOL-1)   : [M:SQH2]YREFERENCIA(NOL)  = [M:SQH2]YREFERENCIA(NOL-1)
#  [M:SQH2]YFLGCRE(NOL)      = [M:SQH2]YFLGCRE(NOL-1)      : [M:SQH2]YCINTAREF(NOL)    = [M:SQH2]YCINTAREF(NOL-1)
#  [M:SQH2]YCINTAREFAR(NOL)  = [M:SQH2]YCINTAREFAR(NOL-1)  : [M:SQH2]YCINTAREFAB(NOL)  = [M:SQH2]YCINTAREFAB(NOL-1)
#  [M:SQH2]YCINTAREFIZ(NOL)  = [M:SQH2]YCINTAREFIZ(NOL-1)  : [M:SQH2]YCINTAREFDE(NOL)  = [M:SQH2]YCINTAREFDE(NOL-1)
#  [M:SQH2]YOLLADOS(NOL)     = [M:SQH2]YOLLADOS(NOL-1)     : [M:SQH2]YANILLAS(NOL)     = [M:SQH2]YANILLAS(NOL-1)
#  [M:SQH2]YCINTAATAR(NOL)   = [M:SQH2]YCINTAATAR(NOL-1)   : [M:SQH2]YLARGO(NOL)       = [M:SQH2]YLARGO(NOL-1)
#  [M:SQH2]YMNGVAINA(NOL)    = [M:SQH2]YMNGVAINA(NOL-1)    : [M:SQH2]YMNGVAINAAR(NOL)  = [M:SQH2]YMNGVAINAAB(NOL-1)
#  [M:SQH2]YMNGVAINAIZ(NOL)  = [M:SQH2]YMNGVAINAIZ(NOL-1)  : [M:SQH2]YMNGVAINADE(NOL)  = [M:SQH2]YMNGVAINADE(NOL-1)
#  [M:SQH2]YCNTMSTL(NOL)     = [M:SQH2]YCNTMSTL(NOL-1)     : [M:SQH2]YCNTMSTLQTY(NOL)  = [M:SQH2]YCNTMSTLQTY(NOL-1)
#  [M:SQH2]YABRPVC(NOL)      = [M:SQH2]YABRPVC(NOL-1)      : [M:SQH2]YABRPVCQTY(NOL)   = [M:SQH2]YABRPVCQTY(NOL-1)
#  [M:SQH2]YCINTASIL(NOL)    = [M:SQH2]YCINTASIL(NOL-1)    : [M:SQH2]YCINTASILAR(NOL)  = [M:SQH2]YCINTASILAR(NOL-1)
#  [M:SQH2]YCINTASILAB(NOL)  = [M:SQH2]YCINTASILAB(NOL-1)  : [M:SQH2]YCINTASILIZ(NOL)  = [M:SQH2]YCINTASILIZ(NOL-1)
#  [M:SQH2]YCINTASILDE(NOL)  = [M:SQH2]YCINTASILDE(NOL-1)  : [M:SQH2]YPALPL256(NOL)    = [M:SQH2]YPALPL256(NOL-1)
#  [M:SQH2]YPALPL306(NOL)    = [M:SQH2]YPALPL306(NOL-1)    : [M:SQH2]YPALPL406(NOL)    = [M:SQH2]YPALPL406(NOL-1)
#  [M:SQH2]YPALPL408(NOL)    = [M:SQH2]YPALPL408(NOL-1)    : [M:SQH2]YPALPL608(NOL)    = [M:SQH2]YPALPL608(NOL-1)
#  [M:SQH2]YPALPL10010(NOL)  = [M:SQH2]YPALPL10010(NOL-1)  : [M:SQH2]YPALPL12012(NOL)  = [M:SQH2]YPALPL12012(NOL-1)
#  [M:SQH2]YPALMA408(NOL)    = [M:SQH2]YPALMA408(NOL-1)    : [M:SQH2]YPALMA608(NOL)    = [M:SQH2]YPALMA608(NOL-1)
#  [M:SQH2]YPALMA100(NOL)    = [M:SQH2]YPALMA100(NOL-1)    : [M:SQH2]YPALMA150(NOL)    = [M:SQH2]YPALMA150(NOL-1)
#  [M:SQH2]YMASTIL44(NOL)    = [M:SQH2]YMASTIL44(NOL-1)    : [M:SQH2]YMASTIL50(NOL)    = [M:SQH2]YMASTIL50(NOL-1)
#  [M:SQH2]YEMBOLSADO(NOL)   = [M:SQH2]YEMBOLSADO(NOL-1)   : [M:SQH2]YVELCRO(NOL)      = [M:SQH2]YVELCRO(NOL-1)
#  [M:SQH2]YVELCROAR(NOL)    = [M:SQH2]YVELCROAR(NOL-1)    : [M:SQH2]YVELCROAB(NOL)    = [M:SQH2]YVELCROAB(NOL-1)
#  [M:SQH2]YVELCROIZ(NOL)    = [M:SQH2]YVELCROIZ(NOL-1)    : [M:SQH2]YVELCRODE(NOL)    = [M:SQH2]YVELCRODE(NOL-1)
#  [M:SQH2]YSILICON(NOL)     = [M:SQH2]YSILICON(NOL-1)     : [M:SQH2]YSILICONAR(NOL)   = [M:SQH2]YSILICONAR(NOL-1)
#  [M:SQH2]YSILICONAB(NOL)   = [M:SQH2]YSILICONAB(NOL-1)   : [M:SQH2]YSILICONIZ(NOL)   = [M:SQH2]YSILICONIZ(NOL-1)
#  [M:SQH2]YSILICONDE(NOL)   = [M:SQH2]YSILICONDE(NOL-1)   : [M:SQH2]YOLLADOSLONA(NOL) = [M:SQH2]YOLLADOSLONA(NOL-1)
#  [M:SQH2]YREFLONA(NOL)     = [M:SQH2]YREFLONA(NOL-1)     : [M:SQH2]YREFLONAAR(NOL)   = [M:SQH2]YREFLONAAR(NOL-1)
#  [M:SQH2]YREFLONAAB(NOL)   = [M:SQH2]YREFLONAAB(NOL-1)   : [M:SQH2]YREFLONAIZ(NOL)   = [M:SQH2]YREFLONAIZ(NOL-1)
#  [M:SQH2]YREFLONADE(NOL)   = [M:SQH2]YREFLONADE(NOL-1)   : [M:SQH2]YPESOITM(NOL)     = [M:SQH2]YPESOITM(NOL-1)
#  [M:SQH2]YPESOLIN(NOL)     = [M:SQH2]YPESOLIN(NOL-1)     : [M:SQH2]YBENLIN(NOL)      = [M:SQH2]YBENLIN(NOL-1)
#  [M:SQH2]YBENUNI(NOL)      = [M:SQH2]YBENUNI(NOL-1)
#
#
#  Call AM_GROPRI([M:SQH2]GROPRI(NOL)) From SUBSQH
#  Call AM_QTY([M:SQH2]QTY(NOL)) From SUBSQH
#
#  #Affzo [M:SQH2]ITMREF(NOL+1)
#  #Call APRES_NBLIG From SUBSQH
#
#  Affzo [SQH2]1-99 : mkstat=4 : GREVFLG+=5
#  # Affzo [M:SQH2]NBLIG(nolign-1)

###############################
  Local Integer  OK  : OK=1
  If [M:SQH2]NBLIG=0 End : Endif

  If [M:SQH2]ITMREF(nolign-1)= "" Then End : Endif # MAB.05062020.NEW

  If dim([M:SQH2]ITMREF)< [M:SQH2]NBLIG+2
    GMESSAGE=mess(122,199,1)
    GERR=1
    End
  Endif
  If [M:SQH2]ITMREF(nolign-1)<>""
    nolign+=1
  Endif

  status=73
  Call INSERE("SQDLIN") From TABLEAUX
  If mkstat
    End
  Endif

  Call AVANT_NBLIG From SUBSQH
  If mkstat
    End
  Endif

  If GREVFLG=0
    Gosub AVANT_MOD From SUBSQHA
    If OK=0
      End
    Endif
  Endif

  Call TEMPON("O") From GESECRAN

  Local Shortint NOL, I, J, K, L : NOL=nolign-1

  Insa NOL,1,[M:SQH2]NBLIG [M:SQH2]NBLIG : [M:SQH2]NBLIG+=1

  J=NOL : L=NOL-1

  [M:SQH2]YASISTENTE(J)   = [M:SQH2]YASISTENTE(L)   : [M:SQH2]YCALCULAPB(J)   = [M:SQH2]YCALCULAPB(L)
  [M:SQH2]YCREAITM(J)     = [M:SQH2]YCREAITM(L)     : [M:SQH2]ITMREF(J)       = [M:SQH2]ITMREF(L)
  [M:SQH2]DSPLINWEI(J)    = [M:SQH2]DSPLINWEI(L)    : [M:SQH2]ITMDES(J)       = [M:SQH2]ITMDES(L)
  [M:SQH2]DSPLINVOL(J)    = [M:SQH2]DSPLINVOL(L)    : [M:SQH2]ITMDES1(J)      = [M:SQH2]ITMDES1(L)
  [M:SQH2]ECCVALMAJ(J)    = [M:SQH2]ECCVALMAJ(L)    : [M:SQH2]ECCVALMIN(J)    = [M:SQH2]ECCVALMIN(L)
  [M:SQH2]SAU(J)          = [M:SQH2]SAU(L)          : [M:SQH2]YDESCITM(J)     = [M:SQH2]YDESCITM(L)
  [M:SQH2]QTY(J)          = [M:SQH2]QTY(L)          : [M:SQH2]SAUSTUCOE(J)    = [M:SQH2]SAUSTUCOE(L)
  [M:SQH2]STU(J)          = [M:SQH2]STU(L)          : [M:SQH2]GROPRI(J)       = [M:SQH2]GROPRI(L)
  [M:SQH2]YGROPRI(J)      = [M:SQH2]YGROPRI(L)      : [M:SQH2]DISCRGVAL1(J)   = [M:SQH2]DISCRGVAL1(L)
  [M:SQH2]DISCRGVAL2(J)   = [M:SQH2]DISCRGVAL2(L)   : [M:SQH2]DISCRGVAL3(J)   = [M:SQH2]DISCRGVAL3(L)
  [M:SQH2]DISCRGVAL4(J)   = [M:SQH2]DISCRGVAL4(L)   : [M:SQH2]DISCRGVAL5(J)   = [M:SQH2]DISCRGVAL5(L)
  [M:SQH2]NETPRI(J)       = [M:SQH2]NETPRI(L)       : [M:SQH2]CPRPRI(J)       = [M:SQH2]CPRPRI(L)
  [M:SQH2]PFM(J)          = [M:SQH2]PFM(L)          : [M:SQH2]VACITM1(J)      = [M:SQH2]VACITM1(L)
  [M:SQH2]VACITM2(J)      = [M:SQH2]VACITM2(L)      : [M:SQH2]VACITM3(J)      = [M:SQH2]VACITM3(L)
  [M:SQH2]SSTCOD(J)       = [M:SQH2]SSTCOD(L)       : [M:SQH2]DPJT(J)         = [M:SQH2]DPJT(L)
  [M:SQH2]REP1(J)         = [M:SQH2]REP1(L)         : [M:SQH2]REPRAT1(J)      = [M:SQH2]REPRAT1(L)
  [M:SQH2]REP2(J)         = [M:SQH2]REP2(L)         : [M:SQH2]REPRAT1(J)      = [M:SQH2]REPRAT1(L)
  [M:SQH2]REPCOE(J)       = [M:SQH2]REPCOE(L)       : [M:SQH2]DBPAADD(J)      = [M:SQH2]DBPAADD(L)
  [M:SQH2]CNDNAM(J)       = [M:SQH2]CNDNAM(L)       : [M:SQH2]DDAYLTI(J)      = [M:SQH2]DDAYLTI(L)
  [M:SQH2]DSTOFCY(J)      = [M:SQH2]DSTOFCY(L)      : [M:SQH2]CCE1(J)         = [M:SQH2]CCE1(L)
  [M:SQH2]CCE2(J)         = [M:SQH2]CCE2(L)         : [M:SQH2]CCE3(J)         = [M:SQH2]CCE3(L)
  [M:SQH2]CCE4(J)         = [M:SQH2]CCE4(L)         : [M:SQH2]CCE5(J)         = [M:SQH2]CCE5(L)
  [M:SQH2]CCE6(J)         = [M:SQH2]CCE6(L)         : [M:SQH2]CCE7(J)         = [M:SQH2]CCE7(L)
  [M:SQH2]CCE8(J)         = [M:SQH2]CCE8(L)         : [M:SQH2]CCE9(J)         = [M:SQH2]CCE9(L)
  [M:SQH2]CCE10(J)        = [M:SQH2]CCE10(L)        : [M:SQH2]CCE11(J)        = [M:SQH2]CCE11(L)
  [M:SQH2]CCE12(J)        = [M:SQH2]CCE12(L)        : [M:SQH2]CCE13(J)        = [M:SQH2]CCE13(L)
  [M:SQH2]CCE14(J)        = [M:SQH2]CCE14(L)        : [M:SQH2]CCE15(J)        = [M:SQH2]CCE15(L)
  [M:SQH2]CCE16(J)        = [M:SQH2]CCE16(L)        : [M:SQH2]CCE17(J)        = [M:SQH2]CCE17(L)
  [M:SQH2]CCE18(J)        = [M:SQH2]CCE18(L)        : [M:SQH2]CCE19(J)        = [M:SQH2]CCE19(L)
  [M:SQH2]CCE20(J)        = [M:SQH2]CCE20(L)        : [M:SQH2]LINQUONOT(J)    = [M:SQH2]LINQUONOT(L)
  [M:SQH2]LINQUOATI(J)    = [M:SQH2]LINQUOATI(L)    : [M:SQH2]LINPFM(J)       = [M:SQH2]LINPFM(L)
  [M:SQH2]LINTYP(J)       = [M:SQH2]LINTYP(L)       : [M:SQH2]FOCFLG(J)       = [M:SQH2]FOCFLG(L)
  [M:SQH2]DSOHNUM(J)      = [M:SQH2]DSOHNUM(L)      : [M:SQH2]SOPLIN(J)       = [M:SQH2]SOPLIN(L)
  [M:SQH2]DPREOPP(J)      = [M:SQH2]DPREOPP(L)      : [M:SQH2]ORILIN(J)       = [M:SQH2]ORILIN(L)
  [M:SQH2]SQDTEX(J)       = [M:SQH2]SQDTEX(L)       : [M:SQH2]PRIREN(J)       = [M:SQH2]PRIREN(L)
  [M:SQH2]DISCRGREN1(J)   = [M:SQH2]DISCRGREN1(L)   : [M:SQH2]DISCRGREN2(J)   = [M:SQH2]DISCRGREN2(L)
  [M:SQH2]DISCRGREN3(J)   = [M:SQH2]DISCRGREN3(L)   : [M:SQH2]DISCRGREN4(J)   = [M:SQH2]DISCRGREN4(L)
  [M:SQH2]DISCRGREN5(J)   = [M:SQH2]DISCRGREN5(L)   : [M:SQH2]VAT1(J)         = [M:SQH2]VAT1(L)
  [M:SQH2]VAT2(J)         = [M:SQH2]VAT2(L)         : [M:SQH2]VAT3(J)         = [M:SQH2]VAT3(L)
  [M:SQH2]CLCAMT1(J)      = [M:SQH2]CLCAMT1(L)      : [M:SQH2]CLCAMT2(J)      = [M:SQH2]CLCAMT2(L)
  [M:SQH2]YQTY(J)         = [M:SQH2]YQTY(L)         : [M:SQH2]STOMGTCOD(J)    = [M:SQH2]STOMGTCOD(L)
  [M:SQH2]GRPFLG(J)       = [M:SQH2]GRPFLG(L)       : [M:SQH2]NETPRINOT(J)    = [M:SQH2]NETPRINOT(L)
  [M:SQH2]NETPRIATI(J)    = [M:SQH2]NETPRIATI(L)    : [M:SQH2]OCNPRNBOM(J)    = [M:SQH2]OCNPRNBOM(L)
  [M:SQH2]NDEPRNBOM(J)    = [M:SQH2]NDEPRNBOM(L)    : [M:SQH2]INVPRNBOM(J)    = [M:SQH2]INVPRNBOM(L)
  [M:SQH2]CQTY(J)         = [M:SQH2]CQTY(L)         : [M:SQH2]ORDQTY(J)       = [M:SQH2]ORDQTY(L)
  [M:SQH2]DACSAUCOE(J)    = [M:SQH2]DACSAUCOE(L)    : [M:SQH2]DSPLINFLG(J)    = [M:SQH2]DSPLINFLG(L)
  [M:SQH2]WUPDAPPFLG(J)   = [M:SQH2]WUPDAPPFLG(L)   : [M:SQH2]DLVFLG(J)       = [M:SQH2]DLVFLG(L)
  [M:SQH2]SQDPSONUM(J)    = [M:SQH2]SQDPSONUM(L)    : [M:SQH2]SQDSEQNUM(J)    = [M:SQH2]SQDSEQNUM(L)
  [M:SQH2]LINREVNUM(J)    = [M:SQH2]LINREVNUM(L)    : [M:SQH2]YRANGO(J)       = [M:SQH2]YRANGO(L)
  [M:SQH2]YTIPOIMP(J)     = [M:SQH2]YTIPOIMP(L)     : [M:SQH2]YMATERIAL(J)    = [M:SQH2]YMATERIAL(L)
  [M:SQH2]YALTO(J)        = [M:SQH2]YALTO(L)        : [M:SQH2]YANCHO(J)       = [M:SQH2]YANCHO(L)
  [M:SQH2]YNUMCOLORES(J)  = [M:SQH2]YNUMCOLORES(L)  : [M:SQH2]YPESPUNTE(J)    = [M:SQH2]YPESPUNTE(L)
  [M:SQH2]YCONFNORMAL(J)  = [M:SQH2]YCONFNORMAL(L)  : [M:SQH2]YCONFFLY(J)     = [M:SQH2]YCONFFLY(L)
  [M:SQH2]YFABRICADA(J)   = [M:SQH2]YFABRICADA(L)   : [M:SQH2]YREFERENCIA(J)  = [M:SQH2]YREFERENCIA(L)
  [M:SQH2]YFLGCRE(J)      = [M:SQH2]YFLGCRE(L)      : [M:SQH2]YCINTAREF(J)    = [M:SQH2]YCINTAREF(L)
  [M:SQH2]YCINTAREFAR(J)  = [M:SQH2]YCINTAREFAR(L)  : [M:SQH2]YCINTAREFAB(J)  = [M:SQH2]YCINTAREFAB(L)
  [M:SQH2]YCINTAREFIZ(J)  = [M:SQH2]YCINTAREFIZ(L)  : [M:SQH2]YCINTAREFDE(J)  = [M:SQH2]YCINTAREFDE(L)
  [M:SQH2]YOLLADOS(J)     = [M:SQH2]YOLLADOS(L)     : [M:SQH2]YANILLAS(J)     = [M:SQH2]YANILLAS(L)
  [M:SQH2]YCINTAATAR(J)   = [M:SQH2]YCINTAATAR(L)   : [M:SQH2]YLARGO(J)       = [M:SQH2]YLARGO(L)
  [M:SQH2]YMNGVAINA(J)    = [M:SQH2]YMNGVAINA(L)    : [M:SQH2]YMNGVAINAAR(J)  = [M:SQH2]YMNGVAINAAB(L)
  [M:SQH2]YMNGVAINAIZ(J)  = [M:SQH2]YMNGVAINAIZ(L)  : [M:SQH2]YMNGVAINADE(J)  = [M:SQH2]YMNGVAINADE(L)
  [M:SQH2]YCNTMSTL(J)     = [M:SQH2]YCNTMSTL(L)     : [M:SQH2]YCNTMSTLQTY(J)  = [M:SQH2]YCNTMSTLQTY(L)
  [M:SQH2]YABRPVC(J)      = [M:SQH2]YABRPVC(L)      : [M:SQH2]YABRPVCQTY(J)   = [M:SQH2]YABRPVCQTY(L)
  [M:SQH2]YCINTASIL(J)    = [M:SQH2]YCINTASIL(L)    : [M:SQH2]YCINTASILAR(J)  = [M:SQH2]YCINTASILAR(L)
  [M:SQH2]YCINTASILAB(J)  = [M:SQH2]YCINTASILAB(L)  : [M:SQH2]YCINTASILIZ(J)  = [M:SQH2]YCINTASILIZ(L)
  [M:SQH2]YCINTASILDE(J)  = [M:SQH2]YCINTASILDE(L)  : [M:SQH2]YPALPL256(J)    = [M:SQH2]YPALPL256(L)
  [M:SQH2]YPALPL306(J)    = [M:SQH2]YPALPL306(L)    : [M:SQH2]YPALPL406(J)    = [M:SQH2]YPALPL406(L)
  [M:SQH2]YPALPL408(J)    = [M:SQH2]YPALPL408(L)    : [M:SQH2]YPALPL608(J)    = [M:SQH2]YPALPL608(L)
  [M:SQH2]YPALPL10010(J)  = [M:SQH2]YPALPL10010(L)  : [M:SQH2]YPALPL12012(J)  = [M:SQH2]YPALPL12012(L)
  [M:SQH2]YPALMA408(J)    = [M:SQH2]YPALMA408(L)    : [M:SQH2]YPALMA608(J)    = [M:SQH2]YPALMA608(L)
  [M:SQH2]YPALMA100(J)    = [M:SQH2]YPALMA100(L)    : [M:SQH2]YPALMA150(J)    = [M:SQH2]YPALMA150(L)
  [M:SQH2]YMASTIL44(J)    = [M:SQH2]YMASTIL44(L)    : [M:SQH2]YMASTIL50(J)    = [M:SQH2]YMASTIL50(L)
  [M:SQH2]YEMBOLSADO(J)   = [M:SQH2]YEMBOLSADO(L)   : [M:SQH2]YVELCRO(J)      = [M:SQH2]YVELCRO(L)
  [M:SQH2]YVELCROAR(J)    = [M:SQH2]YVELCROAR(L)    : [M:SQH2]YVELCROAB(J)    = [M:SQH2]YVELCROAB(L)
  [M:SQH2]YVELCROIZ(J)    = [M:SQH2]YVELCROIZ(L)    : [M:SQH2]YVELCRODE(J)    = [M:SQH2]YVELCRODE(L)
  [M:SQH2]YSILICON(J)     = [M:SQH2]YSILICON(L)     : [M:SQH2]YSILICONAR(J)   = [M:SQH2]YSILICONAR(L)
  [M:SQH2]YSILICONAB(J)   = [M:SQH2]YSILICONAB(L)   : [M:SQH2]YSILICONIZ(J)   = [M:SQH2]YSILICONIZ(L)
  [M:SQH2]YSILICONDE(J)   = [M:SQH2]YSILICONDE(L)   : [M:SQH2]YOLLADOSLONA(J) = [M:SQH2]YOLLADOSLONA(L)
  [M:SQH2]YREFLONA(J)     = [M:SQH2]YREFLONA(L)     : [M:SQH2]YREFLONAAR(J)   = [M:SQH2]YREFLONAAR(L)
  [M:SQH2]YREFLONAAB(J)   = [M:SQH2]YREFLONAAB(L)   : [M:SQH2]YREFLONAIZ(J)   = [M:SQH2]YREFLONAIZ(L)
  [M:SQH2]YREFLONADE(J)   = [M:SQH2]YREFLONADE(L)   : [M:SQH2]YPESOITM(J)     = [M:SQH2]YPESOITM(L)
  [M:SQH2]YPESOLIN(J)     = [M:SQH2]YPESOLIN(L)     : [M:SQH2]YBENLIN(J)      = [M:SQH2]YBENLIN(L)
  [M:SQH2]YBENUNI(J)      = [M:SQH2]YBENUNI(L)

  # Si el artículo tiene extras, también hay que duplicarlos.
  If [M:SQH2]YCODLIN(L) <> "" Then

    LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
    LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)
    [M:SQH2]YCODLIN(J)       = LFECHA + LHORA

    # DUPLICAR EXTRAS
    Local Char    LFECHA(10), LHORA(10) : Raz LFECHA, LHORA

    If !clalev([YTEP0]) Then : Local File YTEXTPRE [YTEP0] : Endif
    If !clalev([YTEP1]) Then : Local File YTEXTPRE [YTEP1] : Endif

    Filter [F:YTEP0] Where YCODLIN =[M:SQH2]YCODLIN(L)
    If rowcount([YTEP0])>0 Then
      For [F:YTEP0]
          Trbegin [YTEP1]
          [F:YTEP1]YCODLIN = [M:SQH2]YCODLIN(J)
          [F:YTEP1]YITMREF = [F:YTEP0]YITMREF
          [F:YTEP1]YEXTCOD = [F:YTEP0]YEXTCOD
          [F:YTEP1]YEXTCANT = [F:YTEP0]YEXTCANT
          [F:YTEP1]YEXTARR = [F:YTEP0]YEXTARR
          [F:YTEP1]YEXTABA = [F:YTEP0]YEXTABA
          [F:YTEP1]YEXTDER = [F:YTEP0]YEXTDER
          [F:YTEP1]YEXTIZQ = [F:YTEP0]YEXTIZQ
          [F:YTEP1]YEXTLARGO = [F:YTEP0]YEXTLARGO

          Write [YTEP1]
          If !fstat Then
            Commit
          Else
            Rollback
          Endif
      Next
    Endif

    # DUPLICAR TRAZA
    Local Char    LFECHA(10), LHORA(10) : Raz LFECHA, LHORA

    If !clalev([YTL0]) Then : Local File YTLOGPRE [YTL0] : Endif
    If !clalev([YTL1]) Then : Local File YTLOGPRE [YTL1] : Endif

    Filter [F:YTL0] Where YCODLIN =[M:SQH2]YCODLIN(L)
    If rowcount([YTL0])>0 Then
      For [F:YTL0]
          Trbegin [YTL1]
          [F:YTL1]YIDLIN = [F:YTL0]YIDLIN
          [F:YTL1]YCODLIN = [M:SQH2]YCODLIN(J)
          [F:YTL1]YITMREF = [F:YTL0]YITMREF
          [F:YTL1]YTEXTO = [F:YTL0]YTEXTO
          Write [F:YTL1]
          If !fstat Then
            Commit
          Else
            Rollback
          Endif
      Next
    Endif


  Endif

  Call TEMPOFF From GESECRAN
  status=0 : Call LINNUM("SQDLIN") From TABLEAUX
  Call APRES_NBLIG From SUBSQH

  Call AM_GROPRI([M:SQH2]GROPRI(J)) From SUBSQH
  Call AM_QTY([M:SQH2]QTY(J)) From SUBSQH

  Affzo [SQH2]1-99 : mkstat=4 : GREVFLG+=5



End

######################################################################################
## Botón 19 - Muestra info. artículo
######################################################################################
Subprog B19_NBLIG
Local Integer LINT2

  # Raz GPARAM1
  Global Char     GPARAM1(250)(0..)
  GPARAM1(0)  = [M:SQH2]ITMREF(nolign-1)                                          # pase de parámetros entre pantallas
  Call SAISIE_LIB(LINT2,GPARAM1,"OYMUESTRAITM","SPEYMI","OBJZON") From GSAISIE    # llamada a la función que abre la pantalla emregente
End

