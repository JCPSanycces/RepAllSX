######################################################################################################################
##############################################################
# TOTAL
Subprog SP_PRECIOFINALUNIDAD()
Local Decimal LCOSTOFINAL               : Raz LCOSTOFINAL
Local Decimal LGASTOS                   : Raz LGASTOS
Local Decimal LBENEFICIOUNIDAD          : Raz LBENEFICIOUNIDAD
Local Decimal LPRECIOUNIDAD             : Raz LPRECIOUNIDAD
Local Decimal LPRECIOUNIDADEUR          : Raz LPRECIOUNIDADEUR
Local Decimal LVALORUNITARIOEXTRAS      : Raz LVALORUNITARIOEXTRAS
Local Decimal LVALORUNITARIOLOCALEXTRAS : Raz LVALORUNITARIOLOCALEXTRAS
Local Decimal LPRECIOFINALUNIDAD        : Raz LPRECIOFINALUNIDAD
Local Char    LDESTIPO(40)

  # BORRAMOS TRAZA SI EXISTE
  #Infbox "SP_PRECIOFINALUNIDAD"
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "", "" ,"1") From SPEYLIB0

  If [M:SQH2]YTIPOIMP(GNUMLIN) = "01" and [M:SQH2]YRANGO(GNUMLIN) = "01" Then         # bandera estampada menor 1m2
    GTIPOITM = 1
    LDESTIPO = "BANDERA ESTAMPADA MENOR 1M2"
  Elsif [M:SQH2]YTIPOIMP(GNUMLIN) = "01" and [M:SQH2]YRANGO(GNUMLIN) = "02" Then      # bandera estampada mayor 1m2
    GTIPOITM = 2
    LDESTIPO = "BANDERA ESTAMPADA MAYOR 1M2"
  Elsif [M:SQH2]YTIPOIMP(GNUMLIN) = "02" and [M:SQH2]YFABRICADA(GNUMLIN) = "01" Then  # bandera digital fabricada ¿?¿?¿¿
    GTIPOITM = 3
    LDESTIPO = "BANDERA DIGITAL FABRICADA"  # MOSTRAR PRECIOS EN EUROS
  Elsif [M:SQH2]YTIPOIMP(GNUMLIN) = "02" and [M:SQH2]YFABRICADA(GNUMLIN) = "02" Then  # bandera digital subcontratada
    GTIPOITM = 4                            # MOSTRAR PRECIO EN YUAN Y LUEGO CONVERTIR A EURO
    LDESTIPO = "BANDERA DIGITAL SUBCONTRATADA"
  Endif

  # (A + B + C) / CANTIDAD
  If GTIPOITM = 1 or GTIPOITM = 2 or GTIPOITM = 4 Then

    Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "TIPO ARTICULO  " + num$(GTIPOITM) + " - " + LDESTIPO + "(Id línea:" + [M:SQH2]YCODLIN(nolign-1) + ")" , "1") From SPEYLIB0
    Call SP_COSTOFINAL(LCOSTOFINAL, "1")
    # SIN TENER EN CUENTA LOS GASTOS Y EL BENEFICIO
    Call SP_GASTOS(LGASTOS, "1")
    Call SP_BENEFICIOUNIDAD(LBENEFICIOUNIDAD, "1")
    If [M:SQH2]QTY(GNUMLIN) <> 0 Then
      # LCOSTEFINAL --> este es el valor que hay que pasarle a la tarifa
      LPRECIOFINALUNIDAD        = arr((LCOSTOFINAL + LGASTOS + LBENEFICIOUNIDAD) / [M:SQH2]QTY(GNUMLIN),0.00001)
      Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Precio unidad = (COSTOFINAL + GASTOS + BENEFICIO)/CANTIDAD -> " + num$(LCOSTOFINAL) + "+" + num$(LGASTOS) + "+" +  num$(LBENEFICIOUNIDAD) +
& "/" + num$([M:SQH2]QTY(GNUMLIN)) + " = " + num$(LPRECIOFINALUNIDAD),"1") From SPEYLIB0
      #quito traza2
#      Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",  "TIPO ARTICULO  " + num$(GTIPOITM) + " - " + LDESTIPO + " - SP_PRECIOFINALUNIDAD = LCOSTOFINAL + LGASTOS + LBENEFICIOUNIDAD) / CANTIDAD --> "
# -
#& "(" + num$(
#& LCOSTOFINAL) + "+" + num$(LGASTOS) + "+"  +
#& num$(LBENEFICIOUNIDAD) + ")/" + [M:SQH2]QTY(GNUMLIN)+" = " + num$(LPRECIOFINALUNIDAD)  ) From SPEYLIB0
    Else
      LPRECIOFINALUNIDAD = 0
    Endif
  Elsif GTIPOITM = 3
    # A11 + A12
    #Call SP_PRECIOUNIDAD(LPRECIOUNIDAD, [M:SQH0]QUODAT)
    # PRECIO UNIDAD CON LA FUNCION
    #If GUSER = "AIT51" Then : Infbox "PRECIO UNIDAD LOCAL:" + num$(LPRECIOUNIDAD) : Endif
    Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "TIPO ARTICULO  " + num$(GTIPOITM) + " - " + LDESTIPO,"1") From SPEYLIB0
    Call SP_PRECIOUNIDAD([M:SQH2]YCODLIN(GNUMLIN), LPRECIOUNIDAD, LPRECIOUNIDADEUR, [M:SQH0]QUODAT, [M:SQH2]YALTO(GNUMLIN), [M:SQH2]YANCHO(GNUMLIN), [M:SQH2]YMATERIAL(GNUMLIN), [M:SQH2]YNUMCOLORES(
& GNUMLIN), [M:SQH2]QTY(GNUMLIN), GTIPOITM,"1") From SPEYLIB0

    Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "**** PRECIO UNIDAD EUR: " + num$(LPRECIOUNIDADEUR) ,"1") From SPEYLIB0
    #If GUSER = "AIT51" Then : Infbox "PRECIO UNIDAD LIBRERIA:"  + num$(LPRECIOUNIDADEUR) + " " + num$(LPRECIOUNIDAD) : Endif
 # Infbox "1. Llamada a SP_VALORUNITARIOEXTRAS : alto: " + num$(val([M:SQH2]YALTO(GNUMLIN))) + " - ancho: " + num$(val([M:SQH2]YANCHO(GNUMLIN)))

   Call SP_VALORUNITARIOEXTRAS(LVALORUNITARIOEXTRAS,LVALORUNITARIOLOCALEXTRAS,[M:SQH0]QUODAT, ([M:SQH2]YANCHO(GNUMLIN)),([M:SQH2]YALTO(GNUMLIN)),"1", LPRECIOUNIDAD, LPRECIOUNIDADEUR, GTIPOITM)

    LPRECIOFINALUNIDAD        = arr(LPRECIOUNIDADEUR + LVALORUNITARIOLOCALEXTRAS,0.00001)
    Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "TOTAL PRECIO UNIDAD: " + num$(LPRECIOFINALUNIDAD) + " (PRECIOUNIDAD + EXTRAS) - (" +  num$(LPRECIOUNIDADEUR) + "+" +  num$(
& LVALORUNITARIOLOCALEXTRAS) + ")","1" ) From SPEYLIB0
  Endif
# JC - 12/05/2020 #  LPRECIOFINALUNIDAD        = LCOSTOFINAL + LGASTOS + LBENEFICIOUNIDAD
  [M:SQH2]YGROPRI(GNUMLIN)  = LPRECIOFINALUNIDAD
  Affzo [M:SQH2]YGROPRI(GNUMLIN)
  [M:SQH2]GROPRI(GNUMLIN)  = LPRECIOFINALUNIDAD
  Affzo [M:SQH2]GROPRI(GNUMLIN) # MAB.22062020.NEW
End

##############################################################CÁLCULO DEL BLOQUE COSTO FINAL
# A = (A1 * CANTIDAD) + A2
Subprog SP_COSTOFINAL(PCOSTOFINAL, PTRAZA)
Variable  Decimal PCOSTOFINAL
Value     Char    PTRAZA
Local Decimal LCOSTO    : Raz LCOSTO
Local Decimal LCOSTOYUAN : Raz LCOSTOYUAN
Local Decimal LENVIO    : Raz LENVIO
Local Decimal LCANTIDAD : Raz LCANTIDAD
  LENVIO = 0
  LCOSTO = 0
  LCANTIDAD = [M:SQH2]QTY(GNUMLIN)
#  If GUSER = 'AIT51' Then : Infbox num$(LCANTIDAD) : Endif
  # A1
  Call SP_COSTO(LCOSTO,LCOSTOYUAN, PTRAZA)
# iván indica que para los casos de prueba de Golden no ha tenido en cuenta el envío - JC - 12/05/2020
# JC - 12/05/2020 # A2
   Call SP_ENVIO(LENVIO, PTRAZA)
#  If GUSER = 'AIT51' Then : Infbox "LCOSTO: " + num$(LCOSTO) : Endif
  PCOSTOFINAL = (LCOSTO * LCANTIDAD)
  PCOSTOFINAL = PCOSTOFINAL + LENVIO
#If GUSER = "AIT51" Then : Infbox "A ="-num$(PCOSTOFINAL) : Endif

  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "LCOSTO: " - num$(LCOSTO),PTRAZA) From SPEYLIB0
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "LCANTIDAD: " - num$(LCANTIDAD),PTRAZA) From SPEYLIB0
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "LENVIO: " - num$(LENVIO),PTRAZA) From SPEYLIB0

  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Valor total línea: " - num$(PCOSTOFINAL) + "--> (VALORUNITARIO * CANTIDAD) + ENVIO -> (" + num$(LCOSTO) + "*" + num$(LCANTIDAD) + ") + " + num$(
& LENVIO),PTRAZA) From SPEYLIB0
End

##############################################################
# A1 = A11 + A12
Subprog SP_COSTO(PCOSTO, PCOSTOYUAN, PTRAZA)
Variable  Decimal PCOSTO, PCOSTOYUAN
Value Char        PTRAZA
Local Decimal LPRECIOUNIDAD             : Raz LPRECIOUNIDAD
Local Decimal LPRECIOUNIDADEUR          : Raz LPRECIOUNIDADEUR
Local Decimal LVALORUNITARIOEXTRAS      : Raz LVALORUNITARIOEXTRAS
Local Decimal LVALORUNITARIOLOCALEXTRAS : Raz LVALORUNITARIOLOCALEXTRAS
Local Char    LDIVISA(5)                : Raz LDIVISA

  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Calculo de Precio unitario + Precio Extras",PTRAZA) From SPEYLIB0
  # A11
  #Call SP_PRECIOUNIDAD(LPRECIOUNIDAD, [M:SQH0]QUODAT)
  #If GUSER = "AIT51" Then : Infbox "PRECIO LOCAL :" + num$(LPRECIOUNIDAD) : Endif
    Call SP_PRECIOUNIDAD([M:SQH2]YCODLIN(GNUMLIN),  LPRECIOUNIDAD, LPRECIOUNIDADEUR, [M:SQH0]QUODAT, [M:SQH2]YALTO(GNUMLIN), [M:SQH2]YANCHO(GNUMLIN), [M:SQH2]YMATERIAL(GNUMLIN), [M:SQH2]YNUMCOLORES(
& GNUMLIN), [M:SQH2]QTY(GNUMLIN), GTIPOITM,PTRAZA) From SPEYLIB0
  # MOSTRAR TRAZA EN UNA SOLA MONEDA
  If GTIPOITM = 1 or GTIPOITM = 2 or GTIPOITM = 4 Then
    Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Precio unitario ¥: " + num$(LPRECIOUNIDAD),PTRAZA) From SPEYLIB0
    Call CONVERTDIV_TR("CNY","EUR",LPRECIOUNIDAD,1,LPRECIOUNIDADEUR, [M:SQH2]YCODLIN(nolign-1), PTRAZA) From SPEYLIB0
  Else
    Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Precio unitario ¥: " + num$(LPRECIOUNIDADEUR),PTRAZA) From SPEYLIB0
  Endif
  #  If GUSER = "AIT51" Then : Infbox "PRECIO LIBRERIA :"  + num$(LPRECIOUNIDADEUR) + " " + num$(LPRECIOUNIDAD) : Endif
  # A12
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "*** Cálculo de extras ***", PTRAZA) From SPEYLIB0
 # Infbox "2. Llamada a SP_VALORUNITARIOEXTRAS : alto: " + num$(val([M:SQH2]YALTO(GNUMLIN))) + " - ancho: " + num$(val([M:SQH2]YANCHO(GNUMLIN)))

  Call SP_VALORUNITARIOEXTRAS(LVALORUNITARIOEXTRAS,LVALORUNITARIOLOCALEXTRAS,[M:SQH0]QUODAT,([M:SQH2]YANCHO(GNUMLIN)),([M:SQH2]YALTO(GNUMLIN)),PTRAZA,LPRECIOUNIDAD,LPRECIOUNIDADEUR,GTIPOITM )

  PCOSTO = LPRECIOUNIDADEUR + (LVALORUNITARIOLOCALEXTRAS)
  PCOSTOYUAN = (LPRECIOUNIDAD + LVALORUNITARIOEXTRAS)

  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Valor total línea (PRECIO UNIDAD + EXTRAS) en ¥ : (" - num$(LPRECIOUNIDAD) + " + " + num$(LVALORUNITARIOEXTRAS) + ") = " + num$(
& PCOSTOYUAN)
& ,PTRAZA) From
& SPEYLIB0
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Valor total línea (PRECIO UNIDAD + EXTRAS) en EUR : (" - num$(LPRECIOUNIDADEUR) + " + " + num$(LVALORUNITARIOLOCALEXTRAS) + ") = " + num$(
& PCOSTO)
& ,PTRAZA) From
& SPEYLIB0
# JC - 12/05/2020 #  PCOSTO = LPRECIOUNIDAD + LVALORUNITARIOLOCALEXTRAS

End

##############################################################
# A11
Subprog SP_PRECIOUNIDAD(PPRECIOUNIDAD, PFECHA)
  Variable Decimal PPRECIOUNIDAD
  Value Date PFECHA

  Local Decimal LALTO           : Raz LALTO
  Local Decimal LANCHO          : Raz LANCHO
  Local Decimal LVALORUNITARIO  : Raz LVALORUNITARIO
  Local Decimal LFOTOLITO       : Raz LFOTOLITO
  Local Decimal LCANTIDAD       : Raz LCANTIDAD
  Local Decimal LAREA           : Raz LAREA
  Local Decimal LAREATOTAL      : Raz LAREATOTAL
  Local Char    LCRITERIO       : Raz LCRITERIO

  LALTO     = arr(val([M:SQH2]YALTO(GNUMLIN)) / 100,0.0001)
  LANCHO    = arr(val([M:SQH2]YANCHO(GNUMLIN)) / 100,0.0001)
  LCANTIDAD = [M:SQH2]QTY(GNUMLIN)
  LAREA     = arr(LALTO * LANCHO,0.0001)
  LAREATOTAL = LAREA * LCANTIDAD

  # If GUSER = "AIT51" Then : Infbox "AREA:" + num$(LAREA) : Endif
  # If GUSER = "AIT51" Then : Infbox "GTIPOITM:" + num$(GTIPOITM) : Endif
  Case GTIPOITM
    When 1  # obtención del valor unitario en la tarifa de banderas estampadas - 1m2
    # A11 = VALOR UNITARIO SEGÚN TARIFA
      If !clalev([F:YLC0]) Then : Local File YTBEM1LC   [F:YLC0] : Endif
      If !clalev([F:YLD0]) Then : Local File YTBEM1LD   [F:YLD0] : Endif
      Filter [F:YLC0] Where ACTFLG = 2 and STRDAT <= PFECHA and ENDDAT >= PFECHA
      Read   [F:YLC0] First
      If !fstat Then
        # If GUSER = "AIT51" Then : Infbox "Area:"  + num$(LAREA) + " - material:" + [M:SQH2]YMATERIAL(GNUMLIN) + " - colores:" + [M:SQH2]YNUMCOLORES(GNUMLIN) + "- LCANTIDAD:" + num$(LCANTIDAD) :
# Endif
        Filter [F:YLD0] Where CODTAR=[F:YLC0]CODTAR and LAREA>=MINAREA and LAREA<=MAXAREA and MATERIAL=[M:SQH2]YMATERIAL(GNUMLIN) and COLOR=[M:SQH2]YNUMCOLORES(GNUMLIN)
&       and LCANTIDAD>=MINQTY and LCANTIDAD<=MAXQTY
       # Infbox evalue(LCRITERIO)
        Read   [F:YLD0] First
        If !fstat Then
          LVALORUNITARIO = [F:YLD0]VUNITARIO
          # If GUSER = "AIT51" Then : Infbox "A113 ("+[F:YLC0]CUR+") ="-num$(LVALORUNITARIO) : Endif
          If [F:YLC0]CUR <> "EUR" Then
            Call CONVERTDIV([F:YLC0]CUR,"EUR",LVALORUNITARIO,1,LVALORUNITARIO) From SPEYLIB0
#            If GUSER = "AIT07" Then : Infbox "A113 (€) ="-num$(LVALORUNITARIO) : Endif
          Endif
        Else
          GESTADO = 1
        Endif
        Filter [F:YLD0]
      Else
        GESTADO = 1
      Endif
      Filter [F:YLC0]
      PPRECIOUNIDAD = LVALORUNITARIO
      # If GUSER = "AIT51" Then : Infbox "A11 (€) ="-num$(PPRECIOUNIDAD) : Endif
      If  clalev([F:YLC0]) Then : Close Local File      [F:YLC0] : Endif
      If  clalev([F:YLD0]) Then : Close Local File      [F:YLD0] : Endif
    When 2 # obtención de fotolito y valor unitario en la tarifa de banderas estampadas + 1m2
    # A11 = (A111 * A112 * A113) + ((A111 * A112 * A114 / CANTIDAD) * (A111 * A112))
      If !clalev([F:YMC0]) Then : Local File YTBEM1MC   [F:YMC0] : Endif
      If !clalev([F:YMD0]) Then : Local File YTBEM1MD   [F:YMD0] : Endif
      Filter [F:YMC0] Where ACTFLG = 2 and STRDAT <= PFECHA and ENDDAT >= PFECHA
      Read   [F:YMC0] First
      If !fstat Then
        Filter [F:YMD0] Where CODTAR=[F:YMC0]CODTAR and COLOR=[M:SQH2]YNUMCOLORES(GNUMLIN) and MATERIAL=[M:SQH2]YMATERIAL(GNUMLIN) and LCANTIDAD>=MINQTY and LCANTIDAD<=MAXQTY
        Read   [F:YMD0] First
        If !fstat Then
          LVALORUNITARIO  = [F:YMD0]VUNITARIO
          #If GUSER = "AIT51" Then : Infbox "A113 ("+[F:YMC0]CUR+") ="-num$(LVALORUNITARIO) : Endif
          LFOTOLITO       = val([F:YMD0]FOTOLITO)
        Else
          GESTADO = 1
        Endif
        Filter [F:YMD0]
      Else
        GESTADO = 1
      Endif
      Filter [F:YMC0]
      If LCANTIDAD <> 0 Then # MA
       # PPRECIOUNIDAD = (LALTO*LANCHO*LVALORUNITARIO) + ((LALTO*LANCHO*LFOTOLITO/LCANTIDAD) * (LALTO*LANCHO))
       PPRECIOUNIDAD = (LAREA*LVALORUNITARIO) + ((LAREA*LFOTOLITO/LCANTIDAD)) # * (LALTO*LANCHO))
       # If GUSER = "AIT51" Then : Infbox "PRECIO UNIDAD EN  ("+[F:YMC0]CUR+") ="-num$(PPRECIOUNIDAD) : Endif
      Endif
      If [F:YMC0]CUR <> "EUR" Then
        Call CONVERTDIV([F:YMC0]CUR,"EUR",PPRECIOUNIDAD,1,PPRECIOUNIDAD) From SPEYLIB0
      Endif
      # If GUSER = "AIT51" Then : Infbox "PRECIO UNIDAD FINAL (€) ="-num$(PPRECIOUNIDAD) : Endif
      If  clalev([F:YMC0]) Then : Close Local File      [F:YMC0] : Endif
      If  clalev([F:YMD0]) Then : Close Local File      [F:YMD0] : Endif
    When 4  # obtención del valor unitario en la tarifa de banderas digitales SUBCONTRATADA
    # A11 = VALOR UNITARIO SEGÚN TARIFA
      If !clalev([F:YSC0]) Then : Local File YTBDSUBC   [F:YSC0] : Endif
      If !clalev([F:YSD0]) Then : Local File YTBDSUBD   [F:YSD0] : Endif
      Filter [F:YSC0] Where ACTFLG = 2 and STRDAT <= PFECHA and ENDDAT >= PFECHA
      Read   [F:YSC0] First
      If !fstat Then
        LAREATOTAL = arr(LALTO * LANCHO,0.0001) * LCANTIDAD # ASI OBTENEMOS EL TOTAL DE M2 # MAB.17082020.NEW
        Filter [F:YSD0] Where CODTAR=[F:YSC0]CODTAR and LAREATOTAL>=MINAREA and LAREATOTAL<=MAXAREA and MATERIAL=[M:SQH2]YMATERIAL(GNUMLIN) and LCANTIDAD>=MINQTY and LCANTIDAD<=MAXQTY
        Read   [F:YSD0] First
        If !fstat Then
          LVALORUNITARIO = [F:YSD0]VUNITARIO*LAREA
          # If GUSER = "AIT51" Then : Infbox "A113 ("+[F:YSC0]CUR+") ="-num$(LVALORUNITARIO) : Endif
          If [F:YSC0]CUR <> "EUR" Then
            Call CONVERTDIV([F:YSC0]CUR,"EUR",LVALORUNITARIO,1,LVALORUNITARIO) From SPEYLIB0
            # If GUSER = "AIT51" Then : Infbox "A113 (€) ="-num$(LVALORUNITARIO) : Endif
          Endif
        Else
          GESTADO = 1
        Endif
        Filter [F:YSD0]
      Else
        GESTADO = 1
      Endif
      Filter [F:YSC0]
      PPRECIOUNIDAD = LVALORUNITARIO
      # If GUSER = "AIT51" Then : Infbox "A11 (€) ="-num$(PPRECIOUNIDAD) : Endif
      If  clalev([F:YSC0]) Then : Close Local File      [F:YSC0] : Endif
      If  clalev([F:YSD0]) Then : Close Local File      [F:YSD0] : Endif
    When 3 # obtención del valor unitario en la tarifa de banderas digitales fabricadas
    # A11 = VALOR UNITARIO SEGÚN TARIFA
      If !clalev([F:YFC0]) Then : Local File YTBDFABC   [F:YFC0] : Endif
      If !clalev([F:YFD0]) Then : Local File YTBDFABD   [F:YFD0] : Endif
      Filter [F:YFC0] Where ACTFLG = 2 and STRDAT <= PFECHA and ENDDAT >= PFECHA
      Read   [F:YFC0] First
      If !fstat Then
        Filter [F:YFD0] Where CODTAR=[F:YFC0]CODTAR and LAREA>=MINAREA and LAREA<=MAXAREA and MATERIAL=[M:SQH2]YMATERIAL(GNUMLIN) and LCANTIDAD>=MINQTY and LCANTIDAD<=MAXQTY
        Read   [F:YFD0] First
        If !fstat Then
          LVALORUNITARIO = [F:YFD0]VUNITARIO
          # If GUSER = "AIT51" Then : Infbox "A113 ("+[F:YFC0]CUR+") ="-num$(LVALORUNITARIO) : Endif
          If [F:YFC0]CUR <> "EUR" Then
            Call CONVERTDIV([F:YFC0]CUR,"EUR",LVALORUNITARIO,1,LVALORUNITARIO) From SPEYLIB0
            #If GUSER = "AIT51" Then : Infbox "A113 (€) ="-num$(LVALORUNITARIO) : Endif
          Endif
        Else
          GESTADO = 1
        Endif
        Filter [F:YFD0]
      Else
        GESTADO = 1
      Endif
      Filter [F:YFC0]
      PPRECIOUNIDAD = LVALORUNITARIO
      # If GUSER = "AIT51" Then : Infbox "A11 (€) ="-num$(PPRECIOUNIDAD) : Endif
      If  clalev([F:YFC0]) Then : Close Local File      [F:YFC0] : Endif
      If  clalev([F:YFD0]) Then : Close Local File      [F:YFD0] : Endif
  Endcase

End

##############################################################
# A12
#**
#*
#*
#* @param PVALORUNITARIOEXTRAS
#* @param PVALORUNITARIOLOCALEXTRAS
#* @param PFECHA Fecha
#* @param PANCHO Char
#* @param PLARGO Char
#*!
Subprog SP_VALORUNITARIOEXTRAS(PVALORUNITARIOEXTRAS2,PVALORUNITARIOLOCALEXTRAS2, PFECHA, PANCHO, PLARGO,PTRAZA, PPRECIOUNIDAD, PPRECIOUNIDADEUR, PTIPO)
Variable Decimal PVALORUNITARIOEXTRAS2
Variable Decimal PVALORUNITARIOLOCALEXTRAS2
Value Date PFECHA
Value Char PANCHO, PLARGO
Value Char PTRAZA
Value Decimal PPRECIOUNIDAD, PPRECIOUNIDADEUR # PRECIO UNIDAD BANDERA
Value Integer PTIPO

Local Decimal PVALORUNITARIOEXTRAS
Local Decimal PVALORUNITARIOLOCALEXTRAS





Local Decimal LVALORUNITARIOEXTRAS2
Local Decimal LVALORUNITARIOLOCALEXTRAS2
Local Decimal LALTO
Local Decimal LANCHO
Local Decimal LAREA

 LALTO     = val(PLARGO) # arr(val(PLARGO) / 100,0.0001)
 LANCHO    = val(PANCHO) # arr(val(PANCHO) / 100,0.0001)
 # LAREA     = arr(LALTO * LANCHO,0.0001)

# Infbox "DENTRO SP_VALORUNITARIOEXTRAS --> PANCHO : " + num$(PANCHO) + " - PLARGO: " + num$(PLARGO)

Local Char    LDIVISA(5)      : Raz LDIVISA
Local Decimal LVALORUNITARIO  : Raz LVALORUNITARIO
Local Decimal LVALORUNITARIOEUR  : Raz LVALORUNITARIOEUR
Local Integer LCUENTAFLAGS    : Raz LCUENTAFLAGS
Local Decimal LTOTALCM        : Raz LTOTALCM
Local Decimal LTOTALM         : Raz LTOTALM
Local Date    LFECHA

If !clalev([F:YEC0]) Then : Local File YTCMPEXC   [F:YEC0] : Endif
If !clalev([F:YED0]) Then : Local File YTCMPEXD   [F:YED0] : Endif

  If PFECHA = [00/00/0000] Then
    LFECHA = date$
  Else
    LFECHA = PFECHA
  Endif

  # obtención del valor de los componentes extra
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Obtención del valor del componente extra",PTRAZA) From SPEYLIB0
  Filter [F:YEC0] Where ACTFLG = 2 and STRDAT <= LFECHA and ENDDAT >= LFECHA
  Read   [F:YEC0] First
  If !fstat Then
    LDIVISA = [F:YEC0]CUR
    # SI EL ARTÍCULO VIENE DEL ASISTENTE, BUSCAMOS PROPIEDADES EN LA TABLA TMP DE EXTRAS DEL PRESUPUESTO
    If [M:SQH2]YCODLIN <> '' Then
      If !clalev([F:YTE0]) Then : Local File YTEXTPRE   [F:YTE0] : Endif # MAB.19062020.NEW
      Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Extras de la línea del presupuesto",PTRAZA) From SPEYLIB0
      Filter [F:YTE0] Where YCODLIN = [M:SQH2]YCODLIN(nolign-1)
    Else # SI EL ARTÍCULO VIENE DEL MAESTRO DE ARTICULOS, BUSCAMOS COMPONENTES EN LA TABLA DE EXTRAS DE ARTICULO
      Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Extras del artículo " + [M:SQH2]ITMREF(nolign-1),PTRAZA) From SPEYLIB0
      If !clalev([F:YTE0]) Then : Local File YTEXTART   [F:YTE0] : Endif
      Filter [F:YTE0] Where ITMREF = [M:SQH2]ITMREF(nolign-1)
    Endif

    #Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Número de componentes extra: " + num$(rowcount([YTE0]))) From SPEYLIB0
    If rowcount([YTE0]) = 0 Then
        Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "No existen extras",PTRAZA) From SPEYLIB0
    Else
      For [F:YTE0]

        LCUENTAFLAGS = 0
        LTOTALCM = 0
        LTOTALM = 0
        # If GUSER = "AIT51" Then : Infbox "0.EXTRA: " + [F:YTE0]YEXTCOD : Endif
        # SUMAMOS LA LONGITUD DE TODOS LOS LADOS
        If [F:YTE0]YEXTARR = 2 Then : LCUENTAFLAGS += 1 :  LTOTALCM += LANCHO : Endif
        If [F:YTE0]YEXTABA = 2 Then : LCUENTAFLAGS += 1 :  LTOTALCM += LANCHO : Endif
        If [F:YTE0]YEXTDER = 2 Then : LCUENTAFLAGS += 1 :  LTOTALCM += LALTO : Endif
        If [F:YTE0]YEXTIZQ = 2 Then : LCUENTAFLAGS += 1 :  LTOTALCM += LALTO : Endif
        # PASAMOS A METROS
        If LTOTALCM <> 0 Then
          LTOTALM = LTOTALCM/100
          # If GUSER = "AIT51" Then : Infbox "1.LTOTALM:" + num$(LTOTALM) : Endif
        Endif
        # SI TENEMOS CANTIDAD Y LARGO, ES UN TIPO DE EXTRA SIN LADOS, PERO TAMBIÉN HAY QUE SACAR LA MEDIDA
        # POR SI ACASO ACUMULO EN LTOTALM
        If [F:YTE0]YEXTCANT <> 0 and [F:YTE0]YEXTLARGO <> 0 Then
            LTOTALM = LTOTALM + ([F:YTE0]YEXTCANT * [F:YTE0]YEXTLARGO / 100)
            # If GUSER = "AIT51" Then : Infbox "2.LTOTALM:" + num$(LTOTALM) : Endif
        Endif
        # BUSCAR EL PRECIO DEL METRO EN LA TABLA DE TARIFAS DE EXTRAS
        Filter [F:YED0] Where CODTAR = [F:YEC0]CODTAR and COMPONENTE = [F:YTE0]YEXTCOD
        Read [F:YED0] First
        If !fstat Then
           LVALORUNITARIO = [F:YED0]VUNITARIO
           LVALORUNITARIOEUR = [F:YED0]VUNITARIOL
          # If GUSER = "AIT51" Then : Infbox "3.VALORUNITARIO:" + num$(LVALORUNITARIO) : Endif
          If LDIVISA <> "EUR" Then
            # de momento quitamos la conversión de divisa, porque los extras ya los tenemos con precios en yuan directamente
            # en la tabla de tarifas de extras
            Call CONVERTDIV(LDIVISA,"EUR",LVALORUNITARIO,1,LVALORUNITARIO) From SPEYLIB0
          #  If GUSER = "AIT51" Then : Infbox "3.1.VALORUNITARIO en euros:" + num$(LVALORUNITARIO) : Endif
          Endif
          If LTOTALM <> 0 Then
             # If GUSER = "AIT51" Then : Infbox "4.0.LVALORUNITARIO * LTOTALM:" + num$(LVALORUNITARIO) + "*" + num$(LTOTALM) : Endif
             PVALORUNITARIOEXTRAS += LVALORUNITARIO * LTOTALM
             # If GUSER = "AIT51" Then : Infbox "4.1PVALORUNITARIOEXTRAS:" + num$(PVALORUNITARIOEXTRAS) : Endif
             PVALORUNITARIOLOCALEXTRAS += LVALORUNITARIOEUR * LTOTALM
             # If GUSER = "AIT51" Then : Infbox "5.PVALORUNITARIOLOCALEXTRAS:" + num$(PVALORUNITARIOLOCALEXTRAS) : Endif
          Endif
          #If LCUENTAFLAGS > 0 Then
          #  PVALORUNITARIOEXTRAS      += LVALORUNITARIO       * LCUENTAFLAGS
          #  PVALORUNITARIOLOCALEXTRAS += [F:YED0]VUNITARIOL   * LCUENTAFLAGS
          #Endif
          If [F:YTE0]YEXTCANT <> 0 and LTOTALM = 0 and [F:YTE0]YEXTLARGO <> 0  Then
             #If GUSER = "AIT51" Then : Infbox "6.0.lvalorunitario*[F:YTE0]YEXTCANT:" + num$(LVALORUNITARIO) + "*" + num$([F:YTE0]YEXTCANT) : Endif
             PVALORUNITARIOEXTRAS      += LVALORUNITARIO  * ([F:YTE0]YEXTCANT * [F:YTE0]YEXTLARGO)
             # If GUSER = "AIT51" Then : Infbox "6.1.PVALORUNITARIOEXTRAS:" + num$(PVALORUNITARIOEXTRAS) : Endif
             PVALORUNITARIOLOCALEXTRAS += LVALORUNITARIOEUR * ([F:YTE0]YEXTCANT * [F:YTE0]YEXTLARGO)
             # If GUSER = "AIT51" Then : Infbox "7.PVALORUNITARIOLOCALEXTRAS:" + num$(PVALORUNITARIOLOCALEXTRAS) : Endif
          Endif
          If [F:YTE0]YEXTCANT <> 0 and LTOTALM = 0 and [F:YTE0]YEXTLARGO = 0  Then
             PVALORUNITARIOEXTRAS      += LVALORUNITARIO     #  * ([F:YTE0]YEXTCANT)  # NO MULTIPLICO POR CANTIDAD MAB.17112020
             # If GUSER = "AIT51" Then : Infbox "6.1.PVALORUNITARIOEXTRAS:" + num$(PVALORUNITARIOEXTRAS) : Endif
             PVALORUNITARIOLOCALEXTRAS += LVALORUNITARIOEUR  # * ([F:YTE0]YEXTCANT)   # NO MULTIPLICO POR CANTIDAD MAB.17112020
          Endif
  #        If [F:YTE0]YEXTCANT > 0 Then
  #          If [F:YTE0]YEXTLARGO > 0 Then
  #            PVALORUNITARIOEXTRAS      += LVALORUNITARIO       * [F:YTE0]YEXTCANT * ([F:YTE0]YEXTLARGO / 100)  #([M:SQH2]YLARGO(GNUMLIN) / 100)
  #            PVALORUNITARIOLOCALEXTRAS += [F:YED0]VUNITARIOL   * [F:YTE0]YEXTCANT * ([F:YTE0]YEXTLARGO / 100)  #([M:SQH2]YLARGO(GNUMLIN) / 100)
  #          Else
  #            PVALORUNITARIOEXTRAS      += LVALORUNITARIO       * [F:YTE0]YEXTCANT
  #            PVALORUNITARIOLOCALEXTRAS += [F:YED0]VUNITARIOL   * [F:YTE0]YEXTCANT
  #          Endif
  #        Endif
        Else
          GESTADO = 1
        Endif
        Filter [F:YED0]
        Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "*** Llamada a Calculo Extra: " + [F:YTE0]YEXTCOD + " - Base :" + num$(LANCHO) + " - Alto: " + num$(LALTO),PTRAZA) From SPEYLIB0

        LVALORUNITARIOEXTRAS = 0          # TODO EL CÓDIGO DE ARRIBA NO SIRVE, YA QUE EL CÁLCULO DEL EXTRA SE HACE DESDE LA FUNCIÓN SP_VALORUNITARIOEXTRAS
        LVALORUNITARIOLOCALEXTRAS = 0     # TODO EL CÓDIGO DE ARRIBA NO SIRVE, YA QUE EL CÁLCULO DEL EXTRA SE HACE DESDE LA FUNCIÓN SP_VALORUNITARIOEXTRAS
        Call SP_VALORUNITARIOEXTRAS([M:SQH2]YCODLIN(nolign-1), LVALORUNITARIOEXTRAS,LVALORUNITARIOLOCALEXTRAS, LFECHA, num$(LANCHO), num$(LALTO), [F:YTE0]YEXTCANT, [F:YTE0]YEXTCOD, [F:YTE0]YEXTLARGO
& , [F:YTE0]YEXTARR, [F:YTE0]YEXTABA, [F:YTE0]YEXTIZQ, [F:YTE0]YEXTDER, PTRAZA,  PPRECIOUNIDAD, PPRECIOUNIDADEUR, PTIPO) From SPEYLIB0
#        Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "*** Resultado Extra (EUR): " + [F:YTE0]YEXTCOD + ": " + num$(LVALORUNITARIOLOCALEXTRAS2)  ) From SPEYLIB0

        PVALORUNITARIOEXTRAS2 += LVALORUNITARIOEXTRAS
        PVALORUNITARIOLOCALEXTRAS2 += LVALORUNITARIOLOCALEXTRAS
      Next
    Endif
    # para cada componente llamar al calculo de ese componente
    #Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Resultado extras CALCULO ANTIGUO :" + num$(PVALORUNITARIOEXTRAS) + " - CALCULO NUEVO: " + num$(PVALORUNITARIOEXTRAS2)) From SPEYLIB0
    #Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Resultado extras local CALCULO ANTIGUO: " + num$(PVALORUNITARIOLOCALEXTRAS) + " - CALCULO NUEVO: " + num$(PVALORUNITARIOLOCALEXTRAS2)) From
#& SPEYLIB0
 Else
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Tarifa de extras no encontrada",PTRAZA) From SPEYLIB0
 Endif
    # MAB.19062020.SOLD

