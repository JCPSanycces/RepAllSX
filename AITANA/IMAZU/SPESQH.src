#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#  If GUSER="AIT51" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "SETBOUT"    : Gosub SETBOUT
  When "EXEBOUT"    : Gosub EXEBOUT
  When "AVANTBOUT"    : Gosub AVANTBOUT
  When "INICRE"     : Gosub INICRE
  When "INIMOD"     : Gosub INIMOD
  When "FIN"        : Gosub FIN
  When "APRES_MODIF": Gosub APRES_MODIF
  When "INICRE_LIG" : Gosub INICRE_LIG
  When "LIENS_LIG"  : Gosub LIENS_LIG

  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
Global Integer  GCOMPRUEBA : GCOMPRUEBA = 1
Global Integer  GNUMLIN    : Raz GNUMLIN
Global Integer  GESTADO    : Raz GESTADO
Global Integer  GTIPOITM   : Raz GTIPOITM
Global Char     GPARAM1(250)(0..)
Global Char     GPARAM2(250)(1)
Return

##############################################################
$APRES_MODIF
  # Infbox "apres modf spe"

Return



##############################################################
$AVANTBOUT
 Local Integer LCREARPED
# Infbox "AVANTBOUT:" + BOUT
 #

 If BOUT = '2' Then # Crear pedido
  LCREARPED = 0
  For I = 0 To [M:SQH2]NBLIG
    If [M:SQH2]YCREAPED(I) = 2 Then
      LCREARPED = 1
      Break
    Endif
  Next
  If LCREARPED = 0 Then
    OK = 0
    GPE = 1
    Infbox "No se ha marcado ninguna línea del presupuesto para pasarla a pedido."
    Return
  Endif
 Endif
Return

##############################################################
$SETBOUT
