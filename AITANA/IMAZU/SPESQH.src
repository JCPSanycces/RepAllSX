   Call SP_PRECIOFINALUNIDAD()

   VALEUR = GPARAM2(0)
   zonsui = "[M:SQH2]YDESCITM(nolign-1)"
#   If GPARAM2(0) <> '' Then
#      [M:SQH2]ITMREF(nolign-1) = GPARAM2(0)
