######################################################################################
## Después de modificar el campo 'Artículo'
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

  If !clalev([F:ITM0]) Then : Local File ITMMASTER [F:ITM0] : Endif
  Read [F:ITM0]ITM0 = VALEUR
  If !fstat Then
    If VALEUR <> "BANDE9999" Then
      If [F:ITM0]YDESCOMPLETA <> "" Then
        [M:SQH2]YDESCITM(nolign-1)    = [F:ITM0]YDESCOMPLETA
        [M:SQH2]YREFERENCIA(nolign-1) = [F:ITM0]YREFERENCIA
        [M:SQH2]YTIPOIMP(nolign-1)    = [F:ITM0]YTIPOIMP
        [M:SQH2]YRANGO(nolign-1)      = [F:ITM0]YRANGO
        [M:SQH2]YFABRICADA(nolign-1)  = [F:ITM0]YFABRICADA
        [M:SQH2]YMATERIAL(nolign-1)   = [F:ITM0]YMATERIAL
        [M:SQH2]YALTO(nolign-1)       = [F:ITM0]YALTO
        [M:SQH2]YANCHO(nolign-1)      = [F:ITM0]YANCHO
        [M:SQH2]YNUMCOLORES(nolign-1) = [F:ITM0]YNUMCOLORES
        [M:SQH2]YPESPUNTE(nolign-1)   = [F:ITM0]YPESPUNTE
        [M:SQH2]YCONFNORMAL(nolign-1) = [F:ITM0]YCONFNORMAL
        [M:SQH2]YCONFFLY(nolign-1)    = [F:ITM0]YCONFFLY
        Affzo [M:SQH2]YDESCITM(nolign-1)
        Affzo [M:SQH2]YREFERENCIA(nolign-1)
        Affzo [M:SQH2]YTIPOIMP(nolign-1)
        Affzo [M:SQH2]YRANGO(nolign-1)
        Affzo [M:SQH2]YFABRICADA(nolign-1)
        Affzo [M:SQH2]YMATERIAL(nolign-1)
        Affzo [M:SQH2]YALTO(nolign-1)
        Affzo [M:SQH2]YANCHO(nolign-1)
        Affzo [M:SQH2]YNUMCOLORES(nolign-1)
        Affzo [M:SQH2]YPESPUNTE(nolign-1)
        Affzo [M:SQH2]YCONFNORMAL(nolign-1)
        Affzo [M:SQH2]YCONFFLY(nolign-1)
      Else
        [M:SQH2]YDESCITM(nolign-1) = [F:ITM0]ITMDES1
        Affzo [M:SQH2]YDESCITM(nolign-1)
      Endif
    Endif
  Close Local File [ITM0]
  Endif

  # MAB.29092020
   Call AM_YGROPRI([M:SQH2]YGROPRI(nolign-1))

End

######################################################################################
## Después de modificar el campo 'Precio bruto' (SPE)
######################################################################################
Subprog AM_YGROPRI(VALEUR)
Variable Decimal VALEUR

Local Decimal LVALEUR
Local Decimal PRECIO : PRECIO = VALEUR

  # Actualizamos el campo standard
  [M:SQH2]GROPRI(nolign -1) = PRECIO
  Affzo [M:SQH2]GROPRI(nolign -1)
  LVALEUR=VALEUR
  VALEUR=PRECIO

  #La acción es DIVDISCRG, pero llama al punto D_DISCRG
  Local Char    WABMSK    :    WABMSK="SQH2"
  Local Integer DISCRGNUM :    DISCRGNUM = 0
  Local Integer NOLIG     :    NOLIG=nolign-1

  If DISCRGNUM > 0 & DISCRGNUM < 10
     Assign "[M:"+WABMSK+"]DISCRGREN"+num$(DISCRGNUM)+"(NOLIG)" With GDACMANSAL
  Elsif DISCRGNUM = 0
     Assign "[M:"+WABMSK+"]PRIREN(NOLIG)" With GDACMANSAL
  Endif

Local Char PARAM(250)(250)
Local Char TRAIT
TRAIT="DIVPRIPFM"
PARAM(1)="0"
PARAM(2)=num$([M:SQH2]QTY(nolign-1))
PARAM(3)=[M:SQH0]BPCORD
PARAM(4)=num$([M:SQH0]CHGTYP)
PARAM(5)=[M:SQH0]QUODAT
PARAM(6)=[M:SQH1]CUR
PARAM(7)=num$(nolign-1)
PARAM(8)=[M:SQH2]DSTOFCY(nolign-1)
PARAM(9)=num$([M:SQH1]PRITYP)
PARAM(10)="GROPRI"
Gosub DIVPRIPFM From TRTVENPRI
VALEUR=LVALEUR
 # Actualizamos el campo standard
  [M:SQH2]GROPRI(nolign-1) = PRECIO
  Affzo [M:SQH2]GROPRI(nolign-1)

End

######################################################################################
## Control en el campo 'Calcula precio'
######################################################################################
Subprog C_YCALCULAPB(VALEUR)
Variable Integer VALEUR
#  If VALEUR = 2 Then
#    Grizo [M:SQH2]YCALCULAPB(nolign-1)
#  Endif
End

######################################################################################
## Después de modificar el campo 'Calcula precio'
######################################################################################
Subprog AM_YCALCULAPB(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    # MAB02062020.SNEW
    If [M:SQH2]QTY(nolign-1) <= 0 Then
      VALEUR = 1
      Infbox "Campo Cantidad obligatorio para realizar el cálculo del precio."
      mkstat = 2
      zonsui = "[M:SQH2]QTY(nolign-1)"
    Else
    # MAB02062020.ENEW
      Local Integer YESNO : YESNO = 1 # no
      Call OUINON("¿Estás seguro que deseas calcular el precio bruto de la línea?", YESNO) From GESECRAN
      If YESNO = 2 Then
        Raz GNUMLIN, GESTADO
        GNUMLIN = nolign-1
        Call SP_PRECIOFINALUNIDAD()
      Endif
      Grizo [M:SQH2]YCALCULAPB(GNUMLIN)
    Endif # MAB02062020.NEW
  Endif
End

######################################################################################
## Control en el campo 'Genera artículo
######################################################################################
Subprog C_YCREAITM(VALEUR)
Variable Integer VALEUR
#  If VALEUR = 2 Then
#    Grizo [M:SQH2]YCREAITM(nolign-1)
#  Endif
End

######################################################################################
## Después de modificar el campo 'Genera artículo'
######################################################################################
Subprog AM_YCREAITM(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    Local Integer YESNO : YESNO = 1 # no
    Call OUINON("¿Estás seguro que deseas generar el artículo de la línea?", YESNO) From GESECRAN
    Global  Integer GNUMLIN # : Raz GNUMLIN
    GNUMLIN = nolign-1
    If YESNO = 2 Then
      Gosub GENERAARTICULOS_DESDECAMPO
    Else
      VALEUR = 1
      [M:SQH2]YCREAITM(nolign-1) = VALEUR
      Affzo [M:SQH2]YCREAITM(nolign-1)
    Endif
  Endif
End

######################################################################################
## Inicializar botón 'Nblig'
######################################################################################
Subprog IB_NBLIG
  # oculta la info. de artículo si no es uno generado
  If ([M:SQH2]YASISTENTE(nolign-1) = 2 and [M:SQH2]YFLGCRE(nolign-1) = 2) or ([M:SQH2]ITMREF(nolign-1) <> '' and [M:SQH2]ITMREF(nolign-1) <> 'BANDE9999')  Then
    GBOUT19 = "Info. artículo"
  Else
    GBOUT19 = ""
  Endif
End

######################################################################################
## Botón 'Duplicar línea'
######################################################################################
Subprog B18_NBLIG

#Local Integer  OK  : OK=1
#
#  If [M:SQH2]NBLIG=0 End : Endif
#
#  If [M:SQH2]ITMREF(nolign-1)<>"" nolign+=1 : Endif
#
