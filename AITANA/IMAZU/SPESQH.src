End

##############################################################
# A2 = A21 + A22
Subprog SP_ENVIO(PENVIO, PTRAZA)
Variable Decimal PENVIO
Value Char  PTRAZA

Local Decimal LTARIFATRANSPORTE : Raz LTARIFATRANSPORTE
Local Decimal LCARGOCOMBUSTIBLE : Raz LCARGOCOMBUSTIBLE
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Calculo del Envío (A2 = A21+A22) A21(Tarifa Transporte) + A22(Cargo Combustible)",PTRAZA) From SPEYLIB0
  #Infbox "LLAMADA A TARIFA TRANSPORTE: TRAZA:" + PTRAZA
  Call SP_TARIFATRANSPORTE(LTARIFATRANSPORTE,LCARGOCOMBUSTIBLE,PTRAZA)

  If [M:SQH2]QTY(GNUMLIN) <> 0 Then
    PENVIO = (LTARIFATRANSPORTE + LCARGOCOMBUSTIBLE)
    Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Calculo del Envío: " + num$(LTARIFATRANSPORTE) + "+" + num$(LCARGOCOMBUSTIBLE) + " = " + num$(PENVIO) + " €",PTRAZA) From SPEYLIB0
# JC - 12/05/2020 #    PENVIO = (LTARIFATRANSPORTE + LCARGOCOMBUSTIBLE) / [M:SQH2]QTY(GNUMLIN)
  Else
    GESTADO = 2
  Endif

End

##############################################################
# A21 y A22; se calcula consultando la tarifa según el peso (A211)
Subprog SP_TARIFATRANSPORTE(PTARIFATRANSPORTE,PCARGOCOMBUSTIBLE, PTRAZA)
Variable  Decimal PTARIFATRANSPORTE
Variable  Decimal PCARGOCOMBUSTIBLE
Value Char PTRAZA

 Local Decimal LPESO             : Raz LPESO
 Local Decimal LCARGOCOMBUSTIBLE : Raz LCARGOCOMBUSTIBLE
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Calculo del Transportes y Cargo combustible A21 Y A22",PTRAZA) From SPEYLIB0

  Call SP_PESO(LPESO,PTRAZA) # peso ya en KG

  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Peso en KG = " + num$(LPESO),PTRAZA) From SPEYLIB0

  If !clalev([F:YTC0]) Then : Local File YTRANSPC   [F:YTC0] : Endif
  If !clalev([F:YTD0]) Then : Local File YTRANSPD   [F:YTD0] : Endif

  # busca la tarifa activa de transportista para calcular sus costes

  Filter [F:YTC0] Where ACTFLG = 2 and STRDAT <= date$ and ENDDAT >= date$ # AÑADO FILTRO DE FECHAS MAB.02122020
  Read   [F:YTC0] First
  If !fstat Then
    Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Tarifa Transportista:" +  [F:YTC0]CODTAR,PTRAZA ) From SPEYLIB0
    LCARGOCOMBUSTIBLE      = [F:YTC0]CARGOCOMB(month(date$)-1)
    Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Cargo combustible (" + month$(date$) + "):" +  num$(LCARGOCOMBUSTIBLE) + "%",PTRAZA ) From SPEYLIB0
    Filter [F:YTD0] Where CODTAR = [F:YTC0]CODTAR and LPESO > MINKG and LPESO < MAXKG
    Read   [F:YTD0] First
    If !fstat Then
      # If LPESO >= 21 Then
      If [F:YTD0]PRECIOXTOTAL = 2 Then
        PTARIFATRANSPORTE = LPESO * [F:YTD0]VUNITARIO
        Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Peso (precio por kilo) :" +  num$(LPESO) +  "*" + num$([F:YTD0]VUNITARIO) + " €",PTRAZA ) From SPEYLIB0
      Else
        PTARIFATRANSPORTE    = [F:YTD0]VUNITARIO
        Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Peso (precio directo de tarifa):" +  num$([F:YTD0]VUNITARIO) + " €",PTRAZA ) From SPEYLIB0
      Endif

    Else
      GESTADO = 1
      PTARIFATRANSPORTE = 0
    Endif
    Filter [F:YTD0]
  Else
    GESTADO = 1
    Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Tarifa Transportista NO ENCONTRADA",PTRAZA) From SPEYLIB0
  Endif
  PCARGOCOMBUSTIBLE       = PTARIFATRANSPORTE * (LCARGOCOMBUSTIBLE / 100)
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Costo transporte:" +  num$(PTARIFATRANSPORTE) + " €",PTRAZA ) From SPEYLIB0
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Cargo combustible: (Tarifa Transporte * Cargo combustible)/100 -> " + num$(PTARIFATRANSPORTE) + "*(" + num$(LCARGOCOMBUSTIBLE) + "/ 100) = " +
& num$(PCARGOCOMBUSTIBLE),PTRAZA ) From SPEYLIB0
#If GUSER = "AIT07" Then : Infbox "CARGOCOMBUSTIBLE"-num$(PCARGOCOMBUSTIBLE): ENDIF

  If  clalev([F:YTC0]) Then : Close Local File      [F:YTC0] : Endif
  If  clalev([F:YTD0]) Then : Close Local File      [F:YTD0] : Endif

End

##############################################################
# A211
Subprog SP_PESO(PPESO,PTRAZA)
Variable Decimal PPESO
Value Char PTRAZA

Local Decimal LALTO             : Raz LALTO
Local Decimal LANCHO            : Raz LANCHO
Local Decimal LCANTIDAD         : Raz LCANTIDAD
Local Decimal LPESOMATERIAL     : Raz LPESOMATERIAL
Local Decimal LAREA             : Raz LAREA
Local Decimal LPESOARTICULO     : Raz LPESOARTICULO
Local Decimal LPESOEXTRAS       : Raz LPESOEXTRAS
Local Decimal LPESOLINEA        : Raz LPESOLINEA
Local Decimal LCAJASNECESARIAS  : Raz LCAJASNECESARIAS
Local Decimal LPESOENVASE       : Raz LPESOENVASE
Local Decimal LPESOTOTALLINEA   : Raz LPESOTOTALLINEA
Local Decimal LPESOCAJA         : LPESOCAJA = 0.5

If !clalev([F:ADI0]) Then : Local File ATABDIV  [F:ADI0] : Endif
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "*** Cálculo del peso *** ",PTRAZA) From SPEYLIB0
  LALTO     = val([M:SQH2]YALTO(GNUMLIN)) / 100
  LANCHO    = val([M:SQH2]YANCHO(GNUMLIN)) / 100
  LCANTIDAD = [M:SQH2]QTY(GNUMLIN)


  Read [F:ADI0]CODE = 2502;[M:SQH2]YMATERIAL(GNUMLIN)                           # busca en la tabla varia de materiales su peso y las unidades por caja
  If !fstat Then
    LPESOMATERIAL  = val([F:ADI0]A1)                                            # peso del material
  Else
    GESTADO = 1
  Endif
  LAREA                       = LALTO * LANCHO                                  # área del artículo
  # A21111
  # LPESOARTICULO               = LAREA  * (LPESOMATERIAL / 1000)                 # peso de cada artículo
  LPESOARTICULO               = LAREA  * (LPESOMATERIAL) * LCANTIDAD                 # peso de cada artículo
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "*** Peso articulo gr: "  + num$(LPESOARTICULO) + " -> Area * Peso Material * Cantidad -> "  + "" + num$(LAREA) + "*"  + num$(LPESOMATERIAL) +
& " * " + num$(LCANTIDAD),PTRAZA) From SPEYLIB0
  # A21112
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "*** Peso extras ***",PTRAZA)  From SPEYLIB0
  Call SP_PESOUNITARIOEXTRAS(LPESOEXTRAS, LCANTIDAD, val([M:SQH2]YANCHO(GNUMLIN)), [M:SQH2]YLARGO(GNUMLIN),PTRAZA)                                       # peso de todos los extras
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Total Peso extras: "  + num$(LPESOEXTRAS) + " gr",PTRAZA  )  From SPEYLIB0
  # A2111
  LPESOLINEA                  = (LPESOARTICULO + LPESOEXTRAS) #  * LCANTIDAD       # peso de la línea
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Peso línea: "  + num$(LPESOLINEA) + " -> (Peso Articulo + Peso Extras)",PTRAZA)  From SPEYLIB0
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Peso línea en KG: "  + num$(LPESOLINEA/1000),PTRAZA)  From SPEYLIB0
  # A21121

  # BUSCAR KILOS POR CAJA EN TARIFA TRANSPORTISTA
  If !clalev([F:YTC1]) Then : Local File YTRANSPC   [F:YTC1] : Endif

  # busca la tarifa activa de transportista para calcular sus impuestos
  Filter [F:YTC1] Where ACTFLG = 2 and STRDAT <= date$ and ENDDAT >= date$
  Read   [F:YTC1] First
  If !fstat Then
    LCAJASNECESARIAS            = abs(arr((LPESOLINEA/1000) / [F:YTC1]KILOSXCAJA,1 )) +1 # 18,1
  Else
    LCAJASNECESARIAS            = abs(arr((LPESOLINEA/1000) / 18,1))+1 # 18,1
  Endif

  Filter [F:YTC1]

  If LCAJASNECESARIAS < 1 Then
    LCAJASNECESARIAS = 1
  Endif
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Cajas necesarias: "  + num$(LCAJASNECESARIAS) + " -> (Peso Línea) / "+num$([F:YTC1]KILOSXCAJA) ,PTRAZA)  From SPEYLIB0

  # A2112
  LPESOENVASE                 = LCAJASNECESARIAS * LPESOCAJA                    # peso total del envase (contenido + continente)
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Peso total cajas: "  + num$(LPESOENVASE) + " kg -> (Cajas necesarias / Peso Caja(0,5))",PTRAZA)  From SPEYLIB0

  # A211
  LPESOTOTALLINEA             = LPESOLINEA/1000 + LPESOENVASE                        # peso total de la línea de artículo
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Peso total línea: "  + num$(LPESOTOTALLINEA) + " -> (Peso línea + Envase) (" + num$(LPESOLINEA/1000) + "+" + num$(LPESOENVASE) + ")",PTRAZA)
& From
& SPEYLIB0
  [M:SQH2]YPESOLIN(GNUMLIN)   = LPESOTOTALLINEA
  Affzo [M:SQH2]YPESOITM(GNUMLIN)

  PPESO = LPESOTOTALLINEA # /1000

  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Peso Total línea en KG (Peso Línea + Envase) : "  + num$(PPESO),PTRAZA )  From SPEYLIB0

  If  clalev([F:ADI0]) Then : Close Local File    [F:ADI0] : Endif

End

##############################################################CÁLCULO DEL BLOQUE GASTOS
# B
Subprog SP_GASTOS(PGASTOS, PTRAZA)
Variable  Decimal PGASTOS
Value Char PTRAZA

Local Decimal LIMPUESTOGASTOS : Raz LIMPUESTOGASTOS
Local Decimal LIMPUESTOADMIN  : Raz LIMPUESTOADMIN
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "*** Cálculo de gastos/impuestos ****",PTRAZA ) From SPEYLIB0

  Call SP_IMPUESTOS(LIMPUESTOGASTOS,LIMPUESTOADMIN,PTRAZA)

  PGASTOS = LIMPUESTOGASTOS + LIMPUESTOADMIN
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Total Gastos: " + num$(PGASTOS),PTRAZA ) From SPEYLIB0
#  If GUSER = "AIT07" Then : Infbox "B ="-num$(PGASTOS) : Endif

End

##############################################################
# B1 y B2
Subprog SP_IMPUESTOS(PIMPUESTOGASTOS,PIMPUESTOADMIN, PTRAZA)
Variable  Decimal PIMPUESTOGASTOS
Variable  Decimal PIMPUESTOADMIN
Value Char PTRAZA

Local     Decimal LIMPUESTOPENINSULA  : Raz LIMPUESTOPENINSULA
Local     Decimal LIMPUESTOCANARIAS   : Raz LIMPUESTOCANARIAS
Local     Decimal LIMPUESTOADM        : Raz LIMPUESTOADM
Local     Decimal LPESO               : Raz LPESO
Local     Decimal LIMPUESTOSEGUNZONA  : Raz LIMPUESTOSEGUNZONA
Local     Decimal LCOSTOFINAL         : Raz LCOSTOFINAL
Local     Decimal LCOSTOFINALYUAN         : Raz LCOSTOFINALYUAN
Local     Decimal LIMPUESTOLOCAL      : Raz LIMPUESTOLOCAL
Local     Decimal LIVA                : LIVA = 0.21

If !clalev([F:YTC1]) Then : Local File YTRANSPC   [F:YTC1] : Endif

  Call SP_PESO(LPESO,"0")

  # busca la tarifa activa de transportista para calcular sus impuestos
  Filter [F:YTC1] Where ACTFLG = 2 and STRDAT <= date$ and ENDDAT >= date$
  Read   [F:YTC1] First
  If !fstat Then
    LIMPUESTOPENINSULA     = ([F:YTC1]IMPPEN / 100)         # es porcentaje
    LIMPUESTOCANARIAS      = ([F:YTC1]IMPCAN / 100)         # es porcentaje
    LIMPUESTOADM           = ([F:YTC1]IMPADM / 100)         # es porcentaje
  Else
    LOK = 1
  Endif

  # calcula los impuestos
  # B21
  Case [M:SQH0]SALFCY
    When  "128" : LIMPUESTOSEGUNZONA = LIMPUESTOPENINSULA
    When  "138" : LIMPUESTOSEGUNZONA = LIMPUESTOCANARIAS
  Endcase
  LIMPUESTOSEGUNZONA = LIMPUESTOSEGUNZONA

  Call SP_COSTOFINAL(LCOSTOFINAL, "0")

  If [M:SQH2]QTY(GNUMLIN) <> 0 Then
    # B2
    PIMPUESTOGASTOS = (LCOSTOFINAL * (LIMPUESTOSEGUNZONA))
    Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   " Impuesto Aduanas = (" + num$(LCOSTOFINAL)+ "*" + num$(LIMPUESTOSEGUNZONA) + "%) = " + num$(PIMPUESTOGASTOS),PTRAZA )  From SPEYLIB0
#    If GUSER = "AIT07" Then : Infbox "B2 ="-num$(PIMPUESTOGASTOS) : Endif
# JC - 12/05/2020 #    PIMPUESTOGASTOS = arr((((LCOSTOFINAL * LIMPUESTOSEGUNZONA))/100) / [M:SQH2]QTY(GNUMLIN),0.0001)
  Else
    GESTADO = 2
  Endif

  # B1
  LIMPUESTOLOCAL = LCOSTOFINAL * (LIVA) # Para sacar los gastos administrativos, hay que sumer al costo el IVA al costo final, y de lo que resulte sacamos los Gastos
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   " Impuesto IVA (" + num$(LIVA) +"%) sobre costo = " + num$(LIMPUESTOLOCAL),PTRAZA)  From SPEYLIB0

  PIMPUESTOADMIN  =  (LIMPUESTOLOCAL + PIMPUESTOGASTOS) * (LIMPUESTOADM)

  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   " Gastos Administrativos = % de " + num$(LIMPUESTOADM*100) +" aplicado sobre Impuestos(21%) + Impuesto Aduana)= " + num$(PIMPUESTOADMIN
& ),PTRAZA)  From SPEYLIB0

  # If PIMPUESTOADMIN < 15 Then
  If PIMPUESTOADMIN < [F:YTC1]IMPMINGASADM Then
    PIMPUESTOADMIN = [F:YTC1]IMPMINGASADM # 15.000
    Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   " Gastos Administrativos inferiores a " + num$([F:YTC1]IMPMINGASADM) + ". Se asigna el mínimo.",PTRAZA)  From SPEYLIB0
  Endif
#  If GUSER = "AIT07" Then : Infbox "B1 ="-num$(PIMPUESTOADMIN) : Endif

  Filter [F:YTC1]

If  clalev([F:YTC1]) Then : Close Local File      [F:YTC1] : Endif

End

##############################################################CÁLCULO DEL BLOQUE BENEFICIO UNIDAD
# C
Subprog SP_BENEFICIOUNIDAD(PBENEFICIOUNIDAD, PTRAZA)
Variable  Decimal PBENEFICIOUNIDAD
Value Char  PTRAZA
Local Decimal LBENEFICIOTOTAL : Raz LBENEFICIOTOTAL
Local Decimal LCOSTOFINAL     : Raz LCOSTOFINAL
Local Decimal LGASTOS         : Raz LGASTOS
Local Decimal LMARGEN         : Raz LMARGEN

  Call SP_COSTOFINAL(LCOSTOFINAL,"0")
  Call SP_GASTOS(LGASTOS,"0")
  Call SP_MARGEN(LMARGEN,PTRAZA)

  If LMARGEN <> 0 Then
    # C1 = ((A + B) * C11)) / 100
    LBENEFICIOTOTAL   = ((LCOSTOFINAL + LGASTOS) * LMARGEN) / 100
# JC - 12/05/2020 #    LBENEFICIOTOTAL   = arr(((LCOSTOFINAL + LGASTOS) * [M:SQH2]QTY(GNUMLIN) * LMARGEN) / 100,0.0001)
    If LBENEFICIOTOTAL < 150 Then LBENEFICIOTOTAL = 150 : Endif

    PBENEFICIOUNIDAD  = LBENEFICIOTOTAL
# JC - 12/05/2020 #    PBENEFICIOUNIDAD  = arr(LBENEFICIOTOTAL / [M:SQH2]QTY(GNUMLIN),0.0001)
  Else
    PBENEFICIOUNIDAD  = 0
  Endif
#  If GUSER = "AIT07" Then : Infbox "C ="-num$(PBENEFICIOUNIDAD) : Endif
  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Importe benificio aplicado: " + num$(PBENEFICIOUNIDAD),PTRAZA)  From SPEYLIB0

End

##############################################################
# C11
Subprog SP_MARGEN(PMARGEN, PTRAZA)
Variable  Decimal PMARGEN
Value   Char      PTRAZA

  If !clalev([F:BPC0]) Then : Local File BPCUSTOMER [F:BPC0] : Endif
  Read [F:BPC0]BPC0 = [M:SQH0]BPCORD
  If !fstat Then
    PMARGEN = [F:BPC0]YMARGEN
  Else
    GESTADO = 1
  Endif

  Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , PTRAZA,   " Margen beneficio aplicado: " + num$([F:BPC0]YMARGEN),PTRAZA)  From SPEYLIB0
  If  clalev([F:BPC0]) Then : Close Local File      [F:BPC0] : Endif
End




