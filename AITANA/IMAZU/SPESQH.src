#    Endif
#    Affzo [M:SQH2]ITMREF(nolign-1)
#    zonsui = "[M:SQH2]SAU(nolign-1)"
#  # MAB.29092020.NEW
   [M:SQH2]NETPRI(GNUMLIN) = [M:SQH2]YGROPRI(GNUMLIN)
   Affzo [M:SQH2]NETPRI(GNUMLIN)
  Endif
End

