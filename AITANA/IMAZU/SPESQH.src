##############################################################
$INICRE_LIG


    [M:SQH2]ITMDES(nolign-1) = [M:SQH2]YDESCITM(nolign-1)
    Affzo [M:SQH2]ITMDES(nolign-1)
    [M:SQH2]GROPRI(nolign-1) = [M:SQH2]YGROPRI(nolign-1)
    Affzo [M:SQH2]GROPRI(nolign-1)



Return

##############################################################
$LIENS_LIG

    If [M:SQH2]ITMDES(nolign-1) = "" or [M:SQH2]ITMDES(nolign-1) = "BANDERA GENÉRICA" Then
      [M:SQH2]ITMDES(nolign-1) = [M:SQH2]YDESCITM(nolign-1)
      Affzo [M:SQH2]ITMDES(nolign-1)
    Endif
    If [M:SQH2]GROPRI(nolign-1) = 0 Then
      [M:SQH2]GROPRI(nolign-1) = [M:SQH2]YGROPRI(nolign-1)
      Affzo [M:SQH2]GROPRI(nolign-1)
    Endif



Return

##############################################################
$EXEBOUT
  Raz GNUMLIN, GESTADO

  Case BOUT
    When "g"
      Gosub GENERAARTICULOS_DESDEBOTON
      # para activar el modo 'Modificación'
      mkstat = 4
    When "p"  :
      Local Integer YESNO : YESNO = 1 # no
      Call OUINON("¿Estás seguro que deseas calcular el precio bruto de TODOS los artículos?", YESNO) From GESECRAN
      If YESNO = 2 Then
        For GNUMLIN = 0 To [M:SQH2]NBLIG-1
          If [M:SQH2]YASISTENTE = 2 Then
            Call SP_PRECIOFINALUNIDAD()
            Call AM_YGROPRI([M:SQH2]GROPRI(GNUMLIN))
            Grizo [M:SQH2]YCALCULAPB(GNUMLIN)
            nolign = GNUMLIN + 1
          Endif
        Next
        # para activar el modo 'Modificación'
        mkstat = 4
      Endif
  Endcase
Return

##############################################################
$INICRE
  If GCOMPRUEBA = 1 Then
    [M:YSQH1]YGENUSR = GUSER
    [M:YSQH1]YGENDAT = date$
    [M:YSQH1]YGENITM = 2
  Endif

Return

##############################################################
$INIMOD
  If GCOMPRUEBA = 1 Then
    [M:YSQH1]YGENUSR = GUSER
    [M:YSQH1]YGENDAT = date$
    [M:YSQH1]YGENITM = 2
  Endif
Return

##############################################################
$FIN
  # Kill GNUMLIN,
  Kill GESTADO, GTIPOITM, GPARAM1, GPARAM2
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$COMPRUEBAFLAGS
Local   Integer LNOL
  For LNOL = 0 To [M:SQH2]NBLIG-1
    # grisea el campo 'Asistente' si ya está marcado
    If [M:SQH2]YASISTENTE(LNOL) = 2 Then
      Grizo [M:SQH2]YASISTENTE(LNOL)
    Else
      Actzo [M:SQH2]YASISTENTE(LNOL)
    Endif

#    # grisea el campo 'Calcula precio' si ya está marcado
#    If [M:SQH2]YCALCULAPB(LNOL) = 2 Then
#      Grizo [M:SQH2]YCALCULAPB(LNOL)
#    Else
#      Actzo [M:SQH2]YCALCULAPB(LNOL)
#    Endif

    # grisea el campo 'Genera artículo' si ya está marcado
    If [M:SQH2]YCREAITM(LNOL) = 2 Then
      Grizo [M:SQH2]YCREAITM(LNOL)
    Else
      Actzo [M:SQH2]YCREAITM(LNOL)
    Endif

    If [M:SQH2]YASISTENTE(LNOL) = 2 and [M:SQH2]YFLGCRE(LNOL) = 1 Then
      GCOMPRUEBA = 0
    Endif
  Next
Kill LNOL
Return

##############################################################
$GENERAARTICULOS_DESDECAMPO

Local Integer LNOL
Local Char    LITMREF(100) : Raz LITMREF
Local Char    LORIITMREF(100) : Raz LORIITMREF
Local Decimal LCOSTO  : LCOSTO = 0 # PARA LA CREACIÓN DE TARIFA
Local Decimal LCOSTOYUAN : LCOSTOYUAN = 0
If !clalev([F:ITM2]) Then : Local File ITMMASTER [F:ITM2] : Endif

  LORIITMREF = [M:SQH2]ITMREF(nolign-1) # MAB.05062020.NEW

  LNOL = nolign-1
  If [M:SQH2]YASISTENTE(LNOL) = 2 and [M:SQH2]YFLGCRE(LNOL) <> 2 Then
    # busca si ya existe un artículo con esas características
    # SE COMENTA LA BUSQUEDA DEL ARTÍCULO A PETICIÓN DEL USUARIO
    # Call SEARCH_ITMLIN(LNOL,LITMREF) From SPEYLIB0 # MAB.01092020.OLD

    LITMREF = "" # MAB.01092020.NEW

    If LITMREF <> "" Then
      Call MESSAGE ("El artículo de la línea "+num$(LNOL+1)+" ya existe: '"+LITMREF+"'") From GESECRAN
      [M:SQH2]ITMREF(LNOL) = LITMREF
      Affzo [M:SQH2]ITMREF(LNOL)
    Else
      # crea un artículo con la descripción y los atributos indicados desde el botón de la ventana
      Global Char GITMREFPRE
      GNUMLIN = nolign-1
      If [M:SQH2]YTIPOIMP(GNUMLIN) = "01" and [M:SQH2]YRANGO(GNUMLIN) = "01" Then         # bandera estampada menor 1m2
        GTIPOITM = 1
      Elsif [M:SQH2]YTIPOIMP(GNUMLIN) = "01" and [M:SQH2]YRANGO(GNUMLIN) = "02" Then      # bandera estampada mayor 1m2
        GTIPOITM = 2
      Elsif [M:SQH2]YTIPOIMP(GNUMLIN) = "02" and [M:SQH2]YFABRICADA(GNUMLIN) = "01" Then  # bandera digital fabricada
        GTIPOITM = 3
      Elsif [M:SQH2]YTIPOIMP(GNUMLIN) = "02" and [M:SQH2]YFABRICADA(GNUMLIN) = "02" Then  # bandera digital subcontratada
        GTIPOITM = 4
      Endif

      Call SP_COSTO(LCOSTO,LCOSTOYUAN, "0") # PARA LA CREACIÓN DE LA TARIFA
      # HAY QUE CREAR LA TARIFA DE COMPRA CON EL PRECIO DEL VALOR UNITARIO +  LOS EXTRAS SIN IMPUESTOS Y SIN ENVIO
      # Infbox "Traza para desarrollo - AIT51 - LCOSTO: "  + num$(LCOSTO)
      Call GENITM(LNOL,LITMREF,LCOSTO, LCOSTOYUAN) From SPEYLIB0
      # Infbox "ARTICULO CREADO:" + GITMREFPRE
      #LITMREF = GITMREFPRE
      #GITMREFPRE = ''
      If LITMREF <> "" Then

        [M:SQH2]ITMREF(LNOL) = LITMREF
        Affzo [M:SQH2]ITMREF(LNOL)
        # llama a la función que compone la descripción completa y la guarda en tabla
        Call COMPONEDESC(LITMREF) From SPEYLIB0
        # se indica en el campo YFLGCRE que el artículo de esa línea ya se ha procesado
        [M:SQH2]YFLGCRE(LNOL) = 2
        Affzo [M:SQH2]YFLGCRE(LNOL)
        [M:SQH2]YCREAITM(LNOL) = 2
        Affzo [M:SQH2]YCREAITM(LNOL)
        GCOMPRUEBA = 1
      Else
        Call MESSAGE("Se ha producido un error durante la creación") From GESECRAN

        [M:SQH2]ITMREF(LNOL) = "BANDE9999" # MAB.05062020.NEW - Esto lo hago para que el campo no se quede vacío.
        Affzo [M:SQH2]ITMREF(LNOL)         # MAB.05062020.NEW
      Endif
    Endif
  Endif
  Grizo [M:SQH2]YCREAITM(LNOL)

 If  clalev([F:ITM2]) Then : Close Local File    [F:ITM2] : Endif
  Kill LNOL


Return

##############################################################
$GENERAARTICULOS_DESDEBOTON
Local Integer LNOL
Local Char    LITMREF(100) : Raz ITMREF
If !clalev([F:ITM2]) Then : Local File ITMMASTER [F:ITM2] : Endif

  Local Integer YESNO : YESNO = 1 # no
  Call OUINON("¿Estás seguro que deseas generar TODOS los artículos genéricos?", YESNO) From GESECRAN
  If YESNO = 2 Then
    For LNOL = 0 To [M:SQH2]NBLIG-1
      [M:SQH2]UPDFLG(LNOL) = 1
      [M:SQH2]CREFLG(LNOL) = 1
      If [M:SQH2]YASISTENTE(LNOL) = 2 and [M:SQH2]YFLGCRE(LNOL) <> 2 Then
        # busca si ya existe un artículo con esas características
        Call SEARCH_ITMLIN(LNOL,LITMREF) From SPEYLIB0
        If LITMREF <> "" Then
          Call MESSAGE ("El artículo de la línea "+num$(LNOL+1)+" ya existe: '"+LITMREF+"'") From GESECRAN
          [M:SQH2]ITMREF(LNOL) = LITMREF
          Affzo [M:SQH2]ITMREF(LNOL)
        Else
          # crea un artículo con la descripción y los atributos indicados desde el botón de la ventana
          Call GENITM(LNOL,LITMREF) From SPEYLIB0
          If LITMREF <> "" Then
            [M:SQH2]ITMREF(LNOL) = LITMREF
            Affzo [M:SQH2]ITMREF(LNOL)
            # llama a la función que compone la descripción completa y la guarda en tabla
            Call COMPONEDESC(LITMREF) From SPEYLIB0
            # se indica en el campo YFLGCRE que el artículo de esa línea ya se ha procesado
            [M:SQH2]YFLGCRE(LNOL) = 2
            Affzo [M:SQH2]YFLGCRE(LNOL)
            [M:SQH2]YCREAITM(LNOL) = 2
            Affzo [M:SQH2]YCREAITM(LNOL)
            Grizo [M:SQH2]YCREAITM(LNOL)
            GCOMPRUEBA = 1
          Else
            Call MESSAGE("Se ha producido un error durante la creación") From GESECRAN
          Endif
        Endif
      Endif
      Grizo [M:SQH2]YCREAITM(LNOL)
    Next
    [M:YSQH1]YGENUSR = GUSER
    [M:YSQH1]YGENDAT = date$
    [M:YSQH1]YGENITM = 2
    Affzo [M:YSQH1]5
  Endif

If  clalev([F:ITM2]) Then : Close Local File    [F:ITM2] : Endif
Kill LNOL
Return

