#  [M:SQH2]DISCRGREN5(NOL)   = [M:SQH2]DISCRGREN5(NOL-1)   : [M:SQH2]VAT1(NOL)         = [M:SQH2]VAT1(NOL-1)
#  [M:SQH2]VAT2(NOL)         = [M:SQH2]VAT2(NOL-1)         : [M:SQH2]VAT3(NOL)         = [M:SQH2]VAT3(NOL-1)
#  [M:SQH2]CLCAMT1(NOL)      = [M:SQH2]CLCAMT1(NOL-1)      : [M:SQH2]CLCAMT2(NOL)      = [M:SQH2]CLCAMT2(NOL-1)
#  [M:SQH2]YQTY(NOL)         = [M:SQH2]YQTY(NOL-1)         : [M:SQH2]STOMGTCOD(NOL)    = [M:SQH2]STOMGTCOD(NOL-1)
