#      Else
#        GESTADO = 1
#      Endif
#      Filter [F:YED1]
#    Else
#      GESTADO = 1
#    Endif
#    # ollados
#    If [M:SQH2]YOLLADOS(GNUMLIN) > 0 Then
#      Filter [F:YED1] Where CODTAR = [F:YEC1]CODTAR and COMPONENTE = "02"
