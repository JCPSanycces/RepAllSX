##############################################################
# A21112
Subprog SP_PESOUNITARIOEXTRAS(PPESOUNITARIOEXTRAS, PCANTIDAD, PANCHO, PALTO, PTRAZA)
Variable Decimal PPESOUNITARIOEXTRAS
Value Decimal PCANTIDAD, PANCHO, PALTO
Value Char PTRAZA

Local Integer LCUENTAFLAGS  : Raz LCUENTAFLAGS
Local Decimal LLARGO
Local Decimal LPESOEXTRA

If !clalev([F:YEC1]) Then : Local File YTCMPEXC   [F:YEC1] : Endif
If !clalev([F:YED1]) Then : Local File YTCMPEXD   [F:YED1] : Endif

  # obtención del valor de los componentes extra
  Filter [F:YEC1] Where ACTFLG = 2
  Read   [F:YEC1] First
  If !fstat Then
    # SI EL ARTÍCULO VIENE DEL ASISTENTE, BUSCAMOS PROPIEDADES EN LA TABLA TMP DE EXTRAS DEL PRESUPUESTO
    If [M:SQH2]YCODLIN(nolign-1) <> '' Then
      If !clalev([F:YTE0]) Then : Local File YTEXTPRE   [F:YTE0] : Endif # MAB.19062020.NEW
      Filter [F:YTE0] Where YCODLIN = [M:SQH2]YCODLIN(nolign-1)
    Else # SI EL ARTÍCULO VIENE DEL MAESTRO DE ARTICULOS, BUSCAMOS COMPONENTES EN LA TABLA DE EXTRAS DE ARTICULO
      If !clalev([F:YTE0]) Then : Local File YTEXTART   [F:YTE0] : Endif
      Filter [F:YTE0] Where ITMREF = [M:SQH2]ITMREF(nolign-1)
    Endif
    For [F:YTE0]
      Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Peso extra: "  + [F:YTE0]YEXTCOD  + " - " + func AFNC.TEXTRALAN("SPA","ATABDIV","LNGDES","2506", [F:YTE0]YEXTCOD),PTRAZA)  From SPEYLIB0
      Raz LCUENTAFLAGS
      LLARGO = 0
      If [F:YTE0]YEXTARR = 2 Then : LCUENTAFLAGS += 1 : LLARGO += PANCHO : Endif
      If [F:YTE0]YEXTABA = 2 Then : LCUENTAFLAGS += 1 : LLARGO += PANCHO : Endif
      If [F:YTE0]YEXTDER = 2 Then : LCUENTAFLAGS += 1 : LLARGO += PALTO  : Endif
      If [F:YTE0]YEXTIZQ = 2 Then : LCUENTAFLAGS += 1 : LLARGO += PALTO  : Endif
      Filter [F:YED1] Where CODTAR = [F:YEC1]CODTAR and COMPONENTE = [F:YTE0]YEXTCOD
      Read [F:YED1] First
      If !fstat Then
        # PPESOUNITARIOEXTRAS       += ([F:YED1]PESO / 1000) * LCUENTAFLAGS
        If LLARGO > 0 Then
          LPESOEXTRA       = ([F:YED1]PESO) * (LLARGO/100) * PCANTIDAD
          Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "1.Peso " + num$([F:YED1]PESO) + "*CANT_EXTRA(" + num$((LLARGO/100) * PCANTIDAD) + ")*CANT.BAND(" + num$(PCANTIDAD)+") =" + num$(
& LPESOEXTRA) + " gr" ,PTRAZA )  From SPEYLIB0
        Endif
      # SI ES UN EXTRA CON CANTIDAD Y/O CON LOGITUD DE EXTRA
      If [F:YTE0]YEXTCANT > 0 Then
          If [F:YTE0]YEXTLARGO > 0 Then
            # PPESOUNITARIOEXTRAS       += ([F:YED1]PESO / 1000) * [F:YTE0]YEXTCANT * ([F:YTE0]YEXTLARGO)
            LPESOEXTRA       = ([F:YED1]PESO) * [F:YTE0]YEXTCANT * ([F:YTE0]YEXTLARGO/100) * PCANTIDAD
            Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "2.Peso " + num$([F:YED1]PESO) + "*CANT_EXTRA(" + num$([F:YTE0]YEXTCANT * [F:YTE0]YEXTLARGO) + ")*CANT.BAND(" + num$(PCANTIDAD)+") =" +
& num$(
& LPESOEXTRA + " gr"),PTRAZA)  From SPEYLIB0

          Else
            # PPESOUNITARIOEXTRAS       += ([F:YED1]PESO / 1000) * [F:YTE0]YEXTCANT
            LPESOEXTRA       = ([F:YED1]PESO) * [F:YTE0]YEXTCANT * PCANTIDAD
            Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "3.Peso " + num$([F:YED1]PESO) + "*CANT_EXTRA(" + num$([F:YTE0]YEXTCANT) + ")*CANT.BAND(" + num$(PCANTIDAD)+") =" + num$(
& LPESOEXTRA) + " gr",PTRAZA)  From SPEYLIB0
          Endif
        Endif

      Else
        GESTADO = 1
      Endif
      # Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Total Peso extra: "  + num$(PPESOUNITARIOEXTRAS))  From SPEYLIB0

      Filter [F:YED1]

      PPESOUNITARIOEXTRAS += LPESOEXTRA
    Next


    # MAB.23062020.SOLD - CALCULO ANTIGUO DEL PESO
    # cinta de refuerzo
#    If [M:SQH2]YCINTAREF(GNUMLIN) = 2 Then
#      Raz LCUENTAFLAGS
