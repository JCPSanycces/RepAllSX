#  [M:SQH2]NETPRIATI(NOL)    = [M:SQH2]NETPRIATI(NOL-1)    : [M:SQH2]OCNPRNBOM(NOL)    = [M:SQH2]OCNPRNBOM(NOL-1)
#  [M:SQH2]NDEPRNBOM(NOL)    = [M:SQH2]NDEPRNBOM(NOL-1)    : [M:SQH2]INVPRNBOM(NOL)    = [M:SQH2]INVPRNBOM(NOL-1)
