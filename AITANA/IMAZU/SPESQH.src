######################################################################################
#**
#* Proceso que actualiza la cantidad de los extras a la nueva cantidad indicada, si coincide con la cantidad
#* de banderas solicitadas
#* @pycodlin
#* @pitmref
#* @pqtyold
#* @pqtynew
#*!
Subprog MODIFICAR_CANTIDAD_EXTRAS(PYCODLIN, PITMREF, PQTYOLD,PQTYNEW)
  Value Char PYCODLIN
  Value Decimal PQTYOLD, PQTYNEW

  If PQTYOLD <> PQTYNEW Then

  # SI EL ARTÍCULO VIENE DEL ASISTENTE, BUSCAMOS PROPIEDADES EN LA TABLA TMP DE EXTRAS DEL PRESUPUESTO
    If PYCODLIN <> '' Then
      If !clalev([F:YTE1]) Then : Local File YTEXTPRE   [F:YTE1] : Endif # MAB.19062020.NEW
      # Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Extras de la línea del presupuesto",PTRAZA) From SPEYLIB0
      Filter [F:YTE1] Where YCODLIN = PYCODLIN
    Else # SI EL ARTÍCULO VIENE DEL MAESTRO DE ARTICULOS, BUSCAMOS COMPONENTES EN LA TABLA DE EXTRAS DE ARTICULO
      #Call TRAZA_PRECIO([M:SQH2]YCODLIN(nolign-1) , "",   "Extras del artículo " + [M:SQH2]ITMREF(nolign-1),PTRAZA) From SPEYLIB0
      If !clalev([F:YTE1]) Then : Local File YTEXTART   [F:YTE1] : Endif
      Filter [F:YTE1] Where ITMREF = PITMREF
    Endif

    For [F:YTE1]
      If [F:YTE1]YEXTCANT = PQTYOLD Then
         Trbegin [F:YTE1]
         [F:YTE1]YEXTCANT = PQTYNEW
         Rewrite [F:YTE1]
          If !fstat Then
            Commit
          Else
            Rollback
          Endif
       Endif
    Next


    Close Local File [YTE1]

  Endif



End

######################################################################################
## Etiqueta añadida por el supervisor (pantalla SQH2) 16/11/2020 12:53:07 (AIT51)
######################################################################################
Subprog C_QTY(VALEUR)
Variable Decimal VALEUR
  # CONTROLAMOS SI SE MODIFICA LA CANTIDAD PARA REPLICARLO EN LOS EXTRAS QUE LLEVEN ESTA MISMA CANTIDAD
  If VALEUR <> [M:SQH2]QTY(nolign-1) Then
    Call MODIFICAR_CANTIDAD_EXTRAS([M:SQH2]YCODLIN(nolign-1), [M:SQH2]ITMREF(nolign-1), [M:SQH2]QTY(nolign-1),VALEUR)
  Endif

End


