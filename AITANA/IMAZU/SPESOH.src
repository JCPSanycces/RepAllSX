#<AdxTL>@(#)0.0.0.0 $Revision$

$ACTION
Case ACTION
  When "CREATION"      : Gosub CREATION
  When Default
Endcase

Return


##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$CREATION


  # Infbox [F:SOH]SQHNUM + " - " + [F:SOH]SOHNUM
  If !clalev([F:YOBJ]) Then : Local File AOBJTXT [YOBJ] : Endif
  If !clalev([F:YOBJ2]) Then : Local File AOBJTXT [YOBJ2] : Endif

  If [F:SOH]SQHNUM <> '' Then
    Filter [F:YOBJ] Where ABREV = 'SQH' and IDENT1 = [F:SOH]SQHNUM
    For [F:YOBJ]
       #Trbegin [YOBJ2]
       [F:YOBJ2]ABREV = 'SOH'
       [F:YOBJ2]IDENT1 = [F:SOH]SOHNUM
       [F:YOBJ2]IDENT3 = [F:YOBJ]IDENT3
       [F:YOBJ2]TYPDOC = [F:YOBJ]TYPDOC
       [F:YOBJ2]NAM    = [F:YOBJ]NAM
       [F:YOBJ2]CAT    = [F:YOBJ]CAT
       Write [YOBJ2]
       #If !fstat Then
       # Commit
       #Else
       # Rollback
       #Endif
    Next
  Endif
  Close Local File [YOBJ]
  Close Local File [YOBJ2]


Return


######################################################################################
Subprog AS_YCHKBOCOK(VALEUR)
Variable Integer VALEUR

If [M:SOH4]YCHKBOCENV(nolign-1) <> 2
  Grizo [M:SOH4]YCHKBOCOK(nolign-1)
  Affzo [M:SOH4]YCHKBOCOK(nolign-1)
Endif

End


######################################################################################
Subprog AS_YCHKBOCENV(VALEUR)
Variable Integer VALEUR

If [M:SOH4]YCHKBOCENV(nolign-1) <> 2
  Grizo [M:SOH4]YCHKBOCENV(nolign-1)
  Affzo [M:SOH4]YCHKBOCENV(nolign-1)
Endif

End


