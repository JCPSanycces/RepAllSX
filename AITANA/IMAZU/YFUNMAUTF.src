#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "TRTAUTFMI" : Gosub TRTAUTFMI
Endcase
Return


#############################################
$TRTAUTFMI
# Si la condición de pago es TRF-1 y no he cobrado el 40%, no permito la generación del pedido de compra
If [F:SOH]PTE = "TRF-1" and 1=2
    If !clalev([PP1]) : Local File GACCDUDATE [PP1] : Endif

    Filter [PP1] Where [PP1]NUM = [F:SOH]SOHNUM Order By [PP1]DUDLIG Asc
    Read [PP1] First # Reviso el primer vencimiento
    If fstat = 0
      If [PP1]PAYCUR < [PP1]AMTCUR
        WMSG=[F:SOH]SOHNUM - " OF no generada. Pendiente el cobro del 40%"
        Call ECR_TRACE(WMSG,1) From GESECRAN
        GPE = 1
      Endif
    Endif
    Filter [PP1]

    Close Local File [PP1]

Endif
Return

