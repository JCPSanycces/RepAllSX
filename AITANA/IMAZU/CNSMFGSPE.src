#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "SETBOUT"    :   Gosub SETBOUT
Endcase
Return

#############################################
$SETBOUT

# 04112020 - MS - Añadir campos: ----------------------------------------------
#                 - Material
#                 - Superficie Bandera
#                 - Fecha Expedición
#                 - Siguiente Operación
If !clalev([YVIOS]) : Local File YITMOFSOH [YVIOS] : Endif

Local Integer LCON

For LCON = 0 To [M:LOF2]NBLIG-1
  Read [YVIOS]YVIOS0 = [M:LOF2]MFGNUM(LCON);[M:LOF2]ITMREF(LCON)

  If !fstat
    [M:LOF2]YMATERIAL(LCON)    = [YVIOS]YMATERIAL
    [M:LOF2]YMATERIALDES(LCON) = [YVIOS]YMATERIALDES
    [M:LOF2]YSUPM2(LCON)       = ar2([YVIOS]YSUPM2)
    [M:LOF2]YSHIDAT(LCON)      = [YVIOS]SHIDAT
    [M:LOF2]YOPENUM(LCON)      = [YVIOS]OPENUM
    [M:LOF2]YROODES(LCON)      = [YVIOS]ROODES
    [M:LOF2]YTIPOSEG(LCON)     = [YVIOS]TIPOSEG

    Affzo [M:LOF2]YMATERIAL(LCON)
    Affzo [M:LOF2]YMATERIALDES(LCON)
    Affzo [M:LOF2]YSUPM2(LCON)
    Affzo [M:LOF2]YSHIDAT(LCON)
    Affzo [M:LOF2]YOPENUM(LCON)
    Affzo [M:LOF2]YROODES(LCON)
    Affzo [M:LOF2]YTIPOSEG(LCON)
  Endif
Next

[M:LOF1]MTKFLGSTR = [M:LOF1]YMFGTRKFLG
[M:LOF1]MTKFLGEND = [M:LOF1]YMFGTRKFLG
[M:CLOF]MTKFLGSTR = [M:LOF1]YMFGTRKFLG
[M:CLOF]MTKFLGEND = [M:LOF1]YMFGTRKFLG


Affzo [M:LOF1]MTKFLGSTR
Affzo [M:LOF1]MTKFLGEND

Close Local File [YVIOS]

# -----------------------------------------------------------------------------

Return

######################################################################################
Subprog AM_YMFGTRKFLG(VALEUR)
Variable Integer VALEUR

[M:LOF1]MTKFLGSTR = VALEUR
[M:LOF1]MTKFLGEND = VALEUR

Affzo [M:LOF1]MTKFLGSTR
Affzo [M:LOF1]MTKFLGEND

End


######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla CONSMFG1) 08/11/2020 19:30:32 (AIT50)
######################################################################################
Subprog AM_MFGSTASTR(VALEUR)
Variable Integer VALEUR

[M:LOF1]MFGSTAEND = VALEUR
Affzo [M:LOF1]MFGSTAEND

End

Subprog AS_MFGSTAEND(VALEUR)
Variable Integer VALEUR

VALEUR = [M:LOF1]MFGSTASTR

End


######################################################################################

