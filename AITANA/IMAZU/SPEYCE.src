#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "FILTRE"     : Gosub FILTRE
  When "LIENS"      : Gosub LIENS
  When "CREATION"   : Gosub CREATION
  When "MODIF"      : Gosub MODIF
  When "ANNULE"     : Gosub ANNULE
  When "APRES_CRE"  : Gosub APRES_CRE
  When "APRES_MOD"  : Gosub APRES_MOD
  When "INICRE_LIG" : Gosub INICRE_LIG
  When "DEFLIG"     : Gosub DEFLIG
  When "DEBUT"      : Gosub DEBUT
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
################################################################
$OUVRE
  Gosub DECLARE From TABLEAUX
Return

################################################################
$FILTRE
  Default File [YCEC]
Return

################################################################
$LIENS
  Gosub LIENS From TABLEAUX
Return

################################################################
$CREATION
  Gosub CREATION From TABLEAUX
Return

################################################################
$MODIF
  Gosub MODIF From TABLEAUX
Return

################################################################
$ANNULE
  Gosub ANNULE From TABLEAUX
Return

################################################################
$APRES_CRE
  Gosub LIENS From TABLEAUX
Return

################################################################
$APRES_MOD
  Gosub LIENS From TABLEAUX
Return

################################################################
$INICRE_LIG
  [F:YCED]CODTAR = [M:YCE0]CODTAR
Return

################################################################
$DEFLIG
  Default Mask [YCE1]   # pantalla de las líneas
  Default File [YCED]   # abreviatura de la tabla de las líneas

  # criterios de filtrado
  CRIT    = 'CODTAR="'+[M:YCE0]CODTAR+'"'      # campo común de las tablas + pantalla cabecera (con el campo común)
  FICLIG  = "YTCMPEXD"                         # nombre de la tabla de detalle
  ABLIG   = "YCED"                             # abreviatura de la tabla de detalle
  ZONLIG  = "LINTAR"                           # campo contador de línea en la tabla detalle
Return

################################################################
$DEBUT
  zonsui = "[M:YCE0]CODTAR"
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Después de modificar el campo 'Fecha inicio validez'
######################################################################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
  If [M:YCE0]ENDDAT <> [00/00/0000] and VALEUR > [M:YCE0]ENDDAT Then
    Call ERREUR("Fecha inicio no puede ser posterior a Fecha fin") From GESECRAN
    mkstat = 2
  Endif
End

######################################################################################
## Después de modificar el campo 'Fecha fin validez'
######################################################################################
Subprog AM_ENDDAT(VALEUR)
Variable Date    VALEUR
  If [M:YCE0]STRDAT <> [00/00/0000] and VALEUR < [M:YCE0]STRDAT Then
    Call ERREUR("Fecha inicio no puede ser posterior a Fecha fin") From GESECRAN
    mkstat = 2
  Endif
End

######################################################################################
## Después de modificar el campo 'Componente'
######################################################################################
Subprog AM_COMPONENTE(VALEUR)
Variable Char    VALEUR()
  # control para que no repita códigos
  Call UNICITE(VALEUR,[M:YCE1]COMPONENTE(0..[M:YCE1]NBLIG-1)) From OBJDIV
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

