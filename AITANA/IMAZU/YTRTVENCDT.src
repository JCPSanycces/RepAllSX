#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "CALCREDIT"  :  Gosub CALCREDIT
Endcase
Return

############################################################
$CALCREDIT
# Si el pedido de venta queda Rebasado Encurso, lo paso a bloqueado
# CDTSTA = 1 -> OK
# CDTSTA = 2 -> bloqueado
# CDTSTA = 3 -> rebasado en curso
# CDTSTA = 4 -> anticipo no abonado
If GFONCTION ="GESSOH"
  # Primero limpio el valor del campo de motivo de bloqueo
  [M:SOH1]YMOTBLOCRE = ''
  Affzo [M:SOH1]YMOTBLOCRE

  # Si el cliente está control = Libre, no hago este segundo control de vencimientos
  #If [F:BPC]OSTCTL = 2 : Return : Endif

  # Si el estado es ya de Bloqueado -> muestro información
  If CDTSTA = 2
    [M:SOH1]YMOTBLOCRE = 'Cliente bloqueado'
    Affzo [M:SOH1]YMOTBLOCRE
  Endif

  # Si el estado es de Rebasado el en curso -> bloqueo el pedido
  If CDTSTA = 3
    CDTSTA = 2
    [M:SOH1]YMOTBLOCRE = 'Rebasado en curso cliente'
    Affzo [M:SOH1]YMOTBLOCRE
  Endif


  # Si no está bloqueado y la condición de pago es TRF-1, compruebo si se ha realizado el anticipo del 40%
  If CDTSTA <> 2 and MAJ = 2 and [M:SOH2]UNL <> 2 and [M:SOH3]PTE = "TRF-1"
    If !clalev([PP1]) : Local File GACCDUDATE [PP1] : Endif

    Filter [PP1] Where [PP1]NUM = NUMPIE Order By [PP1]DUDLIG Asc
    Read [PP1] First # Reviso el primer vencimiento
    If fstat = 0
      If [PP1]PAYCUR < [PP1]AMTCUR
        CDTSTA = 4
        [M:SOH1]YMOTBLOCRE = 'Pendiente el cobro del 40%'
        Affzo [M:SOH1]YMOTBLOCRE
      Endif
    Endif
    Filter [PP1]
    # Si el primer vencimiento está OK (CDTSTA <> 4) compruebo ahora el segundo
    If CDTSTA <> 4
      Filter [PP1] Where [PP1]NUM = NUMPIE Order By [PP1]DUDLIG Asc
      Read [PP1] Last # Reviso el segundo vencimiento, si es que el primero está ya pagado
      If fstat = 0
        If [PP1]PAYCUR < [PP1]AMTCUR
          CDTSTA = 2
          [M:SOH1]YMOTBLOCRE = 'Pendiente el cobro del 60%'
          Affzo [M:SOH1]YMOTBLOCRE
        Endif
      Endif
      Filter [PP1]
    Endif

    Close Local File [PP1]
  Endif

  # Si no está bloqueado, compruebo si hay un impago; si lo hay, también bloqueo, cuando es cliente
  If CDTSTA <> 2 and MAJ = 2 and [M:SOH2]UNL <> 2
    If !clalev([PP1]) : Local File GACCDUDATE [PP1] : Endif

    For [PP1] Where [PP1]BPRPAY = CLI and [PP1]DUDDAT < date$ and [PP1]BPRTYP = 1 and [PP1]PAYCUR < [PP1]AMTCUR and [PP1]SNS > 0
      CDTSTA = 2
      [M:SOH1]YMOTBLOCRE = 'Cliente con impago (' + [PP1]NUM + ')'
      Affzo [M:SOH1]YMOTBLOCRE
      Break
    Next

    Close Local File [PP1]
  Endif

Endif
Return

