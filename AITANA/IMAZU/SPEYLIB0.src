#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################################
#################################   SUBPROGRAMAS  #################################
###################################################################################
#######################
#**
#* devuelve el siguiente número de contador para el código de contador indicado en PCDGCONT
#*
#* @param PCDGCONT  > código del contador
#* @param PSTRDAT   > fecha inicial
#* @param PSEQCODE  > devuelve número de contador
#*!
Subprog GENNUMBER(PCDGCONT,PSTRDAT,PSEQCODE)
Value     Char PCDGCONT
Value     Date PSTRDAT
Variable  Char PSEQCODE
Local Integer STAT
  Call NUMERO(PCDGCONT, nomap, PSTRDAT, "null", PSEQCODE, STAT) From SUBANM
End

#####################################################################
#**
#* Genera los artículos en el sistema a partir de los genéricos del presupuesto
#*
#* @param PNOL       > número de la línea
#* @param PITMREF    > código de artículo
#*!
Subprog GENITM(PNOL,PITMREF, PCOSTO, PCOSTOYUAN)
Value     Integer PNOL
Variable  Char    PITMREF
Value     Decimal PCOSTO, PCOSTOYUAN

Local   Char LDIRIMPORT(250) : Raz LDIRIMPORT : LDIRIMPORT = filpath("IMPORT_EXPORT\GENITM\Mov_ppto","","")
Global  Char LFILE_W(200) : Raz LFILE_W : LFILE_W = "\GeneracionArticulos"
Local   Char LFECHA(10), LHORA(10) : Raz LFECHA, LHORA
Local   Char LSEP(1) : Raz LSEP : LSEP = ";"  # separador
Local   Char LPATHDESE(255) : Raz LPATHDESE : LPATHDESE = filpath("IMPORT_EXPORT\GENITM\Error_ppto","","")    # ruta de la carpeta con errores
Local   Char LPATHDESS(255) : Raz LPATHDESS : LPATHDESS = filpath("IMPORT_EXPORT\GENITM\Success_ppto","","")  # ruta de la carpeta de finalizados con éxito
Local   Char LITMREF(255),LTCLCOD(255),LITMDES1(30),LITMDES2(30),LITMDES3(30) : Raz LITMREF,LTCLCOD,LITMDES1,LITMDES2,LITMDES3

  Local Integer STAT

  Raz PITMREF

  Call GENERA_TRAZA("00", "Generación Art. desde Presupuesto", "")


  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
  LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

  LFILE_W = LDIRIMPORT + LFILE_W + "_" + LFECHA + LHORA + ".txt"

  Call GENERA_TRAZA("00", "", LFILE_W)

  # borramos el fichero si existe...
  If filinfo(LFILE_W, 7) > 0 Then
    System "ae_rm " + LFILE_W
  Endif

  mkstat = 0 : fstat = 0 : GERRTRACE = 0
  Sleep 1

  If !GSERVEUR Then
    Call OUVRE_TRACE("Generación de artículos") From LECFIC
  Endif

  # abrir el fichero para escritura
  Gosub OPEN_FILE_W

  # pantalla detalles
  Local Char    LDETALLES(250)(1..)
  # pantalla extras
  Local Char    LEXTRAS(250)(1..)

  # pantalla detalles
  LDETALLES(1)  = func  GET_CATEGORIA(num$([M:SQH2]YTIPOIMP(PNOL)), num$([M:SQH2]YFABRICADA(PNOL)))  # "YBP" #
  LDETALLES(2)  = ""
  Call LIMPIA_STR(left$([M:SQH2]YDESCITM(PNOL),30),LDETALLES(3))
  Call LIMPIA_STR(mid$([M:SQH2]YDESCITM(PNOL),31,30),LDETALLES(4))
  Call LIMPIA_STR(mid$([M:SQH2]YDESCITM(PNOL),61,30),LDETALLES(5))
  LDETALLES(6)  = num$([M:SQH2]YTIPOIMP(PNOL))
  LDETALLES(7)  = num$([M:SQH2]YMATERIAL(PNOL))     : LDETALLES(8)  = [M:SQH2]YALTO(PNOL)               : LDETALLES(9)  = [M:SQH2]YANCHO(PNOL)
  LDETALLES(10) = num$([M:SQH2]YNUMCOLORES(PNOL))   : LDETALLES(11) = num$([M:SQH2]YPESPUNTE(PNOL))     : LDETALLES(12) = num$([M:SQH2]YCONFNORMAL(PNOL))
  LDETALLES(13) = num$([M:SQH2]YCONFFLY(PNOL))      : LDETALLES(14) = num$([M:SQH2]YFABRICADA(PNOL))    : LDETALLES(15) = [M:SQH2]YREFERENCIA(PNOL)
  LDETALLES(16) = num$([M:SQH2]YRANGO(PNOL))        : LDETALLES(17) = [M:SQH2]YDESCITM(PNOL)
  # pantalla extras
  # MAB.19062020.SOLD
#  LEXTRAS(1)    = num$([M:SQH2]YCINTAREF(PNOL))     : LEXTRAS(2)    = num$([M:SQH2]YCINTAREFAR(PNOL))   : LEXTRAS(3)    = num$([M:SQH2]YCINTAREFAB(PNOL))
#  LEXTRAS(4)    = num$([M:SQH2]YCINTAREFIZ(PNOL))   : LEXTRAS(5)    = num$([M:SQH2]YCINTAREFDE(PNOL))   : LEXTRAS(6)    = num$([M:SQH2]YOLLADOS(PNOL))
#  LEXTRAS(7)    = num$([M:SQH2]YANILLAS(PNOL))      : LEXTRAS(8)    = num$([M:SQH2]YCINTAATAR(PNOL))    : LEXTRAS(9)    = num$([M:SQH2]YLARGO(PNOL))
#  LEXTRAS(10)   = num$([M:SQH2]YMNGVAINA(PNOL))     : LEXTRAS(11)   = num$([M:SQH2]YMNGVAINAAR(PNOL))   : LEXTRAS(12)   = num$([M:SQH2]YMNGVAINAAB(PNOL))
#  LEXTRAS(13)   = num$([M:SQH2]YMNGVAINAIZ(PNOL))   : LEXTRAS(14)   = num$([M:SQH2]YMNGVAINADE(PNOL))   : LEXTRAS(15)   = num$([M:SQH2]YCNTMSTL(PNOL))
#  LEXTRAS(16)   = num$([M:SQH2]YCNTMSTLQTY(PNOL))   : LEXTRAS(17)   = num$([M:SQH2]YABRPVC(PNOL))       : LEXTRAS(18)   = num$([M:SQH2]YABRPVCQTY(PNOL))
#  LEXTRAS(19)   = num$([M:SQH2]YCINTASIL(PNOL))     : LEXTRAS(20)   = num$([M:SQH2]YCINTASILAR(PNOL))   : LEXTRAS(21)   = num$([M:SQH2]YCINTASILAB(PNOL))
#  LEXTRAS(22)   = num$([M:SQH2]YCINTASILIZ(PNOL))   : LEXTRAS(23)   = num$([M:SQH2]YCINTASILDE(PNOL))   : LEXTRAS(24)   = num$([M:SQH2]YPALPL256(PNOL))
#  LEXTRAS(25)   = num$([M:SQH2]YPALPL306(PNOL))     : LEXTRAS(26)   = num$([M:SQH2]YPALPL406(PNOL))     : LEXTRAS(27)   = num$([M:SQH2]YPALPL408(PNOL))
#  LEXTRAS(28)   = num$([M:SQH2]YPALPL608(PNOL))     : LEXTRAS(29)   = num$([M:SQH2]YPALPL10010(PNOL))   : LEXTRAS(30)   = num$([M:SQH2]YPALPL12012(PNOL))
#  LEXTRAS(31)   = num$([M:SQH2]YPALMA408(PNOL))     : LEXTRAS(32)   = num$([M:SQH2]YPALMA608(PNOL))     : LEXTRAS(33)   = num$([M:SQH2]YPALMA100(PNOL))
#  LEXTRAS(34)   = num$([M:SQH2]YPALMA150(PNOL))     : LEXTRAS(35)   = num$([M:SQH2]YMASTIL44(PNOL))     : LEXTRAS(36)   = num$([M:SQH2]YMASTIL50(PNOL))
#  LEXTRAS(37)   = num$([M:SQH2]YEMBOLSADO(PNOL))    : LEXTRAS(38)   = num$([M:SQH2]YVELCRO(PNOL))       : LEXTRAS(39)   = num$([M:SQH2]YVELCROAR(PNOL))
#  LEXTRAS(40)   = num$([M:SQH2]YVELCROAB(PNOL))     : LEXTRAS(41)   = num$([M:SQH2]YVELCROIZ(PNOL))     : LEXTRAS(42)   = num$([M:SQH2]YVELCRODE(PNOL))
#  LEXTRAS(43)   = num$([M:SQH2]YSILICON(PNOL))      : LEXTRAS(44)   = num$([M:SQH2]YSILICONAR(PNOL))    : LEXTRAS(45)   = num$([M:SQH2]YSILICONAB(PNOL))
#  LEXTRAS(46)   = num$([M:SQH2]YSILICONIZ(PNOL))    : LEXTRAS(47)   = num$([M:SQH2]YSILICONDE(PNOL))    : LEXTRAS(48)   = num$([M:SQH2]YOLLADOSLONA(PNOL))
#  LEXTRAS(49)   = num$([M:SQH2]YREFLONA(PNOL))      : LEXTRAS(50)   = num$([M:SQH2]YREFLONAAR(PNOL))    : LEXTRAS(51)   = num$([M:SQH2]YREFLONAAB(PNOL))
#  LEXTRAS(52)   = num$([M:SQH2]YREFLONAIZ(PNOL))    : LEXTRAS(53)   = num$([M:SQH2]YREFLONADE(PNOL))
  # MAB.19062020.EOLD

  Wrseq "I" + LSEP + LDETALLES(1) + LSEP + [M:SQH2]YCODLIN(PNOL)  + LSEP + LDETALLES(2)   + LSEP + LDETALLES(3)   + LSEP + LDETALLES(4)   + LSEP + LDETALLES(5)   + LSEP + LDETALLES(6) + LSEP +
& LDETALLES(7)
&           + LSEP + LDETALLES(8)   + LSEP + LDETALLES(9)   + LSEP + LDETALLES(10)  + LSEP + LDETALLES(11)  + LSEP + LDETALLES(12)  + LSEP + LDETALLES(13)
&           + LSEP + LDETALLES(14)  + LSEP + LDETALLES(15)  + LSEP + LDETALLES(16)  + LSEP + LDETALLES(17)  Using [YIMP_W]
  # MAB.19062020.sOLD
#&           + LSEP + LEXTRAS(1)   + LSEP + LEXTRAS(2)   + LSEP + LEXTRAS(3)   + LSEP + LEXTRAS(4)   + LSEP + LEXTRAS(5)   + LSEP + LEXTRAS(6)   + LSEP + LEXTRAS(7)
#&           + LSEP + LEXTRAS(8)   + LSEP + LEXTRAS(9)   + LSEP + LEXTRAS(10)  + LSEP + LEXTRAS(11)  + LSEP + LEXTRAS(12)  + LSEP + LEXTRAS(13)  + LSEP + LEXTRAS(14)
#&           + LSEP + LEXTRAS(15)  + LSEP + LEXTRAS(16)  + LSEP + LEXTRAS(17)  + LSEP + LEXTRAS(18)  + LSEP + LEXTRAS(19)  + LSEP + LEXTRAS(20)  + LSEP + LEXTRAS(21)
#&           + LSEP + LEXTRAS(22)  + LSEP + LEXTRAS(23)  + LSEP + LEXTRAS(24)  + LSEP + LEXTRAS(25)  + LSEP + LEXTRAS(26)  + LSEP + LEXTRAS(27)  + LSEP + LEXTRAS(28)
#&           + LSEP + LEXTRAS(29)  + LSEP + LEXTRAS(30)  + LSEP + LEXTRAS(31)  + LSEP + LEXTRAS(32)  + LSEP + LEXTRAS(33)  + LSEP + LEXTRAS(34)  + LSEP + LEXTRAS(35)
#&           + LSEP + LEXTRAS(36)  + LSEP + LEXTRAS(37)  + LSEP + LEXTRAS(38)  + LSEP + LEXTRAS(39)  + LSEP + LEXTRAS(40)  + LSEP + LEXTRAS(41)  + LSEP + LEXTRAS(42)
#&           + LSEP + LEXTRAS(43)  + LSEP + LEXTRAS(44)  + LSEP + LEXTRAS(45)  + LSEP + LEXTRAS(46)  + LSEP + LEXTRAS(47)  + LSEP + LEXTRAS(48)  + LSEP + LEXTRAS(49)
#&           + LSEP + LEXTRAS(50)  + LSEP + LEXTRAS(51)  + LSEP + LEXTRAS(52)  + LSEP + LEXTRAS(53) Using [YIMP_W]
# MAB.19062020.EOLD

  # MAB.08072020.NEW - PROVEEDOR ARTÍCULO
  Local Char LPROVEEDOR
  Raz LPROVEEDOR

  LPROVEEDOR = func GET_PROVEEDOR(num$([M:SQH2]YTIPOIMP(PNOL)), num$([M:SQH2]YFABRICADA(PNOL)), num$([M:SQH2]YRANGO(PNOL)) )
  If LPROVEEDOR <> '' Then
    Wrseq "P" + LSEP + LPROVEEDOR + LSEP + "2" + LSEP + "1" + LSEP +  LPROVEEDOR+"_"+LFECHA+LHORA  + LSEP + "2" Using [YIMP_W]
  Endif
  # MAB.08072020.NEW - PROVEEDOR ARTÍCULO

  Gosub CLOSE_FILE_W
  #Call IMPORTSIL("YITMBA",LFILE_W) From GIMPOBJ                              # lanza la importación
  #Call IMPORTSIL("YITMBA2",LFILE_W) From GIMPOBJ                              # lanza la importación
  Call IMPORTSIL("YITMBA3",LFILE_W) From GIMPOBJ                              # lanza la importación
  If !GSERVEUR Then
    Call FERME_TRACE From LECFIC
  Endif


  Call GENERA_TRAZA("00", "", "Fin creación. Nº Errores: " + num$(GERRTRACE))

  If (fstat <> 0 and fstat <> 4) or GERRTRACE <> 0 Then                      # si se produce error de importación...
    Call MOVE(LFILE_W+".err",LPATHDESE,STAT) From ORDSYS                     # mueve el fichero .err con errores en la importación
    System "ae_rm " + LFILE_W                                                # borra el fichero .txt que ha dado errores
  Else
    Call MOVE(LFILE_W,LPATHDESS,STAT) From ORDSYS                            # mueve el fichero .txt con importación exitosa

    # Call SEARCH_ITM(LDETALLES,LEXTRAS,PITMREF) # MAB.19062020.OLD

    Call SEARCH_ITMLIN(PNOL,PITMREF) # MAB.19062020.NEW
    If GITMREFPRE <> '' Then
      PITMREF = GITMREFPRE
      Kill GITMREFPRE
    Endif

    Call GENERA_TRAZA("00", "", "Creación de artículo planta: " + PITMREF)
    # CREAMOS EL ARTÍCULO EN TODAS LAS PLANTAS
    If !clalev([ZFCY]) Then : Local File FACILITY [ZFCY] : Endif
    Read [ZFCY]FCY0=[M:SQH0]SALFCY
    If !fstat Then
      #Infbox [F:ZFCY]LEGCPY
      Local Char LCPY
      LCPY = [F:ZFCY]LEGCPY
      #Filter [F:ZFCY] Where LEGCPY = [F:ZFCY]LEGCPY and FCY <> [M:SQH0]SALFCY
      For [F:ZFCY] Where LEGCPY = LCPY #and FCY <> [M:SQH0]SALFCY
        #Infbox [F:ZFCY]FCY
        #Call GENERA_TRAZA("00", "", "Creación de artículo planta: " + PITMREF + " - PLANTA: " + [F:ZFCY]FCY)
        Call GENITF(PITMREF,[F:ZFCY]FCY, num$([M:SQH2]YTIPOIMP(PNOL)),num$([M:SQH2]YFABRICADA(PNOL)),LPROVEEDOR)
      Next
    Endif
    Close Local File [ZFCY]
    #Call GENITF(PITMREF,[M:SQH0]SALFCY, num$([M:SQH2]YTIPOIMP(PNOL)),num$([M:SQH2]YFABRICADA(PNOL)),LPROVEEDOR)


    Call GENTARIFAITM(PITMREF,[M:SQH0]SALFCY, PCOSTO, PCOSTOYUAN)

    Call GENESTRUCTURAITM(PITMREF,[M:SQH0]SALFCY,PNOL)


    # si el artículo es de fabricación e Imazu

  Endif
  mkstat = 0 : fstat = 0 : GOK = 1 : GERRTRACE = 0

End


#####################################################################
#**
#* Genera los tarifa para el artículo que estamos creando en el sistema a partir de los genéricos del presupuesto
#*
#* @param PNOL       > número de la línea
#* @param PITMREF    > código de artículo
#*!
Subprog GENTARIFAITM(PITMREF, PFCY, PCOSTO, PCOSTOYUAN)
Value     Integer PNOL
Value     Char    PITMREF
Value     Decimal PCOSTO, PCOSTOYUAN

Local   Char LDIRIMPORT(250) : Raz LDIRIMPORT : LDIRIMPORT = filpath("IMPORT_EXPORT\GENITM\Mov_ppto","","")
Global  Char LFILE_W(200) : Raz LFILE_W : LFILE_W = "\GenTarifa_"+PITMREF
Local   Char LFECHA(10), LHORA(10) : Raz LFECHA, LHORA
Local   Char LSEP(1) : Raz LSEP : LSEP = ";"  # separador
Local   Char LPATHDESE(255) : Raz LPATHDESE : LPATHDESE = filpath("IMPORT_EXPORT\GENITM\Error_ppto","","")    # ruta de la carpeta con errores
Local   Char LPATHDESS(255) : Raz LPATHDESS : LPATHDESS = filpath("IMPORT_EXPORT\GENITM\Success_ppto","","")  # ruta de la carpeta de finalizados con éxito
Local   Char LITMREF(255),LTCLCOD(255),LITMDES1(30),LITMDES2(30),LITMDES3(30) : Raz LITMREF,LTCLCOD,LITMDES1,LITMDES2,LITMDES3

Local Integer STAT

 # Call GENERA_TRAZA("00", "Generación Tarifa. desde Presupuesto - Artículo:" + PITMREF, "")

  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
  LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

  LFILE_W = LDIRIMPORT + LFILE_W + "_" + LFECHA + LHORA + ".txt"

  # Call GENERA_TRAZA("00", "", LFILE_W)

  # borramos el fichero si existe...
  If filinfo(LFILE_W, 7) > 0 Then
    System "ae_rm " + LFILE_W
  Endif
  mkstat = 0 : fstat = 0 : GERRTRACE = 0
  Sleep 1

  If !GSERVEUR Then
    Call OUVRE_TRACE("Generación de tarifa") From LECFIC
  Endif

  # abrir el fichero para escritura
  Gosub OPEN_FILE_W
  # pantalla detalles
  Local Char    LDETALLES(250)(1..)
  # pantalla extras
  Local Char    LEXTRAS(250)(1..)


  # cabecera tarifas
  Wrseq "E" + LSEP + "T10" + LSEP + "PPL20-0001"  + LSEP + '20200101'   + LSEP + '20990101'    Using [YIMP_W]

  # detalle tarifa
  # Wrseq "L" + LSEP + PITMREF + LSEP + "" + LSEP + "" + LSEP + "UN" + LSEP + "" + LSEP + "" + LSEP + "EUR" + LSEP + num$(PCOSTO)  Using [YIMP_W]
  Wrseq "L" + LSEP + PITMREF + LSEP + "" + LSEP + "" + LSEP + "UN" + LSEP + "" + LSEP + "" + LSEP + "CNY" + LSEP + num$(PCOSTOYUAN)  Using [YIMP_W]

  Gosub CLOSE_FILE_W
  #Call IMPORTSIL("YITMBA",LFILE_W) From GIMPOBJ                              # lanza la importación
  #Call IMPORTSIL("YITMBA2",LFILE_W) From GIMPOBJ                              # lanza la importación
  GERRTRACE = 0
  Call IMPORTSIL("YPPL",LFILE_W) From GIMPOBJ                              # lanza la importación
  If !GSERVEUR Then
    Call FERME_TRACE From LECFIC
  Endif
 # Infbox "fstat:" + num$(fstat) + " - gerratrace: " + num$(GERRTRACE)
 # Call GENERA_TRAZA("00", "", "Fin creación. Nº Errores: " + num$(GERRTRACE))
  If (fstat <> 0 and fstat <> 4) or GERRTRACE <> 0 Then                      # si se produce error de importación...
    If filinfo(LFILE_W+".err", 7) > 0 Then
      Call MOVE(LFILE_W+".err",LPATHDESE,STAT) From ORDSYS                     # mueve el fichero .err con errores en la importación
      System "ae_rm " + LFILE_W                                                # borra el fichero .txt que ha dado errores
    Endif
  Else
    Call MOVE(LFILE_W,LPATHDESS,STAT) From ORDSYS                            # mueve el fichero .txt con importación exitosa
#    Call GENERA_TRAZA("00", "", "Creación de TARIFA artículo : " + PITMREF)
  Endif
  mkstat = 0 : fstat = 0 : GOK = 1 : GERRTRACE = 0

End


#**
#* Genera los tarifa para el artículo que estamos creando en el sistema a partir de los genéricos del presupuesto
#*
#* @param PNOL       > número de la línea
#* @param PITMREF    > código de artículo
#* @param PFCY       > planta
#*!
Subprog GENESTRUCTURAITM(PITMREF, PFCY, PNOL)
Value     Char    PFCY
Value     Char    PITMREF
Value     Integer PNOL

Local   Char LDIRIMPORT(250) : Raz LDIRIMPORT : LDIRIMPORT = filpath("IMPORT_EXPORT\GENITM\Mov_ppto","","")
Global  Char LFILE_W(200) : Raz LFILE_W : LFILE_W = "\GenEstructura_"+PITMREF
Local   Char LFECHA(10), LHORA(10) : Raz LFECHA, LHORA
Local   Char LSEP(1) : Raz LSEP : LSEP = ";"  # separador
Local   Char LPATHDESE(255) : Raz LPATHDESE : LPATHDESE = filpath("IMPORT_EXPORT\GENITM\Error_ppto","","")    # ruta de la carpeta con errores
Local   Char LPATHDESS(255) : Raz LPATHDESS : LPATHDESS = filpath("IMPORT_EXPORT\GENITM\Success_ppto","","")  # ruta de la carpeta de finalizados con éxito
Local   Char LITMREF(255),LTCLCOD(255),LITMDES1(30),LITMDES2(30),LITMDES3(30) : Raz LITMREF,LTCLCOD,LITMDES1,LITMDES2,LITMDES3

Local Integer STAT

 # Call GENERA_TRAZA("00", "Generación Tarifa. desde Presupuesto - Artículo:" + PITMREF, "")

  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
  LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

  LFILE_W = LDIRIMPORT + LFILE_W + "_" + LFECHA + LHORA + ".txt"

  Call GENERA_TRAZA("00", "", LFILE_W)

  # borramos el fichero si existe...
  If filinfo(LFILE_W, 7) > 0 Then
    System "ae_rm " + LFILE_W
  Endif
  mkstat = 0 : fstat = 0 : GERRTRACE = 0
  Sleep 1

  If !GSERVEUR Then
    Call OUVRE_TRACE("Generación de estructura") From LECFIC
  Endif

  # abrir el fichero para escritura
  Gosub OPEN_FILE_W
  # pantalla detalles
  Local Char    LDETALLES(250)(1..)
  # pantalla extras
  Local Char    LEXTRAS(250)(1..)

   # CREACIÓN DE ESTRUCTURA TEMPORAL - FALTA CONCRETAR CON MARTA/JOAN LA CREACIÓN

  # cabecera estructura
  Wrseq "E" + LSEP + PITMREF + ";10;2;1;1" Using [YIMP_W]

  # lineas estructura
#  Wrseq "L;15;100002;1;1;1;2" Using [YIMP_W]
#  Wrseq "L;15;100048;1;1;1;1,2"  Using [YIMP_W]
#  Wrseq "L;30;100056;6;1;1;25" Using [YIMP_W]
#  Wrseq "L;10;100097;6;1;1;0,18" Using [YIMP_W]
#  Wrseq "L;5;100105;1;1;1;1,5" Using [YIMP_W]


  # JC.09092020.STR
  Local Char LSEP(1)    : LSEP = ";"
  Local Integer LBOMSEQ : Raz LBOMSEQ
  If !clalev([F:ADI0]) Then : Local File ATABDIV [F:ADI0] : Endif
  # busca el artículo equivalente en el campo MATERIAL
  Local Char  ITMMATERIAL(100)
  Read [F:ADI0]CODE = 2502;[M:SQH2]YMATERIAL(PNOL)
  If !fstat Then
    # ARTICULO
    If [F:ADI0]A1 <> "" Then
      LBOMSEQ         += 10
      ITMMATERIAL     = [F:ADI0]A5  # AQUI ELEGIR ARTICULO IMP O ARTICULO LOC, SEGÚN SI ES DE IMPORTACIÓN O NO.
      Wrseq "L" + LSEP + num$(LBOMSEQ) + LSEP + ITMMATERIAL + LSEP + "1" + LSEP + "1" + LSEP + "1" + LSEP +
&           num$((val([M:SQH2]YALTO(PNOL))/100)*(val([M:SQH2]YANCHO(PNOL))/100)) Using [YIMP_W]
    Endif
  Endif
  # busca el artículo equivalente en el campo TIPO CONF. NORMAL
  Local Char  ANILLASCN(100), CINTACN(100)
  Read [F:ADI0]CODE = 2509;[M:SQH2]YCONFNORMALD(PNOL)
  If !fstat Then
    # ANILLAS
    If [F:ADI0]A1 <> "" Then
      LBOMSEQ         += 10
      ANILLASCN       = [F:ADI0]A1
      Wrseq "L" + LSEP + num$(LBOMSEQ) + LSEP + ANILLASCN + LSEP + "1" + LSEP + "1" + LSEP + "1" + LSEP + "2" Using [YIMP_W]
    Endif
    # CINTA
    If [F:ADI0]A2 <> "" Then
      LBOMSEQ         += 10
      CINTACN         = [F:ADI0]A2
      Wrseq "L" + LSEP + num$(LBOMSEQ) + LSEP + CINTACN + LSEP + "1" + LSEP + "1" + LSEP + "1" + LSEP + num$(val([M:SQH2]YALTO(PNOL))/100) Using [YIMP_W]
    Endif
  Endif
  # busca el artículo equivalente en el campo TIPO CONF. FLY
  Local Char  CINTACF(100)
  Read [F:ADI0]CODE = 2509;[M:SQH2]YCONFFLYITM(PNOL)
  If !fstat Then
    # CINTA
    If [F:ADI0]A1 <> "" Then
      LBOMSEQ         += 10
      CINTACF         = [F:ADI0]A1
      Wrseq "L" + LSEP + num$(LBOMSEQ) + LSEP + CINTACF + LSEP + "1" + LSEP + "1" + LSEP + "1" + LSEP +
&     num$((val([M:SQH2]YALTO(PNOL))/100)*(val([M:SQH2]YANCHO(PNOL))/100)) Using [YIMP_W]
    Endif
  Endif
  # busca el artículo equivalente a cada componente EXTRA
  Local Char    ARTICULO(100),OPERACION(100)
  If !clalev([F:YTX0]) Then : Local File YTEXTPRE [F:YTX0] : Endif
  Filter [F:YTX0] Where YCODLIN = [M:SQH2]YCODLIN(PNOL)
  For [YTX0]
    Local Decimal LQTY,LLADOS,LLARGO
    Read [F:ADI0]CODE = 2506;[F:YTX0]YEXTCOD
    If !fstat Then
      # ARTICULO
      If [F:ADI0]A1 <> "" Then
        LBOMSEQ       += 10
        ARTICULO      = [F:ADI0]A1
        If [F:YTX0]YEXTCANT   = 0 Then : LQTY   = 1 : Else LQTY   = [F:YTX0]YEXTCANT        : Endif
        If [F:YTX0]YEXTLARGO  = 0 Then : LLARGO = 1 : Else LLARGO = [F:YTX0]YEXTLARGO / 100 : Endif
        If [F:YTX0]YEXTARR = 2 Then
          LLADOS += val([M:SQH2]YANCHO(PNOL))/100
        Endif
        If [F:YTX0]YEXTABA = 2 Then
          LLADOS += val([M:SQH2]YANCHO(PNOL))/100
        Endif
        If [F:YTX0]YEXTDER = 2 Then
          LLADOS += val([M:SQH2]YALTO(PNOL))/100
        Endif
        If [F:YTX0]YEXTIZQ = 2 Then
          LLADOS += val([M:SQH2]YALTO(PNOL))/100
        Endif
        If LLADOS = 0 Then : LLADOS = 1 : Endif
        Wrseq "L" + LSEP + num$(LBOMSEQ) + LSEP + ARTICULO + LSEP + "1" + LSEP + "1" + LSEP + "1" + LSEP + num$(LQTY * LLADOS * LLARGO) Using [YIMP_W]
      Endif
      # OPERACION                   COMENTO EL CÓDIGO PQ TENGO QUE AVERIGUAR A QUÉ CORRESPONDE (NO CORRESPONDE A UN ARTÍCULO)
#      If [F:ADI0]A2 <> "" Then
#        LBOMSEQ       += 10
#        OPERACION     = [F:ADI0]A2
#        If [F:YTX0]YEXTCANT = 0 Then : LQTY = 1 : Else LQTY = [F:YTX0]YEXTCANT : Endif
#        LLADOS = [F:YTX0]YEXTARR + [F:YTX0]YEXTABA + [F:YTX0]YEXTDER + [F:YTX0]YEXTIZQ
#        If LLADOS = 0 Then : LLADOS = 1 : Endif
#        Wrseq "L" + LSEP + num$(LBOMSEQ) + LSEP + OPERACION + LSEP + "1" + LSEP + "1" + LSEP + "1" + LSEP + num$(LQTY * LLADOS) Using [YIMP_W]
#      Endif
    Endif
  Next
  Filter [F:YTX0]
  Close Local File [ADI0],[YTX0]
  # JC.09092020.END


  Gosub CLOSE_FILE_W
  Call IMPORTSIL("YBOMPIMZ",LFILE_W) From GIMPOBJ                              # lanza la importación
  If !GSERVEUR Then
    Call FERME_TRACE From LECFIC
  Endif

  If (fstat <> 0 and fstat <> 4) or GERRTRACE <> 0 Then                      # si se produce error de importación...
    Call MOVE(LFILE_W+".err",LPATHDESE,STAT) From ORDSYS                     # mueve el fichero .err con errores en la importación
    System "ae_rm " + LFILE_W                                                # borra el fichero .txt que ha dado errores
  Else
  Call MOVE(LFILE_W,LPATHDESS,STAT) From ORDSYS                            # mueve el fichero .txt con importación exitosa

#    Call GENERA_TRAZA("00", "", "Creación de TARIFA artículo : " + PITMREF)

  Endif
  mkstat = 0 : fstat = 0 : GOK = 1 : GERRTRACE = 0

End


########################################################
$OPEN_FILE_W

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE_W Using [YIMP_W]

Return

########################################################
$CLOSE_FILE_W

Openo Using [YIMP_W]

Return


#####################################################################
#**
#* Genera los artículos en el sistema a partir de los genéricos del presupuesto
#*
#* @param PITMREF    > código de artículo
#* @param PFcy       > planta
#*!
Subprog GENITF(PITMREF,PFCY, PTIPOIMPRESION, PFABRICADA, PPROVEEDOR)
Value  Char PITMREF
Value  Char PFCY
Value  Char PTIPOIMPRESION, PFABRICADA

Local Char LCAT, LALMACENAMIENTO # 23122020.new mab
Local   Char LDIRIMPORTP(250) : Raz LDIRIMPORTP : LDIRIMPORTP = filpath("IMPORT_EXPORT\GENITM\Mov_ppto","","")
Global  Char LFILE_WP(200) : Raz LFILE_WP : LFILE_WP = "\GeneracionArticuloPlanta"
Local   Char LFECHAP(10), LHORAP(10) : Raz LFECHAP, LHORAP
Local   Char LSEPP(1) : Raz LSEPP : LSEPP = ";"  # separador
Local   Char LPATHDESEP(255) : Raz LPATHDESEP : LPATHDESEP = filpath("IMPORT_EXPORT\GENITM\Error_ppto","","")    # ruta de la carpeta con errores
Local   Char LPATHDESSP(255) : Raz LPATHDESSP : LPATHDESSP = filpath("IMPORT_EXPORT\GENITM\Success_ppto","","")  # ruta de la carpeta de finalizados con éxito

Local   Char LTIPOSUGERENCIA : Raz LTIPOSUGERENCIA
Local   Char LRUTA           : Raz LRUTA

Local Integer STATP

  LFECHAP = vireblc(num$(date$),4) : LFECHAP = mid$(LFECHAP,1,2)+mid$(LFECHAP,4,2)+mid$(LFECHAP,7,4)
  LHORAP  = vireblc(num$(time$),4) : LHORAP  = mid$(LHORAP,1,2)+mid$(LHORAP,4,2)+mid$(LHORAP,7,2)

  LFILE_WP = LDIRIMPORTP + LFILE_WP + "_" + LFECHAP + LHORAP + ".txt"

  # borramos el fichero si existe...
  If filinfo(LFILE_WP, 7) > 0 Then
    System "ae_rm " + LFILE_WP
  Endif

  mkstat = 0 : fstat = 0 : GERRTRACE = 0
  Sleep 1

  If !GSERVEUR Then
    Call OUVRE_TRACE("Generación de artículos-planta") From LECFIC
  Endif

  # abrir el fichero para escritura
  Gosub OPEN_FILE_WP

  # CONTRAMARCA COMPRA
  If PPROVEEDOR <> '' Then
    LTIPOSUGERENCIA = '2'
  Endif

  If PTIPOIMPRESION = '02' and PFABRICADA = '01' Then # sublimación  y fabricada por imazu
    LTIPOSUGERENCIA = '3' # SUGERENCIA FABRICACIÓN
    LRUTA = "RU001"       # RUTA PARA EL ARTÍCULO-PLANTA
  Endif

  LCAT = func  GET_CATEGORIA(PTIPOIMPRESION, PFABRICADA)
  If LCAT = 'YBF' Then
    LALMACENAMIENTO = 'PTR'
  Endif
  # Wrseq "I" + LSEPP + PITMREF + LSEPP + PFCY + LSEPP + num$(1) + LSEPP + "AVC" + LSEPP + num$(2) Using [YIMP_WP]
  # MODIFICO LA VALORACIÓN A STD POR EL ERROR QUE ESTÁ DANDO AL CREAR ALGUNOS ARTÍCULOS
  # Wrseq "I" + LSEPP + PITMREF + LSEPP + PFCY + LSEPP + num$(1) + LSEPP + "STD" + LSEPP + num$(2) + LSEPP + LTIPOSUGERENCIA + LSEPP + LRUTA Using [YIMP_WP]
  Wrseq "I" + LSEPP + PITMREF + LSEPP + PFCY + LSEPP + num$(1) + LSEPP + "PMP" + LSEPP + num$(2) + LSEPP + LTIPOSUGERENCIA + LSEPP + LRUTA + LSEPP + LALMACENAMIENTO Using [YIMP_WP]

  Gosub CLOSE_FILE_WP
  Call IMPORTSIL("YITFBA",LFILE_WP) From GIMPOBJ                             # lanza la importación
  If !GSERVEUR Then
    Call FERME_TRACE From LECFIC
  Endif
  Call GENERA_TRAZA("00", "", "Creación de artículo planta. Resultado: " + num$(GERRTRACE))
  If (fstat <> 0 and fstat <> 4) or GERRTRACE <> 0 Then                      # si se produce error de importación...
    Call MOVE(LFILE_WP+".err",LPATHDESEP,STATP) From ORDSYS                     # mueve el fichero .err con errores en la importación
    System "ae_rm " + LFILE_WP                                                # borra el fichero .txt que ha dado errores
  Else
    Call MOVE(LFILE_WP,LPATHDESSP,STATP) From ORDSYS                            # mueve el fichero .txt con importación exitosa
  Endif
  mkstat = 0 : fstat = 0 : GOK = 1 : GERRTRACE = 0

   Call GENERA_TRAZA("00", "", "")

End

########################################################
$OPEN_FILE_WP

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE_WP Using [YIMP_WP]

Return

########################################################
$CLOSE_FILE_WP

Openo Using [YIMP_WP]

Return

#####################################################################
#**
#* Busca un artículo por sus atributos y categoría
#*
#* @param PTCLCOD       > categoría
#* @param PYTIPOIMP    > tipo de impresión
#* @param PYMATERIAL   > material
#* @param PYALTO       > alto
#* @param PYANCHO      > ancho
#* @param PYNUMCOLORES > número de colores
#* @param PYPESPUNTE   > pespunte
#* @param PYCONFNORMAL > conf. normal
#* @param PYCONFFLY    > fly banner
#* @param PYFABRICADA  > fabricada
#* @param PYREFERENCIA > referencia
#* @param PITMREF      > código de artículo
#*!
Subprog SEARCH_ITM(PDETALLES,PEXTRAS,PITMREF)
Value     Char  PDETALLES()(1..)
Value     Char  PEXTRAS()(1..)
Variable  Char  PITMREF


Local Clbfile LCRIT(2) : LCRIT = "1=1"

  If !clalev([F:ITM0]) Then : Local File ITMMASTER [F:ITM0] : Endif

  If PDETALLES(1)   <> "" Then : LCRIT += " and TCLCOD='"       + PDETALLES(1)  +"'"  : Endif
  If PDETALLES(6)   <> "" Then : LCRIT += " and YTIPOIMP='"     + PDETALLES(6)  +"'"  : Endif
  If PDETALLES(7)   <> "" Then : LCRIT += " and YMATERIAL='"    + PDETALLES(7)  +"'"  : Endif
  If PDETALLES(8)   <> "" Then : LCRIT += " and YALTO='"        + PDETALLES(8)  +"'"  : Endif
  If PDETALLES(9)   <> "" Then : LCRIT += " and YANCHO='"       + PDETALLES(9)  +"'"  : Endif
  If PDETALLES(10)  <> "" Then : LCRIT += " and YNUMCOLORES='"  + PDETALLES(10) +"'"  : Endif
  If PDETALLES(11)  <> "" Then : LCRIT += " and YPESPUNTE="     + PDETALLES(11)       : Endif
  If PDETALLES(12)  <> "" Then : LCRIT += " and YCONFNORMAL="   + PDETALLES(12)       : Endif
  If PDETALLES(13)  <> "" Then : LCRIT += " and YCONFFLY="      + PDETALLES(13)       : Endif
  If PDETALLES(14)  <> "" Then : LCRIT += " and YFABRICADA='"   + PDETALLES(14) +"'"  : Endif
#  If PDETALLES(15)  <> "" Then : LCRIT += " and YREFERENCIA='"  + PDETALLES(15) +"'"  : Endif
  If PDETALLES(16)  <> "" Then : LCRIT += " and YRANGO='"       + PDETALLES(16) +"'"  : Endif
  If PEXTRAS(1)     <> "" Then : LCRIT += " and YCINTAREF="     + PEXTRAS(1)          : Endif
  If PEXTRAS(2)     <> "" Then : LCRIT += " and YCINTAREFAR="   + PEXTRAS(2)          : Endif
  If PEXTRAS(3)     <> "" Then : LCRIT += " and YCINTAREFAB="   + PEXTRAS(3)          : Endif
  If PEXTRAS(4)     <> "" Then : LCRIT += " and YCINTAREFIZ="   + PEXTRAS(4)          : Endif
  If PEXTRAS(5)     <> "" Then : LCRIT += " and YCINTAREFDE="   + PEXTRAS(5)          : Endif
  If PEXTRAS(6)     <> "" Then : LCRIT += " and YOLLADOS="      + PEXTRAS(6)          : Endif
  If PEXTRAS(7)     <> "" Then : LCRIT += " and YANILLAS="      + PEXTRAS(7)          : Endif
  If PEXTRAS(8)     <> "" Then : LCRIT += " and YCINTAATAR="    + PEXTRAS(8)          : Endif
  If PEXTRAS(9)     <> "" Then : LCRIT += " and YLARGO="        + PEXTRAS(9)          : Endif
  If PEXTRAS(10)    <> "" Then : LCRIT += " and YMNGVAINA="     + PEXTRAS(10)         : Endif
  If PEXTRAS(11)    <> "" Then : LCRIT += " and YMNGVAINAAR="   + PEXTRAS(11)         : Endif
  If PEXTRAS(12)    <> "" Then : LCRIT += " and YMNGVAINAAB="   + PEXTRAS(12)         : Endif
  If PEXTRAS(13)    <> "" Then : LCRIT += " and YMNGVAINAIZ="   + PEXTRAS(13)         : Endif
  If PEXTRAS(14)    <> "" Then : LCRIT += " and YMNGVAINADE="   + PEXTRAS(14)         : Endif
  If PEXTRAS(15)    <> "" Then : LCRIT += " and YCNTMSTL="      + PEXTRAS(15)         : Endif
  If PEXTRAS(16)    <> "" Then : LCRIT += " and YCNTMSTLQTY="   + PEXTRAS(16)         : Endif
  If PEXTRAS(17)    <> "" Then : LCRIT += " and YABRPVC="       + PEXTRAS(17)         : Endif         #############
  If PEXTRAS(18)    <> "" Then : LCRIT += " and YABRPVCQTY="    + PEXTRAS(18)         : Endif
  If PEXTRAS(19)    <> "" Then : LCRIT += " and YCINTASIL="     + PEXTRAS(19)         : Endif
  If PEXTRAS(20)    <> "" Then : LCRIT += " and YCINTASILAR="   + PEXTRAS(20)         : Endif
  If PEXTRAS(21)    <> "" Then : LCRIT += " and YCINTASILAB="   + PEXTRAS(21)         : Endif
  If PEXTRAS(22)    <> "" Then : LCRIT += " and YCINTASILIZ="   + PEXTRAS(22)         : Endif
  If PEXTRAS(23)    <> "" Then : LCRIT += " and YCINTASILDE="   + PEXTRAS(23)         : Endif
  If PEXTRAS(24)    <> "" Then : LCRIT += " and YPALPL256="     + PEXTRAS(24)         : Endif
  If PEXTRAS(25)    <> "" Then : LCRIT += " and YPALPL306="     + PEXTRAS(25)         : Endif
  If PEXTRAS(26)    <> "" Then : LCRIT += " and YPALPL406="     + PEXTRAS(26)         : Endif
  If PEXTRAS(27)    <> "" Then : LCRIT += " and YPALPL408="     + PEXTRAS(27)         : Endif
  If PEXTRAS(28)    <> "" Then : LCRIT += " and YPALPL608="     + PEXTRAS(28)         : Endif
  If PEXTRAS(29)    <> "" Then : LCRIT += " and YPALPL10010="   + PEXTRAS(29)         : Endif
  If PEXTRAS(30)    <> "" Then : LCRIT += " and YPALPL12012="   + PEXTRAS(30)         : Endif
  If PEXTRAS(31)    <> "" Then : LCRIT += " and YPALMA408="     + PEXTRAS(31)         : Endif
  If PEXTRAS(32)    <> "" Then : LCRIT += " and YPALMA608="     + PEXTRAS(32)         : Endif
  If PEXTRAS(33)    <> "" Then : LCRIT += " and YPALMA100="     + PEXTRAS(33)         : Endif
  If PEXTRAS(34)    <> "" Then : LCRIT += " and YPALMA150="     + PEXTRAS(34)         : Endif
  If PEXTRAS(35)    <> "" Then : LCRIT += " and YMASTIL44="     + PEXTRAS(35)         : Endif
  If PEXTRAS(36)    <> "" Then : LCRIT += " and YMASTIL50="     + PEXTRAS(36)         : Endif
  If PEXTRAS(37)    <> "" Then : LCRIT += " and YEMBOLSADO="    + PEXTRAS(37)         : Endif
  If PEXTRAS(38)    <> "" Then : LCRIT += " and YVELCRO="       + PEXTRAS(38)         : Endif
  If PEXTRAS(39)    <> "" Then : LCRIT += " and YVELCROAR="     + PEXTRAS(39)         : Endif
  If PEXTRAS(40)    <> "" Then : LCRIT += " and YVELCROAB="     + PEXTRAS(40)         : Endif
  If PEXTRAS(41)    <> "" Then : LCRIT += " and YVELCROIZ="     + PEXTRAS(41)         : Endif
  If PEXTRAS(42)    <> "" Then : LCRIT += " and YVELCRODE="     + PEXTRAS(42)         : Endif
  If PEXTRAS(43)    <> "" Then : LCRIT += " and YSILICON="      + PEXTRAS(43)         : Endif
  If PEXTRAS(44)    <> "" Then : LCRIT += " and YSILICONAR="    + PEXTRAS(44)         : Endif
  If PEXTRAS(45)    <> "" Then : LCRIT += " and YSILICONAB="    + PEXTRAS(45)         : Endif
  If PEXTRAS(46)    <> "" Then : LCRIT += " and YSILICONIZ="    + PEXTRAS(46)         : Endif
  If PEXTRAS(47)    <> "" Then : LCRIT += " and YSILICONDE="    + PEXTRAS(47)         : Endif
  If PEXTRAS(48)    <> "" Then : LCRIT += " and YOLLADOSLONA="  + PEXTRAS(48)         : Endif
  If PEXTRAS(49)    <> "" Then : LCRIT += " and YREFLONA="      + PEXTRAS(49)         : Endif
  If PEXTRAS(50)    <> "" Then : LCRIT += " and YREFLONAAR="    + PEXTRAS(50)         : Endif
  If PEXTRAS(51)    <> "" Then : LCRIT += " and YREFLONAAB="    + PEXTRAS(51)         : Endif
  If PEXTRAS(52)    <> "" Then : LCRIT += " and YREFLONAIZ="    + PEXTRAS(52)         : Endif
  If PEXTRAS(53)    <> "" Then : LCRIT += " and YREFLONADE="    + PEXTRAS(53)         : Endif


  Filter [F:ITM0] Where evalue(LCRIT) Order By UPDDATTIM Desc
  Read [F:ITM0] First
  If !fstat Then
    PITMREF = [F:ITM0]ITMREF
  Endif
  Filter [F:ITM0]
  If clalev([F:ITM0])  Then : Close Local File     [F:ITM0] : Endif

End

#####################################################################
#**
#* Busca un artículo por sus atributos y categoría
#*
#* @param PNOL         > número de línea
#* @param PITMREF      > código de artículo
#*!
Subprog SEARCH_ITMLIN(PNOL,PITMREF)
Value     Integer PNOL
Variable  Char    PITMREF
Local Integer LNUMEXTART, LNUMEXTPRE
LNUMEXTART = 0
LNUMEXTPRE = 0

#Infbox "Linea que busco:" + num$(PNOL)
Local Clbfile LCRIT(2) : LCRIT = "1=1"

  If !clalev([F:ITM1]) Then : Local File ITMMASTER [F:ITM1] : Endif
  If !clalev([F:YTEX]) Then : Local File YTEXTPRE  [F:YTEX] : Endif # tabla de componentes extra del presupuesto
  If !clalev([F:YTEA]) Then : Local File YTEXTART  [F:YTEA] : Endif # tabla de componentes extra de los artículos

  # ALGUNOS CAMPOS EN PANTALLA TIENEN VALOR 0 Y EN BBDD VALOR 1
  If [M:SQH2]YCINTAREFAR(PNOL) = 0 Then : [M:SQH2]YCINTAREFAR(PNOL) = 1 : Endif
  If [M:SQH2]YCINTAREFAB(PNOL) = 0 Then : [M:SQH2]YCINTAREFAB(PNOL) = 1 : Endif
  If [M:SQH2]YCINTAREFIZ(PNOL) = 0 Then : [M:SQH2]YCINTAREFIZ(PNOL) = 1 : Endif
  If [M:SQH2]YCINTAREFDE(PNOL) = 0 Then : [M:SQH2]YCINTAREFDE(PNOL) = 1 : Endif

  # COMPONENTES BASE
  LCRIT += " and YRANGO='"       + num$([M:SQH2]YRANGO(PNOL)) +"'"
  LCRIT += " and YTIPOIMP='"     + num$([M:SQH2]YTIPOIMP(PNOL))  +"'"
  LCRIT += " and YMATERIAL='"    + num$([M:SQH2]YMATERIAL(PNOL))  +"'"
  LCRIT += " and YALTO='"        + num$([M:SQH2]YALTO(PNOL))  +"'"
  LCRIT += " and YANCHO='"       + num$([M:SQH2]YANCHO(PNOL))  +"'"
  LCRIT += " and YNUMCOLORES='"  + num$([M:SQH2]YNUMCOLORES(PNOL)) +"'"
  LCRIT += " and YPESPUNTE="     + num$([M:SQH2]YPESPUNTE(PNOL))
  LCRIT += " and YCONFNORMAL="   + num$([M:SQH2]YCONFNORMAL(PNOL))
  LCRIT += " and YCONFFLY="      + num$([M:SQH2]YCONFFLY(PNOL))
  LCRIT += " and YFABRICADA='"   + num$([M:SQH2]YFABRICADA(PNOL)) +"'"
  # COMPONENTES EXTRA
  # BUSCARLOS EN LA TABLA YTEXTPRE
  # MAB.19062020.SOLD
#  LCRIT += " and YCINTAREF="     + num$([M:SQH2]YCINTAREF(PNOL))        : LCRIT += " and YCINTAREFAR="   + num$([M:SQH2]YCINTAREFAR(PNOL))
#  LCRIT += " and YCINTAREFAB="   + num$([M:SQH2]YCINTAREFAB(PNOL))      : LCRIT += " and YCINTAREFIZ="   + num$([M:SQH2]YCINTAREFIZ(PNOL))
#  LCRIT += " and YCINTAREFDE="   + num$([M:SQH2]YCINTAREFDE(PNOL))      : LCRIT += " and YOLLADOS="      + num$([M:SQH2]YOLLADOS(PNOL))
#  LCRIT += " and YANILLAS="      + num$([M:SQH2]YANILLAS(PNOL))         : LCRIT += " and YCINTAATAR="    + num$([M:SQH2]YCINTAATAR(PNOL))
#  LCRIT += " and YLARGO="        + num$([M:SQH2]YLARGO(PNOL))           : LCRIT += " and YMNGVAINA="     + num$([M:SQH2]YMNGVAINA(PNOL))
#  LCRIT += " and YMNGVAINAAR="   + num$([M:SQH2]YMNGVAINAAR(PNOL))      : LCRIT += " and YMNGVAINAAB="   + num$([M:SQH2]YMNGVAINAAB(PNOL))
#  LCRIT += " and YMNGVAINAIZ="   + num$([M:SQH2]YMNGVAINAIZ(PNOL))      : LCRIT += " and YMNGVAINADE="   + num$([M:SQH2]YMNGVAINADE(PNOL))
#  LCRIT += " and YCNTMSTL="      + num$([M:SQH2]YCNTMSTL(PNOL))         : LCRIT += " and YCNTMSTLQTY="   + num$([M:SQH2]YCNTMSTLQTY(PNOL))
#  LCRIT += " and YABRPVC="       + num$([M:SQH2]YABRPVC(PNOL))          : LCRIT += " and YABRPVCQTY="    + num$([M:SQH2]YABRPVCQTY(PNOL))
#  LCRIT += " and YCINTASIL="     + num$([M:SQH2]YCINTASIL(PNOL))        : LCRIT += " and YCINTASILAR="   + num$([M:SQH2]YCINTASILAR(PNOL))
#  LCRIT += " and YCINTASILAB="   + num$([M:SQH2]YCINTASILAB(PNOL))      : LCRIT += " and YCINTASILIZ="   + num$([M:SQH2]YCINTASILIZ(PNOL))
#  LCRIT += " and YCINTASILDE="   + num$([M:SQH2]YCINTASILDE(PNOL))      : LCRIT += " and YPALPL256="     + num$([M:SQH2]YPALPL256(PNOL))
#  LCRIT += " and YPALPL306="     + num$([M:SQH2]YPALPL306(PNOL))        : LCRIT += " and YPALPL406="     + num$([M:SQH2]YPALPL406(PNOL))
#  LCRIT += " and YPALPL408="     + num$([M:SQH2]YPALPL408(PNOL))        : LCRIT += " and YPALPL608="     + num$([M:SQH2]YPALPL608(PNOL))
#  LCRIT += " and YPALPL10010="   + num$([M:SQH2]YPALPL10010(PNOL))      : LCRIT += " and YPALPL12012="   + num$([M:SQH2]YPALPL12012(PNOL))
#  LCRIT += " and YPALMA408="     + num$([M:SQH2]YPALMA408(PNOL))        : LCRIT += " and YPALMA608="     + num$([M:SQH2]YPALMA608(PNOL))
#  LCRIT += " and YPALMA100="     + num$([M:SQH2]YPALMA100(PNOL))        : LCRIT += " and YPALMA150="     + num$([M:SQH2]YPALMA150(PNOL))
#  LCRIT += " and YMASTIL44="     + num$([M:SQH2]YMASTIL44(PNOL))        : LCRIT += " and YMASTIL50="     + num$([M:SQH2]YMASTIL50(PNOL))
#  LCRIT += " and YEMBOLSADO="    + num$([M:SQH2]YEMBOLSADO(PNOL))       : LCRIT += " and YVELCRO="       + num$([M:SQH2]YVELCRO(PNOL))
#  LCRIT += " and YVELCROAR="     + num$([M:SQH2]YVELCROAR(PNOL))        : LCRIT += " and YVELCROAB="     + num$([M:SQH2]YVELCROAB(PNOL))
#  LCRIT += " and YVELCROIZ="     + num$([M:SQH2]YVELCROIZ(PNOL))        : LCRIT += " and YVELCRODE="     + num$([M:SQH2]YVELCRODE(PNOL))
#  LCRIT += " and YSILICON="      + num$([M:SQH2]YSILICON(PNOL))         : LCRIT += " and YSILICONAR="    + num$([M:SQH2]YSILICONAR(PNOL))
#  LCRIT += " and YSILICONAB="    + num$([M:SQH2]YSILICONAB(PNOL))       : LCRIT += " and YSILICONIZ="    + num$([M:SQH2]YSILICONIZ(PNOL))
#  LCRIT += " and YSILICONDE="    + num$([M:SQH2]YSILICONDE(PNOL))       : LCRIT += " and YOLLADOSLONA="  + num$([M:SQH2]YOLLADOSLONA(PNOL))
#  LCRIT += " and YREFLONA="      + num$([M:SQH2]YREFLONA(PNOL))         : LCRIT += " and YREFLONAAR="    + num$([M:SQH2]YREFLONAAR(PNOL))
#  LCRIT += " and YREFLONAAB="    + num$([M:SQH2]YREFLONAAB(PNOL))       : LCRIT += " and YREFLONAIZ="    + num$([M:SQH2]YREFLONAIZ(PNOL))
#  LCRIT += " and YREFLONADE="    + num$([M:SQH2]YREFLONADE(PNOL))
  # MAB.19062020.eOLD
  # Infbox "Criterio:" + LCRIT
  # MAB.19062020.SNEW
  # buscar artículos con los componentes base iguales a los de la línea de presupuesto actual
  Filter [F:ITM1] Where evalue(LCRIT) Order By UPDDATTIM Desc
  #Read [F:ITM1] First
  #If !fstat Then

  For [F:ITM1]
    LOK = 0
    # Infbox [F:ITM1]ITMREF
    Filter [F:YTEX] Where  YCODLIN = [M:SQH2]YCODLIN(PNOL)
    LNUMEXTPRE = rowcount([F:YTEX])
    Filter [F:YTEA] Where YITMREF = [F:ITM1]ITMREF
    LNUMEXTART = rowcount([F:YTEA])
    # SI EL NÚMERO DE EXTRAS COINCIDE Y TIENE EXTRAS EL ARTÍCULO DEL PRESPUESTO, ENTRAMOS A COMPARAR
    If LNUMEXTPRE = LNUMEXTART and LNUMEXTPRE > 0 Then
      #Infbox "NUMERO DE EXTRAS COINDICE ARTICULO "
      For [F:YTEX] # Where  YCODLIN = [M:SQH2]YCODLIN(PNOL) # BUSCO LOS COMPONENTES DEl artículo del PRESUPUESTO
          #Infbox "Art:" + [F:ITM1]ITMREF + " - Extra:" + [F:YTEX]YEXTCOD
          Read [F:YTEA]YTEP0=[F:ITM1]ITMREF;[F:YTEX]YEXTCOD # BUSCO EL COMPONENTE DEL PRESUPUESTO EN LOS COMPONENTES EXTRA DEL ARTÍCULO ENCONTRADO
          If !fstat Then # si el artículo que estoy creando tiene el componente extra del artículo base
             If [F:YTEA]YEXTCANT = [F:YTEX]YEXTCANT and [F:YTEA]YEXTARR = [F:YTEX]YEXTARR and [F:YTEA]YEXTABA = [F:YTEX]YEXTABA
&              and [F:YTEA]YEXTDER = [F:YTEX]YEXTDER and [F:YTEA]YEXTIZQ = [F:YTEX]YEXTIZQ Then
              #Infbox "COINCIDE TODO EL EXTRA"
              LOK += 1
             Else # SI EL COMPONENTE COINCIDE PERO LAS PROPIEDADES DEL MISMO SON DIFERENTES, EL ARTICULO ES DIFERENTE
              LOK = 0
              #Infbox "NO COINCIDE EL EXTRA"
             Endif
          Else
             LOK = 0
             #Infbox "EXTRA NO ENCONTRADO EN ARTÍCULO" + [F:ITM1]ITMREF
          Endif
          If LOK = 0 Then
              Break
          Endif
      Next
    Endif
      #Infbox "FIN BUSQUEDA EXTRAS"
      # EL ARTÍCULO CUMPLE CON TODOS LOS COMPONENTES POR LO TANTO ES IGUAL QUE EL QUE ESTOY CREANDO
      # O EL ARTICULO QUE ESTOY CREANDO NO TIENE EXTRAS Y EL ARTICULO ENCONTRADO TAMPOCO TIENE EXTRAS
    If LOK > 0 or (LOK = 0 and LNUMEXTPRE = 0 and LNUMEXTART = 0) Then
      #Infbox "SI" + [F:ITM1]ITMREF
      PITMREF = [F:ITM1]ITMREF
      Break
    Else
      PITMREF = ''
      #Infbox "NO"
    Endif
  Next
  #Endif
  # MAB.19062020.ENEW
  Filter [F:ITM1]

  If clalev([F:ITM1])  Then : Close Local File     [F:ITM1] : Endif
  Close File [F:YTEX]
  Close File [F:YTEA]


End

#######################
#**
#* convierte divisas
#*
#* @param PDIVISAORI  > divisa origen
#* @param PDIVISADES  > divisa destino
#* @param PCANTIDAD   > cantidad a cambiar
#* @param PTIPO       > tipo de cambio (1=cambio día; 2=cambio mes; 3=cambio medio; 4=cambio DEB)
#* @param PCAMBIO     > valor del cambio
#*!
Subprog CONVERTDIV(PDIVISAORI,PDIVISADES,PCANTIDAD,PTIPO,PCAMBIO)
Value     Char    PDIVISAORI
Value     Char    PDIVISADES
Value     Decimal PCANTIDAD
Value     Integer PTIPO
Variable  Decimal PCAMBIO

  If !clalev([F:TCH0]) Then : Local File TABCHANGE  [F:TCH0] : Endif

#  Read [F:TCH0]TCH0 = PTIPO;PDIVISADES;PDIVISAORI;date$
  Filter [F:TCH0] Where CHGTYP = PTIPO and CURDEN = PDIVISADES and CUR = PDIVISAORI and date$ >= CHGSTRDAT
  Read [F:TCH0] First
  If !fstat Then
    PCAMBIO = (PCANTIDAD * [F:TCH0]CHGRAT)
  Endif
  Filter [F:TCH0]
  If  clalev([F:TCH0]) Then : Close Local File      [F:TCH0] : Endif

End


#######################
#**
#* convierte divisas con grabación de TRAZA para presupuestos
#*
#* @param PDIVISAORI  > divisa origen
#* @param PDIVISADES  > divisa destino
#* @param PCANTIDAD   > cantidad a cambiar
#* @param PTIPO       > tipo de cambio (1=cambio día; 2=cambio mes; 3=cambio medio; 4=cambio DEB)
#* @param PCAMBIO     > valor del cambio
#* @param PTRAZA      > "0"  no escribe traza, "1" Escribe traza
#* @param PYCODLIN    > Código de traza
#*!
Subprog CONVERTDIV_TR(PDIVISAORI,PDIVISADES,PCANTIDAD,PTIPO,PCAMBIO, PYCODLIN, PTRAZA)
Value     Char    PDIVISAORI
Value     Char    PDIVISADES
Value     Decimal PCANTIDAD
Value     Integer PTIPO
Value     Char    PTRAZA, PYCODLIN
Variable  Decimal PCAMBIO

  If !clalev([F:TCH0]) Then : Local File TABCHANGE  [F:TCH0] : Endif

#  Read [F:TCH0]TCH0 = PTIPO;PDIVISADES;PDIVISAORI;date$
  Filter [F:TCH0] Where CHGTYP = PTIPO and CURDEN = PDIVISADES and CUR = PDIVISAORI and date$ >= CHGSTRDAT Order By CHGSTRDAT Desc
  Read [F:TCH0] First
  If !fstat Then
    PCAMBIO = (PCANTIDAD * [F:TCH0]CHGRAT)
    If PTRAZA <> "0" and PYCODLIN <> "" Then
       Call TRAZA_PRECIO(PYCODLIN , "","Cambio divisa: " + PDIVISAORI + " a " + PDIVISADES + "(Cambio a fecha " + num$(date$) + " " + num$(time$) + " --> " + num$([F:TCH0]REVCOURS) + ") - Resultado: "
& + num$(PCAMBIO)
& ,
& PTRAZA ) From SPEYLIB0
    Endif
  Endif
  Filter [F:TCH0]
  If  clalev([F:TCH0]) Then : Close Local File      [F:TCH0] : Endif

End


#######################
#**
#* compone descripción completa del artículo
#*
#* @param PITM  > código de artículo
#*!
Subprog COMPONEDESC(PITM)
Value     Char    PITM

Local Clbfile LDES

  If !clalev([F:AXX0]) Then : Local File ATEXTRA    [F:AXX0] : Endif
  If !clalev([F:ITM0]) Then : Local File ITMMASTER  [F:ITM0] : Endif
  Read  [F:ITM0]ITM0 = PITM
  If !fstat Then
    # referencia
    LDES -= [F:ITM0]YREFERENCIA

    # tipo de impresión
    Filter [F:AXX0] Where CODFIC = "ATABDIV" and ZONE = "LNGDES" and LANGUE = GLANGUE and IDENT1 = "2501" and IDENT2 = [F:ITM0]YTIPOIMP
    Read   [F:AXX0] First
    If !fstat Then
      LDES -= ";"-[F:AXX0]TEXTE
    Endif
    Filter [F:AXX0]

    # fabricada
    Filter [F:AXX0] Where CODFIC = "ATABDIV" and ZONE = "LNGDES" and LANGUE = GLANGUE and IDENT1 = "2503" and IDENT2 = [F:ITM0]YFABRICADA
    Read   [F:AXX0] First
    If !fstat Then
      LDES -= ";"-[F:AXX0]TEXTE
    Endif
    Filter [F:AXX0]

    # material
    Filter [F:AXX0] Where CODFIC = "ATABDIV" and ZONE = "LNGDES" and LANGUE = GLANGUE and IDENT1 = "2502" and IDENT2 = [F:ITM0]YMATERIAL
    Read [F:AXX0] First
    If !fstat Then
      LDES -= ";"-[F:AXX0]TEXTE
    Endif
    Filter [F:AXX0]

    # alto y ancho
    LDES -= "; ("+[F:ITM0]YALTO+"x"+[F:ITM0]YANCHO+")cm"

    # número de colores
    Filter [F:AXX0] Where CODFIC = "ATABDIV" and ZONE = "SHODES" and LANGUE = GLANGUE and IDENT1 = "2505" and IDENT2 = [F:ITM0]YNUMCOLORES
    Read   [F:AXX0] First
    If !fstat Then
      LDES -= ";"-[F:AXX0]TEXTE
    Endif
    Filter [F:AXX0]

    # pespunte
    If [F:ITM0]YPESPUNTE = 2    Then : LDES -= "; Pespunte perimetral"      : Endif

    # conf. normal
    If [F:ITM0]YCONFNORMAL = 2  Then : LDES -= "; Cinta y anillas/ollados"  : Endif

    # conf. fly banner
    If [F:ITM0]YCONFFLY    = 2  Then : LDES -= "; Fly Banner"               : Endif

    # cinta de refuerzo
    If [F:ITM0]YCINTAREF = 2 Then
      LDES -= "; con Cinta de Refuerzo Posición"
      If [F:ITM0]YCINTAREFAR = 2 Then
        LDES -= "Arriba"
      Endif
      If [F:ITM0]YCINTAREFAB = 2 Then
        LDES -= "Abajo"
      Endif
      If [F:ITM0]YCINTAREFIZ = 2 Then
        LDES -= "Izquierda"
      Endif
      If [F:ITM0]YCINTAREFDE = 2 Then
        LDES -= "Derecha"
      Endif
    Endif

    # ollados
    If [F:ITM0]YOLLADOS > 0 Then : LDES -= ";"+num$([F:ITM0]YOLLADOS)-"Ollados" : Endif

    # anillas
    If [F:ITM0]YANILLAS > 0 Then : LDES -= ";"+num$([F:ITM0]YANILLAS)-"Anillas" : Endif

    # cinta de atar
    If [F:ITM0]YCINTAATAR > 0 Then : LDES -= ";"+num$([F:ITM0]YCINTAATAR)-"Cintas de atar de"-num$([F:ITM0]YLARGO)-"cms" : Endif

    # manga o vaina
    If [F:ITM0]YMNGVAINA = 2 Then
      LDES -= "; con Manga o Vaina Posición"
      If [F:ITM0]YMNGVAINAAR = 2 Then
        LDES -= "Arriba"
      Endif
      If [F:ITM0]YMNGVAINAAB = 2 Then
        LDES -= "Abajo"
      Endif
      If [F:ITM0]YMNGVAINAIZ = 2 Then
        LDES -= "Izquierda"
      Endif
      If [F:ITM0]YMNGVAINADE = 2 Then
        LDES -= "Derecha"
      Endif
    Endif

    # cinta para mástil
    If [F:ITM0]YCNTMSTL = 2 Then
      LDES -= "; con"-num$([F:ITM0]YCNTMSTLQTY)-"Cintas para mástil"
    Endif

    # abrazadera PVC
    If [F:ITM0]YABRPVC = 2 Then
      LDES -= "; con"-num$([F:ITM0]YABRPVCQTY)-"Abrazaderas PVC"
    Endif

    # cinta de silicon
    If [F:ITM0]YCINTASIL = 2 Then
      LDES -= "; con Cinta de Silicon Posición"
      If [F:ITM0]YCINTASILAR = 2 Then
        LDES -= "Arriba"
      Endif
      If [F:ITM0]YCINTASILAB = 2 Then
        LDES -= "Abajo"
      Endif
      If [F:ITM0]YCINTASILIZ = 2 Then
        LDES -= "Izquierda"
      Endif
      If [F:ITM0]YCINTASILDE = 2 Then
        LDES -= "Derecha"
      Endif
    Endif

    # palitos de plástico 25x6mm
    If [F:ITM0]YPALPL256 > 0    Then : LDES -= ";con"-num$([F:ITM0]YPALPL256)-"Palitos Plástico de 25x6mm"      : Endif

    # palitos de plástico 30x6mm
    If [F:ITM0]YPALPL306 > 0    Then : LDES -= ";con"-num$([F:ITM0]YPALPL306)-"Palitos Plástico de 30x6mm"      : Endif

    # palitos de plástico 40x6mm
    If [F:ITM0]YPALPL406 > 0    Then : LDES -= ";con"-num$([F:ITM0]YPALPL406)-"Palitos Plástico de 40x6mm"      : Endif

    # palitos de plástico 40x8mm
    If [F:ITM0]YPALPL408 > 0    Then : LDES -= ";con"-num$([F:ITM0]YPALPL408)-"Palitos Plástico de 40x8mm"      : Endif

    # palitos de plástico 60x8mm
    If [F:ITM0]YPALPL608 > 0    Then : LDES -= ";con"-num$([F:ITM0]YPALPL608)-"Palitos Plástico de 60x8mm"      : Endif

    # palitos de plástico 100x10mm
    If [F:ITM0]YPALPL10010 > 0  Then : LDES -= ";con"-num$([F:ITM0]YPALPL10010)-"Palitos Plástico de 100x10mm"  : Endif

    # palitos de plástico 120x12mm
    If [F:ITM0]YPALPL12012 > 0  Then : LDES -= ";con"-num$([F:ITM0]YPALPL12012)-"Palitos Plástico de 120x12mm"  : Endif

    # palitos de madera 40x8mm
    If [F:ITM0]YPALMA408 > 0    Then : LDES -= ";con"-num$([F:ITM0]YPALMA408)-"Palitos Madera de 40x8mm"        : Endif

    # palitos de madera 60x8mm
    If [F:ITM0]YPALMA608 > 0    Then : LDES -= ";con"-num$([F:ITM0]YPALMA608)-"Palitos Madera de 60x8mm"        : Endif

    # palitos de madera 100cms
    If [F:ITM0]YPALMA100 > 0    Then : LDES -= ";con"-num$([F:ITM0]YPALMA100)-"Palitos Madera de 100cm"         : Endif

    # palitos de madera 150cms
    If [F:ITM0]YPALMA150 > 0    Then : LDES -= ";con"-num$([F:ITM0]YPALMA150)-"Palitos Madera de 150cm"         : Endif

    # mástil de 44cms para coche
    If [F:ITM0]YMASTIL44 > 0    Then : LDES -= ";con"-num$([F:ITM0]YMASTIL44)-"Mástiles de 44cms para coche"    : Endif

    # mástil de 50cms para coche
    If [F:ITM0]YMASTIL50 > 0    Then : LDES -= ";con"-num$([F:ITM0]YMASTIL50)-"Mástiles de 50cms para coche"    : Endif

    # embolsado
    If [F:ITM0]YEMBOLSADO = 2    Then : LDES -= ";Embolsado individual"                                          : Endif

    # velcro hembra 5cms
    If [F:ITM0]YVELCRO = 2 Then
      LDES -= "; con Velcro Hembra 5cms Posición"
      If [F:ITM0]YVELCROAR = 2 Then
        LDES -= "Arriba"
      Endif
      If [F:ITM0]YVELCROAB = 2 Then
        LDES -= "Abajo"
      Endif
      If [F:ITM0]YVELCROIZ = 2 Then
        LDES -= "Izquierda"
      Endif
      If [F:ITM0]YVELCRODE = 2 Then
        LDES -= "Derecha"
      Endif
    Endif

    # silicon 14mm perfil
    If [F:ITM0]YSILICON = 2 Then
      LDES -= "; con Silicon 14mm Perfil Posición"
      If [F:ITM0]YSILICONAR = 2 Then
        LDES -= "Arriba"
      Endif
      If [F:ITM0]YSILICONAB = 2 Then
        LDES -= "Abajo"
      Endif
      If [F:ITM0]YSILICONIZ = 2 Then
        LDES -= "Izquierda"
      Endif
      If [F:ITM0]YSILICONDE = 2 Then
        LDES -= "Derecha"
      Endif
    Endif

    # ollados para lonas
    If [F:ITM0]YOLLADOSLONA > 0  Then : LDES -= ";con"-num$([F:ITM0]YOLLADOSLONA)-"Ollados para lonas"  : Endif

    # refuerzo para lonas
    If [F:ITM0]YREFLONA = 2 Then
      LDES -= "; Refuerzos para Lonas Posición"
      If [F:ITM0]YREFLONAAR = 2 Then
        LDES -= "Arriba"
      Endif
      If [F:ITM0]YREFLONAAB = 2 Then
        LDES -= "Abajo"
      Endif
      If [F:ITM0]YREFLONAIZ = 2 Then
        LDES -= "Izquierda"
      Endif
      If [F:ITM0]YREFLONADE = 2 Then
        LDES -= "Derecha"
      Endif
    Endif

    # guarda la descripción en tabla
    [F:ITM0]YDESCOMPLETA = LDES
    Trbegin [F:ITM0]
    Rewrite [F:ITM0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif
  If  clalev([F:AXX0]) Then : Close Local File      [F:AXX0] : Endif
  If  clalev([F:ITM0]) Then : Close Local File      [F:ITM0] : Endif

End

#######################
#**
#* limpia caracteres extraños en una cadena
#*
#* @param PCHARIN   > cadena a limpiar
#* @param PCHAROUT  > cadena limpia
#*!
Subprog LIMPIA_STR(PCHARIN,PCHAROUT)
Value     Clbfile  PCHARIN
Variable  Clbfile  PCHAROUT

Local Clbfile PSTR(2) : PSTR=PCHARIN

  PSTR=ctrans(PSTR,"Ã¡" ,"a") : PSTR=ctrans(PSTR,"Ã " ,"a") : PSTR=ctrans(PSTR,"Ã¤" ,"a")
  PSTR=ctrans(PSTR,"Ã¢" ,"a") : PSTR=ctrans(PSTR,"Âª" ,"a") : PSTR=ctrans(PSTR,"Ã?" ,"A")
  PSTR=ctrans(PSTR,"Ã€" ,"A") : PSTR=ctrans(PSTR,"Ã‚" ,"A") : PSTR=ctrans(PSTR,"Ã„" ,"A")
  PSTR=ctrans(PSTR,"Ã©" ,"e") : PSTR=ctrans(PSTR,"Ã¨" ,"e") : PSTR=ctrans(PSTR,"Ã«" ,"e")
  PSTR=ctrans(PSTR,"Ãª" ,"e") : PSTR=ctrans(PSTR,"Ã‰" ,"E") : PSTR=ctrans(PSTR,"Ãˆ" ,"E")
  PSTR=ctrans(PSTR,"ÃŠ" ,"E") : PSTR=ctrans(PSTR,"Ã‹" ,"E") : PSTR=ctrans(PSTR,"Ã­" ,"i")
  PSTR=ctrans(PSTR,"Ã¬" ,"i") : PSTR=ctrans(PSTR,"Ã¯" ,"i") : PSTR=ctrans(PSTR,"Ã®" ,"i")
  PSTR=ctrans(PSTR,"Ã?" ,"I") : PSTR=ctrans(PSTR,"ÃŒ" ,"I") : PSTR=ctrans(PSTR,"Ã?" ,"I")
  PSTR=ctrans(PSTR,"ÃŽ" ,"I") : PSTR=ctrans(PSTR,"Ã³" ,"o") : PSTR=ctrans(PSTR,"Ã²" ,"o")
  PSTR=ctrans(PSTR,"Ã¶" ,"o") : PSTR=ctrans(PSTR,"Ã´" ,"o") : PSTR=ctrans(PSTR,"Ã“" ,"O")
  PSTR=ctrans(PSTR,"Ã’" ,"O") : PSTR=ctrans(PSTR,"Ã–" ,"O") : PSTR=ctrans(PSTR,"Ã”" ,"O")
  PSTR=ctrans(PSTR,"Ãº" ,"u") : PSTR=ctrans(PSTR,"Ã¹" ,"u") : PSTR=ctrans(PSTR,"Ã¼" ,"u")
  PSTR=ctrans(PSTR,"Ã»" ,"u") : PSTR=ctrans(PSTR,"Ãš" ,"U") : PSTR=ctrans(PSTR,"Ã™" ,"U")
  PSTR=ctrans(PSTR,"Ã›" ,"U") : PSTR=ctrans(PSTR,"Ãœ" ,"U") : PSTR=ctrans(PSTR,"Ã±" ,"n")
  PSTR=ctrans(PSTR,"Ã‘" ,"N") : PSTR=ctrans(PSTR,"Ã§" ,"c") : PSTR=ctrans(PSTR,"Ã‡" ,"C")
  PSTR=ctrans(PSTR,"Á" ,"A")  : PSTR=ctrans(PSTR,"À" ,"A")
  PSTR=ctrans(PSTR,"á" ,"a")  : PSTR=ctrans(PSTR,"à" ,"a")
  PSTR=ctrans(PSTR,"É" ,"E")  : PSTR=ctrans(PSTR,"È" ,"E")
  PSTR=ctrans(PSTR,"é" ,"e")  : PSTR=ctrans(PSTR,"è" ,"e")
  PSTR=ctrans(PSTR,"Í" ,"I")  : PSTR=ctrans(PSTR,"Ì" ,"I")
  PSTR=ctrans(PSTR,"í" ,"i")  : PSTR=ctrans(PSTR,"ì" ,"i")
  PSTR=ctrans(PSTR,"Ó" ,"O")  : PSTR=ctrans(PSTR,"Ò" ,"O")
  PSTR=ctrans(PSTR,"ó" ,"o")  : PSTR=ctrans(PSTR,"ò" ,"o")
  PSTR=ctrans(PSTR,"Ú" ,"U")  : PSTR=ctrans(PSTR,"Ù" ,"U")
  PSTR=ctrans(PSTR,"ú" ,"u")  : PSTR=ctrans(PSTR,"ù" ,"U")
  PSTR=ctrans(PSTR,"\" ,"")   : PSTR=ctrans(PSTR,"Â¨" ,"")  : PSTR=ctrans(PSTR,"Âº" ,"")
  PSTR=ctrans(PSTR,"~" ,"")   : PSTR=ctrans(PSTR,"#" ,"")   : PSTR=ctrans(PSTR,"@" ,"")
  PSTR=ctrans(PSTR,"|" ,"")   : PSTR=ctrans(PSTR,"!" ,"")   : PSTR=ctrans(PSTR,'"' ,"")
  PSTR=ctrans(PSTR,"*" ,"")   : PSTR=ctrans(PSTR,"Â·" ,"")  : PSTR=ctrans(PSTR,"$" ,"")
  PSTR=ctrans(PSTR,"%" ,"")   : PSTR=ctrans(PSTR,"&" ,"")   : PSTR=ctrans(PSTR,"(" ,"")
  PSTR=ctrans(PSTR,")" ,"")   : PSTR=ctrans(PSTR,"?" ,"")   : PSTR=ctrans(PSTR,"'" ,"")
  PSTR=ctrans(PSTR,"Â¡" ,"")  : PSTR=ctrans(PSTR,"Â¿" ,"")  : PSTR=ctrans(PSTR,"[" ,"")
  PSTR=ctrans(PSTR,"^" ,"")   : PSTR=ctrans(PSTR,"<" ,"")   : PSTR=ctrans(PSTR,">" ,"")
  PSTR=ctrans(PSTR,"]" ,"")   : PSTR=ctrans(PSTR,"+" ,"")   : PSTR=ctrans(PSTR,"}" ,"")
  PSTR=ctrans(PSTR,"{" ,"")   : PSTR=ctrans(PSTR,"Â´" ,"")  : PSTR=ctrans(PSTR,";" ,"")
  PSTR=ctrans(PSTR,":" ,"")   : PSTR=ctrans(PSTR,"." ,"")   : PSTR=ctrans(PSTR,"/" ,"")

  PCHAROUT = PSTR

End


#######################
#**
#* Devuelve la categoria que tiene asociada el articulo.
#*
#* @param PIMPRESION
#* @param PFABRICACION
#*!
Funprog GET_CATEGORIA(PIMPRESION, PFABRICACION)
  Local Char LRES

  If !clalev([ADI]) Then : Local File ATABDIV [ADI] : Endif

  Filter [F:ADI] Where NUMTAB = 2507 and A2 = PIMPRESION and A3 = PFABRICACION
  Read [F:ADI] First
  If !fstat Then
    LRES = [F:ADI]A1
  Else
    LRES = 'YBP'
  Endif



End LRES


###################################################################################
#**
#* Devuelve el código de proveedor parametrizado en la tabla varia 2508
#*
#* @param LIMPRESION
#* @param LIMPORTACION
#* @param LRANGO
#*!
Funprog GET_PROVEEDOR(PIMPRESION, PFABRICACION, PRANGO)
  Local Char LRES

  If !clalev([ADI]) Then : Local File ATABDIV [ADI] : Endif
#  Infbox "PIMPRESION:" + PIMPRESION
#  Infbox "PFABRICACION:" + PFABRICACION
#  Infbox "PRANGO:" + PRANGO

  # SUBLIMACIÓN E IMPORTADA, NO TENER EN CUENTA EL RANGO
  # MAB.27/10/2020 - Consultor: Ivan. Correo 26/10/2020 16:32
  If PIMPRESION = '02' and PFABRICACION = '02' Then
    Filter [F:ADI] Where NUMTAB = 2508 and A1 = PIMPRESION and A2 = PFABRICACION # and A3 = PRANGO
  Else
    Filter [F:ADI] Where NUMTAB = 2508 and A1 = PIMPRESION and A2 = PFABRICACION and A3 = PRANGO
  Endif
  Read [F:ADI] First
  If !fstat Then
    LRES = [F:ADI]A4
  Else
    LRES = ''
  Endif

End LRES


#######################
#**
#* Generación de traza
#* Si se pasa el titulo la abrirá, si no solo añadirá texto
#*
#* @param PID
#* @param PTITLE
#* @param PTEXTO
#*!
Subprog GENERA_TRAZA(PID, PTITLE, PTEXTO)
Value Char PID
Value Char PTEXTO,PTITLE

  If PTITLE <> "" and PTEXTO = "" Then
    If !GSERVEUR Then
      Call OUVRE_TRACE(PTITLE) From LECFIC
    Endif
  Endif
  If PTITLE = "" and PTEXTO <> "" Then
    Call ECR_TRACE(PID + " - " + PTEXTO,0) From GESECRAN
  Endif

  If PTITLE = "" and PTEXTO = "" Then
    If !GSERVEUR Then
      Call FERME_TRACE From LECFIC
    Endif
  Endif


End

#######################
#**
#* Activa o descactiva campos extra para presupuestos en función de la parametria de la tabla varia 2506
#*
#* @param VALEUR
#*!
Subprog ACTIVAR_CAMPOS(PCAMPO, PNOL, PMASK)
  Value Char PCAMPO
  Value Integer PNOL
  Value Char PMASK

  If !clalev([ZATA]) Then : Local File ATABDIV [ZATA] : Endif


  If PMASK = "PRESUPUESTO" Then
    Local Mask YWZSQHE [YMIA]
  Elsif PMASK = "ARTICULO" Then
    Local Mask YITM1 [YMIA]
  Endif


  Read [ZATA]CODE=2506;PCAMPO
  If !fstat Then
    # activar las caracteristicas del componente extra
    # CANTIDAD
    If [F:ZATA]N1 = 1 Then
      Diszo [M:YMIA]YEXTCANT(PNOL)
    Else
      Actzo [M:YMIA]YEXTCANT(PNOL)
    Endif
    # ARRIBA
    If [F:ZATA]N2 = 1 Then
      Diszo [M:YMIA]YEXTARR(PNOL)
    Else
      Actzo [M:YMIA]YEXTARR(PNOL)
    Endif
    # ABAJO
    If [F:ZATA]N3 = 1 Then
      Diszo [M:YMIA]YEXTABA(PNOL)
    Else
      Actzo [M:YMIA]YEXTABA(PNOL)
    Endif
    # IZQUIERDA
    If [F:ZATA]N4 = 1 Then
      Diszo [M:YMIA]YEXTIZQ(PNOL)
    Else
      Actzo [M:YMIA]YEXTIZQ(PNOL)
    Endif

    # DERECHA
    If [F:ZATA]N5 = 1 Then
      Diszo [M:YMIA]YEXTDER(PNOL)
    Else
      Actzo [M:YMIA]YEXTDER(PNOL)
    Endif

  Endif

End



#**
#*
#*
#* @param PPRECIOUNIDAD
#* @param PFECHA
#* @param PALTO
#* @param PANCHO
#* @param PMATERIAL
#* @param PNUMCOLORES
#* @param PCANTIDAD
#* @param PTIPOITM
#*!
Subprog SP_PRECIOUNIDAD(PCODLIN, PPRECIOUNIDAD, PPRECIOUNIDADEUR, PFECHA, PALTO, PANCHO, PMATERIAL, PNUMCOLORES, PCANTIDAD, PTIPOITM, PTRAZA)
  Variable Decimal PPRECIOUNIDADEUR
  Variable Decimal PPRECIOUNIDAD
  Value Date PFECHA
  Value Char PALTO, PANCHO, PAREA
  Value Decimal PCANTIDAD
  Value Char PMATERIAL, PNUMCOLORES
  Value Integer PTIPOITM
  Value Char PTRAZA

  Local Decimal LALTO           : Raz LALTO
  Local Decimal LANCHO          : Raz LANCHO
  Local Decimal LVALORUNITARIO  : Raz LVALORUNITARIO
  Local Decimal LVALORUNITARIOEUR  : Raz LVALORUNITARIOEUR
  Local Decimal LFOTOLITO       : Raz LFOTOLITO
  Local Decimal LCANTIDAD       : Raz LCANTIDAD
  Local Decimal LAREA           : Raz LAREA
  Local Decimal LAREATOTAL      : Raz LAREATOTAL
  Local Char    LCRITERIO       : Raz LCRITERIO

  LALTO     = arr(val(PALTO) / 100,0.0001)
  LANCHO    = arr(val(PANCHO) / 100,0.0001)
  LCANTIDAD = PCANTIDAD
  LAREA     = arr(LALTO * LANCHO,0.0001)
  LAREATOTAL = LAREA * PCANTIDAD
  #Infbox "ESCRIBO EN LA TRAZA" + GTRACE
  #Call ECR_TRACE("Calculo de precio unitario ", 0 ) From GESECRAN
  #[M:YWQ0]TEXTO = "Calculo de precio unitario "  - chr$(13)


  Call TRAZA_PRECIO(PCODLIN , "", "Calculo de precio unitario",PTRAZA ) From SPEYLIB0

  #[M:YWQ0]TEXTO -= "Alto: " + num$(LALTO) - chr$(13)
  Call TRAZA_PRECIO(PCODLIN , "", "Alto: " + num$(LALTO) - "- Base: " + num$(LANCHO) + " --> Area: " + num$(LAREA),PTRAZA ) From SPEYLIB0
  #[M:YWQ0]TEXTO -= "Material: " + (PMATERIAL) - func AFNC.TEXTRALAN("SPA","ATABDIV","LNGDES","2502", PMATERIAL) - chr$(13)
  Call TRAZA_PRECIO(PCODLIN , "", "Material: " + (PMATERIAL) - func AFNC.TEXTRALAN("SPA","ATABDIV","LNGDES","2502", PMATERIAL) - chr$(13),PTRAZA) From SPEYLIB0
  #[M:YWQ0]TEXTO -= "Colores: " + (PNUMCOLORES) -func AFNC.TEXTRALAN("SPA","ATABDIV","LNGDES","2505", PNUMCOLORES) - chr$(13)
  Call TRAZA_PRECIO(PCODLIN , "", "Colores: " + (PNUMCOLORES) -func AFNC.TEXTRALAN("SPA","ATABDIV","LNGDES","2505", PNUMCOLORES) - chr$(13),PTRAZA) From SPEYLIB0
  #[M:YWQ0]TEXTO -= "Cantidad: " + num$(PCANTIDAD) - chr$(13)
  Call TRAZA_PRECIO(PCODLIN , "", "Cantidad: " + num$(PCANTIDAD) - chr$(13),PTRAZA) From SPEYLIB0
  #Affzo   [M:YWQ0]TEXTO
  If PFECHA = [00/00/0000] Then
     Call TRAZA_PRECIO(PCODLIN , "", "######## Fecha no indicada en el presupuesto. Se toma la fecha actual como referencia. ####### ",PTRAZA) From SPEYLIB0
     PFECHA = date$
  Endif


  # If GUSER = "AIT51" Then : Infbox "AREA:" + num$(LAREA) : Endif
  # If GUSER = "AIT51" Then : Infbox "GTIPOITM:" + num$(PTIPOITM) : Endif
  Case PTIPOITM
    When 1  # obtención del valor unitario en la tarifa de banderas estampadas - 1m2
      #Call ECR_TRACE("Obtener precio de tarifa para bandera estampada de menos de 1m2", 0 ) From GESECRAN
      #[M:YWQ0]TEXTO -= "Tarifa para bandera estampada de menos de 1m2"- chr$(13)
      Call TRAZA_PRECIO(PCODLIN , "", "Tarifa para bandera estampada de menos de 1m2 -  TIPO 1",PTRAZA) From SPEYLIB0
      #Affzo   [M:YWQ0]TEXTO
    # A11 = VALOR UNITARIO SEGÚN TARIFA
      If !clalev([F:YLC0]) Then : Local File YTBEM1LC   [F:YLC0] : Endif
      If !clalev([F:YLD0]) Then : Local File YTBEM1LD   [F:YLD0] : Endif
      Call TRAZA_PRECIO(PCODLIN , "", "Busqueda tarifa a fecha " + num$(PFECHA),PTRAZA) From SPEYLIB0
      Filter [F:YLC0] Where ACTFLG = 2 and STRDAT <= PFECHA and ENDDAT >= PFECHA
      Read   [F:YLC0] First
      If !fstat Then
        # If GUSER = "AIT51" Then : Infbox "Area:"  + num$(LAREA) + " - material:" + [M:SQH2]YMATERIAL(GNUMLIN) + " - colores:" + [M:SQH2]YNUMCOLORES(GNUMLIN) + "- LCANTIDAD:" + num$(LCANTIDAD) :
# Endif
        Call TRAZA_PRECIO(PCODLIN , "", "Busqueda tarifa: " + [F:YLC0]CODTAR + " - Colores: " + PNUMCOLORES + " - Material: " + PMATERIAL + " - Area: " + num$(LAREA),PTRAZA) From SPEYLIB0
        Filter [F:YLD0] Where CODTAR=[F:YLC0]CODTAR and LAREA>=MINAREA and LAREA<=MAXAREA and MATERIAL=PMATERIAL and COLOR=PNUMCOLORES
&       and LCANTIDAD>=MINQTY and LCANTIDAD<=MAXQTY
       # Infbox evalue(LCRITERIO)
        Read   [F:YLD0] First
        If !fstat Then
          LVALORUNITARIO = [F:YLD0]VUNITARIO
          #[M:YWQ0]TEXTO -= "Valor unitario tarifa: " + num$([F:YLD0]VUNITARIO)- chr$(13)
          Call TRAZA_PRECIO(PCODLIN , "", "Valor unitario tarifa en " +[F:YLC0]CUR + ": " + num$([F:YLD0]VUNITARIO),PTRAZA) From SPEYLIB0
          #Affzo   [M:YWQ0]TEXTO
          # If GUSER = "AIT51" Then : Infbox "A113 ("+[F:YLC0]CUR+") ="-num$(LVALORUNITARIO) : Endif
          If [F:YLC0]CUR <> "EUR" Then
            Call CONVERTDIV([F:YLC0]CUR,"EUR",LVALORUNITARIO,1,LVALORUNITARIOEUR) From SPEYLIB0
            # [M:YWQ0]TEXTO -= "Valor unitario tarifa en EUR: " + num$(LVALORUNITARIOEUR)- chr$(13)
            # Call TRAZA_PRECIO(PCODLIN , "", "Valor unitario tarifa en EUR: " + num$(LVALORUNITARIOEUR)) From SPEYLIB0
#            If GUSER = "AIT07" Then : Infbox "A113 (€) ="-num$(LVALORUNITARIO) : Endif
          Endif
        Else
          GESTADO = 1
          #[M:YWQ0]TEXTO -= "Tarifa no econtrada"
          Call TRAZA_PRECIO(PCODLIN , "", "1.Tarifa no econtrada",PTRAZA) From SPEYLIB0
        Endif
        Filter [F:YLD0]
      Else
        GESTADO = 1
        #[M:YWQ0]TEXTO -= "Tarifa no econtrada"
        Call TRAZA_PRECIO(PCODLIN , "", "2.Tarifa no econtrada",PTRAZA) From SPEYLIB0
      Endif
      Filter [F:YLC0]
      PPRECIOUNIDAD = LVALORUNITARIO
      PPRECIOUNIDADEUR = LVALORUNITARIOEUR
      # If GUSER = "AIT51" Then : Infbox "A11 (€) ="-num$(PPRECIOUNIDAD) : Endif
      If  clalev([F:YLC0]) Then : Close Local File      [F:YLC0] : Endif
      If  clalev([F:YLD0]) Then : Close Local File      [F:YLD0] : Endif
    When 2 # obtención de fotolito y valor unitario en la tarifa de banderas estampadas + 1m2
      #Call ECR_TRACE("Obtener precio de fotolito y valor unitario tarifa para bandera estampada de mas de 1m2", 0 ) From GESECRAN
      #[M:YWQ0]TEXTO -= "Precio fotolito y Tarifa para bandera estampada de mas de 1m2"- chr$(13)
       Call TRAZA_PRECIO(PCODLIN , "", "Precio fotolito y Tarifa para bandera estampada de mas de 1m2 -  TIPO 2",PTRAZA) From SPEYLIB0
      #Affzo   [M:YWQ0]TEXTO
    # A11 = (A111 * A112 * A113) + ((A111 * A112 * A114 / CANTIDAD) * (A111 * A112))
      If !clalev([F:YMC0]) Then : Local File YTBEM1MC   [F:YMC0] : Endif
      If !clalev([F:YMD0]) Then : Local File YTBEM1MD   [F:YMD0] : Endif
      Call TRAZA_PRECIO(PCODLIN , "", "Busqueda tarifa a fecha " + num$(PFECHA),PTRAZA) From SPEYLIB0
      Filter [F:YMC0] Where ACTFLG = 2 and STRDAT <= PFECHA and ENDDAT >= PFECHA
      Read   [F:YMC0] First
      If !fstat Then
        Call TRAZA_PRECIO(PCODLIN , "", "Busqueda tarifa: " + [F:YMC0]CODTAR + " - Colores: " + PNUMCOLORES + " - Material: " + PMATERIAL + " - Cantidad: " + num$(LCANTIDAD),PTRAZA) From SPEYLIB0
        Filter [F:YMD0] Where CODTAR=[F:YMC0]CODTAR and COLOR=PNUMCOLORES and MATERIAL=PMATERIAL and LCANTIDAD>=MINQTY and LCANTIDAD<=MAXQTY
        Read   [F:YMD0] First
        If !fstat Then
          LVALORUNITARIO  = [F:YMD0]VUNITARIO
          #Call ECR_TRACE("Valor unitario tarifa: " + num$([F:YMD0]VUNITARIO), 0 ) From GESECRAN
          #[M:YWQ0]TEXTO -= "Valor unitario tarifa: " + num$([F:YMD0]VUNITARIO)- chr$(13)
           Call TRAZA_PRECIO(PCODLIN , "", "Valor M2 tarifa: " + num$([F:YMD0]VUNITARIO) + "¥ M2" ,PTRAZA) From SPEYLIB0
           #Affzo [M:YWQ0]TEXTO
          #If GUSER = "AIT51" Then : Infbox "A113 ("+[F:YMC0]CUR+") ="-num$(LVALORUNITARIO) : Endif
          LFOTOLITO       = val([F:YMD0]FOTOLITO)
          #[M:YWQ0]TEXTO -= "Valor fotolito: " + [F:YMD0]FOTOLITO- chr$(13)
            Call TRAZA_PRECIO(PCODLIN , "", "Valor fotolito: " + [F:YMD0]FOTOLITO,PTRAZA) From SPEYLIB0
          #Affzo   [M:YWQ0]TEXTO
        Else
          #[M:YWQ0]TEXTO -= "Tarifa no econtrada"- chr$(13)
           Call TRAZA_PRECIO(PCODLIN , "", "1.Tarifa no econtrada",PTRAZA) From SPEYLIB0
          GESTADO = 1
        Endif
        Filter [F:YMD0]
      Else
        #[M:YWQ0]TEXTO -= "Tarifa no econtrada"- chr$(13)
        Call TRAZA_PRECIO(PCODLIN , "", "2.Tarifa no econtrada",PTRAZA) From SPEYLIB0
        GESTADO = 1
      Endif
      Filter [F:YMC0]
      If LCANTIDAD <> 0 Then # MA
       # PPRECIOUNIDAD = (LALTO*LANCHO*LVALORUNITARIO) + ((LALTO*LANCHO*LFOTOLITO/LCANTIDAD) * (LALTO*LANCHO))
       PPRECIOUNIDAD = (LAREA*LVALORUNITARIO) + ((LAREA*LFOTOLITO/LCANTIDAD)) # * (LALTO*LANCHO))
       #[M:YWQ0]TEXTO -= "Valor unitario incluido el fotolito: " + num$(PPRECIOUNIDAD)- chr$(13)
        Call TRAZA_PRECIO(PCODLIN , "", "Valor unitario incluido el fotolito: " + num$(PPRECIOUNIDAD) + " --> (AREA*VALORUNITARIO) + (LAREA*FOTOLITO/CANTIDAD)) ",PTRAZA) From SPEYLIB0
       # If GUSER = "AIT51" Then : Infbox "PRECIO UNIDAD EN  ("+[F:YMC0]CUR+") ="-num$(PPRECIOUNIDAD) : Endif
      Endif
      If [F:YMC0]CUR <> "EUR" Then
        Call CONVERTDIV_TR([F:YMC0]CUR,"EUR",PPRECIOUNIDAD,1,PPRECIOUNIDADEUR, PCODLIN, PTRAZA) From SPEYLIB0
        #[M:YWQ0]TEXTO -= "Valor unitario incluido el fotolito en EUR: " + num$(PPRECIOUNIDADEUR)- chr$(13)
        #Call TRAZA_PRECIO(PCODLIN , "", "Valor unitario incluido el fotolito en EUR: " + num$(PPRECIOUNIDADEUR)) From SPEYLIB0
      Endif
      # If GUSER = "AIT51" Then : Infbox "PRECIO UNIDAD FINAL (€) ="-num$(PPRECIOUNIDAD) : Endif
      If  clalev([F:YMC0]) Then : Close Local File      [F:YMC0] : Endif
      If  clalev([F:YMD0]) Then : Close Local File      [F:YMD0] : Endif
    When 4  # obtención del valor unitario en la tarifa de banderas digitales SUBCONTRATADA
     #Call ECR_TRACE("Obtener valor unitario en la tarifa de banderas digitales SUBCONTRATADA", 0 ) From GESECRAN
     #[M:YWQ0]TEXTO -= "Tarifa de banderas digitales SUBCONTRATADA"- chr$(13)
     Call TRAZA_PRECIO(PCODLIN , "", "Tarifa de banderas digitales SUBCONTRATADA -  TIPO 4",PTRAZA) From SPEYLIB0
    # A11 = VALOR UNITARIO SEGÚN TARIFA
      If !clalev([F:YSC0]) Then : Local File YTBDSUBC   [F:YSC0] : Endif
      If !clalev([F:YSD0]) Then : Local File YTBDSUBD   [F:YSD0] : Endif
      Filter [F:YSC0] Where ACTFLG = 2 and STRDAT <= PFECHA and ENDDAT >= PFECHA
      Call TRAZA_PRECIO(PCODLIN , "", "Busqueda tarifa a fecha " + num$(PFECHA),PTRAZA) From SPEYLIB0
      Read   [F:YSC0] First
      If !fstat Then
        Call TRAZA_PRECIO(PCODLIN , "", "Busqueda tarifa: " + [F:YSC0]CODTAR + " - Cantidad: " + num$(LCANTIDAD) + " - Material: " + PMATERIAL + " - Area: " + num$(LAREATOTAL),PTRAZA) From SPEYLIB0
        LAREATOTAL = arr(LALTO * LANCHO,0.0001) * LCANTIDAD # ASI OBTENEMOS EL TOTAL DE M2 # MAB.17082020.NEW
        Filter [F:YSD0] Where CODTAR=[F:YSC0]CODTAR and LAREATOTAL>=MINAREA and LAREATOTAL<=MAXAREA and MATERIAL=PMATERIAL and LCANTIDAD>=MINQTY and LCANTIDAD<=MAXQTY
        Read   [F:YSD0] First
        If !fstat Then
          LVALORUNITARIO = [F:YSD0]VUNITARIO * LAREA
          Call TRAZA_PRECIO(PCODLIN , "",  "Precio según tarifa:  " + num$([F:YSD0]VUNITARIO),PTRAZA) From SPEYLIB0
          Call TRAZA_PRECIO(PCODLIN , "",  "Valor M2 en " + [F:YSC0]CUR + "(PRECIOTARIFA*AREA):" + num$(LVALORUNITARIO),PTRAZA) From SPEYLIB0
          # If GUSER = "AIT51" Then : Infbox "A113 ("+[F:YSC0]CUR+") ="-num$(LVALORUNITARIO) : Endif
          If [F:YSC0]CUR <> "EUR" Then
            Call CONVERTDIV_TR([F:YSC0]CUR,"EUR",LVALORUNITARIO,1,LVALORUNITARIOEUR, PCODLIN, PTRAZA) From SPEYLIB0
            #Call TRAZA_PRECIO(PCODLIN , "",  "Valor unitario en EUR:" + num$(LVALORUNITARIOEUR)) From SPEYLIB0
            # If GUSER = "AIT51" Then : Infbox "A113 (€) ="-num$(LVALORUNITARIO) : Endif
          Endif
        Else
          GESTADO = 1
         # [M:YWQ0]TEXTO -= "Tarifa no econtrada"- chr$(13)
          Call TRAZA_PRECIO(PCODLIN , "",  "1.Tarifa no econtrada",PTRAZA) From SPEYLIB0
        Endif
        Filter [F:YSD0]
      Else
        GESTADO = 1
        #[M:YWQ0]TEXTO -= "Tarifa no econtrada"- chr$(13)
        Call TRAZA_PRECIO(PCODLIN , "",  "2.Tarifa no econtrada",PTRAZA) From SPEYLIB0
      Endif
      Filter [F:YSC0]
      PPRECIOUNIDAD = LVALORUNITARIO
      PPRECIOUNIDADEUR = LVALORUNITARIOEUR
      # If GUSER = "AIT51" Then : Infbox "A11 (€) ="-num$(PPRECIOUNIDAD) : Endif
      If  clalev([F:YSC0]) Then : Close Local File      [F:YSC0] : Endif
      If  clalev([F:YSD0]) Then : Close Local File      [F:YSD0] : Endif
    When 3 # obtención del valor unitario en la tarifa de banderas digitales fabricadas
     #Call ECR_TRACE("Obtener valor unitario en la tarifa de banderas digitales fabricadas", 0 ) From GESECRAN
     #[M:YWQ0]TEXTO -= "Tarifa de banderas digitales fabricadas"- chr$(13)
     Call TRAZA_PRECIO(PCODLIN , "",  "Tarifa de banderas digitales fabricadas  -  TIPO 3",PTRAZA) From SPEYLIB0
    # A11 = VALOR UNITARIO SEGÚN TARIFA
      If !clalev([F:YFC0]) Then : Local File YTBDFABC   [F:YFC0] : Endif
      If !clalev([F:YFD0]) Then : Local File YTBDFABD   [F:YFD0] : Endif
      Filter [F:YFC0] Where ACTFLG = 2 and STRDAT <= PFECHA and ENDDAT >= PFECHA
      Read   [F:YFC0] First
      If !fstat Then
        Call TRAZA_PRECIO(PCODLIN , "", "Busqueda tarifa: " + [F:YFC0]CODTAR + " - Area: " + num$(LAREA) + " - Material: " + PMATERIAL + " - Cantidad: " + num$(LCANTIDAD),PTRAZA) From SPEYLIB0
        Filter [F:YFD0] Where CODTAR=[F:YFC0]CODTAR and LAREA>=MINAREA and LAREA<=MAXAREA and MATERIAL=PMATERIAL and LCANTIDAD>=MINQTY and LCANTIDAD<=MAXQTY
        Read   [F:YFD0] First
        If !fstat Then
          LVALORUNITARIO = [F:YFD0]VUNITARIO
          #[M:YWQ0]TEXTO -= "Valor unitario: " + num$(LVALORUNITARIO)- chr$(13)
          Call TRAZA_PRECIO(PCODLIN , "",  "Valor unitario en  " + [F:YFC0]CUR + ": " + num$(LVALORUNITARIO),PTRAZA) From SPEYLIB0
          # If GUSER = "AIT51" Then : Infbox "A113 ("+[F:YFC0]CUR+") ="-num$(LVALORUNITARIO) : Endif
          If [F:YFC0]CUR <> "EUR" Then
            Call CONVERTDIV([F:YFC0]CUR,"EUR",LVALORUNITARIO,1,LVALORUNITARIO) From SPEYLIB0
            #[M:YWQ0]TEXTO -= "Valor unitario en " + [F:YFC0]CUR +": " + num$(LVALORUNITARIO) - chr$(13)
            #Call TRAZA_PRECIO(PCODLIN , "",  "Valor unitario en " + [F:YFC0]CUR +": " + num$(LVALORUNITARIO)) From SPEYLIB0
            #If GUSER = "AIT51" Then : Infbox "A113 (€) ="-num$(LVALORUNITARIO) : Endif
          Endif
        Else
          GESTADO = 1
          #[M:YWQ0]TEXTO -= "Tarifa no econtrada"- chr$(13)
          Call TRAZA_PRECIO(PCODLIN , "",   "1.Tarifa no econtrada",PTRAZA) From SPEYLIB0
        Endif
        Filter [F:YFD0]
      Else
        GESTADO = 1
        #[M:YWQ0]TEXTO -= "Tarifa no econtrada"- chr$(13)
        Call TRAZA_PRECIO(PCODLIN , "",   "2.Tarifa no econtrada",PTRAZA) From SPEYLIB0
      Endif
      Filter [F:YFC0]

      PPRECIOUNIDAD = LVALORUNITARIO * LAREA
      PPRECIOUNIDADEUR = LVALORUNITARIO * LAREA
      Call TRAZA_PRECIO(PCODLIN , "",  "Valor unitario en EUR: (PRECIO_TARIFA) * AREA --> " +  ": " + num$(LVALORUNITARIO) + "*" + num$(LAREA) + "=" + num$(PPRECIOUNIDADEUR) ,PTRAZA) From SPEYLIB0
      # If GUSER = "AIT51" Then : Infbox "A11 (€) ="-num$(PPRECIOUNIDAD) : Endif
      If  clalev([F:YFC0]) Then : Close Local File      [F:YFC0] : Endif
      If  clalev([F:YFD0]) Then : Close Local File      [F:YFD0] : Endif
  Endcase

End

#**
#*
#*
#* @param PVALORUNITARIOEXTRAS Decimal
#* @param PVALORUNITARIOLOCALEXTRAS Decimal
#* @param PFECHA Date
#* @param PANCHO Decimal
#* @param PLARGO Decimal
#* @param PCANTIDAD Decimal
#* @param PEXTCOD Char
#* @param PEXTLARGO Decimal
#* @param PEXTARR Integer
#* @param PEXTABA Integer
#* @param PEXTIZQ Integer
#* @param PEXTDER Integer
#*!
Subprog SP_VALORUNITARIOEXTRAS(PCODLIN, PVALORUNITARIOEXTRAS,PVALORUNITARIOLOCALEXTRAS, PFECHA, PANCHO, PLARGO, PEXTCANT, PEXTCOD, PEXTLARGO, PEXTARR, PEXTABA, PEXTIZQ, PEXTDER, PTRAZA,  PPRECIOUNIDAD
& , PPRECIOUNIDADEUR, PTIPO)
Variable Decimal PVALORUNITARIOEXTRAS
Variable Decimal PVALORUNITARIOLOCALEXTRAS
Value Date  PFECHA
Value Char PANCHO, PLARGO
Value Decimal PEXTCANT , PEXTLARGO
Value Integer PEXTARR, PEXTABA, PEXTIZQ, PEXTDER
Value Char PEXTCOD
Value Char PTRAZA
Value Decimal  PPRECIOUNIDAD, PPRECIOUNIDADEUR
Value Char PCODLIN
Value Integer PTIPO # TIPODE BANDERA



# Infbox "Dentro Extras:" + PCODLIN + " - "  - PEXTCOD - " - " - func AFNC.TEXTRALAN("SPA","ATABDIV","LNGDES","2506", PEXTCOD)

Local Char    LDIVISA(5)      : Raz LDIVISA
Local Decimal LVALORUNITARIO  : Raz LVALORUNITARIO
Local Decimal LVALORUNITARIOEUR  : Raz LVALORUNITARIOEUR
Local Integer LCUENTAFLAGS    : Raz LCUENTAFLAGS
Local Decimal LTOTALCM        : Raz LTOTALCM
Local Decimal LTOTALM         : Raz LTOTALM
Local Decimal LANCHO, LLARGO, LAREA, LPRECIOM2

If !clalev([F:YEC0]) Then : Local File YTCMPEXC   [F:YEC0] : Endif
If !clalev([F:YED0]) Then : Local File YTCMPEXD   [F:YED0] : Endif

  LANCHO = val(PANCHO)
  LLARGO = val(PLARGO)
  If LLARGO <> 0 Then :  LAREA = (LANCHO/100)*(LLARGO/100) : Endif
  #[M:YWQ0]TEXTO -= "Valor Extra " - PEXTCOD - " - " - func AFNC.TEXTRALAN("SPA","ATABDIV","LNGDES","2506", PEXTCOD) - chr$(13)
  Call TRAZA_PRECIO(PCODLIN , "",   "Búsqueda Tarifa Extra " - PEXTCOD - " - " - func AFNC.TEXTRALAN("SPA","ATABDIV","LNGDES","2506", PEXTCOD),PTRAZA) From SPEYLIB0
  Call TRAZA_PRECIO(PCODLIN , "",   "Búsqueda Tarifa Extra - BASE" - PANCHO - " - ALTO " - PLARGO,PTRAZA) From SPEYLIB0
  Call TRAZA_PRECIO(PCODLIN , "",   "Búsqueda Tarifa Extra - Lados: (Arr - Aba - Izq - Der) " - num$(PEXTARR) + " - " + num$(PEXTABA) + " - " +num$(PEXTIZQ) + " - " + num$(PEXTDER),PTRAZA) From
& SPEYLIB0
  Call TRAZA_PRECIO(PCODLIN , "",   "Búsqueda Tarifa Extra - Cantidad extra: " + num$(PEXTCANT) + " - Largo extra (cm):" + num$(PEXTLARGO) + " - Tipo Bandera:" + num$(PTIPO),PTRAZA) From SPEYLIB0

  # obtención del valor de los componentes extra
  Filter [F:YEC0] Where ACTFLG = 2 and STRDAT <= PFECHA and ENDDAT >= PFECHA
  Read   [F:YEC0] First
  If !fstat Then
    LDIVISA = [F:YEC0]CUR
    # SI EL ARTÍCULO VIENE DEL ASISTENTE, BUSCAMOS PROPIEDADES EN LA TABLA TMP DE EXTRAS DEL PRESUPUESTO
#    If [M:SQH2]YCODLIN <> '' Then
#      If !clalev([F:YTE0]) Then : Local File YTEXTPRE   [F:YTE0] : Endif # MAB.19062020.NEW
#      Filter [F:YTE0] Where YCODLIN = [M:SQH2]YCODLIN(nolign-1)
#    Else # SI EL ARTÍCULO VIENE DEL MAESTRO DE ARTICULOS, BUSCAMOS COMPONENTES EN LA TABLA DE EXTRAS DE ARTICULO
#      If !clalev([F:YTE0]) Then : Local File YTEXTART   [F:YTE0] : Endif
#      Filter [F:YTE0] Where ITMREF = [M:SQH2]ITMREF(nolign-1)
#    Endif
#    For [F:YTE0]
      LCUENTAFLAGS = 0
      LTOTALCM = 0
      LTOTALM = 0
      # If GUSER = "AIT51" Then : Infbox "0.EXTRA: " + [F:YTE0]YEXTCOD : Endif
      # SUMAMOS LA LONGITUD DE TODOS LOS LADOS
      If PEXTARR = 2 Then
          LCUENTAFLAGS += 1
          LTOTALCM += LANCHO
          Call TRAZA_PRECIO(PCODLIN , "",   "Lado Arriba : " + num$(LANCHO) ,PTRAZA) From SPEYLIB0
      Endif

      If PEXTABA = 2 Then
          LCUENTAFLAGS += 1
          LTOTALCM += LANCHO
          Call TRAZA_PRECIO(PCODLIN , "",   "Lado Abajo : " + num$(LANCHO) ,PTRAZA) From SPEYLIB0
      Endif

      If PEXTDER = 2 Then
          LCUENTAFLAGS += 1
          LTOTALCM += LLARGO
          Call TRAZA_PRECIO(PCODLIN , "",   "Lado Derecha : " + num$(LLARGO) ,PTRAZA) From SPEYLIB0
      Endif

      If PEXTIZQ = 2 Then
          LCUENTAFLAGS += 1
          LTOTALCM += LLARGO
          Call TRAZA_PRECIO(PCODLIN , "",   "Lado Izquierda : " + num$(LLARGO),PTRAZA) From SPEYLIB0
      Endif

      # PASAMOS A METROS
      If LTOTALCM <> 0 Then
        LTOTALM = LTOTALCM/100
        Call TRAZA_PRECIO(PCODLIN , "",   "Total Metros lados (A): " + num$(LTOTALM),PTRAZA) From SPEYLIB0
        # If GUSER = "AIT51" Then : Infbox "1.LTOTALM:" + num$(LTOTALM) : Endif
        # Call TRAZA_PRECIO(PCODLIN , "",   "Valor Extra " - PEXTCOD - " - " - func AFNC.TEXTRALAN("SPA","ATABDIV","LNGDES","2506", PEXTCOD)) From SPEYLIB0
      Endif


      # SI TENEMOS CANTIDAD Y LARGO, ES UN TIPO DE EXTRA SIN LADOS, PERO TAMBIÉN HAY QUE SACAR LA MEDIDA
      # POR SI ACASO ACUMULO EN LTOTALM
      If PEXTCANT <> 0 and PEXTLARGO <> 0 Then
          LTOTALM = LTOTALM + (PEXTCANT * PEXTLARGO / 100)
          # If GUSER = "AIT51" Then : Infbox "2.LTOTALM:" + num$(LTOTALM) : Endif
          Call TRAZA_PRECIO(PCODLIN , "",   "Total Metros lados (B): " + num$(LTOTALM) ,PTRAZA) From SPEYLIB0
      Endif
      Call TRAZA_PRECIO(PCODLIN , "",   "Búsqueda tarifa " + [F:YEC0]CODTAR + " - Componente: " + PEXTCOD ,PTRAZA) From SPEYLIB0
      # BUSCAR EL PRECIO DEL METRO EN LA TABLA DE TARIFAS DE EXTRAS
      Filter [F:YED0] Where CODTAR = [F:YEC0]CODTAR and COMPONENTE = PEXTCOD
      Read [F:YED0] First
      If !fstat Then
          LVALORUNITARIO = [F:YED0]VUNITARIO
          LVALORUNITARIOEUR = [F:YED0]VUNITARIOL
          # Si el tipo de artículo es importado, convertimos a EUR el Extra
          If PTIPO <> 3 Then
             Local Decimal LCAMBIO # CAMBIO A EUROS
             Call CONVERTDIV_TR("CNY","EUR",LVALORUNITARIO,1,LVALORUNITARIOEUR, PCODLIN, PTRAZA) From SPEYLIB0
             #Call TRAZA_PRECIO(PCODLIN , "",   "Valor extra despues de CONVERTIR EN DIVIDA: " + num$(LVALORUNITARIOEUR) + " - Variable PVALORUNITARIOLOCALEXTRAS:" + num$(PVALORUNITARIOLOCALEXTRAS),
#& PTRAZA) From SPEYLIB0
             # PVALORUNITARIOLOCALEXTRAS += LVALORUNITARIOEUR
          Endif
#          Call TRAZA_PRECIO(PCODLIN , "",   "Valor en EUR: " + num$(LVALORUNITARIOEUR) ) From SPEYLIB0
        # If GUSER = "AIT51" Then : Infbox "3.VALORUNITARIO:" + num$(LVALORUNITARIO) : Endif
        If LDIVISA <> "EUR" Then
          # de momento quitamos la conversión de divisa, porque los extras ya los tenemos con precios en yuan directamente
          # en la tabla de tarifas de extras
          # Call CONVERTDIV(LDIVISA,"EUR",LVALORUNITARIO,1,LVALORUNITARIO) From SPEYLIB0
        #  If GUSER = "AIT51" Then : Infbox "3.1.VALORUNITARIO en euros:" + num$(LVALORUNITARIO) : Endif
        Endif
        If LTOTALM <> 0 Then
           # Solo mostrar traza en YUAN cuando el tipo de bandera sea diferente a Fabricada
           If PTIPO <> 3 Then
              Call TRAZA_PRECIO(PCODLIN , "",   "Valor tafifa en moneda ¥: " + num$(LVALORUNITARIO),PTRAZA) From SPEYLIB0
           Endif
           # If GUSER = "AIT51" Then : Infbox "4.0.LVALORUNITARIO * LTOTALM:" + num$(LVALORUNITARIO) + "*" + num$(LTOTALM) : Endif
           PVALORUNITARIOEXTRAS += LVALORUNITARIO * LTOTALM
           # If GUSER = "AIT51" Then : Infbox "4.1PVALORUNITARIOEXTRAS:" + num$(PVALORUNITARIOEXTRAS) : Endif
           PVALORUNITARIOLOCALEXTRAS += LVALORUNITARIOEUR * LTOTALM
           # If GUSER = "AIT51" Then : Infbox "5.PVALORUNITARIOLOCALEXTRAS:" + num$(PVALORUNITARIOLOCALEXTRAS) : Endif
           # Solo mostrar traza en YUAN cuando el tipo de bandera sea diferente a Fabricada
          If PTIPO <> 3 Then
           Call TRAZA_PRECIO(PCODLIN , "",   "Total Valor Extra ¥: LVALORUNITARIO * LTOTALM:" + num$(LVALORUNITARIO) + "*" +  num$(LTOTALM) + "=" +  num$(PVALORUNITARIOEXTRAS) ,PTRAZA) From
& SPEYLIB0
          Endif
        Endif
        #If LCUENTAFLAGS > 0 Then
        #  PVALORUNITARIOEXTRAS      += LVALORUNITARIO       * LCUENTAFLAGS
        #  PVALORUNITARIOLOCALEXTRAS += [F:YED0]VUNITARIOL   * LCUENTAFLAGS
        #Endif
        If PEXTCANT <> 0 and LTOTALM = 0 and PEXTLARGO <> 0 Then
           # Solo mostrar traza en YUAN cuando el tipo de bandera sea diferente a Fabricada
          If PTIPO <> 3 Then
            Call TRAZA_PRECIO(PCODLIN , "",   "Valor tarifa en moneda ¥: " + num$(LVALORUNITARIO),PTRAZA) From SPEYLIB0
          Endif
           #If GUSER = "AIT51" Then : Infbox "6.0.lvalorunitario*[F:YTE0]YEXTCANT:" + num$(LVALORUNITARIO) + "*" + num$([F:YTE0]YEXTCANT) : Endif
           PVALORUNITARIOEXTRAS      += LVALORUNITARIO * (PEXTCANT * PEXTLARGO)
           # If GUSER = "AIT51" Then : Infbox "6.1.PVALORUNITARIOEXTRAS:" + num$(PVALORUNITARIOEXTRAS) : Endif
           PVALORUNITARIOLOCALEXTRAS += LVALORUNITARIOEUR * (PEXTCANT * PEXTLARGO)
           # If GUSER = "AIT51" Then : Infbox "7.PVALORUNITARIOLOCALEXTRAS:" + num$(PVALORUNITARIOLOCALEXTRAS) : Endif
           # Solo mostrar traza en YUAN cuando el tipo de bandera sea diferente a Fabricada
          If PTIPO <> 3 Then
             Call TRAZA_PRECIO(PCODLIN , "",   "Total Valor Extra ¥: : LVALORUNITARIO * PEXTCANT * PEXTLARGO:" + num$(LVALORUNITARIO) + "*" +  num$(PEXTCANT) + "*" +  num$(PVALORUNITARIOEXTRAS) +
& "=" + num$(LVALORUNITARIO * (PEXTCANT * PEXTLARGO)),PTRAZA ) From SPEYLIB0
          Endif
#           Call TRAZA_PRECIO(PCODLIN , "",   "Total Valor Extra (EUR): : LVALORUNITARIOEUR * PEXTCANT * PEXTLARGO:" + num$(LVALORUNITARIOEUR) + "*" +  num$(PEXTCANT) + "=" + num$(LVALORUNITARIOEUR *
# (
#& PEXTCANT * PEXTLARGO)) ) From SPEYLIB0
        Endif

        If PEXTCANT <> 0 and LTOTALM = 0 and PEXTLARGO = 0 Then
          # Solo mostrar traza en YUAN cuando el tipo de bandera sea diferente a Fabricada
          If PTIPO <> 3 Then
            Call TRAZA_PRECIO(PCODLIN , "",   "Valor tarifa en moneda ¥: " + num$(LVALORUNITARIO),PTRAZA) From SPEYLIB0
          Endif
           # If GUSER = "AIT51" Then : Infbox "6.1.PVALORUNITARIOEXTRAS:" + num$(PVALORUNITARIOEXTRAS) : Endif
          PVALORUNITARIOEXTRAS      += LVALORUNITARIO  * (PEXTCANT) # NO MULTIPLICO POR CANTIDAD MAB.17112020
          PVALORUNITARIOLOCALEXTRAS += LVALORUNITARIOEUR  * (PEXTCANT) # NO MULTIPLICO POR CANTIDAD MAB.17112020
#           Call TRAZA_PRECIO(PCODLIN , "",   "Valor extra despues de CONVERTIR EN DIVIDA: " + num$(LVALORUNITARIOEUR) + " - Variable PVALORUNITARIOLOCALEXTRAS:" + num$(PVALORUNITARIOLOCALEXTRAS),
#& PTRAZA) From SPEYLIB0
          # Call TRAZA_PRECIO(PCODLIN , "",   "Total Valor Extra ¥: : LVALORUNITARIO * PEXTCANT:" + num$(LVALORUNITARIO) + "*" +  num$(PEXTCANT) + "=" + num$(LVALORUNITARIO * (PEXTCANT)),PTRAZA)
#& From SPEYLIB0
#          Call TRAZA_PRECIO(PCODLIN , "",   "Total Valor Extra (EUR): : LVALORUNITARIOEUR * PEXTCANT:" + num$(LVALORUNITARIOEUR) + "*" +  num$(PEXTCANT) + "=" + num$(LVALORUNITARIOEUR * (PEXTCANT)) )
#& From SPEYLIB0
        Endif

        # ESTE CASO CORRESPONDE AL EXTRA DE MANGA O VAINA

        If PEXTCANT = 0 and LTOTALM <> 0 and PEXTLARGO <> 0 Then
            If LAREA <> 0 Then
              LPRECIOM2 = PPRECIOUNIDAD / LAREA
            Else
              LPRECIOM2 = 0
            Endif
            Call TRAZA_PRECIO(PCODLIN , "",   "Cálculo específico para Vaina",PTRAZA) From SPEYLIB0
            Call TRAZA_PRECIO(PCODLIN , "",   "Precio unidad -->" + num$(PPRECIOUNIDAD) + "-Area -->" + num$(LAREA) +  "-PrecioM2 -->" + num$(LPRECIOM2),PTRAZA) From SPEYLIB0

            LVALORUNITARIO = LTOTALCM/100 * (PEXTLARGO*2/100) *  LPRECIOM2

            Call TRAZA_PRECIO(PCODLIN , "",   "Extra Tipo Vaina: (Precio M2) * (LargoLadoBandera * (LargoVaina * 2)) -->" + num$(LPRECIOM2) + "* (" + num$(LTOTALCM/100) + "*(" + num$((PEXTLARGO*2/100)
& ) + "))=" + num$(LVALORUNITARIO), PTRAZA) From SPEYLIB0

            LPRECIOM2 = PPRECIOUNIDADEUR / LAREA

            LVALORUNITARIOEUR =  LTOTALCM/100 * (PEXTLARGO*2/100) * LPRECIOM2

            If PTIPO <> 3 Then
             Local Decimal LCAMBIO # CAMBIO A EUROS
             Call CONVERTDIV_TR("CNY","EUR",LVALORUNITARIO,1,LVALORUNITARIOEUR, PCODLIN, PTRAZA) From SPEYLIB0
             #Call TRAZA_PRECIO(PCODLIN , "",   "Valor extra despues de CONVERTIR EN DIVIDA: " + num$(LVALORUNITARIOEUR) + " - Variable PVALORUNITARIOLOCALEXTRAS:" + num$(PVALORUNITARIOLOCALEXTRAS),
#& PTRAZA) From SPEYLIB0
             # PVALORUNITARIOLOCALEXTRAS += LVALORUNITARIOEUR
            Endif
            PVALORUNITARIOEXTRAS += LVALORUNITARIO
            PVALORUNITARIOLOCALEXTRAS += LVALORUNITARIOEUR
        Endif

#        If [F:YTE0]YEXTCANT > 0 Then
#          If [F:YTE0]YEXTLARGO > 0 Then
#            PVALORUNITARIOEXTRAS      += LVALORUNITARIO       * [F:YTE0]YEXTCANT * ([F:YTE0]YEXTLARGO / 100)  #([M:SQH2]YLARGO(GNUMLIN) / 100)
#            PVALORUNITARIOLOCALEXTRAS += [F:YED0]VUNITARIOL   * [F:YTE0]YEXTCANT * ([F:YTE0]YEXTLARGO / 100)  #([M:SQH2]YLARGO(GNUMLIN) / 100)
#          Else
#            PVALORUNITARIOEXTRAS      += LVALORUNITARIO       * [F:YTE0]YEXTCANT
#            PVALORUNITARIOLOCALEXTRAS += [F:YED0]VUNITARIOL   * [F:YTE0]YEXTCANT
#          Endif
#        Endif
   #      [M:YWQ0]TEXTO -= "Valor Extra: " - num$(PVALORUNITARIOEXTRAS) - chr$(13)
         If PTIPO = 3 Then
          Call TRAZA_PRECIO(PCODLIN , "",   "Total Valor Extra €: " - num$(PVALORUNITARIOEXTRAS),PTRAZA) From SPEYLIB0
         Else
          Call TRAZA_PRECIO(PCODLIN , "",   "Total Valor Extra ¥: " - num$(PVALORUNITARIOEXTRAS),PTRAZA) From SPEYLIB0
         Endif
   #      [M:YWQ0]TEXTO -= "Valor Extra EUR: " - num$(PVALORUNITARIOLOCALEXTRAS) - chr$(13)
#         Call TRAZA_PRECIO(PCODLIN , "",   "Total Valor Extra EUR: " - num$(PVALORUNITARIOLOCALEXTRAS)) From SPEYLIB0
      Else
        GESTADO = 1
   #     [M:YWQ0]TEXTO -= "Sin Extras" - "\par"
        Call TRAZA_PRECIO(PCODLIN , "",   "Sin Extras",PTRAZA) From SPEYLIB0
      Endif
      Filter [F:YED0]
#    Next
 Endif

 End


#**
#* Añadir texto a línea
#*
#* @param YABRFIC
#* @param YTEXTE - Texto a añadir
#*!
Funprog F_CRELOB(YABRFIC,YTEXTE)

Value Char YABRFIC

# Value Char YTEXTE()
Value Clbfile YTEXTE # poniendo este tipo de variable ya me graba tódos los carácteres.


  Local Char XXRTFTXT(250)(3)
  XXRTFTXT(0) = "" #"{" #"{\rtf1\ansi\ansicpg1252\deff0\deflang1033{\fonttbl{\f0\fswiss\fprq2\fcharset0 MS Sans Serif;}}\viewkind4\uc1\pard\f0\fs17 "
  XXRTFTXT(1) = YTEXTE
  XXRTFTXT(2) = "" # "\par}"
  Local Char X_RET
  Local Integer XXOK
  Local Char XCHAMPLIEN : XCHAMPLIEN = "YYYY"
  Global Char YYYY : YYYY = YABRFIC
  Local Clbfile WWCLOB
  Local Mask ACLOB [M:ACL]
  Setlob WWCLOB With XXRTFTXT
  [M:ACL]CLOB = WWCLOB
  Call CRE_CLOB_ACL(XCHAMPLIEN,XXOK) From TRTX3TEX
  Close Local Mask [M:ACL]
  X_RET = YYYY
  Kill YYYY

End X_RET

