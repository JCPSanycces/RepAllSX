#**
#* Genera traza del calculo del precio
#* Si pasamos itmref y texto en blanco, buscamos y borramos traza actual.
#*
#* @param PYCODLIN
#* @param PYITMREF
#* @param PYTEXTO
#* @param PTRAZA - 0 -> NO ESCRIBE EN TRAZA - RESTO SI QUE ESCRIBE
#*!
Subprog TRAZA_PRECIO(PYCODLIN, PYITMREF, PYTEXTO, PTRAZA)
Value Char PYCODLIN
Value Char PYITMREF
Value Char PYTEXTO()
Value Char PTRAZA
Local Integer RETURN_STATUS
Local Integer LCONT
  If PTRAZA <> "0" Then
    If !clalev([YTLO]) Then : Local File YTLOGPRE [YTLO] : Endif

    If PYITMREF = '' and PYTEXTO = '' Then
      Trbegin [YTLO]
      Delete [F:YTLO] Where YCODLIN = PYCODLIN
      RETURN_STATUS=fstat
      If RETURN_STATUS<>[V]CST_ALOCK Then
        RETURN_STATUS=0
      Endif

     # Error handling

       If RETURN_STATUS
         Rollback
       Else
         Commit
       Endif

    Else

      Filter [F:YTLO] Where YCODLIN = PYCODLIN
      Read [YTLO] First
      If rowcount([YTLO]) = 0 Then
          LCONT = 1
      Else
          LCONT = rowcount([YTLO]) + 1
      Endif
      Trbegin [YTLO]
      [F:YTLO]YIDLIN = LCONT
      [F:YTLO]YCODLIN = PYCODLIN
      [F:YTLO]YITMREF = PYITMREF
      [F:YTLO]YTEXTO = PYTEXTO
      Write [YTLO]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Endif

    Close Local File [YTLO]
  Endif
End

