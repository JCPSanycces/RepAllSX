#**
#* Envía por mail a destinatario una factura de venta
#*
#* @param PFACVEN   > número de la factura de venta
#* @param PINFNAM   > nombre del informe
#* @param PDESTINO  > nombre del destino
#* @param PSTA      > estado
#*!
Subprog ENVMAIL_SIH(PFACVEN, PINFNAM, PDESTINO,PSTA)
Value     Char    PINFNAM
Value     Char    PFACVEN
Value     Char    PDESTINO
Variable  Integer PSTA

Global Char     GCORREO(100)  : Raz GCORREO
Global Char     GNUMFAC(100)  : Raz GNUMFAC
Global Date     GDATFAC
Local  Integer  LVIENEDE40    : Raz LVIENEDE40

  Raz PSTA

  If !clalev([F:YSIV0]) : Local File SINVOICEV   [F:YSIV0] : Endif
  If !clalev([F:YTSV0]) : Local File TABSIVTYP   [F:YTSV0] : Endif
  If !clalev([F:CNT0])  : Local File CONTACT     [F:CNT0]  : Endif

  Local Char    TBPAR(20)(1..15)
  Local Char    TBVAL(20)(1..15)
  Local Integer LIMPFAC # estado impresión factura

  Raz TBPAR, TBVAL, LIMPFAC

  # que exista la factura..
  Read [F:YSIV0]SIV0 = PFACVEN
  If !fstat Then
  GNUMFAC = [F:YSIV0]NUM
  GDATFAC = [F:YSIV0]INVDAT
  If !GSERVEUR Then
    Call TEMPON("Proceso Envío PDF") From GESECRAN
    Call OUVRE_TRACE ("Proceso Envío PDF") From LECFIC
  Endif

    # busca la dirección de correo de todos los contactos
    Filter [F:CNT0] Where BPANUM = [F:YSIV0]BPCINV
    Read [F:CNT0] First
    # si no hay contactos, envía directamente por impresora
    If fstat <> 0 Then
      Call ENVDEST_SIH(PFACVEN,PINFNAM,"IMPDFAC",PSTA)
      Filter [F:CNT0]
    Else
      # contactos con la opción 'Envío + impresión factura'
      Filter [F:CNT0] Where BPANUM = [F:YSIV0]BPCINV and CNTFNC = 16
      For [F:CNT0]
        If [F:CNT0]WEB <> "" Then
          GCORREO = [F:CNT0]WEB
        Else
          mkstat = 2
        Endif

        Call TEMPON("Envío fra. '"+PFACVEN+"' a '"+GCORREO+"'") From GESECRAN

        # solo se lanza cuando son facturas.. (no abonos)
        Filter [F:YTSV0] Where [F:YTSV0]SIVTYP = [F:YSIV0]SIVTYP
        Read [F:YTSV0]TSV1 First
        If !fstat Then
          # solo facturas..
          If [F:YTSV0]INVTYP = 1 or [F:YTSV0]INVTYP = 5 Then
            # tipo de impresión a aplicar al informe..
            If [F:YSIV0]STARPT <> 0
              LIMPFAC = [F:YSIV0]STARPT
            Else
              LIMPFAC = 1
            Endif

            # parámetros del informe
            TBPAR(1)  = "sitedeb"         : TBVAL(1)  = [F:YSIV0]SALFCY
            TBPAR(2)  = "sitefin"         : TBVAL(2)  = [F:YSIV0]SALFCY
            TBPAR(3)  = "facturedeb"      : TBVAL(3)  = [F:YSIV0]NUM
            TBPAR(4)  = "facturefin"      : TBVAL(4)  = [F:YSIV0]NUM
            TBPAR(5)  = "typedeb"         : TBVAL(5)  =  num$([F:YSIV0]INVTYP) # 1 = factura; 5 = proforma
            TBPAR(6)  = "typefin"         : TBVAL(6)  =  num$([F:YSIV0]INVTYP) # 1 = factura; 5 = proforma
            TBPAR(7)  = "clientdeb"       : TBVAL(7)  = [F:YSIV0]BPCINV
            TBPAR(8)  = "clientfin"       : TBVAL(8)  = [F:YSIV0]BPCINV
            TBPAR(9)  = "datedeb"         : TBVAL(9)  = [F:YSIV0]INVDAT
            TBPAR(10) = "datefin"         : TBVAL(10) = [F:YSIV0]INVDAT
            TBPAR(11) = "codimp"          : TBVAL(11) = num$(LIMPFAC) # re-impresión [SIV]STARPT
            TBPAR(12) = "impselections"   : TBVAL(12) = "1" # no
            TBPAR(13) = "duplicata"       : TBVAL(13) = "2" # no

            # lanza el informe..
            Call ETAT(PINFNAM, PDESTINO, "SPA", 0, "", TBPAR, TBVAL) From AIMP3
            Raz GCORREO
          Endif
        Else
          PSTA = 2 # es una factura de abono
        Endif
        If GIMPRESO = 0 Then
          Call ENVDEST_SIH(PFACVEN,PINFNAM,"IMPDFAC",PSTA)
          GIMPRESO = 1
        Endif
      Next
      Filter [F:CNT0]

      # contactos con la opción 'Envío Factura'
      Filter [F:CNT0] Where BPANUM = [F:YSIV0]BPCINV and CNTFNC = 15
      For [F:CNT0]
        If [F:CNT0]WEB <> "" Then
          GCORREO = [F:CNT0]WEB
        Else
          mkstat = 2
        Endif

        Call TEMPON("Envío fra. '"+PFACVEN+"' a '"+GCORREO+"'") From GESECRAN

        # solo se lanza cuando son facturas.. (no abonos)
        Filter [F:YTSV0] Where [F:YTSV0]SIVTYP = [F:YSIV0]SIVTYP
        Read [F:YTSV0]TSV1 First
        If !fstat Then
          # solo facturas..
          If [F:YTSV0]INVTYP = 1 or [F:YTSV0]INVTYP = 5 Then
            # tipo de impresión a aplicar al informe..
            If [F:YSIV0]STARPT <> 0
              LIMPFAC = [F:YSIV0]STARPT
            Else
              LIMPFAC = 1
            Endif

            # parámetros del informe
            TBPAR(1)  = "sitedeb"         : TBVAL(1)  = [F:YSIV0]SALFCY
            TBPAR(2)  = "sitefin"         : TBVAL(2)  = [F:YSIV0]SALFCY
            TBPAR(3)  = "facturedeb"      : TBVAL(3)  = [F:YSIV0]NUM
            TBPAR(4)  = "facturefin"      : TBVAL(4)  = [F:YSIV0]NUM
            TBPAR(5)  = "typedeb"         : TBVAL(5)  = num$([F:YSIV0]INVTYP) # 1 = factura; 5 = proforma
            TBPAR(6)  = "typefin"         : TBVAL(6)  = num$([F:YSIV0]INVTYP) # 1 = factura; 5 = proforma
            TBPAR(7)  = "clientdeb"       : TBVAL(7)  = [F:YSIV0]BPCINV
            TBPAR(8)  = "clientfin"       : TBVAL(8)  = [F:YSIV0]BPCINV
            TBPAR(9)  = "datedeb"         : TBVAL(9)  = [F:YSIV0]INVDAT
            TBPAR(10) = "datefin"         : TBVAL(10) = [F:YSIV0]INVDAT
            TBPAR(11) = "codimp"          : TBVAL(11) = num$(LIMPFAC) # re-impresión [SIV]STARPT
            TBPAR(12) = "impselections"   : TBVAL(12) = "1" # no
            TBPAR(13) = "duplicata"       : TBVAL(13) = "2" # no

            # lanza el informe..
            Call ETAT(PINFNAM, PDESTINO, "SPA", 0, "", TBPAR, TBVAL) From AIMP3
            Raz GCORREO
            GIMPRESO = 1
          Endif
        Else
          PSTA = 2 # es una factura de abono
        Endif
      Next
      Filter [F:CNT0]

      # si no hay contactos con ninguno de los dos envío, lanzan impresora
      If GIMPRESO = 0 Then
        Call ENVDEST_SIH(PFACVEN,PINFNAM,"IMPDFAC",PSTA)
        GIMPRESO = 1                                                                          # ya se ha enviado por impresora
      Endif

    Endif
    Trbegin [F:YSIV0]
    [F:YSIV0]YINVSENT = 2
    Rewrite [F:YSIV0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif

    If !GSERVEUR Then
      Call TEMPOFF() From GESECRAN
      # fin de traza
      Call FERME_TRACE From LECFIC
      # lectura
      Call LEC_TRACE From LECFIC
    Endif
  Else
    PSTA = 1 # no existe la factura
  Endif

  Close Local File [F:YSIV0],[F:YTSV0],[F:CNT0]
  Kill GCORREO,GNUMFAC,GDATFAC
End

#####################################################################
# *******************************************************************
#####################################################################
#**
#* Envía por destino una factura de venta.
#*
#* @param PFACVEN   > número de la factura de venta
#* @param PINFNAM   > nombre del informe
#* @param PDESTINO  > nombre del destino
#* @param PSTA      > estado
#*!
Subprog ENVDEST_SIH(PFACVEN, PINFNAM, PDESTINO,PSTA)
Value     Char    PINFNAM
Value     Char    PFACVEN
Value     Char    PDESTINO
Variable  Integer PSTA

  Raz PSTA

  If !clalev([F:YSIV0]) : Local File SINVOICEV   [F:YSIV0] : Endif
  If !clalev([F:YTSV0]) : Local File TABSIVTYP   [F:YTSV0] : Endif

  Local Char    TBPAR(20)(1..15)
  Local Char    TBVAL(20)(1..15)
  Local Char    LFILE(200)
  Local Integer LIMPFAC # estado impresión factura

  Raz TBPAR, TBVAL, LFILE, LIMPFAC

  # que exista la factura..
  Read [F:YSIV0]SIV0 = PFACVEN
  If !fstat Then
    # solo se lanza cuando son facturas.. (no abonos)
    Filter [F:YTSV0] Where [F:YTSV0]SIVTYP = [F:YSIV0]SIVTYP
    Read [F:YTSV0]TSV1 First
    If !fstat Then
      # solo facturas..
      If [F:YTSV0]INVTYP = 1 Then
        # tipo de impresión a aplicar al informe..
        If [F:YSIV0]STARPT <> 0
          LIMPFAC = [F:YSIV0]STARPT
        Else
          LIMPFAC = 1
        Endif

        # parámetros del informe
        TBPAR(1)  = "sitedeb"         : TBVAL(1)  = [F:YSIV0]SALFCY
        TBPAR(2)  = "sitefin"         : TBVAL(2)  = [F:YSIV0]SALFCY
        TBPAR(3)  = "facturedeb"      : TBVAL(3)  = [F:YSIV0]NUM
        TBPAR(4)  = "facturefin"      : TBVAL(4)  = [F:YSIV0]NUM
        TBPAR(5)  = "typedeb"         : TBVAL(5)  = "1" # factura
        TBPAR(6)  = "typefin"         : TBVAL(6)  = "1" # facura
        TBPAR(7)  = "clientdeb"       : TBVAL(7)  = [F:YSIV0]BPCINV
        TBPAR(8)  = "clientfin"       : TBVAL(8)  = [F:YSIV0]BPCINV
        TBPAR(9)  = "datedeb"         : TBVAL(9)  = [F:YSIV0]INVDAT
        TBPAR(10) = "datefin"         : TBVAL(10) = [F:YSIV0]INVDAT
        TBPAR(11) = "codimp"          : TBVAL(11) = num$(LIMPFAC) # re-impresión [SIV]STARPT
        TBPAR(12) = "impselections"   : TBVAL(12) = "1" # no
        TBPAR(13) = "duplicata"       : TBVAL(13) = "1" # no

        # lanza el informe..
        Call ETAT(PINFNAM, PDESTINO, "SPA", 0, "", TBPAR, TBVAL) From AIMP3

      Endif
    Else
      PSTA = 2 # es una factura de abono
    Endif
  Else
    PSTA = 1 # no existe la factura
  Endif

  Close Local File [F:YSIV0],[F:YTSV0]

End
