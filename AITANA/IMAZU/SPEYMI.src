#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "DEBUT"    Gosub DEBUT
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$DEBUT
  Gosub MUESTRAARTICULO
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$MUESTRAARTICULO
    Local Integer I
    If !clalev([F:ITM2]) Then : Local File ITMMASTER  [F:ITM2] : Endif
    If !clalev([F:YTEA]) Then : Local File YTEXTART   [F:YTEA] : Endif

    Read [F:ITM2]ITM0 = GPARAM1(0)
    If !fstat Then
      # cabecera
      [M:YMI0]ITMREF        = GPARAM1(0)
      [M:YMI0]COMPDES       = [F:ITM2]YDESCOMPLETA
      Affzo [M:YMI0]
      # detalles
      [M:YMI1]REFERENCIA    = [F:ITM2]YREFERENCIA
      [M:YMI1]TIPOIMP       = [F:ITM2]YTIPOIMP
      [M:YMI1]RANGO         = [F:ITM2]YRANGO
      [M:YMI1]FABRICADA     = [F:ITM2]YFABRICADA
      [M:YMI1]MATERIAL      = [F:ITM2]YMATERIAL
      [M:YMI1]ALTO          = [F:ITM2]YALTO
      [M:YMI1]ANCHO         = [F:ITM2]YANCHO
      [M:YMI1]NUMCOLORES    = [F:ITM2]YNUMCOLORES
      [M:YMI1]PESPUNTE      = [F:ITM2]YPESPUNTE
      [M:YMI1]CONFNORMAL    = [F:ITM2]YCONFNORMAL
      [M:YMI1]CONFFLY       = [F:ITM2]YCONFFLY
      Affzo [M:YMI1]
      # extras
#      [M:YMI2]              = [F:ITM2]
#      [M:YMI2]YCINTAREFTAM  = [F:ITM2]YALTO+"x"+[F:ITM2]YANCHO
#      [M:YMI2]YMNGVAINATAM  = [F:ITM2]YALTO+"x"+[F:ITM2]YANCHO
#      [M:YMI2]YCINTASILTAM  = [F:ITM2]YALTO+"x"+[F:ITM2]YANCHO
#      [M:YMI2]YVELCROTAM    = [F:ITM2]YALTO+"x"+[F:ITM2]YANCHO
#      [M:YMI2]YSILICONTAM   = [F:ITM2]YALTO+"x"+[F:ITM2]YANCHO
#      [M:YMI2]YREFLONATAM   = [F:ITM2]YALTO+"x"+[F:ITM2]YANCHO


      Gosub MUESTRA_EXTRAS
    Endif
    Affzo [M:YMI2]

Return


##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################


$MUESTRA_EXTRAS
  Local Integer LCON : Raz LCON
  If !clalev([F:TEA0]) Then : Local File YTEXTART [F:TEA0] : Endif
  Filter [TEA0] Where YITMREF = [M:YMI0]ITMREF  Order By YEXTCOD Asc

  For [TEA0]
    [M:YMI2]YEXTCOD(LCON)  = [F:TEA0]YEXTCOD
    [M:YMI2]YEXTCANT(LCON) = [F:TEA0]YEXTCANT
    [M:YMI2]YEXTARR(LCON)  = [F:TEA0]YEXTARR
    [M:YMI2]YEXTABA(LCON)  = [F:TEA0]YEXTABA
    [M:YMI2]YEXTIZQ(LCON)  = [F:TEA0]YEXTIZQ
    [M:YMI2]YEXTDER(LCON)  = [F:TEA0]YEXTDER
    [M:YMI2]YEXTLARGO(LCON)  = [F:TEA0]YEXTLARGO
    LCON += 1
  Next
  Filter [TEA0]
  [M:YMI2]YNBLIG = LCON
  Close Local File [TEA0]

  Affzo [M:YMI2]15
  Kill LCON
Return

