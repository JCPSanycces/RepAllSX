#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  #If GUSER="AIT51" Then : Infbox ACTION : Endif
Case ACTION
  When "STYLE"      : Gosub STYLE
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$STYLE
  If !clalev([ZBPA]) Then : Local File BPADDRESS [ZBPA] : Endif
  For I = 0 To [M:CNTC]NBCNT
    Read [ZBPA]BPA0=1;[M:BPC0]BPCNUM;[M:CNTC]CNTADD(I)
    If !fstat Then
      [M:CNTC]YCNTADDDES(I) = [F:ZBPA]BPADES
    Else
      [M:CNTC]YCNTADDDES(I) = ''
    Endif
    Affzo [M:CNTC]YCNTADDDES(I)
  Next
  Close Local File [ZBPA]

Return

