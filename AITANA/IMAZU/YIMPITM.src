#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT51" Then : Infbox ACTION : Endif
Case ACTION
  When "FERME"  Then  : Gosub FERME
  When "IMP_CREATION" Then : Gosub IMP_CREATION
  When "AP_IMPORT"  Then   : Gosub AP_IMPORT

  When Default
Endcase

Return

$OUVRE
  Gosub OUVRE From IMPITM
Return


$SAIMSK
  Gosub SAIMSK From IMPITM
Return

$IMP_AVANT_OUVRE

Return

$AP_IMPORT

Return

$IMP_CREATION

   GITMREFPRE = [F:ITM]ITMREF

   If GIMP(98) <> '' Then
    # AÑADIMOS COMPONENTES EXTRA DEL ARTÍCULO
    If !clalev([F:YTEX]) Then : Local File YTEXTPRE  [F:YTEX] : Endif
    If !clalev([F:YTAR]) Then : Local File YTEXTART  [F:YTAR] : Endif
    Filter [F:YTEX] Where YCODLIN = GIMP(98)
    Filter [F:YTAR]
    For [F:YTEX]
      [F:YTAR]YITMREF = [F:ITM]ITMREF
      [F:YTAR]YEXTCOD = [F:YTEX]YEXTCOD
      [F:YTAR]YEXTCANT = [F:YTEX]YEXTCANT
      [F:YTAR]YEXTARR = [F:YTEX]YEXTARR
      [F:YTAR]YEXTABA = [F:YTEX]YEXTABA
      [F:YTAR]YEXTDER = [F:YTEX]YEXTDER
      [F:YTAR]YEXTIZQ = [F:YTEX]YEXTIZQ
      [F:YTAR]YEXTLARGO = [F:YTEX]YEXTLARGO
      Write
    Next
  Endif
Return


$FERME


Return

