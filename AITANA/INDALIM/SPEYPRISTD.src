#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#Infbox ACTION

Case ACTION
    When "DEBUT"        : Gosub DEBUT   # al cargar la pantalla
    When "BOUTON"       : Gosub BOUTON  # se pulsa un botón
    When Default
Endcase
Return


##############################################################
######################    ACCIONES    ########################
##############################################################
$DEBUT
Local Datetime FECHA
  Diszo [M:YPRISTD]YINIVAL                                                     # desactiva el campo Fecha inicio validez
  Diszo [M:YPRISTD]YFINVAL                                                     # desactiva el campo Fecha fin validez
  Diszo [M:YPRISTD]STOFCY                                                      # desactiva el campo Planta stock
  [M:YPRISTD]YFECHAACT  = datesyst
  [M:YPRISTD]YDATEINF   = datesyst
  Affzo [M:YPRISTD]YINIVAL, YFINVAL, YPRIBASE, YFECHAACT, YDATEINF, STOFCY     # refresca los campos de la pantalla
Return

########################################
$BOUTON
Case BOUT
    When "B"     :   Gosub BUSCA                                                # ejecuta la búsqueda
    When "M"     :   Gosub MARCAR_TODOS                                         # marca todos los registros del cuadro
    When "D"     :   Gosub DESMARCAR_TODOS                                      # desmarca todos los registros del cuadro
    When "G"     :   Gosub GUARDAR_PRECIO_ESTANDAR                              # ejecuta la acción de actualizar el precio estándar
    When Default
Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
$BUSCA
  Local Clbfile   LCRIT(0)    :   Raz LCRIT
  Local Integer LCONTROLA     :   Raz LCONTROLA

  Gosub ABRIR_TABLAS
  Gosub BUSCAR_ARTICULOS
  Gosub CERRAR_TABLAS

Return

##############################################################
$ABRIR_TABLAS
  If !clalev([F:ZITV]) : Local File ITMMVT    [F:ZITV]    : Endif
  If !clalev([F:ZITM]) : Local File ITMMASTER [F:ZITM]    : Endif
  If !clalev([F:ZITC]) : Local File ITMCOST   [F:ZITC]    : Endif
  If !clalev([F:ZITP]) : Local File ITMBPS    [F:ZITP]    : Endif
Return

##############################################################
$CERRAR_TABLAS
  If clalev([F:ZITV]) : Close Local File [F:ZITV] : Endif
  If clalev([F:ZITM]) : Close Local File [F:ZITM] : Endif
  If clalev([F:ZITC]) : Close Local File [F:ZITC] : Endif
  If clalev([F:ZITP]) : Close Local File [F:ZITP] : Endif
Return

##############################################################
$BUSCAR_ARTICULOS
Local Integer LCONTROLA     : Raz LCONTROLA
Local Integer LCONT         : Raz LCONT
Local Double  LACTUAL       : Raz LACTUAL
Local Char    LBPS(15)      : Raz LBPS
Local Char    LFAM(15)      : Raz LFAM
Local Char    LSUBF(15)     : Raz LSUBF
Local Char    LGAMA(15)     : Raz LGAMA
Local Decimal LPORBPS       : Raz LPORBPS

  If [M:YPRISTD]YFAMIFIN <> "" Then                                         # filtro por familias
    LCRIT += "[ZITM]TSICOD(0)>=[M:YPRISTD]YFAMIINI and [ZITM]TSICOD(0)<=[M:YPRISTD]YFAMIFIN"
    LCONTROLA = 1
  Endif

  If [M:YPRISTD]YSUBFIN <> "" Then                                          # filtro por subfamilias
    If LCONTROLA = 1 Then
      LCRIT += " & [ZITM]TSICOD(1)>=[M:YPRISTD]YSUBINI and [ZITM]TSICOD(1)<=[M:YPRISTD]YSUBFIN"
    Else
      LCRIT += "[ZITM]TSICOD(1)>=[M:YPRISTD]YSUBINI and [ZITM]TSICOD(1)<=[M:YPRISTD]YSUBFIN"
      LCONTROLA = 1
    Endif
  Endif

  If [M:YPRISTD]YGAMAFIN <> "" Then                                         # filtro por gamas
    If LCONTROLA = 1 Then
      LCRIT += " & [ZITM]TSICOD(2)>=[M:YPRISTD]YGAMAINI and [ZITM]TSICOD(2)<=[M:YPRISTD]YGAMAFIN"
    Else
      LCRIT += "[ZITM]TSICOD(2)>=[M:YPRISTD]YGAMAINI and [ZITM]TSICOD(2)<=[M:YPRISTD]YGAMAFIN"
      LCONTROLA = 1
    Endif
  Endif

  If [M:YPRISTD]YARTFIN <> "" Then                                          # filtro por artículos
    If LCONTROLA = 1 Then
      LCRIT += " & [ZITM]ITMREF>=[M:YPRISTD]YARTINI and [ZITM]ITMREF<=[M:YPRISTD]YARTFIN"
    Else
      LCRIT += "[ZITM]ITMREF>=[M:YPRISTD]YARTINI and [ZITM]ITMREF<=[M:YPRISTD]YARTFIN"
      LCONTROLA = 1
    Endif
  Endif

  If LCRIT <> "" Then
    Filter [ZITM] Where evalue(LCRIT)                                       # filtra por los campos anteriores
  Else
    Filter [ZITM]
  Endif
  For [ZITM]
    If [M:YPRISTD]YPROVINI = "" and [M:YPRISTD]YPROVFIN = "" Then                 # si no tiene informado filtro de proveedores realiza la búsqueda 'normal' por los filtros anteriores
#      Filter [ZITC] Where ITMREF = [F:ZITM]ITMREF and UPDDAT <= [M:YPRISTD]YDATEINF Order By UPDDAT Desc      # filtra el artículo sobre la tabla ITMCOST ordenando por fecha de actualización
      If [M:YPRISTD]STOFCY <> "" Then
        Filter [ZITV] Where ITMREF = [F:ZITM]ITMREF and STOFCY = [M:YPRISTD]STOFCY  # filtra el artículo sobre la tabla ITMMVT
      Else
        Filter [ZITV] Where ITMREF = [F:ZITM]ITMREF
      Endif
#      Read [ZITC] First                                                           # se sitúa sobre el artículo actualizado más recientemente en ITMCOST
#      If !fstat Then
#        LACTUAL = [F:ZITC]VLTTOT                                                  # si existe, muestra el valor del campo VLTTOT
        LACTUAL = [F:ZITM]YPRISTD                                                 # si existe, muestra el valor del campo VLTTOT
#      Else
#        Raz LACTUAL                                                               # si no existe, muestra valor cero
#      Endif
      [M:YPRISTD]YFAMC(LCONT) = [F:ZITM]TSICOD(0)                                 # familia
      [M:YPRISTD]YSUBC(LCONT) = [F:ZITM]TSICOD(1)                                 # subfamilia
      [M:YPRISTD]YGAMC(LCONT) = [F:ZITM]TSICOD(2)                                 # gama
      [M:YPRISTD]YARTC(LCONT) = [F:ZITM]ITMREF                                    # código de artículo
      [M:YPRISTD]YDESC(LCONT) = [F:ZITM]ITMDES1                                   # descripción de artículo
      [M:YPRISTD]YACTC(LCONT) = LACTUAL
      Read [ZITV] First                                                           # se sitúa sobre el artículo en ITMMVT
      If !fstat Then
        Case [M:YPRISTD]YPRIBASE
          When 1        :  [M:YPRISTD]YBASC(LCONT) = [ZITM]YPMP                   # Precio base actualización = Sobre precio medio
          When 2        :  [M:YPRISTD]YBASC(LCONT) = [ZITV]LASRCPPRI              # Precio base actualización = Sobre precio última entrada
#          When 3        :  [M:YPRISTD]YBASC(LCONT) = [ZITC]VLTTOT                 # Precio base actualización = Sobre precio estándar
          When 3        :  [M:YPRISTD]YBASC(LCONT) = [ZITM]YPRISTD                # Precio base actualización = Sobre precio estándar
          When Default  :  Call GET_PRICE([M:YPRISTD]YPRIBASE,[F:ZITM]ITMREF,[M:YPRISTD]YINIVAL,[M:YPRISTD]YFINVAL,[M:YPRISTD]YBASC(LCONT))
        Endcase
      Endif
      Call GET_BPSPRI([F:ZITM]ITMREF,LBPS)                                        # llama a la función que obtiene el proveedor principal del artículo
      Call GET_ITMTSI([F:ZITM]ITMREF,LFAM,LSUBF,LGAMA)                            # llama a la función que obtiene la familia, subfamilia y gama del artículo
      Call GET_PORBPS([F:ZITM]ITMREF,LBPS,LFAM,LSUBF,LGAMA,[M:YPRISTD]YPORC(LCONT))   # llama a la función que obtiene el porcentaje del proveedor principal
      [M:YPRISTD]YINCC(LCONT)     = [M:YPRISTD]YINCREMENTO
      [M:YPRISTD]YPORTOTAL(LCONT) = [M:YPRISTD]YPORC(LCONT) + [M:YPRISTD]YINCREMENTO
      [M:YPRISTD]YNUEC(LCONT) = [M:YPRISTD]YBASC(LCONT) + (([M:YPRISTD]YBASC(LCONT) * [M:YPRISTD]YPORTOTAL(LCONT))/100)
      [M:YPRISTD]YDIFC(LCONT) = [M:YPRISTD]YNUEC(LCONT) - [M:YPRISTD]YACTC(LCONT)
      LCONT += 1
      Filter [ZITC]
      Filter [ZITV]
      Raz LBPS, LFAM, LSUBF, LGAMA, LACTUAL
    Else                                                                    # si tiene informado filtro de proveedores debe buscar que existe el artículo en ITMBPS
      If [M:YPRISTD]YPROVINI <= [M:YPRISTD]YPROVFIN Then                    # comprueba que los límites son válidos
        Filter [ZITP] Where ITMREF = [ZITM]ITMREF and BPSNUM >= [M:YPRISTD]YPROVINI and BPSNUM <= [M:YPRISTD]YPROVFIN
        Read [ZITP] First
        If !fstat Then
#          Filter [ZITC] Where ITMREF = [F:ZITM]ITMREF and UPDDAT <= [M:YPRISTD]YDATEINF Order By UPDDAT Desc
          If [M:YPRISTD]STOFCY <> "" Then
            Filter [ZITV] Where ITMREF = [F:ZITM]ITMREF and STOFCY = [M:YPRISTD]STOFCY  # filtra el artículo sobre la tabla ITMMVT
          Else
            Filter [ZITV] Where ITMREF = [F:ZITM]ITMREF
          Endif
#          Read [ZITC] First
#          If !fstat Then
#            LACTUAL = [F:ZITC]VLTTOT
            LACTUAL = [F:ZITM]YPRISTD
#          Else
#            Raz LACTUAL
#          Endif
          [M:YPRISTD]YFAMC(LCONT) = [F:ZITM]TSICOD(0)                       # familia
          [M:YPRISTD]YSUBC(LCONT) = [F:ZITM]TSICOD(1)                       # subfamilia
          [M:YPRISTD]YGAMC(LCONT) = [F:ZITM]TSICOD(2)                       # gama
          [M:YPRISTD]YARTC(LCONT) = [F:ZITM]ITMREF                          # código de artículo
          [M:YPRISTD]YDESC(LCONT) = [F:ZITM]ITMDES1                         # descripción de artículo
          [M:YPRISTD]YACTC(LCONT) = LACTUAL
          Read [ZITV] First                                                 # se sitúa sobre el artículo en ITMMVT
          If !fstat Then
            Case [M:YPRISTD]YPRIBASE
              When 1        :  [M:YPRISTD]YBASC(LCONT) = [ZITM]YPMP          # Precio base actualización = Sobre precio medio
              When 2        :  [M:YPRISTD]YBASC(LCONT) = [ZITV]LASRCPPRI     # Precio base actualización = Sobre precio última entrada
#              When 3        :  [M:YPRISTD]YBASC(LCONT) = [ZITC]VLTTOT       # Precio base actualización = Sobre precio estándar
              When 3        :  [M:YPRISTD]YBASC(LCONT) = [ZITM]YPRISTD      # Precio base actualización = Sobre precio estándar
              When Default  :  Call GET_PRICE([M:YPRISTD]YPRIBASE,[F:ZITM]ITMREF,[M:YPRISTD]YINIVAL,[M:YPRISTD]YFINVAL,[M:YPRISTD]YBASC(LCONT))
            Endcase
          Endif
          Call GET_BPSPRI([F:ZITM]ITMREF,LBPS)                               # llama a la función que obtiene el proveedor principal del artículo
          Call GET_ITMTSI([F:ZITM]ITMREF,LFAM,LSUBF,LGAMA)                   # llama a la función que obtiene la familia, subfamilia y gama del artículo
          Call GET_PORBPS([F:ZITM]ITMREF,LBPS,LFAM,LSUBF,LGAMA,[M:YPRISTD]YPORC(LCONT))   # llama a la función que obtiene el porcentaje del proveedor
          [M:YPRISTD]YINCC(LCONT)     = [M:YPRISTD]YINCREMENTO
          [M:YPRISTD]YPORTOTAL(LCONT) = [M:YPRISTD]YPORC(LCONT) + [M:YPRISTD]YINCREMENTO
          [M:YPRISTD]YNUEC(LCONT)     = [M:YPRISTD]YBASC(LCONT) + (([M:YPRISTD]YBASC(LCONT) * [M:YPRISTD]YPORTOTAL(LCONT))/100)
          [M:YPRISTD]YDIFC(LCONT)     = [M:YPRISTD]YNUEC(LCONT) - [M:YPRISTD]YACTC(LCONT)
          LCONT += 1
          Filter [ZITC]
          Filter [ZITV]
          Raz LBPS, LFAM, LSUBF, LGAMA, LACTUAL
        Endif
      Else
        Call MESSAGE("Los límites de Proveedores no están bien informados") From GESECRAN
        GOK = -1
      Endif
    Endif
    If !GSERVEUR Then
      Call TEMPON("Buscando artículos") From GESECRAN                         # muestra ventana de progreso
    Endif
  Next
  Filter [ZITM]

  If !GSERVEUR Then
    Call TEMPOFF() From GESECRAN                                              # cierra ventana de progreso
  Endif

  [M:YPRISTD]NBLIG = LCONT
  Gosub MARCAR_TODOS
  Affzo [M:YPRISTD]30

Return

##############################################################
$MARCAR_TODOS
Local Integer LCONT   : Raz LCONT

  For LCONT = 0 To [M:YPRISTD]NBLIG-1     # recorre el cuadro
      [M:YPRISTD]YSELEC(LCONT) = 2        # marca el check
  Next LCONT

  Affzo [M:YPRISTD]30                     # refresca el bloque cuadro (30) de la pantalla

Return

##############################################################
$DESMARCAR_TODOS
Local Integer LCONT   : Raz LCONT

  For LCONT = 0 To [M:YPRISTD]NBLIG-1     # recorre el cuadro
      [M:YPRISTD]YSELEC(LCONT) = 1        # desmarca el check
  Next LCONT

  Affzo [M:YPRISTD]30                     # refresca el bloque cuadro (30) de la pantalla

Return

##############################################################
$GUARDAR_PRECIO_ESTANDAR
Local Integer LCONT     : Raz LCONT
Local Integer LNUMART   : Raz LNUMART

  # inicia la traza si no se lanza la tarea batch
  If !GSERVEUR Then
    Call OUVRE_TRACE("Actualización del precio estándar") From LECFIC
    Call TEMPON("Actualización del precio estándar") From GESECRAN
  Endif

If 1=2 Then         # ***************************************************************************************************************
  If !clalev([F:YITC2]) Then : Local File ITMCOST     [F:YITC2]     : Endif
  If !clalev([F:YFIY])  Then : Local File FISCALYEAR  [F:YFIY]      : Endif
  If !clalev([F:YFCY])  Then : Local File FACILITY    [F:YFCY]      : Endif
  Filter [YFIY] Where [M:YPRISTD]YFECHAACT >= FIYSTR and  [M:YPRISTD]YFECHAACT <= FIYEND
  Read [YFIY] First
  If !fstat Then
    For LCONT = 0 To [M:YPRISTD]NBLIG-1                                         # recorre el cuadro
      If [M:YPRISTD]YSELEC(LCONT) = 2 Then                                      # comprueba que la línea esté seleccionada
        For [F:YFCY]                                                            # se añade un registro por planta
          Trbegin [F:YITC2]
          [F:YITC2]STOFCY     = [F:YFCY]FCY                                     # planta
          [F:YITC2]ITMREF     = [M:YPRISTD]YARTC(LCONT)                         # artículo
          Call GET_ITCSEQ([M:YPRISTD]YARTC(LCONT),[F:YFCY]FCY,[F:YITC2]ITCSEQ)  # valor del campo ITCSEQ
          [F:YITC2]CSTTYP     = 1                                               # tipo de coste
          [F:YITC2]ITCSTRDAT  = [F:YFIY]FIYSTR                                  # inicio de validez
          [F:YITC2]ITCENDDAT  = [F:YFIY]FIYEND                                  # fin de validez
          [F:YITC2]FIYNUM     = [F:YFIY]FIYNUM                                  # código ejercicio
          [F:YITC2]ITCDAT     = [M:YPRISTD]YFECHAACT                            # fecha cálculo
          [F:YITC2]VLTTOT     = [M:YPRISTD]YNUEC(LCONT)                         # coste de valoración
          [F:YITC2]MATTOT     = [M:YPRISTD]YNUEC(LCONT)                         # total material
          [F:YITC2]CLCQTY     = 1                                               # cantidad de cálculo
          Write [F:YITC2]                                                       # añade el registro en la tabla
          If !fstat Then
            Commit
            If !GSERVEUR Then
              Call TEMPON("Artículo '" + num$([M:YPRISTD]YARTC(LCONT)) + "' procesado.") From GESECRAN
            Endif
            LNUMART += 1
          Else
            Rollback
          Endif
        Next                # plantas
      Endif
      LCONT += 1
    Next LCONT              # grid
  Endif

  If clalev([F:YITC2])  Then : Close Local File [F:YITC2]   : Endif
  If clalev([F:YFIY])   Then : Close Local File [F:YFIY]    : Endif
  If clalev([F:YFCY])   Then : Close Local File [F:YFCY]    : Endif
Else   # 1=2
  If !clalev([F:YITM0]) Then : Local File ITMMASTER [F:YITM0] : Endif
  Call DEBTRANS From GLOCK

  # Transacción
  $TR1
    For LCONT = 0 To [M:YPRISTD]NBLIG-1
      If [M:YPRISTD]YSELEC(LCONT) = 2 Then                          # comprueba que la línea esté seleccionada
        GOK = 1
        Trbegin [F:YITM0]
        Readlock [F:YITM0]ITM0 = [M:YPRISTD]YARTC(LCONT)
        If [S]fstat = 1                                             # el campo está en uso
          [V]GOK = -1
          [V]GLOCK = "ITMMASTER"-[M:YPRISTD]YNUEC(LCONT)            # nombre de tabla - nombre del campo
          Goto ROL_TR1
        Elsif [S]fstat                                              # 2,3,... cualquier otro error de acceso al registro
          [V]GOK = 0
          Call RSTA("YITM",[M:YPRISTD]YNUEC(LCONT)) From GLOCK      # abreviatura de la tabla - nombre del campo
          Goto AB_TR1
        Endif
        [F:YITM0]YPRISTD   = [M:YPRISTD]YNUEC(LCONT)
        Rewrite [F:YITM0]
        If [S]fstat                                                 # si no se puede modificar el campo
          [V]GOK = 0
          Call FSTA("YSDH") From GLOCK
          Goto AB_TR1
        Endif
        Commit
        If !GSERVEUR Then
          Call TEMPON("Artículo '" + num$([M:YPRISTD]YARTC(LCONT)) + "' procesado.") From GESECRAN
        Endif
        LNUMART += 1
      Endif
    Next
    If clalev([F:YITM0])  Then : Close Local File     [F:YITM0] : Endif
Endif                                         # ******************************************************************************************

  If !GSERVEUR Then
    Call ECR_TRACE("----------------------------",0) From GESECRAN
    Call ECR_TRACE("Artículos procesados: "+num$(LNUMART),0) From GESECRAN
    Call ECR_TRACE("----------------------------",0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
    Call TEMPOFF() From GESECRAN

    # fin de traza
    Call FERME_TRACE From LECFIC
    # lectura
    Call LEC_TRACE From LECFIC
  Endif

Return

########################################################################
# Rollback de la transacción
$ROL_TR1
Infbox "ROL_TR1"
  Rollback
  Call ROLL From GLOCK                                          # comprueba el número de reintentos que quedan
  If GROLL
    Call ECR_TRACE(mess(17,107,1),1) From GESECRAN              # máximo número de reintentos alcanzado
  Else
    Goto TR1                                                    # puede reintentar una vez más
  Endif
Return

########################################################################
# Abortar la transacción
$AB_TR1
Infbox "AB_TR1"
  Rollback
  Call ECR_TRACE(mess(17,107,1),1) From GESECRAN                # muestra un mensaje de sistema en el idioma correcto
Return


##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
#**
#* obtiene el precio base sobre el cual actualizar
#*
#* @param PTYPE    > tipo de búsqueda
#* @param PITMREF  > código de artículo
#* @param PDATEINF > fecha inicio de validez
#* @param PDATESUP > fecha fin de validez
#* @param PPRI     > devuelve el precio
#*!
Subprog GET_PRICE(PTYPE, PITMREF, PDATEINF, PDATESUP, PPRI)
Variable  Decimal PPRI
Value     Integer PTYPE
Value     Char    PITMREF
Value     Date    PDATEINF
Value     Date    PDATESUP

Local Char LBPSPRI(50)                  # proveedor principal

  # localizamos el proveedor principal por si existen dos tarifas del mismo artículo para varios proveedores
  Call GET_BPSPRI(PITMREF,LBPSPRI)

  If !clalev([F:YPPL])  Then  :  Local File PPRICLIST   [F:YPPL]  : Endif

  # filtra por los parámetros de entrada sobre la tarifa T20
  Filter [YPPL] Where PLI = "T20" and PLICRI2 = PITMREF and PLISTRDAT <= PDATEINF and PLIENDDAT >= PDATESUP and PLICRI1 = LBPSPRI
  Read [YPPL] First
  If !fstat Then
    PPRI = [F:YPPL]PRI
  Else
    Raz PPRI
  Endif
  Filter [YPPL]

  If clalev([F:YPPL])   Then  :   Close Local File [F:YPPL]   :   Endif
End

#######################

#**
#* obtiene el siguiente valor del campo ITCSEQ dentro de la tabla ITMCOST
#*
#* @param PITMREF  > código de artículo
#* @param PSTOFCY  > planta
#* @param PITCSEQ  > devuelve el valor para el campo ITCSEQ
#*!
Subprog GET_ITCSEQ(PITMREF, PSTOFCY, PITCSEQ)
Variable  Integer PITCSEQ
Value     Char    PITMREF
Value     Char    PSTOFCY

  If !clalev([F:YITC3]) Then  : Local File ITMCOST  [F:YITC3] : Endif
  Filter [YITC3] Where ITMREF = PITMREF and STOFCY = PSTOFCY and CSTTYP = 2 and UID = 0     # filtra sobre los parámetros de entrada
  Read [YITC3]  Last
  If !fstat Then
    PITCSEQ = [F:YITC3]ITCSEQ + 1                                                           # devuelve el siguiente al número máximo
  Endif
  Filter [YITC3]
  If clalev([F:YITC3])  Then  : Close Local File  [F:YITC3] : Endif

End

#######################

#**
#* obtiene el proveedor principal del producto
#*
#* @param PITMREF  > código de artículo
#* @param PBPSPRI  > devuelve el proveedor principal
#*!
Subprog GET_BPSPRI(PITMREF, PBPSPRI)
Variable  Char    PBPSPRI
Value     Char    PITMREF

  If !clalev([F:YITP]) Then  : Local File ITMBPS  [F:YITP] : Endif
  Filter [YITP] Where ITMREF = PITMREF and PIO = 0                                          # proveedor principal PIO_= 0, el resto <> 0
  Read [YITP] First
  If !fstat Then
    PBPSPRI = [F:YITP]BPSNUM                                                                # devuelve el proveedor principal
  Endif
  Filter [YITP]
  If clalev([F:YITP])  Then  : Close Local File  [F:YITP] : Endif

End

#######################

#**
#* obtiene la familia, subfamilia y gama del producto
#*
#* @param PITMREF  > código de artículo
#* @param PFAMILIA > devuelve la familia
#* @param PSUBFAM  > devuelve la subfamilia
#* @param PGAMA    > devuelve la gama
#*!
Subprog GET_ITMTSI(PITMREF, PFAMILIA, PSUBFAM, PGAMA)
Variable  Char    PFAMILIA
Variable  Char    PSUBFAM
Variable  Char    PGAMA
Value     Char    PITMREF

  If !clalev([F:YITM]) Then  : Local File ITMMASTER  [F:YITM] : Endif
  Filter [YITM] Where ITMREF = PITMREF                                                      # filtra por código de artículo
  Read [YITM] First
  If !fstat Then
    PFAMILIA  = [F:YITM]TSICOD(0)                                                           # devuelve la familia
    PSUBFAM   = [F:YITM]TSICOD(1)                                                           # devuelve la subfamilia
    PGAMA     = [F:YITM]TSICOD(2)                                                           # devuelve la gama
  Endif
  Filter [YITM]
  If clalev([F:YITM])  Then  : Close Local File  [F:YITM] : Endif

End

#######################

#**
#* obtiene el porcentaje del proveedor principal
#*
#* @param PITMREF  > código de artículo
#* @param PBPS     > proveedor
#* @param PFAMILIA > familia
#* @param PSUBFAM  > subfamilia
#* @param PGAMA    > gama
#* @param PPORBPS  > devuelve el porcentaje del proveedor principal
#*!
Subprog GET_PORBPS(PITMREF, PBPS, PFAMILIA, PSUBFAM, PGAMA, PPORBPS)
Variable  Decimal PPORBPS
Value     Char    PBPS
Value     Char    PITMREF
Value     Char    PFAMILIA
Value     Char    PSUBFAM
Value     Char    PGAMA

#Infbox "ENTRA EN GET_PORBPS"
  If !clalev([F:YPPL2])  Then  :  Local File PPRICLIST   [F:YPPL2]  : Endif

  Filter [F:YPPL2] Where PLI="X3" and PLICRI3 = PGAMA                                       # filtra sobre la tarifa X3 (familia/subfamilia/gama)
  Read   [F:YPPL2] First
  If !fstat Then                                                                            # si existe Tarifa 3
    PPORBPS = [F:YPPL2]DCGVAL(7)                                                            # devuelve el porcentaje (coge 7 por parametrización de estructura)
    Filter [F:YPPL2]                                                                        # desactiva el filtro
  Else                                                                                      # si no existe en X3
    Filter [F:YPPL2]                                                                        # desactiva el filtro anterior
    Filter [F:YPPL2] Where PLI="X2" and PLICRI2 = PSUBFAM                                   # filtra sobre la tarifa X2 (familia/subfamilia)
    Read   [F:YPPL2] First
    If !fstat Then                                                                          # si existe Tarifa 2
      PPORBPS = [F:YPPL2]DCGVAL(7)                                                          # devuelve el porcentaje (coge 7 por parametrización de estructura)
      Filter [F:YPPL2]                                                                      # desactiva el filtro
    Else                                                                                    # si no existe en X2
      Filter [F:YPPL2]                                                                      # desactiva el filtro anterior
      Filter [F:YPPL2] Where PLI="X1" and PLICRI1 = PFAMILIA                                # filtra sobre la tarifa X1 (familia)
      Read   [F:YPPL2] First
      If !fstat Then                                                                        # si existe Tarifa 1
        PPORBPS = [F:YPPL2]DCGVAL(7)                                                        # devuelve el porcentaje (coge 7 por parametrización de estructura)
        Filter [F:YPPL2]                                                                    # desactiva el filtro
      Else                                                                                  # si no existe en X1
        Filter [F:YPPL2]                                                                    # desactiva el filtro anterior
        Filter [F:YPPL2] Where PLI="X4" and PLICRI1 = PBPS                                  # filtra sobre la tarifa X4 (porcentaje por defecto para proveedor)
        Read   [F:YPPL2] First
        If !fstat Then                                                                      # si existe Tarifa 4
          PPORBPS = [F:YPPL2]DCGVAL(7)                                                      # devuelve el porcentaje (coge 7 por parametrización de estructura)
          Filter [F:YPPL2]                                                                  # desactiva el filtro anterior
        Else
          Raz PPORBPS                                                                       # si no existe devuelve 0
        Endif
      Endif
    Endif
  Endif

  If clalev([F:YPPL2])  Then  : Close Local File  [F:YPPL2] : Endif

End
##############################################################
#################    ACCIONES DE BOTÓN    ####################
##############################################################
$DESACTIVA_VIGENCIA
  Raz   [M:YPRISTD]YINIVAL, YFINVAL
  Affzo [M:YPRISTD]YINIVAL, YFINVAL
  Diszo [M:YPRISTD]YINIVAL
  Diszo [M:YPRISTD]YFINVAL
Return

######################################################################################
$ACTIVA_VIGENCIA
  Actzo [M:YPRISTD]YINIVAL
  Actzo [M:YPRISTD]YFINVAL
Return

######################################################################################
$DESACTIVA_PLANTA
  Raz   [M:YPRISTD]STOFCY
  Affzo [M:YPRISTD]STOFCY
  Diszo [M:YPRISTD]STOFCY
Return

######################################################################################
$ACTIVA_PLANTA
  Actzo [M:YPRISTD]STOFCY
Return
######################################################################################

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Después del campo en el grid 'Nuevo'
######################################################################################
Subprog AP_YPRIBASE(VALEUR)
Variable Integer VALEUR
Global   Char    BUSCA_POR(10)

  Case VALEUR
    When  1   : Gosub DESACTIVA_VIGENCIA : Gosub DESACTIVA_PLANTA             # Precio base actualización = Sobre precio medio
    When  2   : Gosub DESACTIVA_VIGENCIA : Gosub ACTIVA_PLANTA                # Precio base actualización = Sobre precio última entrada
    When  3   : Gosub DESACTIVA_VIGENCIA : Gosub DESACTIVA_PLANTA             # Precio base actualización = Sobre precio estándar
    When  4   : Gosub ACTIVA_VIGENCIA    : Gosub DESACTIVA_PLANTA             # Precio base actualización = Sobre precio de reposición
    When  5   : Gosub ACTIVA_VIGENCIA    : Gosub DESACTIVA_PLANTA             # Precio base actualización = Sobre precio de reposición nuevo
  Endcase

  Affzo [M:YPRISTD]YINIVAL, YFINVAL
End

######################################################################################
Subprog AP_YNUEC(VALEUR)
Variable Decimal VALEUR

  [M:YPRISTD]YDIFC(nolign-1) = VALEUR - [M:YPRISTD]YACTC(nolign-1)
  Affzo [M:YPRISTD]YDIFC(nolign-1)

End


##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
#######################

#**
#* lanza la búsqueda de precio estándar para un proveedor concreto
#*
#* @param PBPS     > proveedor
#*!
Subprog GET_PRISTD(PBPS)
Value     Char    PBPS

  If !clalev([M:YPRISTD]) Then : Local Mask YPRISTD [M:YPRISTD] : Endif

[M:YPRISTD]YPROVINI = PBPS
[M:YPRISTD]YPROVFIN = PBPS
Affzo [M:YPRISTD]

End

