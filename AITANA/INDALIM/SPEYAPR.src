##############################################################
$ASIG_MASIVA_ART_ALTERNATIVO
Local Integer LCON        : Raz LCON
Local Char    LALTER(30)  : Raz LALTER

  If !clalev([F:YITM3]) Then : Local File ITMMASTER [F:YITM3] : Endif
  Read [F:YITM3]ITM0 = [M:YAPR0]ITMREF
  If !fstat Then
    LALTER  = [F:YITM3]RPLITM
  Endif
  For LCON = 0 To [M:YAPR0]NBAPR-1
    [S]nolign = LCON + 1
    Call AM_YARTALTER(LALTER)
  Next
  If clalev([F:YITM3]) Then : Close Local File [F:YITM3] : Endif

Return

##############################################################
$SALIR
  Raz [M:YAPR0]
  FIN = 1
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Después de modificar el campo "Artículo"
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local Integer LCON : Raz LCON

  If !clalev([F:YYITV8]) Then : Local File YITMMVT  [F:YYITV8] : Endif
  Read [F:YYITV8]YITV0 = VALEUR;[M:YAPR0]STOFCY
  If !fstat Then
    [M:YAPR0]YTOTSTO  = [F:YYITV8]YTOTEXIST
    [M:YAPR0]YRESTO   = [F:YYITV8]YRESHOJAS
    [M:YAPR0]YPDTESTO = [F:YYITV8]ORDSTO
  Endif

  If !clalev([F:YYSOH8]) Then : Local File YSORDER   [F:YYSOH8] : Endif
  If !clalev([F:YSOP8])  Then : Local File SORDERP   [F:YSOP8]  : Endif
  If !clalev([F:YITM8])  Then : Local File ITMMASTER [F:YITM8]  : Endif
  If !clalev([F:YYSOQ8]) Then : Local File YSORDERQ  [F:YYSOQ8] : Endif
  Filter [F:YYSOQ8] Where ITMREF = VALEUR and SALFCY = [M:YAPR0]STOFCY
  For [F:YYSOQ8]
    Filter [F:YYSOH8] Where SOHNUM = [F:YYSOQ8]SOHNUM
    Read [F:YYSOH8] First
    Filter [F:YSOP8]  Where SOHNUM = [F:YYSOQ8]SOHNUM and ITMREF = VALEUR
    Read [F:YSOP8] First
    [M:YAPR0]SOHNUM(LCON)     = [F:YYSOQ8]SOHNUM
    [M:YAPR0]BPCORD(LCON)     = [F:YSOP8]BPCORD
    [M:YAPR0]YITMREF(LCON)    = VALEUR
    [M:YAPR0]SOPLIN(LCON)     = [F:YYSOQ8]SOPLIN
    [M:YAPR0]SAU(LCON)        = [F:YYSOQ8]SAU
    [M:YAPR0]QTY(LCON)        = [F:YYSOQ8]QTY
    [M:YAPR0]YUNV(LCON)       = [F:YYSOQ8]YUNV
    [M:YAPR0]ALLQTY(LCON)     = [F:YYSOQ8]ALLQTY
    [M:YAPR0]YALLQTY(LCON)    = [F:YYSOQ8]ALLQTY
    [M:YAPR0]NETPRI(LCON)     = [F:YSOP8]NETPRI
    [M:YAPR0]YSAU(LCON)       = [F:YYSOQ8]SAU
    [M:YAPR0]GROPRI(LCON)     = [F:YSOP8]GROPRI
    LCON += 1
    Filter [F:YYSOH8]
    Filter [F:YSOP8]
  Next
  Filter [F:YYSOQ8]
  [M:YAPR0]NBAPR = LCON
  Affzo [M:YAPR0]

  If clalev([F:YYITV8])  Then : Close Local File   [F:YYITV8] : Endif
  If clalev([F:YYSOQ8])  Then : Close Local File   [F:YYSOQ8] : Endif
  If clalev([F:YYSOH8])  Then : Close Local File   [F:YYSOH8] : Endif
  If clalev([F:YSOP8])   Then : Close Local File   [F:YSOP8]  : Endif
  If clalev([F:YITM8])   Then : Close Local File   [F:YITM8]  : Endif

End


######################################################################################

######################################################################################
## Después de modificar el campo "Artículo alternativo"
######################################################################################
Subprog AM_YARTALTER(VALEUR)
Variable Char    VALEUR()

  If !clalev([F:YITM9]) Then : Local File ITMMASTER [F:YITM9] : Endif
  Filter [F:YITM9] Where ITMREF = VALEUR
  Read [F:YITM9] First
  If !fstat Then
    [M:YAPR0]YSAU(nolign-1) = [F:YITM9]SAU                                        # asigna la unidad de venta del artículo alternativo
  Endif
  Filter [F:YITM9]
  If clalev([F:YITM9]) Then : Close Local File [F:YITM9] : Endif

  If !clalev([F:YITS9]) Then : Local File ITMSALES [F:YITS9] : Endif
  Filter [F:YITS9] Where ITMREF = VALEUR
  Read [F:YITS9] First
  If !fstat Then
    [M:YAPR0]GROPRI(nolign-1) = [F:YITS9]BASPRI                                   # asigna el precio de venta del artículo alternativo
  Endif
  Filter [F:YITS9]
  If clalev([F:YITS9]) Then : Close Local File [F:YITS9] : Endif
  [M:YAPR0]YARTALTER(nolign-1) = VALEUR                                           # asigna el código del artículo alternativo

  If !clalev([F:YYITV9]) Then : Local File YITMMVT [F:YYITV9] : Endif
  Filter [F:YYITV9] Where ITMREF = VALEUR
  Read [F:YYITV9] First
  If fstat Then                                                                   # el artículo no está en la tabla temporal YITMMVT
    If !clalev([F:YITV9]) Then : Local File ITMMVT [F:YITV9] : Endif
    Filter [F:YITV9] Where ITMREF = VALEUR
    Read [F:YITV9] First
    Trbegin [F:YYITV9]
    If !fstat Then
      [F:YYITV9]ITMREF     = VALEUR
      [F:YYITV9]STOFCY     = [M:YAPR0]STOFCY
      [F:YYITV9]STU        = [M:YAPR0]YSAU(nolign-1)
      [F:YYITV9]PHYSTO     = [F:YITV9]PHYSTO
      [F:YYITV9]YRESHOJAS  = [F:YITV9]GLOALL + [F:YITV9]PHYALL
      [F:YYITV9]ORDSTO     = [F:YITV9]ORDSTO
      [F:YYITV9]SALSTO     = [F:YITV9]SALSTO
      [F:YYITV9]YPREPQTY   = [F:YITV9]PHYSTO - ([F:YITV9]GLOALL + [F:YITV9]PHYALL)
      [F:YYITV9]YTOTEXIST  = [F:YITV9]PHYSTO
      Write [F:YYITV9]                                                             # añade el artículo a la tabla temporal YITMMVT
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Endif
    Filter [F:YITV9]
    If clalev([F:YITV9])  Then : Close Local File  [F:YITV9] : Endif
  Endif
  Filter [F:YYITV9]

  Filter [F:YYITV9] Where ITMREF = [M:YAPR0]ITMREF
  Trbegin [F:YYITV9]
  Read [F:YYITV9] First
  If !fstat Then
    [F:YYITV9]PHYSTO = [F:YYITV9]PHYSTO + [M:YAPR0]ALLQTY(nolign-1)
    [M:YAPR0]ALLQTY(nolign-1) = 0
    Diszo [M:YAPR0]ALLQTY(nolign-1)
    Diszo [M:YAPR0]YUNV(nolign-1)
    Rewrite [F:YYITV9]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif
  If clalev([F:YYITV9])  Then : Close Local File   [F:YYITV9] : Endif

  Call AM_ALLQTY([M:YAPR0]ALLQTY(nolign-1))
  [M:YAPR0]ALLQTY(nolign-1) = 0

  Affzo [M:YAPR0]YSAU,GROPRI,ALLQTY,YARTALTER

End


######################################################################################

######################################################################################
## Después de modificar el campo "Cantidad preparada"
######################################################################################
Subprog AM_YPREQTY(VALEUR)
Variable Decimal VALEUR
Local Decimal DIFERENCIA : Raz DIFERENCIA
Local Char LITMREF(25) : Raz LITMREF

  If [M:YAPR0]YARTALTER(nolign-1) = "" Then
    LITMREF = [M:YAPR0]ITMREF(nolign-1)
  Else
    LITMREF = [M:YAPR0]YARTALTER(nolign-1)
  Endif

  DIFERENCIA = [M:YAPR0]YPREQTY(nolign-1) - VALEUR

  If !clalev([F:YYITV0]) Then : Local File YITMMVT  [F:YYITV0] : Endif
  If !clalev([F:YYSOQ0]) Then : Local File YSORDERQ [F:YYSOQ0] : Endif
  Trbegin [F:YYSOQ0]
  Filter [F:YYSOQ0] Where SOHNUM = [M:YAPR0]SOHNUM(nolign-1) and SOPLIN = [M:YAPR0]SOPLIN(nolign-1)
  Read [F:YYSOQ0] First
  If !fstat Then
    [F:YYSOQ0]ALLQTY = VALEUR                                   # actualiza el valor del campo (cantidad asignada)
    Rewrite [F:YYSOQ0]
    Read [F:YYITV0]YITV0 = LITMREF;[F:YYSOQ0]SALFCY
    [F:YYITV0]PHYSTO = [F:YYITV0]PHYSTO + DIFERENCIA            # actualiza el campo de la tabla temporal de stocks
    If [F:YYITV0]PHYSTO >= 0 Then
      Rewrite [F:YYITV0]
    Else
      Call MESSAGE("No hay stock suficiente") From GESECRAN
      [M:YAPR0]ALLQTY(nolign-1) = VALEUR + DIFERENCIA
      Affzo [M:YAPR0]ALLQTY
      GERR = 1 : mkstat = 2
    Endif
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif
  Filter [F:YYSOQ0]
  If clalev([F:YYSOQ0])  Then : Close Local File [F:YYSOQ0] : Endif
  If clalev([F:YYITV0])  Then : Close Local File [F:YYITV0] : Endif

End


######################################################################################

######################################################################################
## Al modificar el campo "Ctd. asignada"
######################################################################################
Subprog AM_ALLQTY(VALEUR)
Variable Decimal VALEUR
Local Double DIFERENCIA : Raz DIFERENCIA

  DIFERENCIA = [M:YAPR0]ALLQTY(nolign-1) - VALEUR

  If !clalev([F:YYITVA]) Then : Local File YITMMVT  [F:YYITVA] : Endif
  If !clalev([F:YYSOQA]) Then : Local File YSORDERQ [F:YYSOQA] : Endif
  Trbegin [F:YYSOQA]
  Filter [F:YYSOQA] Where SOHNUM = [M:YAPR0]SOHNUM(nolign-1) and SOPLIN = [M:YAPR0]SOPLIN(nolign-1)
  Read [F:YYSOQA] First
  If !fstat Then
    [F:YYSOQA]ALLQTY = VALEUR                                    # actualiza el valor del campo (cantidad asignada)
    Rewrite [F:YYSOQA]
    Read [F:YYITVA]YITV0 = [F:YYSOQA]ITMREF;[F:YYSOQA]SALFCY
    [F:YYITVA]PHYSTO = [F:YYITVA]PHYSTO + DIFERENCIA             # actualiza el campo de la tabla temporal de stocks
    If [F:YYITVA]PHYSTO >= 0 Then                                # VALIDAR CON IVÁN QUE LA COMPARACIÓN TIENE QUE SE MAYOR O IGUAL QUE CERO!!!!!!!!!!!!!!!
      Rewrite [F:YYITVA]
    Else
      Call MESSAGE("No hay stock suficiente") From GESECRAN
      [M:YAPR0]ALLQTY = VALEUR + DIFERENCIA
      Affzo [M:YAPR0]ALLQTY
      GERR = 1 : mkstat = 2
    Endif
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif
  Filter [F:YYSOQA]
  If clalev([F:YYSOQA])  Then : Close Local File [F:YYSOQA] : Endif
  If clalev([F:YYITVA])  Then : Close Local File [F:YYITVA] : Endif

End


######################################################################################

######################################################################################
## Después pinchar en el botón "Artículo alternativo" de la línea
######################################################################################
Subprog B10_YARTALTER(VALEUR)
Variable Char    VALEUR()

  If !clalev([F:YITM4]) Then : Local File ITMMASTER [F:YITM4] : Endif
  Read [F:YITM4]ITM0 = [M:YAPR0]ITMREF
  If !fstat Then
    VALEUR              = [F:YITM4]RPLITM
    [M:YAPR0]YARTALTER  = [F:YITM4]RPLITM
    Affzo [M:YAPR0]ITMREF
  Endif

  If clalev([F:YITM4]) Then : Close Local File [F:YITM4] : Endif

End

