#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif

  Case ACTION
    When "SEL_LISTE"  : Gosub SEL_LISTE
    When "VERF_LISTE" : Gosub VERF_LISTE
    When "DEBUT"      : Gosub DEBUT
    When "BOUTON"     : Gosub BOUTON
   When Default
  Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$SEL_LISTE
  Case LISTE
    When "YSELITMALT"   : Gosub SEL_YSELITMALT
  Endcase

Return

##############################################################
$VERF_LISTE
Return

##############################################################
$DEBUT
  [M:YAPR0]STOFCY = GPARAM1(0)
  Affzo [M:YAPR0]STOFCY
Return

##############################################################
$BOUTON
  Case BOUT
    When "a"    : Gosub APLICAR_MODIFICACIONES
    When "t"    : Gosub ASIG_MASIVA_ART_ALTERNATIVO
    When "x"    : Gosub SALIR
#    When "r"    : Gosub RESTAURAR_CANTIDAD_PROPUESTA
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$SEL_YSELITMALT
  If !clalev([F:YITM1]) Then : Local File ITMMASTER [F:YITM1] : Endif

  Local Char MYFILTER(250)
  MYFILTER="1=1"

  If PARAM(1) <>""
    MYFILTER-="& [F:YITM1]ITMREF='"+PARAM(1)+"'"
  Endif

  Filter [F:YITM1] Where evalue([L]MYFILTER)

  Local Char TEXTE(80)(1..200,1..3)
  Local Char TIT (50)(0..3)

  NBTEX=0

  For [YITM1]
   NBTEX += 1
   TEXTE(NBTEX,1) = [YITM1]ITMREF
   TEXTE(NBTEX,2) = [YITM1]ITMDES1
   TEXTE(NBTEX,3) = [YITM1]RPLITM

   TEX(NBTEX)   = [YITM1]RPLITM

  Next

  TIT(0) = "Artículos de reemplazo para"-PARAM(1)
  #Columnas
  TIT(1) = "Cód. artículo"
  TIT(2) = "Descripción"
  TIT(3) = "Artículo de reemplazo"

  If NBTEX=0 : Infbox "No hay Registros a seleccionar" : Endif

  Filter [F:YITM1]

Return

##############################################################
$VERF_YSELITMALT

  If !clalev([F:YITM2]) Then : Local File ITMMASTER [F:YITM2] : Endif
  Filter [F:YITM2] Where ITMREF = [F:YITM]RPLITM
  Read [F:YITM2] First
  If !fstat Then
    [M:YAPR0]YSAU(nolign-1)   = [F:YITM2]SAU
  Endif
  Filter [F:YITM2]
  If clalev([F:YITM2]) Then : Close Local File [F:YITM2] : Endif

  If !clalev([F:YITS2]) Then : Local File ITMSALES [F:YITS2] : Endif
  Filter [F:YITS2] Where ITMREF = [F:YITM]RPLITM
  Read [F:YITS2] First
  If !fstat Then
    [M:YAPR0]GROPRI(nolign-1) = [F:YITS2]BASPRI
  Endif
  Filter [F:YITS2]
  If clalev([F:YITS2]) Then : Close Local File [F:YITS2] : Endif

  Affzo [M:YAPR0]YSAU, GROPRI

Return

##############################################################
$APLICAR_MODIFICACIONES

Local Integer LCON : Raz LCON
  If !clalev([F:YYSOQ6]) Then : Local File YSORDERQ [F:YYSOQ6] : Endif
  Trbegin [F:YYSOQ6]
  For LCON = 0 To [M:YAPR0]NBAPR-1
    Read [F:YYSOQ6]YSOQ0 = [M:YAPR0]SOHNUM(LCON);[M:YAPR0]SOPLIN(LCON)
    If [M:YAPR0]YARTALTER(LCON) <> "" Then
      [F:YYSOQ6]YSELEC      = 2
      [F:YYSOQ6]YARTALTER   = [M:YAPR0]YARTALTER(LCON)
      [F:YYSOQ6]YUNV        = [M:YAPR0]YSAU(LCON)
      [F:YYSOQ6]ALLQTY      = [M:YAPR0]YPREQTY(LCON)
      Rewrite [F:YYSOQ6]
    Endif
  Next
  Commit
  If clalev([F:YYSOQ6])  Then : Close Local File    [F:YYSOQ6] : Endif

  Gosub SALIR

  Effzo [M:YEXP1]
  Raz LCON
  If !clalev([F:YYSOH6]) Then : Local File YSORDER [F:YYSOH6] : Endif
  For [YYSOH6]
    [M:YEXP1]SOHNUM(LCON)     = [F:YYSOH6]SOHNUM
    [M:YEXP1]BPCORD(LCON)     = [F:YYSOH6]BPCORD
    [M:YEXP1]BPCNAM(LCON)     = [F:YYSOH6]BPCNAM
    [M:YEXP1]BPAADD(LCON)     = [F:YYSOH6]BPAADD
    [M:YEXP1]BPDADDLIG(LCON)  = [F:YYSOH6]BPDADDLIG
    [M:YEXP1]ORDDAT(LCON)     = [F:YYSOH6]ORDDAT
    [M:YEXP1]DEMDLVDAT(LCON)  = [F:YYSOH6]DEMDLVDAT
    [M:YEXP1]BPDCTY(LCON)     = [F:YYSOH6]BPDCTY
    LCON += 1
  Next
  [M:YEXP1]NBLIG = LCON

  Call CALL_FLAGS From SPEYEXP

  Affzo [M:YEXP1]SOHNUM,BPCORD,BPCNAM,BPAADD,BPDADDLIG,ORDDAT,DEMDLVDAT,BPDCTY
  If clalev([F:YYSOH6])  Then : Close Local File   [F:YYSOH6] : Endif

Return

