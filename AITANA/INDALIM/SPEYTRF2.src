#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif

Case ACTION
    When "SEL_TABLE"    : Gosub SEL_TABLE
    When "VERF_TABLE"   : Gosub VERF_TABLE
    When Default
Endcase
Return

########################################################################


########################################################################
$SEL_TABLE
  If !clalev([F:YCON]) Then : Local File YCONDICIONES [F:YCON] : Endif
  Default File [YCON]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Selección de tarifas"                                          # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Cód. tarifa"                                                   # título de la primera columna
  COL(NBCOL)  = "YCDGCOND"                                                      # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Fecha inicio"                                                  # título de la segunda columna
  COL(NBCOL)  = "YFECHAINI"                                                     # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Fecha fin"                                                     # título de la tercera columna
  COL(NBCOL)  = "YFECHAFIN"                                                     # nombre del campo a mostrar en la tercera columna

Return

########################################################################
# esta etiqueta se utiliza para realizar acciones específicas cuando se selecciona una de las opciones en la ventana de selección
# en la variable VALEUR se devuelve el valor a mostrar
$VERF_TABLE

  [M:YTRF0]YTARDATINI = [F:YCON]YFECHAINI
  [M:YTRF0]YTARDATFIN = [F:YCON]YFECHAFIN
  Affzo [M:YTRF0]YTARDATINI, YTARDATFIN
  zonsui = "[M:YTRF0]YCDGCOND"

Return

