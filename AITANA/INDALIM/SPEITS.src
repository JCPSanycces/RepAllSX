######################################################################################
## Al inicializar el campo "Precio estándar actualizado"
######################################################################################
Subprog D_YPRISTD(VALEUR)
Variable Decimal VALEUR

  If !clalev([F:YITM0]) Then : Local File ITMMASTER [F:YITM0] : Endif
  Read [F:YITM0]ITM0 = [M:ITM0]ITMREF
  If !fstat Then
    [M:ITS]YPRISTD = [F:YITM0]YPRISTD
    Affzo [M:ITS]YPRISTD
  Endif
  If clalev([F:YITM0])  Then : Close Local File     [F:YITM0] : Endif
End

