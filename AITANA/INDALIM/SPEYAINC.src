#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif

  Case ACTION
    When "DEBUT"      : Gosub DEBUT
    When "BOUTON"     : Gosub BOUTON
    When Default
  Endcase

Return


##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$DEBUT
  Gosub MUESTRA_CONSULTA
Return

##############################################################
$BOUTON
  Case BOUT
    When "x"  : Gosub SALIR
    When Default
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$MUESTRA_CONSULTA
Local Integer LCON : Raz LCON
  If !clalev([F:YYITV]) Then : Local File YITMMVT [F:YYITV] : Endif
  Filter [F:YYITV] Where [F:YYITV]YPREPQTY < [F:YYITV]SALSTO
  For [YYITV]
    [M:YAINC]ITMREF(LCON)     = [F:YYITV]ITMREF
    [M:YAINC]STU(LCON)        = [F:YYITV]STU
    [M:YAINC]PHYSTO(LCON)     = [F:YYITV]YTOTEXIST
    [M:YAINC]YRESHOJAS(LCON)  = [F:YYITV]YRESHOJAS
    [M:YAINC]ORDSTO(LCON)     = [F:YYITV]ORDSTO
    [M:YAINC]SALSTO(LCON)     = [F:YYITV]SALSTO
    [M:YAINC]YPREPQTY(LCON)   = [F:YYITV]YPREPQTY
    LCON += 1
  Next
  [M:YAINC]NBLIG = LCON
  Affzo [M:YAINC]5
  Filter [F:YYITV]
  If clalev([F:YYITV])  Then : Close Local File [F:YYITV] : Endif
Return

##############################################################
$SALIR
  Raz [M:YAINC]
  FIN = 1
Return

######################################################################################

