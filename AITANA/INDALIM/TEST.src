#<AdxTL>@(#)0.0.0.0 $Revision$
##############################################################
######################    ACCIONES    ########################
##############################################################

##############################################################
######################    ETIQUETAS    #######################
##############################################################

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################


################################################
$APRES_MOD
  Gosub XREVNUM
  Gosub RELIT From GOBJSUB
Return

$XREVNUM
  Call DEBTRANS From GLOCK
# Transacción
$TR1
  GOK = 1
  Trbegin [XDM]
  Readlock [XDM]XDM0 = [M:XDM0]DOMCOD
  If [S]fstat = 1                               # el campo está en uso
    [V]GOK = -1
    [V]GLOCK = "XDOMMAG"-[M:XDM0]DOMCOD         # nombre de tabla - nombre del campo
    Goto ROL_TR1
  Elsif [S]fstat                                # 2,3,... cualquier otro error de acceso al registro
    [V]GOK = 0
    Call RSTA("XDM",[M:XDM0]DOMCOD) From GLOCK  # abreviatura de la tabla - nombre del campo
    Goto AB_TR1
  Endif

  [F:XDM]XREVNUM += 1                           # actualización del campo
  Rewrite [XDM]
  If [S]fstat                                   # si no se puede modificar el campo
    [V]GOK = 0
    Call FSTA("XDM") From GLOCK
    Goto AB_TR1
  Endif

  Commit
  [M:XDM0]XREVNUM=[F:XDM]XREVNUM
  Affzo [M:XDM0]XREVNUM
Return

# Rollback de la transacción
$ROL_TR1
  Rollback
  Call ROLL From GLOCK                              # comprueba el número de reintentos que quedan
  If GROLL
    Call ECR_TRACE(mess(17,107,1),1) From GESECRAN  # máximo número de reintentos alcanzado
  Else
    Goto TR1                                        # puede reintentar una vez más
  Endif
Return

# Abortar la transacción
$AB_TR1
  Rollback
  Call ECR_TRACE(mess(17,107,1),1) From GESECRAN    # muestra un mensaje de sistema en el idioma correcto
Return

