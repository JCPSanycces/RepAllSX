########################################################
$PLAN_PREPARACION
Local Integer LINT3
Global Char GPARAM3(250)(2)

  GPARAM3(0) = "DESDE_YEXP"                                                     # pase de parámetros entre pantallas
  GPARAM3(1) = [M:YEXP0]STOFCY
  Call SAISIE_LIB(LINT3,GPARAM3,"IPREP","SPEPREP","OBJZON") From GSAISIE    # llamada a la función que abre la pantalla emregente

Return

########################################################
$ENTREGA_VALES_PREPARACION
Local Integer LINT4
Global Char GPARAM4(250)(3)

  GPARAM4(0) = "DESDE_YEXP"                                                     # pase de parámetros entre pantallas
  GPARAM4(1) = GSOC
  GPARAM4(2) = [M:YEXP0]STOFCY
  Call SAISIE_LIB(LINT4,GPARAM4,"DPREDLV","SPEPREDLV","OBJZON") From GSAISIE    # llamada a la función que abre la pantalla emregente

Return

