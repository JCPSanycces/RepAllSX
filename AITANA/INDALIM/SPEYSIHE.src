#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif

Case ACTION
  When "BOUTON"       : Gosub BOUTON
  When Default
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$BOUTON
  Case BOUT
    When "i"  : Gosub PRINT_SEND
    When Default
  Endcase
Return


##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
##############################################################
$PRINT_SEND
Local Char    LCRIT(250)  :  Raz LCRIT
Local Char    LCORREO(250),LADJFIL(250),LRTDIR(250),LRUTA(250)
Local Integer LOKFAC

  If !clalev([F:YSIV]) Then : Local File SINVOICEV  [F:YSIV]  : Endif
  If !clalev([F:YBPC]) Then : Local File BPCUSTOMER [F:YBPC]  : Endif

  LCRIT = "[F:YSIV]INVTYP = 1 AND [F:YSIV]BPCINV >= [M:YSIHE0]BPCINVD AND [F:YSIV]BPCINV <= [M:YSIHE0]BPCINVH "
  If [M:YSIHE0]NUMD <> "" and [M:YSIHE0]NUMH <> ""
    LCRIT += " & [F:YSIV]NUM >= [M:YSIHE0]NUMD AND [F:YSIV]NUM <= [M:YSIHE0]NUMH "
  Endif
  Filter [F:YSIV] Where evalue(LCRIT)
  For [YSIV]
    Read [F:YBPC]BPC0 = [F:YSIV]BPCINV
    If [F:YBPC]YFENFAC = 1 Then                                                         # envío por correo (un correo por factura)
      Call GET_EMAIL([F:YSIV]BPCINV,[F:YSIV]BPAADD,LCORREO) From SPEYLIB0                   # dirección de correo del cliente
      Call GET_MAPFIL([F:YSIV]SIHORINUM,[F:YBPC]YFENFAC,LCORREO) From SPEYLIB0              # número de albarán, tipo de salida y correo electrónico
    Elsif [F:YBPC]YFENFAC = 2 Then                                                      # envío por impresora
      Call GEN_PDFSIH([F:YSIV]NUM,LOKFAC) From SPEYLIB0                                     # imprime factura
      Call GET_MAPFIL([F:YSIV]SIHORINUM,[F:YBPC]YFENFAC,"") From SPEYLIB0                   # imprime albarán/es asociado/s
    Endif
  Next
  Filter [F:YSIV]

  If clalev([F:YSIV])  Then : Close Local File [F:YSIV] : Endif
  If clalev([F:YBPC])  Then : Close Local File [F:YBPC] : Endif

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
##############################################################

