#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "DEBUT"        : Gosub DEBUT
  When "SEL_TABLE"    : Gosub SEL_TABLE
  When "VERF_TABLE"   : Gosub VERF_TABLE
  When "SETBOUT"      : Gosub SETBOUT
  When "BOUTON"       : Gosub BOUTON
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
########################################################################
$DEBUT
Global Char GCODTARFLG(5) : Raz GCODTARFLG

  If GUSER <> "ADMIN" and GUSER <> "AIT07" and GUSER <> "AIT01" and GUSER <> "ANABEL"
#    Grizo [M:YTEC0]YINIVAL,YFINVAL
  Endif

Return

########################################################################
$SEL_TABLE
  Case TABLE
    When "YSELTEC"    : Gosub SEL_YSELTEC                                     # selección para el campo código oferta
    When "YSELTECTAR" : Gosub SEL_YSELTECTAR                                  # selección para el campo código tarifa
    When "YSELREP"    : Gosub SEL_YSELREP                                     # selección para el campo representante
    When "YSELITMTAR" : Gosub SEL_YSELITMTAR                                  # selección para el campo artículo (grid)
  Endcase
Return

########################################################################
$VERF_TABLE
  Case TABLE
    When "YSELTEC"    : Gosub VERF_YSELTEC                                     # selección para el campo código oferta
    When "YSELTECTAR" : Gosub VERF_YSELTECTAR                                  # selección para el campo código tarifa
    When "YSELREP"    : Gosub VERF_YSELREP                                     # selección para el campo representante
    When "YSELITMTAR" : Gosub VERF_YSELITMTAR                                  # selección para el campo artículo (grid)
  Endcase
Return

########################################################################
$SEL_YSELTEC
  If [M:YTEC0]YCLIFLG = 2 Then
    If !clalev([F:YSPF]) Then : Local File SPRICFICH [F:YSPF] : Endif
    Default File [YSPF]
    Filter [F:YSPF] Where (PLISTRDAT <= date$ and PLIENDDAT >= date$ and PLI = "T30") or (PLISTRDAT = [00/00/0000] and PLIENDDAT = [00/00/0000] and PLI = "T30")
    NBCOL       = 0                                                               # número de la columna
    TIT(NBCOL)  = "Código oferta T30"                                             # título de la ventana
    NBCOL       += 1
    TIT(NBCOL)  = "Código oferta"                                                 # título de la segunda columna
    COL(NBCOL)  = "PLICRDIDX"                                                     # nombre del campo a mostrar en la segunda columna
    NBCOL       += 1
    TIT(NBCOL)  = "Descripción oferta"                                            # título de la segunda columna
    COL(NBCOL)  = "YPLIIDXDESC"                                                   # nombre del campo a mostrar en la segunda columna
    NBCOL       += 1
    TIT(NBCOL)  = "Registro tarifa"                                               # título de la segunda columna
    COL(NBCOL)  = "PLICRD"                                                        # nombre del campo a mostrar en la segunda columna
    NBCOL       += 1
    TIT(NBCOL)  = "Inicio vigencia"                                               # título de la primera columna
    COL(NBCOL)  = "PLISTRDAT"                                                     # nombre del campo a mostrar en la primera columna
    NBCOL       += 1
    TIT(NBCOL)  = "Fin vigencia"                                                  # título de la tercera columna
    COL(NBCOL)  = "PLIENDDAT"                                                     # nombre del campo a mostrar en la tercera columna
  Else
    If !clalev([F:YSPF]) Then : Local File SPRICFICH [F:YSPF] : Endif
    Default File [YSPF]
    Filter [F:YSPF] Where (PLISTRDAT <= date$ and PLIENDDAT >= date$ and PLI = "T35")  or (PLISTRDAT = [00/00/0000] and PLIENDDAT = [00/00/0000] and PLI = "T35")
    NBCOL       = 0                                                               # número de la columna
    TIT(NBCOL)  = "Código oferta T35"                                             # título de la ventana
    NBCOL       += 1
    TIT(NBCOL)  = "Código oferta"                                                 # título de la segunda columna
    COL(NBCOL)  = "PLICRDIDX"                                                     # nombre del campo a mostrar en la segunda columna
    NBCOL       += 1
    TIT(NBCOL)  = "Descripción oferta"                                            # título de la segunda columna
    COL(NBCOL)  = "YPLIIDXDESC"                                                   # nombre del campo a mostrar en la segunda columna
    NBCOL       += 1
    TIT(NBCOL)  = "Registro tarifa"                                               # título de la segunda columna
    COL(NBCOL)  = "PLICRD"                                                        # nombre del campo a mostrar en la segunda columna
    NBCOL       += 1
    TIT(NBCOL)  = "Inicio vigencia"                                               # título de la primera columna
    COL(NBCOL)  = "PLISTRDAT"                                                     # nombre del campo a mostrar en la primera columna
    NBCOL       += 1
    TIT(NBCOL)  = "Fin vigencia"                                                  # título de la tercera columna
    COL(NBCOL)  = "PLIENDDAT"                                                     # nombre del campo a mostrar en la tercera columna
  Endif
Return

########################################################################
$VERF_YSELTEC
  [M:YTEC0]YDESOF  = [F:YSPF]YPLIIDXDESC                                          # descripción oferta
  [M:YTEC0]YCDGTAR = [F:YSPF]YTARORICDG                                           # código tarifa origen
  [M:YTEC0]YCDGREP = [F:YSPF]YPLIREPCDG                                           # código representante
  [M:YTEC0]YDESREP = [F:YSPF]YPLIREPDESC                                          # descripción representante
  [M:YTEC0]YINIVAL = [F:YSPF]PLISTRDAT                                            # inicio validez
  [M:YTEC0]YFINVAL = [F:YSPF]PLIENDDAT                                            # fin validez
  [M:YTEC0]YREGTAR = [F:YSPF]PLICRD                                               # código registro tarifa (p.e. SPL19-0022)
  [M:YTEC0]YCREDAT = [F:YSPF]YCREDAT                                              # fecha de creación
  Affzo [M:YTEC0]YDESOF,YCDGTAR,YCDGREP,YDESREP,YINIVAL,YFINVAL,YCREDAT
Return

########################################################################
$SEL_YSELTECTAR
  If !clalev([F:YSF0]) Then : Local File SPRICFICH [F:YSF0] : Endif
  Default File [YSF0]
  Filter [F:YSF0] Where PLI = "T20" and PLISTRDAT <= date$ and PLIENDDAT >= date$
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Código tarifa"                                                 # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "PLICRDIDX"                                                     # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Inicio vigencia"                                               # título de la primera columna
  COL(NBCOL)  = "PLISTRDAT"                                                     # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Fin vigencia"                                                  # título de la tercera columna
  COL(NBCOL)  = "PLIENDDAT"                                                     # nombre del campo a mostrar en la tercera columna
Return

########################################################################
$VERF_YSELTECTAR
Return

########################################################################
$SEL_YSELREP
  If !clalev([F:YREP]) Then : Local File SALESREP [F:YREP] : Endif
  Default File [YREP]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Representantes"                                                # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Número"                                                        # título de la segunda columna
  COL(NBCOL)  = "REPNUM"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Nombre"                                                        # título de la primera columna
  COL(NBCOL)  = "REPNAM"                                                        # nombre del campo a mostrar en la primera columna
Return

########################################################################
$VERF_YSELREP
  [M:YTEC0]YDESREP = [F:YREP]REPNAM
  Affzo [M:YTEC0]YDESREP
Return

########################################################################
$SEL_YSELITMTAR
  If !clalev([F:YITM]) Then : Local File ITMMASTER [F:YITM] : Endif
  Default File [YITM]
  Filter [F:YITM] Where ITMSTA = 1 or ITMSTA = 5 or ITMSTA = 6
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Artículos"                                                     # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Cód. artículo"                                                 # título de la segunda columna
  COL(NBCOL)  = "ITMREF"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la primera columna
  COL(NBCOL)  = "ITMDES1"                                                       # nombre del campo a mostrar en la primera columna
Return

########################################################################
$VERF_YSELITMTAR
Local Char LPLI0(5) : Raz LPLI0

  # identifica si es cliente o grupo para buscar en la tarifa correcta
  If [M:YTEC0]YCLIFLG = 2 Then
    LPLI0 = "T30"
  Else
    LPLI0 = "T35"
  Endif

  [M:YTEC1]TSICOD1(nolign-1)  = [F:YITM]TSICOD(0)                                      # familia
  [M:YTEC1]TSICOD2(nolign-1)  = [F:YITM]TSICOD(1)                                      # subfamilia
  [M:YTEC1]TSICOD3(nolign-1)  = [F:YITM]TSICOD(2)                                      # gama
  [M:YTEC1]YORDEN(nolign-1)   = [F:YITM]YORDEN                                         # orden
  [M:YTEC1]ITMREF(nolign-1)   = [F:YITM]ITMREF                                         # código artículo
  [M:YTEC1]ITMDES(nolign-1)   = [F:YITM]ITMDES1                                        # descripción artículo
  [M:YTEC1]YPRISTD(nolign-1)  = [F:YITM]YPRISTD                                        # coste referencia
  [M:YTEC1]YPMP(nolign-1)     = [F:YITM]YPMP                                           # PM cost.
  Call GET_PRIREP([F:YITM]ITMREF,[M:YTEC1]YPRI(nolign-1)) From YAITLIB                 # PC repos.
  [M:YTEC1]YCDGHE(nolign-1)   = [F:YITM]ITMDES3                                        # código del grupo Heleo

  Affzo [M:YTEC1]TSICOD1(nolign-1),TSICOD2(nolign-1),TSICOD3(nolign-1),YORDEN(nolign-1),ITMREF(nolign-1),
& ITMDES(nolign-1),YPRISTD(nolign-1),YPMP(nolign-1),YPRI(nolign-1),YCDGHE(nolign-1)

Return

########################################################################
$SETBOUT
  # controla los botones
  If GCODTARFLG = "" Then
    Raz CHMEN
    CHMEN += "ntb"
  Else
    Raz CHMEN
    CHMEN += "rcbt"
  Endif
Return

########################################################################
$BOUTON
  Case BOUT
    When "n"
      If [M:YTEC2]BPCNUM(0) <> "" Then
        Gosub NUEVA_OFERTA
      Else
        GERR = 1
        GMESSAGE = "El campo cliente/grupo debe de informarse"
      Endif
    When "r"  : Gosub REGISTRAR_OFERTA
    When "c"  : Gosub CARGAR_OFERTA
    When "t"  : Gosub MOSTRAR_PRECIO_TARIFA
    When "b"  : Gosub VACIAR_PANTALLA
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
########################################################################
$NUEVA_OFERTA
Local Char    LPLI(5),CDGCONT(5),LCONTOF(10),REGTAR(10) : Raz LPLI,CDGCONT,LCONTOF,REGTAR
Local Integer LCON1,LCON2,LCON3 : Raz LCON1,LCON2,LCON3

  # identifica si es cliente o grupo para buscar en la tarifa correcta
  If [M:YTEC0]YCLIFLG = 2 Then
    LPLI    = "T30"
    CDGCONT = "YTECC"
  Else
    LPLI = "T35"
    CDGCONT = "YTECG"
  Endif

  # siguiente número para el contador de "Registro tarifa"
  Call GENNUMBER("SPL",[M:YTEC0]YINIVAL,REGTAR) From YAITLIB
  [M:YTEC0]YREGTAR = REGTAR : Affzo [M:YTEC0]YREGTAR                                            # registro tarifa en pantalla

  # siguiente número para el contador de "Código oferta"
  Call GENNUMBER(CDGCONT,[M:YTEC0]YINIVAL,LCONTOF) From YAITLIB
  [M:YTEC0]YCDGOF = LCONTOF : Affzo [M:YTEC0]YCDGOF                                             # código oferta en pantalla

  # se añaden los artículos en la tarifa correspondiente
  # se realiza este proceso antes que la creación de la cabecera porque tenemos que saber el
  # número de líneas para la tabla cabecera (LCON3)
  LCON3 = 1
  If !clalev([F:YSL1]) Then : Local File SPRICLIST [F:YSL1] : Endif
  For LCON1 = 0 To [M:YTEC2]NBBPC-1
    For LCON2 = 0 To [M:YTEC1]NBITM-1
      Trbegin [F:YSL1]
      [F:YSL1]PLI         = LPLI                                                                # código tarifa
      [F:YSL1]PLICRD      = REGTAR                                                              # registro tarifa
      [F:YSL1]PLILIN      = 1000 * LCON3                                                        # número de línea
      [F:YSL1]PLICRI      = [M:YTEC2]BPCNUM(LCON1)+"~"+[M:YTEC1]ITMREF(LCON2)+"~~~~"
      [F:YSL1]PLICRI1     = [M:YTEC2]BPCNUM(LCON1)                                              # código de cliente
      [F:YSL1]PLICRI2     = [M:YTEC1]ITMREF(LCON2)                                              # código de artículo
      [F:YSL1]CUR         = "EUR"                                                               # divisa
      If !clalev([F:YIT1]) Then : Local File ITMMASTER [F:YIT1] : Endif
      Read [F:YIT1]ITM0 = [M:YTEC1]ITMREF(LCON2)
      If !fstat Then
        [F:YSL1]UOM       = [F:YIT1]SAU                                                         # unidad
      Endif
      If clalev([F:YIT1]) Then : Close Local File      [F:YIT1] : Endif
      [F:YSL1]PRI         = [M:YTEC1]PRI(LCON2)                                                 # valor unitario
      [F:YSL1]DCGVAL(0)   = [M:YTEC1]YDESC1(LCON2)                                              # descuento
      [F:YSL1]PLISTRDAT   = [M:YTEC0]YINIVAL                                                    # inicio validez
      [F:YSL1]PLIENDDAT   = [M:YTEC0]YFINVAL                                                    # fin validez
      [F:YSL1]CREUSR      = GUSER                                                               # usuario creación
      [F:YSL1]CREDAT      = [M:YTEC0]YCREDAT                                                    # fecha creación
      [F:YSL1]CREDATTIM   = [M:YTEC0]YCREDAT                                                    # fecha creación
      [F:YSL1]UPDDAT      = [M:YTEC0]YCREDAT                                                    # fecha modificación
      [F:YSL1]UPDDATTIM   = [M:YTEC0]YCREDAT                                                    # fecha modificación
      Write [F:YSL1]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
      LCON3 += 1
    Next LCON2
  Next LCON1
  If clalev([F:YSL1])  Then : Close Local File     [F:YSL1] : Endif

  # se genera la cabecera de la tarifa
  If !clalev([F:YSF1]) Then : Local File SPRICFICH [F:YSF1] : Endif
  Trbegin [F:YSF1]
  [F:YSF1]PLI         = LPLI                                                                  # código tarifa
  [F:YSF1]PLICRD      = REGTAR                                                                # registro tarifa
  [F:YSF1]PLICRDIDX   = LCONTOF                                                               # índice
  [F:YSF1]PLISTRDAT   = [M:YTEC0]YINIVAL                                                      # inicio validez
  [F:YSF1]PLIENDDAT   = [M:YTEC0]YFINVAL                                                      # fin validez
  [F:YSF1]LINNBR      = LCON3                                                                 # número de líneas
#  [F:YSF1]EXPNUM     =                                                                       # ???????????????
  [F:YSF1]CREUSR      = GUSER                                                                 # usuario creación
  [F:YSF1]CREDAT      = [M:YTEC0]YCREDAT                                                      # fecha creación
  [F:YSF1]CREDATTIM   = [M:YTEC0]YCREDAT                                                      # fecha creación
  [F:YSF1]UPDDAT      = [M:YTEC0]YCREDAT                                                      # fecha modificación
  [F:YSF1]UPDDATTIM   = [M:YTEC0]YCREDAT                                                      # fecha modificación
  [F:YSF1]YPLIIDXDESC = [M:YTEC0]YDESOF                                                       # descripción código tarifa
  [F:YSF1]YPLIREPCDG  = [M:YTEC0]YCDGREP                                                      # código representante
  [F:YSF1]YPLIREPDESC = [M:YTEC0]YDESREP                                                      # descrición representante
  [F:YSF1]YTARORICDG  = [M:YTEC0]YCDGTAR                                                      # código tarifa original
  [F:YSF1]YCREDAT     = [M:YTEC0]YCREDAT                                                      # fecha creación
  Write [F:YSF1]
  If !fstat Then
    Commit
  Else
    Rollback
  Endif
  If clalev([F:YSF1])  Then : Close Local File     [F:YSF1] : Endif

  GCODTARFLG = LCONTOF
  Call MESSAGE("Se ha creado la oferta:"-LCONTOF) From GESECRAN

Return

########################################################################
$REGISTRAR_OFERTA
Local Integer LCON4,LCON5,LCON6  : Raz LCON4,LCON5,LCON6
Local Char    LPLI(5),CDGCONT(5) : Raz LPLI,CDGCONT

  # identifica si es cliente o grupo para buscar en la tarifa correcta
  If [M:YTEC0]YCLIFLG = 2 Then
    LPLI    = "T30"
    CDGCONT = "YTECC"
  Else
    LPLI = "T35"
    CDGCONT = "YTECG"
  Endif

#  # si el usuario no es administrador (es comercial) vacía los campos de fecha inicio validez y fin validez para que actúe como inactiva
#  If GUSER <> "ADMIN" and GUSER <> "AIT07" Then
#    [M:YTEC0]YINIVAL = [00/00/0000]
#    [M:YTEC0]YFINVAL = [00/00/0000]
#    Affzo [M:YTEC0]YINIVAL,YFINVAL
#  Endif

  # elimina todos los registros de artículos en la tabla SPRICLIST
  If !clalev([F:YSF2]) Then : Local File SPRICFICH [F:YSF2] : Endif
  Filter [F:YSF2] Where PLI = LPLI and PLICRDIDX = [M:YTEC0]YCDGOF
  Read [F:YSF2] First
  If !fstat Then
    If !clalev([F:YSL2]) Then : Local File SPRICLIST [F:YSL2] : Endif
    Trbegin [F:YSL2]
    Delete [F:YSL2] Where PLICRD = [F:YSF2]PLICRD and PLI = LPLI
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
    # se añaden los artículos en la tarifa correspondiente
    # se realiza este proceso antes que la creación de la cabecera porque tenemos que saber el
    # número de líneas para la tabla cabecera (LCON6)
    LCON6 = 1
    For LCON4 = 0 To [M:YTEC2]NBBPC-1
      For LCON5 = 0 To [M:YTEC1]NBITM-1
        Trbegin [F:YSL2]
        [F:YSL2]PLI       = LPLI                                                              # código tarifa
        [F:YSL2]PLICRD    = [M:YTEC0]YREGTAR                                                  # registro tarifa
        [F:YSL2]PLILIN    = 1000 * LCON6                                                      # número de línea
        [F:YSL2]PLICRI    = [M:YTEC2]BPCNUM(LCON4)+"~"+[M:YTEC1]ITMREF(LCON5)+"~~~~~"
        [F:YSL2]PLICRI1   = [M:YTEC2]BPCNUM(LCON4)                                            # código de cliente
        [F:YSL2]PLICRI2   = [M:YTEC1]ITMREF(LCON5)                                            # código de artículo
        [F:YSL2]CUR       = "EUR"                                                             # divisa
        If !clalev([F:YIT2]) Then : Local File ITMMASTER [F:YIT2] : Endif
        Read [F:YIT2]ITM0 = [M:YTEC1]ITMREF(LCON5)
        If !fstat Then
          [F:YSL2]UOM       = [F:YIT2]SAU                                                     # unidad
        Endif
        If clalev([F:YIT2]) Then : Close Local File      [F:YIT2] : Endif
        [F:YSL2]PRI       = [M:YTEC1]PRI(LCON5)                                               # valor unitario
        [F:YSL2]DCGVAL(0) = [M:YTEC1]YDESC1(LCON5)                                            # descuento
        [F:YSL2]PLISTRDAT = [M:YTEC0]YINIVAL                                                  # inicio validez
        [F:YSL2]PLIENDDAT = [M:YTEC0]YFINVAL                                                  # fin validez
        [F:YSL2]CREUSR    = GUSER                                                             # usuario creación
        [F:YSL2]CREDAT    = [M:YTEC0]YCREDAT                                                  # fecha creación
        [F:YSL2]CREDATTIM = [M:YTEC0]YCREDAT                                                  # fecha creación
        [F:YSL2]UPDDAT    = [M:YTEC0]YCREDAT                                                  # fecha modificación
        [F:YSL2]UPDDATTIM = [M:YTEC0]YCREDAT                                                  # fecha modificación
        Write [F:YSL2]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
        LCON6 += 1
      Next LCON5
    Next LCON4
    If clalev([F:YSL2])  Then : Close Local File     [F:YSL2] : Endif
  Endif
  Filter [F:YSF2]
  If clalev([F:YSF2])  Then : Close Local File     [F:YSF2] : Endif

  # se actualiza la tabla cabecera
  If !clalev([F:YSF2]) Then : Local File SPRICFICH [F:YSF2] : Endif
  Trbegin [F:YSF2]

  Update [YSF2] Where PLICRDIDX = [M:YTEC0]YCDGOF and PLI = LPLI With CREDAT = [M:YTEC0]YCREDAT,
& PLISTRDAT = [M:YTEC0]YINIVAL, PLIENDDAT = [M:YTEC0]YFINVAL
  If !fstat Then
    Commit
  Else
    Rollback
  Endif
  If clalev([F:YSF2])  Then : Close Local File     [F:YSF2] : Endif

  Call MESSAGE("Proceso realizado satisfactoriamente") From GESECRAN

Return

########################################################################
$CARGAR_OFERTA
Local Integer LCON0,LCON7   : Raz LCON0,LCON7
Local Char    LPLI(5) : Raz LPLI
Local Char    CRIT0(255)(0..4),CRIT1(255)(0..2) : Raz CRIT0,CRIT1
Local Decimal LPON : Raz LPON

  # identifica si es cliente o grupo para buscar en la tarifa correcta
  If [M:YTEC0]YCLIFLG = 2 Then
    LPLI = "T30"
  Else
    LPLI = "T35"
  Endif

  # limpia el grid
  Effzo [M:YTEC1]5

  # rellena la pantalla de artículos
  If !clalev([F:YSF0]) Then : Local File SPRICFICH [F:YSF0] : Endif
#  If !clalev([F:YSL0]) Then : Local File SPRICLIST [F:YSL0] : Endif
  If !clalev([F:YIT0]) Then : Local File ITMMASTER [F:YIT0] : Endif
  Filter [F:YSF0] Where PLI = LPLI and PLICRDIDX = [M:YTEC0]YCDGOF                  # busca en SPRICFICH el código de "Registro de tarifa"
  Read [F:YSF0] First
  If !fstat Then
      # busca en SPRICLIST todos los DISTINTOS artículos del registro correspondiente
      CRIT0(0) = "SELECT PLICRI2_0 AS ITMREF,PLI_0 AS PLI,PLICRD_0 AS PLICRD,PLISTRDAT_0 AS PLISTRDAT,PLIENDDAT_0 AS PLIENDDAT, "
      CRIT0(1) = "UOM_0 AS UOM,CUR_0 AS CUR,PRI_0 AS PRI,DCGVAL_0 AS DCGVAL0,DCGVAL_1 AS DCGVAL1,DCGVAL_2 AS DCGVAL2 "
      CRIT0(2) = "FROM " + nomap + ".SPRICLIST "
      CRIT0(3) = "WHERE PLI_0 = '" + LPLI + "' AND PLICRD_0 = '" + [F:YSF0]PLICRD + "' "
      CRIT0(4) = "GROUP BY PLICRI2_0,PLI_0,PLICRD_0,PLISTRDAT_0,PLIENDDAT_0,UOM_0,CUR_0,PRI_0,DCGVAL_0,DCGVAL_1,DCGVAL_2"
      For (Char ITMREF,Char PLI,Char PLICRD,Date PLISTRDAT,Date PLIENDDAT,Char UOM,Char CUR,Decimal PRI,Decimal DCGVAL0,Decimal DCGVAL1,Decimal DCGVAL2)
&     From "5" Sql CRIT0(0..4) As [ZSQ0]
        Read [F:YIT0]ITM0 = [F:ZSQ0]ITMREF
        If !fstat Then
          [M:YTEC1]TSICOD1(LCON0)  = [F:YIT0]TSICOD(0)                                      # familia
          [M:YTEC1]TSICOD2(LCON0)  = [F:YIT0]TSICOD(1)                                      # subfamilia
          [M:YTEC1]TSICOD3(LCON0)  = [F:YIT0]TSICOD(2)                                      # gama
          [M:YTEC1]YORDEN(LCON0)   = [F:YIT0]YORDEN                                         # orden
          [M:YTEC1]ITMREF(LCON0)   = [F:YIT0]ITMREF                                         # código artículo
          [M:YTEC1]ITMDES(LCON0)   = [F:YIT0]ITMDES1                                        # descripción artículo
          [M:YTEC1]YPRISTD(LCON0)  = [F:YIT0]YPRISTD                                        # coste referencia
          [M:YTEC1]YPMP(LCON0)     = [F:YIT0]YPMP                                           # PM cost.
          Call GET_PRIREP([F:YIT0]ITMREF,[M:YTEC1]YPRI(LCON0)) From YAITLIB                 # PC repos.
          [M:YTEC1]PRI(LCON0)      = [F:ZSQ0]PRI                                            # valor unitario de tarifa
          [M:YTEC1]YDESC1(LCON0)   = [F:ZSQ0]DCGVAL0                                        # descuento en tarifa
          If [F:ZSQ0]PRI <> 0 Then
            LPON = [F:ZSQ0]PRI - (([F:ZSQ0]DCGVAL0 * [F:ZSQ0]PRI) / 100)                    # precio oferta NETO
            [M:YTEC1]YMPCR(LCON0)    = 100-(ar2(([F:YIT0]YPRISTD*100)/LPON))                # margen sobre coste de referencia
            [M:YTEC1]YMPMC(LCON0)    = 100-(ar2(([F:YIT0]YPMP*100)/LPON))                   # margen sobre PMP
            [M:YTEC1]YMPRC(LCON0)    = 100-(ar2(([M:YTEC1]YPRI(LCON0)*100)/LPON))           # margen sobre precio de reposición
          Endif
          [M:YTEC1]YMPCS(LCON0)    = abs(LPON - [F:YIT0]YPRISTD)                            # margen sobre precio estándar
          [M:YTEC1]YCDGHE(LCON0)   = [F:YIT0]ITMDES3                                        # código del grupo Heleo
          LCON0 += 1
        Endif
      Next
    [M:YTEC1]NBITM = LCON0
    # ordena el cuadro por los campos "Artículo", "Familia", "Subfamilia", "Gama"
    Sorta [M:YTEC1]NBITM [M:YTEC1]NBITM Order By [M:YTEC1]ITMREF(indice), [M:YTEC1]TSICOD1(indice), [M:YTEC1]TSICOD2(indice), [M:YTEC1]TSICOD3(indice)
    Affzo [M:YTEC1]5
  Endif

  CRIT1(0) = "SELECT DISTINCT(PLICRI1_0) AS BPCNUM "
  CRIT1(1) = "FROM " + nomap + ".SPRICLIST "
  CRIT1(2) = "WHERE PLI_0 = '" + LPLI + "' AND PLICRD_0 = '" + [F:YSF0]PLICRD + "'"
  For (Char BPCNUM) From "5" Sql CRIT1(0..2) As [ZSQ1]
    [M:YTEC2]BPCNUM(LCON7)  = [F:ZSQ1]BPCNUM
    LCON7 += 1
  Next
  [M:YTEC2]NBBPC = LCON7
  Affzo [M:YTEC2]5

  Filter [F:YSF0]
  If clalev([F:YSF0])  Then : Close Local File     [F:YSF0] : Endif
#  If clalev([F:YSL0])  Then : Close Local File     [F:YSL0] : Endif
  If clalev([F:YIT0])  Then : Close Local File     [F:YIT0] : Endif
Return

########################################################################
$MOSTRAR_PRECIO_TARIFA
Local Integer LCON8   : Raz LCON8
Local Decimal LPON    : Raz LPON

  If !clalev([F:YSL3]) Then : Local File SPRICLIST [F:YSL3] : Endif
  If !clalev([F:YIT3]) Then : Local File ITMMASTER [F:YIT3] : Endif
  For LCON8 = 0 To [M:YTEC1]NBITM-1
    Filter [F:YSL3] Where PLI = "T20" and PLICRI1 = [M:YTEC0]YCDGTAR and PLICRI2 = [M:YTEC1]ITMREF(LCON8)
    Read [F:YSL3] First
    If !fstat Then
      Read [F:YIT3]ITM0 = [M:YTEC1]ITMREF(LCON8)
      If !fstat Then
        If [M:YTEC1]PRI(LCON8) = 0 Then
          [M:YTEC1]PRI(LCON8)     = [F:YSL3]PRI
          [M:YTEC1]YDESC1(LCON8)  = [F:YSL3]DCGVAL(0)
        Endif
        If [M:YTEC1]PRI(LCON8) <> 0 Then
          LPON = [M:YTEC1]PRI(LCON8) - (([M:YTEC1]YDESC1(LCON8) * [M:YTEC1]PRI(LCON8)) / 100)         # precio oferta NETO
          [M:YTEC1]YMPCR(LCON8)    = 100-(ar2(([F:YIT3]YPRISTD*100)/LPON))                            # margen sobre coste de referencia
          [M:YTEC1]YMPMC(LCON8)    = 100-(ar2(([F:YIT3]YPMP*100)/LPON))                               # margen sobre PMP
          [M:YTEC1]YMPRC(LCON8)    = 100-(ar2(([M:YTEC1]YPRI(LCON8)*100)/LPON))                       # margen sobre precio de reposición
          [M:YTEC1]YMPCS(LCON8)    = abs(LPON - [F:YIT3]YPRISTD)                                      # margen sobre precio estándar
          Affzo [M:YTEC1]PRI(LCON8),YDESC1(LCON8),YMPCR(LCON8),YMPMC(LCON8),YMPRC(LCON8),YMPCS(LCON8)
        Endif
      Endif
    Endif
    Filter [F:YSL3]
  Next
  If clalev([F:YSL3])  Then : Close Local File     [F:YSL3] : Endif
  If clalev([F:YIT3])  Then : Close Local File     [F:YIT3] : Endif

  Call MESSAGE("Proceso realizado satisfactoriamente") From GESECRAN

Return

########################################################################
$VACIAR_PANTALLA
  Effzo [M:YTEC0]
  Effzo [M:YTEC1]
  Effzo [M:YTEC2]
  GCODTARFLG = ""
  Chgtfd [M:YTEC2] "Cliente"                              # cambia el nombre a la pestaña
  Chgtzn [M:YTEC2]BPCNUM With "Cliente"                   # cambia el nombre a la columna
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Acción de control del campo "Cliente"
######################################################################################
# si se marca este flag, desmarca el de "Grupo cliente"
Subprog C_YCLIFLG(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    [M:YTEC0]YGRUFLG = 1
    Affzo [M:YTEC0]YGRUFLG
    Chgtfd [M:YTEC2] "Cliente"                              # cambia el nombre a la pestaña
    Chgtzn [M:YTEC2]BPCNUM With "Cliente"                   # cambia el nombre a la columna
  Else
    [M:YTEC0]YGRUFLG = 2
    Affzo [M:YTEC0]YGRUFLG
    Chgtfd [M:YTEC2] "Grupo clientes"                       # cambia el nombre a la pestaña
    Chgtzn [M:YTEC2]BPCNUM With "Grupo clientes"            # cambia el nombre a la columna
  Endif

End

######################################################################################
## Acción de control del campo "Grupo cliente"
######################################################################################
# si se marca este flag, desmarca el de "Cliente"
Subprog C_YGRUFLG(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    [M:YTEC0]YCLIFLG = 1
    Affzo [M:YTEC0]YCLIFLG
    Chgtfd [M:YTEC2] "Grupo clientes"                       # cambia el nombre a la pestaña
    Chgtzn [M:YTEC2]BPCNUM With "Grupo clientes"            # cambia el nombre a la columna
  Else
    [M:YTEC0]YCLIFLG = 2
    Affzo [M:YTEC0]YCLIFLG
    Chgtfd [M:YTEC2] "Cliente"                              # cambia el nombre a la pestaña
    Chgtzn [M:YTEC2]BPCNUM With "Cliente"                   # cambia el nombre a la columna
  Endif

End

######################################################################################
## Después de modificar el campo "Código oferta"
######################################################################################
Subprog AM_YCDGOF(VALEUR)
Variable Char    VALEUR()

  # le doy valor a la variable global para poder activar/desactivar los botones "Nuevo"/"Registrar" a mi gusto
  GCODTARFLG = VALEUR

End

######################################################################################
## Control sobre el campo "Artículo" (grid)
######################################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
  Call UNICITE(VALEUR,[M:YTEC1]ITMREF(0..[M:YTEC1]NBITM-1)) From OBJDIV
  If mkstat = 2 Then
    VALEUR = ""
  Endif
End

######################################################################################
## Después de modificar el campo "Artículo" en el grid
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
  If !clalev([F:YIT2]) Then : Local File ITMMASTER [F:YIT2] : Endif
  Read [F:YIT2]ITM0 = VALEUR
  If !fstat Then
    [M:YTEC1]TSICOD1(nolign-1) =  [F:YIT2]TSICOD(0)                                                         # familia
    [M:YTEC1]TSICOD2(nolign-1) =  [F:YIT2]TSICOD(1)                                                         # subfamilia
    [M:YTEC1]TSICOD3(nolign-1) =  [F:YIT2]TSICOD(2)                                                         # gama
    [M:YTEC1]YORDEN(nolign-1)  =  [F:YIT2]YORDEN                                                            # orden
    [M:YTEC1]ITMDES(nolign-1)  =  [F:YIT2]ITMDES1                                                           # descripción
    [M:YTEC1]YPRISTD(nolign-1) =  [F:YIT2]YPRISTD                                                           # coste referencia
    [M:YTEC1]YPMP(nolign-1)    =  [F:YIT2]YPMP                                                              # PM cost.
    Call GET_PRIREP([F:YIT2]ITMREF,[M:YTEC1]YPRI(nolign-1)) From YAITLIB                                    # PC repos.
    [M:YTEC1]YCDGHE(nolign-1)   = [F:YIT2]ITMDES3                                                           # código del grupo Heleo

    Affzo [M:YTEC1]TSICOD1(nolign-1),TSICOD2(nolign-1),TSICOD3(nolign-1),YORDEN(nolign-1),
&   ITMDES(nolign-1),YPRISTD(nolign-1),YPMP(nolign-1),YPRI(nolign-1),YCDGHE(nolign-1)
  Endif
  If clalev([F:YIT2]) Then : Close Local File      [F:YIT2] : Endif
End

######################################################################################
## Después de modificar el campo "Representante"
######################################################################################
Subprog AM_YCDGREP(VALEUR)
Variable Char    VALEUR()
  If !clalev([F:YRE0]) Then : Local File SALESREP [F:YRE0] : Endif
  Read [F:YRE0]REP0 = VALEUR
  If !fstat Then
    [M:YTEC0]YDESREP = [F:YRE0]REPNAM                                                                       # rellena el campo descripción representante
    Affzo [M:YTEC0]YDESREP
  Endif
End

######################################################################################
## Después de modificar el campo "P. oferta"
######################################################################################
Subprog AM_PRI(VALEUR)
Variable Decimal VALEUR

  If VALEUR <> 0 Then
    LPON = VALEUR - (([M:YTEC1]YDESC1(nolign-1) * VALEUR) / 100)                          # precio oferta NETO
    [M:YTEC1]YMPCR(nolign-1) = 100-(ar2(([M:YTEC1]YPRISTD(nolign-1)*100)/LPON))           # margen sobre coste de referencia
    [M:YTEC1]YMPMC(nolign-1) = 100-(ar2(([M:YTEC1]YPMP(nolign-1)*100)/LPON))              # margen sobre PMP
    [M:YTEC1]YMPRC(nolign-1) = 100-(ar2(([M:YTEC1]YPRI(nolign-1)*100)/LPON))              # margen sobre precio de reposición
    [M:YTEC1]YMPCS(nolign-1) = abs(LPON - [M:YTEC1]YPRISTD(nolign-1))                     # margen sobre precio estándar
    Affzo [M:YTEC1]YMPCR(nolign-1),YMPMC(nolign-1),YMPRC(nolign-1),YMPCS(nolign-1)
  Endif

End

######################################################################################
## Después de modificar el campo "Desc."
######################################################################################
Subprog AM_YDESC1(VALEUR)
Variable Decimal VALEUR

  LPON = [M:YTEC1]PRI(nolign-1) - ((VALEUR * [M:YTEC1]PRI(nolign-1)) / 100)             # precio oferta NETO
  [M:YTEC1]YMPCR(nolign-1) = 100-(ar2(([M:YTEC1]YPRISTD(nolign-1)*100)/LPON))           # margen sobre coste de referencia
  [M:YTEC1]YMPMC(nolign-1) = 100-(ar2(([M:YTEC1]YPMP(nolign-1)*100)/LPON))              # margen sobre PMP
  [M:YTEC1]YMPRC(nolign-1) = 100-(ar2(([M:YTEC1]YPRI(nolign-1)*100)/LPON))              # margen sobre precio de reposición
  [M:YTEC1]YMPCS(nolign-1) = abs(LPON - [M:YTEC1]YPRISTD(nolign-1))                     # margen sobre precio estándar
  Affzo [M:YTEC1]YMPCR(nolign-1),YMPMC(nolign-1),YMPRC(nolign-1),YMPCS(nolign-1)

End

######################################################################################
## Control sobre el campo "Cliente"
######################################################################################
Subprog C_BPCNUM(VALEUR)
Variable Char    VALEUR()
  Call UNICITE(VALEUR,[M:YTEC2]BPCNUM(0..[M:YTEC2]NBBPC-1)) From OBJDIV
  If mkstat = 2 Then
    VALEUR = ""
  Endif
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

