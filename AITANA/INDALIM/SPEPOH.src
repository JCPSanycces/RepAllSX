#####################################################################################
# Src: SPEPOH
#-------------------------------------------------------------------------------------
# Pedidos de compra
#-------------------------------------------------------------------------------------
# Proyecto: Indalim
#-------------------------------------------------------------------------------------
# Version: v11
#-------------------------------------------------------------------------------------
# Fecha: 11/02/2019
#-------------------------------------------------------------------------------------
# Desarrollador: JCH
# Código de desarrollo: IN20, IN20 rev. v2
# Descripción del desarrollo: Fecha nueva recepción en pedido compra
# Fecha: 11/02/2019
# Codigo Actividad: YIN20
#######################################################################################

$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "APRES_CRE"     : Gosub APRES_CRE
  When Default
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
########################################################################
$APRES_CRE
  If GFONCTION = "GESPOH" Then
    Gosub APRES_CRE From SUBPOHA
    Gosub INFORMA_YFECHAREC                                                   # IN20 - YIN20 - rev. v2
    GPE=1
  Endif
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
########################################################################
# IN20 - YIN20 - rev. v2
# Fecha por defecto la de la primera línea de pedido
# tengo que hacerlo de esta forma porque en una ACTION pierde el valor y guarda en tabla 00/00/0000
$INFORMA_YFECHAREC
  If !clalev([F:YPOH]) Then : Local File PORDER [F:YPOH] : Endif
  Read [F:YPOH]POH0 = [M:POH0]POHNUM                                          # busca el pedido en la tabla
  If !fstat Then
    [F:YPOH]YFECHAREC = [M:POH2]EXTRCPDAT(0)                                  # guarda el valor de la fecha en tabla
    Rewrite [F:YPOH]
    [M:POH0]YFECHAREC = [F:YPOH]YFECHAREC                                     # carga en el campo de la pantalla el valor de la tabla
    Affzo [M:POH0]YFECHAREC
  Endif
  If clalev([F:YPOH])  Then : Close Local File  [F:YPOH] : Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Antes de entrada en el campo "Nueva fecha recepción" - IN20 - YIN20
######################################################################################
Subprog AS_YFECHAREC(VALEUR)
Variable Date    VALEUR
  # No permite la entrada si no hay líneas
  If [M:POH2]NBLIG = 0
    mkstat = 2
  Endif
End

######################################################################################
## Después de modificar el campo "Nueva fecha recepción" - IN20 - YIN20
######################################################################################
Subprog AM_YFECHAREC(VALEUR)
Variable Date    VALEUR
  # Confirmar modificación fecha recepción de todas las líneas, actualizar y lanzar acciones de campo
  If VALEUR <> "000000"
    Local Integer OK9
    Call OUINON("¿Desea modificar la fecha de recepción de todas las líneas del pedido?",OK9) From GESECRAN
    If OK9 = 2
      Local Integer LIN
      For LIN=0 To [M:POH2]NBLIG-1
        [M:POH2]EXTRCPDAT(LIN) = VALEUR
        Call AM_EXTRCPDAT(VALEUR) From SUBPOH
        Affzo [M:POH2]EXTRCPDAT(LIN)
      Next
      [M:POH0]YFECHAREC = VALEUR
    Endif
  Endif
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

