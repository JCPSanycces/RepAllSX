##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Al situar el foco en algún registro del grid de cabeceras
######################################################################################
Subprog AS_NBLIG
Local Integer LCON : Raz LCON
Local Decimal LNETPRIC : Raz LNETPRIC

  GNUMLINCAB = nolign-1

  If !clalev([F:YYSOQ]) Then : Local File YSORDERQ [F:YYSOQ] : Endif
  Filter [F:YYSOQ] Where SOHNUM = [M:YEXP1]SOHNUM(nolign-1)        # muestra las líneas del pedido seleccionado
  For [YYSOQ]
    [M:YEXP1]YSOHNUM(LCON)    = [F:YYSOQ]SOHNUM
    [M:YEXP1]POPLIN(LCON)     = ([F:YYSOQ]SOPLIN/1000)
    [M:YEXP1]ITMREF(LCON)     = [F:YYSOQ]ITMREF
    [M:YEXP1]SAU(LCON)        = [F:YYSOQ]SAU
    [M:YEXP1]YUNV(LCON)       = [F:YYSOQ]YUNV
    [M:YEXP1]QTY(LCON)        = [F:YYSOQ]QTY
    [M:YEXP1]YARTALTER(LCON)  = [F:YYSOQ]YARTALTER
    [M:YEXP1]ALLQTY(LCON)     = [F:YYSOQ]ALLQTY
    [M:YEXP1]NETPRI(LCON)     = [F:YYSOQ]NETPRI
    [M:YEXP1]YSELEC1(LCON)    = [F:YYSOQ]YSELEC
    LCON += 1
  Next
  [M:YEXP1]NBLIG1 = LCON
  Affzo [M:YEXP1]15                                                 # tiene que refrescar todo el cuadro porque sino no muestra la descripción del artículo
  Raz LCON
  Filter [F:YYSOQ]

  If clalev([F:YYSOQ])  Then : Close Local File [F:YYSOQ] : Endif

  Gosub PESO_VOLUMEN

End

######################################################################################
## Después de modificar "Unidad preparada"
######################################################################################
Subprog AM_YUNV(VALEUR)
Variable Char    VALEUR()

  If !clalev([F:YYSOQ]) Then : Local File YSORDERQ [F:YYSOQ] : Endif
  Trbegin [F:YYSOQ]
  Filter [F:YYSOQ] Where SOHNUM = [M:YEXP1]YSOHNUM(nolign-1) and SOPLIN = ([M:YEXP1]POPLIN(nolign-1) * 1000)
  Read [F:YYSOQ] First
  If !fstat Then
    [F:YYSOQ]YUNV = VALEUR
    Rewrite [F:YYSOQ]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif
  Filter [F:YYSOQ]
  If clalev([F:YYSOQ])  Then : Close Local File [F:YYSOQ] : Endif

End

######################################################################################
## Después de modificar el campo "Artículo alternativo"
######################################################################################
Subprog AM_YARTALTER(VALEUR)
Variable Char    VALEUR()

  # actualiza la tabla temporal de stocks
  If !clalev([F:YYITV9]) Then : Local File YITMMVT  [F:YYITV9] : Endif
  Filter [F:YYITV9] Where ITMREF = VALEUR
  Read [F:YYITV9] First
  If fstat Then                                                                   # el artículo no está en la tabla temporal YITMMVT
    If !clalev([F:YITV9]) Then : Local File ITMMVT [F:YITV9] : Endif
    Filter [F:YITV9] Where ITMREF = VALEUR
    Read [F:YITV9] First
    If !fstat Then
      Trbegin [F:YYITV9]
      [F:YYITV9]ITMREF     = VALEUR
      [F:YYITV9]STOFCY     = [M:YEXP0]STOFCY
      [F:YYITV9]STU        = [M:YEXP1]SAU(nolign-1)
      [F:YYITV9]PHYSTO     = [F:YITV9]PHYSTO
      [F:YYITV9]YRESHOJAS  = [F:YITV9]GLOALL + [F:YITV9]PHYALL
      [F:YYITV9]ORDSTO     = [F:YITV9]ORDSTO
      [F:YYITV9]SALSTO     = [F:YITV9]SALSTO
      [F:YYITV9]YPREPQTY   = [F:YITV9]PHYSTO - ([F:YITV9]GLOALL + [F:YITV9]PHYALL)
      [F:YYITV9]YTOTEXIST  = [F:YITV9]PHYSTO
      Write [F:YYITV9]                                                             # añade el artículo a la tabla temporal YITMMVT
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Endif
    Filter [F:YITV9]
    Filter [F:YYITV9]
    If clalev([F:YYITV9]) Then : Close Local File  [F:YYITV9] : Endif
    If clalev([F:YITV9])  Then : Close Local File  [F:YITV9]  : Endif
  Endif

  # asigna la unidad de venta del artículo alternativo
  If !clalev([F:YITM9]) Then : Local File ITMMASTER [F:YITM9] : Endif
  Filter [F:YITM9] Where ITMREF = VALEUR
  Read [F:YITM9] First
  If !fstat Then
    [M:YEXP1]SAU(nolign-1) = [F:YITM9]SAU
  Endif
  Filter [F:YITM9]
  If clalev([F:YITM9]) Then : Close Local File [F:YITM9] : Endif

  # asigna el precio de venta del artículo alternativo
  If !clalev([F:YITS9]) Then : Local File ITMSALES [F:YITS9] : Endif
  Filter [F:YITS9] Where ITMREF = VALEUR
  Read [F:YITS9] First
  If !fstat Then
    [M:YEXP1]NETPRI(nolign-1) = [F:YITS9]BASPRI
  Endif
  Filter [F:YITS9]
  If clalev([F:YITS9]) Then : Close Local File [F:YITS9] : Endif

  # actualiza la tabla temporal de líneas añadiendo el código del artículo alternativo
  If !clalev([F:YYSOQ9]) Then : Local File YSORDERQ [F:YYSOQ9] : Endif
  Read [F:YYSOQ9]YSOQ0 = [M:YEXP1]YSOHNUM(nolign-1);([M:YEXP1]POPLIN(nolign-1) * 1000)
  If !fstat Then
    Trbegin [F:YYSOQ9]
    [F:YYSOQ9]YARTALTER = VALEUR
    [F:YYSOQ9]YSELEC    = 2
    [F:YYSOQ9]YUNV      = [M:YEXP1]SAU(nolign-1)
    [F:YYSOQ9]NETPRI    = [M:YEXP1]NETPRI(nolign-1)
    Rewrite [F:YYSOQ9]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif
  If clalev([F:YYSOQ9]) Then : Close Local File  [F:YYSOQ9] : Endif

End

######################################################################################
## Después de modificar el campo "Cantidad asignada"
######################################################################################
Subprog AM_ALLQTY(VALEUR)
Variable Decimal VALEUR
Local Double DIFERENCIA : Raz DIFERENCIA
Local Char CRITSOQ3(255)(0..2) : Raz CRITSOQ3
Local Decimal SUM_CTDASIG : Raz SUM_CTDASIG

######################################################
# AÑADIDO DESPUÉS DE VER QUE NO SE CONTROLABA EL ARTÍCULO ALTERNATIVO
Local Char LITMREF(25) : Raz LITMREF

  If [M:YEXP1]YARTALTER(nolign-1) = "" Then
    LITMREF = [M:YEXP1]ITMREF(nolign-1)
  Else
    LITMREF = [M:YEXP1]YARTALTER(nolign-1)
  Endif
######################################################

  DIFERENCIA  = [M:YEXP1]ALLQTY(nolign-1) - VALEUR
  SUM_CTDASIG = sum([M:YEXP1]ALLQTY(0..[M:YEXP1]NBLIG1-2)) + VALEUR

  If !clalev([F:YYITV3]) Then : Local File YITMMVT  [F:YYITV3] : Endif
  If !clalev([F:YYSOQ3]) Then : Local File YSORDERQ [F:YYSOQ3] : Endif
  If !clalev([F:YYSOH3]) Then : Local File YSORDER  [F:YYSOH3] : Endif
  Trbegin [F:YYSOQ3]
  Filter [F:YYSOQ3] Where SOHNUM = [M:YEXP1]YSOHNUM(nolign-1) and SOPLIN = ([M:YEXP1]POPLIN(nolign-1) * 1000)
  Read [F:YYSOQ3] First
  If !fstat Then
#############    Read [F:YYITV3]YITV0 = [F:YYSOQ3]ITMREF;[F:YYSOQ3]SALFCY
    Read [F:YYITV3]YITV0 = LITMREF;[F:YYSOQ3]SALFCY
    [F:YYITV3]PHYSTO = [F:YYITV3]PHYSTO + DIFERENCIA           # actualiza el campo de la tabla temporal de stocks
    Rewrite [F:YYITV3]
    If [F:YYITV3]PHYSTO >= 0 Then
      [F:YYSOQ3]ALLQTY = VALEUR                                # actualiza el valor del campo (cantidad asignada)
      If VALEUR = 0 Then
        [M:YEXP1]YSELEC1(nolign-1)   = 0
        [F:YYSOQ3]YSELEC  = 0
        Affzo [M:YEXP1]YSELEC1
      Else
        [M:YEXP1]YSELEC1(nolign-1)   = 2
        [M:YEXP1]YSELEC(GNUMLINCAB)  = 2
        Read [F:YYSOH3]YSOH0 = [M:YEXP1]YSOHNUM(nolign-1)
        [F:YYSOQ3]YSELEC  = 2
        Rewrite [F:YYSOQ3]
        Affzo [M:YEXP1]YSELEC1, YSELEC
      Endif
      Rewrite [F:YYSOQ3]
    Else
      Call MESSAGE("No hay stock suficiente") From GESECRAN
      [M:YEXP1]ALLQTY(nolign-1) = VALEUR + DIFERENCIA
      Affzo [M:YEXP1]ALLQTY
      GERR = 1 : mkstat = 2
    Endif
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif

  # realiza la misma función que FLAGS_CABECERA pero para un pedido concreto
  CRITSOQ3(0) = "SELECT SOHNUM_0, SALFCY_0, SUM(QTY_0) AS QTY, SUM(ALLQTY_0) AS ALLQTY "
  CRITSOQ3(1) = "FROM " + nomap + ".YSORDERQ WHERE YARTALTER_0 = '' AND SOHNUM_0 = '" + [M:YEXP1]YSOHNUM(nolign-1) + "' "
  CRITSOQ3(2) = "GROUP BY SOHNUM_0, SALFCY_0"
  For (Char SOHNUM, Char SALFCY, Decimal QTY, Decimal ALLQTY) From "5" Sql CRITSOQ3(0..2) As [ZSQ3]
    If ([F:ZSQ3]ALLQTY - [F:ZSQ3]QTY) < 0                      # si el número de unidades pedidas es superior al de stock restante se marca el check "Inc."
      [M:YEXP1]YINCOMP(GNUMLINCAB) = 2
    Else
      [M:YEXP1]YINCOMP(GNUMLINCAB) = 1
    Endif
    Affzo [M:YEXP1]YINCOMP
  Next

  If SUM_CTDASIG = 0 Then
    [M:YEXP1]YSELEC(GNUMLINCAB)  = 0
    [M:YEXP1]YINCOMP(GNUMLINCAB) = 0
    Read [F:YYSOH3]YSOH0 = [M:YEXP1]YSOHNUM(nolign-1)
    [F:YYSOH3]YSELEC  = 0
    Rewrite [F:YYSOH3]
    Affzo [M:YEXP1]YSELEC, YINCOMP
  Endif

  Filter [F:YYSOQ3]
  If clalev([F:YYSOQ3])  Then : Close Local File [F:YYSOQ3] : Endif
  If clalev([F:YYSOH3])  Then : Close Local File [F:YYSOH3] : Endif
  If clalev([F:YYITV3])  Then : Close Local File [F:YYITV3] : Endif

End

######################################################################################
## Después de modificar el campo "Selec." en el grid de cabeceras
######################################################################################
Subprog AM_YSELEC(VALEUR)
Variable Integer VALEUR
Local Integer LCON : Raz LCON
Local Char CRITSOQ4(255)(0..2) : Raz CRITSOQ4
Local Decimal CTD_REST4 : Raz CTD_REST4

  If VALEUR = 1 Then                                                      # si el check está desactivado...
    If !clalev([F:YYSOH4]) Then : Local File YSORDER  [F:YYSOH4] : Endif
    If !clalev([F:YYSOQ4]) Then : Local File YSORDERQ [F:YYSOQ4] : Endif
    If !clalev([F:YYITV4]) Then : Local File YITMMVT  [F:YYITV4] : Endif
    Trbegin [F:YYSOH4]
    Read [F:YYSOH4]YSOH0 = [M:YEXP1]SOHNUM(nolign-1)
    [F:YYSOH4]YSELEC = 1                                                  #...asigna el mismo valor en la tabla de cabeceras...
    Rewrite [F:YYSOH4]
    Filter [F:YYSOQ4] Where SOHNUM = [M:YEXP1]SOHNUM(nolign-1)
    For [F:YYSOQ4]
      [F:YYSOQ4]YSELEC = 1                                                #...y en la tabla de las líneas...
      [F:YYSOQ4]ALLQTY = 0         # VALIDAR CON IVÁN
      Rewrite [F:YYSOQ4]
    Next
    For LCON = 0 To [M:YEXP1]NBLIG1-1
      [M:YEXP1]YSELEC1(LCON)  = 1
      Read [F:YYITV4]YITV0     = [M:YEXP1]ITMREF(LCON);[M:YEXP0]STOFCY    #...además actualiza las unidades de stock en la tabla de stocks...
      [F:YYITV4]PHYSTO         = [F:YYITV4]PHYSTO + [M:YEXP1]ALLQTY(LCON) #...sumándole la cantidad que tenía asignada al stock disponible...
      [M:YEXP1]ALLQTY(LCON)   = 0                                         #...y deja las unidades del campo en pantalla a cero ******NO HACE CASO!!!!!!!!
      Rewrite [F:YYITV4]
    Next
    Filter [F:YYSOQ4]
    Commit
    If clalev([F:YYSOH4])  Then : Close Local File [F:YYSOH4] : Endif
    If clalev([F:YYSOQ4])  Then : Close Local File [F:YYSOQ4] : Endif
    If clalev([F:YYITV4])  Then : Close Local File [F:YYITV4] : Endif
  Else                                                                   # si se activa el check...
    # realiza la misma función que REPARTIR_STOCK pero para este pedido concreto
    If !clalev([F:YYITV4]) Then : Local File YITMMVT  [F:YYITV4] : Endif
    If !clalev([F:YYSOH4]) Then : Local File YSORDER  [F:YYSOH4] : Endif
    If !clalev([F:YYSOQ4]) Then : Local File YSORDERQ [F:YYSOQ4] : Endif
    Trbegin [F:YYSOQ4]
    Read [F:YYSOH4]YSOH0 = [M:YEXP1]SOHNUM(nolign-1)
    If !fstat Then
      [F:YYSOH4]YSELEC = 2
      Rewrite [F:YYSOH4]
    Endif
    Filter [F:YYSOQ4] Where SOHNUM = [M:YEXP1]SOHNUM(nolign-1)
    For [F:YYSOQ4]
      Read [F:YYITV4]YITV0 = [F:YYSOQ4]ITMREF;[F:YYSOQ4]SALFCY           # busca en la tabla temporal el stock del artículo
      If !fstat Then
        If [F:YYITV4]PHYSTO > 0 Then
          CTD_REST4 = [F:YYITV4]PHYSTO - [F:YYSOQ4]QTY
          If CTD_REST4 > 0 Then                                          # si hay stock suficiente para cubrir la necesidad...
            [F:YYSOQ4]ALLQTY            = [F:YYSOQ4]QTY                  # ...asigna la cantidad...
            [M:YEXP1]ALLQTY(nolign-1)   = [F:YYSOQ4]QTY
            [F:YYSOQ4]YSELEC            = 2                              # ...marca el campo YSELEC como activado
            [M:YEXP1]YSELEC(nolign-1)   = 2
            [F:YYITV4]PHYSTO            = CTD_REST4                      # ...y actualiza el stock del artículo
            Rewrite [F:YYSOQ4]
            Rewrite [F:YYITV4]
            Affzo [M:YEXP1]ALLQTY,YSELEC
          Else                                                           # si no hay stock suficiente para cubrir la necesidad...
            [F:YYSOQ4]ALLQTY            = [F:YYITV4]PHYSTO               # ...asigna las unidades que quedan a la línea de pedido...
            [M:YEXP1]ALLQTY(nolign-1)   = [F:YYITV4]PHYSTO
            [F:YYITV4]PHYSTO            = 0                              # ... y deja el stock a cero
            [F:YYSOQ4]YSELEC            = 2                              # VALIDAR CON IVÁN SI AQUÍ TAMBIÉN HAY QUE PONER EL CAMPO IGUAL A 2
            [M:YEXP1]YSELEC(nolign-1)   = 2
            Rewrite [F:YYSOQ4]
            Rewrite [F:YYITV4]
            Affzo [M:YEXP1]ALLQTY,YSELEC
          Endif
        Endif
      Endif
    Next
    Commit
    If clalev([F:YYSOH4])  Then : Close Local File   [F:YYSOH4] : Endif
    If clalev([F:YYSOQ4])  Then : Close Local File   [F:YYSOQ4] : Endif
    If clalev([F:YYITV4])  Then : Close Local File   [F:YYITV4] : Endif

    # realiza la misma función que FLAGS_CABECERA pero para un pedido concreto
    CRITSOQ4(0) = "SELECT SOHNUM_0, SALFCY_0, SUM(QTY_0) AS QTY, SUM(ALLQTY_0) AS ALLQTY "
    CRITSOQ4(1) = "FROM " + nomap + ".YSORDERQ WHERE YARTALTER_0 = '' AND SOHNUM_0 = '" + [M:YEXP1]SOHNUM(nolign-1) + "' "
    CRITSOQ4(2) = "GROUP BY SOHNUM_0, SALFCY_0"
    For (Char SOHNUM, Char SALFCY, Decimal QTY, Decimal ALLQTY) From "5" Sql CRITSOQ4(0..2) As [ZSQ4]
      If ([F:ZSQ4]ALLQTY - [F:ZSQ4]QTY) < 0                      # si el número de unidades pedidas es superior al de stock restante se marca el check "Inc."
        [M:YEXP1]YINCOMP(nolign-1) = 2
      Else
        [M:YEXP1]YINCOMP(nolign-1) = 1
      Endif
      Affzo [M:YEXP1]YINCOMP
    Next
  Endif

  Affzo [M:YEXP1]YSELEC1

End

######################################################################################
## Después de modificar el campo "Selec." en el grid de líneas
######################################################################################
Subprog AM_YSELEC1(VALEUR)
Variable Integer VALEUR
Local Integer LCON, MARK : Raz LCON, MARK
Local Decimal LALLQTY, CPED, CASI, CTD_REST : Raz LALLQTY, CPED, CASI, CTD_REST
Local Char LITMREF(50), LSALFCY(10) : Raz LITMREF, LSALFCY
Local Char CRITSOQ5(255)(0..2) : Raz CRITSOQ5

  If VALEUR = 1 Then                                                        # si el check está desactivado...
    If !clalev([F:YYSOH5]) Then : Local File YSORDER  [F:YYSOH5] : Endif
    If !clalev([F:YYSOQ5]) Then : Local File YSORDERQ [F:YYSOQ5] : Endif
    If !clalev([F:YYITV5]) Then : Local File YITMMVT  [F:YYITV5] : Endif
    Trbegin [F:YYSOQ5]
    Read [F:YYSOQ5]YSOQ0 = [M:YEXP1]YSOHNUM(nolign-1);([M:YEXP1]POPLIN(nolign-1) * 1000)
    [F:YYSOQ5]YSELEC              = 1                                       #...asigna el mismo valor en la tabla de líneas...
    [F:YYSOQ5]ALLQTY              = 0                                       #...pone a cero la cantidad asignada en la tabla...
    LALLQTY                       = [M:YEXP1]ALLQTY(nolign-1)
    LITMREF                       = [F:YYSOQ5]ITMREF
    LSALFCY                       = [F:YYSOQ5]SALFCY
    [M:YEXP1]ALLQTY(nolign-1)     = 0                                       #...pone a cero la cantidad asignada en la pantalla...
    [F:YYSOQ5]YARTALTER           = ""                                      #...vacía el artículo alternativo en la tabla...
    [M:YEXP1]YARTALTER(nolign-1)  = ""                                      #...vacía el artículo alternativo en la pantalla...
    [F:YYSOQ5]YUNV                = [F:YYSOQ5]SAU                           #...iguala las unidades en la tabla...
    [M:YEXP1]YUNV(nolign-1)       = [M:YEXP1]SAU                            #...iguala las unidades en la pantalla...
    Rewrite [F:YYSOQ5]
    Read [F:YYITV5]YITV0 = LITMREF;LSALFCY
    [F:YYITV5]PHYSTO              = [F:YYITV5]PHYSTO + LALLQTY              #...actualiza el stock disponible del artículo
    Rewrite [F:YYITV5]
    Filter [F:YYSOQ5] Where SOHNUM = [M:YEXP1]YSOHNUM(nolign-1)
    MARK = 1
    For [F:YYSOQ5]
      CPED = CPED + [F:YYSOQ5]QTY                                           # suma las cantidades pedidas de ese pedido
      CASI = CASI + [F:YYSOQ5]ALLQTY                                        # suma las cantidades asignadas de ese pedido
      If [F:YYSOQ5]YSELEC = 2 Then                                          # comprueba si todas las líneas están desmarcadas
        MARK = 2                                                            # si existe alguna línea marcada, cambia de valor la variable de control
      Endif
    Next
    Read [F:YYSOH5]YSOH0 = [M:YEXP1]YSOHNUM(nolign-1)
    If MARK = 1 Then                                                        # si todas las líneas están desmarcadas...
      [F:YYSOH5]YSELEC                = 1                                   #...desmarca el check "Selec." en la tabla de cabeceras...
      [M:YEXP1]YSELEC(GNUMLINCAB)     = 1                                   #...desmarca el check "Selec." en la pantalla...
      [M:YEXP1]YINCOMP(GNUMLINCAB)    = 1                                   #...desmarca el check "Inc." en la pantalla
    Else                                                                    # si existe alguna línea marcada...
      [F:YYSOH5]YSELEC  = 2                                                 #...marca el check "Selec." en la tabla de cabeceras...
      [M:YEXP1]YSELEC(GNUMLINCAB)     = 2                                   #...marca el check "Selec." en la pantalla
      If CPED = CASI                                                        # si el total de las cantidades pedidas es igual a al total de las asignadas
        [M:YEXP1]YINCOMP(GNUMLINCAB)  = 1                                   #...desmarca el check "Inc."
      Else                                                                  # sino...
        [M:YEXP1]YINCOMP(GNUMLINCAB)  = 2                                   #...marca el check "Inc."
      Endif
    Endif
    Rewrite [F:YYSOH5]
    Filter [F:YYSOQ5]
    Commit
    If clalev([F:YYSOH5])  Then : Close Local File [F:YYSOH5] : Endif
    If clalev([F:YYSOQ5])  Then : Close Local File [F:YYSOQ5] : Endif
    If clalev([F:YYITV5])  Then : Close Local File [F:YYITV5] : Endif
  Else                                                                      # si se activa el check...
    # realiza la misma función que REPARTIR_STOCK pero para este pedido concreto
    If !clalev([F:YYITV5]) Then : Local File YITMMVT  [F:YYITV5] : Endif
    If !clalev([F:YYSOH5]) Then : Local File YSORDER  [F:YYSOH5] : Endif
    If !clalev([F:YYSOQ5]) Then : Local File YSORDERQ [F:YYSOQ5] : Endif
    Trbegin [F:YYSOQ5]
    Read [F:YYSOH5]YSOH0 = [M:YEXP1]YSOHNUM(nolign-1)
    If !fstat Then
      [F:YYSOH5]YSELEC = 2
      Rewrite [F:YYSOH5]
    Endif
    Read [F:YYSOQ5]YSOQ0 = [M:YEXP1]YSOHNUM(nolign-1);([M:YEXP1]POPLIN(nolign-1) * 1000)
    If !fstat Then
      Read [F:YYITV5]YITV0 = [F:YYSOQ5]ITMREF;[F:YYSOQ5]SALFCY              # busca en la tabla temporal el stock del artículo
      If !fstat Then
        If [F:YYITV5]PHYSTO > 0 Then
          CTD_REST = [F:YYITV5]PHYSTO - [F:YYSOQ5]QTY
          If CTD_REST > 0 Then                                              # si hay stock suficiente para cubrir la necesidad...
            [F:YYSOQ5]ALLQTY            = [F:YYSOQ5]QTY                     # ...asigna la cantidad...
            [M:YEXP1]ALLQTY(nolign-1)   = [F:YYSOQ5]QTY
            [F:YYSOQ5]YSELEC            = 2                                 # ...marca el campo YSELEC como activado
            [M:YEXP1]YSELEC(GNUMLINCAB) = 2
            [F:YYITV5]PHYSTO            = CTD_REST                          # ...y actualiza el stock del artículo
            Rewrite [F:YYSOQ5]
            Rewrite [F:YYITV5]
            Affzo [M:YEXP1]ALLQTY,YSELEC
          Else                                                              # si no hay stock suficiente para cubrir la necesidad...
            [F:YYSOQ5]ALLQTY            = [F:YYITV5]PHYSTO                  # ...asigna las unidades que quedan a la línea de pedido...
            [M:YEXP1]ALLQTY(nolign-1)   = [F:YYITV5]PHYSTO
            [F:YYITV5]PHYSTO            = 0                                 # ... y deja el stock a cero
            [F:YYSOQ5]YSELEC            = 2                                 # VALIDAR CON IVÁN SI AQUÍ TAMBIÉN HAY QUE PONER EL CAMPO IGUAL A 2
            [M:YEXP1]YSELEC(GNUMLINCAB) = 2
            Rewrite [F:YYSOQ5]
            Rewrite [F:YYITV5]
            Affzo [M:YEXP1]ALLQTY,YSELEC
          Endif
        Endif
      Endif
    Endif
    Commit
    If clalev([F:YYSOH5])  Then : Close Local File   [F:YYSOH5] : Endif
    If clalev([F:YYSOQ5])  Then : Close Local File   [F:YYSOQ5] : Endif
    If clalev([F:YYITV5])  Then : Close Local File   [F:YYITV5] : Endif

    # realiza la misma función que FLAGS_CABECERA pero para un pedido concreto
    CRITSOQ5(0) = "SELECT SOHNUM_0, SALFCY_0, SUM(QTY_0) AS QTY, SUM(ALLQTY_0) AS ALLQTY "
    CRITSOQ5(1) = "FROM " + nomap + ".YSORDERQ WHERE YARTALTER_0 = '' AND SOHNUM_0 = '" + [M:YEXP1]YSOHNUM(nolign-1) + "' "
    CRITSOQ5(2) = "GROUP BY SOHNUM_0, SALFCY_0"
    For (Char SOHNUM, Char SALFCY, Decimal QTY, Decimal ALLQTY) From "5" Sql CRITSOQ5(0..2) As [ZSQ5]
      If ([F:ZSQ5]ALLQTY - [F:ZSQ5]QTY) < 0                      # si el número de unidades pedidas es superior al de stock restante se marca el check "Inc."
        [M:YEXP1]YINCOMP(GNUMLINCAB) = 2
      Else
        [M:YEXP1]YINCOMP(GNUMLINCAB) = 1
      Endif
      Affzo [M:YEXP1]YINCOMP
    Next
  Endif

  Affzo [M:YEXP1]ALLQTY,YARTALTER,YUNV
  Affzo [M:YEXP1]YSELEC,YINCOMP

End

