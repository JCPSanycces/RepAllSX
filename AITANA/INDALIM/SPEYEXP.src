######################################################################################
## Después de modificar el filtro de "Pedido"
######################################################################################
Subprog AM_SOHNUM1(VALEUR)
Variable Char    VALEUR()
Local Integer LCON6 : Raz LCON6

  Effzo [M:YEXP1]10
  If !clalev([F:YYSOH6]) Then : Local File YSORDER  [F:YYSOH6] : Endif
  If VALEUR <> "" Then
    Filter [F:YYSOH6] Where SOHNUM = VALEUR
  Endif
  For [YYSOH6]
    [M:YEXP1]YSELEC(LCON6)     = [F:YYSOH6]YSELEC
    [M:YEXP1]SOHNUM(LCON6)     = [F:YYSOH6]SOHNUM
    [M:YEXP1]BPCORD(LCON6)     = [F:YYSOH6]BPCORD
    [M:YEXP1]BPCNAM(LCON6)     = [F:YYSOH6]BPCNAM
    [M:YEXP1]BPAADD(LCON6)     = [F:YYSOH6]BPAADD
    [M:YEXP1]BPDADDLIG(LCON6)  = [F:YYSOH6]BPDADDLIG
    [M:YEXP1]ORDDAT(LCON6)     = [F:YYSOH6]ORDDAT
    [M:YEXP1]DEMDLVDAT(LCON6)  = [F:YYSOH6]DEMDLVDAT
    [M:YEXP1]BPDCTY(LCON6)     = [F:YYSOH6]BPDCTY
#    [M:YEXP1]DSPTOTWEI(LCON6)  = [F:YYSOH6]DSPTOTWEI
#    [M:YEXP1]DSPTOTVOL(LCON6)  = [F:YYSOH6]DSPTOTVOL
#    [M:YEXP1]ORDNOT(LCON6)     = [F:YYSOH6]ORDNOT
#    [M:YEXP1]ORDATI(LCON6)     = [F:YYSOH6]ORDATI
##    [M:YEXP1]YOBSER(LCON6)     = [F:YYSOH6]YOBSERVC - "-" - [F:ZCPV]YOBSERVP
    LCON6 += 1
  Next
  [M:YEXP1]NBLIG = LCON6
  Gosub FLAGS_CABECERA
  Affzo [M:YEXP1]10
  If clalev([F:YYSOH6])  Then : Close Local File    [F:YYSOH6] : Endif

End

