##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
#######################
#**
#* llama a la función FLAGS_CABECERA
#*
#*!
Subprog CALL_FLAGS()
Local Char CRITSOQ(255)(0..2) : Raz CRITSOQ
Local Integer LCON : Raz LCON

  If !clalev([F:YYSOH]) Then : Local File YSORDER  [F:YYSOH] : Endif
  Trbegin [F:YYSOH]

  CRITSOQ(0) = "SELECT SOHNUM_0, SALFCY_0, SUM(QTY_0) AS QTY, SUM(ALLQTY_0) AS ALLQTY "
  CRITSOQ(1) = "FROM " + nomap + ".YSORDERQ "
  CRITSOQ(2) = "GROUP BY SOHNUM_0, SALFCY_0"
  For (Char SOHNUM, Char SALFCY, Double QTY, Double ALLQTY) From "5" Sql CRITSOQ(0..2) As [ZSQ2]
    For LCON = 0 To [M:YEXP1]NBLIG-1                                      # busca en el cuadro de cabeceras el pedido
      If [M:YEXP1]SOHNUM(LCON) = [F:ZSQ2]SOHNUM
        If [F:ZSQ2]ALLQTY > 0 Then                                        # si hay, al menos, una unidad para servir se marca el check "Sel."
          [M:YEXP1]YSELEC(LCON) = 2
          Read [F:YYSOH]YSOH0 = [F:ZSQ2]SOHNUM
          [F:YYSOH]YSELEC = 2                                             # guarda el valor de "Sel." también en la tabla de cabeceras
          Rewrite [F:YYSOH]
        Endif
        If [F:YYSOH]YSELEC <> 2 Then
          If ([F:ZSQ2]ALLQTY - [F:ZSQ2]QTY) < 0                           # si el número de unidades pedidas es superior al de stock restante se marca el check "Inc."
            [M:YEXP1]YINCOMP(LCON) = 2
          Endif
        Endif
      Endif
    Next
  Next
  Affzo [M:YEXP1]YSELEC,YINCOMP

  Commit
  If clalev([F:YYSOH])  Then : Close Local File [F:YYSOH] : Endif

End

#######################
#**
#* calcula el importe neto de cabecera
#*
#* @param PNUMLIN  > número de línea de grid de cabecera
#* @param PNETPRI  > devuelve el importe neto de las líneas
#*!
Subprog CALC_NETPRIC(PNUMLIN, PNETPRI)
Value     Integer PNUMLIN
Variable  Decimal PNETPRI

  If !clalev([F:YSQ0]) Then : Local File YSORDERQ [F:YSQ0] : Endif
  Filter [F:YSQ0] Where SOHNUM = [M:YEXP1]SOHNUM(PNUMLIN)
  For [YSQ0]
    If [F:YSQ0]YSELEC = 2 Then
      PNETPRI = PNETPRI + ([F:YSQ0]NETPRI * [F:YSQ0]ALLQTY)
    Endif
  Next
  Filter [F:YSQ0]
  If clalev([F:YSQ0])  Then : Close Local File    [F:YSQ0] : Endif
End

#######################
#**
#* genera la asignación en los pedidos
#*
#* @param PSOH  > número de pedido
#*!
Subprog ASIGNACION(PSOH)
Value Char PSOH

Local Integer LRET
Local Char PARAM(20)(1..20)
  PARAM(1)=PSOH
  Call SAISIE_LIB(LRET,PARAM,"DAUTALL","FUNAUTALL","XYFUNAUTALL") From GSAISIE
End


#######################
#**
#* devuelve el siguiente número de contador para YHR
#*
#* @param PSEQCODE  > devuelve número de contador
#*!
Subprog GENNUMBER(PSEQCODE)
Variable Char PSEQCODE
Local Integer LSTAT
  Call NUMERO("YHR", nomap, date$, "null", PSEQCODE, LSTAT) From SUBANM
End

