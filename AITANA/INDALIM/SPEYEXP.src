#######################################################################################

$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "CREATION"     : Gosub CREATION
  When "SEL_TABLE"    : Gosub SEL_TABLE
  When "VERF_TABLE"   : Gosub VERF_TABLE
  When "DEBUT"        : Gosub DEBUT
  When "SETBOUT"      : Gosub SETBOUT
  When "BOUTON"       : Gosub BOUTON
  When "MEN"          : Gosub BOUTON
  When "FIN"          : Gosub FIN
  When Default
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
########################################################################
$CREATION
#Local Integer LCON : Raz LCON
#
#  # guarda las condiciones de Familia
#  For LCON = 0 To [M:YCOND0]NBLIG-1
#    [F:YCFA]YCDGCOND1   = [F:YCON]YCDGCOND
#    [F:YCFA]YCODFAM1    = [M:YCOND0]YCODFAM1(LCON)
#    [F:YCFA]YFECHAINI1  = [F:YCON]YFECHAINI
#    [F:YCFA]YFECHAFIN1  = [F:YCON]YFECHAFIN
#    [F:YCFA]YTIPOMRG1   = [M:YCOND0]YTIPOMRG1(LCON)
#    [F:YCFA]YPORMRG1    = [M:YCOND0]YPORMRG1(LCON)
#    Write [F:YCFA]
#  Next
#  Raz LCON

Return

########################################################################
$SEL_TABLE
  Case TABLE
    When "YVHSEXP"  : Gosub SEL_YVHSEXP                                     # selección para el campo medio (vehículo) en la cabecera
    When "YFILSOH"  : Gosub SEL_YFILSOH                                     # selección para el filtro de Pedido
    When "YFILBPC"  : Gosub SEL_YFILBPC                                     # selección para el filtro de Cliente
    When "YFILBPA"  : Gosub SEL_YFILBPA                                     # selección para el filtro de Dir. entrega
  Endcase
Return

########################################################################
# esta etiqueta se utiliza para realizar acciones específicas cuando se selecciona una de las opciones en la ventana de selección
$VERF_TABLE
  Case TABLE
    When "YVHSEXP"  : Gosub VERF_YVHSEXP
    When "YFILSOH"  : Gosub VERF_YFILSOH
    When "YFILBPC"  : Gosub VERF_YFILBPC
    When "YFILBPA"  : Gosub VERF_YFILBPA
  Endcase
Return

########################################################################
$SEL_YVHSEXP
  If !clalev([F:YVHS]) Then : Local File YVEHICULOS [F:YVHS] : Endif
  Default File [YVHS]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Mantenimiento de vehículos"                                    # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Medio"                                                         # título de la segunda columna
  COL(NBCOL)  = "YMARCA"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Matrícula"                                                     # título de la primera columna
  COL(NBCOL)  = "YMATRICULA"                                                    # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la tercera columna
  COL(NBCOL)  = "YMODELO"                                                       # nombre del campo a mostrar en la tercera columna
Return

########################################################################
$VERF_YVHSEXP

  [M:YEXP0]YMATRICULA   = [F:YVHS]YMATRICULA
  [M:YEXP0]YMODELO      = [F:YVHS]YMODELO
  [M:YEXP0]YCONDHAB     = [F:YVHS]YCONDHAB
  [M:YEXP0]YVOLMAX      = [F:YVHS]YVOLMAX
  [M:YEXP0]YPESMAX      = [F:YVHS]YPESMAX
  [M:YEXP0]YPEBRUMAX    = [F:YVHS]YPEBRUMAX

  Affzo [M:YEXP0]YMARCA,YMODELO,YCONDHAB,YVOLMAX,YPESMAX,YPEBRUMAX

Return

########################################################################
$SEL_YFILSOH
  If !clalev([F:YSO1]) Then : Local File YSORDER [F:YSO1] : Endif
  Default File [YSO1]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Pedidos"                                                       # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Num. pedido"                                                   # título de la segunda columna
  COL(NBCOL)  = "SOHNUM"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Id. cliente"                                                   # título de la primera columna
  COL(NBCOL)  = "BPCORD"                                                        # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Razón social"                                                  # título de la tercera columna
  COL(NBCOL)  = "BPCNAM"                                                        # nombre del campo a mostrar en la tercera columna
Return

########################################################################
$VERF_YFILSOH
Return

########################################################################
$SEL_YFILBPC
  If !clalev([F:YVC]) Then : Local File YVISFILBPC [F:YVC] : Endif
  Default File [YVC]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Clientes"                                                      # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Id. cliente"                                                   # título de la primera columna
  COL(NBCOL)  = "BPCORD"                                                        # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Razón social"                                                  # título de la tercera columna
  COL(NBCOL)  = "BPCNAM"                                                        # nombre del campo a mostrar en la tercera columna
Return

########################################################################
$VERF_YFILBPC
Return

########################################################################
$SEL_YFILBPA
  If !clalev([F:YVD]) Then : Local File YVISFILBPA [F:YVD] : Endif
  Default File [YVD]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Dirección entrega"                                             # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Id. dir. entrega"                                              # título de la segunda columna
  COL(NBCOL)  = "BPAADD"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Dir. entrega"                                                  # título de la primera columna
  COL(NBCOL)  = "BPDADDLIG"                                                     # nombre del campo a mostrar en la primera columna
Return

########################################################################
$VERF_YFILBPA
Return

########################################################################
$DEBUT
Local Integer LCON  : Raz LCON
Global Integer GNUMLINCAB : Raz GNUMLINCAB

  If !clalev([F:YYZNC1]) Then : Local File YZONAC [F:YYZNC1] : Endif
  For [YYZNC1]
    [M:YEXP0]YCODZONA(LCON) = [F:YYZNC1]YCODZONA
    [M:YEXP0]YDESZONA(LCON) = [F:YYZNC1]YDESZONA
    [M:YEXP0]YSELEC(LCON)   = 2
    LCON += 1
  Next
  [M:YEXP0]NBLIG = LCON
  Affzo [M:YEXP0]YCODZONA,YDESZONA,YSELEC,NBLIG
  If clalev([F:YYZNC1]) Then : Close Local File [F:YYZNC1] : Endif
  Raz LCON

  If !clalev([F:YYRTC1]) Then : Local File YRUTAC [F:YYRTC1] : Endif
  For [YYRTC1]
    [M:YEXP0]YCODRUTA(LCON) = [F:YYRTC1]YCODRUTA
    [M:YEXP0]YDESRUTA(LCON) = [F:YYRTC1]YDESRUTA
    [M:YEXP0]YSELEC2(LCON)  = 2
    LCON += 1
  Next
  [M:YEXP0]NBLIG2 = LCON
  Affzo [M:YEXP0]YCODRUTA,YDESRUTA,YSELEC2,NBLIG2
  If clalev([F:YYRTC1]) Then : Close Local File [F:YYRTC1] : Endif

  [M:YEXP0]YDIAS    = 8
  [M:YEXP0]YDISPON  = 1
  Affzo [M:YEXP0]YDIAS,YDISPON

  Gosub VACIAR_TABLAS                                                   # vacía todas las tablas temporales (YSORDER, YSORDERQ, YITMMVT, YSORDERQF, YITMMVTF)

Return

########################################################################
$SETBOUT
Raz CHMEN

  Case BOUT
    When "O" : CHMEN += "mdrts" # : Call VIREBOUT(CHAINE,"abcf") From GOBJET
    When "d" : CHMEN += "mdrtps"
    When "m" : CHMEN += "mdrtps"
    When "r" : CHMEN += "mdrtps"
    When "t" : CHMEN += "mdrtps"
    When "s" : CHMEN += "mdrtpabfs"
    When "a" : CHMEN += "mdrtpabfs"
    When "b" : CHMEN += "mdrtpabfs"
    When "f" : CHMEN += "mdrtp"
    When "p" : CHMEN += "mdrtpabfs"
#    When "q" : CHMEN += "mdrtps"
#    When "e" : CHMEN += "mdrtg"
#    When "g" : CHMEN += "mdrth"
#    When "h" : CHMEN += "mdrt"
  Endcase

  Gosub CALCULA_NETPRI
  Gosub PESO_VOLUMEN

Return

########################################################################
$BOUTON

  Case BOUT
    When "s"  : Gosub PROPONER_CANTIDADES
    When "a"  : Gosub ASIGNAR_REFERENCIA
    When "m"  : Gosub MARCAR_ZONAS
    When "d"  : Gosub DESMARCAR_ZONAS
    When "r"  : Gosub MARCAR_RUTAS
    When "t"  : Gosub DESMARCAR_RUTAS
    When "b"  : Gosub FALTAS_TOTALES
    When "f"  : Gosub GENERA_FICHIE
    When "p"  : Gosub DESMARCAR_PEDIDOS
#    When "q"  : Gosub MARCAR_PEDIDOS
#    When "p"  : Gosub PLAN_PREPARACION
#    When "e"  : Gosub ENTREGA_VALES_PREPARACION
#    When "g"  : Gosub ASIGNAR_PROYECTO_A_ENTREGA
#    When "h"  : Gosub VALIDACION_DE_ENTREGAS
    When Default
  Endcase
Return

########################################################################
$FIN

  Execsql From "5"  Sql "truncate table " + nomap + ".YSORDER"
  Execsql From "5"  Sql "truncate table " + nomap + ".YSORDERQ"
  Execsql From "5"  Sql "truncate table " + nomap + ".YITMMVT"
  Execsql From "5"  Sql "truncate table " + nomap + ".YSORDERQF"
  Execsql From "5"  Sql "truncate table " + nomap + ".YITMMVTF"

Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$PROPONER_CANTIDADES

  Gosub VACIAR_TABLAS
  Gosub BUSCAR_PEDIDOS            # busca los pedidos filtrados y rellena las tablas temporales de cabeceras y líneas
  Gosub RELLENA_STOCKS            # rellena la tabla temporal de stocks
  Gosub REPARTIR_STOCK            # asigna a las líneas de pedidos filtradas las cantidades disponibles del artículo
  Gosub FLAGS_CABECERA            # marca o desmarca los checks "Sel." e "Inc." de las cabeceras en base al stock de sus líneas
  Gosub DUPLICA_TABLAS            # duplica las tablas temporales de líneas y stock por si hay que restaurar a posteriori
  Gosub CALCULA_NETPRI            # calcula el importe neto de las cabeceras

Return

##############################################################
$BUSCAR_PEDIDOS
Local Integer LCON, LCON2, LCON3, W : Raz LCON, LCON2, LCON3
Local Clbfile LCRIT1(2), LCRIT2(2) : Raz LCRIT1, LCRIT2
Local Integer NCHAR, I, J, K, L, M, N, P, Q : Raz NCHAR, I, J, K, L, M, N, P, Q
Local Integer VARINI : Raz VARINI
Local Char DYN_CRIT1(35)(0..), DYN_CRIT2(35)(0..), DYN_CRITSQL(255)(0..) : Raz DYN_CRIT1, DYN_CRIT2, DYN_CRITSQL
Local Integer NUMREG : Raz NUMREG

  If !clalev([F:YYZND])  Then : Local File YZONAD    [F:YYZND]  : Endif                 # zonas
  If !clalev([F:YYRTD])  Then : Local File YRUTAD    [F:YYRTD]  : Endif                 # rutas
  If !clalev([F:YYSOH])  Then : Local File YSORDER   [F:YYSOH]  : Endif                 # temporal cabecera pedidos
  If !clalev([F:YYSOQ])  Then : Local File YSORDERQ  [F:YYSOQ]  : Endif                 # temporal líneas pedidos
  If !clalev([F:YSOQ])   Then : Local File SORDERQ   [F:YSOQ]   : Endif                 # líneas de pedidos (Cantidad)
  If !clalev([F:YSOP])   Then : Local File SORDERP   [F:YSOP]   : Endif                 # líneas de pedidos (Precios)
  If !clalev([F:YITM])   Then : Local File ITMMASTER [F:YITM]   : Endif                 # artículos

  For LCON2 = 0 To [M:YEXP0]NBLIG2-1
    If [M:YEXP0]YSELEC2(LCON2) = 2 Then
      Filter [F:YYRTD] Where YCODRUTA = [M:YEXP0]YCODRUTA(LCON2)
      For [YYRTD]
        If I = 0 Then
          DYN_CRIT1(I) = "BPDPOSCOD_0='"+[YYRTD]POSCOD+"'"
        Else
          DYN_CRIT1(I) = " OR BPDPOSCOD_0='"+[YYRTD]POSCOD+"'"
        Endif
        I += 1
      Next
      Filter [F:YYRTD]
    Endif
  Next LCON2

  For LCON = 0 To [M:YEXP0]NBLIG-1
    If [M:YEXP0]YSELEC(LCON) = 2 Then
      Filter [F:YYZND] Where YCODZONA = [M:YEXP0]YCODZONA(LCON)
      For [YYZND]
        If K = 0 Then
          DYN_CRIT2(K) = " BPDPOSCOD_0='"+[YYZND]POSCOD+"'"
        Else
          DYN_CRIT2(K) = " OR BPDPOSCOD_0='"+[YYZND]POSCOD+"'"
        Endif
        K += 1
      Next
      Filter [F:YYZND]
    Endif
  Next LCON

  DYN_CRITSQL(0) = "SELECT " + nomap + ".SORDER.SOHNUM_0," + nomap + ".SORDER.BPCORD_0," + nomap + ".SORDER.BPCNAM_0," + nomap + ".SORDER.BPAADD_0," + nomap + ".BPDLVCUST.BPDNAM_0,"
  DYN_CRITSQL(0) = DYN_CRITSQL(0) + nomap + ".SORDER.ORDDAT_0," + nomap + ".SORDER.DEMDLVDAT_0," + nomap + ".SORDER.SALFCY_0," + nomap + ".SORDER.BPDCTY_0,"
  DYN_CRITSQL(1) = nomap + ".SORDER.DSPTOTWEI_0," + nomap + ".SORDER.DSPTOTVOL_0," + nomap + ".SORDER.ORDNOT_0," + nomap + ".SORDER.ORDATI_0,"
  DYN_CRITSQL(2) = nomap + ".SORDER.BPDCRY_0," + nomap + ".BPDLVCUST.YOBSERV1_0," + nomap + ".SORDER.YOBSERV_0 "
  DYN_CRITSQL(2) = DYN_CRITSQL(2) + "FROM " + nomap + ".SORDER INNER JOIN " + nomap + ".BPDLVCUST ON " + nomap + ".SORDER.BPCORD_0 = " + nomap + ".BPDLVCUST.BPCNUM_0 AND "
  DYN_CRITSQL(2) = DYN_CRITSQL(2) + nomap + ".SORDER.BPAADD_0 = " + nomap + ".BPDLVCUST.BPAADD_0 "
  If [M:YEXP0]YDIAS <> 8 Then
    DYN_CRITSQL(3) = "WHERE (" + nomap + ".SORDER.SALFCY_0='"+[M:YEXP0]STOFCY+"') AND (" + nomap + ".SORDER.DLVSTA_0=1 OR " + nomap + ".SORDER.DLVSTA_0=2) AND "
    DYN_CRITSQL(3) = DYN_CRITSQL(3) + "(" + nomap + ".SORDER.APPFLG_0=5) AND (" + nomap + ".SORDER.ALLSTA_0<>3) AND (" + nomap + ".SORDER.ORDSTA_0=1) AND "
    DYN_CRITSQL(3) = DYN_CRITSQL(3) + "(" + nomap + ".BPDLVCUST.UVYDAY"+num$([M:YEXP0]YDIAS)+"_0=2) AND "
    DYN_CRITSQL(4) = "(" + nomap + ".SORDER.CDTSTA_0=1) AND (" + nomap + ".SORDER.HLDSTA_0=1) AND "
    DYN_CRITSQL(5) = "(" + nomap + ".BPDLVCUST.YDISPON"+num$([M:YEXP0]YDIAS)+"_0="+num$([M:YEXP0]YDISPON)+") "
  Else
    DYN_CRITSQL(3) = "WHERE (" + nomap + ".SORDER.SALFCY_0='"+[M:YEXP0]STOFCY+"') AND (" + nomap + ".SORDER.DLVSTA_0=1 OR " + nomap + ".SORDER.DLVSTA_0=2) AND "
    DYN_CRITSQL(3) = DYN_CRITSQL(3) + "(" + nomap + ".SORDER.APPFLG_0=5) AND (" + nomap + ".SORDER.ALLSTA_0<>3) AND (" + nomap + ".SORDER.ORDSTA_0=1) AND "
    DYN_CRITSQL(4) = "(" + nomap + ".SORDER.CDTSTA_0=1) AND (" + nomap + ".SORDER.HLDSTA_0=1) AND "
    DYN_CRITSQL(5) = "((" + nomap + ".BPDLVCUST.YDISPON1_0="+num$([M:YEXP0]YDISPON)+" AND " + nomap + ".BPDLVCUST.UVYDAY1_0=2) OR "
    DYN_CRITSQL(5) = DYN_CRITSQL(5) + "(" + nomap + ".BPDLVCUST.YDISPON2_0="+num$([M:YEXP0]YDISPON)+" AND " + nomap + ".BPDLVCUST.UVYDAY2_0=2) OR "
    DYN_CRITSQL(5) = DYN_CRITSQL(5) + "(" + nomap + ".BPDLVCUST.YDISPON3_0="+num$([M:YEXP0]YDISPON)+" AND " + nomap + ".BPDLVCUST.UVYDAY3_0=2) OR "
    DYN_CRITSQL(6) = "(" + nomap + ".BPDLVCUST.YDISPON4_0="+num$([M:YEXP0]YDISPON)+" AND " + nomap + ".BPDLVCUST.UVYDAY4_0=2) OR "
    DYN_CRITSQL(6) = DYN_CRITSQL(6) + "(" + nomap + ".BPDLVCUST.YDISPON5_0="+num$([M:YEXP0]YDISPON)+" AND " + nomap + ".BPDLVCUST.UVYDAY5_0=2) OR "
    DYN_CRITSQL(6) = DYN_CRITSQL(6) + "(" + nomap + ".BPDLVCUST.YDISPON6_0="+num$([M:YEXP0]YDISPON)+" AND " + nomap + ".BPDLVCUST.UVYDAY6_0=2) OR "
    DYN_CRITSQL(7) = "(" + nomap + ".BPDLVCUST.YDISPON7_0="+num$([M:YEXP0]YDISPON)+" AND " + nomap + ".BPDLVCUST.UVYDAY7_0=2)) "
  Endif
  If (maxtab(DYN_CRIT1)) + (maxtab(DYN_CRIT2)) > 0 Then
    DYN_CRITSQL(8) = "AND ("
  Else
    DYN_CRITSQL(8) = " AND (BPDPOSCOD_0='') "
  Endif
  For M = 9 To (maxtab(DYN_CRIT1)+9)
    DYN_CRITSQL(M) = DYN_CRIT1(M-9)
  Next
  If (maxtab(DYN_CRIT1)) > 0 Then
    VARINI = M
    If (maxtab(DYN_CRIT2)) > 0 Then
      DYN_CRITSQL(VARINI) = ") AND ("
    Else
      DYN_CRITSQL(VARINI) = " OR "
    Endif
  Else
    VARINI = M-1
  Endif
  For N = (VARINI+1) To ((VARINI+1) + (maxtab(DYN_CRIT2)))
    DYN_CRITSQL(N) = DYN_CRIT2(N-(VARINI+1))
  Next

  If (maxtab(DYN_CRIT1)) + (maxtab(DYN_CRIT2)) > 0 Then
    DYN_CRITSQL(N) = ")"
  Endif
  DYN_CRITSQL(N) = DYN_CRITSQL(N) + " ORDER BY " + nomap + ".SORDER.SOHNUM_0 ASC"

  Trbegin [F:YYSOH]                 # transacción para insertar en tablas temporales de cabecera y líneas de pedido
  Execsql From "5"  Sql "truncate table " + nomap + ".YSORDER"
  Execsql From "5"  Sql "truncate table " + nomap + ".YSORDERQ"

  Sleep 1

  # ejecuta la consulta que busca las cabeceras de los pedidos a mostrar
  For (Char SOHNUM, Char BPCORD, Char BPCNAM, Char BPAADD, Char BPDNAM, Date ORDDAT, Date DEMDLVDAT, Char SALFCY,
& Char BPDCTY, Decimal DSPTOTWEI, Decimal DSPTOTVOL, Decimal ORDNOT, Decimal ORDATI, Char BPDCRY, Char YOBSERVC, Char YOBSERVP) From "5" Sql DYN_CRITSQL(0..N) As [ZCPV]
    # inserta datos en el grid de la cabecera
    [M:YEXP1]SOHNUM(NUMREG)     = [F:ZCPV]SOHNUM
    [M:YEXP1]BPCORD(NUMREG)     = [F:ZCPV]BPCORD
    [M:YEXP1]BPCNAM(NUMREG)     = [F:ZCPV]BPCNAM
    [M:YEXP1]BPAADD(NUMREG)     = [F:ZCPV]BPAADD
    [M:YEXP1]BPDADDLIG(NUMREG)  = [F:ZCPV]BPDNAM
    [M:YEXP1]ORDDAT(NUMREG)     = [F:ZCPV]ORDDAT
    [M:YEXP1]DEMDLVDAT(NUMREG)  = [F:ZCPV]DEMDLVDAT
    [M:YEXP1]BPDCTY(NUMREG)     = [F:ZCPV]BPDCTY
#    [M:YEXP1]DSPTOTWEI(NUMREG)  = [F:ZCPV]DSPTOTWEI
#    [M:YEXP1]DSPTOTVOL(NUMREG)  = [F:ZCPV]DSPTOTVOL
#    [M:YEXP1]ORDNOT(NUMREG)     = [F:ZCPV]ORDNOT
#    [M:YEXP1]ORDATI(NUMREG)     = [F:ZCPV]ORDATI
    [M:YEXP1]YOBSER(NUMREG)     = [F:ZCPV]YOBSERVC - "-" - [F:ZCPV]YOBSERVP
    NUMREG += 1

    # inserta datos en la tabla temporal de cabecera
    [F:YYSOH]SOHNUM             = [F:ZCPV]SOHNUM
    [F:YYSOH]BPCORD             = [F:ZCPV]BPCORD
    [F:YYSOH]BPCNAM             = [F:ZCPV]BPCNAM
    [F:YYSOH]BPAADD             = [F:ZCPV]BPAADD
    [F:YYSOH]BPDADDLIG          = [F:ZCPV]BPDNAM
    [F:YYSOH]ORDDAT             = [F:ZCPV]ORDDAT
    [F:YYSOH]DEMDLVDAT          = [F:ZCPV]DEMDLVDAT
    [F:YYSOH]BPDCTY             = [F:ZCPV]BPDCTY
#    [F:YYSOH]DSPTOTWEI          = [F:ZCPV]DSPTOTWEI
#    [F:YYSOH]DSPTOTVOL          = [F:ZCPV]DSPTOTVOL
#    [F:YYSOH]ORDNOT             = [F:ZCPV]ORDNOT
#    [F:YYSOH]ORDATI             = [F:ZCPV]ORDATI
    [F:YYSOH]SALFCY             = [F:ZCPV]SALFCY
    Write [F:YYSOH]

    # inserta datos en la tabla temporal de líneas
    Filter [F:YSOQ] Where SOHNUM = [F:ZCPV]SOHNUM and SOQSTA <> 3
    For [YSOQ]
      [F:YYSOQ]SOHNUM              = [F:YSOQ]SOHNUM
      [F:YYSOQ]SOPLIN              = [F:YSOQ]SOPLIN
      [F:YYSOQ]ITMREF              = [F:YSOQ]ITMREF
      Filter [F:YSOP] Where SOHNUM = [F:YSOQ]SOHNUM and SOPLIN = [F:YSOQ]SOPLIN
      Read [F:YSOP] First
      If !fstat Then
        [F:YYSOQ]SAU               = [F:YSOP]SAU
        [F:YYSOQ]YUNV              = [F:YSOP]SAU
        [F:YYSOQ]ALLQTY            = 0
        [F:YYSOQ]NETPRI            = [F:YSOP]NETPRI
      Endif
      Filter [F:YSOP]
      Filter [F:YITM] Where ITMREF = [F:YSOQ]ITMREF
      Read [F:YITM] First
      [F:YYSOQ]QTY                 = [F:YSOQ]QTY - [F:YSOQ]ALLQTY            # sólo se tienen en cuenta las unidades pedidas menos las ya asignadas
      [F:YYSOQ]SALFCY              = [F:YSOQ]SALFCY
      Write [F:YYSOQ]
      Filter [F:YITM]
    Next
    Filter [F:YSOQ]
  Next

  [M:YEXP1]NBLIG = NUMREG
  Affzo [M:YEXP1]SOHNUM,BPCORD,BPCNAM,BPAADD,BPDADDLIG,ORDDAT,DEMDLVDAT,BPDCTY,DSPTOTWEI,DSPTOTVOL,YOBSER,NBLIG
  Commit                            # cierre de la transacción

  If clalev([F:YYZND])  Then : Close Local File [F:YYZND]  : Endif           # zonas
  If clalev([F:YYRTD])  Then : Close Local File [F:YYRTD]  : Endif           # rutas
  If clalev([F:YYSOH])  Then : Close Local File [F:YYSOH]  : Endif           # temporal cabecera pedidos
  If clalev([F:YYSOQ])  Then : Close Local File [F:YYSOQ]  : Endif           # temporal líneas pedidos
  If clalev([F:YSOQ])   Then : Close Local File [F:YSOQ]   : Endif           # líneas de pedidos (Cantidad)
  If clalev([F:YSOP])   Then : Close Local File [F:YSOP]   : Endif           # líneas de pedidos (Precios)
  If clalev([F:YITM])   Then : Close Local File [F:YITM]   : Endif           # artículos

Return

##############################################################
$RELLENA_STOCKS
Local Char CRITSTO(255)(0..2) : Raz CRITSTO

  Execsql From "5"  Sql "truncate table " + nomap + ".YITMMVT"

  Sleep 1

  # inserta datos en la tabla temporal de stocks
  If !clalev([F:YYITV])  Then : Local File YITMMVT  [F:YYITV]  : Endif
  If !clalev([F:YITV])   Then : Local File ITMMVT   [F:YITV]   : Endif
  Trbegin [F:YYITV]
  CRITSTO(0) = "SELECT ITMREF_0, SAU_0, SALFCY_0, SUM(QTY_0) AS QTY_0 "
  CRITSTO(1) = "FROM " + nomap + ".YSORDERQ "
  CRITSTO(2) = "GROUP BY ITMREF_0, SAU_0, SALFCY_0"
  For (Char ITMREF, Char SAU, Char SALFCY, Double QTY) From "5" Sql CRITSTO(0..2) As [ZSOQ]
    [F:YYITV]ITMREF     = [F:ZSOQ]ITMREF
    [F:YYITV]STU        = [F:ZSOQ]SAU
    [F:YYITV]STOFCY     = [F:ZSOQ]SALFCY
    [F:YYITV]SALSTO     = [F:ZSOQ]QTY
    Filter [F:YITV] Where ITMREF = [F:ZSOQ]ITMREF and STOFCY = [F:ZSOQ]SALFCY
    Read [F:YITV] First
    [F:YYITV]PHYSTO     = [F:YITV]PHYSTO - ([F:YITV]GLOALL + [F:YITV]PHYALL)
    [F:YYITV]YRESHOJAS  = [F:YITV]GLOALL + [F:YITV]PHYALL
    [F:YYITV]ORDSTO     = [F:YITV]ORDSTO
    [F:YYITV]YPREPQTY   = [F:YITV]PHYSTO - ([F:YITV]GLOALL + [F:YITV]PHYALL)
    [F:YYITV]YTOTEXIST  = [F:YITV]PHYSTO
    Write [F:YYITV]
    Filter [F:YITV]
  Next

  Commit

  If clalev([F:YYITV])  Then : Close Local File [F:YYITV]  : Endif
  If clalev([F:YITV])   Then : Close Local File [F:YITV]   : Endif
Return

##############################################################
$REPARTIR_STOCK
Local Decimal CTD_REST : Raz CTD_REST

  If !clalev([F:YYITV]) Then : Local File YITMMVT  [F:YYITV] : Endif
  If !clalev([F:YYSOQ]) Then : Local File YSORDERQ [F:YYSOQ] : Endif
  Trbegin [F:YYSOQ]
  For [YYSOQ]
    Read [F:YYITV]YITV0 = [F:YYSOQ]ITMREF;[F:YYSOQ]SALFCY                 # busca en la tabla temporal el stock del artículo
    If !fstat Then
      If [F:YYITV]PHYSTO > 0 Then
#        CTD_REST = [F:YYSOQ]QTY - [F:YYITV]PHYSTO
        CTD_REST = [F:YYITV]PHYSTO - [F:YYSOQ]QTY
        If CTD_REST >= 0 Then                                             # si hay stock suficiente para cubrir la necesidad...
          [F:YYSOQ]ALLQTY = [F:YYSOQ]QTY                                  # ...asigna la cantidad...
          [F:YYSOQ]YSELEC = 2                                             # ...marca el campo YSELEC como activado
          [F:YYITV]PHYSTO = CTD_REST                                      # ...y actualiza el stock del artículo
          Rewrite [F:YYSOQ]
          Rewrite [F:YYITV]
        Else                                                              # si no hay stock suficiente para cubrir la necesidad...
          [F:YYSOQ]ALLQTY = [F:YYITV]PHYSTO                               # ...asigna las unidades que quedan a la línea de pedido...
          [F:YYITV]PHYSTO = 0                                             # ... y deja el stock a cero
          [F:YYSOQ]YSELEC = 2
          Rewrite [F:YYSOQ]
          Rewrite [F:YYITV]
        Endif
      Endif
    Endif
  Next
  Commit
  If clalev([F:YYSOQ])  Then : Close Local File   [F:YYSOQ] : Endif
  If clalev([F:YYITV])  Then : Close Local File   [F:YYITV] : Endif
Return

##############################################################
$FLAGS_CABECERA
Local Char CRITSOQ(255)(0..2) : Raz CRITSOQ
Local Integer LCON : Raz LCON

  If !clalev([F:YYSOH]) Then : Local File YSORDER  [F:YYSOH] : Endif
  Trbegin [F:YYSOH]

  CRITSOQ(0) = "SELECT SOHNUM_0, SALFCY_0, SUM(QTY_0) AS QTY, SUM(ALLQTY_0) AS ALLQTY "
  CRITSOQ(1) = "FROM " + nomap + ".YSORDERQ WHERE YARTALTER_0 = '' "
  CRITSOQ(2) = "GROUP BY SOHNUM_0, SALFCY_0"
  For (Char SOHNUM, Char SALFCY, Double QTY, Double ALLQTY) From "5" Sql CRITSOQ(0..2) As [ZSQ2]
    For LCON = 0 To [M:YEXP1]NBLIG-1                                      # busca en el cuadro de cabeceras el pedido
      If [M:YEXP1]SOHNUM(LCON) = [F:ZSQ2]SOHNUM
        If [F:ZSQ2]ALLQTY > 0 Then                                        # si hay, al menos, una unidad para servir se marca el check "Sel."
          [M:YEXP1]YSELEC(LCON) = 2
          Read [F:YYSOH]YSOH0 = [F:ZSQ2]SOHNUM
          [F:YYSOH]YSELEC = 2                                             # guarda el valor de "Sel." también en la tabla de cabeceras
          Rewrite [F:YYSOH]
        Endif
        If ([F:ZSQ2]ALLQTY - [F:ZSQ2]QTY) < 0                             # si el número de unidades pedidas es superior al de stock restante se marca el check "Inc."
          [M:YEXP1]YINCOMP(LCON) = 2
        Endif
      Endif
      If [M:YEXP1]YSELEC(LCON) = 0 Then
        [M:YEXP1]YINCOMP(LCON) = 0
      Endif
    Next
  Next

  Affzo [M:YEXP1]YSELEC,YINCOMP

  Commit
  If clalev([F:YYSOH])  Then : Close Local File [F:YYSOH] : Endif
Return

##############################################################
$DUPLICA_TABLAS

  Execsql From "5"  Sql "truncate table " + nomap + ".YSORDERQF"
  If !clalev([F:YYSOQ])  Then : Local File YSORDERQ  [F:YYSOQ]  : Endif      # temporal líneas pedidos
  If !clalev([F:YYSOQF]) Then : Local File YSORDERQF [F:YYSOQF] : Endif      # temporal líneas pedidos FIJA (se usa para restaurar desde asignación por referencia)
  Trbegin [F:YYSOQF]
  For [F:YYSOQ]
    # copia el valor de la tabla termporal de líneas sobre otra que no sufrirá cambios en el "juego" posterior que realizan
    # esta tabla la utilizaremos posteriormente si deciden restaurar los valores desde la ventana de "Asignar por referencia"
    [F:YYSOQF] = [F:YYSOQ]
    Write [F:YYSOQF]
  Next
  If clalev([F:YYSOQ])  Then : Close Local File [F:YYSOQ]  : Endif           # temporal líneas pedidos
  If clalev([F:YYSOQF]) Then : Close Local File [F:YYSOQF] : Endif           # temporal cabecera pedidos FIJA (se usa para restaurar desde asignación por referencia)

  Execsql From "5"  Sql "truncate table " + nomap + ".YITMMVTF"
  If !clalev([F:YYITV])  Then : Local File YITMMVT  [F:YYITV]  : Endif
  If !clalev([F:YYITVF]) Then : Local File YITMMVTF [F:YYITVF] : Endif
  For [F:YYITV]
    # copia el valor de la tabla termporal de stocks sobre otra que no sufrirá cambios en el "juego" posterior que realizan
    # esta tabla la utilizaremos posteriormente si deciden restaurar los valores desde la ventana de "Asignar por referencia"
    [F:YYITVF] = [F:YYITV]
    Write [F:YYITVF]
  Next
  If clalev([F:YYITV])  Then : Close Local File [F:YYITV]  : Endif
  If clalev([F:YYITVF]) Then : Close Local File [F:YYITVF] : Endif
  Commit

Return

##############################################################
# calcula el importe neto de las cabeceras
$CALCULA_NETPRI
  For LCON3 = 0 To [M:YEXP1]NBLIG-1
    Raz [M:YEXP1]NETPRIC(LCON3)
    Call CALC_NETPRIC(LCON3,[M:YEXP1]NETPRIC(LCON3))
    Affzo [M:YEXP1]NETPRIC(LCON3)
  Next
Return

