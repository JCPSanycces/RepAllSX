##############################################################
$DESMARCAR_PEDIDOS
Local Integer LCON : Raz LCON

  For LCON = 0 To [M:YEXP1]NBLIG-1
    [M:YEXP1]YSELEC(LCON)  = 1
    [M:YEXP1]YINCOMP(LCON) = 1
    nolign = LCON + 1
    Call AM_YSELEC([M:YEXP1]YSELEC(LCON))
  Next
  Affzo [M:YEXP1]YSELEC, YINCOMP
Return

##############################################################
$GENERA_FICHIE
Local Char LDIRMPORT(250) : LDIRIMPORT = filpath("IMPORT_EXPORT","","")
#Local Char LDIRMPORT(250) : LDIRIMPORT = "C:\Sage\SAGEX3V11\IE\DEVELOP\SOH"
Local Char LFILE_W(200) : LFILE_W = "\PedidosVenta"
Local Char LDATCAB(100)(12), LDATLIN(100)(7)
Local Char LFECHA(10), LHORA(10) : Raz LFECHA, LHORA
Local Char LSEP(1) : LSEP = ";"  # separador
Local Char LCRY(5), LFCY(15), LCTACTBLE(25), LCONTRAP(25), LCPY(10), LCONTHR(15)

  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
  LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

  LFILE_W = LDIRIMPORT + LFILE_W + "_" + LFECHA + LHORA + ".txt"

  # genera número de contador para la hoja de recogida
  Call GENNUMBER(LCONTHR)

  mkstat = 0 : fstat = 0 : GERRTRACE = 0
  # si se lanza la tarea batch
  If !GSERVEUR Then
    Call TEMPON("Proceso actualización de pedidos") From GESECRAN
    Call OUVRE_TRACE ("Proceso actualización de pedidos") From LECFIC
  Endif

  ######
  # Estados del proceso
  ###
  # 1 -> Pendiente
  # 2 -> Listo para enviar
  # 3 -> Importado
  # 4 -> Error
  ######
  # borramos el fichero si existe...
  If filinfo(LFILE_W, 7) > 0 Then
    System "ae_rm " + LFILE
  Endif

  Sleep 3

  # abrir el fichero para escritura
  Gosub OPEN_FILE_W

      ######
      # Línea 1
      ######
      # 0  -> Inidicador                          (E)
      # 1  -> Planta de venta                     (SALFCY)
      # 2  -> Número de pedido                    (SOHNUM)
      # 3  -> Código de cliente                   (BPCORD)
      # 4  -> Razón social del cliente            (BPCNAM)
      # 5  -> Código dirección de entrega         (BPAADD)
      # 6  -> Descripción dirección de entrega    (BPDADDLIG)
      # 7  -> Fecha de pedido                     (ORDDAT)
      # 8  -> Ciudad de entrega                   (BPDCTY)
      # 9  -> Planta expedición                   (STOFCY)
      # 10 -> Modelo del vehículo                 (YMARCA)
      # 11 -> Contador de hoja de recogida        (YHOJAREC)
      ######
      # Línea 2
      ######
      # 0  -> Indicador                           (L)
      # 1  -> Número de línea del pedido          (SOPLIN)
      # 2  -> Código de artículo                  (ITMREF)
      # 3  -> Unidad de venta                     (SAU)
      # 4  -> Cantidad pedida                     (QTY)
      # 5  -> Cantidad asignada                   (ALLQTY)
      # 6  -> Texto línea                         (YSOQTEX)
      ######

  # abrir las tablas para lectura
  If !clalev([F:YYSOQ]) Then : Local File YSORDERQ [F:YYSOQ] : Endif
  If !clalev([F:YYSOH]) Then : Local File YSORDER  [F:YYSOH] : Endif
  Filter [F:YYSOH] Where YSELEC = 2
  For [YYSOH]
    Raz LDATCAB
    LDATCAB(1)  = [F:YYSOH]SALFCY
    LDATCAB(2)  = [F:YYSOH]SOHNUM
    LDATCAB(3)  = [F:YYSOH]BPCORD
    LDATCAB(4)  = [F:YYSOH]BPCNAM
    LDATCAB(5)  = [F:YYSOH]BPAADD
    LDATCAB(6)  = [F:YYSOH]BPDADDLIG
    LDATCAB(7)  = [F:YYSOH]ORDDAT
    LDATCAB(8)  = [F:YYSOH]BPDCTY
    LDATCAB(9)  = [F:YYSOH]SALFCY                # hay que pasarle la planta de expedición pero no está en tabla, por eso le paso la planta de venta
    LDATCAB(10) = [M:YEXP0]YMARCA
    LDATCAB(11) = LCONTHR
    # escribe línea de cabecera
    Wrseq "E" + LSEP +
&         LDATCAB(1) + LSEP + LDATCAB(2) + LSEP + LDATCAB(3) + LSEP + LDATCAB(4) + LSEP +
&         LDATCAB(5) + LSEP + LDATCAB(6) + LSEP + LDATCAB(7) + LSEP + LDATCAB(8) + LSEP + LDATCAB(9) + LSEP + LDATCAB(10) + LSEP + LDATCAB(11) Using [ZIMP_W]

    Filter [F:YYSOQ] Where SOHNUM = [F:YYSOH]SOHNUM and YSELEC = 2
    For [YYSOQ]
      Raz LDATLIN
      LDATLIN(1) = num$([F:YYSOQ]SOPLIN)
      LDATLIN(2) = [F:YYSOQ]ITMREF
      LDATLIN(3) = [F:YYSOQ]SAU
      If [F:YYSOQ]YARTALTER = "" Then
        LDATLIN(4) = num$([F:YYSOQ]QTY)
#        LDATLIN(5) = num$([F:YYSOQ]ALLQTY)
        LDATLIN(6) = ""
      Else
        LDATLIN(4) = "0"
#        LDATLIN(5) = "0"
        LDATLIN(6) = ""
      Endif
      Wrseq "L" + LSEP + LDATLIN(1) + LSEP + LDATLIN(2) + LSEP + LDATLIN(3) + LSEP + LDATLIN(4) + LSEP + LDATLIN(5) + LSEP +
&     LDATLIN(6) Using [ZIMP_W]

      # si existe ARTÍCULO ALTERNATIVO hay que añadir esta línea más en el fichero de importación
      If [F:YYSOQ]YARTALTER <> "" Then
        LDATLIN(1) = num$([F:YYSOQ]SOPLIN + 1000000)
        LDATLIN(2) = [F:YYSOQ]YARTALTER
        LDATLIN(3) = [F:YYSOQ]YUNV
        LDATLIN(4) = num$([F:YYSOQ]ALLQTY)
#        LDATLIN(5) = num$([F:YYSOQ]ALLQTY)
        LDATLIN(6) = "El articulo inicial "+[F:YYSOQ]ITMREF+" ha sido sustituido por "+[F:YYSOQ]YARTALTER
        Wrseq "L" + LSEP + LDATLIN(1) + LSEP + LDATLIN(2) + LSEP + LDATLIN(3) + LSEP + LDATLIN(4) + LSEP + LDATLIN(5) + LSEP +
&       LDATLIN(6) Using [ZIMP_W]
      Endif
    Next    # líneas [F:YYSOQ]
    Filter [F:YYSOQ]
  Next    # cabecera [F:YYSOH]
  Filter [F:YYSOH]

  If clalev([F:YYSOQ]) Then : Close Local File [F:YYSOQ] : Endif
  If clalev([F:YYSOH]) Then : Close Local File [F:YYSOH] : Endif

  Gosub CLOSE_FILE_W

  Call IMPORTSIL("ZSOHL",LFILE_W) From GIMPOBJ                      # lanza la imporación
  Gosub GENERA_ASIGNACION                                           # lanza la asignación

  If !GSERVEUR Then
    Call TEMPOFF() From GESECRAN
    # fin de traza
    Call ECR_TRACE("Fichero " + ctrans(LFILE_W,"\","/") + " generado", 0) From GESECRAN
    Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
    Call FERME_TRACE From LECFIC

    # lectura
    Call LEC_TRACE From LECFIC

    Call MESSAGE("Se ha generado el número de hoja de recogida:\"+"                         "+LCONTHR) From GESECRAN

    mkstat = 0 : fstat = 0 : GERRTRACE = 0 : GOK = 1
  Endif

  Gosub VACIAR_TABLAS                                               # vacía todas las tablas temporales (YSORDER, YSORDERQ, YITMMVT, YSORDERQF, YITMMVTF)

Return

########################################################
$OPEN_FILE_W

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE_W Using [ZIMP_W]

Return

########################################################
$CLOSE_FILE_W

Openo Using [ZIMP_W]

Return

########################################################
$GENERA_ASIGNACION

  If !clalev([F:YSH1]) Then : Local File YSORDER  [F:YSH1] : Endif
  For [YSH1]
    If [F:YSH1]YSELEC = 2 Then
      Call ASIGNACION([F:YSH1]SOHNUM)
    Endif
  Next
  If clalev([F:YSH1])  Then : Close Local File    [F:YSH1] : Endif

Return

########################################################
$PESO_VOLUMEN
Local Decimal PESOTOTAL, VOLUMENTOTAL, IMPORTETOTAL : Raz PESOTOTAL, VOLUMENTOTAL, IMPORTETOTAL
Local Decimal DIFPESO, DIFVOLUMEN, PESOSOH, VOLUMENSOH : Raz DIFPESO, DIFVOLUMEN, PESOSOH, VOLUMENSOH
Local Integer CONT, NUM, LCONC, LCONC1 : Raz CONT, NUM, LCONC, LCONC1

  # cálcula peso y volumen total de las líneas seleccionadas
  # para mostrarlo en los campos situados en cabecera
  If !clalev([F:YITM1])  Then : Local File ITMMASTER [F:YITM1]  : Endif
  If !clalev([F:YYSOQ1]) Then : Local File YSORDERQ  [F:YYSOQ1] : Endif
  For [YYSOQ1]
    If [F:YYSOQ1]YSELEC = 2 Then
      Read [F:YITM1]ITM0 = [F:YYSOQ1]ITMREF
      If !fstat Then
        PESOTOTAL     = PESOTOTAL     + arr(([F:YITM1]ITMWEI * [F:YYSOQ1]ALLQTY),2)
        VOLUMENTOTAL  = VOLUMENTOTAL  + arr(([F:YITM1]ITMVOU * [F:YYSOQ1]ALLQTY),2)
      Endif
    Endif
  Next

  DIFPESO     = [M:YEXP0]YPESMAX - PESOTOTAL
  DIFVOLUMEN  = [M:YEXP0]YVOLMAX - VOLUMENTOTAL

  [M:YEXP0]YPESTOT    = PESOTOTAL
  [M:YEXP0]YVOLTOT    = VOLUMENTOTAL
  [M:YEXP0]YIMPTOT    = 0
  [M:YEXP0]YDIFPES    = DIFPESO
  [M:YEXP0]YDIFVOL    = DIFVOLUMEN

  If clalev([F:YITM1])  Then : Close Local File [F:YITM1]  : Endif
  If clalev([F:YYSOQ1]) Then : Close Local File [F:YYSOQ1] : Endif


  # calcula peso y volumen total de las líneas seleccionadas
  # para mostrarlos en el grid de cabecera de pedidos
  If !clalev([F:YIT1]) Then : Local File ITMMASTER [F:YIT1] : Endif
  If !clalev([F:YSQ1]) Then : Local File YSORDERQ  [F:YSQ1] : Endif
  For LCONC = 0 To [M:YEXP1]NBLIG
    Filter [F:YSQ1] Where SOHNUM = [M:YEXP1]SOHNUM(LCONC) and [F:YSQ1]YSELEC = 2
    For [YSQ1]
      Read [F:YIT1]ITM0 = [F:YSQ1]ITMREF
      If !fstat Then
        PESOSOH     = PESOSOH     + arr(([F:YIT1]ITMWEI * [F:YSQ1]ALLQTY),2)
        VOLUMENSOH  = VOLUMENSOH  + arr(([F:YIT1]ITMVOU * [F:YSQ1]ALLQTY),2)
      Endif
    Next
    If PESOSOH <> 0 Then
      [M:YEXP1]DSPTOTWEI(LCONC) = PESOSOH
    Else
      [M:YEXP1]DSPTOTWEI(LCONC) = 0
    Endif
    If VOLUMENSOH <> 0 Then
      [M:YEXP1]DSPTOTVOL(LCONC) = VOLUMENSOH
    Else
      [M:YEXP1]DSPTOTVOL(LCONC) = 0
    Endif
    Raz PESOSOH, VOLUMENSOH
    Filter [F:YSQ1]
  Next LCONC
  If clalev([F:YIT1]) Then : Close Local File [F:YIT1] : Endif
  If clalev([F:YSQ1]) Then : Close Local File [F:YSQ1] : Endif

  # suma los importes netos de cada cabecera de pedido para añadirlo en el campo "Importe total" de la cabecera de ventana
  Raz [M:YEXP0]YIMPTOT
  For LCONC1 = 0 To [M:YEXP1]NBLIG-1
    [M:YEXP0]YIMPTOT += [M:YEXP1]NETPRIC(LCONC1)
  Next

  Affzo [M:YEXP0]YPESTOT,YVOLTOT,YIMPTOT,YDIFPES,YDIFVOL
  Affzo [M:YEXP1]DSPTOTWEI,DSPTOTVOL


Return

########################################################
$VACIAR_TABLAS

  Execsql From "5"  Sql "truncate table " + nomap + ".YSORDER"
  Execsql From "5"  Sql "truncate table " + nomap + ".YSORDERQ"
  Execsql From "5"  Sql "truncate table " + nomap + ".YSORDERQF"
  Execsql From "5"  Sql "truncate table " + nomap + ".YITMMVT"
  Execsql From "5"  Sql "truncate table " + nomap + ".YITMMVTF"

Return

