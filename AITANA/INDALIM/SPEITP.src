#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif

Case ACTION
  When "CREATION"     : Gosub CREATION
  When "MODIF"        : Gosub MODIF
 When Default
Endcase
Return

##################################################
$CREATION
   Gosub ADD_SECCION
Return

##################################################
$MODIF
   Gosub ADD_SECCION
Return


##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ADD_SECCION

  If !clalev([F:YITP]) Then : Local File ITMBPS [F:YITP] : Endif
    Update [YITP] Where ITMREF = [M:ITM0]ITMREF and BPSNUM = [M:ITP]BPSNUM(NUMLIN) With YSECC = [M:ITP]YSECC
    If fstat
       GOK = 0 : Call FSTA("YITP") From GLOCK
    Endif

  If GOK<1 : Return : Endif
  If clalev([F:YITP])  Then : Close Local File  [F:YITP] : Endif

Return


##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Al moverse por el cuadro de proveedores dentro de la pestaña "Proveedores"
######################################################################################
Subprog AS_NBITP
Global Integer NUMLIN : NUMLIN = nolign-1
Infbox num$(NUMLIN)
  Call BUSCA_SECCION([M:ITM0]ITMREF,[M:ITP]BPSNUM(nolign-1))
End


######################################################################################
Subprog BUSCA_SECCION (PITMREF,PBPSNUM)
Value Char PITMREF, PBPSNUM

  If !clalev([F:YITP]) Then : Local File ITMBPS [F:YITP] : Endif
  Read [F:YITP]ITP0 = PITMREF;PBPSNUM
  If !fstat Then
    [M:ITP]YSECC = [F:YITP]YSECC
  Endif
  Affzo [M:ITP]10
  If clalev([F:YITP])  Then : Close Local File  [F:YITP] : Endif
End

