#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION


Case ACTION
 When "SETBOUT"  : Gosub SETBOUT
 When Default
Endcase
Return


#####################################################################################
$SETBOUT

If PARAM(1) = 'ADB3' # solo si se accede desde el boton de direccion factura

 If [M:ADC]BPAADD <> [M:SOH1]YDIRFAC
   [M:ADC]BPAADD =  [M:SOH1]YDIRFAC
    Affzo [M:ADC]BPAADD
 Endif

Endif

Return

