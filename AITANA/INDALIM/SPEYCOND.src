#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
    When "CREATION"   : Gosub CREATION
    When "LIENS"      : Gosub LIENS
    When "MODIF"      : Gosub MODIF
    When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
########################################################################
$CREATION
Local Integer LCON : Raz LCON

  # guarda las condiciones de Familia
  For LCON = 0 To [M:YCOND0]NBLIG-1
    [F:YCFA]YCDGCOND1   = [F:YCON]YCDGCOND
    [F:YCFA]YCODFAM1    = [M:YCOND0]YCODFAM1(LCON)
    [F:YCFA]YFECHAINI1  = [F:YCON]YFECHAINI
    [F:YCFA]YFECHAFIN1  = [F:YCON]YFECHAFIN
    [F:YCFA]YTIPOMRG1   = [M:YCOND0]YTIPOMRG1(LCON)
    [F:YCFA]YPORMRG1    = [M:YCOND0]YPORMRG1(LCON)
    Write [F:YCFA]
  Next
  Raz LCON

  # guarda las condiciones de Familia/Subfamilia
  For LCON = 0 To [M:YCOND0]NBLIG2-1
    [F:YCSF]YCDGCOND2   = [F:YCON]YCDGCOND
    [F:YCSF]YCODFAM2    = [M:YCOND0]YCODFAM2(LCON)
    [F:YCSF]YFECHAINI2  = [F:YCON]YFECHAINI
    [F:YCSF]YFECHAFIN2  = [F:YCON]YFECHAFIN
    [F:YCSF]YTIPOMRGF2  = [M:YCOND0]YTIPOMRGF2(LCON)
    [F:YCSF]YPORMRGF2   = [M:YCOND0]YPORMRGF2(LCON)
    [F:YCSF]YCODSUB2    = [M:YCOND0]YCODSUB2(LCON)
    [F:YCSF]YTIPOMRGS2  = [M:YCOND0]YTIPOMRGS2(LCON)
    [F:YCSF]YPORMRGS2   = [M:YCOND0]YPORMRGS2(LCON)
    Write [F:YCSF]
  Next
  Raz LCON

  # guarda las condiciones de Familia/Subfamilia/Gama
  For LCON = 0 To [M:YCOND0]NBLIG3-1
    [F:YCGM]YCDGCOND3   = [F:YCON]YCDGCOND
    [F:YCGM]YCODFAM3    = [M:YCOND0]YCODFAM3(LCON)
    [F:YCGM]YFECHAINI3  = [F:YCON]YFECHAINI
    [F:YCGM]YFECHAFIN3  = [F:YCON]YFECHAFIN
    [F:YCGM]YTIPOMRGF3  = [M:YCOND0]YTIPOMRGF3(LCON)
    [F:YCGM]YPORMRGF3   = [M:YCOND0]YPORMRGF3(LCON)
    [F:YCGM]YCODSUB3    = [M:YCOND0]YCODSUB3(LCON)
    [F:YCGM]YTIPOMRGS3  = [M:YCOND0]YTIPOMRGS3(LCON)
    [F:YCGM]YPORMRGS3   = [M:YCOND0]YPORMRGS3(LCON)
    [F:YCGM]YCODGAM3    = [M:YCOND0]YCODGAM3(LCON)
    [F:YCGM]YTIPOMRGG3  = [M:YCOND0]YTIPOMRGG3(LCON)
    [F:YCGM]YPORMRGG3   = [M:YCOND0]YPORMRGG3(LCON)
    Write [F:YCGM]
  Next
  Raz LCON

  # guarda las condiciones de Proveedor
  For LCON = 0 To [M:YCOND0]NBLIG4-1
    [F:YCPR]YCDGCOND4   = [F:YCON]YCDGCOND
    [F:YCPR]BPSNUM      = [M:YCOND0]BPSNUM(LCON)
    [F:YCPR]YFECHAINI4  = [F:YCON]YFECHAINI
    [F:YCPR]YFECHAFIN4  = [F:YCON]YFECHAFIN
    [F:YCPR]YTIPOMRG4   = [M:YCOND0]YTIPOMRG4(LCON)
    [F:YCPR]YPORMRG4    = [M:YCOND0]YPORMRG4(LCON)
    Write [F:YCPR]
  Next
  Raz LCON

Return

########################################################################
$LIENS
Local Integer LCON2 : Raz LCON2

  # carga las condiciones de familia
  If !clalev([F:YCFA2]) Then : Local File YCONDFAM [F:YCFA2] : Endif
  Filter [F:YCFA2] Where YCDGCOND1 = [F:YCON]YCDGCOND
  Read [F:YCFA2] First
  If !fstat Then
    For [YCFA2]
      [M:YCOND0]YCODFAM1(LCON2)   = [F:YCFA2]YCODFAM1
      [M:YCOND0]YTIPOMRG1(LCON2)  = [F:YCFA2]YTIPOMRG1
      [M:YCOND0]YPORMRG1(LCON2)   = [F:YCFA2]YPORMRG1
      [M:YCOND0]YCDGCOND1(LCON2)  = [F:YCFA2]YCDGCOND1
      LCON2 += 1
    Next
  Endif
  [M:YCOND0]NBLIG = LCON2
  Filter [F:YCFA2]
  If clalev([F:YCFA2]) Then : Close Local File [F:YCFA2] : Endif
  Raz LCON2

  # carga las condiciones de subfamilia/familia
  If !clalev([F:YCSF2]) Then : Local File YCONDSUB [F:YCSF2] : Endif
  Filter [F:YCSF2] Where YCDGCOND2 = [F:YCON]YCDGCOND
  Read [F:YCSF2] First
  If !fstat Then
    For [YCSF2]
      [M:YCOND0]YCODFAM2(LCON2)     = [F:YCSF2]YCODFAM2
      [M:YCOND0]YTIPOMRGF2(LCON2)   = [F:YCSF2]YTIPOMRGF2
      [M:YCOND0]YPORMRGF2(LCON2)    = [F:YCSF2]YPORMRGF2
      [M:YCOND0]YCODSUB2(LCON2)     = [F:YCSF2]YCODSUB2
      [M:YCOND0]YTIPOMRGS2(LCON2)   = [F:YCSF2]YTIPOMRGS2
      [M:YCOND0]YPORMRGS2(LCON2)    = [F:YCSF2]YPORMRGS2
      [M:YCOND0]YCDGCOND2(LCON2)    = [F:YCSF2]YCDGCOND2
      LCON2 += 1
    Next
  Endif
  [M:YCOND0]NBLIG2 = LCON2
  Filter [F:YCSF2]
  If clalev([F:YCSF2]) Then : Close Local File [F:YCSF2] : Endif
  Raz LCON2

  # carga las condiciones de subfamilia/familia/gama
  If !clalev([F:YCGM2]) Then : Local File YCONDGAM [F:YCGM2] : Endif
  Filter [F:YCGM2] Where YCDGCOND3 = [F:YCON]YCDGCOND
  Read [F:YCGM2] First
  If !fstat Then
    For [YCGM2]
      [M:YCOND0]YCODFAM3(LCON2)     = [F:YCGM2]YCODFAM3
      [M:YCOND0]YTIPOMRGF3(LCON2)   = [F:YCGM2]YTIPOMRGF3
      [M:YCOND0]YPORMRGF3(LCON2)    = [F:YCGM2]YPORMRGF3
      [M:YCOND0]YCODSUB3(LCON2)     = [F:YCGM2]YCODSUB3
      [M:YCOND0]YTIPOMRGS3(LCON2)   = [F:YCGM2]YTIPOMRGS3
      [M:YCOND0]YPORMRGS3(LCON2)    = [F:YCGM2]YPORMRGS3
      [M:YCOND0]YCODGAM3(LCON2)     = [F:YCGM2]YCODGAM3
      [M:YCOND0]YTIPOMRGG3(LCON2)   = [F:YCGM2]YTIPOMRGG3
      [M:YCOND0]YPORMRGG3(LCON2)    = [F:YCGM2]YPORMRGG3
      [M:YCOND0]YCDGCOND3(LCON2)    = [F:YCGM2]YCDGCOND3
      LCON2 += 1
    Next
  Endif
  [M:YCOND0]NBLIG3 = LCON2
  Filter [F:YCGM2]
  If clalev([F:YCMG2]) Then : Close Local File [F:YCGM2] : Endif
  Raz LCON2

  # carga las condiciones de proveedor
  If !clalev([F:YCPR2]) Then : Local File YCONDPRO [F:YCPR2] : Endif
  Filter [F:YCPR2] Where YCDGCOND4 = [F:YCON]YCDGCOND
  Read [F:YCPR2] First
  If !fstat Then
    For [YCPR2]
      [M:YCOND0]BPSNUM(LCON2)     = [F:YCPR2]BPSNUM
      [M:YCOND0]YTIPOMRG4(LCON2)  = [F:YCPR2]YTIPOMRG4
      [M:YCOND0]YPORMRG4(LCON2)   = [F:YCPR2]YPORMRG4
      [M:YCOND0]YCDGCOND4(LCON2)  = [F:YCPR2]YCDGCOND4
      LCON2 += 1
    Next
  Endif
  [M:YCOND0]NBLIG4 = LCON2
  Filter [F:YCPR2]
  If clalev([F:YCPR2]) Then : Close Local File [F:YCPR2] : Endif
  Raz LCON2

Return

########################################################################
$MODIF

  # modifica las condiciones de Familia
  For LCON = 0 To [M:YCOND0]NBLIG-1
    Read [F:YCFA]YCFA0 = [F:YCON]YCDGCOND;[M:YCOND0]YCODFAM1(LCON);[F:YCON]YFECHAINI;[F:YCON]YFECHAFIN
    If fstat = 0 Then                                       # el registro existe en la tabla
      [F:YCFA]YCDGCOND1   = [F:YCON]YCDGCOND
      [F:YCFA]YCODFAM1    = [M:YCOND0]YCODFAM1(LCON)
      [F:YCFA]YFECHAINI1  = [F:YCON]YFECHAINI
      [F:YCFA]YFECHAFIN1  = [F:YCON]YFECHAFIN
      [F:YCFA]YTIPOMRG1   = [M:YCOND0]YTIPOMRG1(LCON)
      [F:YCFA]YPORMRG1    = [M:YCOND0]YPORMRG1(LCON)
      Rewrite [F:YCFA]
    Else                                                    # fstat=0, el registro no existe en la tabla
      [F:YCFA]YCDGCOND1   = [F:YCON]YCDGCOND
      [F:YCFA]YCODFAM1    = [M:YCOND0]YCODFAM1(LCON)
      [F:YCFA]YFECHAINI1  = [F:YCON]YFECHAINI
      [F:YCFA]YFECHAFIN1  = [F:YCON]YFECHAFIN
      [F:YCFA]YTIPOMRG1   = [M:YCOND0]YTIPOMRG1(LCON)
      [F:YCFA]YPORMRG1    = [M:YCOND0]YPORMRG1(LCON)
      Write [F:YCFA]
    Endif
  Next
  Raz LCON

  # modifica las condiciones de Familia/Subfamilia
  For LCON = 0 To [M:YCOND0]NBLIG2-1
    Read [F:YCSF]YCSF0 = [F:YCON]YCDGCOND;[M:YCOND0]YCODFAM2(LCON);[M:YCOND0]YCODSUB2(LCON);[F:YCON]YFECHAINI;[F:YCON]YFECHAFIN
    If fstat = 0 Then                                       # el registro existe en la tabla
      [F:YCSF]YCDGCOND2   = [F:YCON]YCDGCOND
      [F:YCSF]YCODFAM2    = [M:YCOND0]YCODFAM2(LCON)
      [F:YCSF]YFECHAINI2  = [F:YCON]YFECHAINI
      [F:YCSF]YFECHAFIN2  = [F:YCON]YFECHAFIN
      [F:YCSF]YTIPOMRGF2  = [M:YCOND0]YTIPOMRGF2(LCON)
      [F:YCSF]YPORMRGF2   = [M:YCOND0]YPORMRGF2(LCON)
      [F:YCSF]YCODSUB2    = [M:YCOND0]YCODSUB2(LCON)
      [F:YCSF]YTIPOMRGS2  = [M:YCOND0]YTIPOMRGS2(LCON)
      [F:YCSF]YPORMRGS2   = [M:YCOND0]YPORMRGS2(LCON)
      Rewrite [F:YCSF]
    Else                                                    # fstat=0, el registro no existe en la tabla
      [F:YCSF]YCDGCOND2   = [F:YCON]YCDGCOND
      [F:YCSF]YCODFAM2    = [M:YCOND0]YCODFAM2(LCON)
      [F:YCSF]YFECHAINI2  = [F:YCON]YFECHAINI
      [F:YCSF]YFECHAFIN2  = [F:YCON]YFECHAFIN
      [F:YCSF]YTIPOMRGF2  = [M:YCOND0]YTIPOMRGF2(LCON)
      [F:YCSF]YPORMRGF2   = [M:YCOND0]YPORMRGF2(LCON)
      [F:YCSF]YCODSUB2    = [M:YCOND0]YCODSUB2(LCON)
      [F:YCSF]YTIPOMRGS2  = [M:YCOND0]YTIPOMRGS2(LCON)
      [F:YCSF]YPORMRGS2   = [M:YCOND0]YPORMRGS2(LCON)
      Write [F:YCSF]
    Endif
  Next
  Raz LCON

  # modifica las condiciones de Familia/Subfamilia/Gama
  For LCON = 0 To [M:YCOND0]NBLIG3-1
    Read [F:YCGM]YCGM0 = [F:YCON]YCDGCOND;[M:YCOND0]YCODFAM3(LCON);[M:YCOND0]YCODSUB3(LCON);[M:YCOND0]YCODGAM3(LCON);[F:YCON]YFECHAINI;[F:YCON]YFECHAFIN
    If fstat = 0 Then                                       # el registro existe en la tabla
      [F:YCGM]YCDGCOND3   = [F:YCON]YCDGCOND
      [F:YCGM]YCODFAM3    = [M:YCOND0]YCODFAM3(LCON)
      [F:YCGM]YFECHAINI3  = [F:YCON]YFECHAINI
      [F:YCGM]YFECHAFIN3  = [F:YCON]YFECHAFIN
      [F:YCGM]YTIPOMRGF3  = [M:YCOND0]YTIPOMRGF3(LCON)
      [F:YCGM]YPORMRGF3   = [M:YCOND0]YPORMRGF3(LCON)
      [F:YCGM]YCODSUB3    = [M:YCOND0]YCODSUB3(LCON)
      [F:YCGM]YTIPOMRGS3  = [M:YCOND0]YTIPOMRGS3(LCON)
      [F:YCGM]YPORMRGS3   = [M:YCOND0]YPORMRGS3(LCON)
      [F:YCGM]YCODGAM3    = [M:YCOND0]YCODGAM3(LCON)
      [F:YCGM]YTIPOMRGG3  = [M:YCOND0]YTIPOMRGG3(LCON)
      [F:YCGM]YPORMRGG3   = [M:YCOND0]YPORMRGG3(LCON)
      Rewrite [F:YCGM]
    Else                                                    # fstat=0, el registro no existe en la tabla
      [F:YCGM]YCDGCOND3   = [F:YCON]YCDGCOND
      [F:YCGM]YCODFAM3    = [M:YCOND0]YCODFAM3(LCON)
      [F:YCGM]YFECHAINI3  = [F:YCON]YFECHAINI
      [F:YCGM]YFECHAFIN3  = [F:YCON]YFECHAFIN
      [F:YCGM]YTIPOMRGF3  = [M:YCOND0]YTIPOMRGF3(LCON)
      [F:YCGM]YPORMRGF3   = [M:YCOND0]YPORMRGF3(LCON)
      [F:YCGM]YCODSUB3    = [M:YCOND0]YCODSUB3(LCON)
      [F:YCGM]YTIPOMRGS3  = [M:YCOND0]YTIPOMRGS3(LCON)
      [F:YCGM]YPORMRGS3   = [M:YCOND0]YPORMRGS3(LCON)
      [F:YCGM]YCODGAM3    = [M:YCOND0]YCODGAM3(LCON)
      [F:YCGM]YTIPOMRGG3  = [M:YCOND0]YTIPOMRGG3(LCON)
      [F:YCGM]YPORMRGG3   = [M:YCOND0]YPORMRGG3(LCON)
      Write [F:YCGM]
    Endif
  Next
  Raz LCON

  # modifica las condiciones de Proveedor
  For LCON = 0 To [M:YCOND0]NBLIG4-1
    Read [F:YCPR]YCPR0 = [F:YCON]YCDGCOND;[F:YCON]YFECHAINI;[F:YCON]YFECHAFIN;[M:YCOND0]BPSNUM(LCON)
    If fstat = 0 Then                                       # el registro existe en la tabla
      [F:YCPR]YCDGCOND4   = [F:YCON]YCDGCOND
      [F:YCPR]BPSNUM      = [M:YCOND0]BPSNUM(LCON)
      [F:YCPR]YFECHAINI4  = [F:YCON]YFECHAINI
      [F:YCPR]YFECHAFIN4  = [F:YCON]YFECHAFIN
      [F:YCPR]YTIPOMRG4   = [M:YCOND0]YTIPOMRG4(LCON)
      [F:YCPR]YPORMRG4    = [M:YCOND0]YPORMRG4(LCON)
      Rewrite [F:YCPR]
    Else                                                    # fstat=0, el registro no existe en la tabla
      [F:YCPR]YCDGCOND4   = [F:YCON]YCDGCOND
      [F:YCPR]BPSNUM      = [M:YCOND0]BPSNUM(LCON)
      [F:YCPR]YFECHAINI4  = [F:YCON]YFECHAINI
      [F:YCPR]YFECHAFIN4  = [F:YCON]YFECHAFIN
      [F:YCPR]YTIPOMRG4   = [M:YCOND0]YTIPOMRG4(LCON)
      [F:YCPR]YPORMRG4    = [M:YCOND0]YPORMRG4(LCON)
      Write [F:YCPR]
    Endif
  Next
  Raz LCON

Return


##############################################################
######################    ETIQUETAS    #######################
