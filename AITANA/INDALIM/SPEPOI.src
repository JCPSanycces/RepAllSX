#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "DEBUT"    :   Gosub DEBUT
Endcase
Return

####################################
$DEBUT
# Pongo por defecto el proveedor, y la contramarca
If [M:POI1]HBPSNUM <> ""
  Gosub DEBUT_FEN From SUBPOIA

  [M:PPI2]FOUDEB = [M:POI1]HBPSNUM
  [M:PPI2]FOUFIN = [M:POI1]HBPSNUM
  [M:PPI2]CTMFLG = 2
  Affzo [M:PPI2]FOUDEB
  Affzo [M:PPI2]FOUFIN
  Affzo [M:PPI2]CTMFLG

  GPE = 1
Endif
Return

