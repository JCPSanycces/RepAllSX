#####################################################################
#**
#* Genera el pdf con el report Y-FACVEN de una factura de venta..
#*!
$GEN_PDF_YFACVEN

Local Char WVOL(255), WYPATHPDF(255), NEWNAMEFILE(255), TBPAR(10)(1..100), TBVAL(30)(1..100)
Local Integer LINTENT

If clalev([F:AVL])=0 : Local File AVOLUME  [AVL] : Endif

# parámetros del informe Y-FACVEN
TBPAR(1)  = "sitedeb"         : TBVAL(1)  = [F:SIV]SALFCY
TBPAR(2)  = "sitefin"         : TBVAL(2)  = [F:SIV]SALFCY
TBPAR(3)  = "facturedeb"      : TBVAL(3)  = [F:SIV]NUM
TBPAR(4)  = "facturefin"      : TBVAL(4)  = [F:SIV]NUM
TBPAR(5)  = "typedeb"         : TBVAL(5)  = "1"
TBPAR(6)  = "typefin"         : TBVAL(6)  = "5"
TBPAR(7)  = "clientdeb"       : TBVAL(7)  = [F:SIV]BPCINV
TBPAR(8)  = "clientfin"       : TBVAL(8)  = [F:SIV]BPCINV
TBPAR(9)  = "datedeb"         : TBVAL(9)  = [F:SIV]INVDAT
TBPAR(10) = "datefin"         : TBVAL(10) = [F:SIV]INVDAT
TBPAR(11) = "codimp"          : TBVAL(11) = "2"
TBPAR(12) = "impselections"   : TBVAL(12) = "1" # no
TBPAR(13) = "duplicata"       : TBVAL(13) = "1" # no

If dim([V]GYWNOMFIC)>0 : Kill [V]GYWNOMFIC : Endif
Global Char GYWNOMFIC(255)

WVOL = func AFNC.PARAM("YVOLSIH", "")
If WVOL=""
  GMESSAGE  = "YVOLSIH:" - mess(141,105,1)
  GERR = 1 : FIN = 1 : Return
Endif

Read [F:AVL]CODE=WVOL
If fstat
  GMESSAGE  = WVOL + ":" - mess(47,149,1)
  GERR = 1 : FIN = 1 : Return
Endif

WYPATHPDF = func ASYRSTO.GETFULLPATH(WVOL, "")
Gosub SET_NEWNAMEFILE

GYWNOMFIC =  WYPATHPDF + "\" + NEWNAMEFILE

#Call BORRAR(GYWNOMFIC, I) From SPEYLIB0
# borra la factura si existe..
If filinfo(GYWNOMFIC, 7) > 0 : System "ae_rm " + GYWNOMFIC : Endif

#Infbox TBPAR
#Infbox TBVAL

Call ETAT(WRPTCOD, WCODAIM, GLANGUE, 0, "", TBPAR, TBVAL) From AIMP3

# intentos para comprobar la creación del pdf..
LINTENT = 1
While LINTENT < 10
  Sleep 1
  If filinfo(GYWNOMFIC, 7) > 0 Then
    Break
    #LINTENT = 10 # fin
    #LESTADO = 2  # pdf creado..
  Else
    #LESTADO = 3  # pdf error..
    LINTENT += 1 # un intento más..
  Endif
  If LINTENT = 10
    WMSG = mess(7,6050,1)
  Endif
Wend

Return


#####################################################################
#**
#* Monta el nombre del fichero Pdf:
#* Sociedad_Factura_NombreCliente.pdf
#*
#*!

$SET_NEWNAMEFILE
  If clalev([F:SIV])=0 : Local File SINVOICEV  [SIV] : Endif
  If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
  If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif

#  If [F:SIV]NUM<>WVCRNUM
#    Read [F:SIV]SIV0=WVCRNUM
#    If fstat
#      WMSG = WVCRNUM + ":" - mess(23,100,1)
#      STAT = 1 : Return
#    Endif
#  Endif
  If [F:BPR]BPRNUM<>[F:SIV]BPCINV
    Read [F:BPR]BPR0=[F:SIV]BPCINV
    If fstat : Raz [F:BPR] : Endif
  Endif
#  If [F:BPC]BPCNUM<>[F:SIV]BPCINV
#    Read [F:BPC]BPC0=[F:SIV]BPCINV
#    If fstat : Raz [F:BPC] : Endif
#  Endif

  NEWNAMEFILE = [F:SIV]CPY + '_' + toupper([F:SIV]NUM)
  If [F:BPR]BPRNAM<>""
    Local Char CLEANSTR(255)
    Call LIMPIA_STR([F:BPR]BPRNAM, CLEANSTR) From SPEYLIB0
    NEWNAMEFILE +=  "_" + CLEANSTR
    If right$(NEWNAMEFILE, len(NEWNAMEFILE))<>"."
      NEWNAMEFILE += "."
    Endif
    NEWNAMEFILE += "pdf"
  Endif
Return


