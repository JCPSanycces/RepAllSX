#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
  Case ACTION
    When "OUVRE"   : Gosub OUVRE
    When "DEBUT"   : Gosub DEBUT
    When "SETBOUT" : Gosub SETBOUT
    When "BOUTON"  : Gosub BOUTON
    When "FIN"     : Gosub FIN
  Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
  If clalev([F:SIV])=0 : Local File SINVOICEV  [SIV] : Endif
  If clalev([F:SIH])=0 : Local File SINVOICE   [SIH] : Endif
  If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
  If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
  If clalev([F:AIM])=0 : Local File APRINTER   [AIM] : Endif
  If clalev([F:AVL])=0 : Local File AVOLUME    [AVL] : Endif
  If !clalev([F:YVSB]) : Local File YVSIVBPC   [YVSB]: Endif   # 06/05/2020 - MS
  If !clalev([F:YVASS]): Local File YVATTSDHSIH [YVASS]: Endif # 06/05/2020 - MS Vista factura y adjuntos entregas incluidas

  Local  Char    CRITERE(250), WRPTCOD(GLONARP), WCODAIM(GLONAIM), WYPATHPDF(250),
&                AUXCHAR(250), NOMFIC(250), WMSG(250), PATH_FILE(255), WVOL(GLONAVL), WSDHVOL(30)
  Local  Integer IS_FULL_TABLE, YSTA, WSEC, NBRFIC, STAT, NOL, AUXINT, NBERR
  Global Char    GYWNOMFIC(250)

  WSDHVOL = func AFNC.PARAM("YVOLSDH", "")      # 07/05/2020 - MS - Espacio de almacenamiento entregas
  WRPTCOD = func AFNC.PARAM("YSIHRPTCOD", "")

  If WRPTCOD=""
    GMESSAGE = "YSIHRPTCOD:" - mess(141,105,1)
    GERR = 1 : FIN = 1 : Return
  Endif

  # Destino de impresión igual a fichero con formato de exportación PDF
  Filter [F:AIM] Where PRT=4 and PRTFMT=29 and ENAFLG=2
  Read [F:AIM]AIM0 First
  Filter [F:AIM]
  If fstat
    GMESSAGE  = mess(6,6050,1)
    GERR = 1 : FIN = 1 : Return
  Else
    WCODAIM = [F:AIM]COD
  Endif

  # Volumen facturas documentos adjuntos
  WVOL = func AFNC.PARAM("YVOLSIH", "")
  If WVOL=""
    GMESSAGE  = "YVOLSIH:" - mess(141,105,1)
    GERR = 1 : FIN = 1 : Return
  Endif
  Read [F:AVL]CODE=WVOL
  If fstat
    GMESSAGE  = WVOL + ":" - mess(47,149,1)
    GERR = 1 : FIN = 1 : Return
  Endif
  WYPATHPDF = func ASYRSTO.GETFULLPATH(WVOL, "")
  If right$(WYPATHPDF, len(WYPATHPDF))<>"\"
    WYPATHPDF += "\"
  Endif
#  Infbox "WYPATHPDF " + WYPATHPDF

Return

##############################################################
$DEBUT
  [M:YSIP]ALLCPY = 2
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE : [M:YSIP]ALLCPY = 1 : Endif
  If [M:YSIP]ALLCPY = 1
    Call INICPY([M:YSIP]WCPY) From CPTSUB
  Endif
  If [M:YSIP]ALLCPY=2
    Diszo [M:YSIP]WCPY
  Else
    Actzo [M:YSIP]WCPY
  Endif

  [M:YSIP]ALLFCY = 2
  If [M:YSIP]ALLCPY = 1
    Call INIALLFCY([M:YSIP]ALLFCY,[M:YSIP]WCPY) From CPTTRT
  Endif
  If [M:YSIP]ALLFCY = 1
    Call INIFCY([M:YSIP]WFCY,[M:YSIP]WCPY) From CPTSUB
  Endif
  If [M:YSIP]ALLFCY=2
    Diszo [M:YSIP]WFCY
  Else
    Actzo [M:YSIP]WFCY
  Endif

  #[M:YSIP]ALLTYP = 2 : Diszo [M:YSIP]WINVTYP  # Desactivación Selección Tipo Factura

  [M:YSIP]YPATHPDF = [L]WYPATHPDF
  Affzo [M:YSIP]
  # Infbox [M:YSIP]YPATHPDF
Return

##############################################################
$SETBOUT
  If [M:YSIP]NBLIG=0
    Call VIREBOUT(CHMEN, "234s") From GOBJET
    Gosub SET_BOUT_SPE From GSAISIE
  Endif
Return

##############################################################
$BOUTON
  Case BOUT
    When "1" : Gosub SEARCH
    When "2" : Gosub INCLUDE_ALL
    When "3" : Gosub EXCLUDE_ALL
    When "4" : Gosub GENERATE
    When "s" : Gosub SEND_SIH               # RE04 - JC
  Endcase
Return

##############################################################
$FIN
  If dim([V]GYWNOMFIC)>0 : Kill [V]GYWNOMFIC : Endif
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$SEARCH
  Local Integer IS_FULL_TABLE, YSTA
  Local Char    AUXCHAR(250)

  Call TEMPON("R") From GESECRAN

  Effzo [M:YSIP]15
  CRITERE = "1=1"
  If [M:YSIP]ALLCPY<>2
    CRITERE -= '& CPY="' + [M:YSIP]WCPY + '"'
  Endif
  If [M:YSIP]ALLFCY<>2
    CRITERE -= '& SALFCY="' + [M:YSIP]WFCY + '"'
  Endif
#  If [M:YSIP]ALLTYP<>2         #3042020 - MS - Desactivación Selección Tipo Factura
#    CRITERE -= '& INVTYP=' + num$([M:YSIP]WINVTYP)
#  Endif
  ## 3042020 - MS - T013.4.1 ---------------------------
  CRITERE -= '& INVTYP<=4'
  If [M:YSIP]FLGSEND = 2
    CRITERE -= '& YINVSENT=2'
  Else
    CRITERE -= '& YINVSENT<>2'
  Endif

  If [M:YSIP]FLGIMP = 2
    CRITERE -= '& STARPT=2'
  Else
    CRITERE -= '& STARPT<>2'
  Endif

  # 05052020 - MS - Añadir filtro por tipo de envío cliente
  Case [M:YSIP]LFENFAC
    When 1    :   CRITERE -= '& YFENFAC=1'
    When 2    :   CRITERE -= '& YFENFAC=2'
    When 3    :   CRITERE -= '& YFENFAC=3'
  Endcase
  ## ---------------------------------------------------
  If [M:YSIP]STRDAT<>[0/0/0]
    CRITERE -= "& INVDAT>=[" + format$(GFMD, [M:YSIP]STRDAT) + "]"
  Endif
  If [M:YSIP]ENDDAT<>[0/0/0]
    CRITERE -= "& INVDAT<=[" + format$(GFMD, [M:YSIP]ENDDAT) + "]"
  Endif
  If [M:YSIP]VCRDEB<>""
    CRITERE -= '& NUM>="' + [M:YSIP]VCRDEB + '"'
  Endif
  If [M:YSIP]VCRFIN<>""
    CRITERE -= '& NUM<="' + [M:YSIP]VCRFIN + '"'
  Endif
  If [M:YSIP]BPCINVDEB<>""
    CRITERE -= '& BPCINV>="' + [M:YSIP]BPCINVDEB + '"'
  Endif
  If [M:YSIP]BPCINVFIN<>""
    CRITERE -= '& BPCINV<="' + [M:YSIP]BPCINVFIN + '"'
  Endif

  Raz IS_FULL_TABLE
  Raz nolign

  For [YVSB] Where evalue(CRITERE)
    If nolign>=dim([M:YSIP]NUM)
      IS_FULL_TABLE = 1 : Break
    Endif
    nolign += 1
    NOL = nolign-1
    Read [F:SIH]SIH0=[F:YVSB]NUM
    If fstat : Raz [F:SIH] : Endif

    [M:YSIP] = [F:SIH]
    [M:YSIP] = [F:YVSB]

    Read [F:BPR]BPR0=[F:SIH]BPR
    If fstat : Raz [F:BPR] : Endif
    [M:YSIP]WBPRNAM(NOL)  = [F:BPR]BPRNAM(0)

    Read [F:BPC]BPC0=[F:SIH]BPR
    If fstat : Raz [F:BPC] : Endif
    [M:YSIP]YSENDDLV(NOL) = [F:BPC]YSENDDLV(0)

    [M:YSIP]YEMAILSEND(NOL) = func GET_DIR_TO([F:YVSB]BPCINV,[F:YVSB]BPAADD)

    Gosub GET_NOMFIC

    AUXCHAR = [M:YSIP]YPATHPDF + NOMFIC

    Call EXISTE(AUXCHAR, YSTA) From ORDSYS
    If YSTA=1
      [M:YSIP]PDFEXIST(NOL) = 2
    Else
      [M:YSIP]PDFEXIST(NOL) = 1
    Endif

    [M:YSIP]YINVIMP(NOL) = [F:YVSB]STARPT

  Next
  [M:YSIP]NBLIG = nolign
  Affzo [M:YSIP]15
  Call TEMPOFF From GESECRAN
  If IS_FULL_TABLE
    GMESSAGE = mess(26,100,1) : GERR=2
  Endif
Return

##############################################################
$INCLUDE_ALL
  If [M:YSIP]NBLIG>0 : Call SELECT_ALL(2,0) : Endif
Return

##############################################################
$EXCLUDE_ALL
  If [M:YSIP]NBLIG>0 : Call SELECT_ALL(1,0) : Endif
Return

##############################################################
$GENERATE
Local Integer YN : YN = 1
Local Char WMSJ(30)

If dim([V]GYWDIRFROMYSIP)>0 : Kill [V]GYWDIRFROMYSIP : Endif
Global Char GYWDIRFROMYSIP(100)
GYWDIRFROMYSIP = func GET_DIR_FROM([M:YSIP]CPY, 1)

If [M:YSIP]LFENOPE = 1
  WMSJ = 'ENVIAR POR EMAIL'
Else
  If [M:YSIP]LFENOPE = 2
    WMSJ = 'IMPRIMIR'
  Else
    WMSJ = 'VISTA PREVIA'
  Endif
Endif

If find(2, [M:YSIP]CHKCREPDF(0..[M:YSIP]NBLIG-1))=0
  Call ERREURT('No ha seleccionado ninguna factura', 0) From GESECRAN
  Return
Endif

Call OUINON("Se va proceder a " + WMSJ +" las facturas seleccionadas\¿Desea continuar?" , YN) From GESECRAN
If YN = 2
  Raz NBERR

  Local Char TBPAR(10)(1..50), TBVAL(30)(1..50)
  Raz NBRFIC
  Call TEMPON("R") From GESECRAN

  Call OUVRE_TRACE(mess(10,6050,1)) From LECFIC
  For I=0 To [M:YSIP]NBLIG-1
    If [M:YSIP]CHKCREPDF(I)=2
      Read [F:SIV]SIV0=[M:YSIP]NUM(I)
      If !fstat
#        Read [F:BPC]BPC0=[F:SIV]BPCINV
#        If fstat : Raz [F:BPC] : Endif
        Gosub IMPRIME
      Endif
    Endif
  Next I
  Call FERME_TRACE From LECFIC

#  # Bucle para marcar el check de "PDF generado"
#  If NBRFIC>0
#    For NOL=0 To [M:YSIP]NBLIG-1
#      If [M:YSIP]CHKCREPDF(NOL)=2
#        Raz WSEC
#
#        Gosub GET_NOMFIC
#        AUXCHAR = [M:YSIP]YPATHPDF + [M:YSIP]CPY(NOL) + "\" + NOMFIC
#        Repeat
#          Call EXISTE(AUXCHAR, YSTA) From ORDSYS
#          If YSTA<>1
#            Sleep 1
#            WSEC += 1
#          Endif
#        Until YSTA=1 or WSEC>5
#        If YSTA=1
#          [M:YSIP]PDFEXIST(NOL) = 2
#          [M:YSIP]CHKCREPDF(NOL) = 1
#        Else
#          [M:YSIP]PDFEXIST(NOL) = 1
#        Endif
#      Endif
#      Affzo [M:YSIP]PDFEXIST(NOL)
#      Affzo [M:YSIP]CHKCREPDF(NOL)
#      Affzo [M:YSIP]YEMAILSEND(NOL)
#      Affzo [M:YSIP]YSENDDAT(NOL)
#    Next NOL
#  Endif

  Call TEMPOFF From GESECRAN

  If NBERR>0
    Call LEC_TRACE From LECFIC
  Endif
Endif
Return

##############################################################
$IMPRIME
  Local Char FICORI(255), FICDES(255)

  #Call GEN_PDF("SIH", [F:SIV]NUM, WRPTCOD, WCODAIM, STAT, WMSG) From YSENDPDF
  Gosub GEN_PDF_YFACVEN

  If STAT
    Call ECR_TRACE(mess(55,198,1) - [F:SIV]NUM + ":" - mess(6,123,1) - WMSG, 1) From GESECRAN
    NBERR += 1
  Else
    Call ECR_TRACE(mess(55,198,1) - [F:SIV]NUM + ":" - mess(11,6050,1), 0) From GESECRAN
    NBRFIC += 1

    If  [M:YSIP]YSENDDLV(I) = 2
      Gosub GEN_SIHATT
    Endif

    If [M:YSIP]LFENOPE = 1    # envío email
      If GYWDIRFROMYSIP <> ""
        If dim([V]GYWDIRMAIL)>0 : Kill [V]GYWDIRMAIL : Endif
        Global Char GYWDIRMAIL(100)
        GYWDIRMAIL = func GET_DIR_TO([F:SIV]BPCINV,[F:SIV]BPAADD)
        If GYWDIRMAIL <> ""
          AUXINT = [F:SIV]YNBRINVSENT
          Call WORKFLOW(1,"YED","","") From AWRK
          Read [F:SIV]SIV0=[M:YSIP]NUM(I)
          If fstat : Raz [F:SIV] : Endif
          If [F:SIV]YNBRINVSENT<=AUXINT
            WMSG  = mess(8,6050,1) + "\"
            WMSG += mess(9,6050,1)
            Call ECR_TRACE(WMSG, 1) From GESECRAN
            NBERR += 1
          Endif
        Else
          WMSG  = mess(8,6050,1) + "\"
          WMSG += mess(14,6050,1)
          Call ECR_TRACE(WMSG, 1) From GESECRAN
          NBERR += 1
        Endif
      Else
          WMSG  = mess(8,6050,1) + "\"
          WMSG += mess(13,6050,1)
          Call ECR_TRACE(WMSG, 1) From GESECRAN
          NBERR += 1
      Endif
    Endif                     # fin envío email
    If [M:YSIP]LFENOPE = 2    # Impresión
        Call IMPRIME_DOC(GYWNOMFIC,"VISTA") From SPEYLIB0
    Else                      # vista previa
      Call TEMPOFF From GESECRAN

      Local Char ZURL(250)

      Gosub GET_NAMEFILE

      ZURL  = "//x3indalim.westeurope.cloudapp.azure.com:8124/sdata/x3/erp/PROTO/BDOC('C_AVOLFIL~%C2%A8~CONTENTS~%C2%A8~"
      ZURL += "2001CLI-FACTURAS"
      ZURL += "~%C2%A8~"
      ZURL += PATH_FILE + "')"

      Callui RETORNO ="" With "UIAction="+chr$(1)+"OpenFile",
&     "UILocalDir="+ chr$(1) +"HTTP",
&     "UILocalFile="+ chr$(1) + ZURL
&     ,
&     "UIAdxPubSubFile="+ chr$(1) + "1"

#       Infbox "SE HA IMPRIMIDO EL DOCUMENTO POR LA IMPRESORA PREDETERMINDADA, A FALTA DE DEFINIR"

    Endif
  Endif
Return


##############################################################
$GET_NOMFIC
  NOMFIC = [M:YSIP]CPY(NOL) + '_' + toupper([M:YSIP]NUM(NOL))
  If [M:YSIP]WBPRNAM(NOL)<>""
    #NOMFIC +=  "_" + func YSENDPDF.REMOVE_FILENAME_CHARS([M:YSIP]WBPRNAM(NOL), "")
    Local Char CLEANSTR(255)
    Call LIMPIA_STR([F:BPR]BPRNAM, CLEANSTR) From SPEYLIB0
    NOMFIC +=  "_" + CLEANSTR
    If right$(NOMFIC, len(NOMFIC))<>"."
      NOMFIC += "."
    Endif
    NOMFIC += "pdf"
  Endif
Return

##############################################################
Subprog SELECT_ALL(PON, DESDE)
Value Integer PON
Value Integer DESDE
Local Integer I

  For I=DESDE To [M:YSIP]NBLIG-1
    If PON=2
      [M:YSIP]CHKCREPDF(I) = 2
    Else
      [M:YSIP]CHKCREPDF(I) = 1
    Endif
  Next I
  Affzo [M:YSIP]CHKCREPDF
End

##############################################################
Subprog GET_PDF_SIH(WNUM, WCPY, WBPRNAM, WYPATHPDF)
Value Char WNUM
Value Char WCPY
Value Char WBPRNAM
Value Char WYPATHPDF

  If WNUM="" : End : Endif

  Local Char    WDIR(255), NOMFIC(250), TEMPFILE(255), URL(255)
  Local Char    ORDSYS(255)
  Local Integer STAT

  WDIR = WYPATHPDF + "\"
  Local Char CLEANSTR(255)
  Call LIMPIA_STR(WBPRNAM, CLEANSTR) From SPEYLIB0
  NOMFIC = WCPY + '_' + toupper(WNUM + "_" + CLEANSTR)
  If right$(NOMFIC, len(NOMFIC))<>"."
    NOMFIC += "."
  Endif
  NOMFIC += "pdf"
  TEMPFILE = filpath(nomap + "/TMP/" + NOMFIC, "", "", "X3_PUB")
  ORDSYS = 'COPY "' + WDIR + NOMFIC + '" "' + TEMPFILE + '"'
  Call SYSTEME(adxmac(0), ORDSYS, "", STAT) From ORDSYS
  Call EXISTE(TEMPFILE, STAT) From ORDSYS
  If STAT=1
    URL = func AFNC.PARAM("YDIRPUBPDF", "")
    If URL="" : URL = GVIRTDIR : Endif
    If right$(URL, len(URL))<>"/"
      URL += "/"
    Endif
    URL += nomap + "/TMP/" + NOMFIC

    Infbox URL

    Callui RETOUR="" With "UIAction="    + chr$(1) + "OpenFile",
&                         "UILocalDir="  + chr$(1) + "HTTP",
&                         "UILocalFile=" + chr$(1) + URL
  Else
    GMESSAGE = "|" + WDIR + NOMFIC + "|.\"
    GMESSAGE+= mess(12,6050,1)
    Call ERREUR(GMESSAGE) From GESECRAN
    Raz GMESSAGE
  Endif
End

##############################################################
# RE04 - JC
# envía mensaje con PDF adjunto a los destinatarios de las
# facturas que estén seleccionadas
$SEND_SIH
Local Integer LCON0 : Raz LCON0
Local Integer LSTA  : Raz LSTA

  If find(2, [M:YSIP]CHKCREPDF(0..[M:YSIP]NBLIG-1))=0 : Return : Endif

  For LCON0 = 0 To [M:YSIP]NBLIG-1
    If [M:YSIP]CHKCREPDF(LCON0) = 2 Then
      Call ENVMAIL_SIH([M:YSIP]NUM(LCON0),"ZSBONFAC","ENVIOPDF",LSTA) From SPEYLIB0
      If LSTA = 0 Then
        [M:YSIP]YINVSENT(LCON0) = 2
      Endif
    Endif
  Next

  Affzo [M:YSIP]YINVSENT
  Kill LCON0
Return


#**
#* Agrupa en un único PDF la factura y los adjuntos de las entregas
#* incluidas en la misma
#*
#*!
$GEN_SIHATT
Local Integer STAT
Local Char    RAIZVOL(255)
Local Char    NAMENEWPDF(255), NAMEAUXPDF(255)

Local Char    ORDSYS(255)

Read [AVL]CODE = WSDHVOL
If !fstat
  # HAY QUE TENER CUIDADO QUE LA VARIABLE ORDSYS NO SUPERE LOS 255 CARACTERES
  # PUEDE HACERLO SI LA RUTA DE LOS ESPACIOS DE ALMACENAMIENTO ES COMPLEJA.
  NAMENEWPDF = [M:YSIP]YPATHPDF + [F:SIV]CPY + '_' + [F:SIV]NUM

  RAIZVOL = [AVL]ROOT

  Filter [F:YVASS] Where NUM=[F:SIV]NUM and VOL = "["+ WSDHVOL + "]"
  NAMEAUXPDF = GYWNOMFIC

  For [F:YVASS]
    ORDSYS = 'C:\PDFtk\bin\pdftk.exe A='+ NAMEAUXPDF +' '+'B='+ RAIZVOL +'\' + [F:YVASS]PDF + ' output ' + NAMENEWPDF + '.PDF' + ' dont_ask'
    Call SYSTEME(adxmac(0), ORDSYS, "", STAT) From ORDSYS
    FICORI = NAMENEWPDF + '.PDF'
    FICDES = NAMEAUXPDF
    Call COPIAR (FICORI, FICDES, STAT) From YSENDPDF
    Call BORRAR (FICORI,STAT) From YSENDPDF
  Next
  GYWNOMFIC = NAMEAUXPDF
Endif

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
##############################################################
Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    VALEUR = 1 : mkstat = 1
  Endif
End

##############################################################
Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR
  Raz [M:YSIP]WCPY
  If VALEUR=2
    Diszo [M:YSIP]WCPY
  Else
    Actzo [M:YSIP]WCPY
  Endif
  Affzo [M:YSIP]WCPY
End

##############################################################
Subprog AS_WCPY(VALEUR)
Variable Char    VALEUR()
  If [M:YSIP]ALLCPY=2
    VALEUR = 1 : mkstat = 1
  Endif
End

##############################################################
Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
  If [M:YSIP]ALLCPY=2
    VALEUR = 2
  Else
    Call INIALLFCY(VALEUR, [M:YSIP]WCPY) From CPTTRT
  Endif
  If VALEUR=2
    Raz [M:YSIP]WFCY
    Diszo [M:YSIP]WFCY
  Else
    Actzo [M:YSIP]WFCY
  Endif
  Affzo [M:YSIP]WFCY
End

##############################################################
Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR
  Raz [M:YSIP]WFCY
  If VALEUR=2
    Diszo [M:YSIP]WFCY
  Else
    Actzo [M:YSIP]WFCY
  Endif
  Affzo [M:YSIP]WFCY
End

##############################################################
Subprog AS_WFCY(VALEUR)
Variable Char    VALEUR()
  If [M:YSIP]ALLFCY=2
    VALEUR = 1 : mkstat = 1
  Endif
End

##############################################################
Subprog AM_ALLTYP(VALEUR)
Variable Integer VALEUR
  Raz [M:YSIP]WINVTYP
  If VALEUR=2
    Diszo [M:YSIP]WINVTYP
  Else
    Actzo [M:YSIP]WINVTYP
  Endif
  Affzo [M:YSIP]WINVTYP
End

##############################################################
Subprog AS_WINVTYP(VALEUR)
Variable Integer VALEUR
  If [M:YSIP]ALLTYP=2
    VALEUR = 1 : mkstat = 1
  Endif
End

##############################################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
  If VALEUR<>[0/0/0] : [M:YSIP]ENDDAT = VALEUR : Endif
End

##############################################################
Subprog AM_VCRDEB(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>"" : [M:YSIP]VCRFIN = VALEUR : Endif
End

##############################################################
Subprog AM_BPCINVDEB(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>"" : [M:YSIP]BPCINVFIN = VALEUR : Endif
End

##############################################################
Subprog IB_NBLIG
  GBOUT4 = mess(193, 198,1)-[M:YSIP]NUM(nolign-1)
End

##############################################################
Subprog B1_NBLIG
  Call SELECT_ALL(2,nolign-1)
End

##############################################################
Subprog B2_NBLIG
  Call SELECT_ALL(1,nolign-1)
End

######################################################################################
Subprog AM_LFENFAC(VALEUR)
Variable Integer VALEUR
If VALEUR <> 1
  [M:YSIP]LFENOPE = 2
#  Grizo [M:YSIP]FLGSEND
Else
  [M:YSIP]LFENOPE = 1
  Actzo [M:YSIP]FLGSEND
Endif
[M:YSIP]LFENFAC = VALEUR
Affzo [M:YSIP]FLGSEND
Affzo [M:YSIP]LFENFAC
Affzo [M:YSIP]LFENOPE
Gosub SEARCH

End

######################################################################################
Subprog AM_FLGSEND(VALEUR)
Variable Integer VALEUR
[M:YSIP]FLGSEND = VALEUR
Affzo [M:YSIP]FLGSEND
Gosub SEARCH

End


#**
#* Función que devuelve el email de la dirección predeterminada de la sociedad
#*
#* @param LCPY      Sociedad
#* @param LNUM      Orden del email (1,2,3,4,5)
#*!
Funprog GET_DIR_FROM(LCPY, LNUM)
  Value Char    LCPY
  Value Integer LNUM
  Local Char LMAIL(250)


  If !clalev([ZCOM]) Then : Local File COMPANY   [ZCOM]  : Endif
  If !clalev([ZBPA]) Then : Local File BPADDRESS [ZBPA]  : Endif

  Read [ZCOM]CPY0=LCPY
  If !fstat Then
    Read [ZBPA]BPA0=2;LCPY;[F:ZCOM]BPAADD
    If !fstat
      LMAIL = [F:ZBPA]WEB(LNUM-1)
    Else
      LMAIL = ""
    Endif
  Endif
  Close File [ZCOM], [ZBPA]

End LMAIL


#**
#* Función que devuelve el email de la dirección de facturación para
#* la dirección de envío, o en su defecto el email de la dirección predeterminada
#*
#* @param BPCINV      Cliente Factura
#* @param BPAADD      Dirección Envío
#*!
Funprog GET_DIR_TO(BPCINV, BPAADD)
  Value Char  BPCINV
  Value Char  BPAADD
  Local Char  LMAIL(250)

  Local Char YADINV(5)

  If !clalev([ZBPD])  : Local File BPDLVCUST  [ZBPD]  : Endif
  Read [ZBPD]BPD0 = BPCINV ; BPAADD
  If !fstat
    YADINV = [ZBPD]YDIRFAC
  Endif

  If YADINV <> ''
    If !clalev([ZBPA]) Then : Local File BPADDRESS [ZBPA]  : Endif
    Read [F:ZBPA]BPA0 =1;BPCINV;YADINV
    If !fstat
      If [F:ZBPA]WEB(0) <> ''
        LMAIL = [F:ZBPA]WEB(0)
      Else
        Filter [F:ZBPA] Where BPATYP=1 and BPANUM=BPCINV and BPAADDFLG=2
        Read [F:ZBPA] First
        If !fstat
          LMAIL = [F:ZBPA]WEB(0)
        Else
          LMAIL = ''
        Endif
      Endif
    Endif
  Else
    LMAIL = ""
  Endif
  Close Local File [ZBPA], [ZBPD]

End LMAIL


$GET_NAMEFILE
  If clalev([F:ZBPC])=0 : Local File BPCUSTOMER [ZBPC] : Endif

  Read [F:ZBPC]BPC0=[F:SIV]BPCINV
  PATH_FILE = [F:SIV]CPY + '_' + toupper([F:SIV]NUM)
  If [F:ZBPC]BPCNAM<>""
    Local Char CLEANSTR(255)
    Call LIMPIA_STR([F:ZBPC]BPCNAM, CLEANSTR) From SPEYLIB0
    PATH_FILE +=  "_" + CLEANSTR
    #PATH_FILE +=  "_" + func REMOVE_FILENAME_CHARS([F:ZBPC]BPCNAM, "")
  Endif
  PATH_FILE += ".pdf"
Return

