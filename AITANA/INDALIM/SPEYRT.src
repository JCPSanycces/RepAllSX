#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif

  Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "FILTRE"     : Gosub FILTRE
    When "LIENS"      : Gosub LIENS
    When "CREATION"   : Gosub CREATION
    When "MODIF"      : Gosub MODIF
    When "ANNULE"     : Gosub ANNULE
    When "APRES_CRE"  : Gosub APRES_CRE
    When "APRES_MOD"  : Gosub APRES_MOD
    When "INICRE_LIG" : Gosub INICRE_LIG
    When "DEFLIG"     : Gosub DEFLIG
    When "SEL_TABLE"  : Gosub SEL_TABLE
    When "VERF_TABLE" : Gosub VERF_TABLE
  Endcase
Return

########################################################################
$OUVRE
  Gosub DECLARE From TABLEAUX
Return

########################################################################
$FILTRE
  Default File [YRTC]
Return

########################################################################
$LIENS
  Gosub LIENS From TABLEAUX
Return

########################################################################
$CREATION
  Gosub CREATION From TABLEAUX
Return

########################################################################
$MODIF
  Gosub MODIF From TABLEAUX
Return

########################################################################
$ANNULE
  Gosub ANNULE From TABLEAUX
Return

########################################################################
$APRES_CRE
  Gosub LIENS From TABLEAUX
Return

########################################################################
$APRES_MOD
  Gosub LIENS From TABLEAUX
Return

########################################################################
$INICRE_LIG
  [F:YRTD]YCODRUTA = [M:YRT0]YCODRUTA
Return

########################################################################
$DEFLIG
  Default Mask [YRT1]                                   # pantalla de las líneas
  Default File [YRTD]                                   # abreviatura de la tabla de las líneas

  # criterios de filtrado
  CRIT    = 'YCODRUTA="'+[M:YRT0]YCODRUTA+'"'           # campo común de las tablas + pantalla cabecera (con el campo común)
  FICLIG  = "YRUTAD"                                    # nombre de la tabla de detalle
  ABLIG   = "YRTD"                                      # abreviatura de la tabla de detalle
  ZONLIG  = "YRUTALIN"                                  # campo contador de línea en la tabla detalle
Return

########################################################################
$SEL_TABLE
  If !clalev([F:YZND]) Then : Local File YZONAD [F:YZND] : Endif
  Default File [YZND]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Selección de zonas"                                            # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Cód. zona"                                                     # título de la primera columna
  COL(NBCOL)  = "YCODZONA"                                                      # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Cód. postal"                                                   # título de la segunda columna
  COL(NBCOL)  = "POSCOD"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Subdiv."                                                       # título de la tercera columna
  COL(NBCOL)  = "SATCOD"                                                        # nombre del campo a mostrar en la tercera columna

Return

########################################################################
$VERF_TABLE

  [M:YRT1]POSCOD(nolign-1) = [F:YZND]POSCOD
  [M:YRT1]SATCOD(nolign-1) = [F:YZND]SATCOD
  Affzo [M:YRT1]5

Return

