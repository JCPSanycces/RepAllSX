#######################################################################################

$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
  Case ACTION
    When "SEL_TABLE"    : Gosub SEL_TABLE                                         # IN22
    When "VERF_TABLE"   : Gosub VERF_TABLE                                        # IN22
    When Default
  Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
########################################################################
$SEL_TABLE
  Case TABLE
    When "YVHSEXPSDH"  : Gosub SEL_YVHSEXPSDH                                     # selección para el campo medio (vehículo) - IN22
  Endcase
Return

########################################################################
$VERF_TABLE
  Case TABLE
    When "YVHSEXPSDH"  : Gosub VERF_YVHSEXPSDH                                    # IN22
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
########################################################################
$SEL_YVHSEXPSDH                                                                   # IN22
  If !clalev([F:YVHS]) Then : Local File YVEHICULOS [F:YVHS] : Endif
  Default File [YVHS]
  NBCOL       = 0                                                                 # número de la columna
  TIT(NBCOL)  = "Mantenimiento de vehículos"                                      # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Medio"                                                           # título de la segunda columna
  COL(NBCOL)  = "YMARCA"                                                          # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Matrícula"                                                       # título de la primera columna
  COL(NBCOL)  = "YMATRICULA"                                                      # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                     # título de la tercera columna
  COL(NBCOL)  = "YMODELO"                                                         # nombre del campo a mostrar en la tercera columna
Return

########################################################################
$VERF_YVHSEXPSDH
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

