$ACTION
Case ACTION
  When Default
Endcase

Return


######################################################################################
Subprog C_XWEB1(VALEUR)
Variable Char    VALEUR()

Local Integer CEMAIL  # 1 No 2 Si

Case maskcou
  When 'BPA'    : CEMAIL = 2
  When 'BPABPC' : CEMAIL = 2    # clientes
  When 'BPABPR' : CEMAIL = 2    # terceros
  When Default
Endcase

If CEMAIL = 2
  If [M]XBPAADDFLG = 2
    If VALEUR = ""
      Call ERREURT('El Email es obligatorio para la direcciůn por defecto', 0) From GESECRAN
      mkstat = 1
    Endif
  Endif
Endif

End

