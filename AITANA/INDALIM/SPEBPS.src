# IN24-Tarifas especiales proveedores
# Fecha inicio IN24: 03/04/2019
# Desarrollador: JCH
# Código de desarrollo: IN24
# Descripción del desarrollo: Pantallas adicionales en la ficha del proveedor para controlar tarifas
# Fecha fin: 26/04/2019
# Codigo Actividad: YIN24
#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif

Case ACTION
  When "SEL_TABLE"    : Gosub SEL_TABLE
  When "VERF_TABLE"   : Gosub VERF_TABLE
  When "LIENS"        : Gosub LIENS
  When "INIMOD"       : Gosub INIMOD
  When "EXEBOUT"      : Gosub EXEBOUT
  When "SETBOUT"      : Gosub SETBOUT
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
########################################
$SEL_TABLE
  Case TABLE
    When "YSELBPSIT1"   : Gosub SEL_YSELBPSIT1                            # IN24 - tarifa proveedor-artículo para la pantalla YTEP1
    When "YSELBPSIT2"   : Gosub SEL_YSELBPSIT2                            # IN24 - tarifa proveedor-artículo para la pantalla YTEP2
    When "YSELBPSIT3"   : Gosub SEL_YSELBPSIT3                            # IN24 - tarifa proveedor-artículo para la pantalla YTEP3
    When "YSELBPSIT4"   : Gosub SEL_YSELBPSIT4                            # IN24 - tarifa proveedor-artículo para la pantalla YTEP4
    When "YSELBPSIT5"   : Gosub SEL_YSELBPSIT5                            # IN24 - tarifa a actualizar proveedor-artículo para la pantalla YTEP4
    When "YSELREFBI"    : Gosub SEL_YSELREFBI                             # IN24 - campo referencia proveedor para la pantalla YTEP1
    When "YSELSECBPS"   : Gosub SEL_YSELSECBPS                            # IN24 - campo Sección para la pantalla YTEP1
    When "YSELBPSEC"    : Gosub SEL_YSELBPSEC                             # IN24 - campo proveedor-sección para la pantalla YTEP3
    When "YSELBPSEC1"   : Gosub SEL_YSELBPSEC                             # IN24 - campo proveedor-sección para la pantalla YTEP4
    When "YSELBPSEC2"   : Gosub SEL_YSELBPSEC                             # IN24 - campo proveedor-sección a actualizar para la pantalla YTEP4
  Endcase
Return

########################################
$VERF_TABLE
  Case TABLE
    When "YSELBPSIT1"   : Gosub VERF_YSELBPSIT1                           # IN24
    When "YSELBPSIT2"   : Gosub VERF_YSELBPSIT2                           # IN24
    When "YSELBPSIT3"   : Gosub VERF_YSELBPSIT3                           # IN24
    When "YSELBPSIT4"   : Gosub VERF_YSELBPSIT4                           # IN24
    When "YSELBPSIT5"   : Gosub VERF_YSELBPSIT5                           # IN24
    When "YSELREFBI"    : Gosub SEL_YSELREFBI                             # IN24
    When "YSELSECBPS"   : Gosub VERF_YSELSECBPS                           # IN24
    When "YSELBPSEC"    : Gosub VERF_YSELBPSEC                            # IN24
    When "YSELBPSEC1"   : Gosub VERF_YSELBPSEC1                           # IN24
    When "YSELBPSEC2"   : Gosub VERF_YSELBPSEC2                           # IN24
  Endcase
Return

########################################
# IN24
$SEL_YSELBPSIT1
  If !clalev([F:YPF0]) Then : Local File PPRICFICH [F:YPF0] : Endif
  Default File [YPF0]
  Filter [F:YPF0] Where PLI = "T20" and PLICRDIDX = [M:BPS0]BPSNUM# and PLISTRDAT <= date$ and PLIENDDAT >= date$
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Código tarifa"                                                 # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "PLICRDIDX"                                                     # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Registro tarifa"                                               # título de la primera columna
  COL(NBCOL)  = "PLICRD"                                                        # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Inicio vigencia"                                               # título de la primera columna
  COL(NBCOL)  = "PLISTRDAT"                                                     # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Fin vigencia"                                                  # título de la tercera columna
  COL(NBCOL)  = "PLIENDDAT"                                                     # nombre del campo a mostrar en la tercera columna
Return

########################################
# IN24
$VERF_YSELBPSIT1
  [M:YTEP1]PLICRD     = [F:YPF0]PLICRD
  [M:YTEP1]YINIVAL    = [F:YPF0]PLISTRDAT
  [M:YTEP1]YFINVAL    = [F:YPF0]PLIENDDAT
  Affzo [M:YTEP1]PLICRD,YINIVAL,YFINVAL,LTI
Return

