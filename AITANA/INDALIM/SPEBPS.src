########################################
$LIENS
# IN24
Global Char GNUMREGTAR(15)
  Gosub CARGA_ITMBPS
# IN24
Return

########################################
$SETBOUT
  # IN24
  If [M:YTEP1]YTARBPSITM = "" Then
    Call VIREBOUT(CHAINE,"c") From GOBJET
    CHAINE += "g"
  Else
    CHAINE += "c"
  Endif

  If [M:YTEP1]YINIVAL = [00/00/0000] or [M:YTEP1]YFINVAL = [00/00/0000] Then
    Call VIREBOUT(CHAINE,"g") From GOBJET
  Else
    CHAINE += "g"
  Endif

  If [M:YTEP2]YTARBPSITM = "" Then
    Call VIREBOUT(CHAINE,"h") From GOBJET
  Else
    CHAINE += "h"
  Endif
  # IN24
Return

########################################
$INIMOD
  # IN24
  Gosub INIMOD From SUBBPS
  Gosub REGISTRAR_ITMBPS                                 # IN24 registra modificaciones de la pestaña "Artículos prov."
  Gosub CARGA_ITMBPS                                     # IN24 carga los artículos de nuevo en el grid de la pestaña "Artículos prov."(con los datos actualizados)
  Gosub REGISTRAR_SECBPS                                 # IN24 registra modificaciones de la pestaña "Sección prov."
  Gosub CARGA_SECBPS                                     # IN24 carga los artículos de nuevo en el grid de la pestaña "Sección prov." (con los datos actualizados)
  GPE=1
  # IN24
Return

########################################
$EXEBOUT
  # IN24
  Case BOUT
    When "c"    : Gosub CARGA_PPRICLIST                  # carga tarifas en la pantalla "Articulos prov."
    When "g"    : Gosub GENERA_TARIFA_AP                 # genera la tarifa en "Artículos prov."
    When "h"    : Gosub GENERA_TARIFA_SP                 # genera la tarifa en "Sección prov."
  Endcase
  # IN24
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
########################################
# IN24
# carga los registros en la pestaña "Artículos prov."
$CARGA_ITMBPS
Local Integer LCON0, LNUMREG0 : Raz LCON0, LNUMREG0

  If !clalev([F:YIT0]) Then : Local File ITMBPS     [F:YIT0] : Endif
  If !clalev([F:YIM0]) Then : Local File ITMMASTER  [F:YIM0] : Endif
  Filter [F:YIT0] Where BPSNUM = [M:BPS0]BPSNUM
  LNUMREG0 = rowcount([F:YIT0])
  Read [F:YIT0] First
  If !fstat Then
    For LCON0 = 0 To LNUMREG0-1                                                                     # busca datos en artículos
      Read [F:YIM0]ITM0 = [F:YIT0]ITMREF
      If !fstat Then
        If [F:YIM0]ITMSTA <> 1 Then
          [M:YTEP1]YBAJA(LCON0) = 2
        Endif
      Endif
      [M:YTEP1]ITMREF(LCON0)    = [F:YIT0]ITMREF                                                    # código artículo
      [M:YTEP1]ITMDESBPS(LCON0) = [F:YIT0]ITMDESBPS                                                 # descripción proveedor
      [M:YTEP1]PUU(LCON0)       = [F:YIT0]PUU                                                       # unidad de compra
      [M:YTEP1]ITMREFBPS(LCON0) = [F:YIT0]ITMREFBPS                                                 # referencia proveedor
      [M:YTEP1]YSECC(LCON0)     = [F:YIT0]YSECC2                                                    # sección
      [M:YTEP1]PIO(LCON0)       = [F:YIT0]PIO                                                       # prioridad
      [M:YTEP1]YTSICOD0(LCON0)  = [F:YIM0]TSICOD(0)                                                 # familia (invisible)
      [M:YTEP1]YTSICOD1(LCON0)  = [F:YIM0]TSICOD(1)                                                 # subfamilia (invisible)
      [M:YTEP1]YTSICOD2(LCON0)  = [F:YIM0]TSICOD(2)                                                 # gama (invisible)
      [M:YTEP1]YORDEN(LCON0)    = [F:YIM0]YORDEN                                                    # orden (invisible)
      Read[F:YIT0] Next
    Next
    [M:YTEP1]NBITM = LNUMREG0
#    # ordena el cuadro por los campos "Familia", "Subfamilia", "Gama", "Orden"
    Sorta [M:YTEP1]NBITM [M:YTEP1]NBITM Order By [M:YTEP1]YTSICOD0(indice), [M:YTEP1]YTSICOD1(indice), [M:YTEP1]YTSICOD2(indice), [M:YTEP1]YORDEN(indice)
    Affzo [M:YTEP1]15
  Endif
  Filter [F:YIT0]
  If clalev([F:YIT0])  Then : Close Local File  [F:YIT0] : Endif
  If clalev([F:YIM0])  Then : Close Local File  [F:YIM0] : Endif

Return

########################################
# IN24
# registra modificaciones de la pestaña "Artículos prov."
$REGISTRAR_ITMBPS
Local Integer LCON1 : Raz LCON1
Local Integer LNUMREG1 : Raz LNUMREG1

  If !clalev([F:YIT1]) Then : Local File ITMBPS     [F:YIT1] : Endif
  If !clalev([F:YPL1]) Then : Local File PPRICLIST  [F:YPL1] : Endif
  If !clalev([F:YPL4]) Then : Local File PPRICLIST  [F:YPL4] : Endif
  If !clalev([F:YPF1]) Then : Local File PPRICFICH  [F:YPF1] : Endif
  If !clalev([F:YIM1]) Then : Local File ITMMASTER  [F:YIM1] : Endif
  For LCON1 = 0 To [M:YTEP1]NBITM-1                                                                 # recorre el grid
    Read [F:YIT1]ITP0 = [M:YTEP1]ITMREF(LCON1);[M:BPS0]BPSNUM                                       # comprueba si existe el artículo en la tabla ITMBPS
    If !fstat Then
      # actualización de datos en la tabla ITMBPS
      [F:YIT1]ITMREF    = [M:YTEP1]ITMREF(LCON1)                                                    # código de artículo
      [F:YIT1]ITMDESBPS = [M:YTEP1]ITMDESBPS(LCON1)                                                 # descripción proveedor
      [F:YIT1]ITMREFBPS = [M:YTEP1]ITMREFBPS(LCON1)                                                 # código proveedor
      [F:YIT1]YSECC2    = [M:YTEP1]YSECC(LCON1)                                                     # sección
      [F:YIT1]PIO       = [M:YTEP1]PIO(LCON1)                                                       # prioridad
      Rewrite [F:YIT1]
      If !fstat Then
        # actualización / creación de registro en la tabla PPRICLIST
        Filter [F:YPL1] Where PLI="T20" and PLICRI1=[M:BPS0]BPSNUM and PLICRI2=[F:YIT1]ITMREF and PLISTRDAT=[M:YTEP1]YINIVAL and PLIENDDAT=[M:YTEP1]YFINVAL
&       and MINQTY = [M:YTEP1]MINQTY(LCON1) and MAXQTY = [M:YTEP1]MAXQTY(LCON1)
#        LNUMREG1 = rowcount([F:YPL1])
        Read [F:YPL1] First
        If !fstat Then
          # actualiza el registro en la tabla PPRICLIST
          [F:YPL1]UOM       = [M:YTEP1]PUU(LCON1)                                                   # unidad de compra
          [F:YPL1]MINQTY    = [M:YTEP1]MINQTY(LCON1)                                                # cantidad mínima
          [F:YPL1]MAXQTY    = [M:YTEP1]MAXQTY(LCON1)                                                # cantidad máxima
          [F:YPL1]LTI       = [M:YTEP1]LTI                                                          # plazo
          [F:YPL1]PRI       = [M:YTEP1]PRI(LCON1)                                                   # precio (valor único)
          [F:YPL1]DCGVAL(3) = [M:YTEP1]DCGVAL3(LCON1)                                               # descuento 3
          [F:YPL1]DCGVAL(4) = [M:YTEP1]DCGVAL4(LCON1)                                               # descuento 4
          [F:YPL1]DCGVAL(5) = [M:YTEP1]DCGVAL5(LCON1)                                               # descuento 5
          [F:YPL1]DCGVAL(6) = [M:YTEP1]DCGVAL6(LCON1)                                               # bonificación 2
          Rewrite [F:YPL1]
        Else
          # crea el registro en la tabla PPRICLIST
          [F:YPL1]PLI       = "T20"
          Filter [F:YPF1] Where PLI="T20" and PLICRDIDX=[M:BPS0]BPSNUM and PLISTRDAT=[M:YTEP1]YINIVAL and PLIENDDAT=[M:YTEP1]YFINVAL# and PLICRI2=[F:YIT1]ITMREF
          Read [F:YPF1] First
          If !fstat Then
            [F:YPL1]PLICRD    = [F:YPF1]PLICRD
          Endif
          Filter [F:YPF1]
          Filter [F:YPL4] Where PLI="T20" and PLICRI1=[M:BPS0]BPSNUM and PLISTRDAT=[M:YTEP1]YINIVAL and PLIENDDAT=[M:YTEP1]YFINVAL
&         Order By PLILIN Desc
          Read [F:YPL4] First
          LNUMREG1 = [F:YPL4]PLILIN
          Filter [F:YPL4]
          [F:YPL1]PLILIN    = (LNUMREG1 + 1000)                                                     # número de línea
          [F:YPL1]PLICRI    = [M:BPS0]BPSNUM + "~" + [F:YIT1]ITMREF + "~~~~"
          [F:YPL1]PLICRI1   = [M:BPS0]BPSNUM                                                        # proveedor
          [F:YPL1]PLICRI2   = [F:YIT1]ITMREF                                                        # artículo
          [F:YPL1]PLISTRDAT = [M:YTEP1]YINIVAL                                                      # inicio validez
          [F:YPL1]PLIENDDAT = [M:YTEP1]YFINVAL                                                      # fin validez
          Read [F:YIM1]ITM0 = [F:YIT1]ITMREF
          If !fstat Then
            [F:YPL1]UOM       = [F:YIM1]STU                                                         # unidad
            [F:YPL1]CUR       = "EUR"                                                               # divisa
          Endif
          [F:YPL1]UOM       = [M:YTEP1]PUU(LCON1)                                                   # unidad de compra
          [F:YPL1]MINQTY    = [M:YTEP1]MINQTY(LCON1)                                                # cantidad mínima
          [F:YPL1]MAXQTY    = [M:YTEP1]MAXQTY(LCON1)                                                # cantidad máxima
          [F:YPL1]LTI       = [M:YTEP1]LTI                                                          # plazo
          [F:YPL1]PRI       = [M:YTEP1]PRI(LCON1)                                                   # precio (valor único)
          [F:YPL1]DCGVAL(3) = [M:YTEP1]DCGVAL3(LCON1)                                               # descuento 3
          [F:YPL1]DCGVAL(4) = [M:YTEP1]DCGVAL4(LCON1)                                               # descuento 4
          [F:YPL1]DCGVAL(5) = [M:YTEP1]DCGVAL5(LCON1)                                               # descuento 5
          [F:YPL1]DCGVAL(6) = [M:YTEP1]DCGVAL6(LCON1)                                               # bonificación 2
          Write [F:YPL1]
#          If !fstat Then
#            LNUMREG1 += 1
#          Endif
        Endif
        Filter [F:YPL1]
      Endif
    Else
      # creación de registro en la tabla ITMBPS
      [F:YIT1]ITMREF    = [M:YTEP1]ITMREF(LCON1)                                                    # código de artículo
      [F:YIT1]BPSNUM    = [M:BPS0]BPSNUM                                                            # proveedor
      [F:YPT1]PUU       = [M:YTEP1]PUU(LCON1)                                                       # unidad de compra
      [F:YIT1]ITMDESBPS = [M:YTEP1]ITMDESBPS(LCON1)                                                 # descripción proveedor
      [F:YIT1]ITMREFBPS = [M:YTEP1]ITMREFBPS(LCON1)                                                 # código proveedor
      [F:YIT1]YSECC2    = [M:YTEP1]YSECC(LCON1)                                                     # sección
      [F:YIT1]PIO       = 2                                                                         # prioridad
      Write [F:YIT1]
      If !fstat Then
        # actualización / creación de registro en la tabla PPRICLIST
        Filter [F:YPL1] Where PLI="T20" and PLICRI1=[M:BPS0]BPSNUM and PLICRI2=[F:YIT1]ITMREF and PLISTRDAT=[M:YTEP1]YINIVAL and PLIENDDAT=[M:YTEP1]YFINVAL
&       and MINQTY = [M:YTEP1]MINQTY(LCON1) and MAXQTY = [M:YTEP1]MAXQTY(LCON1)
        Read [F:YPL1] First
        If !fstat Then
          # actualiza el registro en la tabla PPRICLIST
          [F:YPL1]UOM       = [M:YTEP1]PUU(LCON1)                                                   # unidad de compra
          [F:YPL1]MINQTY    = [M:YTEP1]MINQTY(LCON1)                                                # cantidad mínima
          [F:YPL1]MAXQTY    = [M:YTEP1]MAXQTY(LCON1)                                                # cantidad máxima
          [F:YPL1]LTI       = [M:YTEP1]LTI                                                          # plazo
          [F:YPL1]PRI       = [M:YTEP1]PRI(LCON1)                                                   # precio (valor único)
          [F:YPL1]DCGVAL(3) = [M:YTEP1]DCGVAL3(LCON1)                                               # descuento 3
          [F:YPL1]DCGVAL(4) = [M:YTEP1]DCGVAL4(LCON1)                                               # descuento 4
          [F:YPL1]DCGVAL(5) = [M:YTEP1]DCGVAL5(LCON1)                                               # descuento 5
          [F:YPL1]DCGVAL(6) = [M:YTEP1]DCGVAL6(LCON1)                                               # bonificación 2
          Rewrite [F:YPL1]
          Filter [F:YPL1]
        Else
          # crea el registro en la tabla PPRICLIST
#          Filter [F:YPL1] Where PLI="T20" and PLICRI1=[M:BPS0]BPSNUM and PLISTRDAT=[M:YTEP1]YINIVAL and PLIENDDAT=[M:YTEP1]YFINVAL
#          LNUMREG1 = rowcount([F:YPL1])
          [F:YPL1]PLI       = "T20"
          Filter [F:YPF1] Where PLI="T20" and PLICRDIDX=[M:BPS0]BPSNUM and PLISTRDAT=[M:YTEP1]YINIVAL and PLIENDDAT=[M:YTEP1]YFINVAL# and PLICRI2=[F:YIT1]ITMREF
          Read [F:YPF1] First
          If !fstat Then
            [F:YPL1]PLICRD    = [F:YPF1]PLICRD
          Endif
          Filter [F:YPF1]
          Filter [F:YPL4] Where PLI="T20" and PLICRI1=[M:BPS0]BPSNUM and PLISTRDAT=[M:YTEP1]YINIVAL and PLIENDDAT=[M:YTEP1]YFINVAL
&         Order By PLILIN Desc
          Read [F:YPL4] First
          LNUMREG1 = [F:YPL4]PLILIN
          Filter [F:YPL4]
          [F:YPL1]PLILIN    = (LNUMREG1 + 1000)                                                     # número de línea
          [F:YPL1]PLICRI    = [M:BPS0]BPSNUM + "~" + [F:YIT1]ITMREF + "~~~~"
          [F:YPL1]PLICRI1   = [M:BPS0]BPSNUM                                                        # proveedor
          [F:YPL1]PLICRI2   = [F:YIT1]ITMREF                                                        # artículo
          [F:YPL1]PLISTRDAT = [M:YTEP1]YINIVAL                                                      # inicio validez
          [F:YPL1]PLIENDDAT = [M:YTEP1]YFINVAL                                                      # fin validez
          Read [F:YIM1]ITM0 = [F:YIT1]ITMREF
          If !fstat Then
            [F:YPL1]UOM       = [F:YIM1]STU                                                         # unidad
            [F:YPL1]CUR       = "EUR"                                                               # divisa
          Endif
          [F:YPL1]UOM       = [M:YTEP1]PUU(LCON1)                                                   # unidad de compra
          [F:YPL1]MINQTY    = [M:YTEP1]MINQTY(LCON1)                                                # cantidad mínima
          [F:YPL1]MAXQTY    = [M:YTEP1]MAXQTY(LCON1)                                                # cantidad máxim
          [F:YPL1]LTI       = [M:YTEP1]LTI                                                          # plazo
          [F:YPL1]PRI       = [M:YTEP1]PRI(LCON1)                                                   # precio (valor único)
          [F:YPL1]DCGVAL(3) = [M:YTEP1]DCGVAL3(LCON1)                                               # descuento 3
          [F:YPL1]DCGVAL(4) = [M:YTEP1]DCGVAL4(LCON1)                                               # descuento 4
          [F:YPL1]DCGVAL(5) = [M:YTEP1]DCGVAL5(LCON1)                                               # descuento 5
          [F:YPL1]DCGVAL(6) = [M:YTEP1]DCGVAL6(LCON1)                                               # bonificación 2
          Write [F:YPL1]
          Filter [F:YPL1]
#          If !fstat Then
#            LNUMREG1 += 1
#          Endif
        Endif
      Endif
    Endif
  Next
  If clalev([F:YIT1])  Then : Close Local File  [F:YIT1] : Endif
  If clalev([F:YPL1])  Then : Close Local File  [F:YPL1] : Endif
  If clalev([F:YPL4])  Then : Close Local File  [F:YPL4] : Endif
  If clalev([F:YPF1])  Then : Close Local File  [F:YPF1] : Endif
  If clalev([F:YIM1])  Then : Close Local File  [F:YIM1] : Endif

Return

########################################
# IN24
# carga tarifa en la pantalla "Artículos prov."
$CARGA_PPRICLIST
Local Integer LCON3 : Raz LCON3

  If !clalev([F:YPL3]) Then : Local File PPRICLIST  [F:YPL3] : Endif
  For LCON3 = 0 To [M:YTEP1]NBITM-1
    Filter [F:YPL3] Where PLI="T20" and PLICRI1=[M:BPS0]BPSNUM and PLICRI2=[M:YTEP1]ITMREF(LCON3) and PLISTRDAT=[M:YTEP1]YINIVAL and PLIENDDAT=[M:YTEP1]YFINVAL
    Read [F:YPL3] First
    If !fstat Then
      [M:YTEP1]MINQTY(LCON3)  = [F:YPL3]MINQTY                                                # cantidad mínima
      [M:YTEP1]MAXQTY(LCON3)  = [F:YPL3]MAXQTY                                                # cantidad máxima
      [M:YTEP1]PRI(LCON3)     = [F:YPL3]PRI                                                   # precio (valor único)
      [M:YTEP1]DCGVAL3(LCON3) = [F:YPL3]DCGVAL(3)                                             # descuento 3
      [M:YTEP1]DCGVAL4(LCON3) = [F:YPL3]DCGVAL(4)                                             # descuento 4
      [M:YTEP1]DCGVAL5(LCON3) = [F:YPL3]DCGVAL(5)                                             # descuento 5
      [M:YTEP1]DCGVAL6(LCON3) = [F:YPL3]DCGVAL(6)                                             # bonificación 2
      [M:YTEP1]LTI            = [F:YPL3]LTI                                                   # plazo
    Endif
    Filter [F:YPL3]
  Next
  Affzo [M:YTEP1]15
  Affzo [M:YTEP1]LTI
  If clalev([F:YPL3])  Then : Close Local File      [F:YPL3] : Endif

Return

########################################
# IN24
# genera la tarifa en "Artículos prov."
$GENERA_TARIFA_AP
Local Char LCONTPPL(15) : Raz LCONTPPL
Local Integer LCON5    : Raz LCON5

  If [M:YTEP1]YINIVAL <> [000/00/0000] and [M:YTEP1]YFINVAL <> [00/00/0000] Then

    If !clalev([F:YPL5]) Then : Local File PPRICLIST  [F:YPL5] : Endif
    If !clalev([F:YPF5]) Then : Local File PPRICFICH  [F:YPF5] : Endif
    If !clalev([F:YIT5]) Then : Local File ITMMASTER  [F:YIT5] : Endif

    Filter [F:YPF5] Where PLI = "T20" and PLICRDIDX = [M:BPS0]BPSNUM and ((PLISTRDAT <= [M:YTEP1]YINIVAL and PLIENDDAT >= [M:YTEP1]YINIVAL) or
&   (PLISTRDAT <= [M:YTEP1]YFINVAL and PLIENDDAT >= [M:YTEP1]YFINVAL) or (PLISTRDAT >= [M:YTEP1]YINIVAL and PLIENDDAT <= [M:YTEP1]YFINVAL))
    Read [F:YPF5] First
    If !fstat Then
      Call ERREUR("No se puede generar una tarifa nueva porque ya existe"-[F:YPF5]PLICRD-"para:\· Cliente: "-[M:BPS0]BPSNUM+"\· Inicio validez: "-
&     num$([F:YPF5]PLISTRDAT)+"\· Fin validez: "-num$([F:YPF5]PLIENDDAT)) From GESECRAN
    Else

      #obtiene el siguiente número de contador para PPL
      Call GENNUMBER("PPL",[M:YTEP1]YINIVAL,LCONTPPL) From YAITLIB

      # crea registros en la tabla PPRICLIST
      For LCON5 = 0 To [M:YTEP1]NBITM - 1
        Trbegin [F:YPL5]
        [F:YPL5]PLI       = "T20"
        [F:YPL5]PLICRD    = LCONTPPL                                                              # número registro tarifa
        [F:YPL5]PLILIN    = (LCON5 + 1) * 1000                                                    # número línea
        [F:YPL5]PLICRI    = [M:BPS0]BPSNUM + "~" + [M:YTEP1]ITMREF(LCON5) + "~~~~"
        [F:YPL5]PLICRI1   = [M:BPS0]BPSNUM                                                        # proveedor
        [F:YPL5]PLICRI2   = [M:YTEP1]ITMREF(LCON5)                                                # artículo
        [F:YPL5]PLISTRDAT = [M:YTEP1]YINIVAL                                                      # inicio validez
        [F:YPL5]PLIENDDAT = [M:YTEP1]YFINVAL                                                      # fin validez
        Read [F:YIT5]ITM0 = [M:YTEP1]ITMREF(LCON5)
        If !fstat Then
          [F:YPL5]UOM       = [F:YIT5]STU                                                         # unidad stock
          [F:YPL5]CUR       = "EUR"                                                               # divisa
        Endif
        [F:YPL5]MINQTY    = [M:YTEP1]MINQTY(LCON5)                                                # cantidad mínima
        [F:YPL5]MAXQTY    = [M:YTEP1]MAXQTY(LCON5)                                                # cantidad máxima
        [F:YPL5]PRI       = [M:YTEP1]PRI(LCON5)                                                   # precio (valor único)
        [F:YPL5]DCGVAL(3) = [M:YTEP1]DCGVAL3(LCON5)                                               # descuento 3
        [F:YPL5]DCGVAL(4) = [M:YTEP1]DCGVAL4(LCON5)                                               # descuento 4
        [F:YPL5]DCGVAL(5) = [M:YTEP1]DCGVAL5(LCON5)                                               # descuento 5
        [F:YPL5]DCGVAL(6) = [M:YTEP1]DCGVAL6(LCON5)                                               # bonificación 2
        [F:YPL5]LTI       = [M:YTEP1]LTI                                                          # plazo
        Write [F:YPL5]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
      Next

      # crea registro en la tabla PPRICFICH
      Trbegin [F:YPF5]
      [F:YPF5]PLI         = "T20"
      [F:YPF5]PLICRD      = LCONTPPL                                                              # número registro tarifa
      [F:YPF5]PLICRDIDX   = [M:BPS0]BPSNUM                                                        # proveedor
      [F:YPF5]PLISTRDAT   = [M:YTEP1]YINIVAL                                                      # inicio validez
      [F:YPF5]PLIENDDAT   = [M:YTEP1]YFINVAL                                                      # fin validez
      [F:YPF5]LINNBR      = LCON5                                                                 # número total de líneas
      Write [F:YPF5]
      If !fstat Then
        Call MESSAGE("Se ha generado el registro de tarifa: "-LCONTPPL) From GESECRAN
        Commit
      Else
        Rollback
      Endif
    Endif

    If clalev([F:YPL5])  Then : Close Local File      [F:YPL5] : Endif
    If clalev([F:YPF5])  Then : Close Local File      [F:YPF5] : Endif
    If clalev([F:YIT5])  Then : Close Local File      [F:YIT5] : Endif
  Else
    Call ERREUR("Para generar una tarifa se tienen que indicar previamente las fechas de validez") From GESECRAN
  Endif

Return

########################################
# IN24
# registra las modificaciones de la pantalla "Sección prov."
$REGISTRAR_SECBPS
Local Integer LCON02 : Raz LCON02

  # actualización de registros en la tabla PPRICLIST
  If !clalev([F:YPL2]) Then : Local File PPRICLIST  [F:YPL2] : Endif
  Delete [F:YPL2] Where PLI = "T30" and PLICRD = GNUMREGTAR
  For LCON02 = 0 To [M:YTEP2]NBSECC-1
    [F:YPL2]PLI       = "T30"
    [F:YPL2]PLICRD    = GNUMREGTAR
    [F:YPL2]PLILIN    = (LCON02 + 1) * 1000
    [F:YPL2]PLICRI    = [M:BPS0]BPSNUM + "~" + [M:YTEP2]YSECC(LCON02) + "~~~~"
    [F:YPL2]PLICRI1   = [M:BPS0]BPSNUM
    [F:YPL2]PLICRI2   = [M:YTEP2]YSECC(LCON02)
    [F:YPL2]PLISTRDAT = [M:YTEP2]YINIVAL
    [F:YPL2]PLIENDDAT = [M:YTEP2]YFINVAL
    [F:YPL2]DCGVAL(0) = [M:YTEP2]DCGVAL1(LCON02)
    [F:YPL2]DCGVAL(1) = [M:YTEP2]DCGVAL2(LCON02)
    [F:YPL2]UOM       = "UN"
    [F:YPL2]CUR       = "EUR"
    Write [F:YPL2]
  Next
  If clalev([F:YPL2])  Then : Close Local File      [F:YPL2] : Endif

  # actualización del registro en la tabla PPRICFICH
  If !clalev([F:YPF02]) Then : Local File PPRICFICH [F:YPF02] : Endif
  Read [F:YPF02]PPF0 = "T30";GNUMREGTAR
  If !fstat Then
    [F:YPF02]LINNBR     = LCON02
    [F:YPF02]PLISTRDAT  = [M:YTEP2]YINIVAL
    [F:YPF02]PLIENDDAT  = [M:YTEP2]YFINVAL
    Rewrite [F:YPF02]
  Endif
  If clalev([F:YPF02])  Then : Close Local File      [F:YPF02] : Endif

Return

########################################
# IN24
# carga los registros en la pantall "Sección prov."
$CARGA_SECBPS
Local Integer LCON6 : Raz LCON6

  If !clalev([F:YPL6]) Then : Local File PPRICLIST  [F:YPL6] : Endif
  If !clalev([F:YPF6]) Then : Local File PPRICFICH  [F:YPF6] : Endif

  Filter [F:YPF6] Where PLI="T30"  and PLICRDIDX = [M:BPS0]BPSNUM and PLISTRDAT = [M:YTEP2]YINIVAL and PLIENDDAT = [M:YTEP2]YFINVAL
  Read [F:YPF6] First
  If !fstat Then
    GNUMREGTAR = [F:YPF6]PLICRD
  Endif
  Filter [F:YPF6]

  Filter [F:YPL6] Where PLI="T30" and PLICRD = GNUMREGTAR
  For [F:YPL6]
    [M:YTEP2]YSECC(LCON6)    = [F:YPL6]PLICRI2
    [M:YTEP2]DCGVAL1(LCON6)  = [F:YPL6]DCGVAL(0)
    [M:YTEP2]DCGVAL2(LCON6)  = [F:YPL6]DCGVAL(1)
    LCON6 += 1
  Next

  [M:YTEP2]NBSECC = LCON6
  Affzo [M:YTEP2]10

  If clalev([F:YPL6])  Then : Close Local File      [F:YPL6] : Endif
  If clalev([F:YPF6])  Then : Close Local File      [F:YPF6] : Endif
Return

########################################
# IN24
# genera la tarifa de "Sección prov."
$GENERA_TARIFA_SP
Local Integer LCON7 : Raz LCON7
Local Char LCONTPPL7(15) : Raz LCONTPPL7

  If [M:YTEP2]YINIVAL <> [000/00/0000] and [M:YTEP2]YFINVAL <> [00/00/0000] Then
    If !clalev([F:YPL7]) Then : Local File PPRICLIST  [F:YPL7] : Endif
    If !clalev([F:YPF7]) Then : Local File PPRICFICH  [F:YPF7] : Endif

    Filter [F:YPF7] Where PLI = "T30" and PLICRDIDX = [M:BPS0]BPSNUM and ((PLISTRDAT <= [M:YTEP2]YINIVAL and PLIENDDAT >= [M:YTEP2]YINIVAL) or
&   (PLISTRDAT <= [M:YTEP2]YFINVAL and PLIENDDAT >= [M:YTEP2]YFINVAL) or (PLISTRDAT >= [M:YTEP2]YINIVAL and PLIENDDAT <= [M:YTEP2]YFINVAL))
    Read [F:YPF7] First
    If !fstat Then
      Call ERREUR("No se puede generar una tarifa nueva porque ya existe"-[F:YPF7]PLICRD-"para:\· Cliente: "-[M:BPS0]BPSNUM+"\· Inicio validez: "-
&     num$([F:YPF7]PLISTRDAT)+"\· Fin validez: "-num$([F:YPF7]PLIENDDAT)) From GESECRAN
    Else

      #obtiene el siguiente número de contador para PPL
      Call GENNUMBER("PPL",[M:YTEP2]YINIVAL,LCONTPPL7) From YAITLIB

      # crea registros en la tabla PPRICLIST
      For LCON7 = 0 To [M:YTEP2]NBSECC - 1
        Trbegin [F:YPL7]
        [F:YPL7]PLI       = "T30"
        [F:YPL7]PLICRD    = LCONTPPL7
        [F:YPL7]PLILIN    = (LCON7 + 1) * 1000
        [F:YPL7]PLICRI    = [M:BPS0]BPSNUM + "~" + [M:YTEP2]YSECC(LCON7) + "~~~~"
        [F:YPL7]PLICRI1   = [M:BPS0]BPSNUM
        [F:YPL7]PLISTRDAT = [M:YTEP2]YINIVAL
        [F:YPL7]PLIENDDAT = [M:YTEP2]YFINVAL
        [F:YPL7]DCGVAL(0) = [M:YTEP2]DCGVAL1(LCON7)
        [F:YPL7]DCGVAL(1) = [M:YTEP2]DCGVAL2(LCON7)
        Write [F:YPL7]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
      Next

      # actualización del registro en la tabla PPRICFICH
      Trbegin [F:YPF7]
      [F:YPF7]PLI       = "T30"
      [F:YPF7]PLICRD    = LCONTPPL7
      [F:YPF7]PLICRDIDX = [M:BPS0]BPSNUM
      [F:YPF7]PLISTRDAT = [M:YTEP2]YINIVAL
      [F:YPF7]PLIENDDAT = [M:YTEP2]YFINVAL
      [F:YPF7]LINNBR    = LCON7
      Write [F:YPF7]
      If !fstat Then
        Call MESSAGE("Se ha generado el registro de tarifa: "-LCONTPPL7) From GESECRAN
        Commit
      Else
        Rollback
      Endif

    Endif

    If clalev([F:YPL7])  Then : Close Local File      [F:YPL7] : Endif
    If clalev([F:YPF7])  Then : Close Local File      [F:YPF7] : Endif
  Else
    Call ERREUR("Para generar una tarifa se tienen que indicar previamente las fechas de validez") From GESECRAN
  Endif

Return

########################################
# IN24
# carga los registro en la pantalla "Costes rep."
$CARGA_COSTESREP
Local Integer LCON8 : Raz LCON8
Local Char LSEC8(10)
Local Decimal LPRI, LDESC1, LDESC2, LDESC3, LDESC4, LDESC5, LBONIF2

  If !clalev([F:YPL8]) Then : Local File PPRICLIST  [F:YPL8] : Endif
  If !clalev([F:YPL9]) Then : Local File PPRICLIST  [F:YPL9] : Endif
  If !clalev([F:YIT8]) Then : Local File ITMBPS     [F:YIT8] : Endif
  Filter [F:YPL8] Where PLI = "T20" and PLICRD = [M:YTEP3]YTARBPSITM
  For [YPL8]
    [M:YTEP3]ITMREF(LCON8)    = [F:YPL8]PLICRI2                                                   # código de artículo
    [M:YTEP3]PRI(LCON8)       = [F:YPL8]PRI                                                       # precio (valor unitario)
    LPRI                      = [F:YPL8]PRI
    Read [F:YIT8]ITP0 = [F:YPL8]PLICRI2;[F:YPL8]PLICRI1
    If !fstat Then
      LSEC8 = [F:YIT8]YSECC2                                                                      # sección (para buscar en tarifa T30)
    Endif
    Filter [F:YPL9] Where PLI = "T30" and PLICRD = [M:YTEP3]YTARBPSSEC and PLICRI2 = LSEC8
    Read [F:YPL9] First
    If !fstat Then
      [M:YTEP3]DCGVAL1(LCON8)   = [F:YPL9]DCGVAL(0)                                               # descuento 1 (tarifa T30)
      [M:YTEP3]DCGVAL2(LCON8)   = [F:YPL9]DCGVAL(1)                                               # descuento 2 (tarifa T30)
      LDESC1                    = [F:YPL9]DCGVAL(0)
      LDESC2                    = [F:YPL9]DCGVAL(1)
    Endif
    Filter [F:YPL9]
    [M:YTEP3]DCGVAL3(LCON8)   = [F:YPL8]DCGVAL(3)                                                 # descuento 3 (tarifa T20)
    [M:YTEP3]DCGVAL4(LCON8)   = [F:YPL8]DCGVAL(4)                                                 # descuento 4 (tarifa T20)
    [M:YTEP3]DCGVAL5(LCON8)   = [F:YPL8]DCGVAL(5)                                                 # descuento 5 (tarifa T20)
    [M:YTEP3]DCGVAL6(LCON8)   = [F:YPL8]DCGVAL(6)                                                 # bonificación 2 (tarifa T20)
    LDESC3                    = [F:YPL8]DCGVAL(3)
    LDESC4                    = [F:YPL8]DCGVAL(4)
    LDESC5                    = [F:YPL8]DCGVAL(5)
    LBONIF2                   = [F:YPL8]DCGVAL(6)
    If LDESC1 <> 0 Then
      LPRI = (LPRI * (1-(LDESC1/100)))
    Endif
    If LDESC2 <> 0 Then
      LPRI = (LPRI * (1-(LDESC2/100)))
    Endif
    If LDESC3 <> 0 Then
      LPRI = (LPRI * (1-(LDESC3/100)))
    Endif
    If LDESC4 <> 0 Then
      LPRI = (LPRI * (1-(LDESC4/100)))
    Endif
    If LDESC5 <> 0 Then
      LPRI = (LPRI * (1-(LDESC5/100)))
    Endif
    If LBONIF2 <> 0 Then
      LPRI = (LPRI - LBONIF2)
    Endif
    [M:YTEP3]YPRI(LCON8)      = ar2(LPRI)                                                              # precio de reposición (precio - descuentos - bonificación)
    LCON8 += 1
  Next
  Filter [F:YPL8]
  [M:YTEP3]NBCDR = LCON8

  If clalev([F:YPL8])  Then : Close Local File      [F:YPL8] : Endif
  If clalev([F:YPL9])  Then : Close Local File      [F:YPL9] : Endif
  If clalev([F:YIT8])  Then : Close Local File      [F:YIT8] : Endif

Return

########################################
# IN24
# carga los registro en la pantalla "Comparativa"
$CARGA_COMPARA
Local Integer LCON06 : Raz LCON06
Local Char    LCRIT06(250)(0..11)

  # consulta que extrae el código de los artículos coindidentes en las dos tarifas + los que están en la tarifa 1 y no están en la 2
  # + los que están en la tarifa 2 y no están en la 1
  LCRIT06(0) = "SELECT ITMREF1.PLICRI2_0 AS PLICRI2 "
  LCRIT06(1) = "FROM ((SELECT * "
  LCRIT06(2) = "FROM "+nomap+".PPRICLIST "
  LCRIT06(3) = "WHERE PLI_0 = 'T20' and PLICRD_0 = '"+[M:YTEP4]YTARBPSITM1+"' "
  LCRIT06(4) = " )UNION( "
  LCRIT06(5) = "SELECT * "
  LCRIT06(6) = "FROM "+nomap+".PPRICLIST "
  LCRIT06(7) = "WHERE PLI_0 = 'T20' and PLICRD_0 = '"+[M:YTEP4]YTARBPSITM2+"' "
  LCRIT06(8) = ")) AS ITMREF1 "
  LCRIT06(9) = "GROUP By ITMREF1.PLICRI2_0 "
  LCRIT06(10) = "ORDER BY ITMREF1.PLICRI2_0"

  For (Char PLICRI2) From "5" Sql LCRIT06(0..11) As [YC06]
    [M:YTEP4]ITMREF(LCON06)   = [F:YC06]PLICRI2
    Call GET_PRIREP([M:YTEP4]YTARBPSITM1,[M:YTEP4]YTARBPSSEC1,[F:YC06]PLICRI2,[M:BPS0]BPSNUM,[M:YTEP4]YPRI(LCON06))
    Call GET_PRIREP([M:YTEP4]YTARBPSITM2,[M:YTEP4]YTARBPSSEC2,[F:YC06]PLICRI2,[M:BPS0]BPSNUM,[M:YTEP4]YPRIUPD(LCON06))
    [M:YTEP4]YDIFC(LCON06)    = [M:YTEP4]YPRIUPD(LCON06) - [M:YTEP4]YPRI(LCON06)
    If [M:YTEP4]YPRI(LCON06) <> 0 Then
      [M:YTEP4]YPOR(LCON06)     = (([M:YTEP4]YPRIUPD(LCON06)-[M:YTEP4]YPRI(LCON06)) / [M:YTEP4]YPRI(LCON06))*100
    Else
      If ([M:YTEP4]YPRIUPD(LCON06)-[M:YTEP4]YPRI(LCON06)) = 0 Then
        [M:YTEP4]YPOR(LCON06) = 0
      Else
        [M:YTEP4]YPOR(LCON06) = 100
      Endif
    Endif
    LCON06 += 1
  Next
  [M:YTEP4]NBCOM = LCON06

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Click "Filtrar" en pestaña "Artículos proveedor"
######################################################################################
# IN24
Subprog CL_YICOFILTRO1(VALEUR)
Variable Char    VALEUR()

Local Integer LCON2, LNUMREG2 : Raz LCON2, LNUMREG2
Local Char    LCRIT2(250)

  Effzo [M:YTEP1]15

  LCRIT2 = "BPSNUM = [M:BPS0]BPSNUM"
  If [M:YTEP1]FILITMREF     <> "" Then : LCRIT2 -= " and ITMREF = [M:YTEP1]FILITMREF"       : Endif
  If [M:YTEP1]FILITMREFBPS  <> "" Then : LCRIT2 -= " and ITMREFBPS = [M:YTEP1]FILITMREFBPS" : Endif
  If [M:YTEP1]CCE           <> "" Then : LCRIT2 -= " and YSECC2 = [M:YTEP1]CCE"             : Endif

  If !clalev([F:YIT2]) Then : Local File ITMBPS     [F:YIT2] : Endif
  Filter [F:YIT2] Where evalue(LCRIT2)
  LNUMREG2 = rowcount([F:YIT2])
  Read [F:YIT2] First
  If !fstat Then
    For LCON2 = 0 To LNUMREG2-1                                                                     # busca datos en artículos
      [M:YTEP1]ITMREF(LCON2)    = [F:YIT2]ITMREF                                                    # código artículo
      [M:YTEP1]ITMDESBPS(LCON2) = [F:YIT2]ITMDESBPS                                                 # descripción proveedor
      [M:YTEP1]ITMREFBPS(LCON2) = [F:YIT2]ITMREFBPS                                                 # referencia proveedor
      [M:YTEP1]YSECC(LCON2)     = [F:YIT2]YSECC2                                                    # sección
      [M:YTEP1]PIO(LCON2)       = [F:YIT2]PIO                                                       # prioridad (invisible)
      Read[F:YIT2] Next
    Next
    [M:YTEP1]NBITM = LNUMREG2
    Affzo [M:YTEP1]15
  Endif
  Filter [F:YIT2]
  If clalev([F:YIT2])  Then : Close Local File  [F:YIT2] : Endif

End

######################################################################################
## Click "Cargar datos" en pestaña "Sección proveedor"
######################################################################################
# IN24
Subprog CL_YICOFILTRO2(VALEUR)
Variable Char    VALEUR()
  Gosub CARGA_SECBPS
End

######################################################################################
## Click "Cargar datos" en pestaña "Costes de reposición"
######################################################################################
# IN24
Subprog CL_YICOFILTRO3(VALEUR)
Variable Char    VALEUR()
  Gosub CARGA_COSTESREP
  Affzo [M:YTEP3]10
End

######################################################################################
## Click "Cargar datos" en pestaña "Comparativa"
######################################################################################
# IN24
Subprog CL_YICOFILTRO4(VALEUR)
Variable Char    VALEUR()
  Gosub CARGA_COMPARA
  Affzo [M:YTEP4]20
End

######################################################################################
## Control para que no se repita ningún valor en el campo "Sección"
######################################################################################
# IN24
Subprog C_YSECC(VALEUR)
Variable Char    VALEUR()
  Call UNICITE(VALEUR,[M:YTEP2]YSECC(0..[M:YTEP2]NBSECC-1)) From OBJDIV
  If mkstat = 2 Then
    VALEUR = ""
  Endif
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
#######################
# IN24
#**
#* obtiene el precio de reposición de un artículo
#*
#* @param PREGTART20  > código del registro tarifa en T20
#* @param PREGTART30  > código del registro tarifa en T30
#* @param PITMREF     > código de artículo
#* @param PITMBPS     > código del proveedor
#* @param PPRIREP     > devuelve el precio de reposición
#*!
Subprog GET_PRIREP(PREGTART20, PREGTART30, PITMREF, PITMBPS, PPRIREP)
Value     Char    PREGTART20, PREGTART30, PITMREF, PITMBPS
Variable  Decimal PPRIREP

Local Decimal LPRI, LDESC1, LDESC2, LDESC3, LDESC4, LDESC5, LBONIF2 : Raz LPRI, LDESC1, LDESC2, LDESC3, LDESC4, LDESC5, LBONIF2
Local Integer LCON3 : Raz LCON3
Local Char    LSECC(10)

  # obtener la Sección del artículo
  If !clalev([F:YP04]) Then : Local File ITMBPS    [F:YP04] : Endif
  Read [F:YP04]ITP0 = PITMREF;PITMBPS
  If !fstat Then
    LSECC = [F:YP04]YSECC2
  Endif
  If clalev([F:YP04])  Then : Close Local File     [F:YP04] : Endif

  # obtener los descuentos de la tarifa T20
  If !clalev([F:YL04]) Then : Local File PPRICLIST [F:YL04] : Endif
  Filter [F:YL04] Where PLI = "T20" and PLICRD = PREGTART20 and PLICRI1 = PITMBPS and PLICRI2 = PITMREF
  Read [F:YL04] First
  If !fstat Then
    LPRI    = [F:YL04]PRI
    LDESC3  = [F:YL04]DCGVAL(3)
    LDESC4  = [F:YL04]DCGVAL(4)
    LDESC5  = [F:YL04]DCGVAL(5)
    LBONIF2 = [F:YL04]DCGVAL(6)
  Endif
  Filter [F:YL04]
  If clalev([F:YL04])  Then : Close Local File [F:YL04]     : Endif

  # obtener los descuentos de la tarifa T30
  If !clalev([F:YL05]) Then : Local File PPRICLIST [F:YL05] : Endif
  Filter [F:YL05] Where PLI = "T30" and PLICRD = PREGTART30 and PLICRI1 = PITMBPS and PLICRI2 = LSECC
  Read [F:YL05] First
  If !fstat Then
    LDESC1  = [F:YL05]DCGVAL(0)
    LDESC2  = [F:YL05]DCGVAL(1)
  Endif
  Filter [F:YL05]
  If clalev([F:YL05])  Then : Close Local File [F:YL05]     : Endif

  # calcular el precio de reposición
  If LDESC1 <> 0 Then
    LPRI = ar2(LPRI * (1-(LDESC1/100)))
  Endif
  If LDESC2 <> 0 Then
    LPRI = ar2(LPRI * (1-(LDESC2/100)))
  Endif
  If LDESC3 <> 0 Then
    LPRI = ar2(LPRI * (1-(LDESC3/100)))
  Endif
  If LDESC4 <> 0 Then
    LPRI = ar2(LPRI * (1-(LDESC4/100)))
  Endif
  If LDESC5 <> 0 Then
    LPRI = ar2(LPRI * (1-(LDESC5/100)))
  Endif
  If LBONIF2 <> 0 Then
    LPRI = ar2(LPRI - LBONIF2)
  Endif
  PPRIREP = LPRI                                                              # precio de reposición (precio - descuentos - bonificación)

End

