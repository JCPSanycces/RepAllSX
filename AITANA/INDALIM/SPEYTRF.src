######################################################################################



######################################################################################
## Al entrar en el campo "Condiciones tafifa origen"
######################################################################################
Subprog AS_YTAROCOND(VALEUR)
Variable Char    VALEUR()
Local Integer LCONT : Raz LCONT

  Effzo [M:YTRF1]5

  # carga en el grid todos los artículos de la tarifa origen desde la tabla SPRICLIST
  If !clalev([F:YITM]) Then : Local File  ITMMASTER [F:YITM] : Endif
  If !clalev([F:YSPL]) Then : Local File  SPRICLIST [F:YSPL] : Endif
  Filter [F:YSPL] Where PLI = "T20" and PLICRI1 = [M:YTRF0]YTARORI and PLISTRDAT = [M:YTRF0]YTARODATINI and PLIENDDAT = [M:YTRF0]YTARODATFIN
  For [YSPL]
    Filter [F:YITM] Where ITMREF = [F:YSPL]PLICRI2
    Read [F:YITM] First
    If !fstat Then
      [M:YTRF1]YFAMC(LCONT)    = [F:YITM]TSICOD(0)
      [M:YTRF1]YSUBC(LCONT)    = [F:YITM]TSICOD(1)
      [M:YTRF1]YGAMC(LCONT)    = [F:YITM]TSICOD(2)
      [M:YTRF1]YARTC(LCONT)    = [F:YITM]ITMREF
      [M:YTRF1]YDESC(LCONT)    = [F:YITM]ITMDES1
      [M:YTRF1]YBASC(LCONT)    = [F:YSPL]PRI
      [M:YTRF1]YTIPC(LCONT)    = 1
      Filter [F:YITM]
      LCONT += 1
    Endif
  Next
  [M:YTRF1]NBLIG = LCONT
  [M:YTRF0]YTAROCOND = [M:YTRF0]YTARORI

  Affzo [M:YTRF0]5
  Affzo [M:YTRF1]10

  Filter [F:YSPL]
  If clalev([F:YITM]) Then : Close Local File [F:YITM] : Endif
  If clalev([F:YSPL]) Then : Close Local File [F:YSPL] : Endif

  # añade todos los artículos de la nueva tarifa en la tabla SPRICLIST
  Call TEMPON("Guardando la tarifa " + num$([M:YTRF0]YTARCOD)) From GESECRAN
  Gosub CREAR_TARIFA
  Call TEMPOFF() From GESECRAN
End
######################################################################################


######################################################################################
## Al entrar en el campo "Código condiciones"
## Carga o crea la tarifa en función de si existe o no en la tabla varia 413
######################################################################################
Subprog AS_YCDGCOND(VALEUR)
Variable Char    VALEUR()
Local Integer LCONT  : Raz LCONT
Local Integer LCONT2 : Raz LCONT2

If [M:YTRF1]NBLIG = 0 Then
  If !clalev([F:YITM]) Then : Local File ITMMASTER [F:YITM] : Endif
  If !clalev([F:YADI]) Then : Local File ATABDIV   [F:YADI] : Endif
  Filter [F:YADI] Where NUMTAB = 413 and CODE = [M:YTRF0]YTARCOD
  Read [F:YADI] First
  If !fstat Then                                                                        # si la tarifa ya existe la carga en el grid
    [M:YTRF0]YCDGCOND = [M:YTRF0]YTARCOD

    If !clalev([F:YSPF]) Then : Local File SPRICFICH [F:YSPF] : Endif
    Filter [F:YSPF] Where PLI = "T20" and YTARCOD = [M:YTRF0]YTARCOD and PLISTRDAT = [M:YTRF0]YTARDATINI and PLIENDDAT = [M:YTRF0]YTARDATFIN
    Read [F:YSPF] First
    If !fstat Then
      [M:YTRF0]YTARORI      = [F:YSPF]YTARORI
      [M:YTRF0]YTARODATINI  = [F:YSPF]YTARINI
      [M:YTRF0]YTARODATFIN  = [F:YSPF]YTARFIN
      [M:YTRF0]YTAROBS      = [F:YSPF]YTAROBS
    Endif
    Filter [F:YSPF]
    If clalev([F:YSPF])  Then : Close Local File [F:YSPF] : Endif

    If !clalev([F:YSPL]) Then : Local File SPRICLIST [F:YSPL] : Endif
    Filter [F:YSPL] Where PLI = "T20" and PLICRI1 = [M:YTRF0]YTARCOD and PLISTRDAT >= [M:YTRF0]YTARDATINI and PLIENDDAT <= [M:YTRF0]YTARDATFIN   # filtrar para la tarifa T20, código de tarifa y fecha
# validez
    Read [F:YSPL] First
    If !fstat Then
      For [YSPL]
        Filter [F:YITM] Where ITMREF = [F:YSPL]PLICRI2
        Read [F:YITM] First
        If !fstat Then
          [M:YTRF1]YFAMC(LCONT)  = [F:YITM]TSICOD(0)
          [M:YTRF1]YSUBC(LCONT)  = [F:YITM]TSICOD(1)
          [M:YTRF1]YGAMC(LCONT)  = [F:YITM]TSICOD(2)
          [M:YTRF1]YARTC(LCONT)  = [F:YSPL]PLICRI2
          [M:YTRF1]YDESC(LCONT)  = [F:YITM]ITMDES1
          [M:YTRF1]YBASC(LCONT)  = [F:YSPL]YPRIBASE
          [M:YTRF1]YTIPC(LCONT)  = [F:YSPL]YTIPOMRG
          [M:YTRF1]YMARC(LCONT)  = [F:YSPL]YPORMRG
          [M:YTRF1]YPREC(LCONT)  = [F:YSPL]PRI
          [M:YTRF1]YSELEC(LCONT) = [F:YSPL]YMODIFLG
          LCONT += 1
        Endif
        Filter [F:YITM]
      Next
      [M:YTRF1]NBLIG = LCONT
      Filter [F:YSPL]

      Affzo  [M:YTRF0]
      Affzo  [M:YTRF1]10
      Affzo  [M:YTRF2]
    Endif
  Else                                                                                   # si no existe se crea en la tabla varia
    If !clalev([F:YADI2]) Then : Local File ATABDIV   [F:YADI2] : Endif                  # crea el código de la tarifa en la tabla varia 413
    [F:YADI2]NUMTAB  = 413
    [F:YADI2]CODE    = [M:YTRF0]YTARCOD
    [F:YADI2]DEFVAL  = 1
    [F:YADI2]ENAFLG  = 1
    [F:YADI2]UPDDAT  = datesyst
    [F:YADI2]CREDAT  = datesyst
    Write [F:YADI2]
    If clalev([F:YADI2])  Then : Close Local File [F:YADI2] : Endif
    Actzo [M:YTRF0]YTARBASE, YTARORI
  Endif

  Affzo [M:YTRF0]
  Affzo [M:YTRF1]
  Affzo [M:YTRF2]

  Filter [F:YADI]
  If clalev([F:YADI])  Then : Close Local File [F:YADI] : Endif
  If clalev([F:YITM])  Then : Close Local File [F:YITM] : Endif
Endif

End


######################################################################################

######################################################################################
## Al modificar el campo "Código condiciones"
## rellena la pestaña de condiciones
######################################################################################
Subprog AM_YCDGCOND(VALEUR)
Variable Char    VALEUR()
Local Integer LCON : Raz LCON

  If !clalev([F:YCON]) Then : Local File YCONDICIONES [F:YCON] : Endif
  If !clalev([F:YCFA]) Then : Local File YCONDFAM     [F:YCFA] : Endif
  If !clalev([F:YCSF]) Then : Local File YCONDSUB     [F:YCSF] : Endif
  If !clalev([F:YCGM]) Then : Local File YCONDGAM     [F:YCGM] : Endif
  If !clalev([F:YCPR]) Then : Local File YCONDPRO     [F:YCPR] : Endif

  GCC = [M:YTRF0]YGCC
  GFI = [M:YTRF0]YGFI
  GFF = [M:YTRF0]YGFF
  If GCC = ""            Then : GCC = [M:YTRF0]YTARCOD    : Endif
  If GFI = [00/00/00000] Then : GFI = [M:YTRF0]YTARDATINI : Endif
  If GFF = [000/00/0000] Then : GFF = [M:YTRF0]YTARDATFIN : Endif
  # busca en la tabla YCONDICIONES la condición seleccionada
  Filter [F:YCON] Where YCDGCOND  = VALEUR and YFECHAINI  = GFI and YFECHAFIN  = GFF
  Read [F:YCON] First
  If !fstat Then
    [M:YTRF2]YCDGCOND   = GCC
    [M:YTRF2]YFECHAINI  = GFI
    [M:YTRF2]YFECHAFIN  = GFF
    [M:YTRF0]YPORMARGEN = [F:YCON]YPORMRG
  Endif

  Filter [F:YCFA] Where YCDGCOND1 = VALEUR and YFECHAINI1 = GFI and YFECHAFIN1 = GFF    # busca en la tabla YCONDFAM la condición seleccionada
  Filter [F:YCSF] Where YCDGCOND2 = VALEUR and YFECHAINI2 = GFI and YFECHAFIN2 = GFF    # busca en la tabla YCONDSUB la condición seleccionada
  Filter [F:YCGM] Where YCDGCOND3 = VALEUR and YFECHAINI3 = GFI and YFECHAFIN3 = GFF    # busca en la tabla YCONDGAM la condición seleccionada
  Filter [F:YCPR] Where YCDGCOND4 = VALEUR and YFECHAINI4 = GFI and YFECHAFIN4 = GFF    # busca en la tabla YCONDPRO la condición seleccionada

  # escribe en pantalla todas las condiciones de Familia
  For [YCFA]
    [M:YTRF2]YCODFAM1(LCON)   = [F:YCFA]YCODFAM1
    [M:YTRF2]YTIPOMRG1(LCON)  = [F:YCFA]YTIPOMRG1
    [M:YTRF2]YPORMRG1(LCON)   = [F:YCFA]YPORMRG1
    LCON += 1
  Next
  [M:YTRF2]NBLIG = LCON
  Raz LCON

  # escribe en pantalla todas las condiciones de Familia/Subfamilia
  For [YCSF]
    [M:YTRF2]YCODFAM2(LCON)   = [F:YCSF]YCODFAM2
    [M:YTRF2]YCODSUB2(LCON)   = [F:YCSF]YCODSUB2
    [M:YTRF2]YTIPOMRGS2(LCON) = [F:YCSF]YTIPOMRGS2
    [M:YTRF2]YPORMRGS2(LCON)  = [F:YCSF]YPORMRGS2
    LCON += 1
  Next
  [M:YTRF2]NBLIG2 = LCON
  Raz LCON

  # escribe en pantalla todas las condiciones de Familia/Subfamilia/Gama
  For [YCGM]
    [M:YTRF2]YCODFAM3(LCON)   = [F:YCGM]YCODFAM3
    [M:YTRF2]YCODSUB3(LCON)   = [F:YCGM]YCODSUB3
    [M:YTRF2]YCODGAM3(LCON)   = [F:YCGM]YCODGAM3
    [M:YTRF2]YTIPOMRGG3(LCON) = [F:YCGM]YTIPOMRGG3
    [M:YTRF2]YPORMRGG3(LCON)  = [F:YCGM]YPORMRGG3
    LCON += 1
  Next
  [M:YTRF2]NBLIG3 = LCON
  Raz LCON

  # escribe en pantalla todas las condiciones de Proveedor
  For [YCPR]
    [M:YTRF2]BPSNUM(LCON)     = [F:YCPR]BPSNUM
    [M:YTRF2]YTIPOMRG4(LCON)  = [F:YCPR]YTIPOMRG4
    [M:YTRF2]YPORMRG4(LCON)   = [F:YCPR]YPORMRG4
    LCON += 1
  Next
  [M:YTRF2]NBLIG4 = LCON
  Raz LCON

  Affzo [M:YTRF0]
  Affzo [M:YTRF1]
  Affzo [M:YTRF2]

  Filter [F:YCON]
  Filter [F:YCFA]
  Filter [F:YCSF]
  Filter [F:YCGM]
  Filter [F:YCPR]

  If clalev([F:YCON]) Then : Close Local File [F:YCON] : Endif
  If clalev([F:YCFA]) Then : Close Local File [F:YCFA] : Endif
  If clalev([F:YCSF]) Then : Close Local File [F:YCSF] : Endif
  If clalev([F:YCGM]) Then : Close Local File [F:YCGM] : Endif
  If clalev([F:YCPR]) Then : Close Local File [F:YCPR] : Endif

End


######################################################################################

######################################################################################
## Al salir del campo "Condiciones tarifa origen"
######################################################################################
Subprog AP_YTAROCOND(VALEUR)
Variable Char    VALEUR()
  Diszo [M:YTRF0]YTARORI, YTARODATINI, YTARODATFIN, YTAROCOND
End


######################################################################################

######################################################################################
## Al entrar en el campo "Precio venta" del grid
######################################################################################
Subprog AS_YPREC(VALEUR)
Variable Decimal VALEUR

  If [M:YTRF1]YTIPC(nolign-1) = 1 Then
#    [M:YTRF1]YPREC(nolign-1) = [M:YTRF1]YBASC(nolign-1) + (([M:YTRF1]YBASC(nolign-1) * [M:YTRF1]YMARC(nolign-1))/100)
    [M:YTRF1]YPREC(nolign-1) = 100 * ([M:YTRF1]YBASC(nolign-1) / (100 - [M:YTRF1]YMARC(nolign-1)))
  Else
    [M:YTRF1]YPREC(nolign-1) = [M:YTRF1]YBASC(nolign-1) - (([M:YTRF1]YBASC(nolign-1) * [M:YTRF1]YMARC(nolign-1))/100)
  Endif

  [M:YTRF1]YSELEC(nolign-1) = 2
  VALEUR = [M:YTRF1]YPREC(nolign-1)
  Affzo [M:YTRF1]YPREC

End

