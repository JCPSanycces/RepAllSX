Subprog AM_YTAROCOND(VALEUR)
Variable Char    VALEUR()
End
######################################################################################



######################################################################################
## Al entrar en el campo "Condiciones tarifa"
## Carga o crea la tarifa en función de si existe o no en la tabla varia 413
######################################################################################
Subprog AS_YTARCOND(VALEUR)
Variable Char    VALEUR()
End
######################################################################################



######################################################################################
## Al entrar en el campo "Condiciones tarifa base"
######################################################################################
Subprog AS_YTARBCOND(VALEUR)
Variable Char    VALEUR()
