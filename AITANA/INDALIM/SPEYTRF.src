#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Global Char GCC(30)
Global Date GFI(30)
Global Date GFF(30)

Case ACTION
    When "DEBUT"        : Gosub DEBUT
    When "BOUTON"       : Gosub BOUTON  #se pulsa un botón
    When "SETBOUT"      : Gosub SETBOUT
    When "SEL_TABLE"    : Gosub SEL_TABLE
    When "VERF_TABLE"   : Gosub VERF_TABLE
    When Default
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
########################################################################
$DEBUT
  Diszo [M:YTRF0]YTARBASE, YTARBDATINI, YTARBDATFIN
  Diszo [M:YTRF0]YTARORI, YTARODATINI, YTARODATFIN, YTAROCOND
  Affzo [M:YTRF0]
  [M:YTRF0]YFECHAGEN    = datesyst
Return

########################################
$BOUTON
Case BOUT
    When "n"  : Effzo [M:YTRF0] : Effzo [M:YTRF1] : Effzo [M:YTRF2] : [M:YTRF0]YFECHAGEN = datesyst : Affzo [M:YTRF0]
    When "f"  : Gosub FILTRAR
    When "r"  : Gosub RECALCULAR_MARGEN
    When "g"  : Gosub GUARDAR_TARIFA
    When "b"  : Gosub BORRAR_TARIFA
    When Default
Endcase
Return

########################################################################
$SETBOUT
  Case BOUT
    When "m"  : Gosub MARCAR_TODOS
    When "d"  : Gosub DESMARCAR_TODOS
    When "l"  : Gosub LIMPIAR
  Endcase
Return

########################################################################
$SEL_TABLE
  Case TABLE
    When "YCODCON"  : Gosub SEL_YCODCON
    When "YCODTAR"  : Gosub SEL_YCODTAR
    When "YCODORI"  : Gosub SEL_YCODORI
    When Default
  Endcase
Return

########################################################################
$SEL_YCODCON
  If !clalev([F:YCON1]) Then : Local File YCONDICIONES [F:YCON1] : Endif
  Default File [YCON1]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Selección de condiciones"                                      # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Cód. condicion"                                                # título de la primera columna
  COL(NBCOL)  = "YCDGCOND"                                                       # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Fecha inicio"                                                  # título de la segunda columna
  COL(NBCOL)  = "YFECHAINI"                                                     # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Fecha fin"                                                     # título de la tercera columna
  COL(NBCOL)  = "YFECHAFIN"                                                     # nombre del campo a mostrar en la tercera columna
Return

########################################################################
$SEL_YCODTAR
  If !clalev([F:YCON2]) Then : Local File YCONDICIONES [F:YCON2] : Endif
  Default File [YCON2]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Selección de tarifas"                                          # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Cód. tarifa"                                                   # título de la primera columna
  COL(NBCOL)  = "YCDGCOND"                                                      # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Fecha inicio"                                                  # título de la segunda columna
  COL(NBCOL)  = "YFECHAINI"                                                     # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Fecha fin"                                                     # título de la tercera columna
  COL(NBCOL)  = "YFECHAFIN"                                                     # nombre del campo a mostrar en la tercera columna
Return

########################################################################
$SEL_YCODORI
  If !clalev([F:YYTV1]) Then : Local File YVISTARVTA [F:YYTV1] : Endif
  Default File [YYTV1]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Selección de tarifa origen"                                    # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Cód. tarifa"                                                   # título de la primera columna
  COL(NBCOL)  = "PLICRI1"                                                       # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Fecha inicio"                                                  # título de la segunda columna
  COL(NBCOL)  = "PLISTRDAT"                                                     # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Fecha fin"                                                     # título de la tercera columna
  COL(NBCOL)  = "PLIENDDAT"                                                     # nombre del campo a mostrar en la tercera columna
Return

########################################################################
# esta etiqueta se utiliza para realizar acciones específicas cuando se selecciona una de las opciones en la ventana de selección
$VERF_TABLE
  Case TABLE
    When "YCODCON"  : Gosub VERF_YCODCON
    When "YCODTAR"  : Gosub VERF_YCODTAR
    When "YCODORI"  : Gosub VERF_YCODORI
    When Default
  Endcase
Return

########################################################################
$VERF_YCODCON
  GCC = [F:YCON1]YCDGCOND                                                        # se guarda en GCC el código de la condición para usar después
  GFI = [F:YCON1]YFECHAINI                                                       # se guarda en GFI la fecha inicio de la condición para usar después
  GFF = [F:YCON1]YFECHAFIN                                                       # se guarda en GFF la fecha fina de la condición para usar después
  [M:YTRF0]YGCC = GCC
  [M:YTRF0]YGFI = GFI
  [M:YTRF0]YGFF = GFF
  Affzo [M:YTRF0]YGCC, YGFI, YGFF
Return

########################################################################
$VERF_YCODTAR
  [M:YTRF0]YTARDATINI = [F:YCON2]YFECHAINI
  [M:YTRF0]YTARDATFIN = [F:YCON2]YFECHAFIN
  Affzo [M:YTRF0]YTARDATINI, YTARDATFIN
  zonsui = "[M:YTRF0]YCDGCOND"
Return

########################################################################
$VERF_YCODORI
  [M:YTRF0]YTARODATINI = [F:YYTV1]PLISTRDAT
  [M:YTRF0]YTARODATFIN = [F:YYTV1]PLIENDDAT
  Affzo [M:YTRF0]YTARODATINI, YTARODATFIN
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
##############################################################
$FILTRAR
Local Integer LCONTROLA   : Raz LCONTROLA
Local Char LCRIT(255)     : Raz LCRIT
Local Integer LCONT       : Raz LCONT

  Affzo [M:YTRF1]5

  If [M:YTRF1]YFAM <> "" Then                                               # filtro por familias
    LCRIT += "[YITM]TSICOD(0) = [M:YTRF1]YFAM"
    LCONTROLA = 1
  Endif

  If [M:YTRF1]YSUBFAM <> "" Then                                            # filtro por subfamilias
    If LCONTROLA = 1 Then
      LCRIT += " & [YITM]TSICOD(1) = [M:YTRF1]YSUBFAM"
    Else
      LCRIT += "[YITM]TSICOD(1) = [M:YTRF1]YSUBFAM"
      LCONTROLA = 1
    Endif
  Endif

  If [M:YTRF1]YGAMA <> "" Then                                              # filtro por gamas
    If LCONTROLA = 1 Then
      LCRIT += " & [YITM]TSICOD(2) = [M:YTRF1]YGAMA"
    Else
      LCRIT += "[YITM]TSICOD(2) = [M:YTRF1]YGAMA"
      LCONTROLA = 1
    Endif
  Endif

  Effzo [M:YTRF1]10

  If !clalev([F:YITP]) Then : Local File ITMBPS    [F:YITP] : Endif
  If !clalev([F:YSPL]) Then : Local File SPRICLIST [F:YSPL] : Endif
  If !clalev([F:YITM]) Then : Local File ITMMASTER [F:YITM] : Endif

  If  [M:YTRF1]YFAM = "" and [M:YTRF1]YSUBFAM = "" and [M:YTRF1]YGAMA = "" Then
    Filter [YITM]
  Else
    Filter [YITM] Where evalue(LCRIT)                                         # filtra por los campos anteriores
  Endif
  For [YITM]
    If [M:YTRF1]YPROV = "" Then                                             # si no tiene informado un proveedor
      # filtra en la tabla SPRICLIST por el código de tarifa durante el periodo de validez y por cada artículo
      Filter [F:YSPL] Where PLI = "T20" and PLICRI1 = [M:YTRF0]YTARCOD and PLICRI2 = [F:YITM]ITMREF and PLISTRDAT >= [M:YTRF0]YTARDATINI and PLIENDDAT <= [M:YTRF0]YTARDATFIN
      Read [F:YSPL] First
      If !fstat Then
        [M:YTRF1]YFAMC(LCONT)   = [F:YITM]TSICOD(0)
        [M:YTRF1]YSUBC(LCONT)   = [F:YITM]TSICOD(1)
        [M:YTRF1]YGAMC(LCONT)   = [F:YITM]TSICOD(2)
        [M:YTRF1]YARTC(LCONT)   = [F:YITM]ITMREF
        [M:YTRF1]YDESC(LCONT)   = [F:YITM]ITMDES1
        [M:YTRF1]YBASC(LCONT)   = [F:YSPL]YPRIBASE
        [M:YTRF1]YTIPC(LCONT)   = [F:YSPL]YTIPOMRG
        [M:YTRF1]YMARC(LCONT)   = [F:YSPL]YPORMRG
        [M:YTRF1]YPREC(LCONT)   = [F:YSPL]PRI
        [M:YTRF1]YSELEC(LCONT)  = [F:YSPL]YMODIFLG
        LCONT += 1
      Endif
      Filter [F:YSPL]
    Else                                                                          # si tiene informado un proveedor
      Filter [F:YITP] Where ITMREF = [F:YITM]ITMREF and BPSNUM = [M:YTRF1]YPROV   # busca si existe ese artículo para ese proveedor en ITMBPS
      Read [F:YITP] First                                                         # si existe, ya se hace el filtro sobre la tabla SPRICLIST
      If !fstat Then
        Filter [F:YSPL] Where PLI = "T20" and PLICRI1 = [M:YTRF0]YTARCOD and PLICRI2 = [F:YITM]ITMREF and PLISTRDAT >= [M:YTRF0]YTARDATINI and PLIENDDAT <= [M:YTRF0]YTARDATFIN
        Read [F:YSPL] First
        If !fstat Then
          [M:YTRF1]YFAMC(LCONT)   = [F:YITM]TSICOD(0)
          [M:YTRF1]YSUBC(LCONT)   = [F:YITM]TSICOD(1)
          [M:YTRF1]YGAMC(LCONT)   = [F:YITM]TSICOD(2)
          [M:YTRF1]YARTC(LCONT)   = [F:YITM]ITMREF
          [M:YTRF1]YDESC(LCONT)   = [F:YITM]ITMDES1
          [M:YTRF1]YBASC(LCONT)   = [F:YSPL]PRI
          [M:YTRF1]YTIPC(LCONT)   = 1
          [M:YTRF1]YMARC(LCONT)   = 0
          [M:YTRF1]YPREC(LCONT)   = 0
          [M:YTRF1]YSELEC(LCONT)  = [F:YSPL]YMODIFLG
          LCONT += 1
        Endif
        Filter [F:YSPL]
      Endif
      Filter [F:YITP]
    Endif
  Next

  [M:YTRF1]NBLIG = LCONT
  Affzo [M:YTRF1]10
  zonsui = "[M:YTRF1]YFAM"

  Filter [YITM]
  If clalev([F:YIPT]) : Close Local File [F:YITP] : Endif
  If clalev([F:YSPL]) : Close Local File [F:YSPL] : Endif
  If clalev([F:YITM]) : Close Local File [F:YITM] : Endif
Return

##############################################################
$RECALCULAR_MARGEN
Local Integer LCONT
Local Char    CRIT1(255), CRIT2(255), CRIT3(255), CRIT4(255), CRIT5(255) : Raz CRIT1, CRIT2, CRIT3, CRIT4, CRIT5
Local Char    LBPS(15) : Raz LBPS
Local Integer YESNO : YESNO = 1

  Call OUINON("Se perderá toda modificación en las condiciones que no se haya guardado previamente\¿Realmente deseas continuar?",YESNO) From GESECRAN
  If YESNO = 2 Then                                                                   # YESNO = 2 = Sí

    Call TEMPON("Recalculando margen...") From GESECRAN

    If !clalev([F:YCON]) Then : Local File YCONDICIONES [F:YCON] : Endif
    If !clalev([F:YCFA]) Then : Local File YCONDFAM     [F:YCFA] : Endif
    If !clalev([F:YCSF]) Then : Local File YCONDSUB     [F:YCSF] : Endif
    If !clalev([F:YCGM]) Then : Local File YCONDGAM     [F:YCGM] : Endif
    If !clalev([F:YCPR]) Then : Local File YCONDPRO     [F:YCPR] : Endif

    CRIT1 = "YCDGCOND=[M:YTRF2]YCDGCOND and YFECHAINI=[M:YTRF2]YFECHAINI and YFECHAFIN=[M:YTRF2]YFECHAFIN "
    CRIT2 = "YCDGCOND1=[M:YTRF2]YCDGCOND and YFECHAINI1=[M:YTRF2]YFECHAINI and YFECHAFIN1=[M:YTRF2]YFECHAFIN and YCODFAM1=[M:YTRF1]YFAMC(LCONT)"
    CRIT3 = "YCDGCOND2=[M:YTRF2]YCDGCOND and YFECHAINI2=[M:YTRF2]YFECHAINI and YFECHAFIN2=[M:YTRF2]YFECHAFIN and YCODFAM2=[M:YTRF1]YFAMC(LCONT) and YCODSUB2=[M:YTRF1]YSUBC(LCONT)"
    CRIT4 = "YCDGCOND3=[M:YTRF2]YCDGCOND and YFECHAINI3=[M:YTRF2]YFECHAINI and YFECHAFIN3=[M:YTRF2]YFECHAFIN and YCODFAM3=[M:YTRF1]YFAMC(LCONT) and YCODSUB3=[M:YTRF1]YSUBC(LCONT) and YCODGAM3=[M:"
&   + "YTRF1]YGAMC(LCONT)"

    For LCONT = 0 To [M:YTRF1]NBLIG-1
      If [M:YTRF1]YSELEC(LCONT) = 1 Then                                            # no está marcado el check "¿Modificado?"
        Call GET_BPSPRI([M:YTRF1]YARTC(LCONT),LBPS) From SPEYLIB0                   # llama a la función que devuelve el proveedor principal
        CRIT5 = "YCDGCOND4=[M:YTRF2]YCDGCOND and YFECHAINI4=[M:YTRF2]YFECHAINI and YFECHAFIN4=[M:YTRF2]YFECHAFIN and BPSNUM=LBPS"
        Filter [F:YCPR] Where evalue(CRIT5)
        Read [F:YCPR] First
        If !fstat Then                                                              # tiene condiciones para el proveedor
          [M:YTRF1]YTIPC(LCONT) = [F:YCPR]YTIPOMRG4
          [M:YTRF1]YMARC(LCONT) = [F:YCPR]YPORMRG4
          If [M:YTRF1]YTIPC(LCONT) = 1 Then
#            [M:YTRF1]YPREC(LCONT) = [M:YTRF1]YBASC(LCONT) + (([M:YTRF1]YBASC(LCONT) * [M:YTRF1]YMARC(LCONT))/100)
            [M:YTRF1]YPREC(LCONT) = 100 * ([M:YTRF1]YBASC(LCONT) / (100 - [M:YTRF1]YMARC(LCONT)))
          Else
            [M:YTRF1]YPREC(LCONT) = [M:YTRF1]YBASC(LCONT) - (([M:YTRF1]YBASC(LCONT) * [M:YTRF1]YMARC(LCONT))/100)
          Endif
          Filter [F:YCPR]
        Else
          Filter [F:YCGM] Where evalue(CRIT4)
          Read [F:YCGM] First
          If !fstat Then                                                            # no tiene cond. prov. y sí en gama
            [M:YTRF1]YTIPC(LCONT) = [F:YCGM]YTIPOMRGG3
            [M:YTRF1]YMARC(LCONT) = [F:YCGM]YPORMRGG3
            If [M:YTRF1]YTIPC(LCONT) = 1 Then
#              [M:YTRF1]YPREC(LCONT) = [M:YTRF1]YBASC(LCONT) + (([M:YTRF1]YBASC(LCONT) * [M:YTRF1]YMARC(LCONT))/100)
              [M:YTRF1]YPREC(LCONT) = 100 * ([M:YTRF1]YBASC(LCONT) / (100 - [M:YTRF1]YMARC(LCONT)))
            Else
              [M:YTRF1]YPREC(LCONT) = [M:YTRF1]YBASC(LCONT) - (([M:YTRF1]YBASC(LCONT) * [M:YTRF1]YMARC(LCONT))/100)
            Endif
            Filter [F:YCGM]
          Else
            Filter [F:YCSF] Where evalue(CRIT3)
            Read [F:YCSF] First
            If !fstat Then                                                          # no tiene cond. en gama y sí en subfamilia
              [M:YTRF1]YTIPC(LCONT) = [F:YCSF]YTIPOMRGS2
              [M:YTRF1]YMARC(LCONT) = [F:YCSF]YPORMRGS2
              If [M:YTRF1]YTIPC(LCONT) = 1 Then
#                [M:YTRF1]YPREC(LCONT) = [M:YTRF1]YBASC(LCONT) + (([M:YTRF1]YBASC(LCONT) * [M:YTRF1]YMARC(LCONT))/100)
                [M:YTRF1]YPREC(LCONT) = 100 * ([M:YTRF1]YBASC(LCONT) / (100 - [M:YTRF1]YMARC(LCONT)))
              Else
                [M:YTRF1]YPREC(LCONT) = [M:YTRF1]YBASC(LCONT) - (([M:YTRF1]YBASC(LCONT) * [M:YTRF1]YMARC(LCONT))/100)
              Endif
              Filter [F:YCSF]
            Else
              Filter [F:YCFA] Where evalue(CRIT2)
              Read [F:YCFA] First
              If !fstat Then                                                        # no tiene cond. en subfamilia y sí en familia
                [M:YTRF1]YTIPC(LCONT) = [F:YCFA]YTIPOMRG1
                [M:YTRF1]YMARC(LCONT) = [F:YCFA]YPORMRG1
                If [M:YTRF1]YTIPC(LCONT) = 1 Then
#                  [M:YTRF1]YPREC(LCONT) = [M:YTRF1]YBASC(LCONT) + (([M:YTRF1]YBASC(LCONT) * [M:YTRF1]YMARC(LCONT))/100)
                  [M:YTRF1]YPREC(LCONT) = 100 * ([M:YTRF1]YBASC(LCONT) / (100 - [M:YTRF1]YMARC(LCONT)))
                Else
                  [M:YTRF1]YPREC(LCONT) = [M:YTRF1]YBASC(LCONT) - (([M:YTRF1]YBASC(LCONT) * [M:YTRF1]YMARC(LCONT))/100)
                Endif
                Filter [F:YCFA]
              Else                                                                  # no tiene cond. en familía y carga el margen por defecto
                [M:YTRF1]YTIPC(LCONT) = 1
                [M:YTRF1]YMARC(LCONT) = [M:YTRF0]YPORMARGEN
#                [M:YTRF1]YPREC(LCONT) = [M:YTRF1]YBASC(LCONT) + (([M:YTRF1]YBASC(LCONT) * [M:YTRF1]YMARC(LCONT))/100)
                [M:YTRF1]YPREC(LCONT) = 100 * ([M:YTRF1]YBASC(LCONT) / (100 - [M:YTRF1]YMARC(LCONT)))
              Endif # FAMILIA
            Endif # SUBFAMILIA
          Endif # GAMA
        Endif # PROVEEDOR
      Endif # ¿MODIFICADO?
    Next

    Affzo [M:YTRF1]10

    If clalev([F:YCON]) Then : Close Local File [F:YCON] : Endif
    If clalev([F:YCFA]) Then : Close Local File [F:YCFA] : Endif
    If clalev([F:YCSF]) Then : Close Local File [F:YCSF] : Endif
    If clalev([F:YCGM]) Then : Close Local File [F:YCGM] : Endif
    If clalev([F:YCPR]) Then : Close Local File [F:YCPR] : Endif

    Call TEMPOFF() From GESECRAN
  Endif

Return

##############################################################
$ACTUALIZAR_PB
Local Integer LCONT

  For LCONT = 0 To [YTRF1]NBLIG-1
    If [M:YTRF1]YSELEC(LCONT) = 1 Then
      If [M:YTRF1]YTIPC(LCONT) = 1 Then
#        [M:YTRF1]YPREC(LCONT)     = [M:YTRF1]YBASC(LCONT) + (([M:YTRF1]YBASC(LCONT) * [M:YTRF1]YMARC(LCONT))/100)     # incrementa el margen
        [M:YTRF1]YPREC(LCONT)     = 100 * ([M:YTRF1]YBASC(LCONT) / (100 - [M:YTRF1]YMARC(LCONT)))                     # incrementa el margen
      Else
        [M:YTRF1]YPREC(LCONT)     = [M:YTRF1]YBASC(LCONT) - (([M:YTRF1]YBASC(LCONT) * [M:YTRF1]YMARC(LCONT))/100)     # decrementa el margen
      Endif
    Endif
  Next

  Affzo [M:YTRF1]10
Return

##############################################################
$CREAR_TARIFA
Local Char    REG_TAR(10) : Raz REG_TAR
Local Char    LPRE(10)    : Raz LPRE
Local Char    LSUF(10)    : Raz LSUF
Local Integer LCONT       : Raz LSUF

  If !clalev([F:YITM]) Then : Local File ITMMASTER [F:YITM] : Endif
  If !clalev([F:YSPL]) Then : Local File SPRICLIST [F:YSPL] : Endif
  Trbegin [YSPL]
  Filter [YSPL] Where PLI = "T20" Order By PLICRD Desc                    # filtrar para la tarifa T20 el último Registro tarifa
  Read [YSPL] First
  If !fstat Then
    REG_TAR = [F:YSPL]PLICRD                                              # último número Registro tarifa
  Endif
  Filter [YSPL]

  LPRE = left$(REG_TAR,5)                                                 # prefijo antes del signo - (p.ej. SPL18)
  LSUF = right$(REG_TAR,7)                                                # sufijo después del signo - (p.ej. 0017)

  If right$(LPRE,4) = right$(num$(year([M:YTRF0]YFECHAGEN)),3) Then       # si el año de la fecha de generación es igual a los dos últimos caracteres del prefijo
    LSUF = num$(val(LSUF) + 1)                                            # suma una unidad al sufijo
  Else                                                                    # sino significa que se crea una tarifa del año siguiente
    LPRE = left$(LPRE,3) + num$((val(right$(LPRE,4)))+1)                  # suma una unidad al año del prefijo
    LSUF = "01"                                                           # inicia el contador del prefijo
  Endif

  REG_TAR = LPRE + "-00" + LSUF                                           # monta el contador a partir del prefijo y el sufijo
  # guarda en la tabla SPRICLIST
  For LCONT = 0 To [M:YTRF1]NBLIG-1
    [F:YSPL]PLI       = "T20"
    [F:YSPL]PLICRD    = REG_TAR
    [F:YSPL]PLILIN    = (LCONT + 1) * 1000
    [F:YSPL]PLICRI    = [M:YTRF0]YTARCOD+"~"+[M:YTRF1]YARTC(LCONT)+"~~~~"
    [F:YSPL]PLICRI1   = [M:YTRF0]YTARCOD
    [F:YSPL]PLICRI2   = [M:YTRF1]YARTC(LCONT)
    [F:YSPL]PLISTRDAT = [M:YTRF0]YTARDATINI
    [F:YSPL]PLIENDDAT = [M:YTRF0]YTARDATFIN
    Filter [YITM] Where ITMREF = [M:YTRF1]YARTC(LCONT)
    Read [YITM] First
    If !fstat Then
      [F:YSPL]UOM = [F:YITM]STU
    Endif
    Filter [YITM]
    [F:YSPL]CUR       = "EUR"
    [F:YSPL]PRI       = [M:YTRF1]YPREC(LCONT)
    [F:YSPL]COMCOE    = 1
    [F:YSPL]EXPNUM    = 5
    [F:YSPL]YPRIBASE  = [M:YTRF1]YBASC(LCONT)
    Write [F:YSPL]
  Next
  Commit
  If clalev([F:YITM]) Then : Close Local File [F:YITM] : Endif
  If clalev([F:YSPL]) Then : Close Local File [F:YSPL] : Endif

  # guarda en la tabla SPRICFICH
  If !clalev([F:YSPF]) Then : Local File SPRICFICH [F:YSPF] : Endif
  Filter [F:YSPF] Where PLI = "T20" and PLICRD = REG_TAR
  Read [F:YSPF] First
  If fstat Then                                                           # si no existe la tarifa en la tabla SPRICFICH
    Trbegin [F:YSPF]
    [F:YSPF]PLI         = "T20"
    [F:YSPF]PLICRD      = REG_TAR
    [F:YSPF]PLISTRDAT   = [M:YTRF0]YTARDATINI
    [F:YSPF]PLIENDDAT   = [M:YTRF0]YTARDATFIN
    [F:YSPF]LINNBR      = LCONT
    [F:YSPF]EXPNUM      = 5
    [F:YSPF]CREDAT      = datesyst
    [F:YSPF]UPDDAT      = datesyst
    [F:YSPF]YTARCOD     = [M:YTRF0]YTARCOD
    Write [F:YSPF]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif
  If clalev([F:YSPF])  Then : Close Local File [F:YSPF] : Endif


Return

##############################################################
$GUARDAR_TARIFA
Local Integer LCONT : Raz LCONT

  Call TEMPON("Guardando la tarifa " + num$([M:YTRF0]YTARCOD)) From GESECRAN

  # modifica en la tabla SPRICLIST el campo de precio para todos los registros del grid
  If !clalev([F:YSPL]) Then : Local File SPRICLIST [F:YSPL] : Endif
  Trbegin [YSPL]
  For LCONT = 0 To [M:YTRF1]NBLIG-1
#    If [M:YTRF1]YSELEC(LCONT) = 1 Then                                            # no está marcado el check "¿Modificado?"
      Filter [F:YSPL] Where PLICRI1 = [M:YTRF0]YTARCOD and PLISTRDAT = [M:YTRF0]YTARDATINI and PLIENDDAT = [M:YTRF0]YTARDATFIN and PLICRI2 = [M:YTRF1]YARTC(LCONT)
      Read [F:YSPL] First
      If !fstat Then
        [F:YSPL]PRI       = [M:YTRF1]YPREC(LCONT)
        [F:YSPL]YTIPOMRG  = [M:YTRF1]YTIPC(LCONT)
        [F:YSPL]YPORMRG   = [M:YTRF1]YMARC(LCONT)
        [F:YSPL]YMODIFLG  = [M:YTRF1]YSELEC(LCONT)
        Rewrite [F:YSPL]
      Endif
      Filter [F:YSPL]
#    Endif
  Next
  Commit
  Raz LCONT
  If clalev([F:YSPL]) Then : Close Local File [F:YSPL] : Endif

  # modifica en la tabla SPRICFIC los campos de la pantalla relacionados
  If !clalev([F:YSPF]) Then : Local File SPRICFICH [F:YSPF] : Endif
  Trbegin [F:YSPF]
  Filter [F:YSPF] Where YTARCOD = [M:YTRF0]YTARCOD and PLISTRDAT = [M:YTRF0]YTARDATINI and PLIENDDAT = [M:YTRF0]YTARDATFIN
  Read [F:YSPF] First
  If !fstat Then
    [F:YSPF]PLICRDIDX = [M:YTRF0]YTARCOD
    [F:YSPF]YTARORI   = [M:YTRF0]YTARORI
    [F:YSPF]YTARINI   = [M:YTRF0]YTARODATINI
    [F:YSPF]YTARFIN   = [M:YTRF0]YTARODATFIN
    [F:YSPF]YTAROBS   = [M:YTRF0]YTAROBS
    Rewrite [F:YSPF]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Else
    Commit
  Endif
  Filter [F:YSPF]
  If clalev([F:YSPF])  Then : Close Local File [F:YSPF] : Endif

  # da de alta las condiciones con el código y fechas de la tarifa en las tablas YCONDICIONES, YCONDFAM, YCONDSUB, YCONDGAM e YCONDPRO
  # YCONDICIONES
  If !clalev([F:YCON]) Then : Local File YCONDICIONES [F:YCON] : Endif
  Trbegin [F:YCON]
  [F:YCON]YCDGCOND  = [M:YTRF0]YTARCOD
  [F:YCON]YFECHAINI = [M:YTRF0]YTARDATINI
  [F:YCON]YFECHAFIN = [M:YTRF0]YTARDATFIN
  [F:YCON]YPORMRG   = [M:YTRF0]YPORMARGEN
  Write [F:YCON]
  If fstat Then
    Rollback
  Else
    Commit
  Endif
  If clalev([F:YCON]) Then : Close Local File [F:YCON] : Endif

  # YCONDFAM
  If !clalev([F:YCFA]) Then : Local File YCONDFAM     [F:YCFA] : Endif
  For LCONT = 0 To [M:YTRF2]NBLIG-1
    # comprobar si el registro existe (se actualizan los valores) o no existe (se dan de alta los valores)
    Filter [F:YCFA] Where YCDGCOND1=[M:YTRF0]YTARCOD and YFECHAINI1=[M:YTRF0]YTARDATINI and YFECHAFIN1=[M:YTRF0]YTARDATFIN and YCODFAM1=[M:YTRF2]YCODFAM1(LCONT)
    Read [F:YCFA] First
    If !fstat Then                                                    # el registro sí que existe
      Trbegin [F:YCFA]
      [F:YCFA]YTIPOMRG1   = [M:YTRF2]YTIPOMRG1(LCONT)
      [F:YCFA]YPORMRG1    = [M:YTRF2]YPORMRG1(LCONT)
      Rewrite [F:YCFA]
      If fstat <> 0 Then
        Rollback
      Else
        Commit
      Endif
    Else                                                              # el registro no existe
      Trbegin [F:YCFA]
      [F:YCFA]YCDGCOND1   = [M:YTRF0]YTARCOD
      [F:YCFA]YFECHAINI1  = [M:YTRF0]YTARDATINI
      [F:YCFA]YFECHAFIN1  = [M:YTRF0]YTARDATFIN
      [F:YCFA]YCODFAM1    = [M:YTRF2]YCODFAM1(LCONT)
      [F:YCFA]YTIPOMRG1   = [M:YTRF2]YTIPOMRG1(LCONT)
      [F:YCFA]YPORMRG1    = [M:YTRF2]YPORMRG1(LCONT)
      Write [F:YCFA]
      If fstat <> 0 Then
        Rollback
      Else
        Commit
      Endif
    Endif
    Filter [F:YCFA]
  Next
  Raz LCONT
  If clalev([F:YFCA]) Then : Close Local File [F:YFCA] : Endif

  # YCONDSUB
  If !clalev([F:YCSF]) Then : Local File YCONDSUB     [F:YCSF] : Endif
  For LCONT = 0 To [M:YTRF2]NBLIG2-1
    # comprobar si el registro existe (se actualizan los valores) o no existe (se dan de alta los valores)
    Filter [F:YCSF] Where YCDGCOND2=[M:YTRF0]YTARCOD and YFECHAINI2=[M:YTRF0]YTARDATINI and YFECHAFIN2=[M:YTRF0]YTARDATFIN and YCODFAM2=[M:YTRF2]YCODFAM2(LCONT) and YCODSUB2=[M:YTRF2]YCODSUB2(LCONT)
    Read [F:YCSF] First
    If !fstat Then                                                    # el registro sí que existe
      Trbegin [F:YCSF]
      [F:YCSF]YTIPOMRGS2  = [M:YTRF2]YTIPOMRGS2(LCONT)
      [F:YCSF]YPORMRGS2   = [M:YTRF2]YPORMRGS2(LCONT)
      Rewrite [F:YCSF]
      If fstat <> 0 Then
        Rollback
      Else
        Commit
      Endif
    Else                                                              # el registro no existe
      Trbegin [F:YCSF]
      [F:YCSF]YCDGCOND2   = [M:YTRF0]YTARCOD
      [F:YCSF]YFECHAINI2  = [M:YTRF0]YTARDATINI
      [F:YCSF]YFECHAFIN2  = [M:YTRF0]YTARDATFIN
      [F:YCSF]YCODFAM2    = [M:YTRF2]YCODFAM2(LCONT)
      [F:YCSF]YCODSUB2    = [M:YTRF2]YCODSUB2(LCONT)
      [F:YCSF]YTIPOMRGS2  = [M:YTRF2]YTIPOMRGS2(LCONT)
      [F:YCSF]YPORMRGS2   = [M:YTRF2]YPORMRGS2(LCONT)
      Write [F:YCSF]
      If fstat <> 0 Then
        Rollback
      Else
        Commit
      Endif
    Endif
    Filter [F:YCSF]
  Next
  Raz LCONT
  If clalev([F:YCSF]) Then : Close Local File [F:YCSF] : Endif

  # YCONDGAM
  If !clalev([F:YCGM]) Then : Local File YCONDGAM     [F:YCGM] : Endif
  For LCONT = 0 To [M:YTRF2]NBLIG3-1
    # comprobar si el registro existe (se actualizan los valores) o no existe (se dan de alta los valores)
    Filter [F:YCGM] Where YCDGCOND3=[M:YTRF0]YTARCOD and YFECHAINI3=[M:YTRF0]YTARDATINI and YFECHAFIN3=[M:YTRF0]YTARDATFIN and YCODFAM3=[M:YTRF2]YCODFAM3(LCONT) and YCODSUB3=[M:YTRF2]YCODSUB3(LCONT)
& and YCODGAM3=[M:YTRF2]YCODGAM3(LCONT)
    Read [F:YCGM] First
    If !fstat Then                                                    # el registro sí que existe
      Trbegin [F:YCGM]
      [F:YCGM]YTIPOMRGG3  = [M:YTRF2]YTIPOMRGG3(LCONT)
      [F:YCGM]YPORMRGG3   = [M:YTRF2]YPORMRGG3(LCONT)
      Rewrite [F:YCGM]
      If fstat <> 0 Then
        Rollback
      Else
        Commit
      Endif
    Else                                                              # el registro no existe
      Trbegin [F:YCGM]
      [F:YCGM]YCDGCOND3   = [M:YTRF0]YTARCOD
      [F:YCGM]YFECHAINI3  = [M:YTRF0]YTARDATINI
      [F:YCGM]YFECHAFIN3  = [M:YTRF0]YTARDATFIN
      [F:YCGM]YCODFAM3    = [M:YTRF2]YCODFAM3(LCONT)
      [F:YCGM]YCODSUB3    = [M:YTRF2]YCODSUB3(LCONT)
      [F:YCGM]YCODGAM3    = [M:YTRF2]YCODGAM3(LCONT)
      [F:YCGM]YTIPOMRGG3  = [M:YTRF2]YTIPOMRGG3(LCONT)
      [F:YCGM]YPORMRGG3   = [M:YTRF2]YPORMRGG3(LCONT)
      Write [F:YCGM]
      If fstat <> 0 Then
        Rollback
      Else
        Commit
      Endif
    Endif
    Filter [F:YCGM]
  Next
  Raz LCONT
  If clalev([F:YCGM]) Then : Close Local File [F:YCGM] : Endif

  # YCONDPRO
  If !clalev([F:YCPR]) Then : Local File YCONDPRO     [F:YCPR] : Endif
  For LCONT = 0 To [M:YTRF2]NBLIG4-1
    # comprobar si el registro existe (se actualizan los valores) o no existe (se dan de alta los valores)
    Filter [F:YCPR] Where YCDGCOND4=[M:YTRF0]YTARCOD and YFECHAINI4=[M:YTRF0]YTARDATINI and YFECHAFIN4=[M:YTRF0]YTARDATFIN and BPSNUM=[M:YTRF2]BPSNUM(LCONT)
    Read [F:YCPR] First
    If !fstat Then                                                      # el registro sí que existe
      Trbegin [F:YCPR]
      [F:YCPR]YTIPOMRG4   = [M:YTRF2]YTIPOMRG4(LCONT)
      [F:YCPR]YPORMRG4    = [M:YTRF2]YPORMRG4(LCONT)
      Rewrite [F:YCPR]
      If fstat <> 0 Then
        Rollback
      Else
        Commit
      Endif
    Else                                                                # el registro no existe
      Trbegin [F:YCPR]
      [F:YCPR]YCDGCOND4   = [M:YTRF0]YTARCOD
      [F:YCPR]YFECHAINI4  = [M:YTRF0]YTARDATINI
      [F:YCPR]YFECHAFIN4  = [M:YTRF0]YTARDATFIN
      [F:YCPR]BPSNUM      = [M:YTRF2]BPSNUM(LCONT)
      [F:YCPR]YTIPOMRG4   = [M:YTRF2]YTIPOMRG4(LCONT)
      [F:YCPR]YPORMRG4    = [M:YTRF2]YPORMRG4(LCONT)
      Write [F:YCPR]
      If fstat <> 0 Then
        Rollback
      Else
        Commit
      Endif
    Endif
    Filter [F:YCPR]
  Next
  Raz LCONT
  If clalev([F:YCPR]) Then : Close Local File [F:YCPR] : Endif
  Call TEMPOFF() From GESECRAN

  [M:YTRF0]YCDGCOND   = [M:YTRF0]YTARCOD
  [M:YTRF2]YCDGCOND   = [M:YTRF0]YTARCOD
  [M:YTRF2]YFECHAINI  = [M:YTRF0]YTARDATINI
  [M:YTRF2]YFECHAFIN  = [M:YTRF0]YTARDATFIN
  Affzo [M:YTRF0]
  Affzo [M:YTRF2]
Return

##############################################################
$BORRAR_TARIFA
Local Integer LCONT       : Raz LCONT
Local Integer YESNO       : YESNO = 1
Local Char    REG_TAR(15) : Raz REG_TAR

  Call OUINON("Se va a proceder al borrado de la tarifa\¿Realmente deseas continuar?",YESNO) From GESECRAN
  If YESNO = 2 Then                                                                   # YESNO = 2 = Sí
    If !clalev([F:YSPL]) Then : Local File SPRICLIST [F:YSPL] : Endif                 # borra todos los registros de la tarifa en la tabla SPRICLIST
    Filter [F:YSPL] Where PLI = "T20" and PLICRI1 = [M:YTRF0]YTARCOD and PLISTRDAT >= [M:YTRF0]YTARDATINI and PLIENDDAT <= [M:YTRF0]YTARDATFIN
    Trbegin [YSPL]
    Read [F:YSPL] First
    If !fstat Then
      REG_TAR = [F:YSPL]PLICRD
    Endif
    Call TEMPON("Borrando la tarifa " + num$([M:YTRF0]YTARCOD)) From GESECRAN
    For [YSPL]
      Delete [YSPL]
    Next
    Commit
    Filter [F:YSPL]

    Filter [F:YSPL] Where PLI = "T20" and PLICRI1 = [M:YTRF0]YTARCOD
    Read [YSPL] First
    If fstat = 4 Then                                                                 # si no hay registros de esa tarifa en SPRICLIST borra también en ATABDIV
      If !clalev([F:YADI]) Then : Local File ATABDIV   [F:YADI] : Endif
      Filter [F:YADI] Where NUMTAB = 413 and CODE = [M:YTRF0]YTARCOD
      Trbegin [YADI]
      Read [F:YADI] First
      If !fstat Then
        Delete [F:YADI]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
      Endif
      Filter [F:YADI]

      If clalev([F:YADI])  Then : Close Local File [F:YADI] : Endif                   # borra también de la tabla SPRICFICH
      If !clalev([F:YSPF]) Then : Local File SPRICFICH [F:YSPF] : Endif
      Filter [F:YSPF] Where PLICRD = REG_TAR
      Read [F:YSPF] First
      If !fstat Then
        Trbegin [YSPF]
        Delete [F:YSPF]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
      Endif
      Filter [F:YSPF]
      If clalev([F:YSPF])  Then : Close Local File [F:YSPF] : Endif
    Endif
    Filter [F:YSPL]
    If clalev([F:YSPL]) Then : Close Local File [F:YSPL] : Endif
                                                                                      # borra las condiciones de esa tarifa
    If !clalev([F:YCON]) Then : Local File YCONDICIONES [F:YCON] : Endif
    If !clalev([F:YCFA]) Then : Local File YCONDFAM     [F:YCFA] : Endif
    If !clalev([F:YCSF]) Then : Local File YCONDSUB     [F:YCSF] : Endif
    If !clalev([F:YCGM]) Then : Local File YCONDGAM     [F:YCGM] : Endif
    If !clalev([F:YCPR]) Then : Local File YCONDPRO     [F:YCPR] : Endif

    Filter [F:YCON] Where YCDGCOND  = [M:YTRF0]YTARCOD and YFECHAINI  = [M:YTRF0]YTARDATINI and YFECHAFIN  = [M:YTRF0]YTARDATFIN
    Filter [F:YCFA] Where YCDGCOND1 = [M:YTRF0]YTARCOD and YFECHAINI1 = [M:YTRF0]YTARDATINI and YFECHAFIN1 = [M:YTRF0]YTARDATFIN
    Filter [F:YCSF] Where YCDGCOND2 = [M:YTRF0]YTARCOD and YFECHAINI2 = [M:YTRF0]YTARDATINI and YFECHAFIN2 = [M:YTRF0]YTARDATFIN
    Filter [F:YCGM] Where YCDGCOND3 = [M:YTRF0]YTARCOD and YFECHAINI3 = [M:YTRF0]YTARDATINI and YFECHAFIN3 = [M:YTRF0]YTARDATFIN
    Filter [F:YCPR] Where YCDGCOND4 = [M:YTRF0]YTARCOD and YFECHAINI4 = [M:YTRF0]YTARDATINI and YFECHAFIN4 = [M:YTRF0]YTARDATFIN

    Trbegin [YCON]
    For [YCON]
      Delete [F:YCON]
    Next
    Commit

    Trbegin [YCFA]
    For [YCFA]
      Delete [F:YCFA]
    Next
    Commit

    Trbegin [YCSF]
    For [YCSF]
      Delete [F:YCSF]
    Next
    Commit

    Trbegin [YCGM]
    For [YCGM]
      Delete [F:YCGM]
    Next
    Commit

    Trbegin [YCPR]
    For [YCPR]
      Delete [F:YCPR]
    Next
    Commit

    Filter [F:YCON]
    Filter [F:YCFA]
    Filter [F:YCSF]
    Filter [F:YCGM]
    Filter [F:YCPR]

    If clalev([F:YCON]) Then : Close Local File [F:YCON] : Endif
    If clalev([F:YCFA]) Then : Close Local File [F:YCFA] : Endif
    If clalev([F:YCSF]) Then : Close Local File [F:YCSF] : Endif
    If clalev([F:YCGM]) Then : Close Local File [F:YCGM] : Endif
    If clalev([F:YCPR]) Then : Close Local File [F:YCPR] : Endif

    Effzo [M:YTRF0]
    Effzo [M:YTRF1]
    Effzo [M:YTRF2]

    Call TEMPOFF() From GESECRAN

  Endif

Return

##############################################################
$MARCAR_TODOS
Local Integer LCONT   : Raz LCONT

  For LCONT = 0 To [M:YTRF1]NBLIG-1     # recorre el cuadro
      [M:YTRF1]YSELEC(LCONT) = 2        # marca el check
  Next LCONT

  Affzo [M:YTRF1]10                     # refresca el bloque cuadro (30) de la pantalla

Return

##############################################################
$DESMARCAR_TODOS
Local Integer LCONT   : Raz LCONT

  For LCONT = 0 To [M:YTRF1]NBLIG-1     # recorre el cuadro
      [M:YTRF1]YSELEC(LCONT) = 1        # desmarca el check
  Next LCONT

  Affzo [M:YTRF1]10                     # refresca el bloque cuadro (30) de la pantalla

Return

##############################################################
$LIMPIAR
  Effzo [M:YTRF1]5,10
Return


##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Después de modificar el campo "¿Tarifa base?"
## Carga en el grid todos los artículos cogiendo el precio del estándar
######################################################################################
Subprog AM_YTARBASE(VALEUR)
Variable Integer VALEUR
Local Integer LCONT : Raz LCONT

  Call TEMPON("Creando tarifa base...") From GESECRAN

  If VALEUR = 2 Then                                                          # si está marcado el check
    Diszo [M:YTRF0]YTARORI                                                    # desactiva el campo "Tarifa origen"
    If !clalev([F:YITM]) Then : Local File ITMMASTER [F:YITM]  Order By TSICOD(0) ; TSICOD(1) ; TSICOD(2) : Endif
    If !clalev([F:YITC]) Then : Local File ITMCOST   [F:YITC] : Endif
    For [YITM]                                                                # carga todos los artículos
      [M:YTRF1]YFAMC(LCONT)   = [F:YITM]TSICOD(0)                             # familia
      [M:YTRF1]YSUBC(LCONT)   = [F:YITM]TSICOD(1)                             # subfamilia
      [M:YTRF1]YGAMC(LCONT)   = [F:YITM]TSICOD(2)                             # gama
      [M:YTRF1]YARTC(LCONT)   = [F:YITM]ITMREF                                # código de artículo
      [M:YTRF1]YDESC(LCONT)   = [F:YITM]ITMDES1                               # descripción
#      Filter [F:YITC] Where ITMREF = [F:YITM]ITMREF                           # busca el precio estándar en la tabla ITMCOST
#      Read [F:YITC] First
#      If !fstat Then
        [M:YTRF1]YBASC(LCONT) = [F:YITM]YPRISTD                                # si existe lo carga en el precio base
#        [M:YTRF1]YBASC(LCONT) = [F:YITC]VLTTOT                                # si existe lo carga en el precio base
#      Else
#        Effzo [M:YTRF1]YBASC(LCONT)                                           # sino pone valor cero
#      Endif
      [M:YTRF1]YTIPC(LCONT)   = 1                                             # por defecto indica incremento
      Effzo [M:YTRF1]YMARC(LCONT)                                             # %margen = 0
      Effzo [M:YTRF1]YPREC(LCONT)                                             # precio venta = 0
      LCONT += 1
    Next
    [M:YTRF1]NBLIG = LCONT
    If clalev([F:YITM]) Then : Close Local File [F:YITM] : Endif
    If clalev([F:YITC]) Then : Close Local File [F:YITC] : Endif
  Else                                                                        # si no está marcado el check de tarifa base
    Actzo [M:YTRF0]YTARORI                                                    # activa el campo "Tarifa origen"
    Gosub LIMPIAR                                                             # limpia los campos de filtro y el grid
  Endif

  Actzo [M:YTRF0]YTARBDATINI, YTARBDATFIN                                     # activa los campos de fecha inicio, fecha fin validez y condiciones de tarifa base
  Affzo [M:YTRF0]YTARORI
  Affzo [M:YTRF1]10

  Gosub CREAR_TARIFA
  Call TEMPOFF() From GESECRAN

End
######################################################################################



######################################################################################
## Activa o desactiva campos en función de si está marcado o no el campo ¿Actualizar tarifa?
######################################################################################
Subprog AM_YACTTARIFA(VALEUR)
Variable Integer VALEUR
End
######################################################################################



######################################################################################
## Después de modificar el campo "Condiciones tarifa"
######################################################################################
Subprog AM_YTARCOND(VALEUR)
Variable Char    VALEUR()
End
######################################################################################



######################################################################################
## Después de modificar el campo "Tarifa origen"
######################################################################################
Subprog AM_YTARORI(VALEUR)
Variable Char    VALEUR()
  Actzo [M:YTRF0]YTARODATINI, YTARODATFIN, YTAROCOND
  Diszo [M:YTRF0]YTARBASE
End
