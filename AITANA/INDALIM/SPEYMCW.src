#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "BOUTON"     : Gosub BOUTON
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$BOUTON
  Case BOUT
    When "e"  : Gosub EXPORTAR_
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$EXPORTAR_
Local   Clbfile LCRIT(1)            : LCRIT = "1=1"
Local   Char LDIRIMPORT(250)        : LDIRIMPORT = filpath("IMPORT_EXPORT\ARTICULO_WEB","","")
Global  Char LFILE(200)             : Raz LFILE
Local   Char NAMEFILE(200)          : Raz NAMEFILE
Local   Char LFECHA(10), LHORA(10)  : Raz LFECHA, LHORA
Local   Char LSEP(1)                : LSEP = ";"  # separador

  LFECHA = vireblc(num$(date$),4)   : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
  LHORA  = vireblc(num$(time$),4)   : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

  # crea el documento
  NAMEFILE  = "\MntoCampoWeb" + "_" + LFECHA + LHORA
  LFILE     = LDIRIMPORT + NAMEFILE + ".txt"

  # borramos el fichero si existe...
  If filinfo(LFILE, 7) > 0 Then
    System "ae_rm " + LFILE
  Endif

  mkstat = 0 : fstat = 0 : GERRTRACE = 0
  Sleep 1
  # abrir el fichero para escritura
  Gosub OPEN_FILE

  If [M:YMCW]YTCLCODSTR <> "" Then LCRIT -= "AND TCLCOD >= [M:YMCW]YTCLCODSTR" : Endif
  If [M:YMCW]YTCLCODEND <> "" Then LCRIT -= "AND TCLCOD <= [M:YMCW]YTCLCODEND" : Endif
  If [M:YMCW]YITMREFSTR <> "" Then LCRIT -= "AND ITMREF >= [M:YMCW]YITMREFSTR" : Endif
  If [M:YMCW]YITMREFEND <> "" Then LCRIT -= "AND ITMREF <= [M:YMCW]YITMREFEND" : Endif


  If !GSERVEUR Then
    Call OUVRE_TRACE("Creación fichero exportación artículos") From LECFIC
  Endif

  If !clalev([F:YVMW]) Then : Local File YVISMNTCMPW  [F:YVMW] : Endif
  Filter [F:YVMW] Where evalue(LCRIT)
  For [YVMW]
    If !GSERVEUR Then
      Call ECR_TRACE("Atículo"-[F:YVMW]ITMREF,0) From GESECRAN
    Endif
    Wrseq [F:YVMW]ITMREF + LSEP + [F:YVMW]ITMDES1 + LSEP + [F:YVMW]TCLCOD + LSEP + [F:YVMW]TSICOD0 + LSEP + [F:YVMW]TSICOD1 + LSEP + [F:YVMW]TSICOD2 + LSEP +
&   num$([F:YVMW]STALM) + LSEP + num$([F:YVMW]STMLG) Using [YIMP]
  Next
  Filter [F:YVMW]
  Close Local File [YVMW]

  Gosub CLOSE_FILE

  If !GSERVEUR Then
    Call FERME_TRACE From LECFIC
  Endif

  If (fstat <> 0 and fstat <> 4) or GERRTRACE <> 0 Then                           # si se produce error de importación...
    Call ERREUR("Se ha producido un error durante la exportación") From GESECRAN
  Else
    Call MESSAGE("Exportación finalizada correctamente\Puede encontrar el fichero en la ruta") From GESECRAN
  Endif


  mkstat = 0 : fstat = 0 : GOK = 1 : GERRTRACE = 0

  If dim(LCRIT) > 0 Then : Kill LCRIT : Endif
Return

########################################################
$OPEN_FILE
  adxifs = ";"
  adxirs = chr$(13)+chr$(10)
  Openo LFILE Using [YIMP]
Return

########################################################
$CLOSE_FILE
  Openo Using [YIMP]
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
