    When "STYLE"        : Gosub STYLE
    When "SEL_TABLE"    : Gosub SEL_TABLE
    When "VERF_TABLE"   : Gosub VERF_TABLE
#    When "OUVRE"  : Infbox "OUVRE: "+num$([M:ITM0]ITMREF)                           ############################### AL ENTRAR
#    When "BOITE"  : Infbox "BOITE: "+num$([M:ITM0]ITMREF)
#    When "TITRE"  : Infbox "TITRE: "+num$([M:ITM0]ITMREF)
#    When "OUVRE_BOITE"  : Infbox "OUVRE_BOITE: "+num$([M:ITM0]ITMREF)
#    When "AFFMASK"  : Infbox "AFFMASK: "+num$([M:ITM0]ITMREF)
#    When "FILTRE"  : Infbox "FILTRE: "+num$([M:ITM0]ITMREF)
#    When "DROIT"  : Infbox "DROIT: "+num$([M:ITM0]ITMREF)
#    When "CLE_GAUCHE"  : Infbox "CLE_GAUCHE: "+num$([M:ITM0]ITMREF)
#    When "AVANT_VERROU"  : Gosub LIENS     # AQUÍ YA TENEMOS EL CÓDIGO DE ARTÍCULO
#    When "VERROU"  : Infbox "VERROU: "+num$([M:ITM0]ITMREF)
    When "LIENS"  : Gosub LIENS
#    When "STYLE"  : Infbox "STYLE: "+num$([M:ITM0]ITMREF)
#    When "APRES_CHOI"  : Infbox "APRES_CHOI: "+num$([M:ITM0]ITMREF)               ############################# BROWSER
#    When "FIN_ACTION"  : Infbox "FIN_ACTION: "+num$([M:ITM0]ITMREF)
#    When "GAUCHE"  : Infbox "GAUCHE: "+num$([M:ITM0]ITMREF)
#    When "FILTRE"  : Infbox "FILTRE: "+num$([M:ITM0]ITMREF)
#    When "AVANT_DEVERROU"  : Infbox "AVANT_DEVERROU: "+num$([M:ITM0]ITMREF)
#    When "DEVERROU"  : Infbox "DEVERROU: "+num$([M:ITM0]ITMREF)
