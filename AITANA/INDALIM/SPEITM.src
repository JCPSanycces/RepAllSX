# IN03
$MOD_YPRISTD
    If !clalev([F:YITM]) Then : Local File ITMMASTER [F:YITM] : Endif
    Read [F:YITM]ITM0 = [M:ITM0]ITMREF
    If !fstat Then
      [F:YITM]YPRISTD   = [M:YITM11]YPRISTD
      Rewrite [F:YITM]
    Endif
    If clalev([F:YITM])  Then : Close Local File     [F:YITM] : Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Al moverse por el cuadro de proveedores dentro de la pestaña "Proveedores"
######################################################################################
Subprog AS_NBITP
  Call BUSCA_SECCION([M:ITM0]ITMREF,[M:ITP]BPSNUM(nolign-1))
End


######################################################################################
Subprog BUSCA_SECCION (PITMREF,PBPSNUM)
Value Char PITMREF, PBPSNUM

  If PITMREF <> "" and PBPSNUM <> "" Then
    If !clalev([F:YITP]) Then : Local File ITMBPS [F:YITP] : Endif
    Read [F:YITP]ITP0 = PITMREF;PBPSNUM
    If !fstat Then
      [M:ITP]YSECC = [F:YITP]YSECC2
    Endif
    Affzo [M:ITP]10
    If clalev([F:YITP])  Then : Close Local File  [F:YITP] : Endif
  Endif
End

######################################################################################
## Después de modificar el campo "Sección"
######################################################################################
Subprog AM_YSECC(VALEUR)
Variable Char    VALEUR()

  [M:ITP]YSECC2([M]XNUMLIG) = VALEUR
  Affzo [M:ITP]5
End


######################################################################################

