  Endcase

Return

##################################################
$CREATION
Return
  If GFONCTION = "GESITM" Then
    Gosub ADD_SECCION
    Gosub CRE_ADR            # IN19
#    Gosub ADD_YPRISTD        # IN03
  Endif
Return

##################################################
$MODIF
  If GFONCTION = "GESITM" Then
    Gosub ADD_SECCION
    Gosub MOD_ADR            # IN19
    Gosub MOD_YPRISTD        # IN03
  Endif
Return

##################################################
$ANNULE
  If GFONCTION = "GESITM" Then
    Gosub DEL_ADR           # IN19
  Endif
Return

##################################################
$STYLE
Return

##################################################
$SEL_TABLE
  Case TABLE
    When "YSELCDGONU"  : Gosub SEL_YSELCDGONU
  Endcase
Return

##################################################
$SEL_YSELCDGONU
  If !clalev([F:YIO0]) Then : Local File YITMONU [F:YIO0] : Endif
  Default File [YIO0]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Mantenimiento códigos ONU"                                     # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Ref. interna ONU"                                              # título de la segunda columna
  COL(NBCOL)  = "REFONU"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Código ONU"                                                    # título de la primera columna
  COL(NBCOL)  = "CDGONU"                                                        # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la primera columna
  COL(NBCOL)  = "NAMONU"                                                        # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Clase"                                                         # título de la primera columna
  COL(NBCOL)  = "CLAONU"                                                        # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Factor peligrosidad"                                           # título de la primera columna
  COL(NBCOL)  = "FPONU"                                                         # nombre del campo a mostrar en la primera columna
Return

##################################################
$VERF_TABLE
  Case TABLE
    When "YSELCDGONU"  : Gosub VERF_YSELCDGONU
  Endcase
Return

##################################################
$VERF_YSELCDGONU
  [M:YITM11]CDGONU      = [F:YIO0]REFONU
  [M:YITM11]GENDES      = [F:YIO0]NAMONU
  [M:YITM11]DETDES      = [F:YIO0]DESONU
  [M:YITM11]FACPELIGRO  = [F:YIO0]FPONU
  Affzo [M:YITM11]CDGONU,GENDES,DETDES,FACPELIGRO
Return

##################################################
$LIENS
  Gosub GET_YPRISTD       # IN19
  Gosub GET_PMP           # IN19
  Gosub GET_DATES         # IN19
  Gosub GET_PRIREP        # IN19
  Gosub GET_ADR           # IN19
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ADD_SECCION
Local Integer LCON : Raz LCON

  If !clalev([F:YITP]) Then : Local File ITMBPS [F:YITP] : Endif
  For LCON = 0 To [M:ITP]NBITP-1
    Filter [F:YITP] Where ITMREF = [M:ITM0]ITMREF and BPSNUM = [M:ITP]BPSNUM(LCON)
    Read [F:YITP] First
    If !fstat Then
      [F:YITP]YSECC2 = [M:ITP]YSECC2(LCON)
      Rewrite [F:YITP]
      If fstat
##        GOK = 0 : Call FSTA("YITP") From GLOCK
      Else
#        Infbox "REGISTRO ACTUALIZADO"
      Endif
    Else
#      Infbox "REGISTRO NO ENCONTRADO"
    Endif
  Next

#  If GOK<1 : Return : Endif
  If clalev([F:YITP])  Then : Close Local File  [F:YITP] : Endif

Return

##############################################################
# IN19
# rellena el campo "Coste de referencia" (AVC), "Precio última entrada" (LASRCPPRI) y "Último precio de compra" (LASPURPRI)
$GET_PMP
Local Integer LCON, I: Raz LCON, I
Local Decimal LSUMPHYSTO, LDIVIDENDO, LRDO : Raz LCON, LDIVIDENDO, LRDO
Local Decimal LPHYSTO(0..), LAVC(0..) : Raz LPHYSTO, LAVC

  If !clalev([F:YITV0]) Then : Local File ITMMVT [F:YITV0] : Endif
  Filter [F:YITV0] Where ITMREF = [M:ITM0]ITMREF
  For [YITV0]
    [M:YITM11]STOFCY(LCON)    = [F:YITV0]STOFCY
    [M:YITM11]AVC(LCON)       = [F:YITV0]AVC
    [M:YITM11]LASRCPPRI(LCON) = [F:YITV0]LASRCPPRI
    [M:YITM11]LASPURPRI(LCON) = [F:YITV0]LASPURPRI
#    LSUMPHYSTO               += [F:YITV0]PHYSTO
    LSUMPHYSTO                += [F:YITV0]AVCBASQTY
#    LDIVIDENDO               += ([F:YITV0]PHYSTO * [F:YITV0]AVC)
    LDIVIDENDO                += ([F:YITV0]AVCBASQTY * [F:YITV0]AVC)
    LCON += 1
  Next
  [M:YITM11]NBPMP = LCON
  Filter [F:YITV0]
  If clalev([F:YITV0])  Then : Close Local File  [F:YITV0] : Endif

  If !clalev([F:YITM1]) Then : Local File ITMMASTER [F:YITM1] : Endif
  Read [F:YITM1]ITM0 = [M:ITM0]ITMREF
  If !fstat Then
    If LSUMPHYSTO > 0 Then
#      Trbegin [F:YITM1]
      LRDO = LDIVIDENDO / LSUMPHYSTO
      [M:YITM11]YPMP = LRDO
      [F:YITM1]YPMP = LRDO
#Infbox "ANTES REWRITE"
#      Rewrite [F:YITM1]
#Infbox "DESPUÉS REWRITE"
#      If !fstat Then
#Infbox "ANTES COMMIT"
#        Commit
#Infbox "DESPUÉS COMMIT"
#      Else
#Infbox "ANTES ROLLBACK"
#        Rollback
#Infbox "DESPUÉS ROLLBACK"
#      Endif
    Else
#      Trbegin [F:YITM1]
      [M:YITM11]YPMP = 0
      [F:YITM1]YPMP  = 0
#Infbox "ANTES REWRITE"
#      Rewrite [F:YITM1]
#Infbox "DESPUÉS REWRITE"
#      If !fstat Then
#Infbox "ANTES COMMIT"
#        Commit
#Infbox "DESPUÉS COMMIT"
#      Else
#Infbox "ANTES ROLLBACK"
#        Rollback
#Infbox "DESPUÉS ROLLBACK"
#      Endif
    Endif
  Endif
  If clalev([F:YITM1])  Then : Close Local File     [F:YITM1] : Endif

  Affzo [M:YITM11]STOFCY,AVC,YPMP

Return

##############################################################
# IN19
# rellena el campo "Fecha última entrada" (IPTDAT) y "Fecha última compra" (ORDDAT)
$GET_DATES
Local Integer LCON1, LCON2 : Raz LCON1, LCON2

  If !clalev([F:YFCY]) Then : Local File FACILITY [F:YFCY] : Endif
  If !clalev([F:YSMD]) Then : Local File SMVTD    [F:YSMD] : Endif
  If !clalev([F:YSMH]) Then : Local File SMVTH    [F:YSMH] : Endif
  If !clalev([F:YPOQ]) Then : Local File PORDERQ  [F:YPOQ] : Endif
  For [YFCY]
    # muestra el campo "Fecha última entrada" (IPTDAT)
    Filter [F:YSMD] Where ITMREF = [M:ITM0]ITMREF and (left$(VCRNUM,2) = [F:YFCY]FCY) Order By VCRNUM Desc  # filtra en la tabla SMVTD por artículo y codigo de planta en el contador de entrada
    Read [F:YSMD] First
    If !fstat Then
      Filter [F:YSMH] Where VCRNUM = [F:YSMD]VCRNUM                                                         # si existe filtra en la tabal SMVTH por código de entrada
      Read [F:YSMH]First
      If !fstat Then
        For LCON1 = 0 To [M:YITM11]NBPMP-1
          If [M:YITM11]STOFCY(LCON1) = [F:YFCY]FCY Then                                                     # si existe busca en el grid la planta y rellena el campo fecha última entrada
            [M:YITM11]IPTDAT(LCON1) = [F:YSMH]IPTDAT
            Affzo [M:YITM11]IPTDAT(LCON1)
          Endif
        Next
      Endif
    Endif
    Filter [F:YSMD]

    # muestra el campo "Fecha última compra" (ORDDAT)
    Filter [F:YPOQ] Where ITMREF = [M:ITM0]ITMREF and POHFCY = [F:YFCY]FCY Order By ORDDAT Desc         # filtra en la tabla PORDERQ por artículo y planta
    Read [F:YPOQ] First
    If !fstat Then
      For LCON2 = 0 To [M:YITM11]NBPMP-1                                                                # si existe busca en el grid la planta y rellena el campo fecha última compra
        If [M:YITM11]STOFCY(LCON2) = [F:YFCY]FCY Then
          [M:YITM11]ORDDAT(LCON2) = [F:YPOQ]ORDDAT
          Affzo [M:YITM11]ORDDAT(LCON2)
        Endif
      Next
    Endif
    Filter [F:YPOQ]
  Next
  If clalev([F:YPOQ])  Then : Close Local File [F:YPOQ] : Endif
  If clalev([F:YFCY])  Then : Close Local File [F:YFCY] : Endif
  If clalev([F:YSMD])  Then : Close Local File [F:YSMD] : Endif
  If clalev([F:YSMH])  Then : Close Local File [F:YSMH] : Endif
Return

##############################################################
# IN19
# rellena el campo "Precio reposición proveedor principal" (IPTDAT)
$GET_PRIREP
Local Decimal LPRI, LDESC1, LDESC2, LDESC3, LDESC4, LDESC5, LBONIF1, LBONIF2 : Raz LPRI, LDESC1, LDESC2, LDESC3, LDESC4, LDESC5, LBONIF1, LBONIF2
Local Decimal LIPTDAT : Raz LIPTDAT
Local Integer LCON3 : Raz LCON3

  If !clalev([F:YITP]) Then : Local File ITMBPS     [F:YITP] : Endif
  If !clalev([F:YPP1]) Then : Local File PPRICLIST  [F:YPP1] : Endif
  If !clalev([F:YPP2]) Then : Local File PPRICLIST  [F:YPP2] : Endif
  Filter [F:YITP] Where ITMREF = [M:ITM0]ITMREF and PIO = 0
  Read [F:YITP] First
  If !fstat Then
    Filter [F:YPP2] Where PLI = "T30" and PLICRI1 = [F:YITP]BPSNUM and PLICRI2 = [F:YITP]YSECC2 #and PLISTRDAT >= date$ and PLIENDDAT <= date$ AND ACTIVA?????
    Read [F:YPP2] First
    If !fstat Then
      LDESC1  = [F:YPP2]DCGVAL(0)
      LDESC2  = [F:YPP2]DCGVAL(1)
      LBONIF1 = [F:YPP2]DCGVAL(2)
    Endif
    Filter [F:YPP2]

    Filter [F:YPP1] Where PLI = "T20" and PLICRI1 = [F:YITP]BPSNUM and PLICRI2 = [F:YITP]ITMREF #and PLISTRDAT >= date$ and PLIENDDAT <= date$ AND ACTIVA?????
    Read [F:YPP1] First
    If !fstat Then
      LPRI     = [F:YPP1]PRI
      LDESC3   = [F:YPP1]DCGVAL(3)
      LDESC4   = [F:YPP1]DCGVAL(4)
      LDESC5   = [F:YPP1]DCGVAL(5)
      LBONIF2  = [F:YPP1]DCGVAL(6)
    Endif
    Filter [F:YPP1]
  Endif
  Filter [F:YITP]
  If clalev([F:YITP])  Then : Close Local File  [F:YITP] : Endif
  If clalev([F:YPP1])  Then : Close Local File  [F:YPP1] : Endif
  If clalev([F:YPP2])  Then : Close Local File  [F:YPP2] : Endif

  LIPTDAT = LPRI
  If LDESC1 <> 0 Then
    LIPTDAT = ar2(LIPTDAT * (1-(LDESC1/100)))
  Endif
  If LDESC2 <> 0 Then
    LIPTDAT = ar2(LIPTDAT * (1-(LDESC2/100)))
  Endif
  If LBONIF1 <> 0 Then
    LIPTDAT = ar2(LIPTDAT - LBONIF1)
  Endif
  If LDESC3 <> 0 Then
    LIPTDAT = ar2(LIPTDAT * (1-(LDESC3/100)))
  Endif
  If LDESC4 <> 0 Then
    LIPTDAT = ar2(LIPTDAT * (1-(LDESC4/100)))
  Endif
  If LDESC5 <> 0 Then
    LIPTDAT = ar2(LIPTDAT * (1-(LDESC5/100)))
  Endif
  If LBONIF2 <> 0 Then
    LIPTDAT = ar2(LIPTDAT - LBONIF2)
  Endif

  For LCON3 = 0 To [M:YITM11]NBPMP-1
    [M:YITM11]YPRI(LCON3) = LIPTDAT
    Affzo [M:YITM11]YPRI(LCON3)
  Next

Return

##############################################################
# IN19
# rellena el campo "Coste de referencia"
$GET_YPRISTD
  If !clalev([F:YITM0]) Then : Local File ITMMASTER [F:YITM0] : Endif
  Read [F:YITM0]ITM0 = [M:ITM0]ITMREF
  If !fstat Then
    [M:YITM11]YPRISTD = [F:YITM0]YPRISTD
  Endif
  Affzo [M:YITM11]YPRISTD
  If clalev([F:YITM0])  Then : Close Local File     [F:YITM0] : Endif

Return

##############################################################
# IN19
$GET_ADR

  If !clalev([F:YADR0]) Then : Local File YADR  [F:YADR0] : Endif
  Read [F:YADR0]YADR0 = [M:ITM0]ITMREF
  If !fstat Then
    [M:YITM11]  = [F:YADR0]
    Affzo [M:YITM11]GESADR,EXEADR,IMPFICHA,YBPSNUM,YBPSNUM2,CDGONU,GENDES,REVADR,DETDES,FACPELIGRO,GROWEIADR,NETWEIADR
  Endif
  If clalev([F:YADR0])  Then : Close Local File [F:YADR0] : Endif

Return

##############################################################
# IN19
$CRE_ADR

  If !clalev([F:YADR0]) Then : Local File YADR  [F:YADR0] : Endif
  [F:YADR0]ITMREF = [M:ITM0]ITMREF
  [F:YADR0]       = [M:YITM11]
  Write [F:YADR0]
  If [S]fstat                                   # si no se puede crear el campo
    [V]GOK = 0
  Endif
  If clalev([F:YADR0])  Then : Close Local File [F:YADR0] : Endif

Return

##############################################################
# IN19
$MOD_ADR

  If !clalev([F:YADR0]) Then : Local File YADR  [F:YADR0] : Endif
  Read [F:YADR0]YADR0 = [M:ITM0]ITMREF
  If !fstat Then
    [F:YADR0] = [M:YITM11]
    Rewrite   [F:YADR0]
    If [S]fstat                                  # si no se puede modificar el campo
      [V]GOK = 0
    Endif
  Else
    [F:YADR0]ITMREF = [M:ITM0]ITMREF
    [F:YADR0]       = [M:YITM11]
    Write   [F:YADR0]
    If [S]fstat                                  # si no se puede modificar el campo
      [V]GOK = 0
    Endif
  Endif
  If clalev([F:YADR0])  Then : Close Local File [F:YADR0] : Endif

Return

##############################################################
# IN19
$DEL_ADR

  If !clalev([F:YADR0]) Then : Local File YADR  [F:YADR0] : Endif
  Readlock [F:YADR0]YADR0 = [M:ITM0]ITMREF
  If !fstat Then
    Delete [F:YADR0]
    If [S]fstat                                  # si no se puede eliminar el campo
      [V]GOK = 0
    Endif
  Endif
  If clalev([F:YADR0])  Then : Close Local File [F:YADR0] : Endif

Return


