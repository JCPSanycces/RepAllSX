#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif

Case ACTION
  When "SEL_TABLE"    : Gosub SEL_TABLE
  When "INIT"         : Gosub INIT
  When "DEBUT"        : Gosub DEBUT
  When "BOUTON"       : Gosub BOUTON
  When "OK"           : Gosub OK_
  When "CONTROLE"     : Gosub CONTROLE
  When "EXEC"         : Gosub EXEC
  When "TERMINE"      : Gosub TERMINE
  When "SORTIE"       : Gosub SORTIE
  When "OUVRE"        : Gosub OUVRE
  When "PREDLVFIL"    : Gosub PREDLVFIL
  When Default
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
########################################################################
$SEL_TABLE
  Case TABLE
    When "YPREDLV"  : Gosub SEL_YPREDLV
  Endcase
Return

########################################################################
$SEL_YPREDLV

  If !clalev([F:YPRL]) Then : Local File YVISPRELIS [F:YPRL] : Endif
  Default File [YPRL]
  Filter [F:YPRL] Where STOFCY = [M:PDL]STOFCY
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Lista de preparación"                                          # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Nº lista"                                                      # título de la primera columna
  COL(NBCOL)  = "PRLNUM"                                                        # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Planta"                                                        # título de la segunda columna
  COL(NBCOL)  = "STOFCY"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Sociedad"                                                      # título de la tercera columna
  COL(NBCOL)  = "LEGCPY"                                                        # nombre del campo a mostrar en la tercera columna

Return

##############################################################
$INIT
  If GPARAM4(0) = "DESDE_YEXP" Then                 # ejecuta el estándar si viene del desarrollo de Expediciones
    Gosub INIT From FUNPREDLV
    GPE=1
  Endif
Return

##############################################################
$DEBUT
  If GPARAM4(0) = "DESDE_YEXP" Then
    Gosub DEBUT_TRTPREDLV From FUNPREDLV
    [M:PDL]CPY    = GPARAM4(1)
    [M:PDL]STOFCY = GPARAM4(2)
    [M:PDL]FLG1   = 2
    [M:PDL]FLG2   = 2
    [M:PDL]FLG3   = 2
    [M:PDL]DRNSTR = 1
    [M:PDL]DRNEND = 3
    [M:PDL]NDEFLG = 2
    Affzo [M:PDL]CPY, STOFCY, FLG1, FLG2, FLG3, DRNSTR, DRNEND, NDEFLG
    GPE=1
  Endif
Return

##############################################################
$BOUTON
#Infbox BOUT
  If GPARAM4(0) = "DESDE_YEXP" Then                 # ejecuta el estándar si viene del desarrollo de Expediciones
    Gosub BOUT_TRTPREDLV From FUNPREDLV
#    Gosub ACTION From FUNPREDLV
    GPE=1
  Endif
Return

##############################################################
$OK_
  If GPARAM4(0) = "DESDE_YEXP" Then                 # ejecuta el estándar si viene del desarrollo de Expediciones
    Gosub OK_TRTPREDLV  From FUNPREDLV
    Gosub CONTROLE      From FUNPREDLV
    Gosub EXEC          From FUNPREDLV
    Gosub TERMINE       From FUNPREDLV
    GPE=1
  Endif
Return

##############################################################
$CONTROLE
  If GPARAM4(0) = "DESDE_YEXP" Then                 # ejecuta el estándar si viene del desarrollo de Expediciones
    Gosub CONTROLE From FUNPREDLV
    GPE=1
  Endif
Return

##############################################################
$EXEC
  If GPARAM4(0) = "DESDE_YEXP" Then                 # ejecuta el estándar si viene del desarrollo de Expediciones
    Gosub EXEC From FUNPREDLV
    GPE=1
  Endif
Return

##############################################################
$TERMINE
  If GPARAM4(0) = "DESDE_YEXP" Then                 # ejecuta el estándar si viene del desarrollo de Expediciones
    Gosub TEMINE From FUNPREDLV
    GPE=1
  Endif
Return

##############################################################
$SORTIE
  If GPARAM4(0) = "DESDE_YEXP" Then                 # ejecuta el estándar si viene del desarrollo de Expediciones
    Gosub SORTIE From FUNPREDLV
    GPE=1
  Endif
Return

##############################################################
$OUVRE
  If GPARAM4(0) = "DESDE_YEXP" Then                 # ejecuta el estándar si viene del desarrollo de Expediciones
    Gosub INIT          From FUNPREDLV
#    Gosub ACTION From FUNPREDLV
    Gosub OUVRE From FUNPREDLV
    GPE=1
  Endif
Return

##############################################################
# punto de entrada para que sólo genere las entregas de la lista indicada
$PREDLVFIL
  FILSUPENT = 'PRLNUM = "' + [M:PDL]YPRLNUM + '"'
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
