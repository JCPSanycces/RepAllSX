#**
#* envía el correo
#*
#* @param PMAIL    > dirección de correo
#* @param PRTDIR   > ruta absoluta
#*!
Subprog SEND_MAIL(PMAIL, PRTDIR)
Value   Char    PMAIL
Value   Char    PRTDIR

Local Char    L_EMAIL(100)
Local Char    L_EXPMAIL(250), LPCE(200), L_ASUNTO(50), LFICPDF(30)
Local Integer L_ENVOI(1..1) , L_SUIVI(1..1)
Local Char    L_CUERPO(255)

L_EXPMAIL   = adxmac(-1)
L_EMAIL     = PMAIL
L_ENVOI     = 2
L_CUERPO    = "Estimado cliente. Adjuntamos las facturas pertenecientes al periodo de facturación desde el xx al xx"+chr$(10)+chr$(13)
&           +" Saludos!"
L_ASUNTO   = "Facturación mensual"
#LFICPDF  = ""
#LPCE=filpath("TRA",NUMTRAZA,"tra")

    Call ENVOI_MAIL(2,          1,          0,        GUSER,
&                   L_EXPMAIL,  "",         "",       num$(adxuid(1)),    0,
&                   L_EMAIL,    L_ENVOI,    L_SUIVI,  1,
&                   L_CUERPO,   L_ASUNTO,   PRTDIR,
&                   1,          "",         0,        "") From AWRKMEL

#Call ENVOI_MAIL(2,1,0,USUARIO,adxmac(-1),"","",num$(adxuid(1)),0,CORREO,2,L_SUIVI,1,CUERPO,ASUNTO,ADJUNTO,1,"",0,"")

End

