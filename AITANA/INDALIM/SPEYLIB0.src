###############################################################################
#**
#* Limpia los caracteres extraños de una cadena
#*
#* @param PSTR Cadena a limpiar
#* @param PCLEANSTR Cadena a limpiar
#*!
Subprog LIMPIA_STR(PSTR, CLEANSTR)
Value Char    PSTR
Variable Char CLEANSTR

PSTR=ctrans(PSTR,"á" ,"a") : PSTR=ctrans(PSTR,"à" ,"a") : PSTR=ctrans(PSTR,"ä" ,"a")
PSTR=ctrans(PSTR,"â" ,"a") : PSTR=ctrans(PSTR,"ª" ,"a") : PSTR=ctrans(PSTR,"Á" ,"A")
PSTR=ctrans(PSTR,"À" ,"A") : PSTR=ctrans(PSTR,"Â" ,"A") : PSTR=ctrans(PSTR,"Ä" ,"A")
PSTR=ctrans(PSTR,"é" ,"e") : PSTR=ctrans(PSTR,"è" ,"e") : PSTR=ctrans(PSTR,"ë" ,"e")
PSTR=ctrans(PSTR,"ê" ,"e") : PSTR=ctrans(PSTR,"É" ,"E") : PSTR=ctrans(PSTR,"È" ,"E")
PSTR=ctrans(PSTR,"Ê" ,"E") : PSTR=ctrans(PSTR,"Ë" ,"E") : PSTR=ctrans(PSTR,"í" ,"i")
PSTR=ctrans(PSTR,"ì" ,"i") : PSTR=ctrans(PSTR,"ï" ,"i") : PSTR=ctrans(PSTR,"î" ,"i")
PSTR=ctrans(PSTR,"Í" ,"I") : PSTR=ctrans(PSTR,"Ì" ,"I") : PSTR=ctrans(PSTR,"Ï" ,"I")
PSTR=ctrans(PSTR,"Î" ,"I") : PSTR=ctrans(PSTR,"ó" ,"o") : PSTR=ctrans(PSTR,"ò" ,"o")
PSTR=ctrans(PSTR,"ö" ,"o") : PSTR=ctrans(PSTR,"ô" ,"o") : PSTR=ctrans(PSTR,"Ó" ,"O")
PSTR=ctrans(PSTR,"Ò" ,"O") : PSTR=ctrans(PSTR,"Ö" ,"O") : PSTR=ctrans(PSTR,"Ô" ,"O")
PSTR=ctrans(PSTR,"ú" ,"u") : PSTR=ctrans(PSTR,"ù" ,"u") : PSTR=ctrans(PSTR,"ü" ,"u")
PSTR=ctrans(PSTR,"û" ,"u") : PSTR=ctrans(PSTR,"Ú" ,"U") : PSTR=ctrans(PSTR,"Ù" ,"U")
PSTR=ctrans(PSTR,"Û" ,"U") : PSTR=ctrans(PSTR,"Ü" ,"U") : PSTR=ctrans(PSTR,"ñ" ,"n")
PSTR=ctrans(PSTR,"Ñ" ,"N") : PSTR=ctrans(PSTR,"ç" ,"c") : PSTR=ctrans(PSTR,"Ç" ,"C")
PSTR=ctrans(PSTR,"\" ,"")  : PSTR=ctrans(PSTR,"¨" ,"")  : PSTR=ctrans(PSTR,"º" ,"")
PSTR=ctrans(PSTR,"~" ,"")  : PSTR=ctrans(PSTR,"#" ,"")  : PSTR=ctrans(PSTR,"@" ,"")
PSTR=ctrans(PSTR,"|" ,"")  : PSTR=ctrans(PSTR,"!" ,"")  : PSTR=ctrans(PSTR,'"' ,"")
PSTR=ctrans(PSTR,"*" ,"")  : PSTR=ctrans(PSTR,"·" ,"")  : PSTR=ctrans(PSTR,"$" ,"")
PSTR=ctrans(PSTR,"%" ,"")  : PSTR=ctrans(PSTR,"&" ,"")  : PSTR=ctrans(PSTR,"(" ,"")
PSTR=ctrans(PSTR,")" ,"")  : PSTR=ctrans(PSTR,"?" ,"")  : PSTR=ctrans(PSTR,"'" ,"")
PSTR=ctrans(PSTR,"¡" ,"")  : PSTR=ctrans(PSTR,"¿" ,"")  : PSTR=ctrans(PSTR,"[" ,"")
PSTR=ctrans(PSTR,"^" ,"")  : PSTR=ctrans(PSTR,"<" ,"")  : PSTR=ctrans(PSTR,">" ,"")
PSTR=ctrans(PSTR,"]" ,"")  : PSTR=ctrans(PSTR,"+" ,"")  : PSTR=ctrans(PSTR,"}" ,"")
PSTR=ctrans(PSTR,"{" ,"")  : PSTR=ctrans(PSTR,"´" ,"")  : PSTR=ctrans(PSTR,";" ,"")
PSTR=ctrans(PSTR," " ,"")  : PSTR=ctrans(PSTR,":" ,"")  : PSTR=ctrans(PSTR,"," ,"")
PSTR=ctrans(PSTR,"/" ,"")  : PSTR=ctrans(PSTR,"." ,"")

CLEANSTR = PSTR

End


###############################################################################
#**
#* Borrar Fichero - MS-DOS mode (no sandbox)
#*
#* @param FICHERO
#* @param STAT
#*!
Subprog BORRAR(FICHERO, STAT)
Value Char       FICHERO
Variable Integer STAT

Local    Char    ORDSYS(255)

  ORDSYS = 'DEL /Q "' + FICHERO + '"'
  Call SYSTEME(adxmac(0), ORDSYS, "", STAT) From ORDSYS
End



###############################################################################
#**
#* Comprobar existencia Fichero - MS-DOS mode (no sandbox)
#*
#* @param PATH_FILE
#* @param COUNT
#*
#*!
Subprog CHECK_FILE(PATH_FILE,COUNT)
Value    Char     PATH_FILE
Variable Integer  COUNT

Local Char    ORDSYS(255), WFILE(90)
Local Integer I, COUNT
#
Raz COUNT
ORDSYS = 'dir /a:-d /b "' + PATH_FILE + '"'  # Excluir los directorios
Call SYSTEME2(adxmac(0), ORDSYS, "", I, WFILE) From ORDSYS
If pat(PATH_FILE, "*" + WFILE + "*")
  COUNT = 1
Else
  COUNT = 0
Endif
  #
End

#####################################################################
#**
#* descarga un documento
#*
#* @param PINFNAM   > nombre del informe
#* @param PVOLNAM   > nombre del volúmen
#*!
Subprog DESCARGA_DOC(PINFNAM, PVOLNAM)
Value     Char    PINFNAM
Value     Char    PVOLNAM

Local Char    ZURL(255)

  ZURL  = "//x3indalim.westeurope.cloudapp.azure.com:8124/sdata/x3/erp/PROTO/BDOC('C_AVOLFIL~%C2%A8~CONTENTS~%C2%A8~"
  ZURL += PVOLNAM
  ZURL += "~%C2%A8~"
  ZURL += PINFNAM + "')"

  Callui RETORNO ="" With "UIAction="+chr$(1)+"OpenFile",
& "UILocalDir="+ chr$(1) +"HTTP",
& "UILocalFile="+ chr$(1) + ZURL
& ,
& "UIAdxPubSubFile="+ chr$(1) + "1"

End

