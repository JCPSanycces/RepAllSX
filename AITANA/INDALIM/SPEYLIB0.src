#######################
#**
#* obtiene el proveedor principal de un artículo
#*
#* @param PITMREF  > código de artículo
#* @param PBPSPRI  > devuelve el proveedor principal
#*!
Subprog GET_BPSPRI(PITMREF, PBPSPRI)
Variable  Char    PBPSPRI
Value     Char    PITMREF

  If !clalev([F:YITP]) Then  : Local File ITMBPS  [F:YITP] : Endif
  Filter [YITP] Where ITMREF = PITMREF and PIO = 0                                          # proveedor principal PIO_= 0, el resto <> 0
  Read [YITP] First
  If !fstat Then
    PBPSPRI = [F:YITP]BPSNUM                                                                # devuelve el proveedor principal
  Else
    Raz PBPSPRI
  Endif
  Filter [YITP]
  If clalev([F:YITP])  Then  : Close Local File  [F:YITP] : Endif

End

#######################
#**
#* obtiene el correo electrónico de una dirección en un cliente
#*
#* @param PBPANUM  > código del cliente
#* @param PBPAADD  > código de la dirección
#* @param PWEB     > devuelve el correo electrónico de esa dirección
#*!
Subprog GET_EMAIL(PBPANUM, PBPAADD, PWEB)
Value     Char    PBPANUM
Value     Char    PBPAADD
Variable  Char    PWEB

  If !clalev([F:YBPA]) Then  : Local File BPADDRESS  [F:YBPA] : Endif
  Filter [YBPA] Where BPANUM = PBPANUM and BPAADD = PBPAADD
  Read [F:YBPA] First
  If !fstat Then
    PWEB = [F:YBPA]WEB(0)                                                                # devuelve la dirección de correo
  Else
    Raz PWEB
  Endif
  Filter [YBPA]
  If clalev([F:YBPA])  Then  : Close Local File  [F:YBPA] : Endif

End

#######################

#**
#* obtiene el directorio mapeada y el archivo adjunto al albarán
#* además envía el documento a la salida
#*
#* @param PSDHNUM  > número de albarán
#* @param PTYPE    > tipo de salida del documento
#* @param PMAIL    > dirección de correo electrónico
#*!
Subprog GET_MAPFIL(PSDHNUM, PTYPE, PMAIL)
Value     Char    PSDHNUM
Value     Integer PTYPE         # 1 = envío por correo ; 2 = envío a impresora
Value     Char    PMAIL

Local Integer LPOS, LCTRL, LOKALB   : Raz LPOS, LCTRL, LOKALB
Local Char    LDIRABS(250)
Local Char    PDIRMAP(250)
Local Char    PNOMFIL(250)

  If !clalev([F:YAOX]) Then : Local File AOBJTXT [F:YAOX] : Endif
  Filter [F:YAOX] Where IDENT1 = PSDHNUM and ABREV = "SDH"
  For [YAOX]
    LPOS    = instr(1,[F:YAOX]NAM,"/")
    PDIRMAP = mid$(left$([F:YAOX]NAM,LPOS-1),2,len(left$([F:YAOX]NAM,LPOS-1))-2)
    PNOMFIL = right$([F:YAOX]NAM,LPOS+1)
    Call GET_DIRFIL(PDIRMAP,LDIRABS)
    If PTYPE = 1 Then                                                   # envío por correo
      If LCTRL = 0 Then                                                     # recopila todos los albaranes asociados a la factura
        PADJFIL = "'"+LDIRABS+"\"+PNOMFIL+"'"
        LCTRL = 1
      Else
        PADJFIL += ";'"+LDIRABS+"\"+PNOMFIL+"'"
      Endif
    Elsif PTYPE = 2                                                     # envío a impresora
      PADJFIL = LDIRABS+"\"+PNOMFIL
      Call GEN_PDFSDH(PSDHNUM,PADJFIL,LOKALB)
    Endif
  Next
  If PTYPE = 1 Then                                                     # envía el correo
    PADJFIL = "C:\Sage\SAGEX3V11\folders\DEVELOP\Albaranes_firmados\DebugarEnX3.pdf"
    PMAIL   = "joseluis.chiva@aitana.es"
    Call SEND_MAIL2(PMAIL,PADJFIL)
  Endif
  Filter [F:YAOX]
  If clalev([F:YAOX])  Then : Close Local File [F:YAOX]   : Endif

End

#######################

#**
#* obtiene el directorio mapead y el archivo adjunto al albarán
#*
#* @param PVOLUME  > nombre del mapeo
#* @param PRTDIR   > ruta absoluta
#*!
Subprog GET_DIRFIL(PVOLUME, PRTDIR)
Value     Char    PVOLUME
Variable  Char    PRTDIR

  If !clalev([F:YAVL]) Then : Local File AVOLUME [F:YAVL] : Endif
  Read [F:YAVL]CODE = PVOLUME
  PRTDIR = [F:YAVL]ROOT
  If clalev([F:YAVL])  Then : Close Local File [F:YAVL]   : Endif

End

