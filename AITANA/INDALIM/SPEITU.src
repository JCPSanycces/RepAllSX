## Después de modificar el campo 'Clasificación web' (pantalla ITU) 21/12/2020 17:34:49 (AIT07)
######################################################################################
Subprog AM_XYCLAWEB(VALEUR)
# JC.22122020.YSP08.STR
Variable Char    VALEUR()
  [M:ITU]YCLAWEB(nolign-1) = VALEUR
  Affzo [M:ITU]YCLAWEB(nolign-1)
# JC.22122020.YSP08.END
End

######################################################################################
## Antes de entrar en el grid (pantalla ITU) 22/12/2020 10:11:54 (AIT07)
######################################################################################
Subprog AS_NBITU
# JC.22122020.YSP08.STR
  [M:ITU]XYCLAWEB = [M:ITU]YCLAWEB(nolign-1)
  Affzo [M:ITU]XYCLAWEB
# JC.22122020.YSP08.END
End
