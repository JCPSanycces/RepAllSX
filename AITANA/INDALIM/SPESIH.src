#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "SETBOUT"  : Gosub SETBOUT
  When "AFFMASK"  : Gosub AFFMASK
  When "INIMOD"   : Gosub INIMOD
  When "INICRE"   : Gosub INICRE
  When "STATUT"   : Gosub STATUT
  When "RAZDUP"   : Gosub RAZDUP
  When "RAZCRE"   : Gosub RAZCRE
  When "ANNULE"   : Gosub ANNULE
  When "ABANDON"  : Gosub ABANDON
  When "EXEBOUT"  : Gosub EXEBOUT
 When Default
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
#YA032 - Textos de cabecera traspasables
$SETBOUT
# Le indicamos que vaya primero al SUB
Gosub ACTION From SUBSIH
Global Char TABLETEX
#boton cabecera traspasable
CHMEN += "B"
Gosub SET_BOUT_SPE From GSAISIE

# Que no vuelva a ejecutar el la parte del SUB
GPE=1
  # <YDPDF>: Generación y envío de documentos PDF
  If GREP<>"" or !CLECUR
    Call VIREBOUT(CHAINE, "y") From GOBJET
  Endif
  # </YDPDF>
Return

$AFFMASK
# <YA032> - Textos de Cabecera Traspasables
Gosub ACTION From SUBSIH
GPE = 1

Case GFONC1
  When "GESSQH"
    If !clalev([F:YSQH]) : Local File SQUOTE [F:YSQH]   : Endif
    If !clalev([F:YSIH]) : Local File SINVOICE [F:YSIH] : Endif

    Read [F:YSQH]SQH0 = [M:SQH0]SQHNUM
    If !fstat
      Update [F:YSIH] Where NUM = [F:SIH]NUM With YSIHTEX = [F:YSQH]YSQHTEX
      If fstat
        Call FSTA ("YSIH") From GLOCK
      Endif
      ##If [M:SIH0]YSIHTEX<>"" | [F:YSQH]YSQHTEX <> ""
      ##  [M:SIH0]YSIHTEX = [F:YSQH]YSQHTEX
      ##  [F:SIH]YSIHTEX  = [M:SIH0]YSIHTEX
      ##Endif
    Endif

  When "GESSOH"
    If !clalev([F:YSOH]) : Local File SORDER [F:YSOH] : Endif
    If !clalev([F:YSIH]) : Local File SINVOICE [F:YSIH] : Endif

    Read [F:YSOH]SOH0 = [M:SOH0]SOHNUM
    If !fstat
      Update [F:YSIH] Where NUM = [F:SIH]NUM With YSIHTEX = [F:YSOH]YSOHTEX
      If fstat
        Call FSTA ("YSIH") From GLOCK
      Endif
      ##If [M:SIH0]YSIHTEX<>"" | [F:YSOH]YSOHTEX <> ""
      ##  [M:SIH0]YSIHTEX = [F:YSOH]YSOHTEX
      ##  [F:SIH]YSIHTEX  = [M:SIH0]YSIHTEX
      ##Endif
    Endif
Endcase

# </YA032>
Return

##############################################################
$INIMOD
Gosub ACTION From SUBSIH
If [M:SIH0]YSIHTEX<>""
   #If left$([M:SIH0]YSIHTEX,3)="SIH"
      #si no existe creamos el clob
      Call CRE_CLOB([M:SIH0]YSIHTEX,GOK) From TRTX3TEX
      #Infbox("Creacion " - [M:SIH0]YSIHTEX)
      If GOK<1 Return Endif

   #Endif
   [F:SIH]YSIHTEX = [M:SIH0]YSIHTEX
Else
     #borra la cabecera traspasable vacia
   If left$(TABLETEX,3)="SIH"
      Call SUP_CLOB(TABLETEX,WRET) From TRTX3TEX
   Endif
Endif

GPE=1
Return

##############################################################
$INICRE
Gosub ACTION From SUBSIH
If [M:SIH0]YSIHTEX<>""
      #si no existe creamos el clob
   Call CRE_CLOB([M:SIH0]YSIHTEX,GOK) From TRTX3TEX
   If GOK<1 Return Endif
   [F:SIH]YSIHTEX = [M:SIH0]YSIHTEX
Else
  If dim (TABLETEX) >= 0
   #borra la cabecera traspasable vacia
   If left$(TABLETEX,3)="SIH"
      Call SUP_CLOB(TABLETEX,WRET) From TRTX3TEX
   Endif
  Endif
Endif
GPE=1
Return

##############################################################
$STATUT
TABLETEX = [F:SIH]YSIHTEX
Gosub ACTION From SUBSIH
Case BOUT
    When "B"  :   If mkstat=4 & GREP=""
#                      GREP="M" : REP="M"
#                      Gosub SETBOUT From GOBJSUB
                       Gosub ENTRE_MODIF From GOBJSUB
                   Endif
                   If [M]YSIHTEX <> "" & !GIMPORT
                       Call SET_IMAGE (4) From GESECRAN
                   Elsif !GIMPORT
                       Call RESET_IMAGE (4) From GESECRAN
                   Endif

Endcase
GPE=1
Return

##############################################################
$RAZCRE
Gosub ACTION From SUBSIH
Raz [M:SIH0]YSIHTEX
#Infbox "GFLAG ES" + num$(GFLAG)
If num$(GFLAG) = "ALL" Then
 [M:SIH0]SIVTYP = "SI"
 Affzo [M:SIH0]SIVTYP
Else
If num$(GFLAG) = "STD" Then
 [M:SIH0]SIVTYP = "SI"
 Affzo [M:SIH0]SIVTYP
Endif
Endif
GPE=1
Return

##############################################################
$RAZDUP
Gosub ACTION From SUBSIH
If left$([M:SIH0]YSIHTEX,3)="SIH"
  Call DUP_CLOB("SIH",[M:SIH0]YSIHTEX,WRET) From TRTX3TEX
  If WRET<1 Raz [M:SIH0]YSIHTEX Endif
Endif

GPE=1
Return

##############################################################
$ANNULE
Gosub ACTION From SUBSIH

If left$([F:SIH]YSIHTEX,3)="SIH"
   Call SUP_CLOB([F:SIH]YSIHTEX,WRET) From TRTX3TEX
Endif
GPE=1
Return

##############################################################
$ABANDON
Gosub ACTION From SUBSIH
If GREP = "D" & GREP <> "M"
  If left$([M:SIH0]YSIHTEX,3)="SIH"
        Call SUP_CLOB([M:SIH0]YSIHTEX,WRET) From TRTX3TEX
  Endif
Endif
GPE=1
Return

##############################################################
# YA032
$EXEBOUT
Local Integer LSTAT : Raz LSTAT
  Case BOUT
    When "y"
      # <YDPDF>: Generación y envío de documentos PDF
      Gosub RELIT From GOBJSUB
    When "s"  : Call ENVMAIL_SIH([M:SIH0]NUM,"ZSBONFAC","ENVIOPDF",LSTAT) From SPEYLIB0                            # YRE04 - JC
  Endcase
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
# YA037 - Traer el código de articulo para el cliente
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()

If clalev ([F:ZITU])  = 0 : Local File ITMBPC  [ZITU] : Endif

Read [F:ZITU]ITU0 = VALEUR;[M:SIH0]BPCINV
If fstat = 0

  [M:SIH4]YITMCLI(nolign -1) = [F:ZITU]ITMDESBPC

  Affzo [M:SIH4]YITMCLI(nolign -1)

Endif
End

##############################################################
# YA034 - Tipo precio en Ventas
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

If clalev ([F:ZITM])  = 0 : Local File ITMMASTER  [ZITM] : Endif
Read [F:ZITM]ITM0 = VALEUR
If fstat = 0
  [M:SIH4]YTIPPRI(nolign -1) = [F:ZITM]YTIPPRI
  Affzo [M:SIH4]YTIPPRI(nolign -1)
Endif

 Case [M:SIH4]YTIPPRI(nolign -1)
  When 1 : [M:SIH4]YGROPRI(nolign -1) = [M:SIH4]GROPRI(nolign -1)
  When 2 : [M:SIH4]YGROPRI(nolign -1) = [M:SIH4]GROPRI(nolign -1) * 10
  When 3 : [M:SIH4]YGROPRI(nolign -1) = [M:SIH4]GROPRI(nolign -1) * 100
  When 4 : [M:SIH4]YGROPRI(nolign -1) = [M:SIH4]GROPRI(nolign -1) * 1000
Endcase
Affzo [M:SIH4]YGROPRI(nolign -1)

End

##############################################################
# YA034 - Tipo precio en Ventas
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR

Case [M:SIH4]YTIPPRI(nolign -1)
  When 1 : [M:SIH4]YGROPRI(nolign -1) = [M:SIH4]GROPRI(nolign -1)
  When 2 : [M:SIH4]YGROPRI(nolign -1) = [M:SIH4]GROPRI(nolign -1) * 10
  When 3 : [M:SIH4]YGROPRI(nolign -1) = [M:SIH4]GROPRI(nolign -1) * 100
  When 4 : [M:SIH4]YGROPRI(nolign -1) = [M:SIH4]GROPRI(nolign -1) * 1000
Endcase
Affzo [M:SIH4]YGROPRI(nolign -1)

End

##############################################################
# YA034 - Tipo precio en Ventas
Subprog AM_YGROPRI(VALEUR)
Variable Decimal VALEUR
Variable Decimal PRECIO

  Case [M:SIH4]YTIPPRI(nolign -1)
    When 1 : PRECIO  = VALEUR
    When 2 : PRECIO  = VALEUR / 10
    When 3 : PRECIO  = VALEUR / 100
    When 4 : PRECIO  = VALEUR / 1000
  Endcase

  # Actualizamos el campo standard
  [M:SIH4]GROPRI(nolign -1) = PRECIO
  Affzo [M:SIH4]GROPRI(nolign -1)

  #La acción es DIVDISCRG, pero llama al punto D_DISCRG
      Local Char    WABMSK    :    WABMSK="SIH4"
      Local Integer DISCRGNUM :    DISCRGNUM = 0
      Local Integer NOLIG     :    NOLIG=nolign-1

      If DISCRGNUM > 0 & DISCRGNUM < 10
         Assign "[M:"+WABMSK+"]DISCRGREN"+num$(DISCRGNUM)+"(NOLIG)" With GDACMANSAL
      Elsif DISCRGNUM = 0
         Assign "[M:"+WABMSK+"]PRIREN(NOLIG)" With GDACMANSAL
      Endif


  #Para suplir la acción DIVPRIPFM, llamamos a los siguientes subprogramas
  # --> Calcul du prix net
  Call CLCNETPRI([M]QTY(nolign-1), [M]CUR, nolign-1) From TRTVENPRI
  If GDACLOK = 1
      Call CTLNETPRI([M]BPCORD,[M]CHGTYP,[M]INVDAT,[M]CUR,nolign-1) From TRTVENPRI
      If mkstat=2 [M]SAUSTUCOE(nolign-1)=WANC_SAUSTUCOE : End : Endif
  Endif
  # --> Calcul de la marge
  Call CLCPFM([M]DSTOFCY(nolign-1), [M]PRITYP, [M]CHGTYP, [M]INVDAT, [M]CUR, nolign-1, 2) From TRTVENPRI
  If GDACLOK = 1
      Call CTLPFM([M]CUR,[M]CPRPRI(nolign-1), nolign-1) From TRTVENPRI
      If mkstat=2 [M]SAUSTUCOE(nolign-1)=WANC_SAUSTUCOE : End : Endif
  Endif
  If dim([M:SIH4]DISCRGVAL1(nolign-1))>0 Affzo [M:SIH4]DISCRGVAL1(nolign-1) Endif
  If dim([M:SIH4]DISCRGVAL2(nolign-1))>0 Affzo [M:SIH4]DISCRGVAL2(nolign-1) Endif
  If dim([M:SIH4]DISCRGVAL3(nolign-1))>0 Affzo [M:SIH4]DISCRGVAL3(nolign-1) Endif
  If dim([M:SIH4]DISCRGVAL4(nolign-1))>0 Affzo [M:SIH4]DISCRGVAL4(nolign-1) Endif
  If dim([M:SIH4]DISCRGVAL5(nolign-1))>0 Affzo [M:SIH4]DISCRGVAL5(nolign-1) Endif
  If dim([M:SIH4]DISCRGVAL6(nolign-1))>0 Affzo [M:SIH4]DISCRGVAL6(nolign-1) Endif
  If dim([M:SIH4]DISCRGVAL7(nolign-1))>0 Affzo [M:SIH4]DISCRGVAL7(nolign-1) Endif
  If dim([M:SIH4]DISCRGVAL8(nolign-1))>0 Affzo [M:SIH4]DISCRGVAL8(nolign-1) Endif
  If dim([M:SIH4]DISCRGVAL9(nolign-1))>0 Affzo [M:SIH4]DISCRGVAL9(nolign-1) Endif
  Affzo [M:SIH4]NETPRI(nolign-1), CPRPRI(nolign-1), PFM(nolign-1)


End

