#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
  When "ALIMSKSOH4" : Gosub ALIMSKSOH4
  When Default
  Endcase
Return

$ALIMSKSOH4
If ([M:POH0]BETCPY=2 or [M:POH0]BETFCY = 2) and [M:POH2]ORI=3 Then    ##XVT29-06-2020.n
#  Infbox [M:POH2]SOHNUM(NOLPOH-1)
  If !clalev ([F:ZSOQ]) : Local File SORDERQ[ZSOQ]:Endif
  Read [ZSOQ]SOQ0=[M:POH2]SOHNUM(NOLPOH-1);[M:POH2]SOPLIN(NOLPOH-1);[M:POH2]SOQSEQ(NOLPOH-1)
  If !fstat Then
  #  If GUSER = "ADMIN" or GUSER="JVIDA" : Infbox "GUSER: ZTRTVENISOC LO TENEMOS " + [ZSOQ]ZNUMFOU : Endif
#Infbox "actualizando"
    [M:SOH4]DSTOFCY(nolign-1)=[ZSOQ]ZNUMFOU
  #   If GUSER = "ADMIN" or GUSER="JVIDA" : Infbox "GUSER: ZTRTVENISOC [M:SOH4]DSTOFCY(NOLIGN-1)= " + [M:SOH4]DSTOFCY(nolign-1) : Endif
    #PARA QUE LA ANALÍTICA SEA CORRECTA
    If !clalev ([F:ZFCYCCE]): Local File FACILITY [ZFCYCCE] : Endif
    Read [F:ZFCYCCE]FCY0=[ZSOQ]ZNUMFOU
    If !fstat Then
      [M:SOH4]CCE1(nolign-1)=[ZFCYCCE]CCE(0)
      [M:SOH4]CCE2(nolign-1)=[ZFCYCCE]CCE(1)
      [M:SOH4]CCE3(nolign-1)=[ZFCYCCE]CCE(2)
    Endif
    #XVT30-12-2019.bn
    If !clalev ([F:ZSOP]) : Local File SORDERP[ZSOP]:Endif
    Read [ZSOP]SOP0=[M:POH2]SOHNUM(NOLPOH-1);[M:POH2]SOPLIN(NOLPOH-1);[M:POH2]SOQSEQ(NOLPOH-1)
    If !fstat Then
       [M:SOH4]ZGRADO(nolign-1)=[F:ZSOP]ZGRADO
       [M:SOH4]ZDENSIDAD(nolign-1)=[F:ZSOP]ZDENSIDAD
    Endif
    #XVT30-12-2019.en
  Else
    Infbox "Imposible actualizar planta de expedición. "
     GOK=0
  Endif
  Endif
Return

