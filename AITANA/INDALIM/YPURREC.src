#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
# If GUSER="AIT51" Then : Infbox ACTION : Endif
  Case ACTION
    When "OUVRE"   : Gosub OUVRE
    When "DEBUT"   : Gosub DEBUT
    When "SETBOUT" : Gosub SETBOUT
    When "BOUTON"  : Gosub BOUTON
    When "FIN"     : Gosub FIN
  Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
  If clalev([F:SIV])=0 : Local File SINVOICEV  [SIV] : Endif
  If clalev([F:SIH])=0 : Local File PINVOICE   [SIH] : Endif
  If clalev([F:BPR])=0 : Local File YVARTPRO   [YVRP] : Endif # VISTA ARTICULOS DE PROVEEDORES
  If clalev([F:BPC])=0 : Local File BPSUPPLIER [BPS] : Endif
  If clalev([F:AIM])=0 : Local File APRINTER   [AIM] : Endif
  If clalev([F:AVL])=0 : Local File AVOLUME    [AVL] : Endif

  If clalev([F:ATA])=0 : Local File ATABDIV    [ATA]  : Endif

  Local  Char    CRITERE(250), WRPTCOD(GLONARP), WCODAIM(GLONAIM), WYPATHPDF(250),
&                AUXCHAR(250), NOMFIC(250), WMSG(250), PATH_FILE(255), WVOL(GLONAVL)
  Local  Integer IS_FULL_TABLE, YSTA, WSEC, NBRFIC, STAT, NOL, AUXINT, NBERR
  Global Char    GYWNOMFIC(250)

  WRPTCOD = func AFNC.PARAM("YSIHRPTCOD", "")
  If WRPTCOD=""
    GMESSAGE = "YSIHRPTCOD:" - mess(141,105,1)
    GERR = 1 : FIN = 1 : Return
  Endif

  # Destino de impresión igual a fichero con formato de exportación PDF
  Filter [F:AIM] Where PRT=4 and PRTFMT=29 and ENAFLG=2
  Read [F:AIM]AIM0 First
  Filter [F:AIM]
  If fstat
    GMESSAGE  = mess(6,6050,1)
    GERR = 1 : FIN = 1 : Return
  Else
    WCODAIM = [F:AIM]COD
  Endif

  # Volumen facturas documentos adjuntos
  WVOL = func AFNC.PARAM("YVOLJOINT", "")
  If WVOL=""
    GMESSAGE  = "YVOLJOINT:" - mess(141,105,1)
    GERR = 1 : FIN = 1 : Return
  Endif
  Read [F:AVL]CODE=WVOL
  If fstat
    GMESSAGE  = WVOL + ":" - mess(47,149,1)
    GERR = 1 : FIN = 1 : Return
  Endif
  WYPATHPDF = func ASYRSTO.GETFULLPATH(WVOL, "")
  If right$(WYPATHPDF, len(WYPATHPDF))<>"\"
    WYPATHPDF += "\"
  Endif




Return

##############################################################
$DEBUT
  [M:YPRE]ALLCPY = 2
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE : [M:YPRE]ALLCPY = 1 : Endif
  If [M:YPRE]ALLCPY = 1
    Call INICPY([M:YPRE]WCPY) From CPTSUB
  Endif
  If [M:YPRE]ALLCPY=2
    Diszo [M:YPRE]WCPY
  Else
    Actzo [M:YPRE]WCPY
  Endif

  [M:YPRE]ALLFCY = 2
  If [M:YPRE]ALLCPY = 1
    Call INIALLFCY([M:YPRE]ALLFCY,[M:YPRE]WCPY) From CPTTRT
  Endif
  If [M:YPRE]ALLFCY = 1
    Call INIFCY([M:YPRE]WFCY,[M:YPRE]WCPY) From CPTSUB
  Endif
  If [M:YPRE]ALLFCY=2
    Diszo [M:YPRE]WFCY
  Else
    Actzo [M:YPRE]WFCY
  Endif

  Read [ATA]CODE=6008;'1'
  If !fstat Then
    [M:YPRE]FECULTENV =  format$("DD2",[F:ATA]A1)
    Affzo [M:YPRE]FECULTENV
  Endif
  Close File [ATA]

  Affzo [M:YPRE]
Return

##############################################################
$SETBOUT
  If [M:YPRE]NBLIG=0
    Call VIREBOUT(CHMEN, "234s") From GOBJET
    Gosub SET_BOUT_SPE From GSAISIE
  Endif
Return

##############################################################
$BOUTON
  Case BOUT
    When "1" : Gosub SEARCH
    When "2" : Gosub INCLUDE_ALL
    When "3" : Gosub EXCLUDE_ALL
    When "4" : Gosub GENERATE
    When "s" : Gosub SEND_PIH
  Endcase
Return

##############################################################
$FIN
  If dim([V]GYWNOMFIC)>0 : Kill [V]GYWNOMFIC : Endif
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$SEARCH
  Local Integer LSTAT
  Effzo [M:YPRE]15
  CRITERE = "1=1 & BPS <> ''"
  If [M:YPRE]ALLCPY<>2
    CRITERE -= '& CPY="' + [M:YPRE]WCPY + '"'
  Endif
  If [M:YPRE]ALLFCY<>2
    CRITERE -= '& FCY="' + [M:YPRE]WFCY + '"'
  Endif

#  CRITERE -= '& INVTYP<=4'      #3042020 - MS - T013.4.1
#  If [M:YPRE]FLGSEND = 2
#    CRITERE -= '& YINVSENT=2'   #3042020 - MS - T013.4.1
#  Endif
  If [M:YPRE]STRDAT<>[0/0/0]
    CRITERE -= "& ACCDAT>=[" + format$(GFMD, [M:YPRE]STRDAT) + "]"
  Endif
  If [M:YPRE]ENDDAT<>[0/0/0]
    CRITERE -= "& ACCDAT<=[" + format$(GFMD, [M:YPRE]ENDDAT) + "]"
  Endif
  If [M:YPRE]VCRDEB<>""
    CRITERE -= '& NUM>="' + [M:YPRE]VCRDEB + '"'
  Endif
  If [M:YPRE]VCRFIN<>""
    CRITERE -= '& NUM<="' + [M:YPRE]VCRFIN + '"'
  Endif
  If [M:YPRE]BPSINVDEB<>""
    CRITERE -= '& BPS >="' + [M:YPRE]BPSINVDEB + '"'
  Endif
  If [M:YPRE]BPSINVFIN<>""
    CRITERE -= '& BPS <="' + [M:YPRE]BPSINVFIN + '"'
  Endif
  Call TEMPON("R") From GESECRAN
  Raz IS_FULL_TABLE
  Raz nolign
  # Infbox CRITERE
  For [F:YVRP] Where evalue(CRITERE)



    If nolign>=dim([M:YPRE]NUM)
      IS_FULL_TABLE = 1 : Break
    Endif
    nolign += 1
    NOL = nolign-1


    LSTAT = 0
    For J = 0 To NOL-1
      #Infbox [F:YVRP]ITMREF+'~'+[F:YVRP]BPS + " ----- "+ [M:YPRE]ITMREF(J)+'~'+[M:YPRE]BPS(J)
      If [F:YVRP]ITMREF+'~'+[F:YVRP]BPS = [M:YPRE]ITMREF(J)+'~'+[M:YPRE]BPS(J) Then
        LSTAT = 1
        Break
      Endif
    Next J
 #  Call UNICITE ([F:YVRP]ITMREF+'~'+[F:YVRP]BPS,[M:YPRE]YITMBPS) From OBJDIV
 #  Call UNICITE ([F:YVRP]ITMREF+'~'+[F:YVRP]BPS,[M:YPRE]YITMBPS(0..NOL)) From OBJDIV
 #  Infbox num$(GERR) + '-'+GMESSAGE
    # SI ESTA REPETIDO, QUITAMOS UNA LINEA AL NOLIGN
    If LSTAT = 1 Then
      nolign -= 1
      NOL = nolign-1

    Else
      [M:YPRE]FCY(NOL) = [F:YVRP]FCY
      [M:YPRE]ITMREF(NOL) = [F:YVRP]ITMREF
      [M:YPRE]BPS(NOL) = [F:YVRP]BPS
      [M:YPRE]BPSNAM(NOL) = [F:YVRP]BPSNAM
      [M:YPRE]FICVER(NOL) = [F:YVRP]FICVER
      [M:YPRE]FICDAT(NOL) = [F:YVRP]FICDAT
      [M:YPRE]MAIL(NOL) = [F:YVRP]MAIL
      [M:YPRE]CPY(NOL) = [F:YVRP]CPY
    Endif
  Next
  [M:YPRE]NBLIG = nolign
  Affzo [M:YPRE]
  Call TEMPOFF From GESECRAN
  If IS_FULL_TABLE
    GMESSAGE = mess(26,100,1) : GERR=2
  Endif
Return

##############################################################
$INCLUDE_ALL
  If [M:YPRE]NBLIG>0 : Call SELECT_ALL(2,0) : Endif
Return

##############################################################
$EXCLUDE_ALL
  If [M:YPRE]NBLIG>0 : Call SELECT_ALL(1,0) : Endif
Return

##############################################################
$GENERATE

  Local Char REQUEST(255)
  Local Char MYTABLE(20)

  REQUEST="SELECT BPS_0, BPSNAM_0, MAIL_0, CPY_0 FROM " + nomap() + ".YVARTPRO GROUP BY BPS_0, BPSNAM_0, MAIL_0, CPY_0"

  #If find(2, [M:YPRE]CHKCREPDF(0..[M:YPRE]NBLIG-1))=0 : Return : Endif
  Raz NBERR

  Local Char TBPAR(10)(1..50), TBVAL(30)(1..50)
  Raz NBRFIC
  Call TEMPON("R") From GESECRAN

  Call OUVRE_TRACE(mess(10,6050,1)) From LECFIC

  For (Char BPS(20),Char NAM(80), Char MAIL(250), Char CPY(10) ) From "5" Sql REQUEST As [YPRE]
      If [F:YPRE]BPS <> '' Then
         Gosub IMPRIME
      Endif
  Next I

  Call FERME_TRACE From LECFIC
  Call TEMPOFF From GESECRAN

Return

##############################################################
$IMPRIME
  Local Integer POK
  Call  GEN_REPORT([F:YPRE]BPS,[F:YPRE]NAM, POK)
  If POK
    # Call ECR_TRACE(mess(55,198,1) - [F:SIV]NUM + ":" - mess(6,123,1) - WMSG, 1) From GESECRAN
    Call ECR_TRACE("error de impresion", 1) From GESECRAN
    NBERR += 1
  Else
    # Call ECR_TRACE(mess(55,198,1) - [F:SIV]NUM + ":" - mess(11,6050,1), 0) From GESECRAN
    Call ECR_TRACE("Impresión correcta", 0) From GESECRAN
    NBRFIC += 1
#    If [F:BPC]YSENDINVOICE=2
#      AUXINT = [F:SIV]YNBRINVSENT

      # ASIGNACIÓN DE DIRECCIÓN DE CORREO
      If dim([V]GYWDIRMAIL)>0 : Kill [V]GYWDIRMAIL : Endif
      Global Char GYWDIRMAIL(255)
      [V]GYWDIRMAIL = [F:YPRE]MAIL # [M:YPRE]MAIL(I)# "malarcon@sistel.es"

      # ASIGNACIÓN DE DIRECCIÓN DE CORREO PARA EL REMITENTE
      If dim([V]GYWDIRFROM)>0 : Kill [V]GYWDIRFROM : Endif
      Global Char GYWDIRFROM(255)
      GYWDIRFROM = func GET_DIR_FROM([F:YPRE]CPY, "2")
      # [V]GYWDIRFROM = "direcciónfrom@indalim.COM"

      Call WORKFLOW(1,"YER","","") From AWRK # EJECUCIÓN DE WORKFLOW PARA ENVIAR EL CORREO

      If !clalev([ZTAB]) Then : Local File ATABDIV [ZTAB] : Endif
      Read [ZTAB]CODE=6008;"1"
      If !fstat Then
        [F:ZTAB]A1 = num$(date$)
        Rewrite [ZTAB]
      Endif
      Close File [ZTAB]
      [M:YPRE]FECULTENV = date$
      Affzo [M:YPRE]FECULTENV
  Endif
Return

##############################################################
$GET_NOMFIC
  NOMFIC = toupper([M:YPRE]NUM(NOL))
  If [M:YPRE]WBPRNAM(NOL)<>""
    NOMFIC +=  "_" + func YSENDPDF.REMOVE_FILENAME_CHARS([M:YPRE]WBPRNAM(NOL), "")
    If right$(NOMFIC, len(NOMFIC))<>"."
      NOMFIC += "."
    Endif
    NOMFIC += "pdf"
  Endif
Return

##############################################################
Subprog SELECT_ALL(PON, DESDE)
Value Integer PON
Value Integer DESDE
Local Integer I

  For I=DESDE To [M:YPRE]NBLIG-1
    If PON=2
      [M:YPRE]CHKCREPDF(I) = 2
    Else
      [M:YPRE]CHKCREPDF(I) = 1
    Endif
  Next I
  Affzo [M:YPRE]CHKCREPDF
End

##############################################################
Subprog GET_PDF_SIH(WNUM, WCPY, WBPRNAM, WYPATHPDF)
Value Char WNUM
Value Char WCPY
Value Char WBPRNAM
Value Char WYPATHPDF

  If WNUM="" : End : Endif

  Local Char    WDIR(255), NOMFIC(250), ORDSYS(255), TEMPFILE(255), URL(255)
  Local Integer STAT

  WDIR = WYPATHPDF + WCPY + "\"
  NOMFIC = toupper(WNUM + "_" + func YSENDPDF.REMOVE_FILENAME_CHARS(WBPRNAM, ""))
  If right$(NOMFIC, len(NOMFIC))<>"."
    NOMFIC += "."
  Endif
  NOMFIC += "pdf"
  TEMPFILE = filpath(nomap + "/TMP/" + NOMFIC, "", "", "X3_PUB")
  ORDSYS = 'COPY "' + WDIR + NOMFIC + '" "' + TEMPFILE + '"'
  Call SYSTEME(adxmac(0), ORDSYS, "", STAT) From ORDSYS
  Call EXISTE(TEMPFILE, STAT) From ORDSYS
  If STAT=1
    URL = func AFNC.PARAM("YDIRPUBPDF", "")
    If URL="" : URL = GVIRTDIR : Endif
    If right$(URL, len(URL))<>"/"
      URL += "/"
    Endif
    URL += nomap + "/TMP/" + NOMFIC

    Callui RETOUR="" With "UIAction="    + chr$(1) + "OpenFile",
&                         "UILocalDir="  + chr$(1) + "HTTP",
&                         "UILocalFile=" + chr$(1) + URL
  Else
    GMESSAGE = "|" + WDIR + NOMFIC + "|.\"
    GMESSAGE+= mess(12,6050,1)
    Call ERREUR(GMESSAGE) From GESECRAN
    Raz GMESSAGE
  Endif
End

##############################################################
#
# Genera pdf y lo envía al proveedor correspondiente, si está seleccionado.

$SEND_PIH
Local Integer LCON0 : Raz LCON0
Local Integer LSTA  : Raz LSTA

  If find(2, [M:YPRE]CHKCREPDF(0..[M:YPRE]NBLIG-1))=0 : Return : Endif

  For LCON0 = 0 To [M:YPRE]NBLIG-1
    If [M:YPRE]CHKCREPDF(LCON0) = 2 Then
      Call ENVMAIL_SIH([M:YPRE]NUM(LCON0),"ZSBONFAC","ENVIOPDF",LSTA) From SPEYLIB0
      If LSTA = 0 Then
        [M:YPRE]YINVSENT(LCON0) = 2
      Endif
    Endif
  Next

  Affzo [M:YPRE]YINVSENT
  Kill LCON0
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
##############################################################
Subprog AS_ALLCPY(VALEUR)
Variable Integer VALEUR
  If GUSRFCY(1)<>"\" & GNBAUZ<>GNBSITE
    VALEUR = 1 : mkstat = 1
  Endif
End

##############################################################
Subprog AM_ALLCPY(VALEUR)
Variable Integer VALEUR
  Raz [M:YPRE]WCPY
  If VALEUR=2
    Diszo [M:YPRE]WCPY
  Else
    Actzo [M:YPRE]WCPY
  Endif
  Affzo [M:YPRE]WCPY
End

##############################################################
Subprog AS_WCPY(VALEUR)
Variable Char    VALEUR()
  If [M:YPRE]ALLCPY=2
    VALEUR = 1 : mkstat = 1
  Endif
End

##############################################################
Subprog AS_ALLFCY(VALEUR)
Variable Integer VALEUR
  If [M:YPRE]ALLCPY=2
    VALEUR = 2
  Else
    Call INIALLFCY(VALEUR, [M:YPRE]WCPY) From CPTTRT
  Endif
  If VALEUR=2
    Raz [M:YPRE]WFCY
    Diszo [M:YPRE]WFCY
  Else
    Actzo [M:YPRE]WFCY
  Endif
  Affzo [M:YPRE]WFCY
End

##############################################################
Subprog AM_ALLFCY(VALEUR)
Variable Integer VALEUR
  Raz [M:YPRE]WFCY
  If VALEUR=2
    Diszo [M:YPRE]WFCY
  Else
    Actzo [M:YPRE]WFCY
  Endif
  Affzo [M:YPRE]WFCY
End

##############################################################
Subprog AS_WFCY(VALEUR)
Variable Char    VALEUR()
  If [M:YPRE]ALLFCY=2
    VALEUR = 1 : mkstat = 1
  Endif
End

##############################################################
Subprog AM_ALLTYP(VALEUR)
Variable Integer VALEUR
  Raz [M:YPRE]WINVTYP
  If VALEUR=2
    Diszo [M:YPRE]WINVTYP
  Else
    Actzo [M:YPRE]WINVTYP
  Endif
  Affzo [M:YPRE]WINVTYP
End

##############################################################
Subprog AS_WINVTYP(VALEUR)
Variable Integer VALEUR
  If [M:YPRE]ALLTYP=2
    VALEUR = 1 : mkstat = 1
  Endif
End

##############################################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
  If VALEUR<>[0/0/0] : [M:YPRE]ENDDAT = VALEUR : Endif
End

##############################################################
Subprog AM_VCRDEB(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>"" : [M:YPRE]VCRFIN = VALEUR : Endif
End

##############################################################
Subprog AM_BPCINVDEB(VALEUR)
Variable Char    VALEUR()
  If VALEUR<>"" : [M:YPRE]BPCINVFIN = VALEUR : Endif
End

##############################################################
Subprog IB_NBLIG
  GBOUT4 = mess(193, 198,1)-[M:YPRE]NUM(nolign-1)
End

##############################################################
Subprog B1_NBLIG
  Call SELECT_ALL(2,nolign-1)
End

##############################################################
Subprog B2_NBLIG
  Call SELECT_ALL(1,nolign-1)
End



#####################################################################
#**
#* Genera el pdf de una factura de venta..
#*
#* @param PFACVEN > número de la factura de venta
#* @param POK     > devuelve el estado de la creación del pdf
#*!
Subprog GEN_REPORT(PBPS,PNAMEBPS, POK)
Variable  Integer POK
Value     Char    PBPS

  POKFAC = 1 # no

  If !clalev([F:YSIV0]) : Local File SINVOICEV   [F:YSIV0] : Endif
  If !clalev([F:YTSV0]) : Local File TABSIVTYP   [F:YTSV0] : Endif
  Local Integer I,J
  Local Char    TBPAR(20)(1..15)
  Local Char    TBVAL(20)(1..15)
  Local Char    LFILE(200),PATH_FILE(255)
  # Local Char    LDIRIMPORT(250) : LDIRIMPORT = "C:\Sage\SAGEX3V11\folders\TEST\tmp"
  Local Integer STAT

  Local Integer LINTENT # intentos para comprobar si se ha creado un pdf..
  Local Integer LIMPFAC # estado impresión factura

  Raz TBPAR, TBVAL, LFILE, LIMPFAC



          TBPAR(1)  = "fournisseurdeb"          : TBVAL(1)  = PBPS
          TBPAR(2)  = "fournisseurfin"          : TBVAL(2)  = PBPS
         # TBPAR(3)  = "namebpsdeb"              : TBVAL(3)  = PNAMEBPS # [F:YSIV0]NUM
          #TBPAR(4)  = "sitefin"                 : TBVAL(4)  = "" #[F:YSIV0]NUM

          #TBPAR(7) = "impselections"            : TBVAL(12) = "1" # no


          # borra la factura si existe..
          # LFILE = LDIRIMPORT + [F:YSIV0]NUM + ".pdf"
          # If filinfo(LFILE, 7) > 0 : System "ae_rm " + LFILE : Endif


         If dim([V]GYWNOMFIC)>0 : Kill [V]GYWNOMFIC : Endif
         Global Char GYWNOMFIC(255)
         [V]GYWNOMFIC = func AFNC.PARAM("YPATHPDF", "")

         If [V]GYWNOMFIC<>""
           If right$([V]GYWNOMFIC, len([V]GYWNOMFIC))<>"\"
             [V]GYWNOMFIC += "\"
           Endif
         Else
           [V]GYWNOMFIC = filpath("tmp", "", "") + "\"
         Endif
         PATH_FILE = 'Circular_' + PBPS + '.PDF'
         [V]GYWNOMFIC += PATH_FILE

        If PATH_FILE <> "" Then
            Call BORRAR([V]GYWNOMFIC, I) From YSENDPDF
        Endif
#  Infbox TBPAR
#  Infbox TBVAL
        # lanza el informe.. MODIFICAR EL INFORME A GENERAR
        Call ETAT("YPURREC", "YIMP", "SPA", 0, "", TBPAR, TBVAL) From AIMP3

        # intentos para comprobar la creación del pdf..
        Raz I, J
        Repeat
          I = func CHECK_FILE([V]GYWNOMFIC)
          If I>0 : Break : Endif
          Sleep 1
          J += 1
        Until J=10
        If I=0
          STAT = 1 : WMSG = mess(7,6050,1)
        Endif

        If STAT # FUNCIONA CORRECTAMENTE, ENVIAR EL CORREO A LA DIRECCIÓN DEL PROVEEDOR
          POK = 1
        Else
          POK = 0
        Endif

End

#------------------------------------------------------------------------------#
# MS-DOS mode (no sandbox)
Funprog CHECK_FILE(PATH_FILE)
Value    Char    PATH_FILE

  Local Char    ORDSYS(255), WFILE(90)
  Local Integer I, COUNT
  #
  Raz COUNT
  ORDSYS = 'dir /a:-d /b "' + PATH_FILE + '"'  # Excluir los directorios
  Call SYSTEME2(adxmac(0), ORDSYS, "", I, WFILE) From ORDSYS
  If pat(PATH_FILE, "*" + WFILE + "*")
    COUNT = 1
  Else
    COUNT = 0
  Endif
  #
End COUNT

#------------------------------------------------------------------------------#

Funprog GET_DIR_FROM(LCPY, LNUM)
  Value Char LCPY, LNUM
  Local Char LMAIL(250)


  If !clalev([ZCOM]) Then : Local File COMPANY   [ZCOM]  : Endif
  If !clalev([ZBPA]) Then : Local File BPADDRESS [ZBPA]  : Endif

  Read [ZCOM]CPY0=LCPY
  If !fstat Then
    Read [ZBPA]BPA0=2;LCPY;[F:ZCOM]BPAADD
    If !fstat Then
      If LNUM = "2" Then
         LMAIL = [F:ZBPA]WEB(1)
      Else
        LMAIL = ""
      Endif
    Endif
  Endif
  Close File [ZCOM], [ZBPA]


End LMAIL

