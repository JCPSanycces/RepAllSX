#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif

Case ACTION
  When "SETBOUT"    : Gosub SETBOUT
  When "BOUTON"     : Gosub BOUTON
  When "FIN"        : Raz GFLAG
  When Default
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
########################################################################
$SETBOUT
  If [M:YDLP0]YFLAG <> "s" Then
    Raz CHMEN
  Else
    CHMEN += "s"
  Endif
Return

########################################################################
$BOUTON

  Case BOUT
    When "s"    : Gosub UPDTDLV #: Gosub RELIT From GOBJSUB
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
########################################################################
$UPDTDLV
Local Integer LCON    : Raz LCON

  If !clalev([F:YSDH]) Then : Local File SDELIVERY [F:YSDH] : Endif
  Call DEBTRANS From GLOCK

# Transacción
$TR1
  For LCON = 0 To [M:YDLP0]NBDLP - 1
    GOK = 1
    Trbegin [F:YSDH]
    Readlock [F:YSDH]SDH0 = [M:YDLP0]SDHNUM(LCON)
    If [S]fstat = 1                                             # el campo está en uso
      [V]GOK = -1
      [V]GLOCK = "SDELIVERY"-[M:YDLP0]SDHNUM(LCON)              # nombre de tabla - nombre del campo
      Goto ROL_TR1
    Elsif [S]fstat                                              # 2,3,... cualquier otro error de acceso al registro
      [V]GOK = 0
      Call RSTA("YSDH",[M:YDLP0]SDHNUM(LCON)) From GLOCK        # abreviatura de la tabla - nombre del campo
      Goto AB_TR1
    Endif
    [F:YSDH]PJT = [M:YDLP0]PJT
    Rewrite [F:YSDH]
    If [S]fstat                                                 # si no se puede modificar el campo
      [V]GOK = 0
      Call FSTA("YSDH") From GLOCK
      Goto AB_TR1
    Endif
    Commit
  Next

  If clalev([F:YSDH])  Then : Close Local File     [F:YSDH] : Endif

Return

########################################################################
# Rollback de la transacción
$ROL_TR1
  Rollback
  Call ROLL From GLOCK                                          # comprueba el número de reintentos que quedan
  If GROLL
    Call ECR_TRACE(mess(17,107,1),1) From GESECRAN              # máximo número de reintentos alcanzado
  Else
    Goto TR1                                                    # puede reintentar una vez más
  Endif
Return

########################################################################
# Abortar la transacción
$AB_TR1
  Rollback
  Call ECR_TRACE(mess(17,107,1),1) From GESECRAN                # muestra un mensaje de sistema en el idioma correcto
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
########################################################################
## Después de modificar Nº lista preparación
########################################################################
Subprog AM_PRLNUM(VALEUR)
Variable Char    VALEUR()
Local Char LORINUM(30)  : Raz LORINUM
Local Integer LCON      : Raz LCON

  Raz [M:YDLP0]NBDLP,SDHNUM,DLVDAT,SHIDAT,PJT
  Affzo [M:YDLP0]NBDLP,SDHNUM,DLVDAT,SHIDAT,PJT

  If !clalev([F:YPRL]) Then : Local File STOPRELIS [F:YPRL] : Endif
  If !clalev([F:YSDH]) Then : Local File SDELIVERY [F:YSDH] : Endif
  Filter [F:YPRL] Where PRLNUM = VALEUR
  For [YPRL]
    If LORINUM <> [F:YPRL]ORINUM Then
      Filter [F:YSDH] Where SOHNUM = [F:YPRL]ORINUM
      Read [F:YSDH] First
      If !fstat Then
        [M:YDLP0]SDHNUM(LCON) = [F:YSDH]SDHNUM
        [M:YDLP0]DLVDAT(LCON) = [F:YSDH]DLVDAT
        [M:YDLP0]SHIDAT(LCON) = [F:YSDH]SHIDAT
        Filter [F:YSDH]
        LORINUM = [F:YPRL]ORINUM
        LCON += 1
      Endif
    Endif
  Next
  [M:YDLP0]PJT = [F:YSDH]PJT
  Filter [F:YPRL]
  [M:YDLP0]NBDLP = LCON

  If [M:YDLP0]PJT = "" and LCON > 0 Then
    [M:YDLP0]PJT    = VALEUR
    [M:YDLP0]YFLAG  = "s"
  Else
    Raz [M:YDLP0]YFLAG
  Endif

  Affzo [M:YDLP0]SDHNUM,DLVDAT,SHIDAT,PJT,YFLAG

  If clalev([F:YPRL])  Then : Close Local File     [F:YPRL] : Endif

End


########################################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

