$SEL_TABLE
  Case TABLE
    When "YHOJAREC1"    : Gosub SEL_YHOJAREC1
  Endcase
Return

########################################################################
$VERF_TABLE
  Case TABLE
    When "YHOJAREC1"    : Gosub VERF_YHOJAREC1
  Endcase
Return

########################################################################
$SEL_YHOJAREC1
  If !clalev([F:YHR0]) Then : Local File YVISHOJAREC [F:YHR0] : Endif
  Default File [YHR0]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Hoja de recogida"                                              # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Nº hoja"                                                       # título de la primera columna
  COL(NBCOL)  = "YHOJAREC"                                                      # nombre del campo a mostrar en la segunda columna
Return

########################################################################
$VERF_YHOJAREC1
Return

