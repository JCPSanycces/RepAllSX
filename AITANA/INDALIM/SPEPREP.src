######################################################################################
## Después de modificar el campo "Hoja de recogida"
######################################################################################
Subprog AM_YHOJAREC(VALEUR)
Variable Char    VALEUR()

  If !clalev([F:YSOH]) Then : Local File SORDER [F:YSOH] : Endif
  Filter [F:YSOH] Where YHOJAREC = VALEUR
  Read [F:YSOH] First                                                                           # busca uno de los pedidos con la hoja de recogida indicada
  If !fstat Then
    If !clalev([F:YVHS]) Then : Local File YVEHICULOS [F:YVHS] : Endif
    Read [F:YVHS]YVH0 = [F:YSOH]YMARCA                                                          # con este pedido conocemos el medio a cargar
    If !fstat Then
      [M:PREP]YPESMAX = [F:YVHS]YPESMAX                                                         # carga el peso máximo ADR del medio
      [M:PREP]YVOLMAX = [F:YVHS]YVOLMAX                                                         # carga el volumen máximo ADR del medio
    Endif
    If clalev([F:YVHS])  Then : Close Local File      [F:YVHS] : Endif
    [M:PREP]YMEDIO = [F:YSOH]YMARCA                                                             # carga el medio en el campo de la pantalla
    Affzo [M:PREP]YMEDIO, YPESMAX, YVOLMAX
  Endif
  Filter [F:YSOH]
  If clalev([F:YSOH])  Then : Close Local File   [F:YSOH] : Endif

End

