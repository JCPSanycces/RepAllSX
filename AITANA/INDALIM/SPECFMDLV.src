#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif

Case ACTION
  When "SEL_TABLE"    : Gosub SEL_TABLE
  When "DEBUT"        : Gosub DEBUT
  When "OUVRE"        : Gosub OUVRE
  When "OK"           : Gosub OK_
  When "CFMDLVFIL"    : Gosub CFMDLVFIL                                 # punto de entrada para que sólo valide las entregas del proyecto indicado
  When Default
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
########################################################################
$SEL_TABLE
  Case TABLE
    When "YPJTLIS"  : Gosub SEL_YPJTLIS
  Endcase
Return

########################################################################
$SEL_YPJTLIS
  If !clalev([F:YVSP1]) Then : Local File YVISSDHPJT [F:YVSP1] : Endif
  Default File [YVSP1]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Entregas"                                                      # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Proyecto"                                                      # título de la primera columna
  COL(NBCOL)  = "PJT"                                                           # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Planta"                                                        # título de la segunda columna
  COL(NBCOL)  = "STOFCY"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Sociedad"                                                      # título de la tercera columna
  COL(NBCOL)  = "CPY"                                                           # nombre del campo a mostrar en la tercera columna

Return

########################################################################
$DEBUT
  Case GFONCTION
    When "GESYLT"
      [M:DIA]YPJT   = GPSPEYLT0(0)
      [M:DIA]STOFCY = GPSPEYLT0(1)
      [M:DIA]SHIDAT = date$
      Affzo [DIA]YPJT,STOFCY,SHIDAT
#    When "GESYEXP"
#      [M:DIA]CPY    = GPARAM6(1)
#      [M:DIA]STOFCY = GPARAM6(2)
#      Affzo [M:DIA]1-99
#      GPE=1
  Endcase

Return

##############################################################
$OUVRE
#  If GFONCTION = "GESYEXP" Then                 # ejecuta el estándar si viene del desarrollo de Expediciones
#    Gosub INIT_TRTCFMDLV From FUNCFMDLV
#    GPE=1
#  Endif
  If GFONCTION = "GESYLT" Then                 # ejecuta el estándar si viene del desarrollo de Lista de transporte
    Gosub INIT_TRTCFMDLV From FUNCFMDLV
    GPE=1
  Endif
Return

##############################################################
$OK_
  If GFONCTION = "GESYLT" Then                 # ejecuta el estándar si viene del desarrollo de Lista de transporte
    GOK=1
    Gosub CONTROLE_TRTCFMDLV  From FUNCFMDLV
    Gosub EXEC_TRTCFMDLV      From FUNCFMDLV
    Gosub TERMINE_TRTCFMDLV   From FUNCFMDLV
    GPE=1
  Endif
#  If GFONCTION = "GESYEXP" Then                 # ejecuta el estándar si viene del desarrollo de Expediciones
#    GOK=1
#    Gosub CONTROLE_TRTCFMDLV  From FUNCFMDLV
#    Gosub EXEC_TRTCFMDLV      From FUNCFMDLV
#    Gosub TERMINE_TRTCFMDLV   From FUNCFMDLV
#    GPE=1
#  Endif
Return

##############################################################
# punto de entrada para que sólo valide las entregas del proyecto indicado
$CFMDLVFIL
  FILSUP = 'PJT = "' + [M:DIA]YPJT + '"'
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
