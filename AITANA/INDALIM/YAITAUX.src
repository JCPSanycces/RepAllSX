#<AdxTL>@(#)0.0.0.0 $Revision$ 
# ASIGNACIÓN DE PEDIDOS DE VENTA

Call ASIGNACION("00000001-19")

End













Subprog ASIGNACION(VSOH)
Value Char VSOH
# 1 - IMPORTACION Y ACTUALIZACION DE PEDIDOS (SIN ASIGNACIONES)
# IMPORSIL

# 2 - LANZO LA ASIGCION STD PARA UN PEDIDO CONCRETO
Local Integer LRET
Local Char PARAM(20)(1..20)
PARAM(1)=VSOH
Call SAISIE_LIB(LRET,PARAM,"DAUTALL","FUNAUTALL","XYFUNAUTALL") From GSAISIE

End

