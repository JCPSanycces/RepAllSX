#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif

Case ACTION
  When "SEL_TABLE"    : Gosub SEL_TABLE
  When "VERF_TABLE"   : Gosub VERF_TABLE
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
########################################
$SEL_TABLE
#  Case TABLE
#    When "YITPCHOICE" : Gosub SEL_YITPCHOICE
#  Endcase
Return

########################################
$VERF_TABLE
#  Case TABLE
#    When "YITPCHOICE" : Gosub VERF_YITPCHOICE
#  Endcase
Return

########################################
$SEL_YITPCHOICE
If func AFNC.PARAMUTIL("AUTOSEL",GUSER,"")<>"2" : OK=0 : Return : Endif
If VALEUR="" : OK=0 : Return : Endif
If clalev([F:ITP])=0 : Local File ITMBPS [ITP] : Endif
#If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif
#If clalev([F:ATZ])=0 : Local File ATABZON [ATZ] : Endif

Local Char UPVAL(type(VALEUR)-10) : UPVAL = toupper(VALEUR)
Local Integer NBREC
Infbox num$(VALEUR)
Infbox num$(PARAM(2))
If PARAM(2) <> ""
  Read [ITP]ITP2 = PARAM(2);UPVAL
  If !fstat Then
    VALEUR = [F:ITP]ITMREF : OK=0 : Return
  Else
    Filter [ITP] Where BPSNUM = PARAM(2) & EANCODBPS = UPVAL Order By Key ITP2
    Read [ITP] First
    If !fstat Then
      VALEUR = [F:ITP]ITMREF
      OK=0 : Filter [ITP] : Return
    Endif
    Filter [ITP]
  Endif
Endif

