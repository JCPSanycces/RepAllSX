#    OK=0 : Filter [ITM] : Return
#  Endif
#  Filter [ITM]
#Endif
#ORDRE = 'ITMREF'
#START = 'ITMREF'
#OFJET = 'ITM'
#CRITERE = '((left$([F:ITM]ITMREF,' + num$(len(UPVAL)) + ')="'+UPVAL+'")'
#CRITERE -= '| (pat(toupper([F:ITM]ITMDES1),"*'+UPVAL+'*"))'
#CRITERE -= '| (toupper([F:ITM]EANCOD)="'+UPVAL+'"))'
#Local Clbfile SQL_REQ(1)
#SQL_REQ = "select count(*) From ITMMASTER ITM"
#Append SQL_REQ," Where ("+func FUZZIFY("ITM.ITMREF_0",VALEUR,2)
#Append SQL_REQ," or"-func FUZZIFY("upper(ITM.ITMDES1_0)",VALEUR,3)
#Append SQL_REQ," or"-func FUZZIFY("ITM.EANCOD_0",VALEUR,0)+")"
#For (Integer RES) From num$(GTYPDBA*2+1) Sql SQL_REQ As [CONT]
#  NBREC = RES
#Next
#If NBREC<2
#  If NBREC=1
#    Filter [ITM] Where evalue(CRITERE)
#    Read [ITM] First
#    VALEUR = [F:ITM]ITMREF
#    Filter [ITM]
#  Endif
#  OK=0 : Return
#Endif
Return

########################################
$VERF_YITPCHOICE
  VALEUR = [F:ITP]ITMREF
Return


