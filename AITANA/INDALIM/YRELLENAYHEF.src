#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog INSERT_REG()

  If !clalev([F:YHE0]) Then : Local File YHISENVFTFS [F:YHE0] : Endif
  Trbegin [F:YHE0]
  Read [F:YHE0]YHEF0 = GBPCNUMFS;GITMREFFS
  If !fstat Then
    [F:YHE0]ENVFSDAT  = GENVFSDATFS
    [F:YHE0]FSDAT     = GFSDATFS
    [F:YHE0]FSVERSION = GFSVERSIONFS
    Rewrite [F:YHE0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Else
    [F:YHE0]BPCNUM    = GBPCNUMFS
    [F:YHE0]ITMREF    = GITMREFFS
    [F:YHE0]ENVFSDAT  = GENVFSDATFS
    [F:YHE0]FSDAT     = GFSDATFS
    [F:YHE0]FSVERSION = GFSVERSIONFS
    Write [F:YHE0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif
  If  clalev([F:YHE0]) Then : Close Local File       [F:YHE0] : Endif

End

