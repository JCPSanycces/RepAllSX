#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
     When "OUVRE"        : Gosub OUVRE
  Endcase
Return

##########################################################
$OUVRE
  # Cargo la pantalla según STD ###
  If GFONCTION = "GESYEXP" Then
    Gosub INIT From FUNAUTALL
    GPE = 1

    # Cargo campos que necesito alimentar para filtrar pedidos
    [M:DIA]ALLPAR = 2
    [M:DIA]SOHNUMDEB = PARAM(1)
    [M:DIA]SOHNUMFIN = PARAM(1)

    If !clalev([V0]) : Local File SORDER  [V0] : Endif
    Read [V0]SOH0 = PARAM(1)
    If fstat = 0
      [M:DIA]STOFCY    = [V0]STOFCY
    Endif
    Close Local File [V0]

    # Lanzo ejecución y cierre de pantalla
    Gosub OK
  Endif
Return


##########################################################
$OK
  GOK=1
  Gosub EXEC From FUNAUTALL
  GPE = 1
  GOK=0 : FIN=1
Return

