#######################################################################################

$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
  Case ACTION
    When "SEL_TABLE"    : Gosub SEL_TABLE
    When "VERF_TABLE"   : Gosub VERF_TABLE
    When "OUVRE"        : Gosub OUVRE
    When "FILTRE"       : Gosub FILTRE
    When "LIENS"        : Gosub LIENS
    When "CREATION"     : Gosub CREATION
    When "MODIF"        : Gosub MODIF
    When "ANNULE"       : Gosub ANNULE
    When "APRES_CRE"    : Gosub APRES_CRE
    When "APRES_MOD"    : Gosub APRES_MOD
    When "INICRE_LIG"   : Gosub INICRE_LIG
    When "DEFLIG"       : Gosub DEFLIG
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "VERIF_MOD"    : Gosub VERIF_MOD
    When "SETBOUT"      : Gosub SETBOUT
    When "AVANTBOUT"    : Gosub AVANTBOUT
    When "EXEBOUT"      : Gosub EXEBOUT
    When Default
  Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
########################################################################
$SEL_TABLE
  Case TABLE
    When "YVHSEXPYLT"   : Gosub SEL_YVHSEXPYLT                                      # selección para el campo medio (vehículo)
    When "YBPRCONDUC"   : Gosub SEL_YBPRCONDUC                                      # selección para el conductor
    When "YBPRCARGAD"   : Gosub SEL_YBPRCARGAD                                      # selección para el cargador
    When "YSDHYLT"      : Gosub SEL_YSDHYLT                                         # selección para el albarán
  Endcase
Return

########################################################################
$VERF_TABLE
  Case TABLE
    When "YVHSEXPYLT"   : Gosub VERF_YVHSEXPYLT
    When "YBPRCONDUC"   : Gosub VERF_YBPRCONDUC
    When "YBPRCARGAD"   : Gosub VERF_YBPRCARGAD
    When "YSDHYLT"      : Gosub VERF_YSDHYLT
  Endcase
Return

########################################################################
$SEL_YVHSEXPYLT
  If !clalev([F:YVHS]) Then : Local File YVEHICULOS [F:YVHS] : Endif
  Default File [YVHS]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Mantenimiento de vehículos"                                    # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Medio"                                                         # título de la segunda columna
  COL(NBCOL)  = "YMARCA"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Matrícula"                                                     # título de la primera columna
  COL(NBCOL)  = "YMATRICULA"                                                    # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la tercera columna
  COL(NBCOL)  = "YMODELO"                                                       # nombre del campo a mostrar en la tercera columna
Return

########################################################################
$VERF_YVHSEXPYLT

  # muestra el modelo y la matrícula
  [M:YLT0]YDESCMARCA = [F:YVHS]YMODELO - [F:YVHS]YMATRICULA

  # muestra el peso y el volumen máximo
  [M:YLT1]YPESMAX = [F:YVHS]YPESMAX
  [M:YLT1]YVOLMAX = [F:YVHS]YVOLMAX

  Affzo [M:YLT0]YDESCMARCA
  Affzo [M:YLT1]YPESMAX, YVOLMAX
Return

########################################################################
$SEL_YBPRCONDUC
  If !clalev([F:YBP0]) Then : Local File BPARTNER [F:YBP0] : Endif
  Default File [YBP0]
  Filter [F:YBP0] Where BPRACC = 2
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Conductor"                                                     # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "BPRNUM"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Nombre"                                                        # título de la primera columna
  COL(NBCOL)  = "BPRNAM"                                                        # nombre del campo a mostrar en la primera columna
Return

########################################################################
$VERF_YBPRCONDUC
  [M:YLT0]BPRNAM = [F:YBP0]BPRNAM
  Affzo [M:YLT0]BPRNAM
Return

########################################################################
$SEL_YBPRCARGAD
  If !clalev([F:YBP1]) Then : Local File BPARTNER [F:YBP1] : Endif
  Default File [YBP1]
  Filter [F:YBP1] Where BPRACC = 2
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Cargador"                                                      # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "BPRNUM"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Nombre"                                                        # título de la primera columna
  COL(NBCOL)  = "BPRNAM"                                                        # nombre del campo a mostrar en la primera columna
Return

########################################################################
$VERF_YBPRCARGAD
  [M:YLT0]YBPRNAM = [F:YBP1]BPRNAM
  Affzo [M:YLT0]YBPRNAM
Return

########################################################################
$SEL_YSDHYLT
  If !clalev([F:YSDH]) Then : Local File SDELIVERY [F:YSDH] : Endif
  Default File [YSDH]
  # filtra los albaranes con el campo proyecto vacío, de la planta indicada en el campo almacén y no validado
  Filter [F:YSDH] Where PJT = "" and SALFCY = [M:YLT0]FCY and CFMFLG <> 2
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Albarán"                                                       # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Número"                                                        # título de la segunda columna
  COL(NBCOL)  = "SDHNUM"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Cód. cliente"                                                  # título de la primera columna
  COL(NBCOL)  = "BPCORD"                                                        # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Razón social"                                                  # título de la primera columna
  COL(NBCOL)  = "BPINAM"                                                        # nombre del campo a mostrar en la primera columna
Return

########################################################################
$VERF_YSDHYLT
  [M:YLT1]YVOLD(nolign-1)    = [F:YSDH]VOL
  [M:YLT1]YPESOD(nolign-1)   = [F:YSDH]NETWEI      # peso neto

  Affzo [M:YLT1]YVOLD(nolign-1), YPESOD(nolign-1)

Return

########################################################################
$OUVRE
  Gosub DECLARE From TABLEAUX
Return

########################################################################
$FILTRE
  Default File [YLTC]
Return

########################################################################
$LIENS
  Gosub LIENS From TABLEAUX
Return

########################################################################
$CREATION
  Gosub SDH_MODIF
  Gosub CREATION From TABLEAUX
Return

########################################################################
$MODIF
  Gosub SDH_MODIF
  Gosub MODIF From TABLEAUX
Return

########################################################################
$ANNULE
  Gosub ANNULE From TABLEAUX
Return

########################################################################
$APRES_CRE
  Gosub LIENS From TABLEAUX
  Call UPD_PJT([M:YLT0]LTCNUM)
Return

########################################################################
$APRES_MOD
  Gosub LIENS From TABLEAUX
  Call UPD_PJT([M:YLT0]LTCNUM)
Return

########################################################################
$INICRE_LIG
  [F:YLTD]LTCNUM = [M:YLT0]LTCNUM
Return

########################################################################
$DEFLIG
  Default Mask [YLT1]                                   # pantalla de las líneas
  Default File [YLTD]                                   # abreviatura de la tabla de las líneas

  # criterios de filtrado
  CRIT    = 'LTCNUM="'+[M:YLT0]LTCNUM+'"'               # campo común de las tablas + pantalla cabecera (con el campo común)
  FICLIG  = "YLISTRANSD"                                # nombre de la tabla de detalle
  ABLIG   = "YLTD"                                      # abreviatura de la tabla de detalle
  ZONLIG  = "LTCLIN"                                    # campo contador de línea en la tabla detalle
Return

########################################################################
$VERIF_CRE
Local Char LCONTADOR(30)

  # obtiene el siguiente número de contador
  Call GENNUMBER(LCONTADOR)
  [M:YLT0]LTCNUM  = LCONTADOR

  # obtiene los kilómetros totales
  [M:YLT0]YKMTOT  = [M:YLT0]YKMFIN - [M:YLT0]YKMINI

  # obtiene el tiempo de reparto
  [M:YLT0]YHORATOT = format$("N0:4.0", num$(val([M:YLT0]YHORAFIN) - val([M:YLT0]YHORAINI)))

  Gosub GET_WEI
  Gosub GET_VOL
  Gosub GET_WEIADR

  Affzo [M:YLT0]LTCNUM, YKMTOT, YHORATOT

Return

########################################################################
$VERIF_MOD

  # obtiene los kilómetros totales
  [M:YLT0]YKMTOT  = [M:YLT0]YKMFIN - [M:YLT0]YKMINI

  # obtiene el tiempo de reparto
  [M:YLT0]YHORATOT = format$("N0:4.0", num$(val([M:YLT0]YHORAFIN) - val([M:YLT0]YHORAINI)))
  Call DEL_PJT([M:YLT0]LTCNUM)

  Gosub GET_WEI
  Gosub GET_VOL
  Gosub GET_WEIADR

  Affzo [M:YLT0]LTCNUM, YKMTOT, YHORATOT

Return

########################################################################
$SETBOUT
Raz CHMEN
  If [M:YLT0]YDEF <> 2 Then
    If [M:YLT0]YKMINI <> 0 and [M:YLT0]YKMFIN <> 0 and val([M:YLT0]YHORAINI) <> 0 and val([M:YLT0]YHORAFIN) <> 0 Then
      Case BOUT
        When "O"  : CHMEN += "pma"                                                      # Ningún botón pulsado
        When "v"                                                                        # Botón: Validación de entrega
          CHMEN += "pma"
          Call VIREBOUT(CHAINE,"v") From GOBJET
          [M:YLT0]YDEF = 2
          Call AM_YDEF([M:YLT0]YDEF)
          Affzo [M:YLT0]YDEF
          Gosub MARCA_DEF
        When "p"  : CHMEN += "pma"                                                      # Botón: Peso albaranes
        When "m"  : CHMEN += "pma"                                                      # Botón: Volumen albaranes
        When "a"  : CHMEN += "pma"                                                      # Botón: Peso ADR
      Endcase
    Else
      CHMEN += "pma"
      Call VIREBOUT(CHAINE,"v") From GOBJET
    Endif
  Else                                                                                  # se anulan todos los botones si ¿Definitivo? está marcado
    Call VIREBOUT(CHAINE,"v") From GOBJET
  Endif
Return

########################################################################
$AVANTBOUT
  Case BOUT
    When "p"  : Gosub GET_WEI
    When "m"  : Gosub GET_VOL
    When "a"  : Gosub GET_WEIADR
  Endcase
Return

########################################################################
$EXEBOUT
  Case BOUT
    When "v"  : Gosub VALIDA_ENT
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
########################################################################
$GET_WEI
Local Integer LCON0 : Raz LCON0
Local Decimal LPESO : Raz LPESO

  For LCON0 = 0 To [M:YLT1]NBLIG - 1
    LPESO += [M:YLT1]YPESOD(LCON0)
  Next
  [M:YLT1]YPESO = LPESO
  Affzo [M:YLT1]YPESO

Return

########################################################################
$GET_VOL
Local Integer LCON1 : Raz LCON1
Local Decimal LVOL  : Raz LVOL

  For LCON1 = 0 To [M:YLT1]NBLIG - 1
    LVOL += [M:YLT1]YVOLD(LCON1)
  Next
  [M:YLT1]YVOL = LVOL
  Affzo [M:YLT1]YVOL

Return

########################################################################
$GET_WEIADR
Local Integer LCON2 : Raz LCON2
Local Decimal LADR  : Raz LADR

#  For LCON2 = 0 To [M:YLT1]NBLIG - 1
#    If [M:YLT1]ADR(LCON2) = 2 Then
#      LADR += [M:YLT1]YPESADRD(LCON2)
#    Endif
#  Next
#  [M:YLT1]YPESADR = LADR
#  Affzo [M:YLT1]YPESADR

Local Decimal FACTOR : Raz FACTOR
Local Decimal WEIADRLIN : Raz WEIADRLIN
  If !clalev([F:XX0])  Then : Local File SDELIVERYD [F:XX0]  : Endif
  If !clalev([F:XX1])  Then : Local File YADR       [F:XX1] : Endif
  If !clalev([F:XX2])  Then : Local File YITMONU    [F:XX2] : Endif
  For LCON2 = 0 To [M:YLT1]NBLIG-1
    Filter [F:XX0] Where SDHNUM = [M:YLT1]SDHNUM
    For [XX0]
      Read [F:XX1]YADR0 = [F:XX0]ITMREF
      If !fstat Then
        If [F:XX1]GESADR = 2 Then
          Filter [F:XX2] Where REFONU = [F:XX1]CDGONU
          Read   [F:XX2] First
          If !fstat Then
            Case [F:XX2]CATTRA
              When "1" Then FACTOR = 20
              When "2" Then FACTOR = 3
              When "3" Then FACTOR = 1
            Endcase
          Endif
        Endif
        Filter [F:XX2]
      Endif
      WEIADRLIN += [XX0]QTY * FACTOR * [F:XX1]NETWEIADR
    Next
    Filter [F:XX0]
  Next
  [M:YLT1]YPESADR = WEIADRLIN
  Affzo [M:YLT1]YPESADR
  If clalev([F:XX0])   Then : Close Local File      [F:XX0]  : Endif
  If clalev([F:XX1])   Then : Close Local File      [F:XX1] : Endif
  If clalev([F:XX2])   Then : Close Local File      [F:XX2] : Endif

Return

########################################################################
$SDH_MODIF
Local Integer LCON3 : Raz LCON3

  If !clalev([F:YSD0]) Then : Local File SDELIVERY [F:YSD0] : Endif
  For LCON3 = 0 To [M:YLT1]NBLIG - 1
    Read [F:YSD0]SDH0 = [M:YLT1]SDHNUM(LCON3)
    If !fstat Then
      [F:YSD0]YMARCA = [M:YLT0]YMARCA
      Rewrite [F:YSD0]
    Endif
  Next
  If clalev([F:YSD0])  Then : Close Local File     [F:YSD0] : Endif

Return

########################################################################
$VALIDA_ENT
Local Integer LINT1
Global Char GPSPEYLT0(250)(2)

  GPSPEYLT0(0) = [M:YLT0]LTCNUM                                                               # pase de parámetros entre pantallas
  GPSPEYLT0(1) = [M:YLT0]FCY
  Call SAISIE_LIB(LINT1,GPSPEYLT0,"DCFMDLV","SPECFMDLV","OBJZON") From GSAISIE                # llamada a la función que abre la pantalla emregente
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Antes de línea en NBLIG
######################################################################################
Subprog AVANT_NBLIG
  # da número al campo Orden
  [M:YLT1]ORD(nolign-1) = nolign * 10
  Affzo [M:YLT1]ORD(nolign-1)
End

######################################################################################
## Controla que no se repitan albaranes
######################################################################################
Subprog C_SDHNUM(VALEUR)
Variable Char    VALEUR()
  Call UNICITE(VALEUR,[M:YLT1]SDHNUM(0..[M:YLT1]NBLIG-1)) From OBJDIV
  If mkstat = 2 Then
    VALEUR = ""
  Endif
End

######################################################################################
## Después de modificar el campo "¿Definitivo?"
######################################################################################
Subprog AM_YDEF(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    Grizo [M:YLT0]YMARCA,BPRNUM,YBPRNUM,YREPDAT,FCY,YKMINI,YKMFIN,YHORAINI,YHORAFIN
    Grizo [M:YLT1]NBLIG
  Else
    Actzo [M:YLT0]YMARCA,BPRNUM,YBPRNUM,YREPDAT,FCY,YKMINI,YKMFIN,YHORAINI,YHORAFIN
    Actzo [M:YLT1]NBLIG
  Endif
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
#######################
#**
#* devuelve el siguiente número de contador para YLT
#*
#* @param PSEQCODE  > devuelve número de contador
#*!
Subprog GENNUMBER(PSEQCODE)
Variable Char PSEQCODE
Local Integer STAT
  Call NUMERO("YLT", nomap, date$, "null", PSEQCODE, STAT) From SUBANM
End

#######################
#**
#* borra el campo Proyecto en albaranes
#*
#* @param PLTCNUM  > número de lista de transporte
#*!
Subprog DEL_PJT(PLTCNUM)
Value Char PLTCNUM
  If !clalev([F:YSD2]) Then : Local File SDELIVERY [F:YSD2] : Endif
  Trbegin [F:YSD2]
  Update [F:YSD2] Where PJT = PLTCNUM With PJT = ""
  If !fstat Then
    Commit
  Else
    Rollback
  Endif
  If clalev([F:YSD2])  Then : Close Local File     [F:YSD2] : Endif
End

#######################
#**
#* rellena el campo Proyecto en albaranes
#*
#* @param PLTCNUM  > número de lista de transporte
#*!
Subprog UPD_PJT(PLTCNUM)
Value Char PLTCNUM
  If !clalev([F:YSD3]) Then : Local File SDELIVERY  [F:YSD3] : Endif
  If !clalev([F:YLD0]) Then : Local File YLISTRANSD [F:YLD0] : Endif
  Filter [F:YLD0] Where LTCNUM = PLTCNUM
  For [YLD0]
    Trbegin [F:YSD3]
    Update [F:YSD3] Where SDHNUM = [F:YLD0]SDHNUM With PJT = PLTCNUM
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next
  If clalev([F:YSD3])  Then : Close Local File      [F:YSD3] : Endif
  If clalev([F:YLD0])  Then : Close Local File      [F:YLD0] : Endif
End

