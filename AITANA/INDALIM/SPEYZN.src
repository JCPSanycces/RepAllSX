#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif ######

  Case ACTION
    When "OUVRE"      : Gosub OUVRE
    When "FILTRE"     : Gosub FILTRE
    When "LIENS"      : Gosub LIENS
    When "CREATION"   : Gosub CREATION
    When "MODIF"      : Gosub MODIF
    When "ANNULE"     : Gosub ANNULE
    When "APRES_CRE"  : Gosub APRES_CRE
    When "APRES_MOD"  : Gosub APRES_MOD
    When "INICRE_LIG" : Gosub INICRE_LIG
    When "DEFLIG"     : Gosub DEFLIG
  Endcase
Return

########################################################################
$OUVRE
  Gosub DECLARE From TABLEAUX
Return

########################################################################
$FILTRE
  Default File [YZNC]
Return

########################################################################
$LIENS
  Gosub LIENS From TABLEAUX
Return

########################################################################
$CREATION
  Gosub CREATION From TABLEAUX
Return

########################################################################
$MODIF
  Gosub MODIF From TABLEAUX
Return

########################################################################
$ANNULE
  Gosub ANNULE From TABLEAUX
Return

########################################################################
$APRES_CRE
  Gosub LIENS From TABLEAUX
Return

########################################################################
$APRES_MOD
  Gosub LIENS From TABLEAUX
Return

########################################################################
$INICRE_LIG
  [F:YZND]YCODZONA = [M:YZN0]YCODZONA
Return

########################################################################
$DEFLIG
  Default Mask [YZN1]                                   # pantalla de las líneas
  Default File [YZND]                                   # abreviatura de la tabla de las líneas

  # criterios de filtrado
  CRIT    = 'YCODZONA="'+[M:YZN0]YCODZONA+'"'           # campo común de las tablas + pantalla cabecera (con el campo común)
  FICLIG  = "YZONAD"                                    # nombre de la tabla de detalle
  ABLIG   = "YZND"                                      # abreviatura de la tabla de detalle
  ZONLIG  = "YZONALIN"                                  # campo contador de línea en la tabla detalle
Return

