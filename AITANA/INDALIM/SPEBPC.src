Subprog C_YDIRFAC(VALEUR)
  Call BUSCA_DIRECCION(VALEUR)
End

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla BPC4) 29/10/2018 12:07:11 (ADMIN)
######################################################################################
Subprog AS_NBDLV

  NUMLIN = nolign-1

  Call BUSCA_DIRECCION([M:BPC4]YDIRFAC(nolign-1))
  Call BUSCA_ZONAYRUTA([M:BPC4]BPAADD(nolign-1))
  Call SET_DISP([M:BPC4]BPAADD(nolign-1))
# JC.16122020.YSP03.STR
  Call BUSCA_COMPRADORES([M:BPC4]BPAADD(nolign-1))
# JC.16122020.YSP03.END
End

