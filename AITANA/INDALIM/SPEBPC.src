#<AdxTL>@(#)0.0.0.0 $Revision$ Clientes
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif

Case ACTION
  When "DEBUT"        : Gosub DEBUT
  When "STYLE"        : Gosub STYLE
  When "CREATION"     : Gosub CREATION
  When "MODIF"        : Gosub MODIF
  When "APRES_CRE"    : Gosub APRES_CRE
  When "APRES_MOD"    : Gosub APRES_MOD
  When "AP_ANNULE"    : Gosub AP_ANNULE
  When "SEL_TABLE"    : Gosub SEL_TABLE
  When "VERF_TABLE"   : Gosub VERF_TABLE
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$DEBUT
  Global Integer NUMLIN
Return

##################################################
$STYLE
  Call BUSCA_DIRECCION([M:BPC4]YDIRFAC(nolign-1))
# JC.16122020.YSP03.STR
  Call BUSCA_COMPRADORES([M:BPC4]XBPAADD)
# JC.16122020.YSP03.END
Return

##################################################
$CREATION
 Gosub CREAR_CONECT
Return

##################################################
$MODIF
 Gosub CREAR_CONECT
Return

########################################################################
$APRES_CRE
# JC.16122020.YSP03.STR
  Gosub RELLENA_COMPRADORES
# JC.16122020.YSP03.END
Return

########################################################################
$APRES_MOD
# JC.16122020.YSP03.STR
  Gosub RELLENA_COMPRADORES
# JC.16122020.YSP03.END
Return

########################################################################
$AP_ANNULE
# JC.16122020.YSP03.STR
  Gosub VACIA_COMPRADORES
# JC.16122020.YSP03.END
Return

########################################################################
$SEL_TABLE
  Case TABLE
    When "YSELCOMPRA" : Gosub SEL_YSELCOMPRA                                # selección para los compradores # JC.16122020.YSP03.STR
  Endcase
Return

########################################################################
# esta etiqueta se utiliza para realizar acciones específicas cuando se selecciona una de las opciones en la ventana de selección
$VERF_TABLE
  Case TABLE
    When "YSELCOMPRA" : Gosub VERF_YSELCOMPRA                               # selección para los compradores # JC.16122020.YSP03.STR
  Endcase
Return

##############################################################
# JC.16122020.YSP03.STR
$SEL_YSELCOMPRA
  If !clalev([F:YCNT]) Then : Local File CONTACT    [F:YCNT] : Endif
  If !clalev([F:YAIN]) Then : Local File CONTACTCRM [F:YAIN] : Endif
  Link [F:YAIN] With [F:YCNT]CNT2=[F:YAIN]CNTNUM As [LNK0]
  Default File [LNK0]
  Filter [LNK0] Where [F:YCNT]BPANUM = [M:BPC0]BPCNUM and [F:YCNT]CNTFNC = 5
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Contactos"                                                     # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "[F:YAIN]CNTNUM"                                                # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la primera columna
  COL(NBCOL)  = "[F:YAIN]CNTLNA"                                                # nombre del campo a mostrar en la primera columna
Return
# JC.16122020.YSP03.END

##############################################################
# JC.16122020.YSP03.STR
$VERF_YSELCOMPRA
  [M:BPC4]YCNTLNA(nolign-1) = [F:YAIN]CNTLNA
  Affzo [M:BPC4]YCNTLNA(nolign-1)
Return
# JC.16122020.YSP03.END

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$CREAR_CONECT

NUMLIN = nolign-1

    # la variable NUMLING contiene el valor de la línea correspondiente a la dirección de entrega que estamos modificando
    Update [BPD] Where BPCNUM = [M:BPC0]BPCNUM and BPAADD = [M:BPC4]BPAADD(NUMLIN) With YDIRFAC = [M:BPC4]YDIRFAC(NUMLIN),
&   YDISPON1 = [M:BPC4]YDISPON1, YDISPON2 = [M:BPC4]YDISPON2, YDISPON3 = [M:BPC4]YDISPON3,
&   YDISPON4 = [M:BPC4]YDISPON4, YDISPON5 = [M:BPC4]YDISPON5, YDISPON6 = [M:BPC4]YDISPON6, YDISPON7 = [M:BPC4]YDISPON7, YOBSERV1 = [M:BPC4]YOBSERV1
    If fstat
       GOK = 0 : Call FSTA("BPD") From GLOCK
    Endif

  If GOK<1 : Return : Endif

Return

##############################################################
# JC.16122020.YSP03.STR
$RELLENA_COMPRADORES
Local Integer LCON : Raz LCON
  If !clalev([F:YCMP]) Then : Local File YCOMPRADOR [F:YCMP] : Endif
  Trbegin [F:YCMP]
  Delete [F:YCMP] Where BPCNUM = [M:BPC0]BPCNUM and BPAADD = [M:BPC4]XBPAADD
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  For LCON = 0 To [M:BPC4]NBCMP - 1
    [F:YCMP]BPCNUM  = [M:BPC0]BPCNUM
    [F:YCMP]BPAADD  = [M:BPC4]XBPAADD
    [F:YCMP]CNTNUM  = [M:BPC4]YCNTNUM(LCON)
    [F:YCMP]CNTLNA  = [M:BPC4]YCNTLNA(LCON)
    Trbegin [F:YCMP]
    Write [F:YCMP]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next
  Close Local File [YCMP]
  Kill LCON
Return
# JC.16122020.YSP03.END

##############################################################
# JC.16122020.YSP03.STR
$VACIA_COMPRADORES
  If !clalev([F:YCMP]) Then : Local File YCOMPRADOR [F:YCMP] : Endif
  Trbegin [F:YCMP]
  Delete [F:YCMP] Where BPCNUM = [M:BPC0]BPCNUM
  If !fstat Then
    Commit
  Else
    Rollback
  Endif
Return
# JC.16122020.YSP03.END

