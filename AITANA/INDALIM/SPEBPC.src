##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
######################################################################################
Subprog BUSCA_DIRECCION (PDIR_ENT)
Value Char PDIR_ENT

  If PDIR_ENT <> ""
    If clalev([F:BPA])=0 : Local File BPADDRESS [BPA] : Endif
    Read [F:BPA]BPA0 = 1;[M:BPC3]BPCINV;PDIR_ENT
    #Infbox 'PASA1'
    [M:BPC4]YDIRFAC1    =  PDIR_ENT
    [M:BPC4]YDIRFACNAM1 = [F:BPA]BPADES
    #Infbox 'VALOR:'+[M:BPC4]YDIRFAC(nolign-1)
      If fstat
        Call MESSAGE("Dirección Inexistente") From GESECRAN
        GERR = 1 : mkstat = 2
      Endif
  Else
    [M:BPC4]YDIRFAC1 = ""
    [M:BPC4]YDIRFACNAM1 = ""
  Endif

  Affzo [M:BPC4]YDIRFAC1
  Affzo [M:BPC4]YDIRFACNAM1

End

######################################################################################
Subprog BUSCA_ZONAYRUTA(PDIR_LIN)
Value Char PDIR_LIN
Local Integer LCON : Raz LCON

  [M:BPC4]YCODZONA = ""
  [M:BPC4]YCODRUTA(LCON) = ""

  If PDIR_LIN <> ""
    If !clalev([F:YBPA]) Then : Local File BPADDRESS [F:YBPA] : Endif
    Read [F:YBPA]BPA0 = 1;[M:BPC3]BPCINV;PDIR_LIN
    If !fstat Then
      If !clalev([F:YYZND]) Then : Local File YZONAD [F:YYZND] : Endif
      Filter [F:YYZND] Where POSCOD = [F:YBPA]POSCOD
      Read [F:YYZND] First
      If !fstat Then
        [M:BPC4]YCODZONA(0) = [F:YYZND]YCODZONA
      Endif
      [M:BPC4]NBLIG = 1
      If clalev([F:YYZND])  Then : Close Local File [F:YYZND]  : Endif
      If !clalev([F:YYRTD]) Then : Local File YRUTAD [F:YYRTD] : Endif
      Filter [F:YYRTD] Where POSCOD = [F:YBPA]POSCOD
      For [F:YYRTD]
        [M:BPC4]YCODRUTA(LCON) = [F:YYRTD]YCODRUTA
        LCON += 1
      Next
      [M:BPC4]NBLIG1 = LCON
      Affzo [M:BPC4]90,95
      If clalev([F:YYZND])  Then : Close Local File [F:YYRTD]  : Endif
    Endif
  Endif
End

######################################################################################
Subprog SET_DISP(PDIR_LIN)
Value Char PDIR_LIN

  If PDIR_LIN <> "" Then
    If !clalev([F:YBPD]) Then : Local File BPDLVCUST [F:YBPD] : Endif
    Read [F:YBPD]BPD0 = [M:BPC3]BPCINV;PDIR_LIN
    If !fstat Then
      [M:BPC4]YDISPON1 = [F:YBPD]YDISPON1
      [M:BPC4]YDISPON2 = [F:YBPD]YDISPON2
      [M:BPC4]YDISPON3 = [F:YBPD]YDISPON3
      [M:BPC4]YDISPON4 = [F:YBPD]YDISPON4
      [M:BPC4]YDISPON5 = [F:YBPD]YDISPON5
      [M:BPC4]YDISPON6 = [F:YBPD]YDISPON6
      [M:BPC4]YDISPON7 = [F:YBPD]YDISPON7
      [M:BPC4]YOBSERV1 = [F:YBPD]YOBSERV1
    Endif
    Affzo [M:BPC4]40
    If clalev([F:YBPD])  Then : Close Local File     [F:YBPD] : Endif
  Endif
End

######################################################################################
# JC.16122020.YSP03.STR
Subprog BUSCA_COMPRADORES(PDIR_LIN)
Value Char PDIR_LIN
Local Integer LCON : Raz LCON

  For LCON = 0 To [M:BPC4]NBCMP-1
    Raz [M:BPC4]YCNTNUM(LCON)
    Affzo [M:BPC4]YCNTNUM(LCON)
    Raz [M:BPC4]YCNTLNA(LCON)
    Affzo [M:BPC4]YCNTLNA(LCON)
  Next
  Raz LCON
  [M:BPC4]NBCMP = 0
  Affzo [M:BPC4]90

  If !clalev([F:YCMP]) Then : Local File YCOMPRADOR [F:YCMP] : Endif
  Filter [F:YCMP] Where BPCNUM = [M:BPC0]BPCNUM and BPAADD = PDIR_LIN
  For [YCMP]
    [M:BPC4]YCNTNUM(LCON) = [F:YCMP]CNTNUM
    Affzo [M:BPC4]YCNTNUM(LCON)
    [M:BPC4]YCNTLNA(LCON) = [F:YCMP]CNTLNA
    Affzo [M:BPC4]YCNTLNA(LCON)
    LCON += 1
  Next
  Filter [F:YCMP]
  [M:BPC4]NBCMP = LCON
  Affzo [M:BPC4]90
  Close Local File [YCMP]

  Kill LCON
End
# JC.16122020.YSP03.END
