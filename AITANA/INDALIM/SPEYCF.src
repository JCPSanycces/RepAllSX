#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "DEBUT"        : Gosub DEBUT
  When "BOUTON"       : Gosub BOUTON
  When "FIN"          : Gosub FIN
  When "EMAIL"        : Gosub EMAIL       # punto de entrada sobre AWRKMEL para añadir el remitente del correo
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$DEBUT
  Affzo [M:YCF0]
  Grizo [M:YCF0]CPY,FCY
  If !clalev([F:AVL0]) Then : Local File AVOLUME    [F:AVL0] : Endif
  If !clalev([F:AOX0]) Then : Local File AOBJTXT    [F:AOX0] : Endif
  If !clalev([F:CNT0]) Then : Local File CONTACT    [F:CNT0] : Endif
  If !clalev([F:BPA0]) Then : Local File BPADDRESS  [F:BPA0] : Endif
  If !clalev([F:ITM0]) Then : Local File ITMMASTER  [F:ITM0] : Endif
Return

##############################################################
$BOUTON

  Case BOUT
    When "b" : Gosub BUSCAR
    When "e" : Gosub ENVIOFSFT
    When "d" : Gosub DESCARGARFSFT
    When "i" : Gosub IMPRIMIRFSFT
    When "s" : Gosub ENVIORESUMENANUAL
  Endcase

Return

##############################################################
$FIN
  Close Local File [AVL0],[AOX0],[CNT0],[BPA0],[ITM0]
Return

##############################################################
# punto de entrada para indicar el remitente del correo
$EMAIL
  Filter [F:BPA0] Where BPATYP = 2 and BPANUM = "INDA" and BPAADDFLG = 2
  Read [F:BPA0]First
  If !fstat Then
    EXP_MAIL = [F:BPA0]WEB(2)
  Endif
  Filter [F:BPA0]
#Infbox EXP_MAIL
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$BUSCAR
Local Char LCRIT1(250)    : LCRIT1 = "1=1"
Local Char LCRIT2(250)    : Raz LCRIT2
Local Char LCRIT3(250)    : Raz LCRIT3
Local Char LCRIT4(250)    : Raz LCRIT4
Local Char LCRIT5(250)    : Raz LCRIT5
Local Char LCRIT6(250)    : Raz LCRIT6
Local Char LSQL(250)(1..) : Raz LSQL
Local Integer LCON        : Raz LCON
Local Char LDATINI(25),LDATEND(25)  : Raz LDATINI,LDATEND

  If [M:YCF0]CPY        <> ""           Then : LCRIT1 -= "AND SOCIEDAD_0='"+[M:YCF0]CPY+"'"          : Endif
  If [M:YCF0]FCY        <> ""           Then : LCRIT1 -= "AND PLANTA_0='"+[M:YCF0]FCY+"'"            : Endif
  If [M:YCF0]BPCNUMSTR  <> ""           Then : LCRIT2 -= "AND BPCORD_0>='"+[M:YCF0]BPCNUMSTR+"'"     : Endif
  If [M:YCF0]BPCNUMEND  <> ""           Then : LCRIT2 -= "AND BPCORD_0<='"+[M:YCF0]BPCNUMEND+"'"     : Endif
  If [M:YCF0]TCLCODSTR  <> ""           Then : LCRIT3 -= "AND CATEGORIA_0>='"+[M:YCF0]TCLCODSTR+"'"  : Endif
  If [M:YCF0]TCLCODEND  <> ""           Then : LCRIT3 -= "AND CATEGORIA_0<='"+[M:YCF0]TCLCODEND+"'"  : Endif
  If [M:YCF0]ITMREFSTR  <> ""           Then : LCRIT4 -= "AND ITMREF_0>='"+[M:YCF0]ITMREFSTR+"'"     : Endif
  If [M:YCF0]ITMREFEND  <> ""           Then : LCRIT4 -= "AND ITMREF_0<='"+[M:YCF0]ITMREFEND+"'"     : Endif
  If [M:YCF0]DATINI     <> [00/00/0000] Then
    LDATINI = num$(year([M:YCF0]DATINI))+"-"+num$(month([M:YCF0]DATINI))+"-"+num$(day([M:YCF0]DATINI))
    LCRIT5 -= "AND SHIDAT_0>=CONVERT(DATETIME,'"+LDATINI+"',102)"
  Endif
  If [M:YCF0]DATEND     <> [00/00/0000] Then
    LDATEND = num$(year([M:YCF0]DATEND))+"-"+num$(month([M:YCF0]DATEND))+"-"+num$(day([M:YCF0]DATEND))
    LCRIT5 -= "AND SHIDAT_0<=CONVERT(DATETIME,'"+LDATEND+"',102)"
  Endif
  LCRIT5  -= ""

  If [M:YCF0]BPCPEND = 2 Then
    LCRIT6  -= "AND VERFSART_0 > VERFSCLI_0 "
  Endif

  LSQL(1) = "SELECT BPCORD_0, ITMREF_0, MAIL_0, FULENV_0, VERFSCLI_0, VERFSART_0, FFSART_0, CATEGORIA_0, SOCIEDAD_0, PLANTA_0 "
  LSQL(2) = "FROM "+nomap+".YVISCOMFTFS "
  LSQL(3) = "WHERE " + LCRIT1 - LCRIT2 - LCRIT3 - LCRIT4
  LSQL(4) = LCRIT5 - LCRIT6
  LSQL(5) = "GROUP BY BPCORD_0, ITMREF_0, MAIL_0, FULENV_0, VERFSCLI_0, VERFSART_0, FFSART_0, CATEGORIA_0, SOCIEDAD_0, PLANTA_0 "

#If GUSER = "AIT07" Then
#  Local Integer I
#  For I= 1 To 5
#    Infbox LSQL(I)
#  Next
#Endif

  For (Char LBPCORD,Char LITMREF, Char LMAIL, Date LFULENV, Char LVERSFSCLI, Char LVERSFSART, Date LFFSART,
&      Char LCATEGORIA, Char LSOCIEDAD, Char LPLANTA) From "5" Sql LSQL(1..5) As [YPRE]
    [M:YCF1]ITMREF(LCON)    = [F:YPRE]LITMREF
    [M:YCF1]BPCNUM(LCON)    = [F:YPRE]LBPCORD
    [M:YCF1]EMAIL(LCON)     = [F:YPRE]LMAIL
    [M:YCF1]ULTENVDAT(LCON) = [F:YPRE]LFULENV
    [M:YCF1]VERFSBPC(LCON)  = [F:YPRE]LVERSFSCLI
    [M:YCF1]VERFSITM(LCON)  = [F:YPRE]LVERSFSART
    [M:YCF1]DATFSITM(LCON)  = [F:YPRE]LFFSART
    LCON += 1
  Next

  [M:YCF1]NBLIG = LCON
  Affzo [M:YCF1]

Kill LCRIT1, LSQL, LCON

Return

##############################################################
$ENVIOFSFT
Local Integer LCON, STAT : Raz LCON, STAT
Local Char    LVOLFS(255),LVOLFT(255)       : Raz LVOLFS,LVOLFT
Local Char    LPATHFS(255),LPATHFT(255)     : Raz LPATHFS,LPATHFT
Local Char    LVOLFICFS(255),LVOLFICFT(255) : Raz LVOLFICFS,LVOLFICFT
Local Char    LFICHFS(255),LFICHFT(255)     : Raz LFICHFS,LFICHFT
Local Char    ORDSYS(255)
Local Char    NAMEPDF(255) #: NAMEPDF =  "F:\GDOCUMENTAL\ARTICULOS\PDF\Fichero_FSFT.pdf"

If dim([V]GYWNOMFIC)>0 : Kill [V]GYWNOMFIC : Endif
Global Char GYWNOMFIC(255)

  # volumen ficha seguridad
  LVOLFS  = func AFNC.PARAM("YVITMFS", "")

  # volumen ficha técnica
  LVOLFT  = func AFNC.PARAM("YVITMFT", "")

  # fichero PDF unión FT + FS
  Read [F:AVL0]CODE = func AFNC.PARAM("YVPDF", "")
  If !fstat Then
    NAMEPDF = [F:AVL0]ROOT + "\Fichero_FSFT.pdf"
  Endif

  For LCON = 0 To [M:YCF1]NBLIG-1
    If [M:YCF1]SELEC(LCON) = 2 Then
#      If [M:YCF1]VERFSBPC(LCON) <> [M:YCF1]VERFSITM(LCON) Then

        # ruta de la ficha de seguridad y la ficha técnica
        Call GETFICH_FTFS([M:YCF1]ITMREF(LCON),LCON,LVOLFS,LVOLFT,LVOLFICFS,LVOLFICFT,LPATHFS,LPATHFT,LFICHFS,LFICHFT)

        # si hay dos ficheros (ficha tecnica y ficha de seguridad) se ejecuta una aplicación para que los junte en uno sólo
        If LPATHFT <> "" and LPATHFS <> "" Then
          # están marcados los dos flags 'Ficha técnica' y 'Ficha de seguridad'
          If [M:YCF0]FITEC = 2 and [M:YCF0]FISEG = 2 Then
            If filinfo(NAMEPDF, 7) < 0 : Call MESSAGE("No existe el fichero PDF") From GESECRAN : Return : Endif
            ORDSYS = 'C:\PDFtk\bin\pdftk.exe A='+ LPATHFS + ' B='+ LPATHFT + ' output ' + NAMEPDF + ' dont_ask'
            Call SYSTEME(adxmac(0), ORDSYS, "", STAT) From ORDSYS
            GYWNOMFIC = NAMEPDF
          # está marcado solo el flag 'Ficha técnica'
          Elsif [M:YCF0]FITEC = 2 and [M:YCF0]FISEG <> 2 Then
            GYWNOMFIC = LPATHFT
          # está marcado solo el flag 'Ficha de seguridad'
          Elsif [M:YCF0]FITEC <> 2 and [M:YCF0]FISEG = 2 Then
            GYWNOMFIC = LPATHFS
          Else
            Goto ENDNEXT
          Endif
        # sólo tiene adjunto Ficha técnica
        Elsif LPATHFT <> "" and LPATHFS = "" Then
          # sólo se envía si está marcado el flag Ficha técnica
          If [M:YCF0]FITEC = 2 Then
            GYWNOMFIC = LPATHFT
          Else
            Goto ENDNEXT
          Endif
        # sólo tiene adjunto Ficha de seguridad
        Elsif LPATHFT = "" and LPATHFS <> "" Then
          # sólo se envía si está marcado el flag Ficha de seguridad
          If [M:YCF0]FISEG = 2 Then
            GYWNOMFIC = LPATHFS
          Else
            Goto ENDNEXT
          Endif
        Endif

        # busca el destinatario
        If dim([V]GYWDIRMAIL)>0 : Kill [V]GYWDIRMAIL : Endif
        Global Char GYWDIRMAIL(100)
        Filter [F:CNT0] Where BPATYP = 1 and BPANUM = [M:YCF1]BPCNUM(LCON) and CNTMSS = "FS"
        Read [F:CNT0] First
        If !fstat Then
          GYWDIRMAIL = [F:CNT0]WEB
        Endif
        Filter [F:CNT0]

        # alimento las variables globales que se utilizarán en el proceso de actualización de la tabla YHISENVFTFS
        # este proceso se lanza desde la acción YRELLENAFS del propio workflow YENVFCHITM
        If dim(GBPCNUMFS)>0           : Kill GBPCNUMFS : Endif
        Global Char GBPCNUMFS(100)    : GBPCNUMFS = [M:YCF1]BPCNUM(LCON)
        If dim(GITMREFFS)>0           : Kill GITMREFFS : Endif
        Global Char GITMREFFS(100)    : GITMREFFS = [M:YCF1]ITMREF(LCON)
        If dim(GENVFSDATFS)>0         : Kill GENVFSDATFS : Endif
        Global Date GENVFSDATFS(100)  : GENVFSDATFS = date$
        Read [F:ITM0]ITM0 = [M:YCF1]ITMREF(LCON)
        If !fstat Then
          If dim(GFSDATFS)>0            : Kill GFSDATFS : Endif
          Global Date GFSDATFS(100)     : GFSDATFS = [F:ITM0]YFICDAT
          If dim(GFSVERSIONFS)>0        : Kill GFSVERSIONFS : Endif
          Global Char GFSVERSIONFS(100) : GFSVERSIONFS = [F:ITM0]YFICVER
        Endif

        Call WORKFLOW(1,"YEF","","") From AWRK

      Endif
#    Endif
  $ENDNEXT
  Next

Kill LCON,GYWNOMFIC,LVOLFS,LVOLFT,LPATHFS,LPATHFT,LVOLFICFS,LVOLFICFT
Return

##############################################################
$DESCARGARFSFT
Local Integer LCON : Raz LCON
Local Char    LVOLFS(255),LVOLFT(255)       : Raz LVOLFS,LVOLFT
Local Char    LPATHFS(255),LPATHFT(255)     : Raz LPATHFS,LPATHFT
Local Char    LVOLFICFS(255),LVOLFICFT(255) : Raz LVOLFICFS,LVOLFICFT
Local Char    LFICHFS(255),LFICHFT(255)     : Raz LFICHFS,LFICHFT

  # volumen ficha seguridad
  LVOLFS = func AFNC.PARAM("YVITMFS", "")

  # volumen ficha técnica
  LVOLFT = func AFNC.PARAM("YVITMFT", "")

  For LCON = 0 To [M:YCF1]NBLIG-1
    If [M:YCF1]SELEC(LCON) = 2 Then
      # ruta de la ficha de seguridad y la ficha técnica
      Call GETFICH_FTFS([M:YCF1]ITMREF(LCON),LCON,LVOLFS,LVOLFT,LVOLFICFS,LVOLFICFT,LPATHFS,LPATHFT,LFICHFS,LFICHFT)
      If LFICHFS <> "" Then
        Call DESCARGA_DOC(LFICHFS,LVOLFS) From SPEYLIB0
      Endif
      If LFICHFT <> "" Then
        Call DESCARGA_DOC(LFICHFT,LVOLFT) From SPEYLIB0
      Endif
    Endif
  Next

Kill LCON,LVOLFS,LVOLFT,LPATHFS,LPATHFT,LVOLFICFS,LVOLFICFT,LFICHFS,LFICHFT
Return

##############################################################
$IMPRIMIRFSFT
Local Integer LCON : Raz LCON
Local Char    LVOLFS(255),LVOLFT(255)       : Raz LVOLFS,LVOLFT
Local Char    LPATHFS(255),LPATHFT(255)     : Raz LPATHFS,LPATHFT
Local Char    LVOLFICFS(255),LVOLFICFT(255) : Raz LVOLFICFS,LVOLFICFT
Local Char    LFICHFS(255),LFICHFT(255)     : Raz LFICHFS,LFICHFT

  # volumen ficha seguridad
  LVOLFS = func AFNC.PARAM("YVITMFS", "")

  # volumen ficha técnica
  LVOLFT = func AFNC.PARAM("YVITMFT", "")

  For LCON = 0 To [M:YCF1]NBLIG-1
    If [M:YCF1]SELEC(LCON) = 2 Then
      # ruta de la ficha de seguridad y la ficha técnica
      Call GETFICH_FTFS([M:YCF1]ITMREF(LCON),LCON,LVOLFS,LVOLFT,LVOLFICFS,LVOLFICFT,LPATHFS,LPATHFT,LFICHFS,LFICHFT)
#Infbox "1"-LVOLFS
#Infbox "2"-LVOLFT
#Infbox "3"-LVOLFICFS
#Infbox "4"-LVOLFICFT
#Infbox "5"-LPATHFS
#Infbox "6"-LPATHFT
#Infbox "7"-LFICHFS
#Infbox "8"-LFICHFT
      If LPATHFS <> "" Then
        Call IMPRIME_DOC(LPATHFS,"VISTA") From SPEYLIB0
      Endif
      If LPATHFT <> "" Then
        Call IMPRIME_DOC(LPATHFT,"VISTA") From SPEYLIB0
      Endif
    Endif
  Next

Kill LCON,LVOLFS,LVOLFT,LPATHFS,LPATHFT,LVOLFICFS,LVOLFICFT,LFICHFS,LFICHFT
Return

##############################################################
$ENVIORESUMENANUAL
Local Char    TBPAR(20)(1..15)
Local Char    TBVAL(20)(1..15)

Raz TBPAR, TBVAL



  # parámetros del informe
  TBPAR(1)  = "sitedeb"         : TBVAL(1)  = "01"
  TBPAR(2)  = "sitefin"         : TBVAL(2)  = "01"
  TBPAR(3)  = "facturedeb"      : TBVAL(3)  = "9999-17"
  TBPAR(4)  = "facturefin"      : TBVAL(4)  = "9999-17"
  TBPAR(5)  = "typedeb"         : TBVAL(5)  = "1" # factura
  TBPAR(6)  = "typefin"         : TBVAL(6)  = "1" # facura
  TBPAR(7)  = "clientdeb"       : TBVAL(7)  = "285"
  TBPAR(8)  = "clientfin"       : TBVAL(8)  = "285"
  TBPAR(9)  = "datedeb"         : TBVAL(9)  = "01/12/17"
  TBPAR(10) = "datefin"         : TBVAL(10) = "01/12/17"
  TBPAR(11) = "codimp"          : TBVAL(11) = "2" # re-impresión
  TBPAR(12) = "impselections"   : TBVAL(12) = "1" # no
  TBPAR(13) = "duplicata"       : TBVAL(13) = "2" # no

  # lanza el informe..
  Call ETAT("SBONFAC", "VISTA", "SPA", 0, "", TBPAR, TBVAL) From AIMP3

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Botón 'Marcar todos'
######################################################################################
Subprog B1_NBLIG
Local Integer LCON

  For LCON = 0 To [M:YCF1]NBLIG-1
    [M:YCF1]SELEC(LCON) = 2
    Affzo [M:YCF1]SELEC(LCON)
  Next

Kill LCON
End

######################################################################################
## Botón 'Desmarcar todos'
######################################################################################
Subprog B2_NBLIG
Local Integer LCON

  For LCON = 0 To [M:YCF1]NBLIG-1
    [M:YCF1]SELEC(LCON) = 1
    Affzo [M:YCF1]SELEC(LCON)
  Next

Kill LCON
End

######################################################################################
## Inicialización para que muestre o no los botones 1 y 2
######################################################################################
Subprog IB_NBLIG
  If [M:YCF1]NBLIG = 0 Then
    GBOUT1 = ""
    GBOUT2 = ""
  Endif
End

######################################################################################
## Control del campo 'Todas las sociedades'
######################################################################################
Subprog C_YALLCPY(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    Raz   [M:YCF0]CPY
    Affzo [M:YCF0]CPY
    Grizo [M:YCF0]CPY
  Else
    Actzo [M:YCF0]CPY
  Endif
End

######################################################################################
## Control del campo 'Todas las plantas'
######################################################################################
Subprog C_YALLFCY(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    Raz   [M:YCF0]FCY
    Affzo [M:YCF0]FCY
    Grizo [M:YCF0]FCY
  Else
    Actzo [M:YCF0]FCY
  Endif
End

######################################################################################
## Después de modificar el campo 'Cliente inicio'
######################################################################################
Subprog AM_BPCNUMSTR(VALEUR)
Variable Char    VALEUR()
  [M:YCF0]BPCNUMEND = VALEUR
  Affzo [M:YCF0]BPCNUMEND
End

######################################################################################
## Después de modificar el campo 'Categoría inicio'
######################################################################################
Subprog AM_TCLCODSTR(VALEUR)
Variable Char    VALEUR()
  [M:YCF0]TCLCODEND = VALEUR
  Affzo [M:YCF0]TCLCODEND
End

######################################################################################
## Después de modificar el campo 'Artículo inicio'
######################################################################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
  [M:YCF0]ITMREFEND = VALEUR
  Affzo [M:YCF0]ITMREFEND
End

######################################################################################
## Después de modificar el campo 'Fecha inicial'
######################################################################################
Subprog AM_DATINI(VALEUR)
Variable Date    VALEUR
  If [M:YCF0]DATEND <> [00/00/0000] and [M:YCF0]DATEND < VALEUR Then
    Call ERREUR("Fecha incorrecta") From GESECRAN
    mkstat = 2
  Else
    [M:YCF0]DATEND = VALEUR
    Affzo [M:YCF0]DATEND
  Endif
End

######################################################################################
## Después de modificar el campo 'Fecha final'
######################################################################################
Subprog AM_DATEND(VALEUR)
Variable Date    VALEUR
  If [M:YCF0]DATINI <> [00/00/0000] and [M:YCF0]DATINI > VALEUR Then
    Call ERREUR("Fecha incorrecta") From GESECRAN
    mkstat = 2
  Endif
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
#**
#* devuelve las rutas de la ficha técnica y de seguridad asociadas a un artículo
#*
#* @param PITMREF   > código de artículo
#* @param PNUMLIN   > número de línea
#* @param PVOLFS    > volumen de la ficha de seguridad
#* @param PVOLFT    > volumen de la ficha técnica
#* @param PVOLFICFS > volumen + ruta del archivo FS
#* @param PVOLFICFT > volumen + ruta del archivo FT
#* @param PPATHFS   > ruta de la ficha de seguridad
#* @param PPATHFT   > ruta de la ficha técnica
#*!
Subprog GETFICH_FTFS(PITMREF,PNUMLIN,PVOLFS,PVOLFT,PVOLFICFS,PVOLFICFT,PPATHFS,PPATHFT,PFICHFS,PFICHFT)
Value     Char    PITMREF
Value     Integer PNUMLIN
Value     Char    PVOLFS
Value     Char    PVOLFT
Variable  Char    PVOLFICFS
Variable  Char    PVOLFICFT
Variable  Char    PPATHFS
Variable  Char    PPATHFT
Variable  Char    PFICHFS
Variable  Char    PFICHFT

Local Integer LPOS : Raz LPOS
Local Char    LSTR(255) : Raz LSTR
Local Char    LFIC(255) : Raz LFIC

  Filter [F:AOX0] Where ABREV = "ITM" and IDENT1 = [M:YCF1]ITMREF(PNUMLIN)
  For [AOX0]
    LPOS = instr(2,[F:AOX0]NAM,"]")
    LSTR = mid$([F:AOX0]NAM,2,LPOS-2)
    Read [F:AVL0]CODE = LSTR
    If !fstat Then
      If LSTR = "0005ART-FICHATECNICA" Then
        # ruta ficha técnica
        Read [F:AVL0]CODE = PVOLFT
        If !fstat Then
          PPATHFT = [F:AVL0]ROOT
        Endif
        LPOS      = instr(1,[F:AOX0]NAM,"/")
        LFIC      = right$([F:AOX0]NAM,LPOS+1)
        PVOLFICFT = [F:AOX0]NAM
        PPATHFT   += "\"+LFIC
        PFICHFT   = LFIC
      Elsif LSTR = "0006ART-FICHASEGURIDAD" Then
        # ruta ficha seguridad
        Read [F:AVL0]CODE = PVOLFS
        If !fstat Then
          PPATHFS = [F:AVL0]ROOT
        Endif
        LPOS      = instr(1,[F:AOX0]NAM,"/")
        LFIC      = right$([F:AOX0]NAM,LPOS+1)
        PVOLFICFS = [F:AOX0]NAM
        PPATHFS   += "\"+LFIC
        PFICHFS   = LFIC
      Endif
    Endif
  Next
  Filter [F:AOX0]

End

