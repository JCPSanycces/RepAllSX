#XVT10-02-2021 - validar albaranes desde lista de transporte sin usar el campo proyecto, sino el campo
#SDELIVERY.YLISTRANS
$ACTION
  Case ACTION
  When "CFMDLVFIL" : Gosub CFMDLVFIL
  When Default
  Endcase
Return

##############################################################
# punto de entrada para que sólo valide las entregas del proyecto indicado
$CFMDLVFIL
  FILSUP = 'YLISTRANS = "' + [M:DIA]YYLT + '"'
Return
