#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
##If GUSER="AIT50" Then : Infbox ACTION : Endif
Case ACTION
  When "AFTSDHVAL"  : Gosub GET_PTHDLV
  When Default
Endcase
Return


#########################################################
#**
#* Generar Recepción en Malaga y Entrega a cliente final en Málaga
#*!
$GET_PTHDLV

Local Char    LFILE(200), NFILE(200)
Local Char    LDIRIMPORT(250)
Local Integer RECEPCIONAR

LDIRIMPORT = filpath("","","",nomap,"") + "\IMPORT_EXPORT\IMPORT\"

If [F:SDH]BETCPY = 2 and [F:SDH]BETFCY = 2                 # comprobamos que la entrega es Intersociedad e Interplanta
  If [F:SDH]BPCORD = 'IND004' or [F:SDH]BPCORD = 'IND005'  # comprobamos que el cliente ses INDALIM MALAGA-ALM o I.Almeria
    Gosub GEN_PTH
    Gosub IMP_PTH
    Gosub GEN_DLV
    Gosub IMP_DLV
  Endif
Endif

Return

#########################################################
#**
#* Generar Fichero Recepción en Malaga
#*!
$GEN_PTH

Local Char LDATCAB(30)(10),LDATLIN0(30)(10),LDATLIN1(30)(10)
Local Char LSEP(1) : LSEP = ";"
Local Char LFECHA(10), LHORA(10)

LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)

# ruta del fichero..
NFILE  = [F:SDH]SDHNUM + "_PTH_" + LFECHA
LFILE  = LDIRIMPORT + NFILE + ".txt"

Gosub OPEN_FILE

# Modelo Importacón YPTH
#Id,Tabla     Campo   Descripción
# E PRECEIPT  /
# E PRECEIPT  PRHFCY  Planta recepción
# E PRECEIPT  RCPDAT  Fecha recepción
# E PRECEIPT  PTHNUM  Nº recepción
# E PRECEIPT  BPSNUM  Proveedor             Cte. 90001
# E PRECEIPT  TRSCOD  Código movimiento     Cte. INS
# E PRECEIPT  BPSNDE  N. VE proveedor       Nº entrega de la Central
# L PRECEIPTD /                             0 Indica recepcion grabada desde X3
# L PRECEIPTD POHNUN  Pedido de Compra
# L PRECEIPTD POPLIN  Lín. Ped. Compra
# L PRECEIPTD POQSEQ  Seq. Ped. Compra
# L PRECEIPTD ITMREF  Artículo
# L PRECEIPTD UOM     Unidad recepción
# L PRECEIPTD QTYUOM  Cantidad UOM
# L PRECEIPTD GROPRI  Precio bruto
# L PRECEIPTD CPRAMT  Coste fijo unitario
# L PRECEIPTD TRSFAM  Familia movimiento    Cte. 030
# S STOJOU  /
# S STOJOU    PCU     Unidad
# S STOJOU    QTYPCU  Cantidad              Igual que QTYUOM
# S STOJOU    LOC     Ubicación             Cte. TIENDA
# S STOJOU    STA     Estado                Cte. GRUPO

# Ejempo de Fichero
#E;2;20201130;;IND005;INS;20110009;
#L;2188;CAJ;10;;;GRUPO;
#S;CAJ;10;IND;A;

If !clalev([YV02])  : Local File YVINTTRAZAL [YV02] : Endif

[F:SDH]INVFLG = 2
Rewrite [F:SDH]

LDATCAB(1) = [F:SDH]PRHFCY
LDATCAB(2) = [F:SDH]SHIDAT
LDATCAB(3) = ""

If [F:SDH]PRHFCY = '4' : LDATCAB(4) = 'IND001' : Endif
If [F:SDH]PRHFCY = '5' : LDATCAB(4) = 'IND002' : Endif

LDATCAB(5) = "INS"
LDATCAB(6) = [F:SDH]SDHNUM

  Wrseq 'E' + LSEP + LDATCAB(1) + LSEP + LDATCAB(2) + LSEP + LDATCAB(3) + LSEP + LDATCAB(4) + LSEP
&                  + LDATCAB(5) + LSEP + LDATCAB(6) + LSEP
&                  Using [ZIMP]

  If !clalev([ZSDD]) : Local File SDELIVERYD [ZSDD] : Endif

  Filter [ZSDD] Where SDHNUM = [F:SDH]SDHNUM

  Raz  LDATLIN0, LDATLIN1
  For [F:ZSDD]
    Filter [F:YV02] Where EI_SDHNUM = [F:ZSDD]SDHNUM and
&                         EI_SOPLIN = [F:ZSDD]SOPLIN and
&                         EI_SOQSEQ = [F:ZSDD]SOQSEQ
    For [F:YV02]
        LDATLIN0(1) = [F:YV02]CI_POHNUM
        LDATLIN0(2) = num$([F:YV02]CI_POPLIN)
        LDATLIN0(3) = num$([F:YV02]CI_POQSEQ)
        LDATLIN0(4) = [F:ZSDD]ITMREF
        LDATLIN0(5) = [F:ZSDD]STU
        LDATLIN0(6) = num$([F:ZSDD]QTYSTU)
        LDATLIN0(7) = ''
        LDATLIN0(8) = ''
        LDATLIN0(9) = "GRUPO" #MS DAR DE ALTA EN SERV NUEVO. TABLA VARIA 9, RECEPCION INTERSOCIEDAD

        Wrseq 'L' + LSEP + LDATLIN0(1) + LSEP + LDATLIN0(2) + LSEP + LDATLIN0(3) + LSEP + LDATLIN0(4) + LSEP
&                        + LDATLIN0(5) + LSEP + LDATLIN0(6) + LSEP + LDATLIN0(7) + LSEP + LDATLIN0(8) + LSEP
&                        + LDATLIN0(9) + LSEP
&                        Using [ZIMP]


        LDATLIN1(1) = [F:ZSDD]STU
        LDATLIN1(2) = num$([F:ZSDD]QTYSTU)
        LDATLIN1(3) = "IND"
        LDATLIN1(4) = "A"

        Wrseq 'S' + LSEP + LDATLIN1(1) + LSEP + LDATLIN1(2) + LSEP + LDATLIN1(3) + LSEP + LDATLIN1(4) + LSEP
&                        Using [ZIMP]

    Next
  Next

# cerrar fichero import
Gosub CLOSE_FILE

Return


#########################################################
#**
#* Importar Fichero Recepción en Malaga
#*!
$IMP_PTH

# Lo importamos por job ya que da error al validar la entrega desde la transacción INDA
#mkstat = 0 : fstat = 0 : GERRTRACE = 0
#
#Call OUVRE_TRACE("Creación Recepcion a partir de Entrega Validada") From LECFIC
#
#Call IMPORTSIL("YPTH", LFILE) From GIMPOBJ
#
#Call FERME_TRACE From LECFIC
#
#Call LEC_TRACE From LECFIC   #si se quiere mostrar traza
#
#mkstat = 0 : fstat = 0 : GERRTRACE = 0

ZMODIMP = "YPTH"
ZNOMIMP = NFILE + ".txt"
ZVOLFIL = NFILE + ".txt"
ZRUTAJOB= filpath("","","",nomap,"") + "\IMPORT_EXPORT\BATCH\JOB\" + NFILE + ".job"

Call CREAR_JOB(ZMODIMP,ZNOMIMP,ZVOLFIL,ZRUTAJOB) From YAITLIB

Return

#########################################################
#**
#* Generar Fichero Entrega Malaga - Cliente Final
#*!
$GEN_DLV

Local Integer LCON

Local Char LDATCAB(30)(15),LDATLIN0(30)(20),LDATLIN1(30)(10)
Local Char LSEP(1) : LSEP = ";"
Local Char LFECHA(10)

LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)

# Modelo Importacón YDLV
#INDICADOR TABLA CAMPO DESCRIPCIÓN
#H SDELIVERY /
#H SDELIVERY SALFCY  PLANTA VENTA
#H SDELIVERY STOFCY  PLANTA EXPEDICIÓN
#H SDELIVERY SDHNUM  Nº ENTREGA
#H SDELIVERY SDHTYP  TIPO ENTREGA
#H SDELIVERY BPCORD  CLIENTE PEDIDO
#H SDELIVERY BPAADD  DIRECCIÓN ENTREGA
#H SDELIVERY SHIDAT  FECHA EXPEDICIÓN
#H SDELIVERY DLVDAT  FECHA ENTREGA
#L SDELIVERYD  /
#L SDELIVERYD  SOHNUM  Nº PEDIDO
#L SDELIVERYD  SOPLIN  LÍNEA PEDIDO
#L SDELIVERYD  ITMREF  ARTÍCULO
#L SDELIVERYD  SAU UNIDAD VENTA
#L SDELIVERYD  QTY CANTIDAD ENTREGADA
#L SDELIVERYD  VCRTYPORI TIPO ASIENTO ORIGEN
#L SDELIVERYD  VCRNUMORI ASIENTO ORIGEN
#L SDELIVERYD  VCRLINORI NºLÍNEA ASIENTO ORI.
#L SDELIVERYD  VCRSEQORI NºSEC.ASIENTO ORIGEN
#L SDELIVERYD  GROPRI    PRECIO BRUTO
#L SDELIVERYD  DISCRGVAL1 VALOR1 DTO/GTOS
#L SDELIVERYD  DISCRGVAL2 VALOR21 DTO/GTOS
#L SDELIVERYD  DISCRGVAL3 VALOR3 DTO/GTOS
#S STOJOU  /
#S STOJOU  STA ESTADO
#S STOJOU  STU UNIDAD
#S STOJOU  QTYSTU  CANTIDAD
#S STOJOU  LOC UBICACIÓN

#  Ejempo de Fichero
#H;5;5;;SDNB;IND002;1;20201130;20201130;
#L;;;2188;CAJ;10;
#S;A;CAJ;10;IND;


# Registro H

If !clalev([F:YV01]) : Local File YVINTTRAZA [F:YV01] : Endif
Filter [F:YV01] Where EI_STOFCY = [F:SDH]STOFCY and
&                     EI_SDHNUM = [F:SDH]SDHNUM

Read [F:YV01] First

# ruta del fichero..
NFILE  = [YV01]PCLI_SOHNUM + "_DLV_" + LFECHA
LFILE  = LDIRIMPORT + NFILE + ".txt"

Gosub OPEN_FILE

LDATCAB(1) = [YV01]PCLI_SALFCY
LDATCAB(2) = [YV01]PCLI_SALFCY
LDATCAB(3) = ""
LDATCAB(4) = "GENE"
LDATCAB(5) = [YV01]PCLI_BPCORD
LDATCAB(6) = [YV01]PCLI_BPAADD
LDATCAB(7) = format$("D:YYYYMMDD",date$)
LDATCAB(8) = format$("D:YYYYMMDD",date$)

Wrseq 'H' + LSEP + LDATCAB(1) + LSEP + LDATCAB(2) + LSEP + LDATCAB(3) + LSEP + LDATCAB(4) + LSEP
&                + LDATCAB(5) + LSEP + LDATCAB(6) + LSEP + LDATCAB(7) + LSEP + LDATCAB(8) + LSEP
&                  Using [ZIMP]

#REGISTROS L Y S

If !clalev([ZSDD]) : Local File SDELIVERYD  [ZSDD] : Endif
If !clalev([YV02]) : Local File YVINTTRAZAL [YV02] : Endif

Filter [ZSDD] Where SDHNUM = [F:SDH]SDHNUM and STOFCY =  [F:SDD]STOFCY

For [F:ZSDD]
        Filter [YV02] Where EI_STOFCY = [ZSDD]STOFCY and
&                           EI_SDHNUM = [ZSDD]SDHNUM and
&                           EI_SOPLIN = [ZSDD]SOPLIN and
&                           EI_SOQSEQ = [ZSDD]SOQSEQ

        Read [YV02] First

        Raz  LDATLIN0, LDATLIN1

        LDATLIN0(1)  = [YV02]PCLI_SOHNUM
        LDATLIN0(2)  = num$([YV02]PCLI_SOPLIN)
        LDATLIN0(3)  = [F:ZSDD]ITMREF

        LDATLIN0(4)  = [F:ZSDD]SAU
        LDATLIN0(5)  = num$([F:ZSDD]QTY)

        LDATLIN0(6)  = "2"     # Pedido de venta
        LDATLIN0(7)  = [YV02]PCLI_SOHNUM
        LDATLIN0(8)  = num$([YV02]PCLI_SOPLIN)
        LDATLIN0(9)  = num$([YV02]PCLI_SOQSEQ)
        LDATLIN0(10) = num$([YV02]PCLI_GROPRI)
        LDATLIN0(11) = num$([YV02]PCLI_DTO1)
        LDATLIN0(12) = num$([YV02]PCLI_DTO2)
        LDATLIN0(13) = num$([YV02]PCLI_DTO3)

        Wrseq 'L' + LSEP + LDATLIN0(1)  + LSEP + LDATLIN0(2)  + LSEP + LDATLIN0(3)  + LSEP + LDATLIN0(4)  + LSEP
&                            + LDATLIN0(5)  + LSEP + LDATLIN0(6)  + LSEP + LDATLIN0(7)  + LSEP + LDATLIN0(8)  + LSEP
&                            + LDATLIN0(9)  + LSEP + LDATLIN0(10) + LSEP + LDATLIN0(11) + LSEP + LDATLIN0(12) + LSEP
&                            + LDATLIN0(13) + LSEP
&                            Using [ZIMP]

          LDATLIN1(1) = "A"
        LDATLIN1(2) = [F:ZSDD]STU
        LDATLIN1(3) = "-" + num$([F:ZSDD]QTYSTU)
        LDATLIN1(4) = "IND"
        Wrseq 'S' + LSEP + LDATLIN1(1) + LSEP +LDATLIN1(2) + LSEP + LDATLIN1(3) + LSEP + LDATLIN1(4) + LSEP
&                            Using [ZIMP]

      Next
Gosub CLOSE_FILE

Local File [ZSDD],[YV01], [YV02]

Return


#########################################################
#**
#* Importar Fichero Entrega Malaga - Cliente Final
#*!
$IMP_DLV

#mkstat = 0 : fstat = 0 : GERRTRACE = 0
#
#Call OUVRE_TRACE("Creación Entrega al Cliente Final") From LECFIC
#
#Call IMPORTSIL("YSDH", LFILE) From GIMPOBJ
#
#Call FERME_TRACE From LECFIC
#
#Call LEC_TRACE From LECFIC   #si se quiere mostrar traza
#
#DLVOK = GERRTRACE
#
#mkstat = 0 : fstat = 0 : GERRTRACE = 0

ZMODIMP = "YSDH"
ZNOMIMP = NFILE + ".txt"
ZVOLFIL = NFILE + ".txt"
ZRUTAJOB= filpath("","","",nomap,"") + "\IMPORT_EXPORT\BATCH\JOB\" + NFILE + ".job"
Call CREAR_JOB(ZMODIMP,ZNOMIMP,ZVOLFIL,ZRUTAJOB) From YAITLIB


Return





########################################################
$OPEN_FILE

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE Using [ZIMP]

Return


########################################################
$CLOSE_FILE

Openo Using [ZIMP]

Return
