$CONTREMARQ

# Elección del proveedor de Pedido de compra Intersociedad
If [F:SOP]SALFCY = '4' : NUMFOU = [F:SOP]YBPSCOMAR : Endif
If [F:SOP]SALFCY = '5' : NUMFOU = [F:SOP]YBPSCOMAR : Endif

Return

