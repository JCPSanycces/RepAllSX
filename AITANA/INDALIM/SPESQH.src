$ACTION

#Infbox ACTION

Case ACTION
    When "BOUTON"        : Gosub BOUTON  #se pulsa un botón
    When Default
Endcase

Return


########################################################################
$BOUTON
Case BOUT
    When "3"  #el botón pulsado es el de "Búsqueda nueva"
      #Gosub RECHERCHER From FUNMPICK  #ejecuta la carga estÃ¡ndar del cuadro
      Gosub BUSCA_CABECERA  #llama a la etiqueta
      #GPE=1  #detiene el estÃ¡ndar
    When Default
Endcase
Return


########################################################################
$BUSCA_CABECERA
#  Infbox "BUSCA_CABECERA"
Return

