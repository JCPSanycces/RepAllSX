#######################################################################################

$ACTION
  Case ACTION
    When "MODQTEALL"  : Gosub MODQTEALL
  Endcase
Return

################################################
$MODQTEALL
  If GFONCTION = "GESYEXP" Then
    If !clalev([F:YSQ1]) Then : Local File YSORDERQ  [F:YSQ1] : Endif
    Read [F:YSQ1]YSOQ0 = [SOQ]SOHNUM;[SOQ]SOPLIN
    If !fstat Then
      If [F:YSQ1]YSELEC = 2 Then
        WALLSTU = [F:YSQ1]ALLQTY - [SOQ]ALLQTY
      Else
        WALLSTU = 0
      Endif
    Endif
    If clalev([F:YSQ1])  Then : Close Local File     [F:YSQ1] : Endif
  Endif
Return

