#######################################################################################

$ACTION

#Infbox ACTION

Case ACTION
  When "LIENS"        : Gosub LIENS
  When "APRES_MOD"    : Gosub APRES_MOD
  When "APRES_CRE"    : Gosub APRES_CRE
  When "SEL_TABLE"    : Gosub SEL_TABLE                                                 # IN22
  When "VERF_TABLE"   : Gosub VERF_TABLE                                                # IN22
  When Default
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
######################################################################################
$LIENS

Global Char BPINAM1(50)
Global Char BPINAM2(50)
Global Char BPICRY(250)
Global Char BPIADDLIG1(50)
Global Char BPIADDLIG2(50)
Global Char BPIADDLIG3(50)
Global Char BPIPOSCOD(10)
Global Char BPICTY(40)
Global Char BPISAT(35)
Global Char BPICNTNAM(15)
Global Char YDIRFAC(5)

[M:SOH1]YDIRFAC = [F:SOH]BPAINV

Return

######################################################################################
$APRES_CRE
  Gosub REGISTRA_DATOS
Return

######################################################################################
$APRES_MOD
  Gosub REGISTRA_DATOS
Return

########################################################################
$SEL_TABLE
  Case TABLE
    When "YVHSEXPSOH"  : Gosub SEL_YVHSEXPSOH                                     # selección para el campo medio (vehículo) - IN22
  Endcase
Return

########################################################################
$VERF_TABLE
  Case TABLE
    When "YVHSEXPSOH"  : Gosub VERF_YVHSEXPSOH                                    # IN22
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
######################################################################################
$REGISTRA_DATOS

  If !clalev([F:YSOH])  : Local File SORDER [F:YSOH] : Endif

  Read [F:YSOH]SOH0 = [M:SOH0]SOHNUM #buscar el registro a modificar

  If !fstat Then
    [F:YSOH]BPAINV = [M:SOH1]YDIRFAC

    #buscar el resto de campos de la direccion de facturación
    Gosub RESTO_DATOS_FACTURACION

    [F:YSOH]BPIADDLIG(0) = BPIADDLIG1
    [F:YSOH]BPIADDLIG(1) = BPIADDLIG2
    [F:YSOH]BPIADDLIG(2) = BPIADDLIG3
    [F:YSOH]BPIPOSCOD   = BPIPOSCOD
    [F:YSOH]BPICTY      = BPICTY
    [F:YSOH]BPISAT      = BPISAT
    [F:YSOH]BPICRY      = BPICRY

    Rewrite [F:YSOH]
  Endif

  Close Local File [F:YSOH]
Return


######################################################################################
$RESTO_DATOS_FACTURACION

  If clalev([F:BPAA])=0 : Local File BPADDRESS [BPAA] : Endif

  Read [F:BPAA]BPA0 = 1; [M:SOH1]BPCINV;[M:SOH1]YDIRFAC

   BPICRY   = [F:BPAA]CRY
   BPIADDLIG1 = [F:BPAA]BPAADDLIG(0)
   BPIADDLIG2 = [F:BPAA]BPAADDLIG(1)
   BPIADDLIG3 = [F:BPAA]BPAADDLIG(2)
   BPIPOSCOD   = [F:BPAA]POSCOD
   BPICTY      = [F:BPAA]CTY
   BPISAT      = [F:BPAA]SAT


  Close Local File  [BPAA]


Return

########################################################################
$SEL_YVHSEXPSOH
  If !clalev([F:YVHS]) Then : Local File YVEHICULOS [F:YVHS] : Endif            # IN22
  Default File [YVHS]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Mantenimiento de vehículos"                                    # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Medio"                                                         # título de la segunda columna
  COL(NBCOL)  = "YMARCA"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Matrícula"                                                     # título de la primera columna
  COL(NBCOL)  = "YMATRICULA"                                                    # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la tercera columna
  COL(NBCOL)  = "YMODELO"                                                       # nombre del campo a mostrar en la tercera columna
Return

########################################################################
$VERF_YVHSEXPSOH
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Etiqueta añadida por el supervisor (pantalla SOH4) 09/07/2018 14:48:02 (ADMIN)
######################################################################################

# Sustituye artículo reemplazo - Acción de línea de pedido
Subprog B19_NBLIG

Local Char CODIGO_ART(15)
Local Char ART_REEMPLAZO(15)

  CODIGO_ART = [M:SOH4]ITMREF

  If !clalev([F:ZITM]) : Local File ITMMASTER [F:ZITM] : Endif
  Read [F:ZITM]ITM0 = CODIGO_ART
  If !fstat Then
    ART_REEMPLAZO = [F:ZITM]RPLITM
    If [M:SOH4]ALLQTY <> 0 Then
      # incluir la parte que desasigna cantidades #####################################
      [M:SOH4]ITMREF  = ART_REEMPLAZO
      [M:SOH4]ITMDES  = [F:ZITM]ITMDES1
      [M:SOH4]ITMDES1 = [F:ZITM]ITMDES2
    Else
      [M:SOH4]ITMREF  = ART_REEMPLAZO
      [M:SOH4]ITMDES  = [F:ZITM]ITMDES1
      [M:SOH4]ITMDES1 = [F:ZITM]ITMDES2
    Endif
  Else
    Call MESSAGE("No existe artículo de reemplazo\Sustituye el artículo manualmente") From GESECRAN
  Endif

  Close Local File [F:ZITM]

  Affzo [M:SOH4]5

End

######################################################################################
## Etiqueta añadida por el supervisor (pantalla SOH0) 17/07/2018 12:16:42 (ADMIN)
##despues de modificacion de registro
######################################################################################
Subprog AM_BPCORD(VALEUR)
Variable Char    VALEUR()

###buscar la dirección de facturación vinculada a la dirección de entrega

Call BUSCA_DIR_FACTURACION([M:SOH1]BPAADD)

End

######################################################################################
## Etiqueta añadida por el supervisor (pantalla SOH1) 26/07/2018 13:51:16 (ADMIN)
## despues de modificación
######################################################################################
Subprog AM_BPAADD(VALEUR)
Variable Char    VALEUR()

  Call BUSCA_DIR_FACTURACION(VALEUR)

End

######################################################################################
## Etiqueta añadida por el supervisor (pantalla SOH1) 20/07/2018 11:24:12 (ADMIN)
## despues de modificacion
######################################################################################
Subprog C_YDIRFAC(VALEUR)
Variable Char    VALEUR()

#verifica que la dirección indicada existe (para el caso de que la introduzca manualmente)

If clalev([F:BPA])=0 : Local File BPADDRESS [BPA] : Endif

  Read [F:BPA]BPA0 = 1;[M:SOH1]BPCINV;VALEUR

  If fstat
    Call MESSAGE("Dirección Inexistente") From GESECRAN
    GERR = 1 : mkstat = 2

  Endif

Close Local File  [BPA]

End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
######################################################################################

Subprog BUSCA_DIR_FACTURACION(PDIR_ENT)

Value Char PDIR_ENT

If clalev ([F:DIRE]) = 0 : Local File BPDLVCUST [DIRE] Endif

Filter [DIRE] Where  BPCNUM = [M:SOH0]BPCORD and BPAADD = PDIR_ENT #[M:SOH1]BPAADD

Read [DIRE] First


If (fstat = 0)
   [M:SOH1]YDIRFAC = [DIRE]YDIRFAC
Else
   [M:SOH1]YDIRFAC= ""
Endif

Affzo [M:SOH1]YDIRFAC

Close Local File  [DIRE]

End

