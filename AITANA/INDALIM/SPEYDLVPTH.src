#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
$ACTION
#If GUSER="AIT50" Then : Infbox ACTION : Endif

Case ACTION
  When "EXEC" : Gosub EXEC
  When Default
Endcase
Return


######################################################################################
$EXEC
Local Integer DLVOK : DLVOK = 1

If [F:PTH]YTRANSINT <= 0    # no se ha creado ni la entrega ni la recepciĂłn

  Gosub GET_DLV_INT

  If DLVOK = 0        # No se ha producido ningĂşn error en la creaciĂłn de la entrega
    [F:PTH]YTRANSINT = 1
    Rewrite [F:PTH]
    Affzo [M:PTH0]YTRANSINT
    Gosub GET_PTH_INT
    Gosub CHECK_PTH
  Endif
Else
  If [F:PTH]YTRANSINT = 1    # la entrega ya estĂˇ creada
        Gosub GET_PTH_INT
        Gosub CHECK_PTH
  Endif
Endif

Return


#########################################################
#**
#* Comprueba si el job ha generado ya la entrega
#*!
$CHECK_PTH

Local Integer LINTENT : LINENT=1

While LINTENT < 120
  If !clalev([YSDH]) : Local File SDELIVERY [YSDH] : Endif

  Filter [YSDH] Where YRINT = [M:PTH0]PTHNUM
  Read [YSDH] First
  If !clalev([YPTH]) : Local File PRECEIPT [YPTH] : Endif
  Filter [YPTH] Where BPSNDE = [YSDH]SDHNUM
  Read [YPTH] First
  If !fstat
    [F:PTH]YTRANSINT = 2
    Rewrite [F:PTH]
    Infbox "RecepciĂłn " + [YPTH]PTHNUM + " creada en Indalim"
    LINTENT = 200
    Affzo [M:PTH0]YTRANSINT
  Else
    Sleep 1
    LINTENT += 1
  Endif
  Filter [YPTH]
Wend

If LINTENT < 200 : Endbox('Error en la creaciĂłn de la RecepciĂłn') : Endif

Return


#########################################################
#**
#* Generar entrega planta Indalim a partir recepciĂłn en Malaga
#*!
$GET_DLV_INT

Local Char    LFILE(200), NFILE(200)
Local Char    LDIRIMPORT(250)

LDIRIMPORT = filpath("","","",nomap,"") + "\IMPORT_EXPORT\IMPORT\"

Gosub GEN_DLV             # generar fichero
Gosub IMP_DLV             # importar fichero

Return


#########################################################
#**
#* Generar Fichero Entrega Malaga - Indalim
#*!
$GEN_DLV

Local Integer LCON

Local Char LDATCAB(30)(15),LDATLIN0(30)(20),LDATLIN1(30)(10)
Local Char LSEP(1) : LSEP = ";"
Local Char LFECHA(10)

If !clalev([F:YITM]) Then Local File ITMMASTER [F:YITM] : Endif

LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)

# ruta del fichero..
NFILE  = [M:PTH0]PTHNUM + "_DLV_" + LFECHA
LFILE  = LDIRIMPORT + NFILE + ".txt"

Gosub OPEN_FILE

# Modelo ImportacĂłn YDLV
#INDICADOR TABLA CAMPO DESCRIPCIĂ“N
#H SDELIVERY /
#H SDELIVERY SALFCY  PLANTA VENTA
#H SDELIVERY STOFCY  PLANTA EXPEDICIĂ“N
#H SDELIVERY SDHNUM  NÂş ENTREGA
#H SDELIVERY SDHTYP  TIPO ENTREGA
#H SDELIVERY BPCORD  CLIENTE PEDIDO
#H SDELIVERY BPAADD  DIRECCIĂ“N ENTREGA
#H SDELIVERY SHIDAT  FECHA EXPEDICIĂ“N
#H SDELIVERY FECHA   ENTREGA
#H SDELIVERY YRINT   RECEPCION ORIGEN
#H SDELIVERY CFMFLG  VALIDADO
#L SDELIVERYD  /
#L SDELIVERYD  SOHNUM  NÂş PEDIDO
#L SDELIVERYD  SOPLIN  LĂŤNEA PEDIDO
#L SDELIVERYD  ITMREF  ARTĂŤCULO
#L SDELIVERYD  ITMDES  DESCRIPCIĂ“N
#L SDELIVERYD  SAU UNIDAD VENTA
#L SDELIVERYD  QTY CANTIDAD ENTREGADA
#L SDELIVERYD  VCRTYPORI TIPO ASIENTO ORIGEN
#L SDELIVERYD  VCRNUMORI ASIENTO ORIGEN
#L SDELIVERYD  VCRLINORI NÂşLĂŤNEA ASIENTO ORI.
#L SDELIVERYD  VCRSEQORI NÂşSEC.ASIENTO ORIGEN
#S STOJOU  /
#S STOJOU  STA ESTADO
#S STOJOU  PCU UNIDAD
#S STOJOU  QTYPCU  CANTIDAD
#S STOJOU  LOC UBICACIĂ“N

#  Ejempo de Fichero
#H;5;5;;SDNB;IND002;1;20201130;20201130;
#L;;;2188;CAJ;10;
#S;A;CAJ;10;IND;


# Registro H
  LDATCAB(1) = [M:PTH0]PRHFCY
  LDATCAB(2) = [M:PTH0]PRHFCY
  LDATCAB(3) = ""
  LDATCAB(4) = "SDNB"
  If [M:PTH0]PRHFCY = '4' : LDATCAB(5) = 'IND001' : Endif
  If [M:PTH0]PRHFCY = '5' : LDATCAB(5) = 'IND002' : Endif
  LDATCAB(6) = "1"
  LDATCAB(7) = [M:PTH0]RCPDAT
  LDATCAB(8) = [M:PTH0]RCPDAT
  LDATCAB(9) = [M:PTH0]PTHNUM
  LDATCAB(10) = '2'

  Wrseq 'H' + LSEP + LDATCAB(1) + LSEP + LDATCAB(2) + LSEP + LDATCAB(3) + LSEP + LDATCAB(4) + LSEP
&                  + LDATCAB(5) + LSEP + LDATCAB(6) + LSEP + LDATCAB(7) + LSEP + LDATCAB(8) + LSEP
&                  + LDATCAB(9) + LSEP + LDATCAB(10)+ LSEP
&                  Using [ZIMP]

#REGISTROS L Y S
For LCON = 0 To NBLIG-1
  Raz  LDATLIN0, LDATLIN1
    LDATLIN0(1)  = ""
    LDATLIN0(2)  = ""
    LDATLIN0(3)  = [M:PTH1]ITMREF(LCON)
    LDATLIN0(4)  = [M:PTH1]UOM(LCON)
    LDATLIN0(5)  = num$([M:PTH1]QTYUOM(LCON))
#ms al realizar la importaciĂłn no tiene en cuenta los datos que le pasamos ya que
#   debe acturar el std y pone directamente el  VCRTYPORI TIPO ASIENTO ORIGEN a 4 ENTREGA
    LDATLIN0(6) = "6"     # 6 RecepciĂłn  4 ENTREGA
    LDATLIN0(7) = [M:PTH0]PTHNUM
    LDATLIN0(8) = num$([M:PTH1]PTDLIN(LCON))
    LDATLIN0(9) = num$([M:PTH1]PTDLIN(LCON))
    LDATLIN0(10)= num$([M:PTH1]NETPRI)

    Wrseq 'L' + LSEP + LDATLIN0(1) + LSEP + LDATLIN0(2) + LSEP + LDATLIN0(3) + LSEP + LDATLIN0(4) + LSEP
&                    + LDATLIN0(5) + LSEP + LDATLIN0(6) + LSEP + LDATLIN0(7) + LSEP + LDATLIN0(8) + LSEP
&                    + LDATLIN0(9) + LSEP + LDATLIN0(10) + LSEP
&                    Using [ZIMP]

    Read [F:YITM]ITM0=[M:PTH1]ITMREF(LCON)
    LDATLIN1(1) = "A"
    LDATLIN1(2) = [F:YITM]STU
    LDATLIN1(3) = num$([M:PTH1]QTYUOM(LCON)*[F:YITM]PUUSTUCOE)
    #LDATLIN1(4) = "IND"
    LDATLIN1(4) = ""
    Wrseq 'S' + LSEP + LDATLIN1(1) + LSEP +LDATLIN1(2) + LSEP + LDATLIN1(3) + LSEP + LDATLIN1(4) + LSEP
&                    Using [ZIMP]

Next

Gosub CLOSE_FILE

Return


#########################################################
#**
#* Importar Fichero Entrega Malaga - Indalim
#*!
$IMP_DLV

mkstat = 0 : fstat = 0 : GERRTRACE = 0

Call OUVRE_TRACE("CreaciĂłn Entrega a Indalim a partir de RecepciĂłn") From LECFIC

Call IMPORTSIL("YSDH", LFILE) From GIMPOBJ

Call FERME_TRACE From LECFIC

#Call LEC_TRACE From LECFIC   #si se quiere mostrar traza

DLVOK = GERRTRACE

mkstat = 0 : fstat = 0 : GERRTRACE = 0

Return


#########################################################
#**
#* Generar RecepciĂłn en planta Indalim a partir recepciĂłn en Malaga
#*!
$GET_PTH_INT

Local Char    LFILE(200), NFILE(200)
Local Char    LDIRIMPORT(250)
Local Char    LDIRJOB(250)

LDIRIMPORT = filpath("","","",nomap,"") + "\IMPORT_EXPORT\IMPORT\"
LDIRJOB    = filpath("","","",nomap,"") + "\IMPORT_EXPORT\BATCH\JOB\"

Gosub GEN_PTH             # generar fichero
Gosub IMP_PTH             # importar fichero

Return


#########################################################
#**
#* Generar Fichero RecepciĂłn Indalim
#*!
$GEN_PTH

Local Integer LCON

Local Char LDATCAB(30)(15),LDATLIN0(30)(20),LDATLIN1(30)(10)
Local Char LSEP(1) : LSEP = ";"
Local Char LFECHA(10)


LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)

# ruta del fichero..
NFILE  = [M:PTH0]PTHNUM + "_PTH_" + LFECHA
LFILE  = LDIRIMPORT + NFILE + ".txt"

Gosub OPEN_FILE

# Modelo ImportacĂłn YPTHI   ### ACTUALIZAR ###
#Id,Tabla     Campo   DescripciĂłn
# E PRECEIPT  /
# E PRECEIPT  PRHFCY  Planta recepciĂłn
# E PRECEIPT  RCPDAT  Fecha recepciĂłn
# E PRECEIPT  PTHNUM  NÂş recepciĂłn
# E PRECEIPT  BPSNUM  Proveedor             Cte. 90001
# E PRECEIPT  TRSCOD  CĂłdigo movimiento     Cte. INS
# E PRECEIPT  BPSNDE  N. VE proveedor
# L PRECEIPTD /                             0 Indica recepcion grabada desde X3
# L PRECEIPTD SDHNUM  NUMERO ENTREGA
# L PRECEIPTD SDDLIN  LINEA ENTREGA
# L PRECEIPTD POQSEQ  Seq. Ped. Compra    XXXX
# L PRECEIPTD ITMREF  ArtĂ­culo
# L PRECEIPTD UOM     Unidad recepciĂłn
# L PRECEIPTD QTYUOM  Cantidad UOM
# L PRECEIPTD GROPRI  Precio bruto
# L PRECEIPTD CPRAMT  Coste fijo unitario
# L PRECEIPTD TRSFAM  Familia movimiento    Cte. 030
# L PRECEIPTD VCRTYPORI TIPO ASIENTO ORIGEN
# S STOJOU  /
# S STOJOU    PCU     Unidad
# S STOJOU    QTYPCU  Cantidad              Igual que QTYUOM
# S STOJOU    LOC     UbicaciĂłn             Cte. TIENDA
# S STOJOU    STA     Estado                Cte. GRUPO

# Ejempo de Fichero
# E;P0003;20180507;;90001;REC;EPALM0118000019
# L;9054201;UN;100;8.12;8.12;10
# S;UN;100;TIENDA;A


# Registro E
  If [M:PTH0]PRHFCY = '4' : LDATCAB(1) = '1' : Endif
  If [M:PTH0]PRHFCY = '5' : LDATCAB(1) = '2' : Endif
  LDATCAB(2) = [M:PTH0]RCPDAT
  LDATCAB(3) =  ''
  If [M:PTH0]PRHFCY = '4' : LDATCAB(4) = 'IND004' : Endif
  If [M:PTH0]PRHFCY = '5' : LDATCAB(4) = 'IND005' : Endif
  LDATCAB(5) = 'INS'
  LDATCAB(6) = [M:PTH0]PTHNUM

  Wrseq 'E' + LSEP + LDATCAB(1) + LSEP + LDATCAB(2) + LSEP + LDATCAB(3) + LSEP + LDATCAB(4) + LSEP
&                  + LDATCAB(5) + LSEP + LDATCAB(6) + LSEP
&                  Using [ZIMP]

  Raz  LDATLIN0, LDATLIN1

For LCON = 0 To NBLIG-1
  If !clalev([YSDH]) : Local File SDELIVERY [YSDH] : Endif
  Filter [YSDH] Where YRINT = [M:PTH0]PTHNUM
  Read [YSDH] First
  LDATLIN0(1) = [YSDH]SDHNUM
  LDATLIN0(2) = num$([M:PTH1]PTDLIN(LCON))
  LDATLIN0(3) = ''
  LDATLIN0(4) = [M:PTH1]ITMREF(LCON)
  LDATLIN0(5) = [M:PTH1]UOM(LCON)
  LDATLIN0(6) = num$([M:PTH1]QTYUOM(LCON))
  LDATLIN0(7) = ''
  LDATLIN0(8) = ''
  LDATLIN0(9) = 'GRUPO' #MS DAR DE ALTA EN SERV NUEVO. TABLA VARIA 9, RECEPCION INTERSOCIEDAD
  LDATLIN0(10)= '4' #MS RECEPCION

  Wrseq 'L' + LSEP + LDATLIN0(1) + LSEP + LDATLIN0(2) + LSEP + LDATLIN0(3) + LSEP + LDATLIN0(4) + LSEP
&                  + LDATLIN0(5) + LSEP + LDATLIN0(6) + LSEP + LDATLIN0(7) + LSEP + LDATLIN0(8) + LSEP
&                  + LDATLIN0(9) + LSEP + LDATLIN0(10)+ LSEP
&                  Using [ZIMP]

  LDATLIN1(1) = [M:PTH1]UOM(LCON)
  LDATLIN1(2) = num$([M:PTH1]QTYUOM(LCON))
  #LDATLIN1(3) = 'IND'
  LDATLIN1(3) = ''
  LDATLIN1(4) = 'A'

  Wrseq 'S' + LSEP + LDATLIN1(1) + LSEP +LDATLIN1(2) + LSEP + LDATLIN1(3) + LSEP + LDATLIN1(4) + LSEP
&                  Using [ZIMP]

  Next

Gosub CLOSE_FILE

Return


#########################################################
#**
#* Importar Fichero RecepciĂłn Indalim
#*!
$IMP_PTH

#mkstat = 0 : fstat = 0 : GERRTRACE = 0
#
#Call OUVRE_TRACE("CreaciĂłn RecepciĂłn en Indalim a partir de RecepciĂłn Malaga") From LECFIC
#
#Call IMPORTSIL("YPTHI", LFILE) From GIMPOBJ
#
#
#Call FERME_TRACE From LECFIC
#
#Call LEC_TRACE From LECFIC   #si se quiere mostrar traza
#
#mkstat = 0 : fstat = 0 : GERRTRACE = 0

ZMODIMP = "YPTHI"
ZNOMIMP = NFILE + ".txt"
ZVOLFIL = NFILE + ".txt"
ZRUTAJOB= filpath("","","",nomap,"") + "\IMPORT_EXPORT\BATCH\JOB\" + NFILE + ".job"
Call CREAR_JOB(ZMODIMP,ZNOMIMP,ZVOLFIL,ZRUTAJOB) From YAITLIB

Return



########################################################
$OPEN_FILE
#**
#* Abrir fichero txt
#*!
adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE Using [ZIMP]

Return


#########################################################
$CLOSE_FILE
#**
#* Cerrar Fichero txt
#*!
Openo Using [ZIMP]

Return
