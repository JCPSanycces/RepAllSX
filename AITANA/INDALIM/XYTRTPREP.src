# Desarrollador: JCH
# Código de desarrollo: CSA022
# Descripción del desarrollo: Filtro por Hoja de recogida y Mostrar pesos y volúmenes
# Fecha: 15/03/2019
# Codigo Actividad: YIN22
#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif

  Case ACTION
    When "CRIT_SOQ"     : Gosub CRIT_SOQ
    When "BOUTON"       : Gosub BOUTON
    When Default
  Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
########################################################################
# punto de entrada para que sólo muestre las líneas de los pedidos con la hoja de recogida indicada
$CRIT_SOQ
  CRITSOQ += '[F:SOH]YHOJAREC = "' + [M:PREP]YHOJAREC + '"'
Return

########################################################################
$BOUTON
  Case BOUT
    When "p"      : Gosub CALCULO_PESOS
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
########################################################################
$CALCULO_PESOS
Local Integer LCON0 : Raz LCON0
Local Decimal PESTOT, VOLTOT : Raz PESTOT, VOLTOT

  If !clalev([F:YITM]) Then : Local File ITMMASTER [F:YITM] : Endif

  # calcula el peso y volumen totales de las líneas de pedidos seleccionados
  For LCON0 = 0 To [M:PREP]NBLIG-1
    If [M:PREP]COCHAGE(LCON0) = 2 Then
      Read [F:YITM]ITM0 = [M:PREP]ITMREF(LCON0)
      If !fstat Then
        PESTOT += arr(([F:YITM]ITMWEI * [M:PREP]QTYSTU(LCON0)),2)
        VOLTOT += arr(([F:YITM]ITMVOU * [M:PREP]QTYSTU(LCON0)),2)
      Endif
    Endif
  Next

  [M:PREP]YPESTOT = PESTOT
  [M:PREP]YVOLTOT = VOLTOT

  # obtiene la diferencia
  [M:PREP]YDIFPES = [M:PREP]YPESMAX - [M:PREP]YPESTOT
  [M:PREP]YDIFVOL = [M:PREP]YVOLMAX - [M:PREP]YVOLTOT

  Affzo [M:PREP]YPESTOT,YVOLTOT,YDIFPES,YDIFVOL
  If clalev([F:YITM])  Then : Close Local File     [F:YITM] : Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

