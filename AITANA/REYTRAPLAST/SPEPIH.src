#<AdxTL>@(#)0.0.0.0 $Revision$
#MRR01 - 23/03/2021 - Se amplía desarrollo para abonos tipo 'ABAUF'
#--------------------------------------------------------------------------------
$ACTION
Case ACTION
   When "VERIF_CRE": Gosub VERIF_CRE
Endcase
Return

$VERIF_CRE
If [M:PIH0]PIVTYP="AUF"
 Local Integer STAT
 Call NUMERO("ZAUF","",[M:PIH0]ACCDAT,[M:PIH0]BPR,[M:PIH1]BPRVCR,STAT) From SUBANM
 Affzo [M:PIH1]BPRVCR
#MRR01 ini
Else
  If [M:PIH0]PIVTYP="ABAUF"
    Local Integer STAT
    Call NUMERO("ZABAU","",[M:PIH0]ACCDAT,[M:PIH0]BPR,[M:PIH1]BPRVCR,STAT) From SUBANM
    Affzo [M:PIH1]BPRVCR
  Endif
#MRR01 fin
Endif
Return
