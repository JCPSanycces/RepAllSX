#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* #* Caracteristicas de control de calidad de LOTE
#*
#* @param P1 - STOFCY - Planta
#* @param P2 - ITMREF - Articulo
#* @param P3 - LOT    - Lote
#* @param P4 - SLO    - Sublote
#* @param P5 - STA    - Estado
#* @param Pres        - Campo RESP a devolver
#*!
Funprog  GETPROPCC(P1, P2, P3, P4, P5, PRES)
Value Char P1, P2, P3, P4, P5
Value Integer PRES
Local Char LRES
  If !clalev([F:YCC4]) Then : Local File YCC00004 [YCC4] : Endif

  Filter [F:YCC4] Where STOFCY = P1 and ITMREF = P2 and LOT = P3 and SLO = P4 and STA = P5
  Read [F:YCC4] First
  If !fstat Then
    Case PRES
      When 1 : LRES = [F:YCC4]RESP1
      When 2 : LRES = [F:YCC4]RESP2
      When 3 : LRES = [F:YCC4]RESP3
      When 4 : LRES = [F:YCC4]RESP4
    Endcase
  Else
    LRES = '' # P1-P2-P3-P4-P5
  Endif


End LRES

