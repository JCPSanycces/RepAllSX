#<AdxTL>@(#)0.0.0.0 $Revision$
If !clalev([YPOS]) : Local File POSCOD [YPOS] : Endif

For [F:YPOS] Where CRY = 'ES'
Case POSCTYCOD
    When '01' : SATCOD = 'Araba/Álava'
    When '02' : SATCOD = 'Albacete'
    When '03' : SATCOD = 'Alicante/Alacant'
    When '04' : SATCOD = 'Almería'
    When '05' : SATCOD = 'Ávila'
    When '06' : SATCOD = 'Badajoz'
    When '07' : SATCOD = 'Balears, Illes'
    When '08' : SATCOD = 'Barcelona'
    When '09' : SATCOD = 'Burgos'
    When '10' : SATCOD = 'Cáceres'
    When '11' : SATCOD = 'Cádiz'
    When '12' : SATCOD = 'Castellón/Castelló'
    When '13' : SATCOD = 'Ciudad Real'
    When '14' : SATCOD = 'Córdoba'
    When '15' : SATCOD = 'Coruña, A'
    When '16' : SATCOD = 'Cuenca'
    When '17' : SATCOD = 'Girona'
    When '18' : SATCOD = 'Granada'
    When '19' : SATCOD = 'Guadalajara'
    When '20' : SATCOD = 'Gipuzkoa'
    When '21' : SATCOD = 'Huelva'
    When '22' : SATCOD = 'Huesca'
    When '23' : SATCOD = 'Jaén'
    When '24' : SATCOD = 'León'
    When '25' : SATCOD = 'Lleida'
    When '26' : SATCOD = 'Rioja, La'
    When '27' : SATCOD = 'Lugo'
    When '28' : SATCOD = 'Madrid'
    When '29' : SATCOD = 'Málaga'
    When '30' : SATCOD = 'Murcia'
    When '31' : SATCOD = 'Navarra'
    When '32' : SATCOD = 'Ourense'
    When '33' : SATCOD = 'Asturias'
    When '34' : SATCOD = 'Palencia'
    When '35' : SATCOD = 'Palmas, Las'
    When '36' : SATCOD = 'Pontevedra'
    When '37' : SATCOD = 'Salamanca'
    When '38' : SATCOD = 'Santa Cruz de Tenerife'
    When '39' : SATCOD = 'Cantabria'
    When '40' : SATCOD = 'Segovia'
    When '41' : SATCOD = 'Sevilla'
    When '42' : SATCOD = 'Soria'
    When '43' : SATCOD = 'Tarragona'
    When '44' : SATCOD = 'Teruel'
    When '45' : SATCOD = 'Toledo'
    When '46' : SATCOD = 'Valencia/València'
    When '47' : SATCOD = 'Valladolid'
    When '48' : SATCOD = 'Bizkaia'
    When '49' : SATCOD = 'Zamora'
    When '50' : SATCOD = 'Zaragoza'
    When '51' : SATCOD = 'Ceuta'
    When '52' : SATCOD = 'Melilla'
    When Default
Endcase
Rewrite [F:YPOS]
Next
