              LCON += 1
#18112020-STR
            Endif
          Endif
#18112020-END
        Endif
      Elsif [M:YAC0]YSHOWPART = 2 and [M:YAC0]YMCDCA = 2 Then   # mostrar parcial, color distinto a color art獳ulo
        If  [F:SQD0]YCOLOR <> ""
          Read [F:ITM0]ITM0 = [F:SQD0]ITMREF
          If !fstat Then
            If [F:SQD0]YCOLOR = [F:ITM0]YCOLOR or [F:ITM0]YCOLOR = "" or [F:ITM0]LOTMGTCOD = 1 Then     #18112020
