              [M:YAC1]SAU(LCON)         = [F:SQD0]SAU
              [M:YAC1]SAUSTUCOE(LCON)   = [F:SQD0]SAUSTUCOE
              [M:YAC1]BPAADD(LCON)      = [F:SQD0]BPAADD
