#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "DEBUT"      : Gosub DEBUT
  When "SETBOUT"    : Gosub SETBOUT
  When "BOUTON"     : Gosub BOUTON
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$DEBUT

  Gosub LIMPIA_PANTALLAS

Return

##############################################################
$SETBOUT
  Raz CHMEN

  If [M:YAC1]NBLIG = 0 Then
    [M:YAC0]YCOLOR = ""
    Grizo [M:YAC0]YCOLOR
    Grizo [M:YAC0]YSELECTALL
    If [M:YAC0]YCOLOR = "" Then
      CHMEN += "bs"
    Endif
  Else
    Actzo [M:YAC0]YCOLOR
    Actzo [M:YAC0]YSELECTALL
    CHMEN += "bsoc"
  Endif

Return

##############################################################
$BOUTON
  Case BOUT
    When "b"  : Gosub BUSCAR_
    When "s"  : Gosub SALIR_
    When "o"  : Gosub OK_
    When "c"  : Gosub CANCELAR_
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$LIMPIA_PANTALLAS

  Raz [M:YAC0],[M:YAC1]
  Affzo [M:YAC0]
  Affzo [M:YAC1]

  [M:YAC0]YSHOWALL = 2
  Affzo [M:YAC0]YSHOWALL
  Grizo [M:YAC0]YMCI,YMCDCA,YMCICA,YMSC

  Case GFONCTION
    When "GESSQH"   : [M:YAC0]YDOCUMENTO = [M:SQH0]SQHNUM
    When "GESSOH"   : [M:YAC0]YDOCUMENTO = [M:SOH0]SOHNUM
  Endcase

Return

##############################################################
$BUSCAR_
  Case GFONCTION
    When "GESSQH"   : Gosub SHOWSQH
    When "GESSOH"   : Gosub SHOWSOH
  Endcase
Return

##############################################################
$SALIR_
  FIN = 1
  If dim(GDOC) > 0 Then : Kill GDOC : Endif
  If dim(GLIN) > 0 Then : Kill GLIN : Endif
Return

##############################################################
$OK_
  Case GFONCTION
    When "GESSQH"   : Gosub OKSQH
    When "GESSOH"   : Gosub OKSOH
  Endcase
Return

##############################################################
$CANCELAR_

  Gosub LIMPIA_PANTALLAS

Return

##############################################################
$SHOWSQH
If GUSER="AIT07" Then : Infbox "entro en busca presupuesto" : Endif
Local Integer LCON        : Raz LCON
Local Char    LZONA(50)   : Raz LZONA
Local Char    LMUEBLE(50) : Raz LMUEBLE

  Raz [M:YAC1]
  Affzo [M:YAC1]

  If !clalev([F:ITM0]) Then : Local File ITMMASTER  [F:ITM0] : Endif
  If !clalev([F:SQD0]) Then : Local File SQUOTED    [F:SQD0] : Endif

  Filter [F:SQD0] Where SQHNUM = [M:YAC0]YDOCUMENTO
  For [F:SQD0]
    If [F:SQD0]YTIPO = 3 Then
      LZONA   = [F:SQD0]ITMREF
      Goto NEXTSQH_
    Elsif [F:SQD0]YTIPO = 2 Then
      LMUEBLE = [F:SQD0]ITMREF
      Goto NEXTSQH_
    Else
      If [M:YAC0]YSHOWPART = 2 and [M:YAC0]YMCI = 2 Then        # mostrar parcial, color informado
        If [F:SQD0]YCOLOR = "" Then
          Goto NEXTSQH_
        Else
#18112020-STR
          Read [F:ITM0]ITM0 = [F:SQD0]ITMREF
          If !fstat Then
            If [F:ITM0]LOTMGTCOD = 1 Then
              Goto NEXTSQH_
            Else
#18112020-END
              [M:YAC1]YZONA(LCON)   = LZONA
              [M:YAC1]YMUEBLE(LCON) = LMUEBLE
              [M:YAC1]YLINEA(LCON)  = [F:SQD0]SQDLIN
              [M:YAC1]YITMREF(LCON) = [F:SQD0]ITMREF
              [M:YAC1]YITMDES(LCON) = [F:SQD0]ITMDES1
              [M:YAC1]YQTY(LCON)    = [F:SQD0]QTY
              [M:YAC1]YCOLOR(LCON)  = [F:SQD0]YCOLOR

              [M:YAC1]YTIPO(LCON)       = [F:SQD0]YTIPO
              [M:YAC1]YRAL(LCON)        = [F:SQD0]YRAL
              [M:YAC1]STU(LCON)         = [F:SQD0]STU
              [M:YAC1]YGROPRI(LCON)     = [F:SQD0]GROPRI
              [M:YAC1]NETPRI(LCON)      = [F:SQD0]NETPRI
              [M:YAC1]DISCRGVAL1(LCON)  = [F:SQD0]DISCRGVAL1
              [M:YAC1]DISCRGVAL2(LCON)  = [F:SQD0]DISCRGVAL2
              [M:YAC1]DISCRGVAL3(LCON)  = [F:SQD0]DISCRGVAL3
              [M:YAC1]DISCRGVAL4(LCON)  = [F:SQD0]DISCRGVAL4
              [M:YAC1]DISCRGVAL5(LCON)  = [F:SQD0]DISCRGVAL5
