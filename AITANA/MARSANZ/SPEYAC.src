            LCON += 1
          Endif
#18112020-STR
        Endif
      Endif
#18112020-END
    Endif
    $NEXTSQH_
  Next
  [M:YAC1]NBLIG = LCON
  Filter [F:SQD0]
  Close Local File [SQD0],[ITM0]

  Case [M:YAC0]YORDZONA
    When 0,1      : Sorta [M:YAC1]NBLIG [M:YAC1]NBLIG Order By [M:YAC1]YITMREF(indice) Asc
    When 2        : Sorta [M:YAC1]NBLIG [M:YAC1]NBLIG Order By [M:YAC1]YZONA(indice),[M:YAC1]YMUEBLE(indice) Asc
  Endcase

  Affzo [M:YAC1]

Kill LCON

Return

##############################################################
$SHOWSOH
Local Integer LCON        : Raz LCON
Local Char    LZONA(50)   : Raz LZONA
Local Char    LMUEBLE(50) : Raz LMUEBLE

  Raz [M:YAC1]
  Affzo [M:YAC1]

  If !clalev([F:ITM1]) Then : Local File ITMMASTER  [F:ITM1] : Endif
  If !clalev([F:SOQ1]) Then : Local File SORDERQ    [F:SOQ1] : Endif
  If !clalev([F:SOP1]) Then : Local File SORDERP    [F:SOP1] : Endif

  Filter [F:SOQ1] Where SOHNUM = [M:YAC0]YDOCUMENTO
  For [SOQ1]
    If [F:SOQ1]YTIPO = 3 Then
      LZONA   = [F:SOQ1]ITMREF
      Goto NEXTSOH_
    Elsif [F:SOQ1]YTIPO = 2 Then
      LMUEBLE = [F:SOQ1]ITMREF
      Goto NEXTSOH_
    Else
      If [M:YAC0]YSHOWPART = 2 and [M:YAC0]YMCI = 2 Then        # mostrar parcial, color informado
        If [F:SOQ1]YCOLOR = "" Then
          Goto NEXTSOH_
        Else
#18112020-STR
          Read [F:ITM1]ITM0 = [F:SOQ1]ITMREF
          If !fstat Then
            If [F:ITM1]LOTMGTCOD = 1 Then
              Goto NEXTSOH_
            Else
#18112020-END
              [M:YAC1]YZONA(LCON)   = LZONA
              [M:YAC1]YMUEBLE(LCON) = LMUEBLE
              [M:YAC1]YLINEA(LCON)  = [F:SOQ1]SOPLIN
              [M:YAC1]YITMREF(LCON) = [F:SOQ1]ITMREF
              [M:YAC1]YQTY(LCON)    = [F:SOQ1]QTY

              [M:YAC1]YTIPO(LCON)       = [F:SOQ1]YTIPO
              [M:YAC1]YCOLOR(LCON)      = [F:SOQ1]YCOLOR
              [M:YAC1]CPY(LCON)         = [F:SOQ1]CPY
