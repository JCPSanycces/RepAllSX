            [M:YAC1]YLINEA(LCON)  = [F:SOQ1]SOPLIN
            [M:YAC1]YITMREF(LCON) = [F:SOQ1]ITMREF
            [M:YAC1]YQTY(LCON)    = [F:SOQ1]QTY

            [M:YAC1]YTIPO(LCON)       = [F:SOQ1]YTIPO
            [M:YAC1]YCOLOR(LCON)      = [F:SOQ1]YCOLOR
            [M:YAC1]CPY(LCON)         = [F:SOQ1]CPY
            [M:YAC1]SALFCY(LCON)      = [F:SOQ1]SALFCY
            [M:YAC1]BPCORD(LCON)      = [F:SOQ1]BPCORD
            [M:YAC1]DSPLINFLG(LCON)   = [F:SOQ1]DSPLINFLG
            [M:YAC1]DSPWEU(LCON)      = [F:SOQ1]DSPWEU
            [M:YAC1]DSPVOU(LCON)      = [F:SOQ1]DSPVOU
            [M:YAC1]DLVFLG(LCON)      = [F:SOQ1]DLVFLG
            [M:YAC1]ORDDAT(LCON)      = [F:SOQ1]ORDDAT
            [M:YAC1]DEMDLVDAT(LCON)   = [F:SOQ1]DEMDLVDAT
            [M:YAC1]MAXDLVDAT(LCON)   = [F:SOQ1]MAXDLVDAT
            [M:YAC1]SHIDAT(LCON)      = [F:SOQ1]SHIDAT
            [M:YAC1]EXTDLVDAT(LCON)   = [F:SOQ1]EXTDLVDAT
            [M:YAC1]INVFLG(LCON)      = [F:SOQ1]INVFLG
            [M:YAC1]DEMSTA(LCON)      = [F:SOQ1]DEMSTA
            [M:YAC1]DEMNUM(LCON)      = [F:SOQ1]DEMNUM
            [M:YAC1]STOMGTCOD(LCON)   = [F:SOQ1]STOMGTCOD
            [M:YAC1]LOT(LCON)         = [F:SOQ1]LOT
            [M:YAC1]LOC(LCON)         = [F:SOQ1]LOC
            [M:YAC1]ALLTYP(LCON)      = [F:SOQ1]ALLTYP
            [M:YAC1]DRN(LCON)         = [F:SOQ1]DRN
            [M:YAC1]DLVPIO(LCON)      = [F:SOQ1]DLVPIO
            [M:YAC1]DLVPIOCMP(LCON)   = [F:SOQ1]DLVPIOCMP
            [M:YAC1]FMI(LCON)         = [F:SOQ1]FMI
            [M:YAC1]OCNPRNBOM(LCON)   = [F:SOQ1]OCNPRNBOM
            [M:YAC1]NDEPRNBOM(LCON)   = [F:SOQ1]NDEPRNBOM
            [M:YAC1]INVPRNBOM(LCON)   = [F:SOQ1]INVPRNBOM

            Read [F:SOP1]SOP0 = [F:SOQ1]SOHNUM;[F:SOQ1]SOPLIN;[F:SOQ1]SOQSEQ
            If !fstat Then
              [M:YAC1]YITMDES(LCON)     = [F:SOP1]ITMDES
              [M:YAC1]STU(LCON)         = [F:SOP1]STU
              [M:YAC1]YGROPRI(LCON)     = [F:SOP1]GROPRI
              [M:YAC1]NETPRI(LCON)      = [F:SOP1]NETPRI
              [M:YAC1]DISCRGVAL1(LCON)  = [F:SOP1]DISCRGVAL1
              [M:YAC1]DISCRGVAL2(LCON)  = [F:SOP1]DISCRGVAL2
              [M:YAC1]DISCRGVAL3(LCON)  = [F:SOP1]DISCRGVAL3
              [M:YAC1]DISCRGVAL4(LCON)  = [F:SOP1]DISCRGVAL4
              [M:YAC1]DISCRGVAL5(LCON)  = [F:SOP1]DISCRGVAL5
              [M:YAC1]VACITM(LCON)      = [F:SOP1]VACITM
              [M:YAC1]PRIREN(LCON)      = [F:SOP1]PRIREN
              [M:YAC1]VAT(LCON)         = [F:SOP1]VAT
              [M:YAC1]SAU(LCON)         = [F:SOP1]SAU
              [M:YAC1]SAUSTUCOE(LCON)   = [F:SOP1]SAUSTUCOE
              [M:YAC1]BPAADD(LCON)      = [F:SOP1]BPAADD
              [M:YAC1]STOFCY(LCON)      = [F:SOP1]STOFCY
              [M:YAC1]LINTYP(LCON)      = [F:SOP1]LINTYP
              [M:YAC1]FOCFLG(LCON)      = [F:SOP1]FOCFLG
              [M:YAC1]STOFCY(LCON)      = [F:SOP1]STOFCY
              [M:YAC1]SOHCAT(LCON)      = [F:SOP1]SOHCAT
              [M:YAC1]STRDAT(LCON)      = [F:SOP1]STRDAT
              [M:YAC1]ENDDAT(LCON)      = [F:SOP1]ENDDAT
              [M:YAC1]BPCINV(LCON)      = [F:SOP1]BPCINV
              [M:YAC1]REPCOE(LCON)      = [F:SOP1]REPCOE
              [M:YAC1]TSICOD0(LCON)     = [F:SOP1]TSICOD(0)
              [M:YAC1]TSICOD1(LCON)     = [F:SOP1]TSICOD(1)
              [M:YAC1]TSICOD2(LCON)     = [F:SOP1]TSICOD(2)
              [M:YAC1]SOQSTA(LCON)      = [F:SOP1]SOQSTA
              [M:YAC1]EXPNUM(LCON)      = [F:SOP1]EXPNUM
            Endif

            LCON += 1
#18112020-STR
          Endif
        Endif
#18112020-END
      Endif
    Endif
    $NEXTSOH_
  Next
  [M:YAC1]NBLIG = LCON
  Filter [F:SOQ1]
  Close Local File [SOQ1],[SOP1],[ITM1]

  Case [M:YAC0]YORDZONA
    When 0,1      : Sorta [M:YAC1]NBLIG [M:YAC1]NBLIG Order By [M:YAC1]YITMREF(indice) Asc
    When 2        : Sorta [M:YAC1]NBLIG [M:YAC1]NBLIG Order By [M:YAC1]YZONA(indice),[M:YAC1]YMUEBLE(indice) Asc
  Endcase

  Affzo [M:YAC1]

Kill LCON

Return

##############################################################
$OKSQH
Local Integer LCON        : Raz LCON

  If !clalev([F:SQD2]) Then : Local File SQUOTED [F:SQD2] : Endif

  # actualiza el campo color de las l璯eas seleccionadas
  For LCON = 0 To [M:YAC1]NBLIG - 1
    If [M:YAC1]YSELECCION(LCON) = 2 Then
      Read [F:SQD2]SQD0 = [M:YAC0]YDOCUMENTO;[M:YAC1]YLINEA(LCON)
      If !fstat Then
        Trbegin [F:SQD2]
        [F:SQD2]YCOLOR = [M:YAC0]YCOLOR
        Rewrite [F:SQD2]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
      Endif
    Endif
  Next

  # a鎙de las l璯eas que se han generado en la divisi鏮 y borra la que contiene la cantidad total
  For LCON = 0 To [M:YAC1]NBLIG - 1
    If [M:YAC1]YDIVISION(LCON) = 2 Then
      Trbegin [SQD2]
      [F:SQD2]SQHNUM      = [M:YAC0]YDOCUMENTO
      [F:SQD2]SQDLIN      = [M:YAC1]YLINEA(LCON)
      [F:SQD2]YTIPO       = [M:YAC1]YTIPO(LCON)
      [F:SQD2]ITMREF      = [M:YAC1]YITMREF(LCON)
      [F:SQD2]ITMDES      = [M:YAC1]YITMDES(LCON)
      [F:SQD2]ITMDES1     = [M:YAC1]YITMDES(LCON)
      [F:SQD2]QTY         = [M:YAC1]YQTY(LCON)
      [F:SQD2]YCOLOR      = [M:YAC1]YCOLOR(LCON)
      [F:SQD2]YRAL        = [M:YAC1]YRAL(LCON)
      [F:SQD2]STU         = [M:YAC1]STU(LCON)
      [F:SQD2]GROPRI      = [M:YAC1]YGROPRI(LCON)
      [F:SQD2]NETPRI      = [M:YAC1]NETPRI(LCON)
      [F:SQD2]DISCRGVAL1  = [M:YAC1]DISCRGVAL1(LCON)
      [F:SQD2]DISCRGVAL2  = [M:YAC1]DISCRGVAL2(LCON)
      [F:SQD2]DISCRGVAL3  = [M:YAC1]DISCRGVAL3(LCON)
      [F:SQD2]DISCRGVAL4  = [M:YAC1]DISCRGVAL4(LCON)
      [F:SQD2]DISCRGVAL5  = [M:YAC1]DISCRGVAL5(LCON)
      [F:SQD2]CPY         = [M:YAC1]CPY(LCON)
      [F:SQD2]SALFCY      = [M:YAC1]SALFCY(LCON)
      [F:SQD2]BPCORD      = [M:YAC1]BPCORD(LCON)
      [F:SQD2]QUODAT      = [M:YAC1]QUODAT(LCON)
      [F:SQD2]VACITM      = [M:YAC1]VACITM(LCON)
      [F:SQD2]PRIREN      = [M:YAC1]PRIREN(LCON)
      [F:SQD2]VAT         = [M:YAC1]VAT(LCON)
      [F:SQD2]DSPLINFLG   = [M:YAC1]DSPLINFLG(LCON)
      [F:SQD2]SAU         = [M:YAC1]SAU(LCON)
      [F:SQD2]SAUSTUCOE   = [M:YAC1]SAUSTUCOE(LCON)
      [F:SQD2]BPAADD      = [M:YAC1]BPAADD(LCON)
      [F:SQD2]STOFCY      = [M:YAC1]STOFCY(LCON)
      [F:SQD2]LINTYP      = [M:YAC1]LINTYP(LCON)
      [F:SQD2]FOCFLG      = [M:YAC1]FOCFLG(LCON)
      [F:SQD2]ORDFLG      = [M:YAC1]ORDFLG(LCON)
      [F:SQD2]DSPWEU      = [M:YAC1]DSPWEU(LCON)
      [F:SQD2]DSPVOU      = [M:YAC1]DSPVOU(LCON)
      [F:SQD2]DLVFLG      = [M:YAC1]DLVFLG(LCON)
      [F:SQD2]CREDAT      = date$
      Write [F:SQD2]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
      Trbegin [F:SQD2]
      Delete [F:SQD2] Where SQHNUM = GDOC and SQDLIN = GLIN
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Endif
  Next

  Close Local File [SQD2]

  Call MESSAGE("Proceso finalizado") From GESECRAN
  Gosub LIMPIA_PANTALLAS

Kill LCON
Return

##############################################################
$OKSOH
Local Integer LCON        : Raz LCON

  If !clalev([F:SOQ2]) Then : Local File SORDERQ [F:SOQ2] : Endif
  If !clalev([F:SOP2]) Then : Local File SORDERP [F:SOP2] : Endif

  For LCON = 0 To [M:YAC1]NBLIG - 1
    If [M:YAC1]YSELECCION(LCON) = 2 Then
      Filter [F:SOQ2] Where SOHNUM = [M:YAC0]YDOCUMENTO and SOPLIN = [M:YAC1]YLINEA(LCON)
      Read [F:SOQ2] First
      If !fstat Then
        Trbegin [F:SOQ2]
        [F:SOQ2]YCOLOR = [M:YAC0]YCOLOR
        Rewrite [F:SOQ2]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
      Endif
      Filter [F:SOQ2]

      Filter [F:SOP2] Where SOHNUM = [M:YAC0]YDOCUMENTO and SOPLIN = [M:YAC1]YLINEA(LCON)
      Read [F:SOP2] First
      If !fstat Then
        Trbegin [F:SOP2]
        [F:SOP2]YCOLOR = [M:YAC0]YCOLOR
        Rewrite [F:SOP2]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
      Endif
      Filter [F:SOP2]
    Endif
  Next

  # a鎙de las l璯eas que se han generado en la divisi鏮 y borra la que contiene la cantidad total
  For LCON = 0 To [M:YAC1]NBLIG - 1
    If [M:YAC1]YDIVISION(LCON) = 2 Then
      # SORDERP
      Trbegin [SOP2]
      [F:SOP2]SOHNUM      = [M:YAC0]YDOCUMENTO
      [F:SOP2]SOPLIN      = [M:YAC1]YLINEA(LCON)
      [F:SOP2]SOPSEQ      = [M:YAC1]YLINEA(LCON)
      [F:SOP2]YTIPO       = [M:YAC1]YTIPO(LCON)
      [F:SOP2]ITMREF      = [M:YAC1]YITMREF(LCON)
      [F:SOP2]ITMDES      = [M:YAC1]YITMDES(LCON)
      [F:SOP2]ITMDES1     = [M:YAC1]YITMDES(LCON)
      [F:SOP2]YCOLOR      = [M:YAC1]YCOLOR(LCON)
      [F:SOP2]STU         = [M:YAC1]STU(LCON)
      [F:SOP2]GROPRI      = [M:YAC1]YGROPRI(LCON)
      [F:SOP2]NETPRI      = [M:YAC1]NETPRI(LCON)
      [F:SOP2]DISCRGVAL1  = [M:YAC1]DISCRGVAL1(LCON)
      [F:SOP2]DISCRGVAL2  = [M:YAC1]DISCRGVAL2(LCON)
      [F:SOP2]DISCRGVAL3  = [M:YAC1]DISCRGVAL3(LCON)
      [F:SOP2]DISCRGVAL4  = [M:YAC1]DISCRGVAL4(LCON)
      [F:SOP2]DISCRGVAL5  = [M:YAC1]DISCRGVAL5(LCON)
      [F:SOP2]CPY         = [M:YAC1]CPY(LCON)
      [F:SOP2]SALFCY      = [M:YAC1]SALFCY(LCON)
      [F:SOP2]BPCORD      = [M:YAC1]BPCORD(LCON)
      [F:SOP2]VACITM      = [M:YAC1]VACITM(LCON)
      [F:SOP2]PRIREN      = [M:YAC1]PRIREN(LCON)
      [F:SOP2]VAT         = [M:YAC1]VAT(LCON)
      [F:SOP2]SAU         = [M:YAC1]SAU(LCON)
      [F:SOP2]SAUSTUCOE   = [M:YAC1]SAUSTUCOE(LCON)
      [F:SOP2]BPAADD      = [M:YAC1]BPAADD(LCON)
      [F:SOP2]STOFCY      = [M:YAC1]STOFCY(LCON)
      [F:SOP2]LINTYP      = [M:YAC1]LINTYP(LCON)
      [F:SOP2]FOCFLG      = [M:YAC1]FOCFLG(LCON)
      [F:SOP2]CREDAT      = date$
      [F:SOP2]SOHCAT      = [M:YAC1]SOHCAT(LCON)
      [F:SOP2]STRDAT      = [M:YAC1]STRDAT(LCON)
      [F:SOP2]ENDDAT      = [M:YAC1]ENDDAT(LCON)
      [F:SOP2]BPCINV      = [M:YAC1]BPCINV(LCON)
      [F:SOP2]REPCOE      = [M:YAC1]REPCOE(LCON)
      [F:SOP2]TSICOD(0)   = [M:YAC1]TSICOD0(LCON)
      [F:SOP2]TSICOD(1)   = [M:YAC1]TSICOD1(LCON)
      [F:SOP2]TSICOD(2)   = [M:YAC1]TSICOD2(LCON)
      [F:SOP2]SOQSTA      = [M:YAC1]SOQSTA(LCON)
      [F:SOP2]EXPNUM      = [M:YAC1]EXPNUM(LCON)
      Write [F:SOP2]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
      Trbegin [F:SOP2]
      Delete [F:SOP2] Where SOHNUM = GDOC and SOPLIN = GLIN
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
      #SORDERQ
      Trbegin [SOQ2]
      [F:SOQ2]SOHNUM      = [M:YAC0]YDOCUMENTO
      [F:SOQ2]SOPLIN      = [M:YAC1]YLINEA(LCON)
      [F:SOQ2]SOQSEQ      = [M:YAC1]YLINEA(LCON)
      [F:SOQ2]YTIPO       = [M:YAC1]YTIPO(LCON)
      [F:SOQ2]ITMREF      = [M:YAC1]YITMREF(LCON)
      [F:SOQ2]QTY         = [M:YAC1]YQTY(LCON)
      [F:SOQ2]ORIQTY      = [M:YAC1]YQTY(LCON)
      [F:SOQ2]YCOLOR      = [M:YAC1]YCOLOR(LCON)
      [F:SOQ2]CPY         = [M:YAC1]CPY(LCON)
      [F:SOQ2]SALFCY      = [M:YAC1]SALFCY(LCON)
      [F:SOQ2]BPCORD      = [M:YAC1]BPCORD(LCON)
      [F:SOQ2]DSPLINFLG   = [M:YAC1]DSPLINFLG(LCON)
      [F:SOQ2]BPAADD      = [M:YAC1]BPAADD(LCON)
      [F:SOQ2]STOFCY      = [M:YAC1]STOFCY(LCON)
      [F:SOQ2]DSPWEU      = [M:YAC1]DSPWEU(LCON)
      [F:SOQ2]DSPVOU      = [M:YAC1]DSPVOU(LCON)
      [F:SOQ2]DLVFLG      = [M:YAC1]DLVFLG(LCON)
      [F:SOQ2]CREDAT      = date$
      [F:SOQ2]SOHCAT      = [M:YAC1]SOHCAT(LCON)
      [F:SOQ2]ORDDAT      = [M:YAC1]ORDDAT(LCON)
      [F:SOQ2]DEMDLVDAT   = [M:YAC1]DEMDLVDAT(LCON)
      [F:SOQ2]MAXDLVDAT   = [M:YAC1]MAXDLVDAT(LCON)
      [F:SOQ2]EXTDLVDAT   = [M:YAC1]EXTDLVDAT(LCON)
      [F:SOQ2]SHIDAT      = [M:YAC1]SHIDAT(LCON)
      [F:SOQ2]SOQSTA      = [M:YAC1]SOQSTA(LCON)
      [F:SOQ2]INVFLG      = [M:YAC1]INVFLG(LCON)
      [F:SOQ2]DEMSTA      = [M:YAC1]DEMSTA(LCON)
      [F:SOQ2]DEMNUM      = [M:YAC1]DEMNUM(LCON)
      [F:SOQ2]STOMGTCOD   = [M:YAC1]STOMGTCOD(LCON)
      [F:SOQ2]LOT         = [M:YAC1]LOT(LCON)
      [F:SOQ2]LOC         = [M:YAC1]LOC(LCON)
      [F:SOQ2]ALLTYP      = [M:YAC1]ALLTYP(LCON)
      [F:SOQ2]DRN         = [M:YAC1]DRN(LCON)
      [F:SOQ2]DLVPIO      = [M:YAC1]DLVPIO(LCON)
      [F:SOQ2]DLVPIOCMP   = [M:YAC1]DLVPIOCMP(LCON)
      [F:SOQ2]FMI         = [M:YAC1]FMI(LCON)
      [F:SOQ2]OCNPRNBOM   = [M:YAC1]OCNPRNBOM(LCON)
      [F:SOQ2]NDEPRNBOM   = [M:YAC1]NDEPRNBOM(LCON)
      [F:SOQ2]INVPRNBOM   = [M:YAC1]INVPRNBOM(LCON)
      [F:SOQ2]QTYSTU      = [M:YAC1]YQTY(LCON)
      [F:SOQ2]PITFLG      = [M:YAC1]YQTY(LCON)
      Write [F:SOQ2]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
      Trbegin [F:SOQ2]
      Delete [F:SOQ2] Where SOHNUM = GDOC and SOPLIN = GLIN
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Endif
  Next

  Close Local File [SOQ2],[SOP2]

  Call MESSAGE("Proceso finalizado") From GESECRAN
  Gosub LIMPIA_PANTALLAS

Kill LCON
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
##############################################################
######################################################################################
## Despu廥 de modificar el campo 'Mostrar todo'
######################################################################################
Subprog AM_YSHOWALL(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    [M:YAC0]YSHOWPART = 0
    Affzo [M:YAC0]YSHOWPART
    [M:YAC0]YMCI      = 0
    [M:YAC0]YMCDCA    = 0
    [M:YAC0]YMCICA    = 0
    [M:YAC0]YMSC      = 0
    Affzo [M:YAC0]YMCI,YMCDCA,YMCICA,YMSC
    Grizo [M:YAC0]YMCI,YMCDCA,YMCICA,YMSC
  Else
    [M:YAC0]YSHOWPART = 2
    [M:YAC0]YMCI      = 2
    Affzo [M:YAC0]YSHOWPART,YMCI
    Actzo [M:YAC0]YMCI,YMCDCA,YMCICA,YMSC
  Endif
End

######################################################################################
## Despu廥 de modificar el campo 'Mostrar parcial'
######################################################################################
Subprog AM_YSHOWPART(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    [M:YAC0]YSHOWALL  = 0
    [M:YAC0]YMCI      = 2
    Affzo [M:YAC0]YSHOWPART,YMCI
    Affzo [M:YAC0]YSHOWALL
    Actzo [M:YAC0]YMCI,YMCDCA,YMCICA,YMSC
  Else
    [M:YAC0]YSHOWALL  = 2
    Affzo [M:YAC0]YSHOWALL
    [M:YAC0]YMCI      = 0
    [M:YAC0]YMCDCA    = 0
    [M:YAC0]YMCICA    = 0
    [M:YAC0]YMSC      = 0
    Affzo [M:YAC0]YMCI,YMCDCA,YMCICA,YMSC
    Grizo [M:YAC0]YMCI,YMCDCA,YMCICA,YMSC
  Endif
End

######################################################################################
## Despu廥 de modificar el campo 'Mostrar color informado'
######################################################################################
Subprog AM_YMCI(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    [M:YAC0]YMCDCA    = 0
    [M:YAC0]YMCICA    = 0
    [M:YAC0]YMSC      = 0
    Affzo [M:YAC0]YMCDCA,YMCICA,YMSC
  Endif
End

######################################################################################
## Despu廥 de modificar el campo 'Mostrar color distinto color art獳ulo'
######################################################################################
Subprog AM_YMCDCA(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    [M:YAC0]YMCI      = 0
    [M:YAC0]YMCICA    = 0
    [M:YAC0]YMSC      = 0
    Affzo [M:YAC0]YMCI,YMCICA,YMSC
  Endif
End

######################################################################################
## Despu廥 de modificar el campo 'Mostrar color igual color art獳ulo'
######################################################################################
Subprog AM_YMCICA(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    [M:YAC0]YMCI      = 0
    [M:YAC0]YMCDCA    = 0
    [M:YAC0]YMSC      = 0
    Affzo [M:YAC0]YMCI,YMCDCA,YMSC
  Endif
End

######################################################################################
## Despu廥 de modificar el campo 'Mostrar sin color'
######################################################################################
Subprog AM_YMSC(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    [M:YAC0]YMCI      = 0
    [M:YAC0]YMCDCA    = 0
    [M:YAC0]YMCICA    = 0
    Affzo [M:YAC0]YMCI,YMCDCA,YMCICA
  Endif
End

######################################################################################
## Despu廥 de modificar el campo 'Seleccionar todo'
######################################################################################
Subprog AM_YSELECTALL(VALEUR)
Variable Integer VALEUR

Local Integer LCON : Raz LCON

  If VALEUR = 2 Then
    For LCON = 0 To [M:YAC1]NBLIG - 1
      [M:YAC1]YSELECCION(LCON) = 2
    Next
  Else
    For LCON = 0 To [M:YAC1]NBLIG - 1
      [M:YAC1]YSELECCION(LCON) = 0
    Next
  Endif

  Affzo [M:YAC1]

Kill LCON

End

######################################################################################
## Despu廥 de modificar el campo 'Color'
######################################################################################
Subprog AM_YCOLOR(VALEUR)
Variable Char    VALEUR()
  [M:YAC0]YCOLOR = VALEUR
  Affzo [M:YAC0]YCOLOR
End

######################################################################################
## Inicializa el campo 'NBLIG'. Si es componente, oculta la opci鏮 de 'Dividir l璯ea'
######################################################################################
Subprog IB_NBLIG
  If [M:YAC1]YTIPO(nolign-1) = 7 Then
    GBOUT1 = ""
  Endif
End

