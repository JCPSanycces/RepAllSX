            Else
              [M:YAC1]YZONA(LCON)   = LZONA
              [M:YAC1]YMUEBLE(LCON) = LMUEBLE
              [M:YAC1]YLINEA(LCON)  = [F:SQD0]SQDLIN
              [M:YAC1]YITMREF(LCON) = [F:SQD0]ITMREF
              [M:YAC1]YITMDES(LCON) = [F:SQD0]ITMDES1
              [M:YAC1]YQTY(LCON)    = [F:SQD0]QTY
              [M:YAC1]YCOLOR(LCON)  = [F:SQD0]YCOLOR

              [M:YAC1]YTIPO(LCON)       = [F:SQD0]YTIPO
              [M:YAC1]YRAL(LCON)        = [F:SQD0]YRAL
              [M:YAC1]STU(LCON)         = [F:SQD0]STU
              [M:YAC1]YGROPRI(LCON)     = [F:SQD0]GROPRI
              [M:YAC1]NETPRI(LCON)      = [F:SQD0]NETPRI
              [M:YAC1]DISCRGVAL1(LCON)  = [F:SQD0]DISCRGVAL1
              [M:YAC1]DISCRGVAL2(LCON)  = [F:SQD0]DISCRGVAL2
              [M:YAC1]DISCRGVAL3(LCON)  = [F:SQD0]DISCRGVAL3
              [M:YAC1]DISCRGVAL4(LCON)  = [F:SQD0]DISCRGVAL4
              [M:YAC1]DISCRGVAL5(LCON)  = [F:SQD0]DISCRGVAL5
              [M:YAC1]CPY(LCON)         = [F:SQD0]CPY
              [M:YAC1]SALFCY(LCON)      = [F:SQD0]SALFCY
              [M:YAC1]BPCORD(LCON)      = [F:SQD0]BPCORD
