#<AdxTL>@(#)0.0.0.0 $Revision$ 
#LCC-SEPA --- Modificacion control de la fecha de Vencimiento
Local Char PARBOUT(250)(1..1)
Local Char VALBOUT(30)
Local Char OFONCTION(20)
OFONCTION=GFONCTION
If GFONCTION<>"GENBORREM"
 GFONCTION="GENBORREM" : Call AUTORIS From EXEFNC
Endif
GACTION = "GENBORREM"
Call TRAITE_CHAR(VALBOUT,PARBOUT,"","GENBORREM","DGENFRM",3,"") From GTRAITE
If OFONCTION<>GFONCTION
 GFONCTION=OFONCTION : Call AUTORIS From EXEFNC
Endif
End

##########################################################################
$ACTION
##########################################################################
Case ACTION
 When "INIT"        : Gosub INIT
 When "CONTROLE"    : Gosub CONTROLE
 When "EXEC"        : Gosub EXEC
 When "TERMINE"     : Gosub TERMINE
 When "SEL_TABLE"   : Gosub SEL_TABLE
 When "OUVRE_BATCH" : Gosub INIT
Endcase
Return

##########################################################################
$INIT
##########################################################################
Onerrgo CHUT From CONTROLE
If !clalev([F:FCY])  : Local File FACILITY   [FCY]  : Endif
If !clalev([F:CPY])  : Local File COMPANY    [CPY]  : Endif
If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif
If !clalev([F:GCU])  : Local File GRPCUR     [GCU]  : Endif
If !clalev([F:TCU])  : Local File TABCUR     [TCU]  : Endif
If !clalev([F:AUS])  : Local File AUTILIS    [AUS]  : Endif
If !clalev([F:BAN])  : Local File BANK       [BAN]  : Endif
If !clalev([F:PYL])  : Local File PAYLOT     [PYL]  : Endif
If !clalev([F:TED])  : Local File TABCODEDT  [TED]  : Endif
Onerrgo
If GERREUR : GERREUR=0 : Endif
If dim(GCURLEG)>0 : Local Char SAV_GCURLEG(GLONADI) : SAV_GCURLEG = GCURLEG   : Endif
# Dossier mono-leg on force GCURLEG ŕ GDOSLEG
If GNBLEG = 1  : GCURLEG = GDOSLEG : Endif

Return

##########################################################################
$CONTROLE
##########################################################################
TMP=1 : TIT="O"
Return

##########################################################################
$EXEC
##########################################################################
Local Char     PLAN(GLONCOA)
Local Libelle  NIVETB, LCK, FLTRC
Local Integer  OK, STAT, NBCLE, SIGN
Local Integer  MAXLIG, LIGBOR, NBBOR, NBPYH
Local Integer  I, J, K
Local Char     CRITERE(250), CRITERE1(250), CRITERE2(250), CRITSUP(250), EXPCLE(250), ZONE(20)
Local Char     BORFCY(GLONFCY), TYPREG(20), COMPTREG(GLONANM), SEP(6), SEP2(3)
Local Char     DEVLOC(GLONCUR), DEVBAN(GLONCUR), NUMBOR(GLONVCR), CLEGRP(250), PYHCUR(GLONVCR)
Local Char     TRA_BAN(GLONBAN), TRA_TPY(GLONTPY)
Local Decimal  MONTANT, MT, MT2, MTBORMAX, TOTBOR, TOTLOC(3), TOTBAN(3)
Local Date     DATJ
Local Integer  TRANSAC
Local Integer  NIVCUR, NIVECH, NIVUMR
Local Integer  OKTCA

Local Integer I_LPAYLOT
Local Integer STALOT, NB_R
Filter [PYL] Where STA<>5
NB_R = min(10000,rowcount([PYL]))
If NB_R=0 : NB_R=1 : Endif
Filter [PYL]
Local Char    LISTPAYLOT(GLONVCR)(1..NB_R)
Raz I_LPAYLOT

SEP="+', '+" : SEP2=", "

Onerrgo ERREUR From CONTROLE
Local Mask FRM1 [FRM1]
MAXLIG = dim([M:FRM1]NUM)
Close Local Mask [FRM1]
If !clalev([F:GCU])  : Local File GRPCUR     [GCU]  : Endif
If !clalev([F:TCU])  : Local File TABCUR     [TCU]  : Endif
If !clalev([F:TCH])  : Local File TABCHANGE  [TCH]  : Endif
If !clalev([F:BAN])  : Local File BANK       [BAN]  : Endif
If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif
If !clalev([F:PYH])  : Local File PAYMENTH   [PYH]  : Endif
If !clalev([F:PYH2]) : Local File PAYMENTH   [PYH2] : Endif
If !clalev([F:PYH3]) : Local File PAYMENTH   [PYH3] : Endif
If !clalev([F:PYH4]) : Local File PAYMENTH   [PYH4] : Endif
If !clalev([F:FRM])  : Local File PAYFRM     [FRM]  : Endif
If !clalev([F:ANM])  : Local File ACODNUM    [ANM]  : Endif
If !clalev([F:TCA])  : Local File TABCOUAFF  [TCA]  : Endif
If !clalev([F:GAC])  : Local File GACCOUNT   [GAC]  : Endif
If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif
If !clalev([F:ACC])  : Local File ACCES      [ACC]  : Endif
If !clalev([F:PYT])  : Local File TMPPAYTOT  [PYT]  : Endif
If filinfo(filpath("FIL","MANDATE","fde",""),0)>0
 If !clalev([F:MDT])  : Local File MANDATE  [MDT]  : Endif
Endif
If filinfo(filpath("FIL","HISTOMDT","fde",""),0)>0
 If !clalev([F:HMDT]) : Local File HISTOMDT [HMDT] : Endif
Endif

Onerrgo
If GERREUR : GERREUR=0 : FIN=1 : Return : Endif

Local Char    TSYMBOLE(50)(1..max(GNBSOC,nbrecord([F:CPY])))
Local Integer INDLOCK, NBLOCK
NBLOCK = 0
If [M:DIA]ALLCPY<>2
 NBLOCK=1
 TSYMBOLE(NBLOCK) = "GENBORREM\"+[M:DIA]CPY
 Lock =TSYMBOLE(NBLOCK) With lockwait=0
 If fstat
  # Opération en cours sur autre poste
  GERR=1 : GMESSAGE=mess(30,100,1)
  FIN=1 : Return
 Endif
Else
 For [CPY]CPY0 Where LEG=GCURLEG & CPYLEGFLG=2
  NBLOCK+=1
  TSYMBOLE(NBLOCK) = "GENBORREM\"+[F:CPY]CPY
  Lock =TSYMBOLE(NBLOCK) With lockwait=0
  If fstat
   # Opération en cours sur autre poste
   GERR=1 : GMESSAGE=mess(30,100,1)
   FIN=1 : Break
  Endif
 Next
 If FIN=1 : NBLOCK -=1 : Gosub DEVERROU : Return : Endif
Endif


If !GSERVEUR
 Call TITAWI(BCRIT,CRITERE) From OBJDIV
 Call OUVRE_TRACE(CRITERE) From LECFIC
Endif

CRITERE = "STA<5 & FRMNUM='' & BAN<>''"
If [M:DIA]ALLCPY<>2
 CRITERE -= '& CPY="'+[M:DIA]CPY+'"'
Endif
If [M:DIA]ALLFCY<>2
 CRITERE -= '& FCY="'+[M:DIA]FCY+'"'
Endif
If [M:DIA]ALLTYP<>2
 CRITERE -= '& PAYTYP="'+[M:DIA]TYP+'"'
Endif
If [M:DIA]ALLLOT<>2
 CRITERE -= '& PAYLOT="'+[M:DIA]LOT+'"'
Endif
If [M:DIA]ALLUSR<>2
 CRITERE -= '& (UPDUSR="'+[M:DIA]USR+'"'
 CRITERE -= '| (UPDUSR="" & CREUSR="'+[M:DIA]USR+'"))'
Endif
If [M:DIA]ALLBAN<>2
 CRITERE -= '& BAN="'+[M:DIA]BAN+'"'
Endif
If [M:DIA]ALLCUR<>2
 If [M:DIA]CUR<>""
  CRITERE -= '& CUR="'+[M:DIA]CUR+'"'
 Elsif [M:DIA]GRPCUR<>""
  Call LECTURE("GCU",[M:DIA]GRPCUR,"") From CONTOBJ
 Endif
Endif
If [M:DIA]DATECHMAX<>[0/0/0]
 CRITERE -= '& DUDDAT<>[0/0/0]'
 CRITERE -= '& DUDDAT<=['+format$(GFMD,[M:DIA]DATECHMAX)+']'
Endif
CRITSUP = ""
GPOINT = "CRITERE" : Gosub ENTREE From EXEFNC
If CRITSUP="" : CRITSUP = "1=1" : Endif

# 1er tri :
# - Par Type de rčglement
# - Par Banque
# - Par législation saisie
Filter [PYH2] Where evalue(CRITERE) & evalue(CRITSUP)
&              Order By Key CLE = PAYTYP;BAN;CUR
For [PYH2]CLE(1)
 [L]OK = 1
 Call LEC_TPY_LEG(GCURLEG,[F:PYH2]PAYTYP) From CPTLEC
 If fstat | [F:TPY]STA5<>2 | [F:TPY]ENAFLG<>2
  [L]OK = 0
 Else
  Call CONTEXE([F:TPY]ACS) From CPTSUB
  If mkstat : mkstat=0 : OK=0 : GMESSAGE="" : Endif
 Endif
 If OK
  ## SEPA : Regrouper les échéances par date d'échéance
  NIVECH = 0
#  If dim([F:TPY]EPACDTTRF)>0 & [F:TPY]EPACDTTRF=2 	# LCC-SEPA
#   NIVECH = 2										# LCC-SEPA
#  Endif											# LCC-SEPA
  ## SDD : Group by scheme and sequence
  NIVUMR = 0
  If dim(GSDDMGT)>0 & GSDDMGT=2 & dim([F:TPY]EPACDTTRF)>0 & [F:TPY]EPACDTTRF=2 & [F:TPY]SNS=2
   NIVUMR = 2
  Endif
  GPOINT = "FRMGNR" : Gosub ENTREE From EXEFNC
  Gosub TR
  If GOK<1 : Break : Endif
 Endif
Next : # [PYH2]
Filter [PYH2] : Filter [PYH4]

If NBPYH
 If [M:DIA]CPY<>""
  Call SETCUR(1,[M:DIA]CPY,DEVLOC) From CPTDIV
 Else
  Call SETCURFLD(DEVLOC) From CPTDIV
 Endif
 Call ECR_TRACE(" ",0) From GESECRAN

 # Total Transaction
 Filter [PYT] Where TRC=GTRACE Order By Key CLE=PAYTYP
 For [PYT]CLE(1)
  MT=0 : MT2=0
  For [PYT]CLE
   If [F:PYT]SNS=1
    MT+=[F:PYT]AMTLOC
   Else
    MT2+=[F:PYT]AMTLOC
   Endif
  Next
  If MT<>0  : GMESSAGE=mess(1,632,1)-"="-num$(MT)-DEVLOC : Else GMESSAGE="" : Endif
  If MT2<>0 : GMESSAGE=GMESSAGE+string$(MT<>0,SEP2)-mess(2,632,2)-"="-num$(MT2)-DEVLOC : Endif
  Call ECR_TRACE(mess(69,116,1)-mess(3,871,1)-[F:PYT]PAYTYP-":"-GMESSAGE,0) From GESECRAN
 Next

 # Total Banque
 Filter [PYT] Where TRC=GTRACE Order By Key CLE=BAN
 For [PYT]CLE(1)
  MT=0 : MT2=0
  For [PYT]CLE
   If [F:PYT]SNS=1 : MT+=[F:PYT]AMTCUR : Else MT2+=[F:PYT]AMTCUR : Endif
  Next
  If MT<>0  : GMESSAGE=mess(1,632,1)-"="-num$(MT)-[F:PYT]CUR : Else GMESSAGE="" : Endif
  If MT2<>0 : GMESSAGE=GMESSAGE+string$(MT<>0,SEP2)-mess(2,632,2)-"="-num$(MT2)-[F:PYT]CUR : Endif
  Call ECR_TRACE(mess(69,116,1)-mess(1,653,1)-[F:PYT]BAN-":"-GMESSAGE,0) From GESECRAN
 Next

 # Total général
 Filter [PYT] Where TRC=GTRACE
 MT=0 : MT2=0
 For [PYT]PYT0
  If [F:PYT]SNS=1
   MT+=[F:PYT]AMTLOC
  Else
   MT2+=[F:PYT]AMTLOC
  Endif
 Next
 If MT<>0  : GMESSAGE=mess(1,632,1)-"="-num$(MT)-DEVLOC : Else GMESSAGE="" : Endif
 If MT2<>0 : GMESSAGE=GMESSAGE+string$(MT<>0,SEP2)-mess(2,632,2)-"="-num$(MT2)-DEVLOC : Endif
 Call ECR_TRACE(mess(86,117,1)-":"-GMESSAGE,0) From GESECRAN
 Filter [PYT]
 GMESSAGE=""
 Gosub TR_RAZ_PYT
Endif

Trbegin [PYL]
 For I=1 To I_LPAYLOT
  [L]STALOT = func SUBPAY5.CALSTAPYL(LISTPAYLOT(I))
  If [L]STALOT>0
   Update [PYL] Where COD=LISTPAYLOT(I) With STA=[L]STALOT
   If fstat
    GOK=0 : Call FSTA("PYL") From GLOCK : Break
   Endif
  Endif
 Next
Commit

If !GSERVEUR
 Call FERME_TRACE From LECFIC
 TRA=1
Endif

Gosub DEVERROU
Return

##########################################################################
$DEVERROU
##########################################################################
If dim(TSYMBOLE)>0
 For INDLOCK=1 To NBLOCK
  Unlock =TSYMBOLE(INDLOCK)
 Next
Endif
Return


##########################################################################
$TERMINE
##########################################################################
If GSERVEUR : Return : Endif
If !NBPYH
 GERR=2
 If LCK=0 & [L]PYHCUR<>""
  # Rčglement NUM - Modification en cours sur un autre poste
  GMESSAGE=mess(27,117,1)-[L]PYHCUR+"\"+mess(10,100,1)
 Else
  # Aucun rčglement traité
  GMESSAGE=mess(2,117,1)
 Endif
Endif

If dim(SAV_GCURLEG)>0 : GCURLEG = SAV_GCURLEG : Endif
Return

##########################################################################
$TR
##########################################################################
Call LEC_TED(GCURLEG,[F:TPY]CODEDT) From CPTLEC
If !fstat : TYPREG=[F:TED]TRT : Else TYPREG="" : Endif
For [PYH2]CLE(2)
 [L]OK = 1
 Call LEC_BAN([F:PYH2]BAN) From CPTLEC
 If fstat : [L]OK=0 : Endif
 If [L]OK
  Call CONTEXE([F:BAN]ACS) From CPTSUB
  If mkstat : mkstat=0 : OK=0 : GMESSAGE="" : Endif
 Endif
 If [M:DIA]ALLCPY=2 & [L]OK
  Call LEC_CPY([F:PYH2]CPY) From CPTLEC
  If GCURLEG<>[F:CPY]LEG : OK = 0 : Endif
 Endif
 If [L]OK
  DEVBAN = [F:BAN]CUR
  If [F:TPY]SNS>2 : MTBORMAX=0 : Else MTBORMAX=[M:DIA]MAXAMTVCR : Endif
  CRITERE1 = 'FRMNUM="" & PAYTYP="'+[F:PYH2]PAYTYP+'"'
  If [M:DIA]ALLCPY<>2
   CRITERE1 -= '& CPY="'+[M:DIA]CPY+'"'
  Endif
  If [M:DIA]ALLFCY<>2
   CRITERE1 -= '& FCY="'+[M:DIA]FCY+'"'
  Endif
  If [M:DIA]ALLLOT<>2
   CRITERE1 -= '& PAYLOT="'+[M:DIA]LOT+'"'
  Endif
  If [M:DIA]ALLUSR<>2
   CRITERE1 -= '& (UPDUSR="'+[M:DIA]USR+'"'
   CRITERE1 -= '| (UPDUSR="" & CREUSR="'+[M:DIA]USR+'"))'
  Endif
  CRITERE1 -= ' & BAN="'+[F:PYH2]BAN+'"'
  # SDD : Only EURO payments (In fact SDD payments are in EURO. This is a security)
  If dim(GSDDMGT)>0 & GSDDMGT=2 & dim([F:TPY]EPACDTTRF)>0 & [F:TPY]EPACDTTRF=2 & [F:TPY]SNS=2
   CRITERE1 -= '& CUR="'+GEURO+'"'
  Endif
  If [M:DIA]CUR<>""
   CRITERE1 -= '& CUR="'+[M:DIA]CUR+'"'
  Endif
  STAT=0
  If [F:TPY]STA3=2 : STAT=2 : Elsif [F:TPY]STA2=2 : STAT=1 : Endif
  If STAT : CRITERE1 -= " & STA>"+num$(STAT) : Endif
  CRITERE1 -= '& STA<5'
  If [M:DIA]DATECHMAX<>[0/0/0]
   CRITERE1 -= '& DUDDAT<>[0/0/0]'
   CRITERE1 -= '& DUDDAT<=['+format$(GFMD,[M:DIA]DATECHMAX)+']'
  Endif
  CRITSUP = ""
  GPOINT = "CRITERE2" : Gosub ENTREE From EXEFNC
  If CRITSUP="" : CRITSUP = "1=1" : Endif

  # Loop over the bank and each bank is linked with one company.
  # Reading of one company for each bank
  COMPTREG = ""
  GSOCIETE = [F:PYH2]CPY
  Call LECTCA(3,OKTCA) From SUBTCA
  If OKTCA
   COMPTREG = [F:TCA]CODNUM(2)
  Endif
  If COMPTREG="" : COMPTREG = "PY5" : Endif

  Call LECTURE("ANM",COMPTREG,"") From CONTOBJ
  If [F:ANM]NIVDEF=3 : NIVETB=2 : Endif

  # 2čme Tri (Banque et type de rčglement sont figés par le 1er tri) :
  # - Par Etab ou Société selon le niveau de numérotation de PAY5
  # - Par Type de remise si saisi pour le type de rčglement
  # - Par Type de chčque si saisi pour le type de rčglement
  #                   et si Remise chčque SP/HP =Oui pour la banque
  # - Par référence si saisi pour le type de rčglement
  #                 et si groupement par référence voulu

  ## Si une seule étape de comptabilisation (=compta en banque) et avec groupement par
  ## bordereau/avis de domiciliation, on fait une rupture sur la devise.
  NIVCUR = 0
  If [F:TPY]STA3<>2 & [F:TPY]STA8<>2 & ([F:TPY]ACETYP91=2 | [F:TPY]ACETYP92=2)
   NIVCUR = 2
  Endif

  If NIVETB=2 : # Groupement par site
   If [F:TPY]DACFRMTYP<>3 & !find(TYPREG,"CHR","CHE") : # Par type de remise
    If [F:TPY]DACFRMREF<>3 & [M:DIA]REF=2
     EXPCLE="FCY;FRMTYP;FRMREF"
    Else
     If [F:BAN]CHQTYPFLG=2 & [F:TPY]DACCHQTYP<>3
      If [F:TPY]DACFRMREF<>3 & [M:DIA]REF=2
       EXPCLE = "FCY;CHQTYP;FRMREF"
      Else
       EXPCLE = "FCY;CHQTYP"
      Endif
     Else
      If [F:TPY]DACFRMREF<>3 & [M:DIA]REF=2
       EXPCLE = "FCY;FRMREF"
      Else
       EXPCLE = "FCY"
      Endif
     Endif
    Endif
   Else
    EXPCLE = "FCY"
   Endif
  Else : # Groupement par société
   If [F:TPY]DACFRMTYP<>3 & !find(TYPREG,"CHR","CHE") : # Par type de remise
    If [F:TPY]DACFRMREF<>3 & [M:DIA]REF=2
     EXPCLE = "CPY;FRMTYP;FRMREF"
    Else
     EXPCLE = "CPY;FRMTYP"
    Endif
   Else
    If [F:BAN]CHQTYPFLG=2 & [F:TPY]DACCHQTYP<>3
     If [F:TPY]DACFRMREF<>3 & [M:DIA]REF=2
      EXPCLE = "CPY;CHQTYP;FRMREF"
     Else
      EXPCLE = "CPY;CHQTYP"
     Endif
    Else
     If [F:TPY]DACFRMREF<>3 & [M:DIA]REF=2
      EXPCLE = "CPY;FRMREF"
     Else
      EXPCLE = "CPY"
     Endif
    Endif
   Endif
  Endif
  If NIVECH = 2 : EXPCLE += ";DUDDAT" : Endif
  If NIVCUR = 2 : EXPCLE += ";CUR"    : Endif
  If NIVUMR = 2 : EXPCLE += ";UMRSEQ" : Endif
  Filter [PYH4] Where evalue(CRITERE1) & evalue(CRITSUP) Order With Key CLE = EXPCLE

  K=1 : NBCLE=0 : CLEGRP="[F:PYH]BAN"+SEP+"[F:PYH]PAYTYP"
  Repeat
   J=instr(K,EXPCLE,";")
   If !J : ZONE=right$(EXPCLE,K) : Else ZONE=seg$(EXPCLE,K,J-1) : K=J+1 : Endif
   NBCLE+=1
   Case ZONE
    When "CHQTYP" : CLEGRP+=SEP+"mess([F:PYH]CHQTYP,654,1)"
    When "FRMTYP" : CLEGRP+=SEP+"mess([F:PYH]FRMTYP,655,1)"
    When "DUDDAT" : CLEGRP+=SEP+"format$('D:'+GFMDAT,[F:PYH]DUDDAT)"
    When "UMRSEQ" : CLEGRP+=SEP+"mess(val(left$([F:PYH]UMRSEQ,1)),3629,1)"+SEP+"right$([F:PYH]UMRSEQ,3)"
    When Default  : CLEGRP+=SEP+"[F:PYH]"+ZONE
   Endcase
  Until !J

  For [PYH4]CLE(1)
   Call SETMAINREF([F:PYH4]CPY,GTYPGEN,GTYPANA) From CPTDIV
   Call LECPLAN([F:PYH4]CPY,GTYPGEN,PLAN) From CPTDIV
   If [M:DIA]CPY<>""
    Call SETCUR(1,[M:DIA]CPY,DEVLOC) From CPTDIV
   Else
    Call SETCURFLD(DEVLOC) From CPTDIV
   Endif

   If NBCLE>1
    For [PYH4]CLE(NBCLE)
     Gosub CRITERE2
     Gosub GENER
     If GOK<0 : Break(3) : Endif
     If GERR
      If GMESSAGE<>""
       Call ECR_TRACE(GMESSAGE,GERR) From GESECRAN
      Endif
      GERR=0 : GMESSAGE=""
     Endif
    Next : # [PYH4]CLE(NBCLE)
   Else
    Gosub CRITERE2
    Gosub GENER
    If GOK<1 : Break(2) : Endif
    If GERR
     If GMESSAGE<>""
      Call ECR_TRACE(GMESSAGE,GERR) From GESECRAN
     Endif
     GERR=0 : GMESSAGE=""
    Endif
   Endif
  Next : # [PYH4]CLE(1)
 Else
  GOK=1
 Endif : # OK
Next : # [PYH2]CLE(2)
Return

##########################################################################
$CRITERE2
##########################################################################
CRITERE2="" : K=1
For I=1 To NBCLE
 J=instr(K,EXPCLE,";")
 If !J : ZONE=right$(EXPCLE,K) : Else ZONE=seg$(EXPCLE,K,J-1) :  K=J+1 : Endif
 If I<>1 : CRITERE2-=" &" : Endif
 CRITERE2 -= ZONE+"=[F:PYH4]"+ZONE
Next I
Return

##########################################################################
$GENER
##########################################################################
# Transaction = création d'un bordereau de remise
GOK=1 : NUMBOR="" : [L]DATJ=date$ : TRANSAC = 0
For [PYH] Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITSUP) With Nohint
 Readlock [PYH]PYH0 Curr
 If fstat=1
  GOK=-1 : GLOCK="$PAYMENTH"-[F:PYH]NUM : Break
 Elsif fstat
  GOK=0 : Call RSTA("PYH",[F:PYH]NUM) From GLOCK : Break
 Endif

 [L]OK = 1

 PYHCUR=[F:PYH]NUM : LCK=1
 Lock ="PYH"+PYHCUR
 If fstat
  LCK=0 : GOK=-1 : GLOCK="%PYH"+PYHCUR : Break
 Elsif [M:DIA]GRPCUR="" | find([F:PYH]CUR,[F:GCU]CUR(0..[F:GCU]NBRCUR-1))
  OK=1
  If [M:DIA]MAXAMTPAY<>0 | [M:DIA]MINAMTPAY<>0 | MTBORMAX<>0
   If [F:PYH]CUR=[M:DIA]CURMINAMT
    MONTANT=[F:PYH]AMTCUR
   Else
    Call CONVERT([F:PYH]CUR,[M:DIA]CURMINAMT,DEVLOC,[F:TPY]RATTYP
&               ,[F:PYH]ACCDAT,[F:PYH]AMTCUR,MONTANT,STAT) From TRTDEV
    If STAT : # Rčglement PYHCUR : Pas de cours de devises CUR -> [M:DIA]CURMINAMT (ACCDAT)
     Call ECR_TRACE(mess(27,117,1)-PYHCUR-":"-mess(16,114,1)-[F:PYH]CUR-"->"-[M:DIA]CURMINAMT
&                  -"("+format$("D:"+GFMDAT,[F:PYH]ACCDAT)-")",1) From GESECRAN
     OK = 0
    Endif
   Endif
   If ([M:DIA]MAXAMTPAY<>0 & MONTANT>[M:DIA]MAXAMTPAY) |
&     ([M:DIA]MINAMTPAY<>0 & [M:DIA]MINAMTPAY>MONTANT)
    OK=0
   Endif
   # Bug 20661-120609
   If MTBORMAX<>0 & MONTANT>MTBORMAX
    OK=0
   Endif
   # Fin bug 20661
  Endif
 Else
  OK=0
 Endif

 # SDD : The mandate of the payment must be approved or expired
 If OK & dim(GSDDMGT)>0 & GSDDMGT=2 & dim([F:TPY]EPACDTTRF)>0 & [F:TPY]EPACDTTRF=2 & [F:TPY]SNS=2
  Call LEC_MDT([F:PYH]CPY,[F:PYH]UMRNUM) From CPTLEC
  If [F:MDT]STA<>2 & [F:MDT]STA<>5
   OK = 0
  Endif
 Endif

 If OK
  If NUMBOR<>"" & LIGBOR & ((MTBORMAX<>0 & TOTBOR+MONTANT>MTBORMAX) | LIGBOR>=MAXLIG)
   Commit : # Fin de transaction
   Call DELOCK("PYH") From GLOCK
   Unlock [PYH]
   NBPYH+=LIGBOR : NBBOR+=1
   Gosub TRACE
   Gosub TOTAUX
   NUMBOR=""
  Endif
  If NUMBOR=""
   Call DEBTRANS From GLOCK
   LIGBOR=0 : TOTBOR=0 : Raz TOTLOC, TOTBAN
   Trbegin [PYH], [FRM] : # Début de transaction
    TRANSAC = 1 : # <PP 31/10/02> Pour bug 16391
    [L]BORFCY=[M:DIA]FRMFCY
    If [L]BORFCY="" : [L]BORFCY=[F:PYH]FCY : Endif
    Call NUMERO(COMPTREG,[L]BORFCY,datesyst,[F:PYH]PAYTYP,NUMBOR,STAT) From SUBANM
    If STAT
     # Problčme lors de la récupération du compteur
     Gosub MESSAGE From SUBANM
     GMESSAGE = mess(60,199,1)-"("+COMPTREG+") : "+MESSA
     GERR=1 : GOK = 0 : Break
    Endif
  Endif
  [F:PYH]FRMNUM=NUMBOR : [F:PYH]FRMLIN=LIGBOR+1 : [F:PYH]FRMFLG=1
  [F:PYH]STA=5 : [F:PYH]STAFLG(4)=2
  If find(TYPREG,"CHR","CHE")
   [F:PYH]FRMTYP=1 : # Chčques -> Encaissement
  Elsif [F:TPY]DACFRMTYP=3 | [F:PYH]FRMTYP=0
   [F:PYH]FRMTYP=[M:DIA]FRMTYP
  Endif
  [F:PYH]FRMUSR=GUSER  : [F:PYH]FRMDAT=[L]DATJ : [F:PYH]FRMFCY=[L]BORFCY
  GPOINT = "PYH" : Gosub ENTREE From EXEFNC
  Rewrite [PYH]
  If fstat=0
   If dim(GSDDMGT)>0 & GSDDMGT=2 & [F:TPY]EPACDTTRF=2 & [F:TPY]SNS=2
    Update [HMDT] Where PAYNUM=[F:PYH]NUM With FRMNUM=[F:PYH]FRMNUM
    If fstat
     GOK=0 : Call FSTA("HMDT") From GLOCK : Break
    Endif
   Endif
   If dim([F:PYL]STA)>0 & [F:PYH]PAYLOT<>"" & I_LPAYLOT<dim(LISTPAYLOT)
    If !find([F:PYH]PAYLOT,LISTPAYLOT(1..I_LPAYLOT))
     I_LPAYLOT +=1
     LISTPAYLOT(I_LPAYLOT) = [F:PYH]PAYLOT
    Endif
   Endif
   If LIGBOR=0
    Raz [F:FRM]
    [F:FRM] = [F:PYH]
    If dim([F:FRM]UPDDAT)>0 : Raz [F:FRM]UPDDAT : Endif
    If dim([F:FRM]UPDUSR)>0 : Raz [F:FRM]UPDUSR : Endif
    If dim([F:FRM]CREDAT)>0 : [F:FRM]CREDAT=[F:PYH]FRMDAT : Endif
    If dim([F:FRM]CREUSR)>0 : [F:FRM]CREUSR=[F:PYH]FRMUSR : Endif
    If dim([F:FRM]EXEDAT)>0 : [F:FRM]EXEDAT=[M:DIA]EXEDAT : Endif    :# dem. 17278
    Write [FRM]
    If fstat
     GOK=0 : Call FSTA("FRM") From GLOCK : Break
    Endif
    TRA_TPY=[F:PYH]PAYTYP
    TRA_BAN=[F:PYH]BAN
   Endif
   LIGBOR+=1 : TOTBOR+=MONTANT
   If [F:TPY]SNS<3
    If [F:PYH]SNS=[F:TPY]SNS : SIGN=1 : Else SIGN=-1 : Endif
   Elsif [F:PYH]SNS=1 : SIGN=-1 : # Dépense
   Else               : SIGN=1  : # Recette
   Endif
   If [F:PYH]CUR=DEVLOC
    MONTANT=[F:PYH]AMTCUR
   Elsif DEVLOC=DEVBAN & [F:PYH]AMTBAN<>0 : # GH 24/05/99
    MONTANT=[F:PYH]AMTBAN
   Else
    Call CONVERT([F:PYH]CUR,DEVLOC,DEVLOC,[F:TPY]RATTYP,[F:PYH]ACCDAT
&               ,[F:PYH]AMTCUR,MONTANT,STAT) From TRTDEV
    If STAT : MONTANT=0 : Endif
   Endif
   TOTLOC(0)+=SIGN*MONTANT : TOTLOC([F:PYH]SNS)+=MONTANT : MT=MONTANT
   # Montant en devise banque
   If [F:PYH]CUR=DEVBAN
    MONTANT=[F:PYH]AMTCUR
   Elsif [F:PYH]AMTBAN<>0 : # GH 24/05/99
    MONTANT=[F:PYH]AMTBAN
   Elsif DEVBAN<>DEVLOC
    Call CONVERT([F:PYH]CUR,DEVBAN,DEVLOC,[F:TPY]RATTYP,[F:PYH]ACCDAT
&               ,[F:PYH]AMTCUR,MONTANT,STAT) From TRTDEV
    If STAT : MONTANT=0 : Endif
   Endif
   TOTBAN(0)+=SIGN*MONTANT : TOTBAN([F:PYH]SNS)+=MONTANT
  Else
   GOK=0 : Call FSTA("PYH") From GLOCK : Break
  Endif
 Endif : # OK
 If LCK : Unlock ="PYH"+PYHCUR : Endif
Next : # [PYH]
If TRANSAC : # <PP 31/10/02> Pour corriger bug 16391 sans prendre de risque....
 If GOK=0    : Goto AB_TR
 Elsif GOK<0 : Goto ROLL_TR
 Elsif !LIGBOR | NUMBOR="" : Goto AB_TR
 Endif
 Commit : # Fin de transaction
 NBPYH+=LIGBOR : NBBOR+=1
 Gosub TRACE
 Gosub TOTAUX
Endif
Call DELOCK("PYH") From GLOCK
Unlock [PYH]
GPOINT = "AFTCREFRM" : Gosub ENTREE From EXEFNC
Return

##########################################################################
$TRACE
##########################################################################
If [L]NUMBOR="" : Return : Endif
If FLTRC
 Call ECR_TRACE(" ",0) From GESECRAN
 FLTRC=0
Endif
For [PYH3]PYH1 Where FRMFLG=1 & FRMNUM=[L]NUMBOR
 If !FLTRC
  GMESSAGE = evalue(CLEGRP)+SEP2+num$([L]TOTLOC(0))-DEVLOC
  # Bordereau de remise NUM : ... TOTLOC DEVLOC
  Call ECR_TRACE(mess(126,117,1)-[L]NUMBOR-":"-GMESSAGE,0) From GESECRAN
  FLTRC=1
 Endif
 # Rčglement NUM : nom du tiers/libellé du compte, AMTCUR CUR (,RIB obligatoire)
 If [F:PYH3]BPR<>""
  Call LEC_BPR([F:PYH3]BPR) From CPTLEC
  GMESSAGE=[F:BPR]BPRNAM
 Elsif [F:PYH3]ACC<>""
  Call LECTEXTRA(GMESSAGE,"GACCOUNT","DESTRA",PLAN,[F:PYH3]ACC) From ATEXTRA
 Endif
 GMESSAGE += SEP2+num$([F:PYH3]AMTCUR)-[F:PYH3]CUR
 If [F:TPY]DACBID=1 & [F:PYH3]BID="" : # RIB obligatoire
  GMESSAGE += SEP2+mess(27,199,1)
 Endif
 Call ECR_TRACE(mess(27,117,1)-[F:PYH3]NUM-":"-GMESSAGE,0) From GESECRAN
Next : # [PYH3]
GMESSAGE=""
Return

##########################################################################
$TOTAUX
##########################################################################
If [L]NUMBOR="" : Return : Endif
GOK=1
Trbegin [PYT]
 For I=1 To 2
  If TOTLOC(I)<>0 | TOTBAN(I)<>0
   Read [PYT]PYT0 = GTRACE;TRA_TPY;"";DEVBAN;TRA_BAN;[0/0/0];I
   If fstat>2 : Raz [F:PYT] : Endif
   [F:PYT]AMTCUR += TOTBAN(I)
   [F:PYT]AMTLOC += TOTLOC(I)
   If [F:PYT]TRC=""
    [F:PYT]TRC    = GTRACE
    [F:PYT]CUR    = DEVBAN
    [F:PYT]PAYTYP = TRA_TPY
    [F:PYT]BAN    = TRA_BAN
    [F:PYT]SNS    = I
    Write [PYT]
   Else
    Rewrite [PYT]
   Endif
   If fstat
    GOK=2 : Call FSTA("PYT") From GLOCK
   Endif
  Endif
 Next I
Commit
Return

##########################################################################
$TR_RAZ_PYT
##########################################################################
GOK=1
Trbegin [PYT]
 Delete [PYT] Where TRC=GTRACE
 If fstat=1 | fstat>5
  GOK=2 : Call RSTA("PYT",GTRACE) From GLOCK
 Endif
Commit
Return

$AB_TR
Rollback
Call DELOCK("PYH") From GLOCK
Unlock [PYH]
Return

$ROLL_TR
Rollback
Call DELOCK("PYH") From GLOCK
Unlock [PYH]
Call ROLL From GLOCK
If GROLL : Return : Else Goto GENER : Endif


##########################################################################
$SEL_TABLE
##########################################################################
Case COUZON
 When "LOT" : # Lot de saisie
  OBJET="PYL"
  If [M]ALLCPY<>2
   CRITERE-="& CPY='"+[M]CPY+"'"
  Else
   CRITERE-="& [F:CPY]LEG='"+GCURLEG+"'"
  Endif
  If [M]ALLTYP<>2
   CRITERE-="& PAYTYP='"+[M]TYP+"'"
  Endif
  If CRITERE<>"" : CRITERE=right$(CRITERE,4) : Endif
 When "BAN" : Gosub SELBAN From CPTSEL
Endcase
Return

##########################################################################
##
## Etiquettes de l'écran GENBORREM
##
##########################################################################

Subprog AS_ALLCPY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLCPY(VALEUR) From CPTTRT
End

Subprog C_ALLCPY(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CPY,FCY : Grizo CPY,FCY
 [M]ALLFCY=2 : Affzo ALLFCY  : Grizo ALLFCY
 If dim([M]LEG)>0 : Actzo LEG : Endif
 GSOCIETE=""
 GCURFCY=""
Else
 Actzo CPY,ALLFCY
 If dim([M]LEG)>0 : Effzo LEG : Diszo LEG : Endif
Endif
End

Subprog AP_ALLCPY(VALEUR)
Variable Integer VALEUR
## Si le traitement est lançé pour toutes les sociétés, les montants rčglements maxi, mini seront
## ŕ exprimer
##     - en devise référentiel général principal si ttes les sociétés sont associées ŕ la męme devise pour le
##       référentiel général principal
##     - sinon en devise GCURSHR
Local Char DEVISE(GLONCUR)
Call SETCURFLD(DEVISE) From CPTDIV
[M]CURMINAMT  = DEVISE
[M]CURMAXAMT1 = DEVISE
[M]CURMAXAMT2 = DEVISE
Affzo CURMINAMT, CURMAXAMT1, CURMAXAMT2
End


Subprog AS_CPY(VALEUR)
Variable Char     VALEUR
If [M]ALLCPY = 2 : mkstat = 2 : Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
Call C_CPY(VALEUR) From CPTTRT
End

Subprog AM_CPY(VALEUR)
Variable Char     VALEUR
Call AM_CPY (VALEUR) From CPTTRT
End

Subprog AP_CPY(VALEUR)
Variable Char    VALEUR()
## Si le traitement est lançé pour une société, les montants rčglements maxi, mini seront
## ŕ exprimer en devise de référentiel général principal
Local Char DEVLED(GLONCUR)
Call SETCUR(1,VALEUR,DEVLED) From CPTDIV
[M]CURMINAMT  = DEVLED
[M]CURMAXAMT1 = DEVLED
[M]CURMAXAMT2 = DEVLED
Affzo CURMINAMT, CURMAXAMT1, CURMAXAMT2
End

Subprog C_LEG(VALEUR)
Variable Char    VALEUR()
Call C_LEG (VALEUR) From CPTTRT
End

Subprog AS_ALLFCY(VALEUR)
Variable Integer  VALEUR
Call AS_ALLFCY(VALEUR) From CPTTRT
End

Subprog C_ALLFCY(VALEUR)
Variable Integer VALEUR
Call C_ALLFCY(VALEUR) From CPTTRT
End

Subprog AS_FCY(VALEUR)
Variable Char VALEUR
If [M]ALLFCY = 2 : mkstat = 2 : Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call C_FCY(VALEUR) From CPTTRT
End

Subprog C_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo TYP : Grizo TYP
 [M]ALLCUR = 2 : [M]CUR="" : Actzo ALLCUR : Grizo CUR : Affzo ALLCUR, CUR
Else
 Actzo TYP
Endif
End

Subprog AM_ALLTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo TYP : Grizo TYP
 [M]ALLCUR = 2 : Affzo ALLCUR
Else
 Actzo TYP
Endif
End


Subprog AS_TYP(VALEUR)
Variable Char     VALEUR
If [M]ALLTYP = 2 : mkstat = 1 : Endif
End

Subprog C_TYP(VALEUR)
Variable Char     VALEUR
If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif
Call LEC_TPY_LEG(GCURLEG,VALEUR) From CPTLEC
If fstat | [F:TPY]STA5<>2
 # Type de rčglement non paramétré pour cette fonction
 GMESSAGE=mess(29,117,1) : mkstat=2
Else
 Call CONTEXE([F:TPY]ACS) From CPTSUB
Endif
End

Subprog AP_TYP(VALEUR)
Variable Char    VALEUR()
If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif
Call LEC_TPY_LEG(GCURLEG,VALEUR) From CPTLEC
If [F:TPY]EPACDTTRF=2
 [M]ALLCUR = 1 : [M]CUR = GEURO
 Affzo ALLCUR, CUR
 Grizo ALLCUR, CUR
Else
 Actzo ALLCUR, CUR
Endif
End

Subprog C_ALLLOT(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo LOT : Grizo LOT
Else
 Actzo LOT
Endif
End


Subprog AS_LOT(VALEUR)
Variable Char    VALEUR()
If [M]ALLLOT=2 : mkstat=1 : Endif
End

Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
If !clalev([F:PYL]) : Local File PAYLOT [PYL] : Endif
Call LECTURE("PYL",VALEUR,"") From CONTOBJ
If fstat : End
Elsif [M]ALLCPY<>2 & [F:PYL]CPY<>[M]CPY
 # Lot de saisie de société
 GMESSAGE=mess(110,121,1)-[F:PYL]CPY : mkstat=2
Elsif [M]ALLTYP<>2 & [F:PYL]PAYTYP<>[M]TYP
 # Lot de saisie de transaction
 GMESSAGE=mess(111,121,1)-[F:PYL]PAYTYP  : mkstat=2 : End
Endif
End

Subprog C_ALLUSR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo USR : Grizo USR
Else
 Actzo USR
Endif
End


Subprog AS_USR(VALEUR)
Variable Char     VALEUR
If [M]ALLUSR = 2 : mkstat = 1
Elsif VALEUR="" : VALEUR = GUSER
Endif
End

Subprog C_ALLCUR(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo CUR,GRPCUR : Grizo CUR,GRPCUR
Else
 Actzo CUR
 If [M]CUR<>"" : Effzo GRPCUR : Grizo GRPCUR : Else : Actzo GRPCUR : Endif
Endif
End

Subprog AS_CUR(VALEUR)
Variable Char VALEUR
If [M]ALLCUR=2 : mkstat=1 : End : Endif
End

Subprog C_CUR(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" : Effzo GRPCUR :  Grizo GRPCUR : Else : Actzo GRPCUR : Endif
End

Subprog AS_GRPCUR(VALEUR)
Variable Char    VALEUR()
If [M]ALLCUR=2 | [M]CUR<>"" : mkstat=1 : Endif
End

Subprog C_ALLBAN(VALEUR)
Variable Integer VALEUR
If VALEUR=2
 Effzo BAN : Grizo BAN
Else
 Actzo BAN
Endif
End

Subprog AS_BAN(VALEUR)
Variable Char     VALEUR
If [M]ALLBAN = 2 : mkstat = 1 : Endif
End

Subprog AS_REF(VALEUR)
Variable Integer  VALEUR
If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif
If [M]TYP<>""
 Call LEC_TPY_LEG(GCURLEG,[M]TYP) From CPTLEC
 If fstat=0 & [F:TPY]DACFRMREF=3 : mkstat=1 : Endif
Else
 Filter [TPY] Where DACFRMREF<>3 & STA5=2 & LEG=GCURLEG
 Read [TPY]TPY0 First
 If fstat>2 : mkstat=1 : Endif
 Filter [TPY]
Endif
End

Subprog AS_FRMTYP(VALEUR)
Variable Integer  VALEUR
If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif
If !clalev([F:TED])  : Local File TABCODEDT  [TED]  : Endif
If [M]TYP<>""
 Call LEC_TPY_LEG(GCURLEG,[M]TYP) From CPTLEC
 If fstat=0
  Call LEC_TED(GCURLEG,[F:TPY]CODEDT) From CPTLEC
  If find([F:TED]TRT,"CHR","CHE") : VALEUR=1 : mkstat=2
  Elsif fstat=0 & [F:TPY]DACFRMTYP<>3 : mkstat=1
  Endif
 Endif
Else
 Local Libelle I, J
 For [TPY]TPY0 Where STA5=2
  Call LEC_TED(GCURLEG,[F:TPY]CODEDT) From CPTLEC
  If !find([F:TED]TRT,"CHR","CHE") : I=1 : # pas que des chčques
   If [F:TPY]DACFRMTYP=3 : J=1 : Endif : # traite avec type de remise non saisi
  Endif
 Next
 If !I    : VALEUR=1 : mkstat=2 : # que des chčques
 Elsif !J : mkstat=1 : # toutes les traites ont le type de remise saisi
 Endif
Endif
End

Subprog C_MAXAMTPAY(VALEUR)
Variable Decimal  VALEUR
If VALEUR<>0 & VALEUR<[M]MINAMTPAY
 GMESSAGE=mess(20,116,1) : mkstat=2 : # Montant incorrect
Endif
End

Subprog AS_MAXAMTVCR(VALEUR)
Variable Decimal  VALEUR
If !clalev([F:TPY])  : Local File TABPAYTYP  [TPY]  : Endif
If [M]TYP<>""
 Call LEC_TPY_LEG(GCURLEG,[M]TYP) From CPTLEC
 If fstat=0 & [F:TPY]SNS>2 : mkstat=1 : Endif
Else
 Filter [TPY] Where SNS<3 & STA5=2 & LEG=GCURLEG
 Read [TPY]TPY0 First
 If fstat>2 : mkstat=1 : Endif
 Filter [TPY]
Endif
End

Subprog C_MAXAMTVCR(VALEUR)
Variable Decimal  VALEUR
If VALEUR<>0 & VALEUR<[M]MAXAMTPAY
 GMESSAGE=mess(20,116,1) : mkstat=2 : # Montant incorrect
Endif
End

Subprog AS_FRMFCY(VALEUR)
Variable Char VALEUR
If [M]FCY<>""
 VALEUR=[M]FCY : mkstat=2 : End
Elsif [M]CPY=""
 mkstat=1 : End
Else
 If !clalev([F:ANM])  : Local File ACODNUM    [ANM]  : Endif
 If !clalev([F:TCA])  : Local File TABCOUAFF  [TCA]  : Endif
 Local Char COMPTREG(GLONANM) :  COMPTREG = ""
 Local Integer OKTCA
 GSOCIETE = [M]CPY
 Call LECTCA(3,OKTCA) From SUBTCA
 If OKTCA : COMPTREG = [F:TCA]CODNUM(2) : Endif
 If COMPTREG="" : COMPTREG = "PY5" : Endif
 Call LECTURE("ANM",COMPTREG,"") From CONTOBJ
 If [F:ANM]NIVDEF=3
  mkstat = 1 : End
 Endif
Endif
End

########################################

Subprog AV_INI(VALEUR)
Variable Char VALEUR()
If [M]ALLCPY=2
 Effzo CPY,FCY : Grizo CPY,FCY
 [M]ALLFCY=2 : Affzo ALLFCY  : Grizo ALLFCY
Else
 Actzo CPY,ALLFCY
 If [M]ALLFCY=2
  Effzo FCY : Grizo FCY
 Else
  Actzo FCY
 Endif
Endif
If [M]ALLLOT=2
 Effzo LOT : Grizo LOT
Else
 Actzo LOT
Endif
If [M]ALLBAN=2
 Effzo BAN : Grizo BAN
Else
 Actzo BAN
Endif
If [M]ALLCUR=2
 Effzo CUR,GRPCUR : Grizo CUR,GRPCUR
Else
 Actzo CUR
 If [M]CUR<>"" : Effzo GRPCUR : Grizo GRPCUR : Else : Actzo GRPCUR : Endif
Endif
If [M]ALLUSR=2
 Effzo USR : Grizo USR
Else
 Actzo USR
Endif
If GBIDC1<>""
 [M]ALLTYP = 1 : [M]TYP = GBIDC1
 Affzo [M]ALLTYP, TYP
 If dim(ZTYP)>0 : Affzo ZTYP : Endif
 Grizo ALLTYP, TYP
Else
 Actzo ALLTYP
 If [M]ALLTYP=2
  Effzo TYP : Grizo TYP
 Else
  Actzo TYP
 Endif
Endif
End




