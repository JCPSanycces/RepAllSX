$ACTION
Case ACTION
  When "STYLE"    :   Gosub STYLE
  When "SETBOUT"  :   Gosub SETBOUT
Endcase
Return


##############################################################
######################    ACCIONES    ########################
##############################################################
########################################################
$STYLE
## Marco el fondo de las líneas en función del tipo de línea
#Local Integer LINE
#For LINE = 0 To [M:SQH2]NBLIG-1
#  If left$([M:SQH2]ITMREF(LINE),4) = 'ZONA'
#    Chgstl NBLIG(LINE) With "BACKGREEN"      # Fondo verde
#  Elsif left$([M:SQH2]ITMREF(LINE),4) = 'MUEB'
#    Chgstl NBLIG(LINE) With "BACKORANGE"    # Fondo naranja
#  Else
#    Chgstl NBLIG(LINE) With ""
#  Endif
#Next
Return

########################################################
$SETBOUT
  Gosub COLOREA_LINEAS
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$COLOREA_LINEAS
Local Integer LCON1 : Raz LCON1

  For LCON1 = 0 To [M:SQH2]NBLIG - 1
    Case [M:SQH2]YTIPO(LCON1)
      When 2        : Chgstl [M:SQH2]NBLIG(LCON1) With "BACKORANGE"
      When 3        : Chgstl [M:SQH2]NBLIG(LCON1) With "BACKGREEN"
      When Default  : Chgstl [M:SQH2]NBLIG(LCON1) With ""
   Endcase
  Next
Affzo [M:SQH2]5

Return

