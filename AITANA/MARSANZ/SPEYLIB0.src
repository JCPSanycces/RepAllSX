###################################################################################
#################################   SUBPROGRAMAS  #################################
###################################################################################
#######################
#**
#* devuelve el siguiente número de contador para el código de contador indicado en PCDGCONT
#*
#* @param PCDGCONT  > código del contador
#* @param PSTRDAT   > fecha inicial
#* @param PSEQCODE  > devuelve número de contador
#*!
Subprog GENNUMBER(PCDGCONT,PSTRDAT,PSEQCODE)
Value     Char PCDGCONT
Value     Date PSTRDAT
Variable  Char PSEQCODE
Local Integer STAT
  Call NUMERO(PCDGCONT, nomap, PSTRDAT, "null", PSEQCODE, STAT) From SUBANM
End

#######################
#**
#* convierte divisas
#*
#* @param PDIVISAORI  > divisa origen
#* @param PDIVISADES  > divisa destino
#* @param PCANTIDAD   > cantidad a cambiar
#* @param PTIPO       > tipo de cambio (1=cambio día; 2=cambio mes; 3=cambio medio; 4=cambio DEB)
#* @param PCAMBIO     > valor del cambio
#*!
Subprog CONVERTDIV(PDIVISAORI,PDIVISADES,PCANTIDAD,PTIPO,PCAMBIO)
Value     Char    PDIVISAORI
Value     Char    PDIVISADES
Value     Decimal PCANTIDAD
Value     Integer PTIPO
Variable  Decimal PCAMBIO

  If !clalev([F:TCH0]) Then : Local File TABCHANGE  [F:TCH0] : Endif
  Read [F:TCH0]TCH0 = PTIPO;PDIVISADES;PDIVISAORI;date$
  If !fstat Then
    PCAMBIO = ar2(PCANTIDAD * [F:TCH0]CHGRAT)
  Endif
  If  clalev([F:TCH0]) Then : Close Local File      [F:TCH0] : Endif

End

#######################
#**
#* devuelve el documento origen de una factura de compra
#*
#* @param PCTA     > cuenta (proveedores = 40000 ; clientes = 430000)
#* @param PNUM     > número de factura
#*!
Funprog GET_BPRVCR(PCTA,PNUM)
Value     Char    PCTA
Value     Char    PNUM

Local Char LRES(20)

  If PCTA = "400000" Then
    If !clalev([F:PIH0]) Then : Local File PINVOICE  [F:PIH0] : Endif
    Read [F:PIH0]PIH0 = PNUM
    If !fstat Then
      LRES = [F:PIH0]BPRVCR
    Endif
    Close Local File [PIH0]
  Elsif PCTA = "430000" Then
    If !clalev([F:SIH0]) Then : Local File SINVOICE  [F:SIH0] : Endif
    Read [F:SIH0]SIH0 = PNUM
    If !fstat Then
      LRES = [F:SIH0]BPRVCR
    Endif
    Close Local File [SIH0]
  Endif

End LRES

#**
#* Devuelve el ITMREF, ITMDES  de un artículo pasandole el ITMREFBPC del cliente
#*
#* @param PCOD    --> Codigo de referencia del cliente
#* @param PBCPNUM --> Cliente para buscar por referencia/cliente
#* @param PITMDES --> Nos devuelve también la descripción
#*!
Funprog GET_ITMREF(PCOD, PBPCNUM)
#Variable Char PITMDES()
Value Char PCOD
Value Char PBPCNUM
Local Char LRES

If !clalev([F:YITB]) Then : Local File ITMBPC [F:YITB] : Endif
If !clalev([F:YITM]) Then : Local File ITMMASTER [F:YITM] : Endif

Read [F:YITB]ITU1=PBPCNUM;PCOD
If !fstat Then
  LRES = [F:YITB]ITMREF
  Read [F:YITM]ITM0=LRES
  If !fstat Then
    PITMDES = [F:YITM]ITMDES1
  Else
    PITMDES = [F:YITB]ITMDESBPC
  Endif
Else
  LRES = ''
  PITMDES = ''
Endif
Close Local File [YITM], [YITB]

End LRES


#**
#* Función que nos devuelve si el cliente tiene marcado los
#* albaranes como valorados o no en la impresión
#* Se usa en informe Y-ENTREGA
#* func SPEYLIB0.GET_ALBVAAL([M:SDH0]BPCORD)
#* @param PBPCNUM
#*!
Funprog GET_ALBVAL(PBPCNUM)
Value Char PBPCNUM
Local Char LRES

  If !clalev([F:YBPC]) Then : Local File BPCUSTOMER [YBPC] : Endif
  LRES = '1'
  Read [F:YBPC]BPC0=PBPCNUM
  If !fstat Then
    If [F:YBPC]YALBNOVAL = 1 Then
    LRES = '1'
    Else
      LRES = '2'
    Endif
  Endif
  Close Local File [YBPC]

End LRES

