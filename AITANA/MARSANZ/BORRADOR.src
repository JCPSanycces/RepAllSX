##############################################################
$INICRE_LIG
  [F:YPMD]IDBORRADOR = [M:YPM0]IDBORRADOR
Return

##############################################################
$DEFLIG
  Default Mask [YPM3]   # pantalla de las líneas
  Default File [YPMD]   # abreviatura de la tabla de las líneas

  # criterios de filtrado
  CRIT    = 'IDBORRADOR="'+[M:YPM0]IDBORRADOR+'"'   # campo común de las tablas + pantalla cabecera (con el campo común)
  FICLIG  = "YPTOMUEBLESD"                          # nombre de la tabla de detalle
  ABLIG   = "YPMD"                                  # abreviatura de la tabla de detalle
  ZONLIG  = "NUMLIN"                                # campo contador de línea en la tabla detalle
Return

##############################################################
$STYLE
#  Gosub RELLENA_AUX
#  Gosub CARGA_COLOR_COMP
Return

##############################################################
$SETBOUT
  If GREP = "C" Then
    Grizo [M:YPM0]IDBORRADOR
  Else
    Actzo [M:YPM0]IDBORRADOR
  Endif
  Gosub COLOREA_LINEAS
  Gosub ACTIVA_DUPLICAR

  Raz CHMEN
  If GREP <> "C" and GREP <> "M" Then
    CHMEN += "oc"
    Actzo [M:YPM3]OMCAMPOS
    If [M:YPM0]PLANTA = "104" Then
      Raz CHMEN
      CHMEN += "o"
    Endif
  Else
    Grizo [M:YPM3]OMCAMPOS
  Endif

  If NBLIG = 0 Then : Grizo [M:YPM3]DUPLICAR : Endif
Return

##############################################################
$CLE_GAUCHE
  If GREP = "" Then
    Gosub CARGA_ZONAS
    Gosub CARGA_MUEBLES
  Endif
Return

##############################################################
$FIN_ACTION
  If GREP = "" Then
    Gosub CARGA_ZONAS
    Gosub CARGA_MUEBLES
  Endif
#  Gosub MOSTRAR_COMPONENTES
#  Gosub OCULTAR_COMPONENTES
Return

##############################################################
$FIN
  Gosub CERRAR_TABLAS
  If dim(GCOMPSTA) > 0 Then : Kill GCOMPSTA : Endif
  If dim(GPARAM0)  > 0 Then : Kill GPARAM0  : Endif
  If dim(GPARAM1)  > 0 Then : Kill GPARAM1  : Endif
Return

##############################################################
$SEL_TABLE
  Case TABLE
    When "YSELPTOMD"  : Gosub SEL_YSELPTOMD
    When "YSELPMDIRE" : Gosub SEL_YSELPMDIRE
    When "YSELCOLCOM" : Gosub SEL_YSELCOLCOM
  Endcase
Return

##############################################################
$VERF_TABLE
  Case TABLE
    When "YSELPTOMD"  : Gosub VERF_YSELPTOMD
    When "YSELPMDIRE" : Gosub VERF_YSELPMDIRE
    When "YSELCOLCOM" : Gosub VERF_YSELCOLCOM
  Endcase
Return

##############################################################
$AVANTBOUT
  Case BOUT
    When "o"          : Gosub EXPORTA_PRESVEN
    When "c"          : Gosub EXPORTA_PEDCOMP
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ABRIR_TABLAS
  If !clalev([F:ITM0]) Then : Local File ITMMASTER    [F:ITM0] : Endif
  If !clalev([F:ITM1]) Then : Local File ITMMASTER    [F:ITM1] : Endif
  If !clalev([F:ITM2]) Then : Local File ITMMASTER    [F:ITM2] : Endif
  If !clalev([F:ITM3]) Then : Local File ITMMASTER    [F:ITM3] : Endif
  If !clalev([F:ITM4]) Then : Local File ITMMASTER    [F:ITM4] : Endif
  If !clalev([F:ITM5]) Then : Local File ITMMASTER    [F:ITM5] : Endif
  If !clalev([F:ITM6]) Then : Local File ITMMASTER    [F:ITM6] : Endif
  If !clalev([F:ITM7]) Then : Local File ITMMASTER    [F:ITM7] : Endif
  If !clalev([F:ITM8]) Then : Local File ITMMASTER    [F:ITM8] : Endif
  If !clalev([F:ITM9]) Then : Local File ITMMASTER    [F:ITM9] : Endif
  If !clalev([F:ITS0]) Then : Local File ITMSALES     [F:ITS0] : Endif
  If !clalev([F:ITS1]) Then : Local File ITMSALES     [F:ITS1] : Endif
  If !clalev([F:BPA0]) Then : Local File BPADDRESS    [F:BPA0] : Endif
  If !clalev([F:BOH0]) Then : Local File BOM          [F:BOH0] : Endif
  If !clalev([F:BOD0]) Then : Local File BOMD         [F:BOD0] : Endif
  If !clalev([F:BOD1]) Then : Local File BOMD         [F:BOD1] : Endif
  If !clalev([F:SQH0]) Then : Local File SQUOTE       [F:SQH0] : Endif
  If !clalev([F:SQH1]) Then : Local File SQUOTE       [F:SQH1] : Endif
  If !clalev([F:SQD0]) Then : Local File SQUOTED      [F:SQD0] : Endif
  If !clalev([F:SQD1]) Then : Local File SQUOTED      [F:SQD1] : Endif
  If !clalev([F:PMH0]) Then : Local File YPTOMUEBLESH [F:PMH0] : Endif
  If !clalev([F:PMD0]) Then : Local File YPTOMUEBLESD [F:PMD0] : Endif
  If !clalev([F:PMD1]) Then : Local File YPTOMUEBLESD [F:PMD1] : Endif
  If !clalev([F:YCC0]) Then : Local File YCOLORCOMPO  [F:YCC0] : Endif
  If !clalev([F:YCC1]) Then : Local File YCOLORCOMPO  [F:YCC1] : Endif
  If !clalev([F:AXX0]) Then : Local File ATEXTRA      [F:AXX0] : Endif
Return

##############################################################
$CERRAR_TABLAS
  Close Local File [ITM0],[ITM1],[ITM3],[ITM4],[ITM5],[ITM6],[ITM7],[ITM8],[ITM9]
  Close Local File [ITS0],[ITS1]
  Close Local File [BPA0]
  Close Local File [BOH0]
  Close Local File [BOD0]
  Close Local File [SQH0]
  Close Local File [SQD0]
  Close Local File [PMH0]
  Close Local File [PMD0],[PMD1]
  Close Local File [YCC0],[YCC1]
Return

##############################################################
$CARGA_ZONAS
Local Integer LCON0 : Raz LCON0

  Filter [F:ITM0] Where TCLCOD = "ZONAS"
  For [ITM0]
    [M:YPM1]NUMZONA(LCON0)  = [F:ITM0]ITMREF
    [M:YPM1]DESZONA(LCON0)  = [F:ITM0]ITMDES1
    LCON0 += 1
  Next
  Filter [F:ITM0]
  [M:YPM1]NBZONA = LCON0
  Affzo [M:YPM1]5
Return

##############################################################
$CARGA_MUEBLES
Local Integer LCON1 : Raz LCON1

  Filter [F:ITM1] Where TCLCOD = "SUBZO"
  For [ITM1]
    [M:YPM2]NUMSUBZONA(LCON1)  = [F:ITM1]ITMREF
    [M:YPM2]DESSUBZONA(LCON1)    = [F:ITM1]ITMDES1
    LCON1 += 1
  Next
  Filter [F:ITM1]
  [M:YPM2]NBSUBZONA = LCON1
  Affzo [M:YPM2]5,10
Return

##############################################################
# obtiene el siguiente número de contador
$GET_CONT
Local Integer LSTAT
Local Char    LIDBORRADOR(10)

  Call NUMERO("YIDPM", nomap, date$, "null", LIDBORRADOR, LSTAT) From SUBANM
  [M:YPM0]IDBORRADOR = LIDBORRADOR
  Affzo [M:YPM0]IDBORRADOR
Return

##############################################################
# inserta la información en la última línea
$GO_ULTLINEA
Local Char    LNUMZONA3(50), LNUMSUBZONA3(50)   : Raz LNUMZONA3, LNUMSUBZONA3
Local Char    LDESZONA3(50), LDESSUBZONA3(50)   : Raz LDESZONA3, LDESSUBZONA3
Local Decimal LDTOZONA3, LRECZONA3              : Raz LDTOZONA3, LRECZONA3
Local Integer LCON3                             : Raz LCON3
Local Integer LNOL                              : LNOL = [M:YPM3]NBLIG

  # busca la zona seleccionada
  For LCON3 = 0 To [M:YPM1]NBZONA-1
    If [M:YPM1]SELFLGZ(LCON3) = 2 Then
      LNUMZONA3   = [M:YPM1]NUMZONA(LCON3)
      LDESZONA3   = [M:YPM1]DESZONA(LCON3)
      LDTOZONA3   = [M:YPM1]DTOOCULTO(LCON3)
      LRECZONA3   = [M:YPM1]RECOCULTO(LCON3)
      Break
    Endif
  Next

  # busca la subzona seleccionada
  For LCON3 = 0 To [M:YPM2]NBSUBZONA-1
    If [M:YPM2]SELFLGS(LCON3) = 2 Then
      LNUMSUBZONA3  = [M:YPM2]NUMSUBZONA(LCON3)
      LDESSUBZONA3  = [M:YPM2]DESSUBZONA(LCON3)
      Break
    Endif
  Next

  If LNUMZONA3 <> "" Then
    [M:YPM3]TIPO(LNOL)        = 3
    [M:YPM3]ITMREF(LNOL)      = LNUMZONA3
    [M:YPM3]ITMDES(LNOL)      = LDESZONA3
    [M:YPM3]SAU(LNOL)         = "UN"
    [M:YPM3]UNIDADES(LNOL)    = 1
    [M:YPM3]DTOOCULTO(LNOL)   = LDTOZONA3
    [M:YPM3]RECOCULTO(LNOL)   = LRECZONA3
    If [M:YPM3]NBLIG <> 0 Then
      [M:YPM3]NUMLIN(LNOL)      = [M:YPM3]NUMLIN(LNOL-1) + 1000
    Else
      [M:YPM3]NUMLIN(LNOL)      = 1000
    Endif
    [M:YPM3]UPDFLG(LNOL)      = 1
    [M:YPM3]NBLIG             += 1
    LNOL                      += 1
  Endif

  If LNUMSUBZONA3 <> "" Then
    [M:YPM3]TIPO(LNOL)        = 2
    [M:YPM3]ITMREF(LNOL)      = LNUMSUBZONA3
    [M:YPM3]ITMDES(LNOL)      = LDESSUBZONA3
    [M:YPM3]SAU(LNOL)         = "UN"
    [M:YPM3]UNIDADES(LNOL)    = 1
    [M:YPM3]DTOOCULTO(LNOL)   = LDTOZONA3
    [M:YPM3]RECOCULTO(LNOL)   = LRECZONA3
    [M:YPM3]NUMLIN(LNOL)      = [M:YPM3]NUMLIN(LNOL-1) + 1000
    [M:YPM3]UPDFLG(LNOL)      = 1
    [M:YPM3]NBLIG             += 1
    LNOL                      += 1
  Endif

  Affzo [M:YPM3]10
#  Gosub RELLENA_AUX
Return

##############################################################
# carga la pantalla emergente e inserta la información en la línea indicada
$GO_SELLINEA
Local   Integer LINT0
Global  Char    GPARAM0(15)(0..5)
Local   Integer LCON4                             : Raz LCON4
Local   Char    LNUMZONA4(50), LNUMSUBZONA4(50)   : Raz LNUMZONA4, LNUMSUBZONA4
Local   Char    LDESZONA4(50), LDESSUBZONA4(50)   : Raz LDESZONA4, LDESSUBZONA4
Local   Decimal LDTOOCULTO4, LRECOCULTO4          : Raz LDTOOCULTO4, LRECOCULTO4

  # busca la zona seleccionada
  For LCON4 = 0 To [M:YPM1]NBZONA-1
    If [M:YPM1]SELFLGZ(LCON4) = 2 Then
      LNUMZONA4   = [M:YPM1]NUMZONA(LCON4)
      LDESZONA4   = [M:YPM1]DESZONA(LCON4)
      LDTOOCULTO4 = [M:YPM1]DTOOCULTO(LCON4)
      LRECOCULTO4 = [M:YPM1]RECOCULTO(LCON4)
      Break
    Endif
  Next

  # busca la subzona seleccionado
  For LCON4 = 0 To [M:YPM2]NBSUBZONA-1
    If [M:YPM2]SELFLGS(LCON4) = 2 Then
      LNUMSUBZONA4 = [M:YPM2]NUMSUBZONA(LCON4)
      LDESSUBZONA4 = [M:YPM2]DESSUBZONA(LCON4)
      Break
    Endif
  Next

  GPARAM0(0) = LNUMZONA4                                                    # pase de parámetros entre pantallas - número de zona
  GPARAM0(1) = LDESZONA4                                                    # pase de parámetros entre pantallas - descripción de zona
  GPARAM0(2) = LNUMSUBZONA4                                                 # pase de parámetros entre pantallas - número de subzona
  GPARAM0(3) = LDESSUBZONA4                                                 # pase de parámetros entre pantallas - descripción de subzona
  GPARAM0(4) = num$(LDTOOCULTO4)                                            # pase de parámetros entre pantallas - descuento oculto
  GPARAM0(5) = num$(LRECOCULTO4)                                            # pase de parámetros entre pantallas - recargo oculto
  Call SAISIE_LIB(LINT0,GPARAM0,"OYPE","SPEYPE","OBJZON") From GSAISIE      # llamada a la función que abre la pantalla emergente
Return

##############################################################
$SEL_YSELPTOMD
  Case [M:YPM3]TIPO(nolign-1)
    When 1 : Filter [F:ITM2] Where (TCLCOD <> "SUBZO" and TCLCOD <> "ZONAS")  : Default File [ITM2]
    When 2 : Filter [F:ITM2] Where TCLCOD = "SUBZO"                           : Default File [ITM2]
    When 3 : Filter [F:ITM2] Where TCLCOD = "ZONAS"                           : Default File [ITM2]
    When 4 : Filter [F:ITS0] Where [F:ITS0]ITMTYP = 3                         : Default File [ITS0]
  Endcase
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Artículos"                                                     # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "ITMREF"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la segunda columna
  COL(NBCOL)  = "ITMDES1"                                                       # nombre del campo a mostrar en la segunda columna
Return

##############################################################
$VERF_YSELPTOMD
  # si el artículo es 'Zona', 'Subzona' o 'Artículo'
  If [M:YPM3]TIPO(nolign-1) = 1 or [M:YPM3]TIPO(nolign-1) = 2 or [M:YPM3]TIPO(nolign-1) = 3 Then
    [M:YPM3]ITMREF(nolign-1)    = [F:ITM2]ITMREF
    [M:YPM3]ITMDES(nolign-1)    = [F:ITM2]ITMDES1
    [M:YPM3]SAU(nolign-1)       = [F:ITM2]SAU
  # si el artículo es 'Kit'
  Elsif [M:YPM3]TIPO(nolign-1) = 4 Then
    Read [F:ITM5]ITM0 = [F:ITS0]ITMREF
    If !fstat Then
      [M:YPM3]ITMREF(nolign-1)    = [F:ITM5]ITMREF
      [M:YPM3]ITMDES(nolign-1)    = [F:ITM5]ITMDES1
      [M:YPM3]SAU(nolign-1)       = [F:ITM5]SAU
    Endif
  Endif

  [M:YPM3]DTOOCULTO(nolign-1) = [M:YPM3]DTOOCULTO(nolign-2)
  [M:YPM3]RECOCULTO(nolign-1) = [M:YPM3]RECOCULTO(nolign-2)
  If [M:YPM3]TIPO(nolign-1) <> 1 and [M:YPM3]TIPO(nolign-1) <> 4 Then : [M:YPM3]UNIDADES(nolign-1) = 1 : Endif
  Affzo [M:YPM3]10
Return

##############################################################
$SEL_YSELPMDIRE
  Default File [BPA0]
  Filter [F:BPA0] Where BPANUM = [M:YPM0]CLIENTE
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Direcciones de entrega"                                        # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "BPAADD"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la segunda columna
  COL(NBCOL)  = "BPAADDLIG"                                                     # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Municipio"                                                     # título de la segunda columna
  COL(NBCOL)  = "CTY"                                                           # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Cód. postal"                                                   # título de la segunda columna
  COL(NBCOL)  = "POSCOD"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Provincia"                                                     # título de la segunda columna
  COL(NBCOL)  = "SAT"                                                           # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "País"                                                          # título de la segunda columna
  COL(NBCOL)  = "CRYNAM"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Teléfono"                                                      # título de la segunda columna
  COL(NBCOL)  = "TEL(0)"                                                        # nombre del campo a mostrar en la segunda columna
Return

##############################################################
$VERF_YSELPMDIRE
Return

##############################################################
$SEL_YSELCOLCOM
  Link [BOD1] With [AXX0]AXX0="ITMMASTER";"DES1AXX";GLANGUE;[F:BOD1]CPNITMREF;"" As [LNK0]
  Columns [LNK0] ([BOD1]CPNITMREF,[AXX0]TEXTE)
  Default File [LNK0]
  Filter [LNK0] Where ITMREF = [M:YPM3]ITMREF(nolign-1)
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Artículos color"                                               # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "[BOD1]CPNITMREF"                                               # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la segunda columna
  COL(NBCOL)  = "[AXX0]TEXTE"                                                   # nombre del campo a mostrar en la segunda columna
Return

##############################################################
$VERF_YSELCOLCOM
Return

##############################################################
$COLOREA_LINEAS
Local Integer LCON7 : Raz LCON7

  For LCON7 = 0 To [M:YPM3]NBLIG - 1
    Case [M:YPM3]TIPO(LCON7)
      When 2        : Chgstl [M:YPM3]NBLIG(LCON7) With "BACKORANGE" #: Affzo [M:YPM3]NBLIG(LCON7)
      When 3        : Chgstl [M:YPM3]NBLIG(LCON7) With "BACKGREEN"  #: Affzo [M:YPM3]NBLIG(LCON7)
      When Default  : Chgstl [M:YPM3]NBLIG(LCON7) With ""           #: Affzo [M:YPM3]NBLIG(LCON7)
   Endcase
  Next

  Affzo [M:YPM3]10
Return

##############################################################
# activa el campo 'Duplicar' para aquellos registros que son 'Zona'
$ACTIVA_DUPLICAR
Local Integer LCON11 : Raz LCON11

  For LCON11 = 0 To [M:YPM3]NBLIG-1
    If [M:YPM3]TIPO(LCON11) = 3 or [M:YPM3]TIPO(LCON11) = 2 Then
      Actzo [M:YPM3]DUPLICAR(LCON11)
    Else
      Grizo [M:YPM3]DUPLICAR(LCON11)
    Endif
  Next

#  Affzo [M:YPM3]10
Return

##############################################################
# realiza la exportación silenciosa hacia presupuesto de venta
$EXPORTA_PRESVEN
Local Integer LSTAT : Raz LSTAT

  Call GENERA_FICH("SQH",LSTAT)
Return

##############################################################
# realiza la exportación silenciosa hacia pedido de compra
$EXPORTA_PEDCOMP
Local Integer LSTAT : Raz LSTAT

  Call GENERA_FICH("POH",LSTAT)
Return

##############################################################
# actualiza las unidades de lo que cuelga en una subzona
$ACT_UDSSUBZONA
Local Integer LCON13                            : Raz LCON13
Local Integer LDIFUDS, LKITPREV, LKITPOS, LCOMP : Raz LDIFUDS, LKITPREV, LKITPOS, LCOMP

  LDIFUDS = VALEUR - [M:YPM3]UNIDADES(nolign-1)                                 # guarda la diferencia entre el valor actual y el que se modifica

  For LCON13 = nolign To [M:YPM3]NBLIG-1
    If [M:YPM3]TIPO(LCON13) = 1 or [M:YPM3]TIPO(LCON13) = 4 Then                # si la línea es un artículo=1 o un kit=4
      If [M:YPM3]TIPO(LCON13) = 4 Then
        LKITPREV = [M:YPM3]UNIDADES(LCON13)                                     # si es un kit guarda el valor antes de modificarlo
      Endif
      [M:YPM3]UNIDADES(LCON13) = [M:YPM3]UNIDADES(LCON13) + LDIFUDS             # modifica el valor en ambos casos
      [M:YPM3]UPDFLG(LCON13)   = 1
      If [M:YPM3]TIPO(LCON13) = 4 Then
        LKITPOS = [M:YPM3]UNIDADES(LCON13)                                      # si es un kit guarda el valor después de modificarlo
      Endif
    Elsif [M:YPM3]TIPO(LCON13) = 5 Then                                         # si es un componente...
      LCOMP = [M:YPM3]UNIDADES(LCON13) / LKITPREV                               # ...obtiene la cantidad de ese componente para ese kit
      [M:YPM3]UNIDADES(LCON13) = LCOMP * LKITPOS                                # ...obtiene la cantidad de ese componente con la diferencia modificada
      [M:YPM3]UPDFLG(LCON13)   = 1
    Else
      Break
    Endif
  Next
Return

##############################################################
# actualiza las unidades de lo que cuelga en un kit
$ACT_UDSKIT
Local Integer LCON13                            : Raz LCON13
Local Integer LDIFUDS, LKITPREV, LKITPOS, LCOMP : Raz LDIFUDS, LKITPREV, LKITPOS, LCOMP

  LDIFUDS   = VALEUR - [M:YPM3]UNIDADES(nolign-1)                               # guarda la diferencia entre el valor actual y el que se modifica
  LKITPREV  = [M:YPM3]UNIDADES(nolign-1)                                        # si es un kit guarda el valor antes de modificarlo
  LKITPOS   = VALEUR

  For LCON13 = nolign To [M:YPM3]NBLIG-1
    If [M:YPM3]TIPO(LCON13) = 5 Then
      LCOMP = [M:YPM3]UNIDADES(LCON13) / LKITPREV                               # ...obtiene la cantidad de ese componente para ese kit
      [M:YPM3]UNIDADES(LCON13) = LCOMP * LKITPOS                                # ...obtiene la cantidad de ese componente con la diferencia modificada
      [M:YPM3]UPDFLG(LCON13)   = 1
    Else
      Break
    Endif
  Next
Return

##############################################################
# actualiza el campo 'Dto. Oculto' que cuelga de una misma zona
$ACTUALIZA_DTOOCULTO
Local Integer LCON14        : Raz LCON14
Local Char    LZONA(10)     : Raz LZONA
Local Decimal LDTOZONA      : Raz LDTOZONA
Local Integer LCONTROLZONA  : Raz LCONTROLZONA

  LZONA     = [M:YPM3]ITMREF(nolign-1)
  LDTOZONA  = VALEUR

  For LCON14 = 0 To [M:YPM3]NBLIG-1
    If [M:YPM3]TIPO(LCON14) <> 3 and LCONTROLZONA = 0 Then
      [M:YPM3]DTOOCULTO(LCON14) = LDTOZONA
      [M:YPM3]UPDFLG(LCON14)    = 1
      Affzo [M:YPM3]DTOOCULTO(LCON14)
      Affzo [M:YPM3]UPDFLG(LCON14)
    Else
      If [M:YPM3]ITMREF(LCON14) = LZONA Then
        LCONTROLZONA = 0
        [M:YPM3]DTOOCULTO(LCON14) = LDTOZONA
        [M:YPM3]UPDFLG(LCON14)    = 1
      Affzo [M:YPM3]DTOOCULTO(LCON14)
      Affzo [M:YPM3]UPDFLG(LCON14)
      Else
        LCONTROLZONA = 1
      Endif
    Endif
  Next
  Kill LCON14
Return

##############################################################
# actualiza el campo 'Recargo Oculto' que cuelga de una misma zona
$ACTUALIZA_RECOCULTO
Local Integer LCON14        : Raz LCON14
Local Char    LZONA(10)     : Raz LZONA
Local Decimal LRECZONA      : Raz LRECZONA
Local Integer LCONTROLZONA  : Raz LCONTROLZONA

  LZONA     = [M:YPM3]ITMREF(nolign-1)
  LRECZONA  = VALEUR

  For LCON14 = 0 To [M:YPM3]NBLIG-1
    If [M:YPM3]TIPO(LCON14) <> 3 and LCONTROLZONA = 0 Then
      [M:YPM3]RECOCULTO(LCON14) = LRECZONA
      [M:YPM3]UPDFLG(LCON14)    = 1
      Affzo [M:YPM3]RECOCULTO(LCON14)
      Affzo [M:YPM3]UPDFLG(LCON14)
    Else
      If [M:YPM3]ITMREF(LCON14) = LZONA Then
        LCONTROLZONA = 0
        [M:YPM3]RECOCULTO(LCON14) = LRECZONA
        [M:YPM3]UPDFLG(LCON14)    = 1
      Affzo [M:YPM3]RECOCULTO(LCON14)
      Affzo [M:YPM3]UPDFLG(LCON14)
      Else
        LCONTROLZONA = 1
      Endif
    Endif
  Next
  Kill LCON14
Return

##############################################################
# actualiza el campo 'Color' que cuelga de una misma zona
$ACTUALIZA_COLOR_ZONA
Local Integer LCON14          : Raz LCON14
Local Char    LZONA(10)       : Raz LZONA
Local Char    LCOLORZONA(25)  : Raz LCOLORZONA

  LZONA       = [M:YPM3]ITMREF(nolign-1)
  LCOLORZONA  = VALEUR

  For LCON14 = nolign To [M:YPM3]NBLIG-1
    If [M:YPM3]TIPO(LCON14) <> 3
      If [M:YPM3]TIPO(LCON14) = 1 Then
        Read [F:ITM7]ITM0 = [M:YPM3]ITMREF(LCON14)
        If !fstat Then
          If [F:ITM7]LOTMGTCOD <> 1 Then                                  # sólo afecta a los artículos con gestión de lote
            [M:YPM3]YCOLOR(LCON14) = LCOLORZONA
            [M:YPM3]UPDFLG(LCON14) = 1
            Affzo [M:YPM3]YCOLOR(LCON14)
            Affzo [M:YPM3]UPDFLG(LCON14)
          Endif
        Endif
      Elsif [M:YPM3]TIPO(LCON14) <> 6 and [M:YPM3]TIPO(LCON14) <> 7
        [M:YPM3]YCOLOR(LCON14) = LCOLORZONA
        [M:YPM3]UPDFLG(LCON14) = 1
        Affzo [M:YPM3]YCOLOR(LCON14)
        Affzo [M:YPM3]UPDFLG(LCON14)
      Endif
    Else
      Break
    Endif
  Next
  Kill LCON14
Return

##############################################################
# actualiza el campo 'Color' que cuelga de una misma subzona
$ACTUALIZA_COLOR_SUBZONA
Local Integer LCON14 : Raz LCON14

  For LCON14 = nolign To [M:YPM3]NBLIG-1
    If [M:YPM3]TIPO(LCON14) = 1 or [M:YPM3]TIPO(LCON14) = 4 or [M:YPM3]TIPO(LCON14) = 5 Then      # controla 'Artículo', 'Kit comercial', 'Componente comercial'
      Read [F:ITM7]ITM0 = [M:YPM3]ITMREF(LCON14)
      If !fstat Then
        If [F:ITM7]LOTMGTCOD <> 1 Then                                                            # controla que tenga gestión de lote
          [M:YPM3]YCOLOR(LCON14) = VALEUR
          [M:YPM3]UPDFLG(LCON14) = 1
          Affzo [M:YPM3]YCOLOR(LCON14)
          Affzo [M:YPM3]UPDFLG(LCON14)
        Endif
      Endif
    Else
      If [M:YPM3]TIPO(LCON14) <> 6 and [M:YPM3]TIPO(LCON14) <> 7
        Break
      Endif
    Endif
  Next
  Kill LCON14
Return

###############################################################
$ACTUALIZA_COLOR_KIT
Local Integer LCON14 : Raz LCON14

  For LCON14 = nolign To [M:YPM3]NBLIG-1
    [M:YPM4]YCOLOR(LCON14-1) = VALEUR
    [M:YPM4]UPDFLG(LCON14-1) = 1
    Affzo [M:YPM4]YCOLOR(LCON14-1)
    Affzo [M:YPM4]UPDFLG(LCON14-1)
    If [M:YPM3]TIPO(LCON14) = 5 Then      # controla 'Kit'
      Read [F:ITM7]ITM0 = [M:YPM3]ITMREF(LCON14)
      If !fstat Then
        If [F:ITM7]LOTMGTCOD <> 1 Then                                                            # controla que tenga gestión de lote
          [M:YPM3]YCOLOR(LCON14) = VALEUR
          [M:YPM3]UPDFLG(LCON14) = 1
          Affzo [M:YPM3]YCOLOR(LCON14)
          Affzo [M:YPM3]UPDFLG(LCON14)
        Endif
      Endif
    Else
      Break
    Endif
  Next
  Kill LCON14
Return

