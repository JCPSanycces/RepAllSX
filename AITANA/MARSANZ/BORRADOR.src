## Click icono 'Ocultar/Mostrar campos'
######################################################################################
Subprog CL_OMCAMPOS(VALEUR)
Variable Char    VALEUR()
Infbox num$(GCOMPSTA)
  If GCOMPSTA = 0 Then
#    Gosub RELLENA_AUX
#    Gosub MOSTRAR_COMPONENTES
  Else
#    Gosub OCULTAR_COMPONENTES
  Endif
  Gosub COLOREA_LINEAS
End

