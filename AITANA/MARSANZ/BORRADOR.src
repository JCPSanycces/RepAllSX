##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Controla que sólo se pueda marcar una vez el campo SELFLGZ
######################################################################################
Subprog C_SELFLGZ(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    Local Integer LCON
    For LCON = 0 To [M:YPM1]NBZONA - 1
      [M:YPM1]SELFLGZ(LCON) = 0
      Affzo[M:YPM1]SELFLGZ(LCON)
    Next
    [M:YPM1]SELFLGZ(nolign-1) = 2
    Affzo[M:YPM1]SELFLGZ(nolign-1)
    Kill LCON
  Else
    [M:YPM1]DTOOCULTO(nolign-1) = 0
    [M:YPM1]RECOCULTO(nolign-1) = 0
  Endif
End

######################################################################################
## Controla que sólo se pueda marcar una vez el campo SELFLGS
######################################################################################
Subprog C_SELFLGS(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    Local Integer LCON
    For LCON = 0 To [M:YPM2]NBSUBZONA - 1
      [M:YPM2]SELFLGS(LCON) = 0
      Affzo[M:YPM2]SELFLGS(LCON)
    Next
    [M:YPM2]SELFLGS(nolign-1) = 2
    Affzo[M:YPM2]SELFLGS(nolign-1)
    Kill LCON
  Endif
End

######################################################################################
## Controla que esté marcado sólo un check entre 'Última línea' y 'Elegir línea'
######################################################################################
Subprog C_ULTLINEA(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    [M:YPM2]SELLINEA = 1
  Else
    [M:YPM2]SELLINEA = 2
  Endif
  Affzo [M:YPM2]SELLINEA
End

######################################################################################
## Controla que esté marcado sólo un check entre 'Última línea' y 'Elegir línea'
######################################################################################
Subprog C_SELLINEA(VALEUR)
Variable Integer VALEUR

  If VALEUR = 2 Then
    [M:YPM2]ULTLINEA = 1
  Else
    [M:YPM2]ULTLINEA = 2
  Endif
  Affzo [M:YPM2]ULTLINEA
End

######################################################################################
## Control en el campo 'Cantidad'
######################################################################################
Subprog C_UNIDADES(VALEUR)
Variable Decimal VALEUR

  # no permite introducir cantidades negativas
  If VALEUR < 0 Then
    Call ERREUR("No se permiten cantidades negativas") From GESECRAN
    mkstat = 2
  Endif

  # si es 'Subzona', actualiza la cantidad en todo lo que cuelga de ella
  If [M:YPM3]TIPO(nolign-1) = 2 Then
    Gosub ACT_UDSSUBZONA
  Elsif [M:YPM3]TIPO(nolign-1) = 4 Then
    Gosub ACT_UDSKIT
  Endif

  Affzo [M:YPM3]10
End

######################################################################################
## Después de modificar el campo 'Cantidad'
######################################################################################
Subprog AM_UNIDADES(VALEUR)
Variable Decimal VALEUR

  [M:YPM3]UNIDADES(nolign-1) = VALEUR
  Affzo [M:YPM3]UNIDADES(nolign-1)
  zonsui = "[M:YPM3]UNIDADES(nolign-1)"
End

######################################################################################
## Antes de entrada en campo 'Unidades'
######################################################################################
Subprog AS_UNIDADES(VALEUR)
Variable Decimal VALEUR

  # deshabilita el campo cantidad en los artículos de tipo 'Zona' y 'Componente'
  If [M:YPM3]TIPO(nolign-1) = 3 or [M:YPM3]TIPO(nolign-1) = 5 Then
    Diszo [M:YPM3]UNIDADES(nolign-1)
  Else
    Actzo [M:YPM3]UNIDADES(nolign-1)
  Endif
End

######################################################################################
## Click en el icono 'OK'
######################################################################################
Subprog CL_OKLIN(VALEUR)
Variable Char    VALEUR()

  Case [M:YPM2]ULTLINEA
    When 1  : Gosub GO_SELLINEA               # elegir línea
    When 2  : Gosub GO_ULTLINEA               # última línea
  Endcase

  Gosub COLOREA_LINEAS
End

######################################################################################
## Después de marcar el check de Duplicar
######################################################################################
Subprog AM_DUPLICAR(VALEUR)
Variable Integer VALEUR

Local   Integer LINT1       : Raz LINT1
Global  Char GPARAM1(1)(1)

  If VALEUR = 2 Then
    Call SAISIE_LIB(LINT1,GPARAM1,"OYRDP","SPEYRDP","OBJZON") From GSAISIE           # llamada a la función que abre la pantalla emergente
  Endif
End

######################################################################################
## Después de modificar el campo 'Dto. oculto'
######################################################################################
Subprog AM_DTOOCULTO(VALEUR)
Variable Decimal VALEUR

  If [M:YPM3]TIPO(nolign-1) = 3 Then
    Gosub ACTUALIZA_DTOOCULTO
  Endif
End

######################################################################################
## Antes de entrada 'Dto. Oculto'
######################################################################################
Subprog AS_DTOOCULTO(VALEUR)
Variable Decimal VALEUR

  # deshabilita el campo dto. oculto en los artículos de tipo 'Artículo, 'Subzona', 'Kit' y 'Componente'
  If [M:YPM3]TIPO(nolign-1) = 1 or [M:YPM3]TIPO(nolign-1) = 2 or [M:YPM3]TIPO(nolign-1) = 4 or [M:YPM3]TIPO(nolign-1) = 5 Then
    Diszo [M:YPM3]DTOOCULTO(nolign-1)
  Else
    Actzo [M:YPM3]DTOOCULTO(nolign-1)
  Endif
End

######################################################################################
## Después de modificar el campo 'Recargo oculto'
######################################################################################
Subprog AM_RECOCULTO(VALEUR)
Variable Decimal VALEUR

  If [M:YPM3]TIPO(nolign-1) = 3 Then
    Gosub ACTUALIZA_RECOCULTO
  Endif
End

######################################################################################
## Antes de entrada 'Recargo Oculto'
######################################################################################
Subprog AS_RECOCULTO(VALEUR)
Variable Decimal VALEUR

  # deshabilita el campo rec. oculto en los artículos de tipo 'Artículo, 'Subzona', 'Kit' y 'Componente'
  If [M:YPM3]TIPO(nolign-1) = 1 or [M:YPM3]TIPO(nolign-1) = 2 or [M:YPM3]TIPO(nolign-1) = 4 or [M:YPM3]TIPO(nolign-1) = 5 Then
    Diszo [M:YPM3]RECOCULTO(nolign-1)
  Else
    Actzo [M:YPM3]RECOCULTO(nolign-1)
  Endif
End

######################################################################################
## Después de modificar el campo 'Color'
######################################################################################
Subprog AM_YCOLOR(VALEUR)
Variable Char    VALEUR()

  [M:YPM3]YCOLOR(nolign-1) = VALEUR
  Affzo [M:YPM3]YCOLOR(nolign-1)
  If [M:YPM3]TIPO(nolign-1) = 3 Then
    Gosub ACTUALIZA_COLOR_ZONA
  Elsif [M:YPM3]TIPO(nolign-1) = 2 Then
    Gosub ACTUALIZA_COLOR_SUBZONA
  Elsif [M:YPM3]TIPO(nolign-1) = 4 Then
    Gosub ACTUALIZA_COLOR_KIT
  Endif
#  Gosub RELLENA_AUX
  zonsui = "[M:YPM3]YCOLOR(nolign-1)"
End

######################################################################################
## Antes de campo 'Color'
######################################################################################
Subprog AV_YCOLOR(VALEUR)
Variable Char    VALEUR()

  # 'Artículo', 'Kit comercial', 'Componente comercial' o 'Kit fabricación'
  If [M:YPM3]TIPO(nolign-1) = 1 or [M:YPM3]TIPO(nolign-1) = 4 or [M:YPM3]TIPO(nolign-1) = 5 Then
    Read [F:ITM3]ITM0 = [M:YPM3]ITMREF(nolign-1)
    If !fstat Then
      If [F:ITM3]LOTMGTCOD = 1 Then                                                               # Habilita o no en función de si el artículo tiene gestión de lote
        Grizo [M:YPM3]YCOLOR(nolign-1)
      Else
        Actzo [M:YPM3]YCOLOR(nolign-1)
      Endif
    Endif
  Elsif [M:YPM3]TIPO(nolign-1) = 3 or [M:YPM3]TIPO(nolign-1) = 2 Then                             # Habilita si es 'Zona' o 'Subzona'
    Actzo [M:YPM3]YCOLOR(nolign-1)
  Else
    Grizo [M:YPM3]YCOLOR(nolign-1)
  Endif
End

######################################################################################
## Después de modificar el campo 'Color comp.'
######################################################################################
Subprog AM_YCOLORCOMP(VALEUR)
Variable Char    VALEUR()

  [M:YPM3]YCOLORCOMP(nolign-1) = VALEUR
  Affzo [M:YPM3]YCOLORCOMP(nolign-1)
  [M:YPM4]YCOLORCOMP([M:YPM3]IDREG(nolign-1) - 1) = VALEUR
  Affzo [M:YPM4]YCOLORCOMP([M:YPM3]IDREG(nolign-1) - 1)

  zonsui = "[M:YPM3]UNIDADES(nolign-1)"
End

######################################################################################
## Antes de campo 'Color comp.'
######################################################################################
Subprog AV_YCOLORCOMP(VALEUR)
Variable Char    VALEUR()

  If [M:YPM3]TIPO(nolign-1) <> 7
    mkstat = 2
  Endif
End

######################################################################################
## Control en el campo 'Artículo'
######################################################################################
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
  Read [F:ITM1]ITM0 = VALEUR
  If fstat Then
    Call ERREUR("Artículo inexistente") From GESECRAN
    mkstat = 2
  Endif
End

######################################################################################
## Después de modificar el campo 'Artículo'
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

  # busca la tipología del artículo
  [M:YPM3]ITMREF(nolign-1) = VALEUR
  Affzo [M:YPM3]ITMREF(nolign-1)
  Read [F:ITS1]ITS0 = VALEUR
  If !fstat Then
    Case [F:ITS1]ITMTYP
      When 1
        Filter [F:BOH0] Where ITMREF = VALEUR and USESTA = 2
        Read [F:BOH0] First
        If !fstat Then
          [M:YPM3]TIPO(nolign-1) = 6
          Filter [F:BOH0]
        Else
          Read [F:ITM8]ITM0 = VALEUR
          If !fstat Then
            If    [F:ITM8]TCLCOD = "ZONAS"  Then : [M:YPM3]TIPO(nolign-1) = 3
            Elsif [F:ITM8]TCLCOD = "SUBZO"  Then : [M:YPM3]TIPO(nolign-1) = 2
            Else                                 : [M:YPM3]TIPO(nolign-1) = 1
            Endif
          Endif
        Endif
      When 2,3
        Filter [F:BOH0] Where ITMREF = VALEUR and USESTA = 2
        Read [F:BOH0] First
        If !fstat Then
          Case [F:BOH0]BOMALTTYP
            When 1 : [M:YPM3]TIPO(nolign-1) = 4           # Kit comercial
            When 2 : [M:YPM3]TIPO(nolign-1) = 6           # Kit fabricación
          Endcase
        Endif
        Filter [F:BOH0]
    Endcase
    Affzo [M:YPM3]TIPO(nolign-1)
  Endif

End

######################################################################################
## Después de campo 'Artículo'
######################################################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()

  # Marca el fondo de las líneas en función del tipo de línea
  Case [M:YPM3]TIPO(nolign-1)
    When 3        : Chgstl NBLIG(nolign-1) With "BACKGREEN"      # zona = Fondo verde
    When 2        : Chgstl NBLIG(nolign-1) With "BACKORANGE"     # subzona = Fondo naranja
    When Default  : Chgstl NBLIG(nolign-1) With ""
  Endcase
  Read [F:ITM6]ITM0 = VALEUR
  If !fstat Then
    [M:YPM3]ITMDES(nolign-1)    = [F:ITM6]ITMDES1
    [M:YPM3]SAU(nolign-1)       = [F:ITM6]SAU
  Endif
  If [M:YPM3]TIPO(nolign-1) <> 1 and [M:YPM3]TIPO(nolign-1) <> 4 Then : [M:YPM3]UNIDADES(nolign-1) = 1 : Endif
End

######################################################################################
## Antes de entrada 'Descripción artículo'
######################################################################################
Subprog AS_ITMDES(VALEUR)
Variable Char    VALEUR()
# Solamente permito entrar si autorizo modificación descripción en el artículo
Read [F:ITM9]ITM0 = [M:YPM3]ITMREF(nolign-1)
If fstat = 0 and [F:ITM9]YDESMOD <> 2
  mkstat = 2
Endif
End

