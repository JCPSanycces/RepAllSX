######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
Global Integer GCOMPSTA : Raz GCOMPSTA    # 1 = componentes visibles ; 0 = componentes ocultos

  Gosub DECLARE From TABLEAUX
  Gosub ABRIR_TABLAS
Return

##############################################################
$FILTRE
  Default File [YPMH]
Return

##############################################################
$LIENS
  Gosub LIENS From TABLEAUX

  Gosub COLOREA_LINEAS
  Gosub ACTIVA_DUPLICAR

  If GREP = "M" or GREP = "" Then
    Gosub CARGA_ZONAS
    Gosub CARGA_MUEBLES
  Endif
