######################################################################################
## Antes de entrada al campo 'Fecha'
######################################################################################
Subprog AS_FECHA(VALEUR)
Variable Date    VALEUR

  If GREP = "C" and VALEUR = [00/00/0000] Then
    VALEUR = date$
  Endif
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
##############################################################
######################
#**
#* genera el fichero y realiza la importación de presupuesto venta o pedido compra según parámetro
#*
#* @param PTYPE    > tipo de importación: PRESUPUESTO VTA. = 'SQH' ; PEDIDO COMPRA = 'POH'
#* @param PERROR1  > devuelve el estado de la importación  PERROR1=1 -> éxito ; PERROR1<>1 -> error
#*!
Subprog GENERA_FICH(PTYPE, PERROR1)
Value     Char    PTYPE
Variable  Integer PERROR1

Local Char    LDIRIMPORT1(250)                      : LDIRIMPORT1 = filpath("IMPORT_EXPORT","","")
Local Char    LFILE_W1(200)                         : LFILE_W1 = "\" + PTYPE
Local Char    LDATCAB1(100)(8), LDATLINL1(100)(15)
Local Char    LFECHA1(10), LHORA1(10)               : Raz LFECHA1, LHORA1
Local Char    LSEP1(1)                              : LSEP1 = ";"  # separador

  LFECHA1 = vireblc(num$(date$),4) : LFECHA1 = mid$(LFECHA1,1,2)+mid$(LFECHA1,4,2)+mid$(LFECHA1,7,4)
  LHORA1  = vireblc(num$(time$),4) : LHORA1  = mid$(LHORA1,1,2)+mid$(LHORA1,4,2)+mid$(LHORA1,7,2)

  LDIRIMPORT1 += "\" + PTYPE
  LFILE_W1 = LDIRIMPORT1 + LFILE_W1 + "_" + LFECHA1 + LHORA1 + ".txt"

  # borramos el fichero si existe...
  If filinfo(LFILE_W1, 7) > 0 Then
    System "ae_rm " + LFILE_W1
  Endif

  Sleep 1

  # abrir el fichero para escritura
  Gosub OPEN_FILE_W1

  # datos de cabecera
  Raz LDATCAB1
  Filter [F:PMH0] Where IDBORRADOR = [M:YPM0]IDBORRADOR
  Read [F:PMH0] First
  If !fstat Then
    LDATCAB1(0)  = "E"                                                                      # Inidicador
    LDATCAB1(1)  = [F:PMH0]PLANTA                                                           # Planta
    LDATCAB1(2)  = ""                                                                       # Número de pedido/presupuesto
    If PTYPE = "SQH" Then : LDATCAB1(3) = [F:PMH0]CLIENTE Else LDATCAB1(3) = "104" : Endif  # Cliente / Proveedor
    LDATCAB1(4)  = date$                                                                    # Fecha
    If PTYPE = "SQH" Then LDATCAB1(5)  = "SQN" Else LDATCAB1(5) = "" : Endif                # Tipo de documento (sólo se informa cuando es presupuesto venta)
    If PTYPE = "POH" Then LDATCAB1(5)  = "104"                       : Endif                # Tercero factura (sólo se informa cuando es pedido compra)
    LDATCAB1(6)  = [F:PMH0]IDBORRADOR                                                       # Nş de borrador
    LDATCAB1(7)  = [F:PMH0]DIRENTREGA                                                       # Dirección de entrega
  Endif
  Filter [F:PMH0]

  Wrseq LDATCAB1(0) + LSEP1 + LDATCAB1(1) + LSEP1 + LDATCAB1(2) + LSEP1 + LDATCAB1(3) + LSEP1 + LDATCAB1(4) + LSEP1 + LDATCAB1(5) + LSEP1 + LDATCAB1(6) + LSEP1 +
&       LDATCAB1(7) Using [ZIMP_W1]

  # datos de líneas
#  Filter [F:PMD1] Where IDBORRADOR = [M:YPM0]IDBORRADOR
  Filter [F:YCC1] Where IDBORRADOR = [M:YPM0]IDBORRADOR
  For [F:YCC1]
#    If PTYPE <> "SQH" or [F:PMD1]TIPO <> 5 Then
    If [F:YCC1]TIPO <> 7 Then
      Raz LDATLINL1
      LDATLINL1(0) = "L"                                                                    # Indicador
      LDATLINL1(1) = [F:YCC1]ITMREF                                                         # Código de artículo
      LDATLINL1(2) = [F:YCC1]ITMDES                                                         # Descripción de artículo
      LDATLINL1(3) = [F:YCC1]ITMDES                                                         # Descripción de artículo
      LDATLINL1(4) = [F:YCC1]SAU                                                            # Unidad
      LDATLINL1(5) = num$([F:YCC1]UNIDADES)                                                 # Cantidad
      LDATLINL1(6) = num$([F:YCC1]DTOOCULTO)                                                # Descuento oculto
      LDATLINL1(7) = num$([F:YCC1]RECOCULTO)                                                # Recargo oculto
      LDATLINL1(8) = [F:YCC1]YCOLOR                                                         # Color
      LDATLINL1(9) = num$([F:YCC1]TIPO)                                                     # Tipo
      LDATLINL1(10) = "NOR"                                                                 # Nivel de impuesto 1
      LDATLINL1(11) = num$([F:YCC1]NUMLIN)                                                  # Nş línea borrador
      LDATLINL1(12) = [F:YCC1]YIDKIT                                                        # Id. kit fabricación
      LDATLINL1(13) = num$([F:YCC1]IDREG)                                                   # Nş registro borrador
      LDATLINL1(14) = "1"                                                                   # Tipo de línea

      # datos de línea
      Wrseq LDATLINL1(0) + LSEP1 + LDATLINL1(1) + LSEP1 + LDATLINL1(2) + LSEP1 + LDATLINL1(3) + LSEP1 + LDATLINL1(4) + LSEP1 + LDATLINL1(5) + LSEP1 +
&     LDATLINL1(6) + LSEP1 + LDATLINL1(7) + LSEP1 + LDATLINL1(8) + LSEP1 + LDATLINL1(9) + LSEP1 + LDATLINL1(10) + LSEP1 + LDATLINL1(11) + LSEP1 +
&     LDATLINL1(12) + LSEP1 + LDATLINL1(13) + LSEP1 + LDATLINL1(14) Using [ZIMP_W1]
    Endif
  Next
#  Filter [F:PMD1]
  Filter [F:YCC1]

  Gosub CLOSE_FILE_W1

  If !GSERVEUR Then
    Call OUVRE_TRACE("Presupuesto desde borrador") From LECFIC
  Endif
  If PTYPE = "SQH" Then
    Call IMPORTSIL("YPMSQH",LFILE_W1) From GIMPOBJ                      # lanza la imporación de presupuesto de venta
    If (fstat <> 0 and fstat <> 4) or GERRTRACE <> 0 Then               # si se produce error de importación...
      Call ERREUR("Error en la creación del presupuesto") From GESECRAN
    Endif
  Else
    Call IMPORTSIL("YPMPOH",LFILE_W1) From GIMPOBJ                      # lanza la imporación de pedido de compra
  Endif
  If GSERVEUR Then
    Call FERME_TRACE From LECFIC
  Endif
  mkstat = 0 : fstat = 0 : GOK = 1 : GERRTRACE = 0

  PERROR1 = GOK
End

########################################################
$OPEN_FILE_W1

  adxifs = ";"
  adxirs = chr$(13)+chr$(10)
  Openo LFILE_W1 Using [ZIMP_W1]
Return

########################################################
$CLOSE_FILE_W1

  Openo Using [ZIMP_W1]
Return

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla YPTOMUEBLESD) 02/09/2020 18:02:10 (AIT07)
######################################################################################
Subprog AS_TIPO(VALEUR)
Variable Integer VALEUR
End

