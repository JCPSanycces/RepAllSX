##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$DEBUT
Infbox "hola44"
  Raz [M:YPM4]
  [M:YPM4]ZONA        = GPARAM0(0)
  [M:YPM4]DESZONA     = GPARAM0(1)
  [M:YPM4]SUBZONA     = GPARAM0(2)
  [M:YPM4]DESSUBZONA  = GPARAM0(3)
  [M:YPM4]DTOOCULTO   = val(GPARAM0(4))
  [M:YPM4]RECOCULTO   = val(GPARAM0(5))
  Affzo [M:YPM4]ZONA, SUBZONA, DESZONA, DESSUBZONA, DTOOCULTO, RECOCULTO

  Gosub ABRIR_TABLAS

Return

##############################################################
$OK
  Gosub INSERTA_LINEAS
  Gosub COLOREA_LINEAS From SPEYPM
  Gosub ACTIVA_DUPLICAR From SPEYPM
  Affzo [M:YPM3]5
Return

##############################################################
$FIN
  Gosub CERRAR_TABLAS
Return

##############################################################
$SEL_TABLE
  Case TABLE
    When "YSELPTOMT"  : Gosub SEL_YSELPTOMT
  Endcase
Return

##############################################################
$VERF_TABLE
  Case TABLE
    When "YSELPTOMT"  : Gosub VERF_YSELPTOMT
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ABRIR_TABLAS
  If !clalev([F:YTM0]) Then : Local File YTMPMUEBLES [F:YTM0] : Endif
  If !clalev([F:ITM3]) Then : Local File ITMMASTER   [F:ITM3] : Endif
  If !clalev([F:ITM4]) Then : Local File ITMMASTER   [F:ITM4] : Endif
  If !clalev([F:ITM7]) Then : Local File ITMMASTER   [F:ITM7] : Endif
  If !clalev([F:ITM8]) Then : Local File ITMMASTER   [F:ITM8] : Endif
  If !clalev([F:ITM9]) Then : Local File ITMMASTER   [F:ITM9] : Endif
  If !clalev([F:ITS1]) Then : Local File ITMSALES    [F:ITS1] : Endif
  If !clalev([F:BOD1]) Then : Local File BOMD        [F:BOD1] : Endif
  If !clalev([F:SPL1]) Then : Local File SPRICLIST   [F:SPL1] : Endif
Return

##############################################################
$CERRAR_TABLAS
  If clalev([F:YTM0])  Then : Close Local File       [F:YTM0] : Endif
  If clalev([F:ITM7])  Then : Close Local File       [F:ITM7] : Endif
  If clalev([F:ITM8])  Then : Close Local File       [F:ITM8] : Endif
  If clalev([F:ITM9])  Then : Close Local File       [F:ITM9] : Endif
  If clalev([F:BOD1])  Then : Close Local File       [F:BOD1] : Endif
  If clalev([F:SPL1])  Then : Close Local File       [F:SPL1] : Endif
Return

##############################################################
$INSERTA_LINEAS
Local Integer LCON5, LCON6, LCON11, POSICION, NUMREGS : Raz LCON5, LCON6, LCON11, POSICION, NUMREGS
Local Integer LCONTROL : Raz LCONTROL
Local Integer LS, LA : Raz LS, LA
Local Integer LNUMLINEA : Raz LNUMLINEA

  POSICION  = [M:YPM4]LINEA - 1

  # esta variable se utiliza para ańadir número de línea en el detalle del borrador
  LNUMLINEA = [M:YPM4]LINEA

  # desplaza todos los registros desde la posición indicada hacia abajo
  For LCON5 = [M:YPM3]NBLIG-1 To POSICION Step -1
    LS = LCON5 + [M:YPM4]NBEMERGE + 2
    LA = LCON5
    [M:YPM3]TIPO(LS)      = [M:YPM3]TIPO(LA)
    [M:YPM3]ITMREF(LS)    = [M:YPM3]ITMREF(LA)
    [M:YPM3]ITMDES(LS)    = [M:YPM3]ITMDES(LA)
    [M:YPM3]SAU(LS)       = [M:YPM3]SAU(LA)
    [M:YPM3]UNIDADES(LS)  = [M:YPM3]UNIDADES(LA)
    [M:YPM3]DTO1(LS)      = [M:YPM3]DTO1(LA)
    [M:YPM3]DTO2(LS)      = [M:YPM3]DTO2(LA)
    [M:YPM3]DTOOCULTO(LS) = [M:YPM3]DTOOCULTO(LA)
    [M:YPM3]RECOCULTO(LS) = [M:YPM3]RECOCULTO(LA)
    [M:YPM3]YCOLOR(LS)    = [M:YPM3]YCOLOR(LA)
    [M:YPM3]NUMLIN(LS)    = ([M:YPM3]NUMLIN(LA) + (([M:YPM4]NBEMERGE + 2) * 1000))
    [M:YPM3]UPDFLG(LS)    = 1
    NUMREGS += 1
  Next

  [M:YPM3]NBLIG = [M:YPM3]NBLIG + [M:YPM4]NBEMERGE + 2

  # vacía tantas líneas como haya que ańadir a partir de la posición indicada
  For LCON5 = POSICION To (POSICION + ([M:YPM4]NBEMERGE + 2)) - 1
    [M:YPM3]TIPO(LCON5)      = 0
    [M:YPM3]ITMREF(LCON5)    = ""
    [M:YPM3]ITMDES(LCON5)    = ""
    [M:YPM3]SAU(LCON5)       = ""
    [M:YPM3]UNIDADES(LCON5)  = 0
    [M:YPM3]DTO1(LCON5)      = 0
    [M:YPM3]DTO2(LCON5)      = 0
    [M:YPM3]DTOOCULTO(LCON5) = 0
    [M:YPM3]RECOCULTO(LCON5) = 0
    [M:YPM3]YCOLOR(LCON5)     = ""
    [M:YPM3]UPDFLG(LCON5)    = 1
  Next

  # rellena los dos primeros huecos vacíos con la zona y la subzona
  For LCON6 = 0 To [M:YPM3]NBLIG - 1
    If [M:YPM3]TIPO(LCON6)      = 0 and LCONTROL = 0 Then
      [M:YPM3]TIPO(LCON6)       = 3
      [M:YPM3]ITMREF(LCON6)     = [M:YPM4]ZONA
      [M:YPM3]ITMDES(LCON6)     = [M:YPM4]DESZONA
      [M:YPM3]SAU(LCON6)        = "UN"
      [M:YPM3]UNIDADES(LCON6)   = 1
      [M:YPM3]DTOOCULTO(LCON6)  = [M:YPM4]DTOOCULTO
      [M:YPM3]RECOCULTO(LCON6)  = [M:YPM4]RECOCULTO
      [M:YPM3]NUMLIN(LCON6)     = LNUMLINEA * 1000
      [M:YPM3]UPDFLG(LCON6)     = 1
      LNUMLINEA += 1
      LCONTROL += 1
    Elsif [M:YPM3]TIPO(LCON6)   = 0 and LCONTROL = 1
      [M:YPM3]TIPO(LCON6)       = 2
      [M:YPM3]ITMREF(LCON6)     = [M:YPM4]SUBZONA
      [M:YPM3]ITMDES(LCON6)     = [M:YPM4]DESSUBZONA
      [M:YPM3]SAU(LCON6)        = "UN"
      [M:YPM3]UNIDADES(LCON6)   = 1
      [M:YPM3]DTOOCULTO(LCON6)  = [M:YPM4]DTOOCULTO
      [M:YPM3]RECOCULTO(LCON6)  = [M:YPM4]RECOCULTO
      [M:YPM3]NUMLIN(LCON6)    = LNUMLINEA * 1000
      [M:YPM3]UPDFLG(LCON6)    = 1
      LNUMLINEA += 1
      LCONTROL += 1
    Elsif LCONTROL = 2
      Break
    Endif
  Next

  # rellena los huecos vacíos con los artículos de la pantalla emergente
  For LCON5 = 0 To [M:YPM4]NBEMERGE-1
    For LCON6 = 0 To [M:YPM3]NBLIG - 1
      If [M:YPM3]TIPO(LCON6) = 0 Then
        [M:YPM3]TIPO(LCON6)      = [M:YPM4]TIPO(LCON5)
        [M:YPM3]ITMREF(LCON6)    = [M:YPM4]ITMREF(LCON5)
        [M:YPM3]ITMDES(LCON6)    = [M:YPM4]ITMDES(LCON5)
        [M:YPM3]SAU(LCON6)       = [M:YPM4]SAU(LCON5)
        [M:YPM3]UNIDADES(LCON6)  = [M:YPM4]UNIDADES(LCON5)
        [M:YPM3]DTO1(LCON6)      = [M:YPM4]DTO1(LCON5)
        [M:YPM3]DTO2(LCON6)      = [M:YPM4]DTO2(LCON5)
        [M:YPM3]DTOOCULTO(LCON6) = [M:YPM4]DTOOCULTOL(LCON5)
        [M:YPM3]RECOCULTO(LCON6) = [M:YPM4]RECOCULTOL(LCON5)
        [M:YPM3]NUMLIN(LCON6)    = LNUMLINEA * 1000
        [M:YPM3]UPDFLG(LCON6)    = 1
        LNUMLINEA += 1
#        [M:YPM3]NUMLIN(LCON6)    = ([M:YPM3]NUMLIN(LCON6) + ([M:YPM4]NBEMERGE * 1000))
        Break
      Endif
    Next LCON6
  Next LCON5

  For LCON11 = 0 To [M:YPM3]NBLIG-1
    [M:YPM3]DUPLICAR(LCON11) = 1
  Next

Affzo [M:YPM3]5

Return

##############################################################
$SEL_YSELPTOMT
  Case [M:YPM4]TIPO(nolign-1)
    When 1 : Filter [F:ITM3] Where (TCLCOD <> "SUBZO" and TCLCOD <> "ZONAS")  : Default File [ITM3]
    When 2 : Filter [F:ITM3] Where TCLCOD = "SUBZO"                           : Default File [ITM3]
    When 3 : Filter [F:ITM3] Where TCLCOD = "ZONAS"                           : Default File [ITM3]
    When 4 : Filter [F:ITS1] Where [F:ITS1]ITMTYP = 3                         : Default File [ITS1]
  Endcase
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Artículos"                                                     # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "ITMREF"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la segunda columna
  COL(NBCOL)  = "ITMDES1"                                                       # nombre del campo a mostrar en la segunda columna
Return

##############################################################
$VERF_YSELPTOMT
  # si el artículo es 'Zona', 'Subzona' o 'Artículo'
  If [M:YPM4]TIPO(nolign-1) = 1 or [M:YPM4]TIPO(nolign-1) = 2 or [M:YPM4]TIPO(nolign-1) = 3 Then
    [M:YPM4]ITMDES(nolign-1)    = [F:ITM3]ITMDES1
    [M:YPM4]SAU(nolign-1)       = [F:ITM3]SAU
  # si el artículo es 'Kit'
  Elsif [M:YPM4]TIPO(nolign-1) = 4 Then
    Read [F:ITM7]ITM0 = [F:ITS1]ITMREF
    If !fstat Then
      [M:YPM4]ITMDES(nolign-1)    = [F:ITM7]ITMDES1
      [M:YPM4]SAU(nolign-1)       = [F:ITM7]SAU
    Endif
  Endif
  [M:YPM4]DTOOCULTOL(nolign-1) = [M:YPM4]DTOOCULTO
  [M:YPM4]RECOCULTOL(nolign-1) = [M:YPM4]RECOCULTO
  If [M:YPM4]TIPO(nolign-1) <> 1 and [M:YPM4]TIPO(nolign-1) <> 4 Then : [M:YPM4]UNIDADES(nolign-1) = 1 : Endif
  Affzo [M:YPM4]10
Return

##############################################################
# inserta los componentes de un kit en el caso de que se
# seleccione un artículo de este tipo
$INSERTA_KIT_E
Local Integer LCON13  : LCON13 = nolign

  [M:YPM4]UNIDADES(nolign-1) = 1
  Filter [F:BOD0] Where ITMREF = VALEUR Order By BOMSEQ Asc
  For [BOD0]
    [M:YPM4]TIPO(LCON13)      = 5
    [M:YPM4]ITMREF(LCON13)    = [F:BOD0]CPNITMREF
    Read   [F:ITM4]ITM0 = [F:BOD0]CPNITMREF
    If !fstat Then
      [M:YPM4]ITMDES(LCON13)  = [F:ITM4]ITMDES1
    Endif
    [M:YPM4]SAU(LCON13)         = [F:BOD0]BOMUOM
    [M:YPM4]UNIDADES(LCON13)    = [F:BOD0]LIKQTY #* VALEUR
    [M:YPM4]DTOOCULTOL(LCON13)  = [M:YPM4]DTOOCULTO(nolign-1)
    [M:YPM4]RECOCULTOL(LCON13)  = [M:YPM4]RECOCULTO(nolign-1)
    Filter [F:SPL1]
    LCON13 += 1
  Next
  Filter [F:BOD0]
  [M:YPM4]NBEMERGE = LCON13

Return

##############################################################
# actualiza las unidades de lo que cuelga en una subzona
$ACT_UDSSUBZONA
Local Integer LCON13  : Raz LCON13
Local Integer LDIFUDS, LKITPREV, LKITPOS, LCOMP : Raz LDIFUDS, LKITPREV, LKITPOS, LCOMP

  LDIFUDS = VALEUR - [M:YPM4]UNIDADES(nolign-1)                                 # guarda la diferencia entre el valor actual y el que se modifica

  For LCON13 = nolign To [M:YPM4]NBMERGE-1
    If [M:YPM4]TIPO(LCON13) = 1 or [M:YPM4]TIPO(LCON13) = 4 Then                # si la línea es un artículo=1 o un kit=4
      If [M:YPM4]TIPO(LCON13) = 4 Then
        LKITPREV = [M:YPM4]UNIDADES(LCON13)                                     # si es un kit guarda el valor antes de modificarlo
      Endif
      [M:YPM4]UNIDADES(LCON13) = [M:YPM4]UNIDADES(LCON13) + LDIFUDS             # modifica el valor en ambos casos
      If [M:YPM4]TIPO(LCON13) = 4 Then
        LKITPOS = [M:YPM4]UNIDADES(LCON13)                                      # si es un kit guarda el valor después de modificarlo
      Endif
    Elsif [M:YPM4]TIPO(LCON13) = 5 Then                                         # si es un componente...
      LCOMP = [M:YPM4]UNIDADES(LCON13) / LKITPREV                               # ...obtiene la cantidad de ese componente para ese kit
      [M:YPM4]UNIDADES(LCON13) = LCOMP * LKITPOS                                # ...obtiene la cantidad de ese componente con la diferencia modificada
    Else
      Break
    Endif
  Next

Kill LCON13, LDIFUDS, LKITPREV, LKITPOS, LCOMP

Return

##############################################################
# actualiza las unidades de lo que cuelga en un kit
$ACT_UDSKIT
Local Integer LCON13  : Raz LCON13
Local Integer LDIFUDS, LKITPREV, LKITPOS, LCOMP : Raz LDIFUDS, LKITPREV, LKITPOS, LCOMP

  LDIFUDS   = VALEUR - [M:YPM4]UNIDADES(nolign-1)                               # guarda la diferencia entre el valor actual y el que se modifica
  LKITPREV  = [M:YPM4]UNIDADES(nolign-1)                                        # si es un kit guarda el valor antes de modificarlo
  LKITPOS   = VALEUR

  For LCON13 = nolign To [M:YPM4]NBEMERGE-1
    If [M:YPM4]TIPO(LCON13) = 5 Then
      LCOMP = [M:YPM4]UNIDADES(LCON13) / LKITPREV                               # ...obtiene la cantidad de ese componente para ese kit
      [M:YPM4]UNIDADES(LCON13) = LCOMP * LKITPOS                                # ...obtiene la cantidad de ese componente con la diferencia modificada
    Else
      Break
    Endif
  Next

Kill LCON13, LDIFUDS, LKITPREV, LKITPOS, LCOMP

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Antes entrada campo 'Tipo'
######################################################################################
# Oculta la opción 'Componente' de la lista
Subprog AS_TIPO(VALEUR)
Variable Integer VALEUR
#  Raz GMENLOC
#  GMENLOC(2) = 1
#  GMENLOC(3) = 1
#  GMENLOC(5) = 1
End

######################################################################################
## Después de modificar el campo 'Cantidad'
######################################################################################
Subprog AM_UNIDADES(VALEUR)
Variable Decimal VALEUR

  [M:YPM4]UNIDADES(nolign-1) = VALEUR
  Affzo [M:YPM4]UNIDADES(nolign-1)
  zonsui = "[M:YPM4]UNIDADES(nolign-1)"

End

######################################################################################
## Control en el campo 'Cantidad'
######################################################################################
Subprog C_UNIDADES(VALEUR)
Variable Decimal VALEUR

  # si es 'Subzona', actualiza la cantidad en todo lo que cuelga de ella
  If [M:YPM4]TIPO(nolign-1) = 2 Then
    Gosub ACT_UDSSUBZONA
  Elsif [M:YPM4]TIPO(nolign-1) = 4 Then
    Gosub ACT_UDSKIT
  Endif

  Affzo [M:YPM4]10

End

######################################################################################
## Después de modificar el campo 'Artículo'
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

  [M:YPM4]ITMREF(nolign-1) = VALEUR
  Affzo [M:YPM4]ITMREF(nolign-1)
  # rellena la descripción del artículo y la unidad de venta
  Read [F:ITM9]ITM0 = VALEUR
  If !fstat Then
    [M:YPM4]ITMDES(nolign-1)    = [F:ITM9]ITMDES1
    [M:YPM4]SAU(nolign-1)       = [F:ITM9]SAU
  Endif
  [M:YPM4]DTOOCULTOL(nolign-1) = [M:YPM4]DTOOCULTO
  [M:YPM4]RECOCULTOL(nolign-1) = [M:YPM4]RECOCULTO
  If [M:YPM4]TIPO(nolign-1) <> 1 and [M:YPM4]TIPO(nolign-1) <> 4 Then : [M:YPM4]UNIDADES(nolign-1) = 1 : Endif

  # busca la tipología del artículo
  Read [F:ITS1]ITS0 = VALEUR
  If !fstat Then
    Case [F:ITS1]ITMTYP
      When 1
        Read [F:ITM4]ITM0 = VALEUR
        If !fstat Then
          If    [F:ITM4]TCLCOD = "ZONAS"  Then : [M:YPM4]TIPO(nolign-1) = 3
          Elsif [F:ITM4]TCLCOD = "SUBZO"  Then : [M:YPM4]TIPO(nolign-1) = 2
          Else                                 : [M:YPM4]TIPO(nolign-1) = 1
        Endif
        Endif
      When 3 : [M:YPM4]TIPO(nolign-1) = 4
    Endcase
    Affzo [M:YPM4]TIPO(nolign-1)
  Endif

  # si es 'Kit', inserta los componentes
  If [M:YPM4]TIPO(nolign-1) = 4 Then
    Gosub INSERTA_KIT_E
  Endif

  Affzo [M:YPM4]10

End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
