#      [M:YSOH5]YCOLORCOMP(I)    = [M:SOH4]YCOLORCOMP(LCON)
      [M:YSOH5]IDREG(I)         = I + 1
      [M:YSOH5]CREFLG(I)        = I + 1
      [M:YSOH5]UPDFLG(I)        = 0
      [M:YSOH5]YIDKIT(I)        = [M:SOH4]YIDKIT(LCON)
      [M:YSOH5]FMI(I)           = 5
      [M:YSOH5]YIDKIT(I)        = [M:SOH0]SOHNUM + num$((I + 1) * 1000) + [M:SOH4]ITMREF(LCON)
      I += 1
      Local Char LVAR(10)   : LVAR = num$((I + 1) * 1000)
      Filter [F:BOD0] Where ITMREF = [M:SOH4]ITMREF(LCON) Order By BOMSEQ Asc
      For [BOD0]
        Read [F:ITM0]ITM0 = [F:BOD0]CPNITMREF
        If !fstat Then
          If [F:ITM0]TCLCOD = "YFPRO" Then
            [M:YSOH5]YTIPO(I)   = 7                                                # componente fabricación
            [M:YSOH5]YIDKIT(I) = [M:SOH0]SOHNUM + LVAR + [M:SOH4]ITMREF(LCON)
            [M:YSOH5]ITMREF(I)    = [F:BOD0]CPNITMREF
            Read   [F:ITM9]ITM0   = [F:BOD0]CPNITMREF
            If !fstat Then
              [M:YSOH5]ITMDES(I)  = [F:ITM9]ITMDES1
              [M:YSOH5]ITMDES1(I) = [F:ITM9]ITMDES1
            Endif
            [M:YSOH5]ECCVALMAJ(I)     = [M:SOH4]ECCVALMAJ(LCON)     : [M:YSOH5]ECCVALMIN(I)   = [M:SOH4]ECCVALMIN(LCON)   : [M:YSOH5]DSTOFCY(I)       = [M:SOH4]DSTOFCY(LCON)
            [M:YSOH5]LINREVNUM(I)     = [M:SOH4]LINREVNUM(LCON)     : [M:YSOH5]LINREVDAT(I)   = [M:SOH4]LINREVDAT(LCON)   : [M:YSOH5]SAUSTUCOE(I)     = [M:SOH4]SAUSTUCOE(LCON)
            [M:YSOH5]SHTQTY(I)        = 0                           : [M:YSOH5]DALLTYP(I)     = [M:SOH4]DALLTYP(LCON)     : [M:YSOH5]GROPRI(I)        = 0
            [M:YSOH5]YGROPRI(I)       = 0                           : [M:YSOH5]DISCRGVAL1(I)  = 0                         : [M:YSOH5]DISCRGVAL2(I)    = 0
            [M:YSOH5]DISCRGVAL3(I)    = 0                           : [M:YSOH5]DISCRGVAL4(I)  = 0                         : [M:YSOH5]DISCRGVAL5(I)    = 0
            [M:YSOH5]DISCRGVAL6(I)    = 0                           : [M:YSOH5]NETPRI(I)      = 0                         : [M:YSOH5]CPRPRI(I)        = 0
            [M:YSOH5]PFM(I)           = 0                           : [M:YSOH5]VACITM1(I)     = ""                        : [M:YSOH5]VACITM2(I)       = ""
            [M:YSOH5]VACITM3(I)       = ""                          : [M:YSOH5]REP1(I)        = ""                        : [M:YSOH5]REPRAT1(I)       = 0
            [M:YSOH5]REP2(I)          = ""                          : [M:YSOH5]REPRAT2(I)     = 0                         : [M:YSOH5]REPCOE(I)        = 0
            [M:YSOH5]DDEMDLVDAT(I)    = [M:SOH4]DDEMDLVDAT(LCON)    : [M:YSOH5]DSHIDAT(I)     = [M:SOH4]DSHIDAT(LCON)     : [M:YSOH5]EXTDLVDAT(I)     = [M:SOH4]EXTDLVDAT(LCON)
            [M:YSOH5]DBPAADD(I)       = [M:SOH4]DBPAADD(LCON)       : [M:YSOH5]CNDNAM(I)      = [M:SOH4]CNDNAM(LCON)
            [M:YSOH5]USEPLC(I)        = ""                          : [M:YSOH5]DDLVPIO(I)     = [M:SOH4]DDLVPIO(LCON)     : [M:YSOH5]DDRN(I)          = [M:SOH4]DDRN(LCON)
            [M:YSOH5]DMDL(I)          = [M:SOH4]DMDL(LCON)          : [M:YSOH5]DBPTNUM(I)     = [M:SOH4]DBPTNUM(LCON)     : [M:YSOH5]PRECOD(I)        = [M:SOH4]PRECOD(LCON)
            [M:YSOH5]PCK(I)           = [M:SOH4]PCK(LCON)           : [M:YSOH5]PCKCAP(I)      = [M:SOH4]PCKCAP(LCON)      : [M:YSOH5]BPCSALPRI(I)     = [M:SOH4]BPCSALPRI(LCON)
            [M:YSOH5]DEMDLVHOU(I)     = [M:SOH4]DEMDLVHOU(LCON)     : [M:YSOH5]MAXDLVDAT(I)   = [M:SOH4]MAXDLVDAT(LCON)   : [M:YSOH5]MAXDLVHOU(I)     = [M:SOH4]MAXDLVHOU(LCON)
            [M:YSOH5]USELIMDAT(I)     = [M:SOH4]USELIMDAT(LCON)     : [M:YSOH5]CCE1(I)        = [M:SOH4]CCE1(LCON)        : [M:YSOH5]CCE2(I)          = [M:SOH4]CCE2(LCON)
            [M:YSOH5]CCE3(I)          = [M:SOH4]CCE3(LCON)          : [M:YSOH5]CCE4(I)        = [M:SOH4]CCE4(LCON)        : [M:YSOH5]CCE5(I)          = [M:SOH4]CCE5(LCON)
            [M:YSOH5]CCE6(I)          = [M:SOH4]CCE6(LCON)          : [M:YSOH5]CCE7(I)        = [M:SOH4]CCE7(LCON)        : [M:YSOH5]CCE8(I)          = [M:SOH4]CCE8(LCON)
            [M:YSOH5]CCE9(I)          = [M:SOH4]CCE9(LCON)          : [M:YSOH5]CCE10(I)       = [M:SOH4]CCE10(LCON)       : [M:YSOH5]CCE11(I)         = [M:SOH4]CCE11(LCON)
            [M:YSOH5]CCE12(I)         = [M:SOH4]CCE12(LCON)         : [M:YSOH5]CCE13(I)       = [M:SOH4]CCE13(LCON)       : [M:YSOH5]CCE14(I)         = [M:SOH4]CCE14(LCON)
            [M:YSOH5]CCE15(I)         = [M:SOH4]CCE15(LCON)         : [M:YSOH5]CCE16(I)       = [M:SOH4]CCE16(LCON)       : [M:YSOH5]CCE17(I)         = [M:SOH4]CCE17(LCON)
            [M:YSOH5]CCE18(I)         = [M:SOH4]CCE18(LCON)         : [M:YSOH5]CCE19(I)       = [M:SOH4]CCE19(LCON)       : [M:YSOH5]CCE20(I)         = [M:SOH4]CCE20(LCON)
            [M:YSOH5]DEMSTA(I)        = [M:SOH4]DEMSTA(LCON)
  #          [M:YSOH5]LINORDNOT(I)     = [M:SOH4]LINORDNOT(LCON)     : [M:YSOH5]LINORDATI(I)   = [M:SOH4]LINORDATI(LCON)   : [M:YSOH5]LINPFM(I)        = [M:SOH4]LINPFM(LCON)
  #          [M:YSOH5]DETSQHNUM(I)     = [M:SOH4]DETSQHNUM(LCON)
            [M:YSOH5]LINTYP(I)        = 1
            [M:YSOH5]FOCFLG(I)        = [M:SOH4]FOCFLG(LCON)
            [M:YSOH5]ORILIN(I)        = [M:SOH4]ORILIN(LCON)        : [M:YSOH5]SOQSTA(I)      = [M:SOH4]SOQSTA(LCON)      : [M:YSOH5]DCCLREN(I)       = [M:SOH4]DCCLREN(LCON)
            [M:YSOH5]DCCLDAT(I)       = [M:SOH4]DCCLDAT(LCON)       : [M:YSOH5]QTYSTU(I)      = 0                         : [M:YSOH5]ALLQTYSTU(I)     = 0
            [M:YSOH5]WALLQTYSTU(I)    = 0                           : [M:YSOH5]DLVQTY(I)      = 0                         : [M:YSOH5]INVQTY(I)        = 0
