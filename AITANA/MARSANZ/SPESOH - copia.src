######################################################################################
## Click en el icono 'Ocultar/Mostrar componentes' (pantalla SOH4) 30/09/2020 09:05:36 (AIT07)
######################################################################################
Subprog CL_YOMCAMPOS(VALEUR)
Variable Char    VALEUR()
      If GCOMPSTA = 0 Then
        Gosub OCULTAR_COMPONENTES
      Else
        If GTIPOPED = 2 Then
          [M:SOH4] = [M:YSOH5]
        Else
          Gosub RELLENA_AUX
          [M:SOH4] = [M:YSOH5]
        Endif
        Affzo [M:SOH4]
        GCOMPSTA = 0
#        Gosub MOSTRAR_COMPONENTES
      Endif
      Gosub COLOREA_LINEAS
End

######################################################################################
## Después de modificar el campo YGROPRI
######################################################################################
Subprog AM_YGROPRI(VALEUR)
Variable Decimal VALEUR

Local Decimal LVALEUR
Local Decimal PRECIO : PRECIO = VALEUR

  # si es un artículo, modifica GROPRI, sino no hace nada para que no afecte a los KITS
  Read [F:ITS1]ITS0 = [M:SOH4]ITMREF(nolign-1)
  If !fstat Then
    If [F:ITS1]ITMTYP = 1 Then
      # Actualizamos el campo standard
      [M:SOH4]GROPRI(nolign -1) = PRECIO
      Affzo [M:SOH4]GROPRI(nolign -1)
      LVALEUR=VALEUR
      VALEUR=PRECIO

      #La acción es DIVDISCRG, pero llama al punto D_DISCRG
      Local Char    WABMSK    :    WABMSK="SOH4"
      Local Integer DISCRGNUM :    DISCRGNUM = 0
      Local Integer NOLIG     :    NOLIG=nolign-1

      If DISCRGNUM > 0 & DISCRGNUM < 10
         Assign "[M:"+WABMSK+"]DISCRGREN"+num$(DISCRGNUM)+"(NOLIG)" With GDACMANSAL
      Elsif DISCRGNUM = 0
         Assign "[M:"+WABMSK+"]PRIREN(NOLIG)" With GDACMANSAL
      Endif

      Local Char PARAM(250)(250)
      Local Char TRAIT
      TRAIT="DIVPRIPFM"
      PARAM(1)="0"
      PARAM(2)=num$([M]QTY(nolign-1))
      PARAM(3)=[M:SOH0]BPCORD
      PARAM(4)=num$([M:SOH0]CHGTYP)
      PARAM(5)=[M:SOH0]ORDDAT
      PARAM(6)=[M:SOH1]CUR
      PARAM(7)=num$(nolign-1)
      PARAM(8)=[M:SOH4]DSTOFCY(nolign-1)
      PARAM(9)=num$([M:SOH1]PRITYP)
      PARAM(10)="GROPRI"
      Gosub DIVPRIPFM From TRTVENPRI
      VALEUR=LVALEUR
     # Actualizamos el campo standard
      [M:SOH4]GROPRI(nolign-1) = PRECIO
      Affzo [M:SOH4]GROPRI(nolign-1)

    Endif
  Endif
End

######################################################################################
## Después de modificar el campo 'Cantidad' (pantalla SOH4) 05/11/2020 08:59:08 (AIT07)
######################################################################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR

  If GFONCTION = "GESSOH" Then
    Local Integer LKITLIN,LNOL

      If [M:SOH4]YTIPO(nolign-1) = 4 Then
        LKITLIN = nolign-1
        LNOL = nolign
        Repeat
          Filter [F:BOD2] Where ITMREF = [M:SOH4]ITMREF(LKITLIN) and CPNITMREF = [M:SOH4]ITMREF(LNOL)
          Read [F:BOD2] First
          If !fstat Then
            [M:SOH4]QTY(LNOL) = [F:BOD2]BOMQTY * [M:SOH4]QTY(LKITLIN)
            Affzo [M:SOH4]QTY(LNOL)
          Endif
          LNOL += 1
          Filter [F:BOD2]
        Until [M:SOH4]YTIPO(LNOL) <> 5
      Endif

    If dim(LKITLIN) > 0  Then : Kill LKITLIN  : Endif
    If dim(LNOL)    > 0  Then : Kill LNOL     : Endif
  Endif

End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
#######################
#**
#* devuelve el precio bruto sobre YGROPRI
#*
#* @param PITMREF  > código de artículo
#*!
Funprog COPIA_GROPRI(PITMREF)
Value Char PITMREF

Local Decimal LRES, LGROPRI

  Read [F:ITS0]ITS0 = PITMREF
  If !fstat Then
    If [F:ITS0]ITMTYP = 1 Then
      LRES = [M:SOH4]GROPRI(nolign-1)
    Elsif [F:ITS0]ITMTYP = 3 Then
      Filter [F:BOD0] Where ITMREF = PITMREF
      For [BOD0]
        Filter [F:SPL0] Where PLI = "T50" and PLICRI1 = [F:BOD0]CPNITMREF and [M:SOH0]ORDDAT >= PLISTRDAT and [M:SOH0]ORDDAT <= PLIENDDAT
&                                         and [M:SOH4]QTY(nolign-1) >= MINQTY and [M:SOH4]QTY(nolign-1) <= MAXQTY
        Read [F:SPL0] First
        If !fstat Then
          LGROPRI += [F:BOD0]BOMQTY * [F:SPL0]PRI
        Endif
        Filter [F:SPL0]
      Next
      LRES = LGROPRI
      Filter [F:BOD0]
    Else
      LRES = [M:SOH4]GROPRI(nolign-1)
    Endif
  Endif

End LRES

