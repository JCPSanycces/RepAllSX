      [M:SOH4]YSTOMGTCOD(I)    = [M:YSOH5]YSTOMGTCOD(LCON)    : [M:SOH4]FOCNUMLIG(I)   = [M:YSOH5]FOCNUMLIG(LCON)   : [M:SOH4]WUPDAPPFLG(I)    = [M:YSOH5]WUPDAPPFLG(LCON)
      [M:SOH4]DLVFLG(I)        = [M:YSOH5]DLVFLG(LCON)
