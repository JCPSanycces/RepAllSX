      [M:SOH4]YCOLORCOMP(I)    = [M:YSOH5]YCOLORCOMP(LCON)
      [M:SOH4]IDREG(I)         = [M:YSOH5]IDREG(LCON)
      [M:SOH4]YIDKIT(I)        = [M:YSOH5]YIDKIT(LCON)
      [M:SOH4]CREFLG(I)        = I + 1
      [M:SOH4]UPDFLG(I)        = 0
      If [M:YSOH5]YTIPO(LCON)  = 6 Then
        [M:SOH4]FMI(I)         = 5
      Else
        [M:SOH4]FMI(I)         = 1
      Endif
      I += 1
    Endif
    [M:SOH4]NBLIG = I
    Affzo [M:SOH4]
  Next
  Kill LCON, I
  GCOMPSTA = 1
Return

##############################################################
$MOSTRAR_COMPONENTES

Gosub RELLENA_AUX
Gosub CARGA_COLOR_COMP

Local Integer LCON, I : Raz LCON, I

  For LCON = 0 To [M:SOH4]NBLIG-1
    Dela LCON,1,[M:SOH4]NBLIG-1 [M:SOH4]NBLIG : [M:SOH4]NBLIG -= 1
  Next
  Raz [M:SOH4]

  For LCON = 0 To [M:YSOH5]NBLIG - 1
#Infbox num$([M:YSOH5]YTIPO(LCON))
    If [M:YSOH5]YTIPO(LCON) <> 7 Then
      [M:SOH4]NUMLIG(I)        = [M:YSOH5]NUMLIG(LCON)        : [M:SOH4]YZ(I)          = [M:YSOH5]YZ(LCON)          : [M:SOH4]YM(I)            = [M:YSOH5]YM(LCON)
