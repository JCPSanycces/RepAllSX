######################################################################################
## Después de modificar el campo 'Color comp.' (pantalla SOH4) 29/09/2020 12:32:22 (AIT07)
######################################################################################
Subprog AM_YCOLORCOMP(VALEUR)
Variable Char    VALEUR()
  [M:SOH4]YCOLORCOMP(nolign-1) = VALEUR
