            [M:YSOH5]OPRQTY(I)        = 0                           : [M:YSOH5]PREQTY(I)      = 0
            [M:YSOH5]PRIREN(I)        = [M:SOH4]PRIREN(LCON)        : [M:YSOH5]DISCRGREN1(I)  = [M:SOH4]DISCRGREN1(LCON)  : [M:YSOH5]DISCRGREN2(I)    = [M:SOH4]DISCRGREN2(LCON)
            [M:YSOH5]DISCRGREN3(I)    = [M:SOH4]DISCRGREN3(LCON)    : [M:YSOH5]DISCRGREN4(I)  = [M:SOH4]DISCRGREN4(LCON)  : [M:YSOH5]DISCRGREN5(I)    = [M:SOH4]DISCRGREN5(LCON)
            [M:YSOH5]DISCRGREN6(I)    = [M:SOH4]DISCRGREN6(LCON)
            [M:YSOH5]VAT1(I)          = [M:SOH4]VAT1(LCON)          : [M:YSOH5]VAT2(I)        = [M:SOH4]VAT2(LCON)
            [M:YSOH5]VAT3(I)          = [M:SOH4]VAT3(LCON)          : [M:YSOH5]CLCAMT1(I)     = [M:SOH4]CLCAMT1(LCON)     : [M:YSOH5]CLCAMT2(I)       = [M:SOH4]CLCAMT2(LCON)
            [M:YSOH5]LINDLRNOT(I)     = [M:SOH4]LINDLRNOT(LCON)     : [M:YSOH5]LINDLRATI(I)   = [M:SOH4]LINDLRATI(LCON)   : [M:YSOH5]LININRSCHNOT(I)  = [M:SOH4]LININRSCHNOT(LCON)
            [M:YSOH5]LININRSCHATI(I)  = [M:SOH4]LININRSCHATI(LCON)  : [M:YSOH5]YALLQTY(I)     = [M:SOH4]YALLQTY(LCON)     : [M:YSOH5]YQTY(I)          = [M:SOH4]YQTY(LCON)
            [M:YSOH5]YSHTQTY(I)       = [M:SOH4]YSHTQTY(LCON)       : [M:YSOH5]TALLQTYSTU(I)  = [M:SOH4]TALLQTYSTU(LCON)  : [M:YSOH5]TALLQTY(I)       = [M:SOH4]TALLQTY(LCON)
            [M:YSOH5]YSOQSTA(I)       = [M:SOH4]YSOQSTA(LCON)       : [M:YSOH5]STOMGTCOD(I)   = [M:SOH4]STOMGTCOD(LCON)   : [M:YSOH5]TSICOD1(I)       = [M:SOH4]TSICOD1(LCON)
            [M:YSOH5]TSICOD2(I)       = [M:SOH4]TSICOD2(LCON)       : [M:YSOH5]TSICOD3(I)     = [M:SOH4]TSICOD3(LCON)     : [M:YSOH5]TSICOD4(I)       = [M:SOH4]TSICOD4(LCON)
            [M:YSOH5]TSICOD5(I)       = [M:SOH4]TSICOD5(LCON)       : [M:YSOH5]LOT(I)         = [M:SOH4]LOT(LCON)         : [M:YSOH5]LOC(I)           = [M:SOH4]LOC(LCON)
            [M:YSOH5]STA(I)           = [M:SOH4]STA(LCON)           : [M:YSOH5]GRPFLG(I)      = [M:SOH4]GRPFLG(LCON)      : [M:YSOH5]SQDLIN(I)        = [M:SOH4]SQDLIN(LCON)
            [M:YSOH5]NETPRINOT(I)     = [M:SOH4]NETPRINOT(LCON)     : [M:YSOH5]NETPRIATI(I)   = [M:SOH4]NETPRIATI(LCON)   : [M:YSOH5]SOQTEX(I)        = [M:SOH4]SOQTEX(LCON)
            [M:YSOH5]ANCSOQTEX(I)     = [M:SOH4]ANCSOQTEX(LCON)     : [M:YSOH5]ITMREFBPC(I)   = [M:SOH4]ITMREFBPC(LCON)   : [M:YSOH5]INVFLG(I)        = [M:SOH4]INVFLG(LCON)
            [M:YSOH5]YDSHIDAT(I)      = [M:SOH4]YDSHIDAT(LCON)      : [M:YSOH5]WIPFLG(I)      = [M:SOH4]WIPFLG(LCON)      : [M:YSOH5]OCNPRNBOM(I)     = [M:SOH4]OCNPRNBOM(LCON)
            [M:YSOH5]NDEPRNBOM(I)     = [M:SOH4]NDEPRNBOM(LCON)     : [M:YSOH5]INVPRNBOM(I)   = [M:SOH4]INVPRNBOM(LCON)   : [M:YSOH5]CQTY(I)          = [M:SOH4]CQTY(LCON)
            [M:YSOH5]IMPNUMLIG(I)     = [M:SOH4]IMPNUMLIG(LCON)     : [M:YSOH5]CONNUM(I)      = [M:SOH4]CONNUM(LCON)      : [M:YSOH5]TDLQTYSTU(I)     = [M:SOH4]TDLQTYSTU(LCON)
            [M:YSOH5]DACSAUCOE(I)     = [M:SOH4]DACSAUCOE(LCON)     : [M:YSOH5]POPLIN(I)      = [M:SOH4]POPLIN(LCON)      : [M:YSOH5]RERBPCFLG(I)     = [M:SOH4]RERBPCFLG(LCON)
            [M:YSOH5]DLBQTYSTU(I)     = [M:SOH4]DLBQTYSTU(LCON)     : [M:YSOH5]DSPLINFLG(I)   = [M:SOH4]DSPLINFLG(LCON)   : [M:YSOH5]DSPLINWEI(I)     = [M:SOH4]DSPLINWEI(LCON)
            [M:YSOH5]DSPLINVOL(I)     = [M:SOH4]DSPLINVOL(LCON)     : [M:YSOH5]PTOCOD(I)      = [M:SOH4]PTOCOD(LCON)      : [M:YSOH5]CTMFLG(I)        = [M:SOH4]CTMFLG(LCON)
            [M:YSOH5]YSTOMGTCOD(I)    = [M:SOH4]YSTOMGTCOD(LCON)    : [M:YSOH5]FOCNUMLIG(I)   = [M:SOH4]FOCNUMLIG(LCON)   : [M:YSOH5]WUPDAPPFLG(I)    = [M:SOH4]WUPDAPPFLG(LCON)
            [M:YSOH5]DLVFLG(I)        = [M:SOH4]DLVFLG(LCON)
            [M:YSOH5]SAU(I)           = [F:BOD0]BOMUOM
            [M:YSOH5]STU(I)           = [F:BOD0]BOMUOM
            [M:YSOH5]QTY(I)           = [F:BOD0]LIKQTY * [M:SOH4]QTY(LCON)
            [M:YSOH5]ALLQTY(I)        = [F:BOD0]LIKQTY * [M:SOH4]QTY(LCON)
            [M:YSOH5]WALLQTY(I)       = [F:BOD0]LIKQTY * [M:SOH4]QTY(LCON)
            [M:YSOH5]TDLQTY(I)        = [F:BOD0]LIKQTY * [M:SOH4]QTY(LCON)
            [M:YSOH5]YCOLORCOMP(I)    = [M:SOH4]YCOLORCOMP(LCON)
            [M:YSOH5]SOPLIN(I)        = [M:SOH4]SOPLIN(LCON) + I
            [M:YSOH5]IDREG(I)         = I + 1
            [M:YSOH5]CREFLG(I)        = I + 1
            [M:YSOH5]UPDFLG(I)        = 0
            I += 1
          Endif
        Endif
      Next
      Filter [F:BOD0]
    Endif
  Next
  [M:YSOH5]NBLIG = I
#  Affzo [M:YSOH5]

#  For LCON = 0  To [M:YSOH5]NBLIG - 1
#    Read [F:YCC0]YCC0 = [M:SOH0]SOHNUM;[M:YSOH5]SOPLIN(LCON)
#    If !fstat Then
#      [M:YSOH5]YCOLORCOMP(LCON) = [F:YCC0]YCOLORCOMP
#      Affzo [M:YSOH5]YCOLORCOMP(LCON)
#    Endif
#  Next
Endif

  Affzo [M:YSOH5]
  Kill LCON, I
Return

##############################################################
$LIMPIA_TABLA_COLOR_COMP
  Trbegin [F:YCC0]
  Delete [F:YCC0] Where IDBORRADOR = [M:SOH0]SOHNUM
  If !fstat Then
    Commit
  Else
    Rollback
  Endif
Return

##############################################################
$RELLENA_TABLA_COLOR_COMP
Local Integer LCON : Raz LCON

  Gosub LIMPIA_TABLA_COLOR_COMP
If GTIPOPED = 2 Then
  Gosub MOSTRAR_COMPONENTES
  Gosub RELLENA_AUX
  For LCON = 0 To [M:YSOH5]NBLIG - 1
    Trbegin [F:YCC0]
    [F:YCC0]IDBORRADOR      = [M:SOH0]SOHNUM
    [F:YCC0]TIPODOC         = "PED"
    [F:YCC0]NUMLIN          = [M:YSOH5]SOPLIN(LCON)
    [F:YCC0]TIPO            = [M:YSOH5]YTIPO(LCON)
    [F:YCC0]ITMREF          = [M:YSOH5]ITMREF(LCON)
    [F:YCC0]ITMDES          = [M:YSOH5]ITMDES(LCON)
    [F:YCC0]IDREG           = [M:YSOH5]IDREG(LCON)
    If [M:YSOH5]YCOLORCOMP(LCON) <> "" Then
      [F:YCC0]YCOLORCOMP    = [M:YSOH5]YCOLORCOMP(LCON)
    Else
      Filter [F:ITM0] Where ITMREF = [M:YSOH5]ITMREF(LCON)
      Read [F:ITM0] First
      If [M:YSOH5]YTIPO(LCON) = 7 and [F:ITM0]TCLCOD <> "YFPRO" Then
        [F:YCC0]YCOLORCOMP  = [M:YSOH5]ITMREF(LCON)
      Else
        [F:YCC0]YCOLORCOMP  = ""
      Endif
      Filter [F:ITM0]
    Endif
    [F:YCC0]YIDKIT = [M:YSOH5]YIDKIT(LCON)
    Write [F:YCC0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next
  Kill LCON
  Gosub OCULTAR_COMPONENTES
Else
  Gosub RELLENA_AUX
  For LCON = 0 To [M:YSOH5]NBLIG - 1
    Trbegin [F:YCC0]
    [F:YCC0]IDBORRADOR      = [M:SOH0]SOHNUM
    [F:YCC0]TIPODOC         = "PED"
    [F:YCC0]NUMLIN          = [M:YSOH5]SOPLIN(LCON)
    [F:YCC0]TIPO            = [M:YSOH5]YTIPO(LCON)
    [F:YCC0]ITMREF          = [M:YSOH5]ITMREF(LCON)
    [F:YCC0]ITMDES          = [M:YSOH5]ITMDES(LCON)
    [F:YCC0]IDREG           = [M:YSOH5]IDREG(LCON)
    If [M:YSOH5]YCOLORCOMP(LCON) <> "" Then
      [F:YCC0]YCOLORCOMP    = [M:YSOH5]YCOLORCOMP(LCON)
    Else
      Filter [F:ITM0] Where ITMREF = [M:YSOH5]ITMREF(LCON)
      Read [F:ITM0] First
      If [M:YSOH5]YTIPO(LCON) = 7 and [F:ITM0]TCLCOD <> "YFPRO" Then
        [F:YCC0]YCOLORCOMP  = [M:YSOH5]ITMREF(LCON)
      Else
        [F:YCC0]YCOLORCOMP  = ""
      Endif
      Filter [F:ITM0]
    Endif
    [F:YCC0]YIDKIT = [M:YSOH5]YIDKIT(LCON)
    Write [F:YCC0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next
  Kill LCON
Endif
Return

##############################################################
$LIMPIA_TABLA_COLOR_COMP_ST
  Delete [F:YCC0] Where IDBORRADOR = [M:SOH0]SOHNUM
Return

##############################################################
$RELLENA_TABLA_COLOR_COMP_ST
Local Integer LCON : Raz LCON

  Gosub LIMPIA_TABLA_COLOR_COMP_ST
  For LCON = 0 To [M:YSOH5]NBLIG - 1
    [F:YCC0]IDBORRADOR      = [M:SOH0]SOHNUM
    [F:YCC0]NUMLIN          = [M:YSOH5]SOPLIN(LCON)
    [F:YCC0]TIPO            = [M:YSOH5]YTIPO(LCON)
    [F:YCC0]ITMREF          = [M:YSOH5]ITMREF(LCON)
    [F:YCC0]IDREG           = [M:YSOH5]IDREG(LCON)
    If [M:YSOH5]YCOLORCOMP(LCON) <> "" Then
      [F:YCC0]YCOLORCOMP    = [M:YSOH5]YCOLORCOMP(LCON)
    Else
      Filter [F:ITM0] Where ITMREF = [M:YSOH5]ITMREF(LCON)
      Read [F:ITM0] First
      If [M:YSOH5]YTIPO(LCON) = 7 and [F:ITM0]TCLCOD <> "YFPRO" Then
        [F:YCC0]YCOLORCOMP  = [M:YSOH5]ITMREF(LCON)
      Else
        [F:YCC0]YCOLORCOMP  = ""
      Endif
      Filter [F:ITM0]
    Endif
    [F:YCC0]YIDKIT = [M:YSOH5]YIDKIT(LCON)
    Write [F:YCC0]
  Next
  Kill LCON
Return

##############################################################
$CARGA_COLOR_COMP
Local Integer LCON : Raz LCON

  Filter [F:YCC0] Where IDBORRADOR = [M:SOH0]SOHNUM Order By NUMLIN
  For [F:YCC0]
    [M:YSOH5]YCOLORCOMP(LCON) = [F:YCC0]YCOLORCOMP
    LCON += 1
  Next

  Affzo [M:YSOH5]
  Filter [F:YCC0]

  Kill LCON
Return

##############################################################
# cambia los campos LINTYP=1 (normal) e YTIPO=5 (componente com.) para todas aquellas líneas que sean componentes
# de un kit
$CAMBIA_TIPO_COMPONENTE
Local Integer LCON

  For LCON = 0 To [M:SOH4]NBLIG - 1
    If [M:SOH4]LINTYP(LCON) = 7 Then
      [M:SOH4]YTIPO(LCON)   = 5
      [M:SOH4]LINTYP(LCON)  = 1
      Affzo [M:SOH4]YTIPO(LCON)
      Affzo [M:SOH4]LINTYP(LCON)
    Endif

    # cambia el campo 'Origen artículo' para los kits de fabricación
    If [M:SOH4]YTIPO(LCON) = 6 Then
      [M:SOH4]FMI(LCON) = 5
      Affzo [M:SOH4]FMI(LCON)
    Endif
  Next
Kill LCON
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
##############################################################
## Después de modificar 'Color'
##############################################################
Subprog AM_YCOLOR(VALEUR)
Variable Char    VALEUR()

# MA03
  [M:SOH4]LOT(nolign-1) = VALEUR
  Affzo [M:SOH4]LOT(nolign-1)
# MA03

End

######################################################################################
## Después de modificar el campo 'Artículo'
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

  # rellena el campo YCOLOR de la ficha de artículo
  If [M:SOH4]YCOLOR(nolign-1) = "" Then
    Read [F:ITM0]ITM0 = VALEUR
    If !fstat Then
      [M:SOH4]YCOLOR(nolign-1) = [F:ITM0]YCOLOR
      Affzo [M:SOH4]YCOLOR(nolign-1)
    Endif
  Endif

  # busca la tipología del artículo
  [M:SOH4]ITMREF(nolign-1) = VALEUR
  Affzo [M:SOH4]ITMREF(nolign-1)
  Read [F:ITS1]ITS0 = VALEUR
  If !fstat Then
    Case [F:ITS1]ITMTYP
      When 1
        Filter [F:BOH0] Where ITMREF = VALEUR and USESTA = 2
        Read [F:BOH0] First
        If !fstat Then
          [M:SOH4]YTIPO(nolign-1) = 6
          Filter [F:BOH0]
        Else
          Read [F:ITM3]ITM0 = VALEUR
          If !fstat Then
            If    [F:ITM3]TCLCOD = "ZONAS"  Then : [M:SOH4]YTIPO(nolign-1) = 3
            Elsif [F:ITM3]TCLCOD = "SUBZO"  Then : [M:SOH4]YTIPO(nolign-1) = 2
            Else                                 : [M:SOH4]YTIPO(nolign-1) = 1
            Endif
          Endif
        Endif
      When 2,3
        Filter [F:BOH0] Where ITMREF = VALEUR and USESTA = 2
        Read [F:BOH0] First
        If !fstat Then
          Case [F:BOH0]BOMALTTYP
            When 1 : [M:SOH4]YTIPO(nolign-1) = 4           # Kit comercial
            When 2 : [M:SOH4]YTIPO(nolign-1) = 6           # Kit fabricación
          Endcase
        Endif
        Filter [F:BOH0]
    Endcase
    Affzo [M:SOH4]YTIPO(nolign-1)
  Endif

End

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla SOH4) 14/05/2020 09:15:13 (AIT04)
######################################################################################
Subprog AS_ITMDES(VALEUR)
Variable Char    VALEUR()
# Solamente permito entrar si autorizo modificación descripción en el artículo
Read [ITM]ITM0 = [M:SOH4]ITMREF(nolign-1)
If fstat = 0 and [ITM]YDESMOD <> 2
  mkstat = 2
Endif
End

