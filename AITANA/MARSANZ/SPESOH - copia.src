##############################################################
$FIN
  Close Local File [ITM0],[ITM2],[ITM3],[ITM9],[ITS0],[ITS1],[SPL0],[BOH0],[BOD0],[BOD2],[YCC0],[SQH0],[PMH0]
  If dim(GCOMPSTA) > 0 Then : Kill GCOMPSTA : Endif
  If dim(GTIPOPED) > 0 Then : Kill GTIPOPED : Endif
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
# MA01
$COLOREA_LINEAS
Local Integer LCON : Raz LCON

  For LCON = 0 To [M:SOH4]NBLIG - 1
    Case [M:SOH4]YTIPO(LCON)
      When 2        : Chgstl [M:SOH4]NBLIG(LCON) With "BACKORANGE"
      When 3        : Chgstl [M:SOH4]NBLIG(LCON) With "BACKGREEN"
      When Default  : Chgstl [M:SOH4]NBLIG(LCON) With ""
   Endcase
  Next
Affzo [M:SOH4]5
Kill LCON

Return

##############################################################
# rellena el campo YGROPRI con el importe correcto
$SET_GROPRI
#Local Decimal LGROPRI
#
#  Read [F:ITS0]ITS0 = [M:SOH4]ITMREF(NOL)
#  If !fstat Then
#    # si es un kit, se calcula a partir del valor de sus componentes
#    If [F:ITS0]ITMTYP = 3 or [F:ITS0]ITMTYP = 2 Then
#      Filter [F:BOD0] Where ITMREF = [M:SOH4]ITMREF(NOL)
#      For [BOD0]
#        Filter [F:SPL0] Where PLI = "T50" and PLICRI1 = [F:BOD0]CPNITMREF and [M:SOH0]ORDDAT >= PLISTRDAT and [M:SOH0]ORDDAT <= PLIENDDAT
#&                                         and [M:SOH4]QTY(NOL) >= MINQTY and [M:SOH4]QTY(NOL) <= MAXQTY
#        Read [F:SPL0] First
#        If !fstat Then
#          LGROPRI += [F:BOD0]BOMQTY * [F:SPL0]PRI
#        Endif
#        Filter [F:SPL0]
#      Next
#      [M:SOH4]YGROPRI(NOL) = LGROPRI
#      Filter [F:BOD0]
#    Else
#      [M:SOH4]YGROPRI(NOL) = [M:SOH4]GROPRI(NOL)
#    Endif
#  Endif
#
#  Affzo [M:SOH4]YGROPRI(NOL)
#  Call AM_YGROPRI([M:SOH4]YGROPRI(NOL))
#  Kill LGROPRI
Local Integer LCON, LKITLIN
Local Decimal LSUMAGROPRI
  For LCON = 0 To [M:SOH4]NBLIG - 1
    [M:SOH4]YGROPRI(LCON) = [M:SOH4]GROPRI(LCON)
    Affzo [M:SOH4]YGROPRI(LCON)
  Next
  For LCON = 0 To [M:SOH4]NBLIG - 1
    If [M:SOH4]YTIPO(LCON) = 4 Then
      Raz [M:SOH4]YGROPRI(LCON)
      LKITLIN = LCON
      Raz LSUMAGROPRI
      Repeat
        LCON += 1
        LSUMAGROPRI += ([M:SOH4]YGROPRI(LCON) * [M:SOH4]QTY(LCON))
      Until [M:SOH4]YTIPO(LCON + 1) <> 5
      [M:SOH4]YGROPRI(LKITLIN) = LSUMAGROPRI
      Affzo [M:SOH4]YGROPRI(LKITLIN)
    Endif
  Next
  For LCON = 0 To [M:SOH4]NBLIG - 1
    Call AM_YGROPRI([M:SOH4]YGROPRI(LCON))
  Next
Affzo [M:SOH4]5,10

Kill LCON

Return

##############################################################
# calcula los totales del bloque Margen/Acumulados
$CALC_BLOQUE_MARGEN
Local Integer LCON
  If !clalev([F:SOP3]) Then : Local File SORDERP [F:SOP3] : Endif
  If !clalev([F:SOQ3]) Then : Local File SORDERQ [F:SOQ3] : Endif
  Filter [F:SOP3] Where SOHNUM = [M:SOH0]SOHNUM
  Raz [M:SOH4]DLRNOT,INRNOT,ORDNOT,PFMTOT
  For [F:SOP3]
    Read [F:SOQ3]SOQ0 = [F:SOP3]SOHNUM;[F:SOP3]SOPLIN;[F:SOP3]SOPSEQ
    If !fstat Then
      [M:SOH4]DLRNOT += [F:SOP3]NETPRINOT * [F:SOQ3]QTY
      [M:SOH4]INRNOT += [F:SOP3]NETPRINOT * [F:SOQ3]QTY
      [M:SOH4]ORDNOT += [F:SOP3]NETPRINOT * [F:SOQ3]QTY
      [M:SOH4]PFMTOT += [F:SOP3]PFM       * [F:SOQ3]QTY
    Endif
  Next
  Filter [F:SOP3]
  Close Local File [SOP3],[SOQ3]
  Affzo [M:SOH4]DLRNOT,INRNOT,PFMTOT,ORDNOT
Return

##############################################################
$SEL_YSELCOCOPV
  Link [BOD1] With [AXX0]AXX0="ITMMASTER";"DES1AXX";GLANGUE;[F:BOD1]CPNITMREF;"" As [LNK0]
  Columns [LNK0] ([BOD1]CPNITMREF,[AXX0]TEXTE)
  Default File [LNK0]
  Filter [LNK0] Where ITMREF = [M:SOH4]ITMREF(nolign-1)
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Artículos color"                                               # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "[BOD1]CPNITMREF"                                               # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la segunda columna
  COL(NBCOL)  = "[AXX0]TEXTE"                                                   # nombre del campo a mostrar en la segunda columna
Return

##############################################################
$VERF_YSELCOCOPV
Return

##############################################################
$OCULTAR_COMPONENTES
Local Integer LCON  : Raz LCON
Local Integer I     : Raz I

  For LCON = 0 To [M:SOH4]NBLIG-1
    Dela LCON,1,[M:SOH4]NBLIG-1 [M:SOH4]NBLIG : [M:SOH4]NBLIG -= 1
  Next
  Raz [M:SOH4]

  For LCON = 0 To [M:YSOH5]NBLIG-1
    If [M:YSOH5]YTIPO(LCON) <> 5 and [M:YSOH5]YTIPO(LCON) <> 7 Then
      [M:SOH4]NUMLIG(I)        = [M:YSOH5]NUMLIG(LCON)        : [M:SOH4]YZ(I)          = [M:YSOH5]YZ(LCON)          : [M:SOH4]YM(I)            = [M:YSOH5]YM(LCON)
      [M:SOH4]YTIPO(I)         = [M:YSOH5]YTIPO(LCON)         : [M:SOH4]ITMREF(I)      = [M:YSOH5]ITMREF(LCON)      : [M:SOH4]ITMDES(I)        = [M:YSOH5]ITMDES(LCON)
      [M:SOH4]ITMDES1(I)       = [M:YSOH5]ITMDES1(LCON)       : [M:SOH4]ECCVALMAJ(I)   = [M:YSOH5]ECCVALMAJ(LCON)   : [M:SOH4]ECCVALMIN(I)     = [M:YSOH5]ECCVALMIN(LCON)
      [M:SOH4]DSTOFCY(I)       = [M:YSOH5]DSTOFCY(LCON)       : [M:SOH4]LINREVNUM(I)   = [M:YSOH5]LINREVNUM(LCON)   : [M:SOH4]LINREVDAT(I)     = [M:YSOH5]LINREVDAT(LCON)
      [M:SOH4]SAU(I)           = [M:YSOH5]SAU(LCON)           : [M:SOH4]QTY(I)         = [M:YSOH5]QTY(LCON)         : [M:SOH4]SAUSTUCOE(I)     = [M:YSOH5]SAUSTUCOE(LCON)
      [M:SOH4]STU(I)           = [M:YSOH5]STU(LCON)           : [M:SOH4]ALLQTY(I)      = [M:YSOH5]ALLQTY(LCON)      : [M:SOH4]SHTQTY(I)        = [M:YSOH5]SHTQTY(LCON)
      [M:SOH4]WALLQTY(I)       = [M:YSOH5]WALLQTY(LCON)       : [M:SOH4]DALLTYP(I)     = [M:YSOH5]DALLTYP(LCON)     : [M:SOH4]TDLQTY(I)        = [M:YSOH5]TDLQTY(LCON)
      [M:SOH4]GROPRI(I)        = [M:YSOH5]GROPRI(LCON)        : [M:SOH4]YGROPRI(I)     = [M:YSOH5]YGROPRI(LCON)     : [M:SOH4]DISCRGVAL1(I)    = [M:YSOH5]DISCRGVAL1(LCON)
      [M:SOH4]DISCRGVAL2(I)    = [M:YSOH5]DISCRGVAL2(LCON)    : [M:SOH4]DISCRGVAL3(I)  = [M:YSOH5]DISCRGVAL3(LCON)  : [M:SOH4]DISCRGVAL4(I)    = [M:YSOH5]DISCRGVAL4(LCON)
      [M:SOH4]DISCRGVAL5(I)    = [M:YSOH5]DISCRGVAL5(LCON)    : [M:SOH4]DISCRGVAL6(I)  = [M:YSOH5]DISCRGVAL6(LCON)
      [M:SOH4]NETPRI(I)        = [M:YSOH5]NETPRI(LCON)
      [M:SOH4]CPRPRI(I)        = [M:YSOH5]CPRPRI(LCON)        : [M:SOH4]PFM(I)         = [M:YSOH5]PFM(LCON)         : [M:SOH4]VACITM1(I)       = [M:YSOH5]VACITM1(LCON)
      [M:SOH4]VACITM2(I)       = [M:YSOH5]VACITM2(LCON)       : [M:SOH4]VACITM3(I)     = [M:YSOH5]VACITM3(LCON)     : [M:SOH4]DINVCND(I)       = [M:YSOH5]DINVCND(LCON)
      [M:SOH4]DINVCNDISCHG(I)  = [M:YSOH5]DINVCNDISCHG(LCON)  : [M:SOH4]DINVCNDPREV(I) = [M:YSOH5]DINVCNDPREV(LCON) : [M:SOH4]DINVCNDTODEL(I)  = [M:YSOH5]DINVCNDTODEL(LCON)
      [M:SOH4]DINVCNDTODIS(I)  = [M:YSOH5]DINVCNDTODIS(LCON)  : [M:SOH4]DINVCNDTOUPD(I)= [M:YSOH5]DINVCNDTOUPD(LCON): [M:SOH4]DINVCNDUPDK(I)   = [M:YSOH5]DINVCNDUPDK(LCON)
      [M:SOH4]SVICUUID(I)      = [M:YSOH5]SVICUUID(LCON)      : [M:SOH4]SSTCOD(I)      = [M:YSOH5]SSTCOD(LCON)      : [M:SOH4]DPJT(I)          = [M:YSOH5]DPJT(LCON)
      [M:SOH4]DPREOPP(I)       = [M:YSOH5]DPREOPP(LCON)       : [M:SOH4]REP1(I)        = [M:YSOH5]REP1(LCON)        : [M:SOH4]REPRAT1(I)       = [M:YSOH5]REPRAT1(LCON)
      [M:SOH4]REP2(I)          = [M:YSOH5]REP2(LCON)          : [M:SOH4]REPRAT2(I)     = [M:YSOH5]REPRAT2(LCON)     : [M:SOH4]REPCOE(I)        = [M:YSOH5]REPCOE(LCON)
      [M:SOH4]DDEMDLVDAT(I)    = [M:YSOH5]DDEMDLVDAT(LCON)    : [M:SOH4]DDAYLTI(I)     = [M:YSOH5]DDAYLTI(LCON)     : [M:SOH4]DSHIDAT(I)       = [M:YSOH5]DSHIDAT(LCON)
      [M:SOH4]EXTDLVDAT(I)     = [M:YSOH5]EXTDLVDAT(LCON)     : [M:SOH4]DBPAADD(I)     = [M:YSOH5]DBPAADD(LCON)     : [M:SOH4]CNDNAM(I)        = [M:YSOH5]CNDNAM(LCON)
      [M:SOH4]USEPLC(I)        = [M:YSOH5]USEPLC(LCON)        : [M:SOH4]DDLVPIO(I)     = [M:YSOH5]DDLVPIO(LCON)     : [M:SOH4]DDRN(I)          = [M:YSOH5]DDRN(LCON)
      [M:SOH4]DMDL(I)          = [M:YSOH5]DMDL(LCON)          : [M:SOH4]DBPTNUM(I)     = [M:YSOH5]DBPTNUM(LCON)     : [M:SOH4]PRECOD(I)        = [M:YSOH5]PRECOD(LCON)
      [M:SOH4]PCK(I)           = [M:YSOH5]PCK(LCON)           : [M:SOH4]PCKCAP(I)      = [M:YSOH5]PCKCAP(LCON)      : [M:SOH4]BPCSALPRI(I)     = [M:YSOH5]BPCSALPRI(LCON)
      [M:SOH4]DEMDLVHOU(I)     = [M:YSOH5]DEMDLVHOU(LCON)     : [M:SOH4]MAXDLVDAT(I)   = [M:YSOH5]MAXDLVDAT(LCON)   : [M:SOH4]MAXDLVHOU(I)     = [M:YSOH5]MAXDLVHOU(LCON)
      [M:SOH4]USELIMDAT(I)     = [M:YSOH5]USELIMDAT(LCON)     : [M:SOH4]CCE1(I)        = [M:YSOH5]CCE1(LCON)        : [M:SOH4]CCE2(I)          = [M:YSOH5]CCE2(LCON)
      [M:SOH4]CCE3(I)          = [M:YSOH5]CCE3(LCON)          : [M:SOH4]CCE4(I)        = [M:YSOH5]CCE4(LCON)        : [M:SOH4]CCE5(I)          = [M:YSOH5]CCE5(LCON)
      [M:SOH4]CCE6(I)          = [M:YSOH5]CCE6(LCON)          : [M:SOH4]CCE7(I)        = [M:YSOH5]CCE7(LCON)        : [M:SOH4]CCE8(I)          = [M:YSOH5]CCE8(LCON)
      [M:SOH4]CCE9(I)          = [M:YSOH5]CCE9(LCON)          : [M:SOH4]CCE10(I)       = [M:YSOH5]CCE10(LCON)       : [M:SOH4]CCE11(I)         = [M:YSOH5]CCE11(LCON)
      [M:SOH4]CCE12(I)         = [M:YSOH5]CCE12(LCON)         : [M:SOH4]CCE13(I)       = [M:YSOH5]CCE13(LCON)       : [M:SOH4]CCE14(I)         = [M:YSOH5]CCE14(LCON)
      [M:SOH4]CCE15(I)         = [M:YSOH5]CCE15(LCON)         : [M:SOH4]CCE16(I)       = [M:YSOH5]CCE16(LCON)       : [M:SOH4]CCE17(I)         = [M:YSOH5]CCE17(LCON)
      [M:SOH4]CCE18(I)         = [M:YSOH5]CCE18(LCON)         : [M:SOH4]CCE19(I)       = [M:YSOH5]CCE19(LCON)       : [M:SOH4]CCE20(I)         = [M:YSOH5]CCE20(LCON)
      [M:SOH4]DEMSTA(I)        = [M:YSOH5]DEMSTA(LCON)
