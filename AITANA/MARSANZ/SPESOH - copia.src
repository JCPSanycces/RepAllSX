$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif

Case ACTION
  When "OUVRE"        :   Gosub OUVRE
  When "OUVRE_BOITE"  :   Gosub OUVRE_BOITE
  When "SETBOUT"      :   Gosub SETBOUT
  When "AVANTBOUT"    :   Gosub AVANTBOUT
  When "STYLE"        :   Gosub STYLE
  When "LIENS"        :   Gosub LIENS
  When "VERIF_CRE"    :   Gosub VERIF_CRE
  When "VERIF_MOD"    :   Gosub VERIF_MOD
  When "APRES_CRE"    :   Gosub APRES_CRE
  When "APRES_MOD"    :   Gosub APRES_MOD
  When "AP_ANNULE"    :   Gosub AP_ANNULE
  When "SEL_TABLE"    :   Gosub SEL_TABLE
  When "VERF_TABLE"   :   Gosub VERF_TABLE
  When "FIN"          :   Gosub FIN
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
Global Integer GCOMPSTA : GCOMPSTA=1    # 1 = componentes visibles  ; 0 = componentes ocultos
Global Integer GTIPOPED : GTIPOPED=0    # 0 = pedido desde cero     ; 1 = pedido desde presupuesto    ; 2 = pedido desde borrador

  If !clalev([F:ITM0]) Then   : Local File ITMMASTER    [F:ITM0] : Endif
  If !clalev([F:ITM2]) Then   : Local File ITMMASTER    [F:ITM2] : Endif
  If !clalev([F:ITM3]) Then   : Local File ITMMASTER    [F:ITM3] : Endif
  If !clalev([F:ITM9]) Then   : Local File ITMMASTER    [F:ITM9] : Endif
  If !clalev([F:ITS0]) Then   : Local File ITMSALES     [F:ITS0] : Endif
  If !clalev([F:ITS1]) Then   : Local File ITMSALES     [F:ITS1] : Endif
  If !clalev([F:SPL0]) Then   : Local File SPRICLIST    [F:SPL0] : Endif
  If !clalev([F:BOH0]) Then   : Local File BOM          [F:BOH0] : Endif
  If !clalev([F:BOD0]) Then   : Local File BOMD         [F:BOD0] : Endif
  If !clalev([F:BOD1]) Then   : Local File BOMD         [F:BOD1] : Endif
  If !clalev([F:BOD2]) Then   : Local File BOMD         [F:BOD2] : Endif
  If !clalev([F:YCC0]) Then   : Local File YCOLORCOMPO  [F:YCC0] : Endif
  If !clalev([F:YCC1]) Then   : Local File YCOLORCOMPO  [F:YCC1] : Endif
  If !clalev([F:AXX0]) Then   : Local File ATEXTRA      [F:AXX0] : Endif
  If !clalev([F:SQH0]) Then   : Local File SQUOTE       [F:SQH0] : Endif
  If !clalev([F:PMH0]) Then   : Local File YPTOMUEBLESH [F:PMH0] : Endif

Return

##############################################################
$OUVRE_BOITE
#  Global Integer GCOMPSTA : Raz GCOMPSTA    # 1 = componentes visibles  ; 0 = componentes ocultos
#  Global Integer GTIPOPED : GTIPOPED=0      # 0 = pedido desde cero     ; 1 = pedido desde presupuesto    ; 2 = pedido desde borrador
Return

##############################################################
$SETBOUT
  # MA01
  Gosub COLOREA_LINEAS
  # MA01
  If GREP = "C" or GREP = "M" or GREP = "A" Then
    Grizo [M:SOH4]YOMCAMPOS
  Else
    Actzo [M:SOH4]YOMCAMPOS
  Endif

Return

##############################################################
$AVANTBOUT
  Case BOUT
    When "2" Then
      # al generar la entrega debe de rellenar el campo lote con la misma información que el campo color
      Local Integer LCON
      If !clalev([F:SOQ0]) Then : Local File SORDERQ [F:SOQ0] : Endif
      For LCON = 0 To [M:SOH4]NBLIG - 1
        Read [F:SOQ0]SOQ0 = [M:SOH0]SOHNUM;[M:SOH4]SOPLIN(LCON);[M:SOH4]SOPLIN(LCON)
        If !fstat Then
          Read [F:ITM2]ITM0 = [F:SOQ0]ITMREF
          If !fstat Then
            If [F:ITM2]LOTMGTCOD <> 1 Then
              Trbegin [F:SOQ0]
              [F:SOQ0]LOT = [M:SOH4]YCOLOR(LCON)
              Rewrite [F:SOQ0]
              If !fstat Then
                Commit
              Else
                Rollback
              Endif
            Endif
          Endif
        Endif
      Next
  Endcase
Return

##############################################################
$STYLE
  If [M:SOH3]SQHNUM <> "" Then
    GTIPOPED = 1                                  # el pedido viene de un presupuesto
    Read [F:SQH0]SQH0 = [F:SOH]SQHNUM
    If !fstat Then
      If [F:SQH0]YIDBORRADOR <> "" Then
        GTIPOPED = 2                              # el pedido viene de un borrador
      Endif
    Endif
  Else
    GTIPOPED = 0
  Endif

If GTIPOPED = 2 Then
#  Gosub SET_GROPRI
#  Gosub CARGA_COLOR_COMP
##  Gosub MOSTRAR_COMPONENTES
##  Gosub RELLENA_AUX
#  Gosub CALC_BLOQUE_MARGEN
#  Gosub RELLENA_TABLA_COLOR_COMP
##  Gosub OCULTAR_COMPONENTES
Endif
Return

##############################################################
$LIENS
  GCOMPSTA=1
Return

##############################################################
$VERIF_CRE
  Gosub CAMBIA_TIPO_COMPONENTE
#  Gosub RELLENA_AUX
Return

##############################################################
$VERIF_MOD
If GTIPOPED = 2 Then
#  Gosub MOSTRAR_COMPONENTES
#  Gosub RELLENA_AUX
  Gosub RELLENA_TABLA_COLOR_COMP
  Gosub CAMBIA_TIPO_COMPONENTE
  Gosub OCULTAR_COMPONENTES
Else
  Gosub RELLENA_TABLA_COLOR_COMP
Endif
Return

