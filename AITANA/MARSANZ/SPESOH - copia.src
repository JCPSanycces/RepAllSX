##  If !clalev([F:YCC1]) Then : Local File YCOLORCOMPO  [F:YCC1] : Endif
##  Filter [F:YCC1] Where IDBORRADOR = [M:SOH3]SQHNUM
##  Filter [F:YCC1]
##  Close Local File [SQH0],[YCC1]
##Endif
#
#
#          [M:YSOH5]YCOLORCOMP(I)    = [M:SOH4]YCOLORCOMP(LCON)
#          [M:YSOH5]SOPLIN(I)        = [M:SOH4]SOPLIN(LCON) + I
#          [M:YSOH5]IDREG(I)         = I + 1
#          [M:YSOH5]CREFLG(I)        = I + 1
#          [M:YSOH5]UPDFLG(I)        = 0
#          I += 1
#        Endif
#      Next
#      Filter [F:BOD0]
    Elsif [M:SOH4]YTIPO(LCON) = 7
      If [M:SOH4]YCOLORCOMP(LCON) <> "" Then
        [M:YSOH5]YCOLORCOMP([M:SOH4]IDREG(LCON) - 1) = [M:SOH4]YCOLORCOMP(LCON)
        Affzo [M:YSOH5]YCOLORCOMP([M:SOH4]IDREG(LCON) - 1)
      Else
        Read [F:YCC0]YCC0 = [M:SOH0]SOHNUM;[M:SOH4]SOPLIN(LCON)
        If !fstat Then
          [M:YSOH5]YCOLORCOMP([M:SOH4]IDREG(LCON) - 1) = [F:YCC0]YCOLORCOMP
          Affzo [M:YSOH5]YCOLORCOMP([M:SOH4]IDREG(LCON) - 1)
        Endif
      Endif
#      [M:YSOH5]LINTYP([M:SOH4]IDREG(LCON) - 1) = 7
      [M:YSOH5]LINTYP([M:SOH4]IDREG(LCON)) = 7
    Endif
  Next
  [M:YSOH5]NBLIG = I
  Affzo [M:YSOH5]

  For LCON = 0  To [M:YSOH5]NBLIG - 1
    Read [F:YCC0]YCC0 = [M:SOH0]SOHNUM;[M:YSOH5]SOPLIN(LCON)
    If !fstat Then
      [M:YSOH5]YCOLORCOMP(LCON) = [F:YCC0]YCOLORCOMP
      Affzo [M:YSOH5]YCOLORCOMP(LCON)
    Endif
  Next
Else
  For LCON = 0 To [M:SOH4]NBLIG-1
    If [M:SOH4]YTIPO(LCON) <> 6 and [M:SOH4]YTIPO(LCON) <> 7 Then
      [M:YSOH5]NUMLIG(I)        = [M:SOH4]NUMLIG(LCON)        : [M:YSOH5]YZ(I)          = [M:SOH4]YZ(LCON)          : [M:YSOH5]YM(I)            = [M:SOH4]YM(LCON)
      [M:YSOH5]YTIPO(I)         = [M:SOH4]YTIPO(LCON)         : [M:YSOH5]ITMREF(I)      = [M:SOH4]ITMREF(LCON)      : [M:YSOH5]ITMDES(I)        = [M:SOH4]ITMDES(LCON)
      [M:YSOH5]ITMDES1(I)       = [M:SOH4]ITMDES1(LCON)       : [M:YSOH5]ECCVALMAJ(I)   = [M:SOH4]ECCVALMAJ(LCON)   : [M:YSOH5]ECCVALMIN(I)     = [M:SOH4]ECCVALMIN(LCON)
      [M:YSOH5]DSTOFCY(I)       = [M:SOH4]DSTOFCY(LCON)       : [M:YSOH5]LINREVNUM(I)   = [M:SOH4]LINREVNUM(LCON)   : [M:YSOH5]LINREVDAT(I)     = [M:SOH4]LINREVDAT(LCON)
      [M:YSOH5]SAU(I)           = [M:SOH4]SAU(LCON)           : [M:YSOH5]QTY(I)         = [M:SOH4]QTY(LCON)         : [M:YSOH5]SAUSTUCOE(I)     = [M:SOH4]SAUSTUCOE(LCON)
      [M:YSOH5]STU(I)           = [M:SOH4]STU(LCON)           : [M:YSOH5]ALLQTY(I)      = [M:SOH4]ALLQTY(LCON)      : [M:YSOH5]SHTQTY(I)        = [M:SOH4]SHTQTY(LCON)
      [M:YSOH5]WALLQTY(I)       = [M:SOH4]WALLQTY(LCON)       : [M:YSOH5]DALLTYP(I)     = [M:SOH4]DALLTYP(LCON)     : [M:YSOH5]TDLQTY(I)        = [M:SOH4]TDLQTY(LCON)
      [M:YSOH5]GROPRI(I)        = [M:SOH4]GROPRI(LCON)        : [M:YSOH5]YGROPRI(I)     = [M:SOH4]YGROPRI(LCON)     : [M:YSOH5]DISCRGVAL1(I)    = [M:SOH4]DISCRGVAL1(LCON)
      [M:YSOH5]DISCRGVAL2(I)    = [M:SOH4]DISCRGVAL2(LCON)    : [M:YSOH5]DISCRGVAL3(I)  = [M:SOH4]DISCRGVAL3(LCON)  : [M:YSOH5]DISCRGVAL4(I)    = [M:SOH4]DISCRGVAL4(LCON)
      [M:YSOH5]DISCRGVAL5(I)    = [M:SOH4]DISCRGVAL5(LCON)    : [M:YSOH5]DISCRGVAL6(I)  = [M:SOH4]DISCRGVAL6(LCON)
      [M:YSOH5]NETPRI(I)        = [M:SOH4]NETPRI(LCON)
      [M:YSOH5]CPRPRI(I)        = [M:SOH4]CPRPRI(LCON)        : [M:YSOH5]PFM(I)         = [M:SOH4]PFM(LCON)         : [M:YSOH5]VACITM1(I)       = [M:SOH4]VACITM1(LCON)
      [M:YSOH5]VACITM2(I)       = [M:SOH4]VACITM2(LCON)       : [M:YSOH5]VACITM3(I)     = [M:SOH4]VACITM3(LCON)     : [M:YSOH5]DINVCND(I)       = [M:SOH4]DINVCND(LCON)
      [M:YSOH5]DINVCNDISCHG(I)  = [M:SOH4]DINVCNDISCHG(LCON)  : [M:YSOH5]DINVCNDPREV(I) = [M:SOH4]DINVCNDPREV(LCON) : [M:YSOH5]DINVCNDTODEL(I)  = [M:SOH4]DINVCNDTODEL(LCON)
      [M:YSOH5]DINVCNDTODIS(I)  = [M:SOH4]DINVCNDTODIS(LCON)  : [M:YSOH5]DINVCNDTOUPD(I)= [M:SOH4]DINVCNDTOUPD(LCON): [M:YSOH5]DINVCNDUPDK(I)   = [M:SOH4]DINVCNDUPDK(LCON)
      [M:YSOH5]SVICUUID(I)      = [M:SOH4]SVICUUID(LCON)      : [M:YSOH5]SSTCOD(I)      = [M:SOH4]SSTCOD(LCON)      : [M:YSOH5]DPJT(I)          = [M:SOH4]DPJT(LCON)
      [M:YSOH5]DPREOPP(I)       = [M:SOH4]DPREOPP(LCON)       : [M:YSOH5]REP1(I)        = [M:SOH4]REP1(LCON)        : [M:YSOH5]REPRAT1(I)       = [M:SOH4]REPRAT1(LCON)
      [M:YSOH5]REP2(I)          = [M:SOH4]REP2(LCON)          : [M:YSOH5]REPRAT2(I)     = [M:SOH4]REPRAT2(LCON)     : [M:YSOH5]REPCOE(I)        = [M:SOH4]REPCOE(LCON)
      [M:YSOH5]DDEMDLVDAT(I)    = [M:SOH4]DDEMDLVDAT(LCON)    : [M:YSOH5]DDAYLTI(I)     = [M:SOH4]DDAYLTI(LCON)     : [M:YSOH5]DSHIDAT(I)       = [M:SOH4]DSHIDAT(LCON)
      [M:YSOH5]EXTDLVDAT(I)     = [M:SOH4]EXTDLVDAT(LCON)     : [M:YSOH5]DBPAADD(I)     = [M:SOH4]DBPAADD(LCON)     : [M:YSOH5]CNDNAM(I)        = [M:SOH4]CNDNAM(LCON)
      [M:YSOH5]USEPLC(I)        = [M:SOH4]USEPLC(LCON)        : [M:YSOH5]DDLVPIO(I)     = [M:SOH4]DDLVPIO(LCON)     : [M:YSOH5]DDRN(I)          = [M:SOH4]DDRN(LCON)
      [M:YSOH5]DMDL(I)          = [M:SOH4]DMDL(LCON)          : [M:YSOH5]DBPTNUM(I)     = [M:SOH4]DBPTNUM(LCON)     : [M:YSOH5]PRECOD(I)        = [M:SOH4]PRECOD(LCON)
      [M:YSOH5]PCK(I)           = [M:SOH4]PCK(LCON)           : [M:YSOH5]PCKCAP(I)      = [M:SOH4]PCKCAP(LCON)      : [M:YSOH5]BPCSALPRI(I)     = [M:SOH4]BPCSALPRI(LCON)
      [M:YSOH5]DEMDLVHOU(I)     = [M:SOH4]DEMDLVHOU(LCON)     : [M:YSOH5]MAXDLVDAT(I)   = [M:SOH4]MAXDLVDAT(LCON)   : [M:YSOH5]MAXDLVHOU(I)     = [M:SOH4]MAXDLVHOU(LCON)
      [M:YSOH5]USELIMDAT(I)     = [M:SOH4]USELIMDAT(LCON)     : [M:YSOH5]CCE1(I)        = [M:SOH4]CCE1(LCON)        : [M:YSOH5]CCE2(I)          = [M:SOH4]CCE2(LCON)
      [M:YSOH5]CCE3(I)          = [M:SOH4]CCE3(LCON)          : [M:YSOH5]CCE4(I)        = [M:SOH4]CCE4(LCON)        : [M:YSOH5]CCE5(I)          = [M:SOH4]CCE5(LCON)
      [M:YSOH5]CCE6(I)          = [M:SOH4]CCE6(LCON)          : [M:YSOH5]CCE7(I)        = [M:SOH4]CCE7(LCON)        : [M:YSOH5]CCE8(I)          = [M:SOH4]CCE8(LCON)
      [M:YSOH5]CCE9(I)          = [M:SOH4]CCE9(LCON)          : [M:YSOH5]CCE10(I)       = [M:SOH4]CCE10(LCON)       : [M:YSOH5]CCE11(I)         = [M:SOH4]CCE11(LCON)
      [M:YSOH5]CCE12(I)         = [M:SOH4]CCE12(LCON)         : [M:YSOH5]CCE13(I)       = [M:SOH4]CCE13(LCON)       : [M:YSOH5]CCE14(I)         = [M:SOH4]CCE14(LCON)
      [M:YSOH5]CCE15(I)         = [M:SOH4]CCE15(LCON)         : [M:YSOH5]CCE16(I)       = [M:SOH4]CCE16(LCON)       : [M:YSOH5]CCE17(I)         = [M:SOH4]CCE17(LCON)
      [M:YSOH5]CCE18(I)         = [M:SOH4]CCE18(LCON)         : [M:YSOH5]CCE19(I)       = [M:SOH4]CCE19(LCON)       : [M:YSOH5]CCE20(I)         = [M:SOH4]CCE20(LCON)
      [M:YSOH5]DEMSTA(I)        = [M:SOH4]DEMSTA(LCON)
      [M:YSOH5]LINORDNOT(I)     = [M:SOH4]LINORDNOT(LCON)     : [M:YSOH5]LINORDATI(I)   = [M:SOH4]LINORDATI(LCON)   : [M:YSOH5]LINPFM(I)        = [M:SOH4]LINPFM(LCON)
      [M:YSOH5]DETSQHNUM(I)     = [M:SOH4]DETSQHNUM(LCON)
      If [M:SOH4]YTIPO(LCON) = 1 or [M:SOH4]YTIPO(LCON) = 2 or [M:SOH4]YTIPO(LCON) = 3 Then   # si es artículo, zona o subzona -> lintyp = 1 = normal
        [M:YSOH5]LINTYP(I)      = 1
      Elsif [M:SOH4]YTIPO(LCON) = 4 Then                                                      # si es kit comercial -> lintyp = 2 = compuesto kit
        [M:YSOH5]LINTYP(I)      = 2
      Endif
      [M:YSOH5]FOCFLG(I)        = [M:SOH4]FOCFLG(LCON)
      [M:YSOH5]ORILIN(I)        = [M:SOH4]ORILIN(LCON)        : [M:YSOH5]SOQSTA(I)      = [M:SOH4]SOQSTA(LCON)      : [M:YSOH5]DCCLREN(I)       = [M:SOH4]DCCLREN(LCON)
      [M:YSOH5]DCCLDAT(I)       = [M:SOH4]DCCLDAT(LCON)       : [M:YSOH5]SOPLIN(I)      = [M:SOH4]SOPLIN(LCON)      : [M:YSOH5]QTYSTU(I)        = [M:SOH4]QTYSTU(LCON)
      [M:YSOH5]ALLQTYSTU(I)     = [M:SOH4]ALLQTYSTU(LCON)     : [M:YSOH5]WALLQTYSTU(I)  = [M:SOH4]WALLQTYSTU(LCON)  : [M:YSOH5]DLVQTY(I)        = [M:SOH4]DLVQTY(LCON)
      [M:YSOH5]INVQTY(I)        = [M:SOH4]INVQTY(LCON)        : [M:YSOH5]SHTQTYSTU(I)   = [M:SOH4]SHTQTYSTU(LCON)   : [M:YSOH5]ODLQTY(I)        = [M:SOH4]ODLQTY(LCON)
      [M:YSOH5]LPRQTY(I)        = [M:SOH4]LPRQTY(LCON)        : [M:YSOH5]OPRQTY(I)      = [M:SOH4]OPRQTY(LCON)      : [M:YSOH5]PREQTY(I)        = [M:SOH4]PREQTY(LCON)
      [M:YSOH5]PRIREN(I)        = [M:SOH4]PRIREN(LCON)        : [M:YSOH5]DISCRGREN1(I)  = [M:SOH4]DISCRGREN1(LCON)  : [M:YSOH5]DISCRGREN2(I)    = [M:SOH4]DISCRGREN2(LCON)
      [M:YSOH5]DISCRGREN3(I)    = [M:SOH4]DISCRGREN3(LCON)    : [M:YSOH5]DISCRGREN4(I)  = [M:SOH4]DISCRGREN4(LCON)  : [M:YSOH5]DISCRGREN5(I)    = [M:SOH4]DISCRGREN5(LCON)
      [M:YSOH5]DISCRGREN6(I)    = [M:SOH4]DISCRGREN6(LCON)
      [M:YSOH5]VAT1(I)          = [M:SOH4]VAT1(LCON)          : [M:YSOH5]VAT2(I)        = [M:SOH4]VAT2(LCON)
      [M:YSOH5]VAT3(I)          = [M:SOH4]VAT3(LCON)          : [M:YSOH5]CLCAMT1(I)     = [M:SOH4]CLCAMT1(LCON)     : [M:YSOH5]CLCAMT2(I)       = [M:SOH4]CLCAMT2(LCON)
      [M:YSOH5]LINDLRNOT(I)     = [M:SOH4]LINDLRNOT(LCON)     : [M:YSOH5]LINDLRATI(I)   = [M:SOH4]LINDLRATI(LCON)   : [M:YSOH5]LININRSCHNOT(I)  = [M:SOH4]LININRSCHNOT(LCON)
      [M:YSOH5]LININRSCHATI(I)  = [M:SOH4]LININRSCHATI(LCON)  : [M:YSOH5]YALLQTY(I)     = [M:SOH4]YALLQTY(LCON)     : [M:YSOH5]YQTY(I)          = [M:SOH4]YQTY(LCON)
      [M:YSOH5]YSHTQTY(I)       = [M:SOH4]YSHTQTY(LCON)       : [M:YSOH5]TALLQTYSTU(I)  = [M:SOH4]TALLQTYSTU(LCON)  : [M:YSOH5]TALLQTY(I)       = [M:SOH4]TALLQTY(LCON)
      [M:YSOH5]YSOQSTA(I)       = [M:SOH4]YSOQSTA(LCON)       : [M:YSOH5]STOMGTCOD(I)   = [M:SOH4]STOMGTCOD(LCON)   : [M:YSOH5]TSICOD1(I)       = [M:SOH4]TSICOD1(LCON)
      [M:YSOH5]TSICOD2(I)       = [M:SOH4]TSICOD2(LCON)       : [M:YSOH5]TSICOD3(I)     = [M:SOH4]TSICOD3(LCON)     : [M:YSOH5]TSICOD4(I)       = [M:SOH4]TSICOD4(LCON)
      [M:YSOH5]TSICOD5(I)       = [M:SOH4]TSICOD5(LCON)       : [M:YSOH5]LOT(I)         = [M:SOH4]LOT(LCON)         : [M:YSOH5]LOC(I)           = [M:SOH4]LOC(LCON)
      [M:YSOH5]STA(I)           = [M:SOH4]STA(LCON)           : [M:YSOH5]GRPFLG(I)      = [M:SOH4]GRPFLG(LCON)      : [M:YSOH5]SQDLIN(I)        = [M:SOH4]SQDLIN(LCON)
      [M:YSOH5]NETPRINOT(I)     = [M:SOH4]NETPRINOT(LCON)     : [M:YSOH5]NETPRIATI(I)   = [M:SOH4]NETPRIATI(LCON)   : [M:YSOH5]SOQTEX(I)        = [M:SOH4]SOQTEX(LCON)
      [M:YSOH5]ANCSOQTEX(I)     = [M:SOH4]ANCSOQTEX(LCON)     : [M:YSOH5]ITMREFBPC(I)   = [M:SOH4]ITMREFBPC(LCON)   : [M:YSOH5]INVFLG(I)        = [M:SOH4]INVFLG(LCON)
      [M:YSOH5]YDSHIDAT(I)      = [M:SOH4]YDSHIDAT(LCON)      : [M:YSOH5]WIPFLG(I)      = [M:SOH4]WIPFLG(LCON)      : [M:YSOH5]OCNPRNBOM(I)     = [M:SOH4]OCNPRNBOM(LCON)
      [M:YSOH5]NDEPRNBOM(I)     = [M:SOH4]NDEPRNBOM(LCON)     : [M:YSOH5]INVPRNBOM(I)   = [M:SOH4]INVPRNBOM(LCON)   : [M:YSOH5]CQTY(I)          = [M:SOH4]CQTY(LCON)
      [M:YSOH5]IMPNUMLIG(I)     = [M:SOH4]IMPNUMLIG(LCON)     : [M:YSOH5]CONNUM(I)      = [M:SOH4]CONNUM(LCON)      : [M:YSOH5]TDLQTYSTU(I)     = [M:SOH4]TDLQTYSTU(LCON)
      [M:YSOH5]DACSAUCOE(I)     = [M:SOH4]DACSAUCOE(LCON)     : [M:YSOH5]POPLIN(I)      = [M:SOH4]POPLIN(LCON)      : [M:YSOH5]RERBPCFLG(I)     = [M:SOH4]RERBPCFLG(LCON)
      [M:YSOH5]DLBQTYSTU(I)     = [M:SOH4]DLBQTYSTU(LCON)     : [M:YSOH5]DSPLINFLG(I)   = [M:SOH4]DSPLINFLG(LCON)   : [M:YSOH5]DSPLINWEI(I)     = [M:SOH4]DSPLINWEI(LCON)
      [M:YSOH5]DSPLINVOL(I)     = [M:SOH4]DSPLINVOL(LCON)     : [M:YSOH5]PTOCOD(I)      = [M:SOH4]PTOCOD(LCON)      : [M:YSOH5]CTMFLG(I)        = [M:SOH4]CTMFLG(LCON)
      [M:YSOH5]YSTOMGTCOD(I)    = [M:SOH4]YSTOMGTCOD(LCON)    : [M:YSOH5]FOCNUMLIG(I)   = [M:SOH4]FOCNUMLIG(LCON)   : [M:YSOH5]WUPDAPPFLG(I)    = [M:SOH4]WUPDAPPFLG(LCON)
      [M:YSOH5]DLVFLG(I)        = [M:SOH4]DLVFLG(LCON)
      [M:YSOH5]YCOLOR(I)        = [M:SOH4]YCOLOR(LCON)
#      [M:YSOH5]YCOLORCOMP(I)    = [M:SOH4]YCOLORCOMP(LCON)
      [M:YSOH5]IDREG(I)         = I + 1
      [M:YSOH5]CREFLG(I)        = I + 1
      [M:YSOH5]UPDFLG(I)        = 0
      [M:YSOH5]FMI(I)           = 1
      I += 1
    Elsif [M:SOH4]YTIPO(LCON) = 6
      [M:YSOH5]NUMLIG(I)        = [M:SOH4]NUMLIG(LCON)        : [M:YSOH5]YZ(I)          = [M:SOH4]YZ(LCON)          : [M:YSOH5]YM(I)            = [M:SOH4]YM(LCON)
      [M:YSOH5]YTIPO(I)         = [M:SOH4]YTIPO(LCON)         : [M:YSOH5]ITMREF(I)      = [M:SOH4]ITMREF(LCON)      : [M:YSOH5]ITMDES(I)        = [M:SOH4]ITMDES(LCON)
      [M:YSOH5]ITMDES1(I)       = [M:SOH4]ITMDES1(LCON)       : [M:YSOH5]ECCVALMAJ(I)   = [M:SOH4]ECCVALMAJ(LCON)   : [M:YSOH5]ECCVALMIN(I)     = [M:SOH4]ECCVALMIN(LCON)
      [M:YSOH5]DSTOFCY(I)       = [M:SOH4]DSTOFCY(LCON)       : [M:YSOH5]LINREVNUM(I)   = [M:SOH4]LINREVNUM(LCON)   : [M:YSOH5]LINREVDAT(I)     = [M:SOH4]LINREVDAT(LCON)
      [M:YSOH5]SAU(I)           = [M:SOH4]SAU(LCON)           : [M:YSOH5]QTY(I)         = [M:SOH4]QTY(LCON)         : [M:YSOH5]SAUSTUCOE(I)     = [M:SOH4]SAUSTUCOE(LCON)
      [M:YSOH5]STU(I)           = [M:SOH4]STU(LCON)           : [M:YSOH5]ALLQTY(I)      = [M:SOH4]ALLQTY(LCON)      : [M:YSOH5]SHTQTY(I)        = [M:SOH4]SHTQTY(LCON)
      [M:YSOH5]WALLQTY(I)       = [M:SOH4]WALLQTY(LCON)       : [M:YSOH5]DALLTYP(I)     = [M:SOH4]DALLTYP(LCON)     : [M:YSOH5]TDLQTY(I)        = [M:SOH4]TDLQTY(LCON)
      [M:YSOH5]GROPRI(I)        = [M:SOH4]GROPRI(LCON)        : [M:YSOH5]YGROPRI(I)     = [M:SOH4]YGROPRI(LCON)     : [M:YSOH5]DISCRGVAL1(I)    = [M:SOH4]DISCRGVAL1(LCON)
      [M:YSOH5]DISCRGVAL2(I)    = [M:SOH4]DISCRGVAL2(LCON)    : [M:YSOH5]DISCRGVAL3(I)  = [M:SOH4]DISCRGVAL3(LCON)  : [M:YSOH5]DISCRGVAL4(I)    = [M:SOH4]DISCRGVAL4(LCON)
      [M:YSOH5]DISCRGVAL5(I)    = [M:SOH4]DISCRGVAL5(LCON)    : [M:YSOH5]DISCRGVAL6(I)  = [M:SOH4]DISCRGVAL6(LCON)
      [M:YSOH5]NETPRI(I)        = [M:SOH4]NETPRI(LCON)
      [M:YSOH5]CPRPRI(I)        = [M:SOH4]CPRPRI(LCON)        : [M:YSOH5]PFM(I)         = [M:SOH4]PFM(LCON)         : [M:YSOH5]VACITM1(I)       = [M:SOH4]VACITM1(LCON)
      [M:YSOH5]VACITM2(I)       = [M:SOH4]VACITM2(LCON)       : [M:YSOH5]VACITM3(I)     = [M:SOH4]VACITM3(LCON)     : [M:YSOH5]DINVCND(I)       = [M:SOH4]DINVCND(LCON)
      [M:YSOH5]DINVCNDISCHG(I)  = [M:SOH4]DINVCNDISCHG(LCON)  : [M:YSOH5]DINVCNDPREV(I) = [M:SOH4]DINVCNDPREV(LCON) : [M:YSOH5]DINVCNDTODEL(I)  = [M:SOH4]DINVCNDTODEL(LCON)
