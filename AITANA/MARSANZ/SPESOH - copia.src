      [M:SOH4]DACSAUCOE(I)     = [M:YSOH5]DACSAUCOE(LCON)     : [M:SOH4]POPLIN(I)      = [M:YSOH5]POPLIN(LCON)      : [M:SOH4]RERBPCFLG(I)     = [M:YSOH5]RERBPCFLG(LCON)
