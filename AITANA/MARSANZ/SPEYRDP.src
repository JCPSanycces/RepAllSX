# YMA01 - Presupuestos de muebles - PANTALLA PETICIÓN DE LÍNEA PARA DUPLICAR
# Fecha inicio YMA01: 10/10/2019
# Desarrollador: JCH
# Código de desarrollo: YMA01
# Descripción del desarrollo: Pantalla nueva de creación de presupuestos
# Fecha: 10/10/2019
# Codigo Actividad: YMA01
#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"    : Gosub OUVRE
  When "DEBUT"    : Gosub DEBUT
  When "OK"       : Gosub OK
  When "FIN"      : Gosub FIN
  When Default
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
  Gosub ABRIR_TABLAS
Return

##############################################################
$DEBUT
  Raz[YRDP0]
Return

##############################################################
$OK
  GPARAM1(0)=num$([M:YRDP0]NUMLIN)
  Gosub REPETIR_ZONA
  Gosub COLOREA_LINEAS From SPEYPM

#  [M:YPM3]DUPLICAR(nolign-1) = 1
  Gosub LIMPIAR_CHECK_DUPLICAR
  Gosub ACTIVA_DUPLICAR From SPEYPM

#  Affzo [M:YPM3]5

Return

##############################################################
$FIN
  Gosub CERRAR_TABLAS
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ABRIR_TABLAS
  If !clalev([F:TMD0]) Then : Local File YTMPMUEBLES [F:TMD0] : Endif
  If !clalev([F:TMD1]) Then : Local File YTMPMUEBLES [F:TMD1] : Endif
Return

##############################################################
$CERRAR_TABLAS
  If clalev([F:TMD0])  Then : Close Local File       [F:TMD0] : Endif
  If clalev([F:TMD1])  Then : Close Local File       [F:TMD1] : Endif
Return

##############################################################
$REPETIR_ZONA
Local Integer LCON8, LCON9,LCON10, POSICION8, POSICION9 : Raz LCON8, LCON9, LCON10, POSICION8, POSICION9
Local Integer LCONTROL8 : Raz LCONTROL8
Local Integer LS8, LA8 : Raz LS8, LA8

  # inserta en una tabla temporal los registros a duplicar
  Execsql From "5"  Sql "truncate table " + nomap + ".YTMPMUEBLES"
  LCON8 = nolign-1
  Repeat
      Trbegin [TMD0]
      [F:TMD0]NUMLIN    = LCON8
      [F:TMD0]TIPO      = [M:YPM3]TIPO(LCON8)
      [F:TMD0]ITMREF    = [M:YPM3]ITMREF(LCON8)
      [F:TMD0]ITMDES    = [M:YPM3]ITMDES(LCON8)
      [F:TMD0]SAU       = [M:YPM3]SAU(LCON8)
      [F:TMD0]UNIDADES  = [M:YPM3]UNIDADES(LCON8)
      [F:TMD0]GROPRI    = [M:YPM3]GROPRI(LCON8)
      [F:TMD0]DTO1      = [M:YPM3]DTO1(LCON8)
      [F:TMD0]DTO2      = [M:YPM3]DTO2(LCON8)
      [F:TMD0]DTOOCULTO = [M:YPM3]DTOOCULTO(LCON8)
      [F:TMD0]RECOCULTO = [M:YPM3]RECOCULTO(LCON8)
      [F:TMD0]YCOLOR    = [M:YPM3]YCOLOR(LCON8)
      POSICION8 += 1
      LCON8 += 1
      Write [F:TMD0]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
  Until [M:YPM3]TIPO(LCON8) = 3 or LCON8 = ([M:YPM3]NBLIG)
#  Until [M:YPM3]TIPO(LCON8) = [M:YPM3]TIPO(nolign-1) or LCON8 = ([M:YPM3]NBLIG)

  POSICION9 = [M:YRDP0]NUMLIN - 1

  # desplaza todos los registros desde la posición indicada hacia abajo
  For LCON8 = [M:YPM3]NBLIG-1 To (POSICION9-1) Step -1
    LS8 = LCON8 + POSICION8
    LA8 = LCON8
    [M:YPM3]TIPO(LS8)      = [M:YPM3]TIPO(LA8)
    [M:YPM3]ITMREF(LS8)    = [M:YPM3]ITMREF(LA8)
    [M:YPM3]ITMDES(LS8)    = [M:YPM3]ITMDES(LA8)
    [M:YPM3]SAU(LS8)       = [M:YPM3]SAU(LA8)
    [M:YPM3]UNIDADES(LS8)  = [M:YPM3]UNIDADES(LA8)
    [M:YPM3]GROPRI(LS8)    = [M:YPM3]GROPRI(LA8)
    [M:YPM3]DTO1(LS8)      = [M:YPM3]DTO1(LA8)
    [M:YPM3]DTO2(LS8)      = [M:YPM3]DTO2(LA8)
    [M:YPM3]DTOOCULTO(LS8) = [M:YPM3]DTOOCULTO(LA8)
    [M:YPM3]RECOCULTO(LS8) = [M:YPM3]RECOCULTO(LA8)
    [M:YPM3]YCOLOR(LS8)    = [M:YPM3]YCOLOR(LA8)
    [M:YPM3]NUMLIN(LS8)    = ([M:YPM3]NUMLIN(LA8) + ((POSICION8 + 1) * 1000))
    [M:YPM3]UPDFLG(LS8)    = 1
    LCONTROL8 += 1
  Next

  [M:YPM3]NBLIG = [M:YPM3]NBLIG + POSICION8

  # vacía tantas líneas como haya que ańadir a partir de la posición indicada
  For LCON8 = POSICION9 To [M:YPM3]NBLIG - (LCONTROL8 + 1)
    [M:YPM3]TIPO(LCON8)      = 0
    [M:YPM3]ITMREF(LCON8)    = ""
    [M:YPM3]ITMDES(LCON8)    = ""
    [M:YPM3]SAU(LCON8)       = ""
    [M:YPM3]UNIDADES(LCON8)  = 0
    [M:YPM3]GROPRI(LCON8)    = 0
    [M:YPM3]DTO1(LCON8)      = 0
    [M:YPM3]DTO2(LCON8)      = 0
    [M:YPM3]DTOOCULTO(LCON8) = 0
    [M:YPM3]RECOCULTO(LCON8) = 0
    [M:YPM3]YCOLOR(LCON8)    = ""
    [M:YPM3]UPDFLG(LCON8)    = 1
  Next

  # rellena los huecos vacíos con los registros a duplicar
  NUM = 0
  For [TMD1]
    [M:YPM3]TIPO(POSICION9 + NUM)       = [F:TMD1]TIPO
    [M:YPM3]ITMREF(POSICION9 + NUM)     = [F:TMD1]ITMREF
    [M:YPM3]ITMDES(POSICION9 + NUM)     = [F:TMD1]ITMDES
    [M:YPM3]SAU(POSICION9 + NUM)        = [F:TMD1]SAU
    [M:YPM3]UNIDADES(POSICION9 + NUM)   = [F:TMD1]UNIDADES
    [M:YPM3]GROPRI(POSICION9 + NUM)     = [F:TMD1]GROPRI
    [M:YPM3]DTO1(POSICION9 + NUM)       = [F:TMD1]DTO1
    [M:YPM3]DTO2(POSICION9 + NUM)       = [F:TMD1]DTO2
    [M:YPM3]DTOOCULTO(POSICION9 + NUM)  = [F:TMD1]DTOOCULTO
    [M:YPM3]RECOCULTO(POSICION9 + NUM)  = [F:TMD1]RECOCULTO
    [M:YPM3]YCOLOR(POSICION9 + NUM)     = [F:TMD1]YCOLOR
    [M:YPM3]NUMLIN(POSICION9 + NUM)     = ((POSICION9 + 1) + NUM) * 1000
    [M:YPM3]UPDFLG(POSICION9 + NUM)     = 1
    NUM += 1
  Next

  For LCON10 = 0 To [M:YPM3]NBLIG-1
    [M:YPM3]DUPLICAR(LCON10) = 1
  Next

Affzo [M:YPM3]5
Return

#############################################################
$LIMPIAR_CHECK_DUPLICAR
Local Integer LCON10 : Raz LCON10

  For LCON10 = 0 To [M:YPM3]NBLIG - 1
    [M:YPM3]DUPLICAR(LCON10) = 1
    Affzo [M:YPM3]DUPLICAR(LCON10)
  Next

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

