$ACTION
Case ACTION
 When default
Endcase
Return

Subprog AM_BPCORD(VALEUR)

If clalev ([ZBPC])=0 : Local File BPCUSTOMER [ZBPC] : Endif
#Infbox "El cliente de la Entrega es " + VALEUR
Read [ZBPC]BPC0 = VALEUR
#Infbox "El cliente  es " + [ZBPC]BPCNUM
#Infbox "El valor del campo  es " + num$([ZBPC]YALBNOVAL)
[M:SDH2]YALBNOVAL = [ZBPC]YALBNOVAL
#Infbox "Valor cambiado"
Affzo [M:SDH2]YALBNOVAL
Close File [ZBPC]

End


