#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "DEBUT"      : Gosub DEBUT
  When "SETBOUT"    : Gosub SETBOUT
  When "BOUTON"     : Gosub BOUTON
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$DEBUT
Global Char     GDOC(50)  : GDOC  = [M:YAC0]YDOCUMENTO
Global Decimal  GLIN      : GLIN  = [M:YAC1]YLINEA(nolign-1)

  Raz [M:YDLD]
#Infbox num$(nolign-1)
  [M:YDLD]YDOCUMENTO  = [M:YAC0]YDOCUMENTO
  [M:YDLD]YNUMPOS     = nolign-1
  [M:YDLD]YLINEA      = [M:YAC1]YLINEA(nolign-1)
  [M:YDLD]YZONA       = [M:YAC1]YZONA(nolign-1)
  [M:YDLD]YMUEBLE     = [M:YAC1]YMUEBLE(nolign-1)
  [M:YDLD]YITMREF     = [M:YAC1]YITMREF(nolign-1)
  [M:YDLD]YITMDES     = [M:YAC1]YITMDES(nolign-1)
  [M:YDLD]YQTY        = [M:YAC1]YQTY(nolign-1)
  [M:YDLD]YCOLOR      = [M:YAC1]YCOLOR(nolign-1)
  [M:YDLD]YTIPO       = [M:YAC1]YTIPO(nolign-1)

  [M:YDLD]YRAL        = [M:YAC1]YRAL(nolign-1)
  [M:YDLD]STU         = [M:YAC1]STU(nolign-1)
  [M:YDLD]YGROPRI     = [M:YAC1]YGROPRI(nolign-1)
  [M:YDLD]NETPRI      = [M:YAC1]NETPRI(nolign-1)
  [M:YDLD]DISCRGVAL1  = [M:YAC1]DISCRGVAL1(nolign-1)
  [M:YDLD]DISCRGVAL2  = [M:YAC1]DISCRGVAL2(nolign-1)
  [M:YDLD]DISCRGVAL3  = [M:YAC1]DISCRGVAL3(nolign-1)
  [M:YDLD]DISCRGVAL4  = [M:YAC1]DISCRGVAL4(nolign-1)
  [M:YDLD]DISCRGVAL5  = [M:YAC1]DISCRGVAL5(nolign-1)
  [M:YDLD]CPY         = [M:YAC1]CPY(nolign-1)
  [M:YDLD]SALFCY      = [M:YAC1]SALFCY(nolign-1)
  [M:YDLD]BPCORD      = [M:YAC1]BPCORD(nolign-1)
  [M:YDLD]QUODAT      = [M:YAC1]QUODAT(nolign-1)
  [M:YDLD]VACITM      = [M:YAC1]VACITM(nolign-1)
  [M:YDLD]PRIREN      = [M:YAC1]PRIREN(nolign-1)
  [M:YDLD]VAT         = [M:YAC1]VAT(nolign-1)
  [M:YDLD]DSPLINFLG   = [M:YAC1]DSPLINFLG(nolign-1)
  [M:YDLD]SAU         = [M:YAC1]SAU(nolign-1)
  [M:YDLD]SAUSTUCOE   = [M:YAC1]SAUSTUCOE(nolign-1)
  [M:YDLD]BPAADD      = [M:YAC1]BPAADD(nolign-1)
  [M:YDLD]STOFCY      = [M:YAC1]STOFCY(nolign-1)
  [M:YDLD]LINTYP      = [M:YAC1]LINTYP(nolign-1)
  [M:YDLD]FOCFLG      = [M:YAC1]FOCFLG(nolign-1)
  [M:YDLD]ORDFLG      = [M:YAC1]ORDFLG(nolign-1)
  [M:YDLD]DSPWEU      = [M:YAC1]DSPWEU(nolign-1)
  [M:YDLD]DSPVOU      = [M:YAC1]DSPVOU(nolign-1)
  [M:YDLD]DLVFLG      = [M:YAC1]DLVFLG(nolign-1)

  [M:YDLD]ORDDAT      = [M:YAC1]ORDDAT(nolign-1)
  [M:YDLD]DEMDLVDAT   = [M:YAC1]DEMDLVDAT(nolign-1)
  [M:YDLD]MAXDLVDAT   = [M:YAC1]MAXDLVDAT(nolign-1)
  [M:YDLD]SHIDAT      = [M:YAC1]SHIDAT(nolign-1)
  [M:YDLD]EXTDLVDAT   = [M:YAC1]EXTDLVDAT(nolign-1)
  [M:YDLD]INVFLG      = [M:YAC1]INVFLG(nolign-1)
  [M:YDLD]DEMSTA      = [M:YAC1]DEMSTA(nolign-1)
  [M:YDLD]DEMNUM      = [M:YAC1]DEMNUM(nolign-1)
  [M:YDLD]STOMGTCOD   = [M:YAC1]STOMGTCOD(nolign-1)
  [M:YDLD]LOT         = [M:YAC1]LOT(nolign-1)
  [M:YDLD]LOC         = [M:YAC1]LOC(nolign-1)
  [M:YDLD]ALLTYP      = [M:YAC1]ALLTYP(nolign-1)
  [M:YDLD]DRN         = [M:YAC1]DRN(nolign-1)
  [M:YDLD]DLVPIO      = [M:YAC1]DLVPIO(nolign-1)
  [M:YDLD]DLVPIOCMP   = [M:YAC1]DLVPIOCMP(nolign-1)
  [M:YDLD]FMI         = [M:YAC1]FMI(nolign-1)
  [M:YDLD]OCNPRNBOM   = [M:YAC1]OCNPRNBOM(nolign-1)
  [M:YDLD]NDEPRNBOM   = [M:YAC1]NDEPRNBOM(nolign-1)
  [M:YDLD]INVPRNBOM   = [M:YAC1]INVPRNBOM(nolign-1)

  [M:YDLD]SOHCAT      = [M:YAC1]SOHCAT(nolign-1)
  [M:YDLD]STRDAT      = [M:YAC1]STRDAT(nolign-1)
  [M:YDLD]ENDDAT      = [M:YAC1]ENDDAT(nolign-1)
  [M:YDLD]BPCINV      = [M:YAC1]BPCINV(nolign-1)
  [M:YDLD]REPCOE      = [M:YAC1]REPCOE(nolign-1)
  [M:YDLD]TSICOD0     = [M:YAC1]TSICOD0(nolign-1)
  [M:YDLD]TSICOD1     = [M:YAC1]TSICOD1(nolign-1)
  [M:YDLD]TSICOD2     = [M:YAC1]TSICOD2(nolign-1)
  [M:YDLD]SOQSTA      = [M:YAC1]SOQSTA(nolign-1)
  [M:YDLD]EXPNUM      = [M:YAC1]EXPNUM(nolign-1)


  Affzo [M:YDLD]YDOCUMENTO,YLINEA,YZONA,YMUEBLE,YITMREF,YQTY,YCOLOR
  Affzo [M:YDLD]YRAL,STU,YGROPRI,NETPRI,DISCRGVAL1,DISCRGVAL2,DISCRGVAL3,DISCRGVAL4,DISCRGVAL5
  Affzo [M:YDLD]CPY,SALFCY,BPCORD,QUODAT,VACITM,PRIREN,VAT,DSPLINFLG,SAU,SAUSTUCOE,BPAADD,STOFCY,LINTYP,FOCFLG,ORDFLG,DSPWEU,DSPVOU,DLVFLG
Return

##############################################################
$SETBOUT
Return

##############################################################
$BOUTON
  Case BOUT
    When "o"
      Local Integer I,LSUMLIN
      For I = 0 To [M:YDLD]NBLIG-1
        LSUMLIN += [M:YDLD]YQTYD(I)
      Next
      If LSUMLIN = [M:YDLD]YQTY Then
        Gosub OK_
      Else
        Call ERREUR("La suma de las l璯eas debe ser igual que la cantidad total") From GESECRAN
        mkstat = 2
      Endif
    When "s"  : Gosub SALIR_
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$OK_
Local Integer LNOL    : LNOL = [M:YAC1]NBLIG
Local Integer K
Local Integer LLINEA  : LLINEA = [M:YDLD]YLINEA
  For K = 0 To [M:YDLD]NBLIG-1
    [M:YAC1]YSELECCION(LNOL)  = 0
    [M:YAC1]YZONA(LNOL)       = [M:YDLD]YZONA
    [M:YAC1]YMUEBLE(LNOL)     = [M:YDLD]YMUEBLE
    LLINEA                    += 10
    [M:YAC1]YLINEA(LNOL)      = LLINEA
    [M:YAC1]YITMREF(LNOL)     = [M:YDLD]YITMREF
    [M:YAC1]YITMDES(LNOL)     = [M:YDLD]YITMDES
    [M:YAC1]YQTY(LNOL)        = [M:YDLD]YQTYD(K)
    [M:YAC1]YCOLOR(LNOL)      = [M:YDLD]YCOLORD(K)
    [M:YAC1]YDIVISION(LNOL)   = 2

    [M:YAC1]YTIPO(LNOL)       = [M:YDLD]YTIPO
    [M:YAC1]YRAL(LNOL)        = [M:YDLD]YRAL
    [M:YAC1]STU(LNOL)         = [M:YDLD]STU
    [M:YAC1]YGROPRI(LNOL)     = [M:YDLD]YGROPRI
    [M:YAC1]NETPRI(LNOL)      = [M:YDLD]NETPRI
    [M:YAC1]DISCRGVAL1(LNOL)  = [M:YDLD]DISCRGVAL1
    [M:YAC1]DISCRGVAL2(LNOL)  = [M:YDLD]DISCRGVAL2
    [M:YAC1]DISCRGVAL3(LNOL)  = [M:YDLD]DISCRGVAL3
    [M:YAC1]DISCRGVAL4(LNOL)  = [M:YDLD]DISCRGVAL4
    [M:YAC1]DISCRGVAL5(LNOL)  = [M:YDLD]DISCRGVAL5
    [M:YAC1]CPY(LNOL)         = [M:YDLD]CPY
    [M:YAC1]SALFCY(LNOL)      = [M:YDLD]SALFCY
    [M:YAC1]BPCORD(LNOL)      = [M:YDLD]BPCORD
    [M:YAC1]QUODAT(LNOL)      = [M:YDLD]QUODAT
    [M:YAC1]VACITM(LNOL)      = [M:YDLD]VACITM
    [M:YAC1]PRIREN(LNOL)      = [M:YDLD]PRIREN
    [M:YAC1]VAT(LNOL)         = [M:YDLD]VAT
    [M:YAC1]DSPLINFLG(LNOL)   = [M:YDLD]DSPLINFLG
    [M:YAC1]SAU(LNOL)         = [M:YDLD]SAU
    [M:YAC1]SAUSTUCOE(LNOL)   = [M:YDLD]SAUSTUCOE
    [M:YAC1]BPAADD(LNOL)      = [M:YDLD]BPAADD
    [M:YAC1]STOFCY(LNOL)      = [M:YDLD]STOFCY
    [M:YAC1]LINTYP(LNOL)      = [M:YDLD]LINTYP
    [M:YAC1]FOCFLG(LNOL)      = [M:YDLD]FOCFLG
    [M:YAC1]ORDFLG(LNOL)      = [M:YDLD]ORDFLG
    [M:YAC1]DSPWEU(LNOL)      = [M:YDLD]DSPWEU
    [M:YAC1]DSPVOU(LNOL)      = [M:YDLD]DSPVOU
    [M:YAC1]DLVFLG(LNOL)      = [M:YDLD]DLVFLG

    [M:YAC1]ORDDAT(LNOL)      = [M:YDLD]ORDDAT
    [M:YAC1]DEMDLVDAT(LNOL)   = [M:YDLD]DEMDLVDAT
    [M:YAC1]MAXDLVDAT(LNOL)   = [M:YDLD]MAXDLVDAT
    [M:YAC1]SHIDAT(LNOL)      = [M:YDLD]SHIDAT
    [M:YAC1]EXTDLVDAT(LNOL)   = [M:YDLD]EXTDLVDAT
    [M:YAC1]INVFLG(LNOL)      = [M:YDLD]INVFLG
    [M:YAC1]DEMSTA(LNOL)      = [M:YDLD]DEMSTA
    [M:YAC1]DEMNUM(LNOL)      = [M:YDLD]DEMNUM
    [M:YAC1]STOMGTCOD(LNOL)   = [M:YDLD]STOMGTCOD
    [M:YAC1]LOT(LNOL)         = [M:YDLD]LOT
    [M:YAC1]LOC(LNOL)         = [M:YDLD]LOC
    [M:YAC1]ALLTYP(LNOL)      = [M:YDLD]ALLTYP
    [M:YAC1]DRN(LNOL)         = [M:YDLD]DRN
    [M:YAC1]DLVPIO(LNOL)      = [M:YDLD]DLVPIO
    [M:YAC1]DLVPIOCMP(LNOL)   = [M:YDLD]DLVPIOCMP
    [M:YAC1]FMI(LNOL)         = [M:YDLD]FMI
    [M:YAC1]OCNPRNBOM(LNOL)   = [M:YDLD]OCNPRNBOM
    [M:YAC1]NDEPRNBOM(LNOL)   = [M:YDLD]NDEPRNBOM
    [M:YAC1]INVPRNBOM(LNOL)   = [M:YDLD]INVPRNBOM

    [M:YAC1]SOHCAT(LNOL)      = [M:YDLD]SOHCAT
    [M:YAC1]STRDAT(LNOL)      = [M:YDLD]STRDAT
    [M:YAC1]ENDDAT(LNOL)      = [M:YDLD]ENDDAT
    [M:YAC1]BPCINV(LNOL)      = [M:YDLD]BPCINV
    [M:YAC1]REPCOE(LNOL)      = [M:YDLD]REPCOE
    [M:YAC1]TSICOD0(LNOL)     = [M:YDLD]TSICOD0
    [M:YAC1]TSICOD1(LNOL)     = [M:YDLD]TSICOD1
    [M:YAC1]TSICOD2(LNOL)     = [M:YDLD]TSICOD2
    [M:YAC1]SOQSTA(LNOL)      = [M:YDLD]SOQSTA
    [M:YAC1]EXPNUM(LNOL)      = [M:YDLD]EXPNUM

    LNOL                      += 1
  Next
  [M:YAC1]NBLIG += K

  Dela [M:YDLD]YNUMPOS,1,[M:YAC1]NBLIG-1 [M:YAC1]NBLIG : [M:YAC1]NBLIG-=1
  Case [M:YAC0]YORDZONA
    When 0,1      : Sorta [M:YAC1]NBLIG [M:YAC1]NBLIG Order By [M:YAC1]YITMREF(indice) Asc
    When 2        : Sorta [M:YAC1]NBLIG [M:YAC1]NBLIG Order By [M:YAC1]YZONA(indice),[M:YAC1]YMUEBLE(indice) Asc
  Endcase
  Affzo [M:YAC1]

  FIN = 1
Return

##############################################################
$SALIR_
  FIN = 1
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Antes del campo 'Cantidad' de la l璯ea
######################################################################################
Subprog AS_YQTYD(VALEUR)
Variable Decimal VALEUR
  [M:YDLD]YITMREFD(nolign-1) = [M:YDLD]YITMREF
  Affzo [M:YDLD]YITMREFD(nolign-1)
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
