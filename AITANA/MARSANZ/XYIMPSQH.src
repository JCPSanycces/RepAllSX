#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "IMP_APRES_CRE"  : Gosub IMP_APRES_CRE
  When "IMP_FERME"      : Gosub IMP_FERME
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$IMP_APRES_CRE
Local Integer LCON
Local Integer LIDREG

#  # rellena los campos YTIPO e YIDREG para los componentes comerciales
#  Filter [F:SQD1] Where SQHNUM = [F:SQH]SQHNUM
#  For [SQD1]
#    If [F:SQD1]YTIPO = 4 Then
#      LIDREG = [F:SQD1]YIDREG
#      Read [F:SQD1] Next
#      While [F:SQD1]YTIPO = 0
#        Trbegin [F:SQD1]
#        [F:SQD1]YTIPO = 5
#        [F:SQD1]YIDREG = LIDREG + 1
#        LIDREG += 1
#        Rewrite [F:SQD1]
#        If !fstat Then
#          Commit
#        Else
#          Rollback
#        Endif
#        Read [F:SQD1] Next
#      Wend
#    Endif
#  Next

  # rellena el campo YCOLOR en la tabla SQUOTED
  If !clalev([F:YCC0]) Then : Local File YCOLORCOMPO  [F:YCC0] : Endif
  If !clalev([F:SQD0]) Then : Local File SQUOTED      [F:SQD0] : Endif
  If !clalev([F:ITM0]) Then : Local File ITMMASTER    [F:ITM0] : Endif
  Filter [F:SQD0] Where SQHNUM = [F:SQH]SQHNUM and YTIPO = 1 and YCOLOR = ""
  For [SQD0]
    Read [F:ITM0]ITM0 = [F:SQD0]ITMREF
    If !fstat Then
      [F:SQD0]YCOLOR = [F:ITM0]YCOLOR
      Trbegin [F:SQD0]
      Rewrite [F:SQD0]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Endif
  Next
  Filter [F:SQD0]
  Close Local File [SQD0],[ITM0],[YCC0]

  # cambia el campo LINTYP para todas las líneas del presupuesto en la tabla SQUOTED
  # (si no lo fuerzo desde aquí los kits comerciales les pone LINTYP=6 aunque en el fichero de importación le indique 1)
  If !clalev([F:SQD1]) Then : Local File SQUOTED      [F:SQD1] : Endif
  Filter [F:SQD1] Where SQHNUM = [F:SQH]SQHNUM and YTIPO = 4
  Read [F:SQD1] First
  If !fstat Then
    [F:SQD1]LINTYP = 1
    Trbegin [F:SQD1]
    Rewrite [F:SQD1]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif
  Filter [F:SQD1]
  Close Local File [SQD1]


  # ańado en la tabla YCOLORCOMPO los datos del presupuesto creado
  If !clalev([F:YCC0]) Then : Local File YCOLORCOMPO  [F:YCC0] : Endif
  If !clalev([F:YCC1]) Then : Local File YCOLORCOMPO  [F:YCC1] : Endif
  Trbegin [F:YCC1]
  Delete [F:YCC1] Where IDBORRADOR = [F:SQH]SQHNUM
  If !fstat Then
    Commit
  Else
    Rollback
  Endif
  Filter [F:YCC0] Where IDBORRADOR = [M:YPM0]IDBORRADOR
  For [YCC0]
    [F:YCC1]IDBORRADOR  = [F:SQH]SQHNUM
    [F:YCC1]TIPODOC     = "PTO"
    [F:YCC1]NUMLIN      = [F:YCC0]NUMLIN
    [F:YCC1]TIPO        = [F:YCC0]TIPO
    [F:YCC1]ITMREF      = [F:YCC0]ITMREF
    [F:YCC1]ITMDES      = [F:YCC0]ITMDES
    [F:YCC1]SAU         = [F:YCC0]SAU
    [F:YCC1]UNIDADES    = [F:YCC0]UNIDADES
    [F:YCC1]DTOOCULTO   = [F:YCC0]DTOOCULTO
#    [F:YCC1]REOCULTO    = [F:YCC0]RECOCULTO
    [F:YCC1]YCOLORCOMP  = [F:YCC0]YCOLORCOMP
    [F:YCC1]YCOLOR      = [F:YCC0]YCOLOR
    [F:YCC1]YIDKIT      = [F:YCC0]YIDKIT
    [F:YCC1]IDREG       = [F:YCC0]IDREG
    Trbegin [F:YCC1]
    Write [F:YCC1]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next
  Filter [F:YCC0]
  Close Local File [YCC0],[YCC1]

  Kill LCON

Return

##############################################################
$IMP_FERME
  If [F:SQH]SQHNUM <> "" Then
    Infbox "Presupuesto creado"-[F:SQH]SQHNUM
  Endif
Return

