#Return

##############################################################
$INSERTA_LINEAS
Local Integer LCON5, LCON6, LCON11, POSICION, NUMREGS : Raz LCON5, LCON6, LCON11, POSICION, NUMREGS
Local Integer LCONTROL : Raz LCONTROL
Local Integer LS, LA : Raz LS, LA
Local Integer LNUMLINEA : Raz LNUMLINEA

  POSICION  = [M:YPM4]LINEA - 1

  # esta variable se utiliza para adir n伹ero de l匤ea en el detalle del borrador
  LNUMLINEA = [M:YPM4]LINEA

  # desplaza todos los registros desde la posici indicada hacia abajo
  For LCON5 = [M:YPM3]NBLIG-1 To POSICION Step -1
    LS = LCON5 + [M:YPM4]NBEMERGE + 2
    LA = LCON5
    [M:YPM3]TIPO(LS)      = [M:YPM3]TIPO(LA)
    [M:YPM3]ITMREF(LS)    = [M:YPM3]ITMREF(LA)
    [M:YPM3]ITMDES(LS)    = [M:YPM3]ITMDES(LA)
    [M:YPM3]SAU(LS)       = [M:YPM3]SAU(LA)
    [M:YPM3]UNIDADES(LS)  = [M:YPM3]UNIDADES(LA)
    [M:YPM3]GROPRI(LS)    = [M:YPM3]GROPRI(LA)
    [M:YPM3]DTO1(LS)      = [M:YPM3]DTO1(LA)
    [M:YPM3]DTO2(LS)      = [M:YPM3]DTO2(LA)
    [M:YPM3]DTOOCULTO(LS) = [M:YPM3]DTOOCULTO(LA)
    [M:YPM3]RECOCULTO(LS) = [M:YPM3]RECOCULTO(LA)
    [M:YPM3]YCOLOR(LS)    = [M:YPM3]YCOLOR(LA)
    [M:YPM3]NUMLIN(LS)    = ([M:YPM3]NUMLIN(LA) + (([M:YPM4]NBEMERGE + 2) * 1000))
    [M:YPM3]UPDFLG(LS)    = 1
    NUMREGS += 1
  Next

  [M:YPM3]NBLIG = [M:YPM3]NBLIG + [M:YPM4]NBEMERGE + 2

  # vac僘 tantas l匤eas como haya que adir a partir de la posici indicada
  For LCON5 = POSICION To (POSICION + ([M:YPM4]NBEMERGE + 2)) - 1
    [M:YPM3]TIPO(LCON5)      = 0
    [M:YPM3]ITMREF(LCON5)    = ""
    [M:YPM3]ITMDES(LCON5)    = ""
    [M:YPM3]SAU(LCON5)       = ""
    [M:YPM3]UNIDADES(LCON5)  = 0
    [M:YPM3]GROPRI(LCON5)    = 0
    [M:YPM3]DTO1(LCON5)      = 0
    [M:YPM3]DTO2(LCON5)      = 0
    [M:YPM3]DTOOCULTO(LCON5) = 0
    [M:YPM3]RECOCULTO(LCON5) = 0
    [M:YPM3]YCOLOR(LCON5)     = ""
    [M:YPM3]UPDFLG(LCON5)    = 1
  Next

  # rellena los dos primeros huecos vac卲s con la zona y la subzona
  For LCON6 = 0 To [M:YPM3]NBLIG - 1
    If [M:YPM3]TIPO(LCON6)      = 0 and LCONTROL = 0 Then
      [M:YPM3]TIPO(LCON6)       = 3
      [M:YPM3]ITMREF(LCON6)     = [M:YPM4]ZONA
      [M:YPM3]ITMDES(LCON6)     = [M:YPM4]DESZONA
      [M:YPM3]SAU(LCON6)        = "UN"
      [M:YPM3]UNIDADES(LCON6)   = 1
      [M:YPM3]DTOOCULTO(LCON6)  = [M:YPM4]DTOOCULTO
      [M:YPM3]RECOCULTO(LCON6)  = [M:YPM4]RECOCULTO
      [M:YPM3]NUMLIN(LCON6)     = LNUMLINEA * 1000
      [M:YPM3]UPDFLG(LCON6)     = 1
      LNUMLINEA += 1
      LCONTROL += 1
    Elsif [M:YPM3]TIPO(LCON6)   = 0 and LCONTROL = 1
      [M:YPM3]TIPO(LCON6)       = 2
      [M:YPM3]ITMREF(LCON6)     = [M:YPM4]SUBZONA
      [M:YPM3]ITMDES(LCON6)     = [M:YPM4]DESSUBZONA
      [M:YPM3]SAU(LCON6)        = "UN"
      [M:YPM3]UNIDADES(LCON6)   = 1
      [M:YPM3]DTOOCULTO(LCON6)  = [M:YPM4]DTOOCULTO
      [M:YPM3]RECOCULTO(LCON6)  = [M:YPM4]RECOCULTO
      [M:YPM3]NUMLIN(LCON6)    = LNUMLINEA * 1000
      [M:YPM3]UPDFLG(LCON6)    = 1
      LNUMLINEA += 1
      LCONTROL += 1
    Elsif LCONTROL = 2
      Break
    Endif
  Next

  # rellena los huecos vac卲s con los art兤ulos de la pantalla emergente
  For LCON5 = 0 To [M:YPM4]NBEMERGE-1
    For LCON6 = 0 To [M:YPM3]NBLIG - 1
      If [M:YPM3]TIPO(LCON6) = 0 Then
        [M:YPM3]TIPO(LCON6)      = [M:YPM4]TIPO(LCON5)
        [M:YPM3]ITMREF(LCON6)    = [M:YPM4]ITMREF(LCON5)
        [M:YPM3]ITMDES(LCON6)    = [M:YPM4]ITMDES(LCON5)
        [M:YPM3]SAU(LCON6)       = [M:YPM4]SAU(LCON5)
        [M:YPM3]UNIDADES(LCON6)  = [M:YPM4]UNIDADES(LCON5)
        [M:YPM3]GROPRI(LCON6)    = [M:YPM4]GROPRI(LCON5)
        [M:YPM3]DTO1(LCON6)      = [M:YPM4]DTO1(LCON5)
        [M:YPM3]DTO2(LCON6)      = [M:YPM4]DTO2(LCON5)
        [M:YPM3]DTOOCULTO(LCON6) = [M:YPM4]DTOOCULTOL(LCON5)
        [M:YPM3]RECOCULTO(LCON6) = [M:YPM4]RECOCULTOL(LCON5)
        [M:YPM3]NUMLIN(LCON6)    = LNUMLINEA * 1000
        [M:YPM3]UPDFLG(LCON6)    = 1
        LNUMLINEA += 1
#        [M:YPM3]NUMLIN(LCON6)    = ([M:YPM3]NUMLIN(LCON6) + ([M:YPM4]NBEMERGE * 1000))
        Break
      Endif
    Next LCON6
  Next LCON5

  For LCON11 = 0 To [M:YPM3]NBLIG-1
    [M:YPM3]DUPLICAR(LCON11) = 1
  Next

Affzo [M:YPM3]5

Return

###############################################################
#$COLOREA_LINEAS
#Local Integer LCON7 : Raz LCON7
#
#  For LCON7 = 0 To [M:YPM3]NBLIG - 1
#    Case [M:YPM3]TIPO(LCON7)
#      When 2 : Chgstl [M:YPM3]NBLIG(LCON7) With "BACKYELLOW"
#      When 3 : Chgstl [M:YPM3]NBLIG(LCON7) With "BACKGREEN"
#    Endcase
#  Next
#
#Return

##############################################################
$SEL_YSELPTOMT
  Case [M:YPM4]TIPO(nolign-1)
    When 1 : Filter [F:ITM3] Where (TCLCOD <> "SUBZO" and TCLCOD <> "ZONAS")  : Default File [ITM3]
    When 2 : Filter [F:ITM3] Where TCLCOD = "SUBZO"                           : Default File [ITM3]
    When 3 : Filter [F:ITM3] Where TCLCOD = "ZONAS"                           : Default File [ITM3]
    When 4 : Filter [F:ITS1] Where [F:ITS1]ITMTYP = 3                         : Default File [ITS1]
  Endcase
  NBCOL       = 0                                                               # n伹ero de la columna
  TIT(NBCOL)  = "Art兤ulos"                                                     # t咜ulo de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Cigo"                                                        # t咜ulo de la segunda columna
  COL(NBCOL)  = "ITMREF"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripci"                                                   # t咜ulo de la segunda columna
  COL(NBCOL)  = "ITMDES1"                                                       # nombre del campo a mostrar en la segunda columna
Return

##############################################################
$VERF_YSELPTOMT
  # si el art兤ulo es 'Zona', 'Subzona' o 'Art兤ulo'
  If [M:YPM4]TIPO(nolign-1) = 1 or [M:YPM4]TIPO(nolign-1) = 2 or [M:YPM4]TIPO(nolign-1) = 3 Then
    [M:YPM4]ITMDES(nolign-1)    = [F:ITM3]ITMDES1
    [M:YPM4]SAU(nolign-1)       = [F:ITM3]SAU
  # si el art兤ulo es 'Kit'
  Elsif [M:YPM4]TIPO(nolign-1) = 4 Then
    Read [F:ITM7]ITM0 = [F:ITS1]ITMREF
    If !fstat Then
      [M:YPM4]ITMDES(nolign-1)    = [F:ITM7]ITMDES1
      [M:YPM4]SAU(nolign-1)       = [F:ITM7]SAU
    Endif
  Endif
  [M:YPM4]DTOOCULTOL(nolign-1) = [M:YPM4]DTOOCULTO
  [M:YPM4]RECOCULTOL(nolign-1) = [M:YPM4]RECOCULTO
  If [M:YPM4]TIPO(nolign-1) <> 1 and [M:YPM4]TIPO(nolign-1) <> 4 Then : [M:YPM4]UNIDADES(nolign-1) = 1 : Endif
  Affzo [M:YPM4]10
Return

##############################################################
# inserta los componentes de un kit en el caso de que se
# seleccione un art兤ulo de este tipo
$INSERTA_KIT_E
Local Integer LCON13 : LCON13 = nolign

  If [M:YPM4]TIPO(nolign-1) = 4 Then
    Filter [F:BOD1] Where ITMREF = [M:YPM4]ITMREF(nolign-1) Order By BOMSEQ Asc
    For [BOD1]
      [M:YPM4]TIPO(LCON13)       = 5
      [M:YPM4]ITMREF(LCON13)     = [F:BOD1]CPNITMREF
      Read   [F:ITM8]ITM0 = [F:BOD1]CPNITMREF
      If !fstat Then
        [M:YPM4]ITMDES(LCON13)   = [F:ITM8]ITMDES1
      Endif
      [M:YPM4]SAU(LCON13)        = [F:BOD1]BOMUOM
      [M:YPM4]UNIDADES(LCON13)   = [F:BOD1]LIKQTY * VALEUR
      [M:YPM4]DTOOCULTOL(LCON13) = [M:YPM4]DTOOCULTOL(nolign-1)
      [M:YPM4]RECOCULTOL(LCON13) = [M:YPM4]RECOCULTOL(nolign-1)
      LCON13 += 1
    Next
    Filter [F:BOD1]
    [M:YPM4]NBEMERGE = LCON13
    Affzo [M:YPM4]10
  Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Antes entrada campo 'Tipo'
######################################################################################
# Oculta la opci 'Componente' de la lista
Subprog AS_TIPO(VALEUR)
Variable Integer VALEUR
  Raz GMENLOC
  GMENLOC(2) = 1
  GMENLOC(3) = 1
  GMENLOC(5) = 1
End

######################################################################################
## Despu駸 de modificar el campo 'Cantidad'
######################################################################################
Subprog AM_UNIDADES(VALEUR)
Variable Decimal VALEUR

  [M:YPM4]UNIDADES(nolign-1) = VALEUR
  Gosub INSERTA_KIT_E

End

######################################################################################
## Despu駸 de modificar el campo 'Art兤ulo'
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
  # rellena la descripci del art兤ulo y la unidad de venta
  Read [F:ITM9]ITM0 = VALEUR
  If !fstat Then
    [M:YPM4]ITMDES(nolign-1)    = [F:ITM9]ITMDES1
    [M:YPM4]SAU(nolign-1)       = [F:ITM9]SAU
  Endif
  [M:YPM4]DTOOCULTOL(nolign-1) = [M:YPM4]DTOOCULTO
  [M:YPM4]RECOCULTOL(nolign-1) = [M:YPM4]RECOCULTO
  If [M:YPM4]TIPO(nolign-1) <> 1 and [M:YPM4]TIPO(nolign-1) <> 4 Then : [M:YPM4]UNIDADES(nolign-1) = 1 : Endif

End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

