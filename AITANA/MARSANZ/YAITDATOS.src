#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Creo ITMSALES
#Call COMPRUEBA_ITS()

End


#####################################################
Subprog COMPRUEBA_ITS()

If !clalev([X1]) : Local File ITMMASTER  [X1] : Endif
If !clalev([X2]) : Local File ITMSALES   [X2] : Endif

Local Integer CONT
Local Integer ERROR

For [X1]
  If [X1]SAU = ""
    [X1]SAU = [X1]STU
    [X1]SAUSTUCOE = 1
    Trbegin [X1]
      Rewrite [X1]
    Commit
  Endif

  Read [X2]ITS0 = [X1]ITMREF
  If fstat <> 0
    Raz [X2]
    [X2]ITMREF    = [X1]ITMREF
    [X2]BASPRIORI = 1
    [X2]CREDAT    = date$
    [X2]CREUSR    = GUSER
    [X2]CTMFLG    = 1
    [X2]DES1AXX   = [X1]ITMDES1
    [X2]ITMDES1   = [X1]ITMDES1
    [X2]EXPNUM    = 1
    [X2]ITMTYP    = 1
    [X2]LNDFLG    = 1
    [X2]LOAECCFLG = 1
    Trbegin [X2]
      Write [X2]
    Commit
      If fstat = 0
        CONT +=1
      Else
        ERROR +=1
      Endif
  Endif
Next

Infbox "OK: " + num$(CONT)
Infbox "KO: " + num$(ERROR)


Close Local File [X1],[X2]
End

