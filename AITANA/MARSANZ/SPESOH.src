# YMA03 - Asignaciůn de colores ped. venta
# Fecha inicio YMA03: 07/11/2019
# Desarrollador: JCH
# Cůdigo de desarrollo: YMA03
# Descripciůn del desarrollo: Asigna al campo LOT el mismo valor que YCOLOR para que la asignaciůn se haga a ese lote
# Fecha: 07/11/2019
# Codigo Actividad: YMA03
#######################################################################################

$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif

Case ACTION
  When "SETBOUT"    :   Gosub SETBOUT
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
################################################
$SETBOUT
## En modo consulta desactivo el botůn de Colores
#If GCONSULT
#   Call VIREBOUT(CHAINE,"8") From GOBJET
#Endif
#
## En modo creaciůn / modificaciůn, desactivo el botůn de Colores
#If GREP <> ""
#   Call VIREBOUT(CHAINE,"8") From GOBJET
#Endif

  # MA01
  Gosub COLOREA_LINEAS
  # MA01

Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
# MA01
$COLOREA_LINEAS
Local Integer LCON1 : Raz LCON1

  For LCON1 = 0 To [M:SOH4]NBLIG - 1
    Case [M:SOH4]YTIPO(LCON1)
      When 2        : Chgstl [M:SOH4]NBLIG(LCON1) With "BACKORANGE"
      When 3        : Chgstl [M:SOH4]NBLIG(LCON1) With "BACKGREEN"
      When Default  : Chgstl [M:SOH4]NBLIG(LCON1) With ""
   Endcase
  Next
Affzo [M:SOH4]5

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
##############################################################
## Despuťs de modificar 'Color'
##############################################################
Subprog AM_YCOLOR(VALEUR)
Variable Char    VALEUR()

# MA03
  [M:SOH4]LOT(nolign-1) = VALEUR
  Affzo [M:SOH4]LOT(nolign-1)
# MA03

End


