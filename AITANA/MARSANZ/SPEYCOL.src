#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "DEBUT"  :   Gosub DEBUT
Endcase
Return


#####################################################
$DEBUT
# Limpio pantalla
Raz [M:YCOL]

# Cargo bloque de zonas y muebles
Local Integer I
Local Integer LINEZ
Local Integer LINEM

For I=0 To [M:SOH4]NBLIG-1
  If [M:SOH4]YZ(I) <> 0
    If LINEZ = 0
      [M:YCOL]ZONA(LINEZ) = [M:SOH4]YZ(I)
      LINEZ +=1
      [M:YCOL]PIE_Z +=1
    Elsif [M:SOH4]YZ(I) <> [M:YCOL]ZONA(LINEZ-1)
      [M:YCOL]ZONA(LINEZ) = [M:SOH4]YZ(I)
      LINEZ +=1
      [M:YCOL]PIE_Z +=1
    Endif
  Endif

  If [M:SOH4]YM(I) <> 0
    If LINEM = 0
      [M:YCOL]MUEBLE(LINEM) = [M:SOH4]YM(I)
      LINEM +=1
      [M:YCOL]PIE_C +=1
    Elsif [M:SOH4]YM(I) <> [M:YCOL]MUEBLE(LINEM-1)
      [M:YCOL]MUEBLE(LINEM) = [M:SOH4]YM(I)
      LINEM +=1
      [M:YCOL]PIE_C +=1
    Endif
  Endif
Next

Affzo [M:YCOL]

Return

