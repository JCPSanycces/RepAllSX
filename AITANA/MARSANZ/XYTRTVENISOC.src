# Codigo Actividad: YMA01
#######################################################################################

# ESTE ESPECÍFICO SE UTILIZA ÚNICAMENTE COMO PUNTO DE ENTRADA PARA QUE, CUANDO SE IMPORTA
# UN PEDIDO DE COMPRA DESDE EL BORRADOR DE PRESUPUESTOS Y SE GENERA AUTOMÁTICAMENTE UN
# PEDIDO DE VENTA (SI ES INTERPLANTA), QUE SE PASE EL CONTENIDO DEL CAMPO ESPECÍFICO
# 'YCOLOR' DE UNA PANTALLA A OTRA (PEDCOMPRA -> PEDVENTA)

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "ALIMSKSOH4"      : Gosub ALIMSKSOH4
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$ALIMSKSOH4
  [M:SOH4]YCOLOR(nolign-1)  = [M:POH2]YCOLOR(nolign-1)
  [M:SOH4]YTIPO(nolign-1)   = [M:POH2]YTIPO(nolign-1)
Return

