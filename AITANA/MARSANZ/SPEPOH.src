#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif

Case ACTION
  When "SETBOUT"  :   Gosub SETBOUT
Endcase
Return


##############################################################
######################    ACCIONES    ########################
##############################################################
########################################################
$SETBOUT
  #MA01
  Gosub COLOREA_LINEAS
  # MA01

Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$COLOREA_LINEAS
Local Integer LCON1 : Raz LCON1

  For LCON1 = 0 To [M:POH2]NBLIG - 1
    Case [M:POH2]YTIPO(LCON1)
      When 2        : Chgstl [M:POH2]NBLIG(LCON1) With "BACKORANGE"
      When 3        : Chgstl [M:POH2]NBLIG(LCON1) With "BACKGREEN"
      When Default  : Chgstl [M:POH2]NBLIG(LCON1) With ""
   Endcase
  Next
Affzo [M:POH2]5

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

