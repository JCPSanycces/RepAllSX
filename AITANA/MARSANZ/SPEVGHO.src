##############################################################
######################################################################################
## Después de modificar el campo 'Sel.'
######################################################################################
Subprog AM_YSEL(VALEUR)
Variable Integer VALEUR

Local Integer LCON : LCON = nolign

  If VALEUR = 2 Then
    While [M:VGHT]ILEV(LCON) <> 1 and LCON <= [M:VGHT]NBLIG
      Grizo [M:VGHT]YSEL(LCON)
      LCON += 1
    Wend
    LCON = nolign-2
    While [M:VGHT]ILEV(LCON) <> 1 and LCON > 0
      Grizo [M:VGHT]YSEL(LCON)
      LCON -= 1
    Wend
  Else
    While [M:VGHT]ILEV(LCON) <> 1 and LCON <= [M:VGHT]NBLIG
      Actzo [M:VGHT]YSEL(LCON)
      LCON += 1
    Wend
    LCON = nolign-2
    While [M:VGHT]ILEV(LCON) <> 1 and LCON > 0
      Actzo [M:VGHT]YSEL(LCON)
      LCON -= 1
    Wend
  Endif

End


