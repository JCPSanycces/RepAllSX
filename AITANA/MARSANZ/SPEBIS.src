$ACTION
Case ACTION
 When Default
Endcase
Return

Subprog AM_BPRVCR(VALEUR)
Variable Char    VALEUR()
# Cargo el mismo valor en la descripción
If [M:BIS1]DES = "" and VALEUR <> ""
  [M:BIS1]DES = VALEUR
  Affzo [M:BIS1]DES
Endif
End


