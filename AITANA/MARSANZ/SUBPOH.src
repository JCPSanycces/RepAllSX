# Issue 71276 - 2015-03-20 by SR : Versions
######################################################################################
Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
#---------------------------------------------------------#
# La version majeure est-elle modifiable en inter-site ? #
#---------------------------------------------------------#
Local    Shortint NOL : NOL=nolign-1
If [M:POH2]CREFLG<>0 & [M:POH0]SALFCY<>""
  Call AS_SAU([M:POH2]LINOCNNUM(NOL),[M:POH2]OCNLIN(NOL),[M:POH2]OCNLIN(NOL))
&      From TRTVENISOC
Endif
End

######################################################################################
Subprog AM_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()
Local Char    WECCVALMAJ(GLONECS)
Local Char    WECCVALMIN(GLONEVL)
Local Char    PITM(GLONITM)

# Issue 107513 by GA 08/2015: keep EO BOM version
Gosub CHECK_ECCVALMIN From TRTACHSCO1
If mkstat : End : Endif

Raz WECCVALMAJ
Raz WECCVALMIN
Raz PITM
If [F:ITM]ITMREF <> [M:POH2]ITMREF(nolign-1)
 Read [F:ITM]ITM0 = [M:POH2]ITMREF(nolign-1)
 If fstat : Raz [F:ITM] : Endif
Endif
# si version majeure trouvťe et si article gere la version mineure : recherche derniere version mineure
If VALEUR  <> "" & [F:ITM]ECCSTO = 3
   WECCVALMAJ = VALEUR
   PITM = [F:ITM]ITMREF
   Gosub READECCMIN From STKACT
   [M:POH2]ECCVALMIN(nolign-1) = WECCVALMIN
   Affzo [M:POH2]ECCVALMIN(nolign-1)
Elsif VALEUR = "" & [M:POH2]ECCVALMIN(nolign-1) <> ""
      Raz   [M:POH2]ECCVALMIN(nolign-1)
      Affzo [M:POH2]ECCVALMIN(nolign-1)
Endif
End

######################################################################################
Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
#---------------------------------------------------------#
# La version mineure est-elle modifiable en inter-site ? #
#---------------------------------------------------------#
Local    Shortint NOL : NOL=nolign-1
If [M:POH2]CREFLG<>0 & [M:POH0]SALFCY<>""
  Call AS_SAU([M:POH2]LINOCNNUM(NOL),[M:POH2]OCNLIN(NOL),[M:POH2]OCNLIN(NOL))
&      From TRTVENISOC
Endif
End
# End issue 71276

######################################################################################
Subprog AM_ECCVALMIN(VALEUR)
Variable Char    VALEUR()
# Issue 107513 by GA 08/2015: keep EO BOM version
Gosub CHECK_ECCVALMIN From TRTACHSCO1
If mkstat : End : Endif

End
