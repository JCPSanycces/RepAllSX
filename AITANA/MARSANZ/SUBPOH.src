# Issue 112754 - 2016-09-27 by SR : Services
######################################################################################
Subprog IB_ITMKND
Raz GBOUT6
# Issue X3-55891 - 2018-10-05 by SR : Pas de PEC si site de rťception vide
# Issue X3-111488 - 2019-02-05 by SR : Retour arriŤre, on laisse le bouton actif
If [M:POH2]ITMKND(nolign-1) <> 0
#If [M:POH2]ITMKND(nolign-1) <> 0 & [M:POH2]PRHFCY(nolign-1) <> ""
  GBOUT6=mess(42,195,1)
Endif
End

######################################################################################
Subprog AS_ITMKND(VALEUR)
Variable Integer VALEUR
Local Integer NOL : NOL = nolign-1
If [F:ITM]ITMREF <> [M:POH2]ITMREF(nolign-1)
 Read [F:ITM]ITM0 = [M:POH2]ITMREF(nolign-1)
 If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITM]SCSFLG = 2 : GMENLOC(1) = 1 : Endif
If VALEUR = 1 : mkstat = 2 : Endif
If GMODIF<>2 | [M:POH2]LINFLG(nolign-1)<>0 | [M:POH2]PQHNUM(nolign-1)<>""
  mkstat=2
Endif
End

######################################################################################
Subprog C_ITMKND(VALEUR)
Variable Integer VALEUR
Local Integer NOL : NOL = nolign-1
If VALEUR = 1 : End : Endif
If GIMPORT
# Issue 120855 - 2017-01-13 by SR : dissocier import rťel de import simulť
#  #----- L'import n'est pas autorisť pour un article sous-traitance  -----#
#  If [F:ITM]ITMREF <> [M:POH2]ITMREF(NOL)
#     Read [F:ITM]ITM0 = [M:POH2]ITMREF(NOL)
#     If fstat : Raz [F:ITM] : Endif
#  Endif
#  If [M:POH2]ITMKND(NOL) = 2 & [F:ITM]PURFLG<>2
   If VALEUR = 2 & (dim(GIMPSIM)<1 | (dim(GIMPSIM)>0 & GIMPSIM <> 2))
     GMESSAGE=mess(573,194,1) : mkstat = 1 : End
  Endif
Else
     If VALEUR = 2
       [M:POH1]CODE = 4
     Else
       [M:POH1]CODE = 6
     Endif
Endif
End

######################################################################################
Subprog AM_ITMKND(VALEUR)
Variable Integer VALEUR
Local Integer NOL : NOL = nolign-1
# Issue X3-55891 - 2018-09-26 by SR : Lignes dťplacťes de SUBPOH vers SUBPOHD
Gosub AM_ITMKND From SUBPOHD
End

