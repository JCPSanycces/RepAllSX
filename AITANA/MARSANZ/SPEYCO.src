#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara YCOACSU1 (Especifico)

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla YCOACSU1) 28/11/2020 18:57:37 (AIT04)
######################################################################################
$ACTION
Case ACTION
 When "RAZCRE"     :   Gosub RAZCRE
 When "LIENS"      :   Gosub LIENS
 When "INICRE"     :   Gosub INICRE
 When "EXEBOUT"    :   Gosub EXEBOUT
Endcase
Return


######################################################################################
$RAZCRE
# Bloqueo el campo envío
Grizo [M:YCOA0]ENVIO
Return


######################################################################################
$LIENS
# Activo el campo envío
Actzo [M:YCOA0]ENVIO

# Muestro bloque de detalle
Raz [M:YCOA1]
[M:YCOA1]PIE = 0

Local Decimal SUMO
For [F:YCOA1] Where [F:YCOA1]ENVIO = [M:YCOA0]ENVIO
  [M:YCOA1]FACTURA([M:YCOA1]PIE)     = [F:YCOA1]FACTURA
  [M:YCOA1]CLIENTE([M:YCOA1]PIE)     = [F:YCOA1]CLIENTE
  [M:YCOA1]DIVISA([M:YCOA1]PIE)      = [F:YCOA1]DIVISA
  [M:YCOA1]IMPORTE([M:YCOA1]PIE)     = [F:YCOA1]IMPORTE
  [M:YCOA1]DIRENTREGA([M:YCOA1]PIE)  = [F:YCOA1]DIRENTREGA
  SUMO += [F:YCOA1]IMPORTE
  [M:YCOA1]PIE +=1
Next

[M:YCOA1]TOTAL = SUMO
Affzo [M:YCOA1]


# Muestro bloque de traza
Raz [M:YCOA2]PIE_T
[M:YCOA2]PIE_T = 0
Filter [F:YCOA2] Where [F:YCOA2]ENVIO = [M:YCOA0]ENVIO Order By [F:YCOA2]NUMERO Asc
  For [F:YCOA2]
    [M:YCOA2]NUMERO([M:YCOA2]PIE_T)  = [F:YCOA2]NUMERO
    [M:YCOA2]FECHA([M:YCOA2]PIE_T)   = [F:YCOA2]FECHA
    [M:YCOA2]HORA([M:YCOA2]PIE_T)    = [F:YCOA2]HORA
    [M:YCOA2]USUARIO([M:YCOA2]PIE_T) = [F:YCOA2]USUARIO
    [M:YCOA2]IMPORTE([M:YCOA2]PIE_T) = [F:YCOA2]IMPORTE
    [M:YCOA2]PIE_T +=1
  Next
Filter [F:YCOA2]
Return


######################################################################################
$INICRE
# Genero el contador
Local Char CONTADOR
Local Integer STAT
Call NUMERO("YCO","",datesyst,"",CONTADOR,STAT) From SUBANM
Infbox CONTADOR
[F:YCOA0]ENVIO = CONTADOR
[M:YCOA0]ENVIO = CONTADOR
Affzo [M:YCOA0]ENVIO
Actzo [M:YCOA0]ENVIO
Return


######################################################################################
$EXEBOUT
Case BOUT
    When "Z" : Gosub ENVIO
    When "Y" : Gosub BUSCAR
Endcase
Return


######################################################################################
$ENVIO
# Confirmo
Local Integer OK9
Call OUINON("żDesea realizar el envío de las facturas?",OK9) From GESECRAN
If OK9 <> 2
  Goto EXIT_EN
Endif

# Variables
Local Char RUTA(200)
Local Char LFILE(200)

# Busco ruta
Read [YCOAR]YCOAR0 = [M:YCOA0]RECEPTOR
If fstat = 0
  RUTA = [YCOAR]CARPETA
Else
  Infbox "No hay ruta indicada en el receptor"
  Goto EXIT_EN
Endif

# Alimento las variables de las fechas
YR = mid$(date$,1,4)
MH = mid$(date$,5,2)
DY = mid$(date$,7,2)
HH = mid$(time$,1,2)
MM = mid$(time$,4,2)
SS = mid$(time$,7,2)

# Fichero de facturas
LFILE = RUTA + [M:YCOA0]ENVIO + "_"+YR+MH+DY+HH+MM+SS+ ".txt"


adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE


Local Integer I
Local Char EAN_C
Local Char CLI_NAME
If !clalev([PP4]) : Local File BPCUSTOMER [PP4] : Endif
For I=0 To [M:YCOA1]PIE-1
  EAN_C     = ""
  CLIN_NAME = ""

  Read [PP4]BPC0 = [M:YCOA1]CLIENTE(I)
  If fstat = 0
   EAN_C    = [PP4]YEANCOAC
   CLI_NAME = [PP4]BPCNAM
  Endif

  Wrseq '"' + EAN_C + '"',
&   '"' + [M:YCOA1]DIRENTREGA(I) + '"',
&   '"' + CLI_NAME + '"',
&   '"' + [M:YCOA1]FACTURA(I) + '"',
&   '"' + [M:YCOA1]DIVISA(I) + '"',
&   '"' + num$([M:YCOA1]IMPORTE(I)) + '"'
Next

# última línea
Wrseq '"' + [M:YCOA0]ENVIO + '"',
& '"' + date$ + '"',
& '"' + num$([M:YCOA1]TOTAL) + '"'

Close Local File [PP4]

Openo

# Creo traza
Local Integer LATE
Filter [F:YCOA2] Where [F:YCOA2]ENVIO = [M:YCOA0]ENVIO Order By [F:YCOA2]NUMERO Desc
Read [F:YCOA2] Last
If fstat = 0
  LATE = [F:YCOA2]NUMERO + 1
Else
  LATE = 1
Endif

Raz [F:YCOA2]
[F:YCOA2]ENVIO   = [M:YCOA0]ENVIO
[F:YCOA2]NUMERO  = LATE
[F:YCOA2]FECHA   = date$
[F:YCOA2]HORA    = time$
[F:YCOA2]USUARIO = GUSER
[F:YCOA2]IMPORTE = [M:YCOA1]TOTAL
Write [F:YCOA2]

$EXIT_EN
Return


######################################################################################
$BUSCAR
# Si tengo líneas pregunto confirmación antes de buscar
If [M:YCOA1]PIE > 0
  Local Integer OK9
  Call OUINON("żDesea recargar la lista de facturas del envío?",OK9) From GESECRAN
  If OK9 <> 2
    Goto EXIT
  Endif
Endif

# Busco en la tabla de vencimientos según criterios
If !clalev([PP1]) : Local File BPCUSTOMER [PP1] : Endif
If !clalev([PP2]) : Local File GACCDUDATE [PP2] : Endif

[M:YCOA1]PIE = 0

For [PP1] Where [PP1]YRECEPTOR <> ""
  For [PP2] Where [PP2]BPRPAY = [PP1]BPCNUM and [PP2]TYP = [M:YCOA0]SERIE and [PP2]CPY = [M:YCOA0]SOCIEDAD and [PP2]CREDAT >= [M:YCOA0]FECHAINI and [PP2]CREDAT <= [M:YCOA0]FECHAFIN
    [M:YCOA1]FACTURA([M:YCOA1]PIE)     = [PP2]NUM
    [M:YCOA1]CLIENTE([M:YCOA1]PIE)     = [PP2]BPRPAY
    [M:YCOA1]DIVISA([M:YCOA1]PIE)      = [PP2]CUR
    [M:YCOA1]IMPORTE([M:YCOA1]PIE)     = [PP2]AMTCUR
    [M:YCOA1]DIRENTREGA([M:YCOA1]PIE)  = [PP2]BPAPAY
    [M:YCOA1]PIE +=1
  Next
Next
Affzo [M:YCOA1]
Close Local File [PP1],[PP2]

# Guardo en tabla
If [M:YCOA1]PIE > 0
  If !clalev([PP3]) : Local File YCOACSU1 [PP3] : Endif
  Local Integer I

  For [PP3] Where [PP3]ENVIO = [M:YCOA0]ENVIO
    Delete [PP3] Curr
  Next

  For I=0 To [M:YCOA1]PIE-1
    If [M:YCOA1]FACTURA(I) <> ""
      Raz [PP3]
      [PP3]ENVIO       = [M:YCOA0]ENVIO
      [PP3]FACTURA     = [M:YCOA1]FACTURA(I)
      [PP3]CLIENTE     = [M:YCOA1]CLIENTE(I)
      [PP3]DIRENTREGA  = [M:YCOA1]DIRENTREGA(I)
      [PP3]DIVISA      = [M:YCOA1]DIVISA(I)
      [PP3]IMPORTE     = [M:YCOA1]IMPORTE(I)
      Write [PP3]
    Endif
  Next

  Close Local File [PP3]
Endif

$EXIT
Return


######################################################################################
Subprog C_FACTURA(VALEUR)
Variable Char    VALEUR()
End

