$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "SOHALLSEL"   : Gosub SOHALLSEL
  When "MODQTEALL"   : Gosub MODQTEALL
  When "MAJSOQALL"   : Gosub MAJSOQALL
#  When "FILSTO"   : Gosub FILSTO
Endcase

Return

