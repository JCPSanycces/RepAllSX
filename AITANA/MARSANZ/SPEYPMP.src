#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "DEBUT"      : Gosub DEBUT
  When "BOUTON"     : Gosub BOUTON
  When "FIN"        : Gosub FIN
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
  If !clalev([F:YPG0]) Then : Local File YVISPAGR [F:YPG0] : Endif
  If !clalev([F:YPN0]) Then : Local File YVISPAGN [F:YPN0] : Endif
  Global Char GCRITP(255) : GCRITP = "1=1"
  Global Char GCRITN(255) : GCRITN = "1=1"
Return

##############################################################
$DEBUT
  [M:YPMP0]CPY    = "001"
  Affzo [M:YPMP0]CPY
  [M:YPMP0]FCYALL = 2
  Affzo [M:YPMP0]FCYALL
  [M:YPMP0]FCY    = ""
  Grizo [M:YPMP0]FCY
Return

##############################################################
$BOUTON
  Case BOUT
    When "b"
      Raz [M:YPMP1],[M:YPMP2],[M:YPMP3]
      GCRITP = "1=1"
      GCRITN = "1=1"
      Affzo [M:YPMP1]
      Affzo [M:YPMP2]
      Affzo [M:YPMP3]
      Gosub SET_FILTRE
      Gosub GET_PAGOSREALIZADOS
      Gosub GET_PAGOSNOREALIZADOS
      Gosub GET_PMPPROVEEDORES
  Endcase
Return

##############################################################
$FIN
  Close Local File [YPG0],[YPN0]
  If dim(GCRITP) >= 0  Then : Kill GCRITP : Endif
  If dim(GCRITN) >= 0  Then : Kill GCRITN : Endif
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$SET_FILTRE

  # filtro pagos realizados
  If [M:YPMP0]CPY     <> ""           Then  : GCRITP -= "AND CPY = [M:YPMP0]CPY"                                          : Endif
  If [M:YPMP0]FCYALL  <> 2            Then  : GCRITP -= "AND FCY = [M:YPMP0]FCY"                                          : Endif
  If [M:YPMP0]STRDAT  <> [00/00/0000] Then  : GCRITP -= "AND F_FACTURA >= [M:YPMP0]STRDAT AND F_PAGO >= [M:YPMP0]STRDAT"  : Endif
  If [M:YPMP0]ENDDAT  <> [00/00/0000] Then  : GCRITP -= "AND F_FACTURA <= [M:YPMP0]ENDDAT AND F_PAGO <= [M:YPMP0]ENDDAT"  : Endif
  If [M:YPMP0]BPR     <> ""           Then  : GCRITP -= "AND BPR = [M:YPMP0]BPR"                                          : Endif

  # filtro pagos no realizados
  If [M:YPMP0]CPY     <> ""           Then  : GCRITN -= "AND CPY_0='"                                             +[M:YPMP0]CPY+"'"                          : Endif
  If [M:YPMP0]FCYALL  <> 2            Then  : GCRITN -= "AND FCY_0='"                                             +[M:YPMP0]FCYALL+"'"                       : Endif
  If [M:YPMP0]STRDAT  <> [00/00/0000] Then  : GCRITN -= "AND F_FACTURA_0>='"+[M:YPMP0]STRDAT+"' AND (F_PAGO_0>='" +[M:YPMP0]STRDAT+"' OR F_PAGO_0 IS NULL)"  : Endif
  If [M:YPMP0]ENDDAT  <> [00/00/0000] Then  : GCRITN -= "AND F_FACTURA_0<='"+[M:YPMP0]ENDDAT+"' AND (F_PAGO_0<='" +[M:YPMP0]ENDDAT+"' OR F_PAGO_0 IS NULL)"  : Endif
  If [M:YPMP0]BPR     <> ""           Then  : GCRITN -= "AND BPR_0= '"                                            +[M:YPMP0]BPR+"'"                          : Endif

Return

##############################################################
$GET_PAGOSREALIZADOS
Local Integer LCON  : Raz LCON
Local Integer J     : Raz J

  Filter [F:YPG0] Where evalue(GCRITP)
  For [YPG0]
    [M:YPMP1]BPR(LCON)          = [F:YPG0]BPR
    [M:YPMP1]BPRVCR(LCON)       = [F:YPG0]BPRVCR
    [M:YPMP1]BPRDAT(LCON)       = [F:YPG0]BPRDAT
    [M:YPMP1]AMTATI(LCON)       = [F:YPG0]AMTATI
    [M:YPMP1]ACCDAT(LCON)       = [F:YPG0]ACCDAT
    [M:YPMP1]PAYCURLIN(LCON)    = [F:YPG0]IMP_PAGADO
    [M:YPMP1]NUM(LCON)          = [F:YPG0]NUM
    [M:YPMP1]IMPORTE_VTO(LCON)  = [F:YPG0]IMPORTE_VTO
    [M:YPMP1]PAGADO_VTO(LCON)   = [F:YPG0]PAGADO_VTO
    [M:YPMP1]IMP_PAGADO(LCON)   = [F:YPG0]IMP_PAGADO
    [M:YPMP1]BPRSAC(LCON)       = [F:YPG0]BPRSAC
    [M:YPMP1]F_FACTURA(LCON)    = [F:YPG0]F_FACTURA
    [M:YPMP1]F_PAGO(LCON)       = [F:YPG0]F_PAGO
    [M:YPMP1]DIAS(LCON)         = [F:YPG0]DIAS
    [M:YPMP1]DIAS_X_PAGO(LCON)  = [F:YPG0]DIAS_X_PAGO
    LCON += 1
  Next
  Filter [F:YPG0]
  [M:YPMP1]NBLIG1 = LCON

  [M:YPMP1]T_IMP_PAGADO = sigma(J=0,[M:YPMP1]NBLIG1-1,([M:YPMP1]IMP_PAGADO(J)))
  [M:YPMP1]T_DIAS_X_PAG = sigma(J=0,[M:YPMP1]NBLIG1-1,([M:YPMP1]DIAS_X_PAGO(J)))
  If [M:YPMP1]T_IMP_PAGADO <> 0 Then : [M:YPMP1]RATIO_OP_PAG = [M:YPMP1]T_DIAS_X_PAG / [M:YPMP1]T_IMP_PAGADO : Endif
  Affzo [M:YPMP1]
Kill LCON,J
Return

##############################################################
$GET_PAGOSNOREALIZADOS
Local Integer LCON  : Raz LCON
Local Integer J     : Raz J
Local Char    LSELECT(255)(0..)

  LSELECT(1) = "SELECT CPY_0,FCY_0,NUM_0,BPR_0,BPRVCR_0,BPRDAT_0,ACCDAT_0,AMTATI_0,IMPORTE_VTO_0,PAGADO_VTO_0,IMP_PAGADO_0,F_FACTURA_0,F_PAGO_0, "
  LSELECT(2) = "IMP_RESTO_0,DIAS_ANO_0,DIAS_0,DIAS_X_IMP_R_0 "
  LSELECT(3) = "FROM " + nomap + ".YVISPAGN "
  LSELECT(4) = "WHERE " + GCRITN

  For  (Char CPY, Char FCY, Char NUM, Char BPR, Char BPRVCR, Date BPRDAT, Date ACCDAT, Decimal AMTATI, Decimal IMPORTE_VTO, Decimal PAGADO_VTO,
&       Decimal IMP_PAGADO, Date F_FACTURA, Date F_PAGO, Decimal IMP_RESTO, Decimal DIAS_ANO, Decimal DIAS, Decimal DIAS_X_IMP_R)
&       From "5" Sql LSELECT(0..4) As [Y00]
    [M:YPMP2]BPR(LCON)          = [F:Y00]BPR
    [M:YPMP2]BPRVCR(LCON)       = [F:Y00]BPRVCR
    [M:YPMP2]BPRDAT(LCON)       = [F:Y00]BPRDAT
    [M:YPMP2]ACCDAT(LCON)       = [F:Y00]ACCDAT
    [M:YPMP2]AMTATI(LCON)       = [F:Y00]AMTATI
    [M:YPMP2]PAYCURLIN(LCON)    = [F:Y00]IMP_PAGADO
    [M:YPMP2]NUM(LCON)          = [F:Y00]NUM
    [M:YPMP2]IMPORTE_VTO(LCON)  = [F:Y00]IMPORTE_VTO
    [M:YPMP2]PAGADO_VTO(LCON)   = [F:Y00]PAGADO_VTO
    [M:YPMP2]IMP_PAGADO(LCON)   = [F:Y00]IMP_PAGADO
    [M:YPMP2]IMP_RESTO(LCON)    = [F:Y00]IMP_RESTO
    [M:YPMP2]DIAS_ANO(LCON)     = [F:Y00]DIAS_ANO
    [M:YPMP2]DIAS(LCON)         = [F:Y00]DIAS
    [M:YPMP2]DIAS_X_IMP_R(LCON) = [F:Y00]DIAS_X_IMP_R
    LCON += 1
  Next
  [M:YPMP2]NBLIG2 = LCON
  Affzo [M:YPMP2]

  [M:YPMP2]T_IMP_RESTO  = sigma(J=0,[M:YPMP2]NBLIG2-1,([M:YPMP2]IMP_RESTO(J)))
  [M:YPMP2]T_DIAS_X_I_R = sigma(J=0,[M:YPMP2]NBLIG2-1,([M:YPMP2]DIAS_X_IMP_R(J)))
  If [M:YPMP2]T_IMP_RESTO <> 0  Then : [M:YPMP2]RATIO_OP_NPA = [M:YPMP2]T_DIAS_X_I_R / [M:YPMP2]T_IMP_RESTO : Endif
  Affzo [M:YPMP2]
Kill LCON,J
Return

##############################################################
$GET_PMPPROVEEDORES
  If ([M:YPMP1]T_IMP_PAGADO + [M:YPMP2]T_IMP_RESTO) <> 0 Then
    [M:YPMP3]PMPP = (([M:YPMP1]RATIO_OP_PAG * [M:YPMP1]T_IMP_PAGADO) + ([M:YPMP2]RATIO_OP_NPA * [M:YPMP2]T_IMP_RESTO)) / ([M:YPMP1]T_IMP_PAGADO + [M:YPMP2]T_IMP_RESTO)
  Endif
  [M:YPMP3]RATIO_OP_PAG = [M:YPMP1]RATIO_OP_PAG
  [M:YPMP3]RATIO_OP_NPA = [M:YPMP2]RATIO_OP_NPA
  [M:YPMP3]T_PAGOS_REAL = [M:YPMP1]T_IMP_PAGADO
  [M:YPMP3]T_PAGOS_PEND = [M:YPMP2]T_IMP_RESTO
  Affzo [M:YPMP3]
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Después de modificar el campo 'Todas las plantas'
######################################################################################
Subprog AM_FCYALL(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    [M:YPMP0]FCY    = ""
    Grizo [M:YPMP0]FCY
  Else
    Actzo [M:YPMP0]FCY
  Endif
End

######################################################################################
## Después de modificar el campo 'Fecha inicial'
######################################################################################
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
  If [M:YPMP0]ENDDAT = [00/00/0000] Then
    [M:YPMP0]ENDDAT = VALEUR
  Endif
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

