$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "TERMINE"    : Gosub TERMINE
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$TERMINE
#  If GSERVEUR = 0 Then                # interactive mode
    Gosub MODIFICA_COMPONENTES        # YMA15
#  Elsif GSERVEUR = 1 Then             # batch mode
#  Endif
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
# YMA15 - Elimina en la OF los componentes de los colores que no se eligieron en el pedido de venta
$MODIFICA_COMPONENTES
Local Clbfile LCOLORCOMP(2) : Raz LCOLORCOMP

  If !clalev([F:SOQ0]) Then : Local File SORDERQ      [F:SOQ0] : Endif
  If !clalev([F:SOP0]) Then : Local File SORDERP      [F:SOP0] : Endif
  If !clalev([F:SOH0]) Then : Local File SORDER       [F:SOH0] : Endif
  If !clalev([F:SQH0]) Then : Local File SQUOTE       [F:SQH0] : Endif
  If !clalev([F:YCC0]) Then : Local File YCOLORCOMPO  [F:YCC0] : Endif
  If !clalev([F:MFM0]) Then : Local File MFGMAT       [F:MFM0] : Endif

#  Filter [F:SOQ0] Where FMINUM = [M:MFGK]MFGNUM
#  Read [F:SOQ0] First
#  If !fstat Then
#    Read [F:SOH0]SOH0 = [F:SOQ0]SOHNUM
#    If !fstat Then
#      Read [F:SQH0]SQH0 = [F:SOH0]SQHNUM
#      If !fstat Then
#        LCOLORCOMP = "MFGNUM = '" + [M:MFGK]MFGNUM + "'"
#        Filter [F:YCC0] Where IDBORRADOR = [F:SQH0]YIDBORRADOR and YIDKIT = [F:SOQ]YIDKIT
##        Filter [F:SOP0] Where SOHNUM = [F:SOQ]SOHNUM and SOPLIN = [F:SOQ]SOPLIN and SOPSEQ = [F:SOQ]SOQSEQ
#        For [YCC0]
##        For [SOP0]
#          If [F:YCC0]TIPO = 7 Then
##          If [F:SOP0]YTIPO = 7 Then
#            LCOLORCOMP -= "AND ITMREF <> '" + [F:YCC0]YCOLORCOMP + "'"
##            LCOLORCOMP -= "AND ITMREF <> '" + [F:SOP0]YCOLORCOMP + "'"
#          Endif
#        Next
#        Filter [F:YCC0]
##        Filter [F:SOP0]
#Infbox LCOLORCOMP
#        Delete [F:MFM0] Where evalue(LCOLORCOMP)
#      Endif
#    Endif
#  Endif
#  Filter [F:SOQ0]

  Filter [F:SOQ0] Where FMINUM = [M:MFGK]MFGNUM
  Read [F:SOQ0] First
  If !fstat Then
    LCOLORCOMP = "MFGNUM = '" + [M:MFGK]MFGNUM + "'"
    Filter [F:YCC0] Where IDBORRADOR = [F:SOQ0]SOHNUM and YIDKIT = ([F:SOQ0]YIDKIT + [F:SOQ0]ITMREF)
    For [YCC0]
      If [F:YCC0]TIPO = 7 Then
        LCOLORCOMP -= "AND ITMREF <> '" + [F:YCC0]YCOLORCOMP + "'"
      Endif
    Next
    Filter [F:YCC0]
    Delete [F:MFM0] Where evalue(LCOLORCOMP)
  Endif
  Filter [F:SOQ0]

  Close Local File [SOQ0],[SOP0],[SOH0],[SQH0],[YCC0],[MFM0]
  If dim(LCOLORCOMP) > 0  Then : Kill LCOLORCOMP : Endif
Return

