######################
#**
#* actualiza el campo 'Color' y 'Tipo' en el presupuesto después de importarse
#*
#* @param PIDBORRADOR    > número del borrador importado
#*!
Subprog ACT_COLORYTIPO_PPTOVTA(PIDBORRADOR)
Value Char PIDBORRADOR

Local Integer LCON15 : Raz LCON15

  Filter [F:SQH0] Where YIDBORRADOR = PIDBORRADOR
  Read   [F:SQH0] First
  If !fstat Then
    Filter [F:SQD0] Where SQHNUM = [F:SQH0]SQHNUM Order By Key SQD0 Asc
    For [SQD0]
      Trbegin [F:SQD0]
      [F:SQD0]YCOLOR = [M:YPM3]YCOLOR(([F:SQD0]SQDLIN / 1000) - 1)
      [F:SQD0]YTIPO  = [M:YPM3]TIPO(([F:SQD0]SQDLIN / 1000) - 1)
      Rewrite [F:SQD0]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Next
    Filter [F:SQD0]
  Endif
  Filter [F:SQH0]

End

