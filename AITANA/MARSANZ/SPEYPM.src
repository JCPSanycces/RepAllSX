# Descripción del desarrollo: Pantalla nueva de creación de presupuestos
# Fecha: 10/10/2019
# Codigo Actividad: YMA01
#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "FILTRE"       : Gosub FILTRE
  When "LIENS"        : Gosub LIENS
  When "CREATION"     : Gosub CREATION
  When "MODIF"        : Gosub MODIF
  When "ANNULE"       : Gosub ANNULE
  When "APRES_CRE"    : Gosub APRES_CRE
  When "APRES_MOD"    : Gosub APRES_MOD
  When "INICRE_LIG"   : Gosub INICRE_LIG
  When "DEFLIG"       : Gosub DEFLIG
  When "STYLE"        : Gosub STYLE
  When "APRES_MODIF"  : Gosub APRES_MODIF
  When "VERIF_CRE"    : Gosub VERIF_CRE
  When "CLE_GAUCHE"   : Gosub CLE_GAUCHE
  When "SETBOUT"      : Gosub SETBOUT
  When "FIN_ACTION"   : Gosub FIN_ACTION
  When "FIN"          : Gosub FIN
  When "SEL_TABLE"    : Gosub SEL_TABLE
  When "VERF_TABLE"   : Gosub VERF_TABLE
  When "AVANTBOUT"    : Gosub AVANTBOUT
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
  Gosub DECLARE From TABLEAUX
  Gosub ABRIR_TABLAS
Return

##############################################################
$FILTRE
  Default File [YPMH]
Return

##############################################################
$LIENS
  Gosub LIENS From TABLEAUX
#  Grizo [M:YPM2]ULTLINEA,SELLINEA,OKLIN
Return

##############################################################
$CREATION
  Gosub CREATION From TABLEAUX
Return

##############################################################
$MODIF
  Gosub MODIF From TABLEAUX
Return

##############################################################
$ANNULE
  Gosub ANNULE From TABLEAUX
Return

##############################################################
$APRES_CRE
  Gosub LIENS From TABLEAUX
Return

##############################################################
$APRES_MOD
  Gosub LIENS From TABLEAUX
Return

##############################################################
$INICRE_LIG
  [F:YPMD]IDBORRADOR = [M:YPM0]IDBORRADOR
Return

##############################################################
$DEFLIG
  Default Mask [YPM3]   # pantalla de las líneas
  Default File [YPMD]   # abreviatura de la tabla de las líneas

  # criterios de filtrado
  CRIT    = 'IDBORRADOR="'+[M:YPM0]IDBORRADOR+'"'   # campo común de las tablas + pantalla cabecera (con el campo común)
  FICLIG  = "YPTOMUEBLESD"                          # nombre de la tabla de detalle
  ABLIG   = "YPMD"                                  # abreviatura de la tabla de detalle
  ZONLIG  = "NUMLIN"                                # campo contador de línea en la tabla detalle

Return

##############################################################
$STYLE
  If GREP = "M" Then
    Gosub CARGA_ZONAS
    Gosub CARGA_MUEBLES
  Endif
Return

##############################################################
$APRES_MODIF
#Local Integer LOK
#
#  Call CONTROLA_SELECTS(LOK)
#
#  If LOK = 2 Then
#    Actzo [M:YPM2]ULTLINEA,SELLINEA,OKLIN
#    Affzo [M:YPM2]ULTLINEA,SELLINEA,OKLIN
#  Endif
Return

##############################################################
$VERIF_CRE
  Gosub GET_CONT
Return

##############################################################
$SETBOUT
  If GREP = "C" Then
    Grizo [M:YPM0]IDBORRADOR
  Else
    Actzo [M:YPM0]IDBORRADOR
  Endif
  Gosub COLOREA_LINEAS
  CHMEN += "oc"
Return

##############################################################
$CLE_GAUCHE
  If GREP = "" Then
    Gosub CARGA_ZONAS
    Gosub CARGA_MUEBLES
    Gosub ACTIVA_DUPLICAR
  Endif
Return

##############################################################
$FIN_ACTION
  If GREP = "" Then
    Gosub CARGA_ZONAS
    Gosub CARGA_MUEBLES
    Gosub ACTIVA_DUPLICAR
  Endif
Return

##############################################################
$FIN
  Gosub CERRAR_TABLAS
Return

##############################################################
$SEL_TABLE
  Case TABLE
    When "YSELPTOMD"  : Gosub SEL_YSELPTOMD
    When "YSELPMDIRE" : Gosub SEL_YSELPMDIRE
  Endcase
Return

##############################################################
$VERF_TABLE
  Case TABLE
    When "YSELPTOMD"  : Gosub VERF_YSELPTOMD
    When "YSELPMDIRE" : Gosub VERF_YSELPMDIRE
  Endcase
Return

##############################################################
$AVANTBOUT
  Case BOUT
    When "o"          : Gosub EXPORTA_PRESVEN
    When "c"          : Gosub EXPORTA_PEDCOMP
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ABRIR_TABLAS
  If !clalev([F:ITM0]) Then : Local File ITMMASTER  [F:ITM0] : Endif
  If !clalev([F:ITM1]) Then : Local File ITMMASTER  [F:ITM1] : Endif
  If !clalev([F:ITM2]) Then : Local File ITMMASTER  [F:ITM2] : Endif
  If !clalev([F:ITM3]) Then : Local File ITMMASTER  [F:ITM3] : Endif
  If !clalev([F:ITM4]) Then : Local File ITMMASTER  [F:ITM4] : Endif
  If !clalev([F:ITM5]) Then : Local File ITMMASTER  [F:ITM5] : Endif
  If !clalev([F:ITM6]) Then : Local File ITMMASTER  [F:ITM6] : Endif
  If !clalev([F:ITM7]) Then : Local File ITMMASTER  [F:ITM7] : Endif
  If !clalev([F:ITS0]) Then : Local File ITMSALES   [F:ITS0] : Endif
  If !clalev([F:BPA0]) Then : Local File BPADDRESS  [F:BPA0] : Endif
  If !clalev([F:BOH0]) Then : Local File BOM        [F:BOH0] : Endif
  If !clalev([F:BOD0]) Then : Local File BOMD       [F:BOD0] : Endif
  If !clalev([F:SQH0]) Then : Local File SQUOTE     [F:SQH0] : Endif
  If !clalev([F:SQD0]) Then : Local File SQUOTED    [F:SQD0] : Endif
Return

##############################################################
$CERRAR_TABLAS
  If clalev([F:ITM0])  Then : Close Local File      [F:ITM0] : Endif
  If clalev([F:ITM1])  Then : Close Local File      [F:ITM1] : Endif
  If clalev([F:ITM3])  Then : Close Local File      [F:ITM3] : Endif
  If clalev([F:ITM4])  Then : Close Local File      [F:ITM4] : Endif
  If clalev([F:ITM5])  Then : Close Local File      [F:ITM5] : Endif
  If clalev([F:ITM6])  Then : Close Local File      [F:ITM6] : Endif
  If clalev([F:ITM7])  Then : Close Local File      [F:ITM7] : Endif
  If clalev([F:ITS0])  Then : Close Local File      [F:ITS0] : Endif
  If clalev([F:BPA0])  Then : Close Local File      [F:BPA0] : Endif
  If clalev([F:BOH0])  Then : Close Local File      [F:BOH0] : Endif
  If clalev([F:BOD0])  Then : Close Local File      [F:BOD0] : Endif
  If clalev([F:SQH0])  Then : Close Local File      [F:SQH0] : Endif
  If clalev([F:SQD0])  Then : Close Local File      [F:SQD0] : Endif
Return

##############################################################
$CARGA_ZONAS
Local Integer LCON0 : Raz LCON0
#  Filter [F:ITM0] Where left$([F:ITM0]ITMREF,4) = "ZONA"
  Filter [F:ITM0] Where TCLCOD = "ZONAS"
  For [ITM0]
    [M:YPM1]NUMZONA(LCON0)  = [F:ITM0]ITMREF
    [M:YPM1]DESZONA(LCON0)  = [F:ITM0]ITMDES1
#    [M:YPM1]DTOOCULTO(LCON0)     = [F:ITM0]ITMREF
#    [M:YPM1]RECOCULTO(LCON0)     = [F:ITM0]ITMREF
    LCON0 += 1
  Next
  Filter [F:ITM0]
  [M:YPM1]NBZONA = LCON0
  Affzo [M:YPM1]5
Return

##############################################################
$CARGA_MUEBLES
Local Integer LCON1 : Raz LCON1
#  Filter [F:ITM1] Where left$([F:ITM1]ITMREF,4) = "MUEB"
  Filter [F:ITM1] Where TCLCOD = "SUBZO"
  For [ITM1]
    [M:YPM2]NUMSUBZONA(LCON1)  = [F:ITM1]ITMREF
    [M:YPM2]DESSUBZONA(LCON1)    = [F:ITM1]ITMDES1
#    [M:YPM2]DTO1(LCON1)     = [F:ITM1]ITMREF
#    [M:YPM2]DTO2(LCON1)     = [F:ITM1]ITMREF
    LCON1 += 1
  Next
  Filter [F:ITM1]
  [M:YPM2]NBSUBZONA = LCON1
  Affzo [M:YPM2]5,10
Return

##############################################################
# obtiene el siguiente número de contador
$GET_CONT
Local Integer LSTAT
Local Char LIDBORRADOR(10)

  Call NUMERO("YIDPM", nomap, date$, "null", LIDBORRADOR, LSTAT) From SUBANM
  [M:YPM0]IDBORRADOR = LIDBORRADOR
  Affzo [M:YPM0]IDBORRADOR
Return

##############################################################
# inserta la información en la última línea
$GO_ULTLINEA
Local Char LNUMZONA3(50), LNUMSUBZONA3(50)  : Raz LNUMZONA3, LNUMSUBZONA3
Local Char LDESZONA3(50), LDESSUBZONA3(50)  : Raz LDESZONA3, LDESSUBZONA3
Local Decimal LDTOZONA3, LRECZONA3          : Raz LDTOZONA3, LRECZONA3
Local Integer LCON3 : Raz LCON3

  # busca la zona seleccionada
  For LCON3 = 0 To [M:YPM1]NBZONA-1
    If [M:YPM1]SELFLGZ(LCON3) = 2 Then
      LNUMZONA3   = [M:YPM1]NUMZONA(LCON3)
      LDESZONA3   = [M:YPM1]DESZONA(LCON3)
      LDTOZONA3   = [M:YPM1]DTOOCULTO(LCON3)
      LRECZONA3   = [M:YPM1]RECOCULTO(LCON3)
      Break
    Endif
  Next

  # busca la subzona seleccionada
  For LCON3 = 0 To [M:YPM2]NBSUBZONA-1
    If [M:YPM2]SELFLGS(LCON3) = 2 Then
      LNUMSUBZONA3  = [M:YPM2]NUMSUBZONA(LCON3)
      LDESSUBZONA3  = [M:YPM2]DESSUBZONA(LCON3)
      Break
    Endif
  Next

  [M:YPM3]TIPO(NBLIG)       = 3
  [M:YPM3]ITMREF(NBLIG)     = LNUMZONA3
  [M:YPM3]ITMDES(NBLIG)     = LDESZONA3
  [M:YPM3]SAU(NBLIG)        = "UN"
  [M:YPM3]UNIDADES(NBLIG)   = 1
  [M:YPM3]DTOOCULTO(NBLIG)  = LDTOZONA3
  [M:YPM3]RECOCULTO(NBLIG)  = LRECZONA3
  [M:YPM3]UPDFLG(NBLIG) = 1
  [M:YPM3]NBLIG += 1

  [M:YPM3]TIPO(NBLIG)       = 2
  [M:YPM3]ITMREF(NBLIG)     = LNUMSUBZONA3
  [M:YPM3]ITMDES(NBLIG)     = LDESSUBZONA3
  [M:YPM3]SAU(NBLIG)        = "UN"
  [M:YPM3]UNIDADES(NBLIG)   = 1
  [M:YPM3]DTOOCULTO(NBLIG)  = LDTOZONA3
  [M:YPM3]RECOCULTO(NBLIG)  = LRECZONA3
  [M:YPM3]UPDFLG(NBLIG)     = 1
  [M:YPM3]NBLIG += 1
  Affzo [M:YPM3]5
Return

##############################################################
# carga la pantalla emergente e inserta la información en la línea indicada
$GO_SELLINEA
Local Integer LINT0
Global Char GPARAM0(15)(0..5)
Local Integer LCON4 : Raz LCON4
Local Char LNUMZONA4(50), LNUMSUBZONA4(50)  : Raz LNUMZONA4, LNUMSUBZONA4
Local Char LDESZONA4(50), LDESSUBZONA4(50)  : Raz LDESZONA4, LDESSUBZONA4
Local Decimal LDTOOCULTO4, LRECOCULTO4      : Raz LDTOOCULTO4, LRECOCULTO4

  # busca la zona seleccionada
  For LCON4 = 0 To [M:YPM1]NBZONA-1
    If [M:YPM1]SELFLGZ(LCON4) = 2 Then
      LNUMZONA4   = [M:YPM1]NUMZONA(LCON4)
      LDESZONA4   = [M:YPM1]DESZONA(LCON4)
      LDTOOCULTO4 = [M:YPM1]DTOOCULTO(LCON4)
      LRECOCULTO4 = [M:YPM1]RECOCULTO(LCON4)
      Break
    Endif
  Next

  # busca la subzona seleccionado
  For LCON4 = 0 To [M:YPM2]NBSUBZONA-1
    If [M:YPM2]SELFLGS(LCON4) = 2 Then
      LNUMSUBZONA4 = [M:YPM2]NUMSUBZONA(LCON4)
      LDESSUBZONA4 = [M:YPM2]DESSUBZONA(LCON4)
      Break
    Endif
  Next

  GPARAM0(0) = LNUMZONA4                                                    # pase de parámetros entre pantallas - número de zona
  GPARAM0(1) = LDESZONA4                                                    # pase de parámetros entre pantallas - descripción de zona
  GPARAM0(2) = LNUMSUBZONA4                                                 # pase de parámetros entre pantallas - número de subzona
  GPARAM0(3) = LDESSUBZONA4                                                 # pase de parámetros entre pantallas - descripción de subzona
  GPARAM0(4) = num$(LDTOOCULTO4)                                            # pase de parámetros entre pantallas - descuento oculto
  GPARAM0(5) = num$(LRECOCULTO4)                                            # pase de parámetros entre pantallas - recargo oculto
  Call SAISIE_LIB(LINT0,GPARAM0,"OYPE","SPEYPE","OBJZON") From GSAISIE      # llamada a la función que abre la pantalla emergente

Return

##############################################################
$SEL_YSELPTOMD
  Case [M:YPM3]TIPO(nolign-1)
    When 1 : Filter [F:ITM2] Where (TCLCOD <> "SUBZO" and TCLCOD <> "ZONAS")  : Default File [ITM2]
    When 2 : Filter [F:ITM2] Where TCLCOD = "SUBZO"                           : Default File [ITM2]
    When 3 : Filter [F:ITM2] Where TCLCOD = "ZONAS"                           : Default File [ITM2]
    When 4 : Filter [F:ITS0] Where [F:ITS0]ITMTYP = 3                         : Default File [ITS0]
  Endcase
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Artículos"                                                     # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "ITMREF"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la segunda columna
  COL(NBCOL)  = "ITMDES1"                                                       # nombre del campo a mostrar en la segunda columna

Return

##############################################################
$VERF_YSELPTOMD
  # si el artículo es 'Zona', 'Subzona' o 'Artículo'
  If [M:YPM3]TIPO(nolign-1) = 1 or [M:YPM3]TIPO(nolign-1) = 2 or [M:YPM3]TIPO(nolign-1) = 3 Then
    [M:YPM3]ITMDES(nolign-1)    = [F:ITM2]ITMDES1
    [M:YPM3]SAU(nolign-1)       = [F:ITM2]SAU
  # si el artículo es 'Kit'
  Elsif [M:YPM3]TIPO(nolign-1) = 4 Then
    Read [F:ITM5]ITM0 = [F:ITS0]ITMREF
    If !fstat Then
      [M:YPM3]ITMDES(nolign-1)    = [F:ITM5]ITMDES1
      [M:YPM3]SAU(nolign-1)       = [F:ITM5]SAU
    Endif
  Endif
  [M:YPM3]DTOOCULTO(nolign-1) = [M:YPM3]DTOOCULTO(nolign-2)
  [M:YPM3]RECOCULTO(nolign-1) = [M:YPM3]RECOCULTO(nolign-2)
  If [M:YPM3]TIPO(nolign-1) <> 1 and [M:YPM3]TIPO(nolign-1) <> 4 Then : [M:YPM3]UNIDADES(nolign-1) = 1 : Endif
  Affzo [M:YPM3]5
Return

##############################################################
$SEL_YSELPMDIRE
  Default File [BPA0]
  Filter [F:BPA0] Where BPANUM = [M:YPM0]CLIENTE
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Direcciones de entrega"                                        # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "BPAADD"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la segunda columna
  COL(NBCOL)  = "BPAADDLIG"                                                     # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Municipio"                                                     # título de la segunda columna
  COL(NBCOL)  = "CTY"                                                           # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Cód. postal"                                                   # título de la segunda columna
  COL(NBCOL)  = "POSCOD"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Provincia"                                                     # título de la segunda columna
  COL(NBCOL)  = "SAT"                                                           # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "País"                                                          # título de la segunda columna
  COL(NBCOL)  = "CRYNAM"                                                        # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Teléfono"                                                      # título de la segunda columna
  COL(NBCOL)  = "TEL(0)"                                                        # nombre del campo a mostrar en la segunda columna
Return

##############################################################
$VERF_YSELPMDIRE
Return

##############################################################
$COLOREA_LINEAS
Local Integer LCON7 : Raz LCON7

  For LCON7 = 0 To [M:YPM3]NBLIG - 1
    Case [M:YPM3]TIPO(LCON7)
      When 2        : Chgstl [M:YPM3]NBLIG(LCON7) With "BACKORANGE"
      When 3        : Chgstl [M:YPM3]NBLIG(LCON7) With "BACKGREEN"
      When Default  : Chgstl [M:YPM3]NBLIG(LCON7) With ""
   Endcase
  Next
Affzo [M:YPM3]5

Return

##############################################################
# activa el campo 'Duplicar' para aquellos registros que son 'Zona'
$ACTIVA_DUPLICAR
Local Integer LCON11 : Raz LCON11

  For LCON11 = 0 To [M:YPM3]NBLIG-1
    If [M:YPM3]TIPO(LCON11) = 3 or [M:YPM3]TIPO(LCON11) = 2 Then
      Actzo [M:YPM3]DUPLICAR(LCON11)
    Else
      Grizo [M:YPM3]DUPLICAR(LCON11)
    Endif
  Next
Affzo [M:YPM3]5

Return

##############################################################
# inserta los componentes de un kit en el caso de que se
# seleccione un artículo de este tipo
$INSERTA_KIT
Local Integer LCON11 : LCON11 = nolign

  [M:YPM3]UNIDADES(nolign-1) = 1
  Filter [F:BOD0] Where ITMREF = VALEUR Order By BOMSEQ Asc
  For [BOD0]
    [M:YPM3]DUPLICAR(LCON11)  = 1
    [M:YPM3]TIPO(LCON11)      = 5
    [M:YPM3]ITMREF(LCON11)    = [F:BOD0]CPNITMREF
    Read   [F:ITM4]ITM0 = [F:BOD0]CPNITMREF
    If !fstat Then
      [M:YPM3]ITMDES(LCON11)  = [F:ITM4]ITMDES1
    Endif
    [M:YPM3]SAU(LCON11)       = [F:BOD0]BOMUOM
    [M:YPM3]UNIDADES(LCON11)  = [F:BOD0]LIKQTY #* VALEUR
    [M:YPM3]DTOOCULTO(LCON11) = [M:YPM3]DTOOCULTO(nolign-1)
    [M:YPM3]RECOCULTO(LCON11) = [M:YPM3]RECOCULTO(nolign-1)
    [M:YPM3]NUMLIN(LCON11)    = (LCON11 + 1) * 1000
    [M:YPM3]UPDFLG(LCON11)    = 1
    LCON11 += 1
  Next
  Filter [F:BOD0]
  [M:YPM3]NBLIG = LCON11
#  Endif
Return

##############################################################
# realiza la exportación silenciosa hacia presupuesto de venta
$EXPORTA_PRESVEN
Local Integer LSTAT : Raz LSTAT
  Call GENERA_FICH("SQH",LSTAT)
Return

##############################################################
# realiza la exportación silenciosa hacia pedido de compra
$EXPORTA_PEDCOMP
Local Integer LSTAT : Raz LSTAT
  Call GENERA_FICH("POH",LSTAT)
Return

##############################################################
# actualiza las unidades de lo que cuelga en una subzona
$ACT_UDSSUBZONA
Local Integer LCON13  : Raz LCON13
Local Integer LDIFUDS, LKITPREV, LKITPOS, LCOMP : Raz LDIFUDS, LKITPREV, LKITPOS, LCOMP

  LDIFUDS = VALEUR - [M:YPM3]UNIDADES(nolign-1)                                 # guarda la diferencia entre el valor actual y el que se modifica

  For LCON13 = nolign To [M:YPM3]NBLIG-1
    If [M:YPM3]TIPO(LCON13) = 1 or [M:YPM3]TIPO(LCON13) = 4 Then                # si la línea es un artículo=1 o un kit=4
      If [M:YPM3]TIPO(LCON13) = 4 Then
        LKITPREV = [M:YPM3]UNIDADES(LCON13)                                     # si es un kit guarda el valor antes de modificarlo
      Endif
      [M:YPM3]UNIDADES(LCON13) = [M:YPM3]UNIDADES(LCON13) + LDIFUDS             # modifica el valor en ambos casos
      [M:YPM3]UPDFLG(LCON13)   = 1
      If [M:YPM3]TIPO(LCON13) = 4 Then
        LKITPOS = [M:YPM3]UNIDADES(LCON13)                                      # si es un kit guarda el valor después de modificarlo
      Endif
    Elsif [M:YPM3]TIPO(LCON13) = 5 Then                                         # si es un componente...
      LCOMP = [M:YPM3]UNIDADES(LCON13) / LKITPREV                               # ...obtiene la cantidad de ese componente para ese kit
      [M:YPM3]UNIDADES(LCON13) = LCOMP * LKITPOS                                # ...obtiene la cantidad de ese componente con la diferencia modificada
      [M:YPM3]UPDFLG(LCON13)   = 1
    Else
      Break
    Endif
  Next
Return

##############################################################
# actualiza las unidades de lo que cuelga en un kit
$ACT_UDSKIT
Local Integer LCON13  : Raz LCON13
Local Integer LDIFUDS, LKITPREV, LKITPOS, LCOMP : Raz LDIFUDS, LKITPREV, LKITPOS, LCOMP

  LDIFUDS   = VALEUR - [M:YPM3]UNIDADES(nolign-1)                               # guarda la diferencia entre el valor actual y el que se modifica
  LKITPREV  = [M:YPM3]UNIDADES(nolign-1)                                        # si es un kit guarda el valor antes de modificarlo
  LKITPOS   = VALEUR

  For LCON13 = nolign To [M:YPM3]NBLIG-1
    If [M:YPM3]TIPO(LCON13) = 5 Then
      LCOMP = [M:YPM3]UNIDADES(LCON13) / LKITPREV                               # ...obtiene la cantidad de ese componente para ese kit
      [M:YPM3]UNIDADES(LCON13) = LCOMP * LKITPOS                                # ...obtiene la cantidad de ese componente con la diferencia modificada
      [M:YPM3]UPDFLG(LCON13)   = 1
    Else
      Break
    Endif
  Next
Return

##############################################################
# actualiza el campo 'Dto. Oculto' que cuelga de una misma zona
$ACTUALIZA_DTOOCULTO
Local Integer LCON14        : Raz LCON14
Local Char    LZONA(10)     : Raz LZONA
Local Decimal LDTOZONA      : Raz LDTOZONA
Local Integer LCONTROLZONA  : Raz LCONTROLZONA

  LZONA     = [M:YPM3]ITMREF(nolign-1)
  LDTOZONA  = VALEUR

  For LCON14 = 0 To [M:YPM3]NBLIG-1
    If [M:YPM3]TIPO(LCON14) <> 3 and LCONTROLZONA = 0 Then
      [M:YPM3]DTOOCULTO(LCON14) = LDTOZONA
      [M:YPM3]UPDFLG(LCON14)    = 1
      Affzo [M:YPM3]DTOOCULTO(LCON14)
      Affzo [M:YPM3]UPDFLG(LCON14)
    Else
      If [M:YPM3]ITMREF(LCON14) = LZONA Then
        LCONTROLZONA = 0
        [M:YPM3]DTOOCULTO(LCON14) = LDTOZONA
        [M:YPM3]UPDFLG(LCON14)    = 1
      Affzo [M:YPM3]DTOOCULTO(LCON14)
      Affzo [M:YPM3]UPDFLG(LCON14)
      Else
        LCONTROLZONA = 1
      Endif
    Endif
  Next

Return

##############################################################
# actualiza el campo 'Recargo Oculto' que cuelga de una misma zona
$ACTUALIZA_RECOCULTO
Local Integer LCON14        : Raz LCON14
Local Char    LZONA(10)     : Raz LZONA
Local Decimal LRECZONA      : Raz LRECZONA
Local Integer LCONTROLZONA  : Raz LCONTROLZONA

  LZONA     = [M:YPM3]ITMREF(nolign-1)
  LRECZONA  = VALEUR

  For LCON14 = 0 To [M:YPM3]NBLIG-1
    If [M:YPM3]TIPO(LCON14) <> 3 and LCONTROLZONA = 0 Then
      [M:YPM3]RECOCULTO(LCON14) = LRECZONA
      [M:YPM3]UPDFLG(LCON14)    = 1
      Affzo [M:YPM3]RECOCULTO(LCON14)
      Affzo [M:YPM3]UPDFLG(LCON14)
    Else
      If [M:YPM3]ITMREF(LCON14) = LZONA Then
        LCONTROLZONA = 0
        [M:YPM3]RECOCULTO(LCON14) = LRECZONA
        [M:YPM3]UPDFLG(LCON14)    = 1
      Affzo [M:YPM3]RECOCULTO(LCON14)
      Affzo [M:YPM3]UPDFLG(LCON14)
      Else
        LCONTROLZONA = 1
      Endif
    Endif
  Next

Return

##############################################################
# actualiza el campo 'Color' que cuelga de una misma zona
$ACTUALIZA_COLOR_ZONA
Local Integer LCON14          : Raz LCON14
Local Char    LZONA(10)       : Raz LZONA
Local Char    LCOLORZONA(25)  : Raz LCOLORZONA
Local Integer LCONTROLZONA    : Raz LCONTROLZONA

  LZONA       = [M:YPM3]ITMREF(nolign-1)
  LCOLORZONA  = VALEUR

  For LCON14 = 0 To [M:YPM3]NBLIG-1
    If [M:YPM3]TIPO(LCON14) <> 3 and LCONTROLZONA = 0 Then
      If [M:YPM3]TIPO(LCON14) = 1 Then
        Read [F:ITM7]ITM0 = [M:YPM3]ITMREF(LCON14)
        If !fstat Then
          If [F:ITM7]LOTMGTCOD <> 1 Then                                  # sólo afecta a los artículos con gestión de lote
            [M:YPM3]YCOLOR(LCON14) = LCOLORZONA
            [M:YPM3]UPDFLG(LCON14) = 1
            Affzo [M:YPM3]YCOLOR(LCON14)
            Affzo [M:YPM3]UPDFLG(LCON14)
          Endif
        Endif
      Else
        [M:YPM3]YCOLOR(LCON14) = LCOLORZONA
        [M:YPM3]UPDFLG(LCON14) = 1
        Affzo [M:YPM3]YCOLOR(LCON14)
        Affzo [M:YPM3]UPDFLG(LCON14)
      Endif
    Else
      If [M:YPM3]ITMREF(LCON14) = LZONA Then
        LCONTROLZONA = 0
        [M:YPM3]YCOLOR(LCON14) = LCOLORZONA
        [M:YPM3]UPDFLG(LCON14) = 1
        Affzo [M:YPM3]YCOLOR(LCON14)
        Affzo [M:YPM3]UPDFLG(LCON14)
      Else
        LCONTROLZONA = 1
      Endif
    Endif
  Next

Return

##############################################################
# actualiza el campo 'Color' que cuelga de una misma subzona
$ACTUALIZA_COLOR_SUBZONA
Local Char    LCOLORZONA(25)  : Raz LCOLORZONA
Local Integer LCON14          : Raz LCON14

  For LCON14 = nolign To [M:YPM3]NBLIG-1
    If [M:YPM3]TIPO(LCON14) = 1 or [M:YPM3]TIPO(LCON14) = 4 or [M:YPM3]TIPO(LCON14) = 5 Then      # controla 'Artículo', 'Kit', 'Componente'
      Read [F:ITM7]ITM0 = [M:YPM3]ITMREF(LCON14)
      If !fstat Then
        If [F:ITM7]LOTMGTCOD <> 1 Then                                                            # controla que tenga gestión de lote
          [M:YPM3]YCOLOR(LCON14) = VALEUR
          [M:YPM3]UPDFLG(LCON14) = 1
          Affzo [M:YPM3]YCOLOR(LCON14)
          Affzo [M:YPM3]UPDFLG(LCON14)
        Endif
      Endif
    Else
      Break
    Endif
  Next

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Controla que sólo se pueda marcar una vez el campo SELFLGZ
######################################################################################
Subprog C_SELFLGZ(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 Then
  Call UNICITE(VALEUR,[M:YPM1]SELFLGZ(0..[M:YPM1]NBZONA-1)) From OBJDIV
  If mkstat = 2 Then
    VALEUR = 1
  Endif
Else
  [M:YPM1]DTOOCULTO(nolign-1) = 0
  [M:YPM1]RECOCULTO(nolign-1) = 0
Endif
End

######################################################################################
## Controla que sólo se pueda marcar una vez el campo SELFLGS
######################################################################################
Subprog C_SELFLGS(VALEUR)
Variable Integer VALEUR
If VALEUR = 2 Then
  Call UNICITE(VALEUR,[M:YPM2]SELFLGS(0..[M:YPM2]NBSUBZONA-1)) From OBJDIV
  If mkstat = 2 Then
    VALEUR = 1
  Endif
Endif
End

######################################################################################
## Controla que esté marcado sólo un check entre 'Última línea' y 'Elegir línea'
######################################################################################
Subprog C_ULTLINEA(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    [M:YPM2]SELLINEA = 1
  Else
    [M:YPM2]SELLINEA = 2
  Endif
  Affzo [M:YPM2]SELLINEA
End

######################################################################################
## Controla que esté marcado sólo un check entre 'Última línea' y 'Elegir línea'
######################################################################################
Subprog C_SELLINEA(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    [M:YPM2]ULTLINEA = 1
  Else
    [M:YPM2]ULTLINEA = 2
  Endif
  Affzo [M:YPM2]ULTLINEA
End

######################################################################################
## Control campo 'Artículo'
######################################################################################
# Controla que si el artículo tiene gestión de lote se habilite la edición del campo 'Color'
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
#  Read [F:ITM3]ITM0 = VALEUR
#  If !fstat Then
#    If [F:ITM3]LOTMGTCOD = 1 Then
#      Grizo [M:YPM3]YCOLOR(nolign-1)
#    Else
#      Actzo [M:YPM3]YCOLOR(nolign-1)
#    Endif
#  Endif
End

######################################################################################
## Control en el campo 'Cantidad'
######################################################################################
Subprog C_UNIDADES(VALEUR)
Variable Decimal VALEUR

  # si es 'Subzona', actualiza la cantidad en todo lo que cuelga de ella
  If [M:YPM3]TIPO(nolign-1) = 2 Then
    Gosub ACT_UDSSUBZONA
  Elsif [M:YPM3]TIPO(nolign-1) = 4 Then
    Gosub ACT_UDSKIT
  Endif

  Affzo [M:YPM3]5

End

######################################################################################
## Click en el icono 'OK'
######################################################################################
Subprog CL_OKLIN(VALEUR)
Variable Char    VALEUR()

  Case [M:YPM2]ULTLINEA
    When 1  : Gosub GO_SELLINEA               # elegir línea
    When 2  : Gosub GO_ULTLINEA               # última línea
  Endcase

  Gosub COLOREA_LINEAS

End

######################################################################################
## Después de marcar el check de Duplicar
######################################################################################
Subprog AM_DUPLICAR(VALEUR)
Variable Integer VALEUR
Local Integer LINT1 : Raz LINT1
Global Char GPARAM1(1)(1)

  If VALEUR = 2 Then
    Call SAISIE_LIB(LINT1,GPARAM1,"OYRDP","SPEYRDP","OBJZON") From GSAISIE           # llamada a la función que abre la pantalla emergente
  Endif

End

######################################################################################
## Después de modificar el campo 'Cantidad'
######################################################################################
Subprog AM_UNIDADES(VALEUR)
Variable Decimal VALEUR

  [M:YPM3]UNIDADES(nolign-1) = VALEUR

#  # si es 'Kit', inserta los componentes
#  If [M:YPM3]TIPO(nolign-1) = 4 Then
#    Gosub INSERTA_KIT
#  Endif

  Affzo [M:YPM3]5

End

######################################################################################
## Después de modificar el campo 'Dto. oculto'
######################################################################################
Subprog AM_DTOOCULTO(VALEUR)
Variable Decimal VALEUR
  If [M:YPM3]TIPO(nolign-1) = 3 Then
    Gosub ACTUALIZA_DTOOCULTO
  Endif
End

######################################################################################
## Después de modificar el campo 'Recargo oculto'
######################################################################################
Subprog AM_RECOCULTO(VALEUR)
Variable Decimal VALEUR
  If [M:YPM3]TIPO(nolign-1) = 3 Then
    Gosub ACTUALIZA_RECOCULTO
  Endif
End

######################################################################################
## Después de modificar el campo 'Color'
######################################################################################
Subprog AM_YCOLOR(VALEUR)
Variable Char    VALEUR()
  If [M:YPM3]TIPO(nolign-1) = 3 Then
    Gosub ACTUALIZA_COLOR_ZONA
  Elsif [M:YPM3]TIPO(nolign-1) = 2 Then
    Gosub ACTUALIZA_COLOR_SUBZONA
  Endif
End

######################################################################################
## Después de modificar el campo 'Artículo'
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

  # si es 'Kit', inserta los componentes
  If [M:YPM3]TIPO(nolign-1) = 4 Then
    Gosub INSERTA_KIT
  Endif

  Affzo [M:YPM3]5

End

######################################################################################
## Después de campo 'Artículo'
######################################################################################
Subprog AP_ITMREF(VALEUR)
Variable Char    VALEUR()
# Marca el fondo de las líneas en función del tipo de línea
  Case [M:YPM3]TIPO(nolign-1)
    When 3        : Chgstl NBLIG(nolign-1) With "BACKGREEN"      # zona = Fondo verde
    When 2        : Chgstl NBLIG(nolign-1) With "BACKORANGE"     # subzona = Fondo naranja
    When Default  : Chgstl NBLIG(nolign-1) With ""
  Endcase
  Read [F:ITM6]ITM0 = VALEUR
  If !fstat Then
    [M:YPM3]ITMDES(nolign-1)    = [F:ITM6]ITMDES1
    [M:YPM3]SAU(nolign-1)       = [F:ITM6]SAU
  Endif
  [M:YPM3]DTOOCULTO(nolign-1) = [M:YPM3]DTOOCULTO(nolign-2)
  [M:YPM3]RECOCULTO(nolign-1) = [M:YPM3]RECOCULTO(nolign-2)
  If [M:YPM3]TIPO(nolign-1) <> 1 and [M:YPM3]TIPO(nolign-1) <> 4 Then : [M:YPM3]UNIDADES(nolign-1) = 1 : Endif

End

######################################################################################
## Antes entrada campo 'Tipo'
######################################################################################
# Oculta la opción 'Componente' de la lista
Subprog AS_TIPO(VALEUR)
Variable Integer VALEUR
  Raz GMENLOC
  GMENLOC(5) = 1
End

######################################################################################
## Antes de entrada en campo 'Unidades'
######################################################################################
Subprog AS_UNIDADES(VALEUR)
Variable Decimal VALEUR

  # deshabilita el campo cantidad en los artículos de tipo 'Zona' y 'Componente'
  If [M:YPM3]TIPO(nolign-1) = 3 or [M:YPM3]TIPO(nolign-1) = 5 Then
    Diszo [M:YPM3]UNIDADES(nolign-1)
  Else
    Actzo [M:YPM3]UNIDADES(nolign-1)
  Endif

End

######################################################################################
## Antes de entrada 'Dto. Oculto'
######################################################################################
Subprog AS_DTOOCULTO(VALEUR)
Variable Decimal VALEUR

  # deshabilita el campo dto. oculto en los artículos de tipo 'Artículo, 'Subzona', 'Kit' y 'Componente'
  If [M:YPM3]TIPO(nolign-1) = 1 or [M:YPM3]TIPO(nolign-1) = 2 or [M:YPM3]TIPO(nolign-1) = 4 or [M:YPM3]TIPO(nolign-1) = 5 Then
    Diszo [M:YPM3]DTOOCULTO(nolign-1)
  Else
    Actzo [M:YPM3]DTOOCULTO(nolign-1)
  Endif

End

######################################################################################
## Antes de entrada 'Recargo Oculto'
######################################################################################
Subprog AS_RECOCULTO(VALEUR)
Variable Decimal VALEUR

  # deshabilita el campo rec. oculto en los artículos de tipo 'Artículo, 'Subzona', 'Kit' y 'Componente'
  If [M:YPM3]TIPO(nolign-1) = 1 or [M:YPM3]TIPO(nolign-1) = 2 or [M:YPM3]TIPO(nolign-1) = 4 or [M:YPM3]TIPO(nolign-1) = 5 Then
    Diszo [M:YPM3]RECOCULTO(nolign-1)
  Else
    Actzo [M:YPM3]RECOCULTO(nolign-1)
  Endif

End

######################################################################################
## Antes de campo 'Color'
######################################################################################
Subprog AV_YCOLOR(VALEUR)
Variable Char    VALEUR()

  # 'Artículo', 'Kit' o 'Componente'
  If [M:YPM3]TIPO(nolign-1) = 1 or [M:YPM3]TIPO(nolign-1) = 4 or [M:YPM3]TIPO(nolign-1) = 5 Then
    Read [F:ITM3]ITM0 = [M:YPM3]ITMREF(nolign-1)
    If !fstat Then
      If [F:ITM3]LOTMGTCOD = 1 Then                                                               # Habilita o no en función de si el artículo tiene gestión de lote
        Grizo [M:YPM3]YCOLOR(nolign-1)
      Else
        Actzo [M:YPM3]YCOLOR(nolign-1)
      Endif
    Endif
  Elsif [M:YPM3]TIPO(nolign-1) = 3 or [M:YPM3]TIPO(nolign-1) = 2 Then                             # Habilita si es 'Zona' o 'Subzonz'
    Actzo [M:YPM3]YCOLOR(nolign-1)
  Else
    Grizo [M:YPM3]YCOLOR(nolign-1)
  Endif

End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
##############################################################
######################
#**
#* genera el fichero y realiza la importación de presupuesto venta o pedido compra según parámetro
#*
#* @param PTYPE    > tipo de importación: PRESUPUESTO VTA. = 'SQH' ; PEDIDO COMPRA = 'POH'
#* @param PERROR1  > devuelve el estado de la importación  PERROR1=1 -> éxito ; PERROR1<>1 -> error
#*!
Subprog GENERA_FICH(PTYPE, PERROR1)
Value     Char    PTYPE
Variable  Integer PERROR1

Local Char    LDIRIMPORT1(250) : LDIRIMPORT1 = filpath("IMPORT_EXPORT","","")
Local Char    LFILE_W1(200) : LFILE_W1 = "\" + PTYPE
Local Char    LDATCAB1(100)(7), LDATLINL1(100)(10)
Local Char    LFECHA1(10), LHORA1(10) : Raz LFECHA1, LHORA1
Local Char    LSEP1(1) : LSEP1 = ";"  # separador
Local Integer LCON12 : Raz LCON12

  LFECHA1 = vireblc(num$(date$),4) : LFECHA1 = mid$(LFECHA1,1,2)+mid$(LFECHA1,4,2)+mid$(LFECHA1,7,4)
  LHORA1  = vireblc(num$(time$),4) : LHORA1  = mid$(LHORA1,1,2)+mid$(LHORA1,4,2)+mid$(LHORA1,7,2)

  LDIRIMPORT1 += "\" + PTYPE
  LFILE_W1 = LDIRIMPORT1 + LFILE_W1 + "_" + LFECHA1 + LHORA1 + ".txt"

#  mkstat = 0 : fstat = 0 : GERRTRACE = 0
#  # si se lanza la tarea batch
#  If !GSERVEUR Then
#    Call TEMPON("Proceso borrador presupuestos") From GESECRAN
#    Call OUVRE_TRACE ("Proceso borrador presupuestos") From LECFIC
#  Endif

  # borramos el fichero si existe...
  If filinfo(LFILE_W1, 7) > 0 Then
    System "ae_rm " + LFILE_W1
  Endif

  Sleep 1

  # abrir el fichero para escritura
  Gosub OPEN_FILE_W1

  # datos de cabecera
  Raz LDATCAB1
  LDATCAB1(0)  = "E"                                                                      # Inidicador
  LDATCAB1(1)  = [M:YPM0]PLANTA                                                           # Planta
  LDATCAB1(2)  = ""                                                                       # Número de pedido/presupuesto
  If PTYPE = "SQH" Then : LDATCAB1(3) = [M:YPM0]CLIENTE Else LDATCAB1(3) = "104" : Endif  # Cliente / Proveedor
  LDATCAB1(4)  = date$                                                                    # Fecha
  If PTYPE = "SQH" Then LDATCAB1(5)  = "SQN" Else LDATCAB1(5) = "" : Endif                # Tipo de documento (sólo se informa cuando es presupuesto venta)
  If PTYPE = "POH" Then LDATCAB1(5)  = "104"                       : Endif                # Tercero factura (sólo se informa cuando es pedido compra)
  LDATCAB1(6)  = [M:YPM0]IDBORRADOR                                                       # Nş de borrador

  # datos de cabecera
  Wrseq LDATCAB1(0) + LSEP1 + LDATCAB1(1) + LSEP1 + LDATCAB1(2) + LSEP1 + LDATCAB1(3) + LSEP1 + LDATCAB1(4) + LSEP1 + LDATCAB1(5) + LSEP1 + LDATCAB1(6) Using [ZIMP_W1]

  # datos de líneas
  For LCON12 = 0 To [M:YPM3]NBLIG-1
    If PTYPE <> "SQH" or [M:YPM3]TIPO(LCON12) <> 5 Then
      Raz LDATLINL1
      LDATLINL1(0) = "L"                                                                    # Indicador
      LDATLINL1(1) = [M:YPM3]ITMREF(LCON12)                                                 # Código de artículo
      LDATLINL1(2) = [M:YPM3]ITMDES(LCON12)                                                 # Descripción de artículo
      LDATLINL1(3) = [M:YPM3]SAU(LCON12)                                                    # Unidad
      LDATLINL1(4) = num$([M:YPM3]UNIDADES(LCON12))                                         # Cantidad
#      If [M:YPM3]TIPO = 2 or [M:YPM3]TIPO = 3 or [M:YPM3]TIPO = 5 Then                      # Precio bruto (a 0 si es zona, subz. o componente)
#        LDATLINL1(5) = num$(0)
#      Else
#        LDATLIN1(5) = ""
#      Endif
      LDATLINL1(5) = num$([M:YPM3]DTOOCULTO(LCON12))                                        # Descuento oculto
      LDATLINL1(6) = num$([M:YPM3]RECOCULTO(LCON12))                                        # Recargo oculto
      LDATLINL1(7) = [M:YPM3]YCOLOR(LCON12)                                                 # Color
      LDATLINL1(8) = num$([M:YPM3]TIPO(LCON12))                                             # Tipo
      LDATLINL1(9) = "NOR"                                                                  # Nivel de impuesto 1

      # datos de línea
      Wrseq LDATLINL1(0) + LSEP1 + LDATLINL1(1) + LSEP1 + LDATLINL1(2) + LSEP1 + LDATLINL1(3) + LSEP1 + LDATLINL1(4) + LSEP1 + LDATLINL1(5) + LSEP1 +
&     LDATLINL1(6) + LSEP1 + LDATLINL1(7) + LSEP1 + LDATLINL1(8)  + LSEP1 + LDATLINL1(9) Using [ZIMP_W1]
    Endif
  Next

  Gosub CLOSE_FILE_W1

  If PTYPE = "SQH" Then
    Call IMPORTSIL("YPMSQH",LFILE_W1) From GIMPOBJ                      # lanza la imporación de presupuesto de venta
    Call ACT_COLORYTIPO_PPTOVTA([M:YPM0]IDBORRADOR)                     # asigna el color y tipo a las líneas del presupuesto después de importar
  Else
    Call IMPORTSIL("YPMPOH",LFILE_W1) From GIMPOBJ                      # lanza la imporación de pedido de compra
  Endif

  PERROR1 = GOK

#  If !GSERVEUR Then
#    Call TEMPOFF() From GESECRAN
#    # fin de traza
#    Call ECR_TRACE("Fichero " + ctrans(LFILE_W1,"\","/") + " generado", 0) From GESECRAN
#    Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
#    Call FERME_TRACE From LECFIC
#
##    # lectura
##    Call LEC_TRACE From LECFIC
#
##    mkstat = 0 : fstat = 0 : GERRTRACE = 0 : GOK = 1
#  Endif

End

########################################################
$OPEN_FILE_W1

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE_W1 Using [ZIMP_W1]

Return

########################################################
$CLOSE_FILE_W1

Openo Using [ZIMP_W1]

Return


