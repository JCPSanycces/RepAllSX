###########################################################################
# Clave Denia deberûÀ depositar unos ficheros ALQ...CSV en la carpeta E:\IMPORT\ALQUILERES
# Una tarea programada en Sage X3 leera el contenido de esta carpeta, buscara los ficheros
# y los procesarûÀ. A partir de cada uno CREARû UN FICHERO LLAMADO ALQ...[FECHAHORA].CSV EL CUAL
# DEJARû EN LA CARPETA E:\IMPORT para seguidamente llamar al modelo de importaciû°n ZPAYAQL
# el cual genera Cobros
# El fichero original se dejara en E:\IMPORT\ALQUILERES\FIN con el nombre OK[FECHAHORA]ALQ...CSV
# El modelo procesarûÀ el fichero de la Carpeta IMPORT dejando el fichero en FIN si todo va bien
# o en ERR si hay errores
# IMPORTANTE: Es OBLIGATORIO que los ficheros originales comiencen por ALQ y tengan la extensiû°n CSV
# La documentaciû°n estûÀ en Confluence: https://sisconfluence.sistel.es/display/BM/P11601+Alehop+-+Modelo+pago+alquileres
###########################################################################

############################################################################################
#*
#* Funciû°n Principal que inicia el proceso
#*
#Subprog PRINCIPAL()
Local Char LDIR(250)
Local Char LDIR2(250)
Local Char LFILE #: LFILE  = "ALQUILERES.CSV"

Local Char FILELIST(GDIMFIC)(1..100)
Local Integer LNGTH
Local Integer I : I = 3

#LDIR =filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER
#mid$(PFICHERO,1,len(PFICHERO)-4)
LDIR = "E:\IMPORT\ALQUILERES\"
#Infbox "Dir es " + LDIR

#Infbox "ZIMPALQ - 39: entrada al programa"

#Buscamos ficheros con la extension .CSV y el nombre ALQ...
Call SYSTEME2(adxmac(0), "lsadx"-LDIR,"",LNGTH,FILELIST) From ORDSYS
#Infbox "LNGTH es " + num$(LNGTH)
While I <= LNGTH
  #Infbox "I es " + num$(I)
  #Infbox "eL FICHERO ES " + FILELIST(I) #TODO: OJO QUE PETA PORQUE ENCUENTA LOS ..
  If mid$(FILELIST(I),len(FILELIST(I))-3,4) = ".csv" Then
    If mid$(FILELIST(I),1,3) = "ALQ" Then
      #Infbox "Encontrado fichero CSV: " + FILELIST(I)
      #Infbox "ZIMPALQ - 50: fichero encontrado " + FILELIST(I)
      Call PROCESA_FICHERO(LDIR, FILELIST(I))
    Endif
  Endif
  I = I + 1
Wend
#Infbox "Proceso finalizado."
End


############################################################################################
#*
#* Subprograma que genera el Fichero CSV y llama al modelo de Importaciû°n
#*
Subprog PROCESA_FICHERO(PDIR,PFILE)
Local Char LDIR, LFILE : Raz LDIR, LFILE
Local Integer LECOK : Raz LECOK
Local Integer LNUMEXP : Raz LNUMEXP
Local Char CAMPO(200)(30)
Local Float LIMPORTETOTAL: Raz LIMPORTETOTAL

Local Char LFILE_W
Local Char LFECHA
Local Char LFECHAF(10), LHORAF(10) : Raz LFECHAF, LHORAF
Local Char LSOCIEDAD
Local Char LSEP(1) : LSEP = ";"  # LSEParador
Local Char LBLA(1) : LBLA = ""   # Caracter en LBLAnco
Local Char LDENCOD : LDENCOD = ""

LDIR = PDIR
LFILE = PFILE
#LDIR = LDIR + "\TMP\"
#Infbox "El fichero es " + LDIR + LFILE
#Abrimos fichero de Lectura
Gosub ABRIR_FICHERO_R
If filinfo(LDIR+LFILE, 7) > 0 Then
  #Infbox "Fichero abierto!"
  Call OUVRE_TRACE(LDIR+LFILE) From LECFIC
  LECOK = 1
  LNUMEXP = 1
  LFECHAF = vireblc(num$(date$),4) : LFECHAF = mid$(LFECHAF,1,2)+mid$(LFECHAF,4,2)+mid$(LFECHAF,7,4)
  LHORAF  = vireblc(num$(time$),4) : LHORAF  = mid$(LHORAF,1,2)+mid$(LHORAF,4,2)+mid$(LHORAF,7,2)
  LFILE_W = mid$(LFILE,1,len(LFILE)-4) + LFECHAF + LHORAF + ".CSV"
  #Infbox "El nombre del fichero Destino sera " + LFILE_W
  #Abrimos fichero de escritura
  Gosub ABRIR_FICHERO_W
  Repeat
    # leer el archivo
    Rdseq CAMPO(1),CAMPO(2),CAMPO(3), CAMPO(4),CAMPO(5),CAMPO(6),CAMPO(7)  Using [ZIMP_R]
    If fstat = 0 Then
      If LNUMEXP = 1 Then
        #LFECHA = CAMPO(2)
        LFECHA = mid$(CAMPO(2),7,4)+mid$(CAMPO(2),4,2)+mid$(CAMPO(2),1,2)
        #Infbox "Ya tenemos la fecha que es " + LFECHA
      Endif
      #Aqui es donde generamos el fichero y buscamos los datos que necesitamos
      If LNUMEXP >= 3 Then
        #Infbox "Estamos en la linea " + num$(LNUMEXP) + " y los valores son " + CAMPO(1) + ";" + CAMPO(2)
        LDENCOD = func GETDENCOD(CAMPO(6))
        Wrseq "P" + LSEP + LBLA + LSEP + "SPTRF" + LSEP + CAMPO(1) + LSEP + CAMPO(4) + LSEP + LFECHA + LSEP + CAMPO(6) + LSEP + CAMPO(5) + LSEP + "TRF" Using [ZIMP_W]
        Wrseq "D" + LSEP + "PAY" + LSEP + LBLA + LSEP + LBLA + LSEP + CAMPO(5) Using [ZIMP_W]
        Wrseq "D" + LSEP + LDENCOD + LSEP + LBLA + LSEP + LBLA + LSEP + CAMPO(7) Using [ZIMP_W]
        Wrseq "A" + LSEP + "AX1" + LSEP + CAMPO(1) + LSEP + CAMPO(7) Using [ZIMP_W]
        LIMPORTETOTAL = LIMPORTETOTAL + val(ctrans(CAMPO(5),",","."))
        #Infbox "EL CAMPO ES " + num$(CAMPO(5))
        #Infbox "LIMPORTETOTAL ES " + val(ctrans(CAMPO(5),",","."))
      Endif
      LNUMEXP += 1
    Else
      LECOK = 0
    Endif
  Until LECOK = 0
  Call ECR_TRACE("Fichero de la carpeta ALQUILERES Procesado: " + LFILE,0) From GESECRAN
  Call ECR_TRACE("Fichero generado en IMP para el modelo ZPAYALQ: " + LFILE_W,0) From GESECRAN
  Call ECR_TRACE("Numero de cobros procesados: " + num$(LNUMEXP-3),0) From GESECRAN
  Call ECR_TRACE("Importe total cobros: " + num$(LIMPORTETOTAL),0) From GESECRAN
  Call FERME_TRACE From LECFIC
Endif
Gosub CERRAR_FICHERO_R
Gosub CERRAR_FICHERO_W
GERRTRACE = 0
#Tenemos que generar el fichero en IMPORT
#Infbox "ZIMPALQ - 122 Ahora llamamos al modelo para el fichero" + "E:\IMPORT\" + LFILE_W
Call IMPORTSIL('ZPAYALQ',"E:\IMPORT\" + LFILE_W) From GIMPOBJ
#Luego tenemos que mover el fichero a ALQUILERES\FIN (el propio modelo ya dejara el fichero de importacion en ERR si ha ido mal=
LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
LHORA = vireblc(num$(time$),4) : LHORA = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)
DESPATH = LDIR + "FIN\OK_" + LFECHA +LHORA + LFILE
SUCCESS =  renameFile(LDIR + LFILE,DESPATH)
End

############################################################################################
#*
#* Busqueda del campo ZDENCOD (Campo DESTINO CONTABLE de Cuentas Bancarias, pestaûÝa Gestion)
#*
Funprog GETDENCOD(PBANCO)
Local Char LBANCO : LBANCO = PBANCO
Local Char LDENCOD : LDENCOD = ""
If clalev([BAN])  = 0   Local File BANK [BAN] : Endif
#Filtramos la tabla para buscar el campo
Filter [BAN] Where BAN = LBANCO
Read [BAN] First
If !fstat Then
  LDENCOD = [F:BAN]ZDENCOD
Else
  LDENCOD = ""
Endif
Filter [BAN]
Close Local File [BAN]
End LDENCOD

# Abre fichero original para leer
$ABRIR_FICHERO_R
adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openi LDIR+LFILE Using [ZIMP_R]
Iomode adxium 50 Using [ZIMP_R] # 50 = ASCII 0 = UTF8
Return

# Cierra fichero original
$CERRAR_FICHERO_R
Openo Using [ZIMP_R]
Return

# Abre fichero a Generar para llamar alm modelo
$ABRIR_FICHERO_W
adxifs = ";"
adxirs = chr$(13)+chr$(10)
#Openo LDIR + LFILE_W  Using [ZIMP_W]
Openo "E:\IMPORT\" + LFILE_W  Using [ZIMP_W]
Return

# Cierra fichero a Generar cuando termine
$CERRAR_FICHERO_W
Openo Using [ZIMP_W]
Return

