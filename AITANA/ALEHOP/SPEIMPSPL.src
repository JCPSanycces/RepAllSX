#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
 When "EXP_OUVRE"     : Gosub EXP_OUVRE
 When "EXP_ZONE"      : Gosub EXP_ZONE
 When "AP_IMPORT"     : Gosub AP_IMPORT
Endcase
Return

$EXP_OUVRE
If clalev([F:ZITM])=0    : Local File ITMMASTER    [ZITM]   : Endif
Return

$EXP_ZONE
If EXPZON='GIMP(2)'
    Read [F:ZITM]ITM0 = [F:SPL]PLICRI1
    GIMP(2)=[F:ZITM]ITMDES1
Endif
Return

$AP_IMPORT
    [F:SPL]ZAQSEXP=[F:SPL]ZMARCA
    [F:SPL]ZGESEXP=[F:SPL]ZMARCA
Return




