###############################################################################
###############################################################################
#**
#* Generar fichero Impresión Etiquetas Pedido Compra
#*
#* @param NUMPOH Pedido de compras a imprimir Etiquetas
#*!
Subprog PRINT_POHLAB (PNUM)
Value Char PNUM

Local Char    LDIRLABELS(250) : LDIRLABELS = "E:\IMPORT\IMP\"
Local Char    LFILE(20)       : LFILE = LDIRLABELS + "labels.txt"

If !clalev([ZPOQ]) : Local File PORDERQ [ZPOQ] : Endif

Filter [ZPOQ] Where [ZPOQ]POHNUM = PNUM
For [ZPOQ]POQ0
  Local Integer CANTIDAD : CANTIDAD = [ZPOQ]QTYSTU
  While CANTIDAD <> 0
    CANTIDAD -= 1
  Wend
Next

Filter [ZPOQ]

Gosub OPEN_FILE
Wrseq "hola" Using [ZIMP]
Gosub CLOSE_FILE

End

########################################################
$OPEN_FILE

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE Using [ZIMP]

Return

########################################################
$CLOSE_FILE

Openo Using [ZIMP]

Return

