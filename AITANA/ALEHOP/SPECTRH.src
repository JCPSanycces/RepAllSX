#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif

  Case ACTION
    When "CREATION"     : Gosub CREATION
    When "MODIF"        : Gosub MODIF
    When "FILGAUCHE"    : Gosub FILGAUCHE
    When Default
  Endcase
Return

$CREATION
#----------------------------------#
# Container creation               #
#----------------------------------#
# Issue 110325
Local Integer I
# Collection reinit in case of modification after a first creation with error
For I=1 To maxtab(WCONTAINER.CTRD)
  If (WCONTAINER.CTRD(I) <> null and find(WCONTAINER.CTRD(I).ASTALIN, [V]CST_ADEL, [V]CST_ANEWDEL) = 0)
    WRET=fmet WCONTAINER.ADELLINE ("CTRD", WCONTAINER.CTRD(I).AORDER)
    If WRET<>[V]CST_AOK
      GMESSAGE = func ASYRFNC.MES2(mess(273,133,1),'CTRD','CONTAINER')
      GOK=0 : GERR=1
      Return
    Endif
    Endif
Next
# End issue 110325
Gosub CREATION From TABLEAUX
If GOK<1 : Return : Endif
#--- Assign the class properties
SetInstance WCONTAINER With [F:CTRH]
WCONTAINER.BPSNUM = [M:CTRH2]BPSNUM
#--- AINSERT method
MY_STATUS = fmet WCONTAINER.AINSERT()
If [L]MY_STATUS >= [V]CST_AERROR
  Call GET_ERRORS(WCONTAINER)
  If GOK=0 : Return : Endif
Endif
#--- Affect the [M]class with the Syracuse class
[M:CTRH2]CUR  = WCONTAINER.CUR
[M:CTRH2]TOTLINAMT = WCONTAINER.TOTLINAMT
[M:CTRH2]TOTLINWEU = WCONTAINER.TOTLINWEU
[M:CTRH2]TXWOU = WCONTAINER.TXWOU
[M:CTRH2]TXWOU2 = WCONTAINER.TXWOU2
[M:CTRH2]TOTLINVOU = WCONTAINER.TOTLINVOU
[M:CTRH2]MAXWEI = WCONTAINER.MAXWEI
[M:CTRH2]USFVOL = WCONTAINER.USFVOL
# Issue 111256 US2
[M:CTRH2]TCTRVOL = WCONTAINER.TCTRVOL
[M:CTRH2]CRRWEI = WCONTAINER.CRRWEI
[M:CTRH2]AVAWEI = WCONTAINER.AVAWEI
[M:CTRH2]AVAVOL = WCONTAINER.AVAVOL
[M:CTRH2]TARWEI = WCONTAINER.TARWEI
# End issue 111256 US2

# 03/12/2018 - MS - Z613  Planta de Recepción del contenedor
[M:CTRH]ZRFCY = WCONTAINER.ZRFCY
# Fin Z613

[M:CTRH]CTRNUM = WCONTAINER.CTRNUM
If [F:CTRH]CTRNUM = AVOID.ACHAR : [F:CTRH]CTRNUM = [M:CTRH]CTRNUM : Endif
#--- Refresh the fields not in Syracused Class
#I must go to LIENS and not LIENS_SCR, modif after creation don't work
Gosub LIENS From SUBCTRHA
Return

End

#-------------------------------------------------------------#
$MODIF
#--------------------------------------#
# Modification container               #
#--------------------------------------#
Gosub MODIF From TABLEAUX : If GOK<1  Return : Endif
#--- Assign the Syracuse class with [M]class
WCONTAINER.CTRUID=[M:CTRH]CTRUID
WCONTAINER.FCY=[M:CTRH2]FCY
WCONTAINER.BPSNUM=[M:CTRH2]BPSNUM
WCONTAINER.TCTRNUM = [M:CTRH2]TCTRNUM
WCONTAINER.FULFLG = [M:CTRH2]FULFLG
WCONTAINER.SEANUM1 = [M:CTRH2]SEANUM1
WCONTAINER.SEANUM2 = [M:CTRH2]SEANUM2
WCONTAINER.SEANUM3 = [M:CTRH2]SEANUM3
# 03/12/2018 - MS - Z613  Planta de Recepción del contenedor
WCONTAINER.ZRFCY = [M:CTRH]ZRFCY
# Fin Z613

MY_STATUS = fmet WCONTAINER.AUPDATE()
#--- AUPDATE method
If [L]MY_STATUS >= [V]CST_AERROR
  Call GET_ERRORS(WCONTAINER)
  If GOK=0 : Return : Endif
Endif
#--- Affect the [M]class with the Syracuse Class
[M:CTRH2]CUR  = WCONTAINER.CUR
[M:CTRH2]TOTLINAMT = WCONTAINER.TOTLINAMT
[M:CTRH2]TOTLINWEU = WCONTAINER.TOTLINWEU
[M:CTRH2]TXWOU = WCONTAINER.TXWOU
[M:CTRH2]TXWOU2 = WCONTAINER.TXWOU2
[M:CTRH2]TOTLINVOU = WCONTAINER.TOTLINVOU
[M:CTRH2]MAXWEI = WCONTAINER.MAXWEI
[M:CTRH2]USFVOL = WCONTAINER.USFVOL
# Issue 111256 US2
[M:CTRH2]TCTRVOL = WCONTAINER.TCTRVOL
[M:CTRH2]CRRWEI = WCONTAINER.CRRWEI
[M:CTRH2]AVAWEI = WCONTAINER.AVAWEI
[M:CTRH2]AVAVOL = WCONTAINER.AVAVOL
[M:CTRH2]TARWEI = WCONTAINER.TARWEI
# End issue 111256 US2

# 03/12/2018 - MS - Z613  Planta de Recepción del contenedor
[M:CTRH]ZRFCY = WCONTAINER.ZRFCY
# Fin Z613

[M:CTRH]CTRNUM = WCONTAINER.CTRNUM

#--- Refresh the fields not in Syracused Class
If !GIMPORT Gosub LIENS_SCR From SUBCTRHA  Endif
Return


###############################################################################
$FILGAUCHE

Gosub FILGAUCHE From SUBCTRHA

# -----------------------------------------------------------------------------
# 05/09/2019 - MS - Z708  Filtro fecha ETS en Criterios Picking Contenedor
If (GREP="C" | GREP="D" | GREP="1" | [M:CTRH]CTRNUM<>"") & GBIDI2=1
  #----- Purchase order picking -----#
  If currbox=GBOXPO6
    If num$([M:PLCW]ZFECHETSDEB)<>"00/00/0000"
      FILGAUSUP(3)-="& nday([F:POH]ZFECHETIQUET)>=nday([M:PLCW]ZFECHETSDEB)"
    Endif
    If num$([M:PLCW]ZFECHETSFIN)<>"00/00/0000"
      FILGAUSUP(3)-="& nday([F:POH]ZFECHETIQUET)<=nday([M:PLCW]ZFECHETSFIN)"
    Endif
  Endif
Endif
GPE = 1   # Desactivamos el proceso estándar
# Fin Z708 --------------------------------------------------------------------

Return


######################################################################################

#------------------------------------#
#--- Get the errors                  #
#------------------------------------#
Subprog GET_ERRORS(WCONTAINER)
Variable Instance WCONTAINER Using C_CONTAINER

Local Integer I
Local Char WTEXTE(50)

 GMESSAGE = func LCCLIB.MAXMSG(WCONTAINER)
 If GMESSAGE = AVOID.ACHAR
   #--- Lines errors
  For I=1 To maxtab(WCONTAINER.CTRD)
    GMESSAGE = func LCCLIB.MAXMSG(WCONTAINER.CTRD(I))
    If GMESSAGE <> AVOID.ACHAR
      Call TEXTE(53658, WTEXTE) From OBJDIV
      GMESSAGE = WTEXTE + " : " + GMESSAGE
      Break:  Endif
  Next I
Endif
GOK=0 : GERR=1

End

