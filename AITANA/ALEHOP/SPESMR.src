#<AdxTL>@(#)0.0.0.0 $Revision$ Miscellaneous receipts
#XVT09/01/2019 BotĂłn para crear abono/factura para devoluciones de Canarias/Franquicias
#XVT29/11/2019 Cambio en facturas /abonos de canarias: en lugar de usar la descripciĂłn para
#ligar la factura/abono con la entrada varia, se usarĂˇ el propio cĂłdigo de la entrada varia
#XVT16/12/2019 Deshacer el cambio anterior, ya que se pueden realizar devoluciones de mĂˇs de
#300 lĂ­neas, por lo que el cambio anterior ya no tiene sentido. Solicitado por David SUPPORT-2852
#CGB14/02/2019 Incluir  modificacion en Entrada para poner nÂş de Factura Generada en la Entrada (campo ZFACORIGEN)
#EAP24/03/2020 Utilizar el PVM en la generaciĂłn del fichero de Fact/Ab. en caso de que el indicado en la lĂ­nea sea 0
#EAP10/07/2020 Llevar el nÂşde fra rectif. (mid$([M:SMR0]VCRDES,18,len([M:SMR0]VCRDES)-17)
#EAP29/07/2020 Error si no se informa el nÂş de factura en descripciĂłn. (SUPPORT-3675)
######################################################################################
$ACTION
#Infbox ACTION
Case ACTION
  When "SETBOUT"     : Gosub SETBOUT
  When "EXEBOUT"     : Gosub EXEBOUT
  When "AVANTBOUT"   : Gosub AVANTBOUT
  When Default
Endcase
Return

######################################################################################
$SETBOUT

#> ALEHOP-452 MA 20180605 - controlar el valor de un botĂłn
If !clalev([S0]) : Local File SMVTH [S0] : Endif
Local Integer LBLOQ : LBLOQ = 1  # decide si hay que bloquear el botĂłn. 1:no | 2:si
Local Integer LBLOQALL : LBLOQALL = 1 # Cesar 190220 - Si el tipo de Entrada/Salida es 11 o 24 hay que bloquearlo todo

# solo se puede activar si es un movimiento 12
#If 1 = 2 Then
#  If [M:SMR0]TRSFAM <> "12" Then
#    LBLOQ = 2
#
#  Else
#    # si el movimiento es 12 su descripciĂłn no estĂˇ repetida con un movimiento de entrada 11
#    Filter [S0] Where [S0]TRSFAM = "11" and [S0]VCRDES = [M:SMR0]VCRDES
#    If rowcount([S0]) > 0 Then
#      LBLOQ = 2
#    Endif
#    Filter [S0]
#
#    If LBLOQ <> 2 Then
#      # las lĂ­neas deben estar en Q y en MUELLE, cualquier otra cosa es error
#      If find("Q",[M]STA(0..[M]NBLIG-1)) = 0 or find("MUELLE",[M]LOC(0..[M]NBLIG-1)) = 0 Then
#        LBLOQ = 2
#      Endif
#    Endif
#  Endif
#Endif

#XVT09/01/2019.bn
#If ([M:SMR0]TRSFAM = "11" or [M:SMR0]TRSFAM = "12") and (left$([M:SMR0]VCRDES,1)="F" or left$([M:SMR0]VCRDES,1)="C") Then
If ([M:SMR0]TRSFAM = "12") and (left$([M:SMR0]VCRDES,1)="F" or left$([M:SMR0]VCRDES,1)="C") Then
  Local Integer DVCF
  DVCF=0
  If !clalev([ZSIV]) : Local File SINVOICEV [ZSIV] : Endif
  #xvt29/11/2019.o For [SIV] Where [SIV]INVREF = [M:SMR0]VCRDES
  #For [SIV] Where [SIV]INVREF = [M:SMR0]VCRNUM #xvt29/11/2019.n
  #For [SIV] Where [SIV]INVREF = [M:SMR0]VCRDES #xvt16/12/2019.n
  #Infbox "el valor de la pantalla es " + num$([M:SMR0]VCRNUM)
  For [ZSIV] Where [ZSIV]ZDEVSMR = [M:SMR0]VCRNUM #xvt16/12/2019.n
    #Infbox "la factura es " + num$([ZSIV]ZDEVSMR)
    DVCF+=1
  Next
  If !DVCF : CHMEN+="d" : Endif
Endif
#XVT09/01/2019.en

# bloquea botĂłn "en preparaciĂłn"
If LBLOQ = 2 or GREP = "C" or GREP = "M" Then
  Call VIREBOUT(CHAINE,"Z") From GOBJET
Endif

#Cesar 190220 - Comprobamos si las Entradas Salidas son tipo 11 o 24
#Infbox "GFONCTION ES " + GFONCTION
If GFONCTION = "GESSMR" Then
If GFLAG<>"ALL" Then
If [M:SMR0]TRSFAM = "11" Then
  LBLOQALL = 2
  #Infbox "El movimiento viene generado automaticamente ya que el tipo es  " + num$([M:SMR0]TRSFAM)
  Grizo[M:SMR0]
  #Infbox "VAMOS A BLOQUEAR LA PANTALLA"
  Grizo[M:SMR1]
Else
  Actzo[M:SMR0]
  #Infbox "VAMOS A DESBLOQUEAR LA PANTALLA"
  Actzo[M:SMR1]
Endif
Endif
Else
If GFONCTION = "GESSMO" Then
If [M:SMO0]TRSFAM = "24" Then
  LBLOQALL = 2
  #Infbox "El movimiento viene generado automaticamente ya que el tipo es  " + num$([M:SMR0]TRSFAM)
  Grizo[M:SMO0]
  #Infbox "VAMOS A BLOQUEAR LA PANTALLA"
  Grizo[M:SMO1]
Else
  Actzo[M:SMO0]
  #Infbox "VAMOS A DESBLOQUEAR LA PANTALLA"
  Actzo[M:SMO1]
Endif
Endif
Endif

# 21042020 - MS - ALEHOP-1296 - Totalizar PVM ---------------------------------
If GFLAG <> 'EDV'
  Chgfmt [M:SMR0]ZTOTALPVM With "-K:10"
Else
  Local Integer NOL
  [M:SMR0]ZTOTALPVM = 0
  For NOL=0 To [M:SMR1]NBLIG-1
    [M:SMR0]ZTOTALPVM  += [M:SMR1]ZPVMDEV(NOL) * [M:SMR1]QTYSTU(NOL)
    Affzo [M:SMR0]ZTOTALPVM
  Next
Endif
#------------------------------------------------------------------------------

Close Local File [S0]
Return

######################################################################################
$EXEBOUT
#Infbox REP
Case REP
  When "Z" : # en preparaciĂłn
    #Gosub GEN_PREPARA
    Call GEN_ENTSAL([M:SMR0]VCRTYP, [M:SMR0]VCRNUM) From ZGENENTSAL
Endcase
Return

#XVT09/01/2019.bn
$AVANTBOUT
Case BOUT
  When "d" : Gosub FACDEV
Endcase
#XVT09/01/2019.en
Return

######################################################################################
#**
#* Proceso para generar movimientos en preparaciĂłn
#*!
$GEN_PREPARA
  Infbox "Falta poco, paciencia...."
Return

$FACDEV
  Local Char    LDIREXPORT(100)
  Local Char    LFILE(200)
  Local Char    LDATLIN(250)
  Local Integer NOL : NOL=0
  Local Char    ZPVM

  If !clalev([F:ZBPR]) : Local File BPARTNER[ZBPR] : Endif
  If !clalev([ZPM]) : Local File ZPVPT50[ZPM] : Endif                  #EAP 240320 be

  Local Char CLIENTE(5) : Raz CLIENTE
  Local Char LDATLIN(200)
  Local Char NFACTURA: Raz NFACTURA
  Local Char RFACTURA: Raz RFACTURA #EAP10/07/2020.N

  LDIREXPORT="E:\IMPORT\IMP\"
  LFILE=LDIREXPORT + "EDV_" + [M:SMR0]VCRNUM + ".TXT"

  adxifs = ";"
  adxirs = chr$(13)+chr$(10)
  Openo LFILE Using [ZEXP]
  #CANARIAS O FRANQUICIA?
  Case left$([M:SMR0]VCRDES,1)
  When "C" Then
  #canarias
    #ESCRIBIR CABECERA FACTURA
    #xvt29/11/2019.o Wrseq  "V;" + left$([M:SMR0]VCRDES,5) + ";FV;" + [M:SMR0]VCRDES + ";" + format$("D:YYYYMMDD",date$) + ";90001;1" Using [ZEXP]
    #XVT16/12/2019.o Wrseq  "V;" + left$([M:SMR0]VCRDES,5) + ";FV;" + [M:SMR0]VCRNUM + ";" + format$("D:YYYYMMDD",date$) + ";90001;1" Using [ZEXP] #xvt29/11/2019.n
    #Wrseq  "V;" + left$([M:SMR0]VCRDES,5) + ";FV;" + [M:SMR0]VCRDES + ";" + format$("D:YYYYMMDD",date$) + ";90001;1" Using [ZEXP] #XVT16/12/2019.N
    #Wrseq  "V;" + left$([M:SMR0]VCRDES,5) + ";FV;" + [M:SMR0]VCRDES + ";" + format$("D:YYYYMMDD",date$) + ";90001;1;" + [M:SMR0]VCRNUM
    #Using [ZEXP] #XVT16/12/2019.N
    #RFACTURA = mid$([M:SMR0]VCRDES,18,len([M:SMR0]VCRDES)-17) #EAP10/07/2020.N
    RFACTURA = right$([M:SMR0]VCRDES,18) #EAP SUPPORT-3675
    Wrseq  "V;" + left$([M:SMR0]VCRDES,5) + ";FV;" + RFACTURA + ";" + format$("D:YYYYMMDD",date$) + ";90001;1;" + [M:SMR0]VCRNUM Using [ZEXP] #EAP10/07/2020.N
  When "F" Then
  #franquicia
    #ESCRIBIR CABECERA ABONO
    Filter [F:ZBPR] Where FCY=left$([M:SMR0]VCRDES,5)      # Filter [BPR] Where FCY=left$([M:SMR0]VCRDES,5) EAMP030720
    Read     [F:ZBPR] First
    If !fstat Then
        CLIENTE=[F:ZBPR]BPRNUM                             #[F:BPR]BPRNUM EAMP030720
    Else Call MESSAGE ("TERCERO NO ENCONTRADO", 0) From GESECRAN
    Endif
    Filter [F:ZBPR]                                        #Filter [BPR] EAMP030720
    #xvt29/11/2019.o LDATLIN = "V;OF001;AV;" + [M:SMR0]VCRDES + ";" + format$("D:YYYYMMDD",date$) + ";" + CLIENTE +  ";1"
    #XVT16/12/2019.o LDATLIN = "V;OF001;AV;" + [M:SMR0]VCRNUM + ";" + format$("D:YYYYMMDD",date$) + ";" + CLIENTE +  ";1"  #xvt29/11/2019.n
    #LDATLIN = "V;OF001;AV;" + [M:SMR0]VCRDES + ";" + format$("D:YYYYMMDD",date$) + ";" + CLIENTE +  ";1;" + [M:SMR0]VCRNUM #XVT16/12/2019.n
    #RFACTURA = mid$([M:SMR0]VCRDES,18,len([M:SMR0]VCRDES)-17) #EAP10/07/2020.N
    RFACTURA = right$([M:SMR0]VCRDES,18) #EAP SUPPORT-3675
    LDATLIN = "V;OF001;AV;" + RFACTURA + ";" + format$("D:YYYYMMDD",date$) + ";" + CLIENTE +  ";1;" + [M:SMR0]VCRNUM #EAP10/07/2020.N
    Wrseq LDATLIN Using [ZEXP]
  When Default
  Endcase
  #ESCRIBIR LĂŤNEAS DE FACTURA
  For NOL=0 To [M:SMR1]NBLIG-1
    ZPVM="0.0"
    If [M:SMR1]ZPVMDEV(NOL)<> 0 Then
      ZPVM=num$([M:SMR1]ZPVMDEV(NOL))
    Else                                 #EAP 240320 14:27 b
      Read [ZPM]ZP0=[M:SMR1]ITMREF(NOL)
      If !fstat Then
        ZPVM=num$([ZPM]PT50)
      Else
        ZPVM="0.0"
      Endif                              #EAP 240320 14:27 e
    Endif
    Wrseq "D;" + [M:SMR1]ITMREF(NOL) + ";UN;" + num$([M:SMR1]QTYSTU(NOL))
&              + ";" + ZPVM
&  Using [ZEXP]
  Next
  Close Local File [ZPM] #EAP 240320 14:27 be

  ##cerrar fichero si estaba abierto.
  Openo Using [ZEXP]
  #Infbox "Vamos a llamar al modelo de importaciĂłn."
  Call IMPORTSIL("ZDEVSIH", LFILE) From GIMPOBJ
  #Infbox "Vamos a buscar la factura"
  #Si el modelo de importaciĂłn ha ido bien
  If GERRTRACE = 0 Then
    NFACTURA = ""
    If clalev([SIV]) = 0 : Local File SINVOICEV [SIV] : Endif  # Abrimos la tabla de Facturas y buscamos el Numero de Entrada que ha escrito el modelo
    Filter [SIV] Where ZDEVSMR = [M:SMR0]VCRNUM
    Read [SIV] First
    If !fstat Then
      # Nos quedamos con el numero de Factura generada
      NFACTURA=[F:SIV]NUM
    Endif
    #Aqui ya tenemos el numero de Factura que se ha generado-Vamos a escibir este dato en la entrada
    Close Local File [SIV]

    #Vamos a buscar la Entrada para ponerle el numero de Factura
    If clalev([ZSMH]) = 0 : Local File SMVTH [ZSMH] : Endif  # Abrimos la tabla de Entradas
    #Buscamos la entrada actual
    Filter [ZSMH] Where VCRNUM = [M:SMR0]VCRNUM and VCRTYP = [M:SMR0]VCRTYP  #MS 20200803 ALEHOP-1340
    Read [ZSMH] First
    If !fstat Then
      #Infbox "El movimiento es " + num$([F:ZSMH]VCRNUM)
      [F:ZSMH]ZFACORIGEN = NFACTURA
      Rewrite [ZSMH]
      #Infbox "Factura escrita en el movimiento"
      [M:SMR0]ZFACORIGEN = NFACTURA
      Affzo[M:SMR0]ZFACORIGEN
    Endif
    GFLAG = 'EDV'   #MS 20200803 ALEHOP-1340
    Close Local File [ZSMH]
  Endif
Return



######################################################################################
## ACCIONES DE CAMPO
######################################################################################

######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

# tablas..
If clalev([F0])=0 : Local File ITMFACILIT    [F0] : Endif
If clalev([V0])=0 : Local File ITMMVT        [V0] : Endif

If VALEUR <> "" and !GIMPORT Then

  Read [F0]ITF0 = VALEUR;[M:SMR0]STOFCY
  If fstat = 0 Then
    # si es PMP o Ăşltimo precio de compra
    If [F0]VLTCOD = "AVC" or [F0]VLTCOD = "UPC" Then
      # limpia valores..
      Raz [M:SMR1]PRI(nolign-1), [M:SMR1]PRIORD(nolign-1)

      Read [V0]ITV0 = VALEUR;[M:SMR0]STOFCY
      If fstat = 0 Then
        # si es PMP
        If [F0]VLTCOD = "AVC" Then
          [M:SMR1]PRI(nolign-1)    = [V0]AVC
          [M:SMR1]PRIORD(nolign-1) = [V0]AVC
        Endif

        # si es Ăşltimo precio de compra
        If [F0]VLTCOD = "UPC" Then
          [M:SMR1]PRI(nolign-1)    = [V0]LASPURPRI
          [M:SMR1]PRIORD(nolign-1) = [V0]LASPURPRI
        Endif
      Endif

      # actualiza valores
      Affzo [M:SMR1]PRI(nolign-1)
      Affzo [M:SMR1]PRIORD(nolign-1)
    Endif

 Endif

Endif

# cierre de tablas..
Close Local File [V0],[F0]
End

######################################################################################
Subprog C_STA(VALEUR)
Variable Char    VALEUR()

# si es una entrada en devoluciĂłn
If [M:SMR0]TRSFAM = "12" and VALEUR <> "Q" Then
  GERR = 1
  GMESSAGE = "El estado debe ser Q en entradas de devoluciĂłn"
Endif

# entrada en ordenaciĂłn
If [M:SMR0]TRSFAM = "11" and VALEUR <> "A" Then
  GERR = 1
  GMESSAGE = "El estado debe ser A en entradas de ordenaciĂłn"
Endif

End

######################################################################################
Subprog C_LOC(VALEUR)
Variable Char    VALEUR()

# si es una entrada en devoluciĂłn
If [M:SMR0]TRSFAM = "12" and VALEUR <> "MUELLE" Then
  GERR = 1
  GMESSAGE = "La ubicaciĂłn debe ser MUELLE en entradas de devoluciĂłn"
Endif

# entrada en ordenaciĂłn
If [M:SMR0]TRSFAM = "11" and VALEUR <> "MUELLE" Then
  GERR = 1
  GMESSAGE = "La ubicaciĂłn debe ser MUELLE en entradas de ordenaciĂłn"
Endif
End


######################################################################################

