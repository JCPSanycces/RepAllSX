#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

Case ACTION
 When "GENPURORD" : Gosub $GENPURORD

 When Default
Endcase
Return

# Generación de una order de compra desde una solicitud

$GENPURORD

  [F:POH]ZPRODUCTO = [F:PSH]ZPRODUCTO

  If [F:POH]ZRCPFCY = "" Then

      If clalev([ZADW])  = 0 : Local File ADOVAL    [ZADW]  : Endif # valores parámetros
      Filter [ZADW] Where [ZADW]PARAM = 'ZFCYPPAL'
      Read [ZADW] First
      If !fstat Then
         [F:POH]ZRCPFCY = num$([ZADW]VALEUR)
      Endif
      Filter [ZADW]
  Endif

Return

