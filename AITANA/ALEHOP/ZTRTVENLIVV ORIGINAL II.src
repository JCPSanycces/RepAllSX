#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION
  When "AFTSDHVAL"  : Gosub GENERAR_RECEPCION
  When Default
Endcase
Return


#########################################################
$GENERAR_RECEPCION

Local Char    LFILE(200)
Local Char    LDIRIMPORT(250) : LDIRIMPORT = "E:\IMPORT\IMP\"
Local Integer RECEPCIONAR

Infbox("DENTRO GENERAR_RECEPCION "+[F:SDH]SDHNUM)


If [F:SDH]PRHFCY<>"" Then  # comprobamos que la entrega es Interplanta
  Gosub GEN_PTH             # generar fichero
  Gosub IMP_PTH             # importar fichero
Endif

Return

#########################################################
# generar fichero
$GEN_PTH

Infbox("DENTRO GENERAR FICHERO")

Local Char LDATCAB(30)(10),LDATLIN0(30)(10),LDATLIN1(30)(10)
Local Char LFECHA(10), LHORA(10)

LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)


# ruta del fichero..
LFILE  = LDIRIMPORT + "PTH_"+LFECHA+"_"+LHORA+".txt"

Gosub OPEN_FILE

# Modelo Importacón ZPTH
#Id,Tabla     Campo   Descripción
# E PRECEIPT  /
# E PRECEIPT  PRHFCY  Planta recepción
# E PRECEIPT  RCPDAT  Fecha recepción
# E PRECEIPT  PTHNUM  Nº recepción
# E PRECEIPT  BPSNUM  Proveedor             Cte. 90001
# E PRECEIPT  TRSCOD  Código movimiento     Cte. REC
# E PRECEIPT  BPSNDE  N. VE proveedor       Nº entrega de la Central
# E PRECEIPT  ZENPIC  Recepción en PIC      0 y 1 no Traspasado, 2 Traspasado
# L PRECEIPTD /                             0 Indica recepcion grabada desde X3
# L PRECEIPTD ITMREF  Artículo
# L PRECEIPTD UOM     Unidad recepción
# L PRECEIPTD QTYUOM  Cantidad UOM
# L PRECEIPTD GROPRI  Precio bruto
# L PRECEIPTD CPRAMT  Coste fijo unitario
# L PRECEIPTD TRSFAM  Familia movimiento    Cte. 10
# S STOJOU  /
# S STOJOU    PCU     Unidad
# S STOJOU    QTYPCU  Cantidad              Igual que QTYUOM
# S STOJOU    LOC     Ubicación             Cte. TIENDA
# S STOJOU    STA     Estado                Cte. A

# Ejempo de Fichero
# E;P0003;20180507;;90001;REC;EPALM0118000019
# L;9054201;UN;100;8.12;8.12;10
# S;UN;100;TIENDA;A

Infbox([F:SDH]SDHNUM)

If clalev([ZENTR]) = 0 : Local File ZSDHPTH [ZENTR] : Endif # vista que filtra entregas interplanta
                                                            # validadas y que no tengan recepción de
                                                            # compra asociada

For [ZENTR]

  LDATCAB(1) = [ZENTR]PRHFCY
  LDATCAB(2) = [ZENTR]SHIDAT
  LDATCAB(3) = ""
  LDATCAB(4) = "90001"
  LDATCAB(5) = "REC"
  LDATCAB(6) = [ZENTR]SDHNUM
  LDATCAB(7) = "1"

  Wrseq '"E";' +'"'+LDATCAB(1)+'";' +'"'+LDATCAB(2)+'";' +'"'+LDATCAB(3)+'";' +'"'+LDATCAB(4)+'";' +'"'+LDATCAB(5)+'";' +'"'+LDATCAB(6)+'";' +'"'+LDATCAB(7)+'";' Using [ZIMP]

  Filter [SDD] Where [SDD]SDHNUM = [ZENTR]SDHNUM

  For [F:SDD]

    Raz  LDATLIN0, LDATLIN1

    LDATLIN0(1) = [F:SDD]ITMREF
    LDATLIN0(2) = [F:SDD]STU
    LDATLIN0(3) = num$([F:SDD]QTYSTU)
    LDATLIN0(4) = num$([F:SDD]GROPRI)      # Revisar con rcejudo
    LDATLIN0(5) = num$([F:SDD]GROPRI)      # Revisar con rcejudo
    LDATLIN0(6) = "10"

    Wrseq '"L";' +'"'+LDATLIN0(1)+'";' +'"'+LDATLIN0(2)+'";' +'"'+LDATLIN0(3)+'";' +'"'+LDATLIN0(4)+'";' +'"'+LDATLIN0(5)+'";' +'"'+LDATLIN0(6)+'";' Using [ZIMP]

    LDATLIN1(1) = [F:SDD]STU
    LDATLIN1(2) = num$([F:SDD]QTYSTU)
    LDATLIN1(3) = "TIENDA"
    LDATLIN1(4) = "A"

    Wrseq '"S";' +'"'+LDATLIN1(1)+'";' +'"'+LDATLIN1(2)+'";' +'"'+LDATLIN1(3)+'";' +'"'+LDATLIN1(4)+'";' Using [ZIMP]

  Next

  Filter [SDD]

Next

# cerrar fichero import
Gosub CLOSE_FILE

Return


#########################################################
# importar fichero
$IMP_PTH

Infbox("DENTRO IMPORTACION FICHERO")

mkstat = 0 : fstat = 0 : GERRTRACE = 0

Call OUVRE_TRACE("Creación Recepcion a partir de Entrega Validada") From LECFIC


Call IMPORTSIL("ZPTH", LFILE) From GIMPOBJ


Call FERME_TRACE From LECFIC

Call LEC_TRACE From LECFIC   #si se quiere mostrar traza

mkstat = 0 : fstat = 0 : GERRTRACE = 0

Return


########################################################
$OPEN_FILE

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE Using [ZIMP]

Return


########################################################
$CLOSE_FILE

Openo Using [ZIMP]

Return

