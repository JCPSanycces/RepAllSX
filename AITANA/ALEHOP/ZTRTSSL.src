#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION
 When "BOUTON"    : Gosub BOUTON
 When Default
Endcase
Return


######################################################################################
$BOUTON
Local Integer LCON

If BOUT = "J"        # Excluir todo
  Gosub DEL_SRGSGW
Endif

Return


######################################################################################
# Elimina líneas del STOSRGW -detalle - y STOSRG -cabecera- Lista Ordenación
$ DEL_SRGSGW
Local Integer LCON

If clalev([ZSRGW]) = 0   : Local File STOSRGW [ZSRGW]   : Endif     # eliminamos registros de STOSRGW

Trbegin [ZSRGW]

Delete [F:ZSRGW] Where [F:ZSRGW]SRGPPS = [M:SSL1]SRGPPS

If fstat = 1
  Rollback
Else
  Commit
  Rewrite [F:ZSRGW]

  If clalev([ZSRG]) = 0   : Local File STOSRG [ZSRG]   : Endif      # actualizamos registros de STOSRG

  For LCON = 0 To [M:SSL1]NBLIG-1

        Filter [ZSRG] Where [F:ZSRG]STOCOU = [M:SSL1]STOCOU(LCON) &
&                           [F:ZSRG]VCRTYP = [M:SSL1]VCRTYP(LCON) &
&                           [F:ZSRG]VCRNUM = [M:SSL1]VCRNUM(LCON) &
&                           [F:ZSRG]VCRLIN = [M:SSL1]VCRLIN(LCON)

        Read [ZSRG] First
          If !fstat Then
            [F:ZSRG]SRGPPS = ''
            [F:ZSRG]PCU    = ''
            [F:ZSRG]QTYPCU = 0
            [F:ZSRG]PCUSTUCOE = 0
            [F:ZSRG]QTYSTU    = 0
            [F:ZSRG]CRETIM    = ''
            Rewrite [F:ZSRG]
          Endif

        [M:SSL1]SRGPPS(LCON) = ''
        Affzo [M:SSL1]SRGPPS(LCON)
        Filter [ZSRG]
  Next
  Close Local File [ZSRG]
Endif
Close Local File [ZSRGW]

[M:SSL1]SRGPPSSTR = ''
Affzo [M:SSL1]SRGPPSSTR

Return

