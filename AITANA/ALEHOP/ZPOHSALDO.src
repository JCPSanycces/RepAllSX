#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog TRTPOHCLE(WPOHNUM,WMSGFLG,WRET)
Value    Char    WPOHNUM
Value    Integer WMSGFLG
Variable Integer WRET
#-----
Local    Libelle WORIFLG : WORIFLG=1 : # Appel hors Workflow (annulation suivi)
#-----
If !clalev([F:POQ])  Local File PORDERQ  [POQ] : Endif
#-----
Call DEBTRANS From GLOCK
#-----
$TR_TRTPOHCLE
GOK=1
#Trbegin ADOVAL
Gosub POHCLE
##If GOK=-1  Goto ROLL_TRTPOHCLE : Endif
##If GOK=0   Goto AB_TRTPOHCLE   : Endif
#Commit
#End
##-----
#$ROLL_TRTPOHCLE
##Rollback : Call ROLL From GLOCK
##If GROLL  End  Else  Goto TR_TRTPOHCLE : Endif
##-----
#$AB_TRTPOHCLE
#Rollback
End

#----------------------------------------------------#
# Traitement du solde complet d'une commande d'achat #
#----------------------------------------------------#
$POHCLE
#----- Variables locales -----#
Local Char    WFCY(GLONFCY), WPARAME(10), WMSG(100)
Local Integer WPOPLIN, WLINCLEFLG, WCLELINNBR, WCLEFLG, WFLAG
Local Decimal WORDNOT, WORDATI
Local Libelle WTRAIT
Local Integer SAV_GOK                : [L]SAV_GOK      =GOK
Local Char    SAV_GSOCIETE(GLONCPY)  : [L]SAV_GSOCIETE =GSOCIETE
Local Char    SAV_GLOCALDEV(GLONCUR) : [L]SAV_GLOCALDEV=GLOCALDEV
Local Char    SAV_GFINRSP(GLONFCY)   : [L]SAV_GFINRSP  =GFINRSP
Local Integer SAV_GAPPPOH            : [L]SAV_GAPPPOH  =GAPPPOH
Local Libelle WLOCK
Local Integer SIGN
#-----
GOK=1 : Raz [L]WRET

#----- Contrôle lock logique -----#
Call JELOCKE("POH"+[L]WPOHNUM,[L]WRET) From OBJDIV
If [L]WRET=0
  Lock="POH"+[L]WPOHNUM
###  If fstat        [L]WRET=12 : Gosub TRT_ERR_POHCLE : Return : Endif
  [L]WLOCK=1
Else
  Raz [L]WRET, [L]WLOCK
Endif
#-----
If !clalev([F:POH])  Local File PORDER    [POH] : Endif
If !clalev([F:POP])  Local File PORDERP   [POP] : Endif
If !clalev([F:ITM])  Local File ITMMASTER [ITM] : Endif
If !clalev([F:MVS])  Local File BPSUPPMVT [MVS] : Endif
If !clalev([F:GAC])  Local File GACCOUNT  [GAC] : Endif
If !clalev([F:TCO])  Local File TABCOEFF  [TCO] : Endif
If !clalev([F:ORD])  Local File ORDERS    [ORD] : Endif
If !clalev([M:ORDK]) Local Mask ORDK     [ORDK] : Endif
If !clalev([M:SBCK]) Local Mask SBCK     [SBCK] : Endif
#----- Lecture entête commande d'achat -----#
Read [POH] POH0=[L]WPOHNUM
If fstat
  GOK=0 : [L]WRET=14 : ###Gosub TRT_ERR_POHCLE :
  Goto FIN_POHCLE
Endif
[L]WCLELINNBR=[F:POH]CLELINNBR
[L]WCLEFLG   =[F:POH]CLEFLG
#-----
[L]WFCY=[F:POH]POHFCY
Call GETDEV([L]WFCY)  From DEVSUB : If GFINRSP=""  GFINRSP=[L]WFCY : Endif
Call PARAM([L]WFCY,"APPPOH",[L]WPARAME) From ADOVAL
GAPPPOH=val([L]WPARAME)
#----- Mise à jour indicateur solde sur toutes les lignes de la commande -----#
Raz [L]WORDNOT, [L]WORDATI
For [POQ] POQ0 Where POHNUM=[L]WPOHNUM & LINCLEFLG<>2
  [L]WPOPLIN   =[F:POQ]POPLIN
  [L]WLINCLEFLG=[F:POQ]LINCLEFLG
  Readlock [POQ] Curr
  If fstat=1
    GOK=-1  : GLOCK="$PORDERQ"-[L]WPOHNUM-num$([L]WPOPLIN)
###    [L]WRET=16 : Gosub TRT_ERR_POHCLE : Break
  Elsif fstat
    GOK=0   : Call RSTA("POQ",[L]WPOHNUM-num$([L]WPOPLIN)) From GLOCK
###    [L]WRET=17 : Gosub TRT_ERR_POHCLE : Break
  Endif
  #-----
  # Issue 83217 - 2012-07-02 by SR : Ne sert plus à rien
  # Issue 80684 - 2012-03-14 by MUARN : ne pas solder commande si commande vente en cours de livraison
#  If !clalev([F:SOH])  Local File SORDER  [SOH] : Endif
#  Read [SOH] SOH0=[F:POH]OCNNUM
#  If [F:SOH]LASDLVNUM <> ""
#    GOK=0
#    [L]WRET=23 : Gosub TRT_ERR_POHCLE : Goto FIN_POHCLE
#  Endif

  Gosub MAJ_POQCLE : If GOK<1  Break : Endif
  #-----
  Rewrite [POQ]
  If fstat
    GOK=0   : Call FSTA("POQ") From GLOCK
###    [L]WRET=18 : Gosub TRT_ERR_POHCLE : Break
  Endif
Next
If GOK<1  Goto FIN_POHCLE : Endif
#----- Màj nbre lignes soldées et indicateur solde sur l'entête de la commande -----#
[L]WCLEFLG=[F:POH]CLEFLG
Raz [L]WFLAG
If [F:POH]CLELINNBR<>[F:POH]LINNBR | [F:POH]CLEFLG<>2
  [L]WCLELINNBR=[F:POH]LINNBR : [L]WCLEFLG=2 : [L]WFLAG=1
Endif
If [L]WFLAG=1
  Update [POH] Where POHNUM=[L]WPOHNUM
&              With  CLELINNBR=[L]WCLELINNBR, CLEFLG=[L]WCLEFLG, EXPNUM=[C]EXPORT
  If fstat
    GOK=0   : Call FSTA("POH") From GLOCK
    [L]WRET=15 : ## Gosub TRT_ERR_POHCLE :
    Goto FIN_POHCLE
  Endif
  [F:POH]CLEFLG=[L]WCLEFLG
Endif
#----- Positionnement indicateur "Annulé" sur les lignes de suivi de workflow -----#
If GAPPPOH>1 & [L]WORIFLG=1 & [F:POH]CLEFLG=2 & [F:POH]APPFLG<3
  #----- Uniquement si appel hors évènement de Workflow ! -----#
  If [F:POH]POHTYP=1
    Call ANNULE_SUIVI("POH",mess(654,197,1),1,[L]WRET) From TRTACHDIV1
  Else
    Call ANNULE_SUIVI("POC",mess(654,197,1),1,[L]WRET) From TRTACHDIV1
  Endif
  If GOK<1  Goto FIN_POHCLE : Endif
Endif
#----- Mise à jour en commande dans mvts fournisseurs -----#
Call MAJENC_BPS([F:POH]BPSNUM,3,[F:POH]POHFCY,[F:POH]CUR,[F:POH]CHGTYP,[F:POH]ORDDAT,
&               [F:POH]POHNUM,[L]WORDNOT,[L]WORDATI,[F:POH]TTVORD) From TRTBPMVT
If GOK<1  Goto FIN_POHCLE : Endif
#----- Solde de la commande de vente inter-sites si nécessaire -----#
If [F:POH]SALFCY<>"" & [F:POH]OCNNUM<>""
  If !clalev([F:SOH])  Local File SORDER  [SOH] : Endif
  Read [SOH] SOH0=[F:POH]OCNNUM
  #----- Ne pas solder la commande de vente si déjà soldée -----#
  If !fstat & [F:SOH]ORDSTA<>2
###    Call GENSOH("S",1,[L]WRET) From TRTVENISOC
    If GOK<1
      [L]WRET=22 : ### Gosub TRT_ERR_POHCLE :
      Goto FIN_POHCLE
    Endif
  Endif
Endif
#-----
$FIN_POHCLE
If [L]WLOCK  Unlock="POH"+[L]WPOHNUM : Endif
#----- Rétablissement des globales -----#
GSOCIETE =[L]SAV_GSOCIETE
GLOCALDEV=[L]SAV_GLOCALDEV
GFINRSP  =[L]SAV_GFINRSP
GAPPPOH  =[L]SAV_GAPPPOH
#VPO 19/11/10 FQ69241 pb sur retour erreur workflow signature
If GOK & dim([L]SAV_GOK)>0
    GOK=[L]SAV_GOK
Endif
Return


#-----------------------------------------------------------#
# Mises à jour dans le cas du solde d'une ligne de commande #
# --------------------------------------------------------- #
# - Màj qté commandée de l'article-site                     #
# - Màj engagement                                          #
# - Annulation du workflow                                  #
# - Suppression de l'encours                                #
# - Màj opération de sous-traitance                         #
# - Positionnement du flag solde et date/opérateur modif    #
#-----------------------------------------------------------#
$MAJ_POQCLE
If [F:POQ]RCPQTYPUU<[F:POQ]QTYPUU
  #----- Cumuls des montants restant en commande -----#
  Read [POP] POP0=[F:POQ]POHNUM;[F:POQ]POPLIN;1
  If fstat  Raz [F:POP] : Endif
  [L]SIGN=-1 : Gosub CAL_MVS From SUBPOHA
  #----- Mise à jour de la quantité commandée dans l'article-site -----#
  If [F:POQ]WIPNUM<>""
    Call LECITV([F:POQ]PRHFCY,[F:POQ]ITMREF,"",[L]WRET) From STKLIB
    If GOK<1  [L]WRET=0 : Return : Endif
    If [L]WRET=0
      Update [ITV] Where ITMREF=[F:POQ]ITMREF & STOFCY=[F:POQ]PRHFCY
&                  With ORDSTO-=([F:POQ]QTYSTU-[F:POQ]RCPQTYSTU)
      If fstat  GOK=0 : Call FSTA("ITV") From GLOCK : Return : Endif
    Endif
  Endif
Endif
#----- Mise à jour engagement -----#
[F:POQ]LINCLEFLG=2
Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,-1,2,"POQ2",[L]WMSGFLG,[L]WRET) From TRTACHDIV1
If GOK<1  Return  Else  Raz [L]WRET : Endif
#----- Mise à jour opération de sous-traitance -----#
If find([F:POQ]VCRTYPORI,10,36) : # Si achat sous-traitance
  If [F:POH]POHNUM<>[F:POQ]POHNUM
    Read [POH] POH0=[F:POQ]POHNUM : If fstat Raz [F:POH] : Endif
  Endif
  If [F:POQ]RCPQTYSTU=0
    [M:SBCK]MAJCOD="A"
  Else
    [M:SBCK]MAJCOD="M"
  Endif
  [M:SBCK]VCRNUM=[F:POQ]POHNUM
  [M:SBCK]VCRLIN=[F:POQ]POPLIN
  [M:SBCK]VCRSEQ=[F:POQ]POQSEQ
  If dim([M:SBCK]LINTYP)>0 [M:SBCK]LINTYP = [F:POQ]LINTYP Endif  # FQ 76147 GA 09/2011
  [M:SBCK]BPAADD=[F:POQ]SCOADD
  [M:SBCK]ORDQTY=[F:POQ]RCPQTYSTU : # ligne cde soldée donc qté commandée = qté réceptionnée
  [M:SBCK]ORDDAT=[F:POQ]EXTRCPDAT-[F:POQ]OFS
  [M:SBCK]RCPDAT=[F:POQ]EXTRCPDAT
  Call CONVERT2([F:POH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&               [F:POQ]LINAMT,[M:SBCK]EXTPRI,[L]WRET) From TRTDEV
  [M:SBCK]EXTPRI=arr([M:SBCK]EXTPRI/[F:POQ]QTYSTU,10^-GDECPRI)
  [M:SBCK]OFS   =[F:POQ]OFS
  [M:SBCK]MSGFLG=1
  [M:SBCK]CLEFLG=[F:POQ]LINCLEFLG
  [M:SBCK]VCRNUMORI=[F:POQ]VCRNUMORI # Issue 92866 GA 09/2013
  [M:SBCK]VCRLINORI=[F:POQ]VCRLINORI # Issue 92866 GA 09/2013
  [M:SBCK]VCRSEQORI=[F:POQ]VCRSEQORI # Issue 92866 GA 09/2013
  Call MAJ_SBC From SBCLIB
  If [M:SBCK]CODRET<>0
    GMESSAGE=mess(96,193,1) : GERR=1 : GOK=0 : Return
  Endif
Endif

# solde = suppression affectations
If [F:POQ]LINCLEFLG = 2 : Gosub SUP_MTO_POQ From PURMTOLIB : Endif

#----- Suppression de l'encours -----#
If [F:POQ]WIPNUM<>""
  [M:ORDK]MAJCOD="A"
  [M:ORDK]WIPTYP=[F:POQ]WIPTYP
  [M:ORDK]WIPNUM=[F:POQ]WIPNUM
  [M:ORDK]ITMREF=[F:POQ]ITMREF
  Call WIP From TRTWIP
  If GOK<1  [L]WRET=19 : ### Gosub TRT_ERR_POHCLE :
  Return : Endif
Endif
#-----
[F:POQ]RCPCLEFLG=1
[F:POQ]UPDDAT   =date$
[F:POQ]UPDUSR   =GUSER
[F:POQ]EXPNUM   =[C]EXPORT
#----- Appel du point d'entrée POHCLE solde/désolde ligne de commande -----#
[L]WTRAIT=1 : [L]WCLEFLG=1
Gosub POINT_POHCLE From TRTACHCDE1
#-----
Return

