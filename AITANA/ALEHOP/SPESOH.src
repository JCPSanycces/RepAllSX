Subprog AVANT_NBLIG
  Gosub GET_SOHPVP
End
######################################################################################


######################################################################################
Subprog APRES_NBLIG
  Gosub GET_SOHPVP
End
######################################################################################


######################################################################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR
  Gosub GET_SOHPVP
End
######################################################################################


######################################################################################
$GET_SOHPVP

Local Integer LCONT
Local Decimal LINPVP

If !clalev([ZAI]) : Local File ZAQSITMTAR[ZAI] : Endif

[M:SOH4]ZSOHPVP = 0

For LCONT = 0 To [M:SOH4]NBLIG-1
  Read [ZAI]ZAIA0=[M:SOH4]ITMREF(LCONT)
  If !fstat Then
    LINPVP +=   [ZAI]T50PVP * [M:SOH4]QTY(LCONT)
  Endif
Next LCONT

[M:SOH4]ZSOHPVP = LINPVP

Affzo [M:SOH4]ZSOHPVP

Return
