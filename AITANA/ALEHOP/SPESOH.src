######################################################################################
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif

Case ACTION
  When "ZSOHPVP"  : Gosub GET_SOHPVP
  When "AVANT_CHOI" : Gosub GET_SOHPVP
  When "CREATION"   : Gosub CREATION # SUPPORT-2504.NEW . Texto pedido en cliente no pasa a Pedido de venta en intersociedad

  When Default
Endcase
Return


######################################################################################
# SUPPORT-2504.SNEW - MAB.28102019
$CREATION
If GFONCTION = 'GESPOH' Then # Si venimos de un pedido de compra intercompany
#Infbox "CREATION: " + [M:SOH0]SOHNUM + " - " +[M:SOH0]BPCORD
  # busco pedido de venta que hemos creado
  If !clalev([ZSOH]) Then : Local File SORDER [ZSOH] : Endif
  Filter [F:ZSOH] Where SOHNUM = [M:SOH0]SOHNUM
  Read [F:ZSOH] First
  # busco cliente para ver si tiene texto
  If !clalev([ZBPC]) Then : Local File BPCUSTOMER [ZBPC] : Endif


  Filter [F:ZBPC] Where BPCNUM = [M:SOH0]BPCORD
 # Infbox "Registros encontrados:" + num$(rowcount([ZBPC]))
  Read [F:ZBPC] First
  If fstat = 0 Then
#    Infbox "Dentro de if - texto " + [F:ZBPC]ORDTEX + " - " + [F:ZBPC]BPCNUM
    If [F:ZBPC]ORDTEX <> '' Then
 #     Infbox [F:ZBPC]ORDTEX + " pedido " + [F:ZSOH]SOHNUM
      #[F:ZSOH]SOHTEX1 = [F:ZBPC]ORDTEX
      #[M:SOH0]SOHTEX1 = [F:ZBPC]ORDTEX
      Update [F:ZSOH] Where [F:ZSOH]SOHNUM = [M:SOH0]SOHNUM With [F:ZSOH]SOHTEX1 = [F:ZBPC]ORDTEX
 #     Infbox "NUMERO DE REGISTROS MODIFICADOS:" + num$(adxuprec)
      #Rewrite
 #     Infbox "REGISTRO GRABADO"
    Endif
  Endif
  Close File [ZBPC]
  Close File [ZSOH]


Endif


Return
# SUPPORT-2504.ENEW  - MAB.28102019


######################################################################################
Subprog AS_ITMDES(VALEUR)
Variable Char    VALEUR()

# ESTE CODIGO ESTÁ COMENTADO

If 1 = 2 Then # eliminamos la busqueda de plantas con stock, siempre ALM00 o la de la tienda.

#<- ALEHOP-368  MS 20180525
# solicitan proponer una planta con stock para el artículo introducido en vez de la planta de expedición que propone por defecto
If !clalev([S0]) : Local File STOCK    [S0] : Endif
If !clalev([F0]) : Local File FACILITY [F0] : Endif

Local Char LPLANTA(5)
Local Integer LALMACEN
# 2 Almacén : planta con stock, sin ventas ni compras
# 3 Planta de tienda: planta con stock, ventas y compras.

LALMACEN = func IS_STKFCY([M:SOH2]STOFCY)


# si es una Planta de Tienda no buscamos stock en otra planta
If LALMACEN = 3 Then
  LPLANTA = [SOH2]STOFCY
Endif


# si es un Almacén comprobamos si existe stock
If LALMACEN = 2 Then
  Filter [S0] Where [S0]ITMREF = [M:SOH4]ITMREF(nolign-1) and [S0]STOFCY = [M:SOH2]STOFCY and [S0]QTYSTU > 0
    Read [S0] First
    If !fstat Then
      LPLANTA = [S0]STOFCY
    Endif
  Filter [S0]
Endif


# en caso de no encontrar stock en la planta de expedición, buscamos otro almacen
If LPLANTA = "" Then
  For  [F0] Where ([F0]WRHFLG = 2 and [F0]SALFLG <> 2 and [F0]PURFLG <> 2)      # Almacén (Tipo Stock sin vtas ni compras)
    Filter [S0] Where [S0]ITMREF = [M:SOH4]ITMREF(nolign-1) and [S0]STOFCY = [F0]FCY and [S0]QTYSTU > 0
    Read [S0] First
    If !fstat Then
      LPLANTA = [S0]STOFCY
      Break
    Endif
    Filter [S0]
  Next
Endif


# sino encuentra stock en los Almacenes, se propone la planta de Stock de la cabecera del pedido
# que será el predeterminado del cliente si no se ha cambiado

If LPLANTA = "" Then

#  If clalev([ZADW])  = 0 : Local File ADOVAL    [ZADW]  : Endif # valores parámetros

#  Filter [ZADW] Where [ZADW]PARAM = 'ZFCYPPAL'
#  Read [ZADW] First
#  If !fstat Then
     Infbox("No hay stock en ningún Almacen, se selecciona el "+num$([SOH2]STOFCY))
     [M:SOH4]DSTOFCY(nolign-1) = [SOH2]STOFCY
#    [M:SOH4]DSTOFCY(nolign-1) = num$([ZADW]VALEUR)
#  Else
#    Infbox("Falta informar el Parámetro Almacén Principal en Parametros Generales")
#  Endif
#  Filter [ZADW]
Else
  [M:SOH4]DSTOFCY(nolign-1) = LPLANTA
Endif



Affzo [M:SOH4]DSTOFCY(nolign-1)

Close Local File [S0]
Close Local File [F0]

#-> ALEHOP-368  MS 20180525

Endif

End
######################################################################################


#######################################################################################
#**
#* Comprueba si es un Almacén: planta de Tipo Stock sin compras ni vtas
#*
#* @param ZFCY > planta a comprobar
#*!

Funprog IS_STKFCY (ZFCY)
Value Char ZFCY
Local Integer ZALM      # Valor 2: Almacén

Filter [F0] Where [F0]FCY = ZFCY
Read [F0] First
If [F0]WRHFLG = 2 and [F0]SALFLG <> 2 and [F0]PURFLG <> 2 Then    # Planta de stock, sin vtas ni compras: Almacén
  ZALM = 2
Else
  If [F0]WRHFLG = 2 and [F0]SALFLG = 2 and [F0]PURFLG = 2 Then    # Planta de stock, con vtas y compras
    ZALM = 3
  Endif
Endif

Filter [F0]

End ZALM
