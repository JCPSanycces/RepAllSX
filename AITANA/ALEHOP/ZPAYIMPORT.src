#<AdxTL>@(#)0.0.0.0 $Revision$ 
#XVT08-02-2019 - IMPORTACIÓN DE COBROS/ABONOS DESDE AQS
#ALEHOP-713/ALEHOP-714
#ALEHOP-760 APLICAR REDONDEO A 2 DECIMALES PARA A LA COMISIÓN
#           ES TARJETA SEGÚN PARAMETRIZADO EN TABLA VARIA 6005
# ALEHOP-888.SN - Comisión bancaria mínima - MAB - 10/07/2019

$ACTION
  Gosub ACTION From PAYIMPORT
  Case ACTION
    When 'IMP_OUVRE' Gosub IMP_OUVRE
    When 'AP_IMPORT' Gosub AP_IMPORT
  Endcase
Return

$OUVRE
  Gosub OUVRE From PAYIMPORT
  Gosub IMP_OUVRE
Return

$IMP_OUVRE
  If !clalev([F:ZFCY]) : Local File FACILITY[ZFCY] : Endif
  If !clalev([F:ZBAN]) : Local File BANK[ZBAN] : Endif
  If !clalev([F:ZBPR]) : Local File BPARTNER[ZBPR] : Endif
  If !clalev([F:ZADI]) : Local File ATABDIV[ZADI] : Endif

  Local Char TIENDA(5), BANCO(5), DESTINOCONTABLE(5)
  Local Decimal IMPORTE
  Local Integer ESTARJETA : ESTARJETA=0
  Gosub IMP_OUVRE From PAYIMPORT
Return

$RAZCRE
  Gosub RAZCRE From PAYIMPORT
Return

$VALID
  Gosub VALID From PAYIMPORT
Return

$SAIMSK
  Gosub SAIMSK From PAYIMPORT
Return

$AP_IMPORT
  If IMPFIC="PYH" Then
    Filter [F:ZADI] Where NUMTAB=6005 and A1="TARPAYTYP" and A2 = [F:PYH]PAYTYP
    Read [F:ZADI]First
      If !fstat Then
  #    If [F:PYH]PAYTYP = "SCTAR" Then
      ESTARJETA = 1
      Filter [F:ZADI]
    Else
      ESTARJETA = 0
      Filter [F:ZADI]
      Return
    Endif
    #EN LA LECTURA DE CABECERA
    TIENDA=""
    Filter [F:ZBPR] Where right$([F:ZBPR]FCY,3) = right$([F:PYH]BPR,3)
    If !fstat Then
      For [F:ZBPR]
        TIENDA = [F:ZBPR]FCY #LA TIENDA VIENE INDICADA EN EL TERCERO
        Break
      Next
    Endif
    Filter [F:ZBPR]
    If TIENDA = "" : Return : Endif
    Read [F:ZFCY]FCY0=TIENDA
    If !fstat Then
      BANCO=[F:ZFCY]ZBANTAR
      [F:PYH]BAN=BANCO
      Read [F:ZBAN]BAN0=BANCO
      If !fstat Then
        DESTINOCONTABLE=[F:ZBAN]ZDENCOD
        IMPORTE=ar2([F:ZBAN]DEPRAT*[F:PYH]AMTCUR/100)
        # ALEHOP-888.SN - Comisión bancaria mínima
        If [F:ZBAN]ZCOMMIN <> 0 Then
            LCOMMIN = [F:ZBAN]ZCOMMIN
        Else
            LCOMMIN = 0.01
        Endif
        # ALEHOP-888.EN - Comisión bancaria mínima
        If IMPORTE < LCOMMIN : IMPORTE = LCOMMIN : Endif # ALEHOP-888.NEW - Comisión bancaria mínima
      Endif
    Endif
  Endif
  If ESTARJETA and IMPFIC="PYD"
    If [F:PYD]VCRTYP="" Then
      [F:PYD]DENCOD=DESTINOCONTABLE
      [F:PYD]AMTLIN=IMPORTE
    Endif
  Endif
  If ESTARJETA and IMPFIC="PYA"
    [F:PYA]AMTANA=IMPORTE
  Endif
Return

