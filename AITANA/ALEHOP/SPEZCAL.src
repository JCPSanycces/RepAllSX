#<AdxTL>@(#)0.0.0.0 $Revision$
#EXPORTACIĂ“N FICHERO CAPTADORES ALMACĂ‰N

#LA ESTRUCTURA DEL FICHERO DEBE CONTENER LOS SIGUIENTES CAMPOS:
#
#REFERENCIA
#EAN
#DESCRIPCION
#STOCK
#UNIDADES POR CAJA
#MINIMO DE VENTA
#FECHA DE ALTA
#PICKING
#UNIDADES PENDIENTES DE SERVIR
#NUMERO DE PEDIDOS
#UBICACIONES DE ALMACEN (10 UBICACIONES)
#
#LOS CAMPOS DEBEN DE ESTAR SEPARADOS POR TABULADOR.

#XVT10/10/2019 - realizamos varias modificaciones solicitadas por David Ginestar.
#las ubicaciones no deben contener guiones y debe haber varios tabuladores al final, hasta completar 10 ubicaciones
#XVT30/10/2019 - en el campo del PICKING y las UBICACIONES se quite el 3r dĂ­gito que siempre serĂ  un cero.
#COMO EL 3R DĂŤGITO SIEMPRE ES UN CERO NECESITAMOS QUITAR ESTE PARA QUE SE MUESTRE EL SEXTO


Local Char UBIC(200)
Local Integer POS : POS=0
Local Integer REP : REP=0
Local Char ZUBIPRED(5)    #xvt30/10/2019.n

If !clalev([F:ZCAL]) : Local File ZCAPTALM[ZCAL] :Endif
Local Integer YSTAT

Call OUINON("ExportaciĂłn del maestro para captadores de almacĂ©n. ÂżDesea continuar?",[L]YSTAT) From GESECRAN

If [L]YSTAT=2
  adxifs = chr$(9)
  adxirs = chr$(13)+chr$(10)
  Openo "E:\EXPORT\CAPTADORES\ARTALM3.txt",0 Using [ZEXP]

  For [F:ZCAL]

  #######################
  UBIC=""
  If !clalev ([F:ZVL]) : Local File ZVLOC[ZVL] : Endif
  Filter [F:ZVL] Where ZVITMREF=[F:ZCAL]ITMREF
  REP=0 # MAB.17102019.NEW
  For [F:ZVL]
    REP+=1
    If REP <=10 Then
  #  If GUSER="JVIDA" or GUSER="ADMIN" Then
  #    If [F:ZCAL]ITMREF="9551202" Then
  #      Infbox [F:ZVL]ZVLOC
  #      Infbox left$(vireblc(ctrans([F:ZVL]ZVLOC,"-",""),2),2) + right$(vireblc(ctrans([F:ZVL]ZVLOC,"-",""),2),4)
  #    Endif
  #  Endif
#xvt30/10/2019.o      UBIC = UBIC + vireblc([F:ZVL]ZVLOC,2)
      UBIC = UBIC + left$(vireblc(ctrans([F:ZVL]ZVLOC,"-",""),2),2) + right$(vireblc(ctrans([F:ZVL]ZVLOC,"-",""),2),4) #xvt30/10/2019.n


    Endif

    If REP < 10 Then
      UBIC+=chr$(9)
    Endif

  Next
  Filter [F:ZVL]

  REP=0
  Repeat
    POS = instr(POS+1,UBIC,chr$(9))
    REP+=1
  Until POS =0 or REP>10

  For POS=REP To 9
   UBIC+=chr$(9)
  Next

  UBIC=ctrans(UBIC,"-","")

  ZUBIPRED = left$([F:ZCAL]ZUBIPRED,2) + right$([F:ZCAL]ZUBIPRED, 4)  #xvt30/10/2019.n
  #######################


  #  Wrseq right$([F:ZCAL]ITMREF,2)   + adxifs +  SUPPORT-3152.old - Se exporta toda la referencia del artĂ­culo.
    Wrseq [F:ZCAL]ITMREF          + adxifs +
&         [F:ZCAL]EANCOD          + adxifs +
&         [F:ZCAL]ITMDES1         + adxifs +
&         num$([F:ZCAL]QTYSTU)    + adxifs +
&         num$([F:ZCAL]UNICAJA)   + adxifs +
&         num$([F:ZCAL]ZSTOCKMIN) + adxifs +
&         format$("D:DD[-]MM[-]YY",[F:ZCAL]ZFECHALTA) + adxifs +
&         ZUBIPRED                + adxifs +
&         num$([F:ZCAL]QTYPTE)    + adxifs +
&         num$([F:ZCAL]SOHPTE)    + adxifs +
&         UBIC
&   Using [ZEXP]
    #xvt30/10/2019.o &         [F:ZCAL]ZUBIPRED        + adxifs +
  Next
  Openo Using [ZEXP]
  Infbox "ExportaciĂłn finalizada"
Endif

