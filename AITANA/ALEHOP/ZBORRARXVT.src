LOCAL FILE BPARTNER[ZBPR]
LOCAL CHAR CLIENTE(10)

Filter [ZBPR] Where FCY="F0129"
    If !fstat Then
      For [ZBPR]                                         # For [BPR] EAMP030720
        CLIENTE=[ZBPR]BPRNUM                             #[F:BPR]BPRNUM EAMP030720
      Next
    Endif
    Filter [ZBPR]

INFBOX CLIENTE


