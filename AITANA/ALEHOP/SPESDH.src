#<AdxTL>@(#)0.0.0.0 $Revision$
###############################################################################
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif

Case ACTION
  When "SETBOUT"       : Gosub ZSETBOUT
  When "STATUT"        : Gosub STATUT
  When Default
Endcase
Return


###############################################################################
$STATUT
If BOUT = 'O'
   Local Integer NOL
   [M]DLVNOT = 0
   [M]DLVATI = 0
   [M]NETWEI = 0
   [M]GROWEI = 0
   [M:SDH0]DSPTOTQTY = 0
   [M:SDH0]DSPTOTWEI = 0
   [M:SDH0]DSPTOTVOL = 0
   Affzo [M:SDH1]
   Affzo [M:SDH0]

   For NOL = 0 To [M:SDH1]NBLIG-1
      If [M:SDH1]UPDFLG(NOL) = 1  # COMRPOBAR QUE HABIA ALGUNA LINEA DE CAMBIO DE CANT EN ZCS1
        If GUSER="ADMIN" : Infbox num$([M:SDH1]UPDFLG(NOL)) : Endif
        GMODIF = 0
        If [M:SDH1]QTY(NOL) <> 0
          Call AM_QTY([M:SDH1]QTY(NOL)) From SUBSDH #es aqui cuando en la segunda ocasión borra el gropri
        Endif
      Endif
      Gosub ADD_TOT From SUBSDHB
      Affzo [M:SDH1]
      If [M:SDH1]QTY(NOL) = 0 and [M:SDH1]ITMREF(NOL) <> ''
        Gosub SUB_TOT From SUBSDHB
        Dela NOL,1 [M]NBLIG
        If NOL <> 0 : NOL -= 1 : Endif
        [M]NBLIG -= 1
        Affzo [M:SDH1]
      Endif
   Next
   Affzo [M:SDH1]
   Gosub ENTRE_MODIF From GOBJSUB   # para forzar que se active el botón Registrar
Endif

Return


###############################################################################
$ZSETBOUT

Local Char ROTURA(1) :  ROTURA = '1'

If [M:SDH1]CFMFLG <> 2 Then   # Entrega no validada
  CHMEN += "DO"               # activa el botón Modificar cantidades
Endif

If [M:SDH1]CFMFLG <> 2 Then       # comprobamos únicamente las entregas no validadas
  # 29/11/2018 - ALEHOP-620 - MS - Desactivar Validación si hay líneas en ruptura de stock
  If !clalev([S0]) : Local File STOCK    [S0] : Endif
  If !clalev([F0]) : Local File FACILITY [F0] : Endif

  Local Integer NOL

  For NOL = 0 To [M:SDH1]NBLIG-1
    Filter [S0] Where [S0]ITMREF =  [M:SDH1]ITMREF(NOL) and
&                     [S0]STOFCY =  [M:SDH0]STOFCY      and
&                     [S0]STA    =  'A'                 and
&                     [S0]QTYSTU >= [M:SDH1]QTY(NOL)
      Read [S0] First
      If fstat Then
#        If GUSER="ADMIN" Then : Infbox ([M:SDH1]ITMREF(NOL)) : Endif
        ROTURA = '2'
#        Chgstl [M:SDH1]ITMREF(NOL) With "AERROR"
#        Affzo [M:SDH1]ITMREF(NOL)
      Endif
    Filter [S0]
  Next

  If ROTURA = '2' Then
#     Call VIREBOUT(CHAINE,"1") From GOBJET
  Endif
Endif


  #bloquear el botón "validar" entrega si viene de pedido de ventas
  If clalev([M:SOH0]) Then
    Call VIREBOUT(CHAINE,"1") From GOBJET
  Endif

##XVT 2019-05-24 ACTIVAR LA SELECCIÓN PARA IMPRESIÓN
  CHMEN+="zZ"
Return


###############################################################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR

End

