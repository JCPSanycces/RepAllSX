#<AdxTL>@(#)0.0.0.0 $Revision$ 
Local Char LFILE_W : LFILE_W = ""
Local Char LSEP : LSEP = ";"
Local Integer LI : LI = 1

If clalev([SIV]) = 0 : Local File SINVOICEV[SIV] : Endif
If clalev([SIH]) = 0 : Local File SINVOICE[SIH] : Endif

#Bucle Principal: buscamos factura con INVTYP = 2 (Abonos), SIVTYP = 2 ("AV") y ZDEVSMR vacío (sin movimientos generados)
#DONE: Buscar por fecha > 01-04-2020
#DONE: SALCFCY "P" "C" O "F"

#Filtro buscando solo una factura en concreto
#Filter [SIV] Where [SIV]INVTYP = 2 and [SIV]SIVTYP = "AV" and [SIV]NUM = "VR20082125520001" #and [SIV]ZDEVSMR = ""

#Filtro buscando todas las facturas de tienda P, C, F con fecha > 01/04/2020 con Tipo AV (Abono venta tienda), INVTYP = 2 (Abono) y ZDEVSMR vacío (sin movimiento origen)
#Filter [SIV] Where [SIV]INVTYP = 2 and [SIV]INVDAT >= gdat$(1,4,2020)  and [SIV]SIVTYP = "AV" and [SIV]NUM = "VR20082125520001" and [SIV]ZDEVSMR = "" and ( left$([SIV]SALFCY,1)="P" or left$([SIV]
#& SALFCY,1)="C" or left$([SIV]SALFCY,1)="F"
#& )

Filter [SIV] Where [SIV]INVTYP = 2 and [SIV]INVDAT >= gdat$(1,4,2020)  and [SIV]SIVTYP = "AV" and [SIV]ZDEVSMR = "" and ( left$([SIV]SALFCY,1)="P" or left$([SIV]
& SALFCY,1)="C" or left$([SIV]SALFCY,1)="F"
& )

If rowcount([SIV]) > 0 Then
  #Recorremos la cabecera de la factura
  For [SIV]
    Infbox "El registro de factura es " + [SIV]NUM 
    Read [SIH]SIH0 = [SIV]NUM
    Infbox "La factura encontrada es " + [SIH]NUM
    Infbox "El campo validada: " + num$([SIH]STA)
    IF [SIH]STA = 3 Then
     LI = LI +1
     Infbox "Esta validada Estamos en la pasada " + num$(LI)
     If LI = 3
       Infbox "Salimos del bucle"
       Break
     Endif
    Endif
  Next
Else Infbox "No hay registros"
Endif

Close Local File [SIV]
Close Local File [SIH]





