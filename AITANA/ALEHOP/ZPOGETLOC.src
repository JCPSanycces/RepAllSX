#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
## MS 20180613
######################################################################################

$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif

Case ACTION
 When "SORTIE"  : Gosub GET_LOC
 When Default
Endcase
Return

######################################################################################
# Obtener ubicación
$ GET_LOC

Local Integer LCON

If clalev([ZSRG]) = 0   : Local File STOSRG [ZSRG]   : Endif

# deshacemos las propuestas de ubicación del estandar
For LCON = 0 To [M:SSL1]NBLIG-1
  [M:SSL1]COCHAGE(LCON) = 1
  Raz [M:SSL1]LOC(LCON), [M:SSL1]LOCTYP(LCON), [M:SSL1]QTYPCU

  # desmarcar la lína, STAFLG, como incluida en un Plan de Ordeanción
  Filter [ZSRG] Where [F:ZSRG]STOCOU = [M:SSL1]STOCOU(LCON) & [F:ZSRG]VCRTYP = [M:SSL1]VCRTYP(LCON) & [F:ZSRG]VCRNUM = [M:SSL1]VCRNUM(LCON) & [F:ZSRG]VCRLIN = [M:SSL1]VCRLIN(LCON)
  Read [ZSRG] First
  If !fstat Then
   [F:ZSRG]STAFLG = 1
    Rewrite [F:ZSRG]
  Endif
  # fin desmarcaje STAFLG
Next


For LCON = 0 To [M:SSL1]NBLIG-1
  # busqueda de ubicación con stock, seleccionamos la de mayor stock
  If clalev([ZSTOCK]) = 0 : Local File STOCK  [ZSTOCK] : Endif
  Filter [ZSTOCK] Where [ZSTOCK]LOC<>"MUELLE" & [ZSTOCK]ITMREF = [M:SSL1]ITMREF(LCON) & [ZSTOCK]STOFCY = [M:SSL1]STOFCY  Order By [ZSTOCK]QTYSTU Desc

  Read [ZSTOCK] First

  # [M:SSL1]STA(nolign-1) = "A"

  If !fstat Then                            # encontramos stock en una ubicación
    #Infbox("hay stock para "+ num$(LCON))
    [M:SSL1]LOCTYP(LCON) = [ZSTOCK]LOCTYP
    [M:SSL1]LOC(LCON) = [ZSTOCK]LOC
    [M:SSL1]PCU(LCON) = [ZSTOCK]PCU
    [M:SSL1]QTYPCU(LCON) = [M:SSL1]QTYPCUORI
    [M:SSL1]COCHAGE(LCON) = 2
    Grizo [M:SSL1]LOC(LCON)
    Grizo [M:SSL1]LOCTYP(LCON)
    Grizo [M:SSL1]QTYPCU(LCON)
    # marcar la lína, STAFLG, como incluida en un Plan de Ordeanción
    Filter [ZSRG] Where [F:ZSRG]STOCOU = [M:SSL1]STOCOU(LCON) & [F:ZSRG]VCRTYP = [M:SSL1]VCRTYP(LCON) & [F:ZSRG]VCRNUM = [M:SSL1]VCRNUM(LCON) & [F:ZSRG]VCRLIN = [M:SSL1]VCRLIN(LCON)
    Read [ZSRG] First
    If !fstat Then
      [F:ZSRG]STAFLG = 2
    Rewrite [F:ZSRG]
    Endif
  # fin desmarcaje STAFLG

  Else
    Infbox("Línea "+ num$(LCON+1) + " .No hay stock en ninguna ubicación. Hay que completar la ubicación manualmente")
  Endif

  Filter [ZSTOCK]
  Close Local File [ZSTOCK]

Next

Affzo [M:SSL1]25

Filter [ZSRG]
Close Local File [ZSRG]

Return

