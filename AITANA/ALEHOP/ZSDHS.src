#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
    When ZSDHSB : Call ZSDHSB
    When ZSDHS  : Call ZSDHS([M:SDH0]SDHNUM)
  Endcase
Return

Subprog ZSDHSB()
#borrar líneas seleccionadas de impresión
 If  !clalev([F:ZSDHS]) : Local File ZSDHSELEC[ZSDHS] : Endif
 Local Integer SINO
  SINO=2
  Call OUINON("Se borrará la selección de albaranes para imprimir, ¿continuar?" ,SINO) From GESECRAN
  If SINO<>2 : Return : Endif

  For  [ZSDHS]
    Readlock [ZSDHS]First
    Delete [ZSDHS]
  Next
  Call MESSAGE ("Lista de selección borrada") From GESECRAN
End


Subprog ZSDHS(PSDHNUM)
Variable Char PSDHNUM

  If  !clalev([F:ZSDHS]) : Local File ZSDHSELEC[ZSDHS] : Endif
  Local Integer SINO
  SINO=2

  Read [ZSDHS]ZSSDH=PSDHNUM
  If !fstat Then
     SINO=2
     Call OUINON("Eliminar este albarán de la selección de impresión, ¿continuar?" ,SINO) From GESECRAN
     If SINO=2 Then
      Delete [ZSDHS] Where SDHNUM=PSDHNUM
     Endif
  Else
    [ZSDHS]SDHNUM=PSDHNUM
    Write [ZSDHS]
    Call MESSAGE ("Albarán seleccionado correctamente " + PSDHNUM ) From GESECRAN
  Endif
End

