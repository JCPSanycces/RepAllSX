# 04/06/20 EAP IncorporaciÃģn de los cÃģdigos de divisa 841 y 842 para monedas USD con cambio pactado en CABECERA
#################################################
# SAM 104918        JUCON                       #
#################################################
$RELBAN
  Call SPRELBAN([L]FICDON)
Return

##################################################
Subprog SPRELBAN(VFICDON)
Value Char VFICDON
##################################################
#### COPIA DEL FICHERO ORIGINAL               ####
##################################################
Local Char ENR(250)
Local Char TEXTO (250)
Local Integer DET
Local Char    SAVIFS(5) , SAVIRS(5), TEXTO(250) #JCC
Local Integer SAVIUM    # JCC
SAVIFS = adxifs    # JCC
SAVIRS = adxirs    # JCC
SAVIUM = adxium    # JCC
adxium = GASCII    # JCC

Openo filpath("BQR","RELBAN","BAK"),0

### bug 90172 jucon 03/06/13
#Openi [M]FICDON
#Openi [M]FILNAM
Openi VFICDON           # SAM 104918

Rdseq ENR
While fstat=0
TEXTO=ENR                  ####    JCC
Gosub FORMATO_TEXTO        ####    JCC
ENR=TEXTO                  ####    JCC
Wrseq ENR
Rdseq ENR
Wend

Openo
##################################################
#### TRANSFORMACIÃN DEL FICHERO NORMA 43      ####
#### EN EL FORMATO NECESARIO PARA RELBAN      ####
##################################################
#Init SAM 111165
#If [M:DIA]LEG="SPA" #SAM 115846
If GCURLEG="SPA"   #SAM 115846
  Local Char ENREG(81)
#Elsif [M:DIA]LEG="POR" #SAM 115846
Elsif GCURLEG="POR"     #SAM 115846
  Local Char ENREG(82)
Endif
#End  SAM 111165
Local Char BANQUE(5),GUICHET(5),COMPTE(11),DTSOLDE(6),SENS(1)
Local Char DEVISE(3)
Local Char NBDEC

Local Char IMPORTE(14),CAR(1),CIB(2),REF(16), LIBEL(31)
Local Char DTOPE(6), DTVAL(6), DTFIN(6)
Local Char C1,C2
Local Integer I,A,B,J


##################################################
#### APERTURA DE FICHEROS                     ####
##################################################
SAVIFS = adxifs    # JCC
SAVIRS = adxirs    # JCC
SAVIUM = adxium    # JCC
adxium = GASCII    # JCC

Openi filpath("BQR","RELBAN","BAK")

### bug 90172 jucon 03/06/13
#Openo [M]FICDON,0
#Openi [M]FILNAM,0
Openo VFICDON,0           # SAM 104918

adxirs=chr$(13)+chr$(10)

##################################################
#### LECTURA SECUENCIAL DEL FICHERO           ####
##################################################

Rdseq ENREG
While fstat=0
Gosub TRATAMIENTO
Rdseq ENREG
Wend

Openo
adxifs = SAVIFS    # JCC
adxirs = SAVIRS    # JCC
adxium = SAVIUM    # JCC


End

$TRATAMIENTO
##################################################
#### TRATAMIENTO SEGÃN CADA TIPO DE REGISTRO  ####
##################################################
Case left$(ENREG,2)
    When "11" : Gosub CABECERA : Return
    When "22" : Gosub DETALLE  : Return
    When "23" : Gosub DET23    : Return
    When "33" : Gosub TOTAL    : Return
    When Default               : Return
Endcase
Return

$CABECERA
##################################################
### REGISTROS DE CABECERA                     ####
##################################################
Local Integer INIT
DET=0

[L]BANQUE=mid$(ENREG,3,5)
[L]GUICHET=mid$(ENREG,8,3)
#Init SAM 111165
#If [M:DIA]LEG="SPA"
If GCURLEG="SPA"   #SAM 115846
  INIT=21
  [L]COMPTE=mid$(ENREG,11,10)
  Gosub DIGIT_CONTROL
#Elsif [M:DIA]LEG="POR"
Elsif GCURLEG="POR"     #SAM 115846
  Local Char DG(2)
  INIT=22
#  If [F:BAN]BIDNUM<>"": DG=mid$([F:BAN]BIDNUM,9,2) : Endif
  If [F:BAN]BIDNUM<>"": DG=mid$([F:BAN]BIDNUM,20,2) : Endif
#  [L]GUICHET+=DG
  [L]GUICHET=mid$(ENREG,8,5)
  [L]COMPTE=mid$(ENREG,13,9)
  [L]COMPTE+=DG
  GPOINT = "ACCBANPOR" : Gosub ENTREE From EXEFNC #X3-75355 import Portuguese bank account (23/05/2018)
Endif
[L]DTSOLDE=mid$(ENREG,INIT+4,2)+mid$(ENREG,INIT+2,2)+mid$(ENREG,INIT,2)
[L]DTFIN=mid$(ENREG,INIT+10,2)+mid$(ENREG,INIT+8,2)+mid$(ENREG,INIT+6,2)
[L]SENS=mid$(ENREG,INIT+12,1)

#
#--- Quelques devises...
Case mid$(ENREG,INIT+27,3)      #End SAM 111165
    When "392"  : [L]DEVISE="JPY": [L]NBDEC="2"
    When "756"  : [L]DEVISE="CHF": [L]NBDEC="2"
    When "826"  : [L]DEVISE="GBP": [L]NBDEC="2"
#    When "840"  : [L]DEVISE="USD": [L]NBDEC="2"
    When "840"  : [L]DEVISE=[F:BAN]CUR: [L]NBDEC="2"  # EAP 30/06/20
    When "156"  : [L]DEVISE="CNY": [L]NBDEC="2"  # EAP 30/06/20
    When "978"  : [L]DEVISE="EUR": [L]NBDEC="2"
    When "036"  : [L]DEVISE="AUD": [L]NBDEC="2"    # X3-91715 AUD currency management (JUCON 23/05/2018)
    When Default: [L]DEVISE="EUR": [L]NBDEC="2"
Endcase

[L]IMPORTE=mid$(ENREG,INIT+13,14): Gosub FORM_IMPORTE #SAM 111165

REGISTRO  = "01"                            :#   2
REGISTRO += [L]BANQUE                       :#   7
REGISTRO += space$(4)                       :#   11
REGISTRO += [L]GUICHET                      :#   16
REGISTRO += [L]DEVISE                       :#   19
REGISTRO += [L]NBDEC                        :#   20
REGISTRO += space$(1)                       :#   21
REGISTRO += format$("11X",[L]COMPTE)        :#   32
REGISTRO += space$(2)                       :#   34
REGISTRO += [L]DTSOLDE                      :#   40
REGISTRO += space$(50)                      :#   90
REGISTRO += [L]IMPORTE                      :#   104
REGISTRO += space$(16)                      :#   120

Return

$DETALLE
###################################################
#### REGISTROS DETALLE                         ####
###################################################

Wrseq format$("120X",REGISTRO)
DET=1:REGISTRO=""
[L]CIB=mid$(ENREG,23,2)
[L]DTOPE=mid$(ENREG,15,2)+mid$(ENREG,13,2)+mid$(ENREG,11,2)
[L]DTVAL=mid$(ENREG,21,2)+mid$(ENREG,19,2)+mid$(ENREG,17,2)
[L]LIBEL=mid$(ENREG,51,30)
[L]REF=mid$(ENREG,43,10)
[L]SENS=mid$(ENREG,28,1)
[L]IMPORTE=mid$(ENREG,29,14): Gosub FORM_IMPORTE

REGISTRO  = "04"
REGISTRO += [L]BANQUE                       :#   7
REGISTRO += space$(4)                       :#   11
REGISTRO += [L]GUICHET                      :#   16
REGISTRO += [L]DEVISE                       :#   19
REGISTRO += [L]NBDEC                        :#   20
REGISTRO += space$(1)                       :#   21
REGISTRO += format$("11X",[L]COMPTE)        :#   32
REGISTRO += [L]CIB                          :#   34
REGISTRO += [L]DTOPE                        :#   40
REGISTRO += space$(2)                       :#   42
REGISTRO += [L]DTVAL                        :#   48
REGISTRO += format$("31X",[L]LIBEL)         :#   79
REGISTRO += space$(11)                      :#   90
REGISTRO += [L]IMPORTE                      :#   104
REGISTRO += format$("16X",[L]REF)           :#   120

Return

$DET23
######################################################
### registros de tipo 23
######################################################
If mid$(ENREG,3,2)="01": LIBEL="": Endif
If len(LIBEL)<31
[L]LIBEL+=vireblc(mid$(ENREG,5,31),1)
Endif
If len(LIBEL)<31
[L]LIBEL+=vireblc(mid$(ENREG,43,31),1)
Endif

REGISTRO=mid$(REGISTRO,1,48)+format$("31X",[L]LIBEL)+mid$(REGISTRO,80,30)

Return

$TOTAL
###################################################
#### REGISTROS TOTAL                           ####
###################################################

If DET=1
   Wrseq format$("120X",REGISTRO)
Endif

#111165 - RICAR- JCC- BEGIN
[L]SENS=mid$(ENREG,INIT+38,1)
[L]IMPORTE=mid$(ENREG,INIT+39,14): Gosub FORM_IMPORTE
#111165 - RICAR - JCC- END

REGISTRO  = "07"                             :#   2
REGISTRO += [L]BANQUE                        :#   7
REGISTRO += space$(4)                        :#   11
REGISTRO += [L]GUICHET                       :#   16
REGISTRO += [L]DEVISE                        :#   19
REGISTRO += [L]NBDEC                         :#   20
REGISTRO += space$(1)                        :#   21
REGISTRO += format$("11X",[L]COMPTE)         :#   32
REGISTRO += space$(2)                        :#   34
REGISTRO += [L]DTFIN                         :#   40
REGISTRO += space$(50)                       :#   90
REGISTRO += [L]IMPORTE                       :#   104
REGISTRO += space$(16)                       :#   120

If DET=1
   Wrseq format$("120X",REGISTRO)
Endif

Return

$FORM_IMPORTE
###################################################
#### FORMATO DEL IMPORTE                       ####
###################################################
CAR=mid$(IMPORTE,14,1)
If [L]SENS="2"
    Case CAR
         When "0" : CAR="{"
         When "1" : CAR="A"
         When "2" : CAR="B"
         When "3" : CAR="C"
         When "4" : CAR="D"
         When "5" : CAR="E"
         When "6" : CAR="F"
         When "7" : CAR="G"
         When "8" : CAR="H"
         When "9" : CAR="I"
    Endcase
Else
    Case CAR
         When "0" : CAR="}"
         When "1" : CAR="J"
         When "2" : CAR="K"
         When "3" : CAR="L"
         When "4" : CAR="M"
         When "5" : CAR="N"
         When "6" : CAR="O"
         When "7" : CAR="P"
         When "8" : CAR="Q"
         When "9" : CAR="R"
    Endcase
Endif
IMPORTE=mid$(IMPORTE,1,13)+CAR
Return

$DIGIT_CONTROL
###################################################
#### CALCULO DE LOS DIGITOS DE CONTROL         ####
###################################################
C1=[L]BANQUE+[L]GUICHET

P1="37498625"
J=0
    For I=1 To 8
        J+=(val(mid$(C1,I,1)))*(1+val(mid$(P1,I,1)))
    Next I
    J = 11-mod(J,11)
    If J>9 : J = 11-J : Endif
    [L]GUICHET += num$(J)

C2=[L]COMPTE
P2="0137498625"
J=0
    For I=1 To 10
        J+=(val(mid$(C2,I,1)))*(1+val(mid$(P2,I,1)))
    Next I
    J = 11-mod(J,11)
    If J>9 : J = 11-J : Endif
    [L]GUICHET += num$(J)

Return


$FORMATO_TEXTO
######################################################
#### CAMBIO DE LOS CARACTERES NO PERMITIDOS   JCC ####
######################################################
TEXTO=ctrans(TEXTO,"?","e")
TEXTO=ctrans(TEXTO,"ÂĨ","Ã")
TEXTO=ctrans(TEXTO,"ÂĪ","Ãą")
TEXTO=ctrans(TEXTO,"ÂŠ","a")
TEXTO=ctrans(TEXTO,"Âš","o")
TEXTO=ctrans(TEXTO,"Â§","o")
TEXTO=ctrans(TEXTO,"ÂĶ","a")
TEXTO=ctrans(TEXTO,"ÂĄ","i")
TEXTO=ctrans(TEXTO,"ÂĒ","o")
TEXTO=ctrans(TEXTO,"ÂĢ","u")
TEXTO=ctrans(TEXTO,"'"," ")
TEXTO=ctrans(TEXTO,"ÃĄ","a")
TEXTO=ctrans(TEXTO,"ÃĐ","e")
TEXTO=ctrans(TEXTO,"Ã­","i")
TEXTO=ctrans(TEXTO,"Ãģ","o")
TEXTO=ctrans(TEXTO,"Ãš","u")
TEXTO=ctrans(TEXTO,"Ã","A")
TEXTO=ctrans(TEXTO,"Ã","E")
TEXTO=ctrans(TEXTO,"Ã","I")
TEXTO=ctrans(TEXTO,"Ã","O")
TEXTO=ctrans(TEXTO,"Ã","U")
TEXTO=ctrans(TEXTO,"("," ")
TEXTO=ctrans(TEXTO,")"," ")



Return










