#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER = 'ADMIN' : Infbox ACTION : Endif
  Case ACTION
    When 'DEBUT'    : Gosub DEBUT
    When 'AV_CHOIX' : Gosub AV_CHOIX
    When 'FINSAI'   : Gosub FINSAI
  Endcase
Return


######################################################################################
$DEBUT

Global Integer ZNBLIG   : ZNBLIG  = NBLIG
Global Integer ZNOLIGN  : ZNOLIGN = nolign

#[M:SAI1]BAN    = [RLK]BAN
#[M:SAI1]CRICHK = [RLK]CHK
#Affzo [M:SAI1]BAN
#Affzo [M:SAI1]CRICHK


#Infbox num$(NBLIG)
#Infbox num$(nolign)

NBLIG = 0
nolign = 0

#Close Mask [RLK]
Local Char ZLCKSYM(120)
ZLCKSYM = 'RBK' + [RLK]RBKNUM + '\' + [RLK]BAN + '\1\1'
#Infbox ZLCKSYM

#Infbox num$(NBLIG)
#Infbox num$(nolign)

If !clalev([ZALK]) : Local File APLLCK  [ZALK]  : Endif
Filter [ZALK] Where LCKSYM = ZLCKSYM
Read [ZALK] First
If !fstat
  Delete [ZALK]LCKCLE = ZLCKSYM;[ZALK]LCKIND
Endif

ZLCKSYM = 'AUTCHK\' + [RLK]BAN
Filter [ZALK] Where LCKSYM = ZLCKSYM
Read [ZALK] First
If !fstat
  Delete [ZALK]LCKCLE = ZLCKSYM;[ZALK]LCKIND
Endif

#Close Mask [RLK]
Return


######################################################################################
$AV_CHOIX
[M:SAI1]BAN    = [RLK]BAN
[M:SAI1]CRICHK = [RLK]CHK
Affzo [M:SAI1]BAN
Affzo [M:SAI1]CRICHK
Grizo [M:SAI1]BAN
Grizo [M:SAI1]CRICHK
#Diszo [M:SAI1]BAN
#Diszo [M:SAI1]CRICHK

Return


######################################################################################
$FINSAI

[M:RLK]NBLIG = ZNBLIG
nolign       = ZNOLIGN
Kill ZNBLIG
Kill ZNOLIGN
Return

