#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
  Case ACTION

    When "IMP_VERIF_CRE" : Gosub IMP_VERIF_CRE
    When "IMPORT"      : Gosub IMPORT

  Endcase

Return

$IMPORT
#   Infbox "IMPORT:" + GIMP(98)
  [M:POH4]ZDESPACHANTE = GIMP(98)

Return

$IMP_VERIF_CRE
 # Infbox "verif-cre"

  If [F:POH]ZDESPACHANTE = 0 Then
    OK = 0
  Endif

Return






