$POQFILTRE
Local Char VCDEFIN(20)

If [M:DIA]CDEFIN="" Then
  VCDEFIN="ZZZZZZZZZZZZZZZZZZZZ"
Else
  VCDEFIN=[M:DIA]CDEFIN
Endif

If [M:DIA]ZPOSAL=2 Then
  #INCLUIR SÓLO PEDIDOS DE TIENDA QUE DEBEN SER SALDADOS
  #QUE SON INDICADOS MEDIANTE LA VISTA ZPOSAL
  #Y TIENEN ALGUNAS LÍNEAS RECIBIDAS TOTAL O PARCIALMENTE
  #INDEPENDIENTEMENTE DE QUE SEAN DE INSTALACIÓN O APERTURA
  #SEGÚN INDICA V.MONFORT POR TELÉFONO EL 04/11/2019

  # 20/11/2019 - MS
  POHFILTRE = ''
  POHFILTRE += ' POHFCY<>"OF001"'
  POHFILTRE += ' & POHNUM<="'+ VCDEFIN +'"'
  POHFILTRE += ' & [F:POH]RCPFLG = 2'
  POHFILTRE += ' & [F:POH]CLEFLG<>2 '

Endif

Return

