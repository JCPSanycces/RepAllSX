#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif

Case ACTION
  When Default
Endcase
Return

######################################################################################
Subprog AM_ZSPACUSDAT(VALEUR)
Variable Date    VALEUR
[M:CUSSP]SPACUSDAT = [F:PIH]ACCDAT

End


######################################################################################
Subprog AM_SPACUSDAT(VALEUR)
Variable Date    VALEUR

Local Integer OKCAN : OKCAN = 1:# Ok

Call AVERTIR('¿Desea modificar la fecha de presentación para el SII ?', OKCAN) From GESECRAN
If OKCAN = 2
  [M:CUSSP]SPACUSDAT = VALEUR
Else
  VALEUR = [M:CUSSP]SPACUSDAT
Endif

End

