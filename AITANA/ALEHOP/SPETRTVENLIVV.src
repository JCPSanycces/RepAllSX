###############################################################################
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif

Case ACTION
  When "TRT_DIV"    :  Gosub TRT_DIV
  When Default
Endcase
Return


$TRT_DIV
If [M:SDH2]MDL = '' or [M:SDH2]BPTNUM='' Then # Modo Entrega o Transportista
# vacioshttp://192.168.100.166:8124/syracuse-main/html/main.html?url=%2Ftrans%2Fx3%2Ferp%2FPRODUCLVD%2F%24sessions%3Ff%3DGESSDH%252F2%252F%252FM%252F
  Infbox ("Validación Imposible, falta completar el Transportista o el Modo de entrega")
  #   Call VIREBOUT(CHAINE,"1") From GOBJET
  End
Endif

Onerrgo ERROR_MASK
If varinit([M:SOH0]SOHNUM) = 1 Then
  Infbox ("Validación Imposible, debe salir primero del pedido")
  End
Endif

Return


$ERROR_MASK
# Añadimos esta gestión de errores para el caso de que cuando intentamos validar una entrega sin haber llegado a ella
# desde el pedido, la comprobación varinit([M:SOH0]SOHNUM) = 1 no nos bloquee
Resume

