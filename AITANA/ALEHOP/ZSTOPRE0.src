#<AdxTL>@(#)0.0.0.0 $Revision$
# 27/11/2019 - MS - Nueva versión - utilizo vistas - mejoramos el filtrado
# XVT26082020 - Falla el procesamiento porque algunos artículos no existen en la planta ALM00
#               Antes de procesar, se realizará un barrido por todos los artículos para
#               comprobar que existen en ALM00 y dar un aviso para los que no existan.
#####################################################################################
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif

Case ACTION
  When "AV_CHOIX"   : Gosub AV_CHOIX
  When "BOUTON"     : Gosub BOUTON
  When Default
Endcase
Return

######################################################################################
$AV_CHOIX

Effzo [M:ZSTOPRE0]2

Return


###############################################################################
$BOUTON
Case BOUT
  When "X" : Gosub  GET_SMR     # obtiene las entradas varias
  When "Y" : Gosub  SEL_ALL     # seleccionar todo
  When "Z" : Gosub  SET_SMROK   # en desmontaje
Endcase

Return

###############################################################################
$SEL_ALL

Local Integer LCON

For LCON = 0 To [M:ZSTOPRE0]ZNBLIG1-1
  [M:ZSTOPRE0]SEL(LCON) = 2
Next

Affzo [M:ZSTOPRE0]

Return


###############################################################################
$GET_SMR

Local Char REQUESTM(255)(15)

Local Char ZTIENDA(5)

#Local Char FECHA_INI(10)
#Local Char FECHA_FIN(10)
#Local Char ASTO_INI(20)   :   ASTO_INI = [M:ZSTOPRE0]FENTINI
#Local Char ASTO_FIN(20)   :   ASTO_FIN = [M:ZSTOPRE0]FENTFIN


#FECHA_INI = vireblc(num$([M:ZSTOPRE0]FFECINI),4) : FECHA_INI = mid$(FECHA_INI,7,4)+mid$(FECHA_INI,4,2)+mid$(FECHA_INI,1,2)
#FECHA_FIN = vireblc(num$([M:ZSTOPRE0]FFECFIN),4) : FECHA_FIN = mid$(FECHA_FIN,7,4)+mid$(FECHA_FIN,4,2)+mid$(FECHA_FIN,1,2)
#If ASTO_INI = '' : ASTO_INI = '000000000'  : Endif
#If ASTO_FIN = '' : ASTO_FIN = 'ZZZZZZZZZ'  : Endif

# si el movimiento es 12 (Entrada Devolución) su descripción
# no está repetida con un movimiento 24 (Salida Ordenación)    - EA - 27/11/2019
# composición de la consulta de los movimientos de stock candidatos
##REQUESTM(0) = "SELECT STOFCY_0, TRSFAM_0, VCRNUM_0, VCRDES_0, IPTDAT_0, VCRTYP_0, ZFLAGPREP_0 "
##REQUESTM(1) = "FROM SMVTH "
##REQUESTM(2) = "WHERE STOFCY_0 = '" + [M:ZSTOPRE0]FPLANTA + "' "
##REQUESTM(3) = "AND TRSFAM_0 = '12' "
##REQUESTM(4) = "AND (IPTDAT_0 BETWEEN '" + FECHA_INI + "' AND '" + FECHA_FIN + "') "
##REQUESTM(5) = "AND (VCRNUM_0 BETWEEN '" + [L]ASTO_INI + "' AND '" + [L]ASTO_FIN + "')"
##REQUESTM(6) = "AND VCRDES_0 NOT IN "
##REQUESTM(7)     = "(SELECT VCRDES_0 "
##REQUESTM(8)     = "FROM SMVTH "
##REQUESTM(9)     = "WHERE TRSFAM_0 = '24') "

# sustituimos la consulta anterior por una vista ZENTDEV0
If !clalev([ZET0]) : Local File ZENTDEVD0 [ZET0] : Endif

#If !clalev([ZSMVTH]) : Local File SMVTH [ZSMVTH] : Endif

Effzo [M:ZSTOPRE0]2
Affzo [M:ZSTOPRE0]

Raz [M:ZSTOPRE0]ZNBLIG1
nolign = 1

# ejecución de la consulta
#For (Char STOFCY_0, Char TRSFAM_0, Char VCRNUM_0, Char VCRDES_0(60), Date IPTDAT_0, Integer VCRTYP_0, Integer ZFLAGPREP_0) From "5" Sql
#&   REQUESTM(0..9) As [ZSMVT]

If [M:ZSTOPRE0]ZTIENDA <> ''
  Filter [ZET0] Where IPTDAT >= [M:ZSTOPRE0]FFECINI and IPTDAT <= [M:ZSTOPRE0]FFECFIN and
&                   left$(VCRDES,5) = [M:ZSTOPRE0]ZTIENDA
Else
  Filter [ZET0] Where IPTDAT >= [M:ZSTOPRE0]FFECINI and IPTDAT <= [M:ZSTOPRE0]FFECFIN
Endif


For [ZET0]
    [M:ZSTOPRE0]SEL(nolign-1)         =  1
    [M:ZSTOPRE0]FECHA(nolign-1)       =  [ZET0]IPTDAT
    [M:ZSTOPRE0]VCRNUM(nolign-1)      =  [ZET0]VCRNUM
    [M:ZSTOPRE0]VCRDES(nolign-1)      =  [ZET0]VCRDES
    nolign += 1
    [M:ZSTOPRE0]ZNBLIG1 += 1
Next

Affzo [M:ZSTOPRE0]


Return


###############################################################################
$SET_SMROK
Local Integer LCON  : Raz LCON

#Infbox "Contacte con SISTEL para activar esta opción"
# descomentar las líneas siguientes para activarla

If !clalev([ZSMVTH]) : Local File  SMVTH [ZSMVTH] : Endif

#XVT26082020.bn
Local Char ERRORARTPLANTA(200) : ERRORARTPLANTA=""
Local Integer ERRARTPL : ERRARTPL = 0
For LCON = 0 To ZNBLIG1
  If  [M:ZSTOPRE0]SEL(LCON) = 2 Then
      Call COMPRUEBA_ARTPLANTA(19, [M:ZSTOPRE0]VCRNUM(LCON), ERRORARTPLANTA )
      If len(ERRORARTPLANTA) > 0 Then
        Call MESSAGE ( [M:ZSTOPRE0]VCRNUM(LCON) + " Artículos no existen en ALM00 " + ERRORARTPLANTA ) From GESECRAN
        ERRARTPL += 1
      Endif
  Endif
Next

If ERRARTPL
  Call MESSAGE("No se puede continuar, debe crear los artículos indicados en la planta ALM00") From GESECRAN
  Return
Endif
#XVT26082020.en

For LCON = 0 To ZNBLIG1
  If  [M:ZSTOPRE0]SEL(LCON) = 2 Then
      Call GEN_ENTSAL(19, [M:ZSTOPRE0]VCRNUM(LCON), [M:ZSTOPRE0]VCRDES(LCON)) From ZGENENTSAL
  Endif
Next

Close Local File [ZSMVTH]

Gosub  GET_SMR    # obtiene las entradas varias
Affzo [M:ZSTOPRE0]

Return


######################################################################################
Subprog AM_FENTINI(VALEUR)
Variable Char    VALEUR()

[M:ZSTOPRE0]FENTFIN = VALEUR
Affzo [M:ZSTOPRE0]FENTFIN
End


######################################################################################
#XVT26082020.bn
Subprog COMPRUEBA_ARTPLANTA(PVCRTYP, PVCRNUM, PERROR)
Value Integer PVCRTYP
Value Char    PVCRNUM
Variable Char PERROR

  PERROR=""
  If !clalev([ZSMVTD2]) : Local File SMVTD [ZSMVTD2] : Endif
  If !clalev([ZITF2])   : Local File ITMFACILIT [ZITF2] : Endif

  For [F:ZSMVTD2] Where VCRTYP=PVCRTYP and VCRNUM=PVCRNUM
    Read [F:ZITF2]ITF1='ALM00';[F:ZSMVTD2]ITMREF
    If fstat<>0 Then
      If len(PERROR) < 195
        PERROR += [F:ZSMVTD2]ITMREF + "  "
      Else
        If len(PERROR) < 205
          PERROR += "(...)"
        Endif
      Endif
    Endif
  Next

End

