#Filter [SDH] Where CREDAT >= date$-30
If clalev([SIV]) = 0 : Local File SINVOICEV[SIV] : Endif

Filter [SIV] Where [SIV]INVDAT <= gdat$(24,4,2020) AND [SIV]NUM = "VR20082125520001"

If rowcount([SIV]) > 0 Then
  #Recorremos la cabecera de la factura
  For [SIV]
    Infbox "El numero de Factura es " + [SIV]NUM
  Next
Else Infbox "No hay registros"
Endif
Close Local file [SIV]


