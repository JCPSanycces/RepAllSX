#<AdxTL>@(#)7.0.0.0 $Revision$
Local Char PARAM(10)(1..10) , VALEUR(10)
Call TRAITE_CHAR(VALEUR,PARAM,"","RECUPBAL","UTIRECBAL",3,"") From GTRAITE
End

$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "INIT_DIA"    : Gosub INIT_DIA
 When "EXEC"        : Gosub EXEC
 When "OUVRE_BATCH" : Gosub OUVRE
Endcase
Return

$OUVRE
If dim(DOSSIER)<1
 Local Char DOSSIER(GLONADP)
 DOSSIER = nomap
Endif

If clalev([F:HAE])=0 : Local File =DOSSIER+".GACCENTRY"     [HAE] : Endif
If clalev([F:DAE])=0 : Local File =DOSSIER+".GACCENTRYD"    [DAE] : Endif
If clalev([F:DAA])=0 : Local File =DOSSIER+".GACCENTRYA"    [DAA] : Endif
If clalev([F:FIY])=0 : Local File =DOSSIER+".FISCALYEAR"    [FIY] : Endif
If clalev([F:PER])=0 : Local File =DOSSIER+".PERIOD"        [PER] : Endif
If clalev([F:FCY])=0 : Local File =DOSSIER+".FACILITY"      [FCY] : Endif
If clalev([F:CPY])=0 : Local File =DOSSIER+".COMPANY"       [CPY] : Endif
If clalev([F:GAC])=0 : Local File =DOSSIER+".GACCOUNT"      [GAC] : Endif
If clalev([F:BAL])=0 : Local File =DOSSIER+".BALANCE"       [BAL] : Endif
If clalev([F:TCU])=0 : Local File =DOSSIER+".TABCUR"        [TCU] : Endif
If clalev([F:FGR])=0 : Local File =DOSSIER+".FACGROUP"      [FGR] : Endif

If clalev([F:GCM])=0 : Local File =DOSSIER+".GACM"          [GCM] : Endif
If clalev([F:LED])=0 : Local File =DOSSIER+".GLED"          [LED] : Endif
If clalev([F:COA])=0 : Local File =DOSSIER+".GCOA"          [COA] : Endif
If clalev([F:CLS])=0 : Local File =DOSSIER+".GACCCLS"       [CLS] : Endif

If clalev([F:HAT])=0 : Local File =DOSSIER+".GACCTMP"        [HAT] : Endif
If clalev([F:DAT])=0 : Local File =DOSSIER+".GACCTMPD"       [DAT] : Endif

Return

$INIT
Gosub OUVRE
If !GBROWS : TMP = 1 : Endif
Return

$INIT_DIA
[M:DIA]SOCIETE = GDEFSOC
Call SETMAINREF([M:DIA]SOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Call DEFEXE([M:DIA]SOCIETE,GTYPGEN,[M:DIA]EXERCICE) From CPTSUB
Call DATEXE([M:DIA]SOCIETE,GTYPGEN,[M:DIA]EXERCICE,[M:DIA]DATDEB,[M:DIA]DATFIN) From CPTSUB
Return

$EXEC
Local Integer ANOM
Call RECUPBAL([M:DIA]SOCIETE,[M:DIA]TOUSITE,[M:DIA]SITE,[M:DIA]LEDTYP,
&             [M:DIA]EXERCICE,[M:DIA]DEVISE,[M:DIA]BALGEN,[M:DIA]COMPTE,GSERVEUR,0,ANOM)
TRA = 1
Return

##########################################################################################################
$INISOC
Local Integer LNBSOC : LNBSOC=nbrecord([F:CPY])
GDIMSOC=LNBSOC+20
Global Char    GSOC(GLONCPY)(1..GDIMSOC)
Global Char    GDEVSOC(GLONCUR)(1..GDIMSOC)
Global Char    GLEGSOC(GLONADI)(1..GDIMSOC)
Global Char    GGCMSOC(GLONGCM)(1..GDIMSOC)
Global Integer GEXEAN(1..GDIMSOC,1..10)
Return

##########################################################################################################
Subprog RECUPBAL2(DOSSIER,SOCIETE,TOUSITE,SITE,LEDTYP,EXERCICE,DEVISE,BALGEN,COMPTE,BATCH,DIRECT,ANOM)
Value    Char    DOSSIER
Value    Char    SOCIETE
Value    Integer TOUSITE
Value    Char    SITE
Value    Integer LEDTYP
Value    Integer EXERCICE
Value    Char    DEVISE
Value    Integer BALGEN
Value    Char    COMPTE
Value    Integer BATCH
Value    Integer DIRECT
Variable Integer ANOM

If clalev([F:CPY])=0 : Local File =DOSSIER+".COMPANY"       [CPY] : Endif
If clalev([F:FCY])=0 : Local File =DOSSIER+".FACILITY"      [FCY] : Endif
If clalev([F:GCM])=0 : Local File =DOSSIER+".GACM"          [GCM] : Endif
If clalev([F:FIY])=0 : Local File =DOSSIER+".FISCALYEAR"    [FIY] : Endif  # Utile pour EXEAN

If clalev([F:ADW9])=0 : Local File =DOSSIER+".ADOVAL"        [ADW9] : Endif
GRAN =1
Read [ADW9]ADW0 = "";"";"FRWGAC"
If !fstat : GRAN = val([F:ADW9]VALEUR) : Endif

Local Integer ISOC
ISOC   = find(SOCIETE,GSOC(1..GNBSOC))
If !ISOC
 Gosub INISOC
Endif

Call LEC_CPY(SOCIETE) From CPTLEC
Local Integer IGCM
IGCM   = find([F:CPY]ACM,GGCM(1..GGCMNBR))
If !IGCM
 If GNBSOC<>nbrecord([F:CPY]) : Gosub INISOC : Endif
 Call GLOBVAR From SETGLBGCM
Endif

If GRAN=2
 Call EXEAN From GLOBCPT
Endif

Goto RECUP

##########################################################################################################
Subprog RECUPBAL(SOCIETE,TOUSITE,SITE,LEDTYP,EXERCICE,DEVISE,BALGEN,COMPTE,BATCH,DIRECT,ANOM)
Value    Char    SOCIETE
Value    Integer TOUSITE
Value    Char    SITE
Value    Integer LEDTYP
Value    Integer EXERCICE
Value    Char    DEVISE
Value    Integer BALGEN
Value    Char    COMPTE
Value    Integer BATCH
Value    Integer DIRECT    : # Paramètres de récup non saisis
Variable Integer ANOM      : # Nbre d'anomalies

Local Char DOSSIER(GLONADP)
DOSSIER = nomap


$RECUP

Gosub OUVRE

# Indice de travail
Local Integer MAXPER, MAXDEV
MAXPER=func AFNC.ACTIV("PER")
MAXDEV = nbrecord([TCU])

# Variable pour le filtre standard
Local Char   FILTECT(250)(0..4)
Local Integer IFILE

# Variable générale
Local Integer ISOC               # Indice de société sous GSOC
Local Date    DATDEB , DATFIN    # Date début et fin d'exercice

# Variable commune de travails
Local Char    DEVBAL(GLONCUR) , SITBAL(GLONFCY), TIERS(GLONBPR)

Local Integer TEST            # Variable qui permet d'ajouter des éléments dans la trace.
Local Integer FLGL            # Flag de différence entre Vérification GL et Vérification Equilibre
Local Integer OK              # Flag pour le controle de mono-société.
Local Char    PLAN(GLONCOA)   # Plan comptable

# Variables de présence des points d'entrée
Global Integer GCALL_PT : Raz GCALL_PT
If dim(GNBENTREE)>0 & GNBENTREE>0 & find("RECUPBAL",GENTSTD(1..GNBENTREE))
 GCALL_PT=1
Endif

# Variables : Feature 79527 - SP2US26
Local Char   FILTHAT(250)(0..4)
Local Integer IFILH

######################### Trace détaillée si TEST=1
TEST  = 0

#-- Vérification d'équilibre : Pas de critère sur compte
If BALGEN=1 : COMPTE = "" :  Endif

#-- Ouverture de trace
If !(BATCH | DIRECT)
 If BALGEN=3
  Call OUVRE_TRACE(mess(54,116,1)) From LECFIC     # Récupération balance
  If GBROWS : Call OUVRE_VLC(mess(54,116,1),"","") From GESECRAN : Endif
 Else
  Call OUVRE_TRACE(mess(57,116,1)) From LECFIC     # Vérification balance
  If GBROWS : Call OUVRE_VLC(mess(57,116,1),"","") From GESECRAN : Endif
 Endif
Endif

#-- Gestion MONOCPY
If !TEST & BALGEN=3 & !DIRECT
 Call MONOCPY(SOCIETE, OK) From AX3MONO # <JFL>
 If !OK : Goto FIN : Endif # <JFL>
Endif

#-- Contrôle sur l'exercice
GSOCIETE = SOCIETE
Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
If SOCIETE<>[F:FIY]CPY | [L]LEDTYP<>[F:FIY]LEDTYP | EXERCICE<>[F:FIY]FIYNUM
 Read [FIY]FIY0 = SOCIETE;[L]LEDTYP;EXERCICE
 If fstat
  Call ECR_TRACE(SOCIETE-num$(EXERCICE)-mess(52,116,1),1) From GESECRAN  # Exercice incorrect
  ANOM = 1 : Goto FIN
 Endif
Endif
DATDEB = [F:FIY]FIYSTR
DATFIN = [F:FIY]FIYEND

ISOC = find(SOCIETE,GSOC(1..GNBSOC))
Call LEC_CPY(SOCIETE) From CPTLEC
Call LEC_GCM([F:CPY]ACM) From CPTLEC
Call LEC_LED([F:GCM]LED(LEDTYP-1)) From CPTLEC
PLAN = [F:LED]COA
Call LEC_COA(PLAN) From CPTLEC

#-- Feature 79527 - SP2US26
Gosub VERF_HAT
Read [LNK] First
If !fstat
 If BALGEN=3
  Call ECR_TRACE(mess(186,123,1)+"."-mess(49,114,1),1) From GESECRAN
  Goto FIN
 Else
  Call ECR_TRACE(mess(43,187,1)+"."-mess(49,114,1),-1) From GESECRAN
 Endif
Endif

Case BALGEN
 When 1
  FLGL = 0 : Gosub TSTBAL
 When 2
  FLGL = 1 : Gosub TSTBAL
 When 3
  Gosub RECBAL
Endcase

$FIN
If BALGEN=3 & !DIRECT
 Call MULTICPY(SOCIETE) From AX3MONO # <JFL>
Endif

If !(BATCH | DIRECT)
 Call FERME_TRACE From LECFIC
 If GBROWS  : Call FERME_VLC From GESECRAN : Endif
Endif

End


############################################################################################################
#-- Resynchronisation de la balance
############################################################################################################
$RECBAL

# Variable pour le filtre de pagination (gestion snapshot too old)
Local Char    FILTPAG(250)(0..4)
Local Integer IFILP
Local Char    CPTDEB(GLONGAC), TRSDEB(GLONBPR)
Local Char    CPTCUR(GLONGAC)

# Variable pour le filtre de RAZ balance
Local Char    FILTBAL(250)(0..4)
Local Integer IFILTA

#-- Variable pour la re-synchronisation des montants
Local Decimal DEB1(1..MAXDEV,0..MAXPER) , CRE1(1..MAXDEV,0..MAXPER)      #-- Montants Lignes Compte/Tiers (Devise Transaction)
Local Decimal DEB2(1..MAXDEV,0..MAXPER) , CRE2(1..MAXDEV,0..MAXPER)      #-- Montants Lignes Compte/Tiers (Devise Référentiel)
Local Decimal CDEB1(1..MAXDEV,0..MAXPER) , CCRE1(1..MAXDEV,0..MAXPER)    #-- Cumuls Lignes Tiers (Devise Transaction)
Local Decimal CDEB2(1..MAXDEV,0..MAXPER) , CCRE2(1..MAXDEV,0..MAXPER)    #-- Cumuls Lignes Tiers (Devise Référentiel)
Local Decimal RDEB1(1..MAXDEV,0..MAXPER) , RCRE1(1..MAXDEV,0..MAXPER)    #-- Cumuls Lignes pour le Report à nouveau (Devise Transaction)
Local Decimal RDEB2(1..MAXDEV,0..MAXPER) , RCRE2(1..MAXDEV,0..MAXPER)    #-- Cumuls Lignes pour le Report à nouveau (Devise Référentiel)

#-- Stockage du nombre & intitulé de devises parcourues (Mnts Lignes + Cumuls Lignes Tiers + Cumuls Lignes Report à nouveau)
Local Integer NBDEV, CNBDEV, RNBDEV
Local Char    TBDEV(GLONCUR)(1..MAXDEV),CTBDEV(GLONCUR)(1..MAXDEV), RTBDEV(GLONCUR)(1..MAXDEV)

#-- Variable pour stocker les autres valeurs
Local Integer BALREP, BALFIY
Local Char    BALCPY(GLONCPY), BALFCY(GLONFCY)
Local Char    BALACC(GLONGAC), BALBPR(GLONBPR), BALCUR(GLONCUR)

#-- Paramètres d'optimisation des boucles pour éviter le vieux snapshot too old
Local Integer NBECR, TOTECR, ECRMAX  : ECRMAX = 10000     # Nombre pièces à re-synchroniser
Local Integer NBCPT, TOTCPT, CPTMAX  : CPTMAX = 200       # Nombres comptes re-synchroniser
Local Char    CPTE(GLONGAC)                               # Varaibles de stockage
Local Integer STOP


Local Integer FLSOC,FLSIT,FLDEV    # Flag de travail
Local Integer K,IDEV

If DEVISE=""
 FLDEV = 0
Else
 FLDEV = 1
Endif

#-- Entête fichier Trace
Call ECR_TRACE(mess(54,116,1),0) From GESECRAN                    # Récupération balance
Call ECR_TRACE(mess(2,116,1)-SOCIETE,0) From GESECRAN             # Société
Call ECR_TRACE(mess(3,116,1)-num$(EXERCICE),0) From GESECRAN      # Exercice
If TOUSITE=2
 Call ECR_TRACE(mess(4,116,1),0) From GESECRAN                    # Tous sites
Elsif SITE<>""
 Call ECR_TRACE(mess(5,116,1)-SITE,0) From GESECRAN               # Site
Endif
If DEVISE<>""
 Call ECR_TRACE(mess(55,116,1)-DEVISE,0) From GESECRAN            # Devise
Endif
If COMPTE<>""
 Call ECR_TRACE(mess(56,116,1)-COMPTE,0) From GESECRAN            # Compte
Endif

#-- Début récupération
Call ECR_TRACE(mess(49,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

#-- Remise à zéro
Call ECR_TRACE(mess(149,124,1),0) From GESECRAN
Gosub RAZBAL

#-- Récupération par site
If TOUSITE=2 or SITE=""
 If TOUSITE=2
  FLSOC = 1 : FLSIT = 1
 Else
  FLSOC = 1 : FLSIT = 0
 Endif
 For [FCY]FCY0 Where LEGCPY=SOCIETE & FINFLG=2
  SITE = [F:FCY]FCY
  Gosub BALSIT
 Next
Else
 FLSOC = 0 : FLSIT = 1
 Gosub BALSIT
Endif

Call ECR_TRACE(mess(50,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
# Fin récupération
Return

#-- Récupération par site
$BALSIT
Raz FILTECT, IFILE

Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'[F:DAE]LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:DAE]CPY="'+SOCIETE+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"FCY",'[F:DAE]FCYLIN="'+SITE+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAE]ACCDAT>=['+format$(GFMD,DATDEB)+']'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAE]ACCDAT<=['+format$(GFMD,DATFIN)+']'," & ") From GOBJSUB
If COMPTE<>""
 Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:DAE]ACC="'+COMPTE+'"'," & ") From GOBJSUB
Endif
If DEVISE<>""
 Call ADDCRIT(FILTECT,IFILE,"CUR",'[F:DAE]CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif

CPTDEB = ""
TRSDEB = ""
TOTECR = 0
TOTCPT = 0
Gosub RAZREP

#-- Link GACCOUNT & GACCENTRY
Link [DAE] With [GAC]GAC0~=[F:DAE]COA;[F:DAE]ACC, [HAE]HAE0~=[F:DAE]TYP;[F:DAE]NUM As [LNK]
&              Where evalue(FILTECT)
&              Order By Key CLE = [F:DAE]CPY;[F:DAE]FCYLIN;[F:DAE]LEDTYP;[F:DAE]ACC;[F:DAE]BPR;[F:DAE]ACCDAT;[F:DAE]ACCNUM

#-- Boucle optimisée pour éviter le snapshot too old tout en utilisant les index
Gosub SET_FIRST From TRTFIRST
$BOUCLE_BAL
NBECR  = 0
NBCPT  = 0
STOP = 0
Raz FILTPAG, IFILP

If TRSDEB<>""
 Call ADDCRIT(FILTPAG,IFILP,"ACC",'[F:DAE]ACC="'+CPTDEB+'"'," & ") From GOBJSUB
 Call ADDCRIT(FILTPAG,IFILP,"BPR",'[F:DAE]BPR>"'+TRSDEB+'"'," & ") From GOBJSUB
Elsif CPTDEB<>""
 Call ADDCRIT(FILTPAG,IFILP,"ACC",'[F:DAE]ACC>"'+CPTDEB+'"'," & ") From GOBJSUB
Endif
If FILTPAG="" : FILTPAG="1=1" : Endif

#-- Ligne de pièces comptables
For [LNK]CLE(4) Where evalue(FILTPAG)
 CPTCUR = [F:DAE]ACC
 If TRSDEB="" & [F:GAC]SAC=2
  Gosub RAZCOL
 Endif
 For [LNK]CLE(5)
  If NBCPT>=CPTMAX or NBECR>=ECRMAX
   STOP = 1 : CPTDEB = CPTE : TRSDEB = TIERS : Break 2
  Endif
  CPTE   = [F:DAE]ACC
  TIERS  = [F:DAE]BPR
  If GBROWS :  Call AFF_VLC(CPTE,TIERS) From GESECRAN : Endif
  Gosub BALCPT
  If GOK<1 : Break : Endif
  If [F:GAC]SAC=2
   Gosub CUMCOL
  Endif
  NBCPT += 1
 Next
 If [F:GAC]SAC=2
  Gosub BALCOL
 Endif
Next
TOTCPT += NBCPT
TOTECR += NBECR
If TEST : Call ECR_TRACE(time$-"break"-num$(TOTCPT)-num$(TOTECR),0) From GESECRAN : Endif
If STOP
 Goto BOUCLE_BAL
Elsif TRSDEB<>""
 TRSDEB = ""
 Goto BOUCLE_BAL
Endif
Gosub UNSET_FIRST From TRTFIRST
Filter [DAE]

#-- Report à nouveau temps réel
If GRAN=2 & GEXEAN(ISOC,LEDTYP)=EXERCICE & [F:LED]EQLRANANA=2
 Gosub BALREP
Endif

Return

#################
$BALCPT

If TEST : Call ECR_TRACE(time$-"bal compte"-CPTCUR-TIERS,0) From GESECRAN : Endif
Call DEBTRANS From GLOCK
Gosub TR2
Return

$TR2
GOK = 1
Trbegin [BAL]
 Raz DEB1, DEB2
 Raz CRE1, CRE2
 Raz NBDEV, TBDEV
 For [LNK]CLE
  NBECR += 1
  If [F:HAE]CAT<>3 & [F:HAE]CAT<>5
   If !FLDEV | DEVISE=[F:HAE]CUR
    IDEV = find([F:HAE]CUR,TBDEV(1..NBDEV))
    If !IDEV : NBDEV += 1 : TBDEV(NBDEV) = [F:HAE]CUR : IDEV = NBDEV : Endif
    If [F:DAE]SNS>0
     DEB1(IDEV,[F:DAE]PER) += [F:DAE]AMTCUR
     DEB2(IDEV,[F:DAE]PER) += [F:DAE]AMTLED
    Else
     CRE1(IDEV,[F:DAE]PER) += [F:DAE]AMTCUR
     CRE2(IDEV,[F:DAE]PER) += [F:DAE]AMTLED
    Endif
    If GCALL_PT : GPOINT = "LIGNE" : Gosub ENTREE From EXEFNC : Endif
   Endif
  Endif
 Next
 If NBDEV
  BALREP = 0
  BALCPY = SOCIETE
  BALACC = CPTCUR
  BALBPR = TIERS
  BALFIY = EXERCICE
  Gosub CREBAL
  If GOK<1 : Goto AB_TR2 : Endif

  If GRAN=2 & GEXEAN(ISOC,LEDTYP)=EXERCICE : # Report à nouveau temps réel
   BALREP = 1
   BALFIY = EXERCICE+1
   Call LEC_CLS([F:COA]LEGCLS,[F:GAC]CLSCOD) From CPTLEC
   If [F:CLS]ERA<>2 : # Classe remise à zéro => compte de résultat
    Gosub CUMREP
   Else
    BALACC = CPTCUR
    BALBPR = TIERS
    Gosub CREBAL : # Report à nouveau compte
    If GOK<1 : Goto AB_TR2 : Endif
   Endif
  Endif
 Endif
Commit
Return


############################################################################################################
#- Collectif
############################################################################################################
######################################################
$RAZCOL
If TEST : Call ECR_TRACE("raz collectif"-[F:GAC]ACC,0) From GESECRAN : Endif
Raz CDEB1, CDEB2
Raz CCRE1, CCRE2
Raz CNBDEV, CTBDEV
Return

######################################################
$CUMCOL
For IDEV=1 To NBDEV
 JDEV = find(TBDEV(IDEV),CTBDEV(1..CNBDEV))
 If !JDEV : CNBDEV += 1 : CTBDEV(CNBDEV) = TBDEV(IDEV) : JDEV = CNBDEV : Endif
 For K=0 To MAXPER-1
  CDEB1(JDEV,K) += DEB1(IDEV,K)
  CCRE1(JDEV,K) += CRE1(IDEV,K)
  CDEB2(JDEV,K) += DEB2(IDEV,K)
  CCRE2(JDEV,K) += CRE2(IDEV,K)
 Next K
Next IDEV
Return

######################################################
$BALCOL
If TEST : Call ECR_TRACE("maj collectif"-[F:GAC]ACC,0) From GESECRAN : Endif
TIERS = ""
Call DEBTRANS From GLOCK
Gosub TR22
Return

$TR22
GOK = 1
NBDEV = CNBDEV
For IDEV=1 To NBDEV
 TBDEV(IDEV) = CTBDEV(IDEV)
 For K=0 To MAXPER-1
  DEB1(IDEV,K) = CDEB1(IDEV,K)
  CRE1(IDEV,K) = CCRE1(IDEV,K)
  DEB2(IDEV,K) = CDEB2(IDEV,K)
  CRE2(IDEV,K) = CCRE2(IDEV,K)
 Next K
Next IDEV
Trbegin [BAL]
If NBDEV
 BALREP = 0
 BALCPY = SOCIETE
 BALACC = CPTCUR
 BALBPR = ""
 BALFIY = EXERCICE
 Gosub CREBAL
 If GOK<1 : Goto AB_TR22 : Endif

 If GRAN=2 & GEXEAN(ISOC,LEDTYP)=EXERCICE : # Report à nouveau temps réel
  BALREP = 1
  BALFIY = EXERCICE+1

  Call LEC_CLS([F:COA]LEGCLS,[F:GAC]CLSCOD) From CPTLEC
  If [F:CLS]ERA=2
   BALACC = CPTCUR
   BALBPR = ""
   Gosub CREBAL : # Report à nouveau compte
   If GOK<1 : Goto AB_TR22 : Endif
  Endif
 Endif
Endif
Commit
Return

############################################################################################################
#- Report
############################################################################################################
$RAZREP
If TEST : Call ECR_TRACE("raz report",0) From GESECRAN : Endif
Raz RDEB1, RDEB2
Raz RCRE1, RCRE2
Raz RNBDEV, RTBDEV
Return

$CUMREP
For IDEV=1 To NBDEV
 JDEV = find(TBDEV(IDEV),RTBDEV(1..RNBDEV))
 If !JDEV : RNBDEV += 1 : RTBDEV(RNBDEV) = TBDEV(IDEV) : JDEV = RNBDEV : Endif
 For K=0 To MAXPER-1
  RDEB1(JDEV,K) += DEB1(IDEV,K)
  RCRE1(JDEV,K) += CRE1(IDEV,K)
  RDEB2(JDEV,K) += DEB2(IDEV,K)
  RCRE2(JDEV,K) += CRE2(IDEV,K)
 Next K
Next IDEV
Return

$BALREP
If TEST : Call ECR_TRACE("maj report",0) From GESECRAN : Endif
Call LEC_COA(PLAN) From CPTLEC
If !fstat
 CPTCUR = [F:COA]ACCMIS(10)
Else
 CPTCUR = ""
Endif
If CPTCUR="" : # Paramètre non renseigné
 GOK = 0 : Call ECR_TRACE(mess(106,106,1)-"("+PLAN+")",1) From GESECRAN : Return
Endif
Call LEC_GAC(CPTCUR,PLAN) From CPTLEC
TIERS  = ""
Call DEBTRANS From GLOCK
Gosub TR23
Return

$TR23
GOK = 1
NBDEV = RNBDEV
For IDEV=1 To NBDEV
 TBDEV(IDEV) = RTBDEV(IDEV)
 For K=0 To MAXPER-1
  DEB1(IDEV,K) = RDEB1(IDEV,K)
  CRE1(IDEV,K) = RCRE1(IDEV,K)
  DEB2(IDEV,K) = RDEB2(IDEV,K)
  CRE2(IDEV,K) = RCRE2(IDEV,K)
 Next K
Next IDEV
Trbegin [BAL]
 If NBDEV
  BALREP = 1
  BALCPY = SOCIETE
  BALACC = CPTCUR
  BALBPR = ""
  BALFIY = EXERCICE+1
  Gosub CREBAL
  If GOK<1 : Goto AB_TR23 : Endif
 Endif
Commit
Return


############################################################################################################
#-- Ré écriture de la Balance
############################################################################################################
$CREBAL

For IDEV=1 To NBDEV
 If DEVISE="" or DEVISE=TBDEV(IDEV)
  BALCUR = TBDEV(IDEV)
  If FLSOC
   BALFCY = ""
   Gosub MAJBAL
   If GOK<1 : Return : Endif
  Endif
  If FLSIT
   BALFCY = SITE
   Gosub MAJBAL
   If GOK<1 : Return : Endif
  Endif
 Endif
Next IDEV
Return

$MAJBAL

Readlock [BAL]BAL0 = LEDTYP;BALCPY;BALFCY;BALFIY;BALACC;BALBPR;BALCUR
If fstat
 Raz [F:BAL]
 [F:BAL]LEDTYP = LEDTYP
 [F:BAL]CPY    = BALCPY
 [F:BAL]FCY    = BALFCY
 [F:BAL]FIY    = BALFIY
 [F:BAL]ACC    = BALACC
 [F:BAL]BPR    = BALBPR
 [F:BAL]CUR    = BALCUR
 [F:BAL]ACCNUM = uniqid([F:BAL])
 [F:BAL]LED    = [F:DAE]LED
 [F:BAL]COA    = [F:DAE]COA
 [F:BAL]CURLED = [F:DAE]CURLED
 Gosub CALBAL
 Write [BAL]
Else
 [F:BAL]LED    = [F:DAE]LED
 [F:BAL]COA    = [F:DAE]COA
 [F:BAL]CURLED = [F:DAE]CURLED
 Gosub CALBAL
 Rewrite [BAL]
Endif
If fstat
 GOK=0 : Call FSTA("BAL") From GLOCK : Return
Endif
Return

$CALBAL
If BALREP
 For K=0 To MAXPER-1
  [F:BAL]DEB(0)    += DEB1(IDEV,K)
  [F:BAL]CDT(0)    += CRE1(IDEV,K)
  [F:BAL]DEBLED(0) += DEB2(IDEV,K)
  [F:BAL]CDTLED(0) += CRE2(IDEV,K)
 Next K
 If [F:BAL]DEB(0)>[F:BAL]CDT(0)
  [F:BAL]DEB(0) = [F:BAL]DEB(0) - [F:BAL]CDT(0)
  [F:BAL]CDT(0) = 0
 Else
  [F:BAL]CDT(0) = [F:BAL]CDT(0) - [F:BAL]DEB(0)
  [F:BAL]DEB(0) = 0
 Endif
 If [F:BAL]DEBLED(0)>[F:BAL]CDTLED(0)
  [F:BAL]DEBLED(0) = [F:BAL]DEBLED(0) - [F:BAL]CDTLED(0)
  [F:BAL]CDTLED(0) = 0
 Else
  [F:BAL]CDTLED(0) = [F:BAL]CDTLED(0) - [F:BAL]DEBLED(0)
  [F:BAL]DEBLED(0) = 0
 Endif
Else
 For K=0 To MAXPER-1
  [F:BAL]DEB(K)    += DEB1(IDEV,K)
  [F:BAL]CDT(K)    += CRE1(IDEV,K)
  [F:BAL]DEBLED(K) += DEB2(IDEV,K)
  [F:BAL]CDTLED(K) += CRE2(IDEV,K)
 Next K
Endif
If GCALL_PT : GPOINT = "MAJ" : Gosub ENTREE From EXEFNC : Endif
Return

$AB_TR2
$AB_TR22
$AB_TR23
Rollback
Return

$ROLL_TR2
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR2 : Endif


###############################################
## Remise à zéro balance
###############################################
$RAZBAL
If TOUSITE=2
 For [FCY]FCY0 Where LEGCPY=SOCIETE & FINFLG=2
  SITBAL = [F:FCY]FCY
  Call DEBTRANS From GLOCK
  Gosub TR1
  If GRAN=2 & GEXEAN(ISOC,LEDTYP)=EXERCICE : # Report à nouveau temps réel
   Gosub TR11
  Endif
 Next
 SITBAL = ""
 Call DEBTRANS From GLOCK
 Gosub TR1
 If GRAN=2 & GEXEAN(ISOC,LEDTYP)=EXERCICE : # Report à nouveau temps réel
  Gosub TR11
 Endif
Else
 If SITE<>""
  SITBAL = SITE
 Else
  SITBAL = ""
 Endif
 Call DEBTRANS From GLOCK
 Gosub TR1
 If GRAN=2 & GEXEAN(ISOC,LEDTYP)=EXERCICE : # Report à nouveau temps réel
  Gosub TR11
 Endif
Endif
Return

$TR1
If TEST : Call ECR_TRACE(time$-"raz n"-SITBAL,0) From GESECRAN : Endif
GOK = 1

Raz FILTBAL, IFILTA
Call ADDCRIT(FILTBAL,IFILTA,"LEDTYP",'LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTBAL,IFILTA,"CPY",'CPY="'+SOCIETE+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTBAL,IFILTA,"FIY",'FIY='+num$(EXERCICE)," & ") From GOBJSUB
If COMPTE<>""
 Call ADDCRIT(FILTBAL,IFILTA,"ACC",' ACC="'+COMPTE+'"'," & ") From GOBJSUB
Endif
If DEVISE<>""
 Call ADDCRIT(FILTBAL,IFILTA,"CUR",' CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif

Trbegin [BAL]
Delete [BAL] Where evalue(FILTBAL) & FCY=SITBAL
If fstat=1
 GOK = -1 : GLOCK = "$BALANCE" : Goto ROLL_TR1
Endif
If GCALL_PT : GPOINT = "RAZ" : Gosub ENTREE From EXEFNC : Endif
Commit
Return

$TR11
If TEST : Call ECR_TRACE(time$-"raz n+1"-SITBAL,0) From GESECRAN : Endif
GOK = 1

Raz FILTBAL, IFILTA
Call ADDCRIT(FILTBAL,IFILTA,"LEDTYP",'LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTBAL,IFILTA,"CPY",'CPY="'+SOCIETE+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTBAL,IFILTA,"FIY",'FIY='+num$(EXERCICE+1)," & ") From GOBJSUB
If COMPTE<>""
 Call ADDCRIT(FILTBAL,IFILTA,"ACC",' ACC="'+COMPTE+'"'," & ") From GOBJSUB
Endif
If DEVISE<>""
 Call ADDCRIT(FILTBAL,IFILTA,"CUR",' CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif

Trbegin [BAL]
 Update [BAL] Where evalue(FILTBAL) & FCY=SITBAL With DEB(0)=0 , CDT(0)=0 , DEBLED(0)=0 , CDTLED(0)=0
 If fstat
  GOK = 0 : Call FSTA("BAL") From GLOCK : Goto AB_TR11
 Endif
 If GCALL_PT : GPOINT = "RAZ1" : Gosub ENTREE From EXEFNC : Endif
Commit
Return

$AB_TR1
$AB_TR11
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif


#########################################################################################################
## Vérification de la balance
#########################################################################################################
$TSTBAL
ANOM = 0

#-- Entête fichier Trace
Call LEC_CPY(SOCIETE) From CPTLEC
Call ECR_TRACE(mess(57,116,1),0) From GESECRAN                            # Vérification balance
Call ECR_TRACE(mess(2,116,1)-SOCIETE,0) From GESECRAN                     # Société
Call ECR_TRACE(mess(3,116,1)-num$(EXERCICE),0) From GESECRAN              # Exercice
If TOUSITE=2
 Call ECR_TRACE(mess(4,116,1),0) From GESECRAN                            # Tous sites
Elsif SITE<>""
 Call ECR_TRACE(mess(5,116,1)-SITE,0) From GESECRAN                       # Site
Endif
If DEVISE<>""
 Call ECR_TRACE(mess(55,116,1)-DEVISE,0) From GESECRAN                    # Devise
Endif
If COMPTE<>""
 Call ECR_TRACE(mess(56,116,1)-COMPTE,0) From GESECRAN                    # Compte
Endif

#-- Début vérification
Call ECR_TRACE(mess(70,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Gosub VERIF
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(mess(71,116,1)-format$("D:"+GFMDAT,date$)-time$,0) From GESECRAN

#-- Fin Vérification
If ANOM
 Call ECR_TRACE(num$(ANOM)-mess(7,116,1),0) From GESECRAN    # anomalies
Else
 Call ECR_TRACE(mess(8,116,1),0) From GESECRAN               # Aucune anomalie
Endif
Return

###############################################
$VERIF
Local Integer FLG1, FLG2
Local Integer MAXSIT
MAXSIT = 5

# Ajout du filtre sur les sites financiers
Link [FGR] With [FCY]FCY0=[F:FGR]FCY
& As [LFGR]
& Where [FGR]CPY=SOCIETE & [FCY]FINFLG=2

For [LFGR]FGR0
 MAXSIT += 1
Next

If clalev([F:BALC])=0 : Local File =DOSSIER+".BALANCE"       [BALC] : Endif
Local Integer MAXDEV
MAXDEV = 1

Filter [BALC] Where [F:BALC]LEDTYP=[L]LEDTYP & [F:BALC]CPY=[L]SOCIETE & [F:BALC]FCY="" & [F:BALC]FIY=[L]EXERCICE
For [BALC]BAL2(2)
 MAXDEV += 1
Next
Close Local File [BALC]

Local Schar   TBCUR(GLONCUR)(1..MAXDEV)
Local Schar   TBSIT(GLONFCY)(1..MAXSIT)

# Montants transaction
Local Decimal BALDEB(0..MAXPER) , BALCRE(0..MAXPER)
Local Decimal COLDEB(0..MAXPER) , COLCRE(0..MAXPER)
Local Decimal GLDEB(1..MAXDEV,0..MAXPER) , GLCRE(1..MAXDEV,0..MAXPER)
Local Decimal SOCDEB(1..MAXDEV,0..MAXPER) , SOCCRE(1..MAXDEV,0..MAXPER)
Local Decimal SITDEB(1..MAXSIT,1..MAXDEV,0..MAXPER) , SITCRE(1..MAXSIT,1..MAXDEV,0..MAXPER)

# Montant Référentiel
Local Decimal BALDEBLED(0..MAXPER) , BALCRELED(0..MAXPER)
Local Decimal COLDEBLED(0..MAXPER) , COLCRELED(0..MAXPER)
Local Decimal GLDEBLED(1..MAXDEV,0..MAXPER) , GLCRELED(1..MAXDEV,0..MAXPER)
Local Decimal SOCDEBLED(1..MAXDEV,0..MAXPER) , SOCCRELED(1..MAXDEV,0..MAXPER)
Local Decimal SITDEBLED(1..MAXSIT,1..MAXDEV,0..MAXPER) , SITCRELED(1..MAXSIT,1..MAXDEV,0..MAXPER)

Local Integer ANREEL,P,IND, POIERR
Local Integer NBCUR, NBSIT

If FLGL
 If EXERCICE>1
  Read [FIY]FIY0 = SOCIETE;LEDTYP;EXERCICE-1
  If !fstat & [FIY]FIYSTA >2
   # Les montants de l'indice 0 de la BALANCE ne proviennent pas d'AN reconstitués mais d'AN réels...
   ANREEL = 1
  Else
   ANREEL = 0
  Endif
 Else
  ANREEL = 0
 Endif
 Gosub VERECT
Else
 Gosub EQLBAL
Endif
Return

###############################################
## Vérif balance - grand-livre
###############################################

## Phase 1, écritures

$VERECT
Raz FILTECT, IFILE

Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'[F:DAE]LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:DAE]CPY="'+SOCIETE+'"'," & ") From GOBJSUB
If TOUSITE<>2 & SITE<>""
 Call ADDCRIT(FILTECT,IFILE,"FCY",'[F:DAE]FCYLIN="'+SITE+'"'," & ") From GOBJSUB
Endif
If COMPTE<>""
 Call ADDCRIT(FILTECT,IFILE,"ACC",'[F:DAE]ACC="'+COMPTE+'"'," & ") From GOBJSUB
Endif
If DEVISE<>""
 Call ADDCRIT(FILTECT,IFILE,"CUR",'[F:DAE]CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAE]ACCDAT>=['+format$(GFMD,DATDEB)+']'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"ACCDAT",'[F:DAE]ACCDAT<=['+format$(GFMD,DATFIN)+']'," & ") From GOBJSUB

NBCUR = 0
NBSIT = 0

Filter [BAL]

Link [DAE] With [GAC]GAC0~=[F:DAE]COA;[F:DAE]ACC, [HAE]HAE0~=[F:DAE]TYP;[F:DAE]NUM As [LNK]
Filter [LNK] Where evalue(FILTECT) Order By Key CLE = [F:DAE]ACC;[F:DAE]BPR;[F:DAE]FCYLIN;[F:DAE]ACCDAT;[F:DAE]ACCNUM

Gosub SET_FIRST From TRTFIRST
For [LNK]CLE(1)   : # Compte
 COMPTE = [F:DAE]ACC
 Raz SITDEB, SITCRE, SITDEBLED, SITCRELED
 For [LNK]CLE(2)  : # Tiers
  TIERS = [F:DAE]BPR
  Raz SOCDEB, SOCCRE, SOCDEBLED,SOCCRELED
  For [LNK]CLE(3) : # Site
   Raz GLDEB, GLCRE, GLDEBLED, GLCRELED
   SITBAL = [F:DAE]FCYLIN
   If GBROWS  :  Call AFF_VLC(SOCIETE-"/"-SITBAL,COMPTE-"/"-TIERS) From GESECRAN : Endif
   For [LNK]CLE   : # Détail
    If [F:HAE]CAT<>3 & [F:HAE]CAT<>5
     K = find([F:DAE]CUR,TBCUR(1..NBCUR))
     If !K
      NBCUR += 1 : K = NBCUR
      TBCUR(NBCUR) = [F:DAE]CUR
     Endif
     If [F:DAE]SNS>0
      GLDEB(K,[F:DAE]PER)    += [F:DAE]AMTCUR
      GLDEBLED(K,[F:DAE]PER) += [F:DAE]AMTLED
     Else
      GLCRE(K,[F:DAE]PER)    += [F:DAE]AMTCUR
      GLCRELED(K,[F:DAE]PER) += [F:DAE]AMTLED
     Endif
    Endif
   Next
   # Vérif pour 1 compte  1 tiers et 1 site
   Gosub VER_BPR_SIT
   For P=0 To MAXPER-1
    For K=1 To NBCUR
     SOCDEB(K,P)    += GLDEB(K,P)
     SOCCRE(K,P)    += GLCRE(K,P)
     SOCDEBLED(K,P) += GLDEBLED(K,P)
     SOCCRELED(K,P) += GLCRELED(K,P)
    Next K
   Next P
   J = find(SITBAL,TBSIT(1..NBSIT))
   If !J
    NBSIT += 1 : J = NBSIT
    TBSIT(NBSIT) = SITBAL
   Endif
   For P=0 To MAXPER-1
    For K=1 To NBCUR
     SITDEB(J,K,P)    += GLDEB(K,P)
     SITCRE(J,K,P)    += GLCRE(K,P)
     SITDEBLED(J,K,P) += GLDEBLED(K,P)
     SITCRELED(J,K,P) += GLCRELED(K,P)
    Next K
   Next P
  Next
  # Vérif pour 1 compte  1 tiers et société
  If TOUSITE=2 : Gosub VER_BPR_SOC : Endif
 Next
 # Vérif pour 1 compte collectif, société et site
 If [F:GAC]SAC=2
  Gosub VER_CPT
 Endif
Next
Gosub UNSET_FIRST From TRTFIRST
Filter [LNK]
Return


###############################################
## Sous-programmes d'erreurs
###############################################
$VER_BPR_SIT
If TIERS="" &  [F:GAC]SAC=2 : Return : Endif
If TEST : Call ECR_TRACE(time$-"VER_BPR_SIT"-SITBAL-COMPTE-TIERS,0) From GESECRAN : Endif
For K=1 To NBCUR
 DEVBAL = TBCUR(K)
 POIERR = 1  :# bug 7889 : controle bloquant en devise société
 # If DEVBAL<>[F:GCM]CUR(LEDTYP-1) : POIERR=0 : Endif
 Read [BAL]BAL0 = LEDTYP;SOCIETE;SITBAL;EXERCICE;COMPTE;TIERS;DEVBAL
 If fstat : Raz [F:BAL] : Endif
 If ANREEL = 1 : IND = 0 : Else : IND = 1 : Endif
 For P=IND To MAXPER-1

  # Montant Transaction et Montant référentiel
  Raz FLG1, FLG2
  If [F:BAL]DEB(P)<>GLDEB(K,P) | [F:BAL]CDT(P)<>GLCRE(K,P)             : FLG1=1 : Endif
  If [F:BAL]DEBLED(P)<>GLDEBLED(K,P) | [F:BAL]CDTLED(P)<>GLCRELED(K,P) : FLG2=1 : Endif

  If FLG1 or FLG2
   Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
   Call ECR_TRACE(mess(58,116,1)-DEVBAL-SITBAL-COMPTE-TIERS,POIERR) From GESECRAN            #  Erreur
   If P=0
    Call ECR_TRACE(mess(59,116,1)-num$(P),0) From GESECRAN                                  #  Période
   Else
    Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                 -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                       #  Période
   Endif

   If FLG1
    Call LEC_TCU(DEVBAL) From CPTLEC
    Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                 +num$([F:BAL]DEB(P))+" "+DEVBAL+"   "
&                 +num$([F:BAL]CDT(P))+" "+DEVBAL,0) From GESECRAN    #  Balance
    Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                 +num$(GLDEB(K,P))+" "+DEVBAL+"   "
&                 +num$(GLCRE(K,P))+" "+DEVBAL,0) From GESECRAN       #  Grand Livre
    ANOM += 1
   Endif

   If FLG2
    Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
    Call ECR_TRACE(format$("K:30X",mess(60,116,1)-left$(mess(153,116,1),11))
&                 +num$([F:BAL]DEBLED(P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                 +num$([F:BAL]CDTLED(P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Balance Référentiel

    Call ECR_TRACE(format$("K:30X",mess(61,116,1)-left$(mess(153,116,1),11))
&                 +num$(GLDEBLED(K,P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                 +num$(GLCRELED(K,P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Grand Livre Référentiel

    ANOM += 1
   Endif
  Endif
 Next P
Next K
Return

$VER_BPR_SOC
If TIERS="" &  [F:GAC]SAC=2 : Return : Endif
If TEST : Call ECR_TRACE(time$-"VER_BPR_SOC"-COMPTE-TIERS,0) From GESECRAN : Endif
For K=1 To NBCUR
 DEVBAL = TBCUR(K)
 POIERR = 1  :# bug 7889 : controle bloquant en devise société
# If DEVBAL<>[F:GCM]CUR(LEDTYP-1) : POIERR=0 : Endif
 Read [BAL]BAL0 = LEDTYP;SOCIETE;"";EXERCICE;COMPTE;TIERS;DEVBAL
 If fstat : Raz [F:BAL] : Endif
 If ANREEL = 1 : IND = 0 : Else : IND = 1 : Endif
 For P=IND To MAXPER-1

  # Montant Transaction et Montant référentiel
  Raz FLG1, FLG2
  If [F:BAL]DEB(P)<>SOCDEB(K,P) | [F:BAL]CDT(P)<>SOCCRE(K,P)             : FLG1=1 : Endif
  If [F:BAL]DEBLED(P)<>SOCDEBLED(K,P) | [F:BAL]CDTLED(P)<>SOCCRELED(K,P) : FLG2=1 : Endif

  If FLG1 or FLG2
   Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
   Call ECR_TRACE(mess(58,116,1)-DEVBAL-SOCIETE-COMPTE-TIERS,POIERR) From GESECRAN            #  Erreur
   If P=0
    Call ECR_TRACE(mess(59,116,1)-num$(P),0) From GESECRAN                                  #  Période
   Else
    Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                        #  Période
   Endif
   If FLG1
    Call LEC_TCU(DEVBAL) From CPTLEC
    Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                 +num$([F:BAL]DEB(P))+" "+DEVBAL+"   "
&                 +num$([F:BAL]CDT(P))+" "+DEVBAL,0) From GESECRAN    #  Balance
    Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                 +num$(SOCDEB(K,P))+" "+DEVBAL+"   "
&                 +num$(SOCCRE(K,P))+" "+DEVBAL,0) From GESECRAN       #  Grand Livre
    ANOM += 1
   Endif

   If FLG2
    Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
    Call ECR_TRACE(format$("K:30X",mess(60,116,1)-left$(mess(153,116,1),11))
&                 +num$([F:BAL]DEBLED(P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                 +num$([F:BAL]CDTLED(P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Balance Référentiel

    Call ECR_TRACE(format$("K:30X",mess(61,116,1)-left$(mess(153,116,1),11))
&                 +num$(SOCDEBLED(K,P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                 +num$(SOCCRELED(K,P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Grand Livre Référentiel

    ANOM += 1
   Endif
  Endif
 Next P
Next K
Return

$VER_CPT
If TEST : Call ECR_TRACE(time$-"VER_CPT"-COMPTE,0) From GESECRAN : Endif
For K=1 To NBCUR
 DEVBAL = TBCUR(K)
 POIERR = 1  :# bug 7889 : controle bloquant en devise société
# If DEVBAL<>[F:GCM]CUR(LEDTYP-1) : POIERR=0 : Endif
 Raz SOCDEB, SOCCRE, SOCDEBLED, SOCCRELED
 For J=1 To NBSIT
  SITBAL = TBSIT(J)
  Read [BAL]BAL0 = LEDTYP;SOCIETE;SITBAL;EXERCICE;COMPTE;"";DEVBAL

  If fstat : Raz [F:BAL] : Endif
  If ANREEL = 1 : IND = 0 : Else : IND = 1 : Endif
  For P=IND To MAXPER-1
   SOCDEB(K,P)    += SITDEB(J,K,P)
   SOCCRE(K,P)    += SITCRE(J,K,P)
   SOCDEBLED(K,P) += SITDEBLED(J,K,P)
   SOCCRELED(K,P) += SITCRELED(J,K,P)

   # Montant Transaction et Montant référentiel
   Raz FLG1, FLG2
   If [F:BAL]DEB(P)<>SITDEB(J,K,P) | [F:BAL]CDT(P)<>SITCRE(J,K,P)             : FLG1=1 : Endif
   If [F:BAL]DEBLED(P)<>SITDEBLED(J,K,P) | [F:BAL]CDTLED(P)<>SITCRELED(J,K,P) : FLG2=1 : Endif

   If FLG1 or FLG2
    Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
    Call ECR_TRACE(mess(58,116,1)-DEVBAL-SITBAL-COMPTE,POIERR) From GESECRAN            #  Erreur
    If P=0
     Call ECR_TRACE(mess(59,116,1)-num$(P),0) From GESECRAN                                  #  Période
    Else
     Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                 -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                        #  Période
    Endif

    If FLG1
     Call LEC_TCU(DEVBAL) From CPTLEC
     Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                  +num$([F:BAL]DEB(P))+" "+DEVBAL+"   "
&                  +num$([F:BAL]CDT(P))+" "+DEVBAL,0) From GESECRAN    #  Balance
     Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                  +num$(SITDEB(J,K,P))+" "+DEVBAL+"   "
&                  +num$(SITCRE(J,K,P))+" "+DEVBAL,0) From GESECRAN       #  Grand Livre
     ANOM += 1
    Endif

    If FLG2
     Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
     Call ECR_TRACE(format$("K:30X",mess(60,116,1)-left$(mess(153,116,1),11))
&                  +num$([F:BAL]DEBLED(P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                  +num$([F:BAL]CDTLED(P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Balance Référentiel

     Call ECR_TRACE(format$("K:30X",mess(61,116,1)-left$(mess(153,116,1),11))
&                  +num$(SITDEBLED(J,K,P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                  +num$(SITCRELED(J,K,P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Grand Livre Référentiel

     ANOM += 1
    Endif
   Endif
  Next P
 Next J
 If TOUSITE=2   :# 17783
  Read [BAL]BAL0 = LEDTYP;SOCIETE;"";EXERCICE;COMPTE;"";DEVBAL
  If fstat : Raz [F:BAL] : Endif
  If ANREEL = 1 : IND = 0 : Else : IND = 1 : Endif
  For P=IND To MAXPER-1

   # Montant Transaction et Montant référentiel
   Raz FLG1, FLG2
   If [F:BAL]DEB(P)<>SOCDEB(K,P) | [F:BAL]CDT(P)<>SOCCRE(K,P)             : FLG1=1 : Endif
   If [F:BAL]DEBLED(P)<>SOCDEBLED(K,P) | [F:BAL]CDTLED(P)<>SOCCRELED(K,P) : FLG2=1 : Endif

   If FLG1 or FLG2
    Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
    Call ECR_TRACE(mess(58,116,1)-DEVBAL-SOCIETE-COMPTE,POIERR) From GESECRAN            #  Erreur
    If P=0
     Call ECR_TRACE(mess(59,116,1)-num$(P),0) From GESECRAN                                  #  Période
    Else
     Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                 -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                        #  Période
    Endif

    If FLG1
     Call LEC_TCU(DEVBAL) From CPTLEC
     Call ECR_TRACE(format$("K:30X",mess(60,116,1))
&                  +num$([F:BAL]DEB(P))+" "+DEVBAL+"   "
&                  +num$([F:BAL]CDT(P))+" "+DEVBAL,0) From GESECRAN    #  Balance
     Call ECR_TRACE(format$("K:30X",mess(61,116,1))
&                  +num$(SOCDEB(K,P))+" "+DEVBAL+"   "
&                  +num$(SOCCRE(K,P))+" "+DEVBAL,0) From GESECRAN       #  Grand Livre
     ANOM += 1
    Endif

    If FLG2
     Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
     Call ECR_TRACE(format$("K:30X",mess(60,116,1)-left$(mess(153,116,1),11))
&                  +num$([F:BAL]DEBLED(P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                  +num$([F:BAL]CDTLED(P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Balance Référentiel

     Call ECR_TRACE(format$("K:30X",mess(61,116,1)-left$(mess(153,116,1),11))
&                  +num$(SOCDEBLED(K,P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                  +num$(SOCCRELED(K,P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Grand Livre Référentiel
     ANOM += 1
    Endif
   Endif
  Next P
 Endif
Next K
Return



###############################################
## Equilibre de la balance
###############################################

$EQLBAL

Raz FILTECT, IFILE
Call ADDCRIT(FILTECT,IFILE,"LEDTYP",'[F:BAL]LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"CPY",'[F:BAL]CPY="'+SOCIETE+'"'," & ") From GOBJSUB
Call ADDCRIT(FILTECT,IFILE,"FIY",'[F:BAL]FIY='+num$(EXERCICE)," & ") From GOBJSUB
If DEVISE<>""
 Call ADDCRIT(FILTECT,IFILE,"CUR",'[F:BAL]CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif
If [F:LED]FCYBAL=2
 If TOUSITE<>2
  Call ADDCRIT(FILTECT,IFILE,"FCY",'[F:BAL]FCY="'+SITE+'"'," & ") From GOBJSUB
 Endif
Else
 Call ADDCRIT(FILTECT,IFILE,"FCY",'[F:BAL]FCY=""'," & ") From GOBJSUB
Endif


Link [BAL] With [GAC]GAC0~=[F:BAL]COA;[F:BAL]ACC
&   As [LNK]
&   Where evalue(FILTECT)
&   Order By Key CLE=[F:BAL]LEDTYP;[F:BAL]CUR;[F:BAL]CPY;[F:BAL]FCY;[F:BAL]ACC;[F:BAL]BPR;[F:BAL]FIY

Gosub SET_FIRST From TRTFIRST
For [LNK]CLE(2) : # Devise
 DEVBAL = [F:BAL]CUR
 POIERR = 1  : # Bug 7889 : controles bloquants uniquement en devise société
# If DEVBAL<>[F:GCM]CUR(LEDTYP-1) : POIERR=0 : Endif
 For [LNK]CLE(4) : # Site
  SITBAL = [F:BAL]FCY
  Raz BALDEB, BALCRE, BALDEBLED, BALCRELED
  For [LNK]CLE(5) : # Compte
   COMPTE = [F:BAL]ACC
   If GBROWS :  Call AFF_VLC(SOCIETE-"/"-SITBAL,COMPTE) From GESECRAN : Endif
   Raz COLDEB, COLCRE, COLDEBLED, COLCRELED
   For [LNK]CLE : # Tiers
    TIERS = [F:BAL]BPR
    If TIERS=""
     For P=0 To MAXPER-1
      BALDEB(P) += [F:BAL]DEB(P)

      BALCRE(P) += [F:BAL]CDT(P)
      BALDEBLED(P) += [F:BAL]DEBLED(P)
      BALCRELED(P) += [F:BAL]CDTLED(P)
     # Call ECR_TRACE("FLG1 " + num$(P)+ "--> " + num$(BALDEB(P)) + " - " + num$(BALCRE(P)) + " - " + num$(BALDEBLED(P)) + " - " + num$(BALCRELED(P)),0) From GESECRAN
     Next P

     If [F:GAC]SAC=2
      Gosub BAL_COL
     Endif
    Else
     For P=0 To MAXPER-1
      COLDEB(P) += [F:BAL]DEB(P)
      COLCRE(P) += [F:BAL]CDT(P)
      COLDEBLED(P) += [F:BAL]DEB(P)
      COLCRELED(P) += [F:BAL]CDT(P)
     Next P
    Endif
   Next
  Next

  Gosub BAL_SIT

 Next
Next
Gosub UNSET_FIRST From TRTFIRST
Filter [BAL]
Return

$BAL_SIT
If TEST : Call ECR_TRACE(time$-"BAL_SIT"-DEVBAL-SITBAL,0) From GESECRAN : Endif
For P=0 To MAXPER-1

 # Montant Transaction et Montant référentiel
 Raz FLG1, FLG2
 If BALDEB(P)<>BALCRE(P)      Then
     Call ECR_TRACE("FLG1 " + num$(P)+ "--> " + num$(BALDEB(P)) + " - " + num$(BALCRE(P)) + " - " + num$(BALDEBLED(P)) + " - " + num$(BALCRELED(P)),0) From GESECRAN
    FLG1=1
 Endif
 If BALDEBLED(P)<>BALCRELED(P) Then
  Call ECR_TRACE("FLG2 " + num$(P)+ "--> " + num$(BALDEB(P)) + " - " + num$(BALCRE(P)) + " - " + num$(BALDEBLED(P)) + " - " + num$(BALCRELED(P)),0) From GESECRAN
   FLG2=1
  Endif

 If FLG1 or FLG2
  Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
  Call ECR_TRACE(mess(58,116,1)-DEVBAL-SITBAL-mess(64,116,1),POIERR) From GESECRAN            # Balance déséquilibrée
  If P=0
   Call ECR_TRACE(mess(59,116,1)-num$(P),0) From GESECRAN                                  #  Période
  Else
   Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                        # Période
  Endif

  If FLG1
   Call LEC_TCU(DEVBAL) From CPTLEC
   Call ECR_TRACE(format$("K:30X",mess(65,116,1))
&                +num$(BALDEB(P))+" "+DEVBAL+"   "
&                +num$(BALCRE(P))+" "+DEVBAL,0) From GESECRAN    #  Total Balance
  Endif

  If FLG2
   Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
   Call ECR_TRACE(format$("K:30X",mess(60,116,1)-left$(mess(153,116,1),11))
&                +num$(BALDEBLED(P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                +num$(BALCRELED(P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Balance Référentiel
   ANOM += 1
  Endif
 Endif
Next P
Return

$BAL_COL
If TEST : Call ECR_TRACE(time$-"BAL_COL"-DEVBAL-SITBAL-COMPTE,0) From GESECRAN : Endif
For P=0 To MAXPER-1
 # Montant Transaction et Montant référentiel
 Raz FLG1, FLG2
 If COLDEB(P)<>COLCRE(P)       : FLG1=1 : Endif
 If COLDEBLED(P)<>COLCRELED(P) : FLG2=1 : Endif

 If FLG1 or FLG2
  Read [PER]PER0 = SOCIETE;LEDTYP;EXERCICE;P
  Call ECR_TRACE(mess(58,116,1)-DEVBAL-SITBAL-COMPTE-mess(64,116,1),POIERR) From GESECRAN       # Balance déséquilibrée
  If P=0
   Call ECR_TRACE(mess(59,116,1)-num$(P),0) From GESECRAN                                  #  Période
  Else
   Call ECR_TRACE(mess(59,116,1)-num$(P)-format$("D:"+GFMDAT4,[F:PER]PERSTR)
&                -format$("D:"+GFMDAT4,[F:PER]PEREND),0) From GESECRAN                          # Période
  Endif

  If FLG1
   Call LEC_TCU(DEVBAL) From CPTLEC
   Call ECR_TRACE(format$("K:30X",mess(65,116,1))
&                +num$(COLDEB(P))+" "+DEVBAL+"   "
&                +num$(COLCRE(P))+" "+DEVBAL,0) From GESECRAN    #  Total Balance
  Endif

  If FLG2
   Call LEC_TCU([F:GCM]CUR(LEDTYP-1)) From CPTLEC
   Call ECR_TRACE(format$("K:30X",mess(60,116,1)-left$(mess(153,116,1),11))
&                +num$(COLDEBLED(P))+" "+[F:GCM]CUR(LEDTYP-1)+"   "
&                +num$(COLCRELED(P))+" "+[F:GCM]CUR(LEDTYP-1),0) From GESECRAN    #  Balance Référentiel
   ANOM += 1
  Endif
 Endif

Next P
Return

#-- Feature 79527 - SP2US26
$VERF_HAT
Raz FILTHAT, IFILH

Call ADDCRIT(FILTHAT,IFILH,"LEDTYP",'[F:DAT]LEDTYP='+num$([L]LEDTYP)," & ") From GOBJSUB
Call ADDCRIT(FILTHAT,IFILH,"CPY",'[F:DAT]CPY="'+SOCIETE+'"'," & ") From GOBJSUB
If SITE<>""
 Call ADDCRIT(FILTHAT,IFILH,"FCY",'[F:DAT]FCYLIN="'+SITE+'"'," & ") From GOBJSUB
Endif
Call ADDCRIT(FILTHAT,IFILH,"FIY",'FIY='+num$(EXERCICE)," & ") From GOBJSUB
If COMPTE<>""
 Call ADDCRIT(FILTHAT,IFILH,"ACC",'[F:DAT]ACC="'+COMPTE+'"'," & ") From GOBJSUB
Endif
If DEVISE<>""
 Call ADDCRIT(FILTHAT,IFILH,"CUR",'[F:DAT]CUR="'+DEVISE+'"'," & ") From GOBJSUB
Endif


#-- Link GACCOUNT & GACCENTRY
Link [DAT] With [HAT]HAT0~=[F:DAT]TYP;[F:DAT]NUM As [LNK]
&              Where [F:HAT]FLG>=100 & evalue(FILTHAT)
Return

########################################
Subprog AM_SOCIETE(VALEUR)
Variable Char VALEUR
GSOCIETE = VALEUR
Call SETMAINREF(GSOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Call DEFEXE(VALEUR,[M:DIA]LEDTYP,[M:DIA]EXERCICE) From CPTSUB
Call DATEXE(VALEUR,[M:DIA]LEDTYP,[M:DIA]EXERCICE,[M:DIA]DATDEB,[M:DIA]DATFIN) From CPTSUB
If !GIMPORT
 Affzo EXERCICE, DATDEB, DATFIN
Endif
End

Subprog AS_TOUSITE(VALEUR)
Variable Integer  VALEUR
Call INIALLFCY(VALEUR,[M]SOCIETE) From CPTTRT
End

Subprog AS_SITE(VALEUR)
Variable Char VALEUR
If [M]TOUSITE = 2 : VALEUR = "" : mkstat = 1 : End : Endif
End

Subprog AS_LEDTYP(VALEUR)
Variable Integer VALEUR
Call LEDTYP_CHOICE([M:DIA]SOCIETE,1) From CPTDIV
End

Subprog C_LEDTYP(VALEUR)
Variable Integer VALEUR
Local Char LED(GLONLED),DEV(GLONCUR)
Local Integer ILED
Call LECLED([M:DIA]SOCIETE,VALEUR,LED,DEV) From CPTDIV
ILED = find(LED,GLED(1..GLEDNBR))
If !ILED : End : Endif
[M:DIA]COA = GLEDCOA(ILED)
End

Subprog C_EXERCICE(VALEUR)
Variable Decimal VALEUR
Read [FIY]FIY0 = [M]SOCIETE;[M:DIA]LEDTYP;VALEUR
If fstat
 GMESSAGE = mess(52,116,1) : mkstat = 2 : End            # Exercice incorrect
Endif
If [F:FIY]FIYSTA>2
 Local Integer OK
 OK = 1 : Call AVERTIR(mess(21,101,1),OK) From GESECRAN : # Exrcice clôturé
 If OK<>2 : mkstat = 2 : End : Endif
Endif
[M]DATDEB = [F:FIY]FIYSTR
[M]DATFIN = [F:FIY]FIYEND
End

Subprog AS_EXERCICE(VALEUR)
Variable Decimal VALEUR
If VALEUR=0
 Call DEFEXE([M]SOCIETE,[M:DIA]LEDTYP,VALEUR) From CPTSUB
Endif
End

Subprog C_BALGEN(VALEUR)
Variable Integer VALEUR
If VALEUR = 1 & [M:DIA]TOUSITE<>2
 Local Char CODLED(GLONLED), DEVLED(GLONCUR)
 Call LECLED([M:DIA]SOCIETE,[M:DIA]LEDTYP,CODLED,DEVLED) From CPTDIV
 Call LECTURE("LED",[L]CODLED,"") From CONTOBJ
 If [F:LED]FCYBAL<>2
  GMESSAGE = mess(207,107,1)
  mkstat = 2 : End
 Endif
Endif
End
