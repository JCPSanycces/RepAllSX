#<AdxTL>@(#)0.0.0.0 $Revision$
## CBG20080902 - SUPPORT-3698
## LOS ABONOS DE TIENDA NO ESTÁN GENERANDO EL MOVIMIENTO DE STOCK EN TIENDA
## HAY QUE CREAR EL STOCK POR ENTRADA VARIA, ENLAZANDO LA ENTRADA VARIA CON
## EL ABONO QUE LO GENERA
## El script busca todas las Facturas de Abono de Canarias, Tienda o Franquicias (Plantas P..., C..., F... INVTYP = 2 y SIVTYP = 'AV')
## Para posteriormente en las lineas generar una Entrada varia (llamando al modelo de Importacion ZAQSSMRAT)
## y especificando el numero de factura en el campo VCRDES
## Ademas especifica la entrada varia en el campo ZDEVSRM de SINVOICEV
## El proceso se puede lanzar manualmente desde Mas > Alehop > Interfaces > Generacion Stock a Partir de Abonos Tienda
## En la pantalla podemos lanzar una simulación que únicamente nos dirá en una traza qué y cuántas facturas se procesarán
## Falta crear un proceso batch que ejecute este proceso regularmente
## XVT270121 no se actualiza correctamente el campo SINVOICEV.ZDEVSMR por lo que se están importando varias veces los mismos
## abonos.
$ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub TRT_INI
  When "EXEC"           : Gosub EXEC_SYNSTO
  When "TERMINE"        : Gosub TERMINE_SYNSTO
  When "INIT"           : Gosub INIT_DIA_SYNSTO
  When "OK"             : Gosub OK_SYNSTO
  When "END"            : Gosub END_SYNSTO
  When Default
Endcase
Return

$EXEC_SYNSTO
#Inter 1
Gosub TRT_INI
Gosub PROCESAABONOS
Return


$TRT_INI
#Aqui deberiamos inicializar las Tablas
Return


$TERMINE_SYNSTO
#Aqui no hacemos nada (podriamos cerrar la traza)
Return


$INIT_DIA_SYNSTO
#Inicializo pantalla [M:ZEAT]
Local Mask ZABOTIEN [ZEAT]
Raz [M:ZEAT]
[M:ZEAT]SIMULACION = 2
Return

$OK_SYNSTO
FIN  = 1
Return

$END_SYNSTO
Raz [M:ZEAT]
FIN = 1
Return

$PROCESAABONOS

Local Char LFILE_W : LFILE_W = ""
Local Char LSEP : LSEP = ";"
Local Char LTRAZA : LTRAZA = ""
Local Integer LI : LI = 1
Local Decimal LPRECIO : LPRECIO = 0

Local Char LFECHA
Local Char LHORA

If clalev([SIV]) = 0 : Local File SINVOICEV[SIV] : Endif
If clalev([SID]) = 0 : Local File SINVOICED[SID] : Endif
If clalev([SMH]) = 0 : Local File SMVTH[SMH] : Endif
If clalev([ITV]) = 0 : Local File ITMMVT[ITV] : Endif
If clalev([SIH]) = 0 : Local File SINVOICE[SIH] : Endif

#Con esta variable detectamos si estamos en modo simulación (=2), con lo que solo escribiremos una traza, o sin simulacion (=1), con lo que generaremos los movimientos
LTRAZA = num$([M:ZEAT]SIMULACION)
#Infbox "SIMULACION ES " + LTRAZA

#Con GSERVEUR detectamos si estamos en un proceso Batch (GSERVERUR = 1) o interactivo (a petición GSERVEUR = 0)
#Infbox "GSERVEUR es " + num$(GSERVEUR)

If LTRAZA = "2"
  Call OUVRE_TRACE("Generación Entradas Varias desde Abonos Tiendas") From LECFIC
  Call ECR_TRACE("[TRAZA]Inicio Proceso", 0) From GESECRAN
Endif

#Bucle Principal: buscamos factura con INVTYP = 2 (Abonos), SIVTYP = 2 ("AV") y ZDEVSMR vacío (sin movimientos generados)
#DONE: Buscar por fecha > 01-04-2020
#DONE: SALCFCY "P" "C" O "F"

#Filtro buscando solo una factura en concreto
#Filter [SIV] Where [SIV]INVTYP = 2 and [SIV]SIVTYP = "AV" and [SIV]NUM = "VR20082125520001" #and [SIV]ZDEVSMR = ""

#Filtro buscando SOLO ALGUNAS facturas de tienda P, C, F con fecha > 01/04/2020 con Tipo AV (Abono venta tienda), INVTYP = 2 (Abono) y ZDEVSMR vacío (sin movimiento origen)
#Filter [SIV] Where [SIV]INVTYP = 2 and [SIV]INVDAT >= gdat$(1,4,2020)  and [SIV]SIVTYP = "AV" and ([SIV]NUM = "VR2005146720001" or [SIV]NUM = "VR2005149630001" or [SIV]NUM = "VR20051412420001" or
# [SIV
#& ]NUM = "VR20051415440001" or [SIV]NUM = "VR20051419720001") and [SIV]ZDEVSMR = ""  and ( left$([SIV]SALFCY,1)="P" or left$([SIV]
#& SALFCY,1)="C" or left$([SIV]SALFCY,1)="F"
#& )

#Filtro buscando todas las facturas de tienda P, C, F con fecha > 01/04/2020 con Tipo AV (Abono venta tienda), INVTYP = 2 (Abono) y ZDEVSMR vacío (sin movimiento origen)
Filter [SIV] Where [SIV]INVTYP = 2 and [SIV]SIVTYP = "AV" and [SIV]INVDAT >= gdat$(1,4,2020) and [SIV]ZDEVSMR = ""  and ( left$([SIV]SALFCY,1)="P" or left$([SIV]
& SALFCY,1)="C" or left$([SIV]SALFCY,1)="F"
& )

If rowcount([SIV]) > 0 Then
  #Recorremos la cabecera de la factura
  For [SIV]
   LI = LI + 1
   #Contador por si queremos evaluar X facturas (tanto si estan validadas como si no-ya comprobaremos si están validadas después)
   #If LI = 10   #7501
   #  Break
   #Endif
   #Infbox "El registro de factura es " + [SIV]NUM
   #Buscamos si esta validada-Solo procesamos las que esten validadas, las que no esperamos a cuando esten
   Read [SIH]SIH0 = [SIV]NUM
   #Infbox "La factura encontrada para ver si esta validada es " + [SIH]NUM
   #Infbox "El campo validada: " + num$([SIH]STA)
   #Solo la procesamos si esta validada
   If [SIH]STA = 3 Then
    #Aqui solo contaria las validadas
    #LI = LI + 1
    If LTRAZA = "1" Then
      #Abrimos un fichero por cada factura para llamar al modelo IMPORT
      LFILE_W = [SIV]NUM + ".CSV"
      #Infbox "El fichero sera " + "E:\IMPORT\TMP\" + [SIV]NUM
      #$ABRIR_FICHERO_W
      adxifs = ";"
      adxirs = chr$(13)+chr$(10)
      Openo "E:\IMPORT\" + LFILE_W  Using [ZIMP_W]

      #Escribimos en la cabecera del Fichero los datos necesarios para el modelo de Importacion
      Wrseq "E" + LSEP + "19" + LSEP + [SIV]SALFCY + LSEP + [SIV]INVDAT + LSEP + [SIV]NUM + LSEP + "EAT" + LSEP + "27" + LSEP + [SIV]NUM Using [ZIMP_W]

      #Ahora vamos a buscar las lineas de la Factura y buscamos el PMP del Articulo en la planta los articulos
      Filter [SID] Where [SID]NUM = [SIV]NUM
      If rowcount([SID]) > 0 Then
        For [SID]
          #Infbox "La planta de la linea es " + [SIV]SALFCY
          #Buscamos el PMP del Articulo en la planta
          LPRECIO = 0
          Filter [ITV] Where [ITV]ITMREF = [SID]ITMREF and [ITV]STOFCY = [SIV]SALFCY
          If rowcount ([ITV]) > 0 Then
             Read [ITV] First
             #Infbox "El precio es " + num$([ITV]AVC)
             LPRECIO = [ITV]AVC
             #Infbox "La variable vale " + num$([ITV]AVC)
          #Else Infbox "No se ha encontrado el articulo en los precios"
          Endif
          Filter[ITV]

          # Escribimos lineas en el fichero
         #Wrseq "L" + LSEP + [SID]ITMREF + LSEP + [SID]SAU + LSEP + num$([SID]QTY) + LSEP + num$([SID]NETPRI) Using [ZIMP_W]
          Wrseq "L" + LSEP + [SID]ITMREF + LSEP + [SID]SAU + LSEP + num$([SID]QTY) + LSEP + num$(LPRECIO) Using [ZIMP_W]
          Wrseq "S" + LSEP + [SID]SAU + LSEP + num$([SID]QTY) + LSEP + "TIENDA" + LSEP + "A" Using [ZIMP_W]
        Next
      Endif

      #Cerramos el fichero de escritura
      #$CERRAR_FICHERO_W
      Openo Using [ZIMP_W]

      #Ahora aqui llamamos al modelo de importacion ZAQSSMRAT que genera la Entrada Varia y le pasamos como parámetro nuestro fichero
      GERRTRACE = 0
      Call IMPORTSIL('ZAQSSMRAT',"E:\IMPORT\" + LFILE_W) From GIMPOBJ

      #Si el modelo de importacion ha ido bien buscamos en las Cabeceras de Movimiento (Entrada Varia) por el campo ZORIVCRNUM para ver el numero de movimiento
#xvt270121.o      If GERRTRACE = 0 Then
         #Infbox "El modelo de importacion ha funcionado!"
         Filter [SMH] Where [SMH]VCRDES = [SIV]NUM
       If rowcount([SMH]) > 0 Then
        For [SMH]
          #Infbox "El movimiento generado es " + [SMH]VCRNUM
          #Entonces hacemos un rewrite de la Factura (SINVOICEV.ZDEVSMR) CON EL NUMERO DE ENTRADA VARIA GENERADO
          [SIV]ZDEVSMR = [SMH]VCRNUM
          Rewrite[SIV]
            #Infbox "Factura Modificada"
        Next
       Endif
      Endif
#    Else  Call ECR_TRACE([SIV]NUM, 0) From GESECRAN
#xvt270121.o    Endif

    #POR SI QUEREMOS HACERLO POR PARTES (POR EJEMPLO DE 7500 EN 7500)-Aqui solo contaría las validadas
    #If LI = 10   #7501
    # Break
    #Endif
   Endif
  Next
Else
  #Infbox "No hay registros"
  If LTRAZA = "2"
  Call ECR_TRACE("No hay registros.", 0) From GESECRAN    # Cerramos el fichero de Traza
Endif
Endif

If LTRAZA = "2"
  LI = LI - 1
  Call ECR_TRACE("Registros procesados: " + num$(LI), 0) From GESECRAN    # Cerramos el fichero de Traza
  Call FERME_TRACE From LECFIC    # Cerramos el fichero de Traza
  Call LEC_TRACE From LECFIC      # Mostramos el fichero de Traza
Endif

LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,7,4)+ mid$(LFECHA,4,2)+mid$(LFECHA,1,2)
LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

#TODO: Preguntar a Miguel si el Infbox este afecta al proceso Batch. No debería porque si GSERVEUR es 0 es sesión interactiva
#If GSERVEUR = 0 Then
#  Infbox "Proceso Finalizado a las " + LFECHA + "-" + LHORA
#Endif

Close Local File [SIV]
Close Local File [SID]
Close Local File [SMH]
Close Local File [ITV]
Close Local File [SIH]

Return
