#<AdxTL>@(#)0.0.0.0 $Revision$ Traspaso Caja-Banco
$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "OK"         : Gosub OK
  When "EXEC"       : Gosub EXEC
  When "AVANT_PAR"  : Gosub AVANT_PAR
  When "FIN"        : Gosub FIN
  When Default
Endcase

$OUVRE
  If !clalev([F:ZCJBSD]): Local File ZCAJABANCOSD [ZCJBSD]: Endif
  If !clalev([F:BPR]) : Local File BPARTNER   [BPR] : Endif
  If !clalev([F:APX]) : Local File APARIMPEXP [APX] : Endif
  If !clalev([F:ATD]) : Local File ATABDIV [ATD] : Endif

  Local Char TEST(250) : TEST =""
  Local Integer I : I=0
  Local Decimal SALDO : SALDO = 0.0
  Local Date ZEXEDAT  : ZEXEDAT = date$
  Local Integer FILEOPENED : FILEOPENED=0
  Local Decimal IMPORTED

  Local Char LFECHA(10), LHORA(10), LACCDAT(10)
  Local Char PLANTAFIN(5), SOCIEDAD(4)
  Local Char CUENTABANCO(8)
  Local Char IMPORTE(10)
  Local Integer ASIENTO_CREADO
  Local Integer I

  Local Char LFILE(50)
  Local Char LFILED(200)
  Local Char RUTA(50)
  Local Date MACCDAT
  Local Date FECHATOPE
  Local Integer MAXBUCLE : MAXBUCLE = 30
  Local Integer DINI, MINI, AINI
Return

$EXEC
    Gosub OUVRE
    Gosub OK
Return


$OK
# RECORRIDO A LOS CLIENTES DE TIENDAS PROPIAS Y CANARIAS
  Read [ATD]CODE=6007;'1'
  If !fstat Then
    MACCDAT=gdat$(val(mid$([ATD]A1,9,2)), val(mid$([ATD]A1,6,2)), val(mid$([ATD]A1,1,4)) )
#    MACCDAT= gdat$(01,01,2020)
#    FECHATOPE=gdat$(28,02,2020)
  Endif

  Call OUVRE_TRACE("Asiento CAJA-BANCO " + date$ ) From LECFIC
  For [BPR] Where BETFCY=2 and (left$(FCY,1) = "P" or left$(FCY,1) = "C")
#&   and ([BPR]BPRNUM = "91003" or [BPR]BPRNUM = "91005")  #limitación tiendas
  If left$([F:BPR]FCY,1) = "P" Then
    PLANTAFIN="OF001"
    SOCIEDAD ="CLAD"
  Else
    PLANTAFIN="OF002"
    SOCIEDAD ="CLCA"
  Endif
    I=0
$BUCLE
    I+=1
    ASIENTO_CREADO=0
    For [F:ZCJBSD]ZCJBSD0 Where [F:ZCJBSD]CPY=SOCIEDAD and [F:ZCJBSD]BPR=[F:BPR]BPRNUM
&     and [F:ZCJBSD]SALDO > 0
&     and [F:ZCJBSD]ACCDAT >= MACCDAT
#&     and [F:ZCJBSD]ACCDAT <= FECHATOPE
#&     and [F:ZCJBSD]SALDO > 1000
      If !fstat Then
        If [F:ZCJBSD]CUENTABAN = "" Then
          Call ECR_TRACE("Cuenta banco no encontrada: asiento no creado " + [F:ZCJBSD]FCY + " " + LACCDAT + " " + IMPORTE ,1 ) From GESECRAN
        Else
          Gosub CREA_ASIENTO
          Gosub IMPORTA_ASIENTO
          ASIENTO_CREADO += 1
        Endif
      Endif
      Break
    Next
    If ASIENTO_CREADO Then
      #ESTE BUCLE SE CREA PARA EVITAR LA GENERACIÓN DE ERRORES POR ACUMULACIÓN.
      #SI HAY UN CASO EN EL QUE NO SE CREÓ UN ASIENTO EN UNA FECHA PASADA, PORQUE FALLÓ EL BATCH, POR EJEMPLO,
      #ESTA LLAMADA SE ENCARGA DE CREAR PRIMERO UN ASIENTO ANTERIOR Y, UNA VEZ CREADO, REFRESCAR EL
      #CURSOR [F:ZCJBSD] CON LOS NUEVOS VALORES, TENIENDO EN CUENTA EL ASIENTO RECIÉN CREADO PARA
      #CREAR LOS SUCESIVOS. EN CASO DE NO HABER MÁS QUE UN ASIENTO A CREAR (EL ÚLTIMO), NO DEBERÍA ENTRAR
      #LA SEGUNDA VEZ EN EL For [F:ZCJBSD], PASANDO AL SIGUIENTE For [BPR], O SEA, SIGUIENTE TIENDA.
      If I < MAXBUCLE : Goto BUCLE : Endif
    Endif

  Next


  #CIERRE DE TABLAS Y FIN DEL PROCESO
  If clalev([F:ZCJBSD]): Close Local File [ZCJBSD]: Endif
  If clalev([F:BPR]) : Close Local File [BPR] : Endif
  If clalev([F:APX]) : Close Local File [APX] : Endif
  Call FERME_TRACE From LECFIC
  If !GSERVEUR Then
    Call LEC_TRACE From LECFIC
  Endif
Return


$AVANT_PAR
    If !clalev([M:DIA]) Then
         Local Mask ZAQSEXP [DIA]
    Endif
Return

$FIN
Return

# CREACIÓN DEL FICHERO DE ASIENTO
$CREA_ASIENTO

    Gosub ABRE_FICHERO

    #RELLENAR FICHERO EN REGISTRO ACTUAL
    LACCDAT = format$("D:YYYYMMDD",[F:ZCJBSD]ACCDAT)
    #OBTENER CUENTABANCO SEGÚN LA PLANTA
    CUENTABANCO = [F:ZCJBSD]CUENTABAN
    #IMPORTED = [F:ZCJBSD]SALDO-1000
    IMPORTED = [F:ZCJBSD]SALDO
    IMPORTE = num$(IMPORTED)
    Wrseq "G;CJBAN;;" + PLANTAFIN + ";TRAS;" + LACCDAT + ";" + [F:ZCJBSD]FCY + ";CAJABANCO-" + [F:ZCJBSD]BPR + "-" + LACCDAT + ";EUR;STDCO" Using [FIC]
    Wrseq "D;1;1;1;" + PLANTAFIN + ";;" + CUENTABANCO + ";;1;" + IMPORTE + ";EUR" Using [FIC]
    Wrseq "D;2;1;2;" + PLANTAFIN + ";CJ57;57000000;" + [F:ZCJBSD]BPR + ";-1;" + IMPORTE + ";EUR" Using [FIC]

    #CIERRE DEL FICHERO
    Openo Using [FIC]

Return



$ABRE_FICHERO
  #CREACIÓN DEL FICHERO
  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,7,4)+mid$(LFECHA,4,2)+mid$(LFECHA,1,2)
  LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)
  LFILE="CJB_"+[F:ZCJBSD]BPR+"_"+LFECHA+num$(adxuid(1))
  #LFILE="CAJABANCO_" + num$(adxuid(1))

  GOK = 1
  ##-- Buscaremos la ruta de los ficheros por defecto y crearemos la ruta final --##
  #Read [APX]APX0 = 'REPIMPDEF'
  #RUTA = [F:APX]DIRECTORY
  RUTA = "E:\IMPORT\IMP\CAJABANCO\" + nomap
  If RUTA = ""
      Call ERREUR(mess(121,141,1)) From GESECRAN
      End
  Endif

  LFILED = filpath(RUTA,LFILE,"TXT")

  Openo LFILED Using [FIC]

Return

$IMPORTA_ASIENTO
  mkstat = 0 : fstat = 0 : GERRTRACE = 0
  Call ECR_TRACE("Creando asiento " + [F:ZCJBSD]FCY + " " + LACCDAT + " " + IMPORTE, 0 ) From GESECRAN
  Call IMPORTSIL("ZCAJABANCO", LFILED) From GIMPOBJ
  mkstat = 0 : fstat = 0 : GERRTRACE = 0
Return

