$ACTION
  Case ACTION
    When "CTLRCPFCY" : Gosub CTLRCPFCY
    When Default
  Endcase
Return

# PUNTO DE ENTRADA CON EL QUE SE EVITA EL CONTROL PARA QUE LA DIRECCIÓN DE RECEPCIÓN
# SEA ÚNICA POR DIRECCIÓN DE ENTREGA
$CTLRCPFCY
  GPE = 1  # 1 --> EVITA EL CONTROL // 0 --> HACE EL CONTROL

Return

