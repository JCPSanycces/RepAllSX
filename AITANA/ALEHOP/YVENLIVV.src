#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION
  When "EXEC" : Gosub EXEC
  When Default
Endcase
Return


#########################################################################
$EXEC
Local   Decimal WQTY
Local   Integer J, NOL
Local   Integer LCON
Local   Integer LCAB  # variable de control de escritura de la cabecera de la entrada


If [M:SDH2]MDL = '' or [M:SDH2]BPTNUM='' Then # Modo Entrega o Transportista
  End
Endif

For LCON = 0 To NBLIG-1
    If [M:SDH1]FLGRUP(LCON)= 1 # EN RUPTURA
      If LCAB = 0 : LCAB = 1  : Endif
      Gosub GEN_SMR
    Endif
Next
Gosub CLOSE_FILE
Gosub IMP_SMR
Return


########################################################
#**
#* Genera una entrada de stock de la cantidad en espera
#* para aquellos artículos de la entrega con stock en ruptura
#*
#*!#**
$GEN_SMR
Local Char    LDATCAB(30)(8),LDATLIN(30)(5),LDATJOU(30)(5)
Local Char    LDIREXPORT(100) : LDIREXPORT = "E:\import\IMP\"
Local Char    LFILE(200), LRUTA(200)
Local Char    LSEP(1) : LSEP = ";"  # separador PARA TODOS LOS FICHEROS

Local Char LFECHA(10), LHORA(10)
LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)


# Recherche de la date du premier mouvement en attente d'un article
Local Date    LDATRUP
Local Decimal LQTYRUP
Call CTLRUP([M:SDH0]STOFCY,[M:SDH1]ITMREF(LCON),[M:SDH1]DLVDAT,0,LDATRUP,LQTYRUP) From STKLIB
#Infbox num$(LQTYRUP)


# Cabecera del movimiento
If LCAB = 1
    #####
    # SMVTH - cabecera
    ###
    # 1 -> Tipo asiento
    # 2 -> Planta stock
    # 3 -> Fecha imputación
    # 4 -> Descripción
    # 5 -> Código del movimiento
    # 6 -> Familia movimiento
    #####

      LFILE  = LDIREXPORT + "SMR_ERE_" + nomap(0) +"_"+ [M:SDH0]SDHNUM +".txt"
      # apertura de fichero
      Gosub OPEN_FILE

      Raz LDATCAB

      LDATCAB(1) = "19"         # entrada varia
      LDATCAB(2) = [M:SDH0]STOFCY
      LDATCAB(3) = date$
      LDATCAB(4) = "Rupt.Ent.: " + [M:SDH0]SDHNUM
      LDATCAB(5) = "ERE"        # Cod. movimiento > Entrada Rupturas Stock Entregas ERE
      LDATCAB(6) = "15"         # Fam. movimiento > Entrada Regularización Ausencias

      Wrseq '"E";' +
&                    '"' + LDATCAB(1) + '"' + LSEP +
&                    '"' + LDATCAB(2) + '"' + LSEP +
&                    '"' + LDATCAB(3) + '"' + LSEP +
&                    '"' + LDATCAB(4) + '"' + LSEP +
&                    '"' + LDATCAB(5) + '"' + LSEP +
&                    '"' + LDATCAB(6) + '"' + LSEP
&                    Using [ZEXP]

  LCAB = 2
Endif


#####
# SMVTD - detalle
###
# 1 -> Artículo
# 2 -> Unidad
# 3 -> Cantidad
# 4 -> Valor Unitario
#####

Raz LDATLIN
LDATLIN(1) = [M:SDH1]ITMREF(LCON)
LDATLIN(2) = [M:SDH1]STU(LCON)
LDATLIN(3) = num$(LQTYRUP) #num$([M:SDH1]QTYSTU(LCON))
LDATLIN(4) = num$([M:SDH1]CPRPRI(LCON))

Wrseq '"L";' +
&             '"' + LDATLIN(1) + '"' + LSEP +
&             '"' + LDATLIN(2) + '"' + LSEP +
&             '"' + LDATLIN(3) + '"' + LSEP +
&             '"' + LDATLIN(4) + '"' + LSEP
&             Using [ZEXP]


#####
# STOJOU - diario
###
# 1 -> Unidad
# 2 -> Cantidad
# 3 -> Ubicación
# 4 -> Estado
####
Raz LDATJOU
LDATJOU(1) = [M:SDH1]STU(LCON)
LDATJOU(2) = num$(LQTYRUP) #num$([M:SDH1]QTYSTU(LCON))
LDATJOU(3) = 'ALMACEN'
LDATJOU(4) = 'A'

Wrseq '"S";' +
&              '"' + LDATJOU(1) + '"' + LSEP +
&              '"' + LDATJOU(2) + '"' + LSEP +
&              '"' + LDATJOU(3) + '"' + LSEP +
&              '"' + LDATJOU(4) + '"' + LSEP
&              Using [ZEXP]

Return

########################################################
#**
#* Importa movimiento de entrada
#*!
$IMP_SMR
  Call IMPORTSIL("ZSMRSDH2", LFILE) From GIMPOBJ
Return

########################################################
$OPEN_FILE
adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE Using [ZEXP]
Return

########################################################
$CLOSE_FILE
Openo Using [ZEXP]
Return

