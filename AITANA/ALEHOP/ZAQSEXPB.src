Subprog EXPORTAR_AQS()
  Call OUVRE_TRACE("Proceso exportación Cástor " ) From LECFIC
  Call ECR_TRACE("entra bat", 0) From GESECRAN
  Call FERME_TRACE From LECFIC
if !GSERVEUR then
  Call LEC_TRACE From LECFIC
endif
End




