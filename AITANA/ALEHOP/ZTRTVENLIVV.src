#<AdxTL>@(#)0.0.0.0 $Revision$ 
# xvt 2019-11-27 - al generar varios ficheros ENVIO al día, el proceso AQS no está exportando
# correctamente los envios a pick. David solicita que se cree un único fichero.


$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION
  When "AFTSDHVAL"  : Gosub PROCESA_VALIDACION
  When Default
Endcase
Return

#########################################################
$PROCESA_VALIDACION

If [F:SDH]PRHFCY<>"" Then   # comprobamos que la entrega es Interplanta
  Gosub GET_PTH
Endif

Return


#########################################################
#**
#* Generar recepcion de compra a partir de la entrega
#*!
#XVT 20-11-2019 - Generar fichero ENVIO para AQS a partir de la entrega, en lugar de a partir de la recepción
#para que un fallo en la creación de la recepión en SAGE no impida que se cree el stock en AQS/PICK
$GET_PTH

#xvt20-11-2019.bn
Local Char LFECHA(10), LHORA(10)
Local Char LSEP(1) : LSEP = chr$(9)  # separador PARA TODOS LOS FICHEROS TABULADOR   #AQS.n

LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)
#xvt20-11-2019.en

Local Char    LFILE(200)
Local Char    LDIRIMPORT(250)

# 26/02/2020 - MS
If nomap(0) <> 'PRODUCLVD'
  LDIRIMPORT = "E:\PROTOCLVD\IMPORT\IMP\"
Else
  LDIRIMPORT = "E:\IMPORT\IMP\"
Endif

#xvt20-11-2019.bn
Local Char    LCOPY(200), LAQS(200)
Local Char    LDIREXPORT(250)
# 26/02/2020 - MS
If nomap(0) <> 'PRODUCLVD'
  LDIRIMPORT = "E:\PROTOCLVD\EXPORT\AQS\"
Else
  LDIREXPORT = "E:\EXPORT\AQS\"
Endif


#LCOPY   = LDIREXPORT + "COPIA\ENVIO_" + LFECHA + LHORA + ".txt"   #xvt2019-11-27.o
#LAQS       = LDIREXPORT + "ENVIO_" + LFECHA + LHORA + ".txt"      #xvt2019-11-27.o
LCOPY   = LDIREXPORT + "COPIA\ENVIO_" + LFECHA  +  ".txt"   #xvt2019-11-27.n
LAQS    = LDIREXPORT + "ENVIO_" + LFECHA +  ".txt"         #xvt2019-11-27.n

#xvt20-11-2019.en


Gosub GEN_PTH             # generar fichero
#Gosub IMP_PTH             # importar fichero  #xvt 20-11-2019.o la importación se hará en batch por rendimiento

Return

#########################################################
# generar fichero
$GEN_PTH

Local Char LDATCAB(30)(10),LDATLIN0(30)(15),LDATLIN1(30)(15)
Local Char LDATLIN2(30)(15)  #XVT20-11-2019.n


# ruta del fichero..
LFILE  = LDIRIMPORT + [F:SDH]SDHNUM+"_PTH_"+LFECHA+".txt"

Gosub OPEN_FILE

# Modelo Importacón ZPTH
#Id,Tabla     Campo   Descripción
# E PRECEIPT  /
# E PRECEIPT  PRHFCY  Planta recepción
# E PRECEIPT  RCPDAT  Fecha recepción
# E PRECEIPT  PTHNUM  Nº recepción
# E PRECEIPT  BPSNUM  Proveedor             Cte. 90001
# E PRECEIPT  TRSCOD  Código movimiento     Cte. REC
# E PRECEIPT  BPSNDE  N. VE proveedor       Nº entrega de la Central
# E PRECEIPT  INVLINNBR N.líneas tot.fact.  Igualar a LINNBR, n.líneas
# E PRECEIPT  INVLINCTR N.líneas facturadas Igualar a LINNBR, n.líneas
# E PRECEIPT  INVFLG  Facturado             Siempre a 3 Totalmente     QUITADO DEL MODELO
# L PRECEIPTD /                             0 Indica recepcion grabada desde X3
# L PRECEIPTD ITMREF  Artículo
# L PRECEIPTD UOM     Unidad recepción
# L PRECEIPTD QTYUOM  Cantidad UOM
# L PRECEIPTD GROPRI  Precio bruto
# L PRECEIPTD CPRAMT  Coste fijo unitario
# L PRECEIPTD TRSFAM  Familia movimiento    Cte. 10
# L PRECEIPTD POHNUM
# L PRECEIPTD POPLIN
# L PRECEIPTD SDHNUM
# L PRECEIPTD SDDLIN
# L PRECEIPTD LININVFLG Línea Facturada     Siempre a 2               QUITADO DEL MODELO
# S STOJOU  /
# S STOJOU    PCU     Unidad
# S STOJOU    QTYPCU  Cantidad              Igual que QTYUOM
# S STOJOU    LOC     Ubicación             Cte. TIENDA
# S STOJOU    STA     Estado                Cte. A

#  Ejempo de Fichero
# "E";"C0137";"20180618";"";"90001";"REC";"EPALM0218000035";"1";"1";
# "L";"9000001";"UN";"1";"7.5";"7.5";"10";"PCC013718000025";"1000";"EPALM0218000035";"1000";
# "S";"UN";"1";"TIENDA";"A";

If clalev([ZENTR]) = 0  : Local File SDELIVERY [ZENTR] : Endif
If clalev([ZSDD]) = 0 : Local File SDELIVERYD [ZSDD] : Endif
If clalev([ZSP]) = 0    : Local File ZSDHPOH [ZSP]     : Endif

Filter [ZENTR] Where SDHNUM = [F:SDH]SDHNUM

For [ZENTR]
  LDATCAB(1) = [ZENTR]PRHFCY
  LDATCAB(2) = [ZENTR]SHIDAT
  LDATCAB(3) = ""
  LDATCAB(4) = "90001"
  LDATCAB(5) = "REC"
  LDATCAB(6) = [ZENTR]SDHNUM
  LDATCAB(7) = num$([ZENTR]LINNBR)
  LDATCAB(8) = num$([ZENTR]LINNBR)

  Wrseq '"E";' +'"'+LDATCAB(1)+'";' +'"'+LDATCAB(2)+'";' +'"'+LDATCAB(3)+'";' +'"'+LDATCAB(4)+'";'
&              +'"'+LDATCAB(5)+'";' +'"'+LDATCAB(6)+'";' +'"'+LDATCAB(7)+'";' +'"'+LDATCAB(8)+'";'
&              Using [ZIMP]





  Filter [F:ZSDD] Where [F:ZSDD]SDHNUM = [F:ZENTR]SDHNUM

  Raz  LDATLIN0, LDATLIN1, LDATLIN2

  For [F:ZSDD]

    Filter [F:ZSP] Where SDHNUM = [F:ZSDD]SDHNUM and SDDLIN = [F:ZSDD]SDDLIN
    Read [F:ZSP] First


    LDATLIN0(1) = [F:ZSDD]ITMREF
    LDATLIN0(2) = [F:ZSDD]STU
    LDATLIN0(3) = num$([F:ZSDD]QTYSTU)
    LDATLIN0(4) = num$([F:ZSDD]GROPRI)
    LDATLIN0(5) = num$([F:ZSDD]GROPRI)
    LDATLIN0(6) = "10"
    LDATLIN0(7) = [F:ZSP]POHNUM
    If num$([F:ZSP]POPLIN) = "0" Then : LDATLIN0(8) = "" : Else : LDATLIN0(8) = num$([F:ZSP]POPLIN) : Endif
    LDATLIN0(9) = [F:ZSP]SDHNUM
    If num$([F:ZSP]SDDLIN) = "0" Then : LDATLIN0(10) = "" : Else : LDATLIN0(10) = num$([F:ZSP]SDDLIN) : Endif

    Wrseq '"L";' +'"'+LDATLIN0(1)+'";' +'"'+LDATLIN0(2)+'";' +'"'+LDATLIN0(3)+'";' +'"'+LDATLIN0(4)+'";' +'"'+LDATLIN0(5)+'";' +'"'+LDATLIN0(6)+'";'
&                +'"'+LDATLIN0(7)+'";' +'"'+LDATLIN0(8)+'";' +'"'+LDATLIN0(9)+'";' +'"'+LDATLIN0(10)+'";' Using [ZIMP]

    LDATLIN1(1) = [F:ZSDD]STU
    LDATLIN1(2) = num$([F:ZSDD]QTYSTU)
    LDATLIN1(3) = "TIENDA"
    LDATLIN1(4) = "A"

    Wrseq '"S";' +'"'+LDATLIN1(1)+'";' +'"'+LDATLIN1(2)+'";' +'"'+LDATLIN1(3)+'";' +'"'+LDATLIN1(4)+'";' Using [ZIMP]

##XVT20-11-2019.bn
## mejora: crear el fichero ENVIO para AQS al validar la entrega, en lugar de con la recepción
 ######
  # Estructura
  ###
  # POSICIÓN                              TIPO        LONGITUD        FORMATO
  # 1  -> Código almacén(Tienda)          Numérico      3             Rellenar 0 por delante
  # 2  -> Nº albarán                      Numérico      6
  # 3  -> Fecha                           Fecha         8             dd.mm.aa
  # 4  -> Código artículo                 Numérico      7             Rellenar 0 por delante
  # 5  -> Cantidad                        Numérico
  # 6  -> Precio cesión                   Numérico

    LDATLIN2(1)= right$([F:ZSDD]BPCORD, 3)
    LDATLIN2(2)= [F:ZSDD]SDHNUM
    LDATLIN2(3)= format$("D:DD[-]MM[-]YY"  ,[F:ZSDD]SHIDAT)
    LDATLIN2(4)= [F:ZSDD]ITMREF
     Call GET_FORMAT(LDATLIN2(4), 7, "0", LDATLIN2(4)) From SPEAQSE
    LDATLIN2(5)= num$([F:ZSDD]QTYSTU)
    LDATLIN2(6)= ctrans(format$("N:6.2" ,[F:ZSDD]GROPRI), ",",".")

      #escribimos en el fichero...
  Wrseq LDATLIN2(1)  + LSEP +
&       LDATLIN2(2)  + LSEP +
&       LDATLIN2(3)  + LSEP +
&       LDATLIN2(4)  + LSEP +
&       LDATLIN2(5)  + LSEP +
&       LDATLIN2(6)
&   Using [ZAQS]

  #escribimos en el fichero copia...
  Wrseq LDATLIN2(1)  + LSEP +
&       LDATLIN2(2)  + LSEP +
&       LDATLIN2(3)  + LSEP +
&       LDATLIN2(4)  + LSEP +
&       LDATLIN2(5)  + LSEP +
&       LDATLIN2(6)
&   Using [ZCOPY]

##XVT20-11-2019.en

  Next
  Filter [ZSDD]
  Filter [ZSP]
Next

Filter [ZENTR]

Close Local File [ZENTR]
Close Local File [ZSP]
Close Local File [ZSDD]

# cerrar fichero import
Gosub CLOSE_FILE

Return


#########################################################
# importar fichero
$IMP_PTH
## XVT 20-11-2019.bo
## modificación para mejorar el tiempo de respuesta en la validación de entregas
## la importación de los ficheros de recepción se realizará en una tarea BATCH
## no ejecutamos el siguiente código
#mkstat = 0 : fstat = 0 : GERRTRACE = 0
#
#Call OUVRE_TRACE("Creación Recepcion a partir de Entrega Validada") From LECFIC
#
#Call IMPORTSIL("ZPTH", LFILE) From GIMPOBJ
#
#
#Call FERME_TRACE From LECFIC
#
##Call LEC_TRACE From LECFIC   #si se quiere mostrar traza
#
#mkstat = 0 : fstat = 0 : GERRTRACE = 0
## XVT 20-11-2019.bo
Return


########################################################
$OPEN_FILE

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE Using [ZIMP]
Openo LAQS,-1 Using  [ZAQS]   #xvt20-11-2019.n
Openo LCOPY,-1 Using [ZCOPY]  #xvt20-11-2019.n

Return


########################################################
$CLOSE_FILE

Openo Using [ZIMP]
Openo Using [ZAQS]  #xvt20-11-2019.n
Openo Using [ZCOPY] #xvt20-11-2019.n

Return

