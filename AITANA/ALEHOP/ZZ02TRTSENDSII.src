#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "WSIIFILE" : Gosub FICHERO
  When "WVARPOST" : Gosub WVARPOST
  When "BEFWRISII": Gosub BEFWRISII
Endcase
Return

$FICHERO

Local Char LFILE(200)
Local Char ZFECHA
Local Char ZHORA

ZFECHA = vireblc(num$(date$),4)
ZHORA  = vireblc(num$(time$),4)
ZFECHA = mid$(ZFECHA,1,2)+mid$(ZFECHA,4,2)+mid$(ZFECHA,7,4)
ZHORA  = mid$(ZHORA,1,2)+mid$(ZHORA,4,2)+mid$(ZHORA,7,2)

LFILE = ZFECHA + "_" + ZHORA

Openo filpath ("BQT",LFILE,"XML"), 0 Using [XXX]
Wrseq DATAXML Using [XXX]
Openo Using [XXX]
Return

$WVARPOST
If WLIBRO = 2  # Facturas recibidas
  If !clalev([ZPIH])  : Local File PINVOICE [ZPIH]  : Endif
  For WIND = 0 To IND
    Filter [ZPIH] Where SPACUS = WNUMFACID(WIND)
    Read [ZPIH] First
    If !fstat
      WFECHAOPE(WIND)=format$("D:DD[-]MM[-]YYYY", [ZPIH]ZSPACUSDAT)
      WFECHAEXPEDICION(WIND)=format$("D:DD[-]MM[-]YYYY", [ZPIH]ZSPACUSDAT)
    Endif
  Next
Endif

Return


