#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$ Condition saisie champ
########################################################################
#  Sous programmes                                      appeles par CALL
########################################################################
# MAJ_SRG_STAFLG         Mise à jour STAFLG (cochage / decochage) STOSRG
# ACTRUB_LIGNE                  desactivation / activation des rubriques
# CTRCLESRG                                    CONTROLE existence STOSRG
# CTRPPSSRG                Controle existence liste à ranger dans STOSRG
# TRT_STOSRGW_ENRSSL    Enregistrement  suppression / reecriture STOSRGW
# MAJ_SRG_SRGPPS              Mise à jour SRGPPS (enregistrement) STOSRG
# CHARG_PARAM_STOENT          chargement blocs entete parametrage STOENT
# INIT_SSL1                      Initialisation des rubriques stock SSL1

########################################################################
#  Sous programmes                                     appeles par GOSUB
########################################################################
# STKSELTRS                                        Selection transaction
# STKSELSRG                                 Selection sur fichier STOSRG
# STKSELSRGS                Selection sur fichier STOSRG selection piece
# STKSELPPS      Selection sur fichier STOSRG   numero de liste à ranger
# STKVERSRG                                      controle fichier STOSRG
# SET_NOL                                      Alimentation rubrique NOL
# ACT_RUB_CLE                              activation des rubriques cles
# DES_RUB_DESTINATION           desactivation des rubriques destinations
# ACT_RUB_DESTINATION              activation des rubriques destinations
# CHARGETYP_BLOC20      Chargement premiere ligne du bloc 20 saisie type
# CHARGESTR_BLOC20    chargement premiere ligne du bloc 20 saisie NUMSTR
# CHARGEEND_BLOC20    chargement premiere ligne du bloc 20 saisie NUMEND
# LOAD_FILTER            Préparation du filtre bloc filtre  table STOSRG
# LOAD_FILTER2 préparation du filtre  bloc selection / date table STOSRG
# LOAD_FILTER3  Préparation du filtre bloc Bornes debut fin table STOSRG
# LOAD_FILTER4 préparation du filtre  bloc selection / type table STOSRG
# LOAD_CRITERE                                     Concaténation CRITERE
# LOAD_CRITERE2                                   Concaténation CRITERE2
# LOAD_CRITERE3                                   Concaténation CRITERE3
# LOAD_CRITERE4                                   Concaténation CRITERE4
# TRI_TAB                             tri du tableau suivant parametrage
# RECH_CLE                      RECHERCHE meilleur cle pour optimisation
# CTR_EXI_SSL1 Controle existance tableau SSL1 suite selection ou saisie
# FORMATAGE_CLE            Formatage d une zone pour recherche existance
# DECOCHAGE_SSL1  Mise à jour du flag STAFLG à 1 en cas d abandon ou fin
# LECTURE_STOSRG                                          lecture STOSRG
# ACT_PIKSSL Selection par saisie rubrique cle remplisssage tableau SSL1
# DELETE_STOSRGW               Suppression d une ligne SSL1 dans STOSRGW
# ECRITURE_STOSRGW                Ecriture d une ligne SSL1 dans STOSRGW
# CHARGE_ENTW_STOSGW    Chargement du masque STOENTW à partir de STOSRGW
# MAJ_LIGNE_DOCUMENT          Mise à jour des quantités sortie SAISTOENT
# LEC_TABSTO                                         Lecture ITM ITF SRU
# GES_ITM                      affichage rubriques selon gestion article
# INI_GESLOT                                       initialisation GESLOT
# CTL_STOENT      Controle que stocou soit identique dans l ecran STOENT
# AB_TRT                                       Abandon de la transaction
# TRT_ORIGINE_TRSCOD                            recherche TRSCOD origine

########################################################################
#  Sous programmes                                A C T I O N S  boutons
########################################################################
# ACT_SELSSL          bouton RECHERCHE      remplisssage du tableau SSL1
# ACT_LISSSL   bouton LISTE    affectation d un numéro de liste à ranger
# ACT_IMPSSL   bouton IMP. LISTE               impression liste à ranger   (action abandonnée)
# ACT_ENRSSL         bouton ENREGISTREMENT enregistrement liste à ranger
# ACT_VALSSL  bouton VALIDATION  réalisation  changements d emplacements
# ACT_TRISSL bouton TRI            Tri du tableau SSL1 selon parametrage

########################################################################
# ACTION fenetres
########################################################################

#########################################################################
$TIT_TRT
    Call LECTEXTRA(TIT,"STKTRS","DESAXX","5",GSSLNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-GSSLNUM-":"-TIT
Return

######################################################################"
# SELTABLE
######################################################################"
$SELTABLE


Case GACTION
     When "STKSELSRG"       : Gosub STKSELSRG
     When "STKSELSRGS"      : Gosub STKSELSRGS
Endcase
Return

######################################################################"
# CONTROLE
######################################################################"
$CONTROLE
If GFLAG = ""
   FIN = 1
Endif
Return

######################################################################"
# SELLISTE
######################################################################"
$SELLISTE

Case LISTE
     When "SAISSL"          : Gosub STKSELTRS
     When "STKSELPPS"       : Gosub STKSELPPS
Endcase
Return

######################################################################"
# FINLISTE
######################################################################"
$FINLISTE

Case LISTE
     When "SAISSL"          : Gosub STKFINTRS
Endcase
Return

######################################################################"
# VERFTABLE
######################################################################"
$VERFTABLE

Case TABLE
  When "STKSELSRG"     : Gosub STKVERSRG
Endcase
Return

######################################################################"
# INIT
######################################################################"
$INIT
Return

######################################################################"
# OUVRE_BOITE
######################################################################"
$OUVREBOITE
Case GACTION
     When "SAISSL"       : Gosub OUVRE_SAISSL
     When "TRTCRISSL"    : Gosub OUVRE_TRTCRISSL
Endcase
Return

$OUVRE_SAISSL
# ouverture et lecture du dictionnaire des fenetres pour recuperer l ecran generé
If clalev([F:AWI])=0 Local File AWINDOW [AWI] : Endif
Local Char WNOMMSK(GLONAMK)
If dim(GHCBBOI)>0
   If GHCBBOI <> ""
      BOITE = GHCBBOI
   Endif
   Kill GHCBBOI
Endif

Read [AWI] AWI0=BOITE
If fstat
   WNOMMSK="SSL1"
Else
   WNOMMSK=[F:AWI]NOMMSK(0)
Endif
#
Gosub CHANGE_AWI From TRTSSLA
Call INIVAR From GLOBSTO

Global Char GHCBFCY(GLONFCY)

Return

$OUVRE_TRTCRISSL
Return
######################################################################"

######################################################################"
#                                                                OUVRE
######################################################################"
$OUVRE
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
#-----
If clalev([F:FCY])=0 Local File FACILITY   [FCY]  Endif
If clalev([F:STL])=0 Local File STOLOT     [STL]  Endif
If clalev([F:ITF])=0 Local File ITMFACILIT [ITF]  Endif
If clalev([F:ITM])=0 Local File ITMMASTER  [ITM]  Endif
If clalev([F:ITP])=0 Local File ITMBPS     [ITP]  Endif
If clalev([F:TUN])=0 Local File TABUNIT    [TUN]  Endif
If clalev([F:STJ])=0 Local File STOJOU     [STJ]  Endif
If clalev([F:STO])=0 Local File STOCK      [STO]  Endif
If clalev([F:STS])=0 Local File STOSER     [STS]  Endif
If clalev([F:STA])=0 Local File STOALL     [STA]  Endif
If clalev([F:ITG])=0 Local File ITMCATEG   [ITG]  Endif
If clalev([F:SRU])=0 Local File TABSTORUL  [SRU]  Endif
If clalev([F:TST])=0 Local File TABSTASTO  [TST]  Endif
If clalev([F:TLO])=0 Local File TABLOCTYP  [TLO]  Endif
If clalev([F:STC])=0 Local File STOLOC     [STC]  Endif
If clalev([F:SRT])=0 Local File STKTRS     [SRT]  Endif
If clalev([F:SRG])=0 Local File STOSRG     [SRG]  Endif
If clalev([F:SGW])=0 Local File STOSRGW    [SGW]  Endif
If clalev([F:TFO])=0 Local File TABFOR     [TFO]  Endif
If clalev([F:CAL])=0 Local File CPTANALIN  [CAL]  Endif
If clalev([F:DTR])=0 Local File DIETRS     [DTR]  Endif

If !clalev([F:ITV])  Local File ITMMVT     [ITV]  Endif
If GWIPSTOLCK=2
   If clalev([F:TWS])=0 Local File TABWIPSTO [TWS]  Endif
Endif
If clalev([M:ENTW])=0  Local Mask STOENTW    [ENTW]   Endif  #  ecran stockage mvt du document
If clalev([M:STW])=0   Local Mask STOWORK    [STW]    Endif  #  ecran stockage mvt à mettre à jour
If !clalev([M:SVW])  : Local Mask STOVALWORK [SVW] :  Endif
If !clalev([M:SVWD]) : Local Mask STOVALWORK [SVWD]:  Endif
If !clalev([M:SDPA]) : Local Mask SAIDECPRI  [SDPA] : Endif    # sert pour le rangement des modifications de lots
#-----
If GWRHACT=2
   If !clalev([F:WRH])  Local File WAREHOUSE  [WRH] : Endif
   If !clalev([F:ITW])  Local File ITMWRH     [ITW] : Endif
Endif

[M:ENTW]WZONPCU = "PCU"
[M:ENTW]WZONQUC = "QTYPCU"
[M:ENTW]WZONCCS = "PCUSTUCOE"
[M:ENTW]WZONQUS = "QTYSTU"
[M:ENTW]WZONSTOUPD = ""
GSRTNUM = GFLAG
GSSLNUM = GFLAG          # hcb 50197
Read [SRT] SRT0=5;GFLAG
If fstat | [F:SRT]ENAFLG=1 OK=0 : Endif

Read [DTR] DTR0="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;0;0
If fstat
   Raz [F:DTR]
Endif

Gosub STK_INILOC From STKLOC

# hcb 52838
If dim(GLECSTOSRG)>0
   Raz GLECSTOSRG
Else
   Global Integer GLECSTOSRG
Endif


Return

######################################################################"
#                                                                DEBUT
######################################################################"
$DEBUT
Case GACTION
     When "SAISSL"       : Gosub DEBUT_SAISSL
     When "TRTCRISSL"    : Gosub DEBUT_TRTCRISSL
Endcase
Return

$DEBUT_SAISSL
# Remise à zero du masque STOENTW
Call DELSTOENTW (-1,-1,"SSL1",1,1,[M:SSL1]STOFCY,0,"") From STKENT
#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 5 | [F:SRT]SRTNUM <> GSSLNUM
   Read [SRT]SRT0=5;GSSLNUM : If fstat Raz [F:SRT] : Endif
Endif

Raz   [M:SSL1]
Grizo [M:SSL1]LSTWIOFLG
[M:SSL1]FLGDAT    = 1
[M:SSL1]VCRTYPC1  = 1

# hcb 91033 deb
If clalev([M:SSLC])=0  Local Mask SSLC   [SSLC]  Endif  # hcb  92464
Raz  [M:SSLC]
If filinfo(filpath("ETM",GUSER+"_"+"STD","ssl",0),0)>=0
   Call LECMEMO("STD","[M:SSLC]","ssl") From GMEMO
   # Chargement des critères stockés dans le fichier mémo STD
   [M:SSL1]     = [M:SSLC]
Endif
# hcb 91033 fin

[M:SSL1]SRTCRIT1  = [F:SRT]CRIT1
[M:SSL1]SRTCRIT2  = [F:SRT]CRIT2
[M:SSL1]SRGWAIFLG = [F:SRT]SRGWAIFLG
[M:SSL1]SRGPPSCOD = [F:SRT]SRGPPSCOD
[M:SSL1]WRHOBY    = [F:SRT]WRHOBY
GWRHOBY           = [F:SRT]WRHOBY
[M:SSL1]VCRTYPSSL = 27

# controle ajoute le 18 03 04 HCB  : si on change la societe ,DEBUT_SAISSL remet celle par defaut
If GHCBFCY <> ""
   If  [M:SSL1]STOFCY <> GHCBFCY
       [M:SSL1]STOFCY =  GHCBFCY
   Endif
Endif

Grizo [M:SSL1]COCHAGE(0)
Affzo [M:SSL1] 5, 10, 15 ,25
Actzo [M:SSL1]10, 15 , 25
Gosub WRH_ETAT From TRTSSLA

REP = ""
GREP = ""

#--- Bug 65256
Onerrgo TRT_ONERRGO

Return

#--- Bug 65256
$TRT_ONERRGO
Gosub DECOCHAGE_SSL1
Resume
#---

$DEBUT_TRTCRISSL
Raz   [M:SSLC]
[M:SSL1]VCRTYPC   (0) = [M:SSL1]VCRTYPC1
[M:SSL1]VCRNUMSTR (0) = [M:SSL1]VCRNUMSTR1
[M:SSL1]VCRNUMEND (0) = [M:SSL1]VCRNUMEND1
[M:SSLC] = [M:SSL1]
Local Integer I
I = 0
For I = 0 To 5
    If [M:SSL1]VCRTYPC(I) = 0
        Break
    Endif
Next
[M:SSLC]BASPAG = I

If [M:SSL1]LSTWIOFLG = 1 & [M:SSL1]SRGPPSSTR <> ""
   Grizo [M:SSLC]FORMULE
   Grizo [M:SSLC]ITMREFSTR
   Grizo [M:SSLC]ITMREFEND
   Grizo [M:SSLC]LOCSTR
   Grizo [M:SSLC]LOCEND
   Grizo [M:SSLC]STASTR
   Grizo [M:SSLC]STAEND
   Affzo [M:SSLC]VCRTYPC
   Grizo [M:SSLC]VCRTYPC
   Grizo [M:SSLC]VCRNUMSTR
   Grizo [M:SSLC]VCRNUMEND
   If    dim([M:SSLC]WRHSTR) > 0
         Grizo [M:SSLC]WRHSTR
         Grizo [M:SSLC]WRHEND
   Endif
Endif
Gosub WRH_ETAT_SSLC From TRTSSLA
Affzo [M:SSLC]5,10,15

Return
######################################################################"
#                                                              ABANDON
######################################################################"
$ABANDON
Case GACTION
     When "SAISSL"       : Gosub ABANDON_SAISSL
     When "TRTCRISSL"    : Gosub ABANDON_TRTCRISSL
Endcase
Return

$ABANDON_SAISSL
Call DELSTOENTW (-1,-1,"SSL1",1,1,[M:SSL1]STOFCY,0,"") From STKENT

Raz [M:SSL1]SAIFLG

Call ACT_SELSSL From TRTSSLA

Affzo [M:SSL1]10,15
# hcb 60526 deb
Actzo  [M:SSL1]25
Grizo  [M:SSL1]VCRTYP
Grizo  [M:SSL1]VCRNUM
Grizo  [M:SSL1]VCRLIN
Grizo  [M:SSL1]ITMREF
Grizo  [M:SSL1]LOCORI
If dim([M:SSL1]WRHORI) > 0
   Grizo [M:SSL1]WRHORI
Endif
# il faut activer les zones de cle sur la ligne vide ....
Local Integer NOL
NOL = [M:SSL1]NBLIG
Gosub ACT_RUB_CLE
# hcb 60526  fin


REP = ""
GREP = ""

Return

$ABANDON_TRTCRISSL

Return

######################################################################"
#                                                             FINTABLE
######################################################################"
$FINTABLE
Return

######################################################################"
#                                                                  FIN
######################################################################"
$FINSAI
Case GACTION
     When "SAISSL"       : Gosub FIN_SAISSL
     When "TRTCRISSL"    : Gosub FIN_TRTCRISSL
Endcase
#----- Restitution des variables globales -----#
Gosub REST_GLOB From TRTX3GLOB
#-----
Return

$FIN_SAISSL
Call DELSTOENTW (-1,-1,"SSL1",1,1,[M:SSL1]STOFCY,0,"") From STKENT
Gosub DECOCHAGE_SSL1

Kill GHCBFCY
Return

$FIN_TRTCRISSL
Return
######################################################################"
#                                                               FIN
######################################################################"

$FIN

Return

######################################################################"
#                                                             APCHOIX
######################################################################"
$APCHOIX

Case GACTION
     When "SAISSL"       : Gosub APCHOIX_SAISSL
     When "TRTCRISSL"    : Gosub APCHOIX_TRTCRISSL
Endcase
Return

$APCHOIX_SAISSL
If [M:SSL1]NBLIG = 0
   REP = ""
   GREP = ""
Endif

# interception de la touche return
#  recherche si pas de lignes cochées
Local Integer I
Raz I
If REPONSE = GSTARET & !find( 2, [M:SSL1]COCHAGE(I..[M:SSL1]NBLIG-1))
   Call ACT_SELSSL From TRTSSLA
Endif

Return

$APCHOIX_TRTCRISSL
Return


######################################################################"
#                                                               ACTEND
######################################################################"
$ACTEND

Case GACTION
     When "SAISSL"       : Gosub END_SAISSL
     When "TRTCRISSL"    : Gosub END_TRTCRISSL
Endcase
Return

$END_SAISSL
Local Integer WOK
WOK = 0
For I = 0 To [M:SSL1]NBLIG-1
    If [M:SSL1]COCHAGE (I) = 2 & GREP = "M"
       WOK = 9
       Break
    Endif
Next I
If WOK = 9
   WOK = 0
# Avez vous enregistré  les enregistrements cochés ?
   Call OUINON(mess(61,184,1), WOK) From GESECRAN
   If WOK <> 2
      FIN = 0
   Endif
Endif
Return

$END_TRTCRISSL
Return

######################################################################"
#                                                                   OK
######################################################################"
$OK
Case GACTION
     When "SAISSL"       : Gosub OK_SAISSL
     When "TRTCRISSL"    : Gosub OK_TRTCRISSL
Endcase
Return

$OK_SAISSL

Return

$OK_TRTCRISSL
[M:SSL1]           = [M:SSLC]
[M:SSL1]VCRTYPC1   = [M:SSL1]VCRTYPC   (0)
[M:SSL1]VCRNUMSTR1 = [M:SSL1]VCRNUMSTR (0)
[M:SSL1]VCRNUMEND1 = [M:SSL1]VCRNUMEND (0)

Call ACT_SELSSL From TRTSSLA

Affzo [M:SSL1]10,15

Return


######################################################################"
#                                                               BOUTON
######################################################################"
$BOUTON

Case GACTION
     When "SAISSL"       : Gosub BOUTON_SAISSL
     When "TRTCRISSL"    : Gosub BOUTON_TRTCRISSL
Endcase
Return

$BOUTON_SAISSL
#si bouton recherche activation du bouton abandon
If BOUT = "a"
   REP = "M"
Endif
#si bouton criteres activation du bouton abandon
If BOUT = "b"
   REP = "M"
Endif

Return

$BOUTON_TRTCRISSL

Return

######################################################################"
#                                                              SETBOUT
######################################################################"
$SETBOUT

Case GACTION
     When "SAISSL"       : Gosub SETBOUT_SAISSL
     When "TRTCRISSL"    : Gosub SETBOUT_TRTCRISSL
Endcase
Return

$SETBOUT_SAISSL

REP = GREP
Local Integer NOL
Local Integer WLISTE
Raz WLISTE
Raz NOL

# Menu Options / Visu transaction
CHMEN += "H"
# ------------------------------------------------------------------------------------- #
# Suppression des boutons                                                               #
# ------------------------------------------------------------------------------------- #
#     A : Recherche                                                                     #
#     I : Tout inclure                                                                  #
#     J : Tout exclure                                                                  #
#     D : Criteres                                                                      #
#     C : Liste à ranger                                                                #
#     E : Enregistrement                                                                #
#     F : Validation                                                                    #
#     G : Tri                                                                           #
# ------------------------------------------------------------------------------------- #
Local Integer I
I = 0
# Pas de bouton "Recherche","Criteres", si saisie manuelle

If [M:SSL1]SAIFLG = 2
   Call VIREBOUT(CHMEN,"AD") From GOBJET
Endif
# Pas de bouton "Recherche","Criteres",  si on est rentrer en modif
If REP = "M"
   Call VIREBOUT(CHMEN,"AD") From GOBJET
Endif

# Pas de bouton  Liste à ranger  si pas de cochage
If !find( 2, [M:SSL1]COCHAGE(I..[M:SSL1]NBLIG-1))
   Call VIREBOUT(CHMEN,"C") From GOBJET
Endif

# Pas de bouton  Tri  si SSL1 vide
If [M:SSL1]NBLIG  = 0 | [M:SSL1]SAIFLG <> 2
   Call VIREBOUT(CHMEN,"G") From GOBJET
Endif

# Pas de bouton  Liste à ranger  si on est pas rentrer en modif
If REP = ""
   Call VIREBOUT(CHMEN,"C") From GOBJET
Endif

# Pas de bouton  Critere si  Liste à ranger  est inclure sans liste  <> 2
If [M:SSL1]SRGPPSSTR <> "" & [M:SSL1]LSTWIOFLG <> 2
   Call VIREBOUT(CHMEN,"D") From GOBJET
Endif

# Pas de bouton  Enregistrement validation Tout exclure par defaut
Call VIREBOUT(CHMEN,"EFJ") From GOBJET

# Bouton "enregistrement" si liste et cochage et modif
# Bouton "validation"     si cochage
# Bouton "Tout exclure "  si cochage
For NOL = 0 To [M:SSL1]NBLIG-1
    If [M:SSL1]COCHAGE(NOL) = 2
       WLISTE = 1
       If [M:SSL1]SRGPPS(NOL) <> "" | [M:SSL1]SRGPPS_AV(NOL) <> ""
          WLISTE = 2
          Break
       Endif
    Endif
Next

If WLISTE = 2 & REP = "M"
   CHMEN += "EFJ"
Else
   If WLISTE >  0
     CHMEN += "FJ"
   Endif
Endif

# Bouton "Recherche" si on est rentrer en modif , REO1 vide et liste à ranger
If REP = "M" & [M:SSL1]NBLIG  = 0 & [M:SSL1]SRGPPSSTR <> ""
   CHMEN += "A"
Endif

# Bouton "Recherche" "Criteres"si on est rentrer en modif , pas cochage
If REP = "M" & !find( 2, [M:SSL1]COCHAGE(I..[M:SSL1]NBLIG-1))
   CHMEN += "AD"
Endif

# Pas de bouton  Liste à ranger  si parametrage liste à ranger = invisible
If [M:SSL1]SRGPPSCOD = 3                   # hcb 50197
   Call VIREBOUT(CHMEN,"C") From GOBJET
Endif
# Pas de bouton  Tout inclure si pas de ligne
If  [M:SSL1]NBLIG  = 0
   Call VIREBOUT(CHMEN,"I") From GOBJET
Endif


# Pas de bouton  Tout inclure si pas de numero de piece , article , emplacement debut de renseignées
If  [M:SSL1]NBLIG  > 0 & [M:SSL1]VCRNUMSTR(0) = "" & [M:SSL1]ITMREFSTR = "" & [M:SSL1]LOCSTR = ""
   Call VIREBOUT(CHMEN,"I") From GOBJET
Endif

Return

$SETBOUT_TRTCRISSL
Return

#########################################################################
$APRES_MODIF
Local Integer I
# si modif alors rep = M
If find( 2, [M:SSL1]MODFLG(I..[M:SSL1]NBLIG-1))
   REP = "M"
   GREP = "M"
Endif
Return

#########################################################################
$AVANT_LIS
# L enregistrement a t il ete fait ?
Local Integer WOK
WOK = 9

Call OUINON(mess(22,184,1), WOK) From GESECRAN
If WOK <> 2
   Call ACT_ENRSSL From TRTSSLA
Endif

Local Integer I
#tri du tableau SSL1 par liste à ranger pour n editer une seule fois chaque liste
If [M:SSL1]NBLIG <> 0
    Sorta [M:SSL1]NBLIG [M:SSL1]NBLIG Order By [M:SSL1]SRGPPS(indice)
Endif

Raz [M:SSL1]SRGPPSDEB
Raz [M:SSL1]SRGPPSFIN

# edition de chaque liste à ranger
For I = 0 To [M:SSL1]NBLIG-1
    If [M:SSL1]SRGPPS(I) = ""
       Goto NEXTIMP
    Endif
    If [M:SSL1]SRGPPSDEB  = ""
       [M:SSL1]SRGPPSDEB  = [M:SSL1]SRGPPS(I)
    Endif
    If [M:SSL1]SRGPPS(I)  > [M:SSL1]SRGPPSFIN
       [M:SSL1]SRGPPSFIN  = [M:SSL1]SRGPPS(I)
    Endif
$NEXTIMP
Next I

Return


########################################################################
#  Sous programmes                                      appeles par CALL
########################################################################
# CHANGE_AWI                               chargement traitement fenetre
# MAJ_SRG_STAFLG         Mise à jour STAFLG (cochage / decochage) STOSRG
# ACTRUB_LIGNE                  desactivation / activation des rubriques
# CTRCLESRG                                    CONTROLE existence STOSRG
# CTRPPSSRG                Controle existence liste à ranger dans STOSRG
# TRT_STOSRGW_ENRSSL    Enregistrement  suppression / reecriture STOSRGW
# MAJ_SRG_SRGPPS              Mise à jour SRGPPS (enregistrement) STOSRG
# CHARG_PARAM_STOENT          chargement blocs entete parametrage STOENT
# INIT_SSL1                      Initialisation des rubriques stock SSL1



########################################################################
# CHANGE_AWI                               chargement traitement fenetre
########################################################################
$CHANGE_AWI
Local Integer OK
If clalev([F:AWI])=0  : Local File AWINDOW [AWI] : Endif
Read [AWI]AWI0=BOITE
If fstat
    GMESSAGE = BOITE-":"-mess(6,126,1)                 : # Fenêtre inexistante
    GERR = 1
    FIN = 1
    Return
Endif
GBOITE     = BOITE
Call NOMTRTWIN(GBOITE,WINPROG) From MSKDIV
Gosub DEFVAR From =WINPROG

Call EXISTE_ADX("","",WINPROG,OK) From ORDSYS
If OK=0
    GMESSAGE = BOITE-":"-mess(6,126,1)                 : # Fenêtre inexistante
    GERR = 1
    FIN = 1
Endif
Return

#########################################################################
# MAJ_SRG_STAFLG         Mise à jour STAFLG (cochage / decochage) STOSRG
#########################################################################
Subprog MAJ_SRG_STAFLG (NOL,COCHAGE)
Value    Integer NOL
Value    Integer COCHAGE

# verrouillage  / deverrouillage logique
If COCHAGE       = 2
   SYMBOLE2 = "SRG"+[M:SSL1]STOFCY+"\"+num$([M:SSL1]VCRTYP(NOL))+"\"+[M:SSL1]VCRNUM(NOL)+"\"+num$([M:SSL1]VCRLIN(NOL))
   Lock = SYMBOLE2
# modification en cours sur un autre poste
   If fstat
      GERR=1
      Call ERREUR([M:SSL1]STOFCY+"\"+num$([M:SSL1]VCRTYP(NOL))+"\"+[M:SSL1]VCRNUM(NOL)+"\"+num$([M:SSL1]VCRLIN(NOL))-":"-mess(10,100,1)) From GESECRAN
      GOK=0 : End
   Endif
Else
   SYMBOLE2 = "SRG"+[M:SSL1]STOFCY+"\"+num$([M:SSL1]VCRTYP(NOL))+"\"+[M:SSL1]VCRNUM(NOL)+"\"+num$([M:SSL1]VCRLIN(NOL))
   Unlock = SYMBOLE2
Endif

Call DEBTRANS From GLOCK
Trbegin [SRG]
Readlock [F:SRG]SRG0 = [M:SSL1]STOCOU(NOL);[M:SSL1]VCRTYP(NOL);[M:SSL1]VCRNUM(NOL);[M:SSL1]VCRLIN(NOL)
If    fstat=1 GOK=-1 : GLOCK="$STOSRG"-[M:SSL1]STOFCY-num$([M:SSL1]VCRTYP(NOL))-[M:SSL1]VCRNUM(NOL)-num$([M:SSL1]VCRLIN(NOL))
      SYMBOLE2 = "SRG"+[M:SSL1]STOFCY+"\"+num$([M:SSL1]VCRTYP(NOL))+"\"+[M:SSL1]VCRNUM(NOL)+"\"+num$([M:SSL1]VCRLIN(NOL))
      Unlock = SYMBOLE2
      Gosub AB_TRT
      End
Elsif fstat   GOK=0  : Call RSTA("SRG",[M:SSL1]STOFCY-num$([M:SSL1]VCRTYP(NOL))-[M:SSL1]VCRNUM(NOL)-num$([M:SSL1]VCRLIN(NOL))) From GLOCK
      SYMBOLE2 = "SRG"+[M:SSL1]STOFCY+"\"+num$([M:SSL1]VCRTYP(NOL))+"\"+[M:SSL1]VCRNUM(NOL)+"\"+num$([M:SSL1]VCRLIN(NOL))
      Unlock = SYMBOLE2
      Gosub AB_TRT
      End
Endif
If COCHAGE       = 2 & [F:SRG]SRGPPS = ""
  [F:SRG]STAFLG  = 2
Else
  [F:SRG]STAFLG  = 1
Endif
If  [F:SRG]SRGPPS <> ""
    [F:SRG]PCU        = [M:SSL1]PCU       (NOL)
    [F:SRG]QTYPCU     = [M:SSL1]QTYPCU    (NOL)
    [F:SRG]PCUSTUCOE  = [M:SSL1]PCUSTUCOE (NOL)
    [F:SRG]QTYSTU     = [M:SSL1]QTYSTU    (NOL)
Else
    Raz   [F:SRG]PCU, [F:SRG]PCUSTUCOE, [F:SRG]QTYSTU, [F:SRG]QTYPCU
Endif

[F:SRG]UPDDAT  = date$
[F:SRG]UPDUSR  = GUSER
Rewrite [F:SRG]
If fstat
   GOK = 0 : Call FSTA("SRG") From GLOCK
   SYMBOLE2 = "SRG"+[F:SRG]STOFCY+"\"+num$([F:SRG]VCRTYP)+"\"+[F:SRG]VCRNUM+"\"+num$([F:SRG]VCRLIN)
   Unlock = SYMBOLE2
   Gosub AB_TRT
   End
Endif
Commit
End

#########################################################################
#ACTRUB_LIGNE                    desactivation / activation des rubriques
#########################################################################
Subprog ACTRUB_LIGNE (NOL)
Value    Integer NOL

#saisie de nouvelle ligne il faut activer les zones de cle
If [M:SSL1]WFLG(NOL) = 0
    Gosub DES_RUB_DESTINATION
    Gosub ACT_RUB_CLE
    End
Endif
#si saisie détail la modif se fait par clic droit

If [M:SSL1]WSTOSEQ(NOL) <> 0
    Gosub DES_RUB_DESTINATION
    If dim([M:SSL1]SRGPPS(NOL)) > 0
       Actzo [M:SSL1]SRGPPS(NOL)
    Endif
    End
Endif
End


########################################################################
# CTRCLESRG                                    Controle existence STOSRG
#                                  suite à saisie d un element dans SSL1
########################################################################
Subprog CTRCLESRG(LECR,LCHO,LTYP,LNUM,LLIN,LITM,LLOC,LWRH)
Value     Char     LECR
Value    Integer  LCHO
Value    Integer  LTYP
Value    Char     LNUM
Value    Integer  LLIN
Value    Char     LITM
Value    Char     LLOC
Value    Char     LWRH
Local Integer LRET

Local Char LFCY(GLONFCY)
If LECR = "SSL1"
   LFCY = [M:SSL1]STOFCY
Endif
Local Char CRITERE(255)
Local Char CRITER1(255)
Raz CRITERE
Raz CRITER1

Local Char LSRG(GLONVCR)               # hcb 57490
LSRG = ""
CRITERE = "[F:SRG]ORICOD=1&[F:SRG]STAFLG<>2&[F:SRG]STOFCY=LFCY&[F:SRG]SRGPPS=LSRG"


Case LCHO
     When 1 :
  CRITER1 = "[F:SRG]VCRTYP=LTYP"
     When 2 :
  CRITER1 = "[F:SRG]VCRTYP=LTYP&[F:SRG]VCRNUM=LNUM"
     When 3 :
  CRITER1 = "[F:SRG]VCRTYP=LTYP&[F:SRG]VCRNUM=LNUM&[F:SRG]VCRLIN=LLIN"
     When 4 :
  CRITER1 = "[F:SRG]VCRTYP=LTYP&[F:SRG]VCRNUM=LNUM&[F:SRG]VCRLIN=LLIN&[F:SRG]ITMREF=LITM"
     When 5 :
     If LWRH = ""
        CRITER1 = "[F:SRG]VCRTYP=LTYP&[F:SRG]VCRNUM=LNUM&[F:SRG]VCRLIN=LLIN&[F:SRG]ITMREF=LITM&[F:SRG]LOC=LLOC"
     Else
        CRITER1 = "[F:SRG]VCRTYP=LTYP&[F:SRG]VCRNUM=LNUM&[F:SRG]VCRLIN=LLIN&[F:SRG]ITMREF=LITM&[F:SRG]LOC=LLOC&[F:SRG]WRH=LWRH"
     Endif
     When 6 :
  CRITER1 = "[F:SRG]VCRTYP=LTYP&[F:SRG]VCRNUM=LNUM&[F:SRG]VCRLIN=LLIN&[F:SRG]ITMREF=LITM&[F:SRG]WRH=LWRH"
Endcase

If CRITER1 = ""
   CRITER1 = "1=1"
Endif

Filter [SRG]  Where evalue(CRITERE)&evalue(CRITER1)
&             Order By Key SRG3

LRET = 1
For [SRG]
LRET = 2
Break

Next

Filter [F:SRG]

If LRET = 1
   mkstat=2
   GMESSAGE=mess(13,184,1)    # Aucun enregistrement en attente de rangement correspondant
Endif
End

########################################################################
# CTRPPSSRG                Controle existence liste à ranger dans STOSRG
#                                  suite à saisie d un element dans SSL1
########################################################################
Subprog CTRPPSSRG(LECR,LSRG)
Value    Char     LECR
Value    Char     LSRG
Local Integer LRET

Local Char LFCY(GLONFCY)
If LECR = "SSL1"
   LFCY = [M:SSL1]STOFCY
Elsif LECR = "XASY"
   LFCY = [M:XASY]STOFCY
Endif
Local Char CRITERE(255)
Local Char CRITER1(255)
Raz CRITERE

CRITERE = "[F:SRG]ORICOD=1&[F:SRG]STOFCY=LFCY&[F:SRG]SRGPPS=LSRG"

Filter [SRG]  Where evalue(CRITERE)
&             Order By Key SRG4

LRET = 1
For [SRG]
LRET = 2
Break

Next

Filter [F:SRG]

If LRET = 1
   mkstat=2
   GMESSAGE=mess(16,184,1)    # Numéro de liste à ranger inexistant
Endif
End

#########################################################################
# MAJ_SRG_SRGPPS               Mise à jour SRGPPS (enregistrement) STOSRG
#                              STAFLG = 1
#                              SRGPPS = numero de liste
#########################################################################
Subprog MAJ_SRG_SRGPPS (NOL,NUMLIS)
Value    Integer  NOL
Value    Char     NUMLIS

Readlock [F:SRG]SRG0 = [M:SSL1]STOCOU(NOL);[M:SSL1]VCRTYP(NOL);[M:SSL1]VCRNUM(NOL);[M:SSL1]VCRLIN(NOL)
If fstat=1     GOK=-1 : GLOCK="$STOSRG"-num$([M:SSL1]STOCOU(NOL)) : End
   Elsif fstat GOK=0  : Call RSTA("SRG",num$([M:SSL1]STOCOU(NOL))) From GLOCK
   End
Endif

[F:SRG]STAFLG  = 1
[F:SRG]SRGPPS  = NUMLIS
[F:SRG]CREPPS  = date$
[F:SRG]CRETIM  = mid$(time$,1,2)+mid$(time$,4,2)
[F:SRG]UPDDAT  = date$
[F:SRG]UPDUSR  = GUSER

If  [F:SRG]SRGPPS <> ""
    [F:SRG]PCU        = [M:SSL1]PCU       (NOL)
    [F:SRG]QTYPCU     = [M:SSL1]QTYPCU    (NOL)
    [F:SRG]PCUSTUCOE  = [M:SSL1]PCUSTUCOE (NOL)
    [F:SRG]QTYSTU     = [M:SSL1]QTYSTU    (NOL)
    [F:SRG]MVTDES     = [M:SSL1]MVTDES    (NOL)
Else
    Raz   [F:SRG]PCU, [F:SRG]PCUSTUCOE, [F:SRG]QTYSTU, [F:SRG]QTYPCU
Endif

Rewrite [F:SRG]
If fstat
   GOK = 0 : Call FSTA("SRG") From GLOCK : End
Endif
SYMBOLE2 = "SRG"+[F:SRG]STOFCY+"\"+num$([F:SRG]VCRTYP)+"\"+[F:SRG]VCRNUM+"\"+num$([F:SRG]VCRLIN)
Unlock = SYMBOLE2

End

#########################################################################
# TRT_STOSRGW_ENRSSL    Enregistrement  suppression / reecriture STOSRGW
#                              STAFLG = 1
#                              SRGPPS = numero de liste
#########################################################################
Subprog TRT_STOSRGW_ENRSSL (NOL)
Value    Integer  NOL

# delete STOSRGW
Gosub DELETE_STOSRGW
If GOK < 1
   End
Endif
# si liste à ranger renseignée il faut ecrire STOSRGW avec le contenu de STOENTW
If [M:SSL1]SRGPPS(NOL) <> ""

   Gosub ECRITURE_STOSRGW
Endif
End
#########################################################################
# CHARG_PARAM_STOENT           chargement blocs entete parametrage STOENT
#########################################################################

Subprog CHARG_PARAM_STOENT(LLIG)
Value    Integer LLIG
Variable Integer LRET

[M:ENT]STOFCY    = [M:SSL1]STOFCY
[M:ENT]ITMREF    = [M:SSL1]ITMREF    (LLIG)

[M:ENT]QTYTOENT  = [M:SSL1]QTYPCU    (LLIG)
[M:ENT]PCUTOENT  = [M:SSL1]PCU       (LLIG)
[M:ENT]COETOENT  = [M:SSL1]PCUSTUCOE (LLIG)

[M:ENT]STU       = [M:SSL1]STU       (LLIG)
[M:ENT]VCRTYP    = [M:SSL1]VCRTYP    (LLIG)
[M:ENT]VCRNUM    = [M:SSL1]VCRNUM    (LLIG)
[M:ENT]VCRLINORI = [M:SSL1]VCRLINORI (LLIG)
[M:ENT]VCRTYPORI = [M:SSL1]VCRTYPORI (LLIG)
[M:ENT]VCRNUMORI = [M:SSL1]VCRNUMORI (LLIG)
[M:ENT]VCRLIN    = [M:SSL1]VCRLIN    (LLIG)
[M:ENT]QUAFLG    = [M:SSL1]QUAFLG    (LLIG)       # hcb V6CQ
[M:ENT]QUAFRE    = [M:SSL1]QUAFRE    (LLIG)       # hcb V6CQ
If dim([M:SSL1]WRH)>0
  [M:ENT]XWRH    = [M:SSL1]WRH(LLIG)
Endif
[M:ENT]CCECODS   = [F:DTR]STOCCECOD

[M:ENT]SRGWAIFLG = [M:SSL1]SRGWAIFLG           # hcb 50197

# hcb le 020305 ce test est necessaire sinon on transmet dans vcrnumori le numero de session !!
#               ce qui n a rien de fonctionnel mais surtout provoque une erreur (360,199) en control LOT
If [M:SSL1]VCRTYP (LLIG) = 9
   Raz [M:ENT]VCRLINORI
   Raz [M:ENT]VCRTYPORI
   Raz [M:ENT]VCRNUMORI
Endif

[M:ENT]WSTOSEQ   = [M:SSL1]WSTOSEQ(LLIG)
[M:ENT]MVTDES    = [M:SSL1]MVTDES(LLIG)
[M:ENT]TRSTYP    = [M:SSL1]TRSTYP(LLIG)
[M:ENT]TRSCOD    = [M:SSL1]TRSCOD(LLIG)     # code mouvement
[M:ENT]IPTDAT    = [M:SSL1]IPTDAT(LLIG)     # date imputation

[M:ENT]BPRNUM    = ""
[M:ENT]CUR       = GLOCALDEV

# si lot origine renseignée  lot fournisseur et lot non modifiable
If [M:SSL1]LOTORI(LLIG) <> ""
    GSAIFLG = left$(GSAIFLG,6) + "2" + right$(GSAIFLG,8)
    GSAIFLG = left$(GSAIFLG,7) + "2" + right$(GSAIFLG,9)
Endif
# si slo origine renseignée  slo non modifiable

If [M:SSL1]SLOORI(LLIG) <> ""
    GSAIFLG = left$(GSAIFLG,9) + "2" + right$(GSAIFLG,11)
Endif
# si serie origine renseignée  serie non modifiable

If [M:SSL1]SERNUMORI(LLIG) <> ""
    GSAIFLG = left$(GSAIFLG,10) + "2" + right$(GSAIFLG,12)
Endif
End
#########################################################################
# CHARG_PARAM_SLP                      Chargement blocs edition etiquette
#########################################################################

$CHARG_PARAM_SLP

[M:SLP]WZONVCRTYP = "VCRTYP(I)"
[M:SLP]WZONVCRNUM = "VCRNUM(I)"
[M:SLP]WZONVCRLIN = "VCRLIN(I)"
[M:SLP]WZONNBLIG  = "NBLIG"
[M:SLP]WMSKFIL    = "[M:SSL1]COCHAGE(I) = 2"

Return


#########################################################################
# INIT_SSL1                       Initialisation des rubriques stock SSL1
#########################################################################

Subprog INIT_SSL1  (LLIG)
Value    Integer LLIG

#----- Variables locales -----#
Local Integer   I , LRET
Local Char      LUSCAV
Local Integer   LMODIF
Local Decimal   PCOE
Local Char      PLBEFMT
Local Char      WWRH(GLONWRH)

If   [M:SSL1]SRGPPS(LLIG) = ""
     [M:SSL1]SRGPPS(LLIG) = [M:SSL1]SRGPPSSTR
Endif

# initialisation statut si ""

If [M:SSL1]STA  (LLIG) = ""
   Call STKINISTA([M:SSL1]STA(LLIG),"",1) From STKACT
Endif

Local Decimal LQTY

If [F:ITF]LOCMGTCOD > 1
  If dim([M:SSL1]WRH) > 0
    WWRH=[M:SSL1]WRH(LLIG)
  Else
    WWRH=""
  Endif
# Récupération de l'emplacement par défaut de l'art-site pour le type mouvement
   Call STKSUGEMP([M:SSL1]WLOCSEQ(LLIG),[M:SSL1]TRSTYP(LLIG),[M:SSL1]TRSCOD(LLIG),
&       [M:SSL1]STOFCY,[M:SSL1]ITMREF(LLIG),[M:SSL1]PCU(LLIG),[M:SSL1]QTYPCU(LLIG),
&       [M:SSL1]STA(LLIG),[M:SSL1]LOCTYP(LLIG),[M:SSL1]LOC(LLIG),"","QS","",WWRH) From STKLOC    #hcb 29002
   If mkstat = 2 mkstat = 0 Endif
# Controle de l'emplacement par défaut de l'art-site pour le type mouvement
   Call STKCTREMP([M:SSL1]WLOCSEQ(LLIG),[M:SSL1]TRSTYP(LLIG),[M:SSL1]TRSCOD(LLIG),
&       [M:SSL1]STOFCY,[M:SSL1]ITMREF(LLIG),[M:SSL1]PCU(LLIG),[M:SSL1]QTYPCU(LLIG),
&       [M:SSL1]STA(LLIG),[M:SSL1]LOCTYP(LLIG),[M:SSL1]LOC(LLIG),"",0,mkstat,LQTY,
&       string$([M:SSL1]STA(LLIG)="","S"),"",WWRH) From STKLOC
   If mkstat = 2 mkstat = 0 Endif
Endif
# si  type quai mise à blanc des zones type et emplacement
If dim([M:SSL1]LOCTYP) > 0
   If [M:SSL1]LOCTYP (LLIG) <> ""
      If  [M:SSL1]STOFCY <> [F:TLO]STOFCY | [M:SSL1]LOCTYP (LLIG)<> [F:TLO]LOCTYP
          Read [TLO]TLO0=[M:SSL1]STOFCY;[M:SSL1]LOCTYP (LLIG)
          If fstat
             Raz [F:TLO]
          Endif
      Endif
      If [M:SSL1]SRGWAIFLG <> 2   # hcb 50197
# type quai non autorisé
         If [F:TLO]LOCCAT = 2
            Raz [M:SSL1]LOCTYP (LLIG)
            Raz [M:SSL1]LOC    (LLIG)
# si code trs on met à blanc pour l aide sur type emplacement
           If [M:SSL1]TRSCOD  (LLIG) <> ""
              [M:SSL1]TRSCOD  (LLIG) = ""
           Endif
         Endif
      Endif
   Endif
Endif
# hcb STD

#affichage rubriques selon gestion article
Gosub GES_ITM
#initialisation GESLOT
Gosub INI_GESLOT

End


########################################################################
# STKSELTRS                                        Selection transaction
########################################################################
$STKSELTRS
Local Char    TABACS(10)(100)
Local Integer NBACS
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX
Local Char    CRITERE(250)
If dim(GHCBBOI)<=0
#MAE, bg66214    Global Char GHCBBOI(10)
    Global Char GHCBBOI(GLONFEN)
Endif
Raz GHCBBOI

If clalev([F:ACC])=0 : Local File ACCES  [ACC] : Endif
If clalev([F:SRT])=0 : Local File STKTRS [SRT] : Endif
If clalev([F:DTR])=0 : Local File DIETRS [DTR] : Endif

CRITERE = "SRTTYP=5  & [F:SRT]ENAFLG = 2"     # hcb 88573

If GPROFIL<>GSUPER
  For [ACC]CODACC Where USR=GUSER
    If [F:ACC]EXEC=2
      [L]TABACS(NBACS)=vireblc([F:ACC]CODACC,1)
      NBACS +=1
    Endif
    If NBACS>99 Break Endif
  Next
  CRITERE += "&(ACSCOD=''|find(ACSCOD,TABACS(0..99)))"
Endif

If GFLAG=""
    Filter [SRT] Where evalue(CRITERE)
    If rowcount([SRT])=1
        Read [SRT] First
        If !fstat
            GFLAG   = [F:SRT]SRTNUM
            GSSLNUM = [F:SRT]SRTNUM   # hcb 50197
        Endif
    Endif
    Filter [SRT]
Endif
If GFLAG<>""
    Filter [SRT] Where evalue(CRITERE)
    Read [SRT] SRT0=5;GFLAG
    Filter [SRT]
    If !fstat
        GHCBBOI = "WQSSL"+[F:SRT]SRTNUM+"1"
        GSSLNUM = [F:SRT]SRTNUM      # hcb 50197
        OK=0
    Endif
Endif
If GHCBBOI=""
    For [F:SRT] Where evalue(CRITERE)
        NBTEX+= 1
        TEX(NBTEX)   =[F:SRT]SRTNUM
        Call LECTEXTRA(TEXTE(NBTEX),"STKTRS","DESAXX",num$([F:SRT]SRTTYP),[F:SRT]SRTNUM) From ATEXTRA
        TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
    Next
    TIT(0) = mess(3,126,1) # Choix transactions
Endif
Return

$STKFINTRS
If VALEUR = ""
   Raz GFLAG
   Kill GHCBBOI
   Return
Endif
Read [SRT] SRT0=5;VALEUR
If fstat | [F:SRT]ENAFLG=1 OK=0 : Endif

Read [DTR] DTR0="SRT";[F:SRT]SRTTYP;[F:SRT]SRTNUM;0;0
If fstat
   Raz [F:DTR]
Endif

GHCBBOI = "WQSSL"+[F:SRT]SRTNUM+"1"
GFLAG   = [F:SRT]SRTNUM
GSSLNUM = [F:SRT]SRTNUM    # hcb 50197
GGRPFCY = [F:SRT]GFY


Return

#########################################################################
# STKSELSRGS                                 Selection sur fichier STOSRG
#########################################################################
$STKSELSRGS
Local Char    LFCY(GLONFCY)   : LFCY =      PARAM(1)
Local Integer LTYP            : LTYP =  val(PARAM(2))
Local Char    LRUB            : LRUB =      PARAM(3)

#LTYP = fonction menu local 701   selection sur type de piece

#LRUB = rubrique de start

Local Char LFIC(10)
LFIC = "STOSRG"

If clalev([F:SRG])  = 0 : Local File STOSRG    [SRG]  : Endif
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ]  : Endif

Local Integer  W_DIM          : W_DIM = 100
Local Char     W_FCY(GLONFCY)(1..W_DIM)
Local Integer  W_TYP         (1..W_DIM)
Local Char     W_NUM(GLONVCR)(1..W_DIM)     # hcb 57490

Local Integer WI
Local Char    NUM_SRG(GLONVCR)              # hcb 57490
Local Integer TYP_SRG
Raz NUM_SRG
Raz TYP_SRG
WI = 1
Local Char WLISTE(GLONVCR)                  # hcb 57490
WLISTE = ""

If LTYP = 1
#   ORDRE   = "VCRNUM"
   CRITERE = "[F:SRG]STOFCY=LFCY&[F:SRG]ORICOD=1&[F:SRG]STAFLG<>2&[F:SRG]VCRNUM>=LRUB&[F:SRG]SRGPPS=WLISTE"
   Filter [SRG] Where evalue(CRITERE)
&               Order By Key SRG5

Else
#   ORDRE   = "VCRTYP"
   CRITERE = "[F:SRG]STOFCY=LFCY&[F:SRG]ORICOD=1&[F:SRG]STAFLG<>2&[F:SRG]VCRTYP=LTYP-1&[F:SRG]VCRNUM>=LRUB&[F:SRG]SRGPPS=WLISTE"
   Filter [SRG] Where evalue(CRITERE)
&               Order By Key SRG3
Endif

Columns  [SRG](STOFCY,VCRTYP,VCRNUM)
For [SRG]
    If NUM_SRG = [F:SRG]VCRNUM
       If TYP_SRG = [F:SRG]VCRTYP
          Goto NEXT_SRG
       Endif
    Endif
    If WI <= dim(W_FCY)
       NUM_SRG = [F:SRG]VCRNUM
       TYP_SRG = [F:SRG]VCRTYP
       W_FCY(WI) = [F:SRG]STOFCY
       W_TYP(WI) = [F:SRG]VCRTYP
       W_NUM(WI) = [F:SRG]VCRNUM
       WI +=1
    Else
       Break
    Endif

$NEXT_SRG
Next
Columns [SRG]

Filter [SRG]

#
TIT(0) = mess(17,213,1)

NBCOL = 1 : COL(NBCOL) = "ZFCY"
Call TEXTFIC(LFIC,"STOFCY",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ZTYP"
Call TEXTFIC(LFIC,"VCRTYP",2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "ZNUM"
Call TEXTFIC(LFIC,"VCRNUM",2,TIT(NBCOL)) From OBJDIV

#
START   = "ZNUM"
ORDRE   = "ZNUM"
CRITERE = "ZFCY <> ''"
SIZLIG  = 100
SIZCOL  = 200
# hcb 57490
Local File    (Char  ZFCY(GLONFCY), Integer ZTYP, Char ZNUM(GLONVCR))
&     From Variable  W_FCY,                  W_TYP,     W_NUM
&     As [SEL]
Default File [SEL]

Return
#########################################################################
# STKSELSRG                                  Selection sur fichier STOSRG
#########################################################################
$STKSELSRG
Local Char    LFCY(GLONFCY)   : LFCY =      PARAM(1)
Local Char    LORI(3)         : LORI =      PARAM(2)
Local Integer LTYP            : LTYP =  val(PARAM(3))
Local Char    LRUB            : LRUB =      PARAM(4)
Local Integer LLIG            : LLIG =  val(PARAM(5))
Local Integer LCHO            : LCHO =  val(PARAM(6))

#LORI = PIE  selection sur bloc selection
#LORI = LIG  selection sur ligne

#LTYP = fonction menu local 701   selection sur type de piece

#LRUB = rubrique de start
#LCHO = rubrique de la ligne d ou est issue la selection

Local Char LFIC(10)
LFIC = "STOSRG"

If clalev([F:SRG])  = 0 : Local File STOSRG    [SRG]  : Endif
If clalev([F:ATZ])  = 0 : Local File ATABZON   [ATZ]  : Endif
#
TIT(0) = mess(17,213,1)

NBCOL = 1 : COL(NBCOL) = "STOFCY"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "VCRTYP"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
NBCOL += 1 : COL(NBCOL) = "VCRNUM"
Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
If LORI = "LIG"
   NBCOL += 1 : COL(NBCOL) = "VCRLIN"
   Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
   NBCOL += 1 : COL(NBCOL) = "ITMREF"
   Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
   NBCOL += 1 : COL(NBCOL) = "LOC"
   Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
   NBCOL += 1 : COL(NBCOL) = "STOCOU"
   Call TEXTFIC(LFIC,COL(NBCOL),2,TIT(NBCOL)) From OBJDIV
Endif

Local Char WLISTE(GLONVCR)
WLISTE = ""
#
If LORI = "PIE"
   If LTYP = 1
      ORDRE   = "VCRNUM"
      CRITERE = "[F:SRG]STOFCY=LFCY&[F:SRG]ORICOD=1&[F:SRG]STAFLG<>2&[F:SRG]VCRNUM>=LRUB&[F:SRG]SRGPPS=WLISTE"
   Else
      ORDRE   = "VCRTYP"
      CRITERE = "[F:SRG]STOFCY=LFCY&[F:SRG]ORICOD=1&[F:SRG]STAFLG<>2&[F:SRG]VCRTYP=LTYP-1&[F:SRG]VCRNUM>=LRUB&[F:SRG]SRGPPS=WLISTE"
   Endif
Endif
If LORI = "LIG"
   ORDRE   = "STOCOU;VCRTYP;VCRNUM;VCRLIN"
   CRITERE = "[F:SRG]STOFCY=LFCY&[F:SRG]ORICOD=1&[F:SRG]STAFLG<>2&[F:SRG]VCRTYP=LTYP&[F:SRG]VCRNUM>=LRUB&[F:SRG]SRGPPS=WLISTE"
Endif
Case LCHO
     When 0 : START   = "VCRNUM"
     When 1 : START   = "VCRNUM"
     When 2 : START   = "VCRLIN"
     When 3 : START   = "ITMREF"
     When 4 : START   = "LOC"
     When 5 : START   = "LOC"
Endcase
SIZLIG  = 100
SIZCOL  = 200
Default File [SRG]
Return


#########################################################################
# STKSELPPS       Selection sur fichier STOSRG   numero de liste à ranger
#########################################################################
$STKSELPPS
Local Char    LFCY(GLONFCY)      : LFCY =      PARAM(1)
Local Char NUMLIS(GLONVCR)    # hcb 57490
NUMLIS = ""
Local Integer Z
Local Char SZTIT
Z = 0
SZTIT = ""

Filter [SRG] Where [F:SRG]STOFCY = LFCY & [F:SRG]ORICOD = 1 & [F:SRG]SRGPPS <> "" Order By [F:SRG]SRGPPS Asc

For [SRG] With Nohint
    If NUMLIS = [F:SRG]SRGPPS
       Goto NEXTLIS
    Endif
    NUMLIS = [F:SRG]SRGPPS

    If Z >= dim(TEX) - 1 : Break : Endif
    Z += 1
    TEX  (Z) = [F:SRG]SRGPPS
    TEXTE(Z) = [F:SRG]SRGPPS
$NEXTLIS
Next

Filter [SRG]
ORDRE   = "STOFCY;SRGPPS"

NBTEX = Z
SZTIT = mess(454,198,1) #Liste à ranger
TIT = left$(SZTIT, 20)

Return

#########################################################################
# STKVERSRG                                       controle fichier STOSRG
#########################################################################
$STKVERSRG
Local Integer NOL
If LORI <> "LIG"
   Return
Endif
If [F:SRG]STOCOU = 0
   Return
Endif
Read [SRG]SRG0=[F:SRG]STOCOU;LTYP;[F:SRG]VCRNUM;[F:SRG]VCRLIN
If fstat
   Return
Endif
# Verif sert à controler l existance de lenregistrement dans le tableau 1 non verif  2 verif

If GWRHACT = 2 & [M:SSL1]WRHOBY = 2 & [M:SSL1]WRHGES = 2
   Local Integer WITW
   Raz   WITW
   Call CTR_ITW([F:SRG]ITMREF,[M:SSL1]WRHE,WITW)
   If WITW = 2
      GMESSAGE=[F:SRG]ITMREF-":"-mess(343,184,1)-":"-[M:SSL1]WRHE
      GERR = 1
      mkstat = 2
      Return
   Endif
Endif

Gosub CTR_EXI_SSL1 From TRTSSLA
If WEXI <> 0
   GERR = 1
   mkstat = 2
   GMESSAGE=mess(14,184,1)       #  Enregistrement  déjà présent dans le tableau  !
   Return
Endif

[M:SSL1]CREFLG    (LLIG)  = 0
[M:SSL1]MODFLG    (LLIG)  = 2
[M:SSL1]COCHAGE   (LLIG)  = 2
[M:SSL1]WFLG      (LLIG)  = 1
[M:SSL1]WSTOFLG   (LLIG)  = 0
[M:SSL1]VCRTYP    (LLIG)  = [F:SRG]VCRTYP
[M:SSL1]TRSTYP    (LLIG)  = [F:SRG]TRSTYP
[M:SSL1]VCRNUM    (LLIG)  = [F:SRG]VCRNUM
[M:SSL1]VCRLIN    (LLIG)  = [F:SRG]VCRLIN
[M:SSL1]VCRTYPORI (LLIG)  = [F:SRG]VCRTYPORI
[M:SSL1]VCRNUMORI (LLIG)  = [F:SRG]VCRNUMORI
[M:SSL1]VCRLINORI (LLIG)  = [F:SRG]VCRLINORI
[M:SSL1]IPTDAT    (LLIG)  = [F:SRG]IPTDAT
[M:SSL1]ITMREF    (LLIG)  = [F:SRG]ITMREF
[M:SSL1]SRGPPS    (LLIG)  = [F:SRG]SRGPPS
[M:SSL1]SRGPPS_AV (LLIG)  = [F:SRG]SRGPPS

[M:SSL1]QUAFLG    (LLIG)  = [F:SRG]QUAFLG    # hcb V6CQ
[M:SSL1]QUAFRE    (LLIG)  = [F:SRG]QUAFRE    # hcb V6CQ
[M:SSL1]BPRNUM    (LLIG)  = [F:SRG]BPRNUM    # hcb V6CQ

If dim([M:SSL1]LOCORI) > 0
   [M:SSL1]LOCORI(LLIG)   = [F:SRG]LOC
Endif
If dim([M:SSL1]WRHORI) > 0
   [M:SSL1]WRHORI(LLIG)   = [F:SRG]WRH
Endif
If dim([M:SSL1]PJT) > 0
   [M:SSL1]PJT   (LLIG)   = [F:SRG]PJT
Endif

[M:SSL1]STAORI(LLIG)      = [F:SRG]STA
[M:SSL1]STOCOU(LLIG)      = [F:SRG]STOCOU
[M:SSL1]MVTDES(LLIG)      = [F:SRG]MVTDES
# recherche TRSCOD origine
Gosub TRT_ORIGINE_TRSCOD From TRTSSLA
[M:SSL1]TRSCOD(LLIG)      = WTRSCOD
#[M:SSL1]BPRNUM(LLIG)     = WBPRNUM          # hcb V6CQ
[M:SSL1]BETCPY(LLIG)      = WBETCPY

Read [STO] STO0=[F:SRG]STOFCY;[F:SRG]STOCOU
If fstat
   Raz [F:STO]
Endif
If [F:ITM]ITMREF<>[F:SRG]ITMREF
    Read [F:ITM]ITM0=[F:SRG]ITMREF
    If fstat
       Raz [F:ITM]
    Endif
Endif

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [F:SRG]STOFCY | [F:ITF]ITMREF <> [F:SRG]ITMREF
   Read [ITF]ITF0 = [F:SRG]ITMREF;[F:SRG]STOFCY
   If fstat
      Raz [F:ITF]
   Endif
Endif

Default Mask [SSL1]
Call INIZONENT([M:SSL1]ITMREF(LLIG),"SSL1",[M:SSL1]STOFCY,"",0,"",LLIG,
&              [M:SSL1]TRSTYP(LLIG),[M:SSL1]TRSCOD(LLIG),[M:SSL1]VCRNUM(LLIG),
&              1,0) From STKECR

[M:SSL1]STU         (LLIG)   = [F:ITM]STU

#rubrique origine
[M:SSL1]PCUORI      (LLIG)   = [F:STO]PCU
If dim([M:SSL1]PALNUM) > 0
   [M:SSL1]PALNUM      (LLIG)   = [F:STO]PALNUM
Endif
If dim([M:SSL1]CTRNUM) > 0
   [M:SSL1]CTRNUM      (LLIG)   = [F:STO]CTRNUM
Endif
[M:SSL1]QTYSTUORI   (LLIG)   = [F:SRG]QTYSTUACT

[M:SSL1]PCUSTUCOEO  (LLIG)   = [F:STO]PCUSTUCOE
If [F:ITF]STOMGTCOD = 3 | [F:ITM]ECCSTO > 1                                               # hcb 111781
   Read[STL]STL0=[F:SRG]ITMREF;[F:STO]LOT;[F:STO]SLO
   If fstat
      Raz [F:STL]
          [F:STL]POT = 1
   Endif
   [M:SSL1]QTYSTUORI   (LLIG)   = ([F:SRG]QTYSTUACT/[F:STL]POT)*100
Endif
#                                                                                         # hcb 111781 deb
If [F:STL]LOT <> ""
   If dim([M:SSL1]ECCVALMAJ)>0
      [M:SSL1]ECCVALMAJORI(LLIG) = [F:STL]ECCVALMAJ
      [M:SSL1]ECCVALMAJ   (LLIG) = [F:STL]ECCVALMAJ
      [M:SSL1]ECCVALMINORI(LLIG) = [F:STL]ECCVALMIN
      [M:SSL1]ECCVALMIN   (LLIG) = [F:STL]ECCVALMIN
      [M:SSL1]ECCSAIFLG   (LLIG) = 1
      [M:SSL1]ECCSAIFLGORI(LLIG) = 1
   Endif
Endif
#                                                                                         # hcb 111781 deb

If  [F:STO]PCUSTUCOE <> 0
    [M:SSL1]QTYPCUORI  (LLIG)   = [M:SSL1]QTYSTUORI   (LLIG)  /[F:STO]PCUSTUCOE
Endif
If dim([M:SSL1]BPSLOTORI) > 0
   [M:SSL1]BPSLOTORI   (LLIG)   = [F:STO]BPSLOT
Endif
If dim([M:SSL1]LOTORI) > 0
   [M:SSL1]LOTORI      (LLIG)   = [F:STO]LOT
Endif
If dim([M:SSL1]SLOORI) > 0
   [M:SSL1]SLOORI      (LLIG)   = [F:STO]SLO
Endif
If dim([M:SSL1]SERNUMORI) > 0
   [M:SSL1]SERNUMORI   (LLIG)   = [F:STO]SERNUM
Endif
If dim([M:SSL1]PALNUMORI) > 0
   [M:SSL1]PALNUMORI   (LLIG)   = [F:STO]PALNUM
Endif
If dim([M:SSL1]CTRNUMORI) > 0
   [M:SSL1]CTRNUMORI   (LLIG)   = [F:STO]CTRNUM
Endif
#rubrique destination par défaut
[M:SSL1]PCU         (LLIG)   = [M:SSL1]PCUORI      (LLIG)
[M:SSL1]QTYPCU      (LLIG)   = [M:SSL1]QTYPCUORI   (LLIG)
[M:SSL1]QTYSTU      (LLIG)   = [M:SSL1]QTYSTUORI   (LLIG)
[M:SSL1]PCUSTUCOE   (LLIG)   = [M:SSL1]PCUSTUCOEO  (LLIG)
If dim([M:SSL1]LOT) > 0
   [M:SSL1]LOT         (LLIG)   = [M:SSL1]LOTORI      (LLIG)
Endif
If dim([M:SSL1]BPSLOT) > 0
   [M:SSL1]BPSLOT      (LLIG)   = [M:SSL1]BPSLOTORI   (LLIG)
Endif
If dim([M:SSL1]SLO) > 0
   [M:SSL1]SLO         (LLIG)   = [M:SSL1]SLOORI      (LLIG)
    If [M:SSL1]SLO      (LLIG) <> ""
       [M:SSL1]NBSLO    (LLIG)   = 1
    Endif
Endif
If dim([M:SSL1]SERNUM) > 0
   [M:SSL1]SERNUM      (LLIG)   = [M:SSL1]SERNUMORI   (LLIG)
Endif
If dim([M:SSL1]SERNUMF) > 0
   [M:SSL1]SERNUMF     (LLIG)   = [M:SSL1]SERNUMORI   (LLIG)
Endif
If dim([M:SSL1]PALNUM) > 0
   [M:SSL1]PALNUM      (LLIG)   = [M:SSL1]PALNUMORI   (LLIG)
Endif
If dim([M:SSL1]CTRNUM) > 0
   [M:SSL1]CTRNUM      (LLIG)   = [M:SSL1]CTRNUMORI   (LLIG)
Endif

Call INIT_SSL1(LLIG)       From TRTSSLA


Affzo  [M:SSL1]VCRTYP(LLIG)
Grizo  [M:SSL1]VCRTYP(LLIG)
Grizo  [M:SSL1]VCRNUM(LLIG)
Grizo  [M:SSL1]VCRLIN(LLIG)
Grizo  [M:SSL1]ITMREF(LLIG)
Grizo  [M:SSL1]ITMREF(LLIG)
If dim([M:SSL1]LOCORI) > 0
   Grizo  [M:SSL1]LOCORI(LLIG)
Endif
If dim([M:SSL1]WRHORI) > 0
   Grizo  [M:SSL1]WRHORI(LLIG)
Endif
# initialisation liste à ranger par celui de la selection
If   [M:SSL1]SRGPPS(LLIG) = ""
     [M:SSL1]SRGPPS(LLIG) = [M:SSL1]SRGPPSSTR
Endif
NOL = LLIG
Grizo [M:SSL1]SRGPPS(LLIG)
Gosub FORMATAGE_CLE From TRTSSLA

[M:SSL1]WCLE   (LLIG)   = WCLE_FOR
[M:SSL1]SAIFLG = 2         # saisie manuelle à oui permet de desactiver les boutons recherche critere

[M:SSL1]NBLIG  = LLIG+1

Affzo [M:SSL1]

# il faut activer les zones de cle sur la ligne vide ....

NOL = [M:SSL1]NBLIG
Gosub ACT_RUB_CLE

Return

#########################################################################
#SET_NOL                                        Alimentation rubrique NOL
#########################################################################
$SET_NOL
Local Integer NOL : NOL = nolign-1
Return

#########################################################################
# ACT_RUB_CLE                               activation des rubriques cles
#########################################################################
$ACT_RUB_CLE
If dim([M:SSL1]VCRTYP(NOL)) > 0
   Actzo [M:SSL1]VCRTYP(NOL)
Endif
If dim([M:SSL1]VCRLIN(NOL)) > 0
   Actzo [M:SSL1]VCRLIN(NOL)
Endif
If dim([M:SSL1]VCRNUM(NOL)) > 0
   Actzo [M:SSL1]VCRNUM(NOL)
Endif
If dim([M:SSL1]ITMREF(NOL)) > 0
   Actzo [M:SSL1]ITMREF(NOL)
Endif
If dim([M:SSL1]LOCORI(NOL)) > 0
   Actzo [M:SSL1]LOCORI(NOL)
Endif
If dim([M:SSL1]WRHORI(NOL)) > 0
   If [M:SSL1]WRHGES = 2
      Actzo [M:SSL1]WRHORI(NOL)
   Endif
Endif
If dim([M:SSL1]COCHAGE(NOL)) > 0
   Grizo [M:SSL1]COCHAGE(NOL)
Endif
Return

#########################################################################
# DES_RUB_DESTINATION            desactivation des rubriques destinations
#########################################################################
$DES_RUB_DESTINATION
If dim([M:SSL1]COCHAGE(NOL)) > 0
   Actzo [M:SSL1]COCHAGE(NOL)
Endif
    If dim([M:SSL1]PCU(NOL)) > 0
       Grizo [M:SSL1]PCU(NOL)
    Endif
    If dim([M:SSL1]QTYPCU(NOL)) > 0
       Grizo [M:SSL1]QTYPCU(NOL)
    Endif
    If dim([M:SSL1]PCUSTUCOE(NOL)) > 0
       Grizo [M:SSL1]PCUSTUCOE(NOL)
    Endif
    If dim([M:SSL1]STA(NOL)) > 0
       Grizo [M:SSL1]STA(NOL)
    Endif
    If dim([M:SSL1]LOCTYP(NOL)) > 0
       Grizo [M:SSL1]LOCTYP(NOL)
    Endif
    If dim([M:SSL1]LOC(NOL)) > 0
       Grizo [M:SSL1]LOC(NOL)
    Endif
    If dim([M:SSL1]WRH(NOL)) > 0
       Grizo [M:SSL1]WRH(NOL)
    Endif
    If dim([M:SSL1]BPSLOT(NOL)) > 0
       Grizo [M:SSL1]BPSLOT(NOL)
    Endif
    If dim([M:SSL1]LOT(NOL)) > 0
       Grizo [M:SSL1]LOT(NOL)
    Endif
    If dim([M:SSL1]NBSLO(NOL)) > 0
       Grizo [M:SSL1]NBSLO(NOL)
    Endif
    If dim([M:SSL1]SLO(NOL)) > 0
       Grizo [M:SSL1]SLO(NOL)
    Endif
    If dim([M:SSL1]SERNUM(NOL)) > 0
       Grizo [M:SSL1]SERNUM(NOL)
    Endif
    If dim([M:SSL1]PALNUM(NOL)) > 0
       Grizo [M:SSL1]PALNUM(NOL)
    Endif
    If dim([M:SSL1]CTRNUM(NOL)) > 0
       Grizo [M:SSL1]CTRNUM(NOL)
    Endif
    If dim([M:SSL1]MVTDES(NOL)) > 0
       Grizo [M:SSL1]MVTDES(NOL)
    Endif

Return

#########################################################################
# ACT_RUB_DESTINATION               activation des rubriques destinations
#########################################################################
$ACT_RUB_DESTINATION
Local Integer LLIG

If dim([M:SSL1]SRGPPS(NOL)) > 0
   Actzo [M:SSL1]SRGPPS(NOL)
Endif
If dim([M:SSL1]PCU(NOL)) > 0
   Actzo [M:SSL1]PCU(NOL)
Endif
If dim([M:SSL1]QTYPCU(NOL)) > 0
  Actzo [M:SSL1]QTYPCU(NOL)
Endif
If dim([M:SSL1]PCUSTUCOE(NOL)) > 0
   Actzo [M:SSL1]PCUSTUCOE(NOL)
Endif
If dim([M:SSL1]STA(NOL)) > 0
   Actzo [M:SSL1]STA(NOL)
Endif
If dim([M:SSL1]LOCTYP(NOL)) > 0
   Actzo [M:SSL1]LOCTYP(NOL)
Endif
If dim([M:SSL1]LOC(NOL)) > 0
   Actzo [M:SSL1]LOC(NOL)
Endif
If dim([M:SSL1]WRH(NOL)) > 0
   If [M:SSL1]WRHGES = 2
      Actzo [M:SSL1]WRH(NOL)
   Endif
Endif
If dim([M:SSL1]BPSLOT(NOL)) > 0
   Actzo [M:SSL1]BPSLOT(NOL)
Endif
If dim([M:SSL1]LOT(NOL)) > 0
   Actzo [M:SSL1]LOT(NOL)
Endif
If dim([M:SSL1]SLO(NOL)) > 0
   Actzo [M:SSL1]SLO(NOL)
Endif
If dim([M:SSL1]NBSLO(NOL)) > 0
   Actzo [M:SSL1]NBSLO(NOL)
Endif
If dim([M:SSL1]SERNUM(NOL)) > 0
   Actzo [M:SSL1]SERNUM(NOL)
Endif
If dim([M:SSL1]PALNUM(NOL)) > 0
   Actzo [M:SSL1]PALNUM(NOL)
Endif
If dim([M:SSL1]CTRNUM(NOL)) > 0
   Actzo [M:SSL1]CTRNUM(NOL)
Endif
If dim([M:SSL1]MVTDES(NOL)) > 0
   Actzo [M:SSL1]MVTDES(NOL)
Endif

LLIG = NOL

#affichage rubriques selon gestion article
Gosub GES_ITM
Return

#########################################################################
# CHARGETYP_BLOC20       chargement premiere ligne du bloc 20 saisie type
#########################################################################
$CHARGETYP_BLOC20
Raz [M:SSL1]VCRTYPC
Raz [M:SSL1]VCRNUMSTR
Raz [M:SSL1]VCRNUMEND
[M:SSL1]VCRTYPC   (0) = VALEUR
[M:SSL1]VCRNUMSTR (0) = [M:SSL1]VCRNUMSTR1
[M:SSL1]VCRNUMEND (0) = [M:SSL1]VCRNUMEND1
Return

#########################################################################
# CHARGESTR_BLOC20     chargement premiere ligne du bloc 20 saisie NUMSTR
#########################################################################
$CHARGESTR_BLOC20
Raz [M:SSL1]VCRTYPC
Raz [M:SSL1]VCRNUMSTR
Raz [M:SSL1]VCRNUMEND
[M:SSL1]VCRTYPC   (0) = [M:SSL1]VCRTYPC1
[M:SSL1]VCRNUMSTR (0) = VALEUR
[M:SSL1]VCRNUMEND (0) = [M:SSL1]VCRNUMEND1
Return

#########################################################################
# CHARGEEND_BLOC20     chargement premiere ligne du bloc 20 saisie NUMEND
#########################################################################
$CHARGEEND_BLOC20
Raz [M:SSL1]VCRTYPC
Raz [M:SSL1]VCRNUMSTR
Raz [M:SSL1]VCRNUMEND
[M:SSL1]VCRTYPC   (0) = [M:SSL1]VCRTYPC1
[M:SSL1]VCRNUMSTR (0) = [M:SSL1]VCRNUMSTR1
[M:SSL1]VCRNUMEND (0) = VALEUR
Return

########################################################################
#LOAD_FILTER              Préparation du filtre bloc filtre table STOSRG
########################################################################
$LOAD_FILTER
Raz CRITERE
Raz CRITERE1
Raz CRITERE0
Local Char LNUM(GLONVCR)                            # hcb 57490
CRITERE = "[F:SRG]ORICOD=1&[F:SRG]STAFLG<>2"          # filtre origine + statut
Gosub LOAD_CRITERE

If [M:SSL1]STOFCY <> ""
   CRITERE = "[F:SRG]STOFCY=[M:SSL1]STOFCY"           # filtre site
   Gosub LOAD_CRITERE
Endif

If [M:SSL1]SRGPPSSTR <> ""
   CRITERE = "[F:SRG]SRGPPS=[M:SSL1]SRGPPSSTR"           # filtre liste à ranger
   CRITERE0 = CRITERE1
   CRITERE0 += "&"
   CRITERE0 += CRITERE
Endif

LNUM = ""
CRITERE = "[F:SRG]SRGPPS=LNUM"                      # filtre liste à ranger
Gosub LOAD_CRITERE

Return

########################################################################
#LOAD_FILTER2  préparation du filtre  bloc selection / date table STOSRG
########################################################################
$LOAD_FILTER2
Local Integer I
I = 0
Raz CRITERE
Raz CRITERE2

If [M:SSL1]STRDAT <> [0/0/0]
   Case [M:SSL1]FLGDAT
        When 1  CRITERE = "[F:SRG]CREDAT>=[M:SSL1]STRDAT"  # borne date creation
                Gosub LOAD_CRITERE2
                CRITERE = "[F:SRG]CREDAT<=[M:SSL1]ENDDAT"
                Gosub LOAD_CRITERE2
        When 2  CRITERE = "[F:SRG]IPTDAT>=[M:SSL1]STRDAT"  # borne date imputation
                Gosub LOAD_CRITERE2
                CRITERE = "[F:SRG]IPTDAT<=[M:SSL1]ENDDAT"
                Gosub LOAD_CRITERE2
   Endcase
Endif
Return

########################################################################
#LOAD_FILTER3   Préparation du filtre bloc Bornes debut fin table STOSRG
########################################################################
$LOAD_FILTER3
Raz CRITERE
Raz CRITERE3

If [M:SSL1]ITMREFSTR <> ""
    CRITERE = "[F:SRG]ITMREF>=[M:SSL1]ITMREFSTR"      # borne début article
    Gosub LOAD_CRITERE3
Endif
If [M:SSL1]ITMREFEND<>""
    CRITERE = "[F:SRG]ITMREF<=[M:SSL1]ITMREFEND"      # borne fin   article
    Gosub LOAD_CRITERE3
Endif
If [M:SSL1]LOCSTR <> ""
    CRITERE = "[F:SRG]LOC>=[M:SSL1]LOCSTR"            # borne début emplacement
    Gosub LOAD_CRITERE3
Endif
If [M:SSL1]LOCEND<>""
    CRITERE = "[F:SRG]LOC<=[M:SSL1]LOCEND"            # borne fin   emplacement
    Gosub LOAD_CRITERE3
Endif
If [M:SSL1]STASTR <> ""
    CRITERE = "[F:SRG]STA>=[M:SSL1]STASTR"            # borne début statut
    Gosub LOAD_CRITERE3
Endif
If [M:SSL1]STAEND<>""
    CRITERE = "[F:SRG]STA<=[M:SSL1]STAEND"            # borne fin   statut
    Gosub LOAD_CRITERE3
Endif
If dim([M:SSL1]WRHSTR) > 0
   If [M:SSL1]WRHSTR <> ""
      CRITERE = "[F:SRG]WRH>=[M:SSL1]WRHSTR"            # borne début depot
      Gosub LOAD_CRITERE3
   Endif
   If [M:SSL1]WRHEND<>""
      CRITERE = "[F:SRG]WRH<=[M:SSL1]WRHEND"            # borne fin   depot
      Gosub LOAD_CRITERE3
   Endif
Endif

Return

########################################################################
#LOAD_FILTER4  préparation du filtre  bloc selection / type table STOSRG
########################################################################
$LOAD_FILTER4
Raz CRITERE
Raz CRITERE4
Local Integer T (6)
Local Char A (GLONVCR) (6)           # hcb 57490
Local Char B (GLONVCR) (6)           # hcb 57490
Raz T
Raz A
Raz B
Local Integer I
I = 0
For I = 0 To 5
    If [M:SSL1]VCRTYPC(I) = 0
       Break
    Endif
    T (I) = [M:SSL1]VCRTYPC(I)-1
    A (I) = [M:SSL1]VCRNUMSTR(I)
    B (I) = [M:SSL1]VCRNUMEND(I)
Next


If T(0) = 0
   If A(0) <> ""
      CRITERE = "(VCRNUM>=A(0)&VCRNUM<=B(0))"
      Gosub LOAD_CRITERE4
   Endif
   Return
Endif

For I = 0 To 5
    If T(I) = 0
       Break
    Endif
    If A(I) <> ""
       Case I
          When 0 : CRITERE = "(VCRTYP=T(0)&VCRNUM>=A(0)&VCRNUM<=B(0))"
          When 1 : CRITERE = "(VCRTYP=T(1)&VCRNUM>=A(1)&VCRNUM<=B(1))"
          When 2 : CRITERE = "(VCRTYP=T(2)&VCRNUM>=A(2)&VCRNUM<=B(2))"
          When 3 : CRITERE = "(VCRTYP=T(3)&VCRNUM>=A(3)&VCRNUM<=B(3))"
          When 4 : CRITERE = "(VCRTYP=T(4)&VCRNUM>=A(4)&VCRNUM<=B(4))"
          When 5 : CRITERE = "(VCRTYP=T(5)&VCRNUM>=A(5)&VCRNUM<=B(5))"
       Endcase
    Else
       Case I
          When 0 : CRITERE = "(VCRTYP=T(0))"
          When 1 : CRITERE = "(VCRTYP=T(1))"
          When 2 : CRITERE = "(VCRTYP=T(2))"
          When 3 : CRITERE = "(VCRTYP=T(3))"
          When 4 : CRITERE = "(VCRTYP=T(4))"
          When 5 : CRITERE = "(VCRTYP=T(5))"
       Endcase
    Endif
    Gosub LOAD_CRITERE4
Next

Return

########################################################################
# LOAD_CRITERE                                     Concaténation CRITERE
########################################################################
$LOAD_CRITERE
If CRITERE1 <> ""
   CRITERE1 += "&"
Endif
CRITERE1 += CRITERE
Return

########################################################################
# LOAD_CRITERE2                                   Concaténation CRITERE2
########################################################################
$LOAD_CRITERE2
If CRITERE2 <> ""
   CRITERE2 += "&"
Endif
CRITERE2 += CRITERE
Return

########################################################################
# LOAD_CRITERE3                                   Concaténation CRITERE3
########################################################################
$LOAD_CRITERE3
If CRITERE3 <> ""
   CRITERE3 += "&"
Endif
CRITERE3 += CRITERE
Return

########################################################################
# LOAD_CRITERE4                                   Concaténation CRITERE4
########################################################################
$LOAD_CRITERE4
If CRITERE4 <> ""
   CRITERE4 += "|"
Endif
CRITERE4 += CRITERE
Return

########################################################################
#TRI_TAB                              tri du tableau suivant parametrage
########################################################################
$TRI_TAB
Local Integer WSRT
Local Integer I
I = 0
WSRT  = [M:SSL1]SRTCRIT1
WSRT  = WSRT * 10
WSRT += [M:SSL1]SRTCRIT2
If [M:SSL1]NBLIG <> 0
    Case WSRT
        When 20,21,22 : Sorta [M:SSL1]NBLIG [M:SSL1]NBLIG Order By [M:SSL1]IPTDAT(indice)
        When 23       : Sorta [M:SSL1]NBLIG [M:SSL1]NBLIG Order By [M:SSL1]IPTDAT(indice),
&                                                                [M:SSL1]ITMREF(indice)
        When 24       : Sorta [M:SSL1]NBLIG [M:SSL1]NBLIG Order By [M:SSL1]IPTDAT(indice),
&                                                                [M:SSL1]LOCORI(indice)
        When 25       : Sorta [M:SSL1]NBLIG [M:SSL1]NBLIG Order By [M:SSL1]IPTDAT(indice),
&                                                                [M:SSL1]VCRTYP(indice),
&                                                                [M:SSL1]VCRNUM(indice)


        When 30,31,33 : Sorta [M:SSL1]NBLIG [M:SSL1]NBLIG Order By [M:SSL1]ITMREF(indice)
        When 32       : Sorta [M:SSL1]NBLIG [M:SSL1]NBLIG Order By [M:SSL1]ITMREF(indice),
&                                                                [M:SSL1]IPTDAT(indice)
        When 34       : Sorta [M:SSL1]NBLIG [M:SSL1]NBLIG Order By [M:SSL1]ITMREF(indice),
&                                                                [M:SSL1]LOCORI(indice)
        When 35       : Sorta [M:SSL1]NBLIG [M:SSL1]NBLIG Order By [M:SSL1]ITMREF(indice),
&                                                                [M:SSL1]VCRTYP(indice),
&                                                                [M:SSL1]VCRNUM(indice)

        When 40,41,44 : Sorta [M:SSL1]NBLIG [M:SSL1]NBLIG Order By [M:SSL1]LOCORI(indice)
        When 42       : Sorta [M:SSL1]NBLIG [M:SSL1]NBLIG Order By [M:SSL1]LOCORI(indice),
&                                                                [M:SSL1]IPTDAT(indice)
        When 43       : Sorta [M:SSL1]NBLIG [M:SSL1]NBLIG Order By [M:SSL1]LOCORI(indice),
&                                                                [M:SSL1]ITMREF(indice)
        When 45       : Sorta [M:SSL1]NBLIG [M:SSL1]NBLIG Order By [M:SSL1]LOCORI(indice),
&                                                                [M:SSL1]VCRTYP(indice),
&                                                                [M:SSL1]VCRNUM(indice)

        When 50,51,55 : Sorta [M:SSL1]NBLIG [M:SSL1]NBLIG Order By [M:SSL1]VCRTYP(indice),
&                                                                [M:SSL1]VCRNUM(indice)
        When 52       : Sorta [M:SSL1]NBLIG [M:SSL1]NBLIG Order By [M:SSL1]VCRTYP(indice),
&                                                                [M:SSL1]VCRNUM(indice),
&                                                                [M:SSL1]IPTDAT(indice)
        When 53       : Sorta [M:SSL1]NBLIG [M:SSL1]NBLIG Order By [M:SSL1]VCRTYP(indice),
&                                                                [M:SSL1]VCRNUM(indice),
&                                                                [M:SSL1]ITMREF(indice)
        When 54       : Sorta [M:SSL1]NBLIG [M:SSL1]NBLIG Order By [M:SSL1]VCRTYP(indice),
&                                                                [M:SSL1]VCRNUM(indice),
&                                                                [M:SSL1]LOCORI(indice)

    Endcase

# hcb 41128
    GPOINT = "FUNSSLTRI"
    Gosub  ENTREE From EXEFNC

    Grizo  [M:SSL1]VCRTYP
    Grizo  [M:SSL1]VCRNUM
    Grizo  [M:SSL1]VCRLIN
    Grizo  [M:SSL1]ITMREF
    Grizo  [M:SSL1]LOCORI
    If dim([M:SSL1]WRHORI) > 0
       Grizo [M:SSL1]WRHORI
    Endif
    Affzo [M:SSL1]25
Endif


# il faut activer les zones de cle sur la ligne vide ....
Local Integer NOL
NOL = [M:SSL1]NBLIG
Gosub ACT_RUB_CLE

Return

########################################################################
# RECH_CLE                      RECHERCHE meilleur cle pour optimisation
########################################################################
$RECH_CLE

Local Integer WCLE
WCLE = 0
If [M:SSL1]SRGPPSSTR <> "" & [M:SSL1]LSTWIOFLG <> 2
   WCLE = 4
   Return
Endif

If [M:SSL1]VCRTYPC (0) <> 1
    WCLE = 3
    Return
Endif
If [M:SSL1]ITMREFSTR  <> ""
    WCLE = 1
    Return
Endif

If [M:SSL1]LOCSTR  <> ""
    WCLE = 2
    Return
Endif

Return

########################################################################
# CTR_EXI_SSL1 Controle existance tableau SSL1 suite selection ou saisie
########################################################################
$CTR_EXI_SSL1
Gosub FORMATAGE_CLE
Local Integer WEXI
WEXI = 0
WEXI = find ( WCLE_FOR,[M:SSL1]WCLE(0..[M:SSL1]NBLIG))
Return

########################################################################
# FORMATAGE_CLE            Formatage d une zone pour recherche existance
########################################################################
$FORMATAGE_CLE
Local Char WCLE_FOR(70)
WCLE_FOR =  num$([F:SRG]VCRTYP)
WCLE_FOR += num$([F:SRG]STOCOU)
WCLE_FOR += [F:SRG]VCRNUM
WCLE_FOR += num$([F:SRG]VCRLIN)
WCLE_FOR += [F:SRG]ITMREF
WCLE_FOR += [F:SRG]LOC
Return
########################################################################
# DECOCHAGE_SSL1  Mise à jour du flag STAFLG à 1 en cas d abandon ou fin
#                                        pour les enregistrements coches
########################################################################
$DECOCHAGE_SSL1
Local Integer I
Raz I
For I = 0 To [M:SSL1]NBLIG-1
    If [M:SSL1]COCHAGE (I) = 2 &  [M:SSL1]COCHAGE_AV (I) <> 2
       Call MAJ_SRG_STAFLG(I,1)  From TRTSSLA    # mise à jour du flag STAFLG à 1
    Endif
Next I
Return

########################################################################
# LECTURE_STOSRG                                          lecture STOSRG
########################################################################
$LECTURE_STOSRG
Local Integer WLEC
WLEC = 0

# nombre de lecture (sert pour la saisie ligne)
Local Integer WMAX
WMAX = dim([M:SSL1]COCHAGE)     # mémorisation nombre de ligne maxi

If GLECSTOSRG = 1             # hcb 52838
   Default File [SRGX]        # hcb 52838
Else                          # hcb 52838
  Default File  [SRG]         # hcb 52838
Endif                         # hcb 52838

For [F]                       # hcb 52838
# Verification que l enregistrement n existe pas dans le tableau
    If GWRHACT = 2 & [M:SSL1]WRHOBY = 2 & [M:SSL1]WRHGES = 2
       Local Integer WITW
       Raz   WITW
       Call CTR_ITW([F:SRG]ITMREF,[M:SSL1]WRHE,WITW)
       If WITW = 2
          Goto NEXTSRG
       Endif
    Endif
    If VERIF = 2
       Gosub CTR_EXI_SSL1 From TRTSSLA
       If WEXI <> 0
          Goto NEXTSRG
       Endif
    Endif
    If nolign = WMAX : Break : Endif
    WLEC += 1
    [M:SSL1]CREFLG    (nolign-1)  = 0
    [M:SSL1]MODFLG    (nolign-1)  = 1
    [M:SSL1]WFLG      (nolign-1)  = 1
    [M:SSL1]WSTOFLG   (nolign-1)  = 0
    [M:SSL1]VCRTYP    (nolign-1)  = [F:SRG]VCRTYP
    [M:SSL1]TRSTYP    (nolign-1)  = [F:SRG]TRSTYP
    [M:SSL1]VCRNUM    (nolign-1)  = [F:SRG]VCRNUM
    [M:SSL1]VCRLIN    (nolign-1)  = [F:SRG]VCRLIN
    [M:SSL1]VCRTYPORI (nolign-1)  = [F:SRG]VCRTYPORI
    [M:SSL1]VCRNUMORI (nolign-1)  = [F:SRG]VCRNUMORI
    [M:SSL1]VCRLINORI (nolign-1)  = [F:SRG]VCRLINORI
    [M:SSL1]IPTDAT    (nolign-1)  = [F:SRG]IPTDAT
    [M:SSL1]ITMREF    (nolign-1)  = [F:SRG]ITMREF
    [M:SSL1]SRGPPS    (nolign-1)  = [F:SRG]SRGPPS
    [M:SSL1]SRGPPS_AV (nolign-1)  = [F:SRG]SRGPPS
    [M:SSL1]LOCORI    (nolign-1)  = [F:SRG]LOC
    [M:SSL1]STAORI    (nolign-1)  = [F:SRG]STA
    [M:SSL1]STOCOU    (nolign-1)  = [F:SRG]STOCOU
    [M:SSL1]MVTDES    (nolign-1)  = [F:SRG]MVTDES
    [M:SSL1]QUAFLG    (nolign-1)  = [F:SRG]QUAFLG    # hcb V6CQ
    [M:SSL1]QUAFRE    (nolign-1)  = [F:SRG]QUAFRE    # hcb V6CQ
    [M:SSL1]BPRNUM    (nolign-1)  = [F:SRG]BPRNUM    # hcb V6CQ

    If dim([M:SSL1]PJT) > 0
       [M:SSL1]PJT(nolign-1)      = [F:SRG]PJT
    Endif
    If dim([M:SSL1]WRHORI) > 0
       [M:SSL1]WRHORI(nolign-1)   = [F:SRG]WRH
    Endif

# recherche TRSCOD origine
    Gosub TRT_ORIGINE_TRSCOD From TRTSSLA
    [M:SSL1]TRSCOD(nolign-1)      = WTRSCOD
#   [M:SSL1]BPRNUM(nolign-1)      = WBPRNUM          # hcb V6CQ
    [M:SSL1]BETCPY(nolign-1)      = WBETCPY

    Read [STO] STO0=[F:SRG]STOFCY;[F:SRG]STOCOU
    If fstat
       Raz [F:STO]
       Goto NEXTSRG               # si pas de ligne de stock correspondant on ignore
    Endif
    If [F:ITM]ITMREF<>[F:SRG]ITMREF
        Read [F:ITM]ITM0=[F:SRG]ITMREF
        If fstat
           Raz [F:ITM]
        Endif
    Endif
#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
    If [F:ITF]STOFCY <> [F:SRG]STOFCY | [F:ITF]ITMREF <> [F:SRG]ITMREF
       Read [ITF]ITF0 = [F:SRG]ITMREF;[F:SRG]STOFCY
       If fstat
          Raz [F:ITF]
       Endif
     Endif

    [M:SSL1]STU         (nolign-1)   = [F:ITM]STU
#rubrique origine
    If dim([M:SSL1]PALNUM) > 0
       [M:SSL1]PALNUM      (nolign-1)   = [F:STO]PALNUM
    Endif
    If dim([M:SSL1]CTRNUM) > 0
       [M:SSL1]CTRNUM      (nolign-1)   = [F:STO]CTRNUM
    Endif
    [M:SSL1]PCUORI      (nolign-1)   = [F:STO]PCU
    [M:SSL1]QTYSTUORI   (nolign-1)   = [F:SRG]QTYSTUACT
    [M:SSL1]PCUSTUCOEO  (nolign-1)   = [F:STO]PCUSTUCOE
    If [F:ITF]STOMGTCOD = 3 | [F:ITM]ECCSTO > 1                                               # hcb 111781
        Read[STL]STL0=[F:SRG]ITMREF;[F:STO]LOT;[F:STO]SLO
        If fstat
           Raz [F:STL]
           [F:STL]POT = 1
        Endif
        [M:SSL1]QTYSTUORI   (nolign-1)   = ([F:SRG]QTYSTUACT/[F:STL]POT)*100
        #--- Bug ISIS C75J30
        Call QTEARR([M:SSL1]QTYSTUORI(nolign-1),[F:ITM]STU) From TRTDIV
    Endif
# hcb 31014  deb
    GPOINT = "FUNSSLCRI"
    GPE    = 0
    Gosub  ENTREE From EXEFNC
    If GPE  <> 0
       Goto NEXTSRG
    Endif
# hcb 31014  fin
#                                                                                         # hcb 111781 deb
    If [F:STL]LOT <> ""
       If dim([M:SSL1]ECCVALMAJ)>0
          [M:SSL1]ECCVALMAJORI(nolign-1) = [F:STL]ECCVALMAJ
          [M:SSL1]ECCVALMAJ   (nolign-1) = [F:STL]ECCVALMAJ
          [M:SSL1]ECCVALMINORI(nolign-1) = [F:STL]ECCVALMIN
          [M:SSL1]ECCVALMIN   (nolign-1) = [F:STL]ECCVALMIN
          [M:SSL1]ECCSAIFLG   (nolign-1) = 1
          [M:SSL1]ECCSAIFLGORI(nolign-1) = 1
       Endif
    Endif
#                                                                                         # hcb 111781 deb

    If  [F:STO]PCUSTUCOE <> 0
        [M:SSL1]QTYPCUORI   (nolign-1)   = [M:SSL1]QTYSTUORI   (nolign-1) /[F:STO]PCUSTUCOE
    Endif
    If dim([M:SSL1]LOTORI) > 0
       [M:SSL1]LOTORI      (nolign-1)   = [F:STO]LOT
    Endif
    If dim([M:SSL1]BPSLOTORI) > 0
       [M:SSL1]BPSLOTORI   (nolign-1)   = [F:STO]BPSLOT
    Endif
    If dim([M:SSL1]SLOORI) > 0
       [M:SSL1]SLOORI      (nolign-1)   = [F:STO]SLO
    Endif
    If dim([M:SSL1]SERNUMORI) > 0
       [M:SSL1]SERNUMORI   (nolign-1)   = [F:STO]SERNUM
    Endif
    If dim([M:SSL1]PALNUMORI) > 0
       [M:SSL1]PALNUMORI   (nolign-1)   = [F:STO]PALNUM
    Endif
    If dim([M:SSL1]CTRNUMORI) > 0
       [M:SSL1]CTRNUMORI   (nolign-1)   = [F:STO]CTRNUM
    Endif

    If dim([M:SSL1]LOT) > 0
       [M:SSL1]LOT         (nolign-1)   = [M:SSL1]LOTORI      (nolign-1)
    Endif
    If dim([M:SSL1]BPSLOT) > 0
       [M:SSL1]BPSLOT      (nolign-1)   = [M:SSL1]BPSLOTORI   (nolign-1)
    Endif
    If dim([M:SSL1]SLO) > 0
       [M:SSL1]SLO         (nolign-1)   = [M:SSL1]SLOORI      (nolign-1)
       If [M:SSL1]SLO      (nolign-1) <> ""
          [M:SSL1]NBSLO    (nolign-1)   = 1
       Endif
     Endif
    If dim([M:SSL1]SERNUM) > 0
       [M:SSL1]SERNUM      (nolign-1)   = [M:SSL1]SERNUMORI   (nolign-1)
    Endif
    If dim([M:SSL1]SERNUMF) > 0
       [M:SSL1]SERNUMF     (nolign-1)   = [M:SSL1]SERNUMORI   (nolign-1)
    Endif
    If dim([M:SSL1]PALNUM) > 0
       [M:SSL1]PALNUM      (nolign-1)   = [M:SSL1]PALNUMORI   (nolign-1)
    Endif
    If dim([M:SSL1]CTRNUM) > 0
       [M:SSL1]CTRNUM      (nolign-1)   = [M:SSL1]CTRNUMORI   (nolign-1)
    Endif

# si liste à ranger = blanc alors liste du filtre si saisie manuelle
    If VERIF = 2
       If   [M:SSL1]SRGPPS(nolign-1) = ""
            [M:SSL1]SRGPPS(nolign-1) = [M:SSL1]SRGPPSSTR
       Endif
    Endif
    If   [M:SSL1]SRGPPS(nolign-1) = ""
         [M:SSL1]COCHAGE(nolign-1)    = 1
         [M:SSL1]COCHAGE_AV(nolign-1) = 1
    Endif

    If   [M:SSL1]SRGPPS(nolign-1) <> ""
         [M:SSL1]COCHAGE(nolign-1)    = 2
         [M:SSL1]COCHAGE_AV(nolign-1) = 2
    Endif
    If [F:SRG]SRGPPS <> ""
       Default Mask [SSL1]
       Call INIZONENT([M:SSL1]ITMREF(nolign-1),"SSL1",[M:SSL1]STOFCY,"",0,"",
&                     (nolign-1),[M:SSL1]TRSTYP(nolign-1),[M:SSL1]TRSCOD(nolign-1),
&                     [M:SSL1]VCRNUM(nolign-1),1,0) From STKECR
       [M:SSL1]CREFLG    (nolign-1)   = 1
       [M:SSL1]PCU       (nolign-1)   = [F:SRG]PCU
       [M:SSL1]QTYPCU    (nolign-1)   = [F:SRG]QTYPCU
       [M:SSL1]PCUSTUCOE (nolign-1)   = [F:SRG]PCUSTUCOE
       [M:SSL1]QTYSTU    (nolign-1)   = [F:SRG]QTYSTU
       [M:SSL1]VCRTYPORI (nolign-1)   = [F:SRG]VCRTYPORI
       [M:SSL1]VCRNUMORI (nolign-1)   = [F:SRG]VCRNUMORI
       [M:SSL1]VCRLINORI (nolign-1)   = [F:SRG]VCRLINORI
       [M:SSL1]QUAFLG    (nolign-1)   = [F:SRG]QUAFLG    # hcb V6CQ
       [M:SSL1]QUAFRE    (nolign-1)   = [F:SRG]QUAFRE    # hcb V6CQ
       [M:SSL1]BPRNUM    (nolign-1)   = [F:SRG]BPRNUM    # hcb V6CQ

       For [SGW]SGW0 Where STOCOU   = [F:SRG]STOCOU  &
&                          VCRTYP   = [F:SRG]VCRTYP  &
&                          VCRNUM   = [F:SRG]VCRNUM  &
&                          VCRLIN   = [F:SRG]VCRLIN  &
&                          SRGPPS   = [F:SRG]SRGPPS

          Gosub CHARGE_ENTW_STOSGW
          Call LOAD_FROM_ENTW("SSL1",nolign-1,[M:SSL1]STOFCY, [M:SSL1]WSTOSEQ(nolign-1), [M:SSL1]ITMREF(nolign-1), [M:SSL1]VCRTYPORI(nolign-1) )  From STKENT
#                                                                                         # hcb 111781 deb
          If dim([M:SSL1]ECCVALMAJ)>0
             [M:SSL1]ECCVALMAJORI(nolign-1) = [M:SSL1]ECCVALMAJ(nolign-1)
             [M:SSL1]ECCVALMINORI(nolign-1) = [M:SSL1]ECCVALMIN(nolign-1)
             [M:SSL1]ECCSAIFLG   (nolign-1) = 1
             [M:SSL1]ECCSAIFLGORI(nolign-1) = [M:SSL1]ECCSAIFLG(nolign-1)
          Endif
#                                                                                         # hcb 111781 fin

       Next
       [M:SSL1]NBLIG  = nolign
    Endif
    NOL = nolign-1
    [M:SSL1]NBLIG  = nolign
    nolign += 1
    Gosub FORMATAGE_CLE
    [M:SSL1]WCLE   (NOL)   = WCLE_FOR

$NEXTSRG
Next

If GLECSTOSRG <> 1             # hcb 52838
   Filter [F:SRG]
Endif                          # hcb 52838
Return

########################################################################
# DELETE_STOSRGW               Suppression d une ligne SSL1 dans STOSRGW
########################################################################
$DELETE_STOSRGW
# si gestion du fichier TABWIPSTO il faut aussi supprimer les enregistrements correspondant
If GWIPSTOLCK=2
   For [SGW]SGW0 Where STOFCY = [M:SSL1]STOFCY    &
&                    ORICOD = 1                   &
&                    STOCOU = [M:SSL1]STOCOU(NOL) &
&                    VCRTYP = [M:SSL1]VCRTYP(NOL) &
&                    VCRNUM = [M:SSL1]VCRNUM(NOL) &
&                    VCRLIN = [M:SSL1]VCRLIN(NOL)

       Delete [F:TWS] Where STOCOU = [F:SGW]STOCOU      &
&                    STOSEQ = [F:SGW]STOSEQTWS
   Next

Endif

Delete [F:SGW] Where STOCOU = [M:SSL1]STOCOU(NOL) &
&                    VCRTYP = [M:SSL1]VCRTYP(NOL) &
&                    VCRNUM = [M:SSL1]VCRNUM(NOL) &
&                    VCRLIN = [M:SSL1]VCRLIN(NOL) &
&                    STOFCY = [M:SSL1]STOFCY      &
&                    ORICOD = 1
Return

########################################################################
# ECRITURE_STOSRGW                Ecriture d une ligne SSL1 dans STOSRGW
########################################################################
$ECRITURE_STOSRGW
Local Integer I
Local Decimal  WTWSSEQ
Local Decimal  WSRGSEQ
I = 0
WTWSSEQ = 0
WSRGSEQ = 1
For I = 0 To [M:ENTW]NBLIG-1
    If [M:ENTW]WSTOSEQ(I) = [M:SSL1]WSTOSEQ(NOL)

       If [F:ITM]ITMREF<>[M:SSL1]ITMREF(NOL)
          Read [F:ITM]ITM0=[M:SSL1]ITMREF(NOL)
          If fstat
             Raz [F:ITM]
          Endif
       Endif

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
       If [F:ITF]STOFCY <> [M:SSL1]STOFCY | [F:ITF]ITMREF <> [M:SSL1]ITMREF(NOL)
          Read [ITF]ITF0 = [M:SSL1]ITMREF(NOL);[M:SSL1]STOFCY
          If fstat
             Raz [F:ITF]
          Endif
       Endif

# gestion du fichier Quantites stock bloquées
       If GWIPSTOLCK=2
          Filter [TWS] Where STOCOU = [M:SSL1]STOCOU(NOL)
&                         Order By Key TWS0
          Read [TWS] Last
               If fstat = 0  WTWSSEQ =[F:TWS]STOSEQ+ 1
               Else          WTWSSEQ = 1
               Endif
          Raz [F:TWS]
          [F:TWS]STOCOU    = [M:SSL1]STOCOU(NOL)
          [F:TWS]STOSEQ    = WTWSSEQ
          [F:TWS]STOFCY    = [M:SSL1]STOFCY

          [F:TWS]VCRTYP    = 27                   # plan de rangement
          [F:TWS]VCRNUM    = [M:SSL1]SRGPPS(NOL)  # n° liste à ranger
          [F:TWS]VCRLIN    = 0
          [F:TWS]ITMREF    = [M:SSL1]ITMREF(NOL)
          [F:TWS]WIPQTY    = [M:ENTW]QTYSTU(I)
          [F:TWS]WIPQTA    = [M:ENTW]QTYSTU(I)

# calcul quantité active
          If [F:ITF]STOMGTCOD = 3
             If [M:ENTW]NUMLIGLOT(I) <> -1
                If [M:ENTW]POT([M:ENTW]NUMLIGLOT(I)) = 0
                   [M:ENTW]POT([M:ENTW]NUMLIGLOT(I)) = 100
                Endif
                [F:TWS]WIPQTA = ([M:ENTW]QTYSTU(I)* [M:ENTW]POT([M:ENTW]NUMLIGLOT(I)) / 100)
                Call QTEARR([F:TWS]WIPQTA , [F:ITM]STU) From TRTDIV
             Endif
          Endif
          [F:TWS]CREDAT    = date$
          [F:TWS]CREUSR    = GUSER

          Write [TWS]
          If fstat GOK = 0 : Call FSTA("TWS") From GLOCK : Endif
          Filter [TWS]
          If GOK < 1
             Break
          Endif

       Endif

       Filter [SGW] Where STOFCY = [M:SSL1]STOFCY      &
&                         ORICOD = 1                   &
&                         STOCOU = [M:SSL1]STOCOU(NOL) &
&                         VCRTYP = [M:SSL1]VCRTYP(NOL) &
&                         VCRNUM = [M:SSL1]VCRNUM(NOL) &
&                         VCRLIN = [M:SSL1]VCRLIN(NOL)
&                         Order By Key SGW0
       Read [SGW] Last
            If fstat = 0  WSRGSEQ =[F:SGW]SRGSEQ+ 1
            Else          WSRGSEQ = 1
            Endif
       Raz [F:SGW]
       [F:SGW]STOCOU    = [M:SSL1]STOCOU   (NOL)
       [F:SGW]VCRTYP    = [M:SSL1]VCRTYP   (NOL)
       [F:SGW]VCRNUM    = [M:SSL1]VCRNUM   (NOL)
       [F:SGW]VCRLIN    = [M:SSL1]VCRLIN   (NOL)
       [F:SGW]WSTOFLG   = [M:SSL1]WSTOFLG  (NOL)
       [F:SGW]STOFCY    = [M:SSL1]STOFCY
       [F:SGW]SRGSEQ    = WSRGSEQ
       [F:SGW]STOSEQTWS = WTWSSEQ
       [F:SGW]ORICOD    = 1
       [F:SGW]SRGPPS    = [M:SSL1]SRGPPS   (NOL)
       [F:SGW]CREPPS    = date$
       [F:SGW]CREUSR    = GUSER

       [F:SGW]STA       = [M:ENTW]STA      (I)
       [F:SGW]LOCTYP    = [M:ENTW]LOCTYP   (I)
       [F:SGW]LOC       = [M:ENTW]LOC      (I)
       [F:SGW]WRH       = [M:ENTW]WRH      (I)
       [F:SGW]SERNUM    = [M:ENTW]SERNUM   (I)
       [F:SGW]SERNUMF   = [M:ENTW]SERNUMF  (I)
       [F:SGW]PCU       = [M:ENTW]PCU      (I)
       [F:SGW]QTYPCU    = [M:ENTW]QTYPCU   (I)
       [F:SGW]PCUSTUCOE = [M:ENTW]PCUSTUCOE(I)
       [F:SGW]QTYSTU    = [M:ENTW]QTYSTU   (I)
       [F:SGW]PALNUM    = [M:ENTW]PALNUM   (I)
       [F:SGW]CTRNUM    = [M:ENTW]CTRNUM   (I)
       [F:SGW]STOFLD1   = [M:ENTW]STOFLD1  (I)
       [F:SGW]STOFLD2   = [M:ENTW]STOFLD2  (I)

# test numliglot à -1 (pas de saisie de lot possible dans le plan de rangement)
       If [M:ENTW]NUMLIGLOT(I) <> -1
          [F:SGW]SHLDAT    = [M:ENTW]SHLDAT  ([M:ENTW]NUMLIGLOT(I))
          [F:SGW]BPSLOT    = [M:ENTW]BPSLOT  ([M:ENTW]NUMLIGLOT(I))
          [F:SGW]SHL       = [M:ENTW]SHL([M:ENTW]NUMLIGLOT(I))
          [F:SGW]REFPER    = [M:ENTW]REFPER([M:ENTW]NUMLIGLOT(I))
          [F:SGW]LOT       = [M:ENTW]LOT([M:ENTW]NUMLIGLOT(I))
          [F:SGW]GESLOT    = [M:ENTW]GESLOT([M:ENTW]NUMLIGLOT(I))
          [F:SGW]SLO       = [M:ENTW]SLO([M:ENTW]NUMLIGLOT(I))
          [F:SGW]POT       = [M:ENTW]POT([M:ENTW]NUMLIGLOT(I))
          [F:SGW]ACT       = [M:ENTW]ACT([M:ENTW]NUMLIGLOT(I))
          [F:SGW]USRFLD1   = [M:ENTW]USRFLD1([M:ENTW]NUMLIGLOT(I))
          [F:SGW]USRFLD2   = [M:ENTW]USRFLD2([M:ENTW]NUMLIGLOT(I))
          [F:SGW]USRFLD3   = [M:ENTW]USRFLD3([M:ENTW]NUMLIGLOT(I))
          [F:SGW]USRFLD4   = [M:ENTW]USRFLD4([M:ENTW]NUMLIGLOT(I))
#                                                                                         # hcb 111781 deb
          If dim([F:SGW]ECCVALMAJ) > 0
             [F:SGW]ECCVALMAJ = [M:ENTW]ECCVALMAJ([M:ENTW]NUMLIGLOT(I))
          Endif
          If dim([F:SGW]ECCVALMAJ) > 0
             [F:SGW]ECCVALMIN = [M:ENTW]ECCVALMIN([M:ENTW]NUMLIGLOT(I))
          Endif
#                                                                                         # hcb 111781 end
       Endif

       [F:SGW]STU       = [F:ITM]STU

       Write [SGW]
       If fstat GOK = 0 : Call FSTA("SGW") From GLOCK : Endif
       Filter [SGW]
       If GOK < 1
          Break
       Endif
    Endif
Next I
Return


########################################################################
# CHARGE_ENTW_STOSGW    Chargement du masque STOENTW à partir de STOSRGW
########################################################################
$CHARGE_ENTW_STOSGW
# clacul de WSTOSEQ
Local    Integer  LBID
Local    Integer  LRET

Call STKWSTOSEQ("SSL1",nolign-1, [M:SSL1]NBLIG, 0, LBID, LRET) From STKECR

Local Integer WMAX
WMAX = dim([M:ENTW]PCU)     # mémorisation nombre de ligne maxi
Local Integer I
I = [M:ENTW]NBLIG
If I >= WMAX
   Call ERREUR(mess(10,184,1)) From GESECRAN
   Return
Endif

[M:SSL1]WSTOFLG  (nolign-1) = [F:SGW]WSTOFLG

[M:ENTW]WSTOSEQ  (I)  = [M:SSL1]WSTOSEQ (nolign-1)
[M:ENTW]ITMREF   (I)  = [M:SSL1]ITMREF  (nolign-1)
[M:ENTW]STOCOU   (I)  = [M:SSL1]STOCOU  (nolign-1)

[M:ENTW]STA      (I)  = [F:SGW]STA
[M:ENTW]LOCTYP   (I)  = [F:SGW]LOCTYP
[M:ENTW]LOC      (I)  = [F:SGW]LOC
[M:ENTW]WRH      (I)  = [F:SGW]WRH
[M:ENTW]SERNUM   (I)  = [F:SGW]SERNUM
[M:ENTW]SERNUMF  (I)  = [F:SGW]SERNUMF
[M:ENTW]PCU      (I)  = [F:SGW]PCU
[M:ENTW]QTYPCU   (I)  = [F:SGW]QTYPCU
[M:ENTW]PCUSTUCOE(I)  = [F:SGW]PCUSTUCOE
[M:ENTW]QTYSTU   (I)  = [F:SGW]QTYSTU
[M:ENTW]PALNUM   (I)  = [F:SGW]PALNUM
[M:ENTW]CTRNUM   (I)  = [F:SGW]CTRNUM
[M:ENTW]STOFLD1  (I)  = [F:SGW]STOFLD1
[M:ENTW]STOFLD2  (I)  = [F:SGW]STOFLD2
#                                                                                         # hcb 111781 deb
If dim([M:ENTW]ECCVALMAJ) > 0
       [M:ENTW]ECCVALMAJ (I) = [F:SGW]ECCVALMAJ
Endif
If dim([M:ENTW]ECCVALMAJ) > 0
       [M:ENTW]ECCVALMIN (I) = [F:SGW]ECCVALMIN
Endif
#                                                                                         # hcb 111781 end

#recuperation demande analyse du fichier SRU   # hcb 73144
If left$([M:ENTW]STA(I),1)="Q"
   [M:ENTW]QLYCTLFLG (I)        = [F:SRU]QLYCTLFLG
Else
   [M:ENTW]QLYCTLFLG (I)        = 1
Endif

# alimentation lot slo bpslot geslot -> bloc lot de entw
If dim([M:ENTW]LOT(I)) > 0
      Call SETCPTLOTAUTO( [F:SRG]ITMREF, "ENTW", I, [F:SGW]LOT, [F:SGW]SLO, [F:SGW]BPSLOT, [F:SGW]GESLOT,[F:SGW]ECCVALMAJ,[F:SGW]ECCVALMIN,1, LRET ) From STKENT  # hcb 111781
       If [M:ENTW]NUMLIGLOT(I) <> -1

# si existe dans STOLOT non modifiable
          If [M:ENTW]MODIF   ([M:ENTW]NUMLIGLOT(I)) = 2
             [M:ENTW]SHLDAT  ([M:ENTW]NUMLIGLOT(I)) = [F:SGW]SHLDAT
             [M:ENTW]POT     ([M:ENTW]NUMLIGLOT(I)) = [F:SGW]POT
             [M:ENTW]ACT     ([M:ENTW]NUMLIGLOT(I)) = [F:SGW]ACT
             [M:ENTW]USRFLD1 ([M:ENTW]NUMLIGLOT(I)) = [F:SGW]USRFLD1
             [M:ENTW]USRFLD2 ([M:ENTW]NUMLIGLOT(I)) = [F:SGW]USRFLD2
             [M:ENTW]USRFLD3 ([M:ENTW]NUMLIGLOT(I)) = [F:SGW]USRFLD3
             [M:ENTW]USRFLD4 ([M:ENTW]NUMLIGLOT(I)) = [F:SGW]USRFLD4
             [M:ENTW]REFPER  ([M:ENTW]NUMLIGLOT(I)) = [F:SGW]REFPER
             [M:ENTW]SHL     ([M:ENTW]NUMLIGLOT(I)) = [F:SGW]SHL
          Endif
       Endif
Endif

I += 1
[M:ENTW]NBLIG        = I

Return


########################################################################
# LEC_TABSTO                                         Lecture ITM ITF SRU
########################################################################
$LEC_TABSTO
If [M:SSL1]ITMREF(LLIG) = ""
   Return
Endif
If [F:ITM]ITMREF<>[M:SSL1]ITMREF(LLIG)
   Read [ITM]ITM0=[M:SSL1]ITMREF(LLIG)
   If fstat
      Call RSTA("ITM",[M:SSL1]ITMREF(LLIG)) From GLOCK
      LRET=1 : Return
   Endif
Endif

If [F:ITF]ITMREF<>[F:ITM]ITMREF | [F:ITF]STOFCY<>[M:SSL1]STOFCY
    Read [ITF]ITF0=[F:ITM]ITMREF;[M:SSL1]STOFCY
    If fstat
       Call RSTA("ITF",[M:SSL1]ITMREF(LLIG)) From GLOCK
      LRET=1 : Return
   Endif
Endif

Return

########################################################################
# ACT_PIKSSL Selection par saisie rubrique cle remplisssage tableau SSL1
#                                                     apres_modif LOCORI
########################################################################
$ACT_PIKSSL
Local Char    CRITERE(255)
Local Char    CRITER1(255)
Local Char    CRITER2(255)
Local Char LSRG(10)
LSRG = ""
# Verif sert à controler l existance de lenregistrement dans le tableau 1 non verif  2 verif
Local Integer VERIF
VERIF = 2

CRITERE = "[F:SRG]ORICOD=1&[F:SRG]STAFLG<>2&[F:SRG]STOFCY=[M:SSL1]STOFCY&[F:SRG]SRGPPS=LSRG"
CRITER1 = "[F:SRG]VCRTYP=[M:SSL1]VCRTYP(NOL)&[F:SRG]VCRNUM=[M:SSL1]VCRNUM(NOL)&[F:SRG]VCRLIN=[M:SSL1]VCRLIN(NOL)"
CRITER2 = "[F:SRG]ITMREF=[M:SSL1]ITMREF(NOL)&[F:SRG]LOC=VALEUR"
If dim([M:SSL1]WRHORI)> 0
   CRITER2 = "[F:SRG]ITMREF=[M:SSL1]ITMREF(NOL)&[F:SRG]WRH=[M:SSL1]WRHORI(NOL)&[F:SRG]LOC=VALEUR"
Endif
Raz GLECSTOSRG          # hcb 52838
Filter [SRG]  Where evalue(CRITERE)&evalue(CRITER1)&evalue(CRITER2)
&                Order By Key SRG3
Gosub LECTURE_STOSRG

Filter [SRG]
If WLEC = 0
   mkstat=2
   GMESSAGE=mess(13,184,1)    # Aucun enregistrement en attente de rangement correspondant
Else
   [M:SSL1]SAIFLG = 2         # saisie manuelle à oui permet de desactiver les boutons recherche critere

   [M:SSL1]MODFLG     (NOL)  = 2
   [M:SSL1]COCHAGE    (NOL)  = 2
   If   [M:SSL1]SRGPPS(NOL) = ""
        [M:SSL1]SRGPPS(NOL) = [M:SSL1]SRGPPSSTR
   Endif
#rubrique destination par défaut   hcb mars
   [M:SSL1]PCU         (NOL)   = [M:SSL1]PCUORI      (NOL)
   [M:SSL1]QTYPCU      (NOL)   = [M:SSL1]QTYPCUORI   (NOL)
   [M:SSL1]QTYSTU      (NOL)   = [M:SSL1]QTYSTUORI   (NOL)
   [M:SSL1]PCUSTUCOE   (NOL)   = [M:SSL1]PCUSTUCOEO  (NOL)
   If dim([M:SSL1]LOT) > 0
      [M:SSL1]LOT         (NOL)   = [M:SSL1]LOTORI      (NOL)
   Endif
   If dim([M:SSL1]BPSLOT) > 0
      [M:SSL1]BPSLOT      (NOL)   = [M:SSL1]BPSLOTORI   (NOL)
   Endif
   If dim([M:SSL1]SLO) > 0
      [M:SSL1]SLO         (NOL)   = [M:SSL1]SLOORI      (NOL)
      If [M:SSL1]SLO      (NOL) <> ""
         [M:SSL1]NBSLO    (NOL)   = 1
      Endif
   Endif
   If dim([M:SSL1]SERNUM) > 0
      [M:SSL1]SERNUM      (NOL)   = [M:SSL1]SERNUMORI   (NOL)
   Endif
   If dim([M:SSL1]SERNUMF) > 0
      [M:SSL1]SERNUMF     (NOL)   = [M:SSL1]SERNUMORI   (NOL)
   Endif
   If dim([M:SSL1]PALNUM) > 0
      [M:SSL1]PALNUM      (NOL)   = [M:SSL1]PALNUMORI   (NOL)
   Endif
   If dim([M:SSL1]CTRNUM) > 0
      [M:SSL1]CTRNUM      (NOL)   = [M:SSL1]CTRNUMORI   (NOL)
   Endif
#                                                                                         # hcb 111781 deb
   If dim([M:SSL1]ECCVALMAJ)>0
      [M:SSL1]ECCVALMAJ(NOL) = [M:SSL1]ECCVALMAJORI(NOL)
      [M:SSL1]ECCVALMIN(NOL) = [M:SSL1]ECCVALMINORI(NOL)
      [M:SSL1]ECCSAIFLG(NOL) = [M:SSL1]ECCSAIFLGORI(NOL)
   Endif
#                                                                                         # hcb 111781 fin

   Default Mask [SSL1]
   Call INIZONENT([M:SSL1]ITMREF(NOL),"SSL1",[M:SSL1]STOFCY,"",0,"",NOL,
&                 [M:SSL1]TRSTYP(NOL),[M:SSL1]TRSCOD(NOL),[M:SSL1]VCRNUM(NOL),
&                 1,0) From STKECR

   Call INIT_SSL1(NOL)       From TRTSSLA

   Affzo [M:SSL1]25

# il faut activer les zones de cle sur la ligne vide ....

   NOL = [M:SSL1]NBLIG
   Gosub ACT_RUB_CLE From TRTSSLA

Endif
Return

########################################################################
# MAJ_LIGNE_DOCUMENT          Mise à jour des quantités sortie SAISTOENT
########################################################################
$MAJ_LIGNE_DOCUMENT
# Vérifie que le coefficient UC/US peut être modifié,
# que le coef est unique (>0)
# et que l'unité est unique
[M:SSL1]QTYSTU(LLIGDOC) = LQTYSTU
If  LCOEF>0 & LPCU<>""
    [M:SSL1]PCU(LLIGDOC)       = LPCU
    [M:SSL1]PCUSTUCOE(LLIGDOC) = LCOEF
    [M:SSL1]QTYPCU(LLIGDOC)    = LQTYSTU / LCOEF
Else    # Met tout en US
    [M:SSL1]PCU(LLIGDOC)       = [M:SSL1]STU(LLIGDOC)
    [M:SSL1]PCUSTUCOE(LLIGDOC) = 1
    [M:SSL1]QTYPCU(LLIGDOC)    = LQTYSTU
Endif
Affzo [M:SSL1]QTYSTU(LLIGDOC), PCU(LLIGDOC), QTYPCU(LLIGDOC), PCUSTUCOE(LLIGDOC)

Return

########################################################################
# GES_ITM                      affichage rubriques selon gestion article
########################################################################
$GES_ITM
#----- Pas de gestion lot -----#
If [F:ITM]LOTMGTCOD = 1
   If dim([M:SSL1]LOT) > 0
      Raz   [M:SSL1]LOT(LLIG)
      Grizo [M:SSL1]LOT(LLIG)
   Endif
   If dim([M:SSL1]BPSLOT) > 0
      Raz   [M:SSL1]BPSLOT(LLIG)
      Grizo [M:SSL1]BPSLOT(LLIG)
   Endif
Endif

#----- Pas de gestion sous lot -----#
If [F:ITM]LOTMGTCOD<>4
   If dim([M:SSL1]SLO) > 0
      Raz   [M:SSL1]NBSLO(LLIG)
      Raz   [M:SSL1]SLO(LLIG)
      Grizo [M:SSL1]NBSLO(LLIG)
      Grizo [M:SSL1]SLO(LLIG)
   Endif
Endif

#--- Issue 97594
#----- Pas de gestion serie -----#
#If [F:ITM]SERMGTCOD<>3
#   If dim([M:SSL1]SERNUM) > 0
#      Raz   [M:SSL1]SERNUM(LLIG)
#      Raz   [M:SSL1]SERNUMF(LLIG)
#      Grizo [M:SSL1]SERNUM(LLIG)
#      Grizo [M:SSL1]SERNUMF(LLIG)
#   Endif
#Endif
If dim([M:SSL1]SERNUM) > 0
   If [F:ITM]SERMGTCOD<2
      Raz   [M:SSL1]SERNUM(LLIG)
      Raz   [M:SSL1]SERNUMF(LLIG)
   Elsif [F:ITM]SERMGTCOD<>3
      Grizo [M:SSL1]SERNUM(LLIG)
      Grizo [M:SSL1]SERNUMF(LLIG)
   Endif
Endif
#---

#----- Pas de gestion d'emplacement -----#
If [F:ITF]LOCMGTCOD<2
   If dim([M:SSL1]LOCTYP) > 0
      Raz   [M:SSL1]LOCTYP(LLIG)
      Grizo [M:SSL1]LOCTYP(LLIG)
   Endif
   If dim([M:SSL1]LOC) > 0
      Raz   [M:SSL1]LOC(LLIG)
      Grizo [M:SSL1]LOC(LLIG)
   Endif
   If dim([M:SSL1]WRH) > 0
      Raz   [M:SSL1]WRH(LLIG)
      Grizo [M:SSL1]WRH(LLIG)
   Endif
Endif
Return

########################################################################
# INI_GESLOT                                       initialisation GESLOT
########################################################################
$INI_GESLOT
If dim([M:SSL1]LOT) > 0              # hcb 41379
   If [M:SSL1]LOT(LLIG) <> ""
      Return
   Endif
Endif                                # hcb 41379
If [M:SSL1]GESLOT(LLIG) <> ""
    Return
Endif
If [F:ITM]LOTCOU = ""
   If [F:SRU]LOTSUPINH=3 & GSTKCPT(9)<>""
      [M:SSL1]GESLOT(LLIG)    = "V"
   Else
      If [F:ITM]LOTMGTCOD = 2
         [M:SSL1]GESLOT(LLIG) = "B"
      Endif
   Endif
Else
  [M:SSL1]GESLOT(LLIG)        = "C"
Endif

Return

########################################################################
# CTL_STOENT      Controle que stocou soit identique dans l ecran STOENT
########################################################################
$CTL_STOENT
If [M:ENT]PCUTOENT = [M:SSL1]PCUORI(LLIGDOC)
   If [M:ENT]PECQTY > [M:SSL1]QTYPCUORI(LLIGDOC)
      Call ERREUR(mess(29,184,1)) From GESECRAN    # quantité saisie superieur à la quantité à ranger
      mkstat = 2
      Return
   Endif
Else
   If [M:ENT]PECQTY > [M:SSL1]QTYSTUORI(LLIGDOC)
      Call ERREUR(mess(29,184,1)) From GESECRAN    # quantité saisie superieur à la quantité à ranger
      mkstat = 2
      Return
   Endif
Endif

For I = 0 To [M:ENT]NBLIG-1
[M:ENT]STOCOU   (I) =  [M:SSL1]STOCOU(LLIGDOC)
Next I
Return

########################################################################
# AB_TRT                                       Abandon de la transaction
########################################################################
$AB_TRT
Rollback
Return

########################################################################
# TRT_ORIGINE_TRSCOD                            recherche TRSCOD origine
########################################################################
$TRT_ORIGINE_TRSCOD
Local Char    WTRSCOD(3)
Local Char    WBPRNUM(GLONBPR)           # hcb v6
Local Integer WBETCPY
Raz WTRSCOD
Raz WBPRNUM
Case [F:SRG]TRSTYP
     When  1 : Gosub LEC_ENTREE_DIVERSE            # entrée diverse #
     When  3 : Gosub LEC_RECEPTION                 # reception      #
     When  5 : Gosub LEC_DECLARATION_PRODUCTION    # declaration production
     When  7 : Gosub LEC_TRANSFERT                 # changement emplacement
     When  8 : Gosub LEC_QUALITE                   # controle qualité
     When 12 : Gosub LEC_RETOUR                    # retour         #
     When 14 : Gosub LEC_TRANSFERT                 # reception transfert inter site
     When 16 : Gosub LEC_TRANSFERT                 # reception sous traitance
     When 19 : Return                              # reintegration stock
Endcase

Default File [SRG]
Return
# hcb std
$LEC_RECEPTION
If clalev([F:PTH])=0  Local File PRECEIPT  [PTH]  : Endif
If [F:PTH]PTHNUM <> [F:SRG]VCRNUM
   Read [PTH]PTH0=[F:SRG]VCRNUM
   If fstat
      Raz [F:PTH]
   Endif
Endif
If dim([F:PTH]TRSCOD) >0
   WTRSCOD =  [F:PTH]TRSCOD
Endif
WBPRNUM = [F:PTH]BPSNUM
WBETCPY = [F:PTH]BETCPY
Return

$LEC_RETOUR
If clalev ([F:SRH]) <= 0 : Local File SRETURN    [SRH] : Endif

If [F:SRH]SRHNUM <> [F:SRG]VCRNUM
   Read [SRH]SRH0=[F:SRG]VCRNUM
   If fstat
      Raz [F:SRH]
   Endif
Endif
If dim([F:SRH]TRSCOD) >0
   WTRSCOD =  [F:SRH]TRSCOD
Endif
WBPRNUM =  [F:SRH]BPCORD
WBETCPY =  [F:SRH]BETCPY

Return

$LEC_TRANSFERT
If clalev ([F:SGH]) <= 0 : Local File SCHGH   [SGH] : Endif

If [F:SGH]VCRNUM <> [F:SRG]VCRNUM
   Read [SGH]SGH0=[F:SRG]VCRNUM
   If fstat
      Raz [F:SGH]
   Endif
Endif
WTRSCOD =  [F:SGH]TRSCOD
WBETCPY =  [F:SGH]BETCPY

Return

$LEC_QUALITE
If clalev ([F:QLH]) <= 0 : Local File STOQLYH  [QLH] : Endif
If [F:QLH]VCRNUM <> [F:SRG]VCRNUM | [F:QLH]VCRTYP <> 28
   Read [QLH] QLH0=28;[F:SRG]VCRNUM
   If fstat
      Raz [F:QLH]
   Endif
Endif
WTRSCOD =  [F:QLH]TRSCOD
Return


$LEC_DECLARATION_PRODUCTION
If clalev ([F:MTK]) <= 0 : Local File MFGHEADTRK    [MTK] : Endif

If [F:MTK]MFGTRKNUM <> [F:SRG]VCRNUM
   Read [MTK]MTK0=[F:SRG]VCRNUM
   If fstat
      Raz [F:MTK]
   Endif
Endif
If dim([F:MTK]TRSCOD) >0
   WTRSCOD =  [F:MTK]TRSCOD
Endif
Return

$LEC_ENTREE_DIVERSE
If clalev ([F:SMH]) <= 0 : Local File SMVTH    [SMH] : Endif
If [F:SMH]VCRNUM <> [F:SRG]VCRNUM | [F:SMH]VCRTYP <> [F:SRG]VCRTYP
   Read [SMH] SMH0=[F:SRG]VCRTYP;[F:SRG]VCRNUM
   If fstat
      Raz [F:SMH]
   Endif
Endif
If dim([F:SMH]TRSCOD) >0
   WTRSCOD =  [F:SMH]TRSCOD
Endif
Return
# hcb std

########################################################################
#  Sous programmes                                A C T I O N S  boutons
########################################################################
########################################################################
# ACT_SELSSL          bouton RECHERCHE      remplisssage du tableau SSL1
# ACT_LISSSL   bouton LISTE    affectation d un numéro de liste à ranger
# ACT_ENRSSL         bouton ENREGISTREMENT enregistrement liste à ranger
# ACT_VALSSL  bouton VALIDATION  réalisation  changements d emplacements
# ACT_TRISSL bouton TRI            Tri du tableau SSL1 selon parametrage

########################################################################
Subprog ACT_SELSSL
Gosub DECOCHAGE_SSL1

Effzo [M:SSL1]25
REP = ""
GREP = ""

Local Char    CRITERE(255)
Local Char    CRITERE0(255)
Local Char    CRITERE1(255)
Local Char    CRITERE2(255)
Local Char    CRITERE3(255)
Local Char    CRITERE4(255)
Local Char    FORMULE1(250)

Local Date    TODAY : TODAY = date$

Local Integer NOL
Local Integer I
I = 0

# Verif sert à controler l existance de lenregistrement dans le tableau 1 non verif  2 verif
Local Integer VERIF
VERIF = 1



# filtre bloc filtre
Gosub LOAD_FILTER
# filtre bloc selection / date
Gosub LOAD_FILTER2
# filtre bloc selection / piece
Gosub LOAD_FILTER4
# filtre bloc borne debut/fin
Gosub LOAD_FILTER3

Raz GLECSTOSRG          # hcb 52838

nolign = 1
If [M:SSL1]SRGPPSSTR <> ""
   Filter [SRG]  Where evalue(CRITERE0)
&                Order By Key SRG4

   Gosub LECTURE_STOSRG

   If [M:SSL1]LSTWIOFLG = 1
      Goto TRI_SSL1
   Endif
Endif


If CRITERE1  = "" CRITERE1  = "1=1"  : Endif
If CRITERE2  = "" CRITERE2  = "1=1"  : Endif
If CRITERE3  = "" CRITERE3  = "1=1"  : Endif
If CRITERE4  = "" CRITERE4  = "1=1"  : Endif

# analyse présence formule de sélection
If [M:SSL1]FORMULE  = ""
    FORMULE1 = "1=1"
Else
    Read [F:TFO]TFO0=17;[M:SSL1]FORMULE
    If fstat
        FORMULE1 = "1=1"
    Else
        FORMULE1 = [F:TFO]FORFOR
    Endif
Endif
#                                                                    hcb 52838 deb
If (instr(1,FORMULE1,"ITF]")) | (instr(1,FORMULE1,"ITM]"))
   GLECSTOSRG = 1
   Link [SRG] With [ITF]ITF0=[F:SRG]ITMREF;[F:SRG]STOFCY, [ITM]ITM0=[F:SRG]ITMREF As [SRGX]
&             Where evalue(CRITERE1) & evalue(CRITERE2)& evalue(CRITERE3) & evalue(CRITERE4) & evalue(FORMULE1)

Else
   Raz GLECSTOSRG
#                                                                    hcb 52838 fin

# RECHERCHE meilleur cle pour optimisation
   Gosub RECH_CLE

   Case WCLE
     When 0 :
        Filter [SRG]  Where evalue(CRITERE1)&evalue(CRITERE2)&evalue(CRITERE3)&evalue(CRITERE4)&
&                           evalue(FORMULE1)
&                     Order By Key SRG0
     When 1 :
        Filter [SRG]  Where evalue(CRITERE1)&evalue(CRITERE2)&evalue(CRITERE3)&evalue(CRITERE4)&
&                           evalue(FORMULE1)
&                     Order By Key SRG1
     When 2 :
        Filter [SRG]  Where evalue(CRITERE1)&evalue(CRITERE2)&evalue(CRITERE3)&evalue(CRITERE4)&
&                           evalue(FORMULE1)
&                     Order By Key SRG2
     When 3 :
        Filter [SRG]  Where evalue(CRITERE1)&evalue(CRITERE2)&evalue(CRITERE3)&evalue(CRITERE4)&
&                           evalue(FORMULE1)
&                     Order By Key SRG3

     When 4 :
        Filter [SRG]  Where evalue(CRITERE1)&evalue(CRITERE2)&evalue(CRITERE3)&evalue(CRITERE4)&
&                           evalue(FORMULE1)
&                     Order By Key SRG4

   Endcase

Endif                                                                                          # hcb 52383

Gosub LECTURE_STOSRG

$TRI_SSL1

If [M:SSL1]NBLIG > 0
   Gosub TRI_TAB
Endif
Actzo [M:SSL1]25                                # hcb 114605

End
########################################################################
# ACT_LISSSL   bouton LISTE    affectation d un numéro de liste à ranger
########################################################################
Subprog ACT_LISSSL
Local Integer WRET
Local Integer I
Local Integer WCOCHAGE


For I = 0 To [M:SSL1]NBLIG-1
    If [M:SSL1]COCHAGE (I) = 2 & [M:SSL1]SRGPPS (I) = ""
       WCOCHAGE = 1
       Break
    Endif
Next I

If WCOCHAGE = 1
   Call DEBTRANS From GLOCK
   Trbegin [SRG]
   Raz [M:SSL1]SRGPPSEND
   Call NUMERO(GSTKCPT(15),[M:SSL1]STOFCY,date$,[M:SSL1]ITMREF(I),[M:SSL1]SRGPPSEND,WRET) From SUBANM
   If WRET = 1
      GERR = 1
      GMESSAGE= mess(842,196,1)
   Endif
   If WRET = 2
      GERR = 1
      GMESSAGE= mess(30,196,1)
   Endif
   If WRET = 0
      Commit
   Else
      Rollback
      End
   Endif

   For I = 0 To [M:SSL1]NBLIG-1
       If [M:SSL1]COCHAGE (I) = 2 & [M:SSL1]SRGPPS (I) = ""
          [M:SSL1]SRGPPS (I)= [M:SSL1]SRGPPSEND
       Endif
   Next I
Endif
Affzo [M:SSL1]

End


########################################################################
# ACT_ENRSSL         bouton ENREGISTREMENT enregistrement liste à ranger
########################################################################
Subprog ACT_ENRSSL
Local Integer I
# enregistrement impossible si enregistrements cochés sans liste à ranger
#                sauf si liste avant renseigné (mise à blanc du numero)

Local Integer WOK
WOK = 0
For I = 0 To [M:SSL1]NBLIG-1
    If [M:SSL1]COCHAGE(I) = 2 & [M:SSL1]SRGPPS(I) = "" & [M:SSL1]SRGPPS_AV(I) = ""
       WOK = 9
       Break
    Endif
Next I
If WOK = 9
      GERR = 1
      GMESSAGE=mess(15,184,1)    # Enregistrement(s) coché(s) sans liste à ranger !
      Return
Endif

Call DEBTRANS From GLOCK
Trbegin [SRG]
I = 0
For I = 0 To [M:SSL1]NBLIG-1
    If [M:SSL1]COCHAGE(I) = 2
       Call TRT_STOSRGW_ENRSSL (I)                              # delete et ecriture STOSRGW
       If GOK < 1
          Gosub AB_TRT
          End
       Endif
       Call MAJ_SRG_SRGPPS (I,[M:SSL1]SRGPPS(I))   # reecriture STOSRG avec new liste et staflg à 1
          If GOK < 1
             Gosub AB_TRT
             End
          Endif
      [M:SSL1]CREFLG(I) = 1

    Endif

$NEXTI_ENRSSL
Next I

Commit
REP = ""
GREP = ""



Local Integer LRET
Call STKDELRES(0,[M:SSL1]STOFCY,"",LRET) From STKLOC

# ligne suivante supprimée
# si reactivée il faut faire attention car l impression fait appel à cette action
# il faudra dans ce cas restructurer cette action en 2 parties
#Gosub DEBUT_SAISSL
End

########################################################################
# ACT_VALSSL  bouton VALIDATION  réalisation  changements d emplacements
########################################################################
Subprog ACT_VALSSL

Call OUVRE_TRACE(mess(177,198,1)) From LECFIC

Local Decimal LQTA
Local Decimal LSHT
Local Integer LNBR
Local Integer LNBJ
Local Integer LRET
Local Integer NOL
Local Shortint WRET
Local Integer I
WRET = 0
LRET = 0

#----- Relecture transaction de saisie  -----#
If [F:SRT]SRTTYP <> 5 | [F:SRT]SRTNUM <> GSSLNUM                   # hcb 50197
   Read [SRT]SRT0=5;GSSLNUM : If fstat Raz [F:SRT] : Endif
Endif


Call CTLSTOENT( "SSL1", "QTYSTU", [M:SSL1]NBLIG, LRET ) From STKECR
If LRET = 0
   End
Endif
For NOL = 0 To [M:SSL1]NBLIG-1
    LRET = 1
    If [M:SSL1]COCHAGE(NOL) = 2
       If [M:SSL1]PCU(NOL) = [M:SSL1]PCUORI(NOL)
          If [M:SSL1]QTYPCU(NOL) > [M:SSL1]QTYPCUORI(NOL)
             LRET = 0
             Break
          Endif
       Else
          If [M:SSL1]QTYSTU(NOL) > [M:SSL1]QTYSTUORI(NOL)
             LRET = 0
             Break
          Endif
       Endif


       For I=0 To [M:ENTW]NBLIG-1
   # La ligne de l'écran de travail ne concerne pas cette ligne de document
           #--- Issue 108167 by TS
           #If [M:ENTW]WSTOSEQ(I)<>[M:SSL1]WLOCSEQ(NOL) Goto ORI_STOENTW2 Endif
           If [M:ENTW]WSTOSEQ(I)<>[M:SSL1]WSTOSEQ(NOL) Goto ORI_STOENTW2 Endif
           #---
               Call STKCTREMP([M:SSL1]WLOCSEQ(NOL),[M:SSL1]TRSTYP(NOL),[M:SSL1]TRSCOD(NOL),
&                   [M:SSL1]STOFCY,[M:SSL1]ITMREF(NOL),[M:ENTW]PCU(I),
&                   [M:ENTW]QTYPCU(I),[M:ENTW]STA(I),[M:ENTW]LOCTYP(I),
&                   [M:ENTW]LOC(I),"",0,WRET,GBIDD1,"","",[M:ENTW]WRH(I)) From STKLOC
               If WRET<>0 Break 2 Endif
$ORI_STOENTW2
       Next I

   Endif
Next NOL

If WRET <> 0
   Call ERREUR(GMESSAGE) From GESECRAN
   End
Endif
If LRET =  0
   Call ERREUR(mess(61,100,1)-num$(NOL)-":"-mess(29,184,1)) From GESECRAN
   End
Endif
# quantite ranger > quantite à ranger

Call DEBTRANS From GLOCK
Trbegin [SRG]

For NOL = 0 To [M:SSL1]NBLIG-1
    If [M:SSL1]COCHAGE(NOL) = 2
# Initialisation de l'en-tête
       Raz [M:STW]
       [M:STW]STOFCY     = [M:SSL1]STOFCY      # Site
       [M:STW]TRSTYP     = 22                 # changement emplacement  (M.704)
       [M:STW]VCRTYP     = [M:SSL1]VCRTYP   (NOL) # Type pièce à ranger
       [M:STW]VCRNUM     = [M:SSL1]VCRNUM   (NOL) # Numéro pièce à ranger
       [M:STW]VCRLIN     = [M:SSL1]VCRLIN   (NOL) # Numero ligne pièce à ranger
       [M:STW]VCRTYPORI  = [M:SSL1]VCRTYPORI(NOL) # Type pièce à ranger
       [M:STW]VCRNUMORI  = [M:SSL1]VCRNUMORI(NOL) # Numéro pièce à ranger
       [M:STW]VCRLINORI  = [M:SSL1]VCRLINORI(NOL) # Numero ligne pièce à ranger
       [M:STW]ITMREF     = [M:SSL1]ITMREF   (NOL) # Article
       [M:STW]MVTDES     = [M:SSL1]MVTDES   (NOL) # Désignation mouvement
       [M:STW]PRIORDH    = 0
       [M:STW]PJT        = [M:SSL1]PJT      (NOL) # Affaire      # hcb 57642
       [M:STW]TRSFAM     = ""
       [M:STW]IPTDAT     = [M:SSL1]IPTDAT   (NOL) #Date IMPUTATION
       [M:STW]CCECOD     = "STJEND"            # CODE section analytique stock entrée
       [M:STW]CUR        = GLOCALDEV
       [M:STW]BPRNUM     = [M:SSL1]BPRNUM   (NOL)
       [M:STW]BETCPY     = [M:SSL1]BETCPY   (NOL)
       #--- Bug 74720
       If [M:STW]VCRTYP=6
         #--- Bug 62137
         Filter [STJ] Where STOFCY=[M:STW]STOFCY & VCRTYP=[M:STW]VCRTYP
&                         & VCRNUM=[M:STW]VCRNUM & VCRLIN=[M:STW]VCRLIN & ITMREF=[M:STW]ITMREF
&                         & TRSTYP<>29                                  : #--- Issue 115206
         Read [STJ]STJ1 First
         If !fstat [M:STW]ENTCOD=[F:STJ]ENTCOD Endif
         Filter [STJ]
         #---
       #--- Bug 74720
       Endif

       Call ALISTOWORK( 2, [M:SSL1]WSTOSEQ(NOL), LQTA, LSHT,LNBR,LNBJ, LRET ) From STKINT

        #Mise à jour des stock
        #Mise à jour enregistrement STOSRG
       If LRET=0
          Call MAJ_STOCK From STKMAJ
       Endif
       If LRET <> 0 | GOK < 1
          LRET = 1
          Break
       Endif
        #Suppression enregistrement STOSRGW + enregistrement TABWIPSTO
       Gosub DELETE_STOSRGW
       If GOK < 1
          LRET = 1
          Break
       Endif
    Endif
Next NOL

If LRET <> 0
   Gosub AB_TRT
   Goto SUITE1
Endif

Commit

 Local Integer LRET
#--- Impression des étiquettes ----#
If [F:SRT]PRNCOD1 > 1
    Local Char WPARAM(GLONVCR)(1..5) , WVALEUR(10)
    Raz WPARAM
    WPARAM(1) = [M:SSL1]STOFCY
    WPARAM(5) = "SSL1"
    Call TRAITE_CHAR(WVALEUR,WPARAM,"ISTOLBE","SUBSLP","",4,"SPESLP") From GTRAITE
Endif
#---- Régularisation des mouvements et alloc -----#
Call REGFROMENT( 0, "SSL1", "[M:SSL1]COCHAGE(I)=2", "ITMREF", [M:SSL1]STOFCY ) From TRTSHTCOM

Gosub DEBUT_SAISSL
$SUITE

Call STKDELRES(0,[M:SSL1]STOFCY,"",LRET) From STKLOC

$SUITE1

Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
Call OUVRE_TRACE(mess(177,198,1)) From LECFIC

End

########################################################################
# ACT_TRISSL bouton TRI            Tri du tableau SSL1 selon parametrage
########################################################################
$ACT_TRISSL
Gosub TRI_TAB
Return

########################################################################
# PASSAI
########################################################################
Subprog PASSAI


# si on viens du SGW (donc une saise à deja eu lieu) pas de modif possible = clic droit
If [M:SSL1]SRGPPS_AV(nolign-1)<> ""
   mkstat=2
   End
Endif

If [M:SSL1]CREFLG(nolign-1) <> 0
   mkstat = 2
   End
Endif

If [M:SSL1]MODFLG(nolign-1) = 2
   mkstat = 2
   End
Endif

If [M:SSL1]ITMREF(nolign-1) = ""
   mkstat = 2
   End
Endif

Local Integer LLIG
Local Integer LRET

LLIG = nolign-1
LRET = 0

If [M:SSL1]COCHAGE           (nolign-1) <> 2
   Default Mask [SSL1]
   Call INIZONENT([M:SSL1]ITMREF(nolign-1),"SSL1",[M:SSL1]STOFCY,"",0,"",
&                 (nolign-1),[M:SSL1]TRSTYP(nolign-1),[M:SSL1]TRSCOD(nolign-1),
&                 [M:SSL1]VCRNUM(nolign-1),1,0) From STKECR

#RUBRIQUE destination par défaut
   [M:SSL1]PCU            (nolign-1)   = [M:SSL1]PCUORI      (nolign-1)
   [M:SSL1]QTYPCU         (nolign-1)   = [M:SSL1]QTYPCUORI   (nolign-1)
   [M:SSL1]QTYSTU         (nolign-1)   = [M:SSL1]QTYSTUORI   (nolign-1)
   [M:SSL1]PCUSTUCOE      (nolign-1)   = [M:SSL1]PCUSTUCOEO  (nolign-1)
   If dim([M:SSL1]LOT) > 0
      [M:SSL1]LOT         (nolign-1)   = [M:SSL1]LOTORI      (nolign-1)
   Endif
   If dim([M:SSL1]BPSLOT) > 0
      [M:SSL1]BPSLOT      (nolign-1)   = [M:SSL1]BPSLOTORI   (nolign-1)
   Endif
   If dim([M:SSL1]SLO) > 0
      [M:SSL1]SLO         (nolign-1)   = [M:SSL1]SLOORI      (nolign-1)
      If [M:SSL1]SLO      (nolign-1) <> ""
         [M:SSL1]NBSLO    (nolign-1)   = 1
      Endif
   Endif
   If dim([M:SSL1]SERNUM) > 0
      [M:SSL1]SERNUM      (nolign-1)   = [M:SSL1]SERNUMORI   (nolign-1)
   Endif
   If dim([M:SSL1]SERNUMF) > 0
      [M:SSL1]SERNUMF     (nolign-1)   = [M:SSL1]SERNUMORI   (nolign-1)
   Endif
   If dim([M:SSL1]PALNUM) > 0
      [M:SSL1]PALNUM      (nolign-1)   = [M:SSL1]PALNUMORI   (nolign-1)
   Endif
   If dim([M:SSL1]CTRNUM) > 0
      [M:SSL1]CTRNUM      (nolign-1)   = [M:SSL1]CTRNUMORI   (nolign-1)
   Endif
#                                                                                         # hcb 111781 deb
   If dim([M:SSL1]ECCVALMAJ)>0
      [M:SSL1]ECCVALMAJ(nolign-1) = [M:SSL1]ECCVALMAJORI(nolign-1)
      [M:SSL1]ECCVALMIN(nolign-1) = [M:SSL1]ECCVALMINORI(nolign-1)
      [M:SSL1]ECCSAIFLG(nolign-1) = [M:SSL1]ECCSAIFLGORI(nolign-1)
   Endif
#                                                                                         # hcb 111781 fin

   Call INIT_SSL1(nolign-1)       From TRTSSLA
   Call STKFILLENTW([M:SSL1]STOFCY,"SSL1",[M:SSL1]TRSTYP(nolign-1),[M:SSL1]TRSCOD(nolign-1),"",[M:SSL1]VCRTYP(nolign-1),[M:SSL1]IPTDAT(nolign-1),nolign-1,[M:SSL1]NBLIG,"SRT") From STKENT
   GOUVENT = 0
   GOUVLOT = 0
   [M:SSL1]COCHAGE           (nolign-1) = 2
   Affzo [M:SSL1]SRGPPS      (nolign-1)
   Affzo [M:SSL1]WSTOFLG     (nolign-1)
   Affzo [M:SSL1]PCU         (nolign-1)
   Affzo [M:SSL1]QTYPCU      (nolign-1)
   Affzo [M:SSL1]QTYSTU      (nolign-1)
   Affzo [M:SSL1]PCUSTUCOE   (nolign-1)
   If dim([M:SSL1]LOT) > 0
      Affzo [M:SSL1]LOT         (nolign-1)
   Endif
   If dim([M:SSL1]BPSLOT) > 0
      Affzo [M:SSL1]BPSLOT      (nolign-1)
   Endif
   If dim([M:SSL1]SLO) > 0
      Affzo [M:SSL1]SLO         (nolign-1)
      Affzo [M:SSL1]NBSLO       (nolign-1)
   Endif
   If dim([M:SSL1]SERNUM) > 0
      Affzo [M:SSL1]SERNUM      (nolign-1)
   Endif
   If dim([M:SSL1]PALNUM) > 0
      Affzo [M:SSL1]PALNUM      (nolign-1)
   Endif
   If dim([M:SSL1]CTRNUM) > 0
      Affzo [M:SSL1]CTRNUM      (nolign-1)
   Endif
   If dim([M:SSL1]SERNUMF) > 0
      Affzo [M:SSL1]SERNUMF     (nolign-1)
   Endif
   Affzo [M:SSL1]STA            (nolign-1)
   If dim([M:SSL1]LOCTYP) > 0
      Affzo [M:SSL1]LOCTYP      (nolign-1)
   Endif
   If dim([M:SSL1]LOC) > 0
      Affzo [M:SSL1]LOC         (nolign-1)
   Endif
   If dim([M:SSL1]WRH) > 0
      Affzo [M:SSL1]WRH         (nolign-1)
   Endif
   Affzo [M:SSL1]COCHAGE        (nolign-1)
# affzo pour la colorisation
   Affzo [M:SSL1]ITMREF         (nolign-1)
Endif
End

########################################################################
# ACT_INCSSL  bouton TOUT INCLURE
########################################################################
Subprog ACT_INCSSL
Local Integer  NOL
Local Shortint WRET
Local Shortint WAFF
Raz WAFF
Raz NOL
#message opération en cours ...
Call TEMPON("O") From GESECRAN


For NOL = 0 To [M:SSL1]NBLIG-1
    If [M:SSL1]COCHAGE(NOL) <> 2
       Call MAJ_SRG_STAFLG(NOL,2)  From TRTSSLA
       If GOK > 0
          Call INIZONENT([M:SSL1]ITMREF(NOL),"SSL1",[M:SSL1]STOFCY,"",0,"",(NOL),[M:SSL1]TRSTYP(NOL),[M:SSL1]TRSCOD(NOL),[M:SSL1]VCRNUM(NOL),1,0) From STKECR
#RUBRIQUE destination par défaut
          [M:SSL1]PCU          (NOL)   = [M:SSL1]PCUORI      (NOL)
          [M:SSL1]QTYPCU       (NOL)   = [M:SSL1]QTYPCUORI   (NOL)
          [M:SSL1]QTYSTU       (NOL)   = [M:SSL1]QTYSTUORI   (NOL)
          [M:SSL1]PCUSTUCOE    (NOL)   = [M:SSL1]PCUSTUCOEO  (NOL)
          If dim([M:SSL1]LOT) > 0
             [M:SSL1]LOT       (NOL)   = [M:SSL1]LOTORI      (NOL)
          Endif
          If dim([M:SSL1]BPSLOT) > 0
             [M:SSL1]BPSLOT    (NOL)   = [M:SSL1]BPSLOTORI   (NOL)
          Endif
          If dim([M:SSL1]SLO) > 0
             [M:SSL1]SLO       (NOL)   = [M:SSL1]SLOORI      (NOL)
              If [M:SSL1]SLO   (NOL) <> ""
                 [M:SSL1]NBSLO (NOL)   = 1
             Endif
          Endif
#                                                                                         # hcb 111781 deb
         If dim([M:SSL1]ECCVALMAJ)>0
            [M:SSL1]ECCVALMAJ(NOL) = [M:SSL1]ECCVALMAJORI(NOL)
            [M:SSL1]ECCVALMIN(NOL) = [M:SSL1]ECCVALMINORI(NOL)
            [M:SSL1]ECCSAIFLG(NOL) = [M:SSL1]ECCSAIFLGORI(NOL)
         Endif
#                                                                                         # hcb 111781 fin

          If dim([M:SSL1]SERNUM) > 0
             [M:SSL1]SERNUM    (NOL)   = [M:SSL1]SERNUMORI   (NOL)
          Endif
          If dim([M:SSL1]SERNUMF) > 0
             [M:SSL1]SERNUMF   (NOL)   = [M:SSL1]SERNUMORI   (NOL)
          Endif
          If dim([M:SSL1]PALNUM) > 0
             [M:SSL1]PALNUM    (NOL)   = [M:SSL1]PALNUMORI   (NOL)
          Endif
          If dim([M:SSL1]CTRNUM) > 0
             [M:SSL1]CTRNUM    (NOL)   = [M:SSL1]CTRNUMORI   (NOL)
          Endif

          Call INIT_SSL1(NOL)       From TRTSSLA
          Call OUVENT([M:SSL1]STOFCY,"SSL1",[M:SSL1]TRSTYP(NOL),[M:SSL1]TRSCOD(NOL),"",[M:SSL1]VCRTYP(NOL),[M:SSL1]IPTDAT(NOL),NOL,[M:SSL1]NBLIG,"SRT","",WRET) From STKENT

          If [M:SSL1]WSTOFLG (NOL) = 0 | GOUVLOT > 1
             Call MAJ_SRG_STAFLG(NOL,1)  From TRTSSLA
             If [M:SSL1]SRGPPS_AV(NOL) = ""
                [M:SSL1]SRGPPS(NOL)    = ""
                Raz [M:SSL1]SRGPPS      (NOL)
                Raz [M:SSL1]PCU         (NOL)
                Raz [M:SSL1]QTYPCU      (NOL)
                Raz [M:SSL1]QTYSTU      (NOL)
                Raz [M:SSL1]PCUSTUCOE   (NOL)
                Raz [M:SSL1]WSTOFLG     (NOL)
               [M:SSL1]MODFLG(NOL)    = 1
             Endif
             If dim([M:SSL1]LOT) > 0
                Raz [M:SSL1]LOT         (NOL)
             Endif
             If dim([M:SSL1]BPSLOT) > 0
                Raz [M:SSL1]BPSLOT      (NOL)
             Endif
             If dim([M:SSL1]SLO) > 0
                Raz [M:SSL1]SLO         (NOL)
                Raz [M:SSL1]NBSLO       (NOL)
             Endif
             If dim([M:SSL1]SERNUM) > 0
                Raz [M:SSL1]SERNUM      (NOL)
             Endif
             If dim([M:SSL1]SERNUMF) > 0
                Raz [M:SSL1]SERNUMF     (NOL)
             Endif
             If dim([M:SSL1]PALNUM) > 0
                Raz [M:SSL1]PALNUM      (NOL)
             Endif
             If dim([M:SSL1]CTRNUM) > 0
                Raz [M:SSL1]CTRNUM      (NOL)
             Endif
             Raz [M:SSL1]STA            (NOL)
             If dim([M:SSL1]LOCTYP) > 0
                Raz [M:SSL1]LOCTYP      (NOL)
             Endif
             If dim([M:SSL1]LOC) > 0
                Raz [M:SSL1]LOC         (NOL)
             Endif
             If dim([M:SSL1]WRH) > 0
                Raz [M:SSL1]WRH         (NOL)
             Endif
          Else
             WAFF = 1
            [M:SSL1]COCHAGE             (NOL) = 2
            [M:SSL1]MODFLG              (NOL) = 2
            GREP = "M"
          Endif
       Endif
    Endif
Next
#suppression message opération en cours ...
Call TEMPOFF   From GESECRAN

If WAFF = 1
   Affzo [M:SSL1]25
Else
   Call ERREUR(mess(210,184,1)) From GESECRAN   # Aucune ligne complete
Endif
End


##################################################
Subprog ACT_EXCSSL
Local Integer  NOL
Local Shortint WAFF
Raz WAFF
Raz NOL
#message opération en cours ...
Call TEMPON("O") From GESECRAN

For NOL = 0 To [M:SSL1]NBLIG-1
    If [M:SSL1]COCHAGE(NOL) = 2
        Call MAJ_SRG_STAFLG(NOL,1)  From TRTSSLA
        If [M:SSL1]SRGPPS_AV(NOL) = ""
           [M:SSL1]SRGPPS(NOL)    = ""
           Raz [M:SSL1]SRGPPS      (NOL)
           Raz [M:SSL1]PCU         (NOL)
           Raz [M:SSL1]QTYPCU      (NOL)
           Raz [M:SSL1]QTYSTU      (NOL)
           Raz [M:SSL1]PCUSTUCOE   (NOL)
           Raz   [M:SSL1]WSTOFLG   (NOL)
           [M:SSL1]MODFLG(NOL)    = 1
         Endif
         If dim([M:SSL1]LOT) > 0
            Raz [M:SSL1]LOT         (NOL)
         Endif
         If dim([M:SSL1]BPSLOT) > 0
            Raz [M:SSL1]BPSLOT      (NOL)
         Endif
         If dim([M:SSL1]SLO) > 0
            Raz [M:SSL1]SLO         (NOL)
            Raz [M:SSL1]NBSLO       (NOL)
         Endif
#                                                                                         # hcb 111781 deb
         If dim([M:SSL1]ECCVALMAJ)>0
            Raz [M:SSL1]ECCVALMAJ(NOL)
            Raz [M:SSL1]ECCVALMIN(NOL)
            Raz [M:SSL1]ECCSAIFLG(NOL)
         Endif
#                                                                                         # hcb 111781 fin
         If dim([M:SSL1]SERNUM) > 0
            Raz [M:SSL1]SERNUM      (NOL)
         Endif
         If dim([M:SSL1]SERNUMF) > 0
            Raz [M:SSL1]SERNUMF     (NOL)
         Endif
         If dim([M:SSL1]PALNUM) > 0
            Raz [M:SSL1]PALNUM      (NOL)
         Endif
         If dim([M:SSL1]CTRNUM) > 0
            Raz [M:SSL1]CTRNUM      (NOL)
         Endif
         Raz [M:SSL1]STA            (NOL)
         If dim([M:SSL1]LOCTYP) > 0
            Raz [M:SSL1]LOCTYP      (NOL)
         Endif
         If dim([M:SSL1]LOC) > 0
            Raz [M:SSL1]LOC         (NOL)
         Endif
         If dim([M:SSL1]WRH) > 0
            Raz [M:SSL1]WRH         (NOL)
         Endif
         WAFF = 1
        [M:SSL1]COCHAGE             (NOL) = 1
        [M:SSL1]MODFLG              (NOL) = 1
        GREP = "M"
    Endif
Next
#suppression message opération en cours ...
Call TEMPOFF   From GESECRAN

If WAFF = 1
   Affzo [M:SSL1]25
Endif

End

#-------------------------------------------------#
# Actzo ou Grizo [SSL1] des dépôts selon le site  #
#-------------------------------------------------#
$WRH_ETAT
Raz [M:SSL1]WRHGES
# hcb                        61972 deb
If [M]STOFCY<>[F:FCY]FCY
   Read [FCY]FCY0=[M]STOFCY
Endif
#----- Chargement des globales référenciels, comptes et sections de la société -----#
Call GETCPY([F:FCY]FCY,"SRT",5,GSSLNUM) From TRTX3CPT

If GWRHACT <>2
   Return
Endif
# hcb                        61972 fin
[M:SSL1]WRHGES = [F:FCY]WRHGES
If [F:FCY]WRHGES = 2
   Actzo [M:SSL1]WRHE
   Actzo [M:SSL1]WRH
   Actzo [M:SSL1]WRHSTR
   Actzo [M:SSL1]WRHEND
Else
   Grizo [M:SSL1]WRHE
   Grizo [M:SSL1]WRH
   Grizo [M:SSL1]WRHSTR
   Grizo [M:SSL1]WRHEND
   Grizo [M:SSL1]WRHORI
Endif

Return

#-------------------------------------------------#
# Actzo ou Grizo [SSLC] des dépôts selon le site  #
#-------------------------------------------------#
$WRH_ETAT_SSLC
If GWRHACT <>2
   Return
Endif
If [M:SSL1]WRHGES = 2
   Actzo [M:SSLC]WRHSTR
   Actzo [M:SSLC]WRHEND
Else
   Grizo [M:SSLC]WRHSTR
   Grizo [M:SSLC]WRHEND
Endif
Return

########################################################################
# CTR_ITW                                    Controle existence ITMWRH
########################################################################
Subprog CTR_ITW(LITM,LWRH,LRET)
Value    Char     LITM
Value    Char     LWRH
Variable Integer  LRET
Raz LRET
Read [ITW]ITW0=LITM;LWRH
If fstat
   LRET = 2
Endif
End

