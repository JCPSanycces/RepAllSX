#<AdxTL>@(#)0.0.0.0 $Revision$
#EXPORTACIÓN FICHERO FACTURAS PORTUGAL

#LA ESTRUCTURA DEL FICHERO DEBE CONTENER LOS SIGUIENTES CAMPOS:
#
#FECHA DD-MM-YYYY
#Nº FACTURA (ULTIMOS 7 DÍGITOS)
#TIENDA ÚLTIMOS 3 DÍGITOS
#ITMREF
#CANTIDAD
#PRECIO SIN DECIMALES (*100)
#IMPORTE SIN DECIMALES (*100)

#LOS CAMPOS DEBEN DE ESTAR SEPARADOS ***
Local Integer YSTAT
Local Char    YFECZFACPT(8)
Local Char    YCURRNUMFAC(20)
Local Char    YNOMFICH(35)
Local Char    DD(2),MM(2),YYYY(4)

If !clalev([F:ZFPT]) : Local File ZFACPORTUGAL[ZFPT] :Endif
If !clalev([YADI])   : Local File ATABDIV   [YADI]   : Endif  # tablas varias

#LECTURA DEL CONTROL FECHA
Read [F:YADI]CODE=6002;'2'
If !fstat
    YFECZFACPT = [F:YADI]A2
Else
  Call MESSAGE ("Error al leer la fecha de última exportación. Tabla 6002, código 2") From GESECRAN
  End
Endif

If !GSERVEUR
Call OUINON("Exportación de facturas de Portugal. ¿Desea continuar?",[L]YSTAT) From GESECRAN
Else
  [L]YSTAT=2
Endif

If [L]YSTAT=2
  adxifs = chr$(9)
  adxirs = chr$(13)+chr$(10)
  YCURRNUMFAC=""

  For [F:ZFPT] Where [F:ZFPT]FECHAO > YFECZFACPT
    If [F:ZFPT]NUM<>YCURRNUMFAC Then
      If YCURRNUMFAC<>"" Then
        Openo Using [ZEXP] #cierre fichero anterior
      Endif
      YNOMFICH=[F:ZFPT]TIENDA+"FACT"+[F:ZFPT]FACTURA+".txt"
      Openo "E:\EXPORT\FACPORTUGAL\"+YNOMFICH,0 Using [ZEXP]
    Endif

    If [F:ZFPT]FACTURA<>""

    Wrseq [F:ZFPT]FECHA           + adxifs +
&         [F:ZFPT]FACTURA         + adxifs +
&         [F:ZFPT]TIENDA          + adxifs +
&         [F:ZFPT]ITMREF          + adxifs +
&         num$([F:ZFPT]QTY)       + adxifs +
&         num$([F:ZFPT]GROPRI)    + adxifs +
&         num$([F:ZFPT]TOTAL)
&   Using [ZEXP]

    Endif
    YCURRNUMFAC=[F:ZFPT]NUM
  Next
  Openo Using [ZEXP]


  MM = num$(month(date$))
  If len(MM) = 1 : MM = "0" + MM : Endif
  DD = num$(day(date$))
  If len(DD) = 1 : DD= "0" + DD : Endif
  YYYY=num$(year(date$))


  Readlock [F:YADI]CODE=6002;'2'
  If !fstat
      [F:YADI]A2 = YYYY+MM+DD
      Rewrite [F:YADI]
  Endif

  System ESTADO="e:\export\FACPORTUGAL\mover.bat"

  If !GSERVEUR : Infbox "Exportación finalizada" : Endif

Endif

