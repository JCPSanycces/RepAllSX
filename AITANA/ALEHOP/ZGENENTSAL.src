###########################################################
# Fecha creación: 05/06/2018
# Autor: Miguel Angel Pacho
# Versión: 1
# Genera ficheros de entradas y salidas varias para crear listas de ordenación
# Versión: 2 23/01/2020 - Miguel Salvador
##########################################################
# XVT26082020 - PRUEBAS: en ocasiones no se mueve el stock en preparación a MUELLE - A
# XVT28092020 - el stock entrará en MUELLE QA
# XVT29102020 - la entrada devolución ha de cambiar el flag ZFLAGPREP

##########################################################
#**
#* Genera una salida y una entrada varia
#*
#* @param PTYPENT > tipo de entrada
#* @param PNUMENT > número entrada
#*!
Subprog GEN_ENTSAL(PTYPENT, PNUMENT, ZVCRDES)
Value Integer PTYPENT
Value Char    PNUMENT
Value Char    ZVCRDES

##Openo "e:\Sage\X3V11ALEHOP\folders\" + nomap + "\tmp\zgenentsal.tra", -1 Using [XTRA] #xvt26082020.bn
###Wrseq format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss", date$) + " GEN_ENTSAL - inicio" Using [XTRA]
###Openo Using [XTRA]                                                                    #xvt26082020.en


Local Char    LDIREXPORT(100) : LDIREXPORT = "E:\import\IMP\"
Local Char    LFILE(200), LRUTA(200)
Local Char    LSEP(1) : LSEP = ";"  # separador PARA TODOS LOS FICHEROS
Local Char    LNUMSALNEW(30), LNUMENTNEW(30) # código salida y entrada generados
Local Integer LINTENT # intentos

# Campo ZFLAGPREP de la Devolución
# 1 Salida Generada
# 2 Devolución completamente tratada, salida y entrada generadas
# Resto: devolución sin tratar

# utilizado para generar ficheros únicos
Local Char LFECHA(10), LHORA(10)
LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

# abrir tablas
Gosub ABRIR_TBL

# si se lanza la tarea batch
###If !GSERVEUR Then
###  Call TEMPON("Generación Devolución En preparación") From GESECRAN
###  Call OUVRE_TRACE("Generación Devolución En preparación") From LECFIC
###Endif

###If !GSERVEUR Then
###  Call TEMPON("Generación fichero salida ordenación... ") From GESECRAN
###Endif

# Salida
Gosub GEN_SMO
Gosub IMP_SMO

# hay que comprobar que la salida ha sido generada por modelo
LINTENT=1 #XVT29102020.n
#XVT29102020.o While LINTENT < 5
While LINTENT < 10 #XVT29102020.n
  # buscamos si la salida ha sido creada y apuntamos el número
  Filter [T0] Where [T0]TRSFAM = "24" and [T0]ZORIVCRNUM = PNUMENT
    Read [T0] First
    If !fstat Then
      LNUMSALNEW = [T0]VCRNUM
    Endif
  Filter [T0]

  If LNUMSALNEW = "" Then
    #Sleep 2 #XVT29102020.o
#Openo "e:\Sage\X3V11ALEHOP\folders\" + nomap + "\tmp\zgenentsal.tra", -1 Using [XTRA] #xvt26082020.bn
#Wrseq format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss", date$) + " SMO: LINTENT ES " + num$(LINTENT) Using [XTRA]
#Openo Using [XTRA]                                                                    #xvt26082020.en

    Sleep LINTENT
    LINTENT += 1
  Else
    LINTENT = 11 # para salir directos..
  Endif
Wend

If LNUMSALNEW = "" Then
###  Infbox "Error en la importación de la salida de ordenación. Debe procesar nuevamente la Devolución"
###  GERR = 1 : GMESSAGE = "Error, debe volver a procesar la Devolución"

#Openo "e:\Sage\X3V11ALEHOP\folders\" + nomap + "\tmp\zgenentsal.tra", -1 Using [XTRA] #xvt26082020.bn
#Wrseq format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss", date$) + " SMO: LNUMSALNEW ES VACÍO" Using [XTRA]
#Openo Using [XTRA]                                                                    #xvt26082020.en

Else   # se ha generado el movimiento de salida correspondiente a la devolución y se ha importado

#Openo "e:\Sage\X3V11ALEHOP\folders\" + nomap + "\tmp\zgenentsal.tra", -1 Using [XTRA] #xvt26082020.bn
#Wrseq format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss", date$) + " SMO: LNUMSALNEW ES " + LNUMSALNEW  Using [XTRA]
#Openo Using [XTRA]                                                                    #xvt26082020.en

      ################# marcamos la devolución para indicar que ya se ha generado la salida
      Filter [T0] Where [T0]TRSFAM = "12" and [T0]VCRNUM = PNUMENT
        Read [T0] First
        If !fstat Then
          [T0]ZFLAGPREP = '1'
          Rewrite [T0]
        Endif
      Filter [T0]
      ################

###      If !GSERVEUR Then
###        Call TEMPON("Generación fichero entrada ordenación... ") From GESECRAN
###      Endif
      # Entrada
      Gosub GEN_SMR
      Gosub IMP_SMR

      #Raz LINTENT #XVT29102020.O
      LINTENT=1 #XVT29102020.n
      # hay que comprobar que la entrada ha sido generada por modelo
      #XVT29102020.o While LINTENT < 5
      While LINTENT < 10 #XVT29102020.n
        # buscamos si la ENTRADA ha sido creada y apuntamos el número
        Filter [T0] Where [T0]TRSFAM = "11" and [T0]ZORIVCRNUM = PNUMENT
          Read [T0] First
          If !fstat Then
            LNUMENTNEW = [T0]VCRNUM
          Endif
        Filter [T0]

        If LNUMENTNEW = "" Then
          #XVT29102020.O Sleep 2
#Openo "e:\Sage\X3V11ALEHOP\folders\" + nomap + "\tmp\zgenentsal.tra", -1 Using [XTRA] #xvt26082020.bn
#Wrseq format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss", date$) + " SMR: LINTENT ES " + num$(LINTENT) Using [XTRA]
#Openo Using [XTRA]                                                                    #xvt26082020.en
          Sleep LINTENT #XVT29102020.n
          LINTENT += 1
        Else
          LINTENT = 11 # para salir directos..
        Endif
      Wend
      If LNUMENTNEW = "" Then
###        Infbox "Error en la importación de la entrada de ordenación. Entradas no generadas"
###        GERR = 1 : GMESSAGE = "Debe volver a procesar la Devolución para generar los movimientos de Entrada pendientes"
#Openo "e:\Sage\X3V11ALEHOP\folders\" + nomap + "\tmp\zgenentsal.tra", -1 Using [XTRA] #xvt26082020.bn
#Wrseq format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss", date$) + " SMR: LNUMSALNEW ES VACÍO" Using [XTRA]
#Openo Using [XTRA]                                                                    #xvt26082020.en


      Else
        ################# marcamos la devolución para indicar que ya se ha procesado satisfactoriamente
#Openo "e:\Sage\X3V11ALEHOP\folders\" + nomap + "\tmp\zgenentsal.tra", -1 Using [XTRA] #xvt26082020.bn
#Wrseq format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss", date$) + " SMR: LNUMSALNEW ES " + LNUMSALNEW Using [XTRA]
#Openo Using [XTRA]                                                                    #xvt26082020.en

        Filter [T0] Where [T0]TRSFAM = "12" and [T0]VCRNUM = PNUMENT
          Read [T0] First
          If !fstat Then
            [T0]ZFLAGPREP = '2'
            Rewrite [T0]
          Endif
        Filter [T0]
        ################
      Endif
Endif

# mostrar traza
###Gosub GET_TRAZA

###If !GSERVEUR Then
###  Call TEMPOFF() From GESECRAN
###
###  # fin de traza
###  Call FERME_TRACE From LECFIC
###  # lectura
###  Call LEC_TRACE From LECFIC
###Endif

# cerrar tablas
Gosub CERRAR_TBL

End

########################################################
#**
#* Genera una salida de stock Ordenación
#*!
$GEN_SMO
Local Char LDATCAB(30)(8),LDATLIN(30)(4),LDATJOU(30)(5)
#If GUSER='JVIDA' Then
#  Openo  "E:\import\TMP\JVIDA.TXT",-1 Using [XFILE]
#  Infbox "FICHERO ABIERTO - INICIAL"
#  Wrseq "INICIO TRAZA " Using  [XFILE]
#  Openo Using [XFILE]
#Endif
# ruta del fichero..
#LFILE  = LDIREXPORT + "SMO_" + nomap(0) +"_"+LFECHA+"_"+LHORA+".txt"    # MS - cambio del nombre del fichero 17/12/2019

# apertura de fichero
# Gosub OPEN_FILE                                                        # MS - cambio del nombre del fichero 17/12/2019

#####
# SMVTH - cabecera
###
# 1 -> Tipo asiento
# 2 -> Planta stock
# 3 -> Fecha imputación
# 4 -> Descripción
# 5 -> Código del movimiento
# 6 -> Familia movimiento
#####

##Openo "e:\Sage\X3V11ALEHOP\folders\" + nomap + "\tmp\zgenentsal.tra", -1 Using [XTRA] #xvt26082020.bn
##Wrseq format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss", date$) + " GEN_ENTSMO - inicio" Using [XTRA]
##Openo Using [XTRA]                                                                    #xvt26082020.en

Filter [SALC] Where VCRNUM = PNUMENT and ZFLAGPREP <> '1'  # Devoluciones que no tengan ya la salida generada
Read [SALC] First
If !fstat Then

  ##Openo "e:\Sage\X3V11ALEHOP\folders\" + nomap + "\tmp\zgenentsal.tra", -1 Using [XTRA] #xvt26082020.bn
  ##Wrseq format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss", date$) + " GEN_ENTSMO - DEVOLUCION " + PNUMENT  Using [XTRA]
  ##Openo Using [XTRA]                                                                    #xvt26082020.en

  # ruta del fichero..
  LFILE  = LDIREXPORT + "SMO_" + nomap(0) +"_"+PNUMENT+".txt"
  # apertura de fichero

  Gosub OPEN_FILE

  Raz LDATCAB
  LDATCAB(1) = "20"         # salida varia
  LDATCAB(2) = [SALC]STOFCY
  LDATCAB(3) = date$
  LDATCAB(4) = [SALC]VCRDES
  LDATCAB(5) = "SOR"        # Cod. movimiento > salida de ordenación
  LDATCAB(6) = "24"         # Fam. movimiento > salida de ordenación
  LDATCAB(7) = PNUMENT      # Asiento Origen, Devolución

  # escribimos en el fichero
  Wrseq '"E";' +
&       '"' + LDATCAB(1) + '"' + LSEP +
&       '"' + LDATCAB(2) + '"' + LSEP +
&       '"' + LDATCAB(3) + '"' + LSEP +
&       '"' + LDATCAB(4) + '"' + LSEP +
&       '"' + LDATCAB(5) + '"' + LSEP +
&       '"' + LDATCAB(6) + '"' + LSEP +
&       '"' + LDATCAB(7) + '"' + LSEP
&       Using [ZEXP]

  ##Openo "e:\Sage\X3V11ALEHOP\folders\" + nomap + "\tmp\zgenentsal.tra", -1 Using [XTRA] #xvt26082020.bn
#  Wrseq '"E";' +
#&       '"' + LDATCAB(1) + '"' + LSEP +
#&       '"' + LDATCAB(2) + '"' + LSEP +
#&       '"' + LDATCAB(3) + '"' + LSEP +
#&       '"' + LDATCAB(4) + '"' + LSEP +
#&       '"' + LDATCAB(5) + '"' + LSEP +
#&       '"' + LDATCAB(6) + '"' + LSEP +
#&       '"' + LDATCAB(7) + '"' + LSEP
#&       Using [XTRA]
  ##Openo Using [XTRA]                                                                    #xvt26082020.en


#If GUSER='JVIDA' Then
#  Openo  "E:\import\TMP\JVIDA.TXT",-1 Using [XFILE]
#  Infbox "FICHERO ABIERTO - CABECERA"
# Wrseq '"E";' +
#&       '"' + LDATCAB(1) + '"' + LSEP +
#&       '"' + LDATCAB(2) + '"' + LSEP +
#&       '"' + LDATCAB(3) + '"' + LSEP +
#&       '"' + LDATCAB(4) + '"' + LSEP +
#&       '"' + LDATCAB(5) + '"' + LSEP +
#&       '"' + LDATCAB(6) + '"' + LSEP +
#&       '"' + LDATCAB(7) + '"' + LSEP
#&       Using[XFILE]
#  Openo Using [XFILE]
#Endif

    # componemos el fichero de detalle y diario
    Filter [SALD1] Where [SALD1]VCRTYP = PTYPENT and [SALD1]VCRNUM = PNUMENT Order By [SALD1]VCRLIN Asc
      For [SALD1]
        #####
        # SMVTD - detalle
        ###
        # 1 -> Artículo
        # 2 -> Unidad
        # 3 -> Cantidad
        #####

        Raz LDATLIN
        LDATLIN(1) = [SALD1]ITMREF
        LDATLIN(2) = [SALD1]PCU
        LDATLIN(3) = num$([SALD1]SUMQTYSTU)

        # escribimos en el fichero
        Wrseq '"L";' +
&             '"' + LDATLIN(1) + '"' + LSEP +
&             '"' + LDATLIN(2) + '"' + LSEP +
&             '"' + LDATLIN(3) + '"' + LSEP
&       Using [ZEXP]


  ##Openo "e:\Sage\X3V11ALEHOP\folders\" + nomap + "\tmp\zgenentsal.tra", -1 Using [XTRA] #xvt26082020.bn
#  Wrseq '"L";' +
#&             '"' + LDATLIN(1) + '"' + LSEP +
#&             '"' + LDATLIN(2) + '"' + LSEP +
#&             '"' + LDATLIN(3) + '"' + LSEP
#&       Using [XTRA]
  ##Openo Using [XTRA]                                                                    #xvt26082020.en


#If GUSER='JVIDA' Then
#  Openo  "E:\import\TMP\JVIDA.TXT",-1 Using [XFILE]
#        Wrseq '"L";' +
#&             '"' + LDATLIN(1) + '"' + LSEP +
#&             '"' + LDATLIN(2) + '"' + LSEP +
#&             '"' + LDATLIN(3) + '"' + LSEP
#&       Using[XFILE]
#  Openo Using [XFILE]
#Endif



        #####
        # STOJOU - diario
        ###
        # 1 -> Unidad
        # 2 -> Cantidad
        # 3 -> Ubicación
        # 4 -> Estado
        ####
        Raz LDATJOU
        Filter [SALD2] Where [SALD2]VCRNUM = PNUMENT and [SALD2]ITMREF = [SALD1]ITMREF
        For  [SALD2]
            LDATJOU(1) = [SALD2]STU
            LDATJOU(2) = num$([SALD2]QTYSTU)
            LDATJOU(3) = [SALD2]LOC
            LDATJOU(4) = [SALD2]STA
            # escribimos en el fichero
            Wrseq '"S";' +
&                 '"' + LDATJOU(1) + '"' + LSEP +
&                 '"' + LDATJOU(2) + '"' + LSEP +
&                 '"' + LDATJOU(3) + '"' + LSEP +
&                 '"' + LDATJOU(4) + '"' + LSEP
&           Using [ZEXP]

##Openo "e:\Sage\X3V11ALEHOP\folders\" + nomap + "\tmp\zgenentsal.tra", -1 Using [XTRA] #xvt26082020.bn
# Wrseq '"S";' +
#&                 '"' + LDATJOU(1) + '"' + LSEP +
#&                 '"' + LDATJOU(2) + '"' + LSEP +
#&                 '"' + LDATJOU(3) + '"' + LSEP +
#&                 '"' + LDATJOU(4) + '"' + LSEP
#&           Using [XTRA]
  ##Openo Using [XTRA]

#If GUSER='JVIDA' Then
#  Openo  "E:\import\TMP\JVIDA.TXT",-1 Using [XFILE]
#            Wrseq '"S";' +
#&                 '"' + LDATJOU(1) + '"' + LSEP +
#&                 '"' + LDATJOU(2) + '"' + LSEP +
#&                 '"' + LDATJOU(3) + '"' + LSEP +
#&                 '"' + LDATJOU(4) + '"' + LSEP
#&       Using[XFILE]
#  Openo Using [XFILE]
#Endif


        Next
        Filter [SALD2]
      Next
      Filter [SALD1]

  # cerrar fichero import
  Gosub CLOSE_FILE
  ##Openo "e:\Sage\X3V11ALEHOP\folders\" + nomap + "\tmp\zgenentsal.tra", -1 Using [XTRA] #xvt26082020.bn
  ##Wrseq format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss", date$) + " GEN_ENTSMO - DEVOLUCION FICHERO CREADO " + PNUMENT  Using [XTRA]
  ##Openo Using [XTRA]                                                                    #xvt26082020.en

Endif

Return

########################################################
#**
#* Importa movimiento de salida
#*!
$IMP_SMO
mkstat = 0 : fstat = 0 : GERRTRACE = 0

#Call OUVRE_TRACE("Creación Recepcion a partir de Entrega Validada") From LECFIC

Local Integer SIZE : SIZE = filinfo(LFILE, 7)
If SIZE = 0 :# File does not exist
###   Call ERREURT("Error, Debe volver a procesar la Devolución: " + PNUMENT, 1) From GESECRAN
#  Call ERREURT("Error, SALIDA de devolución no procesada: " + PNUMENT, 1) From GESECRAN
Endif

#If GUSER='JVIDA' Then
#  Openo  "E:\import\TMP\JVIDA.TXT",-1 Using [XFILE]
#            Wrseq 'PREVIO IMPORTSIL ZSMO'
#&       Using[XFILE]
#  Openo Using [XFILE]
#Endif

 ##Openo "e:\Sage\X3V11ALEHOP\folders\" + nomap + "\tmp\zgenentsal.tra", -1 Using [XTRA] #xvt26082020.bn
  ##Wrseq format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss", date$) + " PRE-IMPORTSIL - FICHERO " + LFILE Using [XTRA]
  ##Openo Using [XTRA]                                                                    #xvt26082020.en

Call IMPORTSIL("ZSMO", LFILE) From GIMPOBJ

  #Openo "e:\Sage\X3V11ALEHOP\folders\" + nomap + "\tmp\zgenentsal.tra", -1 Using [XTRA] #xvt26082020.bn
  ##Wrseq format$("YYYY[-]MM[-]DD[ ]hh[:]mm[:]ss", date$) + " POST-IMPORTSIL - FICHERO " + LFILE Using [XTRA]
  ##Openo Using [XTRA]                                                                    #xvt26082020.en


#If GUSER='JVIDA' Then
#  Openo  "E:\import\TMP\JVIDA.TXT",-1 Using [XFILE]
#            Wrseq 'TRAS IMPORTSIL ZSMO'
#&       Using[XFILE]
#  Openo Using [XFILE]
#Endif

#Call FERME_TRACE From LECFIC
#Call LEC_TRACE From LECFIC   #si se quiere mostrar traza

mkstat = 0 : fstat = 0 : GERRTRACE = 0
Return

########################################################
#**
#* Genera una entrada de stock Ordenación
#*!
$GEN_SMR
Local Char LDATCAB(30)(8),LDATLIN(30)(5),LDATJOU(30)(5)

# ruta del fichero..
# LFILE  = LDIREXPORT + "SMR_" + nomap(0) +"_"+LFECHA+"_"+LHORA+".txt"      # MS - cambio del nombre del fichero 17/12/2019

# apertura de fichero
# Gosub OPEN_FILE                                                           # MS - cambio del nombre del fichero 17/12/2019

#####
# SMVTH - cabecera
###
# 1 -> Tipo asiento
# 2 -> Planta stock
# 3 -> Fecha imputación
# 4 -> Descripción
# 5 -> Código del movimiento
# 6 -> Familia movimiento
# 7 -> Devolución origen
#####

Filter [SALC] Where VCRNUM = PNUMENT
Read [SALC] First
If !fstat Then
  # ruta del fichero..
  LFILE  = LDIREXPORT + "SMR_" + nomap(0) +"_"+PNUMENT+".txt"
  # apertura de fichero
  Gosub OPEN_FILE

  Raz LDATCAB

  LDATCAB(1) = "19"         # entrada varia
  LDATCAB(2) = [SALC]STOFCY
  LDATCAB(3) = date$
  LDATCAB(4) = [SALC]VCRDES
  LDATCAB(5) = "EOR"        # Cod. movimiento > Entrada varia EOR
  LDATCAB(6) = "11"         # Fam. movimiento > Entrada Ordenación
  LDATCAB(7) = PNUMENT

  # escribimos en el fichero
  Wrseq '"E";' +
&       '"' + LDATCAB(1) + '"' + LSEP +
&       '"' + LDATCAB(2) + '"' + LSEP +
&       '"' + LDATCAB(3) + '"' + LSEP +
&       '"' + LDATCAB(4) + '"' + LSEP +
&       '"' + LDATCAB(5) + '"' + LSEP +
&       '"' + LDATCAB(6) + '"' + LSEP +
&       '"' + LDATCAB(7) + '"' + LSEP
&       Using [ZEXP]

    # componemos el fichero de detalle y diario
    Filter [SALD1] Where [SALD1]VCRTYP = PTYPENT and [SALD1]VCRNUM = PNUMENT Order By [SALD1]VCRLIN Asc
      For [SALD1]
        #####
        # SMVTD - detalle
        ###
        # 1 -> Artículo
        # 2 -> Unidad
        # 3 -> Cantidad
        #####

        Raz LDATLIN
        LDATLIN(1) = [SALD1]ITMREF
        LDATLIN(2) = [SALD1]PCU
        LDATLIN(3) = num$([SALD1]SUMQTYSTU)
        LDATLIN(4) = num$([SALD1]PRIORD)

        # escribimos en el fichero
        Wrseq '"L";' +
&             '"' + LDATLIN(1) + '"' + LSEP +
&             '"' + LDATLIN(2) + '"' + LSEP +
&             '"' + LDATLIN(3) + '"' + LSEP +
&             '"' + LDATLIN(4) + '"' + LSEP
&           Using [ZEXP]

        #####
        # STOJOU - diario
        ###
        # 1 -> Unidad
        # 2 -> Cantidad
        # 3 -> Ubicación
        # 4 -> Estado
        ####
        Raz LDATJOU
        Filter [SALD2] Where [SALD2]VCRNUM = PNUMENT and [SALD2]ITMREF = [SALD1]ITMREF
        For  [SALD2]
            LDATJOU(1) = [SALD2]STU
            LDATJOU(2) = num$([SALD2]QTYSTU)
            LDATJOU(3) = 'MUELLE'
#XVT28092020.o            LDATJOU(4) = 'A'
            LDATJOU(4) = 'QA'   #XVT28092020.n

            # escribimos en el fichero
            Wrseq '"S";' +
&                 '"' + LDATJOU(1) + '"' + LSEP +
&                 '"' + LDATJOU(2) + '"' + LSEP +
&                 '"' + LDATJOU(3) + '"' + LSEP +
&                 '"' + LDATJOU(4) + '"' + LSEP
&           Using [ZEXP]
        Next
        Filter [SALD2]
      Next

    Filter [SALD1]

  # cerrar fichero import
  Gosub CLOSE_FILE
Endif
Return

########################################################
#**
#* Importa movimiento de entrada
#*!
$IMP_SMR
mkstat = 0 : fstat = 0 : GERRTRACE = 0

#Call OUVRE_TRACE("Creación Recepcion a partir de Entrega Validada") From LECFIC

# Get file size
Local Integer SIZE : SIZE = filinfo(LFILE, 7)
If SIZE = 0 :# File does not exist
  Call ERREURT("Error, Para generar las entradas debe volver a procesar la Devolución: " + PNUMENT, 1) From GESECRAN
Endif

Call IMPORTSIL("ZSMR", LFILE) From GIMPOBJ

#Call FERME_TRACE From LECFIC
#Call LEC_TRACE From LECFIC   #si se quiere mostrar traza

mkstat = 0 : fstat = 0 : GERRTRACE = 0
Return

#######################################################
$GET_TRAZA
Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
Call ECR_TRACE("Devolución procesada     : " + PNUMENT, 0) From GESECRAN
Call ECR_TRACE("Salida varia ordenación  : " + LNUMSALNEW, 0) From GESECRAN
Call ECR_TRACE("Entrada varia ordenación : " + LNUMENTNEW, 0) From GESECRAN

Return

########################################################
$OPEN_FILE
adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE Using [ZEXP]
Return

########################################################
$CLOSE_FILE
#If GUSER='JVIDA' Then
#  Openo  "E:\import\TMP\JVIDA.TXT",-1 Using [XFILE]
#  Infbox "FICHERO cerrado - CLOSE FILE"
#  Wrseq "CLOSE FILE " + LFILE Using  [XFILE]
#  Openo Using [XFILE]
#Endif


Openo Using [ZEXP]
Return

##########################################################
$ABRIR_TBL
If clalev([T0]) = 0 : Local File SMVTH  [T0] : Endif  # movimientos cab.
#If clalev([T1]) = 0 : Local File SMVTD  [T1] : Endif  # movimientos lin.
#If clalev([S0]) = 0 : Local File STOJOU [S0] : Endif  # diario

If !clalev([ED0])   : Local File ZENTDEVD0 [ED0]   : Endif  # Vísta Entradas Devolución a Tratar

If !clalev([SALC])   : Local File ZPPSALC [SALC]      : Endif  # Vista Salida Cabecera
If !clalev([SALD1])  : Local File ZPPSALD1 [SALD1]    : Endif  # Vista Salida Detalle 1
If !clalev([SALD2])  : Local File ZPPSALD2 [SALD2]    : Endif  # Vista Salida Detalle 2



If !clalev([ED01])  : Local File ZENTDEVD1 [ED01]  : Endif  # Vísta Entradas Devolución a Tratar,
                                                           # empleada para tratar devoluciones que ya
                                                           # tengan hecha la salida (corte en en proceso de generación
                                                           # de la entrada
If !clalev([ED1])   : Local File ZENTDEV1 [ED1]   : Endif  # Vísta Entradas Devolución acumulada QTY por documento
If !clalev([ED2])   : Local File ZENTDEV2 [ED2]   : Endif  # Vísta Entradas Devolución por documento-artículo
Return

#########################################################
$CERRAR_TBL
Close Local File [T0],[ED0], [ED1], [ED2]
Close Local File [SALC],[SALD1],[SALD2]

Return

