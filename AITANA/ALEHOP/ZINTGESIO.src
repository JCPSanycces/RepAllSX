###########################################################
# Fecha creación: 05/11/2018
# Autor: Mario Alarcón Bonet
# Versión: 1
# Generación de ficheros XML para GESIO
##########################################################


Subprog GENERA_XML()

  Local Char    LDIREXPORT(100) : LDIREXPORT = "\\192.168.100.90\FTPSAGE\dir_xml\"
  Local Char    LFILE(200), LFILECOPY(200)

  
  Local Integer LTOTITM # número total de artículos exportados..
  Local Integer LTOTEAN # número total de códigos ean

  # utilizado para la copia de histórico de ficheros
  Local Char LFECHA(10), LHORA(10)
  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
  LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

  # abrir tablas
  Gosub ABRIR_TBL

  Read [F:YADI]CODE=6002;'0'
  If !fstat
    LDIREXPORT = [F:YADI]A1
  Else
   LDIREXPORT = "\\192.168.100.90\FTPSAGE\dir_xml\"
  Endif


  # si se lanza la tarea batch
  If !GSERVEUR Then
    Call TEMPON("Proceso exportación GESIO") From GESECRAN
    Call OUVRE_TRACE("Proceso exportación GESIO") From LECFIC

  Endif

  # generación fichero de artículos
  If !GSERVEUR Then
    Call TEMPON("Generación de artículos") From GESECRAN
  Endif
  Gosub GEN_ARTICULOS

  # traza
  Gosub GET_TRAZA


  If !GSERVEUR Then
    Call TEMPOFF() From GESECRAN

    # fin de traza
    Call FERME_TRACE From LECFIC
    # lectura
    Call LEC_TRACE From LECFIC
  Endif

  # cerrar tablas
  Gosub CERRAR_TBL

End



#########################################################
$ABRIR_TBL
  If clalev([I0]) = 0 : Local File ITMMASTER   [I0] : Endif  # artículos
  If clalev([C0]) = 0 : Local File ITMCOST     [C0] : Endif  # artículos-costes
  If clalev([IS]) = 0 : Local File ITMSALES    [IS] : Endif  # artículo venta
   If clalev([YADI]) = 0 : Local File ATABDIV   [YADI] : Endif  # tablas varias
  # MAB 03102019 NEW

  If clalev([TP]) = 0 : Local File PRICLIST    [IS] : Endif  # TARIFAS PROVEEDORES


Return


#########################################################
$CERRAR_TBL
  Close Local File [I0], [IS]
  Close Local File [R0], [R1]
  Close Local File [YADI]
  

Return

##########################################################
#**
#* Genera fichero XML de exportación a GESIO
#*!
$GEN_ARTICULOS
  Local Char    LDATLIN(50)(15)
  Local Integer I : I=1
  Local Integer MAXI : MAXI=17
  Local Float LCOSTEM, LPVP, LSTOCK, LLASTPURPRI
  Local Char LDESC_POR(250), LDESC_ENG(250)
  Local Char LTIPO_ARTICULO

  #LFILECOPY   = LDIREXPORT + "COPIA\main_" + LFECHA + "_" + LHORA + ".xml"
  LFILE       = LDIREXPORT + "main.xml"

  # borramos el fichero si existe...
  Gosub DEL_FILE

  # abrir fichero..
  Gosub OPEN_FILE

  # Cabecera del fichero XML
  Wrseq '<?xml version="1.0" encoding="UTF-8"?>'   Using [ZEXP]
  Wrseq '<catalog full="false" gesioid="alehop@clavedenia">'   Using [ZEXP]

  # recorremos todos los artículos
  # pendiente: aquellos artículos desde la última export
  For [I0]ITM0

    Wrseq '<product>'   Using [ZEXP]
    Wrseq '<id>' + [F:I0]ITMREF + '</id>' Using [ZEXP]
    Wrseq '<public_id>' + [F:I0]ITMREF + '</public_id><!-- referencia del producto -->' Using [ZEXP]
    # TABLA VARIA DE PARÁMETROS
    Wrseq '<webs><!-- webs en las que se debe publicar --><web>ALE-HOP</web><!-- Web pública de alehop: www.ale-hop.org -->' Using [ZEXP]
    Wrseq '<web>ALE-HOP Portugal</web><!-- web obsoleta -->' Using [ZEXP]
    Wrseq '<web>Web Tiendas ALE-HOP</web><!-- web obsoleta --></webs>' Using [ZEXP]
    # IMAGENES -- INI - FALTA VER DE DONDE TENGO QUE SACAR LAS IMÁGENES Y COPIARLAS A LA CARPETA IMAGES ANTES DE CREAR EL ZIP
    Wrseq '<images scope="all"><!-- imágenes del producto -->' Using [ZEXP]
    Wrseq '<image><src>images/221402.jpg</src>' Using [ZEXP]
    Wrseq '</image></images>' Using [ZEXP]
    # IMAGENES -- FIN -
    Wrseq '<unit_of_measurement>units</unit_of_measurement><!-- siempre units -->' Using [ZEXP]
    Wrseq '<available>1</available><!-- en catálogo: 1: sí, 0: no -->' Using [ZEXP]  ## preguntar a Enrique / Antonio
    # COSTE --> sacarlo de esta tabla , AVC_0 FROM ITMMVT ITM o de la VISTA DE XIMO --> ZAQSPC
    #Wrseq '<cost_price>' + num$([F:I0]CPRAMT) + '</cost_price><!-- precio de coste del producto -->' Using [ZEXP] # COSTE FIJO UNITARIO
    LCOSTE = func GET_COST_PRICE([F:I0]ITMREF)
    Wrseq '<cost_price>' + num$(LCOSTE) + '</cost_price><!-- precio de coste del producto -->' Using [ZEXP] # COSTE FIJO UNITARIO
    # DATOS DE VENTA - INI -
    Filter [IS] Where ITMREF = [F:I0]ITMREF
    Read [IS] First
    If !fstat Then
        # Vista ZAQSTARIFA - Tarifa T60 y fecha de lanzamiento comprendida entre los dos campos fechas que hay
        # Si hay mas de un registro,quedarse con la que tenga el STARTDATE mas actual.
        # Aqui está el PVP
        # En el escritorio (SistelX3) estn las query que hay que usar.
        # Habra que descontar el porcentaje de impuesto
        LPVP = func GET_PRICE_PVP([F:IS]ITMREF)
        Wrseq '<price>' + num$(LPVP) +  ' </price><!-- precio de venta sin IVA -->' Using [ZEXP]
        # Recuperado arriba
        Wrseq '<vat>21</vat><!-- porcentaje del IVA asociado al producto RRR -->' Using [ZEXP]  ####### ?????

        Wrseq '<max_units_per_order>'+ num$([F:I0]ZSTOCKMAX)  +'</max_units_per_order><!-- Unidades máximas por pedido -->' Using [ZEXP]   ## preguntar a Enrique / Antonio -- CONFIRMAR SI ES
# ITMSALES.MINQTY
        Wrseq '<min_units_per_order>'+ num$([F:I0]ZSTOCKMIN)  +'</min_units_per_order><!-- Unidades mínimas por pedido -->' Using [ZEXP]   ## preguntar a Enrique / Antonio -- CONFIRMAR SI ES
# ITMSALES.MAXQTY
        Wrseq '<min_amount_per_order>0</min_amount_per_order><!-- Importe mínimo por pedido -->' Using [ZEXP]   ## preguntar a Enrique / Antonio
    Endif
    Filter [IS]
    # DATOS DE VENTA - FIN -
    Wrseq '<title>' +[F:I0]ITMDES1 + '</title><!-- Nombre del producto en el idioma por defecto (castellano) -->' Using [ZEXP]
    ###### ????? Esta descripción larga de donde sale?  ## preguntar a Enrique / Antonio
    Wrseq '<description>'+ '-' + '</description><!-- Descripción del producto en elidioma por defecto (castellano) -->'  Using [ZEXP]

    Wrseq '<release_date>2018-07-11</release_date><!-- Fecha de lanzamiento -->' Using [ZEXP]  ###### ?????  ## preguntar a Enrique / Antonio (ZFECHALTA)
    Wrseq '<destocking>0</destocking><!-- En liquidación -->' Using [ZEXP]  ###### ?????  ## preguntar a Enrique / Antonio
    Wrseq '<stock uncontrolled="0"><!-- info stock -->' Using [ZEXP]        ###### ?????  ## preguntar a Enrique / Antonio ( STOMGTCOD)
    LSTOCK = func GET_STOCK_CENTRAL([F:IS]ITMREF)
    Wrseq '<location path="almacen central|general">' + num$(LSTOCK) + '</location><!-- unidades en la ubicacióngeneral (en ale-hop se ha denominado almacen central|general) --></stock>' Using [ZEXP]  ###### ?????
          ###### ????? SELECT ITMREF_0, STOCK_0 FROM PROTOCLVD.ZAQSSTOCK --> ESTE CAMPO ES EL STOCK <--
    Wrseq '<suppliers><!-- proveedores -->' Using [ZEXP]
    Wrseq   '<supplier><!-- info proveedor --><name>221</name><!-- nombre proveedor --><model></model><!-- referencia proveedor --><cost_price>3.7300</cost_price><!-- precio proveedor --></supplier>'
& Using [ZEXP]
# COSTE DE PROVEEDOR  SELECT * FROM PROTOCLVD.ZAQSTARIFA DE LA TARIFA T50 FILTRANDO POR FECHA (PRECIO CHINO)
# RESTO DE CAMPOS DEL PROVEEDOR EN LA TABLA ITMSUPP
    Wrseq '</suppliers>' Using [ZEXP]
    # ITMMASTER #
    Wrseq '<containers><!-- info envases -->' Using [ZEXP]
    Wrseq   '<container><name>inner_box</name><!-- nombre envase --><units>1</units><!-- unidades en el envase --></container>' Using [ZEXP]
    Wrseq   '<container><name>middel_box</name><units>1</units></container>' Using [ZEXP]
    Wrseq '</containers>' Using [ZEXP]
    Wrseq '<barcodes><!-- códigos de barras -->' Using [ZEXP]
    Wrseq   '<barcode type="EAN-13">' + [F:I0]EANCOD + '</barcode>' Using [ZEXP]
    Wrseq '</barcodes>' Using [ZEXP]
    Wrseq '<categories><!-- familias de productos -->' Using [ZEXP] ## preguntar a Enrique / Antonio
    Wrseq   '<category></category>' Using [ZEXP]
    Wrseq '</categories>' Using [ZEXP]
    Wrseq '<internationalization><!-- traducciones a otros idiomas -->' Using [ZEXP]
     ###### ?????
    Wrseq   '<title><!-- nombre del producto -->' Using [ZEXP]
    LDESC_POR = func GET_DESC([F:IS]ITMREF, 'POR')
    Wrseq     '<value lang="pt-PT">'+ LDESC_POR + '</value><!-- traducción al portugés -->' Using [ZEXP]
    LDESC_ENG = func GET_DESC([F:IS]ITMREF, 'ENG')
    Wrseq     '<value lang="en-EN">' + LDESC_ENG + '</value><!-- traducción al inglés -->' Using [ZEXP]
    Wrseq   '</title>' Using [ZEXP]
    Wrseq   '<description><!-- descripción del producto -->' Using [ZEXP]
    
    Wrseq     '<value lang="pt-PT">' + LDESC_POR + '</value><!-- traducción al portugés -->' Using [ZEXP]
    Wrseq     '<value lang="en-EN">' + LDESC_ENG + '</value><!-- traducción al inglés -->' Using [ZEXP]
    Wrseq   '</description>' Using [ZEXP]
    Wrseq '</internationalization>' Using [ZEXP]
     ###### ?????
    Wrseq '<rates><!-- info tarifas --><!-- ALEHOP podrá explicar mejor a que corresponde cada tarifa -->' Using [ZEXP]
    # PREGUNTAR A ENRIQUE / ANTONIO
    Wrseq   '<rate><name>pvm_rate_1</name><!-- nombre de la tarifa: respetar nombre actuales (case-sensitive) --><price>7.2500</price><!-- precio de la tarifa sin impuestos --></rate>' Using [ZEXP]
    Wrseq   '<rate><name>pvm_rate_2</name><price>0</price></rate>' Using [ZEXP]
    Wrseq   '<rate><name>pvm_rate_1_time</name><price>0</price></rate>' Using [ZEXP]
    Wrseq   '<rate><name>pvp_rate_4</name><price>0.0000</price></rate>' Using [ZEXP]
    Wrseq   '<rate><name>pvp_rate_1_time</name><price>0.0000</price></rate>' Using [ZEXP]
    Wrseq '</rates>' Using [ZEXP]
     ###### ?????  # PREGUNTAR A ENRIQUE / ANTONIO
     LTIPO_ARTICULO = func GET_TIPO_ARTICULO([F:I0]ITMREF, [F:I0]TSICOD(2)) 
    Wrseq '<specific_data product_type_path="'+ LTIPO_ARTICULO + '"><!-- otros datos: campos variables --><!-- ALEHOP podrá explicar mejor a que corresponde cada campo variable -->' Using [ZEXP]
    Wrseq   '<var><name>Fecha alta Clave Denia</name><!-- nombre de la variable: respetar nombreactuales (case-sensitive) --><Value>2018-07-11</Value><!-- VALOR DE LA Variable --></var>' Using [ZEXP]
     # UNIDADES DE LINEAS DE COMPRA NO SALDADAS
    Wrseq   '<var><name>unidades pendientes de recibir</name><value>0</value></var>' Using [ZEXP]
     # FAMILIA DE ARTICULOS CAMPO ITMMASTER.TSICOD_3
    Wrseq   '<var><name>Asterisco</name><value></value></var>' Using [ZEXP]
    # ###### ?????  # PREGUNTAR A ENRIQUE / ANTONIO
    Wrseq '<var><name>Nro.Etiquetas de embalaje</name><value>23</value></var>' Using [ZEXP]
    # ###### ?????  # PREGUNTAR A ENRIQUE / ANTONIO
    Wrseq   '<var><name>Producto Web</name><value>W</value></var>' Using [ZEXP]
    ###### TENGO EL DATO EN LA PESTAÑA ALEHOP
    Wrseq   '<var><name>Leer EAN</name><value>S</value></var>' Using [ZEXP]
    # FAMILIA DE ARTICULOS CAMPO ITMMASTER.TSICOD_2 - PLANOGRAMA
    Wrseq   '<var><name>Codigo Catalogo Compra</name><value>10001</value></var>' Using [ZEXP]
    ###### TENGO EL DATO EN LA PESTAÑA ALEHOP
    Wrseq '<var><name>Fecha de Baja</name><value></value></var>' Using [ZEXP]
    # ###### ?????  # PREGUNTAR A ENRIQUE / ANTONIO
    Wrseq '<var><name>Stock Tienda Online</name><value></value></var>' Using [ZEXP]
        # ###### ?????  # PREGUNTAR A ENRIQUE / ANTONIO
    Wrseq '<var><name>Ficha Producto</name><value></value></var>' Using [ZEXP]
    # itmmaster.CUSREF
    Wrseq '<var><name>Partida arancelaria</name><value>9004909000</value></var>' Using [ZEXP]
    # ZUBIPRED
    Wrseq '<var><name>picking</name><value>O371</value></var>' Using [ZEXP]
    # ###### ?????  # PREGUNTAR A ENRIQUE / ANTONIO -- ¿por categoria de articulo?
    Wrseq '<var><name>Inmovilizado o Suministro</name><value></value></var>' Using [ZEXP]
    # Buscar en las líneas de compra
    Wrseq '<var><name>Ultima fecha de compra</name><value>2018-07-11</value></var>' Using [ZEXP]
        # ###### ?????  # PREGUNTAR A ENRIQUE / ANTONIO
    Wrseq '<var><name>CodigoCatalogoAntiguo</name><value>' + [F:I0]TSICOD(2) + '</value></var>' Using [ZEXP]
    # buscar en las líneas de compra
    LLASTPURPRI = GET_LAST_PRICE_PUR(PITMREF)
    Wrseq '<var><name>Ultimo precio compra</name><value>'+ num$(LLASTPURPRI)  + '</value></var>' Using [ZEXP]
        # ###### ?????  # PREGUNTAR A ENRIQUE / ANTONIO
    Wrseq '<var><name>Codigo catalogo</name><value></value></var>' Using [ZEXP]
       ###### ????? SELECT ITMREF_0, STOCK_0 FROM PROTOCLVD.ZAQSSTOCK --> ESTE CAMPO ES EL STOCK <--  # ###### ?????  # PREGUNTAR A ENRIQUE / ANTONIO
    Wrseq '<var><name>Existencias</name><value>1908</value></var>' Using [ZEXP]
     # ###### ?????  # PREGUNTAR A ENRIQUE / ANTONIO
    Wrseq '<var><name>Codigo barras proveedor</name><value></value></var>' Using [ZEXP]
     # ###### ?????  # PREGUNTAR A ENRIQUE / ANTONIO -- pedidos sin saldar
    Wrseq '<var><name>FechaDeLlegada</name><value></value></var>' Using [ZEXP]
    Wrseq '</specific_data>' Using [ZEXP]
    Wrseq '</product>' Using [ZEXP]


    #Call GET_ATEXTRA("ITMMASTER", "DES1AXX", "SPA", [I0]ITMREF, "", LDATLIN(I)) : I+=1
    #Call GET_ATEXTRA("ITMMASTER", "DES1AXX", "POR", [I0]ITMREF, "", LDATLIN(I)) : I+=1
    #Call GET_ATEXTRA("ITMMASTER", "DES1AXX", "ENG", [I0]ITMREF, "", LDATLIN(I)) : I+=1
    #Call GET_ATEXTRA("ITMMASTER", "DES1AXX", "CAT", [I0]ITMREF, "", LDATLIN(I)) : I+=1



    LTOTITM += 1  # número total de artículos exportados..
  Next

  # cerrar fichero import
  Gosub CLOSE_FILE

  # hacemos una copia del fichero generado...
  #System "cp " + LFILE + " " + LFILECOPY

Return


########################################################
$OPEN_FILE

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE Using [ZEXP]

Return

########################################################
$CLOSE_FILE

Openo Using [ZEXP]

Return

########################################################
#**
#* Borramos un fichero existente.
#* El parámetro LFILE debe tener una ruta correcta..
#*!
$DEL_FILE
# borramos el fichero si existe...
If filinfo(LFILE, 7) > 0 Then
  System "ae_rm " + LFILE
Endif
Sleep 3  # los ficheros para que se borren correctamente hay que realizar una pausa

Return

#######################################################
$GET_TRAZA
Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
Call ECR_TRACE("Artículos   : " + num$(LTOTITM), 0) From GESECRAN
Call ECR_TRACE("EAN         : " + num$(LTOTEAN), 0) From GESECRAN

#Call ECR_TRACE("Errores    : " + num$(LNUMERR), 0) From GESECRAN
#Call ECR_TRACE("Exportados : " + num$(LNUMEXP), 0) From GESECRAN

Return
#**
#* COSTE ARTICULO DEL ALMACEN BASE
#*
#* @param PITMREF
#*!
Funprog GET_COST_PRICE(PITMREF)
  Local Float RES
  If !clalev([ZITV])   Then : Local File ITMMVT [ZITV]  : Endif  #

  Filter [ZITV] Where ITMREF = PITMREF and STOFCY = 'ALM00'
  Read [ZITV] First
  If !fstat Then
    RES = [F:ZITV]AVC
  Else
    RES = 0
  Endif

  Close File [ZITV]

End RES



#**
#* PVP ARTICULO
#*
#* @param PITMREF
#*!
Funprog GET_PRICE_PVP(PITMREF)
  Local Float RES
  If !clalev([ZSPR])   Then : Local File SPRICLIST [ZSPR]  : Endif  #

  Filter [ZSPR] Where ITMREF = PITMREF and PLI = 'T50'
  Read [ZSPR] First
  If !fstat Then
    RES = [F:ZSPR]ZPVP
  Else
    RES = 0
  Endif
  Close File [ZSPR]

End RES



#**
#* stock ARTICULO
#*
#* @param PITMREF
#*!
Funprog GET_STOCK_CENTRAL(PITMREF)
  Local Float RES
  If !clalev([ZSTK])   Then : Local File ZAQSSTOCK [ZSTK]  : Endif  #

  Filter [ZSTK] Where ITMREF = PITMREF
  Read [ZSTK] First
  If !fstat Then
    RES = [F:ZSTK]STOCK
  Else
    RES = 0
  Endif
  Close File [ZSTK]

End RES



#**
#* DESCRIPCION EN IDIOMA DEL ARTICULO
#*
#* @param PITMREF
#*!
Funprog GET_DESC(PITMREF, PIDIOMA)
  Local Char RES(250)
  If !clalev([ZATX])   Then : Local File ATEXTRA [ZATX]  : Endif  #

  Filter [ZATX] Where IDENT1 = PITMREF and ZONE = 'DES1AXX' and CODFIC = 'ITMMASTER' and LANGUE = PIDIOMA
  Read [ZATX] First
  If !fstat Then
    RES = [F:ZATX]TEXTE
  Else
    RES = ''
  Endif
  Close File [ZATX]

End RES


#**
#* TIPO DEL ARTICULO
#*
#* @param PITMREF
#*!
Funprog GET_TIPO_ARTICULO(PITMREF, PTIPO)
  Local Char RES
  If !clalev([ZATX])   Then : Local File ATEXTRA [ZATX]  : Endif  #

  Filter [ZATX] Where IDENT1 = '22' and ZONE = 'SHODES' and CODFIC = 'ATAVDIV' and LANGUE = 'SPA' and IDENT2 = PTIPO
  Read [ZATX] First
  If !fstat Then
    RES = [F:ZATX]TEXTE
  Else
    RES = ''
  Endif
  Close File [ZATX]

End RES




#**
#* ultimo precio de compra ARTICULO
#*
#* @param PITMREF
#*!
Funprog GET_LAST_PRICE_PUR(PITMREF)
  Local Float RES
  If !clalev([ZIMV])   Then : Local File ITMMVT [ZIMV]  : Endif  #

  Filter [ZIMV] Where ITMREF = PITMREF and STOFCY = 'ALM00'
  Read [ZIMV] First
  If !fstat Then
    RES = [F:ZIMV]LASPURPRI
  Else
    RES = 0
  Endif
  Close File [ZIMV]

End RES


