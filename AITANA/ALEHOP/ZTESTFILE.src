###########################################################################
# Clave Denia deberá depositar unos ficheros CSV en la carpeta E:\IMPORT\CONTA
# Seguidamente irá a la opción de Menu Alehop-Desarrollos Contabilidad AHP-Importar asientos contables extracto bancario
# y se le solicitarán los parámetros de Fecha Contabilización-Banco-Nombre Fichero
# A partir de aquí el script recibirá los parámetros de SPEZCIMP , meterá los datos en la tabla ZCONTAIMPORT
# y generará un fichero CSV para cada registro. Posteriormente recorrerá los registros de la tabla
# ZCONTAIPORT no procesados y generará un archivo CSV
# el cual dejará en la carpeta IMPORT para seguidamente llamar al modelo de Importación
# ZGAS3, que creará el asiento correspondiente. Una vez creado el Asiento se recuperará el numero del mismo
# y se guardará en la tabla ZCONTAIMPORT
# La documentacion esta en Confluence: https://sisconfluence.sistel.es/pages/viewpage.action?pageId=42548180
# Y la tarea es: ALEHOP-979
###########################################################################

############################################################################################
#*
#* Función Principal que inicia el proceso
#* Esta funcion recibe los parametros (fecha troceada, fichero, carpeta y banco
#* Abre el fichero de traza y llama a los SubProgramas LEER_FICHERO que lee el fichero y almacena
#* los datos en la tabla ZCONTAIMPORT, y a GENERAR_CSV, que genera el CSV, llama al modelo de Importación,
#* recupera el numero de asiento generado (por un campo clave) y marca el registro como procesado (3)
#*
Subprog PRINCIPAL(PDIRECTORY, PFILE, PDIA, PMES, PANYO, PBANCO) #, PMES, PANYO, PBANCO)
Local Char DIR(250)
Local Char filename(GDIMFIC)
Local Integer LNGTH
Local Integer COUNT
Local Char EFICHERO(200)
Local Char LSALDOTMP
Local Char LDIA, LMES, LANYO, BANCO

#Infbox "Estamos ya en el programa que genera el fichero..."
LDIA = PDIA
LMES = PMES
LANYO = PANYO
BANCO = PBANCO #Aqui debemos recoger el parametro del Banco que EMITE
Gosub ABRIR_TBL
#DIR =filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER
DIR = PDIRECTORY
#Infbox "El directorio es " + DIR
EFICHERO = PFILE
#Infbox "El fichero es :" + EFICHERO
#Infbox "El Banco es " + BANCO
#Infbox "La fecha es " + LDIA + " de " + LMES+ " de " + LANYO + ",asi tal cual otra vez"
Call OUVRE_TRACE("Proceso Importacion Contabilidad") From LECFIC
Call ECR_TRACE("Inicio Proceso.",0) From GESECRAN
Call LEER_FICHERO(DIR, EFICHERO, LDIA, LMES, LANYO, BANCO)
Call GENERAR_CSV(DIR, EFICHERO, BANCO, LDIA, LMES, LANYO)
Gosub CERRAR_TBL
Call ECR_TRACE("Proceso Finalizado.",0) From GESECRAN
Call FERME_TRACE From LECFIC
Infbox "Proceso finalizado."
Call LEC_TRACE From LECFIC
End

############################################################################################
#* Funcion que lee el fichero original y almacena los registros en la tabla ZCONTAIMPORT [ZCIMPORT]
#*
Subprog LEER_FICHERO(PDIRECTORIO, PFICHERO, PDIA, PMES, PANYO, PBANCO)
Local Char CAMPO(200)(30)
Local Char LDIRMPORT(250) : LDIRIMPORT = PDIRECTORIO
Local Char LFILE_R(200)   : LFILE_R = PDIRECTORIO + PFICHERO
Local Integer LNUMEXP, LECOK, SUCCESS : Raz LNUMEXP, LECOK, SUCCESS
#Infbox "El fichero que vamos a leer es " + LFILE_R

#Abrimos el fichero
Gosub OPEN_FILE_R
Iomode adxium 50 Using [ZIMP_R] # 50 = ASCII 0 = UTF8
If filinfo(LFILE_R, 7) > 0 Then
  #Infbox "Fichero abierto!"
  LECOK = 1
  Repeat
    # leer el archivo
    Rdseq CAMPO(1),CAMPO(2),CAMPO(3), CAMPO(4),CAMPO(5),CAMPO(6),CAMPO(7), CAMPO(8),CAMPO(9),CAMPO(10)  Using [ZIMP_R]
    If fstat = 0 Then
      LNUMEXP += 1
      #Infbox "Estamos en la linea " + num$(LNUMEXP) + " y los valores son " + CAMPO(1) + ";" + CAMPO(2)
      #Infbox "Los datos del campo 1 en la linea " + num$(LNUMEXP) + " son " + vireblc(CAMPO(1),2) # Test para ver si lee la linea
      [F:ZCIMPORT]ZTIENDA = CAMPO(1)
      [F:ZCIMPORT]ZCUENTA = CAMPO(2)
      [F:ZCIMPORT]ZCODTIENDA = CAMPO(3)
      LSALDOTMP = ctrans(CAMPO(4),".","")
      [F:ZCIMPORT]ZSALDO = val(ctrans(LSALDOTMP,",",".")) # Adaptamos el valor del saldo quitandole el . y cambiando la , por .
      [F:ZCIMPORT]ZFECHA  = gdat$(val(PDIA), val(PMES), val(PANYO)) # -num$(PMES)-num$(PANYO)] # Vendrá en los parametros [01/10/2016]
      [F:ZCIMPORT]ZBANCDEST = PBANCO # VENDRA EN LOS PARAMETROS
      [F:ZCIMPORT]ZSTAIMP  = 1 #1-Registro no Importado
      [F:ZCIMPORT]ZASGEN  = "0"
      [F:ZCIMPORT]ZFIC  = mid$(PFICHERO,1,len(PFICHERO)-4) #Nombre del fichero donde está la línea - Quizás sea util para retroceder
      Write [F:ZCIMPORT]
      #ESCRIBIMOS LA TRAZA DEPENDIENDO DEL RESULTADO
      If fstat <> 0 Then
          #Call ECR_TRACE("No se puede leer la linea:  " + LNUMEXP, 1) From GESECRAN
        Else
          #Call ECR_TRACE("Linea " + LNUMEXP + "insertada. ", 0) From GESECRAN
        Endif
    Else
      LECOK = 0
    Endif
  Until LECOK = 0
Endif
#Cerramos el fichero
Gosub CLOSE_FILE_R
#Infbox "Proceso de generación de registro en tabla Finalizado."
End

############################################################################################
#* Subprograma que genera el fichero CSV, llama al modelo de importacion y recupera el nº de Asiento Creado
#* Posteriormente una vez actualizado el registro de ZCONTAIMPORT con el numero de asiento lo marca como procesado (3)
Subprog GENERAR_CSV(PDIRECTORIO, PFICHERO, BANCO, PDIA, PMES, PANYO)
Local Char CAMPO(200)(30)
Local Char LDIRMPORTW(250) : LDIRIMPORTW = PDIRECTORIO
Local Char LFECHA(10), LHORA(10) : Raz LFECHA, LHORA
Local Char LSEP(1) : LSEP = ";"  # LSEParador
Local Char LBLA(1) : LBLA = ""  # LBLAnco
Local Char LSOCIEDAD, LPLAN, LCUENTA, LDIVISA #Sociedad, Planta y Cuenta
Local Char LCCEMITE, LCCRECIBE, LTEREMITE, LTERRECIBE
Local Char LDIA : LDIA = PDIA
Local Char LMES : LMES = PMES
Local Char LANYO : LANYO = PANYO
Local Char LFECHAPARAM : LFECHAPARAM = LANYO + LMES + LDIA
Local Integer SUCCESS : Raz SUCCESS
Local Char LFILE_W(200) : Raz LFILE_W


Filter [ZCIMPORT] Where [ZCIMPORT]ZSTAIMP = 1  # filtra los pendientes de procesar

#Call ECR_TRACE("Registros encontrados : " + num$(rowcount([ZSWD])) , 0) From GESECRAN
#Si hay registros recorremos la tabla para generar la cabecera y las lineas
#Infbox "Los registros son" + num$(rowcount([ZCIMPORT]))
If rowcount([ZCIMPORT]) > 0 Then
  #En este bucle es donde escribimos la cabecera y linea de los Asientos
  For [ZCIMPORT]
    LSOCIEDAD = ""
    LPLAN  = ""
    LCUENTA = ""
    LDIVISA = ""
    LCCEMITE = ""
    LCCRECIBE = ""
    LTEREMITE = ""
    LTERECIBE = ""

    LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
    LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)
    LFILE_W = PDIRECTORIO + mid$(PFICHERO,1,len(PFICHERO)-4) + LFECHA + LHORA #LFILE_W = PDIRECTORIO + PFICHERO + LFECHA + LHORA
    #Infbox "El fichero es " + LFILE_W

    Call GET_DATOS_RECIBE([F:ZCIMPORT]ZCUENTA, LSOCIEDAD, LPLAN, LCUENTA, LTERECIBE, LCCRECIBE)
    Call GET_DATOS_EMITE(LDIVISA, BANCO, LTEREMITE, LCCEMITE)

    Gosub $OPEN_FILE_W
    #Infbox "El registro es " + [ZCIMPORT]ZTIENDA
    #La variable BANCO debe venir de los parametros, al igual que _FECHA
    Wrseq "G" + LSEP + "ODGEN" + LSEP + LBLA + LSEP +  LPLAN + LSEP + "ZBANK" + LSEP + LFECHAPARAM + LSEP + LCUENTA + LSEP + BANCO + LSEP + LDIVISA + LSEP + "STDCO" +
& LSEP + LFECHA+LHORA+mid$(PFICHERO,1,len(PFICHERO)-4) + LSEP Using [ZIMP_W] #_REF viene como parámetro, es la cuenta que emite
    Wrseq "D" + LSEP + "1" + LSEP + "1" + LSEP + "1" + LSEP + LPLAN + LSEP + LCCEMITE + LSEP + LTEREMITE + LSEP + "1" + LSEP + num$([F:ZCIMPORT]ZSALDO) + LSEP + LDIVISA + LSEP Using [
& ZIMP_W
& ]
    Wrseq "D" + LSEP + "2" + LSEP + "1" + LSEP + "2" + LSEP + LPLAN + LSEP + LCCRECIBE + LSEP + LTERECIBE + LSEP + "-1" + LSEP + num$([F:ZCIMPORT]ZSALDO) + LSEP + LDIVISA + LSEP Using [
& ZIMP_W]
    [F:ZCIMPORT]ZSTAIMP = 3
    [F:ZCIMPORT]ZFIC = LFECHA+LHORA+mid$(PFICHERO,1,len(PFICHERO)-4)
    Rewrite[ZCIMPORT]

    # BUSCAR ASIENTO
    # ACTUALIZAR ZCIMPORT
    Gosub $CLOSE_FILE_W

    #Llamamos al modelo de importacion
    GERRTRACE = 0
    Call IMPORTSIL('ZGAS3',LFILE_W + ".CSV") From GIMPOBJ #Ver con Mario llamada sin filpath
    #Call ECR_TRACE("Modelo de Importación ejecutado para " + LFILE_W + ".CSV" ,0) From GESECRAN

    Local Char LTEMPORAL : LTEMPORAL = 'ODG-OF00119090001'
    #Si el modelo ha ido bien buscamos el asiento y cambiamos tanto ZSTAIMP (Estado) como ZASGEN(Asiento) en ZCIMPORT
    #Infbox "Vamos a buscar por BPRVCR " + LFECHA+LHORA+mid$(PFICHERO,1,len(PFICHERO)-4)
    Filter [HAE] Where BPRVCR = LFECHA+LHORA+mid$(PFICHERO,1,len(PFICHERO)-4) #LTEMPORAL
    Read [HAE] First
    If !fstat Then
      [F:ZCIMPORT]ZASGEN = [F:HAE]NUM
      Rewrite[ZCIMPORT]
      Call ECR_TRACE("Generado Asiento " + [F:HAE]NUM + " de fichero " + mid$(PFICHERO,1,len(PFICHERO)-4) + LFECHA + LHORA + ".CSV",0) From GESECRAN
    Endif
    Filter[HAE]
  Next

  Call ECR_TRACE("Proceso finalizado para fichero CSV: " + LFILE_W, 0) From GESECRAN
  If filinfo(PDIRECTORIO+PFICHERO,7) > 0 Then
    LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
    LHORA = vireblc(num$(time$),4) : LHORA = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)
    DESPATH = PDIRECTORIO+"FIN\OK_" + LFECHA + LHORA + PFICHERO
    #Infbox "El fichero origen a mover es " + PDIRECTORIO + PFICHERO
    #Infbox "El fichero destino a mover sera " + DESPATH
    SUCCESS =  renameFile(PDIRECTORIO+PFICHERO,DESPATH)
  #Infbox "Proceso mover fichero finalizado. SUCCESS es " + num$(SUCCESS)
  Endif
Endif
End

#Abrimos tablas
$ABRIR_TBL
If clalev([ZCIMPORT])  = 0   Local File ZCONTAIMPORT [ZCIMPORT] : Endif # tabla intermedia para conversión
If clalev([HAE])  = 0   Local File GACCENTRY [HAE] : Endif
Return

$CERRAR_TBL
Close Local File [ZCIMPORT]
Close Local File [HAE]
Return

#Etiqueta donde se abre el fichero
#Delimitamos el separados y los campos de salto de linea
$OPEN_FILE_R
adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openi LFILE_R Using [ZIMP_R]
Iomode adxium 50 Using [ZIMP_R] # 50 = ASCII 0 = UTF8
Return

#Etiqueta que cierra el fichero
$CLOSE_FILE_R
Openo Using [ZIMP_R]
Return

#Abre fichero para escritura
$OPEN_FILE_W
adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo filpath('IMP', LFILE_W, 'csv',nomap)  Using [ZIMP_W]
Return

#Cierra fichero en el que hemos escrito
$CLOSE_FILE_W
Openo Using [ZIMP_W]
Return

#Buscamos la Sociedad y de ahí la planta
Subprog  GET_DATOS_RECIBE(CUENTA, LSOCIEDAD, LPLAN, LCUENTA, LTERECIBE, LCCRECIBE)
Variable Char LSOCIEDAD
Variable Char LPLAN
Variable Char LCUENTA
Variable Char LTERECIBE
Variable Char LCCRECIBE
Variable Integer LDIARIOR

LDIARIOR = 0
If clalev([BAN])  = 0   Local File BANK   [BAN] : Endif
If clalev([CPY])  = 0   Local File COMPANY   [CPY] : Endif
Filter [BAN] Where BIDNUM = vireblc(CUENTA,4)
Read [BAN] First
If !fstat Then
    LSOCIEDAD = [F:BAN]CPY
    #LCUENTA = [F:BAN]BAN
    LCUENTA = [F:BAN]BAN-[F:BAN]DES
    LTERECIBE = [F:BAN]BANBPR
    LDIARIOR = find(1,[F:BAN]JOUTYP(0.. 9))
    #Infbox "LDIARIOR es = " & LDIARIOR
    LCCRECIBE = [F:BAN]TREACC(LDIARIOR-1)
#    LCCRECIBE = [F:BAN]TREACC #OJO PORQUE ES UN MENU
    Filter [CPY] Where CPY = LSOCIEDAD
    Read [CPY] First
    If !fstat Then
      LPLAN = [F:CPY]MAIFCY
    Else
      LPLAN = ""
    Endif
  Else
    LSOCIEDAD = ""
    LPLAN = ""
    LCUENTA = ""
    LTERECIBE = ""
    LCCRECIBE = ""
Endif
#Infbox "LSOCIEDAD ES " + LSOCIEDAD
#Infbox "LPLANTA ES " + LPLAN
Close File [BAN]
Close File [CPY]
End

Subprog GET_DATOS_EMITE(LDIVISA, BANCO, LTEREMITE, LCCEMITE)
Variable Char LDIVISA
Variable Char LTEREMITE
Variable Char LCCEMITE
Variable Char LDIARIOE

LDIARIOE = 0
If clalev([BAN])  = 0   Local File BANK   [BAN] : Endif
Filter [BAN] Where BAN = BANCO
Read [BAN] First
If !fstat Then
  LDIVISA = [F:BAN]CUR
  LTEREMITE = [F:BAN]BANBPR
  LDIARIOE = find(1,[F:BAN]JOUTYP(0.. 9))
  #Infbox "LDIARIOE es = " & LDIARIOE
  LCCEMITE = [F:BAN]TREACC(LDIARIOE-1)
  #LCCEMITE = [F:BAN]TREACC #OJO PORQUE ES UN MENU
Else
  LDIVISA = ""
  LTEREMITE = ""
  LCCEMITE
Endif
Close File[BAN]
End

