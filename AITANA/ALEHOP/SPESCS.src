# Gestión de la máscara SSL1 (Especifico)
######################################################################################
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION

  When Default
Endcase
Return

# When "FIN_ACTION"  : Gosub FIN_ACTION

######################################################################################
$FIN_ACTION

If [M:SCS1]SGHTYP = 'SCI' Then     # Transferencia interplanta
  If !clalev ([S0]) : Local File STOSRG [S0] : Endif
  Filter [S0] Where [S0]VCRNUM = [M:SCS1]VCRNUM

  Read [S0]
  If !fstat Then
    If [S0]TRSTYP = '14' Then
    Endif
  Endif

Endif

Return

