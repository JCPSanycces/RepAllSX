#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog MAIN()
##tablas de destino
If !clalev([F:ZSVA]   ) : Local File ZSEMANASVA [ZSVA]    : Endif
If !clalev([F:ZSVT]   ) : Local File ZSEMANASVT [ZSVT]    : Endif
If !clalev([F:ZVAMEDI]) : Local File ZVAMEDIAS  [ZVAMEDI] : Endif
If !clalev([F:ZVTMEDI]) : Local File ZVTMEDIAS  [ZVTMEDI] : Endif

#vistas de origen
If !clalev([F:ZSVAW]   ) : Local File ZSEMANASVAW [ZSVAW]    : Endif
If !clalev([F:ZSVTW]   ) : Local File ZSEMANASVTW [ZSVTW]    : Endif
If !clalev([F:ZVAMEDIW]) : Local File ZVAMEDIASW  [ZVAMEDIW] : Endif
If !clalev([F:ZVTMEDIW]) : Local File ZVTMEDIASW  [ZVTMEDIW] : Endif


Local Integer CZSVA, CZSVT, CZVAMEDI, CZVTMEDI

Local Integer YSTAT
Local Char FECHA(10)

If !GSERVEUR Then
  Call OUINON ("¿Actualizar tablas?", YSTAT ) From GESECRAN
Else
  YSTAT=2
Endif

If YSTAT=2 Then

  Call OUVRE_TRACE ("Actualización de tablas de acumulados 2") From LECFIC
  Gosub ACT_ZSVA
  Gosub ACT_ZSVT
  Gosub ACT_ZVAMEDI

  If !GSERVEUR : Infbox "Actualización finalizada" : Endif
  Call FERME_TRACE From LECFIC
  If !GSERVEUR
    Call LEC_TRACE() From LECFIC
  Endif
Endif

End


$ACT_ZSVA
  Call ECR_TRACE("Actualizar ZSVA",0) From GESECRAN

  CZSVA = 0
  For [F:ZSVAW]
    CZSVA+=1
    Read [F:ZSVA]ITM=[F:ZSVAW]ITMREF;[F:ZSVAW]TIPOTIENDA;[F:ZSVAW]ANY;[F:ZSVAW]SEMANA
    If !fstat Then
      Update [F:ZSVA] Where ITMREF=[F:ZSVAW]ITMREF and TIPOTIENDA=[F:ZSVAW]TIPOTIENDA and ANY=[F:ZSVAW]ANY and SEMANA=[F:ZSVAW]SEMANA
&      With QTY = [F:ZSVAW]CANTIDAD, VALOR=[F:ZSVAW]VALOR
       Call ECR_TRACE("ZSVA - update: "  + [F:ZSVAW]ITMREF + " " + [F:ZSVAW]TIPOTIENDA + " " + num$([F:ZSVAW]ANY) + " " + num$([F:ZSVAW]SEMANA), 0 ) From GESECRAN
    Else
      Trbegin [F:ZSVA]
      [F:ZSVA]=[F:ZSVAW]
      Write [F:ZSVA]
      If fstat=0
        Commit
        Call ECR_TRACE("ZSVA - write: "  + [F:ZSVAW]ITMREF + " " + [F:ZSVAW]TIPOTIENDA + " " + num$([F:ZSVAW]ANY) + " " + num$([F:ZSVAW]SEMANA), 0 ) From GESECRAN
      Else
        Rollback
        Call ECR_TRACE("ZSVA - err-write: "  + [F:ZSVAW]ITMREF + " " + [F:ZSVAW]TIPOTIENDA + " " + num$([F:ZSVAW]ANY) + " " + num$([F:ZSVAW]SEMANA), 1 ) From GESECRAN
      Endif
    Endif
  Next
  Call ECR_TRACE("ZSVA - número de registros tratados: " + num$(CZSVA),0) From GESECRAN
Return

$ACT_ZSVT
  Call ECR_TRACE("Actualizar ZSVT",0) From GESECRAN

  CZSVT = 0
  For [F:ZSVTW]
    CZSVT+=1
    Read [F:ZSVT]ITM=[F:ZSVTW]ITMREF;[F:ZSVTW]TIPOTIENDA;[F:ZSVTW]ANY;[F:ZSVTW]SEMANA
    If !fstat Then
      Update [F:ZSVT] Where ITMREF=[F:ZSVTW]ITMREF and TIPOTIENDA=[F:ZSVTW]TIPOTIENDA and ANY=[F:ZSVTW]ANY and SEMANA=[F:ZSVTW]SEMANA
&      With QTY = [F:ZSVTW]CANTIDAD, VALOR=[F:ZSVTW]PVP
       Call ECR_TRACE("ZSVT - update: "  + [F:ZSVTW]ITMREF + " " + [F:ZSVTW]TIPOTIENDA + " " + num$([F:ZSVTW]ANY) + " " + num$([F:ZSVTW]SEMANA), 0 ) From GESECRAN
    Else
      Trbegin [F:ZSVT]
      [F:ZSVT]=[F:ZSVTW]
      Write [F:ZSVT]
      If fstat=0
        Commit
        Call ECR_TRACE("ZSVT - write: "  + [F:ZSVTW]ITMREF + " " + [F:ZSVTW]TIPOTIENDA + " " + num$([F:ZSVTW]ANY) + " " + num$([F:ZSVTW]SEMANA), 0 ) From GESECRAN
      Else
        Rollback
        Call ECR_TRACE("ZSVT - err-write: "  + [F:ZSVTW]ITMREF + " " + [F:ZSVTW]TIPOTIENDA + " " + num$([F:ZSVTW]ANY) + " " + num$([F:ZSVTW]SEMANA), 1 ) From GESECRAN
      Endif
    Endif
  Next
  Call ECR_TRACE("ZSVT - número de registros tratados: " + num$(CZSVT),0) From GESECRAN
Return


$ACT_ZVAMEDI
  Call ECR_TRACE("Actualizar ZVAMEDI",0) From GESECRAN

  CZVAMEDI = 0
  For [F:ZVAMEDIW]
    CZVAMEDI+=1
    Read [F:ZVAMEDI]ITMREF=[F:ZVAMEDIW]ITMREF;[F:ZVAMEDIW]ANY
    If !fstat Then
      Update [F:ZVAMEDI] Where ITMREF=[F:ZVAMEDIW]ITMREF and ANY=[F:ZVAMEDIW]ANY
&      With QTY = [F:ZVAMEDIW]CANTIDAD, VALOR=[F:ZVAMEDIW]VALOR, NSEMANAS=[F:ZVAMEDIW]NSEMANAS
       Call ECR_TRACE("ZVAMEDI - update: "  + [F:ZVAMEDIW]ITMREF + " " + num$([F:ZVAMEDIW]ANY) , 0 ) From GESECRAN
    Else
      Trbegin [F:ZVAMEDI]
      [F:ZVAMEDI]=[F:ZVAMEDIW]
      Write [F:ZVAMEDI]
      If fstat=0
        Commit
       Call ECR_TRACE("ZVAMEDI - write: "  + [F:ZVAMEDIW]ITMREF + " " + num$([F:ZVAMEDIW]ANY) , 0 ) From GESECRAN
      Else
        Rollback
       Call ECR_TRACE("ZVAMEDI - err-write: "  + [F:ZVAMEDIW]ITMREF + " " + num$([F:ZVAMEDIW]ANY) , 1 ) From GESECRAN
      Endif
    Endif
  Next
  Call ECR_TRACE("ZVAMEDI - número de registros tratados: " + num$(CZVAMEDI),0) From GESECRAN
Return



$ZVTMEDI
  Call ECR_TRACE("Actualizar ZVTMEDI",0) From GESECRAN

  CZVTMEDI = 0
  For [F:ZVTMEDIW]
    CZVTMEDI+=1
    Read [F:ZVTMEDI]ITMREF=[F:ZVTMEDIW]ITMREF;[F:ZVTMEDIW]ANY
    If !fstat Then
      Update [F:ZVTMEDI] Where ITMREF=[F:ZVTMEDIW]ITMREF and ANY=[F:ZVTMEDIW]ANY
&      With QTY = [F:ZVTMEDIW]QTY, PVP=[F:ZVTMEDIW]PVP, NSEMANAS=[F:ZVTMEDIW]NSEMANAS
       Call ECR_TRACE("ZVTMEDI - update: "  + [F:ZVTMEDIW]ITMREF + " " + num$([F:ZVTMEDIW]ANY) , 0 ) From GESECRAN
    Else
      Trbegin [F:ZVTMEDI]
      [F:ZVTMEDI]=[F:ZVTMEDIW]
      Write [F:ZVTMEDI]
      If fstat=0
        Commit
       Call ECR_TRACE("ZVTMEDI - write: "  + [F:ZVTMEDIW]ITMREF + " " + num$([F:ZVTMEDIW]ANY) , 0 ) From GESECRAN
      Else
        Rollback
       Call ECR_TRACE("ZVTMEDI - err-write: "  + [F:ZVTMEDIW]ITMREF + " " + num$([F:ZVTMEDIW]ANY) , 1 ) From GESECRAN
      Endif
    Endif
  Next
  Call ECR_TRACE("ZVTMEDI - número de registros tratados: " + num$(CZVTMEDI),0) From GESECRAN
Return

