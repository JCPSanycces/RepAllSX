##########################################################
#**
#* Genera una salida y una entrada varia
#*
#* @param PTYPENT > tipo de entrada
#* @param PNUMENT > nĂşmero entrada
#*!
Subprog GEN_ENTSAL(PTYPENT, PNUMENT)
Value Integer PTYPENT
Value Char    PNUMENT

Local Char    LDIREXPORT(100) : LDIREXPORT = "E:\import\IMP\"
Local Char    LFILE(200), LFILECOPY(200)
Local Char    LSEP(1) : LSEP = ";"  # separador PARA TODOS LOS FICHEROS
Local Char    LNUMSALNEW(30), LNUMENTNEW(30) # cĂłdigo salida y entrada generados
Local Integer LINTENT # intentos

# utilizado para generar ficheros Ăşnicos
Local Char LFECHA(10), LHORA(10)
LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

# abrir tablas
Gosub ABRIR_TBL

# si se lanza la tarea batch
If !GSERVEUR Then
  Call TEMPON("GeneraciĂłn DevoluciĂłn En preparaciĂłn") From GESECRAN
  Call OUVRE_TRACE("GeneraciĂłn DevoluciĂłn En preparaciĂłn") From LECFIC
Endif

If !GSERVEUR Then
  Call TEMPON("GeneraciĂłn fichero salida ordenaciĂłn... ") From GESECRAN
Endif

Gosub GEN_SMO

Gosub IMP_SMO  # importa primero la salida

# hay que comprobar que la salida ha sido generada por modelo
While LINTENT < 5
  # buscamos si la salida ha sido creada y apuntamos el nĂşmero
  Filter [T0] Where [T0]TRSFAM = "24" and [T0]VCRDES = LDATCAB(4)
    Read [T0] First
    If !fstat Then
      LNUMSALNEW = [T0]VCRNUM
      [T0]ZFLAGPREP = 2
      Rewrite [T0]
    Endif
  Filter [T0]

  If LNUMSALNEW = "" Then
    Sleep 2
    LINTENT += 1
  Else
    LINTENT = 6 # para salir directos..
  Endif
Wend

If LNUMSALNEW = "" Then
  Infbox "Error en la importaciĂłn de la salida de ordenaciĂłn"
Else

  If !GSERVEUR Then
    Call TEMPON("GeneraciĂłn fichero entrada ordenaciĂłn... ") From GESECRAN
  Endif
  ## ENTRADAS
  Gosub GEN_SMR
  Gosub IMP_SMR  # importa entrada

  Raz LINTENT
  # hay que comprobar que la salida ha sido generada por modelo
  While LINTENT < 5
    # buscamos si la salida ha sido creada y apuntamos el nĂşmero
    Filter [T0] Where [T0]TRSFAM = "11" and [T0]VCRDES = LDATCAB(4)
      Read [T0] First
      If !fstat Then
        LNUMENTNEW = [T0]VCRNUM
      Endif
    Filter [T0]

    If LNUMENTNEW = "" Then
      Sleep 2
      LINTENT += 1
    Else
      LINTENT = 6 # para salir directos..
    Endif
  Wend
Endif

# mostrar traza
Gosub GET_TRAZA

If !GSERVEUR Then
  Call TEMPOFF() From GESECRAN

  # fin de traza
  Call FERME_TRACE From LECFIC
  # lectura
  Call LEC_TRACE From LECFIC
Endif

# cerrar tablas
Gosub CERRAR_TBL

End

########################################################
#**
#* Genera una salida de stock OrdenaciĂłn
#*!
$GEN_SMO
Local Char LDATCAB(30)(7),LDATLIN(30)(4),LDATJOU(30)(5)

# ruta del fichero..
LFILE  = LDIREXPORT + "SMO_"+LFECHA+"_"+LHORA+".txt"

# apertura de fichero
Gosub OPEN_FILE

#####
# SMVTH - cabecera
###
# 1 -> Tipo asiento
# 2 -> Planta stock
# 3 -> Fecha imputaciĂłn
# 4 -> DescripciĂłn
# 5 -> CĂłdigo del movimiento
# 6 -> Familia movimiento
#####

# siempre serĂˇn entradas varias
Read [T0]SMH0 = PTYPENT;PNUMENT
If !fstat Then
  Raz LDATCAB

  LDATCAB(1) = "20"         # salida varia
  LDATCAB(2) = [T0]STOFCY
  LDATCAB(3) = date$
  LDATCAB(4) = [T0]VCRDES
  LDATCAB(5) = "SOR"        # Cod. movimiento > salida de ordenaciĂłn
  LDATCAB(6) = "24"         # Fam. movimiento > salida de ordenaciĂłn

  # escribimos en el fichero
  Wrseq '"E";' +
&       '"' + LDATCAB(1) + '"' + LSEP +
&       '"' + LDATCAB(2) + '"' + LSEP +
&       '"' + LDATCAB(3) + '"' + LSEP +
&       '"' + LDATCAB(4) + '"' + LSEP +
&       '"' + LDATCAB(5) + '"' + LSEP +
&       '"' + LDATCAB(6) + '"' + LSEP
&       Using [ZEXP]
Endif


#####
# SMVTD - detalle
###
# 1 -> ArtĂ­culo
# 2 -> Unidad
# 3 -> Cantidad
#####
# STOJOU - diario
###
# 1 -> Unidad
# 2 -> Cantidad
# 3 -> UbicaciĂłn
# 4 -> Estado
####
# componemos el fichero de detalle y diario
Filter [T1] Where [T1]VCRTYP = PTYPENT and [T1]VCRNUM = PNUMENT Order By [T1]VCRLIN Asc
  For [T1]
    #####
    # SMVTD - detalle
    ###
    # 1 -> ArtĂ­culo
    # 2 -> Unidad
    # 3 -> Cantidad
    #####

    Raz LDATLIN
    LDATLIN(1) = [T1]ITMREF
    LDATLIN(2) = [T1]PCU
    LDATLIN(3) = num$([T1]QTYPCU)

    # escribimos en el fichero
    Wrseq '"L";' +
&         '"' + LDATLIN(1) + '"' + LSEP +
&         '"' + LDATLIN(2) + '"' + LSEP +
&         '"' + LDATLIN(3) + '"' + LSEP
&       Using [ZEXP]

    #####
    # STOJOU - diario
    ###
    # 1 -> Unidad
    # 2 -> Cantidad
    # 3 -> UbicaciĂłn
    # 4 -> Estado
    ####
    Raz LDATJOU
    LDATJOU(1) = [T1]PCU
    LDATJOU(2) = num$([T1]QTYPCU)

    # stojou
    Filter [S0] Where [S0]VCRNUM = PNUMENT and [S0]ITMREF = [T1]ITMREF Order By [S0]CREDATTIM Desc
      Read [S0] First
      If !fstat Then
        LDATJOU(3) = [S0]LOC
        LDATJOU(4) = [S0]STA
      Endif
    Filter [S0]

    # escribimos en el fichero
    Wrseq '"S";' +
&         '"' + LDATJOU(1) + '"' + LSEP +
&         '"' + LDATJOU(2) + '"' + LSEP +
&         '"' + LDATJOU(3) + '"' + LSEP +
&         '"' + LDATJOU(4) + '"' + LSEP
&       Using [ZEXP]
  Next
Filter [T1]

# cerrar fichero import
Gosub CLOSE_FILE
Return

########################################################
#**
#* Importa movimiento de salida
#*!
$IMP_SMO
mkstat = 0 : fstat = 0 : GERRTRACE = 0

#Call OUVRE_TRACE("CreaciĂłn Recepcion a partir de Entrega Validada") From LECFIC

Call IMPORTSIL("ZSMO", LFILE) From GIMPOBJ

#Call FERME_TRACE From LECFIC
#Call LEC_TRACE From LECFIC   #si se quiere mostrar traza

mkstat = 0 : fstat = 0 : GERRTRACE = 0
Return

########################################################
#**
#* Genera una entrada de stock OrdenaciĂłn
#*!
$GEN_SMR
Local Char LDATCAB(30)(7),LDATLIN(30)(5),LDATJOU(30)(5)

# ruta del fichero..
LFILE  = LDIREXPORT + "SMR_"+LFECHA+"_"+LHORA+".txt"

# apertura de fichero
Gosub OPEN_FILE

#####
# SMVTH - cabecera
###
# 1 -> Tipo asiento
# 2 -> Planta stock
# 3 -> Fecha imputaciĂłn
# 4 -> DescripciĂłn
# 5 -> CĂłdigo del movimiento
# 6 -> Familia movimiento
#####

# siempre serĂˇn entradas varias
Read [T0]SMH0 = PTYPENT;PNUMENT
If !fstat Then
  Raz LDATCAB

  LDATCAB(1) = "19"         # entrada varia
  LDATCAB(2) = [T0]STOFCY
  LDATCAB(3) = date$
  LDATCAB(4) = [T0]VCRDES
  LDATCAB(5) = "EOR"        # Cod. movimiento > salida de ordenaciĂłn
  LDATCAB(6) = "11"         # Fam. movimiento > salida de ordenaciĂłn

  # escribimos en el fichero
  Wrseq '"E";' +
&       '"' + LDATCAB(1) + '"' + LSEP +
&       '"' + LDATCAB(2) + '"' + LSEP +
&       '"' + LDATCAB(3) + '"' + LSEP +
&       '"' + LDATCAB(4) + '"' + LSEP +
&       '"' + LDATCAB(5) + '"' + LSEP +
&       '"' + LDATCAB(6) + '"' + LSEP
&       Using [ZEXP]
Endif


#####
# SMVTD - detalle
###
# 1 -> ArtĂ­culo
# 2 -> Unidad
# 3 -> Cantidad
#####
# STOJOU - diario
###
# 1 -> Unidad
# 2 -> Cantidad
# 3 -> UbicaciĂłn
# 4 -> Estado
####
# componemos el fichero de detalle y diario
Filter [T1] Where [T1]VCRTYP = PTYPENT and [T1]VCRNUM = PNUMENT Order By [T1]VCRLIN Asc
  For [T1]
    #####
    # SMVTD - detalle
    ###
    # 1 -> ArtĂ­culo
    # 2 -> Unidad
    # 3 -> Cantidad
    #####

    Raz LDATLIN
    LDATLIN(1) = [T1]ITMREF
    LDATLIN(2) = [T1]PCU
    LDATLIN(3) = num$([T1]QTYPCU)
    LDATLIN(4) = num$([T1]PRIORD)

    # escribimos en el fichero
    Wrseq '"L";' +
&         '"' + LDATLIN(1) + '"' + LSEP +
&         '"' + LDATLIN(2) + '"' + LSEP +
&         '"' + LDATLIN(3) + '"' + LSEP +
&         '"' + LDATLIN(4) + '"' + LSEP
&       Using [ZEXP]

    #####
    # STOJOU - diario
    ###
    # 1 -> Unidad
    # 2 -> Cantidad
    # 3 -> UbicaciĂłn
    # 4 -> Estado
    ####
    Raz LDATJOU
    LDATJOU(1) = [T1]PCU
    LDATJOU(2) = num$([T1]QTYPCU)
    LDATJOU(3) = "MUELLE"
    LDATJOU(4) = "A"


    # escribimos en el fichero
    Wrseq '"S";' +
&         '"' + LDATJOU(1) + '"' + LSEP +
&         '"' + LDATJOU(2) + '"' + LSEP +
&         '"' + LDATJOU(3) + '"' + LSEP +
&         '"' + LDATJOU(4) + '"' + LSEP
&       Using [ZEXP]
  Next
Filter [T1]

# cerrar fichero import
Gosub CLOSE_FILE
Return

########################################################
#**
#* Importa movimiento de entrada
#*!
$IMP_SMR
mkstat = 0 : fstat = 0 : GERRTRACE = 0

#Call OUVRE_TRACE("CreaciĂłn Recepcion a partir de Entrega Validada") From LECFIC

Call IMPORTSIL("ZSMR", LFILE) From GIMPOBJ

#Call FERME_TRACE From LECFIC
#Call LEC_TRACE From LECFIC   #si se quiere mostrar traza

mkstat = 0 : fstat = 0 : GERRTRACE = 0
Return

#######################################################
$GET_TRAZA
Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
Call ECR_TRACE("DevoluciĂłn procesada     : " + PNUMENT, 0) From GESECRAN
Call ECR_TRACE("Salida varia ordenaciĂłn  : " + LNUMSALNEW, 0) From GESECRAN
Call ECR_TRACE("Entrada varia ordenaciĂłn : " + LNUMENTNEW, 0) From GESECRAN

Return

########################################################
$OPEN_FILE
adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE Using [ZEXP]
Return

########################################################
$CLOSE_FILE
Openo Using [ZEXP]
Return

##########################################################
$ABRIR_TBL
If clalev([T0]) = 0 : Local File SMVTH  [T0] : Endif  # movimientos cab.
If clalev([T1]) = 0 : Local File SMVTD  [T1] : Endif  # movimientos lin.
If clalev([S0]) = 0 : Local File STOJOU [S0] : Endif  # diario
Return

#########################################################
$CERRAR_TBL
Close Local File [T0], [T1], [S0]
Return

