# Gestión de la máscara CONSSMV2 (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla CONSSMV2) 01/09/2020 13:52:41 (JVIDA)
######################################################################################
Subprog AV_ZVCRDES(VALEUR)
Variable Char    VALEUR()
 Raz VALEUR
 If !clalev ([F:SMH]) : Local File SMVTH [SMH] : Endif
 If [M:SMV2]VCRTYP(nolign-1) = 19
  Read [F:SMH]SMH0=[M:SMV2]VCRTYP(nolign-1);[M:SMV2]VCRNUM(nolign-1)
  If !fstat
    VALEUR = [F:SMH]VCRDES
  Endif
 Endif
End


