Call EXPORTAR_PIC()
End

##########################################################
#**
#* Exportación ficheros a PIC
#*!
Subprog EXPORTAR_PIC()
Local Char    LDIREXPORT(100) : LDIREXPORT = "E:\EXPORT\PIC\"
Local Char    LFILE(200), LFILECOPY(200)
#Local Char LSEP(1) : LSEP = ";"  # separador PARA TODOS LOS FICHEROS  #AQS.o
Local Char LSEP(1) : LSEP = chr$(12)  # separador PARA TODOS LOS FICHEROS TABULADOR   #AQS.n

Local Integer LTOTITM # número total de artículos exportados..
Local Integer LTOTEAN # número total de códigos ean

# utilizado para la copia de histórico de ficheros
Local Char LFECHA(10), LHORA(10)
LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

# abrir tablas
Gosub ABRIR_TBL

# si se lanza la tarea batch
If !GSERVEUR Then
#AQS.so
#  Call TEMPON("Proceso exportación PIC") From GESECRAN
#  Call OUVRE_TRACE("Proceso exportación PIC") From LECFIC
#AQS.eo
#AQS.sn
  Call TEMPON("Proceso exportación Cástor") From GESECRAN
  Call OUVRE_TRACE("Proceso exportación Cástor") From LECFIC
#AQS.en
Endif

# generación fichero de artículos
If !GSERVEUR Then
  Call TEMPON("Generación de artículos") From GESECRAN
Endif
Gosub GEN_ARTICULOS

# generación fichero de códigos ean
If !GSERVEUR Then
  Call TEMPON("Generación de códigos ean") From GESECRAN
Endif
Gosub GEN_ARTEAN

# traza
Gosub GET_TRAZA


If !GSERVEUR Then
  Call TEMPOFF() From GESECRAN

  # fin de traza
  Call FERME_TRACE From LECFIC
  # lectura
  Call LEC_TRACE From LECFIC
Endif

# cerrar tablas
Gosub CERRAR_TBL
End

##########################################################
#**
#* Genera fichero de exportación a PIC de artículos
#*!
$GEN_ARTICULOS
Local Char    LDATLIN(50)(15)
Local Integer I : I=1
Local Integer MAXI : MAXI=17

LFILECOPY   = LDIREXPORT + "COPIA\articulos_" + LFECHA + "_" + LHORA + ".txt"
LFILE       = LDIREXPORT + "articulos.txt"

# borramos el fichero si existe...
Gosub DEL_FILE

# abrir fichero..
Gosub OPEN_FILE

# recorremos todos los artículos
# pendiente: aquellos artículos desde la última export
For [I0]ITM0
  Raz LDATLIN

  ######
  # Estructura
  ###
  # POSICIÓN                              TIPO        LONGITUD        FORMATO
  # 1  -> Código artículo                 Numérico      7
  # 2  -> Descripción en Español          Texto         50
  # 3  -> Descripción en Portugués        Texto         50
  # 4  -> Descripción en Inglés           Texto         50                        #AQS.n
  # 5  -> Descripción en Catalán          Texto         50
  # 6  -> Familia                         Texto       VACÍO                       #AQS.n
  # 7  -> Categoría                       Texto       VACÍO                       #AQS.n
  # 8  -> Planograma / Catálogo compra    Numérico      5             ceros por delante
  # 9  -> Precio Coste (proveedor)        Numérico                    2 decimales
  # 10 -> Precio Coste (Cesión/Mayor)     Numérico                    2 decimales
  # 11 -> PVP                             Numérico                    2 decimales
  # 12 -> Estado (Alta/Baja)              Texto         1             A / B
  # 13 -> Porcentaje IVA                  Numérico      2             2 decimales
  # 14 -> Mínimo                          Numérico
  # 15 -> Máximo                          Numérico
  # 16 -> Stock almacén Ondara            Numérico   VACÍO por tener el stock en otro interfaz  #AQS.n
  # 17 -> Controla stock                  Texto         1            S / N        #AQS.n
  ######

  LDATLIN(I)  = [I0]ITMREF : I+=1
  Call GET_ATEXTRA("ITMMASTER", "DES1AXX", "SPA", [I0]ITMREF, "", LDATLIN(I)) : I+=1
  Call GET_ATEXTRA("ITMMASTER", "DES1AXX", "POR", [I0]ITMREF, "", LDATLIN(I)) : I+=1
  Call GET_ATEXTRA("ITMMASTER", "DES1AXX", "ENG", [I0]ITMREF, "", LDATLIN(I)) : I+=1
  Call GET_ATEXTRA("ITMMASTER", "DES1AXX", "CAT", [I0]ITMREF, "", LDATLIN(I)) : I+=1

  LDATLIN(I)  = " " : I+=1
  LDATLIN(I)  = " " : I+=1
  LDATLIN(I)  = [IO]TSICOD(2) : I+=1
  LDATLIN(I)  = "0" : I+=1 # DUDA??

  If [I0]ITMSTA = 1 Then # DUDA??
    LDATLIN(I)  = "A" : I+=1
  Else
    LDATLIN(I)  = "B" : I+=1
  Endif
  LDATLIN(I)  = "21"  : I+=1 #como se obtiene? depende del artículo y la tienda? o ponemos 0?
  LDATLIN(I)  = num$([I0]ZSTOCKMIN)  : I+=1# DUDA??
  LDATLIN(I)  = num$([I0]ZSTOCKMAX)  : I+=1# DUDA??


  #escribimos en el fichero...
  Wrseq LDATLIN(1)  + LSEP +
&       LDATLIN(2)  + LSEP +
&       LDATLIN(3)  + LSEP +
&       LDATLIN(4)  + LSEP +
&       LDATLIN(5)  + LSEP +
&       LDATLIN(6)  + LSEP +
&       LDATLIN(7)  + LSEP +
&       LDATLIN(8)  + LSEP +
&       LDATLIN(9)  + LSEP +
&       LDATLIN(10) + LSEP +
&       LDATLIN(11) + LSEP +
&       LDATLIN(12) + LSEP +
&       LDATLIN(13) + LSEP +
&       LDATLIN(14) + LSEP +
&       LDATLIN(15) + LSEP +
&       LDATLIN(16) + LSEP +
&       LDATLIN(17)
&   Using [ZEXP]

  LTOTITM += 1  # número total de artículos exportados..
Next

# cerrar fichero import
Gosub CLOSE_FILE

# hacemos una copia del fichero generado...
System "cp " + LFILE + " " + LFILECOPY

Return

##########################################################
#**
#* Genera fichero de exportación a PIC de códigos ean
#*!
$GEN_ARTEAN
Local Char    LDATLIN(50)(15)

LFILECOPY   = LDIREXPORT + "COPIA\ean_" + LFECHA + "_" + LHORA + ".txt"
LFILE       = LDIREXPORT + "ean.txt"

# borramos el fichero si existe...
Gosub DEL_FILE

# abrir fichero..
Gosub OPEN_FILE

# recorremos todos los artículos
For [I0]ITM0
  Raz LDATLIN

  ######
  # Estructura
  ###
  # POSICIÓN                              TIPO        LONGITUD        FORMATO
  # 1  -> Código artículo                 Numérico      7             Rellenar 0 por delante
  # 2  -> Código EAN                      Numérico      13
  ######

  LDATLIN(1)  = [I0]ITMREF
  LDATLIN(2)  = [I0]EANCOD

  Call GET_FORMAT(LDATLIN(1), 7, "0", LDATLIN(1))

  #escribimos en el fichero...
  Wrseq LDATLIN(1)  + LSEP +
&       LDATLIN(2)
&   Using [ZEXP]

  LTOTEAN += 1  # número total de códigos ean exportados..
Next

# cerrar fichero import
Gosub CLOSE_FILE

# hacemos una copia del fichero generado...
System "cp " + LFILE + " " + LFILECOPY

Return

##########################################################
#**
#* Genera fichero de exportación a PIC de repcepciones a tiendas
#*!
$GEN_PTH
Local Char    LDATLIN(50)(15)

LFILECOPY   = LDIREXPORT + "COPIA\enviotienda_" + LFECHA + "_" + LHORA + ".txt"
LFILE       = LDIREXPORT + "enviotienda.txt"

# borramos el fichero si existe...
Gosub DEL_FILE

# abrir fichero..
Gosub OPEN_FILE

# recorremos todos las recepciones sin procesar
Filter [R0] Where [R0]ZENPIC = 1 Order By [R0]PRHFCY
For [R0]PTH0
  Raz LDATLIN

  ######
  # Estructura
  ###
  # POSICIÓN                              TIPO        LONGITUD        FORMATO
  # 1  -> Código almacén(Tienda)          Numérico      3             Rellenar 0 por delante
  # 2  -> Nº albarán                      Numérico      6
  # 3  -> Fecha                           Fecha         8             dd.mm.aa
  # 4  -> Código artículo                 Numérico      7             Rellenar 0 por delante
  # 5  -> Cantidad                        Numérico
  # 6  -> Precio cesión                   Numérico
  ######

  For [R1] Where [R1]PTHNUM = [R0]PTHNUM

    LDATLIN(1)  = [R0]PRHFCY
    LDATLIN(2)  = [R0]PTHNUM
    LDATLIN(3)  = ""
  Next

  #Call GET_FORMAT(LDATLIN(1), 7, "0", LDATLIN(1))

  #escribimos en el fichero...
  Wrseq LDATLIN(1)  + LSEP +
&       LDATLIN(2)  + LSEP +
&       LDATLIN(3)  + LSEP +
&       LDATLIN(4)  + LSEP +
&       LDATLIN(5)  + LSEP +
&       LDATLIN(6)
&   Using [ZEXP]

  LTOTEAN += 1  # número total de códigos ean exportados..
Next

# cerrar fichero import
Gosub CLOSE_FILE

# hacemos una copia del fichero generado...
System "cp " + LFILE + " " + LFILECOPY

Return
########################################################
$OPEN_FILE

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE Using [ZEXP]

Return

########################################################
$CLOSE_FILE

Openo Using [ZEXP]

Return

########################################################
#**
#* Borramos un fichero existente.
#* El parámetro LFILE debe tener una ruta correcta..
#*!
$DEL_FILE
# borramos el fichero si existe...
If filinfo(LFILE, 7) > 0 Then
  System "ae_rm " + LFILE
Endif
Sleep 3  # los ficheros para que se borren correctamente hay que realizar una pausa

Return

#######################################################
$GET_TRAZA
Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
Call ECR_TRACE("Artículos   : " + num$(LTOTITM), 0) From GESECRAN
Call ECR_TRACE("EAN         : " + num$(LTOTEAN), 0) From GESECRAN

#Call ECR_TRACE("Errores    : " + num$(LNUMERR), 0) From GESECRAN
#Call ECR_TRACE("Exportados : " + num$(LNUMEXP), 0) From GESECRAN

Return

#########################################################
$ABRIR_TBL
If clalev([I0]) = 0 : Local File ITMMASTER   [I0] : Endif  # artículos
If clalev([C0]) = 0 : Local File ITMCOST     [C0] : Endif  # artículos-costes

If clalev([R0]) = 0 : Local File PRECEIPT   [R0] : Endif  # recepciones cab.
If clalev([R1]) = 0 : Local File PRECEIPTD  [R1] : Endif  # recepciones lin.
Return

#########################################################
$CERRAR_TBL
Close Local File [I0]
Close Local File [R0], [R1]
Return

#########################################################
#**
#* Obtiene la traducción
#*
#* @param PCODFIC > tabla
#* @param PZONE   > campo
#* @param PLANGUE > idioma
#* @param PIDENT1 > identidad 1
#* @param PIDENT2 > identidad 2
#* @param PTEXTO  > devuelve el texto traducido o en blanco
#*!
Subprog GET_ATEXTRA(PCODFIC, PZONE, PLANGUE, PIDENT1, PIDENT2, PTEXTO)
Variable  Char PTEXTO
Value     Char PCODFIC
Value     Char PZONE
Value     Char PLANGUE
Value     Char PIDENT1
Value     Char PIDENT2

Raz PTEXTO

# tabla
If clalev([A0]) = 0 : Local File ATEXTRA   [A0] : Endif  # traducciones

# obtener la tradución
Read [A0]AXX0 = PCODFIC;PZONE;PLANGUE;PIDENT1;PIDENT2
If !fstat Then
  PTEXTO = [A0]TEXTE
Endif


# cerrar tabla
Close Local File [A0]
End

#**
#* Formatea con espacios en blanco
#*
#* @param PDATORI : dato original
#* @param PESP    : tamaño máximo que ocupa el campo
#* @param PSEPA   : contenido del separador (espacios en blanco, 0, etc..)
#* @param PDATFIN : campo formateado con los espacios restantes
#*!
Subprog GET_FORMAT(PDATORI, PESP, PSEPA, PDATFIN)
Variable  Char    PDATFIN
Value     Char    PDATORI
Value     Integer PESP
Value     Char    PSEPA

# solo rellena si hay espacio..
If len(PDATORI) < PESP Then
  PDATFIN = string$( (PESP - len(PDATORI) ), PSEPA) + PDATORI
Endif
End

