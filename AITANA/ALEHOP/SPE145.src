#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog MAIN()
If !clalev([F:Z145]) : Local File ZFIC145[Z145] :Endif
If !clalev([F:ITV]) : Local File ITMMVT[ITV] :Endif

Local Integer YSTAT
Local Char FICHERO(30)
Local Char FECHA(10)

If !GSERVEUR Then
  Call OUINON ("¿Exportar fichero 14.5?", YSTAT ) From GESECRAN
Else
  YSTAT=2
Endif

If YSTAT=2 Then
  FICHERO = "export" + date$ + time$
  FICHERO = ctrans(FICHERO,":","")

    adxifs = chr$(9)
    adxirs = chr$(13)+chr$(10)
    Openo "E:\EXPORT\14-5\"  + FICHERO + ".txt",0 Using [ZEXP]

#Filter [F:ITV] Where [F:ITV]STOFCY = "ALM00" #and [F:ITV]ITMREF>='1001000' and [F:ITV]ITMREF<='1040005'
#For [F:ITV]
    Filter [F:Z145] #Where ITMREF=[F:ITV]ITMREF
    For [F:Z145]
      If year([Z145]LASPURDAT) > 2000  Then
        FECHA=format$("D:DD[-]MM[-]YYYY",[F:Z145]LASPURDAT)
      Else
        FECHA=""
      Endif
   #   If [F:Z145]ITMREF="9458303" Then Infbox num$([F:Z145]LASPURPRI) Endif
      Wrseq [F:Z145]ITMREF        + adxifs +
&         num$([F:Z145]QTYPTE)    + adxifs +
&         num$([F:Z145]QTYRECACT) + adxifs +
&         num$([F:Z145]T05)       + adxifs +
&         num$([F:Z145]LASPURPRI) + adxifs +
&         FECHA
&   Using [ZEXP]
    Next
    Filter [F:Z145]
#Next
#Filter [F:ITV]
    Openo Using [ZEXP]

  System ESTADO="e:\export\14-5\mover.bat"

  If !GSERVEUR : Infbox "Exportación finalizada" : Endif
Endif

End
#EXPORTACIÓN FICHERO 14.5

#LA ESTRUCTURA DEL FICHERO DEBE CONTENER LOS SIGUIENTES CAMPOS:
#
#REFERENCIA
#UNIDADES PTES DE RECIBIR
#UNIDADES COMPRADAS HASTA EL MOMENTO
#ULTIMO PRECIO DE TARIFA T05
#ULTIMO PRECIO COMPRA
#
#LOS CAMPOS DEBEN DE ESTAR SEPARADOS POR TABULADOR.

