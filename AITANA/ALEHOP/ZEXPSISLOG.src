#<AdxTL>@(#)0.0.0.0 $Revision$
#######################################################################
## Exportación de ficheros hacia SISLOG (Maestros)
##   - Maestro de artículos
##   - Maestro de códigos de barras
##   - Maestro de clientes
##   - Maestro de proveedores
## LCC - Abril 2021
#########################################################################
Gosub EXEC
End
$ACTION
Case ACTION
  When "EXEC": Gosub EXEC
Endcase
Return

###########################################################################
$EXEC
  If !GSERVEUR
    Call OUVRE_TRACE("Proceso exportación ficheros hacía SISLOG") From LECFIC
  Endif

  Gosub OUVRE  # Apertura tablas y definición de variables de trabajo
  Gosub ULTFECHA_EXP # Cálculo fecha ultiam exportación
  Gosub MAESTRO_PROVEEDORES
  Gosub MAESTRO_CLIENTES
  Gosub MAESTRO_ARTICULOS
  Gosub PEDIDO_COMPRAS
  Gosub PEDIDO_VENTAS


  Sleep 1
  Gosub ACT_ULTFECHA_EXP
  If !GSERVEUR
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
  Endif
Return
###########################################################################
## Pedidos de VENTAS
###########################################################################
$PEDIDO_VENTAS
Call ECR_TRACE("==============================================================================",0) From GESECRAN
Call ECR_TRACE("==                          PEDIDOS DE VENTAS                               ==",0) From GESECRAN
Call ECR_TRACE("==============================================================================",0) From GESECRAN
Link [SOH] With [F:FCY]FCY0=[F:SOH]STOFCY As [ZSOH]
Filter [ZSOH] Where ([F:SOH]ZEXPSISLOG=0 or [F:SOH]UPDDATTIM>WULTFECHA) and ORDSTA<>2  &
&       ([F:SOH]STOFCY="ALM00")
If rowcount([F:ZSOH])
  ##---------------- Apertura del fichero -----------------------------------------------------
  ## Recuperamos el contador
   Local Integer STAT
   Call NUMERO("ZSIS","",date$,'cpv',WFICHERO,STAT) From SUBANM
  ##-------------------------------------------------------------------------------------------
  ## Abrimos del fichero
   Openo filpath("SISLOG/ENVIOS",WFICHERO,"dat"),0 Using [CPV]
   Iomode adxirs chr$(13)+chr$(10) Using [CPV]  #Separador de registros. Fin de linea.
   Iomode adxifs ""                Using [CPV]  #Separador de campos.
   Iomode adxium 50                Using [CPV]  #Formato de fichero. 50: ASCII, 122: UCS2, 0: UTF8

   WFICHERO2="lpv"+right$(WFICHERO,4)
   Openo filpath("SISLOG/ENVIOS",WFICHERO2,"dat"),0 Using [DPV]
   Iomode adxirs chr$(13)+chr$(10) Using [DPV]  #Separador de registros. Fin de linea.
   Iomode adxifs ""                Using [DPV]  #Separador de campos.
   Iomode adxium 50                Using [DPV]  #Formato de fichero. 50: ASCII, 122: UCS2, 0: UTF8

  ##--------------------------------------------------------------------------------------------
  ## Bucle sobre la tabla de pedidos
  WNUMREG=0: WNUMLPV=0
  For [ZSOH]
    WNUMREG+=1
    Wrseq format$("N0:6#",WNUMREG);       Using [CPV]
    Wrseq right$(WFICHERO,4);             Using [CPV]
    Wrseq right$([F:ZSOH]SOHNUM,len([ZSOH]SOHNUM)-7); Using [CPV]
    Wrseq "0";                            Using [CPV]
    Wrseq format$("3X",[F:FCY]ZCODSISLOG);Using [CPV]
    Wrseq format$("8X",[F:ZSOH]BPCORD);   Using [CPV]
    Wrseq space$(15);                     Using [CPV]
    Wrseq space$(6);                      Using [CPV]
    Wrseq format$("D:YYYYMMDDhhmmss",datetime$); Using [CPV]
    Wrseq format$("D:YYYYMMDDhhmmss",datetime$); Using [CPV]
    Wrseq "PE";                           Using [CPV]
    Wrseq space$(2);                      Using [CPV]
    Wrseq space$(4);                      Using [CPV]
    Wrseq space$(4);                      Using [CPV]
    Wrseq space$(6);                      Using [CPV]
    Wrseq space$(20);                     Using [CPV]
    Wrseq "0";                            Using [CPV]
    Wrseq "N";                            Using [CPV]
    Wrseq "N";                            Using [CPV]
    Wrseq space$(40);                     Using [CPV]
    Wrseq "S";                            Using [CPV]
    Wrseq space$(16);                     Using [CPV]
    Wrseq format$("N0:8#",0);             Using [CPV]
    Wrseq format$("N0:9#",0);             Using [CPV]
    If [F:ZSOH]BPDADDLIG(0)-[F:ZSOH]BPDADDLIG(1)<>""
      Wrseq format$("80X",[F:ZSOH]BPDADDLIG(0)-[F:ZSOH]BPDADDLIG(1)); Using [CPV]
    Else
      Wrseq format$("80X","-"); Using [CPV]
    Endif
    If [F:ZSOH]BPDCTY<>""
      Wrseq format$("40X",[F:ZSOH]BPDCTY);  Using [CPV]
    Else
      Wrseq format$("40X","-");  Using [CPV]
    Endif
    If [F:ZSOH]BPDSAT<>""
      Wrseq format$("40X",[F:ZSOH]BPDSAT);  Using [CPV]
    Else
     Wrseq format$("40X","-");  Using [CPV]
    Endif
    If [F:SOH]BPDPOSCOD<>""
      Wrseq format$("7X",[F:SOH]BPDPOSCOD);Using [CPV]
    Else
      Wrseq format$("7X","-");Using [CPV]
    Endif
    Read [F:AXX]AXX0="TABCOUNTRY";"CRYDES";"SPA";[F:SOH]BPDCRY;""
    Wrseq format$("40X",[F:AXX]TEXTE);             Using [CPV]
    Wrseq space$(256);                             Using [CPV]
    If [F:ZSOH]ZEXPSISLOG<>2
      Wrseq "A";                          Using [CPV]
    Else
      Wrseq "M";                          Using [CPV]
    Endif
    Wrseq format$("D:YYYYMMDDhhmmss",datetime$)    Using [CPV]

    ### BUCLE SOBRE LINEA
    WNUMLIN=0
    For [F:SOQ] Where SOHNUM=[F:ZSOH]SOHNUM and SOQSTA<>3 and STOMGTCOD>1
      WNUMLPV+=1
      WNUMLIN+=1
      Wrseq format$("N0:6#",WNUMLPV);        Using [DPV]
      Wrseq right$(WFICHERO,4);             Using [DPV]
      Wrseq right$([F:ZSOH]SOHNUM,len([ZSOH]SOHNUM)-7); Using [DPV]
      Wrseq "0";                            Using [DPV]
      Wrseq space$(16);                     Using [DPV]
      Wrseq format$("N0:5#",WNUMLIN);       Using [DPV]
      Wrseq format$("7X",[F:SOQ]ITMREF);    Using [DPV]
      Wrseq "  0";                          Using [DPV]
      Wrseq " 0";                           Using [DPV]
      Wrseq "0";                            Using [DPV]
      Wrseq space$(35);                     Using [DPV]
      Wrseq "   ";                          Using [DPV]
      Wrseq "  ";                           Using [DPV]
      Wrseq " ";                            Using [DPV]
      Wrseq format$("N0:9#", [F:SOQ]QTY-[F:SOQ]DLVQTY); Using [DPV]
      Wrseq "PE";                           Using [DPV]
      Wrseq "U";                            Using [DPV]
      Wrseq space$(15);                     Using [DPV]
      Wrseq space$(256);                    Using [DPV]
      If [F:ZSOH]ZEXPSISLOG<>2
        Wrseq "A";                          Using [DPV]
      Else
        Wrseq "M";                          Using [DPV]
      Endif
      Wrseq format$("D:YYYYMMDDhhmmss",datetime$)    Using [DPV]
    Next

    If [F:ZSOH]ZEXPSISLOG<>2
      Read [F:XSOH]SOH0=[F:ZSOH]SOHNUM
      If !fstat
        [F:XSOH]ZEXPSISLOG=2
        Rewrite [F:XSOH]
      Endif
    Endif
   Call ECR_TRACE("Exportado pedido de venta "-[F:ZSOH]SOHNUM,0) From GESECRAN

  Next
  Call ECR_TRACE("Exportados"-num$(WNUMREG)-"pedidos de venta",0) From GESECRAN
  Call ECR_TRACE("Exportadas"-num$(WNUMLPV)-"líneas de pedidos de compra",0) From GESECRAN
  Wrseq format$("N0:6#","999999");        Using [DPV]
  Wrseq right$(WFICHERO,4)                Using [DPV]
  Wrseq format$("N0:6#","999999");        Using [CPV]
  Wrseq right$(WFICHERO,4)                Using [CPV]
  Openo Using [CPV]
  Openo Using [DPV]
Else
  Call ECR_TRACE("Ningún pedido exportado",0) From GESECRAN
Endif
Return

###########################################################################
## Pedidos de compras
###########################################################################
$PEDIDO_COMPRAS
Call ECR_TRACE("==============================================================================",0) From GESECRAN
Call ECR_TRACE("==                          PEDIDOS DE COMPRA                               ==",0) From GESECRAN
Call ECR_TRACE("==============================================================================",0) From GESECRAN
Link [POH] With [F:FCY]FCY0=[F:POH]POHFCY As [ZPOH]
Filter [ZPOH] Where ([F:POH]ZEXPSISLOG=0 or [F:POH]UPDDATTIM>WULTFECHA) and CLEFLG<>2  &
&       (left$([F:POH]POHNUM,3)="PCP" or left$([F:POH]POHNUM,3)="PCO")
If rowcount([F:ZPOH])
  ##---------------- Apertura del fichero -----------------------------------------------------
  ## Recuperamos el contador
   Local Integer STAT
   Call NUMERO("ZSIS","",date$,'cpc',WFICHERO,STAT) From SUBANM
  ##-------------------------------------------------------------------------------------------
  ## Abrimos del fichero
   Openo filpath("SISLOG/ENVIOS",WFICHERO,"dat"),0 Using [CPC]
   Iomode adxirs chr$(13)+chr$(10) Using [CPC]  #Separador de registros. Fin de linea.
   Iomode adxifs ""                Using [CPC]  #Separador de campos.
   Iomode adxium 50                Using [CPC]  #Formato de fichero. 50: ASCII, 122: UCS2, 0: UTF8

   WFICHERO2="lpc"+right$(WFICHERO,4)
   Openo filpath("SISLOG/ENVIOS",WFICHERO2,"dat"),0 Using [DPC]
   Iomode adxirs chr$(13)+chr$(10) Using [DPC]  #Separador de registros. Fin de linea.
   Iomode adxifs ""                Using [DPC]  #Separador de campos.
   Iomode adxium 50                Using [DPC]  #Formato de fichero. 50: ASCII, 122: UCS2, 0: UTF8

  ##--------------------------------------------------------------------------------------------
  ## Bucle sobre la tabla de pedidos
  WNUMREG=0: WNUMLPC=0
  For [ZPOH]
    WNUMREG+=1
    Wrseq format$("N0:6#",WNUMREG);        Using [CPC]
    Wrseq right$(WFICHERO,4);             Using [CPC]
    Wrseq right$([F:ZPOH]POHNUM,len([ZPOH]POHNUM)-7); Using [CPC]
    Wrseq space$(16);                     Using [CPC]
    Wrseq space$(17);                     Using [CPC]
    Wrseq space$(2);                      Using [CPC]
    Wrseq format$("3X",[F:FCY]ZCODSISLOG);Using [CPC]
    Wrseq space$(6);                      Using [CPC]
    Wrseq format$("6X",[F:ZPOH]BPSNUM);   Using [CPC]
    Wrseq space$(15);                     Using [CPC]
    Wrseq format$("D:YYYYMMDDhhmmss",[F:ZPOH]ORDDAT); Using [CPC]
    Wrseq format$("D:YYYYMMDDhhmmss",[F:POH]EXTRCPDAT1); Using [CPC]
    Wrseq "PE";                           Using [CPC]
    ### BUCLE SOBRE LINEA
    WNUMLIN=0
    For [F:POQ] Where POHNUM=[F:ZPOH]POHNUM and LINCLEFLG<>2
      WNUMLPC+=1
      WNUMLIN+=1
      Wrseq format$("N0:6#",WNUMLPC);        Using [DPC]
      Wrseq right$(WFICHERO,4);             Using [DPC]
      Wrseq right$([F:ZPOH]POHNUM,len([ZPOH]POHNUM)-7); Using [DPC]
      Wrseq space$(16);                     Using [DPC]
      Wrseq format$("N0:5#",WNUMLIN);       Using [DPC]
      Wrseq format$("7X",[F:POQ]ITMREF);    Using [DPC]
      Wrseq "  0";                          Using [DPC]
      Wrseq " 0";                           Using [DPC]
      Wrseq "0";                            Using [DPC]
      Wrseq space$(35);                     Using [DPC]
      Wrseq "   ";                          Using [DPC]
      Wrseq "  ";                           Using [DPC]
      Wrseq " ";                            Using [DPC]
      Wrseq format$("N0:9#", [F:POQ]QTYPUU-[F:POQ]RCPQTYPUU); Using [DPC]
      Wrseq "U";                            Using [DPC]
      Wrseq space$(14);                     Using [DPC]
      Wrseq space$(15);                     Using [DPC]
      Wrseq space$(8);                      Using [DPC]
      Wrseq space$(18);                     Using [DPC]
      Wrseq "PE";                           Using [DPC]
      If [F:ZPOH]ZEXPSISLOG<>2
        Wrseq "A";                          Using [DPC]
      Else
        Wrseq "M";                          Using [DPC]
      Endif
      Wrseq format$("D:YYYYMMDDhhmmss",datetime$)    Using [DPC]
    Next
    Wrseq format$("N0:5#",WNUMLIN);       Using [CPC]
    If [F:ZPOH]ZEXPSISLOG<>2
      Wrseq "A";                          Using [CPC]
    Else
      Wrseq "M";                          Using [CPC]
    Endif
    Wrseq format$("D:YYYYMMDDhhmmss",datetime$)    Using [CPC]

    If [F:ZPOH]ZEXPSISLOG<>2
      Read [F:XPOH]POH0=[F:ZPOH]POHNUM
      If !fstat
        [F:XPOH]ZEXPSISLOG=2
        Rewrite [F:XPOH]
      Endif
    Endif
   Call ECR_TRACE("Exportado pedido de compra "-[F:ZPOH]POHNUM,0) From GESECRAN

  Next
  Call ECR_TRACE("Exportados"-num$(WNUMREG)-"pedidos de compra",0) From GESECRAN
  Call ECR_TRACE("Exportadas"-num$(WNUMLPC)-"líneas de pedidos de compra",0) From GESECRAN
  Wrseq format$("N0:6#","999999");        Using [DPC]
  Wrseq right$(WFICHERO,4)                Using [DPC]
  Wrseq format$("N0:6#","999999");        Using [CPC]
  Wrseq right$(WFICHERO,4)                Using [CPC]
  Openo Using [CPC]
  Openo Using [DPC]
Else
  Call ECR_TRACE("Ningún pedido exportado",0) From GESECRAN
Endif
Return
###########################################################################
## Maestro de artículos
###########################################################################
$MAESTRO_ARTICULOS
Call ECR_TRACE("==============================================================================",0) From GESECRAN
Call ECR_TRACE("==                          MAESTRO DE ARTICULOS                            ==",0) From GESECRAN
Call ECR_TRACE("==============================================================================",0) From GESECRAN
Link [F:ITM] With [ITG]ITG0="";[F:ITM]TCLCOD As [ZITM]

Filter [ZITM] Where [F:ITG]ZGESSISLOG=2 and ([F:ITM]ZEXPSISLOG=0 or [F:ITM]UPDDATTIM>WULTFECHA) and
&                   [F:ITM]STOMGTCOD=2
If rowcount([F:ZITM])>0
#  ##---------------- Apertura del fichero -----------------------------------------------------
#  ## Recuperamos el contador
#   Local Integer STAT
#   Call NUMERO("ZSIS","",date$,'art',WFICHERO,STAT) From SUBANM
#  ##-------------------------------------------------------------------------------------------
#  ## Abrimos del fichero
#   Openo filpath("SISLOG/ENVIOS",WFICHERO,"dat"),0 Using [ART]
#   Iomode adxirs chr$(13)+chr$(10) Using [ART]  #Separador de registros. Fin de linea.
#   Iomode adxifs ""                Using [ART]  #Separador de campos.
#   Iomode adxium 0                 Using [ART]  #Formato de fichero. 50: ASCII, 122: UCS2, 0: UTF8
#
#   WFICHERO2="ica"+right$(WFICHERO,4)
#   Openo filpath("SISLOG/ENVIOS",WFICHERO2,"dat"),0 Using [COD]
#   Iomode adxirs chr$(13)+chr$(10) Using [COD]  #Separador de registros. Fin de linea.
#   Iomode adxifs ""                Using [COD]  #Separador de campos.
#   Iomode adxium 0                 Using [COD]  #Formato de fichero. 50: ASCII, 122: UCS2, 0: UTF8
#  ##--------------------------------------------------------------------------------------------
  ## Bucle sobre la tabla de artículos
  WNUMREG=0: WNUMCOD=0
  Link [F:ITF] With [FCY]FCY0=[F:ITF]STOFCY As [ZITF]

  For [ZITM]
        For [ZITF]ITF0 Where [F:FCY]ZGESSISLOG=2 & ITMREF=[F:ITM]ITMREF
    If WNUMREG=0
        ##---------------- Apertura del fichero -----------------------------------------------------
        ## Recuperamos el contador
         Local Integer STAT
         Call NUMERO("ZSIS","",date$,'art',WFICHERO,STAT) From SUBANM
        ##-------------------------------------------------------------------------------------------
        ## Abrimos del fichero
         Openo filpath("SISLOG/ENVIOS",WFICHERO,"dat"),0 Using [ART]
         Iomode adxirs chr$(13)+chr$(10) Using [ART]  #Separador de registros. Fin de linea.
         Iomode adxifs ""                Using [ART]  #Separador de campos.
         Iomode adxium 50                 Using [ART]  #Formato de fichero. 50: ASCII, 122: UCS2, 0: UTF8

         WFICHERO2="ica"+right$(WFICHERO,4)
         Openo filpath("SISLOG/ENVIOS",WFICHERO2,"dat"),0 Using [COD]
         Iomode adxirs chr$(13)+chr$(10) Using [COD]  #Separador de registros. Fin de linea.
         Iomode adxifs ""                Using [COD]  #Separador de campos.
         Iomode adxium 50                Using [COD]  #Formato de fichero. 50: ASCII, 122: UCS2, 0: UTF8
    Endif

    WNUMREG+=1
#    If WNUMREG=10: Break 2: Endif
    Wrseq format$("N0:6#",WNUMREG);                Using [ART]
    Wrseq right$(WFICHERO,4);                      Using [ART]
    Wrseq "000000";                                Using [ART]
    Wrseq format$("7X",[F:ITM]ITMREF);             Using [ART]
    Wrseq format$("3X","0  ");                     Using [ART]
    Wrseq format$("2X","0 ");                      Using [ART]
    Wrseq format$("1X","0");                       Using [ART]
    Wrseq format$("40X",[F:ITM]ITMDES1);           Using [ART]
    Wrseq format$("15X",[F:ITM]ITMDES1);           Using [ART]
    Wrseq format$("3X",[F:FCY]ZCODSISLOG);         Using [ART]
    Wrseq format$("1X","N");                       Using [ART]
    Wrseq format$("1X","N");                       Using [ART]
    Wrseq format$("1X","N");                       Using [ART]
    Wrseq format$("1X","N");                       Using [ART]
    WUNIMASTER=1: WUNIMIDDLE=1
    For X=0 To 2
      If [F:ITM]PCU(X)="MST": WUNIMASTER=[F:ITM]PCUSTUCOE(X): Endif
      If [F:ITM]PCU(X)="MDL": WUNIMIDDLE=[F:ITM]PCUSTUCOE(X): Endif
    Next
    Case [F:ITM]SAU
      When "UN": Wrseq "U";                        Using [ART]
      When Default: Wrseq " ";                     Using [ART]
    Endcase
#    Case [F:ITM]WEU
#      When "KG": Wrseq format$("N0:8#",WUNIMASTER*[F:ITM]ITMWEI*1000); Using [ART]
#      When Default: Wrseq format$("N0:8#",0);    Using [ART]
#    Endcase
    Wrseq format$("N0:8#",[F:ITM]ZPESOEMB);    Using [ART]
#    If [F:ITM]ITMVOU=1: [F:ITM]ITMVOU=0.99: Endif
#    Case [F:ITM]VOU
#      When "M3": Wrseq format$("N0:9#",1000*WUNIMASTER*[F:ITM]ITMVOU*1000000); Using [ART]
#      When Default: Wrseq format$("N0:9#",0);    Using [ART]
#    Endcase
    Wrseq format$("N0:9#",[F:ITM]ZVOLCARTON);    Using [ART]
    Wrseq format$("N0:5#",[F:ITM]ZMASALTO);       Using [ART]
    Wrseq format$("N0:5#",[F:ITM]ZMASANCHO);       Using [ART]
    Wrseq format$("N0:5#",[F:ITM]ZMASLARGO);       Using [ART]
    Wrseq "G";                                      Using [ART]
    Wrseq format$("N0:8#",WUNIMASTER);             Using [ART]
    Wrseq format$("N0:5#",999);                    Using [ART]
    Wrseq format$("N0:8#",WUNIMIDDLE);             Using [ART]
    Wrseq format$("N0:5#",999);                    Using [ART]
    Wrseq format$("N0:5#",1);                      Using [ART]
    Case [F:ITM]ITMSTA
      When 1: Wrseq "AL";     Using [ART]
      When 2: Wrseq "AP";     Using [ART]
      When 3: Wrseq "BA";     Using [ART]
      When Default Wrseq "AL";     Using [ART]
    Endcase
    Wrseq format$("2X",'01');                      Using [ART]
    Wrseq format$("2X",'01');                      Using [ART]
    Wrseq format$("1X",'A');                       Using [ART]
    Wrseq format$("1X",'N');                       Using [ART]
    Wrseq format$("1X",'M');                       Using [ART]
    Wrseq format$("1X",'N');                       Using [ART]
    Wrseq format$("2X",' ');                       Using [ART]
    Wrseq format$("1X",'N');                       Using [ART]
    Wrseq format$("4X",'    ');                    Using [ART]
    Wrseq format$("4X",'    ');                    Using [ART]
    Wrseq format$("4X",'    ');                    Using [ART]
    Wrseq format$("4X",'    ');                    Using [ART]
    Wrseq format$("2X",'PA');                      Using [ART]
    Wrseq format$("2X",'18');                      Using [ART]
    Wrseq format$("2X",'EU');                      Using [ART]
    Wrseq format$("1X",'N');                       Using [ART]
    Wrseq format$("1X",'C');                       Using [ART]
    Wrseq format$("7X",' ');                       Using [ART]
    Wrseq format$("1X",'N');                       Using [ART]
    Wrseq format$("1X",'N');                       Using [ART]
    Wrseq format$("1X",'N');                       Using [ART]
    Wrseq format$("7X",' ');                       Using [ART]
    Wrseq format$("3X",' ');                       Using [ART]
    Wrseq format$("2X",' ');                       Using [ART]
    Wrseq format$("1X",' ');                       Using [ART]
    Wrseq format$("6X",' ');                       Using [ART]
    Wrseq format$("7X",' ');                       Using [ART]
    Wrseq format$("3X",' ');                       Using [ART]
    Wrseq format$("2X",' ');                       Using [ART]
    Wrseq format$("1X",' ');                       Using [ART]
    Wrseq format$("8X",' ');                       Using [ART]
    Wrseq format$("2X",'01');                      Using [ART]
    Wrseq format$("35X",' ');                      Using [ART]
    Wrseq format$("3X",' ');                       Using [ART]
    Wrseq format$("2X",' ');                       Using [ART]
    Wrseq format$("1X",' ');                       Using [ART]
    Wrseq format$("1X",'N');                       Using [ART]
    Wrseq format$("1X",'N');                       Using [ART]
    Wrseq format$("2X",' ');                       Using [ART]
    Wrseq format$("1X",' ');                       Using [ART]
    Wrseq format$("15X",' ');                      Using [ART]
    Wrseq format$("5X",' ');                       Using [ART]
#    Wrseq format$("6X",' ');                       Using [ART]
    Wrseq format$("5X",' ');                       Using [ART]
    Wrseq format$("2X",' ');                       Using [ART]
    Wrseq format$("2X",' ');                       Using [ART]
    Wrseq format$("9X",' ');                       Using [ART]
    If [F:ITM]ZEXPSISLOG<>2
      Wrseq "A";                                   Using [ART]
    Else
      Wrseq "M";                                   Using [ART]
    Endif
    Wrseq format$("D:YYYYMMDDhhmmss",datetime$) Using [ART]

    ###-----
    ## Codigo de barras
    ###-----
    If [F:ITM]EANCOD<>""
      WNUMCOD+=1
      Wrseq format$("N0:6#",WNUMCOD);                Using [COD]
      Wrseq right$(WFICHERO,4);                      Using [COD]
      Wrseq format$("3X",[F:FCY]ZCODSISLOG);         Using [COD]
      Wrseq "000000";                                Using [COD]
      Wrseq format$("7X",[F:ITM]ITMREF);             Using [COD]
      Wrseq "0  ";                                   Using [COD]
      Wrseq "0 ";                                    Using [COD]
      Wrseq "0";                                     Using [COD]
      Wrseq format$("30X",[F:ITM]EANCOD);            Using [COD]
      Wrseq format$("15X","EAN13");                  Using [COD]
      Wrseq format$("N0:8#",1);                      Using [COD]
      Wrseq format$("D:YYYYMMDDhhmmss",[F:ITM]CREDATTIM);    Using [COD]
      If [F:ITM]ZEXPSISLOG<>2
        Wrseq "A";                                   Using [COD]
      Else
        Wrseq "M";                                   Using [COD]
      Endif
      Wrseq format$("D:YYYYMMDDhhmmss",datetime$)    Using [COD]
    Endif
    ##---
    If [F:ITM]ZEXPSISLOG<>2
      Read [F:XITM]ITM0=[F:ITM]ITMREF
      If !fstat
        [F:XITM]ZEXPSISLOG=2
        Rewrite [F:XITM]
      Endif
    Endif
    Call ECR_TRACE("Exportado"-[F:ITM]ITMREF-[F:ITM]ITMDES1-"Planta"-[F:FCY]ZCODSISLOG,0) From GESECRAN
   Next
  Next
  If WNUMREG>0
  Wrseq format$("N0:6#","999999");               Using [ART]
  Wrseq right$(WFICHERO,4)                       Using [ART]
  Call ECR_TRACE("Exportados"-num$(WNUMREG)-"artículos",0) From GESECRAN
  Call ECR_TRACE("Exportados"-num$(WNUMCOD)-"códigos de barras",0) From GESECRAN
  Wrseq format$("N0:6#","999999");        Using [ART]
  Wrseq right$(WFICHERO,4)                Using [ART]
  Wrseq format$("N0:6#","999999");        Using [COD]
  Wrseq right$(WFICHERO,4)                Using [COD]
  Openo Using [ART]
  Openo Using [COD]
  Endif
Else
  Call ECR_TRACE("Ningún artículo exportado",0) From GESECRAN
Endif
Return
###########################################################################
## Maestro de clientes
###########################################################################
$MAESTRO_CLIENTES
Call ECR_TRACE("==============================================================================",0) From GESECRAN
Call ECR_TRACE("==                          MAESTRO DE CLIENTES                             ==",0) From GESECRAN
Call ECR_TRACE("==============================================================================",0) From GESECRAN
Link [F:BPC] With [BCG]BCG0=[F:BPC]BCGCOD As [ZBPC]
Filter [ZBPC] Where [F:BCG]ZGESSISLOG=2 and ([F:BPC]ZEXPSISLOG<>2 or [F:BPC]UPDDATTIM>WULTFECHA)
If rowcount([F:ZBPC])
  ##---------------- Apertura del fichero -----------------------------------------------------
  ## Recuperamos el contador
   Local Integer STAT
   Call NUMERO("ZSIS","",date$,'cli',WFICHERO,STAT) From SUBANM
  ##-------------------------------------------------------------------------------------------
  ## Abrimos del fichero
   Openo filpath("SISLOG/ENVIOS",WFICHERO,"dat"),0 Using [CLI]
   Iomode adxirs chr$(13)+chr$(10) Using [CLI]  #Separador de registros. Fin de linea.
   Iomode adxifs ""                Using [CLI]  #Separador de campos.
   Iomode adxium 50                Using [CLI]  #Formato de fichero. 50: ASCII, 122: UCS2, 0: UTF8

  ##--------------------------------------------------------------------------------------------
  ## Bucle sobre la tabla de clientes
  WNUMREG=0
  For [ZBPC]
    WNUMREG+=1
    Wrseq format$("N0:6#",WNUMREG);                Using [CLI]
    Wrseq right$(WFICHERO,4);                      Using [CLI]
    Wrseq format$("8X",[F:BPC]BPCNUM);             Using [CLI]
    Wrseq format$("40X",[F:BPC]BPCNAM);            Using [CLI]
    If [F:BPC]BPCSHO<>""
      Wrseq format$("15X",[F:BPC]BPCSHO);            Using [CLI]
    Else
      Wrseq format$("15X",[F:BPC]BPCNAM);            Using [CLI]
    Endif
    Wrseq format$("40X",[F:BPC]BPCNAM);            Using [CLI]
    ##---- Dirección
    Raz [F:BPA]
    Read [F:BPA]BPA0=1;[F:BPC]BPCNUM;[F:BPC]BPAADD
    If [F:BPA]BPAADDLIG(0)<>""
      Wrseq format$("40X",[F:BPA]BPAADDLIG(0)-[F:BPA]BPAADDLIG(1)); Using [CLI]
    Else
      Wrseq format$("40X","-");                    Using [CLI]
    Endif
    Wrseq format$("7X",[F:BPA]POSCOD);             Using [CLI]
    If [F:BPA]CTY<>""
      Wrseq format$("40X",[F:BPA]CTY);             Using [CLI]
    Else
      Wrseq format$("40X","-");                    Using [CLI]
    Endif
    If [F:BPA]SAT<>""
      Wrseq format$("40X",[F:BPA]SAT);             Using [CLI]
    Else
      Wrseq format$("40X","-");                    Using [CLI]
    Endif
    ##---- Pais
    Read [F:AXX]AXX0="TABCOUNTRY";"CRYDES";"SPA";[F:BPA]CRY;""
    Wrseq format$("40X",[F:AXX]TEXTE);             Using [CLI]
    Wrseq format$("40X",[F:BPA]TEL(0));            Using [CLI]
    Wrseq space$(14);                              Using [CLI]
    Wrseq "  ";                                    Using [CLI]  ##Tipo cliente
    Wrseq "  ";                                    Using [CLI]  ##Tipo contenedor
    Wrseq "    ";                                  Using [CLI]  ## Código ruta
    Wrseq "    ";                                  Using [CLI]  ## Orden de ruta
    Wrseq space$(40);                              Using [CLI]
    Wrseq space$(15);                              Using [CLI]
    If [F:BPC]ZEXPSISLOG<>2
      Wrseq "A";                                   Using [CLI]
    Else
      Wrseq "M";                                   Using [CLI]
    Endif
    Wrseq format$("D:YYYYMMDDhhmmss",datetime$) Using [CLI]
    If [F:BPC]ZEXPSISLOG<>2
      Read [F:XBPC]BPC0=[F:BPC]BPCNUM
      If !fstat
        [F:XBPC]ZEXPSISLOG=2
        Rewrite [F:XBPC]
      Endif
    Endif
    Call ECR_TRACE("Exportado"-[F:BPC]BPCNUM-[F:BPC]BPCNAM,0) From GESECRAN
  Next
  Call ECR_TRACE("Exportados"-num$(WNUMREG)-"clientes",0) From GESECRAN
  Openo Using [CLI]
Else
  Call ECR_TRACE("Ningún clientes exportado",0) From GESECRAN
Endif

Return
###########################################################################
## Maestro de proveedores
###########################################################################
$MAESTRO_PROVEEDORES
Call ECR_TRACE("==============================================================================",0) From GESECRAN
Call ECR_TRACE("==                          MAESTRO DE PROVEEDORES                          ==",0) From GESECRAN
Call ECR_TRACE("==============================================================================",0) From GESECRAN
Link [F:BPS] With [BSG]BSG0=[F:BPS]BSGCOD As [ZBPS]
Filter [ZBPS] Where [F:BSG]ZGESSISLOG=2 and ([F:BPS]ZEXPSISLOG<>2 or [F:BPS]UPDDATTIM>WULTFECHA)
If rowcount([F:ZBPS])
  ##---------------- Apertura del fichero -----------------------------------------------------
  ## Recuperamos el contador
   Local Integer STAT
   Call NUMERO("ZSIS","",date$,'pro',WFICHERO,STAT) From SUBANM
  ##-------------------------------------------------------------------------------------------
  ## Abrimos del fichero
   Openo filpath("SISLOG/ENVIOS",WFICHERO,"dat"),0 Using [PRO]
   Iomode adxirs chr$(13)+chr$(10) Using [PRO]  #Separador de registros. Fin de linea.
   Iomode adxifs ""                Using [PRO]  #Separador de campos.
   Iomode adxium 50                Using [PRO]  #Formato de fichero. 50: ASCII, 122: UCS2, 0: UTF8

  ##--------------------------------------------------------------------------------------------
  ## Bucle sobre la tabla de proveedores
  WNUMREG=0
  For [ZBPS]
    WNUMREG+=1
    Wrseq format$("N0:6#",WNUMREG);                Using [PRO]
    Wrseq right$(WFICHERO,4);                      Using [PRO]
    Wrseq format$("6X",[F:BPS]BPSNUM);             Using [PRO]
    Wrseq space$(15);                              Using [PRO]
    Wrseq format$("40X",[F:BPS]BPSNAM);            Using [PRO]
    If [F:BPS]BPSSHO<>""
      Wrseq format$("15X",[F:BPS]BPSSHO);            Using [PRO]
    Else
      Wrseq format$("15X",[F:BPS]BPSNAM);            Using [PRO]
    Endif
    Wrseq format$("40X",[F:BPS]BPSNAM);            Using [PRO]
    ##---- Dirección
    Raz [F:BPA]
    Read [F:BPA]BPA0=1;[F:BPS]BPSNUM;[F:BPS]BPAADD
    If [F:BPA]BPAADDLIG(0)<>""
      Wrseq format$("40X",[F:BPA]BPAADDLIG(0)-[F:BPA]BPAADDLIG(1)); Using [PRO]
    Else
      Wrseq format$("40X","-");                    Using [PRO]
    Endif
    Wrseq format$("7X",[F:BPA]POSCOD);             Using [PRO]
    If [F:BPA]CTY<>""
      Wrseq format$("40X",[F:BPA]CTY);             Using [PRO]
    Else
      Wrseq format$("40X","-");                    Using [PRO]
    Endif
    If [F:BPA]SAT<>""
      Wrseq format$("40X",[F:BPA]SAT);             Using [PRO]
    Else
      Wrseq format$("40X","-");                    Using [PRO]
    Endif
    ##---- Pais
    Read [F:AXX]AXX0="TABCOUNTRY";"CRYDES";"SPA";[F:BPA]CRY;""
    Wrseq format$("40X",[F:AXX]TEXTE);             Using [PRO]
    Wrseq format$("40X",[F:BPA]TEL(0));            Using [PRO]
    Wrseq space$(14);                              Using [PRO]
    If [F:BPS]ZEXPSISLOG<>2
      Wrseq "A";                                   Using [PRO]
    Else
      Wrseq "M";                                   Using [PRO]
    Endif
    Wrseq format$("D:YYYYMMDDhhmmss",datetime$) Using [PRO]
    If [F:BPS]ZEXPSISLOG<>2
      Read [F:XBPS]BPS0=[F:BPS]BPSNUM
      If !fstat
        [F:XBPS]ZEXPSISLOG=2
        Rewrite [F:XBPS]
      Endif
    Endif
    Call ECR_TRACE("Exportado"-[F:BPS]BPSNUM-[F:BPS]BPSNAM,0) From GESECRAN
  Next
  Call ECR_TRACE("Exportados"-num$(WNUMREG)-"proveedores",0) From GESECRAN
  Openo Using [PRO]
Else
  Call ECR_TRACE("Ningún proveedor exportado",0) From GESECRAN
Endif

Return
###########################################################################
## Apertura de tablas y definición de variables de trabajo
###########################################################################
$OUVRE
Local Datetime WULTFECHA
Local Char WFICHERO(30)
Local Integer WNUMREG
##----
If !clalev([ADW]): Local File ADOVAL: Endif
If !clalev([ITF]): Local File ITMFACILIT: Endif
If !clalev([BPS]): Local File BPSUPPLIER: Endif
If !clalev([BPC]): Local File BPCUSTOMER: Endif
If !clalev([XBPC]): Local File BPCUSTOMER [F:XBPC]: Endif
If !clalev([XBPS]): Local File BPSUPPLIER [F:XBPS]: Endif
If !clalev([BSG]): Local File BPSCATEG: Endif
If !clalev([BCG]): Local File BPCCATEG: Endif
If !clalev([BPA]): Local File BPADDRESS: Endif
If !clalev([AXX]): Local File ATEXTRA: Endif
If !clalev([ITM]): Local File ITMMASTER: Endif
If !clalev([XITM]): Local File ITMMASTER[XITM]: Endif
If !clalev([ITG]): Local File ITMCATEG: Endif
If !clalev([FCY]): Local File FACILITY: Endif
If !clalev([POH]): Local File PORDER: Endif
If !clalev([POQ]): Local File PORDERQ: Endif
If !clalev([XPOH]): Local File PORDER[XPOH]: Endif
If !clalev([SOH]): Local File SORDER: Endif
If !clalev([SOQ]): Local File SORDERQ: Endif
If !clalev([XSOH]): Local File SORDER[XSOH]: Endif
Return
############################################################################
## Gestión de la fecha/hora de ultima exportación
############################################################################
$ULTFECHA_EXP
  Local Char WULTFECHAX(20)
  Read [F:ADW]ADW0="";"";"ZULTEXP"
  If fstat
   Call ECR_TRACE("Problemas con la fecha de última exportación",1) From GESECRAN
  Else
   WULTFECHA = gdatetime$(num$([F:ADW]VALEUR))
  Endif
#  [F:ADW]VALEUR=num$(datetime$)
#  Rewrite [F:ADW]
Return
$ACT_ULTFECHA_EXP
  Read [F:ADW]ADW0="";"";"ZULTEXP"
  If fstat
   Call ECR_TRACE("Problemas con la fecha de última exportación",1) From GESECRAN
  Else
  [F:ADW]VALEUR=num$(datetime$)
  Rewrite [F:ADW]
  Endif
Return
