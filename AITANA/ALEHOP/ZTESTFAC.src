#<AdxTL>@(#)0.0.0.0 $Revision$ 
If clalev([SIV]) = 0 : Local File SINVOICEV[SIV] : Endif
Filter [SIV] Where [SIV]INVTYP = 2 and [SIV]SIVTYP = "AV" and (LEFT$([SIV]SALFCY,1) = "P" OR LEFT$([SIV]SALFCY,1) = "C" OR LEFT$([SIV]SALFCY,1) = "F") and [SIV]ZDEVSMR = ""
If rowcount([SIV]) > 0 Then
  #Recorremos la cabecera de la factura
  For [SIV]
    INFBOX "La factura es " + [SIV]NUM
  Next
Endif
Close Local File [SIV]



