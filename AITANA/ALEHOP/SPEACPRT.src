&      With QTY = [F:ZSVTW]CANTIDAD, PVP=[F:ZSVTW]PVP
       If [M]YTRAZA=2 : Call ECR_TRACE("ZSVT - update: "  + [F:ZSVTW]ITMREF + " " + [F:ZSVTW]TIPOTIENDA + " " + num$([F:ZSVTW]ANY) + " " + num$([F:ZSVTW]SEMANA), 0 ) From GESECRAN : Endif
    Else
      Trbegin [F:ZSVT]
      [F:ZSVT]=[F:ZSVTW]
      Write [F:ZSVT]
      If fstat=0
        Commit
        If [M]YTRAZA=2 : Call ECR_TRACE("ZSVT - write: "  + [F:ZSVTW]ITMREF + " " + [F:ZSVTW]TIPOTIENDA + " " + num$([F:ZSVTW]ANY) + " " + num$([F:ZSVTW]SEMANA), 0 ) From GESECRAN : Endif
      Else
        Rollback
        If [M]YTRAZA=2 : Call ECR_TRACE("ZSVT - err-write: "  + [F:ZSVTW]ITMREF + " " + [F:ZSVTW]TIPOTIENDA + " " + num$([F:ZSVTW]ANY) + " " + num$([F:ZSVTW]SEMANA), 1 ) From GESECRAN : Endif
      Endif
    Endif
  Next
  If [M]YTRAZA=2 : Call ECR_TRACE("ZSVT - número de registros tratados: " + num$(CZSVT),0) From GESECRAN : Endif
Return


$ACT_ZVAMEDI
  If [M]YTRAZA=2 : Call ECR_TRACE("Actualizar ZVAMEDI",0) From GESECRAN : Endif

  CZVAMEDI = 0
  For [F:ZVAMEDIW]
    CZVAMEDI+=1
    Read [F:ZVAMEDI]ITMREF=[F:ZVAMEDIW]ITMREF;[F:ZVAMEDIW]ANY
    If !fstat Then
      Update [F:ZVAMEDI] Where ITMREF=[F:ZVAMEDIW]ITMREF and ANY=[F:ZVAMEDIW]ANY
&      With QTY = [F:ZVAMEDIW]QTY, VALOR=[F:ZVAMEDIW]VALOR, NSEMANAS=[F:ZVAMEDIW]NSEMANAS
       If [M]YTRAZA=2 : Call ECR_TRACE("ZVAMEDI - update: "  + [F:ZVAMEDIW]ITMREF + " " + num$([F:ZVAMEDIW]ANY) , 0 ) From GESECRAN : Endif
    Else
