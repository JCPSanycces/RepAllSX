       If [M]YTRAZA=2 : Call ECR_TRACE("ZVAMEDI - write: "  + [F:ZVAMEDIW]ITMREF + " " + num$([F:ZVAMEDIW]ANY) , 0 ) From GESECRAN : Endif
      Else
        Rollback
       If [M]YTRAZA=2 : Call ECR_TRACE("ZVAMEDI - err-write: "  + [F:ZVAMEDIW]ITMREF + " " + num$([F:ZVAMEDIW]ANY) , 1 ) From GESECRAN : Endif
      Endif
    Endif
  Next
  If [M]YTRAZA=2 : Call ECR_TRACE("ZVAMEDI - número de registros tratados: " + num$(CZVAMEDI),0) From GESECRAN : Endif
Return



$ACT_ZVTMEDI
  If [M]YTRAZA=2 : Call ECR_TRACE("Actualizar ZVTMEDI",0) From GESECRAN : Endif

  CZVTMEDI = 0
  For [F:ZVTMEDIW]
    CZVTMEDI+=1
    Read [F:ZVTMEDI]ITMREF=[F:ZVTMEDIW]ITMREF;[F:ZVTMEDIW]ANY
    If !fstat Then
      Update [F:ZVTMEDI] Where ITMREF=[F:ZVTMEDIW]ITMREF and ANY=[F:ZVTMEDIW]ANY
&      With QTY = [F:ZVTMEDIW]QTY, PVP=[F:ZVTMEDIW]PVP, NSEMANAS=[F:ZVTMEDIW]NSEMANAS
       If [M]YTRAZA=2 : Call ECR_TRACE("ZVTMEDI - update: "  + [F:ZVTMEDIW]ITMREF + " " + num$([F:ZVTMEDIW]ANY) , 0 ) From GESECRAN : Endif
    Else
      Trbegin [F:ZVTMEDI]
      [F:ZVTMEDI]=[F:ZVTMEDIW]
      Write [F:ZVTMEDI]
      If fstat=0
        Commit
       If [M]YTRAZA=2 : Call ECR_TRACE("ZVTMEDI - write: "  + [F:ZVTMEDIW]ITMREF + " " + num$([F:ZVTMEDIW]ANY) , 0 ) From GESECRAN : Endif
      Else
        Rollback
       If [M]YTRAZA=2 : Call ECR_TRACE("ZVTMEDI - err-write: "  + [F:ZVTMEDIW]ITMREF + " " + num$([F:ZVTMEDIW]ANY) , 1 ) From GESECRAN : Endif
      Endif
    Endif
  Next
  If [M]YTRAZA=2 : Call ECR_TRACE("ZVTMEDI - número de registros tratados: " + num$(CZVTMEDI),0) From GESECRAN : Endif
Return




$EXEC
 If GSERVEUR Then
   Gosub OUVRE
   Gosub DEBUT
   Gosub OK
 Endif
Return
##################################################################################################################
$AVANT_PAR
Return
##################################################################################################################
$FIN
Return



Subprog ZACTABPR()
  If !clalev([M:DIA]) : Local Mask ZACUMPRTAB[DIA] : Endif
  Default Mask [M:DIA]
  [M:DIA]YTRAZA = 2
  Gosub EXEC
End

