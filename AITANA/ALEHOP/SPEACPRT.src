#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "DEBUT"      : Gosub DEBUT
  When "OK"         : Gosub OK
  When "EXEC"       : Gosub EXEC
  When "AVANT_PAR"  : Gosub AVANT_PAR
  When "FIN"        : Gosub FIN
  When Default
Endcase
Return

$OUVRE
  If !clalev([M:DIA]) : Local Mask ZACUMPRTAB[DIA] : Endif
  Default Mask [M:DIA]
  ##tablas de destino
  If !clalev([F:ZPC]) : Local File ZPC[ZPC] :Endif
  If !clalev([F:ZVT]) : Local File ZVENTIEN[ZVT] :Endif
  If !clalev([F:ZVA]) : Local File ZVALM[ZVA] :Endif
  If !clalev([F:ZMD]) : Local File ZMEDIAS[ZMD] :Endif
  If !clalev([F:ZPR]) : Local File ZPROV[ZPR] Endif
  If !clalev([F:ZSVA]   ) : Local File ZSEMANASVA [ZSVA]    : Endif
  If !clalev([F:ZSVT]   ) : Local File ZSEMANASVT [ZSVT]    : Endif
  If !clalev([F:ZVAMEDI]) : Local File ZVAMEDIAS  [ZVAMEDI] : Endif
  If !clalev([F:ZVTMEDI]) : Local File ZVTMEDIAS  [ZVTMEDI] : Endif

  #vistas de origen
  If !clalev([F:ZPCW]) : Local File ZPCW[ZPCW] :Endif
  If !clalev([F:ZVTW]) : Local File ZVENTIENW[ZVTW] :Endif
  If !clalev([F:ZVAW]) : Local File ZVALMW[ZVAW] :Endif
  If !clalev([F:ZMDW]) : Local File ZMEDIAW[ZMDW] :Endif
  If !clalev([F:ZMEW]) : Local File ZMESESW[ZMEW] :Endif
  If !clalev([F:ZPRW]) : Local File ZPROVW[ZPRW] Endif
  If !clalev([F:ZSVAW]   ) : Local File ZSEMANASVAW [ZSVAW]    : Endif
  If !clalev([F:ZSVTW]   ) : Local File ZSEMANASVTW [ZSVTW]    : Endif
  If !clalev([F:ZVAMEDIW]) : Local File ZVAMEDIASW  [ZVAMEDIW] : Endif
  If !clalev([F:ZVTMEDIW]) : Local File ZVTMEDIASW  [ZVTMEDIW] : Endif


  Local Integer CZPCW, CZVTW, CZVAW, CZMDW, CZPRW
  Local Integer CZSVA, CZSVT, CZVAMEDI, CZVTMEDI

  Local Integer ANYOMES,ANYO
  Local Integer YSTAT

Return


$DEBUT
#  If month(date$)=1 Then
#    [M]YFECINI = gdat$(1,12,year(date$)-1)
#  Else
#    [M]YFECINI = gdat$(1,month(date$)-1,year(date$))
#  Endif
Return

$OK
#
#  ANYOMES=year([M]YFECINI)*100 + month([M]YFECINI)
#  ANYO   =year([M]YFECINI)

If !GSERVEUR Then
  Call OUINON ("¿Actualizar tablas?", YSTAT ) From GESECRAN
Else
  YSTAT=2
Endif

If YSTAT=2 Then

  If [M]YTRAZA=2 Then
     Call OUVRE_TRACE ("Actualización de tablas de acumulados") From LECFIC
  Endif
  Gosub ACT_ZPC

  Gosub ACT_ZVENTIEN

  Gosub ACT_ZAVALM

  Gosub ACT_ZMEDIAS

  Gosub ACT_ZPROV

  Gosub ACT_ZVT
  Gosub ACT_ZSVA
  Gosub ACT_ZSVT
  Gosub ACT_ZVAMEDI
  Gosub ACT_ZVTMEDI

  If [M]YTRAZA=2  : Call FERME_TRACE From LECFIC : Endif
  If !GSERVEUR and [M]YTRAZA=2 Then
    Call LEC_TRACE() From LECFIC
  Endif
Endif

Return


$ACT_ZPC
  #SE ACTUALIZAN TODOS LOS ARTÍCULOS DE LA VISTA
   If [M]YTRAZA=2 : Call ECR_TRACE("Actualizar ZPC",0) From GESECRAN : Endif

  CZPCW = 0
  For [F:ZPCW]
    CZPCW+=1
    Read [F:ZPC]ITMREF=[F:ZPCW]ITMREF
    If !fstat Then
      Update [F:ZPC] Where ITMREF = [F:ZPCW]ITMREF With PC = [F:ZPCW]PC
       If [M]YTRAZA=2 : Call ECR_TRACE("ZPC - update: " + [F:ZPCW]ITMREF + " " + num$([F:ZPCW]PC),0) From GESECRAN : Endif
    Else
      Trbegin [F:ZPC]
      [F:ZPC]=[F:ZPCW]
      Write [F:ZPC]
      If fstat=0
        Commit
         If [M]YTRAZA=2 : Call ECR_TRACE("ZPC - write:   " + [F:ZPCW]ITMREF + " " + num$([F:ZPCW]PC),0) From GESECRAN : Endif
      Else
        Rollback
         If [M]YTRAZA=2 : Call ECR_TRACE("ZPC - write_err:" + [F:ZPCW]ITMREF + " " + num$([F:ZPCW]PC),1) From GESECRAN : Endif
      Endif
    Endif
  Next
   If [M]YTRAZA=2 : Call ECR_TRACE("ZPC - número de registros tratados: " + num$(CZPCW),0) From GESECRAN : Endif

Return


$ACT_ZVENTIEN
  #SE ACTUALIZAN TODOS LOS ARTÍCULOS DE LA VISTA
   If [M]YTRAZA=2 : Call ECR_TRACE("Actualizar ZVT",0) From GESECRAN :  Endif

  CZVTW = 0
  Filter [F:ZVTW] #Where [F:ZVTW]ANY*100+[F:ZVTW]MES >= ANYOMES
  For [F:ZVTW]
    CZVTW+=1
    Read [F:ZVT]ZVT0=[F:ZVTW]ITMREF;[F:ZVTW]TIPOTIEN;[F:ZVTW]ANY;[F:ZVTW]MES
    If !fstat Then
      Update [F:ZVT] Where ITMREF=[F:ZVTW]ITMREF and TIPOTIEN=[F:ZVTW]TIPOTIEN and ANY=[F:ZVTW]ANY and MES=[F:ZVTW]MES
&     With QTY=[F:ZVTW]QTY,CONSUMO=[F:ZVTW]CONSUMO,IMPORTEPVP=[F:ZVTW]IMPORTEPVP
     If [M]YTRAZA=2 : Call ECR_TRACE("ZVT - update:   " + [F:ZVTW]ITMREF + " " + [F:ZVTW]TIPOTIEN + " " + num$([F:ZVTW]ANY)+ " " + num$([F:ZVTW]MES),0) From GESECRAN : Endif

    Else
      Trbegin [F:ZVT]
      [F:ZVT]=[F:ZVTW]
      Write [F:ZVT]
      If !fstat
        Commit
         If [M]YTRAZA=2 : Call ECR_TRACE("ZVT - write:   " + [F:ZVTW]ITMREF + " " + [F:ZVTW]TIPOTIEN + " " + num$([F:ZVTW]ANY)+ " " + num$([F:ZVTW]MES),0) From GESECRAN : Endif
      Else
        Rollback
         If [M]YTRAZA=2 : Call ECR_TRACE("ZVT - write_err:" + [F:ZVTW]ITMREF + " " + [F:ZVTW]TIPOTIEN + " " + num$([F:ZVTW]ANY)+ " " + num$([F:ZVTW]MES),1) From GESECRAN : Endif
      Endif
    Endif
  Next
   If [M]YTRAZA=2 : Call ECR_TRACE("ZVT - número de registros tratados: " + num$(CZVTW),0) From GESECRAN : Endif

Return



$ACT_ZAVALM
  #SE ACTUALIZAN LAS SALIDAS DE ALMACÉN
   If [M]YTRAZA=2 : Call ECR_TRACE("Actualizar ZAVALM",0) From GESECRAN : Endif
  CZVAW = 0

  Filter [F:ZVAW] # Where [F:ZVAW]ANY >= ANYO
  For [F:ZVAW]
    CZVAW+=1
    Read [F:ZVA]ITMREF=[F:ZVAW]ITMREF;[F:ZVAW]ANY
    If !fstat Then
      Update [F:ZVA] Where ITMREF=[F:ZVAW]ITMREF and ANY=[F:ZVAW]ANY
&     With SALIDA=[F:ZVAW]SALIDA,CSALIDA=[F:ZVAW]CSALIDA,VSALIDA=[F:ZVAW]VSALIDA,VENTA=[F:ZVAW]VENTA,CVENTA=[F:ZVAW]CVENTA,
&     VVENTA=[F:ZVAW]VVENTA,PC=[F:ZVAW]PC
     If [M]YTRAZA=2 : Call ECR_TRACE("ZVA - update:   " + [F:ZVAW]ITMREF + " " + num$([F:ZVAW]ANY),0) From GESECRAN : Endif

    Else
      Trbegin [F:ZVA]
      [F:ZVA]=[F:ZVAW]
      Write [F:ZVA]
      If !fstat
        Commit
         If [M]YTRAZA=2 : Call ECR_TRACE("ZVA - write:   " + [F:ZVAW]ITMREF + " " + num$([F:ZVAW]ANY),0) From GESECRAN : Endif
      Else
        Rollback
         If [M]YTRAZA=2 : Call ECR_TRACE("ZVA - write_err:" + [F:ZVAW]ITMREF + " " + num$([F:ZVAW]ANY),1) From GESECRAN : Endif
      Endif
    Endif
  Next
   If [M]YTRAZA=2 : Call ECR_TRACE("ZVA - número de registros tratados: " + num$(CZVAW),0) From GESECRAN : Endif

Return



$ACT_ZMEDIAS
  #SE ACTUALIZAN LAS MEDIAS
   If [M]YTRAZA=2 : Call ECR_TRACE("Actualizar ZMEDIAS",0) From GESECRAN : Endif
  CZMDW = 0
#AQUI
  #PRIMERA FASE, ACTUALIZAR MESES
  Filter [F:ZMEW] # Where [F:ZMEW]ANY >= ANYO
  For [F:ZMEW]
    CZMDW+=1
    Read [F:ZMD]ITMREF=[F:ZMEW]ITMREF;[F:ZMEW]ANY
    If !fstat Then
      Update [F:ZMD] Where ITMREF=[F:ZMEW]ITMREF and ANY=[F:ZMEW]ANY
&     With MESES=[F:ZMEW]MESES,NMES=[F:ZMEW]NMES
     If [M]YTRAZA=2 : Call ECR_TRACE("ZMD - update:   " + [F:ZMEW]ITMREF + " " + num$([F:ZMEW]ANY),0) From GESECRAN : Endif
    Else
      Trbegin [F:ZMD]
      [F:ZMD]=[F:ZMEW]
      Write [F:ZMD]
      If !fstat
        Commit
         If [M]YTRAZA=2 : Call ECR_TRACE("ZMD - write:   " + [F:ZMEW]ITMREF + " " + num$([F:ZMEW]ANY),0) From GESECRAN : Endif
      Else
        Rollback
         If [M]YTRAZA=2 : Call ECR_TRACE("ZMD - write_err:" + [F:ZMEW]ITMREF + " " + num$([F:ZMEW]ANY),1) From GESECRAN : Endif
      Endif
    Endif
  Next
   If [M]YTRAZA=2 : Call ECR_TRACE("ZMD - número de registros tratados: " + num$(CZMDW),0) From GESECRAN : Endif

  CZMDW=0
  #SEGUNDA FASE, ACTUALIZAR MEDIAS
  Filter [F:ZMDW] # Where [F:ZMDW]ANY >= ANYO
  For [F:ZMDW]
    CZMDW+=1
    Read [F:ZMD]ITMREF=[F:ZMDW]ITMREF;[F:ZMDW]ANY
    If !fstat Then
      Update [F:ZMD] Where ITMREF=[F:ZMDW]ITMREF and ANY=[F:ZMDW]ANY
&     With MEDIA=[F:ZMDW]MEDIA
     If [M]YTRAZA=2 : Call ECR_TRACE("ZMD2 - update:   " + [F:ZMDW]ITMREF + " " + num$([F:ZMDW]ANY),0) From GESECRAN : Endif
    Else
      Trbegin [F:ZMD]
      [F:ZMD]=[F:ZMDW]
      Write [F:ZMD]
      If !fstat
        Commit
         If [M]YTRAZA=2 : Call ECR_TRACE("ZMD2 - write:   " + [F:ZMDW]ITMREF + " " + num$([F:ZMDW]ANY),0) From GESECRAN : Endif
      Else
        Rollback
         If [M]YTRAZA=2 : Call ECR_TRACE("ZMD2 - write_err:" + [F:ZMDW]ITMREF + " " + num$([F:ZMDW]ANY),1) From GESECRAN : Endif
      Endif
    Endif
  Next
   If [M]YTRAZA=2 : Call ECR_TRACE("ZMD2 - número de registros tratados: " + num$(CZMDW),0) From GESECRAN : Endif

Return

$ACT_ZPROV
  #SE ACTUALIZAN ZPROV
   If [M]YTRAZA=2 : Call ECR_TRACE("Actualizar ZPROV",0) From GESECRAN : Endif
  CZPRW = 0

  Filter [F:ZPRW]
  For [F:ZPRW]
    CZPRW+=1
    Read [F:ZPR]=[F:ZPRW]ITMREF
    If !fstat Then
      Update [F:ZPR] Where ITMREF=[F:ZPRW]ITMREF
&     With PROV=[F:ZPRW]PROV
     If [M]YTRAZA=2 : Call ECR_TRACE("ZPR - update:   " + [F:ZPRW]ITMREF ,0) From GESECRAN : Endif
##aqui
    Else
      Trbegin [F:ZPR]
      [F:ZPR]=[F:ZPRW]
      Write [F:ZPR]
      If !fstat
        Commit
         If [M]YTRAZA=2 : Call ECR_TRACE("ZPR - write:   " + [F:ZPRW]ITMREF,0) From GESECRAN : Endif
      Else
        Rollback
         If [M]YTRAZA=2 : Call ECR_TRACE("ZPR - write_err:" + [F:ZPRW]ITMREF,1) From GESECRAN : Endif
      Endif
    Endif
  Next
   If [M]YTRAZA=2 : Call ECR_TRACE("ZPR - número de registros tratados: " + num$(CZPRW),0) From GESECRAN : Endif

Return



$ACT_ZVT
  If [M]YTRAZA=2 : Call ECR_TRACE("Actualizar ZVT",0) From GESECRAN : Endif

  CZVTW = 0
  For [F:ZVTW]
    CZVTW+=1
    Read [F:ZVT]ZVT0=[F:ZVTW]ITMREF;[F:ZVTW]TIPOTIEN;[F:ZVTW]ANY;[F:ZVTW]MES
    If !fstat Then
      Update [F:ZVT] Where ITMREF = [F:ZVTW]ITMREF and TIPOTIEN=[F:ZVTW]TIPOTIEN and ANY=[F:ZVTW]ANY and MES=[F:ZVTW]MES
&     With QTY = [F:ZVTW]QTY, CONSUMO = [F:ZVTW]CONSUMO, IMPORTEPVP = [F:ZVTW]IMPORTEPVP
      If [M]YTRAZA=2 :Call ECR_TRACE("ZVT - update: " + [F:ZVTW]ITMREF + " " + [F:ZVTW]TIPOTIEN + " " + num$([F:ZVTW]ANY) + " " + num$([F:ZVTW]MES),0) From GESECRAN : Endif
    Else
      Trbegin [F:ZVT]
      [F:ZPC]=[F:ZVTW]
      Write [F:ZVT]
      If fstat=0
        Commit
        If [M]YTRAZA=2 : Call ECR_TRACE("ZVT - write: " + [F:ZVTW]ITMREF + " " + [F:ZVTW]TIPOTIEN + " " + num$([F:ZVTW]ANY) + " " + num$([F:ZVTW]MES),0) From GESECRAN : Endif
      Else
        Rollback
        If [M]YTRAZA=2 : Call ECR_TRACE("ZVT - err-write: " + [F:ZVTW]ITMREF + " " + [F:ZVTW]TIPOTIEN + " " + num$([F:ZVTW]ANY) + " " + num$([F:ZVTW]MES),1) From GESECRAN : Endif
      Endif
    Endif
  Next
  If [M]YTRAZA=2 : Call ECR_TRACE("ZVT - número de registros tratados: " + num$(CZVTW),0) From GESECRAN : Endif
Return



$ACT_ZVA
  If [M]YTRAZA=2 : Call ECR_TRACE("Actualizar ZVA",0) From GESECRAN : Endif

  CZVAW = 0
  For [F:ZVAW]
    CZVAW+=1
    Read [F:ZVA]ITMREF=[F:ZVAW]ITMREF;[F:ZVAW]ANY
    If !fstat Then
      Update [F:ZVA] Where ITMREF = [F:ZVAW]ITMREF and ANY=[F:ZVAW]ANY
&     With SALIDA=[F:ZVAW]SALIDA, CSALIDA=[F:ZVAW]CSALIDA, VSALIDA=[F:ZVAW]VSALIDA, VENTA=[F:ZVAW]VENTA,
&     CVENTA=[F:ZVAW]CVENTA, VVENTA=[F:ZVAW]VVENTA, PC=[F:ZVAW]PC
      If [M]YTRAZA=2 : Call ECR_TRACE("ZVA - update: " + [F:ZVAW]ITMREF + " " + num$([F:ZVAW]ANY) ,0) From GESECRAN : Endif
    Else
      Trbegin [F:ZVA]
      [F:ZVA]=[F:ZVAW]
      Write [F:ZVA]
      If fstat=0
        Commit
        If [M]YTRAZA=2 : Call ECR_TRACE("ZVA - write: "  + [F:ZVAW]ITMREF + " " + num$([F:ZVAW]ANY) ,0) From GESECRAN : Endif
      Else
        Rollback
        If [M]YTRAZA=2 : Call ECR_TRACE("ZVA - err-write: "  + [F:ZVAW]ITMREF + " " + num$([F:ZVAW]ANY) ,1) From GESECRAN : Endif
      Endif
    Endif
  Next
  If [M]YTRAZA=2 : Call ECR_TRACE("ZVA - número de registros tratados: " + num$(CZVAW),0) From GESECRAN : Endif
Return


$ACT_ZSVA
  If [M]YTRAZA=2 : Call ECR_TRACE("Actualizar ZSVA",0) From GESECRAN : Endif

  CZSVA = 0
  For [F:ZSVAW]
    CZSVA+=1
    Read [F:ZSVA]ITM=[F:ZSVAW]ITMREF;[F:ZSVAW]TIPOTIENDA;[F:ZSVAW]ANY;[F:ZSVAW]SEMANA
    If !fstat Then
      Update [F:ZSVA] Where ITMREF=[F:ZSVAW]ITMREF and TIPOTIENDA=[F:ZSVAW]TIPOTIENDA and ANY=[F:ZSVAW]ANY and SEMANA=[F:ZSVAW]SEMANA
&      With QTY = [F:ZSVAW]CANTIDAD, VALOR=[F:ZSVAW]VALOR
       If [M]YTRAZA=2 : Call ECR_TRACE("ZSVA - update: "  + [F:ZSVAW]ITMREF + " " + [F:ZSVAW]TIPOTIENDA + " " + num$([F:ZSVAW]ANY) + " " + num$([F:ZSVAW]SEMANA), 0 ) From GESECRAN : Endif
    Else
      Trbegin [F:ZSVA]
      [F:ZSVA]=[F:ZSVAW]
      Write [F:ZSVA]
      If fstat=0
        Commit
        If [M]YTRAZA=2 : Call ECR_TRACE("ZSVA - write: "  + [F:ZSVAW]ITMREF + " " + [F:ZSVAW]TIPOTIENDA + " " + num$([F:ZSVAW]ANY) + " " + num$([F:ZSVAW]SEMANA), 0 ) From GESECRAN : Endif
      Else
        Rollback
        If [M]YTRAZA=2 : Call ECR_TRACE("ZSVA - err-write: "  + [F:ZSVAW]ITMREF + " " + [F:ZSVAW]TIPOTIENDA + " " + num$([F:ZSVAW]ANY) + " " + num$([F:ZSVAW]SEMANA), 1 ) From GESECRAN : Endif
      Endif
    Endif
  Next
  If [M]YTRAZA=2 : Call ECR_TRACE("ZSVA - número de registros tratados: " + num$(CZSVA),0) From GESECRAN : Endif
Return

$ACT_ZSVT
  If [M]YTRAZA=2 : Call ECR_TRACE("Actualizar ZSVT",0) From GESECRAN : Endif

  CZSVT = 0
  For [F:ZSVTW]
    CZSVT+=1
    Read [F:ZSVT]ITM=[F:ZSVTW]ITMREF;[F:ZSVTW]TIPOTIENDA;[F:ZSVTW]ANY;[F:ZSVTW]SEMANA
    If !fstat Then
