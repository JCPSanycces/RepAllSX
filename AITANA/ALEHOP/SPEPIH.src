# Gestión de la máscara PIH3 (Especifico)
# XVT20190219 Gestión inmovilizado. Si la factura es de una planta que pertenece a un grupo
# de plantas que está marcado para realizar esta gestión, y el importe de línea sin impuestos
# supera el importe marcado por parámetro en la tabla varia 6003, el tipo de línea será inmovilizado
# y las cuentas contables, las correspondientes a inmovilizado.

######################################################################################
## Etiqueta añadida por el supervisor (pantalla PIH3) 19/02/2019 15:13:45 (ADMIN)
######################################################################################
$ACTION
Case ACTION
 When Default
Endcase
Return
######################################################################################

##############################################################
######################    ACCIONES    ########################
##############################################################

##############################################################
######################    ETIQUETAS    #######################
##############################################################

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
Subprog AM_ZSPACUSDAT(VALEUR)
Variable Date    VALEUR
[M:PIH1]SPACUSDAT= [M:PIH0]ACCDAT

End

######################################################################################
Subprog AM_SPACUSDAT(VALEUR)
Variable Date    VALEUR
Local Integer OKCAN : OKCAN = 1:# Ok

Call AVERTIR('¿Desea modificar la fecha de presentación para el SII ?', OKCAN) From GESECRAN
If OKCAN = 2
  [M:PIH1]SPACUSDAT = VALEUR
Else
  VALEUR = [M:PIH1]SPACUSDAT
Endif

End

######################################################################################
Subprog C_LINPURTYP(VALEUR)
Variable Integer VALEUR
 If func SPEPIH.ES_INMOVILIZADO([M:PIH0]FCY,[M:PIH3]ITMREF(nolign-1),[M:PIH3]AMTNOTLIN(nolign-1))>0 Then
    VALEUR=2
  Endif
End

######################################################################################
## Después de modificar el campo 'Fecha fact. Prov.' (pantalla PIH1) 21/04/2021 15:50:03 (AIT07)
######################################################################################
Subprog AM_BPRDAT(VALEUR)
Variable Date    VALEUR
  [M:PIH1]STRDUDDAT = [M:PIH0]ACCDAT
  Affzo [M:PIH1]STRDUDDAT
End

######################################################################################
## Después de modificar el campo 'Fecha contable' (pantalla PIH0) 21/04/2021 15:52:01 (AIT07)
######################################################################################
Subprog AM_ACCDAT(VALEUR)
Variable Date    VALEUR
  [M:PIH1]STRDUDDAT = VALEUR
  Affzo [M:PIH1]STRDUDDAT
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
##############################################################
Funprog ES_INMOVILIZADO(P_FCY, P_ITMREF, P_AMTNOTLIN)
Value Char P_FCY
Value Char P_ITMREF
Value Decimal P_AMTNOTLIN
#LA FUNCIÓN DEVUELVE EL IMPORTE MÍNIMO A PARTIR DEL CUAL SE VA A INMOVILIZAR
#O UN CERO, EN CASO CONTRARIO.

  If !clalev([ZITM]) : Local File ITMMASTER [ZITM] : Endif
  If !clalev([ZFGR]) : Local File FACGROUP  [ZFGR] : Endif
  If !clalev([ZAGC]) : Local File AGRPCPY   [ZAGC] : Endif
  If !clalev([ZADI]) : Local File ATABDIV   [ZADI] : Endif

  VALEUR=0

  Read [F:ZITM]ITM0=P_ITMREF
  If !fstat and [F:ZITM]TCLCOD="AVI" Then
    Filter [F:ZFGR] Where FCY=P_FCY
    For [ZFGR]
      Filter [F:ZAGC] Where CPY=[F:ZFGR]CPY
      For [F:ZAGC]
        Read [ZADI]CODE=6003;[ZAGC]GRP
        If !fstat Then
            If [F:ZADI]ENAFLG=2 and P_AMTNOTLIN>=[F:ZADI]N1 : VALEUR = 1 : Endif
        Endif
      Next
      Filter [F:ZAGC]
    Next
    Filter [F:ZFGR]
  Endif

End VALEUR
