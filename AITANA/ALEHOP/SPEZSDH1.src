#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION
  When "AVANT_OK" : Gosub AVANT_OK
  When "AV_CHOIX" : Gosub AV_CHOIX
  When "FINSAI"        : Gosub FINSAI
  When Default
Endcase
Return


###############################################################################
$FINSAI
#Local Integer LCON, NLIN
#  If GUSER="ADMIN" Then : Infbox "hola1" : Endif
#For LCON = 0 To [M:ZSDH1]NBLIG-1
#  If GUSER="ADMIN" Then : Infbox "hola" : Endif
#  NLIN = [M:ZSDH1]SDDLIN(LCON)
#  If GUSER="ADMIN" Then : Infbox num$([M:SDH1]QTY(3000)) : Endif
#  [M:SDH1]QTY(NLIN) = [M:ZSDH1]QTY(LCON)
#  Affzo [M:SDH1]QTY(NLIN)
#  Affzo [M:SDH1]
#  Gosub AMM_QTY
#  [M:SDH1]UPDFLG(NLIN) = 1
#Next

Local Integer LCON, LCON2
For LCON = 0 To [M:ZSDH1]NBLIG-1
  For LCON2 = 0 To [M:SDH1]NBLIG-1
    If [M:SDH1]SDDLIN(LCON2)  = [M:ZSDH1]SDDLIN(LCON)
      If GUSER="ADMIN" : Infbox "AQUI " + num$([M:SDH1]QTY(LCON2)) : Endif
      [M:SDH1]QTY(LCON2)      = [M:ZSDH1]QTY(LCON)
      Affzo [M:SDH1]QTY(LCON2)
      Affzo [M:SDH1]
      Gosub AMM_QTY

      [M:SDH1]UPDFLG(LCON2) = 1
      Break
    Endif
  Next
Next
Return

######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local Integer LCON
Local Integer FINDITM : FINDITM = 1 # 1 artículo no encontrado , 2 arículo encontrado

For LCON = 0 To [M:SDH1]NBLIG
  If [M:SDH1]ITMREF(LCON) = VALEUR
    [M:ZSDH1]ITMREF(nolign-1)   = VALEUR
    [M:ZSDH1]ITMDES(nolign-1)   = [M:SDH1]ITMDES(LCON)
    [M:ZSDH1]STU(nolign-1)      = [M:SDH1]STU(LCON)
    [M:ZSDH1]QTY(nolign-1)      = [M:SDH1]QTY(LCON)
    [M:ZSDH1]SDDLIN(nolign-1)   = [M:SDH1]SDDLIN(LCON)
    nolign += 1
    [M:ZSDH1]NBLIG += 1
    Affzo [M:ZSDH1]
    FINDITM = 2
  Endif
Next
Affzo [M:ZSDH1]
If FINDITM <> 2
  VALEUR = ''
  mkstat = 1
Endif

End

######################################################################################
$AV_CHOIX
Local Integer LCON
Raz [M:ZSDH1]
nolign = 0
[M:ZSDH1]NBLIG = 0

Return

######################################################################################
$AVANT_OK

Return


######################################################################################
$AMM_QTY
Local    Decimal ZVALEUR : ZVALEUR = [M:SDH1]QTY(LCON2) ###MS-ERROR
Local    Integer OK, WRECH_TAR
Local    Integer NOL, I, TYP
Local    Decimal MAJREM(0..8)
Local    Decimal WSNETPRI, WSNETPRINOT, WSNETPRIATI : # Bug 70861

NOL=LCON2  ###MS-ERROR

# --> Calcul des montants base calcul taxe
Local Decimal WUNTCLCAMT1, WUNTCLCAMT2
Raz WUNTCLCAMT1, WUNTCLCAMT2
If [M:SDH1]QTY(NOL) <> 0
   WUNTCLCAMT1=[M:SDH1]CLCAMT1(NOL)/[M:SDH1]QTY(NOL)
   WUNTCLCAMT2=[M:SDH1]CLCAMT2(NOL)/[M:SDH1]QTY(NOL)
Endif


Call ALICLCAMT([M:SDH1]ITMREF(NOL),ZVALEUR,NOL,"SDH1",[M:SDH1]CLCAMT1(NOL),
&              [M:SDH1]CLCAMT2(NOL)) From TRTX3

Call CALCNETPRI("[M:SDH1]",ZVALEUR, [M:SDH1]CUR, NOL) From TRTVENPRI

# comentamos las siguientes líneas porque según el usuario que está realizando
# la modificación de stock, el GDACLOK está bloqueado.
#If GDACLOK = 1
#   Call CTLNETPRI([M:SDH0]BPCORD,[M:SDH0]CHGTYP,[M:SDH1]SHIDAT,[M:SDH1]CUR,NOL) From TRTVENPRI
#   If mkstat=2 Return Endif
#Endif

[M:SDH1]LINDLVNOT(NOL) = [M:SDH1]NETPRI(NOL) * [M:SDH1]QTY(NOL)
[M:SDH1]LINDLVATI(NOL) = [M:SDH1]NETPRIATI(NOL) * [M:SDH1]QTY(NOL)

Affzo [M:SDH1]LINDLVNOT(NOL)
Affzo [M:SDH1]LINDLVATI(NOL)

Affzo [M:SDH1]GROPRI(NOL)

If dim([M:SDH1]DISCRGVAL1(NOL))>0 Affzo [M:SDH1]DISCRGVAL1(NOL) Endif
If dim([M:SDH1]DISCRGVAL2(NOL))>0 Affzo [M:SDH1]DISCRGVAL2(NOL) Endif
If dim([M:SDH1]DISCRGVAL3(NOL))>0 Affzo [M:SDH1]DISCRGVAL3(NOL) Endif
If dim([M:SDH1]DISCRGVAL4(NOL))>0 Affzo [M:SDH1]DISCRGVAL4(NOL) Endif
If dim([M:SDH1]DISCRGVAL5(NOL))>0 Affzo [M:SDH1]DISCRGVAL5(NOL) Endif
If dim([M:SDH1]DISCRGVAL6(NOL))>0 Affzo [M:SDH1]DISCRGVAL6(NOL) Endif
If dim([M:SDH1]DISCRGVAL7(NOL))>0 Affzo [M:SDH1]DISCRGVAL7(NOL) Endif
If dim([M:SDH1]DISCRGVAL8(NOL))>0 Affzo [M:SDH1]DISCRGVAL8(NOL) Endif
If dim([M:SDH1]DISCRGVAL9(NOL))>0 Affzo [M:SDH1]DISCRGVAL9(NOL) Endif
Affzo [M:SDH1]NETPRI(NOL)


Return


######################################################################################
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR

End


######################################################################################
Subprog AV_ZSDHNUM(VALEUR)
Variable Char    VALEUR()
VALEUR = [M:SDH0]SDHNUM
End

