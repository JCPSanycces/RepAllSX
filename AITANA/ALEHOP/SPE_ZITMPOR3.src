#<AdxTL>@(#)0.0.0.0 $Revision$ 
#<AdxTL>@(#)0.0.0.0 $Revision$
#05/05/2020 EAP
#19/05/2000 EAP Ampliación de campos y descripción en Portugués
  Local Char    LDIREXPORT(100)
  Local Char    LFILE(200)
  Local Char    LDATLIN(255)

  Local Char REF(10) : Raz REF
  Local Char ZDESC(80) : Raz ZDESC
  Local Char PVP(10) : Raz PVP
  Local Char NPLAN(5) : Raz NPLAN
  Local Char PLANSHO(12) : Raz PLANSHO
  Local Char PLAN(60) : Raz PLAN
  Local Char CATEG(5) : Raz CATEG
  Local Char EAN(20) : Raz EAN
  Local Char STKMIN(5) : Raz STKMIN
  Local Char STKMAX(5) : Raz STKMAX
  Local Char ZFECBAJ(10) : Raz ZFECBAJ
  Local Char ZFECALT(10) : Raz ZFECALT
  Local Char STK(10) : Raz STK

  
  If !clalev([ZIP]) : Local File ZITMPOR3[ZIP] : Endif

  LDIREXPORT = "E:\export\ARTPORTUGAL\"
  LFILE = LDIREXPORT + "ITM_" + format$("D:YYYYMMDD",date$) + ".TXT"
  
  adxifs = chr$(9)
  adxirs = chr$(13)+chr$(10)
  Openo LFILE Using [ZEXP]
  
  Filter [ZIP] 
    If !fstat Then
      For [ZIP]
		REF=[ZIP]ITMREF
		ZDESC=[ZIP]ITMDES
		PVP=[ZIP]PVP
		NPLAN=[ZIP]TSICOD
		PLANSHO=[ZIP]TEXTESHO
		PLAN=[ZIP]TEXTE
		CATEG=[ZIP]TCLCOD
		EAN=[ZIP]EANCOD
		STKMIN=[ZIP]ZSTOCKMIN
		STKMAX=[ZIP]ZSTOCKMAX
		ZFECBAJ=[ZIP]ZFECHABAJA
		ZFECALT=[ZIP]ZFECHALTA
                STK=[ZIP]STOCK
                LDATLIN = REF + adxifs + ZDESC + adxifs +PVP + adxifs + NPLAN + adxifs 
                LDATLIN = LDATLIN + PLANSHO + adxifs
		LDATLIN = LDATLIN + PLAN + adxifs + CATEG + adxifs + EAN + adxifs
		LDATLIN = LDATLIN + STKMIN + adxifs + STKMAX + adxifs + ZFECBAJ + adxifs + ZFECALT + adxifs + STK
		Wrseq LDATLIN Using [ZEXP]
      Next
    Endif        
 Openo Using [ZEXP]
 Close Local File [ZIP]
End








