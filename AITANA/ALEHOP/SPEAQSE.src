##########################################################
#**
#* Genera fichero de exportaciĂłn a AQS de PC
#*!
$GEN_PC
Local Char    LDATLIN(50)(15)

#LECTURA DEL CONTROL FECHA PC
  Read [F:YADI]CODE=6001;'6'
  If !fstat
      [M:DIA]YFECPC = [F:YADI]A2
      Affzo [M:DIA]YFECPC
#  Else
#      MES = num$(month(date$))
#      If len(MES) = 1 : MES = "0" + MES : Endif
#      DIA = num$(day(date$))
#      If len(DIA) = 1 : DIA= "0" + DIA : Endif
  Endif

Gosub INICIALIZACIONES
LFILECOPY   = LDIREXPORT + "COPIA\PRECIOCH_" + LFECHA + LHORA + ".txt"
LFILE       = LDIREXPORT + "PRECIOCH_" + LFECHA + LHORA + ".txt"

# recorremos todos los artĂ­culos-coste de la planta indicada por parĂˇmetro
YCRITERE = 'PCLOC >= ctrans([M:DIA]YFECPC,":-ZT","")'

For [T2]ZAQC0 Where evalue(YCRITERE)
# abrir fichero en la primera pasada
    Gosub OPEN_FILE
    Raz LDATLIN

    ######
    # Estructura
    ###
    # POSICIĂ“N                              TIPO        LONGITUD        FORMATO
    # 1  -> CĂłdigo artĂ­culo                 NumĂ©rico      7             Rellenar 0 por delante
    # 2  -> Referencia tarifa               Texto        10
    # 3  -> Fecha inicio
    # 4  -> Fecha fin
    # 5  -> Precio
    # 6  -> Impuesto especial
    ######

    LDATLIN(1)  = [F:T2]ITMREF
    LDATLIN(2)  = "PRECIO_CHINO"
    LDATLIN(3)  = " "
    LDATLIN(4)  = " "
    #LDATLIN(5)  = num$([F:T2]AVC) #XVT20181024.o
    #LDATLIN(5)  = ctrans(format$("N:6.2" ,[F:T2]AVC), ",",".")  #XVT20181024.n
    # MAB.17102019.SNEW
    Filter [F:Z145] Where ITMREF = [F:T2]ITMREF
    Read [Z145] First
    If !fstat Then
      LDATLIN(5)  = ctrans(format$("N:6.2" ,[F:Z145]LASPURPRI), ",",".")  # MAB.17102019.OLD
    Endif
    Filter [F:Z145]
    LDATLIN(6)  = " "

    #escribimos en el fichero...
    Wrseq LDATLIN(1)  + LSEP +
&         LDATLIN(2)  + LSEP +
&         LDATLIN(3)  + LSEP +
&         LDATLIN(4)  + LSEP +
&         LDATLIN(5)  + LSEP +
&         LDATLIN(6)
&     Using [ZEXP]

    #escribimos en el fichero...
    Wrseq LDATLIN(1)  + LSEP +
&         LDATLIN(2)  + LSEP +
&         LDATLIN(3)  + LSEP +
&         LDATLIN(4)  + LSEP +
&         LDATLIN(5)  + LSEP +
&         LDATLIN(6)
&     Using [ZCOPY]

    LTOTPC += 1  # nĂşmero total de registros PC exportados..

Next

# cerrar fichero import
Gosub CLOSE_FILE

Return

$COLUMNAS_PRECIOS
    #SE HACE UNA LLAMADA PARA PVP Y OTRA PARA PVM, CONSECUTIVAS EN ESE ORDEN
    LDATLIN(1)  = [F:SPL]PLICRI1
    LDATLIN(2)  = NOMBRE_TARIFA
    If FECHA_FUTURO Then
      LDATLIN(3)  = format$("D:DD[.]MM[.]YY"  ,[F:SPL]PLISTRDAT)
      LDATLIN(4)  = format$("D:DD[.]MM[.]YY"  ,[F:SPL]PLIENDDAT)
    Else
      LDATLIN(3)  = " "  #FECHA INI - VACĂŤO PARA ACTUALIZAR TARIFAS ACTUALES
      LDATLIN(4)  = " "  #FECHA FIN - VACĂŤO PARA ACTUALIZAR TARIFAS ACTUALES
    Endif
    #LDATLIN(5) SE RELLENA SEGĂšN EL NOMBRE_TARIFA
    LDATLIN(6)  = " "

    If NOMBRE_TARIFA="PVP" Then
      LDATLIN(5)  = ctrans(format$("N:6.2" ,[F:SPL]ZPVP), ",",".")
      Read [F:T3]ZAIVA=[F:T1]ITMREF
      If !fstat Then
        If [F:T3]VACITM<>'NOR' Then
          LDATLIN(6) = ctrans(format$("N:2" ,[F:T3]VATRAT ), ",",".")
        Endif
      Endif
        #escribimos en el fichero PVP
        Wrseq LDATLIN(1)  + LSEP +
&         LDATLIN(2)  + LSEP +
&         LDATLIN(3)  + LSEP +
&         LDATLIN(4)  + LSEP +
&         LDATLIN(5)  + LSEP +
&         LDATLIN(6)
&     Using [ZEXP]

            #escribimos en el fichero...
        Wrseq LDATLIN(1)  + LSEP +
&         LDATLIN(2)  + LSEP +
&         LDATLIN(3)  + LSEP +
&         LDATLIN(4)  + LSEP +
&         LDATLIN(5)  + LSEP +
&         LDATLIN(6)
&     Using [ZCOPY]
    Else
        # PVM
        LDATLIN(5)  = ctrans(format$("N:6.2" ,[F:SPL]PRI), ",",".")
         #escribimos en el fichero PVM
        Wrseq LDATLIN(1)  + LSEP +
&         LDATLIN(2)  + LSEP +
&         LDATLIN(3)  + LSEP +
&         LDATLIN(4)  + LSEP +
&         LDATLIN(5)  + LSEP +
&         LDATLIN(6)
&     Using [ZEXP2]

            #escribimos en el fichero...
        Wrseq LDATLIN(1)  + LSEP +
&         LDATLIN(2)  + LSEP +
&         LDATLIN(3)  + LSEP +
&         LDATLIN(4)  + LSEP +
&         LDATLIN(5)  + LSEP +
&         LDATLIN(6)
&     Using [ZCOPY2]

    Endif
Return



$COLUMNAS_PRECIOS_OLD  #BORRAR CUANDO ESTĂ‰ PROBADO EL NUEVO PROCESO
    LDATLIN(1)  = [F:T1]ITMREF
    LDATLIN(2)  = NOMBRE_TARIFA
    LDATLIN(3)  = format$("D:DD[.]MM[.]YY"  ,[F:T1]PLISTRDAT)
    LDATLIN(4)  = format$("D:DD[.]MM[.]YY"  ,[F:T1]PLIENDDAT)
#    LDATLIN(5)  = num$([F:T1]PRI) # format$("N:6.3" , [F:T1]PRI) #XVT20181024.O
    LDATLIN(5)  = ctrans(format$("N:6.2" ,[F:T1]PRI), ",",".")    #XVT20181024.n ajuste decimales y coma decimal
    LDATLIN(6)  = " "

    If NOMBRE_TARIFA="PVP" Then
      Read [F:T3]ZAIVA=[F:T1]ITMREF
      If !fstat Then
        If [F:T3]VACITM<>'NOR' Then
          LDATLIN(6) = ctrans(format$("N:2" ,[F:T3]VATRAT ), ",",".")
        Endif
      Endif
    Endif

    If (NOMBRE_TARIFA="PVP" and [M:DIA]YPVPSF=2) or (NOMBRE_TARIFA="PRECIO_CESION" and [M:DIA]YPVMSF=2) Then
      #si el usuario decide que "actualiza el pvp o el pvm actual" las fechas de inicio y fin irĂˇn vacĂ­as
      #para que CĂˇstor actualice el precio actual de la tarifa correspondiente
      LDATLIN(3)=""
      LDATLIN(4)=""
    Endif

    #escribimos en el fichero...
    Wrseq LDATLIN(1)  + LSEP +
&         LDATLIN(2)  + LSEP +
&         LDATLIN(3)  + LSEP +
&         LDATLIN(4)  + LSEP +
&         LDATLIN(5)  + LSEP +
&         LDATLIN(6)
&     Using [ZEXP]

    #escribimos en el fichero...
    Wrseq LDATLIN(1)  + LSEP +
&         LDATLIN(2)  + LSEP +
&         LDATLIN(3)  + LSEP +
&         LDATLIN(4)  + LSEP +
&         LDATLIN(5)  + LSEP +
&         LDATLIN(6)
&     Using [ZCOPY]
Return


########################################################
$OPEN_FILE
#abrimos el fichero sĂłlo si hay datos para crearlo, en la primera pasada del FOR
If !FILEOPENED Then
  adxifs = LSEP
  adxirs = chr$(13)+chr$(10)
  Openo LFILE Using [ZEXP]
  Openo LFILECOPY Using [ZCOPY]
  If LFILE2<>"" Then
    Openo LFILE2 Using [ZEXP2]
    Openo LFILECOPY2 Using [ZCOPY2]
  Endif
  FILEOPENED=1
Endif

Return

########################################################
$CLOSE_FILE
#cerrar fichero si estaba abierto.
If FILEOPENED Then
  Openo Using [ZEXP]
  Openo Using [ZCOPY]
  If LFILE2<>"" Then
    Openo Using [ZEXP2]
    Openo Using [ZCOPY2]
  Endif
Endif
FILEOPENED=0

Return


$INICIALIZACIONES
  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,7,4)+mid$(LFECHA,4,2)+mid$(LFECHA,1,2)
  LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)
  LDIREXPORT  = [M:DIA]DIREXP

  MES = num$(month(date$))
  If len(MES) = 1 : MES = "0" + MES : Endif
  DIA = num$(day(date$))
  If len(DIA) = 1 : DIA= "0" + DIA : Endif
  FECHA_HORA  = "" + num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
  # Infbox FECHA_HORA
Return

