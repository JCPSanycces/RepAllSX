#<AdxTL>@(#)0.0.0.0 $Revision$ 
#XVT08/01/2019 modificaciones para ajustar el formato a las peticiones de AQS en correo del 4 de enero de 2019.
#XVT27/02/2019 ajuste fecha ENVIO tienda segĂşn peticiones AQS correo del 26/02/2019
#XVT25/10/2019 ajuste fecha de baja (fin de vida): si el artĂ­culo no tiene ni fecha de alta ni de baja,
# la fecha fin de vida a exportar serĂˇ la fecha actual de la exportaciĂłn. AsĂ­, aquellos artĂ­culos que se crean
# nuevos sin fecha de alta ni baja, entrarĂˇn en CĂˇstor como "baja", ya que hasta que no tengan fecha de alta
# no deben estar disponibles para tiendas.
#xvt22-11-2019 modificaciĂłn para generar el fichero ENVIO a tienda desde la validaciĂłn de las entregas, no desde
#la creaciĂłn de la recepciones. Inhabilito el cĂłdigo referente al ENVIO.

$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "DEBUT"      : Gosub DEBUT
  When "OK"         : Gosub OK
  When "EXEC"       : Gosub EXEC
  When "AVANT_PAR"  : Gosub AVANT_PAR
  When "FIN"        : Gosub FIN
  When Default
Endcase

$OUVRE
  If clalev([YADI]) = 0 : Local File ATABDIV   [YADI] : Endif  # tablas varias
  If clalev([I0])   = 0 : Local File ITMMASTER   [I0] : Endif  # artĂ­culos
  If clalev([C0])   = 0 : Local File ITMCOST     [C0] : Endif  # artĂ­culos-costes
  If clalev([IU])   = 0 : Local File ZITMUPDDATIM [IU] : Endif  # artĂ­culos-UPD LOCAL
  If clalev([IT])   = 0 : Local File ZAQSITMTAR  [IT] : Endif  # artĂ­culos-tarifas-UPD LOCAL
  #al exportar las tarifas en el fichero "precios" ya no es necesario comprobar los Ăşltimos cambios en las
  #tarifas T50 y T60
  If clalev([PL])   = 0 : Local File ZAQSPLNGR [PL] : Endif  # planograma-UPD LOCAL
  If clalev([RC])   = 0 : Local File ZAQSPTH [RC] : Endif  # Recepciones-UPD LOCAL
  If clalev([R0]) = 0 : Local File PRECEIPT   [R0] : Endif  # recepciones cab.
  If clalev([R1]) = 0 : Local File PRECEIPTD  [R1] : Endif  # recepciones lin.
  If clalev([T1]) = 0 : Local File ZAQSTARIFA [T1] : Endif  # Tarifas AQS. - PVP PVM
  If clalev([T2]) = 0 : Local File ZAQSPC     [T2] : Endif  # Tarifas AQS  - PRECIO COSTE. UPD LOCAL
  If clalev([T3]) = 0 : Local File ZAQSTASAIVA [T3] : Endif  # Tasa IVA por artĂ­culo
  If clalev([T4]) = 0 : Local File ZAQSSTOCK  [T4] : Endif  # STOCK acumulado almacenes centrales
  If clalev([SPL]) = 0 : Local File SPRICLIST  [SPL] : Endif  # LĂ­neas de tarifas
  If clalev([SPLU]) = 0 : Local File SPRICLIST  [SPLU] : Endif  # LĂ­neas de tarifas actualizar
  If clalev([ZPPL]) = 0 : Local File PPRICLIST  [ZPPL] : Endif  # LĂ­neas de tarifas de compras @ amb16102019
  If clalev([ZPPU]) = 0 : Local File PPRICLIST  [ZPPU] : Endif  # LĂ­neas de tarifas de compras actualizar @ amb16102019
  If !clalev([Z145])  : Local File ZFIC145 [Z145] : Endif # MAB.PARA SACAR EL PRECIO EN EL FICHERO PRECIOCH


  Local Integer ERR : ERR=0

  Local Char    LDIREXPORT(100)
  Local Char    LFILE(200), LFILECOPY(200), LFILE2(200), LFILECOPY2(200)
  Local Char LSEP(1) : LSEP = chr$(9)  # separador PARA TODOS LOS FICHEROS TABULADOR   #AQS.n
  Local Integer FILEOPENED : FILEOPENED=0   # indicador de fichero abierto
  Local Integer LTOTITM # nĂşmero total de artĂ­culos exportados..
  Local Integer LTOTEAN # nĂşmero total de cĂłdigos ean
  Local Integer LTOTPLG # nĂşmero total de planogramas
#  Local Integer LTOTPTH # nĂşmero total de recepciones #xvt22-11-2019.o
  Local Integer LTOTPVP # nĂşmero total de registros PVP
  Local Integer LTOTPVM # nĂşmero total de registros PVM
  Local Integer LTOTPC  # nĂşmero total de registros PC
  Local Integer LTOTSTK # nĂşmero total de registros STOCK
  Local Integer FECHA_FUTURO # indicador para exportar precios a futuro

  # utilizado para la copia de histĂłrico de ficheros
  Local Char LFECHA(10), LHORA(10)
  Local Char YCRITERE(255),YCRITEREL(255)
  Local Char FECITM(250)
  Local Integer EXPORTADOS : EXPORTADOS = 0
  Local Char FECHA_HORA
Return


$DEBUT
  Local Char MES (2), DIA(2)
  #LECTURA DEL DIRECTORIO DE EXPORTACIĂ“N
  Raz [M:DIA]
  Read [F:YADI]CODE=6001;'0'
  If !fstat
    [M:DIA]DIREXP = [F:YADI]A1
  Else
    Call ERREUR("Directorio de exportaciĂłn no definido") From GESECRAN
    ERR=-1
    Return
  Endif
  [M:DIA]YSEP = chr$(12)

  #LECTURA DEL CONTROL FECHA EAN
  Read [F:YADI]CODE=6001;'1'
  If !fstat
      [M:DIA]YFECEAN = [F:YADI]A2
  Endif

  #LECTURA DEL CONTROL FECHA ITM
  Read [F:YADI]CODE=6001;'2'
  If !fstat
      [M:DIA]YFECITM = [F:YADI]A2
  Endif

  #LECTURA DEL CONTROL FECHA PLANOGRAMA
  Read [F:YADI]CODE=6001;'3'
  If !fstat
      [M:DIA]YFECPLG = [F:YADI]A2
  Endif

  #LECTURA DEL CONTROL FECHA RECEPCIONES
  Read [F:YADI]CODE=6001;'4'
  If !fstat
      [M:DIA]YFECPTH = [F:YADI]A2
  Endif

  #LECTURA DEL CONTROL FECHA PRECIO COSTE
  Read [F:YADI]CODE=6001;'6'
  If !fstat
      [M:DIA]YFECPC  = [F:YADI]A2
  Endif

  #LECTURA DEL CONTROL FECHA STOCK
  Read [F:YADI]CODE=6001;'7'
  If !fstat
      [M:DIA]YFECSTOCK = [F:YADI]A2
      Affzo [M:DIA]YFECSTOCK
  Endif

  Affzo [M:DIA]1-99

Return

$OK
  Local Integer YSTAT

  LTOTITM =0 # nĂşmero total de artĂ­culos exportados..
  LTOTEAN =0 # nĂşmero total de cĂłdigos ean
  LTOTPLG =0 # nĂşmero total de planogramas
#  LTOTPTH =0 # nĂşmero total de recepciones #xvt22-11-2019.o
  LTOTPVP =0
  LTOTPVM =0
  LTOTPC  =0
  LTOTSTK =0

  If !GSERVEUR Then
    Call OUINON("ÂżDesea continuar?",[L]YSTAT) From GESECRAN
  Else
   [L]YSTAT=2
   [M:DIA]YEAN = 2
   [M:DIA]YITM = 2
   [M:DIA]YPLG = 2
   [M:DIA]YPTH = 2
   [M:DIA]YPVPPVM=2
   [M:DIA]YPVC = 2
   [M:DIA]YSTOCK = 2
  Endif

If [L]YSTAT=2
  #apertura de traza
  If !GSERVEUR Then
    Call TEMPON("Proceso exportaciĂłn CĂˇstor") From GESECRAN
    Call OUVRE_TRACE("Proceso exportaciĂłn CĂˇstor") From LECFIC
  Endif

  ##################### GENERA FICHERO EAN ###########################
  If [M:DIA]YEAN = 2 Then
    If !GSERVEUR Then
      Call TEMPON("GeneraciĂłn de EAN") From GESECRAN
    Endif

    Gosub GEN_ARTEAN

    Readlock [F:YADI]CODE=6001;'1'
    If !fstat
        [F:YADI]A2 = FECHA_HORA
        Rewrite [F:YADI]
    Endif
    EXPORTADOS+=1
  Endif

  ##################### GENERA FICHERO ARTICULOS #####################
  If [M:DIA]YITM = 2 Then
    If !GSERVEUR Then
      Call TEMPON("GeneraciĂłn de artĂ­culos") From GESECRAN
    Endif
    Gosub GEN_ARTICULOS

    Readlock [F:YADI]CODE=6001;'2'
    If !fstat
        [F:YADI]A2 = FECHA_HORA
        Rewrite [F:YADI]
    Endif
    EXPORTADOS+=1
  Endif

  ##################### GENERA FICHERO PLANOGRAMA ###########################
  If [M:DIA]YPLG = 2 Then
    If !GSERVEUR Then
      Call TEMPON("GeneraciĂłn de PLANOGRAMA") From GESECRAN
    Endif

    Gosub GEN_PLANOGRAMA

    Readlock [F:YADI]CODE=6001;'3'
    If !fstat
        [F:YADI]A2 = FECHA_HORA
        Rewrite [F:YADI]
    Endif
    EXPORTADOS+=1
  Endif

  ##################### GENERA FICHERO RECEPCIONES ###########################
  #xvt22-11-2019.bo
#  If [M:DIA]YPTH = 2 Then
#    If !GSERVEUR Then
#      Call TEMPON("GeneraciĂłn de RECEPCIONES") From GESECRAN
#    Endif
#
#    Gosub GEN_RECEPCIONES
#
#    Readlock [F:YADI]CODE=6001;'4'
#    If !fstat
#        [F:YADI]A2 = FECHA_HORA
#        Rewrite [F:YADI]
#    Endif
#    EXPORTADOS+=1
#  Endif
  #xvt22-11-2019.eo

##################### GENERA FICHERO TARIFA PVP/PVM ACTUAL ################
  If [M:DIA]YPVPPVM = 2 Then
    If !GSERVEUR Then
      Call TEMPON("GeneraciĂłn de Tarifa PVP-PVM ACTUAL") From GESECRAN
    Endif

    FECHA_FUTURO = 0
    Gosub GEN_PVP_PVM
    EXPORTADOS+=1
  Endif

##################### GENERA FICHERO TARIFA PVP/PVM FUTURO  ################
  If [M:DIA]YPVPPVMF = 2 Then
    If !GSERVEUR Then
      Call TEMPON("GeneraciĂłn de Tarifa PVP-PVM FUTURO") From GESECRAN
    Endif

    FECHA_FUTURO = 1
    Gosub GEN_PVP_PVM
    EXPORTADOS+=1
  Endif


#
###################### GENERA FICHERO TARIFA PVP ###########################
#  If [M:DIA]YPVP = 2 Then
#    If !GSERVEUR Then
#      Call TEMPON("GeneraciĂłn de Tarifa PVP") From GESECRAN
#    Endif
#
#    Gosub GEN_PVP
#    EXPORTADOS+=1
#  Endif
#
###################### GENERA FICHERO TARIFA PVM ###########################
#  If [M:DIA]YPVM = 2 Then
#    If !GSERVEUR Then
#      Call TEMPON("GeneraciĂłn de Tarifa PVM") From GESECRAN
#    Endif
#
#    Gosub GEN_PVM
#    EXPORTADOS+=1
#  Endif

##################### GENERA FICHERO PC ###########################
  If [M:DIA]YPVC = 2 Then
    If !GSERVEUR Then
      Call TEMPON("GeneraciĂłn de Tarifa PC") From GESECRAN
    Endif

    Gosub GEN_PC # MAB16102019.OLD
    # Gosub GEN_PC2  # MAB16102019.NEW
    Readlock [F:YADI]CODE=6001;'6'
    If !fstat
        [F:YADI]A2 = FECHA_HORA
        Rewrite [F:YADI]
    Endif
    EXPORTADOS+=1
  Endif

##################### GENERA FICHERO STOCK ###########################
  If [M:DIA]YSTOCK = 2 Then
    If !GSERVEUR Then
      Call TEMPON("GeneraciĂłn de STOCK") From GESECRAN
    Endif

    Gosub GEN_STOCK
    Readlock [F:YADI]CODE=6001;'7'
    If !fstat
        [F:YADI]A2 = FECHA_HORA
        Rewrite [F:YADI]
    Endif

    EXPORTADOS+=1
  Endif


########################## FIN ##############################################
  Gosub GET_TRAZA
  If !GSERVEUR Then
    Call TEMPOFF() From GESECRAN
    # fin de traza
    Call FERME_TRACE From LECFIC
    # lectura
    Call LEC_TRACE From LECFIC
  Endif
Endif #if YSTAT=2
  # cerrar tablas
  Gosub CERRAR_TBL

Return

$EXEC
  If GSERVEUR Then
    Gosub OUVRE
    Gosub DEBUT
    Gosub OK
  Endif
Return

$AVANT_PAR
    If !clalev([M:DIA]) Then
         Local Mask ZAQSEXP [DIA]
    Endif
Return

$FIN
Return



##########################################################
#**
#* Genera fichero de exportaciĂłn a AQS de artĂ­culos
#*!
$GEN_ARTICULOS
Local Integer MAXI : MAXI=18
Local Char    LDATLIN(50)(MAXI)
Local Integer I : I=0

Gosub INICIALIZACIONES

LFILECOPY   = LDIREXPORT + "COPIA\PRODUC_" + LFECHA + LHORA + ".txt"
LFILE       = LDIREXPORT + "PRODUC_" + LFECHA +  LHORA + ".txt"

#LECTURA DEL CONTROL FECHA ITM
  Read [F:YADI]CODE=6001;'2'
  If !fstat
      [M:DIA]YFECITM = [F:YADI]A2
      Affzo [M:DIA]YFECITM
  #Else
  #    MES = num$(month(date$))
  #    If len(MES) = 1 : MES = "0" + MES : Endif
  #    DIA = num$(day(date$))
  #    If len(DIA) = 1 : DIA= "0" + DIA : Endif
  Endif

# recorremos todos los artĂ­culos USANDO LA VISTA ZITMUPDDATIM
YCRITERE = 'LOCDATTIM >= ctrans([M:DIA]YFECITM,":-ZT","")'
For [IU]ZIU0 Where evalue(YCRITERE)

## recorremos todos los artĂ­culos modificados desde la Ăşltima export.
#FECITM=ctrans([M:DIA]YFECITM,":-ZT","")
##YCRITERE = 'ITMLOC >= FECITM or T50LOC >= FECITM or T60LOC >= FECITM'  #cambios en tarifas no necesarios
##porque se exportan en fichero precios, aparte.
#YCRITERE = 'ITMLOC >= FECITM'

#For [IT]ZAIA0 Where evalue(YCRITERE)
# abrir fichero en la primera pasada

Gosub OPEN_FILE
  #Read [F:I0]ITM0=[F:IT]ITMREF
  Read [F:I0]ITM0=[F:IU]ITMREF
  Raz LDATLIN
  I=0
  ######
  # Estructura
  ###
  # POSICIĂ“N                              TIPO        LONGITUD        FORMATO
  # 1  -> CĂłdigo artĂ­culo                 NumĂ©rico      7
  # 2  -> DescripciĂłn en EspaĂ±ol          Texto         50
  # 3  -> DescripciĂłn en PortuguĂ©s        Texto         50
  # 4  -> DescripciĂłn en InglĂ©s           Texto         50                        #AQS.n
  # 5  -> DescripciĂłn en CatalĂˇn          Texto         50
  # 6  -> Familia                         Texto       VACĂŤO                       #AQS.n
  # 7  -> CategorĂ­a                       Texto       VACĂŤO                       #AQS.n
  # 8  -> Planograma / CatĂˇlogo compra    NumĂ©rico      5             ceros por delante
  # 9  -> Precio Coste (proveedor)        NumĂ©rico                    2 decimales  #NO NECESARIO
  # 10 -> Precio Coste (CesiĂłn/Mayor)     NumĂ©rico                    2 decimales  #NO NECESARIO
  # 11 -> PVP                             NumĂ©rico                    2 decimales  #NO NECESARIO
  # 12 -> Estado (Alta/Baja)              Texto         1             A / B
  # 13 -> Porcentaje IVA                  NumĂ©rico      2             2 decimales  #NO NECESARIO
  # 14 -> MĂ­nimo                          NumĂ©rico
  # 15 -> MĂˇximo                          NumĂ©rico
  # 16 -> Stock almacĂ©n Ondara            NumĂ©rico   VACĂŤO por tener el stock en otro interfaz  #AQS.n
  # 17 -> Controla stock                  Texto         1            S / N        #AQS.n
  # 18 -> Fin de vida                     Fecha         8             DD.MM.AA
  ######

  LDATLIN(I)  = [I0]ITMREF : I+=1  #codigo artĂ­culo
  Call GET_ATEXTRA("ITMMASTER", "DES1AXX", "SPA", [I0]ITMREF, "", LDATLIN(I)) : I+=1  #desc SPA
  Call GET_ATEXTRA("ITMMASTER", "DES1AXX", "POR", [I0]ITMREF, "", LDATLIN(I)) : I+=1  #desc POR
  Call GET_ATEXTRA("ITMMASTER", "DES1AXX", "ENG", [I0]ITMREF, "", LDATLIN(I)) : I+=1  #desc ENG
  Call GET_ATEXTRA("ITMMASTER", "DES1AXX", "CAT", [I0]ITMREF, "", LDATLIN(I)) : I+=1  #desc CAT

  LDATLIN(I)  = " " : I+=1   #familia vacĂ­o
  LDATLIN(I)  = " " : I+=1   #categoria vacĂ­o
  LDATLIN(I)  = [I0]TSICOD(2) : I+=1 # planograma
  LDATLIN(I)  = "0" : I+=1 #  DUDA??  # precio coste (proveedor)  #NO NECESARIO VA EN FICHERO PRECIOS
  LDATLIN(I)  = "0" : I+=1 #  num$([IT]T50MAJ) : I+=1    # precio mayorista NO SE EXPORTA, VA EN FICHERO PRECIOS
  LDATLIN(I)  = "0" : I+=1 #num$([IT]T60PVP) : I+=1      # PVP NO SE EXPORTA, VA EN FICHERO PRECIOS
  If [I0]ITMSTA = 1 Then   # estado PENDIENTE VER SI SE USA TAMBIĂ‰N LA FECHA INICIO VIDA/FIN Y CĂ“MO
    LDATLIN(I)  = "A" : I+=1
  Else
    LDATLIN(I)  = "B" : I+=1
  Endif
  LDATLIN(I)  = "0"  : I+=1 # NO SE USA, VA EN FICHERO PRECIOS porcentaje IVA #como se obtiene? depende del artĂ­culo y la tienda? o ponemos 0? #pendiente
  LDATLIN(I)  = num$([I0]ZSTOCKMIN)  : I+=1# stock mĂ­nimo tienda
  LDATLIN(I)  = num$([I0]ZSTOCKMAX)  : I+=1# stock mĂˇximo tienda
  LDATLIN(I)  = "" : I+=1 #stock Ondara, no tiene sentido porque hay una vista que lo da
  LDATLIN(I)  = "" : I+=1 #controla stock, vacĂ­o, mantenido por compatibilidad hacia atrĂˇs
#XVT25/10/2019.bo
#  If [F:I0]ZFECHABAJA > gdat$(01,01,2000) Then
#    LDATLIN(I)  = format$("D:DD[.]MM[.]YY", [F:I0]ZFECHABAJA    )  # FECHA FIN DE VIDA
#  Else
#    LDATLIN(I)  = ""
#  Endif
#XVT25/10/2019.eo
#XVT25/10/2019.bn
  If [F:I0]ZFECHABAJA <= gdat$(01,01,2000) and [F:I0]ZFECHALTA <= gdat$(01,01,2000)  Then
   LDATLIN(I)  = format$("D:DD[.]MM[.]YY", date$    )  # FECHA ACTUAL para entrar como baja en tiendas
  Elsif [F:I0]ZFECHABAJA > gdat$(01,01,2000) Then
   LDATLIN(I)  = format$("D:DD[.]MM[.]YY", [F:I0]ZFECHABAJA    )  # FECHA FIN DE VIDA
  Else
    LDATLIN(I)  = ""
  Endif
#XVT25/10/2019.en

  LSEP = chr$(9) #[M:DIA]YSEP
  #escribimos en el fichero...
  Wrseq LDATLIN(0)  + LSEP +
&       LDATLIN(1)  + LSEP +
&       LDATLIN(2)  + LSEP +
&       LDATLIN(3)  + LSEP +
&       LDATLIN(4)  + LSEP +
&       LDATLIN(5)  + LSEP +
&       LDATLIN(6)  + LSEP +
&       LDATLIN(7)  + LSEP +
&       LDATLIN(8)  + LSEP +
&       LDATLIN(9)  + LSEP +
&       LDATLIN(10) + LSEP +
&       LDATLIN(11) + LSEP +
&       LDATLIN(12) + LSEP +
&       LDATLIN(13) + LSEP +
&       LDATLIN(14) + LSEP +
&       LDATLIN(15) + LSEP +
&       LDATLIN(16) + LSEP +
&       LDATLIN(17)
&   Using [ZEXP]

  Wrseq LDATLIN(0)  + LSEP +
&       LDATLIN(1)  + LSEP +
&       LDATLIN(2)  + LSEP +
&       LDATLIN(3)  + LSEP +
&       LDATLIN(4)  + LSEP +
&       LDATLIN(5)  + LSEP +
&       LDATLIN(6)  + LSEP +
&       LDATLIN(7)  + LSEP +
&       LDATLIN(8)  + LSEP +
&       LDATLIN(9)  + LSEP +
&       LDATLIN(10) + LSEP +
&       LDATLIN(11) + LSEP +
&       LDATLIN(12) + LSEP +
&       LDATLIN(13) + LSEP +
&       LDATLIN(14) + LSEP +
&       LDATLIN(15) + LSEP +
&       LDATLIN(16) + LSEP +
&       LDATLIN(17)
&   Using [ZCOPY]

  LTOTITM += 1  # nĂşmero total de artĂ­culos exportados..
Next

# cerrar fichero import
Gosub CLOSE_FILE

Return


##########################################################
#**
#* Genera fichero de exportaciĂłn a AQS de cĂłdigos ean
#*!
$GEN_ARTEAN
Local Char    LDATLIN(50)(15)

Gosub INICIALIZACIONES
LFILECOPY   = LDIREXPORT + "COPIA\EAN_" + LFECHA + LHORA + ".txt"
LFILE       = LDIREXPORT + "EAN_" + LFECHA + LHORA + ".txt"

 #LECTURA DEL CONTROL FECHA EAN
  Read [F:YADI]CODE=6001;'1'
  If !fstat
      [M:DIA]YFECEAN = [F:YADI]A2
      Affzo [M:DIA]YFECEAN
#  Else
#      MES = num$(month(date$))
#      If len(MES) = 1 : MES = "0" + MES : Endif
#      DIA = num$(day(date$))
#      If len(DIA) = 1 : DIA= "0" + DIA : Endif
#      [M]YFECEAN = "" + num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
  Endif

# recorremos todos los artĂ­culos
YCRITERE = 'LOCDATTIM >= ctrans([M:DIA]YFECEAN,":-ZT","")'

For [IU]ZIU0 Where evalue(YCRITERE)
# abrir fichero en la primera pasada
  Read [F:I0]ITM0=[F:IU]ITMREF
  If [F:I0]EANCOD<>"" Then
    Gosub OPEN_FILE
    Raz LDATLIN

    ######
    # Estructura
    ###
    # POSICIĂ“N                              TIPO        LONGITUD        FORMATO
    # 1  -> CĂłdigo artĂ­culo                 NumĂ©rico      7             Rellenar 0 por delante
    # 2  -> CĂłdigo EAN                      NumĂ©rico      13
    ######

    LDATLIN(1)  = [I0]ITMREF
    LDATLIN(2)  = [I0]EANCOD
    Call GET_FORMAT(LDATLIN(1), 7, "0", LDATLIN(1))

    #escribimos en el fichero...
    Wrseq LDATLIN(1)  + LSEP +
&         LDATLIN(2)
&     Using [ZEXP]

    #escribimos en el fichero copia...
    Wrseq LDATLIN(1)  + LSEP +
&         LDATLIN(2)
&     Using [ZCOPY]


    LTOTEAN += 1  # nĂşmero total de cĂłdigos ean exportados..
  Endif
Next

# cerrar fichero import
Gosub CLOSE_FILE

Return

##STOCKINI
##########################################################
#**
#* Genera fichero de exportaciĂłn a AQS de stock
#*!
$GEN_STOCK
Local Char    LDATLIN(50)(15)

  Read [F:YADI]CODE=6001;'7'
  If !fstat
      [M:DIA]YFECSTOCK = [F:YADI]A2
      Affzo [M:DIA]YFECSTOCK
  Endif
   Gosub INICIALIZACIONES
  If date$ > gdat$(val(mid$([M:DIA]YFECSTOCK,9,2)),val(mid$([M:DIA]YFECSTOCK,6,2)),val(mid$([M:DIA]YFECSTOCK,1,4))) Then


    LFILECOPY   = LDIREXPORT + "COPIA\STOCK_" + LFECHA + LHORA + ".txt"
    LFILE       = LDIREXPORT + "STOCK_" + LFECHA + LHORA + ".txt"

    Gosub OPEN_FILE

    For [T4]ZAQST0

       Raz LDATLIN

    ######
    # Estructura
    ###
    # POSICIĂ“N                              TIPO        LONGITUD        FORMATO
    # 1  -> CĂłdigo artĂ­culo                 NumĂ©rico      7             Rellenar 0 por delante
    # 2  -> STOCK                           NumĂ©rico      13
    ######

        LDATLIN(1)  = [T4]ITMREF
        LDATLIN(2)  = num$([T4]STOCK)

        #escribimos en el fichero...
    Wrseq LDATLIN(1)  + LSEP +
&         LDATLIN(2)
&     Using [ZEXP]

    #escribimos en el fichero copia...
    Wrseq LDATLIN(1)  + LSEP +
&         LDATLIN(2)
&     Using [ZCOPY]


        LTOTSTK += 1  # nĂşmero total de lĂ­neas de stock exportados..
    Next

    # cerrar fichero import
    Gosub CLOSE_FILE
Endif

Return

##STOCKFIN

##########################################################
#**
#* Genera fichero de exportaciĂłn a AQS de planograma
#*!
$GEN_PLANOGRAMA
Local Char    LDATLIN(50)(15)

Gosub INICIALIZACIONES
LFILECOPY   = LDIREXPORT + "COPIA\PLANO_" + LFECHA + LHORA + ".txt"
LFILE       = LDIREXPORT + "PLANO_" + LFECHA + LHORA + ".txt"

 #LECTURA DEL CONTROL FECHA PLANOGRAMA
  Read [F:YADI]CODE=6001;'3'
  If !fstat
      [M:DIA]YFECPLG = [F:YADI]A2
      Affzo [M:DIA]YFECPLG
#  Else
#      MES = num$(month(date$))
#      If len(MES) = 1 : MES = "0" + MES : Endif
#      DIA = num$(day(date$))
#      If len(DIA) = 1 : DIA= "0" + DIA : Endif
#      [M]YFECPLG = "" + num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
  Endif

# recorremos todos los artĂ­culos
YCRITERE = 'LOCDATTIM >= ctrans([M:DIA]YFECPLG,":-ZT","")'

For [PL]ZAQP0 Where evalue(YCRITERE)
# abrir fichero en la primera pasada

    Gosub OPEN_FILE
    Raz LDATLIN

    ######
    # Estructura
    ###
    # POSICIĂ“N                              TIPO        LONGITUD        FORMATO
    # 1  -> CĂłdigo planograma               NumĂ©rico      7             Rellenar 0 por delante
    # 2  -> descripciĂłn SPA                 Texto        50
    ######

    LDATLIN(0) = [PL]PLANOGRAMA
    Call GET_FORMAT(LDATLIN(0), 7, "0", LDATLIN(0) )
    Call GET_ATEXTRA("ATABDIV", "LNGDES", "SPA", "22", [PL]PLANOGRAMA, LDATLIN(1))  #desc SPA


    #escribimos en el fichero...
    Wrseq LDATLIN(0)  + LSEP +
&         LDATLIN(1)
&     Using [ZEXP]

    #escribimos en el fichero copia...
    Wrseq LDATLIN(0)  + LSEP +
&         LDATLIN(1)
&     Using [ZCOPY]

    LTOTPLG += 1  # nĂşmero total de cĂłdigos ean exportados..
Next

# cerrar fichero import
Gosub CLOSE_FILE

Return

