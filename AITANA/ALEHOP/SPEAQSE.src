##########################################################
#**
#* Genera fichero de exportaciĂłn a AQS de tarifa PVM-PVP
#*!
$GEN_PVP_PVM
Local Char    LDATLIN(50)(15)
Local Char    NOMBRE_TARIFA(15)

Gosub INICIALIZACIONES

LFILECOPY   = LDIREXPORT + "COPIA\PRECIOPV_" + LFECHA + LHORA + ".txt"
LFILE       = LDIREXPORT + "PRECIOPV_" + LFECHA + LHORA + ".txt"
LFILECOPY2  = LDIREXPORT + "COPIA\PRECIOCE_" + LFECHA + LHORA + ".txt"
LFILE2      = LDIREXPORT + "PRECIOCE_" + LFECHA + LHORA + ".txt"

# recorremos las lĂ­neas de precios que estĂˇn vigentes y pendientes de exportar
If !FECHA_FUTURO Then
  #VIGENTES
  YCRITERE = 'PLI = "T50" AND PLISTRDAT<=date$ AND PLIENDDAT>=date$ AND ZAQSEXP=2 '
Else
  #FUTURO
  YCRITERE = 'PLI = "T50" AND PLISTRDAT=[M:DIA]YPVMI AND ZAQSEXP=2 '
Endif
For [SPL]SPL0 Where evalue(YCRITERE)
# abrir fichero en la primera pasada

    Gosub OPEN_FILE
    Raz LDATLIN

    ######
    # Estructura
    ###
    # POSICIĂ“N                              TIPO        LONGITUD        FORMATO
    # 1  -> CĂłdigo artĂ­culo                 NumĂ©rico      7             Rellenar 0 por delante
    # 2  -> Referencia tarifa               Texto        10
    # 3  -> Fecha inicio
    # 4  -> Fecha fin
    # 5  -> Precio
    # 6  -> Impuesto especial
    ######

    NOMBRE_TARIFA="PVP"
    Gosub COLUMNAS_PRECIOS

    LTOTPVP += 1  # nĂşmero total de registros PVP exportados..

    NOMBRE_TARIFA="PRECIO_CESION"
    Gosub COLUMNAS_PRECIOS

    LTOTPVM += 1  # nĂşmero total de registros PVM exportados..

    #ACTUALIZACIĂ“N DEL REGISTRO EXPORTADO
    Trbegin [SPLU]
    Readlock [F:SPLU]SPL0=[F:SPL]PLI;[F:SPL]PLICRD;[F:SPL]PLILIN
    If fstat=0 Then
      [F:SPLU]ZAQSEXP=1
      If [F:SPL]ZGESEXP<>2 Then
        [F:SPLU]ZMARCA=1
      Endif
      Rewrite [F:SPLU]
      Commit
      Unlock [F:SPLU]
    Else
      Rollback
    Endif
Next

# cerrar fichero import
Gosub CLOSE_FILE
LFILE2=""
LFILECOPY2=""

Return

