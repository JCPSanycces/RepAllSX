#<AdxTL>@(#)0.0.0.0 $Revision$
## XVT20082020 - SUPPORT-3698
## LOS ABONOS DE TIENDA NO ESTÁN GENERANDO EL MOVIMIENTO DE STOCK EN TIENDA
## HAY QUE CREAR EL STOCK POR ENTRADA VARIA, ENLAZANDO LA ENTRADA VARIA CON
## EL ABONO QUE LO GENERA

$ACTION
#  Infbox ACTION
  Gosub ACTION From IMPSMRS
  Case ACTION
    When 'AP_IMPORT'  Gosub AP_IMPORT
  Endcase
Return


##XVT18032019.BN
$OUVRE
  Local Integer SALTAR : SALTAR=0
  If !clalev ([F:ZIF]) : Local File ITMFACILIT [ZIF] : Endif
  If !clalev ([F:ZITM]) : Local File ITMMASTER [ZITM] : Endif
  Gosub OUVRE From IMPSMRS
  Local Integer HAY_LINEAS : HAY_LINEAS = 0
Return

$RAZCRE
  Gosub RAZCRE From IMPSMRS
Return

$VALID
  If !HAY_LINEAS Then
     OK=0
     GREP=""
     Gosub RAZCRE From IMPSMRS
  Else
    Gosub VALID From IMPSMRS
  Endif
Return

$SAIMSK
 Case IMPFIC
    When "SMH"
      SALTAR=0
      HAY_LINEAS=0
      Gosub SAIMSK From IMPSMRS
    When "SMD"
      SALTAR=0
      Read [F:ZITM]ITM0 = [F:SMD]ITMREF
      If fstat  # el artículo no existe
          SALTAR=1
      Else
          Read [F:ZIF]ITF0=[F:SMD]ITMREF;[F:SMH]STOFCY
          If !fstat Then
            If [F:ZIF]STOMGTCOD<>2 Then
              #si el artículo-planta no tiene gestión de stock, saltar
              SALTAR=1
            Else
              SALTAR=0
              HAY_LINEAS+=1
              Gosub SAIMSK From IMPSMRS
            Endif
          Else    #artículo-planta no existe: error
            Local Integer ITMFCYOK : ITMFCYOK = 1     # 1 Error 2 OK
            Local Integer TIMEINI  : TIMEINI = time
            Local Integer TIMECOUNT: TIMECOUNT = TIMEINI
            While ITMFCYOK = 1 and TIMECOUNT-TIMEINI <= 180
              Gosub GEN_FILEITMFCY  #ALEHOP-1264 - MS
              Read [F:ZIF]ITF0=[F:SMD]ITMREF;[F:SMH]STOFCY
              If !fstat
                Local Integer ZSTOMGRCOD  : ZSTOMGRCOD = 2
                Call GET_GESTSTOCK ([F:SMD]ITMREF,ZSTOMGRCOD)
                If ZSTOMGRCOD = 1
                  SALTAR = 1
                  ITMFCYOK = 2
                Else
                  HAY_LINEAS+=1
                  ITMFCYOK = 2
                  Gosub SAIMSK From IMPSMRS
                Endif
              Else
                TIMECOUNT = time
              Endif
            Wend
          Endif
      Endif
    When "STJ"
      If !SALTAR Then
        Gosub SAIMSK From IMPSMRS
      Endif
      SALTAR=0
  Endcase
Return
#XVT18032019.EN

$AP_IMPORT
  #If IMPFIC = 'SMH'
  #    If GIMP(92) <> '' Then
  #      [M:SMR0]ZFACORIGEN = GIMP(92)
  #    Endif
  #Endif

  If IMPFIC='SMD' Then
  #EN LA LECTURA DE LÍNEAS
    If !clalev([F:ZADW]) : Local File ADOVAL[ZADW] : Endif
    If !clalev([F:ZITV]) : Local File ITMMVT[ZITV] : Endif
    If !clalev([F:ZITC]) : Local File ITMCOST[ZITC] : Endif

    [F:SMD]PRI=0
    #BUSCAR EL ALMACÉN PRINCIPAL AÑADIDO COMO PARÁMETRO
    Read [F:ZADW]ADW1 = 'ZFCYPPAL'
    If !fstat Then
    #BUSCAR EL PMP DEL ARTICULO EN EL ALMACÉN PRINCIPAL
      Read [F:ZITV]ITV0=[F:SMD]ITMREF;[F:ZADW]VALEUR
      If !fstat Then
        #FORZAR EL VALOR PMP
        If [F:ZITV]AVC<>0 Then
          [F:SMD]PRI = [F:ZITV]AVC
        Else
          #FORZAR VALOR COSTE ESTÁNDAR
          Filter [F:ZITC] Where STOFCY=[F:ZADW]VALEUR and ITMREF=[F:SMD]ITMREF and CSTTYP=1
          For [F:ZITC]
            [F:SMD]PRI = [F:ZITC]CSTTOT
          Next
          Filter [F:ZITC]
        Endif
      Endif
    Endif

  Endif
Return


###############################################################################
$GEN_FILEITMFCY
Local Char    TEXITMFCY(50)(5)
Local Char    LDIRIMPORT(100) : LDIRIMPORT = "E:\IMPORT\IMP\REGSTOFCY\"
Local Char    LSEP(1) : LSEP = ","
Local Char    LFILE(200), NFILE(200), JFILEOLD(200)
Local Integer ZSTOMGRCOD  : ZSTOMGRCOD = 2

NFILE  = "ZITFES_" + nomap(0) +"_"+num$([F:SMH]STOFCY)+"_"+[F:SMD]ITMREF
LFILE  = LDIRIMPORT + NFILE +".csv"

JFILEOLD = "E:\IMPORT\BATCH\OLD\" + NFILE + ".old"

Local Integer SIZE

SIZE = filinfo(JFILEOLD,7)
If SIZE < 0
  SIZE = filinfo(LFILE,7)
Endif

If SIZE < 0
    Call GET_GESTSTOCK ([F:SMD]ITMREF,ZSTOMGRCOD)
    Gosub OPEN_FILE     #ALEHOP-1264 - MS - abrimos el fichero donde escribimos el artículo-planta

    TEXITMFCY(1) = [F:SMD]ITMREF
    TEXITMFCY(2) = num$([F:SMH]STOFCY)
    If ZSTOMGRCOD = 1
      TEXITMFCY(3) = '1,"STD",2,"*","","*","",0,0,1,0,1'
    Else
      TEXITMFCY(3) = '1,"AVC",2,"*","","*","",0,0,1,0,2'
    Endif
    # ESCRIBIMOS EN EL FICHERO
    Wrseq '"I",' +
&            '"' + TEXITMFCY(1) + '"' + LSEP +
&            '"' + TEXITMFCY(2) + '"' + LSEP +
&                  TEXITMFCY(3)
&   Using [ZEXP]

    Gosub CLOSE_FILE #ALEHOP-1264 - MS - Cerramos el fichero donde escribimos el artículo-planta

    #--------Generamos el job para la importación del artículo planta----------#
    Local Char    ZMODIMP(20), ZNOMIMP(100), ZVOLFIL(100), ZRUTAJOB(100)

    ZMODIMP = "ZITFES"
    ZNOMIMP = LFILE
    ZVOLFIL = "[IMPORT]/IMP/REGSTOFCY/" + NFILE +".csv"
    ZRUTAJOB= "E:\IMPORT\BATCH\JOB\" + NFILE + ".job"
    Call CREAR_JOB(ZMODIMP,ZNOMIMP,ZVOLFIL,ZRUTAJOB) From ZSISLIB
Endif

Return


########################################################
$OPEN_FILE
adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE Using [ZEXP]
Return

########################################################
$CLOSE_FILE
Openo Using [ZEXP]
Return

###############################################################################
#**
#* Devuelve si la categoría del artículo tiene o no gestión de stock
#* 1 No gestionado  /  2 Con gestión
#*
#* @param ZITMREF     Artículo a comprobar
#* @param ZSTOMGRCOD  Gestión Stock
#*!
Subprog GET_GESTSTOCK (ZITMREF,ZSTOMGRCOD)
Value Char       ZITMREF
Variable Integer ZSTOMGRCOD

If !clalev([ZITM]) : Local File ITMMASTER [ZITM] : Endif
If !clalev([ZITG]) : Local File ITMCATEG  [ZITG] : Endif
Local Char ZSTOFCY(10)

Link [ZITM] With [ZITG]ITG0=[F:ZITM]ITMREF;ZSTOFCY
&           As [LIC]
&           Where  [F:ZITM]ITMREF = ZITMREF

Read [F:LIC]ITM0 = ZITMREF
If !fstat
  If [LIC]STOMGTCOD <> 1
    ZSTOMGRCOD = 2
  Else
    ZSTOMGRCOD = 1
  Endif
Endif

End

