#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION
  When "APRES_CRE" : Gosub APRES_CRE
  When Default
Endcase
Return


#########################################################################
$APRES_CRE

# 20200805 - MS - ALEHOP-1312 - SALDO PEDIDO DE COMPRA TRAS VALIDAR ENTREGA (INTERPLANTA)
Local Integer LCON
Local Integer WRET
If !clalev([ZPOH]) : Local File PORDER [ZPOH] : Endif
If [M:PTH0]BPSNUM = '90001' and BETFCY = 2    # interplanta
  For LCON=0 To NBLIG-1
    Read [ZPOH]POH0 = [M:PTH1]POHNUM
    If !fstat
      If [ZPOH]CLEFLG <> 2
        Call TRTPOHCLE([M:PTH1]POHNUM,0,WRET) From ZPOHSALDO
      Endif
    Endif
  Next
Endif
###############################################################################

Return

