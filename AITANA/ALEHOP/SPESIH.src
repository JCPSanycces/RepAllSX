#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################################
#If GUSER="SIST1" Then : Infbox ACTION : Endif

$ACTION

Case ACTION
 When Default
 #When "APRES_CRE" : Gosub APRES_CRE      # 22/01/2018 Se desactiva ya se se van a recibir facturas agrupadas desde AQS
Endcase
Return


#########################################################################
$APRES_CRE

Local Char REQUESTNT(255)(3)
Local Char REQUESTTI(255)(4)
Local Char REQUESTTF(255)(4)

Local Char FACTURA(20)

FACTURA = [SIH0]NUM

If !clalev([F:ZSIH2]) : Local File SINVOICE  [ZSIH2]  : Endif
If !clalev([T0])      : Local File TABSIVTYP [T0]     : Endif

#> ALEHOP-458 MA 20180604 - solo se ejecuta si tiene marcado agrupación de tickets
If [M:SIH0]INVTYP = 1        # Tipo de Factura: Factura
  Read [T0]TSV0=[M:SIH0]SIVTYP
  If [T0]ZAGRUTCK = 2 Then            # Factura de tipo Agrupación Tickets

    # composicion de la consulta para obtener el nº de entregas contenidas en la factura
    REQUESTNT(0)  = "SELECT COUNT(SDHNUM_0) "
    REQUESTNT(1)  = "FROM   SINVOICED "
    REQUESTNT(2)  = "WHERE  SINVOICED.NUM_0 ='" + FACTURA + "' "

    # composicion de la consulta para obtener el nº de ticket inicial
    REQUESTTI(0)  = "SELECT TOP 1 SDHNUM_0 "
    REQUESTTI(1)  = "FROM   SINVOICED "
    REQUESTTI(2)  = "WHERE  SINVOICED.NUM_0 ='" + FACTURA + "' "
    REQUESTTI(3)  = "Order By SINVOICED.SDHNUM_0 Asc "

    # composicion de la consulta para obtener el nº de ticket final
    REQUESTTF(0)  = "SELECT TOP 1 SDHNUM_0 "
    REQUESTTF(1)  = "FROM   SINVOICED "
    REQUESTTF(2)  = "WHERE  SINVOICED.NUM_0 ='" + FACTURA + "' "
    REQUESTTF(3)  = "Order By SINVOICED.SDHNUM_0 Desc "


    Read [ZSIH2]SIH0  = [SIH0]NUM
    If fstat = 0
      For (Integer NUMTICKETS) From "5" Sql REQUESTNT(0..2) As [NUMENTRE]
        # Infbox("Num. Tickets: " + num$([F:NUMENTRE]NUMTICKETS))
        [F:ZSIH2]TCKNUM = [F:NUMENTRE]NUMTICKETS
      Next

      For (Char TICKETINI(20)) From "5" Sql REQUESTTI(0..3) As [TCKINI0]
        # Infbox("Ticket Ini.: " + [F:TCKINI0]TICKETINI)
        [ZSIH2]TCKINI = [F:TCKINI0]TICKETINI
      Next

      For (Char TICKETFIN(20)) From "5" Sql REQUESTTF(0..3) As [TCKFIN0]
        # Infbox("Ticket Fin.: " + [F:TCKFIN0]TICKETFIN)
        [ZSIH2]TCKEND = [F:TCKFIN0]TICKETFIN
      Next

      Rewrite [ZSIH2]
    Endif

  Endif
Endif


#If [M:SIH0]INVTYP = 1               # Tipo de Factura: Factura
#   Read [TSV]TSV0=[M:SIH0]SIVTYP
#   If [TSV]ZAGRUTCK = 2             # Factura de tipo Agrupación Tickets


#   Endif
#Endif

Close Local File [ZSIH2], [T0]

Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla SIH1) 04/06/2018 13:52:12 (SISD1)
######################################################################################
Subprog AS_TCKINI(VALEUR)
Variable Char    VALEUR()

#> ALEHOP-458 MA 20180604 - bloqueo los campos sino es una importación y si el usuario no tiene perfil ADMIN
If !GIMPORT and GPROFIL <> "ADMIN" Then
  mkstat = 2
Endif

End

######################################################################################
Subprog AS_TCKEND(VALEUR)
Variable Char    VALEUR()

#> ALEHOP-458 MA 20180604 - bloqueo los campos sino es una importación y si el usuario no tiene perfil ADMIN
If !GIMPORT and GPROFIL <> "ADMIN" Then
  mkstat = 2
Endif
End

######################################################################################
Subprog AS_TCKNUM(VALEUR)
Variable Decimal VALEUR

#> ALEHOP-458 MA 20180604 - bloqueo los campos sino es una importación y si el usuario no tiene perfil ADMIN
If !GIMPORT and GPROFIL <> "ADMIN" Then
  mkstat = 2
Endif
End


