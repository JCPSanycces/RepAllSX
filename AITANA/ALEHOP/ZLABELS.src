#<AdxTL>@(#)0.0.0.0 $Revision$
$IMPRIME
If !clalev([ZPOQ]) : Local File PORDERQ [ZPOQ] : Endif

Filter [ZPOQ] Where [ZPOQ]POHNUM = [M:POH0]POHNUM
Read [ZPOQ] First
If !fstat Then
  For [ZPOQ]
    Local Integer CANTIDAD : CANTIDAD = [ZPOQ]QTYSTU
    While CANTIDAD <> 0
      Infbox ("hola")
    Wend
  Next
Endif
Filter [ZPOQ]

Return

