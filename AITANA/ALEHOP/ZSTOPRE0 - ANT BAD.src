#<AdxTL>@(#)0.0.0.0 $Revision$
#####################################################################################
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION
  When "BOUTON"     : Gosub BOUTON           # Busqueda de entradas varias
  When "ZSTOENPREP"  : Gosub SET_STOENPREP  # Realiza movimientos de stock Plan en Preparación
  When Default
Endcase
Return

######################################################################################
$BOUTON
Case BOUT
  When "X" : # en preparación
    Gosub GET_ENTVAR
  When "X" : # en preparación
    Gosub SET_STOENPREP
  Endcase

Return


######################################################################################
$GET_ENTVAR
If !clalev([S0]) : Local File SMVTH [S0] : Endif

Filter [S0] Where [S0]STOFCY =  [M:ZSTOPRE0]FPLANTA     &
&                 [S0]IPTDAT >= [M:ZSTOPRE0]FFECINI     &
&                 [S0]IPTDAT <= [M:ZSTOPRE0]FFECFIN     &
&                 [S0]VCRNUM >= [M:ZSTOPRE0]FENTRADAINI &
&                 [S0]VCRNUM <= [M:ZSTOPRE0]FENTRADAFIN &
&                 [S0]ZFLAGPREP <> '2'                  &
&                 [S0]TRSFAM = '12'                         # Entrada de Devolución
# ZFLAGPREP Hecha ya la entrada 1:no | 2:si

Local Integer LCONT : Raz LCONT

[M:ZSTOPRE0]ZNBLIG1 = 0

For [S0]
  [M:ZSTOPRE0]NUMENTRADA(LCONT) = [S0]VCRNUM
  [M:ZSTOPRE0]FECHA(LCONT) = [S0]IPTDAT
  LCONT += 1
  [M:ZSTOPRE0]ZNBLIG1 += 1

Next

Affzo [M:ZSTOPRE0]

Filter [S0]

Return

######################################################################################
$SET_STOENPREP
Infbox ("DENTRO MENU En Preparacion")

Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZSTOENPREP0) 02/08/2018 18:27:43 (ADMIN)
######################################################################################
Subprog AM_SEL(VALEUR)
Variable Integer VALEUR

If VALEUR = '2' Then
  If !clalev([S0]) : Local File SMVTH [S0] : Endif
  If !clalev([S1]) : Local File SMVTD [S1] : Endif

  Filter [S1] Where [S1]VCRNUM = [M:ZSTOPRE0]NUMENTRADA
  Read [S1]
  If find("Q",[M]STA(0..[M]NBLIG-1)) = 0 or find("MUELLE",[M]LOC(0..[M]NBLIG-1)) = 0 Then
      Infbox("Las líneas de la entrada no cumple los requerimientos, no en Q o no en MUELLE")
    Endif

End


######################################################################################

