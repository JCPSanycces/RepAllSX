#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
When "LIENS" Gosub LIENS
Endcase
Return

$LIENS
  If !clalev ([F:ZSTO]) : Local File STOCK [ZSTO] : Endif
  [M:ITF8]ZMUELLEQ = 0
  [M:ITF8]ZMUELLEQA= 0
  For [F:ZSTO] Where [F:ZSTO]STOFCY=[M:ITF0]STOFCY and [F:ZSTO]ITMREF=[M:ITF0]ITMREF and [F:ZSTO]LOC='MUELLE' and [F:ZSTO]STA='Q'
    [M:ITF8]ZMUELLEQ += [F:ZSTO]QTYSTU
  Next

  For [F:ZSTO] Where [F:ZSTO]STOFCY=[M:ITF0]STOFCY and [F:ZSTO]ITMREF=[M:ITF0]ITMREF and [F:ZSTO]LOC='MUELLE' and [F:ZSTO]STA='QA'
    [M:ITF8]ZMUELLEQA += [F:ZSTO]QTYSTU
  Next

Return

