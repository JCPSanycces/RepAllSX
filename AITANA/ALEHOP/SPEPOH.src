###############################################################################
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif

  Case ACTION
    When "APRES_MODIF"  : Gosub APRES_MODIF
    When "VERIF_CRE"    : Gosub VERIF_CRE
    When "RAZCRE"       : Gosub RAZCRE
    When "SETBOUT"      : Gosub SETBOUT
    When Default
  Endcase
Return

###############################################################################
$APRES_MODIF
# 19/01/2018 - MS Rev. - Comento esto porque en la versión de Nov2018 ya no es así
#  [M:POH2]PRHFCY(NBLIG)     = [M:POH1]ZRCPFCY
#  [M:POH2]EXTRCPDAT(NBLIG)  = [M:POH1]ZRCPDAT
#  Affzo [M:POH2]5
Return


###############################################################################
$SETBOUT

If !GIMPORT and GFLAG = "ALHC" Then  # Limitar la transacción para la que se puede modificar el comprador
  Actzo [M:POH1]BUY
Endif

Return


###############################################################################
$VERIF_CRE

Gosub GET_ZRCPFCY

Return


###############################################################################
$RAZCRE

Gosub GET_ZRCPFCY

Return


###############################################################################
# 19/01/2018 - MS Rev. - Tomar Planta de recepción de los Parámetros
$GET_ZRCPFCY
  If [M:POH1]ZRCPFCY = "" Then
    If clalev([ZADW]) = 0 : Local File ADOVAL [ZADW] : Endif  # valores parámetros
    Filter [ZADW] Where [ZADW]PARAM = 'ZFCYPPAL'
    Read [ZADW] First
    If !fstat Then
       [M:POH1]ZRCPFCY = num$([ZADW]VALEUR)
    Endif
    Filter [ZADW]
  Endif
Return


###############################################################################
Subprog AM_ZRCPDAT(VALEUR)
Variable Date    VALEUR
Local Char    LCADENA(100)      : Raz LCADENA
Local Integer YESNO             : YESNO = 1 # 1=No ; 2=Sí
Local Integer LCONT             : Raz LCONT

  If [M:POH2]NBLIG > 0 Then             # el pedido ya tiene líneas
    LCADENA = "Se ha modificado la fecha de recepción.\¿Quieres aplicar los cambios a las líneas?"
    Call OUINON(LCADENA, YESNO) From GESECRAN
    If YESNO = 2 Then  # Sí
      If [M:POH1]ZRCPDAT <> [00/00/0000] Then
        For LCONT = 0 To NBLIG-1
          [M:POH2]EXTRCPDAT(LCONT) = VALEUR()
        Next LCONT
      Endif
    Endif
    Affzo [M:POH2]5
  Endif

End


###############################################################################
Subprog C_QTYUOM(VALEUR)
Variable Decimal VALEUR
  Call MOSTRAR_UNI_MASTER([M:POH2]ITMREF(nolign-1) , VALEUR)

End

###############################################################################
############################### FUNCIONES ESPECÍFICAS #########################
###############################################################################
#**
#* Comprueba si existe Artículo-Planta
#*
#* @param PITMREF código de artículo
#* @param PFCY planta
#* @param PEXISTE devuelve si existe el artículo en la planta
#*!
Subprog GET_ITMFACILIT(PITMREF,PFCY,PEXISTE)
Variable  Char PEXISTE
Value     Char PITMREF, PFCY

# si existe el artículo en la planta -> PEXISTE = 'YES'
# si no existe el artículo en la planta -> PEXISTE = 'NO'

If clalev([ZITF]) = 0 : Local File ITMFACILIT [ZITF] : Endif
Filter [ZITF] Where [ZITF]ITMREF = PITMREF and [ZITF]STOFCY = PFCY
Read [ZITF] First
If !fstat Then
  PEXISTE = "YES"
Else
  PEXISTE = "NO"
Endif
Filter [ZITF]
Close Local File [ZITF]

End


###############################################################################
#**
#*
#* Muestra en pantalla la cantidad en unidad MASTER
#*   PITEMREF  --> Referencia articulo a buscar
#*   PCANTIDAD --> Cantidad a convertir
#*!
Subprog MOSTRAR_UNI_MASTER(PITEMREF, PCANTIDAD)
  Local Decimal LCANTIDAD_MASTER
  Local Integer I
  If clalev([ZITM]) = 0 : Local File ITMMASTER [ZITM] : Endif
  # Si la unidad introducida no es Master
  If [M:POH2]UOM(nolign-1) <> "MST" Then

    Filter [F:ZITM] Where ITMREF = [M:POH2]ITMREF(nolign-1)
    Read [F:ZITM] First
    For I = 0 To 3
      If [F:ZITM]PCU(I) = "MST" and [F:ZITM]PCUSTUCOE(I) <> 0 Then
           LCANTIDAD_MASTER = PCANTIDAD/[F:ZITM]PCUSTUCOE(I)
      Endif
    Next
    [M:POH2]ZQTYMASTER(nolign-1) = LCANTIDAD_MASTER
  Else
    [M:POH2]ZQTYMASTER(nolign-1) = PCANTIDAD
  Endif

End

######################################################################################
## Etiqueta añadida por el supervisor (pantalla POH2) 19/11/2018 16:15:25 (ADMIN)
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

If [M:POH0]BETFCY <> 2 and [M:POH0]BETCPY <> 2 Then     # Interplanta/Intersociedad
  [M:POH2]PRHFCY(nolign-1) = [M:POH1]ZRCPFCY
Endif

[M:POH2]EXTRCPDAT(nolign-1) = [POH1]ZRCPDAT

Affzo [M:POH2]EXTRCPDAT

End


######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla POH2) 26/03/2019 10:40:14 (ADMIN)
######################################################################################
Subprog AS_GROPRI(VALEUR)
Variable Decimal VALEUR
  #APLICACIÓN EN TIENDAS PROPIAS: REQUIERE EL PRECIO AL PMP DEL ALMACÉN CENTRAL.
    If left$([M:POH0]POHFCY,1) <> "P" : End : Endif
    If !clalev([F:ZADW]) : Local File ADOVAL[ZADW] : Endif
    If !clalev([F:ZITV]) : Local File ITMMVT[ZITV] : Endif
    If !clalev([F:ZITC]) : Local File ITMCOST[ZITC] : Endif

    #BUSCAR EL ALMACÉN PRINCIPAL AÑADIDO COMO PARÁMETRO
    Read [F:ZADW]ADW1 = 'ZFCYPPAL'
    If !fstat Then
    #BUSCAR EL PMP DEL ARTICULO EN EL ALMACÉN PRINCIPAL
      Read [F:ZITV]ITV0=[M:POH2]ITMREF(nolign-1);[F:ZADW]VALEUR
      If !fstat Then
        #FORZAR EL VALOR PMP
        If [F:ZITV]AVC<>0 Then
          VALEUR = [F:ZITV]AVC
        Else
          #FORZAR VALOR COSTE ESTÁNDAR
          Filter [F:ZITC] Where STOFCY=[F:ZADW]VALEUR and ITMREF=[M:POH2]ITMREF(nolign-1) and CSTTYP=1
          For [F:ZITC]
            VALEUR = [F:ZITC]CSTTOT
          Next
          Filter [F:ZITC]
        Endif
      Endif
    Endif

End


######################################################################################
Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()

[M:POH1]BUY = [F:BPS]ZBUY
Affzo [M:POH1]
#Actzo [M:POH1]BUY
End


