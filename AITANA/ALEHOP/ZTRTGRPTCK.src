#<AdxTL>@(#)0.0.0.0 $Revision$
## MS 08/05/2018 Tarea ALEHOP-264
#########################################################################
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION
 When "EXEC" : Gosub COMPLETA_TCK
 When Default
Endcase
Return


#########################################################################
$COMPLETA_TCK

If !GIMPOR

    Local Char FACTURA(20)

    If !clalev([F:ZSIH]) Local File SINVOICE  [ZSIH] Endif
    If !clalev([F:ZTSV]) Local File TABSIVTYP [ZTSV]  Endif

    #Facturas a actualizar campos Tickets
    # No validadas
    # Tipo 'Factura'
    # Con nº ticket vacío
    # Tipo de factura con "Agrupación de Tickets"

    Link [ZSIH] With [ZTSV]TSV1 = [ZSIH]SIVTYP As [ZINV]
&   Where [ZSIH]STA= 1 :
&         [ZSIH]INVTYP = 1 :
&         [ZSIH]TCKNUM = 0 :
&         [ZTSV]ZAGRUTCK = 2


    For [ZINV]

      If !clalev([F:ZSID]) Local File SINVOICED  [ZSID] Endif

      # cálculo del nº de entregas contenidas en la factura
      Filter [ZSID] Where NUM = [ZINV]NUM Order By Key SDHX = SDHNUM Asc

      Local Integer NUMTCK
      Local Char ENTREGA(20): Raz ENTREGA

      For [ZSID]
        If [ZSID]SDHNUM <> ENTREGA
          ENTREGA = [ZSID]SDHNUM
          NUMTCK += 1
        Endif
      Next

      [F:ZINV]TCKNUM = NUMTCK


      # cálculo del ticket inicial TCKINI
      Read [ZSID] First
      [F:ZINV]TCKINI = [ZSID]SDHNUM
      Filter [ZSID]

      # cálculo del ticket final TCKEND
      Filter [ZSID] Where NUM = [ZINV]NUM Order By Key SDHX = SDHNUM Desc
      Read [ZSID] First
      [F:ZINV]TCKEND = [ZSID]SDHNUM

      Rewrite [F:ZSIH]

    Next

    Close Local File [ZSIH], [ZTSV] , [ZSID]

Endif

Return

