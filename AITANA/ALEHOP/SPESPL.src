#<AdxTL>@(#)0.0.0.0 $Revision$ Entrada de tarifas
$ACTION
 Case ACTION
  When "RAZDUP" : Gosub RAZDUP
  When "APRES_CRE" : Gosub APRES_CRE
  When "RAZCRE" : Gosub RAZCRE
  When Default
 Endcase
Return

Char LESDUPLICADO : LESDUPLICADO = "0"

######################################################################################
## Etiqueta añadida por el supervisor (pantalla SPLW) 26/12/2018 16:29:50 (ADMIN)
######################################################################################
Subprog AM_PRI(VALEUR)
Variable Decimal VALEUR
  [M:SPLW]ZMARCA(nolign-1)=2
  Affzo [M:SPLW]ZMARCA(nolign-1)
  [M:SPLW]ZAQSEXP(nolign-1)=2
  #Affzo [M:SPLW]ZAQSEXP(nolign-1)
  [M:SPLW]ZGESEXP(nolign-1)=2
  #Affzo [M:SPLW]ZGESEXP(nolign-1)
  zonsui="[M:SPLW]ZPVP(nolign-1)"
End

Subprog AM_ZPVP(VALEUR)
Variable Decimal VALEUR
  [M:SPLW]ZMARCA(nolign-1)=2
  Affzo [M:SPLW]ZMARCA(nolign-1)
  [M:SPLW]ZAQSEXP(nolign-1)=2
  #Affzo [M:SPLW]ZAQSEXP(nolign-1)
  [M:SPLW]ZGESEXP(nolign-1)=2
  #Affzo [M:SPLW]ZGESEXP(nolign-1)
End

Subprog AM_ZMARCA(VALEUR)
Variable Integer VALEUR
    [M:SPLW]ZAQSEXP(nolign-1)=VALEUR
    [M:SPLW]ZGESEXP(nolign-1)=VALEUR
End

#Controlamos que estemos duplicando una tarifa (borrando el nº de Tarifa para que X3 nos dé uno nuevo al hacer clic en Crear)
$RAZDUP
  #Infbox "Duplicado realizado"
  If GFLAG = "T50" Then
    LESDUPLICADO = "1"
    #Infbox "Estamos duplicando"
  Endif
Return

#Al pulsar Registrar deberemos controlar si estamos duplicando o no para resetear los valores de las variables caso de que estemos duplicando
$APRES_CRE
  #Infbox "Tarifa creada como " + [M:SPLW]PLICRD
  #Infbox "LESDUPLICADO ES " + LESDUPLICADO
  If GFLAG = "T50" Then
    If LESDUPLICADO = "1" Then
      #Infbox "Estamos en T50 y el valor es " + [M:SPLW]PLICRD
      If clalev([ZSPL]) = 0 : Local File SPRICLIST   [ZSPL] : Endif
      Filter [ZSPL] Where [ZSPL]PLICRD = [M:SPLW]PLICRD
      If rowcount([SPL]) > 0 Then
       For [ZSPL]
         #Infbox "El registro es " + [ZSPL]PLICRI1
         [ZSPL]ZMARCA = 2
         [ZSPL]ZAQSEXP = 2
         [ZSPL]ZGESEXP= 2
         Rewrite[ZSPL]
        Next
      Endif
      Close Local File [ZSPL]
    Endif
  Endif
Return

#Si hacemos clic en Nuevo inicializamos la variable de control que indica si estamos duplicando o no
$RAZCRE
  #Infbox "Hemos dado a crear"
  LESDUPLICADO = "0"
  #Infbox "LESDUPLICADO ES " + LESDUPLICADO
Return
######################################################################################








