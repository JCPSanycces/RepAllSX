#<AdxTL>@(#)0.0.0.0 $Revision$ Expedición
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif

Case ACTION
  When "APRES_MOD"        : Gosub APRES_MOD
  When "APRES_CRE"        : Gosub APRES_CRE
  When "RAZCRE"           : Gosub RAZCRE
  When "AVANT_CHOI"       : Gosub AVANT_CHOI
  When "FILGAUCHE"        : Gosub FILGAUCHE
  When Default
Endcase
Return


###############################################################################
# ALEHOP-1140 - 08/01/2020 - MS - Modificar Fecha Llegada prevista en Expediciones
# script para que se respete la Fecha llegada prevista introducida en la pantalla
# para deshacer el recálculo de dicha fecha realizado por el std
# se opta por esta opción ya que esta pantalla tiene un desarrollo híbrido
$APRES_CRE

If !clalev([SHH]) : Local File SHIPMENT [SHH] : Endif

Trbegin [SHH]  :# Transaction start

# Read record and lock.
Readlock [SHH]SHH0 = [F:SHH]SHIPNUM
If fstat > 1
    # Record not found
    Rollback
Elsif fstat = 1
    # Record already locked by another user
    Rollback
Else
    # Modify
    [F:SHH]ARVEXPDAT = [M:SHIP2]ZARVEXPDAT
    # Rewrite table
    Rewrite [F:SHH]
    If fstat=0
        Commit
    Else
        Rollback
    Endif
Endif

Return



###############################################################################
# Actualizar en la BD el campo DUA con lo capturado en la pantalla
$APRES_MOD

If !clalev([SHH]) : Local File SHIPMENT [SHH] : Endif

Trbegin [SHH]  :# Transaction start

# Read record and lock.
Readlock [SHH]SHH0 = [F:SHH]SHIPNUM
If fstat > 1
    # Record not found
    Rollback
Elsif fstat = 1
    # Record already locked by another user
    Rollback
Else
    # Modify
    [F:SHH]ZDUA =     [M:SHIP0]ZDUA
    # Rewrite table
    Rewrite [F:SHH]
    If fstat=0
        Commit
    Else
        Rollback
    Endif
Endif

Return


###############################################################################
$RAZCRE
  If GREP="C" Then
   [M:SHIP0]ZRFCY="ALM00"
   Affzo [M:SHIP0]ZRFCY

  Endif
Return


###############################################################################
$AVANT_CHOI
If GREP="C" Then
   [M:SHIP0]ZRFCY="ALM00"
   Affzo [M:SHIP0]ZRFCY

  Endif
Return


###############################################################################
$FILGAUCHE

Gosub FILGAUCHE From SUBSHIPA

# -----------------------------------------------------------------------------
# 05/09/2019 - MS - Z708  Añadir filtro fecha ETS en Criterios Picking Expedición
If (GREP="C" | GREP="D" | GREP="1" | [M:SHIP0]SHIPNUM<>"") & GBIDI2=1
  #----- Picking des commandes d'achat -----#
  If currbox=GBOXPO6
    If num$([M:PLCW]ZFECHETSDEB)<>"00/00/0000"
      FILGAUSUP(3)-="& nday([F:POH]ZFECHETIQUET)>=nday([M:PLCW]ZFECHETSDEB)"
    Endif
    If num$([M:PLCW]ZFECHETSFIN)<>"00/00/0000"
      FILGAUSUP(3)-="& nday([F:POH]ZFECHETIQUET)<=nday([M:PLCW]ZFECHETSFIN)"
    Endif
  Endif
Endif
GPE = 1   # Desactivamos el proceso estándar
# Fin Z708 --------------------------------------------------------------------

Return


######################################################################################
Subprog AM_ARVEXPDAT(VALEUR)
Variable Date    VALEUR

# ALEHOP-1140 - 08/01/2020 - MS - Modificar Fecha Llegada prevista en Expediciones
# guardamos la nueva Fecha llegada prevista en un campo temporal de la pantalla para
# luego recuperarla tras la grabación de la expedición y asignarla al campo ARVEXPDAT
[SHIP2]ZARVEXPDAT = VALEUR
Affzo [SHIP2]ZARVEXPDAT

End


######################################################################################

