#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif

Case ACTION
  When "LIENS"      : Gosub LIENS
  When "VERIF_CRE"  : Gosub VERIF_CRE
  When "CREATION"   : Gosub CREATION
  When "MODIF"      : Gosub MODIF
  When "ANNULE"     : Gosub ANNULE
  When "SETBOUT"    : Gosub SETBOUT
  When "AVANTBOUT"  : Gosub AVANTBOUT
  When Default
Endcase
Return


######################################################################################
$SETBOUT

If [M:ZITM0]ZLEER = 2
  CHMEN += "z"  # por defecto activamos siempre el botón de generar EAN
Endif

Return


######################################################################################
$AVANTBOUT

Case BOUT

  When "z" : # generar EAN13
    Local Integer LYESNO : LYESNO = 1  # por defecto (no)
    Local Char LEANITM(13)

    If [M:ITM1]EANCOD <> "" Then
      # preguntar si quiere seguir con la generación
      Call OUINONT("Existe un código EAN.\¿Desea genera un código nuevo?", LYESNO) From GESECRAN
    Else
      # si está en blanco el código EAN marcamos si
      LYESNO = 2
    Endif

    If LYESNO = 2 Then
#      Call GEN_CODEAN13(LEANITM) From ZGENEAN13
#      [M:ITM1]EANCOD = LEANITM
      Char PEAN(13)
      Integer OK_EAN(1) : OK_EAN = 1  # 1 No 2 Si
      While OK_EAN = 1
          Call GEN_CODEAN13(PEAN) From ZGENEAN13
          If PEAN <> '' Then
            If !clalev([F:ZITM]) : Local File ITMMASTER [ZITM] : Endif
            Filter [F:ZITM] Where EANCOD = PEAN
            If rowcount([F:ZITM]) > 0
              #Infbox("Código EAN existente, aumentar contador")
              # Call GEN_CODEAN13(PEAN) From ZGENEAN13
            Else
              [M:ITM1]EANCOD = PEAN
              OK_EAN = 2
            Endif
          Else
            Infbox ("Numero máximo de EANS, avise al administrador")
            OK_EAN = 2    # el contador ha sobrepasado los 99.999 registros, no tenemos EAN
          Endif
      Wend

      Affzo [M:ITM1]EANCOD

      # forzar modificación
      If GREP="" Then
        Gosub ENTRE_MODIF From GOBJSUB
      Endif
    Endif

Endcase

Return


######################################################################################
$LIENS
# 28/10/2018 - MS - Rellenamos el bloque de Ubicaciones Virtuales
Call GET_VIRTUAL_LOC([M:ITM0]ITMREF)
Return


######################################################################################
$CREATION
Gosub CREATION_VIRTUAL_LOC

Return


######################################################################################
$VERIF_CRE
Char PEAN(13)
Integer OK_EAN(1) : OK_EAN = 1  # 1 No 2 Si

If [M:ITM1]EANCOD = ''  & !GIMPORT & [M:ZITM0]ZLEER=2 Then
  While OK_EAN = 1
    Call GEN_CODEAN13(PEAN) From ZGENEAN13
    If PEAN <> '' Then
      If !clalev([F:ZITM]) : Local File ITMMASTER [ZITM] : Endif
      Filter [F:ZITM] Where EANCOD = PEAN
      If rowcount([F:ZITM]) > 0
        #Infbox("Código EAN existente, aumentar contador")
        # Call GEN_CODEAN13(PEAN) From ZGENEAN13
      Else
        [M:ITM1]EANCOD = PEAN
        OK_EAN = 2
      Endif
    Else
      Infbox ("Numero máximo de EANS, avise al administrador")
      OK_EAN = 2    # el contador ha sobrepasado los 99.999 registros, no tenemos EAN
    Endif
  Wend
Endif
Return


######################################################################################
$MODIF
# Eliminamos las Ubicaciones Virtuales
Gosub ANNULE

Gosub CREATION_VIRTUAL_LOC
Return


######################################################################################
$ANNULE
# Borramos las Ubicaciones Virtuales
If clalev([ZVLOC]) = 0   : Local File ZVLOC [ZVLOC]   : Endif

Delete [F:ZVLOC] Where [F:ZVLOC]ZVITMREF = [M:ITM0]ITMREF
Return



##########################################################################
#**
#* Obtiene las Ubicaciones Virtuales de un artículo
#*
#* @param PITMREF > código del artículo
#*!
Subprog GET_VIRTUAL_LOC(PITMREF)
Value Char PITMREF

If clalev([ZVLOC]) = 0   : Local File ZVLOC [ZVLOC]   : Endif

# Lista de Ubicaciones Virtuales creadas para este artículo
[M:ZITMVLOC]ZNBLIGV = 0
nolign = 1

Filter [ZVLOC] Where [F:ZVLOC]ZVITMREF = PITMREF
For [ZVLOC]
  [M:ZITMVLOC]ZVITMREF(nolign-1) = [F:ZVLOC]ZVITMREF
  [M:ZITMVLOC]ZVFCY(nolign-1)    = [F:ZVLOC]ZVFCY
  [M:ZITMVLOC]ZVLOC(nolign-1)    = [F:ZVLOC]ZVLOC

  nolign += 1
  [M:ZITMVLOC]ZNBLIGV += 1
Next

Filter [F:ZVLOC]

Affzo [M:ZITMVLOC]

End


##########################################################################
#**
#* Función para crear Ubicaciones Virtuales de artículos
#* Solo para transacciones abiertas
#*!
$CREATION_VIRTUAL_LOC
Local Integer LCON

If clalev([ZVLOC]) = 0   : Local File ZVLOC [ZVLOC]   : Endif

# registrasmos las Ubicaciones Virtuales
For LCON = 0 To [M:ZITMVLOC]ZNBLIGV-1
  [F:ZVLOC]ZVITMREF = [M:ITM0]ITMREF
  [F:ZVLOC]ZVFCY    = [M:ZITMVLOC]ZVFCY(LCON)
  [F:ZVLOC]ZVLOC    = [M:ZITMVLOC]ZVLOC(LCON)

  Write [F:ZVLOC]
Next

Return

