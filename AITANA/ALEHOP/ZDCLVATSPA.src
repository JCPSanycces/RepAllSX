#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "BEFWRIDVS" : Gosub INSERTAR_TICKET : # Inserta tickets en la tabla de impuestos
 When Default
Endcase
Return

#################################################################################################
$INSERTAR_TICKET
If [F:DVS]ORIMOD=5
 If dim([F:SIH]TCKINI)>0: [F:DVS]TCKINI =[F:SIH]TCKINI: Endif
 If dim([F:SIH]TCKEND)>0: [F:DVS]TCKEND =[F:SIH]TCKEND: Endif
 If dim([F:SIH]TCKNUM)>0: [F:DVS]TCKNUM =[F:SIH]TCKNUM: Endif
Endif
Return

