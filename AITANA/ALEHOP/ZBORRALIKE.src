#<AdxTL>@(#)0.0.0.0 $Revision$
  If !clalev([F:ZPOSAL]) : Local File ZPOSAL [ZPOSAL] : Endif
  If !clalev([F:POH]) : Local File PORDER [POH] : Endif

  Local Char CRITERE(40)(100)
  Local Integer I : I=0
  Local Integer J : J=0

  Filter [F:ZPOSAL]
  For [F:ZPOSAL]
    I+=1
    CRITERE(I)="[F:POH]POHNUM='" + [F:ZPOSAL]POHNUM + "'"
    If I>=3 : Break: Endif
  Next
  Filter [F:ZPOSAL]

  Infbox (num$(I))

#  For J=1 To I
#    Infbox (CRITERE(J))
#  Next

J=0

  Filter [F:POH] Where evalue(CRITERE)
  For [F:POH]
   Infbox [F:POH]POHNUM
   J+=1
   If J>= 10 : Break:Endif
  Next

