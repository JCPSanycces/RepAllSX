#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog MAIN()

Infbox "VERSIﾃ哲 10.12"

Local Char LDATCAB(30)(10),LDATLIN0(30)(15),LDATLIN1(30)(15)
Local Char LDATLIN2(30)(15)  #XVT20-11-2019.n
Local Char LFECHA(10), LHORA(10)
Local Char LSEP(1) : LSEP = chr$(9)  # separador PARA TODOS LOS FICHEROS TABULADOR   #AQS.n

LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

If !clalev ([ZENR]) : Local File ZENTNOREC [ZENR] : Endif
If clalev([ZENTR]) = 0  : Local File SDELIVERY [ZENTR] : Endif
If clalev([ZSDD]) = 0 : Local File SDELIVERYD [ZSDD] : Endif
If clalev([ZSP]) = 0    : Local File ZSDHPOH [ZSP]     : Endif


#xvt20-11-2019.en

Local Char    LFILE(200)
Local Char    LDIRIMPORT(250) : LDIRIMPORT = "E:\IMPORT\IMP\XVT\X"
#xvt20-11-2019.bn
Local Char    LAQS(200)
Local Char    LDIREXPORT(250) : LDIREXPORT = "E:\EXPORT\AQS\XVT\"


LAQS       = LDIREXPORT + "XENVIO_" + LFECHA + LHORA + ".txt"
#xvt20-11-2019.en



For [ZENR]

  Filter [ZENTR] Where SDHNUM = [F:ZENR]SDHNUM

  For [ZENTR]
    # ruta del fichero..
    LFILE  = LDIRIMPORT + [F:ZENR]SDHNUM+"_XVT_"+LFECHA+".txt"


    adxifs = ";"
    adxirs = chr$(13)+chr$(10)
    Openo LFILE Using [ZIMP]
    Openo LAQS,-1 Using  [ZAQS]   #xvt20-11-2019.n


    LDATCAB(1) = [ZENTR]PRHFCY
    LDATCAB(2) = [ZENTR]SHIDAT
    LDATCAB(3) = ""
    LDATCAB(4) = "90001"
    LDATCAB(5) = "REC"
    LDATCAB(6) = [ZENTR]SDHNUM
    LDATCAB(7) = num$([ZENTR]LINNBR)
    LDATCAB(8) = num$([ZENTR]LINNBR)

    Wrseq '"E";' +'"'+LDATCAB(1)+'";' +'"'+LDATCAB(2)+'";' +'"'+LDATCAB(3)+'";' +'"'+LDATCAB(4)+'";'
&              +'"'+LDATCAB(5)+'";' +'"'+LDATCAB(6)+'";' +'"'+LDATCAB(7)+'";' +'"'+LDATCAB(8)+'";'
&              Using [ZIMP]



    Filter [F:ZSDD] Where [F:ZSDD]SDHNUM = [F:ZENTR]SDHNUM

    Raz  LDATLIN0, LDATLIN1

    For [F:ZSDD]

      Filter [F:ZSP] Where SDHNUM = [F:ZSDD]SDHNUM and SDDLIN = [F:ZSDD]SDDLIN
      Read [F:ZSP] First

      LDATLIN0(1) = [F:ZSDD]ITMREF
      LDATLIN0(2) = [F:ZSDD]STU
      LDATLIN0(3) = num$([F:ZSDD]QTYSTU)
      LDATLIN0(4) = num$([F:ZSDD]GROPRI)
      LDATLIN0(5) = num$([F:ZSDD]GROPRI)
      LDATLIN0(6) = "10"
      LDATLIN0(7) = [F:ZSP]POHNUM
      If num$([F:ZSP]POPLIN) = "0" Then : LDATLIN0(8) = "" : Else : LDATLIN0(8) = num$([F:ZSP]POPLIN) : Endif
      LDATLIN0(9) = [F:ZSP]SDHNUM
      If num$([F:ZSP]SDDLIN) = "0" Then : LDATLIN0(10) = "" : Else : LDATLIN0(10) = num$([F:ZSP]SDDLIN) : Endif

      Wrseq '"L";' +'"'+LDATLIN0(1)+'";' +'"'+LDATLIN0(2)+'";' +'"'+LDATLIN0(3)+'";' +'"'+LDATLIN0(4)+'";' +'"'+LDATLIN0(5)+'";' +'"'+LDATLIN0(6)+'";'
&                +'"'+LDATLIN0(7)+'";' +'"'+LDATLIN0(8)+'";' +'"'+LDATLIN0(9)+'";' +'"'+LDATLIN0(10)+'";' Using [ZIMP]

      LDATLIN1(1) = [F:ZSDD]STU
      LDATLIN1(2) = num$([F:ZSDD]QTYSTU)
      LDATLIN1(3) = "TIENDA"
      LDATLIN1(4) = "A"

      Wrseq '"S";' +'"'+LDATLIN1(1)+'";' +'"'+LDATLIN1(2)+'";' +'"'+LDATLIN1(3)+'";' +'"'+LDATLIN1(4)+'";' Using [ZIMP]


##XVT20-11-2019.bn
## mejora: crear el fichero ENVIO para AQS al validar la entrega, en lugar de con la recepciﾃｳn
 ######
  # Estructura
  ###
  # POSICIﾃ哲                              TIPO        LONGITUD        FORMATO
  # 1  -> Cﾃｳdigo almacﾃｩn(Tienda)          Numﾃｩrico      3             Rellenar 0 por delante
  # 2  -> Nﾂｺ albarﾃ｡n                      Numﾃｩrico      6
  # 3  -> Fecha                           Fecha         8             dd.mm.aa
  # 4  -> Cﾃｳdigo artﾃｭculo                 Numﾃｩrico      7             Rellenar 0 por delante
  # 5  -> Cantidad                        Numﾃｩrico
  # 6  -> Precio cesiﾃｳn                   Numﾃｩrico

    LDATLIN2(1)= right$([F:ZSDD]BPCORD, 3)
    LDATLIN2(2)= [F:ZSDD]SDHNUM
    LDATLIN2(3)= format$("D:DD[-]MM[-]YY"  ,[F:ZSDD]SHIDAT)
    LDATLIN2(4)= [F:ZSDD]ITMREF
     Call GET_FORMAT(LDATLIN2(4), 7, "0", LDATLIN2(4)) From SPEAQSE
    LDATLIN2(5)= num$([F:ZSDD]QTYSTU)
    LDATLIN2(6)= ctrans(format$("N:6.2" ,[F:ZSDD]GROPRI), ",",".")

      #escribimos en el fichero...
  Wrseq LDATLIN2(1)  + LSEP +
&       LDATLIN2(2)  + LSEP +
&       LDATLIN2(3)  + LSEP +
&       LDATLIN2(4)  + LSEP +
&       LDATLIN2(5)  + LSEP +
&       LDATLIN2(6)
&   Using [ZAQS]


##XVT20-11-2019.en

    Next

    Filter [ZSDD]

    Filter [ZSP]

  Next



  # cerrar fichero import
  Openo Using [ZIMP]
  Openo Using [ZAQS]  #xvt20-11-2019.n


Next #[ZENR]

  Close Local File [ZENR]
  Close Local File [ZSDD]
  Close Local File [ZENTR]
  Close Local File [ZSP]

End

