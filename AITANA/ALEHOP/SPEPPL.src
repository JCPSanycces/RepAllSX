Subprog AM_PRI(VALEUR)
Variable Decimal VALEUR
  [M:PPLW]ZMARCA(nolign-1)=2
  Affzo [M:PPLW]ZMARCA(nolign-1)
  [M:PPLW]ZAQSEXP(nolign-1)=2
  #Affzo [M:SPLW]ZAQSEXP(nolign-1)
End

Subprog AM_ZMARCA(VALEUR)
Variable Integer VALEUR
  [M:PPLW]ZAQSEXP(nolign-1)=VALEUR
End


