# Gestión de la máscara SSL1 (Especifico)
######################################################################################
$ACTION
#If GUSER="ADMIN" Then : Infbox ACTION : Endif
Case ACTION
 When Default
Endcase
Return


######################################################################################
Subprog AM_COCHAGE(VALEUR)
Variable Integer VALEUR

If VALEUR <> 2 Then
  Gosub DEL_COCHAGE
Endif

Grizo [M:SSL1]ITMREF(nolign-1)
Affzo [M:SSL1]

End




######################################################################################
Subprog APRES_NBLIG

Local Integer LCON

For LCON = 0 To [M:SSL1]NBLIG-1
  If [M:SSL1]LOC(LCON)<>'' Then
    [M:SSL1]COCHAGE(LCON) = 2
    Affzo [M:SSL1]COCHAGE(LCON)
  Else
    Actzo [M:SSL1]LOC(LCON)
  Endif
Next

End


######################################################################################
# Eliminar el registro de STOSRGW y modificar campos de STOSRG para que las tablas de
# la lista de ordenación queden consistente con la pantalla
$ DEL_COCHAGE

If clalev([ZSRGW]) = 0   : Local File STOSRGW [ZSRGW]   : Endif     # eliminamos registros de STOSRGW

Trbegin [ZSRGW]

Delete [F:ZSRGW] Where [F:ZSRGW]SRGPPS = [M:SSL1]SRGPPS &
&                      [F:ZSRGW]VCRNUM = [M:SSL1]VCRNUM(nolign-1) &
&                      [F:ZSRGW]VCRLIN = [M:SSL1]VCRLIN(nolign-1)

If fstat = 1
  Rollback
Else
  Commit
  Rewrite [F:ZSRGW]

#  Effzo [M:SSL1]VCRNUM(nolign-1)
#  Affzo [M:SSL1]

  If clalev([ZSRG]) = 0   : Local File STOSRG [ZSRG]   : Endif      # actualizamos registros de STOSRG

  Filter [ZSRG] Where [F:ZSRG]STOCOU = [M:SSL1]STOCOU(nolign-1) &
&                     [F:ZSRG]VCRTYP = [M:SSL1]VCRTYP(nolign-1) &
&                     [F:ZSRG]VCRNUM = [M:SSL1]VCRNUM(nolign-1) &
&                     [F:ZSRG]VCRLIN = [M:SSL1]VCRLIN(nolign-1)

  Read [ZSRG] First
    If !fstat Then
      [F:ZSRG]SRGPPS = ''
      [F:ZSRG]PCU    = ''
      [F:ZSRG]QTYPCU = 0
      [F:ZSRG]PCUSTUCOE = 0
      [F:ZSRG]QTYSTU    = 0
      [F:ZSRG]CRETIM    = ''
      Rewrite [F:ZSRG]
    Endif

  Filter [ZSRG]
  Close Local File [ZSRG]

Endif
Close Local File [ZSRGW]

### Gosub TRTSSLA From

Return


######################################################################################
Subprog AM_QTYPCU(VALEUR)
Variable Decimal VALEUR
End


