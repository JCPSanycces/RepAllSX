#<AdxTL>@(#)0.0.0.0 $Revision$ 
#  SUPPORT-3472 EXPORTACIÓN GESIO PARAMETRO W. Buscar en el nuevo campo de ITMMASTER ZW. MAB.13052020

$ACTION
#Openo "E:\EXPORT\GESIO\TR.TXT", -1 Using [TR]
#Wrseq date$ + " " +  ACTION Using [TR]
#Openo Using [TR]

Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "DEBUT"      : Gosub DEBUT
  When "OK"         : Gosub OK
  When "EXEC"       : Gosub EXEC
  When "AVANT_PAR"  : Gosub AVANT_PAR
  When "FIN"        : Gosub FIN
  When Default
Endcase
F
Return

##################################################################################################################
$OUVRE

  Local Integer ERR : ERR=0

  Local Char    LDIREXPORT(200), LDIREXPORT_TMP(200)
  Local Char    LFILE(200), LFILECOPY(200)
  Local Char LSEP(1) : LSEP = chr$(9)  # separador PARA TODOS LOS FICHEROS TABULADOR   #AQS.n
  Local Integer FILEOPENED : FILEOPENED=0   # indicador de fichero abierto
  Local Integer LTOTITM # número total de artículos exportados..
  Local Integer LTOTEAN # número total de códigos ean
  Local Integer LTOTPLG # número total de planogramas
  Local Integer LTOTPTH # número total de recepciones
  Local Integer LTOTPVP # número total de registros PVP
  Local Integer LTOTPVM # número total de registros PVM
  Local Integer LTOTPC  # número total de registros PC

  # utilizado para la copia de histórico de ficheros
  Local Char LFECHA(10), LHORA(10)
  Local Char YCRITERE(255),YCRITEREL(255)
  Local Char FECITM(250)
  Local Integer EXPORTADOS : EXPORTADOS = 0
  Local Char FECHA_HORA

  Gosub ABRIR_TBL


Return

##################################################################################################################
$DEBUT
  Local Char MES (2), DIA(2)
  #LECTURA DEL DIRECTORIO DE EXPORTACIÓN
  Raz [M:GES]
  Read [F:YADI]CODE=6002;'0'
  If !fstat
    [M:GES]DIREXP = [F:YADI]A1
  Else
    Call ERREUR("Directorio de exportación no definido") From GESECRAN
    ERR=-1
    Return
  Endif


    #LECTURA DEL CONTROL FECHA ITM
  Read [F:YADI]CODE=6002;'1'
  If !fstat
      [M:GES]YFECITM = [F:YADI]A2
  Endif


  Affzo [M:GES]1-99

Return
##################################################################################################################
$OK
  LTOTITM =0 # número total de artículos exportados..

  LTOTPVP =0
  LTOTPVM =0
  LTOTPC  =0

  #apertura de traza
  If !GSERVEUR Then
    Call TEMPON("Proceso exportación GESIO") From GESECRAN
    Call OUVRE_TRACE("Proceso exportación GESIO") From LECFIC
  Endif



##################### GENERA FICHERO ARTICULOS #####################
  If [M:GES]YITM = 2  or GSERVEUR Then
    If !GSERVEUR Then
      Call TEMPON("Generación de artículos") From GESECRAN
    Endif
    Gosub GEN_ARTICULOS

    Readlock [F:YADI]CODE=6002;'1'
    If !fstat
        [F:YADI]A2 = FECHA_HORA
        Rewrite [F:YADI]
    Endif
    EXPORTADOS+=1
  Endif

########################## FIN ##############################################
  Gosub GET_TRAZA
  # fin de traza
  Call FERME_TRACE From LECFIC
  If !GSERVEUR Then
    Call TEMPOFF() From GESECRAN
    # lectura
    Call LEC_TRACE From LECFIC
  Endif

  # cerrar tablas
  Gosub CERRAR_TBL

Return
##################################################################################################################
$EXEC
 If GSERVEUR Then
   If !clalev([M:GES]) : Local Mask ZGESEXP [GES] : Endif
   Default Mask [M:GES]
   Gosub OUVRE
   Gosub DEBUT
   Gosub OK
 Endif
Return
##################################################################################################################
$AVANT_PAR
Return
##################################################################################################################
$FIN
Return





##################################################################################################################
$ABRIR_TBL
  If clalev([I0]) = 0 : Local File ITMMASTER   [I0] : Endif  # artículos
  If clalev([C0]) = 0 : Local File ITMCOST     [C0] : Endif  # artículos-costes
  If clalev([IS]) = 0 : Local File ITMSALES    [IS] : Endif  # artículo venta
  If clalev([YADI]) = 0 : Local File ATABDIV   [YADI] : Endif  # tablas varias
  If clalev([YADI2]) = 0 : Local File ATABDIV   [YADI2] : Endif  # tablas varias
  If clalev([IT])   = 0 : Local File ZGESITMTAR  [IT] : Endif  # artículos-tarifas-UPD LOCAL GESIO


Return


##################################################################################################################
$CERRAR_TBL
  Close Local File [I0], [IS]
  Close Local File [C0], [YADI], [IT]


Return

##################################################################################################################
$GEN_ARTICULOS
  Local Integer MAXI : MAXI=18
  Local Char    LDATLIN(50)(MAXI)
  Local Integer I : I=0
  Local Integer VMARCA_WEB
  Local Decimal LUNIDADES_PENDIENTES_RECIBIR, LPRECIO_VENTA, LSTOCK, LUNIDADES_PENDIENTES_SERVIR
  Local Decimal LTOTAL_STOCK, LCOSTE
  Local Decimal LPORCENTAJE_IMPUESTO
  Local Char LLEER, LPRECIO_COMPRA
  Local Char LTIPO_ARTICULO, LFECHA_DE_LLEGADA
  Local Integer LCONTADOR
  LCONTADOR = 0

  # Dbgaff
#Openo "E:\EXPORT\GESIO\TR.TXT", -1 Using [TR]
#Wrseq date$ + " " +  "GEN_ARTICULOS" Using [TR]
#Openo Using [TR]

  Gosub INICIALIZACIONES

  LFILECOPY   = LDIREXPORT + "COPIA\PRODUC_" + LFECHA + LHORA + ".xml"
  LFILE       = LDIREXPORT_TMP + "\PRODUC_" + LFECHA +  LHORA + ".xml"  # main.xml


  #LECTURA DEL CONTROL FECHA ITM
    Read [F:YADI]CODE=6002;'1'
    If !fstat
        [M:GES]YFECITM = [F:YADI]A2
    Else
        MES = num$(month(date$))
        If len(MES) = 1 : MES = "0" + MES : Endif
        DIA = num$(day(date$))
        If len(DIA) = 1 : DIA= "0" + DIA : Endif
    Endif

  # borramos el fichero si existe...
  Gosub DEL_FILE


  # recorremos todos los artículos modificados desde la última export.
  FECITM=ctrans([M:GES]YFECITM,":-ZT","")
  #YCRITERE = 'ITMLOC >= FECITM or T50LOC >= FECITM or T60LOC >= FECITM'  #cambios en tarifas  necesarios
  # SE AÑADEN REGISTROS QUE ESTEN MARCADOS COMO TARIFA A EXPORTAR A GESIO
  #porque se exportan en fichero precios, aparte.
  # YCRITERE = '(ITMLOC >= FECITM OR ZGESEXP = 2) AND (ITMREF = "9499108" OR ITMREF = "9880119" OR ITMREF = "9702230") '
  YCRITERE = 'ITMLOC >= FECITM OR ZGESEXP = 2 '

  # ESTO HACE QUE SE EJECUTA SOLO UNA VEZ AL DÍA TODAS LAS IMPORTACIONES, ES DECIR, INCLUIDA LA EXPORTACIÓN DE STOCK
  # 29/05/2020.
  # DAVID ME HA LLAMADO SOLICITANDO UNA MODIFICACIÓN PARA QUE ESTA OPCIÓN SE EJECUTE DOS VECES AL DIA, UNA A LAS 12.00 Y OTRA A LAS
  # 21.00. VA A CREAR SUPPORT PARA QUE LO REALICEMOS LO ANTES POSIBLE


  If (num$(time$) >= '12:00:00' and num$(time$) <= '13:00:00') or
&    (num$(time$) >= '19:00:00' and num$(time$) <= '20:00:00') or
&    [M:GES]EXPSTOCK = 2
  #If date$ > gdat$(val(mid$([M:GES]YFECITM,9,2)),val(mid$([M:GES]YFECITM,6,2)),val(mid$([M:GES]YFECITM,1,4))) or [M:GES]EXPSTOCK = 2  Then
    Call ECR_TRACE( '******EXPORTACION CON STOCK DE ARTICULO MODIFICADO ************',0) From GESECRAN
  Else
    YCRITERE += ' AND TABLA <> "B" '
    Call ECR_TRACE( '*****EXPORTACION SIN STOCK ***********************************',0) From GESECRAN
  Endif

  Call ECR_TRACE( 'Fecha de ultima exportación: ' + FECITM,0) From GESECRAN

  # YCRITERE = 'ITMREF = "9000007"' # MAB.03102019.TEST
   # borramos el fichero si existe...
    Gosub DEL_FILE

    # abrir fichero..
    Gosub OPEN_FILE

    # Cabecera del fichero XML
    Wrseq '<?xml version="1.0" encoding="UTF-8"?>'   Using [ZEXP]
    Wrseq '<catalog full="false" gesioid="alehop@clavedenia">'   Using [ZEXP]


  For [IT]ZAIA0 Where evalue(YCRITERE)

  # COMPROBACIONES INICIALES, PARA EXPORTAR O NO UN ARTICULO
  # NO EXPORTAR CUANDO:
  #   - NO TIENE CODIGO CATALOGO COMPRA --> [F:I0]TSICOD(2) = ''
  #   - FECHA BAJA O FECHA RELEASE ES NULA     [F:I0]ZFECHABAJA     [F:I0]ZFECHALTA

    Read [F:I0]ITM0=[F:IT]ITMREF

    If [F:I0]TSICOD(2) <> '' and ([F:I0]ZFECHABAJA <> [00/00/0000] or [F:I0]ZFECHALTA <> [00/00/0000] )  Then
        LCONTADOR+=1
        Call ECR_TRACE("ARTICULO EXPORTADO: " + [F:IT]ITMREF + " - TABLA: " + [F:IT]TABLA ,0) From GESECRAN
        Call ECR_TRACE('Código catalogo: ' + [F:I0]TSICOD(2) ,0) From GESECRAN
        Call ECR_TRACE('Fecha Baja: ' + num$([F:I0]ZFECHABAJA),0) From GESECRAN
        Call ECR_TRACE('Fecha Alta: ' + num$([F:I0]ZFECHALTA) ,0) From GESECRAN
        Call ECR_TRACE('Precio (ZPVP): ' + num$([F:IT]ZPVP) + " - Tarifa: " + [F:IT]PLICRD,0) From GESECRAN

       # Gosub OPEN_FILE


        Raz LDATLIN
        I=0

        Wrseq '<product>'   Using [ZEXP]
        Wrseq '<id>' + [F:I0]ITMREF + '</id>' Using [ZEXP]
        Wrseq '<public_id>' + [F:I0]ITMREF + '</public_id><!-- referencia del producto TABLA: ' + [F:IT]TABLA  + ' -->' Using [ZEXP]
        # TABLA VARIA DE PARÁMETROS
        Wrseq '<webs>' Using [ZEXP]
        # Wrseq '<web>ALE-HOP Portugal</web><!-- web obsoleta -->' Using [ZEXP]

        # Si el artículo tiene fecha de alta y tiene marca WEB mostrarlo en la web siguiente
        #If year([F:I0]ZFECHALTA) > 0 Then                         #   COMENTADO. 23/06/2020. ORDENADO POR RAMON DE GESIO
           VMARCA_WEB = func SPEGESE.ITM_MARCA_WEB([F:I0]ITMREF)
           If [F:I0]ZW = 2 Then                                    #   SUPPORT-3472 EXPORTACIÓN GESIO PARAMETRO W NEW
           #If VMARCA_WEB = 2 Then                                 #   SUPPORT-3472 EXPORTACIÓN GESIO PARAMETRO W NEW
            Wrseq '<web>ALE-HOP</web>' Using [ZEXP]
          Endif
        #Endif                                                     #   COMENTADO. 23/06/2020. ORDENADO POR RAMON DE GESIO
        # Si tiene fecha de alta o (tiene fecha de baja + unidades_pendientes_de_recibir+precio_venta en T50) mostrarlo en la web:
        If year([F:I0]ZFECHALTA) > 0 Then
          Wrseq '<web>Web Tiendas ALE-HOP</web>' Using [ZEXP]
        Elsif year([F:I0]ZFECHABAJA) > 0 Then
          LUNIDADES_PENDIENTES_RECIBIR = func SPEGESE.UNIDADES_PENDIENTES_RECIBIR([F:I0]ITMREF, LSTOCK, LUNIDADES_PENDIENTES_SERVIR)
          LPRECIO_VENTA = func SPEGESE.TARIFA_VENTA([F:I0]ITMREF, 'T50')
          If LUNIDADES_PENDIENTES_RECIBIR > 0 and LPRECIO_VENTA <> 0 Then
            Wrseq '<web>Web Tiendas ALE-HOP</web>' Using [ZEXP]
          Endif
        Endif

        Wrseq '</webs>' Using [ZEXP]
        # IMAGENES -- INI - FALTA VER DE DONDE TENGO QUE SACAR LAS IMÁGENES Y COPIARLAS A LA CARPETA IMAGES ANTES DE CREAR EL ZIP
        Wrseq '<images scope="all"><!-- imágenes del producto -->' Using [ZEXP]
        # Wrseq '<image><src>images/221402.jpg</src></image>' Using [ZEXP]
        Wrseq '</images>' Using [ZEXP]
        # IMAGENES -- FIN -
        Wrseq '<unit_of_measurement>units</unit_of_measurement><!-- siempre units -->' Using [ZEXP]
        Wrseq '<available>1</available><!-- en catálogo: 1: sí, 0: no -->' Using [ZEXP]  # SIEMPRE VALOR 1
        # COSTE --> sacarlo de esta tabla , AVC_0 FROM ITMMVT ITM o de la VISTA DE XIMO --> ZAQSPC
        # LCOSTE = func SPEGESE.COSTE_ARTICULO([F:I0]ITMREF)
        LCOSTE = func GET_COST_PRICE([F:I0]ITMREF) # SE SACA DE LA TABLA ITMMVT
        Wrseq '<cost_price>' + num$(LCOSTE) + '</cost_price><!-- precio de coste del producto -->' Using [ZEXP] # COSTE FIJO UNITARIO
        Call ECR_TRACE( '<cost_price>' + num$(LCOSTE),0) From GESECRAN
        # DATOS DE VENTA - INI -
        Filter [IS] Where ITMREF = [F:I0]ITMREF
        Read [IS] First
        If !fstat Then
            # Vista ZAQSTARIFA - Tarifa T60 y fecha de lanzamiento comprendida entre los dos campos fechas que hay
            # Si hay mas de un registro,quedarse con la que tenga el STARTDATE mas actual.
            # Aqui está el PVP
            # En el escritorio (SistelX3) estn las query que hay que usar.
            # Habra que descontar el porcentaje de impuesto
            LPRECIO_VENTA = 0
            #LPRECIO_VENTA = func SPEGESE.TARIFA_VENTA([F:I0]ITMREF, 'T60')
            # PRECIO DE VENTA MAYORIFAS
            LPRECIO_VENTA = [F:IT]PVM
            LPORCENTAJE_IMPUESTO = func SPEGESE.PORTENTAJE_IMPUESTO([F:I0]VACITM)
            #If LPORCENTAJE_IMPUESTO <> 0 Then
            #  LPRECIO_VENTA =  (LPRECIO_VENTA/(LPORCENTAJE_IMPUESTO/100+1))
            #Endif
            LPRECIO_VENTA = func GET_PRICE_PVP([F:IS]ITMREF, [F:IT]PLICRD)
            #LPRECIO_VENTA = [F:IT]ZPVP # con esta linea evito ir a buscar el precio, ya que lo tengo en la Vista de Gesio.

            Wrseq '<price>' + num$(LPRECIO_VENTA) +  '</price><!-- precio de venta sin IVA -->' Using [ZEXP]
            Call ECR_TRACE( '<price>' + num$(LPRECIO_VENTA),0) From GESECRAN
            Wrseq '<vat>' + num$(LPORCENTAJE_IMPUESTO) + '</vat><!-- porcentaje del IVA asociado al producto -->' Using [ZEXP]

            Wrseq '<max_units_per_order>' + num$([F:I0]ZSTOCKMAX) + '</max_units_per_order><!-- Unidades máximas por pedido -->' Using [ZEXP]   ## preguntar a Enrique / Antonio -- CONFIRMAR SI ES
    # ITMSALES.MINQTY   --- num$([F:IS]MAXQTY)
            Wrseq '<min_units_per_order>' + num$([F:I0]ZSTOCKMIN)  + '</min_units_per_order><!-- Unidades mínimas por pedido -->' Using [ZEXP]   ## preguntar a Enrique / Antonio -- CONFIRMAR SI ES
    # ITMSALES.MAXQTY   ---- num$([F:IS]MINQTY)
            Wrseq '<min_amount_per_order>0</min_amount_per_order><!-- Importe mínimo por pedido -->' Using [ZEXP]   ## preguntar a Enrique / Antonio
        Endif
        Filter [IS]
        # DATOS DE VENTA - FIN -
        Wrseq '<title><![CDATA[' +[F:I0]ITMDES1 + ']]></title><!-- Nombre del producto en el idioma por defecto (castellano) -->' Using [ZEXP]
        Wrseq '<description></description>'  Using [ZEXP] # Esta descripción se rellena desde GESIO
        If year([F:I0]ZFECHALTA) > 0 Then
          Wrseq '<release_date>' + format$("D:YYYY[-]MM[-]DD", [F:I0]ZFECHALTA)   + '</release_date><!-- Fecha de lanzamiento -->' Using [ZEXP]  # FECHA DE ALTA
        Else
          Wrseq '<release_date></release_date><!-- Fecha de lanzamiento -->' Using [ZEXP]  # FECHA DE ALTA
        Endif
        Wrseq '<destocking>0</destocking><!-- En liquidación -->' Using [ZEXP]  # Fijo a 0
        Wrseq '<stock uncontrolled="0"><!-- info stock -->' Using [ZEXP]   # No utilizado - Fijo a 0
        LUNIDADES_PENDIENTES_RECIBIR = func SPEGESE.UNIDADES_PENDIENTES_RECIBIR([F:I0]ITMREF, LSTOCK, LUNIDADES_PENDIENTES_SERVIR)
        #Wrseq '<location path="almacen central|general">' + num$(LSTOCK - LUNIDADES_PENDIENTES_RECIBIR) + '</location></stock>' Using [ZEXP]  # Stock Almacén menos cantidad pendiente de servir
        Wrseq '<location path="almacen central|general">' + num$(LSTOCK - LUNIDADES_PENDIENTES_SERVIR) + '</location></stock>' Using [ZEXP]  # Stock Almacén menos cantidad pendiente de servir
        Call ECR_TRACE( '<location path="almacen central|general">' + num$(LSTOCK - LUNIDADES_PENDIENTES_SERVIR),0) From GESECRAN
        # Datos proveedores
        Wrseq '<suppliers><!-- proveedores -->' Using [ZEXP]
        If clalev([ZITS]) = 0 : Local File ITMBPS [ZITS] : Endif # Art. Proveedor
        Filter [ZITS] Where ITMREF = [F:I0]ITMREF
        #LPRECIO_VENTA = func SPEGESE.TARIFA_VENTA([F:I0]ITMREF, 'T50')
        LPRECIO_VENTA = [F:IT]ZPVP
        For [ZITS]
          Wrseq '<supplier><!-- info proveedor -->' Using [ZEXP]
          Wrseq '<name><![CDATA[' + [F:ZITS]BPSNUM + ']]></name>'  Using [ZEXP]
          Wrseq '<model><![CDATA[' + [F:ZITS]ITMREFBPS + ']]></model>'  Using [ZEXP]
          # Wrseq '<cost_price>' + num$(LPRECIO_VENTA) + '</cost_price><!-- precio proveedor -->' Using [ZEXP] # num$(LCOSTE)
          Wrseq '<cost_price>' +   num$(LCOSTE) + '</cost_price><!-- precio proveedor -->' Using [ZEXP]
          Wrseq '</supplier><!-- info proveedor -->' Using [ZEXP]
        Next
        Close File [ZITS]
    # COSTE DE PROVEEDOR  SELECT * FROM PROTOCLVD.ZAQSTARIFA DE LA TARIFA T50 FILTRANDO POR FECHA (PRECIO CHINO)
    # RESTO DE CAMPOS DEL PROVEEDOR EN LA TABLA ITMSUPP
        Wrseq '</suppliers>' Using [ZEXP]
        # ITMMASTER #
        Wrseq '<containers><!-- info envases -->' Using [ZEXP]
        Wrseq   '<container><name>inner_box</name><!-- nombre envase --><units>1</units><!-- unidades en el envase --></container>' Using [ZEXP]
        Wrseq   '<container><name>middel_box</name><units>1</units></container>' Using [ZEXP]
        Wrseq '</containers>' Using [ZEXP]
        Wrseq '<barcodes><!-- códigos de barras -->' Using [ZEXP]
        Wrseq   '<barcode type="EAN-13">' + [F:I0]EANCOD + '</barcode>' Using [ZEXP]
        Wrseq '</barcodes>' Using [ZEXP]
        Wrseq '<categories><!-- familias de productos -->' Using [ZEXP] ## preguntar a Enrique / Antonio
        Wrseq   '<category></category>' Using [ZEXP]
        Wrseq '</categories>' Using [ZEXP]
        Wrseq '<internationalization><!-- traducciones a otros idiomas -->' Using [ZEXP]


        Wrseq   '<title><!-- nombre del producto -->' Using [ZEXP]
        # LTRADUCCION = func AFNC.TEXTRA("ITMMASTER","DES1AXX","POR",)
        LTRADUCCION = func SPEGESE.TRADUCCION_DESITM([F:I0]ITMREF,"DES1AXX",'POR')
        Wrseq     '<value lang="pt-PT"><![CDATA['+ LTRADUCCION + ']]></value><!-- traducción al portugés -->' Using [ZEXP]
        # LTRADUCCION = func AFNC.TEXTRA("ITMMASTER","DES1AXX","ENG",[F:I0]ITMREF)
        LTRADUCCION = func SPEGESE.TRADUCCION_DESITM([F:I0]ITMREF,"DES1AXX",'ENG')
        Wrseq     '<value lang="en-EN"><![CDATA[' + LTRADUCCION + ']]></value><!-- traducción al inglés -->' Using [ZEXP]
        Wrseq   '</title>' Using [ZEXP]
        Wrseq   '<description><!-- descripción del producto -->' Using [ZEXP]
        # LTRADUCCION = func AFNC.TEXTRA("ITMMASTER","DES2AXX","POR",[F:I0]ITMREF)
        LTRADUCCION = func SPEGESE.TRADUCCION_DESITM([F:I0]ITMREF,"DES2AXX",'POR')
        Wrseq     '<value lang="pt-PT"><![CDATA['+ LTRADUCCION + ']]></value><!-- traducción al portugés -->' Using [ZEXP]
        # LTRADUCCION = func AFNC.TEXTRA("ITMMASTER","DES2AXX","ENG",[F:I0]ITMREF)
        LTRADUCCION = func SPEGESE.TRADUCCION_DESITM([F:I0]ITMREF,"DES2AXX",'ENG')
        Wrseq     '<value lang="en-EN"><![CDATA[' + LTRADUCCION + ']]></value><!-- traducción al inglés -->' Using [ZEXP]
        Wrseq   '</description>' Using [ZEXP]
        Wrseq '</internationalization>' Using [ZEXP]

        Wrseq '<rates><!-- info tarifas --><!-- ALEHOP podrá explicar mejor a que corresponde cada tarifa -->' Using [ZEXP]
        LPRECIO_VENTA = func SPEGESE.TARIFA_VENTA([F:I0]ITMREF, 'T50')
        Wrseq   '<rate><name>pvm_rate_1</name><price>' + num$([F:IT]PVM) + '</price><!-- precio de la tarifa sin impuestos --></rate>' Using [ZEXP]
        Wrseq   '<rate><name>pvm_rate_2</name><price>0</price></rate>' Using [ZEXP]
        Wrseq   '<rate><name>pvm_rate_1_time</name><price>0</price></rate>' Using [ZEXP]
        Wrseq   '<rate><name>pvp_rate_4</name><price>' + num$([F:IT]ZPVP) + '</price></rate>' Using [ZEXP]
        Wrseq   '<rate><name>pvp_rate_1_time</name><price>0.0000</price></rate>' Using [ZEXP]
        Wrseq '</rates>' Using [ZEXP]
        LTIPO_ARTICULO = func GET_TIPO_ARTICULO([F:I0]ITMREF, [F:I0]TSICOD(2))
        Wrseq '<specific_data product_type_path="'+ LTIPO_ARTICULO + '"><!-- otros datos: campos variables --><!-- ALEHOP podrá explicar mejor a que corresponde cada campo variable -->' Using [ZEXP]
        # Wrseq '<specific_data product_type_path="">' Using [ZEXP]
        If year([F:I0]ZFECHALTA) > 0 Then
          Wrseq   '<var><name>Fecha alta Clave Denia</name><value>' + format$("D:YYYY[-]MM[-]DD", [F:I0]ZFECHALTA) +  '</value></var>' Using [ZEXP]
        Else
          Wrseq   '<var><name>Fecha alta Clave Denia</name><value></value></var>' Using [ZEXP]
        Endif
        # UNIDADES DE LINEAS DE COMPRA NO SALDADAS - UNIDADES FUTURO
        Wrseq   '<var><name>unidades pendientes de recibir</name><value>'+ num$(LUNIDADES_PENDIENTES_RECIBIR) + '</value></var>' Using [ZEXP]
         # FAMILIA DE ARTICULOS CAMPO ITMMASTER.TSICOD_3
        Wrseq   '<var><name>Asterisco</name><value><![CDATA[' + [F:I0]TSICOD(3) +  ']]></value></var>' Using [ZEXP]
        # ###### ?????  # PREGUNTAR A ENRIQUE / ANTONIO
        Wrseq '<var><name>Nro.Etiquetas de embalaje</name><value><![CDATA[' + [F:I0]TSICOD(1) +  ']]></value></var>' Using [ZEXP] # Etiqueta
        # ###### ?????  # PREGUNTAR A ENRIQUE / ANTONIO
        # VMARCA_WEB = func SPEGESE.ITM_MARCA_WEB([F:I0]ITMREF)
        If [F:I0]ZW = 2 Then                                    #   SUPPORT-3472 EXPORTACIÓN GESIO PARAMETRO W NEW
        # If VMARCA_WEB = 2 Then                                #   SUPPORT-3472 EXPORTACIÓN GESIO PARAMETRO W OLD
            Wrseq   '<var><name>Producto Web</name><value>W</value></var>' Using [ZEXP]
        Else
            Wrseq   '<var><name>Producto Web</name><value></value></var>' Using [ZEXP]
        Endif
        ###### TENGO EL DATO EN LA PESTAÑA ALEHOP
        If [F:I0]ZLEER = 2 Then
           LLEER = 'S'
        Else
           LLEER = 'N'
        Endif
        Wrseq   '<var><name>Leer EAN</name><value>' + LLEER + '</value></var>' Using [ZEXP]
        # FAMILIA DE ARTICULOS CAMPO ITMMASTER.TSICOD_2 - PLANOGRAMA
        Wrseq   '<var><name>Codigo Catalogo Compra</name><value><![CDATA[' + [F:I0]TSICOD(2) +  ']]></value></var>' Using [ZEXP] # Planograma
        If year([F:I0]ZFECHABAJA)>0 Then
          Wrseq '<var><name>Fecha de Baja</name><value>' + format$("D:YYYY[-]MM[-]DD", [F:I0]ZFECHABAJA) + '</value></var>' Using [ZEXP]
        Else
          Wrseq '<var><name>Fecha de Baja</name><value></value></var>' Using [ZEXP]
        Endif
        Wrseq '<var><name>Stock Tienda Online</name><value></value></var>' Using [ZEXP]
        Wrseq '<var><name>Ficha Producto</name><value></value></var>' Using [ZEXP] # NO SE UTLIZA
        # itmmaster.CUSREF
        Wrseq '<var><name>Partida arancelaria</name><value>' + [F:I0]CUSREF + '</value></var>' Using [ZEXP]
        # ZUBIPRED
        Wrseq '<var><name>picking</name><value>' + [F:I0]ZUBIPRED + '</value></var>' Using [ZEXP]
        Wrseq '<var><name>Inmovilizado o Suministro</name><value></value></var>' Using [ZEXP]
        # Buscar en las líneas de facturas de compra
        LFECHA = func SPEGESE.DATOS_COMPRA([F:I0]ITMREF, LPRECIO_COMPRA)
        Wrseq '<var><name>Ultima fecha de compra</name><value>' + LFECHA + '</value></var>' Using [ZEXP]
        Wrseq '<var><name>CodigoCatalogoAntiguo</name><value>' + [F:I0]TSICOD(4) +  '</value></var>' Using [ZEXP]
        # buscar en las líneas de compra
    #    If LPRECIO_COMPRA = '0' Then
    #      LPRECIO_COMPRA = num$(func GET_LAST_PRICE_PUR([F:I0]ITMREF))
    #    Endif

        LPRECIO_COMPRA = num$(func GET_ULTIMO_PRECIO_TARIFA_T05([F:I0]ITMREF))
        Wrseq '<var><name>Ultimo precio compra</name><value>'+ LPRECIO_COMPRA  + '</value></var>' Using [ZEXP]
        Call ECR_TRACE( '<var><name>Ultimo precio compra</name><value>'+ LPRECIO_COMPRA,0) From GESECRAN
        Wrseq '<var><name>Codigo catalogo</name><value>' + [F:I0]TSICOD(0) +  '</value></var>' Using [ZEXP]
        Wrseq '<var><name>Existencias</name><value>' + num$(LSTOCK) + '</value></var>' Using [ZEXP] ##### ????? SELECT ITMREF_0, STOCK_0 FROM PROTOCLVD.ZAQSSTOCK --> ESTE CAMPO ES EL STOCK
        Call ECR_TRACE('<var><name>Existencias</name><value>' + num$(LSTOCK),0) From GESECRAN
         Wrseq '<var><name>Codigo barras proveedor</name><value></value></var>' Using [ZEXP] # VACIO - NO SE UTILIZA
        # pedidos de compra que se van a plante pedido OF001
         # proveedor <>  90001 / 9001
         # mostrar el mas cercano a la fecha actual
         LFECHA_DE_LLEGADA = func GET_FECHA_ULTIMO_PEDIDO([F:I0]ITMREF)

        Wrseq '<var><name>FechaDeLlegada</name><value>' + LFECHA_DE_LLEGADA + '</value></var>' Using [ZEXP]  #
        Call ECR_TRACE('<var><name>FechaDeLlegada</name><value>' + LFECHA_DE_LLEGADA,0) From GESECRAN
        Wrseq '</specific_data>' Using [ZEXP]
        Wrseq '</product>' Using [ZEXP]


        #Call GET_ATEXTRA("ITMMASTER", "DES1AXX", "SPA", [I0]ITMREF, "", LDATLIN(I)) : I+=1
        #Call GET_ATEXTRA("ITMMASTER", "DES1AXX", "POR", [I0]ITMREF, "", LDATLIN(I)) : I+=1
        #Call GET_ATEXTRA("ITMMASTER", "DES1AXX", "ENG", [I0]ITMREF, "", LDATLIN(I)) : I+=1
        #Call GET_ATEXTRA("ITMMASTER", "DES1AXX", "CAT", [I0]ITMREF, "", LDATLIN(I)) : I+=1


        # ACTUALIZAR TARIFA Y MARCA DE MODIFICACIÓN SI EL ARTÍCULO ESTÁ MARCADO COMO A EXPORTAR A GESIO
        If [F:IT]ZGESEXP = 2 and [F:IT]PLI <> '' and [F:IT]PLICRD <> '' Then
          Call ECR_TRACE('Actualizar tarifa: ' + [F:I0]ITMREF + ' - Tarifa: ' + [F:IT]PLI + ' - Precio: ' + [F:IT]PLICRD ,0) From GESECRAN
          Call ACTUALIZAR_TARIFA([F:IT]ITMREF, [F:IT]PLI, [F:IT]PLICRD)
        Endif

        LTOTITM +=1  # número total de artículos exportados..



    Else
         Call ECR_TRACE('**** **** **** Articulo excluido de la exportación: ' + [F:I0]ITMREF ,0) From GESECRAN
         Call ECR_TRACE('Código catalogo: ' + [F:I0]TSICOD(2) ,0) From GESECRAN
         Call ECR_TRACE('Fecha Baja: ' + num$([F:I0]ZFECHABAJA),0) From GESECRAN
         Call ECR_TRACE('Fecha Alta: ' + num$([F:I0]ZFECHALTA) ,0) From GESECRAN
         Call ECR_TRACE('Precio (ZPVP): ' + num$([F:IT]ZPVP) + " - Tarifa: " + [F:IT]PLICRD,0) From GESECRAN
    Endif
  Next
  If LTOTITM > 0 : Wrseq '</catalog>' Using [ZEXP] : Endif
   # cerrar fichero import
  Gosub CLOSE_FILE
  # copiar fichero
  #Local Integer STAT : STAT = 1
  #Infbox "copiar de :" + LFILE +  " a " + LDIREXPORT
  #Call MOVE (LFILE, LDIREXPORT, STAT) From ORDSYS
  Call MOVEFILE(LFILE,LDIREXPORT)


  Call ECR_TRACE('TOTAL ARTICULOS EN EL XML: ' + num$(LCONTADOR) ,0) From GESECRAN
  # hacemos una copia del fichero generado...
  # System "cp " + LFILE + " " + LFILECOPY
  # 04092019.MAB - Comento la línea de la copia ya que de momento no es necesaria.

Return

##################################################################################################################
$INICIALIZACIONES
  # LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4) # MAB.13092019.OLD - ALEHOP-972
  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,7,4)+ mid$(LFECHA,4,2)+mid$(LFECHA,1,2)  # MAB.13092019.NEW - ALEHOP-972
  LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

  LDIREXPORT  = [M:GES]DIREXP

    #LECTURA DEL CONTROL FECHA ITM
  # SUPPORT-3170
  # BUSCO LA CARPETA TEMPORAL PARA CREAR EL FICHERO Y LUEGO MOVERLO A LA CARPETA DEFINITIVA

  Read [F:YADI2]CODE=6002;'3'
  If !fstat
      LDIREXPORT_TMP = [F:YADI2]A1
  Endif
  # SUPPORT-3170
  #LDIREXPORT    = "E:\EXPORT\GESIO\" # MAB-09012020
  MES = num$(month(date$))
  If len(MES) = 1 : MES = "0" + MES : Endif
  DIA = num$(day(date$))
  If len(DIA) = 1 : DIA= "0" + DIA : Endif
  FECHA_HORA  = "" + num$(year(date$)) + "-" + MES + "-" + DIA + "T" + num$(time$) + "Z"
Return


##############################################################################################################
$GET_TRAZA
Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
Call ECR_TRACE("Artículos actualizados   : " + num$(LTOTITM), 0) From GESECRAN
Return


################################################################################################################
#**
#* Borramos un fichero existente.
#* El parámetro LFILE debe tener una ruta correcta..
#*!
$DEL_FILE
# borramos el fichero si existe...
If filinfo(LFILE, 7) > 0 Then
  System "ae_rm " + LFILE
Endif
Sleep 3  # los ficheros para que se borren correctamente hay que realizar una pausa

Return


################################################################################################################
$OPEN_FILE
#abrimos el fichero sólo si hay datos para crearlo, en la primera pasada del FOR
If !FILEOPENED Then
  adxifs = LSEP
  adxirs = chr$(13)+chr$(10)
  Openo LFILE Using [ZEXP]
 # Openo LFILECOPY Using [ZCOPY]
  FILEOPENED=1
Endif

Return

################################################################################################################
$CLOSE_FILE
#cerrar fichero si estaba abierto.
If FILEOPENED Then
  Openo Using [ZEXP]
 # Openo Using [ZCOPY]
Endif
FILEOPENED=0

Return


##################################################################################################################
#**
#* Obtiene la traducción
#*
#* @param PCODFIC > tabla
#* @param PZONE   > campo
#* @param PLANGUE > idioma
#* @param PIDENT1 > identidad 1
#* @param PIDENT2 > identidad 2
#* @param PTEXTO  > devuelve el texto traducido o en blanco
#*!
Subprog GET_ATEXTRA(PCODFIC, PZONE, PLANGUE, PIDENT1, PIDENT2, PTEXTO)
Variable  Char PTEXTO
Value     Char PCODFIC
Value     Char PZONE
Value     Char PLANGUE
Value     Char PIDENT1
Value     Char PIDENT2
Onerrgo ERR_TRADUCCION
Raz PTEXTO

# tabla
If clalev([A0]) = 0 : Local File ATEXTRA   [A0] : Endif  # traducciones

# obtener la tradución
Read [A0]AXX0 = PCODFIC;PZONE;PLANGUE;PIDENT1;PIDENT2
If !fstat Then
  PTEXTO = [A0]TEXTE
Endif


# cerrar tabla
Close Local File [A0]
End
########################################################################################################################
#######  MAS FORMAS DE OBTENER LA TRADUCCIÓN
########################################################################################################################
# func AFNC.TEXTRA("ITMMASTER","SHODES","SPA",PITMREF)
Funprog TRADUCCION_DESITM(PITMREF, PZONE, PIDIOMA)
  Value Char PITMREF, PIDIOMA, PZONE
  Local Char TEXTO

  If !clalev([F:YATX])
      Local File ATEXTRA [F:YATX]
  Endif
  Read[F:YATX]AXX0 = "ITMMASTER";PZONE;PIDIOMA;PITMREF
  TEXTO = [F:YATX]TEXTE

End TEXTO


##################################################################################################################
$ERR_TRADUCCION
  PTEXTO=""
  Resume
Return


####################################################################################################################
# FUNCIONES ########################################################################################################
####################################################################################################################
#**
#* Función que nos devuelve si el articulo cumple el parámetro de Marca Web
#* @return 2 - Si es Marca Web
#*
#*!
Funprog ITM_MARCA_WEB(PITMREF)
  Local Integer MARCA_WEB

  If clalev([ZVW]) = 0 : Local File ZVITMWEB [ZVW] : Endif # Art. Web Stock en 70% Plantas

  Filter [ZVW] Where ITMREF = PITMREF
  Read [ZVW] First
  If !fstat Then
    MARCA_WEB = [F:ZVW]WEB
  Else
    MARCA_WEB = 0
  Endif
  Close File [ZVW]



End MARCA_WEB
####################################################################################################################
#**
#* Función que nos devolverá las unidades pendientes de recibir
#*
#* @param PIMPREF
#*!
Funprog UNIDADES_PENDIENTES_RECIBIR(PITMREF, PSTOCK, PUNIDADES_PENDIENTES_SERVIR)
  Variable Decimal PSTOCK
  Variable Decimal PUNIDADES_PENDIENTES_SERVIR
  Local Integer UNIDADES_PTR # unidades pendientes de recibir


  If clalev([ZSTC]) = 0 : Local File ZGESSTOCK [ZSTC] : Endif # Stock Central

  Filter [ZSTC] Where ITMREF = PITMREF
  Read [ZSTC] First
  If !fstat Then
    UNIDADES_PTR = [F:ZSTC]QTYPTR
    PSTOCK = [F:ZSTC]STOCK
    PUNIDADES_PENDIENTES_SERVIR = [F:ZSTC]QTYSER
  Else
    UNIDADES_PTR = 0
  Endif
  Close File [ZSTC]

End UNIDADES_PTR
####################################################################################################################
#**
#* Funcion que devuelve el PVP de la tarifa T50
#*
#* @param PITMREF
#* @return Precio Tarifa T50
#*!
Funprog TARIFA_VENTA(PITMREF, PTARIFA)
  Local Decimal TARIFA

  If clalev([ZTAR]) = 0 : Local File ZAQSTARIFA [ZTAR] : Endif # Tarifa T50
  # ordenamos por fecha de inicio DESC, para coger la más cercana a la fecha actual
  Filter [ZTAR] Where PLI = PTARIFA and ITMREF = PITMREF and PLISTRDAT <= date$ and (PLIENDDAT <> '00000000' and PLIENDDAT >= date$) Order By PLISTRDAT Desc
  Read [ZTAR] First
  If !fstat Then
    TARIFA = [F:ZTAR]PRI
  Else
    TARIFA = 0
  Endif
  Close File [ZTAR]
End TARIFA



####################################################################################################################
#**
#* Funcion que devuelve el COSTE DEL ARTICULO
#*
#* @param PITMREF
#* @return Coste
#*!
Funprog COSTE_ARTICULO(PITMREF)
  Local Decimal COSTE
  Local Char LVAT

  If clalev([ZAQC]) = 0 : Local File ZAQSPC [ZAQC] : Endif # Tarifa T50

  Filter [ZAQC] Where ITMREF = PITMREF
  Read [ZAQC] First
  If !fstat Then
    COSTE = [F:ZAQC]AVC
  Else
    COSTE = 0
  Endif

  Close File [ZAQC]
End COSTE

#**
#*
#*
#* @param PVACITM
#*!
Funprog PORTENTAJE_IMPUESTO(PVACITM)
  Local Decimal PORCENTAJE
  Local Char LVAT

  If clalev([TVAC]) = 0 : Local File TABVAC [TVAC] : Endif #
  If clalev([ZRAT]) = 0 : Local File TABRATVAT [ZRAT] : Endif #

  Filter [TVAC] Where LEG = 'SPA' and VACITM = PVACITM  and VACBPR = 'NAC'
  Read [TVAC] First
  If !fstat Then
    LVAT = [F:TVAC]VAT
    Filter [ZRAT] Where VAT = LVAT Order By STRDAT Desc
    Read [ZRAT] First
    If !fstat Then
       PORCENTAJE = [F:ZRAT]VATRAT
    Else
       PORCENTAJE = 0
    Endif
    Close File [ZRAT]
  Else
    PORCENTAJE = 0
  Endif

  Close File [TVAC]


End PORCENTAJE


#**
#* Busqueda datos de Compra
#*
#*!
Funprog DATOS_COMPRA(PITMREF, PPRECIO_COMPRA)
  Variable Char PPRECIO_COMPRA
  Local Char LFECHA

  If clalev([PID]) = 0 : Local File PINVOICED [PID] : Endif #


  Filter [PID] Where ITMREF = PITMREF and BPSNUM <> '9001'  Order By ACCDAT Desc
  Read [PID] First
  If !fstat Then
    LFECHA  = num$([F:PID]ACCDAT) # FECHA ULTIMA COMPRA
    PPRECIO_COMPRA = num$([F:PID]NETPRI)
  Endif
  Close File [PID]
End LFECHA


#**
#* Proceso que desmarca la tarifa como modificada
#* Si el campo EXPGES esta a 2, modificarlo a 1
#* Si también estuviera el campo EXPAQS  a 1, modifcar campo MARCA A 1.
#*
#* @param PITMREF
#* @param PCODTARIFA
#* @param PREGTARIFA
#*!
Subprog ACTUALIZAR_TARIFA(PITMREF, PCODTARIFA, PREGTARIFA)


  If clalev([STAR]) = 0 : Local File SPRICLIST [STAR] : Endif

  Filter [STAR] Where PLICRI1 = PITMREF and PLI = PCODTARIFA and PLICRD = PREGTARIFA
 # Infbox num$(rowcount([STAR]))

  Readlock [STAR] First
  If !fstat Then
    Trbegin [STAR]
    [F:STAR]ZGESEXP = 1
    If [F:STAR]ZAQSEXP = 1 Then
      [F:STAR]ZMARCA = 1
    Endif
    Call ECR_TRACE('Articulo: ' + [F:I0]ITMREF + ' actualizado. ' ,0) From GESECRAN
    Rewrite [STAR]
    Commit

#   Else
#      Rollback
    Endif

  Close File [STAR]
End


#**
#* PVP ARTICULO
#*
#* @param PITMREF --> Articulo
#* @param PPLICRD --> codigo de tarifa
#*!
Funprog GET_PRICE_PVP(PITMREF, PPLICRD)
  Local Float RES
  If !clalev([ZSPR])   Then : Local File SPRICLIST [ZSPR]  : Endif  #

  Filter [ZSPR] Where PLICRI1 = PITMREF and PLI = 'T50' and PLICRD = PPLICRD
  Read [ZSPR] First
  If !fstat Then
    RES = [F:ZSPR]ZPVP
  Else
    RES = 0
  Endif
  Close File [ZSPR]

End RES

#**
#* ultimo precio de compra ARTICULO
#*
#* @param PITMREF
#*!
Funprog GET_LAST_PRICE_PUR(PITMREF)
  Local Float RES
  If !clalev([ZIMV])   Then : Local File ITMMVT [ZIMV]  : Endif  #

  Filter [ZIMV] Where ITMREF = PITMREF and STOFCY = 'ALM00'
  Read [ZIMV] First
  If !fstat Then
    RES = [F:ZIMV]LASPURPRI
  Else
    RES = 0
  Endif
  Close File [ZIMV]

End RES


#**
#* TIPO DEL ARTICULO
#*
#* @param PITMREF
#*!
Funprog GET_TIPO_ARTICULO(PITMREF, PTIPO)
  Local Char RES
  If !clalev([ZATX])   Then : Local File ATEXTRA [ZATX]  : Endif  #

  Filter [ZATX] Where IDENT1 = '22' and ZONE = 'SHODES' and CODFIC = 'ATAVDIV' and LANGUE = 'SPA' and IDENT2 = PTIPO
  Read [ZATX] First
  If !fstat Then
    RES = [F:ZATX]TEXTE
  Else
    RES = ''
  Endif
  Close File [ZATX]

End RES


#**
#* COSTE ARTICULO DEL ALMACEN BASE
#*
#* @param PITMREF
#*!
Funprog GET_COST_PRICE(PITMREF)
  Local Float RES
  If !clalev([ZITV])   Then : Local File ITMMVT [ZITV]  : Endif  #

  Filter [ZITV] Where ITMREF = PITMREF and STOFCY = 'ALM00'
  Read [ZITV] First
  If !fstat Then
    RES = [F:ZITV]AVC
  Else
    RES = 0
  Endif
  # Si el precio es 0, debemos buscarlo en la tabla ITMCOST
  If RES = 0 Then
    If !clalev([ZITC]) Then : Local File ITMCOST [ZITC] : Endif
    Filter [ZITC] Where ITMREF = PITMREF and STOFCY = 'ALM00'
    Read [ZITC] First
    If !fstat Then
      RES = [F:ZITC]MATTOT
    Else
      RES = 0
    Endif
    Close File [ZITC]
  Endif
  Close File [ZITV]

End RES


Funprog GET_FECHA_ULTIMO_PEDIDO(PITMREF)
  Local Char RES
   # pedidos de compra que se van a plante pedido OF001
     # proveedor <>  90001 / 9001
     # mostrar el mas cercano a la fecha actual
     # A petición de David, se modifica la fecha de llegada. Ahora se saca de las expediciones.
     # es posible que este dato esté vacio

#  If !clalev([ZSHH]) Then : Local File SHIPMENT [ZSHH] : Endif
#  If !clalev([ZSHD]) Then : Local File SHIPMENTD [ZSHD] : Endif
#
#  Filter [F:ZSHD] Where ITMREF = PITMREF and POHFCY = 'OF001' and CLEFLG = 1
#  Read [F:ZSHD] First
#  If !fstat Then
#    Filter [F:ZSHH] Where SHIPNUM = [F:ZSHD]SHIPNUM
#    Read [F:ZSHH] First
#    If !fstat Then
#      RES = num$([F:ZSHH]ARVEXPDAT)
#    Else
#      RES = ''
#    Endif
#  Endif

  If !clalev([ZGFU]) Then : Local File ZGESFUC [ZGFU] : Endif

  Filter [F:ZGFU] Where ITMREF = PITMREF Order By EXTRCPDAT Asc
  Read [F:ZGFU] First
  If !fstat Then
    RES = num$([F:ZGFU]EXTRCPDAT)
  Else
    RES = ''
  Endif
  Close File [ZGFU]

#  Close File [ZSHH]
#  Close File [ZSHD]

End RES

Funprog GET_ULTIMO_PRECIO_TARIFA_T05(PITMREF)
    Local Float RES
    If !clalev([ZPPL]) Then: Local File PPRICLIST [ZPPL] : Endif

    Filter [F:ZPPL] Where PLI = 'T05' and PLICRI1 = PITMREF
    Read [F:ZPPL] First
    If !fstat Then
      RES = [F:ZPPL]PRI
    Else
      RES = 0
    Endif
    Close File [ZPPL]
End RES

#**
#*
#*
#* @param PATH1
#* @param PATH2
#*!
Subprog MOVEFILE(PATH1,PATH2)
  Value Char PATH1
  Value Char PATH2
  Local Integer RETURN_VALUE
  RETURN_VALUE=Delfile(filpath("TMP","","","","",adxmac(0))+'\COPY.BAT')
  Local Char WRET(250) (0..4)

  Openo filpath("TMP","","","","",adxmac(0))+'\COPY.BAT' Using [FACS]
  WRET(0)="XCOPY "+PATH1+" " +PATH2+ " /z "
  Wrseq WRET(0) Using [FACS]

  Openo Using [FACS]
  System CHAINE=(filpath("TMP","","","","",adxmac(0))+'\COPY.BAT') ###To execute the bat file

End
