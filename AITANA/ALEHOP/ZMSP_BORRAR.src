#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
#########################################################
# 14/03/2017
# Genera Recepción de compra a partir de Vale de transporte
#########################################################
$ACTION
#If GUSER="SIST1" Then : Infbox ACTION : Endif
Case ACTION
  When "STATUT"       : Gosub STATUT
  When "SETBOUT"      : Gosub SETBOUT
  When Default
Endcase
Return


######################################################################################
$SETBOUT

If [BOL0]BOLNUM <> '' Then CHMEN += "C5" Endif

Return


######################################################################################
$STATUT

  Case BOUT
    When "5" : Gosub GENERAR_RECEPCION
    When Default
  Endcase
Return


#########################################################
$GENERAR_RECEPCION

Local Char    LFILE(200)
Local Char    LDIRIMPORT(250) : LDIRIMPORT = "E:\IMPORT\IMP\"
Local Integer RECEPCIONAR
# estados
# 1 -> Ya existe recepción
# 2 -> No existe recepción
Local Decimal IMPORTE_PORTES

Gosub ABRIR_TBL


#Comprueba el Vale no tiene asociado una Recepcion
Gosub SIN_RECEPCION

If RECEPCIONAR=2 Then
  Gosub GEN_PTH
  Gosub IMP_PTH
Endif

Gosub CERRAR_TBL

Return



#########################################################
# generar fichero
$GEN_PTH
Local Char LDATCAB(30)(10),LDATLIN(30)(10)
Local Char LFECHA(10), LHORA(10)

LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)


# ruta del fichero..
LFILE  = LDIRIMPORT + "PTH_"+LFECHA+"_"+LHORA+".txt"

Gosub OPEN_FILE

LDATCAB(1) = [BOL0]FCY
LDATCAB(2) = [BOL0]BOLDAT
LDATCAB(3) = [BOL0]BPTNUM
LDATCAB(4) = [BOL0]BOLNUM

Wrseq '"E";' +'"'+LDATCAB(1)+'";' +'"'+LDATCAB(2)+'";' +'"'+LDATCAB(3)+'";' +'"'+LDATCAB(4)+'";' Using [ZIMP]

Raz LDATLIN

Filter [ZADW] Where [ZADW]PARAM = 'ZITMPORTES'
Read [ZADW] First
If !fstat Then
  LDATLIN(1) = num$([ZADW]VALEUR)
Endif
Filter [ZADW]

LDATLIN(2) = 'UN'

LDATLIN(3) = '1'

Gosub SUMAR_PORTES
LDATLIN(4) = num$(IMPORTE_PORTES)

#escribimos en el fichero...
Wrseq '"L";' +'"'+LDATLIN(1)+'";' + '"'+LDATLIN(2)+'";' +'"'+LDATLIN(3)+'";' +'"'+LDATLIN(4)+'";' Using [ZIMP]

# cerrar fichero import
Gosub CLOSE_FILE

Return


#########################################################
# importar fichero
$IMP_PTH

mkstat = 0 : fstat = 0 : GERRTRACE = 0

Call OUVRE_TRACE("Creación Recepcion a partir de Vale Transporte") From LECFIC

Call IMPORTSIL("ZPTHI", LFILE) From GIMPOBJ

Call FERME_TRACE From LECFIC

#If fstat or GERRTRACE <> 0
#  Call ECR_TRACE("Error al crear la Recepción",1) From GESECRAN
#Else
#  Infbox ("Se ha creado la Recepción de Compras")
#Endif

Call LEC_TRACE From LECFIC   #si se quiere mostrar traza

mkstat = 0 : fstat = 0 : GERRTRACE = 0

Return


#########################################################
$ABRIR_TBL

If clalev([ZBOLD]) = 0 : Local File BILLLADH  [ZBOLD] : Endif # vale transporte cab.
If clalev([ZBOLH]) = 0 : Local File BILLLADD  [ZBOLH] : Endif # vale transporte lin.
If clalev([ZPTH])  = 0 : Local File PRECEIPT  [ZPTH]  : Endif # recepciones cab.
If clalev([ZPTD])  = 0 : Local File PRECEIPTD [ZPTD]  : Endif # recepciones lin.
If clalev([ZADW])  = 0 : Local File ADOVAL    [ZADW]  : Endif # valores parámetros
Return


#########################################################
$CERRAR_TBL

Close Local File [ZBOLD],[ZBOLH],[ZPTH],[ZPTD],[ZADW]

Return


########################################################
$OPEN_FILE

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE Using [ZIMP]

Return


########################################################
$CLOSE_FILE

Openo Using [ZIMP]

Return


######################################################################################
#Comprueba el Vale no tiene asociado una Recepcion
$SIN_RECEPCION

RECEPCIONAR = 2

Filter [ZPTH] Where [ZPTH]BPSNDE = [BOL0]BOLNUM

Read [ZPTH] First
If !fstat Then
  RECEPCIONAR = 1
  GERR = 1
  GMESSAGE = "Ya existe una Recepción de este Vale de Transporte: "+[ZPTH]PTHNUM
Endif
Filter [ZPTH]

Return


######################################################################################
#Suma los portes de las líneas del Vale de Transporte
$SUMAR_PORTES
Local Integer LCON

Raz IMPORTE_PORTES

For LCON = 0 To [M:BOL1]NBLIG-1
  IMPORTE_PORTES += [M:BOL1]ZPRIPOR(LCON)
Next

Return


End

