#######################################################################################
#**
#* Genera un código EAN13
#*
#* @param PEAN > devuelve el código EAN13
#*!
Subprog GEN_CODEAN13(PEAN)
Variable Char PEAN

Local Char    LNUMEAN(20) # número ean (12 dígitos)
Local Integer LSTAT       # estado contador
Local Integer LDIGCON     # dígito de control

# Calculamos el número del contador (está parametrizado
Call NUMERO("ZEAN0", "", date$, "", LNUMEAN, LSTAT) From SUBANM

# si el contador retorna 12 dígitos, calculamos el dígito de control
# diponemos 99.999 codigos diferentes, si contador >= 100.000 no devuelve EAN
If LSTAT = 0 and len(LNUMEAN) = 12 Then
  # obtiene el dígito de control
  Call GEN_DIGITO_CONTROL(LNUMEAN, LDIGCON)
Endif

PEAN = LNUMEAN + num$(LDIGCON)
End

#######################################################################################
#**
#* Obtiene el dígito de control del EAN13
#*
#* @param PEAN > código EAN de 12 números
#* @param PDIGCON > devuelve el dígito de control para completar el EAN13
#*!
Subprog GEN_DIGITO_CONTROL(PEAN, PDIGCON)
Variable  Integer PDIGCON
Value     Char    PEAN

Local Integer LNUMIMPAR,LNUMPAR
Local Integer I

If len(PEAN) = 12 Then
  #Obtengo el Dígito de Control
  For I=1 To 11 Step + 2
      LNUMPAR=LNUMPAR + val(mid$(PEAN,I,1))
  Next
  For I=2 To 12 Step + 2
      LNUMIMPAR=LNUMIMPAR + val(mid$(PEAN,I,1))
  Next
  PDIGCON=LNUMPAR + (LNUMIMPAR * 3)
  PDIGCON=mod((10 - mod(PDIGCON,10)),10)
Endif

End

