#<AdxTL>@(#)0.0.0.0 $Revision$
#XVT28-05-2019.bn - CORRECCIĂ“N POR PROBLEMA EN VALORACIĂ“N DE LĂŤNEA EN PLAN DE ORDENACIĂ“N
#CUANDO SE INTENTA REALIZAR UN PLAN DE ORDENACIĂ“N APARECE EL ERROR: PRECIO VALORACIĂ“N NULO NO ACEPTADO
#XVAL

$ACTION

  Case ACTION
    When "DEFPRI" : Gosub DEFPRI
  Endcase
Return

$DEFPRI
  If LTYP=22 Then
  #PARA PLAN DE ORDENACIĂ“N

    [L]WVLT =[F:TCM]ISSVLTCOD(LNUMVLT)
    [L]WVLT2=[F:TCM]ISSVLT2(LNUMVLT)
    [L]WNUL =[F:TCM]NULPRI(LNUMVLT)

  Endif
Return
#XVT28-05-2019.en

