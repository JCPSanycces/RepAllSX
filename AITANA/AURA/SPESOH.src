######################################################################################
## Etiqueta ańadida por el supervisor (pantalla SOH1) 04/09/2019 17:21:53 (AIT04)
######################################################################################
$ACTION
Case ACTION
 When Default
Endcase
Return

Subprog AM_PJT(VALEUR)
Variable Char    VALEUR()
# Si pongo valor, estoy en creación y no tengo valor de pedido, pongo el valor como número de pedido
If GREP = "C" and VALEUR <>""
  [M:SOH0]SOHNUM = VALEUR
  Affzo [M:SOH0]SOHNUM
Endif
End


######################################################################################
Subprog C_PJT(VALEUR)
Variable Char    VALEUR()
# Controlo que el cliente pertenezca al grupo indicado en el proyecto
If VALEUR <> ""
  Read [OPP]OPP0 = VALEUR
  If fstat = 0 and [OPP]YBPCGRUPO <> ""
    Read [BPC]BPC0 = [M:SOH0]BPCORD
    If fstat = 0
      If [BPC]BPCGRU <> [OPP]YBPCGRUPO
        Errbox "El cliente del pedido (" + [M:SOH0]BPCNAM + "), NO pertenece al grupo indicado en el proyecto (" + [OPP]YBPCGRUPO + ")"
        mkstat = 2
      Endif
    Endif
  Endif
Endif
End



######################################################################################
Subprog IB_PJT
# Pongo nombre a la opción del menú contextual
GBOUT10 = 'Selección de proyectos cliente grupo'
End

######################################################################################
Subprog B10_PJT(VALEUR)
Variable Char    VALEUR()
# Selecciono los proyectos por cliente grupo
Local Char BPC_BGRUPO
Read [BPC]BPC0 = [M:SOH0]BPCORD
If fstat = 0
  BPC_GRUPO = [BPC]BPCGRU
Endif

Filter [OPP] Where [OPP]YBPCGRUPO = BPC_GRUPO
  Call SELECT("OPP","",VALEUR,"") From SELOBJ
Filter [OPP]
End


