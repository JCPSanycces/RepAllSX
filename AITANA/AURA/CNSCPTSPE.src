#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "SETBOUT" :  Gosub SETBOUT
Endcase
Return

#70500001  #572
######################################################################################
$SETBOUT
# Lanzo el proceso STD
Gosub SETBOUT From CNSCPTSTD

# Cargo la razón social de la contrapartida
If [M:CPT2]NBLIG>0
  If !clalev([PP1]) : Local File BPARTNER [PP1] : Endif
  Local Integer LINE

  For LINE=0 To [M:CPT2]NBLIG-1
    Read [PP1]BPR0 = [M:CPT2]OFFACC(LINE)
    If fstat = 0
      [M:CPT2]YRAZON(LINE) = [PP1]BPRNAM
      Affzo [M:CPT2]YRAZON(LINE)
    Endif
  Next

  Close Local File [PP1]
Endif

# Bloqueo STD
GPE = 1
Return

