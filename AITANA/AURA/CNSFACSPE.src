#<AdxTL>@(#)0.0.0.0 $Revision$
# 10/02/2020 - MS - Consulta Facturas Terceros

$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "AV_AFFICHE" : Gosub AV_AFFICHE
Endcase
Return


############################################
$AV_AFFICHE

Local Integer LINEA

If !clalev([PP1])   : Local File SINVOICED  [PP1]   : Endif
If !clalev([PP2])   : Local File GACCDUDATE [PP2]   : Endif
If !clalev([PP3])   : Local File ATEXTRA    [PP3]   : Endif
If !clalev([ZDAE])  : Local File GACCENTRYD [ZDAE]  : Endif
If !clalev([ZBPR])  : Local File BPARTNER   [ZBPR]  : Endif
If !clalev([PP4])   : Local File PINVOICE   [PP4]   : Endif
If !clalev([PP5])   : Local File SINVOICE   [PP5]   : Endif
If !clalev([ZVDVS1])  : Local File YVDCLVAT1   [ZVDVS1]  : Endif
If !clalev([ZVDVS2])  : Local File YVDCLVAT2   [ZVDVS2]  : Endif

# JC 27/03/2020
If !clalev([F:PIL0]) Then : Local File BPSINVLIG [F:PIL0] : Endif
If !clalev([F:AXX0]) Then : Local File ATEXTRA   [F:AXX0] : Endif
If !clalev([F:SIL1]) Then : Local File BPCINVLIG [F:SIL1] : Endif
If !clalev([F:AXX1]) Then : Local File ATEXTRA   [F:AXX1] : Endif


For LINEA = 0 To [M:FAC2]NBLIG-1

  # Impuestos. Modificación 12/04/20; saco los datos directamente de la línea de la factura de tercero proveedor
  If 1=2
    Filter [ZVDVS1] Where [ZVDVS1]NUM = [M:FAC2]NUM(LINEA)
    Read [ZVDVS1] First
    If !fstat
      [M:FAC2]YNIMP1(LINEA) = [ZVDVS1]VAT
      [M:FAC2]YVIMP1(LINEA) = [ZVDVS1]AMTTAX
      Affzo [M:FAC2]YNIMP1(LINEA)
      Affzo [M:FAC2]YVIMP1(LINEA)
    Endif
    Filter [ZVDVS1]

    Filter [ZVDVS2] Where [ZVDVS2]NUM = [M:FAC2]NUM(LINEA)
    Read [ZVDVS2] First
    If !fstat
      [M:FAC2]YNIMP2(LINEA) = [ZVDVS2]VAT
      [M:FAC2]YVIMP2(LINEA) = [ZVDVS2]AMTTAX
      Affzo [M:FAC2]YNIMP2(LINEA)
      Affzo [M:FAC2]YVIMP2(LINEA)
    Endif
    Filter [ZVDVS2]
  Else
    For [F:PIL0] Where [F:PIL0]NUM = [M:FAC2]NUM(LINEA)
      If [F:PIL0]VAT <> ""
        If [M:FAC2]YNIMP1(LINEA) = ""
          [M:FAC2]YNIMP1(LINEA) = [F:PIL0]VAT
          [M:FAC2]YVIMP1(LINEA) = [F:PIL0]AMTVAT
        Elsif [M:FAC2]YNIMP2(LINEA) = ""
          [M:FAC2]YNIMP2(LINEA) = [F:PIL0]VAT
          [M:FAC2]YVIMP2(LINEA) = [F:PIL0]AMTVAT
        Elsif [M:FAC2]YNIMP3(LINEA) = ""
          [M:FAC2]YNIMP3(LINEA) = [F:PIL0]VAT
          [M:FAC2]YVIMP3(LINEA) = [F:PIL0]AMTVAT
        Endif
      Endif

      If [F:PIL0]TAX1 <> ""
        If [M:FAC2]YNIMP1(LINEA) = ""
          [M:FAC2]YNIMP1(LINEA) = [F:PIL0]TAX1
          [M:FAC2]YVIMP1(LINEA) = [F:PIL0]AMTTAX1
        Elsif [M:FAC2]YNIMP2(LINEA) = ""
          [M:FAC2]YNIMP2(LINEA) = [F:PIL0]TAX1
          [M:FAC2]YVIMP2(LINEA) = [F:PIL0]AMTTAX1
        Elsif [M:FAC2]YNIMP3(LINEA) = ""
          [M:FAC2]YNIMP3(LINEA) = [F:PIL0]TAX1
          [M:FAC2]YVIMP3(LINEA) = [F:PIL0]AMTTAX1
        Endif
      Endif

      If [F:PIL0]TAX2 <> ""
        If [M:FAC2]YNIMP1(LINEA) = ""
          [M:FAC2]YNIMP1(LINEA) = [F:PIL0]TAX2
          [M:FAC2]YVIMP1(LINEA) = [F:PIL0]AMTTAX2
        Elsif [M:FAC2]YNIMP2(LINEA) = ""
          [M:FAC2]YNIMP2(LINEA) = [F:PIL0]TAX2
          [M:FAC2]YVIMP2(LINEA) = [F:PIL0]AMTTAX2
        Elsif [M:FAC2]YNIMP3(LINEA) = ""
          [M:FAC2]YNIMP3(LINEA) = [F:PIL0]TAX2
          [M:FAC2]YVIMP3(LINEA) = [F:PIL0]AMTTAX2
        Endif
      Endif

      Affzo [M:FAC2]YNIMP1(LINEA)
      Affzo [M:FAC2]YVIMP1(LINEA)
      Affzo [M:FAC2]YNIMP2(LINEA)
      Affzo [M:FAC2]YVIMP2(LINEA)
      Affzo [M:FAC2]YNIMP3(LINEA)
      Affzo [M:FAC2]YVIMP3(LINEA)
    Next
  Endif


#  Filter [PP1] Where [PP1]NUM = [M:FAC2]NUM(LINEA)
#  Read [PP1]First
#  If fstat = 0
#    [M:FAC2]YNIMP1(LINEA) = [PP1]VACITM(0)
#    [M:FAC2]YNIMP2(LINEA) = [PP1]VACITM(1)
#    [M:FAC2]YNIMP3(LINEA) = [PP1]VACITM(2)
#    [M:FAC2]YVIMP1(LINEA) = [PP1]AMTTAXLIN(0)
#    [M:FAC2]YVIMP2(LINEA) = [PP1]AMTTAXLIN(1)
#    [M:FAC2]YVIMP3(LINEA) = [PP1]AMTTAXLIN(2)
#    [M:FAC2]YPJT(LINEA)   = [PP1]PJT
#    Affzo [M:FAC2]YNIMP1(LINEA)
#    Affzo [M:FAC2]YNIMP2(LINEA)
#    Affzo [M:FAC2]YNIMP3(LINEA)
#    Affzo [M:FAC2]YVIMP1(LINEA)
#    Affzo [M:FAC2]YVIMP2(LINEA)
#    Affzo [M:FAC2]YVIMP3(LINEA)
#    Affzo [M:FAC2]YPJT(LINEA)
#  Endif

  # Vencimientos
#  Filter [PP2] Where [PP2]NUM = [M:FAC2]NUM(LINEA)
#  Read [PP2] First
#  If fstat = 0
#    [M:FAC2]YFECVEN(LINEA) = [PP2]DUDDAT
#    Affzo [M:FAC2]YFECVEN(LINEA)
#  Endif
#  Filter [PP2]

  # Descripción del proyecto
  Read [PP3]AXX0 = "PIMPL";"PIMDESAX1";"SPA";[M:FAC2]YPJT(LINEA);""
  If fstat = 0
    [M:FAC2]YPJTDES(LINEA) = [PP3]TEXTE
    Affzo [M:FAC2]YPJTDES(LINEA)
  Endif

  # C.C. Contrapartida
  # 30/04/2020. Referenciales GR, IT, MOR, PT, SPA + grupo 2,6,7
  If 1=2 # Desactivo antes del 30/04
    Filter [ZDAE] Where [ZDAE]NUM = [M:FAC2]NUM(LINEA) and (left$([ZDAE]ACC,1)='6' or left$([ZDAE]ACC,1)='7') and [ZDAE]LED = 'SPA'
    Read [ZDAE] First
    If !fstat
      [M:FAC2]YCCONTRA(LINEA) = [ZDAE]ACC
    Endif
    Filter [ZDAE]
  Else # Activo modificación del 30/04
    Filter [ZDAE] Where [ZDAE]NUM = [M:FAC2]NUM(LINEA) and
&                       (left$([ZDAE]ACC,1)='2' or left$([ZDAE]ACC,1)='6' or left$([ZDAE]ACC,1)='7') and
&                       ([ZDAE]LED = 'SPA' or [ZDAE]LED = 'GR' or [ZDAE]LED = 'IT' or [ZDAE]LED = 'MOR' or [ZDAE]LED = 'PT')
    Read [ZDAE] First
    If !fstat
      [M:FAC2]YCCONTRA(LINEA) = [ZDAE]ACC
    Endif
    Filter [ZDAE]
  Endif



  # Razón Social - 06/02/2020 - MS
  Read [ZBPR]BPR0 = [M:FAC2]BPR(LINEA)
  If !fstat
    [M:FAC2]YBPRNAM(LINEA) = [ZBPR]BPRNAM
  Endif

  # Saco el importe AI de la factura de proveedor
  Read [PP4]PIH0 = [M:FAC2]NUM(LINEA)
  If fstat = 0
    [M:FAC2]YAMTNOTLIN(LINEA) = [PP4]AMTNOT
    Affzo [M:FAC2]YAMTNOTLIN(LINEA)
  Endif

  # JC 27/03/2020 - facturas tercero proveedor
  Filter [F:PIL0] Where NUM = [M:FAC2]NUM(LINEA)
  Read   [F:PIL0] First
  If !fstat Then
    [M:FAC2]YPJT(LINEA)       = [F:PIL0]PJTLIN
    Affzo [M:FAC2]YPJT(LINEA)
    Filter [F:AXX0] Where CODFIC = "PIMPL" and ZONE = "PIMDESAXX" and LANGUE = GLANGUE and IDENT1 = [F:PIL0]PJTLIN
    Read   [F:AXX0] First
    If !fstat Then
      [M:FAC2]YPJTDES(LINEA) = [F:AXX0]TEXTE
      Affzo [M:FAC2]YPJTDES(LINEA)
    Endif
    Filter [F:AXX0]
  Endif
  Filter [F:PIL0]


  # Saco el importe AI de la factura de cliente
  Read [PP5]SIH0 = [M:FAC2]NUM(LINEA)
  If fstat = 0
    [M:FAC2]YAMTNOTLIN(LINEA) = [PP5]AMTNOT
    Affzo [M:FAC2]YAMTNOTLIN(LINEA)
  Endif


  # JC 27/03/2020 - facturas tercero cliente
  Filter [F:SIL1] Where NUM = [M:FAC2]NUM(LINEA)
  Read   [F:SIL1] First
  If !fstat Then
    [M:FAC2]YPJT(LINEA)       = [F:SIL1]PJTLIN
    Affzo [M:FAC2]YPJT(LINEA)
    Filter [F:AXX1] Where CODFIC = "PIMPL" and ZONE = "PIMDESAXX" and LANGUE = GLANGUE and IDENT1 = [F:SIL1]PJTLIN
    Read   [F:AXX1] First
    If !fstat Then
      [M:FAC2]YPJTDES(LINEA) = [F:AXX1]TEXTE
      Affzo [M:FAC2]YPJTDES(LINEA)
    Endif
    Filter [F:AXX1]
  Endif
  Filter [F:SIL1]
Next

Close Local File [PP1],[PP2],[PP3],[PP4],[ZDAE],[ZBPR],[ZVDVS1],[ZVDVS2]

# JC 27/03/2020
If  clalev([F:SIL1]) Then : Close Local File     [F:SIL1] : Endif
If  clalev([F:AXX1]) Then : Close Local File     [F:AXX1] : Endif
If  clalev([F:SIL1]) Then : Close Local File     [F:SIL1] : Endif
If  clalev([F:AXX1]) Then : Close Local File     [F:AXX1] : Endif

Return

