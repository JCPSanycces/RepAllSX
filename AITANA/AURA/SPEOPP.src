#<AdxTL>@(#)0.0.0.0 $Revision$ Proyecto
# Gestión de la máscara OPP0 (Especifico)

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla OPP0) 09/09/2019 16:04:19 (AIT04)
######################################################################################
$ACTION
Case ACTION
 When "APRES_CRE" :   Gosub APRES_CRE
 When "APRES_MOD" :   Gosub APRES_MOD
Endcase
Return


######################################################################################
$APRES_CRE
# Guardo el campo del cliente grupo
Read [OPP]OPP0 = [M:OPP0]OPPNUM
If fstat = 0
  [OPP]YBPCGRUPO = [M:OPP0]YBPCGRUPO
  Rewrite [OPP]
Endif

Read [OPPCRM]OPPCRM0 = [M:OPP0]OPPNUM
If fstat = 0
  [OPPCRM]YBPCGRUPO = [M:OPP0]YBPCGRUPO
  Rewrite [OPPCRM]
Endif

# Busco si hay ya una sección para el proyecto introducido; sino lo hay, lo creo
Local Integer SIGO
If !clalev([P1]) : Local File CACCE  [P1]  :  Endif

Read [P1]CCE0 = "PRJ";[M:OPP0]OPPNUM
If fstat <> 0
  SIGO = 2
Endif

Close Local File [P1]

If SIGO = 2
  # Compongo fichero e importo para crear la sección
  Local Char YR,MH,DY,HH,MM,SS

  # Alimento las variables de las fechas
  YR = mid$(date$,1,4)
  MH = mid$(date$,5,2)
  DY = mid$(date$,7,2)
  HH = mid$(time$,1,2)
  MM = mid$(time$,4,2)
  SS = mid$(time$,7,2)

  Local Char PFILE (200) : PFILE = "E:\Sage\SAGEEMAURA\folders\PROTO\YIE\SECCIONES\"+ [M:OPP0]OPPNUM + "_"+YR+MH+DY+HH+MM+SS+ ".txt"
  Local Char LTRK : LTRK = "no read"
  Local Integer PRTN

  Gosub OPEN_FILE
  Gosub WRT_CAB_COM
  Gosub CLOSE_FILE

  Call IMP_MODEL(LTRK,"CCE",PFILE,PRTN)
  If PRTN = 0 Then
    Infbox "La sección analítica " + [M:OPP0]OPPNUM + " ha sido creada con éxito"
  Else
    Errbox "Problemas en la creación de la sección analítica " + [M:OPP0]OPPNUM
  Endif
Endif
Return


########################################################
$APRES_MOD
# Guardo el campo del cliente grupo
Read [OPP]OPP0 = [M:OPP0]OPPNUM
If fstat = 0
  [OPP]YBPCGRUPO = [M:OPP0]YBPCGRUPO
  Rewrite [OPP]
Endif

Read [OPPCRM]OPPCRM0 = [M:OPP0]OPPNUM
If fstat = 0
  [OPPCRM]YBPCGRUPO = [M:OPP0]YBPCGRUPO
  Rewrite [OPPCRM]
Endif

Return



########################################################
$OPEN_FILE
adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo PFILE
Return


########################################
$WRT_CAB_COM

#####
# Función que se encarga de escribir a fichero los datos de la cabecera
#####
# PDATCAB
#####
# 1 -> Planta
# 2 -> Tipo factura
# 3 -> Asiento
# 4 -> Fecha
# 5 -> Terceros
# 6 -> Colectivo
# 7 -> Divisa
# 8 -> Autoriz. Pago
# 9 -> Documento
# 10 -> Fecha Origen
# 11 -> Código Interno
# 12 -> Comentarios 1
# 13 -> Comentarios 2
# 14 -> Comentarios 3

Wrseq 'PRJ',
& [M:OPP0]OPPNUM ,
& [M:OPP0]OPPDESAXX ,
& right$([M:OPP0]OPPDESAXX,10),
& '',
& '',
& '',
& '',
& '',
& '2',
& '1',
& '',
& '0',
& '',
& '0',
& '',
& '0',
& '',
& '0',
& '',
& '0',
& '',
& '0',
& '',
& '0',
& '',
& '',
& '',
& '',
& ';'

Return


#############################################
Subprog IMP_MODEL(PTRA,PMOD,PFILE,PRTN)
Value Char PTRA
Value Char PMOD
Value Char PFILE
Variable Integer PRTN

#####
# Proceso encargado de integrar un registro a traves de un modelo de datos..
#####
# PTRA  = indica si hay lectura de traza "read".- lee traza, "no read".- no lee traza
# PMOD  = modelo a tratar
# PFILE = el fichero a importar..

Local File AOBJEXT    [AOE]
Local File AOBJEXTD   [AOD]
Local File AOBJET     [ZAOB]
Local File ADOVAL     [ADW]
Local File ATYPE      [ZATY]
Local File AMSK       [ZAMK]
Local File AMSKZON    [ZAMZ]
Local File ATABLE     [ZATB]
Local File ATABZON    [ZATZ]
Local File ATABIND    [ZATI]
Local File AFONCTION  [ZAFC]
Local File APARIMPEXP [APX]
Local Mask AOE0       [AOE0]
Local Mask AOE1       [AOE1]
Local Mask AOE2       [AOE2]
Local Mask IMPTEST    [IEX]
Local Mask IMPENCH    [DIA]
Local Mask IMPOBJ2    [IMP2]


PRTN = 0
mkstat = 0 : fstat = 0 : GERRTRACE = 0
# Lanzamiento de la importación silenciosa
Call OUVRE_TRACE("Importación estandar") From LECFIC
Call IMPORTSIL(PMOD,PFILE) From GIMPOBJ
Call FERME_TRACE From LECFIC

If (fstat <> 0 and fstat <> 4) or GERRTRACE <> 0 : PRTN = 1 : Endif
If PTRA = "read" Then
    Call LEC_TRACE From LECFIC
Endif

mkstat = 0 : fstat = 0 : GERRTRACE = 0

Close Local File [AOE],[AOD],[ZAOB],[ADW],[ZATY],[ZAMK],[ZAMZ],[ZATB],[ZATZ],[ZATI],[ZAFC],[APX]
Close Local Mask [AOE0],[AOE1],[AOE2],[IEX],[DIA],[IMP2]

End


########################################################
$CLOSE_FILE
Openo
Return


######################################################################################
Subprog C_OPPNUM(VALEUR)
Variable Char    VALEUR()
# Obligo a poner valor y tamańo inferior a 10 caracteres
If VALEUR = ""
  Errbox "Debe introducir el código del proyecto"
  mkstat = 2
Elsif len(VALEUR)>10
  Errbox "El tamańo del código del proyecto no puede ser superior a 10 caracteres"
  mkstat = 2
Endif
End


######################################################################################
Subprog AS_OPPCMP(VALEUR)
Variable Char    VALEUR()
# Si tengo cliente grupo no permito entrada
If [M:OPP0]YBPCGRUPO <> ""
  mkstat = 2
Endif
End


######################################################################################
Subprog AM_OPPCMP(VALEUR)
Variable Char    VALEUR()
# Si pongo valor verifico que no hay cliente grupo
If VALEUR <> ""
  [M:OPP0]YBPCGRUPO = ""
  Affzo [M:OPP0]YBPCGRUPO
Endif
End


######################################################################################
Subprog AS_YBPCGRUPO(VALEUR)
Variable Char    VALEUR()
# Si tengo tercero no permito entrada
If [M:OPP0]OPPCMP <> ""
  mkstat = 2
Endif
End


######################################################################################
Subprog C_YBPCGRUPO(VALEUR)
Variable Char    VALEUR()
# Controlo que el cliente introducido sea un grupo
If VALEUR <> ""
  Read [BPC]BPC0 = VALEUR
  If fstat  = 0
    If [BPC]BCGCOD <> 'GRUPO'
      Errbox "El cliente " + [BPC]BPCNAM + " no es un cliente GRUPO"
      mkstat = 2
    Endif
  Endif
Endif
End


######################################################################################
Subprog AM_YBPCGRUPO(VALEUR)
Variable Char    VALEUR()
# Si pongo valor verifico que no hay tercero
If VALEUR <> ""
  [M:OPP0]OPPCMP = ""
  Affzo [M:OPP0]OPPCMP
Endif
End


######################################################################################
Subprog S_YBPCGRUPO(VALEUR)
Variable Char    VALEUR()
# Solamente permito selección de clientes grupo
Filter [BPC] Where [BPC]BCGCOD = 'GRUPO'
  Call SELECT("BPC","",VALEUR,"") From SELOBJ
Filter [BPC]
End




