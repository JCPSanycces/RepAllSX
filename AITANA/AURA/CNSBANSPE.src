#<AdxTL>@(#)0.0.0.0 $Revision$
# 10/02/2020 - MS - Consulta de Bancos
$ACTION
Case ACTION
  When "AV_AFFICHE" : Gosub AV_AFFICHE
Endcase
Return

############################################
$AV_AFFICHE

Local Integer LINEA

If !clalev([ZBPR])   : Local File BPARTNER   [ZBPR]   : Endif
If !clalev([ZBANK])  : Local File BANK       [ZBANK]  : Endif

For LINEA = 0 To [M:CBA2]NBLIG-1

 # Detalle Tarjeta
 Read [ZBANK]BAN0 = [M:CBA1]BAN
 If !fstat
  [M:CBA2]YDETTJ(LINEA) = [ZBANK]DES
 Endif

 # Detalle Tarjeta
 Read [ZBPR]BPR0 = [M:CBA2]BPR(LINEA)
 If !fstat
   [M:CBA2]YBPRNAM(LINEA) = [ZBPR]BPRSHO
 Endif

Next

Close Local File [ZBPR],[ZBANK]

Return

