#<AdxTL>@(#)0.0.0.0 $Revision$ 
#####################################################################################
# Src: SPEYCG
#-------------------------------------------------------------------------------------
# Proyecto: Estándar
#-------------------------------------------------------------------------------------
# Version: v12
#-------------------------------------------------------------------------------------
# AU02 - Consulta estadísticas por proyecto
# Fecha inicio AU02: 30/09/2019
# Desarrollador: JCH
# Código de desarrollo: AU02
# Descripción del desarrollo: Consulta estadísticas de gastos por proyecto
# Fecha: 30/09/2019
# Codigo Actividad: YP12
#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "DEBUT"      : Gosub DEBUT
  When "BOUTON"     : Gosub BOUTON
  When "FIN"        : Gosub FIN
  When "SEL_TABLE"  : Gosub SEL_TABLE
  When "VERF_TABLE" : Gosub VERF_TABLE
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
  Gosub ABRIR_TABLAS
Return

##############################################################
$DEBUT
  Affzo [M:YCG0]15
Return

##############################################################
$BOUTON
  Case BOUT
    When "Z"  : Gosub BUSCAR
  Endcase
Return

##############################################################
$FIN
  Gosub CERRAR_TABLAS
Return

##############################################################
$SEL_TABLE
  Case TABLE
    When "YSELCGPJT"  : Gosub SEL_YSELCGPJT
  Endcase
Return

##############################################################
$VERF_TABLE
  Case TABLE
    When "YSELCGPJT"  : Gosub VERF_YSELCGPJT
  Endcase
Return

##############################################################
$SEL_YSELCGPJT
  Default File [OPP0]
  Link [AXX0] With [OPP0]OPP0=[F:AXX0]IDENT1 As [LNK0] Where CODFIC="PIMPL" and ZONE = "PIMDESAXX" and LANGUE=GLANGUE
  Columns [LNK0] ([OPP0]OPPNUM,[AXX0]TEXTE,[OPP0]OPPTYP)
  Default File [LNK0]
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Proyectos"                                                     # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Código"                                                        # título de la segunda columna
  COL(NBCOL)  = "[OPP0]OPPNUM"                                                  # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la segunda columna
  COL(NBCOL)  = "[AXX0]TEXTE"                                                   # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Categoría"                                                     # título de la segunda columna
  COL(NBCOL)  = "[OPP0]OPPTYP"                                                  # nombre del campo a mostrar en la segunda columna
Return

##############################################################
$VERF_YSELCGPJT
  [M:YCG0]CATEGORIAI = [F:OPP0]OPPTYP
  [M:YCG0]CATEGORIAF = [F:OPP0]OPPTYP
  Affzo [M:YCG0]CATEGORIAI, CATEGORIAF
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ABRIR_TABLAS
  If !clalev([F:OPP0]) Then : Local File OPPOR    [F:OPP0] : Endif
  If !clalev([F:AXX0]) Then : Local File ATEXTRA  [F:AXX0] : Endif
Return

##############################################################
$CERRAR_TABLAS
Return

##############################################################
$BUSCAR
  Raz [M:YCG1]
  If [M:YCG0]REFACFLG = 2 Then
    Gosub BUSCAR_REFACTURACION
    Gosub NEW_ZONES  # 16/03/2020
  Endif
  If [M:YCG0]RENTAFLG = 2 Then
    Gosub BUSCAR_RENTABILIDAD
    Gosub NEW_ZONES  # 16/03/2020
  Endif
  Gosub COLOREAR
  Gosub CALCULA_TOTALES
Return

##############################################################
$BUSCAR_REFACTURACION
Local Char LUNION0(15) : LUNION0 = " UNION ALL "
Local Char CRITSQL0(250)(0..56)   : Raz CRITSQL0
Local Integer LCON0 : Raz LCON0

  # facturas proveedor
  CRITSQL0(0)  = "SELECT OP0.OPPNUM_0 AS NUMPROY, AX0.TEXTE_0 AS DESPROY, AX00.TEXTE_0 AS CATEGORIA, PIH.ACCDAT_0 AS FECHA, PID.NUM_0 AS NUMINT, "
  CRITSQL0(0) += "PIH.BPRVCR_0 AS NUMDOC, PIH.BPRNAM_0 AS CONTRAP, PID.ITMDES_0 AS CONCEPTO, "
  CRITSQL0(1)  = "CASE PID.YTIPO_0 WHEN 1 THEN 'FACTURA' WHEN 2 THEN 'TICKET' END AS TOF, "
  CRITSQL0(1) += "CASE PID.YREFACTURA_0 WHEN 1 THEN 'NO' WHEN 2 THEN 'SÍ' END AS IMPUTABLE, "
  CRITSQL0(2)  = "PID.AMTNOTLIN_0 AS BASE, (PID.AMTNOTLIN_0 * TR0.VATRAT_0) / 100 AS IVA, "
  CRITSQL0(2) += "PID.AMTNOTLIN_0 + ((PID.AMTNOTLIN_0 * TR0.VATRAT_0) / 100) AS TOTAL, '' AS COMENTARIOS, 'FP' AS TIPODOC "
  CRITSQL0(3)  = "FROM "+nomap+".TABRATVAT AS TR0 "
  CRITSQL0(4)  = "INNER JOIN "+nomap+".PINVOICED AS PID ON TR0.VAT_0 = PID.VAT_0 "
  CRITSQL0(5)  = "INNER JOIN "+nomap+".PINVOICE AS PIH ON PID.NUM_0 = PIH.NUM_0 "
  CRITSQL0(6)  = "INNER JOIN "+nomap+".OPPOR AS OP0 "
  CRITSQL0(7)  = "INNER JOIN "+nomap+".ATEXTRA AS AX0 ON OP0.OPPNUM_0 = AX0.IDENT1_0 AND AX0.CODFIC_0 = 'PIMPL' AND AX0.ZONE_0 = 'PIMDESAXX' AND "
  CRITSQL0(7) += "AX0.LANGUE_0 = '"+GLANGUE+"' ON PID.PJT_0 = OP0.OPPNUM_0 "
  CRITSQL0(8)  = "LEFT OUTER JOIN "+nomap+".ATEXTRA AS AX00 ON OP0.OPPTYP_0 = AX00.IDENT2_0 AND AX00.IDENT1_0 = '434' "
  CRITSQL0(8) += "AND AX00.CODFIC_0 = 'ATABDIV' AND AX00.ZONE_0 = 'LNGDES' AND AX00.LANGUE_0 = '"+GLANGUE+"' "
  CRITSQL0(9)  = "WHERE NOT EXISTS(SELECT * FROM "+nomap+".TABRATVAT AS HIGH0 WHERE HIGH0.VAT_0 = TR0.VAT_0 AND HIGH0.STRDAT_0 > TR0.STRDAT_0) "
  CRITSQL0(9) += "AND PIH.STA_0 = 3 "
  If [M:YCG0]PLANTAI    <> ""           Then : CRITSQL0(10)  = "AND OP0.SALFCY_0 >= '"  +[M:YCG0]PLANTAI+     "' " : Endif
  If [M:YCG0]PLANTAF    <> ""           Then : CRITSQL0(11)  = "AND OP0.SALFCY_0 <= '"  +[M:YCG0]PLANTAF+     "' " : Endif
  If [M:YCG0]PROYECTO   <> ""           Then : CRITSQL0(12)  = "AND OP0.OPPNUM_0 =  '"  +[M:YCG0]PROYECTO+    "' " : Endif
  If [M:YCG0]CATEGORIAI <> ""           Then : CRITSQL0(13)  = "AND OP0.OPPTYP_0 >= '"  +[M:YCG0]CATEGORIAI+  "' " : Endif
  If [M:YCG0]CATEGORIAF <> ""           Then : CRITSQL0(14)  = "AND OP0.OPPTYP_0 <= '"  +[M:YCG0]CATEGORIAF+  "' " : Endif
  If [M:YCG0]FECHAI     <> [00/00/0000] Then : CRITSQL0(15)  = "AND PIH.ACCDAT_0 >= '"  +[M:YCG0]FECHAI+      "' " : Endif
  If [M:YCG0]FECHAF     <> [00/00/0000] Then : CRITSQL0(16)  = "AND PIH.ACCDAT_0 <= '"  +[M:YCG0]FECHAF+      "' " : Endif
  Case [M:YCG0]REFACTURABLE
    When 2 : CRITSQL0(17) = "AND PID.YREFACTURA_0 = 2 "      # refacturable
    When 3 : CRITSQL0(17) = "AND PID.YREFACTURA_0 = 1 "      # no refacturable
  Endcase

  CRITSQL0(18) = LUNION0

  # facturas terceros proveedor
   CRITSQL0(19)  = "SELECT OP2.OPPNUM_0 AS NUMPROY, AX2.TEXTE_0 AS DESPROY, AX22.TEXTE_0 AS CATEGORIA, PI1.ACCDAT_0 AS FECHA, PIL.NUM_0 AS NUMINT, "
#  CRITSQL0(19)  = "SELECT ISNULL(OP2.OPPNUM_0,'_') AS NUMPROY, AX2.TEXTE_0 AS DESPROY, AX22.TEXTE_0 AS CATEGORIA, PI1.ACCDAT_0 AS FECHA, PIL.NUM_0 AS NUMINT, "
  CRITSQL0(19) += "PI1.BPRVCR_0 AS NUMDOC, PI1.BPRNAM_0 AS CONTRAP, '' AS CONCEPTO, "
  CRITSQL0(20)  = "CASE PIL.YTIPO_0 WHEN 1 THEN 'FACTURA' WHEN 2 THEN 'TICKET' END AS TOF, "
  CRITSQL0(20) += "CASE PIL.YREFACTURA_0 WHEN 1 THEN 'NO' WHEN 2 THEN 'SÍ' END AS IMPUTABLE, "
  CRITSQL0(21)  = "PIL.AMTNOTLIN_0 AS BASE, (PIL.AMTNOTLIN_0 * TR2.VATRAT_0) / 100 AS IVA, "
  CRITSQL0(21) += "PIL.AMTNOTLIN_0 + ((PIL.AMTNOTLIN_0 * TR2.VATRAT_0) / 100) AS TOTAL, PIL.DES_0 AS COMENTARIOS, 'FTP' AS TIPODOC "
  CRITSQL0(22)  = "FROM "+nomap+".ATEXTRA AS AX2 "
  CRITSQL0(23)  = "INNER JOIN "+nomap+".OPPOR AS OP2 ON AX2.IDENT1_0 = OP2.OPPNUM_0 "
  # CRITSQL0(24)  = "INNER JOIN "+nomap+".BPSINVLIG AS PIL ON AX2.CODFIC_0 = 'PIMPL' AND AX2.ZONE_0 = 'PIMDESAXX' AND AX2.LANGUE_0 = '"+GLANGUE+"' "
  CRITSQL0(24)  = "RIGHT JOIN "+nomap+".BPSINVLIG AS PIL ON AX2.CODFIC_0 = 'PIMPL' AND AX2.ZONE_0 = 'PIMDESAXX' AND AX2.LANGUE_0 = '"+GLANGUE+"' "
  CRITSQL0(24) += "AND OP2.OPPNUM_0 = PIL.PJTLIN_0 "
  CRITSQL0(25)  = "INNER JOIN "+nomap+".PINVOICE AS PI1 ON PIL.NUM_0 = PI1.NUM_0 AND PIL.CPYLIN_0 = PI1.CPY_0 AND PIL.FCYLIN_0 = PI1.FCY_0 "
  CRITSQL0(26)  = "INNER JOIN "+nomap+".TABRATVAT AS TR2 ON PIL.VAT_0 = TR2.VAT_0 "
  CRITSQL0(27)  = "LEFT OUTER JOIN "+nomap+".ATEXTRA AS AX22 ON OP2.OPPTYP_0 = AX22.IDENT2_0 AND AX22.IDENT1_0 = '434' "
  CRITSQL0(27) += "AND AX22.CODFIC_0 = 'ATABDIV' AND AX22.ZONE_0 = 'LNGDES' AND AX22.LANGUE_0 = '"+GLANGUE+"' "
  CRITSQL0(28)  = "WHERE NOT EXISTS(SELECT * FROM "+nomap+".TABRATVAT AS HIGH2 WHERE HIGH2.VAT_0 = TR2.VAT_0 AND HIGH2.STRDAT_0 > TR2.STRDAT_0) "
  CRITSQL0(28) += "AND PI1.STA_0 = 3 "
#  If [M:YCG0]PLANTAI    <> ""           Then : CRITSQL0(29)  = "AND OP2.SALFCY_0 >= '"  +[M:YCG0]PLANTAI+     "' " : Endif
#  If [M:YCG0]PLANTAF    <> ""           Then : CRITSQL0(30)  = "AND OP2.SALFCY_0 <= '"  +[M:YCG0]PLANTAF+     "' " : Endif
  If [M:YCG0]PLANTAI    <> ""           Then : CRITSQL0(29)  = "AND PI1.FCY_0 >= '"  +[M:YCG0]PLANTAI+     "' " : Endif
  If [M:YCG0]PLANTAF    <> ""           Then : CRITSQL0(30)  = "AND PI1.FCY_0 <= '"  +[M:YCG0]PLANTAF+     "' " : Endif
  If [M:YCG0]PROYECTO   <> ""           Then : CRITSQL0(31)  = "AND OP2.OPPNUM_0 =  '"  +[M:YCG0]PROYECTO+    "' " : Endif
  If [M:YCG0]CATEGORIAI <> ""           Then : CRITSQL0(32)  = "AND OP2.OPPTYP_0 >= '"  +[M:YCG0]CATEGORIAI+  "' " : Endif
  If [M:YCG0]CATEGORIAF <> ""           Then : CRITSQL0(33)  = "AND OP2.OPPTYP_0 <= '"  +[M:YCG0]CATEGORIAF+  "' " : Endif
  If [M:YCG0]FECHAI     <> [00/00/0000] Then : CRITSQL0(34)  = "AND PI1.ACCDAT_0 >= '"  +[M:YCG0]FECHAI+      "' " : Endif
  If [M:YCG0]FECHAF     <> [00/00/0000] Then : CRITSQL0(35)  = "AND PI1.ACCDAT_0 <= '"  +[M:YCG0]FECHAF+      "' " : Endif
  Case [M:YCG0]REFACTURABLE
    When 2 : CRITSQL0(36) = "AND PIL.YREFACTURA_0 = 2 "      # refacturable
    When 3 : CRITSQL0(36) = "AND PIL.YREFACTURA_0 = 1 "      # no refacturable
  Endcase

  CRITSQL0(37) = LUNION0

  # pedidos proveedor
  CRITSQL0(38)  = "SELECT OP1.OPPNUM_0 AS NUMPROY, AX1.TEXTE_0 AS DESPROY, AX11.TEXTE_0 AS CATEGORIA, POQ.ORDDAT_0 AS FECHA, POQ.POHNUM_0 AS NUMINT, "
  CRITSQL0(38) += "POH.ORDREF_0 AS NUMDOC, POH.BPRNAM_0 AS CONTRAP, POP.ITMDES_0 AS CONCEPTO, "
  CRITSQL0(39)  = "CASE POQ.YTIPO_0 WHEN 1 THEN 'FACTURA' WHEN 2 THEN 'TICKET' END AS TOF, "
  CRITSQL0(39) += "CASE POQ.YREFACTURA_0 WHEN 1 THEN 'NO' WHEN 2 THEN 'SÍ' END AS IMPUTABLE, "
  CRITSQL0(40)  = "POQ.LINAMT_0 AS BASE, (POQ.LINAMT_0 * TR1.VATRAT_0) / 100 AS IVA, POQ.LINAMT_0 + ((POQ.LINAMT_0 * TR1.VATRAT_0) / 100) AS TOTAL, "
  CRITSQL0(40) += "'' AS COMENTARIOS, 'PP' AS TIPODOC "
  CRITSQL0(41)  = "FROM "+nomap+".PORDERP AS POP "
  CRITSQL0(42)  = "INNER JOIN "+nomap+".OPPOR AS OP1 ON POP.PJT_0 = OP1.OPPNUM_0 "
  CRITSQL0(43)  = "INNER JOIN "+nomap+".ATEXTRA AS AX1 ON OP1.OPPNUM_0 = AX1.IDENT1_0 AND AX1.CODFIC_0 = 'PIMPL' "
  CRITSQL0(43) += "AND AX1.ZONE_0 = 'PIMDESAXX' AND AX1.LANGUE_0 = '"+GLANGUE+"' "
  CRITSQL0(44)  = "INNER JOIN "+nomap+".PORDERQ AS POQ ON POP.POHNUM_0 = POQ.POHNUM_0 AND POP.POPLIN_0 = POQ.POPLIN_0 "
  CRITSQL0(45)  = "INNER JOIN "+nomap+".PORDER AS POH ON POP.POHNUM_0 = POH.POHNUM_0 AND POP.CPY_0 = POH.CPY_0 "
  CRITSQL0(46)  = "INNER JOIN "+nomap+".TABRATVAT AS TR1 ON POP.VAT_0 = TR1.VAT_0 "
  CRITSQL0(47)  = "LEFT OUTER JOIN "+nomap+".ATEXTRA AS AX11 ON OP1.OPPTYP_0 = AX11.IDENT2_0 AND AX11.IDENT1_0 = '434' "
  CRITSQL0(47) += "AND AX11.CODFIC_0 = 'ATABDIV' AND AX11.ZONE_0 = 'LNGDES' AND AX11.LANGUE_0 = '"+GLANGUE+"' "
  CRITSQL0(48)  = "WHERE NOT EXISTS(SELECT * FROM "+nomap+".TABRATVAT AS HIGH1 WHERE HIGH1.VAT_0 = TR1.VAT_0 AND HIGH1.STRDAT_0 > TR1.STRDAT_0) "
  If [M:YCG0]PLANTAI    <> ""           Then : CRITSQL0(49)  = "AND OP1.SALFCY_0 >= '"  +[M:YCG0]PLANTAI+     "' " : Endif
  If [M:YCG0]PLANTAF    <> ""           Then : CRITSQL0(50)  = "AND OP1.SALFCY_0 <= '"  +[M:YCG0]PLANTAF+     "' " : Endif
  If [M:YCG0]PROYECTO   <> ""           Then : CRITSQL0(51)  = "AND OP1.OPPNUM_0 =  '"  +[M:YCG0]PROYECTO+    "' " : Endif
  If [M:YCG0]CATEGORIAI <> ""           Then : CRITSQL0(52)  = "AND OP1.OPPTYP_0 >= '"  +[M:YCG0]CATEGORIAI+  "' " : Endif
  If [M:YCG0]CATEGORIAF <> ""           Then : CRITSQL0(53)  = "AND OP1.OPPTYP_0 <= '"  +[M:YCG0]CATEGORIAF+  "' " : Endif
  If [M:YCG0]FECHAI     <> [00/00/0000] Then : CRITSQL0(54)  = "AND POH.ORDDAT_0 >= '"  +[M:YCG0]FECHAI+      "' " : Endif
  If [M:YCG0]FECHAF     <> [00/00/0000] Then : CRITSQL0(55)  = "AND POH.ORDDAT_0 <= '"  +[M:YCG0]FECHAF+      "' " : Endif
  Case [M:YCG0]REFACTURABLE
    When 2 : CRITSQL0(56) = "AND POQ.YREFACTURA_0 = 2 "      # refacturable
    When 3 : CRITSQL0(56) = "AND POQ.YREFACTURA_0 = 1 "      # no refacturable
  Endcase

  # busca facturas proveedor, facturas tercero proveedor y pedidos proveedor
  If [M:YCG0]MUESTRAPOH = 2 Then
    For (Char NUMPROY,Char DESPROY,Char CATEGORIA,Date FECHA,Char NUMINT,Char NUMDOC,Char CONTRAP,Char CONCEPTO,Char TOF,Char IMPUTABLE,
&   Decimal BASE, Decimal IVA, Decimal TOTAL, Char COMENTARIOS, Char TIPODOC) From "5" Sql CRITSQL0(0..56) As [Y00]
      [M:YCG1]LNUMPROY(LCON0)     = [F:Y00]NUMPROY
      [M:YCG1]LDESPROY(LCON0)     = [F:Y00]DESPROY
      [M:YCG1]LCATEGORIA(LCON0)   = [F:Y00]CATEGORIA
      [M:YCG1]LFECHA(LCON0)       = [F:Y00]FECHA
      [M:YCG1]LNUMINT(LCON0)      = [F:Y00]NUMINT
      [M:YCG1]LNUMDOC(LCON0)      = [F:Y00]NUMDOC
      [M:YCG1]LCONTRAP(LCON0)     = [F:Y00]CONTRAP
      [M:YCG1]LCONCEPTO(LCON0)    = [F:Y00]CONCEPTO
      [M:YCG1]LTOF(LCON0)         = [F:Y00]TOF
      [M:YCG1]LIMPUTABLE(LCON0)   = [F:Y00]IMPUTABLE
      [M:YCG1]LBASE(LCON0)        = [F:Y00]BASE
      [M:YCG1]LIVA(LCON0)         = [F:Y00]IVA
      [M:YCG1]LTOTAL(LCON0)       = [F:Y00]TOTAL
      [M:YCG1]LCOMENTARIOS(LCON0) = [F:Y00]COMENTARIOS
      [M:YCG1]LTIPODOC(LCON0)     = [F:Y00]TIPODOC
      LCON0 += 1
    Next
  # busca factuas proveedor y facturas tercero proveedor
  Else
    For (Char NUMPROY,Char DESPROY,Char CATEGORIA,Date FECHA,Char NUMINT,Char NUMDOC,Char CONTRAP,Char CONCEPTO,Char TOF,Char IMPUTABLE,
&   Decimal BASE, Decimal IVA, Decimal TOTAL, Char COMENTARIOS, Char TIPODOC) From "5" Sql CRITSQL0(0..36) As [Y00]
      [M:YCG1]LNUMPROY(LCON0)     = [F:Y00]NUMPROY
      [M:YCG1]LDESPROY(LCON0)     = [F:Y00]DESPROY
      [M:YCG1]LCATEGORIA(LCON0)   = [F:Y00]CATEGORIA
      [M:YCG1]LFECHA(LCON0)       = [F:Y00]FECHA
      [M:YCG1]LNUMINT(LCON0)      = [F:Y00]NUMINT
      [M:YCG1]LNUMDOC(LCON0)      = [F:Y00]NUMDOC
      [M:YCG1]LCONTRAP(LCON0)     = [F:Y00]CONTRAP
      [M:YCG1]LCONCEPTO(LCON0)    = [F:Y00]CONCEPTO
      [M:YCG1]LTOF(LCON0)         = [F:Y00]TOF
      [M:YCG1]LIMPUTABLE(LCON0)   = [F:Y00]IMPUTABLE
      [M:YCG1]LBASE(LCON0)        = [F:Y00]BASE
      [M:YCG1]LIVA(LCON0)         = [F:Y00]IVA
      [M:YCG1]LTOTAL(LCON0)       = [F:Y00]TOTAL
      [M:YCG1]LCOMENTARIOS(LCON0) = [F:Y00]COMENTARIOS
      [M:YCG1]LTIPODOC(LCON0)     = [F:Y00]TIPODOC
      LCON0 += 1
    Next
  Endif

  [M:YCG1]PIE_P = LCON0
  Affzo [M:YCG1]5

Return

##############################################################
$BUSCAR_RENTABILIDAD
Local Char LUNION1(15) : LUNION1 = " UNION ALL "
Local Char CRITSQL1(250)(0..59)   : Raz CRITSQL1
Local Integer LCON1 : Raz LCON1

  # facturas cliente
  CRITSQL1(0)    = "SELECT OP0.OPPNUM_0 AS NUMPROY, AX0.TEXTE_0 AS DESPROY, AX00.TEXTE_0 AS CATEGORIA, SI0.ACCDAT_0 AS FECHA, "
  CRITSQL1(0)   += "SD0.NUM_0 AS NUMINT, SI0.BPRVCR_0 AS NUMDOC, SI0.BPRNAM_0 AS CONTRAP, SUM(SD0.AMTNOTLIN_0) AS BASE, 'FC' AS TIPODOC  "
  CRITSQL1(1)    = "FROM "+nomap+".OPPOR AS OP0 "
  CRITSQL1(2)    = "INNER JOIN "+nomap+".SINVOICED AS SD0 ON OP0.OPPNUM_0 = SD0.PJT_0 "
  CRITSQL1(3)    = "INNER JOIN "+nomap+".ATEXTRA AS AX0 ON OP0.OPPNUM_0 = AX0.IDENT1_0 AND AX0.CODFIC_0 = 'PIMPL' AND AX0.ZONE_0 = 'PIMDESAXX' "
  CRITSQL1(3)   += "AND AX0.LANGUE_0 = '"+GLANGUE+"' "
  CRITSQL1(4)    = "INNER JOIN "+nomap+".SINVOICE AS SI0 ON SD0.NUM_0 = SI0.NUM_0 AND SD0.CPY_0 = SI0.CPY_0 "
  CRITSQL1(5)    = "LEFT OUTER JOIN "+nomap+".ATEXTRA AS AX00 ON OP0.OPPTYP_0 = AX00.IDENT2_0 AND AX00.IDENT1_0 = '434' "
  CRITSQL1(6)   += "AND AX00.CODFIC_0 = 'ATABDIV' AND AX00.ZONE_0 = 'LNGDES' AND AX00.LANGUE_0 = '"+GLANGUE+"' "
  CRITSQL1(7)    = "GROUP BY OP0.OPPNUM_0,AX0.TEXTE_0,AX00.TEXTE_0,SI0.ACCDAT_0,SD0.NUM_0,SI0.BPRVCR_0,SI0.BPRNAM_0,SI0.STA_0,"
  CRITSQL1(7)   += "OP0.SALFCY_0,OP0.OPPNUM_0,OP0.OPPTYP_0,SI0.ACCDAT_0 "
  CRITSQL1(7)   += "HAVING SI0.STA_0 = 3 "
  If [M:YCG0]PLANTAI    <> ""           Then : CRITSQL1(8)   = "AND OP0.SALFCY_0 >= '"  +[M:YCG0]PLANTAI+     "' " : Endif
  If [M:YCG0]PLANTAF    <> ""           Then : CRITSQL1(9)   = "AND OP0.SALFCY_0 <= '"  +[M:YCG0]PLANTAF+     "' " : Endif
  If [M:YCG0]PROYECTO   <> ""           Then : CRITSQL1(10)  = "AND OP0.OPPNUM_0 =  '"  +[M:YCG0]PROYECTO+    "' " : Endif
  If [M:YCG0]CATEGORIAI <> ""           Then : CRITSQL1(11)  = "AND OP0.OPPTYP_0 >= '"  +[M:YCG0]CATEGORIAI+  "' " : Endif
  If [M:YCG0]CATEGORIAF <> ""           Then : CRITSQL1(12)  = "AND OP0.OPPTYP_0 <= '"  +[M:YCG0]CATEGORIAF+  "' " : Endif
  If [M:YCG0]FECHAI     <> [00/00/0000] Then : CRITSQL1(13)  = "AND SI0.ACCDAT_0 >= '"  +[M:YCG0]FECHAI+      "' " : Endif
  If [M:YCG0]FECHAF     <> [00/00/0000] Then : CRITSQL1(14)  = "AND SI0.ACCDAT_0 <= '"  +[M:YCG0]FECHAF+      "' " : Endif

  CRITSQL1(15)   = LUNION1

  # facturas terceros clientes
  CRITSQL1(16)   = "SELECT OP1.OPPNUM_0 AS NUMPROY, AX1.TEXTE_0 AS DESPROY, AX11.TEXTE_0 AS CATEGORIA, SI1.ACCDAT_0 AS FECHA, "
  CRITSQL1(16)  += "BI1.NUM_0 AS NUMINT, SI1.BPRVCR_0 AS NUMDOC, SI1.BPRNAM_0 AS CONTRAP, SUM(BI1.AMTNOTLIN_0) AS BASE, 'FTC' AS TIPODOC  "
  CRITSQL1(17)   = "FROM "+nomap+".ATEXTRA AS AX1 "
  CRITSQL1(18)   = "INNER JOIN "+nomap+".OPPOR AS OP1 ON AX1.IDENT1_0 = OP1.OPPNUM_0 AND AX1.CODFIC_0 = 'PIMPL' "
  CRITSQL1(18)  += "AND AX1.ZONE_0 = 'PIMDESAXX' AND AX1.LANGUE_0 = '"+GLANGUE+"' "
  CRITSQL1(19)   = "INNER JOIN "+nomap+".ATEXTRA AS AX11 ON OP1.OPPTYP_0 = AX11.IDENT2_0 AND AX11.IDENT1_0 = '434'"
  CRITSQL1(19)  += "AND AX11.CODFIC_0 = 'ATABDIV' AND AX11.ZONE_0 = 'LNGDES' AND AX11.LANGUE_0 = '"+GLANGUE+"' "
  CRITSQL1(20)   = "RIGHT OUTER JOIN "+nomap+".BPCINVLIG AS BI1 ON OP1.OPPNUM_0 = BI1.PJTLIN_0 "
  CRITSQL1(21)   = "LEFT OUTER JOIN "+nomap+".SINVOICE AS SI1 ON BI1.NUM_0 = SI1.NUM_0 AND BI1.CPYLIN_0 = SI1.CPY_0 "
  CRITSQL1(22)   = "GROUP BY OP1.OPPNUM_0,AX1.TEXTE_0,AX11.TEXTE_0,SI1.ACCDAT_0,BI1.NUM_0,SI1.BPRVCR_0,SI1.BPRNAM_0,SI1.STA_0,"
  CRITSQL1(22)  += "OP1.SALFCY_0,OP1.OPPNUM_0,OP1.OPPTYP_0,SI1.ACCDAT_0 "
  CRITSQL1(22)  += "HAVING SI1.STA_0 = 3 "
  If [M:YCG0]PLANTAI    <> ""           Then : CRITSQL1(23)  = "AND OP1.SALFCY_0 >= '"  +[M:YCG0]PLANTAI+     "' " : Endif
  If [M:YCG0]PLANTAF    <> ""           Then : CRITSQL1(24)  = "AND OP1.SALFCY_0 <= '"  +[M:YCG0]PLANTAF+     "' " : Endif
  If [M:YCG0]PROYECTO   <> ""           Then : CRITSQL1(25)  = "AND OP1.OPPNUM_0 =  '"  +[M:YCG0]PROYECTO+    "' " : Endif
  If [M:YCG0]CATEGORIAI <> ""           Then : CRITSQL1(26)  = "AND OP1.OPPTYP_0 >= '"  +[M:YCG0]CATEGORIAI+  "' " : Endif
  If [M:YCG0]CATEGORIAF <> ""           Then : CRITSQL1(27)  = "AND OP1.OPPTYP_0 <= '"  +[M:YCG0]CATEGORIAF+  "' " : Endif
  If [M:YCG0]FECHAI     <> [00/00/0000] Then : CRITSQL1(28)  = "AND SI1.ACCDAT_0 >= '"  +[M:YCG0]FECHAI+      "' " : Endif
  If [M:YCG0]FECHAF     <> [00/00/0000] Then : CRITSQL1(29)  = "AND SI1.ACCDAT_0 <= '"  +[M:YCG0]FECHAF+      "' " : Endif

  CRITSQL1(30)   = LUNION1

  # facturas proveedor
  CRITSQL1(31)   = "SELECT OP2.OPPNUM_0 AS NUMPROY, AX2.TEXTE_0 AS DESPROY, AX22.TEXTE_0 AS CATEGORIA, PI2.ACCDAT_0 AS FECHA, "
  CRITSQL1(31)  += "PD2.NUM_0 AS NUMINT, PI2.BPRVCR_0 AS NUMDOC, PI2.BPRNAM_0 AS CONTRAP, SUM(PD2.AMTNOTLIN_0) AS BASE, 'FP' AS TIPODOC  "
  CRITSQL1(32)   = "FROM "+nomap+".OPPOR AS OP2 "
  CRITSQL1(33)   = "INNER JOIN "+nomap+".PINVOICED AS PD2 ON OP2.OPPNUM_0 = PD2.PJT_0 "
  CRITSQL1(34)   = "INNER JOIN "+nomap+".ATEXTRA AS AX2 ON OP2.OPPNUM_0 = AX2.IDENT1_0 AND AX2.CODFIC_0 = 'PIMPL' "
  CRITSQL1(34)  += "AND AX2.ZONE_0 = 'PIMDESAXX' AND AX2.LANGUE_0 = '"+GLANGUE+"' "
  CRITSQL1(35)   = "INNER JOIN "+nomap+".PINVOICE AS PI2 ON PD2.NUM_0 = PI2.NUM_0 AND PD2.CPY_0 = PI2.CPY_0 "
  CRITSQL1(36)   = "LEFT OUTER JOIN "+nomap+".ATEXTRA AS AX22 ON OP2.OPPTYP_0 = AX22.IDENT2_0 AND AX22.IDENT1_0 = '434' "
  CRITSQL1(36)  += "AND AX22.CODFIC_0 = 'ATABDIV' AND AX22.ZONE_0 = 'LNGDES' AND AX22.LANGUE_0 = '"+GLANGUE+"' "
  CRITSQL1(37)   = "GROUP BY OP2.OPPNUM_0,AX2.TEXTE_0,AX22.TEXTE_0,PI2.ACCDAT_0,PD2.NUM_0,PI2.BPRVCR_0,PI2.BPRNAM_0,PI2.STA_0,"
  CRITSQL1(37)  += "OP2.SALFCY_0,OP2.OPPNUM_0,OP2.OPPTYP_0,PI2.ACCDAT_0 "
  CRITSQL1(37)  += "HAVING PI2.STA_0 = 3 "
  If [M:YCG0]PLANTAI    <> ""           Then : CRITSQL1(38)  = "AND OP2.SALFCY_0 >= '"  +[M:YCG0]PLANTAI+     "' " : Endif
  If [M:YCG0]PLANTAF    <> ""           Then : CRITSQL1(39)  = "AND OP2.SALFCY_0 <= '"  +[M:YCG0]PLANTAF+     "' " : Endif
  If [M:YCG0]PROYECTO   <> ""           Then : CRITSQL1(40)  = "AND OP2.OPPNUM_0 =  '"  +[M:YCG0]PROYECTO+    "' " : Endif
  If [M:YCG0]CATEGORIAI <> ""           Then : CRITSQL1(41)  = "AND OP2.OPPTYP_0 >= '"  +[M:YCG0]CATEGORIAI+  "' " : Endif
  If [M:YCG0]CATEGORIAF <> ""           Then : CRITSQL1(42)  = "AND OP2.OPPTYP_0 <= '"  +[M:YCG0]CATEGORIAF+  "' " : Endif
  If [M:YCG0]FECHAI     <> [00/00/0000] Then : CRITSQL1(43)  = "AND PI2.ACCDAT_0 >= '"  +[M:YCG0]FECHAI+      "' " : Endif
  If [M:YCG0]FECHAF     <> [00/00/0000] Then : CRITSQL1(44)  = "AND PI2.ACCDAT_0 <= '"  +[M:YCG0]FECHAF+      "' " : Endif

  CRITSQL1(45)   = LUNION1

  # facturas terceros proveedor
  CRITSQL1(46)   = "SELECT OP3.OPPNUM_0 AS NUMPROY, AX3.TEXTE_0 AS DESPROY, AX33.TEXTE_0 AS CATEGORIA, PI3.ACCDAT_0 AS FECHA, "
  CRITSQL1(46)  += "BI3.NUM_0 AS NUMINT, PI3.BPRVCR_0 AS NUMDOC, PI3.BPRNAM_0 AS CONTRAP, SUM(BI3.AMTNOTLIN_0) AS BASE, 'FTP' AS TIPODOC "
  CRITSQL1(47)   = "FROM "+nomap+".ATEXTRA AS AX3 "
  CRITSQL1(48)   = "INNER JOIN "+nomap+".OPPOR AS OP3 ON AX3.IDENT1_0 = OP3.OPPNUM_0 AND AX3.CODFIC_0 = 'PIMPL' "
  CRITSQL1(48)  += "AND AX3.ZONE_0 = 'PIMDESAXX' AND AX3.LANGUE_0 = '"+GLANGUE+"' "
  CRITSQL1(49)   = "INNER JOIN "+nomap+".ATEXTRA AS AX33 ON OP3.OPPTYP_0 = AX33.IDENT2_0  AND AX33.IDENT1_0 = '434' "
  CRITSQL1(49)  += "AND AX33.CODFIC_0 = 'ATABDIV' AND AX33.ZONE_0 = 'LNGDES' AND AX33.LANGUE_0 = '"+GLANGUE+"' "
  CRITSQL1(50)   = "RIGHT OUTER JOIN "+nomap+".BPSINVLIG AS BI3 ON OP3.OPPNUM_0 = BI3.PJTLIN_0 "
  CRITSQL1(51)   = "LEFT OUTER JOIN "+nomap+".PINVOICE AS PI3 ON BI3.NUM_0 = PI3.NUM_0 AND BI3.CPYLIN_0 = PI3.CPY_0 "
  CRITSQL1(52)   = "GROUP BY OP3.OPPNUM_0,AX3.TEXTE_0,AX33.TEXTE_0,PI3.ACCDAT_0,BI3.NUM_0,PI3.BPRVCR_0,PI3.BPRNAM_0,PI3.STA_0,"
  CRITSQL1(52)  += "OP3.SALFCY_0,OP3.OPPNUM_0,OP3.OPPTYP_0,PI3.ACCDAT_0 "
  CRITSQL1(52)  += "HAVING PI3.STA_0 = 3 "
  If [M:YCG0]PLANTAI    <> ""           Then : CRITSQL1(53)  = "AND OP3.SALFCY_0 >= '"  +[M:YCG0]PLANTAI+     "' " : Endif
  If [M:YCG0]PLANTAF    <> ""           Then : CRITSQL1(54)  = "AND OP3.SALFCY_0 <= '"  +[M:YCG0]PLANTAF+     "' " : Endif
  If [M:YCG0]PROYECTO   <> ""           Then : CRITSQL1(55)  = "AND OP3.OPPNUM_0 =  '"  +[M:YCG0]PROYECTO+    "' " : Endif
  If [M:YCG0]CATEGORIAI <> ""           Then : CRITSQL1(56)  = "AND OP3.OPPTYP_0 >= '"  +[M:YCG0]CATEGORIAI+  "' " : Endif
  If [M:YCG0]CATEGORIAF <> ""           Then : CRITSQL1(57)  = "AND OP3.OPPTYP_0 <= '"  +[M:YCG0]CATEGORIAF+  "' " : Endif
  If [M:YCG0]FECHAI     <> [00/00/0000] Then : CRITSQL1(58)  = "AND PI3.ACCDAT_0 >= '"  +[M:YCG0]FECHAI+      "' " : Endif
  If [M:YCG0]FECHAF     <> [00/00/0000] Then : CRITSQL1(59)  = "AND PI3.ACCDAT_0 <= '"  +[M:YCG0]FECHAF+      "' " : Endif

  # busca ingresos (factura cliente y factura tercero cliente)
  If [M:YCG0]RENTABILIDAD = 2 Then
    For (Char NUMPROY,Char DESPROY,Char CATEGORIA,Date FECHA,Char NUMINT,Char NUMDOC,Char CONTRAP,Decimal BASE,Char TIPODOC) From "5" Sql CRITSQL1(0..29) As [Y00]
      [M:YCG1]LNUMPROY(LCON1)     = [F:Y00]NUMPROY
      [M:YCG1]LDESPROY(LCON1)     = [F:Y00]DESPROY
      [M:YCG1]LCATEGORIA(LCON1)   = [F:Y00]CATEGORIA
      [M:YCG1]LFECHA(LCON1)       = [F:Y00]FECHA
      [M:YCG1]LNUMINT(LCON1)      = [F:Y00]NUMINT
      [M:YCG1]LNUMDOC(LCON1)      = [F:Y00]NUMDOC
      [M:YCG1]LCONTRAP(LCON1)     = [F:Y00]CONTRAP
      [M:YCG1]LINGRESOS(LCON1)    = [F:Y00]BASE
      [M:YCG1]LTIPODOC(LCON1)     = [F:Y00]TIPODOC
      LCON1 += 1
    Next
  # busca gastos (factura proveedor y factura tecero proveedor)
  Elsif [M:YCG0]RENTABILIDAD = 3
    For (Char NUMPROY,Char DESPROY,Char CATEGORIA,Date FECHA,Char NUMINT,Char NUMDOC,Char CONTRAP,Decimal BASE,Char TIPODOC) From "5" Sql CRITSQL1(31..59) As [Y00]
      [M:YCG1]LNUMPROY(LCON1)     = [F:Y00]NUMPROY
      [M:YCG1]LDESPROY(LCON1)     = [F:Y00]DESPROY
      [M:YCG1]LCATEGORIA(LCON1)   = [F:Y00]CATEGORIA
      [M:YCG1]LFECHA(LCON1)       = [F:Y00]FECHA
      [M:YCG1]LNUMINT(LCON1)      = [F:Y00]NUMINT
      [M:YCG1]LNUMDOC(LCON1)      = [F:Y00]NUMDOC
      [M:YCG1]LCONTRAP(LCON1)     = [F:Y00]CONTRAP
      [M:YCG1]LGASTOS(LCON1)      = [F:Y00]BASE
      [M:YCG1]LTIPODOC(LCON1)     = [F:Y00]TIPODOC
      LCON1 += 1
    Next
  # busca todos (factura cliente, factura tercero cliente, factura proveedor y factura tercero proveedor
  Elsif [M:YCG0]RENTABILIDAD = 1
    For (Char NUMPROY,Char DESPROY,Char CATEGORIA,Date FECHA,Char NUMINT,Char NUMDOC,Char CONTRAP,Decimal BASE,Char TIPODOC) From "5" Sql CRITSQL1(0..29) As [Y00]
      [M:YCG1]LNUMPROY(LCON1)     = [F:Y00]NUMPROY
      [M:YCG1]LDESPROY(LCON1)     = [F:Y00]DESPROY
      [M:YCG1]LCATEGORIA(LCON1)   = [F:Y00]CATEGORIA
      [M:YCG1]LFECHA(LCON1)       = [F:Y00]FECHA
      [M:YCG1]LNUMINT(LCON1)      = [F:Y00]NUMINT
      [M:YCG1]LNUMDOC(LCON1)      = [F:Y00]NUMDOC
      [M:YCG1]LCONTRAP(LCON1)     = [F:Y00]CONTRAP
      [M:YCG1]LINGRESOS(LCON1)    = [F:Y00]BASE
      [M:YCG1]LTIPODOC(LCON1)     = [F:Y00]TIPODOC
      LCON1 += 1
    Next
    For (Char NUMPROY,Char DESPROY,Char CATEGORIA,Date FECHA,Char NUMINT,Char NUMDOC,Char CONTRAP,Decimal BASE,Char TIPODOC) From "5" Sql CRITSQL1(31..59) As [Y00]
      [M:YCG1]LNUMPROY(LCON1)     = [F:Y00]NUMPROY
      [M:YCG1]LDESPROY(LCON1)     = [F:Y00]DESPROY
      [M:YCG1]LCATEGORIA(LCON1)   = [F:Y00]CATEGORIA
      [M:YCG1]LFECHA(LCON1)       = [F:Y00]FECHA
      [M:YCG1]LNUMINT(LCON1)      = [F:Y00]NUMINT
      [M:YCG1]LNUMDOC(LCON1)      = [F:Y00]NUMDOC
      [M:YCG1]LCONTRAP(LCON1)     = [F:Y00]CONTRAP
      [M:YCG1]LGASTOS(LCON1)      = [F:Y00]BASE
      [M:YCG1]LTIPODOC(LCON1)     = [F:Y00]TIPODOC
      LCON1 += 1
    Next
  Endif

  [M:YCG1]PIE_P = LCON1
  Affzo [M:YCG1]5

Return


##############################################################
$NEW_ZONES
# 16/03/2020. Ańadimos dos campos de las líneas de facturas de compra
If !clalev([F:ZZ1]) Then : Local File PINVOICED  [ZZ1] : Endif
Local Integer LINE

For LINE = 0 To [M:YCG1]PIE_P-1
  Filter [ZZ1] Where [ZZ1]NUM = [M:YCG1]LNUMINT(LINE) and [ZZ1]ITMDES = [M:YCG1]LCONCEPTO(LINE) and [ZZ1]PJT = [M:YCG1]LNUMPROY(LINE) and [ZZ1]AMTNOTLIN = [M:YCG1]LBASE(LINE)
  Read [ZZ1] First
  If fstat = 0
    [M:YCG1]LNUMDOC2(LINE)   = [ZZ1]YDOCUMENTO
    [M:YCG1]LPROVEEDOR(LINE) = [ZZ1]YPROVEEDOR
    Affzo [M:YCG1]LNUMDOC2(LINE)
    Affzo [M:YCG1]LPROVEEDOR(LINE)
  Endif
  Filter [ZZ1]
Next

Close Local File [ZZ1]
Return


##############################################################
$COLOREAR
Local Integer LCON2 : Raz LCON2

  For LCON2 = 0 To [M:YCG1]PIE_P - 1
    Case [M:YCG1]LTIPODOC(LCON2)
      When "FP"   : Chgstl [M:YCG1]PIE_P(LCON2) With "BACKRED"           # factura proveedor
      When "FTP"  : Chgstl [M:YCG1]PIE_P(LCON2) With "BACKORANGE"        # factura tercero proveedor
      When "FC"   : Chgstl [M:YCG1]PIE_P(LCON2) With "BACKGREEN"         # factura cliente
      When "FTC"  : Chgstl [M:YCG1]PIE_P(LCON2) With "BACKYELLOW"        # factura tercero cliente
      When "PP"   : Chgstl [M:YCG1]PIE_P(LCON2) With "BACKYELLOW"        # pedido proveedor
      When ""     : Chgstl [M:YCG1]PIE_P(LCON2) With ""
    Endcase
  Next
  Affzo [M:YCG1]5

Return

##############################################################
$CALCULA_TOTALES
Local Integer J : Raz J
  [M:YCG1]TBASE     = sigma(J=0,[M:YCG1]PIE_P-1,([M:YCG1]LBASE(J)))      # suma el importe de las bases
  [M:YCG1]TIVA      = sigma(J=0,[M:YCG1]PIE_P-1,([M:YCG1]LIVA(J)))       # suma el importe de la cuota de iva
  [M:YCG1]TTOTAL    = sigma(J=0,[M:YCG1]PIE_P-1,([M:YCG1]LTOTAL(J)))     # suma el importe total (base+iva)
  [M:YCG1]TINGRESOS = sigma(J=0,[M:YCG1]PIE_P-1,([M:YCG1]LINGRESOS(J)))  # suma el importe de ingresos
  [M:YCG1]TGASTOS   = sigma(J=0,[M:YCG1]PIE_P-1,([M:YCG1]LGASTOS(J)))    # suma el importe de gastos
  Affzo [M:YCG1]10
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
##############################################################
Subprog C_REFACFLG(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    [M:YCG0]RENTAFLG = 1
    Actzo [M:YCG0]MUESTRAPOH
  Else
    [M:YCG0]RENTAFLG = 2
    [M:YCG0]MUESTRAPOH = 1
    Grizo [M:YCG0]MUESTRAPOH
  Endif
  Affzo [M:YCG0]15
End

##############################################################
Subprog C_RENTAFLG(VALEUR)
Variable Integer VALEUR
  If VALEUR = 2 Then
    [M:YCG0]REFACFLG = 1
    [M:YCG0]MUESTRAPOH = 1
    Grizo [M:YCG0]MUESTRAPOH
  Else
    [M:YCG0]REFACFLG = 2
    Actzo [M:YCG0]MUESTRAPOH
  Endif
  Affzo [M:YCG0]15
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

