## Etiquette ajoutée par le superviseur (écran AEXP1) 10/10/2006 18:09:24 (CCORA)
######################################################################################
Subprog AP_ALTERNAT(VALEUR)
Variable Integer VALEUR
End


Subprog AV_VISTIT(VALEUR)
Variable Char    VALEUR()
If [M:AEY4]STYTIT<>""
  Read [AS_Y]ASY0=[M:AEY4]STYTIT
  If fstat=0
    Call TEXTE([F:AS_Y]DES,VALEUR) From OBJDIV
    Chgstl [M:AEY4]VISTIT With [M:AEY4]STYTIT
  Endif
Else
  Raz VALEUR
  Chgstl [M:AEY4]VISTIT With ""
Endif
End


