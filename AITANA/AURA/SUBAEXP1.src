Subprog AV_VISCUM(VALEUR)
Variable Char    VALEUR()
If [M:AEY4]STYCUM<>""
  Read [AS_Y]ASY0=[M:AEY4]STYCUM
  If fstat=0
    Call TEXTE([F:AS_Y]DES,VALEUR) From OBJDIV
    Chgstl [M:AEY4]VISCUM With [M:AEY4]STYCUM
  Endif
Else
  Raz VALEUR
  Chgstl [M:AEY4]VISCUM With ""
Endif
End

Subprog AV_VISFOOT(VALEUR)
Variable Char    VALEUR()
If [M:AEY4]STYFOOT<>""
  Read [AS_Y]ASY0=[M:AEY4]STYFOOT
  If fstat=0
    Call TEXTE([F:AS_Y]DES,VALEUR) From OBJDIV
    Chgstl [M:AEY4]VISFOOT With [M:AEY4]STYFOOT
  Endif
Else
  Raz VALEUR
  Chgstl [M:AEY4]VISFOOT With ""
Endif
End


######################################################################################

######################################################################################
## Etiquette ajoutée par le superviseur (écran AEXP1) 13/10/2006 10:04:19 (CCORA)
######################################################################################
Subprog AM_LIGCUM(VALEUR)
Variable Integer VALEUR
#  Traitements des cumuls
Local Integer NBL
For NBL=0 To [M:AEY2]NBCH-1
  If [M:AEY2]FORMCH(NBL)="N" or [M:AEY2]FORMCH(NBL)="C"
    [M:AEY2]CUMCH(NBL)=VALEUR
  Else
    [M:AEY2]CUMCH(NBL)=1
  Endif
Next NBL
Affzo [M:AEY2]
End



######################################################################################

$NOMACTION
Local Integer OKTRT
Local Char    PROGSUB(GLONADC) , PROGSPE(GLONADC) , PROGSPV(GLONADC)
If dim(GACTION)>0
 Local Char AACTION : AACTION=GACTION
 If GACTION="ADOTRT" and dim(GGGACTION)>0 : AACTION=GGGACTION : Endif
 Case AACTION
  When ""
  When Default
   Local File ACTION [AC_]
   Read [AC_]ACTION=AACTION
   If !fstat
    Case [F:AC_]TYP
     When 1 : # Objet
      Local Char    PROGSUB(GLONADC) , PROGSPE(GLONADC) , PROGSPV(GLONADC)
      PROGSUB = "SUB"+GABREV
      PROGSPE = "SPE"+GABREV
      PROGSPV = "SPV"+GABREV
      Gosub NOMFIC From ="WO"+GABREV
      Call EXISTE_ADX("","",PROGSPE,OKTRT) From ORDSYS
      If !OKTRT : PROGSPE = "" : Endif
      Call EXISTE_ADX("","",PROGSPV,OKTRT) From ORDSYS
      If !OKTRT : PROGSPV = "" : Endif
     When 2 : # Consultation
      Local Char    PROGCNS(GLONADC)
      PROGCNS= "WWCNS"+[F:AC_]PARAM1
      Gosub NOMFIC From =PROGCNS
      If PROGSPE<>""
       Call EXISTE_ADX("","",PROGSPE,OKTRT) From ORDSYS
       If !OKTRT : PROGSPE = "" : Endif
      Endif
      Call EXISTE_ADX("","",PROGSTD,OKTRT) From ORDSYS
      If !OKTRT : PROGSUB = "" : Endif
     When 3,4,5,6,7 : # Traitement standard/Saisie fenętre/ Sélection liste/Sélection table/Affichage divers
      PROGSUB = [F:AC_]CODTRT
      PROGSPE = [F:AC_]SPETRT
      If PROGSPE<>""
       Call EXISTE_ADX("","",PROGSPE,OKTRT) From ORDSYS
       If !OKTRT : PROGSPE="" : Endif
      Endif
    Endcase
   Endif
   Close Local File [AC_]
 Endcase
Endif
Return


$APPELACTION
#  Call EXPEXCEL(TYPCALL,BOIT,MASK1,NBASPAG,ABRMASK1,NOLIGT+1,FINT) From =[F:AM_K]TRTSTD
  SAVACTION=ACTION
  ACTION=ACTION1
  If PROGSUB<>""
    Gosub ACTION From =PROGSUB
  Else
    GPOINT = "EXCPAR" : Gosub ENTREE From EXEFNC
  Endif
  If PROGSPV<>""
    Gosub ACTION From =PROGSPV
  Endif
  If PROGSPE<>""
    Gosub ACTION From =PROGSPE
  Endif
  ACTION=SAVACTION
Return




