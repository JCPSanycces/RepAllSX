#<AdxTL>@(#)0.0.0.0 $Revision$
# 10/02/2020 - MS - Consulta de LĒneas de Facturas de Compras

$ACTION
Case ACTION
  When "AV_AFFICHE" : Gosub AV_AFFICHE
Endcase
Return

#When "SETBOUT"  :   Gosub SETBOUT


############################################
$AV_AFFICHE
# Cargo campos SPE
Local Integer LINEA

If !clalev([PP1])     : Local File PINVOICED  [PP1]   : Endif
If !clalev([PP2])     : Local File GACCDUDATE [PP2]   : Endif
If !clalev([PP3])     : Local File ATEXTRA    [PP3]   : Endif
If !clalev([ZDAE])    : Local File GACCENTRYD [ZDAE]  : Endif
If !clalev([ZVDUD])   : Local File YCVCTOS    [ZVDUD] : Endif  # vista acumulado importes vctos por factura,
                                                               # con fecha ·ltimo pago
If !clalev([YVCTAI])  : Local File YVCTAITM  [YVCTAI] : Endif  # vista de las ctas. vta/compra de un art.

For LINEA = 0 To [M:CPJ2]NBLIG-1

  # Impuestos
  Read [PP1]PID0 = [M:CPJ2]NUM(LINEA);[M:CPJ2]PIDLIN(LINEA)
  If fstat = 0
    [M:CPJ2]YNIMP1(LINEA) = [PP1]VAT(0)
    [M:CPJ2]YNIMP2(LINEA) = [PP1]VAT(1)
    [M:CPJ2]YNIMP3(LINEA) = [PP1]VAT(2)
    [M:CPJ2]YVIMP1(LINEA) = [PP1]AMTTAXLIN1
    [M:CPJ2]YVIMP2(LINEA) = [PP1]AMTTAXLIN2
    [M:CPJ2]YVIMP3(LINEA) = [PP1]AMTTAXLIN3
    Affzo [M:CPJ2]YNIMP1(LINEA)
    Affzo [M:CPJ2]YNIMP2(LINEA)
    Affzo [M:CPJ2]YNIMP3(LINEA)
    Affzo [M:CPJ2]YVIMP1(LINEA)
    Affzo [M:CPJ2]YVIMP2(LINEA)
    Affzo [M:CPJ2]YVIMP3(LINEA)
  Endif

  # Pago
  Read [ZVDUD]YAV0 = [M:CPJ2]NUM(LINEA)
  If !fstat
    [M:CPJ2]YPAYLASTDAT(LINEA) = [ZVDUD]MAXVCTOPAG
    Affzo [M:CPJ2]YPAYLASTDAT(LINEA)
  Endif

  # Descripci¾n del proyecto
  Read [PP3]AXX0 = "PIMPL";"PIMDESAX1";"SPA";[M:CPJ2]PJT(LINEA);""
  If fstat = 0
    [M:CPJ2]YPRODES(LINEA) = [PP3]TEXTE
    Affzo [M:CPJ2]YPRODES(LINEA)
  Endif

  # C.C. Contrapartida
  Read [YVCTAI]YVITM = [M:CPJ2]ITMREF(LINEA)
  If !fstat
    [M:CPJ2]YCCONTRA(LINEA) = [YVCTAI]CTACOMP
    Affzo [M:CPJ2]YCCONTRA(LINEA)
  Endif

Next

Close Local File [PP1],[PP2],[PP3],[ZDAE],[ZVDUD],[YVCTAI]

Return

