# 10/02/2020 - MS - Consulta de Líneas de Facturas de Venta

$ACTION
Case ACTION
 When "AV_AFFICHE" : Gosub AV_AFFICHE
Endcase
Return


Return
############################################
$AV_AFFICHE

#If GUSER = "AIT50"
#  Infbox "HOLA5"
#Endif


# Cargo campos SPE
Local Integer LINEA

If !clalev([PP1])     : Local File SINVOICED  [PP1]   : Endif
If !clalev([PP2])     : Local File GACCDUDATE [PP2]   : Endif
If !clalev([PP3])     : Local File ATEXTRA    [PP3]   : Endif
If !clalev([ZDAE])    : Local File GACCENTRYD [ZDAE]  : Endif
If !clalev([PP4])     : Local File OPPOR      [PP4]   : Endif
If !clalev([ZVDUD])   : Local File YAVCTOS    [ZVDUD] : Endif  # vista acumulado importes vctos por factura,
                                                               # con fecha último pago
If !clalev([YVCTAI])  : Local File YVCTAITM  [YVCTAI] : Endif  # vista de las ctas. vta/compra de un art.

For LINEA = 0 To [M:CST2]NBLIG-1

  # Impuestos
  Read [PP1]SID0 = [M:CST2]NUM(LINEA);[M:CST2]SIDLIN(LINEA)
  If fstat = 0
    [M:CST2]YNIMP1(LINEA) = [PP1]VAT(0)
#    [M:CST2]YNIMP2(LINEA) = [PP1]RATTAXLIN(1)
#    [M:CST2]YNIMP3(LINEA) = [PP1]RATTAXLIN(2)
    [M:CST2]YVIMP1(LINEA) = [PP1]AMTTAXLIN(0)
#    [M:CST2]YVIMP2(LINEA) = [PP1]AMTTAXLIN(1)
#    [M:CST2]YVIMP3(LINEA) = [PP1]AMTTAXLIN(2)
    Affzo [M:CST2]YNIMP1(LINEA)
    Affzo [M:CST2]YNIMP2(LINEA)
    Affzo [M:CST2]YNIMP3(LINEA)
    Affzo [M:CST2]YVIMP1(LINEA)
    Affzo [M:CST2]YVIMP2(LINEA)
    Affzo [M:CST2]YVIMP3(LINEA)
  Endif

  # Cobro
  Read [ZVDUD]YAV0 = [M:CST2]NUM(LINEA)
  If !fstat
    [M:CST2]YPAYLASTDAT(LINEA) = [ZVDUD]MAXVCTOPAG
    Affzo [M:CST2]YPAYLASTDAT(LINEA)
  Endif

  # Descripción del proyecto
  Read [PP3]AXX0 = "PIMPL";"PIMDESAX1";"SPA";[M:CST2]PJT(LINEA);""
  If fstat = 0
    [M:CST2]YPROYDES(LINEA) = [PP3]TEXTE
    Affzo [M:CST2]YPROYDES(LINEA)
  Endif

  # C.C. Contrapartida
  Read [YVCTAI]YVITM = [M:CST2]ITMREF(LINEA)
  If !fstat
    [M:CST2]YCCONTRA(LINEA) = [YVCTAI]CTAVTA
    Affzo [M:CST2]YCCONTRA(LINEA)
  Endif

  # Categoría del proyecto
  Read [PP4]OPP0 = [M:CST2]PJT(LINEA)
  If fstat = 0
    [M:CST2]YCATPROY(LINEA) = [PP4]OPPTYP
  Endif
Next

Close Local File [PP1],[PP2],[PP3],[PP4],[ZDAE],[ZVDUD],[YVCTAI]

Return

