#MRR01 - 05/04/2021 - AU-003 - Permitir modificaciˇn de direcciˇn cliente en facturas
#                              y abonos validados.
######################################################################################
$ACTION
#Infbox ACTION
Case ACTION
 When Default
Endcase
Return

######################################################################################
Subprog AS_BPAADD(VALEUR)
Variable Char    VALEUR()

If GFONCTION = 'GESSIH' Then
  Affzo [M:SIH0]
#  Infbox 'INVTYP: ' + num$([F:SIH]INVTYP) + ' STA: ' + num$([F:SIH]STA)
  If ([F:SIH]INVTYP = 1 or [F:SIH]INVTYP = 2) and [F:SIH]STA = 3 Then #factura y abono validados
    Actzo [M:ADC]BPAADD
    Affzo [M:ADC]
  Endif
Endif

End

######################################################################################
Subprog AS_BPAADDLIG(VALEUR)
Variable Char    VALEUR()

If GFONCTION = 'GESSIH' Then
  Affzo [M:SIH0]
  If ([F:SIH]INVTYP = 1 or [F:SIH]INVTYP = 2) and [F:SIH]STA = 3 Then
    Actzo [M:ADC]BPAADDLIG(0)
    Actzo [M:ADC]BPAADDLIG(1)
    Actzo [M:ADC]BPAADDLIG(2)
    Affzo [M:ADC]
  Endif
Endif

End

