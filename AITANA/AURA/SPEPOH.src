#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "LIENS"  :  Gosub LIENS
  When "RAZCRE" :  Gosub RAZCRE
  When "FILTRE" :  Gosub FILTRE
Endcase
Return

########################################
$LIENS
# Activación de los campos propios de la transacción de viajes
If GPTRNUM = "AU02"
  Actzo [M:POH1]YESTADOV
  Actzo [M:POH1]YNBILLETE
  Actzo [M:POH1]YOBSERVA
Else
  Diszo [M:POH1]YESTADOV
  Diszo [M:POH1]YNBILLETE
  Diszo [M:POH1]YOBSERVA
Endif
Return


########################################
$RAZCRE
# Activación de los campos propios de la transacción de viajes
If GPTRNUM = "AU02"
  Actzo [M:POH1]YESTADOV
  Actzo [M:POH1]YNBILLETE
  Actzo [M:POH1]YOBSERVA
Else
  Diszo [M:POH1]YESTADOV
  Diszo [M:POH1]YNBILLETE
  Diszo [M:POH1]YOBSERVA
Endif

# Si creo el pedido en la transacción AU02, lo marco como tipo Viajes
If GPTRNUM = "AU02"
  [M:POH0]YVIAJES = 2
Else
  [M:POH0]YVIAJES = 1
Endif
Affzo [M:POH0]YVIAJES
Return


########################################
$FILTRE
# Filtro los pedidos en función de la transacción
Gosub FILTRE From SUBPOHA

If GPTRNUM = "AU02"
  FILTSUP+=" & YVIAJES=2"
Else
  FILTSUP+=" & YVIAJES<>2"
Endif

GPE = 1
Return

######################################################################################
## Etiqueta ańadida por el supervisor (pantalla POH1) 18/09/2019 12:00:10 (AIT04)
######################################################################################
Subprog C_PJTH(VALEUR)
Variable Char    VALEUR()
End


