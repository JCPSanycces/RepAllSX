###################################################################################
#################################   SUBPROGRAMAS  #################################
###################################################################################
#######################
#**
#* muestra el CIF del proveedor en la pantalla de consulta de facturas (terceros proveedor)
#*
#* @param PBPR      > código del proveedor
#*!
Funprog GET_CRN(PBPR)
Value     Char PBPR

Local Char LRES(20)

  If !clalev([F:BPR0])  : Local File BPARTNER   [F:BPR0]  : Endif
  Read [F:BPR0]BPR0 = PBPR
  If !fstat
    LRES = [F:BPR0]CRN
  Endif
  Close Local File [BPR0]

End LRES

#######################
#**
#* muestra el el comentario de la factura tercer proveedor en la pantalla de consulta de facturas (terceros proveedor)
#*
#* @param PNUM      > número de asiento
#*!
Funprog GET_DES(PNUM)
Value     Char PNUM

Local Char LRES(30)

  If !clalev([F:PIH0])  : Local File PINVOICE   [F:PIH0]  : Endif
  Read [F:PIH0]PIH0 = PNUM
  If !fstat
    LRES = [F:PIH0]DES
  Endif
  Close Local File [PIH0]

End LRES

