#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub OUVRE_BATCH
  When "EXEC"           : Gosub EXEC
  When "TERMINE"        : Gosub TERMINE
  When "INIT"           : Gosub INIT
  When "OK"             : Gosub OK
Endcase

Return

$OUVRE_BATCH
Return

$EXEC
  Local Char CRITERE(250)
  Local Char ERRORES(255)(0..)
  Local Char REQUEST(255)
  Local Integer HAYERRORES

  Raz CRITERE

  CRITERE = "1=1"
#  If [M:ZTRAITM]ZARTDESDE<>"" and [M:ZTRAITM]ZARTHASTA<>"" Then
#    CRITERE -= ' & ITMREF>="' + [M:ZTRAITM]ZARTDESDE + '"'
#    CRITERE -= ' & ITMREF<="' + [M:ZTRAITM]ZARTHASTA + '"'
#  Elsif [M:ZTRAITM]ZARTDESDE<>"" and [M:ZTRAITM]ZARTHASTA="" Then
#    CRITERE -= ' & ITMREF>="' + [M:ZTRAITM]ZARTDESDE + '"'
#  Elsif [M:ZTRAITM]ZARTDESDE="" and [M:ZTRAITM]ZARTHASTA<>"" Then
#    CRITERE -= ' & ITMREF<="' + [M:ZTRAITM]ZARTHASTA + '"'
#  Endif

  #CRITERE -= ' & UPDDATTIM>=[' + format$(GFMD,[M:ZTRAITM]ZDESDEFMOD1) + ']'
  #CRITERE -= ' & UPDDATTIM<=[' + format$(GFMD,[M:ZTRAITM]ZHASTAFMOD2) + ' 23:59:59]'

  If [M:ZTRAITM]ZARTDESDE<>"" and [M:ZTRAITM]ZARTHASTA<>"" Then
    CRITERE -= " AND ITMREF_0>='"+ [M:ZTRAITM]ZARTDESDE+"'"
    CRITERE -= " AND ITMREF_0<='"+ [M:ZTRAITM]ZARTHASTA+"'"
  Elsif [M:ZTRAITM]ZARTDESDE<>"" and [M:ZTRAITM]ZARTHASTA="" Then
    CRITERE -= " AND ITMREF_0>='" + [M:ZTRAITM]ZARTDESDE + "'"
  Elsif [M:ZTRAITM]ZARTDESDE="" and [M:ZTRAITM]ZARTHASTA<>"" Then
    CRITERE -= " AND ITMREF_0<='" + [M:ZTRAITM]ZARTHASTA + "'"
  Endif

  CRITERE -= " AND UPDDATTIM_0>='"+format$(GFMD,[M:ZTRAITM]ZDESDEFMOD1)+"'"
  CRITERE -= " AND UPDDATTIM_0<='"+format$(GFMD,[M:ZTRAITM]ZHASTAFMOD2)+"'"

  #Infbox(CRITERE)

  Call OUVRE_TRACE("Traducción de artículos") From LECFIC
  Call ECR_TRACE("Filtros seleccionados:",0) From GESECRAN
  Call ECR_TRACE("Desde artículo: "+[M:ZTRAITM]ZARTDESDE+" Hasta artículo: "+[M:ZTRAITM]ZARTHASTA,0) From GESECRAN
  Call ECR_TRACE("Desde fecha: "+num$([M:ZTRAITM]ZDESDEFMOD1)+" Hasta fecha: "+num$([M:ZTRAITM]ZHASTAFMOD2),0) From GESECRAN

  Call ECR_TRACE("-----------------------------",0) From GESECRAN

  REQUEST="SELECT ITMREF_0 FROM ITMMASTER WHERE "+CRITERE
  For (Char REFARTI(50)) From "5" Sql REQUEST As [YYY]
    HAYERRORES=0
  #Filter [F:WITM2] Where evalue(CRITERE)

  #Call ECR_TRACE("Se van a analizar "+num$(rowcount([F:WITM2]))-"artículos",0) From GESECRAN
  #For [F:WITM2]
  #For [F:YYY]
    #Call TRADUCCIONES([F:WITM2]ITMREF,ERRORES) From ZFUNCIONES
    Call TRADUCCIONES([F:YYY]REFARTI,ERRORES) From ZFUNCIONES

    For JJ=0 To dim(ERRORES)-1
      If ERRORES(JJ)<>"" Then
        HAYERRORES=1
        Call ECR_TRACE(ERRORES(JJ),1) From GESECRAN
      Endif
    Next

    If HAYERRORES=0 Then
      Call ECR_TRACE("Artículo "+[F:YYY]REFARTI+" actualizado con éxito",0) From GESECRAN
    Endif

    Call ECR_TRACE("-----------------------------",0) From GESECRAN

    Raz HAYERRORES
  Next

  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC

Return

$TERMINE
Return

$INIT
  Local Date FECHAINI
  Local Date FECHAFIN


  If clalev([F:WITM2])<=0 : Local File ITMMASTER [WITM2]  : Endif
  If clalev([M:ZTRAITM])<=0 : Local Mask ZTRAITM [M:ZTRAITM]  : Endif


  FECHAINI=func ZCOMUN.CHAR_TO_DATE("01/01/"+num$(year(date$)))
  FECHAFIN=func ZCOMUN.CHAR_TO_DATE("31/12/"+num$(year(date$)))

  [M:ZTRAITM]ZDESDEFMOD1=FECHAINI
  Affzo [M:ZTRAITM]ZDESDEFMOD1

  [M:ZTRAITM]ZHASTAFMOD2=FECHAFIN
  Affzo [M:ZTRAITM]ZHASTAFMOD2


Return

$OK
Return

