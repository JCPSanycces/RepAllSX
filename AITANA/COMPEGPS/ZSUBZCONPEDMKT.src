#<AdxTL>@(#)0.0.0.0 $Revision$
#Proceso integracion de pedidos lanzado mediante tarea programada en batch.
$ACTION
#Infbox ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub TRT_INI
  When "EXEC"           : Gosub EXEC_CONPED
  When "TERMINE"        : Gosub TERMINE_CONPED
  When "INIT"           : Gosub INIT_DIA_CONPED
  When "OK"             : Gosub OK_CONPED
  When "END"            : Gosub END_CONPED
Endcase

Return

$TRT_INI
Return


$EXEC_CONPED
  #Infbox("a ejecutar")
  #System CHAINE="C:\Program Files (x86)\Azeta\Actualizacion de imagenes X3\Impima.exe"

  #####System RESULT="D:\actu\Impima.exe"
  System RESULT=chr$(34) + "C:\Program Files (x86)\Azeta\EDI X3\EDI.exe" + chr$(34)


  End

  #Local Char RETOUR : RETOUR = ""
  #Callui RETOUR="" With "UIAction="+chr$(1)+"OpenFile", "UILocalDir="+chr$(1) + "Temp", "UILocalFile="+ chr$(1) +"C:\Program Files (x86)\Azeta\Actualizacion de imagenes X3\Impima.exe"
  #End
Return

$TERMINE_CONPED
Return

$INIT_DIA_CONPED
Return

$OK_CONPED
Return

$END_CONPED
Return

