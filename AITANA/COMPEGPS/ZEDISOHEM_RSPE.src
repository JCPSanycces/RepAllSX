#<AdxTL>@(#)0.0.0.0 $Revision$
# Clase ZEDISOHEM

## FJCP --> Personalizacion Amazon
## Fuente original : EDISOHEM_RSTD
###############################################################################
# Representation EDISOHEM                                                     #
# Author : JUCON + RBA                                                        #
###############################################################################

$METHODS
  Case [L]CURPTH
    When ""
      Case [L]ACTION
        When "MET_AFTER_LOAD_REPRESENTATION" : Gosub MET_AFTER_LOAD_REPRESENTATION
      Endcase
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
  Endcase
Return


#********************************************************************
# Method MET_AFTER_LOAD_REPRESENTATION
#********************************************************************
#
#* @param WCATCOD
#* @param WCATACT
#* @param WPARCOD
#* @param WDUPLICATE
#* @param WTEST
#* @param WERR
#* @return [V]CST_AOK/[V]CST_AERROR
#*!

$MET_AFTER_LOAD_REPRESENTATION
  Local Integer I, J
  Local Integer WOK     : WOK     = [V]CST_AOK
  Local Integer WSTATUS : WSTATUS = [V]CST_AOK

  Case WCATACT
    When 1 :
      Case WPARCOD
        When "EDICOM" : Gosub EDICOM_ISSUE
        When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
      Endcase
    When 2 :
      Case WPARCOD
        When "EDICOM" : Gosub EDICOM_RECEIPT
        When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
      Endcase
  Endcase

  ARET_VALUE = WSTATUS
Return



################################################################################
$EDICOM_ISSUE
  #
Return

################################################################################
$EDICOM_RECEIPT

  ####################################
  #   HEADER
  ####################################
  this.E="E"    #Indicator header for import template model
  #1 - Control value to EDIFUNCTION property (only 9 and 5 are supported at the moment)
  Local Integer K

  Case this.EDIFUNCTION
    When "16":  K=1: WERR= mess(9,137,1)-mess(36,120,1)   #Proposal
    When "46":  K=1: WERR= mess(9,137,1)-mess(1,2258,1)   #Provisional
  Endcase
  If K=1
    WSTATUS = [V]CST_AERROR
  Endif
## FJCP --> Personalizacion Amazon
Local Date WORDDAT
WORDDAT=left$(this.EDIORDDAT,8)

#this.EDIORDDAT=date$
If this.ZTIPPEDAMA = "QUCP4"
    Case dayn(WORDDAT+4)
       When 6 Then
           this.EDIDLVDAT=WORDDAT+6

       When 7 Then
           this.EDIDLVDAT=WORDDAT+5

       When Default
           this.EDIDLVDAT=WORDDAT+4
    Endcase
    this.ZTIPPEDAMA = "2"
Else
    Case dayn(WORDDAT+14)
       When 6 Then
           this.EDIDLVDAT=WORDDAT+16

       When 7 Then
           this.EDIDLVDAT=WORDDAT+15

       When Default
           this.EDIDLVDAT=WORDDAT+14

    Endcase
    this.ZTIPPEDAMA = "1"
Endif

# Plazo de Entrega
# Si Fecha Entrega Lunes --> 3 Dias (Fecha Expedicion Viernes)
# Si Fecha Entrega Martes --> 4 Dias. (Fecha Expedicion Viernes)
# En Otro caso 2 Dias
Case dayn(this.EDIDLVDAT)
     When 1
       this.ZDAYLTI = 3
     When 2
       this.ZDAYLTI = 4
     When Default
       this.ZDAYLTI = 2
Endcase

## FIN FJCP --> Personalizacion Amazon

  #2 - Formating date properties
  If WSTATUS = [V]CST_AOK
    this.SOH.ORDDAT    = format$("D:YYYYMMDD",left$(this.EDIORDDAT, 8))
    this.SOH.SHIDAT    = format$("D:YYYYMMDD",left$(this.EDISHIDAT, 8))
    this.SOH.DEMDLVDAT = format$("D:YYYYMMDD",left$(this.EDIDLVDAT, 8))
  Endif
#      3 - Open order? Now not used. Pending CRUD in class SOH
#      If this.EDIOPENUM <> "" and this.EDISOHTYP = "221"
#        Local File SORDER [SOH]
#        Filter [SOH] Where SOHNUM = this.EDIOPENUM and SOHCAT = 4
#        Read First
#        If fstat=[V]CST_AOK
#          this.SOH.SOHNUM    = this.EDIOPENUM
#          this.SOH.CUSORDREF = this.EDIOPEREF
#          this.SOH.ORDDAT    = this.EDIORDDAT
#        Endif
#        LogicClose File [SOH]
#      Endif

  #4 - Searching EDICPY code
  If WSTATUS = [V]CST_AOK
    Local File EDICPYPAR [ECP]
    Filter [ECP] Where PARCOD = WPARCOD and EXCEDICOD = this.EDICPY
    Read First
    If fstat=[V]CST_AOK
      this.SOH.CPY = [F:ECP]CPY
    Else
      WSTATUS = [V]CST_AERROR
      WERR = mess(124,2006,1)   #Cannot find company code for this EDI code
    Endif
    LogicClose File [ECP]
  Endif

  #5- Searching price list
  If WSTATUS = [V]CST_AOK
    If this.SOH.CPY<>""
      Local File COMPANY [CPY]
      Read [CPY]CPY0=this.SOH.CPY
      If fstat= [V]CST_AOK
 #       this.SOH.PLISTC=[F:CPY]PLISTC   #Not use if you do not use discounts
        this.SOH.LEG   =[F:CPY]LEG
        If WDUPLICATE=2 and this.EDIFUNCTION="7" and WTEST=1
          Local File EDICATL [ECAL]
#          Local Char WDUPLIASORI(1)
          Local Integer WDUPLIASORI
          Read [ECAL]ECAL2=WCATCOD;this.SOH.LEG
          If fstat= [V]CST_AOK
            If [F:ECAL]DUPLICATE=2
#              Call PARAMUTIL("DUPLIASORI",WDUPLIASORI,this.ACTX.USER,"") From SUBAUS     #Pending new general parameter
#              If val(WDUPLIASORI)=1
              WDUPLIASORI = fmet this.ACTX.APARAM.AGETUSERVALNUM("DUPLIASORI")
              If WDUPLIASORI = 1
                WSTATUS = [V]CST_AERROR
                WERR = mess(145,2006,1)-this.SOH.CPY    #Duplicate not allowed for the company
              Endif
            Endif
          Endif
          LogicClose File [ECAL]
        Endif
      Else
        WSTATUS = [V]CST_AERROR
        WERR = mess(231,111,1)    #No company found for the given parameters
#        WERR = "Cannot find price list for the company"-this.SOH.CPY #Not use if you do not use discounts
      Endif
      LogicClose File [CPY]
    Else
      WSTATUS = [V]CST_AERROR
      WERR = mess(231,111,1)    #No company found for the given parameters
    Endif
  Endif


  #6- Searching site form EDICOM code (EXCEDICOD)
  If WSTATUS = [V]CST_AOK
    Local File EDIFCYPAR [EFP]
    Filter [EFP] Where PARCOD = WPARCOD and EXCEDICOD = this.EXCEDICOD
    Read First
    If fstat=[V]CST_AOK
      Local File FACILITY [FCY]
      Read [FCY]FCY0=[F:EFP]FCY
      If fstat=[V]CST_AOK
        If [F:FCY]LEGCPY=this.SOH.CPY
          this.SOH.SALFCY = [F:FCY]FCY
        Else
          WSTATUS = [V]CST_AERROR
          WERR = [F:FCY]FCY+":"-mess(125,2006,1)-this.SOH.CPY    #Site does not belong to the company
        Endif
      Endif
      LogicClose File [FCY]
    Else
      WSTATUS = [V]CST_AERROR
      WERR = mess(126,2006,1)   #Cannot find the site code
    Endif
    LogicClose File [EFP]
  Endif

  #7- Searching customer´s EDI code
  Local File EDIBPRPAR [EBP]







## FJCP - ZEDI - Busqueda Cliente Pedido
 If WSTATUS = [V]CST_AOK & this.ZEDIBPCORD<>""
    Filter [EBP] Where PARCOD = WPARCOD and EXCEDICOD = this.ZEDIBPCORD
    Read First
    If fstat = [V]CST_AOK
      this.SOH.BPCORD = [F:EBP]BPANUM
      this.SOH.BPAORD = [F:EBP]BPAADD
      this.SOH.BPAADD = [F:EBP]BPAADD
      this.ZBPAORD = [F:EBP]BPAADD ## FJCP - ZEDI - Direccion pedido
    Else
      WSTATUS = [V]CST_AERROR
      WERR = mess(127,2006,1) #Cannot find the BP or ADDRESS code
    Endif
  Endif
## FIN FJCP - ZEDI
## Cliente pedido y Entrega
 If WSTATUS = [V]CST_AOK
    Filter [EBP] Where PARCOD = WPARCOD and EXCEDICOD = this.EDIBPCCOD
    Read First
    If fstat = [V]CST_AOK
      this.SOH.BPCORD = [F:EBP]BPANUM
      ## FJCP - ZEDI - Direccion pedido
      # this.SOH.BPAORD = [F:EBP]BPAADD ## FJCP - ZEDI - Comentado
      If this.ZBPAORD = ""
         this.ZBPAORD = [F:EBP]BPAADD
         this.SOH.BPAORD = [F:EBP]BPAADD
       Endif
      ## FIN FJCP - ZEDI
       this.SOH.BPAADD = [F:EBP]BPAADD
    Else
      WSTATUS = [V]CST_AERROR
      WERR = mess(127,2006,1) #Cannot find the BP or ADDRESS code
    Endif
  Endif

  If WSTATUS = [V]CST_AOK
    If  this.EDIBPCINV<>""
      Filter [EBP] Where PARCOD = WPARCOD and EXCEDICOD = this.EDIBPCINV
      Read First
      If fstat = [V]CST_AOK
        this.SOH.BPCINV = [F:EBP]BPANUM
        this.ZBPAINV = [F:EBP]BPAADD ## FJCP - ZEDI - Direccion Factura
      Else
        WSTATUS = [V]CST_AERROR
        WERR = mess(128,2006,1) #Cannot find the bill-to customer code
      Endif
    Else
      this.ZBPAINV= this.SOH.BPAADD  ## FJCP - ZEDI - Direccion Factura
    Endif
  Endif

  If WSTATUS = [V]CST_AOK
    If this.EDIBPCPAY<>""
      Filter [EBP] Where PARCOD = WPARCOD and EXCEDICOD = this.EDIBPCPAY
      Read First
      If fstat = [V]CST_AOK
        this.SOH.BPCPYR = [F:EBP]BPANUM
      Else
        WSTATUS = [V]CST_AERROR
        WERR = mess(129,2006,1) #Cannot find the BP pay by code
      Endif
    Endif
  Endif

  #8.- Filling BPTNUM code
  If WSTATUS = [V]CST_AOK
    If this.EDIBPTCOD<>""
      Filter [EBP] Where PARCOD = WPARCOD and EXCEDICOD = this.EDIBPTCOD
      Read First
      If fstat = [V]CST_AOK
        this.SOH.BPTNUM = [F:EBP]BPANUM
      Else
        WSTATUS = [V]CST_AERROR
        WERR = mess(130,2006,1) #Cannot find the BP carrier code
      Endif
    Endif
  Endif

  LogicClose File [EBP]

  #9.- Managing the EDIFUNCTION propierty
  If WSTATUS = [V]CST_AOK
    Local Char WPED(20)
    Local File SORDER [SOHX]
    Read[SOHX]SOH1=this.SOH.BPCORD;this.SOH.CUSORDREF
    If fstat = [V]CST_AOK
      WPED=[F:SOHX]SOHNUM
      Case this.EDIFUNCTION
        When "3" : WSTATUS = [V]CST_AERROR: WERR= mess(131,2006,1)- WPED  #Nothing to do. Cancellation of the sales order
        When "5" : this.SOH.SOHNUM=WPED  # Modification of this sales order
        When "6" : WSTATUS = [V]CST_AERROR: WERR= mess(132,2006,1)- WPED   #Nothing to do. Confirmation of the sales order
        #When "7" : WSTATUS = [V]CST_AERROR: WERR= mess(133,2006,1)- WPED   #Nothing to do. Duplication of the sales order
        When "9" :If WPED<>"" and WTEST=1: WSTATUS = [V]CST_AERROR: WERR= mess(6,159,1)-this.SOH.CUSORDREF-mess(134,2006,1)- WPED: Endif  #already in use
                   # else Original (default value). Nothing to do
        When "31": WSTATUS = [V]CST_AERROR: WERR= mess(135,2006,1)- WPED   #Nothing to do. Copy of the sales order
      Endcase
    Else
      If this.EDIFUNCTION="7" and WDUPLICATE=1  # If WDUPLICATE =2 is traited like original, so nothing to do
        WSTATUS = [V]CST_AERROR: WERR= mess(136,2006,1)-this.SOH.CUSORDREF  #Nothing to do. Original does not exist and duplicate flag not checked. Duplicate of the customer reference
      Endif
    Endif
    LogicClose File [SOHX]
  Endif

  #transcodings

  Local Char WREP(20) : WREP = right$(this.AINF.NAMCLA,3)
  Local Char WNODE(20)
  Local Char WTYP(20)
  Local Integer WTAB
  Local Integer WSEQ

  Local File ASHWPAR [ASWP]

  #8- Transcoding EDISOHTYP property (in STD table 230)
  If WSTATUS = [V]CST_AOK
    Filter [ASWP] Where CODREP=WREP and CODLNK="EDISOHTYP"
    Read First
    If fstat=[V]CST_AOK
      WTYP  = this.EDISOHTYP
      WTAB  = val([F:ASWP]VALEUR)
      WNODE = func TRTFUNEDI.TRANSCODE(WTYP, WTAB, WCATACT)
      If WNODE<>""
        this.SOH.SOHTYP = left$(WNODE,3)
      Else
        WSTATUS = [V]CST_AERROR
        WERR = mess(137,2006,1) #Cannot find sales order type
      Endif
    Endif
    Filter [ASWP]
  Endif

  #9- Transcoding EDIPTE property (in STD table 222)
  If WSTATUS = [V]CST_AOK
    Filter [ASWP] Where CODREP=WREP and CODLNK="EDIPTE"
    Read First
    If fstat=[V]CST_AOK
      WTYP = this.EDIPTE
      WTAB = val([F:ASWP]VALEUR)
      WNODE = func TRTFUNEDI.TRANSCODE(WTYP, WTAB, WCATACT)
      If WNODE<>""
       # this.SOH.PTE = left$(WNODE,3)
         this.SOH.PTE = WNODE
      Else
        WSTATUS = [V]CST_AERROR
        WERR = mess(138,2006,1) #Cannot find payment term
      Endif
    Endif
    Filter [ASWP]
  Endif

  #10- Transcoding EDIDTAx properties (in STD table 226)
  If WSTATUS = [V]CST_AOK
    Filter [ASWP] Where CODREP=WREP and CODLNK="EDIDTA"
    Read First
    If fstat=[V]CST_AOK
      For I = 1 To 5
        WTYP = evalue("this.EDIDTA"+num$(I))
        If WTYP <> ""
          WTAB  = val([F:ASWP]VALEUR)
          WNODE = func TRTFUNEDI.TRANSCODE(WTYP, WTAB, WCATACT)
          If WNODE<>""
            If I > maxtab(this.SOH.C_INVDTAAMT)
              WSEQ = fmet this.SOH.ADDLINE("C_INVDTAAMT",[V]CST_ALASTPOS)
            Else
              WSEQ = I
            Endif
            this.SOH.C_INVDTAAMT(WSEQ).INVDTA    = val(left$(WNODE,3))
            this.SOH.C_INVDTAAMT(WSEQ).INVDTAAMT = evalue("this.EDIDTAAMT"+num$(I))
          Else
            WSTATUS = [V]CST_AERROR
            WERR = mess(139,2006,1) #Cannot find discount or charge type
          Endif
        Endif
      Next
    Endif
    Filter [ASWP]
  Endif

  #11- Transcoding EDIMDL property (in STD table 231)
  If WSTATUS = [V]CST_AOK
    If this.EDIMDL<>""
      Filter [ASWP] Where CODREP=WREP and CODLNK="EDIMDL"
      Read First
      If fstat=[V]CST_AOK
        WTYP  = this.EDIMDL
        Case WTYP
          When "10","20","30","40": WSTATUS = [V]CST_AOK
          When Default
            WSTATUS = [V]CST_AERROR
            WERR = mess(140,2006,1) #Cannot find a correct delivery mode
        Endcase
        If WSTATUS= [V]CST_AOK
          WTAB  = val([F:ASWP]VALEUR)
          WNODE = func TRTFUNEDI.TRANSCODE(WTYP, WTAB, WCATACT)
          this.SOH.MDL= left$(WNODE,3)
        Endif
      Endif
    Endif
    Filter [ASWP]
  Endif
  LogicClose File [ASWP]
#



  ####################################
  #   LINES
  ####################################
  #Filling C_SOH.SOP collection
  ## FJCP --> Personalizacion Amazon
  Local Char WITMREF(30), WBPCNUM(20), WEANCOD(30)
  Local Integer WW_OK

  WBPCNUM=this.SOH.BPCORD
   ## FIN FJCP --> Personalizacion Amazon
  If WSTATUS = [V]CST_AOK
    For I = 1 To maxtab(this.SOH.R_SOP)
      # FJCP --> Personalizacion EDI
    #    If this.SOH.R_SOP(I).ITMREF=""
        WEANCOD=this.SOH.R_SOP(I).EANCOD
        WITMREF=this.SOH.R_SOP(I).ZITMREF
      # WITMREF=func QUITAR_CEROS(WITMREF)
      #Searching ITMREF
      this.SOH.R_SOP(I).L="L"   #Indicator lines for import template model
      If WITMREF="" and WEANCOD="" Then
        WSTATUS = [V]CST_AERROR
        WERR =  mess(141,2006,1)#Mandatory field EANCOD is empty
        Break
      Endif
      If WEANCOD<>""
         WITMREF   = func TRTFUNEDI.ORD_ITMREF(WEANCOD,1)
       ## FJCP --> Personalizacion Amazon
       ## Busqueda Articulo - Cliente
          If WITMREF = ""
              WITMREF  = func TRTFUNEDI.ORD_ITMREFBPC(WBPCNUM,WEANCOD)
          Endif
       Endif
       WW_OK = func ORD_ITMVERIF(WITMREF)
       If  WW_OK = 1 Then
          this.SOH.SOP(I).ITMREF=WITMREF
          If this.SOH.SOP(I).ITMDES = ""
             this.SOH.SOP(I).ITMDES = func ORD_ITMDES(WITMREF)
          Endif
       Else
         this.SOH.SOP(I).ITMREF=""
       Endif
      ## FJCP --> Personalizacion Amazon
#      If this.SOH.SOP(I).ITMREF=""
#       WSTATUS = [V]CST_AERROR
#        WERR = mess(142,2006,1)#Cannot find a product for this EANCOD
#        Break
#      Endif

      If this.SOH.SOP(I).ITMREF=""
         this.SOH.SOP(I).ITMREF="GEN012"
      Endif
      If this.SOH.SOP(I).ITMREF = "GEN012"
         this.SOH.SOP(I).ITMDES = this.SOH.R_SOP(I).EANCOD - WITMREF
      Endif
      ## FIN FJCP --> Personalizacion Amazon

      # Transcoding EDISAU  properties (in STD table 228)
      Local File ASHWPAR [ASWP]
      Filter [ASWP] Where CODREP=WREP and CODLNK="EDISAU"
      Read First
      If fstat=[V]CST_AOK
        WTYP  = this.SOH.R_SOP(I).EDISAU
        WTAB  = val([F:ASWP]VALEUR)
        WNODE = func TRTFUNEDI.TRANSCODE(WTYP, WTAB, WCATACT)
        If left$(WNODE,3) = ""
          this.SOH.SOP(I).SAU = this.SOH.R_SOP(I).EDISAU  #STD import will make the final control
        Else
          this.SOH.SOP(I).SAU = left$(WNODE,3)
        Endif
      Endif
      LogicClose File [ASWP]

      #   Formating devilery date in the lines
      this.SOH.SOP(I).SOPSOQ.DEMDLVDAT = format$("D:YYYYMMDD",left$(this.SOH.R_SOP(I).EDIDLVDATLIN, 8))
      this.SOH.SOP(I).SOPSOQ.EXTDLVDAT = format$("D:YYYYMMDD",left$(this.SOH.R_SOP(I).EDIEXTDLVDAT, 8))
      this.SOH.SOP(I).SOPSOQ.MAXDLVDAT = format$("D:YYYYMMDD",left$(this.EDIMAXDLV, 8))                    # 106776
      this.SOH.SOP(I).SOPSOQ.USELIMDAT = format$("D:YYYYMMDD",left$(this.SOH.R_SOP(I).EDIUSELIMDAT, 8))    # 106776


          #Filling discounts or charges in the line.  Now not used in the import model. Pending CRUD in class SOH
#          Local Shortint WDC (4), J
#          For J = 0 To 3
#            WDC(J)=func TRTFUNEDI.ORD_DSCTYP(this.SOH.PLISTC,IND)
#            Case J
#              When 0: If WDC(J)=0 : this.SOH.SOP(I).DISCRGVAL1 = this.SOH.R_SOP(I).EDIDCPER1
#                      Else        : this.SOH.SOP(I).DISCRGVAL1 = this.SOH.R_SOP(I).EDIDCAMT1
#                      Endif
#              When 1: If WDC(J)=0 : this.SOH.SOP(I).DISCRGVAL2 = this.SOH.R_SOP(I).EDIDCPER2
#                      Else        : this.SOH.SOP(I).DISCRGVAL2 = this.SOH.R_SOP(I).EDIDCAMT2
#                      Endif
#              When 2: If WDC(J)=0 : this.SOH.SOP(I).DISCRGVAL3 = this.SOH.R_SOP(I).EDIDCPER3
#                      Else        : this.SOH.SOP(I).DISCRGVAL3 = this.SOH.R_SOP(I).EDIDCAMT3
#                      Endif
#              When 3: If WDC(J)=0 : this.SOH.SOP(I).DISCRGVAL4 = this.SOH.R_SOP(I).EDIDCPER4
#                      Else        : this.SOH.SOP(I).DISCRGVAL4 = this.SOH.R_SOP(I).EDIDCAMT4
#                      Endif
#            Endcase
#          Next J
    Next I
  Endif

  #############################
  #    NOTES
  #############################
  #Filling properties for Notes file
  Local Integer WNBCOUNT : WNBCOUNT = 0
  If WSTATUS = [V]CST_AOK

    For I = 1 To maxtab(this.SOH.R_NOTES) #4 # Only can import 4 lines of notes (2 to header and 2 to footer)
      If this.SOH.R_NOTES(I).NOTLIN = "" #it's a header note
        WNBCOUNT = WNBCOUNT + 1
        If WNBCOUNT <= 4
          Case WNBCOUNT
            When 1:   this.IMP71 = this.SOH.R_NOTES(I).NOT1
                      this.IMP72 = this.SOH.R_NOTES(I).NOT2
                      this.IMP73 = this.SOH.R_NOTES(I).NOT3
                      this.IMP74 = this.SOH.R_NOTES(I).NOT4
            When 2:   this.IMP75 = this.SOH.R_NOTES(I).NOT1
                      this.IMP76 = this.SOH.R_NOTES(I).NOT2
                      this.IMP77 = this.SOH.R_NOTES(I).NOT3
                      this.IMP78 = this.SOH.R_NOTES(I).NOT4
            When 3:   this.IMP81 = this.SOH.R_NOTES(I).NOT1
                      this.IMP82 = this.SOH.R_NOTES(I).NOT2
                      this.IMP83 = this.SOH.R_NOTES(I).NOT3
                      this.IMP84 = this.SOH.R_NOTES(I).NOT4
            When 4:   this.IMP85 = this.SOH.R_NOTES(I).NOT1
                      this.IMP86 = this.SOH.R_NOTES(I).NOT2
                      this.IMP87 = this.SOH.R_NOTES(I).NOT3
                      this.IMP88 = this.SOH.R_NOTES(I).NOT4
          Endcase
        Endif
      Endif

    Next I
  Endif


  #############################
  #   NOTES IN LINES
  #############################
  #Filling properties for Notes lines file

  Local Integer WNBCOUNT : WNBCOUNT = 0
  If WSTATUS = [V]CST_AOK
    For J = 1 To maxtab(this.SOH.R_SOP)
      If this.SOH.R_SOP <> null
        WNBCOUNT = 0
        For I = 1 To maxtab(this.SOH.R_NOTES) #4 # Only can import 4 lines of notes (2 to header and 2 to footer)
          If this.SOH.R_NOTES(I).NOTLIN <> "" and this.SOH.R_NOTES(I).NOTLIN = this.SOH.R_SOP(J).EDISOHLIN
            WNBCOUNT = WNBCOUNT + 1
            If WNBCOUNT <=2
              Case WNBCOUNT
                When 1:   this.SOH.R_SOP(J).IMP91 = this.SOH.R_NOTES(I).NOT1
                          this.SOH.R_SOP(J).IMP92 = this.SOH.R_NOTES(I).NOT2
                          this.SOH.R_SOP(J).IMP93 = this.SOH.R_NOTES(I).NOT3
                          this.SOH.R_SOP(J).IMP94 = this.SOH.R_NOTES(I).NOT4
                When 2:   this.SOH.R_SOP(J).IMP95 = this.SOH.R_NOTES(I).NOT1
                          this.SOH.R_SOP(J).IMP96 = this.SOH.R_NOTES(I).NOT2
                          this.SOH.R_SOP(J).IMP97 = this.SOH.R_NOTES(I).NOT3
                          this.SOH.R_SOP(J).IMP98 = this.SOH.R_NOTES(I).NOT4
              Endcase
            Endif
            WNOTLIN = ""
          Else
            WNBCOUNT = 0
          Endif
        Next I

      Endif
    Next J
  Endif


Return

Funprog QUITAR_CEROS(VS1)
Value Char VS1
Local Char VS2 (30)
VS2=VS1
For I=1 To len(VS1)

  If left$(VS2,1)="0"
     VS2=right$(VS1,I+1)
  Else
     Break
  Endif
Next

End VS2


Funprog ORD_ITMDES(WITMREF)
Value Char WITMREF           # UPC code
  Local File ITMMASTER [ITM]
  Local Char WDES (30)

  Filter [ITM] Where ITMREF=WITMREF
  Read First
  If fstat=[V]CST_AOK

     WDES=[F:ITM]ITMDES1

  Endif

  LogicClose File [ITM]
End WDES

Funprog ORD_ITMVERIF(WITMREF)
Value Char WITMREF           # ITMREF
  Local File ITMMASTER [ITM]
  Local Integer WOK

  Filter [ITM] Where ITMREF=WITMREF
  Read First
  If fstat=[V]CST_AOK

   WOK=1
  Else
   WOK=0

  Endif

  LogicClose File [ITM]
End WOK


