#<AdxTL>@(#)0.0.0.0 $Revision$
#Proceso integracion de pedidos lanzado mediante tarea programada en batch.
$ACTION
#Infbox ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub TRT_INI
  When "EXEC"           : Gosub EXEC_INBAR
  When "TERMINE"        : Gosub TERMINE_INBAR
  When "INIT"           : Gosub INIT_DIA_INBAR
  When "OK"             : Gosub OK_INBAR
  When "END"            : Gosub END_INBAR
Endcase

Return

$TRT_INI
  If clalev([F:ZINPE])<=0  : Local File ZINTEGRADOR    [ZINPE] : Endif

Return

$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

$EXEC_INBAR
  Gosub TRT_INI
  If GSERVEUR
    Onerrgo ERRBATCH
    Call ECR_TRACE("Inicio barrido de stocks de plantas",0) From GESECRAN
  Else
    Call OUVRE_TRACE("Inicio barrido de stocks de plantas") From LECFIC
  Endif

  WMSG = "Barrido de stocks de plantas"
  Call ECR_TRACE(WMSG,0) From GESECRAN
  Call ECR_TRACE(mess(174,100,1),-1) From GESECRAN
  Call ECR_TRACE(mess(51,9010,1),-1) From GESECRAN

  #Infbox("INICIANDO EXE")
  Call ECR_TRACE("Barrido de stocks de plantas",0) From GESECRAN
  System RESULT=chr$(34) + "C:\Program Files (x86)\Azeta\Barrido de stocks X3\Barrido.exe" + chr$(34)

  Gosub IMPBAR

  End
Return

$TERMINE_INBAR
Return

$INIT_DIA_INBAR
Return

$OK_INBAR
Return

$END_INBAR
Return

$IMPBAR
  Local Integer ERRORIMP

  Filter [ZINPE] Where [ZINPE]ZESTADO=3 and [ZINPE]ZINTE='BAR'
  For [ZINPE]
    Gosub INTEGR_FICH
  Next
  Filter [ZINPE]

Return


$INTEGR_FICH

  ##############################################################################

  Call ECR_TRACE("PROCESANDO FICHERO: "+[F:ZINPE]ZFICHENT,0) From GESECRAN
  Call DEBTRANS From GLOCK

  Gosub IMP_ENTREGA

  ##############################################################################

  Call ECR_TRACE("PROCESANDO FICHERO: "+[F:ZINPE]ZFICHREC,0) From GESECRAN
  Call DEBTRANS From GLOCK

  Gosub IMP_RECEPCION

Return


############################################################################################################
$IMP_ENTREGA
  Local Char FICORI(250), FICFIN(250)
  Local Char WAUX(50)
  Local Integer STAT
  Local Integer WESTADO
  WESTADO=0

  STAT=0

  FICORI=filpath("BQT",[F:ZINPE]ZFICHENT,"")
  FICFIN=filpath("ZFP",[F:ZINPE]ZFICHENT,"")

  If [F:ZINPE]ZFICHENT<>"" Then
    #Infbox("LLAMANDO IMPORTACION")
    Call IMPORTSIL("ZSDH",filpath("BQT",[F:ZINPE]ZFICHENT,"")) From GIMPOBJ

    WAUX=[F:ZINPE]ZFICHENT
    #Call MOVE(FICORI,FICFIN,STAT) From ORDSYS

    If filinfo(filpath("BQT",[F:ZINPE]ZFICHENT,"")+".err",0)>0
      Call ECR_TRACE("Error importando entrega",1) From GESECRAN
      ERRORIMP=1
    Endif

    If ERRORIMP=1 Then
      WESTADO=5
    Else
      WESTADO=4
    Endif

    #Se modifican todas las líneas de la tabla ZINTEGRADOR a "Si procesadas" porque estan todas en el mismo fichero de importación
    Update [ZINPE] Where [ZINPE]ZESTADO=3 and [ZINPE]ZFICHENT=WAUX With ZESTADO=WESTADO,ZPROCESADO=2
    If fstat
      GOK=0 : Call FSTA("ZBARRIDO") From GLOCK : STA=14
    Endif
    If GOK<0 : Goto ROLL_IMP_ENTREGA
    Elsif !GOK : Goto AB_IMP_ENTREGA
    Endif
    #Commit
    FILTRANS=0

  Endif


  Return

$AB_IMP_ENTREGA
  #Rollback
  FILTRANS=0
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto IMP_ENTREGA : Endif

$ROLL_IMP_ENTREGA
  #Rollback
  FLTRANS = 0
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto IMP_ENTREGA : Endif

##########################################################################################################################
$IMP_RECEPCION
  Local Char FICORI(250), FICFIN(250)
  Local Char WAUX(50)
  Local Integer STAT
  Local Integer WESTADO
  WESTADO=0

  STAT=0

  FICORI=filpath("BQT",[F:ZINPE]ZFICHREC,"")
  FICFIN=filpath("ZFP",[F:ZINPE]ZFICHREC,"")

  If [F:ZINPE]ZFICHREC<>"" Then
    #Infbox("LLAMANDO IMPORTACION")
    Call IMPORTSIL("ZPTH",filpath("BQT",[F:ZINPE]ZFICHREC,"")) From GIMPOBJ

    WAUX=[F:ZINPE]ZFICHREC
    #Call MOVE(FICORI,FICFIN,STAT) From ORDSYS

    If filinfo(filpath("BQT",[F:ZINPE]ZFICHREC,"")+".err",0)>0
      Call ECR_TRACE("Error importando recepción",1) From GESECRAN
      ERRORIMP=1
    Endif

    If ERRORIMP=1 Then
      WESTADO=5
    Else
      WESTADO=4
    Endif

    #Se modifican todas las líneas de la tabla ZINTEGRADOR a "Si procesadas" porque estan todas en el mismo fichero de importación
    Update [ZINPE] Where [ZINPE]ZESTADO=3 and [ZINPE]ZFICHREC=WAUX With ZESTADO=WESTADO,ZPROCESADO=2
    If fstat
      GOK=0 : Call FSTA("ZBARRIDO") From GLOCK : STA=14
    Endif
    If GOK<0 : Goto ROLL_IMP_RECEPCION
    Elsif !GOK : Goto AB_IMP_RECEPCION
    Endif
    #Commit
    FILTRANS=0

  Endif

  Return

$AB_IMP_RECEPCION
  #Rollback
  FILTRANS=0
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto IMP_RECEPCION : Endif

$ROLL_IMP_RECEPCION
  #Rollback
  FLTRANS = 0
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto IMP_RECEPCION : Endif

