$ACTION
Case ACTION
When "IMPORT"        : Gosub IMPORT
When "IMP_ZONE"      : Gosub IMP_ZONE
Endcase
Return


$IMPORT
Case IMPFIC
When "TSK"
  If GREP = "C" Then
    [M:TSK1]ZPERIODO=[F:TSK]ZPERIODO
    [M:TSK1]TSKDES  =[F:TSK]TSKDES
  Endif
Endcase
Return

