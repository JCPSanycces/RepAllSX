# Clase EDISDHEM_R_SDD


$METHODS
Case [L]CURPTH
   When ""
      Case [L]ACTION
          When "MET_AFTER_LOAD_REPRESENTATION" : Gosub MET_AFTER_LOAD_REPRESENTATION
      Endcase
Endcase

Return


$PROPERTIES
Case [L]CURPRO
Endcase
Return


$MET_AFTER_LOAD_REPRESENTATION
#Return
#$TT
  Local File SPACK [SPH]
  Filter [F:SPH] Where VCRNUM=this.SDH.SDHNUM

  Raz [F:SPH]
  For [F:SPH]
     Break
  Next
  Filter [F:SPH]
  If [F:SPH]VCRNUM=""
     #Formating ZEDINUMPAQ property
     this.ZEDINUMPAQ=format$("N0:11.3#",1)

     #Formating ZEDITIPEMB property
     this.ZEDITIPEMB="PK"

     #Formating ZEDITIPEMB property
     this.ZEDISSCC1=""
  Else
     #Formating ZEDINUMPAQ property
     this.ZEDINUMPAQ=format$("N0:11.3#",1)

     #Formating ZEDITIPEMB property
     this.ZEDITIPEMB=[F:SPH]PCK

     #Formating ZEDITIPEMB property
     this.ZEDISSCC1=[F:SPH]SCCCOD
  Endif

  LogicClose File [SPH]
Return


