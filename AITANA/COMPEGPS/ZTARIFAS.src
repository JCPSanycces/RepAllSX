#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
Call IMPORTAR
End

$ACTION
Case ACTION
    When "EXEC": Call IMPORTAR
Endcase
#    When "INIT"
#    When "AVANT_PAR"
#    When "CONTROLE"
#    When "TERMINE"
#    When "SORTIE"
Return

Subprog IMPORTAR
Local Integer STAT
Local Integer TOTOK, LINOK, CAPOK
Local Char RESULT  (200)(50)
Local Char FICHERO (200), NOMFICIMPORTTARIFA(200), NOMFICIMPORTNOCOMER(200), NOMFICIMPORTREF(200)
Local Char VTARIFA(6), VPROVEEDOR(15), VTFECINI(8), VTFECFIN(8)
Local Char VINDICE(10), VEAN(13), VREF(20), VDESC(30), VTCANMIN(20), VTCANMAX(20), VTIMPORTE(20)
Local Char VITEM(20)
Local Integer VCANMIN, VCANMAX
Local Decimal VIMPORTE
Local Date VFECINI, VFECFIN
Local Integer A, PASO, FICTAR, FICNOCOM

Gosub INI_VAR

ORDSYS = "dir /b "+filpath("TARIFAS","","")+"\*.csv"
Call SYSTEME2 (adxmac(0),ORDSYS,"",STAT,RESULT) From ORDSYS
If GSERVEUR
  Call ECR_TRACE("Importación de tarifas",0) From GESECRAN
Else
  Call OUVRE_TRACE("Importación de tarifas") From LECFIC
Endif

For JJ=0 To dim(RESULT)-1
    If RESULT(JJ)<>''
    If right$(RESULT(JJ),len(RESULT(JJ))-3)='.csv' or right$(RESULT(JJ),len(RESULT(JJ))-3)='.CSV'
      Onerrgo ERRGENERAL
        TOTOK = 1
        CAPOK = 1
        Raz A, VTARIFA, VPROVEEDOR, VINDICE, VFECINI, VFECFIN, FICTAR, FICNOCOM
        Call ECR_TRACE("Fichero a importar: "+RESULT(JJ),0) From GESECRAN
        Local Char NOMFICINI(250) : NOMFICINI= filpath("TARIFAS","","") + "\" +RESULT(JJ)
        Gosub ABRIRFICHEROS
        PASO = 1
        Rdseq VTARIFA, VPROVEEDOR, VINDICE, VTFECINI, VTFECFIN Using [ORI]
        While !fstat
            A+=1
            If A = 1
              # Primer linea
              Gosub VERIF_TARIFA
              Gosub VERIF_PROVEEDOR
              Gosub VERIF_FECHAS
              PASO = 5
              Rdseq VEAN, VREF, VDESC, VTCANMIN, VTCANMAX, VTIMPORTE Using [ORI] # Primera linea
              If !fstat
                  A+=1
                  Rdseq VEAN, VREF, VDESC, VTCANMIN, VTCANMAX, VTIMPORTE Using [ORI] #Segunda linea con los nombres de los campos
              Endif
            Else
              LINOK = 1
              Gosub VERIF_ITEM
              Gosub VERIF_CANTIDADES
              Gosub VERIF_IMPORTE
              #Gosub VERIF_DTO
              If LINOK and CAPOK
                  Gosub FICHERO_REFERENCIAS
                  Gosub FICHERO_TARIFA
              Else
                  If TOTOK
                      Gosub FICHERO_NOCOMERCIAL
                  Endif
              Endif
            Endif
            Rdseq VEAN, VREF, VDESC, VTCANMIN, VTCANMAX, VTIMPORTE Using [ORI]
            Raz VITEM, VCANMIN, VCANMAX, VIMPORTE
        Wend
        PASO = 99

FICHERO:
        Openi  Using [ORI]
        Openo  Using [EXX]
        Openo  Using [EYY]
        Openo  Using [EZZ]
        Gosub IMPTARIFAS
        Gosub IMPTARNOCOMER
        If TOTOK
          Gosub ACTUALIZA_REFERENCIAS
        Endif
        If TOTOK
          Call MOVE(NOMFICINI,filpath("TARIFAS\PROCESADO","","") + "\" + RESULT(JJ),STAT)    From ORDSYS
        Else
          Call MOVE(NOMFICINI,filpath("TARIFAS\INCIDENCIAS","","") + "\" + RESULT(JJ),STAT)    From ORDSYS
        Endif
        # Eliminamos los ficheros generados de importación, da un error
        #Call SYSTEME (adxmac(1), 'ae_rm'+NOMFICIMPORTTAR," ", STAT) From ORDSYS
        #Call SYSTEME (adxmac(1), 'ae_rm'+NOMFICIMPORTNOCOM," ", STAT) From ORDSYS
    Endif
    Endif
Next
FIN:
If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

End

$INI_VAR
    Global Integer VG_IMPSIL
    Global Char CP_FORMATNUM(30)
    Global Char CP_FORMATAMT(30)
    Global Char CP_FORMATDAT(30)
    VG_IMPSIL = 1
    CP_FORMATNUM = "NZ0>:12"
    CP_FORMATAMT = "NZ0>:12.2"
    CP_FORMATDAT = "D<:YYYYMMDD"
Return

$ERRGENERAL
TOTOK = 0
If PASO <>99
  #Errro en la lectura de la primera linea
  Call ECR_TRACE("La linea " + num$(A) + " del fichero no tiene correcto formato"- errmes$(errn)-num$(errl)-errm,1) From GESECRAN
  Goto FICHERO
Endif
If PASO = 99
  Call ECR_TRACE("Al realizar la importación de los datos se ha producido un error"- errmes$(errn)-num$(errl)-errm,1) From GESECRAN
  Goto FIN
Endif
End

$VERIF_TARIFA
PASO = 2
If !clalev([F:PPC])  : Local File PPRICCONF   [PPC]  : Endif
Read [F:PPC]PPC0 = VTARIFA
If fstat
  TOTOK = 0
  CAPOK = 0
  Call ECR_TRACE("El código de tarifa no existe",1) From GESECRAN
Endif
Return

$VERIF_PROVEEDOR
PASO = 3
If !clalev([F:BPS])  : Local File BPSUPPLIER   [BPS]  : Endif
Read [F:BPS]BPS0 = VPROVEEDOR
If fstat
  TOTOK = 0
  CAPOK = 0
  Call ECR_TRACE("El código de proveedor no existe",1) From GESECRAN
Endif
Return

$VERIF_FECHAS
PASO = 4
  VFECINI = gdat$(val(mid$(VTFECINI,1,2)), val(mid$(VTFECINI,3,2)), val(mid$(VTFECINI,5,4)))
PASO = 5
  VFECFIN = gdat$(val(mid$(VTFECFIN,1,2)), val(mid$(VTFECFIN,3,2)), val(mid$(VTFECFIN,5,4)))
  If VFECFIN < VFECINI
    TOTOK = 0
    CAPOK = 0
    Call ECR_TRACE("La fecha final es menor que la inicial",1) From GESECRAN
  Endif
Return

$VERIF_ITEM
PASO = 6
If VEAN<>''
    If !clalev([F:ITM])  : Local File ITMMASTER[ITM]  : Endif
    Filter [ITM] Where EANCOD = VEAN
    Read [ITM] ITM0 First
    If fstat
      LINOK = 0
      Call ECR_TRACE("Linea " + num$(A) + "->NO se encuentra el código EAN",0) From GESECRAN
    Else
        VITEM = [F:ITM]ITMREF
    Endif
Else
      LINOK = 0
      Call ECR_TRACE("Linea " + num$(A) + "->Código EAN Vacio",0) From GESECRAN
Endif
Return

$VERIF_CANTIDADES
PASO = 7
VCANMIN = val(VTCANMIN)
If VCANMIN = 0: VCANMIN = 1: Endif
PASO = 8
VCANMAX = val(VTCANMAX)
If VCANMAX = 0: VCANMAX = 99999999: Endif
If VCANMIN > VCANMAX
    LINOK = 0
    Call ECR_TRACE("Linea " + num$(A) + "->La cantidad mínima es superior a la máxima",0) From GESECRAN
Endif
Return

$VERIF_IMPORTE
PASO = 9
VIMPORTE = val(ctrans(VTIMPORTE,",","."))
If VIMPORTE <= 0
    LINOK = 0
    Call ECR_TRACE("Linea " + num$(A) + "->El precio es cero o inferior a cero",0) From GESECRAN
Endif
Return

$VERIF_DTO
PASO = 10
VDTO= val(ctrans(VTDTO,",","."))
If VDTO >= 100
    LINOK = 0
    Call ECR_TRACE("Linea " + num$(A) + "->El descuento supera el máximo ",0) From GESECRAN
Endif
Return

$FICHERO_TARIFA
If FICTAR = 0
    #Primera linea de las tarifas
    Wrseq "E", VTARIFA, VINDICE, format$(CP_FORMATDAT,VFECINI), format$(CP_FORMATDAT,VFECFIN) Using [EXX]
Endif
FICTAR += 1
Wrseq "L", num$(0), VPROVEEDOR, VITEM,"UN", format$(CP_FORMATNUM,VCANMIN), format$(CP_FORMATNUM,VCANMAX), "EUR", format$(CP_FORMATAMT,VIMPORTE) Using [EXX]
Return


$FICHERO_NOCOMERCIAL
FICNOCOM = 1
Wrseq "L", num$(date$)+num$(time$)+num$(A), RESULT(JJ), VTARIFA, VINDICE, VPROVEEDOR, format$(CP_FORMATDAT,VFECINI), format$(CP_FORMATDAT,VFECFIN), VEAN, VREF, VDESC, format$(CP_FORMATNUM,VCANMIN),
& format$(CP_FORMATNUM,VCANMAX), format$(CP_FORMATAMT,VIMPORTE) Using [EYY]

Return

$FICHERO_REFERENCIAS
Local Integer RSLT
    If VREF <>''
        If !clalev([F:ITP])  : Local File ITMBPS[ITP]  : Endif
        Read [ITP]ITP0 = VITEM;VPROVEEDOR
        If !fstat
#            If [F:ITP]ITMREFBPS = ''
#                Wrseq VITEM, VPROVEEDOR, VREF, VDESC Using [EZZ]
#           Endif
#  Cambio
            If [F:ITP]ITMREFBPS = '' or [F:ITP]ITMREFBPS = VITEM
              Call ISNUMERIC (VREF, RSLT)
              If len(VREF)<= 6 and RSLT = 1
                Wrseq VITEM, VPROVEEDOR, VREF + ".", VDESC Using [EZZ]
              Else
                Wrseq VITEM, VPROVEEDOR, VREF, VDESC Using [EZZ]
              Endif
            Endif
        Endif
    Endif
Return

$ACTUALIZA_REFERENCIAS
        If !clalev([F:ITP])  : Local File ITMBPS[ITP]  : Endif
        Openi NOMFICIMPORTREF Using [EZZ]
        Iomode adxifs  ";"                 Using [EZZ]
        Iomode adxirs  chr$(13)+chr$(10)   Using [EZZ]
        Iomode adxium  GASCII              Using [EZZ]
        Rdseq VITEM, VPROVEEDOR, VREF, VDESC Using [EZZ]
        While !fstat
            Update [ITP] Where ITMREF = VITEM & BPSNUM = VPROVEEDOR & ITMREFBPS = '' With ITMREFBPS = VREF
            If !fstat
                Call ECR_TRACE("Artículo " + VITEM + "-> Referencia actualizada de proveedor " + VPROVEEDOR,0) From GESECRAN
                Rdseq VITEM, VPROVEEDOR, VREF, VDESC Using [EZZ]
            Else
                Call ECR_TRACE("Error al actualizar la referencia del articulo " + VITEM + " del proveedor " + VPROVEEDOR,1) From GESECRAN
                TOTOK = 0
            Endif
        Wend
        Openi  Using [EZZ]
Return


$IMPTARIFAS
        If FICTAR and TOTOK
            Call IMPORTSIL("ZTPP",NOMFICIMPORTTARIFA) From GIMPOBJ
            If GERRTRACE <> 0
                TOTOK=0
                Call ECR_TRACE("Error importando fichero de tarifas",1) From GESECRAN
            Endif
        Endif
Return

$IMPTARNOCOMER
        If FICNOCOM and TOTOK
            Call IMPORTSIL("ZTP",NOMFICIMPORTNOCOMER) From GIMPOBJ
            If GERRTRACE <> 0
                TOTOK=0
                Call ECR_TRACE("Error importando fichero tarifas no comerciales",1) From GESECRAN
            Endif
        Endif
Return

$ABRIRFICHEROS
        Openi  NOMFICINI Using [ORI]
        Iomode adxifs  ";"                 Using [ORI]
        Iomode adxirs  chr$(10)            Using [ORI]
        Iomode adxium  GASCII              Using [ORI]
        NOMFICIMPORTTARIFA = filpath("TARIFAS\IMPORT","","") + "\TAR" + RESULT(JJ)
        Openo NOMFICIMPORTTARIFA , 0     Using [EXX]
        Iomode adxifs  ";"                 Using [EXX]
        Iomode adxirs  chr$(13)+chr$(10)   Using [EXX]
        Iomode adxium  GASCII              Using [EXX]
        NOMFICIMPORTNOCOMER = filpath("TARIFAS\IMPORT","","") + "\NOCOM" + RESULT(JJ)
        Openo NOMFICIMPORTNOCOMER , 0     Using [EYY]
        Iomode adxifs  ";"                 Using [EYY]
        Iomode adxirs  chr$(13)+chr$(10)   Using [EYY]
        Iomode adxium  GASCII              Using [EYY]
        NOMFICIMPORTREF= filpath("TARIFAS\IMPORT","","") + "\REF" + RESULT(JJ)
        Openo NOMFICIMPORTREF, 0     Using [EZZ]
        Iomode adxifs  ";"                 Using [EZZ]
        Iomode adxirs  chr$(13)+chr$(10)   Using [EZZ]
        Iomode adxium  GASCII              Using [EZZ]
Return

Subprog ISNUMERIC(VVALUE, RSLT)
Variable Char VVALUE
Value Integer RSLT
Local Integer I
Local Char NUMEROS
NUMEROS = sigma( I = 0, 9, chr$(48+I) )
RSLT = 1

  For I = 1 To len(VVALUE)
    If instr(1,NUMEROS, mid$(VVALUE, I, 1)) = 0
      RSLT = 0
    Endif
  Next I
End

