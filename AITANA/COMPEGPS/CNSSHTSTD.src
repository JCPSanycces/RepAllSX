#<AdxTL>@(#)2.0.0.0 $Revision$
#############################################################################
#                        Consultation                                       #
#                        Ruptures matières                                  #
#                                                                GPAO 08.99 #
#############################################################################
# Paramètres de la consultation via PARAM()                                 #
# 1  = site                                                                 #
# 2  = origine (1 = OF, 2 = Commandes client, 3 = les 2)                    #
# 3  = article                                                              #
# 4  = pièce                                                                #
# 5  = Date besoin                                                          #
# 6  = filtre        + 1 - rupture sur global                               #
#                    + 2 - rupture sur détaillé                             #
# 7 = tri                                                                   #
#                      1 - date besoin                                      #
#                      2 - priorité                                         #
#                      3 - article                                          #
#                      4 - type rupture                                     #
#############################################################################
Local Char PARAM(15)(1..7)
PARAM(1) ="PAR"
PARAM(2) ="8"
PARAM(3) =""
PARAM(4) =""
PARAM(5) =""
PARAM(6) =""
PARAM(7) =""
Call GCONSULT("SHT","",PARAM) From GCONSULT
End

#############################################################################
$ACTION
Case ACTION
 When "OUVRE"      : Gosub OUVRE
 When "LECTURE"    : Gosub LECTURE
 When "AB3_NBLIG"  : Gosub AB3_NBLIG
 When "BB3_NBLIG"  : Gosub BB3_NBLIG
Endcase
Return

#############################################################################
# analyse paramères, initialisations, ouvertures et déclarations
$OUVRE
Local Integer WFLT
Local Integer WSRT,WRET
Local Integer I, J, WLEC,WDER, WPREM,WPOS                  # llc 09.02 15624
Local Char    WNUM
Local Char    CRITERE(255)
Local Char    CRITERE1(255)
Local Char    CRITERE2(255)
Local Char    CRITERE3(255)
Local Decimal WDIS
Local Char    WSUP
Local Integer WTYPLOC, WSTA

Local Char    SSTOFCY(GLONFCY)
Local Char    SITMREF(GLONITM)
Local Decimal SSTOCOU
Local Integer SSEQ

Default Mask [M:SHT1]
Gosub DEFCRIT

NAVIG="CONSSHT"
If [M:CSHT]SHTG <> 2 & [M:CSHT]SHTD <> 2
    [M:CSHT]SHTG = 2
    [M:CSHT]SHTD = 2
Endif
If !find([M:CSHT]TRI,1,2,3,4) : [M:CSHT]TRI = 1 : Endif

If clalev([F:ITF])=0 Local File ITMFACILIT [ITF]  Endif

# V6 Affectations
Gosub OPEN_MTO From MTOLINKLIB

Return

#############################################################################
# analyse paramètres
$DEFCRIT
For I = 1 To dim(PARAM)
    Case I
        When 1 : # site
                 If PARAM(I) <> ""
                     Call LECTURE("FCY",PARAM(I),"") From CONTOBJ
                     #If !fstat & [F:FCY]MFGFLG = 2 : [M:SHT1]STOFCY = PARAM(I) : Endif
                     If !fstat : [M:SHT1]STOFCY = PARAM(I) : Endif
                 Endif
        When 2 : # code origine
                 If PARAM(I) = "" : PARAM(I) = "1" : Endif
                 [M:SHT1]WORIGINE = PARAM(I)
                 Case PARAM(I)
                     When "1": [M:SHT1]WVCRTYP = 10   # OF
                     When "2": [M:SHT1]WVCRTYP = 2    # Commandes Vente
                     When "3": [M:SHT1]WVCRTYP = 10   # OF + Commandes
                     When "4": [M:SHT1]WVCRTYP = 4    # Livraisons
                     When "5": [M:SHT1]WVCRTYP = 10   # OF + Livraisons
                     When "6": [M:SHT1]WVCRTYP = 2    # Commandes + Livraisons
                     When "7": [M:SHT1]WVCRTYP = 10   # OF + Commandes + Livraisons
                     When "8": [M:SHT1]WVCRTYP = 36   # EO               # FQ 53604 GA 03/2009
                 Endcase
                 # FQ 66483 GA 08/2010 utiliser Sélection F12 du type de données VCR, en renseignant WVCROBJ
                 Call AM_WVCRTYP([M:SHT1]WVCRTYP)
        When 3 : # article
                 If PARAM(I) <> ""
                     Read [ITM]ITM0 = PARAM(I)
                     If !fstat
                         [M:SHT1]ITMREFSTR = PARAM(I)
                         [M:SHT1]ITMREFEND = PARAM(I)
                     Endif
                 Endif
        When 4 : # Pièce
                 If PARAM(I) <> ""
                     [M:SHT1]VCRNUMSTR = PARAM(I)
                     [M:SHT1]VCRNUMEND = PARAM(I)
                 Endif
        When 5 : # date début
                 If PARAM(I) <> ""
                     If instr(1,PARAM(I),"/")
                         [M:SHT1]STRDATSTR = "["+PARAM(I)+"]"
                         [M:SHT1]STRDATEND = "["+PARAM(I)+"]"
                     Else
                         [M:SHT1]STRDATSTR = PARAM(I)
                         [M:SHT1]STRDATEND = PARAM(I)
                     Endif
                 Endif
        When 6 : # filtre
                 If PARAM(I) <> ""
                     WFLT = val(PARAM(I))
                     If WFLT < 0 | WFLT > 3 : WFLT = 3 : Endif
                     If WFLT > 1 : [M:CSHT]SHTD = 2 : WFLT -= 2 : Endif
                     If WFLT > 0 : [M:CSHT]SHTG = 2 : WFLT -= 1 : Endif
                 Endif
        When 7 : # tri
                 If PARAM(I) <> ""
                     WSRT = val(PARAM(I))
                     If WSRT < 0 | WSRT > 4  : WSRT = 3 : Endif
                     [M:CSHT]TRI = WSRT
                 Endif
        When Default: Break
    Endcase
Next I
# copie de l'écran critères (CSHT) vers le masque 0 (SHT1)
Gosub CRITENT From =PROGCNS
Return


############################################################
$LECTURE
Local Char SVBPRNUM(GLONBPR)   # FGR 27/06/2014 : X3SUIVI101011

# si le tri n'est pas passé en paramètre, pas de chargement automatique
If [M:SHT1]STOFCY = ""  : NBLU = 0 : Return : Endif
If PARAM(7) = "" : PARAM(7) = "1" : Endif
Gosub CHANGE_MSK From GCONSULT
If CHGPAG < 0 : NOL = MAXLIG : Endif

# filtres
Gosub LOAD_FILTER
If PROGSPE <> ""
  ACTION = "FILTRE" : Gosub ACTION From =PROGSPE
Endif

# ------------------------------------------------------- #
# CHGPAG = 1    :    Recherche                            #
# ------ = 2    :    Suite                                #
#        = 3    :    F5 (Rafraichissement page courante)  #
# CHGPAG = -1   :    Dernier                              #
# ------ = -2   :    Retour (Page précédente)             #
# ------------------------------------------------------- #
# sr 09.01 Si aucun type d'allocation sélectionné, on sort.
If CRITERE1 = ""  :  Raz [M:SHT2] : Return : Endif
# application des Filtres
If CHGPAG > 0
    SUITE=1
    If    CHGPAG = 1 : RETOUR = 1 : Elsif CHGPAG = 2 : RETOUR = 2 : Endif
    Case [M:CSHT]TRI
      When 1 : # tri par date
       If [M:SHT1]WVCRTYP=4
                Link [STA] With [ORD]ORD3=[F:STA]STOFCY;[F:STA]VCRTYP;[F:STA]VCRNUM;[F:STA]VCRLIN;[F:STA]VCRSEQ
&                          As [SHT]
&                          Order By [F:STA]BESDAT;[F:STA]ITMREF;[F:STA]STOCOU;[F:STA]SEQ
       Else
                Link [STA] With [ORD]ORD3=[F:STA]STOFCY;[F:STA]VCRTYP;[F:STA]VCRNUM;[F:STA]VCRLIN;[F:STA]VCRSEQ
&                          As [SHT]
&                          Order By [F:ORD]STRDAT;[F:STA]ITMREF;[F:STA]STOCOU;[F:STA]SEQ
       Endif

       If find(CHGPAG,2,3)
          J=([M:SHT2]NBLIG-1)*(CHGPAG=2)
          Filter [SHT] Where Key > [M:SHT2]STRDAT(J); [M:SHT2]ITMREF(J); [M:SHT2]STOCOU(J); [M:SHT2]SEQ(J)
       Endif

      When 3 : # tri par article
       Link [STA] With [ORD]ORD3=[F:STA]STOFCY;[F:STA]VCRTYP;[F:STA]VCRNUM;[F:STA]VCRLIN;[F:STA]VCRSEQ
&                 As [SHT]
&                 Order By [F:STA]ITMREF;[F:STA]STOCOU;[F:STA]SEQ

       If find(CHGPAG,2,3)
          J=([M:SHT2]NBLIG-1)*(CHGPAG=2)
          Filter [SHT] Where Key > [M:SHT2]ITMREF(J); [M:SHT2]STOCOU(J); [M:SHT2]SEQ(J)
       Endif
    Endcase
Else
    RETOUR=1
    If    CHGPAG = -1 : SUITE = 1 : Else  SUITE = 2 : Endif
    Case [M:CSHT]TRI
      When 1 : # tri par date
       If [M:SHT1]WVCRTYP=4
               Link [STA] With [ORD]ORD3=[F:STA]STOFCY;[F:STA]VCRTYP;[F:STA]VCRNUM;[F:STA]VCRLIN;[F:STA]VCRSEQ
&                         As [SHT]
&                         Order By [F:STA]BESDAT Desc; [F:STA]ITMREF Desc ;[F:STA]STOCOU Desc;[F:STA]SEQ Desc
        Else
               Link [STA] With [ORD]ORD3=[F:STA]STOFCY;[F:STA]VCRTYP;[F:STA]VCRNUM;[F:STA]VCRLIN;[F:STA]VCRSEQ
&                         As [SHT]
&                         Order By [F:ORD]STRDAT Desc; [F:STA]ITMREF Desc ;[F:STA]STOCOU Desc;[F:STA]SEQ Desc
        Endif

        If CHGPAG <> -1
           Filter [SHT] Where Key > [M:SHT2]STRDAT(0); [M:SHT2]ITMREF(0); [M:SHT2]STOCOU(0); [M:SHT2]SEQ(0)
        Endif

      When 3 : # tri par article
       Link [STA] With [ORD]ORD3=[F:STA]STOFCY;[F:STA]VCRTYP;[F:STA]VCRNUM;[F:STA]VCRLIN;[F:STA]VCRSEQ
&                            , [ITM]ITM0=[F:STA]ITMREF
&                  As [SHT]
&                  Order By [F:STA]ITMREF Desc ;[F:STA]STOCOU Desc;[F:STA]SEQ Desc

        If CHGPAG <> -1
           Filter [SHT] Where Key > [M:SHT2]ITMREF(0); [M:SHT2]STOCOU(0); [M:SHT2]SEQ(0)
        Endif

    Endcase
Endif

# raz du masque
If !find(CHGPAG,2,-2) : Raz [M:SHT2] : Endif

# lecture
$BOUCLE
Raz SSTOFCY, SITMREF, SSTOCOU, SSEQ

For [SHT] Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3)

  # problème double affichage ...
  If SSTOFCY <> ""
      If [F:STA]STOFCY = SSTOFCY &
&        [F:STA]ITMREF = SITMREF &
&        [F:STA]STOCOU = SSTOCOU &
&        [F:STA]SEQ    = SSEQ
         Goto SUIV
      Endif
   Endif

  SSTOFCY = [F:STA]STOFCY
  SITMREF = [F:STA]ITMREF
  SSTOCOU = [F:STA]STOCOU
  SSEQ    = [F:STA]SEQ

  If NBLU = 1
     If CHGPAG = 2 | CHGPAG = -2 : Raz [M:SHT2] : Endif
     NBLU = 2
  Endif

  If CHGPAG > 0
     If NOL >= MAXLIG-1 : SUITE = 2 : Break : Endif
     NOL    += 1
  Else
     If NOL <= 0 : RETOUR = 2 : Break : Endif
     NOL    -= 1
  Endif
  nolign = NOL+1

  Gosub FILLTAB

$SUIV
Next

Filter [SHT]
Return

#############################################################################
# Chargements spéciaux
$FILLTAB
SVBPRNUM = [F:ORD]BPRNUM     # FGR 27/06/2014 : X3SUIVI101011
[M:SHT2] = [F:ORD]
[M:SHT2] = [F:STA]

If [M:SHT2]BPRNUM(nolign-1) = "" and SVBPRNUM <> "" Then
  # FGR 27/06/2014 : X3SUIVI101011
  [M:SHT2]BPRNUM(nolign-1) = SVBPRNUM
Endif

If [M:SHT1]WVCRTYP=4
 [M:SHT2]STRDAT(nolign-1) = [F:STA]BESDAT
Endif

Case [F:STA]ALLTYP
    When 4: [M:SHT2]ALLTYP(nolign-1) = 3
    When 5: [M:SHT2]ALLTYP(nolign-1) = 1
Endcase

If [F:ITM]ITMREF <> [F:STA]ITMREF
    Read [ITM]ITM0 = [F:STA]ITMREF
    If fstat : Raz [F:ITM] : Endif
Endif

#lecture ITMFACILIT  pour recuperer STOMGTCOD   hcb ST
If [F:ITF]STOFCY <> [F:STA]STOFCY | [F:ITF]ITMREF <> [F:STA]ITMREF
   Read [ITF]ITF0 = [F:STA]ITMREF;[F:STA]STOFCY
   If fstat : Raz [F:ITF] : Endif
Endif

# (titres llc v130)
If [F:ITF]STOMGTCOD > 2 & dim([M:SHT2]DEFPOT(nolign-1)) > 0
    [M:SHT2]DEFPOT(nolign-1) = [F:ITM]DEFPOT
Else
    If dim([M:SHT2]QTYSTU(nolign-1)) > 0 : [M:SHT2]QTYSTU(nolign-1) = 0 : Endif
    If dim([M:SHT2]DEFPOT(nolign-1)) > 0 : [M:SHT2]DEFPOT(nolign-1) = 0 : Endif
Endif

#[M:SHT2]ITMDES1(nolign-1) = [F:ITM]ITMDES1
Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:SHT2]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
[M:SHT2]STU(nolign-1)     = [F:ITM]STU
[M:SHT2]ALLQTY(nolign-1) = [F:STA]QTYSTUACT

Raz WDIS
Call LECITM2([M:SHT1]STOFCY,[M:SHT2]ITMREF(nolign-1),WSUP,WRET) From STKLIB
If WRET=0
    Raz WNUM
    If [M:SHT2]VCRTYP(nolign-1)=2
        If [F:SOQ]SOHNUM<>[M:SHT2]VCRNUM(nolign-1)
&        | [F:SOQ]SOPLIN<>[M:SHT2]VCRLIN(nolign-1)
&        | [F:SOQ]SOQSEQ<>[M:SHT2]VCRSEQ(nolign-1)
            Read [SOQ]SOQ0=[M:SHT2]VCRNUM(nolign-1);[M:SHT2]VCRLIN(nolign-1);[M:SHT2]VCRSEQ(nolign-1)
            If fstat : Raz [F:SOQ] : Endif
        Endif
        # --> Récupération du paramètre vente : USERERBPC : Consommation réservations clients
        Local Char     WPARAM(10)
        Call PARAM([M]STOFCY,"USERERBPC",WPARAM) From ADOVAL
        If find(val(WPARAM),2,3)
            WNUM=vireblc(format$("K:15X",[F:SOQ]BPCORD)+format$("K:3X",[F:SOQ]BPAADD),1)
        Endif
    Endif
    Call STODISALL([M:SHT1]STOFCY,[M:SHT2]ITMREF(nolign-1),[M:SHT2]VCRTYP(nolign-1),
&                  [M:SHT2]ALLTYP(nolign-1),2,2,1,"",WNUM,WDIS,WRET) From STKALL
Endif

[M:SHT2]AVAQTY(nolign-1) = WDIS

If [M:SHT2]VCRTYP(nolign-1)=4
    If [F:SDH]SDHNUM <> [M:SHT2]VCRNUM(nolign-1)
        Read [SDH]SDH0 = [M:SHT2]VCRNUM(nolign-1)
        If fstat : Raz [F:SDH] : Endif
    Endif
    [M:SHT2]BPRNUM(nolign-1) = [F:SDH]BPCORD
    [M:SHT2]ORIFCY(nolign-1) = [F:SDH]SALFCY
Elsif [M:SHT2]VCRTYP(nolign-1)=5
    If [F:SIH]NUM <> [M:SHT2]VCRNUM(nolign-1)
        Read [SIH]SIH0 = [M:SHT2]VCRNUM(nolign-1)
        If fstat : Raz [F:SIH] : Endif
    Endif
    [M:SHT2]BPRNUM(nolign-1) = [F:SIH]BPR
    [M:SHT2]ORIFCY(nolign-1) = [F:SIH]FCY
Endif

Return

#############################################################################
# Préparation du filtre                                                     #
#############################################################################
$LOAD_FILTER
Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3

If [M:CSHT]SHTG = 2
    CRITERE  = "[F:STA]ALLTYP=5"
    Gosub LOAD_CRITERE
Endif

If [M:CSHT]SHTD = 2
    CRITERE  = "[F:STA]ALLTYP=4"
    Gosub LOAD_CRITERE
Endif

If [M:CSHT]SHTG = 2 | [M:CSHT]SHTD = 2
# fin de la première partie
    CRITERE1 += ")"
Endif

#sr pour ne pas récupérer un CRITERE chargé si on veut toutes les allocs
Raz CRITERE
Case [M:SHT1]WVCRTYP
    When 10: CRITERE  = "[F:STA]VCRTYP=10"
    When 2 : CRITERE  = "[F:STA]VCRTYP=2"
    When 4 : CRITERE  = "find([F:STA]VCRTYP,4,5)<>0"
    When 36: CRITERE  = "[F:STA]VCRTYP=36"                          # FQ 53604 GA 03/2009
Endcase
Gosub LOAD_CRITERE2

# site
If [M:SHT1]STOFCY <> ""
   CRITERE = "[F:STA]STOFCY=[M:SHT1]STOFCY"
   Gosub LOAD_CRITERE2
Endif

# Dépôt (PLI, le 29/01/2010)
If dim([M:SHT1]WRH)>0 & [M:SHT1]WRH <> ""
   CRITERE = "[F:STA]WRH=[M:SHT1]WRH"
   Gosub LOAD_CRITERE2
Endif

# article
If [M:CSHT]ITMREFSTR <> ""
    CRITERE = "[F:STA]ITMREF>=[M:CSHT]ITMREFSTR"
    Gosub LOAD_CRITERE2
Endif
If [M:CSHT]ITMREFEND <> ""
    CRITERE = "[F:STA]ITMREF<=[M:CSHT]ITMREFEND"
    Gosub LOAD_CRITERE2
Endif

# OF
If [M:CSHT]VCRNUMSTR <> ""
   CRITERE = "[F:STA]VCRNUM>=[M:CSHT]VCRNUMSTR"
   Gosub LOAD_CRITERE2
Endif
If [M:CSHT]VCRNUMEND <> ""
   CRITERE = "[F:STA]VCRNUM<=[M:CSHT]VCRNUMEND"
   Gosub LOAD_CRITERE2
Endif

# date
#   Pour les livraisons et factures, il n'y a pas d'enregistrement en-cours
#   --> On prend la date du besoin de l'enregistrement allocation
Case [M:SHT1]WVCRTYP
  When 4 : # Livraison
    If [M:CSHT]STRDATSTR <> [0/0/0]
       CRITERE = "[F:STA]BESDAT>=[M:CSHT]STRDATSTR"
       Gosub LOAD_CRITERE3
    Endif
    If [M:CSHT]STRDATEND <> [0/0/0]
       CRITERE = "[F:STA]BESDAT<=[M:CSHT]STRDATEND"
       Gosub LOAD_CRITERE3
    Endif
  When 2 : # Commandes de vente : # GH 19/11/13 bug 93830
    If [M:CSHT]STRDATSTR <> [0/0/0]
       CRITERE = "[F:ORD]ENDDAT>=[M:CSHT]STRDATSTR"
       Gosub LOAD_CRITERE3
    Endif
    If [M:CSHT]STRDATEND <> [0/0/0]
       CRITERE = "[F:ORD]ENDDAT<=[M:CSHT]STRDATEND"
       Gosub LOAD_CRITERE3
    Endif
  When  Default
    # GH 12/12/11 bug 78559
    # Raz CRITERE
    # If [M:CSHT]STRDATSTR <> [0/0/0]
    #    CRITERE = "([F:ORD]STRDAT>=[M:CSHT]STRDATSTR&[F:ORD]STRDAT<=[M:CSHT]STRDATEND)"
    # Endif
    # If [M:CSHT]STRDATEND <> [0/0/0]
    #    If CRITERE<>"" CRITERE += "|" Endif
    #    CRITERE+= "([F:ORD]ENDDAT>=[M:CSHT]STRDATSTR&[F:ORD]ENDDAT<=[M:CSHT]STRDATEND)"
    # Endif
    # If CRITERE<>""
    #    If find("|",CRITERE) CRITERE+="("+CRITERE+")" Endif
    #    Gosub LOAD_CRITERE3
    # Endif
    If [M:CSHT]STRDATSTR <> [0/0/0]
       CRITERE = "[F:ORD]STRDAT>=[M:CSHT]STRDATSTR"
       Gosub LOAD_CRITERE3
    Endif
    If [M:CSHT]STRDATEND <> [0/0/0]
       CRITERE = "[F:ORD]STRDAT<=[M:CSHT]STRDATEND"
       Gosub LOAD_CRITERE3
    Endif
Endcase

# priorité
If [M:SHT1]WVCRTYP<>4
    If [M:CSHT]PIOSTR <> 0
        CRITERE = "[F:ORD]PIO>=[M:CSHT]PIOSTR"
        Gosub LOAD_CRITERE3
    Endif
    If [M:CSHT]PIOEND <> 0
        CRITERE = "[F:ORD]PIO<=[M:CSHT]PIOEND"
        Gosub LOAD_CRITERE3
    Endif
Endif

If CRITERE3 = "" : CRITERE3 = "1=1" : Endif
Return

#############################################################################
$LOAD_CRITERE
If len(CRITERE1)=0
    CRITERE1 += "("
Else
    CRITERE1 += "|"
Endif
CRITERE1 += CRITERE
Return

#############################################################################
$LOAD_CRITERE2
If len(CRITERE2)<>0 : CRITERE2 += "&" : Endif
CRITERE2 += CRITERE
Return

#############################################################################
$LOAD_CRITERE3
If len(CRITERE3)<>0 : CRITERE3 += "&" : Endif
CRITERE3 += CRITERE
Return

#############################################################################
#    ETIQUETTES ECRAN
#############################################################################

Subprog AS_STOFCY(VALEUR)
Variable Char     VALEUR
If GCONSULT <> 0
  mkstat = 2
Endif
End

########################################
Subprog AM_STOFCY(VALEUR)
Variable Char    VALEUR()
If dim([M:SHT1]WRH) > 0
   Raz   [M:SHT1]WRH
   Affzo [M:SHT1]WRH
Endif
End

########################################
Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
# Actzo ou Grizo des dépôts selon le site  #
If [M]STOFCY<>[F:FCY]FCY
  Read [FCY]FCY0=[M]STOFCY
Endif
If [F:FCY]WRHGES <> 2
  Raz   [M]WRH
  Affzo [M]WRH
  mkstat = 2
Endif
End

########################################
Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M]ITMREFSTR = ""     : [M]ITMREFEND = VALEUR : Endif
If [M]ITMREFEND < VALEUR : [M]ITMREFEND = VALEUR : Endif
End

########################################
Subprog AS_WVCRTYP(VALEUR)
Variable Integer VALEUR
Local Integer I
For I=1 To len(mess(0,701,1))
    GMENLOC(I)=1
Next
Case [M:SHT1]WORIGINE
    When "1": GMENLOC(10)=0: mkstat=2                : # OF
    When "2": GMENLOC(2)=0                           : # Commandes
    When "3": GMENLOC(10)=0:GMENLOC(2)=0             : # OF + Commandes
    When "4": GMENLOC(4)=0                           : # Livraisons
    When "5": GMENLOC(10)=0:GMENLOC(4)=0             : # OF + Livraisons
    When "6": GMENLOC(2)=0 :GMENLOC(4)=0             : # Commandes + Livraisons
    When "7": GMENLOC(10)=0:GMENLOC(2)=0:GMENLOC(4)=0: # OF + Commandes + Livraisons
    When "8": GMENLOC(36)=0: mkstat=2                : # EO            # FQ 53604 GA 03/2009
Endcase
End

########################################
Subprog AM_WVCRTYP(VALEUR)
Variable Integer VALEUR
If VALEUR=4
#   Pour les livraisons et factures, pas de critère de priorité (pas d'enregistrement en-cours)
    Diszo [M:CSHT]PIOSTR, PIOEND
Else
    Actzo [M:CSHT]PIOSTR, PIOEND
Endif
# FQ 66483 GA 08/2010 utiliser Sélection F12 du type de données VCR, en renseignant WVCROBJ
Case VALEUR
     When 2   : [M]WVCROBJ="SOH"      : # Commandes Vente
     When 4   : [M]WVCROBJ="SDH"      : # Livraisons
     When 10  : [M]WVCROBJ="MFG"      : # OF
     When 36  : [M]WVCROBJ="SCO"      : # EO               # FQ 53604 GA 03/2009
Endcase
End

########################################
Subprog AM_VCRNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M]VCRNUMSTR = ""     : [M]VCRNUMEND = VALEUR  : Endif
If [M]VCRNUMEND < VALEUR : [M]VCRNUMEND = VALEUR  : Endif
End

########################################
Subprog IB_VCRNUMSTR
# FQ 66483 GA 08/2010 utiliser Sélection F12 du type de données VCR au lieu de 4 boutons différents
### # FQ 54056 ajout GBOUT4 pour Débrancht vers EO
### Case [M:SHT1]WVCRTYP
###     When 10      :    GBOUT2 = "" : GBOUT4 = ""
###     When  2      :    GBOUT1 = "" : GBOUT4 = ""
###     When 36      :    GBOUT1 = "" : GBOUT2 = "" # FQ 54056 GA 03/2009
###     When Default :    GBOUT1 = "" : GBOUT2 = "" : GBOUT4 = ""
### Endcase
  Gosub SELECTION_VCRNUM
End

########################################
Subprog IB_VCRNUMEND
# FQ 66483 GA 08/2010 utiliser Sélection F12 du type de données VCR au lieu de 4 boutons différents
### # FQ 54056 ajout GBOUT4 pour Débrancht vers EO
### Case [M:SHT1]WVCRTYP
###     When 10      :    GBOUT2 = "" : GBOUT4 = ""
###     When  2      :    GBOUT1 = "" : GBOUT4 = ""
###     When 36      :    GBOUT1 = "" : GBOUT2 = "" # FQ 54056 GA 03/2009
###     When Default :    GBOUT1 = "" : GBOUT2 = ""
### Endcase
  Gosub SELECTION_VCRNUM
End

$SELECTION_VCRNUM
# FQ 66483 GA 08/2010 GBIDC1=filtre selon site courant action SELOBJCRIT, GBIDC2=Option
Case [M:SHT1]WVCRTYP
    When 2 : GBIDC1="[F:SOH]STOFCY=[M]STOFCY & [F:SOH]ORDSTA<>2 & [F:SOH]ALLSTA>1 & [F:SOH]DLVSTA<>3 & [F:SOH]INVSTA<>3" : GBIDC2=""
             GBOUT1=mess(391,198,1)

    When 4 : GBIDC1="[F:SDH]STOFCY=[M]STOFCY & [F:SDH]ALLSTA>1" : GBIDC2=""
             GBOUT1=mess(372,198,1)

    When 10: GBIDC1="[F:MFG]MFGFCY=[M]STOFCY & [F:MFG]MFGSTA=1 & [F:MFG]ALLSTA>1 & [F:MFG]MFGTRKFLG<5" : GBIDC2="A"
             GBOUT1=mess(1,344,1)

    When 36: GBIDC1="[F:SCO]POHFCY=[M]STOFCY & [F:SCO]SCOSTA=1 & [F:SCO]ALLSTA>1 & [F:SCO]SCOTRKFLG<5" : GBIDC2="A"
             GBOUT1=mess(643,197,1)

    When Default : Raz GBOUT1
Endcase
End

########################################
Subprog AM_STRDATSTR(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] : [M]STRDATEND = eomonth(VALEUR) : Endif
End

########################################
Subprog C_STRDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]STRDATSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog C_PIOEND(VALEUR)
Variable Integer    VALEUR
If VALEUR < [M]PIOSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog AM_PIOSTR(VALEUR)
Variable Integer    VALEUR()
If [M]PIOEND < VALEUR : [M]PIOEND = VALEUR : Endif
End

########################################
Subprog C_SHTD(VALEUR)
Variable Integer VALEUR
If [M:CSHT]SHTG <> 2 &  VALEUR <> 2
   mkstat = 2 : # une case au moins doit être cochée  (16/02/00 TB)
Endif
End

########################################
Subprog AS_TRI(VALEUR)
Variable Integer VALEUR
GMENLOC(2)=1
GMENLOC(4)=1
GMENLOC(5)=1
GMENLOC(6)=1
GMENLOC(7)=1
End

########################################
Subprog AV_AVAQTY(VALEUR)
Variable Decimal VALEUR
If [M:SHT2]AVAQTY(nolign-1) > 0
    pcolor = GCOUL(3)
Else
    pcolor = GCOUL(0)
Endif
End

########################################
Subprog IB_NBLIG
# FQ 54056 ajout GBOUT4 pour Alloc sur EO
If [M:SHT2]AVAQTY(nolign-1) > 0
    Case [M:SHT2]VCRTYP(nolign-1)
        When  2  :
            Raz GBOUT2, GBOUT4
            If clalev([F:SOH])=0  : Local File SORDER  [SOH] : Endif
            If [F:SOH]SOHNUM <> [M:SHT2]VCRNUM(nolign-1)
                Read [SOH]SOH0 = [M:SHT2]VCRNUM(nolign-1)
                If fstat : Raz [F:SOH] : Endif
            Endif
        When 4,5 : Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4
        When 10  : Raz GBOUT1, GBOUT4
        When 36  : Raz GBOUT1, GBOUT2
    Endcase
Else
    Raz GBOUT1, GBOUT2, GBOUT3, GBOUT4
Endif
# FQ 66483 GA 08/2010 Bouton5 tunnel vers le document
Case [M:SHT2]VCRTYP(nolign-1)
    When  2  : GBOUT5=mess(391,198,1)-[M:SHT2]VCRNUM(nolign-1)
    When 4,5 : GBOUT5=mess(372,198,1)-[M:SHT2]VCRNUM(nolign-1)
    When 10  : GBOUT5=mess(1,344,1)  -[M:SHT2]VCRNUM(nolign-1)
    When 36  : GBOUT5=mess(643,197,1)-[M:SHT2]VCRNUM(nolign-1)
    When Default : Raz GBOUT5
Endcase
End

# --------------------------------------------------------------------- #
#     ETIQUETTES UTILISEES PAR ACTION SAISTOALL (ALLOCATIONS MANUELLES) #
#                                                                       #
#                Appelées depuis TRTSTOALLA                             #
# --------------------------------------------------------------------- #

#---------------------------------------------------------------------- #
# Action avant bouton  : Vérifications au préalable                     #
# Si GNOTALL=1 Pas d'ouverture de la fenêtre allocations manuelles      #
#---------------------------------------------------------------------- #
$AB3_NBLIG
Local Integer WOK, NOL : NOL=nolign-1

Case [M:SHT2]VCRTYP(NOL)
    When 2    : Gosub VERIF_CDE
    When 10   : Gosub VERIF_OF
    When 36   : Gosub VERIF_EO                      # FQ 53604 GA 03/2009
Endcase
Return


#--------------------------------------------------#
# Contrôle de la commande                          #
#--------------------------------------------------#
$VERIF_CDE
Local Char    SYMBOLE(50)

If clalev([F:SOH])=0 : Local File SORDER     [SOH] : Endif
If clalev([F:SOQ])=0 : Local File SORDERQ    [SOQ] : Endif
If clalev([F:SOC])=0 : Local File SORDERC    [SOC] : Endif
If clalev([F:SOP])=0 : Local File SORDERP    [SOP] : Endif

# -- Verrouillage de la commande
If [M:SHT2]VCRLIN(NOL)=[M:SHT2]VCRSEQ(NOL)
#   Ligne de commande normale
    SYMBOLE = "SOH"+[M:SHT2]VCRNUM(NOL)
Else
#   Ligne de commande ouverte
    SYMBOLE = "SOC"+num$([M:SHT2]VCRLIN(NOL))+"\"+[M:SHT2]VCRNUM(NOL)
Endif
Lock = SYMBOLE
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[M:SHT2]VCRNUM(NOL)-":"-mess(10,100,1) : GNOTALL=1 : Return
Endif
# -- Ligne allouée en Global : On demande si on veut l'allouer en détaillé
If [M:SHT2]ALLTYP(NOL)=1
    WOK=1 : Call OUINON (mess(144,191,1), WOK) From GESECRAN
    If WOK=1 GNOTALL=1 : Return : Endif
Endif

# -- Contrôle de la commande
Local Integer WCDTSTA, WCDTUNL, WOK

Local Char WPARAM(10)
Call PARAMUTIL("SCDTUNL",WPARAM,"","") From SUBAUS
WCDTUNL=val(WPARAM)
If WCDTUNL=0 WCDTUNL=1 Endif
# lecture de la commande et contrôle de l'état crédit
Read [SOH]SOH0=[M:SHT2]VCRNUM(NOL)
If fstat : GNOTALL=1 : Return : Endif
Call GETDEV([F:SOH]SALFCY) From DEVSUB
Call GLOBVAR([F:SOH]SALFCY) From WWGLOBVEN
Call SDCDTSTA([F:SOH]SOHNUM,[F:SOH]BPCORD,[F:SOH]CHGTYP,0, "",[F:SOH]ORDDAT,[F:SOH]UNL, 2,WCDTSTA,GBIDD1,GBIDD2) From TRTVENCDT
If WCDTSTA<>1
    GMESSAGE=mess(98,197,1)-[F:SOH]SOHNUM-mess(99,197,1)-[F:SOH]BPCORD-":"
    If WCDTSTA = 2
#       Commande bloquée
        GERR=1:GMESSAGE-=mess(100,197,1):GNOTALL=1: Return
    Elsif WCDTSTA=3
#       Commande avec dépassement d'en-cours
        If WCDTUNL = 1
            GERR=1:GMESSAGE-=mess(101,197,1):GNOTALL=1: Return
        Else
            Call AVERTIR (GMESSAGE-"\"-mess(17,191,1), WOK) From GESECRAN
            Raz GMESSAGE
            If WOK=1 GNOTALL=1 : Return : Endif
        Endif
    Elsif WCDTSTA=4
#       Commande avec acomptes non versés
        If GLOKORD = 2
            GERR=1:GMESSAGE-=mess(102,197,1):FIN=1: Return
        Else
            Call AVERTIR (GMESSAGE-"\"-mess(18,191,1), WOK) From GESECRAN
            Raz GMESSAGE
            If WOK=1 GNOTALL=1 : Return : Endif
        Endif
    Endif
Endif
# lecture de la ligne de commande
Read [SOQ]SOQ0=[M:SHT2]VCRNUM(NOL);[M:SHT2]VCRLIN(NOL);[M:SHT2]VCRSEQ(NOL)
If fstat GNOTALL=1: Return : Endif
# Ligne de contremarque
If find([F:SOQ]FMI,3,5)
    If [F:SOQ]FMI=3
        GMESSAGE=mess(281,197,1)
        If [F:SOQ]FMINUM<>"" GMESSAGE-=":"-mess(142,191,1) : Endif
    Endif
    If [F:SOQ]FMI=5
        GMESSAGE=mess(280,197,1)
        If [F:SOQ]FMINUM<>"" GMESSAGE-=":"-mess(143,191,1) : Endif
    Endif
    WOK=1 : Call OUINON (GMESSAGE-"\"-mess(205,100,1), WOK) From GESECRAN : Raz GMESSAGE
    If WOK=1 GNOTALL=1 : Return : Endif
Endif

Return

#--------------------------------------------------#
# Contrôle de l'OF                                 #
#--------------------------------------------------#
$VERIF_OF
Local Char    SYMBOLE(50)

If clalev([F:MFG])=0 : Local File MFGHEAD    [MFG] : Endif
If clalev([F:MFM])=0 : Local File MFGMAT     [MFM] : Endif

# -- Verrouillage de l'OF
SYMBOLE = "MFG"+[M:SHT2]VCRNUM(NOL)
Lock = SYMBOLE
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[M:SHT2]VCRNUM(NOL)-":"-mess(10,100,1) : GNOTALL=1 : Return
Endif
Return

#--------------------------------------------------#
# Contrôle de l'EO                   FQ 53604      #
#--------------------------------------------------#
$VERIF_EO
Local Char    SYMBOLE(50)

If clalev([F:SCO])=0 : Local File SCOHEAD    [SCO] : Endif
If clalev([F:SCM])=0 : Local File SCOMAT     [SCM] : Endif
If clalev([F:SCI])=0 : Local File SCOITM     [SCI] : Endif

# -- Verrouillage de l'EO
SYMBOLE = "SCO"+[M:SHT2]VCRNUM(NOL)
Lock = SYMBOLE
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[M:SHT2]VCRNUM(NOL)-":"-mess(10,100,1) : GNOTALL=1 : Return
Endif
Return

#---------------------------------------------------------------------- #
# Chargement des paramètres dans masque STOALL                          #
# Cette étiquette est appelée depuis CHARGE_PARAM From TRTSTOALLA       #
#---------------------------------------------------------------------- #
$CHARGE_STOALL
#Local Char    LWRH(GLONWRH)
#Local Integer LEXC

If clalev([M:ORDK])=0 : Local Mask ORDK      [ORDK] : Endif
Default Mask [ALL]

Case [M:SHT2]VCRTYP(LNOL)
    When 2    : Gosub CHARGE_CDE
    When 10   : Gosub CHARGE_OF
    When 36   : Gosub CHARGE_EO                      # FQ 53604 GA 03/2009
Endcase
Return

#--------------------------------------------------#
# Chargement de la commande                        #
#--------------------------------------------------#
$CHARGE_CDE
Local Char    WSAU(GLONUOM)
Local Integer WDME
Local Decimal WSAUSTUCOE, WTOTDLVQTYSTU

# lecture de la commande
If [F:SOH]SOHNUM<>[M:SHT2]VCRNUM(LNOL)
    Read [SOH]SOH0=[M:SHT2]VCRNUM(LNOL)
    If fstat Return : Endif
Endif
# lecture ligne de commande - quantités
If [F:SOQ]SOHNUM<>[M:SHT2]VCRNUM(LNOL) | [F:SOQ]SOPLIN<>[M:SHT2]VCRLIN(LNOL) | [F:SOQ]SOQSEQ<>[M:SHT2]VCRSEQ(LNOL)
    Read [SOQ]SOQ0=[M:SHT2]VCRNUM(LNOL);[M:SHT2]VCRLIN(LNOL);[M:SHT2]VCRSEQ(LNOL)
    If fstat Return : Endif
Endif
# lecture ligne de commande - prix
If [F:SOH]SOHCAT = 4
   Read [SOC]SOC0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN
   If fstat Return : Endif
   Raz [F:SOP]
   If [F:SOC]PLI = ""
      Filter [SOP] Where SOHNUM  = [F:SOQ]SOHNUM & SOPLIN  = [F:SOQ]SOPLIN &
&                        STRDAT <= [F:SOQ]SHIDAT & ENDDAT >= [F:SOQ]SHIDAT
      Read [SOP]SOP0 First
      If fstat : Raz [F:SOP] : Endif
      Filter [SOP]
   Endif
   WLINTYP       = 1
   WSAU          = [F:SOC]SAU
   WSAUSTUCOE    = [F:SOC]SAUSTUCOE
   WTOTDLVQTYSTU = [F:SOQ]DLVQTYSTU + [F:SOQ]ODLQTYSTU
Else
   Read [SOP]SOP0 = [F:SOQ]SOHNUM; [F:SOQ]SOPLIN; [F:SOQ]SOQSEQ
   If fstat Return : Endif
   WLINTYP       = [F:SOP]LINTYP
   WSAU          = [F:SOP]SAU
   WSAUSTUCOE    = [F:SOP]SAUSTUCOE
   If[F:SOH]SOHCAT=3
       WTOTDLVQTYSTU = [F:SOQ]INVQTYSTU + [F:SOQ]ODLQTYSTU
   Else
       WTOTDLVQTYSTU = [F:SOQ]DLVQTYSTU + [F:SOQ]ODLQTYSTU
   Endif
Endif
WDME=[F:SOH]DME
# Chargement du masque [M:ALL]
Raz [M:ALL]
[M:ALL]VCRTYP=2
[M:ALL]VCRNUM=[M:SHT2]VCRNUM (LNOL)
[M:ALL]VCRLIN=[M:SHT2]VCRLIN (LNOL)
[M:ALL]VCRSEQ=[M:SHT2]VCRSEQ (LNOL)
[M:ALL]PCU=WSAU
[M:ALL]STU=[M:SHT2]STU (LNOL)
[M:ALL]PCUSTUCOE=WSAUSTUCOE
[M:ALL]BPCORD=[F:SOH]BPCORD
[M:ALL]BPAADD=[F:SOQ]BPAADD
# Quantité besoin = commandé - déjà livré/facturé
[M:ALL]RETQTY = [F:SOQ]QTYSTU - WTOTDLVQTYSTU
If [M:ALL]RETQTY < 0 [M:ALL]RETQTY = 0 Endif

[M:ALL]OLDALLQTY = [F:SOQ]ALLQTYSTU
[M:ALL]SHTQTY    = [F:SOQ]SHTQTYSTU
# Alimentation de la qté à allouer
#[M:ALL]QTYTOALL  = [M:SAL2]ALLQTYSTU (LNOL)
# Composant de kit/sous-traité: on garde la quantité allouée
If find(WLINTYP, 3,4,5,11,12,13)
    [M:ALL]QTYTOALL = [M:ALL]OLDALLQTY+[M:ALL]SHTQTY
Else
# autre: quantité besoin
    [M:ALL]QTYTOALL = [M:ALL]RETQTY
Endif
[M:ALL]ALLTYP = [M:SHT2]ALLTYP (LNOL)
[M:ALL]RETDAT = max(date$, [F:SOQ]SHIDAT)
[M:ALL]DLVDAT = max(date$, [F:SOQ]EXTDLVDAT)
[M:ALL]PECINTLOC = 2
[M:ALL]PECPLFLOC = 2    : # Prise en cpte empl quai : Oui
[M:ALL]XLOT   = [F:SOQ]LOT
[M:ALL]XLOC   = [F:SOQ]LOC
[M:ALL]XSTA   = [F:SOQ]STA
#Call WRHAUTO([F:SOQ]STOFCY,[F:SOQ]ITMREF,2,0,0,LWRH,LEXC) From STKWRH
#If LEXC=1 [M:ALL]XWRH=LWRH Endif

GTYPLIG=0
If find(WLINTYP, 3,4,5,11,12,13) GTYPLIG=1 Endif
If find([F:SOQ]FMI, 3,5)         GTYPLIG=2 Endif
If find(WLINTYP, 3,4,5,11,12,13) Diszo [M:ALL]QTYTOALL Endif

# Récupération du paramêtre stock : Génération de ruptures
Local Char     WPARAM(10)
Call PARAM([F:SOQ]STOFCY,"GENSHT",WPARAM) From ADOVAL
GGENSHT=val(WPARAM)
Return

#--------------------------------------------------#
# Chargement de l'OF                               #
#--------------------------------------------------#
$CHARGE_OF

# lecture de l'OF
If [F:MFG]MFGNUM<>[M:SHT2]VCRNUM(LNOL)
    Read [MFG]MFG0=[M:SHT2]VCRNUM(LNOL)
    If fstat : Return : Endif
Endif
# lecture matière
If [F:MFM]MFGNUM <> [M:SHT2]VCRNUM(LNOL) |
&  [F:MFM]MFGLIN <> [M:SHT2]VCRLIN(LNOL) |
&  [F:MFM]BOMSEQ<>[M:SHT2]VCRSEQ(LNOL) |
&  [F:MFM]ITMREF <> [M:SHT2]ITMREF(LNOL)
    Read [MFM]MFM0=[M:SHT2]VCRNUM(LNOL);[M:SHT2]VCRLIN(LNOL);[M:SHT2]VCRSEQ(LNOL);[M:SHT2]ITMREF(LNOL)
    If fstat  : Return : Endif
Endif
# Chargement du masque [M:ALL]
Raz [M:ALL]
[M:ALL]VCRTYP    = 10
[M:ALL]VCRNUM    = [M:SHT2]VCRNUM(LNOL)
[M:ALL]VCRLIN    = [M:SHT2]VCRLIN(LNOL)
[M:ALL]VCRSEQ    = [M:SHT2]VCRSEQ(LNOL)
[M:ALL]PCU       = [M:SHT2]STU(LNOL)
[M:ALL]STU       = [M:SHT2]STU(LNOL)
[M:ALL]PCUSTUCOE = 1
[M:ALL]RETQTY    = [F:MFM]RETQTY - [F:MFM]USEQTY
If [M:ALL]RETQTY < 0 : [M:ALL]RETQTY = 0 : Endif
[M:ALL]OLDALLQTY = [F:MFM]ALLQTY
[M:ALL]SHTQTY    = [F:MFM]SHTQTY
[M:ALL]QTYTOALL  = [M:ALL]RETQTY
[M:ALL]ALLTYP    = 2
[M:ALL]RETDAT    = [F:MFM]RETDAT
[M:ALL]DLVDAT    = [F:MFM]RETDAT
[M:ALL]PECINTLOC = 2
[M:ALL]PECPLFLOC = 2    : # Prise en cpte empl quai : Oui
If [F:MFM]SCOFLG = 2    : # Prise en compte emplacements sous-traitants
    [M:ALL]PECSCOLOC = 2
    # on renseigne le tiers et l'adresse, on prend le premier tiers trouvé (approximation en cas de splittage)
    If [F:MFM]BOMOPE <> 0
        If clalev([F:MFO])  = 0 : Local File MFGOPE [MFO] : Endif
        Filter [MFO] Where MFGNUM=[F:MFM]MFGNUM & OPENUM=[F:MFM]BOMOPE
&                    Order By Key MFO0
        For [MFO]
            [M:ALL]BPCORD = [F:MFO]BPRNUM
            [M:ALL]BPAADD = [F:MFO]BPAADD
            If [M:ALL]BPCORD <> "" : Break : Endif
        Next
        Filter [MFO]
    Endif
Else
    [M:ALL]PECSCOLOC = 1
Endif
[M:ALL]XLOT      = [F:MFM]LOT
[M:ALL]XLOC      = [F:MFM]LOC
[M:ALL]XSTA      = [F:MFM]STA
#Call WRHAUTO([F:MFM]MFGFCY,[F:MFM]ITMREF,10,0,[M:ALL]PECSCOLOC-1,LWRH,LEXC) From STKWRH
#If LEXC=1 [M:ALL]XWRH=LWRH Endif

Diszo [M:ALL]QTYTOALL
Return

#--------------------------------------------------#
# Chargement de l'EO                               #
#--------------------------------------------------#
$CHARGE_EO                   # FQ 53604 GA 03/2009 #

# lecture de l'OF
If [F:SCO]SCONUM<>[M:SHT2]VCRNUM(LNOL)
    Read [SCO]SCO0=[M:SHT2]VCRNUM(LNOL)
    If fstat : Return : Endif
Endif
# lecture matière
If [F:SCM]SCONUM <> [M:SHT2]VCRNUM(LNOL) |
&  [F:SCM]SCILIN <> [M:SHT2]VCRLIN(LNOL) |
&  [F:SCM]SCMLIN <> [M:SHT2]VCRSEQ(LNOL) |
&  [F:SCM]CPNITMREF <> [M:SHT2]ITMREF(LNOL)
    Read [SCM]SCM0=[M:SHT2]VCRNUM(LNOL);[M:SHT2]VCRLIN(LNOL);[M:SHT2]VCRSEQ(LNOL)
    If fstat  : Return : Endif
Endif
# Chargement du masque [M:ALL]
Raz [M:ALL]
[M:ALL]VCRTYP    = 36
[M:ALL]VCRNUM    = [M:SHT2]VCRNUM(LNOL)
[M:ALL]VCRLIN    = [M:SHT2]VCRLIN(LNOL)
[M:ALL]VCRSEQ    = [M:SHT2]VCRSEQ(LNOL)
[M:ALL]PCU       = [M:SHT2]STU(LNOL)
[M:ALL]STU       = [M:SHT2]STU(LNOL)
[M:ALL]PCUSTUCOE = 1
[M:ALL]RETQTY    = [F:SCM]RETQTY - [F:SCM]USEQTY
If [M:ALL]RETQTY < 0 : [M:ALL]RETQTY = 0 : Endif
[M:ALL]OLDALLQTY = [F:SCM]ALLQTY
[M:ALL]SHTQTY    = [F:SCM]SHTQTY
[M:ALL]QTYTOALL  = [M:ALL]RETQTY
[M:ALL]ALLTYP    = 2
[M:ALL]RETDAT    = [F:SCM]DLVDAT
[M:ALL]DLVDAT    = [F:SCM]DLVDAT
[M:ALL]PECINTLOC = 2
[M:ALL]PECPLFLOC = 2    : # Prise en cpte empl quai : Oui
If [F:SCM]SCOFLG = 2    : # Prise en compte emplacements sous-traitants
    [M:ALL]PECSCOLOC = 2
    If [F:SCI]SCONUM <> [M:SHT2]VCRNUM(LNOL) |
&      [F:SCI]SCILIN <> [M:SHT2]VCRLIN(LNOL)
        Read [SCI]SCI0=[M:SHT2]VCRNUM(LNOL);[M:SHT2]VCRLIN(LNOL)
        If fstat  : Return : Endif
    Endif
    # on renseigne le tiers et l'adresse
    [M:ALL]BPCORD = [F:SCO]BPRNUM
    [M:ALL]BPAADD = [F:SCI]BPAADD
Else
    [M:ALL]PECSCOLOC = 1
Endif
[M:ALL]XLOT      = [F:SCM]LOT
[M:ALL]XLOC      = [F:SCM]LOC
[M:ALL]XSTA      = [F:SCM]STA
#Call WRHAUTO([F:SCM]STOFCY,[F:SCM]CPNITMREF,36,0,1,LWRH,LEXC) From STKWRH
#If LEXC=1 [M:ALL]XWRH=LWRH Endif

Diszo [M:ALL]QTYTOALL
Return


#---------------------------------------------------------------------- #
# Contrôle avant enregistrement                                         #
# Si contrôle non OK, mettre OK=0 pour ne pas enregister                #
# Cette étiquette est appelée depuis AVANT_ENR From TRTSTOALLA          #
#---------------------------------------------------------------------- #
$AVANT_STOALL
Case [M:SHT2]VCRTYP(NOL)
    When 2    : Gosub AVANT_CDE
    When 10   : Gosub AVANT_OF
    When 36   : Gosub AVANT_EO                      # FQ 53604 GA 03/2009
Endcase
Return

#--------------------------------------------------#
# Contrôle de la commande avant enregistrement     #
#--------------------------------------------------#
$AVANT_CDE
# Quantité totale <> quantité à allouer
If [M:ALL]PECQTY < [M:ALL]QTYTOALL
    OK = 2
#   Livraison ligne/cde complète : On doit tout allouer
    If find(WDME, 2,3) & !find(WLINTYP,2,10)
        Call OUINON(mess(107,191,1),OK) From GESECRAN
    Endif
    If OK <> 2 FOK=0 : Return : Endif
Endif
Return

#--------------------------------------------------#
# Contrôle avant enregistrement                    #
#--------------------------------------------------#
$AVANT_OF
Return

#--------------------------------------------------#
# Contrôle avant enregistrement                    #
#--------------------------------------------------#
$AVANT_EO                    # FQ 53604 GA 03/2009 #
Return

#---------------------------------------------------------------------- #
# Mise à jour complémentaires après enregistrement                      #
# Si problème mettre GOK=0 pour annuler l'enregistrement                #
#---------------------------------------------------------------------- #
# WALLQTY contient la quantité allouée                                  #
# WSHTQTY contient la quantité en rupture                               #
#---------------------------------------------------------------------- #
$APRES_STOALL
Case [M:SHT2]VCRTYP(LNOL)
    When 2    : Gosub APRES_CDE
    When 10   : Gosub APRES_OF
    When 36   : Gosub APRES_EO                      # FQ 53604 GA 03/2009
Endcase
Return

#--------------------------------------------------#
# Mise à jour de la commande avant enregistrement  #
#--------------------------------------------------#
$APRES_CDE
Local Integer NOL : NOL=LNOL
Local Integer WRET
Local Decimal WALLSTU
Local Char    WTRTLIG(1)

#[M:ALL]ALLTYP=2
If WCSOQTY<>0
    Local Char WVCRRER
    WVCRRER = format$("K:"+num$(GLONBPC)+"X", [M:ALL]BPCORD)+format$("K:"+num$(GLONBPD)+"X", [M:ALL]BPAADD)
    WVCRRER = vireblc(WVCRRER, 1)
    # Si consommation des réservations clients : Maj de l'encours correspondant
    Call MAJORDBPC(1,WVCRRER,[M:SHT2]ITMREF(LNOL),[M:SHT1]STOFCY,WCSOQTY,WRET) From TRTVENALL
    If WRET <> 0 GOK=0 : Return Endif
Endif
#   Mise à jour commande
Call MAJALLORD([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, [M:ALL]ALLTYP, 1, WALLQTY, WSHTQTY, WRET) From TRTVENALL
If WRET <> 0 : GOK = 0 : Return : Endif
#   Si Composé de kit, il faut allouer les composants
WALLSTU=WALLQTY+WSHTQTY
WALLSTU=WALLSTU-([M:ALL]OLDALLQTY+[M:ALL]SHTQTY)
Raz WTRTLIG
If find(WLINTYP,2,10) & WALLSTU <> 0
    If WALLSTU < 0
# ----- C'est une diminution/annulation de l'allocation
        WTRTLIG = "D"
        WALLSTU = abs(WALLSTU)
    Elsif WALLSTU > 0
# ----- C'est une augmentation de l'allocation
        If [M:ALL]OLDALLQTY = 0 & [M:ALL]SHTQTY = 0
             WTRTLIG = "C"
        Else
             WTRTLIG = "M"
        Endif
        WALLSTU=WALLQTY+WSHTQTY
    Endif
    Call GENALLKIT ([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, WTRTLIG, GRERBPC, 2, 0, 1, 0, WALLSTU,
&                   WRET) From TRTVENALL
    If WRET <> 0 GOK=0 : Return : Endif
Endif
Return

#--------------------------------------------------#
# Mise à jour de l'OF                              #
#--------------------------------------------------#
$APRES_OF
Local Integer WRET
Local Decimal WDIS

Call MAJALLMAT([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, [M:ALL]ITMREF, WALLQTY, WSHTQTY, 2, WRET) From MFGALL
If WRET <> 0 : GOK = 0 : Return : Endif
Return

#--------------------------------------------------#
# Mise à jour de l'EO                              #
#--------------------------------------------------#
$APRES_EO                    # FQ 53604 GA 03/2009 #
Local Integer WRET
Local Decimal WDIS

Call MAJALLMAT([M:ALL]VCRNUM, [M:ALL]VCRLIN, [M:ALL]VCRSEQ, [M:ALL]ITMREF, WALLQTY, WSHTQTY, 2, WRET) From SCOALL
If WRET <> 0 : GOK = 0 : Return : Endif
Return

#---------------------------------------------------------------------- #
# Action apres bouton                                                   #
#---------------------------------------------------------------------- #
$BB3_NBLIG
# Suppression du verrou sur la commande
Unlock=SYMBOLE

Return

