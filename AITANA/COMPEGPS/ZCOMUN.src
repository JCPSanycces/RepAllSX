#################################################################################
Funprog ART_STOCK_REAL(FCY,ITM,STA,FEC)
Value Char    FCY,ITM
Value Char    STA  # Tipo stock  'A' - 'Q' - 'R' etc...
Value Date    FEC
Local Decimal STK
STK=func ART_STOCK(FCY,ITM,STA,FEC,1)
End STK

Funprog ART_STOCK_DISPONIBLE(FCY,ITM,STA)
Value Char    FCY,ITM
Value Char    STA  # Tipo stock  'A' - 'Q' - 'R' etc...
Local Decimal STK
STK=func ART_STOCK(FCY,ITM,STA,[0/0/0],2)
End STK

Funprog ART_STOCK(FCY,ITM,STA,FEC,TIP)
Value Char    FCY,ITM
Value Char    STA  # Tipo stock  'A' - 'Q' - 'R' etc...
Value Date    FEC
Value Integer TIP  #  <=1 Real/Fisico  2=Disponible
Local Decimal STK  :    STK=0
Local Char    BD(1)  :   BD=func DATA_BASE_TIPO
Local Char    TXT(250)(15)
Local Integer F  :  F=-1
If FEC=[0/0/0]
  # Actual     Fisico ó Disponible
  F+=1:TXT(F)="select 1,isnull(sum(QTYSTU_0),0) "
  F+=1:TXT(F)="from STOCK "
  F+=1:TXT(F)="where STOFCY_0 ='"+FCY+"' and ITMREF_0 ='"+ITM+"' and STA_0 ='"+STA+"'"
  F+=1:TXT(F)="union all "
  F+=1:TXT(F)="select 2,isnull(sum(QTYSTU_0),0)*-1 "
  F+=1:TXT(F)="from STOALL "
  F+=1:TXT(F)="where STOFCY_0 ='"+FCY+"' and ITMREF_0 ='"+ITM+"' "
Else
  # A fecha    Fisico ó Disponible
  F+=1:TXT(F)="select 1,isnull(sum(QTYSTU_0),0) "
  F+=1:TXT(F)="from STOJOU "
  F+=1:TXT(F)="where STOFCY_0 ='"+FCY+"' and ITMREF_0 ='"+ITM+"'and IPTDAT_0<='"+format$("D:YYYYMMDD",FEC)+"' and STA_0 ='"+STA+"' "
  F+=1:TXT(F)="union all "
  F+=1:TXT(F)="select 2,isnull(sum(QTYSTU_0),0)*-1 "
  F+=1:TXT(F)="from STOALL "
  F+=1:TXT(F)="where STOFCY_0 ='"+FCY+"' and ITMREF_0 ='"+ITM+"'and BESDAT_0<='"+format$("D:YYYYMMDD",FEC)+"'and ALLDAT_0>='"+format$("D:YYYYMMDD",FEC)+"' "
Endif
For (Integer FTIP,Decimal FQTY )From BD Sql TXT As [MYT]
  If [MYT]FTIP=1
    STK+=[MYT]FQTY
  Elsif TIP=2
    STK+=[MYT]FQTY
  Endif
Next
End STK

#################################################################################
Subprog ART_TER_REG(ITM,CTE_PRV,TIPO,REGART,REGTER)
Value Char    ITM,CTE_PRV
Value Integer TIPO # 0->Cte  #   1->Proveedor
Variable Char REGART,REGTER
Raz REGART,REGTER
# 1º Sacar tipos IVA del articulo
If clalev([F:ITM])<=0    :  Local File ITMMASTER [F:ITM]  : Endif
Read [F:ITM]ITM0=ITM
If fstat<>0   End    Endif
For F=0 To dim(REGART)-1
  REGART(F)=[F:ITM]VACITM(F)
Next
# 2º Sacar regimen IVA del Cliente / Proveedor
Case TIPO
When 1
  If clalev([F:BPS])<=0    :  Local File BPSUPPLIER[F:BPS]  : Endif
  Read [F:BPS]BPS0=CTE_PRV
  If fstat=0  REGTER=[F:BPS]VACBPR   Endif
When Default
  If clalev([F:BPC])<=0    :  Local File BPCUSTOMER[F:BPC]  : Endif
  Read [F:BPC]BPC0=CTE_PRV
  If fstat=0    REGTER=[F:BPC]VACBPR  Endif
Endcase
End

Subprog ART_IVA(ITM,CTE,CPY,FEC,IVA)
Value Char       ITM,CTE,CPY
Value Date       FEC
Variable Decimal IVA()
Gosub ART_IVA_DEF_VAR
Call ART_TER_REG(ITM,CTE,0,REGART,REGTER)
Gosub ART_IVA_COMUN
End

Subprog ART_IVA_CTE(ITM,CTE,CPY,FEC,IVA,IVAREG)
Value Char       ITM,CTE,CPY
Value Date       FEC
Variable Decimal IVA
Variable Char    IVAREG
Gosub ART_IVA_DEF_VAR
Call ART_TER_REG(ITM,CTE,0,REGART,REGTER)
Raz IVAREG
Gosub ART_IVA_COMUN
End

Subprog ART_IVA_PRV(ITM,PRV,CPY,FEC,IVA,IVAREG)
Value Char       ITM,PRV,CPY
Value Date       FEC
Variable Decimal IVA
Variable Char    IVAREG
Gosub ART_IVA_DEF_VAR
Call ART_TER_REG(ITM,PRV,1,REGART,REGTER)
Raz IVAREG
Gosub ART_IVA_COMUN
End

$ART_IVA_DEF_VAR
Local Integer F     :    F=dim([F:ITM]VACITM)
Local Char REGART(GLONVAT)(F),REGTER(GLONTVB)
Raz IVA
Return

$ART_IVA_COMUN
If REGTER=""  Return    Endif
# 3º Sacar %IVA
If clalev([F:TVC])<=0    :  Local File TABVAC    [F:TVC]  : Endif
If clalev([F:TRA])<=0    :  Local File TABRATVAT [F:TRA]  : Endif
For F=0 To dim([F:ITM]VACITM)-1
  Read [F:TVC]TVC1=REGTER;REGART(F)
  If fstat=0 and [F:TVC]ENAFLG=2
    If dim(IVAREG)>0 IVAREG(F)=[F:TVC]VAT   Endif
    If fstat=0
      Read [F:TRA]TRA1(3)<=[F:TVC]VAT;CPY;FEC
      If fstat=0 or fstat=2   IVA(F)=[F:TRA]VATRAT   Endif
    Endif
  Endif
Next
Return


#################################################################################
Funprog ART_COSTE(FCY,ITM,LOT,SLOT,FIFO)
Value Char    FCY,ITM,LOT,SLOT
Variable Date FIFO
Local Decimal COSTE_UNITARIO
COSTE_UNITARIO=func ART_COSTE_1(FCY,ITM,LOT,SLOT,"",date$,FIFO)
End COSTE_UNITARIO

Funprog ART_COSTE_1(FCY,ITM,LOT,SLOT,SERN,FEC,FIFO)
Value Char    FCY,ITM,LOT,SLOT,SERN
Value Date    FEC
Variable Date FIFO
Local Char TXT(255)(5)
Local Char BD_TIPO(1)   :  BD_TIPO=func DATA_BASE_TIPO()
Local Decimal COSTE_UNITARIO
Raz COSTE_UNITARIO,FIFO,TXT
If LOT<>"" and SERN=""
  # 1º intento sacar el precio de compra del lote, para lo cual DEBE ESTAR EN STOCK, de lo contrario no hay Rgtos en STOLOT
  #      STOLOT y STOSER son una pila FIFO, luego es posible que estando en stock no esté en estas tablas
  TXT(0)="select CST_0/QTYSTUACT_0, CSTDAT_0 "
  TXT(1)="from STOCOST c "
  TXT(2)="inner join STOLOT l on c.VCRNUM_0=l.VCRNUM_0 and c.VCRLIN_0 =l.VCRLIN_0 and c.VCRTYP_0 =l.VCRTYP_0 "
  TXT(3)="where c.STOFCY_0='" + FCY + "' and c.ITMREF_0='" + ITM + "' and l.LOT_0='" + LOT + "' "
  If SLOT<>"" TXT(2)+="and l.SLO_0='" + SLOT + "' "  Endif
  For (Decimal PREC, Date CSTDAT) From BD_TIPO Sql TXT As [MYT]
    COSTE_UNITARIO=PREC
    FIFO=CSTDAT
  Next
  # 2º De no lograrlo, saco el precio medio
  If FIFO=[0/0/0]
    If clalev([F:SLF])<=0   :  Local File STOLOTFCY    [F:SLF] : Endif
    Read [F:SLF]SLF0=ITM;LOT;SLOT;FCY
    If fstat=0
      COSTE_UNITARIO=[F:SLF]AVC # Precio medio ponderado PMP
      FIFO=[F:SLF]LASRCPDAT     # Fecha última entrada
    Endif
  Endif
Elsif SERN<>""
  # 1º intento sacar el precio de compra del nº serie, para lo cual DEBE ESTAR EN STOCK, de lo contrario no hay Rgtos en STOSER
  #      STOLOT y STOSER son una pila FIFO, luego es posible que estando en stock no esté en estas tablas
  TXT(0)="select CST_0/QTYSTUACT_0, CSTDAT_0 "
  TXT(1)="from STOCOST c "
  TXT(2)="inner join STOSER l on c.VCRNUM_0=l.VCRNUM_0 and c.VCRLIN_0 =l.VCRLIN_0 and c.VCRTYP_0 =l.VCRTYP_0 "
  TXT(3)="where c.STOFCY_0='" + FCY + "' and c.ITMREF_0='" + ITM + "' and l.SERNUM_0='" + SERN + "' "
  For (Decimal PREC, Date CSTDAT) From BD_TIPO Sql TXT As [MYT]
    COSTE_UNITARIO=PREC
    FIFO=CSTDAT
  Next
  # 2º De no lograrlo, saco el precio del STOJOU
  If FIFO=[0/0/0]
    COSTE_UNITARIO=func ART_COSTE_STOJOU(FCY,ITM,LOT,SLOT,SERN,FEC,FIFO)
  Endif
Endif
# 3º De no lograrlo, es
#        - Un articulo sin gestión de LOTES ni SERIE
#        - De serlo, no está en stock el lote ó nº serie en el momento de realizar la consulta
If FIFO=[0/0/0]
  If clalev([F:ITV])<=0   :  Local File ITMMVT    [F:ITV] : Endif
  Read [F:ITV]ITV0=ITM;FCY
  If fstat=0
    COSTE_UNITARIO=[F:ITV]AVC # Precio medio ponderado PMP
    FIFO=[F:ITV]LASRCPDAT     # Fecha última entrada
  Endif
Endif
End COSTE_UNITARIO

Funprog ART_COSTE_STOJOU(FCY,ITM,LOT,SLOT,SERN,FEC,FIFO)
Value Char    FCY,ITM,LOT,SLOT,SERN
Value Date    FEC
Variable Date FIFO
Local Char    FILT(255)
Local Decimal COSTE_UNITARIO,TQTY,TIMP
If clalev([F:WSTJ]) <=0    :  Local File STOJOU     [F:WSTJ]  : Endif
FILT="[F:WSTJ]STOFCY=FCY & [F:WSTJ]IPTDAT<FEC & [F:WSTJ]ITMREF=ITM"
If LOT <>"" FILT+=" & [F:WSTJ]LOT=LOT"      Endif
If SLOT<>"" FILT+=" & [F:WSTJ]SLO=SLOT"     Endif
If SERN<>"" FILT+=" & [F:WSTJ]SERNUM=SERN"  Endif
Filter [F:WSTJ]
Filter [F:WSTJ] Where evalue (FILT) Order By Key STJ4
Raz COSTE_UNITARIO,TQTY,TIMP,FIFO
For [F:WSTJ]
  TQTY+=[F:WSTJ]QTYSTU
  If [F:WSTJ]AMTVAL=0 and  [F:WSTJ]QTYSTU*[F:WSTJ]PRIVAL<>0
    TIMP+=([F:WSTJ]QTYSTU*[F:WSTJ]PRIVAL)
  Else
    TIMP+= [F:WSTJ]AMTVAL   # Los cambios de valor solo reflejan la variación en AMTVAL, dejando QTYSTU=0
  Endif
  #Guardo datos primer mvto de entrada, el que originó la entrada en stock
  If [F:WSTJ]QTYSTU>0 and FIFO=[0/0/0]
    FIFO=[F:WSTJ]IPTDAT
  Endif
Next
Filter [F:WSTJ]
If TQTY<>0  COSTE_UNITARIO=TIMP/TQTY   Endif
End  COSTE_UNITARIO



$CONTABILIDAD
Return
