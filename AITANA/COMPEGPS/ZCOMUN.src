Funprog REDONDEAR(NUM,POS)
Value Decimal NUM
Value Integer POS
Local Decimal N
Local Integer F
#int(3.375*100+0.5)/100
If POS=0
  F=1
Else
  F=10^POS
Endif
N=int(NUM*F+0.5)/F
End N
