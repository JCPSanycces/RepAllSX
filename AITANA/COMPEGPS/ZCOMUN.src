#####################################################################################
$GEN_DEF_VAR
# Variables para XML
Local Char    WNOM(20),WJOB(30),WXML(250),WOUT(250),WDIR(250),WFICH(250),WABR(10)
Local Integer WOK    :    WOK=1
Return

$GEN_ABRIR
#Lectura modelo importacion, para formato fecha
If !clalev([F:AOE])       :  Local File  AOBJEXT    [F:AOE]   : Endif
Read [F:AOE]AOE0=WNOM
If fstat<>0
  Call ECR_TRACE("No existe modelo importacion "+WNOM+"   fstat="+num$(fstat),1)             From GESECRAN
  WOK=0
Else
  # Comprobar directorio y crearlo en caso de que no exista
  Call IMPORT_DIR(WDIR)
  # Abrir fichero a importar
  If WJOB=""   WJOB="_"+format$("D:YYYYMMDD",date$)+"_"+num$(time)     Endif
  If WXML=""   WXML = WNOM                                             Endif
  WXML+=WJOB
  WOUT = filpath(WDIR,WXML,"XML")
  Openo WOUT,0 Using [TIF]
  # Inicio
  Call XML_INICIO(WABR)        From ZXML   #   ISO  /   UTF
  Call XML_INICIO_NOMBRE(WNOM) From ZXML
Endif
Return

$GEN_FIN
# Fin
Call XML_FIN(WNOM) From ZXML
Openo Using [TIF]   #Cerramos el fichero XML generado
# Lanzamos importación
If WOK=1
  Call IMPORTSIL(WNOM,WOUT) From GIMPOBJ  # Lo comento hasta comprobar que el fichero se genera correctamente
  # De esta manera comprobando si existe el fichero <<.err>> sabemos si la traza ha dado errores.
  WFICH = filpath(WDIR,WXML,"XML.err")
  If filinfo(WFICH,0) > 0 Then
    WMSG= "Hubieron Problemas en la importacion del fichero\"+WXML
    Call ECR_TRACE(WMSG,1) From GESECRAN
    WOK=0
    Return
  Endif
Endif
Return

Subprog IMPORT_DIR(WDIR)
Variable Char WDIR
Call COMUN_DIR(WDIR,"REPIMPDEF")
End

Subprog COMUN_DIR(WDIR,WTIP)
Variable Char WDIR
Value    Char WTIP  #  REPEXPTMP  REPEXPDEF   REPIMPDEF  REPIMPERR  REPIMPFIN  REPIMPTMP
Gosub COMUN_DIR1
If WDIR=""
  Case WTIP
  When "REPEXPTMP"
    WDIR="ZIMPEXP\EXTMP"
  When "REPEXPDEF"
    WDIR="ZIMPEXP\EXPOR"
  When "REPIMPDEF"
    WDIR="ZIMPEXP\IMPOR"
  When "REPIMPERR"
    WDIR="ZIMPEXP\IMERR"
  When "REPIMPFIN"
    WDIR="ZIMPEXP\IMFIN"
  When "REPIMPTMP"
    WDIR="ZIMPEXP\IMTMP"
  When Default
    WDIR="ZIMPEXP"
  Endcase
Endif
Call CREAR_DIR(WDIR)
End

$COMUN_DIR1
If clalev([F:APX])<=0    :  Local File APARIMPEXP [F:APX]  : Endif
Read [F:APX]APX0=WTIP
If fstat<>0 or [F:APX]DIRECTORY=""
  WDIR=""
Else
  WDIR=[F:APX]DIRECTORY
  WDIR=func REPLACE(WDIR,"[","" ,-1,V)
  WDIR=func REPLACE(WDIR,"]","" ,-1,V)
  WDIR=func REPLACE(WDIR,"/","\",-1,V)
Endif
Return

$ABRIR_TRAZA
  #Abrir la traza
  If GTRACE=""
     LOUVTRC=1
     Call OUVRE_TRACE("Inicio Importacion Silenciosa. ") From LECFIC
  Endif
Return

$CERRAR_TRAZA
  #Cerrar y mostrar traza
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Return

