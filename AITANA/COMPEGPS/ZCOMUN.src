# 15/09/2016 Asier
#PERFIL_FUNCION_USUARIO: Función para retornar el Perfil Funcion de un Usuario
Funprog PERFIL_FUNCION_USUARIO(WUSER)
Value Char WUSER()
Local Char LPERFIL(10)

  If clalev([F:AUS])<=0 : Local File AUTILIS    [F:AUS] : Endif

  Raz [F:AUS]
  Raz LPERFIL

  Read [F:AUS]CODUSR = WUSER
  LPERFIL = [F:AUS]PRFFCT

End LPERFIL
################################################################################

#--- 04/10/2016 Asier
# Subprograma para recuperar los valores de un Rol para un usuario
Subprog GET_VALORES_ROL(WUSR,WROL,WVAL)
Value Char WUSR, WROL
Variable Char WVAL()(1..)
Local Char LCRITERIO(250)
Local Integer I

  If clalev([F:ZAUB])<=0 : Local File AUSRBPR    [F:ZAUB] : Endif

  LCRITERIO = "USR='" + WUSR + "' & ROL='" + WROL + "'"
  I = 1

  Filter [F:ZAUB] Where evalue(LCRITERIO)
  For [F:ZAUB]
    WVAL(I) = [F:ZAUB]BPR
    I+=1
  Next
  Filter [F:ZAUB]

End

################################################################################
Funprog REPLACE(TXT1,ACT,NUEVO,REP,V)
Value Char TXT1,ACT,NUEVO
Value Integer REP
Variable Integer V
# Parametros de entrada
#  TXT1        Tipo CHAR(255) => Texto original
#  ACT         Tipo CHAR(255) => Texto a buscar
#  NUEVO       Tipo CHAR(255) => Texto nuevo en sustitucion del indicado en ACT
#  REP         TIPO Integer   => Nº de veces a sustituir.....minimo 1
# Parametros de salida
#  V           TIPO Integer   => Nº de veces que se ha sustituido...si cero es que no se ha encontrado
# Valor devuelto
#              Tipo CHAR(255) => Texto tras la sustitución
Local Integer F,P
Local Char TXT(255)
Raz V
TXT=TXT1
P=instr(1,TXT,ACT)
While P>0
  TXT=left$(TXT,P-1)+NUEVO+right$(TXT,1+(P-1)+len(ACT))
  V+=1
  If REP<>-1 and V>=REP
    Break
  Endif
# P=instr(1,TXT,ACT)
  P=instr(P+len(NUEVO),TXT,ACT)
Wend
End TXT
################################################################################

Funprog SIGUIENTE_NUMERO_TEXCLOB(OBJ)
Value Char OBJ
Local Char WSIGUIENTE(50)
Local Char WULTIMO(50)
Local Char WNUMERO(50)

Raz WSIGUIENTE
WULTIMO=OBJ+"~"+format$("N0:8",0)
# Buscamos el ultimo codigo de los texclob para las lineas de los pedidos
If clalev([F:TXC])<=0     Local File TEXCLOB       [F:TXC]   Endif
Filter [F:TXC] Where left$(CODE,3) = OBJ Order By CODE Desc
For [F:TXC]
    WULTIMO= [F:TXC]CODE
    Break
Next
# Siguiente
WNUMERO = format$("N0:8",val(right$(WULTIMO,8)) + 1)
WSIGUIENTE = left$(WULTIMO,4) + WNUMERO
End WSIGUIENTE
################################################################################


Funprog INFORME(USR_P,RPT_P,SRV,NAM)
Value Char USR_P,RPT_P
Variable Char SRV,NAM
# Parametros de entrada
#  USR_P       Tipo CHAR(255) => Usuario X3
#  RPT_P       Tipo CHAR(255) => Informe X3
# Parametros de salida
#  SRV         Tipo CHAR(255) => Puerto      de la impresora
#  NAM         Tipo CHAR(255) => Descripcion de la impresora
# Valor devuelto
#              Tipo CHAR(255) => nombre      de la impresora
Local Char DEST(GLONAIM)
If clalev([F:WAIA]) <=0 : Local File APRTAUS     [F:WAIA]  : Endif
If clalev([F:WAIM]) <=0 : Local File APRINTER    [F:WAIM]  : Endif
If clalev([F:WARP]) <=0 : Local File AREPORT     [F:WARP]  : Endif
Raz SRV,NAM,DEST
Filter [F:WAIA] Where USR=USR_P and RPTCOD=RPT_P
Read [F:WAIA] First
If fstat=0      DEST=[F:WAIA]PRT      Endif
If DEST=""
  Read [F:WARP]ARP0=RPT_P
  If fstat=0    DEST=[F:WARP]PRTDEF   Endif
Endif
If DEST<>""
  Read [F:WAIM]AIM0=DEST
  If fstat=0
    SRV=[F:WAIM]PRTSRV
    NAM=[F:WAIM]PRTNAM
  Endif
Endif
Close Local File [F:WAIA],[F:WAIM], [F:WARP]
End DEST


