Funprog PROVINCIA_ESP(CODPOS, PAIS)
# Parametros de entrada
#  CODPOS      Tipo POS => Código Postal
#  PAIS        Tupo CRY => Pais
# Valor devuelto
#              TIPO CHAR(100)
#              #  =>   No existe traducción
Value Char CODPOS(), PAIS()
Local Char TXT(100)
Local Char PROV(GLONSAT), VALOR(GLONID1)(2)

If clalev([F:ATU])<=0  :  Local File TABSUBDIV  [F:ATU] : Endif

Raz TXT
PROV=left$(CODPOS,2)
Read [F:ATU]ATU0=PAIS; 3; PROV
If fstat=0
  VALOR(0)=[F:ATU]CRYTYP
  VALOR(1)=PROV
  TXT= func ZCOMUN.TRADUCIR_VALOR_CAMPO("TABSUBDIV", VALOR, "SPA", 3)
Endif
End TXT
#####################################################################################

Funprog TRADUCIR_VALOR_CAMPO(TABLA,VALOR,IDIOMA,TIPO)
# Parametros de entrada
#  TABLA       Tipo ATB => Nombre de la tabla
#  VALOR       Tipo ID1 => Valor del campo a traducir. matriz de 2  VALOR(0) + VALOR(1)
#  IDIOMA      Tipo LAN => Idioma cuya traduccion se desea
#  TIPO        TIPO AVA => Tipo de descripcion a devolver, SI TIPO = 3, devolver primer valor existente según orden Corta, Larga, Columna
# Valor devuelto
#              TIPO CHAR(100)
#              #  =>   No existe traducción

Value Char TABLA,VALOR,IDIOMA
Value Integer TIPO
Local Char TXT(100), ZONE(GLONAVA)
If clalev([F:AXX])<=0  :  Local File ATEXTRA    [F:AXX] : Endif

# Controlar valores especiales de columna ZONE
Case TABLA
When "TABSUBDIV"
  TIPO=-1
When "ATABDIV"
  TIPO=-2
Endcase

Raz TXT
Case TIPO
When -1 # Especial tabla    TABSUBDIV
  ZONE="INTIT"
  Gosub TRADUCIR_VALOR_CAMPO_LEER

When -2 # Especial tabla    ATABDIV
  ZONE="SHODES"
  Gosub TRADUCIR_VALOR_CAMPO_LEER
  If TXT="" or TXT="#"
    ZONE="LNGDES"
    Gosub TRADUCIR_VALOR_CAMPO_LEER
  Endif

When 0  #  Descripción corta
  ZONE="SHOTRA"
  Gosub TRADUCIR_VALOR_CAMPO_LEER
  If TXT="" or TXT="#"
    ZONE="SHODES"
    Gosub TRADUCIR_VALOR_CAMPO_LEER
  Endif

When 1  #  Descripción larga
  ZONE="DESTRA"
  Gosub TRADUCIR_VALOR_CAMPO_LEER
  If TXT="" or TXT="#"
    ZONE="LNGDES"
    Gosub TRADUCIR_VALOR_CAMPO_LEER
  Endif

When 2  #  Descripción columna
  ZONE="COLHEA"
  Gosub TRADUCIR_VALOR_CAMPO_LEER

When Default
  ZONE="SHOTRA"
  Gosub TRADUCIR_VALOR_CAMPO_LEER
  If TXT="" or TXT="#"
    ZONE="SHODES"
    Gosub TRADUCIR_VALOR_CAMPO_LEER
    If TXT="" or TXT="#"
      ZONE="DESTRA"
      Gosub TRADUCIR_VALOR_CAMPO_LEER
      If TXT="" or TXT="#"
        ZONE="LNGDES"
        Gosub TRADUCIR_VALOR_CAMPO_LEER
        If TXT="" or TXT="#"
          ZONE="COLHEA"
          Gosub TRADUCIR_VALOR_CAMPO_LEER
        Endif
      Endif
    Endif
  Endif
Endcase
End TXT

$TRADUCIR_VALOR_CAMPO_LEER
  Read [F:AXX]AXX0=TABLA;ZONE;IDIOMA;VALOR(0);VALOR(1)
  If fstat=0
    TXT=[F:AXX]TEXTE
  Else
    TXT="#"
  Endif
Return
