#GET_NUMERO_CONTADOR --> OBTENER EL NUMERO DEL CONTADOR PASADO COMO PARAMETRO
Subprog GET_NUMERO_CONTADOR(WCONTADOR,WFCY,WNUM)
Variable Char WCONTADOR, WFCY, WNUM
#Local Integer STAT

  # SIGUIENTE NUMERO DEL CONTADOR
  #Call NUMERO(WCONTADOR,WFCY,date$,"",WNUM,STAT) From SUBANM

  Local Char MESSAGE(250)
  Local Integer OK

  OK=func ANM_TOOL.NUMERO(GACTX,WCONTADOR,WFCY,date$,"",WNUM,MESSAGE)

  If OK=[V]CST_AERROR
    ASTATUS=fmet this.ASETERROR("",MESSAGE,OK)
    WNUM = "-1"
  Endif

  #If STAT <> 0
  #  WNUM = "-1"
  #Endif

End
