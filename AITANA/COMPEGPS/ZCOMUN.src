#################################################################################
Funprog DIR_FCY(FCY)
Value Char FCY
Local Char ADR(GLONADR)
Raz ADR
If clalev([F:WBPA]) <=0   :  Local File BPADDRESS      [F:WBPA]  : Endif
Filter [F:WBPA]
Filter [F:WBPA] Where [F:WBPA]BPATYP=3 and [F:WBPA]BPANUM=FCY and  [F:WBPA]BPAADDFLG=2
For [F:WBPA]
  ADR=[F:WBPA]BPAADD
  Break
Next
Filter [F:WBPA]
End ADR
#################################################################################

Subprog PLANTAS_CPY(CPYP,FCY)
Value Char    CPYP
Variable Char FCY()
Local Integer F
Raz FCY,F
If clalev([F:WFCY]) <=0   :  Local File FACILITY     [F:WFCY]  : Endif
Filter [F:WFCY] Where LEGCPY=CPYP
For [F:WFCY]
  FCY(F)=[F:WFCY]FCY
  F+=1
  If F>9 Break Endif
Next
End
#################################################################################

Funprog CPY_FCY(FCY)
Value Char FCY
Local Char CPY(GLONCPY)
Raz CPY
If clalev([F:WFCY]) <=0   :  Local File FACILITY     [F:WFCY]  : Endif
Read [F:WFCY]FCY0=FCY
If fstat=0 CPY=[F:WFCY]LEGCPY Endif
End CPY
#################################################################################

Funprog ESTADO_PERIODO (FECHA,CPY,TIP)
Value Date    FECHA
Value Char    CPY
Value Integer TIP
#
Local Integer STA
Local Char    CRITERE(250)
STA=-1
If clalev([F:WPER])<=0    :  Local File PERIOD     [F:WPER]  : Endif
Raz CRITERE
CRITERE  = "1=1"
CRITERE -= ' & CPY="' + CPY + '"'
CRITERE -= ' & PERSTR= [' + format$(GFMD,FECHA) + ']'
Filter [F:WPER] Where evalue(CRITERE)
For [F:WPER]
  Case TIP
  When 1 # Contabilidad
    STA=[F:WPER]PERSTA
  When 2 # Stock
    STA=[F:WPER]PERSTOSTA
  Endcase
Next
End STA

Funprog ULTIMO_PERIODO(FECHA,CPY,TIP)
Value Date    FECHA
Value Char    CPY
Value Integer TIP
#
Local Date    ULTIMO
Local Char    CRITERE(250)
If clalev([F:WPER])<=0    :  Local File PERIOD     [F:WPER]  : Endif
Raz CRITERE,ULTIMO
CRITERE  = "1=1"
CRITERE -= ' & CPY="' + CPY + '"'
Case TIP
When 1 # Contabilidad
  CRITERE -= ' & PERSTA=4'
When 2 # Stock
  CRITERE -= ' & PERSTOSTA=4'
Endcase
Filter [F:WPER] Where evalue(CRITERE) Order By PEREND Desc
For [F:WPER]
  ULTIMO=[F:WPER]PEREND
  Break
Next
End ULTIMO
#################################################################################

Subprog REFERENCIALES_PLANTA(PLANTA, REFER, RCUR)
  Value Char PLANTA
  Variable Char REFER,RCUR
  Local Char TXT(250)(3),BD_TIPO(1)
  Local Integer FLAG_ERR,F,N
  FLAG_ERR=0

  Raz TXT,REFER
  TXT(0)="select LED_0, LED_1, LED_2, LED_3, LED_4, LED_5, LED_6, LED_7, LED_8, LED_9, CUR_0, CUR_1, CUR_2, CUR_3, CUR_4, CUR_5, CUR_6, CUR_7, CUR_8, CUR_9 "
  TXT(1)="from FACILITY inner join COMPANY on LEGCPY_0=CPY_0 inner join GACM on COMPANY.ACM_0=GCM_0 " #FACILITY.LEG_0=GCM_0 "
  TXT(2)="where FCY_0='" + PLANTA +"'"
  BD_TIPO=func DATA_BASE_TIPO()
  Onerrgo ERRORES
  For (Char FLD0(GLONLED)(10), Char FLD1(GLONCUR)(10)) From BD_TIPO Sql TXT As [MYT]
    For F=0 To 9
      REFER(F)=FLD0(F)
      RCUR(F)=FLD1(F)
    Next
    Break
  Next
  Onerrgo
End
#################################################################################

Subprog PLANES_CONTAB_PLANTA(PLANTA, PLAN, REFERE, RCUR, RANA)
  Value Char PLANTA
  Variable Char PLAN, REFERE, RCUR
  Variable Integer RANA
  Local Integer FLAG_ERR,F

  If clalev([F:LED])<=0  :  Local File GLED  [F:LED] : Endif

  Raz PLAN,REFERE,RCUR
  Onerrgo ERRORES
  Call REFERENCIALES_PLANTA(PLANTA,REFERE,RCUR)
  For F=0 To 9
    If REFERE(F)<>""
      Read [F:LED]LED0=REFERE(F)
      PLAN(F)=[F:LED]COA
      RANA(F)=[F:LED]ANA
    Endif
  Next
  Onerrgo
End
#################################################################################
Subprog EJES_CONTAB_PLANTA(REFERE,RANA, REJES)
Value Char REFERE
Value Integer RANA
Variable Char REJES
Local Integer F,L
Local Char TXT(100)
If clalev([F:LED])<=0  :  Local File GLED       [F:LED] : Endif
For F=0 To 9
  If RANA(F)=2   #  Solo hay un plan contable analitico ????
    Read [F:LED]LED0=REFERE(F)
    For L=0 To [F:LED]DIENBR-1
      REJES(L)=[F:LED]DIE(L)
#      TXT= func ZCOMUN.TRADUCIR_VALOR_CAMPO("GDIE", [F:LED]DIE(L), "SPA", 0)
#      If TXT="#"
#        TXT=[F:LED]DIE(L)
#      Else
#        TXT=[F:LED]DIE(L) + "-" + TXT
#      Endif
    Next
  Endif
Next
End
##################################################################################

Funprog VALIDAR_FECHA_ASIENTO(FECHA, CPY)
Value Date FECHA
Value Char CPY
Local Char TXT(200),CRITERE(250)
Local Integer OK,X
# Para Validar fecha asiento
If clalev([F:FIY])<=0    :  Local File FISCALYEAR [F:FIY]  : Endif
#If clalev([F:FIS])<=0    :  Local File FISCYEAR   [F:FIS]  : Endif
If clalev([F:PER])<=0    :  Local File PERIOD     [F:PER]  : Endif

TXT=""
If FECHA=[0/0/0]
  TXT="Debe indicar una Fecha asiento"
Elsif CPY=""
  TXT="Debe indicar una Sociedad"
Else
  OK=1
  Raz CRITERE
  CRITERE = "1=1"
  CRITERE -= ' & CPY="' + CPY + '"'
  CRITERE -= ' & LEDTYP=1'
  CRITERE -= ' & FIYSTR<= [' + format$(GFMD,FECHA) + ']'
  CRITERE -= ' & FIYEND>= [' + format$(GFMD,FECHA) + ']'
  Filter [F:FIY] Where evalue(CRITERE)
  For [F:FIY]
    OK=0
  #  Infbox [F:FIY]DES + "    " + [F:FIY]CPY  + "    " + [F:FIY]FIYSTR + "   " + [F:FIY]FIYEND + "   Estado=" + num$([F:FIY]FIYSTA)
    If [F:FIY]FIYSTA<>2
      TXT="El año " + num$(year(FECHA)) + " existe, pero no está abierto\" + [F:FIY]DES + "  Estado " + num$([F:FIY]FIYSTA)
    Endif
  Next
  Filter [F:FIY]

  If OK=1
      TXT="El año " + num$(year(FECHA)) + " no existe en Contabilidad"
  Elsif TXT=""
    OK=1
    Raz CRITERE
    CRITERE = "1=1"
    CRITERE -= ' & CPY="' + CPY + '"'
  #  CRITERE -= ' & DATSTRFIY<= [' + format$(GFMD,FECHA) + ']'
  #  CRITERE -= ' & DATENDFIY>= [' + format$(GFMD,FECHA) + ']'
    CRITERE -= ' & PERSTR<= [' + format$(GFMD,FECHA) + ']'
    CRITERE -= ' & PEREND>= [' + format$(GFMD,FECHA) + ']'
  #  Filter [F:FIS] Where evalue(CRITERE)
  #  For [F:FIS]
  #    For X=0 To [F:FIS]NBRPER-1
  #      If [F:FIS]DATSTRPER(X)<=FECHA and [F:FIS]DATENDPER(X)>=FECHA
  #        OK=0
  #        If [F:FIS]STAPER(X)<>3
  #          TXT="La fecha " + format$("DD2",FECHA) + " pertenece a un periodo que no está abierto"
  #        Endif
  #      Endif
  #    Next
  #  Next
  #  Filter [F:FIS]
    Filter [F:PER] Where evalue(CRITERE)
    For [F:PER]
      OK=0
      If [F:PER]PERSTA<>2
        TXT="La fecha " + format$("DD2",FECHA) + " pertenece a un periodo que no está abierto"
      Endif
    Next
    Filter [F:PER]
    If OK=1
        TXT="No se han definido periodos para El año " + num$(year(FECHA))
    Endif
  Endif
Endif
End TXT
##################################################################################

Subprog CTAS_COD_CONTABLE(TIP,COD,COA,INDEX,DH,ERR_MSG,CTA)
Value Integer TIP,INDEX
Value Char COD,COA,DH
Variable Char ERR_MSG,CTA

Local Char TMP(200), T(100), T1(20)
Local Integer F1

If clalev([F:CAC])<=0  :  Local File GACCCODE [F:CAC] : Endif

Raz ERR_MSG,CTA
For F1=0 To dim(COA)-1  # Hay un maximo de 10 Planes contables del 0 al 9
   If COA(F1)<>""
      Read [F:CAC]CAC0=TIP;COD;COA(F1)
      T=" (" + num$(TIP) + " - " + COD + " - " + COA(F1) + ")"
      If fstat<>0
         ERR_MSG="# No existe Codigo Contable (" + T + ")       fstat="+num$(fstat)
      Else
        TMP=[F:CAC]ACC(INDEX)
        If DH="D"
          T1="Debe"
        Else
          T1="Haber"
        Endif
        If TMP=""
          ERR_MSG="# No se indicó CUENTA(" + num$(INDEX)  +") para el " + T1 + " EN EL COD.CONTABLE " + T
        Else
          CTA(F1)=TMP
        Endif
      Endif
   Endif
Next
End

###############################################################################################
Funprog CTA_SOCIAL_COD_CONTABLE(TIP,COD,COA,INDEX,DH,ERR_MSG)
Value Integer TIP,INDEX
Value Char COD,COA,DH
Variable Char ERR_MSG
Local Char CTA(GLONGAC)(dim(COA))
Call CTAS_COD_CONTABLE(TIP,COD,COA,INDEX,DH,ERR_MSG,CTA)
End CTA(0)

