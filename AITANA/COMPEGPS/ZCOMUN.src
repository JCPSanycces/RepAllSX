Funprog USR_ACC(USR,ACC)
Value Char USR,ACC
Local Integer ZOK   :   ZOK=0
If clalev([F:ZAUS]) <=0 : Local File AUTILIS     [F:ZAUS]  : Endif #Usuarios
If clalev([F:ZACC]) <=0 : Local File ACCES       [F:ZACC]  : Endif #Usuarios-Codigos acceso
Read [F:ZAUS]CODUSR=USR
If fstat=0
  If [F:ZAUS]ALLACS=2
    ZOK=1
  Else
    Read [F:ZACC]CODACC=USR;ACC
    If fstat=0 and ([F:ZACC]EXEC=2 or [F:ZACC]MODIF=2)
      ZOK=1
    Endif
  Endif
Endif
End ZOK

################################################################################
Funprog USR_FUN(USR,FUN)
Value Char USR,FUN
Local Integer ZOK   :   ZOK=0
If clalev([F:ZAUS]) <=0 : Local File AUTILIS     [F:ZAUS]  : Endif #Usuarios
If clalev([F:ZAFT]) <=0 : Local File AFCTFCT     [F:ZAFT]  : Endif #Perfil Funcion
If clalev([F:ZAFP]) <=0 : Local File AFCTPRF     [F:ZAFP]  : Endif #Perfil Funcion-Habilitaciones
#
Read [F:ZAUS]CODUSR=USR
If fstat=0
  Read [F:ZAFT]AFT0=[F:ZAUS]PRFFCT
  If fstat=0
    If [F:ZAFT]ALLFCT=2
      ZOK=1
    Else
      Read [F:ZAFP]AFP0(2)=[F:ZAUS]PRFFCT;FUN
      If fstat=0 and [F:ZAFP]ACS=2
        ZOK=1
      Endif
    Endif
  Endif
Endif
End ZOK

################################################################################
#GET_CODREP_FROM_USR --> RECUPERA EL CODIGO DEL REPRESENTANTE ASOCIADO AL USUARIO
Funprog GET_CODREP_FROM_USR(WUSR)
Variable Char WUSR
Local Char WCODREP(15)

  If clalev([F:ZREP]) <=0 : Local File SALESREP     [F:ZREP]  : Endif #Representantes

  Read [F:ZREP]REP1 = WUSR
  If fstat=0
    WCODREP = [F:ZREP]REPNUM
  Endif

End WCODREP
################################################################################

#GET_CODUSR_FROM_REP --> RECUPERA EL CODIGO DEL USUARIO ASOCIADO AL REPRESENTANTE
Funprog GET_CODUSR_FROM_REP(WREP)
Variable Char WREP
Local Char WUSR(5)

  If clalev([F:ZREP]) <=0 : Local File SALESREP     [F:ZREP]  : Endif #Representantes

  Read [F:ZREP]REP0 = WREP
  If fstat=0
    WUSR = [F:ZREP]AUSNUM
  Endif

End WUSR
################################################################################

#GET_EMAIL_REPUSR --> recupera el email del usuario pasandole el Codigo Representante
Funprog GET_EMAIL_REPUSR(WCODREP)
Variable Char WCODREP
Local Char WUSR(5)
Local Char WEMAIL(80)

  If clalev([F:ZAUS]) <=0 : Local File AUTILIS     [F:ZAUS]  : Endif #Usuarios

  WUSR = func GET_CODUSR_FROM_REP(WCODREP)
  Read [F:ZAUS]CODUSR = WUSR
  If fstat=0
    WEMAIL = [F:ZAUS]ADDEML
  Endif

End WEMAIL
################################################################################

#GET_EMAIL_USER --> recupera el email del usuario
Funprog GET_EMAIL_USER(WUSER)
Variable Char WUSER
Local Char WEMAIL(80)

  If clalev([F:ZAUS]) <=0 : Local File AUTILIS     [F:ZAUS]  : Endif #Usuarios

  Read [F:ZAUS]CODUSR = WUSER
  If fstat=0
    WEMAIL = [F:ZAUS]ADDEML
  Endif

End WEMAIL
