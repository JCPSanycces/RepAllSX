Subprog DIRECTORY_LIST(FILES,ORDSYS,F)
Variable Char    FILES()
Variable Integer F
Value Char       ORDSYS
# Ejemplo de valor para    ORDSYS = adxmac(0)+'@lsadx -t -r -n'+num$(GZFIL)+' -a '+nomap+' BQT txt'
# @lsadx -t   FIJO
# -r          Orden descendente
# -n100       Tope de ficheros a devolver
# -a PRUEBAS  Dossier
# BQT         Carpeta dentro de Dossier
# txt         Extension de los ficheros
Raz FILES,F
If ORDSYS=""   End     Endif
Local File (FICHE(GLONTRA)) From System ORDSYS As [FTR]
For [FTR] Where FICHE<>""
  FILES(F)=[F:FTR]FICHE
  F+=1
Next
End

#####################################################################################
Funprog DIGITOCONTROL(NUMERO)
Value Char NUMERO
##########################################
#   NO incluir el digito de control !!!! #
##########################################
Local Integer DC,X,H,SUMA1,SUMA2,VALOR
Raz DC,X,H,SUMA1,SUMA2,VALOR
For H=len(NUMERO) To 1 Step -1
  X+=1
  If mod(X, 2) = 0
    SUMA2+=val(mid$(NUMERO,H,1))
  Else
    SUMA1+=val(mid$(NUMERO,H,1))
  Endif
Next
VALOR=(SUMA1*3)+SUMA2
While mod(VALOR,10)<>0
  DC+=1
  VALOR+=1
Wend
End DC

#####################################################################################
Subprog DIR_NOM(WDIR)
Variable Char WDIR
If right$(WDIR,len(WDIR))<>"\"
  WDIR=WDIR+"\"
Endif
If instr(1,WDIR,":")<1 and left$(WDIR,1)<>"\"
  WDIR="\"+WDIR
Endif
End

#####################################################################################
Subprog CREAR_DIR(WDIR)
Variable Char WDIR
Call DIR_NOM(WDIR)
Local Char TMP(255)
If instr(1,WDIR,"X3_PUB")>0
  TMP=WDIR
Else
  TMP=filpath("","","","","",adxmac(0)) + WDIR
Endif
If filinfo(TMP,7)<0
  Local Integer STAT
  Call SYSTEME(adxmac(0),'ae_mkdir'-'"' + TMP + '"',"",STAT) From ORDSYS
  If !STAT   WDIR=TMP  Else  WDIR=""   Endif
Else
  WDIR=TMP
Endif
End

#####################################################################################
Funprog FICHERO_OK(FICHADJ)
Value Char FICHADJ
Local Integer NB_ATTEMPTS,OK
Local Decimal SIZE,RSIZE
NB_ATTEMPTS=0
OK=0
Repeat
   SIZE=filinfo(FICHADJ,7)
   If NB_ATTEMPTS=0 or SIZE<1 or (NB_ATTEMPTS>0 and SIZE<>RSIZE)
     NB_ATTEMPTS+=1
     RSIZE=SIZE
    Sleep 1
   Else
    OK=1
    Break
   Endif
Until NB_ATTEMPTS>10
End OK

#####################################################################################
Subprog ARRAY(STR,SEP,MAT)
# STR     String con el texto
# SEP     String correspondiente al separador
# MAT     String definida como   Char MAT(255)(0..), donde se devolverá el array de strings
Value Char STR,SEP
Variable Char MAT
Local Char TXT(255)
Local Integer I,P,E
Raz E,MAT
I=1
P=instr(I,STR,SEP)
While P>0
  MAT(E)=mid$(STR,I,P-I)
  I=P+len(SEP)
  E+=1
  P=instr(I,STR,SEP)
Wend
If P=0 and I<=len(STR)
  MAT(E)=right$(STR,I)
Endif
End


#####################################################################################

Funprog FILAS_GRID(PANTA,NBLIG)
# PANTA    tipo Char(GLONAMK)
# NBLIG    tipo Char(GLONAVA)
Value Char PANTA,NBLIG
Local Integer F,T
Raz T
If clalev([F:AMK])<=0    :  Local File AMSK [F:AMK]  : Endif
Read [F:AMK]CODMSK=PANTA
If fstat<>0
  Call FSTA("AMK") From GLOCK
Else
  For F=0 To 14
    If [F:AMK]BASPAG(F)=NBLIG
      If [F:AMK]NBLIGT(F)>0
        T=[F:AMK]NBLIGT(F)
      Elsif [F:AMK]ACTBLOC(F)<>""
        If clalev([F:ACV])<=0    :  Local File ACTIV [F:ACV]  : Endif
        Read [F:ACV]ACV0=[F:AMK]ACTBLOC(F)
        T=[F:ACV]DIME
      Endif
      Break
    Endif
  Next
Endif
End T
