$BORRAR_ASIENTO
#Estas 4 variables deben definirse e inicializarse antes de llamar a la subrutina !!!!!
#  TYPPCE            Tipo Asiento
#  PIECE             Nº Asiento
#  BORRAR_ASIENTO_V  0-Solo Comprobar, 1-Comprobar y Borrar
#  BORRAR_ASIENTO_M  Se devuelve el error si lo hubiera

# Tablas y definiciones necesarias para borrado ASIENTO CONTABLE
If clalev([F:HAE])<=0    :  Local File GACCENTRY  [F:HAE]  : Endif
If clalev([F:DAE])<=0    :  Local File GACCENTRYD [F:DAE]  : Endif
If clalev([F:DAA])<=0    :  Local File GACCENTRYA [F:DAA]  : Endif
If clalev([F:BAL])<=0    :  Local File BALANCE    [F:BAL]  : Endif
If clalev([F:BLA])<=0    :  Local File BALANA     [F:BLA]  : Endif
If clalev([F:DUD])<=0    :  Local File GACCDUDATE [F:DUD]  : Endif
If clalev([F:TVD])<=0    :  Local File TRCVCRDOC  [F:TVD]  : Endif

Local Integer OK

BORRAR_ASIENTO_M=""
#  COMPROBAR
Read [F:HAE]HAE0=TYPPCE; PIECE
If fstat<>0
  BORRAR_ASIENTO_M="No se encontró el asiento  (fstat="+num$(fstat) + ")\\Compruebe tareas contables y servidor batch"
Elsif [F:HAE]STA>1
  BORRAR_ASIENTO_M=TYPPCE-PIECE-mess(67,119,1)
Endif
If BORRAR_ASIENTO_M=""
  OK = 1
  For [DAE]DAE0 Where TYP=TYPPCE & NUM=PIECE & MTC<>""
   OK = 0
  Next
  If !OK
   BORRAR_ASIENTO_M=TYPPCE-PIECE-mess(64,119,1)
  Endif
Endif
#  BORRAR
If BORRAR_ASIENTO_V=1 and BORRAR_ASIENTO_M=""
  GOK=1
  Call ANUPCE(TYPPCE,PIECE) From ANUBIS
  BORRAR_ASIENTO_M=GMESSAGE
Endif
Return
