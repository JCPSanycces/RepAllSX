#X3 2 ICG S
#Proceso BAT = Importación Stock en ICG.
$ACTION
#Infbox ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub TRT_INI
  When "EXEC"           : Gosub EXEC_EXIM
  When "TERMINE"        : Gosub TERMINE_EXIM
  When "INIT"           : Gosub INIT_DIA_EXIM
  When "OK"             : Gosub OK_EXIM
  When "END"            : Gosub END_EXIM
Endcase

Return

$TRT_INI
Return

$EXEC_EXIM
 System RESULT=chr$(34) + "D:\Sage\X3V9\folders\FANNYSDES\BAT\X3_2_ICG_04.BAT" + chr$(34)
 End
Return

$TERMINE_EXIM
Return

$INIT_DIA_EXIM
Return

$OK_EXIM
Return

$END_EXIM
Return

