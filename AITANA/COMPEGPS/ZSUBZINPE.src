#<AdxTL>@(#)0.0.0.0 $Revision$
#Proceso integracion de pedidos lanzado mediante tarea programada en batch.
#VERSIÓN 1.0 #############################################################
##########################################################################

$ACTION
#Infbox ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub TRT_INI
  When "EXEC"           : Gosub EXEC_INPE
  When "TERMINE"        : Gosub TERMINE_INPE
  When "INIT"           : Gosub INIT_DIA_INPE
  When "OK"             : Gosub OK_INPE
  When "END"            : Gosub END_INPE
Endcase

Return

$TRT_INI
  If !clalev([F:SOH])      : Local File SORDER          [SOH] : Endif
  If !clalev([F:SOQ])      : Local File SORDERQ         [SOQ] : Endif
  If !clalev([F:SOP])      : Local File SORDERP         [SOP] : Endif
  If !clalev([F:BPC])      : Local File BPCUSTOMER      [BPC] : Endif
  If clalev([F:ZINPE])<=0  : Local File ZINTEGRADOR     [ZINPE] : Endif
  If clalev([M:ALP])=0 Local Mask ALLPAR [ALP] Endif
  If clalev([M:ORDK])=0 Local Mask ORDK [ORDK] Endif

Return

$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

$EXEC_INPE
  #Gosub ENVIAR_EMAIL
  #End

  Gosub TRT_INI
  If GSERVEUR
    Onerrgo ERRBATCH
    Call ECR_TRACE("Inicio integracion de pedidos",0) From GESECRAN
  Else
    Call OUVRE_TRACE("Inicio integracion de pedidos") From LECFIC
  Endif

  WMSG = "Integracion de pedidos"
  Call ECR_TRACE(WMSG,0) From GESECRAN
  Call ECR_TRACE(mess(174,100,1),-1) From GESECRAN
  #Call PRTSCR("ZINPE","","",0,1) From ATRTX3
  Call ECR_TRACE(mess(51,9010,1),-1) From GESECRAN

  #Infbox("INICIANDO EXE")
  Call ECR_TRACE("DESCARGANDO PEDIDOS",0) From GESECRAN
  System RESULT=chr$(34) + "C:\Program Files (x86)\Azeta\Integracion de pedidos X3\IntPedidos.exe" + chr$(34)
  #Infbox("FINALIZANDO EXE")


  Gosub INPE

  Call ECR_TRACE("COMUNICACIÓN CON EL PORTAL",0) From GESECRAN
  System RESULT=chr$(34) + "C:\Program Files (x86)\Azeta\Integracion de pedidos X3\Comportal.exe" + chr$(34)

  #Gosub SALDAR_PEDIDO
  #Gosub ASIGNAR_ALLPEDIDO
  End
Return

$TERMINE_INPE
Return

$INIT_DIA_INPE
Return

$OK_INPE
Return

$END_INPE
Return

$INPE

  #Gosub ASIGNAR_IMAGENES
  #End

#Gosub ASIGNAR_ALLPEDIDO
#End

  Local Integer ERRORIMP
  Local Char PEDABIERTO(100)
  Local Char NUMPEDIDO(100)
  Local Char ORIGEN(10)
  Local Char CLIOPEN(100)

  Local Integer ERROR_CLIENTE

  ############################################
  #Infbox("EMPIEZA FUNCION")
  #Call AUTALLTRT (' & ITMREF >= "VEN"') From FUNAUTALL
  #Infbox("FINALIZA FUNCION")

  Filter [ZINPE] Where [ZINPE]ZESTADO=3 and [ZINPE]ZINTE<>'BAR'
  For [ZINPE]
    Call ECR_TRACE("-----------------------------------------------",0) From GESECRAN
    Call ECR_TRACE("Procesando pedido: "+[F:ZINPE]ZREF1,0) From GESECRAN
    ERRORIMP=0

    ORIGEN = [F:ZINPE]ZINTE
   #Infbox(ORIGEN)

    #COMPROBAMOS SI EL PEDIDO ESTÁ ABIERTO
    NUMPEDIDO=""
    REQUEST="SELECT SOHNUM_0 FROM SORDER WHERE CUSORDREF_0='"+[F:ZINPE]ZREF1+"'"
    For (Char NUMPED(100)) From "5" Sql REQUEST As [YYY]
      NUMPEDIDO = [F:YYY]NUMPED
    Next

    If NUMPEDIDO = "" Then
      REQUEST="SELECT SOHNUM_0 FROM SORDER WHERE SOHNUM_0='"+[F:ZINPE]ZREF1+"'"
      For (Char NUMPED(100)) From "5" Sql REQUEST As [YYY]
        NUMPEDIDO = [F:YYY]NUMPED
      Next
    Endif

    PEDABIERTO=""
    REQUEST="SELECT LCKSYM_0 FROM APLLCK WHERE LCKSYM_0='SOH"+NUMPEDIDO+"'"
    For (Char NUMPED(100)) From "5" Sql REQUEST As [YYY]
      PEDABIERTO = [F:YYY]NUMPED
    Next

    #COMPROBAMOS SI EL CLIENTE ESTÁ ABIERTO.
    CLIOPEN=""
    REQUEST = "SELECT LCKSYM_0 FROM APLLCK WHERE LCKSYM_0='BPC"+[F:ZINPE]ZIDCLISA+"'"
    For (Char CODCLI(100)) From "5" Sql REQUEST As [YYY]
      CLIOPEN = [F:YYY]CODCLI
    Next

    If [F:ZINPE]ZINTE<>'X3' Then
      If PEDABIERTO="" and CLIOPEN="" Then
      #If PEDABIERTO="" Then
        Gosub INTEGR_FICH
      Else
        Call ECR_TRACE("No se puede importar el pedido: "+[F:ZINPE]ZREF1,1) From GESECRAN
        Call ECR_TRACE("El cliente "+[F:ZINPE]ZIDCLISA+" está abierto en otra sesión",1) From GESECRAN

        #Infbox("PEDIDO ABIERTO: " + PEDABIERTO)
      Endif
    Else
      Gosub INTEGR_FICH
    Endif
  Next
  Filter [ZINPE]
Return

$INTEGR_FICH

  WNUMMOV=[F:ZINPE]ZREF1
  WNUMLIN=[F:ZINPE]ZIDLIN

  Call ECR_TRACE("PROCESANDO FICHERO: "+[F:ZINPE]ZFICHCLI,0) From GESECRAN
  Call DEBTRANS From GLOCK

  Gosub IMP_CLIENTE

  If ERROR_CLIENTE=1 Then
    ##############################################################################

    Call ECR_TRACE("PROCESANDO FICHERO: "+[F:ZINPE]ZFICHREC,0) From GESECRAN
    Call DEBTRANS From GLOCK

    Gosub IMP_RECEPCION


    ##############################################################################

    Call ECR_TRACE("PROCESANDO FICHERO: "+[F:ZINPE]ZFICHENT,0) From GESECRAN
    Call DEBTRANS From GLOCK

    Gosub IMP_ENTREGA
    ##############################################################################

    Call ECR_TRACE("PROCESANDO FICHERO: "+[F:ZINPE]ZFICHERO,0) From GESECRAN
    Call DEBTRANS From GLOCK

    Gosub IMP_PEDIDO
  Endif

Return

##########################################################################################################################
$IMP_CLIENTE
  Local Char FICORI(250), FICFIN(250)
  Local Char WAUX(50)
  Local Integer STAT
  Local Integer WESTADO
  WESTADO=0

  STAT=0
  ERROR_CLIENTE=1

  FICORI=filpath("BQT",[F:ZINPE]ZFICHCLI,"")
  FICFIN=filpath("ZFP",[F:ZINPE]ZFICHCLI,"")


  If [F:ZINPE]ZFICHCLI<>"" Then
    Call IMPORTSIL("ZBPC",filpath("BQT",[F:ZINPE]ZFICHCLI,"")) From GIMPOBJ
    WAUX=[F:ZINPE]ZFICHCLI
    #Call MOVE(FICORI,FICFIN,STAT) From ORDSYS

    If filinfo(filpath("BQT",[F:ZINPE]ZFICHCLI,"")+".err",0)>0
      Call ECR_TRACE("Error importando cliente",1) From GESECRAN
      ERRORIMP=1
      ERROR_CLIENTE=2
    Endif

    #Se modifican todas las líneas de la tabla ZINTEGRADOR a "Si procesadas" porque estan todas en el mismo fichero de importación
    #Update [ZINPE] Where [ZINPE]ZREF1=WNUMMOV and [ZINPE]ZESTADO=3 and [ZINPE]ZFICHCLI=WAUX and [ZINPE]ZPROCESADO=1 With ZESTADO=WESTADO, ZPROCESADO=2
    #If fstat
    #  GOK=0 : Call FSTA("ZINPE") From GLOCK : STA=14
    #Endif
    #If GOK<0 : Goto ROLL_IMP_CLIENTE
    #Elsif !GOK : Goto AB_IMP_CLIENTE
    #Endif
  Endif

  #Commit
  FILTRANS=0
  Return

#$AB_IMP_CLIENTE
#  #Rollback
#  FILTRANS=0
#  Call ROLL From GLOCK
#  If GROLL : Return : Else : Goto IMP_CLIENTE : Endif

#$ROLL_IMP_CLIENTE
#  #Rollback
#  FLTRANS = 0
#  Call ROLL From GLOCK
#  If GROLL : Return : Else : Goto IMP_CLIENTE : Endif

