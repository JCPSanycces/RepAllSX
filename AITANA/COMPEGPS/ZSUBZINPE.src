############################################################################################################
$IMP_PEDIDO
  Local Char FICORI(250), FICFIN(250)
  Local Char WAUX(100)
  Local Integer STAT
  Local Integer WESTADO
  Local Char MODPEDIDO(100)

  #Extraemos el modelo asociado al cliente
  Raz [F:BPC]
  Read [F:BPC]BPC0=[F:ZINPE]ZIDCLISA
  MODPEDIDO = [F:BPC]ZMODPED
  Filter [F:BPC]

  If MODPEDIDO = "" Then
      MODPEDIDO="ZSOHX"
  Endif

  WESTADO=0

  STAT=0

  FICORI=filpath("BQT",[F:ZINPE]ZFICHERO,"")
  FICFIN=filpath("ZFP",[F:ZINPE]ZFICHERO,"")

  WAUX=""

  If [F:ZINPE]ZFICHERO<>"" Then
    #Extraemos el modelo del pedido que hay relacionado con el cliente
    #En el caso que no haya asignado ninguno en el campo ZMODPED se toma ZSOHX

    #Infbox("LLAMANDO IMPORTACION")
    Call IMPORTSIL(MODPEDIDO,filpath("BQT",[F:ZINPE]ZFICHERO,"")) From GIMPOBJ

    WAUX=[F:ZINPE]ZFICHERO
    #Call MOVE(FICORI,FICFIN,STAT) From ORDSYS

    If filinfo(filpath("BQT",[F:ZINPE]ZFICHERO,"")+".err",0)>0
      Call ECR_TRACE("Error importando pedido",1) From GESECRAN
      ERRORIMP=1
    Endif
  Endif

  #Se modifican todas las líneas de la tabla ZINTEGRADOR a "Si procesadas" porque estan todas en el mismo fichero de importación
  If ERRORIMP=1 Then
    WESTADO=5
  Else
    WESTADO=4
  Endif

  If WAUX<>"" Then
    Update [ZINPE] Where [ZINPE]ZREF1=WNUMMOV and [ZINPE]ZESTADO=3 and [ZINPE]ZFICHERO=WAUX and [ZINPE]ZPROCESADO=1 With ZESTADO=WESTADO,ZPROCESADO=2
  Else
    #Infbox("actualizamos")
    #Infbox(WNUMMOV)

    Update [ZINPE] Where [ZINPE]ZREF1=WNUMMOV and [ZINPE]ZESTADO=3 and [ZINPE]ZPROCESADO=1 With ZESTADO=WESTADO,ZPROCESADO=2
  Endif
  If fstat
    GOK=0 : Call FSTA("ZINPE") From GLOCK : STA=14
  Endif
  If GOK<0 : Goto ROLL_IMP_PEDIDO
  Elsif !GOK : Goto AB_IMP_PEDIDO
  Endif
  #Commit
  FILTRANS=0

  Gosub ASIGNAR_PEDIDO



  If ORIGEN="Privalia" Then
    #Gosub SALDAR_PEDIDO
  Endif

  Return

$AB_IMP_PEDIDO
  #Rollback
  FILTRANS=0
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto IMP_PEDIDO : Endif

$ROLL_IMP_PEDIDO
  #Rollback
  FLTRANS = 0
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto IMP_PEDIDO : Endif

$ASIGNAR_PEDIDO
  Local Char NUMPED(50)
  Local Char PLANTAPED(50)
  Local Char REQUEST(255)
  Local Integer WZGSERVEUR
  Local Char WSAVFNC(255)
  Local Date FECHAEXPEDICION

  Local Integer ENTREGA_PARCIAL
  Local Double TOTUNIASIG
  Local Integer ENTREGABLE
  Local Double TOTUNIRUP
  Local Double TOTIMPPS
  Local Double TOTALIMPX3

  Local Char FPAGOX3(25)


  #keep GFONCTION
  WSAVFNC = GFONCTION
  GFONCTION = "FUNAUTALL"


  #indicate that is not web service
  WZGSERVEUR = GSERVEUR
  GSERVEUR = 1

  #Extraemos el nº de pedido a partir de la referencia
  NUMPED = ""
  REQUEST="SELECT SOHNUM_0 FROM SORDER WHERE CUSORDREF_0='"+[F:ZINPE]ZREF1+"'"
  For (Char NUMPEDIDO(50)) From "5" Sql REQUEST As [XXX]
    NUMPED = [F:XXX]NUMPEDIDO
  Next

  If NUMPED = "" Then
    REQUEST="SELECT SOHNUM_0 FROM SORDER WHERE SOHNUM_0='"+[F:ZINPE]ZREF1+"'"
    For (Char NUMPEDIDO(50)) From "5" Sql REQUEST As [XXX]
      NUMPED = [F:XXX]NUMPEDIDO
    Next
  Endif

  PLANTAPED=""
  REQUEST="SELECT STOFCY_0 FROM SORDER WHERE CUSORDREF_0='"+[F:ZINPE]ZREF1+"'"
  For (Char PLANTA(50)) From "5" Sql REQUEST As [YYY]
    PLANTAPED = [F:YYY]PLANTA
  Next

  If PLANTAPED = "" Then
    REQUEST="SELECT STOFCY_0 FROM SORDER WHERE SOHNUM_0='"+[F:ZINPE]ZREF1+"'"
    For (Char PLANTA(50)) From "5" Sql REQUEST As [YYY]
      PLANTAPED = [F:YYY]PLANTA
    Next
  Endif

  Raz FECHAEXPEDICION
  REQUEST="SELECT SHIDAT_0 FROM SORDER WHERE CUSORDREF_0='"+[F:ZINPE]ZREF1+"'"
  For (Date FEXP) From "5" Sql REQUEST As [YYY]
    FECHAEXPEDICION = [F:YYY]FEXP
  Next

  REQUEST="SELECT SHIDAT_0 FROM SORDER WHERE SOHNUM_0='"+[F:ZINPE]ZREF1+"'"
  For (Date FEXP) From "5" Sql REQUEST As [YYY]
    FECHAEXPEDICION = [F:YYY]FEXP
  Next

  # Lanzar una acción, existente en X3
  If NUMPED<>"" and PLANTAPED<>"" Then
    Call ECR_TRACE("ASIGNANDO PEDIDO: "+NUMPED+" DE LA PLANTA "+PLANTAPED,0) From GESECRAN

    Local Char VALBOUT(250),PARBOUT(250)(1..20)
    PARBOUT(1)=PLANTAPED
    PARBOUT(2)=FECHAEXPEDICION
    PARBOUT(3)=NUMPED
    FLGEXE=1
    # ZPAGPRV => Nombre de la acción existente en X3
    GACTION="TRTAUTALL"
    # ZSUBPAG => Nombre del Estándar
    # ZSPEPAG => Nombre del Específico
    Call TRAITE_CHAR(VALBOUT,PARBOUT,"","FUNAUTALL","",1,"XYFUNAUTALL") From GTRAITE

    #restore back the original values
    GFONCTION = WSAVFNC
    GSERVEUR = WZGSERVEUR
  Else
    Call ECR_TRACE("****** PEDIDO "+[F:ZINPE]ZREF1+" SIN ASIGNAR. No se ha encontrado el pedido en X3",0) From GESECRAN
  Endif

  ###########################################################################################################
  #Después de lanzar la asignación actualizar el campo ZENTREGABLE.
  #Comprobamos qué tipo de asignación tiene el cliente
  ENTREGA_PARCIAL=0
  ENTREGABLE=2

  REQUEST="SELECT DME_0 FROM BPCUSTOMER WHERE BPCNUM_0='"+[F:ZINPE]ZIDCLISA+"'"
  For (Integer ENTREGA) From "5" Sql REQUEST As [XXX]
    ENTREGA_PARCIAL = [F:XXX]ENTREGA
  Next

  #Solo Pedidos de PS: Si ‘total pedido X3’ = ‘Total origen’
  #ENTREGABLE =SI ELSE ENTREGABLE = NO y forzar que se detenga el proceso.
  If [F:ZINPE]ZINTE="Prestashop" Then
    TOTIMPPS=[F:ZINPE]ZIMPECC
    TOTALIMPX3=0
    REQUEST="SELECT ORDINVATI_0 FROM SORDER WHERE SOHNUM_0='"+NUMPED+"'"
    For (Double PRECIO) From "5" Sql REQUEST As [XXX]
      TOTALIMPX3 = [F:XXX]PRECIO
    Next


    If TOTIMPPS<>TOTALIMPX3 and abs(TOTIMPPS-TOTALIMPX3)>0.05 Then
      ENTREGABLE=1
    Endif
    #Infbox("DIFERENCIA:" + num$(ENTREGABLE))

    #SI CLIENTE.ENTREGA-PARCIAL = SI Y TOTAL UNIDADES ASIGNADAS DEL PEDIDO > 0, ENTREGABLE = SI
    TOTUNIASIG=0
    REQUEST="SELECT SUM(ALLQTY_0) AS CANTIDAD FROM SORDERQ WHERE SOHNUM_0='"+NUMPED+"'"
    For (Double CANTIDAD) From "5" Sql REQUEST As [XXX]
      TOTUNIASIG = [F:XXX]CANTIDAD
    Next
    If ENTREGA_PARCIAL=1 and TOTUNIASIG<=0 Then
      ENTREGABLE=1
    Endif

    #Infbox("CANTIDAD ASIGNDA: " + num$(ENTREGABLE))

    #Si Pedido.Cantidad ruptura total = 0, ENTREGABLE = ‘NO’
    TOTUNIASIG=0
    REQUEST="SELECT SUM(ALLQTY_0) AS CANTIDAD FROM SORDERQ WHERE SOHNUM_0='"+NUMPED+"'"
    For (Double CANTIDAD) From "5" Sql REQUEST As [XXX]
      TOTUNIASIG = [F:XXX]CANTIDAD
    Next
    If TOTUNIASIG=0 Then
      ENTREGABLE=1
    Endif

    #Infbox("CANTIDAD RUPTURA: " + num$(ENTREGABLE))

    #Si Cliente.Entrega-completa = SI y pedido.total cantidad ruptura > 0, ENTREGABLE = NO
    TOTUNIRUP=0
    REQUEST="SELECT SUM(SHTQTY_0) AS CANTIDAD FROM SORDERQ WHERE SOHNUM_0='"+NUMPED+"'"
    For (Double CANTIDAD) From "5" Sql REQUEST As [XXX]
      TOTUNIRUP = [F:XXX]CANTIDAD
    Next

    If ENTREGA_PARCIAL=3 and TOTUNIRUP>0 Then
      ENTREGABLE=1
    Endif


    #Infbox("PEDIDO COMPLETO CANTIDAD RUPTURA: " + num$(ENTREGABLE))

  Else
    #SI CLIENTE.ENTREGA-PARCIAL = SI Y TOTAL UNIDADES ASIGNADAS DEL PEDIDO > 0, ENTREGABLE = SI
    TOTUNIASIG=0
    REQUEST="SELECT SUM(ALLQTY_0) AS CANTIDAD FROM SORDERQ WHERE SOHNUM_0='"+NUMPED+"'"
    For (Double CANTIDAD) From "5" Sql REQUEST As [XXX]
      TOTUNIASIG = [F:XXX]CANTIDAD
    Next
    If ENTREGA_PARCIAL=1 and TOTUNIASIG<=0 Then
      ENTREGABLE=1
    Endif

    #Infbox("PEDIDO PARCIAL CANTIDAD ASIGNADA: " + num$(ENTREGABLE))

    #Si Pedido.Cantidad ruptura total = 0, ENTREGABLE = ‘NO’
    TOTUNIASIG=0
    REQUEST="SELECT SUM(ALLQTY_0) AS CANTIDAD FROM SORDERQ WHERE SOHNUM_0='"+NUMPED+"'"
    For (Double CANTIDAD) From "5" Sql REQUEST As [XXX]
      TOTUNIASIG = [F:XXX]CANTIDAD
    Next
    If TOTUNIASIG=0 Then
      ENTREGABLE=1
    Endif

    #Infbox("CANTIDAD ASIGNADA: " + num$(ENTREGABLE))

    #Si Cliente.Entrega-completa = SI y pedido.total cantidad ruptura > 0, ENTREGABLE = NO
    TOTUNIRUP=0
    REQUEST="SELECT SUM(SHTQTY_0) AS CANTIDAD FROM SORDERQ WHERE SOHNUM_0='"+NUMPED+"'"
    For (Double CANTIDAD) From "5" Sql REQUEST As [XXX]
      TOTUNIRUP = [F:XXX]CANTIDAD
    Next

    If ENTREGA_PARCIAL=3 and TOTUNIRUP>0 Then
      ENTREGABLE=1
    Endif

    #Infbox("PEDIDO COMPLETO CANTIDAD RUPTURA: " + num$(ENTREGABLE))
  Endif

  #Comprobamos la forma de pago si es transferencia
  FPAGOX3=""
  REQUEST="SELECT PTE_0 FROM SORDER WHERE SOHNUM_0='"+NUMPED+"'"
  For (Char PAGO(25)) From "5" Sql REQUEST As [XXX]
    FPAGOX3 = [F:XXX]PAGO
  Next
  #Infbox(FPAGOX3)
  If FPAGOX3="TRANSF0" Then
    ENTREGABLE=1
  Endif

  #Actualizamos el campo ZENTREGABLE en el pedido
   #Infbox(NUMPED)
  Update [SOH] Where [SOH]SOHNUM=NUMPED With ZENTREGABLE=ENTREGABLE


  Return

############################################################################################
$SALDAR_PEDIDO

  Local Char VALBOUT(250),PARBOUT(250)(1..20)
  Local Char NUMPED(50)
  Local Char REQUEST(255)
  Local Integer WZGSERVEUR

  WZGSERVEUR = GSERVEUR
  GSERVEUR = 1

  #Extraemos el nº de pedido a partir de la referencia
  NUMPED = ""
  REQUEST="SELECT SOHNUM_0 FROM SORDER WHERE CUSORDREF_0='"+[F:ZINPE]ZREF1+"'"
  For (Char NUMPEDIDO(50)) From "5" Sql REQUEST As [XXX]
    NUMPED = [F:XXX]NUMPEDIDO
  Next

  PARBOUT(1)=NUMPED
  PARBOUT(2)=""
  FLGEXE=1

  Call ECR_TRACE("SALDANDO PEDIDO: "+NUMPED,0) From GESECRAN

  GACTION="TRTCLESOH"
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","TRTVENCDE","",1,"XYTRTVENCDE") From GTRAITE

  GSERVEUR = WZGSERVEUR

  Return
############################################################################################
$SALDAR_PEDIDO_OLD
  Local Char NUMPED(50)
  Local Char REQUEST(255)
  Local Integer WZGSERVEUR
  Local Char WSAVFNC(255)


  #keep GFONCTION
  WSAVFNC = GFONCTION
  GFONCTION = "ZSALDOPED"

  #indicate that is not web service
  WZGSERVEUR = GSERVEUR
  GSERVEUR = 1

  #Extraemos el nº de pedido a partir de la referencia
  NUMPED = ""
  REQUEST="SELECT SOHNUM_0 FROM SORDER WHERE CUSORDREF_0='"+[F:ZINPE]ZREF1+"'"
  For (Char NUMPEDIDO(50)) From "5" Sql REQUEST As [XXX]
    NUMPED = [F:XXX]NUMPEDIDO
  Next



  Call ECR_TRACE("SALDANDO PEDIDO: "+NUMPED,0) From GESECRAN

  # Lanzar una acción, existente en X3
  Local Char VALBOUT(250),PARBOUT(250)(1..20)
  PARBOUT(1)=NUMPED
  #PARBOUT(2)=""
  FLGEXE=1
  # ZPAGPRV => Nombre de la acción existente en X3
  GACTION="TRTFUNCLE"
  # ZSUBPAG => Nombre del Estándar
  # ZSPEPAG => Nombre del Específico
  Call TRAITE_CHAR(VALBOUT,PARBOUT,"","TRTVENCDE","",1,"XYTRTVENCDE") From GTRAITE

  #restore back the original values
  GFONCTION = WSAVFNC
  GSERVEUR = WZGSERVEUR

  Return

###########################################################################################
$ASIGNAR_IMAGENES
  Local Char DIR(250),FILELIST(250)(1..4002)
  Local Integer LNGTH : Raz LNGTH

  DIR="C:\test"

  Call SYSTEME2(adxmac(0),"lsadx"-DIR,"",LNGTH,FILELIST) From ORDSYS

  For I=3 To LNGTH
    Infbox FILELIST(I)
  Next
  Return

$ASIGNAR_ALLPEDIDO
  Local Char NUMPED(50)
  Local Char PLANTAPED(50)
  Local Char REQUEST(255)
  Local Integer WZGSERVEUR
  Local Char WSAVFNC(255)

  #Extraemos el nº de pedido a partir de la referencia
  REQUEST="SELECT SOHNUM_0,STOFCY_0 FROM SORDER WHERE CREDATTIM_0>='20/09/2016' ORDER BY CREDATTIM_0"
  For (Char NUMPEDIDO(50),Char PLANTAPED(50)) From "5" Sql REQUEST As [XXX]

    #keep GFONCTION
    WSAVFNC = GFONCTION
    GFONCTION = "FUNAUTALL"


    #indicate that is not web service
    WZGSERVEUR = GSERVEUR
    GSERVEUR = 1



    #Call ECR_TRACE("ASIGNANDO PEDIDO: "+NUMPED+" DE LA PLANTA "+PLANTAPED,0) From GESECRAN

    # Lanzar una acción, existente en X3
    Local Char VALBOUT(250),PARBOUT(250)(1..20)
    PARBOUT(1)=[F:XXX]PLANTAPED
    PARBOUT(2)=""
    PARBOUT(3)=[F:XXX]NUMPEDIDO
    FLGEXE=1

    #Infbox([F:XXX]NUMPEDIDO)

    # ZPAGPRV => Nombre de la acción existente en X3
    GACTION="TRTAUTALL"
    # ZSUBPAG => Nombre del Estándar
    # ZSPEPAG => Nombre del Específico
    Call TRAITE_CHAR(VALBOUT,PARBOUT,"","FUNAUTALL","",1,"XYFUNAUTALL") From GTRAITE

    #restore back the original values
    GFONCTION = WSAVFNC
    GSERVEUR = WZGSERVEUR

  Next
  Return

$ENVIAR_EMAIL
Infbox (GSERMES)
Send GSERMES With
& "__TO="+chr$(1)+"floren.presumido@grupoazeta.com",
& "__CONTXT="+chr$(1)+"GESBPC",
& "__NOTE="+chr$(1)+"Error al importar el pedido XXX"

Infbox("ENVIADO EMAIL")

Return

$CONTROL_ENTREGABLE

