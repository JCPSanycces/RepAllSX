#<AdxTL>@(#)0.0.0.0 $Revision$
# JLPR ZCRM -
# Fuente  TRTCRMPE.src
#         GPOINT = "CRMAGD" : Gosub ENTREE From EXEFNC
#

$ACTION
Case ACTION
  When "CRMAGD" : Gosub CRMAGD
Endcase
Return

$CRMAGD
Local Char WF(250)
Local Integer WOK
Raz WOK,WF
#Sacar todos los representantes autorizados al usuarioX3 conectado
If [M:CRM0]REP = "" and dim(SZAND)>0 Then
  If !clalev([F:WZAUTAG])   :  Local File ZAUTAGENDA   [F:WZAUTAG]  :  Endif
  Filter [F:WZAUTAG] Where CODUSR=GUSER
  If rowcount([F:WZAUTAG])>0
    For [F:WZAUTAG]
      Case SZCNTCRMAGD
      When  "AGDBAP","INFBAP","BAPPOINT"   # Plan trabajo/Agenda  +  Citas
        If WF<>"" WF+=" OR " Endif
        WF+="[F:BAP]APTREPNUM='"+ [F:WZAUTAG]APTCMP+"'"
      When "AGDCLL","INFCLL","PHONECALL"   # Plan trabajo/Agenda  +  Llamadas
        If WF<>"" WF+=" OR " Endif
        WF+="[F:CLL]CLLREP='"   + [F:WZAUTAG]APTCMP+"'"
      When "AGDTSK","INFTSK","TASK"        # Plan trabajo/Agenda  +  Tareas
        If WF<>"" WF+=" OR " Endif
        WF+="[F:TSK]TSKREP='"   + [F:WZAUTAG]APTCMP+"'"
      When "OPPOR","INFOPP"                #                         Proyectos
        If WF<>"" WF+=" OR " Endif
        WF+="[F:OPP]OPPREP='"   + [F:WZAUTAG]APTCMP+"'"
      When "PHONING","INFCON"              #                         Campañas
        If WF<>"" WF+=" OR " Endif
        WF+="[F:CON]SALREP='"   + [F:WZAUTAG]APTCMP+"'"
      Endcase
    Next
    If WF<>""   WF="("+WF+") "      Endif
  Else
    WF="1<>1 "
  Endif
  If WF<>""
    SZWHERE(ILIGNEWHERE) = SZAND - WF
    ILIGNEWHERE += 1
    SZAND = " AND "
#    If GUSER="ADMIN" Infbox "SZCNTCRMAGD="+SZCNTCRMAGD+"    WF= "+WF Endif
  Endif
Endif

Return

