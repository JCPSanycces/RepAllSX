#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
When "LIENS"    :     Gosub LIENS
When "AFFMASK"  :     Gosub AFFMASK
When "FERME"    :     Gosub FERME
Endcase
Return


$LIENS
Call LLENA_REJILLA
Return

$AFFMASK
Local Integer BORRAR_G
If dim(GFLDNUM)<1
  Global Decimal GFLDNUM(5)
  BORRAR_G=1
Endif
# Tope de filas en rejilla
GFLDNUM(0) = func ZCOMUN.FILAS_GRID("ZAUTAG0","NBLIG")
Return

$FERME
If BORRAR_G Kill GFLDNUM Endif
Return


Subprog LLENA_REJILLA
Local Integer F
#Vaciar  rejilla
Raz [M:ZAUTAG0]NBLIG
Effzo [M:ZAUTAG0]10
#Llenarla
If !clalev([F:WZAUTAG])   :  Local File ZAUTAGENDA   [F:WZAUTAG]  :  Endif
Filter [F:WZAUTAG] Where CODUSR=[M:ZAUTAG0]CODUSR
For [F:WZAUTAG]
  F=[M:ZAUTAG0]NBLIG
  [M:ZAUTAG0]ZREP(F)=[F:WZAUTAG]APTCMP
  If [M:ZAUTAG0]NBLIG+1>=GFLDNUM(0)
    MSG="FALTAN DATOS\Alcanzado máximo de " + num$(GFLDNUM(0)+1) + " filas para mostrar resumen\.\Avise para que se lo aumenten"
    Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
    Break
  Else
    [M:ZAUTAG0]NBLIG+=1
  Endif
Next
End

