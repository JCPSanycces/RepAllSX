#<AdxTL>@(#)0.0.0.0 $Revision$
#Proceso integracion de pedidos lanzado mediante tarea programada en batch.
#Versión 2.0
###########################################################################
#Envío de alerta para informar de recepciones en opción 17 con Q2 y Q3
#
###########################################################################
#Versión 3.0
###########################################################################
#Importación de ficheros generados en opción 18 (Picking pedidos grandes)

$ACTION
#Infbox ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub TRT_INI
  When "EXEC"           : Gosub EXEC_INPE
  When "TERMINE"        : Gosub TERMINE_INPE
  When "INIT"           : Gosub INIT_DIA_INPE
  When "OK"             : Gosub OK_INPE
  When "END"            : Gosub END_INPE
Endcase

Return

$TRT_INI
  If !clalev([F:SOH])        : Local File SORDER         [SOH]   : Endif
  If !clalev([F:PTH])        : Local File PRECEIPT       [PTH]   : Endif
  If clalev([F:ZPREP])<=0    : Local File ZPREP          [ZPREP] : Endif
  If clalev([F:ZINPE])<=0    : Local File ZINTEGRADOR    [ZINPE] : Endif
  If clalev([F:ZPRESOD])<=0  : Local File ZPRESOD        [ZPSD]  : Endif
  If clalev([F:ZPREPAC])<=0  : Local File ZPREPPACK      [ZPREPAC]  : Endif
  If !clalev([F:SDH])        : Local File SDELIVERY      [SDH]   : Endif
  If clalev([F:ZPRESOD])<=0     : Local File ZPRESOD        [ZPSD2]  : Endif
  If clalev([F:SPH])<=0    : Local File SPACK          [SPH] : Endif
  If clalev([F:SPD])<=0    : Local File SPACKD          [SPD] : Endif


  Local Char     DOSIERACTUAL(50)
  Local Char     FICHEROTRAZA(250)

  DOSIERACTUAL="FANNYSDES"
Return

$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

$EXEC_INPE
  Local Clbfile  TEXTORECEPCION(0)
  Local Char     ASUNTO(250)
  Local Clbfile  ENCABEZADO(0)
  Local Clbfile  PIE(0)
  Local Clbfile  MENSAJE(0)


  Gosub TRT_INI
  If GSERVEUR
    Onerrgo ERRBATCH
    Call ECR_TRACE("Inicio integracion de pedidos",0) From GESECRAN
  Else
    Call OUVRE_TRACE("Inicio integracion de pedidos") From LECFIC
  Endif

  WMSG = "Integracion de pedidos"
  Call ECR_TRACE(WMSG,0) From GESECRAN
  Call ECR_TRACE(mess(174,100,1),-1) From GESECRAN
  #Call PRTSCR("ZINPE","","",0,1) From ATRTX3
  Call ECR_TRACE(mess(51,9010,1),-1) From GESECRAN

  #Gosub ACTU_SCCCOD
  Gosub INPE
  Gosub INPE_SGA18
  #Gosub ASIGNAR_ALLPEDIDO
Return

$TERMINE_INPE
Return

$INIT_DIA_INPE
Return

$OK_INPE
Return

$END_INPE
Return

$INPE_SGA18
 Local Char FICHACTUAL(255)

 Filter [ZPSD] Where ([ZPSD]ZSTAPRE=5 or [ZPSD]ZSTAPRE=2 or [ZPSD]ZSTAPRE=6) and [ZPSD]ZFICENTXML<>'' and [ZPSD]ZESTADO=1 Order By [ZPSD]ZFICENTXML
  For [ZPSD]
    If FICHACTUAL<>[ZPSD]ZFICENTXML
      FICHACTUAL = [ZPSD]ZFICENTXML

      #Comprobamos que el pedido no esté abierto en otra sesión
      PEDABIERTO=""
      REQUEST="SELECT LCKSYM_0 FROM APLLCK WHERE LCKSYM_0='SOH"+[ZPSD]ZNUMPED+"'"
      For (Char NUMPED(100)) From "5" Sql REQUEST As [YYY]
        PEDABIERTO = [F:YYY]NUMPED
      Next
      If PEDABIERTO="" Then
        Gosub IMP_ENTREGA_SGA18
      Else
        Call ECR_TRACE("**** Error en la creacion de la entrega ****",1) From GESECRAN
        Call ECR_TRACE("El pedido "+[ZPSD]ZNUMPED+" está abierto en otra sesión",1) From GESECRAN
      Endif
    Endif
  Next
 Filter [ZPSD]

Return

$INPE
  #Gosub ASIGNAR_IMAGENES
  #End

  Local Integer ERRORIMP
  Local Char NUMPEDIDO(100)
  Local Char CODCLIENTE(50)

  Local Char CURRDATE(50)
  Local Char CURRTIME(50)
  Local Char CURRDATETIME_STR(100)

  ############################################
  #Infbox("EMPIEZA FUNCION")
  #Call AUTALLTRT (' & ITMREF >= "VEN"') From FUNAUTALL
  #Infbox("FINALIZA FUNCION")
  Filter [ZPREP] Where ([ZPREP]ZESTADO=3) and ([ZPREP]ZINTE='SGA' or [ZPREP]ZINTE='SGA14' or [ZPREP]ZINTE='SGA16' or [ZPREP]ZINTE='SGA17')
  For [ZPREP]
    ERRORIMP=0

    Raz ASUNTO
    Raz ENCABEZADO
    Raz PIE
    Raz MENSAJE
    Raz TEXTORECEPCION

    If [ZPREP]ZINTE="SGA" Then
      #COMPROBAMOS SI EL PEDIDO DE VENTA ESTÁ ABIERTO
      NUMPEDIDO=""
      REQUEST="SELECT SOHNUM_0,BPCORD_0 FROM SORDER WHERE CUSORDREF_0='"+[F:ZPREP]ZREF1+"'"
      For (Char NUMPED(100),Char CLIENTE(50)) From "5" Sql REQUEST As [YYY]
        NUMPEDIDO = [F:YYY]NUMPED
        CODCLIENTE = [F:YYY]CLIENTE
      Next

      If NUMPEDIDO = "" Then
        REQUEST="SELECT SOHNUM_0,BPCORD_0 FROM SORDER WHERE SOHNUM_0='"+[F:ZPREP]ZREF1+"'"
        For (Char NUMPED(100),Char CLIENTE(50)) From "5" Sql REQUEST As [YYY]
          NUMPEDIDO = [F:YYY]NUMPED
          CODCLIENTE = [F:YYY]CLIENTE
        Next
      Endif

      PEDABIERTO=""
      REQUEST="SELECT LCKSYM_0 FROM APLLCK WHERE LCKSYM_0='SOH"+NUMPEDIDO+"'"
      For (Char NUMPED(100)) From "5" Sql REQUEST As [YYY]
        PEDABIERTO = [F:YYY]NUMPED
      Next
      If PEDABIERTO="" Then
        Gosub INTEGR_FICH
      Else
        #Infbox("PEDIDO ABIERTO: " + PEDABIERTO)
      Endif
   Elsif [ZPREP]ZINTE="SGA14" Then
      NUMPEDIDO=""
      If NUMPEDIDO = "" Then
          REQUEST="SELECT POHNUM_0 FROM PORDER WHERE POHNUM_0='"+[F:ZPREP]ZREF1+"'"
          For (Char NUMPED(100)) From "5" Sql REQUEST As [YYY]
            NUMPEDIDO = [F:YYY]NUMPED
          Next
      Endif
      PEDABIERTO=""
      REQUEST="SELECT LCKSYM_0 FROM APLLCK WHERE LCKSYM_0='POH"+NUMPEDIDO+"'"
      For (Char NUMPED(100)) From "5" Sql REQUEST As [YYY]
          PEDABIERTO = [F:YYY]NUMPED
      Next
      If PEDABIERTO="" Then
          Gosub INTEGR_FICH
      Else
      Endif

   Elsif [ZPREP]ZINTE="SGA16" Then
      Gosub INTEGR_FICH

   Elsif [ZPREP]ZINTE="SGA17" Then
      NUMPEDIDO=""
      If NUMPEDIDO = "" Then
          REQUEST="SELECT POHNUM_0 FROM PORDER WHERE POHNUM_0='"+[F:ZPREP]ZREF1+"'"
          For (Char NUMPED(100)) From "5" Sql REQUEST As [YYY]
            NUMPEDIDO = [F:YYY]NUMPED
          Next
      Endif
      PEDABIERTO=""
      REQUEST="SELECT LCKSYM_0 FROM APLLCK WHERE LCKSYM_0='POH"+NUMPEDIDO+"'"
      For (Char NUMPED(100)) From "5" Sql REQUEST As [YYY]
          PEDABIERTO = [F:YYY]NUMPED
      Next
      If PEDABIERTO="" Then
          Gosub INTEGR_FICH
      Else

        FICHEROTRAZA=filpath("TRA",GTRACE,"tra")

        Call ECR_TRACE("**** Error en la creacion de la recepción ****",1) From GESECRAN
        Call ECR_TRACE("El pedido "+NUMPEDIDO+" está abierto en otra sesión",1) From GESECRAN

        Append TEXTORECEPCION,chr$(10)+'**** Error en la creacion de la recepción ****'+chr$(10)+chr$(10)
        Append TEXTORECEPCION,'Se ha producido un error al importar el fichero '+[F:ZINPE]ZFICHREC+chr$(10)+chr$(10)
        Append TEXTORECEPCION,'El pedido '+NUMPEDIDO+' está abierto en otra sesión'+chr$(10)+chr$(10)
        Append TEXTORECEPCION,'El proceso intentará importar el fichero en la siguiente ejecución'+chr$(10)+chr$(10)
        Append TEXTORECEPCION,'Revise el fichero de traza que se adjunta en el email'+chr$(10)+chr$(10)

        ASUNTO="ZIMPSGA: Error en la importación - "+DOSIERACTUAL
        Append ENCABEZADO, 'Le informamos que se han producido errores durante la importación en X3'+chr$(10)+chr$(10)
        Append PIE, "Administrador del sistema"
        Append MENSAJE,ENCABEZADO
        Append MENSAJE,TEXTORECEPCION
        Append MENSAJE,PIE

        Gosub ENVIAR_EMAIL

      Endif
    Endif
  Next
  Filter [ZPREP]
Return

$INTEGR_FICH

  Local Char WNUMOV(255)

  WNUMMOV=[F:ZPREP]ZREF1
  WNUMLIN=[F:ZPREP]ZIDLIN

  ##############################################################################
  If [ZPREP]ZINTE='SGA' Then
      Call ECR_TRACE("PROCESANDO FICHERO: "+[F:ZPREP]ZFICHENT,0) From GESECRAN
      Call DEBTRANS From GLOCK

      Gosub IMP_ENTREGA
      ##############################################################################
  Elsif [ZPREP]ZINTE='SGA14' Then
      Call ECR_TRACE("PROCESANDO FICHERO: "+[F:ZPREP]ZFICHREC,0) From GESECRAN
      Call DEBTRANS From GLOCK

      Gosub IMP_RECEPCION
      ##############################################################################
  Elsif [ZPREP]ZINTE='SGA16' Then
      If [F:ZPREP]ZFICHERO<>"" Then
          Call ECR_TRACE("PROCESANDO FICHERO: "+[F:ZPREP]ZFICHERO,0) From GESECRAN
      Elsif [F:ZPREP]ZFICHREC<>"" Then
          Call ECR_TRACE("PROCESANDO FICHERO: "+[F:ZPREP]ZFICHREC,0) From GESECRAN
      Endif
      Call DEBTRANS From GLOCK

      Gosub IMP_CAMBIOUBI

      Gosub IMP_RECEPCION

  Elsif [ZPREP]ZINTE='SGA17' Then
      If [F:ZPREP]ZFICHREC<>"" Then
          Call ECR_TRACE("PROCESANDO FICHERO: "+[F:ZPREP]ZFICHREC,0) From GESECRAN
      Endif
      Call DEBTRANS From GLOCK

      Gosub IMP_RECEPCION_SGA17
  Endif
Return


############################################################################################################
$IMP_ENTREGA
  Local Char FICORI(250), FICFIN(250)
  Local Char WAUX(100)
  Local Integer STAT
  Local Integer WESTADO
  WESTADO=0

  STAT=0

  FICORI=filpath("BQT",[F:ZPREP]ZFICHENT,"")
  FICFIN=filpath("ZFP",[F:ZPREP]ZFICHENT,"")

  If [F:ZPREP]ZFICHENT<>"" Then
    #Infbox("LLAMANDO IMPORTACION")
    Call IMPORTSIL("ZSDH",filpath("BQT",[F:ZPREP]ZFICHENT,"")) From GIMPOBJ

    WAUX=[F:ZPREP]ZFICHENT
    #Call MOVE(FICORI,FICFIN,STAT) From ORDSYS

    If filinfo(filpath("BQT",[F:ZPREP]ZFICHENT,"")+".err",0)>0
      Call ECR_TRACE("Error importando entrega",1) From GESECRAN
      ERRORIMP=1
    Endif
  Endif

  #Se modifican todas las líneas de la tabla ZINTEGRADOR a "Si procesadas" porque estan todas en el mismo fichero de importación
   #Se modifican todas las líneas de la tabla ZINTEGRADOR a "Si procesadas" porque estan todas en el mismo fichero de importación
   ERRORIMP=0
  If ERRORIMP=1 Then
    WESTADO=5
  Else
    WESTADO=4

    If CODCLIENTE="43001746" or CODCLIENTE="43002136" Then #SE TRATA DE UN PEDIDO DE PRIVALIA
      CURRDATE = (num$(day(date$))) + "/" + (num$(month(date$))) + "/" + num$(year(date$))
      CURRTIME = num$(time$)

      CURRDATETIME_STR =CURRDATE + " " + CURRTIME

      Update [SOH] Where SOHNUM=NUMPEDIDO With ZFCONFSALMKT=CURRDATETIME_STR
      Update [ZINPE] Where ZREF1=[ZPREP]ZREF1 With ZFCONFSALMKT=CURRDATETIME_STR
    Endif

    #Gosub ASIGNAR_PEDIDO
  Endif

  Update [ZPREP] Where [ZPREP]ZREF1=WNUMMOV and ([ZPREP]ZESTADO=3 or [ZPREP]ZESTADO=5) and [ZPREP]ZFICHENT=WAUX With ZESTADO=WESTADO
  If fstat
    GOK=0 : Call FSTA("ZIMPSGA") From GLOCK : STA=14
  Endif
  If GOK<0 : Goto ROLL_IMP_ENTREGA
  Elsif !GOK : Goto AB_IMP_ENTREGA
  Endif
  #Commit
  FILTRANS=0
  Return

$AB_IMP_ENTREGA
  #Rollback
  FILTRANS=0
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto IMP_ENTREGA : Endif

$ROLL_IMP_ENTREGA
  #Rollback
  FLTRANS = 0
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto IMP_ENTREGA : Endif

############################################################################################################
$IMP_RECEPCION
  Local Char FICORI(250), FICFIN(250)
  Local Char WAUX(250)
  Local Integer STAT
  Local Integer WESTADO
  Local Integer ID
  WESTADO=0

  STAT=0

  FICORI=filpath("BQT",[F:ZPREP]ZFICHREC,"")
  FICFIN=filpath("ZFP",[F:ZPREP]ZFICHREC,"")

  WAUX=[F:ZPREP]ZFICHREC

  If [F:ZPREP]ZFICHREC<>"" Then
    #Infbox("LLAMANDO IMPORTACION")
    Call IMPORTSIL("ZPTH",filpath("BQT",[F:ZPREP]ZFICHREC,"")) From GIMPOBJ


    #Call MOVE(FICORI,FICFIN,STAT) From ORDSYS

    ERRORIMP=0
    If filinfo(filpath("BQT",[F:ZPREP]ZFICHREC,"")+".err",0)>0
      Call ECR_TRACE("Error importando entrega",1) From GESECRAN
      ERRORIMP=1
    Endif
  Endif

  #Se modifican todas las líneas de la tabla ZINTEGRADOR a "Si procesadas" porque estan todas en el mismo fichero de importación
   #Se modifican todas las líneas de la tabla ZINTEGRADOR a "Si procesadas" porque estan todas en el mismo fichero de importación

  If ERRORIMP=1 Then
    WESTADO=5
  Else
    WESTADO=4

    #Gosub ASIGNAR_PEDIDO
  Endif
  Update [ZPREP] Where [ZPREP]ZFICHREC=WAUX With ZESTADO=WESTADO
  If fstat
    GOK=0 : Call FSTA("ZIMPSGA") From GLOCK : STA=14
  Endif
  If GOK<0 : Goto ROLL_IMP_RECEPCION
  Elsif !GOK : Goto AB_IMP_RECEPCION
  Endif
  #Commit
  FILTRANS=0
  Return

$AB_IMP_RECEPCION
  #Rollback
  FILTRANS=0
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto IMP_RECEPCION : Endif

$ROLL_IMP_RECEPCION
  #Rollback
  FLTRANS = 0
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto IMP_RECEPCION : Endif


############################################################################################################
$IMP_CAMBIOUBI
  Local Char FICORI(250), FICFIN(250)
  Local Char WAUX(100)
  Local Integer STAT
  Local Integer WESTADO
  WESTADO=0

  STAT=0

  FICORI=filpath("BQT",[F:ZPREP]ZFICHERO,"")
  FICFIN=filpath("ZFP",[F:ZPREP]ZFICHERO,"")

  WAUX=[F:ZPREP]ZFICHERO

  If [F:ZPREP]ZFICHERO<>"" Then
    #Infbox("LLAMANDO IMPORTACION")
    Call IMPORTSIL("ZCAMUBISGA",filpath("BQT",[F:ZPREP]ZFICHERO,"")) From GIMPOBJ


    #Call MOVE(FICORI,FICFIN,STAT) From ORDSYS

    If filinfo(filpath("BQT",[F:ZPREP]ZFICHERO,"")+".err",0)>0
      Call ECR_TRACE("Error importando cambio de ubicación",1) From GESECRAN
      ERRORIMP=1
    Endif

    #Se modifican todas las líneas de la tabla ZINTEGRADOR a "Si procesadas" porque estan todas en el mismo fichero de importación
    ERRORIMP=0
    If ERRORIMP=1 Then
      WESTADO=5
    Else
      WESTADO=4

      #Gosub ASIGNAR_PEDIDO
    Endif

    Update [ZPREP] Where [ZPREP]ZREF1=WNUMMOV and ([ZPREP]ZESTADO=3 or [ZPREP]ZESTADO=5) and [ZPREP]ZFICHERO=WAUX With ZESTADO=WESTADO
    #Update [ZPREP] Where [ZPREP]ZREF1=WNUMMOV and [ZPREP]ZESTADO=3 and [ZPREP]ZFICHERO=WAUX With ZESTADO=WESTADO
  Endif


  If fstat
    GOK=0 : Call FSTA("ZIMPSGA") From GLOCK : STA=14
  Endif
  If GOK<0 : Goto ROLL_IMP_CAMBIOUBI
  Elsif !GOK : Goto AB_IMP_CAMBIOUBI
  Endif
  #Commit
  FILTRANS=0
  Return

$AB_IMP_CAMBIOUBI
  #Rollback
  FILTRANS=0
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto IMP_CAMBIOUBI : Endif

$ROLL_IMP_CAMBIOUBI
  #Rollback
  FLTRANS = 0
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto IMP_CAMBIOUBI : Endif

################################################################################################################
$IMP_RECEPCION_SGA17
  Local Char FICORI(250), FICFIN(250)
  Local Char WAUX(250)
  Local Integer STAT
  Local Integer WESTADO
  Local Integer ID
  Local Char EXISTEQ(5)
  WESTADO=0

  STAT=0

  FICORI=filpath("BQT",[F:ZPREP]ZFICHREC,"")
  FICFIN=filpath("ZFP",[F:ZPREP]ZFICHREC,"")

  WAUX=[F:ZPREP]ZFICHREC

  If [F:ZPREP]ZFICHREC<>"" Then
    If mid$([F:ZPREP]ZFICHREC,1,6)="AZRECP" Then
      Call IMPORTSIL("ZPTH2",filpath("BQT",[F:ZPREP]ZFICHREC,"")) From GIMPOBJ
    Else
      Call IMPORTSIL("ZPTH",filpath("BQT",[F:ZPREP]ZFICHREC,"")) From GIMPOBJ
    Endif


    #Call MOVE(FICORI,FICFIN,STAT) From ORDSYS

    ERRORIMP=0
    If filinfo(filpath("BQT",[F:ZPREP]ZFICHREC,"")+".err",0)>0
      Call ECR_TRACE("Error importando entrega",1) From GESECRAN
      ERRORIMP=1
    Else
      #Comprobamos si la recepción tiene artículos en Q2 o Q3
      EXISTEQ=""
      REQUEST="SELECT STA_0 FROM STOJOU WHERE VCRNUM_0='"+[F:PTH]PTHNUM+"' AND STA_0 IN('Q2','Q3')"
      For (Char ESTADO(5)) From "5" Sql REQUEST As [YYY]
        EXISTEQ = [F:YYY]ESTADO
      Next
      If EXISTEQ<>"" Then
        #Enviamos la alerta
        Append TEXTORECEPCION,'Revise los artículos de la recepción indicada'+chr$(10)+chr$(10)

        ASUNTO="ZIMPSGA: Recepciones con artículo en estado Q - "+DOSIERACTUAL
        Append ENCABEZADO,'Le informamos que la recepción '+[F:PTH]PTHNUM+' generada en X3 tiene artículos en estados Q2 o Q3'+chr$(10)+chr$(10)
        Append PIE, "Administrador del sistema"
        Append MENSAJE,ENCABEZADO
        Append MENSAJE,TEXTORECEPCION
        Append MENSAJE,PIE

        Gosub ENVIAR_EMAIL
      Endif
    Endif
  Endif

  #Se modifican todas las líneas de la tabla ZINTEGRADOR a "Si procesadas" porque estan todas en el mismo fichero de importación
   #Se modifican todas las líneas de la tabla ZINTEGRADOR a "Si procesadas" porque estan todas en el mismo fichero de importación

  If ERRORIMP=1 Then
    WESTADO=5
  Else
    WESTADO=4

    #Gosub ASIGNAR_PEDIDO
  Endif
  Update [ZPREP] Where [ZPREP]ZFICHREC=WAUX With ZESTADO=WESTADO
  If fstat
    GOK=0 : Call FSTA("ZIMPSGA") From GLOCK : STA=14
  Endif
  If GOK<0 : Goto ROLL_IMP_RECEPCION_SGA17
  Elsif !GOK : Goto AB_IMP_RECEPCION_SGA17
  Endif
  #Commit
  FILTRANS=0
  Return

$AB_IMP_RECEPCION_SGA17
  #Rollback
  FILTRANS=0
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto IMP_RECEPCION_SGA17 : Endif

$ROLL_IMP_RECEPCION_SGA17
  #Rollback
  FLTRANS = 0
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto IMP_RECEPCION_SGA17 : Endif

$ENVIAR_EMAIL
  Local Integer  STA
  Local Integer  TRACE
  Local Char     A_USER(250)(1..)
  Local Char     CC_USER(250)(1..)
  Local Char     LEMAIL_DE(250)
  Local Char     ISSUERMAIL(250)
  Local Char     ATTACHMENTS(250)(1..)

  ISSUERMAIL="info@perfumeriaselectiva.net"
  A_USER(1)="jennifer.perfum@hotmail.com"
  A_USER(2)="comercial@perfumeriaselectiva.net"
  A_USER(3)="info@perfumeriaselectiva.net"
  A_USER(4)="logistica@infobaix.com"

  #CC_USER(1)="floren.presumido@grupoazeta.com"
  #CC_USER(2)="josep.rodriguez@grupoazeta.com"
  #CC_USER(3)="angel.delatorre@grupoazeta.com"

  #A_USER(1)="floren.presumido@grupoazeta.com"

  TRACE=2

  #--- Envio del email
  STA = func ASYRMAIL.ASEND_MAIL(GACTX,ISSUERMAIL,A_USER,CC_USER,ASUNTO,MENSAJE,FICHEROTRAZA,TRACE)

Return

############################################################################################################
$IMP_ENTREGA_SGA18
  Local Char FICORI(250), FICFIN(250)
  Local Char WAUX(100)
  Local Integer STAT
  Local Integer WESTADO
  Local Integer ERRORIMP_SGA18

  WESTADO=0
  ERRORIMP_SGA18=0

  STAT=0

  FICORI=filpath("BQT",[F:ZPSD]ZFICENTXML,"")
  FICFIN=filpath("ZFP",[F:ZPSD]ZFICENTXML,"")

  If [F:ZPSD]ZFICENTXML<>"" Then
    #Infbox("LLAMANDO IMPORTACION")
    Call IMPORTSIL("ZSDH3",filpath("BQT",[F:ZPSD]ZFICENTXML,"")) From GIMPOBJ

    WAUX=[F:ZPSD]ZFICENTXML
    #Call MOVE(FICORI,FICFIN,STAT) From ORDSYS

    If filinfo(filpath("BQT",[F:ZPSD]ZFICENTXML,"")+".err",0)>0
      Call ECR_TRACE("Error importando entrega",1) From GESECRAN
      ERRORIMP_SGA18=1
    Endif
  Endif

  #Se modifican todas las líneas de la tabla ZINTEGRADOR a "Si procesadas" porque estan todas en el mismo fichero de importación
   #Se modifican todas las líneas de la tabla ZINTEGRADOR a "Si procesadas" porque estan todas en el mismo fichero de importación
  If ERRORIMP_SGA18=1 Then
    WESTADO=5
  Else
    WESTADO=4

    Update [ZPREPAC] Where ([ZPREPAC]ZESTADO=1) and [ZPREPAC]ZNUMPREP=[ZPSD]ZNUMPREP With ZESTADO=3,SDHNUM=[SDH]SDHNUM
    Update [SPH] Where ([SPH]ZNUMPREP=[ZPSD]ZNUMPREP) With VCRNUM=[SDH]SDHNUM
    Update [SPD] Where ([SPD]ZNUMPREP=[ZPSD]ZNUMPREP) With VCRNUM=[SDH]SDHNUM




  Endif

  Gosub IMPRIMIR_ALBARAN
  Gosub IMPRIMIR_PACKINGLIST

  Update [ZPSD2] Where ZNUMENT=[ZPSD]ZNUMENT With ZNUMENT=[SDH]SDHNUM
  Update [ZPSD2] Where ([ZPSD2]ZESTADO=1) and [ZPSD2]ZFICENTXML=WAUX With ZESTADO=WESTADO,ZQTYENT=ZQTYENT+ZQTYCAP
  Update [ZPSD2] Where ([ZPSD2]ZESTADO=4) and [ZPSD2]ZFICENTXML=WAUX and [ZPSD2]ZQTYASG<>[ZPSD2]ZQTYENT With ZQTYCAP=0

  If fstat
    GOK=0 : Call FSTA("ZIMPSGA") From GLOCK : STA=14
  Endif
  If GOK<0 : Goto ROLL_IMP_ENTREGA_SGA18
  Elsif !GOK : Goto AB_IMP_ENTREGA_SGA18
  Endif
  #Commit
  FILTRANS=0
  Return

$AB_IMP_ENTREGA_SGA18
  #Rollback
  FILTRANS=0
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto IMP_ENTREGA_SGA18 : Endif

$ROLL_IMP_ENTREGA_SGA18
  #Rollback
  FLTRANS = 0
  Call ROLL From GLOCK
  If GROLL : Return : Else : Goto IMP_ENTREGA_SGA18 : Endif

$ACTU_SCCCOD
  Local Char CODCAJA(100)
  Local Integer LRET

  #Generamos el SCCCOD de la caja
  REQUEST="SELECT PACNUM_0,STOFCY_0 FROM SPACK WHERE SCCCOD_0=''"
  For (Char PAC(50),Char PLANTA(10)) From "5" Sql REQUEST As [YYY]
    Call NUMERO_SSCC([F:YYY]PLANTA,"757",CODCAJA,LRET) From FUNPKD

    Update [SPH] Where ([SPH]PACNUM=[F:YYY]PAC) With SCCCOD=CODCAJA
  Next

  #Generamos el SCCCOD del pallet
  REQUEST="SELECT ZNUMPALET_0,STOFCY_0,VCRNUM_0 FROM SPACK WHERE ZPALEAN_0=''"
  For (Char PALET(50),Char PLANTA(10),Char ENTREGA(50)) From "5" Sql REQUEST As [YYY]
    Call NUMERO_SSCC([F:YYY]PLANTA,"1002",CODCAJA,LRET) From FUNPKD

    Update [SPH] Where ([SPH]VCRNUM=[F:YYY]ENTREGA) and ([SPH]ZNUMPALET=[F:YYY]PALET) With ZPALEAN=CODCAJA
  Next

  Return

$IMPRIMIR_ALBARAN

Local Integer NBPAR_MAX:NBPAR_MAX=20
