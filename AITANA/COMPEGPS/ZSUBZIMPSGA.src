TBPAR(16)="facfin":TBVAL(16)="1"
TBPAR(17)="codimp":TBVAL(17)="1"
TBPAR(18)="impdet":TBVAL(18)="1"
TBPAR(19)="impselections":TBVAL(19)="1"


Call ETAT('BONLIV','ALM-BRO-1',"",0,"",TBPAR,TBVAL) From AIMP3

Return

$IMPRIMIR_PACKINGLIST

