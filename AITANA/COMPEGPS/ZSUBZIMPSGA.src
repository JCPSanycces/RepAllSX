TBPAR(1)="sitedeb":TBVAL(1)=[F:SDH]STOFCY
TBPAR(2)="sitefin":TBVAL(2)=[F:SDH]STOFCY
TBPAR(3)="Livraisondeb":TBVAL(3)=[F:SDH]SDHNUM
TBPAR(4)="Livraisonfin":TBVAL(4)=[F:SDH]SDHNUM
TBPAR(5)="datedeb":TBVAL(5)=[F:SDH]SHIDAT
TBPAR(6)="datefin":TBVAL(6)=[F:SDH]SHIDAT
