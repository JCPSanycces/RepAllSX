$ACTION
#Infbox(ACTION)
Case ACTION

 When Default
Endcase
Return

Subprog CL_BTNCF(VALEUR)
Variable Char    VALEUR()
Local Char WRUTA(100)
Local Char WNOMF(100)
Local Char WJOB(10)
WRUTA="BQR"


WJOB = num$(time)

WNOMF="SELFIC_" + GUSER + "_" + format$("YYYYMMDD",date$) +"_"+WJOB


Local Char RETOUR(250)
Askui RETOUR="" With "UIAsk="+chr$(1) + "AskPutFile",
& "UIRemotePath="+ chr$(1) + WRUTA,
& "UIRemoteFileName="+ chr$(1) + WNOMF + ".TXT",
& "UILocalFileExts="+ chr$(1) + "TXT",
& "UILocalPath="+chr$(1) + "#myDocuments"

Gosub CONT_FICHEROS
#& "UILocalFileName="+ chr$(1) + "",
#
End



### Verifica la existencia de los ficheros
$CONT_FICHEROS

[M:ZSF]NOMIMP=""

If filinfo(filpath(WRUTA,WNOMF,"TXT"),1)>=0 Then
     [M:ZSF]NOMIMP=filpath(WRUTA,WNOMF,"TXT")
Endif


Affzo [M:ZSF]NOMIMP
End
######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZSELFIC) 14/12/2014 12:30:18 (ADMIN)
######################################################################################
Subprog CL_BTNFC(VALEUR)
Variable Char    VALEUR()
End


