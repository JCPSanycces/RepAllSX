#<AdxTL>@(#)0.0.0.0 $Revision$ 
###############################################################################
# Representation ZEDISDHEM                                                     #
###############################################################################

$METHODS
  Case [L]CURPTH
    When ""
      Case [L]ACTION
        When "MET_AFTER_LOAD_REPRESENTATION" : Gosub MET_AFTER_LOAD_REPRESENTATION
      Endcase
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
  Endcase
Return

#********************************************************************
# Method MET_AFTER_LOAD_REPRESENTATION
#********************************************************************
#
#*
#* @param WCATACT
#* @param WCATCOD
#* @param WPARCOD
#* @param WDUPLICATE
#* @param WTEST
#* @param WSEPDEC #114721
#* @param WERR
#* @return [V]CST_AOK/[V]CST_AERROR
#*!
$MET_AFTER_LOAD_REPRESENTATION
  Local Integer I, J
  Local Integer WOK     : WOK     = [V]CST_AOK
  Local Integer WSTATUS : WSTATUS = [V]CST_AERROR

  Case WCATACT
    When 1 :
      Case WPARCOD
        When "EDICOM" : Gosub EDICOM_ISSUE
        When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
      Endcase
    When 2 :
      Case WPARCOD
        When "EDICOM" : Gosub EDICOM_RECEIPT
        When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
      Endcase
  Endcase

  ARET_VALUE = WSTATUS
Return



################################################################################
$EDICOM_ISSUE
  Local Char WCODE(20), WREP(20), WPROP(25) # 114721
  WREP=right$(this.AINF.NAMCLA,3)

  #Formating EDISDHNUM property
  Local Char EDINUM(20)
  EDINUM=space$(20-len(this.SDH.SDHNUM))+this.SDH.SDHNUM
  this.EDISDHNUM =right$(EDINUM,11)

  #Filling EDISDHTYP property
  this.EDISDHTYP="351"

  #Filling EDISDHFUN property
  this.EDISDHFUN="9"

  #Formating EDISHIDAT property
  this.EDISHIDAT=format$("D:YYYYMMDD",this.SDH.SHIDAT)

  #Formating EDIDLVDAT property
  this.EDIDLVDAT=format$("D:YYYYMMDD",this.SDH.DLVDAT)

  #Filling Especial condition property
  If this.SDH.LND=2: this.EDILND="82E": Endif

  #Searching EDIORDNUM property
  Local Char WSOHNUM(20)
  Local Date WSOHDAT

  If this.SDH.SOHNUM<>"": WSOHNUM=this.SDH.SOHNUM: Endif

  If WSOHNUM=""
    For I=1 To maxtab(this.SDH.SDD)
      If this.SDH.SDD(I).SOHNUM<>"": WSOHNUM=this.SDH.SDD(I).SOHNUM: Break: Endif
    Next
  Endif

  If WSOHNUM<>""
    this.EDIORDNUM= func TRTFUNEDI.SDH_ORDNUM(WSOHNUM,1)
    this.EDIORDDAT= func TRTFUNEDI.SDH_ORDNUM(WSOHNUM,2)
  Endif
  # If we don´t have order number, we feed this mandatory field
  If this.EDIORDNUM="": this.EDIORDNUM="ORD1": Endif

  #Searching EDIPRHNUM property
  Local Char WPRHNUM(20)

  For I=1 To maxtab(this.SDH.SDD)
    If this.SDH.SDD(I).PRHNUM<>"": WPRHNUM=this.SDH.SDD(I).PRHNUM: Break: Endif
  Next
  this.EDIPRHNUM=WPRHNUM
  this.EDIPRHDAT=func TRTFUNEDI.SDH_PRHDAT(WPRHNUM)

  #Searching EDICPY code
  Local File EDICPYPAR [ECP]

  Read [ECP]ECP0=this.SDH.CPY;WPARCOD
  If fstat=[V]CST_AOK
    this.EDICPY=[F:ECP]EXCEDICOD
  Endif

  LogicClose File [ECP]

  # Searching EDICOM code from finantial site (EDIFCYPAY)
  Local Char WFFCY(5)
  Local File FACILITY [FCY]

  Read [FCY]FCY0=this.SDH.SALFCY
  If fstat=[V]CST_AOK
    WFFCY=[F:FCY]FINRSPFCY
  Endif
  If WFFCY<>""
    WCODE=func TRTFUNEDI.INV_EDICODE_FCY(WFFCY,WPARCOD)
    this.EDIFCYPAY=left$(WCODE,17)
  Endif

  LogicClose File [FCY]

  # Searching EDIBPCCOD property
  Local File EDIBPRPAR [EBP]
  Read [EBP]EBP0=1;this.SDH.BPCORD;this.SDH.BPAADD;WPARCOD
  If fstat=[V]CST_AOK
    this.EDIBPCCOD=[F:EBP]EXCEDICOD
  Endif
  Filter [EBP] Where BPANUM=this.SDH.BPTNUM and PARCOD=WPARCOD
  Read First
  If fstat=[V]CST_AOK
    this.EDIBPTCOD=[F:EBP]EXCEDICOD
  Endif

  LogicClose File [EBP]

  # FJCP - ZEDI - Busqueda del codigo EDI COMPRADOR (Cliente, Direccion Pedido)
  this.ZEDIBPCORD=func SDH_ZEDIBPCORD(WSOHNUM,WPARCOD)

  # Searching EDICOM code from shipment site (EDISTOFCY)
  WCODE=func TRTFUNEDI.INV_EDICODE_FCY(this.SDH.STOFCY,WPARCOD)
  this.EDISTOFCY=left$(WCODE,17)

  #Searching Open order sequence
  Local Shortint WNB
  WNB=func TRTFUNEDI.SDH_OPENUM(this.EDIORDNUM,this.SDH.DLVDAT)
  this.EDIOPENUM=num$(WNB)

 #Filling CPYNAME & CPYCRN properties
  Local File COMPANY [CPY]

  Read [CPY]CPY0=this.SDH.CPY
  If fstat=[V]CST_AOK
    this.CPYNAME=[F:CPY]CPYNAM
    this.CPYCRN=[F:CPY]CRN

    # FJCP Nif Intracomunitario.
    this.ZCPYEECNUM=[F:CPY]EECNUM
  Endif
  LogicClose File [CPY]

  #Converting LANDCOST property
  Local File BPCUSTOMER [BPC]
  Read [BPC]BPC0=this.SDH.BPCINV
  If fstat=[V]CST_AOK and [F:BPC]FREINV=2
    this.LANDCOST="PP"
  Else
    this.LANDCOST="CC"
  Endif

  # Transcoding EDIMDL property (in STD table 231)
  Local File ASHWPAR [ASWP]
  Filter [ASWP] Where CODREP=WREP and CODLNK="EDIMDL"
  Read First
  If fstat=[V]CST_AOK
    Local Char WNODE(20), WTYP(5)
    Local Integer WTAB
    Local File TABMODELIV [TMD]
    If this.SDH.EECTRN<>0
      Filter [TMD] Where EECTRN=this.SDH.EECTRN and EECLOC=this.SDH.EECLOC and EECICT=this.SDH.EECICT
      Read First
      If fstat=[V]CST_AOK: WTYP= [F:TMD]MDL :Endif
      Filter [TMD]
    Endif
    If WTYP="":  WTYP=this.SDH.MDL: Endif
    WTAB=val([F:ASWP]VALEUR)
    WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
    this.EDIMDL= left$(WNODE,3)

    LogicClose File [TMD]
  Endif

  LogicClose File [ASWP]

  #Calculating EDITOTQTY property
  Local Decimal WEDITOTQTY

  If toupper(this.SDH.WEU)<>"KG"
    Local File TABCOEFF [TCO]
    Read [TCO]TCO0="KG";this.SDH.WEU
   # If fstat=[V]CST_AOK: this.EDITOTQTY=ar2(this.SDH.NETWEI*[F:TCO]COEUOM): Endif
     If fstat=[V]CST_AOK: WEDITOTQTY=ar2(this.SDH.NETWEI*[F:TCO]COEUOM): Endif
    LogicClose File [TCO]
  Else
    # this.EDITOTQTY=this.SDH.NETWEI
    WEDITOTQTY=this.SDH.NETWEI
  Endif
  this.EDITOTQTY = format$("N0:11.3#",WEDITOTQTY)
  # FJCP Total Cantidad
   this.EDITOTQTY = format$("N0:11.3#",this.SDH.DSPTOTQTY)
  this.ZCRLF=chr$(13)+chr$(10)


  #Filling IDENTIF property
  this.IDENTIF="X6"   ## Default value

  #Filling EDIBPCNAME property
  If maxtab(this.SDH.C_BPDNAM)>0
    If this.SDH.C_BPDNAM(1).BPDNAM<>""
      this.EDIBPCNAME=this.SDH.C_BPDNAM(1).BPDNAM
    Endif
  Endif
  If this.EDIBPCNAME=""
    Local File BPDLVCUST [BPD]
    Read [BPD]BPD0=this.SDH.BPCORD;this.SDH.BPAADD
    If fstat=[V]CST_AOK
      this.EDIBPCNAME=[F:BPD]BPDNAM(0)
    Endif
    LogicClose File [BPD]
  Endif

  #Filling EDIBPCCRN and EDIORDNAME properties
  Local File BPARTNER [BPR]
  Read [BPR]BPR0= this.SDH.BPCORD
  If fstat=[V]CST_AOK
    this.EDIBPCCRN=[F:BPR]CRN
    this.EDIORDNAME=[F:BPR]BPRNAM(0)
  Endif
  LogicClose File [BPR]

  #Searching BPTNAME property
  Local File BPCARRIER [BPT]

  Read [BPT]BPT0=this.SDH.BPTNUM
  If fstat=[V]CST_AOK
    this.BPTNAME=[F:BPT]BPTNAM
  Endif

  LogicClose File [BPT]

  #Filling Address properties
  Local File BPADDRESS [BPA]
  #company
  Filter [BPA] Where BPATYP=2 and BPANUM=this.SDH.CPY and BPAADDFLG=2
  Read First
  If fstat=[V]CST_AOK
      this.CPYSAT     =[F:BPA]SAT
      this.CPYCITY    =[F:BPA]CTY
      this.CPYPOSCOD  =[F:BPA]POSCOD
      this.CPYADDLIG  =[F:BPA]BPAADDLIG(0)
      ## FJCP Pais Sociedad
      this.ZCPYCRY   =[F:BPA]CRY
  Endif
  Filter [BPA]

  # delivery
  If maxtab(this.SDH.C_BPDADDLIG)>0
    this.EDIBPDSAT    =this.SDH.BPDSAT
    this.EDIBPDCITY   =this.SDH.BPDCTY
    this.EDIBPDPOSCOD =this.SDH.BPDPOSCOD
    this.EDIBPDADDLIG =this.SDH.C_BPDADDLIG(1).BPDADDLIG
          ## FJCP Pais Entrega
    this.ZEDIBPDCRY   =this.SDH.BPDCRY
  Else
    Read [BPA]BPA0=1;this.SDH.BPCORD;this.SDH.BPAADD
    If fstat=[V]CST_AOK
      this.EDIBPDSAT    =[F:BPA]SAT
      this.EDIBPDCITY   =[F:BPA]CTY
      this.EDIBPDPOSCOD =[F:BPA]POSCOD
      this.EDIBPDADDLIG =[F:BPA]BPAADDLIG(0)
      ## FJCP Pais Entrega
      this.ZEDIBPDCRY   =[F:BPA]CRY
    Endif
  Endif

  #invoice
  If maxtab(this.SDH.C_BPIADDLIG)>0
    this.EDIBPISAT    =this.SDH.BPISAT
    this.EDIBPICITY   =this.SDH.BPICTY          #SAM 111252
    this.EDIBPIPOSCOD =this.SDH.BPIPOSCOD
    this.EDIBPIADDLIG =this.SDH.C_BPIADDLIG(1).BPIADDLIG
          ## FJCP Pais Factura
    this.ZEDIBPICRY   =this.SDH.BPICRY
  Else
    Read [BPA]BPA0=1;this.SDH.BPCINV;this.SDH.BPAINV
    If fstat=[V]CST_AOK
      this.EDIBPISAT    =[F:BPA]SAT
      this.EDIBPICTY    =[F:BPA]CTY
      this.EDIBPIPOSCOD =[F:BPA]POSCOD
      this.EDIBPIADDLIG =[F:BPA]BPAADDLIG(0)
      ## FJCP Pais Factura
      this.ZEDIBPICRY   =[F:BPA]CRY
    Endif
  Endif
  LogicClose File [BPA]

# ----> FJCP - direccion Pto Emision
  Local File BPADDRESS [BPA]
  Local File FACILITY [FCY]
  Read [FCY]FCY0=this.SDH.STOFCY
  If fstat=[V]CST_AOK
     Read [BPA]BPA0=3;[FCY]FCY;[FCY]ZADDPTOENV
     If fstat=[V]CST_AOK
      this.ZNOMPTOEMI   =[F:BPA]BPADES
      this.ZPOBPTOEMI   =[F:BPA]CTY
      this.ZPRVPTOEMI   =[F:BPA]SAT
      this.ZCPPTOEMI    =[F:BPA]POSCOD
      this.ZDIRPTOEMI   =[F:BPA]BPAADDLIG(0)+[F:BPA]BPAADDLIG(1)
     Endif
  Endif
  LogicClose File [FCY]
  LogicClose File [BPA]
# ----> Fin FJCP

  If this.SDH.SHIHOU=""
    this.DATIME=format$("D:DDMMYY",this.SDH.SHIDAT)+"T0000"
  Else
    this.DATIME=format$("D:DDMMYY",this.SDH.SHIDAT)+"T"+this.SDH.SHIHOU
  Endif

# issue 114721 Decimal separator in generated file
  #Formating decimal fields from the properties:
  WPROP=format$("N0:11.3#",this.SDH.DLVINVNOT)
  this.EDIDLVINVNOT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
  WPROP=format$("N0:11.3#",this.SDH.DLVINVATI)
  this.EDIDLVINVATI=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
#      this.EDITOTQTY   =format$("N0:11.3#",this.SDH.NETWEI)
  #/ 114721

###
### ASN
  Local File SDELIVERY [SDHX]
  Read [F:SDHX]SDH0=this.SDH.SDHNUM
  If [SDHX]ZASN=""
      this.ZASN=this.SDH.SDHNUM
      this.ZFECASN=format$("D:YYYYMMDD",this.SDH.SHIDAT)
      this.ZCONASN=1
  Else
      this.ZASN=[F:SDHX]ZASN
      this.ZFECASN=format$("D:YYYYMMDD",[F:SDHX]ZFVALASN)
      this.ZCONASN=[F:SDHX]ZCONFASN
  Endif
  LogicClose File [SDHX]
####


#Dbgaff

#####################################
#####          EMBALB         #######
#####################################

  this.IDPACK="1"
  this.LEVELPACK="1"


# FJCP Prueba Coleccion Embalajes
#####################################
#####          EMBALAJES     #######
#####################################



# FJCP Esquema para basarnos SPACKD
# Bucle SPACK
  # Bucle SPACKD
   # Bucle Lineas  SDD
      # Si SDD.LINEA = SPACKD Linea.
        ## Tratamiento Lineas
        ## Unidades las indicadas en SPACK
   # Fin Bucle SDD
  # Fin Bucle SPACKD
# Fin Bucle SPACK
# FJCP definicion Ficheros

Local File SPACKD [SPD]
Local File SPACK [SPH]

Local Char WLZNUMPALET(12)

Local Integer WLIN, WLINPADRE, WNUMPAQS
Local Integer WHAYPACK
Filter [SPH] Where VCRTYP=4 and VCRNUM=this.SDH.SDHNUM Order By ZNUMPALET; ZNUMCAJA

WNUMPAQS = 0
WLZNUMPALET = "-1"

For [SPH]
  # Si cambia el numero de palet (ZNUMPALET)
  If WLZNUMPALET <> [F:SPH]ZNUMPALET
     WLZNUMPALET=[F:SPH]ZNUMPALET
     # Añadir Plet  a la coleccion (R_PKG)
     WLIN = fmet this.ADDLINE('R_PKG',[V]CST_ALASTPOS)
     WLINPADRE = WLIN
     this.R_PKG(WLINPADRE).ZIDCAB = this.EDISDHNUM
     this.R_PKG(WLINPADRE).ZBLNKPKG = this.BLANK
     # this.R_PKG(WLIN).ZCPS = format$("N0:12#",WLIN)
     this.R_PKG(WLINPADRE).ZCPS = num$(WLIN)
     this.R_PKG(WLINPADRE).ZCPSPADRE = ""
    # this.R_PKG(WLINPADRE).ZEDITIPEMB = [F:SPH]ZPALTIP
     this.R_PKG(WLINPADRE).ZEDITIPEMB = "201"   # Tipo de PAlet segun fichero EDICOM para Amazon
     this.R_PKG(WLINPADRE).ZEDISSCC1 = ""    #  [F:SPH]ZPALEAN - No se informa  (Monica Edicom 6-2-2017)
  #   this.R_PKG(WLINPADRE).ZIDPACK = this.R_PKG(WLIN).ZCPS
      this.R_PKG(WLINPADRE).ZIDPACK = [F:SPH]ZPALCOD
      this.R_PKG(WLINPADRE).ZEDINUMPAQ = format$("N0:12#",1)  # Cantidad  de pallets  FJCP 28/02/17
  Endif
  WNUMPAQS += 1
  # Añadir Paquete a la coleccion (R_PKG)
  WLIN = fmet this.ADDLINE('R_PKG',[V]CST_ALASTPOS)
  this.R_PKG(WLIN).ZIDCAB = this.EDISDHNUM
  this.R_PKG(WLIN).ZBLNKPKG = this.BLANK
  #this.R_PKG(WLIN).ZCPS = format$("N0:12#",WLIN)
  #this.R_PKG(WLIN).ZCPSPADRE = format$("N0:12#",WLINPADRE)
  this.R_PKG(WLIN).ZCPS = num$(WLIN)
  this.R_PKG(WLIN).ZCPSPADRE = num$(WLINPADRE)
  this.R_PKG(WLIN).ZEDITIPEMB = "PK" # [SPH]PCK - Se pone fijo a "PK"  (Monica Edicom 6-2-2017)
  this.R_PKG(WLIN).ZEDISSCC1 = [SPH]SCCCOD
  #this.R_PKG(WLIN).ZIDPACK = this.R_PKG(WLIN).ZCPS
  this.R_PKG(WLIN).ZIDPACK = [SPH]PACNUM
  this.R_PKG(WLIN).ZEDINUMPAQ = format$("N0:12#",1)

  Filter [SPD] Where STOFCY=this.SDH.STOFCY and VCRTYP=4 and VCRNUM=this.SDH.SDHNUM and PACNUM=[SPH]PACNUM and PACSEQ=[SPH]PACSEQ
  For [SPD]

        #Filling R_SDD collection

        Gosub $EDICOM_ISSUE_LINES

  Next   # SPD
  Filter [SPD]

Next # SPH
Filter [SPH]
If WNUMPAQS<>0
  # this.R_PKG(WLINPADRE).ZEDINUMPAQ = format$("N0:12#",WNUMPAQS)
   this.R_PKG(WLINPADRE).ZTCAJAS = format$("N0:12#",WNUMPAQS)
   this.R_PKG(WLINPADRE).ZTIPO2 = "PK"
Endif

LogicClose File [SPH]
LogicClose File [SPD]

If WNUMPAQS=0 Then
# Paquete padre
WLIN = fmet this.ADDLINE('R_PKG',[V]CST_ALASTPOS)
WLINPADRE = WLIN
this.R_PKG(WLINPADRE).ZIDCAB = this.EDISDHNUM
this.R_PKG(WLINPADRE).ZBLNKPKG = this.BLANK
# this.R_PKG(WLIN).ZCPS = format$("N0:12#",WLIN)
this.R_PKG(WLINPADRE).ZCPS = num$(WLIN)
this.R_PKG(WLINPADRE).ZCPSPADRE = ""
this.R_PKG(WLINPADRE).ZEDITIPEMB = "201"
this.R_PKG(WLINPADRE).ZEDISSCC1 = ""
this.R_PKG(WLINPADRE).ZIDPACK = this.R_PKG(WLIN).ZCPS
## FJCP si no hay lista de paquetes ejecutamos el codigo original

#####################################
#####          LINES          #######
#####################################
  #Filling R_SDD collection
  Local Integer WSEQ
  Local File STOJOU [STJ]

  For I=1 To maxtab(this.SDH.SDD)
    Filter [STJ] Where STOFCY=this.SDH.SDD(I).STOFCY and VCRTYP=4 and VCRNUM=this.SDH.SDHNUM and VCRLIN=this.SDH.SDD(I).SDDLIN
    For [STJ]
      WSEQ= fmet this.ADDLINE('R_SDD',[V]CST_ALASTPOS)
      # ITMTYP property (constant in the lines)
      this.R_SDD(WSEQ).ITMTYP="CU"
      this.R_SDD(WSEQ).BLANKLIN=this.BLANK
      this.R_SDD(WSEQ).SDHNUMLIN=this.EDISDHNUM    # SDHNUMLIN property
      this.R_SDD(WSEQ).EDISDHLIN=WSEQ             # EDISDHLIN property
      this.R_SDD(WSEQ).DLVDATLIN=this.EDIDLVDAT
      this.R_SDD(WSEQ).BPCCODLIN=this.EDIBPCCOD
      this.R_SDD(WSEQ).FCYPAYLIN=this.EDIFCYPAY

      Local File ITMMASTER [ITM]
      Read [ITM]ITM0=this.SDH.SDD(I).ITMREF
      If fstat= [V]CST_AOK

        this.R_SDD(WSEQ).EANCOD=[F:ITM]EANCOD                           ####R_SDD.EANCOD
        this.R_SDD(WSEQ).REFITMBPC=func TRTFUNEDI.INV_REFCLI(this.SDH.BPCORD, this.SDH.SDD(I).ITMREF) ####R_SDD.REFITMBPC

        ### FJCP Si codigo de Barras vacio se informa de la referencia del cliente
        If [F:ITM]EANCOD="" or len([F:ITM]EANCOD)<>13 Then
           this.R_SDD(WSEQ).EANCOD=this.R_SDD(WSEQ).REFITMBPC
        Endif
      Endif
      LogicClose File [ITM]

   # issue 114721 Decimal separator in generated file
      # Filling QTYFREE property
      WPROP=format$("N0:11.3#",func TRTFUNEDI.SDH_QTYFREE(this.SDH.SDHNUM,this.SDH.SDD(I).SDDLIN))
      this.R_SDD(WSEQ).QTYFREE=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

      #Filling SOHDAT property
      this.R_SDD(WSEQ).SOHDAT=func TRTFUNEDI.SDH_SOHDAT(this.SDH.SDD(I).SOHNUM)

      #Filling SOHQTY property
      WPROP=format$("N0:11.3#",func TRTFUNEDI.SDH_SOHQTY(this.SDH.SDD(I).SOHNUM,this.SDH.SDD(I).SOPLIN,this.SDH.SDD(I).SOQSEQ))
      this.R_SDD(WSEQ).SOHQTY=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
#/ 114721
      #Filling SOHSAU property
      this.R_SDD(WSEQ).SOHSAU=func TRTFUNEDI.SDH_SOHSAU(this.SDH.SDD(I).SOHNUM,this.SDH.SDD(I).SOPLIN,this.SDH.SDD(I).SOQSEQ)

      #Filling stock details
      If format$("D:YYYYMMDD",[F:STJ]SHLDAT)<> "29991231"
        this.R_SDD(WSEQ).STOSHLDAT = format$("D:YYYYMMDD",[F:STJ]SHLDAT)
      Else
        this.R_SDD(WSEQ).STOSHLDAT ="00000000"
      Endif
      this.R_SDD(WSEQ).STOQTY = abs([F:STJ]QTYSTU)
      this.R_SDD(WSEQ).STOSAU = [F:STJ]STU
      this.R_SDD(WSEQ).STOLOT = [F:STJ]LOT
      this.R_SDD(WSEQ).STOSER = [F:STJ]SERNUM

      #Calculating LINWEI property
      Local Decimal WLINWEI
      If toupper(this.SDH.SDD(I).WEU)<>"KG"
        Local File TABCOEFF [TCO]
        Read [TCO]TCO0="KG";this.SDH.SDD(I).WEU
        If fstat=[V]CST_AOK:
          WLINWEI=ar2((this.SDH.SDD(I).UNTWEI*[F:TCO]COEUOM)*this.R_SDD(WSEQ).STOQTY)
#          WLINWEI=ar2((this.SDH.SDD(I).UNTWEI*[F:TCO]COEUOM)*this.SDH.SDD(I).QTY)
        Endif
        LogicClose File [TCO]
      Else
        WLINWEI=ar2(this.SDH.SDD(I).UNTWEI*this.R_SDD(WSEQ).STOQTY)
#        WLINWEI=ar2(this.SDH.SDD(I).UNTWEI*this.SDH.SDD(I).QTY)
      Endif

      #Filling GROWEILIN property
      Local Decimal WPACKWEI
      Local Shortint WNBPACK
      Local File TABPACKAGE [TPA]

      If this.SDH.SDD(I).PCKCAP<>0
         WNBPACK=this.R_SDD(WSEQ).STOQTY/this.SDH.SDD(I).PCKCAP
#        WNBPACK=this.SDH.SDD(I).QTY/this.SDH.SDD(I).PCKCAP
      Else
        WNBPACK=1
      Endif

      If this.SDH.SDD(I).PCK<>"" and WNBPACK<>0
        Read [TPA]TPA0=this.SDH.SDD(I).PCK
        If toupper([F:TPA]WEU)="KG"
          WPACKWEI=[F:TPA]PCKWEI*WNBPACK
        Else
          Local File TABCOEFF [TCO]
          Read [TCO]TCO0="KG";[F:TPA]WEU
          If fstat=[V]CST_AOK
            WPACKWEI = ar2(([F:TPA]PCKWEI*[F:TCO]COEUOM)*WNBPACK)
          Endif
          LogicClose File [TCO]
        Endif
      Endif
      this.R_SDD(WSEQ).GROLINWEI=WLINWEI+WPACKWEI

      LogicClose File [TPA]

# issue 114721 Decimal separator in generated file
      #Formating decimal fields from the properties:
      WPROP= format$("N0:11.3#",this.SDH.SDD(I).QTY)
      this.R_SDD(WSEQ).SDDQTY =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      WPROP=format$("N0:11.3#",WLINWEI)
      this.R_SDD(WSEQ).LINWEI =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
#/ 114721

      #############################
      ##  NOTES lines            ##
      #############################
      #Filling text of line
      Local Char WTEXLIN (70)(5)
      Local Integer WOK, L

      WOK=func TRTFUNEDI.SDH_NUMOBSL(this.SDH.SDHNUM,this.SDH.SDD(I).SDDLIN,WTEXLIN())
      If WOK=1
        For L=0 To 4
          If WTEXLIN(L)<>""
            Assign ("this.R_SDD("+num$(WSEQ)+").NOTE"+num$(L+1)) With WTEXLIN(L)
          Endif
        Next
      Endif
      ## FJCP Pedido Cliente
      this.R_SDD(WSEQ).ZORDNUMLIN=this.EDIORDNUM

    Next  STJ
  Next
  LogicClose File [STJ]
Endif
  WSTATUS = [V]CST_AOK
Return

$EDICOM_ISSUE_LINES

 Local Integer WSEQ
 Local File STOJOU [STJ]
For I=1 To maxtab(this.SDH.SDD)
   ###
   ### FJCP solo filtramos las lineas que pertenezcan al embalaje
   ###
   If [SPD]VCRLIN=this.SDH.SDD(I).SDDLIN


    Filter [STJ] Where STOFCY=this.SDH.SDD(I).STOFCY and VCRTYP=4 and VCRNUM=this.SDH.SDHNUM and VCRLIN=this.SDH.SDD(I).SDDLIN
    For [STJ]
      WSEQ= fmet this.ADDLINE('R_SDD',[V]CST_ALASTPOS)
      # ITMTYP property (constant in the lines)
      this.R_SDD(WSEQ).ITMTYP="CU"
      this.R_SDD(WSEQ).BLANKLIN=this.BLANK
      this.R_SDD(WSEQ).SDHNUMLIN=this.EDISDHNUM    # SDHNUMLIN property
      this.R_SDD(WSEQ).EDISDHLIN=WSEQ             # EDISDHLIN property
      this.R_SDD(WSEQ).DLVDATLIN=this.EDIDLVDAT
      this.R_SDD(WSEQ).BPCCODLIN=this.EDIBPCCOD
      this.R_SDD(WSEQ).FCYPAYLIN=this.EDIFCYPAY

      Local File ITMMASTER [ITM]
      Read [ITM]ITM0=this.SDH.SDD(I).ITMREF
      If fstat= [V]CST_AOK

        this.R_SDD(WSEQ).EANCOD=[F:ITM]EANCOD                           ####R_SDD.EANCOD
        this.R_SDD(WSEQ).REFITMBPC=func TRTFUNEDI.INV_REFCLI(this.SDH.BPCORD, this.SDH.SDD(I).ITMREF) ####R_SDD.REFITMBPC

        ### FJCP Si codigo de Barras vacio se informa de la referencia del cliente
        If [F:ITM]EANCOD="" or len([F:ITM]EANCOD)<>13 Then
           this.R_SDD(WSEQ).EANCOD=this.R_SDD(WSEQ).REFITMBPC
        Endif

      Endif
      LogicClose File [ITM]

   # issue 114721 Decimal separator in generated file
      # Filling QTYFREE property
      WPROP=format$("N0:11.3#",func TRTFUNEDI.SDH_QTYFREE(this.SDH.SDHNUM,this.SDH.SDD(I).SDDLIN))
      this.R_SDD(WSEQ).QTYFREE=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

      #Filling SOHDAT property
      this.R_SDD(WSEQ).SOHDAT=func TRTFUNEDI.SDH_SOHDAT(this.SDH.SDD(I).SOHNUM)

      #Filling SOHQTY property
      WPROP=format$("N0:11.3#",func TRTFUNEDI.SDH_SOHQTY(this.SDH.SDD(I).SOHNUM,this.SDH.SDD(I).SOPLIN,this.SDH.SDD(I).SOQSEQ))
      this.R_SDD(WSEQ).SOHQTY=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
#/ 114721
      #Filling SOHSAU property
      this.R_SDD(WSEQ).SOHSAU=func TRTFUNEDI.SDH_SOHSAU(this.SDH.SDD(I).SOHNUM,this.SDH.SDD(I).SOPLIN,this.SDH.SDD(I).SOQSEQ)

      #Filling stock details
      If format$("D:YYYYMMDD",[F:STJ]SHLDAT)<> "29991231"
        this.R_SDD(WSEQ).STOSHLDAT = format$("D:YYYYMMDD",[F:STJ]SHLDAT)
      Else
        this.R_SDD(WSEQ).STOSHLDAT ="00000000"
      Endif


      # FJCP la cantidad entregada es la indicada en el embalaje
    #  this.R_SDD(WSEQ).STOQTY = abs([F:STJ]QTYSTU)
      this.R_SDD(WSEQ).STOQTY = abs([F:SPD]QTY)


      # fin FJCP

      this.R_SDD(WSEQ).STOSAU = [F:STJ]STU
      this.R_SDD(WSEQ).STOLOT = [F:STJ]LOT
      this.R_SDD(WSEQ).STOSER = [F:STJ]SERNUM

      #Calculating LINWEI property
      Local Decimal WLINWEI
      If toupper(this.SDH.SDD(I).WEU)<>"KG"
        Local File TABCOEFF [TCO]
        Read [TCO]TCO0="KG";this.SDH.SDD(I).WEU
        If fstat=[V]CST_AOK:
          WLINWEI=ar2((this.SDH.SDD(I).UNTWEI*[F:TCO]COEUOM)*this.R_SDD(WSEQ).STOQTY)
#          WLINWEI=ar2((this.SDH.SDD(I).UNTWEI*[F:TCO]COEUOM)*this.SDH.SDD(I).QTY)
        Endif
        LogicClose File [TCO]
      Else
        WLINWEI=ar2(this.SDH.SDD(I).UNTWEI*this.R_SDD(WSEQ).STOQTY)
#        WLINWEI=ar2(this.SDH.SDD(I).UNTWEI*this.SDH.SDD(I).QTY)
      Endif

      #Filling GROWEILIN property
      Local Decimal WPACKWEI
      Local Shortint WNBPACK
      Local File TABPACKAGE [TPA]

      If this.SDH.SDD(I).PCKCAP<>0
         WNBPACK=this.R_SDD(WSEQ).STOQTY/this.SDH.SDD(I).PCKCAP
#        WNBPACK=this.SDH.SDD(I).QTY/this.SDH.SDD(I).PCKCAP
      Else
        WNBPACK=1
      Endif

      If this.SDH.SDD(I).PCK<>"" and WNBPACK<>0
        Read [TPA]TPA0=this.SDH.SDD(I).PCK
        If toupper([F:TPA]WEU)="KG"
          WPACKWEI=[F:TPA]PCKWEI*WNBPACK
        Else
          Local File TABCOEFF [TCO]
          Read [TCO]TCO0="KG";[F:TPA]WEU
          If fstat=[V]CST_AOK
            WPACKWEI = ar2(([F:TPA]PCKWEI*[F:TCO]COEUOM)*WNBPACK)
          Endif
          LogicClose File [TCO]
        Endif
      Endif
      this.R_SDD(WSEQ).GROLINWEI=WLINWEI+WPACKWEI

      LogicClose File [TPA]

# issue 114721 Decimal separator in generated file
      #Formating decimal fields from the properties:
    #  WPROP= format$("N0:11.3#",this.SDH.SDD(I).QTY)
    ### FJCP Se toma la cantidad a entregar de SPACKD
      WPROP= format$("N0:11.3#",[F:SPD]QTY)
      this.R_SDD(WSEQ).SDDQTY =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      WPROP=format$("N0:11.3#",WLINWEI)
      this.R_SDD(WSEQ).LINWEI =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
#/ 114721

      #############################
      ##  NOTES lines            ##
      #############################
      #Filling text of line
      Local Char WTEXLIN (70)(5)
      Local Integer WOK, L

      WOK=func TRTFUNEDI.SDH_NUMOBSL(this.SDH.SDHNUM,this.SDH.SDD(I).SDDLIN,WTEXLIN())
      If WOK=1
        For L=0 To 4
          If WTEXLIN(L)<>""
            Assign ("this.R_SDD("+num$(WSEQ)+").NOTE"+num$(L+1)) With WTEXLIN(L)
          Endif
        Next
      Endif


       ## Identificador embalaje
       this.R_SDD(WSEQ).ZIDPACKLIN=[SPD]PACNUM
       ## FJCP Pedido Cliente
       this.R_SDD(WSEQ).ZORDNUMLIN=this.EDIORDNUM
     Next  STJ

  Endif

Next
    LogicClose File [STJ]
Return

################################################################################
$EDICOM_RECEIPT
Return


################################################################################
###################################################################################
## Busca el codigo Operacional para el comprador
## por Cliente Pedido y direccion de pedido.
Funprog SDH_ZEDIBPCORD(WNUM,WPARCOD)
Value Char    WNUM ,WPARCOD        # Sales order number


  Local Char WRES(20)

  Local File SORDER [SOH]
  Local File EDIBPRPAR [EBP]


  Read [SOH]SOH0=WNUM
  If fstat=[V]CST_AOK
  # Searching ZEDIBPCCOD property

     Read [EBP]EBP0=1;[SOH]BPCORD;[SOH]BPAORD;WPARCOD
     If fstat=[V]CST_AOK
       WRES=[F:EBP]EXCEDICOD
     Endif

  Endif

  LogicClose File [SOH]
  LogicClose File [EBP]

End WRES



