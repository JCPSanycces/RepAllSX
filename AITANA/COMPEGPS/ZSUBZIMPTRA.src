#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  #Infbox(ACTION)
     Case ACTION
      When "EXEC"     : Gosub EXEC
      When "OUVRE"    : Gosub OUVRE
      When "CONTROLE" : Gosub CONTROLE
      When "OK"       : Gosub OK
      When "DEBUT"    : Gosub DEBUT
      When "INIT"     : Gosub INIT
      When Default
     Endcase
Return

$INIT
  If !clalev([F:WAXX2]) : Local File ATEXTRA    [F:WAXX2] : Endif
  If !clalev([F:WITM])  : Local File ITMMASTER  [F:WITM] : Endif
  If !clalev([F:WTLA])  : Local File TABLAN     [F:WTLA] : Endif

Return

$CONTROLE
    TMP = 1
    TIT = "Importación en curso"
Return

$OK
    WEXE = 1
    WNOM = [M:ZIMPTRA]NOMFIC(0)

Return

$OUVRE
    Global Char WNOM(250)
    Global Integer WEXE
    Global Integer CODMODELO

    WEXE = 0
Return

$DEBUT
   Local Char MENSAJE(255)
   Local Char MENSAJE2(255)

   Append MENSAJE,"Esta opción permite al usuario importar el fichero con las traducciones de las descripciones de los artículos." +chr$(13)+chr$(10)
   Append MENSAJE,"Se trata de un fichero CSV con la estructura ARTICULO;IDIOMA;DESCRIPCION" +chr$(13)+chr$(10)
   Append MENSAJE,"Por ejemplo 1669;SPA;Sportiva2+ & España Topo" +chr$(13)+chr$(10)

   Call ERREURT(MENSAJE+MENSAJE2, 0) From GESECRAN

Return

$EXEC
   If WEXE = 1
      Gosub PROCESA
   Endif
Return

$PROCESA
  Local Integer STAT
  Local Char A(250)(1..110)

  WNOM = mid$(WNOM,7,len(WNOM))
  WNOM = filpath("BQT","","") +"\" +WNOM

  Call OUVRE_TRACE("Importación de fichero de traducciones "+WNOM) From LECFIC
  Call ECR_TRACE("Importación de fichero de traducciones iniciado",0) From GESECRAN

  adxifs=";"
  adxirs=chr$(13)+chr$(10)
  adxium=0 # ASCII

  Openi WNOM Using [TIE]
  Gosub LEER_REGISTRO
  While !fstat
    #Comprobamos que el artículo exista en X3
    Read [F:WITM]ITM0=vireblc(A(1),2)
    If fstat=0 Then
      #Comprobamos que el idioma exista en X3
      Read [F:WTLA]TLA0=vireblc(A(2),2)
      If fstat=0 Then
        Read [F:WAXX2]AXX0='ITMMASTER';'DES1AXX';vireblc(A(2),2);vireblc(A(1),2);''
        If fstat Then
          Raz [F:WAXX2]
          [F:WAXX2]CODFIC="ITMMASTER"
          [F:WAXX2]ZONE="DES1AXX"
          [F:WAXX2]LANGUE=vireblc(A(2),2)

          [F:WAXX2]IDENT1=vireblc(A(1),2)
          [F:WAXX2]TEXTE=vireblc(A(3),2)
          Write [F:WAXX2]
        Else
          [F:WAXX2]TEXTE=vireblc(A(3),2)
          Rewrite [F:WAXX2]
        Endif
        Filter [F:WAXX2]
      Else
        Call ECR_TRACE("Artículo: "+vireblc(A(1),2)+": El idioma "+vireblc(A(2),2)+" no existe en X3",1) From GESECRAN
      Endif
    Else
      Call ECR_TRACE("El artículo "+vireblc(A(1),2)+" no existe en X3",1) From GESECRAN
    Endif

    Gosub LEER_REGISTRO
  Wend
  Openi Using [TIE]

  Call ECR_TRACE("Importación de fichero de traducciones finalizado",0) From GESECRAN

  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Return

$LEER_REGISTRO
Rdseq A(1), A(2), A(3), A(4), A(5), A(6), A(7), A(8), A(9), A(10),
& A(11), A(12), A(13), A(14), A(15), A(16), A(17), A(18), A(19), A(20),
& A(21), A(22), A(23), A(24), A(25), A(26), A(27), A(28), A(29), A(30),
& A(31), A(32), A(33), A(34), A(35), A(36), A(37), A(38), A(39), A(40),
& A(41), A(42), A(43), A(44), A(45), A(46), A(47), A(48), A(49), A(50),
& A(51), A(52), A(53), A(54), A(55), A(56), A(57), A(58), A(59), A(60),
& A(61), A(62), A(63), A(64), A(65), A(66), A(67), A(68), A(69), A(70),
& A(71), A(72), A(73), A(74), A(75), A(76), A(77), A(78), A(79), A(80),
& A(81), A(82), A(83), A(84), A(85), A(86), A(87), A(88), A(89), A(90),
& A(91), A(92), A(93), A(94), A(95), A(96), A(97), A(98), A(99), A(100),
& A(101), A(102), A(103), A(104), A(105), A(106), A(107), A(108), A(109), A(110) Using [TIE]
Return

