#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara ZPEDMAP (Especifico Generacion pedidos de compra tipo mapas)
# PEDRO 02/10/2018


$ACTION
 #Infbox ACTION
 Case ACTION
     When "OUVRE"       : Gosub OUVRE
     When "DEBUT"       : Gosub INICIALIZA
     When "BOUTON"      : Gosub EJECUTA
     When "SETBOUT"     : Gosub SETBOUT
 Endcase
Return

######################################################################################
$EJECUTA
  Case BOUT
      When "B" :  Gosub LIMPIAR
                  Gosub CARGAR
      When "C" :  Gosub CREAR_PEDIDOS

  Endcase
Return

######################################################################################
$OUVRE
  If clalev([ITM]) = 0 Local File ITMMASTER   [ITM]: Endif
  If clalev([BPS]) = 0 Local File BPSUPPLIER  [BPS]: Endif
  If clalev([ZVT]) = 0 Local File ZVTSCHNM    [ZVT]: Endif   # Vista de donde parte la consulta

  Local Integer WOK

  WOK = 1

Return

######################################################################################
$INICIALIZA
   Raz[M:ZPEDMAP]
   [M:ZPEDMAP]CFECHAPED = date$
   Affzo [M:ZPEDMAP]
Return

######################################################################################
$LIMPIAR
  [M:ZPEDMAP]NBLIG = 0
  #GMR - 09/07/19 - INICIO - AÑADIR FILTRO PROVEEDOR Y FECHA QUE NO SE MODIFIQUE
  #[M:ZPEDMAP]CFECHAPED = date$
  #GMR - 09/07/19 - FIN
  Affzo [M:ZPEDMAP]
Return

######################################################################################
$SETBOUT
  Call COLOREAR_GRID
Return

######################################################################################
$CARGAR
  Local Char WFILTRO(250)
  Local Char MSG(250),TXT(250)(10), W(250)(2)
  Local Integer F
  Local Char BD_TIPO(1)

  BD_TIPO=func ZCOMUN.DATA_BASE_TIPO()

  If [M:ZPEDMAP]CFECHADEB <> [0/0/0] Then # DESDE FECHA
     WFILTRO = "FEC_0 >=  " + "'" + num$([M:ZPEDMAP]CFECHADEB) + "'"
  Endif

  If [M:ZPEDMAP]CFECHAFIN  <> [0/0/0] Then # HASTA FECHA
     WFILTRO = "FEC_0 <=  " + "'" + num$([M:ZPEDMAP]CFECHAFIN) + "'" + " AND " + WFILTRO
  Endif

  #GMR - 09/07/19 - INICIO - AÑADIR FILTRO PROVEEDOR Y FECHA QUE NO SE MODIFIQUE
  If [M:ZPEDMAP]CBPSNUM <> "" Then # HASTA FECHA
     WFILTRO = "NPROV_0 LIKE " + "'" + [M:ZPEDMAP]CBPSNUM + "'" + " AND " + WFILTRO
  Endif
  #GMR - 09/07/19 - FIN

  If WFILTRO = "" : WFILTRO = "1=1" : Endif

  TXT(0)="SELECT NPROV_0,IDART_0,sum(QTY_0) FROM ZVTSCHNM"
  TXT(1)=" Where " + WFILTRO
  TXT(2)=" group By NPROV_0,IDART_0"
  TXT(3)=" Order By NPROV_0,IDART_0"

  #### las siguientes instrucciones crean un fichero en la carpeta tmp donde esta la sentencia de SQL para poder depurar
#  Local Char FICSRV(250)
#  Local Integer YN
#  Call GRABARFICHERO(TXT,FICSRV) From ZCOMUN
#  Call OUINON(FICSRV, YN) From GESECRAN
#  If YN=1
#    Return
#  Endif

  For (Char FBPS(GLONBPS),Char FITM(GLONITM),Decimal FQTY) From BD_TIPO Sql TXT As [MYT]

        F = [M:ZPEDMAP]NBLIG

        [M:ZPEDMAP]BPS(F)=FBPS
        If [M:ZPEDMAP]BPS(F)= "" Then : [M:ZPEDMAP]BPS(F)= "SIN PROVEEDOR"  : Endif
        [M:ZPEDMAP]ITM(F)=FITM
        [M:ZPEDMAP]QTY(F)=FQTY
        [M:ZPEDMAP]MARCAR(F) = 1
        [M:ZPEDMAP]NBLIG+=1

  Next
  Affzo [M:ZPEDMAP]
  Call COLOREAR_GRID

Return


######################################################################################

$CREAR_PEDIDOS
  Local Char WPOHNUM(30)
  Local Char WBPS(GLONBPS)
  Local Char TMP(250)
  Local Integer STAT

  Gosub ABRIR_TRAZA From ZCOMUN

  # Variables para XML
  Gosub GEN_DEF_VAR From ZCOMUN

  WNOM="ZPOHM"

  # Abrimos el modelo de importacion

  WABR = "UTF"
  Gosub GEN_ABRIR From ZCOMUN

  For I = 0 To [M:ZPEDMAP]NBLIG - 1
    If [M:ZPEDMAP]MARCAR(I) = 2 Then
       # Nuevo bloque de proveedor
       If WBPS <> [M:ZPEDMAP]BPS(I)
          If WBPS <> "" Then
             Call XML_CIERRA_ETIQUETA("E") From ZXML
          Endif

          WBPS = [M:ZPEDMAP]BPS(I)

          Read [BPS]BPS0 = [M:ZPEDMAP]BPS(I)

          # Siguiente numero de PEDIDO
          Call NUMERO("MAP", "100", [M:ZPEDMAP]CFECHAPED,"",WPOHNUM,STAT) From SUBANM

          # Agregamos a la traza
          Call ECR_TRACE("PEDIDO GENERADO: " + WPOHNUM,0) From GESECRAN

          Call XML_ABRE_ETIQUETA("E") From ZXML

          Call XML_LINEA("POH_POHFCY","100")                                               From ZXML       # Planta
          Call XML_LINEA("POH_POHNUM",WPOHNUM)                                             From ZXML       # Nº Pedido
          Call XML_LINEA("POH_ORDDAT",format$("D:YYYY[-]MM[-]DD",[M:ZPEDMAP]CFECHAPED))    From ZXML       # Fecha
          Call XML_LINEA("POH_BPSNUM",[M:ZPEDMAP]BPS(I))                                   From ZXML       # Proveedor
          Call XML_LINEA("POH_CUR",[BPS]CUR)                                               From ZXML       # Moneda
       Endif

       Call XML_ABRE_ETIQUETA("L") From ZXML

       Read [ITM]ITM0 = [M:ZPEDMAP]ITM(I)

       Call XML_LINEA("POQ_ITMREF",[M:ZPEDMAP]ITM(I))                                       From ZXML       # Articulo
       Call XML_LINEA("POP_ITMDES",[ITM]ITMDES1)                                            From ZXML       # Descripción
       Call XML_LINEA("POQ_PRHFCY","100")                                                   From ZXML       # Planta
       Call XML_LINEA("POQ_UOM",[ITM]PUU)                                                   From ZXML       # Unidad compra
       Call XML_LINEA("POQ_QTYUOM",num$([M:ZPEDMAP]QTY(I)))                                 From ZXML       # Cantidad
       Call XML_LINEA("POQ_EXTRCPDAT",format$("D:YYYY[-]MM[-]DD",[M:ZPEDMAP]CFECHAPED))     From ZXML       # Fecha

       Call XML_CIERRA_ETIQUETA("L") From ZXML

    Endif
  Next

  Call XML_CIERRA_ETIQUETA("E") From ZXML

  # Cerramos el modelo de importacion
  Gosub GEN_FIN From ZCOMUN



  If WOK = 1 # si no ha dado error la importacion


  Else
    Call ERREUR("Error creando Pedidos Compra: " ) From GESECRAN
  Endif


  #Cerrar y mostrar traza
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC

Return

######################################################################################
Subprog COLOREAR_GRID
  For I = 0 To [M:ZPEDMAP]NBLIG - 1
    If [M:ZPEDMAP]BPS(I) = "SIN PROVEEDOR" Then
       Chgstl [M:ZPEDMAP]NBLIG(I) With "BACKRED"
    Endif
  Next
  Affzo [M:ZPEDMAP]
End


######################################################################################
Subprog AM_MARCAR(VALEUR)
  Variable Integer VALEUR
  If VALEUR = 1 Then
    [M:ZPEDMAP]MARCAR(nolign-1) = 1
  Else
    [M:ZPEDMAP]MARCAR(nolign-1) = 2
  Endif
  Affzo[M:ZPEDMAP]MARCAR(nolign-1)
End

######################################################################################
Subprog B1_NBLIG # Boton marcar todo en NBLIG
  Local Integer I

  For I = 0 To [M:ZPEDMAP]NBLIG - 1
    If [M:ZPEDMAP]BPS(I) <> "SIN PROVEEDOR" Then
       [M:ZPEDMAP]MARCAR(I) = 2
    Endif
  Next
  Affzo[M:ZPEDMAP]
End

######################################################################################
Subprog B2_NBLIG # Boton desmarcar todo en NBLIG
  Local Integer I

  For I = 0 To [M:ZPEDMAP]NBLIG - 1
    [M:ZPEDMAP]MARCAR(I) = 1
  Next
  Affzo[M:ZPEDMAP]
End


######################################################################################

