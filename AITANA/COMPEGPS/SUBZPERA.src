$EXPORT0_TSK
 # Alpha
NOMVAR = 'TSK'
LIGNE = ''+NOMVAR+''
Wrseq LIGNE Using [AEXP]
 # Alpha
NOMVAR = ''        #[F:WTSK]TSKNUM   Nº de tarea
LIGNE = ''+NOMVAR+''
Wrseq LIGNE Using [AEXP]
 # Alpha
NOMVAR = FCY_P     #[F:WTSK]SALFCY   Planta
LIGNE = ''+NOMVAR+''
Wrseq LIGNE Using [AEXP]
 # Alpha
NOMVAR = TERCERO_P #[F:WTSK]TSKCMP   Tercero
LIGNE = ''+NOMVAR+''
Wrseq LIGNE Using [AEXP]
 # Alpha
NOMVAR = INTERLO_P #[F:WTSK]TSKCCN   Interlocutor
LIGNE = ''+NOMVAR+''
Wrseq LIGNE Using [AEXP]
 # Alpha
NOMVAR = CONTACT_P #[F:WTSK]TSKCOR   Contacto
LIGNE = ''+NOMVAR+''
Wrseq LIGNE Using [AEXP]
 # Alpha
NOMVAR = PROYECT_P #[F:WTSK]TSKPJT   Proyecto
LIGNE = ''+NOMVAR+''
Wrseq LIGNE Using [AEXP]
 # Alpha
NOMVAR = [F:WTSK]TSKTYP
LIGNE = ''+NOMVAR+''
Wrseq LIGNE Using [AEXP]
 # Date
DAT = FECHA_P      #[F:WTSK]TSKDAT   Fecha Vencimiento
Call SETDATE(DAT,LIGNE,[F:AOE]OPTDAT) From SUBEXPOBJ
Wrseq LIGNE Using [AEXP]
 # Date
DAT = FECHA_P      #[F:WTSK]TSKSTR   Fecha
Call SETDATE(DAT,LIGNE,[F:AOE]OPTDAT) From SUBEXPOBJ
Wrseq LIGNE Using [AEXP]
 # Alpha
NOMVAR = [F:WTSK]TSKPIOLEV
LIGNE = ''+NOMVAR+''
Wrseq LIGNE Using [AEXP]
 # Alpha
NOMVAR = REPRESE_P #[F:WTSK]TSKREP   Representante
LIGNE = ''+NOMVAR+''
Wrseq LIGNE Using [AEXP]
 # Numérique
NOMVAR = num$([F:WTSK]TSKDEL)
LIGNE = num$(NOMVAR)
Wrseq LIGNE Using [AEXP]
 # Menu local
LIBEL = 1          #[F:WTSK]TSKDON    Efectuado
Call SETLIB(LIBEL,1,NOMVAR) From SUBEXPOBJ
LIGNE = num$(NOMVAR)
Wrseq LIGNE Using [AEXP]
 # Alpha
NOMVAR = ''        #[F:WTSK]TSKSAO   Satisfaccion
LIGNE = ''+NOMVAR+''
Wrseq LIGNE Using [AEXP]
 # Alpha
NOMVAR = PERIODO_P #[F:WTSK]ZPERIODO   Periodo
LIGNE = ''+NOMVAR+''
Wrseq LIGNE Using [AEXP]
 # Numérique
NOMVAR = num$(0)   #num$([F:WTSK]HOUTIMSPG)  Tiempo realizado hrs
LIGNE = num$(NOMVAR)
Wrseq LIGNE Using [AEXP]
 # Numérique
NOMVAR = num$(0)   #num$([F:WTSK]MNTTIMSPG)  Tiempo realizado minutos
LIGNE = num$(NOMVAR)
Wrseq LIGNE Using [AEXP]
 # Alpha
NOMVAR = [F:WTSK]TSKDES
LIGNE = ''+NOMVAR+''
Wrseq LIGNE Using [AEXP]

#
#For [F:HD4]HD40 Where NUM=[F:WTSK]NUMFULRPO & TYP=[F:WTSK]TYPFULRPO
#  Gosub EXPORT1_TSK
#Next
For [F:HD6]HD60 Where NUM=[F:WTSK]NUMFULOBJ & TYP=[F:WTSK]TYPFULOBJ
  Gosub EXPORT2_TSK
  Break
# Call GERE_TEXTE_SYNTHESE([M:TSK1]FULOBJ, VALEUR, [M:TSK1]TSKDES) From CRMUTIL150  # FGR 06/08/2014 : X3SUIVI95250
Next
Return

