LIGNE = ''+NOMVAR+''
Wrseq LIGNE Using [AEXP]
#
#For [HD4]HD40 Where NUM=[F:WCLL]NUMFULRPO & TYP=[F:WCLL]TYPFULRPO
#  Gosub EXPORT1_CLL
#Next
For [HD5]HD50 Where NUM=[F:WCLL]NUMFULOBJ & TYP=[F:WCLL]TYPFULOBJ
  Gosub EXPORT2_CLL
Next
Return

