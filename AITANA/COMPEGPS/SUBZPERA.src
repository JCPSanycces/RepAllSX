 # Date
DAT = [F:WOPP]ENDDAT
If DAT<>[0/0/0] DAT=nday$(nday(DAT)+DIAS_P) Endif
If [M:ZCAMDUP]ZETAPAS<>2 Raz DAT Endif
Call SETDATE(DAT,LIGNE,[F:AOE]OPTDAT) From SUBEXPOBJ
Wrseq LIGNE; Using [AEXP]
 # Date
DAT = [F:WOPP]ENDDAT(1)
If DAT<>[0/0/0] DAT=nday$(nday(DAT)+DIAS_P) Endif
If [M:ZCAMDUP]ZETAPAS<>2 Raz DAT Endif
Call SETDATE(DAT,LIGNE,[F:AOE]OPTDAT) From SUBEXPOBJ
Wrseq LIGNE; Using [AEXP]
 # Date
