 # Alpha
NOMVAR = "" # [F:WOPP]OPPSTE Última etapa pasada
LIGNE = ''+NOMVAR+''
Wrseq LIGNE; Using [AEXP]
 # Alpha
NOMVAR = [F:WOPP]OPPSTEA2
LIGNE = ''+NOMVAR+''
Wrseq LIGNE; Using [AEXP]
 # Menu local
LIBEL = 1  # [F:WOPP]OPPCLO   Asunto cerrado
Call SETLIB(LIBEL,1,NOMVAR) From SUBEXPOBJ
LIGNE = num$(NOMVAR)
Wrseq LIGNE; Using [AEXP]
 # Date
DAT = [0/0/0] #[F:WOPP]STRSTE  Ultima etapa pasada
Call SETDATE(DAT,LIGNE,[F:AOE]OPTDAT) From SUBEXPOBJ
Wrseq LIGNE; Using [AEXP]
 # Numérique
NOMVAR = num$(IMPORTE_P) # num$([F:WOPP]OPPAMT)   Importe
LIGNE = num$(NOMVAR)
Wrseq LIGNE; Using [AEXP]
 # Numérique
NOMVAR = num$([F:WOPP]PBYPRJ)
LIGNE = num$(NOMVAR)
Wrseq LIGNE; Using [AEXP]
 # Numérique
NOMVAR = num$([F:WOPP]PBYPRJAAM)
