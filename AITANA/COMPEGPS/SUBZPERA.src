LIBEL = [F:WOPP]DAMCUM
Call SETLIB(LIBEL,1,NOMVAR) From SUBEXPOBJ
LIGNE = num$(NOMVAR)
Wrseq LIGNE; Using [AEXP]
 # Date
DAT = FECHA_F  # [F:WOPP]OPPCDA   Fecha de finalización
Call SETDATE(DAT,LIGNE,[F:AOE]OPTDAT) From SUBEXPOBJ
Wrseq LIGNE; Using [AEXP]
 # Date
DAT = [0/0/0] #[F:WOPP]OPPREACDA  #  Fecha cierre definitivo
Call SETDATE(DAT,LIGNE,[F:AOE]OPTDAT) From SUBEXPOBJ
Wrseq LIGNE; Using [AEXP]
