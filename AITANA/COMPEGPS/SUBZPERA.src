$EXPORT0_OPP
 # Alpha
NOMVAR = PROYECT_P  #[F:WOPP]OPPNUM   Proyecto
LIGNE = ''+NOMVAR+''
Wrseq LIGNE; Using [AEXP]
 # Alpha
NOMVAR = [F:WOPP]OPPDES
LIGNE = ''+NOMVAR+''
Wrseq LIGNE; Using [AEXP]
 # Alpha
NOMVAR = ZCAMID_P  #[F:WOPP]ZCAMID   Nº campaña
LIGNE = ''+NOMVAR+''
Wrseq LIGNE; Using [AEXP]
 # Alpha
NOMVAR = [F:WOPP]OPPTYP
LIGNE = ''+NOMVAR+''
Wrseq LIGNE; Using [AEXP]
 # Alpha
NOMVAR = [F:WOPP]OPPSRENUM
LIGNE = ''+NOMVAR+''
