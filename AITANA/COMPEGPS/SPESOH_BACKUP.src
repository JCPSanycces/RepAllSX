#<AdxTL>@(#)0.0.0.0 $Revision$ Pedidos
$ACTION
Case ACTION
 When "LIENS_LIG"     : Gosub LIENS_LIG
 When "SETBOUT"       : Gosub SETBOUT
 When "EXEBOUT"       : Gosub EXEBOUT
 When "INICRE"        : Gosub INICRE
 When "INIMOD"        : Gosub INICRE
 When "APRES_CRE"     : Gosub APRES_CRE
 When Default
Endcase
Return




$INICRE
#If GUSER='ADMIN' : Dbgaff : Endif
If [M:SOH1]ZCVPSTA=3
Else
   # Chequear si hay lineas en Gestion Compra - Venta de la planta 100
   Local Integer WI
   Local Integer WFOUND : WFOUND = 0
   If [M:SOH0]SOHTYP="WEB"
      [M:SOH1]ZCVPSTA=3 : # Compra-Venta Gestionada
   Else
      For WI= 0 To [M:SOH4]NBLIG - 1
         If [M:SOH4]ZCVPQTYSTU(WI)>0
            WFOUND=1
            Break
         Endif
      Next
      If WFOUND Then
         [M:SOH1]ZCVPSTA=2 : # Pendiente Generar Compra-Venta
      Else
         [M:SOH1]ZCVPSTA=1 : # No Gestiona Compra-Venta
      Endif
   Endif
  Affzo [M:SOH1]ZCVPSTA
  [F:SOH]ZCVPSTA=[M:SOH1]ZCVPSTA
Endif
Return


$APRES_CRE
# FJCP ZCVP - Gestion Compra Venta en Pedidos
# Si importacion y tipo de pedido EDI
# Lanzamos la gestion Compra-Venta
If GIMPORT & [M:SOH0]SOHTYP="EDI"
   Gosub TR_ZCVP
Endif
# FIN FJCP ZCVP - Gestion Compra Venta en Pedidos.
Return



$SETBOUT
#### ATG do nothing - 25/10/2017
### FJCP ZCVP - Gestion Compra Venta en Pedidos.
# Activacion del Botón 7 "Gestion C-V"
#If [M:SOH1]ZCVPSTA<>2 | GCONSULT Then
#   Call VIREBOUT(CHAINE,"7") From GOBJET
#Endif
#If GREP <> "" | [M:SOH0]SOHCAT = 3  | CLECUR = 0 | [M:SOH1]ORDSTA = 2 | [M:SOH1]APPFLG<3
#   Call VIREBOUT(CHAINE,"7") From GOBJET
#Endif
# FIN FJCP ZCVP - Gestion Compra Venta en Pedidos.
Return


$EXEBOUT
GCONSDIA=0

Case BOUT
   When "7" :
      # FJCP ZCVP - Gestion Compra Venta en Pedidos.
      Gosub TR_ZCVP
      If GOK : Gosub RELIT From GOBJSUB : Endif
      # FIN FJCP ZCVP - Gestion Compra Venta en Pedidos.
Endcase
Return




#### FJCP ZCVP - Gestion Compra Venta en Pedidos.
## Gestion Compra Venta
## Inserccion en tabla ZINTEGRADOR con estado 2 para que
## lo gestione el proceso ZIMPE.
##
$TR_ZCVP
If !clalev([F:ZINTE]) : Local File ZINTEGRADOR [ZINTE] : Endif
If !clalev([F:SOQX]) : Local File SORDERQ [SOQX] : Endif
If !clalev([F:SOPX]) : Local File SORDERP [SOPX] : Endif
If !clalev([F:SOHX]) : Local File SORDER [SOHX] : Endif

If [M:SOH0]SOHNUM="" : Return : Endif
Read [F:SOHX]SOH0=[M:SOH0]SOHNUM
If fstat : Return : Endif
## Preguntar si Continua
  Local Integer LOK
    LOK=1
    Call OUINON ("Generar Compra Venta. El pedido se bloquerá.¿Continuar?",LOK) From GESECRAN
    If LOK<>2: Return:  Endif


Filter [F:SOQX] Where SOHNUM = [M:SOH0]SOHNUM  and ZCVPFCYORI='100' and ZCVPQTYSTU>0 and STOMGTCOD=2
GOK=1
Trbegin [ZINTE], [SOHX]
For [F:SOQX]
   Read [F:SOPX]SOP0=[F:SOQX]SOHNUM;[F:SOQX]SOPLIN;[F:SOQX]SOQSEQ
   Raz [F:ZINTE]
   [F:ZINTE]ZINTE="X3"
   [F:ZINTE]ZREF1=[F:SOQX]SOHNUM
   [F:ZINTE]ZIDPED=[F:SOQX]SOHNUM
   [F:ZINTE]ZIDLIN=[F:SOQX]SOPLIN
   [F:ZINTE]ZSOC=[F:SOQX]CPY
   [F:ZINTE]ZPLANTA=[F:SOQX]STOFCY
   [F:ZINTE]ZFEPED=[F:SOQX]ORDDAT
   [F:ZINTE]ZDIV=[F:SOH]CUR # Revisar
   [F:ZINTE]ZREF1=[F:SOQX]SOHNUM
   [F:ZINTE]ZCODART=[F:SOQX]ITMREF
   [F:ZINTE]ZDESART=[F:SOPX]ITMDES
   [F:ZINTE]ZUNI=[F:SOQX]ZCVPQTYSTU
   [F:ZINTE]ZPREEXC=[F:SOPX]GROPRI
   [F:ZINTE]ZDTO1=[F:SOPX]DISCRGVAL1
   [F:ZINTE]ZDTO2=[F:SOPX]DISCRGVAL2
   [F:ZINTE]ZDTO3=[F:SOPX]DISCRGVAL3
   [F:ZINTE]ZVENDEDOR=[F:SOPX]REP1
   [F:ZINTE]ZESTADO=2
   Write [F:ZINTE]
   If fstat
      GOK=0
      Call FSTA("ZINTE") From GLOCK
   Endif
Next
Filter [F:SOQX]
If GOK
   [F:SOHX]ZCVPSTA=3
   Rewrite [F:SOHX]
   If fstat
      GOK=0
      Call FSTA("SOHX") From GLOCK
   Endif
Endif
If GOK
   Commit
Else
   Rollback
Endif
Return


$LIENS_LIG
Local Shortint NOL
NOL=nolign-1
Call CALC_ZPFMPCT(NOL)
Return
# FJCP ZCVP - Gestion Compra Venta en Pedidos.

############################################################################
##### Acciones Campo
############################################################################
Subprog AM_BPCORD(VALEUR)
Variable Char    VALEUR()

### FJCP Control planta Autorizada.
Local Integer WFOUND, WI
WFOUND=0
For I=0 To 9
  If [F:BPC]ZPLAPER(I)=""
      Break
  Endif
  If [F:BPC]ZPLAPER(I)=[M:SOH0]SALFCY
    WI=I
    WFOUND=1
    Break
  Endif
Next
If I>0 & !WFOUND
   GMESSAGE = "Planta no Autorizada"
   [M:SOH0]BPCORD=""
   Affzo [M:SOH0]BPCORD
   mkstat = 2
   End
Endif
### Fin FJCP Control planta Autorizada

### FJCP Forma de Pago por Defecto de planta
If WFOUND & [F:BPC]ZPLAPTE(WI)<>"" Then
   WPTE=[F:BPC]ZPLAPTE(WI)
   Call C_PTE(WPTE) From SUBSOH
   If mkstat Then
      End
   Endif
   Call AM_PTE(WPTE) From SUBSOH
   If mkstat Then
      End
   Endif
   [M:SOH3]PTE=WPTE
   Affzo [M:SOH3]PTE
Endif
### Fin FJCP Forma de Pago por Defecto de planta

### FJCP - Regimen de impuesto por Defecto de planta
If WFOUND & [F:BPC]ZPLAVAC(WI)<>"" Then
   WVAC=[F:BPC]ZPLAVAC(WI)
   Call C_VACBPR(WVAC) From SUBSOH
   If mkstat Then
      End
   Endif
   Call AM_VACBPR(WVAC) From SUBSOH
   If mkstat Then
      End
   Endif
   [M:SOH1]VACBPR=WVAC
   Affzo [M:SOH1]VACBPR
Endif
### Fin FJCP - Regimen de impuesto por Defecto de planta

End


Subprog AS_QTY(VALEUR)
Variable Decimal VALEUR

# FJCP ZCVP - Gestion Compra Venta en Pedidos.
# Si pedido con Compraventa Gestionada no se permita modificar la cantidad.
If [M:SOH1]ZCVPSTA=3 Then
   mkstat=2
Endif
# Fin FJCP ZCVP - Gestion Compra Venta en Pedidos.

End

Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR
Local Integer NOL : NOL=nolign - 1

### FJCP ZCVP - Gestion Compra Venta en Pedidos.
#Calculo Stock Disponible Planta 100 Estado AVI
Local Char WLFCY(5), WART(20), WSTA(5)
Local Decimal WDIS
WART=[M:SOH4]ITMREF(NOL)
WLFCY='100'
WSTA='AVI'
WDIS=0
#Infbox "AM_QTY(SPE)"
# si la planta es la propia , no se gestiona compra-venta

If [M:SOH0]SALFCY=WLFCY : End : Endif
# si el tipo de pedido es "WEB" no se gestiona compra venta
If [M:SOH0]SOHTYP="WEB" : End : Endif
#Dbgaff
Gosub STOCK_DISPONIBLE
If WDIS > VALEUR
   [M:SOH4]ZCVESTODIS(NOL)=WDIS
   [M:SOH4]ZCVPFCYORI(NOL)=WLFCY
   [M:SOH4]ZCVPQTYSTU(NOL)=VALEUR
   Affzo [M:SOH4]ZCVESTODIS(NOL)
   Affzo [M:SOH4]ZCVPFCYORI(NOL)
   Affzo [M:SOH4]ZCVPQTYSTU(NOL)
   If !GIMPORT Then
     Infbox "Stock en Planta " - WLFCY - ": " + num$(WDIS)
   Endif
Else
   #[M:SOH4]ZCVESTODIS(NOL)=0
   #[M:SOH4]ZCVPFCYORI(NOL)=""
   [M:SOH4]ZCVESTODIS(NOL)=WDIS
   [M:SOH4]ZCVPFCYORI(NOL)=WLFCY
   # Modificacion (01/09/2016) La planta de origen es la planta 100 incluso si el es stock
   # es insuficiente (Angel de la Torre)
 #  [M:SOH4]ZCVPQTYSTU(NOL)=0
  [M:SOH4]ZCVPQTYSTU(NOL)=VALEUR
   Affzo [M:SOH4]ZCVESTODIS(NOL)
   Affzo [M:SOH4]ZCVPFCYORI(NOL)
   Affzo [M:SOH4]ZCVPQTYSTU(NOL)
   If !GIMPORT Then
     # mkstat = 2 : GMESSAGE = "Stock No disponible en Planta:" - WLFCY
     Infbox "Stock Insuficiente en Planta " - WLFCY - ": " + num$(WDIS)
   Endif
Endif


# Actualizacion Margen Planta Origen.
    [M]QTY(NOL)=VALEUR
    Call CLCPFM([M]DSTOFCY(NOL), [M:SOH1]PRITYP, [M]CHGTYP, [M:SOH0]ORDDAT, [M:SOH0]CUR, NOL, 2) From TRTVENPRI
    If GDACLOK = 1
        Call CTLPFM([M:SOH0]CUR,[M:SOH4]CPRPRI(NOL), NOL) From TRTVENPRI
        If mkstat=2 End Endif
    Endif
    Affzo [M:SOH4]CPRPRI(NOL)
    Affzo [M:SOH4]PFM(NOL)
  # Infbox "AM_QTY(SPE)-2"
    Call CALC_ZPFMPCT(NOL)
### FIN FJCP ZCVP - Gestion Compra Venta en Pedidos.

End

###FJCP ZCVP - GESTION COMPRA VENTA EN PEDIDOS.
### Calculo Stock disponibel en planta origen
$STOCK_DISPONIBLE
If  !clalev([F:STOX]) : Local File STOCK [STOX] : Endif

Local Char CRIT(250)

CRIT="ITMREF='" + WART + "' & STOFCY='" + WLFCY + "' & STA='"+ WSTA +"'"

   For [STOX]STO3 Where evalue(CRIT)
#      WDIS += [F:STOX]QTYSTUACT-[F:STOX]CUMALLQTA-[F:STOX]CUMWIPQTA
# 01/09/2016 Ignoramos las cantidas en curso de entrega
        WDIS += [F:STOX]QTYSTUACT-[F:STOX]CUMALLQTA
   Next

Return
### FIN FJCP ZCVP - Gestion Compra Venta en Pedidos.


Subprog C_NBLIG
### FJCP ZCVP - Gestion Compra Venta en Pedidos.
If [M:SOH1]ZCVPSTA=3
   If (status=65 or status=68 or status=73) & GFLAG<>"MOD"
       mkstat=2
       End
   Endif
Else
   # Chequear si hay lineas en Gestion Compra - Venta de la planta 100
   Local Integer WI
   Local Integer WFOUND : WFOUND = 0
   If [M:SOH0]SOHTYP="WEB"
      [M:SOH1]ZCVPSTA=3 : # Compra-Venta Gestionada
   Else
      For WI= 0 To [M:SOH4]NBLIG - 1
         If [M:SOH4]ZCVPQTYSTU(WI)>0
            WFOUND=1
            Break
         Endif
      Next
      If WFOUND Then
         [M:SOH1]ZCVPSTA=2 : # Pendiente Generar Compra-Venta
      Else
         [M:SOH1]ZCVPSTA=1 : # No Gestiona Compra-Venta
      Endif
   Endif
  Affzo [M:SOH1]ZCVPSTA
Endif
### FIN FJCP ZCVP - Gestion Compra Venta en Pedidos.
End


