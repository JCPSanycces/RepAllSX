End

Subprog AM_SAUSTUCOE(VALEUR)
Variable Decimal VALEUR

# FJCP ZCVP -
# Calculo Margen Porcentual en Linea
Local Integer NOL : NOL = nolign - 1
Call CALC_ZPFMPCT(NOL)
End


######################################################################################

Subprog CALC_ZPFMPCT(WNLIG)
Value Integer WNLIG
If [M:SOH4]NETPRI(WNLIG)<>0
   [M:SOH4]ZPFMPCT(WNLIG)=[M:SOH4]PFM(WNLIG)/[M:SOH4]NETPRI(WNLIG)*100
Else
   [M:SOH4]ZPFMPCT(WNLIG)=0
Endif
Affzo[M:SOH4]ZPFMPCT(WNLIG)
End


