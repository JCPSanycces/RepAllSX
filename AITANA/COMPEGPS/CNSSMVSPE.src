#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  #Infbox(ACTION)
     Case ACTION
      When "SETBOUT" : Gosub AV_AFFICHE
      When Default
     Endcase
Return


$AV_AFFICHE

Local Integer WI
Local Char ZPLADES(5)

If !clalev([F:ZSTJ]) Local File STOJOU [ZSTJ] Endif


For WI=0 To NBLIG-1

  Filter [F:ZSTJ] Where VCRTYP = 29 and ITMREF = [M:SMV1]ITMREF and VCRNUM = [M:SMV2]VCRNUM(WI)
& and SERNUM = [M:SMV2]SERNUM(WI) and QTYPCU = (-1)*[M:SMV2]QTYPCU(WI)
  Raz ZPLADES
  For [F:ZSTJ]
    ZPLADES = [F:ZSTJ]STOFCY
    Break
  Next
  If ZPLADES <> "" and [M:SMV2]QTYPCU(WI) < 0
    [M:SMV2]FCYDES(WI) = ZPLADES
    Affzo [M:SMV2]
  Endif
Next


Return

