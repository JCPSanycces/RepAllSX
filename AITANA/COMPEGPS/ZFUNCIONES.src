#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog TRADUCCIONES(CODART,ERRORES)
  Value Char CODART
  Variable Char ERRORES

  If !clalev([F:WITM])  : Local File ITMMASTER  [F:WITM] : Endif
  If !clalev([F:WADI])  : Local File ATABDIV    [F:WADI] : Endif
  If !clalev([F:WAXX])  : Local File ATEXTRA    [F:WAXX] : Endif
  If !clalev([F:WAXX2]) : Local File ATEXTRA    [F:WAXX2] : Endif

  Local Char DESBASE(150)
  Local Char DESCSPA(150)
  Local Char VALORES(255)(0..)
  Local Char DESCRIPCION(150)
  Local Integer ENCONTRADO
  Local Char CODIDIOMA(5)
  Local Char REQUEST(250)
  Local Char REQUEST2(250)(5)

  Local Integer VUELTAS

  GOK=1
  VUELTAS=0

  Raz ERRORES

  Trbegin [F:WITM]
  Filter [F:WITM] Where ITMREF=CODART
  For [F:WITM]
    Raz DESCRIPCION
    Raz DESCSPA
    Raz DESBASE



    #DESCRIPCION=""
    #DESCSPA=""
    #DESBASE=""
    DESBASE=[F:WITM]ZDESBASE

    If DESBASE<>"" Then
      #Llamamos a la funcíón que pasa la cadena de texto a un array
      Call ARRAY(DESBASE," ",VALORES) From ZCOMUN

      #Borramos los registros de la tabla ATEXTRA correspondientes al artículo
      Filter [F:WAXX] Where IDENT1=CODART and CODFIC='ITMMASTER' and ZONE='DES3AXX'
        For [F:WAXX]
            Delete [F:WAXX]
        Next
      Filter [F:WAXX]

      #Recontruimos la cadena a partir del diccionario
      For JJ=0 To dim(VALORES)-1
        If VALORES(JJ)<>"" Then
          Raz DESCRIPCION
          Raz ENCONTRADO
          #DESCRIPCION=""
          #ENCONTRADO=0

          REQUEST="SELECT A1_0 FROM ATABDIV WHERE NUMTAB_0='6048' GROUP BY A1_0"
          For (Char IDIOMA(5)) From "5" Sql REQUEST As [YYY]
            #Filter [F:WAXX] Where 1=1 and IDENT1='6048' and CODFIC='ATABDIV' and TEXTE=ctrans(VALORES(JJ),","," ")
            #For [F:WAXX]
              #ENCONTRADO=0
              #REQUEST2="SELECT A2_0 FROM ATABDIV WHERE NUMTAB_0='6048' AND CODE_0='"+[F:WAXX]IDENT2+"' AND A1_0='"+[F:YYY]IDIOMA+"'"
              REQUEST2(0)="SELECT A2_0 FROM ATABDIV WHERE NUMTAB_0='6048' AND CODE_0 IN(SELECT IDENT2_0 FROM COMPEGPS.ATEXTRA "
              #REQUEST2(1)="WHERE IDENT1_0='6048' AND CODFIC_0='ATABDIV' AND ZONE_0='LNGDES' AND TEXTE_0='"+ctrans(VALORES(JJ),","," ")+"') AND A1_0='"+[F:YYY]IDIOMA+"'"
              REQUEST2(1)="WHERE IDENT1_0='6048' AND CODFIC_0='ATABDIV' AND ZONE_0='LNGDES' AND REPLACE(TEXTE_0,CHAR(39),'')='"+ctrans(ctrans(VALORES(JJ),","," "),chr$(39),'')+"') AND A1_0='"+[F:YYY]
& IDIOMA+"'"



              For (Char TEXTO(40)) From "5" Sql REQUEST2 As [ZZZ]
                ENCONTRADO=1
                DESCRIPCION=[F:ZZZ]TEXTO
                CODIDIOMA=[F:YYY]IDIOMA
                Gosub ADDREG
              Next
            #Next
            #Filter [F:WAXX]
            If ENCONTRADO=0 Then
              #Append ERRORES,"Artículo "+CODART+"-Palabra clave"-VALORES(JJ)-"Idioma"-[F:YYY]IDIOMA
              ERRORES(VUELTAS)="Artículo "+CODART+"-Palabra clave"-VALORES(JJ)-" no encontrada para el idioma"-[F:YYY]IDIOMA

              VUELTAS=VUELTAS+1
              DESCRIPCION=ctrans(VALORES(JJ),","," ")
              CODIDIOMA=[F:YYY]IDIOMA
              Gosub ADDREG
            Endif
            Raz ENCONTRADO
          Next

       Endif
      Next

      #[F:WITM]DES3AXX=DESCSPA
      Rewrite [F:WITM]
    Endif
  Next
  Filter [F:WITM]
  If GOK
    Commit
  Else
    Rollback
  Endif

End ERRORES

$ADDREG

Read [F:WAXX2]AXX0='ITMMASTER';'DES3AXX';CODIDIOMA;CODART;''
If fstat Then
  Raz [F:WAXX2]
  [F:WAXX2]CODFIC="ITMMASTER"
  [F:WAXX2]ZONE="DES3AXX"
  #[F:WAXX2]LANGUE=[WADI]A1
  [F:WAXX2]LANGUE=CODIDIOMA

  [F:WAXX2]IDENT1=CODART
  [F:WAXX2]TEXTE=DESCRIPCION
  If CODIDIOMA="SPA"
    DESCSPA=DESCSPA-DESCRIPCION
  Endif
  Write [F:WAXX2]
Else
  [F:WAXX2]TEXTE=[F:WAXX2]TEXTE-DESCRIPCION
  If CODIDIOMA="SPA"
    DESCSPA=DESCSPA-DESCRIPCION
  Endif
  Rewrite [F:WAXX2]
Endif
Filter [F:WAXX2]

If fstat
  GOK=0
  Call FSTA("WAXX2") From GLOCK
Endif
Filter [F:WADI]

Return

Subprog PVTARIFAS(ITMREF,BPCORD,BPAADD,FCY,SAU,QTY,CUR,GROPRI,NETPRI,DISCRGVAL)
Value Char ITMREF
Value Char BPCORD
Value Char BPAADD
Value Char FCY
Value Char SAU
Value Integer QTY
Value Char CUR
Variable Decimal GROPRI
Variable Decimal NETPRI
Variable Decimal DISCRGVAL



#--- Recherche du tarif
Local Char    VAT (GLONVAT) (0..2)
Local Integer NOL
Local Decimal WXAUTRE
Local Integer WSENS
Global Char GPNTITMREF(GLONITM)
Local Decimal FOCQTY (0..)
Local Char FOCUOM(250) (0..)
Local Char GFOCITMREF
Local Char GFOCUOM
Local Integer GFOCQTY

GPNTITMREF=ITMREF
GFOCITMREF=ITMREF
GFOCUOM=SAU
GFOQTY=1
GFOCQTY=QTY

If clalev([M:SPM0])
    If clalev([M:SPM0])=0 : Local Mask SPSIMUL0 [SPW0] : Endif
    [M:SPW0]=[M:SPM0]
Else
    Local Mask SPSIMUL0 [SPM0]
Endif

If clalev([M:SOH0])
    If clalev([M:SOW0])=0 : Local Mask SOH0 [SOW0] : Endif
    [M:SOW0]=[M:SOH0]
Else
    Local Mask SOH0 [SOH0]
Endif
If clalev([M:SOH1])
    If clalev([M:SOW1])=0 : Local Mask SOH1 [SOW1] : Endif
    [M:SOW1]=[M:SOH1]
Else
    Local Mask SOH1 [SOH1]
Endif
If clalev([M:SOH2])
    If clalev([M:SOW2])=0 : Local Mask SOH2 [SOW2] : Endif
    [M:SOW2]=[M:SOH2]
Else
    Local Mask SOH2 [SOH2]
Endif
If clalev([M:SOH3])
    If clalev([M:SOW3])=0 : Local Mask SOH3 [SOW3] : Endif
    [M:SOW3]=[M:SOH3]
Else
    Local Mask SOH3 [SOH3]
Endif
If clalev([M:SOH4])
    If clalev([M:SOW4])=0 : Local Mask SOH4 [SOW4] : Endif
    [M:SOW4]=[M:SOH4]
Else
    Local Mask SOH4 [SOH4]
Endif
Raz [M:SOH0] : Raz [M:SOH1] : Raz [M:SOH2] : Raz [M:SOH3] : Raz [M:SOH4]

Default Mask [SOH4]
Default Mask [SOH3]
Default Mask [SOH2]
Default Mask [SOH1]
Default Mask [SOH0]

If clalev([F:BPD])=0 : Local File BPDLVCUST  [BPD] : Endif
If clalev([F:SPK])=0 : Local File SPRICLINK  [SPK] : Endif
If clalev([F:TCU])=0 : Local File TABCUR  [TCU] : Endif
If clalev([F:PRS])=0 : Local File PRICSTRUCT   [PRS] : Endif
If clalev([F:CPY])=0 : Local File COMPANY   [CPY] : Endif


# --- Positionnement du flag affichage
MGEFFAC=1
# --- Chargement des ecrans SOH0, SOH1, SOH2, SOH3, SOH4

[SPM0]BPCORD=BPCORD
[SPM0]SALFCY=FCY
[SPM0]STOFCY=FCY
[SPM0]XITMREF=ITMREF
[SPM0]ORDDAT=date$
[SPM0]CUR=CUR
[SPM0]PRITYP=2
[SPM0]XQTY=1

[SPM0]XSAU=SAU

[M:SOH0]=[M:SPM0] : [M:SOH1]=[M:SPM0] : [M:SOH2]=[M:SPM0] : [M:SOH3]=[M:SPM0]
[M:SOH2]DEMDLVDAT    = [M:SOH0]ORDDAT
[M:SOH4]DDEMDLVDAT(0)= [M:SOH0]ORDDAT
[M:SOH4]ITMREF(0)    = [M:SPM0]XITMREF
[M:SOH4]DSTOFCY(0)   = [M:SPM0]STOFCY
[M:SOH4]DBPAADD(0)   = [M:SOH1]BPAADD
[M:SOH4]VACITM1(0)   = [F:ITM]VACITM(0)
[M:SOH4]VACITM2(0)   = [F:ITM]VACITM(1)
[M:SOH4]VACITM3(0)   = [F:ITM]VACITM(2)


#   Alimentation flag inter-site et inter-société

Call ALIBETCPY(2,[M:SPM0]SALFCY,[M:SPM0]BPCORD,GBIDC1,GBIDC2,GBIDC3,[M:SOH1]BETFCY,[M:SOH1]BETCPY) From TRTVENISOC

#Call ALITAXEV([M]VACBPR,[F:ITM]VACITM,VAT) From TRTX3
Call RECHVATCOD(1,1,[M:SOH0]BPCORD,[M:SOH4]ITMREF(0),"SOH4",0,VAT) From TRTX3
[M:SOH4]VAT1(0)=VAT(0) : [M:SOH4]VAT2(0)=VAT(1) :[M:SOH4]VAT3(0)=VAT(2) :
[M:SOH4]SAU(0)       = [M:SPM0]XSAU
[M:SOH4]QTY(0)       = [M:SPM0]XQTY

# --- Recherche du tarif (utilisation de ligne 1 de ecran commande SOH4)
NOL=nolign : nolign=1

Call TARIFCHGT(5) From TRTPRICE
Call RECH_TARIF(1,[M]ITMREF,0,[M]QTY,"SOH",[M]GROPRI(NOL)) From TRTVENTAR
nolign=NOL

Call CLCNETPRI([M:SOH4]QTY(0),[M:SOH0]CUR,0) From TRTVENPRI

# --- Transfert dans ecran SPM0

If [F:TCU]CUR<>[M:SPM0]CUR
  Read [TCU]TCU0=[M:SPM0]CUR
Endif

[M:SPM0]XGROPRI(0)      = arr([M:SOH4]GROPRI(0),10^-GDECPRI)
[M:SPM0]XNETPRI(0)      = arr([M:SOH4]NETPRI(0),10^-GDECPRI)
[M:SPM0]XNETPRI(1)      = arr([M:SOH4]NETPRI(0)*[M:SPM0]XQTY,[F:TCU]CURRND)

GROPRI=arr([M:SOH4]GROPRI(0),10^-GDECPRI)
NETPRI=arr([M:SOH4]NETPRI(0),10^-GDECPRI)
DISCRGVAL(0)=[M:SOH4]DISCRGVAL1
DISCRGVAL(1)=[M:SOH4]DISCRGVAL2
DISCRGVAL(2)=[M:SOH4]DISCRGVAL3


Affzo [SPM0]1-99

End

