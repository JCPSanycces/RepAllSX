$ACTION
Return

# Gestión de la máscara ZCAM1 (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZCAM1) 17/04/2017 21:13:20 (ADMIN)
######################################################################################
Subprog IB_NBLIG
Local Char TXT(60)
Raz GBOUT1,GBOUT2
TXT="Proyecto "+[M:ZCAM1]OPPNUM(nolign-1)
GBOUT1=TXT
If [M:ZCAM1]ZOBJETONUM(nolign-1)<>""
  Case [M:ZCAM1]ZOBJETOTIP(nolign-1)
  When 1
    TXT="Cita "
  When 2
    TXT="Tarea "
  When 3
    TXT="Llamada "
  Endcase
  TXT+=[M:ZCAM1]ZOBJETONUM(nolign-1)
  GBOUT2=TXT
Endif
End


######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZCAM0) 19/04/2017 08:52:45 (ADMIN)
######################################################################################
Subprog AM_ZCAMDES(VALEUR)
Variable Char    VALEUR()
VALEUR=toupper(VALEUR)
Local Char ID(GLONVCR)
ID=func SPEZCAMDUP.CAMPA_NOM(VALEUR)
If ID<>""
  Call ERREURT("Descripción ya se indicó en campaña nº "+ID, 1) From GESECRAN   #0-Informativo, 1-Error
  mkstat=2
  End
Endif
End


