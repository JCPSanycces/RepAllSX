#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
When  "AFFMASK"   :  Gosub AFFMASK
When  "FERME"     :  Gosub FERME

When  "SETBOUT"   :  Gosub SETBOUT
When  "EXEBOUT"   :  Gosub EXEBOUT

#Acciones control flujo CREACION     RAZCRE + VERIF_CRE + INICRE + CREATION + APRES_CRE + AB_CREATION
When  "RAZCRE"    :  Gosub RAZCRE
When  "VERIF_CRE" :  Gosub VERIFCRE_MOD
When  "INICRE"    :  Gosub INICRE
When  "APRES_CRE" :  Gosub APRESCRE_MOD

#Acciones control flujo MODIFICACION   LIENS + STYLE + AVANT_MOD + VERIF_MOD + AVANT_MODFIC + INIMOD + MODIF + APRES_MOD + FIN_MOD + AB_MODIF
When  "LIENS"     :  Gosub LIENS
When  "VERIF_MOD" :  Gosub VERIFCRE_MOD
When  "APRES_MOD" :  Gosub APRESCRE_MOD

When  "DEGRISE"   :  Gosub DEGRISE

When  "AB2_NBLIG" :  Gosub AB2_NBLIG
Endcase
Return



$AB2_NBLIG
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1 (GLONVCR)
Local Char     WCLE2 (GLONVCR)
Case [M:ZCAM1]ZOBJETOTIP(nolign-1)
When 1
  WOBJET="BAP"
When 2
  WOBJET="TSK"
When 3
  WOBJET="CLL"
Endcase
WCLE1 =[M:ZCAM1]ZOBJETONUM(nolign-1)
WCLE2 =""
Return


$AFFMASK
Chgfmt [M:ZCAM0]ZNADA    With "-"
# Guardo valores
Global Char GFLDCHR(80)(5)
Global Decimal GFLDNUM(5)
GFLDCHR(0) = func ZCOMUN.DATA_BASE_TIPO()
GFLDCHR(1) = "" # Alta, baja, modificacion fila rejilla   SPEZCAMDUP.src
GFLDCHR(2) = "" # Guardo el contador para PROYECTOS       SPEZCAMDUP.src
# Tope de filas en rejilla
GFLDNUM(0) = func ZCOMUN.FILAS_GRID("ZCAM1","NBLIG")
#GFLDNUM(1) = func ZCOMUN.FILAS_GRID("ZCAMDUP","NPROY")
#GFLDNUM(2) = func ZCOMUN.FILAS_GRID("ZCAMDUP","NACCI")

Return

$FERME
If GFONCTION1="GESZCAM"
  Kill GFLDCHR,GFLDNUM
Endif
Return

$DESABILITAR
#Imposible modificar
Grizo [M:ZCAM0]ZCAMID
Return

$DEGRISE
Gosub DESABILITAR
Return

$RAZCRE
Raz GFLDNUM(1)
Gosub DESABILITAR
# gosub siguiente
Return

$LIENS
Gosub DESABILITAR
Call LLENA_REJILLA
Return

$APRESCRE_MOD
#Refrescar registro en pantalla
Gosub RELIT From GOBJSUB
Return

$VERIFCRE_MOD
If [M:ZCAM0]ZCAMFECFIN<[M:ZCAM0]ZCAMFECINI
  Call ERREURT("Fecha final nueva campaña debe ser posterior al "+format$(GFMD,[M:ZCAM0]ZCAMFECINI), 1) From GESECRAN   #0-Informativo, 1-Error
  OK = 0
  zonsui = "[M:ZCAM0]ZCAMFECFIN"
  Return
Endif
If GREP="C" or GREP="D"
  [M:ZCAM0]ZCAMID=func SIGUIENTE_CAMPA
  Affzo [M:ZCAM0]ZCAMID
Endif
Return

$INICRE
[F:ZCAM]ZCAMID=[M:ZCAM0]ZCAMID
Return

$SETBOUT
If (GREP="C" or GREP="D" or GREP="M") or func RGTO_BLOQUEADO or [M:ZCAM0]ZCAMID=""
  Call VIREBOUT(CHAINE,"b") From GOBJET
Endif
Return

$EXEBOUT
Case BOUT
When "b"
#  Infbox "hola desde $EXEBOUT"
Endcase
Return


Funprog SIGUIENTE_CAMPA
# Variables para sacar siguiente nº del contador
Local Integer STAT
Local Char SIGUIENTE(GLONVCR)
# Sacar siguiente nº asiento
Call NUMERO ("ZCAM", [M:ZCAM0]ZFCY, [M:ZCAM0]ZCAMFECINI, "" , SIGUIENTE, STAT) From SUBANM
If STAT
  TMP="No se pudo obtener siguiente nº para contador << ZCAM >>\Se asumirá siguiente valor numérico al mayor existente"
  Call ERREURT(TMP, 1) From GESECRAN   #0-Informativo, 1-Error
  Local Char TXT(255)(10)
  Local Integer ULT
  TXT(0)="select max(ZCAMID_0) from ZCAMPA"
  For (Char FULT(GLONVCR)) From GFLDCHR(0) Sql TXT As [MYT]
    ULT=val([MYT]FULT)
  Next
  SIGUIENTE=num$(ULT+1)# format$("N0:20",ULT+1)
Endif
End SIGUIENTE

Funprog RGTO_BLOQUEADO
If !clalev([F:WALK])      :  Local File APLLCK   [F:WALK]  : Endif
Filter [F:WALK] Where LCKSYM='ZCAM~'+[M:ZCAM0]ZCAMID
For [F:WALK]
  If [F:WALK]LCKPID<>adxuid(1)#adxpid
#    Infbox "Rgto Bloqueado   adxuid(1)="+num$(adxuid(1)) + "   adxuid(2)="+num$(adxuid(2))
#    End 1
  Endif
Next
End 0


Subprog LLENA_REJILLA
Local Integer F
Local Char WMSK(10)
WMSK="ZCAM1"
#Vaciar rejilla
Raz [M:ZCAM1]NBLIG
Effzo [M:ZCAM1]10
#
If !clalev([F:WOPP])      :  Local File OPPOR   [F:WOPP]  : Endif
Gosub MONTAR_SQL
For (Date FPJTFEC,Char FPJTNUM(GLONVCR),Date FFEC,Char FHORI(10),Char FHORF(10),Char FREP(GLONBPR),Integer FEFE,Char FACC(GLONVCR),Integer FTIP) From GFLDCHR(0) Sql TXT As [MYT]
  F=[M:ZCAM1]NBLIG
  Gosub DAT_CAMPA
  Gosub DAT_PROYE
  Gosub DAT_ACCIO

  If [M:ZCAM1]NBLIG+1>=GFLDNUM(0)
    MSG="FALTAN DATOS\Alcanzado máximo de " + num$(GFLDNUM(0)+1) + " filas para mostrar resumen\.\Avise para que se lo aumenten"
    Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
    Break
  Else
    [M:ZCAM1]NBLIG+=1
  Endif
Next
End


$DAT_ACCIO
#Infbox "depurar   $DAT_ACCIO"
Assign "[M:"+WMSK+"]APTDAT(F)"     With [MYT]FFEC
Assign "[M:"+WMSK+"]APTHOU(F)"     With [MYT]FHORI
Assign "[M:"+WMSK+"]APTHOUEND(F)"  With [MYT]FHORF
Assign "[M:"+WMSK+"]ZOBJETOTIP(F)" With [MYT]FTIP
Assign "[M:"+WMSK+"]ZOBJETONUM(F)" With [MYT]FACC
Assign "[M:"+WMSK+"]APTREPNUM(F)"  With [MYT]FREP
#If evalue("dim([M:"+WMSK+"]APTDON(F))")>0
Assign "[M:"+WMSK+"]APTDON(F)"     With [MYT]FEFE
#Endif
#[M:ZCAM1]APTDAT(F)    =[MYT]FFEC
#[M:ZCAM1]APTHOU(F)    =[MYT]FHORI
#[M:ZCAM1]APTHOUEND(F) =[MYT]FHORF
#[M:ZCAM1]ZOBJETOTIP(F)=[MYT]FTIP
#[M:ZCAM1]ZOBJETONUM(F)=[MYT]FACC
#[M:ZCAM1]APTDON(F)    =[MYT]FEFE
#[M:ZCAM1]APTREPNUM(F) =[MYT]FREP
Return

$DAT_CAMPA
[M:ZCAM1]ZDCAMID(F)    =[M:ZCAM0]ZCAMID
[M:ZCAM1]ZDCAMDES(F)   =[M:ZCAM0]ZCAMDES
[M:ZCAM1]ZDCAMFECINI(F)=[M:ZCAM0]ZCAMFECINI
[M:ZCAM1]ZDCAMFECFIN(F)=[M:ZCAM0]ZCAMFECFIN
[M:ZCAM1]ZDSTAT(F)     =[M:ZCAM0]ZSTAT
Return

$DAT_PROYE
Read [F:WOPP]OPP0=[MYT]FPJTNUM
[M:ZCAM1]OPPTYP(F)    =[F:WOPP]OPPTYP
[M:ZCAM1]OPPNUM(F)    =[F:WOPP]OPPNUM
[M:ZCAM1]OPPDES(F)    =[F:WOPP]OPPDES
[M:ZCAM1]OPPDATOPN(F) =[F:WOPP]OPPDATOPN
[M:ZCAM1]OPPCMP(F)    =[F:WOPP]OPPCMP
Return

$MONTAR_SQL
#######################################
# Es llamado desde   SUBZCAMDUP.src   #
#######################################
Local Char TXT(250)(20)
Raz TXT
TXT(0) ="select p.OPPDATOPN_0,p.OPPNUM_0,c.APTDAT_0 as fecha,c.APTHOU_0 as horini,c.APTHOUEND_0 as horfin,c.APTREPNUM_0 as rep,c.APTDON_0 as efectuado,c.APTNUM_0 as num,1 as typ "
TXT(1) ="From OPPOR p inner join BAPPOINT c on p.OPPNUM_0=c.APTPJT_0 "
TXT(2) ="Where p.ZCAMID_0='"+[M:ZCAM0]ZCAMID+"' "
TXT(3) ="union "
TXT(4) ="select p.OPPDATOPN_0,p.OPPNUM_0,c.TSKSTR_0 as fecha,''     as horini,''        as horfin,c.TSKREP_0    as rep,c.TSKDON_0 as efectuado,c.TSKNUM_0 as num,2 as typ "
TXT(5) ="from OPPOR p inner join TASK c on p.OPPNUM_0=c.TSKPJT_0 "
TXT(6) ="Where p.ZCAMID_0='"+[M:ZCAM0]ZCAMID+"' "
TXT(7) ="union "
TXT(8) ="select p.OPPDATOPN_0,p.OPPNUM_0,c.CLLDAT_0 as fecha,c.CLLHOU_0 as horini,''        as horfin,c.CLLREP_0    as rep,c.CLLDON_0 as efectuado,c.CLLNUM_0 as num,3 as typ "
TXT(9) ="From OPPOR p inner join PHONECALL c on p.OPPNUM_0=c.CLLOPP_0 "
TXT(10)="Where p.ZCAMID_0='"+[M:ZCAM0]ZCAMID+"' "
TXT(11)="union "
TXT(12)="select p.OPPDATOPN_0,p.OPPNUM_0,c.CLLDAT_0 as fecha,c.CLLHOU_0 as horini,''        as horfin,c.CLLREP_0    as rep,c.CLLDON_0 as efectuado,c.CLLNUM_0 as num,0 as typ "
TXT(13)="from OPPOR p "
TXT(14)="left join PHONECALL c on p.OPPNUM_0=c.CLLOPP_0 "
TXT(15)="left join TASK      t on p.OPPNUM_0=t.TSKPJT_0 "
TXT(16)="left join BAPPOINT  b on p.OPPNUM_0=b.APTPJT_0 "
TXT(17)="where ZCAMID_0='"+[M:ZCAM0]ZCAMID+"' and c.CLLDAT_0 is null and t.TSKSTR_0 is null and b.APTDAT_0 is null "
TXT(18)="order by fecha,horini,OPPDATOPN_0,OPPNUM_0"
Return

