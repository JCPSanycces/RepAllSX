#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
When "DEBUT"     :  Gosub DEBUT

When "AVANT_OK"  :  Gosub AVANT_OK
When "OK"        :  Gosub OK

When "AB1_NACCI" :  Gosub AB1_NACCI
When Default
Endcase
Return


$AB1_NACCI
Local Char     WOBJET(GLONAOB)
Local Char     WCLE1 (GLONVCR)
Local Char     WCLE2 (GLONVCR)
Case [M:ZCAMDUP]NAOBJTIP(nolign-1)
When 1
  WOBJET="BAP"
When 2
  WOBJET="TSK"
When 3
  WOBJET="CLL"
Endcase
WCLE1 =[M:ZCAMDUP]NAOBJNUM(nolign-1)
WCLE2 =""
Return




$DEBUT
#Chgfmt [M:ZCAMDUP]ZNADA    With "-"
# Guardo valores en variables definidas en    SUBZCAM.src
# Tope de filas en rejilla
GFLDNUM(1) = func ZCOMUN.FILAS_GRID("ZCAMDUP","NPROY")
GFLDNUM(2) = func ZCOMUN.FILAS_GRID("ZCAMDUP","NACCI")
GFLDCHR(2) = "" # Guardo el contador para PROYECTOS
#
Raz [M:ZCAMDUP]
Call MOSTRAR_DATOS_CAMPANA
Affzo [M:ZCAMDUP]5
Call MOSTRAR_DATOS_PROYECTOS
Affzo [M:ZCAMDUP]10
Call MOSTRAR_DATOS_ACCIONES
Affzo [M:ZCAMDUP]15
[M:ZCAMDUP]ZETAPAS=2
Affzo [M:ZCAMDUP]ZETAPAS
[M:ZCAMDUP]ZCOMPE=2
Affzo [M:ZCAMDUP]ZCOMPE
Return

$OK
#Infbox "En desarrollo     (JLPR 19/04/17 08:00"
#If GUSER<>"ADMIN" Return Endif
Call ADD
Return

$AVANT_OK
If [M:ZCAMDUP]NPROY<1 or [M:ZCAMDUP]NACCI<1
    FOK=0
    GMESSAGE="Deben haber    proyectos   y   acciones comerciales"
    GERR=1     # No ejecutará ACCION  "OK"
    FIN=0
    Return
Endif

Raz GFLDCHR(2)
For (Char FCONT(GLONANM))  From GFLDCHR(0) Sql "select CODNUM_1 from TABCOUAFF where MODULE_0=13" As [MYT]
  GFLDCHR(2)=[MYT]FCONT
  Break
Next
If GFLDCHR(2) = ""
    FOK=0
    GMESSAGE="No se ha asignado contador a PROYECTOS"
    GERR=1     # No ejecutará ACCION  "OK"
    FIN=0
    Return
Endif

Local Integer YN
YN=1
Call OUINON("Está seguro de proceder a la duplicacion de esta campaña", YN) From GESECRAN
If YN=1
    FOK=0
    GMESSAGE=""#"Bobinas asignadas > Producidas"
    GERR=1     # No ejecutará ACCION  "OK"
    FIN=0
    Return
Endif
Return

Subprog MOSTRAR_DATOS_CAMPANA
[M:ZCAMDUP]ZDESORI   =[M:ZCAM0]ZCAMDES
[M:ZCAMDUP]ZDES      =[M:ZCAM0]ZCAMDES+" "+num$(year(date$))
[M:ZCAMDUP]ZFECINIORI=[M:ZCAM0]ZCAMFECINI
[M:ZCAMDUP]ZFECFINORI=[M:ZCAM0]ZCAMFECFIN
End

Subprog MOSTRAR_DATOS_PROYECTOS
Local Integer F
If !clalev([F:WOPP])      :  Local File OPPOR   [F:WOPP]  : Endif
Filter [F:WOPP] Where ZCAMID=[M:ZCAM0]ZCAMID Order By OPPDATOPN;OPPNUM
Call VACIAR_PROY
For [F:WOPP]
  F=[M:ZCAMDUP]NPROY
  Gosub DAT_PROY

  If [M:ZCAMDUP]NPROY+1>=GFLDNUM(1)
    MSG="FALTAN DATOS\Alcanzado máximo de " + num$(GFLDNUM(1)+1) + " filas para mostrar proyectos\.\Avise para que se lo aumenten"
    Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
    Call VACIAR_PROY
    Break
  Else
    [M:ZCAMDUP]NPROY+=1
  Endif
Next
End

$DAT_PROY
[M:ZCAMDUP]NPOPPNUM(F)   =[F:WOPP]OPPNUM
[M:ZCAMDUP]NOOPPDES(F)   =[F:WOPP]OPPDES
[M:ZCAMDUP]NPSALFCY(F)   =[F:WOPP]SALFCY
[M:ZCAMDUP]NPOPPTYP(F)   =[F:WOPP]OPPTYP
[M:ZCAMDUP]NPFECINIORI(F)=[F:WOPP]OPPDATOPN
[M:ZCAMDUP]NPFECFINORI(F)=[F:WOPP]OPPCDA
[M:ZCAMDUP]NPOPPDATOPN(F)=[0/0/0]
[M:ZCAMDUP]NPOPPCDA(F)   =[0/0/0]
[M:ZCAMDUP]NPOPPCMP(F)   =[F:WOPP]OPPCMP
[M:ZCAMDUP]NPOPPMCN(F)   =[F:WOPP]OPPMCN
[M:ZCAMDUP]NPOPPREP(F)   =[F:WOPP]OPPREP
[M:ZCAMDUP]NPCUR(F)      =[F:WOPP]CUR
[M:ZCAMDUP]NPOPPAMT(F)   =[F:WOPP]OPPAMT
Return

Subprog MOSTRAR_DATOS_ACCIONES
Local Integer F
Local Char WMSK(10)
WMSK="ZCAMDUP"
Gosub MONTAR_SQL From SUBZCAM
For (Date FPJTFEC,Char FPJTNUM(GLONVCR),Date FFEC,Char FHORI(10),Char FHORF(10),Char FREP(GLONBPR),Integer FEFE,Char FACC(GLONVCR),Integer FTIP) From GFLDCHR(0) Sql TXT As [MYT]
  If [MYT]FTIP>0
    F=[M:ZCAMDUP]NACCI
    Assign "[M:"+WMSK+"]NAOPPNUM(F)"   With [MYT]FPJTNUM
    Assign "[M:"+WMSK+"]NAFECORI(F)"   With [MYT]FFEC
    Assign "[M:"+WMSK+"]NAFECHA(F)"    With [0/0/0]
    Assign "[M:"+WMSK+"]NAHORAINI(F)"  With [MYT]FHORI
    Assign "[M:"+WMSK+"]NAHORAFIN(F)"  With [MYT]FHORF
    Assign "[M:"+WMSK+"]NAOBJTIP(F)"   With [MYT]FTIP
    Assign "[M:"+WMSK+"]NAOBJNUM(F)"   With [MYT]FACC
    Assign "[M:"+WMSK+"]NAREP(F)"      With [MYT]FREP
    #If evalue("dim([M:"+WMSK+"]APTDON(F))")>0   endif

    If [M:ZCAMDUP]NACCI+1>=GFLDNUM(2)
      MSG="FALTAN DATOS\Alcanzado máximo de " + num$(GFLDNUM(2)+1) + " filas para mostrar acciones comerciales\.\Avise para que se lo aumenten"
      Call ERREURT(MSG, 1) From GESECRAN   #0-Informativo, 1-Error
      Break
    Else
      [M:ZCAMDUP]NACCI+=1
    Endif
  Endif
Next
End

Subprog VACIAR_PROY
Raz [M:ZCAMDUP]NPROY
Effzo [M:ZCAMDUP]10
End

Subprog VACIAR_ACCI
Raz [M:ZCAMDUP]NACCI
Effzo [M:ZCAMDUP]15
End

Subprog ADD
#Infbox "Depurar"
Gosub DEF_VARIABLES
Gosub ADD_CAMPA
Gosub ADD_PROYE
Gosub ADD_ACCIO
If not ZWOK
  Read [F:WZCAM]ZCAM0=NUEVA_CAMP
  If fstat=0 Delete [F:WZCAM] Endif
  MSG="BORRADA campaña nueva nº "+NUEVA_CAMP+"     fstat="+num$(fstat)
  Call ECR_TRACE(MSG,0) From GESECRAN   #0-Informativo, 1-Error, -1-Aviso
Endif
#Cerrar y mostrar traza
Call FERME_TRACE From LECFIC
Call LEC_TRACE   From LECFIC
End


$ADD_CAMPA
If not ZWOK Return Endif
Local Char NUEVA_CAMP(GLONVCR)
NUEVA_CAMP=func SUBZCAM.SIGUIENTE_CAMPA
If !clalev([F:WZCAM])      :  Local File ZCAMPA   [F:WZCAM]  : Endif
Raz [F:WZCAM]
[F:WZCAM]ZCAMID    =NUEVA_CAMP
[F:WZCAM]ZCAMDES   =[M:ZCAMDUP]ZDES
[F:WZCAM]ZCAMFECINI=[M:ZCAMDUP]ZFECINI
[F:WZCAM]ZCAMFECFIN=[M:ZCAMDUP]ZFECFIN
[F:WZCAM]ZFCY      =[M:ZCAM0]ZFCY
[F:WZCAM]ZSTAT     =2
[F:WZCAM]ZCAMIDORI =[M:ZCAM0]ZCAMID
Write  [F:WZCAM]
If fstat<>0
  ZWOK=0
  MSG="Error al AÑADIR campaña nueva nº "+NUEVA_CAMP+"     fstat="+num$(fstat)
  Call ECR_TRACE(MSG,1) From GESECRAN   #0-Informativo, 1-Error, -1-Aviso
  Call ERREURT(MSG, 1)  From GESECRAN   #0-Informativo, 1-Error
Else
  MSG="ANADIDA campaña nueva nº "+NUEVA_CAMP
  Call ECR_TRACE(MSG,0) From GESECRAN   #0-Informativo, 1-Error, -1-Aviso
Endif
Return

$MANUAL_SI
Local Integer RV,NV,RVVAL(10)
Local Char    RVCPY(GLONCPY)(10),RVLEG(5)(10)
If !clalev([F:WTCA])    :  Local File TABCOUAFF [F:WTCA]  : Endif
#TCA0=MODULE+LEG+CPY
Raz RVVAL,RVLEG,RVCPY,RV
Filter [F:WTCA] Where MODULE=13
For [F:WTCA]
  RVLEG(RV)=[F:WTCA]LEG
  RVCPY(RV)=[F:WTCA]CPY
  RVVAL(RV)=[F:WTCA]MANCOU(1)
  If [F:WTCA]MANCOU(1)<>2
    [F:WTCA]MANCOU(1)=2
    Rewrite [F:WTCA]
  Endif
  RV+=1
Next
Return

$MANUAL_ANTERIOR
#TCA0=MODULE+LEG+CPY
For NV=0 To RV-1
  Read [F:WTCA]TCA0=13;RVLEG(NV);RVCPY(NV)
  If [F:WTCA]MANCOU(1)<>RVVAL(NV)
    [F:WTCA]MANCOU(1)=RVVAL(NV)
    Rewrite [F:WTCA]
  Endif
Next
Return

$ADD_PROYE
If not ZWOK Return Endif
Local Char PROY1(GLONVCR)([M:ZCAMDUP]NPROY+1) # Guardo el nuevo nº de proyecto asignado
# Variables para sacar siguiente nº del con2tador
Local Integer STAT
Local Char NUEVO_PROY(GLONVCR)
#
If !clalev([F:WOPP])    :  Local File OPPOR     [F:WOPP]  : Endif
WNOM="ZOPP"    #   Modelo de importación
Gosub ABRIR_FIC
If not ZWOK Return Endif
# Comenzar a generar fichero para importacion proyectos
For F=0 To [M:ZCAMDUP]NPROY-1
  # Sacar siguiente nº proyecto
  Call NUMERO (GFLDCHR(2), [M:ZCAMDUP]NPSALFCY(F), [M:ZCAMDUP]ZFECINI, "" , NUEVO_PROY, STAT) From SUBANM
  If STAT
    MSG="No se pudo obtener siguiente nº para contador << "+GFLDCHR(2)+" >>"
    Call ECR_TRACE(MSG, 1) From GESECRAN   #0-Informativo, 1-Error, -1-Aviso
    Call ERREURT(MSG, 1)   From GESECRAN   #0-Informativo, 1-Error
    ZWOK=0
    Break
  Endif
  #
  Read [F:WOPP]OPP0=[M:ZCAMDUP]NPOPPNUM(F)
  If fstat=0
    MSG="Proyecto nuevo añadido "+NUEVO_PROY+" partiendo del "+[M:ZCAMDUP]NPOPPNUM(F)
    Call ECR_TRACE(MSG,0) From GESECRAN   #0-Informativo, 1-Error, -1-Aviso
    Gosub GRABAR_PROY
  Else
    MSG="Se omitió duplicacion proyecto nº "+[M:ZCAMDUP]NPOPPNUM(F)+", por no existir     fstat="+num$(fstat)
    Call ECR_TRACE(MSG,-1) From GESECRAN   #0-Informativo, 1-Error, -1-Aviso
  Endif
Next
#Pongo registro a MANUAL, para que me respete el nº de proyecto que paso en modelo importacion
Gosub MANUAL_SI
Gosub IMPORTAR
Gosub MANUAL_ANTERIOR
Return

$ADD_ACCIO
If not ZWOK Return Endif
Gosub ADD_ACCIO_TSK
Gosub ADD_ACCIO_CLL
Gosub ADD_ACCIO_BAP
Return

$ADD_ACCIO_TSK
If not ZWOK Return Endif
WNOM="ZTSK"    #   Modelo de importación
Raz A
# Comenzar a generar fichero para importacion proyectos
For F=0 To [M:ZCAMDUP]NACCI-1
  If [M:ZCAMDUP]NAOBJTIP(F)=2
    P=func PROYECTO_ACCION([M:ZCAMDUP]NAOPPNUM(F))
    If P>=0
      If A=0
        A=1
        Gosub ABRIR_FIC
        If not ZWOK Break Endif
      Endif
      NUM=[M:ZCAMDUP]NAOBJNUM(F)
      PROYECT_P=PROY1(P)
      FECHA_P  =[M:ZCAMDUP]NAFECHA(F)
      REPRESE_P=[M:ZCAMDUP]NAREP(F)
      TERCERO_P=[M:ZCAMDUP]NPOPPCMP(P)
      Gosub LEER_TAREA From SPEZPER
      If NUM="" or fstat<>0
        Raz INTERLO_P,CONTACT_P,[F:WTSK]
        FCY_P    =[M:ZCAMDUP]NPSALFCY(P)
      Else
        INTERLO_P=[F:WTSK]TSKCCN
        CONTACT_P=[F:WTSK]TSKCOR
        FCY_P    =[F:WTSK]SALFCY
      Endif
      Gosub EXPORT0_TSK From SUBZPERA
      Call ECR_TRACE("Tarea añadida al proyecto "+PROY1(P)+"  Fecha "+format$(GFMD,FECHA_P),0) From GESECRAN
    Else
      Call ECR_TRACE("Tarea NO añadida por no encontrarse proyecto original "+[M:ZCAMDUP]NAOPPNUM(F)+" en rejilla  ",0) From GESECRAN
    Endif
  Endif
Next
If A>0 Gosub IMPORTAR Endif
Return

$ADD_ACCIO_CLL
If not ZWOK Return Endif
WNOM="ZCLL"    #   Modelo de importación
Raz A
# Comenzar a generar fichero para importacion proyectos
For F=0 To [M:ZCAMDUP]NACCI-1
  If [M:ZCAMDUP]NAOBJTIP(F)=3
    P=func PROYECTO_ACCION([M:ZCAMDUP]NAOPPNUM(F))
    If P>=0
      If A=0
        A=1
        Gosub ABRIR_FIC
        If not ZWOK Break Endif
      Endif
      NUM=[M:ZCAMDUP]NAOBJNUM(F)
      PROYECT_P=PROY1(P)
      FECHA_P  =[M:ZCAMDUP]NAFECHA(F)
      HORAI_P  =[M:ZCAMDUP]NAHORAINI(F)
      REPRESE_P=[M:ZCAMDUP]NAREP(F)
      TERCERO_P=[M:ZCAMDUP]NPOPPCMP(P)
      Gosub LEER_LLAMADA From SPEZPER
      If NUM="" or fstat<>0
        Raz INTERLO_P,CONTACT_P,[F:WCLL]
        FCY_P    =[M:ZCAMDUP]NPSALFCY(P)
      Else
        INTERLO_P=[F:WCLL]CLLCCN
        CONTACT_P=[F:WCLL]CLLCOR
        FCY_P    =[F:WCLL]SALFCY
      Endif
      Gosub EXPORT0_CLL From SUBZPERA
      Call ECR_TRACE("Llamada añadida al proyecto "+PROY1(P)+"  Fecha "+format$(GFMD,FECHA_P)+"  Hora "+HORAI_P,0) From GESECRAN
    Else
      Call ECR_TRACE("Llamada NO añadida por no encontrarse proyecto original "+[M:ZCAMDUP]NAOPPNUM(F)+" en rejilla  ",0) From GESECRAN
    Endif
  Endif
Next
If A>0 Gosub IMPORTAR Endif
Return

$ADD_ACCIO_BAP
If not ZWOK Return Endif
WNOM="ZBAP"    #   Modelo de importación
Raz A
# Comenzar a generar fichero para importacion proyectos
For F=0 To [M:ZCAMDUP]NACCI-1
  If [M:ZCAMDUP]NAOBJTIP(F)=1
    P=func PROYECTO_ACCION([M:ZCAMDUP]NAOPPNUM(F))
    If P>=0
      If A=0
        A=1
        Gosub ABRIR_FIC
        If not ZWOK Break Endif
      Endif
      NUM=[M:ZCAMDUP]NAOBJNUM(F)
      PROYECT_P=PROY1(P)
      FECHA_P  =[M:ZCAMDUP]NAFECHA(F)
      HORAI_P  =[M:ZCAMDUP]NAHORAINI(F)
      HORAF_P  =[M:ZCAMDUP]NAHORAFIN(F)
      REPRESE_P=[M:ZCAMDUP]NAREP(F)
      TERCERO_P=[M:ZCAMDUP]NPOPPCMP(P)
      Gosub LEER_CITA From SPEZPER
      If NUM="" or fstat<>0
        Raz INTERLO_P,CONTACT_P,[F:WBAP]
        FCY_P    =[M:ZCAMDUP]NPSALFCY(P)
      Else
        FCY_P    =[F:WBAP]SALFCY
      Endif
      Gosub EXPORT0_BAP From SUBZPERA
      Call ECR_TRACE("Cita añadida al proyecto "+PROY1(P)+"  Fecha "+format$(GFMD,FECHA_P)+" Hora "+HORAI_P,0) From GESECRAN
    Else
      Call ECR_TRACE("Cita NO añadida por no encontrarse proyecto original "+[M:ZCAMDUP]NAOPPNUM(F)+" en rejilla  ",0) From GESECRAN
    Endif
  Endif
Next
If A>0 Gosub IMPORTAR Endif
Return

$GRABAR_PROY
PROY1(F)=NUEVO_PROY # Para luego asignar nuevo nº proyecto a las acciones comerciales
PROYECT_P=NUEVO_PROY
ZCAMID_P =NUEVA_CAMP
FECHA_P  =[M:ZCAMDUP]NPOPPDATOPN(F)
FECHA_F  =[M:ZCAMDUP]NPOPPCDA(F)
REPRESE_P=[M:ZCAMDUP]NPOPPREP(F)
TERCERO_P=[M:ZCAMDUP]NPOPPCMP(F)
INTERLO_P=[M:ZCAMDUP]NPOPPMCN(F)
IMPORTE_P=[M:ZCAMDUP]NPOPPAMT(F)
CUR_P    =[M:ZCAMDUP]NPCUR(F)
Gosub EXPORT0_OPP From SUBZPERA
Return

$ABRIR_FIC
#Lectura modelo importacion, para formato fecha
Read [F:AOE]AOE0=WNOM
If fstat<>0
  Call ECR_TRACE("No existe modelo importacion "+WNOM+"   fstat="+num$(fstat),1)             From GESECRAN
  ZWOK=0
  Return
Endif
# Comprobar directorio y crearlo en caso de que no exista
WDIR="ZIMPEXP\IMPOR"
TMP=filpath("","","","","",adxmac(0)) +"\" + WDIR
If filinfo(TMP,7)<0
  Local Integer STAT
  Call SYSTEME(adxmac(0),'ae_mkdir'-'"' + TMP + '"',"",STAT) From ORDSYS
Endif
# Abrir fichero a importar
#WNOM="ZCLL"    #   Modelo de importación
WJOB = num$(time)
WXML = WNOM+"_"+format$("D:YYYYMMDD",date$)+"_"+WJOB
WOUT = filpath(WDIR,WXML,"txt")
Openo WOUT,0 Using [AEXP]
SIFX=adxifs : SIRS=adxirs : SIUM=adxium
Case [F:AOE]TYPFIL
When 1 # Sep.Campo
When 2 # Sep.Registro
  Iomode adxifs [F:AOE]SEPFLD Using [AEXP]
#  Iomode adxirs [F:AOE]SEPREC Using [AEXP]
  Iomode adxirs chr$(13)+chr$(10) Using [AEXP]
  Iomode adxium 50 Using [AEXP]
Endcase
Return

$IMPORTAR
Openo Using [AEXP]   #Cerramos el fichero XML generado
adxifs=SIFX : adxirs=SIRS : adxium=SIUM # Restauro valores
# << Importar >>
Call IMPORTSIL(WNOM,WOUT) From GIMPOBJ
# De esta manera comprobando si existe el fichero <<.err>> sabemos si la traza ha dado errores.
WFICH = filpath("ZIMPEXP\IMPOR",WXML,"XML.err")
If filinfo(WFICH,0) > 0 Then
  MSG= "Revise la traza.\Hubo problemas en la importacion del fichero\"+WXML
  Call ERREURT(MSG,1)   From GESECRAN   #0-Informativo, 1-Error
  Call ECR_TRACE(MSG,1) From GESECRAN
  ZWOK=0
Endif
Return

$DEF_VARIABLES
Local Char MSG(255),NUM(GLONVCR),SIFS(20),SIRS(20)
Local Integer ZWOK,F,P,A,SIUM
# Variables para XML
Local Char WNOM(20),WJOB(10),WXML(250),WOUT(250),WDIR(250),WFICH(250)
# Variables para generar modelo importacion
Local Char TERCERO_P(GLONBPR),INTERLO_P(GLONAIN),CONTACT_P(GLONCOR),PROYECT_P(GLONOPP),REPRESE_P(GLONREP)
Local Char PERIODO_P(GLONVCR),HORAI_P(6),HORAF_P(6),FCY_P(GLONFCY)
Local Date FECHA_P
# Variables adicionales para importacion PROYECTOS
Local Decimal IMPORTE_P
Local Char CUR_P(GLONCUR),ZCAMID_P(GLONVCR)
Local Integer DIAS_P
Local Date FECHA_F
# << Abrir >>
# Traza
Call OUVRE_TRACE("Duplicacion Campaña")  From LECFIC
Call ECR_TRACE(" ",0)             From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE("Duplicacion Campaña "+[M:ZCAM0]ZCAMID+"    "+ format$(GFMD,date$) + " " + time$+"   Usuario "+GUSER,0) From GESECRAN
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
Call ECR_TRACE(" ",0)             From GESECRAN
#
DIAS_P=[M:ZCAMDUP]ZFECINI - [M:ZCAMDUP]ZFECINIORI
ZWOK=1
If !clalev([F:AOE])       :  Local File  AOBJEXT    [F:AOE]   : Endif
Return

Funprog PROYECTO_ACCION(PROY)
Value Char PROY
Local Integer F,P
P=-1
For F=0 To [M:ZCAMDUP]NPROY-1
  If [M:ZCAMDUP]NPOPPNUM(F)=PROY
    P=F
    Break
  Endif
Next
End P

