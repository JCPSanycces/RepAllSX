#<AdxTL>@(#)0.0.0.0 $Revision$
#Proceso de importación de clientes X3-->Sage100 con asientos contables
$ACTION
#Infbox ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub TRT_INI
  When "EXEC"           : Gosub EXEC_ACCL
  When "TERMINE"        : Gosub TERMINE_ACCL
  When "INIT"           : Gosub INIT_DIA_ACCL
  When "OK"             : Gosub OK_ACCL
  When "END"            : Gosub END_ACCL
Endcase

Return

$TRT_INI
Return


$EXEC_ACCL
  Call ECR_TRACE("Proceso de importación de clientes X3-->Sage100 iniciado",0) From GESECRAN
  System RESULT=chr$(34) + "C:\Program Files (x86)\Azeta\Importacion clientes Sage100\ExImCli.exe" + chr$(34)
  Call ECR_TRACE("Proceso de importación de clientes X3-->Sage100 finalizado",0) From GESECRAN
  End

Return

$TERMINE_ACCL
Return

$INIT_DIA_ACCL
Return

$OK_ACCL
Return

$END_ACCL
Return

