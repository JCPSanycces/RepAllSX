#####################################################
#Se modifica la generación de la analítica pasándole los campos ZCENX3 y ZDETX3 de la tabla ZACTL100

$ACTION
Case ACTION

  When "OUVRE_BATCH"    : Gosub OUVRE_BATCH
  When "EXEC"           : Gosub EXEC
  When "TERMINE"        : Gosub TERMINE
  When "INIT"           : Gosub INIT
  When "OK"             : Gosub OK
Endcase

Return

$OUVRE_BATCH
Return

$EXEC

Return

$TERMINE
Return

$INIT
  If clalev([F:ZACL100])<=0 : Local File ZACL100 [ZACL]  : Endif
  If clalev([F:ZACL2])<=0 : Local File ZACL100 [ZACL2]  : Endif
  If clalev([F:HAE])<=0 : Local File GACCENTRY [HAE]  : Endif
  If clalev([F:HAD])<=0 : Local File GACCENTRYD [HAD]  : Endif
  If clalev([F:WHAD])<=0 : Local File GACCENTRYA [WHAD]  : Endif


Return

$OK
  Local Char CADENA(100)
  Local Char PERIODO(25)
  Local Char DIA(2)
  Local Char FECHACONTABLE(25)
  Local Integer NUMLINEA
  Local Integer SENTIDO
  Local Char FECHAPROCESO(50)
  Local Char ORIGEN(100)
  Local Char DOSIERACTUAL(30)

  DOSIERACTUAL="FANNYSDES"

  FECHAPROCESO=date$+" "+time$

  adxifs=";"
  adxirs=chr$(13)+chr$(10)
  adxium=50 # ASCII

  Call OUVRE_TRACE("Importación de asientos contables iniciado") From LECFIC

  If GFONCTION="ZACL100RE" Then
    #Borramos los registros de la tabla ZACL100, GACCENTRY y GACCENTRYD asignados al diario IL100

    Filter [ZACL]
    For [ZACL]
        Delete [ZACL]
    Next
    Filter [ZACL]

    Filter [HAE] Where JOU='IL100'
    For [HAE]
      Delete [WHAD] Where NUM=[HAE]NUM
      Delete [HAD] Where NUM=[HAE]NUM
    Next
    Filter [HAE]

    Filter [HAE] Where JOU='IL100'
    For [HAE]
        Delete [HAE]
    Next
    Filter [HAE]


  Endif

  Call ECR_TRACE("Exportando asientos contables Línea 100",0) From GESECRAN

 #Gosub IMPORTAR_FICHEROS
 #End

  System RESULT=chr$(34) + "C:\Program Files (x86)\Azeta\Integracion X3-L100 Presupuestaria\IntPres.exe" + chr$(34)


  #Creamos fichero donde se guardarán los registros de los asientos


  Filter [F:ZACL] Where 1=1 and ZESTADO=0 and ZTIPOMOV='D' Order By ZCONTA;JO_NUM;EC_PIECE
  For [ZACL]
    DESCLINEA = ""

    ORIGEN=[ZACL]ZCONTA+" "+[ZACL]JO_NUM+" "+[ZACL]EC_PIECE
    If len(num$([ZACL]EC_JOUR))<2 Then
      DIA = "0"+num$([ZACL]EC_JOUR)
    Else
      DIA = num$([ZACL]EC_JOUR)
    Endif

    PERIODO=DIA+right$(num$([ZACL]JM_DATE),3)

    FECHACONTABLE=mid$(PERIODO,7,4)+mid$(PERIODO,4,2)+mid$(PERIODO,1,2)
    If CADENA="" or CADENA<>[ZACL]ZPLANTAX3-[ZACL]ZDIARIOX3-[ZACL]EC_PIECE Then
      NUMLINEA=1
      If CADENA<>"" Then
        Openo Using [TIE]
      Endif
      #Información de la cabecera del asiento
      Openo filpath("CTA","Asiento_"+[ZACL]ZPLANTAX3+[ZACL]ZDIARIOX3+[ZACL]EC_PIECE,"csv"),0 Using [TIE]
      Wrseq "G,"+[ZACL]ZTIPASIX3+",,"+[ZACL]ZPLANTAX3+","+[ZACL]ZDIARIOX3+","+FECHACONTABLE+","+[ZACL]JO_NUM+"-"+[ZACL]EC_PIECE+"-"+num$([ZACL]EC_DATE)+",,STDCO,"+FECHAPROCESO+","+[ZACL]EC_INTITULE
& Using [
& TIE]
    Endif

    If [ZACL]EC_SENS=0 Then
      SENTIDO=1
    Else
      SENTIDO=-1
    Endif

    If [ZACL]CT_NUM<>"" Then
      #Registro de la línea del asiento con tercero
      Wrseq "D,"+num$(NUMLINEA)+",1,"+num$(NUMLINEA)+","+[ZACL]ZPLANTAX3+","+[ZACL]ZCOLECTIVO+","+[ZACL]ZCUENTAX3+","+[ZACL]ZCLIENTEX3+","+[ZACL]EC_INTITULE+","+num$(SENTIDO)+","+num$([ZACL]EC_MONTANT
& )+",,"+[ZACL]JO_NUM+"-"+[ZACL]EC_PIECE+"-"+num$([ZACL]EC_DATE)+","+FECHAPROCESO
&  Using [TIE]
    Else
      #Registro de la línea del asiento sin tercero
      Wrseq "D,"+num$(NUMLINEA)+",1,"+num$(NUMLINEA)+","+[ZACL]ZPLANTAX3+",,"+[ZACL]ZCUENTAX3+",,"+[ZACL]EC_INTITULE+","+num$(SENTIDO)+","+num$([ZACL]EC_MONTANT)+",,"+[ZACL]JO_NUM+"-"+[ZACL]EC_PIECE+
& "-"+num$([ZACL]EC_DATE)+","+FECHAPROCESO Using [TIE]
    Endif

    #Comprobamos si existen registros analíticos
    Filter [F:ZACL2] Where 1=1 and ZTIPOMOV='A' and EC_NO=[F:ZACL]EC_NO Order By EA_LIGNE
    For [F:ZACL2]
     Wrseq "A,"+num$([F:ZACL2]EA_LIGNE)+",COS,"+[F:ZACL2]ZCENX3+",DET,"+[F:ZACL2]ZDETX3+",CAM,,PRJ,,,,,,,,,,,,"+num$([F:ZACL2]EA_MONTANT) Using [TIE]
    Next
    Filter [F:ZACL2]

    CADENA = [ZACL]ZPLANTAX3-[ZACL]ZDIARIOX3-[ZACL]EC_PIECE

    [ZACL]ZESTADO=2
    [ZACL]ZFICHERO="Asiento_"+[ZACL]ZPLANTAX3+[ZACL]ZDIARIOX3+[ZACL]EC_PIECE+".csv"
    Rewrite [ZACL]

    NUMLINEA=NUMLINEA+1
  Next
  Filter [ZACL]

  Openo Using [TIE]

  Gosub IMPORTAR_FICHEROS


  Call ECR_TRACE("Importación de asientos contables finalizado",0) From GESECRAN
  Call FERME_TRACE From LECFIC


  Call LEC_TRACE From LECFIC
Return

$IMPORTAR_FICHEROS
  Local Integer STAT
  Local Char RESULT  (200)(9000)
  Local Char NOMFICINI(250)
  Local Integer TOTOK
  Local Integer NUMERRORES
  Local Char FICHEROTRAZA(250)
  Local Char     ASUNTO(250)
  Local Clbfile  ENCABEZADO(0)
  Local Clbfile  PIE(0)
  Local Clbfile  MENSAJE(0)

  #Leemos los ficheros generados que se encuentran dentro de la carpeta CTA
  ORDSYS = "dir /b "+filpath("CTA","","")+"\*.*"
  Call SYSTEME2 (adxmac(0),ORDSYS,"",STAT,RESULT) From ORDSYS
  If GSERVEUR
    Call ECR_TRACE("Importación de asientos contables",0) From GESECRAN
  Else
    Call OUVRE_TRACE("Importación de asientos contables") From LECFIC
  Endif

#Infbox("IMPORTANDO FICHEROS")
  For JJ=0 To dim(RESULT)-1
    If RESULT(JJ)<>''
      If mid$(RESULT(JJ),1,7)="Asiento" Then
        TOTOK=1
        FILTRANS=1
        GERRTRACE=0
        NOMFICINI= filpath("CTA","","") + "\" +RESULT(JJ)

        Call IMPORTSIL("ZGAS",NOMFICINI) From GIMPOBJ

        #If filinfo(filpath("CTA",RESULT(JJ),"csv")+".err",0)>0
        If GERRTRACE<>0 Then
          NUMERRORES=NUMERRORES+1
          TOTOK=0
          Call ECR_TRACE("Error importando fichero"+RESULT(JJ),1) From GESECRAN

          Update [ZACL] Where ZFICHERO=RESULT(JJ) With ZESTADO=4

        Else
          Call ECR_TRACE("Importado fichero"+RESULT(JJ),0) From GESECRAN

          Update [ZACL] Where ZFICHERO=RESULT(JJ) With ZESTADO=3

        Endif
        If fstat
          GOK=0: Call FSTA("ZACL") From GLOCK : STA=14
        Endif
        If GOK<0: Goto ROLL_TR_ACL
        Elsif !GOK : Goto AB_TR_ACL
        Endif
        FILTRANS=0

        If TOTOK
          Call MOVE(NOMFICINI,filpath("CTA\PROCESADOS","","") + "\" + RESULT(JJ),STAT)    From ORDSYS
        Else
          Call MOVE(NOMFICINI,filpath("CTA\ERRONEOS","","") + "\" + RESULT(JJ),STAT)    From ORDSYS
        Endif
      Endif
    Endif
  Next

  GERRTRACE=NUMERRORES

  FICHEROTRAZA=filpath("TRA",GTRACE,"tra")

  If NUMERRORES>0 Then
    ASUNTO="Proceso de sincronización L100 **ERROR** - "+DOSIERACTUAL
    Append ENCABEZADO, 'Le informamos que se han producido errores durante la importación en X3'+chr$(10)+chr$(10)
    Append ENCABEZADO, 'Revise el fichero de traza que se adjunta en el email'+chr$(10)+chr$(10)
    Append PIE,'Administrador del sistema'

    Append MENSAJE,ENCABEZADO
    Append MENSAJE,PIE

    Gosub ENVIAR_EMAIL
  Endif

  #End
Return

$AB_TR_ACL
#Rollback
FLTRANS = 0
Return

$ROLL_TR_ACL
#Rollback
FLTRANS = 0
Call ROLL From GLOCK
If GROLL : Return : Else : Goto IMPORTAR_FICHEROS : Endif

$ENVIAR_EMAIL
  Local Integer  STA
  Local Integer  TRACE
  Local Char     A_USER(250)(1..)
  Local Char     CC_USER(250)(1..)
  Local Char     LEMAIL_DE(250)
  Local Char     ISSUERMAIL(250)
  Local Char     ATTACHMENTS(250)(1..)

  ISSUERMAIL="info@perfumeriaselectiva.net"
  #A_USER(1)="info@perfumeriaselectiva.net"
  A_USER(1)="floren.presumido@grupoazeta.com"
  A_USER(2)="josep.rodriguez@grupoazeta.com"

  #A_USER(1)="jennifer.perfum@hotmail.com"
  #A_USER(2)="comercial@perfumeriaselectiva.net"
  #A_USER(3)="info@perfumeriaselectiva.net"

  #CC_USER(1)="floren.presumido@grupoazeta.com"
  #CC_USER(2)="josep.rodriguez@grupoazeta.com"
  #CC_USER(3)="angel.delatorre@grupoazeta.com"


  TRACE=2

  #--- Envio del email
  STA = func ASYRMAIL.ASEND_MAIL(GACTX,ISSUERMAIL,A_USER,CC_USER,ASUNTO,MENSAJE,FICHEROTRAZA,TRACE)

Return

