#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  #Infbox(ACTION)
     Case ACTION
      When "EXEC"  : Gosub EXEC
      When "OUVRE" : Gosub OUVRE
      When "CONTROLE" : Gosub CONTROLE
      When "OK"    : Gosub OK
      When Default
     Endcase
Return

$CONTROLE
    TMP = 1
    TIT = "Importación en curso"
Return

$OK
    WEXE = 1
    WNOM = [M:ZPRFCMKT]NOMFIC(0)
Return

$OUVRE
    Global Char WNOM(250)
    Global Integer WEXE
    WEXE = 0
Return

$EXEC
   If WEXE = 1
      Gosub PROCESA
   Endif
Return

$PROCESA
    Local Char A(250)(1..110)
    Local Char WOUT(250)
    Local Char WJOB(10)

    Local Integer CONTADOR
    Local Char REQUEST(255)

    Local Integer WERROR
    Local Integer WESPERA,WCONT,STAT
    Local Char WITMREF(25), WESTADO(20), NUMERO(25)

    Local Char WDEP(10)

    Local Char REFPEDIDO(50)
    Local Char NUMPREFAC(50)
    Local Decimal CTDPREFAC
    Local Decimal PVPPREFAC
    Local Char PROCPREFAC(100)
    Local Char REFARTICULO(50)
    Local Char NOMFICHERO(250)
    Local Char REFPEDIDONEW(50)

    If !clalev([SDH])  : Local File SDELIVERY   [SDH]  : Endif
    If !clalev([SDD])  : Local File SDELIVERYD  [SDD]  : Endif
    If !clalev([ZPF])  : Local File ZPREFACMKT  [ZPF]  : Endif

    #Infbox("1")
    Raz WERROR,WCONT
    WJOB = num$(time)

    adxifs=";"
    adxirs=chr$(13)+chr$(10)
    adxium=50 # ASCII

    Call OUVRE_TRACE("Importación de prefactura MKT ") From LECFIC
    Call ECR_TRACE(" Importación de prefactura MKT  ",0) From GESECRAN


    #lectura de fichero
    Delete [ZPF] Where 1=1

    WNOM = mid$(WNOM,7,len(WNOM))
    NOMFICHERO = WNOM
    WNOM = filpath("BQT","","") +"\" +WNOM

    Openi WNOM Using [TIE]

    #Paso 1. Verificar datos del fichero correctos

    Gosub LEER_REGISTRO   #fichero viene con cabecera de los campos
    Gosub LEER_REGISTRO
    While !fstat
      WCONT += 1

      Raz [ZPF]
      [F:ZPF]ZPREFAC =  ctrans(ctrans(vireblc(A(1),2),chr$(34),""),"=","")
      [F:ZPF]ZPEDMKT =  ctrans(ctrans(vireblc(A(2),2),chr$(34),""),"=","")
      [F:ZPF]ZITMREF = ctrans(vireblc(A(3),2),chr$(34),"")
      [F:ZPF]ZQTY = val(ctrans(A(4),",","."))
      [F:ZPF]ZPVP = val(ctrans(A(5),",","."))
      Write [ZPF]

      Gosub LEER_REGISTRO
    Wend
    Openi Using [TIE]

    #Abrimos la tabla agrupando por num.pedido, referencia y cantidad
    CONTADOR=0
    REQUEST="SELECT SUM(ZQTY_0),ZPEDMKT_0 FROM ZPREFACMKT GROUP BY ZPEDMKT_0,ZITMREF_0 HAVING SUM(ZQTY_0)<>0 ORDER BY ZPEDMKT_0"
    For (Decimal CANT,Char REFPED(50)) From "5" Sql REQUEST As [YYY]
      If [F:YYY]REFPED<>REFPEDIDO Then
        Call ECR_TRACE("Actualizando entrega "+[F:YYY]REFPED,0) From GESECRAN

        REQUEST="SELECT ZPREFAC_0,ZPEDMKT_0,ZITMREF_0,ZQTY_0,ZPVP_0 FROM ZPREFACMKT WHERE ZPEDMKT_0='"+[F:YYY]REFPED+"'"
        For (Char ZPREFAC(50),Char ZPEDMKT(50),Char ZITMREF(50),Decimal ZQTY,Decimal ZPVP) From "5" Sql REQUEST As [XXX]

          NUMPREFAC =  [F:XXX]ZPREFAC
          REFPEDIDO =  [F:XXX]ZPEDMKT
          REFARTICULO =  [F:XXX]ZITMREF
          CTDPREFAC = [F:XXX]ZQTY
          PVPPREFAC = [F:XXX]ZPVP

          #Comprobamos si existe la cabecera de la entrega
          Raz [SDH]
          Filter [F:SDH] Where [F:SDH]CUSORDREF=REFPEDIDO
          If (rowcount([F:SDH])>0) Then
            For [F:SDH]
              #Encontramos la entrega y ahora comprobamos que el artículo exista dentro de la entrega
              Raz [SDD]
              Filter [F:SDD] Where [F:SDD]SDHNUM=[F:SDH]SDHNUM and [F:SDD]ITMREF=REFARTICULO
              If (rowcount([F:SDD])>0) Then
                For [F:SDD]
                  #Artículo encontrado, actualizamos los valores
                  [F:SDD]ZPREFAC=NUMPREFAC
                  [F:SDD]ZPVPPREFAC=PVPPREFAC
                  [F:SDD]ZPROCPREFAC=format$("D:DDMMYYYY",date$) + ' ' + time$ + ' ' + NOMFICHERO

                  If CTDPREFAC>0 Then
                    [F:SDD]ZCTDPREFAC=CTDPREFAC

                    #Comprobamos que la cantidad prefactura MKT no sea distinta a la de la entrega
                    If (CTDPREFAC<>[F:SDD]QTY) Then
                      Call ECR_TRACE("Cantidad de prefactura("+num$(CTDPREFAC)+") es distinta la de la entrega("+num$([F:SDD]QTY)+"). "+REFPEDIDO+"/"+[F:SDD]SDHNUM+"/"+REFARTICULO,1) From GESECRAN
                    Endif
                  Else
                    [F:SDD]ZCTDEVPREFAC=CTDPREFAC
                    #Comprobamos que la cantidad devolución MKT no sea distinta a la de la entreaga
                    If (abs(CTDPREFAC)<>[F:SDD]RTNQTY) Then
                      Call ECR_TRACE("Cantidad de prefactura("+num$(abs(CTDPREFAC))+") es distinta la de la devolución("+num$([F:SDD]RTNQTY)+"). "+REFPEDIDO+"/"+[F:SDD]SDHNUM+"/"+REFARTICULO,1) From
& GESECRAN
                    Endif
                  Endif
                  Rewrite [SDD]
                Next
              Else
                #Artículo no encontrado
                Call ECR_TRACE("No se ha encontrado el artículo "+REFARTICULO+" en la entrega "+[F:SDH]SDHNUM+"/"+REFPEDIDO,1) From GESECRAN
              Endif
              [F:SDH]ZPREFAC=NUMPREFAC
              Rewrite [SDH]
            Next
          Else
            #Entrega no encontrada
            If REFPEDIDONEW<>REFPEDIDO Then
              Call ECR_TRACE("No se ha encontrado la entrega con referencia "+REFPEDIDO,1) From GESECRAN
            Endif
            REFPEDIDONEW = ctrans(ctrans(vireblc(A(2),2),chr$(34),""),"=","")
          Endif
        Next
      Endif
      REFPEDIDO =  [F:YYY]REFPED


    Next

    Call LEC_TRACE() From LECFIC

Return


$FIN
    Kill WNOM
    Kill WEXE
Return

$LEER_REGISTRO
Rdseq A(1), A(2), A(3), A(4), A(5), A(6), A(7), A(8), A(9), A(10),
& A(11), A(12), A(13), A(14), A(15), A(16), A(17), A(18), A(19), A(20),
& A(21), A(22), A(23), A(24), A(25), A(26), A(27), A(28), A(29), A(30),
& A(31), A(32), A(33), A(34), A(35), A(36), A(37), A(38), A(39), A(40),
& A(41), A(42), A(43), A(44), A(45), A(46), A(47), A(48), A(49), A(50),
& A(51), A(52), A(53), A(54), A(55), A(56), A(57), A(58), A(59), A(60),
& A(61), A(62), A(63), A(64), A(65), A(66), A(67), A(68), A(69), A(70),
& A(71), A(72), A(73), A(74), A(75), A(76), A(77), A(78), A(79), A(80),
& A(81), A(82), A(83), A(84), A(85), A(86), A(87), A(88), A(89), A(90),
& A(91), A(92), A(93), A(94), A(95), A(96), A(97), A(98), A(99), A(100),
& A(101), A(102), A(103), A(104), A(105), A(106), A(107), A(108), A(109), A(110) Using [TIE]
Return

