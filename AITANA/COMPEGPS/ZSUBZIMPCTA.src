        Endif
        PERIODO=DIA+right$(num$([F:ZAPU]JM_DATE),3)

        FECHACONTABLE=mid$(PERIODO,7,4)+mid$(PERIODO,4,2)+mid$(PERIODO,1,2)

        #Extraemos la equivalencia con la condición de pago
        Raz CONDPAGO
        Filter [F:ZCPA] Where 1=1 and ZPTE100=[F:ZAPU]MR_NO
        If rowcount([F:ZCPA])>0 Then
          For [F:ZCPA]
            CONDPAGO=[F:ZCPA]PTE
          Next
        Endif
        Filter [F:ZCPA]

        If CONDPAGO="" Then
          Call ECR_TRACE("AZETA> La factura de venta "+"ZBIC_"+[F:ZAPU]EC_PIECE+"_"+[F:ZAPU]JO_NUM+"_"+FECHACONTABLE+" no tiene CONDICIÓN DE PAGO informada. Se asignará ANTICIPADO",2) From GESECRAN
          CONDPAGO="ANTICIPADO"
        Endif

        #Régimen de impuesto
        Raz CATCONTABLE
        Case [F:ZAPU]N_CATCOMPTA
          When 1 : CATCONTABLE="NAC"
          When 2 : CATCONTABLE="EXP"
          When 3 : CATCONTABLE="CEE"
          When 4 : CATCONTABLE="CAN"
          When 5 : CATCONTABLE="REQ"
        Endcase

        #Extraemos la categoría contable a partir de la tabla de equivalencias de impuesto
        TACODE=""
        Filter [F:ZAPU3] Where 1=1 and TA_CODE<>'' and EC_PIECE=[F:ZAPU]EC_PIECE and JM_DATE=[F:ZAPU]JM_DATE
        For [F:ZAPU3]
          TACODE=[F:ZAPU3]TA_CODE
          Break
        Next
        Filter [F:ZAPU3]

        CATCONTABLE=""
        Filter [F:ZIMP] Where 1=1 and ZVAT100=TACODE
        For [F:ZIMP]
          CATCONTABLE=[F:ZIMP]ZCATX3
        Next
        Filter [F:ZIMP]

        #Tipo de factura de venta
        Raz TIPOFAC
        If [F:ZAPU]DO_PROVENAN=0 and [F:ZAPU]DO_DOMAINE=0 Then
          TIPOFAC="FAC"
        Elsif [F:ZAPU]DO_PROVENAN=2 and [F:ZAPU]DO_DOMAINE=0 Then
          TIPOFAC="ABO"
        Endif



#        #Comprobamos por el sentido de la cuenta 700 si es un abono
#        REQUEST="SELECT EC_SENS_0 FROM ZAPUCTA WHERE EC_REFPIECE_0='"+[F:ZAPU]EC_REFPIECE+"' AND CG_NUM_0 LIKE '700%'"
#        For (Integer SENTIDO) From "5" Sql REQUEST As [YYY]
#          If [F:YYY]SENTIDO=0 Then
#            TIPOFAC="ABO"
#          Endif
#        Next

#        #Extraemos el colectivo a partir de la cuenta general del asiento para el cliente
#        CGENERAL=""
#        Filter [F:ZAPU2] Where 1=1 and CT_NUM=[F:]
        If [F:ZAPU]CT_NUM<>"" Then
          COLECTIVO=""
          Filter [F:XGAC] Where 1=1 and  ACC=[F:ZAPU]CG_NUM
          For [F:XGAC]
            COLECTIVO=[F:XGAC]ACCSHO
            Break
          Next
          Filter [F:XGAC]

         If COLECTIVO=""  Then
          Call ECR_TRACE("AZETA> La factura de venta "+"ZBIC_"+[F:ZAPU]EC_PIECE+"_"+[F:ZAPU]JO_NUM+"_"+FECHACONTABLE+" no tiene el COLECTIVO informado. Se asignará el C300",2) From GESECRAN
          COLECTIVO="C300"
          Endif
        Endif

        Filter [F:ZBPC] Where 1=1 and ZBPCNUM=[F:ZAPU]CT_NUM
        For [F:ZBPC]
          If vireblc([F:ZBPC]ZCRN,2)="" and [F:ZBPC]ZCRY="ES" Then
            CATCONTABLE="NACS"
          Endif
        Next
        Filter [F:ZBPC]



#        Read [F:XGAC]GAC0="SPA";[F:ZAPU]CG_NUM
#        If fstat=0 Then
#          COLECTIVO=[F:XGAC]ACCSHO
#        Endif

        #Extraemos el nº de factura de la tabla de relaciones
#        NUMFACX3=""
#        Filter [F:ZREL] Where 1=1 and ZNUMFACL100=[F:ZAPU]EC_REFPIECE
#        For [F:ZREL]
#          NUMFACX3=[F:ZREL]ZNUMFACX3
#        Next
#        Filter [F:ZREL]


        Openo filpath("CONTA\ASIENTOSV","ZBIC_"+[F:ZAPU]EC_PIECE+"_"+[F:ZAPU]JO_NUM+"_"+FECHACONTABLE+"_2","txt"),0 Using [TIE]
        Iomode  adxium 0 Using [TIE]

        Wrseq "T;"+TIPOFAC+";"+NUMFACX3+";ENTETE;"+[F:ZAPU]CT_NUM+";"+"001;100;"+FECHACONTABLE+";EUR;1;"+FECHACONTABLE+";"+[F:ZAPU]CT_NUM+";"+FECHACONTABLE+";"+CONDPAGO+";"+CATCONTABLE+";"+[F:ZAPU]
& EC_REFPIECE+";"
& +COLECTIVO+";"+[F:ZAPU]EC_REFPIECE+";"+[F:ZAPU]JO_NUM+"/"+FECHACONTABLE+"/"+[F:ZAPU]EC_PIECE+";"+[F:ZAPU]EC_REFPIECE
& Using [TIE]
      Endif

      If mid$([F:ZAPU]CG_NUM,1,3)<>"430" Then
        #Comprobamos la equivalencia del código de IVA
        Raz CODVAT
        If [F:ZAPU]TA_CODE<>"" Then
          Filter [F:ZIMP] Where 1=1 and ZVAT100=[F:ZAPU]TA_CODE
          If rowcount([F:ZIMP])>0 Then
            For [F:ZIMP]
              CODVAT=[F:ZIMP]VAT
              CODVAT2=[F:ZIMP]VAT2
            Next
          Endif
          Filter [F:ZIMP]
        Endif

        If vireblc(CODVAT,2)="" Then
          CODVAT="SP999"
        Endif
        #Extraemos los porcentajes de iva
        PORC1=0
        If vireblc(CODVAT,2)<>"" Then
          Filter [F:TRA] Where 1=1 and VAT=vireblc(CODVAT,2) Order By STRDAT Desc
          For [F:TRA]
            PORC1=[F:TRA]VATRAT
            Break
          Next
          Filter [F:TRA]
        Endif

        PORC2=0
        If vireblc(CODVAT2,2)<>"" Then
          Filter [F:TRA] Where 1=1 and VAT=vireblc(CODVAT2,2) Order By STRDAT Desc
          For [F:TRA]
            PORC2=[F:TRA]VATRAT
            Break
          Next
          Filter [F:TRA]
        Endif

        IMPTAX1=0
        IMPTAX2=0
        #Calculamos los importes para cada uno de los IVAS
        IMPTAX1=ar2((PORC1*[F:ZAPU]EC_MONTANT)/100)
        IMPTAX2=ar2((PORC2*[F:ZAPU]EC_MONTANT)/100)



        Wrseq "D;"+num$(NUMLINEA)+";100;SPA;;;;;;;;;;;"+[F:ZAPU]CG_NUM+";;;;;;;;;;;;"+num$([F:ZAPU]EC_MONTANT)+";0;"+CODVAT+";"+CODVAT2+";;"+num$(IMPTAX1)+";"+num$(IMPTAX2)+";0" Using [TIE]
        NUMLINEA=NUMLINEA+1
      Endif

      If mid$([F:ZAPU]CG_NUM,1,3)="430" Then
        Raz CODFPAGO
        CODFPAGO=0
        Filter [F:ZAPU3] Where 1=1 and EC_PIECE=[F:ZAPU]EC_PIECE and JM_DATE=[F:ZAPU]JM_DATE and N_REGLEMENT<>0
        For [F:ZAPU3]
          CODFPAGO=[F:ZAPU3]N_REGLEMENT
          Break
        Next
        Filter [F:ZAPU3]

        #Extraemos la equivalencia con la forma de pago
        Raz FORMAPAGO
        Filter [F:ZFPA] Where 1=1 and ZPAM100=CODFPAGO
        If rowcount([F:ZFPA])>0 Then
          For [F:ZFPA]
            FORMAPAGO=[F:ZFPA]PAM
          Next
        Endif
        Filter [F:ZFPA]

        If CODFPAGO=0 Then
          FORMAPAGO="CONT"
        Endif


        If FORMAPAGO="SDD" Then
          FORMAPAGO="CONT"
        Endif

       #Sumamos los importes
        SUMTOT=0
        REQUEST="SELECT SUM(EC_MONTANT_0) FROM ZAPUCTA WHERE EC_REFPIECE_0='"+[F:ZAPU]EC_REFPIECE+"' AND CG_NUM_0 LIKE '700%' AND EC_SENS_0=0"
        For (Decimal SUMA) From "5" Sql REQUEST As [YYY]
          SUMTOT=[F:YYY]SUMA
        Next

        FECHAVEN=mid$(num$([F:ZAPU]EC_ECHEANCE),7,4)+mid$(num$([F:ZAPU]EC_ECHEANCE),4,2)+mid$(num$([F:ZAPU]EC_ECHEANCE),1,2)
        Append VENCIMIENTOS,"E;"+num$(NUMLINEAVEN)+";"+FECHAVEN+";"+FORMAPAGO+";1;"+num$(SUMTOT)+";1;001"+chr$(13)+chr$(10)
        NUMLINEAVEN=NUMLINEAVEN+1
      Endif

      ECPIECE=[F:ZAPU]EC_PIECE
    Next
    Wrseq VENCIMIENTOS Using [TIE]
    Openo Using [TIE]
  Endif
  Filter [F:ZAPU]



Return


$CREAR_APUNTESC
  Local Char ECPIECE(50)
  Local Clbfile VENCIMIENTOS(0)
  Local Char FECHACONTABLE(25)
  Local Char FECHAVEN(25)
  Local Char PERIODO(25)
  Local Char DIA(2)
  Local Integer NUMLINEA
  Local Integer NUMLINEAVEN
  Local Char CONDPAGO(GLONPTE)
  Local Char CATCONTABLE(GLONTVB)
  Local Char CODVAT(GLONVAT)
  Local Char FORMAPAGO(GLONPTE)
  Local Char TIPOFAC(5)
  Local Char COLECTIVO(25)
  Local Double IMPTAX1
  Local Double IMPTAX2
  Local Double PORC1
  Local Double PORC2
  Local Integer CODFPAGO
  Local Char NUMFACX3(50)
  Local Char TACODE(10)
  Local Integer AUTOIVA
  Local Integer TIPMOV

  Filter [F:ZAPU] Where 1=1 and (JO_NUM='COM' or JO_NUM='CCI') and ZTIPO=0 Order By EC_PIECE;JO_NUM;JM_DATE;CT_NUM Desc
  If rowcount([F:ZAPU])>0 Then
    For [F:ZAPU]
    #Infbox([F:ZAPU]CG_NUM)
      If ECPIECE<>[F:ZAPU]EC_PIECE Then
        If ECPIECE<>"" Then
          #If vireblc(VENCIMIENTOS,2)<>"" Then
            Onerrgo ERRBATCH
            Wrseq mid$(VENCIMIENTOS,1,len(VENCIMIENTOS)-2) Using [TIE]
          #Endif
          Raz VENCIMIENTOS

          Openo Using [TIE]
        Endif
        #Creamos el fichero
        NUMLINEA=1
        NUMLINEAVEN=1

        #Escribimos la cabecera del fichero
        If len(num$([F:ZAPU]EC_JOUR))<2 Then
          DIA = "0"+num$([F:ZAPU]EC_JOUR)
        Else
          DIA = num$([F:ZAPU]EC_JOUR)
        Endif
        PERIODO=DIA+right$(num$([F:ZAPU]JM_DATE),3)

        FECHACONTABLE=mid$(PERIODO,7,4)+mid$(PERIODO,4,2)+mid$(PERIODO,1,2)

        #Extraemos la equivalencia con la condición de pago
        Raz CONDPAGO
        Filter [F:XBPS] Where 1=1 and BPSNUM=[F:ZAPU]CT_NUM
        If rowcount([F:XBPS])>0 Then
          For [F:XBPS]
            CONDPAGO=[F:XBPS]PTE
            Break
          Next
        Endif
        Filter [F:XBPS]

        If CONDPAGO="" Then
          CONDPAGO="ANTICIPADO"
          Call ECR_TRACE("AZETA> La factura de compra "+"ZBIS_"+[F:ZAPU]EC_PIECE+"_"+[F:ZAPU]JO_NUM+"_"+FECHACONTABLE+" no tiene CONDICIÓN DE PAGO informada. Se asignará ANTICIPADO",2) From GESECRAN
        Endif

        #Régimen de impuesto
        Raz CATCONTABLE
        Case [F:ZAPU]N_CATCOMPTA
          When 1 : CATCONTABLE="NAC"
          When 2 : CATCONTABLE="EXP"
          When 3 : CATCONTABLE="CEE"
          When 4 : CATCONTABLE="CAN"
          When 5 : CATCONTABLE="REQ"
        Endcase



        #Extraemos la categoría contable a partir de la tabla de equivalencias de impuesto
        TACODE=""
        Filter [F:ZAPU3] Where 1=1 and TA_CODE<>'' and EC_PIECE=[F:ZAPU]EC_PIECE and JM_DATE=[F:ZAPU]JM_DATE
        For [F:ZAPU3]
          TACODE=[F:ZAPU3]TA_CODE
          Break
        Next
        Filter [F:ZAPU3]

        CATCONTABLE=""
        AUTOIVA=1
        Filter [F:ZIMP] Where 1=1 and ZVAT100=TACODE
        For [F:ZIMP]
          CATCONTABLE=[F:ZIMP]ZCATX3
          AUTOIVA=[F:ZIMP]CEEFLG
        Next
        Filter [F:ZIMP]


        #Tipo de factura de venta
        Raz TIPOFAC
        If [F:ZAPU]DO_PROVENAN=0 and [F:ZAPU]DO_DOMAINE=1 Then
          TIPOFAC="FAS"
        Elsif [F:ZAPU]DO_PROVENAN=2 and [F:ZAPU]DO_DOMAINE=1 Then
          TIPOFAC="ABO"
        Endif

        If [F:ZAPU]CT_NUM<>"" Then
          COLECTIVO=""
          Filter [F:XGAC] Where 1=1 and  ACC=[F:ZAPU]CG_NUM
          For [F:XGAC]
            COLECTIVO=[F:XGAC]ACCSHO
            Break
          Next
          Filter [F:XGAC]

          If COLECTIVO=""  Then
            Call ECR_TRACE("AZETA> La factura de compra "+"ZBIS_"+[F:ZAPU]EC_PIECE+"_"+[F:ZAPU]JO_NUM+"_"+FECHACONTABLE+" no tiene el COLECTIVO informado. Se asignará el P000",2) From GESECRAN
            COLECTIVO="P000"
          Endif
        Endif

        Filter [F:ZBPC] Where 1=1 and ZBPCNUM=[F:ZAPU]CT_NUM
        For [F:ZBPC]
          If vireblc([F:ZBPC]ZCRN,2)="" and [F:ZBPC]ZCRY="ES" Then
            CATCONTABLE="NACS"
          Endif
        Next
        Filter [F:ZBPC]

#        #Extraemos el nº de factura de la tabla de relaciones
#        NUMFACX3=""
#        Filter [F:ZREL] Where 1=1 and ZNUMFACL100=[F:ZAPU]EC_REFPIECE
#        For [F:ZREL]
#          NUMFACX3=[F:ZREL]ZNUMFACX3
#        Next
#        Filter [F:ZREL]
        TIPMOV=0
        If [F:ZAPU]JO_NUM='COM' Then
          TIPMOV=1
        Else
          TIPMOV=2
        Endif

        Openo filpath("CONTA\ASIENTOSC","ZBIS_"+[F:ZAPU]EC_PIECE+"_"+[F:ZAPU]JO_NUM+"_"+FECHACONTABLE,"txt"),0 Using [TIE]
        Iomode  adxium 0 Using [TIE]

        Wrseq "T;"+TIPOFAC+";"+NUMFACX3+";"+[F:ZAPU]CT_NUM+";"+"001;100;"+FECHACONTABLE+";EUR;1;"+FECHACONTABLE+";"+[F:ZAPU]CT_NUM+";"+FECHACONTABLE+";"+CONDPAGO+";"+CATCONTABLE+";"+[F:ZAPU]
& EC_REFPIECE+";"+
& COLECTIVO+";"+[F:ZAPU]EC_REFPIECE+";"+[F:ZAPU]JO_NUM+"/"+FECHACONTABLE+"/"+[F:ZAPU]EC_PIECE+";"+num$(AUTOIVA)+";"+num$(TIPMOV)
& Using [TIE]
      Endif

      If mid$([F:ZAPU]CG_NUM,1,3)<>"400" and mid$([F:ZAPU]CG_NUM,1,3)<>"410" Then

        #Comprobamos la equivalencia del código de IVA
        Raz CODVAT
        If [F:ZAPU]TA_CODE<>"" Then
          Filter [F:ZIMP] Where 1=1 and ZVAT100=[F:ZAPU]TA_CODE
          If rowcount([F:ZIMP])>0 Then
            For [F:ZIMP]
              CODVAT=[F:ZIMP]VAT
              CODVAT2=[F:ZIMP]VAT2
            Next
          Endif
          Filter [F:ZIMP]
        Endif

        #Extraemos los porcentajes de iva
        POR1=0
        If vireblc(CODVAT,2)<>"" Then
          Filter [F:TRA] Where 1=1 and VAT=vireblc(CODVAT,2) Order By STRDAT Desc
          For [F:TRA]
            PORC1=[F:TRA]VATRAT
            Break
          Next
          Filter [F:TRA]
        Endif

        PORC2=0
        If vireblc(CODVAT2,2)<>"" Then
          Filter [F:TRA] Where 1=1 and VAT=vireblc(CODVAT2,2) Order By STRDAT Desc
          For [F:TRA]
            PORC2=[F:TRA]VATRAT
            Break
          Next
          Filter [F:TRA]
        Endif

        #Calculamos los importes para cada uno de los IVAS
        IMPTAX1=ar2((PORC1*[F:ZAPU]EC_MONTANT)/100)
        IMPTAX2=ar2((PORC2*[F:ZAPU]EC_MONTANT)/100)

        Wrseq "L;"+num$(NUMLINEA)+";100;SPA;;;;;;;;;;;"+[F:ZAPU]CG_NUM+";;;;;;;;;;;;"+num$([F:ZAPU]EC_MONTANT)+";0;"+CODVAT+";"+CODVAT2+";;"+num$(IMPTAX1)+";"+num$(IMPTAX2)+";0;"+num$(TIPMOV) Using [
& TIE]
        NUMLINEA=NUMLINEA+1
      Endif

      If mid$([F:ZAPU]CG_NUM,1,3)="400" or mid$([F:ZAPU]CG_NUM,1,3)="410" Then
        CODFPAGO=0
        Filter [F:ZAPU3] Where 1=1 and EC_PIECE=[F:ZAPU]EC_PIECE and JM_DATE=[F:ZAPU]JM_DATE and N_REGLEMENT<>0
        For [F:ZAPU3]
          CODFPAGO=[F:ZAPU3]N_REGLEMENT
          Break
        Next
        Filter [F:ZAPU3]


        #Extraemos la equivalencia con la forma de pago
        Raz FORMAPAGO
        Filter [F:ZFPA] Where 1=1 and ZPAM100=CODFPAGO
        If rowcount([F:ZFPA])>0 Then
          For [F:ZFPA]
            FORMAPAGO=[F:ZFPA]PAM


          Next
        Endif
        Filter [F:ZFPA]


        If CODFPAGO=0 Then
          FORMAPAGO="CONT"
        Endif

        If FORMAPAGO="SDD" Then
          FORMAPAGO="CONT"
        Endif

        FECHAVEN=mid$(num$([F:ZAPU]EC_ECHEANCE),7,4)+mid$(num$([F:ZAPU]EC_ECHEANCE),4,2)+mid$(num$([F:ZAPU]EC_ECHEANCE),1,2)
        Append VENCIMIENTOS,"E;"+num$(NUMLINEAVEN)+";"+FECHAVEN+";"+FORMAPAGO+";1;"+num$([F:ZAPU]EC_MONTANT)+";1;001"+chr$(13)+chr$(10)
        NUMLINEAVEN=NUMLINEAVEN+1

        Raz CODFPAGO
        CODFPAGO=0
      Endif

      ECPIECE=[F:ZAPU]EC_PIECE
    Next
    Wrseq mid$(VENCIMIENTOS,1,len(VENCIMIENTOS)-2) Using [TIE]
    Openo Using [TIE]
  Endif
  Filter [F:ZAPU]


Return

$CREAR_APUNTESC_2
  Local Char ECPIECE(50)
  Local Clbfile VENCIMIENTOS(0)
  Local Char FECHACONTABLE(25)
  Local Char FECHAVEN(25)
  Local Char PERIODO(25)
  Local Char DIA(2)
  Local Integer NUMLINEA
  Local Integer NUMLINEAVEN
  Local Char CONDPAGO(GLONPTE)
  Local Char CATCONTABLE(GLONTVB)
  Local Char CODVAT(GLONVAT)
  Local Char FORMAPAGO(GLONPTE)
  Local Char TIPOFAC(5)
  Local Char COLECTIVO(25)
  Local Double IMPTAX1
  Local Double IMPTAX2
  Local Double PORC1
  Local Double PORC2
  Local Integer CODFPAGO
  Local Char NUMFACX3(50)
  Local Char TACODE(10)
  Local Integer AUTOIVA
  Local Integer TIPMOV

  Filter [F:ZAPU] Where 1=1 and (JO_NUM='COM' or JO_NUM='CCI') and ZTIPO=1 Order By EC_PIECE;JO_NUM;JM_DATE;CT_NUM Desc
  If rowcount([F:ZAPU])>0 Then
    For [F:ZAPU]
      If ECPIECE<>[F:ZAPU]EC_PIECE Then
        If ECPIECE<>"" Then
          Wrseq mid$(VENCIMIENTOS,1,len(VENCIMIENTOS)-2) Using [TIE]
          Raz VENCIMIENTOS

          Openo Using [TIE]
        Endif
        #Creamos el fichero
        NUMLINEA=1
        NUMLINEAVEN=1

        #Escribimos la cabecera del fichero
        If len(num$([F:ZAPU]EC_JOUR))<2 Then
          DIA = "0"+num$([F:ZAPU]EC_JOUR)
        Else
          DIA = num$([F:ZAPU]EC_JOUR)
        Endif
        PERIODO=DIA+right$(num$([F:ZAPU]JM_DATE),3)

        FECHACONTABLE=mid$(PERIODO,7,4)+mid$(PERIODO,4,2)+mid$(PERIODO,1,2)

        #Extraemos la equivalencia con la condición de pago
        Raz CONDPAGO
        Filter [F:XBPS] Where 1=1 and BPSNUM=[F:ZAPU]CT_NUM
        If rowcount([F:XBPS])>0 Then
          For [F:XBPS]
            CONDPAGO=[F:XBPS]PTE
            Break
          Next
        Endif
        Filter [F:XBPS]

        If CONDPAGO="" Then
          CONDPAGO="ANTICIPADO"
          Call ECR_TRACE("AZETA> La factura de compra "+"ZBIS_"+[F:ZAPU]EC_PIECE+"_"+[F:ZAPU]JO_NUM+"_"+FECHACONTABLE+" no tiene CONDICIÓN DE PAGO informada. Se asignará ANTICIPADO",2) From GESECRAN
        Endif

        #Régimen de impuesto
        Raz CATCONTABLE
        Case [F:ZAPU]N_CATCOMPTA
          When 1 : CATCONTABLE="NAC"
          When 2 : CATCONTABLE="EXP"
          When 3 : CATCONTABLE="CEE"
          When 4 : CATCONTABLE="CAN"
          When 5 : CATCONTABLE="REQ"
        Endcase

        #Extraemos la categoría contable a partir de la tabla de equivalencias de impuesto
        TACODE=""
        AUTOIVA=1
        Filter [F:ZAPU3] Where 1=1 and TA_CODE<>'' and EC_PIECE=[F:ZAPU]EC_PIECE and JM_DATE=[F:ZAPU]JM_DATE
        For [F:ZAPU3]
          TACODE=[F:ZAPU3]TA_CODE
          AUTOIVA=[F:ZIMP]CEEFLG
          Break
        Next
        Filter [F:ZAPU3]

        CATCONTABLE=""
        Filter [F:ZIMP] Where 1=1 and ZVAT100=TACODE
        For [F:ZIMP]
          CATCONTABLE=[F:ZIMP]ZCATX3
        Next
        Filter [F:ZIMP]


        #Tipo de factura de venta
        Raz TIPOFAC
        If [F:ZAPU]DO_PROVENAN=0 and [F:ZAPU]DO_DOMAINE=1 Then
          TIPOFAC="FAS"
        Elsif [F:ZAPU]DO_PROVENAN=2 and [F:ZAPU]DO_DOMAINE=1 Then
          TIPOFAC="ABO"
        Endif

        TIPOFAC="ABO"

        If [F:ZAPU]CT_NUM<>"" Then
          COLECTIVO=""
          Filter [F:XGAC] Where 1=1 and  ACC=[F:ZAPU]CG_NUM
          For [F:XGAC]
            COLECTIVO=[F:XGAC]ACCSHO
            Break
          Next
          Filter [F:XGAC]

          If COLECTIVO=""  Then
            Call ECR_TRACE("AZETA> La factura de compra "+"ZBIS_"+[F:ZAPU]EC_PIECE+"_"+[F:ZAPU]JO_NUM+"_"+FECHACONTABLE+" no tiene el COLECTIVO informado. Se asignará el P000",2) From GESECRAN
            COLECTIVO="P000"
          Endif
        Endif

        Filter [F:ZBPC] Where 1=1 and ZBPCNUM=[F:ZAPU]CT_NUM
        For [F:ZBPC]
          If vireblc([F:ZBPC]ZCRN,2)="" and [F:ZBPC]ZCRY="ES" Then
            CATCONTABLE="NACS"
          Endif
        Next
        Filter [F:ZBPC]

        TIPMOV=0
        If [F:ZAPU]JO_NUM='COM' Then
          TIPMOV=1
        Else
          TIPMOV=2
        Endif

#        #Extraemos el nº de factura de la tabla de relaciones
#        NUMFACX3=""
#        Filter [F:ZREL] Where 1=1 and ZNUMFACL100=[F:ZAPU]EC_REFPIECE
#        For [F:ZREL]
#          NUMFACX3=[F:ZREL]ZNUMFACX3
#        Next
#        Filter [F:ZREL]

        Openo filpath("CONTA\ASIENTOSC","ZBIS_"+[F:ZAPU]EC_PIECE+"_"+[F:ZAPU]JO_NUM+"_"+FECHACONTABLE,"txt"),0 Using [TIE]
        Iomode  adxium 0 Using [TIE]

        Wrseq "T;"+TIPOFAC+";"+NUMFACX3+";"+[F:ZAPU]CT_NUM+";"+"001;100;"+FECHACONTABLE+";EUR;1;"+FECHACONTABLE+";"+[F:ZAPU]CT_NUM+";"+FECHACONTABLE+";"+CONDPAGO+";"+CATCONTABLE+";"+[F:ZAPU]
& EC_REFPIECE+";"+
& COLECTIVO+";"+[F:ZAPU]EC_REFPIECE+";"+[F:ZAPU]JO_NUM+"/"+FECHACONTABLE+"/"+[F:ZAPU]EC_PIECE+";"+num$(AUTOIVA)+";"+num$(TIPMOV)
& Using [TIE]
      Endif

      If mid$([F:ZAPU]CG_NUM,1,3)<>"400" and mid$([F:ZAPU]CG_NUM,1,3)<>"410" Then

        #Comprobamos la equivalencia del código de IVA
        Raz CODVAT
        If [F:ZAPU]TA_CODE<>"" Then
          Filter [F:ZIMP] Where 1=1 and ZVAT100=[F:ZAPU]TA_CODE
          If rowcount([F:ZIMP])>0 Then
            For [F:ZIMP]
              CODVAT=[F:ZIMP]VAT
              CODVAT2=[F:ZIMP]VAT2
            Next
          Endif
          Filter [F:ZIMP]
        Endif

        #Extraemos los porcentajes de iva
        POR1=0
        If vireblc(CODVAT,2)<>"" Then
          Filter [F:TRA] Where 1=1 and VAT=vireblc(CODVAT,2) Order By STRDAT Desc
          For [F:TRA]
            PORC1=[F:TRA]VATRAT
            Break
          Next
          Filter [F:TRA]
        Endif

        PORC2=0
        If vireblc(CODVAT2,2)<>"" Then
          Filter [F:TRA] Where 1=1 and VAT=vireblc(CODVAT2,2) Order By STRDAT Desc
          For [F:TRA]
            PORC2=[F:TRA]VATRAT
            Break
          Next
          Filter [F:TRA]
        Endif

        #Calculamos los importes para cada uno de los IVAS
        IMPTAX1=ar2((PORC1*[F:ZAPU]EC_MONTANT)/100)
        IMPTAX2=ar2((PORC2*[F:ZAPU]EC_MONTANT)/100)

        Wrseq "L;"+num$(NUMLINEA)+";100;SPA;;;;;;;;;;;"+[F:ZAPU]CG_NUM+";;;;;;;;;;;;"+num$([F:ZAPU]EC_MONTANT)+";0;"+CODVAT+";"+CODVAT2+";;"+num$(IMPTAX1)+";"+num$(IMPTAX2)+";0;"+num$(TIPMOV) Using [
& TIE]
        NUMLINEA=NUMLINEA+1
      Endif

      If mid$([F:ZAPU]CG_NUM,1,3)="400" or mid$([F:ZAPU]CG_NUM,1,3)="410" Then
        CODFPAGO=0
        Filter [F:ZAPU3] Where 1=1 and EC_PIECE=[F:ZAPU]EC_PIECE and JM_DATE=[F:ZAPU]JM_DATE and N_REGLEMENT<>0
        For [F:ZAPU3]
          CODFPAGO=[F:ZAPU3]N_REGLEMENT
          Break
        Next
        Filter [F:ZAPU3]


        #Extraemos la equivalencia con la forma de pago
        Raz FORMAPAGO
        Filter [F:ZFPA] Where 1=1 and ZPAM100=CODFPAGO
        If rowcount([F:ZFPA])>0 Then
          For [F:ZFPA]
            FORMAPAGO=[F:ZFPA]PAM


          Next
        Endif
        Filter [F:ZFPA]


        If CODFPAGO=0 Then
          FORMAPAGO="CONT"
        Endif

        If FORMAPAGO="SDD" Then
          FORMAPAGO="CONT"
        Endif

        FECHAVEN=mid$(num$([F:ZAPU]EC_ECHEANCE),7,4)+mid$(num$([F:ZAPU]EC_ECHEANCE),4,2)+mid$(num$([F:ZAPU]EC_ECHEANCE),1,2)
        Append VENCIMIENTOS,"E;"+num$(NUMLINEAVEN)+";"+FECHAVEN+";"+FORMAPAGO+";1;"+num$([F:ZAPU]EC_MONTANT*-1)+";1;001"+chr$(13)+chr$(10)
        NUMLINEAVEN=NUMLINEAVEN+1

        Raz CODFPAGO
        CODFPAGO=0
      Endif

      ECPIECE=[F:ZAPU]EC_PIECE
    Next
    Wrseq mid$(VENCIMIENTOS,1,len(VENCIMIENTOS)-2) Using [TIE]
    Openo Using [TIE]
  Endif
  Filter [F:ZAPU]


Return

$IMPORTAR_FICHEROS
  NUMERRORES=0
  GERRTRACE=0

  Gosub IMPORTAR_CLIENTES
  Gosub IMPORTAR_PROVEEDORES
  Gosub ACTUALIZAR_CLIENTES
  Gosub IMPORTAR_CUENTAS
  Gosub IMPORTAR_ASIENTOSV
  Gosub IMPORTAR_ASIENTOSC

  GERRTRACE=NUMERRORES
Return

$IMPORTAR_CLIENTES
  Local Char RESULT  (200)(9000)
  Local Char NOMFIC  (250)
  Local Integer STAT
  Local Char A(250)(1..110)
  Local Char MODELO(10)
  Local Integer TOTOK


  ORDSYS = "dir /b "+filpath("CONTA\CLIENTES","","")+"\*.txt"
  Call SYSTEME2 (adxmac(0),ORDSYS,"",STAT,RESULT) From ORDSYS

  #Recorremos los ficheros leidos comprobando la raiz del mismo
  For JJ=0 To dim(RESULT)-1
    If RESULT(JJ)<>''
      If instr(1,RESULT(JJ),"_")<>0 Then
        MODELO = mid$(RESULT(JJ),1,instr(1,RESULT(JJ),"_")-1)
      Endif
      #If MODELO="ZBPCCONTA" or MODELO="ZGAC" or MODELO="ZJOU" or MODELO="ZBIC" Then
      If MODELO="ZBPCCONTA" Then
        TOTOK=1
        GERRTRACE=0

        NOMFIC= filpath("CONTA\CLIENTES","","") + "\" +RESULT(JJ)
        Call IMPORTSIL(MODELO,NOMFIC) From GIMPOBJ
        If GERRTRACE<>0 Then
          NUMERRORES=NUMERRORES+GERRTRACE
          TOTOK=0
        Endif
        If TOTOK
          Call MOVE(NOMFIC,filpath("CONTA\IMPORTADOS","","") + "\" + RESULT(JJ),STAT)    From ORDSYS
        Else
          Call MOVE(NOMFIC,filpath("CONTA\ERRONEOS","","") + "\" + RESULT(JJ),STAT)    From ORDSYS
        Endif
      Endif
    Endif
  Next


Return

