#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "OUVRE_BATCH"    : Gosub OUVRE_BATCH
  When "EXEC"           : Gosub EXEC
  When "TERMINE"        : Gosub TERMINE
  When "INIT"           : Gosub INIT
  When "OK"             : Gosub OK
Endcase

Return

$OUVRE_BATCH
Return

$EXEC
  Local Char FICORI(250)
  Local Integer MODE_FIC

  Local Char     ASUNTO(250)
  Local Clbfile  ENCABEZADO(0)
  Local Clbfile  PIE(0)
  Local Clbfile  MENSAJE(0)
  Local Char     FICHEROTRAZA(250)
  Local Integer  ERRORIMP
  Local Char     DOSIERACTUAL(30)

  ERRORIMP=1
  DOSIERACTUAL="FANNYSDES"

  Call OUVRE_TRACE("Generación de tarifas de venta") From LECFIC
  Filter [ZFT] Where ZESTADO=0
  For [ZFT]
    FICORI=[ZFT]ZFICHERO

    Call ECR_TRACE("Importando fichero "+[ZFT]ZFICHERO,0) From GESECRAN

    MODE_FIC = filinfo(FICORI, 0)
    If MODE_FIC < 0 :
       #Errbox "Error on file :"-errmes$(-MODE_FIC)
       Call ECR_TRACE("Error en el fichero "+[ZFT]ZFICHERO-errmes$(-MODE_FIC),1) From GESECRAN
       ERRORIMP=2
       Update [ZFT] Where ZFICHERO=FICORI With ZESTADO=1
       #Return
    Else
      Call IMPORTSIL("ZSPLCSV",FICORI) From GIMPOBJ
      If filinfo(FICORI+".err",0)>0
        ERRORIMP=2
        Call ECR_TRACE("Error importando fichero",1) From GESECRAN

        Update [ZFT] Where ZFICHERO=FICORI With ZESTADO=1
      Else
        Update [ZFT] Where ZFICHERO=FICORI With ZESTADO=2
      Endif
      #Infbox(FICORI)
    Endif

  Next

  FICHEROTRAZA=filpath("TRA",GTRACE,"tra")

  If ERRORIMP=1 Then
    ASUNTO="Importación de ficheros de tarifas de ventas - OK - "+DOSIERACTUAL
    Append ENCABEZADO, 'Le informamos que el proceso de importación de tarifas de ventas ha finalizado sastisfactoriamente'+chr$(10)+chr$(10)
    Append ENCABEZADO, 'Puede revisar el fichero de traza que se adjunta en el email para revisar los ficheros importandos'+chr$(10)+chr$(10)
    Append PIE,'Administrador del sistema'
  Elsif ERRORIMP=2 Then
    ASUNTO="Importación de ficheros de tarifas de ventas - ERROR - "+DOSIERACTUAL
    Append ENCABEZADO, 'Le informamos que se han producido errores durante la importación en X3'+chr$(10)+chr$(10)
    Append ENCABEZADO, 'Revise el fichero de traza que se adjunta en el email'+chr$(10)+chr$(10)
    Append PIE,'Administrador del sistema'
  Endif


  Call ECR_TRACE("Proceso finalizado",0) From GESECRAN
  Call FERME_TRACE From LECFIC


  Call LEC_TRACE From LECFIC

  Append MENSAJE,ENCABEZADO
  Append MENSAJE,PIE

  Gosub ENVIAR_EMAIL

  End
Return

$TERMINE
Return

$INIT
  If clalev([F:ZFT])<=0 : Local File ZFILTARVEN [ZFT]  : Endif

Return

$OK
Return

$ENVIAR_EMAIL
  Local Integer  STA
  Local Integer  TRACE
  Local Char     A_USER(250)(1..)
  Local Char     CC_USER(250)(1..)
  Local Char     LEMAIL_DE(250)
  Local Char     ISSUERMAIL(250)
  Local Char     ATTACHMENTS(250)(1..)

  ISSUERMAIL="info@perfumeriaselectiva.net"
  A_USER(1)="info@perfumeriaselectiva.net"
  #A_USER(1)="floren.presumido@grupoazeta.com"

  #A_USER(1)="jennifer.perfum@hotmail.com"
  #A_USER(2)="comercial@perfumeriaselectiva.net"
  #A_USER(3)="info@perfumeriaselectiva.net"

  CC_USER(1)="floren.presumido@grupoazeta.com"
  #CC_USER(2)="josep.rodriguez@grupoazeta.com"
  #CC_USER(3)="angel.delatorre@grupoazeta.com"


  TRACE=2

  #--- Envio del email
  STA = func ASYRMAIL.ASEND_MAIL(GACTX,ISSUERMAIL,A_USER,CC_USER,ASUNTO,MENSAJE,FICHEROTRAZA,TRACE)

Return

