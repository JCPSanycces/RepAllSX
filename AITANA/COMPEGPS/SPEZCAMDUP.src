#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
When "AS_NAOBJNUM" : Gosub AS_NAOBJNUM
Endcase
Return

$AS_NAOBJNUM
Local Char     WOBJET(GLONAOB)
Case [M:ZCAMDUP]NAOBJTIP(nolign-1)
When 1 : WOBJET="BAP" # Citas
When 2 : WOBJET="TSK" # Tareas
When 3 : WOBJET="CLL" # Llamadas
Endcase
Return

######################################################################################
######################################################################################
Subprog IB_NPROY
Raz GBOUT1
If [M:ZCAMDUP]NPOPPNUM(nolign-1)<>""
  GBOUT1="Proyecto "+[M:ZCAMDUP]NPOPPNUM(nolign-1)
Endif
End

Subprog C_NPROY
#Control
Local Integer NOL
GFLDCHR(1) =""
Case status
When 65:             #GMODIF = 1                      # Annulation simple
                     NOL=nolign-1
                     Gosub TEST_ANU
When 68,83:          #GMODIF = 1
                     For NOL=nolign-1 To nolign1-1    # Annulation multiple
                         Gosub TEST_ANU
                         If mkstat : Break : Endif
                     Next NOL
When 75:             #GMODIF=0                        # Modification
                     NOL=nolign-1
                     Gosub TEST_MOD
When 73,82:          NOL=nolign-1                     # Insertion
                     Gosub TEST_INSERT
When 1,4,5,20,21,26,31,92,93
                     Gosub TEST_VALID
Endcase
End

Subprog IB_NACCI
Local Char TXT(60)
Raz GBOUT1
If [M:ZCAMDUP]NAOBJNUM(nolign-1)<>""
  Case [M:ZCAMDUP]NAOBJTIP(nolign-1)
  When 1
    TXT="Cita "
  When 2
    TXT="Tarea "
  When 3
    TXT="Llamada "
  Endcase
  TXT+=[M:ZCAMDUP]NAOBJNUM(nolign-1)
  GBOUT1=TXT
Endif
End


Subprog AM_ZDES(VALEUR)
Variable Char    VALEUR()
Local Char ID(GLONVCR)
ID=func CAMPA_NOM(VALEUR)
If ID<>""
  Call ERREURT("Descripción ya se indicó en campaña nº "+ID, 1) From GESECRAN   #0-Informativo, 1-Error
  mkstat=2
  End
Endif
End

Subprog AM_ZFECINI(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:ZCAMDUP]ZFECFINORI
  Call ERREURT("Fecha inicio nueva campaña deberia ser posterior al "+format$(GFMD,[M:ZCAMDUP]ZFECFINORI), 0) From GESECRAN   #0-Informativo, 1-Error
#  Call ERREURT("Fecha inicio nueva campaña debe ser posterior al "+format$(GFMD,[M:ZCAMDUP]ZFECFINORI), 1) From GESECRAN   #0-Informativo, 1-Error
#  mkstat=2
#  End
Endif
If [M:ZCAMDUP]ZFECFIN=[0/0/0] or [M:ZCAMDUP]ZFECFIN<VALEUR
  Local Integer DIAS
#  DIAS= [M:ZCAMDUP]ZFECFINORI - [M:ZCAMDUP]ZFECINIORI
  DIAS= VALEUR - [M:ZCAMDUP]ZFECINIORI
  [M:ZCAMDUP]ZFECFIN=nday$(nday([M:ZCAMDUP]ZFECFINORI)+DIAS)
Endif
[M:ZCAMDUP]ZFECINI=VALEUR
Call AJUSTAR_FECHAS
End

Subprog AM_ZFECFIN(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:ZCAMDUP]ZFECINI
  Call ERREURT("Fecha final nueva campaña deberia ser posterior al "+format$(GFMD,[M:ZCAMDUP]ZFECINI), 0) From GESECRAN   #0-Informativo, 1-Error
#  Call ERREURT("Fecha final nueva campaña debe ser posterior al "+format$(GFMD,[M:ZCAMDUP]ZFECINI), 1) From GESECRAN   #0-Informativo, 1-Error
#  mkstat=2
#  End
Endif
End

Subprog AV_NPOPPNUM(VALEUR)
Variable Char    VALEUR()
##Antes de campo.....Solo se puede para lineas SIN proyecto
#If [M:ZCAMDUP]NPOPPNUM(nolign-1)<>""
#  mkstat=2
#Endif
End

Subprog AM_NPOPPNUM(VALEUR)
Variable Char    VALEUR()
Local Integer EXISTE
Raz EXISTE
For F=0 To [M:ZCAMDUP]NPROY-1
  If [M:ZCAMDUP]NPOPPNUM(F)=VALEUR
    EXISTE=F+1
    Break
  Endif
Next
If EXISTE
  Call ERREURT("El proyecto ya se indicó en fila "+num$(EXISTE), 1) From GESECRAN   #0-Informativo, 1-Error
  mkstat=2
  End
Endif
If !clalev([F:WOPP])      :  Local File OPPOR   [F:WOPP]  : Endif
Read [F:WOPP]OPP0=VALEUR
If fstat<>0
  Call ERREURT("El proyecto indicado no existe", 1) From GESECRAN   #0-Informativo, 1-Error
  mkstat=2
  End
Endif
Local Integer F,DIAS
DIAS= [M:ZCAMDUP]ZFECINI - [M:ZCAMDUP]ZFECINIORI
F=nolign-1
Gosub DAT_PROY From SUBZCAMDUP
If [M:ZCAMDUP]NPFECINIORI(F)<>[0/0/0] [M:ZCAMDUP]NPOPPDATOPN(F)=nday$(nday([M:ZCAMDUP]NPFECINIORI(F))+DIAS) Endif
If [M:ZCAMDUP]NPFECFINORI(F)<>[0/0/0] [M:ZCAMDUP]NPOPPCDA(F)   =nday$(nday([M:ZCAMDUP]NPFECFINORI(F))+DIAS) Endif
End

