Subprog AM_NPOPPDATOPN(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0]
  If VALEUR<[M:ZCAMDUP]ZFECINI
    Call ERREURT("Fecha apertura proyecto NO puede ser anterior al de inicio campaña "+format$(GFMD,[M:ZCAMDUP]ZFECINI), 1) From GESECRAN   #0-Informativo, 1-Error
    mkstat=2
    End
  Elsif VALEUR>[M:ZCAMDUP]ZFECFIN
    Call ERREURT("Fecha apertura proyecto NO puede ser posterior al final de campaña "+format$(GFMD,[M:ZCAMDUP]ZFECFIN), 1) From GESECRAN   #0-Informativo, 1-Error
    mkstat=2
    End
  Endif
Endif
End

Subprog AM_NPOPPCDA(VALEUR)
Variable Date    VALEUR
If VALEUR<>[0/0/0]
  If VALEUR<[M:ZCAMDUP]ZFECINI
    Call ERREURT("Fecha finalización proyecto NO puede ser anterior al de inicio campaña "+format$(GFMD,[M:ZCAMDUP]ZFECINI), 1) From GESECRAN   #0-Informativo, 1-Error
    mkstat=2
    End
  Elsif VALEUR>[M:ZCAMDUP]ZFECFIN
    Call ERREURT("Fecha finalización proyecto NO puede ser posterior al final de campaña "+format$(GFMD,[M:ZCAMDUP]ZFECFIN), 1) From GESECRAN   #0-Informativo, 1-Error
    mkstat=2
    End
  Elsif VALEUR<[M:ZCAMDUP]NPOPPDATOPN(nolign-1)
    Call ERREURT("Fecha finalización proyecto NO puede ser anterior al de apertura "+format$(GFMD,[M:ZCAMDUP]NPOPPDATOPN(nolign-1)), 1) From GESECRAN   #0-Informativo, 1-Error
    mkstat=2
    End
  Endif
Endif
End

Subprog AM_NPOPPCMP(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_NAOPPNUM(VALEUR)
Variable Char    VALEUR()
Local Integer EXISTE
Raz EXISTE
For F=0 To [M:ZCAMDUP]NPROY-1
  If [M:ZCAMDUP]NPOPPNUM(F)=VALEUR
    EXISTE=F+1
    Break
  Endif
Next
If not EXISTE
  Call ERREURT("El proyecto indicado no existe en la rejilla de proyectos", 1) From GESECRAN   #0-Informativo, 1-Error
  mkstat=2
Endif
End

Subprog AM_NAFECHA(VALEUR)
Variable Date    VALEUR
If VALEUR<[M:ZCAMDUP]ZFECINI
  Call ERREURT("Fecha accion NO puede ser anterior al de inicio campaña "+format$(GFMD,[M:ZCAMDUP]ZFECINI), 1) From GESECRAN   #0-Informativo, 1-Error
  mkstat=2
  End
Elsif VALEUR>[M:ZCAMDUP]ZFECFIN
  Call ERREURT("Fecha accion NO puede ser posterior al final de campaña "+format$(GFMD,[M:ZCAMDUP]ZFECFIN), 1) From GESECRAN   #0-Informativo, 1-Error
  mkstat=2
  End
Endif
End

