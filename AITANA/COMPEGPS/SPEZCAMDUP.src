Variable Char    VALEUR()
End

Subprog AM_NPOPPREP(VALEUR)
Variable Char    VALEUR()
End


######################################################################################
######################################################################################


Subprog AJUSTAR_FECHAS
  Call AJUSTAR_FECHAS_PROY
  Affzo [M:ZCAMDUP]10
  Call AJUSTAR_FECHAS_ACCI
  Affzo [M:ZCAMDUP]15
End

Subprog AJUSTAR_FECHAS_PROY
Local Integer F,DIAS
DIAS= [M:ZCAMDUP]ZFECINI - [M:ZCAMDUP]ZFECINIORI
For F=0 To [M:ZCAMDUP]NPROY-1
  If [M:ZCAMDUP]NPOPPDATOPN(F)=[0/0/0]
    If [M:ZCAMDUP]NPFECINIORI(F)<>[0/0/0] [M:ZCAMDUP]NPOPPDATOPN(F)=nday$(nday([M:ZCAMDUP]NPFECINIORI(F))+DIAS) Endif
    If [M:ZCAMDUP]NPFECFINORI(F)<>[0/0/0] [M:ZCAMDUP]NPOPPCDA(F)   =nday$(nday([M:ZCAMDUP]NPFECFINORI(F))+DIAS) Endif
  Endif
Next
End

Subprog AJUSTAR_FECHAS_ACCI
Local Integer F,DIAS
DIAS= [M:ZCAMDUP]ZFECINI - [M:ZCAMDUP]ZFECINIORI
For F=0 To [M:ZCAMDUP]NACCI-1
  If [M:ZCAMDUP]NAFECHA(F)=[0/0/0]
    [M:ZCAMDUP]NAFECHA(F)=nday$(nday([M:ZCAMDUP]NAFECORI(F))+DIAS)
    While dayn([M:ZCAMDUP]NAFECHA(F))>=6
      [M:ZCAMDUP]NAFECHA(F)=nday$(nday([M:ZCAMDUP]NAFECHA(F))+1)
    Wend
  Endif
Next
End

$TEST_ANU
Local Integer YN : YN=1
MSG= "Está seguro de eliminar esta linea\.\Recuerde que se borraran las acciones comerciales asociadas al proyecto "+[M:ZCAMDUP]NPOPPNUM(NOL)
Call OUINON(MSG, YN) From GESECRAN
If YN=1
  mkstat = 2
  Return
Endif
GFLDCHR(1) ="B"
#Borrar acciones comerciales asociadas al proyecto
Call BORRAR_ACCIONES_PROY([M:ZCAMDUP]NPOPPNUM(NOL))
Return

$TEST_MOD
GFLDCHR(1) ="M"
Return

$TEST_INSERT
GFLDCHR(1) ="A"
Return

$TEST_VALID
Return

Subprog BORRAR_ACCIONES_PROY(NUM)
Value Char NUM
Local Integer I,X
For I = 0 To [M:ZCAMDUP]NACCI - 1
  If [M:ZCAMDUP]NAOPPNUM(I)=NUM
     Dela I,1 [M:ZCAMDUP]NACCI(I)
     X +=1
  Endif
Next
 [M:ZCAMDUP]NACCI -= X
Affzo[M:ZCAMDUP]15
End

