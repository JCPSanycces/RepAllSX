#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Clase ZEDISIHEM_R_NOTES

###############################################################################
# Fuente original Representation EDISIHEM                  (EDIIHEM_RSTD.src) #
###############################################################################
## FJCP --> Personalizacion Amazon

$METHODS
  Case [L]CURPTH
    When ""
      Case [L]ACTION
        When "MET_AFTER_LOAD_REPRESENTATION" : Gosub MET_AFTER_LOAD_REPRESENTATION
      Endcase
  Endcase
Return

$PROPERTIES
  Case [L]CURPRO
  Endcase
Return

#********************************************************************
# Method MET_AFTER_LOAD_REPRESENTATION
#********************************************************************
#
#*
#* @param WCATACT
#* @param WCATCOD
#* @param WPARCOD
#* @param WDUPLICATE
#* @param WTEST
#* @param WSEPDEC #114721
#* @param WERR
#* @return [V]CST_AOK/[V]CST_AERROR
#*!
$MET_AFTER_LOAD_REPRESENTATION
  Local Integer I, J
  Local Integer WOK     : WOK     = [V]CST_AOK
  Local Integer WSTATUS : WSTATUS = [V]CST_AERROR

  Case WCATACT
    When 1 :
      Case WPARCOD
        When "EDICOM" : Gosub EDICOM_ISSUE
        When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
      Endcase
    When 2 :
      Case WPARCOD
        When "EDICOM" : Gosub EDICOM_RECEIPT
        When Default  : WSTATUS = [V]CST_AERROR : WERR = ""
      Endcase
  Endcase

  ARET_VALUE = WSTATUS
Return



################################################################################
$EDICOM_ISSUE
  #####################################
  #####           HEAD          #######
  #####################################
  Local Char WCODE(20), WREP(20), WPROP(25) # 114721
  WREP=right$(this.AINF.NAMCLA,3)

  #Searching EDICPY code
  Local File EDICPYPAR [ECP]

  Read [ECP]ECP0=this.SIV.CPY;WPARCOD
  If fstat=[V]CST_AOK
    this.EDICPY=[F:ECP]EXCEDICOD
    this.EXCEDICOD=[F:ECP]EXCEDICOD  # FJCP esta informado en el fichero secuencial. pero no se inicializa.
  Endif
  LogicClose File [ECP]

  # Searching EDICOM code from finantial site (EDIFCYPAY)
  Local Char WFFCY(5)
  Local File FACILITY [FCY]

  Read [FCY]FCY0=this.SIV.SALFCY
  If fstat=[V]CST_AOK
    WFFCY=[F:FCY]FINRSPFCY
  Endif
  If WFFCY<>""
    WCODE=func TRTFUNEDI.INV_EDICODE_FCY(WFFCY,WPARCOD)
    this.EDIFCYPAY=left$(WCODE,17)
  Endif

  LogicClose File [FCY]

  # Searching EDICOM code from customer (EDIBPCCOD)
  Local File EDIBPRPAR [EBP]

  Read [EBP]EBP0=1;this.SIV.BPCORD;this.SIV.BPAADD;WPARCOD
  If fstat=[V]CST_AOK
    this.EDIBPCCOD=[F:EBP]EXCEDICOD
  Endif

  # Searching EDICOM code from customer (EDIBPCINV)
  Read [EBP]EBP0=1;this.SIV.BPCINV;this.SIV.SIH.BPAINV;WPARCOD
  If fstat=[V]CST_AOK
    this.EDIBPCINV=[F:EBP]EXCEDICOD
  Endif
  # Searching EDICOM code from customer (EDIBPCPAY)
  Local Char WADR(5)

  WADR=this.SIV.SIH.BPAPAY
  If this.SIV.SIH.BPAPAY="": WADR=this.SIV.SIH.BPAINV: Endif

  Read [EBP]EBP0=1;this.SIV.BPRPAY;WADR;WPARCOD
  If fstat=[V]CST_AOK
    this.EDIBPCPAY=[F:EBP]EXCEDICOD
  Endif

  LogicClose File [EBP]

  # Filling function property (EDIFUNCTION)
  If WTEST = [V]CST_AYES
    this.EDIFUNCTION="9"
  Else
    this.EDIFUNCTION="7"
  Endif
#  Local File EDITRKDOC [EDK]
#
#  Filter [EDK] Where DOCID=this.SIV.NUM and CATTYP=2 and TESTFLG<>2
#  Read First
#  If fstat=[V]CST_AOK
#    this.EDIFUNCTION="7"
#  Else
#    this.EDIFUNCTION="9"
#  Endif
#
#  LogicClose File [EDK]

  #Filling BPAADDLIGx properties
  For I=1 To maxtab(this.SIV.SIH.C_BPAADDLIG)
    Case I
      When 1: this.BPAADDLIG =this.SIV.SIH.C_BPAADDLIG(I).BPAADDLIG
      When 2: this.BPAADDLIG1=this.SIV.SIH.C_BPAADDLIG(I).BPAADDLIG
    Endcase
  Next

  # Formating credit note number (INVNUM property)
  this.ORINUM=right$(this.SIV.SIH.INVNUM,4)

  # Formating invoice number (EDINVNUM property)
  Local Char EDINUM(20)
  EDINUM=space$(20-len(this.SIV.NUM))+this.SIV.NUM
  this.EDINVNUM=right$(EDINUM,6)

  #Formating INVDAT   (EDIINVDAT property)
  this.EDIINVDAT=format$("D:YYYYMMDD",this.SIV.INVDAT)

  # Filling BPCINVNAME property
  Local Char WBNAME(35)(1..2)

  For I=1 To maxtab(this.SIV.C_BPINAM)
    WBNAME(I)=this.SIV.C_BPINAM(I).BPINAM
  Next
  this.BPCINVNAME=WBNAME(1)-WBNAME(2)

  # Filling BPCRN property
  Local File BPARTNER [BPR]

  Read [BPR]BPR0=this.SIV.BPCINV
  If fstat=[V]CST_AOK
    this.BPCRN=[F:BPR]CRN
    # FJCP --> Personalizacion Amazon
    this.ZBPCCRY=[F:BPR]CRY
    this.ZBPCEECNUM = [F:BPR]EECNUM
    # Fin FJCP --> Personalizacion Amazon
  Endif

# issue 114721 Decimal separator in generated file
  #Calculating EDITOTGRO property
  WPROP=format$("N0:11.3#",func TRTFUNEDI.INV_TOTAMT(this.SIV.NUM,1))
  this.EDITOTGRO=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

  #Calculating EDITOTNET property
  WPROP=format$("N0:11.3#",func TRTFUNEDI.INV_TOTAMT(this.SIV.NUM,2))
  this.EDITOTNET=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

  #Calculating EDITOTCHG property
  WPROP=format$("N0:11.3#",func TRTFUNEDI.INV_CHADISC(this.SIV.NUM,1))
  this.EDITOTCHG=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

  #Calculating EDITOTDSC property
  WPROP=format$("N0:11.3#",abs(func TRTFUNEDI.INV_CHADISC(this.SIV.NUM,2)))
  this.EDITOTDSC=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
#/ 114721

  # Transcoding NODE property (in STD table 220)
  Local File ASHWPAR [ASWP]
  Filter [ASWP] Where CODREP=WREP and CODLNK="NODE"
  Read First
  If fstat=[V]CST_AOK
    Local Char WNODE(20), WTYP(1)
    Local Integer WTAB
    WTYP=num$(this.SIV.INVTYP)
    WTAB=val([F:ASWP]VALEUR)
    WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
    this.NODE= left$(WNODE,3)
  Endif

  # Calculating ORDNUM property
  Local Char WPED(20)
  Local Shortint WTYP

  Filter [ASWP] Where CODREP=WREP and CODLNK="ORDNUM"
  Read First
  If fstat=[V]CST_AOK
    Local Shortint WTYP
    WTYP=val([F:ASWP]VALEUR)
    WPED=func TRTFUNEDI.INV_SOH(this.SIV.NUM,WTYP)
    this.ORDNUM= right$(WPED,4)
  Endif

 # issue 114721 Decimal separator in generated file
 # Calculating EDIAMTTAX property
  Local Shortint MAXL
  MAXL=maxtab(this.SIV.SVV)
  WPROP=format$("N0:11.3#",sum(0,this.SIV.SVV(1..MAXL).AMTTAX))
  this.EDIAMTTAX=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

  # Calculating EDIDUDx properties
  this.EDIDUD1=func TRTFUNEDI.INV_OPIT(this.SIV.NUM,1,1)
  this.EDIDUD2=func TRTFUNEDI.INV_OPIT(this.SIV.NUM,1,2)
  this.EDIDUD3=func TRTFUNEDI.INV_OPIT(this.SIV.NUM,1,3)

  # Calculating EDIAMTDUDx properties
  WPROP=format$("N0:11.3#",func TRTFUNEDI.INV_OPIT(this.SIV.NUM,2,1))
  this.EDIAMTDUD1=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
  WPROP=format$("N0:11.3#",func TRTFUNEDI.INV_OPIT(this.SIV.NUM,2,2))
  this.EDIAMTDUD2=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
  WPROP=format$("N0:11.3#",func TRTFUNEDI.INV_OPIT(this.SIV.NUM,2,3))
  this.EDIAMTDUD3=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

  #Filling BASTAXx, VATRATx and AMTTAXx
  For I=1 To maxtab(this.SIV.SVV)
    Case I
      When 1: WPROP=format$("N0:11.3#",this.SIV.SVV(I).BASTAX)
              this.BASTAX1=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              WPROP=format$("N0:4.3#", this.SIV.SVV(I).VATRAT)
              this.VATRAT1=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              WPROP=format$("N0:11.3#",this.SIV.SVV(I).AMTTAX)
              this.AMTTAX1=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      When 2: WPROP=format$("N0:11.3#",this.SIV.SVV(I).BASTAX)
              this.BASTAX2=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              WPROP=format$("N0:4.3#", this.SIV.SVV(I).VATRAT)
              this.VATRAT2=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              WPROP=format$("N0:11.3#",this.SIV.SVV(I).AMTTAX)
              this.AMTTAX2=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      When 3: WPROP=format$("N0:11.3#",this.SIV.SVV(I).BASTAX)
              this.BASTAX3=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              WPROP=format$("N0:4.3#", this.SIV.SVV(I).VATRAT)
              this.VATRAT3=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              WPROP=format$("N0:11.3#",this.SIV.SVV(I).AMTTAX)
              this.AMTTAX3=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      When 4: WPROP=format$("N0:11.3#",this.SIV.SVV(I).BASTAX)
              this.BASTAX4=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              WPROP=format$("N0:4.3#", this.SIV.SVV(I).VATRAT)
              this.VATRAT4=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              WPROP=format$("N0:11.3#",this.SIV.SVV(I).AMTTAX)
              this.AMTTAX4=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      When 5: WPROP=format$("N0:11.3#",this.SIV.SVV(I).BASTAX)
              this.BASTAX5=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              WPROP=format$("N0:4.3#", this.SIV.SVV(I).VATRAT)
              this.VATRAT5=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              WPROP=format$("N0:11.3#",this.SIV.SVV(I).AMTTAX)
              this.AMTTAX5=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      When 6: WPROP=format$("N0:11.3#",this.SIV.SVV(I).BASTAX)
              this.BASTAX6=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              WPROP=format$("N0:4.3#", this.SIV.SVV(I).VATRAT)
              this.VATRAT6=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
              WPROP=format$("N0:11.3#",this.SIV.SVV(I).AMTTAX)
              this.AMTTAX6=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    Endcase
  Next
#/ 114721


  # Transcoding EDICNOREN (using table 221 in STD)
  Filter [ASWP] Where CODREP=WREP and CODLNK="EDICNOREN"
  Read First
  If fstat=[V]CST_AOK
    Local Char WNODE(20), WTYP(20)
    Local Integer WTAB
    WTYP=num$(this.SIV.CNOREN)
    WTAB=val([F:ASWP]VALEUR)
    WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
    this.EDICNOREN= left$(WNODE,3)
  Endif

  # Calculating DELNUM property
  Local Char WSDH(20)
  Local Shortint WTYP

  Filter [ASWP] Where CODREP=WREP and CODLNK="DELNUM"
  Read First
  If fstat=[V]CST_AOK
    Local Shortint WTYP
    WTYP=val([F:ASWP]VALEUR)
    WSDH=func TRTFUNEDI.INV_SDH(this.SIV.NUM,WTYP)
    this.DELNUM= right$(WSDH,4)
  Endif

  # Calculating CONTRA property
  Local Char WCON(20)
  Local Shortint WTYP

  Filter [ASWP] Where CODREP=WREP and CODLNK="CONTRA"
  Read First
  If fstat=[V]CST_AOK
    Local Shortint WTYP
    WTYP=val([F:ASWP]VALEUR)
    WCON=func TRTFUNEDI.INV_CONTRACT(this.SIV.NUM,WTYP)
    this.CONTRA= right$(WCON,4)
  Endif

  # Transcoding EDIPTE property (in STD table 222)
  Filter [ASWP] Where CODREP=WREP and CODLNK="EDIPTE"
  Read First
  If fstat=[V]CST_AOK
    Local Char WNODE(20), WTYP(20)
    Local Integer WTAB
    WTYP=num$(this.SIV.SIH.PTE)
    WTAB=val([F:ASWP]VALEUR)
    WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
    this.EDIPTE= left$(WNODE,3)
  Endif

  # Transcoding EDICUR property (in STD table 223)
  Filter [ASWP] Where CODREP=WREP and CODLNK="EDICUR"
  Read First
  If fstat=[V]CST_AOK
    Local Char WNODE(20), WTYP(20)
    Local Integer WTAB
    WTYP=num$(this.SIV.CUR)
    WTAB=val([F:ASWP]VALEUR)
    WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
    this.EDICUR= left$(WNODE,3)
  Endif
  If this.EDICUR="": this.EDICUR=this.SIV.CUR : Endif

  # Transcoding EDIVATx  properties (in STD table 225)
  Filter [ASWP] Where CODREP=WREP and CODLNK="EDIVAT"
  Read First
  If fstat=[V]CST_AOK
    Local Char WNODE(20), WTYP(20)
    Local Integer WTAB

    For I=1 To maxtab(this.SIV.SVV)
      If I=7: Break: Endif
      WTYP=num$(this.SIV.SVV(I).VAT)
      WTAB=val([F:ASWP]VALEUR)
      WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
      Case I
        When 1: this.EDIVAT1= left$(WNODE,3)
        When 2: this.EDIVAT2= left$(WNODE,3)
        When 3: this.EDIVAT3= left$(WNODE,3)
        When 4: this.EDIVAT4= left$(WNODE,3)
        When 5: this.EDIVAT5= left$(WNODE,3)
        When 6: this.EDIVAT6= left$(WNODE,3)
      Endcase
    Next
  Endif

  # Transcoding EDIQUALx properties (in STD table 224)
  Local Shortint WQTYP
  For I=1 To maxtab(this.SIV.SVF)
    If I=6: Break: Endif
    WQTYP=func TRTFUNEDI.INV_QUALIF_DISC(this.SIV.NUM, this.SIV.SVF(I).DTA)
    Filter [ASWP] Where CODREP=WREP and CODLNK="EDIQUAL"
    Read First
    If fstat=[V]CST_AOK
      Local Char WNODE(20), WTYP(20)
      Local Integer WTAB
      WTYP=num$(WQTYP)
      WTAB=val([F:ASWP]VALEUR)
      WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
      Case I
        When 1: this.EDIQUAL1= left$(WNODE,3)
        When 2: this.EDIQUAL2= left$(WNODE,3)
        When 3: this.EDIQUAL3= left$(WNODE,3)
        When 4: this.EDIQUAL4= left$(WNODE,3)
        When 5: this.EDIQUAL5= left$(WNODE,3)
      Endcase
    Endif
  Next

  # Transcoding DCTYPx properties (in STD table 226)
  Local Shortint WQTYP
  For I=1 To maxtab(this.SIV.SVF)
    If I=6: Break: Endif
    WQTYP=this.SIV.SVF(I).DTA
    Filter [ASWP] Where CODREP=WREP and CODLNK="DCTYP"
    Read First
    If fstat=[V]CST_AOK
      Local Char WNODE(20), WTYP(20)
      Local Integer WTAB
      WTYP=num$(WQTYP)
      WTAB=val([F:ASWP]VALEUR)
      WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
      Case I
        When 1: this.DCTYP1= left$(WNODE,3)
        When 2: this.DCTYP2= left$(WNODE,3)
        When 3: this.DCTYP3= left$(WNODE,3)
        When 4: this.DCTYP4= left$(WNODE,3)
        When 5: this.DCTYP5= left$(WNODE,3)
      Endcase
    Endif
  Next

  # Calculating REALDATE property
  Local Char WCON(20)
  Local Shortint WTYP

  Filter [ASWP] Where CODREP=WREP and CODLNK="REALDATE"
  Read First
  If fstat=[V]CST_AOK
    Local Shortint WTYP
    WTYP=val([F:ASWP]VALEUR)
    this.REALDATE=func TRTFUNEDI.INV_DATEDEL(this.SIV.NUM,WTYP)
  Endif

  LogicClose File [ASWP]
# issue 114721 Decimal separator in generated file
  # Filling DCAMTx properties
  For I=1 To maxtab(this.SIV.SVF)
    If I=6 : Break: Endif
    Local Char WZERO(8)
    WPROP=format$("N0:4.3#",0)
    WZERO=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    Case I
        When 1: If this.SIV.SVF(I).AMTCOD<>1: this.DCPER1=WZERO Else WPROP=format$("N0:4.3#",this.SIV.SVF(I).DTAAMT):this.DCPER1=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC): Endif
                WPROP=format$("N0:11.3#",abs(this.SIV.SVF(I).DTANOT))
                this.DCAMT1=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        When 2: If this.SIV.SVF(I).AMTCOD<>1: this.DCPER2=WZERO Else WPROP=format$("N0:4.3#",this.SIV.SVF(I).DTAAMT):this.DCPER2=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC): Endif
                WPROP=format$("N0:11.3#",abs(this.SIV.SVF(I).DTANOT))
                this.DCAMT2=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        When 3: If this.SIV.SVF(I).AMTCOD<>1: this.DCPER3=WZERO Else WPROP=format$("N0:4.3#",this.SIV.SVF(I).DTAAMT):this.DCPER3=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC): Endif
                WPROP=format$("N0:11.3#",abs(this.SIV.SVF(I).DTANOT))
                this.DCAMT3=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        When 4: If this.SIV.SVF(I).AMTCOD<>1: this.DCPER4=WZERO Else WPROP=format$("N0:4.3#",this.SIV.SVF(I).DTAAMT):this.DCPER4=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC): Endif
                WPROP=format$("N0:11.3#",abs(this.SIV.SVF(I).DTANOT))
                this.DCAMT4=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
        When 5: If this.SIV.SVF(I).AMTCOD<>1: this.DCPER5=WZERO Else WPROP=format$("N0:4.3#",this.SIV.SVF(I).DTAAMT):this.DCPER5=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC): Endif
                WPROP=format$("N0:11.3#",abs(this.SIV.SVF(I).DTANOT))
                this.DCAMT5=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
      Endcase
  Next
#/ 114721

  #Filling CPYNAME & CPYCRN properties
  Local File COMPANY [CPY]
  Read [CPY]CPY0=this.SIV.CPY
  If fstat=[V]CST_AOK
    this.CPYNAME=[F:CPY]CPYNAM
    this.CPYCRN =[F:CPY]CRN

    # FJCP
    this.ZCPYCRY =[F:CPY]CRY
    this.ZCPYEECNUM=[F:CPY]EECNUM
    # Fin FJCP
  Endif

  LogicClose File [CPY]

  #Filling CPYADD, CPYCTY & CPYPOSCOD  properties
  Local File BPADDRESS
  Filter [BPA] Where BPATYP=2 and BPANUM=this.SIV.CPY and BPAADDFLG=2
  Read First
  If fstat=[V]CST_AOK
    this.CPYADD   =[F:BPA]BPAADDLIG(0)
    this.CPYCTY   =[F:BPA]CTY
    this.CPYPOSCOD=[F:BPA]POSCOD
  Endif

  LogicClose File [BPA]
# issue 114721 Decimal separator in generated file
  #Formating decimal fields from the properties:
  WPROP=format$("N0:11.3#",this.SIV.SIH.AMTATI)
  this.EDIAMTATI=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

  WPROP=format$("N0:11.3#",this.SIV.SIH.AMTNOT)
  this.EDIAMTNOT=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
#/ 114721

  ####################################
  ######           LINES         #####
  ####################################
  #Filling R_SID collection
  Local Integer WSEQ , WNBL

  For I=1 To maxtab(this.SIV.SID)
    WSEQ = fmet this.ADDLINE('R_SID',[V]CST_ALASTPOS)
    this.R_SID(WSEQ).INVNUMLIN=this.EDINVNUM    # INVNUMLIN property
    this.R_SID(WSEQ).EDISIDLIN=WSEQ             # EDISIDLIN property
    this.R_SID(WSEQ).BLANKLIN=this.BLANK
    Local File ITMMASTER [ITM]
    Read [ITM]ITM0=this.SIV.SID(I).ITMREF
    If fstat= [V]CST_AOK
      this.R_SID(WSEQ).EANCOD=[F:ITM]EANCOD                           ####R_SID.EANCOD
      this.R_SID(WSEQ).REFITMBPC=func TRTFUNEDI.INV_REFCLI(this.SIV.BPCORD, this.SIV.SID(I).ITMREF) ####R_SID.REFITMBPC

        ### FJCP Si codigo de Barras vacio se informa de la referencia del cliente
        If [F:ITM]EANCOD="" or  len([F:ITM]EANCOD)<>13 Then
           this.R_SID(WSEQ).EANCOD=this.R_SID(WSEQ).REFITMBPC
        Endif
    Endif

    LogicClose File [ITM]

    #Calculating discounts to trait
    Local Shortint WOK, WDTA(4), WDISQUA(4), WDISEQ(4)

    WOK=func TRTFUNEDI.INV_DISCTOTRAIT(this.SIV.PLISTC,this.SIV.NUM,this.SIV.SID(I).SIDLIN,WDTA(),WDISQUA(),WDISEQ())


    # Transcoding EDIVATLINx  properties (in STD table 225)
    Local File ASHWPAR [ASWP]
    Filter [ASWP] Where CODREP=WREP and CODLNK="EDIVAT"
    Read First
    If fstat=[V]CST_AOK
      Local Char WNODE(20), WTYP(20)
      Local Integer WTAB
      For J=1 To maxtab(this.SIV.SID.C_VAT)
        If J=4: Break: Endif
        WTYP=num$(this.SIV.SID.C_VAT(J).VAT)
        WTAB=val([F:ASWP]VALEUR)
        WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
        Case J                                            ####R_SID.VATLINx
          When 1: this.R_SID(WSEQ).VATLIN1= left$(WNODE,3)
          When 2: this.R_SID(WSEQ).VATLIN2= left$(WNODE,3)
          When 3: this.R_SID(WSEQ).VATLIN3= left$(WNODE,3)
        Endcase
      Next
    Endif

    # Transcoding EDISAU  properties (in STD table 228)
    Filter [ASWP] Where CODREP=WREP and CODLNK="EDISAU"
    Read First
    If fstat=[V]CST_AOK
      Local Char WNODE(20), WTYP(20)
      Local Integer WTAB
      WTYP=num$(this.SIV.SID(I).SAU)
      WTAB=val([F:ASWP]VALEUR)
      WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
      this.R_SID(WSEQ).EDISAU= left$(WNODE,3)
      If this.R_SID(WSEQ).EDISAU="": this.R_SID(WSEQ).EDISAU=this.SIV.SID(I).SAU : Endif
    Endif

    # Transcoding EDISTOMGT  properties (in STD table 229)
    Filter [ASWP] Where CODREP=WREP and CODLNK="EDISTOMGT"
    Read First
    If fstat=[V]CST_AOK
      Local Char WNODE(20), WTYP(20)
      Local Integer WTAB
      WTYP=num$(this.SIV.SID(I).STOMGTCOD)
      WTAB=val([F:ASWP]VALEUR)
      WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)
      this.R_SID(WSEQ).EDISTOMGT= left$(WNODE,3)
    Endif

    # Transcoding EDIQUALx  properties (in STD table 224)
    Filter [ASWP] Where CODREP=WREP and CODLNK="EDIQUAL"
    Read First
    If fstat=[V]CST_AOK
      Local Char WNODE(20), WTYP(20)
      Local Integer WTAB
      WTAB=val([F:ASWP]VALEUR)
      For J=1 To 4
        Case J
          When 1: WTYP=num$(WDISQUA(0))
          When 2: WTYP=num$(WDISQUA(1))
          When 3: WTYP=num$(WDISQUA(2))
          When 4: WTYP=num$(WDISQUA(3))
        Endcase

        WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)

        Case J
          When 1: this.R_SID(WSEQ).QUALIN1= left$(WNODE,3)  ####R_SID.QUALINx
          When 2: this.R_SID(WSEQ).QUALIN2= left$(WNODE,3)
          When 3: this.R_SID(WSEQ).QUALIN3= left$(WNODE,3)
          When 4: this.R_SID(WSEQ).QUALIN4= left$(WNODE,3)
        Endcase
      Next
    Endif

    #Transcoding DCTYPLINx properties (table 227 in STD)
    For J=1 To 4
      Filter [ASWP] Where CODREP=WREP and CODLNK="DCTYPLIN"
      Read First
      If fstat=[V]CST_AOK
        Local Char WNODE(20), WTYP(20)
        Local Integer WTAB
        WTAB=val([F:ASWP]VALEUR)

        Case J
          When 1: WTYP=num$(WDTA(0))
          When 2: WTYP=num$(WDTA(1))
          When 3: WTYP=num$(WDTA(2))
          When 4: WTYP=num$(WDTA(3))
        Endcase

        WNODE=func TRTFUNEDI.TRANSCODE(WTYP,WTAB,WCATACT)

        Case J
          When 1: this.R_SID(WSEQ).DCTYPLIN1= left$(WNODE,3)
          When 2: this.R_SID(WSEQ).DCTYPLIN2= left$(WNODE,3)
          When 3: this.R_SID(WSEQ).DCTYPLIN3= left$(WNODE,3)
          When 4: this.R_SID(WSEQ).DCTYPLIN4= left$(WNODE,3)
        Endcase
      Endif
    Next


    LogicClose File [ASWP]
# issue 114721 Decimal separator in generated file
    If this.R_SID(WSEQ).VATLIN2<>""
      WPROP=format$("N0:11.3#",func TRTFUNEDI.INV_PERTAXLIN(this.SIV.NUM,this.SIV.SID(I).SIDLIN,2))
      this.R_SID(WSEQ).TAXLIN2=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    Endif
    If this.R_SID(WSEQ).VATLIN3<>""
      WPROP=format$("N0:11.3#",func TRTFUNEDI.INV_PERTAXLIN(this.SIV.NUM,this.SIV.SID(I).SIDLIN,3))
      this.R_SID(WSEQ).TAXLIN3=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    Endif
#/ 114721

    # Calculating SEQLINx properties
    Local Shortint WOKK
    For J=1 To 4
      Case J
        When 1: this.R_SID(WSEQ).SEQLIN1=num$(WDISEQ(0))
        When 2: If val(this.R_SID(WSEQ).SEQLIN1)<>0 and WDISEQ(1)<>0
                  this.R_SID(WSEQ).SEQLIN2=num$(val(this.R_SID(WSEQ).SEQLIN1)+1)
                Else this.R_SID(WSEQ).SEQLIN2=num$(WDISEQ(1))
                Endif
        When 3: If val(this.R_SID(WSEQ).SEQLIN2)<>0 and WDISEQ(2)<>0
                  this.R_SID(WSEQ).SEQLIN3=num$(val(this.R_SID(WSEQ).SEQLIN2)+1)
                Else this.R_SID(WSEQ).SEQLIN3=num$(WDISEQ(2))
                Endif
        When 4: If val(this.R_SID(WSEQ).SEQLIN3)<>0 and WDISEQ(3)<>0
                  this.R_SID(WSEQ).SEQLIN4=num$(val(this.R_SID(WSEQ).SEQLIN3)+1)
                Else this.R_SID(WSEQ).SEQLIN4=num$(WDISEQ(3))
                Endif
      Endcase
    Next

    # Calculating DCPERLINx & DCAMTLINx properties
    Local Decimal WAMT(4), WRES, H
    For H=0 To 3
      If WDTA(H)<>0:  WAMT(H)=evalue("this.SIV.SID(I).DISCRGVAL"+num$(WDTA(H))): Endif
    Next

  # issue 114721 Decimal separator in generated file
    For J=1 To 4
      Local Shortint WTYP
      WTYP=func TRTFUNEDI.INV_PERAMTLIN_DISC(this.SIV.NUM,WDTA(J-1))
      Case J
        When 1: If WTYP=1
                  WPROP=format$("N0:4.3#",0)
                  this.R_SID(WSEQ).DCPERLIN1=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                  WPROP=format$("N0:11.3#",abs(WAMT(J-1)))
                  this.R_SID(WSEQ).DCAMTLIN1=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                Else
                  WPROP=format$("N0:4.3#",WAMT(J-1))
                  this.R_SID(WSEQ).DCPERLIN1=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                  WRES=func TRTFUNEDI.INV_CALAMTPERLIN_DISC(this.SIV.NUM,this.SIV.SID(I).GROPRI, WAMT(),WDTA(J-1),J)
                  WPROP=format$("N0:11.3#",abs(WRES))
                  this.R_SID(WSEQ).DCAMTLIN1=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                Endif
        When 2: If WTYP=1
                  WPROP=format$("N0:4.3#",0)
                  this.R_SID(WSEQ).DCPERLIN2=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                  WPROP=format$("N0:11.3#",abs(WAMT(J-1)))
                  this.R_SID(WSEQ).DCAMTLIN2=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                Else
                  WPROP=format$("N0:4.3#",WAMT(J-1))
                  this.R_SID(WSEQ).DCPERLIN2=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                  WRES=func TRTFUNEDI.INV_CALAMTPERLIN_DISC(this.SIV.NUM,this.SIV.SID(I).GROPRI, WAMT(),WDTA(J-1),J)
                  WPROP=format$("N0:11.3#",abs(WRES))
                  this.R_SID(WSEQ).DCAMTLIN2=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                Endif
        When 3: If WTYP=1
                  WPROP=format$("N0:4.3#",0)
                  this.R_SID(WSEQ).DCPERLIN3=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                  WPROP=format$("N0:11.3#",abs(WAMT(J-1)))
                  this.R_SID(WSEQ).DCAMTLIN3=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                Else
                  WPROP=format$("N0:4.3#",WAMT(J-1))
                  this.R_SID(WSEQ).DCPERLIN4=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                  WRES=func TRTFUNEDI.INV_CALAMTPERLIN_DISC(this.SIV.NUM,this.SIV.SID(I).GROPRI, WAMT(),WDTA(J-1),J)
                  WPROP=format$("N0:11.3#",abs(WRES))
                  this.R_SID(WSEQ).DCAMTLIN4=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                Endif
        When 4: If WTYP=1
                  WPROP=format$("N0:4.3#",0)
                  this.R_SID(WSEQ).DCPERLIN4=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                  WPROP=format$("N0:11.3#",abs(WAMT(J-1)))
                  this.R_SID(WSEQ).DCAMTLIN4=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                Else
                  WPROP=format$("N0:4.3#",WAMT(J-1))
                  this.R_SID(WSEQ).DCPERLIN4=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                  WRES=func TRTFUNEDI.INV_CALAMTPERLIN_DISC(this.SIV.NUM,this.SIV.SID(I).GROPRI, WAMT(),WDTA(J-1),J)
                  WPROP=format$("N0:11.3#",abs(WRES))
                  this.R_SID(WSEQ).DCAMTLIN4=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
                Endif
      Endcase
    Next

    # Filling QTYFREE property
    WPROP=format$("N0:15#",func TRTFUNEDI.INV_QTYFREE(this.SIV.NUM,this.SIV.SID(I).SIDLIN))
    this.R_SID(WSEQ).QTYFREE=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)

    #Formating decimal fields from properties:
    Local Decimal WRES(3)
    WPROP =format$("N0:11.3#",this.SIV.SID(I).QTY)
    this.R_SID(WSEQ).EDIQTY=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    WPROP=format$("N0:11.3#",this.SIV.SID(I).GROPRI)
    this.R_SID(WSEQ).EDIGROPRI =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    WPROP=format$("N0:11.3#",this.SIV.SID(I).NETPRINOT)
    this.R_SID(WSEQ).EDINETPRINOT =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    WPROP=format$("N0:4.3#",this.SIV.SID(I).RATTAXLIN)
    this.R_SID(WSEQ).EDIRATTAXLIN =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    For J=1 To maxtab(this.SIV.SID(I).C_AMTTAXLIN)
      If maxtab(this.SIV.SID(I).C_AMTTAXLIN(J))>0
        WRES(J-1)=this.SIV.SID(I).C_AMTTAXLIN(J).AMTTAXLIN
      Endif
    Next
    WPROP=format$("N0:11.3#",WRES(0))
    this.R_SID(WSEQ).EDAMTTAXLIN1=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    WPROP=format$("N0:11.3#",WRES(1))
    this.R_SID(WSEQ).EDAMTTAXLIN2=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    WPROP=format$("N0:11.3#",WRES(2))
    this.R_SID(WSEQ).EDAMTTAXLIN3=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    WPROP=format$("N0:11.3#",this.SIV.SID(I).AMTNOTLIN)
    this.R_SID(WSEQ).EDIAMTNOTLIN=func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
    this.R_SID(WSEQ).EDISOHLIN    =right$(this.SIV.SID(I).SOHNUM,4)

 # FJCP Personalizacion Amazon
 # this.R_SID(WSEQ).EDISDHLIN    =right$(this.SIV.SID(I).SDHNUM,4)
    If len(this.SIV.SID(I).SDHNUM)<=17
     this.R_SID(WSEQ).EDISDHLIN    =this.SIV.SID(I).SDHNUM
    Else
     this.R_SID(WSEQ).EDISDHLIN    =right$(this.SIV.SID(I).SDHNUM,len(this.SIV.SID(I).SDHNUM)-16)
    Endif

    # FJCP --> Personalizacion Amazon
    # Leer pedido origen
    Local Char WSOHNUM (20)
    Local File SORDER [SOH]
    If this.SIV.SID(I).SOHNUM<>""
       WSOHNUM=this.SIV.SID(I).SOHNUM
       Raz [SOH]
       Read [SOH]SOH0=WSOHNUM
       If !fstat Then
           this.R_SID(WSEQ).ZORDNUMLIN=[F:SOH]CUSORDREF
       Else
           this.R_SID(WSEQ).ZORDNUMLIN=""
       Endif
    Endif
    LogicClose File [SOH]
    # Fin FJCP --> Personalizacion Amazon


#/ 114721
    #############################
    ##  NOTES lines            ##
    #############################
    #Filling text of line
    Local Char WTEXLIN (70)(5)
    Local Integer WOK

    WOK=func TRTFUNEDI.INV_NUMOBSL(this.SIV.SID(I).NUM,this.SIV.SID(I).SIDLIN,WPARCOD,WTEXLIN())
    If WOK=1
      Local Integer L
      WNBL+=1

   # issue 114721 Decimal separator in generated file
      For L=0 To 4
        If WTEXLIN(L)<>""
          this.R_SID(WSEQ).TLINVNUM =this.R_SID(WSEQ).INVNUMLIN
          WPROP=format$("N0:5#",this.R_SID(WSEQ).EDISIDLIN)
          this.R_SID(WSEQ).TLNUMOBS =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
          WPROP=format$("N0:3#",WNBL)
          this.R_SID(WSEQ).NUMOBSL  =func TRTFUNEDI.FMTDEC(WPROP,WSEPDEC)
          this.R_SID(WSEQ).NOTTYPL  ="AAI"
          Assign ("this.R_SID("+num$(WSEQ)+").NOTLIN"+num$(L+1)) With WTEXLIN(L)
        Endif
      Next
    Endif
  Next I
#/ 114721

  #############################
  ##          NOTES          ##
  #############################
  #Filling properties for Notes file
  Local Integer WNSEQ, WOKK
  Local Char WNOTES(70)(5)

  For N=1 To 4
    Raz WNOTES()
    WOKK=func TRTFUNEDI.INV_NUMOBS(this.SIV.NUM,N,WNOTES())
    If WOKK=1
      WNSEQ = fmet this.ADDLINE('R_NOTES',[V]CST_ALASTPOS)
      this.R_NOTES(WNSEQ).NOTINVNUM=this.EDINVNUM    # NOTINVNUM property
      this.R_NOTES(WNSEQ).OBSNUM=format$("N0:5#",WNSEQ)
      this.R_NOTES(WNSEQ).TYPNOT="AAI"
      this.R_NOTES(WNSEQ).NOT1=WNOTES(0)
      this.R_NOTES(WNSEQ).NOT2=WNOTES(1)
      this.R_NOTES(WNSEQ).NOT3=WNOTES(2)
      this.R_NOTES(WNSEQ).NOT4=WNOTES(3)
      this.R_NOTES(WNSEQ).NOT5=WNOTES(4)
    Endif

  Next N
  WSTATUS = [V]CST_AOK
Return

################################################################################
$EDICOM_RECEIPT
Return


