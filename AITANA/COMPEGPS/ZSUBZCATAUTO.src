#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
    When "INIT" : Gosub INIT
    When "EXEC" : Gosub EXEC
  Endcase
Return

$INIT
  If !clalev([F:WITM]) : Local File ITMMASTER   [WITM] :  Endif
  If !clalev([F:ITM])  : Local File ITMMASTER    [ITM] :  Endif
  If clalev([F:BPR])<=0 : Local File BPARTNER    [F:BPR]  : Endif
  If clalev([F:BPC])<=0 : Local File BPCUSTOMER  [F:BPC]  : Endif
  If clalev([F:ITS])<=0 : Local File ITMSALES    [F:ITS]  : Endif
  If clalev([F:ITF])<=0 : Local File ITMFACILIT  [F:ITF]  : Endif
Return

$EXEC
  Local Decimal GROPRI
  Local Decimal NETPRI
  Local Decimal DISCRGVAL(0..)

  adxifs=";"
  adxirs=chr$(13)+chr$(10)
  adxium=50 # ASCII

  Openo filpath("ZFP","CATALOGO","csv"),0 Using [TIE]
  Wrseq "ITMREF_0,GROPRI_0,DCGVAL_0,DCGVAL_1,DCGVAL_2,NETPRI_0" Using [TIE]
  Filter [F:WITM] Where 1=1 Order By ITMREF
  For [F:WITM]
    Raz GROPRI
    Raz NETPRI
    Raz DISCRGVAL

    Call PVTARIFAS([F:WITM]ITMREF, "C1000000", "001", "210", "UN", 2, "EUR", GROPRI, NETPRI, DISCRGVAL) From ZFUNCIONES

    Wrseq [F:WITM]ITMREF+","+num$(GROPRI)+","+num$(DISCRGVAL(0))+","+num$(DISCRGVAL(1))+","+num$(DISCRGVAL(2))+","+num$(NETPRI) Using [TIE]

  Next
  Filter [F:WITM]

  Openo Using [TIE]
Return

