#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara ZPER0 (Especifico)
$ACTION
Case ACTION
When "AS_ZOBJETONUM" : Gosub AS_ZOBJETONUM
When Default
Endcase
Return


$AS_ZOBJETONUM
Local Char     WOBJET(GLONAOB)
Case [M:ZPER0]ZOBJETOTIP
When 1 : WOBJET="BAP" # Citas
When 2 : WOBJET="TSK" # Tareas
When 3 : WOBJET="CLL" # Llamadas
Endcase
Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZPER0) 06/04/2017 12:40:54 (ADMIN)
######################################################################################
Subprog AM_ZOBJETOTIP(VALEUR)
Variable Integer VALEUR
Raz [M:ZPER0]ZOBJETONUM
Affzo [M:ZPER0]ZOBJETONUM
End

Subprog AM_ZPAUTA(VALEUR)
Variable Integer VALEUR
Raz [M:ZTSK1],[M:ZTSK2],[M:ZTSK3]#,[M:ZTSK4]
Call ABILITAR_MASK(VALEUR,1) From SUBZPER
End

Subprog AM_ZOBJETONUM(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
  Call ERREURT("Debe indicarse un valor", 1) From GESECRAN   #0-Informativo, 1-Error
  mkstat=2
  End
Elsif not func OBJETONUM_OK(VALEUR)
  mkstat=2
  End
Endif
End

Subprog C_ZOBJETONUM(VALEUR)
Variable Char    VALEUR()
#If (GREP="C" or GREP="D") and not func OBJETONUM_OK(VALEUR)
If [M:ZPER0]ZGENERADO<>2 and not func OBJETONUM_OK(VALEUR)
  mkstat=2
  End
Endif
End

Funprog OBJETONUM_OK(NUM)
Value Char NUM
Case [M:ZPER0]ZOBJETOTIP
When 1 # Citas
  Gosub LEER_CITA
  If fstat<>0
    Call ERREURT("Cita indicada no existe", 1) From GESECRAN   #0-Informativo, 1-Error
    End 0
  Endif
When 2 # Tareas
  Gosub LEER_TAREA
  If fstat<>0
    Call ERREURT("Tarea indicada no existe", 1) From GESECRAN   #0-Informativo, 1-Error
    End 0
  Endif
When 3 # Llamadas
  Gosub LEER_LLAMADA
  If fstat<>0
    Call ERREURT("Llamada indicada no existe", 1) From GESECRAN   #0-Informativo, 1-Error
    End 0
  Elsif [F:WCLL]CLLTYP=1
    Call ERREURT("No tiene sentido periodificar llamadas ENTRANTES", 1) From GESECRAN   #0-Informativo, 1-Error
    End 0
  Endif
Endcase
#
Local Char TXT(255)(10),PERIODO(GLONVCR)
Raz TXT,PERIODO
#
TXT(0)="select ZPERIODO_0 "
TXT(1)="from ZPERIODOS "
TXT(2)="where ZGENERADO_0<>2 and ZOBJETOTIP_0="+num$([M:ZPER0]ZOBJETOTIP)+" and ZOBJETONUM_0='"+NUM+"'"
For (Char FPER(GLONVCR)) From GFLDCHR(0) Sql TXT As [MYT]
  PERIODO=FPER
Next
If PERIODO<>""
  Call ERREURT("El Nºobjeto indicado ya está pendiente de PERIODIFICAR en periodificación nº "+PERIODO, 1) From GESECRAN   #0-Informativo, 1-Error
    End 0
Endif
End 1

$LEER_CITA
If !clalev([F:HD6])       :  Local File HD6CLOB   [F:HD6]   : Endif
If !clalev([F:WBAP])      :  Local File BAPPOINT  [F:WBAP]  : Endif
Read [F:WBAP]APP0=NUM
Return

$LEER_TAREA
If !clalev([F:HD6])       :  Local File HD6CLOB   [F:HD6]   : Endif
If !clalev([F:WTSK])      :  Local File TASK      [F:WTSK]  : Endif
Read [F:WTSK]TSK0=NUM
Return

$LEER_LLAMADA
If !clalev([F:HD5])       :  Local File HD5CLOB   [F:HD5]   : Endif
If !clalev([F:WCLL])      :  Local File PHONECALL [F:WCLL]  : Endif
Read [F:WCLL]CLL0=NUM
Return

