If [M:ZTSK4]ZAP1HORINI>VALEUR
  Call ERREURT("Hora inicio, no puede ser mayor que la de Fin\"+[M:ZTSK4]ZAP1HORINI+">"+VALEUR, 1) From GESECRAN   #0-Informativo, 1-Error
#  mkstat=2
  [M:ZTSK4]ZAP1HORINI=VALEUR
  Affzo [M:ZTSK4]ZAP1HORINI
Endif
End
