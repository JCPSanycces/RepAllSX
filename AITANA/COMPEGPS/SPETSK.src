######################################################################################
Subprog AM_ZDFECINI(VALEUR)
Variable Date    VALEUR
If VALEUR>[M:ZTSK1]ZDFECFIN
  Call ERREURT("Fecha inicio, no puede ser mayor que la de Fin\"+VALEUR+">"+[M:ZTSK1]ZDFECFIN, 1) From GESECRAN   #0-Informativo, 1-Error
#  mkstat=2
  [M:ZTSK1]ZDFECFIN=VALEUR
  Affzo [M:ZTSK1]ZDFECFIN
Endif
[M:ZTSK1]ZDFECINI=VALEUR
Call REPE_DUR([M:ZTSK1]ZDFECINI,[M:ZTSK1]ZDFECFIN,[M:ZPER0]ZPAUTA)
End
Subprog AM_ZDFECFIN(VALEUR)
Variable Date    VALEUR
If [M:ZTSK1]ZDFECINI>VALEUR
  Call ERREURT("Fecha inicio, no puede ser mayor que la de Fin\"+[M:ZTSK1]ZDFECINI+">"+VALEUR, 1) From GESECRAN   #0-Informativo, 1-Error
#  mkstat=2
  [M:ZTSK1]ZDFECINI=VALEUR
  Affzo [M:ZTSK1]ZDFECINI
Endif
[M:ZTSK1]ZDFECFIN=VALEUR
Call REPE_DUR([M:ZTSK1]ZDFECINI,[M:ZTSK1]ZDFECFIN,[M:ZPER0]ZPAUTA)
End


