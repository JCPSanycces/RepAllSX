Subprog AM_ZMFECFIN(VALEUR)
Variable Date    VALEUR
If [M:ZTSK3]ZMFECINI>VALEUR
  Call ERREURT("Fecha inicio, no puede ser mayor que la de Fin\"+[M:ZTSK3]ZMFECINI+">"+VALEUR, 1) From GESECRAN   #0-Informativo, 1-Error
#  mkstat=2
  [M:ZTSK3]ZMFECINI=VALEUR
  Affzo [M:ZTSK3]ZMFECINI
Endif
[M:ZTSK3]ZMFECFIN=VALEUR
Call REPE_DUR([M:ZTSK3]ZMFECINI,[M:ZTSK3]ZMFECFIN,[M:ZPER0]ZPAUTA)
End



######################################################################################
# Gestión de la máscara ZTSK4 (Especifico)
######################################################################################
$ANUAL
Return
Subprog AM_ZACADA(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 VALEUR=1 Endif
[M:ZTSK4]ZACADA=VALEUR
Call REPE_TOT([M:ZPER0]ZPAUTA)
End

Subprog AM_ZAMESDIA(VALEUR)
Variable Decimal VALEUR
Local Integer DIA
DIA=day(eomonth(gdat$(1, [M:ZTSK4]ZAMES1, year([M:ZTSK4]ZAFECINI))))
If VALEUR>DIA VALEUR=DIA Endif
If VALEUR>0
  Actzo [M:ZTSK4]ZAMES1
  Raz [M:ZTSK4]ZAOPC,[M:ZTSK4]ZADIA,[M:ZTSK4]ZAMES2
  Grizo [M:ZTSK4]ZAOPC
  Grizo [M:ZTSK4]ZADIA
  Grizo [M:ZTSK4]ZAMES2
Else
  Raz [M:ZTSK4]ZAMESDIA,[M:ZTSK4]ZAMES1
#  Grizo [M:ZTSK4]ZAMESDIA
  Grizo [M:ZTSK4]ZAMES1
  Actzo [M:ZTSK4]ZAOPC
  Actzo [M:ZTSK4]ZADIA
  Actzo [M:ZTSK4]ZAMES2
  [M:ZTSK4]ZAMES2=month(date$)
  Affzo [M:ZTSK4]ZAMES2
Endif
End
Subprog AM_ZAMES1(VALEUR)
Variable Integer VALEUR
Local Integer DIA
DIA=day(eomonth(gdat$(1, VALEUR, year([M:ZTSK4]ZAFECINI))))
If [M:ZTSK4]ZAMESDIA>DIA
  [M:ZTSK4]ZAMESDIA=DIA
  Affzo [M:ZTSK4]ZAMESDIA
Endif
End

Subprog AM_ZAPAUTA(VALEUR)
Variable Integer VALEUR
[M:ZTSK4]ZAPAUTA=VALEUR
Case [M:ZTSK4]ZAPAUTA
When 1 # Una sola vez
  Actzo [M:ZTSK4]ZAP1HORINI
  Actzo [M:ZTSK4]ZAP1HORFIN
  If [M:ZTSK4]ZAP1HORINI=""
    [M:ZTSK4]ZAP1HORINI= left$(time$,3)+"00"
    [M:ZTSK4]ZAP1HORFIN=[M:ZTSK4]ZAP1HORINI
  Endif
  Raz [M:ZTSK4]ZAP2CADA,[M:ZTSK4]ZAP2HORINI,[M:ZTSK4]ZAP2HORFIN
  Grizo [M:ZTSK4]ZAP2CADA
  Grizo [M:ZTSK4]ZAP2HORINI
  Grizo [M:ZTSK4]ZAP2HORFIN
When 2 # Cada x horas
  Actzo [M:ZTSK4]ZAP2CADA
  Actzo [M:ZTSK4]ZAP2HORINI
  Actzo [M:ZTSK4]ZAP2HORFIN
  If [M:ZTSK4]ZAP2HORINI=""
    [M:ZTSK4]ZAP2CADA=1
    [M:ZTSK4]ZAP2HORINI= left$(time$,3)+"00"
    [M:ZTSK4]ZAP2HORFIN=[M:ZTSK4]ZAP2HORINI
  Endif
  Raz [M:ZTSK4]ZAP1HORINI,[M:ZTSK4]ZAP1HORFIN
  Grizo [M:ZTSK4]ZAP1HORINI
  Grizo [M:ZTSK4]ZAP1HORFIN
When 3 # Todo el dia
  Raz [M:ZTSK4]ZAP1HORINI,[M:ZTSK4]ZAP1HORFIN,[M:ZTSK4]ZAP2CADA,[M:ZTSK4]ZAP2HORINI,[M:ZTSK4]ZAP2HORFIN
  Grizo [M:ZTSK4]ZAP1HORINI
  Grizo [M:ZTSK4]ZAP1HORFIN
  Grizo [M:ZTSK4]ZAP2CADA
  Grizo [M:ZTSK4]ZAP2HORINI
  Grizo [M:ZTSK4]ZAP2HORFIN
Endcase
Call REPE_DIA([M:ZPER0]ZPAUTA)
Affzo [M:ZTSK3]
End

Subprog AM_ZAP2CADA(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 VALEUR=1 Endif
[M:ZTSK4]ZAP2CADA=VALEUR
Call REPE_DIA([M:ZPER0]ZPAUTA)
End
