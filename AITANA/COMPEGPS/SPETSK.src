Variable Char    VALEUR()
If [M:ZTSK1]ZDP1HORINI>VALEUR
  Call ERREURT("Hora inicio, no puede ser mayor que la de Fin\"+[M:ZTSK1]ZDP1HORINI+">"+VALEUR, 1) From GESECRAN   #0-Informativo, 1-Error
#  mkstat=2
  [M:ZTSK1]ZDP1HORINI=VALEUR
  Affzo [M:ZTSK1]ZDP1HORINI
Endif
End
######################################################################################
Subprog AM_ZDP2HORINI(VALEUR)
Variable Char    VALEUR()
#VALEUR=left$(VALEUR,2)+"00"
If VALEUR>[M:ZTSK1]ZDP2HORFIN
