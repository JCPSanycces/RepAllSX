  Actzo [M:ZTSK2]ZSP1HORFIN
  If [M:ZTSK2]ZSP1HORINI=""
    [M:ZTSK2]ZSP1HORINI= left$(time$,3)+"00"
    [M:ZTSK2]ZSP1HORFIN=[M:ZTSK2]ZSP1HORINI
  Endif
  Raz [M:ZTSK2]ZSP2CADA,[M:ZTSK2]ZSP2HORINI,[M:ZTSK2]ZSP2HORFIN
