When 2 # Cada x horas
  Actzo [M:ZTSK2]ZSP2CADA
  Actzo [M:ZTSK2]ZSP2HORINI
  Actzo [M:ZTSK2]ZSP2HORFIN
  If [M:ZTSK2]ZSP2HORINI=""
    [M:ZTSK2]ZSP2CADA=1
