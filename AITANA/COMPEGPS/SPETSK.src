Subprog AM_ZMFECINI(VALEUR)
Variable Date    VALEUR
If VALEUR>[M:ZTSK3]ZMFECFIN
  Call ERREURT("Fecha inicio, no puede ser mayor que la de Fin\"+VALEUR+">"+[M:ZTSK3]ZMFECFIN, 1) From GESECRAN   #0-Informativo, 1-Error
#  mkstat=2
