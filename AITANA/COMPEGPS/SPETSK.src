######################################################################################
# Gestión de la máscara ZTSK3 (Especifico)
######################################################################################
$MENSUAL
Return
Subprog AM_ZM1DIA(VALEUR)
Variable Decimal VALEUR
Local Integer DIA
If VALEUR>0
  DIA=day(eomonth([M:ZTSK3]ZMFECINI))
  If VALEUR>DIA VALEUR=DIA Endif
  Raz [M:ZTSK3]ZM2OPC,[M:ZTSK3]ZM2DIA,[M:ZTSK3]ZM2CADA
  Grizo [M:ZTSK3]ZM2OPC
  Grizo [M:ZTSK3]ZM2DIA
  Grizo [M:ZTSK3]ZM2CADA
Else
  Raz [M:ZTSK3]ZM1DIA,[M:ZTSK3]ZM1CADA
  Grizo [M:ZTSK3]ZM1DIA
  Grizo [M:ZTSK3]ZM1CADA
  Actzo [M:ZTSK3]ZM2OPC
  Actzo [M:ZTSK3]ZM2DIA
  Actzo [M:ZTSK3]ZM2CADA
  [M:ZTSK3]ZM2CADA=1
  Affzo [M:ZTSK3]ZM2CADA
  Call REPE_TOT([M:ZPER0]ZPAUTA)
Endif
End

Subprog AM_ZM1CADA(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 VALEUR=1 Endif
[M:ZTSK3]ZM1CADA=VALEUR
Call REPE_TOT([M:ZPER0]ZPAUTA)
End

Subprog AM_ZM2OPC(VALEUR)
Variable Integer VALEUR
End

Subprog AM_ZM2DIA(VALEUR)
Variable Integer VALEUR
End

Subprog AM_ZM2CADA(VALEUR)
Variable Decimal VALEUR
If VALEUR>0
  Raz [M:ZTSK3]ZM1DIA,[M:ZTSK3]ZM1CADA
  Grizo [M:ZTSK3]ZM1DIA
  Grizo [M:ZTSK3]ZM1CADA
Else
  Raz [M:ZTSK3]ZM2OPC,[M:ZTSK3]ZM2DIA,[M:ZTSK3]ZM2CADA
  Grizo [M:ZTSK3]ZM2OPC
  Grizo [M:ZTSK3]ZM2DIA
  Grizo [M:ZTSK3]ZM2CADA
  Actzo [M:ZTSK3]ZM1DIA
  Actzo [M:ZTSK3]ZM1CADA
  [M:ZTSK3]ZM1DIA  =1
  [M:ZTSK3]ZM1CADA =1
  Affzo [M:ZTSK3]ZM1DIA
  Affzo [M:ZTSK3]ZM1CADA
Endif
[M:ZTSK3]ZM2CADA=VALEUR
Call REPE_TOT([M:ZPER0]ZPAUTA)
End

Subprog AM_ZMPAUTA(VALEUR)
Variable Integer VALEUR
[M:ZTSK3]ZMPAUTA=VALEUR
Case [M:ZTSK3]ZMPAUTA
When 1 # Una sola vez
  Actzo [M:ZTSK3]ZMP1HORINI
  Actzo [M:ZTSK3]ZMP1HORFIN
  If [M:ZTSK3]ZMP1HORINI=""
    [M:ZTSK3]ZMP1HORINI= left$(time$,3)+"00"
    [M:ZTSK3]ZMP1HORFIN=[M:ZTSK3]ZMP1HORINI
  Endif
  Raz [M:ZTSK3]ZMP2CADA,[M:ZTSK3]ZMP2HORINI,[M:ZTSK3]ZMP2HORFIN
  Grizo [M:ZTSK3]ZMP2CADA
  Grizo [M:ZTSK3]ZMP2HORINI
  Grizo [M:ZTSK3]ZMP2HORFIN
When 2 # Cada x horas
  Actzo [M:ZTSK3]ZMP2CADA
  Actzo [M:ZTSK3]ZMP2HORINI
  Actzo [M:ZTSK3]ZMP2HORFIN
  If [M:ZTSK3]ZMP2HORINI=""
    [M:ZTSK3]ZMP2CADA=1
    [M:ZTSK3]ZMP2HORINI= left$(time$,3)+"00"
    [M:ZTSK3]ZMP2HORFIN=[M:ZTSK3]ZMP2HORINI
  Endif
  Raz [M:ZTSK3]ZMP1HORINI,[M:ZTSK3]ZMP1HORFIN
  Grizo [M:ZTSK3]ZMP1HORINI
  Grizo [M:ZTSK3]ZMP1HORFIN
When 3 # Todo el dia
  Raz [M:ZTSK3]ZMP1HORINI,[M:ZTSK3]ZMP1HORFIN,[M:ZTSK3]ZMP2CADA,[M:ZTSK3]ZMP2HORINI,[M:ZTSK3]ZMP2HORFIN
  Grizo [M:ZTSK3]ZMP1HORINI
  Grizo [M:ZTSK3]ZMP1HORFIN
  Grizo [M:ZTSK3]ZMP2CADA
  Grizo [M:ZTSK3]ZMP2HORINI
  Grizo [M:ZTSK3]ZMP2HORFIN
Endcase
Call REPE_DIA([M:ZPER0]ZPAUTA)
Affzo [M:ZTSK3]
End

Subprog AM_ZMP2CADA(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 VALEUR=1 Endif
[M:ZTSK3]ZMP2CADA=VALEUR
Call REPE_DIA([M:ZPER0]ZPAUTA)
End
######################################################################################
Subprog AM_ZMP1HORINI(VALEUR)
Variable Char    VALEUR()
If VALEUR>[M:ZTSK3]ZMP1HORFIN
  Call ERREURT("Hora inicio, no puede ser mayor que la de Fin\"+VALEUR+">"+[M:ZTSK3]ZMP1HORFIN, 1) From GESECRAN   #0-Informativo, 1-Error
#  mkstat=2
  [M:ZTSK3]ZMP1HORFIN=VALEUR
  Affzo [M:ZTSK3]ZMP1HORFIN
Endif
End
