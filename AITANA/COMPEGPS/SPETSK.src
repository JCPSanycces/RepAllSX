  Call ERREURT("Hora inicio, no puede ser mayor que la de Fin\"+VALEUR+">"+[M:ZTSK4]ZAP1HORFIN, 1) From GESECRAN   #0-Informativo, 1-Error
#  mkstat=2
  [M:ZTSK4]ZAP1HORFIN=VALEUR
  Affzo [M:ZTSK4]ZAP1HORFIN
Endif
End
