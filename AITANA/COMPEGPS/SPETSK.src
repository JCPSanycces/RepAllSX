#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
When  "RAZCRE"    :  Gosub RAZCRE_LIENS
When  "LIENS"     :  Gosub RAZCRE_LIENS
When  "FILGAUCHE" :  Gosub FILGAUCHE
When  "FERME"     :  Gosub FERME
When Default
Endcase
Return

$RAZCRE_LIENS
Grizo [M:TSK1]ZPERIODO
Return

$FILGAUCHE
If dim(GCTSKCPT)<1 or dim(GBOXTSK)<1
#  Infbox "dim(GBOXTSK)="+num$(dim(GBOXTSK))
  Gosub OUVRE       From SUBTSK
  Gosub OUVRE_BOITE From SUBTSK
Endif
Return

$FERME
If dim(GCTSKCPT)<1
  Gosub OUVRE       From SUBTSK
Endif

######################################################################################
# Gestión de la máscara ZTSK1 (Especifico)
######################################################################################
$DIARIO
Return
Subprog AM_ZDCADA0(VALEUR)
Variable Decimal VALEUR
If VALEUR>0
  Raz [M:ZTSK1]ZDCADA1
  Grizo [M:ZTSK1]ZDCADA1
Else
  Actzo [M:ZTSK1]ZDCADA1
  [M:ZTSK1]ZDCADA1=2
Endif
[M:ZTSK1]ZDCADA0=VALEUR
Call REPE_TOT([M:ZPER0]ZPAUTA)
End

Subprog AM_ZDCADA1(VALEUR)
Variable Integer VALEUR
If VALEUR=2
  Raz [M:ZTSK1]ZDCADA0
  Affzo [M:ZTSK1]ZDCADA0
Else
[M:ZTSK1]ZDCADA0=1
Affzo [M:ZTSK1]ZDCADA0
Endif
[M:ZTSK1]ZDCADA1=VALEUR
Call REPE_TOT([M:ZPER0]ZPAUTA)
End

Subprog AM_ZDPAUTA(VALEUR)
Variable Integer VALEUR
[M:ZTSK1]ZDPAUTA=VALEUR
Case [M:ZTSK1]ZDPAUTA
When 1 # Una sola vez
  Actzo [M:ZTSK1]ZDP1HORINI
  Actzo [M:ZTSK1]ZDP1HORFIN
  If [M:ZTSK1]ZDP1HORINI=""
    [M:ZTSK1]ZDP1HORINI= left$(time$,3)+"00"
    [M:ZTSK1]ZDP1HORFIN=[M:ZTSK1]ZDP1HORINI
  Endif
  Raz [M:ZTSK1]ZDP2CADA,[M:ZTSK1]ZDP2HORINI,[M:ZTSK1]ZDP2HORFIN
  Grizo [M:ZTSK1]ZDP2CADA
  Grizo [M:ZTSK1]ZDP2HORINI
  Grizo [M:ZTSK1]ZDP2HORFIN
When 2 # Cada x horas
  Actzo [M:ZTSK1]ZDP2CADA
  Actzo [M:ZTSK1]ZDP2HORINI
  Actzo [M:ZTSK1]ZDP2HORFIN
  If [M:ZTSK1]ZDP2HORINI=""
    [M:ZTSK1]ZDP2CADA=1
    [M:ZTSK1]ZDP2HORINI= left$(time$,3)+"00"
    [M:ZTSK1]ZDP2HORFIN=[M:ZTSK1]ZDP2HORINI
  Endif
  Raz [M:ZTSK1]ZDP1HORINI,[M:ZTSK1]ZDP1HORFIN
  Grizo [M:ZTSK1]ZDP1HORINI
  Grizo [M:ZTSK1]ZDP1HORFIN
When 3 # Todo el dia
  Raz [M:ZTSK1]ZDP1HORINI,[M:ZTSK1]ZDP1HORFIN,[M:ZTSK1]ZDP2CADA,[M:ZTSK1]ZDP2HORINI,[M:ZTSK1]ZDP2HORFIN
  Grizo [M:ZTSK1]ZDP1HORINI
  Grizo [M:ZTSK1]ZDP1HORFIN
  Grizo [M:ZTSK1]ZDP2CADA
  Grizo [M:ZTSK1]ZDP2HORINI
  Grizo [M:ZTSK1]ZDP2HORFIN
Endcase
Call REPE_DIA([M:ZPER0]ZPAUTA)
Affzo [M:ZTSK1]
End
######################################################################################
######################################################################################
Subprog AM_ZDP2CADA(VALEUR)
Variable Decimal VALEUR
If VALEUR<1 VALEUR=1 Endif
[M:ZTSK1]ZDP2CADA=VALEUR
Call REPE_DIA([M:ZPER0]ZPAUTA)
End
######################################################################################
Subprog AM_ZDP1HORINI(VALEUR)
Variable Char    VALEUR()
If VALEUR>[M:ZTSK1]ZDP1HORFIN
  Call ERREURT("Hora inicio, no puede ser mayor que la de Fin\"+VALEUR+">"+[M:ZTSK1]ZDP1HORFIN, 1) From GESECRAN   #0-Informativo, 1-Error
#  mkstat=2
  [M:ZTSK1]ZDP1HORFIN=VALEUR
  Affzo [M:ZTSK1]ZDP1HORFIN
Endif
End
