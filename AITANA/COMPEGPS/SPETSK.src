If [M:ZTSK3]ZMP1HORINI>VALEUR
  Call ERREURT("Hora inicio, no puede ser mayor que la de Fin\"+[M:ZTSK3]ZMP1HORINI+">"+VALEUR, 1) From GESECRAN   #0-Informativo, 1-Error
#  mkstat=2
