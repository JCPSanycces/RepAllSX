Endcase
Call REPE_DIA([M:ZPER0]ZPAUTA)
Affzo [M:ZTSK2]
End

Subprog AM_ZSP2CADA(VALEUR)
Variable Decimal VALEUR
Local Integer MINIMO
MINIMO=func MINIMO_PAUTA
If VALEUR<MINIMO VALEUR=MINIMO Endif
[M:ZTSK2]ZSP2CADA=VALEUR
Call REPE_DIA([M:ZPER0]ZPAUTA)
End
