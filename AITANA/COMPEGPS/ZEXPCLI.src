#<AdxTL>@(#)0.0.0.0 $Revision$
Subprog EXPDATA(WCODCLI)
  Value Char WCODCLI()

  Local Clbfile REGISTRO(0)
  Local Char WOUT(250)
  Local Char EMPRESA(35)
  Local Char IDIOMA(3)

  #Declaramos las tablas
  If !clalev([XBPC])  : Local File BPCUSTOMER [XBPC] : Endif
  If !clalev([XBPA])  : Local File BPADDRESS  [XBPA] : Endif
  If !clalev([XBPR])  : Local File BPARTNER   [XBPR] : Endif
  If !clalev([XBPD])  : Local File BPDLVCUST  [XBPD] : Endif

  #Recorremos las tablas
  #BPARTNER
  Read [XBPR]BPR0=WCODCLI
  If fstat=0 Then
    EMPRESA=[XBPR]BPRNAM
    IDIOMA=[XBPR]LAN
    Append REGISTRO,"3;"+WCODCLI+";"+[XBPR]BPRNAM+";"+[XBPR]CRY+";"+[XBPR]CRN+";"+[XBPR]CUR+";"
  Endif

  #BPCUSTOMER
  Read [XBPC]BPC0=WCODCLI
  If fstat=0 Then
    Append REGISTRO,[XBPC]PTE+";"
  Endif

  #BPDLVCUST
  Read [XBPD]BPD0=WCODCLI;"001"+";"
  If fstat=0 Then
    Append REGISTRO,[XBPD]MDL+";"+[XBPD]BPTNUM+";"
  Else
    Append REGISTRO,";;"
  Endif

  #BPCUSTOMER
  Read [XBPC]BPC0=WCODCLI
  If fstat=0 Then
    Append REGISTRO,[XBPC]BPCPYR+";"+[XBPC]REP+";"+[XBPC]VACBPR+";"
  Endif

  #BPADDRESS
  Read [XBPA]BPA0=1;WCODCLI;"001"
  If fstat=0 Then
    Append REGISTRO,"001;"+EMPRESA+";"+[XBPA]BPADES+";;"+[XBPA]MOB+";"+[XBPA]BPAADDLIG(0)+";"+[XBPA]BPAADDLIG(1)+";"+[XBPA]CTY+";"+[XBPA]POSCOD+";"+[XBPA]CRY+";"+[XBPA]SAT+";"+[XBPA]WEB+";"+[XBPA]FAX+
& ";"+[XBPA]TEL+";"
  Else
    Append REGISTRO,"001;"+EMPRESA+";;;;;;;;;;;;"
  Endif

  Read [XBPA]BPA0=1;WCODCLI;"002"
  If fstat=0 Then
    Append REGISTRO,"002;"+EMPRESA+";"+[XBPA]BPADES+";;"+[XBPA]MOB+";"+[XBPA]BPAADDLIG(0)+";"+[XBPA]BPAADDLIG(1)+";"+[XBPA]CTY+";"+[XBPA]POSCOD+";"+[XBPA]CRY+";"+[XBPA]SAT+";"+[XBPA]WEB+";"+[XBPA]FAX+
& ";"+[XBPA]TEL+";"
  Else
    Append REGISTRO,"002;"+EMPRESA+";;;;;;;;;;;;"
  Endif

  #OTROS
  Append REGISTRO,"ZBPC"+"_"+WCODCLI+";"+IDIOMA+";"+[XBPC]ZCLIECC+";"

  WOUT = filpath("ECOMMERCE/SALIDA","ZBPC"+"_"+WCODCLI,"")

  Openo WOUT,0 Using [TIF]
  Iomode adxium 0 Using [TIF]
  Wrseq REGISTRO Using [TIF]
  Openo Using [TIF]

End

