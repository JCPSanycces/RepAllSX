####################################################
Subprog AM_BPCORD(VALEUR)
    Variable Char    VALEUR()
    Local Integer WFOUND, WI
    Local Char WPTE(25), WVAC(5)
    ### FJCP Control planta Autorizada.
    WFOUND=0
    For I=0 To 9
      If [F:BPC]ZPLAPER(I)=""
          Break
      Endif
      If [F:BPC]ZPLAPER(I)=[M:SOH0]SALFCY
        WFOUND=1
        WI=I
        Break
      Endif
    Next
    If I>0 & !WFOUND
       GMESSAGE = "Planta no Autorizada"
       [M:SOH0]BPCORD=""
       Affzo [M:SOH0]BPCORD
       mkstat = 2
       End
    Endif
    ### Fin FJCP Control planta Autorizada

    ### Forma de Pago por Defecto de planta
    If WFOUND & [F:BPC]ZPLAPTE(WI)<>"" Then
       WPTE=[F:BPC]ZPLAPTE(WI)
       Call C_PTE(WPTE) From SUBSOH
       If mkstat Then
          End
       Endif
       Call AM_PTE(WPTE) From SUBSOH
       If mkstat Then
          End
       Endif
       [M:SOH3]PTE=WPTE
       Affzo [M:SOH3]PTE
    Endif

    ### Regimen de impuesto por Defecto de planta
    If WFOUND & [F:BPC]ZPLAVAC(WI)<>"" Then
       WVAC=[F:BPC]ZPLAVAC(WI)
       Call C_VACBPR(WVAC) From SUBSOH
       If mkstat Then
          End
       Endif
       Call AM_VACBPR(WVAC) From SUBSOH
       If mkstat Then
          End
       Endif
       [M:SOH1]VACBPR=WVAC
       Affzo [M:SOH1]VACBPR
    Endif

End

