## VALOR(0)="6058" : Chgtzn [M:SOH4]ZTALLAD  With func ZCOMUN.TRADUCIR_VALOR_CAMPO("ATABTAB", VALOR, "SPA", 3)
#VALOR(0)="6009" : Chgtzn [M:SOH4]ZMARCOMD With func ZCOMUN.TRADUCIR_VALOR_CAMPO("ATABTAB", VALOR, "SPA", 3)
Return

