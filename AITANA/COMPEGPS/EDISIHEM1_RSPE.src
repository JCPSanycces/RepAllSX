# Clase EDISIHEM_R_NOTES


$METHODS
Case [L]CURPTH
   When ""
      Case [L]ACTION
          When "MET_AFTER_LOAD_REPRESENTATION" : Gosub MET_AFTER_LOAD_REPRESENTATION
      Endcase
Endcase
Return


$PROPERTIES
Case [L]CURPRO
Endcase
Return

$MET_AFTER_LOAD_REPRESENTATION

## Detalles Vencimiento
this.ZRELVTO="3"
this.ZDIASVTO=""
this.ZPORCVTO=format$("N0:4.3#",0)


  # Nif Intracomunitarios y pais Sociedad
  Local File COMPANY [CPY]
  Read [CPY]CPY0=this.SIV.CPY
  If fstat=[V]CST_AOK
    this.CPYNAME=[F:CPY]CPYNAM
    this.ZCPYCRY =[F:CPY]CRY
    this.ZCPYEECNUM=[F:CPY]EECNUM
  Endif

  LogicClose File [CPY]


  # NIF Intracomunitario y pais Cliente
  Local File BPARTNER [BPR]

  Read [BPR]BPR0=this.SIV.BPCINV
  If fstat=[V]CST_AOK
    this.ZBPCCRY=[F:BPR]CRY
    this.ZBPCEECNUM = [F:BPR]EECNUM
  Endif
  LogicClose File [BPR]
Dbgaff

### Lineas
  Local File SORDER [SOH]
  Local File SINVOICED [SIDX]
  Local Char WSOHNUM (20) , WSIHNUM (20)
  Local Integer WSIDLIN
  For I=1 To maxtab(this.R_SID)
    WSIHNUM=this.SIV.NUM
    WSIDLIN=this.R_SID(I).EDISIDLIN
    Raz [SIDX]
    Read [SIDX]SID0=WSIHNUM;WSIDLIN
    If !fstat Then
       WSOHNUM=[F:SIDX]SOHNUM
       Raz [SOH]
       Read [SOH]SOH0=WSOHNUM
       If !fstat Then
           this.R_SID(I).ORDNUMLIN=[F:SOH]CUSORDREF
       Endif
     Endif
  Next
  LogicClose File [SOH]
  LogicClose File [SIDX]
Return


