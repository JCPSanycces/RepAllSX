End

######################################
$ACTION
Case ACTION
 When "INIT"        : Gosub INIT
 When "DEBUT"   : Gosub DEBUT
 When "EXEC"     : Gosub EXEC
Endcase
Return

#**
#* INIT
#*!
$INIT
Return

#**
#* DEBUT
#*!
$DEBUT
Return

#**
#* EXEC
#*!
$EXEC
Local Char    FICDES (250),PATHDES(250), FICSRV (250),FICCLI (250),VOLUME(20),VOLDES(20)
Local Integer OK,FILEDESINFO
Gosub ENUM_VOLFIL_TYPE From ASYRSTO

# 1 Copy on [TMP] volume
VOLUME = ""
FICSRV = VOLUME


OK = func ASYRSTO.UPLOAD(FICCLI,FICSRV)
If OK<>1
 Goto ERREXEC
Endif

# 2 Copy in the good folder
VOLDES =PARAM(1)
VOLDES = "BQT"
FICDES =   '[' + VOLDES+ ']' + '/' + FICCLI

OK  = func ASYRSTO.CTL_VOLFIL(2,FICDES,PATHDES,E_TYPE_FILEOVERWRITE,GMESSAGE)
If !OK
 OK = func ASYRSTO.GETFILEINFO(VOLDES ,FICCLI,0,FILEDESINFO)
 If FILEDESINFO>0
  Call OUINON(mess(127,105,1),OK) From GESECRAN : #  : Fichier existant, souhaitez-vous l'écraser ?
  If OK<>2 : Goto FINEXEC : Endif
 Endif
 Call MOVE(FICSRV,PATHDES,OK) From ORDSYS
 If OK>0 : Goto ERREXEC : Endif
 PARAM(2) = FICDES
Else
 Goto ERREXEC
Endif
Return

$ERREXEC
Call ERREUR(mess(12,139,1)-string$(GMESSAGE<>"",":")-GMESSAGE)From GESECRAN :# Copie non réalisée'
$FINEXEC
Call EFFACE(FICSRV,OK) From ORDSYS : # Clear tempory file on [TMP]
PARAM(2) = ""
Return

#OK = func ASYRSTO.UPLOAD(FICCLI,FICSRV)
