#####################################################################################
Funprog DIGITOCONTROL(NUMERO)
##########################################
#   NO incluir el digito de control !!!! #
##########################################
Value Char NUMERO
Local Integer DC,X,H,SUMA1,SUMA2,VALOR
Raz DC,X,H,SUMA1,SUMA2,VALOR
For H=len(NUMERO) To 1 Step -1
  X+=1
  If mod(X, 2) = 0
    SUMA2+=val(mid$(NUMERO,H,1))
  Else
    SUMA1+=val(mid$(NUMERO,H,1))
  Endif
Next
VALOR=(SUMA1*3)+SUMA2
While mod(VALOR,10)<>0
  DC+=1
  VALOR+=1
Wend
End DC

#####################################################################################

Subprog DIR_NOM(WDIR)
Variable Char WDIR
If right$(WDIR,len(WDIR))<>"\"
  WDIR=WDIR+"\"
Endif
If instr(1,WDIR,":")<1 and left$(WDIR,1)<>"\"
  WDIR="\"+WDIR
Endif
End

#####################################################################################
Subprog CREAR_DIR(WDIR)
Variable Char WDIR
Call DIR_NOM(WDIR)
Local Char TMP(255)
TMP=filpath("","","","","",adxmac(0)) + WDIR
If filinfo(TMP,7)<0
  Local Integer STAT
  Call SYSTEME(adxmac(0),'ae_mkdir'-'"' + TMP + '"',"",STAT) From ORDSYS
Endif
End

#####################################################################################

Funprog FICHERO_OK(FICHADJ)
Value Char FICHADJ
Local Integer NB_ATTEMPTS,OK
Local Decimal SIZE,RSIZE
NB_ATTEMPTS=0
OK=0
Repeat
   SIZE=filinfo(FICHADJ,7)
   If NB_ATTEMPTS=0 or (NB_ATTEMPTS>0 and SIZE<>RSIZE)
     NB_ATTEMPTS+=1
     RSIZE=SIZE
    Sleep 1
   Else
    OK=1
    Break
   Endif
Until NB_ATTEMPTS>10
End OK

#####################################################################################

Subprog ARRAY(STR,SEP,MAT)
# STR     String con el texto
# SEP     String correspondiente al separador
# MAT     String definida como   Char MAT(255)(0..), donde se devolverá el array de strings
Value Char STR,SEP
Variable Char MAT
Local Char TXT(255)
Local Integer I,P,E
Raz E,MAT
I=1
P=instr(I,STR,SEP)
While P>0
  MAT(E)=mid$(STR,I,P-I)
  I=P+len(SEP)
  E+=1
  P=instr(I,STR,SEP)
Wend
If P=0 and I<=len(STR)
  MAT(E)=right$(STR,I)
Endif
End


#####################################################################################

Funprog FILAS_GRID(PANTA,NBLIG)
# PANTA    tipo Char(GLONAMK)
# NBLIG    tipo Char(GLONAVA)
Value Char PANTA,NBLIG
Local Integer F,T
Raz T
If clalev([F:AMK])<=0    :  Local File AMSK [F:AMK]  : Endif
Read [F:AMK]CODMSK=PANTA
If fstat<>0
  Call FSTA("AMK") From GLOCK
Else
  For F=0 To 14
    If [F:AMK]BASPAG(F)=NBLIG
      T=[F:AMK]NBLIGT(F)
      Break
    Endif
  Next
Endif
End T
#####################################################################################


Funprog REDONDEAR(NUM,POS)
Value Decimal NUM
Value Integer POS
Local Decimal N
Local Integer F
#int(3.375*100+0.5)/100
If POS=0
  F=1
Else
  F=10^POS
Endif
N=int(NUM*F+0.5)/F
End N
#####################################################################################

Funprog CONTINUAR
Local Integer YN,CONT
Local Char MSG(255)
YN = 1 :# By default points on No
MSG= "DESEA CONTINUAR"
Call OUINON(MSG, YN) From GESECRAN
If YN=1
  CONT=0
Else
  CONT=1
Endif
End CONT
#####################################################################################

Funprog PROVINCIA_ESP(CODPOS, PAIS)
# Parametros de entrada
#  CODPOS      Tipo POS => Código Postal
#  PAIS        Tupo CRY => Pais
# Valor devuelto
#              TIPO CHAR(100)
#              #  =>   No existe traducción
Value Char CODPOS(), PAIS()
Local Char TXT(100)
Local Char PROV(GLONSAT), VALOR(GLONID1)(2)

If clalev([F:ATU])<=0  :  Local File TABSUBDIV  [F:ATU] : Endif

Raz TXT
PROV=left$(CODPOS,2)
Read [F:ATU]ATU0=PAIS; 3; PROV
If fstat=0
  VALOR(0)=[F:ATU]CRYTYP
  VALOR(1)=PROV
  TXT= func ZCOMUN.TRADUCIR_VALOR_CAMPO("TABSUBDIV", VALOR, "SPA", 3)
Endif
End TXT
#####################################################################################

Funprog TRADUCIR_VALOR_CAMPO(TABLA,VALOR,IDIOMA,TIPO)
# Parametros de entrada
#  TABLA       Tipo ATB => Nombre de la tabla
#  VALOR       Tipo ID1 => Valor del campo a traducir. matriz de 2  VALOR(0) + VALOR(1)
#  IDIOMA      Tipo LAN => Idioma cuya traduccion se desea
#  TIPO        TIPO AVA => Tipo de descripcion a devolver, SI TIPO = 3, devolver primer valor existente según orden Corta, Larga, Columna
# Valor devuelto
#              TIPO CHAR(100)
#              #  =>   No existe traducción

Value Char TABLA,VALOR,IDIOMA
Value Integer TIPO
Local Char TXT(100), ZONE(GLONAVA)
If clalev([F:AXX])<=0  :  Local File ATEXTRA    [F:AXX] : Endif

# Controlar valores especiales de columna ZONE
Case TABLA
When "TABSUBDIV"
  TIPO=-1
When "ATABDIV"
  TIPO=-2
Endcase

Raz TXT
Case TIPO
When -1 # Especial tabla    TABSUBDIV
  ZONE="INTIT"
  Gosub TRADUCIR_VALOR_CAMPO_LEER
When -2 # Especial tabla    ATABDIV
  ZONE="LNGDES"
  Gosub TRADUCIR_VALOR_CAMPO_LEER
When 0  #  Descripción corta
  ZONE="SHOTRA"
  Gosub TRADUCIR_VALOR_CAMPO_LEER
When 1  #  Descripción larga
  ZONE="DESTRA"
  Gosub TRADUCIR_VALOR_CAMPO_LEER
When 2  #  Descripción columna
  ZONE="COLHEA"
  Gosub TRADUCIR_VALOR_CAMPO_LEER
When Default
  ZONE="SHOTRA"
  Gosub TRADUCIR_VALOR_CAMPO_LEER
  If TXT="" or TXT="#"
    ZONE="DESTRA"
    Gosub TRADUCIR_VALOR_CAMPO_LEER
    If TXT="" or TXT="#"
      ZONE="COLHEA"
      Gosub TRADUCIR_VALOR_CAMPO_LEER
    Endif
  Endif
Endcase
End TXT

$TRADUCIR_VALOR_CAMPO_LEER
  Read [F:AXX]AXX0=TABLA;ZONE;IDIOMA;VALOR(0);VALOR(1)
  If fstat=0
    TXT=[F:AXX]TEXTE
  Else
    TXT="#"
  Endif
Return
###############################################################################

Subprog PEDIRFICHERO (FICSRV,OK,FICCLI)
  Variable Char  FICSRV(),FICCLI()
  Variable Integer OK
  Local Integer STAT

  FICCLI=""
  FICSRV= filpath("tmp",num$(timestamp$),"")      # Nombre del fichero de destino en el servidor
  Call SET_NAMCLI(FICCLI) From ORDSYS
  Call COPSRV(FICCLI,FICSRV,STAT) From ORDSYS     # Funcion que abre la seleccion del fichero en el puesto de cliente
  If STAT
      Call ERREUR(mess(12,139,1)) From GESECRAN : # Copie non rÃ©alisÃ©e
      OK=0
  Else
      OK=1
  Endif
End
################################################################################

Subprog GRABARFICHERO(MSG,FICSRV)
Value Char MSG
Variable Char FICSRV
Local Integer H
Onerrgo ERRORES
FICSRV= filpath("tmp",num$(timestamp$),"txt")     # Nombre del fichero de destino en el servidor
Openo FICSRV Using [FIC1]                         # Lo abre para escritura
Iomode adxifs  ";"  Using [FIC1]
Iomode adxirs  chr$(13)+chr$(10)  Using [FIC1]
#Iomode adxium  50 Using [FIC1] #  50 = ASCII  0 = UTF8
For H=0 To dim(MSG)-1
 Wrseq MSG(H) Using [FIC1]                        # Graba texto
Next
Openo Using [FIC1]                                # Lo cierra
Onerrgo
End
