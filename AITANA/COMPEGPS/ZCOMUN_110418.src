# **    ARTICULOS        **
# *************************

#################################################################################
Subprog ART_IVA(ITM,CTE,CPY,FEC,IVA)
Value Char ITM,CTE,CPY
Value Date FEC
Variable Decimal IVA()
Local Integer F
Raz IVA
# 1º Sacar tipos    IVA del articulo
If clalev([F:ITM])<=0    :  Local File ITMMASTER [F:ITM]  : Endif
Read [F:ITM]ITM0=ITM
If fstat=0
  # 2º Sacar regimen IVA del Cliente
  If clalev([F:BPC])<=0    :  Local File BPCUSTOMER[F:BPC]  : Endif
  Read [F:BPC]BPC0=CTE
  If fstat=0
    # 3º Sacar %IVA
    If clalev([F:TVC])<=0    :  Local File TABVAC    [F:TVC]  : Endif
    If clalev([F:TRA])<=0    :  Local File TABRATVAT [F:TRA]  : Endif
    For F=0 To dim([F:ITM]VACITM)-1
      Read [F:TVC]TVC1=[F:BPC]VACBPR;[F:ITM]VACITM(F)
      If fstat=0
        Filter [F:TRA] Where [F:TRA]VAT=[F:TVC]VAT and [F:TRA]CPY=CPY and [F:TRA]STRDAT<=FEC Order By [F:TRA]STRDAT Desc
        For [F:TRA]
          IVA(F)=[F:TRA]VATRAT
          Break
        Next
      Endif
    Next
  Endif
Endif
End


#################################################################################
Funprog ART_COSTE(FCY,ITM,LOT,SLOT,FIFO)
Value Char FCY,ITM,LOT,SLOT
Variable Date FIFO
Local Char TXT(255)(3),BD_TIPO(1)
Local Decimal COSTE_UNITARIO
Raz COSTE_UNITARIO,FIFO,TXT
# 1º intento sacar el precio de compra del lote
BD_TIPO=func DATA_BASE_TIPO()
TXT(0)="select CST_0/QTYSTUACT_0, CSTDAT_0 "
TXT(1)="from STOCOST c inner join STOLOT l on c.VCRNUM_0=l.VCRNUM_0 and c.VCRLIN_0 =l.VCRLIN_0 and c.VCRTYP_0 =l.VCRTYP_0 "
TXT(2)="where c.ITMREF_0='" + ITM + "' and LOT_0='" + LOT + "' and SLO_0='" + SLOT + "'"
For (Decimal PREC, Date CSTDAT) From BD_TIPO Sql TXT As [MYT]
  COSTE_UNITARIO=PREC
  FIFO=CSTDAT
Next
# 2º De no lograrlo, saco el precio medio
If FIFO=[0/0/0]
  If clalev([F:SLF])<=0   :  Local File STOLOTFCY    [F:SLF] : Endif
  Read [F:SLF]SLF0=ITM;LOT;SLOT;FCY
  If fstat=0
    COSTE_UNITARIO=[F:SLF]AVC # Precio medio ponderado PMP
    FIFO=[F:SLF]LASRCPDAT     # Fecha última entrada
  Endif
Endif
End COSTE_UNITARIO


# *************************
# **    CONTABILIDAD     **
# *************************

Subprog REFERENCIALES_PLANTA(PLANTA, REFER, RCUR)
  Value Char PLANTA
  Variable Char REFER,RCUR
  Local Char TXT(250)(3),BD_TIPO(1)
  Local Integer FLAG_ERR,F,N
  FLAG_ERR=0

  Raz TXT,REFER
  TXT(0)="select LED_0, LED_1, LED_2, LED_3, LED_4, LED_5, LED_6, LED_7, LED_8, LED_9, CUR_0, CUR_1, CUR_2, CUR_3, CUR_4, CUR_5, CUR_6, CUR_7, CUR_8, CUR_9 "
  TXT(1)="from FACILITY inner join COMPANY on LEGCPY_0=CPY_0 inner join GACM on COMPANY.ACM_0=GCM_0 " #FACILITY.LEG_0=GCM_0 "
  TXT(2)="where FCY_0='" + PLANTA +"'"
  BD_TIPO=func DATA_BASE_TIPO()
  Onerrgo ERRORES
  For (Char FLD0(GLONLED)(10), Char FLD1(GLONCUR)(10)) From BD_TIPO Sql TXT As [MYT]
    For F=0 To 9
      REFER(F)=FLD0(F)
      RCUR(F)=FLD1(F)
    Next
    Break
  Next
  Onerrgo
End
#################################################################################

Subprog PLANES_CONTAB_PLANTA(PLANTA, PLAN, REFERE, RCUR, RANA)
  Value Char PLANTA
  Variable Char PLAN, REFERE, RCUR
  Variable Integer RANA
  Local Integer FLAG_ERR,F

  If clalev([F:LED])<=0  :  Local File GLED  [F:LED] : Endif

  Raz PLAN,REFERE,RCUR
  Onerrgo ERRORES
  Call REFERENCIALES_PLANTA(PLANTA,REFERE,RCUR)
  For F=0 To 9
    If REFERE(F)<>""
      Read [F:LED]LED0=REFERE(F)
      PLAN(F)=[F:LED]COA
      RANA(F)=[F:LED]ANA
    Endif
  Next
  Onerrgo
End
#################################################################################
Subprog EJES_CONTAB_PLANTA(REFERE,RANA, REJES)
Value Char REFERE
Value Integer RANA
Variable Char REJES
Local Integer F,L
Local Char TXT(100)
If clalev([F:LED])<=0  :  Local File GLED       [F:LED] : Endif
For F=0 To 9
  If RANA(F)=2   #  Solo hay un plan contable analitico ????
    Read [F:LED]LED0=REFERE(F)
    For L=0 To [F:LED]DIENBR-1
      REJES(L)=[F:LED]DIE(L)
#      TXT= func ZCOMUN.TRADUCIR_VALOR_CAMPO("GDIE", [F:LED]DIE(L), "SPA", 0)
#      If TXT="#"
#        TXT=[F:LED]DIE(L)
#      Else
#        TXT=[F:LED]DIE(L) + "-" + TXT
#      Endif
    Next
  Endif
Next
End
