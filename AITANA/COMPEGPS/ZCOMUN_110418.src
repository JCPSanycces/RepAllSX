Funprog DATA_BASE_TIPO
# 13.06.16 Sacado de http://www.greytrix.com/blogs/sagex3/2016/06/04/find-the-database-type-to-execute-the-sql-query-from-sage-x3/
If !clalev([XADS]) : Local File ADOSSIER [XADS] : Endif
Read [XADS] = nomap
Local Char DATABASE_TYPE(1)
If !fstat
   Case [F:XADS]TYPDBA
  When 1 :  DATABASE_TYPE="3"
  When 2 :  DATABASE_TYPE="5"
   Endcase
Endif
If clalev([XADS]) : Close File [XADS] : Endif
#  Local Integer DBTYPE
#  Local Char DATABASE_TYPE(10)
#  DBTYPE = fmet GACTX.APARAM.AGETVALNUM([V]CST_ALEVFOLD,"","TYPDBA")
#  DATABASE_TYPE=string$(DBTYPE=1,"O")+string$(DBTYPE=2,"S")

#  DATABASE_TYPE=func GETDBTYP
End DATABASE_TYPE
###############################################################################
Funprog FECHA_DIA_SEM_F(DIA_SEM,FEC)
#Devuelve el primer lun/mar a partir de la fecha pasada
Value Integer DIA_SEM
Value Date FEC
Local Date FECR,FECT
Local Integer D,F,O
F=day(eomonth(gdat$(1,1,year(FEC))))
Raz O,FECR
For D=1 To F
  FECT=gdat$(D,month(FEC),year(FEC))
  If dayn(FECT)=DIA_SEM and FECT>=FEC
    FECR=FECT
    Break
  Endif
Next
End FECR
###############################################################################

Funprog FECHA_DIA_SEM(DIA_ORD,DIA_SEM,MES,ANO)
#Devuelve el 1º/2º/3º..   lun/mar/mie/... del mes/año pasados
Value Integer DIA_ORD,DIA_SEM,MES,ANO
Local Date FEC
Local Integer D,F,O
F=day(eomonth(gdat$(1,MES,ANO)))
Raz O,FEC
For D=1 To F
  If dayn(gdat$(D,MES,ANO))=DIA_SEM
    O+=1
    If O=DIA_ORD or (O=4 and DIA_ORD>4 and D+7>F)
      FEC=gdat$(D,MES,ANO)
      Break
    Endif
  Endif
Next
End FEC

###############################################################################
Funprog DIF_FECHAS(FINI,FFIN,TIPO)
Value Date FINI,FFIN
Value Integer TIPO
Local Integer DIF
Case TIPO
When 1 # dias
  DIF=FFIN-FINI
When 2 # semanas
  DIF=(FFIN-FINI)/7
When 3 # meses
  DIF=(year(FFIN)-year(FINI))*12+month(FFIN)-month(FINI)
When 4 # años
  DIF=(year(FFIN)-year(FINI))
Endcase
End DIF

###############################################################################
Funprog CHAR_TO_DATE(TXT_FEC)
Value Char TXT_FEC
Local Date FEC
Local Char XDATE(10),D(10)
Raz FEC,XDATE
Call DATEVALIDATE(TXT_FEC,XDATE,0) From ZCOMUN
If TXT_FEC <> "" and XDATE = ""
Else
  D=format$("DD2",TXT_FEC)
  FEC=gdat$(val(mid$(D,1,2)),val(mid$(D,4,2)),val(mid$(D,7,4)))
Endif
End FEC
###############################################################################

Subprog DATEVALIDATE(VALEUR, XDATE, AVISO)
Value Char VALEUR
Variable Char XDATE
Value Integer AVISO  # 0=NO  1=SI
Local Char LC2(10):LC2=""
XDATE = format$("DD2",VALEUR)
LC2= format$("DD2","gfdbf")
#Infbox "VALEUR " + VALEUR +"   XDATE " + XDATE + "    LC2 " + LC2
If XDATE = LC2
 If VALEUR<>"" and AVISO=1 : Infbox "Fecha errónea" : Endif
 XDATE = ""
Endif
End
###############################################################################

Funprog FECHA_INI_FIN(INI,FIN)
Value Date INI,FIN
Local Integer Z_OK,OK
Z_OK=0:OK=1
If INI<>[0/0/0] Then Z_OK+=1:Endif
If FIN<>[0/0/0] Then Z_OK+=1:Endif
#Infbox "valor Z_OK=" + num$(Z_OK) + chr$(13) + INI + chr$(13) + FIN
If Z_OK=2 Then
  If INI>FIN Then
    Infbox "Fecha INICIAL no puede ser mayor que FINAL"
    OK=0
  Endif
Endif
End OK
