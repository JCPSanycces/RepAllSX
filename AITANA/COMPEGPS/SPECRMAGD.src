# Gestión de la máscara CRMAGD0 (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla CRMAGD0) 17/04/2017 10:13:04 (ADMIN)
######################################################################################
Subprog AM_REP(VALEUR)
Variable Char    VALEUR()
#Infbox "GAUSCRMF="+GAUSCRMF
If VALEUR<>""
  If !clalev([F:WZAUTAG])   :  Local File ZAUTAGENDA   [F:WZAUTAG]  :  Endif
  Read [F:WZAUTAG]ZAUTAG0=GUSER;VALEUR #[M:CRMAGD0]REP
  If fstat<>0
    Call ERREURT("El usuario "+GUSER+"\no está autorizado a ver la agenda de "+VALEUR, 0) From GESECRAN   #0-Informativo, 1-Error
    mkstat=2
    End
  Endif
Endif
End


Subprog IB_NBLIGAPP
If [M:CRM7]APTPJT(nolign-1)=""
  GBOUT3=""
Else
  GBOUT3="Proyecto "+[M:CRM7]APTPJT(nolign-1)
Endif
End


Subprog IB_NBLIGCLL
If [M:CRM2]CLLOPP(nolign-1)=""
  GBOUT10=""
Else
  GBOUT10="Proyecto "+[M:CRM2]CLLOPP(nolign-1)
Endif
End


Subprog IB_NBLIGTSK
If [M:CRM3]TSKPJT(nolign-1)=""
  GBOUT3=""
Else
  GBOUT3="Proyecto "+[M:CRM3]TSKPJT(nolign-1)
Endif
End

