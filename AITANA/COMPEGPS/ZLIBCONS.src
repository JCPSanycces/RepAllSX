#Función para devolver el valor del campo ZDIVPED CLI/DIR
#ZDIVPED A(80)
#LLAMADA:
# func ZLIBCONS.ZGETZDIVPED([M:SOH1]BPAADD,[M:SOH0]BPCORD)

Funprog ZGETZDIVPED(WADD,WCLI)
 Value Char WADD,WCLI
 Local Char WZDIVPED(80)

 Local Char WEVAL(250)
 WEVAL = " 1=1 "

 Raz WZDIVPED
 If !clalev([F:BPA]) : Local File BPADDRESS [F:BPA] : Endif

 Filter [F:BPA] Where [F:BPA]BPAADD = WADD and [F:BPA]BPANUM = WCLI and evalue(WEVAL)
 For [F:BPA]
     WZDIVPED = [F:BPA]ZDIVPED
     #Call ERREURT(WADD + " | " + WCLI + " | " + WZDIVPED, 0) From GESECRAN
     Break
 Next

End WZDIVPED


#Función para devolver el valor del campo ZACUERDO de ART/CLI
#ZACUERDO ES UNA VARIABLE MENU LOCAL 1 (NO/SI)
#LLAMADA:
# func ZLIBCONS.ZGETZACUERDO([F:SOH4]ITMREF,[F:SOH0]BPCORD)

Funprog ZGETZACUERDO(WART,WCLI)
 Value Char WART,WCLI
 Local Integer WZACUERDO

 Local Char WEVAL(250)
 WEVAL = " 1=1 "

 Raz WZACUERDO
 If !clalev([F:ITU]) : Local File ITMBPC [F:ITU] : Endif

 Filter [F:ITU] Where [F:ITU]ITMREF = WART and [F:ITU]BPCNUM = WCLI and evalue(WEVAL)
 For [F:ITU]
     WZACUERDO = [F:ITU]ZACUERDO
     #Call ERREURT(WART + " | " + WCLI + " | " + num$(WZACUERDO), 0) From GESECRAN
     Break
 Next

End WZACUERDO


#Funcion para devolver estado de movimientos de stock especifico
#Si error en alguna linea entonces el estado a devolver es error error
#El estado tiene los siguientes posibles valores dle menu local 6224 (Estados importacion)
#1->Pdte. importacion / 2->En tratamiento / 3->Importado OK / 4->Importacion ERROR
Funprog ZESTZMS(WNUM)
Value Char WNUM
Local Integer WESTNUM
Local Char WESTCAR(50)
Local Integer WNBRPTE, WNBRTRT, WNBROK, WNBRERR

If clalev ([ZMSX])<=0  :  Local File ZMOVSTO [ZMSX]  :  Endif
Filter [ZMSX] Where NUM=WNUM
WNBRPTE=0
WNBRTRT=0
WNBROK =0
WNBRERR=0
For [ZMSX]
   Case [F:ZMSX]ESTADO
      When 1 : WNBRPTE+=1
      When 2 : WNBRTRT+=1
      When 3 : WNBROK+ =1
      When 4 : WNBRERR+=1
   Endcase
Next
Filter [ZMSX]
WESTNUM=3
If WNBRERR>0
   WESTNUM=4
Endif
If WNBRTRT>0
   WESTNUM=2
Endif
If WNBRPTE>0
   WESTNUM=1
Endif
WESTCAR=""
Case WESTNUM
   When 1 : WESTCAR=mess(1,6224,1)
   When 2 : WESTCAR=mess(2,6224,1)
   When 3 : WESTCAR=mess(3,6224,1)
   When 4 : WESTCAR=mess(4,6224,1)
Endcase
WESTCAR=num$(WESTNUM)+" "+WESTCAR
End WESTNUM

#ZCALSTO -> Funcion que retorna el stock de la referencia en la ubicacion y estado pasados como parametro
Funprog ZCALSTO(WITMREF,WSTOFCY,WLOC,WSTA)

 Value Char WITMREF,WSTOFCY,WLOC,WSTA
 Local Integer WQTY

 Local Char WEVAL(250)
 WEVAL = "1=1"

 Raz WQTY
 If !clalev([F:STO]) : Local File STOCK [F:STO]: Endif

 If WLOC <> ""
    WEVAL += " AND [F:STO]LOC = WLOC"
 Endif
 If WSTA <> ""
   WEVAL += " AND LEFT$([F:STO]STA,1) = '"+WSTA+"'"
 Endif

 Filter [F:STO] Where ITMREF = WITMREF and STOFCY = WSTOFCY and evalue(WEVAL)
 For [F:STO]
     WQTY += [F:STO]QTYSTU-[F:STO]CUMALLQTY
 Next

End WQTY

#ZCALSTO2 -> Funcion que retorna el stock de la referencia en el tipo de ubicacion y estado pasados como parametro
Funprog ZCALSTO2(WITMREF,WSTOFCY,WLOC,WSTA)

 Value Char WITMREF,WSTOFCY,WLOC,WSTA
 Local Integer WQTY

 Local Char WEVAL(250)
 WEVAL = "1=1"

 Raz WQTY
 If !clalev([F:STO]) : Local File STOCK [F:STO]: Endif

 If WLOC <> ""
    WEVAL += " AND [F:STO]LOCTYP = WLOC"
 Endif
 If WSTA <> ""
   WEVAL += " AND LEFT$([F:STO]STA,1) = '"+WSTA+"'"
 Endif

 Filter [F:STO] Where ITMREF = WITMREF and STOFCY = WSTOFCY and evalue(WEVAL)
 For [F:STO]
     WQTY += [F:STO]QTYSTU-[F:STO]CUMALLQTY
 Next

End WQTY

#ZCALSTO3 -> Funcion que retorna el stock de la referencia en el tipo de ubicacion diferente al pasado
#            como parametro
Funprog ZCALSTO3(WITMREF,WSTOFCY,WLOC,WSTA)

 Value Char WITMREF,WSTOFCY,WLOC,WSTA
 Local Integer WQTY

 Local Char WEVAL(250)
 WEVAL = "1=1"

 Raz WQTY
 If !clalev([F:STO]) : Local File STOCK [F:STO]: Endif

 If WLOC <> ""
    WEVAL += " AND [F:STO]LOCTYP <> WLOC"
 Endif
 If WSTA <> ""
   WEVAL += " AND LEFT$([F:STO]STA,1) = '"+WSTA+"'"
 Endif

 Filter [F:STO] Where ITMREF = WITMREF and STOFCY = WSTOFCY and evalue(WEVAL)
 For [F:STO]
     WQTY += [F:STO]QTYSTU-[F:STO]CUMALLQTY
 Next

End WQTY

#ZCALSTO4-> Retorna el stock del articulo para los tipos de ubicacion y estados
#           pasados como parametro
Funprog ZCALSTO4(WITMREF,WSTOFCY,WTLOC1,WTLOC2,WTLOC3,WTLOC4,WTLOC5,WSTA1,WSTA2)

 Value Char WITMREF(),WSTOFCY(),WTLOC1(),WTLOC2(),WTLOC3(),WTLOC4(),WTLOC5(),WSTA1(),WSTA2()
 Local Integer WQTY

 Local Char WEVAL(250)
 WEVAL = "1=1"

 Raz WQTY
 If !clalev([F:STO]) : Local File STOCK [F:STO]: Endif

 If WTLOC1 <> "" and WTLOC2<>"" and WTLOC3<>"" and WTLOC4<>"" and WTLOC5<>""
    WEVAL += " AND ([F:STO]LOCTYP = WTLOC1 OR [F:STO]LOCTYP=WTLOC2 OR [F:STO]LOCTYP=WTLOC3 OR [F:STO]LOCTYP=WTLOC4 OR [F:STO]LOCTYP=WTLOC5)"
 Endif
 If WTLOC1 <> "" and WTLOC2<>"" and WTLOC3<>"" and WTLOC4<>"" and WTLOC5=""
    WEVAL += " AND ([F:STO]LOCTYP = WTLOC1 OR [F:STO]LOCTYP=WTLOC2 OR [F:STO]LOCTYP=WTLOC3 OR [F:STO]LOCTYP=WTLOC4)"
 Endif
 If WTLOC1 <> "" and WTLOC2<>"" and WTLOC3<>"" and WTLOC4="" and WTLOC5=""
    WEVAL += " AND ([F:STO]LOCTYP = WTLOC1 OR [F:STO]LOCTYP=WTLOC2 OR [F:STO]LOCTYP=WTLOC3)"
 Endif
 If WTLOC1 <> "" and WTLOC2<>"" and WTLOC3="" and WTLOC4="" and WTLOC5=""
    WEVAL += " AND ([F:STO]LOCTYP = WTLOC1 OR [F:STO]LOCTYP=WTLOC2)"
 Endif
 If WTLOC1 <> "" and WTLOC2="" and WTLOC3="" and WTLOC4="" and WTLOC5=""
    WEVAL += " AND ([F:STO]LOCTYP = WTLOC1)"
 Endif
 If WSTA1 <> "" and WSTA2 <>""
   WEVAL += " AND (LEFT$([F:STO]STA,1) = '"+WSTA1+"' OR LEFT$([F:STO]STA,1) = '"+WSTA2+"')"
 Endif
 If WSTA1 <> "" and WSTA2 =""
   WEVAL += " AND (LEFT$([F:STO]STA,1) = '"+WSTA1+"')"
 Endif

 Filter [F:STO] Where ITMREF = WITMREF and STOFCY = WSTOFCY and evalue(WEVAL)
 For [F:STO]
     WQTY += [F:STO]QTYSTU-[F:STO]CUMALLQTY
 Next

End WQTY

Funprog CALVENTSEM(WITMREF,WSTOFCY,WLOC,WINI,WFIN)

   Value Char WITMREF,WSTOFCY,WLOC
   Value Char WINI,WFIN
   Local Decimal WQTYV, WQTYD, WQTYR
   Local Char WREQUETE(250)(1..2)

   WQTYV=0

   WREQUETE(1) = " SELECT ITMREF_0,ISNULL(SUM(QTY_0),0) FROM SDELIVERYD WHERE SHIDAT_0 >= ( GETDATE()-"+WFIN+" ) AND SHIDAT_0 <= GETDATE() "
   If WINI <> ""
      WREQUETE(1) += " -"+WINI+""
   Endif

   WREQUETE(2) = " AND ITMREF_0 = '"+WITMREF+"' AND STOFCY_0='"+WSTOFCY+"'"
   WREQUETE(2) += " GROUP BY ITMREF_0"
   For (Char WITM,Decimal WQTY) From "5" Sql WREQUETE(1..2) As  [XXX]
     WQTYV += [XXX]WQTY
   Next

   WQTYD=0
   WREQUETE(1) = " SELECT ITMREF_0,ISNULL(SUM(QTY_0),0) FROM SRETURND WHERE RTNDAT_0 >= ( GETDATE()-"+WFIN+" ) AND RTNDAT_0 <= GETDATE() "
   If WINI <> ""
      WREQUETE(1) += " -"+WINI+""
   Endif

   WREQUETE(2) = " AND ITMREF_0 = '"+WITMREF+"' AND STOFCY_0='"+WSTOFCY+"'"
   WREQUETE(2) += " GROUP BY ITMREF_0"
   For (Char WITM,Decimal WQTY) From "5" Sql WREQUETE(1..2) As  [XXX]
     WQTYD += [XXX]WQTY
   Next

   WQTYR=WQTYV-WQTYD
End WQTYR

#ZCALCUMQTY -> Funcion que retorna la asignacion de la referencia en la ubicacion y estado pasados como parametro
Funprog ZCALCUMQTY(WITMREF,WSTOFCY,WLOC,WSTA)

 Value Char WITMREF,WSTOFCY,WLOC,WSTA
 Local Integer WQTY

 Local Char WEVAL(250)
 WEVAL = "1=1"

 Raz WQTY
 If !clalev([F:STO]) : Local File STOCK [F:STO]: Endif

 If WLOC <> ""
    WEVAL += " AND [F:STO]LOC = WLOC"
 Endif
 If WSTA <> ""
   WEVAL += " AND LEFT$([F:STO]STA,1) = '"+WSTA+"'"
 Endif

 Filter [F:STO] Where ITMREF = WITMREF and STOFCY = WSTOFCY and evalue(WEVAL)
 For [F:STO]
     WQTY += [F:STO]CUMALLQTY
 Next

End WQTY

Funprog TEXTO(WTSICOD,WREF)

  Value Char WTSICOD,WREF
  Local Char WTEXTO(75)

  Raz WTEXTO

  If !clalev([F:AXX]): Local File ATEXTRA [AXX] : Endif

  Read [AXX]AXX0 = "ATABDIV";"LNGDES";"SPA";WREF;WTSICOD
  WTEXTO = [AXX]TEXTE

End WTEXTO


Funprog CALPRICOMP(WITMREF,WBPSNUM)

Value Char WITMREF(),WBPSNUM()
Local Decimal WPRI
Local Char WPRI2(20)

Raz WPRI

If !clalev([F:PPL]) : Local File PPRICLIST [PPL] : Endif

 Filter [F:PPL] Where WITMREF = PLICRI2 and PLI = "T01" and PLISTRDAT <= date$ and PLIENDDAT >= date$
 For [F:PPL]
     WPRI = [F:PPL]PRI
 Next

 WPRI2 = ctrans(num$(WPRI),",",".")

End WPRI2


Funprog CALPRIVEN(WITMREF)

Value Char WITMREF()
Local Decimal WPRI
Local Char WPRI2(20)

Raz WPRI

If !clalev([F:SPL]) : Local File SPRICLIST [SPL] : Endif

 Filter [F:SPL] Where PLICRI1= "001" and WITMREF = PLICRI2 and PLI = "T01" and PLISTRDAT <= date$ and PLIENDDAT >= date$
 For [F:SPL]
     WPRI = [F:SPL]PRI
 Next

 WPRI2 = ctrans(num$(WPRI),",",".")

End WPRI2

Funprog CALPRIVEND(WITMREF)

Value Char WITMREF()
#Local Char WBPSNUM
Local Decimal WPRI

Raz WPRI

If !clalev([F:PPL]) : Local File PPRICLIST [PPL] : Endif

 Filter [F:PPL] Where WITMREF = PLICRI2 and PLI = "T01" and PLISTRDAT <= date$ and PLIENDDAT >= date$
 For [F:PPL]
     WPRI = [F:PPL]DCGVAL
 Next

 WPRI2 = ctrans(num$(WPRI),",",".")

End WPRI2

Funprog FUNDESC(WITMREF,WLAN)

Value Char WITMREF(),WLAN()
Local Char WDESC(250)

 If !clalev([F:AXX]): Local File ATEXTRA [AXX] : Endif

  Raz [AXX]
  Read [AXX]AXX0 = "ITMMASTER";"DES1AXX";WLAN;WITMREF;""
  WDESC = [AXX]TEXTE


End WDESC

#Retorna el codigo de proveedor
Funprog BUSBPS(WITMREF)
 Value Char WITMREF()

 Local Char  WDESC(20)

 If !clalev ([F:ITPX]) : Local File ITMBPS [ITPX] : Endif

 Filter [F:ITPX] Where ITMREF = WITMREF
 For [F:ITPX]
   WDESC = [F:ITPX]BPSNUM
 Next
 Filter [ITPX]

End WDESC

#Retorna el codigo de proveedor
Funprog BUSBPSNOM(WITMREF)
 Value Char WITMREF()

 Local Char  WBPSNUM(15), WDESC(30)

 If !clalev ([F:ITPX]) : Local File ITMBPS     [ITPX] : Endif
 If !clalev ([F:BPSX]) : Local File BPSUPPLIER [BPSX] : Endif

 Raz WBPSNUM
 Filter [F:ITPX] Where ITMREF = WITMREF
 For [F:ITPX]
   WBPSNUM = [F:ITPX]BPSNUM
 Next
 Filter [ITPX]
 Raz [F:BPSX]
 Read [BPSX]BPS0=[F:ITPX]BPSNUM
 Raz WDESC
 WDESC=[F:BPSX]BPSNAM
End WDESC

#Retorna la refernecia de proveedor
Funprog BUSITMREF(WITMREF)
 Value Char WITMREF()

 Local Char  WDESC(20)

 If !clalev ([F:ITPX]) : Local File ITMBPS [ITPX] : Endif

 Filter [F:ITPX] Where ITMREF = WITMREF
 For [F:ITPX]
   WDESC = [F:ITPX]ITMREFBPS
 Next

 Filter [ITPX]
End WDESC

#ZC_LISA -> Retorna la camiseta lisa (primer componente) de la estructura
Funprog ZC_LISA(WESTR)

  Value Char WESTR()
  Local Char WCAML(25)

  Raz WCAML

  If !clalev([F:BOM]): Local File BOM       [BOM] : Endif
  If !clalev([F:BOD]): Local File BOMD      [BOD] : Endif
  If !clalev([F:ITX]): Local File ITMMASTER [ITX] : Endif

  Filter [BOD] Where ITMREF=WESTR Order By Key BOD0

  For [BOD]
     Read [F:ITX]ITM0=[F:BOD]CPNITMREF
     If [F:ITX]ZESTAMPABLE
        WCAML = [F:BOD]CPNITMREF
        Break
     Endif
  Next
  Filter [BOD]
End WCAML

#ZSTO_CLISA -> Retorna el stock de la camiseta lisa (primer componente) de la estructura
Funprog ZSTO_CLISA(WESTR)

  Value Char WESTR()
  Local Char WCAML(25)
  Local Decimal WSTOCL

  Raz WCAML
  Raz WSTOCL

  If !clalev([F:BOM]): Local File BOM       [BOM] : Endif
  If !clalev([F:BOD]): Local File BOMD      [BOD] : Endif
  If !clalev([F:ITX]): Local File ITMMASTER [ITX] : Endif

  Filter [BOD] Where ITMREF=WESTR Order By Key BOD0

  For [BOD]
     Read [F:ITX]ITM0=[F:BOD]CPNITMREF
     If [F:ITX]ZESTAMPABLE
        WCAML = [F:BOD]CPNITMREF
        Break
     Endif
  Next

  If WCAML<>""
     WSTOCL = func ZLIBCONS.ZCALSTO4(WCAML,"001","REC","NIK","PUL","VAS","","A","Q")
  Endif

End WSTOCL

#ZCTDPTE_FIRME -> Retorna la cantidad pendiente de seguimiento de las OF en firme
#WSTA -> 1 - Firme / 2 - Planificado
#MFGPIO -> 1 - Normal / 2 - Urgente / 3 - Muy urgente
Funprog ZCTDPTE_FIRME(WITMREF, WSTA, WPIO)

  Value Char WITMREF()
  Value Integer WSTA
  Value Integer WPIO
  Local Decimal WFIRME

  If !clalev([F:MFG]): Local File MFGHEAD   [MFG] : Endif
  If !clalev([F:MFI]): Local File MFGITM    [MFI] : Endif

  Raz WFIRME
  Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM As [LNK]
  Filter [LNK] Where [MFI]ITMREF=WITMREF and pat([MFG]MFGNUM,'MFG*') and [MFG]MFGSTA=WSTA

  For [LNK]
     WFIRME += [F:MFG]RMNEXTQTY
  Next
End WFIRME

#ZCTDPTE_FIRME -> Retorna la cantidad pendiente de seguimiento de las OF en firme
#WSTA -> 1 - Firme / 2 - Planificado
#MFGPIO -> 1 - Normal / 2 - Urgente / 3 - Muy urgente
Funprog ZCTDPTE_PLANIF(WITMREF, WSTA, WPIO)

  Value Char WITMREF()
  Value Integer WSTA
  Value Integer WPIO
  Local Decimal WPLANIF

  If !clalev([F:MFG]): Local File MFGHEAD   [MFG] : Endif
  If !clalev([F:MFI]): Local File MFGITM    [MFI] : Endif

  Raz WPLANIF
  Link [MFI] With [MFG]MFG0=[F:MFI]MFGNUM As [LNK]
  Filter [LNK] Where [MFI]ITMREF=WITMREF and pat([MFG]MFGNUM,'MFG*') and [MFG]MFGSTA=WSTA and [MFG]MFGPIO=WPIO

  For [LNK]
     WPLANIF += [F:MFG]RMNEXTQTY
  Next
End WPLANIF

#ZMINMAXLOC_CAR -> Retorna el minimo-maximo de una referencia para una ubicacion en un string
Funprog ZMINMAXLOC_CAR(WFCY, WITMREF, WLOC)

  Value Char WFCY()
  Value Char WITMREF()
  Value Char WLOC()
  Local Char WMINMAX(15)

  Raz WMINMAX

  If !clalev([F:STF]): Local File STOLOCAFF [STF] : Endif

  Read [STF]STF1=WFCY;WITMREF;WLOC

  If fstat=0
     WMINMAX= num$([F:STF]REOTSD)+" - "+num$([F:STF]MAXSTO)
  Endif

End WMINMAX

#ZMINMAXLOC_CAR -> Retorna el minimo o el maximo, segun WTIPO de una referencia para una ubicacion
#                  WTIPO: 1-Minimo / 2-Maximo
Funprog ZMINMAXLOC(WFCY, WITMREF, WLOC, WTIPO)
  Value Char WFCY()
  Value Char WITMREF()
  Value Char WLOC()
  Value Integer WTIPO
  Local Decimal WMINMAX

  Raz WMINMAX

  If !clalev([F:STF]): Local File STOLOCAFF [STF] : Endif

  Read [STF]STF1=WFCY;WITMREF;WLOC

  If fstat=0
     If WTIPO=1
        WMINMAX= [F:STF]REOTSD
     Else
        WMINMAX= [F:STF]MAXSTO
     Endif
  Endif

End WMINMAX

#ZPRIULTVTA -> Retorna la fecha de primera o ultimaventa, segun WTIPO, de una referencia
#                  WTIPO: 1-Minimo / 2-Maximo
Funprog ZPRIULTVTA(WFCY,WITMREF,WTIPO)
  Value Char WFCY()
  Value Char WITMREF()
  Value Integer WTIPO
  Local Date WPRIVTA,WULTVTA,WFECHA

  Raz WPRIVTA
  Raz WULTVTA

  If !clalev([F:SDD]): Local File SDELIVERYD [SDD] : Endif

  Filter [SDD] Where ITMREF=WITMREF and STOFCY=WFCY Order By Key SDD2 Asc
  For [SDD]
     WPRIVTA=[F:SDD]SHIDAT
     Break
  Next
  Filter [SDD]
  Filter [SDD] Where ITMREF=WITMREF and STOFCY=WFCY Order By Key SDD2 Desc
  For [SDD]
     WULTVTA=[F:SDD]SHIDAT
     Break
  Next
  Filter [SDD]

  If WTIPO=1
     WFECHA = WPRIVTA
  Else
     WFECHA = WULTVTA
  Endif

End WFECHA

#Función para devolver las unidades de pedidos de compra sin saldar
# en todas las plantas de un artículo
#LLAMADA:
# func ZLIBCONS.ZGETUDSCOM([F:ITM]ITMREF)

Funprog ZGETUDSCOM(WITM,WRESULTAT)
 Value Char WITM
 Variable Integer WRESULTAT
 Local Char WQUERY(250)

 WQUERY = " SELECT ISNULL(SUM(QTYSTU_0),0) FROM PORDERQ WHERE ITMREF_0 = '"+WITM+"' AND LINCLEFLG_0 = 1 GROUP BY ITMREF_0"
 Infbox(WQUERY)

 For (Decimal WWUNIPED) From "5" Sql WQUERY As [XXX]
    WRESULTAT = int([F:XXX]WWUNIPED)
 Next

#WRESULTAT = 320

End WRESULTAT


