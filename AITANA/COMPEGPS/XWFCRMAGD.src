#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
When "OUVRE"    :   Gosub OUVRE
When "FIN"      :   Gosub FIN
When "BOUTON"   :   Gosub BOUTON
When "SETBOUT"  :   Gosub SETBOUT
When Default
Endcase
Return

$OUVRE
Global Decimal GFLDNUM(5)
Raz GFLDNUM
Return

$FIN
Kill GFLDNUM
Return


$BOUTON
Case BOUT
When "C"
  GFLDNUM(0)=1
When Default
Endcase
Return

$SETBOUT
If GFLDNUM(0)=1
  Raz GFLDNUM(0)
  Call COMPLETAR__BAP
  Call COMPLETAR__CLL
  Call COMPLETAR__TSK
  Call COMPLETAR__OPP
Endif
Return

Subprog COMPLETAR__BAP
Local Integer F
For F=0 To [M:CRM7]NBLIGAPP-1
  If [M:CRM7]APTPJT(F)<>""
    [M:CRM7]ZCAMID(F)=func ZCAMPA([M:CRM7]APTPJT(F))
  Endif
Next
Affzo [M:CRM7]1-99
End

Subprog COMPLETAR__CLL
Local Integer F
For F=0 To [M:CRM2]NBLIGCLL-1
  If [M:CRM2]CLLOPP(F)<>""
    [M:CRM2]ZCAMID(F)=func ZCAMPA([M:CRM2]CLLOPP(F))
  Endif
Next
Affzo [M:CRM2]1-99
End

Subprog COMPLETAR__TSK
Local Integer F
For F=0 To [M:CRM3]NBLIGTSK-1
  If [M:CRM3]TSKPJT(F)<>""
    [M:CRM3]ZCAMID(F)=func ZCAMPA([M:CRM3]TSKPJT(F))
  Endif
Next
Affzo [M:CRM3]1-99
End

Subprog COMPLETAR__OPP
End

Funprog ZCAMPA(PROYECTO_P)
Value Char PROYECTO_P
Local Char CAMPANA(20)
If !clalev([F:WOPP])   :  Local File OPPOR   [F:WOPP]  :  Endif
Read [F:WOPP]OPP0=PROYECTO_P
If fstat=0  CAMPANA=[F:WOPP]ZCAMID  Endif
End  CAMPANA

