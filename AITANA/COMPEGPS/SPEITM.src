# Gestión de la máscara ITM6 (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ITM6) 17/05/2016 20:11:40 (ADMIN)
######################################################################################

$ACTION
Case ACTION
 When "EXEBOUT"       : Gosub EXEBOUT
 When Default
Endcase
Return

Subprog IB_ZLISTCOME
End

$EXEBOUT
Case BOUT
   When "5" :
      # FJCP ZCVP - Gestion Compra Venta en Pedidos.
      Gosub TR_ZART
      If GOK : Gosub RELIT From GOBJSUB : Endif
      # FIN FJCP ZCVP - Gestion Compra Venta en Pedidos.
Endcase

Return

$TR_ZART


## Preguntar si Continua
  Local Integer LOK
  Local Char ERRORES(255)(0..)

    LOK=1
    Call OUINON ("Se actualizarán las traducciones de las descripciones del artículo.¿Continuar?",LOK) From GESECRAN
    If LOK<>2: Return:  Endif

#Call TRADUCCIONES([M:ITM0]ITMREF) From ZFUNCIONES
  #ERRORES=func ZFUNCIONES.TRADUCCIONES([M:ITM0]ITMREF)

    Call TRADUCCIONES([M:ITM0]ITMREF,ERRORES) From ZFUNCIONES



Return


