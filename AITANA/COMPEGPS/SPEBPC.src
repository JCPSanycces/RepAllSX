#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
   When "LIENS" : Gosub $LIENS
   When "INIMOD"  : Gosub $INIMOD
   When "INICRE" : Gosub $INICRE
   When "FIN_MOD"  : Gosub $FINMOD #FPP - 210618
Endcase
Return

$LIENS
Local Integer WN
Raz [M:ZBPC2]

WN=0
For I=0 To 9
  If [F:BPC]ZPLAPER(I)<>""
    [M:ZBPC2]ZPLAPER(WN)=[F:BPC]ZPLAPER(I)
    [M:ZBPC2]ZPLAVAC(WN)=[F:BPC]ZPLAVAC(I)
    [M:ZBPC2]ZPLAPTE(WN)=[F:BPC]ZPLAPTE(I)
    WN+=1
  Else
    [M:ZBPC2]ZPLAPER(I)=""
    [M:ZBPC2]ZPLAVAC(I)=""
    [M:ZBPC2]ZPLAPTE(I)=""
  Endif
Next
[M:ZBPC2]ZNPLAPER=WN
Affzo [M:ZBPC2]
Return

$INIMOD
Gosub $INICRE_ZBPC2
Return

$INICRE
Gosub $INICRE_ZBPC2
Return

$INICRE_ZBPC2
Local Integer WN
WN=0
# Borrado
For I=0 To 9
 [F:BPC]ZPLAPER(I)=""
 [F:BPC]ZPLAVAC(I)=""
 [F:BPC]ZPLAPTE(I)=""
Next
#Asignacion
For I=0 To [M:ZBPC2]ZNPLAPER - 1
  If [M:ZBPC2]ZPLAPER(I)<>""
    [F:BPC]ZPLAPER(WN)=[M:ZBPC2]ZPLAPER(I)
    [F:BPC]ZPLAVAC(WN)=[M:ZBPC2]ZPLAVAC(I)
    [F:BPC]ZPLAPTE(WN)=[M:ZBPC2]ZPLAPTE(I)
    WN+=1
  Endif
Next
Return

#FPP - 300118
$EXPDATA
  Call EXPDATA([F:BPC]BPCNUM) From ZEXPCLI
Return

#FPP - 300118
$FINMOD
    Gosub $EXPDATA
Return

