# Gestión de la máscara ZTSK2 (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZTSK2) 06/04/2017 17:46:32 (ADMIN)
######################################################################################
Subprog AM_ZDPAUTA(VALEUR)
Variable Integer VALEUR
Case VALEUR
When 1 # Una sola vez
  Actzo [M:ZTSK2]ZDP1HORINI
  Actzo [M:ZTSK2]ZDP1HORFIN
  [M:ZTSK2]ZDP1HORINI= left$(time$,5)
  [M:ZTSK2]ZDP1HORFIN=[M:ZTSK2]ZDP1HORINI
  Raz [M:ZTSK2]ZDP2CADA,[M:ZTSK2]ZDP2HORINI,[M:ZTSK2]ZDP2HORFIN
  Grizo [M:ZTSK2]ZDP2CADA
  Grizo [M:ZTSK2]ZDP2HORINI
  Grizo [M:ZTSK2]ZDP2HORFIN
When 2 # Cada x horas
  Actzo [M:ZTSK2]ZDP2CADA
  Actzo [M:ZTSK2]ZDP2HORINI
  Actzo [M:ZTSK2]ZDP2HORFIN
  [M:ZTSK2]ZDP2CADA=1
  [M:ZTSK2]ZDP2HORINI= left$(time$,5)
  [M:ZTSK2]ZDP2HORFIN=[M:ZTSK2]ZDP2HORINI
  Raz [M:ZTSK2]ZDP1HORINI,[M:ZTSK2]ZDP1HORFIN
  Grizo [M:ZTSK2]ZDP1HORINI
  Grizo [M:ZTSK2]ZDP1HORFIN
When 3 # Todo el dia
  Raz [M:ZTSK2]ZDP1HORINI,[M:ZTSK2]ZDP1HORFIN,[M:ZTSK2]ZDP2CADA,[M:ZTSK2]ZDP2HORINI,[M:ZTSK2]ZDP2HORFIN
  Grizo [M:ZTSK2]ZDP1HORINI
  Grizo [M:ZTSK2]ZDP1HORFIN
  Grizo [M:ZTSK2]ZDP2CADA
  Grizo [M:ZTSK2]ZDP2HORINI
  Grizo [M:ZTSK2]ZDP2HORFIN
Endcase
Affzo [M:ZTSK2]
End

