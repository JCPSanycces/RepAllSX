#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  #Infbox(ACTION)
     Case ACTION
      When "EXEC"  : Gosub EXEC
      When "OUVRE" : Gosub OUVRE
      When "CONTROLE" : Gosub CONTROLE
      When "OK"    : Gosub OK
      When "DEBUT" : Gosub DEBUT
      When Default
     Endcase
Return

$CONTROLE
    TMP = 1
    TIT = "Importación en curso"
Return

$OK
    WEXE = 1
    WNOM = [M:ZIMPCSV]NOMFIC(0)
    CODMODELO = [M:ZIMPCSV]ZMOD1

Return

$OUVRE
    Global Char WNOM(250)
    Global Integer WEXE
    Global Integer CODMODELO

    WEXE = 0
Return

$DEBUT
   Local Char MENSAJE(255)
   Local Char MENSAJE2(255)

   Append MENSAJE,"Esta opción permite al usuario importar ficheros para la generación de pedidos a proveedor." +chr$(13)
   Append MENSAJE,"Existen 2 modelos según si se incluye el precio en fichero o si tiene que ser calculado por X3." +chr$(13)
   Append MENSAJE2,"Antes compruebe que la estructura de los mismos es correcta."

   Call ERREURT(MENSAJE+MENSAJE2, 0) From GESECRAN

Return

$EXEC
   If WEXE = 1
      Gosub PROCESA
   Endif
Return

$PROCESA
  WNOM = mid$(WNOM,7,len(WNOM))
  WNOM = filpath("BQT","","") +"\" +WNOM

  Call OUVRE_TRACE("Importación de fichero csv "+WNOM) From LECFIC
  #Call ECR_TRACE(" Importación de fichero csv de pedido de compra "+WNOM,0) From GESECRAN

  If CODMODELO=1 Then
    Call IMPORTSIL("ZPOH",filpath("BQT",WNOM,"")) From GIMPOBJ
  Else
    Call IMPORTSIL("ZPOH2",filpath("BQT",WNOM,"")) From GIMPOBJ
  Endif

  Call LEC_TRACE() From LECFIC

Return

