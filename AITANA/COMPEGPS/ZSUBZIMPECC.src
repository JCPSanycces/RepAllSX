#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
    When "INIT"        : Gosub INIT
    When "EXEC"        : Gosub EXEC
    When "OK"          : Gosub OK
    When "OUVRE"       : Gosub OUVRE
    When "OUVRE_BATCH" : Gosub TRT_INI
    When "TERMINE"     : Gosub TERMINE
    When "END"         : Gosub END_IMP
  Endcase
Return

$ERRBATCH
  Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

$INIT
  #Tablas propias
  If !clalev([ZECCCLI])  : Local File ZECCCLI    [ZECCCLI]  : Endif
  If !clalev([WZECCCLI]) : Local File ZECCCLI   [WZECCCLI]  : Endif
  If !clalev([ZECCCAB])  : Local File ZECCCABFAC [ZECCCAB]  : Endif
  If !clalev([WZECCCAB]) : Local File ZECCCABFAC [WZECCCAB] : Endif
  If !clalev([ZECCLIN])  : Local File ZECCLINFAC [ZECCLIN]  : Endif
  If !clalev([WZECCLIN]) : Local File ZECCLINFAC [WZECCLIN] : Endif
  If !clalev([ZECCPAG])  : Local File ZECCPAGFAC [ZECCPAG]  : Endif
  If !clalev([WZECCPAG]) : Local File ZECCPAGFAC [WZECCPAG] : Endif
  If !clalev([ZECCMAT])  : Local File ZECCMATCH  [ZECCMAT]  : Endif
  If !clalev([ZECCLAC])  : Local File ZECCCLIACT [ZECCLAC]  : Endif

  #Tablas X3
  If !clalev([BPC])  : Local File BPCUSTOMER [BPC] : Endif
  If !clalev([XBPC]) : Local File BPCUSTOMER [XBPC] : Endif
  If !clalev([XBPR]) : Local File BPARTNER   [XBPR] : Endif
  If !clalev([XBPA]) : Local File BPADDRESS  [XBPA] : Endif
  If !clalev([XTVC]) : Local File TABVAC     [XTVC] : Endif
  If !clalev([XTVB]) : Local File TABVACBPR  [XTVB] : Endif
  If !clalev([SIH])  : Local File SINVOICE   [SIH]  : Endif
  If !clalev([DUD])  : Local File GACCDUDATE [DUD]  : Endif
  If !clalev([XTPT]) : Local File TABPAYTERM [XTPT] : Endif
  If !clalev([FIY])  : Local File FISCALYEAR [FIY]  : Endif
  If !clalev([ZSID]) : Local File SINVOICED  [ZSID] : Endif
  If !clalev([SIH])  : Local File SINVOICE   [SIH]  : Endif
  If !clalev([SID])  : Local File SINVOICED  [SID]  : Endif
  If !clalev([ZSIH2]): Local File SINVOICE   [ZSIH2]: Endif
  If !clalev([ZSIH]) : Local File SINVOICE   [ZSIH] : Endif
  If !clalev([WSIH]) : Local File SINVOICE   [WSIH] : Endif
  If !clalev([SIV])  : Local File SINVOICEV  [SIV]  : Endif
  If !clalev([SOH])  : Local File SORDER     [SOH]  : Endif
  If !clalev([ZSOH]) : Local File SORDER     [ZSOH] : Endif
  If !clalev([ITM])  : Local File ITMMASTER  [ITM]  : Endif
  If !clalev([STJ])  : Local File STOJOU     [STJ]  : Endif
  If !clalev([BOD])  : Local File BOMD       [BOD]  : Endif
  If !clalev([ZSRH]) : Local File SRETURN    [ZSRH]  : Endif


  Local Integer NUMERRORES

Return

$EXEC
  Local Char FICHEROTRAZA(250)
  Local Char     ASUNTO(250)
  Local Clbfile  ENCABEZADO(0)
  Local Clbfile  PIE(0)
  Local Clbfile  MENSAJE(0)
  Local Clbfile  PROCLI(0)
  Local Clbfile  PROPED(0)
  Local Clbfile  PROFAC(0)
  Local Clbfile  PROABO(0)
  Local Clbfile  PROVEN(0)
  Local Clbfile  PROMAT(0)
  Local Clbfile  PROVAL(0)

  Local Integer  PROERR

  Call TEMPON("") From GESECRAN

  If GSERVEUR
    Onerrgo ERRBATCH
    Call ECR_TRACE("Importando ficheros de Ecommerce",0) From GESECRAN
  Else
   Call OUVRE_TRACE("Importando ficheros de Ecommerce") From LECFIC
  Endif
  FICHEROTRAZA=filpath("TRA",GTRACE,"tra")

  WMSG = "Importación de ficheros de Ecommerce"
  Call ECR_TRACE(WMSG,0) From GESECRAN
  Call ECR_TRACE(mess(174,100,1),-1) From GESECRAN
  Call PRTSCR("ZSUBZIMPECC","","",0,1) From ATRTX3
  Call ECR_TRACE(mess(51,9010,1),-1) From GESECRAN

  #LEEMOS LOS FICHEROS Y GUARDAMOS EL CONTENIDO EN LAS TABLAS INTERMEDIAS DE X3
  #Gosub CREAR_COBROS
  #End

  Gosub LEER_FICHEROS

  Gosub CREAR_CLIENTES
  Gosub IMPORTAR_CLIENTES

  Gosub CREAR_FACTURAS_VENTA
  Gosub IMPORTAR_FACTURAS
  Gosub CREAR_PEDIDOS_VENTA
  Gosub IMPORTAR_PEDIDOS_VENTA

  If GFONCTION="ZIMPECCABO" Then
    Gosub CREAR_ABONOS_VENTA
  Endif

  Gosub CREAR_VENCIMIENTOS
  Gosub IMPORTAR_VENCIMIENTOS

  Gosub COMPROBAR_MATCH

  Gosub VALIDAR_DOCUMENTOS

  Gosub CREAR_CLIENTES_ACTU
  Gosub IMPORTAR_CLIENTES_ACTU


  Call TEMPOFF From GESECRAN


Return

$OK
Return

$OUVRE
Return

$TRT_INI


Return

$TERMINE
  If !GSERVEUR
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
    Call IMPSCR From ATRTX3
  Endif

  If PROERR=2 Then
     Append ASUNTO,"Proceso de importación ECC/X3 en COMPEGPS *** ERRORES ***"
  Else
     Append ASUNTO,"Proceso de importación ECC/X3 en COMPEGPS *** CORRECTO ***"
  Endif
  Append MENSAJE,PROCLI
  Append MENSAJE,PROPED
  Append MENSAJE,PROFAC
  Append MENSAJE,PROABO
  Append MENSAJE,PROVEN
  Append MENSAJE,PROMAT
  Append MENSAJE,PROVAL

  Gosub ENVIAR_EMAIL
Return

$END_IMP
Return

$LEER_REGISTRO
Rdseq A(1), A(2), A(3), A(4), A(5), A(6), A(7), A(8), A(9), A(10),
& A(11), A(12), A(13), A(14), A(15), A(16), A(17), A(18), A(19), A(20),
& A(21), A(22), A(23), A(24), A(25), A(26), A(27), A(28), A(29), A(30),
& A(31), A(32), A(33), A(34), A(35), A(36), A(37), A(38), A(39), A(40),
& A(41), A(42), A(43), A(44), A(45), A(46), A(47), A(48), A(49), A(50),
& A(51), A(52), A(53), A(54), A(55), A(56), A(57), A(58), A(59), A(60),
& A(61), A(62), A(63), A(64), A(65), A(66), A(67), A(68), A(69), A(70),
& A(71), A(72), A(73), A(74), A(75), A(76), A(77), A(78), A(79), A(80),
& A(81), A(82), A(83), A(84), A(85), A(86), A(87), A(88), A(89), A(90),
& A(91), A(92), A(93), A(94), A(95), A(96), A(97), A(98), A(99), A(100),
& A(101), A(102), A(103), A(104), A(105), A(106), A(107), A(108), A(109), A(110) Using [TIE]
Return

$LEER_FICHEROS
  Local Char RESULT  (200)(9000)
  Local Char NOMFIC  (250)
  Local Integer STAT
  Local Char A(250)(1..110)
  Local Integer WINC
  Local Integer CONTALIN
  Local Char WBPR (GLONBPR)
  Local Char WBPRPAG (GLONBPR)
  Local Integer ZENLACE
  Local Date FECHADOC
  Local Date FECHAENT
  Local Date FECHAVENC
  Local Char CONDPAGO(50)
  Local Char FPAGO(30)
  Local Char REQUEST(250)
  Local Integer NUMNIF
  Local Integer EXISTEPED
  Local Date FECHAMATCH

  adxifs=";"
  adxirs=chr$(13)+chr$(10)
  adxium=50 # ASCII

   #Leemos los ficheros generados que se encuentran dentro de la carpeta CONTA
  ORDSYS = "dir /b "+filpath("ECOMMERCE/ENTRADA","","")+"\*.txt"
  Call SYSTEME2 (adxmac(0),ORDSYS,"",STAT,RESULT) From ORDSYS

  #Extraemos el IDEnlace más alto
  REQUEST="SELECT MAX(ZENLACE_0) FROM ZECCCLI"
  For (Integer NUMMAX) From "5" Sql REQUEST As [AAA]
    ZENLACE=[F:AAA]NUMMAX
  Next

  #Recorremos los ficheros leidos comprobando la raiz del mismo
  For JJ=0 To dim(RESULT)-1
    If RESULT(JJ)<>''
      NOMFIC= filpath("ECOMMERCE/ENTRADA","","") + "\" +RESULT(JJ)

      If mid$(RESULT(JJ),1,1)="W" Then
        #Comprobamos si está creado el pedido
        EXISTEPED=1
        Filter [F:SOH] Where ZFICHORI=RESULT(JJ)
        If rowcount([F:SOH])=0 Then
          EXISTEPED=1
        Else
          EXISTEPED=2
        Endif
        Filter [F:SOH]



        #Comprobamos si ya está importada la factura en X3
        Filter [F:SIH] Where ZFICHORI=RESULT(JJ)
        If rowcount([F:SIH])=0 and EXISTEPED=1 Then
          #Borramos de las tablas los registros correspondientes
          Delete [F:ZECCCLI] Where ZFICHORI=RESULT(JJ)
          Delete [F:ZECCCAB] Where ZFICHORI=RESULT(JJ)
          Delete [F:ZECCLIN] Where ZFICHORI=RESULT(JJ)
          Delete [F:ZECCPAG] Where ZFICHORI=RESULT(JJ)

          WINC=1
          CONTALIN=1
          ZENLACE = ZENLACE+1

          Openi NOMFIC Using [TIE]
          Gosub LEER_REGISTRO
          While !fstat
            If mid$(A(1),1,2)="00" Then #SEGMENTO DE CLIENTES
              #Extraemos el código del cliente de X3 a partir del NIF
              NUMNIF=0
              If WBPR="" Then
                If vireblc(A(23),2)<>"" Then
                  Filter [F:XBPR] Where CRN=vireblc(A(23),2)
                  For [F:XBPR]
                    NUMNIF=NUMNIF+1
                    WBPR=[F:XBPR]BPRNUM
                  Next
                  Filter [F:XBPR]
                Endif
              Endif

              #Si no lo encontramos a partir del NIF, buscamos por el email
              If NUMNIF<>1 Then
                WBPR=""
                If WBPR="" or NUMNIF>1 Then
                  Filter [F:XBPA] Where WEB=vireblc(A(17),2)
                  For [F:XBPA]
                    WBPR=[F:XBPA]BPANUM
                    Break
                  Next
                  Filter [F:XBPA]
                Endif
              Endif

              WBPRPAG=WBPR

              #Guardamos los datos en nuestra tabla temporal
              Raz [F:ZECCCLI]
              [F:ZECCCLI]ZESTADO=0
              [F:ZECCCLI]ZIDCLISA=WBPR
              [F:ZECCCLI]ZCODPAIS=vireblc(A(3),2)
              [F:ZECCCLI]ZFPAGO=vireblc(A(4),2)
              [F:ZECCCLI]ZIDTRANS=val(vireblc(A(5),2))
              [F:ZECCCLI]ZCODDIR=vireblc(A(6),2)
              [F:ZECCCLI]ZEMPFAC=vireblc(A(7),2)
              [F:ZECCCLI]ZNOMFAC=vireblc(A(8),2)
              [F:ZECCCLI]ZAPEFAC=vireblc(A(9),2)
              [F:ZECCCLI]ZTELMOVFAC=vireblc(A(10),2)
              [F:ZECCCLI]ZDIR1FAC=vireblc(A(11),2)
              [F:ZECCCLI]ZDIR2FAC=vireblc(A(12),2)
              [F:ZECCCLI]ZCIUFAC=vireblc(A(13),2)
              [F:ZECCCLI]ZCPFAC=vireblc(A(14),2)
              [F:ZECCCLI]ZPAISFAC=vireblc(A(15),2)
              [F:ZECCCLI]ZPROVFAC=vireblc(A(16),2)
              [F:ZECCCLI]ZEMAIFAC=vireblc(A(17),2)
              [F:ZECCCLI]ZTELFAXFAC=vireblc(A(18),2)
              [F:ZECCCLI]ZTELFIJFAC=vireblc(A(19),2)
              [F:ZECCCLI]ZIDSHOP=val(vireblc(A(20),2))
              [F:ZECCCLI]ZTRANS=vireblc(A(21),2)
              [F:ZECCCLI]ZCLIPAG=vireblc(A(22),2)
              [F:ZECCCLI]ZDNI=vireblc(A(23),2)
              [F:ZECCCLI]ZSOC=vireblc(A(24),2)
              [F:ZECCCLI]ZPLANTA=vireblc(A(25),2)
              [F:ZECCCLI]ZPLANTAEXP=vireblc(A(26),2)
              [F:ZECCCLI]ZVENDEDOR=vireblc(A(27),2)
              [F:ZECCCLI]ZIDIOMA=vireblc(A(28),2)
              [F:ZECCCLI]ZREGIMP=vireblc(A(29),2)
              [F:ZECCCLI]ZCOMENT=vireblc(A(30),2)
              [F:ZECCCLI]ZFICHERO=""
              [F:ZECCCLI]ZNUMIMP=0
              [F:ZECCCLI]ZENLACE=ZENLACE
              [F:ZECCCLI]ZFICHORI=RESULT(JJ)

              Write [F:ZECCCLI]
              If fstat
                Infbox("ERROR CLIENTES " + num$(fstat))
                End
              Endif
  #2017-12-14
            Elsif mid$(A(1),1,2)="10" #SEGMENTO DE CABECERA DE FACTURA
              FECHADOC=func ZCOMUN.CHAR_TO_DATE(mid$(A(6),9,2)+"/"+mid$(A(6),6,2)+"/"+mid$(A(6),1,4))
              FECHAENT=func ZCOMUN.CHAR_TO_DATE(mid$(A(49),9,2)+"/"+mid$(A(49),6,2)+"/"+mid$(A(49),1,4))
              CONDPAGO=vireblc(A(12),2)

              FPAGO=""
              Filter [F:XTPT] Where PTE=CONDPAGO
              For [XTPT]
                FPAGO=[F:XTPT]PAM
              Next
              Filter [XTPT]

              Raz [F:ZECCCAB]
              [F:ZECCCAB]ZESTADO=0
              [F:ZECCCAB]ZTIPMOV=val(vireblc(A(2),2))
              [F:ZECCCAB]ZSERDOC=vireblc(A(3),2)
              [F:ZECCCAB]ZNUMDOC=vireblc(A(4),2)
              [F:ZECCCAB]ZORIGEN=vireblc(A(5),2)
              [F:ZECCCAB]ZDAT=FECHADOC
              [F:ZECCCAB]ZTIM=vireblc(A(7),2)
              [F:ZECCCAB]ZREF=vireblc(A(8),2)
              [F:ZECCCAB]ZSOC=vireblc(A(9),2)
              [F:ZECCCAB]ZFCYA=vireblc(A(10),2)
              [F:ZECCCAB]ZFCYZ=vireblc(A(11),2)
              [F:ZECCCAB]ZCONDPAGO=vireblc(A(12),2)
              [F:ZECCCAB]ZELEFAC(0)=val(vireblc(A(13),2))
              [F:ZECCCAB]ZELEFAC(1)=val(vireblc(A(14),2))
              [F:ZECCCAB]ZELEFAC(2)=val(vireblc(A(15),2))
              [F:ZECCCAB]ZELEFAC(3)=val(vireblc(A(16),2))
              [F:ZECCCAB]ZELEFAC(4)=val(vireblc(A(17),2))
              [F:ZECCCAB]ZELEFAC(5)=val(vireblc(A(18),2))
              [F:ZECCCAB]ZELEFAC(6)=val(vireblc(A(19),2))
              [F:ZECCCAB]ZELEFAC(7)=val(vireblc(A(20),2))
              [F:ZECCCAB]ZELEFAC(8)=val(vireblc(A(21),2))
              [F:ZECCCAB]ZELEFAC(9)=val(vireblc(A(22),2))
              [F:ZECCCAB]ZELEFAC(10)=val(vireblc(A(23),2))
              [F:ZECCCAB]ZELEFAC(11)=val(vireblc(A(24),2))
              [F:ZECCCAB]ZELEFAC(12)=val(vireblc(A(25),2))
              [F:ZECCCAB]ZELEFAC(13)=val(vireblc(A(26),2))
              [F:ZECCCAB]ZELEFAC(14)=val(vireblc(A(27),2))
              [F:ZECCCAB]ZBPR=WBPRPAG
              [F:ZECCCAB]ZBPRPAG=WBPRPAG
              [F:ZECCCAB]ZDIR=vireblc(A(30),2)
              [F:ZECCCAB]ZNOMENT=vireblc(A(31),2)
              [F:ZECCCAB]ZAPEENT=vireblc(A(32),2)
              [F:ZECCCAB]ZTELMOVENT=""
              [F:ZECCCAB]ZDIR1ENT=vireblc(A(33),2)
              [F:ZECCCAB]ZDIR2ENT=vireblc(A(34),2)
              [F:ZECCCAB]ZCIUENT=vireblc(A(35),2)
              [F:ZECCCAB]ZCPENT=vireblc(A(36),2)
              [F:ZECCCAB]ZPAISENT=vireblc(A(37),2)
              [F:ZECCCAB]ZPROVENT=vireblc(A(38),2)
              [F:ZECCCAB]ZEMAIENT=vireblc(A(39),2)
              [F:ZECCCAB]ZTELFAXENT=vireblc(A(40),2)
              [F:ZECCCAB]ZTELFIJENT=vireblc(A(41),2)
              [F:ZECCCAB]ZPERCON=vireblc(A(42),2)
              [F:ZECCCAB]ZDNI=vireblc(A(43),2)
              [F:ZECCCAB]ZIL(0)=vireblc(A(44),2)
              [F:ZECCCAB]ZIL(1)=vireblc(A(45),2)
              [F:ZECCCAB]ZIL(2)=vireblc(A(46),2)
              [F:ZECCCAB]ZIL(3)=vireblc(A(47),2)
              [F:ZECCCAB]ZMODENV=val(vireblc(A(48),2))
              [F:ZECCCAB]ZFECENT=FECHAENT
              [F:ZECCCAB]ZREP1=vireblc(A(50),2)
              [F:ZECCCAB]ZTRANS=vireblc(A(51),2)
              [F:ZECCCAB]ZMODTRANS=val(vireblc(A(52),2))
              [F:ZECCCAB]ZBULTOS=val(vireblc(A(53),2))
              [F:ZECCCAB]ZPESO=val(vireblc(A(54),2))
              [F:ZECCCAB]ZVOLUMEN=val(vireblc(A(55),2))
              [F:ZECCCAB]ZTOTALBI=val(ctrans(vireblc(A(56),2),",","."))
              [F:ZECCCAB]ZFICHERO=""
              [F:ZECCCAB]ZNUMIMP=0
              [F:ZECCCAB]ZENLACE=ZENLACE
              [F:ZECCCAB]ZFICHORI=RESULT(JJ)
              [F:ZECCCAB]ZREGIMP=vireblc(A(58),2)

              Write [F:ZECCCAB]
              If fstat
                Infbox("ERROR CABECERA " + num$(fstat))
                End
              Endif

              #Guardamos los datos del vencimiento en nuestra tabla temporal
              Raz [F:ZECCPAG]
              [F:ZECCPAG]ZESTADO=0
              [F:ZECCPAG]ZTIPMOV=val(vireblc(A(2),2))
              [F:ZECCPAG]ZSERDOC=vireblc(A(3),2)
              [F:ZECCPAG]ZNUMDOC=vireblc(A(4),2)
              [F:ZECCPAG]ZORIGEN=vireblc(A(5),2)
              [F:ZECCPAG]ZDAT=FECHADOC
              [F:ZECCPAG]ZTIM=vireblc(A(7),2)
              [F:ZECCPAG]ZNUMLIN=1
              #If vireblc(A(9),2)<>"" Then
              #  [F:ZECCPAG]ZDATVTO=FECHAVENC
              #Else
              [F:ZECCPAG]ZDATVTO=FECHADOC
              #Endif
              [F:ZECCPAG]ZREF=vireblc(A(8),2)
              [F:ZECCPAG]ZSOC=vireblc(A(9),2)
              [F:ZECCPAG]ZFCYA=vireblc(A(10),2)
              [F:ZECCPAG]ZIMPORTE=val(ctrans(vireblc(A(56),2),",","."))
              [F:ZECCPAG]ZFACPAG=FPAGO
              [F:ZECCPAG]ZTIPPAG=0
              [F:ZECCPAG]ZSTAPAG=""
              [F:ZECCPAG]ZCOM=""
              [F:ZECCPAG]ZDIV=""
              [F:ZECCPAG]ZBPR=WBPR
              [F:ZECCPAG]ZBPRPAG=WBPRPAG
              [F:ZECCPAG]ZTIPORI=""
              [F:ZECCPAG]ZTIPDOC=""
              [F:ZECCPAG]ZFICHERO=""
              [F:ZECCPAG]ZNUMIMP=0
              [F:ZECCPAG]ZENLACE=ZENLACE
              [F:ZECCPAG]ZFICHORI=RESULT(JJ)


              Write [F:ZECCPAG]
              If fstat
                Infbox("ERROR PAGOS " + num$(fstat))
                End
              Endif
            Elsif mid$(A(1),1,2)="20" Then #SEGMENTO DE LINEAS DE FACTURA
              #Guardamos los datos en nuestra tabla temporal
              #FECHADOC=func ZCOMUN.CHAR_TO_DATE(mid$(A(6),9,2)+"/"+mid$(A(6),6,2)+"/"+mid$(A(6),1,4))
              FECHAVENC=func ZCOMUN.CHAR_TO_DATE(mid$(A(9),9,2)+"/"+mid$(A(9),6,2)+"/"+mid$(A(9),1,4))

              Raz [F:ZECCLIN]
              [F:ZECCLIN]ZESTADO=0
              [F:ZECCLIN]ZTIPMOV=val(vireblc(A(2),2))
              [F:ZECCLIN]ZSERDOC=vireblc(A(3),2)
              [F:ZECCLIN]ZNUMDOC=vireblc(A(4),2)
              [F:ZECCLIN]ZORIGEN=vireblc(A(5),2)
              [F:ZECCLIN]ZDAT=FECHADOC
              [F:ZECCLIN]ZTIM=vireblc(A(7),2)
              [F:ZECCLIN]ZREF=vireblc(A(8),2)
              [F:ZECCLIN]ZSOC=vireblc(A(9),2)
              [F:ZECCLIN]ZFCYA=vireblc(A(10),2)
              [F:ZECCLIN]ZFCYZ=vireblc(A(11),2)
              [F:ZECCLIN]ZNLINX3=CONTALIN
              [F:ZECCLIN]ZNLINECC=val(vireblc(A(13),2))
              [F:ZECCLIN]ZDIV=vireblc(A(14),2)
              [F:ZECCLIN]ZGROPRI=val(ctrans(vireblc(A(15),2),",","."))
              [F:ZECCLIN]ZIMPINC=val(vireblc(A(16),2))
              [F:ZECCLIN]ZDTO1=val(vireblc(A(17),2))
              [F:ZECCLIN]ZDTO2=val(vireblc(A(18),2))
              [F:ZECCLIN]ZDTO3=val(vireblc(A(19),2))
              [F:ZECCLIN]ZDTOPIE=val(vireblc(A(20),2))
              [F:ZECCLIN]ZDTOPP=val(vireblc(A(21),2))
              [F:ZECCLIN]ZIMPTO1=val(ctrans(vireblc(A(22),2),",","."))
              [F:ZECCLIN]ZIMPTO2=val(ctrans(vireblc(A(23),2),",","."))
              [F:ZECCLIN]ZIMPTO3=val(vireblc(A(24),2))
              [F:ZECCLIN]ZQTY=val(vireblc(A(25),2))
              [F:ZECCLIN]ZSTAA=vireblc(A(26),2)
              [F:ZECCLIN]ZUBIA=vireblc(A(27),2)
              [F:ZECCLIN]ZLOTA=vireblc(A(28),2)
              [F:ZECCLIN]ZSER=vireblc(A(29),2)
              [F:ZECCLIN]ZITMREF=vireblc(A(30),2)
              [F:ZECCLIN]ZITMDES=vireblc(A(31),2)
              [F:ZECCLIN]ZNUMIMP=0
              [F:ZECCLIN]ZFICHERO=""
              [F:ZECCLIN]ZVERSION=vireblc(A(34),2)
              [F:ZECCLIN]ZLICENCIA=vireblc(A(35),2)
              [F:ZECCLIN]ZENLACE=ZENLACE
              [F:ZECCLIN]ZFICHORI=RESULT(JJ)

              Write [F:ZECCLIN]
              If fstat
                Infbox("ERROR LINEAS " + num$(fstat))
                End
              Endif

              CONTALIN=CONTALIN+1


            Endif
            Gosub LEER_REGISTRO
          Wend
          Openi Using [TIE]

          #Movemos el fichero a la carpeta de tratados
          Call MOVE(NOMFIC,filpath("ECOMMERCE\ENTRADA\TRATADOS","","") + "\" + RESULT(JJ),STAT)    From ORDSYS
        Endif
        Filter [F:SIH]
      Elsif mid$(RESULT(JJ),1,5)="Match" Then
        #Borramos la tabla de match
        Filter [F:ZECCMAT]
        For [F:ZECCMAT]
          Delete [F:ZECCMAT]
        Next
        Filter [F:ZECCMAT]

        Openi NOMFIC Using [TIE]
        Gosub LEER_REGISTRO
        While !fstat
          Raz [F:ZECCMAT]
          FECHAMATCH=func ZCOMUN.CHAR_TO_DATE(mid$(A(1),9,2)+"/"+mid$(A(1),6,2)+"/"+mid$(A(1),1,4))

          [F:ZECCMAT]ZDAT=FECHAMATCH
          [F:ZECCMAT]ZTIM=vireblc(A(2),2)
          [F:ZECCMAT]ZTIPDOC=vireblc(A(3),2)
          [F:ZECCMAT]ZNUMDOC=vireblc(A(4),2)
          [F:ZECCMAT]ZTOTALBI=val(ctrans(vireblc(A(5),2),",","."))
          [F:ZECCMAT]ZIMPIVA=val(ctrans(vireblc(A(6),2),",","."))
          [F:ZECCMAT]ZTOTCONIMP=val(ctrans(vireblc(A(7),2),",","."))
          [F:ZECCMAT]ZTOTALDTO=val(ctrans(vireblc(A(8),2),",","."))
          [F:ZECCMAT]ZCODCLI=vireblc(A(9),2)
          [F:ZECCMAT]ZEMPENT=vireblc(A(10),2)
          [F:ZECCMAT]ZNOMENT=vireblc(A(11),2)
          [F:ZECCMAT]ZEMAIENT=vireblc(A(12),2)
          [F:ZECCMAT]ZDNI=vireblc(A(13),2)
          [F:ZECCMAT]ZINTRA=val(vireblc(A(14),2))
          [F:ZECCMAT]ZCP=vireblc(A(15),2)
          [F:ZECCMAT]ZPAIS=vireblc(A(16),2)
          [F:ZECCMAT]ZDNIORI=vireblc(A(17),2)
          [F:ZECCMAT]ZTIPO=val(vireblc(A(18),2))
          [F:ZECCMAT]ZREGIMP=vireblc(A(19),2)
          [F:ZECCMAT]ZREGIMPX3=vireblc(A(20),2)
          [F:ZECCMAT]ZPEDECC=vireblc(A(21),2)
          [F:ZECCMAT]ZTOTALUNI=val(ctrans(vireblc(A(22),2),",","."))
          [F:ZECCMAT]ZOBSERV=vireblc(A(23),2)
          [F:ZECCMAT]ZFPAGO=vireblc(A(24),2)
          [F:ZECCMAT]ZIMPCOB=val(ctrans(vireblc(A(25),2),",","."))

          Write [F:ZECCMAT]
          If fstat
            Infbox("ERROR MATCH " + num$(fstat))
            End
          Endif
          Gosub LEER_REGISTRO
        Wend
        Openi Using [TIE]

        #Movemos el fichero a la carpeta de tratados
        Call MOVE(NOMFIC,filpath("ECOMMERCE\ENTRADA\TRATADOS","","") + "\" + RESULT(JJ),STAT)    From ORDSYS

      Elsif mid$(RESULT(JJ),1,4)="ZBPC" Then
        #Borramos la tabla de match
        Filter [F:ZECCLAC]
        For [F:ZECCLAC]
          Delete [F:ZECCLAC]
        Next
        Filter [F:ZECCLAC]

        Openi NOMFIC Using [TIE]
        Gosub LEER_REGISTRO
        While !fstat
          Raz [F:ZECCLAC]

          [F:ZECCLAC]ZESTADO=0
          [F:ZECCLAC]ZIDCLISA=vireblc(A(2),2)
          [F:ZECCLAC]ZNOMEMP=vireblc(A(3),2)
          [F:ZECCLAC]ZCODPAIS=vireblc(A(4),2)
          [F:ZECCLAC]ZDNI=vireblc(A(5),2)
          [F:ZECCLAC]ZDIVISA=vireblc(A(6),2)
          [F:ZECCLAC]ZCONDPAGO=vireblc(A(7),2)
          [F:ZECCLAC]ZIDTRANS=val(vireblc(A(8),2))
          [F:ZECCLAC]ZTRANS=vireblc(A(9),2)
          [F:ZECCLAC]ZCLIPAG=vireblc(A(10),2)
          [F:ZECCLAC]ZVENDEDOR=vireblc(A(11),2)
          [F:ZECCLAC]ZREGIMP=vireblc(A(12),2)
          [F:ZECCLAC]ZDIRFAC=vireblc(A(13),2)
          [F:ZECCLAC]ZEMPFAC=vireblc(A(14),2)
          [F:ZECCLAC]ZNOMFAC=vireblc(A(15),2)
          [F:ZECCLAC]ZAPEFAC=vireblc(A(16),2)
          [F:ZECCLAC]ZTELMOVFAC=vireblc(A(17),2)
          [F:ZECCLAC]ZDIR1FAC=vireblc(A(18),2)
          [F:ZECCLAC]ZDIR2FAC=vireblc(A(19),2)
          [F:ZECCLAC]ZCIUFAC=vireblc(A(20),2)
          [F:ZECCLAC]ZCPFAC=vireblc(A(21),2)
          [F:ZECCLAC]ZCODPAISFAC=vireblc(A(22),2)
          [F:ZECCLAC]ZPROVFAC=vireblc(A(23),2)
          [F:ZECCLAC]ZEMAIFAC=vireblc(A(24),2)
          [F:ZECCLAC]ZTELFAXFAC=vireblc(A(25),2)
          [F:ZECCLAC]ZTELFIJFAC=vireblc(A(26),2)
          [F:ZECCLAC]ZDIRENT=vireblc(A(27),2)
          [F:ZECCLAC]ZNOMENT=vireblc(A(28),2)
          [F:ZECCLAC]ZAPEENT=vireblc(A(29),2)
          [F:ZECCLAC]ZTELMOVENT=vireblc(A(30),2)
          [F:ZECCLAC]ZDIR1ENT=vireblc(A(31),2)
          [F:ZECCLAC]ZDIR2ENT=vireblc(A(32),2)
          [F:ZECCLAC]ZCIUENT=vireblc(A(33),2)
          [F:ZECCLAC]ZCPENT=vireblc(A(34),2)
          [F:ZECCLAC]ZPAISENT=vireblc(A(35),2)
          [F:ZECCLAC]ZPROVENT=vireblc(A(36),2)
          [F:ZECCLAC]ZEMAIENT=vireblc(A(37),2)
          [F:ZECCLAC]ZTELFAXENT=vireblc(A(38),2)
          [F:ZECCLAC]ZTELFIJENT=vireblc(A(39),2)
          [F:ZECCLAC]ZFICHERO=vireblc(A(40),2)
          [F:ZECCLAC]ZIDIOMATER=vireblc(A(41),2)
          [F:ZECCLAC]ZCLIECC=vireblc(A(42),2)

          Write [F:ZECCLAC]
          If fstat
            Infbox("ERROR MATCH " + num$(fstat))
            End
          Endif
          Gosub LEER_REGISTRO
        Wend
        Openi Using [TIE]

        #Movemos el fichero a la carpeta de tratados
        Call MOVE(NOMFIC,filpath("ECOMMERCE\ENTRADA\TRATADOS","","") + "\" + RESULT(JJ),STAT)    From ORDSYS
      Endif
    Endif
  Next

Return

$CREAR_FACTURAS_VENTA
  Local Char WOUT(250)
  Local Char ZBPR(30)
  Local Char ZBPRPAG(30)
  Local Char ZCUR(10)
  Local Char ZREGIMP(10)
  Local Char VACITM0(GLONTVI)
  Local Char VACITM1(GLONTVI)
  Local Char VACITM2(GLONTVI)
  Local Char VAT0(GLONVAT)
  Local Char VAT1(GLONVAT)
  Local Char VAT2(GLONVAT)
  Local Char FECHADOC(25)
  Local Char ZVAC(10)
  Local Decimal ZIMPDTO


  Filter [F:ZECCCAB] Where 1=1 and (ZTIPMOV=2) and ZESTADO=0
  For [F:ZECCCAB]
    ZBPR=""
    ZBPRPAG=""
    Filter [F:ZECCCLI] Where 1=1 and ZFICHORI=[F:ZECCCAB]ZFICHORI
    For [F:ZECCCLI]
      ZBPR=[F:ZECCCLI]ZIDCLISA
      ZBPRPAG=ZBPR
    Next
    Filter [F:ZECCCLI]

    WOUT = filpath("ECOMMERCE/ENTRADA","ZSIHECC_"+[F:ZECCCAB]ZSERDOC+"_"+[F:ZECCCAB]ZNUMDOC+"_"+format$("D:YYYYMMDD",date$),"")

    Openo WOUT,0 Using [TIF]
    Iomode adxium 0 Using [TIF]

    Call XML_INICIO("UTF") From ZXML
    Call XML_INICIO_NOMBRE("ZSIHECC") From ZXML

    Call XML_ABRE_ETIQUETA("V") From ZXML
    #Call XML_LINEA("SIV_NUM",[F:ZICGM]ZNUM) From ZXML
    Call XML_LINEA("SIV_CPY",[F:ZECCCAB]ZSOC) From ZXML
    Call XML_LINEA("SIV_SALFCY",[F:ZECCCAB]ZFCYA) From ZXML
    Call XML_LINEA("SIV_INVTYP","01:SPA:FACTURA") From ZXML
    Call XML_LINEA("SIV_BPCINV",ZBPR) From ZXML
    Call XML_LINEA("SIV_BPRPAY",ZBPRPAG) From ZXML

    #Extraemos la divisa del cliente
    ZVAC=""
    ZCUR=""
    Read [XBPC]BPC0=[F:ZECCCAB]ZBPRPAG
    If fstat=0 Then
       ZCUR = [XBPC]CUR
       ZVAC = [XBPC]VACBPR
    Endif

    If ZCUR="" Then
      ZCUR="EUR"
    Endif

    Call XML_LINEA("SIV_CUR",ZCUR) From ZXML
    Call XML_LINEA("SIH_ACCDAT",mid$(num$([F:ZECCCAB]ZDAT),7,4)+"-"+mid$(num$([F:ZECCCAB]ZDAT),4,2)+"-"+mid$(num$([F:ZECCCAB]ZDAT),1,2)) From ZXML
    #Call XML_LINEA("SIH_ACCDAT",num$([F:ZECCCAB]ZDAT)) From ZXML
    Call XML_LINEA("SIH_BPAINV",[F:ZECCCAB]ZDIR) From ZXML
    Call XML_LINEA("SIH_SIVTYP",[F:ZECCCAB]ZSERDOC) From ZXML
    Call XML_LINEA("SIV_STOMVTFLG","true") From ZXML
    Call XML_LINEA("SIV_STOFCY",[F:ZECCCAB]ZFCYA) From ZXML
    #Call XML_LINEA("SIV_PRITYP","01:SPA:AI") From ZXML
    Call XML_LINEA("SIV_PRITYP","02:SPA:II") From ZXML
    Call XML_LINEA("SIH_STA","03:SPA:Validada") From ZXML
    Call XML_LINEA("SIH_PTE",[F:ZECCCAB]ZCONDPAGO) From ZXML
    Call XML_LINEA("SIH_BPAPAY",[F:ZECCCAB]ZDIR) From ZXML
    Call XML_LINEA("SIV_BPAADD",[F:ZECCCAB]ZDIR) From ZXML

#    #Extraemos el descuento del fichero del match para aplicarlo en el elemento de facturacion
#    ZIMPDTO=0
#    Filter [F:ZECCMAT] Where 1=1 and ZNUMDOC=[F:ZECCCAB]ZNUMDOC
#    For [F:ZECCMAT]
#      ZIMPDTO=[F:ZECCMAT]ZTOTALDTO*-1
#    Next
#    Filter [F:ZECCMAT]


    #Call XML_LINEA("SIH_BPAADDLIG_0","UN") From ZXML
    #Call XML_LINEA("SIH_BPAADDLIG_1","UN") From ZXML
    #Call XML_LINEA("SIH_BPAADDLIG_2","UN") From ZXML
    #Call XML_LINEA("SIH_POSCOD","UN") From ZXML
    #Call XML_LINEA("SIH_CTY","UN") From ZXML
    #Call XML_LINEA("SIH_SAT","UN") From ZXML
    #Call XML_LINEA("SIH_CRY","UN") From ZXML
    Call XML_LINEA("SIV_INVDTAAMT_0",num$([F:ZECCCAB]ZELEFAC(0))) From ZXML
    Call XML_LINEA("SIV_INVDTAAMT_1",num$([F:ZECCCAB]ZELEFAC(1))) From ZXML
    Call XML_LINEA("SIV_INVDTAAMT_2",num$([F:ZECCCAB]ZELEFAC(2))) From ZXML
    Call XML_LINEA("SIV_INVDTAAMT_3",num$([F:ZECCCAB]ZELEFAC(3))) From ZXML
    Call XML_LINEA("SIV_INVDTAAMT_4",num$([F:ZECCCAB]ZELEFAC(4))) From ZXML
    Call XML_LINEA("SIV_INVDTAAMT_5",num$([F:ZECCCAB]ZELEFAC(5))) From ZXML
    Call XML_LINEA("SIV_INVDTAAMT_6",num$([F:ZECCCAB]ZELEFAC(6))) From ZXML
    Call XML_LINEA("SIV_INVDTAAMT_7",num$([F:ZECCCAB]ZELEFAC(7))) From ZXML
    Call XML_LINEA("SIV_INVDTAAMT_8",num$([F:ZECCCAB]ZELEFAC(8))) From ZXML
    Call XML_LINEA("SIV_INVDTAAMT_9",num$([F:ZECCCAB]ZELEFAC(9))) From ZXML
    Call XML_LINEA("SIV_INVDTAAMT_10",num$([F:ZECCCAB]ZELEFAC(10))) From ZXML
    Call XML_LINEA("SIV_INVDTAAMT_11",num$([F:ZECCCAB]ZELEFAC(11))) From ZXML
    Call XML_LINEA("SIV_INVDTAAMT_12",num$([F:ZECCCAB]ZELEFAC(12))) From ZXML
    Call XML_LINEA("SIV_INVDTAAMT_13",num$([F:ZECCCAB]ZELEFAC(13))) From ZXML
    Call XML_LINEA("SIV_INVDTAAMT_14",num$([F:ZECCCAB]ZELEFAC(14))) From ZXML


    Call XML_LINEA("SIH_ZNUMDOC",[F:ZECCCAB]ZNUMDOC) From ZXML
    Call XML_LINEA("SIH_ZSERDOC",[F:ZECCCAB]ZSERDOC) From ZXML
    Call XML_LINEA("SIH_ZDAT",mid$(num$([F:ZECCCAB]ZDAT),7,4)+"-"+mid$(num$([F:ZECCCAB]ZDAT),4,2)+"-"+mid$(num$([F:ZECCCAB]ZDAT),1,2)) From ZXML
    Call XML_LINEA("SIH_ZNUMPEDEECC",[F:ZECCCAB]ZORIGEN) From ZXML
    Call XML_LINEA("SIV_INVREF",[F:ZECCCAB]ZREF) From ZXML
    #Call XML_LINEA("SIV_INVSTA","03:SPA:Validada") From ZXML
    Call XML_LINEA("SIH_VAC",[F:ZECCCAB]ZREGIMP) From ZXML


    #Call XML_LINEA("SIH_DIE_0","UN") From ZXML
    #Call XML_LINEA("SIH_DIE_1","UN") From ZXML
    #Call XML_LINEA("SIH_DIE_2","UN") From ZXML
    #Call XML_LINEA("SIH_CCE_0","UN") From ZXML
    #Call XML_LINEA("SIH_CCE_1","UN") From ZXML
    #Call XML_LINEA("SIH_CCE_2","UN") From ZXML
    #Call XML_LINEA("SIV_V__33","UN") From ZXML
    #Call XML_LINEA("SIV_V__34","UN") From ZXML
    #Call XML_LINEA("SIV_V__35","UN") From ZXML
    #Call XML_LINEA("SIV_V__36","UN") From ZXML

    #Extraemos el régimen de impuesto del cliente asignado a la factura de venta
    ZREGIMP=""
    Filter [F:ZECCCLI] Where ZENLACE=[F:ZECCCAB]ZENLACE
    For [F:ZECCCLI]
      ZREGIMP=[F:ZECCCLI]ZREGIMP
    Next
    Filter [F:ZECCCLI]

    VAT0=""
    Filter [F:XTVB] Where VACBPR=ZREGIMP
    For [F:XTVB]
      VAT0=[F:XTVB]VAT
    Next
    Filter [F:XTVB]

    VACITM0=""
    Filter [F:XTVC] Where VAT=VAT0 and VACBPR=ZREGIMP
    For [F:XTVC]
      VACITM0=[F:XTVC]VACITM
    Next
    Filter [F:XTVC]

    #Abrimos las líneas
    Filter [F:ZECCLIN] Where 1=1 and ZSERDOC=[F:ZECCCAB]ZSERDOC and ZNUMDOC=[F:ZECCCAB]ZNUMDOC
    For [F:ZECCLIN]
      Call XML_ABRE_ETIQUETA("L") From ZXML
      Call XML_LINEA("SID_ITMREF",[F:ZECCLIN]ZITMREF) From ZXML
      Call XML_LINEA("SID_ITMDES",[F:ZECCLIN]ZITMDES) From ZXML
      Call XML_LINEA("SID_SIDLIN",num$([F:ZECCLIN]ZNLINX3)) From ZXML
      Call XML_LINEA("SID_SAU","UN") From ZXML
      Call XML_LINEA("SID_QTY",num$([F:ZECCLIN]ZQTY)) From ZXML
      #If [F:ZECCLIN]ZGROPRI=0 Then
        Call XML_LINEA("SID_GROPRI",num$([F:ZECCLIN]ZGROPRI)) From ZXML
      #Else
      #  Call XML_LINEA("SID_GROPRI",num$([F:ZECCLIN]ZGROPRI-[F:ZECCLIN]ZIMPTO1)) From ZXML
      #Endif
      Call XML_LINEA("SID_DISCRGVAL1",num$([F:ZECCLIN]ZDTO1)) From ZXML
      Call XML_LINEA("SID_DISCRGVAL2",num$([F:ZECCLIN]ZDTO2)) From ZXML
      Call XML_LINEA("SID_DISCRGVAL3",num$([F:ZECCLIN]ZDTO3)) From ZXML
#      Call XML_LINEA("SID_VACITM_0",VACITM0) From ZXML
#      Call XML_LINEA("SID_VACITM_1",VACITM1) From ZXML
#      Call XML_LINEA("SID_VACITM_2",VACITM2) From ZXML
#      Call XML_LINEA("SID_VAT_0",num$(VAT0)) From ZXML
#      Call XML_LINEA("SID_VAT_1",num$(VAT1)) From ZXML
#      Call XML_LINEA("SID_VAT_2",num$(VAT2)) From ZXML
      Call XML_LINEA("SID_ZSERDOC",[F:ZECCLIN]ZSERDOC) From ZXML
      Call XML_LINEA("SID_ZNUMDOC",[F:ZECCLIN]ZNUMDOC) From ZXML

      #Call XML_LINEA("SID_ZDAT",mid$(num$([F:ZECCLIN]ZDAT),7,4)+"-"+mid$(num$([F:ZICGM]ZDAT),4,2)+"-"+mid$(num$([F:ZICGM]ZDAT),1,2)) From ZXML
      Call XML_LINEA("SID_ZDAT",date$) From ZXML

      Call XML_LINEA("SID_ZNUMLIN",num$([F:ZECCLIN]ZNLINECC)) From ZXML

      Call XML_ABRE_ETIQUETA("S") From ZXML
      Call XML_LINEA("STJ_STA",[F:ZECCLIN]ZSTAA) From ZXML
      Call XML_LINEA("STJ_LOC",[F:ZECCLIN]ZUBIA) From ZXML
      Call XML_LINEA("STJ_PCU","UN") From ZXML
      Call XML_LINEA("STJ_QTYPCU",num$([F:ZECCLIN]ZQTY*-1)) From ZXML

      Call XML_CIERRA_ETIQUETA("S") From ZXML
      Call XML_CIERRA_ETIQUETA("L") From ZXML

      [F:ZECCLIN]ZFICHERO="ZSIHECC_"+[F:ZECCCAB]ZSERDOC+"_"+[F:ZECCCAB]ZNUMDOC+"_"+format$("D:YYYYMMDD",date$)
      [F:ZECCLIN]ZESTADO=2
      Rewrite [F:ZECCLIN]
    Next
    Filter [F:ZECCLIN]

    Call XML_CIERRA_ETIQUETA("V") From ZXML
    Call XML_FIN("ZSIHECC") From ZXML
    Openo Using [TIF]

    [F:ZECCCAB]ZFICHERO="ZSIHECC_"+[F:ZECCCAB]ZSERDOC+"_"+[F:ZECCCAB]ZNUMDOC+"_"+format$("D:YYYYMMDD",date$)
    [F:ZECCCAB]ZESTADO=2
    [F:ZECCCAB]ZBPR=ZBPR
    [F:ZECCCAB]ZBPRPAG=ZBPRPAG
    Rewrite [F:ZECCCAB]
  Next
  Filter [F:ZECCCAB]

Return

$CREAR_CLIENTES
  Local Char WOUT(250)
  Local Char ZBPR(30)
  Local Char ZBPRPAG(30)
  Local Char ZCUR(10)
  Local Char ZREGIMP(10)
  Local Char VACITM0(GLONTVI)
  Local Char VACITM1(GLONTVI)
  Local Char VACITM2(GLONTVI)
  Local Char VAT0(GLONVAT)
  Local Char VAT1(GLONVAT)
  Local Char VAT2(GLONVAT)
  Local Integer ZCONTROL

  Filter [F:ZECCCLI] Where 1=1 and ZESTADO=0
  For [F:ZECCCLI]
    WOUT = filpath("ECOMMERCE/ENTRADA","ZBPCECC_"+[F:ZECCCLI]ZCLIPAG+format$("D:YYYYMMDD",date$),"")

    Openo WOUT,0 Using [TIF]
    Iomode adxium 0 Using [TIF]

    Call XML_INICIO("UTF") From ZXML
    Call XML_INICIO_NOMBRE("ZBPCECC") From ZXML

    Call XML_ABRE_ETIQUETA("B") From ZXML
    Call XML_LINEA("BPC_BCGCOD","CD") From ZXML
    Call XML_LINEA("BPC_BPCNUM",[F:ZECCCLI]ZIDCLISA) From ZXML
    Call XML_LINEA("BPR_BPRNAM",[F:ZECCCLI]ZNOMFAC) From ZXML
    Call XML_LINEA("BPR_BPRSHO",[F:ZECCCLI]ZNOMFAC) From ZXML
    Call XML_LINEA("BPC_BPAINV",[F:ZECCCLI]ZCODDIR) From ZXML
    Call XML_LINEA("BPC_BPAPYR",[F:ZECCCLI]ZCODDIR) From ZXML
    Call XML_LINEA("BPC_BPAADD",[F:ZECCCLI]ZCODDIR) From ZXML
    Call XML_LINEA("BPC_BPDADD",[F:ZECCCLI]ZCODDIR) From ZXML
    Call XML_LINEA("BPC_CUR","EUR") From ZXML
    Call XML_LINEA("BPR_CRN",[F:ZECCCLI]ZDNI) From ZXML
    Call XML_LINEA("BPC_BPCINV",[F:ZECCCLI]ZIDCLISA) From ZXML
    Call XML_LINEA("BPC_VACBPR",[F:ZECCCLI]ZREGIMP) From ZXML
    Call XML_LINEA("BPC_PTE","ANTICIPADO") From ZXML
    Call XML_LINEA("BPC_ACCCOD","LOCAL") From ZXML
    #Call XML_LINEA("BPC_TSCCOD_0",[F:ZICGM]ZFCYA) From ZXML
    Call XML_LINEA("BPC_OSTAUZ","1") From ZXML
    Call XML_LINEA("BPC_COMCAT","01:SPA:Categoría 1") From ZXML
    Call XML_LINEA("BPC_REP_0",[F:ZECCCLI]ZVENDEDOR) From ZXML
    Call XML_LINEA("BPC_B__28",[F:ZECCCLI]ZCODPAIS) From ZXML
    #Call XML_LINEA("BPC_B__26",[F:ZICGM]ZFCYA) From ZXML
    Call XML_LINEA("BPC_BPCPYR",[F:ZECCCLI]ZIDCLISA) From ZXML
    Call XML_LINEA("BPC_BPCRSK",[F:ZECCCLI]ZIDCLISA) From ZXML
    Call XML_LINEA("BPC_DME","01:SPA:Autorizada") From ZXML
    If [F:ZECCCLI]ZIDCLISA="" Then
      Call XML_LINEA("BPC_OSTCTL","02:SPA:Libre") From ZXML
    Else
      #Extraemos el tipo de control de riesgo del cliente de X3
      Read [F:XBPC]BPC0=[F:ZECCCLI]ZIDCLISA
      If fstat=0 Then
        ZCONTROL=[F:XBPC]OSTCTL
        If ZCONTROL=1 Then
          Call XML_LINEA("BPC_OSTCTL","01:SPA:Controlado") From ZXML
        Elsif ZCONTROL=2 Then
          Call XML_LINEA("BPC_OSTCTL","02:SPA:Libre") From ZXML
        Elsif ZCONTROL=3 Then
          Call XML_LINEA("BPC_OSTCTL","03:SPA:Bloqueado") From ZXML
        Endif

      Endif
    Endif


    Call XML_ABRE_ETIQUETA("A") From ZXML
    Call XML_LINEA("BPA_BPAADD",[F:ZECCCLI]ZCODDIR) From ZXML
    Call XML_LINEA("BPA_BPADES",[F:ZECCCLI]ZNOMFAC) From ZXML
    Call XML_LINEA("BPA_BPAADDLIG",[F:ZECCCLI]ZDIR1FAC) From ZXML
    Call XML_LINEA("BPA_BPAADDLIG_1",[F:ZECCCLI]ZDIR2FAC) From ZXML
    Call XML_LINEA("BPA_WEB",[F:ZECCCLI]ZEMAIFAC) From ZXML
    Call XML_LINEA("BPA_POSCOD",[F:ZECCCLI]ZCPFAC) From ZXML
    Call XML_LINEA("BPA_CTY",[F:ZECCCLI]ZCIUFAC) From ZXML
    Call XML_LINEA("BPA_CRY",[F:ZECCCLI]ZPAISFAC) From ZXML
    Call XML_LINEA("BPA_TEL",[F:ZECCCLI]ZTELFIJFAC) From ZXML
    Call XML_LINEA("BPA_MOB",[F:ZECCCLI]ZTELMOVFAC) From ZXML
    Call XML_LINEA("BPA_FAX",[F:ZECCCLI]ZTELFAXFAC) From ZXML
    Call XML_CIERRA_ETIQUETA("A") From ZXML

    Filter [F:ZECCCAB] Where 1=1 and ZENLACE=[F:ZECCCLI]ZENLACE
    For [F:ZECCCAB]
      Call XML_ABRE_ETIQUETA("A") From ZXML
      Call XML_LINEA("BPA_BPAADD",[F:ZECCCAB]ZDIR) From ZXML
      Call XML_LINEA("BPA_BPADES",[F:ZECCCAB]ZNOMENT) From ZXML
      Call XML_LINEA("BPA_BPAADDLIG",[F:ZECCCAB]ZDIR1ENT) From ZXML
      Call XML_LINEA("BPA_BPAADDLIG_1",[F:ZECCCAB]ZDIR2ENT) From ZXML
      Call XML_LINEA("BPA_WEB",[F:ZECCCAB]ZEMAIENT) From ZXML
      Call XML_LINEA("BPA_POSCOD",[F:ZECCCAB]ZCPENT) From ZXML
      Call XML_LINEA("BPA_CTY",[F:ZECCCAB]ZCIUENT) From ZXML
      Call XML_LINEA("BPA_CRY",[F:ZECCCAB]ZPAISENT) From ZXML
      Call XML_LINEA("BPA_TEL",[F:ZECCCAB]ZTELFIJENT) From ZXML
      Call XML_LINEA("BPA_MOB",[F:ZECCCAB]ZTELMOVENT) From ZXML
      Call XML_LINEA("BPA_FAX",[F:ZECCCAB]ZTELFAXENT) From ZXML
      Call XML_CIERRA_ETIQUETA("A") From ZXML
    Next
    Filter [F:ZECCCAB]

    Call XML_ABRE_ETIQUETA("D") From ZXML
    Call XML_LINEA("BPD_BPAADD",[F:ZECCCLI]ZCODDIR) From ZXML
    Call XML_LINEA("BPD_BPDNAM_0",[F:ZECCCLI]ZNOMFAC) From ZXML
    Call XML_LINEA("BPD_REP_0",[F:ZECCCLI]ZVENDEDOR) From ZXML
    #Call XML_LINEA("BPD_MDL",[F:ZECCCLI]ZFCYA) From ZXML
    Call XML_LINEA("BPD_BPTNUM",[F:ZECCCLI]ZTRANS) From ZXML
    #Call XML_LINEA("BPD_EECLOC",[F:ZECCCLI]ZFCYA) From ZXML
    Call XML_CIERRA_ETIQUETA("D") From ZXML

    Filter [F:ZECCCAB] Where 1=1 and ZENLACE=[F:ZECCCLI]ZENLACE
    For [F:ZECCCAB]
      Call XML_ABRE_ETIQUETA("D") From ZXML
      Call XML_LINEA("BPD_BPAADD",[F:ZECCCAB]ZDIR) From ZXML
      Call XML_LINEA("BPD_BPDNAM_0",[F:ZECCCAB]ZNOMENT) From ZXML
      Call XML_LINEA("BPD_REP_0",[F:ZECCCAB]ZREP1) From ZXML
      #Call XML_LINEA("BPD_MDL",[F:ZECCCLI]ZFCYA) From ZXML
      Call XML_LINEA("BPD_BPTNUM",[F:ZECCCAB]ZTRANS) From ZXML
      #Call XML_LINEA("BPD_EECLOC",[F:ZECCCLI]ZFCYA) From ZXML
      Call XML_CIERRA_ETIQUETA("D") From ZXML
    Next
    Filter [F:ZECCCAB]

    Call XML_CIERRA_ETIQUETA("B") From ZXML
    Call XML_FIN("ZBPCECC") From ZXML

    Openo Using [TIF]

    [F:ZECCCLI]ZFICHERO="ZBPCECC_"+[F:ZECCCLI]ZCLIPAG+format$("D:YYYYMMDD",date$)
    [F:ZECCCLI]ZESTADO=2
    Rewrite [F:ZECCCLI]
  Next
  Filter [F:ZECCCLI]

Return

$CREAR_CLIENTES_ACTU
  Local Char WOUT(250)
  Local Char ZBPR(30)
  Local Char ZBPRPAG(30)
  Local Char ZCUR(10)
  Local Char ZREGIMP(10)
  Local Char VACITM0(GLONTVI)
  Local Char VACITM1(GLONTVI)
  Local Char VACITM2(GLONTVI)
  Local Char VAT0(GLONVAT)
  Local Char VAT1(GLONVAT)
  Local Char VAT2(GLONVAT)
  Local Integer ZCONTROL
  Local Char WBPC(GLONBPC)
  Local Char WPAG(GLONBPC)

  Filter [F:ZECCLAC] Where 1=1 and ZESTADO=0
  For [F:ZECCLAC]
    WBPC=""
    If [F:ZECCLAC]ZCLIECC<>"" Then
      Filter [F:BPC] Where ZCLIECC=[F:ZECCLAC]ZCLIECC
      For [F:BPC]
        WBPC=[F:BPC]BPCNUM
      Next
      Filter [F:BPC]
    Endif

    WPAG=""
    If [F:ZECCLAC]ZCLIPAG<>"" Then
      Filter [F:BPC] Where ZCLIECC=[F:ZECCLAC]ZCLIPAG
      For [F:BPC]
        WPAG=[F:BPC]BPCNUM
      Next
      Filter [F:BPC]
    Endif

    If WBPC<>"" Then
      WOUT = filpath("ECOMMERCE/ENTRADA","ZBPCACTECC_"+[F:ZECCLAC]ZCLIECC+format$("D:YYYYMMDD",date$),"")

      Openo WOUT,0 Using [TIF]
      Iomode adxium 0 Using [TIF]

      Call XML_INICIO("UTF") From ZXML
      Call XML_INICIO_NOMBRE("ZBPCACTECC") From ZXML

      Call XML_ABRE_ETIQUETA("B") From ZXML
      Call XML_LINEA("BPC_BCGCOD","CD") From ZXML

      Call XML_LINEA("BPC_BPCNUM",WBPC) From ZXML
      Call XML_LINEA("BPR_BPRNAM",[F:ZECCLAC]ZNOMFAC) From ZXML
      Call XML_LINEA("BPR_BPRSHO",[F:ZECCLAC]ZNOMFAC) From ZXML
      Call XML_LINEA("BPC_BPAINV",[F:ZECCLAC]ZDIRFAC) From ZXML
      Call XML_LINEA("BPC_BPAPYR",[F:ZECCLAC]ZDIRFAC) From ZXML
      Call XML_LINEA("BPC_BPAADD",[F:ZECCLAC]ZDIRFAC) From ZXML
      Call XML_LINEA("BPC_BPDADD",[F:ZECCLAC]ZDIRFAC) From ZXML
      Call XML_LINEA("BPC_CUR",[F:ZECCLAC]ZDIVISA) From ZXML
      Call XML_LINEA("BPR_CRN",[F:ZECCLAC]ZDNI) From ZXML
      Call XML_LINEA("BPC_BPCINV",WBPC) From ZXML
      Call XML_LINEA("BPC_VACBPR",[F:ZECCLAC]ZREGIMP) From ZXML
      Call XML_LINEA("BPC_PTE",[F:ZECCLAC]ZCONDPAGO) From ZXML
      #Call XML_LINEA("BPC_ACCCOD","LOCAL") From ZXML
      #Call XML_LINEA("BPC_TSCCOD_0",[F:ZICGM]ZFCYA) From ZXML
      #Call XML_LINEA("BPC_OSTAUZ","1") From ZXML
      #Call XML_LINEA("BPC_COMCAT","01:SPA:Categoría 1") From ZXML
      Call XML_LINEA("BPC_REP_0",[F:ZECCLAC]ZVENDEDOR) From ZXML
      Call XML_LINEA("BPC_B__28",[F:ZECCLAC]ZCODPAIS) From ZXML
      #Call XML_LINEA("BPC_B__26",[F:ZICGM]ZFCYA) From ZXML
      Call XML_LINEA("BPC_BPCPYR",WPAG) From ZXML
      Call XML_LINEA("BPC_BPCRSK",WBPC) From ZXML
      Call XML_LINEA("BPC_ZCLIECC",[F:ZECCLAC]ZCLIECC) From ZXML
      Call XML_LINEA("BPR_LAN",[F:ZECCLAC]ZIDIOMATER) From ZXML


      #Call XML_LINEA("BPC_DME","01:SPA:Autorizada") From ZXML
#      If [F:ZECCLAC]ZIDCLISA="" Then
#        Call XML_LINEA("BPC_OSTCTL","02:SPA:Libre") From ZXML
#      Else
#        #Extraemos el tipo de control de riesgo del cliente de X3
#        Read [F:XBPC]BPC0=[F:ZECCLAC]ZIDCLISA
#        If fstat=0 Then
#          ZCONTROL=[F:XBPC]OSTCTL
#          If ZCONTROL=1 Then
#            Call XML_LINEA("BPC_OSTCTL","01:SPA:Controlado") From ZXML
#          Elsif ZCONTROL=2 Then
#            Call XML_LINEA("BPC_OSTCTL","02:SPA:Libre") From ZXML
#          Elsif ZCONTROL=3 Then
#            Call XML_LINEA("BPC_OSTCTL","03:SPA:Bloqueado") From ZXML
#          Endif
#
#        Endif
#      Endif


      Call XML_ABRE_ETIQUETA("A") From ZXML
      Call XML_LINEA("BPA_BPAADD",[F:ZECCLAC]ZDIRFAC) From ZXML
      Call XML_LINEA("BPA_BPADES",[F:ZECCLAC]ZNOMFAC) From ZXML
      Call XML_LINEA("BPA_BPAADDLIG",[F:ZECCLAC]ZDIR1FAC) From ZXML
      Call XML_LINEA("BPA_BPAADDLIG_1",[F:ZECCLAC]ZDIR2FAC) From ZXML
      Call XML_LINEA("BPA_WEB",[F:ZECCLAC]ZEMAIFAC) From ZXML
      Call XML_LINEA("BPA_POSCOD",[F:ZECCLAC]ZCPFAC) From ZXML
      Call XML_LINEA("BPA_CTY",[F:ZECCLAC]ZCIUFAC) From ZXML
      Call XML_LINEA("BPA_SAT",[F:ZECCLAC]ZPROVFAC) From ZXML
      Call XML_LINEA("BPA_CRY",[F:ZECCLAC]ZCODPAISFAC) From ZXML
      Call XML_LINEA("BPA_TEL",[F:ZECCLAC]ZTELFIJFAC) From ZXML
      Call XML_LINEA("BPA_MOB",[F:ZECCLAC]ZTELMOVFAC) From ZXML
      Call XML_LINEA("BPA_FAX",[F:ZECCLAC]ZTELFAXFAC) From ZXML
      Call XML_CIERRA_ETIQUETA("A") From ZXML

      Call XML_ABRE_ETIQUETA("A") From ZXML
      Call XML_LINEA("BPA_BPAADD",[F:ZECCLAC]ZDIRENT) From ZXML
      Call XML_LINEA("BPA_BPADES",[F:ZECCLAC]ZNOMENT) From ZXML
      Call XML_LINEA("BPA_BPAADDLIG",[F:ZECCLAC]ZDIR1ENT) From ZXML
      Call XML_LINEA("BPA_BPAADDLIG_1",[F:ZECCLAC]ZDIR2ENT) From ZXML
      Call XML_LINEA("BPA_WEB",[F:ZECCLAC]ZEMAIENT) From ZXML
      Call XML_LINEA("BPA_POSCOD",[F:ZECCLAC]ZCPENT) From ZXML
      Call XML_LINEA("BPA_CTY",[F:ZECCLAC]ZCIUENT) From ZXML
      Call XML_LINEA("BPA_SAT",[F:ZECCLAC]ZPROVENT) From ZXML
      Call XML_LINEA("BPA_CRY",[F:ZECCLAC]ZCODPAISFAC) From ZXML
      Call XML_LINEA("BPA_TEL",[F:ZECCLAC]ZTELFIJENT) From ZXML
      Call XML_LINEA("BPA_MOB",[F:ZECCLAC]ZTELMOVENT) From ZXML
      Call XML_LINEA("BPA_FAX",[F:ZECCLAC]ZTELFAXENT) From ZXML
      Call XML_CIERRA_ETIQUETA("A") From ZXML

      Call XML_ABRE_ETIQUETA("D") From ZXML
      Call XML_LINEA("BPD_BPAADD",[F:ZECCLAC]ZDIRFAC) From ZXML
      Call XML_LINEA("BPD_BPDNAM_0",[F:ZECCLAC]ZNOMFAC) From ZXML
      Call XML_LINEA("BPD_REP_0",[F:ZECCLAC]ZVENDEDOR) From ZXML
      Call XML_LINEA("BPD_MDL",num$([F:ZECCLAC]ZIDTRANS)) From ZXML
      Call XML_LINEA("BPD_BPTNUM",[F:ZECCLAC]ZTRANS) From ZXML
      Call XML_CIERRA_ETIQUETA("D") From ZXML

      Call XML_ABRE_ETIQUETA("D") From ZXML
      Call XML_LINEA("BPD_BPAADD",[F:ZECCLAC]ZDIRENT) From ZXML
      Call XML_LINEA("BPD_BPDNAM_0",[F:ZECCLAC]ZNOMENT) From ZXML
      Call XML_LINEA("BPD_REP_0",[F:ZECCLAC]ZVENDEDOR) From ZXML
      Call XML_LINEA("BPD_MDL",num$([F:ZECCLAC]ZIDTRANS)) From ZXML
      Call XML_LINEA("BPD_BPTNUM",[F:ZECCLAC]ZTRANS) From ZXML
      Call XML_CIERRA_ETIQUETA("D") From ZXML

      Call XML_CIERRA_ETIQUETA("B") From ZXML
      Call XML_FIN("ZBPCACTECC") From ZXML

      Openo Using [TIF]

      [F:ZECCLAC]ZFICHERO="ZBPCACTECC_"+[F:ZECCLAC]ZCLIECC+format$("D:YYYYMMDD",date$)
      [F:ZECCLAC]ZESTADO=3
      Rewrite [F:ZECCLAC]
    Endif
  Next
  Filter [F:ZECCLAC]

Return

$CREAR_VENCIMIENTOS
  Local Char REQUEST(255)(0..)
  Local Char REQUEST2(255)
  Local Char REQUEST3(255)(0..)
  Local Char REQUEST4(255)(0..)

  Local Char TIPOFAC(10)
  Local Integer WACCNUM

  Local Char CUR(10)
  Local Char SAC(10)
  Local Char BPR(50)
  Local Char BPRPAY(50)
  Local Integer BPRTYP
  Local Char BPAPAY(15)

  Local Integer FYNUM

  Local Integer CONTAVENC

  Local Char PAM(50)

  Local Integer VUELTAS
  Local Char TIPOVENC(10)

  Local Char FILTROVENC(50)
  Local Decimal ZIMPDTO

  Local Decimal TOTALFAC

  For VUELTAS=0 To 1
    #0--> FACTURA DE VENTA
    #1--> ABONO DE VENTA
    If VUELTAS=0 Then
      TIPOVENC="FAC"
      FILTROVENC="ZIMPORTE_0>0"
    Else
      FILTROVENC="ZIMPORTE_0<0"
      TIPOVENC="ABO"
    Endif
    REQUEST(0)= "SELECT D.NUM_0, D.ZSERDOC_0, D.CPY_0, D.STOFCY_0,D.ZNUMDOC_0 FROM SINVOICED AS D INNER JOIN SINVOICE AS C ON D.NUM_0 = C.NUM_0 AND D.CPY_0 = C.CPY_0 "
    REQUEST(1)= "WHERE (D.ZGENVENC_0 in (1)) AND C.SIVTYP_0='"+TIPOVENC+"' AND D.ZNUMDOC_0 IN(SELECT ZNUMDOC_0 FROM ZECCCABFAC) "
    REQUEST(2)=" GROUP BY D.NUM_0,D.ZSERDOC_0,D.CPY_0,D.STOFCY_0,D.ZNUMDOC_0"

    For (Char NUM(50),Char ZSERDOC(15),Char CPY(5),Char STOFCY(10),Char ZNUMDOC(30)) From "5" Sql REQUEST As [AAA]

      #Extraemos el tipo de factura
      TIPOFAC=""
      WACCNUM=0
      Filter [F:SIH] Where 1=1 and NUM=[F:AAA]NUM and CPY=[F:AAA]CPY
      For [F:SIH]
        TIPOFAC=[F:SIH]GTE
        WACCNUM=[F:SIH]ACCNUM
      Next
      Filter [F:SIH]

      #Extramos los valores del registro del vencimiento asociado a la factura de venta
      CUR=""
      SAC=""
      BPR=""
      BPRPAY=""
      BPRTYP=0
      BPAPAY=""
      Filter [F:DUD] Where 1=1 and ACCNUM=WACCNUM
      For [F:DUD]
        CUR=[F:DUD]CUR
        SAC=[F:DUD]SAC
        BPR=[F:DUD]BPR
        BPRPAY=[F:DUD]BPRPAY
        BPRTYP=[F:DUD]BPRTYP
        BPAPAY=[F:DUD]BPAPAY
      Next
      Filter [F:DUD]

      #Creamos el fichero XML
      CONTAVENC=1

      WOUT = filpath("ECOMMERCE/ENTRADA","ZDUDECC_"+[F:AAA]ZSERDOC+"_"+[F:AAA]NUM,"")

      Openo WOUT,0 Using [TIF]
      Iomode adxium 0 Using [TIF]

      Call XML_INICIO("UTF") From ZXML
      Call XML_INICIO_NOMBRE("ZDUD") From ZXML

      #Abrimos los registros de pagos realizando el sumatorio de los vencimientos
      If VUELTAS=0 or VUELTAS=1 Then
        REQUEST3(0)="SELECT SUM(ZIMPORTE_0),ZDATVTO_0,ZFACPAG_0,ZNUMDOC_0 FROM ZECCPAGFAC WHERE ZNUMDOC_0='"+[F:AAA]ZNUMDOC+"' "
        REQUEST3(1)="AND ZSERDOC_0='"+[F:AAA]ZSERDOC+"' GROUP BY ZNUMDOC_0,ZSERDOC_0,ZORIGEN_0,ZDATVTO_0,ZFACPAG_0"
         For (Decimal ZIMPORTE,Date FECHAVENC,Char ZFORPAG(30),Char ZNUMDOC(50)) From "5" Sql REQUEST3 As [CCC]
          PAM=""

#          Read [F:ZICGPAG]ZICGPAG0=abs([F:CCC]ZFORPAG)
#          If fstat=0 Then
#            PAM=[F:ZICGPAG]ZCODPAGOX3
#          Endif

          PAM=[F:CCC]ZFORPAG

          FYNUM=0
          Filter [F:FIY] Where 1=1 and CPY=[F:AAA]CPY and (FIYSTR<=[F:CCC]FECHAVENC and FIYEND>=[F:CCC]FECHAVENC)
          For [F:FIY]
            FIYNUM=[F:FIY]FIYNUM
          Next
          Filter [F:FIY]

#          #Extraemos el descuento del fichero del match para aplicarlo en el elemento de facturacion
#          ZIMPDTO=0
#          Filter [F:ZECCMAT] Where 1=1 and ZNUMDOC=[F:CCC]ZNUMDOC
#          For [F:ZECCMAT]
#            ZIMPDTO=[F:ZECCMAT]ZTOTALDTO*-1
#          Next
#          Filter [F:ZECCMAT]

          TOTALFAC=0
          Filter [F:ZSIH] Where 1=1 and ZNUMDOC=[F:CCC]ZNUMDOC
          For [F:ZSIH]
            TOTALFAC=[F:ZSIH]AMTATI
          Next
          Filter [F:ZSIH]


          Call XML_ABRE_ETIQUETA("E") From ZXML
          Call XML_LINEA("DUD_TYP",TIPOFAC) From ZXML
          Call XML_LINEA("DUD_NUM",[F:AAA]NUM) From ZXML
          Call XML_LINEA("DUD_LIG","1") From ZXML
          Call XML_LINEA("DUD_DUDLIG",num$(CONTAVENC)) From ZXML
          Call XML_LINEA("DUD_PAM",PAM) From ZXML
          Call XML_LINEA("DUD_PAMTYP","01:SPA:Vencimiento") From ZXML
          #Call XML_LINEA("DUD_AMTCUR",num$([F:CCC]ZIMPORTE-ZIMPDTO)) From ZXML
          Call XML_LINEA("DUD_AMTCUR",num$(TOTALFAC)) From ZXML

          Call XML_LINEA("DUD_CUR",CUR) From ZXML
          Call XML_LINEA("DUD_NUMDUD",num$(WACCNUM)+"/"+num$(CONTAVENC)) From ZXML
          Call XML_LINEA("DUD_ACCNUM",num$(WACCNUM)) From ZXML
          Call XML_LINEA("DUD_CPY",[F:AAA]CPY) From ZXML
          Call XML_LINEA("DUD_FCY",[F:AAA]STOFCY) From ZXML
          Call XML_LINEA("DUD_BPR",BPR) From ZXML
          Call XML_LINEA("DUD_BPRTYP","01:SPA:Cliente") From ZXML
          Call XML_LINEA("DUD_BPRPAY",BPRPAY) From ZXML
          Call XML_LINEA("DUD_BPAPAY",BPAPAY) From ZXML
          Call XML_LINEA("DUD_DUDDAT",mid$(num$([F:CCC]FECHAVENC),7,4)+"-"+mid$(num$([F:CCC]FECHAVENC),4,2)+"-"+mid$(num$([F:CCC]FECHAVENC),1,2)) From ZXML
          Call XML_LINEA("DUD_SNS","1") From ZXML
          Call XML_LINEA("DUD_AMTLOC",num$(TOTALFAC)) From ZXML
          Call XML_LINEA("DUD_FLGFUP","false") From ZXML
          Call XML_LINEA("DUD_FLGPAZ","04:SPA:Autorización pago") From ZXML
          Call XML_LINEA("DUD_SOI","false") From ZXML
          Call XML_LINEA("DUD_DUDSTA","2") From ZXML
          Call XML_LINEA("DUD_FIY",num$(FYNUM)) From ZXML
          Call XML_LINEA("DUD_PER",num$(month([F:CCC]FECHAVENC))) From ZXML
          Call XML_LINEA("DUD_FLGCLE","2") From ZXML
          If VUELTAS=0 Then
            Call XML_LINEA("DUD_TYPDUD","01:SPA:Factura") From ZXML
          Else
            Call XML_LINEA("DUD_TYPDUD","02:SPA:Abono") From ZXML
          Endif

          Call XML_CIERRA_ETIQUETA("E") From ZXML

          CONTAVENC=CONTAVENC+1
        Next
        #Next

        #Actualizamos el estado de la línea a 1 porque el fichero se ha generado
        #Update [F:ZICGP] Where ZSERDOC=[F:AAA]ZSERDOC and ZBPR=BPR and ZDAT=[F:YYY]ZDAT With ZESTADO=1,ZFICHERO="ZDUD_"+[F:AAA]ZSERDOC+"_"+[F:AAA]NUM
        Call XML_FIN("ZDUD") From ZXML
        Openo Using [TIF]

        Update [F:ZECCPAG] Where ZNUMDOC=[F:AAA]ZNUMDOC and ZSERDOC=[F:AAA]ZSERDOC With ZFICHERO="ZDUDECC_"+[F:AAA]ZSERDOC+"_"+[F:AAA]NUM,ZESTADO=2

      Endif

    Next

  Next

Return

$IMPORTAR_CLIENTES
  Local Char RESULT  (200)(9000)
  Local Char NOMFIC  (250)
  Local Integer STAT
  Local Char A(250)(1..110)
  Local Char MODELO(10)
  Local Integer TOTOK
  Local Char FICH(100)
  Local Integer WESTADO
  Local Integer NUMFIL
  Local Integer OKFIL
  Local Integer ERFIL

  Append PROCLI, '#######################################################'+chr$(10)
  Append PROCLI, '## Proceso de importación de CLIENTES #################'+chr$(10)+chr$(10)
  #Append PROCLI, '#######################################################'+chr$(10)+chr$(10)


  Filter [F:ZECCCLI] Where 1=1 and ZFICHERO<>'' and ZESTADO=2 Order By ZFICHERO
  For [F:ZECCCLI]
    If [F:ZECCCLI]ZFICHERO<>FICH Then
      FICH=[F:ZECCCLI]ZFICHERO
      TOTOK=1
      GERRTRACE=0

      NOMFIC= filpath("ECOMMERCE\ENTRADA","","") + "\" +[F:ZECCCLI]ZFICHERO
      If filinfo(NOMFIC,7)>0 Then
        NUMFIL=NUMFIL+1
        Call IMPORTSIL("ZBPCECC",NOMFIC) From GIMPOBJ
        If GERRTRACE<>0 Then
          NUMERRORES=NUMERRORES+GERRTRACE
          TOTOK=0
        Endif
        If TOTOK
          Call ECR_TRACE("----------------------------------------------------------------------",0) From GESECRAN
          Call ECR_TRACE("AZ>CLIENTE "+[F:ZECCCLI]ZCLIPAG-[F:ZECCCLI]ZNOMFAC,0) From GESECRAN
          Call ECR_TRACE("",0) From GESECRAN
          WESTADO=4
          Call MOVE(NOMFIC,filpath("ECOMMERCE\ENTRADA\IMPORTADOS","","") + "\" + [F:ZECCCLI]ZFICHERO,STAT)    From ORDSYS

          [F:ZECCCLI]ZESTADO=4
          [F:ZECCCLI]ZNUMIMP=[F:ZECCCLI]ZNUMIMP+1
          [F:ZECCCLI]ZIDCLISA=[BPC]BPCNUM

          Update [F:WZECCCAB] Where ZFICHORI=[F:ZECCCLI]ZFICHORI With ZBPR=[BPC]BPCNUM,ZBPRPAG=[BPC]BPCNUM
          Update [F:WZECCPAG] Where ZFICHORI=[F:ZECCCLI]ZFICHORI With ZBPR=[BPC]BPCNUM,ZBPRPAG=[BPC]BPCNUM

          #Actualizamos el código del cliente de magento en la tabla de X3
          Update [F:BPC] Where BPCNUM=[F:ZECCCLI]ZIDCLISA With ZCLIECC=[F:ZECCCLI]ZCLIPAG

          OKFIL=OKFIL+1

        Else
          Call ECR_TRACE("----------------------------------------------------------------------",0) From GESECRAN
          Call ECR_TRACE("AZ>CLIENTE "+[F:ZECCCLI]ZCLIPAG-[F:ZECCCLI]ZNOMFAC,0) From GESECRAN
          Call ECR_TRACE("",0) From GESECRAN

          PROERR=2
          ERFIL=ERFIL+1
          WESTADO=5
          Call MOVE(NOMFIC,filpath("ECOMMERCE\ENTRADA\ERRONEOS","","") + "\" + [F:ZECCCLI]ZFICHERO,STAT)    From ORDSYS
          [F:ZECCCLI]ZESTADO=5
          [F:ZECCCLI]ZNUMIMP=[F:ZECCCLI]ZNUMIMP+1

          Append PROCLI, '**** '+[F:ZECCCLI]ZFICHORI+': Error en la creación/actualización del cliente ECC '+[F:ZECCCLI]ZCLIPAG+' '+[F:ZECCCLI]ZNOMFAC+' ****'+chr$(10)
        Endif
        Rewrite [F:ZECCCLI]
      Else
        #Infbox("no existe")
      Endif
    Else
      [F:ZECCCLI]ZESTADO=WESTADO
      [F:ZECCCLI]ZIDCLISA=[BPC]BPCNUM
      Rewrite [F:ZECCCLI]
    Endif
  Next
  Filter [F:ZECCCLI]

  Append PROCLI, 'Clientes leídos: '+num$(NUMFIL)+chr$(10)
  Append PROCLI, 'Clientes actualizados/creados: '+num$(OKFIL)+chr$(10)
  Append PROCLI, 'Clientes con error: '+num$(ERFIL)+chr$(10)+chr$(10)

  If ERFIL>0 Then
    Append PROCLI, '**** CONSULTE EL FICHERO DE TRAZA ADJUNTO PARA VER EL DETALLE DEL ERROR ****'+chr$(10)+chr$(10)
  Endif

Return

$IMPORTAR_CLIENTES_ACTU
  Local Char RESULT  (200)(9000)
  Local Char NOMFIC  (250)
  Local Integer STAT
  Local Char A(250)(1..110)
  Local Char MODELO(10)
  Local Integer TOTOK
  Local Char FICH(100)
  Local Integer WESTADO
  Local Integer NUMFIL
  Local Integer OKFIL
  Local Integer ERFIL

  Append PROCLI, '#######################################################'+chr$(10)
  Append PROCLI, '## Proceso de actualización de CLIENTES #################'+chr$(10)+chr$(10)
  #Append PROCLI, '#######################################################'+chr$(10)+chr$(10)


  Filter [F:ZECCLAC] Where 1=1 and ZFICHERO<>'' and ZESTADO=3
  For [F:ZECCLAC]
    FICH=[F:ZECCLAC]ZFICHERO
    TOTOK=1
    GERRTRACE=0

    NOMFIC= filpath("ECOMMERCE\ENTRADA","","") + "\" +[F:ZECCLAC]ZFICHERO
    If filinfo(NOMFIC,7)>0 Then
      NUMFIL=NUMFIL+1
      Call IMPORTSIL("ZBPCACTECC",NOMFIC) From GIMPOBJ
      If GERRTRACE<>0 Then
        NUMERRORES=NUMERRORES+GERRTRACE
        TOTOK=0
      Endif
      If TOTOK
        Call ECR_TRACE("----------------------------------------------------------------------",0) From GESECRAN
        Call ECR_TRACE("AZ>CLIENTE "+[F:ZECCLAC]ZCLIECC-[F:ZECCLAC]ZNOMFAC,0) From GESECRAN
        Call ECR_TRACE("",0) From GESECRAN
        WESTADO=4
        Call MOVE(NOMFIC,filpath("ECOMMERCE\ENTRADA\IMPORTADOS","","") + "\" + [F:ZECCLAC]ZFICHERO,STAT)    From ORDSYS

        [F:ZECCLAC]ZESTADO=4
        [F:ZECCLAC]ZIDCLISA=[BPC]BPCNUM

        OKFIL=OKFIL+1

      Else
        Call ECR_TRACE("----------------------------------------------------------------------",0) From GESECRAN
        Call ECR_TRACE("AZ>CLIENTE "+[F:ZECCLAC]ZCLIECC-[F:ZECCLAC]ZNOMFAC,0) From GESECRAN
        Call ECR_TRACE("",0) From GESECRAN

        PROERR=2
        ERFIL=ERFIL+1
        WESTADO=5
        Call MOVE(NOMFIC,filpath("ECOMMERCE\ENTRADA\ERRONEOS","","") + "\" + [F:ZECCLAC]ZFICHERO,STAT)    From ORDSYS
        [F:ZECCLAC]ZESTADO=5

        Append PROCLI, '**** '+[F:ZECCCLI]ZFICHORI+': Error en la actualización del cliente ECC '+[F:ZECCLAC]ZCLIECC+' '+[F:ZECCLAC]ZNOMFAC+' ****'+chr$(10)
      Endif
      Rewrite [F:ZECCLAC]
    Else
      #Infbox("no existe")
    Endif
  Next
  Filter [F:ZECCCLI]

  Append PROCLI, 'Clientes leídos: '+num$(NUMFIL)+chr$(10)
  Append PROCLI, 'Clientes actualizados: '+num$(OKFIL)+chr$(10)
  Append PROCLI, 'Clientes con error: '+num$(ERFIL)+chr$(10)+chr$(10)

  If ERFIL>0 Then
    Append PROCLI, '**** CONSULTE EL FICHERO DE TRAZA ADJUNTO PARA VER EL DETALLE DEL ERROR ****'+chr$(10)+chr$(10)
  Endif

Return

$IMPORTAR_FACTURAS
  Local Char RESULT  (200)(9000)
  Local Char NOMFIC  (250)
  Local Integer STAT
  Local Char A(250)(1..110)
  Local Char MODELO(10)
  Local Integer TOTOK
  Local Integer NUMFIL
  Local Integer OKFIL
  Local Integer ERFIL

  Append PROFAC, '#######################################################'+chr$(10)
  Append PROFAC, '## Proceso de importación de FACTURAS DE VENTA ########'+chr$(10)+chr$(10)
  #Append PROFAC, '#######################################################'+chr$(10)+chr$(10)

  Filter [F:ZECCCAB] Where 1=1 and ZFICHERO<>'' and ZESTADO=2 and (ZTIPMOV=2)
  For [F:ZECCCAB]
    NUMFIL=NUMFIL+1
    TOTOK=1
    GERRTRACE=0

    #Actualizamos el campo ZCOMP de la tabla MATCH para indicar que hay que comparar esos ficheros
    Update [F:ZECCMAT] Where 1=1 and ZNUMDOC=[F:ZECCCAB]ZNUMDOC and ZTIPDOC='2' With ZCOMP=2

    NOMFIC= filpath("ECOMMERCE\ENTRADA","","") + "\" +[F:ZECCCAB]ZFICHERO
    Call IMPORTSIL("ZSIHECC",NOMFIC) From GIMPOBJ
    If GERRTRACE<>0 Then
      NUMERRORES=NUMERRORES+GERRTRACE
      TOTOK=0
    Endif
    If TOTOK
      OKFIL=OKFIL+1
      Call ECR_TRACE("----------------------------------------------------------------------",0) From GESECRAN
      Call ECR_TRACE("AZ>FACTURA "+[F:ZECCCAB]ZNUMDOC+"/"+[F:ZECCCAB]ZORIGEN+"/"+[F:ZECCCAB]ZFICHORI,0) From GESECRAN
      Call ECR_TRACE("",0) From GESECRAN

      Call MOVE(NOMFIC,filpath("ECOMMERCE\ENTRADA\IMPORTADOS","","") + "\" + [F:ZECCCAB]ZFICHERO,STAT)    From ORDSYS
      [F:ZECCCAB]ZESTADO=4
      [F:ZECCCAB]ZNUMIMP=[F:ZECCCAB]ZNUMIMP+1

      Update [F:ZECCLIN] Where ZENLACE=[F:ZECCCAB]ZENLACE With ZESTADO=4,ZNUMIMP=ZNUMIMP+1
      Update [F:ZSID] Where NUM=[SIH]NUM With ZGENVENC=1,ZGENCOB=1

      Update [F:ZSIH] Where NUM=[SIH]NUM With ZFICHORI=[F:ZECCCAB]ZFICHORI


    Else
      PROERR=2
      ERFIL=ERFIL+1

      Call ECR_TRACE("----------------------------------------------------------------------",0) From GESECRAN
      Call ECR_TRACE("AZ>FACTURA "+[F:ZECCCAB]ZNUMDOC+"/"+[F:ZECCCAB]ZORIGEN+"/"+[F:ZECCCAB]ZFICHORI,0) From GESECRAN
      Call ECR_TRACE("",0) From GESECRAN

      Call MOVE(NOMFIC,filpath("ECOMMERCE\ENTRADA\ERRONEOS","","") + "\" + [F:ZECCCAB]ZFICHERO,STAT)    From ORDSYS
      [F:ZECCCAB]ZESTADO=5
      [F:ZECCCAB]ZNUMIMP=[F:ZECCCAB]ZNUMIMP+1

      Update [F:ZECCLIN] Where ZENLACE=[F:ZECCCAB]ZENLACE With ZESTADO=5,ZNUMIMP=ZNUMIMP+1

      Append PROFAC, '**** '+[F:ZECCCAB]ZFICHORI+': Error en la creación de la factura de venta '+[F:ZECCCAB]ZNUMDOC+'/'+[F:ZECCCAB]ZORIGEN+' ****'+chr$(10)

    Endif
    Rewrite [F:ZECCCAB]
  Next
  Filter [F:ZECCCAB]

  Append PROFAC, 'Facturas leídas: '+num$(NUMFIL)+chr$(10)
  Append PROFAC, 'Facturas creadas: '+num$(OKFIL)+chr$(10)
  Append PROFAC, 'Facturas con error: '+num$(ERFIL)+chr$(10)+chr$(10)

  If ERFIL>0 Then
    Append PROFAC, '**** CONSULTE EL FICHERO DE TRAZA ADJUNTO PARA VER EL DETALLE DEL ERROR ****'+chr$(10)+chr$(10)
  Endif

Return

$IMPORTAR_PEDIDOS_VENTA
  Local Char RESULT  (200)(9000)
  Local Char NOMFIC  (250)
  Local Integer STAT
  Local Char A(250)(1..110)
  Local Char MODELO(10)
  Local Integer TOTOK
  Local Integer NUMFIL
  Local Integer OKFIL
  Local Integer ERFIL

  Append PROPED, "#######################################################"+chr$(10)
  Append PROPED, "## Proceso de importación de PEDIDOS DE VENTA #########"+chr$(10)+chr$(10)
  #Append PROPED, "#######################################################"+chr$(10)+chr$(10)

  Filter [F:ZECCCAB] Where 1=1 and ZFICHERO<>'' and ZESTADO=2 and (ZTIPMOV=1)
  For [F:ZECCCAB]
    NUMFIL=NUMFIL+1
    TOTOK=1
    GERRTRACE=0

    #Actualizamos el campo ZCOMP de la tabla MATCH para indicar que hay que comparar esos ficheros
    Update [F:ZECCMAT] Where 1=1 and ZNUMDOC=[F:ZECCCAB]ZNUMDOC and ZTIPDOC='1' With ZCOMP=2

    NOMFIC= filpath("ECOMMERCE\ENTRADA","","") + "\" +[F:ZECCCAB]ZFICHERO
    Call IMPORTSIL("ZSOHECC",NOMFIC) From GIMPOBJ
    If GERRTRACE<>0 Then
      NUMERRORES=NUMERRORES+GERRTRACE
      TOTOK=0
    Endif
    If TOTOK
      OKFIL=OKFIL+1
      Call ECR_TRACE("----------------------------------------------------------------------",0) From GESECRAN
      Call ECR_TRACE("AZ>PEDIDO "+[F:ZECCCAB]ZORIGEN+"/"+[F:ZECCCAB]ZNUMDOC+"/"+[F:ZECCCAB]ZFICHORI,0) From GESECRAN
      Call ECR_TRACE("",0) From GESECRAN

      Call MOVE(NOMFIC,filpath("ECOMMERCE\ENTRADA\IMPORTADOS","","") + "\" + [F:ZECCCAB]ZFICHERO,STAT)    From ORDSYS
      [F:ZECCCAB]ZESTADO=4
      [F:ZECCCAB]ZNUMIMP=[F:ZECCCAB]ZNUMIMP+1

      Update [F:ZECCLIN] Where ZENLACE=[F:ZECCCAB]ZENLACE With ZESTADO=4,ZNUMIMP=ZNUMIMP+1

      Update [F:ZSOH] Where SOHNUM=[SOH]SOHNUM With ZFICHORI=[F:ZECCCAB]ZFICHORI


    Else
      ERFIL=ERFIL+1
      PROERR=2

      Call ECR_TRACE("----------------------------------------------------------------------",0) From GESECRAN
      Call ECR_TRACE("AZ>PEDIDO "+[F:ZECCCAB]ZORIGEN+"/"+[F:ZECCCAB]ZNUMDOC+"/"+[F:ZECCCAB]ZFICHORI,0) From GESECRAN
      Call ECR_TRACE("",0) From GESECRAN

      Call MOVE(NOMFIC,filpath("ECOMMERCE\ENTRADA\ERRONEOS","","") + "\" + [F:ZECCCAB]ZFICHERO,STAT)    From ORDSYS
      [F:ZECCCAB]ZESTADO=5
      [F:ZECCCAB]ZNUMIMP=[F:ZECCCAB]ZNUMIMP+1

      Update [F:ZECCLIN] Where ZENLACE=[F:ZECCCAB]ZENLACE With ZESTADO=5,ZNUMIMP=ZNUMIMP+1

      Append PROPED, '**** '+[F:ZECCCAB]ZFICHORI+': Error en la creación del pedido de venta '+[F:ZECCCAB]ZORIGEN+'/'+[F:ZECCCAB]ZNUMDOC+' ****'+chr$(10)
    Endif
    Rewrite [F:ZECCCAB]
  Next
  Filter [F:ZECCCAB]

  Append PROPED, 'Pedidos leídos: '+num$(NUMFIL)+chr$(10)
  Append PROPED, 'Pedidos creados: '+num$(OKFIL)+chr$(10)
  Append PROPED, 'Pedidos con error: '+num$(ERFIL)+chr$(10)+chr$(10)

  If ERFIL>0 Then
    Append PROPED, '**** CONSULTE EL FICHERO DE TRAZA ADJUNTO PARA VER EL DETALLE DEL ERROR ****'+chr$(10)+chr$(10)
  Endif
Return

$IMPORTAR_VENCIMIENTOS
  Local Char RESULT  (200)(9000)
  Local Char NOMFIC  (250)
  Local Integer STAT
  Local Char A(250)(1..110)
  Local Char MODELO(10)
  Local Integer TOTOK
  Local Char FICH(100)
  Local Integer WESTADO
  Local Integer NUMFIL
  Local Integer OKFIL
  Local Integer ERFIL

  Append PROVEN, '#######################################################'+chr$(10)
  Append PROVEN, '## Proceso de importación de VENCIMIENTOS #############'+chr$(10)+chr$(10)
  #Append PROVEN, '#######################################################'+chr$(10)+chr$(10)

  Filter [F:ZECCPAG] Where 1=1 and ZFICHERO<>'' and ZESTADO=2 Order By ZFICHERO
  For [F:ZECCPAG]
    If [F:ZECCPAG]ZFICHERO<>FICH Then
      FICH=[F:ZECCPAG]ZFICHERO
      TOTOK=1
      GERRTRACE=0

      NUMFIL=NUMFIL+1
      NOMFIC= filpath("ECOMMERCE\ENTRADA","","") + "\" +[F:ZECCPAG]ZFICHERO
      Call IMPORTSIL("ZDUDECC",NOMFIC) From GIMPOBJ
      If GERRTRACE<>0 Then
        NUMERRORES=NUMERRORES+GERRTRACE
        TOTOK=0
      Endif
      If TOTOK
        OKFIL=OKFIL+1
        Call ECR_TRACE("----------------------------------------------------------------------",0) From GESECRAN
        Call ECR_TRACE("AZ>VENCIMIENTO "+[F:ZECCPAG]ZNUMDOC+"/"+[F:ZECCPAG]ZORIGEN+"/"+[F:ZECCPAG]ZFICHORI,0) From GESECRAN
        Call ECR_TRACE("",0) From GESECRAN

        WESTADO=4
        Call MOVE(NOMFIC,filpath("ECOMMERCE\ENTRADA\IMPORTADOS","","") + "\" + [F:ZECCPAG]ZFICHERO,STAT)    From ORDSYS

        Update [F:ZSID] Where NUM=[DUD]NUM With ZGENVENC=2

        [F:ZECCPAG]ZESTADO=WESTADO
        [F:ZECCPAG]ZNUMIMP=[F:ZECCPAG]ZNUMIMP+1

      Else
        PROERR=2
        ERFIL=ERFIL+1
        Call ECR_TRACE("----------------------------------------------------------------------",0) From GESECRAN
        Call ECR_TRACE("AZ>VENCIMIENTO "+[F:ZECCPAG]ZNUMDOC+"/"+[F:ZECCPAG]ZORIGEN+"/"+[F:ZECCPAG]ZFICHORI,0) From GESECRAN
        Call ECR_TRACE("",0) From GESECRAN

        WESTADO=5
        Call MOVE(NOMFIC,filpath("ECOMMERCE\ENTRADA\ERRONEOS","","") + "\" + [F:ZECCPAG]ZFICHERO,STAT)    From ORDSYS
        [F:ZECCPAG]ZESTADO=WESTADO
        [F:ZECCPAG]ZNUMIMP=[F:ZECCPAG]ZNUMIMP+1

        Append PROVEN, '**** '+[F:ZECCPAG]ZFICHORI+': Error en la creación del vencimiento '+[F:ZECCPAG]ZNUMDOC+'/'+[F:ZECCPAG]ZORIGEN+' ****'+chr$(10)

      Endif
    Else
      [F:ZECCPAG]ZESTADO=WESTADO
    Endif
    Rewrite [F:ZECCPAG]
  Next
  Filter [F:ZECCPAG]

  Append PROVEN, 'Vencimientos leídos: '+num$(NUMFIL)+chr$(10)
  Append PROVEN, 'Vencimientos creados: '+num$(OKFIL)+chr$(10)
  Append PROVEN, 'Vencimientos con error: '+num$(ERFIL)+chr$(10)+chr$(10)

  If ERFIL>0 Then
    Append PROVEN, '**** CONSULTE EL FICHERO DE TRAZA ADJUNTO PARA VER EL DETALLE DEL ERROR ****'+chr$(10)+chr$(10)
  Endif

Return

$CREAR_COBROS
  Local Char REQUEST(255)(0..)
  Local Char REQUEST2(255)
  Local Char REQUEST3(255)(0..)
  Local Char REQUEST4(255)(0..)

  Local Char TIPOFAC(10)
  Local Integer WACCNUM

  Local Char CUR(10)
  Local Char SAC(10)
  Local Char BPR(50)
  Local Char BPRPAY(50)
  Local Integer BPRTYP
  Local Char BPAPAY(15)

  Local Integer FYNUM

  Local Integer CONTAVENC

  Local Char PAM(50)

  Local Integer VUELTAS
  Local Char TIPOVENC(10)

  Local Char FILTROVENC(50)

  For VUELTAS=0 To 1
    #0--> FACTURA DE VENTA
    #1--> ABONO DE VENTA
    If VUELTAS=0 Then
      TIPOVENC="ZZZ"
      FILTROVENC="ZIMPORTE_0>0"
    Else
      FILTROVENC="ZIMPORTE_0<0"
      TIPOVENC="ZZA"
    Endif
    REQUEST(0)= "SELECT D.NUM_0, D.ZSERDOC_0, D.CPY_0, D.STOFCY_0,D.ZNUMDOC_0 FROM SINVOICED AS D INNER JOIN SINVOICE AS C ON D.NUM_0 = C.NUM_0 AND D.CPY_0 = C.CPY_0 "
    REQUEST(1)= "WHERE (D.ZGENCOB_0 in (1)) AND C.SIVTYP_0='"+TIPOVENC+"' AND D.ZNUMDOC_0 IN(SELECT ZNUMDOC_0 FROM ZECCCABFAC) "
    REQUEST(2)=" GROUP BY D.NUM_0,D.ZSERDOC_0,D.CPY_0,D.STOFCY_0,D.ZNUMDOC_0"

    For (Char NUM(50),Char ZSERDOC(15),Char CPY(5),Char STOFCY(10),Char ZNUMDOC(30)) From "5" Sql REQUEST As [AAA]

      #Extraemos el tipo de factura
      TIPOFAC=""
      WACCNUM=0
      Filter [F:SIH] Where 1=1 and NUM=[F:AAA]NUM and CPY=[F:AAA]CPY
      For [F:SIH]
        TIPOFAC=[F:SIH]GTE
        WACCNUM=[F:SIH]ACCNUM
      Next
      Filter [F:SIH]

      #Extramos los valores del registro del vencimiento asociado a la factura de venta
      CUR=""
      SAC=""
      BPR=""
      BPRPAY=""
      BPRTYP=0
      BPAPAY=""
      Filter [F:DUD] Where 1=1 and ACCNUM=WACCNUM
      For [F:DUD]
        CUR=[F:DUD]CUR
        SAC=[F:DUD]SAC
        BPR=[F:DUD]BPR
        BPRPAY=[F:DUD]BPRPAY
        BPRTYP=[F:DUD]BPRTYP
        BPAPAY=[F:DUD]BPAPAY
      Next
      Filter [F:DUD]

      #Creamos el fichero XML
      CONTAVENC=1

      WOUT = filpath("ECOMMERCE/ENTRADA","ZPAYECC_"+[F:AAA]ZSERDOC+"_"+[F:AAA]NUM,"")

      Openo WOUT,0 Using [TIF]
      Iomode adxium 0 Using [TIF]

      Call XML_INICIO("UTF") From ZXML
      Call XML_INICIO_NOMBRE("ZPAY") From ZXML

      #Abrimos los registros de pagos realizando el sumatorio de los vencimientos
      If VUELTAS=0 or VUELTAS=1 Then
        REQUEST3(0)="SELECT SUM(ZIMPORTE_0),ZDATVTO_0,ZFACPAG_0 FROM ZECCPAGFAC WHERE ZNUMDOC_0='"+[F:AAA]ZNUMDOC+"' "
        REQUEST3(1)="AND ZSERDOC_0='"+[F:AAA]ZSERDOC+"' GROUP BY ZNUMDOC_0,ZSERDOC_0,ZORIGEN_0,ZDATVTO_0,ZFACPAG_0"
         For (Decimal ZIMPORTE,Date FECHAVENC,Char ZFORPAG(30)) From "5" Sql REQUEST3 As [CCC]
          PAM=""

#          Read [F:ZICGPAG]ZICGPAG0=abs([F:CCC]ZFORPAG)
#          If fstat=0 Then
#            PAM=[F:ZICGPAG]ZCODPAGOX3
#          Endif

          PAM=[F:CCC]ZFORPAG

          FYNUM=0
          Filter [F:FIY] Where 1=1 and CPY=[F:AAA]CPY and (FIYSTR<=[F:CCC]FECHAVENC and FIYEND>=[F:CCC]FECHAVENC)
          For [F:FIY]
            FIYNUM=[F:FIY]FIYNUM
          Next
          Filter [F:FIY]

          Call XML_ABRE_ETIQUETA("P") From ZXML
          #Call XML_LINEA("PYH_NUM",TIPOFAC) From ZXML
          Call XML_LINEA("PYH_PAYTYP","STAR") From ZXML
          Call XML_LINEA("PYH_BPR",BPR) From ZXML
          Call XML_LINEA("PYH_COA","SPA") From ZXML
          Call XML_LINEA("PYH_ACC","43000000") From ZXML
          Call XML_LINEA("PYH_PAM",PAM) From ZXML
          Call XML_LINEA("PYH_FCY","100") From ZXML
          Call XML_LINEA("PYH_BAN","001") From ZXML
          Call XML_LINEA("PYH_SNS","02:SPA:Ingreso") From ZXML
          Call XML_LINEA("PYH_CUR","EUR") From ZXML
          Call XML_LINEA("PYH_AMTCUR",num$([F:CCC]ZIMPORTE)) From ZXML
          Call XML_LINEA("PYH_ACCDAT",mid$(num$([F:CCC]FECHAVENC),7,4)+"-"+mid$(num$([F:CCC]FECHAVENC),4,2)+"-"+mid$(num$([F:CCC]FECHAVENC),1,2)) From ZXML
          Call XML_ABRE_ETIQUETA("D") From ZXML
          Call XML_LINEA("PYD_DENCOD","REC") From ZXML
          Call XML_LINEA("PYD_COA","SPA") From ZXML
          Call XML_LINEA("PYD_ACC","43000000") From ZXML
          Call XML_LINEA("PYD_BPRLIN",BPR) From ZXML
          Call XML_LINEA("PYD_VCRTYP",TIPOFAC) From ZXML
          Call XML_LINEA("PYD_VCRNUM",[F:AAA]NUM) From ZXML
          Call XML_LINEA("PYD_D__24",BPR) From ZXML
          Call XML_LINEA("PYD_D__25",mid$(num$([F:CCC]FECHAVENC),7,4)+mid$(num$([F:CCC]FECHAVENC),4,2)+mid$(num$([F:CCC]FECHAVENC),1,2)) From ZXML
          Call XML_LINEA("PYD_D__26","100") From ZXML
          Call XML_LINEA("PYD_CURLIN","EUR") From ZXML
          Call XML_LINEA("PYD_AMTLIN",num$([F:CCC]ZIMPORTE)) From ZXML
          Call XML_ABRE_ETIQUETA("A") From ZXML
          Call XML_LINEA("PYA_DIE_0","COS") From ZXML
          Call XML_LINEA("PYA_AMTANA",num$([F:CCC]ZIMPORTE)) From ZXML

          Call XML_CIERRA_ETIQUETA("A") From ZXML
          Call XML_CIERRA_ETIQUETA("D") From ZXML

          Call XML_CIERRA_ETIQUETA("E") From ZXML

          CONTAVENC=CONTAVENC+1
        Next
        #Next

        #Actualizamos el estado de la línea a 1 porque el fichero se ha generado
        #Update [F:ZICGP] Where ZSERDOC=[F:AAA]ZSERDOC and ZBPR=BPR and ZDAT=[F:YYY]ZDAT With ZESTADO=1,ZFICHERO="ZDUD_"+[F:AAA]ZSERDOC+"_"+[F:AAA]NUM
        Call XML_FIN("ZPAY") From ZXML
        Openo Using [TIF]

        Update [F:ZECCPAG] Where ZNUMDOC=[F:AAA]ZNUMDOC and ZSERDOC=[F:AAA]ZSERDOC With ZFICHCOB="ZPAYECC_"+[F:AAA]ZSERDOC+"_"+[F:AAA]NUM,ZESTADO=2

      Endif

    Next

  Next

Return

$CREAR_PEDIDOS_VENTA
  Local Char WOUT(250)
  Local Char ZBPR(30)
  Local Char ZBPRPAG(30)
  Local Char ZCUR(10)
  Local Char ZREGIMP(10)
  Local Char VACITM0(GLONTVI)
  Local Char VACITM1(GLONTVI)
  Local Char VACITM2(GLONTVI)
  Local Char VAT0(GLONVAT)
  Local Char VAT1(GLONVAT)
  Local Char VAT2(GLONVAT)
  Local Char FECHADOC(25)
  Local Char ZVAC(10)
  Local Char ZREP(10)


  Filter [F:ZECCCAB] Where 1=1 and (ZTIPMOV=1) and ZESTADO=0
  For [F:ZECCCAB]
    WOUT = filpath("ECOMMERCE/ENTRADA","ZSOHECC_"+[F:ZECCCAB]ZSERDOC+"_"+[F:ZECCCAB]ZNUMDOC+"_"+format$("D:YYYYMMDD",date$),"")

    Openo WOUT,0 Using [TIF]
    Iomode adxium 0 Using [TIF]

    Call XML_INICIO("UTF") From ZXML
    Call XML_INICIO_NOMBRE("ZSOHECC") From ZXML

    Call XML_ABRE_ETIQUETA("E") From ZXML
    #Call XML_LINEA("SIV_NUM",[F:ZICGM]ZNUM) From ZXML
    Call XML_LINEA("SOH_CPY",[F:ZECCCAB]ZSOC) From ZXML
    Call XML_LINEA("SOH_SALFCY",[F:ZECCCAB]ZFCYA) From ZXML
    Call XML_LINEA("SOH_SOHTYP",[F:ZECCCAB]ZSERDOC) From ZXML
    Call XML_LINEA("SOH_PRITYP","02:SPA:II") From ZXML
    Call XML_LINEA("SOH_BPCORD",[F:ZECCCAB]ZBPR) From ZXML
    Call XML_LINEA("SOH_ORDDAT",mid$(num$([F:ZECCCAB]ZDAT),7,4)+"-"+mid$(num$([F:ZECCCAB]ZDAT),4,2)+"-"+mid$(num$([F:ZECCCAB]ZDAT),1,2)) From ZXML
    Call XML_LINEA("SOH_DEMDLVDAT",mid$(num$([F:ZECCCAB]ZDAT),7,4)+"-"+mid$(num$([F:ZECCCAB]ZDAT),4,2)+"-"+mid$(num$([F:ZECCCAB]ZDAT),1,2)) From ZXML
    Call XML_LINEA("SOH_CUSORDREF",[F:ZECCCAB]ZREF) From ZXML
    Call XML_LINEA("SOH_STOFCY",[F:ZECCCAB]ZFCYA) From ZXML

    #Extraemos la divisa del cliente
    ZVAC=""
    ZCUR=""
    Read [XBPC]BPC0=[F:ZECCCAB]ZBPRPAG
    If fstat=0 Then
       ZCUR = [XBPC]CUR
       ZVAC = [XBPC]VACBPR
    Endif

#    ZREP=""
#    Filter [F:ZECCCLI] Where ZFICHORI=[F:ZECCCAB]ZFICHORI
#    For [F:ZECCCLI]
#      ZREP=[F:ZECCCLI]ZVENDEDOR
#    Next
#    Filter [F:ZECCCLI]

    Call XML_LINEA("SOH_PTE",[F:ZECCCAB]ZCONDPAGO) From ZXML
    Call XML_LINEA("SOH_CUR",ZCUR) From ZXML
    Call XML_LINEA("SOH_REP",[F:ZECCCAB]ZREP1) From ZXML
    Call XML_LINEA("SOH_INVDTAAMT_0",num$([F:ZECCCAB]ZELEFAC(0))) From ZXML
    Call XML_LINEA("SOH_INVDTAAMT_1",num$([F:ZECCCAB]ZELEFAC(1))) From ZXML
    Call XML_LINEA("SOH_INVDTAAMT_2",num$([F:ZECCCAB]ZELEFAC(2))) From ZXML
    Call XML_LINEA("SOH_INVDTAAMT_3",num$([F:ZECCCAB]ZELEFAC(3))) From ZXML
    Call XML_LINEA("SOH_INVDTAAMT_4",num$([F:ZECCCAB]ZELEFAC(4))) From ZXML
    Call XML_LINEA("SOH_INVDTAAMT_5",num$([F:ZECCCAB]ZELEFAC(5))) From ZXML
    Call XML_LINEA("SOH_INVDTAAMT_6",num$([F:ZECCCAB]ZELEFAC(6))) From ZXML
    Call XML_LINEA("SOH_INVDTAAMT_7",num$([F:ZECCCAB]ZELEFAC(7))) From ZXML
    Call XML_LINEA("SOH_INVDTAAMT_8",num$([F:ZECCCAB]ZELEFAC(8))) From ZXML
    Call XML_LINEA("SOH_INVDTAAMT_9",num$([F:ZECCCAB]ZELEFAC(9))) From ZXML
    Call XML_LINEA("SOH_INVDTAAMT_10",num$([F:ZECCCAB]ZELEFAC(10))) From ZXML
    Call XML_LINEA("SOH_INVDTAAMT_11",num$([F:ZECCCAB]ZELEFAC(11))) From ZXML
    Call XML_LINEA("SOH_INVDTAAMT_12",num$([F:ZECCCAB]ZELEFAC(12))) From ZXML
    Call XML_LINEA("SOH_INVDTAAMT_13",num$([F:ZECCCAB]ZELEFAC(13))) From ZXML
    Call XML_LINEA("SOH_INVDTAAMT_14",num$([F:ZECCCAB]ZELEFAC(14))) From ZXML
    Call XML_LINEA("SOH_BPAADD",[F:ZECCCAB]ZDIR) From ZXML
    Call XML_LINEA("SOH_MDL",num$([F:ZECCCAB]ZMODTRANS)) From ZXML
    Call XML_LINEA("SOH_BPTNUM",[F:ZECCCAB]ZTRANS) From ZXML
    Call XML_LINEA("SOH_ZNUMDOC",[F:ZECCCAB]ZNUMDOC) From ZXML
    Call XML_LINEA("SOH_ZSERDOC",[F:ZECCCAB]ZSERDOC) From ZXML
    Call XML_LINEA("SOH_ZDAT",mid$(num$([F:ZECCCAB]ZDAT),7,4)+"-"+mid$(num$([F:ZECCCAB]ZDAT),4,2)+"-"+mid$(num$([F:ZECCCAB]ZDAT),1,2)) From ZXML
    Call XML_LINEA("SOH_ZNUMPEDEECC",[F:ZECCCAB]ZORIGEN) From ZXML
    Call XML_LINEA("SOH_VACBPR",[F:ZECCCAB]ZREGIMP) From ZXML

    #Extraemos el régimen de impuesto del cliente asignado a la factura de venta
    ZREGIMP=""
    Filter [F:ZECCCLI] Where ZENLACE=[F:ZECCCAB]ZENLACE
    For [F:ZECCCLI]
      ZREGIMP=[F:ZECCCLI]ZREGIMP
    Next
    Filter [F:ZECCCLI]

    VAT0=""
    Filter [F:XTVB] Where VACBPR=ZREGIMP
    For [F:XTVB]
      VAT0=[F:XTVB]VAT
    Next
    Filter [F:XTVB]

    VACITM0=""
    Filter [F:XTVC] Where VAT=VAT0 and VACBPR=ZREGIMP
    For [F:XTVC]
      VACITM0=[F:XTVC]VACITM
    Next
    Filter [F:XTVC]

    #Abrimos las líneas
    Filter [F:ZECCLIN] Where 1=1 and ZSERDOC=[F:ZECCCAB]ZSERDOC and ZNUMDOC=[F:ZECCCAB]ZNUMDOC
    For [F:ZECCLIN]
      Call XML_ABRE_ETIQUETA("L") From ZXML
      Call XML_LINEA("SOQ_ITMREF",[F:ZECCLIN]ZITMREF) From ZXML
      Call XML_LINEA("SOP_ITMDES",[F:ZECCLIN]ZITMDES) From ZXML
      Call XML_LINEA("SOP_SAU","UN") From ZXML
      Call XML_LINEA("SOQ_QTY",num$([F:ZECCLIN]ZQTY)) From ZXML
      Call XML_LINEA("SOP_GROPRI",num$([F:ZECCLIN]ZGROPRI)) From ZXML
      Call XML_LINEA("SOP_DISCRGVAL1",num$([F:ZECCLIN]ZDTO1)) From ZXML
      Call XML_LINEA("SOP_DISCRGVAL2",num$([F:ZECCLIN]ZDTO2)) From ZXML
      Call XML_LINEA("SOP_DISCRGVAL3",num$([F:ZECCLIN]ZDTO3)) From ZXML
      Call XML_LINEA("SOQ_SOPLIN",num$([F:ZECCLIN]ZNLINX3)) From ZXML
      Call XML_LINEA("SOP_SOPLIN",num$([F:ZECCLIN]ZNLINX3)) From ZXML
      Call XML_LINEA("SOQ_ZSERDOC",[F:ZECCLIN]ZSERDOC) From ZXML
      Call XML_LINEA("SOQ_ZNUMDOC",[F:ZECCLIN]ZNUMDOC) From ZXML
      Call XML_LINEA("SOQ_ZDAT",mid$(num$([F:ZECCCAB]ZDAT),7,4)+"-"+mid$(num$([F:ZECCCAB]ZDAT),4,2)+"-"+mid$(num$([F:ZECCCAB]ZDAT),1,2)) From ZXML
      Call XML_LINEA("SOQ_ZNUMLIN",num$([F:ZECCLIN]ZNLINECC)) From ZXML

      Call XML_CIERRA_ETIQUETA("L") From ZXML

      [F:ZECCLIN]ZFICHERO="ZSOHECC_"+[F:ZECCCAB]ZSERDOC+"_"+[F:ZECCCAB]ZNUMDOC+"_"+format$("D:YYYYMMDD",date$)
      [F:ZECCLIN]ZESTADO=2
      Rewrite [F:ZECCLIN]
    Next
    Filter [F:ZECCLIN]

    Call XML_CIERRA_ETIQUETA("E") From ZXML
    Call XML_FIN("ZSOHECC") From ZXML
    Openo Using [TIF]

    [F:ZECCCAB]ZFICHERO="ZSOHECC_"+[F:ZECCCAB]ZSERDOC+"_"+[F:ZECCCAB]ZNUMDOC+"_"+format$("D:YYYYMMDD",date$)
    [F:ZECCCAB]ZESTADO=2
    Rewrite [F:ZECCCAB]
  Next
  Filter [F:ZECCCAB]

Return

$CREAR_ABONOS_VENTA
  Local Char WOUT(250)
  Local Char REQUEST(255)
  Local Integer CABCREADA
  Local Char ZBPR(GLONBPR)
  Local Char ZBPRPAG(GLONBPR)
  Local Char ZPLANTAX3(GLONFCY)
  Local Char VACITM0(GLONTVI)
  Local Char VACITM1(GLONTVI)
  Local Char VACITM2(GLONTVI)

  Local Char VAT0(GLONVAT)
  Local Char VAT1(GLONVAT)
  Local Char VAT2(GLONVAT)

  Local Integer ENCONTRADO

  Local Integer USARWS
  Local Integer NUMLIN

  Local Integer GESLOT
  Local Integer GESSER
  Local Char NUMFACORI(30)

  Local Integer NOFACORI

  Local Integer NUMFIL
  Local Integer OKFIL
  Local Integer ERFIL

  Local Integer WSTOM
  Local Integer WARTLOTSER

  Local Char WNUMFACORI(GLONVCR)
  Local Char WNUMENT(GLONVCR)
  Local Integer WNUMLINENT
  Local Char WNUMLOTE(GLONLOT)
  Local Char WSERNUM(GLONSER)

  Local Char WHIJOS(GLONITM)(0..50)
  Local Decimal WCANT(0..50)
  Local Char WDESC(GLONDES)(0..50)
  Local Integer WFLGSTK(0..50)
  Local Integer WGESLOT(0..50)
  Local Integer WGESSER(0..50)
  Local Integer WSTOMGTCOD(0..50)
  Local Integer WSTOMGTCODPADRE(0..50)

  Local Integer WMOVSTOCK

  Local Integer WCONTA
  Local Integer WVUELTAS
  Local Integer CREARDEV

  Local Char WNUMDEV(GLONVCR)
  Local Integer WEMPDEV

  Append PROABO, '#######################################################'+chr$(10)
  Append PROABO, '## Proceso de importación de ABONOS DE VENTA ##########'+chr$(10)+chr$(10)
  #Append PROABO, '#######################################################'+chr$(10)+chr$(10)

  USARWS=2

  Filter [F:ZECCCAB] Where 1=1 and (ZTIPMOV=3) and ZESTADO=0 and ZBPR<>''
  For [F:ZECCCAB]
    #Actualizamos el campo ZCOMP de la tabla MATCH para indicar que hay que comparar esos ficheros
    Update [F:ZECCMAT] Where 1=1 and ZNUMDOC=[F:ZECCCAB]ZNUMDOC and ZTIPDOC='3' With ZCOMP=2

    NUMFIL=NUMFIL+1
    WNUMDEV=""
    CREARDEV=1

    NUMLIN=0
    WEMPDEV=1

    CABCREADA=1
    ZBPR=""
    ZBPRPAG=""
    Filter [F:ZECCCLI] Where 1=1 and ZFICHORI=[F:ZECCCAB]ZFICHORI
    For [F:ZECCCLI]
      ZBPR=[F:ZECCCLI]ZIDCLISA
      ZBPRPAG=ZBPR
    Next
    Filter [F:ZECCCLI]

    #Extraemos la divisa del cliente
    ZVAC=""
    ZCUR=""
    Read [XBPC]BPC0=[F:ZECCCAB]ZBPRPAG
    If fstat=0 Then
       ZCUR = [XBPC]CUR
       ZVAC = [XBPC]VACBPR
    Endif

    If ZCUR="" Then
      ZCUR="EUR"
    Endif


    #Abrimos todos los artículos del abono para comprobar si existe alguno que no tiene factura origen.
    WARTLOTSER=1
    WSTOMGTCODPADRE=1

    Filter [F:WZECCLIN] Where 1=1 and ZFICHORI=[F:ZECCCAB]ZFICHORI
    For [F:WZECCLIN]
      #If GUSER = "ADMIN" : Infbox "AQUI 1" : Endif  #MS
      NOFACORI=1
      #Comprobamos si el artículo tiene gestión de lote y gestión de número de serie
      GESLOT=0
      GESSER=0
      Read [F:ITM]ITM0=[F:WZECCLIN]ZITMREF
      If fstat=0 Then
        GESLOT=[F:ITM]LOTMGTCOD
        GESSER=[F:ITM]SERMGTCOD
        WSTOMGTCODPADRE=[F:ITM]STOMGTCOD
      Else
        GESSER=-1
        Break
      Endif

      If GESSER<>1 or GESLOT<>1 Then
        WARTLOTSER=2
        WNUMFACORI=""

        Filter [F:ZSIH] Where vireblc(ZNUMPEDEECC,2)=[F:ZECCCAB]ZORIGEN
        For [F:ZSIH]
          WNUMFACORI=[F:ZSIH]NUM
          NOFACORI=2
        Next
        Filter [F:ZSIH]

        If NOFACORI=1 Then
          #Break
        Endif
      Else
        NOFACORI=2
      Endif
    Next
    Filter [F:WZECCLIN]

    #Extraemos el nº de entrega en el caso que se trate de artículos con lote y con factura origen
    Filter [F:BOD] Where ITMREF=[F:WZECCLIN]ZITMREF
    For [F:BOD]
      Read [ITM]ITM0=[F:BOD]CPNITMREF
      If [ITM]LOTMGTCOD<>1 or [ITM]SERMGTCOD<>1 Then
        Filter [F:ZSIH] Where vireblc(ZNUMPEDEECC,2)=[F:ZECCCAB]ZORIGEN
        For [F:ZSIH]
          WNUMFACORI=[F:ZSIH]NUM
          NOFACORI=2
        Next
        Filter [F:ZSIH]
      Endif
    Next

    If WNUMFACORI<>"" Then
      Filter [ZSID] Where NUM=WNUMFACORI
      For [ZSID]
        WNUMENT=[F:ZSID]SDHNUM
        Break
      Next
      Filter [ZSID]
    Endif


    # Definicion de variables del webservice
    #Los abonos con gestión de número de serie y con factura de venta origen creada
   If (WARTLOTSER=1 or (WARTLOTSER=2 and NOFACORI=2)) and GESSER>=0 Then

      #############################################################
      ### FACTURA DE DEVOLUCIÓN DE VENTA
      #############################################################
      Gosub DEFVAR From WJZSRH
      WW_ACTION="CREATE"
      Filter [F:ZECCLIN] Where 1=1 and ZFICHORI=[F:ZECCCAB]ZFICHORI
      For [F:ZECCLIN]
        #If GUSER = "ADMIN" : Infbox "AQUI 2" : Endif  #MS

        #Extraemos los elementos hijos de un padre
        #El primer elemento del array siempre será el padre
        Dela 0,50 WHIJOS
        Dela 0,50 WCANT
        Dela 0,50 WFLGSTK
        Dela 0,50 WGESLOT
        Dela 0,50 WGESSER
        Dela 0,50 WSTOMGTCOD

        CREARDEV=1
        WCONTA=1
        WHIJOS(0)=[F:ZECCLIN]ZITMREF
        WCANT(0)=[F:ZECCLIN]ZQTY
        WDESC(0)=[F:ZECCLIN]ZITMDES
        WFLGSTK(0)=WARTLOTSER
        Read [ITM]ITM0=[F:ZECCLIN]ZITMREF
        GESLOT=[ITM]LOTMGTCOD
        GESSER=[ITM]SERMGTCOD

        WGESLOT(0)=GESLOT
        WGESSER(0)=GESSER
        WSTOMGTCOD(0)=WSTOMGTCODPADRE
        Filter [F:BOD] Where ITMREF=WHIJOS(0)
        For [F:BOD]
          WHIJOS(WCONTA)=[F:BOD]CPNITMREF
          WCANT(WCONTA)=[F:BOD]BOMQTY

          Read [ITM]ITM0=[F:BOD]CPNITMREF
          WDESC(WCONTA)=[ITM]ITMDES1
          WSTOMGTCOD(WCONTA)=[ITM]STOMGTCOD
          If [ITM]LOTMGTCOD<>1 or [ITM]SERMGTCOD<>1 Then
            WFLGSTK(WCONTA)=2
            CREARDEV=2
          Else
            WFLGSTK(WCONTA)=1
          Endif

          WCONTA=WCONTA+1
        Next
        Filter [F:BOD]

        If WGESLOT(0)<>1 or WGESSER(0)<>1 Then
          CREARDEV=2
        Endif


        If CREARDEV=2 Then
          WEMPDEV=2
          ### WebService ZSRH ( Devolucion ) ###


          #Existe un artículo con número de serie
          #Vamos a crear la devolución
          For WVUELTAS=0 To WCONTA-1

            #SRHNUM_A= WNUMDEV
            STOFCY_A=[F:ZECCCAB]ZFCYA
            SRHTYP_A= "SRN"
            ENTRTNDAT_A= [F:ZECCCAB]ZDAT

            BPCORD_A=ZBPR
            BPAADD_A= [F:ZECCCAB]ZDIR

            BPCINV_B=ZBPR

            ZSERDOC_A=[F:ZECCCAB]ZSERDOC
            ZNUMDOC_A=[F:ZECCCAB]ZNUMDOC
            ZDAT_A=[F:ZECCCAB]ZDAT
            ZNUMPEDEECC_A=[F:ZECCCAB]ZORIGEN

            NUMLIN+=1
            NBLIG_1=NUMLIN

            # Lectura del articulo
            Read[ITM]ITM0 = WHIJOS(WVUELTAS)

            ITMREF_1(NUMLIN-1) = WHIJOS(WVUELTAS)
            ITMDES_1(NUMLIN-1) = WDESC(WVUELTAS)
            SAU_1(NUMLIN-1) = "UN"
            EXTQTY_1(NUMLIN-1) = WCANT(WVUELTAS)
            QTY_1(NUMLIN-1) = WCANT(WVUELTAS)
            SAUSTUCOE_1(NUMLIN-1) = [ITM]SAUSTUCOE
            STU_1(NUMLIN-1) = [ITM]STU
            DLVQTY_1(NUMLIN-1) = 0
            NETPRI_1(NUMLIN-1)=[F:ZECCLIN]ZGROPRI
            RTNREN_1(NUMLIN-1) = "NCF"
            DETRTNDAT_1(NUMLIN-1) = [F:ZECCCAB]ZDAT

            If WSTOMGTCOD(WVUELTAS)=1 Then
              RTNSTOUPD_1(NUMLIN-1) = 1
            Else
              RTNSTOUPD_1(NUMLIN-1) = 2
            Endif

            If WGESLOT(WVUELTAS)<>1 or WGESSER(WVUELTAS)<>1 Then
              #Extraemos el nº de serie y el número de lote.
              WNUMLOTE=""
              WSERNUM=""
              Filter [F:STJ] Where ITMREF=WHIJOS(WVUELTAS) and VCRNUM=WNUMENT
              For [F:STJ]
                WNUMLOTE=[F:STJ]LOT
                WSERNUM=[F:STJ]SERNUM
                Break
              Next
              Filter [F:STJ]

              If vireblc(WNUMLOTE,2)<>"" Then
                LOT_1(NUMLIN-1)=WNUMLOTE
              Else
                LOT_1(NUMLIN-1)="ABO"+mid$(num$([F:ZECCLIN]ZDAT),7,4)+mid$(num$([F:ZECCLIN]ZDAT),4,2)+mid$(num$([F:ZECCLIN]ZDAT),1,2)
                #LOT_1(NUMLIN-1)=""
              Endif
              If vireblc(WSERNUM,2)<>"" Then
                SERNUM_1(NUMLIN-1)=WSERNUM
                SERNUMF_1(NUMLIN-1)=WSERNUM
              Else
                SERNUM_1(NUMLIN-1)=""
              Endif
            Endif
            STA_1(NUMLIN-1) = "A"
            #LOT_1(NUMLIN-1) = [ZTD]LOTNUM
            #SERNUM_1(NUMLIN-1) = [ZTD]SERNUM
            #SERNUMF_1(NUMLIN-1) = [ZTD]SERNUM
            PRIORD_1(NUMLIN-1) = 0
            RTNINVUPD_1(NUMLIN-1) = 1
            RTNCNOFLG_1(NUMLIN-1) = 2

            ZSERDOC_1(NUMLIN-1) = [F:ZECCLIN]ZSERDOC
            ZNUMDOC_1(NUMLIN-1) = [F:ZECCLIN]ZNUMDOC
            ZDAT_1(NUMLIN-1) = [F:ZECCLIN]ZDAT
            ZNUMLIN_1(NUMLIN-1) = [F:ZECCLIN]ZNLINECC
          Next

        Endif



      Next
      Filter [F:ZECCLIN]

      If WEMPDEV=2 Then
        Gosub WEBSERV From WJZSRH
          Call ECR_TRACE(mess(218,123,1)+" : "+num$(WW_OK)-"("+mess(WW_OK+3,2940,1)+")",0) From GESECRAN
        TEXTE="CREACION"

        Case WW_OK
           When 0   # ERROR
              WOK = 0

              PROERR=2
              ERFIL=ERFIL+1
              Call ECR_TRACE("----------------------------------------------------------------------",0) From GESECRAN
              Call ECR_TRACE("AZ>ABONO "+[F:ZECCCAB]ZNUMDOC+"/"+[F:ZECCCAB]ZORIGEN+"/"+[F:ZECCCAB]ZFICHORI,0) From GESECRAN
              Call ECR_TRACE("",0) From GESECRAN

              If WW_ZONE<>""
                Call ECR_TRACE(TEXTE-WW_IDENT-":"-mess(32,126,1)-WW_ZONE,0) From GESECRAN
              Endif
              #Update [F:ZICGM] Where ZSERDOC=[F:YYY]ZSERDOC and ZDAT=[F:YYY]ZDAT and ZBPR=[F:YYY]ZBPR and ZQTY<0 With ZESTADO=5,ZNUMINT=ZNUMINT+1
              Update [F:WZECCCAB] Where ZFICHORI=[F:ZECCCAB]ZFICHORI With ZESTADO=5
              Update [F:ZECCLIN] Where ZFICHORI=[F:ZECCCAB]ZFICHORI With ZESTADO=5

              Update [F:ZSRH] Where SRHNUM=SRHNUM_A With ZNUMPEDEECC=[F:ZECCCAB]ZORIGEN

              Append PROABO, '**** '+[F:ZECCCAB]ZFICHORI+': Error en la creación de la devolución '+[F:ZECCCAB]ZNUMDOC+'/'+[F:ZECCCAB]ZORIGEN+' ****'+chr$(10)

                #Call ECR_TRACE("ERROR:"-WW_MESS,0) From GESECRAN

              If WW_ZONE<>""
                  Call ECR_TRACE(TEXTE-WW_IDENT-":"-mess(32,126,1)-WW_ZONE,0) From GESECRAN
              Endif

            When 1  # OK
              WOK = 1
                 Call ECR_TRACE("DEVOLUCION Creada:" - SRHNUM_A,0) From GESECRAN

              WNUMDEV = SRHNUM_A

            When 9
              WOK = 0

              PROERR=2
              ERFIL=ERFIL+1
              Call ECR_TRACE("----------------------------------------------------------------------",0) From GESECRAN
              Call ECR_TRACE("AZ>ABONO "+[F:ZECCCAB]ZNUMDOC+"/"+[F:ZECCCAB]ZORIGEN+"/"+[F:ZECCCAB]ZFICHORI,0) From GESECRAN
              Call ECR_TRACE("",0) From GESECRAN

              Update [F:WZECCCAB] Where ZFICHORI=[F:ZECCCAB]ZFICHORI With ZESTADO=5
              Update [F:ZECCLIN] Where ZFICHORI=[F:ZECCCAB]ZFICHORI With ZESTADO=5

              Append PROABO, '**** '+[F:ZECCCAB]ZFICHORI+': Error en la creación de la devolución '+[F:ZECCCAB]ZNUMDOC+'/'+[F:ZECCCAB]ZORIGEN+' ****'+chr$(10)

              #[F:ZECCCAB]ZESTADO=5

              IMPSTA=1
              Call ECR_TRACE(mess(221,123,1),0) From GESECRAN

        Endcase
      Endif


    # Definicion de variables del webservice
    #Sólo se crean los abonos que tengan artículos sin gestión de lote ni serie
    #Los abonos con gestión de número de serie y con factura de venta origen creada

      NUMLIN=0
      CREARDEV=1
      #############################################################
      ### FACTURA DE ABONO DE VENTA
      #############################################################

      Gosub DEFVAR From WJZABO
      WW_ACTION="CREATE"

      Filter [F:ZECCLIN] Where 1=1 and ZFICHORI=[F:ZECCCAB]ZFICHORI
      For [F:ZECCLIN]
      #If GUSER = "ADMIN" : Infbox "AQUI 3" : Endif  #MS
      #Extraemos los elementos hijos de un padre
        #El primer elemento del array siempre será el padre
        Dela 0,50 WHIJOS
        Dela 0,50 WCANT
        Dela 0,50 WFLGSTK
        Dela 0,50 WGESLOT
        Dela 0,50 WGESSER
        Dela 0,50 WSTOMGTCOD

        WMOVSTOCK=1
        WCONTA=1
        WHIJOS(0)=[F:ZECCLIN]ZITMREF
        WCANT(0)=[F:ZECCLIN]ZQTY
        WDESC(0)=[F:ZECCLIN]ZITMDES
        WFLGSTK(0)=WARTLOTSER

        Read [ITM]ITM0=[F:ZECCLIN]ZITMREF
        GESLOT=[ITM]LOTMGTCOD
        GESSER=[ITM]SERMGTCOD

        WGESLOT(0)=GESLOT
        WGESSER(0)=GESSER
        WSTOMGTCOD(0)=WSTOMGTCODPADRE

        Filter [F:BOD] Where ITMREF=WHIJOS(0)
        For [F:BOD]
          WHIJOS(WCONTA)=[F:BOD]CPNITMREF
          WCANT(WCONTA)=[F:BOD]BOMQTY

          Read [ITM]ITM0=[F:BOD]CPNITMREF
          WDESC(WCONTA)=[ITM]ITMDES1
          WSTOMGTCOD(WCONTA)=[ITM]STOMGTCOD
          If [ITM]LOTMGTCOD<>1 or [ITM]SERMGTCOD<>1 Then
            WFLGSTK(WCONTA)=2
            CREARDEV=2
          Else
            WMOVSTOCK=2
            WFLGSTK(WCONTA)=1
          Endif

          WCONTA=WCONTA+1
        Next
        Filter [F:BOD]

        If WGESLOT(0)<>1 or WGESSER(0)<>1 Then
          WFLGSTK(WCONTA)=2
          CREARDEV=2
        Endif

        #If WARTLOTSER=2 Then
        #NUMLIN=0
        #If (WARTLOTSER=2 and WNUMDEV="") Then
        #  Goto SIGUIENTE
        #Endif

        For WVUELTAS=0 To WCONTA-1  #MS 20210416 ANTES WVUELTAS=0
          #Comprobamos si el artículo tiene gestión de lote y gestión de número de serie
          GESLOT=0
          GESSER=0
          WSTOM=0
          Read [F:ITM]ITM0=WHIJOS(WVUELTAS)
          If fstat=0 Then
            GESLOT=[F:ITM]LOTMGTCOD
            GESSER=[F:ITM]SERMGTCOD
            WSTOM=[F:ITM]STOMGTCOD
          Endif

          NUMLIN+=1
          NBLIG_3=NUMLIN

          SALFCY_A=[F:ZECCCAB]ZFCYA
          SIVTYP_A=[F:ZECCCAB]ZSERDOC
          INVDAT_A= [F:ZECCCAB]ZDAT
          ZSERDOC_A=[F:ZECCCAB]ZSERDOC
          ZNUMDOC_A=[F:ZECCCAB]ZNUMDOC
          ZDAT_A=[F:ZECCCAB]ZDAT
          ZNUMPEDEECC_A=[F:ZECCCAB]ZORIGEN

          BPCINV_A=ZBPR

          BPRPAY_B=ZBPRPAG
          CUR_A=ZCUR
          BPAINV_A=[F:ZECCCAB]ZDIR
          BPAADD_B=[F:ZECCCAB]ZDIR
          STARPT_B=1

#          If WARTLOTSER=2 Then
#           STOMVTFLG_B=1
#          Else
#           STOMVTFLG_B=2
#          Endif



          If CREARDEV=2 Then
            STOMVTFLG_B=1
          Else
            STOMVTFLG_B=2
          Endif
          STOFCY_B=[F:ZECCCAB]ZFCYA
          VACBPR_B=[F:ZECCCAB]ZREGIMP
          PTE_C=[F:ZECCCAB]ZCONDPAGO
          PRITYP_B=2

          NBFAC_2=15
          INVDTAAMT_2(0)=[F:ZECCCAB]ZELEFAC(0)
          INVDTAAMT_2(1)=[F:ZECCCAB]ZELEFAC(1)
          INVDTAAMT_2(2)=[F:ZECCCAB]ZELEFAC(2)
          INVDTAAMT_2(3)=[F:ZECCCAB]ZELEFAC(3)
          INVDTAAMT_2(4)=[F:ZECCCAB]ZELEFAC(4)
          INVDTAAMT_2(5)=[F:ZECCCAB]ZELEFAC(5)
          INVDTAAMT_2(6)=[F:ZECCCAB]ZELEFAC(6)
          INVDTAAMT_2(7)=[F:ZECCCAB]ZELEFAC(7)
          INVDTAAMT_2(8)=[F:ZECCCAB]ZELEFAC(8)
          INVDTAAMT_2(9)=[F:ZECCCAB]ZELEFAC(9)
          INVDTAAMT_2(10)=[F:ZECCCAB]ZELEFAC(10)
          INVDTAAMT_2(11)=[F:ZECCCAB]ZELEFAC(11)
          INVDTAAMT_2(12)=[F:ZECCCAB]ZELEFAC(12)
          INVDTAAMT_2(13)=[F:ZECCCAB]ZELEFAC(13)
          INVDTAAMT_2(14)=[F:ZECCCAB]ZELEFAC(14)

          ITMREF_3(NUMLIN-1) = WHIJOS(WVUELTAS)
          ITMDES_3(NUMLIN-1) = WDESC(WVUELTAS)
          SAU_3(NUMLIN-1)="UN"
          QTY_3(NUMLIN-1) = WCANT(WVUELTAS)
          #QTY_3(NUMLIN-1) = 1

          If WVUELTAS=0 Then
            GROPRI_3(NUMLIN-1) = [F:ZECCLIN]ZGROPRI
          Else
            GROPRI_3(NUMLIN-1) = 0
            NETPRI_3(NUMLIN-1) = 0
            AMTLIN_3(NUMLIN-1)=0
          Endif
          If WVUELTAS=0 Then
            DISCRGVAL1_3(NUMLIN-1) = [F:ZECCLIN]ZDTO1
            DISCRGVAL2_3(NUMLIN-1) = [F:ZECCLIN]ZDTO2
            DISCRGVAL3_3(NUMLIN-1) = [F:ZECCLIN]ZDTO3
          Else
            DISCRGVAL1_3(NUMLIN-1) = 100
          Endif

          ZSERDOC_3(NUMLIN-1) = [F:ZECCLIN]ZSERDOC
          ZNUMDOC_3(NUMLIN-1) = [F:ZECCLIN]ZNUMDOC
          ZDAT_3(NUMLIN-1) = [F:ZECCLIN]ZDAT
          ZNUMLIN_3(NUMLIN-1) = [F:ZECCLIN]ZNLINECC

         #ms  Infbox num$(NUMLIN)
        #  If GUSER = "ADMIN" : Infbox "AQUI 4" : Endif  #MS
          If WSTOM=1 Then
           #If GUSER = "ADMIN" : Infbox "AQUI BIS 4" : Endif  #MS
           #If GUSER = "ADMIN" : Infbox num$(maskcou) : Endif  #MS
            STOMGTCOD_3(NUMLIN-1)=1
          Else
            If WFLGSTK(WVUELTAS)=2 Then
             #If GUSER = "ADMIN" : Infbox "AQUI 5" : Endif  #MS
              STOMGTCOD_3(NUMLIN-1)=1
            Else
             #If GUSER = "ADMIN" : Infbox "AQUI 6" : Endif  #MS
             #If GUSER = "ADMIN" : Infbox(num$(NUMLIN)): Endif
              STOMGTCOD_3(NUMLIN-1)=2
            Endif
            If WGESLOT(WVUELTAS)<>1 Then
              #Extraemos el nº de serie y el número de lote.
              WNUMLOTE=""
              WSERNUM=""
              Filter [F:STJ] Where ITMREF=WHIJOS(WVUELTAS) and VCRNUM=WNUMENT
              For [F:STJ]
                WNUMLOTE=[F:STJ]LOT
                WSERNUM=[F:STJ]SERNUM
                Break
              Next
              Filter [F:STJ]

              #Infbox(WNUMLOTE)
                If vireblc(WNUMLOTE,2)<>"" Then
                  LOT_3(NUMLIN-1)=WNUMLOTE
                Else
                  LOT_3(NUMLIN-1)="ABO"+mid$(num$([F:ZECCLIN]ZDAT),7,4)+mid$(num$([F:ZECCLIN]ZDAT),4,2)+mid$(num$([F:ZECCLIN]ZDAT),1,2)
                Endif
                If vireblc(WSERNUM,2)<>"" Then
                  #SERNUM_3(NUMLIN-1)=WSERNUM
                  #SERNUMF_3(NUMLIN-1)=WSERNUM

                Else
                  #SERNUM_3(NUMLIN-1)=""
                Endif
            Endif
          Endif
        Next
        #Endif
      Next
      Gosub WEBSERV From WJZABO
      #Gosub DETAILRES From WJZABO
      #Call TEST From WJZABO

      Call ECR_TRACE(mess(218,123,1)+" : "+num$(WW_OK)-"("+mess(WW_OK+3,2940,1)+")",0) From GESECRAN
      TEXTE="CREACION"

      Case WW_OK

        When 0
          PROERR=2
          ERFIL=ERFIL+1
          Call ECR_TRACE("----------------------------------------------------------------------",0) From GESECRAN
          Call ECR_TRACE("AZ>ABONO "+[F:ZECCCAB]ZNUMDOC+"/"+[F:ZECCCAB]ZORIGEN+"/"+[F:ZECCCAB]ZFICHORI,0) From GESECRAN
          Call ECR_TRACE("",0) From GESECRAN

          If WW_ZONE<>""
            Call ECR_TRACE(TEXTE-WW_IDENT-":"-mess(32,126,1)-WW_ZONE,0) From GESECRAN
          Endif
          #Update [F:ZICGM] Where ZSERDOC=[F:YYY]ZSERDOC and ZDAT=[F:YYY]ZDAT and ZBPR=[F:YYY]ZBPR and ZQTY<0 With ZESTADO=5,ZNUMINT=ZNUMINT+1
          Update [F:WZECCCAB] Where ZFICHORI=[F:ZECCCAB]ZFICHORI With ZESTADO=5
          Update [F:ZECCLIN] Where ZFICHORI=[F:ZECCCAB]ZFICHORI With ZESTADO=5

          Append PROABO, '**** '+[F:ZECCCAB]ZFICHORI+': Error en la creación del abono de venta '+[F:ZECCCAB]ZNUMDOC+'/'+[F:ZECCCAB]ZORIGEN+' ****'+chr$(10)

          #[F:ZECCCAB]ZESTADO=5

        When 1
          OKFIL=OKFIL+1
          Call ECR_TRACE("----------------------------------------------------------------------",0) From GESECRAN
          Call ECR_TRACE("AZ>ABONO "+[F:ZECCCAB]ZNUMDOC+"/"+[F:ZECCCAB]ZORIGEN+"/"+[F:ZECCCAB]ZFICHORI,0) From GESECRAN
          Call ECR_TRACE("",0) From GESECRAN

          Call ECR_TRACE(TEXTE-WW_IDENT-":"-"OK",0) From GESECRAN

          Update [F:WZECCCAB] Where ZFICHORI=[F:ZECCCAB]ZFICHORI With ZESTADO=4
          Update [F:ZECCLIN] Where ZFICHORI=[F:ZECCCAB]ZFICHORI With ZESTADO=4
          Update [F:ZSID] Where NUM=[F:SIH]NUM With ZGENVENC=1
          Update [F:ZSIH] Where NUM=[SIH]NUM With ZFICHORI=[F:ZECCCAB]ZFICHORI

          # Actualizamos las lineas SINVOICEV de la factura de abono
          Update [SIV] Where NUM = NUM_A With SIHORINUM = WNUMDEV,SIHORI = 6,SIHORITYP = 3

          # Actualizamos las lineas SINVOICED de la factura de abono
          NUMLIN = 1
          Filter[SID] Where NUM = NUM_A
          For[SID]
             [SID]SRHNUM = WNUMDEV
             [SID]SRDLIN = NUMLIN * 1000
             Rewrite[SID]
             NUMLIN = NUMLIN + 1
          Next
          Filter[SID]

        When 9
          PROERR=2
          ERFIL=ERFIL+1
          Call ECR_TRACE("----------------------------------------------------------------------",0) From GESECRAN
          Call ECR_TRACE("AZ>ABONO "+[F:ZECCCAB]ZNUMDOC+"/"+[F:ZECCCAB]ZORIGEN+"/"+[F:ZECCCAB]ZFICHORI,0) From GESECRAN
          Call ECR_TRACE("",0) From GESECRAN

          Update [F:WZECCCAB] Where ZFICHORI=[F:ZECCCAB]ZFICHORI With ZESTADO=5
          Update [F:ZECCLIN] Where ZFICHORI=[F:ZECCCAB]ZFICHORI With ZESTADO=5

          Append PROABO, '**** '+[F:ZECCCAB]ZFICHORI+': Error en la creación del abono de venta '+[F:ZECCCAB]ZNUMDOC+'/'+[F:ZECCCAB]ZORIGEN+' ****'+chr$(10)

          #[F:ZECCCAB]ZESTADO=5

          IMPSTA=1
          Call ECR_TRACE(mess(221,123,1),0) From GESECRAN
      Endcase
    Else
      PROERR=2
      ERFIL=ERFIL+1
      Call ECR_TRACE("----------------------------------------------------------------------",0) From GESECRAN
      Call ECR_TRACE("AZ>ABONO "+[F:ZECCCAB]ZNUMDOC+"/"+[F:ZECCCAB]ZORIGEN+"/"+[F:ZECCCAB]ZFICHORI,0) From GESECRAN
      Call ECR_TRACE("",0) From GESECRAN

      Update [F:WZECCCAB] Where ZFICHORI=[F:ZECCCAB]ZFICHORI With ZESTADO=5
      Update [F:ZECCLIN] Where ZFICHORI=[F:ZECCCAB]ZFICHORI With ZESTADO=5

      Append PROABO, '**** '+[F:ZECCCAB]ZFICHORI+': Error en la creación del abono de venta '+[F:ZECCCAB]ZNUMDOC+'/'+[F:ZECCCAB]ZORIGEN+' ****'+chr$(10)
      Append PROABO, '**** '+[F:ZECCCAB]ZFICHORI+': No se han encontrado los números de serie de los artículos incluidos en la factura ****'+chr$(10)

      #[F:ZECCCAB]ZESTADO=5

      IMPSTA=1
    Endif
SIGUIENTE:
  Next
  #Rewrite [F:ZECCCAB]
  Filter [F:ZECCCAB]

  Append PROABO, 'Abonos leídos: '+num$(NUMFIL)+chr$(10)
  Append PROABO, 'Abonos creados: '+num$(OKFIL)+chr$(10)
  Append PROABO, 'Abonos con error: '+num$(ERFIL)+chr$(10)+chr$(10)

  If ERFIL>0 Then
    Append PROABO, '**** CONSULTE EL FICHERO DE TRAZA ADJUNTO PARA VER EL DETALLE DEL ERROR ****'+chr$(10)+chr$(10)
  Endif

Return

