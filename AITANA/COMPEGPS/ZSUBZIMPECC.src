$VALIDAR_DOCUMENTOS
  Local Char CODFAC(30)
  Local Decimal IMPTOTAL
  Local Integer WTIPO
  Local Integer WVALID
  Local Integer NUMFIL
  Local Integer OKFIL
  Local Integer ERFIL


  Append PROVAL, '#######################################################'+chr$(10)
  Append PROVAL, '## Proceso de validación de facturas ##################'+chr$(10)+chr$(10)


  Filter [F:ZECCMAT] Where 1=1 and ZCOMP=2
  For [F:ZECCMAT]
    NUMFIL=NUMFIL+1
    If [F:ZECCMAT]ZTIPDOC<>'1' Then
      CODFAC=""
      IMPTOTAL=0
      WVALID=0
      WTIPO=0
      Filter [F:ZSIH] Where 1=1 and ZNUMDOC=[F:ZECCMAT]ZNUMDOC
      For [F:ZSIH]
        CODFAC=[F:ZSIH]NUM
        IMPTOTAL=[F:ZSIH]AMTATI
        WVALID=[F:ZSIH]STA
        WTIPO=[F:ZSIH]INVTYP
      Next
      Filter [F:ZSIH]

      If IMPTOTAL<>[F:ZECCMAT]ZTOTCONIMP Then
        ERFIL=ERFIL+1
        PROERR=2
        Append PROVAL,"**** Existen diferencias entre el documento de ECC "+[F:ZECCMAT]ZNUMDOC+"("+num$([F:ZECCMAT]ZTOTCONIMP)+") y el de X3 "+CODFAC+"("+num$(IMPTOTAL)+")"+chr$(10)
      Else
        #Validamos la factura
        If CODFAC<>"" and WVALID=1 Then
          If clalev([SI2]) Close Local File [SI2] Endif
          Gosub OUVRE From FUNCFMINV

          Call VALIDATION(2,CODFAC) From TRTVENFACV
          OKFIL=OKFIL+1
        Endif
      Endif
    Endif

  Next
  Filter [F:ZECCMAT]

  Append PROVAL, ""+chr$(10)+chr$(10)
  Append PROVAL, 'Documentos comprobados: '+num$(NUMFIL)+chr$(10)
  Append PROVAL, 'Documentos validados: '+num$(OKFIL)+chr$(10)
  Append PROVAL, 'Documentos con diferencias: '+num$(ERFIL)+chr$(10)+chr$(10)

Return


$COMPROBAR_MATCH
  Local Char CODFAC(30)
  Local Char CODPED(30)
  Local Decimal IMPTOTAL

  Local Integer NUMFIL
  Local Integer OKFIL
  Local Integer ERFIL

  Local Integer WVALID

  #FLOPR - V5.0 - 261118
  Local Integer WTIPO

  Append PROMAT, '#######################################################'+chr$(10)
  Append PROMAT, '## Proceso de comprobación del MATCH ##################'+chr$(10)+chr$(10)


  #Recorremos los registros que están marcados
  Filter [F:ZECCMAT] Where 1=1 and ZCOMP=2
  For [F:ZECCMAT]
    NUMFIL=NUMFIL+1

    If [F:ZECCMAT]ZTIPDOC<>'1' Then
      CODFAC=""
      IMPTOTAL=0
      WVALID=0
      WTIPO=0
      Filter [F:ZSIH] Where 1=1 and ZNUMDOC=[F:ZECCMAT]ZNUMDOC
      For [F:ZSIH]
        CODFAC=[F:ZSIH]NUM
        IMPTOTAL=[F:ZSIH]AMTATI
        WVALID=[F:ZSIH]STA
        #FLOPR - V5.0 - 261118 - Se guarda el tipo de factura
        WTIPO=[F:ZSIH]INVTYP
      Next
      Filter [F:ZSIH]

      If IMPTOTAL<>[F:ZECCMAT]ZTOTCONIMP Then
        #Comprobamos si la diferencia de descuadre es superior a 0.02 céntimos
        If abs(IMPTOTAL-[F:ZECCMAT]ZTOTCONIMP)>0.02 Then
          ERFIL=ERFIL+1
          PROERR=2
          Append PROMAT,"**** Existen diferencias entre el documento de ECC "+[F:ZECCMAT]ZNUMDOC+"("+num$([F:ZECCMAT]ZTOTCONIMP)+") y el de X3 "+CODFAC+"("+num$(IMPTOTAL)+")"+chr$(10)
        Else
          If WTIPO=1 Then
            #Realizamos la llamada al werbservice de las facturas de venta
            Gosub DEFVAR From WJZSIH

            WW_ACTION="MODIFY"
            WW_IDENT=CODFAC

            If IMPTOTAL-[F:ZECCMAT]ZTOTCONIMP<0 Then
              NBFAC_2=10
              INVDTAAMT_2(9)=abs(IMPTOTAL-[F:ZECCMAT]ZTOTCONIMP)
            Else
              NBFAC_2=11
              INVDTAAMT_2(10)=abs(IMPTOTAL-[F:ZECCMAT]ZTOTCONIMP)
            Endif
            Gosub WEBSERV From WJZSIH

            If clalev([SI2]) Close Local File [SI2] Endif

          Else
            #Realizamos la llamada al webservice de facturas de abono
            Gosub DEFVAR From WJZABO

            WW_ACTION="MODIFY"
            WW_IDENT=CODFAC

            If IMPTOTAL-[F:ZECCMAT]ZTOTCONIMP<0 Then
              NBFAC_2=10
              INVDTAAMT_2(9)=abs(IMPTOTAL-[F:ZECCMAT]ZTOTCONIMP)
            Else
              NBFAC_2=11
              INVDTAAMT_2(10)=abs(IMPTOTAL-[F:ZECCMAT]ZTOTCONIMP)
            Endif

            Gosub WEBSERV From WJZABO

            If clalev([SI2]) Close Local File [SI2] Endif

          Endif
        Endif
      Else
        # Validamos la factura
        If CODFAC<>"" and WVALID=1 Then
          If clalev([SI2]) Close Local File [SI2] Endif
          Gosub OUVRE From FUNCFMINV
          Call VALIDATION(2,CODFAC) From TRTVENFACV
        Endif

        OKFIL=OKFIL+1
      Endif

    Elsif [F:ZECCMAT]ZTIPDOC='1' Then
      CODPED=""
      IMPTOTAL=0
      Filter [F:ZSOH] Where 1=1 and ZNUMDOC=[F:ZECCMAT]ZNUMDOC
      For [F:ZSOH]
        CODPED=[F:ZSOH]SOHNUM
        IMPTOTAL=[F:ZSOH]ORDINVATI
      Next
      Filter [F:ZSIH]

      If IMPTOTAL<>[F:ZECCMAT]ZTOTCONIMP Then
        ERFIL=ERFIL+1
        PROERR=2
        Append PROMAT,"**** Existen diferencias entre el documento de ECC "+[F:ZECCMAT]ZNUMDOC+"("+num$([F:ZECCMAT]ZTOTCONIMP)+") y el de X3 "+CODPED+"("+num$(IMPTOTAL)+")"+chr$(10)
      Else
        OKFIL=OKFIL+1
      Endif
    Endif
  Next
  Filter [F:ZECCMAT]

  Append PROMAT, ""+chr$(10)+chr$(10)
  Append PROMAT, 'Documentos comprobados: '+num$(NUMFIL)+chr$(10)
  Append PROMAT, 'Documentos correctos: '+num$(OKFIL)+chr$(10)
  Append PROMAT, 'Documentos con error: '+num$(ERFIL)+chr$(10)+chr$(10)

Return
