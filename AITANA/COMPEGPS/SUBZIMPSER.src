#<AdxTL>@(#)0.0.0.0 $Revision$
# Fuente que gestiona
#    Ventana Diversos + Dialogo
#    Accion de tipo Proceso+Varios
#
# Al mostrar ventana dialogo   INIT  #  AVANT_PAR  #  INIT_DIA   #  TIT_DIA
#    Salir   SORTIE #
#    OK      CONTROLE  #  EXEC   #   TERMINE  #  SORTIE
$ACTION
#If GUSER="PALAU"  Infbox "Depurar   $ACTION=("+ACTION+")"   Endif
Case ACTION
When "INIT"        : Gosub INIT
When "CONTROLE"    : Gosub CONTROLE
When "EXEC"        : Gosub EXEC
When "TERMINE"     : Gosub TERMINE
Endcase
Return

$INIT
Return

$CONTROLE
Return

$EXEC
#If GUSER<>"PALAU"    Infbox   "En desarrollo   10-04-18"  :  Return    :   Endif
If GUSER="PALAU"    Infbox   "Depurar  $EXEC    SUBZIMPSER.src"  Endif
Gosub ABRIR_FIC
Gosub DEF_VAR
Gosub TRAZA_ABRIR
Gosub PROCESO
Gosub TRAZA_CERRAR
Return

$TERMINE
If NUMERRORES<1 or !GSERVEUR Return   Endif
Gosub ENVIAR_EMAIL
Return

$ABRIR_FIC
If !clalev([F:ZSERR]): Local File ZSERREG    [F:ZSERR]: Endif
If !clalev([F:XBPC]) : Local File BPCUSTOMER [F:XBPC] : Endif
If !clalev([F:XITM]) : Local File ITMMASTER  [F:XITM] : Endif
If !clalev([F:XSTJ]) : Local File STOJOU     [F:XSTJ] : Endif
Return

$DEF_VAR
Local Char    BD(1)       :    BD=func ZCOMUN.DATA_BASE_TIPO
Local Char    CTE(GLONBPR)
Local Char    ZMSG(250), RTRACE(250)
Local Integer LOUVTRC
Local Integer F, JJ, WOK, T, ZSTAT
Local Char    NOMFIC(250)
Local Char    A(250)(1..110)
Local Char    WRESULT(250)
Local Clbfile MENSAJE(0),MENSFIC(0)
Local Integer NUMERRORES
Local Char    TXT(250)(10)
# Usadas para sacar relacion de ficheros a importar
Local Char    ORDSYS(250)
Local Char    WDIR(250)
Local Char    RESULT(200)(9000)
Local Integer STAT
# Usadas para lectura/grabacion ficheros planos
adxifs=";"
adxirs=chr$(13)+chr$(10)
adxium=50 # ASCII
Return

$TRAZA_ABRIR
ZMSG="Importando Registro nº series"
If GSERVEUR
  Onerrgo ERRBATCH
  Call ECR_TRACE(ZMSG-"(Batch)",0) From GESECRAN
Else
  Call TEMPON(ZMSG) From GESECRAN
  If GTRACE=""
    LOUVTRC=1
    Call OUVRE_TRACE(ZMSG) From LECFIC
  Endif
Endif
RTRACE=GTRACE
Return

$PROCESO
#Leemos los ficheros generados que se encuentran dentro de la carpeta
Raz RESULT
WDIR="ECOMMERCE\ENTRADA"
ORDSYS = "dir /b "+filpath(WDIR,"","")+"\ZSERREG*.txt"
Call SYSTEME2 (adxmac(0),ORDSYS,"",STAT,RESULT) From ORDSYS
#Recorremos los ficheros leidos
For JJ=0 To dim(RESULT)-1
  If RESULT(JJ)=""   Break   Endif
  ZMSG="Importando datos de fichero "+RESULT(JJ)
  Call ECR_TRACE(ZMSG,0) From GESECRAN
  WOK=1
  NOMFIC= filpath(WDIR,"","") + "\"+RESULT(JJ)
  Openi NOMFIC Using [TIE]
  Gosub LEER
  While !ZSTAT
    Gosub LEER
  Wend
  Openi Using [TIE]
  #Movemos el fichero a la carpeta de tratados
  If WOK
    ZMSG="Importación OK. Fichero movido"
    Call ECR_TRACE(ZMSG,0) From GESECRAN
    Call MOVE(NOMFIC,filpath(WDIR+"\TRATADOS","","") + "\" + RESULT(JJ),STAT)    From ORDSYS
  Else
    ZMSG="Importación fallida. Fichero se procesará la siguiente vez"
    Call ECR_TRACE(ZMSG,1) From GESECRAN
    NUMERRORES+=1
  Endif
Next
Return

$LEER
Gosub LEER_REGISTRO
Gosub VALIDAR
Gosub GRABAR
Return

$VALIDAR
If !WOK   Return   Endif
If A(3)+A(7)=""   Return   Endif
# Validar Articulo
Read [F:XITM]ITM0=A(3)
If fstat<>0
  WOK=0
  ZMSG=A(3)-"articulo inexistente en X3"
  Call ECR_TRACE(ZMSG,1) From GESECRAN
  Append MENSFIC,RESULT(JJ)+"  "+ZMSG+chr$(10)+chr$(10)
  Return
Endif
# Validar Entrada  Articulo+Serie
Raz T,TXT:  F=-1
F+=1:TXT(F)="select count(*) "
F+=1:TXT(F)="from STOJOU "
F+=1:TXT(F)="where ITMREF_0='"+A(3)+"' and SERNUM_0='"+A(7)+"' and VCRTYP_0 in(6,15,17,19)"
For (Integer FRGT) From BD Sql TXT As [MYT2]
  T=[MYT2]FRGT
Next
If T<1
  WOK=0
  ZMSG=A(3)-A(7)-"articulo serie, no se ha encontrado mvto de entrada (6-Recp,17-Fra,19-EntVar ó 15-Fabric)"
  Call ECR_TRACE(ZMSG,1) From GESECRAN
  Append MENSFIC,RESULT(JJ)+"  "+ZMSG+chr$(10)+chr$(10)
Endif
# Validar cliente
A(5)=vireblc(A(5),2)
If A(5)<>""
  Read [F:XBPC]BPC0=A(5)
  If fstat<>0
    WOK=0
    ZMSG=A(5)-"cliente inexistente en X3"
    Call ECR_TRACE(ZMSG,1) From GESECRAN
    Append MENSFIC,RESULT(JJ)+"  "+ZMSG+chr$(10)+chr$(10)
    Return
  Endif
  CTE=A(5)
Else
  A(9)=vireblc(A(9),2)
  If A(9)=""
    WOK=0
    ZMSG="Cliente X3 y Magento vacios"
    Call ECR_TRACE(ZMSG,1) From GESECRAN
    Append MENSFIC,RESULT(JJ)+"  "+ZMSG+chr$(10)+chr$(10)
    Return
  Else
  Filter [F:XBPC]
  Filter [F:XBPC] Where ZCLIECC=A(9)
  For [F:XBPC]
    CTE=[F:XBPC]BPCNUM
    Break
  Next
  Filter [F:XBPC]
  Endif
Endif
# Validar Salida   cliente+Articulo+Serie
Raz T,TXT:  F=-1
F+=1:TXT(F)="select count(*) "
F+=1:TXT(F)="from STOJOU "
F+=1:TXT(F)="where ITMREF_0='"+A(3)+"' and SERNUM_0='"+A(7)+"' and VCRTYP_0 in(4,5) and BPRNUM_0='"+CTE+"'"
For (Integer FRGT) From BD Sql TXT As [MYT2]
  T=[MYT2]FRGT
Next
If T<1
  WOK=0
  ZMSG=A(3)-A(7)-CTE-"articulo serie cliente, no se ha encontrado mvto de salida (4-Entrega ó 5-Fra)"
  Call ECR_TRACE(ZMSG,1) From GESECRAN
  Append MENSFIC,RESULT(JJ)+"  "+ZMSG+chr$(10)+chr$(10)
  Return
Endif
Return

$GRABAR
If !WOK   Return   Endif
Raz [F:ZSERR]
[F:ZSERR]ITMREF=A(3)
[F:ZSERR]SERNUM=A(7)
[F:ZSERR]ZNUMLIN=ULTIMO(A(3),A(7),BD)  # A(10)
[F:ZSERR]ZDAT   =A(1)
[F:ZSERR]ZTIM   =A(2)
[F:ZSERR]ITMDES1=A(4)
[F:ZSERR]BPCNUM =CTE # A(5)
[F:ZSERR]BPCNAM =A(6)
[F:ZSERR]ZDOCORI=A(8)
[F:ZSERR]ZCLIECC=A(9)
[F:ZSERR]ZNOMFIC=A(11)
Write [F:ZSERR]
If fstat=0
  ZMSG=A(3)-A(7)-CTE-"articulo serie cliente, importado"
  Call ECR_TRACE(ZMSG,0) From GESECRAN
Else
  ZMSG=A(3)-A(7)-CTE-"articulo serie cliente, error al importar (fstat="+num$(fstat)+")"
  Call ECR_TRACE(ZMSG,1) From GESECRAN
Endif
Return

$LEER_REGISTRO
Rdseq A(1), A(2), A(3), A(4), A(5), A(6), A(7), A(8), A(9), A(10),
& A(11), A(12), A(13), A(14), A(15), A(16), A(17), A(18), A(19), A(20),
& A(21), A(22), A(23), A(24), A(25), A(26), A(27), A(28), A(29), A(30),
& A(31), A(32), A(33), A(34), A(35), A(36), A(37), A(38), A(39), A(40),
& A(41), A(42), A(43), A(44), A(45), A(46), A(47), A(48), A(49), A(50),
& A(51), A(52), A(53), A(54), A(55), A(56), A(57), A(58), A(59), A(60),
& A(61), A(62), A(63), A(64), A(65), A(66), A(67), A(68), A(69), A(70),
& A(71), A(72), A(73), A(74), A(75), A(76), A(77), A(78), A(79), A(80),
& A(81), A(82), A(83), A(84), A(85), A(86), A(87), A(88), A(89), A(90),
& A(91), A(92), A(93), A(94), A(95), A(96), A(97), A(98), A(99), A(100),
& A(101), A(102), A(103), A(104), A(105), A(106), A(107), A(108), A(109), A(110) Using [TIE]
ZSTAT=fstat
A(3)=vireblc(A(3),2)
A(7)=vireblc(A(7),2)
If ZSTAT   WOK=0    Endif
Return

$TRAZA_CERRAR
If !GSERVEUR
  Call TEMPOFF From GESECRAN
  If LOUVTRC
    Call FERME_TRACE From LECFIC
    Call LEC_TRACE   From LECFIC
  Endif
Endif
Return

