Return

$ERRBATCH
Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End
Return

Funprog ULTIMO(ART,SER,BD)
Value Char    ART,SER,BD
Local Integer ULT
Local Char    TXT(250)(10)
Local Integer F :  F=-1
F+=1:TXT(F)="select isnull(max(ZNUMLIN_0),0) "
F+=1:TXT(F)="from ZSERREG "
F+=1:TXT(F)="where ITMREF_0 ='"+ART+"' and SERNUM_0 ='"+SER+"'"
For (Integer FULT) From BD Sql TXT As [MYT2]
  ULT=[MYT2]FULT
Next
End ULT

