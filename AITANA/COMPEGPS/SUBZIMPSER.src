CC_USER(4)="miriam@twonav.com"

ATTACHMENTS(1)=filpath("TRA",RTRACE,"tra")
#  EN PRUEBAS!!! #
ASUNTO="Proceso de importación de registro nºserie **ERROR** - "+adxmac(-1)
Append MENSAJE, 'Le informamos que los siguientes ficheros, no se han procesado por los motivos indicados'+chr$(10)+chr$(10)
