#############################################################################################

$ACTION
   Case ACTION
        When "BEFWRIBOP"   : Gosub BEFWRIBOP
    Endcase
    
Return
#############################################################################################
$BEFWRIBOP
If !clalev([F:YBOM]): Local File BOM [YBOM]: Endif
Read [F:YBOM]BOH0=[F:BOP]CPNITMREF;65;3
	If !fstat
		[F:BOP]YBOMALTTYP=3
	Endif	
Return























