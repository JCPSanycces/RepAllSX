Subprog AM_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
If [M]ITMREFEND = ""     : [M]ITMREFEND = VALEUR : Affzo ITMREFEND : Endif
If [M]ITMREFEND < VALEUR : [M]ITMREFEND = VALEUR : Affzo ITMREFEND : Endif
End

