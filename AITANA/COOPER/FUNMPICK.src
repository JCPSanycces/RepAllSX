#<AdxTL>@(#)0.0.0.0 $Revision$ 
#PATCH   09/11/2018. No bloqueo el campo proveedor
#PATCH_1 12/11/2018. Permito agrupaciones aunque el artículo sea Bajo Pedido
#PATCH_2 21/11/2018. Fuerzo a que no hayan agrupaciones en POF
#<AdxTL>@(#)1.0.0.0 $Revision$
# Issue 107498/107 - 2016-05-20 by BAKHA : Only allow lines with same PJT to be grouped
# Issue 107498/18 - 2016-07-18 by JUSYN : Treatment for PJT related orders without existing project management material record
# Issue 107498/18 - 2016-08-15 by JUSYN : Using existing functions and check for activity code PJM
#---------------------------------------------------------------------------#
# Action FMFGR Regroupements
#---------------------------------------------------------------------------#
$ACTION
Case ACTION
    When "INIT"          : Gosub INIT
    When "SEL_LISTE"     : Gosub SEL_LISTE
    When "FIN_LISTE"     : Gosub FIN_LISTE
    When "CONTROLE"      : Gosub CONTROLE
    When "OUVRE"         : Gosub OUVRE
    When "TITRE"         : Gosub TIT
    When "DEBUT"         : Gosub DEBUT
    When "SETBOUT"       : Gosub SETBOUT
    When "AVANT_BOUTON"  : Gosub AVANT_BOUTON
    When "BOUTON"        : Gosub BOUTON
    When "MEN"           : Gosub BOUTON
    When "AP_CHOIX"      : Gosub AP_CHOIX
    When "EDI"           : Gosub EDITION
    When "TERMINE"       : Gosub TERMINE
Endcase
Return

#########################################################################
$INIT
Global Char    GMRLNUM(GLONTRS)
GMRLNUM = ""
Global Integer LINC_I   # Issue 107498/107 - include in grouping
LINC_I = 0

Return

###########################################################################
# selection de la transaction
$SEL_LISTE
# sr 10.05 demande 32570
Local Char     TABACS(10)(100)
Local Integer  NBACS
Local Char    TEX(30)(0..100) , TEXTE(50)(0..100)
Local Char    TIT(30)
Local Integer NBTEX

If clalev ([F:BTS])=0  : Local File BENCHTRS [BTS] : Endif
# si on vient du planning global, on vérifie si un code transaction est passé
# 07.05 31326
If left$(GFONCTION,9) = "FUNGBENCH"
    If [M:MGB]RTRS <> ""
        Read [BTS]BTS0=53;[M:MGB]RTRS
        If fstat | [F:BTS]ENAFLG=1  : Return : Endif
      # GA 08/2006 si <Planif. ss-trait.> on a [F:BTS]PLANNER=2 & [F:BTS]BUYER=2
      # If [F:BTS]PLANNER <> 2 & GMODU(6) <> 2 : Return : Endif
      # If [F:BTS]PLANNER  = 2 & GMODU(8) <> 2 : Return : Endif
        If [F:BTS]BUYER=2 & GMODU(6) <> 2 : Return : Endif   :
        If [F:BTS]PLANNER=2 & [F:BTS]BUYER<>2 & GMODU(8) <> 2 : Return : Endif
        GMRLNUM = [F:BTS]BTSNUM
        OK = 0
        Return
    Endif
Endif

If clalev([F:ACC]) = 0 : Local File ACCES [ACC] : Endif
CRITERE = "BTSTYP=53&ENAFLG=2"
# sr 10.05 demande 32570
If GPROFIL <> GSUPER
    For [ACC]CODACC Where USR=GUSER
       If [F:ACC]EXEC=2 [L]TABACS(NBACS)=vireblc([F:ACC]CODACC,1) : NBACS +=1
       Endif
       If NBACS>99 Break : Endif
    Next
    CRITERE += "& (ACSCOD = ''  | find(ACSCOD,TABACS(0..99)))"
Endif
If GFLAG=""
    Filter [BTS] Where evalue(CRITERE)
    If rowcount([BTS])=1
        Read [BTS] First
        If !fstat
            GFLAG=[F:BTS]BTSNUM
        Endif
    Endif
    Filter [BTS]
Endif
If GFLAG<>""
    Filter [BTS] Where evalue(CRITERE)
    Read [BTS]BTS0=53;GFLAG
    Filter [BTS]
    If !fstat
&    & !([F:BTS]PLANNER <> 2 & GMODU(6) <> 2)
&    & !([F:BTS]PLANNER  = 2 & [F:BTS]BUYER = 2 & GMODU(6) <> 2)
&    & !([F:BTS]PLANNER  = 2 & [F:BTS]BUYER <>2 & GMODU(8) <> 2)
        GMRLNUM = [F:BTS]BTSNUM
        OK=0
    Endif
Endif
If GMRLNUM=""
    For [F:BTS] Where evalue(CRITERE)
        NBTEX+= 1
        TEX(NBTEX)   =[F:BTS]BTSNUM
        Call LECTEXTRA(TEXTE(NBTEX),"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
        TEXTE(NBTEX) = TEX(NBTEX)-TEXTE(NBTEX)
    Next
    TIT(0) = mess(3,126,1) # Choix transactions
Endif
Return

###########################################################################
$FIN_LISTE
GMRLNUM = TEX(CHOIX)
Return

###########################################################################
$CONTROLE
If clalev ([F:BTS]) <= 0  : Local File BENCHTRS [BTS] : Endif
Read [BTS]BTS0=53;GMRLNUM
If fstat | [F:BTS]ENAFLG=1  : FIN = 1 : Return : Endif
# GA 08/2006 si Planif. ss-trait. [F:BTS]PLANNER=2 & [F:BTS]BUYER=2
# If [F:BTS]PLANNER <> 2 & GMODU(6) <> 2 : FIN = 1 : Return : Endif
# If [F:BTS]PLANNER  = 2 & GMODU(8) <> 2 : FIN = 1 : Return : Endif
If [F:BTS]BUYER=2                     & GMODU(6) <> 2 : FIN = 1 : Return : Endif
If [F:BTS]PLANNER=2 & [F:BTS]BUYER<>2 & GMODU(8) <> 2 : FIN = 1 : Return : Endif

Return

###########################################################################
# Initialisation/ouverture tables/substitution fenêtre
#########################################################################
$OUVRE
Global Integer GRLRET : GRLRET = 0

If dim(GVCR) < 0
    Global Char    GVCR(GLONVCR)
    Global Integer GLIN
    Global Integer GSEQ
Endif

Local Char     WFCY(GLONFCY)
Local Char     WPLN(GLONAUS) : # Planificateur
Local Integer  WSRT
Local Char     WROH(GLONVCR)    # Issue 7729 GA 08/2014
Local Char     WITMD(GLONITM)
Local Char     WITMF(GLONITM)
Local Char     WPJT(GLONPJT)
Local Char     WVCR(GLONVCR)
Local Char     WBPR(GLONBPR)
Local Date     WSTRDAT
Local Date     WENDDAT
Local Char     WDATC1(10), WDATC2(10)
Local Char     WORI(10)

Local Char    CODE(3)
Local Integer RETOUR
Local Integer L,I,OK
Local Integer REPONSE
Local Integer WMAXT
Local Char    CRITERE(255)
Local Char    CRITERE1(255)
Local Char    CRITERE2(255)
Local Char    CRITERE3(255)
Local Char    CRITERE4(255)
Local Char    FORMULE1(250)
Local Char    CUSFLT(255)
Local Char    WNUM(GLONVCR)
Local Date    TODAY : TODAY = date$
Local Date    WDATEREF
Local Integer WRET
Local Char    WMFGNUM(GLONVCR), WBPS(GLONBPR), WUSEPLC(10)
Local Integer WSTA
Local Integer WTYP
Local Decimal WTOTPEC, WTOTWOP, WTOTWOPC
Local Integer WFLGPEC
Local Integer WPRO, WSCO
Local Decimal WMAJDA
Local Char    WRCPDAT(10), WORIFCY(GLONFCY)
Local Integer WMAX : WMAX = 49
Local Decimal WCOEF
Local Decimal C_QTY
Local Char    WPOHNUM(GLONVCR)
Local Char    WBPSNUM(GLONBPR)
Local Integer WTRI
Local Integer WLIN
Local Integer WFLT
#Local Char    WLEGCPY(GLONCPY)
Local Integer ISINTERCPY
Local Integer WOFS                # 09.04 25242
Local Char    WPTOCOD(GLONPTO)
Local Integer WPTODIR
Local Char    WECCMAJ(GLONICVVAL), WECCMIN(GLONICVVAL) # Issue 110957 - 2015-10-07 by GH

# ouverture des tables
If clalev ([F:ORD]) <= 0 : Local File ORDERS     [ORD] : Endif # Issue 79916 GA 02/2012 - pb sur Local File direct
If clalev ([F:ORDM]) <= 0: Local File ORDERS     [ORDM]: Endif # Issue 107498/107 - orders table
If clalev ([F:ITM]) <= 0 : Local File ITMMASTER  [ITM] : Endif
If clalev ([F:ITF]) <= 0 : Local File ITMFACILIT [ITF] : Endif
If clalev ([F:ITV]) <= 0 : Local File ITMMVT     [ITV] : Endif
If clalev ([F:TUN]) <= 0 : Local File TABUNIT    [TUN] : Endif
If clalev ([F:BPS]) <= 0 : Local File BPSUPPLIER [BPS] : Endif
If clalev ([F:ITP]) <= 0 : Local File ITMBPS     [ITP] : Endif
If clalev ([F:TFO]) <= 0 : Local File TABFOR     [TFO] : Endif
If clalev ([F:FCY]) <= 0 : Local File FACILITY   [FCY] : Endif
If clalev ([F:BTS]) <= 0 : Local File BENCHTRS   [BTS] : Endif
If clalev ([F:CAL]) <= 0 : Local File CPTANALIN  [CAL] : Endif
If clalev ([F:DTR]) <= 0 : Local File DIETRS     [DTR] : Endif
If clalev ([F:LED]) <= 0 : Local File GLED       [LED] : Endif
If clalev ([F:PTO]) <= 0 : Local File PARMTO     [PTO] : Endif

If clalev ([F:BPD]) <= 0  : Local File BPDLVCUST  [BPD] : Endif
If clalev ([F:BPR]) <= 0  : Local File BPARTNER   [BPR] : Endif
If clalev ([F:BPC]) <= 0  : Local File BPCUSTOMER [BPC] : Endif
If clalev ([F:FCY]) <= 0  : Local File FACILITY   [FCY] : Endif
If clalev ([F:EVL]) <= 0  : Local File ECCVAL     [EVL] : Endif # Issue 110957 - 2015-10-07 by GH

If dim(GRCPFCY)<0 : Global Char GRCPFCY(GLONFCY) : Endif

If GMODU(8) = 2
    If clalev ([F:MFG])  <= 0 : Local File MFGHEAD    [MFG] : Endif
    If clalev ([F:MFO])  <= 0 : Local File MFGOPE     [MFO] : Endif
    If clalev ([F:TCA])  <= 0 : Local File TABCOUAFF  [TCA] : Endif
    If clalev ([F:MTS])  <= 0 : Local File MFGTRS     [MTS] : Endif
    If clalev ([F:ROH])  <= 0 : Local File ROUTING    [ROH] : Endif # Issue 7729 GA 08/2014
    If clalev ([F:TRO])  <= 0 : Local File TABROUALT  [TRO] : Endif # Issue 7729 GA 08/2014
    If clalev ([F:MFI])  <= 0 : Local File MFGITM     [MFI] : Endif # Isuue 7729 GA 08/2014
    ## GH 19/05/2014 bug 100108 société et législation non encore déterminées ici
    #Call LECTCA(8,OK) From SUBTCA
    #If OK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
    #GOPS    = [F:TCA]CODNUM(4)   # compteur suggestion opérations
Endif

If GMODU(6) = 2
    If clalev ([F:PSD]) <= 0 : Local File PREQUISD   [PSD] : Endif
    If clalev ([F:POH]) <= 0 : Local File PORDER     [POH] : Endif
    If clalev ([F:POC]) <= 0 : Local File PORDERC    [POC] : Endif
    If clalev ([F:POP]) <= 0 : Local File PORDERP    [POP] : Endif
    If clalev ([F:POQ]) <= 0 : Local File PORDERQ    [POQ] : Endif
    If clalev ([M:PMG]) <= 0 : Local Mask PURMGT     [PMG] : Endif
    If clalev ([F:PTR]) <= 0 : Local File PURTRS     [PTR] : Endif
    Gosub OPEN_FILES_SCO From SCOLIB
    If clalev ([M:SCOK])  <= 0 : Local Mask SCOK     [SCOK] : Endif
Endif

If GMODU(5) = 2
    If clalev ([F:SOH]) <= 0 : Local File SORDER     [SOH] : Endif
    If clalev ([F:SOP]) <= 0 : Local File SORDERP    [SOP] : Endif
    If clalev ([F:SOQ]) <= 0 : Local File SORDERQ    [SOQ] : Endif
    If clalev ([F:SOC]) <= 0 : Local File SORDERC    [SOC] : Endif
Endif

# masque pour paramètres mises à jour
If clalev ([M:RFOK])  <= 0 : Local Mask REPFOUK   [RFOK] : Endif
If GMODU(8) = 2
   If clalev ([M:ORCK])  <= 0 : Local Mask ORCK      [ORCK] : Endif
   If clalev ([M:MFGK])  <= 0 : Local Mask MFGK      [MFGK] : Endif
Endif

# 15806 MM 05.05  : pour memo
If clalev ([M:MFB2]) <= 0 : Local Mask MFGBCRIT2  [MFB2] : Endif
If clalev ([M:MFB3]) <= 0 : Local Mask MFGBCRIT3  [MFB3] : Endif
If clalev ([M:MFB5]) <= 0 : Local Mask MFGBCRIT5  [MFB5] : Endif

# mise en relief affectations
Gosub OPEN_HL_TABLIN From HLIGHTLIB

# chargement des paramètres action
WFCY    = PARAM(1)
WPLN    = PARAM(2)
WSRT    = val(PARAM(3))
WITMD   = PARAM(4)
WITMF   = PARAM(5)
WPJT    = PARAM(6)
WVCR    = PARAM(7)
WBPR    = PARAM(8)
WDATC1  = PARAM(9)
WDATC2  = PARAM(10)
WORI    = PARAM(11)
 # Issue 110957 - 2015-10-07 by GH
If dim(PARAM(13))>0 : WECCMAJ=PARAM(13)  : Endif
If dim(PARAM(14))>0 : WECCMIN=PARAM(14) : Endif

Gosub LECTURE_BTS
# initialisations
WAPP = 0 : WPRO = 0  : # Planif. prod.
If [F:BTS]PLNPLN = 2 : WPRO += 2 : Endif
If [F:BTS]PLNLAN = 2 : WPRO += 4 : Endif

WSCO = 0        : # GA 08/2006 Planif. ss-trait.
If [F:BTS]SCOPLN = 2 : WSCO += 2 : Endif
If [F:BTS]SCOLAN = 2 : WSCO += 4 : Endif

# substitution fenêtre
If [F:BTS]PLANNER = 2 & [F:BTS]BUYER <> 2   # Planif production mono-article
    MASKREF = "MFGPICK"
    BOITE   = "WFMFGR"+GMRLNUM
Elsif [F:BTS]PLANNER = 2 & [F:BTS]BUYER = 2 # V6 Planif ss-traitance mono-article
    MASKREF = "MFGPICK"
    BOITE   = "WFMFGRB"+GMRLNUM
Else                                        # Acheteur (multi-articles)
  MASKREF = "MFGPICKA"
  BOITE   = "WFMFGRA"+GMRLNUM
Endif
WMASQUE   = "WT53"+GMRLNUM+"1"     # avant WT52 ?
#MAE, le 31/01/08, GRP_SITE
GGRPFCY = [F:BTS]GFY
Gosub CHANGE_AWI From BENCHLIB

Return

#########################################################################
$TIT
    Call LECTEXTRA(TIT,"BENCHTRS","DESAXX",num$([F:BTS]BTSTYP),[F:BTS]BTSNUM) From ATEXTRA
    If !clalev([F:AWI]) : Local File AWINDOW : Endif
    Read [AWI]AWI0=BOITE
    Call TEXTE([F:AWI]DES,GBIDC1) From OBJDIV
    TIT = GBIDC1-[F:BTS]BTSNUM-":"-TIT
Return

#########################################################################
# alimentation initiale écran
$DEBUT
# mémorisation nombre de ligne maxi
WMAX  = dim([M:PMG]WIPTYP)
WMAXT = dim([M:MGP]WIPTYPSTA)
Raz [M:MGP]

# FQ 74895 GA 07/2011 déplacé avant recopie des autres critères et déclenché de façon systématique, même si appel en tunnel
# 15806 MM 05.05 : application memo STD
# If WORI =""
    If [F:BTS]PLANNER = 2 & [F:BTS]BUYER<>2    : # Planif. prod.
        Raz [M:MFB2]
        If filinfo(filpath("ETM",GUSER+"_"+GMRLNUM+"_"+"STD","mfr",0),0)>=0
            Call LECMEMO("STD","[M:MFB2]",GMRLNUM+"~mfr") From GMEMO
            [M:MGP]        = [M:MFB2]
            [M:MGP]FLT     = [M:MFB2]TMPFLT
            Raz [M:MFB2]TMPFLT
        Endif
    Elsif [F:BTS]PLANNER = 2 & [F:BTS]BUYER=2 : # Planif. ss-trait.
        Raz [M:MFB5]
        If filinfo(filpath("ETM",GUSER+"_"+GMRLNUM+"_"+"STD","mfs",0),0)>=0
            Call LECMEMO("STD","[M:MFB5]",GMRLNUM+"~mfs") From GMEMO
            [M:MGP]        = [M:MFB5]
            [M:MGP]FLT     = [M:MFB5]TMPFLT
            Raz [M:MFB5]TMPFLT
        Endif
    Else
        Raz [M:MFB3]
        If filinfo(filpath("ETM",GUSER+"_"+GMRLNUM+"_"+"STD","mfa",0),0)>=0
            Call LECMEMO("STD","[M:MFB3]",GMRLNUM+"~mfa") From GMEMO
            [M:MGP]        = [M:MFB3]
            [M:MGP]FLT     = [M:MFB3]TMPFLT
            Raz [M:MFB3]TMPFLT
        Endif
    Endif
# Endif

If WFCY <> ""
    [M:MGP]FCY        = WFCY
Else
    If [F:BTS]BUYER = 2      : [M:MGP]FCY = GFCYDEF(6)
    Elsif [F:BTS]PLANNER = 2 : [M:MGP]FCY = GFCYDEF(8)
    Endif
Endif
GFCY = [M:MGP]FCY : Gosub CHARG_PARAM
If GMODU(8)=2 & GOPS="" : Raz [M:MGP]FCY : Endif : ## GH 19/05/2014 bug 100108
If WPLN <> "" : [M:MGP]PLANNER = WPLN : Else : [M:MGP]PLANNER = GUSER : Endif
If WSRT<>0 : # GH 05/12/12 bug 86277
   [M:MGP]SRTCOD     = WSRT
Endif
If [M:MGP]SRTCOD = 0 : [M:MGP]SRTCOD = 5 : Endif
If [F:BTS]PLANNER = 2                                   # Planificateur => écran MFGPICK
  If WITMD<>""
      [M:MGP]ITMREFS  = WITMD
      Call AM_ITMREFS([M:MGP]ITMREFS)
  Elsif dim([M:MGP]IECCVALMAJ)>0                        # Issue 110957 - 2015-10-07 by GH
      Diszo [M:MGP]IECCVALMIN
      Diszo [M:MGP]IECCVALMAJ
  Endif
Else                                                    # Acheteur      => écran MFGPICKA
    [M:MGP]ITMREFSTR  = WITMD
    [M:MGP]ITMREFEND  = WITMF
Endif
# Issue 7729 GA 08/2014 Manufacturing: group different products with a common routing
If [F:BTS]PLANNER = 2  & dim([M:MGP]ROUNUMS)>0          # Planificateur => écran MFGPICK
    If WROH<>"" [M:MGP]ROUNUMS = WROH Endif
    If [M:MGP]ROUNUMS <> ""
        WROH = [M:MGP]ROUNUMS
        Read [ROH]ROH0 = [M:MGP]ROUNUMS;[M:MGP]ROUALTS;[M:MGP]FCY
        Read [ITM]ITM0 = [M:MGP]ROUNUMS
        If !fstat : [M:MGP]STU = [F:ITM]STU : Endif
    Endif
Endif
If WPJT<>""
   [M:MGP]PJTSTR     = WPJT
   [M:MGP]PJTEND     = WPJT
Endif
If WVCR<>""
   [M:MGP]VCRNUMSTR  = WVCR
   [M:MGP]VCRNUMEND  = WVCR
Endif
If WBPR<>""
   [M:MGP]BPRNUMSTR  = WBPR
   [M:MGP]BPRNUMEND  = WBPR
Endif
If WDATC1 <> ""
    If instr(1,WDATC1,"/")
        WSTRDAT = "["+WDATC1+"]"
    Else
        WSTRDAT = WDATC1
    Endif
Endif
If WDATC2 <> ""
    If instr(1,WDATC2,"/")
        WENDDAT = "["+WDATC2+"]"
    Else
        WENDDAT = WDATC2
    Endif
Endif
If WSTRDAT <> [0/0/0] | WENDDAT <> [0/0/0]
    [M:MGP]ENDDATSTR  = WSTRDAT
    [M:MGP]ENDDATEND  = WENDDAT
Elsif [M:MGP]ENDDATEND = [0/0/0] # GH 04/08/14 bug 101859
    [M:MGP]ENDDATSTR  = [0/0/0]
    [M:MGP]ENDDATEND  = date$+(GPLNHOR*7)
Endif

# GA 08/2006 "Planif. prod." et "Planif. ss-trait." même codification pour [M:MGP]FLT
If [F:BTS]PLANNER = 2 & [M:MGP]MEMO="" : [M:MGP]FLT = 24 : Endif

If [F:BTS]APPBUY  = 2 | [F:BTS]APPINT = 2
    If [M:MGP]MEMO="" : # GH 05/12/12 bug 86277
       [M:MGP]FLT = 15                        #  30400 MM 05.05
    Endif
    If [F:BTS]APPBUY = 2 & [F:BTS]APPINT = 1 : [M:MGP]APPPRF = 1 : Endif
    If [F:BTS]APPBUY = 1 & [F:BTS]APPINT = 2 : [M:MGP]APPPRF = 2 : Endif
    If [F:BTS]APPBUY = 2 & [F:BTS]APPINT = 2 : [M:MGP]APPPRF = 3 : Endif
Endif
If [F:BTS]PLANNER = 1 & ( [F:BTS]BUYER   = 2 | [F:BTS]INTBUY = 2 ) : # GA 08/2006 sauf Planif. ss-trait.
    If [M:MGP]MEMO="" : # GH 05/12/12 bug 86277
       If [F:BTS]BUYER  = 2  : [M:MGP]FLT = 56 : Else : [M:MGP]FLT = 24 : Endif
    Endif
    If [F:BTS]BUYER  = 2 & [F:BTS]INTBUY = 1 : [M:MGP]APPPRF = 1 : Endif
    If [F:BTS]BUYER  = 1 & [F:BTS]INTBUY = 2 : [M:MGP]APPPRF = 2 : Endif
    If [F:BTS]BUYER  = 2 & [F:BTS]INTBUY = 2 : [M:MGP]APPPRF = 3 : Endif
Endif

# mémorisation contexte habilitation suivant transaction
Gosub ANALYSE_CTX

# Issue 110957 - 2015-10-07 by GH
If dim([M:MGP]IECCVALMAJ)>0
    If varmode([M:MGP]IECCVALMAJ)=0 : [M:MGP]IECCVALMAJ=WECCMAJ : Endif
    If varmode([M:MGP]IECCVALMIN)=0 : [M:MGP]IECCVALMIN=WECCMIN : Endif
Endif

# en consultation, les champs ne sont pas saissables
If [F:BTS]TRSCNL =2 : Diszo [MGP]NBLIG : Endif

If WITMD <> ""
    I = GRLRET
    [M:MGP]REACT = 2
    Gosub REACTUALISATION
    [M:MGP]REACT = 1
    GRLRET = I
Endif

# 106430 - populate Container weight and volume UOM
# no container selected yet - so just use parameters
If dim([M:MGP]TCTRWEU)>0
  [M:MGP]TCTRWEU  = GSALDSPWEU
  [M:MGP]TCTRVOU  = GSALDSPVOU
  [M:MGP]ORDCUR   = GSYSCUR
  [M:MGP]TOTCUR   = GSYSCUR
Endif

# Issue 110957 - 2015-10-07 by GH
If dim([M:MGP]ICRID)>0
   Diszo [MGP]ICRID
   If [M:MGP]ITMREFS<>"" & func ECCLIB.NBRCPN([M:MGP]ITMREFS)>0 : # already done via AM_ITMREF for a product with no version
      [M:MGP]ICRID = func TRTX3FNC.CCMID([M:MGP]ITMREFS,[M:MGP]IECCVALMAJ,[M:MGP]IECCVALMIN)
      If dim([M:MGP]ICRFLG)>0
         [M:MGP]ICRFLG = string$([M:MGP]ICRID<>"","151")
      Endif
   Endif
Endif
If dim([M:MGP]CRID)>0
   Diszo [MGP]CRID
Endif

Diszo [MGP]14    #106430 - Was 15 - updated to 14 to handle screen changes (existing block)
Affzo [MGP]5-19  #106430 - Was 5-15, updated to 5-19 to include new blocks

Return

#########################################################################
# état des boutons
$SETBOUT
ETABOU(GSPE1) = 1                                     # recherche
ETABOU(GSPE2) = 1                                     # critères

# If [M:MGP]NBLIG = 0 : # GH 07/03/2014 bug 97631 en mode consultatif, ces boutons doivent être inactifs
If [M:MGP]NBLIG = 0 | [F:BTS]TRSCNL = 2
    ETABOU(GSPE3) = 0                                 # inclure
    ETABOU(GSPE4) = 0                                 # exclure
    ETABOU(GSPE5) = 0                                 # générer
#Elsif [F:BTS]TRSCNL <> 2
#        ETABOU(GSPE3) = 1
#        ETABOU(GSPE4) = 1
#        ETABOU(GSPE5) = 1
Endif
ETABOU(GBFIN) = 1                                     # fin
ETABOU(GEDIT) = 1                                     # hardcopy
Return

########################################################################
$AVANT_BOUTON
Case BOUT
    When "5"       : If [M:MGP]TOTPECQTY = 0 : FOK = 0 : Return : Endif
                     If [F:BTS]PLANNER = 2 & [F:BTS]BUYER <> 2 : Gosub AVANT_WOX : Endif
                     If [F:BTS]PLANNER = 2 & [F:BTS]BUYER =  2 : Gosub AVANT_EOX : Endif
Endcase
FIN=0
Return

########################################################################
$BOUTON
Case BOUT
    When "1"       :     Gosub RECHERCHER
    When "2"       :     Gosub CRITERES
    When "3"       :     Gosub INCLURE
    When "4"       :     Gosub EXCLURE
    When "5"       :     Gosub GENERER
    When "T"       :     Gosub LECTURE_BTS                # rechargement BTS après visualisation
Endcase
FIN=0
Return

#########################################################################
$AP_CHOIX
# interception de la touche return
If REPONSE = GSTARET
    Gosub RECHERCHER
Endif
Return

#########################################################################
$RECHERCHER
Gosub LECTURE_BTS
If [M:MGP]NBLIG <> 0
    OK = 1
    Call OUINON(mess(420,198,1),OK) From GESECRAN
    If OK <> 2 : Return : Endif
Endif
I = GRLRET
[M:MGP]REACT = 2
Gosub REACTUALISATION
[M:MGP]REACT = 1
GRLRET = I
# Issue 107498/107 - de-activate lines for PJT
Gosub INC_ALL

Return

#########################################################################
$CRITERES
Gosub REACTUALISATION
Return

#########################################################################
$INCLURE
Gosub INC_ALL
Return

#########################################################################
$EXCLURE
Gosub EXC_ALL
Return

#########################################################################
$GENERER
Gosub LECTURE_BTS

If [M:MGP]REACT = 2
   If [F:BTS]PLANNER = 2 & [F:BTS]BUYER <> 2
      Gosub MAJ_CONSO_OF    : # Planif. prod.
   Elsif [F:BTS]PLANNER = 2 & [F:BTS]BUYER = 2 # GH 14/04/2014 bug 97405 # Else
      Gosub MAJ_CONSO_EO : # GA 08/2006 Planif. ss-trait.
   Endif
Endif
If [F:BTS]PLANNER<>2 & ([F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2) : Gosub GEN_POP   : Endif
If [F:BTS]PLANNER<>2 & ([F:BTS]BUYER  = 2 | [F:BTS]INTBUY = 2) : Gosub GEN_POF   : Endif
Gosub REACTUALISATION
Return

#########################################################################
$REACTUALISATION
If [M:MGP]REACT = 2
    Gosub CHARGE_MGP
    If nolign = WMAXT : GMESSAGE = mess(168,190,1) : GERR = 2 : Endif
    [M:MGP]REACT = 1
    GRLRET = 2
    # Issue 107498/107 - 2016-06-10 by JUSYN : After actualization needed to display lines correctly ticked
    Gosub INC_ALL
Endif
Return

############################################################################
$EDITION
Call PRTSCR(WMASQUE,"MGP","",0,0) From ATRTX3
# Issue 77648 - 2011-11-08 by VPO : edition partait à la sortie de la fonction
Call IMPSCR From ATRTX3
Return

#########################################################################
$TERMINE
PARAM(12) = num$(GRLRET)
# 07.05 31326
If GRLRET = 2 & left$(GFONCTION,9) = "FUNGBENCH"
    [M:MGB]REACT = 2
    Gosub FABRICATION From FUNGBENCH
Endif
Call IMPSCR From ATRTX3
Return

########################################################################
# Analyse et mémorisation contexte
########################################################################
$ANALYSE_CTX
[M:MGP]PLNHAB = WPRO
[M:MGP]SCOHAB = WSCO  : # GA 08/2006 Planif. ss-trait.

# pour les sélections article/site
#If [F:BTS]BUYER <> 2 & [F:BTS]INTBUY <> 2
If [F:BTS]PLANNER = 2           : # GA 08/2006 pour tenir compte <Planif. ss-trait.>
    #   filtre sur planificateur
    Case GPLNFLT
        When 2: [M:MGP]ITMFILTER = 'PLANNER=[M:MGP]PLANNER | PLANNER=""'
        When 3: [M:MGP]ITMFILTER = 'PLANNER=[M:MGP]PLANNER'
    Endcase
Else
    #   filtre sur acheteur
    Case GBUYFLT
        When 1: # ben rien
        When 2: # [M:MGP]ITMFILTER = 'BUY=[M:MGP]PLANNER': # GH 15/05/2014 bug 99197
                [M:MGP]ITMFILTER = 'BUY=[M:MGP]PLANNER | BUY=""'
    Endcase
Endif

If [F:BTS]PLANNER = 2 & [F:BTS]BUYER  = 1 : [M:MGP]ITMCAT = "2"   : Endif : # GA dans FUNDBENCH "23" ?
If [F:BTS]BUYER   = 2 & [F:BTS]PLANNER= 1 : [M:MGP]ITMCAT = "14"  : Endif
If [F:BTS]APPBUY  = 2                     : [M:MGP]ITMCAT = "14"  : Endif
If [F:BTS]INTBUY  = 2 | [F:BTS]APPINT = 2 : [M:MGP]ITMCAT = "124" : Endif
If [F:BTS]PLANNER = 2 & [F:BTS]BUYER  = 2 : [M:MGP]ITMCAT = "1234": Endif : # GA 08/2006 Planif. ss-trait.

If [M:MGP]MEMO="" : # GH 05/12/12 bug 86277
   [M:MGP]FORMULE = [F:BTS]DEFFOR

    # 21180 MM 01.05 : filtre "origine des suggestions" provenant de la transaction, appliqué par défaut
    [M:MGP]MRPFLG = [F:BTS]MRPFLG
Endif

Return

########################################################################
# Traitement de la génération d'ordres de fabrication                  #
# Traitement de la génération d'ordres de sous-traitance               #
########################################################################
$AVANT_WOX
$AVANT_EOX
Gosub ANALYSE_BESOIN
[M:MGP]INDPEC = 0
If find(2, [M:MGP]FLGPEC(0..[M:MGP]NBLIG-1)) & find(2, [M:MGP]FLGREG(0..[M:MGP]NBLIG-1))
    [M:MGP]INDPEC = 1
Endif
Return

########################################################################
# Traitement de la génération d'achats planifiés                       #
########################################################################
$GEN_POP
Local Integer I_DEPART, SAV_NBRELIGNE
Raz GPURTRACE
Call OUVRE_TRACE(mess(218,197,1)) From LECFIC : GPURTRACE=1

#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
# première phase, génération DA
SAVIND = 0
$LECDA
Raz [M:PMG]
[M:PMG]MAJCOD     = "C"
[M:PMG]MAJTYP     = "P"
[M:PMG]RGRFLG     = 3
[M:PMG]MSGFLG     = 1
[M:PMG]TRAFLG     = 2
If [M:MGP]PLANNER = ""
    [M:PMG]REQUSR     = GUSER
Else
    [M:PMG]REQUSR     = [M:MGP]PLANNER
Endif
[M:PMG]NBLIG      = 0
For I = SAVIND To [M:MGP]NBLIG - 1
    If [M:PMG]NBLIG > WMAX : SAVIND = I : Goto UPDDA : Endif
    If [M:MGP]PECQTY(I) = 0   : Goto SUIVANTDA : Endif
    If [M:MGP]POHNUM(I) <> "" : Goto SUIVANTDA : Endif
    If [M:MGP]PUUPECQTY(I) = 0: Goto SUIVANTDA : Endif

    If [M:MGP]WIPNUM(I) <> ""
        Gosub CHECK_WIP
        If WRET : Goto SUIVANTDA : Endif
    Endif

    If find([M:MGP]WIPTYP(I),2,7)
        [M:PMG]WIPTYP([M:PMG]NBLIG) = [M:MGP]WIPTYP(I)
        [M:PMG]WIPSTA([M:PMG]NBLIG) = [M:MGP]WIPSTA(I)
        [M:PMG]WIPNUM([M:PMG]NBLIG) = [M:MGP]WIPNUM(I)
    Endif
    [M:PMG]ITMREF([M:PMG]NBLIG)    = [M:MGP]ITMREF(I)
    # sr 04.05 demande 24624
    [M:PMG]ORDFCY([M:PMG]NBLIG)    = [M:MGP]POHFCY(I)
    [M:PMG]ORIFCY([M:PMG]NBLIG)    = [M:MGP]ORIFCY(I)
    [M:PMG]STOFCY([M:PMG]NBLIG)    = [M:MGP]STOFCY(I)
    [M:PMG]BPRNUM([M:PMG]NBLIG)    = [M:MGP]BPSNUM(I)
    [M:PMG]PJT([M:PMG]NBLIG)       = [M:MGP]PJT(I)
    [M:PMG]ENDDAT([M:PMG]NBLIG)    = [M:MGP]REQDAT(I)
    [M:PMG]STU([M:PMG]NBLIG)       = [M:MGP]STU(I)
    [M:PMG]EXTSTUQTY([M:PMG]NBLIG) = [M:MGP]PECQTY(I)
    [M:PMG]PUU([M:PMG]NBLIG)       = [M:MGP]PUU(I)
    [M:PMG]EXTPUUQTY([M:PMG]NBLIG) = [M:MGP]PUUPECQTY(I)
    # point d'entrée permettant de renseigner des zones spécifiques - 39129 mm 01.07
    GPOINT = "LOADZON" : Gosub ENTREE From EXEFNC
    [M:PMG]NBLIG     += 1
$SUIVANTDA
Next I
SAVIND = 0

$UPDDA
If [M:PMG]NBLIG <> 0
    Call TEMPON(mess(217,197,1)) From GESECRAN
    Call UPD_PURCHASE
Endif
If SAVIND : Goto LECDA : Endif

# seconde phase, génération DL planifiée
SAVIND = 0
$LECDLP
Raz [M:PMG]
[M:PMG]MAJCOD     = "C"
[M:PMG]MAJTYP     = "P"

# pas de regroupement sur commande ouverte pour le moment
[M:PMG]RGRFLG     = 1
[M:PMG]WRCPDAT    = ""

[M:PMG]MSGFLG     = 1
[M:PMG]TRAFLG     = 2
If [M:MGP]PLANNER = ""
    [M:PMG]REQUSR     = GUSER
Else
    [M:PMG]REQUSR     = [M:MGP]PLANNER
Endif
[M:PMG]PSHFCY     = [M:MGP]FCY    # FQ 76315 GA 09/2011 avant ""
[M:PMG]PRQDAT     = date$
[M:PMG]NBLIG      = 0
For I = SAVIND To [M:MGP]NBLIG - 1
    If [M:PMG]NBLIG > WMAX : SAVIND = I : Goto UPDDLP : Endif
    If [M:MGP]PECQTY(I) = 0   : Goto SUIVANTDLP : Endif
    If [M:MGP]POHNUM(I) = ""  : Goto SUIVANTDLP : Endif
    If [M:MGP]PUUPECQTY(I) = 0: Goto SUIVANTDLP : Endif

    If [M:MGP]WIPNUM(I) <> ""
        Gosub CHECK_WIP
        If WRET : Goto SUIVANTDLP : Endif
    Endif

    If find([M:MGP]WIPTYP(I),2,7)
        [M:PMG]WIPTYP([M:PMG]NBLIG) = [M:MGP]WIPTYP(I)
        [M:PMG]WIPSTA([M:PMG]NBLIG) = [M:MGP]WIPSTA(I)
        [M:PMG]WIPNUM([M:PMG]NBLIG) = [M:MGP]WIPNUM(I)
    Endif
    [M:PMG]POCNUM([M:PMG]NBLIG)    = [M:MGP]POHNUM(I)
    [M:PMG]ITMREF([M:PMG]NBLIG)    = [M:MGP]ITMREF(I)
    If [M:PMG]PSHFCY<>[M:MGP]POHFCY(I) # Issue 99743 GA 09/2014
       Raz [M:PMG]PSHFCY
    Endif
    [M:PMG]ORDFCY([M:PMG]NBLIG)    = [M:MGP]POHFCY(I)   # FQ 78863 GA 12/2011
    [M:PMG]ORIFCY([M:PMG]NBLIG)    = [M:MGP]ORIFCY(I)
    [M:PMG]STOFCY([M:PMG]NBLIG)    = [M:MGP]STOFCY(I)
    [M:PMG]BPRNUM([M:PMG]NBLIG)    = [M:MGP]BPSNUM(I)
    [M:PMG]PJT([M:PMG]NBLIG)       = [M:MGP]PJT(I)
    [M:PMG]ENDDAT([M:PMG]NBLIG)    = [M:MGP]REQDAT(I)
    [M:PMG]STU([M:PMG]NBLIG)       = [M:MGP]STU(I)
    [M:PMG]EXTSTUQTY([M:PMG]NBLIG) = [M:MGP]PECQTY(I)
    [M:PMG]PUU([M:PMG]NBLIG)       = [M:MGP]PUU(I)
    [M:PMG]EXTPUUQTY([M:PMG]NBLIG) = [M:MGP]PUUPECQTY(I)
    # point d'entrée permettant de renseigner des zones spécifiques - 39129 mm 01.07
    GPOINT = "LOADZON" : Gosub ENTREE From EXEFNC
    [M:PMG]NBLIG     += 1
$SUIVANTDLP
Next I
SAVIND = 0

$UPDDLP

If [M:PMG]NBLIG <> 0
    Call TEMPON(mess(237,197,1)) From GESECRAN
    Call UPD_PURCHASE
Endif

If SAVIND : Goto LECDLP : Endif

Call TEMPOFF From GESECRAN

# lecture du fichier trace si nécessaire
If GPURTRACE
  Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
  GPURTRACE=0 : GTRACE=""
Endif
#----- Restauration variables globales -----#
Gosub REST_GLOB From TRTX3GLOB

[M:MGP]REACT = 2
Return

########################################################################
# Traitement de la génération d'achats fermes                          #
########################################################################
$GEN_POF
Local Integer I_DEPART, SAV_NBRELIGNE

Raz GPURTRACE
#----- Sauvegarde variables globales -----#
Gosub SAUV_GLOB From TRTX3GLOB
Call OUVRE_TRACE(mess(14,197,1)) From LECFIC : GPURTRACE=1
# première phase, génération commandes
SAVIND = 0
$LECPO
Raz [M:PMG]
[M:PMG]MAJCOD     = "C"
[M:PMG]MAJTYP     = "F"
[M:PMG]RGRFLG     = 2
[M:PMG]MSGFLG     = 1
[M:PMG]TRAFLG     = 2
# FQ 73645 GA 05/2011 Une transaction par commande
If dim(GPURRGRFLG)>0 & GPURRGRFLG=4
   [M:PMG]RGRFLG  = 4
   [M:PMG]TRAFLG  = 3
Endif

#PATCH_2 21/11/2018. Fuerzo a que no haya agrupaciones en la creación de POF
[M:PMG]RGRFLG     = 1

If [M:MGP]PLANNER = ""
    [M:PMG]REQUSR     = GUSER
Else
    [M:PMG]REQUSR     = [M:MGP]PLANNER
Endif
[M:PMG]NBLIG      = 0
For I = SAVIND To [M:MGP]NBLIG - 1
    If [M:PMG]NBLIG > WMAX : SAVIND = I : Goto UPDPO : Endif
    If [M:MGP]PECQTY(I) = 0   : Goto SUIVANTPO : Endif
    If [M:MGP]BPSNUM(I) = ""  : Goto SUIVANTPO : Endif
    If [M:MGP]POHNUM(I) <> "" : Goto SUIVANTPO : Endif

    # GA 08/2006 cas des EOF commande de sous-traitance
    #----- If [M:MGP]WIPTYP(I) = 4 : Goto SUIVANTPO : Endif
    If find([M:MGP]WIPTYP(I),4,13) : Goto SUIVANTPO : Endif
    If [M:MGP]PUUPECQTY(I) = 0     : Goto SUIVANTPO : Endif

    If [M:MGP]WIPNUM(I) <> ""
        Gosub CHECK_WIP
        If WRET : Goto SUIVANTPO : Endif
    Endif

    If find([M:MGP]WIPTYP(I),2,7,1,8) : # GH 15/05/2014 bug 99197 # If find([M:MGP]WIPTYP(I),2,7)
        [M:PMG]WIPTYP([M:PMG]NBLIG) = [M:MGP]WIPTYP(I)
        [M:PMG]WIPSTA([M:PMG]NBLIG) = [M:MGP]WIPSTA(I)
        [M:PMG]WIPNUM([M:PMG]NBLIG) = [M:MGP]WIPNUM(I)
    Endif
    [M:PMG]ITMREF([M:PMG]NBLIG)    = [M:MGP]ITMREF(I)
    #[M:PMG]ITMREFORI([M:PMG]NBLIG) = [M:MGP]ITMREFORI(I)  # Issue 91309 GA 09/2013 Ko
    [M:PMG]VCRNUM([M:PMG]NBLIG)    = [M:MGP]VCRNUM(I)
    [M:PMG]VCRLIN([M:PMG]NBLIG)    = [M:MGP]VCRLIN(I)
    [M:PMG]VCRSEQ([M:PMG]NBLIG)    = [M:MGP]VCRSEQ(I)
    # sr 04.05 demande 24624
    [M:PMG]ORDFCY([M:PMG]NBLIG)    = [M:MGP]POHFCY(I)
    [M:PMG]ORIFCY([M:PMG]NBLIG)    = [M:MGP]ORIFCY(I)
    [M:PMG]STOFCY([M:PMG]NBLIG)    = [M:MGP]STOFCY(I)
    [M:PMG]BPRNUM([M:PMG]NBLIG)    = [M:MGP]BPSNUM(I)
    [M:PMG]PJT([M:PMG]NBLIG)       = [M:MGP]PJT(I)
    [M:PMG]ENDDAT([M:PMG]NBLIG)    = [M:MGP]REQDAT(I)
    [M:PMG]STU([M:PMG]NBLIG)       = [M:MGP]STU(I)
    [M:PMG]EXTSTUQTY([M:PMG]NBLIG) = [M:MGP]PECQTY(I)
    [M:PMG]PUU([M:PMG]NBLIG)       = [M:MGP]PUU(I)
    [M:PMG]EXTPUUQTY([M:PMG]NBLIG) = [M:MGP]PUUPECQTY(I)
    If ([M:MGP]FMI(I)=2 |[M:MGP]FMI(I)=3)
        Read [SOQ]SOQ0= [M:MGP]VCRNUM(I);[M:MGP]VCRLIN(I);[M:MGP]VCRSEQ(I)
        If !fstat
            If [M:MGP]PECQTY(I) < [F:SOQ]QTYSTU
                GMESSAGE = mess(18,197,1)-num$(I+1)+","-mess(255,194,1)
                Call ECR_TRACE(GMESSAGE,0) From GESECRAN : GPURTRACE = 2
                Goto SUIVANTPO
            Else
                If [F:SOQ]FMINUM=""
                    [M:PMG]SOHNUM([M:PMG]NBLIG)     = [M:MGP]VCRNUM(I)
                    [M:PMG]SOPLIN([M:PMG]NBLIG)     = [M:MGP]VCRLIN(I)
                    [M:PMG]SOQSEQ([M:PMG]NBLIG)     = [M:MGP]VCRSEQ(I)
                Endif
            Endif
            # Issue 91423 GA 12/2013 site d'expédition particulier
            If [F:SOQ]STOFCY<>"" & [F:SOQ]STOFCY<>[M:MGP]STOFCY(I)
               [M:MGP]STOFCY(I)=[F:SOQ]STOFCY
            Endif
        Endif
    Endif
    # point d'entrée permettant de renseigner des zones spécifiques - 39129 mm 01.07
    GPOINT = "LOADZON" : Gosub ENTREE From EXEFNC
    #
    [M:PMG]NBLIG     += 1
$SUIVANTPO
Next I
SAVIND = 0

$UPDPO
If [M:PMG]NBLIG <> 0
    Call TEMPON(mess(357,197,1)) From GESECRAN
    Call UPD_PURCHASE
Endif

If SAVIND : Goto LECPO : Endif

# seconde phase, génération commandes sous-traitance
SAVIND = 0
$LECPOST

WRET=0
Raz [M:PMG]
[M:PMG]MAJCOD     = "C"
[M:PMG]MAJTYP     = "F"
[M:PMG]RGRFLG     = 1
[M:PMG]MSGFLG     = 1
[M:PMG]TRAFLG     = 2
If [M:MGP]PLANNER = ""
    [M:PMG]REQUSR     = GUSER
Else
    [M:PMG]REQUSR     = [M:MGP]PLANNER
Endif
[M:PMG]PSHFCY     = [M:MGP]FCY    # FQ 76315 GA 09/2011 avant ""
[M:PMG]PRQDAT     = date$
[M:PMG]NBLIG      = 0
For I = SAVIND To [M:MGP]NBLIG - 1
    If [M:PMG]NBLIG > WMAX : SAVIND = I : Goto UPDPOST : Endif
    If [M:MGP]PECQTY(I) = 0   : Goto SUIVANTPOST : Endif
    If [M:MGP]BPSNUM(I) = ""  : Goto SUIVANTPOST : Endif
    If [M:MGP]POHNUM(I) <> "" : Goto SUIVANTPOST : Endif
    # GA 08/2006 cas des EOF commande de sous-traitance
    #----If [M:MGP]WIPTYP(I) <> 4  : Goto SUIVANTPOST : Endif
    If !find([M:MGP]WIPTYP(I),4,13): Goto SUIVANTPOST : Endif
    If [M:MGP]PUUPECQTY(I) = 0     : Goto SUIVANTPOST : Endif

    If [M:MGP]WIPNUM(I) <> ""
        Gosub CHECK_WIP
        If WRET : Goto SUIVANTPOST : Endif
    Endif

    [M:PMG]WIPTYP([M:PMG]NBLIG)    = [M:MGP]WIPTYP(I)
    [M:PMG]WIPSTA([M:PMG]NBLIG)    = [M:MGP]WIPSTA(I)
    [M:PMG]WIPNUM([M:PMG]NBLIG)    = [M:MGP]WIPNUM(I)
    # Issue 84787 GA 10/2012 Ko si on regroupe les Services
    #If [M:MGP]WIPTYP(I)=13
    #   [M:PMG]VCRTYP([M:PMG]NBLIG) = 36  : # GA 08/2006 36=EO
    #Elsif [M:MGP]WIPTYP(I)=4
    #   [M:PMG]VCRTYP([M:PMG]NBLIG) = 10  : # GA 08/2006 10=OF
    #Endif
    [M:PMG]VCRTYP([M:PMG]NBLIG)    = [M:MGP]VCRTYP(I) : # Issue 84787 GA 10/2012
    [M:PMG]VCRNUM([M:PMG]NBLIG)    = [M:MGP]VCRNUM(I) : # GA 08/2006
    [M:PMG]VCRLIN([M:PMG]NBLIG)    = [M:MGP]VCRLIN(I) : # GA 08/2006
    [M:PMG]VCRSEQ([M:PMG]NBLIG)    = [M:MGP]VCRSEQ(I) : # GA 08/2006
    [M:PMG]ITMREF([M:PMG]NBLIG)    = [M:MGP]ITMREF(I)
    #[M:PMG]ITMREFORI([M:PMG]NBLIG) = [M:MGP]ITMREFORI(I)  # Issue 91309 GA 09/2013 Ko
    If dim([M:MGP]POHFCY(I))>0 & [M:MGP]POHFCY(I)<>""
       [M:PMG]ORDFCY([M:PMG]NBLIG)    = [M:MGP]POHFCY(I)   # FQ 78863 GA 12/2011
    Else
       [M:PMG]ORDFCY([M:PMG]NBLIG)    = [M:MGP]ORIFCY(I)   # Issue 88156 GA 03/2013
    Endif
    [M:PMG]ORIFCY([M:PMG]NBLIG)    = [M:MGP]ORIFCY(I)
    [M:PMG]STOFCY([M:PMG]NBLIG)    = [M:MGP]STOFCY(I)
    [M:PMG]BPRNUM([M:PMG]NBLIG)    = [M:MGP]BPSNUM(I)
    [M:PMG]PJT([M:PMG]NBLIG)       = [M:MGP]PJT(I)
    [M:PMG]ENDDAT([M:PMG]NBLIG)    = [M:MGP]REQDAT(I)
    [M:PMG]STU([M:PMG]NBLIG)       = [M:MGP]STU(I)
    [M:PMG]EXTSTUQTY([M:PMG]NBLIG) = [M:MGP]PECQTY(I)
    [M:PMG]PUU([M:PMG]NBLIG)       = [M:MGP]PUU(I)
    [M:PMG]EXTPUUQTY([M:PMG]NBLIG) = [M:MGP]PUUPECQTY(I)
    # point d'entrée permettant de renseigner des zones spécifiques - 39129 mm 01.07
    GPOINT = "LOADZON" : Gosub ENTREE From EXEFNC
    [M:PMG]NBLIG     += 1
$SUIVANTPOST
Next I
SAVIND = 0

$UPDPOST

If [M:PMG]NBLIG <> 0
    Call TEMPON(mess(388,197,1)) From GESECRAN
    Call UPD_PURCHASE
Endif

If SAVIND : Goto LECPOST : Endif

# troisième phase, génération DL ferme
SAVIND = 0
$LECDLF

Raz [M:PMG]
[M:PMG]MAJCOD     = "C"
[M:PMG]MAJTYP     = "F"

# pas de regroupement sur commande ouverte pour le moment
[M:PMG]RGRFLG     = 1
[M:PMG]WRCPDAT    = ""

[M:PMG]MSGFLG     = 1
[M:PMG]TRAFLG     = 2
If [M:MGP]PLANNER = ""
    [M:PMG]REQUSR     = GUSER
Else
    [M:PMG]REQUSR     = [M:MGP]PLANNER
Endif
[M:PMG]PSHFCY     = [M:MGP]FCY    # FQ 76315 GA 09/2011 avant ""
[M:PMG]PRQDAT     = date$
[M:PMG]NBLIG      = 0
For I = SAVIND To [M:MGP]NBLIG - 1
    If [M:PMG]NBLIG > WMAX : SAVIND = I : Goto UPDDLF : Endif
    If [M:MGP]PECQTY(I) = 0   : Goto SUIVANTDLF : Endif
    If [M:MGP]POHNUM(I) = ""  : Goto SUIVANTDLF : Endif
    If [M:MGP]PUUPECQTY(I) = 0: Goto SUIVANTDLF : Endif

    If [M:MGP]WIPNUM(I) <> ""
        Gosub CHECK_WIP
        If WRET : Goto SUIVANTDLF : Endif
    Endif

    If find([M:MGP]WIPTYP(I),2,7)
        [M:PMG]WIPTYP([M:PMG]NBLIG) = [M:MGP]WIPTYP(I)
        [M:PMG]WIPSTA([M:PMG]NBLIG) = [M:MGP]WIPSTA(I)
        [M:PMG]WIPNUM([M:PMG]NBLIG) = [M:MGP]WIPNUM(I)
    Endif
    [M:PMG]POCNUM([M:PMG]NBLIG)    = [M:MGP]POHNUM(I)
    [M:PMG]VCRNUM([M:PMG]NBLIG)    = [M:MGP]VCRNUM(I)
    [M:PMG]VCRLIN([M:PMG]NBLIG)    = [M:MGP]VCRLIN(I)
    [M:PMG]VCRSEQ([M:PMG]NBLIG)    = [M:MGP]VCRSEQ(I)
    [M:PMG]ITMREF([M:PMG]NBLIG)    = [M:MGP]ITMREF(I)
    [M:PMG]ORDFCY([M:PMG]NBLIG)    = [M:MGP]POHFCY(I)   # FQ 78863 GA 12/2011
    [M:PMG]ORIFCY([M:PMG]NBLIG)    = [M:MGP]ORIFCY(I)
    [M:PMG]STOFCY([M:PMG]NBLIG)    = [M:MGP]STOFCY(I)
    [M:PMG]BPRNUM([M:PMG]NBLIG)    = [M:MGP]BPSNUM(I)
    [M:PMG]PJT([M:PMG]NBLIG)       = [M:MGP]PJT(I)
    [M:PMG]ENDDAT([M:PMG]NBLIG)    = [M:MGP]REQDAT(I)
    [M:PMG]STU([M:PMG]NBLIG)       = [M:MGP]STU(I)
    [M:PMG]EXTSTUQTY([M:PMG]NBLIG) = [M:MGP]PECQTY(I)
    [M:PMG]PUU([M:PMG]NBLIG)       = [M:MGP]PUU(I)
    [M:PMG]EXTPUUQTY([M:PMG]NBLIG) = [M:MGP]PUUPECQTY(I)
    # point d'entrée permettant de renseigner des zones spécifiques - 39129 mm 01.07
    GPOINT = "LOADZON" : Gosub ENTREE From EXEFNC
    [M:PMG]NBLIG     += 1
$SUIVANTDLF
Next I
SAVIND = 0

$UPDDLF
If [M:PMG]NBLIG <> 0
    Call TEMPON(mess(237,197,1)) From GESECRAN
    Call UPD_PURCHASE
Endif
If SAVIND : Goto LECDLF : Endif

Call TEMPOFF From GESECRAN
# lecture du fichier trace si nécessaire
If GPURTRACE
  Call FERME_TRACE From LECFIC : Call LEC_TRACE From LECFIC
  GPURTRACE=0 : GTRACE=""
Endif
#----- Restauration variables globales -----#
Gosub REST_GLOB From TRTX3GLOB

[M:MGP]REACT = 2
Return

########################################################################
# GH 15/05/2014 bug 99197

Subprog CRE_MTO_SO_PO(WIPTYP,WIPNUM,ITM)
Value Integer WIPTYP
Value Char    WIPNUM(), ITM()

If !clalev([M:PMG]) | !clalev([F:SOQ]) : End : Endif

Local Decimal WLIKMAX
Local Integer I

For I=0 To [M:PMG]NBLIG-1
  If [M:PMG]WIPTYP(I)=[L]WIPTYP & [M:PMG]WIPNUM(I)=[L]WIPNUM & [M:PMG]ITMREF(I)=[L]ITM
     Read [SOQ]SOQ0=[M:PMG]VCRNUM(I);[M:PMG]VCRLIN(I);[M:PMG]VCRSEQ(I)
     If !fstat
        WLIKMAX = [M:PMG]EXTSTUQTY(I)
        Gosub CRE_MTO_SO_PO From PURMTOLIB
     Endif
     Break
  Endif
Next I
End

########################################################################
# vérif encours
$CHECK_WIP
WRET=0
# Issue 84787 GA 10/2012 avant [M:MGP]EXTQTY(I)
Call CHECK_WIP([M:MGP]WIPTYP(I), [M:MGP]ITMREF(I), [M:MGP]WIPNUM(I), [M:MGP]RMNEXTQTY(I), C_QTY, WRET) From MFGLIB
If !WRET
    Return
Else
    GMESSAGE = mess(18,197,1)-num$(I+1)+","-mess(80,197,1)-[M:MGP]ITMREF(I)-"("+num$([M:MGP]PUUPECQTY(I))-[M:MGP]PUU(I)
&              +")"-num$(WRET)

    Call ECR_TRACE(GMESSAGE,0) From GESECRAN : GPURTRACE = 2
    GMESSAGE = "            "+mess(427,197,1)
    Call ECR_TRACE(GMESSAGE,0) From GESECRAN
Endif

Return

########################################################################
# Préparation du filtre sur la table encours                           #
########################################################################
$LOAD_FILTER
WFLT = [M:MGP]FLT
Raz CRITERE
Raz CRITERE1
Raz CRITERE2
Raz CRITERE3
Raz CRITERE4
# planificateur prod
If [F:BTS]PLANNER = 2 & [F:BTS]BUYER <> 2             # GA 08/2006 sauf Planif. ss-trait.
    If WFLT > 15                                      # WOS
        CRITERE  = "(WIPTYP=5 & WIPSTA=3)"
        Gosub LOAD_CRITERE
        WFLT -= 16
    Endif

    If WFLT > 7                                       # WOP
        CRITERE  = "(WIPTYP=5 & WIPSTA=2 & FMI<>5)"
        Gosub LOAD_CRITERE
        WFLT -= 8
    Endif

    If WFLT > 3                                       # SOF
        #CRITERE  = "(WIPTYP=1 & WIPSTA=1 & FMI<>5)"  # GH 25/04/2014 bug 84573
        CRITERE  = "(WIPTYP=1 & WIPSTA=1 & FMI=1)"
        Gosub LOAD_CRITERE
        WFLT -= 4
    Endif

    If WFLT > 1                                       # MWF
        CRITERE  = "(WIPTYP=6 & WIPSTA=1)"
        Gosub LOAD_CRITERE
        WFLT -= 2
    Endif

    If WFLT > 0                                       # TPF
        #CRITERE  = "(WIPTYP=8 & WIPSTA=1)"           # GH 25/04/2014 bug 84573
        CRITERE  = "(WIPTYP=8 & WIPSTA=1 & FMI=1)"
        Gosub LOAD_CRITERE
        WFLT -= 1
    Endif
Endif

# Ajout GA 08/2006 <Planif. ss-trait.>
If [F:BTS]PLANNER = 2 & [F:BTS]BUYER = 2
    If WFLT > 15                                      # EOS
        CRITERE  = "(WIPTYP=13 & WIPSTA=3)"
        Gosub LOAD_CRITERE
        WFLT -= 16
    Endif

    If WFLT > 7
        CRITERE  = "(WIPTYP=13 & WIPSTA=2)"           # EOP
        Gosub LOAD_CRITERE
        WFLT -= 8
    Endif

    If WFLT > 3                                       # SOF
        #CRITERE  = "(WIPTYP=1 & WIPSTA=1 & FMI<>5)"  # GH 25/04/2014 bug 84573
        CRITERE  = "(WIPTYP=1 & WIPSTA=1 & FMI=1)"
        Gosub LOAD_CRITERE
        WFLT -= 4
    Endif

    If WFLT > 1                                       # MSF
        CRITERE  = "(WIPTYP=3 & WIPSTA=1)"
        Gosub LOAD_CRITERE
        WFLT -= 2
    Endif

    If WFLT > 0                                       # TPF
        #CRITERE  = "(WIPTYP=8 & WIPSTA=1)"           # GH 25/04/2014 bug 84573
        CRITERE  = "(WIPTYP=8 & WIPSTA=1 & FMI=1)"
        Gosub LOAD_CRITERE
        WFLT -= 1
    Endif

Endif

# approvisionneur
If [F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2
    If WFLT > 7                                       # 30400 MM 05.05
        If [F:BTS]APPBUY = 2                          # POS
          CRITERE  = "(WIPTYP=2 & WIPSTA=3)"
          Gosub LOAD_CRITERE
        Endif
        If [F:BTS]APPINT = 2                          # TRS
          CRITERE  = "(WIPTYP=7 & WIPSTA=3)"
          Gosub LOAD_CRITERE
        Endif
        WFLT -= 8
    Endif

    If WFLT > 3                                       # SOF
        CRITERE  = "(WIPTYP=1 & WIPSTA=1 & FMI<>5 & FMI<>6)"
        Gosub LOAD_CRITERE
        WFLT -= 4
    Endif

    If WFLT > 1                                       # MWF
        CRITERE  = "(WIPTYP=6 & WIPSTA=1)"
        Gosub LOAD_CRITERE
        WFLT -= 2
    Endif

    If WFLT > 0                                       # TPF
        #CRITERE  = "(WIPTYP=8 & WIPSTA=1)"           # GH 25/04/2014 bug 84573
        CRITERE  = "(WIPTYP=8 & WIPSTA=1 & FMI<>5 & FMI<>6)"
        Gosub LOAD_CRITERE
        WFLT -= 1
    Endif
Endif

# acheteur
If [F:BTS]PLANNER=1 & ([F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2)    # GA 08/2006 sauf Planif. ss-trait.
    If WFLT > 31                                      # EOF     # GA 08/2006 achat de sous-traitance
        CRITERE  = "(WIPTYP=13 & WIPSTA=1)"
        Gosub LOAD_CRITERE

        #CRITERE  = "(WIPTYP=4&WIPSTA=1)"             # SCF     # GA 08/2006 SCF provenant d'un OF uniquement, sinon EOF
        CRITERE  = "(WIPTYP=4 & WIPSTA=1 & VCRTYP=10)"
        Gosub LOAD_CRITERE

        WFLT -= 32
    Endif

    If WFLT > 15
        If [F:BTS]BUYER = 2                           # POS
            CRITERE  = "(WIPTYP=2 & WIPSTA=3)"
            Gosub LOAD_CRITERE
        Endif
        If [F:BTS]INTBUY = 2                          # TRS
            CRITERE  = "(WIPTYP=7 & WIPSTA=3)"
            Gosub LOAD_CRITERE
        Endif
        WFLT -= 16
    Endif

    If WFLT > 7
        If [F:BTS]BUYER = 2                           # POP
            CRITERE  = "(WIPTYP=2 & WIPSTA=2)"
            Gosub LOAD_CRITERE
        Endif
        If [F:BTS]INTBUY = 2                          # TRP
            CRITERE  = "(WIPTYP=7 & WIPSTA=2)"
            Gosub LOAD_CRITERE
        Endif
        WFLT -= 8
    Endif

    If WFLT > 3                                       # SOF
        CRITERE  = "(WIPTYP=1 & WIPSTA=1 & FMI<>5 & FMI<>6)"
        Gosub LOAD_CRITERE
        WFLT -= 4
    Endif

    If WFLT > 1                                       # MWF
        CRITERE  = "(WIPTYP=6 & WIPSTA=1)"
        Gosub LOAD_CRITERE
        WFLT -= 2
    Endif

    If WFLT > 0                                       # TPF
        #CRITERE  = "(WIPTYP=8 & WIPSTA=1)"           # GH 25/04/2014 bug 84573
        CRITERE  = "(WIPTYP=8 & WIPSTA=1 & FMI<>5 & FMI<>6)"
        Gosub LOAD_CRITERE
        WFLT -= 1
    Endif
Endif

# fin de la première partie
If CRITERE1 <> "" : CRITERE1 += ")" : Else : CRITERE1 = "WIPTYP=99" : Endif

Return

########################################################################
$LOAD_FILTER2

CRITERE3 = "1=1"
CRITERE4 = "1=1"
CRITERE = "(find(WIPTYP,13,4)<>0 | RMNEXTQTY>(ALLQTY+MTOQTY))"
Gosub LOAD_CRITERE2

If [F:BTS]PLANNER = 2
    If [M:MGP]ITMREFS<>""  # Issue 7729 GA 08/2014 sauf si selection par gamme
      # article
      CRITERE = "[F:ORD]ITMREF=[M:MGP]ITMREFS"                           # article
      Gosub LOAD_CRITERE2
    Endif
    If [F:BTS]BUYER <> 2 & dim([M:MGP]ROUNUMS)>0 & [M:MGP]ROUNUMS<>""  # Issue 7729 GA 08/2014 planificateur prod uniquement
      # article
      CRITERE = "([F:ITF]ITMREF=[M:MGP]ROUNUMS | ([F:ITF]MFGROU=[M:MGP]ROUNUMS&[F:ITF]MFGROUALT=[M:MGP]ROUALTS))"  # gamme/alternative
      Gosub LOAD_CRITERE2
    Endif
    # planificateur/approvisionneur
    Case GPLNFLT
        When 2:        CRITERE = '([F:ITF]PLANNER=[M:MGP]PLANNER|[F:ITF]PLANNER="")'   # filtre planificateur
                       Gosub LOAD_CRITERE2
        When 3:        CRITERE = '[F:ITF]PLANNER=[M:MGP]PLANNER'   # filtre planificateur
                       Gosub LOAD_CRITERE2
    Endcase
Else
    If [F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2
        # planificateur/approvisionneur
        Case GPLNFLT
            When 2:        CRITERE = '([F:ITF]PLANNER=[M:MGP]PLANNER|[F:ITF]PLANNER="")'   # filtre planificateur
                           Gosub LOAD_CRITERE2
            When 3:        CRITERE = '[F:ITF]PLANNER=[M:MGP]PLANNER'   # filtre planificateur
                           Gosub LOAD_CRITERE2
        Endcase
    Else
        Case GBUYFLT
            When 1:        # ben rien
            When 2:        CRITERE = '[F:ITF]BUY=[M:MGP]PLANNER'   # filtre acheteur
                           Gosub LOAD_CRITERE2
        Endcase
    Endif
    # article
    If [M:MGP]ITMREFSTR <> ""
        CRITERE = "ITMREF>=[M:MGP]ITMREFSTR"      # borne début article
        Gosub LOAD_CRITERE2
    Endif
    If [M:MGP]ITMREFEND<>""
        CRITERE = "ITMREF<=[M:MGP]ITMREFEND"      # borne fin   article
        Gosub LOAD_CRITERE2
    Endif
Endif

# site
If [M:MGP]FCY <> ""
    CRITERE = "STOFCY=[M:MGP]FCY"                # filtre site
    Gosub LOAD_CRITERE2
Endif

# affaire
If [M:MGP]PJTSTR <> ""
   CRITERE = "PJT>=[M:MGP]PJTSTR"               # borne début affaire
   Gosub LOAD_CRITERE2
Endif
If [M:MGP]PJTEND <> ""
   CRITERE = "PJT<=[M:MGP]PJTEND"               # borne fin   affaire
   Gosub LOAD_CRITERE2
Endif

If [M:MGP]VCRNUMSTR <> ""
   CRITERE = "VCRNUM>=[M:MGP]VCRNUMSTR"         # borne début pièce
   Gosub LOAD_CRITERE2
Endif
If [M:MGP]VCRNUMEND <> ""
   CRITERE = "VCRNUM<=[M:MGP]VCRNUMEND"         # borne fin   pièce
   Gosub LOAD_CRITERE2
Endif

If [M:MGP]VCRORISTR <>""
    CRITERE="VCRNUMORI>=[M:MGP]VCRORISTR"      # borne début pièce origine
    Gosub LOAD_CRITERE2
Endif
If [M:MGP]VCRORIEND <>""
    CRITERE ="VCRNUMORI<=[M:MGP]VCRORIEND"     # borne fin pièce origine
    Gosub LOAD_CRITERE2
Endif

# tiers
If [M:MGP]BPRNUMSTR <> ""
   CRITERE = "BPRNUM>=[M:MGP]BPRNUMSTR"         # borne début tiers
   Gosub LOAD_CRITERE2
Endif
If [M:MGP]BPRNUMEND <> ""
   CRITERE = "BPRNUM<=[M:MGP]BPRNUMEND"         # borne fin   tiers
   Gosub LOAD_CRITERE2
Endif

# date
If [M:MGP]ENDDATSTR <> [0/0/0]
   CRITERE = "ENDDAT>=[M:MGP]ENDDATSTR"         # borne date début
   Gosub LOAD_CRITERE2
Endif
If [M:MGP]ENDDATEND <> [0/0/0]
   CRITERE = "ENDDAT<=[M:MGP]ENDDATEND"         # borne date fin
   Gosub LOAD_CRITERE2
Endif

# date début
If [M:MGP]STRDATSTR <> [0/0/0]
   CRITERE = "STRDAT>=[M:MGP]STRDATSTR"         # borne date début
   Gosub LOAD_CRITERE3
Endif
If [M:MGP]STRDATEND <> [0/0/0]
   CRITERE = "STRDAT<=[M:MGP]STRDATEND"         # borne date début
   Gosub LOAD_CRITERE3
Endif

# Issue 110957 - 2015-10-07 by GH
If dim([M:MGP]IECCVALMAJ)>0
    If [M:MGP]IECCVALMAJ<>""
        CRITERE = "[F:ORD]ECCVALMAJ=[M:MGP]IECCVALMAJ"
        Gosub LOAD_CRITERE3
    Endif
    If [M:MGP]IECCVALMIN<>""
        CRITERE = "[F:ORD]ECCVALMIN=[M:MGP]IECCVALMIN"
        Gosub LOAD_CRITERE3
    Endif
Endif

If [F:BTS]PLANNER = 2 : Return : Endif

If [M:MGP]TCLCODSTR <> ""
   CRITERE = "[F:ITM]TCLCOD>=[M:MGP]TCLCODSTR"         # borne catégorie
   Gosub LOAD_CRITERE3
Endif
If [M:MGP]TCLCODEND <> ""
   CRITERE = "[F:ITM]TCLCOD<=[M:MGP]TCLCODEND"         # borne catégorie
   Gosub LOAD_CRITERE3
Endif

If dim([M:MGP]TSICODSTR) > 0                # familles statistiques
    For I = 0 To dim([M:MGP]TSICODSTR)-1
        If [M:MGP]TSICODSTR(I) <> ""
            CRITERE = "[F:ITM]TSICOD("+num$(I)+")>=[M:MGP]TSICODSTR("+num$(I)+")"
            Gosub LOAD_CRITERE3
        Endif
        If [M:MGP]TSICODEND(I) <> ""
            CRITERE = "[F:ITM]TSICOD("+num$(I)+")<=[M:MGP]TSICODEND("+num$(I)+")"
            Gosub LOAD_CRITERE3
        Endif
    Next I
Endif
Return

############################################################
$LOAD_CRITERE
If len(CRITERE)+len(CRITERE1)+1 < 255    # 73841
    If len(CRITERE1)=0
        CRITERE1 += "("
    Else
        CRITERE1 += "|"
    Endif
    CRITERE1 += CRITERE
Else
    Infbox mess (574,199,1)
Endif
Return

############################################################
$LOAD_CRITERE2
If len(CRITERE)+len(CRITERE1)+1 < 255
  CRITERE1 += "&"
  CRITERE1 += CRITERE
Else
  If CRITERE2 <> ""
     CRITERE2 += "&"
  Endif
  CRITERE2 += CRITERE
Endif
Return

############################################################
$LOAD_CRITERE3
If len(CRITERE)+len(CRITERE3)+1 < 255
  If CRITERE3 <> ""
      CRITERE3 += "&"
  Endif
  CRITERE3 += CRITERE
Else
  If CRITERE4 <> ""
     CRITERE4 += "&"
  Endif
  CRITERE4 += CRITERE
Endif
Return

###########################################################################
# Chargement du masque
$CHARGE_MGP

Effzo [MGP]20
Gosub LOAD_FILTER
Gosub LOAD_FILTER2
# Point d'entrée pour permettre à l'utilisateur de rajouter des sélections
Raz CUSFLT
GPOINT = "CUSSELFLT" : Gosub ENTREE From EXEFNC
If CUSFLT = "" : CUSFLT = "1=1" : Endif

If [F:BTS]PLANNER = 2  # Planif production ou sous-traitance: mono-article
    Goto CHARGE_MONO
Else
    Goto CHARGE_MULTI
Endif

#--------------------------------------------------------------------------------------#
# chargement version mono-article
$CHARGE_MONO
# Issue 107498/107 - 2016-06-22 by JUSYN : Filter out what shall not be grouped because project taskline not launched.
Local Integer LMTXFLG  #  check flag for project management treatment 1 = okay 0 = not okay

# Issue 7729 GA 08/2014 Manufacturing: group different products with a common routing
If dim([M:MGP]ROUNUMS)>0
   If ([M:MGP]ITMREFS = "" & [M:MGP]ROUNUMS = "") | [M:MGP]FCY = "" : Return : Endif
Else
   If [M:MGP]ITMREFS = "" | [M:MGP]FCY = "" : Return : Endif
Endif

# analyse présence formule de sélection
If [M:MGP]FORMULE  = ""
    FORMULE1 = "1=1"
Else
    Read [F:TFO]TFO0=10;[M:MGP]FORMULE
    If fstat
        FORMULE1 = "1=1"
    Else
        FORMULE1 = [F:TFO]FORFOR
    Endif
Endif

# Issue 7729 GA 08/2014 optimization: change to [LNK] to be able to filter on [F:ITF]MFGROU/MFGROUALT
# ATTENTION: vérifier s'il faut prévoir le cas d'encours n'ayant pas de ligne article-site associée ?
Link [ORD] With [ITF]ITF0=[F:ORD]ITMREF;[F:ORD]STOFCY, [ITM]ITM0=[F:ORD]ITMREF As [LNK]
If CRITERE2 <> ""
    Filter [LNK] Where evalue(CRITERE1) & evalue(CRITERE2) & evalue(CRITERE3) &
&                      evalue(CUSFLT) & evalue(FORMULE1)
&                Order By Key ORD0
Else
    Filter [LNK] Where evalue(CRITERE1) & evalue(CRITERE3) &
&                      evalue(CUSFLT) & evalue(FORMULE1)
&                Order By Key ORD0
Endif
[M:MGP]TOTPECQTY = 0
nolign=1
For [LNK]
    If nolign = WMAXT : Break : Endif

    If [F:ORD]WIPTYP <> 1 & [F:ORD]WIPSTA = 3
        If [M:MGP]MRPFLG = 1  & [F:ORD]ORI <> 5 : Goto NXT_MONO : Endif
        If [M:MGP]MRPFLG = 2  & [F:ORD]ORI <> 6 : Goto NXT_MONO : Endif
    Endif

    # GH 15/05/2014 bug 99197 # SOF/TPF de FMI=1 exclus si règle d'affectation 1<=>1 maj en tps réel
                              # pour ne pas générer des affectations entre une ressource et plusieurs besoins
    If nolign=1
       # Issue 7729 GA 08/2014
       # Raz [F:ITF]
       #WPTOCOD = func ITMLIB.GET_PTOCOD([M:MGP]ITMREFs,[M:MGP]FCY)
       WPTOCOD = func ITMLIB.GET_PTOCOD([F:ORD]ITMREF,[F:ORD]STOFCY)
       Read [PTO]PTO0=WPTOCOD
       If fstat : Raz [F:PTO] : Endif
       WPTODIR = ([F:PTO]PTODIR=2 & [F:PTO]PTOREAL=2)
    Endif
    If WPTODIR & [F:ORD]VCRTYP=2 & [F:ORD]FMI=1
       Goto NXT_MONO
    Endif

    # 20814 llc 04.04
    # point d'entrée permettant de sauter des enregistrements de la sélection
    GPE=0
    GPOINT = "CHECKORD" : Gosub ENTREE From EXEFNC
    If GPE : Goto NXT_MONO : Endif

    # Issue 107498/107 - 2016-06-22 by JUSYN : Filter out what shall not be grouped because project taskline not launched.
    # Issue number 107498/18 - 2016-08-15 by JUSYN : Only when activity code PJM active
    If func AFNC.ACTIV("PJM")
        Gosub CHECK_PROJECT_CONDITIONS
    Else
        LMTXFLG = 1
    Endif
    If LMTXFLG = 0 : Goto NXT_MONO : Endif
    #

    [M:MGP] = [F:ORD]
    # Issue 7729 GA 08/2014 [F:ITF] already read
    #If [F:ITF]ITMREF <> [F:ORD]ITMREF & [F:ITF]STOFCY <> [M:MGP]FCY
    #    Read [ITF]ITF0=[F:ORD]ITMREF;[M:MGP]FCY
    #    If fstat : Raz [F:ITF] : Endif
    #Endif
    [M:MGP]PLANNER2(nolign-1) = [F:ITF]PLANNER
    [M:MGP]BUY(nolign-1)      = [F:ITF]BUY
    #[M:MGP]POHFCY(nolign-1)  = [M:MGP]FCY # FQ 76315 GA 09/2011 : # GH bug 77656 08/11/11
    If dim([M:MGP]POHFCY(nolign-1))>0 & find([F:ORD]VCRTYP,10,36) # Issue 84787 GA 10/2012
       [M:MGP]POHFCY(nolign-1)   = [M:MGP]ORIFCY(nolign-1)
    Endif
    [M:MGP]WIPTYPSTA(nolign-1)= mess([F:ORD]WIPTYP,341,1)+mess([F:ORD]WIPSTA,342,1)
    If dim([M:MGP]XMRPMES(nolign-1)) > 0
        If [M:MGP]MRPMES(nolign-1) > 0
            [M:MGP]XMRPMES(nolign-1) = mess([M:MGP]MRPMES(nolign-1),318,1)
        Else
            [M:MGP]XMRPMES(nolign-1) = mess(1,318,1)
        Endif
    Endif

    ## GH 14/04/2014 bug 97405
    #[M:MGP]PECQTY(nolign-1)     = [M:MGP]RMNEXTQTY(nolign-1)-[M:MGP]ALLQTY(nolign-1)-[M:MGP]MTOQTY(nolign-1)
    [M:MGP]PECQTY(nolign-1)     = [M:MGP]RMNEXTQTY(nolign-1)
    If !find([M:MGP]WIPTYP(nolign-1),13,4)
       [M:MGP]PECQTY(nolign-1) -= [M:MGP]ALLQTY(nolign-1) + [M:MGP]MTOQTY(nolign-1)
    Endif
    ##
    [M:MGP]FIE(nolign-1) = 1+([M:MGP]PECQTY(nolign-1) <> 0)                # 01.03
    [M:MGP]TOTPECQTY    += [M:MGP]PECQTY(nolign-1)

    If [F:ORD]WIPTYP = 5 & find([F:ORD]WIPSTA,1,2)
        Read [MFG]MFG0=[F:ORD]VCRNUM
        If !fstat
            [M:MGP]ROUNUM(nolign-1) = [F:MFG]ROUNUM
            [M:MGP]ROUALT(nolign-1) = [F:MFG]ROUALT
        Endif
        # Issue 7729 GA 08/2014
        Read [MFI]MFI0=[F:ORD]VCRNUM;[F:ORD]VCRLIN
        If !fstat
            [M:MGP]BOMALT(nolign-1) = [F:MFI]BOMALT
        Endif
    Endif

    # Issue 84787 GA 10/2012 idem CHARGE_MULTI
    # récupération données supplémentaires sur document
    #If find([M:MGP]WIPTYP(nolign-1),1,2,4,5,7,9,13) : # GH 14/11/12 bug 85907
       Default Mask [MGP] : Gosub GET_DOCUMENT_DATA From BENCHLIB
    #Endif

    If [F:ORD]WIPTYP = 5 & [F:ORD]WIPSTA = 2
        WTOTPEC = 0
        Call CUM_PEC([F:ORD]VCRTYP, [F:ORD]VCRNUM, [F:ORD]VCRLIN, [F:ORD]VCRSEQ, [F:ORD]WIPSTA,
&                    WTOTPEC, WTOTWOP, WTOTWOPC) From TRTWIP
        If WTOTPEC > 0
            [M:MGP]FLGPEC(nolign-1) = 2
            [M:MGP]WIPTYPSTA(nolign-1) += "*"
            [M:MGP]FLGREG(nolign-1) = 2
        Else
            [M:MGP]FLGPEC(nolign-1) = 1
        Endif
    Endif

    # Issue 110957 - 2015-10-07 by GH
    If dim([M:MGP]CRID)>0 & varmode([M:MGP]CRID(nolign-1))<>3
       If dim([M:MGP]IECCVALMAJ)<0 | ([F:ORD]ECCVALMAJ=[M:MGP]IECCVALMAJ & [F:ORD]ECCVALMIN=[M:MGP]IECCVALMIN)
          [M:MGP]CRID(nolign-1) = [M:MGP]ICRID
       Else
          [M:MGP]CRID(nolign-1) = func TRTX3FNC.CCMID([F:ORD]ITMREF,[F:ORD]ECCVALMAJ,[F:ORD]ECCVALMIN)
       Endif
       If dim([M:MGP]CRFLG)>0
          [M:MGP]CRFLG(nolign-1) = string$([M:MGP]CRID(nolign-1)<>"","151")
       Endif
    Endif

    # point d'entrée permettant de renseigner des zones spécifiques
    GPOINT = "ADDLIN" : Gosub ENTREE From EXEFNC

    nolign += 1
$NXT_MONO
Next
Goto FIN_CHARGE

#------------------------------------------------------------------------------------------#
# chargement version multi-article
$CHARGE_MULTI
Local Char WSTOFCY(GLONFCY)
# Issue 107498/107 - 2016-06-22 by JUSYN : Filter out what shall not be grouped because project taskline not launched.
Local Integer LMTXFLG  #  check flag for project management treatment 1 = okay 0 = not okay

# analyse présence formule de sélection
If [M:MGP]FORMULE  = ""
    FORMULE1 = "1=1"
Else
    Read [F:TFO]TFO0=10;[M:MGP]FORMULE
    If fstat
        FORMULE1 = "1=1"
    Else
        FORMULE1 = [F:TFO]FORFOR
    Endif
Endif

If CRITERE2 <> ""
    Link [ORD] With [ITF]ITF0=[F:ORD]ITMREF;[F:ORD]STOFCY, [ITM]ITM0=[F:ORD]ITMREF As [ORDX]
&              Where evalue(CRITERE1)&evalue(CRITERE2)&evalue(CRITERE3)&evalue(FORMULE1)&
&                    evalue(CUSFLT)
&              Order By Key ORD0
Else
    Link [ORD] With [ITF]ITF0=[F:ORD]ITMREF;[F:ORD]STOFCY, [ITM]ITM0=[F:ORD]ITMREF As [ORDX]
&              Where evalue(CRITERE1)&evalue(CRITERE3)&evalue(FORMULE1) &
&                    evalue(CUSFLT)
&              Order By Key ORD0
Endif
Raz [F:PTO]
[M:MGP]TOTPECQTY = 0
nolign=1
For [ORDX]
    If nolign = WMAXT : Break : Endif

    If [F:ORD]WIPTYP <> 1 & [F:ORD]WIPSTA = 3
        If [M:MGP]MRPFLG = 1  & [F:ORD]ORI <> 5 : Goto NXT_1 : Endif
        If [M:MGP]MRPFLG = 2  & [F:ORD]ORI <> 6 : Goto NXT_1 : Endif
    Endif

    # GH 15/05/2014 bug 99197 # SOF/TPF de FMI=1 exclus si règle d'affectation 1<=>1 maj en tps réel
                              # pour ne pas générer des affectations entre une ressource et plusieurs besoins
    If [F:ITF]PTOCOD<>"" : WPTOCOD = [F:ITF]PTOCOD : Else WPTOCOD = GDEFPTO : Endif
    If [F:PTO]PTOCOD <> WPTOCOD
       Read [PTO]PTO0=WPTOCOD
       If fstat : Raz [F:PTO] : Endif
    Endif
    If [F:PTO]PTODIR=2  & [F:PTO]PTOREAL=2 & [F:ORD]VCRTYP=2 & [F:ORD]FMI=1
       Goto NXT_1
    Endif

    # 20814 llc 04.04
    # point d'entrée permettant de sauter des enregistrements de la sélection
    GPE=0
    GPOINT = "CHECKORD" : Gosub ENTREE From EXEFNC
    If GPE : Goto NXT_1 : Endif

    If ([F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2) & [F:ITM]PRQFLG = 2 & !([F:ORD]WIPTYP=2 & [F:ORD]WIPSTA=2)
        Goto NXT_1
    Endif

    If ([F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2) & [F:ITM]ITMSTA <> 1
        Goto NXT_1
    Endif

    # Issue 107498/107 - 2016-06-22 by JUSYN : Filter out what shall not be grouped because project taskline not launched.
    # Issue number 107498/18 - 2016-08-15 by JUSYN : Only when activity code PJM active
    If func AFNC.ACTIV("PJM")
        Gosub CHECK_PROJECT_CONDITIONS
    Else
        LMTXFLG = 1
    Endif
    If LMTXFLG = 0 : Goto NXT_1 : Endif
    #

    [M:MGP] = [F:ORD]
    WSTOFCY = [F:ORD]STOFCY
    # Issue 91423 GA 12/2013 site d'expédition particulier sur la SOF ?
    If find([F:ORD]FMI,2,3) | [F:ORD]VCRTYP=2
         Read [SOQ]SOQ0= [F:ORD]VCRNUM;[F:ORD]VCRLIN;[F:ORD]VCRSEQ
         If !fstat
            If find([F:ORD]FMI,2,3) & ([F:SOQ]FMINUM<>"" | [F:BTS]APPBUY  = 2 | [F:BTS]APPINT = 2)
               # Si transaction Approvisionneur et contremarque: pas de DA
               # Si on a déjà généré une POF à partir de sa SOF de contremarque, la ligne n'apparait pas
                Goto NXT_1
            Endif
            # Issue 91423 GA 12/2013 site d'expédition particulier
            If [F:SOQ]STOFCY<>"" & [F:SOQ]STOFCY<>[M:MGP]STOFCY(nolign-1)
               [M:MGP]STOFCY(nolign-1)=[F:SOQ]STOFCY
               WSTOFCY=[F:SOQ]STOFCY
               Read [ITF]ITF0=[M:MGP]ITMREF(nolign-1);WSTOFCY
               If fstat : Raz [F:ITF] : Endif
            Endif
         Endif
    Endif
    #
    If [F:FCY]FCY <> WSTOFCY
       Read [FCY]FCY0 = WSTOFCY # Issue 91423 GA 12/2013 [F:ORD]STOFCY
       If fstat : Raz [F:FCY] : Endif
    Endif
    [M:MGP]STOSOC(nolign-1) = [F:FCY]LEGCPY

    [M:MGP]WIPTYPSTA(nolign-1)  = mess([F:ORD]WIPTYP,341,1)+mess([F:ORD]WIPSTA,342,1)

    ISINTERCPY = 0
   # Issue 93777 GA 12/2013 en priorité le fournisseur indiqué sur l'encours
    If func CBNLIB.ISDEM([F:ORD]WIPTYP)
       # when a demand order
       [M:MGP]BPSNUM(nolign-1) = ""  : # Bug 117377 GH 30/06/2016 - supplier to generate the resource has to be found
    Else
       # chen a resource order
       [M:MGP]BPSNUM(nolign-1) = [F:ORD]BPRNUM
    Endif

   # FQ 63497 GA 06/2010 tenir compte des SOx intersite
    If [F:ORD]WIPTYP = 1 & GMODU(5) = 2
        If [F:ORD]BPRNUM <> ""
            Read [BPR]BPR0=[F:ORD]BPRNUM
            If fstat : Raz [F:BPR] : Endif

            # Inter-société ?
            If [F:BPR]FCY <> ""
                ISINTERCPY = func BENCHLIBP.ISINTERCPY([F:BPR]FCY,WSTOFCY)
            Endif

            # si on ne veut pas les SO inter-sociétés
            If ISINTERCPY
                If [F:BTS]ICPYFLG = 3 : Goto NXT_1 : Endif
                If ISINTERCPY : [M:MGP]WIPTYPSTA(nolign-1) +=  chr$(126) : Endif
            Endif
        Endif
        # si on ne veut que les SO inter-sociétés
        If !ISINTERCPY & [F:BTS]ICPYFLG = 2 : Goto NXT_1 : Endif

# GH 15/05/2014 bug 99197 DLVFLG inexistant dans SORDER !! à priori le test devrait porter sur DLVSTA
#                         mais En cours non géré sur les autres types d'ordre
# => pour l'instant, on ne gère l'affichage des ordres en-cours dans cette fonction
#        If [F:ORD]WIPSTA = 1
#            Read [SOH]SOH0=[F:ORD]VCRNUM
#            If fstat : Raz [F:SOH] : Endif
#            If dim([F:SOH]DLVFLG)>0 & [F:SOH]DLVFLG > 1 : [M:MGP]WIPTYPSTA(nolign-1) += ">" : Endif
#        Endif
    Endif
    If [F:ORD]WIPTYP = 2 & GMODU(6) = 2
        If [F:ORD]BPRNUM <> ""
            Read [BPR]BPR0=[F:ORD]BPRNUM
            If fstat : Raz [F:BPR] : Endif

            # Inter-société ?
            If [F:BPR]FCY <> ""
                ISINTERCPY = func BENCHLIBP.ISINTERCPY([F:BPR]FCY, WSTOFCY)
            Endif

            # si on ne veut pas les PO inter-sociétés
            If ISINTERCPY
                If [F:BTS]ICPYFLG = 3 : Goto NXT_1 : Endif
                If ISINTERCPY : [M:MGP]WIPTYPSTA(nolign-1) +=  chr$(126) : Endif
            Endif
        Endif

        # 41707 mm 09.07
        Read [BPS]BPS0 =[M:MGP]BPSNUM(nolign-1)
        If fstat : Raz [M:MGP]BPSNUM(nolign-1) : Endif
        If [M:MGP]BPSNUM(nolign-1) <> ""
            # Article géré  à la commande
            If [F:ITM]STDFLG =4
                Read [ITP]ITP0 =[M:MGP]ITMREF(nolign-1);[M:MGP]BPSNUM(nolign-1)
                If fstat : Raz [M:MGP]BPSNUM(nolign-1) : Endif
            Endif
            #
            If !find([M:MGP]APPPRF,2,3) & [F:BPR]FCY <> "" & !ISINTERCPY
                [M:MGP]BPSNUM(nolign-1) = ""
            Endif
            If !find([M:MGP]APPPRF,1,3) & ([F:BPR]FCY = "" | ([F:BPR]FCY <> "" & ISINTERCPY))
                [M:MGP]BPSNUM(nolign-1) = ""
            Endif
        Endif
        # si on ne veut que les PO inter-sociétés
        If !ISINTERCPY & [F:BTS]ICPYFLG = 2 : Goto NXT_1 : Endif
    Endif

    # récupération US, UA
    [M:MGP]STU(nolign-1) = [F:ITM]STU
    [M:MGP]PUU(nolign-1) = [F:ITM]PUU

    # 106430.n - Set item weight and volume and UOMs
    [M:MGP]ITMWEI(nolign-1)     = [F:ITM]ITMWEI
    [M:MGP]LINWEU(nolign-1)     = [F:ITM]WEU
    [M:MGP]ITMVOL(nolign-1)     = [F:ITM]ITMVOU
    [M:MGP]LINVOU(nolign-1)     = [F:ITM]VOU
    [M:MGP]PURBASPRI(nolign-1)  = [F:ITM]PURBASPRI

    #[M:MGP]ITMDES1(nolign-1) = [F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MGP]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    [M:MGP]PUUSTUCOE(nolign-1) = [F:ITM]PUUSTUCOE
    # analyse date proposée
    # Issue 115348 - 2016-07-27 by YARAM : Used funprog LTI_GET_EXTRCPDAT from benchlibp.src to calculate WOFS & EXTRCPDAT
    # So as to add price list lead time to the calculation.
    [M:MGP]REQDAT(nolign-1) = func BENCHLIBP.LTI_GET_EXTRCPDAT(WOFS, [F:ITM]OFS, [F:ITF]OFS, [M:MGP]ENDDAT(nolign-1), [F:ITM]ITMREF)

    [M:MGP]EXTRCPDAT(nolign-1)  = [M:MGP]REQDAT(nolign-1)
    [M:MGP]CAD(nolign-1) = 1
    Gosub CHARGE_WRCPDATL

    [M:MGP]PLANNER2(nolign-1)   = [F:ITF]PLANNER
    [M:MGP]BUY(nolign-1)        = [F:ITF]BUY
    If dim([M:MGP]POHFCY(nolign-1))>0 & find([F:ORD]VCRTYP,10,36) # Issue 84787 GA 10/2012
       [M:MGP]POHFCY(nolign-1)   = [M:MGP]ORIFCY(nolign-1)
    Endif

    # si POS, avec un fournisseur, on récupère l'UA du fournisseur - 37829 mm 10.06
    If find([F:ORD]WIPTYP,2,7) & [F:ORD]WIPSTA =3 & [M:MGP]BPSNUM(nolign-1) <>""
       Read [ITP]ITP0=[M:MGP]ITMREF(nolign-1);[M:MGP]BPSNUM(nolign-1)
       If fstat
           Raz [F:ITP]
       Else
          [M:MGP]PUU(nolign-1) = [F:ITP]PUU
       Endif
    Endif

    # si POP/TRP, on vérifie situation signature !
    If find([F:ORD]WIPTYP,2,7) & [F:ORD]WIPSTA = 2
        Case [F:ORD]ABBFIL
            When "PSD" : # lecture ligne DA
                         Read [PSD]PSD0 = [F:ORD]VCRNUM;[F:ORD]VCRLIN
                         If fstat : Goto NXT_1 : Endif
                         [M:MGP]PUU(nolign-1) = [F:PSD]PUU
                         If [F:PSD]LINAPPFLG < 3 : Goto NXT_1 : Endif
            When "POC" : # lecture ligne DL planifiée
                         Read [POH]POH0 = [F:ORD]VCRNUM
                         If fstat | [F:POH]APPFLG < 3 : Goto NXT_1 : Endif
 # Bug 117377 GH 30/06/2016 : # If [F:POH]BETFCY = 2 & find([M:MGP]APPPRF,2,3) | [F:POH]BETFCY = 1 & !find([M:MGP]APPPRF,1,3)
                         If ([F:POH]BETFCY = 2 & find([M:MGP]APPPRF,2,3)) | ([F:POH]BETFCY = 1 & find([M:MGP]APPPRF,1,3))
                            [M:MGP]POHNUM(nolign-1) = [F:ORD]VCRNUM
                            [M:MGP]POPLIN(nolign-1) = [F:ORD]VCRLIN
                            [M:MGP]BPSNUM(nolign-1) = [F:POH]BPSNUM
                         Endif
        Endcase
    Endif

    # si SCF, récupération fournisseur + prix!
    If [F:ORD]WIPTYP = 4 & [F:ORD]WIPSTA = 1 & [F:ORD]BPRNUM <> "" & [F:ORD]VCRTYP=10
        [M:MGP]BPSNUM(nolign-1) = [F:ORD]BPRNUM
        Filter [MFO] Where MFGNUM = [F:ORD]VCRNUM & WIPNUM = [F:ORD]WIPNUM Order By Key MFO0
        Read [MFO] First
        If !fstat
            [M:MGP]NETPRI(nolign-1) = [F:MFO]REFPRI
        Endif
        Filter [MFO]
    Endif
    If dim([M:MGP]POHFCY(nolign-1))>0 & find([F:ORD]VCRTYP,10,36) # Issue 84787 GA 10/2012
       [M:MGP]POHFCY(nolign-1)   = [M:MGP]ORIFCY(nolign-1)
    Endif

    If ([F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2) & [F:ITM]ITMSTA = 3
        [M:MGP]WIPTYPSTA(nolign-1) += "-"
    Endif

    If dim([M:MGP]XMRPMES(nolign-1)) > 0
        If [M:MGP]MRPMES(nolign-1) > 0
            [M:MGP]XMRPMES(nolign-1) = mess([M:MGP]MRPMES(nolign-1),318,1)
        Else
            [M:MGP]XMRPMES(nolign-1) = mess(1,318,1)
        Endif
    Endif
    If [F:ORD]WIPTYP = 1
        [M:MGP]RMNEXTQTY(nolign-1)  = [F:ORD]RMNEXTQTY
    Endif

    ## GH 14/04/2014 bug 97405
    #[M:MGP]PECQTY(nolign-1)     = [M:MGP]RMNEXTQTY(nolign-1)-[M:MGP]ALLQTY(nolign-1)-[M:MGP]MTOQTY(nolign-1)
    [M:MGP]PECQTY(nolign-1)     = [M:MGP]RMNEXTQTY(nolign-1)
    If !find(WIPTYP(nolign-1),13,4)
       [M:MGP]PECQTY(nolign-1) -= [M:MGP]ALLQTY(nolign-1) + [M:MGP]MTOQTY(nolign-1)
    Endif
    ##
    [M:MGP]FIE(nolign-1) = 1+([M:MGP]PECQTY(nolign-1) <> 0)
    [M:MGP]TOTPECQTY   += [M:MGP]PECQTY(nolign-1)

    Call UPD_PPLINTOTALS  # 106430.n

    [M:MGP]POHIND(nolign-1) = 1

    #If [F:ORD]ABBFIL="POC" & GMODU(6) = 2  : # Pour les DL uniquement : ## GH 18/01/2013 bug 87167
    If ([F:ORD]ABBFIL="POC" | ([F:ORD]WIPTYP=2 & [ORD]WIPSTA=3)) & GMODU(6) = 2  : # Pour les DL ou les POS : ## GH 11/03/2013 bug 87167
        # vérification présence contrat
        OK = 0
        ## GH 11/01/2013 bug 87167 init de WDATEREF
        If [M:MGP]ENDDAT(nolign-1) >= TODAY
            WDATEREF = [M:MGP]ENDDAT(nolign-1)
        Else
            WDATEREF = TODAY
        Endif
        ## GH 27/06/2012 bug 83199
        #Filter [POC] Where ITMREF = [F:ORD]ITMREF & ENDDAT >= WDATEREF & PRHFCY = [F:ORD]STOFCY
        Filter [POC] Where ITMREF = [F:ORD]ITMREF & ENDDAT >= WDATEREF & PRHFCY = WSTOFCY & STRDAT <= WDATEREF
        WPOHNUM = ""
        For [POC]POC2
            If fstat : Break : Endif
            If [F:POH]POHNUM <> [F:POC]POHNUM
                Read [POH]POH0 = [F:POC]POHNUM
                If fstat : Goto N_POC : Endif
            Endif
            If !find([F:POH]APPFLG,3,4,5)                    : Goto N_POC : Endif
            If [F:POH]CLEFLG = 2                             : Goto N_POC : Endif
            If [F:POH]BETFCY = 2 & !find([M:MGP]APPPRF,2,3)  : Goto N_POC : Endif
            If [F:POH]BETFCY = 1 & !find([M:MGP]APPPRF,1,3)  : Goto N_POC : Endif
            [M:MGP]POHIND(nolign-1) = 2
            If [F:ORD]WIPTYP = 1 & find([F:ORD]FMI,2,3) : Break : Endif
            # si contrat = oui, on récupère le n° de contrat + fournisseur
            If WPOHNUM = "" : WPOHNUM = [F:POH]POHNUM :  WBPSNUM = [F:POH]BPSNUM : Endif
            If [M:MGP]POHNUM(nolign-1) <> "" & [F:POC]POHNUM = [M:MGP]POHNUM(nolign-1)
                [M:MGP]PUU(nolign-1) = [F:POC]PUU
                OK = 1
            Endif
$N_POC
        Next
        Filter [POC]
        If !OK :  [M:MGP]POHNUM(nolign-1) = "" : Endif
        If [M:MGP]POHIND(nolign-1) = 2  & [M:MGP]POHNUM(nolign-1) = ""
            [M:MGP]POHNUM(nolign-1) = WPOHNUM
            [M:MGP]BPSNUM(nolign-1) = WBPSNUM
        Endif
    Endif

    # recherche fournisseur
    If [M:MGP]BPSNUM(nolign-1) = "" & [M:MGP]POHIND(nolign-1) = 1
        # 11.05 33075 (si TRS, traitement special)
        If [F:ORD]WIPTYP = 7 & [F:ORD]WIPSTA = 3
            [M:MGP]ORIFCY(nolign-1)   = [F:ORD]STOFCY   # FQ 59321 site de commande en V6 POHFCY
            Filter [BPR] Where BETFCY = 2 & FCY = [F:ORD]ORIFCY
&                        Order By Key BPR2
            For [BPR]
                # lecture fournisseur
                Read [BPS]BPS0=[F:BPR]BPRNUM
                If fstat : Raz [F:BPS] : Endif
                [M:MGP]BPSNUM(nolign-1) = [F:BPR]BPRNUM
                Break
            Next
            Filter [BPR]
        Elsif ISINTERCPY & [F:ORD]WIPTYP=1
          # Issue 84692 Dans ITP, FCY et BPRNUM n'existent pas: clause Where revue
          # FQ 63497 GA 06/2010 cas particulier SOx intersite: le fournisseur ne doit être ni le site courant, ni le site client
          # Filter [ITP] Where ITMREF=[F:ORD]ITMREF & FCY<>[F:ORD]ORIFCY & BPRNUM<>[F:ORD]BPRNUM & DOUFLG = 1 Order By Key ITP1
            Filter [ITP] Where ITMREF=[F:ORD]ITMREF & BPSNUM<>[F:ORD]BPRNUM & DOUFLG = 1 Order By Key ITP1
            For [ITP]
                Read [BPS]BPS0=[F:ITP]BPSNUM
                If !fstat & [F:BPS]ENAFLG=2 : # GH 06/07/2016 Bug 117056 - the supplier should be active
                  Read [BPR]BPR0=[F:ITP]BPSNUM
                  If fstat : Raz [F:BPR] : Endif
                  If ([F:BPR]FCY <> "" & find([M:MGP]APPPRF,2,3)) | ([F:BPR]FCY = "" & find([M:MGP]APPPRF,1,3))
                      [M:MGP]BPSNUM(nolign-1) = [F:ITP]BPSNUM
                      [M:MGP]PUU(nolign-1)    = [F:ITP]PUU
                      [M:MGP]PUUSTUCOE(nolign-1)    = [F:ITP]PUUSTUCOE
                      Break
                  Endif
                Endif
            Next
            Filter [ITP]
        Else
            Filter [ITP] Where ITMREF=[F:ORD]ITMREF & DOUFLG = 1 Order By Key ITP1
            For [ITP]
                Read [BPS]BPS0=[F:ITP]BPSNUM
                If !fstat & [F:BPS]ENAFLG=2 : # GH 06/07/2016 Bug 117056 - the supplier should be active
                  Read [BPR]BPR0=[F:ITP]BPSNUM
                  If !fstat & (([F:BPR]FCY <> "" & find([M:MGP]APPPRF,2,3)) | ([F:BPR]FCY = "" & find([M:MGP]APPPRF,1,3)))
                     If [F:BPR]FCY<>WSTOFCY : ## GH 28/07/2014 bug 101438
                      [M:MGP]BPSNUM(nolign-1) = [F:ITP]BPSNUM
                      [M:MGP]PUU(nolign-1)    = [F:ITP]PUU
                      [M:MGP]PUUSTUCOE(nolign-1)    = [F:ITP]PUUSTUCOE
                      Break
                     Endif
                  Endif
                Endif
            Next
            Filter [ITP]
        Endif
    Endif

  # Issue 115840 - 09-05-2016 by STLIG : Incorporate rounding type: up or down, into conversion type parameter.
  Call PCAL_QTY([M:MGP]PECQTY(nolign-1),
&               [M:MGP]STU(nolign-1),
&               [M:MGP]PUUPECQTY(nolign-1),
&               [M:MGP]PUU(nolign-1),
&               [M:MGP]ITMREF(nolign-1),
&               [M:MGP]BPSNUM(nolign-1),
&               func TRTACHQTE1.ROUND_CONVERSION_TYPE(1,[F:ITF]REOPOL),
&               WCOEF) From TRTACHQTE1

    If WCOEF <> 0 : [M:MGP]PUUSTUCOE(nolign-1) = 1/WCOEF : Endif

    # récupération données supplémentaires sur document
    #If find([M:MGP]WIPTYP(nolign-1),1,2,4,5,7,9,13) : # GH 14/11/12 bug 85907
       Default Mask [MGP] : Gosub GET_DOCUMENT_DATA From BENCHLIB
    #Endif

    # 01.05 27638
    If ([F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2) & ([M:MGP]BPSNUM(nolign-1) = "" | [M:MGP]PUUPECQTY(nolign-1) = 0)
        [M:MGP]FIE(nolign-1) = 1
    Endif
    If ([F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2) & ([M:MGP]PUUPECQTY(nolign-1) = 0)
        [M:MGP]FIE(nolign-1) = 1
    Endif
    #--------------------
    # 11.05 33075 (si TRS traitement spécial)
    # sr 04.05 demande 24624 initialisation du site d'achat
    # FQ 59321 GA 11/2009 If [M:MGP]WIPTYP(nolign-1) = 7 & [M:MGP]WIPTYP(nolign-1) = 3
    If [M:MGP]WIPTYP(nolign-1) = 7 & [M:MGP]WIPSTA(nolign-1) = 3
        [M:MGP]POHFCY(nolign-1)    = [M:MGP]STOFCY(nolign-1)
        # FQ 59321 GA 11/2009 idem v140 et V5 proposer le Fournisseur inter-site
        Filter [BPR] Where BETFCY = 2 & FCY = [F:ORD]ORIFCY
&                        Order By Key BPR2
        For [BPR]
            # lecture fournisseur
            Read [BPS] BPS0=[F:BPR]BPRNUM
            If fstat : Raz [F:BPS] : Endif
            [M:MGP]BPSNUM(nolign-1) = [F:BPR]BPRNUM
            Break
        Next
        Filter [BPR]
    Elsif [M:MGP]WIPTYP(nolign-1) = 8
        # GH 25/07/2016 bug 113721 -The purchase site should be the TP receipt site instead of the purchase site from which the TP was generated
        [M:MGP]POHFCY(nolign-1)    = [M:MGP]STOFCY(nolign-1)
    Else
        [M:MGP]POHFCY(nolign-1)    = [M:MGP]ORIFCY(nolign-1)
        If [F:FCY]FCY<>[M:MGP]ORIFCY(nolign-1)
            Read [FCY]FCY0=[M:MGP]ORIFCY(nolign-1)
            If fstat : Raz [F:FCY] : Endif
        Endif
    Endif

  # Issue 99743 GA 09/2014 code reused
    Gosub CTRL_POHFCY

    # Issue 110957 - 2015-10-07 by GH
    If dim([M:MGP]CRID)>0 & varmode([M:MGP]CRID(nolign-1))<>3
       [M:MGP]CRID(nolign-1) = func TRTX3FNC.CCMID([F:ORD]ITMREF,[F:ORD]ECCVALMAJ,[F:ORD]ECCVALMIN)
       If dim([M:MGP]CRFLG)>0
          [M:MGP]CRFLG(nolign-1) = string$([M:MGP]CRID(nolign-1)<>"","151")
       Endif
    Endif

    #------------------------

    # 20699 llc 04.04
    # point d'entrée permettant de renseigner des zones spécifiques
    GPOINT = "ADDLIN" : Gosub ENTREE From EXEFNC

    nolign += 1
$NXT_1
Next


$FIN_CHARGE
[M:MGP]NBLIG  = nolign-1
Gosub TRI_TAB
Gosub HIGHLIGHT
# 106430 - update purchase planning fields
Call UPD_PPHEADER
If dim([M:MGP]ORDCUR)>0
  [M:MGP]ORDCUR = GLOCALDEV
  [M:MGP]TOTCUR = GLOCALDEV
  Affzo [M:MGP]TOTCUR, ORDCUR
Endif

Filter [ORD]
#
Return

###########################################################################
$HIGHLIGHT
Affzo [MGP]1-99

If [F:BTS]PLANNER = 2 : Return : Endif

# mise en relief affectations
[M:HLIK]ABB          = "MGP"
[M:HLIK]VARABS       = "NBLIG"
[M:HLIK]NBREX        = 1
[M:HLIK]EXCLUDE(0)   = "FIE"

# réinitialisation style
# Chgstl [M:MGP]NBLIG  With ""                      # GH 10/04/2014 bug 95576

# application style
For I = 0 To [M:MGP]NBLIG - 1
    [M:HLIK]LINNUM = I
    Gosub HIGHLIGHT_LINE
Next I
Return

$HIGHLIGHT_CURLINE
## GH 10/04/2014 bug 95576
If [F:BTS]PLANNER = 2 : Return : Endif

[M:HLIK]ABB          = "MGP"
[M:HLIK]VARABS       = "NBLIG"
[M:HLIK]NBREX        = 1
[M:HLIK]EXCLUDE(0)   = "FIE"
[M:HLIK]LINNUM       = nolign-1
##
Gosub HIGHLIGHT_LINE
Return

$HIGHLIGHT_LINE
[M:HLIK]STYLE = ""
If [F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2
    If ([M:MGP]BPSNUM([M:HLIK]LINNUM) = "" | [M:MGP]PUUPECQTY([M:HLIK]LINNUM) = 0)
        [M:HLIK]STYLE = "MTOLINKC"
    Endif
Elsif [F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2
    If [M:MGP]PUUPECQTY([M:HLIK]LINNUM) = 0
        [M:HLIK]STYLE = "MTOLINKC"
    Endif
Endif

GPOINT = "STYLE" : Gosub ENTREE From EXEFNC         # GH 19/01/12 dm 78713
If [M:HLIK]STYLE<>""
   Gosub STYLE_HL_TABLIN From HLIGHTLIB
Else
   Chgstl [M:MGP]NBLIG([M:HLIK]LINNUM)  With ""     # GH 10/04/2014 bug 95576
Endif
Return

###########################################################################
$TRI_TAB
If [M:MGP]NBLIG <> 0
    WTRI = 0
    GPOINT = "CUSSRT" : Gosub ENTREE From EXEFNC
    If !WTRI
        # FQ 67298 GA 09/2010 ajout VCRNUM dans les tris
        Case [M:MGP]SRTCOD
            When 1: #Sorta [M:MGP]NBLIG [M:MGP]NBLIG Order By [M:MGP]ENDDAT(indice),[M:MGP]VCRNUM(indice) : # GH 06/03/2014 bug 97640
                    Sorta [M:MGP]NBLIG [M:MGP]NBLIG Order By [M:MGP]STOFCY(indice),[M:MGP]ENDDAT(indice),[M:MGP]VCRNUM(indice)
            When 2: Sorta [M:MGP]NBLIG [M:MGP]NBLIG Order By [M:MGP]ITMREF(indice),[M:MGP]ENDDAT(indice),[M:MGP]VCRNUM(indice)
            When 3: Sorta [M:MGP]NBLIG [M:MGP]NBLIG Order By [M:MGP]WIPTYPSTA(indice),[M:MGP]ENDDAT(indice),[M:MGP]VCRNUM(indice)
            When 4: Sorta [M:MGP]NBLIG [M:MGP]NBLIG Order By [M:MGP]VCRTYP(indice),[M:MGP]ENDDAT(indice),[M:MGP]VCRNUM(indice)
            When 5: Sorta [M:MGP]NBLIG [M:MGP]NBLIG Order By [M:MGP]ENDDAT(indice),[M:MGP]VCRNUM(indice)
            When 7: Sorta [M:MGP]NBLIG [M:MGP]NBLIG Order By [M:MGP]BPRNUM(indice),[M:MGP]VCRNUM(indice)    # Tiers
        Endcase
    Endif
Endif
Return

###########################################################################
$INC_ALL

Local Integer LINE_I : LINES_I = 0   # 107498/107

[M:MGP]TOTPECQTY = 0
For  I = 0 To [M:MGP]NBLIG-1

    ## GH 14/04/2014 bug 97405
    #[M:MGP]PECQTY(I)  = [M:MGP]RMNEXTQTY(I) - [M:MGP]ALLQTY(I) - [M:MGP]MTOQTY(I)#

    # Issue 107498/107 - only include lines with blank PJT or if management mode is available stock, source not project demand
    LINC_I = 0
    If ([M:MGP]PJT(I)<>"")
      Gosub CHECK_CAN_GROUP
    Endif
    If (LINC_I = 0)
      LINES_I += 1
      [M:MGP]PECQTY(I)     = [M:MGP]RMNEXTQTY(I)
      If !find([M:MGP]WIPTYP(I),13,4)
         [M:MGP]PECQTY(I) -= [M:MGP]ALLQTY(I) + [M:MGP]MTOQTY(I)
      Endif
      ##

      If [F:BTS]PLANNER <> 2
          # Issue 115840 - 23-05-2016 by STLIG : Incorporate rounding type: up or down, into conversion type parameter.
          Call PCAL_QTY([M:MGP]PECQTY(I),
&                       [M:MGP]STU(I),
&                       [M:MGP]PUUPECQTY(I),
&                       [M:MGP]PUU(I),
&                       [M:MGP]ITMREF(I),
&                       [M:MGP]BPSNUM(I),
&                       func TRTACHQTE1.ROUND_CONVERSION_TYPE(1,[F:ITF]REOPOL),
&                       GBIDD1) From TRTACHQTE1
      Endif
      [M:MGP]TOTPECQTY += [M:MGP]PECQTY(I)
      If [M:MGP]FLGPEC(I) = 2 : [M:MGP]FLGREG(I) = 2 : Endif
      # 01.05 27638  # V6 sauf planif. ss-traitance
      If [F:BTS]PLANNER <> 2 & ([F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2) & ([M:MGP]BPSNUM(I) = "" | [M:MGP]PUUPECQTY(I) = 0)
          [M:MGP]FIE(I)    = 1
      Else
          If ([F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2) & ([M:MGP]PUUPECQTY(I) = 0)
              [M:MGP]FIE(I)    = 1
          Else
              [M:MGP]FIE(I)    = 2
          Endif
      Endif
      # Issue Jira X3-3535 - 2016-09-13 by JUSYN : Tick field needs to be enabled again/at all
      Actzo [M:MGP]FIE(I)
      Actzo [M:MGP]FLGPEC(I)
   # Issue 107498/107 - assume these lines are not ticked
    Else
      # Issue 107498/107 - 2016-06-15 by JUSYN : quantity reset
      [M:MGP]TOTPECQTY       -= [M:MGP]PECQTY(I)
      [M:MGP]PECQTY(I) = 0
      If [F:BTS]PLANNER <> 2
          [M:MGP]PUUPECQTY(I) = 0
      Endif
      #
      If [M:MGP]FLGPEC(I) = 2 : [M:MGP]FLGREG(I) = 1 : Endif
      If [M:MGP]FIE(I) = 2 : [M:MGP]FIE(I) = 1 : Endif
      Grizo [M:MGP]FIE(I) # disable field
      Grizo [M:MGP]FLGPEC(I) # disable field
    Endif  # End issue 107498/107
    # Issue 107498/107 - 2016-06-10 by JUSYN : Disable enterable fields because of project link
    Call DISABLE_PROJ_LINES(I)
Next I
# 107498/107 - if no lines selected, then activate all lines so user can start picking
If (LINES_I = 0)
  Gosub EXC_ALL
Endif

Gosub HIGHLIGHT
Return

###########################################################################
$EXC_ALL
[M:MGP]TOTPECQTY = 0
For  I = 0 To [M:MGP]NBLIG-1
    [M:MGP]PECQTY(I)  = 0
    If [F:BTS]PLANNER <> 2
        [M:MGP]PUUPECQTY(I) = 0
    Endif
    If [M:MGP]FLGPEC(I) = 2 : [M:MGP]FLGREG(I) = 1 : Endif
    If [M:MGP]FIE(I) = 2 : [M:MGP]FIE(I) =1 : Endif
    Actzo [M:MGP]FIE(I) # Issue 107498/107 - enable field
    Actzo [M:MGP]FLGPEC(I) # Issue 107498/107 - enable field
    # Issue 107498/107 - 2016-06-10 by JUSYN : Disable enterable fields because of project link
    Call DISABLE_PROJ_LINES(I)
Next I
Gosub HIGHLIGHT
Return

###########################################################################
# CHECK_CAN_GROUP - if Management mode = Available stock, and source
#                   is not from Project demand then you can group this line
# Return:     LINC_I
#             0 - Management mode=Available stock, source not MTx, can group
#             1 - Management mode=Available stock, source MTx, can not group
#             2 - Management mode=By order, can not group
#
$CHECK_CAN_GROUP
  LINC_I = 0
  # Check Management mode = Available stock, source is from Project demand
  Read [ITM]ITM0=[M:MGP]ITMREF(I)
 #PATCH_1 If (fstat=0 and [F:ITM]STDFLG = 3)
 If (fstat=0 and [F:ITM]STDFLG >= 3)  #PATCH_1. Añado '>' para que pueda agrupar artículos que sean bajo pedido
        Filter [ORDM]
        Filter [ORDM] Where [F:ORDM]STOFCY = [M:MGP]STOFCY(I) and [F:ORDM]WIPTYP = 14 and [F:ORDM]VCRTYP = 40 and
&                   [F:ORDM]PJT = [M:MGP]PJT(I) and [F:ORDM]ITMREF = [M:MGP]ITMREF(I) and [F:ORDM]VCRLIN = [M:MGP]VCRLINORI(I)
        Read [ORDM] First
        # if from Project demand MTx
        If fstat=0
          LINC_I = 1
        Endif
        Filter [ORDM]
  # Management mode = By order
  Else
    LINC_I = 2
  Endif

Return

###########################################################################
$MAJ_CONSO_OF
For  I = 0 To [M:MGP]NBLIG-1
    If [M:MGP]PECQTY(I) = 0 : Goto SUIV : Endif

    Case [M:MGP]WIPTYP(I)
        When 1, 8 : # SOF et TPF : # GH 15/05/2014 bug 99197 ajout TPF
                Raz [M:MFGK]
                [M:MFGK]CODMAJ    = "S"
                [M:MFGK]CODTRS    = 1
                [M:MFGK]ITMREF    = [M:MGP]ITMREFS
                [M:MFGK]EXTQTY    = [M:MGP]PECQTY(I)
## GH 15/05/2014 bug 99197 paramètres supprimés
#                [M:MFGK]WIPNUM    = [M:MGP]WIPNUM(I)
#                [M:MFGK]WIPTYP    = [M:MGP]WIPTYP(I)
## GH 15/05/2014 bug 99197 paramètres ajoutés
                [M:MFGK]MFGFCY    = [M:MGP]FCY
                [M:MFGK]FMI       = [M:MGP]FMI(I)
                # SOF
                [M:MFGK]VCRNUMORI = [M:MGP]VCRNUM(I)
                [M:MFGK]VCRLINORI = [M:MGP]VCRLIN(I)
                [M:MFGK]VCRSEQORI = [M:MGP]VCRSEQ(I)
                # WOF
                [M:MFGK]MFGNUM    = GVCR
                [M:MFGK]MFGLIN    = GLIN
##
                Call MAJ_OF From MFGAUTLIB
                If [M:MFGK]CODRET <> 0 : Break : Endif

                # 01.06 34228
                Read [ORD]ORD3=[M:MGP]FCY;10;GVCR;GLIN;0
                If !fstat
                    Raz [M:ORCK]
                    [M:ORCK]MAJCOD = "C"
                    [M:ORCK]WIPNUM = [M:MGP]WIPNUM(I)
                    [M:ORCK]WIPTYP = [M:MGP]WIPTYP(I)
                    [M:ORCK]ITMREF = [M:MGP]ITMREFS
                    [M:ORCK]COVQTY = [M:MGP]PECQTY(I)
                    [M:ORCK]VCRTYPDST = 10
                    [M:ORCK]VCRNUMDST = [F:ORD]VCRNUM
                    [M:ORCK]VCRLINDST = [F:ORD]VCRLIN
                    [M:ORCK]VCRSEQDST = [F:ORD]VCRSEQ
                    [M:ORCK]WIPSTADST = [F:ORD]WIPSTA
                    [M:ORCK]WIPTYPDST = [F:ORD]WIPTYP
                    Call COVER From TRTWIP
                Endif

        When 5: # WOS/WOP
               Case [M:MGP]WIPSTA(I)
                    When 3:    If [M:MGP]PECQTY(I) >= [M:MGP]RMNEXTQTY(I)
                                   Raz [M:MFGK]
                                   [M:MFGK]CODMAJ = "A"
                                   [M:MFGK]CODTRS = 1
                                   [M:MFGK]MFGNUM = [M:MGP]VCRNUM(I)
                                   [M:MFGK]MFGFCY = [M:MGP]FCY
                                   [M:MFGK]MFGSTA = [M:MGP]WIPSTA(I)
                                   [M:MFGK]ITMREF = [M:MGP]ITMREFS
                                   Call MAJ_OF From MFGAUTLIB
                                   If [M:MFGK]CODRET <> 0 : Break : Endif
                               Else
                                   Raz [M:MFGK]
                                   [M:MFGK]CODMAJ = "D"
                                   [M:MFGK]CODTRS = 1
                                   [M:MFGK]MFGNUM = [M:MGP]VCRNUM(I)
                                   [M:MFGK]MFGFCY = [M:MGP]FCY
                                   [M:MFGK]MFGSTA = [M:MGP]WIPSTA(I)
                                   [M:MFGK]ITMREF = [M:MGP]ITMREFS
                                   [M:MFGK]PRVQTY = [M:MGP]RMNEXTQTY(I)
                                   [M:MFGK]EXTQTY = [M:MGP]RMNEXTQTY(I) - [M:MGP]PECQTY(I)
                                   [M:MFGK]WIPNUM = [M:MGP]WIPNUM(I)
                                   [M:MFGK]WIPTYP = [M:MGP]WIPTYP(I)
                                   Call MAJ_OF From MFGAUTLIB
                                   If [M:MFGK]CODRET <> 0 : Break : Endif
                               Endif
                    When 2:    # 01.06 34228
                               Read [ORD]ORD3=[M:MGP]FCY;10;GVCR;GLIN;0
                               If !fstat & [F:ORD]WIPSTA = 1
                                    Raz [M:ORCK]
                                    [M:ORCK]MAJCOD = "C"
                                    [M:ORCK]WIPNUM = [M:MGP]WIPNUM(I)
                                    [M:ORCK]WIPTYP = [M:MGP]WIPTYP(I)
                                    [M:ORCK]ITMREF = [M:MGP]ITMREFS
                                    [M:ORCK]COVQTY = [M:MGP]PECQTY(I)
                                    [M:ORCK]VCRTYPDST = 10
                                    [M:ORCK]VCRNUMDST = [F:ORD]VCRNUM
                                    [M:ORCK]VCRLINDST = [F:ORD]VCRLIN
                                    [M:ORCK]VCRSEQDST = [F:ORD]VCRSEQ
                                    [M:ORCK]WIPSTADST = [F:ORD]WIPSTA
                                    [M:ORCK]WIPTYPDST = [F:ORD]WIPTYP
                                    Read [MFG]MFG0=GVCR
                                    If !fstat
                                        [M:ORCK]ROUNUM = [F:MFG]ROUNUM
                                        [M:ORCK]ROUALT = [F:MFG]ROUALT
                                    Endif
                                    Call COVER From TRTWIP
                               Endif
                               If [M:MGP]PECQTY(I) >= [M:MGP]RMNEXTQTY(I)
                                   Raz [M:MFGK]
                                   [M:MFGK]CODMAJ = "A"
                                   [M:MFGK]CODTRS = 1
                                   [M:MFGK]MFGNUM = [M:MGP]VCRNUM(I)
                                   [M:MFGK]MFGFCY = [M:MGP]FCY
                                   [M:MFGK]MFGSTA = [M:MGP]WIPSTA(I)
                                   [M:MFGK]ITMREF = [M:MGP]ITMREFS
                                   [M:MFGK]MAJPEC = 9
                                   Call MAJ_OF From MFGAUTLIB
                                   If [M:MFGK]CODRET <> 0 : Break : Endif
                               Else
                                   Raz [M:MFGK]
                                   [M:MFGK]CODMAJ = "M"
                                   [M:MFGK]CODTRS = 1
                                   [M:MFGK]MFGNUM = [M:MGP]VCRNUM(I)
                                   [M:MFGK]MFGLIN = [M:MGP]VCRLIN(I)
                                   [M:MFGK]MFGFCY = [M:MGP]FCY
                                   [M:MFGK]MFGSTA = [M:MGP]WIPSTA(I)
                                   [M:MFGK]ITMREF = [M:MGP]ITMREFS
                                   [M:MFGK]PRVQTY = [M:MGP]RMNEXTQTY(I)
                                   [M:MFGK]EXTQTY = [M:MGP]RMNEXTQTY(I) - [M:MGP]PECQTY(I)
                                   [M:MFGK]STRDAT = [M:MGP]STRDAT(I)
                                   [M:MFGK]ENDDAT = [M:MGP]ENDDAT(I)
                                   [M:MFGK]BOMALT = [M:MGP]BOMALT(I)
                                   [M:MFGK]ROUNUM = [M:MGP]ROUNUM(I)
                                   [M:MFGK]ROUALT = [M:MGP]ROUALT(I)
                                   [M:MFGK]MAJPEC = 9
                                   Call MAJ_OF From MFGAUTLIB
                                   If [M:MFGK]CODRET <> 0 : Break : Endif
                               Endif
               Endcase
    Endcase
$SUIV
Next I
Return

###########################################################################
$MAJ_CONSO_EO
For  I = 0 To [M:MGP]NBLIG-1
    If [M:MGP]PECQTY(I) = 0 : Goto SUIV_EO : Endif

    Case [M:MGP]WIPTYP(I)
        When 1, 8 : # SOF et TPF : # GH 15/05/2014 bug 99197 ajout TPF
                Raz [M:SCOK]
                [M:SCOK]CODMAJ = "S"
                [M:SCOK]CODTRS = 1
                [M:SCOK]ITMREF = [M:MGP]ITMREFS
                [M:SCOK]EXTQTY = [M:MGP]PECQTY(I)
## GH 15/05/2014 bug 99197 paramètres supprimés
#                [M:SCOK]WIPNUM = [M:MGP]WIPNUM(I)
#                [M:SCOK]WIPTYP = [M:MGP]WIPTYP(I)
## GH 15/05/2014 bug 99197 paramètres ajoutés
                [M:SCOK]PRHFCY = [M:MGP]FCY
                [M:SCOK]FMI    = [M:MGP]FMI(I)
                # SOF
                [M:SCOK]VCRNUMORI = [M:MGP]VCRNUM(I)
                [M:SCOK]VCRLINORI = [M:MGP]VCRLIN(I)
                [M:SCOK]VCRSEQORI = [M:MGP]VCRSEQ(I)
                # EOF
                [M:SCOK]SCONUM = GVCR
                [M:SCOK]SCILIN = GLIN
##
                Call MAJ_SCO From SCOAUTLIB
                If [M:SCOK]CODRET <> 0 : Break : Endif

                Read [ORD]ORD3=[M:MGP]FCY;36;GVCR;GLIN;0
                If !fstat
                    Raz [M:ORCK]
                    [M:ORCK]MAJCOD = "C"
                    [M:ORCK]WIPNUM = [M:MGP]WIPNUM(I)
                    [M:ORCK]WIPTYP = [M:MGP]WIPTYP(I)
                    [M:ORCK]ITMREF = [M:MGP]ITMREFS
                    [M:ORCK]COVQTY = [M:MGP]PECQTY(I)
                    [M:ORCK]VCRTYPDST = 36
                    [M:ORCK]VCRNUMDST = [F:ORD]VCRNUM
                    [M:ORCK]VCRLINDST = [F:ORD]VCRLIN
                    [M:ORCK]VCRSEQDST = [F:ORD]VCRSEQ
                    [M:ORCK]WIPSTADST = [F:ORD]WIPSTA
                    [M:ORCK]WIPTYPDST = [F:ORD]WIPTYP
                    Call COVER From TRTWIP
                Endif

        When 13: # EOS/EOP
               Case [M:MGP]WIPSTA(I)
                    When 3:    If [M:MGP]PECQTY(I) >= [M:MGP]RMNEXTQTY(I)
                                   Raz [M:SCOK]
                                   [M:SCOK]CODMAJ = "A"
                                   [M:SCOK]CODTRS = 1
                                   [M:SCOK]SCONUM = [M:MGP]VCRNUM(I)
                                   [M:SCOK]POHFCY = [M:MGP]FCY
                                   [M:SCOK]SCOSTA = [M:MGP]WIPSTA(I)
                                   [M:SCOK]ITMREF = [M:MGP]ITMREFS
                                   # Issue 107498/107 - 2016-06-24 by JUSYN : Error correction STOFCY missing for deletion EOS
                                   [M:SCOK]STOFCY = [M:MGP]STOFCY(I)
                                   Call MAJ_SCO From SCOAUTLIB
                                   If [M:SCOK]CODRET <> 0 : Break : Endif
                               Else
                                   Raz [M:SCOK]
                                   [M:SCOK]CODMAJ = "D"
                                   [M:SCOK]CODTRS = 1
                                   [M:SCOK]BPRNUM = [M:MGP]BPRNUM(I)     # Issue 92063 GA 09/2013 suite correction 91792 GH
                                   [M:SCOK]SCONUM = [M:MGP]VCRNUM(I)
                                   [M:SCOK]POHFCY = [M:MGP]FCY
                                   [M:SCOK]SCOSTA = [M:MGP]WIPSTA(I)
                                   [M:SCOK]ITMREF = [M:MGP]ITMREFS
                                   [M:SCOK]PRVQTY = [M:MGP]RMNEXTQTY(I)
                                   [M:SCOK]EXTQTY = [M:MGP]RMNEXTQTY(I) - [M:MGP]PECQTY(I)
                                   [M:SCOK]WIPNUM = [M:MGP]WIPNUM(I)
                                   [M:SCOK]WIPTYP = [M:MGP]WIPTYP(I)
                                   # Issue 107498/107 - 2016-06-24 by JUSYN : Error correction STOFCY missing for deletion EOS
                                   [M:SCOK]STOFCY = [M:MGP]STOFCY(I)
                                   Call MAJ_SCO From SCOAUTLIB
                                   If [M:SCOK]CODRET <> 0 : Break : Endif
                               Endif
                    When 2:
                               Read [ORD]ORD3=[M:MGP]FCY;36;GVCR;GLIN;0
                               If !fstat & [F:ORD]WIPSTA = 1
                                    Raz [M:ORCK]
                                    [M:ORCK]MAJCOD = "C"
                                    [M:ORCK]WIPNUM = [M:MGP]WIPNUM(I)
                                    [M:ORCK]WIPTYP = [M:MGP]WIPTYP(I)
                                    [M:ORCK]ITMREF = [M:MGP]ITMREFS
                                    [M:ORCK]COVQTY = [M:MGP]PECQTY(I)
                                    [M:ORCK]VCRTYPDST = 36       : # Ordre de sous-traitance
                                    [M:ORCK]VCRNUMDST = [F:ORD]VCRNUM
                                    [M:ORCK]VCRLINDST = [F:ORD]VCRLIN
                                    [M:ORCK]VCRSEQDST = [F:ORD]VCRSEQ
                                    [M:ORCK]WIPSTADST = [F:ORD]WIPSTA
                                    [M:ORCK]WIPTYPDST = [F:ORD]WIPTYP
                                    Call COVER From TRTWIP
                               Endif
                               If [M:MGP]PECQTY(I) >= [M:MGP]RMNEXTQTY(I)
                                   Raz [M:SCOK]
                                   [M:SCOK]CODMAJ = "A"
                                   [M:SCOK]CODTRS = 1
                                   [M:SCOK]SCONUM = [M:MGP]VCRNUM(I)
                                   [M:SCOK]POHFCY = [M:MGP]FCY
                                   [M:SCOK]SCOSTA = [M:MGP]WIPSTA(I)
                                   [M:SCOK]ITMREF = [M:MGP]ITMREFS
                                   [M:SCOK]MAJPEC = 9
                                   # Issue 107498/107 - 2016-06-24 by JUSYN : Error correction STOFCY missing for deletion EOS
                                   [M:SCOK]STOFCY = [M:MGP]STOFCY(I)
                                   Call MAJ_SCO From SCOAUTLIB
                                   If [M:SCOK]CODRET <> 0 : Break : Endif
                               Else
                                   Raz [M:SCOK]
                                   [M:SCOK]CODMAJ = "M"
                                   [M:SCOK]CODTRS = 1
                                   [M:SCOK]BPRNUM = [M:MGP]BPRNUM(I)     # Issue 92063 GA 09/2013 suite correction 91792 GH
                                   [M:SCOK]SCONUM = [M:MGP]VCRNUM(I)
                                   [M:SCOK]SCILIN = [M:MGP]VCRLIN(I)
                                   [M:SCOK]POHFCY = [M:MGP]FCY
                                   [M:SCOK]SCOSTA = [M:MGP]WIPSTA(I)
                                   [M:SCOK]ITMREF = [M:MGP]ITMREFS
                                   [M:SCOK]PRVQTY = [M:MGP]RMNEXTQTY(I)
                                   [M:SCOK]EXTQTY = [M:MGP]RMNEXTQTY(I) - [M:MGP]PECQTY(I)
                                   [M:SCOK]STRDAT = [M:MGP]STRDAT(I)
                                   [M:SCOK]ENDDAT = [M:MGP]ENDDAT(I)
                                   [M:SCOK]BOMALT = [M:MGP]BOMALT(I)
                                   [M:SCOK]MAJPEC = 9
                                   # Issue 107498/107 - 2016-06-24 by JUSYN : Error correction STOFCY missing for deletion EOS
                                   [M:SCOK]STOFCY = [M:MGP]STOFCY(I)
                                   Call MAJ_SCO From SCOAUTLIB
                                   If [M:SCOK]CODRET <> 0 : Break : Endif
                               Endif
               Endcase
    Endcase
$SUIV_EO
Next I
Return


###########################################################################
$ANALYSE_BESOIN
WRET=0
[M:MGP]DATBES = [0/0/0]
[M:MGP]HPJT = ""
For  I = 0 To [M:MGP]NBLIG-1
    If [M:MGP]PECQTY(I) = 0 : Goto SUIV2 : Endif

    # Vérification qté encours inchangée
## GH 15/05/2014 bug 99197
#    Call CHECK_WIP([M:MGP]WIPTYP(I), [M:MGP]ITMREFS, [M:MGP]WIPNUM(I), [M:MGP]EXTQTY(I), C_QTY, WRET) From MFGLIB
#    If WRET
#        Case WRET
#            When 1:    If [M:MGP]PECQTY(I) > C_QTY
#                           [M:MGP]TOTPECQTY -= [M:MGP]PECQTY(I)
#                           [M:MGP]PECQTY(I) = C_QTY
#                           [M:MGP]TOTPECQTY += [M:MGP]PECQTY(I)
#                       Endif
#            When 9:    [M:MGP]TOTPECQTY -= [M:MGP]PECQTY(I)
#                       [M:MGP]PECQTY(I)  = 0
#        Endcase
#    Endif

## GH 10/07/2014 bug 101396
#    Read [ORD]ORD0=[M:MGP]WIPTYP(I);[M:MGP]WIPNUM(I);[M:MGP]ITMREFS
#    If fstat | [M:MGP]FMI(I)<>[F:ORD]FMI
#        C_QTY = 0
#    Else
#        C_QTY = [F:ORD]RMNEXTQTY
#        If !find([F:ORD]WIPTYP,13,4)
#           C_QTY -= [F:ORD]ALLQTY + [F:ORD]MTOQTY
#        Endif
#    Endif
#    If [M:MGP]PECQTY(I) > C_QTY
#       [M:MGP]TOTPECQTY -= [M:MGP]PECQTY(I)
#       [M:MGP]PECQTY(I) = C_QTY
#       [M:MGP]TOTPECQTY += [M:MGP]PECQTY(I)
#       If [M:MGP]PECQTY(I)=0 : Goto SUIV2 : Endif
#    Endif

    If [M:MGP]HPJT = "" & [M:MGP]PJT(I) <> ""
        [M:MGP]HPJT = [M:MGP]PJT(I)
    Endif

    If [M:MGP]DATBES = [0/0/0] | [M:MGP]ENDDAT(I) < [M:MGP]DATBES
        [M:MGP]DATBES = [M:MGP]ENDDAT(I)
    Endif
$SUIV2
Next I
Return

###########################################################################
# Issue 99743 GA 09/2014 Extracted/completed from FUNMPICK to be reused
###########################################################################
$CTRL_POHFCY
If dim([M:MGP]POHFCY(nolign-1))<=0  Return Endif
# Issue GA 09/2014
Call CTL_POHFCY([M:MGP]STOFCY(nolign-1),[M:MGP]POHFCY(nolign-1)) From BENCHLIB
Return

########################################################################
$CHARG_PARAM
Call GETCPY(GFCY,"BTS",53,GMRLNUM) From TRTX3CPT

#----- Variables globales stock
Call GLOBVAR(GFCY)    From WWGLOBSTO
#----- Variables globales GPAO
Call GLOBVAR(GFCY)    From WWGLOBGPA
#----- Variables globales Achat
Call GLOBVAR(GFCY)    From WWGLOBACH

## GH 19/05/2014 bug 100108
If GMODU(8) = 2
    If clalev ([F:TCA]) <= 0 : Local File TABCOUAFF [TCA] : Endif
    Local Integer WOK
    Call LECTCA(8,WOK) From SUBTCA
    If WOK=0 : GOPS = "" : Else GOPS = [F:TCA]CODNUM(4) : Endif  # compteur suggestion opérations
Endif
Return

########################################################################
$LECTURE_BTS
#----- Relecture transaction de saisie  -----#
If [F:BTS]BTSTYP <> 53 | [F:BTS]BTSNUM <> GMRLNUM
    Read [BTS]BTS0=53;GMRLNUM
    If fstat : Raz [F:BTS] : Endif
Endif
# 09.05 31994
If GMODU(8) = 2
    If [F:BTS]MFGTRS <> ""
        Read  [MTS]MTS0=1;[F:BTS]MFGTRS
    Else
        Read  [MTS]MTS0=1;GMFGMTSNUM
    Endif
    If fstat : Raz [F:MTS] : Endif
Endif
# Achats de sous-traitance: transaction de maj auto d'EO
If GMODU(6) = 2
    If dim([F:BTS]SCOTRS)>0 & [F:BTS]SCOTRS <> ""
        Read  [PTR]PTR0=9;[F:BTS]SCOTRS
    Else
        Read  [PTR]PTR0=9;GSCOPTRNUM
    Endif
    If fstat : Raz [F:PTR] : Endif
Endif
Return

########################################################################
$DAT8
Local Char WWJOUR(2) ,WWMOIS(2) ,WWANNEE(4)
If len(num$(WJOUR)) = 1
             WWJOUR= "0"+num$(WJOUR)
Else         WWJOUR = num$(WJOUR)
Endif
If len(num$(WMOIS)) = 1
       WWMOIS = "0"+num$(WMOIS)
Else   WWMOIS = num$(WMOIS)
Endif
WWANNEE = num$(WANNEE)
WDATE=format$("D:"+GFMDAT4,gdat$(val(WWJOUR),val(WWMOIS),val(WWANNEE)))
Return

########################################################################
$CHARGE_WRCPDATL
Local    Shortint   WJOUR ,WMOIS ,WANNEE
Local    Char       WDATE(10)

# chargement zone wrcpdat
WANNEE = val(left$([M:MGP]EXTRCPDAT(nolign-1),4))
WMOIS  = val(mid$([M:MGP]EXTRCPDAT(nolign-1),5,2))
WJOUR  = val(right$([M:MGP]EXTRCPDAT(nolign-1),7))

If [M:MGP]CAD(nolign-1) = 1           : # cadencement jour
     Gosub DAT8
     [M:MGP]WRCPDAT(nolign-1)     = WDATE
     [M:MGP]STRRCPDAT(nolign-1)   = [M:MGP]EXTRCPDAT(nolign-1)
Elsif [M:MGP]CAD(nolign-1) = 3        : # cadencement mois
      [M:MGP]STRRCPDAT(nolign-1)  = aweek([M:MGP]WEE(nolign-1),[M:MGP]YEA(nolign-1))
      Local Char WWMOIS(2)
      If len(num$(WMOIS))= 1
          WWMOIS = "0"+num$(WMOIS)
      Else  WWMOIS = num$(WMOIS)
      Endif
      WDATE= format$("K:2#[-]4#",WWMOIS+num$(WANNEE))
      [M:MGP]WRCPDAT(nolign-1) = WDATE
Else                    : # cadencement semaine
    [M:MGP]STRRCPDAT(nolign-1) = aweek([M:MGP]WEE(nolign-1),[M:MGP]YEA(nolign-1))
    Local Char WSEM(10)
    If len(num$([M:MGP]WEE(nolign-1)))= 1
          WSEM = "00"+num$([M:MGP]WEE(nolign-1))
    Elsif len(num$([M:MGP]WEE(nolign-1)))= 2
          WSEM = "0"+num$([M:MGP]WEE(nolign-1))
    Else  WSEM = num$([M:MGP]WEE(nolign-1))
    Endif
    WDATE= format$("K:3#[-]4#",WSEM+num$([M:MGP]YEA(nolign-1)))
    [M:MGP]WRCPDAT(nolign-1) = WDATE
Endif

Return

###########################################################################
Subprog UPD_PURCHASE
Call MGT_PURCHASE From TRTACHMGT1
End

###########################################################################
# 106430 - Purchase planning
# Update the weight and volume totals for a line after the line
# convert to container UOMs as well for easier/faster totaling
Subprog UPD_PPLINTOTALS
Local Integer NOL : NOL=nolign-1
Local Integer STAT

If [F:BTS]PLANNER = 2 : End : Endif

If [M:MGP]FIE(NOL)=2
  # Set the total weight and volume for the line in product UOM
  [M:MGP]LINWEI(NOL) = [M:MGP]ITMWEI(NOL) * [M:MGP]PECQTY(NOL)
  [M:MGP]LINVOL(NOL) = [M:MGP]ITMVOL(NOL) * [M:MGP]PECQTY(NOL)

  # Conver the product UOMs to Container UOMs
  [M:MGP]LINTCTRWEI(NOL) = [M:MGP]LINWEI(NOL)
  [M:MGP]LINTCTRVOL(NOL) = [M:MGP]LINVOL(NOL)
  If [M:MGP]LINWEU(NOL)<>[M:MGP]TCTRWEU
    Call CONVERT_QTY([M:MGP]LINWEU(NOL),[M:MGP]TCTRWEU,[M:MGP]LINTCTRWEI(NOL))From TRTX3
  Endif
  If [M:MGP]LINVOU(NOL)<>[M:MGP]TCTRVOU
    Call CONVERT_QTY([M:MGP]LINVOU(NOL),[M:MGP]TCTRVOU,[M:MGP]LINTCTRVOL(NOL))From TRTX3
  Endif

  [M:MGP]LINAMT(NOL) = [M:MGP]PURBASPRI(NOL) * [M:MGP]PECQTY(NOL)
  If GSYSCUR <> GLOCALDEV
    Call CONVERT (GSYSCUR,GLOCALDEV,GLOCALDEV,[F:BPS]CHGTYP,[M:MGP]REQDAT(NOL),[M:MGP]LINAMT(NOL),[M:MGP]LINAMT(NOL),STAT) From TRTDEV
  Endif
Else
  Raz [M:MGP]LINWEI(NOL), LINVOL(NOL), LINTCTRWEI(NOL), LINTCTRVOL(NOL), LINAMT(NOL)
Endif

Affzo [M:MGP]LINWEI(NOL), LINVOL(NOL), LINTCTRWEI(NOL), LINTCTRVOL(NOL), LINAMT(NOL)

End

# Sum up all picked lines for container totals
Subprog UPD_PPHEADER
Local Integer I
If [F:BTS]PLANNER = 2 : End : Endif

Raz [M:MGP]WEITOT, VOLTOT, TOTCOST

# Sum up the weight and volume from the lines (already converted to container UOMs)
For I=0 To [M:MGP]NBLIG-1
  If [M:MGP]FIE(I)=2
    [M:MGP]WEITOT   += [M:MGP]LINTCTRWEI(I)
    [M:MGP]VOLTOT   += [M:MGP]LINTCTRVOL(I)
    [M:MGP]TOTCOST  += [M:MGP]LINAMT(I)
  Endif
Next I

# Calculate the available amounts
If [M:MGP]WEICAP > 0 : [M:MGP]WEIAVL = [M:MGP]WEICAP-[M:MGP]WEITOT : Endif
If [M:MGP]VOLCAP > 0 : [M:MGP]VOLAVL = [M:MGP]VOLCAP-[M:MGP]VOLTOT : Endif
Call UPD_AVAILFIELDS

Affzo [M:MGP]WEITOT, VOLTOT, WEIAVL, VOLAVL, TOTCOST

End

#When updating a container, get new UOM, update totals and convert lines if needed
Subprog UPD_CONTAINER (TCTRNUM,TCTRQTY)
Value Char    TCTRNUM
Value Integer TCTRQTY
Local Integer NOL
Local Char CURWEU(3), CURVOU(3)

If [F:BTS]PLANNER = 2 : End : Endif

If !clalev([F:TCTR]) : Local File TABCONTAINER [TCTR] : Endif
Read [TCTR]TCTR0 = [L]TCTRNUM
If fstat : Raz [F:TCTR] : Endif

If [L]TCTRNUM = ""
  Raz [M:MGP]TCTRQTY : Diszo [M:MGP]TCTRQTY
  Actzo [M:MGP]WEICAP, VOLCAP
Else
  Actzo [M:MGP]TCTRQTY

  #Set the weight and volume capacity for the container
  If [L]TCTRQTY <= 0 : [L]TCTRQTY=1 : Endif
  [M:MGP]WEICAP = [F:TCTR]MAXWEI  * [L]TCTRQTY
  [M:MGP]VOLCAP = [F:TCTR]TCTRVOL * [L]TCTRQTY

  Diszo [M:MGP]WEICAP, VOLCAP
Endif

[L]CURWEU = [M:MGP]TCTRWEU
[L]CURVOU = [M:MGP]TCTRVOU

#Set the UOM for both weight and volume
If [F:TCTR]WEU=""
  [M:MGP]TCTRWEU = GSALDSPWEU
Else
  [M:MGP]TCTRWEU = [F:TCTR]WEU
Endif

If [F:TCTR]VOU=""
  [M:MGP]TCTRVOU = GSALDSPVOU
Else
  [M:MGP]TCTRVOU = [F:TCTR]VOU
Endif

Affzo [M:MGP]15-19

#If the neither UOM changed, end now, no need to update lines.
If [L]CURWEU<>[M:MGP]TCTRWEU | [L]CURVOU<>[M:MGP]TCTRVOU
  For NOL=0 To [M:MGP]NBLIG-1
    If [M:MGP]FIE(NOL)=2
      # Conver the product UOMs to Container UOMs
      [M:MGP]LINTCTRWEI(NOL) = [M:MGP]LINWEI(NOL)
      [M:MGP]LINTCTRVOL(NOL) = [M:MGP]LINVOL(NOL)
      If [M:MGP]LINWEU(NOL)<>[M:MGP]TCTRWEU
        Call CONVERT_QTY([M:MGP]LINWEU(NOL),[M:MGP]TCTRWEU,[M:MGP]LINTCTRWEI(NOL))From TRTX3
      Endif
      If [M:MGP]LINVOU(NOL)<>[M:MGP]TCTRVOU
        Call CONVERT_QTY([M:MGP]LINVOU(NOL),[M:MGP]TCTRVOU,[M:MGP]LINTCTRVOL(NOL))From TRTX3
      Endif
    Endif
  Next NOL

  Affzo [M:MGP]LINTCTRWEI, LINTCTRVOL
Endif

Call UPD_PPHEADER

End

# Conditional formating for Available fields
# Red if negative, black if >= 0
Subprog UPD_AVAILFIELDS

If [M:MGP]WEIAVL<0
  Chgstl [M:MGP]WEIAVL With "NBNEGATIF"
Else
  Chgstl [M:MGP]WEIAVL With ""
Endif

If [M:MGP]VOLAVL<0
  Chgstl [M:MGP]VOLAVL With "NBNEGATIF"
Else
  Chgstl [M:MGP]VOLAVL With ""
Endif

End

###########################################################################
# ETIQUETTES                                                              #
###########################################################################

########################################
Subprog AM_PJTSTR(VALEUR)
Variable Char    VALEUR()
If [M]PJTEND = ""     : [M]PJTEND = VALEUR : Affzo PJTEND : Endif
If [M]PJTEND < VALEUR : [M]PJTEND = VALEUR : Affzo PJTEND : Endif
End

########################################
Subprog AM_VCRNUMSTR(VALEUR)
Variable Char    VALEUR()
If VALEUR = "" : End : Endif
If [M]VCRNUMEND = ""     : [M]VCRNUMEND = VALEUR : Affzo VCRNUMEND : Endif
If [M]VCRNUMEND < VALEUR : [M]VCRNUMEND = VALEUR : Affzo VCRNUMEND : Endif
End

########################################
Subprog AM_BPRNUMSTR(VALEUR)
Variable Char    VALEUR()
If [M]BPRNUMEND = ""     : [M]BPRNUMEND = VALEUR : Affzo BPRNUMEND  : Endif
If [M]BPRNUMEND < VALEUR : [M]BPRNUMEND = VALEUR : Affzo BPRNUMEND  : Endif
End

########################################
Subprog AM_ENDDATSTR(VALEUR)
Variable Date    VALEUR
If VALEUR <> [0/0/0] : [M]ENDDATEND = eomonth(VALEUR) : Affzo ENDDATEND : Endif
End

########################################
Subprog C_ENDDATEND(VALEUR)
Variable Date    VALEUR
If VALEUR < [M]ENDDATSTR : GMESSAGE= mess(44,199,1) : mkstat=2 : Endif
End

########################################
Subprog B1_NBLIG
If [M:MGP]PECQTY(nolign-1) = 0

    ## GH 14/04/2014 bug 97405
    #[M:MGP]PECQTY(nolign-1)     = [M:MGP]RMNEXTQTY(nolign-1)-[M:MGP]ALLQTY(nolign-1)-[M:MGP]MTOQTY(nolign-1)
    [M:MGP]PECQTY(nolign-1)     = [M:MGP]RMNEXTQTY(nolign-1)
    If !find([M:MGP]WIPTYP(nolign-1),13,4)
       [M:MGP]PECQTY(nolign-1) -= [M:MGP]ALLQTY(nolign-1) + [M:MGP]MTOQTY(nolign-1)
    Endif
    ##

    If [F:BTS]PLANNER <> 2
      # Issue 115840 - 09-05-2016 by STLIG : Incorporate rounding type: up or down, into conversion type parameter.
      Call PCAL_QTY([M:MGP]PECQTY(nolign-1),
&                   [M:MGP]STU(nolign-1),
&                   [M:MGP]PUUPECQTY(nolign-1),
&                   [M:MGP]PUU(nolign-1),
&                   [M:MGP]ITMREF(nolign-1),
&                   [M:MGP]BPSNUM(nolign-1),
&                   func TRTACHQTE1.ROUND_CONVERSION_TYPE(1,[F:ITF]REOPOL),
&                   GBIDD1) From TRTACHQTE1
    Endif
    [M:MGP]TOTPECQTY       += [M:MGP]PECQTY(nolign-1)
    # 01.05 27638
    If [F:BTS]PLANNER <> 2 & ([F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2) & ([M:MGP]BPSNUM(nolign-1) = "" | [M:MGP]PUUPECQTY(nolign-1) = 0)
    ## GH 28/03/12 bug 79951
    # If ([F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2) & ([M:MGP]BPSNUM(nolign-1) = "" | [M:MGP]PUUPECQTY(nolign-1) = 0)
        [M:MGP]FIE(nolign-1)    = 1
    Elsif ([F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2) & ([M:MGP]PUUPECQTY(nolign-1) = 0)
        [M:MGP]FIE(nolign-1)    = 1
    Else
        [M:MGP]FIE(nolign-1)    = 2
    Endif
    If [M:MGP]FLGPEC(nolign-1) = 2 : [M:MGP]FLGREG(nolign-1) = 2 : Endif
Else
    [M:MGP]TOTPECQTY       -= [M:MGP]PECQTY(nolign-1)
    [M:MGP]PECQTY(nolign-1) = 0
    If [F:BTS]PLANNER <> 2
        [M:MGP]PUUPECQTY(nolign-1) = 0
    Endif
    [M:MGP]FIE(nolign-1) = 1
    If [M:MGP]FLGPEC(nolign-1) = 2 : [M:MGP]FLGREG(nolign-1) = 1 : Endif
Endif

Gosub HIGHLIGHT
End

########################################
Subprog AV_PECQTY(VALEUR)
Variable Decimal VALEUR
End

########################################
Subprog IB_NBLIG
Local Integer I
GBOUT1= ""
GBOUT2= ""
GBOUT3= ""
GBOUT4= ""
GBOUT6= ""
GBOUT7= ""

If [M:MGP]WIPTYPSTA(nolign-1) <> ""
    If [F:BTS]BTSTYP<>53 | [F:BTS]BTSNUM<>GMRLNUM
       Read [BTS]BTS0 = 53;GMRLNUM
    Else
       fstat=0
    Endif
    If !fstat & [F:BTS]TRSCNL<>2
       GBOUT1 = mess(306,198,1)   # inclure/exclure
    Endif
    #
    GBOUT4 = mess(102,198,1)      # stock
    GBOUT5 = mess(456,198,1)      # données de gestion
Endif
If [M:MGP]FLGPEC(nolign-1) = 2 : GBOUT2 = mess(175,195,1) : Endif

# s'il s'agit d'un POS, lien vers fenetre d'éclatement du POS
If ([M:MGP]WIPTYP(nolign-1) = 2 & [M:MGP]WIPSTA(nolign-1) = 3)
    GBOUT3 = mess(11, 198,1)    # éclatement
    GBOUT6 = mess(501,198,1)    # 106430 - Products by supplier
    GBOUT7 = mess(499,198,1)    # 106430 - Product usage
Endif
End

########################################
Subprog C_ITMREFS(VALEUR)
Variable Char    VALEUR()
Local    Char    WFCY(GLONFCY) : WFCY = [M]FCY
Local    Char    WART(GLONITM) : WART = VALEUR
Local    Char    WUSR(GLONAUS) : WUSR = [M]PLANNER
Local    Char    WFCY(GLONFCY)

If VALEUR = "" : End : Endif

# GA 08/2006 sinon pb dans CONTMFGITM
If [F:ITM]ITMREF <> VALEUR
   Read [ITM]ITM0=VALEUR
Endif

WFCY = [M]FCY
Look [ITF]ITF0=VALEUR;WFCY
If fstat : GMESSAGE = mess(25,192,1) : mkstat = 2 : End : Endif

If [F:BTS]PLANNER = 2 & [F:BTS]BUYER <> 2
  Call CONTMFGITM(WFCY, 1) From MFGLIB
Else
  Call CONTSCOITM(WFCY, 1) From SCOLIB
Endif

#    Contrôle filtre par planificateur
Call CTLPLNFLT(WFCY, VALEUR, WUSR) From MFGLIB

If GMESSAGE <> ""
    mkstat=1
    End
Endif

End

########################################
Subprog AM_ITMREFS(VALEUR)
Variable Char    VALEUR()

If VALEUR <> ""
    Read [ITM]ITM0 = VALEUR
    If !fstat : [M:MGP]STU = [F:ITM]STU : Affzo [MGP]STU : Endif
Endif

# Issue 110957 - 2015-10-07 by GH
If dim([M:MGP]IECCVALMAJ)>0
    Effzo [MGP] IECCVALMAJ, IECCVALMIN
    If VALEUR<>""
        Local Integer I
        I=func ECCLIB.NBRCPN(VALEUR)
        If I>0
           Actzo [MGP]IECCVALMAJ
        Else
           Diszo [MGP]IECCVALMAJ
        Endif
        If I>1
           Actzo [MGP]IECCVALMIN
        Else
           Diszo [MGP]IECCVALMIN
        Endif
    Else
        Diszo [MGP]IECCVALMIN
        Diszo [MGP]IECCVALMAJ
    Endif
Endif

# Issue 110957 - 2015-10-07 by GH
If dim([M:MGP]ICRID)=1 & func ECCLIB.NBRCPN(VALEUR)<1
    [M:MGP]ICRID = func TRTX3FNC.CCMID(VALEUR,"","")
    Affzo [MGP]ICRID
    If dim([M:MGP]ICRFLG)>0
       [M:MGP]ICRFLG = string$([M:MGP]ICRID<>"","151") : Affzo [MGP]ICRFLG
    Endif
Endif
End

########################################
Subprog AM_PECQTY(VALEUR)
Variable Decimal VALEUR
If [M:MGP]FLGPEC(nolign-1) = 2
   [M:MGP]FLGREG(nolign-1) = 1 + (VALEUR>0)
Endif
[M:MGP]TOTPECQTY -= [M:MGP]PECQTY(nolign-1)
[M:MGP]TOTPECQTY += VALEUR
Affzo [MGP]TOTPECQTY                  # GH 28/04/2014 bug 95576

If [F:BTS]PLANNER <> 2
  # Issue 115840 - 09-05-2016 by STLIG : Incorporate rounding type: up or down, into conversion type parameter.
  Call PCAL_QTY(VALEUR,
&               [M:MGP]STU(nolign-1),
&               [M:MGP]PUUPECQTY(nolign-1),
&               [M:MGP]PUU(nolign-1),
&               [M:MGP]ITMREF(nolign-1),
&               [M:MGP]BPSNUM(nolign-1),
&               func TRTACHQTE1.ROUND_CONVERSION_TYPE(1,[F:ITF]REOPOL),
&               GBIDD1) From TRTACHQTE1
    Affzo [MGP]PUUPECQTY(nolign-1)    # GH 28/04/2014 bug 95576
Endif

# 01.05 27638
If [F:BTS]PLANNER <> 2 & ([F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2) & ([M:MGP]BPSNUM(nolign-1) = "" | [M:MGP]PUUPECQTY(nolign-1) = 0)
## GH 28/03/12 bug 79951
# If ([F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2) & ([M:MGP]BPSNUM(nolign-1) = "" | [M:MGP]PUUPECQTY(nolign-1) = 0)
    [M:MGP]FIE(nolign-1) = 1
Elsif ([F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2) & [M:MGP]PUUPECQTY(nolign-1) = 0
    [M:MGP]FIE(nolign-1) = 1
Else
    [M:MGP]FIE(nolign-1) = 1 + (VALEUR<>0)
Endif
Affzo [MGP]FIE(nolign-1)             # GH 28/04/2014 bug 95576

[M:MGP]PECQTY(nolign-1) = VALEUR

# Issue 95576 GA 03/2014 performances (before Gosub HIGHLIGHT)
# Local Integer I : I=nolign-1       # GH 10/04/2014 bug 95576
Gosub HIGHLIGHT_CURLINE
End

########################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
GFCY = VALEUR
Gosub CHARG_PARAM

## GH 19/05/2014 bug 100108
If GMODU(8)=2 & GOPS="" : # compteur suggestion opérations
   GMESSAGE = mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1) : mkstat=2 : End
Endif
End

