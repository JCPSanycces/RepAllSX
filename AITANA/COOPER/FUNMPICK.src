########################################
Subprog AS_USEPLC(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog AM_POHNUM(VALEUR)
Variable Char    VALEUR()
Local    Char    WUOM1(GLONUOM), WUOM2(GLONUOM)
Local    Decimal WCOEFF
Read [POC]POC0=VALEUR;[M:MGP]POPLIN(nolign-1)
If !fstat
    [M:MGP]PUU(nolign-1) = [F:POC]PUU
    WUOM1                = [F:POC]PUU
    WUOM2                = [F:POC]STU
    Call RECH_COEFF(WUOM1,WUOM2,WCOEFF) From MFGLIB
    [M:MGP]PUUSTUCOE(nolign-1) = WCOEFF
    Affzo [MGP]PUU(nolign-1), PUUSTUCOE(nolign-1)      # GH 28/04/2014 bug 95576
Endif
If VALEUR <> ""
    Read [POH]POH0=VALEUR
    If fstat : Raz [F:POH] : Endif

    [M:MGP]BPSNUM(nolign-1) = [F:POH]BPSNUM
    [M:MGP]PJT(nolign-1)    = ""
    Affzo [MGP]BPSNUM(nolign-1)
    Affzo [MGP]PJT(nolign-1)

    # Issue 115840 - 09-05-2016 by STLIG : Incorporate rounding type: up or down, into conversion type parameter.
    Call PCAL_QTY([M:MGP]PECQTY(nolign-1),
&                 [M:MGP]STU(nolign-1),
&                 [M:MGP]PUUPECQTY(nolign-1),
&                 [M:MGP]PUU(nolign-1),
&                 [M:MGP]ITMREF(nolign-1),
&                 [M:MGP]BPSNUM(nolign-1),
&                 func TRTACHQTE1.ROUND_CONVERSION_TYPE(1,[F:ITF]REOPOL),
&                 WCOEFF) From TRTACHQTE1
    Affzo [MGP]PUUPECQTY(nolign-1)                     # GH 28/04/2014 bug 95576
    If WCOEFF <> 0
       [M:MGP]PUUSTUCOE(nolign-1) = 1/WCOEFF
       Affzo [MGP]PUUSTUCOE(nolign-1)                  # GH 28/04/2014 bug 95576
    Endif

    [M:MGP]POHNUM(nolign-1) = VALEUR

    # Issue 95576 GA 03/2014 performances (before Gosub HIGHLIGHT)
    # Local Integer I : I=nolign-1            # GH 10/04/2014 bug 95576
    Gosub HIGHLIGHT_CURLINE
Endif
End

########################################
Subprog C_PUUPECQTY(VALEUR)
Variable Decimal VALEUR
End

########################################
Subprog AM_PUUPECQTY(VALEUR)
Variable Decimal VALEUR

# 01.05 27638
If ([F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2) & ([M:MGP]BPSNUM(nolign-1) = "" | VALEUR = 0)
    [M:MGP]FIE(nolign-1) = 1
Elsif ([F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2) & VALEUR = 0
    [M:MGP]FIE(nolign-1) = 1
Else
    [M:MGP]FIE(nolign-1) = 1+(VALEUR<>0)
Endif
Affzo [MGP]FIE(nolign-1)       # GH 28/04/2014 bug 95576

If [M:MGP]FLGPEC(nolign-1) = 2
   [M:MGP]FLGREG(nolign-1) = 1+(VALEUR>0)
Endif

[M:MGP]TOTPECQTY -= [M:MGP]PECQTY(nolign-1)
[M:MGP]TOTPECQTY += VALEUR
Affzo [MGP]TOTPECQTY          # GH 28/04/2014 bug 95576

# relecture article si nécessaire
If [F:ITM]ITMREF <> [M:MGP]ITMREF(nolign-1)
    Read [ITM]ITM0=[M:MGP]ITMREF(nolign-1)
    If fstat : Raz [F:ITM] : Endif
Endif

# Issue 115840 - 09-05-2016 by STLIG : Incorporate rounding type: up or down, into conversion type parameter.
Call PCAL_QTY(VALEUR,
&             [M:MGP]PUU(nolign-1),
&             [M:MGP]PECQTY(nolign-1),
&             [M:MGP]STU(nolign-1),
&             [M:MGP]ITMREF(nolign-1),
&             [M:MGP]BPSNUM(nolign-1),
&             func TRTACHQTE1.ROUND_CONVERSION_TYPE(1,[F:ITF]REOPOL),
&             GBIDD1) From TRTACHQTE1
Affzo [MGP]PECQTY(nolign-1)          # GH 28/04/2014 bug 95576

[M:MGP]PUUPECQTY(nolign-1) = VALEUR

# Issue 95576 GA 03/2014 performances (before Gosub HIGHLIGHT)
# Local Integer I : I=nolign-1       # GH 10/04/2014 bug 95576
Gosub HIGHLIGHT_CURLINE
End

########################################
Subprog AV_PUUPECQTY(VALEUR)
Variable Decimal VALEUR
End

########################################
Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
End

########################################
Subprog AS_ITMREF(VALEUR)
Variable Char    VALEUR()
GBOUT1 = mess(22,198,1)
End

########################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
    Read [ITM]ITM0 = VALEUR
    If fstat : Raz [F:ITM] : Endif
    [M:MGP]STU(nolign-1)         = [F:ITM]STU
    #[M:MGP]ITMDES1(nolign-1)     = [F:ITM]ITMDES1
    Call CHARGE_DEFITMDES("DES1AXX",GLANGUE,[F:ITM]ITMREF,[M:MGP]ITMDES1(nolign-1), "[F:ITM]") From TRTX3 # FGR 30/06/2009 : X3SUIVI56189
    [M:MGP]PUU(nolign-1)         = [F:ITM]PUU
    [M:MGP]PUUSTUCOE(nolign-1)   = [F:ITM]PUUSTUCOE

    Filter [ITP] Where ITMREF=[F:ITM]ITMREF Order By Key ITP1
    Read [ITP] First
    If fstat
        Raz [F:ITP]
        [M:MGP]BPSNUM(nolign-1) = [F:ITP]BPSNUM
        Affzo [MGP]BPSNUM(nolign-1)
    Else
        [M:MGP]PUU(nolign-1)    = [F:ITP]PUU
        [M:MGP]PUUSTUCOE(nolign-1)    = [F:ITP]PUUSTUCOE
    Endif
    Filter [ITP]

    Affzo [MGP] STU(nolign-1), PUU(nolign-1), PUUSTUCOE(nolign-1)

#    If [F:ITF]STOFCY <> [M:MGP]STOFCY | [F:ITF]ITMREF <> [F:XXX]ITMREF
#       Read [ITF]ITF0 = [F:XXX]ITMREF;[F:XXX]STOFCY
#       If fstat
#          Raz [F:ITF]
#       Endif
#    Endif
Endif
End

########################################
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
Local    Char    WART(GLONITM) : WART = VALEUR
Local    Char    WUSR(GLONAUS) : WUSR = [M]PLANNER
Local    Char    WFCY(GLONFCY)        # FQ 70078 avant GLONFCY1
Local    Integer OK
Local    Date    TODAY : TODAY = date$

Read [FCY]FCY0 = VALEUR
If fstat : GMESSAGE =mess(83,123,1) : mkstat = 2 : End : Endif
If [M:MGP]STOSOC(nolign-1) <> ""
    If [F:FCY]LEGCPY <> [M:MGP]STOSOC(nolign-1) : GMESSAGE=mess(2,194,1) : mkstat=2 : End : Endif
Endif

Read [ITF]ITF0=[M:MGP]ITMREF(nolign-1);VALEUR
If fstat: GMESSAGE = mess(25,192,1) : mkstat = 2 : End : Endif

If [F:BTS]PLANNER = 2 & [F:BTS]BUYER <> 2
    Call CONTMFGITM(VALEUR, 1) From MFGLIB
Endif

# FQ 54966 pb sur l'action CTLPRHFCY si GSOCIETE non renseigné
If GFCY=""
   GFCY=VALEUR
   Gosub CHARG_PARAM
Endif

#    Contrôle filtre par planificateur
Call CTLPLNFLT(VALEUR, [M:MGP]ITMREF(nolign-1), WUSR) From MFGLIB

If GMESSAGE <> ""
    mkstat=1
    End
Endif
[M:MGP]PLANNER2(nolign-1)   = [F:ITF]PLANNER
[M:MGP]BUY(nolign-1)        = [F:ITF]BUY

[M:MGP]POHIND(nolign-1) = 1

# vérification présence contrat
OK = 0
# GH 27/06/2012 bug 83199
#Filter [POC] Where ITMREF = [M:MGP]ITMREF(nolign-1) & ENDDAT >= TODAY & PRHFCY = VALEUR
Filter [POC] Where ITMREF = [M:MGP]ITMREF(nolign-1) & ENDDAT >= TODAY & STRDAT <= TODAY & PRHFCY = VALEUR
For [POC]POC2
    If fstat : Break : Endif
    [M:MGP]POHIND(nolign-1) = 2
    If [M:MGP]POHNUM(nolign-1) <> "" & [F:POC]POHNUM = [M:MGP]POHNUM(nolign-1)
        OK = 1
    Endif
Next
Filter [POC]
Affzo [MGP] PLANNER2(nolign-1), BUY(nolign-1), POHIND(nolign-1)
If !OK : [M:MGP]POHNUM(nolign-1) = "" : Affzo [MGP]POHNUM(nolign-1) : Endif

End

########################################
Subprog C_REQDAT(VALEUR)
Variable Date    VALEUR
Local    Date    TODAY : TODAY = date$
If VALEUR < TODAY : mkstat = 2 : Endif
End

########################################
Subprog AM_VCRORISTR(VALEUR)
Variable Char    VALEUR()
If [M]VCRORIEND ="" : [M]VCRORIEND = VALEUR : Affzo VCRORIEND : Endif
If [M]VCRORIEND < VALEUR : [M]VCRORIEND = VALEUR : Affzo VCRORIEND : Endif
End

########################################
Subprog AM_FIE(VALEUR)
Variable Integer VALEUR

Local Integer LINES       # Issue 107498/107
Local Char WKPJT(GLONPJT) # Issue 107498/107

Case VALEUR
  When 1 :    If [M:MGP]PECQTY(nolign-1) <> 0
                  [M:MGP]TOTPECQTY       -= [M:MGP]PECQTY(nolign-1)
                  [M:MGP]PECQTY(nolign-1) = 0
                  If [F:BTS]PLANNER <> 2
                      [M:MGP]PUUPECQTY(nolign-1) = 0
                  Endif
                  If [M:MGP]FLGPEC(nolign-1) = 2 : [M:MGP]FLGREG(nolign-1) = 1 : Endif
              Endif
  When 2 :    If [M:MGP]PECQTY(nolign-1) = 0
                  ## GH 15/05/2014 bug 97405
                  #[M:MGP]PECQTY(nolign-1)     = [M:MGP]RMNEXTQTY(nolign-1)-[M:MGP]ALLQTY(nolign-1)-[M:MGP]MTOQTY(nolign-1)
                  [M:MGP]PECQTY(nolign-1)     = [M:MGP]RMNEXTQTY(nolign-1)
                  If !find([M:MGP]WIPTYP(nolign-1),13,4)
                   [M:MGP]PECQTY(nolign-1) -= [M:MGP]ALLQTY(nolign-1) + [M:MGP]MTOQTY(nolign-1)
                  Endif
                  ##
                  If [F:BTS]PLANNER <> 2
                      # Issue 115840 - 09-05-2016 by STLIG : Incorporate rounding type: up or down, into conversion type parameter.
                      Call PCAL_QTY([M:MGP]PECQTY(nolign-1),
&                                   [M:MGP]STU(nolign-1),
&                                   [M:MGP]PUUPECQTY(nolign-1),
&                                   [M:MGP]PUU(nolign-1),
&                                   [M:MGP]ITMREF(nolign-1),
&                                   [M:MGP]BPSNUM(nolign-1),
&                                   func TRTACHQTE1.ROUND_CONVERSION_TYPE(1,[F:ITF]REOPOL),
&                                   GBIDD1) From TRTACHQTE1
                  Endif
                  [M:MGP]TOTPECQTY       += [M:MGP]PECQTY(nolign-1)
                  If [M:MGP]FLGPEC(nolign-1) = 2 : [M:MGP]FLGREG(nolign-1) = 2 : Endif
              Endif
Endcase
If [F:BTS]PLANNER <> 2 : Affzo [MGP]PUUPECQTY(nolign-1) : Endif # GH 28/04/2014 bug 95576
Affzo [MGP]TOTPECQTY                                            # GH 28/04/2014 bug 95576

[M:MGP]FIE(nolign-1) = VALEUR
# Issue 95576 GA 03/2014 performances (before Gosub HIGHLIGHT)
# Local Integer I : I=nolign-1       # GH 10/04/2014 bug 95576
Gosub HIGHLIGHT_CURLINE

# Issue 107498/107 - if no lines selected, then enable all lines
If (VALEUR = 1)
  LINES = 0
  For  I = 0 To [M:MGP]NBLIG-1
    If [M:MGP]FIE(I) = 2
      LINES = 1
      Break
    Endif
  Next
  If LINES = 0
    For  I = 0 To [M:MGP]NBLIG-1
      Actzo [M:MGP]FIE(I) # enable field
    Next I
  Endif
# Issue 107498/107 - if first line selected, then disable any lines which we cannot group
Elsif (VALEUR = 2)
  LINES = 0
  WKPJT = ""
  For  I = 0 To [M:MGP]NBLIG-1
    If [M:MGP]FIE(I) = 2
      LINES += 1
      If LINES > 1
        Break
      Endif
      WKPJT = [M:MGP]PJT(I)
      If ([M:MGP]PJT(I) <> "")
        # check if management mode is available stock, source not project demand
        Gosub CHECK_CAN_GROUP
        If (LINC_I = 0)
          WKPJT = ""
        Endif
      Endif
    Endif
  Next I
  # if first line selected, disable lines which can not be grouped
  If (LINES = 1)
    For  I = 0 To [M:MGP]NBLIG-1
      # disable lines where project is blank or Management mode = Available stock and source not MTx
      If (WKPJT = "")
        If [M:MGP]PJT(I) <> ""
          Gosub CHECK_CAN_GROUP
          If (LINC_I > 0)
            Grizo [M:MGP]FIE(I) # disable field
            Grizo [M:MGP]FLGPEC(I) # disable field
          Endif
        Endif
      # disable lines which are not for same project
      Else
        If [M:MGP]PJT(I) <> WKPJT
          Grizo [M:MGP]FIE(I) # disable field
          Grizo [M:MGP]FLGPEC(I) # disable field
        Endif
      Endif
    Next I
  Endif
Endif
# End issue 107498/107

End

##########################################################################
