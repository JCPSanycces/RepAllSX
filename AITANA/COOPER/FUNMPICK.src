######################################################################################
# Issue 7729 GA 08/2014 Manufacturing: group different products with a common routing
######################################################################################
Subprog C_ROUNUMS(VALEUR)
Variable Char    VALEUR()
If VALEUR<>"" & [M:MGP]ROUALTS<>0
  #    Lecture ROUTING
  Read [TRO]TRO0=VALEUR
  If fstat : mkstat=2 : End : Endif
  Read [ROH]ROH0=VALEUR;[M:MGP]ROUALTS;[M:MGP]FCY
  If fstat : mkstat=2 : End : Endif
Else
  Raz [M:MGP]ROUALTS: Affzo [M:MGP]ROUALTS
Endif
End

Subprog C_ROUALTS(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0 & [M:MGP]ROUNUMS<>""
  #    Lecture ROUTING
  Read [TRO]TRO0=VALEUR
  If fstat : mkstat=2 : End : Endif
  Read [ROH]ROH0=[M:MGP]ROUNUMS;VALEUR;[M:MGP]FCY
  If fstat : mkstat=2 : End : Endif
Endif
End

######################################################################################
# 106430 - Purhcase planning header fields.
######################################################################################
Subprog AM_TCTRNUM(VALEUR)
Variable Char    VALEUR()

Call UPD_CONTAINER (VALEUR, [M:MGP]TCTRQTY)

End

Subprog AM_TCTRQTY(VALEUR)
Variable Decimal VALEUR

Call UPD_CONTAINER ([M:MGP]TCTRNUM, VALEUR)

End

Subprog AM_WEICAP(VALEUR)
Variable Decimal VALEUR

Raz [M:MGP]WEIAVL
If VALEUR > 0 : [M:MGP]WEIAVL = VALEUR-[M:MGP]WEITOT : Endif

If [M:MGP]WEIAVL<0
  Chgstl [M:MGP]WEIAVL With "NBNEGATIF"
Else
  Chgstl [M:MGP]WEIAVL With ""
Endif

Affzo [M:MGP]WEIAVL

End

Subprog AM_VOLCAP(VALEUR)
Variable Decimal VALEUR

Raz [M:MGP]VOLAVL
If VALEUR > 0 : [M:MGP]VOLAVL = VALEUR-[M:MGP]VOLTOT : Endif

If [M:MGP]VOLAVL<0
  Chgstl [M:MGP]VOLAVL With "NBNEGATIF"
Else
  Chgstl [M:MGP]VOLAVL With ""
Endif

Affzo [M:MGP]VOLAVL

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran MFGPICK) 09/10/2015 14:43:06 (GH)
######################################################################################

Subprog C_IECCVALMAJ(VALEUR)
Variable Char    VALEUR()

If VALEUR<>""
    Filter [EVL] Where ECCTYP=4
    Look [EVL]EVL1(2) = [M:MGP]ITMREFS;VALEUR
    Filter [EVL]
    If fstat>2
       GMESSAGE = mess(308,193,1) # Non-existing version
       mkstat=2 : End
    Endif
Endif

If dim([M:MGP]ICRID)=1 & (VALEUR="" | func ECCLIB.NBRCPN([M:MGP]ITMREFS)=1)
    [M:MGP]ICRID = func TRTX3FNC.CCMID([M:MGP]ITMREFS,VALEUR,"")
    Affzo [MGP]ICRID
    If dim([M:MGP]ICRFLG)>0
       [M:MGP]ICRFLG = string$([M:MGP]ICRID<>"","151") : Affzo [MGP]ICRFLG
    Endif
Endif
End

######################################################################################
Subprog AS_IECCVALMIN(VALEUR)
Variable Char    VALEUR()

If [M:MGP]IECCVALMAJ=""
    mkstat=1
Endif
End

######################################################################################
Subprog C_IECCVALMIN(VALEUR)
Variable Char    VALEUR()

If VALEUR<>""
   Look [EVL]EVL1(3) = [M:MGP]ITMREFS;[M:MGP]IECCVALMAJ;VALEUR;4
   If fstat>2
      GMESSAGE = mess(308,193,1) : # Non-existing version
      mkstat=2 : End
   Endif
Endif

If dim([M:MGP]ICRID)=1 & func ECCLIB.NBRCPN([M:MGP]ITMREFS)=2
    [M:MGP]ICRID = func TRTX3FNC.CCMID([M:MGP]ITMREFS,[M:MGP]IECCVALMAJ,VALEUR)
    Affzo [MGP]ICRID
    If dim([M:MGP]ICRFLG)>0
       [M:MGP]ICRFLG = string$([M:MGP]ICRID<>"","151") : Affzo [MGP]ICRFLG
    Endif
Endif
End

# Issue 107498/107 - 2016-06-10 by JUSYN : Disable enterable fields because of project relationship
######################################################################################
Subprog DISABLE_PROJ_LINES(LLINE)
Value Integer LLINE
If dim([MGP]PJT(LLINE)) > 0
    If [M:MGP]PJT(LLINE) = ""  :  End  :  Endif
Else
    End
Endif

If dim([MGP]POHFCY(LLINE)) > 0    : Diszo [MGP]POHFCY(LLINE)    : Endif
#PATCH If dim([MGP]BPSNUM(LLINE)) > 0    : Diszo [MGP]BPSNUM(LLINE)    : Endif
If dim([MGP]REQDAT(LLINE)) > 0    : Diszo [MGP]REQDAT(LLINE)    : Endif
If dim([MGP]PUUPECQTY(LLINE)) > 0 : Diszo [MGP]PUUPECQTY(LLINE) : Endif
If dim([MGP]PECQTY(LLINE)) > 0    : Diszo [MGP]PECQTY(LLINE)    : Endif
If dim([MGP]PJT(LLINE)) > 0       : Diszo [MGP]PJT(LLINE)       : Endif

If dim([MGP]POHFCY(LLINE)) > 0    : Affzo [MGP]POHFCY(LLINE)    : Endif
#PATCH If dim([MGP]BPSNUM(LLINE)) > 0    : Affzo [MGP]BPSNUM(LLINE)    : Endif
If dim([MGP]REQDAT(LLINE)) > 0    : Affzo [MGP]REQDAT(LLINE)    : Endif
If dim([MGP]PUUPECQTY(LLINE)) > 0 : Affzo [MGP]PUUPECQTY(LLINE) : Endif
If dim([MGP]PECQTY(LLINE)) > 0    : Affzo [MGP]PECQTY(LLINE)    : Endif
If dim([MGP]PJT(LLINE)) > 0       : Affzo [MGP]PJT(LLINE)       : Endif

End

# Issue 107498/107 - 2016-06-22 by JUSYN : treatment to check orders concerning project management conditions
# returned field LMTXFLG 1 for okay 0 for not okay

$CHECK_PROJECT_CONDITIONS
# Issue number 107498/18 - 2016-07-18 by JUSYN : Project task status
Local Integer LPIMSTA
# Issue number 107498/18 - 2016-08-15 by JUSYN : Using existing func PIMPL_CSTD_PROGS.GET_PIMSTA_VALUE
Local Char BUDGET(15)
Local Char TASK(15)
Local Char SMESSAGE(250)

# SEPARATE File ORDERS For PROJECT MANAGEMENT TREATMENT
If clalev([F:ORDM])  = 0 : Local File ORDERS [ORDM]  : Endif
If clalev([F:ORDM2]) = 0 : Local File ORDERS [ORDM2] : Endif

LMTXFLG = 1
# WOS, EOS, POS
If !([F:ORD]WIPTYP=5 & [F:ORD]WIPSTA=3) and !([F:ORD]WIPTYP=13 & [F:ORD]WIPSTA=3) and !([F:ORD]WIPTYP=2 & [F:ORD]WIPSTA=3)
    Return
Endif

# only when project related
If [F:ORD]PJT <> ""
    LMTXFLG = 0
    # check for requirement origin MTx or MWx
    # MTx
    Filter [ORDM]
    Filter [ORDM] Where [F:ORDM]STOFCY = [F:ORD]STOFCY and [F:ORDM]VCRTYP = 40 and [F:ORDM]PJT = [F:ORD]PJT and [F:ORDM]WIPTYP = 14 and [F:ORDM]ITMREF = [F:ORD]ITMREF
& and [F:ORDM]VCRLIN = [F:ORD] VCRLINORI
     Read [ORDM] First
     If !fstat
         # material demand from project material task = MTx = wiptyp 14 and launched
         If [F:ORDM]WIPSTA = 1 : LMTXFLG = 1 : Endif
     Else
         # management mode = by order
         If [F:ITM]STDFLG = 4
             Filter[ORDM2]
             Filter [ORDM2] Where [F:ORDM2]STOFCY = [F:ORD]STOFCY and [F:ORDM2]VCRTYP = 40 and [F:ORDM2]PJT = [F:ORD]PJT and [F:ORDM2]WIPTYP = 14 and [F:ORDM2]VCRLIN = [F:ORD]VCRLINORI
             Read [ORDM2] First
             # Issue number 107498/18 - 2016-07-18 by JUSYN : Order with PJT but without already existing project management material record
             If !fstat
                 If [F:ORDM2]WIPSTA = 1 : LMTXFLG = 1 : Endif
             Else
                 # Issue number 107498/18 - 2016-08-15 by JUSYN : Using existing func PIMPL_CSTD_PROGS.GET_PIMSTA_VALUE
                 LPIMSTA = func PIMPL_CSTD_PROGS.GET_PIMSTA_VALUE (GACTX, [F:ORD]PJT, BUDGET, TASK, SMESSAGE)
                 If LPIMSTA = 2 : LMTXFLG = 1 : Endif
             Endif
             Filter[ORDM2]
         Endif
         # management mode = Available stock
         If [F:ITM]STDFLG = 3
             # material demand with product in management mode = available stock can be processed generally
             LMTXFLG = 1
         Endif
     Endif
     Filter [ORDM]
Endif

Return

