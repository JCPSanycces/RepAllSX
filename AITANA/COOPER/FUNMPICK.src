Subprog AS_ITMREFS(VALEUR)
Variable Char    VALEUR()
GBOUT1 = mess(22,198,1)
End

########################################
Subprog AV_VCRNUM(VALEUR)
Variable Char VALEUR()
End

########################################
Subprog AS_ITMREFSTR(VALEUR)
Variable Char    VALEUR()
GBOUT1 = mess(4,198,1)
End

########################################
Subprog C_ITMREFSTR(VALEUR)
Variable Char    VALEUR()

If VALEUR = "" : End : Endif

If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
    If fstat : mkstat= 1 : End : Endif
Endif

If ([F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2) & [M]FCY <> ""
    Call CTLPLNFLT([M]FCY,VALEUR,[M]PLANNER) From MFGLIB
    If GMESSAGE <> ""
        mkstat = 2
        End
    Endif
Endif

If ([F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2)
    Call CONTROLE("ITM","AB",VALEUR,"",mkstat) From CONTOBJ
    #----- Contrôle code acheteur sur article ou article-site -----#
    Call CTLITMBUY(VALEUR,[M]PLANNER ,mkstat) From TRTACHCTL1
Endif

End

