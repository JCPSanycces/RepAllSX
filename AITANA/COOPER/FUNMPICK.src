Subprog AS_ITMREFEND(VALEUR)
Variable Char    VALEUR()
GBOUT1 = mess(4,198,1)
End

########################################
Subprog C_ITMREFEND(VALEUR)
Variable Char    VALEUR()

If VALEUR = "" : End : Endif

If [F:ITM]ITMREF <> VALEUR
    Read [ITM]ITM0=VALEUR
    If fstat : mkstat= 1 : End : Endif
Endif

If ([F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2) & [M]FCY <> ""
    Call CTLPLNFLT([M]FCY,VALEUR,[M]PLANNER) From MFGLIB
    If GMESSAGE <> ""
        mkstat = 2
        End
    Endif
Endif

If ([F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2)
    Call CONTROLE("ITM","AB",VALEUR,"",mkstat) From CONTOBJ
    #----- Contrôle code acheteur sur article ou article-site -----#
    Call CTLITMBUY(VALEUR,[M]PLANNER ,mkstat) From TRTACHCTL1
Endif

End

########################################
Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Integer    WRETOUR
Local Decimal    WQTY
Local Decimal    WCOEUOM, WCOEF1, WCOEF2
Local Char       WPUU(GLONUOM)

If VALEUR = "" : Goto NXT_BPS : Endif

# interx
If [F:BPR]BPRNUM <> VALEUR
    Read [F:BPR]BPR0=VALEUR
    If fstat : Raz [F:BPR] : Endif
Endif
If [F:BPR]FCY <> ""
    [M:MGP]APPFCY(nolign-1) = [F:BPR]FCY
Endif

#-------------------------------------------#
# vérification couple article - fournisseur #
#-------------------------------------------#
If clalev([F:ITP]) = 0 : Local File ITMBPS [ITP] : Endif
Read [ITP]ITP0 = [M:MGP]ITMREF(nolign-1);VALEUR
If fstat = 0
    # test du code blocage
    If [F:ITP]DOUFLG = 3
           GMESSAGE = mess(9,194,1)
           Call ERREUR(GMESSAGE) From GESECRAN
           mkstat = 2
           End
    Elsif [F:ITP]DOUFLG = 2
           GMESSAGE = mess(9,194,1)
           Call AVERTIR(GMESSAGE, WRETOUR) From GESECRAN
           If WRETOUR= 1
             VALEUR = [M:MGP]BPSNUM(nolign-1)
             mkstat = 2
             End
           Endif
    Endif

    WQTY = [M:MGP]PUUPECQTY(nolign-1)
    WPUU = [F:ITP]PUU

    #----- Récupération des coefficients entre UA et US -----#
    # 05.05 30036
    #----- Récupération des coefficients entre UA et US -----#
    # Issue 115840 - 09-05-2016 by STLIG : Incorporate rounding type: up or down, into conversion type parameter.
    Call PCAL_QTY (1,
&                  [M:MGP]PUU(nolign-1),
&                  GBIDD3,
&                  [M:MGP]STU(nolign-1),
&                  [M:MGP]ITMREF(nolign-1),
&                  [M:MGP]BPSNUM(nolign-1),
&                  func TRTACHQTE1.ROUND_CONVERSION_TYPE(1,[F:ITF]REOPOL),
&                  WCOEF1) From TRTACHQTE1
    # Issue 115840 - 09-05-2016 by STLIG : Incorporate rounding type: up or down, into conversion type parameter.
    Call PCAL_QTY (1,
&                  [F:ITP]PUU,
&                  GBIDD3,
&                  [M:MGP]STU(nolign-1),
&                  [M:MGP]ITMREF(nolign-1),
&                  VALEUR,
&                  func TRTACHQTE1.ROUND_CONVERSION_TYPE(1,[F:ITF]REOPOL),
&                  WCOEF2) From TRTACHQTE1
    If [M:MGP]PUU(nolign-1) <> [F:ITP]PUU | WCOEF1 <> WCOEF2
           GMESSAGE = mess(13,194,1)
           Call MESSAGE(GMESSAGE) From GESECRAN
           #--------- qté achat saisie ------#
           # Issue 115840 - 09-05-2016 by STLIG : Incorporate rounding type: up or down, into conversion type parameter.
           Call PCAL_QTY ([M:MGP]PECQTY(nolign-1),
&                         [M:MGP]STU(nolign-1),
&                         WQTY,
&                         [F:ITP]PUU,
&                         [M:MGP]ITMREF(nolign-1),
&                         VALEUR,
&                         func TRTACHQTE1.ROUND_CONVERSION_TYPE(1,[F:ITF]REOPOL),
&                         [M:MGP]PUUSTUCOE(nolign-1)) From TRTACHQTE1
    Endif
    [M:MGP]PUUPECQTY(nolign-1) = WQTY
    [M:MGP]PUU(nolign-1)       = WPUU
    # qté stock saisie
    # Issue 115840 - 09-05-2016 by STLIG : Incorporate rounding type: up or down, into conversion type parameter.
    Call PCAL_QTY ([M:MGP]PUUPECQTY(nolign-1),
&                  [M:MGP]PUU(nolign-1),
&                  [M:MGP]PECQTY(nolign-1),
&                  [M:MGP]STU(nolign-1),
&                  [M:MGP]ITMREF(nolign-1),
&                  VALEUR,
&                  func TRTACHQTE1.ROUND_CONVERSION_TYPE(1,[F:ITF]REOPOL),
&                  [M:MGP]PUUSTUCOE(nolign-1)) From TRTACHQTE1
    Affzo [MGP]PUU(nolign-1), PUUPECQTY(nolign-1),PECQTY(nolign-1)  # GH 28/04/2014 bug 95576
    Goto FIN_BPS   # Issue 97007 GA 02/2014
    #Gosub HIGHLIGHT
    #End
Endif
$NXT_BPS
# couple article - fournisseur n'existe pas
# Issue 77999 - 2011-11-18 by VPO : référencement inutile si fournisseur de type Divers
If [F:BPS]BPSNUM<>VALEUR
  Read [BPS]BPS0=VALEUR
  If fstat : Raz [F:BPS] : Endif
Endif
#----- Si fournisseur <> Divers -----#
If [F:BPS]BPSTYP<>3
  # Issue 6976 - 2011-12-16 by MUARN : référencement inutile si article type générique
  If [F:ITM]ITMREF <> [M]ITMREF(nolign-1)
    Read [ITM]ITM0=[M]ITMREF(nolign-1)
    If fstat : Raz [F:ITM] : Endif
  Endif
  If [F:ITM]GENFLG <> 2
    # couple article - fournisseur n'existe pas
    If GITMBPS = 1
        # paramètre général : on ne continue pas
        Call ERREUR(mess(8,194,1)) From GESECRAN
        mkstat = 2
        End
    Elsif GITMBPS = 2
        # paramètre général : facultatif donc avertir
        Call AVERTIR(mess(8,194,1),WRETOUR) From GESECRAN
        If WRETOUR = 1
            VALEUR = [M:MGP]BPSNUM(nolign-1)
            mkstat = 2
            End
        Endif
    Endif
  Endif
Endif
$FIN_BPS
[M:MGP]BPSNUM(nolign-1) = VALEUR

# 01.05 27638
If ([F:BTS]BUYER = 2 | [F:BTS]INTBUY = 2) & ([M:MGP]BPSNUM(nolign-1) = "" | [M:MGP]PUUPECQTY(nolign-1) = 0)
    [M:MGP]FIE(nolign-1) = 1
Else
    If ([F:BTS]APPBUY = 2 | [F:BTS]APPINT = 2) & ([M:MGP]PUUPECQTY(nolign-1) = 0)
        [M:MGP]FIE(nolign-1) = 1
    Else
        [M:MGP]FIE(nolign-1) = 2
    Endif
Endif
Affzo [MGP]FIE(nolign-1)             # GH 28/04/2014 bug 95576

# Issue 95576 GA 03/2014 performances (before Gosub HIGHLIGHT)
# Local Integer I : I=nolign-1       # GH 10/04/2014 bug 95576
Gosub HIGHLIGHT_CURLINE

End

########################################
Subprog C_POHNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer WOK
Local    Date    WDATREF
Local    Date    TODAY : TODAY = date$

If VALEUR = "" : End : Endif

Look [POH]POH0=VALEUR
If fstat: GMESSAGE = mess(354,197,1) : mkstat = 2 : End : Endif

If [M:MGP]ENDDAT(nolign-1) >= TODAY
    WDATEREF = [M:MGP]ENDDAT(nolign-1)
Else
    WDATEREF = TODAY
Endif
# GH 27/06/2012 bug 83199
#Filter [POC] Where POHNUM = VALEUR & ITMREF = [M:MGP]ITMREF(nolign-1) & ENDDAT >= WDATEREF & PRHFCY = [M:MGP]STOFCY(nolign-1)
Filter [POC] Where POHNUM = VALEUR & ITMREF = [M:MGP]ITMREF(nolign-1) & ENDDAT >= WDATEREF & PRHFCY = [M:MGP]STOFCY(nolign-1)
&                & STRDAT <= WDATEREF
WOK = 0
For [POC]POC1
    WOK = 1 : Break
Next
Filter [POC]
If !WOK : GMESSAGE = mess(128,192,1) : mkstat = 2 : End : Endif
End

