##########################################################################
Subprog B2_NBLIG
End

##########################################################################
## Etiquette ajoutée par le superviseur 20/02/2004 09:43:46 (LLC)
##########################################################################
Subprog C_BPSNUM(VALEUR)
Variable Char    VALEUR()
#Local    Integer INDINTER : INDINTER = 0

If VALEUR <> ""
    Read [BPR]BPR0=VALEUR
    If fstat : Raz [F:BPR] : Endif

    If [F:BPR]FCY <> "" & [F:FCY]FCY <> [F:BPR]FCY
        Read [FCY]FCY0=[F:BPR]FCY
        If fstat : Raz [F:FCY] : Endif
    Endif

    If [M:MGP]APPPRF = 1 & [F:BPR]FCY <> "" & [F:FCY]LEGCPY = GSOCIETE
        GMESSAGE =mess(233,193,1) :  mkstat=2 : End
    Endif
    If [M:MGP]APPPRF = 2 & ([F:BPR]FCY = "" | ([F:BPR]FCY <> "" & [F:FCY]LEGCPY <> GSOCIETE))
        GMESSAGE =mess(235,193,1) :  mkstat=2 : End
    Endif
    ## GH 28/07/2014 bug 101438
    # If [F:BPR]FCY =  [M:MGP]FCY
    ## GH 13/11/2014 bug 101438
    If [F:BPR]FCY <> "" & [F:BPR]FCY = [M:MGP]FCY
        GMESSAGE =VALEUR-[M:MGP]FCY-mess(334,194,1) :  mkstat=2 : End
    Endif
    ##
    # If [F:BPR]FCY <> "" & [F:FCY]LEGCPY = GSOCIETE  : INDINTER = 1 : Endif
Endif

End

##########################################################################
## Etiquette ajoutée par le superviseur 25/02/2004 08:50:05 (LLC)
##########################################################################
Subprog APRES_NBLIG
#After line
# 106430 - Add current line back to Purchase planning header total fields
If [F:BTS]PLANNER <> 2
  Call UPD_PPLINTOTALS
  [M:MGP]TOTCOST  += [M:MGP]LINAMT(nolign-1)
  [M:MGP]WEITOT   += [M:MGP]LINTCTRWEI(nolign-1)
  [M:MGP]VOLTOT   += [M:MGP]LINTCTRVOL(nolign-1)
  # Calculate the available amounts
  If [M:MGP]WEICAP > 0 : [M:MGP]WEIAVL = [M:MGP]WEICAP-[M:MGP]WEITOT : Endif
  If [M:MGP]VOLCAP > 0 : [M:MGP]VOLAVL = [M:MGP]VOLCAP-[M:MGP]VOLTOT : Endif
  Call UPD_AVAILFIELDS
  Affzo [M:MGP]WEITOT, VOLTOT, WEIAVL, VOLAVL, TOTCOST
Endif

End

Subprog AVANT_NBLIG
#Before line
# 106430 - Remove current line from Purchase planning header total fields
If [F:BTS]PLANNER <> 2
  [M:MGP]TOTCOST  -= [M:MGP]LINAMT(nolign-1)
  [M:MGP]WEITOT   -= [M:MGP]LINTCTRWEI(nolign-1)
  [M:MGP]VOLTOT   -= [M:MGP]LINTCTRVOL(nolign-1)
  # Calculate the available amounts
  If [M:MGP]WEICAP > 0 : [M:MGP]WEIAVL = [M:MGP]WEICAP-[M:MGP]WEITOT : Endif
  If [M:MGP]VOLCAP > 0 : [M:MGP]VOLAVL = [M:MGP]VOLCAP-[M:MGP]VOLTOT : Endif
  Call UPD_AVAILFIELDS
  Affzo [M:MGP]WEITOT, VOLTOT, WEIAVL, VOLAVL, TOTCOST
Endif

# Issue 107498/107 - 2016-06-10  by JUSYN : Disable enterable fields because of project link
Call DISABLE_PROJ_LINES(nolign-1)

End

