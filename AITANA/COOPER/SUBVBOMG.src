#<AdxTL>@(#)5.0.0.0 $Revision$
# Gestion du masque VISUBOMG - Visualisation graphique nomenclature multi-niveaux
######################################################################################

$ACTION
If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
 When "AB2_NBLIG" : # Avant tunnel vers articles
 When "BB2_NBLIG" : # Apres tunnel vers articles
 When "AB3_NBLIG" : # avant Cas d'emploi
                    Gosub AB3_NBLIG
 When "BB3_NBLIG" : # apres Cas d'emploi
 When "AB4_NBLIG" : Gosub AVANT_NOMP
 When "AB5_NBLIG" : Gosub AVANT_NOMS
Endcase
Return

######################################################################################
$AB3_NBLIG
# action VISUBOMWUS se base sur la ligne courante [F:ITF]
  Read [ITF]ITF0=[M:VBOG]XCPNITMREF;[M:VBOG]STOFCY
  If fstat Raz [F:ITF] Endif
  GFONCTION = "VISUBOMG"
Return

######################################################################################

$AVANT_NOMP

Local Char     WCLE1(GLONITM)
Local Char     WCLE2(15)
Local Integer  NBTBO
Local Char CLETMP

  WCLE1=[M:VBOG]CPNITMREF(nolign-1)
  #   sélectionner les alt. de nomenclature compatibles
  # si décliné par société, il faudra filtrer aussi sur le site
  If clalev([F:TBO]) = 0 : Local File TABBOMALT   [TBO]  : Endif
  For [TBO]TBO0 Where MFGUSE=2 & BOMALTTYP=2
    GBOMALT(NBTBO) = [F:TBO]BOMALT
    NBTBO += 1
  Next
#
  ###If clalev([F:BOH]) > 0 : Close File [BOH] : Endif
  #  FILTRE sur article parent
  ###Local File BOM [F:BOH] Where find(BOMALT, GBOMALT) & ITMREF=WCLE1  & BOMALTTYP = 2
  If clalev([F:BOH]) = 0 : Local File BOM   [BOH]  : Endif
  Filter [BOH] Where find(BOMALT, GBOMALT) & ITMREF=WCLE1  & BOMALTTYP = 2
  Read [F:BOH]BOH0 First
  If !fstat : WCLE2 = num$([F:BOH]BOMALT) : Endif
  #WCLE2 = num$([M:VBOG]BOMALT)
  Filter [BOH]
#
  GFONBOD="BOMP"
  GDATEREF=date$
  GFONCTION = "GESBODP"
  # on sauvegarde l'enregistrement courant
Return


######################################################################################
$AVANT_NOMS

Local Char     WCLE1(GLONITM)
Local Char     WCLE2(15)
Local Integer  NBTBO

  WCLE1=[M:VBOG]CPNITMREF(nolign-1)
  #   sélectionner les alt. de nomenclature compatibles
  # si décliné par société, il faudra filtrer aussi sur le site
  If clalev([F:TBO]) = 0 : Local File TABBOMALT   [TBO]  : Endif
  For [TBO]TBO0 Where BOMALTTYP=3
    GBOMALT(NBTBO) = [F:TBO]BOMALT
    NBTBO += 1
  Next
#
  ###If clalev([F:BOH]) > 0 : Close File [BOH] : Endif
  #  FILTRE sur article parent
  ###Local File BOM [F:BOH] Where find(BOMALT, GBOMALT) & ITMREF=WCLE1  & BOMALTTYP = 3
  If clalev([F:BOH]) = 0 : Local File BOM   [BOH]  : Endif
  Filter [BOH] Where find(BOMALT, GBOMALT) & ITMREF=WCLE1  & BOMALTTYP = 3
  Read [F:BOH]BOH0 First
  If !fstat : WCLE2 = num$([F:BOH]BOMALT) : Endif
  Filter [BOH]
#
  GFONBOD="BOMS"
  GDATEREF=date$
  GFONCTION = "GESBODS"

Return


######################################################################################

#Subprog AV_MSTOFCY(VALEUR)
#Variable Char    VALEUR()
#If [M:VBOG]STOFCY = "" : Raz VALEUR : Else : VALEUR = "("+[M]STOFCY+")" : Endif
#End


######################################################################################
Subprog AM_PARITMREF(VALEUR)
Variable Char    VALEUR()
  # Lecture composé
  Read [ITM1]ITM0=VALEUR
  If fstat : End : Endif
  Look [F:BOH3]BOH0=VALEUR;[M:VBOG]BOMALT;[M:VBOG]BOMALTTYP
  If fstat > 0 Then
    [M:VBOG]BOMALT = 0
    Affzo [M:VBOG]BOMALT
  Endif
  # [M:VBOG]BOMSTU  = [F:ITM1]STU :  ## GH 06/03/2013 bug 87902

# Issue 109708 - 2015-07-24 by JUSYN : ECC versioning
If dim([M:VBOG]VBOGECCMAJ) > 0
    Affzo [M:VBOG]VBOGECCMAJ
    Affzo [M:VBOG]VBOGECCMIN
    If VALEUR <> ""
        Local Integer I
        I = func ECCLIB.NBRCPN(VALEUR)
        If I > 0
           Actzo [M:VBOG]VBOGECCMAJ
        Else
           Diszo [M:VBOG]VBOGECCMAJ
        Endif
        If I > 1
           Actzo [M:VBOG]VBOGECCMIN
        Else
           Diszo [M:VBOG]VBOGECCMIN
        Endif
    Else
        Diszo [M:VBOG]VBOGECCMIN
        Diszo [M:VBOG]VBOGECCMAJ
    Endif
Endif

End

######################################################################################
Subprog AS_NBLIG
Local Integer NOL

NOL = nolign-1
Effzo [M:VBOG]30
If NOL>0
   Gosub CHARGE_BOD From VISUBOMG
Else
   Gosub CHARGE_BOH From VISUBOMG
Endif
End

######################################################################################
Subprog AS_XCPNITMREF(VALEUR)
Variable Char     VALEUR
mkstat=2
End

######################################################################################
Subprog IB_NBLIG
Local Integer  NBTBO
Local Integer NOBOM
Local Integer OITF

# FQ 60665 GA 12/2009 (????)
  If !clalev([F:TBO]) : Local File TABBOMALT     [TBO]  Endif
  #Filter [TBO] Where [F:TBO]MFGUSE=2 & [F:TBO]BOMALTTYP = [M:VBOG] BOMALTTYP & find ([F:TBO] FCY,"", [M:VBOG] STOFCY)
  Filter [TBO] Where MFGUSE=2 & BOMALTTYP = [M:VBOG]BOMALTTYP & find (FCY,"",[M:VBOG]STOFCY)
    For [TBO] TBO0
      GBOMALT(NBTBO)=[F:TBO]BOMALT
    Next
    NBTBO = rowcount([TBO])
  Filter [TBO]
  If !clalev([BOH]) Local File BOM [BOH] Endif
  Read [F:BOH] BOH0 = [M:VBOG]PARITMREF;[M:VBOG]BOMALT;[M:VBOG]BOMALTTYP
  Look [F:BOH]BOH0 = [M:VBOG]CPNITMREF(nolign-1);[M:VBOG]BOMALT;ALTTYPR(nolign)
  If fstat > 0 or clalev([M:BOD1]) > 0  Then
    NOBOM = 1
  Endif
  #STANT Pourquoi limiter la remonter sur les nomenclatures productions au composé ayant un article site ?
#  If nolign > 1 Then
#    If !clalev([F:ITF]) : Local File ITMFACILIT [F:ITF] :OITF=1: Endif
#    Read [F:ITF]ITF0 = [M:VBOG]CPNITMREF(nolign-1);[M:VBOG]STOFCY
#    If fstat > 0 Then
#      NOBOM = 1
#    Elsif !find([F:ITF]REOCOD,1,3,5,0)Then
#      NOBOM = 1
#    Endif
#    If OITF : Close File [ITF] : Endif
#  Endif
  If [M:VBOG]ALTTYPR(nolign) = 2  Then
    GBOUT5 = ""
  Elsif [M:VBOG]ALTTYPR(nolign) = 3  Then
    GBOUT4 = ""
  Endif

  If [M:VBOG]XCPNTYP = 4 or NOBOM = 1 Then  #si le type de composé est un sous produit, on ne remonte pas sur les nomenclatures
    GBOUT5 = ""
    GBOUT4 = ""
  Endif
  If [M:VBOG]XCPNTYP = 5 Then
    GBOUT2 = ""
    GBOUT3 = ""
    GBOUT4 = ""
    GBOUT5 = ""
    GBOUT6 = ""
  Endif
  If find("CASNOMENP", GNAVIG(1..GPILNAV-1))
    GBOUT3 = ""
  Elsif find("CONSSFC",GNAVIG(1..GPILNAV-1))
    GBOUT6 = ""
  Endif
  # FQ 71292 GA 02/2010
  #If NOBOM = 0 :  Close File [BOH] : Endif
End


######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUBOMG) 09/10/2008 11:04:35 (STANT)
######################################################################################
Subprog AS_BOMALTTYP(VALEUR)
Variable Integer VALEUR

  GMENLOC(1)=1
  Filter[BOH3] Where BOMALTTYP = VALEUR
  Case VALEUR
    When 2 : GFONBOD = "BOMP"
    When 3 : GFONBOD = "BOMS"
  Endcase

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUBOMG) 09/10/2008 11:55:01 (STANT)
######################################################################################
Subprog AS_PARITMREF(VALEUR)
Variable Char    VALEUR()
Global Char G_MEM_ITM

  Case BOMALTTYP
    When  2: [M:VBOG]OPTION_ITM = "C" : # Sélection des articles fabriqués
      [M:VBOG]FILTRE     = "MFGFLG=2" : # Article fabriqué
      [M:VBOG]OPTIONA    = "B"
    When 3: [M:VBOG]OPTION_ITM = "D" : # Sélection des articles sous-traités
      [M:VBOG]FILTRE     = "SCPFLG=2" : # Article sous-traité
      [M:VBOG]OPTIONA    = "D"
  Endcase
  G_MEM_ITM = VALEUR
 End


######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUBOMG) 09/10/2008 16:50:03 (STANT)
######################################################################################
Subprog AP_BOMALTTYP(VALEUR)
Variable Integer VALEUR

  If VALEUR <> [M:VBOG]BOMALTTYP Then
    Case VALEUR
      When 2 : GFONBOD = "BOMP"
      When 3 : GFONBOD = "BOMS"
    Endcase

    Filter[BOH3] Where BOMALTTYP = VALEUR
    [M:VBOG]PARITMREF = ""
    [M:VBOG]BOMALT = 0
    Affzo [M:VBOG]PARITMREF,BOMALT
  Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUBOMG) 13/10/2008 10:03:16 (STANT)
######################################################################################
Subprog C_PARITMREF(VALEUR)
Variable Char    VALEUR()
  Look [F:BOH1]BOH0(1) = VALEUR
  If fstat >=2 Then
     GERR=1
     GMESSAGE=mess(40,7750,1)  # article non conforme
     mkstat=2
  Endif

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUBOMG) 06/11/2008 16:45:09 (STANT)
######################################################################################
Subprog S_PARITMREF(VALEUR)
Variable Char    VALEUR()
  If dim(G_MEM_BOMALT)>0 & G_MEM_BOMALT <> [M:VBOG]BOMALT & VALEUR <> "" & [M:VBOG]STOFCY <> "" Then
    Gosub TRT_AFFBOM From VISUBOMG
  Endif
End   # FQ 71292 Ctrl des sources End manquant


######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUBOMG) 07/11/2008 14:16:05 (STANT)
######################################################################################
Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
Global Char G_MEM_FCY(GLONFCY)

G_MEM_FCY = VALEUR
End

Subprog AS_BOMALT(VALEUR)
Variable Decimal VALEUR
Global Integer G_MEM_BOMALT
G_MEM_BOMALT = VALEUR

End

######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUBOMG) 13/11/2008 17:21:47 (STANT)
######################################################################################
Subprog IB_PARITMREF

 # on bloque le tunnel si l'on vient des articles ou des articles site
  If GPILNAV > 1 Then
    If find(GNAVIG(GPILNAV-1),"GESITM") or find(GNAVIG(GPILNAV),"GESITM") Then
      GBOUT1=""
    Endif
  Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran VISUBOMG) 19/02/2014 14:30:46 (GH)
######################################################################################
Subprog C_DATREF(VALEUR)
Variable Date    VALEUR

# Issue 109708 - 2015-09-04 by JUSYN : versioning
If func ECCLIB.NBRCPN([M:VBOG]PARITMREF)
   [M:VBOG]DATREF = VALEUR
   Gosub READECC From ECCVISUBOM
Endif

# Issue 94442 GH 23/07/2018 -  Loading was triggered only if reference date was changed for folder with no versioning
mkstat=4 : # pour declencher l'affichage de l'arborescence apres passage sur la zone
End

######################################################################################
## Section automatically added (screen VISUBOMG) 23.07.2015 14:28:04 (JUSYN)
######################################################################################
# Issue 109708 - 2015-08-21 by JUSYN : versioning
Subprog C_VBOGECCMIN(VALEUR)
Variable Char    VALEUR()

Filter [EVL] Where USESTA=[M:VBOG]USESTA
Read [EVL]EVL1 = [M:VBOG]PARITMREF;[M:VBOG]VBOGECCMAJ;VALEUR;[M:VBOG]BOMALTTYP
Filter [EVL]
If fstat>2
   GMESSAGE = mess(308,193,1) : mkstat=2 : # Non existing version
Elsif [M:VBOG]DATREF<[F:EVL]STRDAT | ([M:VBOG]DATREF>[F:EVL]ENDDAT & [F:EVL]ENDDAT<>[0/0/0])
   GDATEREF=[F:EVL]STRDAT : [M:VBOG]DATREF=GDATEREF : Affzo [VBOG]DATREF
Endif
End

Subprog C_VBOGECCMAJ(VALEUR)
Variable Char    VALEUR()

If VALEUR=""
   Filter [EVL] Where ITMREF=[M:VBOG]PARITMREF & ECCTYP=[M:VBOG]BOMALTTYP & USESTA=[M:VBOG]USESTA
   If rowcount([EVL])=0
      GMESSAGE = mess(10,123,1) : mkstat=2 : # Mandatory field
   Else
      GDATEREF=[0/0/0] : [M:VBOG]DATREF=GDATEREF : Affzo [VBOG]DATREF
   Endif
   Filter [EVL]
   End
Endif

Local Integer OK
Local Char FMT(GLONICVVAL)
Filter [EVL] Where ECCTYP=[M:VBOG]BOMALTTYP & USESTA=[M:VBOG]USESTA
Read [EVL]EVL1(2) = [M:VBOG]PARITMREF;VALEUR
If fstat>2 & find(GREP,"C","D")
   If !func ECCLIB.CTLCPN([M:VBOG]PARITMREF,1,VALEUR,FMT)
     If FMT=""
        GMESSAGE = mess(209,187,1)
     Else
        GMESSAGE = mess(209,187,1)-"("+FMT+")"+string$(GMESSAGE<>"","\")+GMESSAGE
     Endif
     mkstat=2 :  # Incorrect format for version
   Endif
Elsif fstat>2
   GMESSAGE = mess(308,193,1) : mkstat=2 : # Non existing version
Elsif VALEUR<>[M:VBOG]VBOGECCMAJ & func ECCLIB.NBRCPN([M:VBOG]PARITMREF)=1
   OK=1 : mkstat = 4
Elsif VALEUR<>[M:VBOG]VBOGECCMAJ & func ECCLIB.NBRCPN([M:VBOG]PARITMREF)=2
   Read [EVL]EVL1 = [M:VBOG]PARITMREF;VALEUR;[M:VBOG]VBOGECCMIN;[M:VBOG]BOMALTTYP
   If fstat<2 : OK=1 : Else Effzo [VBOG]VBOGECCMIN : Endif
Endif
Filter [EVL]
If OK & ([M:VBOG]DATREF<[F:EVL]STRDAT | ([M:VBOG]DATREF>[F:EVL]ENDDAT & [F:EVL]ENDDAT<>[0/0/0]))
   GDATEREF = [F:EVL]STRDAT : [M:VBOG]DATREF = GDATEREF
   [M:VBOG]ECCSTRDAT  = [F:EVL]STRDAT
   [M:VBOG]ECCENDDAT  = [F:EVL]ENDDAT
   Affzo [VBOG]DATREF, ECCSTRDAT, ECCENDDAT
Endif
End

######################################################################################
## Section automatically added (screen VISUBOMG) 24.07.2015 10:25:50 (JUSYN)
######################################################################################
# Issue 109708 - 2015-08-21 by JUSYN : versioning
Subprog AM_BOMALT(VALEUR)
Variable Decimal VALEUR

If func ECCLIB.NBRCPN([M:VBOG]PARITMREF) : # Issue 94442 GH 23/07/2018 - crash for a folder with no versioning
  If VALEUR = evalue("[F:ITM]ECCBOMALT"+ num$([M:VBOG]BOMALTTYP) +"(0)")
      [M:VBOG]USESTA = 1
  Elsif VALEUR = evalue("[F:ITM]ECCBOMALT"+ num$([M:VBOG]BOMALTTYP) +"(1)")
      [M:VBOG]USESTA = 2
  Endif
  Affzo [M:VBOG]USESTA
Endif

End

