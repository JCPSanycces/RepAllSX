#<AdxTL>@(#)0.0.0.0 $Revision$ Gestion objet PJM
##########################################################################################################
# Objet PJM
##########################################################################################################
##########################################################################################################
$ACTION
  Case ACTION
    When "OUVRE"        : Gosub OUVRE               From SUBPJMA
    When "FERME"        : Gosub FERME               From SUBPJMA
    When "LIENS"        : Gosub LIENS               From SUBPJMA
    When "FIN_ACTION"   : Gosub FIN_ACTION          From SUBPJMA
    When "ABANDON"      : Gosub ABANDON             From SUBPJMA
    When "BOITE"        : Gosub BOITE               From SUBPJMA
    When "OUVRE_BOITE"  : Gosub OUVRE_BOITE         From SUBPJMA
    When "FILTRE"       : Gosub FILTRE              From SUBPJMA
    When "FILGAUCHE"    : Gosub FILGAUCHE           From SUBPJMA
    When "AVANTBOUT"    : Gosub AVANTBOUT           From SUBPJMA     # Issue X3-99928 - 2018-07-19 by FGR
    When "SETBOUT"      : Gosub SETBOUT             From SUBPJMA
    When "EXEBOUT"      : Gosub EXEBOUT             From SUBPJMA
    When "STATUT"       : Gosub STATUT              From SUBPJMA    # Issue X3-6201/119572 - 2016-11-15 by FGR
    When "RAZCRE"       : Gosub RAZCRE              From SUBPJMA
    When "RAZDUP"       : Gosub RAZDUP              From SUBPJMA
    When "CREATION"     : Gosub CREATION            From SUBPJMA
    When "APRES_CRE"    : Gosub APRES_CRE           From SUBPJMA     # Issue 109158-11
    When "MODIF"        : Gosub MODIF               From SUBPJMA
    When "APRES_MOD"    : Gosub APRES_MOD           From SUBPJMA
    When "AV_ANNULE"    : Gosub AV_ANNULE           From SUBPJMA
    When "ANNULE"       : Gosub ANNULE              From SUBPJMA
    When Default
  Endcase
Return

##########################################################################################################
##########################################################################################################
# Screens fields
##########################################################################################################
# PJM0
##########################################################################################################
##########################################################################################################
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()

Local Integer NI
Local Integer MY_STATUS
Local Char    WMODELE(GLONGCM)

  # ------------------------
  If GZINSPJM = null Then
    GMESSAGE = mess(1013,196,1)
    GERR = 1
    mkstat = 2
    End
  Endif
  # ------------------------
  GZINSPJM.SALFCY = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GERR = 1
    mkstat = 2
    End
  Else
    SetInstance [F:OPP] With GZINSPJM.PJM(1)
    [M:PJM0] = [F:OPP]
    [M:PJM1] = [F:OPP]
    SetInstance [F:OPPPJM] With GZINSPJM.PJM(1)
    [M:PJM0] = [F:OPPPJM]
    [M:PJM1] = [F:OPPPJM]
    Affzo [M:PJM0]1-99
    Affzo [M:PJM1]1-99
  Endif
  # ------------------------
  [M:PJM0]SALFCY = VALEUR
  # ------------------------
  GFCY = [M:PJM0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  GFINRSP = fmet GZINSPJM.ACTX.ACACHE.AFCY.AGETVALCHAR([M:PJM0]SALFCY, "FINRSPFCY")
  #
  Call SETGCM(GSOCIETE, [L]WMODELE) From CPTDIV
  #----- Chargement codes plans, types de référentiel d'une société   -----#
  Call SETPLAN3([L]WMODELE, GNBCOA, GCOA, GTYPLED) From CPTDIV
  #
  [L]MY_STATUS = func SUBPJMA.CDIE_CLASS_TO_SCREEN(GZINSPJM.PJM(1), "PJM4", "NBRDIE", "SUBPJMA")
  # ------------------------
  Affzo [M:PJM4]1-99
End

##########################################################################################################
# PJM1
##########################################################################################################
##########################################################################################################
Subprog AM_OPPCMP(VALEUR)
Variable Char    VALEUR()

  GZINSPJM.OPPCMP = VALEUR
  [M:PJM1]OPPMCN = GZINSPJM.OPPMCN
  If [M:PJM1]OPPREP = "" Then
    [M:PJM1]OPPREP = GZINSPJM.OPPREP
  Endif
  [M:PJM1]CUR = GZINSPJM.CUR
  # ------------------------
  GFCY = [M:PJM0]SALFCY
  Call GETDEV(GFCY) From DEVSUB
  [M:PJM1]OPPCMP = VALEUR
  Affzo [M:PJM0]1-99
  Affzo [M:PJM1]1-99
End

##########################################################################################################
# PJM2
##########################################################################################################

##########################################################################################################
# PJM3
##########################################################################################################

##########################################################################################################
# PJM4
##########################################################################################################
Subprog AM_CCE(VALEUR)
Variable Char    VALEUR()

  GZINSPJM.PJM(1).CDIE([M:PJM4]COLLIN(nolign-1)).CCE = VALEUR
  # ---------------------------
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GERR = 1
    mkstat = 2
    End
  Endif
  # ---------------------------
End

##########################################################################################################
# PJM6
##########################################################################################################
Subprog C_NBPJM6

  # Issue X3-39889 - 2017-08-16 by FGR
  If status = 82 or status = 73 Then
    # Insert line
    If [M:PJM6]PAFCLB(nolign-1) = AVOID.ACHAR Then
      ILINE = fmet GZINSPJM.PJM(1).ADDLINE("PAF", [V]CST_ALASTPOS)
      If ILINE <> [V]CST_ANOTDEFINED Then
        Call SHOW_PJM_PJM6(ILINE) From SUBPJMA
      Else
        GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
        GERR = 4
        mkstat = 2
        GOK = 1
        End
      Endif
      Affzo [M:PJM6]5
    Endif
  Elsif status = 65 Then
    # Delete a line
    IRET = fmet GZINSPJM.PJM(1).ADELLINE("PAF", GZINSPJM.PJM(1).PAF([M:PJM6]COLLIN(nolign-1)).AORDER)
    If IRET = [V]CST_ANOTDEFINED Then
      GMESSAGE = func SYRSTACKTOOLS.MSGSTACK_GET_FIRST_MAX_MESSAGE(GZINSPJM)
      GOK = 0
      GERR = 1
      mkstat = 2
    Endif
  Endif
End

##########################################################################################################
Subprog AM_PAFCLB(VALEUR)
Variable Char    VALEUR()

  # Issue X3-39889 - 2017-08-16 by FGR
  #  [M:PJM6]PAFCLB(nolign-1) = VALEUR
  #  # -----------------------------
  #  Call LECTEXTRA([M:PJM6]PAFNAM(nolign-1),"AUTILIS","INTUSR",VALEUR,"") From ATEXTRA # Issue X3-5205/119116 - 2016-10-10 by SINGO
  #  # -----------------------------
  #  Read [PAS]PAUS = VALEUR
  #  If !fstat Then
  ##    [M:PJM6]PAFNAM(nolign-1) = [F:PAS]PAUSNAM # Issue X3-5205/119116 - 2016-10-10 by SINGO : Removed from class and table
  #    [M:PJM6]PAFROL(nolign-1) = [F:PAS]PAUSROL
  #  Else
  #    GMESSAGE = func AFNC.MES1(mess(185,2260,1), VALEUR)
  #    GERR = 1
  #    mkstat = 2
  #    End
  #  Endif
  #  # -----------------------------
  #  Affzo [M:PJM6]PAFNAM(nolign-1)
  #  Affzo [M:PJM6]PAFROL(nolign-1)
  GZINSPJM.PJM(1).PAF([M:PJM6]COLLIN(nolign-1)).PAFCLB = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).PAF([M:PJM6]COLLIN(nolign-1)).PAFCLB = GZINSPJM.PJM(1).PAF([M:PJM6]COLLIN(nolign-1)).snapshot.PAFCLB
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_PJM_PJM6([M:PJM6]COLLIN(nolign-1)) From SUBPJMA
  Endif
  # -----------------------------
  Affzo [M:PJM6]1-99
End

##########################################################################################################
Subprog AM_PAFROL(VALEUR)
Variable Char    VALEUR()

  # Issue X3-39889 - 2017-08-16 by FGR
  GZINSPJM.PJM(1).PAF([M:PJM6]COLLIN(nolign-1)).PAFROL = VALEUR
  Call RECOVERS_ERROR_IN_CLASSIC(GZINSPJM) From SUBPJMA
  If GERR = 1 Then
    GZINSPJM.PJM(1).PAF([M:PJM6]COLLIN(nolign-1)).PAFROL = GZINSPJM.PJM(1).PAF([M:PJM6]COLLIN(nolign-1)).snapshot.PAFROL
    GERR = 1
    mkstat = 2
    End
  Else
    Call SHOW_PJM_PJM6([M:PJM6]COLLIN(nolign-1)) From SUBPJMA
  Endif
End

