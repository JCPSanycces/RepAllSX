#<AdxTL>@(#)0.0.0.0 $Revision$
#####################################################################################
# Src: SPESFTL
#-------------------------------------------------------------------------------------
# (Seguimiento tallet)
#-------------------------------------------------------------------------------------
# Proyecto: JAE
#-------------------------------------------------------------------------------------
# Version: v11
#-------------------------------------------------------------------------------------
# Fecha:01-12-2017
#-------------------------------------------------------------------------------------
# Desarrollador: DSAL
# Codigo Actividad: YS001
#######################################################################################
$ACTION
Return

######################################################################################
$LOAD_LIGNES
# Solamente si hay líneas cargadas
If [M:SFTL1]NBLIG > 0
  # Abro tablas
  If !clalev([YY0])   : Local File MFGITM    [YY0]   : Endif
  If !clalev([YY1])   : Local File MFGOPE    [YY1]   : Endif
  If !clalev([YY2])   : Local File MFGMAT    [YY2]   : Endif
  If !clalev([YY3])   : Local File ITMMASTER [YY3]   : Endif
  If !clalev([YY4])   : Local File ATEXTRA   [YY4]   : Endif   #JAE

  # Para cada línea cargada alimento los campos específicos
  Local Integer J
  For J=0 To [M:SFTL1]NBLIG-1
    For [YY0] Where [YY0]MFGNUM = [M:SFTL1]MFGNUM(J)
      [M:SFTL1]YARTICULO(J) = [YY0]ITMREF
      [M:SFTL1]YCANTIDAD(J) = [YY0]EXTQTY
      Break
    Next
    Read [YY1]MFO0 =  [M:SFTL1]MFGNUM(J);[M:SFTL1]OPENUM(J);0
    If fstat = 0
      [M:SFTL1]YOPERACION(J) = [YY1]ROODES
      [M:SFTL1]YORDEN(J)     = [YY1]YORDEN
    Endif
    # Muestro ahora la relación de compontenes
    # Muestro ahora la relación de compontenes, solamente para MTB; para JAE muestro el proyecto (código y descripción) #JAE
    Local Char COMPOS(200)
    If [M:SFTL1]FCY = 'MTB'
      For [YY2] Where [YY2]MFGNUM = [YY0]MFGNUM and [YY2]MFGLIN = [YY0]MFGLIN
        Read [YY3]ITM0 = [YY2]ITMREF
        If fstat = 0
          COMPOS += [YY3]ITMREF + ' ' + [YY3]ITMDES1 + ';'
        Endif
      Next
    Elsif [M:SFTL1]FCY = 'JAE'
      If [F:YY0]PJT <> ''
        [L]COMPOS += [F:YY0]PJT + ' // '
        #Read [YY4]AXX0 = 'PIMPL';'PIMDESAXX';'SPA';left$([F:YY0]PJT,11);''    #Pongo la descripción del proyecto
        Read [YY4]AXX0 = 'PIMPL';'PIMDESAXX';'SPA';[F:YY0]PJT;''               #Pongo la descripción de la tarea del proyecto
        If fstat = 0
          [L]COMPOS += [YY4]TEXTE
        Endif
      Endif
    Endif
    [M:SFTL1]YCOMPO(J) = [L]COMPOS
  Next

  Affzo 15    # Refresh the grid

  # Cierro tablas
  Close Local File [YY0],[YY1],[YY2],[YY3],[YY4] #JAE
Endif
Return


######################################################################################
Subprog AM_MFGNUMF(VALEUR)
Variable Char    VALEUR()
# Primero llamo a la acción STD
Call AM_MFGNUMF(VALEUR) From TRTSFTL

# Solamente si hay líneas cargadas
If [M:SFTL1]NBLIG > 0
  # Abro tablas
  If !clalev([YY0])   : Local File MFGITM    [YY0]   : Endif
  If !clalev([YY1])   : Local File MFGOPE    [YY1]   : Endif
  If !clalev([YY2])   : Local File MFGMAT    [YY2]   : Endif
  If !clalev([YY3])   : Local File ITMMASTER [YY3]   : Endif

  # Para cada línea cargada alimento los campos específicos
  Local Integer J
  For J=0 To [M:SFTL1]NBLIG-1
    For [YY0] Where [YY0]MFGNUM = [M:SFTL1]MFGNUM(J)
      [M:SFTL1]YARTICULO(J) = [YY0]ITMREF
      [M:SFTL1]YCANTIDAD(J) = [YY0]EXTQTY
      Break
    Next
    Read [YY1]MFO0 =  [M:SFTL1]MFGNUM(J);[M:SFTL1]OPENUM(J);0
    If fstat = 0
      [M:SFTL1]YOPERACION(J) = [YY1]ROODES
      [M:SFTL1]YORDEN(J)     = [YY1]YORDEN
    Endif
    # Muestro ahora la relación de compontenes
    Local Char COMPOS(200)
    For [YY2] Where [YY2]MFGNUM = [YY0]MFGNUM and [YY2]MFGLIN = [YY0]MFGLIN
      Read [YY3]ITM0 = [YY2]ITMREF
      If fstat = 0
        COMPOS += [YY3]ITMREF + ' ' + [YY3]ITMDES1 + ';'
      Endif
    Next
    [M:SFTL1]YCOMPO(J) = [L]COMPOS
  Next

  Affzo 15    # Refresh the grid

  # Cierro tablas
  Close Local File [YY0],[YY1],[YY2],[YY3]
Endif

# Si tengo una línea, la marco
If [M:SFTL1]NBLIG = 1
  [M:SFTL1]FLGL(0) = 2
  Affzo [M:SFTL1]FLGL(0)
Endif

# Bloqueo ahora el STD
GPE = 1

End


######################################################################################
Subprog AM_LSD(VALEUR)
Variable Date    VALEUR
