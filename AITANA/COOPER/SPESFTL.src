######################################################################################
Subprog AM_WCRF(VALEUR)
Variable Char    VALEUR()
# Primero WCRF a la acción STD
If VALEUR <> '' and [M:SFTL1]WSTF <> ''
  Gosub CARGO_LINEA_SPE
Else
  Call AM_WCRF(VALEUR) From TRTSFTL
  Gosub CARGO_LINEA_SPE
  # Bloqueo ahora el STD
  GPE = 1
Endif
End


######################################################################################
Subprog B1_WCRF(VALEUR)
Variable Char    VALEUR()
If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
If clalev ([F:MWS])=0 : Local File WORKSTATIO : Endif
If clalev ([F:AXX])=0 : Local File ATEXTRA    : Endif        # 03.09 mm - libellé traduisible
Local Char CODFIC     : CODFIC = "WORKSTATIO"

Link [MWS] With [AXX]AXX0="WORKSTATIO";"WSTDESAXX";'SPA';[F:MWS]WST;[F:MWS]WCRFCY
&            As [LNK]
Default File [LNK]

Choose [LNK]
& Where ([F:MWS]WCRFCY = [M:SFTL1]FCY)
& Order By evalue("WST") Desc Using
& [F:MWS]WCR Titled "Sección",
& [F:MWS]WST Titled "Centro de Trabajo",
& [F:AXX]TEXTE Titled "Descripción"
& Sized(80,240)
& Titled "Sección / Centro de Trabajo"
If !fstat Then
    VALEUR        = [F:MWS]WCR
    [M:SFTL1]WSTF = [F:MWS]WST
    Affzo [M:SFTL1]WSTF
    Call AM_WSTF([M:SFTL1]WSTF)
Else
    Infbox "Ningún registro selecciónado"
Endif
End


######################################################################################
Subprog AM_YCARTICULO(VALEUR)
Variable Char    VALEUR()
#JAE. Busco por artículo
Call POPULATE_WORK_ORDERS ([M:SFTL1]FCY,[M:SFTL1]MFGNUMF,[M:SFTL1]OPENUMF, [M:SFTL1]WCRF,[M:SFTL1]WSTF, [M:SFTL1]LSD,VALEUR,[M:SFTL1]YCPROYECTO)
Gosub CARGO_LINEA_SPE
End


######################################################################################
Subprog C_YCPROYECTO(VALEUR)
Variable Char    VALEUR()
#JAE. Controlo que el proyecto exista y esté lanzado
If VALEUR <> ""
  If !clalev([XX1])     : Local File OPPORPJM    [XX1]   : Endif

  Read [XX1]OPPPJM0 = VALEUR
  If fstat = 0
    If [XX1]OPPSTATE <> 2
      Call ERREUR("El proyecto debe estar en estado 'Lanzado'") From GESECRAN
      mkstat = 2
    Endif
  Else
    Call ERREUR("Proyecto inexistente") From GESECRAN
    mkstat = 2
  Endif

  Close Local File [XX1]
Endif
End


######################################################################################
Subprog AM_YCPROYECTO(VALEUR)
Variable Char    VALEUR()
#JAE. Busco por proyecto
Call POPULATE_WORK_ORDERS ([M:SFTL1]FCY,[M:SFTL1]MFGNUMF,[M:SFTL1]OPENUMF, [M:SFTL1]WCRF,[M:SFTL1]WSTF, [M:SFTL1]LSD,[M:SFTL1]YCARTICULO,VALEUR)
Gosub CARGO_LINEA_SPE
End


######################################################################################
Subprog S_YCPROYECTO(VALEUR)
Variable Char    VALEUR()
#JAE. Selecciono de entre los proyectos PJM que estén lanzados
If !clalev([XX1])     : Local File OPPORPJM    [XX1]   : Endif
If clalev ([F:AXX])=0 : Local File ATEXTRA    : Endif        # 03.09 mm - libellé traduisible
Local Char CODFIC     : CODFIC = "WORKSTATIO"

Link [XX1] With [AXX]AXX0="PIMPL";"PIMDESAX1";'SPA';[F:XX1]OPPNUM;''
&            As [LNK]
Default File [LNK]

Choose [LNK]
& Where ([F:XX1]OPPSTATE = 2)
& Order By evalue("OPPNUM") Desc Using
& [F:XX1]OPPNUM Titled "Proyecto",
& [F:AXX]TEXTE Titled "Descripción"
& Sized(80,240)
& Titled "Proyectos Lanzados"
If !fstat Then
    VALEUR        = [F:XX1]OPPNUM
Else
    Infbox "Ningún registro selecciónado"
Endif

Close Local File [XX1]
End



######################################################################################
## Sub program to populate work orders bases on search fields
######################################################################################
Subprog POPULATE_WORK_ORDERS(STE, WO, OPE, WCG, WC, STARTDATE,YITM,YPJM)

Value Char    STE
Value Char    WO
Value Char    WCG
Value Char    WC
Value Integer OPE
Value Date    STARTDATE
Value Char    YITM
Value Char    YPJM

  Local Char    WCENTERGRP(5), WCENTER(8), LCENTER(8), CRIT(250)
  Local Integer OPERPREC, I, NUMMAC

  Local Integer WMAX
  WMAX = dim([M:SFTL1]MFGNUM)  # Max lines to be displayed

  # TODAN-118504.sn
  Local Integer T_EMPNUM
  T_EMPNUM = [M:SFTL1]EMPNUM
  If func SFTLIB.ISTEAM(EMPNUM) = [V]CST_AYES
    Local Integer EMPLOYEELIST(1..)
    Call TEAM_LIST (EMPNUM, 'A', EMPLOYEELIST) From SFTLIB
    T_EMPNUM = EMPLOYEELIST(1)
  Endif
  # TODAN-118504.en

  # Initialize grid
  Raz [M:SFTL1]NBLIG
  Effzo 15

  # Build the criteria for the search
  CRIT = "[MFO]OPESTA<5 & [MFG]MFGSTA=1 & [MFG]SUSFLG=1"
  If STE <> AVOID.ACHAR
    CRIT += " & [MFO]MFGFCY='"+STE+"'"
  Endif
  If WO <> AVOID.ACHAR
    CRIT += " & [MFO]MFGNUM='"+WO+"'"
  Endif
  If OPE <> AVOID.AINT
    CRIT += " & [MFO]OPENUM="+num$(OPE)
  Endif
  If STARTDATE <> AVOID.ADATE
    CRIT += " & [MFO]OPESTR<=[" + format$(GFMD,STARTDATE) + "]"
  Endif
  If GMTKALLMGT = [V]CST_AYES   # Allocation required
    CRIT += " & find([MFG]ALLSTA,3,5)"
  Endif
  If GDOSFAB = [V]CST_AYES      # Printing required
    CRIT += " & [MFG]MFGTRKFLG >=3"
  Endif

  Link [MFO] With [MFG]MFG0~=[MFO]MFGNUM As [SFTMFO]
& Where evalue(CRIT)
& Order By [MFO]YORDEN Asc           #PATCH
#& Order By Key KEY1=[MFO]MFGNUM;[MFO]OPENUM
  For [SFTMFO]  #KEY1
    #JAE. Si la planta en JAE compruebo criterios de Artículo / Proyecto
    If [M:SFTL1]FCY = 'JAE'
      If !clalev([YY0])   : Local File MFGITM    [YY0]   : Endif
      If !clalev([YY1])   : Local File PIMPL     [YY1]   : Endif

      Filter [YY0] Where [YY0]MFGNUM = [MFO]MFGNUM
      Read [YY0] First
      If fstat = 0
        If YITM <> '' and YITM <> [F:YY0]ITMREF
          Goto NEXT_WO
        Elsif YPJM <> ''
          Read [YY1]PIM0 =  [F:YY0]PJT
          If fstat = 0
            If [F:YY1]OPPNUM <> YPJM
              Goto NEXT_WO
            Endif
          Else
            Goto NEXT_WO
          Endif
        Endif
      Else
        Goto NEXT_WO
      Endif
      Filter [YY0]

      Close Local File [YY0],[YY1]
    Endif
    #JAE Fin

    If I >= WMAX
        Call ERREUR(func AFNC.MES1(mess(37,2422,1),num$(WMAX))) From GESECRAN
        Break
    Endif
    #-----------------------------------------------------------------------------
    # Subcontracting operation is currently not supported in our SFT project
    #-----------------------------------------------------------------------------
    Read [F:MWS]WST0 = [F:MFO]EXTWST;[M:SFTL1]FCY
    If [F:MWS]WSTTYP = 3 : Goto NEXT_WO : Endif

    #-------------------------------------------------------------
    # Check if the operation is completed. If yes, do not display
    #-------------------------------------------------------------
    Filter [F:SFTX] Where [F:SFTX]VCRNUM = [SFTMFO]MFGNUM &
&                         [F:SFTX]OPENUM = [SFTMFO]OPENUM &
&                         [F:SFTX]CLEFLG = [V]CST_AYES
    Look [F:SFTX] First
    Filter [F:SFTX]
    If fstat = 0 : Goto NEXT_WO : Endif   # Found

    #-------------------------------------------------------------
    # Tracking WO based on the CTLOPEPRE parameter
    #-------------------------------------------------------------
    If GCTLOPEPRE > 1
      [L]OPERPREC = 0
      # Find the prior operation number
      Filter [SCH] Where MFGNUM = [SFTMFO]MFGNUM & NEXOPENUM = [SFTMFO]OPENUM
      Read [SCH]SCH0 First
      Filter [SCH]
      If !fstat : [L]OPERPREC = [F:SCH]OPENUM : Endif
      If [L]OPERPREC<>0 & [V]GCTLOPEPRE = 3
        # Check if prior marked complete in MFG Operations table
        Filter [MFOP] Where MFGNUM = [SFTMFO]MFGNUM & OPENUM = [L]OPERPREC
        Read [MFOP]MFO0 First
        Filter [MFOP]
        If !fstat & [F:MFOP]OPESTA < 5
          # This operation is not closed in the MFG tables - see if closed in SFTTXN tables
          Filter [F:SFTX] Where [F:SFTX]VCRNUM = [SFTMFO]MFGNUM &
&                               [F:SFTX]OPENUM = [L]OPERPREC &
&                               [F:SFTX]CLEFLG = [V]CST_AYES
          Read [F:SFTX]SFT0 First
          Filter [F:SFTX]
          If fstat <> 0 : Goto NEXT_WO : Endif
        Endif
      Endif
    Endif

    #-------------------------------------------------------------
    # Don't display the WO that is running (SFTTYP=5)
    #-------------------------------------------------------------
  # TODAN-118504.o
#    Local Integer T_EMPNUM
#    T_EMPNUM = [M:SFTL1]EMPNUM
#    If func SFTLIB.ISTEAM(EMPNUM) = [V]CST_AYES
#      Local Integer EMPLOYEELIST(1..)
#      Call TEAM_LIST (EMPNUM, 'A', EMPLOYEELIST) From SFTLIB
#      T_EMPNUM = EMPLOYEELIST(1)
#    Endif

    Filter [F:SFTX] Where [F:SFTX]EMPNUM = T_EMPNUM &
&                         [F:SFTX]VCRNUM = [SFTMFO]MFGNUM &
&                         [F:SFTX]OPENUM = [SFTMFO]OPENUM &
&                         [F:SFTX]SFTTYP = 5 &
&                         [F:SFTX]UTCENDDATTIM = AVOID.ADATTIM

    Read [F:SFTX]SFT0 First
    Filter [F:SFTX]
    If fstat = 0 : Goto NEXT_WO : Endif

    #-------------------------------------------------------------
    # Check for Work center and Work center group for filter
    # Need to run even if no filter - need the values for display
    #-------------------------------------------------------------
    # Get the Work Centers from MFG table, overwrite from SFTTXN if found
    [L]WCENTER = [SFTMFO]EXTWST
    [L]LCENTER = [SFTMFO]EXTLAB
#PATCH. Quitamos comprobacion del cambio del centro de trabajo OF y colaborador (06/11/2018)
If 1=2
    Call GET_SFT_WC_LC([SFTMFO]MFGNUM, [SFTMFO]OPENUM, [F:MWS]WSTTYP, [SFTMFO]EXTWST,
&                      [SFTMFO]EXTLAB, WCENTER, LCENTER) From SFTLIB
    If WC<>AVOID.ACHAR & WC<>[L]WCENTER
      Goto NEXT_WO
    Endif
Endif
    #---------------------------------------------------------------
    # If someone else has this operation running at same Workstation
    # Default NUMMAC to 1-No
    #---------------------------------------------------------------
    # TODAN-119090.so
    # Now check if this operation already running...
    If [F:MWS]WSTTYP = 1
      If func SFTLIB.OPERATION_RUN([SFTMFO]MFGNUM, [SFTMFO]OPENUM, WCENTER) = [V]CST_ANO
        [L]NUMMAC = [V]CST_AYES
      Else
        If [L]LCENTER = AVOID.ACHAR   # Machine only...set to yes bc it is required.
          [L]NUMMAC = [V]CST_AYES
        Else
          [L]NUMMAC = [V]CST_ANO
        Endif
      Endif
    Endif
    # TODAN-119090.eo
    # Get work center group
    If [F:MWS]WST<>[L]WCENTER | [F:MWS]WCRFCY<>[M:SFTL1]FCY
      Read [F:MWS]WST0=[L]WCENTER;[M:SFTL1]FCY
    Endif
    [L]WCENTERGRP = [F:MWS]WCR

    # If the primary work center is not a machine type, NUMMAC needs to be unchecked, 1-No
    If [F:MWS]WSTTYP <> 1 : [L]NUMMAC = [V]CST_ANO : Endif    # TODAN-119090
#    If [F:MWS]WSTTYP <> 1 : [L]NUMMAC = 0 : Endif

    If WCG<>AVOID.ACHAR & WCG<>[L]WCENTERGRP
      Goto NEXT_WO
    Endif

    [M:SFTL1]FLGL(I)      = 0
    [M:SFTL1]MFGNUM(I)    = [SFTMFO]MFGNUM
    [M:SFTL1]OPENUM(I)    = [SFTMFO]OPENUM
    [M:SFTL1]OPERPREC(I)  = [L]OPERPREC
    [M:SFTL1]OPEUOM(I)    = [SFTMFO]OPEUOM
    [M:SFTL1]NUMMAC(I)    = [L]NUMMAC
    [M:SFTL1]OPESTR(I)    = [SFTMFO]OPESTR
    [M:SFTL1]OPEEND(I)    = [SFTMFO]OPEEND
    [M:SFTL1]OPESTA(I)    = [SFTMFO]OPESTA
    [M:SFTL1]CPLWST(I)    = [L]WCENTER
    [M:SFTL1]CPLLAB(I)    = [L]LCENTER
    [M:SFTL1]LWCG(I)      = [L]WCENTERGRP
    [M:SFTL1]WSTTYP(I)    = [F:MWS]WSTTYP

    #If no notes - clear out the button
    If [F:MFG]MFGTEX="" : [M:SFTL1]WONOTE(I)=AVOID.ACHAR : Endif
    If [F:MFO]MFOTEX="" : [M:SFTL1]OPNOTE(I)=AVOID.ACHAR : Endif
    I += 1

NEXT_WO:

  Next

  [M:SFTL1]NBLIG = I
  Affzo 15    # Refresh the grid
End


######################################################################################
$CARGO_LINEA_SPE
# Solamente si hay líneas cargadas
If [M:SFTL1]NBLIG > 0
  # Abro tablas
  If !clalev([YY0])   : Local File MFGITM    [YY0]   : Endif
  If !clalev([YY1])   : Local File MFGOPE    [YY1]   : Endif
  If !clalev([YY2])   : Local File MFGMAT    [YY2]   : Endif
  If !clalev([YY3])   : Local File ITMMASTER [YY3]   : Endif
  If !clalev([YY4])   : Local File ATEXTRA   [YY4]   : Endif #JAE

  # Para cada línea cargada alimento los campos específicos
  Local Integer J
  For J=0 To [M:SFTL1]NBLIG-1
    For [YY0] Where [YY0]MFGNUM = [M:SFTL1]MFGNUM(J)
      [M:SFTL1]YARTICULO(J) = [YY0]ITMREF
      [M:SFTL1]YCANTIDAD(J) = [YY0]EXTQTY
      Break
    Next
    Read [YY1]MFO0 =  [M:SFTL1]MFGNUM(J);[M:SFTL1]OPENUM(J);0
    If fstat = 0
      [M:SFTL1]YOPERACION(J) = [YY1]ROODES
      [M:SFTL1]YORDEN(J)     = [YY1]YORDEN
    Endif
    # Muestro ahora la relación de compontenes, solamente para MTB; para JAE muestro el proyecto (código y descripción) #JAE
    Local Char COMPOS(200)
    If [M:SFTL1]FCY = 'MTB'
      For [YY2] Where [YY2]MFGNUM = [YY0]MFGNUM and [YY2]MFGLIN = [YY0]MFGLIN
        Read [YY3]ITM0 = [YY2]ITMREF
        If fstat = 0
          COMPOS += [YY3]ITMREF + ' ' + [YY3]ITMDES1 + ';'
        Endif
      Next
    Elsif [M:SFTL1]FCY = 'JAE'
      If [F:YY0]PJT <> ''
        [L]COMPOS += [F:YY0]PJT + ' // '
        #Read [YY4]AXX0 = 'PIMPL';'PIMDESAXX';'SPA';left$([F:YY0]PJT,11);''    #Pongo la descripción del proyecto
        Read [YY4]AXX0 = 'PIMPL';'PIMDESAXX';'SPA';[F:YY0]PJT;''               #Pongo la descripción de la tarea del proyecto
        If fstat = 0
          [L]COMPOS += [YY4]TEXTE
        Endif
      Endif
    Endif
    [M:SFTL1]YCOMPO(J) = [L]COMPOS
  Next

  Affzo 15    # Refresh the grid

  # Cierro tablas
  Close Local File [YY0],[YY1],[YY2],[YY3],[YY4] #JAE
Endif

# Si tengo una línea, la marco
If [M:SFTL1]NBLIG = 1
  [M:SFTL1]FLGL(0) = 2
  Affzo [M:SFTL1]FLGL(0)
Endif
Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla SFTL1) 09/10/2018 15:59:42 (PT02)
######################################################################################
Subprog S_YCARTICULO(VALEUR)
Variable Char    VALEUR()
# Filtro solamente los artículos en función de la planta de la pantalla
Filter [ITM] Where [ITM]TSICOD(0) = [M:SFTL1]FCY
  Call SELECT("ITM", "", VALEUR, "") From SELOBJ
Filter [ITM]
End


