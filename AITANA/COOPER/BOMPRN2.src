#<AdxTL>@(#)7.0.0.0 $Revision$
Subprog IMPRIME(NBPAR,PARAMETRE)
Variable Integer NBPAR
Variable Char    PARAMETRE()(1..)
Local  Integer OK
Local Char ORISCREEN(10), VALEUR(10)

# appelle depuis l'écran des nomenclatures
  If clalev([M:BOH0]) <> 0
    ORISCREEN = "[M:BOH0]"
  Endif
# appelle depuis l'écran des nomenclatures multi niveaux
  If clalev([M:VBOG]) <> 0 Then
    ORISCREEN = "[M:VBOG]"
  Endif
  If clalev([M:BOP0]) = 0
    Local Mask BOP0 [BOP0]
    Raz [M:BOP0]  : [M:BOP0]TRT=1 : # GH 26/02/2014 bug 96937
  Endif
  If clalev([F:BOP])=0 : Local File BOMPRN [BOP] : Endif
  Trbegin [BOP]
  Delete [BOP] Where CREUSR = GUSER & CREDAT < date$
# GH 21/01/2015 bug 105598 personne d'autre que moi a ce adxuid(1) tant que ma session existe, mais ensuite ce no peut être attribué à un autre utilisateur
#  Delete [BOP] Where CREUSR = GUSER & BOPUID = adxuid(1) : # les enreg du User avec son n° process
  Delete [BOP] Where BOPUID = adxuid(1)                   : # les enreg du  n° process
  If fstat = 1 | fstat > 5
    Rollback
    #  "Problème à l'effacement du fichier temporaire"
       Call MESSAGE (mess(155,197,1)) From GESECRAN
    Return
  Else
    Commit
  Endif

  VALEUR = num$(adxuid(1))
  Call SETPARAM("BOPUID",NBPAR,PARAMETRE,VALEUR) From ETAT
  If clalev([M:BOH0]) <> 0 or clalev([M:VBOG]) <> 0
    [M:BOP0]ALTDEB   = evalue(ORISCREEN+"BOMALT")
    [M:BOP0]ALTFIN   = evalue(ORISCREEN+"BOMALT")
    If ORISCREEN = "[M:VBOG]" Then
      [M:BOP0]ITMREFDEB=evalue(ORISCREEN+"PARITMREF")
      [M:BOP0]ITMREFFIN=evalue(ORISCREEN+"PARITMREF")
    Else
      [M:BOP0]ITMREFDEB=evalue(ORISCREEN+"ITMREF")
      [M:BOP0]ITMREFFIN=evalue(ORISCREEN+"ITMREF")
    Endif
    [M:BOP0]ALTTYPDEB=evalue(ORISCREEN+"BOMALTTYP")
    [M:BOP0]ALTTYPFIN=evalue(ORISCREEN+"BOMALTTYP")
    [M:BOP0]DATREF   =evalue(ORISCREEN+"DATREF")
    [M:BOP0]STOFCY   =evalue(ORISCREEN+"STOFCY") : # GH 05/02/2013 bug 85993
  Endif
  Call TEMPON("") From GESECRAN

  ## GH 26/02/2014 bug 96937
  #If ORISCREEN = "[M:BOH0]" Then
  #  Call FILTDERMUL(OK) From BOMPRN
  #Else
  # #  Local File BOMPRN [BOP]
  #  Local Date BOMSTRDAT
  #  Local Mask BOP0   [BOP0]
  #  Call FILTDERMUL(OK) From BOMPRN
  #Endif
  Call FILTDERMUL(OK) From BOMPRN
  ##

  Call TEMPOFF From GESECRAN

End

