#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara YITM9 (Especifico)
$ACTION
Case ACTION
  When "MODIF"    :   Gosub MODIF
  When "CREATION" :   Gosub MODIF
  When "LIENS"    :   Gosub LIENS
Endcase
Return


######################################################################################
$MODIF
# Guardo tabla de atributos
For [YAIT] Where [YAIT]ARTICULO = [M:ITM0]ITMREF
    Delete [YAIT] Curr
Next

For nolign = 1 To [M:YITM9]PIE_9
    Raz [YAIT]
    [YAIT]ARTICULO = [ITM0]ITMREF
    [YAIT]ATRIBUTO = [M:YITM9]ATRIBUTO(nolign-1)
    [YAIT]VALOR    = [M:YITM9]VALOR(nolign-1)
    Write [YAIT]
Next
Return


######################################################################################
$LIENS
# Muestro pestaña de atributos
nolign = 1
[M:YITM9]PIE_9 = 0
Filter [YAIT] Where [YAIT]ARTICULO = [ITM0]ITMREF
    For [YAIT]
        [M:YITM9]ATRIBUTO(nolign-1) = [YAIT]ATRIBUTO
        [M:YITM9]VALOR(nolign-1)    = [YAIT]VALOR
        nolign+=1
        [M:YITM9]PIE_9+=1
    Next
Filter [YAIT]
Return


######################################################################################
Subprog C_ATRIBUTO(VALEUR)
Variable Char    VALEUR()
# No permito duplicar atributos
Call UNICITE(VALEUR,[M:YITM9]ATRIBUTO(0..[M:YITM9]PIE_9-1)) From OBJDIV
End

