Funprog IS_CADGES(PS_ITMREF)
Value Char PS_ITMREF

Local File ITMMASTER
Local Integer IS_CADGES

Read [ITM]ITM0 = PS_ITMREF
If fstat = 0 Then
  If [F:ITM]EXYMGTCOD > 1 Then
    [L]IS_CADGES = 1
  Endif

Endif

End IS_CADGES

