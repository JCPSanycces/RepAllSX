# Gestión de la máscara PJMFOVDE (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla PJMFOVDE) 13/12/2019 07:58:50 (AIT04)
######################################################################################
Subprog AM_YVERDES(VALEUR)
Variable Integer VALEUR
# Si marco este campo muestro las descripciones de los artículos
If VALEUR = 2
  # Para el detalle de gastos, busco las descripciones de los artículos en los pedidos de compra
  If [M:PFODE]NBDET>0
    Local Integer LIN
    If !clalev([PP1]) : Local File PORDERP [PP1] : Endif

    For LIN=0 To [M:PFODE]NBDET-1
     Filter [PP1] Where [PP1]POHNUM = [M:PFODE]PDEORICOD(LIN) and [PP1]ITMREF = [M:PFODE]PDENUM(LIN) and [PP1]GROPRI = [M:PFODE]PDEAMT1D(LIN) and left$([PP1]PJT,len([M:PFOV]OPPNUM)) = [M:PFOV]OPPNUM
     Read [PP1] First
     If fstat = 0
      [M:PFODE]YDESCRIPCION(LIN) = [PP1]ITMDES
      Affzo [M:PFODE]YDESCRIPCION(LIN)
     Endif
     Filter [PP1]
    Next

    Close Local File [PP1]
  Endif
Else
  # Si es que NO, los dejo en blanco
  If [M:PFODE]NBDET>0
    Local Integer LIN
    For LIN=0 To [M:PFODE]NBDET-1
      [M:PFODE]YDESCRIPCION(LIN) = ''
      Affzo [M:PFODE]YDESCRIPCION(LIN)
    Next
  Endif
Endif
End


######################################################################################

