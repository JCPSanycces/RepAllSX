#<AdxTL>@(#)0.0.0.0 $Revision$
#####################################################################################
# Gestión de la máscara POH2 (Especifico)
#-------------------------------------------------------------------------------------
# Src: CNSCPOSPE
#-------------------------------------------------------------------------------------
# Proyecto: Cooper Standard
#-------------------------------------------------------------------------------------
# Version: v11
#-------------------------------------------------------------------------------------
# Fecha: 23/01/2019
#-------------------------------------------------------------------------------------
# Desarrollador: JCH
# Desarrollo:      CSA017
# Codigo Actividad: YCS17
#######################################################################################

######################################################################################
$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif

  Case ACTION
    When "CLECUR"     : Gosub CLECUR
    When Default
  Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
################################################
$CLECUR
Local Integer LCON : Raz LCON

  If !clalev([F:YRPOH0]) : Local File YRECLAMAPOH [F:YRPOH0] : Endif
  If !clalev([F:YPOQ0])  : Local File PORDERQ     [F:YPOQ0]  : Endif
  For LCON = 0 To [M:CPO2]NBLIG-1
    # busca la nueva fecha de recepción que es la que está informada en las líneas del pedido - CSA017 - YCS17
    Filter [F:YPOQ0] Where POHNUM = [M:CPO2]POHNUM(LCON) Order By ORDDAT Desc
    Read [F:YPOQ0] First
    If !fstat Then
      [M:CPO2]YFECHAREC(LCON) = [F:YPOQ0]EXTRCPDAT
    Endif
    # busca de las reclamaciones y las muestra en el grid - CSA017 - YCS17
    Filter [F:YRPOH0] Where POHNUM = [M:CPO2]POHNUM(LCON)
    Read [F:YRPOH0] First
    If !fstat Then
      [M:CPO2]DESCR(LCON)     = [F:YRPOH0]DESCR
      [M:CPO2]RECDAT(LCON)    = [F:YRPOH0]RECDAT
      [M:CPO2]CONFDAT(LCON)   = [F:YRPOH0]CONFDAT
      [M:CPO2]OBSERVA(LCON)   = [F:YRPOH0]OBSERVA
      Read [F:YRPOH0] Next
      If !fstat Then
        [M:CPO2]DESCR2(LCON)    = [F:YRPOH0]DESCR
        [M:CPO2]RECDAT2(LCON)   = [F:YRPOH0]RECDAT
        [M:CPO2]CONFDAT2(LCON)  = [F:YRPOH0]CONFDAT
        [M:CPO2]OBSERVA2(LCON)  = [F:YRPOH0]OBSERVA
        Read [F:YRPOH0] Next
        If !fstat Then
          [M:CPO2]DESCR3(LCON)    = [F:YRPOH0]DESCR
          [M:CPO2]RECDAT3(LCON)   = [F:YRPOH0]RECDAT
          [M:CPO2]CONFDAT3(LCON)  = [F:YRPOH0]CONFDAT
          [M:CPO2]OBSERVA3(LCON)  = [F:YRPOH0]OBSERVA
          Read [F:YRPOH0] Next
          If !fstat Then
            [M:CPO2]DESCR4(LCON)    = [F:YRPOH0]DESCR
            [M:CPO2]RECDAT4(LCON)   = [F:YRPOH0]RECDAT
            [M:CPO2]CONFDAT4(LCON)  = [F:YRPOH0]CONFDAT
            [M:CPO2]OBSERVA4(LCON)  = [F:YRPOH0]OBSERVA
            Read [F:YRPOH0] Next
            If !fstat Then
              [M:CPO2]DESCR5(LCON)    = [F:YRPOH0]DESCR
              [M:CPO2]RECDAT5(LCON)   = [F:YRPOH0]RECDAT
              [M:CPO2]CONFDAT5(LCON)  = [F:YRPOH0]CONFDAT
              [M:CPO2]OBSERVA5(LCON)  = [F:YRPOH0]OBSERVA
              Read [F:YRPOH0] Next
              If !fstat Then
                [M:CPO2]DESCR6(LCON)    = [F:YRPOH0]DESCR
                [M:CPO2]RECDAT6(LCON)   = [F:YRPOH0]RECDAT
                [M:CPO2]CONFDAT6(LCON)  = [F:YRPOH0]CONFDAT
                [M:CPO2]OBSERVA6(LCON)  = [F:YRPOH0]OBSERVA
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Filter [F:YRPOH0]
  Filter [F:YPOQ0]
  Next
  Affzo [M:CPO2]DESCR,RECDAT,CONFDAT,OBSERVA,DESCR2,RECDAT2,CONFDAT2,OBSERVA2,DESCR3,RECDAT3,CONFDAT3,OBSERVA3
  Affzo [M:CPO2]DESCR4,RECDAT4,CONFDAT4,OBSERVA4,DESCR5,RECDAT5,CONFDAT5,OBSERVA5,DESCR6,RECDAT6,CONFDAT6,OBSERVA6,YFECHAREC
  If clalev([F:YRPOH0])  : Close Local File       [F:YRPOH0] : Endif
  If clalev([F:YPOQ0])   : Close Local File       [F:YPOQ0]  : Endif

Return

