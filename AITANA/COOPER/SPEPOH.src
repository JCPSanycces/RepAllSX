######################################################################################
## Etiqueta añadida por el supervisor (pantalla POH2) 28/12/2018 10:28:27 (AIT04)
######################################################################################
$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif

  Case ACTION
    When "MODIF"        : Gosub MODIF
    When "CREATION"     : Gosub CREATION
    When "SETBOUT"      : Gosub SETBOUT
    When "AVANT_CHOI"   : Gosub AVANT_CHOI
    When "APRES_CRE"    : Gosub APRES_CRE
    When "APRES_MOD"    : Gosub APRES_MOD
    When "LIENS_LIG"    : Gosub LIENS_LIG
    When Default
  Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
################################################
$LIENS_LIG
Gosub LIENS_LIG From SUBPOHA

Local Integer J
If [M:POH2]PJT(NOL) <> ""
  For J=1 To len([M:POH2]PJT(NOL))
   If mid$([M:POH2]PJT(NOL),J,1)='!'
    Break
   Endif
  Next

  Local Char PROY : PROY = mid$([M:POH2]PJT(NOL),1,J-1)
  Local Char TARE : TARE = mid$([M:POH2]PJT(NOL),J+1,(len([M:POH2]PJT(NOL))-len(mid$([M:POH2]PJT(NOL),1,J))))

  Read [YCCP]YCCP0 = PROY;TARE
  If fstat = 0
    Read [YCCO]YCC0 = [YCCP]OPPNUM;[YCCP]ROUTEKEY
    If fstat = 0
     [M:POH2]YCONCERTODAT(NOL) = [YCCO]DUEDAT
     Affzo [M:POH2]YCONCERTODAT(NOL)
    Endif
  Endif

Endif

GPE = 1
Return

################################################
$MODIF

  # guarda los datos de las reclamaciones - CSA017 - YCS17
  If GFONCTION = "GESPOH"
    Gosub INSERT_RECLAM
  Endif
  # CSA017 - YCS17
Return

###############################################################
$APRES_CRE
# Actualización 02/10/2019. Gestión con llamada a subprograma
# Cuando creo los pedidos desde fuera de la ventana, cargo campos específicos de línea
If GFONCTION <> "GESPOH"
  Gosub MNG_ZONE_SPE
Endif

# Actualización 02/10/2019. Bloqueo proceso empleado hasta ahora
# Cuando creo los pedidos desde fuera de la ventana, cargo campos específicos de línea
If 1=2
  If GFONCTION <> "GESPOH"
    # Bloqueo el código empleado antes de la actualización del 09/09/2019
    If 1=2
      If !clalev([ZZ0])   : Local File ORDERS    [ZZ0]   : Endif
      If !clalev([ZZ1])   : Local File PORDERQ   [ZZ1]   : Endif
      If !clalev([ZZ2])   : Local File PORDERP   [ZZ2]   : Endif
      If !clalev([ZZ3])   : Local File ATEXTRA   [ZZ3]   : Endif

      For [ZZ1] Where [ZZ1]POHNUM = [F:POH]POHNUM
        Local Char ORIGEN
        Local Char ARTICULO  : ARTICULO = [ZZ1]ITMREF
        Local Char VCRORI
        Local Char ITMEST
        Local Char PJT_ORD

        Read [ZZ2]POP0 = [ZZ1]POHNUM;[ZZ1]POPLIN;[ZZ1]POQSEQ
        If fstat = 0
          PJT_ORD = [ZZ2]PJT

          # Ajusto la descripción del artículo
          Read [ZZ3]AXX0 = 'ITMMASTER';'DES1AXX';'SPA';[ZZ2]ITMREF;''
          If fstat = 0
             [ZZ2]ITMDES  = [ZZ3]TEXTE
             [ZZ2]ITMDES1 = [ZZ3]TEXTE
             Rewrite [ZZ2]
          Endif

        Endif

        Filter [ZZ0] Where [ZZ0]VCRTYP = 14 and [ZZ0]VCRNUM = [F:POH]POHNUM and [ZZ0]VCRLIN = [ZZ1]POPLIN and [ZZ0]ITMREF = [ZZ1]ITMREF and [ZZ0]PJT = PJT_ORD
        Read [ZZ0] First
        If fstat = 0
          ORIGEN   = [F:ZZ0]ITMREFORI
          VCRORI   = [F:ZZ0]VCRNUMORI
        Endif
        Filter [ZZ0]

    #If GUSER = 'AIT04' : Infbox VCRORI : Endif
        If ORIGEN = ""
          Call ARTICULO_ORIGEN([ZZ1]ITMREF,VCRORI,ORIGEN) From YAITLIB
        Endif

        If ORIGEN <> ""
          Call ARTICULO_BOM(ORIGEN,PJT_ORD,ITMEST) From YAITLIB
        Endif

        If VCRORI <> ""
          Local Char VSUBC
          Call ARTICULO_SUB(VCRORI,ITMEST,PJT_ORD,VSUBC) From YAITLIB  # Si vengo de una Orden de subcontratación, busco la OF origen
          If VSUBC <> ""
            VCRORI = VSUBC
            Else
            # Si vengo de una solicitud de compra, busco la OF origen
            Local Char VSC
            Call ARTICULO_SC(VCRORI,ITMEST,PJT_ORD,VSC) From YAITLIB
            If VSC <> ""
              VCRORI = VSC
            Endif
          Endif
        Endif

        Local Char DES_BOM
        Call DESCRIP_BOM(ORIGEN,[ZZ1]ITMREF,DES_BOM) From  YAITLIB

        [ZZ1]YITMORI = ORIGEN
        [ZZ1]YVCRORI = VCRORI
        [ZZ1]YITMEST = ITMEST
        [ZZ1]YDESEST = DES_BOM
        Rewrite [ZZ1]
      Next
      Close Local File [ZZ0],[ZZ1],[ZZ2],[ZZ3]
    Else
      # Activo nuevo código el 09/09/2019
      If !clalev([ZZ0])   : Local File ORDERS    [ZZ0]   : Endif
      If !clalev([ZZ1])   : Local File PORDERQ   [ZZ1]   : Endif
      If !clalev([ZZ2])   : Local File PORDERP   [ZZ2]   : Endif
      If !clalev([ZZ3])   : Local File ATEXTRA   [ZZ3]   : Endif

      For [ZZ1] Where [ZZ1]POHNUM = [F:POH]POHNUM #and [ZZ1]YVCRORI = ""
        Local Char ORIGEN
        Local Char ARTICULO  : ARTICULO = [ZZ1]ITMREF
        Local Char VCRORI
        Local Char ITMEST
        Local Char PJT_ORD

        Read [ZZ2]POP0 = [ZZ1]POHNUM;[ZZ1]POPLIN;[ZZ1]POQSEQ
        If fstat = 0
          PJT_ORD = [ZZ2]PJT

          # Ajusto la descripción del artículo
          Read [ZZ3]AXX0 = 'ITMMASTER';'DES1AXX';'SPA';[ZZ2]ITMREF;''
          If fstat = 0
             [ZZ2]ITMDES  = [ZZ3]TEXTE
             [ZZ2]ITMDES1 = [ZZ3]TEXTE
             Rewrite [ZZ2]
          Endif

        Endif

        Filter [ZZ0] Where [ZZ0]VCRTYP = 14 and [ZZ0]VCRNUM = [F:POH]POHNUM and [ZZ0]VCRLIN = [ZZ1]POPLIN and [ZZ0]ITMREF = [ZZ1]ITMREF and [ZZ0]PJT = PJT_ORD
        Read [ZZ0] First
        If fstat = 0
          ORIGEN   = [F:ZZ0]ITMREFORI
          VCRORI   = [F:ZZ0]VCRNUMORI
        Endif
        Filter [ZZ0]

        # Refuerzo 15/07/19. Si no encuentro asiento origen (POF generado a partir de MWF), busco primero en tabla de asignación de asientos
        If VCRORI = ""
          If clalev([F:YXX1]) = 0 : Local File MTOLINK  [YXX1]  : Endif
          Filter [YXX1] Where [YXX1]STOFCY = [F:POH]POHFCY and [YXX1]ITMREF = [ZZ1]ITMREF and [YXX1]RESSNUM = [F:POH]POHNUM and [YXX1]RESSLIN = [F:ZZ1]POPLIN and [YXX1]RESSSEQ = [F:ZZ1]POQSEQ
          Read [YXX1] First
          If fstat = 0
            VCRORI = [YXX1]DEMNUM
          Endif
          Filter [YXX1]
          Close Local File [YXX1]
        Endif

        # Refuerzo 17/09/19. Si no encuentro asiento origen (POF generado a partir de MWF), busco ahora MWF en ORDERS y que origen sea WOF sin tener en cuenta el artículo origen
        If VCRORI = ""
         Filter [ZZ0] Where [ZZ0]VCRTYP = 10 and [ZZ0]WIPTYP = 6 and [ZZ0]ITMREF = [ZZ1]ITMREF and [ZZ0]PJT = PJT_ORD
         Read [ZZ0] First
         If fstat = 0
           VCRORI   = [F:ZZ0]VCRNUM
         Endif
         Filter [ZZ0]
        Endif

        # Refuerzo 15/07/19. Si no encuentro asiento origen (POF generado a partir de MWF), busco ahora MWF en ORDERS y que origen sean subcontratación
        If VCRORI = ""
         Filter [ZZ0] Where [ZZ0]VCRTYP = 36 and [ZZ0]WIPTYP = 3 and [ZZ0]ITMREF = [ZZ1]ITMREF and [ZZ0]PJT = PJT_ORD
         Read [ZZ0] First
         If fstat = 0
           VCRORI   = [F:ZZ0]VCRNUMORI
         Endif
         Filter [ZZ0]
        Endif

        # Refuerzo 12/08/19. Si no encuentro (componentes multinivel) busco en las OFs a partir del proyecto y de la estructura origen
        If VCRORI = ""
          If clalev([F:YXX2]) = 0 : Local File MFGITM  [YXX2]  : Endif
          Filter [YXX2] Where [YXX2]PJT = PJT_ORD and [YXX2]ITMREF = [ZZ1]YITMEST
          Read [YXX2] First
          If fstat = 0
            VCRORI   = [F:YXX2]MFGNUM
          Endif
          Filter [YXX2]
          Close Local File [YXX2]
        Endif


        #If GUSER = 'AIT04' : Infbox VCRORI : Endif
        If ORIGEN = ""
          Call ARTICULO_ORIGEN([ZZ1]ITMREF,VCRORI,ORIGEN) From YAITLIB
        Endif

        If ORIGEN <> ""
          Call ARTICULO_BOM(ORIGEN,PJT_ORD,ITMEST) From YAITLIB
        Endif

        If VCRORI <> ""
          Local Char VSUBC
          Call ARTICULO_SUB(VCRORI,ITMEST,PJT_ORD,VSUBC) From YAITLIB  # Si vengo de una Orden de subcontratación, busco la OF origen
          If VSUBC <> ""
            # En este caso, recalculo el artículo origen
            Filter [ZZ0] Where [ZZ0]WIPTYP = 3 and [ZZ0]ITMREF = [ZZ1]ITMREF and [ZZ0]PJT = PJT_ORD and [ZZ0]VCRNUM = VCRORI
            Read [ZZ0] Last
            If fstat = 0
              ORIGEN = [ZZ0]ITMREFORI
            Endif
            Filter [ZZ0]

            VCRORI = VSUBC
            Else
            # Si vengo de una solicitud de compra, busco la OF origen
            Local Char VSC
            Call ARTICULO_SC(VCRORI,ITMEST,PJT_ORD,VSC) From YAITLIB
            If VSC <> ""
              VCRORI = VSC
            Endif
          Endif
        Endif

        Local Char DES_BOM
        Call DESCRIP_BOM(ORIGEN,[ZZ1]ITMREF,DES_BOM) From  YAITLIB

        # Control 12/08/2019. Solamente actualizo y tengo alguno de los dos primeros campos en blanco
        If [ZZ1]YITMORI = "" or [ZZ1]YVCRORI = ""
          [ZZ1]YITMORI = ORIGEN
          [ZZ1]YVCRORI = VCRORI
          [ZZ1]YITMEST = ITMEST
          [ZZ1]YDESEST = DES_BOM
          Rewrite [ZZ1]
        Endif
      Next
      Close Local File [ZZ0],[ZZ1],[ZZ2],[ZZ3]

    Endif
  Endif
Endif
Return


###############################################################
$APRES_MOD
# Actualización 02/10/2019. Gestión con llamada a subprograma
# Cuando creo los pedidos desde fuera de la ventana, cargo campos específicos de línea
Gosub MNG_ZONE_SPE

# Actualización 02/10/2019. Bloqueo proceso empleado hasta ahora
# Cuando creo los pedidos desde fuera de la ventana, cargo campos específicos de línea
If 1=2
  If GUSER = 'AIT04' or GUSER = '110'
    If !clalev([ZZ0])   : Local File ORDERS    [ZZ0]   : Endif
    If !clalev([ZZ1])   : Local File PORDERQ   [ZZ1]   : Endif
    If !clalev([ZZ2])   : Local File PORDERP   [ZZ2]   : Endif
    If !clalev([ZZ3])   : Local File ATEXTRA   [ZZ3]   : Endif

    For [ZZ1] Where [ZZ1]POHNUM = [F:POH]POHNUM #and [ZZ1]YVCRORI = ""
      Local Char ORIGEN
      Local Char ARTICULO  : ARTICULO = [ZZ1]ITMREF
      Local Char VCRORI
      Local Char ITMEST
      Local Char PJT_ORD

      Read [ZZ2]POP0 = [ZZ1]POHNUM;[ZZ1]POPLIN;[ZZ1]POQSEQ
      If fstat = 0
        PJT_ORD = [ZZ2]PJT

        # Ajusto la descripción del artículo
        Read [ZZ3]AXX0 = 'ITMMASTER';'DES1AXX';'SPA';[ZZ2]ITMREF;''
        If fstat = 0
           [ZZ2]ITMDES  = [ZZ3]TEXTE
           [ZZ2]ITMDES1 = [ZZ3]TEXTE
           Rewrite [ZZ2]
        Endif

      Endif

      Filter [ZZ0] Where [ZZ0]VCRTYP = 14 and [ZZ0]VCRNUM = [F:POH]POHNUM and [ZZ0]VCRLIN = [ZZ1]POPLIN and [ZZ0]ITMREF = [ZZ1]ITMREF and [ZZ0]PJT = PJT_ORD
      Read [ZZ0] First
      If fstat = 0
        ORIGEN   = [F:ZZ0]ITMREFORI
        VCRORI   = [F:ZZ0]VCRNUMORI
      Endif
      Filter [ZZ0]

      # Refuerzo 15/07/19. Si no encuentro asiento origen (POF generado a partir de MWF), busco primero en tabla de asignación de asientos
      If VCRORI = ""
        If clalev([F:YXX1]) = 0 : Local File MTOLINK  [YXX1]  : Endif
        Filter [YXX1] Where [YXX1]STOFCY = [F:POH]POHFCY and [YXX1]ITMREF = [ZZ1]ITMREF and [YXX1]RESSNUM = [F:POH]POHNUM and [YXX1]RESSLIN = [F:ZZ1]POPLIN and [YXX1]RESSSEQ = [F:ZZ1]POQSEQ
        Read [YXX1] First
        If fstat = 0
          VCRORI = [YXX1]DEMNUM
        Endif
        Filter [YXX1]
        Close Local File [YXX1]
      Endif

      # Refuerzo 15/07/19. Si no encuentro asiento origen (POF generado a partir de MWF), busco ahora MWF en ORDERS y que origen sea WOF
      If VCRORI = ""
       Filter [ZZ0] Where [ZZ0]VCRTYP = 10 and [ZZ0]WIPTYP = 6 and [ZZ0]ITMREF = [ZZ1]ITMREF and [ZZ0]PJT = PJT_ORD
       Read [ZZ0] First
       If fstat = 0
         VCRORI   = [F:ZZ0]VCRNUM
       Endif
       Filter [ZZ0]
      Endif

      # Refuerzo 15/07/19. Si no encuentro asiento origen (POF generado a partir de MWF), busco ahora MWF en ORDERS y que origen sean subcontratación
      If VCRORI = ""
       Filter [ZZ0] Where [ZZ0]VCRTYP = 36 and [ZZ0]WIPTYP = 3 and [ZZ0]ITMREF = [ZZ1]ITMREF and [ZZ0]PJT = PJT_ORD
       Read [ZZ0] First
       If fstat = 0
         VCRORI   = [F:ZZ0]VCRNUMORI
       Endif
       Filter [ZZ0]
      Endif

      # Refuerzo 12/08/19. Si no encuentro (componentes multinivel) busco en las OFs a partir del proyecto y de la estructura origen
      If VCRORI = ""
        If clalev([F:YXX2]) = 0 : Local File MFGITM  [YXX2]  : Endif
        Filter [YXX2] Where [YXX2]PJT = PJT_ORD and [YXX2]ITMREF = [ZZ1]YITMEST
        Read [YXX2] First
        If fstat = 0
          VCRORI   = [F:YXX2]MFGNUM
        Endif
        Filter [YXX2]
        Close Local File [YXX2]
      Endif


  #If GUSER = 'AIT04' : Infbox VCRORI : Endif
      If ORIGEN = ""
        Call ARTICULO_ORIGEN([ZZ1]ITMREF,VCRORI,ORIGEN) From YAITLIB
      Endif

      If ORIGEN <> ""
        Call ARTICULO_BOM(ORIGEN,PJT_ORD,ITMEST) From YAITLIB
      Endif

      If VCRORI <> ""
        Local Char VSUBC
        Call ARTICULO_SUB(VCRORI,ITMEST,PJT_ORD,VSUBC) From YAITLIB  # Si vengo de una Orden de subcontratación, busco la OF origen
        If VSUBC <> ""
          # En este caso, recalculo el artículo origen
          Filter [ZZ0] Where [ZZ0]WIPTYP = 3 and [ZZ0]ITMREF = [ZZ1]ITMREF and [ZZ0]PJT = PJT_ORD and [ZZ0]VCRNUM = VCRORI
          Read [ZZ0] Last
          If fstat = 0
            ORIGEN = [ZZ0]ITMREFORI
          Endif
          Filter [ZZ0]

          VCRORI = VSUBC
          Else
          # Si vengo de una solicitud de compra, busco la OF origen
          Local Char VSC
          Call ARTICULO_SC(VCRORI,ITMEST,PJT_ORD,VSC) From YAITLIB
          If VSC <> ""
            VCRORI = VSC
          Endif
        Endif
      Endif

      Local Char DES_BOM
      Call DESCRIP_BOM(ORIGEN,[ZZ1]ITMREF,DES_BOM) From  YAITLIB

      # Control 12/08/2019. Solamente actualizo y tengo alguno de los dos primeros campos en blanco
      If [ZZ1]YITMORI = "" or [ZZ1]YVCRORI = ""
        [ZZ1]YITMORI = ORIGEN
        [ZZ1]YVCRORI = VCRORI
        [ZZ1]YITMEST = ITMEST
        [ZZ1]YDESEST = DES_BOM
        Rewrite [ZZ1]
      Endif
    Next
    Close Local File [ZZ0],[ZZ1],[ZZ2],[ZZ3]
  Endif
Endif
Return


###############################################################
$MNG_ZONE_SPE
# Activo nuevo código el 09/09/2019
If !clalev([ZZ0])   : Local File ORDERS    [ZZ0]   : Endif
If !clalev([ZZ1])   : Local File PORDERQ   [ZZ1]   : Endif
If !clalev([ZYY1])  : Local File PORDERQ   [ZYY1]  : Endif
If !clalev([ZZ2])   : Local File PORDERP   [ZZ2]   : Endif
If !clalev([ZZ3])   : Local File ATEXTRA   [ZZ3]   : Endif

For [ZZ1] Where [ZZ1]POHNUM = [F:POH]POHNUM #and [ZZ1]YVCRORI = ""
  Local Char ORIGEN
  Local Char ARTICULO  : ARTICULO = [ZZ1]ITMREF
  Local Char VCRORI
  Local Char ITMEST
  Local Char PJT_ORD
  Local Char WIPNUM_SPE

  Read [ZZ2]POP0 = [ZZ1]POHNUM;[ZZ1]POPLIN;[ZZ1]POQSEQ
  If fstat = 0
    PJT_ORD = [ZZ2]PJT

    # Ajusto la descripción del artículo solamente en la creación
    If ACTION = "APRES_CRE"
      Read [ZZ3]AXX0 = 'ITMMASTER';'DES1AXX';'SPA';[ZZ2]ITMREF;''
      If fstat = 0
         [ZZ2]ITMDES  = [ZZ3]TEXTE
         [ZZ2]ITMDES1 = [ZZ3]TEXTE
         Rewrite [ZZ2]
      Endif
    Endif

  Endif

  # 01/09/21 Primero busco por el WIPNUM
  Read [ZZ0]ORD0 = 6;WIPNUM_SPE;[ZZ2]ITMREF
  If fstat = 0
    ORIGEN   = [F:ZZ0]ITMREFORI
    VCRORI   = [F:ZZ0]VCRNUM  # 01/09/21
#    If GUSER = 'AIT07' : Infbox ("PRIMERA " + " -  " + ORIGEN + " - " + VCRORI) : Endif
  Endif
  # 01/09/21 Fin

#  Filter [ZZ0] Where [ZZ0]VCRTYP = 14 and [ZZ0]VCRNUM = [F:POH]POHNUM and [ZZ0]VCRLIN = [ZZ1]POPLIN and [ZZ0]ITMREF = [ZZ1]ITMREF and [ZZ0]PJT = PJT_ORD
#  Read [ZZ0] First
#  If fstat = 0
#    ORIGEN   = [F:ZZ0]ITMREFORI
#    VCRORI   = [F:ZZ0]VCRNUMORI
#  Endif
#  Filter [ZZ0]
  If VCRORI = "" # 01/09/21
    Filter [ZZ0] Where [ZZ0]VCRTYP = 14 and [ZZ0]VCRNUM = [F:POH]POHNUM #and [ZZ0]VCRLIN = [ZZ1]POPLIN and [ZZ0]ITMREF = [ZZ1]ITMREF and [ZZ0]PJT = PJT_ORD
    Read [ZZ0] First
    If fstat = 0
      ORIGEN   = [F:ZZ0]ITMREFORI
#      VCRORI   = [F:ZZ0]VCRNUM      #JC.10032021.CSA028
      VCRORI   = [F:ZZ0]VCRNUMORI   #JC.10032021.CSA028
#      If GUSER = 'AIT07' : Infbox ("SEGUNDA " + " -  " + ORIGEN + " - "+ VCRORI) : Endif
    Endif
    Filter [ZZ0]
  Endif # 01/09/21

  # Refuerzo 17/09/19. Si no encuentro asiento origen (POF generado a partir de MWF), busco ahora MWF en ORDERS y que origen sea WOF sin tener en cuenta el artículo origen
  If VCRORI = ""
   For [ZZ0] Where [ZZ0]VCRTYP = 10 and [ZZ0]WIPTYP = 6 and [ZZ0]ITMREF = [ZZ1]ITMREF and [ZZ0]PJT = PJT_ORD and [ZZ0]RMNEXTQTY = [ZZ1]QTYUOM
    Local Integer ENCUENTRO
    For [ZYY1] Where [ZYY1]POHNUM = [ZZ1]POHNUM and [ZYY1]YWIPNUM = [ZZ0]WIPNUM
      ENCUENTRO = 2
      Break
    Next
    If ENCUENTRO <> 2
       VCRORI     = [F:ZZ0]VCRNUM
       ORIGEN     = [F:ZZ0]ITMREFORI
       WIPNUM_SPE = [F:ZZ0]WIPNUM
    Endif
   Next
  Endif

  # Refuerzo 15/07/19. Si no encuentro asiento origen (POF generado a partir de MWF), busco ahora MWF en ORDERS y que origen sean subcontratación
  If VCRORI = ""
   Filter [ZZ0] Where [ZZ0]VCRTYP = 36 and [ZZ0]WIPTYP = 3 and [ZZ0]ITMREF = [ZZ1]ITMREF and [ZZ0]PJT = PJT_ORD
   Read [ZZ0] First
   If fstat = 0
     VCRORI   = [F:ZZ0]VCRNUMORI
   Endif
   Filter [ZZ0]
  Endif

  # Refuerzo 12/08/19. Si no encuentro (componentes multinivel) busco en las OFs a partir del proyecto y de la estructura origen
  If VCRORI = ""
    If clalev([F:YXX2]) = 0 : Local File MFGITM  [YXX2]  : Endif
    Filter [YXX2] Where [YXX2]PJT = PJT_ORD and [YXX2]ITMREF = [ZZ1]YITMEST
    Read [YXX2] First
    If fstat = 0
      VCRORI   = [F:YXX2]MFGNUM
    Endif
    Filter [YXX2]
    Close Local File [YXX2]
  Endif


  #If GUSER = 'AIT04' : Infbox VCRORI : Endif
  If ORIGEN = ""
    Call ARTICULO_ORIGEN([ZZ1]ITMREF,VCRORI,ORIGEN) From YAITLIB
  Endif

#  If ORIGEN <> ""
#    Call ARTICULO_BOM(ORIGEN,PJT_ORD,ITMEST) From YAITLIB
#  Endif
  If ORIGEN <> ""
    If GFONCTION <> "GESSCO" Then     #JC.10032021.CSA028
      Call ARTICULO_BOM(ORIGEN,PJT_ORD,ITMEST) From YAITLIB
    Else                              #JC.10032021.CSA028
      ITMEST = ORIGEN                 #JC.10032021.CSA028
    Endif                             #JC.10032021.CSA028
  Endif


  If VCRORI <> ""
    Local Char VSUBC
    Call ARTICULO_SUB(VCRORI,ITMEST,PJT_ORD,VSUBC) From YAITLIB  # Si vengo de una Orden de subcontratación, busco la OF origen
    If VSUBC <> ""
      # En este caso, recalculo el artículo origen
      Filter [ZZ0] Where [ZZ0]WIPTYP = 3 and [ZZ0]ITMREF = [ZZ1]ITMREF and [ZZ0]PJT = PJT_ORD and [ZZ0]VCRNUM = VCRORI
      Read [ZZ0] Last
      If fstat = 0
        ORIGEN = [ZZ0]ITMREFORI
      Endif
      Filter [ZZ0]

      VCRORI = VSUBC
      Else
      # Si vengo de una solicitud de compra, busco la OF origen
      Local Char VSC
      Call ARTICULO_SC(VCRORI,ITMEST,PJT_ORD,VSC) From YAITLIB
      If VSC <> ""
        VCRORI = VSC
      Endif
    Endif
  Endif

  Local Char DES_BOM
  Call DESCRIP_BOM(ORIGEN,[ZZ1]ITMREF,DES_BOM) From  YAITLIB

  # Control 12/08/2019. Solamente actualizo y tengo alguno de los dos primeros campos en blanco
  If [ZZ1]YITMORI = "" or [ZZ1]YVCRORI = ""
    [ZZ1]YITMORI = ORIGEN
    [ZZ1]YVCRORI = VCRORI
    [ZZ1]YITMEST = ITMEST
    If [ZZ1]YDESEST = ""
      [ZZ1]YDESEST = DES_BOM
    Endif
    [ZZ1]YWIPNUM = WIPNUM_SPE
    Rewrite [ZZ1]
  Elsif [ZZ1]YITMEST = ""
    [ZZ1]YITMEST = ITMEST
    Rewrite [ZZ1]
  Endif
Next
Close Local File [ZZ0],[ZZ1],[ZZ2],[ZZ3],[ZYY1]

Return


################################################
$CREATION

  # guarda los datos de las reclamaciones - CSA017 - YCS17
  If GFONCTION = "GESPOH"
    Gosub INSERT_RECLAM
  Endif
  # CSA017 - YCS17

Return

################################################
$SETBOUT

#  # si el campo ya tiene informada una fecha, no permito modificarla (desactivando el campo) - CSA017 - YCS17
#  If GFONCTION = "GESPOH"
#    If [M:YRPOH]YINIRECDAT <> "000000" Then
#      Diszo [M:YRPOH]YINIRECDAT
#    Else
#      Actzo [M:YRPOH]YINIRECDAT
#    Endif
#    Affzo [M:YRPOH]YINIRECDAT
#  Endif
#  # CSA017 - YCS17

Return

################################################
$AVANT_CHOI

  # muestra los datos de las reclamaciones en la pestaña - CSA017 - YCS17
  If GFONCTION = "GESPOH"
    Gosub SHOW_RECLAM
  Endif
  # CSA017 - YCS17

Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
################################################
# actualiza los datos de las reclamaciones sobre la tabla - CSA017 - YCS17
$INSERT_RECLAM
Local Integer LCON0 : Raz LCON0

  If !clalev([F:YRPOH0]) Then : Local File YRECLAMAPOH [F:YRPOH0] : Endif
  For LCON0 = 0 To [M:YRPOH]NBREC-1
    Read [F:YRPOH0]YRPOH0 = LCON0;[M:POH0]POHNUM
    If !fstat Then
      [F:YRPOH0]DESCR   = [M:YRPOH]DESCR(LCON0)
      [F:YRPOH0]RECDAT  = [M:YRPOH]RECDAT(LCON0)
      [F:YRPOH0]CONFDAT = [M:YRPOH]CONFDAT(LCON0)
      [F:YRPOH0]OBSERVA = [M:YRPOH]OBSERVA(LCON0)
      Rewrite [F:YRPOH0]
    Else
      [F:YRPOH0]IDLIN   = LCON0
      [F:YRPOH0]POHNUM  = [M:POH0]POHNUM
      [F:YRPOH0]DESCR   = [M:YRPOH]DESCR(LCON0)
      [F:YRPOH0]RECDAT  = [M:YRPOH]RECDAT(LCON0)
      [F:YRPOH0]CONFDAT = [M:YRPOH]CONFDAT(LCON0)
      [F:YRPOH0]OBSERVA = [M:YRPOH]OBSERVA(LCON0)
      Write [F:YRPOH0]
    Endif
  Next
  If clalev([F:YRPOH0])  Then : Close Local File       [F:YRPOH0] : Endif
# CSA017 - YCS17

Return

################################################
# muestra los datos de las reclamaciones sobre la tabla - CSA017 - YCS17
$SHOW_RECLAM
Local Integer LCON1 : Raz LCON1

  If !clalev([F:YRPOH1]) Then : Local File YRECLAMAPOH [F:YRPOH1] : Endif
  Filter [F:YRPOH1] Where POHNUM = [M:POH0]POHNUM Order By IDLIN Asc
  For [YRPOH1]
    [M:YRPOH]DESCR(LCON1)   = [F:YRPOH1]DESCR
    [M:YRPOH]RECDAT(LCON1)  = [F:YRPOH1]RECDAT
    [M:YRPOH]CONFDAT(LCON1) = [F:YRPOH1]CONFDAT
    [M:YRPOH]OBSERVA(LCON1) = [F:YRPOH1]OBSERVA
    LCON1 += 1
  Next
  [M:YRPOH]NBREC = LCON1
  Affzo [M:YRPOH]DESCR,RECDAT,CONFDAT,OBSERVA
  Filter [F:YRPOH1]
  If clalev([F:YRPOH1])  Then : Close Local File       [F:YRPOH1] : Endif
# CSA017 - YCS17

Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
Subprog AM_YFECHAREC(VALEUR)
Variable Date    VALEUR
# Confirmo modificación fecha recepción de todas las líneas, actualizo y lanzo acciones de campo
If VALEUR <> "000000"
  Local Integer OK9
  Call OUINON("¿Desea modificar la fecha de recepción de todas las líneas del pedido?",OK9) From GESECRAN
  If OK9 = 2
    Local Integer LIN
    For LIN=0 To [M:POH2]NBLIG-1
      [M:POH2]EXTRCPDAT(LIN) = VALEUR
      nolign = LIN + 1
      Call AM_EXTRCPDAT(VALEUR) From SUBPOH
      Affzo [M:POH2]EXTRCPDAT(LIN)
    Next
  Endif
Endif
End



######################################################################################
Subprog AS_YFECHAREC(VALEUR)
Variable Date    VALEUR
# No permito la entrada si no hay líneas
If [M:POH2]NBLIG = 0
  mkstat = 2
Endif
End



######################################################################################
Subprog C_YVCRORI(VALEUR)
Variable Char    VALEUR()
If VALEUR <> ""
  # 1 - Existencia del a OF
  If !clalev([XX0])   : Local File MFGHEAD    [XX0]   : Endif
  If !clalev([XX1])   : Local File MFGITM     [XX1]   : Endif

  Read [XX0]MFG0 = VALEUR
  If fstat <> 0
    Call ERREUR ('Orden de fabricación inexistente') From GESECRAN
    mkstat = 2
  Else
    # 2 - Planta de la OF tiene que ser la misma que la planta del pedido
    If [XX0]MFGFCY <> [M:POH0]POHFCY
      Call ERREUR ('La planta de la OF tiene que ser la misma que la planta del pedido') From GESECRAN
      mkstat = 2
    Else
      # 3 - La OF tiene que estar asociada al proyecto de la línea del pedido de compra
      If [M:POH2]PJT(nolign-1) <>""
        Read [XX1]MFI2 = VALEUR
        If fstat = 0
          If [XX1]PJT <> [M:POH2]PJT(nolign-1)
            Call ERREUR ('La OF no está asociada al mismo proyecto que la línea del pedido de compra') From GESECRAN
            mkstat = 2
          Endif
        Endif
      Endif
    Endif
  Endif
  Close Local File [XX0],[XX1]
Endif
End


######################################################################################
Subprog S_YVCRORI(VALEUR)
Variable Char    VALEUR()
# Filtro OF's de la planta y que estén asociados al proyecto (si el campo tiene valor)
If !clalev([XX0])   : Local File MFGHEAD    [XX0]   : Endif
If !clalev([XX1])   : Local File MFGITM     [XX1]   : Endif

Local Char CRITERIO(250)
CRITERIO +="[XX0]MFGFCY = [M:POH0]POHFCY"

If [M:POH2]PJT(nolign-1) <>""
  CRITERIO +=" & [XX1]PJT = [M:POH2]PJT(nolign-1)"
Endif

Link [F:XX0] With [F:XX1]MFI2 = [F:XX0]MFGNUM As [XX00]

Filter [XX00] Where evalue(CRITERIO)
  Choose [XX00]
& Where 1=1
& Using
& [F:XX0]MFGNUM Titled 'OF',
& [F:XX1]ITMREF Titled 'Artículo',
& [F:XX1]PJT Titled 'Proyecto'
& Sized(80,240)
& Titled "Selección de órdenes de fabricación"

  If status = 28 Then
      VALEUR = [F:XX0]MFGNUM
  Endif

Filter [XX00]

Close Local File [XX0],[XX1]
End

######################################################################################
## Elimina una línea del grid de reclamaciones
######################################################################################
# controla el borrado de de las líneas de reclamación - CSA017 - YCS17
Subprog B10_NBREC
Local Integer LCON3, TREG : Raz LCON3, TREG

  If !clalev([F:YRPOH2]) Then : Local File YRECLAMAPOH [F:YRPOH2] : Endif

  # elimina la línea de reclamación solicitada - CSA017 - YCS17
  Trbegin [F:YRPOH2]
  Readlock [F:YRPOH2]YRPOH0 = (nolign-1);[M:POH0]POHNUM
  If !fstat Then
    Delete [F:YRPOH2]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif

  # renumera el campo IDLIN de la tabla de reclamaciones (para que la carga de las líneas se haga correctamente) - CSA017 - YCS17
  Filter [F:YRPOH2] Where POHNUM = [M:POH0]POHNUM Order By IDLIN Asc
  TREG = rowcount([YRPOH2])
  Read [F:YRPOH2] First
  If !fstat Then
    For LCON3 = 0 To TREG-1
      Trbegin [F:YRPOH2]
      [F:YRPOH2]IDLIN = LCON3
      Rewrite [F:YRPOH2]
      If !fstat Then
        Commit
        Read [F:YRPOH2] Next
      Else
        Rollback
      Endif
    Next
  Endif

  If clalev([F:YRPOH2])  Then : Close Local File       [F:YRPOH2] : Endif

  Effzo [M:YRPOH]10
  Gosub SHOW_RECLAM
# CSA017 - YCS17

End

######################################################################################
## Después de modificar el campo "Fecha confirmación"
######################################################################################
# cuando se modifica el campo "Fecha confirmación" de cualquier línea de reclamación, se ejecuta el proceso de actualización en
# las líneas del pedido (proceso que ya estaba implementado en este específico) - CSA017 - YCS17
Subprog AM_CONFDAT(VALEUR)
Variable Date    VALEUR

  [M:POH2]YFECHAREC = VALEUR      # se informa la fecha en el campo situado en la pestaña de Líneas
  Affzo [M:POH2]YFECHAREC         # se actualiza el campo
  Call AM_YFECHAREC(VALEUR)       # se llama al proceso de actualización de las líneas del pedido (proceso implementado con anterioridad)
# CSA017 - YCS17

End

######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla POH2) 15/02/2019 11:42:41 (AIT04)
######################################################################################
Subprog AM_YVCRORI(VALEUR)
Variable Char    VALEUR()
# Confirmo el artículo origen, atacando directamente a las OF's
If !clalev([ZZ2])   : Local File MFGITM  [ZZ2]   : Endif

Filter [ZZ2] Where [ZZ2]MFGNUM = VALEUR and [ZZ2]PJT = [M:POH2]PJT(nolign-1)
Read [ZZ2] First
If fstat = 0
  [M:POH2]YITMORI(nolign-1) = [ZZ2]ITMREF
  Affzo [M:POH2]YITMORI(nolign-1)
Endif
Filter [ZZ2]

Close Local File [ZZ2]
End


