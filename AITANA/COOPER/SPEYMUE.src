#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "DEBUT"   :   Gosub DEBUT
  When "BOUTON"  :   Gosub BOUTON
Endcase
Return


#####################################
$DEBUT
# Limpio pantalla
Effzo [M:YMUE]
[M:YMUE]PIE_MUE = 0

# Muestro registros asociados a la OF seleccionada
If !clalev([YY0])   : Local File MFGMATTRK [YY0]   : Endif
If !clalev([YY1])   : Local File STOJOU    [YY1]   : Endif
If !clalev([YY2])   : Local File STOJOU    [YY2]   : Endif
If !clalev([YY3])   : Local File MFGITMTRK [YY3]   : Endif
If !clalev([YY4])   : Local File STOJOU    [YY4]   : Endif
If !clalev([YY5])   : Local File STOJOU    [YY5]   : Endif

# Si vengo del Seguimiento taller...
If GFONCTION = 'FUNSFTPOR'
  Local Integer J
  nolign = 1
  For J=0 To [M:SFTP0]NBLIG-1
    If [M:SFTP0]SELLIN(J) = 2 and [M:SFTP0]SFTTYP(J) > 3
      Filter [YY0] Where [YY0]MFGNUM = [M:SFTP0]VCRNUM(J) Order By [YY0]MFGTRKNUM Desc
        For [YY0]
          Filter [YY1] Where [YY1]VCRNUMORI = [YY0]MFGNUM and  [YY1]VCRLINORI = [YY0]MFGLIN and [YY1]TRSTYP = 5 and [YY1]LOT = [YY0]YLOTE and [YY1]SLO = [YY0]YSUBLOTE
          Read [YY1] First
          If fstat = 0
            [M:YMUE]SEL(nolign-1) = 2
            [M:YMUE]OF(nolign-1)         = [YY0]MFGNUM
            [M:YMUE]SEGUMIENTO(nolign-1) = [YY1]VCRNUM
            [M:YMUE]COMPUESTO(nolign-1)  = [YY1]ITMREF
            [M:YMUE]LOTEPF(nolign-1)     = [YY1]LOT
            [M:YMUE]SLOTEPF(nolign-1)    = [YY1]SLO
            For [YY4] Where [YY4]VCRNUMORI = [YY0]MFGNUM and  [YY4]VCRLINORI = [YY0]MFGLIN and [YY4]TRSTYP = 5 and [YY4]LOT = [YY0]YLOTE and [YY4]SLO = [YY0]YSUBLOTE
              [M:YMUE]CANTIDADPF(nolign-1) += [YY4]QTYPCU
            Next
            [M:YMUE]UNIDADPF(nolign-1)   = [YY1]PCU
            [M:YMUE]NROLLOSPF(nolign-1)  = val([YY1]PALNUM) # Nº de rollos
            [M:YMUE]NSOLDAPF(nolign-1)   = val([YY1]CTRNUM) # Nº de soldaduras
            [M:YMUE]NROLLOSPF(nolign-1)  = val([YY1]PALNUM)
            Read [YY3]MKI0 = [YY1]VCRNUM;[YY1]VCRLIN
            If fstat = 0
              [M:YMUE]CANTIDADEPF(nolign-1)   = [YY3]YQTYSSU
              [M:YMUE]YPESOBRUTO(nolign-1)    = [YY3]YPESOBRUTO
              [M:YMUE]UNIDADEPD(nolign-1)     = [YY3]YSSU
            Endif
            Filter [YY2] Where [YY2]VCRNUM = [YY0]MFGTRKNUM and  [YY2]VCRLIN = [YY0]MATTRKLIN and [YY2]TRSTYP = 6 and [YY2]ITMREF = [YY0]ITMREF
            Read [YY2] First
            If fstat = 0
              [M:YMUE]COMPONENTE(nolign-1)  = [YY0]ITMREF
              [M:YMUE]LOTECOM(nolign-1)     = [YY2]LOT
              [M:YMUE]SLOTECOM(nolign-1)    = [YY2]SLO
              #[M:YMUE]CANTIDADCOM(nolign-1) = [YY2]QTYSTU
              [M:YMUE]UNIDADCOM(nolign-1)   = [YY2]STU
              [M:YMUE]NROLLOSCOM(nolign-1)  = [YY0]YROLLOS # Nº de rollos
              [M:YMUE]YPOSICION(nolign-1)   = [YY0]YPOSICION
              # Saco la cantidad consumida para este lote en concreto, por si hay varias imputaciones de consumos
              Filter [YY5] Where [YY5]VCRNUM = [YY0]MFGTRKNUM and  [YY5]VCRLIN = [YY0]MATTRKLIN and [YY5]TRSTYP = 6 and [YY5]ITMREF = [YY0]ITMREF Order By [YY5]MVTSEQ Asc
                For [YY5]#and [YY5]LOT = [YY2]LOT and [YY5]SLO = [YY2]SLO
                  [M:YMUE]CANTIDADCOM(nolign-1)+= [YY5]QTYSTU
                  If [YY5]LOT <> [M:YMUE]LOTECOM(nolign-1) : [M:YMUE]LOTECOM(nolign-1) = [YY5]LOT : Endif # Actualizo último lote de componente consumido
                Next
              Filter [YY5]
            Endif
            Filter [YY2]
            nolign +=1
          Endif
          Filter [YY1]
        Next
      Filter [YY0]
      [M:YMUE]PIE_MUE = nolign-1
      Affzo [M:YMUE]
      # Salgo del bucle
      Break
    Endif
  Next
# Si vengo de la OF...
Elsif GFONCTION = 'GESMFG'
  Local Integer ENTRO
  nolign = 1
  Filter [YY0] Where [YY0]MFGNUM = [M:MFG0]MFGNUM Order By [YY0]MFGTRKNUM Desc
    For [YY0]
      Filter [YY1] Where [YY1]VCRNUMORI = [YY0]MFGNUM and  [YY1]VCRLINORI = [YY0]MFGLIN and [YY1]TRSTYP = 5 and [YY1]LOT = [YY0]YLOTE and [YY1]SLO = [YY0]YSUBLOTE
      Read [YY1] First
      If fstat = 0
        [L]ENTRO +=1
        [M:YMUE]SEL(nolign-1) = 2
        [M:YMUE]OF(nolign-1)         = [YY0]MFGNUM
        [M:YMUE]SEGUMIENTO(nolign-1) = [YY1]VCRNUM
        [M:YMUE]COMPUESTO(nolign-1)  = [YY1]ITMREF
        [M:YMUE]LOTEPF(nolign-1)     = [YY1]LOT
        [M:YMUE]SLOTEPF(nolign-1)    = [YY1]SLO
        For [YY4] Where [YY4]VCRNUMORI = [YY0]MFGNUM and  [YY4]VCRLINORI = [YY0]MFGLIN and [YY4]TRSTYP = 5 and [YY4]LOT = [YY0]YLOTE and [YY4]SLO = [YY0]YSUBLOTE
          [M:YMUE]CANTIDADPF(nolign-1) += [YY4]QTYPCU
        Next
        [M:YMUE]UNIDADPF(nolign-1)   = [YY1]PCU
        [M:YMUE]NROLLOSPF(nolign-1)  = val([YY1]PALNUM)  # Nº de rollos
        [M:YMUE]NSOLDAPF(nolign-1)   = val([YY1]CTRNUM)  # Nº de soldaduras
        Read [YY3]MKI0 = [YY1]VCRNUM;[YY1]VCRLIN
        If fstat = 0
          [M:YMUE]CANTIDADEPF(nolign-1)   = [YY3]YQTYSSU
          [M:YMUE]YPESOBRUTO(nolign-1)    = [YY3]YPESOBRUTO
          [M:YMUE]UNIDADEPD(nolign-1)     = [YY3]YSSU
        Endif
        Filter [YY2] Where [YY2]VCRNUM = [YY0]MFGTRKNUM and  [YY2]VCRLIN = [YY0]MATTRKLIN and [YY2]TRSTYP = 6 and [YY2]ITMREF = [YY0]ITMREF
        Read [YY2] First
        If fstat = 0
          [M:YMUE]COMPONENTE(nolign-1)  = [YY0]ITMREF
          [M:YMUE]LOTECOM(nolign-1)     = [YY2]LOT
          [M:YMUE]SLOTECOM(nolign-1)    = [YY2]SLO
          [M:YMUE]UNIDADCOM(nolign-1)   = [YY2]STU
          [M:YMUE]NROLLOSCOM(nolign-1)  = [YY0]YROLLOS
          [M:YMUE]YPOSICION(nolign-1)   = [YY0]YPOSICION
          # Saco la cantidad consumida para este lote en concreto, por si hay varias imputaciones de consumos
          Filter [YY5] Where [YY5]VCRNUM = [YY0]MFGTRKNUM and  [YY5]VCRLIN = [YY0]MATTRKLIN and [YY5]TRSTYP = 6 and [YY5]ITMREF = [YY0]ITMREF Order By [YY5]MVTSEQ Asc
            For [YY5]#and [YY5]LOT = [YY2]LOT and [YY5]SLO = [YY2]SLO
              [M:YMUE]CANTIDADCOM(nolign-1)+= [YY5]QTYSTU
              If [YY5]LOT <> [M:YMUE]LOTECOM(nolign-1) : [M:YMUE]LOTECOM(nolign-1) = [YY5]LOT : Endif # Actualizo último lote de componente consumido
            Next
          Filter [YY5]
        Endif
        Filter [YY2]
        nolign +=1
      Endif
      Filter [YY1]
    Next
  Filter [YY0]
  # Para el caso que no hayan consumos
  If [L]ENTRO = 0
    Filter [YY1] Where [YY1]VCRNUMORI = [M:MFG0]MFGNUM and [YY1]TRSTYP = 5
    Read [YY1] First
    If fstat = 0
      [L]ENTRO +=1
      [M:YMUE]SEL(nolign-1) = 2
      [M:YMUE]SEGUMIENTO(nolign-1) = [YY1]VCRNUM
      [M:YMUE]COMPUESTO(nolign-1)  = [YY1]ITMREF
      [M:YMUE]LOTEPF(nolign-1)     = [YY1]LOT
      [M:YMUE]SLOTEPF(nolign-1)    = [YY1]SLO
      For [YY4] Where [YY4]VCRNUMORI = [M:MFG0]MFGNUM and [YY4]TRSTYP = 5
        [M:YMUE]CANTIDADPF(nolign-1) += [YY1]QTYPCU
      Next
      [M:YMUE]UNIDADPF(nolign-1)   = [YY1]PCU
      [M:YMUE]NROLLOSPF(nolign-1)  = val([YY1]PALNUM) # Nº de rollos
      [M:YMUE]NSOLDAPF(nolign-1)   = val([YY1]CTRNUM) # Nº de soldaduras
      Read [YY3]MKI0 = [YY1]VCRNUM;[YY1]VCRLINORI
      If fstat = 0
        [M:YMUE]CANTIDADEPF(nolign-1)   = [YY3]YQTYSSU
        [M:YMUE]UNIDADEPD(nolign-1)     = [YY3]YSSU
      Endif
      nolign +=1
    Endif
    Filter [YY1]
  Endif

  # Ahora saco las altas que no tengan ningún consumo asociado (lotes de PT que no estén asociados en los seguimientos de materiales)
  For [YY1] Where [YY1]VCRNUMORI = [M:MFG0]MFGNUM and [YY1]TRSTYP = 5
    Filter [YY0] Where [YY0]MFGNUM = [M:MFG0]MFGNUM and [YY0]YLOTE = [YY1]LOT
    Read [YY0] First
    If fstat <> 0
      [M:YMUE]SEL(nolign-1) = 1
      [M:YMUE]OF(nolign-1)         = [YY0]MFGNUM
      [M:YMUE]SEGUMIENTO(nolign-1) = [YY1]VCRNUM
      [M:YMUE]COMPUESTO(nolign-1)  = [YY1]ITMREF
      [M:YMUE]LOTEPF(nolign-1)     = [YY1]LOT
      [M:YMUE]SLOTEPF(nolign-1)    = [YY1]SLO
      [M:YMUE]CANTIDADPF(nolign-1) = [YY1]QTYPCU
      [M:YMUE]UNIDADPF(nolign-1)   = [YY1]PCU
      [M:YMUE]NROLLOSPF(nolign-1)  = val([YY1]PALNUM) # Nº de rollos
      [M:YMUE]NSOLDAPF(nolign-1)   = val([YY1]CTRNUM) # Nº de soldaduras
      Read [YY3]MKI0 = [YY1]VCRNUM;[YY1]VCRLIN
      If fstat = 0
        [M:YMUE]CANTIDADEPF(nolign-1)   = [YY3]YQTYSSU
        [M:YMUE]YPESOBRUTO(nolign-1)    = [YY3]YPESOBRUTO
        [M:YMUE]UNIDADEPD(nolign-1)     = [YY3]YSSU
      Endif
      nolign +=1
    Endif
    Filter [YY0]
  Next

  [M:YMUE]PIE_MUE = nolign-1
  Affzo [M:YMUE]
Endif

Close Local File [YY0],[YY1],[YY2],[YY3],[YY4],[YY5]
Return


#####################################
$BOUTON
If BOUT = 'Z'
  # Etiqueta e impresora asociada por defecto al usuario. Pongo primero valores por defecto
  If !clalev([XX1])   : Local File APRTAUS      [XX1]   : Endif

  Local Char ETIQUETA  : ETIQUETA  = "Y-ETMTMUP"
  Local Char IMPRESORA : IMPRESORA = "VISTA"

  Filter [XX1] Where [XX1]USR = GUSER and [XX1]RPTCOD = [L]ETIQUETA
  Read [XX1] First
  If fstat = 0
    [L]IMPRESORA = [XX1]PRT
  Endif
  Filter [XX1]

  Close Local File [XX1]

  # Parámetros del informe
  Local Integer I
  For I=0 To [M:YMUE]PIE_MUE-1
    If [M:YMUE]SEL(I) = 2
      Local Char TBPAR(12)(5),TBVAL(30)(5)
      TBPAR(0) = "SEGUIMIENTO"
      TBVAL(0) = [M:YMUE]SEGUMIENTO(I)

      TBPAR(1) = "LOTE"
      TBVAL(1) = [M:YMUE]LOTECOM(I)

      TBPAR(2) = "SUBLOTE"
      TBVAL(2) = [M:YMUE]SLOTECOM(I)

      TBPAR(3) = "CPTE"
      TBVAL(3) = [M:YMUE]COMPONENTE(I)

      TBPAR(4) = "LOTEC"
      TBVAL(4) = [M:YMUE]LOTECOM(I)

      Call ETAT(ETIQUETA,IMPRESORA,GLANGUE,0,"",TBPAR,TBVAL) From AIMP3
    Endif
  Next

  FIN = 1

Elsif BOUT = 'Y'    # Impresión etiqueta de producción
  # Etiqueta e impresora asociada por defecto al usuario. Pongo primero valores por defecto
  If !clalev([XX0])   : Local File ITMMASTER    [XX0]   : Endif
  If !clalev([XX1])   : Local File APRTAUS      [XX1]   : Endif

  Local Char ETIQUETA  : ETIQUETA  = "Y-ETMTPROD"
  Local Char IMPRESORA : IMPRESORA = "VISTA"

  Filter [XX1] Where [XX1]USR = GUSER and [XX1]RPTCOD = [L]ETIQUETA
  Read [XX1] First
  If fstat = 0
    [L]IMPRESORA = [XX1]PRT
  Endif
  Filter [XX1]

  Close Local File [XX0],[XX1]

  # Parámetros del informe
  Local Integer I
  For I=0 To [M:YMUE]PIE_MUE-1
    If [M:YMUE]SEL(I) = 2
      Local Char TBPAR(12)(3),TBVAL(30)(3)
      TBPAR(0) = "SEGUIMIENTO"
      TBVAL(0) = [M:YMUE]SEGUMIENTO(I)
      Call ETAT(ETIQUETA,IMPRESORA,GLANGUE,0,"",TBPAR,TBVAL) From AIMP3
    Endif
  Next

  FIN = 1

Elsif BOUT = 'X'    # Búsqueda de registros
  # Limpio pantalla
  Effzo [M:YMUE]10
  [M:YMUE]PIE_MUE = 0

  # Muestro registros asociados a la OF seleccionada
  If !clalev([YY0])   : Local File MFGMATTRK [YY0]   : Endif
  If !clalev([YY1])   : Local File STOJOU    [YY1]   : Endif
  If !clalev([YY2])   : Local File STOJOU    [YY2]   : Endif
  If !clalev([YY3])   : Local File MFGITMTRK [YY3]   : Endif
  If !clalev([YY4])   : Local File STOJOU    [YY4]   : Endif
  If !clalev([YY5])   : Local File MFGHEAD   [YY5]   : Endif
  If !clalev([YY6])   : Local File STOJOU    [YY6]   : Endif

  # Compongo criterios de búsqueda
  Local Char CRITERIO_MFG(250) : [L]CRITERIO_MFG = "1=1"
  Local Char CRITERIO_MFI(250) : [L]CRITERIO_MFI = "1=1"

  If [M:YMUE]FECHAINI >= gdat$(01,01,2001) : [L]CRITERIO_MFG += " & [YY5]STRDAT >= [M:YMUE]FECHAINI" : Endif
  If [M:YMUE]FECHAFIN >= gdat$(01,01,2001) : [L]CRITERIO_MFG += " & [YY5]STRDAT <= [M:YMUE]FECHAFIN" : Endif
  If [M:YMUE]OFINI <> ""                   : [L]CRITERIO_MFG += " & [YY5]MFGNUM >= [M:YMUE]OFINI"    : Endif
  If [M:YMUE]OFFIN <> ""                   : [L]CRITERIO_MFG += " & [YY5]MFGNUM <= [M:YMUE]OFFIN"    : Endif
  If [M:YMUE]ITMINI <> ""                  : [L]CRITERIO_MFI += " & [YY1]ITMREF >= [M:YMUE]ITMINI"    : Endif
  If [M:YMUE]ITMFIN <> ""                  : [L]CRITERIO_MFI += " & [YY1]ITMREF <= [M:YMUE]ITMFIN"    : Endif

  Local Integer ENTRO
  nolign = 1
  Filter [YY5] Where evalue([L]CRITERIO_MFG) Order By [YY5]MFGNUM Asc
    For [YY5]
      Filter [YY0] Where [YY0]MFGNUM = [YY5]MFGNUM Order By [YY0]MFGTRKNUM Desc
        For [YY0]
          Filter [YY1] Where [YY1]VCRNUMORI = [YY0]MFGNUM and  [YY1]VCRLINORI = [YY0]MFGLIN and [YY1]TRSTYP = 5 and [YY1]LOT = [YY0]YLOTE and [YY1]SLO = [YY0]YSUBLOTE and evalue([L]CRITERIO_MFI)
          Read [YY1] First
          If fstat = 0
            [L]ENTRO +=1
            [M:YMUE]SEL(nolign-1) = 2
            [M:YMUE]OF(nolign-1)         = [YY0]MFGNUM
            [M:YMUE]SEGUMIENTO(nolign-1) = [YY1]VCRNUM
            [M:YMUE]COMPUESTO(nolign-1)  = [YY1]ITMREF
            [M:YMUE]LOTEPF(nolign-1)     = [YY1]LOT
            [M:YMUE]SLOTEPF(nolign-1)    = [YY1]SLO
            For [YY4] Where [YY4]VCRNUMORI = [YY0]MFGNUM and  [YY4]VCRLINORI = [YY0]MFGLIN and [YY4]TRSTYP = 5 and [YY4]LOT = [YY0]YLOTE and [YY4]SLO = [YY0]YSUBLOTE
              [M:YMUE]CANTIDADPF(nolign-1) += [YY4]QTYPCU
            Next
            [M:YMUE]UNIDADPF(nolign-1)   = [YY1]PCU
            [M:YMUE]NROLLOSPF(nolign-1)  = val([YY1]PALNUM)  # Nº de rollos
            [M:YMUE]NSOLDAPF(nolign-1)   = val([YY1]CTRNUM)  # Nº de soldaduras
            Read [YY3]MKI0 = [YY1]VCRNUM;[YY1]VCRLIN
            If fstat = 0
              [M:YMUE]CANTIDADEPF(nolign-1)   = [YY3]YQTYSSU
              [M:YMUE]YPESOBRUTO(nolign-1)    = [YY3]YPESOBRUTO
              [M:YMUE]UNIDADEPD(nolign-1)     = [YY3]YSSU
            Endif
            Filter [YY2] Where [YY2]VCRNUM = [YY0]MFGTRKNUM and  [YY2]VCRLIN = [YY0]MATTRKLIN and [YY2]TRSTYP = 6 and [YY2]ITMREF = [YY0]ITMREF
            Read [YY2] First
            If fstat = 0
              [M:YMUE]COMPONENTE(nolign-1)  = [YY0]ITMREF
              [M:YMUE]LOTECOM(nolign-1)     = [YY2]LOT
              [M:YMUE]SLOTECOM(nolign-1)    = [YY2]SLO
              #[M:YMUE]CANTIDADCOM(nolign-1) = [YY2]QTYSTU
              [M:YMUE]UNIDADCOM(nolign-1)   = [YY2]STU
              [M:YMUE]NROLLOSCOM(nolign-1)  = val([YY2]PALNUM)
              [M:YMUE]YPOSICION(nolign-1)   = [YY0]YPOSICION
              # Saco la cantidad consumida para este lote en concreto, por si hay varias imputaciones de consumos
              Filter [YY6] Where [YY6]VCRNUM = [YY0]MFGTRKNUM and  [YY6]VCRLIN = [YY0]MATTRKLIN and [YY6]TRSTYP = 6 and [YY6]ITMREF = [YY0]ITMREF Order By [YY6]MVTSEQ Asc
                For [YY6]#and [YY5]LOT = [YY2]LOT and [YY5]SLO = [YY2]SLO
                  [M:YMUE]CANTIDADCOM(nolign-1)+= [YY6]QTYSTU
                  If [YY6]LOT <> [M:YMUE]LOTECOM(nolign-1) : [M:YMUE]LOTECOM(nolign-1) = [YY6]LOT : Endif # Actualizo último lote de componente consumido
                Next
              Filter [YY6]
            Endif
            Filter [YY2]
            nolign +=1
          Endif
          Filter [YY1]
        Next
      Filter [YY0]

      # Para el caso que no hayan consumos
      If [L]ENTRO = 0
        Filter [YY1] Where [YY1]VCRNUMORI = [YY5]MFGNUM and [YY1]TRSTYP = 5 and evalue([L]CRITERIO_MFI)
        Read [YY1] First
        If fstat = 0
          [L]ENTRO +=1
          [M:YMUE]SEL(nolign-1) = 2
          [M:YMUE]SEGUMIENTO(nolign-1) = [YY1]VCRNUM
          [M:YMUE]COMPUESTO(nolign-1)  = [YY1]ITMREF
          [M:YMUE]LOTEPF(nolign-1)     = [YY1]LOT
          [M:YMUE]SLOTEPF(nolign-1)    = [YY1]SLO
          For [YY4] Where [YY4]VCRNUMORI = [YY5]MFGNUM and [YY4]TRSTYP = 5
            [M:YMUE]CANTIDADPF(nolign-1) += [YY1]QTYPCU
          Next
          [M:YMUE]UNIDADPF(nolign-1)   = [YY1]PCU
          [M:YMUE]NROLLOSPF(nolign-1)  = val([YY1]PALNUM)  # Nº de rollos
          [M:YMUE]NSOLDAPF(nolign-1)   = val([YY1]CTRNUM)  # Nº de soldaduras
          Read [YY3]MKI0 = [YY1]VCRNUM;[YY1]VCRLINORI
          If fstat = 0
            [M:YMUE]CANTIDADEPF(nolign-1)   = [YY3]YQTYSSU
            [M:YMUE]UNIDADEPD(nolign-1)     = [YY3]YSSU
          Endif
          nolign +=1
        Endif
        Filter [YY1]
      Endif

      # Ahora saco las altas que no tengan ningún consumo asociado (lotes de PT que no estén asociados en los seguimientos de materiales)
      Filter [YY1] Where [YY1]VCRNUMORI = [YY5]MFGNUM and [YY1]TRSTYP = 5 and evalue([L]CRITERIO_MFI)
        For [YY1]
          Filter [YY0] Where [YY0]MFGNUM = [YY1]VCRNUMORI and [YY0]YLOTE = [YY1]LOT
          Read [YY0] First
          If fstat <> 0
            [M:YMUE]SEL(nolign-1) = 1
            [M:YMUE]OF(nolign-1)         = [YY0]MFGNUM
            [M:YMUE]SEGUMIENTO(nolign-1) = [YY1]VCRNUM
            [M:YMUE]COMPUESTO(nolign-1)  = [YY1]ITMREF
            [M:YMUE]LOTEPF(nolign-1)     = [YY1]LOT
            [M:YMUE]SLOTEPF(nolign-1)    = [YY1]SLO
            [M:YMUE]CANTIDADPF(nolign-1) = [YY1]QTYPCU
            [M:YMUE]UNIDADPF(nolign-1)   = [YY1]PCU
            [M:YMUE]NROLLOSPF(nolign-1)  = val([YY1]PALNUM) # Nº de rollos
            [M:YMUE]NSOLDAPF(nolign-1)   = val([YY1]CTRNUM) # Nº de soldaduras
            Read [YY3]MKI0 = [YY1]VCRNUM;[YY1]VCRLIN
            If fstat = 0
              [M:YMUE]CANTIDADEPF(nolign-1)   = [YY3]YQTYSSU
              [M:YMUE]YPESOBRUTO(nolign-1)    = [YY3]YPESOBRUTO
              [M:YMUE]UNIDADEPD(nolign-1)     = [YY3]YSSU
            Endif
            nolign +=1
          Endif
          Filter [YY0]
        Next
      Filter [YY1]

    Next
  Filter [YY5]

  [M:YMUE]PIE_MUE = nolign-1
  Affzo [M:YMUE]
  Close Local File [YY0],[YY1],[YY2],[YY3],[YY4],[YY5],[YY6]
Endif
Return

