#<AdxTL>@(#)11.0.0.0 $Revision$
Local Char FILGAUSUP(240)
Local Integer I : Raz I
FILGAUSUP(0) ='find([F:STA]VCRTYP,10,36)'
FILGAUSUP(0)+='&[F:STA]STOFCY="INO"'
FILGAUSUP(0)+='&[F:STA]BPRNUM="001"'
FILGAUSUP(0)+='&[F:STA]BPAADD="001"'
FILGAUSUP(0)+='&find([F:STA]LOC,"")'
FILGAUSUP(0)+='&[F:STA]SCOFLG=2'
FILGAUSUP(0)+='&[F:STA]ALLTYP=4'
Local File STOALL [STA]
Filter [STA] Where evalue(FILGAUSUP)
For [STA]
   I+=1
Next
Filter [STA]
#Infbox "I = "+num$(I)-[F:STA]LOC
End

#########################################################################
# Gestion des livraisons                                        SUBSDHC #
#-----------------------------------------------------------------------#
# Novembre 2000                                                      TS #
#########################################################################

#########################################################################
# TRAITEMENTS LIES AU PICKING DES COMMANDES                             #
#########################################################################

#########################################################################
# Actions de l'objet                                                    #
#########################################################################
# Issue 122277 - 20170419 by LD : Ship line complete in a non allocated context KO
# Issue X3-38309 - 20171229 by LD : PE picking subcontract shortage
# Issue X3-138971 - 20190703 by LD : Picking pick ticket in sales delivery

#########################################################################
$HINT_KEY

#Case currbox
# When GBOXSTO : HINTLIS(val(right$(GBOXSO1,8)))="STO"
# When Default : Return
#Endcase

#VPO 14/05/09 55116 perf picking commande GBOXSO1
#VPO 11/12/09 60816 perf picking cde ouverte GBOXSO2
Case currbox
 When GBOXSO1 : HINTLIS(val(right$(GBOXSO1,8)))="SOP2"
 When GBOXSO2 : HINTLIS(val(right$(GBOXSO2,8)))="SOQ4"
 When Default : Return
Endcase
Return

#########################################################################
$TIROIR

ILIS=val(right$(currbox,8))
Gosub REMP_LISGAU From GOBJSUB
WPICK=2
Gosub RAFFRAICHI

Return

#########################################################################
$REMP_DERLU

# Pas de dernier lu
If GFONC1 <> "GESSDH"
   adxmxl=0
Endif
Return

#########################################################################
# 87484
$CLE_GAUCHE

Case currbox
 When GBOXSC1 :
    # Sélection manquant sous-traitant
    # 87484 : Ajout ITMREF à la clé STA1 pour éviter les homonymes (picking impossible)
    # Cas d'un fantôme ds la nomenc. de prod : Les composants de ce fantôme se retrouve avec le même n°SEQ ds l'OF
    CLELISTE="VCRTYP;VCRNUM;VCRLIN;VCRSEQ;STOCOU;ITMREF"
 When Default : Return
Endcase

Return
# 87484

#########################################################################
$FILGAUCHE

Local Date WSHIDAT

# Pas de liste gauche
If GFONC1 <> "GESSDH"
   If ILIS=0 adxmxl=0 Endif
Endif

Case currbox
 When GBOXSO1 : Gosub FILGAUCHE1
 When GBOXSO2 : Gosub FILGAUCHE2
 When GBOXRE1 : Gosub FILGAUCHE3
 When GBOXSC1 : Gosub FILGAUCHE4
 When GBOXPH1 : Gosub FILGAUCHE5    #MAE BP_LIV
 When GBOXPJ5 : Gosub FILGAUCHE6    # X3-1152 : Non invoiceable deliveries
 When Default : Return
Endcase

Return

#########################################################################
$FILGAUCHE1

# Si pas de clé courante (sauf si création) ou liv validée,
# rien dans la liste de picking
If (GREP="" & !CLECUR) | [M]CFMFLG=2
   FILGAUSUP(0) = '[F:SOP]SOQSTA=99'
   Return
Endif

#  Si livraison sous-traitance, rien dans la liste de picking
If dim([M:SDH0]SCO) > 0
   If [M]SCO=2
      FILGAUSUP(0) = '[F:SOP]SOQSTA=99'
      Return
   Endif
Endif

# If the delivery category is Nonbillable, the left lists are not populated
# X3-99883 (lcc - 19/07/18)
If [M:SDH0]SDHCAT=4
   FILGAUSUP(0)+='[F:SOP]SOQSTA=99'
   Return
Endif
# End X3-99883 (lcc - 19/07/18)

FILGAUSUP(0) = '[F:SOP]SOQSTA=1'

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="LND"
##   If val(CZ)=2
##      FILGAUSUP(0)+='&[F:SOP]SOHCAT=2'
##   Else
##      FILGAUSUP(0)+='&[F:SOP]SOHCAT=1'
##   Endif
##Else
##   If [M]LND=2
##      FILGAUSUP(0)+='&[F:SOP]SOHCAT=2'
##   Else
##      FILGAUSUP(0)+='&[F:SOP]SOHCAT=1'
##   Endif
##Endif
If [M]LND=2
  FILGAUSUP(0)+='&[F:SOP]SOHCAT=2'
Else
  FILGAUSUP(0)+='&[F:SOP]SOHCAT=1'
Endif

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="STOFCY"
##   If CZ<>""        FILGAUSUP(0)+='&[F:SOP]STOFCY=CZ'        Endif
##Else
##   If [M]STOFCY<>"" FILGAUSUP(0)+='&[F:SOP]STOFCY=[M]STOFCY' Endif
##Endif
If [M]STOFCY<>"" FILGAUSUP(0)+='&[F:SOP]STOFCY=[M]STOFCY' Endif

If find(REPONSE,GSTARAF,GSTATIR,GSTAPRG,GSTASVG)
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="BPCORD"
   ##   If CZ<>""        FILGAUSUP(0)+='&[F:SOP]BPCORD=CZ'        Endif
   ##Else
   ##   If [M]BPCORD<>"" FILGAUSUP(0)+='&[F:SOP]BPCORD=[M]BPCORD' Endif
   ##Endif
   If [M]BPCORD<>"" FILGAUSUP(0)+='&[F:SOP]BPCORD=[M]BPCORD' Endif
Else
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="BPCORD"
   ##   FILGAUSUP(0)+='&[F:SOP]BPCORD=CZ'
   ##Else
   ##   FILGAUSUP(0)+='&[F:SOP]BPCORD=[M]BPCORD'
   ##Endif
   FILGAUSUP(0)+='&[F:SOP]BPCORD=[M]BPCORD'
Endif
# Pb : Bien que COUZON="BPAADD" CZ contient toujours la valeur du dernier champs saisi
#      BPAADD est chargé directement à partir du client, s'il n'est pas modifié CZ=[M:SRL1]BPCORD
#      CZ n'est bon que si on saisit BPAADD
#If COUZON="BPAADD"
#   If CZ<>""        FILGAUSUP(0)+='&[F:SOP]BPAADD=CZ'        Endif
#Else
#   If [M]BPAADD<>"" FILGAUSUP(0)+='&[F:SOP]BPAADD=[M]BPAADD' Endif
#Endif
# Particularité pour [M]BPAADD : On le charge dans l'action APRES_MODIF
If [M]BPAADD <> ""  FILGAUSUP(0)+='&[F:SOP]BPAADD=[M]BPAADD'    Endif

If [M]NBLIG <> 0
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="BPCINV"
   ##   If CZ<>""        FILGAUSUP(0)+='&[F:SOH]BPCINV=CZ'        Endif
   ##Else
   ##   If [M]BPCINV<>"" FILGAUSUP(0)+='&[F:SOH]BPCINV=[M]BPCINV' Endif
   ##Endif
   If [M]BPCINV<>"" FILGAUSUP(0)+='&[F:SOH]BPCINV=[M]BPCINV' Endif
Endif

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="SALFCY"
##   If CZ<>""        FILGAUSUP(0)+='&[F:SOH]SALFCY=CZ'        Endif
##Else
##   If [M]SALFCY<>"" FILGAUSUP(0)+='&[F:SOH]SALFCY=[M]SALFCY' Endif
##Endif

If [M]NBLIG > 0 | ([M]NBLIG = 0 & [M]PJT <> "")
   #--CPO 71065 Code affaire
   If GPJTSNGDOC = G_OUI Then
     FILGAUSUP(1)+='&[F:SOQ]PJT=[M]PJT'
   Endif
   #--/CPO
Endif

# LTA.sn  79065
# If func AFNC.ACTIV("LTA") & GLOCUSATAX & [M]NBLIG > 0   # 106867.o
If func TRTTAXSST.CHK_SSTTAXACT([F:SOH]CPY) & [M]NBLIG > 0   # 106867.n
  FILGAUSUP(0)+='&[F:SOH]SSTENTCOD=[M]SSTENTCOD'
Endif
# LTA.en  79065

If [M]SALFCY<>"" FILGAUSUP(0)+='&[F:SOH]SALFCY=[M]SALFCY' Endif

If [M]NBLIG <> 0
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="CUR"
   ##   If CZ<>""     FILGAUSUP(0)+='&[F:SOH]CUR=CZ'           Endif
   ##Else
   ##   If [M]CUR<>"" FILGAUSUP(0)+='&[F:SOH]CUR=[M]CUR'       Endif
   ##Endif
   If [M]CUR<>"" FILGAUSUP(0)+='&[F:SOH]CUR=[M]CUR'       Endif

   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="PTE"
   ##   If CZ<>""     FILGAUSUP(0)+='&[F:SOH]PTE=CZ'           Endif
   ##Else
   ##   If [M]PTE<>"" FILGAUSUP(0)+='&[F:SOH]PTE=[M]PTE'       Endif
   ##Endif
   If [M]PTE<>"" FILGAUSUP(0)+='&[F:SOH]PTE=[M]PTE'       Endif
Endif

# Les lignes ne doivent pas être soldées et doivent être fermes
FILGAUSUP(1)  = '&[F:SOQ]DEMSTA=1'
#--- Issue 112531 by TS
FILGAUSUP(1) += '&[F:SOQ]DLVFLG=2'
#---
# Date expédition cdes doit être < date d'expédition liv + nbre jours paramétrés
FILGAUSUP(1) += '&[F:SOQ]SHIDAT<=[M]SHIDAT+GSHINBRDAY'
# les commandes ne doivent être ni soldées, ni livrées
FILGAUSUP(1) += '&[F:SOH]ORDSTA<>2&[F:SOH]DLVSTA<>3'
#  Les Lignes ne doivent pas être des composants de kit
#FILGAUSUP(1) += '&([F:SOP]LINTYP<3|[F:SOP]LINTYP>5)'
FILGAUSUP(1) += '& !find([F:SOP]LINTYP,3,4,5,11,12,13)'
# La commande doit être signée
FILGAUSUP(1) += '& [F:SOH]APPFLG > 2'
# order holds
FILGAUSUP(1) += '& [F:SOH]HLDSTA < 2'

#  Les Lignes ne doivent pas être des lignes de contrats de service
FILGAUSUP(1) += '&[F:SOP]CONNUM=""'

If [M]NBLIG <> 0
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="PRITYP"
   ##   If CZ<>""        FILGAUSUP(1)+='&[F:SOH]PRITYP=CZ'        Endif
   ##Else
   ##   If [M]PRITYP<>0  FILGAUSUP(1)+='&[F:SOH]PRITYP=[M]PRITYP' Endif
   ##Endif
   If [M]PRITYP<>0  FILGAUSUP(2)+='&[F:SOH]PRITYP=[M]PRITYP' Endif

   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="VACBPR"
   ##   If CZ<>""        FILGAUSUP(1)+='&[F:SOH]VACBPR=CZ'        Endif
   ##Else
   ##   If [M]VACBPR<>"" FILGAUSUP(1)+='&[F:SOH]VACBPR=[M]VACBPR' Endif
   ##Endif
   If [M]VACBPR<>"" FILGAUSUP(2)+='&[F:SOH]VACBPR=[M]VACBPR' Endif

Endif

#--CPO 75115 Nouveau champ SDHTYP
#--On filtre sur les cdes ayant le même type de livraison ou ""
FILGAUSUP(2) += '& find([F:SOH]SDHTYP,"",[M]SDHTYP)>0'
#--/CPO

GBIDC3="" : Call FILROLE("SOH",GBIDC3) From SUBARL
If GBIDC3<>"" FILGAUSUP(3)= "& " + GBIDC3 : Endif

Return

#########################################################################
$FILGAUCHE2
# Si pas de clé courante (sauf si création) ou liv validée,
# rien dans la liste de picking
If (GREP="" & !CLECUR) | [M]CFMFLG=2
   FILGAUSUP(0) = '[F:SOQ]SOQSTA=99'
   Return
Endif

# If the delivery category is Nonbillable, the left lists are not populated
# X3-99883 (lcc - 19/07/18)
If [M:SDH0]SDHCAT=4
   FILGAUSUP(0)+='[F:SOQ]SOQSTA=99'
   Return
Endif
# End X3-99883 (lcc - 19/07/18)

# Si livraison de prêt, rien dans la liste de picking
##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="LND"
##   If val(CZ)=2
##      FILGAUSUP(0) ='[F:SOQ]SOQSTA=99'
##      Return
##   Endif
##Else
##   If [M]LND=2
##      FILGAUSUP(0) ='[F:SOQ]SOQSTA=99'
##      Return
##   Endif
##Endif
If [M]LND=2
  FILGAUSUP(0) ='[F:SOQ]SOQSTA=99'
  Return
Endif

#  Si livraison sous-traitance, rien dans la liste de picking
If dim([M:SDH0]SCO) > 0
   If [M]SCO=2
      FILGAUSUP(0) = '[F:SOQ]SOQSTA=99'
      Return
   Endif
Endif

FILGAUSUP(0) = '[F:SOQ]SOQSTA<3'
FILGAUSUP(0)+='&[F:SOQ]SOHCAT=4'

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="STOFCY"
##   If CZ<>""        FILGAUSUP(0)+='&[F:SOQ]STOFCY=CZ'        Endif
##Else
##   If [M]STOFCY<>"" FILGAUSUP(0)+='&[F:SOQ]STOFCY=[M]STOFCY' Endif
##Endif

If [M]NBLIG > 0 | ([M]NBLIG = 0 & [M]PJT <> "")
  # FGR 19/12/2011 : X3SUIVI71065 (début)
  If GPJTSNGDOC = G_OUI Then
     FILGAUSUP(0) += '&[F:SOQ]PJT=[M:SDH2]PJT'
  Endif
  # FGR 19/12/2011 : X3SUIVI71065 (fin)
Endif

If [M]STOFCY<>"" FILGAUSUP(0)+='&[F:SOQ]STOFCY=[M]STOFCY' Endif

If find(REPONSE,GSTARAF,GSTATIR,GSTAPRG,GSTASVG)
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="BPCORD"
   ##   If CZ<>""        FILGAUSUP(0)+='&[F:SOQ]BPCORD=CZ'        Endif
   ##Else
   ##   If [M]BPCORD<>"" FILGAUSUP(0)+='&[F:SOQ]BPCORD=[M]BPCORD' Endif
   ##Endif
   If [M]BPCORD<>"" FILGAUSUP(0)+='&[F:SOQ]BPCORD=[M]BPCORD' Endif
Else
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="BPCORD"
   ##   FILGAUSUP(0)+='&[F:SOQ]BPCORD=CZ'
   ##Else
   ##   FILGAUSUP(0)+='&[F:SOQ]BPCORD=[M]BPCORD'
   ##Endif
   FILGAUSUP(0)+='&[F:SOQ]BPCORD=[M]BPCORD'
Endif

# Pb : Bien que COUZON="BPAADD" CZ contient toujours la valeur du dernier champs saisi
#      BPAADD est chargé directement à partir du client, s'il n'est pas modifié CZ=[M:SRL1]BPCORD
#      CZ n'est bon que si on saisit BPAADD
#If COUZON="BPAADD"
#   If CZ<>""        FILGAUSUP(0)+='&[F:SOQ]BPAADD=CZ'        Endif
#Else
#   If [M]BPAADD<>"" FILGAUSUP(0)+='&[F:SOQ]BPAADD=[M]BPAADD' Endif
#Endif
# Particularité pour [M]BPAADD : On le charge dans l'action APRES_MODIF
If [M]BPAADD <> ""  FILGAUSUP(0)+='&[F:SOQ]BPAADD=[M]BPAADD'    Endif

If [M]NBLIG <> 0
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="BPCINV"
   ##   If CZ<>""        FILGAUSUP(0)+='&[F:SOH]BPCINV=CZ'        Endif
   ##Else
   ##   If [M]BPCINV<>"" FILGAUSUP(0)+='&[F:SOH]BPCINV=[M]BPCINV' Endif
   ##Endif
   If [M]BPCINV<>"" FILGAUSUP(0)+='&[F:SOH]BPCINV=[M]BPCINV' Endif
Endif

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="SALFCY"
##   If CZ<>""        FILGAUSUP(0)+='&[F:SOH]SALFCY=CZ'        Endif
##Else
##   If [M]SALFCY<>"" FILGAUSUP(0)+='&[F:SOH]SALFCY=[M]SALFCY' Endif
##Endif
If [M]SALFCY<>"" FILGAUSUP(0)+='&[F:SOH]SALFCY=[M]SALFCY' Endif

If [M]NBLIG <> 0
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="CUR"
   ##   If CZ<>""     FILGAUSUP(0)+='&[F:SOH]CUR=CZ'           Endif
   ##Else
   ##   If [M]CUR<>"" FILGAUSUP(0)+='&[F:SOH]CUR=[M]CUR'       Endif
   ##Endif
   If [M]CUR<>"" FILGAUSUP(0)+='&[F:SOH]CUR=[M]CUR'       Endif

   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="PTE"
   ##   If CZ<>""     FILGAUSUP(0)+='&[F:SOH]PTE=CZ'           Endif
   ##Else
   ##   If [M]PTE<>"" FILGAUSUP(0)+='&[F:SOH]PTE=[M]PTE'       Endif
   ##Endif
   If [M]PTE<>"" FILGAUSUP(0)+='&[F:SOH]PTE=[M]PTE'       Endif
Endif

# Les lignes ne doivent pas être soldées et doivent être fermes
FILGAUSUP(1)  = '&[F:SOQ]DEMSTA=1'
#--- Issue 112531 by TS
FILGAUSUP(1) += '&[F:SOQ]DLVFLG=2'
#---
# Date expédition cdes doit être < date d'expédition liv + nbre jours paramétrés
FILGAUSUP(1) += '&[F:SOQ]SHIDAT<=[M]SHIDAT+GSHINBRDAY'

FILGAUSUP(1) += '&[F:SOQ]CAD=1'

# LTA.sn  79065
# If func AFNC.ACTIV("LTA") & GLOCUSATAX & [M]NBLIG > 0   # 106867.o
If func TRTTAXSST.CHK_SSTTAXACT([F:SOH]CPY) & [M]NBLIG > 0   # 106867.n
  FILGAUSUP(1)+='&[F:SOH]SSTENTCOD=[M]SSTENTCOD'
Endif
# LTA.en  79065


If [M]NBLIG <> 0
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If COUZON="PRITYP"
   ##   If CZ<>""        FILGAUSUP(1)+='&[F:SOH]PRITYP=CZ'        Endif
   ##Else
   ##   If [M]PRITYP<>0  FILGAUSUP(1)+='&[F:SOH]PRITYP=[M]PRITYP' Endif
   ##Endif
   If [M]PRITYP<>0  FILGAUSUP(1)+='&[F:SOH]PRITYP=[M]PRITYP' Endif
Endif

#--CPO 75115 Nouveau champ SDHTYP
#--On filtre sur les cdes ayant le même type de livraison ou ""
FILGAUSUP(2) += '& find([F:SOH]SDHTYP,"",[M]SDHTYP)>0'
#--/CPO

GBIDC3="" : Call FILROLE("SOQ",GBIDC3) From SUBARL
If GBIDC3<>"" FILGAUSUP(3)= "& " + GBIDC3 : Endif

Return

#########################################################################
$FILGAUCHE3

# Si pas de clé courante (sauf si création) ou liv validée
# ou pas de client livré, rien dans la liste de picking
##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##&  (COUZON="BPAADD" & CZ="") | (COUZON<>"BPAADD" & [M]BPAADD="")
If (GREP="" & !CLECUR) | [M]CFMFLG=2 |
&  [M]BPAADD=""
   FILGAUSUP(0) = '[F:REO]LOC=""'
   Return
Endif

# If the delivery category is Nonbillable, the left lists are not populated
# X3-99883 (lcc - 19/07/18)
If [M:SDH0]SDHCAT=4
   FILGAUSUP(0)+='[F:REO]LOC=""'
   Return
Endif
# End X3-99883 (lcc - 19/07/18)

# Si pas livraison sous-traitance ou pas d'emplacement sous-traitant,
# rien dans la liste de picking
If dim([M:SDH0]SCO) > 0
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If (COUZON="SDHCAT"& val(CZ)<>2) | [M]SDHCAT<>2 | (dim([M:SDH3]BPCLOC)>0 & [M]BPCLOC="")
   If [M]SCO<>2 | (dim([M:SDH3]BPCLOC)>0 & [M]BPCLOC="")
      FILGAUSUP(0) = '[F:REO]LOC=""'
      Return
   Endif
Endif

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="STOFCY"
##   FILGAUSUP(0)='[F:REO]STOFCY=CZ'
##Else
##   FILGAUSUP(0)='[F:REO]STOFCY=[M]STOFCY'
##Endif
FILGAUSUP(0)='[F:REO]STOFCY=[M]STOFCY'

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="BPCLOC"
##   FILGAUSUP(0)+='&[F:REO]LOC=CZ'
##Else
##   FILGAUSUP(0)+='&[F:REO]LOC=[M]BPCLOC'
##Endif
FILGAUSUP(0)+='&[F:REO]LOC=[M]BPCLOC'

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="BPCORD"
##   FILGAUSUP(0)+='&[F:REO]BPRNUM=CZ'
##Else
##   FILGAUSUP(0)+='&[F:REO]BPRNUM=[M]BPCORD'
##Endif
FILGAUSUP(0)+='&[F:REO]BPRNUM=[M]BPCORD'

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="BPAADD"
##   FILGAUSUP(0)+='&[F:REO]BPAADD=CZ'
##Else
##   FILGAUSUP(0)+='&[F:REO]BPAADD=[M]BPAADD'
##Endif
FILGAUSUP(0)+='&[F:REO]BPAADD=[M]BPAADD'

# Les besoins de réappro ne doivent pas être dans un plan de réappro
FILGAUSUP(0) += '&[F:REO]VCRNUM=""'
# Les besoins de réappro ne doivent pas être en cours de réappro
FILGAUSUP(0) += '&[F:REO]STAFLG<>2'

Return

#########################################################################
$FILGAUCHE4

# Si pas de clé courante (sauf si création) ou liv validée
# ou pas de client livré, rien dans la liste de picking
##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##&  (COUZON="BPAADD" & CZ="") | (COUZON<>"BPAADD" & [M]BPAADD="")
If (GREP="" & !CLECUR) | [M]CFMFLG=2 |
&  [M]BPAADD=""
   FILGAUSUP(0) = '[F:STA]ITMREF=""'
   Return
Endif

# If the delivery category is Nonbillable, the left lists are not populated
# X3-99883 (lcc - 19/07/18)
If [M:SDH0]SDHCAT=4
   FILGAUSUP(0)+='[F:STA]ITMREF=""'
   Return
Endif
# End X3-99883 (lcc - 19/07/18)

# Si pas livraison sous-traitance ou pas d'emplacement sous-traitant,
# rien dans la liste de picking
If dim([M:SDH0]SCO) > 0
   ##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
   ##If (COUZON="SDHCAT"& val(CZ)<>2) | [M]SDHCAT<>2 | (dim([M:SDH3]BPCLOC)>0 & [M]BPCLOC="")
   If [M]SCO<>2 | (dim([M:SDH3]BPCLOC)>0 & [M]BPCLOC="")
      FILGAUSUP(0) = '[F:STA]ITMREF=""'
      Return
   Endif
Endif

# OF ou EO
FILGAUSUP(0)='find([F:STA]VCRTYP,10,36)'

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="STOFCY"
##   FILGAUSUP(0)+='&[F:STA]STOFCY=CZ'
##Else
##   FILGAUSUP(0)+='&[F:STA]STOFCY=[M]STOFCY'
##Endif
FILGAUSUP(0)+='&[F:STA]STOFCY=[M]STOFCY'

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="BPCORD"
##   FILGAUSUP(0)+='&[F:STA]BPRNUM=CZ'
##Else
##   FILGAUSUP(0)+='&[F:STA]BPRNUM=[M]BPCORD'
##Endif
FILGAUSUP(0)+='&[F:STA]BPRNUM=[M]BPCORD'

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="BPAADD"
##   FILGAUSUP(0)+='&[F:STA]BPAADD=CZ'
##Else
##   FILGAUSUP(0)+='&[F:STA]BPAADD=[M]BPAADD'
##Endif
FILGAUSUP(0)+='&[F:STA]BPAADD=[M]BPAADD'

##VPO 05/05/09 51742 pb listes gauches et CZ (modif FILGAUCHE et APRES_MODIF)
##If COUZON="BPCLOC"
##   FILGAUSUP(0)+='&find([F:STA]LOC,CZ,"")'
##Else
##   FILGAUSUP(0)+='&find([F:STA]LOC,[M]BPCLOC,"")'
##Endif
FILGAUSUP(0)+='&find([F:STA]LOC,[M]BPCLOC,"")'

# Matière à livrer au sous-traitant
FILGAUSUP(0)+='&[F:STA]SCOFLG=2'
# Uniquement manquant détail
FILGAUSUP(0)+='&[F:STA]ALLTYP=4'
# Ne doit pas être en cours de préparation
FILGAUSUP(0)+='&[F:STA]SRGQTYSTU=0'
Return

#########################################################################
# $FILGAUCHE5 : Tiroir Bon de préparation                               #
#########################################################################
$FILGAUCHE5

# Si pas de clé courante (sauf si création) ou liv validée
# rien dans la liste de picking
If (GREP="" & !CLECUR) | [M]CFMFLG=2
   FILGAUSUP(0) = '[F:PRH]STOFCY=""'
   Return
Endif

# If the delivery category is Nonbillable, the left lists are not populated
# X3-99883 (lcc - 19/07/18)
If [M:SDH0]SDHCAT=4
   FILGAUSUP(0)+='[F:PRH]STOFCY=""'
   Return
Endif
# End X3-99883 (lcc - 19/07/18)

FILGAUSUP(0)+='[F:PRH]STOFCY=[M]STOFCY'

If [M]BPCORD <> ""
    FILGAUSUP(0)+='&[F:PRH]BPCORD=[M]BPCORD'
Endif

If [M]BPAADD <> ""
    FILGAUSUP(0)+='&[F:PRH]BPAADD=[M]BPAADD'
Endif


# bons de préparation doit être livrable
FILGAUSUP(0)+='&[F:PRH]DLVFLG=2'

#si livraison de sous traitance, BP origine sous traitance
If [M:SDH0]LND = 2
  FILGAUSUP(0)+='&[F:PRH]ORIPRH=2'
Endif
#si livraison de prêt, BP origine cde de prêt
If dim([M:SDH0]SCO) > 0
 If [M:SDH0]SCO = 2
  FILGAUSUP(0)+='&[F:PRH]ORIPRH=3'
 Endif
Endif

#--CPO 22.10.2013
#If [M:SDH0]LND <> 2  & [M:SDH0]SCO <> 2
If dim([M:SDH0]SCO) > 0
  If [M:SDH0]LND <> 2  & [M:SDH0]SCO <> 2 : FILGAUSUP(0)+='&[F:PRH]ORIPRH=1' : Endif
Else
  If [M:SDH0]LND <> 2 : FILGAUSUP(0)+='&[F:PRH]ORIPRH=1' : Endif
Endif

#--JDE 75115 Nouveau champ SDHTYP
#--On filtre sur les BP ayant le même type de livraison ou ""
If dim([M]SDHTYP) > 0
  FILGAUSUP(0) += '& find([F:PRH]SDHTYP,"",[M]SDHTYP)>0'
Endif

Return

# X3-1152 : Non invoiceable deliveries
$FILGAUCHE6

# Si pas de clé courante (sauf si création) ou liv validée,
# rien dans la liste de picking
If (GREP="" & !CLECUR) | [M]CFMFLG=2
   FILGAUSUP(0) = '1=2'
   Return
Endif
### Project management site equal to the sales site
FILGAUSUP(0) = '[F:OPP]SALFCY=[M:SDH0]SALFCY'

### Site task equal to the shipment site
FILGAUSUP(0) += ' & [F:PJTA]TASFCY=[M:SDH0]STOFCY'

### Deliverable
FILGAUSUP(0) += ' & [F:JTT]DLVFLG=2'

## Customer
FILGAUSUP(0) +=' & [F:OPP]OPPCMP=[M:SDH0]BPCORD & [F:OPP]OPPCMP<>""'

### delivery type = Nonbillable
FILGAUSUP(0) +=' & [M:SDH0]SDHCAT=4'

### Task launched or started
FILGAUSUP(1) = '& ([F:PJTA]TASSTATE=2 OR [F:PJTA]TASSTATE=3) '
### Header project/Task/budget

If [M:SDH2]PJT<>""
   I=find("!",[M:SDH2]PJT)
   If I
   Else
     FILGAUSUP(1)+=' &[F:JTT]OPPNUM=[M:SDH2]PJT'
   Endif
Endif
Return
# X3-1152 : Non invoiceable deliveries

#########################################################################
$AP_FILGAUCHE
 #MAE BP_LIV When GBOXSO1,GBOXSO2,GBOXRE1,GBOXSC1 : WPICK=2 : Gosub RAFFRAICHI
Case currbox
 When GBOXSO1,GBOXSO2,GBOXRE1,GBOXSC1, GBOXPH1 : WPICK=2 : Gosub RAFFRAICHI
  # X3-1152 : Non invoiceable deliveries
 When GBOXPJ5 : WPICK=2 : Gosub RAFFRAICHI
 # X3-1152 : Non invoiceable deliveries
 When Default
Endcase
Return

#########################################################################
$DEB_PICK

Local Integer I, J, WOK, FUNCTION, NOL
Local Char    SYMBOLE2(50)
Local Integer WCTL : WCTL=0

FUNCTION = 3  : # Identifiant livraison pour TRTVENBOM

Return

#########################################################################
$PICKE
If REP=""
   If !CLECUR | !VERROU | !ACTMOD | GCONSULT OK=0
      Return
   Endif
Endif

Case currbox
 When GBOXSO1,GBOXSO2 : Gosub SEL
 When GBOXRE1         : Gosub SEL3
 When GBOXSC1         : Gosub SEL4
 When GBOXPH1         : Gosub SEL5  #MAE LIV_BP
 When GBOXPJ5         : Gosub SEL6  # X3-1152 : Non invoiceable deliveries
 When Default
Endcase

# 101380 - If contract order, get SFI override for inv elem
If [M:SDH1]SOHCAT(nolign-1)=4 : Call RELOAD_SFISST From SUBSDHA1 : Endif

# Tax by document - before VALTTC call
# If func AFNC.ACTIV("LTA") & GLOCUSATAX   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
  GTAXBYDOC = 1
Endif


Return

#########################################################################
$DEPICK


Case currbox
 When GBOXSO1,GBOXSO2 : Gosub DESEL
                        #Maj Qty fait lors du AVANT_LIGNE
                        # Gosub SOH_MOINS From SUBSFIT
 When GBOXRE1         : Gosub DESEL3
 When GBOXSC1         : Gosub DESEL4
 When GBOXPH1         : Gosub DESEL5  #MAE LIV_BP
 When GBOXPJ5         : Gosub DESEL6  # X3-1152 : Non invoiceable deliveries
 When Default
Endcase


Return

#########################################################################
$ETAT_PICK_ZONE

If [M]NBLIG=0
    Actzo [M:SDH0]STOFCY, SALFCY, BPCORD, BPAADD, BPCINV
    Actzo [M:SDH0]SDHTYP  :#--CPO 75115 - 203 Nouveau champ SDHTYP
    Actzo [M:SDH2]PTE, VACBPR
    If GDLVTYP=4 Actzo [M:SDH0]LND Endif
    If GUPDCUR=2 Actzo [M:SDH1]CUR Endif
    If GNOTATI=2 Actzo [M:SDH1]PRITYP Endif
    If dim([M:SDH0]SCO) > 0 & [M:SDH0]LND <> 2
        Actzo [M:SDH0]SCO
        If [M:SDH0]SCO = 2 & dim([M:SDH3]BPCLOC)>0 Actzo [M:SDH3]BPCLOC Endif
    Endif
Else
    Diszo [M:SDH0]STOFCY, SALFCY, LND, BPCORD, BPAADD, BPCINV
    Diszo [M:SDH0]SDHTYP  :#--CPO 75115 - 203 Nouveau champ SDHTYP
    Diszo [M:SDH1]CUR, PRITYP
    Diszo [M:SDH2]PTE, VACBPR
    If dim([M:SDH0]SCO) > 0 Diszo [M:SDH0]SCO : Diszo [M:SDH3]20 Endif
Endif
Return
#########################################################################
$FIN_PICK

Call PJT_INFO_MSG() From TRTPJT   # FGR 15/12/2011 : X3SUIVI71065

Raz WCTL

Call SOH_SDH_CALCUL From SUBSFIT

# 101874 : V9 : Taxe code control
# Valuation depends on SOHVALLIG parameter
#If dim(GVALTTCSDH)>0 & dim(GVALTTC)>0 : GVALTTC=GVALTTCSDH : Endif
GVALTTC=GSDHVALLIG
#Call VALTTC ("GESSDH") From TRTVENFACR
#---- Paramètres complementaires appel valorisation
# PARAM_T(0) : Flag contrôle des taxes             (1=Non/2=Oui)
# PARAM_T(1) : Lecture de la trace par le sous-pro (1=Non/2=Oui)
# PARAM_T(2) : Flag retour                         (1=KO/2=OK)
Local    Char     PARAM_T (25) (0..10)
PARAM_T(0)="1"      : # Pas de contrôle des taxes
PARAM_T(1)="1"      : # Pas de lecture de la trace
PARAM_T(2)="0"
Call VALTTC ("GESSDH", PARAM_T) From TRTVENFACR
If PARAM_T(2)="1" GERR=1 : OK=0 : Endif
# 101874

If REP=""
   If !VERROU
      GMESSAGE=mess(10,100,1) : GERR=1 : OK=0 : Return
   Elsif !CLECUR | !ACTMOD | GCONSULT
      GMESSAGE=mess(9,123,1)  : GERR=1 : OK=0 : Return
   Endif
Endif

# ACA (2009-09-22) Lot S03 : chargement des sections des elts de fac des documents origine
# 81878 : Ajout borne pour ne pas trier le tableau complet
#Sorta [M:SFIT]NBTRF Order By [M:SFIT]DAC([S]indice)
Sorta [M:SFIT]NBTRF [M:SFIT]NBTRF Order By [M:SFIT]DAC([S]indice)
# 81878
Call CHARG_CCE_MULTI(20,"[M:SFIT]VCRENT","[M:SFIT]DTA","[M:SIHV]XFNUM","[M:SIHV]SFICCE","[M:SIHV]DSP") From TRTX3CPT

#MAE, LIV_BP When GBOXSO1,GBOXSO2,GBOXRE1,GBOXSC1 : Affzo [M:SDH0]1-99
# X3-1152 : Non invoiceable deliveries
# When GBOXSO1,GBOXSO2,GBOXRE1,GBOXSC1,GBOXPH1: Affzo [M:SDH0]1-99
Case currbox
 When GBOXSO1,GBOXSO2,GBOXRE1,GBOXSC1,GBOXPH1,GBOXPJ5 : Affzo [M:SDH0]1-99
                                        Affzo [M:SDH1]1-99
                                        Affzo [M:SDH2]1-99
                                        Affzo [M:SDH3]1-99
                                        Gosub ETAT_PICK_ZONE
                                        zonsui = "[M:SDH1]NBLIG("+num$(NOL)+")"
 When Default
Endcase

Return
#########################################################################
# Etiquettes de traitement                                              #
#########################################################################

$REMPBOX
#-----------------------------------------------------------------------#
# Remplissage des boites de picking                                     #
#-----------------------------------------------------------------------#

ILIS=val(right$(currbox,8))

Gosub REMP_LISGAU From GOBJSUB

Return

#########################################################################
$SEL
#-----------------------------------------------------------------------#
# Sélection d'une ligne de commande                                     #
#-----------------------------------------------------------------------#

# Si cde classique, alimentation de la clé de SOQ et forçage de SOPSEQ
If currbox=GBOXSO1
   [F:SOQ]SOHNUM = [F:SOP]SOHNUM
   [F:SOQ]SOPLIN = [F:SOP]SOPLIN
   [F:SOQ]SOQSEQ = [F:SOP]SOPLIN
   [F:SOP]SOPSEQ = [F:SOP]SOPLIN
Endif
#--- Lecture des tables [SOQ],[SOH],[SOP] et [SOC] si cde ouv
Read [SOQ]SOQ0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOQSEQ
If fstat
   Call RSTA ("SOQ",[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)) From GLOCK
   OK=0 : Return
Endif
# Vérification si la ligne n'a pas été soldée
# depuis le dernier raffraichissement de la liste de picking
If [F:SOQ]ODLQTY + [F:SOQ]DLVQTY >= [F:SOQ]QTY
    GMESSAGE = [F:SOQ]SOHNUM-":"-mess(27,159,1)-[F:SOQ]ITMREF-":"-mess(247,192,1)
    OK=0 : Return
Endif

# Cette ligne est en préparation
If sum([F:SOQ]LPRQTYSTU,[F:SOQ]OPRQTYSTU,[F:SOQ]PREQTYSTU)<>0
   GMESSAGE = [F:SOQ]SOHNUM-":"-mess(27,159,1)-[F:SOQ]ITMREF-":"-mess(309,192,1)
   OK=0 : Return
Endif

Read [SOH]SOH0=[F:SOQ]SOHNUM
If fstat
   Call RSTA ("SOH",[F:SOH]SOHNUM) From GLOCK : OK=0 : Return
Endif
If currbox=GBOXSO1
   Raz [F:SOC]
   Read [SOP]SOP0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN;[F:SOQ]SOPLIN
   If fstat
      Call RSTA ("SOP",[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)) From GLOCK
      OK=0 : Return
   Endif
Else
   Read [SOC]SOC0=[F:SOQ]SOHNUM;[F:SOQ]SOPLIN
   If fstat
      Call RSTA ("SOC",[F:SOQ]SOHNUM-num$([F:SOQ]SOPLIN)) From GLOCK
      OK=0 : Return
   Endif
   # Si pas de code tarif, on recherche s'il y a un enregistrement prix
   Raz [F:SOP]
   If [F:SOC]PLI = ""
      Filter [SOP] Where SOHNUM  = [F:SOQ]SOHNUM & SOPLIN  = [F:SOQ]SOPLIN &
&                        STRDAT <= [F:SOQ]SHIDAT & ENDDAT >= [F:SOQ]SHIDAT
      Read [SOP]SOP0 First
      If fstat : Raz [F:SOP] : Endif
      Filter [SOP]
   Endif
Endif

If [M:SDH0]SALFCY = ""
   # Alim. GSOCIETE,GFINRSP,GLOCALDEV
   #Call GETDEV([F:SOH]SALFCY) From DEVSUB
   If GFCY<>[F:SOH]SALFCY
       # Chargement globales référenciels, comptes et sections de la société
       GFCY=[F:SOH]SALFCY : Gosub CHARG_PARAM From SUBSDHA
   Endif
   # Alimentation des paramètres
   # Gestion avance(GEARMGT), Acompte non versé(GLOKORD), Ctrl en-cours(GOSTCTL)
   Call GLOBVAR([F:SOH]SALFCY,"VEN") From TRTX3
Endif

#--- Lecture des tables articles
Gosub LEC_TABART

#--- Contrôle état crédit de la commande
# WCTL=0 : Ctrl non encore effectué car 1ère ligne de la cde traitée
# WCTL=1 : Ctrl déjà effectué sur les lignes précédentes de la cde avec abandon
# WCTL=2 : Ctrl déjà effectué sur les lignes précédentes de la cde avec poursuite
If WCTL=0
    WCTL=2

    Call SDCDTSTA ([F:SOH]SOHNUM,[F:SOH]BPCORD,[F:SOH]CHGTYP,0,[F:SOH]CUR,[F:SOH]ORDDAT,
&                  [F:SOH]UNL,1,CDTSTA,[M]OST,[M]OSTAUZ) From TRTVENCDT
    Case CDTSTA
     When 2 : OK=0 : GERR=1          : # Client bloqué
              GMESSAGE=[F:SOH]SOHNUM-mess(52,192,1)
              WCTL=1 : Return
     When 3 :                   : # Dépassement d'en cours
            # X3-1152 : Non invoiceable deliveries
            If [M:SDH0]SDHCAT<>4
            # X3-1152 : Non invoiceable deliveries
              If !([F:SOH]BETFCY = 2 & [F:SOH]BETCPY <> 2) or GCTLBETFCY = 2 Then      # FGR 10/03/2015 : X3SUIVI23273 : pas en inter-sites ou GCTLBETFCY <> 2
                # Si déblocage crédit non autorisé on bloque
                # FGR 09/03/2015 : X3SUIVI68376 (début)
                # -----------------------
                #If GCDTUNL=1
                #    OK=0:GERR=1
                #    GMESSAGE=[F:SOH]SOHNUM-mess(29,192,1)
                #    WCTL=1 : Return
                #Endif
                #WOK=2
                #Call AVERTIR([F:SOH]SOHNUM-mess(29,192,1),WOK) From GESECRAN
                #If WOK=1 OK=0 : WCTL=1 : Return Endif
                # -----------------------
                Local Integer WCTRLENCOURS  # =1 : Le contrôle a déjà été fait et le message affiché
                                            # =2 : Le contrôle n'a pas encore été fait, il faut le faire et afficher le message
                WCTRLENCOURS = 1
                If [M]NBLIG = 0 Then
                  WCTRLENCOURS = 2
                Elsif [M]NBLIG > 0 Then
                  # Cas de la modification de livraison : si la dernière ligne actuelle existe en base on fait le contrôle.
                  # Si elle n'existe pas, c'est que c'est une nouvelle ligne donc le contrôle a déjà été fait. On ne le refait pas.
                  # Du coup, ça marche aussi quand on est en création.
                  Read [SDD1]SDD0=[M:SDH0]SDHNUM;[M:SDH1]SDDLIN([M:SDH1]NBLIG-1)
                  If !fstat Then
                    WCTRLENCOURS = 2      #-- Article precedent existe en table : on est donc sur le 1er ajout et on fait le ctrl --#
                  Endif
                Endif
                If WCTRLENCOURS <> 2 Then
                  WOK = 2
                Else
                  # Si déblocage crédit non autorisé on bloque
                  If GCDTUNL = 1 Then
                    OK = 0
                    GERR = 1
                    GMESSAGE = [F:SOH]SOHNUM - mess(29,192,1)
                    #-- 81855
                    If dim(GVENFLG02) >= 0 & (GVENFLG02 = 2 or GVENFLG02 = 3) Then
                      GMESSAGE += WMESS9
                    Endif
                    WCTL = 1
                    Return
                  Endif
                  WOK = 2
                  WMESS1 = [F:SOH]SOHNUM - mess(29,192,1)
                  #-- 81855
                  If dim(GVENFLG02) >= 0 & (GVENFLG02 = 2 or GVENFLG02 = 3) Then
                    WMESS1 += WMESS9
                  Endif
                  Call AVERTIR(WMESS1, WOK) From GESECRAN
                  If WOK = 1 Then
                    OK = 0
                    WCTL = 1
                    Return
                  Endif
                Endif
                # FGR 09/03/2015 : X3SUIVI68376 (fin)
              Endif
            # X3-1152 : Non invoiceable deliveries
            Endif
            # X3-1152 : Non invoiceable deliveries
     When 4 : If GLOKORD=2
                 OK=0 : GERR=1       : # Acomptes non versés
                 GMESSAGE=[F:SOH]SOHNUM-mess(53,192,1)
                 WCTL=1 : Return
              Endif
     When 5 : OK=0 : GERR=1          : # Sage Exchange
              Local Char VCRNUM
              Local Integer VCRTYP
              Call SEPP_CUR_DOC([F:SOH]SOHNUM,[L]VCRTYP,[L]VCRNUM) From SEPPCDT
              If [L]VCRNUM<>[F:SOH]SOHNUM
                If [L]VCRTYP=4
                  GMESSAGE = func AFNC.MES1(mess(52,2092,1),mess(54,198,1)-[L]VCRNUM)
                Else
                  GMESSAGE = func AFNC.MES1(mess(52,2092,1),mess(55,198,1)-[L]VCRNUM)
                Endif
              Else
                GMESSAGE = mess(9,2092,1)
              Endif
              GMESSAGE=[F:SOH]SOHNUM-GMESSAGE
              WCTL=1 : Return
     When Default
    Endcase
Elsif WCTL=1
    OK=0 : Return
Endif

#--- Appel au traitement de contrôle de la sélection
# C'est la 1ére commande de la livraison
If [M:SDH1]NBLIG <> 0
   #CPO 68235
   #If sum([M:SDH1]XSOHNUM(0..[M:SDH1]NBLIG-1)) = ""
   If sigma(0,[M:SDH1]NBLIG-1,[M:SDH1]XSOHNUM(indcum)) = ""
      YSOHNUM     = [F:SOH]SOHNUM
      [M:SDH0]ODL = [F:SOH]ODL
      [M:SDH0]IME = [F:SOH]IME
   Endif
Endif

# Contrôle que la ligne de commande est livrable
Gosub CTL_CDE_LIG
If OK=0 Return Endif

# C'est la première ligne de la livraison
If [M]NBLIG = 0
   If currbox=GBOXSO1
      WSOHCAT=1
      If [M:SDH0]LND=2 WSOHCAT=2 Endif
   Elsif currbox=GBOXSO2
      WSOHCAT=4
   Endif

   # Alimentation des masques (entête)
   Call ALISOHSDH(WSOHCAT) From TRTVENLIV

   YSOHNUM = [F:SOH]SOHNUM
Else
   # Contrôle des conditions des regroupement, et des liens cde/liv/fac
   Gosub CTL_CDE
   If OK=0 Return Endif
Endif

# Contrôle de l'insertion
If [M:SDH1]NBLIG+1 >= dim([M:SDH1]ITMREF)-1
   GERR=1 : GMESSAGE=mess(122,199,1)
   OK=0   : Return
Endif

If currbox=GBOXSO1
   SYMBOLE2 = "SOH"+[F:SOH]SOHNUM
Elsif currbox=GBOXSO2
   SYMBOLE2 = "SOC"+num$([F:SOC]SOPLIN)+"\"+[F:SOC]SOHNUM
Endif
Lock = SYMBOLE2
If fstat
   # modification en cours sur un autre poste
   GERR=1 : GMESSAGE=[F:SOH]SOHNUM-":"-mess(10,100,1)
   OK=1   : Return
Endif

# Issue X3-135586 - 2019-04-25 by ANKUL : begin
If currbox=GBOXSO1
  If func AFNC.ACTIV("KPO")> 0 and func PORLEGLIB.PORLEG([M:SDH0]SALFCY,"") =1 and func PORLEGLIB.DIGSIGN([M:SDH0]SALFCY, "")
    If [F:SOH]SOHCFMFLG <> 2
      GMESSAGE = func AFNC.MES1(mess(295,7711,1), [F:SOH]SOHNUM)
      OK=0 : Return
    Endif
  Endif
Endif
# Issue X3-135586 - 2019-04-25 by ANKUL : end

#---------------------------------------------
# Traitement de la ligne de commande à livrer
#---------------------------------------------

Gosub TRT_LIGCDE
If OK=0 Unlock = SYMBOLE2 : Endif

If COUZON="STOFCY" & CZ="" CZ=[M:SDH0]STOFCY Endif
If COUZON="SALFCY" & CZ="" CZ=[M:SDH0]SALFCY Endif
If COUZON="BPCORD" & CZ="" CZ=[M:SDH0]BPCORD Endif

#Affzo [M:SDH0]1-99
#Affzo [M:SDH1]1-99
#Affzo [M:SDH2]1-99
Raz GMESSAGE

Return

#########################################################################
$SEL3
#-----------------------------------------------------------------------#
# Sélection d'un besoin de reappro d'emplacement sous-traitant          #
#-----------------------------------------------------------------------#
Read [REO]REO0=[F:REO]STOFCY;[F:REO]LOC;[F:REO]ITMREF
If fstat
   Call RSTA ("REO",[F:REO]STOFCY-[F:REO]LOC-[F:REO]ITMREF) From GLOCK
   OK=0 : Return
Endif

If [M:SDH0]SALFCY = ""
   # Alim. GSOCIETE,GFINRSP,GLOCALDEV
   #Call GETDEV([F:REO]STOFCY) From DEVSUB
   If GFCY<>[F:REO]STOFCY
       # Chargement globales référenciels, comptes et sections de la société
       GFCY=[F:REO]STOFCY : Gosub CHARG_PARAM From SUBSDHA
   Endif
Endif

#--- Lecture des tables articles
Gosub LEC_TABART

# Contrôle de l'insertion
If [M:SDH1]NBLIG+1 >= dim([M:SDH1]ITMREF)-1
   GERR=1 : GMESSAGE=mess(122,199,1)
   OK=0   : Return
Endif

SYMBOLE2 = "REO"+[F:REO]STOFCY+"\"+[F:REO]LOC+"\"+[F:REO]ITMREF
Lock = SYMBOLE2
# modification en cours sur un autre poste
If fstat
   GERR=1
   GMESSAGE=[F:REO]STOFCY+"\"+[F:REO]LOC+"\"+[F:REO]ITMREF-":"-mess(10,100,1)
   OK=1 : Return
Endif

#---------------------------------------
# Traitement du besoin réappro à livrer
#---------------------------------------

Gosub TRT_STOREO
If OK=0 Unlock = SYMBOLE2 : Endif

If COUZON="STOFCY" & CZ="" CZ=[M:SDH0]STOFCY Endif
If COUZON="SALFCY" & CZ="" CZ=[M:SDH0]SALFCY Endif
If COUZON="BPCORD" & CZ="" CZ=[M:SDH0]BPCORD Endif

Raz GMESSAGE

Return

#########################################################################
$SEL4

#-----------------------------------------------------------------------#
# Sélection d'un manquant sous-traitant issu d'un OF ou d'un EO         #
#-----------------------------------------------------------------------#
Read [STA]STA0=[F:STA]STOFCY;[F:STA]ITMREF;[F:STA]STOCOU;[F:STA]SEQ
If fstat
   Call RSTA ("STA",[F:STA]STOFCY-[F:STA]ITMREF-num$([F:STA]STOCOU)) From GLOCK
   OK=0 : Return
Endif

If [M:SDH0]SALFCY = ""
   # Alim. GSOCIETE,GFINRSP,GLOCALDEV
   #Call GETDEV([F:STA]STOFCY) From DEVSUB
   If GFCY<>[F:STA]STOFCY
       # Chargement globales référenciels, comptes et sections de la société
       GFCY=[F:STA]STOFCY : Gosub CHARG_PARAM From SUBSDHA
   Endif
Endif

#--- Lecture des tables articles
Gosub LEC_TABART

# Contrôle de l'insertion
If [M:SDH1]NBLIG+1 >= dim([M:SDH1]ITMREF)-1
   GERR=1 : GMESSAGE=mess(122,199,1)
   OK=0   : Return
Endif

# Issue X3-38309
# Entry point to stop picking subcontract shortage
GPOINT = "SELPICSTA" : Gosub ENTREE From EXEFNC
If OK=0 Return Endif
# End issue X3-38309

SYMBOLE2 = "STA"+[F:STA]STOFCY+"\"+[F:STA]ITMREF+"\"+num$([F:STA]STOCOU)+"\"+num$([F:STA]SEQ)
Lock = SYMBOLE2
# modification en cours sur un autre poste
If fstat
   GERR=1
   GMESSAGE=[F:STA]STOFCY+"\"+[F:STA]ITMREF+"\"+num$([F:STA]STOCOU)-":"-mess(10,100,1)
   OK=1 : Return
Endif

#-----------------------------------------------
# Traitement du manquant sous-traitant à livrer
#-----------------------------------------------

Gosub TRT_STOSTA
If OK=0 Unlock = SYMBOLE2 : Endif

If COUZON="STOFCY" & CZ="" CZ=[M:SDH0]STOFCY Endif
If COUZON="SALFCY" & CZ="" CZ=[M:SDH0]SALFCY Endif
If COUZON="BPCORD" & CZ="" CZ=[M:SDH0]BPCORD Endif

Raz GMESSAGE

Return

#########################################################################
$SEL5

Local Integer WSTOSEQ
Local Decimal WOALQTYSTU    : # Qté allouée origine en US
#-----------------------------------------------------------------------#
# Sélection d'un bon de préparation                                     #
#-----------------------------------------------------------------------#
Read [PRH]PRH0=[F:PRH]PRHNUM
If fstat
   Call RSTA ("PRH",[F:PRH]PRHNUM) From GLOCK
   OK=0 : Return
Endif

If [M:SDH0]SALFCY = ""
   # Alim. GSOCIETE,GFINRSP,GLOCALDEV
      If GFCY<>[F:PRH]STOFCY
       # Chargement globales référenciels, comptes et sections de la société
       GFCY=[F:PRH]STOFCY : Gosub CHARG_PARAM From SUBSDHA
   Endif
Endif

#--- Lecture des tables articles
Gosub LEC_TABART

# Ce n'est pas la première ligne de la livraison
If [M]NBLIG>0
   # Contrôle des conditions des regroupement
   Gosub CTL_PRH
   If OK=0 Return Endif
Endif

# Contrôle de l'insertion
If [M:SDH1]NBLIG+1 >= dim([M:SDH1]ITMREF)-1
   GERR=1 : GMESSAGE=mess(122,199,1)
   OK=0   : Return
Endif

SYMBOLE3 = "PRH"+[F:PRH]PRHNUM
Lock = SYMBOLE3
# modification en cours sur un autre poste
If fstat
   GERR=1
   GMESSAGE=[F:PRH]PRHNUM+":"-mess(10,100,1)
   OK=1 : Return
Endif

#-----------------------------------------------
# Traitement du bon de préparation
#-----------------------------------------------
GOK = 1

For [PRE]PRE0 Where [F:PRE]PRHNUM = [F:PRH]PRHNUM & [F:PRE]FLGANN = 0
       #--CPO 93104 Livraison : picking de préparations et commandes avec 1 cde / Facture
       #--WORINUM contient le numéro du BP et [F:PRE]ORINUM est le numéro du doc à l'origine du BP
       #If WORINUM <> [F:PRE]ORINUM & WORINUM <> "" & [M:SDH0]ODL = 2
       If YSOHNUM <> ""
         If [F:PRE]ORINUM<>"" & [F:SOH]SOHNUM<>[F:PRE]ORINUM
           Read [F:SOH]SOH0=[F:PRE]ORINUM
           If fstat : Raz [F:SOH] : Endif
         Endif
         If [F:SOH]SOHNUM<>"" &
&          ((([F:SOH]IME=2 | [F:SOH]IME=3  | [F:SOH]ODL=2)  & [F:SOH]SOHNUM<>YSOHNUM) |
&          (([M:SDH0]IME=2 | [M:SDH0]IME=3 | [M:SDH0]ODL=2) & [F:SOH]SOHNUM<>YSOHNUM))
        #--/
           GMESSAGE=[F:PRH]PRHNUM+":"-mess(55,192,1)
           OK=0 : Break
         Endif
       Endif

      #--- Bug 70801
      #If nolign-1=0
      #--CPO 79638 Le nolign-1 vaut 0 pour les deux premières lignes pickées !
      #--Test sur NBLIG pour alimenter en-tête
      If [M:SDH1]NBLIG=0
         WORINUM = [F:PRE]ORINUM
         YSOHNUM = [F:PRE]ORINUM :#--CPO 93104 Livraison : picking de préparations et commandes avec 1 cde / Facture
         # Issue X3-138971 - 20190703 by LD
         # ALICLISDH needs to have [F:BPC] fed
         If [F:BPC]BPCNUM <> [F:PRH]BPCORD
             Read [BPC]BPC0=[F:PRH]BPCORD
             If fstat OK=0 : Return : Endif
         Endif
         # [M:SDH0]BPCORD can be not fed
         #Call ALICLISDH("C", [M:SDH0]BPCORD) From TRTVENLIV
         Call ALICLISDH("C", [F:PRH]BPCORD) From TRTVENLIV
         If GERR=1 OK=0 : Return : Endif
         # Issue X3-138971 - 20190703 by LD
      Endif
      #---
      #--CPO 93104 Livraison : picking de préparations et commandes avec 1 cde / Facture
      #--On gère le cas où la 1ére commande de la livraison n'est pas pickée sur la 1ère ligne
      If [M:SDH1]NBLIG <> 0 and find([F:PRH]ORIPRH,1,2)>0
         If sigma(0,[M:SDH1]NBLIG-1,[M:SDH1]XSOHNUM(indcum)) = ""
           If [F:PRE]ORINUM<>"" & [F:SOH]SOHNUM<>[F:PRE]ORINUM
             Read [F:SOH]SOH0=[F:PRE]ORINUM
             If fstat : Raz [F:SOH] : Endif
           Endif
           If [F:SOH]SOHNUM<>""
             YSOHNUM     = [F:PRE]ORINUM
             [M:SDH0]ODL = [F:SOH]ODL
             [M:SDH0]IME = [F:SOH]IME
           Endif
         Endif
      Endif
      #--/

      Case [F:PRE]ORITYP
       When 1,2 : Gosub TRT_SOQ_PRH From SUBSDHB
       When 3   : Gosub TRT_REO_PRH From SUBSDHB
       When 4   : Gosub TRT_STA_PRH From SUBSDHB
      Endcase
      If GOK<>1
        # FGR 16/02/2015 : X3SUIVI104756 (début)
        #If GMESSAGE<>"" Call ERREUR(GMESSAGE) From GESECRAN Endif
        OK = 0
        # FGR 16/02/2015 : X3SUIVI104756 (fin)
        Break
      Endif
     #init de la commande d'origine
     #If nolign-1=0
     #   WORINUM = [F:PRE]ORINUM
     #   Call ALICLISDH("C", [M:SDH0]BPCORD) From TRTVENLIV
     #Endif
 Next

# FGR 16/02/2015 : X3SUIVI104756 (début) : à faire avant
#on repositionne currbox après la simulation de picking d'une commande
currbox = GBOXPH1
# FGR 16/02/2015 : X3SUIVI104756 (fin)

If OK=0 Unlock = SYMBOLE3 : Return :Endif

# FGR 16/02/2015 : X3SUIVI104756
##on repositionne currbox après la simulation de picking d'une commande
#currbox = GBOXPH1

If COUZON="STOFCY" & CZ="" CZ=[M:SDH0]STOFCY Endif
If COUZON="SALFCY" & CZ="" CZ=[M:SDH0]SALFCY Endif
If COUZON="BPCORD" & CZ="" CZ=[M:SDH0]BPCORD Endif

Raz GMESSAGE

Return

# X3-1152 : Non invoiceable deliveries
$SEL6
#-----------------------------------------------------------------------#
# Selection of a Task                                                   #
#-----------------------------------------------------------------------#

#- Reading of [JTT], [OPP]
Read [JTT]JTT0=[F:JTT]OPPNUM;[F:JTT]TASCOD;[F:JTT]ITTSEQ
If fstat
   Call RSTA("JTT",[F:JTT]OPPNUM-[F:JTT]TASCOD) From GLOCK
   OK=0 : Return
Endif

Read [OPP]OPP0=[F:JTT]OPPNUM
If fstat
   Call RSTA("OPP",[F:JTT]OPPNUM) From GLOCK
   OK=0 : Return
Endif
#### Verification over [JTT]
## Verification if the line is not delivered
If [F:JTT]ITTQTY<0
   GMESSAGE = [F:JTT]OPPNUM-":"-mess(27,159,1)-[F:JTT]ITMREF-":"-mess(754,197,1)
   OK=0: Return
Endif

#- Reading of the items table
Gosub LEC_TABART

#- Control procceses of the selection
#- It is the first project of the delivery..

#- The task is deliverable and nonbillable

#- It is the fist line of the delivery

#- Insertion control

Local Char SYMBOLE3(70)
SYMBOLE3 = "JTT"+[F:JTT]OPPNUM+"\"+[F:JTT]TASCOD+"\"+num$([F:JTT]ITTSEQ)
Lock = SYMBOLE3
If fstat
   # Change In Progress on another workstation
   GERR=1 :GMESSAGE=[F:JTT]OPPNUM+"\"+[F:JTT]TASCOD-  mess(10,100,1)
   OK=1: Return
Endif

#-----------------------------------------------------------
# Treatment of the task to deliver
#-----------------------------------------------------------
Gosub TRT_TASK
If OK=0: Unlock = SYMBOLE2: Endif

If COUZON="STOFCY" & CZ="" CZ=[M:SDH0]STOFCY Endif
If COUZON="SALFCY" & CZ="" CZ=[M:SDH0]SALFCY Endif
If COUZON="BPCORD" & CZ="" CZ=[M:SDH0]BPCORD Endif
Raz GMESSAGE

Return
# X3-1152 : Non invoiceable deliveries
#########################################################################
$DESEL

Local Integer WRET
Local Char    WSAVE_SOHNUM(GLONVCR) :#--CPO 93104

  # FGR 06/12/2013 : X3SUIVI91484 (début)
  # Cette ligne est en préparation
  If sum([F:SOQ]LPRQTYSTU,[F:SOQ]OPRQTYSTU,[F:SOQ]PREQTYSTU)<>0
     GMESSAGE = [F:SOQ]SOHNUM-":"-mess(27,159,1)-[F:SOQ]ITMREF-":"-mess(309,192,1)
     OK=0 : Return
  Endif
  # FGR 06/12/2013 : X3SUIVI91484 (fin)

#-----------------------------------------------------------------------#
# Désélection d'une ligne de commande                                   #
#-----------------------------------------------------------------------#
# Si cde classique, alimentation de la clé de SOQ et forçage de la valeur de SOPSEQ
If currbox=GBOXSO1
   [F:SOQ]SOHNUM = [F:SOP]SOHNUM
   [F:SOQ]SOPLIN = [F:SOP]SOPLIN
   [F:SOQ]SOQSEQ = [F:SOP]SOPLIN
   [F:SOP]SOPSEQ = [F:SOP]SOPLIN
Endif
Raz I,J
OK = 0
If [M:SDH1]NBLIG <> 0
   While OK <> 1
      I = find([F:SOQ]SOHNUM,[M:SDH1]XSOHNUM(J..[M:SDH1]NBLIG-1))
      If !I Break Endif
      If [M:SDH1]CREFLG(J+I-1)=0 & [F:SOQ]SOPLIN=[M:SDH1]SOPLIN(J+I-1)
&                                & [F:SOQ]SOQSEQ=[M:SDH1]SOQSEQ(J+I-1)
         # Maj montants livrés ,poids et suppression des textes
         GMODIF = 1
         NOL    = J+I-1
         Call AVANT_LIGNE(NOL) From SUBSDHB
         #--CPO 79343
         If GMODIF=1 and GREP<>"C" and GSDHSUPPLIGDSP>0 and GSDHSUPPLIGDSP<>999999
           Local Integer WTEMPDSP : Raz WTEMPDSP
           Call CTLSUPP_EXISTDSP("SDH",NOL,WTEMPDSP) From TRTVENDIV
           If WTEMPDSP=1
             GSDHSUPPLIGDSP -=1
           Endif
         Endif
         #--/CPO

         If [M:SDH1]STOMGTCOD(NOL)<>1
            # Nettoyage de l'écran de travail STOSORW
            Call DELSTOSORW(NOL,NOL,"SDH1",[M:SDH0]STOFCY,WRET) From STKSOR
            If WRET<>0 OK=0 : Return Endif
         Endif

         Dela NOL,1,[M:SDH1]NBLIG-1 [M:SDH1]NBLIG
         [M:SDH1]NBLIG -= 1
          #-- X3Suivi S81355 TranspoteursMultiples
         If [M:SDH1]NBLIG=0 : [M:SDH2]BPTNUM = '' : Endif

         # Si annulation composé kit alors suppression des composants
         If GMODIF = 3
            NL = NOL
            Gosub SUPNOM From TRTVENBOM
         Endif

         Raz GMESSAGE
         OK = 1
      Else
         J = J+I
      Endif
   Wend
   I = find([F:SOQ]SOHNUM,[M:SDH1]XSOHNUM(0..[M:SDH1]NBLIG-1))
   If !I
      # Local Integer NBPOSTE : NBPOSTE = 10
      If [F:SOH]SOHNUM <> [F:SOQ]SOHNUM
         Read [SOH]SOH0=[F:SOQ]SOHNUM
         If fstat
            Call RSTA ("SOH",[F:SOH]SOHNUM) From GLOCK
            OK=0 : Return
         Endif
      Endif
      # Plus aucune ligne pour cette cde -->
      # Suppression des montants cde dans les elements de facturation
      # ACA
      #Call SAISFOOT2(4,"SDH2",NBPOSTE,[M:SDH0]CHGTYP,[F:SOH]CUR,[M:SDH1]CUR,"SUP")
      #  &                    From TRTVENELT
   Endif
Endif

Raz GMODIF

# Si suite à désélection de la ligne, il n'y a plus de ligne sélectionnée
# sur cette cde, il faut la débloquer
Raz I,J
OK = 2
If [M:SDH1]NBLIG <> 0
   While OK <> 1
      I = find([F:SOQ]SOHNUM,[M:SDH1]XSOHNUM(J..[M:SDH1]NBLIG-1))
      If !I Break Endif
      If currbox=GBOXSO1
         If [M:SDH1]CREFLG(J+I-1)=0
            OK = 1
         Else
            J = J+I
         Endif
      Elsif currbox=GBOXSO2
         If [M:SDH1]CREFLG(J+I-1)=0 & [F:SOQ]SOPLIN=[M:SDH1]SOPLIN(J+I-1)
            OK = 1
         Else
            J = J+I
         Endif
      Endif
   Wend
Endif

#--CPO 93104
If ([M:SDH1]NBLIG>0 & sigma(0,[M:SDH1]NBLIG-1,[M:SDH1]XSOHNUM(indcum)) = "") | [M:SDH1]NBLIG=0
  Raz YSOHNUM
  Raz [M:SDH0]ODL, [M:SDH0]IME
Endif
#--Cas du depick total d'une commande dont le numéro est dans le YSOHNUM et qu'il reste d'autres cdes
If YSOHNUM <>"" & [M:SDH1]NBLIG>0 & find(YSOHNUM,[M:SDH1]XSOHNUM(0..[M:SDH1]NBLIG-1))<1
   For IJCPO=0 To [M:SDH1]NBLIG-1
      If [M:SDH1]XSOHNUM(IJCPO) <> ""
         YSOHNUM = [M:SDH1]XSOHNUM(IJCPO)
         #--Alimenter les ODL et IME depuis la commande retenue
         Raz WSAVE_SOHNUM
         If [F:SOH]SOHNUM<>YSOHNUM
           WSAVE_SOHNUM = [F:SOH]SOHNUM
           Read [F:SOH]SOH0=YSOHNUM
           If fstat : Raz [F:SOH] : Endif
         Endif
         If [F:SOH]SOHNUM<>""
           [M:SDH0]ODL = [F:SOH]ODL
           [M:SDH0]IME = [F:SOH]IME
         Endif
         If WSAVE_SOHNUM<>"" and [F:SOH]SOHNUM<>WSAVE_SOHNUM
           Read [F:SOH]SOH0=WSAVE_SOHNUM
           If fstat : Raz [F:SOH] : Endif
         Endif
         Break
      Endif
   Next I
Endif
#--/

  # FGR 31/01/2014 : X3SUIVI90148 (début) S'il n'y a plus de ligne on efface les textes
  If [M:SDH1]NBLIG = 0 Then
    If GSALTEXDLV = 1 Then
      # ---   Suivi texte livraison du client livré sur entete liv
      Raz [M:SDH0]SDHTEX1
    Elsif GSALTEXDLV = 2 Then
      # ---   Suivi texte livraison du client livré sur pied liv
      Raz [M:SDH0]SDHTEX2
    Endif
    If GSALTEXPRP = 1 Then
      # ---   Suivi texte préparation du client livré sur entete liv
      Raz [M:SDH0]PRPTEX1
    Elsif GSALTEXPRP = 2 Then
      Raz [M:SDH0]PRPTEX2
    Endif
  Endif
  # FGR 31/01/2014 : X3SUIVI90148 (début)

If OK = 2
   # Unlock entête commande
   If currbox=GBOXSO1
      SYMBOLE2 = "SOH"+[F:SOQ]SOHNUM
   Elsif currbox=GBOXSO2
      SYMBOLE2 = "SOC"+num$([F:SOQ]SOPLIN)+"\"+[F:SOC]SOHNUM
   Endif
   Unlock = SYMBOLE2
Endif

Return

#########################################################################
$DESEL3

Local Integer WRET
#-----------------------------------------------------------------------#
# Désélection d'un besoin de reappro d'emplacement sous-traitant        #
#-----------------------------------------------------------------------#
Raz I,J
OK = 0
If [M:SDH1]NBLIG <> 0
   While OK <> 1
      I = find([F:REO]ITMREF,[M:SDH1]ITMREF(J..[M:SDH1]NBLIG-1))
      If !I Break Endif
      If [M:SDH1]CREFLG(J+I-1)=0 & [M:SDH1]STOREOFLG(J+I-1)=1
         # Maj montants livrés ,poids et suppression des textes
         GMODIF = 1
         NOL    = J+I-1
         Call AVANT_LIGNE(NOL) From SUBSDHB

         If [M:SDH1]STOMGTCOD(NOL)<>1
            # Nettoyage de l'écran de travail STOSORW
            Call DELSTOSORW(NOL,NOL,"SDH1",[M:SDH0]STOFCY,WRET) From STKSOR
            If WRET<>0 OK=0 : Return Endif
         Endif

         Dela NOL,1,[M:SDH1]NBLIG-1 [M:SDH1]NBLIG
         [M:SDH1]NBLIG -= 1

         Raz GMESSAGE
         OK = 1
      Else
         J = J+I
      Endif
   Wend
Endif

Raz GMODIF

# Unlock besoin réappro
SYMBOLE2 = "REO"+[F:REO]STOFCY+"\"+[F:REO]LOC+"\"+[F:REO]ITMREF
Unlock = SYMBOLE2

Return

#########################################################################
$DESEL4

Local Integer WRET
#-----------------------------------------------------------------------#
# Désélection d'un manquant sous-traitant issu d'un OF ou d'un EO       #
#-----------------------------------------------------------------------#
Raz I,J
OK = 0
If [M:SDH1]NBLIG <> 0
   While OK <> 1
      I = find([F:STA]ITMREF,[M:SDH1]ITMREF(J..[M:SDH1]NBLIG-1))
      If !I Break Endif
      If [M:SDH1]CREFLG(J+I-1)=0 & [M:SDH1]STOREOFLG(J+I-1)=2
&                                & [F:STA]SEQ=[M:SDH1]SEQ(J+I-1)
         # Maj montants livrés ,poids et suppression des textes
         GMODIF = 1
         NOL    = J+I-1
         Call AVANT_LIGNE(NOL) From SUBSDHB

         If [M:SDH1]STOMGTCOD(NOL)<>1
            # Nettoyage de l'écran de travail STOSORW
            Call DELSTOSORW(NOL,NOL,"SDH1",[M:SDH0]STOFCY,WRET) From STKSOR
            If WRET<>0 OK=0 : Return Endif
         Endif

         Dela NOL,1,[M:SDH1]NBLIG-1 [M:SDH1]NBLIG
         [M:SDH1]NBLIG -= 1

         Raz GMESSAGE
         OK = 1
      Else
         J = J+I
      Endif
   Wend
Endif

Raz GMODIF

# Unlock manquant sous-traitant
SYMBOLE2 = "STA"+[F:STA]STOFCY+"\"+[F:STA]ITMREF+"\"+num$([F:STA]STOCOU)+"\"+num$([F:STA]SEQ)
Unlock = SYMBOLE2

Return

#########################################################################
$DESEL5

Local Integer WRET
Local Char    WSAVE_SOHNUM(GLONVCR) :#--CPO 93104
#-----------------------------------------------------------------------#
# Désélection d'un bon de préparation                                   #
#-----------------------------------------------------------------------#

Raz I,J
#OK = 0
If [M:SDH1]NBLIG <> 0
   While NOL < [M:SDH1]NBLIG
      I = find([F:PRH]PRHNUM,[M:SDH1]PRHNUM(J..[M:SDH1]NBLIG-1))
      If !I Break Endif
      If [M:SDH1]CREFLG(J+I-1)=0
         # Maj montants livrés ,poids et suppression des textes
         GMODIF = 1
         NOL    = J+I-1
         Call AVANT_LIGNE(NOL) From SUBSDHB
         #--CPO 79343
         If GMODIF=1 and GREP<>"C" and GSDHSUPPLIGDSP>0 and GSDHSUPPLIGDSP<>999999
           Local Integer WTEMPDSP : Raz WTEMPDSP
           Call CTLSUPP_EXISTDSP("SDH",NOL,WTEMPDSP) From TRTVENDIV
           If WTEMPDSP=1
             GSDHSUPPLIGDSP -=1
           Endif
         Endif
         #--/CPO
         If [M:SDH1]STOMGTCOD(NOL)<>1
            # Nettoyage de l'écran de travail STOSORW
            Call DELSTOSORW(NOL,NOL,"SDH1",[M:SDH0]STOFCY,WRET) From STKSOR
            If WRET<>0 OK=0 : Return Endif
         Endif
         If NOL = 0 & WORINUM <> ""
            Raz WORINUM
         Endif

         Dela NOL,1,[M:SDH1]NBLIG-1 [M:SDH1]NBLIG
         [M:SDH1]NBLIG -= 1

         Raz GMESSAGE
      Else
         J = J+I
      Endif
   Wend
Endif

#--CPO 93104
If ([M:SDH1]NBLIG>0 & sigma(0,[M:SDH1]NBLIG-1,[M:SDH1]XSOHNUM(indcum)) = "")  | [M:SDH1]NBLIG=0
  Raz YSOHNUM
  Raz [M:SDH0]ODL, [M:SDH0]IME
Endif
#--Cas du depick total d'une commande dont le numéro est dans le YSOHNUM et qu'il reste d'autres cdes
If YSOHNUM <>"" & [M:SDH1]NBLIG>0 & find(YSOHNUM,[M:SDH1]XSOHNUM(0..[M:SDH1]NBLIG-1))<1
   For IJCPO=0 To [M:SDH1]NBLIG-1
      If [M:SDH1]XSOHNUM(IJCPO) <> ""
         YSOHNUM = [M:SDH1]XSOHNUM(IJCPO)
         #--Alimenter les ODL et IME depuis la commande retenue
         Raz WSAVE_SOHNUM
         If [F:SOH]SOHNUM<>YSOHNUM
           WSAVE_SOHNUM = [F:SOH]SOHNUM
           Read [F:SOH]SOH0=YSOHNUM
           If fstat : Raz [F:SOH] : Endif
         Endif
         If [F:SOH]SOHNUM<>""
           [M:SDH0]ODL = [F:SOH]ODL
           [M:SDH0]IME = [F:SOH]IME
         Endif
         If WSAVE_SOHNUM<>"" and [F:SOH]SOHNUM<>WSAVE_SOHNUM
           Read [F:SOH]SOH0=WSAVE_SOHNUM
           If fstat : Raz [F:SOH] : Endif
         Endif
         Break
      Endif
   Next I
Endif
#--/

Raz GMODIF

# Unlock bon de préparation
SYMBOLE3 = "PRH"+[F:PRH]PRHNUM
Unlock = SYMBOLE3

Return

# X3-1152 : Non invoiceable deliveries
$DESEL6
Local Integer WRET
#-----------------------------------------------------------------------#
# Deselection of the a nonbillable task                                 #
#-----------------------------------------------------------------------#
Raz I
OK = 0

If [M:SDH1]NBLIG <> 0
   For I=0 To [M:SDH1]NBLIG-1
     NOL=I
     If [M:SDH1]DPJT(I)=[F:JTT]OPPNUM+"!"+[F:JTT]TASCOD & [M:SDH1]VCRLINORI(I)=[F:JTT]ITTSEQ
        If [M:SDH1]CREFLG(I)=0
         # Maj montants livrés ,poids et suppression des textes
         GMODIF = 1
         Call AVANT_LIGNE(NOL) From SUBSDHB
         If [M:SDH1]STOMGTCOD(NOL)<>1
            # Nettoyage de l'écran de travail STOSORW
            Call DELSTOSORW(NOL,NOL,"SDH1",[M:SDH0]STOFCY,WRET) From STKSOR
            If WRET<>0 OK=0 : Return Endif
         Endif

         Dela NOL,1,[M:SDH1]NBLIG-1 [M:SDH1]NBLIG
         [M:SDH1]NBLIG -= 1
         OK=1
         Raz GMESSAGE
         Break
        Endif
     Endif
   Next
 Endif

Raz GMODIF

# Unlock task
SYMBOLE2 = "JTT"+[F:JTT]OPPNUM+"\"+[F:JTT]TASCOD+"\"+num$([F:JTT]ITTSEQ)
Unlock = SYMBOLE2
Return
# X3-1152 : Non invoiceable deliveries


#########################################################################
#-----------------------------------------------------------------------#
# Contrôle du bon de prépa sélectionné                                  #
# Il doit être cohérent par rapport aux autres bons sélectionnés        #
#-----------------------------------------------------------------------#
$CTL_PRH
Local Integer I
Local Char SWPJTMSG(250)  # FGR 15/12/2011 : X3SUIVI71065

#-----------------------------------------#
#  Contrôle des critéres de regroupement  #
#-----------------------------------------#
If [F:PRH]BPCORD<>[M]BPCORD | [F:PRH]BPAADD<>[M]BPAADD
   OK=0 : GERR=1 : GMESSAGE=[F:PRH]PRHNUM+"\"+mess(342,192,1)+"\"+mess(102,192,1)
   Return
Endif

#--- Bug 70801
If find([F:PRH]ORIPRH,1,2)
   For [PRE]PRE0 Where [F:PRE]PRHNUM=[F:PRH]PRHNUM & [F:PRE]FLGANN=0
      Read [F:SOH]SOH0=[F:PRE]ORINUM
      # Issue 114429 - 2016-02-29 by CPO : Different delivery address on order line and picking tickets
      #--In this case, the BPDNAM has to be read according to the SOQ record
      #If !fstat & [F:SOH]BPDNAM(0)<>"" & [F:SOH]BPDNAM(0)<>[M]BPDNAM
      #   OK=0 : GERR=1
      #   GMESSAGE=[F:PRH]PRHNUM+"\"+mess(342,192,1)+"\"+mess(102,192,1)
      #   Break  : # 85826
      #Endif
      If fstat>0
        OK=0 : GERR=1
        Call RSTA("SOH",[F:PRE]ORINUM) From GLOCK
        Break
      Endif
      # End issue 114429

      # LTA.sn 79065
      # If !fstat & func AFNC.ACTIV("LTA") & GLOCUSATAX & [M:SDH1]NBLIG>0 & [F:SOH]SSTENTCOD<>[M:SDH2]SSTENTCOD   # 106867.o
      If !fstat & func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 & [M:SDH1]NBLIG>0 & [F:SOH]SSTENTCOD<>[M:SDH2]SSTENTCOD   # 106867.n
        OK=0 : GERR=1
        GMESSAGE=func AFNC.MES2(mess(374,192,1), [F:SOH]SOHNUM, [F:SOH]SSTENTCOD)
        #Return : # 85826
        Break   : # 85826
      Endif
      # LTA.en 79065

      #--CPO 71065 - Code affaire à la ligne (Partie : rajout paramètre société pour contrôle documents mono-affaire)
      #--Contrôles sur le code affaire de la commande à l'origine du bon de préparation
      If !fstat
        # FGR 15/12/2011 : X3SUIVI71065 (début)
        If func TRTPJT.IS_PJT_AVAILABLE([F:SOH]PJT, "[M:SDH2]PJT", SWPJTMSG) = G_NON Then
          Call PJT_ADD_MSG([F:SOH]PJT, SWPJTMSG) From TRTPJT
          OK = 0 : GERR = 1
          #Return : # 85826
          Break   : # 85826
        Endif
        # FGR 15/12/2011 : X3SUIVI71065 (fin)
      Endif
      #--/CPO

      # -------------------------------------
      # FGR 13/01/2014 : X3SUIVI94287 (début)
      Read [SOQ]SOQ0=[F:PRE]ORINUM;[F:PRE]ORILIN;[F:PRE]ORISEQ
      If [F:SOH]SOHCAT=4 Then
        Read [SOC]SOC0=[F:PRE]ORINUM;[F:PRE]ORILIN
      Else
        If clalev([F:SOC]) Then
          Raz [F:SOC]
        Endif
      Endif
      Gosub CTL_CDE_OR_PRH
      If OK = 0 Then
        Break
      Endif
      # FGR 13/01/2014 : X3SUIVI94287 (fin)
      # -------------------------------------
      #Break             : # 85826
   Next
   If OK=0 Return Endif  : # 85826

Endif
#---
Return
#########################################################################
#-------------------------------------------------------------------------#
# Contrôle de la ligne commande sélectionnée                              #
# Elle doit être cohérente par rapport aux autres cdes sélectionnées      #
#-------------------------------------------------------------------------#
$CTL_CDE
Local Integer I
For I=0 To [M]NBLIG-1
   If [F:SOQ]SOHNUM=[M]XSOHNUM(I) & [F:SOQ]SOPLIN=[M]SOPLIN(I) &
&     [F:SOQ]SOQSEQ=[M]SOQSEQ(I) & [M]CREFLG(I)=0
      OK=0 : GERR=1
      GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&              format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(145,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
      Break
   Endif
Next I
If OK=0 Return Endif

#-----------------------------------------#
#  Contrôle des critéres de regroupement  #
#-----------------------------------------#
$CTL_CDE_OR_PRH    # FGR 13/01/2014 : X3SUIVI94287

If [F:SOH]BPCORD<>[M]BPCORD | [F:SOQ]BPAADD<>[M]BPAADD |
&  [F:SOH]BPCINV<>[M]BPCINV | ([M]BPCPYR<>"" & [F:SOH]BPCPYR<>[M]BPCPYR) |
&  ([M]BPCGRU<>"" & [F:SOH]BPCGRU<>[M]BPCGRU) | [F:SOH]BETFCY<>[M]BETFCY |
&  [F:SOH]BETCPY<>[M]BETCPY
   OK=0 : GERR=1
   GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-format$(GFMDAT,[F:SOQ]SHIDAT)
&           +"\"+mess(101,192,1)+"\"+mess(102,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
   Return
Endif
# Livraison inter-site
If [M]BETFCY=2
    # Pas de cdes créés manuellement avec des cdes créés automatiquement ou une livraison directe
    If [F:SOH]ORIFCY=[F:SOH]SALFCY & [M]ORIFCY<>[M]SALFCY
        OK=0 : GERR=1
        GMESSAGE=[F:SOH]SOHNUM-":"-mess(27,159,1)-":"-[F:SOQ]ITMREF-format$(GFMDAT,[F:SOQ]SHIDAT)
&           +"\"+mess(171,191,1)+":\"+mess(172,191,1)-mess(182,191,1) :#--CPO 83985 GFMDAT au lieu de GFMD
        Return
    Endif
    # Pas de cdes créés automatiquement avec des cdes créés manuellement
    If [F:SOH]ORIFCY<>[F:SOH]SALFCY & [M]ORIFCY=[M]SALFCY
        OK=0 : GERR=1
        GMESSAGE=[F:SOH]SOHNUM-":"-mess(27,159,1)-":"-[F:SOQ]ITMREF-format$(GFMDAT,[F:SOQ]SHIDAT)
&           +"\"+mess(177,191,1)+":\"+mess(178,191,1) :#--CPO 83985 GFMDAT au lieu de GFMD
        Return
    Endif
Endif
If [F:SOH]SALFCY<>[M]SALFCY
   OK=0 : GERR=1
   GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&           format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(101,192,1)+"\"+mess(103,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
   Return
Endif
# Bug 53724 : Ne pas mettre des lignes de commandes avec des sites d'expédition différents
If [F:SOQ]STOFCY<>[M]STOFCY
   OK=0 : GERR=1
   GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&           format$(GFMDAT,[F:SOQ]SHIDAT)-mess(498,197,1)-[F:SOP]STOFCY-"\"+mess(334,192,1)+"\"+mess(333,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
   Return
Endif
If [F:SOH]PLISTC<>[M]PLISTC
   OK=0 : GERR=1
   GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&           format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(101,192,1)+"\"+mess(305,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
   Return
Endif
If [F:SOH]CUR<>[M]CUR | [F:SOH]PTE<>[M]PTE | ([M]DEP<>"" & [F:SOH]DEP<>[M]DEP)
   OK=0 : GERR=1
   GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&           format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(101,192,1)+"\"+mess(104,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
   Return
Endif
If (([F:SOH]SOHCAT<>4 & [F:SOH]VACBPR<>[M]VACBPR) | ([F:SOH]SOHCAT=4 & [F:SOC]VACBPR<>[M]VACBPR)) |
&    [F:SOH]PRITYP<>[M]PRITYP
   OK=0 : GERR=1
   GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&           format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(101,192,1)+"\"+mess(105,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
   Return
Endif

# LTA.sn 79065
# If func AFNC.ACTIV("LTA") & GLOCUSATAX & [M:SDH1]NBLIG>0 & [F:SOH]SSTENTCOD<>[M:SDH2]SSTENTCOD   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 & [M:SDH1]NBLIG>0 & [F:SOH]SSTENTCOD<>[M:SDH2]SSTENTCOD   # 106867.n
  OK=0 : GERR=1
  GMESSAGE=func AFNC.MES2(mess(374,192,1), [F:SOH]SOHNUM, [F:SOH]SSTENTCOD)
  Return
Endif
# LTA.en 79065

#--- CPO 72237 Le champ BPIEECNUM est soumis à code activité, par contre le EECICT non
#If ([F:SOH]SOHCAT<>4 & ([F:SOH]BPIEECNUM<>[M]BPIEECNUM | [F:SOH]EECICT<>[M]EECICT)) |
#&  ([F:SOH]SOHCAT=4  & ([F:SOC]BPIEECNUM<>[M]BPIEECNUM | [F:SOC]EECICT<>[M]EECICT))
#   GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
#&           format$(GFMD,[F:SOQ]SHIDAT)+"\"+mess(101,192,1)+"\"+mess(303,192,1)
#   OK=0 : GERR=1 : Return
#Endif

#--CPO 87919 Cas de la ligne de cde ayant l'adresse de livraison différente de l'en-tête
#--Explication du : find([F:SOQ]SOHNUM,[M]XSOHNUM(0..[M]NBLIG-1))<1
#--1) Si une des lignes de cette même cde a déjà été pickée => soit le contrôle était OK,
#--soit c'est la première ligne de la cde pickée qui ré-initialise les infos => plus besoin de ce ctrl
#--Explication du : [F:SOC ou SOH]BPAADD=[F:SOQ]BPAADD
#--2) S'il n'y a pas de lignes de cette cde encore pickées sur la livraison :
#--si l'adresse de livr de la ligne de cde est différente de l'en-tête de la cde
#--et est forcèment égale à l'en-tête de la livraison (filtre sur listes gauches...),
#--nous sommes dans le même cas que 1)
#--si l'adresse de livr de la ligne de cde est identique à celle en-tête cde, il faut faire le test de cohérence
If find([F:SOQ]SOHNUM,[M]XSOHNUM(0..[M]NBLIG-1))<1
& & (   [F:SOQ]BPAADD=[M]BPAADD
& &  ( ([F:SOH]SOHCAT =4 & [F:SOC]BPAADD=[F:SOQ]BPAADD)
&  |([F:SOH]SOHCAT<>4 & [F:SOH]BPAADD=[F:SOQ]BPAADD)))
#--/CPO
  #--- CPO 72237 Le champ BPIEECNUM est soumis à code activité, par contre le EECICT non
  If dim([M]BPIEECNUM)>0 &(([F:SOH]SOHCAT<>4 & [F:SOH]BPIEECNUM<>[M]BPIEECNUM) |
&       ([F:SOH]SOHCAT=4  & [F:SOC]BPIEECNUM<>[M]BPIEECNUM))
     GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&           format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(101,192,1)+"\"+mess(303,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
     OK=0 : GERR=1 : Return
  Endif
  If ([F:SOH]SOHCAT<>4 & ([F:SOH]EECICT<>[M]EECICT)) |
&    ([F:SOH]SOHCAT=4  & ([F:SOC]EECICT<>[M]EECICT))
     GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&           format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(101,192,1)+"\"+mess(303,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
     OK=0 : GERR=1 : Return
  Endif
  #---
  If dim([M]EECLOC)>0 & (([F:SOH]SOHCAT<>4 & [F:SOH]EECLOC<>[M]EECLOC) | ([F:SOH]SOHCAT=4 & [F:SOC]EECLOC<>[M]EECLOC))
     GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&           format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(101,192,1)+"\"+mess(304,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
     OK=0 : GERR=1 : Return
  Endif
Endif :#--CPO 87919

# 71065 : PJT
#If [F:SOH]PJT<>[M]PJT
#   OK=0 : GERR=1
#   GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
#&           format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(101,192,1)+"\"+mess(107,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
#   Return
#Endif
# 71065 : PJT

# FGR 15/12/2011 : X3SUIVI71065 (début)
Local Char SWPJTMSG(250)

If func TRTPJT.IS_PJT_AVAILABLE([F:SOQ]PJT, "[M:SDH1]DPJT", SWPJTMSG) = G_NON Then
  Call PJT_ADD_MSG([F:SOQ]PJT, SWPJTMSG) From TRTPJT
  OK = 0
  Return
Endif
# FGR 15/12/2011 : X3SUIVI71065 (fin)

If dim([M]LNDRTNDAT) > 0
    If [M]LND = 2 & [F:SOH]LNDRTNDAT<>[M]LNDRTNDAT
       OK=0 : GERR=1
       GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&               format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(101,192,1)+"\"+mess(106,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
       Return
    Endif
Endif

# Dde de confirmation si transporteur ou mode de livraison sont différent
If ([F:SOQ]BPTNUM<>"" & [F:SOQ]BPTNUM<>[M]BPTNUM) | ([F:SOQ]MDL<>"" & [F:SOQ]MDL<>[M]MDL)
    GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&            format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(101,192,1)+"\"+mess(135,191,1) :#--CPO 83985 GFMDAT au lieu de GFMD
    Call AVERTIR(GMESSAGE,OK) From GESECRAN
    If OK=1 OK=0 : Raz GMESSAGE : GERR=1 : Return : Endif
Endif
#----------------------------------#
# Contrôle des liens cde/liv/fac   #
#----------------------------------#
# 1 facture/commande(soldée) ou 1 commande/BL
If YSOHNUM<>"" &
&  ((([F:SOH]IME=2 | [F:SOH]IME=3  | [F:SOH]ODL=2)  & [F:SOH]SOHNUM<>YSOHNUM) |
&  (([M:SDH0]IME=2 | [M:SDH0]IME=3 | [M:SDH0]ODL=2) & [F:SOH]SOHNUM<>YSOHNUM))
   OK=0 : GERR=1
   GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&           format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(55,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
   Return
Endif

# Controle du champ GRUFLG :
# Si Oui (1), pas de restriction
#  Sinon (2), vérifier que les éléments en % ont la meme valeur
Local Integer I2
Local Decimal DTAAMTCMP
Local Char    TSTRUL
#--CPO 107663
For I=0 To dim([F:SOH]INVDTA) - 1
    If [F:SOH]INVDTA(I) = 0 : Break : Endif
    If [F:SOH]INVDTATYP(I) = 3 : # %
        # Recherche Param concernant Doc Ori et Dest
        TSTRUL = num$([F:SOH]INVDTA(I)) + "~10~2"
        I2=find(TSTRUL, [M:SFIT]T_TST_RUL(0..[M:SFIT]NBSFIT-1))-1

        If I2>=0 and [M:SFIT]T_GRUFLG(I2) = 2 : # non si diff  # FGR 22/01/2015 : X3SUIVI105274 manque I2>0
            If [M:SFIT]T_BRDRUL(I2)=2 and [F:SOH]DLVSTA<>1 : # eclaté sur 1ere comm et deja partiellement ou totalement livrée
                DTAAMTCMP=0
            Else
                DTAAMTCMP=[F:SOH]INVDTAAMT(I)
            Endif
            I2 = find ( [F:SOH]INVDTA(I) , [M:SDH2]INVDTA(0..[M:SDH2]NBFAC-1))
            If I2>0 and [M:SDH2]INVDTAAMT(I2-1) <> DTAAMTCMP
                OK=0 : GERR=1
                # Pour cet élément de facturation, le regroupement avec des valeurs différentes est interdit (xxx)"
                Local Char SHOAXX
                Call LECTEXTRA([L]SHOAXX,"SFOOTINV","SHOAXX",num$([F:SOH]INVDTA(I)),"") From ATEXTRA
                GMESSAGE = mess(327,192,1) + " (" + SHOAXX+ ")"
                Break
            Endif
        Endif
    Endif
Next I
#--/

# ACA - Controle des codes adresses client commande et facture
# Issue 66151 - 2010-07-21 by ACA : We don't check address when inter-site (no invoice)
If [F:SOH]BPAINV<>[M:ADB3]BPAADD and ([F:SOH]BETFCY=1 or [F:SOH]BETCPY=2)
    OK=0 : GERR=1
    GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&       format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(101,192,1)+"\"+mess(329,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
    Return
Endif

# 71048 - Contrôle des raisons sociales des clients livrés et des clients facturés
# 73365 - Cas des cdes ouvertes ou les champs peuvent ne pas être renseignés (test si <>"")
#--CPO xxxxx Ne pas utiliser les [M:ADBx] car pas chargées si rien sur [F:SDH] (cause GACTSAD=1)
#--CPO 88262 Regroupement commandes en livraisons adr différentes (complément)
#--Vu lors de la correction du 87919
#--le VALTTC appelé en FIN_PICK fait un raz [f:sdh], du coup le [f:sdh]BPxNAM(0) sont "" => pas de contrôle
#--Il faut passer par le [M:SDH0]BPxNAM(0) et [M:ADBx]BPRNAM(1) (et si "" => lire [BPR] pour BPINAM(1) et [BPD] pour BPDNAM(1)
#If (([F:SOH]BPDNAM(0)<>"" & [F:SOH]BPDNAM(0)<>[M:ADB2]BPRNAM(0))  or
#&   ([F:SOH]BPDNAM(1)<>"" & [F:SOH]BPDNAM(1)<>[M:ADB2]BPRNAM(1))) or
#&  (([F:SOH]BPINAM(0)<>"" & [F:SOH]BPINAM(0)<>[M:ADB3]BPRNAM(0))  or
#&   ([F:SOH]BPINAM(1)<>"" & [F:SOH]BPINAM(1)<>[M:ADB3]BPRNAM(1)))
#    OK=0 : GERR=1
#    GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
#&       format$(GFMD,[F:SOQ]SHIDAT)+"\"+mess(101,192,1)+"\"+ mess(351,192,1)
#    Return
#Endif
Gosub CTL_BPNAM
#--/CPO

#--CPO 75115 Nouveau champ SDHTYP
#--Contrôle que le type de livraison de la cde est le même que celui de la livraison
If [F:SOH]SDHTYP<>"" & [F:SOH]SDHTYP<>[M]SDHTYP
  OK=0 : GERR=1
  GMESSAGE=[F:SOH]SOHNUM+"\"+mess(101,192,1)+"\"+mess(362,192,1)-[F:SOH]SDHTYP
  Return
Endif

Return

#--------------------------------------------------------------------------------#
# Contrôle de la ligne commande sélectionnée                                     #
# Elle doit être livrable                                                        #
#--------------------------------------------------------------------------------#
$CTL_CDE_LIG

# Ligne gérée en contremarque et commande d'achat non générée
If currbox=GBOXSO1 & [F:SOQ]FMI>1 & [F:SOQ]FMI<4 & [F:SOQ]FMINUM=""
   If [F:SOQ]ALLQTY=0
       OK=0 : GERR=1
       GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&               format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(111,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
       Return
   Else
       WOK=1
       Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&              format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(160,197,1)+"\"+mess(146,191,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
       If WOK=1 OK=0 : Return Endif
   Endif
Endif
# Ligne gérée en contremarque réceptionnée et pas de quantité allouée
If currbox=GBOXSO1 & [F:SOQ]FMI=3 & [F:SOQ]ALLQTY=0 & [F:SOQ]STOMGTCOD>1
   WOK=1
   Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&              format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(65,192,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
   If WOK=1 OK=0 : Return Endif
Endif
# Ligne gérée avec un ordre de production et OF non généré
If currbox=GBOXSO1 & [F:SOQ]FMI=5 & [F:SOQ]FMINUM=""
   If [F:SOQ]ALLQTY=0
       OK=0 : GERR=1
       GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&               format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(138,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
       Return
   Else
       WOK=1
       Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&              format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(201,197,1)+"\"+mess(146,191,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
       If WOK=1 OK=0 : Return Endif
   Endif
Endif
# Ligne gérée avec un ordre de production et pas de quantité allouée
If currbox=GBOXSO1 & [F:SOQ]FMI=5 & [F:SOQ]ALLQTY=0
   WOK=1
   Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&              format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(124,192,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
   If WOK=1 OK=0 : Return Endif
Endif
# Si livraison (ligne) cde complète et ligne cde non allouée totalement
#If [F:SOH]DME>1 & (WQTY+[F:SOQ]ODLQTY+[F:SOQ]DLVQTY < [F:SOQ]QTY)
#   WOK=1
#   Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
#&              format$(GFMD,[F:SOQ]SHIDAT)+"\"+mess(57,192,1),WOK) From GESECRAN
#   If WOK=1 OK=0 : Return Endif
#Endif

Return

#########################################################################
$LEC_TABART
#-----------------------------------------------------------------------#
# Lecture des tables articles                                           #
#-----------------------------------------------------------------------#
Local Char WITMREF(GLONITM)
Local Char WBPCORD(GLONBPC)

#--CPO 81442 28.05.2013 Suite annulation correction précedante par TS (bug 89918)
#Case currbox
# When GBOXSC1 : WITMREF = [F:STA]ITMREF
#                WBPCORD = [F:STA]BPRNUM
# When GBOXRE1 : WITMREF = [F:REO]ITMREF
#                WBPCORD = [F:REO]BPRNUM
# When Default : WITMREF = [F:SOQ]ITMREF
#                WBPCORD = [F:SOH]BPCORD
#Endcase
Case currbox
 When GBOXSO1,GBOXSO2: WITMREF = [F:SOQ]ITMREF
                       WBPCORD = [F:SOH]BPCORD
 When GBOXSC1 :        WITMREF = [F:STA]ITMREF
                       WBPCORD = [F:STA]BPRNUM
 When GBOXRE1 :        WITMREF = [F:REO]ITMREF
                       WBPCORD = [F:REO]BPRNUM
 When GBOXPH1 :        WITMREF = [F:PRE]ITMREF
                       WBPCORD = [F:PRH]BPCORD
 When GBOXPJ5 :        WITMREF = [F:JTT]ITMREF   # X3-1152 : Non invoiceable deliveries
                       WBPCORD = [F:OPP]OPPCMP   # X3-1152 : Non invoiceable deliveries

 When Default :
Endcase
#--/

If [F:ITM]ITMREF <> WITMREF
   Read [ITM]ITM0=WITMREF
   If fstat Raz [F:ITM] Endif
Endif
If [F:ITS]ITMREF <> WITMREF
   Read [ITS]ITS0 = WITMREF
   If fstat Raz [F:ITS] Endif
Endif
If ([F:ITU]ITMREF <> WITMREF) | ([F:ITU]BPCNUM <> WBPCORD)
   Read [F:ITU]ITU0 = WITMREF;WBPCORD
   If fstat Raz [F:ITU] Endif
Endif
Return
#########################################################################
$RAFFRAICHI
#-----------------------------------------------------------------------#
# Raffraichissement des listes de picking pour les lignes déjà saisies  #
#-----------------------------------------------------------------------#
Case currbox
 When GBOXSO2 : If sum([M:SDH1]SOQSEQ)<>0
                   For I=0 To [M:SDH1]NBLIG-1
                      # Ligne issue d'un picking commande ouverte réalisée au cours de cette transaction
                      If [M:SDH1]XSOHNUM(I)<>"" & [M:SDH1]SOHCAT(I)=4 & [M:SDH1]CREFLG(I)=0 & !find([M:SDH1]LINTYP(I),3,4,5,11,12,13)
                          Read [SOQ]SOQ0=[M:SDH1]XSOHNUM(I);[M:SDH1]SOPLIN(I);[M:SDH1]SOQSEQ(I)
                          If    WPICK=1 Gosub DEPICK From GOBJSUB
                          Elsif WPICK=2 Gosub REPICK From GOBJSUB
                          Endif
                      Endif
                   Next I
                Endif
 When GBOXSO1 : If sum([M:SDH1]SOQSEQ)<>0
                   For I=0 To [M:SDH1]NBLIG-1
                      # Ligne issue d'un picking commande réalisée au cours de cette transaction
                      If [M:SDH1]XSOHNUM(I)<>"" & [M:SDH1]SOHCAT(I)<>4 & [M:SDH1]CREFLG(I)=0 & !find([M:SDH1]LINTYP(I),3,4,5,11,12,13)
                          Read [SOP]SOP0=[M:SDH1]XSOHNUM(I);[M:SDH1]SOPLIN(I);[M:SDH1]SOQSEQ(I)
                          If    WPICK=1 Gosub DEPICK From GOBJSUB
                          Elsif WPICK=2 Gosub REPICK From GOBJSUB
                          Endif
                      Endif
                   Next I
                Endif
 When GBOXRE1 : If sum([M:SDH1]SOQSEQ)<>0
                   For I=0 To [M:SDH1]NBLIG-1
                      # Ligne issue d'un picking besoin réappro réalisé au cours de cette transaction
                      If [M:SDH1]STOREOFLG(I)=1 & [M:SDH1]CREFLG(I)=0
                          If dim([M:SDH3]BPCLOC)>0
                              Read [REO]REO0=[M:SDH0]STOFCY;[M:SDH1]ITMREF(I);[M:SDH3]BPCLOC
                          Else
                              Read [REO]REO0=[M:SDH0]STOFCY;[M:SDH1]ITMREF(I)
                          Endif
                          If    WPICK=1 Gosub DEPICK From GOBJSUB
                          Elsif WPICK=2 Gosub REPICK From GOBJSUB
                          Endif
                      Endif
                   Next I
                Endif
 When GBOXSC1 :  If sum([M:SDH1]SOQSEQ)<>0
                   For I=0 To [M:SDH1]NBLIG-1
                      # Ligne issue d'un picking manquant sous-traitant réalisé au cours de cette transaction
                      If [M:SDH1]STOREOFLG(I)=2 & [M:SDH1]CREFLG(I)=0
                          Read [STA]STA0=[M:SDH0]STOFCY;[M:SDH1]ITMREF(I);0;[M:SDH1]SEQ(I)
                          If    WPICK=1 Gosub DEPICK From GOBJSUB
                          Elsif WPICK=2 Gosub REPICK From GOBJSUB
                          Endif
                      Endif
                   Next I
                Endif
#MAE, LIV_BP
 When GBOXPH1 : If sum([M:SDH1]SOQSEQ)<>0

                   For I=0 To [M:SDH1]NBLIG-1
                      # Ligne issue d'un picking manquant sous-traitant réalisé au cours de cette transaction
                      If [M:SDH1]PRHNUM(I)<>"" & [M:SDH1]CREFLG(I)=0
                          Read [PRH]PRH0=[M:SDH1]PRHNUM(I)
                          If    WPICK=1 Gosub DEPICK From GOBJSUB
                          Elsif WPICK=2 Gosub REPICK From GOBJSUB
                          Endif
                      Endif
                   Next I
                Endif
 When Default
Endcase
Return
#########################################################################
$RAFFRAICHISVG
#-----------------------------------------------------------------------#
# Raffraichissement des listes de picking pour les lignes déjà saisies  #
#-----------------------------------------------------------------------#
If sum([M:SDH1]SOQSEQ) <> 0
   For I=0 To [M:SDH1]NBLIG-1
      # La ligne est issue d'un picking commande réalisé au cours de cette transaction
      If [M:SDH1]XSOHNUM(I)<>"" & [M:SDH1]CREFLG(I)=0 & !find([M:SDH1]LINTYP(I),3,4,5,11,12,13)
         Case currbox
          When GBOXSO1 : Read [SOP]SOP0=[M:SDH1]XSOHNUM(I);[M:SDH1]SOPLIN(I);[M:SDH1]SOQSEQ(I)
          When GBOXSO2 : Read [SOQ]SOQ0=[M:SDH1]XSOHNUM(I);[M:SDH1]SOPLIN(I);[M:SDH1]SOQSEQ(I)
          When Default
         Endcase
         If    WPICK=1 Gosub DEPICK From GOBJSUB
         Elsif WPICK=2 Gosub REPICK From GOBJSUB
         Endif
      # La ligne est issue d'un picking besoin réappro réalisé au cours de cette transaction
      Elsif [M:SDH1]STOREOFLG(I) <> 0 & [M:SDH1]CREFLG(I) = 0
         Case currbox
          When GBOXRE1 : If dim([M:SDH3]BPCLOC)>0
                             Read [REO]REO0=[M:SDH0]STOFCY;[M:SDH1]ITMREF(I);[M:SDH3]BPCLOC
                         Else
                             Read [REO]REO0=[M:SDH0]STOFCY;[M:SDH1]ITMREF(I)
                         Endif
          When Default
         Endcase
         If    WPICK=1 Gosub DEPICK From GOBJSUB
         Elsif WPICK=2 Gosub REPICK From GOBJSUB
         Endif
      Endif
   Next I
Endif
Return

###########################################################################
# TRT_LIGCDE    Détermination de la quantité à livrer                     #
#               et alimentation de la ligne de livraison                  #
#-------------------------------------------------------------------------#
# Utilisation : picking de commandes depuis la gestion livraison          #
#               bouton livraison     depuis la gestion commandes          #
###########################################################################

$TRT_LIGCDE
Local Integer WRUP          : # Génération des ruptures (0=non / 1=oui)
Local Integer WRET
Local Integer WSTA, WA, WQ, WR
Local Integer WSTOSEQ
Local Decimal WQTY, WQTYSTU, WSTUDIS, WQTYARR, WQTA
Local Decimal WQTYCPE, WQTYSTUCPE, WCOECPE, WQTYDLVCPE
Local Char    WSAU(GLONUOM)
Local Decimal WSAUSTUCOE
Local Decimal WOALQTYSTU    : # Qté allouée origine en US
Local Decimal WOALQTYCPE    : # Qté allouée origine du composé en US
Local Decimal WSVGQTYSTU
Local Integer WNEGSTO

WNEGSTO = [F:ITM]NEGSTO

GPOINT = "TRT_LIGCDE" : Gosub ENTREE From EXEFNC

If currbox=GBOXSO1
   WSAUSTUCOE = [F:SOP]SAUSTUCOE
   WSAU       = [F:SOP]SAU
Else
   WSAUSTUCOE = [F:SOC]SAUSTUCOE
   WSAU       = [F:SOC]SAU
Endif
If WSAUSTUCOE=0 WSAUSTUCOE=1 Endif

#----------------------------------------
# Détermination de la quantité à livrer
#----------------------------------------
# Qté livrée = qté restant à livrer sauf
# si article géré en stock ou article non géré en stock et quantité allouée <> 0
WQTY    = [F:SOQ]QTY - ([F:SOQ]ODLQTY+[F:SOQ]DLVQTY)
WQTYSTU = [F:SOQ]QTYSTU - ([F:SOQ]ODLQTYSTU+[F:SOQ]DLVQTYSTU)

# Si article non géré en stock et non composé d'un kit/sous-traité
If [F:SOQ]STOMGTCOD=1 & (currbox=GBOXSO2 | (currbox=GBOXSO1 & !find([F:SOP]LINTYP,2,10)))
   If [F:SOQ]TDLQTY<>0
      WQTY    = [F:SOQ]TDLQTY
      WQTYSTU = [F:SOQ]TDLQTYSTU
   Endif
Endif

Raz WRUP
# Article géré en stock ou composé de kit/sous-traité
# Détermination de la quantité théorique à livrer
If [F:SOQ]STOMGTCOD<>1 | (currbox=GBOXSO1 & find([F:SOP]LINTYP,2,10))
   # Si qté allouée
   If [F:SOQ]ALLQTY<>0
      WQTY    = [F:SOQ]ALLQTY
      WQTYSTU = [F:SOQ]ALLQTYSTU
      # Si livraison classique (ni prêt, ni sous-traitance) et
      # si qté rupture, stock négatif autorisé et livraison des ruptures
      If (dim([M:SDH0]SCO)<0 | dim([M:SDH0]SCO)>0 & [M:SDH0]SCO<>2) & [M:SDH0]LND <>2
         # Si qté rupture
         If [F:SOQ]SHTQTY <>0
            #If WNEGSTO=2 & GSHTDLV=2
            If (WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3
               WQTY    += [F:SOQ]SHTQTY
               WQTYSTU += [F:SOQ]SHTQTYSTU
               WRUP  = 1
            Else
               Call MESSAGE(mess(323,192,1)) From GESECRAN
            Endif
         # Sinon si stock négatif autorisé et livraison des ruptures,
         # on génèrera une rupture si nécessaire
         #Elsif WNEGSTO=2 & GSHTDLV=2
         Elsif (WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3
            WRUP=1
         Endif
      Endif
   # Sinon si livraison classique (ni prêt, ni sous-traitance)
   Elsif (dim([M:SDH0]SCO)<0 | dim([M:SDH0]SCO)>0 & [M:SDH0]SCO<>2) & [M:SDH0]LND <>2
      # Si qté rupture
      If [F:SOQ]SHTQTY<>0
         # Si stock négatif autorisé et livraison des ruptures
         #If WNEGSTO=2 & GSHTDLV=2
         If (WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3
            WQTY    = [F:SOQ]SHTQTY
            WQTYSTU = [F:SOQ]SHTQTYSTU
            WRUP = 1
         Endif
      # Sinon si stock négatif autorisé et livraison des ruptures,
      # on génèrera une rupture si nécessaire
      #Elsif WNEGSTO=2 & GSHTDLV=2
      Elsif (WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3
         WRUP=1
      Endif
   Endif

   # Si livraison (ligne) cde complète et ligne cde non allouée totalement
   If [F:SOH]DME>1 & (WQTY+[F:SOQ]OPRQTY+[F:SOQ]PREQTY+[F:SOQ]ODLQTY+[F:SOQ]DLVQTY < [F:SOQ]QTY)
      WOK=1
      If [F:SOQ]ODLQTY+[F:SOQ]DLVQTY<>0
          Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-":"-[F:SOQ]ITMREF-mess(184,197,1)-":"-
&                     format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(57,192,1)-"\"-mess(146,191,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
      Else
          Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-":"-[F:SOQ]ITMREF-mess(184,197,1)-":"-
&                     format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(297,192,1)-"\"-mess(146,191,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
      Endif
      If WOK=1
         OK=0 : Return
      Endif
   Endif

   #---------------------------------------------
   # TS : réajustement qté en unité vente entière
   #---------------------------------------------
   Gosub REAJUSTE_QTY

   # Bug 29257
   WSVGQTYSTU = WQTYSTU

   # Dem 36237
   If WNEGSTO=2
      GPOINT = "ALI_NEGSTO" : Gosub ENTREE From EXEFNC
   Endif

   # Si article géré en stock (composé de kit ou non)
   # Détermination de la quantité réellement livrable
   If [F:SOQ]STOMGTCOD<>1
      # Si allocation détaillée et qté allouée<>0 ou qté rupture livrable
      If [F:SOQ]ALLTYP=2 &
&       ([F:SOQ]ALLQTY<>0 | ([F:SOQ]SHTQTY<>0 & ((WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3)))
#&       ([F:SOQ]ALLQTY<>0 | ([F:SOQ]SHTQTY<>0 & WNEGSTO=2 & GSHTDLV=2))
         # Chargement STOSORW à partir des allocations
         [M:ALP]TRSTYP    = [M:SDH0]TRSTYP
         [M:ALP]TRSCOD    = [M:SDH0]TRSCOD
         [M:ALP]VCRTYP    = 2
         [M:ALP]VCRNUM    = [F:SOQ]SOHNUM
         [M:ALP]VCRLIN    = [F:SOQ]SOPLIN
         [M:ALP]VCRSEQ    = [F:SOQ]SOQSEQ
         [M:ALP]STOFCY    = [M:SDH0]STOFCY
         [M:ALP]ITMREF    = [F:SOQ]ITMREF
         # --------------------------------------
         # FGR 21/04/2015 : X3SUIVI105605 (début)
         If func AFNC.ACTIV("ECC") Then
           [M:ALP]ECCVALMAJ    = [F:SOQ]ECCVALMAJ
         Endif
         # FGR 21/04/2015 : X3SUIVI105605 (fin)
         # --------------------------------------
         [M:ALP]QTY       = WQTYSTU
         [M:ALP]TYPQTY    = 2
         [M:ALP]STA       = [F:SOQ]STA
         [M:ALP]PECSCOLOC = 1
         [M:ALP]PECQLYCTL = 1              : #--- Bug 73267
         [M:ALP]BESDAT    = [M:SDH1]SHIDAT
         [M:ALP]DLVDAT    = [M:SDH1]DLVDAT
         #DLUBPC
         [M:ALP]BPRNUM    = [M:SDH0]BPCORD
         Raz WRET
         If dim(GWRHOBY)>0 & GWRHOBY=2 & dim([M:SDH1]WRHE)>0
            [M:ALP]WRH = [M:SDH1]WRHE
         Else
            Raz [M:ALP]WRH
         Endif
         Raz [M:ALP]LOT : # 101581

         Call ALLSTOSORW("SDH1",[M:SDH1]NBLIG,[M:SDH1]NBLIG,WRUP,1,1,WRET)
&                        From STKSOR
         If WRET<>0
            Raz WQTYSTU,WQTY
            OK=0 : Return
         Elsif [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT=0
            Raz WQTYSTU,WQTY
            #OK=0 : GERR=1  : # 100104
            OK=0            : # 100104
            GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&                    format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(156,191,1) :#--CPO 83985 GFMDAT au lieu de GFMD
            Call ERREUR(GMESSAGE) From GESECRAN
            Return
         Else
            # Issue 122277
            If [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT<WQTYSTU & find([F:SOH]DME,2,3)
                WOK=1
                Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-":"-[F:SOQ]ITMREF-
&                           format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(156,191,1)-"\"-mess(146,191,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
                If WOK=1
                    OK=0 : Raz WQTYSTU,WQTY
                    # Nettoyage du STOSORW
                    Call DELSTOSORW([M:SDH1]NBLIG,[M:SDH1]NBLIG,"SDH1",[M:SDH0]STOFCY,WRET) From STKSOR
                    Raz [M:SDH1]WSTOSEQ([M:SDH1]NBLIG)
                    Return
                Endif
            Endif
            # End issue 122277
            WQTYSTU = [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
            WQTY    = WQTYSTU/WSAUSTUCOE
            Call QTEARR(WQTY,WSAU) From TRTDIV
         Endif
         # Qté allouée origine = qté allouée (+ qté rupture)
         WOALQTYSTU = WQTYSTU

      # Sinon si détermination automatique du stock
      # allocation globale ou
      # allocation détaillée et qté allouée=0 ou qté rupture non livrable
      Elsif GSLTSTKFLG=2
         # Chargement STOSORW par éxécution de l'algorithme
         [M:ALP]TRSTYP    = [M:SDH0]TRSTYP
         [M:ALP]TRSCOD    = [M:SDH0]TRSCOD
         [M:ALP]VCRTYP    = 4
         [M:ALP]STOFCY    = [M:SDH0]STOFCY
         [M:ALP]ITMREF    = [F:SOQ]ITMREF
         # --------------------------------------
         # FGR 21/04/2015 : X3SUIVI105605 (début)
         If func AFNC.ACTIV("ECC") Then
           [M:ALP]ECCVALMAJ    = [F:SOQ]ECCVALMAJ
         Endif
         # FGR 21/04/2015 : X3SUIVI105605 (fin)
         # --------------------------------------
         [M:ALP]QTY       = WQTYSTU
         [M:ALP]TYPQTY    = 2
         # Si bouton livraison ou picking commande
         #If GCREPARBOU=1 & GFONC1="GESSOH" | currbox=GBOXSO1
         [M:ALP]PCU       = WSAU
         [M:ALP]PCUSTUCOE = WSAUSTUCOE
         [M:ALP]BESDAT    = [M:SDH1]SHIDAT
         [M:ALP]DLVDAT    = [M:SDH1]DLVDAT
         [M:ALP]ALLDAT    = [0/0/0]
         [M:ALP]STOLOC    = ""
         [M:ALP]PECINTLOC = 2
         [M:ALP]PECSCOLOC = 1
         [M:ALP]PECPLFLOC = 2
         [M:ALP]PECCUNLOK = 1
         [M:ALP]FILSTO    = ""
         [M:ALP]LOT       = [F:SOQ]LOT
         [M:ALP]LOC       = [F:SOQ]LOC
         [M:ALP]STA       = [F:SOQ]STA
         If dim(GWRHOBY)>0 & GWRHOBY=2 & dim([M:SDH1]WRHE)>0
            [M:ALP]WRH = [M:SDH1]WRHE
         Else
            Raz [M:ALP]WRH
         Endif
         Raz [M:ALP]ALLQTY
         # Si allocation globale, on passe la qté déjà alloée en global
         If [F:SOQ]ALLTYP=1 [M:ALP]ALLQTY=[F:SOQ]ALLQTYSTU Endif
         #DLUBPC
         [M:ALP]BPRNUM    = [M:SDH0]BPCORD
         Raz WRET

         Call GENSTOSORW("SDH1",[M:SDH1]NBLIG,[M:SDH1]NBLIG,WRUP,"C",WRET)
&                        From STKSOR
         If WRET<>0
            Raz WQTYSTU,WQTY
            OK=0 : Return
         Elsif [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT=0
            Raz WQTYSTU,WQTY
            #OK=0 : GERR=1  : # 100104
            OK=0            : # 100104
            GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&                    format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(126,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
            Call ERREUR(GMESSAGE) From GESECRAN
            Return
         Else
            # Issue 122277
            If [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT<WQTYSTU & find([F:SOH]DME,2,3)
                WOK=1
                Call OUINON([F:SOH]SOHNUM-mess(27,159,1)-":"-[F:SOQ]ITMREF-
&                           format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(126,192,1)-"\"-mess(146,191,1),WOK) From GESECRAN :#--CPO 83985 GFMDAT au lieu de GFMD
                If WOK=1
                    OK=0 : Raz WQTYSTU,WQTY
                    # Nettoyage du STOSORW
                    Call DELSTOSORW([M:SDH1]NBLIG,[M:SDH1]NBLIG,"SDH1",[M:SDH0]STOFCY,WRET) From STKSOR
                    Raz [M:SDH1]WSTOSEQ([M:SDH1]NBLIG)
                    Return
                Endif
            Endif
            # End issue 122277
            WQTYSTU = [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
            WQTY    = WQTYSTU/WSAUSTUCOE

            # Bug 29257
            If WQTYSTU=WSVGQTYSTU
               Call QTEARR(WQTY,WSAU) From TRTDIV
            Else
               #---------------------------------------------
               # TS : réajustement qté en unité vente entière
               #---------------------------------------------
               Gosub REAJUSTE_QTY
               # Si la qté a été réajustée, il faut diminuer STOSORW en conséquence
               If WQTYSTU < [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
                  WQTA = [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT-WQTYSTU
                  Call DIM_STOSORW([M:SDH1]NBLIG,"SDH1",[M:SDH0]STOFCY,WQTA,WRET) From STKSOR
               Endif
               # 95179 : Si qté en UV à 0 après réajustement, il n'y a rien à livrer
               If WQTY=0
                    Raz WQTYSTU,WQTY
                    #OK=0 : GERR=1  : # 100104
                    OK=0            : # 100104
                    GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&                            format$(GFMD,[F:SOQ]SHIDAT)+"\"+mess(126,192,1)
                    Call ERREUR(GMESSAGE) From GESECRAN
                    Return
               Endif
               # 95179
            Endif

         Endif
         # Si allocation globale, qté allouée origine=qté allouée (+qté rupture)
         If [F:SOQ]ALLTYP=1 &
&          ([F:SOQ]ALLQTY<>0 | ([F:SOQ]SHTQTY<>0 & ((WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3)))
#&          ([F:SOQ]ALLQTY<>0 | ([F:SOQ]SHTQTY<>0 & WNEGSTO=2 & GSHTDLV=2))
            WOALQTYSTU = WQTYSTU
         # Sinon qté allouée origine=0
         Else
            WOALQTYSTU = 0
         Endif

      # Sinon pas de détermination automatique du stock et
      # stock négatif interdit ou stock négatif autorisé mais pas de liv des ruptures
      # allocation globale ou
      # allocation détaillée et qté allouée=0 ou qté rupture non livrable
      # --> calcul du stock disponible
      #Elsif WNEGSTO<>2 | (WNEGSTO=2 & GSHTDLV<>2)
      Elsif (WNEGSTO<>2 & GSHTDLV<>3) | (WNEGSTO=2 & GSHTDLV<2)
         # Lecture cumuls article
         Read [ITV]ITV0=[F:ITM]ITMREF;[M:SDH0]STOFCY
         If fstat Raz [F:ITV] Endif
         # Lecture de la règle de gestion à utiliser
         Call LECSRU([F:SOQ]STOFCY,[F:ITM]TCLCOD,[M:SDH0]TRSTYP,
&                    [M:SDH0]TRSCOD,"",WRET) From STKLIB
         If WRET<>0 OK=0 : Return Endif
         # Statuts autorisés par la règle de gestion
         If find([F:SRU]AUZSTA,1,3,5,7) WA=1  Endif
         If find([F:SRU]AUZSTA,2,3,6,7) WQ=1  Endif
         If find([F:SRU]AUZSTA,4,5,6,7) WR=1  Endif
         WSTA = WA+2*WQ+4*WR
         # Calcul stock disponible
         Call STODISTOT("",1,WSTA,"",WSTUDIS) From STKLIB
         # On rajoute l'allouée global
         If [F:SOQ]ALLTYP=1 WSTUDIS+=[F:SOQ]ALLQTYSTU Endif

         # Pas de disponible --> rien à livrer
         If WSTUDIS <= 0 | (find([F:SOH]DME,2,3) & WSTUDIS < WQTYSTU)
            #OK=0 : GERR=1  : # 100104
            OK=0            : # 100104
            GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&                    format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(126,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
            If find([F:SOH]DME,2,3) GMESSAGE -="\"-mess(105,197,1) Endif
            Call ERREUR(GMESSAGE) From GESECRAN
            Raz WQTYSTU,WQTY
            Return
            # Disponible < qte à livrer ---> qte à livrer = disponible
         Elsif WSTUDIS < WQTYSTU
            WQTYSTU = WSTUDIS
            WQTY    = WQTYSTU/WSAUSTUCOE

            # Bug 29257
            If WQTYSTU=WSVGQTYSTU
               Call QTEARR(WQTY,WSAU) From TRTDIV
            Else
               #---------------------------------------------
               # TS : réajustement qté en unité vente entière
               #---------------------------------------------
               Gosub REAJUSTE_QTY
               # 95179 : Si qté en UV à 0 après réajustement, il n'y a rien à livrer
               If WQTY=0
                  #OK=0 : GERR=1  : # 100104
                  OK=0            : # 100104
                  GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&                          format$(GFMD,[F:SOQ]SHIDAT)+"\"+mess(126,192,1)
                  If find([F:SOH]DME,2,3) GMESSAGE -="\"-mess(105,197,1) Endif
                  Call ERREUR(GMESSAGE) From GESECRAN
                  Raz WQTYSTU,WQTY
                  Return
               Endif
               # 95179
            Endif

         Endif
         # Si allocation globale, qté allouée origine=qté allouée (+qté rupture)
         If [F:SOQ]ALLTYP=1 &
&          ([F:SOQ]ALLQTY<>0 | ([F:SOQ]SHTQTY<>0 & ((WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3)))
#&          ([F:SOQ]ALLQTY<>0 | ([F:SOQ]SHTQTY<>0 & WNEGSTO=2 & GSHTDLV=2))
            WOALQTYSTU = WQTYSTU
         # Sinon qté allouée origine=0
         Else
            WOALQTYSTU = 0
         Endif
      Endif
   Endif
Endif

# Si bouton livraison ou picking commande et composé d'un kit/sous-traité
#If (GCREPARBOU=1 & GFONC1="GESSOH" | currbox=GBOXSO1) & [F:SOP]LINTYP=2
If currbox=GBOXSO1 & find([F:SOP]LINTYP,2,10)
   WQTYCPE    = WQTY
   WQTYSTUCPE = WQTYSTU
   WQTYDLVCPE = WQTYCPE+[F:SOQ]ODLQTY+[F:SOQ]DLVQTY

   # Détermination de la quantité livrable du composé
   OK=1
   Gosub STODETKIT
   If OK=0 | WQTYSTUCPE=0
      Raz WQTY,WQTYSTU,WQTYCPE,WQTYSTUCPE : Return
   Endif

   WQTY    = WQTYCPE
   WQTYSTU = WQTYSTUCPE

   #---------------------------------------------
   # TS : réajustement qté en unité vente entière
   #---------------------------------------------
   Gosub REAJUSTE_QTY
   WQTYDLVCPE = WQTY+[F:SOQ]ODLQTY+[F:SOQ]DLVQTY

   # Alimentation de la qté allouée origine pour le composé d'un kit
   #If [F:SOQ]ALLQTY<>0 | ([F:SOQ]SHTQTY<>0 & WNEGSTO=2 & GSHTDLV=2)
   If [F:SOQ]ALLQTY<>0 | ([F:SOQ]SHTQTY<>0 & ((WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3))
      WOALQTYSTU = WQTYSTU
      WOALQTYCPE = WQTYSTU
   Else
      WOALQTYSTU = 0
      WOALQTYCPE = 0
   Endif

   # Repositionnement sur l'article composé
   If [F:ITM]ITMREF <> [F:SOQ]ITMREF
      Read [ITM]ITM0=[F:SOQ]ITMREF
      If fstat
         Raz [F:ITM] : OK=0 : Return
      Endif
   Endif

Endif

# Relecture des tables articles (Bug 42512)
Gosub LEC_TABART

#--- La sélection est correcte

# If [M:SDH1]NBLIG > 0
   # Local Integer NBPOSTE, WNEWCDE : NBPOSTE=
   # WNEWCDE = find([F:SOH]SOHNUM,[M:SDH1]XSOHNUM(0..[M:SDH1]NBLIG-1))
   # Nouvelle commande pour cette livraison
   # Alimentation des elements de facturation
   # ACA
   # If !WNEWCDE
   #   Call SAISFOOT2(4,"SDH2",NBPOSTE,[M:SDH0]CHGTYP,[F:SOH]CUR,[M:SDH1]CUR,
# &                    "NON") From TRTVENELT
   # Endif
   Gosub SOH_SDH_PLUS From SUBSFIT
   #If GERR <> 0 Then          # FGR 19/08/2014 : X3SUIVI100811
   If GERR = 1 Then            # FGR 22/06/2015 : X3SUIVI109023
     OK = 0
     Call ERREUR(GMESSAGE) From GESECRAN
     Return
   Endif
# Endif

# Sauvegarde du lien entre ligne document et écran travail
[L]WSTOSEQ = [M:SDH1]WSTOSEQ([M:SDH1]NBLIG)
# Ouverture de la ligne
nolign = [M:SDH1]NBLIG
Insa nolign,1,[M:SDH1]NBLIG [M:SDH1]NBLIG
[M:SDH1]NBLIG += 1
nolign = [M:SDH1]NBLIG
NOL = nolign-1
status = 0

# Alimentation de la classe [M:SDH1] de la ligne
Call ALISOQSDH(NOL,WOALQTYSTU,WQTY,WQTYSTU) From TRTVENLIV

# Récupération du lien entre ligne document et écran travail
[M:SDH1]WSTOSEQ(NOL) = [L]WSTOSEQ

Call LINNUM("SDDLIN") From TABLEAUX

# Calculs prix net, marge et maj montants livrés et poids
GNETMAR=0
Call ALICLCAMT([M:SDH1]ITMREF(NOL),[M]QTY(NOL),NOL,"SDH1",[M:SDH1]CLCAMT1(NOL),
&              [M:SDH1]CLCAMT2(NOL)) From TRTX3
# Bug 59754:Calcul prix net ssi il y a eu une recherche tarif sinon il faut garder le prix net de la cde
# (Si frais/remise dépendant de la qté (par ligne) et plusieurs liv.,le prix net doit être le même sur chaque liv.)
If [F:SOH]SOHCAT=4 & ([F:SOH]BETFCY=2 | [F:SOC]PLI<>"")
    Call CLCNETPRI([M:SDH1]QTY(NOL),[M:SDH1]CUR, NOL)From TRTVENPRI
Endif
Call CLCPFM([M:SDH0]STOFCY,[M:SDH1]PRITYP,[M:SDH0]CHGTYP,[M:SDH1]SHIDAT,
&           [M:SDH1]CUR,NOL,1) From TRTVENPRI
Call APRES_LIGNE(NOL,0) From SUBSDHB
#--CPO 79343
If GIMPORT=0 and GREP<>"C" and GSDHSUPPLIGDSP<>999999
  Local Integer WTEMPDSP : Raz WTEMPDSP
  Call CTLSUPP_EXISTDSP("SDH",NOL,WTEMPDSP) From TRTVENDIV
  If WTEMPDSP=1
    GSDHSUPPLIGDSP +=1
  Endif
Endif
#--/CPO
GNETMAR=1

Raz GOUVSOR
# La ligne de livraison est-elle complète du point de vue stock
If [M]STOMGTCOD(NOL)<>1
   # Si stock à sortir non encore déterminé, init emplacement par défaut
   If dim([M:SDH1]LOC)>0 & [M:SDH1]WSTOSEQ(NOL)=0
      Call STKINIEMPS([M:SDH1]LOC(NOL)) From STKLOC
   Endif
   # Alimentation de [M:ALP]
   Gosub ALI_ALP From SUBSDH
   # Détermination du stock à sortir (automatisme, saisie)
   Call OUVSOR("SDH1",NOL,[M:SDH1]NBLIG,[M:SDH1]WSTOSEQ(NOL),GSLTSTKFLG,WRET)
&              From STKSOR
   If WRET=1 Endif
Endif

nolign  = NOL+1
# Sauvegarde qté cde et qté à livrer du composé
WQTYCPE    = [F:SOQ]QTY
WALLQTYCPE = WQTY
WQTYDLVCPE = WQTY+[F:SOQ]ODLQTY+[F:SOQ]DLVQTY

# Si composé de kit/sous-traité
If currbox=GBOXSO1 & find([M:SDH1]LINTYP(NOL),2,10)
   If !clalev([F:SOP1]) Local File SORDERP [SOP1] Endif
   Filter [SOP1] Where SOHNUM = [F:SOP]SOHNUM & SOPSEQ > [F:SOP]SOPSEQ
   For [SOP1]
      If find([F:SOP1]LINTYP,3,4,5,11,12,13)
         Read [SOQ]SOQ0=[F:SOP1]SOHNUM;[F:SOP1]SOPLIN;[F:SOP1]SOPSEQ
         If fstat
            Call RSTA ("SOQ",[F:SOP1]SOHNUM+num$([F:SOP1]SOPLIN)) From GLOCK
            Goto SEL_SUI
         Endif
         [F:SOP] = [F:SOP1]
         # Lecture des tables articles
         Gosub LEC_TABART
         # Contrôle de l'insertion
         If [M:SDH1]NBLIG+1 >= dim([M:SDH1]ITMREF)-1
            Raz OK : GERR=1 : GMESSAGE=mess(122,199,1)
            Call ERREUR(GMESSAGE) From GESECRAN
            Break
         Endif
         # Sauvegarde du lien entre ligne document et écran travail
         [L]WSTOSEQ = [M:SDH1]WSTOSEQ([M:SDH1]NBLIG)
         # Ouverture de la ligne
         Insa nolign,1,[M:SDH1]NBLIG [M:SDH1]NBLIG
         [M:SDH1]NBLIG += 1
         nolign = [M:SDH1]NBLIG
         NOL = nolign-1
         status = 0
         # Calcul de la quantité livrée du composant
         WQTY = (WALLQTYCPE * [F:SOQ]QTY) / WQTYCPE
         Call QTEARR(WQTY,[F:SOP1]SAU) From TRTDIV
         # Cas d'une livraison d'une nomenclature de sous-traitance avec un service forfaitaire
         # Si livraison partielle, le service forfaitaire est également livré partiellement
         # Sur la dernière livraison, il faut vérifier que le service est complètement livré (pb d'arrondi)
         If [F:SOP1]LINTYP=13 & WQTYDLVCPE=WQTYCPE
             If  WQTY+[F:SOQ]ODLQTY+[F:SOQ]DLVQTY<>[F:SOQ]QTY
                 WQTY=[F:SOQ]QTY-[F:SOQ]ODLQTY-[F:SOQ]DLVQTY
             Endif
         Endif
         WQTYSTU = WQTY*[F:SOQ]QTYSTU/[F:SOQ]QTY
         Call QTEARR(WQTYSTU,[F:SOP1]STU) From TRTDIV
         # Si composant géré en stock et qté allouée origine sur composé
         # calcul de la qté allouée origine du composant
         If WOALQTYCPE<>0
            WOALQTYSTU = (WOALQTYCPE * [F:SOQ]QTYSTU) / WQTYSTUCPE
         Else
            WOALQTYSTU = 0
         Endif

         # Alimentation de la classe [M:SDH1] de la ligne
         Call ALISOQSDH(NOL,WOALQTYSTU,WQTY,WQTYSTU) From TRTVENLIV

         # Récupération du lien entre ligne document et écran travail
         [M:SDH1]WSTOSEQ(NOL) = [L]WSTOSEQ

         Call LINNUM("SDDLIN") From TABLEAUX
         # Calculs prix net, marge et maj montants livrés et poids
         GNETMAR=0
         Call ALICLCAMT([M:SDH1]ITMREF(NOL),[M]QTY(NOL),NOL,"SDH1",
&                       [M:SDH1]CLCAMT1(NOL),[M:SDH1]CLCAMT2(NOL)) From TRTX3
         # Bug 59754:Calcul prix net ssi il y a eu une recherche tarif sinon il faut garder le prix net de la cde
         # (Si frais/remise dépendant de la qté (par ligne) et plusieurs liv.,le prix net doit être le même sur chaque liv.)
         If [F:SOH]SOHCAT=4 & ([F:SOH]BETFCY=2 | [F:SOC]PLI<>"")
             Call CLCNETPRI([M:SDH1]QTY(NOL),[M:SDH1]CUR,NOL) From TRTVENPRI
         Endif
         Call CLCPFM([M:SDH0]STOFCY,[M:SDH1]PRITYP,[M:SDH0]CHGTYP,
&                    [M:SDH1]SHIDAT,[M:SDH1]CUR,NOL,1) From TRTVENPRI
         Call APRES_LIGNE(NOL,0) From SUBSDHB
         GNETMAR=1

         Raz GOUVSOR
         #--- Bug 23899 : TS le 23.08.04
         # La ligne de livraison est-elle complète du point de vue stock
         If [M]STOMGTCOD(NOL)<>1
            # Alimentation de [M:ALP]
            Gosub ALI_ALP From SUBSDH
            # Détermination du stock à sortir (automatisme, saisie)
            Call OUVSOR("SDH1",NOL,[M:SDH1]NBLIG,[M:SDH1]WSTOSEQ(NOL),GSLTSTKFLG,WRET) From STKSOR
            If WRET=1 Endif
         Endif
         Raz GOUVSOR
         #---

         nolign = NOL+1
      Else
         Break
      Endif
   $SEL_SUI
   Next
   Filter [SOP1]
   Close Local File [SOP1]
Endif

Return

###########################################################################
# STODETKIT : Détermination de la quantité à livrer d'un kit              #
#             à partir des quantités livrables des composants             #
###########################################################################
$STODETKIT

Local    Decimal WQUS, WQTYDIM
Local    Decimal WQTYCPS, WQTYSTUCPS
Local    Decimal WDISCPS, WDISSTUCPS
Local    Integer WSTA, WA, WQ, WR
Local    Integer WINDICE, I
Local    Integer WSTOSEQ
Local    Integer WMODQTYCPE : Raz WMODQTYCPE
Local    Integer WSVG_NEGSTO

If WQTYSTUCPE=0
   Raz OK : Return
Endif

If clalev ([F:SOQ1]) = 0 Local File SORDERQ [SOQ1]:Endif
If clalev ([F:SOP1]) = 0 Local File SORDERP [SOP1]:Endif

WINDICE = [M:SDH1]NBLIG
# --- Recherche stock disponible des composants
For [SOP1]SOP0 Where SOHNUM=[F:SOQ]SOHNUM & SOPLIN > [F:SOQ]SOPLIN
   # Sortie de la boucle quand on est plus sur un composant
   If !(find([F:SOP1]LINTYP, 3,4,5,11,12,13)) Break Endif
   Read [SOQ1]SOQ0 = [F:SOP1]SOHNUM;[F:SOP1]SOPLIN;[F:SOP1]SOPSEQ
   If fstat
      Call RSTA("SOQ",[F:SOP1]SOHNUM-num$([F:SOP1]SOPLIN)-num$([F:SOP1]SOPSEQ))
&               From GLOCK
      Raz WQTYCPE, WQTYSTUCPE
      Raz OK : Break
   Endif
   If [F:ITM]ITMREF <> [F:SOQ1]ITMREF
      Read [ITM]ITM0=[F:SOQ1]ITMREF
      If fstat Raz [F:ITM] Endif
   Endif

   WINDICE += 1
   If [F:SOQ1]STOMGTCOD<>1
      # Calcul de la qté à traiter du composant en UV et en US
      WQTYCPS    = WQTYCPE*([F:SOQ1]QTY/[F:SOQ]QTY)
      Call QTEARR(WQTYCPS,[F:SOP1]SAU) From TRTDIV
      # Cas d'une livraison d'une nomenclature de sous-traitance avec un service forfaitaire
      # Si livraison partielle, le service forfaitaire est également livré partiellement
      # Sur la dernière livraison, il faut vérifier que le service est complètement livré (pb d'arrondi)
      If [F:SOP1]LINTYP=13 & WQTYDLVCPE=WQTYCPE
          If  WQTYCPS+[F:SOQ1]ODLQTY+[F:SOQ1]DLVQTY<>[F:SOQ1]QTY
              WQTYCPS=[F:SOQ1]QTY-[F:SOQ1]ODLQTY-[F:SOQ1]DLVQTY
          Endif
      Endif
      WQTYSTUCPS = WQTYCPS*[F:SOP1]SAUSTUCOE
      Call QTEARR (WQTYSTUCPS,[F:SOP1]STU) From TRTDIV

      # Recherche de la quantité livrable du composant
      WSVG_NEGSTO=WNEGSTO
      WNEGSTO=[F:ITM]NEGSTO
      Gosub RECH_QTEDIS
      WNEGSTO=WSVG_NEGSTO

      # Qté disponible du composant nulle, rien à livrer
      If OK=0 & WDISSTUCPS<=0
         Raz WQTYCPE, WQTYSTUCPE
         Break
      # Qté disponible du composant < qté origine du composant
      Elsif WDISSTUCPS < WQTYSTUCPS
         # Flag : la qté à livrer du composé a été modifiée
         WMODQTYCPE = 1
         # La qté à livrer du cpsa doit être un multiple du rapport cpsé/cpsa
         #WDISCPS    = WDISCPS-mod(WDISCPS,[F:SOQ1]QTY/[F:SOQ]QTY)
         #WDISSTUCPS = WDISCPS*[F:SOP1]SAUSTUCOE
         #Call QTEARR(WDISSTUCPS,[F:SOP1]STU) From TRTDIV
         # Recalcul de la nouvelle qté à livrer du composé
         WQTYCPE    = WDISCPS*([F:SOQ]QTY/[F:SOQ1]QTY)
         Call QTEARR(WQTYCPE,[F:SOP]SAU) From TRTDIV
         WQTYSTUCPE = WQTYCPE*[F:SOP]SAUSTUCOE
         Call QTEARR(WQTYSTUCPE,[F:SOP]STU) From TRTDIV
      Endif
   Endif
Next

#-- X3Suivi 74180-76472 JDE 07/07/2011: Controle composé Kit avec si option commande = lignes commande complète ou commande complète --#
#-- X3Suivi 90162 : Controle composé Kit avec si option commande = lignes commande complète ou commande complète --#
#If WQTYCPE <> [F:SOQ]QTY
If WQTYCPE < [F:SOQ]QTY - [F:SOQ]DLVQTY
  #-- Composé kit xx : lignes non totalement allouées \Alors qu'on est en livraison lig commande complète ou commande complète
  If [F:SOH]DME = 2 : # Ligne complète
     Raz OK
     Call ERREUR(mess(3,436,1) - [F:SOQ]ITMREF - ':' - num$([F:SOQ]QTY) - '<>'  - num$(WQTYCPE) -'\' -mess(142,192,1)) From GESECRAN
     Goto STODETKIT_SUI
  Elsif [F:SOH]DME = 3 : # Commande complète
     Raz OK
     Call ERREUR(mess(3,436,1) - [F:SOQ]ITMREF - ':' - num$([F:SOQ]QTY) - '<>'  - num$(WQTYCPE) -'\' -mess(353,192,1)) From GESECRAN
     Goto STODETKIT_SUI
  Endif
Endif

# Nettoyage du STOSORW si la quantité livrable a diminuée
If WMODQTYCPE=1
   WINDICE = [M:SDH1]NBLIG
   If [F:SOQ]STOMGTCOD<>1
      WQUS=sigma(I=0,[M:SOW]NBLIG-1,([M:SOW]WQTYSTU(I)*([M:SOW]WSTOSEQ(I)=[M:SDH1]WSTOSEQ(WINDICE))))
      # La qté composé stockée dans STOSORW est > à celle qui est livrable
      If WQUS>WQTYSTUCPE
         # Diminution de la qté stockée dans STOSORW
         WQTYDIM=WQUS-WQTYSTUCPE
         Call DIM_STOSORW(WINDICE,"SDH1",[M:SDH0]STOFCY,WQTYDIM,WRET) From STKSOR
         If WRET<>0 Goto STODETKIT_SUI Endif
      Else
         Raz WMODQTYCPE
      Endif
   Endif
   If WMODQTYCPE=1
      For [SOP1]SOP0 Where SOHNUM=[F:SOQ]SOHNUM & SOPLIN>[F:SOQ]SOPLIN
         # Sortie de la boucle quand on est plus sur un composant
         If !(find([F:SOP1]LINTYP, 3,4,5,11,12,13)) Break Endif
         Read [SOQ1]SOQ0=[F:SOP1]SOHNUM;[F:SOP1]SOPLIN;[F:SOP1]SOPSEQ
         WINDICE += 1
         # Calcul de la qté à traiter du composant
         WQTYCPS    = WQTYCPE*([F:SOQ1]QTY/[F:SOQ]QTY)
         WQTYSTUCPS = WQTYCPS*[F:SOP1]SAUSTUCOE
         If [F:SOQ1]STOMGTCOD<>1
            WQUS=sigma(I=0,[M:SOW]NBLIG-1,([M:SOW]WQTYSTU(I)*([M:SOW]WSTOSEQ(I)=[M:SDH1]WSTOSEQ(WINDICE))))
            # La qté composant stockée dans STOSORW est > à celle qui est livrable
            If WQUS>WQTYSTUCPS
               # Diminution de la qté stockée dans STOSORW
               WQTYDIM=WQUS-WQTYSTUCPS
               Call DIM_STOSORW(WINDICE,"SDH1",[M:SDH0]STOFCY,WQTYDIM,WRET) From STKSOR
               If WRET<>0 Break Endif
            Endif
         Endif
      Next
   Endif
Endif

$STODETKIT_SUI
# Nettoyage du STOSORW s'il y a eu un problème
If OK=0 & WINDICE >= [M:SDH1]NBLIG
   Call DELSTOSORW([M:SDH1]NBLIG,WINDICE,"SDH1",[M:SDH0]STOFCY,WRET) From STKSOR
   #--- Bug 51776
   For I=[M:SDH1]NBLIG To WINDICE
      Raz [M:SDH1]WSTOSEQ(I)
   Next I
   #---
Endif

Return

###########################################################################
# Recherche de la quantité livrable du composant                          #
###########################################################################
$RECH_QTEDIS

Raz WDISCPS,WDISSTUCPS
Raz WQTY, WQTYSTU

Raz WRUP

# Détermination de la qté à livrer du composant

# Si qté allouée
If [F:SOQ1]ALLQTY<>0
   WQTY    = [F:SOQ1]ALLQTY
   WQTYSTU = [F:SOQ1]ALLQTYSTU
   # Si livraison classique (ni prêt, ni sous-traitance) et
   # si qté rupture, stock négatif autorisé et livraison des ruptures
   If (dim([M:SDH0]SCO)<0 | dim([M:SDH0]SCO)>0 & [M:SDH0]SCO<>2)
&    & [M:SDH0]LND <>2 & [F:SOQ1]SHTQTY<>0 & ((WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3)
#&    & [M:SDH0]LND <>2 & [F:SOQ1]SHTQTY<>0 & WNEGSTO=2 & GSHTDLV=2
      WQTY    += [F:SOQ1]SHTQTY
      WQTYSTU += [F:SOQ1]SHTQTYSTU
      WRUP  = 1
   Endif
# Sinon si livraison classique (ni prêt, ni sous-traitance)
Elsif (dim([M:SDH0]SCO)<0 | dim([M:SDH0]SCO)>0 & [M:SDH0]SCO<>2) & [M:SDH0]LND <>2
   # Si qté rupture
   If [F:SOQ1]SHTQTY<>0
      # Si stock négatif autorisé et livraison des ruptures
      #If WNEGSTO=2 & GSHTDLV=2
      If (WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3
         WQTY    = [F:SOQ1]SHTQTY
         WQTYSTU = [F:SOQ1]SHTQTYSTU
         WRUP    = 1
      Endif
   # Sinon si stock négatif autorisé et livraison des ruptures,
   # on génèrera une rupture si nécessaire
   #Elsif WNEGSTO=2 & GSHTDLV=2
   Elsif (WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3
      WRUP = 1
   Endif
Endif

# Si pas de qte allouée/rupture ou si qte allouée/rupture > qté à livrer
# on conserve la quantité à livrer
# sinon la quantité à livrer devient la qte allouée/rupture
If WQTYSTU=0 | WQTYSTU>WQTYSTUCPS
   WQTY    = WQTYCPS
   WQTYSTU = WQTYSTUCPS
Endif

# Si allocation détaillée et qté allouée<>0 ou qté rupture livrable
If [F:SOQ1]ALLTYP=2 &
& ([F:SOQ1]ALLQTY<>0 | ([F:SOQ1]SHTQTY<>0 & ((WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3)))
#& ([F:SOQ1]ALLQTY<>0 | ([F:SOQ1]SHTQTY<>0 & WNEGSTO=2 & GSHTDLV=2))
   # Chargement STOSORW à partir des allocations
   [M:ALP]TRSTYP    = [M:SDH0]TRSTYP
   [M:ALP]TRSCOD    = [M:SDH0]TRSCOD
   [M:ALP]VCRTYP    = 2
   [M:ALP]VCRNUM    = [F:SOQ1]SOHNUM
   [M:ALP]VCRLIN    = [F:SOQ1]SOPLIN
   [M:ALP]VCRSEQ    = [F:SOQ1]SOQSEQ
   [M:ALP]STOFCY    = [M:SDH0]STOFCY
   [M:ALP]ITMREF    = [F:SOQ1]ITMREF
   # --------------------------------------
   # FGR 21/04/2015 : X3SUIVI105605 (début)
   If func AFNC.ACTIV("ECC") Then
     [M:ALP]ECCVALMAJ    = [F:SOQ1]ECCVALMAJ
   Endif
   # FGR 21/04/2015 : X3SUIVI105605 (fin)
   # --------------------------------------
   [M:ALP]QTY       = WQTYSTU
   [M:ALP]TYPQTY    = 2
   [M:ALP]STA       = [F:SOQ1]STA
   [M:ALP]PECSCOLOC = 1
   [M:ALP]BESDAT    = [M:SDH1]SHIDAT
   [M:ALP]DLVDAT    = [M:SDH1]DLVDAT
   Raz WRET
   If dim(GWRHOBY)>0 & GWRHOBY=2 & dim([M:SDH1]WRHE)>0
      [M:ALP]WRH = [M:SDH1]WRHE
   Else
      Raz [M:ALP]WRH
   Endif
   Raz [M:ALP]LOT : # 101581

   Call ALLSTOSORW("SDH1",WINDICE,[M:SDH1]NBLIG,WRUP,0,1,WRET) From STKSOR
   If WRET<>0
      OK=0 : Return
   Elsif [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT=0
      #OK=0 : GERR=1  : # 100104
      OK=0            : # 100104
      GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ1]ITMREF-
&              format$(GFMDAT,[F:SOQ1]SHIDAT)+"\"+mess(156,191,1) :#--CPO 83985 GFMDAT au lieu de GFMD
      Call ERREUR(GMESSAGE) From GESECRAN
      Return
   Else
      WQTYSTU = [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
      If [F:SOP1]SAUSTUCOE=0 [F:SOP1]SAUSTUCOE=1 Endif
      WQTY    = WQTYSTU/[F:SOP1]SAUSTUCOE
      Call QTEARR(WQTY,[F:SOP1]SAU) From TRTDIV
   Endif

# Sinon si détermination automatique du stock
# allocation globale ou
# allocation détaillée et qté allouée=0 ou qté rupture non livrable
Elsif GSLTSTKFLG=2
   # Chargement STOSORW par éxécution de l'algorithme
   [M:ALP]TRSTYP    = [M:SDH0]TRSTYP
   [M:ALP]TRSCOD    = [M:SDH0]TRSCOD
   [M:ALP]VCRTYP    = 4
   [M:ALP]STOFCY    = [M:SDH0]STOFCY
   [M:ALP]ITMREF    = [F:SOQ1]ITMREF
   # --------------------------------------
   # FGR 21/04/2015 : X3SUIVI105605 (début)
   If func AFNC.ACTIV("ECC") Then
     [M:ALP]ECCVALMAJ    = [F:SOQ1]ECCVALMAJ
   Endif
   # FGR 21/04/2015 : X3SUIVI105605 (fin)
   # --------------------------------------
   [M:ALP]QTY       = WQTYSTU
   [M:ALP]TYPQTY    = 2
   [M:ALP]PCU       = [F:SOP1]SAU
   [M:ALP]PCUSTUCOE = [F:SOP1]SAUSTUCOE
   [M:ALP]BESDAT    = [M:SDH1]SHIDAT
   [M:ALP]DLVDAT    = [M:SDH1]DLVDAT
   [M:ALP]ALLDAT    = [0/0/0]
   [M:ALP]STOLOC    = ""
   [M:ALP]PECINTLOC = 2
   [M:ALP]PECSCOLOC = 1
   [M:ALP]PECPLFLOC = 2
   [M:ALP]PECCUNLOK = 1
   [M:ALP]FILSTO    = ""
   [M:ALP]LOT       = [F:SOQ1]LOT
   [M:ALP]LOC       = [F:SOQ1]LOC
   [M:ALP]STA       = [F:SOQ1]STA
   Raz [M:ALP]ALLQTY
   If dim(GWRHOBY)>0 & GWRHOBY=2 & dim([M:SDH1]WRHE)>0
      [M:ALP]WRH = [M:SDH1]WRHE
   Else
      Raz [M:ALP]WRH
   Endif
   # Si allocation globale, on passe la qté déjà alloée en global
   If [F:SOQ1]ALLTYP=1 [M:ALP]ALLQTY=[F:SOQ1]ALLQTYSTU Endif
   Raz WRET
   Call GENSTOSORW("SDH1",WINDICE,[M:SDH1]NBLIG,WRUP,"C",WRET) From STKSOR
   If WRET<>0
      # Nécessaire car WSTOSEQ a été affecté dans GENSTOSORW
      If [M:ALP]ALLQTY=0 & [M:ALP]ALLQTYSHT=0
         [M:SDH1]WSTOSEQ(WINDICE) = 0
      Endif
      OK=0 : Return
   Elsif [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT=0
      # Nécessaire car WSTOSEQ a été affecté dans GENSTOSORW
      [M:SDH1]WSTOSEQ(WINDICE) = 0
      #OK=0 : GERR=1  : # 100104
      OK=0            : # 100104
      GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ1]ITMREF-
&              format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(126,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
      Call ERREUR(GMESSAGE) From GESECRAN
      Return
   Else
      WQTYSTU = [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
      If [F:SOP1]SAUSTUCOE=0 [F:SOP1]SAUSTUCOE=1 Endif
      WQTY    = WQTYSTU/[F:SOP1]SAUSTUCOE
      Call QTEARR(WQTY,[F:SOP1]SAU) From TRTDIV
   Endif
# Sinon pas de détermination automatique du stock et
# stock négatif interdit ou stock négatif autorisé mais pas de liv des ruptures
# allocation globale ou
# allocation détaillée et qté allouée=0 ou qté rupture non livrable
# --> calcul du stock disponible
#Elsif WNEGSTO<>2 | (WNEGSTO=2 & GSHTDLV<>2)
Elsif (WNEGSTO<>2 & GSHTDLV<>3) | (WNEGSTO=2 & GSHTDLV<2)
   # Lecture cumuls article
   Read [ITV]ITV0=[F:ITM]ITMREF;[M:SDH0]STOFCY
   If fstat Raz [F:ITV] Endif
   # Lecture de la règle de gestion à utiliser
   Call LECSRU([F:SOQ1]STOFCY,[F:ITM]TCLCOD,[M:SDH0]TRSTYP,[M:SDH0]TRSCOD,
&              "",WRET) From STKLIB
   If WRET<>0
      OK=0 : Return
   Endif
   # Statuts autorisés par la règle de gestion
   If find([F:SRU]AUZSTA,1,3,5,7) WA=1  Endif
   If find([F:SRU]AUZSTA,2,3,6,7) WQ=1  Endif
   If find([F:SRU]AUZSTA,4,5,6,7) WR=1  Endif
   WSTA = WA+2*WQ+4*WR
   # Calcul stock disponible
   Call STODISTOT("",1,WSTA,"",WSTUDIS) From STKLIB
   # On rajoute l'allouée global
   If [F:SOQ1]ALLTYP=1 WSTUDIS+=[F:SOQ1]ALLQTYSTU Endif

   # Pas de disponible --> rien à livrer
   If WSTUDIS <= 0 | (find([F:SOH]DME,2,3) & WSTUDIS < WQTYSTU)
      #OK=0 : GERR=1  : # 100104
      OK=0            : # 100104
      GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ1]ITMREF-
&              format$(GFMDAT,[F:SOQ1]SHIDAT)+"\"+mess(126,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
      If find([F:SOH]DME,2,3) GMESSAGE -="\"-mess(105,197,1) Endif
      Call ERREUR(GMESSAGE) From GESECRAN
      Return
   # Disponible < qte à livrer ---> qte à livrer = disponible
   Elsif WSTUDIS < WQTYSTU
      WQTY    = (WQTY*WSTUDIS)/WQTYSTU
      WQTYSTU = WSTUDIS
   Endif
Endif

WDISSTUCPS = WQTYSTU
WDISCPS    = WQTY

Return

###########################################################################
# TRT_STOREO    Alimentation de la ligne de livraison                     #
#               à partir du besoin de réappro                             #
###########################################################################
$TRT_STOREO
Local Integer WRUP          : # Génération des ruptures (0=non / 1=oui)
Local Integer WRET
Local Integer WSTA, WA, WQ, WR
Local Integer WSTOSEQ
Local Decimal WQTY, WQTYSTU, WSTUDIS, WQTYARR, WQTA
Local Char    WSAU(GLONUOM)
Local Decimal WSAUSTUCOE
Local Integer WDAC

# Détermination de l'UV et du coef UV/US
WSAU       = [F:REO]PCU
WSAUSTUCOE = [F:REO]PCUSTUCOE
WDAC       = 1

If [F:REO]PCU<>[F:REO]STU
   # Recherche si PCU peut être une unité de vente et récup du coef
   Call CTLUOM([F:REO]ITMREF,2,[F:REO]BPRNUM,WSAU,WSAUSTUCOE,GBIDC1,GBIDC2,WDAC)
&       From STKACT
   # PCU n'est pas autorisé comme UV
   If mkstat=2
      WSAU       = [F:REO]STU
      WSAUSTUCOE = 1
   # PCU est autorisé comme UV,
   # mais le coef est différent et sa modif n'est pas autorisé
   Elsif WSAUSTUCOE<>[F:REO]PCUSTUCOE & WDAC<>2
      # On force l'US
      WSAU       = [F:REO]STU
      WSAUSTUCOE = 1
   Endif
Endif

#----------------------------------------
# Détermination de la quantité à livrer
#----------------------------------------

WQTYSTU = [F:REO]QTYSTU
WQTY    = WQTYSTU/WSAUSTUCOE

#---------------------------------------------
# TS : réajustement qté en unité vente entière
#---------------------------------------------
Gosub REAJUSTE_QTY

Raz WRUP
# Si stock négatif autorisé et livraison des ruptures,
# on génèrera une rupture si nécessaire
#If [F:ITM]NEGSTO=2 & GSHTDLV=2 WRUP=1 Endif
#--- Bug 86598
#If ([F:ITM]NEGSTO=2 & GSHTDLV=2) | GSHTDLV=3 : WRUP=1 : Endif

# Article géré en stock, détermination de la quantité à livrer
If [F:ITM]STOMGTCOD<>1
    If [F:ITF]ITMREF<>[F:ITM]ITMREF | [F:ITF]STOFCY<>[M:SDH0]STOFCY
       Read [ITF]ITF0=[F:ITM]ITMREF;[M:SDH0]STOFCY
       If fstat Raz [F:ITF] : Endif
    Endif
    If [F:ITF]STOMGTCOD>1
       # Si détermination automatique du stock
       If GSLTSTKFLG=2
          # Chargement STOSORW par éxécution de l'algorithme
          [M:ALP]TRSTYP    = [M:SDH0]TRSTYP
          [M:ALP]TRSCOD    = [M:SDH0]TRSCOD
          [M:ALP]VCRTYP    = 4
          [M:ALP]STOFCY    = [M:SDH0]STOFCY
          [M:ALP]ITMREF    = [F:REO]ITMREF
          [M:ALP]QTY       = WQTYSTU
          [M:ALP]TYPQTY    = 2
          [M:ALP]PCU       = WSAU
          [M:ALP]PCUSTUCOE = WSAUSTUCOE
          [M:ALP]BESDAT    = [M:SDH1]SHIDAT
          [M:ALP]DLVDAT    = [M:SDH1]DLVDAT
          [M:ALP]ALLDAT    = [0/0/0]
          [M:ALP]STOLOC    = ""
          [M:ALP]PECINTLOC = 2
          [M:ALP]PECSCOLOC = 1
          [M:ALP]PECPLFLOC = 2
          [M:ALP]PECCUNLOK = 1
          [M:ALP]FILSTO    = ""
          [M:ALP]LOT       = ""
          [M:ALP]LOC       = ""
          [M:ALP]STA       = ""
          Raz [M:ALP]ALLQTY
          If dim(GWRHOBY)>0 & GWRHOBY=2 & dim([M:SDH1]WRHE)>0
             [M:ALP]WRH = [M:SDH1]WRHE
          Else
             Raz [M:ALP]WRH
          Endif
          Raz WRET
          Call GENSTOSORW("SDH1",[M:SDH1]NBLIG,[M:SDH1]NBLIG,WRUP,"C",WRET)
&                         From STKSOR
          If WRET<>0
             Raz WQTYSTU,WQTY
             OK=0 : Return
          Elsif [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT=0
             Raz WQTYSTU,WQTY
             OK=0 : GERR=1
             GMESSAGE=mess(27,159,1)-[F:REO]ITMREF-":"-mess(126,192,1)
             Call ERREUR(GMESSAGE) From GESECRAN
             Return
          Else
             WQTYSTU = [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
             WQTY    = WQTYSTU/WSAUSTUCOE

             #---------------------------------------------
             # TS : réajustement qté en unité vente entière
             #---------------------------------------------
             Gosub REAJUSTE_QTY
             # Si la qté a été réajustée, il faut diminuer STOSORW en conséquence
             If WQTYSTU < [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
                WQTA = [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT-WQTYSTU
                Call DIM_STOSORW([M:SDH1]NBLIG,"SDH1",[M:SDH0]STOFCY,WQTA,WRET) From STKSOR
             Endif

          Endif

       # Sinon pas de détermination automatique du stock et
       # stock négatif interdit ou stock négatif autorisé mais pas de liv des ruptures
       # --> calcul du stock disponible
       #Elsif [F:ITM]NEGSTO<>2 | ([F:ITM]NEGSTO=2 & GSHTDLV<>2)
       Elsif ([F:ITM]NEGSTO<>2 & GSHTDLV<>3) | ([F:ITM]NEGSTO=2 & GSHTDLV<2)
          # Lecture cumuls article
          Read [ITV]ITV0=[F:ITM]ITMREF;[M:SDH0]STOFCY
          If fstat Raz [F:ITV] Endif
          # Lecture de la règle de gestion à utiliser
          Call LECSRU([M:SDH0]STOFCY,[F:ITM]TCLCOD,[M:SDH0]TRSTYP,
&                     [M:SDH0]TRSCOD,"",WRET) From STKLIB
          If WRET<>0 OK=0 : Return Endif
          # Statuts autorisés par la règle de gestion
          If find([F:SRU]AUZSTA,1,3,5,7) WA=1  Endif
          If find([F:SRU]AUZSTA,2,3,6,7) WQ=1  Endif
          If find([F:SRU]AUZSTA,4,5,6,7) WR=1  Endif
          WSTA = WA+2*WQ+4*WR
          # Calcul stock disponible
          Call STODISTOT("",1,WSTA,"",WSTUDIS) From STKLIB
          # Pas de disponible --> rien à livrer
          If WSTUDIS <= 0
             OK=0 : GERR=1
             GMESSAGE=mess(27,159,1)-[F:REO]ITMREF-":"-mess(126,192,1)
             Call ERREUR(GMESSAGE) From GESECRAN
             Raz WQTYSTU,WQTY
             Return
             # Disponible < qte à livrer ---> qte à livrer = disponible
          Elsif WSTUDIS < WQTYSTU
             WQTYSTU = WSTUDIS
             WQTY    = WQTYSTU/WSAUSTUCOE

             #---------------------------------------------
             # TS : réajustement qté en unité vente entière
             #---------------------------------------------
             Gosub REAJUSTE_QTY

          Endif
       Endif
    Endif
Endif
#--- La sélection est correcte

# Sauvegarde du lien entre ligne document et écran travail
[L]WSTOSEQ = [M:SDH1]WSTOSEQ([M:SDH1]NBLIG)
# Ouverture de la ligne
nolign = [M:SDH1]NBLIG
Insa nolign,1,[M:SDH1]NBLIG [M:SDH1]NBLIG
[M:SDH1]NBLIG += 1
nolign = [M:SDH1]NBLIG
NOL = nolign-1
status = 0

[M:SDH1]STU(NOL)       = [F:REO]STU
[M:SDH1]SAU(NOL)       = WSAU
[M:SDH1]SAUSTUCOE(NOL) = WSAUSTUCOE
[M:SDH1]DACSAUCOE(NOL) = WDAC

[M:SDH1]QTYSTU(NOL)    = WQTYSTU
[M:SDH1]QTY(NOL)       = WQTY

# Alimentation de la classe [M:SDH1] de la ligne
Call ALIREOSDH([F:REO]ITMREF,NOL) From TRTVENLIV

# Alimentation flag ligne issue d'un picking besoin réappro
[M:SDH1]STOREOFLG(NOL)=1

# Récupération du lien entre ligne document et écran travail
[M:SDH1]WSTOSEQ(NOL) = [L]WSTOSEQ

Call LINNUM("SDDLIN") From TABLEAUX

# Calculs prix net, marge et maj montants livrés et poids
GNETMAR=0
Call ALICLCAMT([M:SDH1]ITMREF(NOL),[M]QTY(NOL),NOL,"SDH1",[M:SDH1]CLCAMT1(NOL),
&              [M:SDH1]CLCAMT2(NOL)) From TRTX3
Call CLCNETPRI([M:SDH1]QTY(NOL),[M:SDH1]CUR, NOL)From TRTVENPRI
Call CLCPFM([M:SDH0]STOFCY,[M:SDH1]PRITYP,[M:SDH0]CHGTYP,[M:SDH1]SHIDAT,
&           [M:SDH1]CUR,NOL,1) From TRTVENPRI
Call APRES_LIGNE(NOL,0) From SUBSDHB
GNETMAR=1

Raz GOUVSOR
# La ligne de livraison est-elle complète du point de vue stock
If [M]STOMGTCOD(NOL)<>1
   # Si stock à sortir non encore déterminé, init emplacement par défaut
   If dim([M:SDH1]LOC)>0 & [M:SDH1]WSTOSEQ(NOL)=0
      Call STKINIEMPS([M:SDH1]LOC(NOL)) From STKLOC
   Endif
   # Alimentation de [M:ALP]
   Gosub ALI_ALP From SUBSDH
   # Détermination du stock à sortir (automatisme, saisie)
   Call OUVSOR("SDH1",NOL,[M:SDH1]NBLIG,[M:SDH1]WSTOSEQ(NOL),GSLTSTKFLG,WRET)
&              From STKSOR
   If WRET=1 Endif
Endif

nolign  = NOL+1

Return

###########################################################################
# TRT_STOSTA    Alimentation de la ligne de livraison                     #
#               à partir du manquant sous-traitant                        #
###########################################################################
$TRT_STOSTA

Local Integer WRUP          : # Génération des ruptures (0=non / 1=oui)
Local Integer WRET
Local Integer WSTA, WA, WQ, WR
Local Integer WSTOSEQ
Local Decimal WQTY, WQTYSTU, WSTUDIS, WQTYARR, WQTA
Local Char    WSAU(GLONUOM)
Local Decimal WSAUSTUCOE
Local Decimal WSVGQTYSTU
Local Integer WDAC
Local Integer WNEGSTO

WNEGSTO = [F:ITM]NEGSTO

WSAU       = [F:ITM]STU
WSAUSTUCOE = 1
WDAC       = 1

#----------------------------------------
# Détermination de la quantité à livrer
#----------------------------------------
WQTYSTU = [F:STA]QTYSTUACT
WQTY    = WQTYSTU/WSAUSTUCOE

Raz WRUP
# Si stock négatif autorisé et livraison des ruptures,
# on génèrera une rupture si nécessaire
#If [F:ITM]NEGSTO=2 & GSHTDLV=2 WRUP=1 Endif
#--- Bug 86598
#If ([F:ITM]NEGSTO=2 & GSHTDLV=2) | GSHTDLV=3 : WRUP=1 : Endif

WSVGQTYSTU = WQTYSTU

# Article géré en stock, détermination de la quantité réellement livrable
If [F:ITM]STOMGTCOD<>1
   If [F:ITF]ITMREF<>[F:ITM]ITMREF | [F:ITF]STOFCY<>[M:SDH0]STOFCY
      Read [ITF]ITF0=[F:ITM]ITMREF;[M:SDH0]STOFCY
      If fstat Raz [F:ITF] : Endif
   Endif
   If [F:ITF]STOMGTCOD>1
       # Si détermination automatique du stock
       If GSLTSTKFLG=2
          # Chargement STOSORW par éxécution de l'algorithme
          [M:ALP]TRSTYP    = [M:SDH0]TRSTYP
          [M:ALP]TRSCOD    = [M:SDH0]TRSCOD
          [M:ALP]VCRTYP    = 4
          [M:ALP]STOFCY    = [M:SDH0]STOFCY
          [M:ALP]ITMREF    = [F:STA]ITMREF
          # --------------------------------------
          # FGR 21/04/2015 : X3SUIVI105605 (début)
          If func AFNC.ACTIV("ECC") Then
            [M:ALP]ECCVALMAJ    = [F:STA]ECCVALMAJ
          Endif
          # FGR 21/04/2015 : X3SUIVI105605 (fin)
          # --------------------------------------
          [M:ALP]QTY       = WQTYSTU
          [M:ALP]TYPQTY    = 2
          [M:ALP]PCU       = WSAU
          [M:ALP]PCUSTUCOE = WSAUSTUCOE
          [M:ALP]BESDAT    = [M:SDH1]SHIDAT
          [M:ALP]DLVDAT    = [M:SDH1]DLVDAT
          [M:ALP]ALLDAT    = [0/0/0]
          [M:ALP]STOLOC    = ""
          [M:ALP]PECINTLOC = 2
          [M:ALP]PECSCOLOC = 1
          [M:ALP]PECPLFLOC = 2
          [M:ALP]PECCUNLOK = 1
          [M:ALP]FILSTO    = ""
          [M:ALP]LOT       = ""
          [M:ALP]LOC       = ""
          [M:ALP]STA       = ""
          Raz [M:ALP]ALLQTY
          If dim(GWRHOBY)>0 & GWRHOBY=2 & dim([M:SDH1]WRHE)>0
             [M:ALP]WRH = [M:SDH1]WRHE
          Else
             Raz [M:ALP]WRH
          Endif
          Raz WRET
          Call GENSTOSORW("SDH1",[M:SDH1]NBLIG,[M:SDH1]NBLIG,WRUP,"C",WRET)
&                         From STKSOR
          If WRET<>0
             Raz WQTYSTU,WQTY
             OK=0 : Return
          Elsif [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT=0
             Raz WQTYSTU,WQTY
             OK=0 : GERR=1
             GMESSAGE=mess(27,159,1)-[F:STA]ITMREF-":"-mess(126,192,1)
             Call ERREUR(GMESSAGE) From GESECRAN
             Return
          Else
             WQTYSTU = [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
             WQTY    = WQTYSTU/WSAUSTUCOE
          Endif

       # Sinon pas de détermination automatique du stock et
       # stock négatif interdit ou stock négatif autorisé mais pas de liv des ruptures
       # --> calcul du stock disponible
       #Elsif [F:ITM]NEGSTO<>2 | ([F:ITM]NEGSTO=2 & GSHTDLV<>2)
       Elsif ([F:ITM]NEGSTO<>2 & GSHTDLV<>3) | ([F:ITM]NEGSTO=2 & GSHTDLV<2)
          # Lecture cumuls article
          Read [ITV]ITV0=[F:ITM]ITMREF;[M:SDH0]STOFCY
          If fstat Raz [F:ITV] Endif
          # Lecture de la règle de gestion à utiliser
          Call LECSRU([M:SDH0]STOFCY,[F:ITM]TCLCOD,[M:SDH0]TRSTYP,
&                     [M:SDH0]TRSCOD,"",WRET) From STKLIB
          If WRET<>0 OK=0 : Return Endif
          # Statuts autorisés par la règle de gestion
          If find([F:SRU]AUZSTA,1,3,5,7) WA=1  Endif
          If find([F:SRU]AUZSTA,2,3,6,7) WQ=1  Endif
          If find([F:SRU]AUZSTA,4,5,6,7) WR=1  Endif
          WSTA = WA+2*WQ+4*WR

          # Calcul stock disponible
          Call STODISTOT("",1,WSTA,"",WSTUDIS) From STKLIB
          # Pas de disponible --> rien à livrer
          If WSTUDIS <= 0
             OK=0 : GERR=1
             GMESSAGE=mess(27,159,1)-[F:STA]ITMREF-":"-mess(126,192,1)
             Call ERREUR(GMESSAGE) From GESECRAN
             Raz WQTYSTU,WQTY
             Return
             # Disponible < qte à livrer ---> qte à livrer = disponible
          Elsif WSTUDIS < WQTYSTU
             WQTYSTU = WSTUDIS
             WQTY    = WQTYSTU/WSAUSTUCOE
          Endif
       Endif
   Endif
Endif

#--- La sélection est correcte

# Sauvegarde du lien entre ligne document et écran travail
[L]WSTOSEQ = [M:SDH1]WSTOSEQ([M:SDH1]NBLIG)
# Ouverture de la ligne
nolign = [M:SDH1]NBLIG
Insa nolign,1,[M:SDH1]NBLIG [M:SDH1]NBLIG
[M:SDH1]NBLIG += 1
nolign = [M:SDH1]NBLIG
NOL = nolign-1
status = 0

[M:SDH1]STU(NOL)       = [F:ITM]STU
[M:SDH1]SAU(NOL)       = WSAU
[M:SDH1]SAUSTUCOE(NOL) = WSAUSTUCOE
[M:SDH1]DACSAUCOE(NOL) = WDAC

[M:SDH1]QTYSTU(NOL)    = WQTYSTU
[M:SDH1]QTY(NOL)       = WQTY

# Alimentation flag ligne issue d'un manquant sous-traitant
[M:SDH1]STOREOFLG(NOL) = 2
# Alimentation lien séquence allocation
[M:SDH1]SEQ(NOL)       = [F:STA]SEQ

# Alimentation chrono stock            : # 92919 : Lock pb when cancel after picking
[M:SDH1]STOCOU(NOL)    = [F:STA]STOCOU : # 92919

# Alimentation de la classe [M:SDH1] de la ligne
Call ALIREOSDH([F:STA]ITMREF,NOL) From TRTVENLIV

[M:SDH1]VCRTYPORI(NOL) = [F:STA]VCRTYP
[M:SDH1]VCRNUMORI(NOL) = [F:STA]VCRNUM
[M:SDH1]VCRLINORI(NOL) = [F:STA]VCRLIN
[M:SDH1]VCRSEQORI(NOL) = [F:STA]VCRSEQ

# Récupération du lien entre ligne document et écran travail
[M:SDH1]WSTOSEQ(NOL) = [L]WSTOSEQ

Call LINNUM("SDDLIN") From TABLEAUX

# Calculs prix net, marge et maj montants livrés et poids
GNETMAR=0
Call ALICLCAMT([M:SDH1]ITMREF(NOL),[M]QTY(NOL),NOL,"SDH1",[M:SDH1]CLCAMT1(NOL),
&              [M:SDH1]CLCAMT2(NOL)) From TRTX3
Call CLCNETPRI([M:SDH1]QTY(NOL),[M:SDH1]CUR, NOL)From TRTVENPRI
Call CLCPFM([M:SDH0]STOFCY,[M:SDH1]PRITYP,[M:SDH0]CHGTYP,[M:SDH1]SHIDAT,
&           [M:SDH1]CUR,NOL,1) From TRTVENPRI
Call APRES_LIGNE(NOL,0) From SUBSDHB
GNETMAR=1

Raz GOUVSOR
# La ligne de livraison est-elle complète du point de vue stock
If [M]STOMGTCOD(NOL)<>1
   # Si stock à sortir non encore déterminé, init emplacement par défaut
   If dim([M:SDH1]LOC)>0 & [M:SDH1]WSTOSEQ(NOL)=0
      Call STKINIEMPS([M:SDH1]LOC(NOL)) From STKLOC
   Endif
   # Alimentation de [M:ALP]
   Gosub ALI_ALP From SUBSDH
   # Détermination du stock à sortir (automatisme, saisie)
   Call OUVSOR("SDH1",NOL,[M:SDH1]NBLIG,[M:SDH1]WSTOSEQ(NOL),GSLTSTKFLG,WRET)
&              From STKSOR
   If WRET=1 Endif
Endif

nolign  = NOL+1

Return

########################################################################
$AB_TRT
Rollback
Return

########################################################################
$REAJUSTE_QTY
#---------------------------------------------
# TS : réajustement qté en unité vente entière
#---------------------------------------------

GPOINT = "NO_REAJUST" : Gosub ENTREE From EXEFNC
If GOK=0 : GOK=1 :  Return : Endif

If WSAU<>[F:ITM]STU

   # Bug 29257
   WQTYARR = WQTY
   Call QTEARR(WQTYARR,WSAU) From TRTDIV
   If WQTYARR=WQTY Return Endif

   Call CTRQTYPCU(WSAU,WSAUSTUCOE,WQTYSTU,WQTYARR) From STKLIB
   If WQTYARR<>WQTYSTU
      WQTYSTU = WQTYARR
      WQTY    = WQTYSTU/WSAUSTUCOE
   Endif
Endif
Return
#######################################################################
#--CPO 88262
$CTL_BPNAM
Local Char WTEMP_BPAADD(GLONADR) # Issue 114429 - 2016-02-29 by CPO : Different delivery address on order line and picking tickets

  #--Cohérence client livré
  #--Contrôle à faire sous les mêmes conditions que les BPIEECNUM/EECLOC/EECICT
  #--Car ces informations peuvent avoir été initialisées par la ligne de commande
  #--(voir explication plus haut CPO 87919)
  # Issue 114429 - 2016-02-29 by CPO : Different delivery address on order line and picking tickets
  #--We also have to deal with the case [F:SOH]BPAADD<>[F:SOQ]BPAADD
  #  If find([F:SOQ]SOHNUM,[M]XSOHNUM(0..[M]NBLIG-1))<1
  #& & (   [F:SOQ]BPAADD=[M]BPAADD
  #& &  ( ([F:SOH]SOHCAT =4 & [F:SOC]BPAADD=[F:SOQ]BPAADD)
  #&     |([F:SOH]SOHCAT<>4 & [F:SOH]BPAADD=[F:SOQ]BPAADD)))
  If find([F:SOQ]SOHNUM,[M]XSOHNUM(0..[M]NBLIG-1))<1
& & (   [F:SOQ]BPAADD=[M]BPAADD)
  # End issue 114429
    #--Raison sociale client livré commande
    Local Char WSOHBPDNAM(GLONNAM)(0..1)
    Local Char WSDHBPDNAM(GLONNAM)(0..1)
    [L]WSOHBPDNAM(0)=[F:SOH]BPDNAM(0)
    [L]WSOHBPDNAM(1)=[F:SOH]BPDNAM(1)
    # Issue 114429 - 2016-02-29 by CPO : Different delivery address on order line and picking tickets
    WTEMP_BPAADD=[F:SOH]BPAADD
    If [F:SOH]BPAADD<>[F:SOQ]BPAADD
      Raz [L]WSOHBPDNAM(0),[L]WSOHBPDNAM(1)
      WTEMP_BPAADD=[F:SOQ]BPAADD
    Endif
    # End issue 114429
    If [L]WSOHBPDNAM(0)="" and [L]WSOHBPDNAM(1)="" :# Issue X3-39478
      #--Il faut lire à partir du client livré de la commande
      If clalev([F:BPDW])=0 : Local File BPDLVCUST [BPDW] : Endif
      # Issue 114429 - 2016-02-29 by CPO : Different delivery address on order line and picking tickets
      #If [F:BPDW]BPCNUM<>[F:SOH]BPCORD or [F:BPDW]BPAADD<>[F:SOH]BPAADD
      #  Read [F:BPDW]BPD0=[F:SOH]BPCORD;[F:SOH]BPAADD
      #  If fstat : Raz [F:BPDW] : Endif
      #Endif
      If [F:BPDW]BPCNUM<>[F:SOH]BPCORD or [F:BPDW]BPAADD<>WTEMP_BPAADD
        Read [F:BPDW]BPD0=[F:SOH]BPCORD;WTEMP_BPAADD
        If fstat : Raz [F:BPDW] : Endif
      Endif
      # End issue 114429
      [L]WSOHBPDNAM(0)=[F:BPDW]BPDNAM(0)
      [L]WSOHBPDNAM(1)=[F:BPDW]BPDNAM(1)
    Endif
    #--Raison sociale client livré livraison
    [L]WSDHBPDNAM(0)=[M:SDH0]BPDNAM
    [L]WSDHBPDNAM(1)=[M:ADB2]BPRNAM(1)
    If [L]WSDHBPDNAM(1)=""
      #--Il faut lire à partir du client livré de la livraison
      If clalev([F:BPDW])=0 : Local File BPDLVCUST [BPDW] : Endif
      If [F:BPDW]BPCNUM<>[M:SDH0]BPCORD or [F:BPDW]BPAADD<>[M:SDH0]BPAADD
        Read [F:BPDW]BPD0=[M:SDH0]BPCORD;[M:SDH0]BPAADD
        If fstat : Raz [F:BPDW] : Endif
      Endif
      [L]WSDHBPDNAM(1)=[F:BPDW]BPDNAM(1)
    Endif
    #--Contrôle cohérence :
    If (([L]WSDHBPDNAM(0)<>"" & [L]WSOHBPDNAM(0)<>"" & [L]WSOHBPDNAM(0)<>[L]WSDHBPDNAM(0))  or
&       ([L]WSDHBPDNAM(1)<>"" & [L]WSOHBPDNAM(1)<>"" & [L]WSOHBPDNAM(1)<>[L]WSDHBPDNAM(1)))
      OK=0 : GERR=1
      GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&       format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(101,192,1)+"\"+ mess(351,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
      Return
    Endif
  Endif
  #--Cohérence client facture
  If find([F:SOQ]SOHNUM,[M]XSOHNUM(0..[M]NBLIG-1))<1 : # 105083 : Ctrl à faire uniquement pour la 1ère ligne de la cde
      Local Char WSOHBPINAM(GLONNAM)(0..1)
      Local Char WSDHBPINAM(GLONNAM)(0..1)
      [L]WSOHBPINAM(0)=[F:SOH]BPINAM(0)
      [L]WSOHBPINAM(1)=[F:SOH]BPINAM(1)
      # FGR 16/01/2013 : X3SUIVI95700 : Si l'un des deux est renseigné, ça n'est plus vide
      #If [L]WSOHBPINAM(0)="" or [L]WSOHBPINAM(1)=""
      If [L]WSOHBPINAM(0)="" and [L]WSOHBPINAM(1)=""
        #--Il faut lire à partir du tiers client de la commande
        If clalev([F:BPRW])=0 : Local File BPARTNER [BPRW] : Endif
        If [F:BPRW]BPRNUM<>[F:SOH]BPCINV
          Read [F:BPRW]BPR0=[F:SOH]BPCINV
          If fstat : Raz [F:BPRW] : Endif
        Endif
        [L]WSOHBPINAM(0)=[F:BPRW]BPRNAM(0)
        [L]WSOHBPINAM(1)=[F:BPRW]BPRNAM(1)
      Endif
      #--Raison sociale client facture livraison
      [L]WSDHBPINAM(0)=[M:SDH0]BPINAM
      #--04.03.2013 Corr ection complémentaire suite détection pb par LD
      #[L]WSDHBPINAM(1)=[M:ADB3]BPRNAM(0) : # LD
      [L]WSDHBPINAM(1)=[M:ADB3]BPRNAM(1)  : # LD
      If [L]WSDHBPINAM(1)=""
        #--Il faut lire à partir du client livré de la livraison
        If clalev([F:BPRW])=0 : Local File BPARTNER [BPRW] : Endif
        If [F:BPRW]BPRNUM<>[M:SDH0]BPCINV
          Read [F:BPRW]BPR0=[M:SDH0]BPCINV
          If fstat : Raz [F:BPRW] : Endif
        Endif
        [L]WSDHBPINAM(1)=[F:BPRW]BPRNAM(1)
      Endif
      #--Contrôle cohérence :
      If (([L]WSDHBPINAM(0)<>"" & [L]WSOHBPINAM(0)<>"" & [L]WSOHBPINAM(0)<>[L]WSDHBPINAM(0))  or
&         ([L]WSDHBPINAM(1)<>"" & [L]WSOHBPINAM(1)<>"" & [L]WSOHBPINAM(1)<>[L]WSDHBPINAM(1)))
        OK=0 : GERR=1
        GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:SOQ]ITMREF-
&           format$(GFMDAT,[F:SOQ]SHIDAT)+"\"+mess(101,192,1)+"\"+ mess(351,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
        Return
      Endif
  Endif                                              :  # 105083 : Ctrl à faire uniquement pour la 1ère ligne de la cde

Return

# X3-1152 : Non invoiceable deliveries
###########################################################################
# TRT_TASK      Determination of the quantity to deliver                  #
#               and feeding of the line of the delivery                   #
#-------------------------------------------------------------------------#
# Usage       : Picking nonbillable tasks from deliveries management      #
###########################################################################
$TRT_TASK
Local Integer WRUP, WRET, WSTA
Local Integer WA, WQ, WR
Local Decimal WQTY, WQTYSTU
Local Char    WSAU(GLONUOM)
Local Decimal WSAUSTUCOE
Local Decimal WOALQTYSTU
Local Decimal WSVGQTYSTU
Local Integer WSTOSEQ
Local Integer WNEGSTO

WNEGSTO = [F:ITM]NEGSTO

#- Determination of the quantity to deliver
WQTY       = [F:JTT]ITTQTY  ## Allocated quatity / Already delivered quantity??
WSAU       = [F:JTT]UOM
WQTYSTU    = WQTY
WSAUSTUCOE = 1
WOALQTYSTU = 0


Raz WRUP
If (WNEGSTO=2 & GSHTDLV=2) | GSHTDLV=3
   WRUP=1
Endif

WSVGQTYSTU = WQTYSTU
#-
If [F:SOQ]STOMGTCOD<>1
      # Détermination automatique du stock
      # allocation globale ou
      # allocation détaillée et qté allouée=0 ou qté rupture non livrable
      If GSLTSTKFLG=2
         # Chargement STOSORW par éxécution de l'algorithme
         [M:ALP]TRSTYP    = [M:SDH0]TRSTYP
         [M:ALP]TRSCOD    = [M:SDH0]TRSCOD
         [M:ALP]VCRTYP    = 4
         [M:ALP]STOFCY    = [M:SDH0]STOFCY
         [M:ALP]ITMREF    = [F:ITM]ITMREF
         [M:ALP]QTY       = WQTYSTU
         [M:ALP]TYPQTY    = 2
         [M:ALP]PCU       = WSAU
         [M:ALP]PCUSTUCOE = WSAUSTUCOE
         [M:ALP]BESDAT    = [M:SDH1]SHIDAT
         [M:ALP]DLVDAT    = [M:SDH1]DLVDAT
         [M:ALP]ALLDAT    = [0/0/0]
         [M:ALP]STOLOC    = ""
         [M:ALP]PECINTLOC = 2
         [M:ALP]PECSCOLOC = 1
         [M:ALP]PECPLFLOC = 2
         [M:ALP]PECCUNLOK = 1
         [M:ALP]FILSTO    = ""
         [M:ALP]LOT       = ""
         [M:ALP]LOC       = ""
         [M:ALP]STA       = ""
         If dim(GWRHOBY)>0 & GWRHOBY=2 & dim([M:SDH1]WRHE)>0
            [M:ALP]WRH = [M:SDH1]WRHE
         Else
            Raz [M:ALP]WRH
         Endif
         Raz [M:ALP]ALLQTY
         #Dlu client
         [M:ALP]BPRNUM    = [M:SDH0]BPCORD
         Raz WRET

         Call GENSTOSORW("SDH1",[M:SDH1]NBLIG,[M:SDH1]NBLIG,WRUP,"C",WRET)
&                        From STKSOR
         If WRET<>0
            Raz WQTYSTU,WQTY
            OK=0 : Return
         Elsif [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT=0
            Raz WQTYSTU,WQTY
            #OK=0 : GERR=1  : # 100104
            OK=0            : # 100104
            GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:ITM]ITMREF-
&                    format$(GFMDAT,[M:SDH1]SHIDAT)+"\"+mess(126,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
            Call ERREUR(GMESSAGE) From GESECRAN
            Return
         Else
            WQTYSTU = [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
            WQTY    = WQTYSTU/WSAUSTUCOE

            # Bug 29257
            If WQTYSTU=WSVGQTYSTU
               Call QTEARR(WQTY,WSAU) From TRTDIV
            Else
               #---------------------------------------------
               # TS : réajustement qté en unité vente entière
               #---------------------------------------------
               Gosub REAJUSTE_QTY
               # Si la qté a été réajustée, il faut diminuer STOSORW en conséquence
               If WQTYSTU < [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT
                  WQTA = [M:ALP]ALLQTY+[M:ALP]ALLQTYSHT-WQTYSTU
                  Call DIM_STOSORW([M:SDH1]NBLIG,"SDH1",[M:SDH0]STOFCY,WQTA,WRET) From STKSOR
               Endif
               # 95179 : Si qté en UV à 0 après réajustement, il n'y a rien à livrer
               If WQTY=0
                    Raz WQTYSTU,WQTY
                    #OK=0 : GERR=1  : # 100104
                    OK=0            : # 100104
                    GMESSAGE=[F:SOH]SOHNUM-mess(27,159,1)-[F:ITM]ITMREF-
&                            format$(GFMD,[M:SDH1]SHIDAT)+"\"+mess(126,192,1)
                    Call ERREUR(GMESSAGE) From GESECRAN
                    Return
               Endif
               # 95179
            Endif

         Endif
         # Si allocation globale, qté allouée origine=qté allouée (+qté rupture)
         If GALLTYP=1
            WOALQTYSTU = 0
         Endif

      # Sinon pas de détermination automatique du stock et
      # stock négatif interdit ou stock négatif autorisé mais pas de liv des ruptures
      # allocation globale ou
      # allocation détaillée et qté allouée=0 ou qté rupture non livrable
      # --> calcul du stock disponible
      #Elsif WNEGSTO<>2 | (WNEGSTO=2 & GSHTDLV<>2)
      Elsif (WNEGSTO<>2 & GSHTDLV<>3) | (WNEGSTO=2 & GSHTDLV<2)
         # Lecture cumuls article
         Read [ITV]ITV0=[F:ITM]ITMREF;[M:SDH0]STOFCY
         If fstat Raz [F:ITV] Endif
         # Lecture de la règle de gestion à utiliser
         Call LECSRU([M:SDH0]STOFCY,[F:ITM]TCLCOD,[M:SDH0]TRSTYP,
&                    [M:SDH0]TRSCOD,"",WRET) From STKLIB
         If WRET<>0 OK=0 : Return Endif
         # Statuts autorisés par la règle de gestion
         If find([F:SRU]AUZSTA,1,3,5,7) WA=1  Endif
         If find([F:SRU]AUZSTA,2,3,6,7) WQ=1  Endif
         If find([F:SRU]AUZSTA,4,5,6,7) WR=1  Endif
         WSTA = WA+2*WQ+4*WR
         # Calcul stock disponible
         Call STODISTOT("",1,WSTA,"",WSTUDIS) From STKLIB
#         # On rajoute l'allouée global
#         If GALLTYP=1 WSTUDIS+=[F:SOQ]ALLQTYSTU Endif

         # Pas de disponible --> rien à livrer
         If WSTUDIS <= 0
            #OK=0 : GERR=1  : # 100104
            OK=0            : # 100104
            GMESSAGE=[F:JTT]OPPNUM-mess(27,159,1)-[F:ITM]ITMREF-
&                    format$(GFMDAT,[M:SDH1]SHIDAT)+"\"+mess(126,192,1) :#--CPO 83985 GFMDAT au lieu de GFMD
#            If find([F:SOH]DME,2,3) GMESSAGE -="\"-mess(105,197,1) Endif
            Call ERREUR(GMESSAGE) From GESECRAN
            Raz WQTYSTU,WQTY
            Return
            # Disponible < qte à livrer ---> qte à livrer = disponible
         Elsif WSTUDIS < WQTYSTU
            WQTYSTU = WSTUDIS
            WQTY    = WQTYSTU/WSAUSTUCOE

            # Bug 29257
            If WQTYSTU=WSVGQTYSTU
               Call QTEARR(WQTY,WSAU) From TRTDIV
            Else
               #---------------------------------------------
               # TS : réajustement qté en unité vente entière
               #---------------------------------------------
               Gosub REAJUSTE_QTY
               # 95179 : Si qté en UV à 0 après réajustement, il n'y a rien à livrer
               If WQTY=0
                  #OK=0 : GERR=1  : # 100104
                  OK=0            : # 100104
                  GMESSAGE=[F:JTT]OPPNUM-mess(27,159,1)-[F:ITM]ITMREF-
&                          format$(GFMD,[M:SDH1]SHIDAT)+"\"+mess(126,192,1)
#                  If find([F:SOH]DME,2,3) GMESSAGE -="\"-mess(105,197,1) Endif
                  Call ERREUR(GMESSAGE) From GESECRAN
                  Raz WQTYSTU,WQTY
                  Return
               Endif
               # 95179
            Endif

         Endif
         # Si allocation globale, qté allouée origine=qté allouée (+qté rupture)
         If GALLTYP=1
            WOALQTYSTU = 0
         Endif
      Endif
  Endif




## Saving the link between document and line screen work
WSTOSEQ=[M:SDH1]WSTOSEQ([M:SDH1]NBLIG)
## Opening of the line
nolign = [M:SDH1]NBLIG
Insa nolign,1,[M:SDH1]NBLIG [M:SDH1]NBLIG
[M:SDH1]NBLIG +=1
nolign = [M:SDH1]NBLIG
NOL = nolign-1
status=0

## Feeding of the class [M:SDH1] of the line
[M:SDH1]ITMREF(NOL) = [F:JTT]ITMREF
[M:SDH1]LINTYP(NOL)=1
Call ALIARTSDH ([F:JTT]ITMREF,NOL) From TRTVENLIV
[M:SDH1]SAU(NOL)=[F:JTT]UOM
[M:SDH1]SAUSTUCOE(NOL)=1
[M:SDH1]QTY(NOL)=WQTY
[M:SDH1]QTYSTU(NOL)=WQTYSTU
[M:SDH1]WSTOSEQ(NOL) = [L]WSTOSEQ
[M:SDH1]UNTWEI(NOL) = [F:ITM]ITMWEI
[M:SDH1]VCRTYPORI(NOL)=40
[M:SDH1]VCRNUMORI(NOL)=[F:JTT]TASCOD
[M:SDH1]VCRLINORI(NOL)=[F:JTT]ITTSEQ
[M:SDH1]DPJT(NOL)=[F:JTT]OPPNUM+"!"+[F:JTT]TASCOD
Call LINNUM("SDDLIN") From TABLEAUX

## Calculation of Net Price, margin & updating of delivered amounts and weights
GNETMAR=0

Call ALICLCAMT([M:SDH1]ITMREF(NOL),[M]QTY(NOL),NOL,"SDH1",[M:SDH1]CLCAMT1(NOL),
&              [M:SDH1]CLCAMT2(NOL)) From TRTX3
Call RECH_TARIF(1,[M]ITMREF(NOL),NOL,[M]QTY(NOL),"SDH",[M]GROPRI(NOL))
&                  From TRTVENTAR

Call CLCNETPRI([M:SDH1]QTY(NOL),[M:SDH1]CUR, NOL)From TRTVENPRI
Call CLCPFM([M:SDH0]STOFCY,[M:SDH1]PRITYP,[M:SDH0]CHGTYP,[M:SDH1]SHIDAT,
&           [M:SDH1]CUR,NOL,1) From TRTVENPRI


# La ligne de livraison est-elle complète du point de vue stock
Raz GOUVSOR
If [M]STOMGTCOD(NOL)<>1
   # Si stock à sortir non encore déterminé, init emplacement par défaut
   If dim([M:SDH1]LOC)>0 & [M:SDH1]WSTOSEQ(NOL)=0
      Call STKINIEMPS([M:SDH1]LOC(NOL)) From STKLOC
   Endif
   # Alimentation de [M:ALP]
   Gosub ALI_ALP From SUBSDH
   # Détermination du stock à sortir (automatisme, saisie)
   Call OUVSOR("SDH1",NOL,[M:SDH1]NBLIG,[M:SDH1]WSTOSEQ(NOL),GSLTSTKFLG,WRET)
&              From STKSOR
   If WRET=1 Endif
Endif

Call APRES_LIGNE(NOL,0) From SUBSDHB
#--/CPO
GNETMAR=0

Return
# X3-1152 : Non invoiceable deliveries

