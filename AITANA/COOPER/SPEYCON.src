#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
  When "DEBUT"     :   Gosub DEBUT
  When "BOUTON"    :   Gosub BOUTON
Endcase
Return


################################################
$DEBUT
# Limpio pantalla
Raz [M:YCON]
[M:YCON]PIE = 0

# Abro tablas
If !clalev([YY1])   : Local File YCONSIGNA     [YY1]   : Endif
If !clalev([YY2])   : Local File STOJOU        [YY2]   : Endif

# Cargo pantalla
[M:YCON]FACTURA   = [M:PIH0]NUM
[M:YCON]FACLIN    = nolign * 1000
[M:YCON]RECEPCION = [M:PIH3]NUMORI(nolign-1)
[M:YCON]RECLIN    = [M:PIH3]LINORI(nolign-1)

Local Integer J
# Primero los que ya están registrados
If [M:YCON]FACTURA <> ""
  For [YY1] Where [YY1]FACTURA = [M:YCON]FACTURA and [YY1]FACLIN = [M:YCON]FACLIN
    [M:YCON]SEL(J)       = 2
    [M:YCON]LOTE(J)      = [YY1]LOTE
    [M:YCON]SUBLOTE(J)   = [YY1]SUBLOTE
    [M:YCON]CADUCIDAD(J) = [YY1]CADUCIDAD
    [M:YCON]LOTPROV(J)   = [YY1]LOTPROV
    [M:YCON]FACNUMLIN(J) = [YY1]FACTURA
    [M:YCON]FACLINLIN(J) = [YY1]FACLIN
    J+=1
  Next
Endif

# Ahora el resto de sublotes que NO estén en otras facturas
For [YY2] Where [YY2]TRSTYP = 3 and [YY2]VCRNUM = [M:YCON]RECEPCION and [YY2]VCRLIN = [M:YCON]RECLIN and [YY2]ITMREF = [M:PIH3]ITMREF(nolign-1)
  Read [YY1]YCON1=[YY2]LOT;[YY2]SLO;[M:YCON]RECEPCION;[M:YCON]RECLIN
  If fstat <> 0
    # Compruebo ahora que el mismo lote no lo haya ya traído a la pantalla
    Local Integer LIN, YA_EN_MASK
    For LIN=0 To J+1
      If LIN <> J
        If [M:YCON]LOTE(LIN) = [YY2]LOT
          YA_EN_MASK = 2
          Break
        Endif
      Endif
    Next
    If YA_EN_MASK <> 2
      [M:YCON]SEL(J)       = 1
      [M:YCON]LOTE(J)      = [YY2]LOT
      [M:YCON]SUBLOTE(J)   = [YY2]SLO
      [M:YCON]CADUCIDAD(J) = [YY2]SHLDAT
      [M:YCON]LOTPROV(J)   = [YY2]BPSLOT
      [M:YCON]FACNUMLIN(J) = ""
      [M:YCON]FACLINLIN(J) = 0
      J+=1
    Endif
  Endif
Next

Close Local File [YY1],[YY2]
[M:YCON]PIE = J
Sorta [M:YCON]PIE [M:YCON]PIE Order By [M:YCON]LOTE(indice) Asc
Affzo [M:YCON]
Return


################################################
$BOUTON
If BOUT = 'Z'
  If !clalev([YY1])   : Local File YCONSIGNA     [YY1]   : Endif

  # Primero borro
  Trbegin [YY1]
    For [YY1] Where [YY1]FACTURA = [M:YCON]FACTURA and [YY1]FACLIN = [M:YCON]FACLIN
      Delete [YY1] Curr
    Next
  Commit

  # Ahora escribo
  Local Integer I
  For I=0 To [M:YCON]PIE-1
    If [M:YCON]SEL(I) = 2
      Raz [YY1]
      [YY1]FACTURA   = [M:YCON]FACTURA
      [YY1]FACLIN    = [M:YCON]FACLIN
      [YY1]RECEPCION = [M:YCON]RECEPCION
      [YY1]RECLIN    = [M:YCON]RECLIN
      [YY1]LOTE      = [M:YCON]LOTE(I)
      [YY1]SUBLOTE   = [M:YCON]SUBLOTE(I)
      [YY1]CADUCIDAD = [M:YCON]CADUCIDAD(I)
      [YY1]LOTPROV   = [M:YCON]LOTPROV(I)
      Trbegin [YY1]
       Write [YY1]
      Commit
    Endif
  Next

  Close Local File [YY1]

  # Cierro la pantalla
  FIN = 1
Endif
Return

