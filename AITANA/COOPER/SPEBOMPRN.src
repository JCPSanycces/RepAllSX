# ESPECÍFICO DEL INFORME
#####################################################################################
# Src: SPEBOMPRN
#-------------------------------------------------------------------------------------
# Proyecto: Cooper
#-------------------------------------------------------------------------------------
# Version: v11
#-------------------------------------------------------------------------------------
# CSA025 - Ajustes report BOMPRN
# Fecha inicio CSA025: 02/12/2019
# Desarrollador: JCH
# Código de desarrollo: CSA025
# Descripción del desarrollo: Modificar la impresión del documento para que aparezcan también
# los componentes de las estructuras de subcontratación
# Fecha: 02/12/2019
# Codigo Actividad: YCS25
#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "EXEC"       : Gosub EXEC From BOMPRN
  When "INIT"       : Gosub INIT From BOMPRN
  When "CONTROLE"   : Gosub CONTROLE From BOMPRN
  When "TERMINE"    : SAI = 1
  When "SORTIE"     :
  When "DEBUT"      : Gosub DEBUT From BOMPRN
  When "SUP"        : Gosub EFFACE From BOMPRN : SAI=1
  When "END"        : PARAM(1) = "END"
  When "BEFWRIBOP"  : Gosub BEFWRIBOP
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################

##############################################################
######################    ETIQUETAS    #######################
##############################################################
# punto de entrada para ańadir  en la tabla BOMPRN si el artículo es de subcontratación (BOMALTTYP=3)
$BEFWRIBOP
  #[F:BOP]YBOMALTTYP = [F:BOH]BOMALTTYP
If !clalev([BOM]): Local File BOM: Endif
Read [BOM]BOM0=[F:BOP]CPNITMREF;65;3
	If !fstat
		INFBOX("YES")
		[F:BOP]YBOMALTTYPTYP=3
	Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################










