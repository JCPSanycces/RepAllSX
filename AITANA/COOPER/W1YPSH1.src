#<AdxTL>@(#)0.0.0.0 $Revision$
# Supervisor
# Gestión de la máscara YPSH1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$HORODAT
Local Date    A_DATE
Local Char    A_HEURE(10) , A_USER(10)
Local Char    A_STAMP(15)
A_DATE  = [05/02/2019]
A_HEURE = "17:18:27"
A_USER  = "AIT07"
A_STAMP = "20190205171827"
Return

$TITRES
Return

$CHG_FMT
Case zoncou
 When "NBBPS"
  If [M]NBBPS=0
  Endif
 When "NBITM"
  If [M]NBITM=0
  Endif
Endcase
Return

$VISU
Local Integer A_REPONSE
Global Integer GPRE_VIEW
If dim(A_WINDPREV)<=0 : Local Char A_WINDPREV(30) : Endif
Local Mask YPSH1 [YPSH1]
Gosub HORODAT
Local Inpbox "YPSH1" From GFONCTION At A_STAMP With A_WINDPREV Mask [YPSH1] As [SIM_]
Grizo [YPSH1]5
Grizo [YPSH1]10
Boxact [SIM_]
Gosub TITRES
Boxinp [SIM_] Using A_REPONSE
Close Local Inpbox [SIM_]
Close Local Mask [YPSH1]
Kill GPRE_VIEW
Return

$HARDCOP
Local Integer X1(0..14),X2(0..14),Y1(0..14),Y2(0..14)
X1(0)=1 : X2(0)=74 : Y1(0)=1 : Y2(0)=13
X1(1)=1 : X2(1)=74 : Y1(1)=14 : Y2(1)=25
Return

$ON_PSHNUM
Return

$ON_BPSNUM
Onevent CONTROL Call C_BPSNUM(zc) From W1YPSH1
Onevent BEFORE_INPUT Call AS_BPSNUM(zc) From W1YPSH1
Onevent AFTER_CHANGE Gosub AMM_BPSNUM From W1YPSH1
Return

Subprog AS_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Integer INDIC : INDIC = indice
Raz mkstat
Call TEXTE(1515,GBOUT1) From OBJDIV
Call TEXTE(6109,GBOUTS) From OBJDIV
Call TEXTE(12276,GBOUTP) From OBJDIV
Call TEXTE(16134,GBOUTA) From OBJDIV
Onkey 129 Titled GBOUT1 Call B1_BPSNUM(zc) From W1YPSH1
Onkey   2 Titled GBOUTS Call S_BPSNUM(zc) From W1YPSH1
Onkey 144 Titled GBOUTP Call P_BPSNUM(zc) From W1YPSH1
Onkey 146 Titled GBOUTA Call SA_BPSNUM(zc) From W1YPSH1
Gosub _AFF
End

Subprog C_BPSNUM(VALEUR)
Variable Char    VALEUR()
## Action %OBLIG
If vireblc(VALEUR,2)=""
 mkstat = 1 : GMESSAGE = mess(10,123,1)
Endif
If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
If !GWEBSERV
 If !mkstat
  ## Action BPSCHOICE
  Local Char    PARMSK(250)(1..20) , SAVACT(20)
  SAVACT = GACTION : GACTION = "BPSCHOICE"
  Call S_TAB_CHAR(VALEUR,PARMSK,"BPSCHOICE","TRTSEL","") From GACTION
  GACTION = SAVACT
  If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
 Endif
Endif
If !mkstat
 ## Action %CNTOBJ
 Call CONTSEL("BPS","AB",VALEUR,"",mkstat) From CONTOBJ
 If mkstat : GERR = 1 : GZONE = "BPSNUM" : GZNUM = 3680 : Endif
Endif
Gosub _AFF
End

$AMM_BPSNUM
Call AM_BPSNUM(zc)
If !mkstat & GOBJET
 zoncou = "BPSNUM" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()
If !mkstat & evalue("dim("+clanam([M])+"ZBPSNUM)")>indice
 [M]BPSNUM(indice) = VALEUR
 Affzo ZBPSNUM(indice)
Endif
Gosub _AFF
End

Subprog S_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16)
PARMSK(1) = "BPS"
PARMSK(2) = "AB"
Call S_TAB_CHAR(VALEUR,PARMSK,"SELOBJ","SELOBJ","") From GACTION
Gosub _AFF
End

Subprog B1_BPSNUM(VALEUR)
Variable Char    VALEUR()
Call OBJET("BPS",VALEUR,"") From GOBJET
Gosub _AFF
End

Subprog SA_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Char PARMSK(250)(1..16) , SAVACT(20)
SAVACT = GACTION : GACTION = "SELOBJAW"
PARMSK(1) = "BPS"
Call SAISIE_CHAR(VALEUR,PARMSK,"DSELOBJAW","SELOBJAW","XWDSELOBJAW") From GSAISIE
GACTION = SAVACT
Gosub _AFF
End

Subprog P_BPSNUM(VALEUR)
Variable Char    VALEUR()
Local Char PAROBJ(250)
PAROBJ = ""
Call VISU("BPS",VALEUR,PAROBJ) From SUBAOP
Gosub _AFF
End

$ON_ZBPSNUM
Onevent BEFORE_AREA Gosub AV_ZBPSNUM From W1YPSH1
Return

$AV_ZBPSNUM
If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
Call LECTURE("BPS",num$([M]BPSNUM(indice)),"") From CONTOBJ
zc = [F:BPS]BPSNAM
Gosub _AFF
Return

$ON_PQHNUM
Onevent CONTROL Call C_PQHNUM(zc) From W1YPSH1
Return

Subprog C_PQHNUM(VALEUR)
Variable Char    VALEUR()
If !GWEBSERV
 ## Action CONTVCR
 Call CONTVCR(VALEUR) From TRTDIV
 If mkstat : GERR = 1 : GZONE = "PQHNUM" : GZNUM = 14418 : Endif
Endif
Gosub _AFF
End

$ON_YPLAZO
Onevent BEFORE_AREA Gosub AV_YPLAZO From W1YPSH1
Return

$AV_YPLAZO
Chgfmt [M]YPLAZO(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$ON_NETPRI
Onevent BEFORE_AREA Gosub AV_NETPRI From W1YPSH1
Return

$AV_NETPRI
If !GWEBSERV
 ## Action PARDEV
Endif
Gosub _AFF
Return

$ON_YSELEC
Onevent AFTER_CHANGE Gosub AMM_YSELEC From W1YPSH1
Onevent INIT_AREA Call D_YSELEC(zc) From W1YPSH1
Onevent BEFORE_INPUT Call AS_YSELEC(zc) From W1YPSH1
Return

Subprog D_YSELEC(VALEUR)
Variable Integer VALEUR
If varinit([M]YSELEC,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

Subprog AS_YSELEC(VALEUR)
Variable Integer VALEUR
Local Integer INDIC : INDIC = indice
Raz mkstat
If VALEUR<1
 VALEUR = 1
Endif
Gosub _AFF
End

$AMM_YSELEC
Call AM_YSELEC(zc)
If !mkstat & GOBJET
 zoncou = "YSELEC" : Gosub APRES_MODIF From =GPROGRAMME
Endif
Return

Subprog AM_YSELEC(VALEUR)
Variable Integer VALEUR
## Action SPE
Call AM_YSELEC(VALEUR) From SPEPSH
If mkstat : GERR = 1 : GZONE = "YSELEC" : GZNUM = 6109 : Endif
Gosub _AFF
End

$ON_YSOLPDAT
Onevent BEFORE_AREA Gosub AV_YSOLPDAT From W1YPSH1
Return

$AV_YSOLPDAT
Chgfmt [M]YSOLPDAT(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$ON_YRECDAT
Onevent BEFORE_AREA Gosub AV_YRECDAT From W1YPSH1
Return

$AV_YRECDAT
Chgfmt [M]YRECDAT(indice) With "DZ:"+GFMDAT
Gosub _AFF
Return

$ON_ITMREF
Return

$ON_ZITMREF
Onevent BEFORE_AREA Gosub AV_ZITMREF From W1YPSH1
Return

$AV_ZITMREF
If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif
Call LECTURE("ITM",num$([M]ITMREF(indice)),"") From CONTOBJ
zc = [F:ITM]DES1AXX
Gosub _AFF
Return

$ON_QTYPUU
Onevent BEFORE_AREA Gosub AV_QTYPUU From W1YPSH1
Return

$AV_QTYPUU
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find("",GUNITE(1..GNBUNT)),1))
Endif
Chgfmt [M]QTYPUU(indice) With "NPz:"+GUNTFMT
Gosub _AFF
Return

$ON_NETPRI1
Onevent BEFORE_AREA Gosub AV_NETPRI1 From W1YPSH1
Return

$AV_NETPRI1
If !GWEBSERV
 ## Action PARDEV
Endif
Gosub _AFF
Return

$ON_NETPRI2
Onevent BEFORE_AREA Gosub AV_NETPRI2 From W1YPSH1
Return

$AV_NETPRI2
If !GWEBSERV
 ## Action PARDEV
Endif
Gosub _AFF
Return

$ON_NETPRI3
Onevent BEFORE_AREA Gosub AV_NETPRI3 From W1YPSH1
Return

$AV_NETPRI3
If !GWEBSERV
 ## Action PARDEV
Endif
Gosub _AFF
Return

$ON_NETPRI4
Onevent BEFORE_AREA Gosub AV_NETPRI4 From W1YPSH1
Return

$AV_NETPRI4
If !GWEBSERV
 ## Action PARDEV
Endif
Gosub _AFF
Return

$ON_NETPRI5
Onevent BEFORE_AREA Gosub AV_NETPRI5 From W1YPSH1
Return

$AV_NETPRI5
If !GWEBSERV
 ## Action PARDEV
Endif
Gosub _AFF
Return

$CHG_STY
Return


