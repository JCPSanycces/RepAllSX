#######################################################################################
#PATCH: Ajustes de la pantalla de consumo de materiales VT
#######################################################################################

######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
# Traigo la descripción del artículo
If !clalev([YY2])   : Local File ITMMASTER  [YY2]   : Endif
Read [YY2]ITM0 = VALEUR
If fstat = 0
  [M:XAMT]YITMDES = [YY2]ITMDES1
Endif
Affzo [M:XAMT]YITMDES
Close Local File [YY2]
End


######################################################################################
Subprog AM_YROLLOS(VALEUR)
Variable Decimal VALEUR
# Propongo la cantidad
If VALEUR <> 0
  If !clalev([YY5])   : Local File STOCK  [YY5]   : Endif
  Filter [YY5] Where [YY5]ITMREF = [M:XAMT]ITMREF and [YY5]STOFCY = [M:XAMT]FCY and [YY5]LOT = [M:XAMT]LOT and [YY5]SLO = [M:XAMT]SLO
  Read [YY5] First
  If fstat = 0 and [YY5]PALNUM <> ''
    [M:XAMT]USEQTY = ar2((VALEUR * [YY5]QTYSTUORI)/val([YY5]PALNUM))
    Affzo [M:XAMT]USEQTY
  Endif
  Filter [YY5]
  Close Local File [YY5]
Endif
End


#####################################################################################
Subprog AS_YPDTE(VALEUR)
Variable Decimal VALEUR
# No permito la entrada a este campo
mkstat = 2
End

######################################################################################
Subprog AM_SLO(VALEUR)
Variable Char    VALEUR()
# Alimento el campo cantidad como la cantidad del lote - sublote disponible. Propongo también el número de rollos
If !clalev([YY1])   : Local File STOCK     [YY1]   : Endif
If !clalev([YY2])   : Local File STOJOU    [YY2]   : Endif
If !clalev([YY3])   : Local File MFGMATTRK [YY3]   : Endif

Local Integer ROLLOS_INI, ROLLOS_CON, ENTRO

# Primero realizo la búsqueda con sublote
Filter [YY1] Where [YY1]ITMREF = [M:XAMT]ITMREF and [YY1]STA = 'A' and [YY1]LOT = [M:XAMT]LOT and [YY1]SLO = VALEUR
Read [YY1] First
If fstat = 0
  ENTRO = 2
  [M:XAMT]USEQTY  = [YY1]QTYSTUACT - [YY1]CUMALLQTY
  ROLLOS_INI = val([YY1]PALNUM)
  Affzo [M:XAMT]USEQTY
Endif
Filter [YY1]

If ENTRO = 2
  For [YY2] Where [YY2]ITMREF = [M:XAMT]ITMREF and [YY2]LOT = [M:XAMT]LOT and [YY2]SLO = VALEUR
    Read [YY3]MKM0 = [YY2]VCRNUM;[YY2]VCRLIN
    If fstat = 0
      ROLLOS_CON += [YY3]YROLLOS
    Endif
  Next
Endif

# Ahora la refuerzo sin sublote
If ENTRO = 0
  Filter [YY1] Where [YY1]ITMREF = [M:XAMT]ITMREF and [YY1]STA = 'A' and [YY1]LOT = [M:XAMT]LOT
  Read [YY1] First
  If fstat = 0
    [M:XAMT]USEQTY  = [YY1]QTYSTUACT - [YY1]CUMALLQTY
    ROLLOS_INI = val([YY1]PALNUM)
    Affzo [M:XAMT]USEQTY
  Endif
  Filter [YY1]

  For [YY2] Where [YY2]ITMREF = [M:XAMT]ITMREF and [YY2]LOT = [M:XAMT]LOT
    Read [YY3]MKM0 = [YY2]VCRNUM;[YY2]VCRLIN
    If fstat = 0
      ROLLOS_CON += [YY3]YROLLOS
    Endif
  Next
Endif

[M:XAMT]YROLLOS = ROLLOS_INI - ROLLOS_CON
If [M:XAMT]YROLLOS < 0 : [M:XAMT]YROLLOS = 0 : Endif
Affzo [M:XAMT]YROLLOS

Close Local File [YY1],[YY2],[YY3]
End


######################################################################################
Subprog AM_LOT(VALEUR)
Variable Char    VALEUR()
# Si pongo valor y también en sublote, lanzo acción después modif del sublote
[M:XAMT]LOT = VALEUR
If VALEUR <> ""
  Call AM_SLO([M:XAMT]SLO)
Endif
End


######################################################################################
Subprog C_YROLLOS(VALEUR)
Variable Decimal VALEUR
# No puedo introducir una cantidad superior a la propuesta
If VALEUR > [M:XAMT]YROLLOS
  Errbox "No se puede introducir más de " + num$([M:XAMT]YROLLOS) + " rollos consumidos"
  VALEUR = [M:XAMT]YROLLOS
  mkstat = 2
Endif
End


######################################################################################

