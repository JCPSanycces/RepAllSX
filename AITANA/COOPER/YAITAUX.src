#<AdxTL>@(#)0.0.0.0 $Revision$ 
#################################################################
#                         AUXILIAR AITANA                       #
#################################################################
#MAJ_POQ: Regularizo campos SPE de la línea de los pedidos de compra
####################################################################

#########################################################
$MAJ_PROQ

If !clalev([ZZ0])   : Local File ORDERS    [ZZ0]   : Endif
If !clalev([ZZ1])   : Local File PORDERQ   [ZZ1]   : Endif
If !clalev([ZZ2])   : Local File PORDERP   [ZZ2]   : Endif
If !clalev([ZZ3])   : Local File MFGITM    [ZZ3]   : Endif


For [ZZ1] Where ([ZZ1]POHNUM >= "JPC190002" and [ZZ1]POHNUM < "JPC190010")
  Local Char ORIGEN
  Local Char ARTICULO  : ARTICULO = [ZZ1]ITMREF
  Local Char VCRORI
  Local Char ITMEST
  Local Char PJT_ORD

  Read [ZZ2]POP0 = [ZZ1]POHNUM;[ZZ1]POPLIN;[ZZ1]POQSEQ
  If fstat = 0
    PJT_ORD = [ZZ2]PJT
  Endif

  Filter [ZZ0] Where [ZZ0]VCRTYP = 14 and ([ZZ1]POHNUM >= "JPC190002" and [ZZ1]POHNUM < "JPC190010") and [ZZ0]VCRLIN = [ZZ1]POPLIN and [ZZ0]ITMREF = [ZZ1]ITMREF and [ZZ0]PJT = PJT_ORD
  Read [ZZ0] First
  If fstat = 0
    ORIGEN   = [F:ZZ0]ITMREFORI
    VCRORI   = [F:ZZ0]VCRNUMORI
  Endif
  Filter [ZZ0]

  If ORIGEN = ""
    Filter [ZZ3] Where [ZZ3]MFGNUM= [ZZ1]YVCRORI and [ZZ3]PJT = PJT_ORD
    Read [ZZ3] First
    If fstat = 0
      ORIGEN   = [F:ZZ3]ITMREF
    Endif
    Filter [ZZ3]
  Endif

  If ORIGEN = "" AND PJT_ORD <> ""
    Filter [ZZ3] Where [ZZ3]PJT = PJT_ORD
    Read [ZZ3] First
    If fstat = 0
      ORIGEN   = [F:ZZ3]ITMREF
      VCRORI   = [F:ZZ3]MFGNUM
    Endif
    Filter [ZZ3]
  Endif

  If ORIGEN = ""
    Call ARTICULO_ORIGEN([ZZ1]ITMREF,VCRORI,ORIGEN) From YAITLIB
  Endif

  If ORIGEN <> ""
    Call ARTICULO_BOM(ORIGEN,PJT_ORD,ITMEST) From YAITLIB
  Endif

  If VCRORI <> ""
    Local Char VSUBC
    Call ARTICULO_SUB(VCRORI,ITMEST,PJT_ORD,VSUBC) From YAITLIB
    If VSUBC <> ""
      VCRORI = VSUBC
    Endif
  Endif

  Local Char DES_BOM
  Call DESCRIP_BOM(ORIGEN,[ZZ1]ITMREF,DES_BOM) From  YAITLIB

  [ZZ1]YITMORI = ORIGEN
  If [ZZ1]YVCRORI = ""
    [ZZ1]YVCRORI = VCRORI
  Endif
  [ZZ1]YITMEST = ITMEST
  [ZZ1]YDESEST = DES_BOM

  Rewrite [ZZ1]
Next
Close Local File [ZZ0],[ZZ1],[ZZ2],[ZZ3]
End










