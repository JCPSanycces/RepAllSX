#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "LIENS"  :   Gosub LIENS
  When "LIENS_LIG"  :  Gosub LIENS_LIG
Endcase
Return

################################################
$LIENS_LIG
Gosub LIENS_LIG From SUBMFGA

Local Integer J
If [M:MFG1]PJT(LIG) <> ""
  For J=1 To len([M:MFG1]PJT(LIG))
   If mid$([M:MFG1]PJT(LIG),J,1)='!'
    Break
   Endif
  Next

  Local Char PROY : PROY = mid$([M:MFG1]PJT(LIG),1,J-1)
  Local Char TARE : TARE = mid$([M:MFG1]PJT(LIG),J+1,(len([M:MFG1]PJT(LIG))-len(mid$([M:MFG1]PJT(LIG),1,J))))

  Read [YCCP]YCCP0 = PROY;TARE
  If fstat = 0
    Read [YCCO]YCC0 = [YCCP]OPPNUM;[YCCP]ROUTEKEY
    If fstat = 0
     [M:MFG1]YCONCERTODAT(LIG) = [YCCO]DUEDAT
     Affzo [M:MFG1]YCONCERTODAT(LIG)
    Endif
  Endif

Endif

GPE = 1
Return


######################################
$LIENS
# Para JAE, cargo campos SPE de la pestaña de componentes. Lo pongo en esta acción para asegurarme que tenga las líneas de componentes ya mostrados en pantalla
If [M:MFG0]MFGFCY = 'JAE'
  Gosub LIENS From SUBMFGA
  Local Integer LINE

  If clalev([F:XX1]) = 0 : Local File MTOLINK  [XX1]  : Endif
  If clalev([F:XX2]) = 0 : Local File PORDER   [XX2]  : Endif
  If clalev([F:XX3]) = 0 : Local File PORDERQ  [XX3]  : Endif
  If clalev([F:XX4]) = 0 : Local File ORDERS   [XX4]  : Endif

  For LINE=0 To [M:MFG2]NBLIG-1
      Read [XX1]MLK0 = [M:MFG0]MFGFCY;[M:MFG2]ITMREF(LINE);10;[M:MFG0]MFGNUM;[M:MFG2]MFGLIN(LINE);[M:MFG2]BOMSEQ(LINE)
      If fstat = 0
        [M:MFG2]YPCOMPRA(LINE) = [XX1]RESSNUM
        Read [XX2]POH0 = [XX1]RESSNUM
        If fstat = 0
          [M:MFG2]YPROVEEDOR(LINE) = [XX2]BPRNAM
        Endif
        Affzo [M:MFG2]YPCOMPRA(LINE)
        Affzo [M:MFG2]YPROVEEDOR(LINE)
      Else
        # Saco la información del pedido de compra
        Filter [XX3] Where [XX3]ITMREF = [M:MFG2]ITMREF(LINE) and [XX3]YVCRORI = [M:MFG0]MFGNUM
        Read [XX3] First
        If fstat = 0
          [M:MFG2]YPCOMPRA(LINE) = '**' + [XX3]POHNUM
          Read [XX2]POH0 = [XX3]POHNUM
          If fstat = 0
            [M:MFG2]YPROVEEDOR(LINE) = [XX2]BPRNAM
          Endif
          Affzo [M:MFG2]YPCOMPRA(LINE)
          Affzo [M:MFG2]YPROVEEDOR(LINE)
        Else
          # Si no hay pedido de compra, verifico que haya una orden de subcontratación
          Filter [XX4] Where [XX4]VCRNUMORI = [M:MFG0]MFGNUM and [XX4]ITMREF = [M:MFG2]ITMREF(LINE) and [XX4]WIPTYP = 13
          Read [XX4] First
          If fstat = 0
            [M:MFG2]YPCOMPRA(LINE)   = [XX4]VCRNUM
            [M:MFG2]YPROVEEDOR(LINE) = [XX4]BPRNUM
          Endif
          Filter [XX4]
          Affzo [M:MFG2]YPCOMPRA(LINE)
          Affzo [M:MFG2]YPROVEEDOR(LINE)
        Endif
        Filter [XX3]
      Endif
      Filter [XX1]
  Next

  Close Local File [XX1],[XX2],[XX3],[XX4]

  GPE = 1
Endif
Return

