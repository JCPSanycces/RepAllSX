#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
    Case ACTION
        When "OUVRE"        : Gosub OUVRE            # Pone a 5 los decimales de precio neto sobre precio bruto en redondeo
    Endcase
Return
#########################################################################################################################
$OUVRE
    # Se modifica la variable global GDECPRI para redondear el precio a 5 decimales en vez de 4
    # Este punto de entrada se ejecuta al arrancar X3
    GDECPRI = 5
return





