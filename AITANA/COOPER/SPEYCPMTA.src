#####################################################################################
# Src: SRC
#-------------------------------------------------------------------------------------
# Acciones del objeto YCPMT
#-------------------------------------------------------------------------------------
# Proyecto: JAE
#-------------------------------------------------------------------------------------
# Version: v11
#-------------------------------------------------------------------------------------
# Fecha:08-02-2018
#-------------------------------------------------------------------------------------
# Desarrollador: OREN
# Codigo Actividad: Y100
#######################################################################################
#DEV: OREN 07-02-2018 JYM180202
$ACTION
Case GACTION
  When "YCPMT"
    Case ACTION
      When "OUVRE"      : Gosub OUVRE
      When "DEBUT"      : Gosub DEBUT
      When "SETBOUT"    : Gosub SETBOUT
      When "AVANT_ENR"   : Gosub AVANT_ENR
      When "FINSAI"     : Gosub FINSAI
    Endcase
Endcase
Return


#---------------------------------------------------------------------------------------------------#
#                                           SUBPROGS                                                #
#---------------------------------------------------------------------------------------------------#

$OUVRE
  #Abro mi tabla
  If !clalev([XX9])   : Local File YCALPROMT [XX9]  : Endif
Return


#######################################################################################
$DEBUT
  #Cargo los datos
  If GFONCTION1 = "FUNSFTPOR" or GFONCTION1 = "GESMTK"  Then
    Raz [M:YCPMT1]
    Read [F:XX9]YCPMT0 = [M:MTK0]MFGTRKNUM

    If fstat = 0 Then
      [M:YCPMT1]MFGTRKNUM = [F:XX9]MFGTRKNUM
      [M:YCPMT1]EMPNUM    = [F:XX9]EMPNUM
      [M:YCPMT1]YADEFEMB  = [F:XX9]YADEFEMB
      [M:YCPMT1]YAPREEMB  = [F:XX9]YAPREEMB
      [M:YCPMT1]YMATPRI   = [F:XX9]YMATPRI
      [M:YCPMT1]YMUBOB    = [F:XX9]YMUBOB
      [M:YCPMT1]YREVF     = [F:XX9]YREVF
      [M:YCPMT1]YOBSERV   = [F:XX9]YOBSERV
    Else
      Grizo [M:YCPMT1]
    Endif
    Affzo [M:YCPMT1]
  Endif
Return


#######################################################################################
$SETBOUT

If COUZON <> "" Then
  CHBOU += "E"
Else
  Raz CHBOU
Endif
Return


#######################################################################################
$AVANT_ENR
  Trbegin [XX9]
  [F:XX9]MFGTRKNUM = [M:YCPMT1]MFGTRKNUM
  [F:XX9]EMPNUM    = [M:YCPMT1]EMPNUM

  [F:XX9]YADEFEMB  = [M:YCPMT1]YADEFEMB
  [F:XX9]YAPREEMB  = [M:YCPMT1]YAPREEMB
  [F:XX9]YMATPRI   = [M:YCPMT1]YMATPRI
  [F:XX9]YMUBOB    = [M:YCPMT1]YMUBOB
  [F:XX9]YREVF     = [M:YCPMT1]YREVF
  [F:XX9]YOBSERV   = [M:YCPMT1]YOBSERV

  Rewrite [XX9]
  If fstat = 0 Then
   Commit
   Raz CHBOU
  Else : Rollback
  Endif

Return



#######################################################################################
$FINSAI
  Close Local File [XX9]
Return

