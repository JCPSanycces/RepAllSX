$ON_WQTYORDSTU
Onevent BEFORE_AREA Gosub AV_WQTYORDSTU From W3WE2JM1
Return

$AV_WQTYORDSTU
If !GWEBSERV
 ## Action FMTQTY
 GUNTFMT="15F" : GUNTFMT = GUNTFMT1(max(find([M]STU(nolign-1),GUNITE(1..GNBUNT)),1))
Endif
Gosub _AFF
Return

