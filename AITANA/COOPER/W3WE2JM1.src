$ON_TAXOTH2
Return

$ON_LINCLEFLG
Onevent INIT_AREA Call D_LINCLEFLG(zc) From W3WE2JM1
Return

Subprog D_LINCLEFLG(VALEUR)
Variable Integer VALEUR
If varinit([M]LINCLEFLG,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

