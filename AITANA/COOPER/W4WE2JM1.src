# Supervisor
# Gesti¾n de la mßscara WE2JM1 

$_AFF
If GIMPORT
 Gosub AFF From GSAISIE
Else
 If GMESSAGE <>""
  Gosub ERR From GSAISIE
 Else
  Raz GERR , GZNUM
 Endif
Endif
Return

$ON_CMMPRPTAX
Onevent INIT_AREA Call D_CMMPRPTAX(zc) From W4WE2JM1
Return

Subprog D_CMMPRPTAX(VALEUR)
Variable Integer VALEUR
If varinit([M]CMMPRPTAX,indice)=0
 VALEUR = 1
Endif
Gosub _AFF
End

$ON_CMMPRPNUM
Return

$ON_CLCAMT1
Onevent BEFORE_AREA Gosub AV_CLCAMT1 From W4WE2JM1
Return

$AV_CLCAMT1
## Action INIDEV
GDEVFMT="11.2" : GDEVFMT = GDEVFMT1(max(find([M]CUR(nolign-1),GDEVISE(1..GNBDEV)),1))
Gosub _AFF
Return

