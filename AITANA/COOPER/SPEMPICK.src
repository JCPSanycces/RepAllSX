# Gestión de la máscara MFGPICKA (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla MFGPICKA) 03/04/2019 18:37:08 (AIT04)
######################################################################################
Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()
# Guardo el proveedor en tabla
If !clalev([PP1]) : Local File ORDERS [PP1] : Endif
Read [PP1]ORD0 = [M:MGP]WIPTYP(nolign-1);[M:MGP]WIPNUM(nolign-1);[M:MGP]ITMREF(nolign-1)
If fstat = 0
  [PP1]BPRNUM = VALEUR
  Rewrite [PP1]
Endif

Close Local File [PP1]
End


######################################################################################
Subprog AS_YPJTDES(VALEUR)
Variable Char    VALEUR()
# Si tengo valor en campo origen, propongo el mismo valor
If VALEUR = "" and [M:MGP]YPJTORI <> ""
  VALEUR = [M:MGP]YPJTORI
Endif
End



######################################################################################
Subprog AS_YVCRDES(VALEUR)
Variable Char    VALEUR()
# Si tengo valor en campo origen, propongo el mismo valor
If VALEUR = "" and [M:MGP]YVCRORI <> ""
  VALEUR = [M:MGP]YVCRORI
Endif
End


