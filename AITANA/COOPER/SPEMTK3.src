# Gestión de la máscara MTK3 (Especifico)
$ACTION
Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla MTK3) 05/02/2018 15:39:53 (PT02)
######################################################################################
Subprog B13_NBMAT
# Abro pantalla de modificación de rollos y posición y el lote PT
Global Char GL5LLE(250)(8)
Local Integer LINT
GL5LLE(0)   = [M:MTK0]MFGTRKNUM
GL5LLE(1)   = num$([M:MTK3]MATTRKLIN(nolign-1))
GL5LLE(2)   = [M:MTK3]MATITMREF(nolign-1)
GL5LLE(3)   = [M:MTK3]LOT(nolign-1)
GL5LLE(4)   = num$([M:MTK3]YROLLOS(nolign-1))
GL5LLE(5)   = [M:MTK3]YPOSICION(nolign-1)
GL5LLE(6)   = [M:MTK3]YLOTE(nolign-1)

Call SAISIE_LIB(LINT,GL5LLE,"YMODIFMTK3","SPEYMTK3","OBJZON") From GSAISIE
End


