#<AdxTL>@(#)0.0.0.0 $Revision$
#####################################################################################
# Src: SPEPSH
#-------------------------------------------------------------------------------------
# (Solicitudes de compra)
#-------------------------------------------------------------------------------------
# Proyecto: JAE
#-------------------------------------------------------------------------------------
# Version: v11
#-------------------------------------------------------------------------------------
# Fecha: 31-01-2019
#-------------------------------------------------------------------------------------
# Desarrollador: JCH
# Código de desarrollo: CSA018
# Descripción del desarrollo: Comparativo entre proveedores dentro de Solicitudes de compra
# Fecha: 31/01/2019
# Codigo Actividad: YCS18
#######################################################################################

$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif

Case ACTION
  When "APRES_CRE"    : Gosub APRES_CRE
  When "ANNULE"       : Gosub ANNULE
  When "STYLE"        : Gosub STYLE
  When "APRES_MOD"    : Gosub APRES_MOD
  When "OUVRE"        : Gosub OUVRE
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
################################################
$APRES_CRE
  If GFONCTION = "GESPSH"
    Call ADDAMK_PSHNUM([M:PSH0]PSHNUM)                                                # rellena el grid de artículos en compara                 - CSA018 - YCS18
    Call ADDATB_PSHNUM([M:PSH0]PSHNUM)                                                # crea los registros en tabla de una solicitud de compra  - CSA018 - YCS18
  Endif
Return

################################################
$APRES_MOD
Local Integer LCON9

  If GFONCTION = "GESPSH"
    # CSA018 - YCS18
    Call DELATB_PSHNUM([M:PSH0]PSHNUM,"A")                                            # borrar registro en la tabla de artículos    (BORRAR)    - CSA018 - YCS18
    Call DELATB_PSHNUM([M:PSH0]PSHNUM,"P")                                            # borrar registro en la tabla de proveedores  (BORRAR)    - CSA018 - YCS18
    Call ADDAMK_PSHNUM([M:PSH0]PSHNUM)                                                # rellena el grid de artículos en compara                 - CSA018 - YCS18
    Call MODATB_PSHNUM([M:PSH0]PSHNUM)                                                # modifica las tablas                                     - CSA018 - YCS18
    Gosub ADD_NETPRI                                                                  # actualiza el precio total por proveedor                 - CSA018 - YCS18

    # para que los valores de proveedor y precio neto no se pierdan (no hemos podido averiguar el por qué)
    # necesito llamar al estándar y cargar los datos en tabla directamente
    Gosub APRES_MOD From SUBPSH1                                                      # llamada al estándar
    If !clalev([F:YPSD]) Then : Local File PREQUISD  [F:YPSD] : Endif
    If !clalev([F:PSA1]) Then : Local File YCOMPPSHA [F:PSA1] : Endif
    If !clalev([F:PSP1]) Then : Local File YCOMPPSHP [F:PSP1] : Endif
    For LCON9 = 0 To [M:PSH1]NBLIG-1                                                  # para cada línea de solicitud de compra
      Read [F:YPSD]PSD0 = [M:PSH0]PSHNUM;[M:PSH1]PSDLIN(LCON9)                        # busco que exista en la tabla
      If !fstat Then
        [F:YPSD]BPSNUM = YGBPSNUM                                                     # cargo el valor del proveedor seleccionado en la tabla
        [M:PSH1]BPSNUM(LCON9) = [F:YPSD]BPSNUM                                        # cargo el valor del proveedor seleccionado en la pantalla pq aquí se pierde
        Affzo [M:PSH1]BPSNUM(LCON9)                                                   # refresco el campo en pantalla
        Rewrite [F:YPSD]                                                              # actualizo el valor en tabla
      Endif
      Filter [F:PSP1] Where PSHNUM = [M:PSH0]PSHNUM and BPSNUM = [M:PSH1]BPSNUM(LCON9)  # busco que exista el registro en la tabla nueva (solicitud+artículo)
      Read [F:PSP1] First
      Filter [F:PSA1] Where PSHNUM = [M:PSH0]PSHNUM and ITMREF = [M:YPSH1]ITMREF(LCON9) # busco que exista el registro en la tabla nueva (solicitud+artículo)
      Read [F:PSA1] First
      If !fstat Then
        Read [F:YPSD]PSD0 = [F:PSA1]PSHNUM;[F:PSA1]PSDLIN                             # me sitúo sobre el registro en la tabla de solicitudes
        If !fstat Then
          Case YGNUMLIN                                                               # en base al proveedor seleccionado
            When 1
              [F:YPSD]GROPRI            = [F:PSA1]NETPRI1                             # cargo en la tabla el importe bruto para el proveedor 1
              [F:YPSD]NETPRI            = [F:PSA1]NETPRI1                             # cargo en la tabla el importe neto para el proveedor 1
              [F:YPSD]LINAMT            = [F:PSA1]NETPRI1*[F:PSA1]QTYPUU              # cargo en la tabla el Importe línea AI para el proveedor 1
              [F:YPSD]EXTRCPDAT         = [F:PSP1]YPLAZO                              # cargo en la tabla la fecha deseada indicada por el proveedor 1
              [F:YPSD]EXTORDDAT         = [F:PSP1]YPLAZO                              # cargo en la tabla la fecha estimada de pedido indicada por el proveedor 1
              [M:PSH1]GROPRI(LCON9)     = [F:YPSD]NETPRI                              # cargo en la pantalla el precio para el proveedor 1 pq aquí se pierde
              [M:PSH1]NETPRI(LCON9)     = [F:YPSD]NETPRI                              # cargo en la pantalla el precio para el proveedor 1 pq aquí se pierde
              [M:PSH1]LINAMT(LCON9)     = [F:YPSD]LINAMT                              # cargo en la pantalla el Importe línea AI para el proveedor 1 pq aquí se pierde
              [M:PSH1]EXTRCPDAT(LCON9)  = [F:YPSD]EXTRCPDAT                           # cargo en la pantalla la fecha deseada para el proveedor 1 pq aquí se pierde
              [M:PSH1]EXTORDDAT(LCON9)  = [F:YPSD]EXTORDDAT                           # cargo en la pantalla la fecha estimada ped. para el proveedor 1 pq aquí se pierde
              Affzo [M:PSH1]GROPRI(LCON9),NETPRI(LCON9),LINAMT(LCON9),EXTRCPDAT(LCON9),EXTORDDAT(LCON9)        # refresco el campo en pantalla
            When 2
              [F:YPSD]GROPRI            = [F:PSA1]NETPRI2                             # cargo en la tabla el importe bruto para el proveedor 2
              [F:YPSD]NETPRI            = [F:PSA1]NETPRI2                             # cargo en la tabla el importe neto para el proveedor 2
              [F:YPSD]LINAMT            = [F:PSA1]NETPRI2*[F:PSA1]QTYPUU              # cargo en la tabla el Importe línea AI para el proveedor 2
              [F:YPSD]EXTRCPDAT         = [F:PSP1]YPLAZO                              # cargo en la tabla la fecha deseada indicada por el proveedor 1
              [F:YPSD]EXTORDDAT         = [F:PSP1]YPLAZO                              # cargo en la tabla la fecha estimada de pedido indicada por el proveedor 1
              [M:PSH1]GROPRI(LCON9)     = [F:YPSD]NETPRI                              # cargo en la pantalla el precio para el proveedor 2 pq aquí se pierde
              [M:PSH1]NETPRI(LCON9)     = [F:YPSD]NETPRI                              # cargo en la pantalla el precio para el proveedor 2 pq aquí se pierde
              [M:PSH1]LINAMT(LCON9)     = [F:YPSD]LINAMT                              # cargo en la pantalla el Importe línea AI para el proveedor 2 pq aquí se pierde
              [M:PSH1]EXTRCPDAT(LCON9)  = [F:YPSD]EXTRCPDAT                           # cargo en la pantalla la fecha deseada para el proveedor 1 pq aquí se pierde
              [M:PSH1]EXTORDDAT(LCON9)  = [F:YPSD]EXTORDDAT                           # cargo en la pantalla la fecha estimada para el proveedor 1 pq aquí se pierde
              Affzo [M:PSH1]GROPRI(LCON9),NETPRI(LCON9),LINAMT(LCON9),EXTRCPDAT(LCON9),EXTORDDAT(LCON9)        # refresco el campo en pantalla
            When 3
              [F:YPSD]GROPRI            = [F:PSA1]NETPRI3                             # cargo en la tabla el importe bruto para el proveedor 3
              [F:YPSD]NETPRI            = [F:PSA1]NETPRI3                             # cargo en la tabla el importe neto para el proveedor 3
              [F:YPSD]LINAMT            = [F:PSA1]NETPRI3*[F:PSA1]QTYPUU              # cargo en la tabla el Importe línea AI para el proveedor 3
              [F:YPSD]EXTRCPDAT         = [F:PSP1]YPLAZO                              # cargo en la tabla la fecha deseada indicada por el proveedor 1
              [F:YPSD]EXTORDDAT         = [F:PSP1]YPLAZO                              # cargo en la tabla la fecha estimada de pedido indicada por el proveedor 1
              [M:PSH1]GROPRI(LCON9)     = [F:YPSD]NETPRI                              # cargo en la pantalla el precio para el proveedor 3 pq aquí se pierde
              [M:PSH1]NETPRI(LCON9)     = [F:YPSD]NETPRI                              # cargo en la pantalla el precio para el proveedor 3 pq aquí se pierde
              [M:PSH1]LINAMT(LCON9)     = [F:YPSD]LINAMT                              # cargo en la pantalla el Importe línea AI para el proveedor 3 pq aquí se pierde
              [M:PSH1]EXTRCPDAT(LCON9)  = [F:YPSD]EXTRCPDAT                           # cargo en la pantalla la fecha deseada para el proveedor 1 pq aquí se pierde
              [M:PSH1]EXTORDDAT(LCON9)  = [F:YPSD]EXTORDDAT                           # cargo en la pantalla la fecha estimada para el proveedor 1 pq aquí se pierde
              Affzo [M:PSH1]GROPRI(LCON9),NETPRI(LCON9),LINAMT(LCON9),EXTRCPDAT(LCON9),EXTORDDAT(LCON9)        # refresco el campo en pantalla
            When 4
              [F:YPSD]GROPRI            = [F:PSA1]NETPRI4                             # cargo en la tabla el importe bruto para el proveedor 4
              [F:YPSD]NETPRI            = [F:PSA1]NETPRI4                             # cargo en la tabla el importe neto para el proveedor 4
              [F:YPSD]LINAMT            = [F:PSA1]NETPRI4*[F:PSA1]QTYPUU              # cargo en la tabla el Importe línea AI para el proveedor 4
              [F:YPSD]EXTRCPDAT         = [F:PSP1]YPLAZO                              # cargo en la tabla la fecha deseada indicada por el proveedor 1
              [F:YPSD]EXTORDDAT         = [F:PSP1]YPLAZO                              # cargo en la tabla la fecha estimada de pedido indicada por el proveedor 1
              [M:PSH1]GROPRI(LCON9)     = [F:YPSD]NETPRI                              # cargo en la pantalla el precio para el proveedor 4 pq aquí se pierde
              [M:PSH1]NETPRI(LCON9)     = [F:YPSD]NETPRI                              # cargo en la pantalla el precio para el proveedor 4 pq aquí se pierde
              [M:PSH1]LINAMT(LCON9)     = [F:YPSD]LINAMT                              # cargo en la pantalla el Importe línea AI para el proveedor 4 pq aquí se pierde
              [M:PSH1]EXTRCPDAT(LCON9)  = [F:YPSD]EXTRCPDAT                           # cargo en la pantalla la fecha deseada para el proveedor 1 pq aquí se pierde
              [M:PSH1]EXTORDDAT(LCON9)  = [F:YPSD]EXTORDDAT                           # cargo en la pantalla la fecha estimada para el proveedor 1 pq aquí se pierde
              Affzo [M:PSH1]GROPRI(LCON9),NETPRI(LCON9),LINAMT(LCON9),EXTRCPDAT(LCON9),EXTORDDAT(LCON9)        # refresco el campo en pantalla
            When 5
              [F:YPSD]GROPRI            = [F:PSA1]NETPRI5                             # cargo en la tabla el importe bruto para el proveedor 5
              [F:YPSD]NETPRI            = [F:PSA1]NETPRI5                             # cargo en la tabla el importe neto para el proveedor 5
              [F:YPSD]LINAMT            = [F:PSA1]NETPRI5*[F:PSA1]QTYPUU              # cargo en la tabla el Importe línea AI para el proveedor 5
              [F:YPSD]EXTRCPDAT         = [F:PSP1]YPLAZO                              # cargo en la tabla la fecha deseada indicada por el proveedor 1
              [F:YPSD]EXTORDDAT         = [F:PSP1]YPLAZO                              # cargo en la tabla la fecha estimada de pedido indicada por el proveedor 1
              [M:PSH1]GROPRI(LCON9)     = [F:YPSD]NETPRI                              # cargo en la pantalla el precio para el proveedor 5 pq aquí se pierde
              [M:PSH1]NETPRI(LCON9)     = [F:YPSD]NETPRI                              # cargo en la pantalla el precio para el proveedor 5 pq aquí se pierde
              [M:PSH1]LINAMT(LCON9)     = [F:YPSD]LINAMT                              # cargo en la pantalla el Importe línea AI para el proveedor 5 pq aquí se pierde
              [M:PSH1]EXTRCPDAT(LCON9)  = [F:YPSD]EXTRCPDAT                           # cargo en la pantalla la fecha deseada para el proveedor 1 pq aquí se pierde
              [M:PSH1]EXTORDDAT(LCON9)  = [F:YPSD]EXTORDDAT                           # cargo en la pantalla la fecha estimada para el proveedor 1 pq aquí se pierde
              Affzo [M:PSH1]GROPRI(LCON9),NETPRI(LCON9),LINAMT(LCON9),EXTRCPDAT(LCON9),EXTORDDAT(LCON9)        # refresco el campo en pantalla
          Endcase
          Rewrite [F:YPSD]                                                            # actualizo el valor en la tabla
        Endif
      Endif
      Filter [F:PSA1]
    Next
    If clalev([F:YPSD])  Then : Close Local File     [F:YPSD] : Endif
    If clalev([F:PSA1])  Then : Close Local File     [F:PSA1] : Endif
    If clalev([F:PSP1])  Then : Close Local File     [F:PSP1] : Endif
    GPE=1
    # CSA018 - YCS18
  Endif
Return

################################################
$ANNULE
  If GFONCTION = "GESPSH"
    Call DELATB_PSHNUM([M:PSH0]PSHNUM,"P")                                            # borrar registro en la tabla de proveedores  (BORRAR)    - CSA018 - YCS18
    Call DELATB_PSHNUM([M:PSH0]PSHNUM,"A")                                            # borrar registro en la tabla de artículos    (BORRAR)    - CSA018 - YCS18
  Endif
Return

################################################
$STYLE
  If GFONCTION = "GESPSH"
    Gosub MUESTRA_COMPARA                                                             # al entrar o moverse por el browser izquierdo            - CSA018 - YCS18
  Endif
Return

################################################
$OUVRE
  Global Char     YGBPSNUM(50)  : Raz YGBPSNUM
  Global Integer  YGNUMLIN      : Raz YGNUMLIN
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
################################################
# al entrar o moverse por el browser izquierdo - CSA018 - YCS18
$MUESTRA_COMPARA
Local Integer LCON0 : Raz LCON0

  Filter [F:PSP] Where PSHNUM = [M:PSH0]PSHNUM                         # busca proveedores para esa solicitud y carga la información en el grid
  For [PSP]
    [M:YPSH1]PSHNUM(LCON0)    = [F:PSP]PSHNUM
    [M:YPSH1]BPSNUM(LCON0)    = [F:PSP]BPSNUM
    [M:YPSH1]PQHNUM(LCON0)    = [F:PSP]PQHNUM
    [M:YPSH1]YPLAZO(LCON0)    = [F:PSP]YPLAZO
    [M:YPSH1]NETPRI(LCON0)    = [F:PSP]NETPRI
    [M:YPSH1]YSELEC(LCON0)    = [F:PSP]YSELEC
    [M:YPSH1]YSOLPDAT(LCON0)  = [F:PSP]YSOLPDAT
    [M:YPSH1]YRECDAT(LCON0)   = [F:PSP]YRECDAT
    LCON0 += 1
  Next
  [M:YPSH1]NBBPS = LCON0
  Filter [F:PSP]

  Raz LCON0
  Filter [F:PSA] Where PSHNUM = [M:PSH0]PSHNUM                         # busca artículos para esa solicitud y carga la información en el grid
  For [PSA]
    [M:YPSH1]PSDLIN(LCON0)    = [F:PSA]PSDLIN
    [M:YPSH1]ITMREF(LCON0)    = [F:PSA]ITMREF
    [M:YPSH1]QTYPUU(LCON0)    = [F:PSA]QTYPUU
    [M:YPSH1]NETPRI1(LCON0)   = [F:PSA]NETPRI1
    [M:YPSH1]NETPRI2(LCON0)   = [F:PSA]NETPRI2
    [M:YPSH1]NETPRI3(LCON0)   = [F:PSA]NETPRI3
    [M:YPSH1]NETPRI4(LCON0)   = [F:PSA]NETPRI4
    [M:YPSH1]NETPRI5(LCON0)   = [F:PSA]NETPRI5
    LCON0 += 1
  Next
  [M:YPSH1]NBITM = LCON0
  Filter [F:PSA]

  Affzo [M:YPSH1]5,10

Return

################################################
# suma los precios unitarios por proveedor - CSA018 - YCS18
$ADD_NETPRI
Local Integer J : Raz J
  [M:YPSH1]NETPRI(0) = sigma(J=0,[M:YPSH1]NBITM-1,([M:YPSH1]NETPRI1(J)*[M:YPSH1]QTYPUU(J)))         # suma los precios unitarios para el proveedor 1
  [M:YPSH1]NETPRI(1) = sigma(J=0,[M:YPSH1]NBITM-1,([M:YPSH1]NETPRI2(J)*[M:YPSH1]QTYPUU(J)))         # suma los precios unitarios para el proveedor 2
  [M:YPSH1]NETPRI(2) = sigma(J=0,[M:YPSH1]NBITM-1,([M:YPSH1]NETPRI3(J)*[M:YPSH1]QTYPUU(J)))         # suma los precios unitarios para el proveedor 3
  [M:YPSH1]NETPRI(3) = sigma(J=0,[M:YPSH1]NBITM-1,([M:YPSH1]NETPRI4(J)*[M:YPSH1]QTYPUU(J)))         # suma los precios unitarios para el proveedor 4
  [M:YPSH1]NETPRI(4) = sigma(J=0,[M:YPSH1]NBITM-1,([M:YPSH1]NETPRI5(J)*[M:YPSH1]QTYPUU(J)))         # suma los precios unitarios para el proveedor 5
  Affzo [M:YPSH1]NETPRI
  If !clalev([F:PSP1]) Then : Local File YCOMPPSHP [F:PSP1] : Endif             # abro la tabla con otro alias porque sino me arrastra el filtro
  For J=0 To [M:YPSH1]NBBPS-1
    Filter [F:PSP1] Where PSHNUM = [M:PSH0]PSHNUM and BPSNUM = [M:YPSH1]BPSNUM(J)
    Read [F:PSP1] First
    If !fstat Then
      [F:PSP1]NETPRI = [M:YPSH1]NETPRI(J)
      Rewrite [F:PSP1]
    Endif
    Filter [F:PSP1]
  Next
  If clalev([F:PSP1])  Then : Close Local File     [F:PSP1] : Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Después de modificar el campo "Selección"
######################################################################################
Subprog AM_YSELEC(VALEUR)
Variable Integer VALEUR

# CSA018 - YCS18
Local Integer LCON7, LCON8 : Raz LCON7, LCON8
Local Integer OK

  If VALEUR = 2 Then
    YGBPSNUM  = [M:YPSH1]BPSNUM(nolign-1)
    YGNUMLIN  = nolign
    # sustituye el preveedor seleccionado en las líneas de solicitud
    For LCON7 = 0 To [M:PSH1]NBLIG-1
      [M:PSH1]LINFLG(LCON7)     = 2  #AITANA
      [M:PSH1]BPSNUM(LCON7)     = [M:YPSH1]BPSNUM(nolign-1)
      [M:PSH1]EXTRCPDAT(LCON7)  = [M:YPSH1]YPLAZO(nolign-1)
      [M:PSH1]EXTORDDAT(LCON7)  = [M:YPSH1]YPLAZO(nolign-1)
      Call C_BPSNUM([M:PSH1]BPSNUM(LCON7))  From SUBPSH
      Call AM_BPSNUM([M:PSH1]BPSNUM(LCON7)) From SUBPSH
      Call AM_EXTRCPDAT([M:PSH1]EXTRCPDAT(LCON8)) From SUBPSH
      Call AM_EXTORDDAT([M:PSH1]EXTRCPDAT(LCON8)) From SUBPSH
      [M:PSH1]PRIFLG(LCON7) = 1
    Next
    # rellena el campo importe y lanza la acción para que actualice el Importe línea AI
    Case nolign                                                                 # en función de la línea que haya seleccionada se insertan los precios de ese proveedor
      When  1                                                                   # PROVEEDOR 1
        For LCON8 = 0 To [M:YPSH1]NBITM-1
          [M:PSH1]GROPRI(LCON8)     = [M:YPSH1]NETPRI1(LCON8)
          [M:PSH1]NETPRI(LCON8)     = [M:YPSH1]NETPRI1(LCON8)
          nolign = LCON8+1
          [M:PSH1]LINFLG(LCON8) = 2  #AITANA
          Call AM_NETPRI([M:PSH1]GROPRI(LCON8))
        Next
      When  2                                                                   # PROVEEDOR 2
        For LCON8 = 0 To [M:YPSH1]NBITM-1
          [M:PSH1]GROPRI(LCON8) = [M:YPSH1]NETPRI2(LCON8)
          [M:PSH1]NETPRI(LCON8) = [M:YPSH1]NETPRI2(LCON8)
          nolign = LCON8+1
          [M:PSH1]LINFLG(LCON8) = 2  #AITANA
          Call AM_NETPRI([M:PSH1]GROPRI(LCON8))
        Next
      When  3                                                                   # PROVEEDOR 3
        For LCON8 = 0 To [M:YPSH1]NBITM-1
          [M:PSH1]GROPRI(LCON8) = [M:YPSH1]NETPRI3(LCON8)
          [M:PSH1]NETPRI(LCON8) = [M:YPSH1]NETPRI3(LCON8)
          nolign = LCON8+1
          [M:PSH1]LINFLG(LCON8) = 2  #AITANA
          Call AM_NETPRI([M:PSH1]GROPRI(LCON8))
        Next
      When  4                                                                   # PROVEEDOR 4
        For LCON8 = 0 To [M:YPSH1]NBITM-1
          [M:PSH1]GROPRI(LCON8) = [M:YPSH1]NETPRI4(LCON8)
          [M:PSH1]NETPRI(LCON8) = [M:YPSH1]NETPRI4(LCON8)
          nolign = LCON8+1
          [M:PSH1]LINFLG(LCON8) = 2  #AITANA
          Call AM_NETPRI([M:PSH1]GROPRI(LCON8))
        Next
      When  5                                                                   # PROVEEDOR 5
        For LCON8 = 0 To [M:YPSH1]NBITM-1
          [M:PSH1]GROPRI(LCON8) = [M:YPSH1]NETPRI5(LCON8)
          [M:PSH1]NETPRI(LCON8) = [M:YPSH1]NETPRI5(LCON8)
          nolign = LCON8+1
          [M:PSH1]LINFLG(LCON8) = 2  #AITANA
          Call AM_NETPRI([M:PSH1]GROPRI(LCON8))
        Next
    Endcase
  Endif
  Affzo [M:PSH1]5
# CSA018 - YCS18

End

######################################################################################
## Controla que sólo se pueda marcar una vez el campo YSELEC
######################################################################################
Subprog C_YSELEC(VALEUR)
Variable Integer VALEUR

# CSA018 - YCS18
  If VALEUR = 2 Then
    Call UNICITE(VALEUR,[M:YPSH1]YSELEC(0..[M:YPSH1]NBBPS-1)) From OBJDIV
    If mkstat = 2 Then
      VALEUR = 1
    Endif
  Endif
# CSA018 - YCS18

End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
################################################
#**
#* crea los registros en tabla de una solicitud de compra
#*
#* @param PPSHNUM  > código de la solicitud de compra
#*!
# CSA018 - YCS18
Subprog ADDATB_PSHNUM(PPSHNUM)
Value     Char    PPSHNUM

Local Integer LCON1, LCON2 : Raz LCON1, LCON2

  # añade registros en la tabla de proveedores
  For LCON1 = 0 To [M:YPSH1]NBBPS-1
    [F:PSP]PSHNUM    = [M:PSH0]PSHNUM
    [F:PSP]BPSNUM    = [M:YPSH1]BPSNUM(LCON1)
    [F:PSP]PQHNUM    = [M:YPSH1]PQHNUM(LCON1)
    [F:PSP]YPLAZO    = [M:YPSH1]YPLAZO(LCON1)
    [F:PSP]NETPRI    = [M:YPSH1]NETPRI(LCON1)
    [F:PSP]YSELEC    = [M:YPSH1]YSELEC(LCON1)
    [F:PSP]YSOLPDAT  = [M:YPSH1]YSOLPDAT(LCON1)
    [F:PSP]YRECDAT  = [M:YPSH1]YRECDAT(LCON1)
    Write [F:PSP]
  Next LCON1

  # añade registros en la tabla de artículos
  For LCON2 = 0 To [M:YPSH1]NBITM-1
    [F:PSA]PSHNUM    = [M:PSH0]PSHNUM
    [F:PSA]PSDLIN    = [M:YPSH1]PSDLIN(LCON2)
    [F:PSA]ITMREF    = [M:YPSH1]ITMREF(LCON2)
    [F:PSA]QTYPUU    = [M:YPSH1]QTYPUU(LCON2)
    [F:PSA]NETPRI1   = [M:YPSH1]NETPRI1(LCON2)
    [F:PSA]NETPRI2   = [M:YPSH1]NETPRI2(LCON2)
    [F:PSA]NETPRI3   = [M:YPSH1]NETPRI3(LCON2)
    [F:PSA]NETPRI4   = [M:YPSH1]NETPRI4(LCON2)
    [F:PSA]NETPRI5   = [M:YPSH1]NETPRI5(LCON2)
    Write [F:PSA]
  Next LCON2

End

################################################
#**
#* modifica los registros en tabla de una solicitud de compra
#*
#* @param PPSHNUM  > código de la solicitud de compra
#*!
#  CSA018 - YCS18
Subprog MODATB_PSHNUM(PPSHNUM)
Value     Char    PPSHNUM

Local Integer LCON3, LCON4 : Raz LCON3, LCON4

  # modifica registros en la tabla de proveedores
  For LCON3 = 0 To [M:YPSH1]NBBPS-1
    Filter [F:PSP] Where PSHNUM = [M:PSH0]PSHNUM and BPSNUM = [M:YPSH1]BPSNUM(LCON3)
    Read [F:PSP] First
    If !fstat Then                                                                # modifica proveedor en la tabla si existe
      [F:PSP]PSHNUM    = [M:PSH0]PSHNUM
      [F:PSP]BPSNUM    = [M:YPSH1]BPSNUM(LCON3)
      [F:PSP]PQHNUM    = [M:YPSH1]PQHNUM(LCON3)
      [F:PSP]YPLAZO    = [M:YPSH1]YPLAZO(LCON3)
      [F:PSP]NETPRI    = [M:YPSH1]NETPRI(LCON3)
      [F:PSP]YSELEC    = [M:YPSH1]YSELEC(LCON3)
      [F:PSP]YSOLPDAT  = [M:YPSH1]YSOLPDAT(LCON3)
      [F:PSP]YRECDAT   = [M:YPSH1]YRECDAT(LCON3)
      Rewrite [F:PSP]
    Else
      [F:PSP]PSHNUM    = [M:PSH0]PSHNUM
      [F:PSP]BPSNUM    = [M:YPSH1]BPSNUM(LCON3)
      [F:PSP]PQHNUM    = [M:YPSH1]PQHNUM(LCON3)
      [F:PSP]YPLAZO    = [M:YPSH1]YPLAZO(LCON3)
      [F:PSP]NETPRI    = [M:YPSH1]NETPRI(LCON3)
      [F:PSP]YSELEC    = [M:YPSH1]YSELEC(LCON3)
      [F:PSP]YSOLPDAT  = [M:YPSH1]YSOLPDAT(LCON3)
      [F:PSP]YRECDAT   = [M:YPSH1]YRECDAT(LCON3)
      Write [F:PSP]
    Endif
    Filter [F:PSP]
  Next

  # modifica registros en la tabla de artículos
  For LCON4 = 0 To [M:YPSH1]NBITM-1
    Filter [F:PSA] Where PSHNUM = [M:PSH0]PSHNUM and PSDLIN = [M:PSH1]PSDLIN(LCON4)
    Read [F:PSA] First
    If !fstat Then                                                                # modifica artículo en la tabla si existe
      [F:PSA]PSHNUM    = [M:PSH0]PSHNUM
      [F:PSA]PSDLIN    = [M:YPSH1]PSDLIN(LCON4)
      [F:PSA]ITMREF    = [M:YPSH1]ITMREF(LCON4)
      [F:PSA]QTYPUU    = [M:YPSH1]QTYPUU(LCON4)
      [F:PSA]NETPRI1   = [M:YPSH1]NETPRI1(LCON4)
      [F:PSA]NETPRI2   = [M:YPSH1]NETPRI2(LCON4)
      [F:PSA]NETPRI3   = [M:YPSH1]NETPRI3(LCON4)
      [F:PSA]NETPRI4   = [M:YPSH1]NETPRI4(LCON4)
      [F:PSA]NETPRI5   = [M:YPSH1]NETPRI5(LCON4)
      Rewrite [F:PSA]
    Else
      [F:PSA]PSHNUM    = [M:PSH0]PSHNUM
      [F:PSA]PSDLIN    = [M:YPSH1]PSDLIN(LCON4)
      [F:PSA]ITMREF    = [M:YPSH1]ITMREF(LCON4)
      [F:PSA]QTYPUU    = [M:YPSH1]QTYPUU(LCON4)
      [F:PSA]NETPRI1   = [M:YPSH1]NETPRI1(LCON4)
      [F:PSA]NETPRI2   = [M:YPSH1]NETPRI2(LCON4)
      [F:PSA]NETPRI3   = [M:YPSH1]NETPRI3(LCON4)
      [F:PSA]NETPRI4   = [M:YPSH1]NETPRI4(LCON4)
      [F:PSA]NETPRI5   = [M:YPSH1]NETPRI5(LCON4)
      Write [F:PSA]
    Endif
    Filter [F:PSA]
  Next

End

################################################
#**
#* elimina los registros en tabla de una solicitud de compra
#*
#* @param PPSHNUM  > código de la solicitud de compra
#* @param PTABLE   > código que identifica la tabla a borrar
#*!
# CSA018 - YCS18
Subprog DELATB_PSHNUM(PPSHNUM, PTABLE)
Value     Char    PPSHNUM
Value     Char    PTABLE

  ###################
  #     PTABLE      #
  ###################
  # 'P' = Proveedor #
  # 'A' = Artículo  #
  ###################

  Case PTABLE
    When "P"
      # elimina registros en la tabla de proveedores
      If !clalev([F:PSP0]) Then : Local File YCOMPPSHP [F:PSP0] : Endif             # para el borrado me ha tocado abrir la tabla
      Filter [F:PSP0] Where PSHNUM = PPSHNUM
      For [PSP0]
        Delete [F:PSP0]
      Next
      Filter [F:PSP0]
      If clalev([F:PSP0])  Then : Close Local File     [F:PSP0] : Endif
    When "A"
      # elimina registros en la tabla de artículos
      If !clalev([F:PSA0]) Then : Local File YCOMPPSHA [F:PSA0] : Endif             # para el borrado me ha tocado abrir la tabla
      Filter [F:PSA0] Where PSHNUM = PPSHNUM
      For [PSA0]
        Delete [F:PSA0]
      Next
      Filter [F:PSA0]
      If clalev([F:PSA0])  Then : Close Local File     [F:PSA0] : Endif
  Endcase

End

################################################
#**
#* crea los registros en pantalla de una solicitud de compra
#*
#* @param PPSHNUM  > código de la solicitud de compra
#*!
# CSA018 - YCS18
Subprog ADDAMK_PSHNUM(PPSHNUM)
Value     Char    PPSHNUM

Local Integer LCON5 : Raz LCON5

  # añade registros en el grid de artículos en la pestaña Compara
  For LCON5 = 0 To [M:PSH1]NBLIG-1
    [M:YPSH1]PSDLIN(LCON5) = [M:PSH1]PSDLIN(LCON5)
    [M:YPSH1]ITMREF(LCON5) = [M:PSH1]ITMREF(LCON5)
    [M:YPSH1]QTYPUU(LCON5) = [M:PSH1]QTYPUU(LCON5)
  Next LCON5
  [M:YPSH1]NBITM = LCON5
  Affzo [M:YPSH1]10

End

################################################
# subrutina extraida del estándar y puesta aquí porque se tiene que ejecutar pero con alguna modificación respecto al estándar
Subprog AM_NETPRI(VALEUR)
#----------------------#
# Apres modif prix net #
#----------------------#
Variable Decimal  VALEUR
Local    Shortint NOL  : NOL=nolign-1
#If VALEUR=[M:PSH1]NETPRI(NOL) End : Endif   #AITANA
#-------------------------------------#
# initialisation prix brut et remises #
#-------------------------------------#
[M:PSH1]GROPRI (NOL) = VALEUR
[M:PSH1]PRIREN (NOL) = GDACMANPUR
For I = 1 To 9
  If evalue("dim([M:PSH1]DISCRGVAL"+num$(I)+"(NOL))") >= 0
    Assign "[M:PSH1]DISCRGVAL"+num$(I)+"(NOL)" With 0
    If [M:PSH1]LINFLG (NOL) <> 1
      Assign "[M:PSH1]DISCRGREN"+num$(I)+"(NOL)" With GDACMANPUR
    Endif
  Endif
Next I
#----- Initialisation comptes et type d'achat lors de la 1ère modif du prix -----#
# Issue 105858 - 2015-05-12 by MUARN : ne pas faire si les comptes sont déjà initialisés
If [M:PSH1]CREFLG(NOL)=0 & [M:PSH1]LINFLG(NOL)<>1 & [M:PSH1]ITMREF(NOL)<>"" & !varinit([M:PSH1]LINACC1,NOL)
  [M:PSH1]NETPRI(NOL)=VALEUR
  Call INIT_COMPTES_LIGNE(NOL) From SUBPSH
  Call D_LINPURTYP([M:PSH1]LINPURTYP(NOL)) From SUBPSH
  If !GIMPORT
    Gosub AFFICH_LINACC From SUBPSH
    Affzo [PSH1]LINPURTYP(NOL)
  Endif
Endif
#----- Calcul du montant HT ligne -----#
[M:PSH1]LINAMT(NOL)=VALEUR*[M:PSH1]QTYPUU(NOL)
Call ARRDEV([M:PSH1]LINAMT(NOL),[M:PSH1]CUR(NOL)) From TRTDIV
If !GIMPORT Affzo [PSH1]LINAMT(NOL) : Endif
End

