$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif

Case ACTION
  When "DEBUT"    :   Gosub DEBUT
  When "SETBOUT"  :   Gosub SETBOUT
Endcase
Return


##############################################################
######################    ACCIONES    ########################
##############################################################
################################################
$DEBUT
# Solamente si vengo del Seguimiento Taller
If GFONCTION = "FUNSFTPOR"

  # Primero lanzo el proceso STD
  Gosub DEBUT From TRTSFTEAC

  # Ahora pongo por defecto el número de identificación y la planta del seguimiento taller
  [M:SFTEA]FLTEMPNUM = [M:SFTP0]EMPNUM
  [M:SFTEA]FLTFCY    = [M:SFTP0]FCY
  Affzo [M:SFTEA]FLTEMPNUM
  Affzo [M:SFTEA]FLTFCY

  # Bloqueo la acción del STD
  GPE = 1
Endif
Return

################################################
$SETBOUT
  # ordena el cuadro por los campos "Fecha inicial" y "Hora inicio" (CSA003 - JC)
  Sorta [M:SFTEA]NBLIG [M:SFTEA]NBLIG Order By [M:SFTEA]STRDAT(indice), [M:SFTEA]STRTIM(indice)

  Case BOUT
    When "H"      : Gosub PAINTFILES   # cambia el color de las líneas cuando "Fecha arranque centro" <> "Fecha inicial" (CSA007)
    When Default
  Endcase

  Affzo [M:SFTEA]25
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
################################################
# cambia el color de las líneas cuando "Fecha arranque centro" <> "Fecha inicial" (CSA007)
$PAINTFILES
Local Integer LCON : Raz LCON

  For LCON = 0 To [M:SFTEA]NBLIG
    If [M:SFTEA]SHIFTDAT(LCON) <> [M:SFTEA]STRDAT(LCON)
      Chgstl [M:SFTEA]NBLIG(LCON) With "BACKRED"
    Endif
  Next

Return

