#<AdxTL>@(#)0.0.0.0 $Revision$
Global  Char GCORREO(100)
Global  Char GNUMPED(100)
Local   Char TBPAR(50)(1..19)
Local   Char TBVAL(50)(1..19)

If !clalev([F:YRP0]) Then : Local File  YRECPOH   [F:YRP0] : Endif
If !clalev([F:BPA0]) Then : Local File  BPADDRESS [F:BPA0] : Endif
If !clalev([F:POH0]) Then : Local File  PORDER    [F:POH0] : Endif

  # si se lanza la tarea batch
  If !GSERVEUR Then
    Call TEMPON("Proceso reclamaciˇn de compras") From GESECRAN
  Endif
  Call OUVRE_TRACE ("Proceso reclamaciˇn de compras") From LECFIC

For [YRP0]

  Raz GCORREO, GNUMPED

  # parßmetros del informe
  TBPAR(1)  = "commandedeb"         : TBVAL(1)  = [F:YRP0]POHNUM
  TBPAR(2)  = "commandefin"         : TBVAL(2)  = [F:YRP0]POHNUM
  TBPAR(3)  = "fournisseurdeb"      : TBVAL(3)  = [F:YRP0]BPSNUM
  TBPAR(4)  = "fournisseurfin"      : TBVAL(4)  = [F:YRP0]BPSNUM
  TBPAR(5)  = "sitedeb"             : TBVAL(5)  = [F:YRP0]POHFCY
  TBPAR(6)  = "sitefin"             : TBVAL(6)  = [F:YRP0]POHFCY
  TBPAR(7)  = "datedeb"             : TBVAL(7)  = [F:YRP0]ORDDAT
  TBPAR(8)  = "datefin"             : TBVAL(8)  = [F:YRP0]ORDDAT
  TBPAR(9)  = "devdeb"              : TBVAL(9)  = [F:YRP0]NETCUR
  TBPAR(10) = "devfin"              : TBVAL(10) = [F:YRP0]NETCUR
  TBPAR(11) = "avenantdeb"          : TBVAL(11) = "0"
  TBPAR(12) = "avenantfin"          : TBVAL(12) = "0"
  TBPAR(13) = "comsolddeb"          : TBVAL(13) = "1"
  TBPAR(14) = "comsoldfin"          : TBVAL(14) = "1"
  TBPAR(15) = "etatlivdeb"          : TBVAL(15) = "1"
  TBPAR(16) = "etatlivfin"          : TBVAL(16) = "1"
  TBPAR(17) = "etatfacdeb"          : TBVAL(17) = "1"
  TBPAR(18) = "etatfacfin"          : TBVAL(18) = "1"
  TBPAR(19) = "codimp"              : TBVAL(19) = "2"

  # guarda el n˙mero de pedido para a˝adirlo al asunto del mensaje
  GNUMPED   = [F:YRP0]POHNUM

  # guarda el nombre del proveedor para el cuerpo del mensaje
  Read [F:POH0]POH0 = [F:YRP0]POHNUM
  If !fstat Then
    GNOMPRO = [F:POH0]BPRNAM
  Endif

  # busca la direcciˇn de correo del proveedor
  Filter [F:BPA0] Where BPAADDFLG = 2 and BPANUM = [F:YRP0]BPSNUM
  Read   [F:BPA0] First
  If !fstat Then
    GCORREO = [F:BPA0]WEB(0)
  Endif
  Filter [F:BPA0]

  # lanza el informe si existe direcciˇn de correo
  If GCORREO <> "" Then
    Call ETAT("Y-PCOMPRA", "YRECPOH", "SPA", 0, "", TBPAR, TBVAL) From AIMP3
    Call ECR_TRACE("Pedido n║ " + GNUMPED + " enviado a la direcciˇn de correo " + GCORREO, 0) From GESECRAN
  Endif


Next

If !GSERVEUR Then
  Call TEMPOFF() From GESECRAN
Endif
# fin de traza
Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
Call FERME_TRACE From LECFIC
# lectura
If !GSERVEUR Then
  Call LEC_TRACE From LECFIC
Endif

If clalev([F:YRP0])  Then : Close Local File      [F:YRP0] : Endif
If clalev([F:BPA0])  Then : Close Local File      [F:BPA0] : Endif
If clalev([F:POH0])  Then : Close Local File      [F:POH0] : Endif

If dim(GCORREO) > 0 : Kill GCORREO : Endif
If dim(GNUMPED) > 0 : Kill GNUMPED : Endif

End
