######################################################################################
$ACTION
Case ACTION
 When Default
Endcase
Return

######################################################################################
Subprog IB_NBLIG
# Si es una línea que facturo recepción, muestro botón contextual para introducir datos de consigna
If [M:PIH3]TYPORI = 2 and [M:PIH0]NUM <> ''
  GBOUT15 = "Detalle lotes - Consigna"
Else
  GBOUT15 = ""
Endif
End


######################################################################################
Subprog B15_NBLIG
# Lanzo acción para gestionar la introducción de detalle de sublotes para la consigna
Local Integer LINT
Global Char GL1LLE(50)(2)
Call SAISIE_LIB(LINT,GL1LLE,"YCONSIGNA","SPEYCON","OBJZON") From GSAISIE
End

