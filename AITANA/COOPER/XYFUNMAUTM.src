#<AdxTL>@(#)0.0.0.0 $Revision$
#####################################################################################
# Src: XYFUNMAUTM
#-------------------------------------------------------------------------------------
# (Puesta a nivel)
#-------------------------------------------------------------------------------------
# Proyecto: JAE
#-------------------------------------------------------------------------------------
# Version: v11
#-------------------------------------------------------------------------------------
# Fecha:31-08-2018
#-------------------------------------------------------------------------------------
# Desarrollador: DSAL
# Codigo Actividad: YS001
# Modificaciones #JAE
#######################################################################################
$ACTION
Case ACTION
 When "BOUTON"        : Gosub BOUTON
Endcase
Return


##########################################################################
$BOUTON
Case BOUT
    When "1" : Gosub TRT_OF_SEL : FIN=1
    When "2" : Gosub INCLUDE From FUNMAUTM
    When "3" : Gosub EXCLUDE From FUNMAUTM
Endcase

# Bloqueo STD
GPE = 1
Return



##########################################################################
$TRT_OF_SEL

# récupération compteur OF
Local Integer WOK
Call LECTCA(8,WOK) From SUBTCA
If WOK=0 : Call ERREUR(mess(58,105,1)-mess(8,14,1)-":"-mess(250,199,1)) From GESECRAN : Return : Endif
GCODNUM    = [F:TCA]CODNUM(0)   # compteur OF
GOPS       = [F:TCA]CODNUM(4)   # compteur encours opérations
If !GSERVEUR
    TRA = 1
    Call OUVRE_TRACE(TIT) From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call PRTSCR("MAUTMFG","DIA","",0,1) From ATRTX3
    Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
    Call ECR_TRACE(" ",0) From GESECRAN
Endif

Gosub MAJ_OF_TRANSAC
If GNBOF
    Call ECR_TRACE(" ", 0) From GESECRAN
    WMESS1= num$(GNBOF)-mess(638,197,1)    # Mise(s) à niveau en série effectuée(s)
    Call ECR_TRACE(WMESS1, 0) From GESECRAN
Endif

# aucune mise à niveau effectuée
If !GNBOF & OK
     GERR = 2 : Call ECR_TRACE (mess(88,193,1),0) From GESECRAN
Endif

# fermeture trace
Call FERME_TRACE From LECFIC

# Sup. des globales perso
If dim (GRELITM)>0 : Kill GRELITM : Endif
If dim (GMFGLIN)>0 : Kill GMFGLIN : Endif
If dim (GUNUSE) >0 : Kill GUNUSE  : Endif
If dim (GNBOF) >0  : Kill GNBOF : Endif

Call LEC_TRACE From LECFIC

Return



#########################################################################
# traitement des ordres
$MAJ_OF_TRANSAC
Local Integer I
GNBOF = 0

# On boucle sur les lignes du tableau
For I = 0 To [M:MMF1]NBLIG-1
# Issue 113530 - 2016-01-25 by BEEBE : inner join link for correct selection to be able for a Rewrite MFG
  Link [MFI] With [MFG]MFG0~=[F:MFI]MFGNUM
&          As [MFX]
&          Where [F:MFI]MFGNUM = [M:MMF1]MFGNUM(I) & [M:MMF1]FMODIF(I)=2 & [F:MFG]ROUNUM=[M:MMF1]ROUNUM(I) &
&                [F:MFG]ROUALT=[M:MMF1]ROUALT(I) & [F:MFI]BOMALT=[M:MMF1]BOMALT(I)
&                      Order By Key MFI0(1)
  For [MFX]

      # GH 08/10/2013 dm 91540
      #If [F:MFG]MFGTRKFLG >1 : Goto NXT_MFG_TRANSAC : Endif  # on ne met à niveau que les oF en attente
      #If [F:MFG]MFGTRKFLG > 3 : Goto NXT_MFG_TRANSAC : Endif  # on ne met pas à niveau que les OF >= En cours   #JAE. Autorizo cambios de OF que estén En Curso
      If [F:MFG]MFGTRKFLG > 4 : Goto NXT_MFG_TRANSAC : Endif  # on ne met pas à niveau que les OF > En cours
      #GPE = ([F:MFG]MFGTRKFLG = 1) #JAE. Autorizo cambios de OF que estén En Curso
      GPE = ([F:MFG]MFGTRKFLG = 1 or [F:MFG]MFGTRKFLG = 4) #JAE. Autorizo cambios de OF que estén En Curso
      GPOINT = "CUSSELFLT2" : Gosub ENTREE From EXEFNC
      If !GPE : Goto NXT_MFG_TRANSAC : Endif

      Raz [M:MFGK]
      STOP = 0
      GUNUSE = 0
      WVISUGHOST = 0
      WLOAD = 0
      WJAL  = 0
      [M:MFGK]MFGNUM  = [F:MFG]MFGNUM
      [M:MFGK]MFGFCY  = [F:MFG]MFGFCY
      [M:MFGK]MFGSTA  = [F:MFG]MFGSTA
      [M:MFGK]PRVQTY  = [F:MFG]EXTQTY
      [M:MFGK]EXTQTY  = [F:MFG]EXTQTY
      [M:MFGK]STRDAT  = [F:MFG]STRDAT
      [M:MFGK]ENDDAT  = [F:MFG]ENDDAT
      [M:MFGK]ROUNUM  = [F:MFG]ROUNUM
      [M:MFGK]ROUALT  = [F:MFG]ROUALT
      [M:MFGK]PIO     = [F:MFG]MFGPIO
      [M:MFGK]ITMREF  = [F:MFI]ITMREF
      GRELITM = [M:MFGK]ITMREF

      [M:MFGK]AUTOTRT = 2

      # Issue 113530 - 2016-01-25 by BEEBE : Read MFGHEAD separate to be able for a Rewrite on MFG
      Read [MFG]MFG0=[F:MFI]MFGNUM

      # Ignorer les OF qui possèdent des éléments non prévus
      # mode de lancement OF  : complet ou matières seules
      # On recherche s'il existe une matière non prévue
      If find([F:MFG]MFGMOD,1,2) & [M:DIA]UNENVISAG=1
          For [MFM]MFM0 Where MFGNUM=[M:MFGK]MFGNUM
              If [F:MFM]BOMSEQ=0
                  # l'OF posséde des éléments non prévus : ignoré
                  WMESS1 =mess(156,197,1)-[F:MFM]MFGNUM-mess(250,193,1)
                  Call ECR_TRACE( WMESS1 ,0) From GESECRAN
                  STOP = 1  : Break
              Endif
          Next
      Endif
      If STOP = 1 :  Goto NXT_MFG_TRANSAC  : Endif

      # mode de lancement OF  : complet ou opérations seules
      # On recherche s'il existe une ope non prévue ou commandée (sous-traitance)
      If find([F:MFG]MFGMOD,1,3) & ([M:DIA]UNENVISAG=1 | find([M:DIA]TYPMAN,2,4))
          For [MFO]MFO0 Where MFGNUM=[M:MFGK]MFGNUM
              If [F:MFO]ROUOPENUM=0 & [M:DIA]UNENVISAG=1
                 # l'OF possède des éléments non prévus : ignoré
                 WMESS1 =mess(156,197,1)-[F:MFO]MFGNUM-mess(250,193,1)
                 Call ECR_TRACE( WMESS1 ,0) From GESECRAN
                 STOP = 1  : Break
              # Issue 115619 - 2016-05-26 by GH : not consider WO with ordered operations
              Elsif [F:MFO]OPESTA=7 & find([M:DIA]TYPMAN,2,4)
                 # Operation status x = Ordered
                 WMESS1 =mess(156,197,1)-[F:MFO]MFGNUM-":"-mess(108,200,1)-num$([F:MFO]OPENUM)-"="-mess(7,308,1)-"->"-mess(1215,9900,1)
                 Call ECR_TRACE( WMESS1 ,0) From GESECRAN
                 STOP = 1  : Break
              Endif
          Next
      Endif
      If STOP = 1 :  Goto NXT_MFG_TRANSAC : Endif

      Gosub TRTMAN From FUNMAUTM
      If GOK<1 : Break : Endif   # FQ 69909 Ctrl des sources avant Return

$NXT_MFG_TRANSAC
  Next
Next
Filter [MFG]
Return

