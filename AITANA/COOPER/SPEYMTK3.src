#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "DEBUT"    :   Gosub DEBUT
  When "BOUTON"   :   Gosub BOUTON
Endcase
Return

##################################################
$DEBUT
# Limpio la pantalla
Raz [M:YMTK3]

If !clalev([YY1])   : Local File MFGMATTRK     [YY1]   : Endif

# Cargo los valores de los campos que traigo del seguimiento
[M:YMTK3]SEGUIMIENTO = GL5LLE(0)
[M:YMTK3]LINEA       = val(GL5LLE(1))
[M:YMTK3]ARTICULO    = GL5LLE(2)
[M:YMTK3]LOTE        = GL5LLE(3)

# Capturo los valores de la tabla, no los de la pantalla
Read [YY1]MKM0 = [M:YMTK3]SEGUIMIENTO;[M:YMTK3]LINEA
If fstat = 0
  [M:YMTK3]AROLLO      = [YY1]YROLLOS
  [M:YMTK3]APOSICION   = [YY1]YPOSICION
  [M:YMTK3]ALOTEPT     = [YY1]YLOTE
Else
  [M:YMTK3]AROLLO      = val(GL5LLE(4))
  [M:YMTK3]APOSICION   = GL5LLE(5)
  [M:YMTK3]ALOTEPT     = GL5LLE(6)
Endif

# Por defecto, nuevos valores son los mismos que los actuales
[M:YMTK3]NROLLO      = [M:YMTK3]AROLLO
[M:YMTK3]NPOSICION   = [M:YMTK3]APOSICION
[M:YMTK3]NLOTEPT     = [M:YMTK3]ALOTEPT

# Muestro valores
Affzo [M:YMTK3]
Return



##################################################
$BOUTON
# Actualizo los valores de
If BOUT = 'Z'
  If !clalev([YY1])   : Local File MFGMATTRK     [YY1]   : Endif
  Read [YY1]MKM0 = [M:YMTK3]SEGUIMIENTO;[M:YMTK3]LINEA
  If fstat = 0
    [YY1]YROLLOS   = [M:YMTK3]NROLLO
    [YY1]YPOSICION = [M:YMTK3]NPOSICION
    [YY1]YLOTE     = [M:YMTK3]NLOTEPT
    Rewrite [YY1]
  Endif
  Close Local File [YY1]

  # Cierro la pantalla
  FIN = 1

Endif
Return

