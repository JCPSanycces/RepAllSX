#######################################################################################
#PATCH: Modificaciones del proceso STD (TRTSFTP) que bajamos a SPE (XYTRTSFTP)
#######################################################################################
$ACTION
Case [L]ACTION
  When "SETBOUT"   : Gosub SETBOUT
  When "DEBUT"     : Gosub DEBUT
  When "AV_CHOIX"  : Gosub AV_CHOIX
  When "BOUTON"    : Gosub BOUTON
Endcase
Return



######################################################################################
$SETBOUT
  Raz CHMEN, CHBOU

  # Clear is always enabled
  CHMEN += "R"

  #PATCH. Si el trabajador está indicado, habilito el botón de consumo de materiales y el de alta de material e impresión de etiquetas de muestras
  If [M:SFTP0]EMPNUM > 0 & len([M:SFTP0]FCY) > 0
    CHMEN += "ZXW"
  Endif

  # Elapsed labor is based on employee access (and must be clocked in if required by site)
#  If [M:SFTP0]EMPNUM > 0 & len([M:SFTP0]FCY) > 0 & func SFTLIB.ELAPSEDLABORENTRY([M:SFTP0]EMPNUM) = [V]CST_AYES &
#&    ((SFTDTLTEAM = [V]CST_AYES & TEAMMEMCLK = [V]CST_AYES & SFTEMPCLK = [V]CST_AYES) |
#&     (SFTDTLTEAM = [V]CST_ANO & SFTEMPCLK <> [V]CST_AYES) |
#&     (SFTDTLTEAM = [V]CST_ANO & SFTEMPCLK = [V]CST_AYES & func SFTLIB.EMPLOYEE_CLOCKED_IN([M:SFTP0]EMPNUM) = [V]CST_AYES))
#    CHMEN += "T"
#  Endif

  # Enable the Labor link when employee id, site have been entered and clocked in.
  If [M:SFTP0]EMPNUM > 0 & len([M:SFTP0]FCY) > 0 &
&    !find(2,[M:SFTP0]INDTYP) & !find(4,[M:SFTP0]INDTYP) &
&    ((SFTDTLTEAM = [V]CST_AYES & TEAMMEMCLK = [V]CST_AYES & SFTEMPCLK = [V]CST_AYES) |
&     (SFTDTLTEAM = [V]CST_ANO & SFTEMPCLK <> [V]CST_AYES) |
&     (SFTDTLTEAM = [V]CST_ANO & SFTEMPCLK = [V]CST_AYES & func SFTLIB.EMPLOYEE_CLOCKED_IN([M:SFTP0]EMPNUM) = [V]CST_AYES))
    CHMEN += "L"  # Labor
    CHMEN += "B"  # Break
    CHMEN += "I"  # Indirect references
  Endif

  # Only enable Clock in if not a team
  If [M:SFTP0]EMPNUM > 0 & len([M:SFTP0]FCY) > 0 & SFTDTLTEAM = [V]CST_ANO & SFTEMPCLK = [V]CST_AYES
    CHMEN += "C"
  Endif

  # Only enable the Stop if there are open actions in the grid and employee is clocked in
  If [M:SFTP0]NBLIG > 0 &
&    ((SFTDTLTEAM = [V]CST_AYES & TEAMMEMCLK = [V]CST_AYES & SFTEMPCLK = [V]CST_AYES) |
&     (SFTDTLTEAM = [V]CST_ANO & SFTEMPCLK<> [V]CST_AYES) |
&     (SFTDTLTEAM = [V]CST_ANO & SFTEMPCLK = [V]CST_AYES & func SFTLIB.EMPLOYEE_CLOCKED_IN([M:SFTP0]EMPNUM) = [V]CST_AYES))
    CHMEN += "S"
  Endif

  # If Employee ID is entered - enable Defaults button
  If [M:SFTP0]EMPNUM > 0
    CHMEN += "D"  # Defaults
  Endif

  # If Employee ID is a summary team and was NOT on exclusive task - enable Adjust team button
  If [M:SFTP0]EMPNUM > 0 & func SFTLIB.EMPTYP(EMPNUM) = 3 & !find(2,[M:SFTP0]INDTYP) & !find(4,[M:SFTP0]INDTYP)
    CHMEN += "A"  # Adjust team
  Endif

  #If employee is a part of a team and there are open team activities that this employee is not active in, enable Join team button
  If [M:SFTP0]TEAMNUM <> 0 &  [M:SFTP0]CLOCKINFO <> "" & func SFTLIB.OPEN_ACTIVITIES(0, [M:SFTP0]EMPNUM) = [V]CST_ANO & SFTEMPCLK = [V]CST_AYES
    If func SFTLIB.TEAM_ON_TASK([M:SFTP0]TEAMNUM, "EX") <> [V]CST_AYES & func SFTLIB.TEAM_ON_TASK([M:SFTP0]TEAMNUM, "NON") = [V]CST_AYES
      CHMEN += "J"
    Endif
  Endif

GPE=1 #PATCH. Bloqueo la acción SETBOUT del STD

Return



######################################################################################
$DEBUT
#PATCH. Cargo valores por defecto de la pantalla y bloqueo acción del STD
# Limpio pantalla
Raz [SFTP0]

# Busco si hay un Colaborador asignado al usuario X3. Si lo hay, cargo valor y lanzo acción de campo
If !clalev([XX0])   : Local File TABMAT    [XX0]   : Endif
Read [XX0]TMA1 = GUSER
If fstat = 0
  [M:SFTP0]EMPNUM = [XX0]EMPNUM
  Affzo [M:SFTP0]EMPNUM
Endif
Close Local File [XX0]
Call AM_EMPNUM([M:SFTP0]EMPNUM) From TRTSFTP

# Busco la primera línea de la pantalla, la selecciono y cargo cuadro de información
If [M:SFTP0]NBLIG > 0
  [M:SFTP0]SELLIN(0) = 2
  Affzo [M:SFTP0]SELLIN(0)
  Call CARGO_INFO(0)
  Call CARGO_TEXTO(0)
Endif

# Cargo la variable global de la planta que voy a emplear en el consumo de materiales
GXAFCY = [M:SFTP0]FCY

# Bloqueo STD
GPE = 1
Return


######################################################################################
$AV_CHOIX
#PATCH. Marco la primera línea y muestro el campo de Información
If [M:SFTP0]NBLIG > 0
  [M:SFTP0]SELLIN(0) = 2
  Affzo [M:SFTP0]SELLIN(0)
  Gosub TIEMPOS_LINEA #JAE
  Call CARGO_INFO(0)
  Call CARGO_TEXTO(0)
Endif
Return


######################################################################################
$BOUTON
#PATCH. Ejecución de los botones
Case BOUT
  When "X"    :   Gosub ALTA
Endcase
Return


######################################################################################
$ALTA
#PATCH. Llamo al objeto MTK
Local Char VECTOR (50)(1)
Call OBJET("MTK",VECTOR(0),"JAEAP") From GOBJET

Return


######################################################################################
Subprog AM_SELLIN(VALEUR)
Variable Integer VALEUR
# Limpio bloque de información
Raz [M:SFTP0]YINFO

# Si marco el flag, cargo información
If VALEUR = 2
  Call CARGO_INFO(nolign-1)
  Call CARGO_TEXTO(nolign-1)
Endif

# Refresco pantalla
Affzo [M:SFTP0]YINFO
End


######################################################################################
Subprog AM_EMPNUM(VALEUR)
Variable Decimal VALEUR
# Llamo a la acción STD
Call AM_EMPNUM([M:SFTP0]EMPNUM) From TRTSFTP

# Marco primera línea y bloque informativo
If [M:SFTP0]NBLIG > 0
  [M:SFTP0]SELLIN(0) = 2
  Affzo [M:SFTP0]SELLIN(0)
  Call CARGO_INFO(0)
  Call CARGO_TEXTO(0)
Endif

# Cargo la variable global de la planta que voy a emplear en el consumo de materiales
GXAFCY = [M:SFTP0]FCY

# Bloqueo STD
GPE = 1
End


######################################################################################
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
# Cargo la variable global de la planta que voy a emplear en el consumo de materiales
GXAFCY = VALEUR
End


######################################################################################
Subprog CARGO_INFO(VLIN)
Value Integer VLIN

# Declaro variables
Local Char TEXTO(200)
Local Char OPERA

# Saco el tipo de operación
Case [M:SFTP0]SFTTYP(VLIN)
  When 1 : OPERA = 'RELOJ'
  When 2 : OPERA = 'INDIRECTO'
  When 3 : OPERA = 'PAUSA'
  When 4 : OPERA = 'PREPARACION'
  When 5 : OPERA = 'EJECUCIÓN'
Endcase

# Informo en el caso que esté la OF en Indirecto
If [M:SFTP0]SFTTYP(VLIN) = 2
  If !clalev([XX4])   : Local File ATEXTRA [XX4]   : Endif
  Read [XX4]AXX0 = 'SFTINDREF';'INDESAXX';'SPA';[M:SFTP0]VCRNUM(VLIN);''
  If fstat = 0
    TEXTO = 'En trabajo fuera de carga por ' + [XX4]TEXTE + ' desde las ' + [M:SFTP0]STRTIM(VLIN)
  Endif
  Close Local File [XX4]
Endif

# Informo en el caso que esté la OF en Pausa
If [M:SFTP0]SFTTYP(VLIN) = 3
  If !clalev([XX4])   : Local File ATEXTRA [XX4]   : Endif
  Read [XX4]AXX0 = 'SFTINDREF';'INDESAXX';'SPA';[M:SFTP0]VCRNUM(VLIN);''
  If fstat = 0
    TEXTO = 'En pausa por ' + [XX4]TEXTE + ' desde las ' + [M:SFTP0]STRTIM(VLIN)
  Endif
  Close Local File [XX4]
Endif

# Informo en el caso que esté la OF en Preparación / Operacion
If [M:SFTP0]SFTTYP(VLIN) = 4 or [M:SFTP0]SFTTYP(VLIN) = 5
  # Saco el artículo, la cantidad lanzada y datos de la operación
  If !clalev([XX1])   : Local File MFGITM       [XX1]   : Endif
  If !clalev([XX2])   : Local File ITMMASTER    [XX2]   : Endif

  # Primera línea del texto información general
  #JAE
  If [M:SFTP0]FCY = 'JAE'
    If !clalev([YY4])   : Local File ATEXTRA   [YY4]   : Endif
    Local Char PRO_DES (200)
    Local Char PRO_COD (50)
    Read [XX1]MFI2 = [M:SFTP0]VCRNUM(VLIN)
    If fstat = 0
      Read [YY4]AXX0 = 'PIMPL';'PIMDESAXX';'SPA';[XX1]PJT;''               #Pongo la descripción de la tarea del proyecto
      If fstat = 0
        [L]PRO_COD = [XX1]PJT
        [L]PRO_DES = [YY4]TEXTE
      Endif
    Endif
    If [L]PRO_COD <> ''
      TEXTO = 'OF:' + [M:SFTP0]VCRNUM(VLIN) + ' PRO:' + [XX1]PJT + ' ' + [L]PRO_DES + ' en ' + OPERA + ' desde las ' + [M:SFTP0]STRTIM(VLIN) + chr$(10)
    Else
      TEXTO = [M:SFTP0]VCRNUM(VLIN) + ' en ' + OPERA + ' desde las ' + [M:SFTP0]STRTIM(VLIN) + chr$(10)
    Endif
    Close Local File [YY4]
  Else
    TEXTO = [M:SFTP0]VCRNUM(VLIN) + ' en ' + OPERA + ' desde las ' + [M:SFTP0]STRTIM(VLIN) + chr$(10)
  Endif

  # Segunda línea del texto
  # Saco el artículo, la cantidad lanzada y datos de la operación
  If !clalev([XX1])   : Local File MFGITM       [XX1]   : Endif
  If !clalev([XX2])   : Local File ITMMASTER    [XX2]   : Endif
  Read [XX1]MFI2 = [M:SFTP0]VCRNUM(VLIN)
  If fstat = 0
    Read [XX2]ITM0 = [XX1]ITMREF
    If fstat = 0
      TEXTO += [XX2]ITMREF + ' ||| ' + [XX2]ITMDES1 + ' .Cantidad OF: ' + num$([XX1]UOMEXTQTY) + ' ' + [XX1]UOM + chr$(10)
    Endif
  Endif
  Close Local File [XX1],[XX2]

  # Tercera línea del texto
  # Datos de la operación
  # 25/10/18. Quito la información del tiempo estimado
  If !clalev([XX3])   : Local File MFGOPE       [XX3]   : Endif

  Read [XX3]MFO0 = [M:SFTP0]VCRNUM(VLIN);[M:SFTP0]OPENUM(VLIN);0
  If fstat = 0
    Case [XX3]TIMUOMCOD
      When 1 : TEXTO += [XX3]ROODES + chr$(10)#+ ' .Tiempo estimado: ' + num$([XX3]EXTSETTIM + [XX3]EXTOPETIM) + ' Horas'+ chr$(10)
      When 2 : TEXTO += [XX3]ROODES + chr$(10)#+ ' .Tiempo estimado: ' + num$(ar2(([XX3]EXTSETTIM + [XX3]EXTOPETIM)/60)) + ' Horas' + chr$(10)
    Endcase
  Endif
  Close Local File [XX3]
Endif

# Informo de los componentes
If [M:SFTP0]SFTTYP(VLIN) = 4 or [M:SFTP0]SFTTYP(VLIN) = 5
  # Saco el artículo, la cantidad lanzada y datos de la operación
  If !clalev([XX1])   : Local File MFGMAT       [XX1]   : Endif
  If !clalev([XX2])   : Local File ITMMASTER    [XX2]   : Endif

  Local Char COMPO(200)

  For [XX1] Where [XX1]MFGNUM = [M:SFTP0]VCRNUM(VLIN)
    Read [XX2]ITM0 = [XX1]ITMREF
    If fstat = 0
      [L]COMPO += [XX2]ITMREF + ' ' + [XX2]ITMDES1 + ' ' + num$([XX1]RETQTY) + ' ' + [XX1]BOMUOM
      Break # Por seguridad solamente saco un componente
    Endif
  Next
  TEXTO += [L]COMPO
  Close Local File [XX1],[XX2]
Endif

# Muestro texto informativo
[M:SFTP0]YINFO = TEXTO
Affzo [M:SFTP0]YINFO
End


######################################################################################
Subprog CARGO_TEXTO(VLIN)
Value Integer VLIN

# Busco el TEXTO PRODUCCION introducido en el maestro del artículo que lanzamos en la OF
If !clalev([ZZ1])   : Local File MFGITM    [ZZ1]   : Endif
If !clalev([ZZ2])   : Local File ITMMASTER [ZZ2]   : Endif
If !clalev([ZZ3])   : Local File TEXCLOB   [ZZ3]   : Endif

Read [ZZ1]MFI2 = [M:SFTP0]VCRNUM(VLIN)
If fstat = 0
  Read [ZZ2]ITM0 = [ZZ1]ITMREF
  If fstat = 0
    Read [ZZ3]TXC0 = [ZZ2]MFGTEX
    If fstat = 0
      [M:SFTP0]YTEXTO = [ZZ3]TEXTE
      Affzo [M:SFTP0]YTEXTO
    Endif
  Endif
Endif
Close Local File [ZZ1],[ZZ2],[ZZ3]
End


######################################################################################
$TIEMPOS_LINEA
#Muestro los tiempos de las actividades en curso de las tareas de tipo Ejecución
Local Integer LINE

For LINE=0 To [M:SFTP0]NBLIG-1
  If [M:SFTP0]SFTTYP(LINE) = 5
    If !clalev([XX9])   : Local File MFGOPE [XX9]   : Endif

    Read [XX9]MFO0 = [M:SFTP0]VCRNUM(LINE);[M:SFTP0]OPENUM(LINE);0
    If fstat = 0
      [M:SFTP0]YTPREV(LINE) =   [XX9]EXTSETTIM + [XX9]EXTOPETIM               # Tiempo previsto
      [M:SFTP0]YTREA(LINE)  =   [XX9]CPLSETTIM + [XX9]CPLOPETIM               # Tiempo realizado
      [M:SFTP0]YTRES(LINE)  =   [M:SFTP0]YTPREV(LINE) - [M:SFTP0]YTREA(LINE)  # Tiempo restante
      Affzo [M:SFTP0]YTPREV(LINE)
      Affzo [M:SFTP0]YTREA(LINE)
      Affzo [M:SFTP0]YTRES(LINE)
    Endif
    Close Local File [XX9]
  Endif
Next
Return

