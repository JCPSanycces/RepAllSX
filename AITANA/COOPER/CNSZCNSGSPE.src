#####################################################################################
# Src: CNSZCNSGSPE
#-------------------------------------------------------------------------------------
# (Consulta consigna)
#-------------------------------------------------------------------------------------
# Proyecto: JAE
#-------------------------------------------------------------------------------------
# Version: PU11
#-------------------------------------------------------------------------------------
# Fecha:02-05-2018
#-------------------------------------------------------------------------------------
# Desarrollador: PT07
# Codigo Actividad: Z001
#######################################################################################
#DEV: PT07 02-05-2018 JYM180501_Consulta consigna

$ACTION

Case ACTION
  When "OUVRE"   : Gosub OUVRE
  When "LECTURE" : Gosub LECTURE
Endcase

Return
#############################################################################

$OUVRE

Local Char S_CRIT(250)
Local Char S_CRIT2(250)
Local Char S_CRIT3(250)
Local Integer I_BREAK

Raz [M:ZSG0]
Raz [M:ZSG1]

RETOUR = 1
SUITE = 1
CHARGMT = 0

Return
#############################################################################

$LECTURE
# Si no hay fechas, paro búsqueda
If [M:ZSG0]DATEDEB='000000' and [M:ZSG0]DATEFIN='000000'
  Return
Endif

Gosub CHANGE_MSK From GCONSULT
If CHGPAG<0 : NOL = MAXLIG : Endif

Local Integer I_WRITE

Gosub FORMAR_CRITERIO

Gosub PAGINACION_1

[L]I_BREAK = 0
For [F:STJ]
  [L]I_WRITE = 1
  Gosub COMPROBACIONES
  If I_WRITE Then
    Gosub PAGINACION_2

    If [L]I_BREAK : Break : Endif


    [M:ZSG1]BPSNUM(nolign-1)        = [F:STJ]BPRNUM
    [M:ZSG1]TCLCOD(nolign-1)        = func GET_TCLCOD([F:STJ]ITMREF)
    [M:ZSG1]ITMREF(nolign-1)        = [F:STJ]ITMREF
    [M:ZSG1]ZKG(nolign-1)           = [F:STJ]QTYSTU
    [M:ZSG1]ZPRECIOREC(nolign-1)    = [F:STJ]PRIORD
    [M:ZSG1]ZCONSUMIDO(nolign-1)    = [L]F_SUM_CONSUMOS
    [M:ZSG1]ZEXISTENCIAS(nolign-1)  = [M:ZSG1]ZKG(nolign-1) - [L]F_SUM_CONSUMOS
    [M:ZSG1]DES(nolign-1)           = func GET_ITMDES([F:STJ]ITMREF)
    [M:ZSG1]LOT(nolign-1)           = [F:STJ]LOT
    [M:ZSG1]PTHNUM(nolign-1)        = [F:STJ]VCRNUM
    [M:ZSG1]PTHDAT(nolign-1)        = [F:STJ]IPTDAT
    [M:ZSG1]ZCADDAT(nolign-1)       = func GET_CADDAT([F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO)
    [M:ZSG1]ZPLAZO(nolign-1)        = [M:ZSG1]ZCADDAT(nolign-1) - date$
    [M:ZSG1]ZCONSIGNA(nolign-1)     = [L]S_CONSIGNA
    [M:ZSG1]ZPRODUCCION(nolign-1)   = [L]S_PRODUCCION
    [M:ZSG1]ZFACTURACION(nolign-1)  = [L]S_FACTURACION
    [M:ZSG1]ZNUMALBPRO(nolign-1)    = func GET_BPSNDE([F:STJ]VCRNUM)
    [M:ZSG1]BPSLOT(nolign-1)        = [F:STJ]BPSLOT
    [M:ZSG1]ZESTADO(nolign-1)       = func GET_ESTADO([F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]STOFCY)
    If [M:ZSG1]ZEXISTENCIAS(nolign-1) = 0 : [M:ZSG1]ZULTCON(nolign-1) = func GET_ULTCON([F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]STOFCY) : Endif
    If [M:ZSG1]ZFACTURACION(nolign-1) <> "SIN NOTIFICAR" : [M:ZSG1]FACNUM(nolign-1) = func GET_FACNUM([F:STJ]SLO,[F:STJ]LOT,[F:STJ]VCRNUM,[F:STJ]VCRLIN) : Endif
    If [M:ZSG1]ZFACTURACION(nolign-1) <> "SIN NOTIFICAR" : [M:ZSG1]FACPRO(nolign-1) = func GET_FACPRO([F:STJ]SLO,[F:STJ]LOT,[F:STJ]VCRNUM,[F:STJ]VCRLIN) : Endif
  Endif

Next

Filter [F:STJ]

Return

#############################################################################

$FORMAR_CRITERIO

[L]S_CRIT = "([F:STJ]VCRTYP = 6 OR [F:STJ]VCRTYP = 19) & [F:STJ]REGFLG<>2"
[L]S_CRIT2 = "1=1"
[L]S_CRIT3 = "1=1"

If [M:ZSG0]BPSNUM <> "" Then
  [L]S_CRIT -= "& [F:stj]BPRNUM = [M:ZSG0]BPSNUM"
Endif

If [M:ZSG0]DATEDEB <> "00000000" Then
  [L]S_CRIT -= "& [F:stj]IPTDAT >= [M:ZSG0]DATEDEB"
Endif

If [M:ZSG0]DATEFIN <> "00000000" Then
  [L]S_CRIT -= "& [F:stj]IPTDAT <= [M:ZSG0]DATEFIN"
Endif

If [M:ZSG0]ITMREFDEB <> "" Then
  [L]S_CRIT2 -= "& [F:stj]ITMREF >= [M:ZSG0]ITMREFDEB"
Endif

If [M:ZSG0]ITMREFFIN <> "" Then
  [L]S_CRIT2 -= "& [F:stj]ITMREF <= [M:ZSG0]ITMREFFIN"
Endif

#Dependiendo del cambio de página que se haga se genera el criterio con los límites
#de registro inicial o final
Case CHGPAG
   When 3 :  [L]S_CRIT3 -= "and [F:stj]BPRNUM >= DEBNUM"
   When 2 :  [L]S_CRIT3 -= "and [F:stj]BPRNUM >  FINNUM"
   When -2 : [L]S_CRIT3 -= "and [F:stj]BPRNUM <  DEBNUM"
Endcase

Return

#############################################################################

$PAGINACION_1

If CHGPAG > 0
  SUITE=1
  If CHGPAG = 1 Then
    RETOUR = 1
  Elsif CHGPAG = 2 Then
    RETOUR = 2
  Endif

  Filter [F:STJ] Where evalue([L]S_CRIT) and evalue([L]S_CRIT2) and evalue([L]S_CRIT3)
Else
  RETOUR=1
  If CHGPAG = -1 Then
    SUITE = 1
  Else
    SUITE = 2
  Endif

    Filter [F:STJ] Where evalue([L]S_CRIT) and evalue([L]S_CRIT2) and evalue([L]S_CRIT3)
Endif

If CHGPAG<>2 & CHGPAG<>-2 : Raz [M:ZSG1] : Endif

Return

#############################################################################

$PAGINACION_2

If NBLU = 1 Then
  If CHGPAG=2 or CHGPAG=-2 Then
    Raz [M:ZSG1]
  Endif

  NBLU = 2
Endif

If CHGPAG > 0 Then
  If NOL >= MAXLIG-1 Then
    SUITE=2
    I_BREAK = 1
  Endif

  If !I_BREAK Then
    NOL += 1
    If NOL=0 Then
      DEBNUM = [F:STJ]BPRNUM
    Endif
      FINNUM = [F:STJ]BPRNUM
  Endif

Else
  If NOL <= 0 Then
    RETOUR=2
    I_BREAK = 1
  Endif

  If !I_BREAK Then
    NOL -= 1
    If NOL = MAXLIG-1 Then
      FINNUM = [F:STJ]BPRNUM
    Endif

    DEBNUM = [F:STJ]BPRNUM
  Endif
Endif

nolign = NOL +1

Return
#############################################################################

$COMPROBACIONES

Local Integer IS_CADGES
Local Integer I_STA
Local Decimal F_SUM_CONSUMOS : [L]F_SUM_CONSUMOS = 0



Local Char S_CONSIGNA (250)
Local Char S_PRODUCCION (250)
Local Char S_FACTURACION(250)
Local Integer I_CONSIGNA    : [L]I_CONSIGNA = 0
Local Integer I_PRODUCCION  : [L]I_PRODUCCION = 0
Local Integer I_FACTURACION : [L]I_FACTURACION = 0

IS_CADGES = func SPEITML.IS_CADGES([F:STJ]ITMREF)

If [L]IS_CADGES Then
  Local Date S_CADDAT : S_CADDAT = func GET_CADDAT([F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO)
  #If [F:STJ]SHLDAT <> [31/12/2999] Then
  If S_CADDAT <> [31/12/2999] Then
    If [M:ZSG0]ZFUERACONS = 2  or [M:ZSG0]ZENCONSIGNA = 2 Then
      [L]I_CONSIGNA = 1
    Endif

    #If [F:STJ]SHLDAT < date$
    If S_CADDAT < date$
      If [L]I_CONSIGNA Then
        If [M:ZSG0]ZFUERACONS <> 2 : [L]I_WRITE = 0 : Endif
      Endif

      [L]S_CONSIGNA = "FUERA DE CONSIGNA"
    Else
      If [L]I_CONSIGNA Then
        If [M:ZSG0]ZENCONSIGNA <> 2 : [L]I_WRITE = 0 : Endif
      Endif

      [L]S_CONSIGNA = "EN CONSIGNA"
    Endif

    [L]F_SUM_CONSUMOS = func SUMA_CONSUMOS([F:STJ]ITMREF, [F:STJ]LOT, [F:STJ]SLO)

    If [M:ZSG0]ZCONSUMIDO = 2 or [M:ZSG0]ZSINCONSUMIR = 2 Then
      [L]I_PRODUCCION = 1
    Endif

    If [L]F_SUM_CONSUMOS >= [F:STJ]QTYSTU Then
      If [L]I_PRODUCCION Then
        If [M:ZSG0]ZCONSUMIDO <> 2 : [L]I_WRITE = 0 : Endif
      Endif

      [L]S_PRODUCCION = "CONSUMIDO"
    Else
      If [L]I_PRODUCCION Then
        If [M:ZSG0]ZSINCONSUMIR <> 2 : [L]I_WRITE = 0 : Endif
      Endif

      [L]S_PRODUCCION = "SIN CONSUMIR"
    Endif

    [L]I_STA = func RECUPERAR_ESTADO_FACTURA([F:STJ]VCRNUM, [F:STJ]VCRLIN, [F:STJ]LOT , [F:STJ]SLO)

    If [M:ZSG0]ZSINNOTIF = 2 or [M:ZSG0]ZNOTIF = 2 or [M:ZSG0]ZFACTURADO = 2 Then
      [L]I_FACTURACION = 1
    Endif

    If [L]I_STA = 0 Then
      If [L]I_FACTURACION Then
        If [M:ZSG0]ZSINNOTIF <> 2 : [L]I_WRITE = 0 : Endif
      Endif

      [L]S_FACTURACION = "SIN NOTIFICAR"
    Elsif I_STA <> 3 Then
      If [L]I_FACTURACION Then
        If [M:ZSG0]ZNOTIF <> 2 :[L]I_WRITE = 0 : Endif
      Endif

      [L]S_FACTURACION = "NOTIFICADO"
    Else
      If [L]I_FACTURACION Then
        If [M:ZSG0]ZFACTURADO <> 2 : [L]I_WRITE = 0 : Endif
      Endif

      [L]S_FACTURACION = "FACTURADO"
    Endif

    If [M:ZSG0]DATECADDEB <> [00/00/0000]
      If S_CADDAT < [M:ZSG0]DATECADDEB : [L]I_WRITE = 0 : Endif
    Endif
    If [M:ZSG0]DATECADFIN <> [00/00/0000]
      If S_CADDAT > [M:ZSG0]DATECADFIN : [L]I_WRITE = 0 : Endif
    Endif

    If [M:ZSG0]DATECON <> [00/00/0000]
      Local Date S_ULTCON : S_ULTCON = func GET_ULTCON([F:STJ]ITMREF,[F:STJ]LOT,[F:STJ]SLO,[F:STJ]STOFCY)
      If ([F:STJ]QTYSTU - [L]F_SUM_CONSUMOS > 0)
        [L]I_WRITE = 0
      Elsif [M:ZSG0]DATECON <> S_ULTCON
        [L]I_WRITE = 0
      Endif
    Endif
  Else
    [L]I_WRITE = 0
  Endif

Else
  [L]I_WRITE = 0
Endif
Return

#############################################################################

Funprog SUMA_CONSUMOS (PS_ITMREF, PS_LOT, PS_SLO)
Value Char PS_ITMREF
Value Char PS_LOT
Value Char PS_SLO

If 1=2
  Local File MFGMATTRK [MKM]

  Local Decimal F_SUM_QTY


  For [F:MKM] Where [F:MKM]ITMREF = PS_ITMREF and [F:MKM]YLOTE = PS_LOT and [F:MKM]YSUBLOTE = PS_SLO
    [L]F_SUM_QTY += [F:MKM]USEQTY
  Next
Endif

If !clalev([YY5])   : Local File STOJOU  [YY5]   : Endif
  Local Decimal F_SUM_QTY

  For [F:YY5] Where [F:YY5]ITMREF = PS_ITMREF and [F:YY5]LOT = PS_LOT and [F:YY5]SLO = PS_SLO and ([F:YY5]VCRTYP = 12 or [F:YY5]VCRTYP = 20)  # Consumos vienen de seguimientos de producción o de
# salidas varias
    [L]F_SUM_QTY += [F:YY5]QTYSTU
  Next
  # Cambio el signo para que salgan los consumos en positivo
  [L]F_SUM_QTY = (-1) * [L]F_SUM_QTY
Close Local File [YY5]

End [L]F_SUM_QTY
#############################################################################


Funprog RECUPERAR_ESTADO_FACTURA(PS_NUM, PI_NUMLIN, P_LOTE, P_SLOTE)
Value Char PS_NUM
Value Integer PI_NUMLIN
Value Char P_LOTE
Value Char P_SLOTE

Local File PINVOICE  [PIH]
Local File PINVOICED [PID]
If !clalev([YCON])   : Local File YCONSIGNA     [YCON]   : Endif


Local Integer I_STA : [L]I_STA = 0

For [F:PID] Where [F:PID]NUMORI = PS_NUM and [F:PID]LINORI = PI_NUMLIN
  Read [PIH]PIH0 = [F:PID]NUM
  If [F:PIH]STA < I_STA or I_STA = 0 Then
    I_STA = [F:PIH]STA
  Endif

  # Si está facturado (validado o no) verifico que el lote está en esta factura. Sino paso variable como no facturado
  If I_STA > 0
    Read [YCON]YCON1 = P_LOTE;P_SLOTE;PS_NUM;PI_NUMLIN
    If fstat <> 0 or [YCON]FACTURA = ''
      I_STA = 0
    Endif
  Endif

Next

End [L]I_STA

#############################################################################

Funprog GET_TCLCOD(PS_ITMREF)
Value Char PS_ITMREF

Local File ITMMASTER

Local Char S_TCLCOD(GLONITG)


Read [F:ITM]ITM0 = PS_ITMREF

[L]S_TCLCOD = [F:ITM]TCLCOD

End [L]S_TCLCOD

#############################################################################
Funprog GET_ESTADO(PS_ITMREF,PS_LOT,PS_SLO,PS_STOFCY)
Value Char PS_ITMREF
Value Char PS_LOT
Value Char PS_SLO
Value Char PS_STOFCY

Local Char S_STA(3)

If !clalev([YY8])   : Local File STOCK  [YY8]   : Endif
Filter [YY8] Where [YY8]STOFCY = PS_STOFCY and [YY8]ITMREF = PS_ITMREF and [YY8]LOT = PS_LOT and [YY8]SLO = PS_SLO
Read [YY8] First
If fstat = 0
  [L]S_STA = [YY8]STA
Endif
Filter [YY8]
Close Local File [YY8]
End [L]S_STA


#############################################################################
Funprog GET_ULTCON(PS_ITMREF,PS_LOT,PS_SLO,PS_STOFCY)
Value Char PS_ITMREF
Value Char PS_LOT
Value Char PS_SLO
Value Char PS_STOFCY

Local Date S_ULTCON

If !clalev([YY9])   : Local File STOJOU  [YY9]   : Endif
Filter [YY9] Where [YY9]STOFCY = PS_STOFCY and [YY9]ITMREF = PS_ITMREF and [YY9]LOT = PS_LOT and [YY9]SLO = PS_SLO and [YY9]TRSTYP = 6 Order By [YY9]IPTDAT Desc
Read [YY9] First
If fstat = 0
  [L]S_ULTCON = [YY9]IPTDAT
Endif
Filter [YY9]
Close Local File [YY9]
End [L]S_ULTCON


#############################################################################
Funprog GET_FACNUM(PS_SLO,PS_LOT,PS_RECNUM,PS_RECLIN)
Value Char PS_SLO
Value Char PS_LOT
Value Char PS_RECNUM
Value Decimal PS_RECLIN

Local Char S_NUMFAC

If !clalev([ZYY0])   : Local File YCONSIGNA [ZYY0]   : Endif
Read [ZYY0]YCON1 = PS_LOT;PS_SLO;PS_RECNUM;PS_RECLIN
If fstat = 0
  [L]S_NUMFAC = [ZYY0]FACTURA
Endif
Close Local File [ZYY0]
End [L]S_NUMFAC


#############################################################################
Funprog GET_FACPRO(PS_SLO,PS_LOT,PS_RECNUM,PS_RECLIN)
Value Char PS_SLO
Value Char PS_LOT
Value Char PS_RECNUM
Value Decimal PS_RECLIN

Local Char S_NUMPRO

If !clalev([ZYY0])   : Local File YCONSIGNA [ZYY0]   : Endif
If !clalev([ZYY1])   : Local File PINVOICE  [ZYY1]   : Endif

Read [ZYY0]YCON1 = PS_LOT;PS_SLO;PS_RECNUM;PS_RECLIN
If fstat = 0
  Read [ZYY1]PIH0 = [ZYY0]FACTURA
  If fstat = 0
    [L]S_NUMPRO = [ZYY1]BPRVCR
  Endif
Endif
Close Local File [ZYY0],[ZYY1]
End [L]S_NUMPRO


#############################################################################
Funprog GET_CADDAT(PS_ITMREF,PS_LOT,PS_SLO)
Value Char PS_ITMREF
Value Char PS_LOT
Value Char PS_SLO

Local Date S_CADDAT

If !clalev([YY7])   : Local File STOLOT [YY7]   : Endif

Read [YY7]STL0=PS_ITMREF;PS_LOT;PS_SLO
If fstat = 0
  [L]S_CADDAT = [YY7]SHLDAT
Endif
Filter [YY7]
Close Local File [YY7]
End [L]S_CADDAT


#############################################################################

Funprog GET_WEI(PS_VCRNUM, PI_VCRLIN)
Value Char    PS_VCRNUM
Value Integer PI_VCRLIN

Local File PRECEIPTD [PTD]

Local Decimal F_WEI

Read [PTD]PTD0 = PS_VCRNUM; PI_VCRLIN

[L]F_WEI = [F:PTD]QTYWEU

End [L]F_WEI

#############################################################################

Funprog GET_ITMDES(PS_ITMREF)
Value Char PS_ITMREF

Local File ITMMASTER

Local Char S_ITMDES(GLONDES)


Read [F:ITM]ITM0 = PS_ITMREF

[L]S_ITMDES = [F:ITM]ITMDES1

End [L]S_ITMDES
#############################################################################

Funprog GET_BPSNDE(PS_VCRNUM)
Value Char    PS_VCRNUM

Local File PRECEIPT [PTH]

Local Char S_BPSNDE(20)

Read [PTH]PTH0 = PS_VCRNUM

[L]S_BPSNDE = [F:PTH]BPSNDE

End [L]S_BPSNDE

