$TRTZONSPE
[M:POI1]YITMORI(NOL) = [M:PMG]YITMORI(I)
[M:POI1]YVCRORI(NOL) = [M:PMG]YVCRORI(I)
[M:POI1]YITMEST(NOL) = [M:PMG]YITMEST(I)
