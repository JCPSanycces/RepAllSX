#<AdxTL>@(#)0.0.0.0 $Revision$ 
######################################################################################
# Shop floor tracking main portal
######################################################################################
$ACTION
Case [L]ACTION
  When "OUVRE"    : Gosub OUVRE
  When "FERME"    : Gosub FERME
  When "DEBUT"    : Gosub DEBUT
  When "SETBOUT"  : Gosub SETBOUT
  When "BOUTON"   : Gosub BOUTON
Endcase
Return

######################################################################################
$OUVRE
  Local Instance SFTTXN Using C_SFTTXN
  Global Integer SFTEMPCLK
  Global Integer SFTDTLTEAM
  Global Integer TEAMMEMCLK
  Global Char    GMTSNUM(GLONTRS) : GMTSNUM = GFLAG

  If !clalev([MFG])   : Local File MFGHEAD    [MFG]   : Endif
  If !clalev([MFO])   : Local File MFGOPE     [MFO]   : Endif

Return

######################################################################################
$FERME
  # Free the instance on close
  If SFTTXN <> null : FreeGroup SFTTXN : Endif
	Kill SFTTXN

  LogicClose File [MFG], [MFO]

Return

######################################################################################
$DEBUT
  Raz [SFTP0]
Return

######################################################################################
$SETBOUT
  Raz CHMEN, CHBOU

  # Clear is always enabled
  CHMEN += "R"

  # Elapsed labor is based on employee access (and must be clocked in if required by site)
  If [M:SFTP0]EMPNUM > 0 & len([M:SFTP0]FCY) > 0 & func SFTLIB.ELAPSEDLABORENTRY([M:SFTP0]EMPNUM) = [V]CST_AYES &
&    ((SFTDTLTEAM = [V]CST_AYES & TEAMMEMCLK = [V]CST_AYES & SFTEMPCLK = [V]CST_AYES) |
&     (SFTDTLTEAM = [V]CST_ANO & SFTEMPCLK <> [V]CST_AYES) |
&     (SFTDTLTEAM = [V]CST_ANO & SFTEMPCLK = [V]CST_AYES & func SFTLIB.EMPLOYEE_CLOCKED_IN([M:SFTP0]EMPNUM) = [V]CST_AYES))
    CHMEN += "T"
  Endif

  # Enable the Labor link when employee id, site have been entered and clocked in.
  If [M:SFTP0]EMPNUM > 0 & len([M:SFTP0]FCY) > 0 &
&    !find(2,[M:SFTP0]INDTYP) & !find(4,[M:SFTP0]INDTYP) &
&    ((SFTDTLTEAM = [V]CST_AYES & TEAMMEMCLK = [V]CST_AYES & SFTEMPCLK = [V]CST_AYES) |
&     (SFTDTLTEAM = [V]CST_ANO & SFTEMPCLK <> [V]CST_AYES) |
&     (SFTDTLTEAM = [V]CST_ANO & SFTEMPCLK = [V]CST_AYES & func SFTLIB.EMPLOYEE_CLOCKED_IN([M:SFTP0]EMPNUM) = [V]CST_AYES))
    CHMEN += "L"  # Labor
    CHMEN += "B"  # Break
    CHMEN += "I"  # Indirect references
  Endif

  # Only enable Clock in if not a team
  If [M:SFTP0]EMPNUM > 0 & len([M:SFTP0]FCY) > 0 & SFTDTLTEAM = [V]CST_ANO & SFTEMPCLK = [V]CST_AYES
    CHMEN += "C"
  Endif

  # Only enable the Stop if there are open actions in the grid and employee is clocked in
  If [M:SFTP0]NBLIG > 0 &
&    ((SFTDTLTEAM = [V]CST_AYES & TEAMMEMCLK = [V]CST_AYES & SFTEMPCLK = [V]CST_AYES) |
&     (SFTDTLTEAM = [V]CST_ANO & SFTEMPCLK<> [V]CST_AYES) |
&     (SFTDTLTEAM = [V]CST_ANO & SFTEMPCLK = [V]CST_AYES & func SFTLIB.EMPLOYEE_CLOCKED_IN([M:SFTP0]EMPNUM) = [V]CST_AYES))
    CHMEN += "S"
  Endif

  # If Employee ID is entered - enable Defaults button
  If [M:SFTP0]EMPNUM > 0
    CHMEN += "D"  # Defaults
  Endif

  # If Employee ID is a summary team and was NOT on exclusive task - enable Adjust team button
  If [M:SFTP0]EMPNUM > 0 & func SFTLIB.EMPTYP(EMPNUM) = 3 & !find(2,[M:SFTP0]INDTYP) & !find(4,[M:SFTP0]INDTYP)
    CHMEN += "A"  # Adjust team
  Endif

  #If employee is a part of a team and there are open team activities that this employee is not active in, enable Join team button
  If [M:SFTP0]TEAMNUM <> 0 &  [M:SFTP0]CLOCKINFO <> "" & func SFTLIB.OPEN_ACTIVITIES(0, [M:SFTP0]EMPNUM) = [V]CST_ANO & SFTEMPCLK = [V]CST_AYES
    If func SFTLIB.TEAM_ON_TASK([M:SFTP0]TEAMNUM, "EX") <> [V]CST_AYES & func SFTLIB.TEAM_ON_TASK([M:SFTP0]TEAMNUM, "NON") = [V]CST_AYES
      CHMEN += "J"
    Endif
  Endif


Return

######################################################################################
$BOUTON
  Case BOUT
    When "C"  : Gosub EMPTIMECLOCK
    When "L"  : Call  LOAD_ACTIVITIES([M:SFTP0]EMPNUM,[M:SFTP0]FCY) # This is called after the Actual labor action is complete
    When "A"  : Call  LOAD_ACTIVITIES([M:SFTP0]EMPNUM,[M:SFTP0]FCY) # This is called after the Actual labor action is complete
    When "B"  : Call  LOAD_ACTIVITIES([M:SFTP0]EMPNUM,[M:SFTP0]FCY) # This is called after the action is complete
    When "I"  : Call  LOAD_ACTIVITIES([M:SFTP0]EMPNUM,[M:SFTP0]FCY) # This is called after the action is complete
    When "S"  : Gosub OPERATION_STOP
    When "D"  : Gosub DEFAULT_RETURN
    When "R"  : Gosub CLEAR_FORM
    When "J"  : Call  JOIN_TEAM([M:SFTP0]EMPNUM) : Gosub CLEAR_FORM
  Endcase
Return

######################################################################################
$EMPTIMECLOCK
  Local Integer RETSTATUS
  Local Char STRYEAR(4), STRMONTH(2), STRDAY(2), STRHOUR(2), STRMIN(2)

  SFTTXN = NewInstance C_SFTTXN AllocGroup null

  If func SFTLIB.EMPLOYEE_CLOCKED_IN([M:SFTP0]EMPNUM) = [V]CST_ANO

    If fmet SFTTXN.EMPLOYEE_CLOCKIN([M:SFTP0]EMPNUM, [M:SFTP0]FCY) <> [V]CST_AOK
      Call ERREUR(SFTTXN.AERROR.MES) From GESECRAN
      FreeGroup SFTTXN
      Return
    Endif

    Call PARSEDATETIME (SFTTXN.UTCSTRDATTIM, SFTTXN.UTCOFFSET, STRYEAR, STRMONTH, STRDAY, STRHOUR, STRMIN) From SFTLIB
    [M:SFTP0]CLOCKINFO  = STRMONTH+"/"+STRDAY+"/"+STRYEAR-STRHOUR+":"+STRMIN
    [M:SFTP0]CLOCKSEQ   = SFTTXN.SFTSEQ

  Else

    # Read the correct record then call the correct method
    If fmet SFTTXN.AREAD([M:SFTP0]EMPNUM, 1, "", [M:SFTP0]CLOCKSEQ) <> [V]CST_AOK
      Call ERREUR(SFTTXN.AERROR.MES) From GESECRAN
      FreeGroup SFTTXN
      Return
    Endif

    If fmet SFTTXN.EMPLOYEE_CLOCKOUT([M:SFTP0]EMPNUM, [M:SFTP0]FCY) <> [V]CST_AOK
      Call ERREUR(SFTTXN.AERROR.MES) From GESECRAN
      FreeGroup SFTTXN
      Return
    Endif

    Call LOAD_ACTIVITIES([M:SFTP0]EMPNUM,[M:SFTP0]FCY)
    Raz [M:SFTP0]CLOCKINFO, CLOCKSEQ

  Endif

  FreeGroup SFTTXN

  Affzo [M:SFTP0]

Return

######################################################################################
$OPERATION_STOP
  Local Integer   RETSTATUS, RESTART_OPER
  Local Integer   I, STOP
  Local Integer   ACTIVITIES : ACTIVITIES = [M:SFTP0]NBLIG-1
  Local Integer   SFTTYP    (0..ACTIVITIES) # Key field
  Local Char      VCRNUM(20)(0..ACTIVITIES) # Key field
  Local Integer   OPENUM    (0..ACTIVITIES) # TTD - 1447
  Local Integer   SFTSEQ    (0..ACTIVITIES) # Key field
  Local Integer   PRIORITY  (0..ACTIVITIES) # Priority used to sort - breaks must go first
  Local Integer   CPLQTY    (0..ACTIVITIES) # Completed Quantity
  Local Integer   REJQTY    (0..ACTIVITIES) # Rejected Quantity
  Local Integer   SCANUM    (0..ACTIVITIES) # Rejection Code
  Local Integer   CLEFLG    (0..ACTIVITIES) # Completed (Binary)
  Local Integer   INDTYP    (0..ACTIVITIES) # Exclusive or Non-Exclusive for Indirect
  Local Datetime  STOPTIME
  Local Integer   ERRNUM
  Local Char      ERRMSG(255)



  # Initialize restart operation variable
  RESTART_OPER  = 0

  For I = 0 To ACTIVITIES
    If [M:SFTP0]SELLIN(I)=[V]CST_AYES
      STOP+=1
      PRIORITY(I) = func OPERATION_STOP_PRIORITY([M:SFTP0]SFTTYP(I),[M:SFTP0]INDTYP(I))
      SFTTYP(I)   = [M:SFTP0]SFTTYP(I)

      If find([M:SFTP0]SFTTYP(I),2,3)
        VCRNUM(I) = AVOID.ACHAR
      Else
        VCRNUM(I) = [M:SFTP0]VCRNUM(I)
      Endif
      OPENUM(I)   = [M:SFTP0]OPENUM(I)    #TTD-1447
      SFTSEQ(I)   = [M:SFTP0]SFTSEQ(I)
      CPLQTY(I)   = [M:SFTP0]CPLQTY(I)
      REJQTY(I)   = [M:SFTP0]REJCPLQTY(I)
      SCANUM(I)   = [M:SFTP0]SCANUM(I)
      CLEFLG(I)   = [M:SFTP0]CLEFLG(I)
      INDTYP(I)   = [M:SFTP0]INDTYP(I)
    Else
      # Default the piroty to 99 so this will fall to the end of the list
      PRIORITY(I) = 99
    Endif
  Next I
  # If nothing selected - end
  If STOP=0
    GERR=1
    GMESSAGE = mess(187,7900,1)   # No line selected
    Return
  Endif

  # Order the arrays based on their priority
  Sorta PRIORITY, SFTTYP, SFTSEQ, VCRNUM, OPENUM, CPLQTY, REJQTY, SCANUM, CLEFLG, INDTYP  #TTD-1447

  Call STOP_OPERATIONS([M:SFTP0]EMPNUM, FCY, SFTTYP, VCRNUM, OPENUM, SFTSEQ, INDTYP, CPLQTY, REJQTY, SCANUM, CLEFLG, STOP) From SFTLIB #TTD-1447
#  Sorta PRIORITY, SFTTYP, SFTSEQ, VCRNUM, CPLQTY, REJQTY, SCANUM, CLEFLG, INDTYP #TTD-1447
#  Call STOP_OPERATIONS([M:SFTP0]EMPNUM, FCY, SFTTYP, VCRNUM, SFTSEQ, INDTYP, CPLQTY, REJQTY, SCANUM, CLEFLG, STOP) From SFTLIB #TTD-1447

  Call LOAD_ACTIVITIES([M:SFTP0]EMPNUM, [M:SFTP0]FCY)
  gosub ACTUALIZAR_NUMJOBS from sfttxn_cstd
  
Return

######################################################################################
$CLEAR_FORM
  Actzo [M:SFTP0]
  Effzo [M:SFTP0]
Return

######################################################################################
Subprog JOIN_TEAM(IEMPNUM)
Value Integer IEMPNUM
  #We already know that this employee is a part of a team and that there are team activities running
  Local Integer  FIRST_EMP
  Local Datetime STARTTIME
  Local Integer  EMP_LIST(1..)

  #Filter the transaction table for all relevant records
  Local File SFTTXN [SFTX]
  Call TEAM_LIST ([M:SFTP0]TEAMNUM(0), "A", EMP_LIST) From SFTLIB
  Filter [SFTX] Where TEAMNUM = [M:SFTP0]TEAMNUM(0) and EMPNUM = EMP_LIST(1) and UTCENDDATTIM = AVOID.ADATTIM


  #Start a SFTTXN instance
  Local Instance SFTTXN Using C_SFTTXN
  SFTTXN = NewInstance C_SFTTXN AllocGroup null

  STARTTIME = datetime$

  #Loop though the records
  For [SFTX]
      SFTTXN.EMPNUM       = IEMPNUM
      SFTTXN.TEAMNUM      = [SFTX]TEAMNUM
      SFTTXN.SFTTYP       = [SFTX]SFTTYP
      SFTTXN.VCRNUM       = [SFTX]VCRNUM
      SFTTXN.SFTSEQ       = func SFTTXN_CSTD.NEXT_SEQ(IEMPNUM, [SFTX]SFTTYP, [SFTX]VCRNUM)
      SFTTXN.UTCSTRDATTIM = [L]STARTTIME
      SFTTXN.UTCOFFSET    = [SFTX]UTCOFFSET
      SFTTXN.INDREF       = [SFTX]INDREF
      SFTTXN.NUMJOBS      = [SFTX]NUMJOBS
      SFTTXN.OPENUM       = [SFTX]OPENUM
      SFTTXN.NUMMAC       = [SFTX]NUMMAC
      SFTTXN.WCENTER      = [SFTX]WCENTER
      SFTTXN.LCENTER      = [SFTX]LCENTER
      SFTTXN.OPEUOM       = [SFTX]OPEUOM
      SFTTXN.INDTYP       = [SFTX]INDTYP
      SFTTXN.FCY          = [SFTX]FCY
      SFTTXN.SHIFT        = [SFTX]SHIFT
      SFTTXN.SHIFTDAT     = [SFTX]SHIFTDAT
      SFTTXN.TXNUUID      = [SFTX]TXNUUID
      SFTTXN.STRTXNUUID   = [SFTX]STRTXNUUID #Jira 50317.n 08/03/17 by CATUA Set value for STRTXNUUID
      SFTTXN.MACFLG       = [SFTX]MACFLG

      If fmet SFTTXN.AINSERT <> [V]CST_AOK
        [L]ASTATUS = fmet this.ASETERROR ("", mess(5,2422,1), [V]CST_AERROR)
        [L]ARET_VALUE = [V]CST_AERROR
        Break
      Endif


  Next


  Infbox func AFNC.MES2(mess(116,2422,1), num$(IEMPNUM), num$([M:SFTP0]TEAMNUM(0)))

  #Free resources
  FreeGroup SFTTXN
  Kill SFTTXN
  Filter [SFTX]
  LogicClose File [SFTX]


End

######################################################################################
Subprog LOAD_ACTIVITIES(EMPNUM,FCY)
Value Integer EMPNUM
Value Char    FCY

  Local Integer   I
  Local Char      STRYEAR(4), STRMONTH(2), STRDAY(2), STRHOUR(2), STRMIN(2)
  Local Date      DATETEMP
  Local Integer   EMPLIST(1..)
  Local Uuident   RECORDS_DISPLAY(0..)
  Local Integer   TEAM : TEAM = [V]CST_ANO #TTD-1330


  If !clalev([SFTX]) : Local File SFTTXN [SFTX] : Endif

  Local Integer WMAX
  WMAX = dim([M:SFTP0]VCRNUM)  # Max lines to be displayed

  # Clear the screen
  Raz [M:SFTP0]CLOCKINFO, [M:SFTP0]CLOCKSEQ, [M:SFTP0]NBLIG
  Gosub CLEAR_GRID

  If EMPNUM>0 & len(FCY)>0
    # Check for a clockin record - not site specific
    Filter [SFTX] Where EMPNUM=[L]EMPNUM & SFTTYP=1 & UTCENDDATTIM=AVOID.ADATTIM Order By SFTTYP; VCRNUM; OPENUM; SFTSEQ
    For [SFTX]
      Call PARSEDATETIME ([F:SFTX]UTCSTRDATTIM, [F:SFTX]UTCOFFSET, STRYEAR, STRMONTH, STRDAY, STRHOUR, STRMIN) From SFTLIB
      [L]DATETEMP         = evalue("["+STRDAY+"/"+STRMONTH+"/"+STRYEAR+"]")
      [M:SFTP0]CLOCKINFO  = format$(GFMDAT4,DATETEMP)-STRHOUR+":"+STRMIN
      [M:SFTP0]CLOCKSEQ   = [F:SFTX]SFTSEQ
    Next
    Filter [SFTX]

    # Use different filter if this is a team. Search using TEAMNUM field instead of EMPNUM field
    If func SFTLIB.ISTEAM([L]EMPNUM) = [V]CST_AYES
      TEAM = [V]CST_AYES
      # Don't want a team records, only employee belong to the team records
      Filter [SFTX] Where TEAMNUM=[L]EMPNUM & FCY=[L]FCY & SFTTYP<>1 &
&                         UTCENDDATTIM=AVOID.ADATTIM & TEAMNUM <> EMPNUM
&                   Order By SFTTYP; VCRNUM; OPENUM; SFTSEQ

    Else
      Filter [SFTX] Where EMPNUM=[L]EMPNUM & FCY=[L]FCY & SFTTYP<>1 & UTCENDDATTIM=AVOID.ADATTIM &
&                         (MACFLG <> [V]CST_AYES | TXNUUID = AVOID.AUUID  |
&                         (TEAMNUM <> [L]EMPNUM & TEAMNUM <> 0 & MACFLG = [V]CST_AYES))
&                   Order By SFTTYP; VCRNUM; OPENUM; SFTSEQ

    Endif

    For [SFTX]
      If I >= WMAX
          Call ERREUR(func AFNC.MES1(mess(37,2422,1),num$(WMAX))) From GESECRAN
          Break
      Endif

      # TTD-1330.s: Team only - filter records to display. if the record already existed don't add.
      If TEAM = [V]CST_AYES
        If find([F:SFTX]TXNUUID, RECORDS_DISPLAY)
          Goto NEXT_RECORD
        Else
          RECORDS_DISPLAY(I) = [F:SFTX]TXNUUID
        Endif
      Endif
      #TTD-1330.e

      Call PARSEDATETIME ([F:SFTX]UTCSTRDATTIM, [F:SFTX]UTCOFFSET, STRYEAR, STRMONTH, STRDAY, STRHOUR, STRMIN) From SFTLIB
      [M:SFTP0]SFTSEQ(I)  = [F:SFTX]SFTSEQ
      If find([F:SFTX]SFTTYP,2,3)
        [M:SFTP0]VCRNUM(I)  = [F:SFTX]INDREF
      Else
        [M:SFTP0]VCRNUM(I)  = [F:SFTX]VCRNUM
      Endif
      [M:SFTP0]SFTTYP(I)  = [F:SFTX]SFTTYP
      [M:SFTP0]INDTYP(I)  = [F:SFTX]INDTYP
      [M:SFTP0]OPENUM(I)  = [F:SFTX]OPENUM
      [M:SFTP0]OPEUOM(I)  = [F:SFTX]OPEUOM
      [M:SFTP0]NUMJOBS(I) = [F:SFTX]NUMJOBS
      [M:SFTP0]STRDAT(I)  = evalue("["+STRDAY+"/"+STRMONTH+"/"+STRYEAR+"]")
      [M:SFTP0]STRTIM(I)  = STRHOUR+":"+STRMIN
      [M:SFTP0]MACFLG(I)  = [F:SFTX]MACFLG

      Raz [M:SFTP0]WONOTE(I)
      Raz [M:SFTP0]OPNOTE(I)

      # Set the notes icon for WO and Operation
      If find([F:SFTX]SFTTYP,2,3)
        [M:SFTP0]WONOTE(I)=AVOID.ACHAR
        [M:SFTP0]OPNOTE(I)=AVOID.ACHAR
      Else
        Read [MFG]MFG0=[F:SFTX]VCRNUM
        If [F:MFG]MFGTEX="" : [M:SFTP0]WONOTE(I)=AVOID.ACHAR : Endif

        Read [MFO]MFO0=[F:SFTX]VCRNUM;[F:SFTX]OPENUM
        If [F:MFO]MFOTEX="" : [M:SFTP0]OPNOTE(I)=AVOID.ACHAR : Endif
      Endif

      #Disable entering data for Detailed team dummy record
      If [SFTX]TEAMNUM <> [L]EMPNUM & [SFTX]TEAMNUM <> 0 &  [SFTX]MACFLG = [V]CST_AYES
        Grizo [M:SFTP0]CPLQTY(I)
        Grizo [M:SFTP0]CLEFLG(I)
      Else
        Actzo [M:SFTP0]CPLQTY(I)
        Actzo [M:SFTP0]CLEFLG(I)
      Endif

      I+=1
NEXT_RECORD:
    Next
    Filter [SFTX]
  Endif

  [M:SFTP0]NBLIG = I

  # Disable the Rejected qty and Rejected code fields
  Grizo [M:SFTP0]REJCPLQTY
  Grizo [M:SFTP0]SCANUM

  Affzo [M:SFTP0]

  LogicClose File [SFTX]

End

######################################################################################
Funprog OPERATION_STOP_PRIORITY(SFTTYP,INDTYP)
Value Integer SFTTYP
Value Integer INDTYP

  # Breaks need a higher priority
  Case SFTTYP
    When 3        : End 1
    When 2        : If INDTYP=4 : End 1 : Else : End 2 : Endif
    When Default  : End 2
  Endcase

End

######################################################################################
Subprog AM_EMPNUM(VALEUR)
Variable Decimal VALEUR

  #Get the employee default site (if it exists)
  If !clalev([TMA]) : Local File TABMAT [TMA] : Endif

  Read [TMA]TMA0=VALEUR

  # Default the site if populated
  [M:SFTP0]FCY=[F:TMA]DEFFCY
  Call AM_FCY([M:SFTP0]FCY)

  LogicClose File [TMA]

  [M:SFTP0]EMPNUM=VALEUR

  Local Integer ITEAMNUM
  Call EMP_TEAM_NUM([M:SFTP0]EMPNUM, ITEAMNUM) From SFTLIB
  [M:SFTP0]TEAMNUM = ITEAMNUM

  Call TIMEANDATT(VALEUR, [M:SFTP0]FCY) # TTD-1955
  Call LOAD_ACTIVITIES(VALEUR,[M:SFTP0]FCY)
#  Call TIMEANDATT(VALEUR, [M:SFTP0]FCY)  # TTD-1955

End
######################################################################################
Subprog AM_FCY (VALEUR)
Variable Char    VALEUR()

  # Make sure the global variables and parameters are updated
  GFCY=VALEUR : Gosub CHARG_PARAM From SUBMTKA

  Call TIMEANDATT([M:SFTP0]EMPNUM, VALEUR)
  Call LOAD_ACTIVITIES([M:SFTP0]EMPNUM,VALEUR)

  # Make sure the screen is updated for SETBOUT
  [M:SFTP0]FCY=VALEUR

End

######################################################################################
Subprog AM_SELLIN(VALEUR)
Variable Integer VALEUR
End

######################################################################################
# Get the Parameter value for T & A and hide fields as needed
######################################################################################
Subprog TIMEANDATT(EMPNUM, FCY)
Value Integer EMPNUM
Value Char    FCY

  Local Integer EMP_LIST(1..)
  Local Char PARAMRET(4)

  Call PARAM(FCY,"SFTEMPCLK",PARAMRET) From ADOVAL
  SFTEMPCLK = val([L]PARAMRET)

  #TEAMMEMCLK flag checks for the following:
  #(A) Employee type is a detailed team
  #(B) At least one team member in the detailed team is clocked in and does not have an open individual transaction
  TEAMMEMCLK = [V]CST_ANO
  Raz EMP_LIST()

  If func SFTLIB.ISTEAM(EMPNUM) = [V]CST_AYES
    SFTDTLTEAM = [V]CST_AYES

    Call TEAM_LIST (EMPNUM, 'A', EMP_LIST) From SFTLIB
    If maxtab(EMP_LIST) > 0
      TEAMMEMCLK = [V]CST_AYES
    Endif

  Else
    SFTDTLTEAM = [V]CST_ANO
  Endif

  #Detailed Teams cannot clock in, we want to disable the clocking button
#  If !clalev([TMA]) : Local File TABMAT [TMA] : Endif
#  Read [TMA]TMA0 = EMPNUM
#  If [TMA]EMPTYP = 2 : SFTEMPCLK = [V]CST_ANO : Endif

  #Visibilty of clocking info
  If SFTDTLTEAM = [V]CST_ANO & SFTEMPCLK = [V]CST_AYES
    Chgfmt [M:SFTP0]CLOCKINFO  With "K:"   + num$(type([M:SFTP0]CLOCKINFO)-10)  + "B"    # Show enterable
  Else
    Chgfmt [M:SFTP0]CLOCKINFO  With "-K:"  + num$(type([M:SFTP0]CLOCKINFO)-10)  + "B"    # Hide
  Endif

End

######################################################################################
Subprog AVANT_NBLIG
  If [M:SFTP0]SFTTYP(nolign-1)<>5
    Grizo [M:SFTP0]CPLQTY(nolign-1)
    Grizo [M:SFTP0]REJCPLQTY(nolign-1)
    Grizo [M:SFTP0]SCANUM(nolign-1)
    Grizo [M:SFTP0]CLEFLG(nolign-1)
  Else
    If [M:SFTP0]CLOCKINFO = "" or ([M:SFTP0]MACFLG(nolign-1) <> [V]CST_AYES and [M:SFTP0]TEAMNUM(nolign-1) <> 0)
      Actzo [M:SFTP0]CPLQTY(nolign-1)
      Actzo [M:SFTP0]CLEFLG(nolign-1)
    Endif
  Endif

  #If [M:SFTP0]WONOTE(nolign-1) = AVOID.ACHAR
  #  Grizo [M:SFTP0]WONOTE(nolign-1)
  #Endif

  #If [M:SFTP0]OPNOTE(nolign-1) = AVOID.ACHAR
  #   Grizo [M:SFTP0]OPNOTE(nolign-1)
  #Endif

End

######################################################################################
Subprog AM_CPLQTY(VALEUR)
Variable Decimal VALEUR

Local Integer OK, CPLQTY_HIGHER,  OPERCLOSE

  # Check if the completed qty and more than the estimated/planned qty
  Call VAL_COMPLETEQTY([M:SFTP0]VCRNUM(nolign-1),[M:SFTP0]OPENUM(nolign-1),VALEUR, CPLQTY_HIGHER, OPERCLOSE) From SFTLIB
  If CPLQTY_HIGHER = [V]CST_AYES
    Call AVERTIR(mess(54,190,1),OK) From GESECRAN   # Actual quantity larger than estimated quantity. Continue?
    If OK = 1     # Cancel
      mkstat = 1
      End
    Endif
  Endif

  [M:SFTP0]CLEFLG(nolign-1) = OPERCLOSE
  Affzo [M:SFTP0]CLEFLG(nolign-1)
  Call SELECTLINE(VALEUR)
  Call REJECTQTY(VALEUR)
  Call REJECTCODE([M:SFTP0]REJCPLQTY(nolign-1))
End

######################################################################################
Subprog AM_REJCPLQTY(VALEUR)
Variable Decimal VALEUR

  # Display message when rejected qty is > completed qty and
  # clear out the selection option
  If VALEUR > [M:SFTP0]CPLQTY(nolign-1)
      GERR=1 : GMESSAGE = mess (25,2422,1)  # Rejected qty. cannot be more than Completed qty.
      VALEUR = 0
      OK = 1
      mkstat = 1
  Else
    Call SELECTLINE(VALEUR)
    Call REJECTCODE(VALEUR)
  Endif

End

######################################################################################
Subprog AM_SCANUM(VALEUR)
Variable Decimal VALEUR
  Call SELECTLINE(VALEUR)
End

######################################################################################
Subprog AM_CLEFLG(VALEUR)
Variable Integer VALEUR
  Call SELECTLINE(VALEUR)
End

######################################################################################
Subprog C_SCANUM(VALEUR)
Variable Decimal VALEUR
  Local Char WSCANUM(12) : WSCANUM = num$(VALEUR)
  If VALEUR <> 0
    Call CONTROLE("TSR","",WSCANUM,"",mkstat) From CONTOBJ
  Endif
End

######################################################################################
Subprog C_EMPNUM(VALEUR)
Variable Decimal VALEUR

If func SFTLIB.EMPLOYEEACTIVE(VALEUR) = [V]CST_ANO
  Local Char EMPID(100) : Call TEXTE(10793,EMPID) From OBJDIV
  GERR=1 : GMESSAGE =  EMPID - ":" - num$(VALEUR) - " \" + mess(2,126,1)
  mkstat = 2
Endif

End

######################################################################################
Subprog AS_WONOTE(VALEUR)
Variable Char    VALEUR()

  #Read the correct record into MFG table for the text to display
  Call RAZ_CLOB From ACLOB
  Read [MFG]MFG0=[M:SFTP0]VCRNUM(nolign-1)

End

######################################################################################
Subprog AS_OPNOTE(VALEUR)
Variable Char    VALEUR()

  #Read the correct record into MFO table for the text to display
  Call RAZ_CLOB From ACLOB
  Read [MFO]MFO0=[M:SFTP0]VCRNUM(nolign-1);[M:SFTP0]OPENUM(nolign-1)

End

######################################################################################
Subprog SELECTLINE(I)
Value Decimal I
  If I<>0
    [M:SFTP0]SELLIN(nolign-1)=[V]CST_AYES
    Affzo [M:SFTP0]SELLIN(nolign-1)
  Endif
End

######################################################################################
Subprog REJECTQTY(I)
Value Decimal I
  If I > 0
    Actzo [M:SFTP0]REJCPLQTY(nolign-1)
  Else
    Raz [M:SFTP0]REJCPLQTY(nolign-1)
    Grizo [M:SFTP0]REJCPLQTY(nolign-1)
  Endif
  Affzo [M:SFTP0]REJCPLQTY(nolign-1)
End
######################################################################################
Subprog REJECTCODE(I)
Value Decimal I
  If I > 0
    Actzo [M:SFTP0]SCANUM(nolign-1)
  Else
    Raz [M:SFTP0]SCANUM(nolign-1)
    Grizo [M:SFTP0]SCANUM(nolign-1)
  Endif
  Affzo [M:SFTP0]SCANUM(nolign-1)
End

######################################################################################
$CLEAR_GRID

    Raz [M:SFTP0]SELLIN, [M:SFTP0]SFTSEQ, [M:SFTP0]SFTTYP, [M:SFTP0]VCRNUM, [M:SFTP0]OPENUM,
&       [M:SFTP0]OPEUOM, [M:SFTP0]STRDAT, [M:SFTP0]STRTIM, [M:SFTP0]CPLQTY, [M:SFTP0]REJCPLQTY,
&       [M:SFTP0]SCANUM, [M:SFTP0]CLEFLG, [M:SFTP0]NUMJOBS, [M:SFTP0]INDTYP

Return

######################################################################################
$DEFAULT_RETURN
  If !clalev([TMAD]) : Local File TABMAT [TMAD] : Endif

  Read [TMAD]TMA0=[M:SFTP0]EMPNUM

  # The default site was updated - re-load the screen
  If [F:TMAD]DEFFCY<>"" & [M:SFTP0]FCY<>[F:TMAD]DEFFCY
    [M:SFTP0]FCY=[F:TMAD]DEFFCY
    Call TIMEANDATT([M:SFTP0]EMPNUM, [M:SFTP0]FCY)
    Call LOAD_ACTIVITIES([M:SFTP0]EMPNUM, [M:SFTP0]FCY)
  Endif

  LogicClose File [TMAD]
Return

######################################################################################
## Init button
######################################################################################
Subprog IB_NBLIG

  # Do not display the WO status action if the type is not Setup or Run
  If SFTTYP(nolign-1) <> 4 & SFTTYP(nolign-1) <> 5
    Raz GBOUT1
  Endif

End





































