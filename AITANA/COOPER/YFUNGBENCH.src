#######################################################################################
$ACTION
Case ACTION
  When "ADDLIN"    :   Gosub ADDLIN  # Pongo valor a Artículo Origen si está en blanco
Endcase
Return


################################################################
$ADDLIN
If [M:MGB]ITMREFORI(nolign-1) = ""
  Local Char ART_ORIGEN
  Call ARTICULO_ORIGEN([M:MGB]ITMREF(nolign-1),[M:MGB]VCRNUM(nolign-1),ART_ORIGEN) From YAITLIB
  [M:MGB]ITMREFORI(nolign-1) = ART_ORIGEN
Endif
Return

