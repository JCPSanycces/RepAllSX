#######################################################################################
$ACTION
Case ACTION
  When "ALIMSKPOH"    :   Gosub ALIMSKPOH  # Pongo valor a campos específicos de la línea del pedido de compra
Endcase
Return


################################################################
$ALIMSKPOH
Local Integer LIN
For LIN=0 To [M:POI1]NBLIG-1
  [M:POH2]YITMORI    (LIN)= [M:POI1]YITMORI (LIN)
  [M:POH2]YVCRORI    (LIN)= [M:POI1]YVCRORI (LIN)
  [M:POH2]YITMEST    (LIN)= [M:POI1]YITMEST (LIN)
Next
Return

