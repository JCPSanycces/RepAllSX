#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara YSCO3 (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla YSCO3) 18/06/2018 07:46:25 (PT02)
######################################################################################
$ACTION
#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
    When "LIENS"      :    Gosub LIENS
    When "CREATION"   :    Gosub MODIF
    When "MODIF"      :    Gosub MODIF
    When "ANNULE"     :    Gosub ANNULE
    When "APRES_CRE"  :    Gosub APRES
    When "APRES_MOD"  :    Gosub APRES
    When "STYLE"      :    Gosub STYLE
Endcase
Return

######################################################################################
$APRES
# 15/11/2019. Guardo la descripción de enlace de los componentes
If GFONCTION = "GESSCO"
  Local Integer LINE
  For LINE = 0 To [M:SCO2]NBLIG-1
    Read [SCM] = [M:SCO0]SCONUM;1000;[M:SCO2]SCMLIN(LINE)
    If fstat = 0
      Read [BOD]BOD0 = [M:SCO2]ITMREF(LINE);[M:SCO2]BOMALT(LINE);[M:SCO2]BOMSEQ(LINE);[M:SCO2]CPNITMREF(LINE);3
      If fstat = 0
        [M:SCO2]YDESEST(LINE) = [BOD]BOMSHO
        Affzo [M:SCO2]YDESEST(LINE)
        [SCM]YDESEST = [BOD]BOMSHO
        Rewrite [SCM]
      Endif
    Endif
  Next
Endif
Return

######################################################################################
$LIENS
# Muestro pestaña Proveedores
nolign=1
[M:YSCO3]YPIE = 0
For [YSPR] Where [F:YSPR]YORDEN = [M:SCO0]SCONUM
    [M:YSCO3] = [YSPR]
    nolign+=1
Next
[M:YSCO3]YPIE = nolign-1
Return


######################################################################################
$MODIF
# Registro valores pestaña Proveedores
For [YSPR] Where [YSPR]YORDEN = [M:SCO0]SCONUM
    Delete [YSPR] Curr
Next

For nolign = 1 To [M:YSCO3]YPIE
    Raz [YSPR]
    [YSPR] = [M:YSCO3]
    [YSPR]YORDEN = [M:SCO0]SCONUM
    Write [YSPR]
Next
Return


######################################################################################
$ANNULE
# Borro valores pestaña Proveedores
For [YSPR] Where [YSPR]YORDEN = [M:SCO0]SCONUM
    Delete [YSPR] Curr
Next
Return

##############################################################
$STYLE
  #JC.12032021.CSA028
  Gosub CARGA_YBOMSHO
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
#JC.12032021.CSA028
$CARGA_YBOMSHO
Local Integer LCON
Local Char    LDESC(250)
  If !clalev([F:YSCM]) Then : Local File SCOMAT [F:YSCM] : Endif
  For LCON = 0 To [M:SCO2]NBLIG - 1
    LDESC = func GET_DESCENLACE(LCON)
    # pantalla
    [M:SCO2]YBOMSHO(LCON) = LDESC
    Affzo [M:SCO2]YBOMSHO(LCON)
    # tabla
    Filter [F:YSCM] Where SCONUM = [M:SCO0]SCONUM and SCMLIN = [M:SCO2]SCMLIN(LCON)
    Read [F:YSCM] First
    If !fstat Then
      [F:YSCM]YBOMSHO = LDESC
      Trbegin [F:YSCM]
      Rewrite [F:YSCM]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Endif
  Next
  Close Local File [YSCM]

If dim(LCON) > 0 Then : Kill LCON : Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
##############################################################
######################################################################################
Subprog C_YPROVEEDOR(VALEUR)
Variable Char    VALEUR()
# No permito introducir el mismo proveedor en dos líneas
Call UNICITE(VALEUR, [M:YSCO3]YPROVEEDOR(0..[M:YSCO3]YPIE-1)) From OBJDIV
End


######################################################################################
Subprog C_YSELECCION(VALEUR)
Variable Integer VALEUR
# No permito introducir el mismo valor en dos líneas
If VALEUR = 2
  Call UNICITE(VALEUR, [M:YSCO3]YSELECCION(0..[M:YSCO3]YPIE-1)) From OBJDIV
Endif
End


######################################################################################
Subprog AM_YSELECCION(VALEUR)
Variable Integer VALEUR
# Pregunto si actualizo proveedor en cabecera
If VALEUR = 2 and [M:SCO1]ALLSTA = 1
  Local Integer OK9
  Call OUINON("¿Desea actualizar el proveedor de la orden de subcontratación?", OK9) From GESECRAN
  If OK9 = 2
    [M:SCO0]BPRNUM = [M:YSCO3]YPROVEEDOR(nolign-1)
    Affzo [M:SCO0]BPRNUM

    # Lanzo rutina del STD
    Local Decimal QTY_PUU : QTY_PUU = [M:SCO1]QTYPUU # Guardo la cantidad y luego la vuelvo a poner
    Local Integer WBOMALT : WBOMALT = [M:SCO0]BOMALT
    Local Char    YPJT    : YPJT    = [M:SCO1]PJT
    Local    Char    WBPRNUM(GLONBPR) : WBPRNUM=[M:YSCO3]YPROVEEDOR(nolign-1)
    If [M:SCO0]ITMREF<>"" & WBOMALT>0
       # Issue 116684 - 2016-05-23 by MUARN : alimentation fournisseur
       # FQ 74423 GA 06/2011 maj de mkstat en cas d'erreur
       # FQ 63394 GA 03/2010 + 2 paramètres [M:SCO0]BOMALT,1(=Raz)
       Call RECH_SCO1_ITMREF ([M:SCO0]ITMREF,WBPRNUM,WBOMALT,1,mkstat ) From SUBSCO
       [M:SCO0]BOMALT=WBOMALT : Affzo [M:SCO0]BOMALT    # Issue 85534 - 2012-11-06 by CCC
       If mkstat<>0 End Endif
       # Issue 118457 - 2016-09-21 by MUARN : affzo avec indice
       Affzo [M:SCO1]1-99 : Affzo [M:SCO2]1-99 : Affzo [M:SCO3]1-99
    Endif
    [M:SCO1]QTYPUU = [L]QTY_PUU
    [M:SCO1]PJT    = [L]YPJT
    Affzo [M:SCO1]QTYPUU
    Affzo [M:SCO1]PJT
  Endif
Endif
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
##############################################################
#JC.12032021.CSA028
Funprog GET_DESCENLACE(PNOL)
Value Integer PNOL
Local Char    LRES(250)

  If [M:SCO2]YBOMSHO(PNOL) = "" Then
    Call DESCRIP_BOM([M:SCO0]ITMREF,[M:SCO2]CPNITMREF(PNOL),LRES) From  YAITLIB
  Else
    LRES = [M:SCO2]YBOMSHO(PNOL)
  Endif

End LRES
