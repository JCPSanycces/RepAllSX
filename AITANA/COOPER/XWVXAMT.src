#####################################################################################
# Src: XWVXAMT
#-------------------------------------------------------------------------------------
# (Consumo de materiales)
#-------------------------------------------------------------------------------------
# Proyecto: JAE
#-------------------------------------------------------------------------------------
# Version: v11
#-------------------------------------------------------------------------------------
# Fecha:01-12-2017
#-------------------------------------------------------------------------------------
# Desarrollador: DSAL
# Codigo Actividad: YS001
#######################################################################################
#PATCH: Ajustes de la pantalla de consumo de materiales VT
#######################################################################################
$ACTION
Case [L]ACTION
  When "DEBUT"     : Gosub DEBUT
  When "BOUTON"    : Gosub BOUTON
Endcase
Return


#####################################################################
$DEBUT
# Si vengo del Seguimiento taller..
If GFONCTION1 = "FUNSFTPOR"
  # Llamo al STD
  Gosub DEBUT From VXAMT

  # Pongo valor por defecto a la transacción
  [M:XAMT]MMLNUM = 'VT'
  Affzo [M:XAMT]MMLNUM

  # Pongo la OF
  Local Integer J
  If !clalev([YY1])   : Local File MFGMAT     [YY1]   : Endif
  If !clalev([YY2])   : Local File ITMMASTER  [YY2]   : Endif
  If !clalev([YY3])   : Local File STOJOU     [YY3]   : Endif
  If !clalev([YY4])   : Local File MFGITM     [YY4]   : Endif
  If !clalev([YY5])   : Local File MFGMATTRK  [YY5]   : Endif

  For J=0 To [M:SFTP0]NBLIG-1
    If [M:SFTP0]SELLIN(J) = 2 and [M:SFTP0]SFTTYP(J) > 3
      [M:XAMT]MFGNUM = [M:SFTP0]VCRNUM(J)
      Affzo [M:XAMT]MFGNUM


      # Propongo ahora el primer componente que tenga cantidad pendiente de consumir
      # Asocio el consumo con el último lote - sublote declarado
      # Primero bloqueo la lógica anterior
      If 1=2
        For [YY1] Where [YY1]MFGNUM = [M:XAMT]MFGNUM #and ([YY1]RETQTY - [YY1]USEQTY)>0
          [M:XAMT]ITMREF = [YY1]ITMREF
          Read [YY2]ITM0 = [YY1]ITMREF
          If fstat = 0
            [M:XAMT]YITMDES = [YY2]ITMDES1
          Endif
          Affzo [M:XAMT]ITMREF
          Affzo [M:XAMT]YITMDES
          Call AM_ITMREF ([M:XAMT]ITMREF) From VXAMT
          [M:XAMT]LOC    = "" # La ubicación la dejo en blanco
          Affzo [M:XAMT]LOC

          # Pongo como cantidad pendiente SPE la que el sistema calcula en el campo STD, y el campo STD lo dejo en blanco
          [M:XAMT]YPDTE  = [M:XAMT]USEQTY
          [M:XAMT]USEQTY = 0
          Affzo [M:XAMT]YPDTE,USEQTY

          # Asocio el consumo con el último lote - sublote declarado
          Filter [YY3] Where [YY3]TRSTYP = 5 and [YY3]VCRNUMORI = [M:XAMT]MFGNUM Order By [YY3]VCRNUM Desc
          Read [YY3] First
          If fstat = 0
            If [YY3]SLO <> ""
              [M:XAMT]YLOTEPT  = [YY3]LOT + '-' + [YY3]SLO
            Else
              [M:XAMT]YLOTEPT  = [YY3]LOT
            Endif
            [M:XAMT]YLOTE    = [YY3]LOT
            [M:XAMT]YSUBLOTE = [YY3]SLO
            Affzo [M:XAMT]YLOTEPT,YLOTE,YSUBLOTE
          Endif
          Filter [YY3]

          zonsui = '[M:XAMT]LOT'
          Break
        Next
      Else
        # Propongo ahora el primer componente que tenga cantidad pendiente de consumir
        For [YY1] Where [YY1]MFGNUM = [M:XAMT]MFGNUM #and ([YY1]RETQTY - [YY1]USEQTY)>0
          [M:XAMT]ITMREF = [YY1]ITMREF
          Read [YY2]ITM0 = [YY1]ITMREF
          If fstat = 0
            [M:XAMT]YITMDES = [YY2]ITMDES1
          Endif
          Affzo [M:XAMT]ITMREF
          Affzo [M:XAMT]YITMDES
          Call AM_ITMREF ([M:XAMT]ITMREF) From VXAMT
          [M:XAMT]LOC    = "" # La ubicación la dejo en blanco
          Affzo [M:XAMT]LOC

          # Asocio el consumo con el último lote - sublote declarado
          # Ajusto la cantidad pendiente. No propongo la de toda la OF, sino la proporcional a la última cantidad declarada
          # Modif 04/04/2018. Ajusto la cantidad pendiente propuesta por el sistema en base a fórmulas indicadas por Eduardo:
          # Ctd propuesta consumida inicial (CPCI) = Ctd a consumir STD de la OF x (Ctd dada de alta en último seguimiento / Ctd prevista de realizar en la OF)
          # Ctd propuesta consumida = Ctd propuesta consumida inicial (CPCI) - Ctd consumida anteriormente (CCA)
          Local Decimal CPCI,CCA,ALTA
          Local Char LOTE_PT
          # Saco primero el último lote dado de alta
          Filter [YY3] Where [YY3]TRSTYP = 5 and [YY3]VCRNUMORI = [M:XAMT]MFGNUM Order By [YY3]LOT Desc
          Read [YY3] First
          If fstat = 0
            [L]LOTE_PT = [YY3]LOT
          Endif
          Filter [YY3]
          # Saco ahora las cantidades en función de la última declaración
          Filter [YY3] Where [YY3]TRSTYP = 5 and [YY3]VCRNUMORI = [M:XAMT]MFGNUM  and [YY3]LOT = [L]LOTE_PT  Order By [YY3]VCRNUM Desc
            For [YY3]
            [M:XAMT]YLOTEPT      = [YY3]LOT + '-' + [YY3]SLO
            [M:XAMT]YLOTE        = [YY3]LOT
            [M:XAMT]YSUBLOTE     = [YY3]SLO
            [L]ALTA += [F:YY3]QTYPCU
            Next
          Filter [YY3]
          #Infbox num$(ALTA)
          Read [YY4]MFI0 = [M:XAMT]MFGNUM;[M:XAMT]MFGLIN
          If fstat = 0
            #[M:XAMT]USEQTY = [M:XAMT]USEQTY * ([F:YY3]QTYPCU / [F:YY4]UOMEXTQTY)  Esto es lo que había antes de la modificación del 04/04/2018
            [L]CPCI = [YY1]RETQTY * ([L]ALTA / [F:YY4]UOMEXTQTY)
            #Infbox "CPCI=" + num$([L]CPCI)
          Endif
          Affzo [M:XAMT]YLOTEPT,YLOTE,YSUBLOTE,USEQTY

          # Saco ahora las cantidades consumidas de la última declaración
          For [YY5] Where [YY5]MFGNUM = [M:XAMT]MFGNUM and [YY5]MFGLIN = [M:XAMT]MFGLIN and [YY5]ITMREF = [M:XAMT]ITMREF and [YY5]YLOTE = [L]LOTE_PT
            For [YY3] Where [YY3]TRSTYP = 6 and [YY3]VCRNUMORI = [M:XAMT]MFGNUM and [YY3]VCRLINORI = [M:XAMT]MFGLIN and [YY3]ITMREF = [M:XAMT]ITMREF and [YY3]VCRNUM = [YY5]MFGTRKNUM
             [L]CCA += [YY3]QTYPCU
            Next
          Next
          #Infbox "CCA=" + num$([L]CCA)
          [M:XAMT]USEQTY = [L]CPCI + [L]CCA

          # Pongo como cantidad pendiente SPE la que el sistema calcula en el campo STD, y el campo STD lo dejo en blanco
          [M:XAMT]YPDTE  = [M:XAMT]USEQTY
          [M:XAMT]USEQTY = 0
          Affzo [M:XAMT]YPDTE,USEQTY

          zonsui = '[M:XAMT]LOT'
          Break
        Next
      Endif



      # Salgo del bucle
      Break
    Endif
  Next

  Close Local File [YY1],[YY2],[YY3],[YY4],[YY5]

  # Bloqueo el STD
  GPE = 1
Endif
Return


#####################################################################
$BOUTON
# Creación del consumo, si estoy en seguimiento taller
# 1- llamo al STD
# 2- Impresión etiqueta de muestras
# 3- No limpio la pantalla, vuelvo a la acción DEBUT
If BOUT="1" and GFONCTION1 = "FUNSFTPOR"
  # Me guardo primero el lote y sublote del componente y PF
  Local Char LOTE_COM(20)    : [L]LOTE_COM  = [M:XAMT]LOT
  Local Char SLOTE_COM(20)   : [L]SLOTE_COM = [M:XAMT]SLO
  Local Char LOTE_PF(20)     : [L]LOTE_PF   = [M:XAMT]YLOTE
  Local Char SLOTE_PF(20)    : [L]SLOTE_PF  = [M:XAMT]YSUBLOTE
  Local Char OF(20)          : [L]OF = [M:XAMT]MFGNUM
  Local Integer OFLIN        : [L]OFLIN = [M:XAMT]MFGLIN

  # Lanzo el STD
  Gosub BOUTON From VXAMT

  # Lanzo etiqueta de muestras
  If !clalev([YY1])   : Local File STOJOU    [YY1]   : Endif
  Local Char SEGUIMIENTO_PF(20)

  Filter [YY1] Where [YY1]VCRNUMORI = [L]OF and  [YY1]VCRLINORI = [L]OFLIN and [YY1]TRSTYP = 5 and [YY1]LOT = [L]LOTE_PF and [YY1]SLO = [L]SLOTE_PF
  Read [YY1] First
  If fstat = 0
    [L]SEGUIMIENTO_PF = [YY1]VCRNUM
  Endif
  Filter [YY1]
  Close Local File [YY1]

  # Etiqueta e impresora asociada por defecto al usuario. Pongo primero valores por defecto
  If !clalev([XX1])   : Local File APRTAUS      [XX1]   : Endif

  Local Char ETIQUETA  : ETIQUETA  = "Y-ETMTMUP"
  Local Char IMPRESORA : IMPRESORA = "VISTA"

  Filter [XX1] Where [XX1]USR = GUSER and [XX1]RPTCOD = [L]ETIQUETA
  Read [XX1] First
  If fstat = 0
    [L]IMPRESORA = [XX1]PRT
  Endif
  Filter [XX1]

  Close Local File [XX1]

  # Parámetros del informe
  Local Char TBPAR(12)(3),TBVAL(30)(3)
  TBPAR(0) = "SEGUIMIENTO"
  TBVAL(0) = [L]SEGUIMIENTO_PF

  TBPAR(1) = "LOTE"
  TBVAL(1) = [L]LOTE_COM

  TBPAR(2) = "SUBLOTE"
  TBVAL(2) = [L]SLOTE_COM

  Call ETAT(ETIQUETA,IMPRESORA,GLANGUE,0,"",TBPAR,TBVAL) From AIMP3

  # Vuelvo a comenzar la pantalla
  Gosub DEBUT
Endif

Return

