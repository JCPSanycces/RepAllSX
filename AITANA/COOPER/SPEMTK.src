# Codigo Actividad: YS004
#######################################################################################

#######################################################################################
$ACTION
Case ACTION
  When "SETBOUT"    :  Gosub SETBOUT From SPEMTKA   #MODIF PEOPLETECH OREN JYM180202
  When "RAZCRE"     :  Gosub RAZCRE
  When "APRES_CRE"  :  Gosub APRES_CRE
  When "LIENS"      :  Gosub LIENS
Endcase
Return

#######################################################################################
$LIENS
# Muestro valor del registro de calidad en cabecera
Read [YCPMT]YCPMT0 = [M:MTK0]MFGTRKNUM
If fstat = 0
  [M:MTK0]YREVF = [F:YCPMT]YREVF
Else
  [M:MTK0]YREVF = 0
Endif
Affzo [M:MTK0]YREVF
Return

#######################################################################################
$RAZCRE
# Si vengo del Seguimiento taller, traigo planta, OF y voy directo a la cantidad a seguir
If GFONCTION1 = "FUNSFTPOR"
  # Llamo primero a STD
  GFONC1 = "GESMTK"

  Gosub RAZCRE From SUBMTKA

  Local Integer J
  [M:MTK0]MFGFCY = [M:SFTP0]FCY
  Affzo [M:MTK0]MFGFCY
  For J=0 To [M:SFTP0]NBLIG-1
    If [M:SFTP0]SELLIN(J) = 2 and [M:SFTP0]SFTTYP(J) > 3
      [M:MTK0]MFGNUM = [M:SFTP0]VCRNUM(J)
      Call C_MFGNUM([M:MTK0]MFGNUM) From SUBMTK
      Call AM_MFGNUM([M:MTK0]MFGNUM) From SUBMTK
      Affzo [M:MTK0]MFGNUM,MFGTRKDAT
      Affzo [M:MTK2]QTESUIVITM,UL
      Break
    Endif
  Next

  zonsui = "[M:MTK2]QTESUIVITM"

  # Bloqueo STD
  GPE = 1
Endif
Return



#########################################################################################
$APRES_CRE
# Si vengo del seguimiento taller, lanzo la impresión automática de la etiqueta

If GFONCTION1 = "FUNSFTPOR" and [M:MTK0]ITMTRKFLG = 2 and [M:MTK2]NBITM > 0
  # Etiqueta e impresora asociada por defecto al usuario. Pongo primero valores por defecto
  If !clalev([XX0])   : Local File ITMMASTER    [XX0]   : Endif
  If !clalev([XX1])   : Local File APRTAUS      [XX1]   : Endif

  Local Char ETIQUETA  : ETIQUETA  = "Y-ETMTPROD"
  Local Char IMPRESORA : IMPRESORA = "VISTA"

  Filter [XX1] Where [XX1]USR = GUSER and [XX1]RPTCOD = [L]ETIQUETA
  Read [XX1] First
  If fstat = 0
    [L]IMPRESORA = [XX1]PRT
  Endif
  Filter [XX1]

  Close Local File [XX0],[XX1]

  # Parámetros del informe
  Local Char TBPAR(12)(1),TBVAL(30)(1)
  TBPAR = "SEGUIMIENTO"
  TBVAL = [M:MTK0]MFGTRKNUM
  Call ETAT(ETIQUETA,IMPRESORA,GLANGUE,0,"",TBPAR,TBVAL) From AIMP3

Endif

#**
#* Modif PEOPLETECH OREN JYM180202
#*!
#Si vengo de Seguimiento de taller y Si es tipo "Declaración producción"
If GFONCTION1 = "FUNSFTPOR" and [M:MTK0]ITMTRKFLG = 2 Then
  #registramos en la tabla YCALPROMT
  If !clalev([XX0])   : Local File YCALPROMT [XX0] : Endif
  Trbegin [XX0]

  [F:XX0]MFGTRKNUM = [M:MTK0]MFGTRKNUM
  [F:XX0]EMPNUM    = [M:SFTP0]EMPNUM

  [F:XX0]YADEFEMB  = 1
  [F:XX0]YAPREEMB  = 1
  [F:XX0]YMATPRI   = 1
  [F:XX0]YMUBOB    = 1
  [F:XX0]YREVF     = 1

  Write [XX0]
  If fstat = 0 Then : Commit
  Else : Rollback
  Endif

  Close Local File [XX0]
Endif
#**
#* Fin modif PEOPLETECH OREN JYM180202
#*!
Return










