# Codigo Actividad: YS008
#######################################################################################
$ACTION
Case ACTION
    When "BOUTON":        Case GACTION
                              When "SAICREPOX" : Gosub BOUTON_CREPOX
                              When "SAIMODPOX" : Gosub BOUTON_MODPOX
                          Endcase

Endcase
Return


###################################################
$BOUTON_CREPOX
Gosub BOUTON_CREPOX From BENCHLIBP
GPE = 1
Return


###################################################
$BOUTON_MODPOX
# Lanzo STD
If 1=2 # Comentado por seguridad antes de borrar 07/02/2019
Gosub BOUTON_MODPOX From BENCHLIBP

# Saco el artículo origen
Local Char ORIGEN
Local Char ARTICULO
Local Char VCRORI
Local Char ITMEST

If !clalev([XX0])   : Local File ORDERS    [XX0]   : Endif
Filter [XX0] Where [XX0]VCRNUM = [F:POH]POHNUM
Read [XX0] First
If fstat = 0
  ARTICULO = [XX0]ITMREF
  ORIGEN   = [XX0]ITMREFORI
  VCRORI   = [XX0]VCRNUMORI
Endif
Filter [XX0]
Close Local File [XX0]

If ORIGEN = ""
  # Busco componente en estructuras y traigo el artículo padre
  If !clalev([XX0])   : Local File BOMD    [XX0]   : Endif
  If !clalev([XX1])   : Local File BOM     [XX1]   : Endif

  For [XX0] Where [XX0]CPNITMREF = ARTICULO
    For [XX1] Where [XX1]ITMREF = [XX0]ITMREF and [XX1]USESTA = 2
      ORIGEN = [XX1]ITMREF
      Break 2
    Next
  Next
  Close Local File [XX0],[XX1]
Endif

If ORIGEN <> ""
  # Busco ahora el artículo estructura (artículo origen del artículo origen de la línea del pedido)
  If !clalev([XX0])   : Local File BOMD    [XX0]   : Endif
  If !clalev([XX1])   : Local File BOM     [XX1]   : Endif

  For [XX0] Where [XX0]CPNITMREF = ORIGEN
    For [XX1] Where [XX1]ITMREF = [XX0]ITMREF and [XX1]USESTA = 2
      ITMEST = [XX1]ITMREF
      Break 2
    Next
  Next
  Close Local File [XX0],[XX1]
Endif


# Cargo campos SPE en pedidos de compra
If !clalev([XX0])   : Local File PORDERQ    [XX0]   : Endif
Trbegin [XX0]
  For [XX0] Where [XX0]POHNUM = [F:POH]POHNUM
    [XX0]YITMORI = ORIGEN
    [XX0]YVCRORI = VCRORI
    [XX0]YITMEST = ITMEST
    Rewrite [XX0]
  Next
Commit
Close Local File [XX0]

# Bloqueo STD
GPE = 1
Endif
Return

