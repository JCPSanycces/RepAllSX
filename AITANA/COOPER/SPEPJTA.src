#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "SETBOUT"    : Gosub SETBOUT
  When "SEL_TABLE"  : Gosub SEL_TABLE
  When "VERF_TABLE" : Gosub VERF_TABLE
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$SETBOUT
  # llama a la función la primera vez que entra en la ventana
  Call GET_CONCERTO([M:PJTA0]OPPNUM,[M:PJTA0]TASCOD)
Return

##############################################################
$SEL_TABLE
  Case TABLE
    When "YSELFKDESK" : Gosub SEL_YSELFKDESK
  Endcase
Return

##############################################################
$VERF_TABLE
  Case TABLE
    When "YSELFKDESK" : Gosub VERF_YSELFKDESK
  Endcase
Return

##############################################################
$SEL_YSELFKDESK
  If !clalev([F:YCC0]) Then : Local File YCONCERTO [F:YCC0] : Endif
  Default File [F:YCC0]
  Filter [F:YCC0] Where [F:YCC0]OPPNUM = [M:PJTA0]OPPNUM
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Route Key"                                           # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Route Key"                                                      # título de la segunda columna
  COL(NBCOL)  = "ROUTEKEY"                                                       # nombre del campo a mostrar en la segunda columna
  #If clalev([F:YCC0])  Then : Close Local File    [F:YCC0] : Endif
Return

##############################################################
$VERF_YSELFKDESK
  [M:PJTA2]ROUTEKEY = [F:YCC0]ROUTEKEY
  Affzo [M:PJTA2]ROUTEKEY
  Call GET_CONCERTO([M:PJTA0]OPPNUM,[M:PJTA0]TASCOD)
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
######################################################################################
## Control en el campo NBLIG
# lo utilizo para saber en cada momento sobre qué proyecto y tarea estoy
######################################################################################
Subprog AS_NBLIG

Call GET_CONCERTO([M:PJTA0]OPPNUM,[M:PJTA0]TASCOD)
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
#######################
#**
#* muestra la información de la tabla YCONCERTO en el bloque de la pantalla
#*
#* @param POPPNUM  > código del proyecto
#* @param PTASCOD  > código de la tarea
#*!
Subprog GET_CONCERTO(POPPNUM,PTASCOD)
Value Char POPPNUM
Value Char PTASCOD

Local Integer NOL : Raz NOL

  If !clalev([F:YCC0]) Then : Local File YCONCERTO    [F:YCC0] : Endif
  If !clalev([F:YCCP]) Then : Local File YCONCERTOPJM [F:YCCP] : Endif

  Read [YCCP]YCCP0 =  POPPNUM;PTASCOD
  If fstat = 0
    Read [F:YCC0]YCC0 = [YCCP]OPPNUM;[YCCP]ROUTEKEY
    If !fstat Then
      [M:PJTA2]ROUTEKEY    = [F:YCC0]ROUTEKEY
      [M:PJTA2]YFKDESC     = [F:YCC0]YFKDESC
      [M:PJTA2]YESTADO     = [F:YCC0]ESTADO
      [M:PJTA2]YCOMPLETADO = [F:YCC0]COMPLETADO
      [M:PJTA2]YDUEDAT     = [F:YCC0]DUEDAT
      [M:PJTA2]YENDDAT     = [F:YCC0]ENDDAT
    Else
      Raz [M:PJTA2]ROUTEKEY
      Raz [M:PJTA2]YFKDESC
      Raz [M:PJTA2]YESTADO
      Raz [M:PJTA2]YCOMPLETADO
      Raz [M:PJTA2]YDUEDAT
      Raz [M:PJTA2]YENDDAT
    Endif
  Else
    Raz [M:PJTA2]ROUTEKEY
    Raz [M:PJTA2]YFKDESC
    Raz [M:PJTA2]YESTADO
    Raz [M:PJTA2]YCOMPLETADO
    Raz [M:PJTA2]YDUEDAT
    Raz [M:PJTA2]YENDDAT
  Endif

  Affzo [M:PJTA2]ROUTEKEY
  Affzo [M:PJTA2]YFKDESC
  Affzo [M:PJTA2]YESTADO
  Affzo [M:PJTA2]YCOMPLETADO
  Affzo [M:PJTA2]YDUEDAT
  Affzo [M:PJTA2]YENDDAT

  If clalev([F:YCC0])  Then : Close Local File    [F:YCC0] : Endif
  If clalev([F:YCCP])  Then : Close Local File    [F:YCCP] : Endif

End




######################################################################################
## Etiqueta añadida por el supervisor (pantalla PJMTAS2) 09/03/2020 15:46:31 (AIT04)
######################################################################################
Subprog AM_ROUTEKEY(VALEUR)
Variable Char    VALEUR()
# Si pongo valor asocio la tarea al registro de Concerto. Si borro valor, libero la tarea al registro de concerto
If !clalev([F:ZZ1]) Then : Local File YCONCERTO    [ZZ1] : Endif
If !clalev([F:ZZ2]) Then : Local File YCONCERTOPJM [ZZ2] : Endif

  If VALEUR <> ""
    # 1 - Traigo los valores de la tabla de concepto a los campos de la pantalla
    Read [F:ZZ1]YCC0 = [M:PJTA0]OPPNUM;VALEUR
    If fstat = 0
      [M:PJTA2]YFKDESC      = [ZZ1]YFKDESC
      [M:PJTA2]YESTADO      = [ZZ1]ESTADO
      [M:PJTA2]YCOMPLETADO  = [ZZ1]COMPLETADO
      [M:PJTA2]YDUEDAT      = [ZZ1]DUEDAT
      [M:PJTA2]YENDDAT      = [ZZ1]ENDDAT
    Else
      Raz [M:PJTA2]YFKDESC
      Raz [M:PJTA2]YESTADO
      Raz [M:PJTA2]YCOMPLETADO
      Raz [M:PJTA2]YDUEDAT
      Raz [M:PJTA2]YENDDAT
    Endif

    Affzo [M:PJTA2]YFKDESC
    Affzo [M:PJTA2]YESTADO
    Affzo [M:PJTA2]YCOMPLETADO
    Affzo [M:PJTA2]YDUEDAT
    Affzo [M:PJTA2]YENDDAT

    # 2 - Guardo / refresco el dato en tabla YCONCERTOPJM
    For [ZZ2] Where [ZZ2]OPPNUM = [M:PJTA0]OPPNUM and [ZZ2]TASCOD = [M:PJTA0]TASCOD
      Delete [ZZ2] Curr
    Next
    Raz [ZZ2]
    [ZZ2]OPPNUM   = [M:PJTA0]OPPNUM
    [ZZ2]TASCOD   = [M:PJTA0]TASCOD
    [ZZ2]ROUTEKEY = VALEUR
    Write [ZZ2]

  Else

    # 1 - Limpio pantalla
    Raz [M:PJTA2]YFKDESC
    Raz [M:PJTA2]YESTADO
    Raz [M:PJTA2]YCOMPLETADO
    Raz [M:PJTA2]YDUEDAT
    Raz [M:PJTA2]YENDDAT
    Affzo [M:PJTA2]YFKDESC
    Affzo [M:PJTA2]YESTADO
    Affzo [M:PJTA2]YCOMPLETADO
    Affzo [M:PJTA2]YDUEDAT
    Affzo [M:PJTA2]YENDDAT

    # 2 - Borro el dato en tabla YCONCERTOPJM
    For [ZZ2] Where [ZZ2]OPPNUM = [M:PJTA0]OPPNUM and [ZZ2]TASCOD = [M:PJTA0]TASCOD
      Delete [ZZ2] Curr
    Next
  Endif

Close Local File [ZZ1],[ZZ2]
End


######################################################################################
######################################################################################
## Etiqueta añadida por el supervisor (pantalla PJMTAS2) 09/03/2020 16:16:58 (AIT04)
######################################################################################
Subprog C_ROUTEKEY(VALEUR)
Variable Char    VALEUR()
# Controlo la existencia del valor introducido
If !clalev([F:ZZ1]) Then : Local File YCONCERTO [ZZ1] : Endif

If VALEUR <> ""
  Read [F:ZZ1]YCC0 = [M:PJTA0]OPPNUM;VALEUR
  If fstat <> 0
    Errbox "No existe la relación Proyecto / RouteKey introducida: " + [M:PJTA0]OPPNUM + " / " + VALEUR
    mkstat = 2
  Endif
Endif

Close Local File [ZZ1]
End

