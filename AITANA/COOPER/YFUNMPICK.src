#####################################################################################
# Src: YFUNMPICK
#-------------------------------------------------------------------------------------
# (FUNMPICK - PUNTO DE ENTRADA)
#-------------------------------------------------------------------------------------
# Proyecto: JAE
#-------------------------------------------------------------------------------------
# Version: v11
#-------------------------------------------------------------------------------------
# Fecha:15-01-2019
#-------------------------------------------------------------------------------------
# Desarrollador: DSAL
# Codigo Actividad: YS008
#######################################################################################

$ACTION
Case ACTION
  When "ADDLIN"     : Gosub ADDLIN    # Muestro el código del proveedor que he guardado
  When "CUSSELFLT"  : Gosub CUSSELFLT # Añado criterio de asiento origen
  When "CUSSRT"     : Gosub CUSSRT    # Ordenación de líneas
  When "STYLE"      : Gosub STYLE     # Gestión de estilos de las líneas
  When "CHECKORD"   : Gosub CHECKORD  # Sobre los resultantes, verifico si han sido gestionados
Endcase
Return

################################################
$ADDLIN
#If [M:MGP]BPSNUM(nolign-1) = ""
If MASKREF = "MFGPICKA"
  If !clalev([PP1]) : Local File ORDERS [PP1] : Endif
  Read [PP1]ORD0 = [M:MGP]WIPTYP(nolign-1);[M:MGP]WIPNUM(nolign-1);[M:MGP]ITMREF(nolign-1)
  If fstat = 0 and [PP1]BPRNUM <> ""
    [M:MGP]BPSNUM(nolign-1) = [PP1]BPRNUM
    Affzo [M:MGP]BPSNUM(nolign-1)
  Endif
  Close Local File [PP1]

  # Corrijo el proveedor si es JAE -> en este caso lo dejo directamente en blanco
  If [M:MGP]BPSNUM(nolign-1) = "JAE"
    [M:MGP]BPSNUM(nolign-1) = ""
    Affzo [M:MGP]BPSNUM(nolign-1)
  Endif

  # Muestro información de la gestión de la necesidad
  If !clalev([PP2]) : Local File ORDERS [PP2] : Endif
  Filter [PP2] Where [PP2]VCRNUMORI = [M:MGP]VCRNUM(nolign-1) and [PP2]ITMREF = [M:MGP]ITMREF(nolign-1) and [PP2]WIPTYP <> 6 and ([PP2]WIPSTA = 1 or [PP2]WIPSTA = 4)
  Read [PP2]Last
  If fstat= 0
    [M:MGP]YVCRGES(nolign-1) = [PP2]VCRNUM
    [M:MGP]YBPSGES(nolign-1) = [PP2]BPRNUM
    Affzo [M:MGP]YVCRGES(nolign-1)
  Endif
  Filter [PP2]
  Close Local File [PP2]

  # Refuerzo 15/07/19. Busco ahora en las líneas de los pedidos de compra
  If [M:MGP]YVCRGES(nolign-1) = ""
    If clalev([F:YXX1]) = 0 : Local File MTOLINK [YXX1]  : Endif
    If clalev([F:YXX2]) = 0 : Local File PORDERQ [YXX2]  : Endif
    If clalev([F:YXX3]) = 0 : Local File PORDER  [YXX3]  : Endif

      Filter [YXX1] Where [YXX1]ITMREF = [M:MGP]ITMREF(nolign-1) and [YXX1]DEMNUM = [M:MGP]VCRNUM(nolign-1) and [YXX1]DEMLIN = [M:MGP]VCRLIN(nolign-1)
      Read [YXX1] First
      If fstat = 0
        [M:MGP]YVCRGES(nolign-1) = [YXX1]RESSNUM
        Read [YXX3]POH0 = [YXX1]RESSNUM
        If fstat = 0
          [M:MGP]YBPSGES(nolign-1) = [YXX3]BPSNUM
        Endif
        Affzo [M:MGP]YVCRGES(nolign-1)
        Affzo [M:MGP]YBPSGES(nolign-1)
      Endif
      Filter [YXX1]

    Close Local File [YXX1],[YXX2],[YXX3]
  Endif

  If [M:MGP]YVCRGES(nolign-1) = ""
    If clalev([F:YXX2]) = 0 : Local File PORDERQ [YXX2]  : Endif
    Filter [YXX2] Where [YXX2]ITMREF = [M:MGP]ITMREF(nolign-1) and [YXX2]YVCRORI = [M:MGP]VCRNUM(nolign-1)
    Read [YXX2]Last
    If fstat= 0
      [M:MGP]YVCRGES(nolign-1) = [YXX2]POHNUM
      [M:MGP]YBPSGES(nolign-1) = [YXX2]BPSNUM
      Affzo [M:MGP]YVCRGES(nolign-1)
      Affzo [M:MGP]YBPSGES(nolign-1)
    Endif
    Filter [YXX2]
    Close Local File [YXX2]
  Endif

  # 13/03/2020. Sino encuentro asiento origen y éste es una orden de subcontratación, busco por el asiento origen de la ORDERS
  If [M:MGP]YVCRGES(nolign-1) = "" and left$([M:MGP]VCRNUM(nolign-1),3) = "JOS"
    If clalev([F:ZXX1]) = 0 : Local File PORDERP [ZXX1]  : Endif
    If clalev([F:YXX2]) = 0 : Local File PORDERQ [YXX2]  : Endif

    Filter [YXX2] Where [YXX2]ITMREF = [M:MGP]ITMREF(nolign-1) and [YXX2]YVCRORI = [M:MGP]VCRNUMORI(nolign-1)
    Read [YXX2]Last
    If fstat= 0
      Read [ZXX1]POP0 = [YXX2]POHNUM;[YXX2]POPLIN;[YXX2]POQSEQ
      If fstat = 0 and [ZXX1]PJT = [M:MGP]PJT(nolign-1)
        [M:MGP]YVCRGES(nolign-1) = [YXX2]POHNUM
        [M:MGP]YBPSGES(nolign-1) = [YXX2]BPSNUM
        Affzo [M:MGP]YVCRGES(nolign-1)
        Affzo [M:MGP]YBPSGES(nolign-1)
      Endif
    Endif
    Filter [YXX2]
    Close Local File [YXX2],[ZXX1]
  Endif

  # 18/03/2020. Sino encuentro busco en las JOS; puede ser que se haya generado una JOS contra la JOF (VCRNUM) de la ORDERS
  If [M:MGP]YVCRGES(nolign-1) = "" and left$([M:MGP]VCRNUM(nolign-1),3) = "JOF"
    If clalev([F:YXX5]) = 0 : Local File SCOITM  [YXX5]  : Endif
    If clalev([F:YXX2]) = 0 : Local File PORDERQ [YXX2]  : Endif
    Filter [YXX5] Where [YXX5]ITMREF = [M:MGP]ITMREF(nolign-1) and [YXX5]VCRNUMORI = [M:MGP]VCRNUM(nolign-1) and [YXX5]PJT = [M:MGP]PJT(nolign-1)
    Read [YXX5]Last
    If fstat= 0
      Read [YXX2]POQ0 = [YXX5]POHNUM;[YXX5]POPLIN;[YXX5]POQSEQ
      If fstat = 0
        [M:MGP]YVCRGES(nolign-1) = [YXX2]POHNUM
        [M:MGP]YBPSGES(nolign-1) = [YXX2]BPSNUM
        Affzo [M:MGP]YVCRGES(nolign-1)
        Affzo [M:MGP]YBPSGES(nolign-1)
      Endif
    Endif
    Filter [YXX5]
    Close Local File [YXX5],[YXX2]
  Endif

  # 27/04/2020. Sino encuentro asiento origen y éste es una orden de subcontratación, busco por proyecto y artículo directamente
  If [M:MGP]YVCRGES(nolign-1) = "" and left$([M:MGP]VCRNUM(nolign-1),3) = "JOS"
    If clalev([F:ZXX1]) = 0 : Local File PORDERP [ZXX1]  : Endif
    If clalev([F:YXX2]) = 0 : Local File PORDERQ [YXX2]  : Endif

    Filter [ZXX1] Where [ZXX1]ITMREF = [M:MGP]ITMREF(nolign-1) and [ZXX1]PJT = [M:MGP]PJT(nolign-1)
    Read [ZXX1]Last
    If fstat= 0
      Read [YXX2]POQ0 = [ZXX1]POHNUM;[ZXX1]POPLIN;[ZXX1]POPSEQ
      If fstat = 0 and [YXX2]QTYUOM = [M:MGP]RMNEXTQTY(nolign-1)
        [M:MGP]YVCRGES(nolign-1) = [YXX2]POHNUM
        [M:MGP]YBPSGES(nolign-1) = [YXX2]BPSNUM
        Affzo [M:MGP]YVCRGES(nolign-1)
        Affzo [M:MGP]YBPSGES(nolign-1)
      Endif
    Endif
    Filter [YXX2]
    Close Local File [YXX2],[ZXX1]
  Endif

  # 12/05/2020. Cambio el proveedor por el proveedor asociado en el articulo
  If clalev([F:ZXX9]) = 0 : Local File ITMBPS [ZXX9]  : Endif

  Filter [ZXX9] Where [ZXX9]ITMREF = [M:MGP]ITMREF(nolign-1) Order By [ZXX9]PIO Asc
  Read [ZXX9] First
  If fstat = 0
    [M:MGP]BPSNUM(nolign-1) = [ZXX9]BPSNUM
    Affzo [M:MGP]BPSNUM(nolign-1)
  Endif
  Filter [ZXX9]

  Close Local File [ZXX9]
#Endif
Endif

Return


################################################
$CUSSELFLT
If [M:MGP]YITMORI <> ""
  CUSFLT +=" [F:ORD]ITMREFORI = [M:MGP]YITMORI"
Endif

If [M:MGP]YMWF = 2
  CRITERE1 = "(WIPTYP=6 OR WIPTYP=3) & WIPSTA=1"    # Muestro materiales subcontratación y necesidades componentes fabricación

  If [M:MGP]FCY <> ""
      CRITERE1 += " & STOFCY=[M:MGP]FCY"     # planta
  Endif

  If MASKREF = "MFGPICKA"
    If [M:MGP]ITMREFSTR <> ""
        CRITERE1 += " & ITMREF>=[M:MGP]ITMREFSTR"     # borne début article
    Endif

    If [M:MGP]ITMREFEND<>""
        CRITERE1 += " & ITMREF<=[M:MGP]ITMREFEND"     # borne fin   article
    Endif
  Else
    If [M:MGP]ITMREFS <> ""
        CRITERE1 += " & ITMREF>=[M:MGP]ITMREFS"     # borne début article
    Endif
  Endif

  If [M:MGP]YVCRORI<>""
      CRITERE1 += " & VCRNUM>=[M:MGP]YVCRORI"        # borne fin  asiento
  Endif

  If [M:MGP]YVCRDES<>""
      CRITERE1 += " & VCRNUM<=[M:MGP]YVCRDES"        # borne fin  asiento
  Endif

  If [M:MGP]YPJTORI<>""
      CRITERE1 += " & PJT>=[M:MGP]YPJTORI"        # borne fin projet
  Endif

  If [M:MGP]YPJTDES<>""
      CRITERE1 += " & PJT<=[M:MGP]YPJTDES"        # borne fin projet
  Endif

  # 12/03/2020. Cambio la gestión de las líneas pendientes
  If 1=2
    If [M:MGP]YPENDIENTES = 2
        #CRITERE1 += " & RMNEXTQTY>(ALLQTY+MTOQTY)"     # ver solamente las pendientes
        CRITERE1 += " & RMNEXTQTY>(MTOQTY)"     # ver solamente las pendientes, sin tener en cuenta las asignaciones de stock
    Endif
  Endif
Endif
Return


################################################
$CUSSRT
Case [F:BTS]BTSTYP
    When 53: Sorta [M:MGP]NBLIG [M:MGP]NBLIG Order By [M:MGP]ITMREF(indice),[M:MGP]ITMREFORI(indice) Asc : WTRI = 1
Endcase
Return


################################################
$STYLE
# Cambio de colores 07/05/2020
If 1=2
  # Si tengo valor en el campo Gestionado, marco la línea
  If [M:MGP]YVCRGES([M:HLIK]LINNUM) <> ""
    [M:HLIK]STYLE = "PJMTOTALB"   # Fondo amarillo
  Endif

  # Si la necesidad está asignada contra stock, marco la línea
  If !clalev([PP5]) : Local File STOALL [PP5] : Endif

  If [M:MGP]ALLQTY([M:HLIK]LINNUM) <> 0
    Filter [PP5] Where [PP5]STOFCY = [M:MGP]STOFCY([M:HLIK]LINNUM) and [PP5]ITMREF = [M:MGP]ITMREF([M:HLIK]LINNUM) and [PP5]VCRNUM = [M:MGP]VCRNUM([M:HLIK]LINNUM)
    Read [PP5] First
    If fstat = 0
      [M:HLIK]STYLE = "PJMEXPENSB"   # Fondo verde
    Endif
    Filter [PP5]
  Endif

  Close Local File [PP5]
Else
  # Sin gestionar Sin proveedor no indicado, fondo rojo
  If [M:MGP]BPSNUM([M:HLIK]LINNUM) = ""
    [M:HLIK]STYLE = "PJMBUD"   # Fondo rojo
  # Gestionado fondo verde
  Elsif [M:MGP]YVCRGES([M:HLIK]LINNUM) <> ""
    [M:HLIK]STYLE = "PJMEXPENSB"   # Fondo verde
  Endif
Endif
Return


################################################
$CHECKORD
# Si marco el campo de Solo Pendientes, descarto registro en caso que éste haya sido gestionado
If [M:MGP]YPENDIENTES = 2
  If !clalev([PP2]) : Local File ORDERS [PP2] : Endif
  Local Char ASIENTO_ORIGEN
  Filter [PP2] Where [PP2]VCRNUMORI = [F:ORD]VCRNUM and [PP2]ITMREF = [F:ORD]ITMREF and [PP2]WIPTYP <> 6 and ([PP2]WIPSTA = 1 or [PP2]WIPSTA = 4)
  Read [PP2]Last
  If fstat= 0 and [PP2]VCRNUM <> ""
    ASIENTO_ORIGEN = [PP2]VCRNUM
  Endif
  Filter [PP2]
  Close Local File [PP2]

  # Refuerzo 15/07/19. Busco ahora en las líneas de los pedidos de compra
  If ASIENTO_ORIGEN = ""
    If clalev([F:YXX1]) = 0 : Local File MTOLINK [YXX1]  : Endif
    If clalev([F:YXX2]) = 0 : Local File PORDERQ [YXX2]  : Endif
    If clalev([F:YXX3]) = 0 : Local File PORDER  [YXX3]  : Endif
      Filter [YXX1] Where [YXX1]ITMREF = [F:ORD]ITMREF and [YXX1]DEMNUM = [F:ORD]VCRNUM and [YXX1]DEMLIN = [F:ORD]VCRLIN
      Read [YXX1] First
      If fstat = 0
        ASIENTO_ORIGEN = [YXX1]RESSNUM
      Endif
      Filter [YXX1]
    Close Local File [YXX1],[YXX2],[YXX3]
  Endif

  If ASIENTO_ORIGEN = ""
    If clalev([F:YXX2]) = 0 : Local File PORDERQ [YXX2]  : Endif
    Filter [YXX2] Where [YXX2]ITMREF = [F:ORD]ITMREF and [YXX2]YVCRORI = [F:ORD]VCRNUM
    Read [YXX2]Last
    If fstat= 0
      ASIENTO_ORIGEN = [YXX2]POHNUM
    Endif
    Filter [YXX2]
    Close Local File [YXX2]
  Endif

  # 13/03/2020. Sino encuentro asiento origen y éste es una orden de subcontratación, busco por el asiento origen de la ORDERS
  If ASIENTO_ORIGEN = "" and left$([F:ORD]VCRNUM,3) = "JOS"
    If clalev([F:ZXX1]) = 0 : Local File PORDERP [ZXX1]  : Endif
    If clalev([F:YXX2]) = 0 : Local File PORDERQ [YXX2]  : Endif
    Filter [YXX2] Where [YXX2]ITMREF = [F:ORD]ITMREF and [YXX2]YVCRORI = [F:ORD]VCRNUMORI
    Read [YXX2]Last
    If fstat= 0
      Read [ZXX1]POP0 = [YXX2]POHNUM;[YXX2]POPLIN;[YXX2]POQSEQ
      If fstat = 0 and [ZXX1]PJT = [F:ORD]PJT
        ASIENTO_ORIGEN = [YXX2]POHNUM
      Endif
    Endif
    Filter [YXX2]
    Close Local File [YXX2],[ZXX1]
  Endif

  # 18/03/2020. Sino encuentro busco en las JOS; puede ser que se haya generado una JOS contra la JOF (VCRNUM) de la ORDERS
  If ASIENTO_ORIGEN = "" and left$([F:ORD]VCRNUM,3) = "JOF"
    If clalev([F:YXX5]) = 0 : Local File SCOITM  [YXX5]  : Endif
    If clalev([F:YXX2]) = 0 : Local File PORDERQ [YXX2]  : Endif
    Filter [YXX5] Where [YXX5]ITMREF = [F:ORD]ITMREF and [YXX5]VCRNUMORI = [F:ORD]VCRNUM and [YXX5]PJT = [F:ORD]PJT
    Read [YXX5]Last
    If fstat= 0
      Read [YXX2]POQ0 = [YXX5]POHNUM;[YXX5]POPLIN;[YXX5]POQSEQ
      If fstat = 0
        ASIENTO_ORIGEN = [YXX2]POHNUM
      Endif
    Endif
    Filter [YXX5]
    Close Local File [YXX5],[YXX2]
  Endif

  # 27/04/2020. Sino encuentro asiento origen y éste es una orden de subcontratación, busco por proyecto y artículo directamente
  If ASIENTO_ORIGEN = "" and left$([F:ORD]VCRNUM,3) = "JOS"
    If clalev([F:ZXX1]) = 0 : Local File PORDERP [ZXX1]  : Endif
    If clalev([F:YXX2]) = 0 : Local File PORDERQ [YXX2]  : Endif

    Filter [ZXX1] Where [ZXX1]ITMREF = [F:ORD]ITMREF and [ZXX1]PJT = [F:ORD]PJT
    Read [ZXX1]Last
    If fstat= 0
      Read [YXX2]POQ0 = [ZXX1]POHNUM;[ZXX1]POPLIN;[ZXX1]POPSEQ
      If fstat = 0 and [YXX2]QTYUOM = [F:ORD]RMNEXTQTY
        ASIENTO_ORIGEN  = [YXX2]POHNUM
      Endif
    Endif
    Filter [YXX2]
    Close Local File [YXX2],[ZXX1]
  Endif

  # 12/05/2020. Cambio el proveedor por el proveedor asociado en el articulo
  If clalev([F:ZXX9]) = 0 : Local File ITMBPS [ZXX9]  : Endif

  Filter [ZXX9] Where [ZXX9]ITMREF = [M:MGP]ITMREF(nolign-1) Order By [ZXX9]PIO Asc
  Read [ZXX9] First
  If fstat = 0
    [M:MGP]BPSNUM(nolign-1) = [ZXX9]BPSNUM
    Affzo [M:MGP]BPSNUM(nolign-1)
  Endif
  Filter [ZXX9]

  Close Local File [ZXX9]

  # Si tengo asiento origen, no debo mostrar la línea
  If ASIENTO_ORIGEN <> ""
    GPE = 1
  Endif

Endif
Return

