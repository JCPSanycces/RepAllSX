#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "DEBUT"     :   Gosub DEBUT
  When "BOUTON"    :   Gosub BOUTON
Endcase
Return


#####################################################
$DEBUT
# Limpio pantalla
Gosub LIMPIO_PANTALLA
Return


#####################################################
$BOUTON
# Ejecución de botones
Case BOUT
  When "Z"    :   Gosub BUSCAR
  When "Y"    :   Gosub REGISTRAR
Endcase
Return


#####################################################
$BUSCAR
# Primero limpio la pantalla
Gosub LIMPIO_PANTALLA

# Busco datos de las muestras a partir de los criterios introducidos
# Apertura de tablas
If !clalev([YY1])   : Local File YKEYENCE     [YY1]   : Endif

# Compongo criterio de búsqueda
Local Char CRITERIO_PT(250)  :  [L]CRITERIO_PT = "1=1"
Local Char CRITERIO_CO(250)  :  [L]CRITERIO_CO = "1=1"

If [M:YKEY0]PT_INI <> ""    :  [L]CRITERIO_PT += "& [F:YY1]PT>=[M:YKEY0]PT_INI" : Endif
If [M:YKEY0]PT_FIN <> ""    :  [L]CRITERIO_PT += "& [F:YY1]PT<=[M:YKEY0]PT_FIN" : Endif
If [M:YKEY0]LOTOF_INI <> "" :  [L]CRITERIO_PT += "& [F:YY1]LOTEPT_OF>=[M:YKEY0]LOTOF_INI" : Endif
If [M:YKEY0]LOTOF_FIN <> "" :  [L]CRITERIO_PT += "& [F:YY1]LOTEPT_OF<=[M:YKEY0]LOTOF_FIN" : Endif
If [M:YKEY0]CP_INI <> ""    :  [L]CRITERIO_CO += "& [F:YY1]COMPONENTE>=[M:YKEY0]CP_INI"   : Endif
If [M:YKEY0]CP_FIN <> ""    :  [L]CRITERIO_CO += "& [F:YY1]COMPONENTE<=[M:YKEY0]CP_FIN"   : Endif
If [M:YKEY0]LOTEC_INI <> "" :  [L]CRITERIO_PT += "& [F:YY1]LOTECO>=[M:YKEY0]LOTEC_INI"    : Endif
If [M:YKEY0]LOTEC_FIN <> "" :  [L]CRITERIO_PT += "& [F:YY1]LOTECO<=[M:YKEY0]LOTEC_FIN"    : Endif

# Muestro registros
nolign = 1
Filter [YY1] Where [YY1]TIPO = [M:YKEY0]TIPO and evalue([L]CRITERIO_PT) and evalue([L]CRITERIO_CO)
  For [YY1]
    [M:YKEY0] = [YY1]
    nolign+=1
    [M:YKEY0]PIE_K+=1
  Next
Filter [YY1]

# Cierro tabla
Close Local File [YY1]

# Ordeno registros. Muestro pantalla
#Sorta [M:YKEY0]PIE_K [M:YKEY0]PIE_K Order By [M:YKEY0]PT(indice),[M:YKEY0]LOTEPT_OF(indice) Asc
Sorta [M:YKEY0]PIE_K [M:YKEY0]PIE_K Order By [M:YKEY0]LOTEPT_OF(indice),[M:YKEY0]LOTECO(indice) Asc
Affzo [M:YKEY0]
Return


#####################################################
$LIMPIO_PANTALLA
# Limpio pantalla
Effzo [M:YKEY0]10
[M:YKEY0]PIE_K = 0
Affzo [M:YKEY0]
Return


######################################################################################
## Etiqueta añadida por el supervisor (pantalla YKEYENCE) 19/04/2018 09:42:24 (PT02)
######################################################################################
Subprog AM_VATR01(VALEUR)
Variable Char    VALEUR()
# Ajuste del color si modificación
If VALEUR <> [M:YKEY0]VATR01(nolign-1)
  Chgstl [M:YKEY0]VATR01(nolign-1) With "NTRANSLATE"
  [M:YKEY0]MODIF(nolign-1) = 2
Else
  Chgstl [M:YKEY0]VATR01(nolign-1) With ""
  [M:YKEY0]MODIF(nolign-1) = 1
Endif
End


