#####################################################
$REGISTRAR
# Apertura de tablas
If !clalev([YY1])   : Local File YKEYENCE     [YY1]   : Endif

# Guardo registros para las líneas en las que ha habido modificación
Local Integer LIN, CONTA
For LIN = 0 To [M:YKEY0]PIE_K-1
  If [M:YKEY0]MODIF(LIN) = 2
    Read [YY1]YKEY0 = [M:YKEY0]PT(LIN);[M:YKEY0]LOTEPT_OF(LIN);[M:YKEY0]COMPONENTE(LIN);[M:YKEY0]LOTECO(LIN)
    If fstat = 0
      [YY1]CATR01 = [M:YKEY0]CATR01(LIN)
      [YY1]CATR02 = [M:YKEY0]CATR02(LIN)
      [YY1]CATR03 = [M:YKEY0]CATR03(LIN)
      [YY1]CATR04 = [M:YKEY0]CATR04(LIN)
      [YY1]CATR05 = [M:YKEY0]CATR05(LIN)
      [YY1]CATR06 = [M:YKEY0]CATR06(LIN)
      [YY1]CATR07 = [M:YKEY0]CATR07(LIN)
      [YY1]CATR08 = [M:YKEY0]CATR08(LIN)
      [YY1]CATR09 = [M:YKEY0]CATR09(LIN)
