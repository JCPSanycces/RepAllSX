######################################################################################
Subprog AM_FECHAD(VALEUR)
Variable Date    VALEUR
# Si modifico propongo la fecha final con el mismo valor
[M:YOMFG]FECHAH = VALEUR
Affzo [M:YOMFG]FECHAH
End


######################################################################################
Subprog C_FECHAH(VALEUR)
Variable Date    VALEUR
# La fecha final no puede ser inferior a la fecha inicial
If VALEUR < [M:YOMFG]FECHAD
  Errbox "La fecha Hasta no puede ser inferior a la fecha Desde"
  mkstat = 2
Endif
End


######################################################################################
Subprog C_ORDEN1(VALEUR)
Variable Decimal VALEUR
# No permito repetir orden
Call UNICITE(VALEUR,[M:YOMFG]ORDEN1(0..[M:YOMFG]PIE1-1)) From OBJDIV
End


######################################################################################
Subprog C_ORDEN2(VALEUR)
Variable Decimal VALEUR
# No permito repetir orden
Call UNICITE(VALEUR,[M:YOMFG]ORDEN2(0..[M:YOMFG]PIE2-1)) From OBJDIV
