#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "LIENS"    :   Gosub LIENS
Endcase
Return

###########################################
$LIENS
# Primero lanzo el STD
Gosub LIENS From SUBTKI
# Muestro ahora el nombre del colaborador
If [M:MKI3]NBLIG > 0
  If !clalev([YY0])   : Local File TABMAT    [YY0]   : Endif
  Local Integer I
  For I=0 To [M:MKI3]NBLIG-1
    Read [YY0]TMA0 = [M:MKI3]EMPNUM(I)
    If fstat = 0
      [M:MKI3]YNOMBRE(I) = [YY0]EMPDES
      Affzo [M:MKI3]YNOMBRE(I)
    Endif
  Next
Endif

# Bloqueo el STD
GPE = 1
Return

