#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara MTK2 (Especifico)
$ACTION

Case ACTION
  When "LABEL" : Gosub LABEL
Endcase

Return

#---------------------------------------------------------------------------------------------------#
#                                           LABELS                                                  #
#---------------------------------------------------------------------------------------------------#
$LABEL
Return

#---------------------------------------------------------------------------------------------------#
#                                           SUBPROGS                                                #
#---------------------------------------------------------------------------------------------------#
######################################################################################
Subprog AS_YQTYSSU(VALEUR)
Variable Decimal VALEUR
# Si la unidad de stock es la misma que la unidad estadística, no permito la entrada
If [M:MTK2]STU(nolign-1) = [M:MTK2]YSSU(nolign-1) : mkstat = 2 : Endif
End


######################################################################################
Subprog AP_QTESUIVITM(VALEUR)
Variable Decimal VALEUR
# Llamo la acción del STD
Call AP_QTESUIVITM(VALEUR) From SUBMTK2

# Si se han cargado líneas, alimento campos específicos
If [M:MTK2]NBITM>0
  If !clalev([XX0])   : Local File ITMMASTER    [XX0]   : Endif
  Local Integer LINE
  For LINE = 0 To [M:MTK2]NBITM-1
    Read [XX0]ITM0 = [M:MTK2]ITMREF(LINE)
    If fstat = 0
      [M:MTK2]YSSU(LINE)    = [XX0]SSU
      If [M:MTK2]STU(LINE) = [M:MTK2]YSSU(LINE)
       [M:MTK2]YQTYSSU(LINE) = [M:MTK2]CPLQTY(LINE)
      Else
       [M:MTK2]YQTYSSU(LINE) = 0
      Endif
      Affzo [M:MTK2]YSSU(LINE)
      Affzo [M:MTK2]YQTYSSU(LINE)
    Endif
  Next
  Close Local File [XX0]
Endif
End


######################################################################################
Subprog B13_NBITM
# Abro pantalla de modificación de peso bruto y de cantidad UE
Global Char GL5LLE(250)(7)
Local Integer LINT
GL5LLE(0)   = [M:MTK0]MFGTRKNUM
GL5LLE(1)   = num$([M:MTK2]ITMTRKLIN(nolign-1))
GL5LLE(2)   = [M:MTK2]ITMREF(nolign-1)
GL5LLE(3)   = [M:MTK2]LOT(nolign-1)
GL5LLE(4)   = num$([M:MTK2]YPESOBRUTO(nolign-1))
GL5LLE(5)   = num$([M:MTK2]YQTYSSU(nolign-1))
GL5LLE(6)   = [M:MTK2]YSSU(nolign-1)

Call SAISIE_LIB(LINT,GL5LLE,"YMODIFMTK2","SPEYMTK2","OBJZON") From GSAISIE
End


######################################################################################

