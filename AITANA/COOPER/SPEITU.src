# Gestión de la máscara ITU (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ITU) 13/02/2018 09:00:49 (PT02)
######################################################################################
$ACTION
Case ACTION
 When Default
Endcase
Return

######################################################################################
Subprog AM_ZPLANO(VALEUR)
Variable Char    VALEUR()
# Guardo el valor del campo
[M:ITU]YZPLANO ([M:ITU]XLIGITU) = VALEUR
End


######################################################################################
Subprog AM_ZFECHA(VALEUR)
Variable Date    VALEUR
# Guardo el valor del campo
[M:ITU]YZFECHA ([M:ITU]XLIGITU) = VALEUR
End


######################################################################################
Subprog AM_ZREVISION(VALEUR)
Variable Char    VALEUR()
# Guardo el valor del campo
[M:ITU]YZREVISION ([M:ITU]XLIGITU) = VALEUR
End


######################################################################################
Subprog AS_NBITU
# Traigo rutina de STD y bloqueo
Local Integer NOL
NOL = nolign-1
[M]XLIGITU = nolign-1
Gosub CHARGE_ITU
Raz GBOUT1, GBOUT2
If [M:ITU]BPCNUM(NOL) <> ""
  # Bouton texte document vente
  GBOUT1 = mess(231,198,1)
  # Bouton texte bon préparation
  GBOUT2 = mess(229,198,1)
Endif

# Bloqueo STD
GPE=1
End


######################################################################################
$CHARGE_ITU
# Identifico moficicaciones con #@patchYS009
# Chargement des zones à saisir
## If [M:ITU]NBITU > 0 #pour effacer le bloc droite après suppr. ligne(22/12/99)
#MAE, le 08/10/08, ajout client
 [M:ITU]XBPCNUM            = [M:ITU]BPCNUM(NOL)
 [M:ITU]XITMREFBPC         = [M:ITU]ITMREFBPC(NOL)
 [M:ITU]XITMDESBPC         = [M:ITU]ITMDESBPC(NOL)
 If [M:ITU]ISAU(NOL)=""
    [M:ITU]ISAU(NOL)=[M:ITM3]SAU
    [M:ITU]ISAUSTUCOE(NOL)=[M:ITM3]SAUSTUCOE
 Endif
 [M:ITU]XSAU               = [M:ITU]ISAU(NOL)
 [M:ITU]XSAUSTUCOE         = [M:ITU]ISAUSTUCOE(NOL)
 If [M:ITU]XSAU=[M:ITM3]STU
    Diszo [M]XSAUSTUCOE
 Else
    Actzo [M]XSAUSTUCOE
 Endif
 [M:ITU]XPCU1              = [M:ITU]PCU1(NOL)
 [M:ITU]XPCUSAUCO1         = [M:ITU]PCUSAUCOE1(NOL)
 [M:ITU]XPCU2              = [M:ITU]PCU2(NOL)
 [M:ITU]XPCUSAUCO2         = [M:ITU]PCUSAUCOE2(NOL)
 [M:ITU]XPCK               = [M:ITU]PCK(NOL)
 [M:ITU]XPCKCAP            = [M:ITU]PCKCAP(NOL)
 [M:ITU]XITSTEX            = [M:ITU]ITSTEX(NOL)
 [M:ITU]XITPTEX            = [M:ITU]ITPTEX(NOL)
 [M:ITU]WITSTEX = 2
 If [M:ITU]XITSTEX = "" [M:ITU]WITSTEX = 1 Endif
 [M:ITU]WITPTEX = 2
 If [M:ITU]XITPTEX = "" [M:ITU]WITPTEX = 1 Endif
 [M:ITU]XBETFCY            = [M:ITU]BETFCY(NOL)
 [M:ITU]XDLUBPC               = [M:ITU]DLUBPC(NOL)        #DLUBPC
 [M:ITU]ZPLANO             = [M:ITU]YZPLANO(NOL)        #@patchYS009
 [M:ITU]ZFECHA             = [M:ITU]YZFECHA(NOL)        #@patchYS009
 [M:ITU]ZREVISION          = [M:ITU]YZREVISION(NOL)     #@patchYS009

# --------------------------------------
# FGR 21/04/2015 : X3SUIVI105605 (début)
If func AFNC.ACTIV("ECC") Then
  [M:ITU]XLOAECCFLG = [M:ITU]LOAECCFLG(NOL)
Endif
# FGR 21/04/2015 : X3SUIVI105605 (fin)
# --------------------------------------
#                                       hcb dlu deb
Local Integer WDLULTI
Local Integer LCOD
Local Integer LSHL
Local Integer LUOM
Local Decimal LDLU
# Issue 113992
If dim([M:ITM2]EXYMGTCOD)>0
  LCOD = [M:ITM2]EXYMGTCOD
  LSHL = [M:ITM2]SHL
  LUOM = [M:ITM2]SHLUOM
  LDLU = [M:ITU]XDLUBPC
  Gosub CALDLULTI From SUBITM
  [M:ITU]DLULTI  = WDLULTI
  [M:ITU]XDLULTI = WDLULTI
Endif
# End issue 113992
#                                        hcb dlu fin

## Endif

#--- Bug 63896
#Affzo [ITU]10
Affzo [ITU]10,15,20,25
Affzo [ITU]35  #@patchYS009
#---
Return

