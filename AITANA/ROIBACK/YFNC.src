#<AdxTL>@(#)0.0.0.0 $Revision$ 

Funprog MENS (CODMENS, LINEA, IDIOMA)
Value Integer CODMENS
Value Integer LINEA
Value Char IDIOMA ()

Local Char MENSTXT (250)

If !clalev([F:YAST]) : Local File APLSTD [YAST] : Endif

Read [F:YAST]CLE = CODMENS; LINEA; IDIOMA
If !fstat
    MENSTXT = [F:YAST]LANMES
Endif


End MENSTXT

######################################################################################

Funprog MENS_LANCLI (CODMENS, LINEA, CLIENTE)
Value Integer CODMENS
Value Integer LINEA
Value Char CLIENTE ()

Local Char MENSTXT (250)

If !clalev([F:YBPR]) : Local File BPARTNER [YBPR] : Endif

Read [F:YBPR]BPR0 = CLIENTE
If !fstat
    MENSTXT = func MENS (CODMENS, LINEA, [F:YBPR]LAN)
Endif

#Si no he encontrado el texto lo busco en inglés (ENG)
If MENSTXT = ""
  MENSTXT = func MENS (CODMENS, LINEA, "ENG")
Endif
If MENSTXT = ""
  MENSTXT = func MENS (CODMENS, LINEA, "SPA")
Endif
End MENSTXT

######################################################################################

Funprog GETMAILBPR (TERCERO)
Value Char TERCERO()

Local Char MAIL (250)

If !clalev([F:YBPR]) : Local File BPARTNER [YBPR] : Endif
If !clalev([F:YBPA]) : Local File BPADDRESS [YBPA] : Endif

Read [F:YBPR]BPR0 = TERCERO
If !fstat
    Read [F:YBPA]BPA0 = 1; [F:YBPR]BPRNUM; [F:YBPR]BPAADD
    If !fstat
      MAIL = [F:YBPA]WEB(0)
    Endif
Endif

If MAIL = ""
  Call ERREUR(mess(21,6003,1)) From GESECRAN
  MAIL = "@"
Endif

End MAIL

######################################################################################

Funprog GETNOMUSR (USUARIO)
Value Char USUARIO ()

Local Char NOMUSR (100)

If !clalev([F:YAUS]) : Local File AUTILIS [YAUS] : Endif

Read [F:YAUS]CODUSR = USUARIO
If !fstat
  NOMUSR = [F:YAUS]NOMUSR
Endif


End NOMUSR

######################################################################################

Funprog TRAE_CAMBIO (DIV1, DIV2, FECHA)
Value Char DIV1()
Value Char DIV2()
Value Date FECHA

If !clalev([F:YTCH]) : Local File TABCHANGE [YTCH] : Endif
Local Decimal COEF

Filter [F:YTCH] Where CUR = DIV1 and CURDEN = DIV2 and CHGSTRDAT <= FECHA Order By CHGSTRDAT Desc
Read [F:YTCH] First
If !fstat
    COEF = [F:YTCH]CHGRAT
Else
    COEF = 0
Endif

End COEF

######################################################################################

Funprog GETMAILRSP (USUARIO)
Value Char USUARIO ()

Local Char RSP (10)

If !clalev([F:YAUS]) : Local File AUTILIS [YAUS] : Endif

Read [F:YAUS]CODUSR = USUARIO
If !fstat
  RSP = [F:YAUS]CHEF (1)
Endif

End RSP

######################################################################################

Funprog MENS_LANRSPUSR (CODMENS, LINEA, USUARIO)
Value Integer CODMENS
Value Integer LINEA
Value Char USUARIO ()

Local Char MENSTXT (250)

If !clalev([F:YAUS]) : Local File AUTILIS [YAUS] : Endif

Read [F:YAUS]CODUSR = USUARIO
If !fstat
  Read [F:YAUS]CODUSR = [F:YAUS]CHEF (1)
  If !fstat
    If [F:YAUS]CCE(1) = 'FR' or [F:YAUS]CCE(1) = 'BE'
      MENSTXT = func MENS (CODMENS, LINEA, 'FRA')
    Else
      MENSTXT = func MENS (CODMENS, LINEA, 'SPA')
    Endif
  Endif
Endif

End MENSTXT

######################################################################################

Funprog NOMTER (TERCERO)
Value Char TERCERO ()

Local Char NOMTER (250)

If !clalev([F:YBPR]) : Local File BPARTNER [YBPR] : Endif

Read [F:YBPR]BPR0 = TERCERO
If !fstat
  NOMTER = [F:YBPR]BPRNAM
Endif

End NOMTER

######################################################################################

