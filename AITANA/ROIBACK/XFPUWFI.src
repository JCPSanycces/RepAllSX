#<AdxTL>@(#)0.0.0.0 $Revision$ 
##################################################
Subprog XPRUE1
Local File AWRKPARH [ZAWH]
Local File XRECWRK [ZRWK]
Local file SINVOICEV [ZSIV]
Local file CONTACT [ZCNT]
Local File FUP  [XFUP]
Local char mail(250)

INFBOX "LLEGA"
  Read [ZRWK]XRWK0 = [M:FUP]QURNUM;[M:FUP]BPC(nolign-1)
  if !fstat 
    UPDATE [ZAWH] WHERE [F:ZAWH]CODE = 'FUP' WITH [F:ZAWH]DESTIN = '"'+VIREBLC([F:ZRWK]EMAIL,1)+'"'

  Else

    FOR [XFUP] WHERE [F:XFUP]NUMEDT = [M:FUP]QURNUM & [F:XFUP]BPRFUP = [M:FUP]BPC(nolign-1)
       mail = ''
       Gosub CARGA_MAIL
       if mail <> ''
          UPDATE [ZAWH] WHERE [F:ZAWH]CODE = 'FUP' WITH [F:ZAWH]DESTIN = '"'+mail+'"'
       endif
    Next
  Endif
Close File [ZAWH],[XRWK],[ZSIV],[ZCNT],[ZFUP]

End



###################################################################################
$CARGA_MAIL
###################################################################################
local char existe(1)
existe = '0'
   
   
   Read [ZSIV]SIV0 = [F:XFUP]NUM   
   if !fstat

      if [F:ZSIV]BPAADD <> ''
         existe = '0'
         For [ZCNT] where [F:ZCNT]BPANUM = [F:ZSIV]BPCINV and  [F:ZCNT]BPAADD = [f:ZSIV]BPAADD and [F:ZCNT]CNTFNC = 13

          existe = '1'
          mail = [F:ZCNT]WEB
          break
         Next
         if existe = '0'
            For [ZCNT] where [F:ZCNT]BPANUM = [F:ZSIV]BPCINV and  [F:ZCNT]BPAADD = '' and [F:ZCNT]CNTFNC = 13


              existe = '1'
              mail = [F:ZCNT]WEB
              break
            Next
         endif
         if existe = '0'
            For [ZCNT] where [F:ZCNT]BPANUM = [F:ZSIV]BPCINV and  [F:ZCNT]BPAADD = ' ' and [F:ZCNT]CNTFNC = 13


              existe = '1'
              mail = [F:ZCNT]WEB
              break
            Next
         endif
       else
         For [ZCNT] where [F:ZCNT]BPANUM = [F:ZSIV]BPCINV and  [F:ZCNT]BPAADD = '' and [F:ZCNT]CNTFNC = 13

              existe = '1'
              mail = [F:ZCNT]WEB
              break
            Next
            if existe = '0'
            For [ZCNT] where [F:ZCNT]BPANUM = [F:ZSIV]BPCINV and  [F:ZCNT]BPAADD = ' ' and [F:ZCNT]CNTFNC = 13

              existe = '1'
              mail = [F:ZCNT]WEB
              break
            Next
         endif
       endif
   endif    
Return


