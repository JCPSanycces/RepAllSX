#<AdxTL>@(#)0.0.0.0 $Revision$
Local Integer ESTADO
Call XMLFACT("4EUR1001812V-0002155",ESTADO)

End
Subprog XMLFACT(FACTURA, ESTADO)
Value Char FACTURA
Value Integer ESTADO
Gosub DEC_VARIABLES
Gosub OPEN_FILE
Gosub DATOS_GENERALES
Gosub PROVEEDOR
Gosub CLIENTE
Gosub ESTABLECIMIENTOS
Gosub COMMENTS
Gosub REFERENCIAS
Gosub DETALLE
Gosub RESUMEN_IMPUESTOS
Gosub VENCIMIENTOS
Gosub RESUMEN_TOTALES
Gosub CLOSE_FILE
# JC.13102020.Y10FE.STR
Gosub ENVIO_FTP
# JC.13102020.Y10FE.END

End
#####################################################
$DEC_VARIABLES
If !clalev([XSIH]): Local File SINVOICE[XSIH]: Endif
If !clalev([ZSIH]): Local File SINVOICE[ZSIH]: Endif
If !clalev([XCPY]): Local File COMPANY[XCPY]: Endif
If !clalev([F:XSID]): Local File SINVOICED[XSID]:Endif
If !clalev([F:XSRH]): Local File SRETURN[XSRH]: Endif
If !clalev([F:XSDH]): Local File SDELIVERY[XSDH]: Endif
If !clalev([F:BPAC]): Local File BPADDRESS[F:BPAC]: Endif
If !clalev([F:BPR]): Local File BPARTNER[BPR]: Endif
If !clalev([F:BPAT]): Local File BPADDRESS[F:BPAT]: Endif
If !clalev([F:TCY]): Local File TABCOUNTRY[F:TCY] : Endif
If !clalev([F:TVT]) : Local File TABVAT: Endif
If !clalev([F:TRA]): Local File TABRATVAT: Endif
If !clalev([F:DUD]): Local File GACCDUDATE: Endif
If !clalev([F:TAM]): Local File TABPAM: Endif
If !clalev([F:AXX]): Local File ATEXTRA: Endif
# JC.13102020.Y10FE.STR
If !clalev([F:SIV0]): Local File SINVOICEV [F:SIV0]  : Endif
# JC.13102020.Y10FE.END


Local Char WFICHERO(200),WNOMBREFICH(50)
Local Char SEQ(3)
Return
#####################################################
$OPEN_FILE
Read [F:XSIH]SIH0=FACTURA
If fstat: ESTADO = 1: End: Endif
For X=1 To 999
  WNOMBREFICH="Factura_"+format$("D:YYYYMMDD",date$)+"_"+ctrans(time$,":","")+"_"+format$("N0:3#",X)
  If filinfo(filpath("BAVEL",WNOMBREFICH,"XML"),7)<0
    Break
  Endif
Next
Openo filpath("BAVEL",WNOMBREFICH,"XML"),0 Using [BAV]
Wrseq '<?xml version="1.0" encoding="utf-8"?>' Using [BAV]
Wrseq '<Transaction xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">' Using [BAV]
Return
#####################################################
$DATOS_GENERALES
Wrseq "<GeneralData ";                                        Using [BAV]
Wrseq 'Ref="'+[F:XSIH]NUM+'" ';                                 Using [BAV]
Case [F:XSIH]INVTYP
   When 1,3: Wrseq 'Type="FacturaComercial" ';                  Using [BAV]
   When 2,3: Wrseq 'Type="FacturaAbono" ';                      Using [BAV]
Endcase
Wrseq 'Date="'+format$("D:YYYY[-]MM[-]DD",[F:XSIH]ACCDAT)+'" '; Using [BAV]
Wrseq 'Language="es-ES" ';                                      Using [BAV]
Wrseq 'Currency="'+[F:XSIH]CUR+'" ';                            Using [BAV]
Wrseq 'TaxSystemText="General" ';                               Using [BAV]
Wrseq 'OnlyArchive="false" ';                                   Using [BAV]
If [F:XSIH]ZBAVELEMI=2
  Wrseq 'PrintAsCopy="true" ';                                  Using [BAV]
Else
  Wrseq 'PrintAsCopy="false" ';                                 Using [BAV]
Endif
Wrseq "/>"                                          Using [BAV]
Return
#####################################################
$PROVEEDOR
Read [F:XCPY]CPY0=[F:XSIH]CPY
Wrseq "<Supplier ";                                           Using [BAV]
Wrseq 'CIF="'+[F:XCPY]CRN+'" ';                                  Using [BAV]
#Wrseq 'Company="'+[F:XCPY]CPYNAM+'" ';                           Using [BAV]
Wrseq 'Company="'+"GLOBAL OBI SL - ROIBACK"+'" ';                           Using [BAV]
Read [F:BPAC]BPA0=2;[F:XSIH]CPY;[F:XCPY]BPAADD
If fstat: Raz [F:BPAC]: Endif
#Wrseq 'Address="'+[F:BPAC]BPAADDLIG+'" ';                       Using [BAV]
Wrseq 'Address="'+"C/Porto Pi, 8 Edificio Reina Constanza Baios"+'" ';                       Using [BAV]
Wrseq 'City="'+[F:BPAC]CTY+'" ';                                Using [BAV]
Wrseq 'PC="'+[F:BPAC]POSCOD+'" ';                               Using [BAV]
#Wrseq 'Province="'+[F:BPAC]SAT+'" ';                            Using [BAV]
Wrseq 'Province="'+"Baleares"+'" ';                            Using [BAV]
Wrseq 'Country="ESP" ';                                           Using [BAV]
Wrseq 'Email="clientes@roiback.com" '                  Using [BAV]
Wrseq "<PhoneNumbers>"                                 Using [BAV]
Wrseq "<PhoneNumber ";                                 Using [BAV]
Wrseq 'Number="971406149" '                            Using [BAV]
Wrseq "</PhoneNumbers>"                                Using [BAV]
Wrseq "/>"                                             Using [BAV]
Return
#####################################################
$CLIENTE

Wrseq "<Client ";                                             Using [BAV]
Wrseq 'SupplierClientID="'+[F:XSIH]BPR+'" ';                     Using [BAV]
Read [F:BPR]BPR0=[F:XSIH]BPR
If [F:BPR]CRN<>""
Wrseq 'CIF="'+[F:BPR]CRN+'" ';                                  Using [BAV]
Else
Wrseq 'CIF="'+[F:BPR]EECNUM+'" ';                               Using [BAV]
Endif
Wrseq 'Company="'+[F:BPR]BPRNAM+'" ';                           Using [BAV]
Read [F:BPAT]BPA0=1;[F:XSIH]BPR;[F:XSIH]BPAINV
Wrseq 'Address="'+[F:XSIH]BPAADDLIG(2)+'" ';                     Using [BAV]
Wrseq 'City="'+[F:XSIH]CTY+'" ';                                 Using [BAV]
Wrseq 'PC="'+[F:XSIH]POSCOD+'" ';                                Using [BAV]
Wrseq 'Province="'+[F:XSIH]SAT+'" ';                             Using [BAV]
Read [TCY]TCY0=[F:XSIH]CRY
Wrseq 'Country="'+[F:TCY]ISOA3+'" ';                            Using [BAV]
Wrseq 'Email="'+[F:BPAT]WEB+'" ';                               Using [BAV]
Wrseq 'IsPublicAdministration="false" ';                          Using [BAV]
Wrseq 'B2C="false" ';                                            Using [BAV]
Wrseq "/>"                                               Using [BAV]
Return
#####################################################
$ESTABLECIMIENTOS
Wrseq "<Customers>"                                             Using [BAV]
Wrseq "<Customer ";                                            Using [BAV]
Wrseq 'SupplierClientID="'+[F:XSIH]BPR+'" ';                     Using [BAV]
Wrseq 'SupplierCustomerID="'+[F:XSIH]BPR+'" ';                   Using [BAV]
Wrseq 'Customer="'+[F:BPAT]BPADES+'" ';                          Using [BAV]
Wrseq 'Address="'+[F:XSIH]BPAADDLIG+'" ';                        Using [BAV]
Wrseq 'City="'+[F:XSIH]CTY+'" ';                                 Using [BAV]
Wrseq 'PC="'+[F:XSIH]POSCOD+'" ';                                Using [BAV]
Wrseq 'Province="'+[F:XSIH]SAT+'" ';                             Using [BAV]
Read [TCY]TCY0=[F:XSIH]CRY
Wrseq 'Country="'+[F:TCY]ISOA3+'" ';                            Using [BAV]
Wrseq 'Email="'+[F:BPAT]WEB+'" ';                               Using [BAV]
Wrseq "/> "                                           Using [BAV]
Wrseq "</Customers>"                                            Using [BAV]
Return
#####################################################
$COMMENTS
Wrseq "<Comments>"                                              Using [BAV]
If [F:XSIH]VAC<>"NAC"
Wrseq "<Commnet ";                                              Using [BAV]
Wrseq 'Subject="'+"EXIVA"+'" ';                                  Using [BAV]
Wrseq 'Msg="'+"exonerado de IVA, según el código general de impuestos"+'" ';                         Using [BAV]
Wrseq "/>"                                                      Using [BAV]
Endif

# JC.13102020.Y10FE.STR
Local Char  LYOGESTION(250)
If !clalev([F:BPD0]) Then : Local File BPDLVCUST [F:BPD0] : Endif
If GUSER="AIT07" Then
  Infbox [F:SIV0]BPCINV
  Infbox [F:SIV0]BPAADD
Endif
Read [F:BPD0]BPD0 = [F:SIV0]BPCINV;[F:SIV0]BPAADD
If !fstat Then
  LYOGESTION = [F:BPD0]YOGESTION
Endif
Close Local File [BPD0]
Wrseq "<Comment ";                                              Using [BAV]
Wrseq 'Subject="'+"RoleTypeCode"+'" ';                          Using [BAV]
Wrseq 'Msg="'+"02"+'" ';                                        Using [BAV]
Wrseq "/>" Using [BAV]
Wrseq "<Comment ";                                              Using [BAV]
Wrseq 'Subject="'+"CentreCode"+'" ';                            Using [BAV]
Wrseq 'Msg="'+LYOGESTION+'" ';                                  Using [BAV]
Wrseq "/>" Using [BAV]

If [F:SIV0]INVREF <> "" Then
Wrseq "<Comment ";                                              Using [BAV]
Wrseq 'Subject="'+"RecieverTransactionLine"+'" ';               Using [BAV]
Wrseq 'Msg="'+[F:SIV0]INVREF+'" ';                              Using [BAV]
Wrseq "/>" Using [BAV]
Endif
# JC.13102020.Y10FE.END

Wrseq "<Commnet ";                                              Using [BAV]
Wrseq 'Subject="'+"Pie de página"+'" ';                                  Using [BAV]
Wrseq 'Msg="'+"Phone: +34971406149 | Fax: +34971702449 | Website: www.roiback.com | VAT: ESB57667586 | Reg: GLOBAL OBI, S.L.U."
& +"Código SWIFT/BIC IBAN R.M. Palma de Mallorca. Folio 208. Tomo 2437. Libro 0. Hoja: PM-66441. Inscripción: 1ª"
& +'" ';                         Using [BAV]
Wrseq "/>"                         Using [BAV]

Wrseq "<Commnet ";                                              Using [BAV]
Wrseq 'Subject="'+"Texto Legal"+'" ';                                  Using [BAV]
Wrseq 'Msg="'+"De conformidad con lo que establece la Ley Orgánica 15/1999 de Protección de Datos de Carácter Personal, le informamos que sus datos personales serán"
&+" incluidos dentro de un fichero automatizado bajo la responsabilidad de GLOBAL OBI, SL, con la finalidad de poder atender los compromisos derivados de la relación"
&+" que mantenemos con usted. Puede ejercer sus derechos de acceso, cancelaci ón, rectificación y oposición mediante un escrito a la dirección C/ Porto Pi, 8 Palma de"
&+" Mallorca 07015-Palma de Mallorca. Si en el plazo de 30 días no nos comunica lo contrario, entenderemos que los datos no han sido modificados, que se compromete a"
&+" notificarnos cualquier variación y que tenemos el consentimiento para utilizarlos a fin de poder fidelizar la relación entre las partes."
&+'" ';                         Using [BAV]
Wrseq "/>"                         Using [BAV]

Wrseq "</Comments>"                                             Using [BAV]
Return
#####################################################
$REFERENCIAS
Wrseq "<References>  " Using [BAV]
For [F:XSID] Where NUM=[F:XSIH]NUM
Wrseq "<Reference ";                                            Using [BAV]
If [F:XSIH]INVTYP=1 or [F:XSIH]INVTYP=3 ## Factura
Wrseq 'DNRef="';                                                  Using [BAV]
If [F:XSID]SDHNUM<>""
  Read [F:XSDH]SDH0=[F:XSID]SDHNUM
  Wrseq [F:XSID]SDHNUM+'" ';                                        Using [BAV]
  Wrseq 'DNRefDate="'+format$("D:YYYY[-]MM[-]DD",[F:XSDH]DLVDAT)+'" '; Using [BAV]
  Wrseq 'PORef="'+[F:XSDH]SOHNUM+'" '; Using [BAV]
Else
  Wrseq [F:SIH]NUM+'" ';                                            Using [BAV]
  Wrseq 'DNRefDate="'+format$("D:YYYY[-]MM[-]DD",[F:XSIH]ACCDAT)+'" '; Using [BAV]
Endif
Else
Wrseq 'DNRef="'                                                     Using [BAV]
If [F:XSID]SRHNUM<>""
  Read [F:XSRH]SRH0=[F:XSID]SRHNUM
  Wrseq [F:XSRH]SRHNUM+'" ';                                      Using [BAV]
  Wrseq 'DNRefDate="'+format$("D:YYYY[-]MM[-]DD",[F:XSRH]DLVDAT)+'" '; Using [BAV]
Else
  Wrseq [F:XSID]SIHORINUM+'" ';                                  Using [BAV]
  Read [F:ZSIH]SIH0=[F:XSID]SIHORINUM
  Wrseq 'DNRefDate="'+format$("D:YYYY[-]MM[-]DD",[F:ZSIH]ACCDAT)+'" '; Using [BAV]
Endif
Endif
Wrseq "/> "                                           Using [BAV]
Next
Wrseq "</References>" Using [BAV]
Return
#####################################################
$DETALLE
Wrseq "<ProductList>  " Using [BAV]
For [F:XSID] Where NUM=[F:XSIH]NUM
Wrseq "<Product "; Using [BAV]
Wrseq 'SupplierSKU="'+[F:XSID]ITMREF+'" ';                Using [BAV]
Wrseq 'Item="'+[F:XSID]ITMDES+'" ';                       Using [BAV]
Wrseq 'Qty="'+num$([F:XSID]QTY)+'" ';                     Using [BAV]
Wrseq 'MU="Unidades" ';                                    Using [BAV]
Wrseq 'UP="'+num$([F:XSID]GROPRI)+'" ';                   Using [BAV]
Wrseq 'Total="'+num$(ar2([F:XSID]QTY*[F:XSID]GROPRI))+'" ';    Using [BAV]
Wrseq 'NetAmount="'+num$([F:XSID]AMTNOTLIN)+'">'           Using [BAV]
Wrseq "<Taxes>" Using [BAV]
Wrseq "<Tax "; Using [BAV]
Wrseq 'Type="IVA" '; Using [BAV]
Wrseq 'Base="'+num$([F:XSID]BASTAXLIN)+'" '; Using [BAV]
Wrseq 'Rate="'+num$([F:XSID]RATTAXLIN)+'" '; Using [BAV]
Wrseq 'Amount="'+num$([F:XSID]AMTTAXLIN)+'" '; Using [BAV]
Read [F:TVT]TVT0=[F:XSID]VAT;""
Wrseq 'Description="';   Using [BAV]
Case [F:TVT]VATTYP
   When 1: Wrseq 'IVA" ';   Using [BAV]
   When 2: Wrseq 'RE" ';    Using [BAV]
   When 3: Wrseq 'IRPF" ';  Using [BAV]
Endcase
Wrseq '" '; Using [BAV]
Wrseq "/>" Using [BAV]
Wrseq "</Taxes>" Using [BAV]
Wrseq "<Remarks>"                                              Using [BAV]
Wrseq "<Remark ";                                              Using [BAV]
Wrseq 'Subject="'+"TEST"+'" ';                                  Using [BAV]
Wrseq 'Msg="'+"factura de prueba"+'" ';                         Using [BAV]
Wrseq "/>"                                                      Using [BAV]
Wrseq "</Remarks>"                                             Using [BAV]
Wrseq "</Product>  "                                       Using [BAV]
Next
Wrseq "</ProductList>" Using [BAV]
Return
#####################################################
$RESUMEN_IMPUESTOS
Wrseq "<TaxSummary>  " Using [BAV]
For X=0 To 9
If [F:XSIH]BASTAX(X)<>0
Read [F:TVT]TVT0=[F:XSIH]TAX(X);[F:XCPY]LEG
If fstat
  Read [F:TVT]TVT0=[F:XSIH]TAX(X);""
Endif
Filter [F:TRA] Where VAT=[F:XSIH]TAX(X) & LEG=[F:XCPY]LEG & CPY=[F:XCPY]CPY and STRDAT<=[F:XSIH]ACCDAT
Read [F:TRA]TRA0 Last
If fstat
  Filter [F:TRA] Where VAT=[F:XSIH]TAX(X) & LEG="" & CPY=[F:XCPY]CPY and STRDAT<=[F:XSIH]ACCDAT
  Read [F:TRA]TRA0 Last
  If fstat
    Filter [F:TRA] Where VAT=[F:XSIH]TAX(X) & LEG=[F:XCPY]LEG  & CPY="" and STRDAT<=[F:XSIH]ACCDAT
  Read [F:TRA]TRA0 Last
  Endif
Endif
Wrseq "<Tax ";     Using [BAV]
Wrseq 'Type="';   Using [BAV]
Case [F:TVT]VATTYP
   When 1: Wrseq 'IVA" ';   Using [BAV]
   When 2: Wrseq 'RE" ';    Using [BAV]
   When 3: Wrseq 'IRPF" ';  Using [BAV]
Endcase
If [F:TRA]VATEXEFLG<>2
Wrseq 'Rate="'+num$([F:TRA]VATRAT)+'" '; Using [BAV]
Else
Wrseq 'Rate="0.00" '; Using [BAV]
Endif
Wrseq 'Base="'+num$([F:XSIH]BASTAX(X))+'" '; Using [BAV]
Wrseq 'Amount="'+num$([F:XSIH]AMTTAX(X))+'" '; Using [BAV]
Read [F:AXX]AXX0="TABVAT";"DESAXX";"SPA";[F:XSIH]TAX(X);"SPA"
Wrseq 'Description="'+[F:AXX]TEXTE+'" ';        Using [BAV]
#Case [F:TVT]VATTYP
#   When 1: Wrseq 'IVA" ';  Using [BAV]
#   When 2: Wrseq 'Recargo de equivalencia" ';    Using [BAV]
#   When 3: Wrseq 'IRPF" ';  Using [BAV]
#Endcase
Wrseq "/>"     Using [BAV]
Endif
Next
Wrseq "</TaxSummary>" Using [BAV]
Return
#####################################################
$VENCIMIENTOS
Wrseq "<DueDates>  " Using [BAV]
For [F:DUD] Where NUM=[F:XSIH]NUM
Wrseq "<DueDate "; Using [BAV]
Wrseq 'Date="'+format$("D:YYYY[-]MM[-]DD",[F:DUD]DUDDAT)+'" '; Using [BAV]
Wrseq 'Amount="'+num$([F:DUD]AMTCUR)+'" ';    Using [BAV]
Read [TAM]TAM0=[F:DUD]PAM;[F:XCPY]LEG
If fstat
  Read [TAM]TAM0=[F:DUD]PAM;""
Endif
Wrseq 'PaymentID="'+"Otros"+'" '; Using [BAV]
Wrseq "/>  " Using [BAV]
Next
Wrseq "</DueDates>" Using [BAV]
Return
#####################################################
$RESUMEN_TOTALES
Wrseq "<TotalSummary "; Using [BAV]
Wrseq 'SubTotal="'+num$([F:XSIH]AMTNOT)+'" '; Using [BAV]
Wrseq 'Tax="'+num$([F:XSIH]AMTTAX)+'" '; Using [BAV]
Wrseq 'Total="'+num$([F:XSIH]AMTATI)+'" '; Using [BAV]
Wrseq "/>" Using [BAV]
Wrseq "</Transaction>" Using [BAV]
Return
#####################################################
$CLOSE_FILE
Openo Using [BAV]
Return
#####################################################

######################################################
# JC.13102020.Y10FE.STR
$ENVIO_FTP

Local Char PFICHERO(250)            : PFICHERO = WNOMBREFICH
Local Char PDIRECTORIO_DESTINO(250) : PDIRECTORIO_DESTINO = "/envio/facturae_3.2.1/"

Local Char ORIGEN_DOSSIER(250)
Local Char FICHERO_CSV(250)
Local Char FICHERO_CFG(250)
Local Char FICHERO_BAT(250)
Local Char CURRDATETIME_STR(250)
Local Char ORIGEN_DOSSIER(250)
Local Char ORIGEN(250)

Local Char LHOST(250)   : LHOST   = "webconnect.seresnet.com"
Local Char LPUERTO(250) : LPUERTO = "21"
Local Char LLOGIN(250)  : LLOGIN  = "ftp4692"
Local Char LPASS(250)   : LPASS   = "Y9NwBYkX"

Local Integer STAT : STAT=1
Local Char    RES(250)

  ORIGEN_DOSSIER=filpath("","","",[S]nomap(0),"") # Ruta del actual DOSSIER

  CURRDATETIME_STR=format$("D:YYYYMMDDhhmmss",datetime$)

  FICHERO_BAT = "ficherobat"
  FICHERO_CFG = PFICHERO

  # borrado de fichero .bat
  Local Integer RETURN_STATUS
  Local Char LFILES(100)(1..)
  RETURN_STATUS = Delfile(ORIGEN_DOSSIER + "\IMPEXP\TRC\XML\" + FICHERO_BAT + ".bat")
  Call SYSTEME2(adxmac(0),ORIGEN_DOSSIER + "\IMPEXP\TRC\XML\" + FICHERO_BAT + ".bat","",STAT,LFILES) From ORDSYS


  ###### envío del fichero #####
  # Creacion de fichero BAT
  Openo filpath("IMPEXP\TRC\XML",FICHERO_BAT, "bat",nomap)
  adxifs=';'
  adxirs = chr$(13) + chr$(10)
  adxium =  50

  # CBG 03/09/2020-Se añade el parametro /hostkey=* para reconocer el host y no preguntar OS-592
  Wrseq '"C:\Program Files (x86)\WinSCP\WinSCP.com" /hostkey=* /command "option batch continue" "option confirm off" "open ftp://' + LLOGIN + ':' + LPASS  + '@' + LHOST + ':' + LPUERTO + '" "cd ' +
& PDIRECTORIO_DESTINO + '" "put ' + filpath("SERES",PFICHERO, "xml",nomap) + '" "exit"  "/log=' + filpath("SERES",PFICHERO, "log",nomap) + '" '

  Openo

  System CHAINE= filpath("IMPEXP\TRC\XML",FICHERO_BAT, "bat",nomap)

  # comprobar si se ha realizado el envío
  STAT = func COMPRUEBA_ENVIO(filpath("SERES",PFICHERO, "log",nomap))
  If STAT = 0 Then
    # mover fichero a la carpeta de errores
    DESTINO = ORIGEN_DOSSIER+"\SERES\TRAZA_DE_ERRORES\"# + PFICHERO+".xml"
    ORIGEN  = ORIGEN_DOSSIER+"\SERES\"+PFICHERO+".xml"
    Call MOVE (ORIGEN,DESTINO,STAT) From ORDSYS
    DESTINO = ORIGEN_DOSSIER+"\SERES\TRAZA_DE_ERRORES\"# + PFICHERO+".log"
    ORIGEN  = ORIGEN_DOSSIER+"\SERES\"+PFICHERO+".log"
    Call MOVE (ORIGEN,DESTINO,STAT) From ORDSYS
    Call ERREUR("No se ha podido enviar el fichero XML") From GESECRAN
  Else
    # mover fichero a la carpeta enviados correctamente
    DESTINO = ORIGEN_DOSSIER+"\SERES\FACTURAS_ENVIADAS\"# + PFICHERO+".xml"
    ORIGEN  = ORIGEN_DOSSIER+"\SERES\"+PFICHERO+".xml"
    Call MOVE (ORIGEN,DESTINO,STAT) From ORDSYS
    DESTINO = ORIGEN_DOSSIER+"\SERES\FACTURAS_ENVIADAS\"# + PFICHERO+".log"
    ORIGEN  = ORIGEN_DOSSIER+"\SERES\"+PFICHERO+".log"
    Call MOVE (ORIGEN,DESTINO,STAT) From ORDSYS
    Call MESSAGE("Envío finalizado correctamente") From GESECRAN
  Endif

Return

########################################################
Funprog COMPRUEBA_ENVIO(PFILENAME)
Value Char PFILENAME

Local Char    SEARCH_WORD(50) : SEARCH_WORD = "226 Transfer complete"
Local Integer OCCURRENCES,I,K
Local Clbfile RESBODY

  adxifs = chr$(13)+chr$(10)
  Openi PFILENAME Using [ZREST]
  K = len(SEARCH_WORD)
  I = 1-K
  OCCURRENCES = -1
  Repeat
    Rdseq RESBODY Using [ZREST]
    I = instr(I+K, RESBODY, SEARCH_WORD)
    OCCURRENCES += 1
  Until I <> 0

  Openi

End OCCURRENCES
# JC.13102020.Y10FE.END

