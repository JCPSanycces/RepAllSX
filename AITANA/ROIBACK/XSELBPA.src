#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "SEL_TABLE"      : Gosub SEL_TABLE
#  When "VERF_TABLE"     : Gosub VERF_TABLE
  When Default
Endcase
Return

$SEL_TABLE
 # Infbox TABLE
  Case TABLE
    When "XSELBPA"    : Gosub S_XSELBPDITM
  Endcase

Return

$S_XSELBPDITM
#Infbox ("entra")
If clalev([F:BPD])= 0: Local File BPDLVCUST[BPD]:Endif

Default File [F:BPD]
TIT(0) = "Seleccion"
START = "BPAADD"
CODFIC = "BPD"


CRITERE(1) += 'BPCNUM="'+PARAM(1)+'"'
NBCOL += 1 : COL(NBCOL) = "BPAADD" : TIT(NBCOL)= "Cliente entrega"
NBCOL += 1 : COL(NBCOL) = "BPCNUM" : TIT(NBCOL)= "Cliente"

Return

