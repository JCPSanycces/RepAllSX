#----------------------------------------------------------------------------
Subprog ZMELADX(FICH, FROMM, TTO, SUBJECT,TEXTO,FFIC)
Value Char FICH, FROMM, TTO, SUBJECT, TEXTO,FFIC

Local Char    FICHIER(GDIMFIC), ORDSYS(250)
Local Char    SERMES(50)
Local Integer STAT
Call PARAM("","SERMES",SERMES) From ADOVAL

FICHIER = filpath("tmp",FICH,"txt",0)
Openo FICHIER,0 Using [MES]
Iomode adxifs "" Using [MES]
Iomode adxirs chr$(10) Using [MES]
Iomode adxium GASCII Using [MES]

Wrseq "From: ";FROMM Using [MES]
Wrseq "To: ";TTO Using [MES]
#Wrseq "CCO: mariajose.juarez@roiback.com" Using [MES]
#Wrseq "CC: ";CC Using [MES]
If SUBJECT="ENVÍO DE FACTURA / SEND INVOICE ROIBACK"
#FROMM = 'asotelo@quonext.com'
Wrseq "CC:  ";FROMM Using [MES]
Endif

SUBJECT = format$("KTv2:250X",SUBJECT)
If SUBJECT  <>""
Wrseq "Subject: ";ctrans(SUBJECT) Using [MES]
Endif

Wrseq Using [MES]
Iomode adxium GUTF8 Using [MES]

Gosub TEXTOS
Wrseq Using [MES]
For JJ = 0 To dim(FFIC)-1
    If FFIC(JJ)<>''
        Local Char WPIECE,WSUF
        Local Char    FICHIER2(GDIMFIC)
        WPIECE=FFIC(JJ)
        If WPIECE = 'XLOCCLIBREV' Then
          WSUF='xls'
        Else
          WSUF='pdf'
        Endif
#        If GFONCTION="GESFRM" or GFONCTION="FUNAUTINVD"
           # FICHIER2 = filpath("PDF/AUT",WPIECE,WSUF)
            FICHIER2= filpath("ZPDF",WPIECE,WSUF)
#        Endif

        Wrseq '# Application/pdf ; name="';WPIECE+"."+WSUF;'"'; Using [MES]
        Wrseq '['+WPIECE+"."+WSUF+'] '; Using [MES]
        Wrseq ' "';FICHIER2;'"' Using [MES]
    Endif
Next
Openo Using [MES]

ORDSYS = "meladx -r clientes@roiback.com -s"-SERMES-"<"+FICHIER
#ORDSYS = "meladx -r santitarragona@leds-c4.com -s"-SERMES-"<"+FICHIER
#ORDSYS = "meladx -s"-SERMES-"<"+FICHIER


Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS

End
$TEXTOS
For KK = 0 To dim(TEXTO)-1
    If KK<3
        Wrseq TEXTO(KK); Using [MES]
        Wrseq Using [MES]
    Else
        If TEXTO(KK)='' and TEXTO(KK-1)='' and TEXTO(KK-2)=''
        Else
            Wrseq TEXTO(KK); Using [MES]
            Wrseq Using [MES]
        Endif
    Endif
Next
Return

