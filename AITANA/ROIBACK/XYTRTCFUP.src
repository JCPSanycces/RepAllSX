$ACTION

Case ACTION
  When "AV_CHOIX"      : Gosub AV_CHOIX

#  When "OK"         : Gosub OK
  When Default
Endcase
Return

$AV_CHOIX
Local Char FILTRO(250)
Local Integer CORREOS

If [M:FUP]QURNUM <> ''
#      Filtro = "select count(*) from TMPFUP2 where NUMREQ_0 = '"+[M:FUP]QURNUM+"'"
       FILTRO = "select count(distinct (c.BPCINV_0+c.BPAADD_0)) from x3v9."+nomap+".TMPFUP2 a join x3v9."+nomap+".GACCDUDATE b on a.NUMDUD_0 = b.NUMDUD_0 join x3v9."+nomap+
&               ".SINVOICEV c on b.NUM_0 = c.NUM_0 where NUMREQ_0 ='"+[M:FUP]QURNUM+"' and a.SEL_0 = '2'"

      For (Integer CORREOS) From "S" Sql FILTRO As [XXX]
        [M:FUP]NBM =[F:XXX]CORREOS
        Affzo [M:FUP]NBM
      Next

Endif

#infbox action - "XYTRTCFUP"-num$([M:FUP]NBM)-"ñññ"-[M:FUP]QURNUM-"numero"-num$(correos)

Return

