Subprog IB_NBR
End

Subprog AS_NBR
If [M]ZVCRTYP(nolign-1)="" and left$(GUSER,1)="S"
mkstat=2
Endif

If GREP<>""
 Raz GBOUT3
 Raz GBOUT4
 Raz GBOUT5
Endif
 If [M]FLGPCT(nolign-1) <> "117":Raz GBOUT5: Endif
End


######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla EXSBLB) 17/01/2020 10:15:19 (ADMIN)
######################################################################################
Subprog CL_ZPDF(VALEUR)
Variable Char    VALEUR()
End

$TR_OK_BLB
Trbegin [BEXP]
# SAM 100682
  Readlock [BEXP]BEXP0 = [M:EXS0]ACCNUM(nolign-1)
  If fstat=1
   GOK=-1 : GLOCK="$BLOBEXPENSES"-[M:EXS0]CLB-num$(DDAT)-NUM([M:EXS0]ACCNUM(nolign-1))
  Elsif fstat=0
   [F:BEXP]BLOB   = XXX
   [F:BEXP]ZPDF =2
   Rewrite [BEXP]
   If fstat
    GOK=0 : Call FSTA("BEXP") From GLOCK
   Endif
  Elsif fstat
   Raz [F:BEXP]
   [F:BEXP]CLB    = [M:EXS0]CLB
   [F:BEXP]DATEXS = DDAT
   [F:BEXP]ACCNUM = [M:EXS0]ACCNUM(nolign-1)
   [F:BEXP]BLOB   = XXX
   [F:BEXP]ZPDF =2
   Write [BEXP]
   If fstat
    GOK = 0 : Call FSTA("BEXP") From GLOCK
   Endif
  Endif
  If GOK<0   : Goto ROLL_TR_OK_BLB
  Elsif !GOK : Goto AB_TR_OK_BLB
  Endif
Commit
Return
######################################################################################
$ROLL_TR_OK_BLB
Rollback
Call ROLL From GLOCK
If GROLL
 Return
Else
 Goto TR_OK_BLB
Endif
Return

$AB_TR_OK_BLB
Rollback
Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla EXS0) 20/01/2020 01:11:58 (ADMIN)
######################################################################################
Subprog B4_NBR
Local Char FICPATCH(100)
Local Integer STAT
Local Char    WFICHIER (GDIMFIC) , WFICCLI(GDIMFIC) , URL(10)
Call COPSRV(WFICCLI,WFICHIER,STAT) From ORDSYS
If WFICCLI="": End: Endif
Openi WFICHIER Using [A__]
Local Date DDAT
DDAT = [M:EXS0]DATEXS
Local Blbfile XXX(9)

If !clalev([F:BEXP])  : Local File BLOBEXPENSES [BEXP]  : Endif
Getseq 1,XXX Using [A__]
Openi Using [A__]
Gosub TR_OK_BLB


 Look [BEXP]BEXP0=[M]ACCNUM(nolign-1)
 If !fstat
  [M]FLGPCT(nolign-1) = "117"
 Else
  [M]FLGPCT(nolign-1) = ""
 Endif
 Affzo [M]FLGPCT(nolign-1)

End


