# Gestión de la máscara EXS0 (Especifico) - MRR
######################################################################################
## Etiqueta añadida por el supervisor (pantalla EXS0) 23/09/2019 18:06:45 (ADMIN)
######################################################################################
$ACTION
#Infbox ACTION
Case ACTION
 When "OUVRE"          :    Gosub OUVRE
 When "LIENS"          :    Gosub LIENS
 When "SETBOUT"        :    Gosub SETBOUT
 When "EXEBOUT"        :    Gosub EXEBOUT
 When "FIN_ACTION"     :    #Gosub FIN_ACTION
 When "STYLE"          :    #Gosub STYLE
 When "SEL_TABLE"      :    Gosub SEL_TABLE
 When "AV_CHOIX"       :    #Gosub AV_CHOIX
 When Default
Endcase
Return

######################################################################################
$OUVRE
If !clalev([F:EXS1])   : Local File EXPENSES[EXS1]    : Endif
If !clalev([BEXP1]): Local File BLOBEXPENSES: Endif
Return

######################################################################################
$LIENS


Return

$SETBOUT
If dim(GMODX)>0
 If GMODX=2
  Call VIREBOUT(CHAINE,"M") From GOBJET
 Endif
Endif
Return
######################################################################################
$EXEBOUT
Local Integer I

If BOUT = 'Z' Then   #mostrar contabilizadas
 If !clalev([BEXP1]): Local File BLOBEXPENSES[BEXP1]: Endif
 Raz I
 Filter [F:EXS1] Where CLB = [M:EXS0]CLB and DATEXS >= [M:EXS0]DATDEB and DATEXS <= [M:EXS0]DATFIN and STA = 3
 Read [F:EXS1] First
 If !fstat Then
  Gosub BORRA_LINEAS
  [M:EXS0]NBR=0
  Affzo [M:EXS0]
  For [F:EXS1]
    Gosub RELLENA_LINEAS
    Gosub BLOQUEAR_CAMPOS
    I += 1
  Next
 Endif
 [M:EXS0]NBR = I
 Affzo [M:EXS0]
 Global Integer GMODX
 GMODX=2: Gosub SETBOUT
Endif

If BOUT = 'Y'  Then  #mostrar no contabilizadas
 If !clalev([BEXP1]): Local File BLOBEXPENSES[BEXP1]: Endif
 Raz I
 Filter [F:EXS1] Where CLB = [M:EXS0]CLB and DATEXS >= [M:EXS0]DATDEB and DATEXS <= [M:EXS0]DATFIN and STA <> 3
 Read [F:EXS1] First
 If !fstat Then
  #Gosub BORRA_LINEAS
  [M:EXS0]NBR=0
  Affzo [M:EXS0]
  For [F:EXS1]
    Gosub RELLENA_LINEAS
    #If left$(GUSER,2) = 'S0' Then
      Gosub BLOQUEAR_CAMPOS
#    Else
#      Gosub DESBLOQUEAR_CAMPOS
#    Endif
    I += 1
  Next
 Endif
 [M:EXS0]NBR = I
 Affzo [M:EXS0]
 Global Integer GMODX
 GMODX=2:  Gosub SETBOUT
Endif
If BOUT = '1'
 If !clalev([BEXP1]): Local File BLOBEXPENSES[BEXP1]: Endif
 Raz I
 Filter [F:EXS1] Where CLB = [M:EXS0]CLB and DATEXS >= [M:EXS0]DATDEB and DATEXS <= [M:EXS0]DATFIN
 Read [F:EXS1] First
 If !fstat Then
  #Gosub BORRA_LINEAS
  [M:EXS0]NBR=0
  Affzo [M:EXS0]
  For [F:EXS1]
    Gosub RELLENA_LINEAS
      Gosub DESBLOQUEAR_CAMPOS
    I += 1
  Next
 Endif
 [M:EXS0]NBR = I
 Affzo [M:EXS0]
 Global Integer GMODX
 GMODX=1:  Gosub SETBOUT
Endif
Affzo [M:EXS0]

Return

######################################################################################
$FIN_ACTION

If BOUT = 'B' Then
 Raz I
 Filter [F:EXS1] Where CLB = [M:EXS0]CLB and DATEXS >= [M:EXS0]DATDEB and DATEXS <= [M:EXS0]DATFIN and STA = 1
 Read  First
 If !fstat Then
  Gosub BORRA_LINEAS
  For [F:EXS1]
    Gosub RELLENA_LINEAS
    If left$(GUSER,2) = 'S0' Then
      Gosub BLOQUEAR_CAMPOS
    Else
      Gosub DESBLOQUEAR_CAMPOS
    Endif
    I += 1
  Next
 Endif
 [M:EXS0]NBR = I
Endif

Affzo [M:EXS0]

Return

######################################################################################
$STYLE # El estándar carga líneas contabilizadas y no contabilizadas. Se quiere que por defecto muestre solo las no contabilizadas

If !clalev([F:BEXP1])   : Local File BLOBEXPENSES[BEXP1]   : Endif

Raz I

Filter [F:EXS1] Where CLB = [M:EXS0]CLB and DATEXS >= [M:EXS0]DATDEB and DATEXS <= [M:EXS0]DATFIN and STA = 1
Read [F:EXS1] First
If !fstat Then
 Gosub BORRA_LINEAS
 For [F:EXS1]
    Gosub RELLENA_LINEAS
    If left$(GUSER,2) = 'S0' Then
      Gosub BLOQUEAR_CAMPOS
    Else
      Gosub DESBLOQUEAR_CAMPOS
    Endif
   I += 1
 Next
Endif
[M:EXS0]NBR = I

Affzo [M:EXS0]

#Read [F:BEXP1]BEXP0 = [F:EXS1]ACCNUM
#If !fstat
# [M:EXSB]BLOB = [F:BEXP1]BLOB
#Endif

Return

######################################################################################
$AV_CHOIX
If !clalev([F:BEXP])  : Local File BLOBEXPENSES [BEXP]  : Endif

Raz [F:BEXP]

Filter [F:BEXP] Where ACCNUM = [M:EXS0]ACCNUM(nolign-1)
Read [F:BEXP] First
If !fstat
# Infbox 'encuentra foto'
 [M:EXSB]BLOB = [F:BEXP]BLOB
Endif

Return

######################################################################################
$SEL_TABLE
Case COUZON
  When "AUS" : Gosub S_AUS
  When "GTE" : Gosub S_GTE
  When "FCY" : Gosub S_FCY
Endcase

Return

######################################################################################
$S_AUS
If !clalev([F:AUS1])    : Local File AUTILIS[AUS1]    : Endif
Local Char NOAPROBADO(20)

NOAPROBADO = 'S0NOA'

#poner o quitar critere segun si el usuario es supervisor o no
If left$(GUSER,2) = 'S0' Then
#  CRITERE(1) += "[F:AUS1]USR = '" + GUSER + "'"
  CRITERE(1) += "[F:AUS1]USR = '" + GUSER + "'" + "or [F:AUS1]USR = '" + NOAPROBADO + "'"
  NBCOL += 1 : COL(NBCOL) = "USR"    : TIT(NBCOL)= "Usuario"
  NBCOL += 1 : COL(NBCOL) = "NOMUSR" : TIT(NBCOL)= "Nombre"
Else
  NBCOL += 1 : COL(NBCOL) = "USR"    : TIT(NBCOL)= "Usuario"
  NBCOL += 1 : COL(NBCOL) = "NOMUSR" : TIT(NBCOL)= "Nombre"
Endif

TIT(0) = "Usuario"
START = "USR"
CODFIC = "AUS1"

Default File [F:AUS1]

Return

######################################################################################
$S_GTE
If !clalev([F:GTE1])    : Local File GTYPACCENT[GTE1]    : Endif

CRITERE(1) += "[F:GTE1]TYP = 'NGVIS' OR [F:GTE1]TYP = 'NGANT' OR [F:GTE1]TYP = 'NGTRA'"
NBCOL += 1 : COL(NBCOL) = "TYP"    : TIT(NBCOL)= "Tipo asiento"
NBCOL += 1 : COL(NBCOL) = "DES"    : TIT(NBCOL)= "Descripción"

TIT(0) = "Tipos de asiento"
START = "TYP"
CODFIC = "GTE1"

Default File [F:GTE1]

Return

######################################################################################
$S_FCY
If !clalev([F:FCY1])    : Local File FACILITY[FCY1]    : Endif

CRITERE(1) += "[F:FCY1]FCY <> '200'"
NBCOL += 1 : COL(NBCOL) = "FCY"      : TIT(NBCOL)= "Planta"
NBCOL += 1 : COL(NBCOL) = "FCYNAM"   : TIT(NBCOL)= "Nombre"
NBCOL += 1 : COL(NBCOL) = "FCYSHO"   : TIT(NBCOL)= "Desc. corta"

TIT(0) = "Planta"
START = "FCY"
CODFIC = "FCY1"

Default File [F:FCY1]

Return

######################################################################################
$BORRA_LINEAS
  Raz [M:EXS0]FCY
  Raz [M:EXS0]DATEXS
  Raz [M:EXS0]VCRTYP
  Raz [M:EXS0]CODEXP
  Raz [M:EXS0]AMTATI
  Raz [M:EXS0]CUR
  Raz [M:EXS0]STA
  Raz [M:EXS0]VISA
  Raz [M:EXS0]DES
  Raz [M:EXS0]NBR

Return

######################################################################################
$BLOQUEAR_CAMPOS
  Diszo [M:EXS0]FCY(I)
  Diszo [M:EXS0]DATEXS(I)
  Diszo [M:EXS0]VCRTYP(I)
  Diszo [M:EXS0]CODEXP(I)
  Diszo [M:EXS0]AMTATI(I)
  Diszo [M:EXS0]CUR(I)
  Diszo [M:EXS0]STA(I)
  Diszo [M:EXS0]DES(I)
  Diszo [M:EXS0]NBR
Return

######################################################################################
$DESBLOQUEAR_CAMPOS
  Actzo [M:EXS0]FCY(I)
  Actzo [M:EXS0]DATEXS(I)
  Actzo [M:EXS0]VCRTYP(I)
  Actzo [M:EXS0]CODEXP(I)
  Actzo [M:EXS0]AMTATI(I)
  Actzo [M:EXS0]CUR(I)
  Actzo [M:EXS0]STA(I)
  Actzo [M:EXS0]DES(I)
  Actzo [M:EXS0]NBR

Return

######################################################################################
$RELLENA_LINEAS
  [M:EXS0]FCY(I)    = [F:EXS1]FCY
  [M:EXS0]DATEXS(I) = [F:EXS1]DATEXS
  [M:EXS0]VCRTYP(I) = [F:EXS1]VCRTYP
  [M:EXS0]CODEXP(I) = [F:EXS1]CODEXP
  [M:EXS0]AMTATI(I) = [F:EXS1]AMTATI
  [M:EXS0]CUR(I)    = [F:EXS1]CUR
  Look [BEXP1]BEXP0=[F:EXS1]ACCNUM
  If !fstat :[M:EXS0]FLGPCT(I) = "306" : Endif
  [M:EXS0]STA(I)    = [F:EXS1]STA
  [M:EXS0]VISA(I)   = [F:EXS1]VISA
  [M:EXS0]DES(I)    = [F:EXS1]DES
  [M:EXS0]ACCNUM(I) = [F:EXS1]ACCNUM

Return

