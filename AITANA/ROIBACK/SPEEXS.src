######################################################################################
## Etiqueta añadida por el supervisor (pantalla EXS0) 20/01/2020 08:35:41 (ADMIN)
######################################################################################
Subprog B5_NBR
WFICHERO=filpath("BQT",[M:EXS0]CLB+format$("D:YYYYMMDD",[M:EXS0]DATEXS)+num$(nolign),"pdf")
Openo WFICHERO,0 Using [XXX]
If !clalev([F:BEXP])  : Local File BLOBEXPENSES [BEXP]  : Endif
Local Integer STAT
Read [BEXP]BEXP0 = [M:EXS0]ACCNUM(nolign-1)
If !fstat
  Putseq 1,[F:BEXP]BLOB Using [XXX]
  Openo Using [XXX]
#FIC1="C:\SAGE\APP\X3V9\folders\PROTO\tmp\Acta_LAVINIA_202001009_Soporte al arranque.pdf"
FICCLI=""
Call COPCLI(WFICHERO,FICCLI,STAT) From ORDSYS
Endif
End


