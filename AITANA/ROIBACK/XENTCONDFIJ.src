Local integer cur_ano, cur_mes, sumar,I,mes_temp
Local Date fecha_dia, fectemp
Local Char reg(250)

#adxirs = chr$(10)

cur_ano = YEAR(DATE$)
cur_mes = MONTH(DATE$)


local char xfich(250)
xfich = "C:\prueba.txt"
Trbegin
Openo "C:\SAGE\APP\X3V9\folders\PROTO\BQT\PRUEBA6.TXT", 0 Using  [XCSV]
Local File SORDERP [XSOP]
Local File SORDER  [XSOH]
For [XSOP] where XCANPER > 0 and XFECINI > [00/00/0000]


    Read [XSOH]SOH0 = [F:XSOP]SOHNUM

    if [F:XSOP]XPERIODO = 1 
       sumar = 1
    endif
    if [F:XSOP]XPERIODO = 2
       sumar = 3
    endif
    if [F:XSOP]XPERIODO = 4 
       sumar = 6
    endif
    if [F:XSOP]XPERIODO = 5 
       sumar = 12
    endif
 



   FOR I = 1 TO 12
       



        fectemp =  addmonth([XSOP]XFECINI,sumar)
        fectemp =  addmonth([XSOP]XFECINI,I)
        mes_temp = MONTH(fectemp)
        if fectemp >= [XSOP]XFECFIN
           break
	Endif
        if mes_temp = cur_mes
          	reg = ""	
		reg = "H" - ";"
		reg = reg - [F:XSOP]SALFCY
		reg = reg - ";"
		reg = reg - [F:XSOP]STOFCY
		reg = reg - ";"
                reg = reg - ""
                reg = reg - "SDN"
		reg = reg - ";"
		reg = reg - [F:XSOP]BPCORD
		reg = reg - ";"
		reg = reg - NUM$([F:XSOP]BPAADD)
		reg = reg - ";"
		reg = reg - [F:XSOH]CUR
                reg = reg - ";"
                reg = reg - num$(DATE$)
                reg = reg - ";2;;;"
		wrseq reg using [XCSV]
infbox(reg)
		reg= ""	
		reg = "L" - ";;"
		reg = reg - NUM$([F:XSOP]SOPLIN)
		reg = reg - ";"
		reg = reg - [F:XSOP]ITMREF
		reg = reg - ";"
                reg = reg - [f:XSOP]ITMDES
		reg = reg - ";"
		reg = reg - [F:XSOP]SAU
		reg = reg - ";"
		reg = reg - NUM$([F:XSOP]XCANPER)
		reg = reg - ";;;"
		wrseq reg using [XCSV]

                break
	  Endif

    Next I
Next

Openo "C:\SAGE\APP\X3V9\folders\PROTO\BQT\PRUEBA6.TXT", 0 Using  [XCSV] 
Close Local File [XSOP]
Commit


