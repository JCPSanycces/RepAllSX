#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
#infbox ACTION
Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "AV_CHOIX"      : Gosub AV_CHOIX
  When "OK"            : Gosub OK
  When "FIN"           : Gosub FIN
  When Default
Endcase
Return

$OUVRE

Local File XCLIFLTR [XFL1]

Return

$FIN

 Close Local File [XFL1]
Return


$AV_CHOIX

    Local Integer I
    Raz [M:XRCF1]
    [M:XRCF1]BPCNUM = [BPC0]BPCNUM
    [M:XRCF1]BPAADD = [M:BPC4]BPAADD(nolign-1)
    Affzo [M:XRCF1]BPCNUM
    Affzo [M:XRCF1]BPAADD

    I = 0
    For [XFL1] Where [F:XFL1]BPCNUM  = [M:XRCF1]BPCNUM & [F:XFL1]BPAADD = [M:XRCF1]BPAADD


        Effzo [M:XRCF1]XFLTCOD(I)
        Effzo [M:XRCF1]XFLTRES(I)
        Effzo [M:XRCF1]XFLTORD(I)
        [M:XRCF1]XFLTCOD(I) = [F:XFL1]XFLTCOD
        [M:XRCF1]XFLTRES(I) = [F:XFL1]XFLTRES
        [M:XRCF1]XFLTORD(I) = [F:XFL1]XFLTORD
        I +=1
    Next
    [M:XRCF1]NBLIG = I



    I = 0
    For [XFL1] Where [F:XFL1]BPCNUM  = [M:XRCF1]BPCNUM

        Effzo [M:XRCF1]CAMPO1(I)
        Effzo [M:XRCF1]CAMPO2(I)
        Effzo [M:XRCF1]CAMPO3(I)
        [M:XRCF1]CAMPO1(I) = [F:XFL1]BPCNUM
        [M:XRCF1]CAMPO2(I) = [F:XFL1]BPAADD
        [M:XRCF1]CAMPO3(I) = [F:XFL1]XFLTCOD
        I +=1
    Next
    [M:XRCF1]NBLIG2 = I
    Affzo [M:XRCF1]


Return


$OK
   Local Integer I
   Delete [XFL1]XFLT1 = [M:XRCF1]BPCNUM ; [M:XRCF1]BPAADD
   For I = 0 To [M:XRCF1]NBLIG - 1

    If [M:XRCF1]XFLTCOD(I) <> ''
     Readlock [XFL1]XFLT0 = [M:XRCF1]BPCNUM ; [M:XRCF1]BPAADD; [M:XRCF1]XFLTCOD(I)
     If fstat = 0
         [F:XFL1]XFLTCOD = [M:XRCF1]XFLTCOD(I)
         [F:XFL1]XFLTRES = [M:XRCF1]XFLTRES(I)
         [F:XFL1]XFLTORD = [M:XRCF1]XFLTORD(I)
         Rewrite [XFL1]
         Unlock [XFL1]
     Else
         [F:XFL1]BPCNUM =  [M:XRCF1]BPCNUM
         [F:XFL1]BPAADD  = [M:XRCF1]BPAADD
         [F:XFL1]XFLTCOD = [M:XRCF1]XFLTCOD(I)
         [F:XFL1]XFLTRES = [M:XRCF1]XFLTRES(I)
         [F:XFL1]XFLTORD = [M:XRCF1]XFLTORD(I)
         Write
     Endif
    Endif
   Next I
Return


######################################################################################
## Etiqueta añadida por el supervisor (pantalla XRCF1) 03/10/2016 17:23:02 (ADMIN)
######################################################################################
Subprog AM_BPCNUM(VALEUR)
Variable Char    VALEUR()
End

Subprog AM_BPAADD(VALEUR)
Variable Char    VALEUR()

    Raz [M:XRCF1]XFLTCOD,[M:XRCF1]XFLTRES,[M:XRCF1]XFLTORD
    I = 0

    For [XFL1] Where [F:XFL1]BPCNUM  = [M:XRCF1]BPCNUM & [F:XFL1]BPAADD = VALEUR


        Effzo [M:XRCF1]XFLTCOD(I)
        Effzo [M:XRCF1]XFLTRES(I)
        Effzo [M:XRCF1]XFLTORD(I)
        [M:XRCF1]XFLTCOD(I) = [F:XFL1]XFLTCOD
        [M:XRCF1]XFLTRES(I) = [F:XFL1]XFLTRES
        [M:XRCF1]XFLTORD(I) = [F:XFL1]XFLTORD
        I +=1
    Next
    [M:XRCF1]NBLIG = I
    Affzo [M:XRCF1]

End


######################################################################################


######################################################################################
## Etiqueta añadida por el supervisor (pantalla XRCF1) 03/10/2016 17:46:37 (ADMIN)
######################################################################################
Subprog S_BPAADD(VALEUR)
Variable Char    VALEUR()
End


