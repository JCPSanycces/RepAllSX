#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "OK"         : Gosub OK
  When "DEBUT"      : Gosub DEBUT
  When Default
Endcase
Return

$OUVRE

 Local File XREFACTUR  [XREF]
 Local File XREFACTUR  [XREF2] Order By [F:XREF2]BPR;[XREF2]ACCDAT;[XREF2]XNUMFAC;[XREF2]XHTLCOD;[XREF2]ITMREF;[XREF2]XREFAC
 Local File XREFACTUR  [XREF3]
 Local File XREFACTUR  [XREF4]
 Local File ITMMASTER  [XITM]
 Local File BPCUSTOMER [XBPC]
 Local File PINVOICE   [XPIH]
 Local File PINVOICED  [XPID]
 Local File PINVOICED  [XPID2]
 Local File BPSUPPLIER [XBPS]
 Local File BPDLVCUST  [XBPD]
 Local File TABCHANGE  [XTCH]

Return
###################################################################################

$DEBUT

#[M]SALFCY= ''
#[M]Mes=0
#[M]Anio=0
[M]PROC = 1
Affzo [M]SALFCY
Affzo [M]MES
Affzo [M]ANIO
Affzo [M]PROC
Return

#####################################################################################
$FIN

 Close Local File [XREF],[XREF2],[XITM],[XREF3],[XBPC],[XPIH],[XPID], [XBPS], [XBPD],[XPID2],[XREF4],[XTCH]


Return

####################################################################################
$OK

Local Char PROCESA_FACTURAS(1)

If [M]PROC = 1 Then
    PROCESA_FACTURAS = ''
    Gosub CARGA_FICHERO
    If PROCESA_FACTURAS = '1'
       Gosub GENERA_FACTURAS
    Endif


Endif

If [M]PROC = 2 Then

    Gosub GENERA_ENTREGAS

Endif



Return

##########################################################
$CARGA_FICHERO
##########################################################

Local Char DIR_IMP(250), DIR_ERR(250), DIR_OK(250), RUTA(250)
Local Char CURRFIC(250)(1..1000),PROCESO(17)
Local Integer  NUMFICS, LIN, STAT

DIR_IMP="C:\SAGE\APP\X3V9\folders\PROD\REFACTURABLES\"
DIR_OK =DIR_IMP + "OK\"

RUTA = DIR_IMP

ORDSYS = "dir " + RUTA + "\*.* /a-d /b" #
Call SYSTEME2 (adxmac(0),ORDSYS,"",NUMFICS,CURRFIC) From ORDSYS

If NUMFICS=0 or (NUMFICS=1 and left$(CURRFIC(1),5)="No se")
   MENSAJE = "Ningún fichero a procesar."
   Call ECR_TRACE(MENSAJE,0) From GESECRAN
Else
 PROCESA_FACTURAS = '1'
Call NUMERO ("XREF","","01/01/12","",PROCESO,STAT) From SUBANM
   PROCESO = num$(val(PROCESO))
   LIN = 0
   Gosub LEEFICS
Endif

Return


##########################################################
$LEEFICS
##########################################################
Local Integer STAT
    If !GSERVEUR
        Call OUVRE_TRACE("") From LECFIC
    Endif

    For A = 1 To NUMFICS
        TIT = "Fichero"-num$(A)-"de"-num$(NUMFICS)-":"-CURRFIC(A)
        Gosub TRATAFICH

        RUTA=DIR_OK
        If filinfo(RUTA,0)>0
           Call MOVE(DIR_IMP+CURRFIC(A),DIR_OK+CURRFIC(A),STAT) From ORDSYS
        Endif
        MENSAJE = "Procesado Fichero:"-CURRFIC(A)+" con éxito."

        Call ECR_TRACE(string$(70,"-"),0) From GESECRAN
        Call ECR_TRACE(MENSAJE,0) From GESECRAN
    Next

    If !GSERVEUR
        Call FERME_TRACE From LECFIC
        Call LEC_TRACE From LECFIC
    Endif
Return

$TRATAFICH

Local Char FICHX3(GDIMFIC), FICHAGN(GDIMFIC), CAMPOS(235)(100), WNUMEXPED_OLD(20), WNUMEXPED(20), WITEM
Local Integer WCONT : WCONT = 0
Local Integer WFOUND
Local Decimal WPRI
Local Char IVAEXE(5),IVANOR(5),IVARED(5), F_PROV(25), F_HOTEL(25), F_REF(50), F_FECHA(8), F_REFAC(1)
Local Char F_CANT(25), F_IMP(25), F_PLANTA(10),F_FECHA_CONT(8),F_VAT(25),F_NUMFAC(30)



FICHAGN = DIR_IMP + CURRFIC(A)



Openi FICHAGN,0 Using [XFICH]
Iomode adxifs ";" Using [XFICH]                   # SEPARACION DE CAMPOS ";"
Iomode adxirs chr$(13)+chr$(10) Using [XFICH]     # FIN DE LINEA
Iomode adxium 50 Using [XFICH]



Repeat

   Rdseq F_PROV, F_PLANTA, F_FECHA_CONT, F_HOTEL, F_REF, F_CANT, F_IMP, F_FECHA, F_REFAC, F_VAT, F_NUMFAC Using [XFICH]

   If F_PROV <> '' Then
      LIN +=1
      [F:XREF]XPROCESO = PROCESO
      [F:XREF]XLINEA = LIN
      [F:XREF]FCY = F_PLANTA
      If len(F_FECHA_CONT) = 7
         F_FECHA_CONT = "0"+F_FECHA_CONT
      Endif
      [F:XREF]ACCDAT =  gdat$(val(mid$(F_FECHA_CONT,1,2)),val(mid$(F_FECHA_CONT,3,2)),val(mid$(F_FECHA_CONT,5,4)))
      [F:XREF]BPR = F_PROV
      [F:XREF]XHTLCOD = tolower(F_HOTEL)
      [F:XREF]ITMREF = F_REF
      [F:XREF]XCANTIDAD = val(ctrans( vireblc(format$("N:15.4",F_CANT),0) ,",","."))
      [F:XREF]XFACTURADO = val(ctrans( vireblc(format$("N:15.4",F_IMP),0) ,",","."))
      [F:XREF]XIMPUESTO = val(ctrans( vireblc(format$("N:15.4",F_VAT),0) ,",","."))


      [F:XREF]XNUMFAC = F_NUMFAC
      If len(F_FECHA) = 7
         F_FECHA = "0"+F_FECHA
      Endif
      [F:XREF]XFECSERV = gdat$(val(mid$(F_FECHA,1,2)),val(mid$(F_FECHA,3,2)),val(mid$(F_FECHA,5,4)))


      [F:XREF]XREFAC = val(F_REFAC)
      If [F:XREF]XCANTIDAD < 0  | [F:XREF]XFACTURADO < 0
        [F:XREF]XREFAC = 1
      Endif


      Write[XREF]
    Endif

Until fstat<>0

Openi Using [XFICH]

Return

########################################################
$GENERA_FACTURAS
########################################################


  Local Char TODOS(1),XFICH(50),XDIR(250),XEXT(3), FICHERO(250),IMPORTA(1),LANZA(1)
  Local Date F_PRIMER_DIAMES, F_ULTIMO_DIAMES, OLD_XFECSERV, OLD_FECVTO
  Local Char GRABA(1), PRIMERA(1), IMPORTA(1), REG(250),XDESC(60),XFCY(5)
  Local Char OLD_ITMREF(50), OLD_BPR(25), OLD_HTLCOD(50), FECHA_TXT(8),XCLIENT(35),XDIRENT(15),OLD_NUMFAC(30)
  Local Integer NUM_LIN , OLD_REFAC
  Local Decimal CANTIDAD, IMPORTE, IMPORTEAI, IMPUESTO

  XDIR = "C:\SAGE\APP\X3V9\folders\PROD\BQT"
  XFICH = "FACTURAS_REF"
  XEXT = "txt"
  FICHERO      = filpath(XDIR,XFICH,XEXT,"","","")
  Openo FICHERO,0 Using [XREFFAC]
  Iomode adxirs chr$(13)+chr$(10) Using [XREFFAC]

  GRABA = '0'
  PRIMERA = '0'


  For [XREF2] Where [F:XREF2]XPROCESADO = ''
    IMPORTA = '1'
    GRABA = '1'
    If PRIMERA <> '0' and( [XREF2]ITMREF <> OLD_ITMREF | [F:XREF2]BPR <> OLD_BPR | [XREF2]XHTLCOD <> OLD_XHTLCOD | [XREF2]XREFAC <> OLD_REFAC)

      NUM_LIN +=1000

      XDESC = ''
      Read[XITM]ITM0 = OLD_ITMREF
      If !fstat
         XDESC = [F:XITM]ITMDES1
      Endif



      REG= ""
      REG = "L" + ";"
      REG = REG + "5" + ";"
      REG = REG + ";"
      REG = REG + "0;"
      REG = REG + "0;"
      REG = REG + OLD_ITMREF
      REG = REG + ";"
      REG = REG + XDESC
      REG = REG + ";"
      REG = REG + "UN"
      REG = REG + ";"
      REG = REG + ctrans( vireblc(format$("N:15.4",CANTIDAD),0) ,",",".")
      REG = REG + ";"
      #reg = reg + ctrans( vireblc(Format$("N:15.4",IMPORTE),0) ,",",".")
      REG = REG + ";"
      REG = REG + ctrans( vireblc(format$("N:15.4",IMPORTE),0) ,",",".")
      REG = REG + ";0;0;0;"
      REG = REG + OLD_XHTLCOD
      REG = REG + ";"

      FECHA_TXT = ""
      FECHA_TXT = seg$(num$(OLD_XFECSERV),1,2) +  seg$(num$(OLD_XFECSERV),4,5)
      FECHA_TXT = FECHA_TXT + seg$(num$(OLD_XFECSERV),7,10)
      REG = REG + FECHA_TXT
      REG = REG + ";"
      REG = REG + num$(OLD_REFAC)
      REG = REG + ";"

      XCLIENT = ''
      XDIRENT = ''
      XFCY = ''
      If OLD_XHTLCOD <> ''
       For [XBPD] Where [F:XBPD]XHTLCRS = OLD_XHTLCOD
         XCLIENT = [F:XBPD]BPCNUM
         XDIRENT = [F:XBPD]BPAADD
         XFCY = [F:XBPD]STOFCY
         Break
       Next
      Endif

      REG = REG + XCLIENT

      REG = REG + ";"
      REG = REG + XDIRENT
      REG = REG + ";"


      REG = REG + XFCY
      REG = REG + ";"
      REG = REG + "3"
      REG = REG + ";"
      REG = REG + ";"

      Wrseq REG Using [XREFFAC]

      For [XBPC] Where [F:XBPC]BPCNUM = XCLIENT
         Break
      Next
#      if old_refac = 2
        REG = ""
        REG = "LC"
        REG = REG +";"
        REG = REG + [F:XBPC]CCE(0)
        REG = REG + ";"
        REG = REG + [F:XBPC]CCE(1)
        REG = REG + ";"
        REG = REG + [F:XBPC]CCE(2)
        #VGOMEZ--05/12/2017
       REG = REG + ";"
       REG = REG + [F:XBPC]CCE(3)
       REG = REG + ";"
       REG = REG + [F:XBPC]CCE(4)
       REG = REG + ";"
       REG = REG + [F:XBPC]CCE(5)
        Wrseq REG Using [XREFFAC]
#      Endif



      CANTIDAD = [F:XREF2]XCANTIDAD
      IMPORTE  = [F:XREF2]XFACTURADO

     Else

      CANTIDAD = CANTIDAD + [F:XREF2]XCANTIDAD
      IMPORTE  = IMPORTE  + [F:XREF2]XFACTURADO

    Endif
    OLD_ITMREF = [F:XREF2]ITMREF
    OLD_XHTLCOD = [F:XREF2]XHTLCOD
    OLD_REFAC = [F:XREF2]XREFAC
    OLD_XFECSERV = [F:XREF2]XFECSERV

    PRIMERA = '1'

     If [F:XREF2]BPR <> OLD_BPR or [F:XREF2]ACCDAT <> OLD_FECVTO or [F:XREF2]XNUMFAC <> OLD_NUMFAC # OR [XREF2]XHTLCOD <> OLD_XHTLCOD

      OLD_BPR = [F:XREF2]BPR
      OLD_FECVTO = [F:XREF2]ACCDAT
      OLD_NUMFAC = [F:XREF2]XNUMFAC

      Read [XBPS]BPS0 = [F:XREF2]BPR

      NUM_LIN = 0

      FECHA_TXT = ""
      FECHA_TXT = seg$(num$([F:XREF2]ACCDAT),1,2) +  seg$(num$([F:XREF2]ACCDAT),4,5)
      FECHA_TXT = FECHA_TXT + seg$(num$([F:XREF2]ACCDAT),7,10)


      REG = ""
      REG = "E" + ";"
      REG = REG + [F:XREF2]FCY
      REG = REG + ";"
      REG = REG + "FAS"
      REG = REG + ";"
      REG = REG + ";"
      REG = REG + FECHA_TXT
      REG = REG + ";"
      REG = REG + [F:XREF2]BPR
      REG = REG + ";"
      REG = REG + "PR01"
      REG = REG + ";"
      REG = REG + [F:XBPS]CUR
      REG = REG + ";"
      REG = REG + "4"+";"
      REG = REG + [F:XREF2]XNUMFAC+";"
      REG = REG + FECHA_TXT

      FECHA_TXT = ""
      FECHA_TXT = seg$(num$([F:XREF2]XFECSERV),1,2) +  seg$(num$([F:XREF2]XFECSERV),4,5)
      FECHA_TXT = FECHA_TXT + seg$(num$([F:XREF2]XFECSERV),7,10)
#      reg = reg + fecha_txt

      IMPORTEAI = 0
      IMPUESTO = 0

      For [F:XREF4] Where [F:XREF4]BPR = OLD_BPR & [F:XREF4]ACCDAT = OLD_FECVTO & [F:XREF4]XNUMFAC = OLD_NUMFAC & [F:XREF4]XPROCESADO <> '1'

          IMPORTEAI = IMPORTEAI + [F:XREF4]XFACTURADO
          IMPUESTO  = IMPUESTO  + [F:XREF4]XIMPUESTO
      Next

      REG = REG + ";;"
      REG = REG + ctrans( vireblc(format$("N:15.4",IMPORTEAI),0) ,",",".")
      REG = REG + ";"
      REG = REG + ctrans( vireblc(format$("N:15.4",[F:XREF2]XIMPUESTO),0) ,",",".") + ";"

      Wrseq REG Using [XREFFAC]

     Endif
     Update [XREF3] Where [F:XREF3]XPROCESO = [F:XREF2]XPROCESO & [F:XREF3]XLINEA = [F:XREF2]XLINEA With [F:XREF3]XPROCESADO = '1'

  Next

  If GRABA = '1'

      NUM_LIN +=1000

      XDESC = ''
      Read[XITM]ITM0 = OLD_ITMREF
      If !fstat
         XDESC = [F:XITM]ITMDES1
      Endif

      REG= ""
      REG = "L" + ";"
      REG = REG + "5" + ";"
      REG = REG + ";"
      REG = REG + "0;"
      REG = REG + "0;"
      REG = REG + OLD_ITMREF
      REG = REG + ";"
      REG = REG + XDESC
      REG = REG + ";"
      REG = REG + "UN"
      REG = REG + ";"
      REG = REG + ctrans( vireblc(format$("N:15.4",CANTIDAD),0) ,",",".")
      REG = REG + ";"
      #reg = reg + ctrans( vireblc(Format$("N:15.4",IMPORTE),0) ,",",".")
      REG = REG + ";"
      REG = REG + ctrans( vireblc(format$("N:15.4",IMPORTE),0) ,",",".")
      REG = REG + ";0;0;0;"
      REG = REG + OLD_XHTLCOD
      REG = REG + ";"

      FECHA_TXT = ""
      FECHA_TXT = seg$(num$(OLD_XFECSERV),1,2) +  seg$(num$(OLD_XFECSERV),4,5)
      FECHA_TXT = FECHA_TXT + seg$(num$(OLD_XFECSERV),7,10)
      REG = REG + FECHA_TXT
      REG = REG + ";"
      REG = REG + num$(OLD_REFAC)
      REG = REG + ";"

      XCLIENT = ''
      XDIRENT = ''
      XFCY = ''

      If OLD_XHTLCOD <> ''
       For [XBPD] Where [F:XBPD]XHTLCRS = OLD_XHTLCOD
         XCLIENT = [F:XBPD]BPCNUM
         XDIRENT = [F:XBPD]BPAADD
         XFCY = [F:XBPD]STOFCY
         Break
       Next
      Endif
      REG = REG + XCLIENT

      REG = REG + ";"
      REG = REG + XDIRENT


      REG = REG +";"
      REG = REG + XFCY
      REG = REG + ";"
      REG = REG + "3"
      REG = REG + ";;"

      Wrseq REG Using [XREFFAC]


      For [XBPC] Where [F:XBPC]BPCNUM = XCLIENT
         Break
      Next
#      if old_refac = 2
         REG = ""
         REG = "LC"
         REG = REG +";"
         REG = REG + [F:XBPC]CCE(0)
         REG = REG + ";"
         REG = REG + [F:XBPC]CCE(1)
         REG = REG + ";"
         REG = REG + [F:XBPC]CCE(2)
         #VGOMEZ--05/12/2017
         REG = REG + ";"
         REG = REG + [F:XBPC]CCE(3)
         REG = REG + ";"
         REG = REG + [F:XBPC]CCE(4)
         REG = REG + ";"
         REG = REG + [F:XBPC]CCE(5)
         Wrseq REG Using [XREFFAC]
#      Endif


  Endif

  Openo Using [XREFFAC]

  If IMPORTA = '1' Then
      Call IMPORTSIL("XPIH",FICHERO) From GIMPOBJ
  Endif
Return

################################################################################
$GENERA_ENTREGAS
################################################################################
Local Char OLD_BPCNUM(25), OLD_BPAADD(10), FECHA_TXT(8),REG(250), PRIMERA(1), OLD_ITMREF(30),GRABA(1),IMPORTA(1),OLD_BPR(15)
Local Date F_ULT_DIAMES
Local Integer NUM_LIN
Local Decimal TOTAL, IMPTO_PORCEN, IMPTO_TOTAL, V_IMPORTE
Local Char COND(1), XDESC(60), XCLICUR(5), OLD_NETCUR(5)
Local Char XFICH(50),XDIR(250),XEXT(3), FICHERO(250)
Local Date F_PRIMER_DIAMES, F_ULTIMO_DIAMES, OLD_XFECSERV

  XDIR = "C:\SAGE\APP\X3V9\folders\PROD\BQT"
  XFICH = "ENTREGAS_REF"
  XEXT = "txt"
  FICHERO      = filpath(XDIR,XFICH,XEXT,"","","")
  Openo FICHERO,0 Using [XREFENT]
  Iomode adxirs chr$(13)+chr$(10) Using [XREFENT]


  FECHA_INI = gdat$(1, [M]MES, [M]ANIO)
  FECHA_FIN = eomonth(FECHA_INI)
  FECHA_TXT = ""
  FECHA_TXT = seg$(num$(FECHA_FIN),7,10) +  seg$(num$(FECHA_FIN),4,5)
  FECHA_TXT = FECHA_TXT + seg$(num$(FECHA_FIN),1,2)

     GRABA   = '0'
     PRIMERA = '0'
#infbox num$(fecha_ini)-num$(fecha_fin)-
  Link [XPIH] With [XPID]PID0 = [XPIH]NUM  As [XLINK]
&      Where
&            [XPID]XFECSERV >= FECHA_INI &
&            [XPID]XFECSERV <= FECHA_FIN &
&            [XPID]XREFAC = 2 &
&            [XPID]XHTLCOD <> '' &
&            [XPID]XPROCESADO = '' &
&            [XPID]XFCY = [M]SALFCY
&            Order By [F:XPID]XBPCNUM; [F:XPID]XBPAADD; [F:XPID]ITMREF; [F:XPID]BPR


  For [XLINK]

       IMPORTA = '1'
       GRABA = '1'

#       IF primera <> '0' and( [XPID]ITMREF <> OLD_ITMREF | [F:XPID]XBPCNUM <> OLD_BPCNUM | [F:XPID]XBPAADD <> OLD_BPAADD | [F:XPID]BPR <> OLD_BPR)
       If PRIMERA <> '0' and( [XPID]ITMREF <> OLD_ITMREF | [F:XPID]XBPCNUM <> OLD_BPCNUM | [F:XPID]XBPAADD <> OLD_BPAADD )
          NUM_LIN +=1000

                XDESC = ''
                Read[XITM]ITM0 = OLD_ITMREF
                If !fstat
                     XDESC = [F:XITM]ITMDES1
                Endif

##
                V_IMPORTE = V_IMPORTE / TOTAL
##

                REG= ""
                REG = "L" + ";"
	        REG = REG + num$(NUM_LIN)
                REG = REG + ";"
                REG = REG + ";"
	        REG = REG + ";"
	        REG = REG + OLD_ITMREF
	        REG = REG + ";"
                REG = REG + XDESC
	        REG = REG + ";"
	        REG = REG + "UN"
                REG = REG + ";"
	        REG = REG + ctrans( vireblc(format$("N:15.4",TOTAL),0) ,",",".")
	        REG = REG + ";"
                REG = REG + ctrans( vireblc(format$("N:15.4",V_IMPORTE),0) ,",",".")
                REG = REG + ";;"


	        Wrseq REG Using [XREFENT]

                XCLICUR = ''
                Read [XBPC] = [F:XPID]XBPCNUM
                XCLICUR = [F:XBPC]CUR
                Gosub CAMBIO_DIVISA
#                V_IMPORTE = [F:XPID]NETPRI
                V_IMPORTE = [F:XPID]AMTNOTLIN
                TOTAL = [F:XPID]QTYUOM

         Else
                XCLICUR = ''
                Read [XBPC] = [F:XPID]XBPCNUM
                XCLICUR = [F:XBPC]CUR
                Gosub CAMBIO_DIVISA
#                V_IMPORTE = V_IMPORTE + [F:XPID]NETPRI
                V_IMPORTE = V_IMPORTE + [F:XPID]AMTNOTLIN
                TOTAL = TOTAL + [F:XPID]QTYUOM
         Endif

         OLD_ITMREF = [F:XPID]ITMREF
         OLD_BPR = [F:XPID]BPR
         OLD_NETCUR = [F:XPID]NETCUR
         PRIMERA = '1'

         If [F:XPID]XBPCNUM <> OLD_BPCNUM or [XPID]XBPAADD <> OLD_BPAADD

            OLD_BPCNUM = [F:XPID]XBPCNUM
            OLD_BPAADD = [F:XPID]XBPAADD
            NUM_LIN = 0




                REG = ""
		REG = "H" + ";"
		REG = REG + [M]SALFCY
		REG = REG + ";"
		REG = REG + [M]SALFCY
		REG = REG + ";"
                REG = REG + ";"
                REG = REG + "REF"
		REG = REG + ";"
		REG = REG + [F:XPID]XBPCNUM
		REG = REG + ";"
		REG = REG + [F:XPID]XBPAADD
		REG = REG + ";"
		REG = REG + XCLICUR
                REG = REG + ";"
                REG = REG + FECHA_TXT
                REG = REG + ";"
                REG = REG + FECHA_TXT
                REG = REG + ";1;;;"
		Wrseq REG Using [XREFENT]

         Endif

         Update [XPID2] Where [F:XPID2]NUM = [F:XPID]NUM & [F:XPID2]PIDLIN = [F:XPID]PIDLIN With [F:XPID2]XPROCESADO = '1'

     Next
     ###### grabamos la última linea leida y no procesada.
     If GRABA = '1' Then

                NUM_LIN +=1000
                XDESC = ''
                Read[XITM]ITM0 = OLD_ITMREF
                If !fstat
                     XDESC = [F:XITM]ITMDES1
                Endif
##
                V_IMPORTE = V_IMPORTE / TOTAL
##
                REG= ""
                REG = "L" + ";"
	        REG = REG + num$(NUM_LIN)
                REG = REG + ";"
                REG = REG + ";"
	        REG = REG + ";"
	        REG = REG + OLD_ITMREF
	        REG = REG + ";"
                REG = REG + XDESC
	        REG = REG + ";"
	        REG = REG + "UN"
                REG = REG + ";"
	        REG = REG + ctrans( vireblc(format$("N:15.4",TOTAL),0) ,",",".")
	        REG = REG + ";"
                REG = REG + ctrans( vireblc(format$("N:15.4",V_IMPORTE),0) ,",",".")
                REG = REG + ";;"


	        Wrseq REG Using [XREFENT]
      Endif

Openo Using [XREFENT]

  If IMPORTA = '1' Then
      Call IMPORTSIL("XSDH2",FICHERO) From GIMPOBJ
  Endif

Return

###################################################################################
$CAMBIO_DIVISA
###################################################################################

Local Decimal CAMBIO, XDIV,XMULT


  CAMBIO = [F:XPID]NETPRI
  If XCLICUR <> [F:XPID]NETCUR Then
     XDIV = 1
     XMULT = 1
     For [XTCH] Where [F:XTCH]CHGTYP = 1 & [F:XTCH]CURDEN = [F:XPID]NETCUR & [F:XTCH]CUR = XCLICUR & [F:XTCH]CHGSTRDAT <= FECHA_FIN
          XDIV = [F:XTCH]CHGDIV
          XMULT = [F:XTCH]REVCOURS
     Next

#     [F:XPID]NETPRI = cambio / xdiv * XMULT
     [F:XPID]AMTNOTLIN = CAMBIO / XDIV * XMULT
  Endif

Return

