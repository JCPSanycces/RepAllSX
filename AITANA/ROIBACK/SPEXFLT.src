#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
#infbox ACTION
Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "AV_CHOIX"      : Gosub AV_CHOIX
  When "OK"            : Gosub OK
  When "FIN"           : Gosub FIN
  When Default
Endcase
Return

$OUVRE

Local File XCRSFLTR [XFLT]
Local File XCRSFLTRH [XFLTH]

Return

$FIN

 Close Local File [XFLT],[XFLTH]
Return


$AV_CHOIX
    
    Raz [M:XFLT1]  
 


Return


$OK
   Local integer I
   Local char graba(1)
   Delete [XFLT]XFLT0 = [M:XFLT1]XFLTCOD 
   Delete [XFLTH]XFLTH0 = [M:XFLT1]XFLTCOD
   graba = '0'
   For I = 0 to [M:XFLT1]NBLIG - 1
    

     Readlock [XFLT]XFLT0 = [M:XFLT1]XFLTCOD;I
     If fstat = 0
         [F:XFLT]XFLTLIN = I  
         [F:XFLT]XFLTCAMP = [M:XFLT1]XFLTCAMP(I)
         [F:XFLT]XFLTOPE =  [M:XFLT1]XFLTOPE(I)
         [F:XFLT]XFLTVAL =  [M:XFLT1]XFLTVAL(I)
         [F:XFLT]XFLTCOND = [M:XFLT1]XFLTCOND(I)
         Rewrite [XFLT]
         Unlock [XFLT]
     else
         [F:XFLT]XFLTCOD = [M:XFLT1]XFLTCOD
         [F:XFLT]XFLTLIN = I  
         [F:XFLT]XFLTCAMP = [M:XFLT1]XFLTCAMP(I)
         [F:XFLT]XFLTOPE =  [M:XFLT1]XFLTOPE(I)
         [F:XFLT]XFLTVAL =  [M:XFLT1]XFLTVAL(I)
         [F:XFLT]XFLTCOND = [M:XFLT1]XFLTCOND(I)
         Write [XFLT]
         graba = '1'
         
     Endif

   Next I
   if graba = '1' then
      [F:XFLTH]XFLTCOD = [M:XFLT1]XFLTCOD
      [F:XFLTH]XTIPFLT = [M:XFLT1]XTIPFLT
      Write [XFLTH]
   Endif
Return


######################################################################################
## Etiqueta añadida por el supervisor (pantalla XFLT1) 27/09/2016 16:25:57 (ADMIN)
######################################################################################
Subprog AM_XFLTCOD(VALEUR)
Variable Char    VALEUR()

Local Integer I
    
    Read [XFLTH]XFLTH0 = VALEUR
    [M:XFLT1]XTIPFLT = [F:XFLTH]XTIPFLT

    I = 0
    For [XFLT] Where [F:XFLT]XFLTCOD  = VALEUR


        Effzo [M:XFLT1]XFLTLIN(I)
        Effzo [M:XFLT1]XFLTCAMP(I)
        Effzo [M:XFLT1]XFLTOPE(I)
        Effzo [M:XFLT1]XFLTVAL(I)
        Effzo [M:XFLT1]XFLTCOND(I)
        [M:XFLT1]XFLTLIN(I) = [F:XFLT]XFLTLIN
        [M:XFLT1]XFLTCAMP(I) = [F:XFLT]XFLTCAMP
        [M:XFLT1]XFLTOPE(I) = [F:XFLT]XFLTOPE
        [M:XFLT1]XFLTVAL(I) = [F:XFLT]XFLTVAL
        [M:XFLT1]XFLTCOND(I) = [F:XFLT]XFLTCOND
        I +=1
    Next    
    [M:XFLT1]NBLIG = I
    Affzo [M:XFLT1]    
End


