#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
#infbox action

CASE ACTION
 When "OK"     Gosub   OK
 When "OUVRE"  Gosub OUVRE
 When "FIN"    Gosub FIN
 When  "DEBUT" Gosub DEBUT
 When Default

Endcase

Return


$OUVRE
 
Local File XRECCOM [XRCO]
Return

$FIN
Close File [XRCO]
Return

$DEBUT
 
     READ [XRCO] First 
     if !fstat
       [M:XRCO]XLEVFUP = [F:XRCO]XLEVFUP
     endif
Return
$OK
#Local File XRECCOM [XRCO]


     READLOCK [XRCO] First 
     IF fstat > 1
        [F:XRCO]XLEVFUP = [M:XRCO]XLEVFUP
        WRITE[XRCO]    
     ELSE 
       if fstat = 0
        [F:XRCO]XLEVFUP = [M:XRCO]XLEVFUP
        REWRITE[XRCO]

      endif
     endif
#Close File [XRCO]

Return





