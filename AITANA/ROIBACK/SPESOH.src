######################################################################################
### EMF 11/10/2016 Validamos la fecha fin contrato
######################################################################################
## Etiqueta añadida por el supervisor (pantalla SOH4) 11/10/2016 12:14:55 (ADMIN)
######################################################################################
Subprog AM_XFECFIN(VALEUR)
Variable Date    VALEUR
   if VALEUR <> [00/00/0000] & VALEUR < [M:SOH4]XFECINI then
     GERR = 1 
     GMESSAGE = mess(1,6000,1) 
     OK = 0
   endif
End


######################################################################################

### EMF 11/10/2016 Validamos la fecha fin contrato
######################################################################################
## Etiqueta añadida por el supervisor (pantalla SOH4) 11/10/2016 12:29:33 (ADMIN)
######################################################################################
Subprog AM_XFECINI(VALEUR)
Variable Date    VALEUR

 if VALEUR <> [00/00/0000] & [M:SOH4]XFECFIN <> [00/00/0000] & VALEUR > [M:SOH4]XFECFIN then
     GERR = 1 
     GMESSAGE = mess(1,6000,1) 
     OK = 0
   endif
End


