#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)9.0.0.0 $Revision$
Local Char    IDENT(30)(1..10) , MESSA(80)
Local Integer STAT
IDENT(1) = "FC"
IDENT(2) = "9710/00000050"
Call VALPCE("EXTOURNE",IDENT,STAT,MESSA)
#Error STAT;" ";MESSA
End

####################################
## Identification par les clés
####################################
Subprog VALPCE(CODE,IDENT,STAT,MESSA)
Value    Char    CODE
Value    Char    IDENT()(1..)
Variable Integer STAT
Variable Char    MESSA()
Local    Integer CAS , DIRECT , SIMUL
Local    Integer TYPVAL
Local    Char    TMESSA(250)(1..1)
CAS = 1 : DIRECT = 0 : SIMUL = 0
TYPVAL = 1
Local Integer LECGRP : LECGRP = 1
Goto PCEVAL

####################################
## Identification par un critère
####################################
Subprog VALPCE2(CODE,CRIT,STAT,MESSA)
Value    Char    CODE
Value    Char    CRIT
Variable Integer STAT
Variable Char    MESSA()
Local    Integer CAS , DIRECT , SIMUL
Local    Integer TYPVAL
Local    Char    IDENT(30)(1..3)
Local    Char    TMESSA(250)(1..1)
CAS = 2 : DIRECT = 0 : SIMUL = 0
TYPVAL = 1
Local Integer LECGRP : LECGRP = 1
Goto PCEVAL

####################################
## Avec valeurs imposées
####################################
Subprog VALPCE3(CODE,IDENT,STAT,MESSA,ZONE,VALEUR)
Value    Char    CODE
Value    Char    IDENT()(1..)
Variable Integer STAT
Variable Char    MESSA()
Value    Char    ZONE()(1..)
Value    Char    VALEUR()(1..)
Local    Integer CAS , DIRECT , SIMUL
Local    Integer TYPVAL
Local    Char    TMESSA(250)(1..1)
CAS = 1 : DIRECT = 0 : SIMUL = 0
TYPVAL = 1
Local Integer LECGRP : LECGRP = 1
Goto PCEVAL

#########################################################
## Identification par un critère avec valeurs imposées
#########################################################
Subprog VALPCE4(CODE,CRIT,STAT,MESSA,ZONE,VALEUR)
Value    Char    CODE
Value    Char    CRIT
Variable Integer STAT
Variable Char    MESSA()
Value    Char    ZONE()(1..)
Value    Char    VALEUR()(1..)
Local    Integer CAS , DIRECT , SIMUL
Local    Integer TYPVAL
Local    Char    IDENT(30)(1..3)
Local    Char    TMESSA(250)(1..1)
CAS = 2 : DIRECT = 0 : SIMUL = 0
TYPVAL = 1
Local Integer LECGRP : LECGRP = 1
Goto PCEVAL

######################################################################
## Identification par un critère avec valeurs imposées
## Passage d'un tableau de messages : Utile pour les règlements où
## X pièces peuvent être générées à chaque appel du VALPCE (OD devise)
######################################################################
Subprog VALPCE5(CODE,CRIT,GRP,GRPPCE,STAT,TMESSA,ZONE,VALEUR) : # Réservé règlements
Value    Char    CODE
Value    Char    CRIT
Value    Integer GRP
Value    Char    GRPPCE()
Variable Integer STAT
Variable Char    TMESSA()(1..)
Value    Char    ZONE()(1..)
Value    Char    VALEUR()(1..)
Local    Char    MESSA(250)
Local    Integer CAS , DIRECT , SIMUL
Local    Integer TYPVAL
Local    Char    IDENT(30)(1..3)
CAS = 2 : DIRECT = 0 : SIMUL = 0
TYPVAL = 2
Local Integer LECGRP : LECGRP = 0
Goto PCEVAL

##################################################
## Identification par les clés, validation réelle
##################################################
Subprog VALPCER1(CODE,IDENT,STAT,MESSA)
Value    Char    CODE
Value    Char    IDENT()(1..)
Variable Integer STAT
Variable Char    MESSA()
Local    Char    TMESSA(250)(1..1)
Local    Integer CAS , DIRECT , SIMUL , TYPVAL
CAS = 1 : DIRECT = 1 : SIMUL = 0 : TYPVAL = 1
Local Integer LECGRP : LECGRP = 0
Goto PCEVAL

Subprog VALPCER3(CODE,IDENT,STAT,MESSA,ZONE,VALEUR)
Value    Char    CODE
Value    Char    IDENT()(1..)
Variable Integer STAT
Variable Char    MESSA()
Value    Char    ZONE()(1..)
Value    Char    VALEUR()(1..)
Local    Char    TMESSA(250)(1..1)
Local    Integer CAS , DIRECT , SIMUL , TYPVAL
CAS = 1 : DIRECT = 1 : SIMUL = 0 : TYPVAL = 1
Local Integer LECGRP : LECGRP = 0
Goto PCEVAL

####################################
## Simulation de validation
####################################
Subprog SIMPCE(CODE,IDENT,STAT,MESSA)
Value    Char    CODE
Value    Char    IDENT()(1..)
Variable Integer STAT
Variable Char    MESSA()
Local    Integer CAS , DIRECT , SIMUL
Local    Integer TYPVAL
Local    Char    TMESSA(250)(1..1)
CAS = 1 : DIRECT = 0 : SIMUL = 1 : TYPVAL = 1
Local Integer LECGRP : LECGRP = 0
Goto PCEVAL

#################################################
## Simulation de validation avec valeurs imposées
#################################################
Subprog SIMPCE3(CODE,IDENT,STAT,MESSA,ZONE,VALEUR)
Value    Char    CODE
Value    Char    IDENT()(1..)
Variable Integer STAT
Variable Char    MESSA()
Value    Char    ZONE()(1..)
Value    Char    VALEUR()(1..)
Local    Integer CAS , DIRECT , SIMUL
Local    Integer TYPVAL
Local    Char    TMESSA(250)(1..1)
CAS = 1 : DIRECT = 0 : SIMUL = 1 : TYPVAL = 1
Local Integer LECGRP : LECGRP = 0
Goto PCEVAL


#############################################################################
## Simulation avec identification par un critère et avec valeurs imposées
#############################################################################
Subprog SIMPCE4(CODE,CRIT,STAT,MESSA,ZONE,VALEUR)
Value    Char    CODE
Value    Char    CRIT
Variable Integer STAT
Variable Char    MESSA()
Value    Char    ZONE()(1..)
Value    Char    VALEUR()(1..)
Local    Integer CAS , DIRECT , SIMUL
Local    Integer TYPVAL
Local    Char    IDENT(30)(1..3)
Local    Char    TMESSA(250)(1..1)
CAS = 2 : DIRECT = 0 : SIMUL = 1 : TYPVAL = 1
Local Integer LECGRP : LECGRP = 0
Goto PCEVAL


####################################
## Identification par les clés
####################################
Subprog VALGRPPCE(CODE,IDENT,STAT,MESSA)
Value    Char    CODE
Value    Char    IDENT()(1..)
Variable Integer STAT
Variable Char    MESSA()
Local    Integer CAS , DIRECT , SIMUL
Local    Integer TYPVAL
Local    Char    TMESSA(250)(1..1)
CAS = 1 : DIRECT = 0 : SIMUL = 0
TYPVAL = 1
Local Integer LECGRP : LECGRP = 0
Goto PCEVAL


####################################
## Identification par un critère
####################################
Subprog VALGRPPCE2(CODE,CRIT,STAT,MESSA)
Value    Char    CODE
Value    Char    CRIT
Variable Integer STAT
Variable Char    MESSA()
Local    Integer CAS , DIRECT , SIMUL
Local    Integer TYPVAL
Local    Char    IDENT(30)(1..3)
Local    Char    TMESSA(250)(1..1)
CAS = 2 : DIRECT = 0 : SIMUL = 0
TYPVAL = 1
Local Integer LECGRP : LECGRP = 0
Goto PCEVAL

####################################
## Avec valeurs imposées
####################################
Subprog VALGRPPCE3(CODE,IDENT,STAT,MESSA,ZONE,VALEUR)
Value    Char    CODE
Value    Char    IDENT()(1..)
Variable Integer STAT
Variable Char    MESSA()
Value    Char    ZONE()(1..)
Value    Char    VALEUR()(1..)
Local    Integer CAS , DIRECT , SIMUL
Local    Integer TYPVAL
Local    Char    TMESSA(250)(1..1)
CAS = 1 : DIRECT = 0 : SIMUL = 0
TYPVAL = 1
Local Integer LECGRP : LECGRP = 0
Goto PCEVAL


#########################################################
## Identification par un critère avec valeurs imposées
#########################################################
Subprog VALGRPPCE4(CODE,CRIT,STAT,MESSA,ZONE,VALEUR)
Value    Char    CODE
Value    Char    CRIT
Variable Integer STAT
Variable Char    MESSA()
Value    Char    ZONE()(1..)
Value    Char    VALEUR()(1..)
Local    Integer CAS , DIRECT , SIMUL
Local    Integer TYPVAL
Local    Char    IDENT(30)(1..3)
Local    Char    TMESSA(250)(1..1)
CAS = 2 : DIRECT = 0 : SIMUL = 0
TYPVAL = 1
Local Integer LECGRP : LECGRP = 0
Goto PCEVAL


$PCEVAL
If clalev([M:HAE0])=0 : Local Mask GACCENT0   [HAE0] : Endif
If clalev([M:HAE1])=0 : Local Mask GACCENT1   [HAE1] : Endif
If clalev([M:HAE2])=0 : Local Mask GACCENT2   [HAE2] : Endif
If clalev([M:HAEF])=0 : Local Mask GACCENTFMT [HAEF] : Endif
If clalev([M:HAEW])=0 : Local Mask GACCENTW   [HAEW] : Endif
If clalev([M:VTL])=0  : Local Mask VENTILE    [VTL]  : Endif
If clalev([M:VT2])=0  : Local Mask VENTILE2   [VT2]  : Endif
Default Mask [VT2]
Default Mask [VTL]
Default Mask [HAEF]
Default Mask [HAEW]
Default Mask [HAE2]
Default Mask [HAE1]
Default Mask [HAE0]

Local Integer MAXLIG
MAXLIG = dim([M:HAE2]ACC1)
Local Integer ERR
Local Decimal DEB , FIN , TETE , REPET_GADLINTYP
Local Integer I , J , K , AXE , OK , GENEURO, K0, K1, K2, SUIVI
Local Integer NBCLE , NBCLE2 , INDCUR
Local Char    PROG(10)
Local Char    CLE(30)(1..16) , CLE2(30)(1..16)
Local Char    CLE3(30)(1..16)
Local Char    CRITERE(250) , CRITERE2(250), CRIT2(250) , CRITLIG(250)
Local Integer NOL , VENT
Local Decimal SENS
Local Decimal MONTLIG , QTELIG , MONTANA , QTEANA
Local Decimal TMONTFORCE(1..len(mess(0,2644,1)))
Local Char    TCOMPTE(GLONGAC)(1..len(mess(0,2644,1))), TPLAN(GLONCOA)(1..len(mess(0,2644,1)))
Local Char    TSAC(GLONSAC)(1..len(mess(0,2644,1)))
Local Char    TDIE(GLONDIE)(1..max(GOPTCANA,20))   : # Axes (DIE)
Local Integer TOBLIG(1..max(GOPTCANA,20))          : # Axes obligatoires (O/N)
Local Char    TIERS(GLONBPR), LIBEL(80)
Local Char    CLECPT(30) , CODCPT(30) , MSKCPT(10)
Local Char    PLGEN(GLONCOA), PLANA(GLONCOA)
Local Char    CPTGEN(GLONGAC), CPTANA(GLONGAC)
Local Char    SITE(GLONFCY) , REPART(10) , TAXE(GLONVAT) , UNITE(GLONUOM)
Local Char    CRIGRP(80)  : # Critère regroupement libre
Local Char    CRITIMP(80) : # Critère regroupement imposé
Local Char    CRIMTC(80)  : # Critère pour lettrage
Local Char    CRICLC(80)  : # Critère détail
Local Integer NBGRP
Local Char    CLEGRP(250) , TBGRP(250)(1..MAXLIG)
Local Decimal COURSTYP , COEUOM
Local Integer TYPCOURS
Local Char    GRPSEC(200), GRPVENT(200)
Local Char    DIE1(GLONCCE), DIE2(GLONCCE), DIE3(GLONCCE), DIE4(GLONCCE), DIE5(GLONCCE)
Local Char    DIE6(GLONCCE), DIE7(GLONCCE), DIE8(GLONCCE), DIE9(GLONCCE), DIE10(GLONCCE)
Local Char    DIE11(GLONCCE), DIE12(GLONCCE), DIE13(GLONCCE), DIE14(GLONCCE), DIE15(GLONCCE)
Local Char    DIE16(GLONCCE), DIE17(GLONCCE), DIE18(GLONCCE), DIE19(GLONCCE), DIE20(GLONCCE)
Local Char    SEC1(GLONCCE), SEC2(GLONCCE), SEC3(GLONCCE), SEC4(GLONCCE), SEC5(GLONCCE)
Local Char    SEC6(GLONCCE), SEC7(GLONCCE), SEC8(GLONCCE), SEC9(GLONCCE), SEC10(GLONCCE)
Local Char    SEC11(GLONCCE), SEC12(GLONCCE), SEC13(GLONCCE), SEC14(GLONCCE), SEC15(GLONCCE)
Local Char    SEC16(GLONCCE), SEC17(GLONCCE), SEC18(GLONCCE), SEC19(GLONCCE), SEC20(GLONCCE)
Local Char    SECTION(GLONCCE)
Local Char    AXI1(GLONDIE), AXI2(GLONDIE), AXI3(GLONDIE), AXI4(GLONDIE), AXI5(GLONDIE)
Local Char    AXI6(GLONDIE), AXI7(GLONDIE), AXI8(GLONDIE), AXI9(GLONDIE), AXI10(GLONDIE)
Local Char    AXI11(GLONDIE), AXI12(GLONDIE), AXI13(GLONDIE), AXI14(GLONDIE), AXI15(GLONDIE)
Local Char    AXI16(GLONDIE), AXI17(GLONDIE), AXI18(GLONDIE), AXI19(GLONDIE), AXI20(GLONDIE)
Local Char    AXEANA(GLONDIE)
Local Char    OFFACC(30)
Local Char    IDENT2(30)(1..16)
Local Char    WCHAINE(250), XZONE(40)
Local Integer N_CLE

Local Integer V , VV , VD , VF , PTVA
Local Integer SAVGOBJET, ETABOU(1..GNBBOU)
Local Char    SAV_SCHEMA(10), SAV_REP(1)
Local Integer SNSLIG
Local Integer EXTOURNE , XNBLET
Local Integer REGROUP   : # Si =1, on regroupe les lignes ayant mêmes caractéristiques CLEGRP+critère regroup libre
Local Integer OKREGROUP
Local Integer OKPCE
Local Integer TACCNUM(MAXLIG), XACCNUM(1..10), XDUDLIG(1..10), FLG_VAL(1..10)
Local Decimal XAMTIPT(1..10)
Local Char    MESSA1(80)
Local Char    SVGMESSA(80)
Local Char    CHAMP(10)
Local Integer NBVAL
Local Integer NBPIECE
Local Integer NBREF : NBREF = len(mess(0,2644,1))
Local Integer NBPLAN
Local Integer NBDIE                                : # Nb d'axes à saisir (max 20)
Local Integer OBLIG(1..max(GOPTCANA,20))           : # Obligatoire (O/N)
Local Integer IREF, INDREF
Local Integer OKDELLIG
Local Integer TLEDTYP(1..len(mess(0,2644,1)))
Local Integer NBLEDTYP
Local Integer ZONZ_A
Local Char    ERRCLAN(10) : ERRCLAN=messname(0)
Local Integer PREPA_LETTRAGE
Local Char    PCEMTE(GLONGAU) : ## Code de la pièce d'écart de change extournée  (standard : MTE)
Local Integer ACC_FND
Local Char    OPT(1)
Local Char    RVSORIGTE(GLONGTE), RVSORIVCR(GLONVCR)

Global Integer GREF : # Permet de passer le référentiel au pg CPTINIVAR qui gère la variable V_CONVERT

# Existence of entry points
Global Integer GCALL_PT : Raz GCALL_PT
If dim(GNBENTREE)>0 & GNBENTREE>0 & find("CPTAUTO",GENTSTD(1..GNBENTREE))
 GCALL_PT=1
Endif

## Performances when creating accounting entries
#              (save the 20 first account to initialization Dimensions - see $EVALSEC From CPTAUTO)
Global Char    GGACKEY(GLONGAC+GLONCOA+1)(0..20)
Global Integer GGACKEYNBR
Global Integer GGACDIENBR(0..20)
Global Char    GGACDIE(GLONDIE)(0..max(GOPTCANA,20)-1,0..20)
Global Char    GGACCCE(GLONCCE)(0..max(GOPTCANA,20)-1,0..20)
Local  Char    WGACKEY(GLONGAC+GLONCOA+1)
Local  Integer INDGAC
##

## Performances when creating accounting entries
#              (save the 20 first keys to control Compatible Accounts - see $COMPTE_OK From TRTCPE)
Global Char    GCNTKEY(255)(0..20)
Global Integer GCNTKEYNBR
Global Integer GCNTSTAT(0..20)
Local  Char    WCNTKEY(250)
Local  Integer INDCNT
##

NBVAL = 1
SAV_SCHEMA = GSCHEMA
SAV_REP    = GREP

If clalev([F:GAU])=0 : Local File GAUTACE     [GAU] : Endif
If clalev([F:GAD])=0 : Local File GAUTACED    [GAD] : Endif
If clalev([F:GAG])=0 : Local File GAUTACEF    [GAG] : Endif
If clalev([F:GTT])=0 : Local File GAUTRCTMP   [GTT] : Endif
If clalev([F:GAT])=0 : Local File GAUTRCVCR   [GAT] : Endif
If clalev([F:CAC])=0 : Local File GACCCODE    [CAC] : Endif
If clalev([F:CPY])=0 : Local File COMPANY     [CPY] : Endif
If clalev([F:FCY])=0 : Local File FACILITY    [FCY] : Endif
If clalev([F:TCU])=0 : Local File TABCUR      [TCU] : Endif
If clalev([F:DIE])=0 : Local File GDIE        [DIE] : Endif
If clalev([F:COA])=0 : Local File GCOA        [COA] : Endif
If clalev([F:GCM])=0 : Local File GACM        [GCM] : Endif
If clalev([F:LED])=0 : Local File GLED        [LED] : Endif
If clalev([F:TCY])=0 : Local File TABCOUNTRY  [TCY] : Endif

# Si Compta X3, GTABCPT contient le chemin d'accés au dossier Comptable
# Si pas de compta X3, GTABCPT vide, on prend les fichiers sous le dossier courant.
# Ces fichiers existent sous le dossier courant pour générer les écritures comptables
# dans un fichier temporaire qui sera ensuite exporté vers le module de compta Non X3

If clalev([F:GAC])=0 : Local File =GTABCPT+"GACCOUNT"    [GAC] : Endif
If clalev([F:GCF])=0 : Local File =GTABCPT+"GACCDEF"     [GCF] : Endif
If clalev([F:GCD])=0 : Local File =GTABCPT+"GACCDIM"     [GCD] : Endif
If clalev([F:TCH])=0 : Local File =GTABCPT+"TABCHANGE"   [TCH] : Endif
If clalev([F:TCK])=0 : Local File =GTABCPT+"TABACCLIK"   [TCK] : Endif
If clalev([F:CCE])=0 : Local File =GTABCPT+"CACCE"       [CCE] : Endif
If clalev([F:DSP])=0 : Local File =GTABCPT+"CADSP"       [DSP] : Endif
If clalev([F:AUZ])=0 : Local File =GTABCPT+"CAAUZ"       [AUZ] : Endif
If clalev([F:ANM])=0 : Local File =GTABCPT+"ACODNUM"     [ANM] : Endif
If clalev([F:AVN])=0 : Local File =GTABCPT+"AVALNUM"     [AVN] : Endif
If clalev([F:CCE2])=0 : Local File =GTABCPT+"CACCE"     [CCE2] : Endif
If clalev([F:HAE2])=0 : Local File =GTABCPT+"GACCTMP"   [HAE2] : Endif
If clalev([F:MGT])=0 : Local File =GTABCPT+"MTCGAUTMP"   [MGT] : Endif
If clalev([F:TVT])=0 : Local File =GTABCPT+"TABVAT"      [TVT] : Endif
If clalev([F:BPC])=0 : Local File =GTABCPT+"BPCUSTOMER"  [BPC] : Endif
If clalev([F:BPS])=0 : Local File =GTABCPT+"BPSUPPLIER"  [BPS] : Endif


If clalev([F:TUN])=0  : Local File TABUNIT     [TUN]  : Endif
If clalev([F:ADI])=0  : Local File ATABDIV     [ADI]  : Endif
If clalev([F:ATZ])=0  : Local File ATABZON     [ATZ]  : Endif
If clalev([F:ATZ2])=0 : Local File ATABZON     [ATZ2] : Endif
If clalev([F:ATI])=0  : Local File ATABIND     [ATI]  : Endif
If clalev([F:ATB])=0  : Local File ATABLE      [ATB]  : Endif

# Comptabilisation dans compta X3
# Ces fichiers sont uniquement sous le dossier comptable X3
If GCOMPTA<>3
 If clalev([F:GDE])=0  : Local File =GTABCPT+"GDIAENTRY"   [GDE] : Endif
 If clalev([F:GDD])=0  : Local File =GTABCPT+"GDIAENTRYD"  [GDD] : Endif
 If clalev([F:PBS])=0  : Local File =GTABCPT+"GAPARBSE"    [PBS] : Endif
 If clalev([F:JOU])=0  : Local File =GTABCPT+"GJOURNAL"    [JOU] : Endif
 If clalev([F:JST])=0  : Local File =GTABCPT+"GAJOUSTA"    [JST] : Endif
 If clalev([F:HAE1])=0 : Local File =GTABCPT+"GACCENTRY"  [HAE1] : Endif
 If clalev([F:FIY])=0  : Local File =GTABCPT+"FISCALYEAR"  [FIY] : Endif
 If clalev([F:PER])=0  : Local File =GTABCPT+"PERIOD"      [PER] : Endif
 If clalev([F:BPR])=0  : Local File =GTABCPT+"BPARTNER"    [BPR] : Endif
 If clalev([F:GTE])=0  : Local File =GTABCPT+"GTYPACCENT"  [GTE] : Endif
 If clalev([F:DUD])=0  : Local File =GTABCPT+"GACCDUDATE"  [DUD] : Endif
Endif

Local Integer XTLEDTYP(1..len(mess(0,2644,1)))
Local Integer X, XNBREF
NBREF = len(mess(0,2644,1))
If GSOCIETE<>""
 Call LSTLEDTYP(GSOCIETE,0,XTLEDTYP,XNBREF) From CPTDIV
Else
 XNBREF = len(mess(0,2644,1))
 For X=1 To XNBREF
  XTLEDTYP(X) = X
 Next
Endif
Call LEC_CPY(GSOCIETE) From CPTLEC

#--- Opening forced for these 3 files to avoid all risk
If DIRECT & GCOMPTA<>3 :# If Finance
 Local File =GTABCPT+"GACCENTRY"  [HAE]
 Local File =GTABCPT+"GACCENTRYD" [DAE]
 Local File =GTABCPT+"GACCENTRYA" [DAA]
Else
 Local File =GTABCPT+"GACCTMP"  [HAE]
 Local File =GTABCPT+"GACCTMPD" [DAE]
 Local File =GTABCPT+"GACCTMPA" [DAA]
 If clalev([F:DAT8])=0 : Local File =GTABCPT+"GACCTMPD" [DAT8] : Endif
Endif

# Point d'entrée
If GCALL_PT : GPOINT = "OPNTAB" : Gosub ENTREE From EXEFNC : Endif

#--- Initialization
STAT = 0
MESSA = ""

#--- Localization for Russia - Integration of "Double Entry Method"
Local Integer FLGDEM
FLGDEM = 0
Call FLGDEM(GSOCIETE,FLGDEM) From CPTDIV
If FLGDEM=2
 Local Integer INDLIN, NOL2, NIDT, NIDT2
 Local Integer IDTHEA, IDTLIN
 Local Integer TNBIDT(1..MAXLIG)          : # Nombre identifiants par ligne d'écriture
 Local Char    TIDT(15)(1..MAXLIG,1..500) : # Tableau d'identifiants
 Local Char    NOMIDT(15)
 Raz IDTHEA, IDTLIN, TNBIDT, TIDT, NOMIDT
Endif

## Si le code de la pièce automatique existe en tant que groupe de pièces, c'est une groupe de pièces qu'on va exécuter
If TYPVAL = 1 & LECGRP = 1
 If clalev([F:GRA])=0 : Local File GRPAUTACE [GRA] : Endif
 Read [GRA]GRA0 = CODE
 If !fstat
  If CAS = 1
   If dim(ZONE)<0
    Call VALGRP(CODE,IDENT,STAT,TMESSA) From VALGRP
   Else
    Call VALGRP3(CODE,IDENT,STAT,TMESSA,ZONE,VALEUR,FLG_VAL) From VALGRP
   Endif
  Else
   If dim(ZONE)<0
    Call VALGRP2(CODE,CRIT,STAT,TMESSA) From VALGRP
   Else
    Call VALGRP4(CODE,CRIT,STAT,TMESSA,ZONE,VALEUR,FLG_VAL) From VALGRP
   Endif
  Endif
  MESSA = TMESSA(1)
  GSCHEMA = SAV_SCHEMA
  GREP    = SAV_REP
  If STAT : End : Endif
  End
 Endif
Endif

# Existence du code
Read [GAU]GAU0 = CODE
If fstat : MESSA = CODE : STAT = 1 : Goto FIN : Endif
PROG = "WMGAU"+CODE

# Lecture table déclenchante
Onerrgo ERREUR
Local File =[F:GAU]TBL [TB0]
Onerrgo
If ERR : MESSA = [F:GAU]TBL : STAT = 3 : Goto FIN : Endif

If [F:GAU]REITBL <> ""
 Onerrgo ERREUR
 Local File =[F:GAU]REITBL [TB4]
 Onerrgo
 If ERR : MESSA = [F:GAU]TBL : STAT = 3 : Goto FIN : Endif
Endif

# Ouvertures des tables liées
Gosub OUVRE From =PROG
Gosub CLE From =PROG
If CAS = 1 & NBCLE>dim(IDENT) : STAT = 4 : Goto FIN : Endif
CRITERE = ""
For I=1 To NBCLE
 If CAS=1
  If [F:GAU]GRPFLG=1 | IDENT(I)<>""
   If CRITERE<>"" : CRITERE += " & " : Endif
   Case evalue("type([F:TB0]"+CLE(I)+")")
    When 1,2,4,5,6,7,8,9
     CRITERE += CLE(I)+'='+IDENT(I)
    When 3
     If IDENT(I)<>""
      CRITERE += CLE(I)+'=['+format$(GFMD,gdat$(IDENT(I)))+']'
     Else
      CRITERE = left$(CRITERE,len(CRITERE)-3)
     Endif
    When Default
     CRITERE += CLE(I)+'="'+IDENT(I)+'"'
   Endcase
  Endif
 Else
  If CRIT2<>"" : CRIT2 += " & " : Endif
  CRIT2 += CLE(I)+"=[F:TB0]"+CLE(I)
 Endif
Next I

#  Table of tracability - Abreviation TB9 - Local File XXXXX [TB9]
If [F:GAU]TRCFLG=2
 Gosub DECLARE From CPTTRCVCR
Endif

If CAS=2
 CRITERE = CRIT
Else
 CRIT2 = "1=1"
Endif

Default File [TB0]
CRITERE2 = "1=1"
For I=0 To dim([F:GAU]FORCND)-1
 If [F:GAU]FORCND(I)<>""
  If CRITERE2<>"" : CRITERE2 -= "&" : Endif
  CRITERE2 -= "("+[F:GAU]FORCND(I)+")"
 Endif
Next
If CRITERE<>""
 Filter [TB0] Where evalue(CRITERE) & evalue(CRITERE2)
 If [F:GAU]REITBL<>""
  Gosub LNKTBL From =PROG
 Endif
Endif
Raz GMESSAGE
If INDCUR<>0
 [G:TB0]currind = INDCUR
Else
 [G:TB0]currind = 1
Endif
[G:TB0]currlen = 0

If CAS = 2
 CRITERE = "1=1"
 If TYPVAL = 2
  [F:GAU]GRPFLG = [L]GRP
 Endif
Endif

Case [F:GAU]GRPFLG

 When 1
  If [F:GAU]REITBL=""
   For [TB0]
    If FLGDEM=2
     IDTHEA += 1
    Endif
    Gosub LIENS From =PROG
    Gosub AP_LIENS From =PROG
    Gosub TSTENT : If STAT : Break : Endif
    If OKPCE
     Gosub INIPCE
     Call TETE(STAT,MESSA) From TRTPCE
     If STAT : Break : Endif
     Gosub INIPCE2
     Gosub LIGNES
     If STAT : Break : Endif
     Gosub PIECE
     TMESSA(1) = MESSA
     If STAT : Break : Endif
    Endif
   Next
  Else
   CHAMP = [F:GAU]REIFLD : NBVAL = 0 : NBPIECE = 0
   Read [ATZ]CODZONE = [F:GAU]REITBL ; CHAMP
   Gosub DCLTAB
   For [LNK]CLE(1)
    NBVAL += 1
    If FLGDEM=2
     IDTHEA = 0
    Endif
    For [TB0]
     If FLGDEM=2
      IDTHEA += 1
     Endif
     TVALCHP(NBVAL) = evalue("[F:LNK]"+CHAMP)
     Gosub LIENS From =PROG
     Gosub AP_LIENS From =PROG
     Gosub TSTENT : If STAT : Break 2 : Endif
     If OKPCE
      Gosub INIPCE
      Call TETE(STAT,MESSA) From TRTPCE
      If STAT : Break 2 : Endif
      Gosub INIPCE2
      Gosub LIGNES
      If STAT : Break 2 : Endif
      Gosub PIECE
      If MESSA<>""
       NBPIECE += 1
       If NBPIECE<=dim(TMESSA)
        TMESSA(NBPIECE) = MESSA
       Else
        STAT=47
       Endif
      Endif
      If STAT : Break : Endif
     Endif
    Next
   Next
  Endif

 When 2
  If [F:GAU]REITBL=""
   TETE = 0
   Gosub INIPCE
   For [TB0]
    Gosub LIENS From =PROG
    Gosub AP_LIENS From =PROG
    Gosub TSTENT : If STAT : Break : Endif
    If OKPCE
     If TETE=0
      If FLGDEM=2
       IDTHEA += 1
      Endif
      Call TETE(STAT,MESSA) From TRTPCE : TETE = 1
      If STAT : Break : Endif
      Gosub INIPCE2
     Endif
     Gosub LIGNES
     If STAT : Break : Endif
    Endif
   Next
   If OKPCE & !STAT
    Gosub PIECE
    TMESSA(1) = MESSA
   Endif
  Else
   CHAMP = [F:GAU]REIFLD : NBVAL = 0 : NBPIECE = 0
   Read [ATZ]CODZONE = [F:GAU]REITBL ; CHAMP
   Gosub DCLTAB
   For [LNK]CLE(1)
    NBVAL += 1
    If FLGDEM=2
     IDTHEA = 0
    Endif
    TVALCHP(NBVAL) = evalue("[F:LNK]"+CHAMP)
    TETE = 0
    Gosub INIPCE
    For [TB0]
     Gosub LIENS From =PROG
     Gosub AP_LIENS From =PROG
     Gosub TSTENT : If STAT : Break 2 : Endif
     If OKPCE
      If TETE=0
       If FLGDEM=2
        IDTHEA += 1
       Endif
       Call TETE(STAT,MESSA) From TRTPCE : TETE = 1
       If STAT : Break 2 : Endif
       Gosub INIPCE2
      Endif
     Endif
     Gosub LIGNES
     If STAT : Break 2 : Endif
    Next

    If OKPCE & !STAT
     Gosub PIECE
     If MESSA<>""
      NBPIECE += 1
      If NBPIECE<=dim(TMESSA)
       TMESSA(NBPIECE) = MESSA
      Else
       STAT=47
      Endif
     Endif
     If STAT : Break : Endif
    Endif
   Next
  Endif
Endcase

$FIN
If STAT : Gosub MESSAGE : TMESSA(1) = MESSA : Endif
GSCHEMA = SAV_SCHEMA
GREP    = SAV_REP

If dim(ERRCLAN)>0 and ERRCLAN<>messname(0)
 messname(0) = ERRCLAN
Endif

If SIMUL
 Gosub DEL_GTT From CPTTRCVCR
Endif

Kill GREF
Kill GCALL_PT

If dim(GGACKEY)>0
 Kill GGACKEY
 Kill GGACKEYNBR
 Kill GGACDIENBR
 Kill GGACDIE
 Kill GGACCCE
Endif

If dim(GCNTKEY)>0
 Kill GCNTKEY
 Kill GCNTKEYNBR
 Kill GCNTSTAT
Endif
End

$INIPCE
Raz [M:HAE0], [M:HAE1], [M:HAE2], [M:VTL], [M:VT2]
NBGRP = 0
Raz TBGRP
# Affectation des valeurs imposées
For I=1 To dim(ZONE)
 If ZONE(I)<>""
  Case evalue("type([M]"+ZONE(I)+")")
   When 1,2,4,5,6,7,8,9
    Assign "[M]"+ZONE(I) With val(VALEUR(I))
   When 3
    Assign "[M]"+ZONE(I) With gdat$(VALEUR(I))
   When Default
    Assign "[M]"+ZONE(I) With VALEUR(I)
  Endcase
 Endif
Next I
Return

$INIPCE2
Call GETSOC([M]FCY) From DEVSUB

#--- Est-ce la pièce MTC extournée ?
PCEMTE=""
If left$([M]REFINT,3)="MTC"
 Call PARAM([M]FCY,"GAUMTE",PCEMTE) From ADOVAL
 If PCEMTE="" : PCEMTE = "MTE" : Endif
Endif

## Initialisation masque de référence [HAEF]
Call LEC_GDE([M]DACDIA) From CPTLEC
If [M]AUTACE=PCEMTE
 Call INIMSKFMT3([M]FCY,2,[M]DACDIA,[M]TYP,[M]ACCDAT,STAT) From SUBGASA
Else
 Call INIMSKFMT3([M]FCY,1,[M]DACDIA,[M]TYP,[M]ACCDAT,STAT) From SUBGASA
Endif
For I=1 To [M:HAEF]NBRLED
 Assign "[M:HAE1]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
 Assign "[M:HAE2]COA("+num$(I-1)+")" With [M:HAEF]COA(I-1)
Next
Return

$PIECE
[M]NBLIG = NBGRP
If TYPVAL = 2 & FLGDEM<>2
 Sorta [M]NBLIG [M]NBLIG Order By [M]LIGPCEAUTO(indice)
Endif

For NOL=0 To [M]NBLIG-1
 Gosub DEBCDT
 Gosub FINREP
Next NOL

If sum([M]DEB(0..[M]NBLIG-1))<>0
 NOLI = 0 : OKDELLIG = 1
 While NOLI<=[M]NBLIG-1
  If [M]DEB(NOLI)=0 & [M]CDT(NOLI)=0
   For I=1 To NBREF
    If evalue("[M]AMTFLG"+num$(I)+"("+num$(NOLI)+")")=0 or evalue("[M]AMTFRC"+num$(I)+"("+num$(NOLI)+")")=0
     OKDELLIG = 1
    Else
     OKDELLIG = 0 : Break
    Endif
    If [M]FLGREP=2 & ([M]QTY(NOLI)<>0 | [M]DSP(NOLI)<>"")
     OKDELLIG = 0 : Break
    Endif
   Next
   If OKDELLIG
    Dela NOLI,1,[M]NBLIG-1 [M]NBLIG
    [M]NBLIG -= 1
   Else
    NOLI += 1
   Endif
  Else
   NOLI += 1
  Endif
 Wend
 If [M]NBLIG=0 : STAT = 23 : Gosub MESSAGE : Return : Endif
Endif

# Preview (Temporary)
If GTEST & filinfo(filpath("ECR","GACCENT2","msk"),0)>0
 Read [TCU]TCU0 = "EUR"
 Call DIALWIN(I,mess(34,114,1),"DEBUGCPT") From GESECRAN : # Journal Posting
Endif

# Entry points
If GCALL_PT : GPOINT = "PIECE" : Gosub ENTREE From EXEFNC : Endif

If FLGDEM = 2 & dim([M]CPALIN)>0 & dim([M]DOEPTR)>0
 For NOL=0 To [M]NBLIG
  If [M]CPALIN(NOL)<>0
   For NIDT = 1 To TNBIDT(NOL+1)
    TROUVE = 0 : INDLIN = 0 : NOL2 = 1
    While !TROUVE & NOL2>0
     NOL2 = find([M]CPALIN(NOL),[M]LIGPCEAUTO(INDLIN..[M]NBLIG-1))
     If NOL2
      For NIDT2 = 1 To TNBIDT(NOL2+INDLIN)
       If TIDT(NOL2+INDLIN,NIDT2) = TIDT(NOL+1,NIDT)
        [M]DOEPTR(NOL) = NOL2+INDLIN
        TROUVE = 1 : Break 3
       Elsif right$(TIDT(NOL2+INDLIN,NIDT2),len(TIDT(NOL2+INDLIN,NIDT2)))="*"
        If left$(TIDT(NOL2+INDLIN,NIDT2),len(TIDT(NOL2+INDLIN,NIDT2))-1)=left$(TIDT(NOL+1,NIDT),len(TIDT(NOL2+INDLIN,NIDT2))-1)
         [M]DOEPTR(NOL) = NOL2+INDLIN
         TROUVE = 1 : Break 3
        Endif
       Endif
      Next
     Endif
     If !TROUVE : INDLIN += NOL2 : Endif
    Wend
   Next
  Endif
 Next
Endif

If NBGRP>0
 Call CONTROLE(STAT,MESSA) From CPTBATCH
 If STAT : Return : Endif
Endif

# Reversal ?
If [M:HAE1]RVS=2 & [M:HAE0]CAT=1
 EXTOURNE = 1
 [M:HAE1]RVS = 3   : # Reversed
Else
 EXTOURNE = 0
Endif

# Preview
If SIMUL
 If NBGRP>0
  Gosub AP_PIECE From =PROG
  If GOK<1 | STAT : Return : Endif
 Endif
Endif
If SIMUL : Return : Endif

If [M:HAE1]TYPDUD=0
 [M:HAE1]TYPDUD=4 :# Others
Endif

# Validation de la pièce dans les fichiers temporaires
If NBGRP>0
 If DIRECT
  Call VALPIECER(STAT,MESSA) From CPTBATCH
 Else
  Call VALPIECE(STAT,MESSA) From CPTBATCH
 Endif
 If STAT : Return : Endif
Endif

## Lettrage à postériori ???
If PREPA_LETTRAGE
 Local Integer NOLI, VU
 For [GAD]GAD0 Where COD = CODE & FLGMTC = 2
  VU = find([F:GAD]LINNUM,[M:HAE2]LIGPCEAUTO(0..[M:HAE2]NBLIG-1))
  If VU
   For NOLI = VU To [M:HAE2]NBLIG-1
    If [M:HAE2]LIGPCEAUTO(NOLI-1) = [F:GAD]LINNUM & evalue("[M]ACC"+num$(GTYPGEN)+"("+num$(VU-1)+")")<>""
     [F:MGT]COD    = [F:GAD]COD
     [F:MGT]LINNUM = [F:GAD]LINNUM
     [F:MGT]ACCNUM = [M:HAE2]ACCNUM(VU-1)
     [F:MGT]CPY    = [M:HAE0]CPY
     [F:MGT]CUR    = [M:HAE1]CUR
     [F:MGT]ACC    = [M:HAE2]ACC(VU-1)
     [F:MGT]BPR    = [M:HAE2]BPR(VU-1)
     [F:MGT]AMTCUR = [M:HAE2]DEB(VU-1)+[M:HAE2]CDT(VU-1)
     [F:MGT]AMTLED = evalue("[M:HAE2]AMT"+num$(GTYPGEN)+"("+num$(VU-1)+")")
     For CURCLE = 1 To NBCLE
      Case CAS
       When 1
        Assign "[F:MGT]CLEA"+num$(CURCLE) With evalue("[F:TB0]"+CLE(CURCLE))
       When 2
        Assign "[F:MGT]CLEA"+num$(CURCLE) With evalue("[F:TB0]"+CLE(CURCLE))
      Endcase
     Next
     NOLI += 1
     Write [MGT]
     If fstat
      GOK = 0 : Call FSTA("MGT") From GLOCK : Break 2
     Endif
    Endif
   Next
  Endif
 Next
 If GOK<1 : Return : Endif
Endif

If NBGRP>0
 Gosub AP_PIECE From =PROG
 If GOK<1 | STAT : Return : Endif
Endif

If NBGRP>0 & [L]TYPVAL = 2
 Gosub AP_PIECE From PAYCPTA
 If GOK<1 | STAT : Return : Endif
Endif

If [F:GAU]TRCFLG=2
 Gosub AP_TRCVCR From CPTTRCVCR
 If GOK<1 | STAT : Return : Endif
 Gosub DEL_GTT From CPTTRCVCR
 If GOK<1  : Return : Endif
Endif

# Reversal
If EXTOURNE & NBGRP>0

 [L]RVSORIGTE = [M:HAE0]TYP
 [L]RVSORIVCR = [M:HAE0]NUM
 [M:HAE1]RVSORITYP = [M:HAE0]TYP
 [M:HAE1]RVSORINUM = [M:HAE0]NUM

 MESSA1 = MESSA
 #--- Libellé par défaut de la pièce d'extourne : on remplace le car. '*' par TYP-NUM
 K = instr(1,mess(92,106,1),"*")
 If K
  #--- TYP NUM reversed
  [M:HAE1]DESVCR = left$(mess(92,106,1),K-1) + [M:HAE0]TYP-[M:HAE0]NUM + right$(mess(92,106,1),K+1)
 Endif
 [M:HAE0]NUM = ""
 [M:HAE0]ACCDAT = [M:HAE1]RVSDAT
 [M:HAE1]ENTDAT = [M:HAE0]ACCDAT
 [M:HAE1]DUDDAT = [M:HAE0]ACCDAT
 [M:HAE1]VALDAT = [M:HAE0]ACCDAT
 [M:HAE1]RVS = 1
 [M:HAE1]RVSDAT = [0/0/0]
 # Génération de la pièce en Euro si nécessaire
 Raz GENEURO
 If [M:HAE1]CUR<>GEURO
  Call LEC_TCU([M:HAE1]CUR) From CPTLEC
  # Date de validité
  If [F:TCU]EURFLG=2 & [M:HAE0]ACCDAT>=[F:TCU]CURENDDAT
   Call LECLED([M]CPY,GTYPGEN,CODLED,DEVLED) From CPTDIV
   If DEVLED = GEURO
    GENEURO = 1
    [M:HAE1]CUR = GEURO
   Else
    # La société n'est pas passée à l'Euro
    STAT=99 : GMESSAGE = mess(99,106,1) : Return
   Endif
  Endif
 Endif
 # re-initialisation des champs FIY et PER car la date comptable de l'extourne
 # peut être sur une période differente de la pièce d'origine
 Call GETPER([M:HAE0]FCY,GTYPGEN,[M:HAE0]ACCDAT,[M:HAE0]FIY,[M:HAE0]PER) From CPTSUB
 Local Date VALEUR
 VALEUR = [M:HAE0]ACCDAT
 Gosub CONTDAT From SUBGA1
 If mkstat
  MESSA = mess(64,106,1)-"\ ACCDAT"-format$("D:"+GFMDAT,[M:HAE0]ACCDAT)
  STAT = 99 : Return
 Endif
 For NOL=0 To [M:HAE2]NBLIG-1
  If [M]DEB(NOL)<>0
   [M]CDT(NOL) = [M]DEB(NOL)
   [M]DEB(NOL) = 0
   If GENEURO : [M]CDT(NOL)=evalue("[M]AMT"+num$(GTYPGEN)+"("+num$(NOL)+")") : Endif
  Else
   [M]DEB(NOL) = [M]CDT(NOL)
   [M]CDT(NOL) = 0
   If GENEURO : [M]DEB(NOL)=evalue("[M]AMT"+num$(GTYPGEN)+"("+num$(NOL)+")") : Endif
  Endif
  If ([M]DEB(NOL)=0 & [M]CDT(NOL)=0)
   For IREF=1 To len(mess(0,2644,1))
    Assign "[M]AMT"+num$(IREF)+"("+num$(NOL)+")" With evalue("[M]AMT"+num$(IREF)+"("+num$(NOL)+")")*-1
    Assign "[M]AMTFRC"+num$(IREF)+"("+num$(NOL)+")" With evalue("[M]AMTFRC"+num$(IREF)+"("+num$(NOL)+")")*-1
   Next
  Endif
  TACCNUM(NOL)  = [M:HAE2]ACCNUM(NOL)
 Next NOL
 Raz [M:HAE2]ACCNUM, [M:HAE2]CHRNUM
 Raz [M:HAE2]MTC, [M:HAE2]MTCDAT, [M:HAE2]MTCDATMAX, [M:HAE2]MTCDATMIN
 Raz [M:HAE2]CHK, [M:HAE2]CHKDAT
 Raz [M:HAE2]AMTVAT

 # Entry point
 If GCALL_PT : GPOINT = "PIECE" : Gosub ENTREE From EXEFNC : Endif

 Call CONTROLE(STAT,MESSA) From CPTBATCH
 If STAT : Return : Endif

 If DIRECT
  Call VALPIECER(STAT,MESSA) From CPTBATCH
 Else
  Call VALPIECE(STAT,MESSA) From CPTBATCH
 Endif
 If STAT : STAT = 20 : Return : Endif

 If MESSA1<>""
  MESSA = MESSA1+"\"+mess(59,123,1)-tolower(mess(55,105,1))-":"-MESSA
 Endif

 #--- Lettrage avec pièce d'origine
 If GCOMPTA<>3
  If clalev([F:DAEX])=0 : Local File GACCENTRYD [DAEX] : Endif
  If clalev([F:DATX])=0 : Local File GACCTMPD   [DATX] : Endif
  For NOL=0 To [M:HAEW]NB-1
   INDREF = [M:HAEW]LEDTYP(NOL)
   If [M:HAEF]GENC(INDREF-1) = 2 & [M:HAEF]MTC(INDREF-1) = 2
    Call LEC_GAC([M:HAEW]ACC(NOL),[M:HAEW]COA(NOL)) From CPTLEC
    If !fstat & [F:GAC]MTC=2
     XNBLET = 2
     Read [DAEX]DAE0 = [L]RVSORIGTE;[L]RVSORIVCR;[M:HAEW]LIN(NOL);INDREF
     If !fstat
      XACCNUM(1)  = [F:DAEX]ACCNUM
      XDUDLIG(1) = 1
      XAMTIPT(1) = [M:HAEW]DEB(NOL)+[M:HAEW]CDT(NOL)
     Else
      Read [DATX]DAT0 = [L]RVSORIGTE;[L]RVSORIVCR;[M:HAEW]LIN(NOL);INDREF
      If !fstat
       XACCNUM(1)  = [F:DATX]ACCNUM
       XDUDLIG(1) = 1
       XAMTIPT(1) = [M:HAEW]DEB(NOL)+[M:HAEW]CDT(NOL)
      Endif
     Endif
     XACCNUM(2)  = [M:HAEW]ACCNUM(NOL)
     XDUDLIG(2) = 1
     XAMTIPT(2) = [M:HAEW]DEB(NOL)+[M:HAEW]CDT(NOL)
     Call LETDIF(XNBLET,XACCNUM,XDUDLIG,XAMTIPT,2) From CPTLET
     If GOK<1 : Break : Endif
    Endif
   Endif
  Next NOL
 Endif
Endif
Return


$LIGNES
# Parcours des lignes
For [GAD]GAD0 Where COD=CODE and ([F:GAD]NBRLEG=0 or find([F:CPY]LEG,[F:GAD]ACTLEG(0..dim([F:GAD]ACTLEG)-1))<>0)
 If FLGDEM = 2
  IDTLIN = 0
 Endif

 If [F:GAD]DETCND="" | evalue([F:GAD]DETCND)=1
  REGROUP = 1
 Else
  REGROUP = 0
 Endif

 ## Dans [M:HAEF]LEDTYP, on a les types de référentiels potentiellement saisissables (ce qui ne veut
 ## pas forcément dire tous les types référentiels associés à la transaction car le type de pièce peut
 ## en interdire certains...)
 ## Dans le tableau TLEDTYP, on remplit les types de référentiels à gérer pour la ligne de pièce auto
 ## compte tenu des types de référentiels paramétrés au niveau de la ligne de pièce auto et compte tenu
 ## des types référentiels potentiellement saisissables
 Raz TLEDTYP, NBLEDTYP
 For I=1 To [F:GAD]NBRLED
  If find([F:GAD]LEDTYP(I-1),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
   NBLEDTYP += 1
   TLEDTYP(NBLEDTYP) = [F:GAD]LEDTYP(I-1)
  Endif
 Next

 If NBLEDTYP>0

  ## Si au moins une ligne de la pièce auto est flaguée 'lettrage à postériori',
  ## on fera une prépa lettrage après le VALPIECE
  If [F:GAD]FLGMTC = 2
   PREPA_LETTRAGE = 1
  Endif

  Case [F:GAD]LINTYP
   When 1
    Gosub LIENS_LIG
    Gosub TSTLIG : If STAT : Break : Endif
    If OK
     If [F:GAD]LINTBL2<>"" & clalev([F:TB2])=0
      Onerrgo ERREUR
      Local File =[F:GAD]LINTBL2 [TB2]
      Onerrgo
      If ERR : MESSA = [F:GAD]LINTBL2-":"-errmes$(ERR) : STAT = 97 : Break : Endif
     Endif
     Gosub LEC_CPTANALIN
     If STAT : Break : Endif
     Gosub LIGGEN
     If STAT : SVGMESSA =  MESSA : MESSA = [F:GAD]COD-mess(1,114,1)-num$([F:GAD]LINNUM)-":"-SVGMESSA : Break : Endif
     If ACC_FND
      If [F:GAD]LINTBL2 = ""
       Gosub LIGANA
       If STAT : SVGMESSA =  MESSA : MESSA = [F:GAD]COD-mess(1,114,1)-num$([F:GAD]LINNUM)-":"-SVGMESSA : Break : Endif
      Else
       Gosub CLE_LIG
       Gosub CRITLIG
       For [TB2] Where evalue(CRITLIG)
        Gosub LIGREP
        If STAT : SVGMESSA =  MESSA : MESSA = [F:GAD]COD-mess(1,114,1)-num$([F:GAD]LINNUM)-":"-SVGMESSA : Break 2 : Endif
       Next
      Endif
     Endif
    Endif

   When 2
    Call EVAL_NUM(DEB,"STR",2,0,0,STAT)
    If STAT : MESSA = "STR" : Break : Endif
    Call EVAL_NUM(FIN,"END",2,0,0,STAT)
    If STAT : MESSA = "END" : Break : Endif
    If [F:GAD]LINTBL2<>"" & clalev([F:TB2])=0
     Onerrgo ERREUR
     Local File =[F:GAD]LINTBL2 [TB2]
     Onerrgo
     If ERR : MESSA = [F:GAD]LINTBL2-":"-errmes$(ERR) : STAT = 97 : Break : Endif
    Endif
    For REPET_GADLINTYP=DEB To FIN
     indice = REPET_GADLINTYP
     Gosub LIENS_LIG
     Gosub TSTLIG : If STAT : Break 2 : Endif
     If OK
      Gosub LEC_CPTANALIN
      If STAT : Break 2 : Endif
      Gosub LIGGEN
      If STAT : SVGMESSA =  MESSA : MESSA = [F:GAD]COD-mess(1,114,1)-num$([F:GAD]LINNUM)-":"-SVGMESSA : Break 2 : Endif
      If ACC_FND
       If [F:GAD]LINTBL2 = ""
        Gosub LIGANA
        If STAT : SVGMESSA =  MESSA : MESSA = [F:GAD]COD-mess(1,114,1)-num$([F:GAD]LINNUM)-":"-SVGMESSA : Break 2 : Endif
       Else
        Gosub CLE_LIG
        Gosub CRITLIG
        For [TB2] Where evalue(CRITLIG)
         Gosub LIGREP
         If STAT : SVGMESSA =  MESSA : MESSA = [F:GAD]COD-mess(1,114,1)-num$([F:GAD]LINNUM)-":"-SVGMESSA : Break 3 : Endif
        Next
       Endif
      Endif
     Endif
    Next REPET_GADLINTYP
   When 3
    Onerrgo ERREUR
    Local File =[F:GAD]LINTBL1 [TB1]
    Onerrgo
    If ERR : MESSA = [F:GAD]LINTBL1-":"-errmes$(ERR) : STAT = 97  : Break : Endif
    If [F:GAD]LINTBL2<>""
     Onerrgo ERREUR
     Local File =[F:GAD]LINTBL2 [TB2]
     Onerrgo
     If ERR : MESSA = [F:GAD]LINTBL2-":"-errmes$(ERR) : STAT = 97 : Break : Endif
     Gosub CLE_LIG
     If [F:GAD]LIKTBL2<>""
      Gosub CRITLIG
     Else
      ## On fait comme avant....
      CRITLIG = CLE2(NBCLE2-1)+"=[F:TB1]"+CLE2(NBCLE2-1)
     Endif
    Endif
    For [TB1] Where evalue(CRITERE) & evalue(CRITERE2) & evalue(CRIT2)
&                 & ([F:GAD]LINTBL1<>[F:GAU]REITBL | evalue(CHAMP)=TVALCHP(NBVAL))
     Gosub LIENS_LIG
     Gosub TSTLIG : If STAT : Break 2 : Endif
     If OK
      Gosub LEC_CPTANALIN
      If STAT : Break 2 : Endif
      Gosub LIGGEN
      If STAT : SVGMESSA =  MESSA : MESSA = [F:GAD]COD-mess(1,114,1)-num$([F:GAD]LINNUM)-":"-SVGMESSA : Break 2 : Endif
      If ACC_FND
       If [F:GAD]LINTBL2<>"" & clalev([F:TB2])>0 & [M]DSP(NOL)=""
        If [F:GAD]LIKTBL2<>""
         For [TB2] Where evalue(CRITLIG)
          Gosub LIGREP
          If STAT : Break 3 : Endif
         Next
        Else
         For [TB2] Where evalue(CRITERE) & evalue(CRITERE2) & evalue(CRIT2) & evalue(CRITLIG)
          Gosub LIGREP
          If STAT : Break 3 : Endif
         Next
        Endif
       Else
        Gosub LIGANA
        If STAT : SVGMESSA =  MESSA : MESSA = [F:GAD]COD-mess(1,114,1)-num$([F:GAD]LINNUM)-":"-SVGMESSA : Break 2 : Endif
       Endif
      Endif
     Endif
    Next
  Endcase
  If clalev([F:TB1])>0 : Close Local File [TB1] : Endif
  If clalev([F:TB2])>0 : Close Local File [TB2] : Endif
 Endif
Next
Return

$TSTENT
OKPCE = 1
If [F:GAU]FORCND2<>""
 Onerrgo ERREUR
 OKPCE = evalue([F:GAU]FORCND2)
 Onerrgo
 If ERR : MESSA = [F:GAU]FORCND2 : STAT = 9 : Endif
Endif
If dim([F:GAU]NBRLEG)>0 & [F:GAU]NBRLEG<>0
 If [F:CPY]LEG<>"" & !find([F:CPY]LEG,[F:GAU]ACTLEG(0..dim([F:GAU]ACTLEG)-1))
  OKPCE=0
 Endif
Endif
Return

$TSTLIG
OK = 1
For J=0 To dim([F:GAD]FORCND)-1
 If [F:GAD]FORCND(J)<>""
  Onerrgo ERREUR
  OK = evalue([F:GAD]FORCND(J))
  Onerrgo
  If ERR : MESSA = [F:GAD]FORCND(J) : STAT = 9 : Break
  Elsif !OK : Break
  Endif
 Endif
Next
Return

$LIENS_LIG
Gosub LIENS_X From =PROG
Gosub AP_LIENS_X From =PROG
If STAT : Return : Endif
Return

$CLE_LIG
Gosub CLE_X From =PROG
WCHAINE = [F:GAD]LIKTBL2
N_CLE = 0
While WCHAINE<>""
 I = instr(1,WCHAINE,";")
 If I
  XZONE = left$(WCHAINE,I-1) : WCHAINE = right$(WCHAINE,I+1)
 Else
  XZONE = WCHAINE : WCHAINE = ""
 Endif
 N_CLE += 1
 IDENT2(N_CLE) = XZONE
Wend
Return

$CRITLIG
CRITLIG = "1=1"
For J=1 To NBCLE2
 If IDENT2(J)<>""
  CRITLIG += " & "+CLE2(J)+"="+IDENT2(J)
 Endif
Next
Return

$LEC_CPTANALIN
## Lecture CPTANALIN avant l'appel au LIGGEN pour les comptes...
If [F:GAD]LINTBL2 = "CPTANALIN"
 Gosub CLE_LIG
 Gosub CRITLIG
 Filter [TB2] Where evalue(CRITLIG)
 Read [TB2] First
 Filter [TB2]
Endif
Return


$MESSAGE
Case STAT
 When  1 : MESSA = MESSA-":"-mess(39,114,1)           : # Pièce automatique inexistante
 When  2 : MESSA = mess(3,114,1)                      : # Table déclenchante non référencée
 When  3 : MESSA = MESSA-":"-mess(4,114,1)            : # Table déclenchante inexistante
 When  4 : MESSA = mess(5,114,1)                      : # Nombre d'arguments incorrect
 When  5 : MESSA = mess(6,114,1)                      : # Table déclenchante non référencée
 When  6 : MESSA = MESSA-":"-mess(7,114,1)            : # Table secondaire inexistante
 When  7 : MESSA = MESSA-":"-mess(8,114,1)            : # Table analytique inexistante
 When  9 : MESSA = MESSA-mess(9,114,1)+"\"+GMESSAGE   : # Erreur en évaluation de zone
 When 10 : MESSA = mess(10,114,1)-MESSA               : # Lien incorrect sur
 When 11 : MESSA = MESSA-":"-mess(11,114,1)           : # Code comptable inexistant
 When 12 : MESSA = mess(12,114,1)-MESSA               : # Compteur inexistant
 When 13 : MESSA = mess(13,114,1)-MESSA               : # Dépassement de compteur
 When 14 : MESSA = MESSA-":"-mess(14,114,1)           : # Site inexistant
 When 15 : MESSA = MESSA-":"-mess(15,114,1)           : # Société inexistante
 When 16 : MESSA = MESSA-":"-mess(16,114,1)           : # Pas de cours de devise
 When 17 : MESSA = MESSA-":"-mess(17,114,1)           : # Type de pièce inexistant
 When 20 : MESSA = mess(18,114,1)                     : # Transaction abandonnée
 When 21 : MESSA = MESSA-":"-mess(19,114,1)           : # Pièce réelle déjà existante
 When 22 : MESSA = MESSA-":"-mess(20,114,1)           : # Pièce temporaire déjà existante
 When 23 : MESSA = mess(21,114,1)                     : # Pas de ligne
 When 24 : MESSA = mess(22,114,1)                     : # Pièce déséquilibrée
 When 25 : MESSA = mess(23,114,1)-MESSA               : # Ventilation déséquilibrée
 When 26 : MESSA = mess(24,114,1)-MESSA               : # Ventilation déséquilibrée (qté)
 When 27 : MESSA = mess(38,106,1)-MESSA               : # Compte inexistant
 When 28 : MESSA = mess(16,114,1)-MESSA               : # pas de cours pour la devise ...
 When 29 : MESSA = MESSA-":"-mess(107,106,1)          : # Aucun compte trouvé
 When 30 : MESSA = MESSA-":"-mess(68,103,1)           : # Nature de provision non référencée
 When 31 : MESSA = MESSA-":"-mess(39,107,1)           : # En cours de modification
 When 32 : MESSA = MESSA-":"-mess(40,114,1)           : # Code transaction inexistant
 When 33 : MESSA = MESSA-":"-mess(41,114,1)           : # Code transaction incompatible
 When 34 : MESSA = MESSA-":"-mess(54,126,1)           : # Nombre de lignes maximum dépassé
 When 35 : MESSA = mess(17,106,1)                     : # Il y a aucune ligne saisie
 When 36 : MESSA = mess(112,106,1)                    : # Aucun référentiel possible
 When 37 : MESSA = mess(113,106,1)                    : # Type de pièce mono-référentiel
 When 38 : MESSA = mess(183,124,1)+">"+num$(GOPTCANA) : # Nombre d'axes analytiques
 When 39 : MESSA = mess(114,106,1)                    : # Référentiel obligatoire : pas de compte par défaut
 When 43 : MESSA = mess(110,106,1)                    : # Référentiel obligatoire non présent
 When 44 : MESSA = MESSA-":"-"\"+mess(197,107,1)      : # Tiers non défini
 When 45 : MESSA = mess(205,105,1)-":"-"\"+mess(83,123,1) : # Pointeur partie double : valeur incorrecte
 When 46 : MESSA = mess(205,105,1)-":"-"\"+mess(206,105,1) : # Pointeur  partie double : Ecriture non autorisée
 When 47 : MESSA = mess(126,106,1)                    : # Dépassement de capacité d'affichage des pièces à générer
 When 48 : MESSA = mess(79,117,1)-"("+mess(240,117,1)-num$(dim([M:VT2]TBAMT))+")" : # Trop de ventilation analytique (maximum X)
 When 97 : MESSA = MESSA                              : # Message contenu dans MESSA
 When 98 : MESSA = GMESSAGE                           : # Message contenu dans GMESSAGE
 When 99 : If MESSA<>"" : MESSA = MESSA-":"-"\"+GMESSAGE
           Else         : MESSA = GMESSAGE
           Endif
Endcase
Return


#################################################
$LIGGEN
If FLGDEM=2
 If find([F:GAD]LINTYP,1,2)
  NOMIDT = num$(NBVAL)+"/"+num$(IDTHEA)+"/"+"*"
 Else : # Table liée
  IDTLIN += 1
  NOMIDT = num$(NBVAL)+"/"+num$(IDTHEA)+"/"+num$(IDTLIN)
 Endif
Endif

Default Mask [HAE2]

# Montant
MONTLIG = 0
Call EVAL_NUM(MONTLIG,"AMT",2,I,0,STAT)
If STAT : MESSA = "AMT" : Return : Endif

# Montant forcés
For IREF=1 To NBREF
 TMONTFORCE(IREF) = 0
 If find(IREF,XTLEDTYP(1..XNBREF))
  GREF = IREF
  Call EVAL_NUM(TMONTFORCE(IREF),"AMTL"+num$(IREF),2,I,0,STAT)
  Raz GREF
 Endif
 If STAT : MESSA = "AMTL"+num$(IREF) : Return : Endif
Next

Raz TPLAN, TCOMPTE, TSAC, TIERS, PLGEN, PLANA, CPTGEN, CPTANA

Call SETPLANAXE([M]CPY,NBLEDTYP,TLEDTYP,NBPLAN,TPLAN,NBDIE,TDIE,TOBLIG) From CPTDIV

Call CPTNAT(NBLEDTYP,TLEDTYP,TPLAN,TCOMPTE,TSAC,TIERS,1,[M:HAE0]TYP-[M:HAE0]NUM,[M:HAE1]DUDDAT,STAT,MESSA) From TRTPCE

## On ne bloque pas si aucun compte trouvé et que la ligne est nulle, sachant qu'on exclut de ce mécanisme
## les pièces auto de Stock et Manufacturing (module 7 et 8)
## => Si montant ligne d'écriture nulle (y compris montants forcés) + pas de compte trouvé + la ligne de pièce auto
## n'a pas de formule quantité => on ignore la ligne de pièce auto
ACC_FND = 1
If !find([F:GAU]MODULE,7,8)
 If STAT = 29 & MONTLIG = 0
  STAT = 0 : ACC_FND = 0
  For IREF=1 To NBREF
   If TMONTFORCE(IREF) <> 0
    STAT = 29 : Break
   Endif
  Next
  If !STAT & !ACC_FND
   Read [GAG]GAG0 = [F:GAU]COD ; [F:GAD]LINNUM ; "QTY"
   If !fstat & [F:GAG]FORCLC<>""
    STAT = 29
   Endif
  Endif
 Else
  ACC_FND = 1
 Endif
 If !ACC_FND & !STAT : Return : Endif
Endif

If STAT : Return : Endif
Call RECH_ACC(1,[M]CPY,TLEDTYP,NBLEDTYP,TPLAN,TCOMPTE,PLGEN,CPTGEN) From CPTDIV
Call RECH_ACC(2,[M]CPY,TLEDTYP,NBLEDTYP,TPLAN,TCOMPTE,PLANA,CPTANA) From CPTDIV
Call SUIVI_ANA([M]CPY,TLEDTYP,NBLEDTYP,TPLAN,TCOMPTE,[M:HAEF]DIE,[M:HAEF]NBRAXI,SUIVI) From CPTDIV
If !SUIVI : Raz CPTANA : Endif

# Site à la ligne
SITE = ""
Call EVAL_CHAR(SITE,"FCY",2,I,[M]FCY,STAT)
If STAT : MESSA = "FCYLIN" : Return : Endif

# Taxe
Call LEC_GAC(CPTGEN,PLGEN) From CPTLEC
If dim([F:GAC]FLGVAT)>0 & [F:GAC]FLGVAT=1
 TAXE = ""
Elsif dim([F:GAC]VAT)>0
 Call EVAL_CHAR(TAXE,"TAX",2,I,[F:GAC]VAT,STAT)
 If STAT : MESSA = "TAX" : Return : Endif
Endif

# Répartition
If CPTANA<>""
 Call EVAL_CHAR(REPART,"DSP",2,I,"",STAT)
 If STAT : MESSA = "DSP" : Return : Endif
Else
 REPART = ""
Endif

# Sens
Call EVAL_NUM(SENS,"SNS",2,I,1,STAT)
If STAT : MESSA = "SNS" : Return : Endif

# Libellé
Call EVAL_CHAR(LIBEL,"DES",2,I,[M]DESVCR,STAT)
If STAT : MESSA = "DES" : Return : Endif

# Critère regroupement libre
Call EVAL_CHAR(CRIGRP,"LIB",2,I,"",STAT)
If STAT : MESSA = "CRITGRP" : Return : Endif

SNSLIG = SENS # par défaut

If MONTLIG<>0
 SNSLIG = SENS*sgn(MONTLIG)
Else
 For TYPREF=1 To len(mess(0,2644,1))
  If TMONTFORCE(TYPREF)<>0
   SNSLIG = SENS*sgn(TMONTFORCE(TYPREF)) : Break
  Endif
 Next
Endif

# On tente de regrouper par comptes + section si USA
CRITIMP = ""
Gosub AV_CREAT_X From =PROG
If STAT : Return : Endif


OKREGROUP = 0
CLEGRP = SITE
For I=1 To [M:HAEF]NBRLED
 INDREF = find([M:HAEF]LEDTYP(I-1),TLEDTYP(1..NBLEDTYP))
 If !INDREF
  CLEGRP += "/"
 Else
  CLEGRP += "/"+TCOMPTE(INDREF)
 Endif
Next
CLEGRP += "/"+TIERS+"/"+TAXE+"/"+REPART+"/"+LIBEL+"/"+CRITIMP
If [F:GAD]DEBCDT<>2
 CLEGRP += "/"+num$(SNSLIG)
Else
 CLEGRP += "/0"
Endif
If TYPVAL = 2
 Filter [GRM] Where (CODACE1=[F:GAU]COD & LIG1=[F:GAD]LINNUM & INVMTC<>2) | (CODACE2=[F:GAU]COD & LIG2=[F:GAD]LINNUM)
 Read [GRM]GRM0 First
 If !fstat
  CLEGRP += "/"+num$([F:GAD]LINNUM)
 Endif
 Filter [GRM]
Endif
If REGROUP
 CLEGRP += "/"+CRIGRP
Endif
If FLGDEM = 2
 CLEGRP += "/"+num$([F:GAD]LINNUM)+"/"+num$([F:GAD]CPALIN)
Endif

If GCALL_PT : GPOINT = "CLEGRP" : Gosub ENTREE From EXEFNC : Endif

NOL = find(CLEGRP,TBGRP(1..NBGRP))-1
If NOL<0
 NOL = NBGRP : NBGRP += 1
 If NBGRP > MAXLIG : STAT = 34 : Return  : Endif
 TBGRP(NBGRP) = CLEGRP
Else
 OKREGROUP = 1
Endif
nolign = NOL+1

If [L]TYPVAL = 2
 Gosub LIGNE From PAYCPTA
 If GOK<1 | STAT : Return : Endif
Endif

If [F:GAU]TRCFLG=2 & [F:GAD]TRCFLG=2
 Gosub TRCVCR From CPTTRCVCR
Endif

[M]FCYLIN(NOL) = SITE
[M]BPR(NOL) = TIERS
For I=1 To NBLEDTYP
 INDREF = find(TLEDTYP(I),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
 If INDREF
  Assign "[M]ACC"+num$(INDREF)+"("+num$(NOL)+")" With TCOMPTE(I)
  Assign "[M]SAC"+num$(INDREF)+"("+num$(NOL)+")" With TSAC(I)
  If [M]AUTACE=PCEMTE
   Assign "[M]COA1("+num$(NOL)+")" With TPLAN(I)
   Assign "[M]ACC1("+num$(NOL)+")" With TCOMPTE(I)
   Assign "[M]SAC1("+num$(NOL)+")" With TSAC(I)
   Assign "[M]LEDTYP"+"("+num$(NOL)+")" With TLEDTYP(I)
  Endif
 Endif
Next
[M]TAX(NOL) = TAXE
[M]DSP(NOL) = REPART
[M]DES(NOL) = LIBEL
If CRITIMP<>""
 [M]CRITGRPIMP(NOL) = CRITIMP
Else
 [M]CRITGRPIMP(NOL) = "1=1"
Endif
If CRIMTC<>""
 [M]CRIMTC(NOL) = CRIMTC
Else
 [M]CRIMTC(NOL) = "1=1"
Endif

Read [GAG]GAG0 = [F:GAD]COD;[F:GAD]LINNUM;"LIB"
If !fstat
 [M]CRITGRP(NOL) = [F:GAG]FORCLC+"="+CRIGRP

 If [F:GAD]LINTBL1<>""
  Read [ATB]CODFIC = [F:GAD]LINTBL1
  K0 = instr(1,[F:GAG]FORCLC,"TB1")
  If K0>0
   K0 += 4
   CRICLC  = right$([F:GAG]FORCLC,K0)
   K1 = instr(1,CRICLC,")")
   If K1
    CRICLC = left$(CRICLC,len(CRICLC)-1)
   Endif
   Read [ATZ2]CODZONE = [F:GAD]LINTBL1 ; CRICLC
   If !fstat
    If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
    Read [ATY]CODTYP = [F:ATZ2]CODTYP
    If !fstat & [F:ATY]TYPTYP = 7
     [M]CRITGRP(NOL) = [F:GAG]FORCLC+"="+"'"+CRIGRP+"'"
    Endif
   Endif
  Endif

  Call SUBST([M]CRITGRP(NOL),"TB1",[F:ATB]ABRFIC) From SUBGAU
  Repeat
   K1 = instr(1,[M]CRITGRP(NOL),"Num$(") : K2 = 5
   If !K1 : K1 = instr(1,[M]CRITGRP(NOL),"num$(") : K2 = 5 : Endif
   If !K1 : K1 = instr(1,[M]CRITGRP(NOL),"NUM$(") : K2 = 5 : Endif
   If !K1 : K1 = instr(1,[M]CRITGRP(NOL),")") : K2 = 1 : Endif
   If K1
    [M]CRITGRP(NOL) = left$([M]CRITGRP(NOL),K1-1)+right$([M]CRITGRP(NOL),K1-1+K2+1)
   Endif
  Until K1=0
 Endif
Else
 [M]CRITGRP(NOL) = "1=1"
Endif

If !OKREGROUP
 # Si ligne 1 de la pièce auto est regroupée avec la ligne 3 de la pièce auto, on veut
 # stocker 1 dans [M]LIGPCEAUTO(NOL)
 [M]LIGPCEAUTO(NOL) = [F:GAD]LINNUM
Endif
If REGROUP
 [M]INDGRP(NOL) = 1
Endif

If FLGDEM=2 & dim([M]CPALIN)>0
 [M]CPALIN(NOL) = [F:GAD]CPALIN
 TNBIDT(NOL+1) += 1
 TIDT(NOL+1,TNBIDT(NOL+1)) = NOMIDT
Endif


# Stats
Call EVAL_CHAR([M]STT1(NOL),"ST1",2,I,"",STAT)
If STAT : MESSA = "ST1" : Return : Endif
If [M]STT1(NOL)<>""
 Read [ADI]CODE = 351;[M]STT1(NOL)
 If fstat : [M]STT1(NOL) = "" : Endif
Endif
Call EVAL_CHAR([M]STT2(NOL),"ST2",2,I,"",STAT)
If STAT : MESSA = "ST2" : Return : Endif
If [M]STT2(NOL)<>""
 Read [ADI]CODE = 352;[M]STT2(NOL)
 If fstat : [M]STT2(NOL) = "" : Endif
Endif
Call EVAL_CHAR([M]STT3(NOL),"ST3",2,I,"",STAT)
If STAT : MESSA = "ST3" : Return : Endif
If [M]STT3(NOL)<>""
 Read [ADI]CODE = 353;[M]STT3(NOL)
 If fstat : [M]STT3(NOL) = "" : Endif
Endif

# Contrepartie
For TYPREF=1 To NBLEDTYP
 ZONE_A = "OFF"+num$(TLEDTYP(TYPREF))
 INDREF = find(TLEDTYP(TYPREF),[M:HAEF]LEDTYP(0..[M:HAEF]NBRLED-1))
 Call EVAL_CHAR([L]OFFACC,ZONE_A,2,I,"",STAT)
 If STAT : MESSA = "CPA"-mess(TLEDTYP(TYPREF),2644,1) : Return : Endif
 If INDREF
  Assign "[M]CPA"+num$(INDREF)+"("+num$(NOL)+")" With [L]OFFACC
 Endif
Next

# Consolidation : Partenaire
Call EVAL_CHAR([M]CSLCOD(NOL),"CSLC",2,I,"",STAT)
If STAT : MESSA = "CSLCOD" : Return : Endif

# Consolidation : Flux
If dim([M]CSLFLO)>0
 Call EVAL_CHAR([M]CSLFLO(NOL),"CSLF",2,I,"",STAT)
 If STAT : MESSA = "CSLFLO" : Return : Endif
Endif

# Référence libre
Call EVAL_CHAR([M]FREREF(NOL),"FREREF",2,I,"",STAT)
If STAT : MESSA = "FREREF" : Return : Endif

# Identifiant ligne
Call EVAL_CHAR([M]IDTLIN(NOL),"IDL",2,I,"",STAT)
If STAT : MESSA = "IDTLIN" : Return : Endif

# Quantité, unité
QTELIG = 0
If CPTANA<>""
 Call EVAL_NUM(QTELIG,"QTY",2,I,0,STAT)
 If STAT : MESSA = "QTY" : Return : Endif
 If QTELIG<>0
  Call EVAL_CHAR(UNITE,"UNT",2,I,"",STAT)
  Call LEC_GAC(CPTANA,PLANA) From CPTLEC
  If [F:GAC]UOM<>""
   If UNITE<>"" & UNITE<>[F:GAC]UOM
    Call CALCUL_QTY(QTELIG,UNITE,QTELIG,[F:GAC]UOM,COEUOM) From TRTX3
   Endif
  Else
   QTELIG = 0
  Endif
 Endif
Endif
If SENS>0
 [M]DEB(NOL) += MONTLIG
Else
 [M]CDT(NOL) += MONTLIG
Endif
[M]QTY(NOL) += SENS*QTELIG

## Dans un premier temps, on comptabilise les montants forcés avec leurs signes
For I=1 To NBREF
 If evalue("TMONTFORCE("+num$(I)+")")<>0
  Assign "[M]AMTFRC"+num$(I)+"("+num$(NOL)+")" With evalue("[M]AMTFRC"+num$(I)+"("+num$(NOL)+")")+
&         (SENS*evalue("TMONTFORCE("+num$(I)+")"))
  Assign "[M]AMTFLG"+num$(I)+"("+num$(NOL)+")" With 1
 Endif
Next

If [F:GAD]FLGDUD = 2 : [M]FLGDUD(NOL) = 2 : Endif

Gosub AP_CREAT_X From =PROG
If STAT : Return : Endif

If GCALL_PT : GPOINT = "LIGNE" : Gosub ENTREE From EXEFNC : Endif
Return

###################################################
$LIGANA
If CPTANA<>"" & [M]DSP(NOL)=""
 Gosub CHERCHE_VENT
 If STAT : Return : Endif
 [M:VT2]TBAMT(VENT) += SENS*MONTLIG
 [M:VT2]TBQTY(VENT) += SENS*QTELIG
 If GCALL_PT : GPOINT = "LIN_ANA" : Gosub ENTREE From EXEFNC : Endif
Endif
Return

##############################################################
$LIGREP
If CPTANA<>""
 Gosub CHERCHE_VENT
 If STAT : Return : Endif

 # Montant
 Call EVAL_NUM(MONTANA,"AMTA",2,I,0,STAT)
 If STAT : MESSA = "TBAMT" : Return : Endif
 [M:VT2]TBAMT(VENT) += SENS*MONTANA

 # Quantité
 Call EVAL_NUM(QTEANA,"QTYA",2,I,0,STAT)
 If STAT : MESSA = "TBQTY" : Return : Endif
 If UNITE<>""
  Call LEC_GAC(CPTANA,PLANA) From CPTLEC
  If [F:GAC]UOM<>"" & UNITE<>[F:GAC]UOM
   Call CALCUL_QTY(QTEANA,UNITE,QTEANA,[F:GAC]UOM,COEUOM) From TRTX3
  Endif
 Endif
 [M:VT2]TBQTY(VENT) += SENS*QTEANA

 If GCALL_PT : GPOINT = "LIN_ANA" : Gosub ENTREE From EXEFNC : Endif
Endif
Return

##############################################################
$CHERCHE_VENT
# Sections
Gosub EVALSEC
If STAT : Return : Endif
If [M]PTV(NOL)=0
 If ([M:VT2]PTVENT+1)>=dim([M:VT2]TBAMT)
  #Trop de ventilations analytiques
  STAT = 48 : Return
 Endif
 [M:VT2]PTVENT += 1
 VENT = [M:VT2]PTVENT
 [M]PTV(NOL) = VENT
 [M]PTF(NOL) = VENT
Else
 VENT = 0
 For V=[M]PTV(NOL) To [M]PTF(NOL)
  GRPVENT=""
  For AXE=1 To [M:HAEF]NBRAXI
   GRPVENT += evalue("[M:VT2]TBCCE"+num$(AXE)+"("+num$(V)+")")+"/"
  Next AXE
  If GRPVENT=GRPSEC
   VENT = V : Break
  Endif
 Next V
 If VENT=0
  If [M:VT2]PTVENT=[M]PTF(NOL)
   [M:VT2]PTVENT += 1
   VENT = [M:VT2]PTVENT
   [M]PTF(NOL) = VENT
  Else
   VD = [M:VT2]PTVENT+1
   VF = [M:VT2]PTVENT+1
   For V=[M]PTV(NOL) To [M]PTF(NOL)
    [M:VT2]TBAMT(VF) = [M:VT2]TBAMT(V)
    [M:VT2]TBQTY(VF) = [M:VT2]TBQTY(V)
    For AXE=1 To [M:HAEF]NBRAXI
     Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$(VF)+")" With evalue("[M:VT2]TBCCE"+num$(AXE)+"("+num$(V)+")")
    Next AXE
    VF += 1
   Next V
   [M:VT2]PTVENT = VF
   PTVA = [M]PTF(NOL)-[M]PTV(NOL)+1
   Call ANUVENTIL([M]PTV,[M]PTF,NBGRP,[M]PTV(NOL),PTVA) From VENTILE
   VD -= PTVA
   VF -= PTVA
   [M]PTV(NOL) = VD
   [M]PTF(NOL) = VF
   VENT = VF
   [M]TBAMT(VENT) = 0
   [M]TBQTY(VENT) = 0
  Endif
 Endif
Endif
For AXE=1 To [M:HAEF]NBRAXI
 Assign "[M:VT2]TBCCE"+num$(AXE)+"("+num$(VENT)+")" With evalue("[L]SEC"+num$(AXE))
Next AXE
Return

$EVALSEC
# Initialization of the dimensions
# => 1st step : Read the dimension type and the dimension of the automatic journal
# => 2nd step : No dimension found and the dimention type is mandatory
#               Initialize the dimension with the default dimension defined in the account that is tracked on this dimension type

Local Integer NLD, VU, VU2, IND, AXI
GRPSEC = ""
For AXE=1 To GOPTCANA
 Assign "[L]SEC"+num$(AXE) With ""
Next
For AXE=1 To GOPTCANA
 Call EVAL_CHAR(AXEANA,"DIE"+num$(AXE),2,I,"",STAT)
 If STAT : MESSA = "DIE"+num$(AXE) : Break : Endif
 INDAXE = find(AXEANA,[M:HAEF]DIE(0..GOPTCANA-1))
 If INDAXE & AXEANA<>""
  Assign "[L]DIE"+num$(INDAXE) With AXEANA
  For NLD = 1 To [M:HAEF]NBRLED
   Call INDLED([M:HAEF]LED(NLD-1),[L]AXEANA,IND,AXI) From CPTDIV
   If IND>0 & GLEDFLGANA(IND)=2 & AXI
    ## Performances when creating accounting entries (save the 20 first account)
    ## (EVALSEC called by LIGANA from CPTAUTO but LIGANA called by IPTACPT/CPTTRS)
    If dim(GGACKEY)>0
     WGACKEY = evalue("[M]ACC"+num$(NLD)+"("+num$(NOL)+")")+"/"+[M:HAEF]COA(NLD-1)
     INDGAC=find(WGACKEY,GGACKEY(0..GGACKEYNBR))
     If INDGAC=0 & GGACKEYNBR<dim(GGACKEY)-1
      Call LEC_GAC(evalue("[M]ACC"+num$(NLD)+"("+num$(NOL)+")"),[M:HAEF]COA(NLD-1)) From CPTLEC
      GGACKEY(GGACKEYNBR) = WGACKEY
      GGACDIENBR(GGACKEYNBR) = [F:GAC]DACDIENBR
      For J=0 To [F:GAC]DACDIENBR-1
       GGACDIE(J,GGACKEYNBR) = [F:GAC]DIE(J)
       GGACCCE(J,GGACKEYNBR) = [F:GAC]CCEDEF(J)
      Next
      GGACKEYNBR+=1
      INDGAC=GGACKEYNBR
     Endif
    Endif
    If dim(GGACKEY)>0 & INDGAC>0 ## Perf - Account saved on the Global.
     VU = find([L]AXEANA,GGACDIE(0..GGACDIENBR(INDGAC-1)-1,INDGAC-1))
     If VU
      Call EVAL_CHAR(SECTION,"CCE"+num$(AXE),2,I,"",STAT)
      If STAT : MESSA = "CCE"+num$(AXE) : Break 2 : Endif
      If SECTION<>""
       Assign "[L]SEC"+num$(INDAXE) With SECTION : Break
      Elsif SECTION = ""
       VU2 = find([L]AXEANA,TDIE(1..NBDIE))
       If VU2 & TOBLIG(VU2) = 2 & GGACCCE(VU-1,INDGAC-1)<>""
        Assign "[L]SEC"+num$(INDAXE) With GGACCCE(VU-1,INDGAC-1) : Break
       Endif
      Endif
     Endif
    Else
     # old process... Read Account
     Call LEC_GAC(evalue("[M]ACC"+num$(NLD)+"("+num$(NOL)+")"),[M:HAEF]COA(NLD-1)) From CPTLEC
     VU = find([L]AXEANA,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
     If VU
      Call EVAL_CHAR(SECTION,"CCE"+num$(AXE),2,I,"",STAT)
      If STAT : MESSA = "CCE"+num$(AXE) : Break 2 : Endif
      If SECTION<>""
       Assign "[L]SEC"+num$(INDAXE) With SECTION : Break
      Elsif SECTION = ""
       VU2 = find([L]AXEANA,TDIE(1..NBDIE))
       If VU2 & TOBLIG(VU2) = 2
        If [F:GAC]CCEDEF(VU-1)<>""
         Assign "[L]SEC"+num$(INDAXE) With [F:GAC]CCEDEF(VU-1) : Break
        Endif
       Endif
      Endif
     Endif
    Endif
   Endif
  Next NLD
 Endif
Next AXE
If STAT : Return : Endif
For AXE=1 To [M:HAEF]NBRAXI
 GRPSEC += evalue("[L]SEC"+num$(AXE))+"/"
Next
Return

######################################################
$FINREP
If [M]PTF(NOL)=[M]PTV(NOL) : # 1 seule ligne
 VENT = [M]PTV(NOL)
 For AXE=1 To [M:HAEF]NBRAXI
  Assign "[M]CCE"+num$(AXE)+"("+num$(NOL)+")" With evalue("[M:VT2]TBCCE"+num$(AXE)+"("+num$(VENT)+")")
 Next AXE
 [M]PTV(NOL) = 0 : [M]PTF(NOL) = 0
Elsif [M]PTF(NOL)>[M]PTV(NOL)
 [M]DSP(NOL) = "$"
Endif
Return

######################################################
$DEBCDT
If [F:GAU]NEGAMT<>2 or ([M]DEB(NOL)<>0 and [M]CDT(NOL)<>0)
 [M]DEB(NOL) = [M]DEB(NOL)-[M]CDT(NOL)
 [M]CDT(NOL) = 0
 If [M]DEB(NOL)<0
  [M]CDT(NOL) = -[M]DEB(NOL)
  [M]DEB(NOL) = 0
 Endif
Endif
If [M]CDT(NOL)<>0
 [M]QTY(NOL) = -[M]QTY(NOL)
 If [M]PTV(NOL)<>0
  For V=[M]PTV(NOL) To [M]PTF(NOL)
   [M:VT2]TBAMT(V) = -[M:VT2]TBAMT(V)
   [M:VT2]TBQTY(V) = -[M:VT2]TBQTY(V)
  Next V
 Endif
Endif

## On force le signe>0 des montants forcés s'il y a un montant pièce<>0
If [M]DEB(NOL)<>0 or [M]CDT(NOL)<>0
 If [M]FLGREP = 2
  For IREF=1 To NBREF
   If evalue("[M]AMTFLG"+num$(IREF)+"("+num$(NOL)+")")<>0
    If [M]CDT(NOL)>0 & evalue("[M]AMTFRC"+num$(IREF)+"("+num$(NOL)+")")>0
     Assign "[M]AMTFRC"+num$(IREF)+"("+num$(NOL)+")" With evalue("[M]AMTFRC"+num$(IREF)+"("+num$(NOL)+")")*-1
    Elsif [M]DEB(NOL)>0 & evalue("[M]AMTFRC"+num$(IREF)+"("+num$(NOL)+")")<0
     ## Pas de valeur absolue
    Else
     Assign "[M]AMTFRC"+num$(IREF)+"("+num$(NOL)+")" With abs(evalue("[M]AMTFRC"+num$(IREF)+"("+num$(NOL)+")"))
    Endif
   Endif
  Next
 Else
  For IREF=1 To NBREF
   If evalue("[M]AMTFLG"+num$(IREF)+"("+num$(NOL)+")")<>0
    Assign "[M]AMTFRC"+num$(IREF)+"("+num$(NOL)+")" With abs(evalue("[M]AMTFRC"+num$(IREF)+"("+num$(NOL)+")"))
   Endif
  Next
 Endif
Else
 ## Et si le montant pièce = 0 ???? que fait-on ?
Endif
Return


$ERREUR
ERR = errn
Resume

Subprog EVAL_CHAR(ZONE,EXPR,CAS,I,VALDEF,STAT)
Variable Char    ZONE
Value    Char    EXPR
Value    Integer CAS
Value    Integer I
Value    Char    VALDEF
Variable Integer STAT
ZONE = "" : Gosub EVALE
If ZONE="" : ZONE = VALDEF : Endif
End

Subprog EVAL_NUM(ZONE,EXPR,CAS,I,VALDEF,STAT)
Variable Decimal ZONE
Value    Char    EXPR
Value    Integer CAS
Value    Integer I
Value    Decimal VALDEF
Variable Integer STAT
ZONE = 0 : Gosub EVALE
If ZONE=0 : ZONE = VALDEF : Endif
End

Subprog EVAL_INT(ZONE,EXPR,CAS,I,VALDEF,STAT)
Variable Integer ZONE
Value    Char    EXPR
Value    Integer CAS
Value    Integer I
Value    Integer VALDEF
Variable Integer STAT
ZONE = 0 : Gosub EVALE
If ZONE=0 : ZONE = VALDEF : Endif
End

Subprog EVAL_DATE(ZONE,EXPR,CAS,I,VALDEF,STAT)
Variable Date    ZONE
Value    Char    EXPR
Value    Integer CAS
Value    Integer I       : # Cet argument sert pour les evalue
Value    Date    VALDEF
Variable Integer STAT
ZONE = [0/0/0] : Gosub EVALE
If ZONE=[0/0/0] : ZONE = VALDEF : Endif
End

$EVALE
Local Integer I , ERR
Local Char    PROG(10)
PROG = "WMGAU"+[F:GAU]COD
Onerrgo ERREUR
Case CAS
 When 1
  Gosub EVAL0 From =PROG
 When 2
  Gosub EVAL_X From =PROG
 When 3
  Gosub ACC_X From =PROG
Endcase
Onerrgo
If ERR
 Case CAS
  When 1
   If clalev([F:GAG])=0 : Local File GAUTACEF [GAG] : Endif
   Read [GAG]GAG0 = [F:GAU]COD;0;EXPR
   GMESSAGE = vireblc(format$("KT:80X",[F:GAG]FORCLC),2)
  When 2
   If clalev([F:GAG])=0 : Local File GAUTACEF [GAG] : Endif
   Read [GAG]GAG0 = [F:GAU]COD;[F:GAD]LINNUM;EXPR
   GMESSAGE = vireblc(format$("KT:80X",[F:GAG]FORCLC),2)
  When 3
   GMESSAGE = vireblc(format$("KT:80X",[F:GAD]ACCKEY(val(EXPR))),2)
 Endcase
 STAT = 9
Endif
Return

###############################################
Subprog CRECPT(PLAN,COMPTE,DESIG,TAXE,OK)
Value    Char    PLAN
Value    Char    COMPTE
Value    Char    DESIG
Value    Char    TAXE
Variable Integer OK

Local Integer I , NOL , DUPLI
Local Char    CLAS(GLONCLA)
Local Integer ILED, NBLED
Local Char    PLAN_DES(GLONCOA)
Local Char    CODLED(GLONLED)(1..len(mess(0,2644,1)))
If clalev([F:GAC])=0  : Local File =GTABCPT+"GACCOUNT"   [GAC]  : Endif
If clalev([F:GAC2])=0 : Local File =GTABCPT+"GACCOUNT"   [GAC2] : Endif
If clalev([F:GRY])=0  : Local File =GTABCPT+"GACCGRUPYM" [GRY]  : Endif
If clalev([F:COA])=0  : Local File =GTABCPT+"GCOA"       [COA]  : Endif
If clalev([F:CLS])=0  : Local File =GTABCPT+"GACCCLS"    [CLS]  : Endif
If clalev([F:GCF])=0  : Local File =GTABCPT+"GACCDEF"    [GCF]  : Endif
If clalev([F:GCD])=0  : Local File =GTABCPT+"GACCDIM"    [GCD]  : Endif
If clalev([F:LED])=0  : Local File =GTABCPT+"GLED"       [LED]  : Endif
If clalev([F:CLS])=0  : Local File =GTABCPT+"GACCCLS"    [CLS]  : Endif
If GCOMPTA<>3  :# Compta
 If clalev([F:PBS])=0 : Local File =GTABCPT+"GAPARBSE" [PBS] : Endif
Endif

## Vérification préalable
OK = 1

# BY (09/02/2009) A priori il ne faut plus faire ce contrôle
#For I=len(COMPTE) To 1 Step-1
# Read [GAC]GAC0 = PLAN;left$(COMPTE,I)
# If fstat=0 & [F:GAC]SAC=2
#  # Il existe le collectif
#  GMESSAGE = COMPTE-":"-mess(41,102,1)-[F:GAC]ACC
#  OK = 0 : Break
# Endif
#Next I
#If !OK : End : Endif

# Par contre celui-ci est pour le Portugal (et inclut l'ancien contrôle)

Call VERIF_CUMUL(PLAN,COMPTE,1,0,OK) From SUBGAC
If !OK : End : Endif

Gosub TR1
End

$TR1

# 1) On recherche un compte de racine voisine

DUPLI = 0
For I=len(COMPTE) To 1 Step -1
 Filter [GAC] Where COA=[L]PLAN & ACC>=left$(COMPTE,I) & SAC<>2
 Read [GAC]GAC0 First
 If fstat<=2 & left$([F:GAC]ACC,I)=left$(COMPTE,I)
  DUPLI = 1 : Break
 Endif
Next I
Filter [GAC]
If !DUPLI
 Raz [F:GAC]
Endif

# 2) On affecte ce qu'on connaît sur le compte

[F:GAC]COA    = PLAN
[F:GAC]ACC    = COMPTE
[F:GAC]SAC    = 1
# Dans le cadre d'une duplication, je conserve la classe de compte initiale.
If [F:GAC]CLSCOD=""
 Call CLASSE(PLAN,COMPTE,CLAS) From SUBGAC
 [F:GAC]CLSCOD = CLAS
Endif
If [F:GAC]CLSCOD=""
 Call LEC_COA(PLAN) From CPTLEC
 Filter [CLS] Where LEG=[F:COA]LEGCLS
 Read [CLS]CLS0 Last
 [F:GAC]CLSCOD=[F:CLS]CLSCOD
 Filter [CLS]
Endif

If GCOMPTA<>3   :# Compta
 For NOL=0 To dim([F:GAC]BSEDEB)-1
  For I=len(COMPTE) To 1 Step -1
   Read [PBS]PBS0 = PLAN ; num$(NOL+1) ; left$(COMPTE,I)
   If !fstat
    [F:GAC]RPTCODDEB(NOL) = [F:PBS]CODDEB
    [F:GAC]RPTCODCDT(NOL) = [F:PBS]CODCDT
    Break
   Endif
  Next I
 Next NOL
Endif
Call SETREF(GSOCIETE,NBLED,CODLED) From CPTDIV
#Raz tableau compte par défaut
For I=0 To [F:GAC]COANBR-1
 [F:GAC]OTHCOA(I) = ""
 [F:GAC]DEFACC(I) = ""
 [F:GAC]SCRACC(I) = ""
Next
[F:GAC]COANBR = 0
For ILED = 1 To NBLED
 Call LEC_LED(CODLED(ILED)) From CPTLEC
 PLAN_DES = [F:LED]COA
 For I=len(COMPTE) To 1 Step -1
  Read [GCF]GCF0 = PLAN ; PLAN_DES ; left$(COMPTE,I)
  If !fstat & [F:GAC]COANBR<dim([F:GAC]OTHCOA)
   [F:GAC]OTHCOA([F:GAC]COANBR) = [F:GCF]COADEN #[F:GCF]COAORI
   [F:GAC]DEFACC([F:GAC]COANBR) = [F:GCF]ACC
   [F:GAC]SCRACC([F:GAC]COANBR) = "*" : # Pour ne pas refuser le compte plus tard...
   [F:GAC]COANBR += 1
   Break
  Endif
 Next I
Next ILED
#Raz tableau section
For I=0 To [F:GAC]DACDIENBR-1
 [F:GAC]DIE(I) = ""
 [F:GAC]CCEDEF(I) = ""
Next
[F:GAC]DACDIENBR = 0
For [GCD]GCD0 Where COA=PLAN
 If left$([F:GAC]ACC,len([F:GCD]ACCSTR))=[F:GCD]ACCSTR
  I = find([F:GCD]DIE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
  If !I
   If [F:GAC]DACDIENBR<dim([F:GAC]DIE)
    [F:GAC]DIE([F:GAC]DACDIENBR)    = [F:GCD]DIE
    [F:GAC]CCEDEF([F:GAC]DACDIENBR) = [F:GCD]CCE
    [F:GAC]DACDIENBR += 1
   Endif
  Elsif [F:GAC]CCEDEF(I-1)=""
   [F:GAC]CCEDEF(I-1) = [F:GCD]CCE
  Endif
 Endif
Next
[F:GAC]ACS    = ""
[F:GAC]ACCSHO = ""
If dim([F:GAC]SUBACC)>0 : [F:GAC]SUBACC = "" : Endif
If dim([F:GAC]SUBBPR)>0 : [F:GAC]SUBBPR = "" : Endif
[F:GAC]FCY    = ""
[F:GAC]VLYSTR = [0/0/0]
[F:GAC]VLYEND = [0/0/0]
If dim([F:GAC]FLGVAT)>0 & [F:GAC]FLGVAT>1
 [F:GAC]VAT = TAXE
Endif

Call MAJTEXTRA(DESIG,"GACCOUNT","DESTRA",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
Call MAJTEXTRA([F:GAC]ACC,"GACCOUNT","DESSHO",[F:GAC]COA,[F:GAC]ACC) From ATEXTRA
If dim([F:GAC]CREDAT)>0 : [F:GAC]CREDAT = date$ : Endif
If dim([F:GAC]CREUSR)>0 : [F:GAC]CREUSR = GUSER : Endif
If dim([F:GAC]EXPNUM)>0 : [F:GAC]EXPNUM = [C]EXPORT : Endif

# 3) On affecte comme on peut si on n'a pas trouvé de modèle

If !DUPLI
 If dim([F:GAC]CEN)>0    : [F:GAC]CEN = 1    : Endif
 If dim([F:GAC]DAS)>0    : [F:GAC]DAS = 1    : Endif
 If dim([F:GAC]DIF)>0    : [F:GAC]DIF = 1    : Endif
 If dim([F:GAC]FLGVAT)>0 : [F:GAC]FLGVAT = 1 : Endif
 If [F:COA]COA<>PLAN
  Read [COA]COA0 = PLAN
 Endif
 Read [CLS]CLS0 = [F:COA]LEGCLS;CLAS
 If dim([F:GAC]SNSBLC)>0 : [F:GAC]SNSBLC = [F:CLS]DEFSNS : Endif
 If dim([F:GAC]SNSDEF)>0 : [F:GAC]SNSDEF = [F:CLS]DEFSNS : Endif
Endif

# 5) On crée le compte

Write [GAC]
If fstat
 GOK = 0 : Call FSTA("GAC") From GLOCK : Return
Endif

Call ECR_TRACE(mess(91,107,1)-PLAN-COMPTE-DESIG,0) From GESECRAN
Return


$DCLTAB
If clalev([F:ATY])=0 : Local File ATYPE [ATY] : Endif
Local Integer L
Read [ATY]CODTYP = [F:ATZ]CODTYP
Case [F:ATY]TYPTYP
 When 7                          : # Alphanumérique
  If [F:ATY]LNGTYP<>0 : L = [F:ATY]LNGTYP
  Else                : L = [F:ATZ]LONG
  Endif
 When Default
  L = 10
Endcase
Local Char TVALCHP(L)(1..300)
Return


###############################################
Subprog CRESEC(AXE,SECTION,DESIG)
Value Char    AXE()
Value Char    SECTION()
Value Char    DESIG()
Local Integer I , NOL
If clalev([F:CCE])=0 : Local File =GTABCPT+"CACCE"     [CCE] : Endif
Gosub TR3
End

$TR3
Raz [F:CCE]
[F:CCE]DIE = AXE
Call INICCEFMT([F:CCE]DIE) From SETGLBDIE
[F:CCE]CCE = vireblc(format$(GCCEFMT,SECTION),2)
[F:CCE]DES = DESIG
If dim([F:CCE]BUDTRK)>0 : [F:CCE]BUDTRK = 2         : Endif
If dim([F:CCE]IPT)>0    : [F:CCE]IPT = 2            : Endif
If dim([F:CCE]CREDAT)>0 : [F:CCE]CREDAT = date$     : Endif
If dim([F:CCE]CREUSR)>0 : [F:CCE]CREUSR = GUSER     : Endif
If dim([F:CCE]EXPNUM)>0 : [F:CCE]EXPNUM = [C]EXPORT : Endif
Write [CCE]
If fstat
 GOK = 0 : Call FSTA("CCE") From GLOCK : Return
Endif
Return



Subprog SUBST(CHAINE,AB1,AB2)
Variable Char CHAINE
Value    Char AB1
Value    Char AB2
Local Integer K
Repeat
 K = instr(1,CHAINE,AB1)
 If K
  CHAINE = left$(CHAINE,K-1)+AB2+right$(CHAINE,K-1+len(AB1)+1)
 Endif
Until K=0
End

