#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
#infbox ACTION
Case ACTION
  
  When "AV_AFFICHE"  : Gosub AV_AFFICHE
  When Default
Endcase
Return


$AV_AFFICHE
Local integer i, otra

#    Gosub LECTURE from CNSCSISTD
#    [V]GPE = 1
      
     i = 0
     While I < [M:CSI2]NBLIG
        For [SIH] where [F:SIH]NUM  = [M:CSI2]NUM(i)
          If [F:SIH]XENVIADA <> 1 and [F:SIH]XENVIADA <> 2
            [M:CSI2]XENVIADA(i)=1
           else
           [M:CSI2]XENVIADA(i) = [F:SIH]XENVIADA
          endif
           Break
        Next
        i += 1
     Wend
     Affzo [M:CSI2]
Return




######################################################################################
## Etiqueta añadida por el supervisor (pantalla CONSCSI2) 18/09/2017 15:58:44 (ADMIN)
######################################################################################
Subprog IB_INVCAN
End


