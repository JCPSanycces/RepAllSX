#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#Infbox ACTION

Case ACTION
   When "OUVRE"    :  Gosub OUVRE
   When "FILTRE"   :  Gosub FILTRE
   When "LIENS"    :  Gosub LIENS
   When "CREATION" :  Gosub CREATION
   When "MODIF"    :  Gosub MODIF
   When "ANNULE"   :  Gosub ANNULE
   When "APRES_CRE":  Gosub APRES_CRE
   When "APRES_MOD" : Gosub APRES_MOD
   When "INICRE_LIG": Gosub INICRE_LIG
   When "DEFLIG" :    Gosub DEFLIG



  When Default
Endcase
Return

########################################################################

$OUVRE
Gosub DECLARE From TABLEAUX

Return

$FILTRE
Default File [XBPC]
Return

$LIENS
Gosub LIENS From TABLEAUX
#MRR 10/10/18 Añadir campo XENVIO en clientes entrega
# If GACTFTC=2
#    [M]XXENVIO = [M]XENVIO(0)
# Endif
#MRR 10/10/18 Añadir campo XENVIO en clientes entrega

Return

$CREATION

[F:XBPC]BPCNUM = [M:XBPC0]BPCNUM

Gosub CREATION From TABLEAUX
Update [F:XBPC] Where BPCNUM = '' With BPCNUM = [M:XBPC0]BPCNUM
Return

$MODIF
Gosub MODIF From TABLEAUX
Return

$ANNULE
Gosub ANNULE From TABLEAUX
Return

$APRES_CRE
Gosub LIENS From TABLEAUX
Return

$APRES_MOD
Gosub LIENS From TABLEAUX
Return

$INICRE_LIG
[F:XBPI]BPCNUM = [M:XBPC0]BPCNUM
Return

$DEFLIG
If !clalev([F:XBPI])   : Local File XBPDITM[XBPI]    : Endif
Default Mask [XBPC2]
Default File [XBPI]

CRIT="[F:XBPI]BPCNUM='"+[M:XBPC0]BPCNUM+"'"
FICLIG = "XBPDITM"
ABLIG = "XBPI"
ZONLIG = "LINEA"

Return

