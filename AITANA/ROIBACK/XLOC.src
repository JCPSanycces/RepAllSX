#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "DEBUT"   : Gosub DEBUT
  When "OK"      : Gosub OK
  When Default
Endcase
Return
#----------------------------------------------------------------------------------
$DEBUT
  Effzo [M:XLOC]XDATEINI
  Effzo [M:XLOC]XDATEFIN
  Effzo [M:XLOC]XCUGROINI
  Effzo [M:XLOC]XCUGROFIN
  Effzo [M:XLOC]XCUSTINI
  Effzo [M:XLOC]XCUSTFIN
  Effzo [M:XLOC]XCODCRSINI
  Effzo [M:XLOC]XCODCRSFIN
  Effzo [M:XLOC]XSDHNUMINI
  Effzo [M:XLOC]XSDHNUMFIN
  Effzo [M:XLOC]XCODCADINI
  Effzo [M:XLOC]XCODCADFIN
Return

#----------------------------------------------------------------------------------
$OK              #IMPRESIÓN INFORME XLOCALIZADOR
  Local Char FFIC(50)(1..5)
  Local Char TBPAR(20)(50), TBVAL(20)(50)

  If !clalev([F:SDH])   : Local File SDELIVERY[SDH]    : Endif

  FFIC(1) = 'XLOCALIZADOR.rpt'

#PARÁMETROS DEL INFORME
  TBPAR (1)  = "datedeb"      : TBVAL (1)  = [M:XLOC]XDATEINI
  TBPAR (2)  = "datefin"      : TBVAL (2)  = [M:XLOC]XDATEFIN
  TBPAR (3)  = "cligrudeb"    : TBVAL (3)  = [M:XLOC]XCUGROINI
  TBPAR (4)  = "cligrufin"    : TBVAL (4)  = [M:XLOC]XCUGROFIN
  TBPAR (5)  = "clientdeb"    : TBVAL (5)  = [M:XLOC]XCUSTINI
  TBPAR (6)  = "clientfin"    : TBVAL (6)  = [M:XLOC]XCUSTFIN
  TBPAR (7)  = "codcrsdeb"    : TBVAL (7)  = [M:XLOC]XCODCRSINI
  TBPAR (8)  = "codcrsfin"    : TBVAL (8)  = [M:XLOC]XCODCRSFIN
  TBPAR (9)  = "deliverydeb"  : TBVAL (9)  = [M:XLOC]XSDHNUMINI
  TBPAR (10) = "deliveryfin"  : TBVAL (10) = [M:XLOC]XSDHNUMFIN
  TBPAR (11) = "codcadeb"     : TBVAL (11) = [M:XLOC]XCODCADINI
  TBPAR (12) = "codcafin"     : TBVAL (12) = [M:XLOC]XCODCADFIN

#Infbox"fecha ini: "+TBVAL (1)
#Infbox"fecha fin: "+TBVAL (2)
#Infbox"cadena: "+TBVAL (11)

# Imprimir solo las entregas CRS NO validadas.
  C_FICHIER = filpath("ZPDF","XLOCALIZADOR","xls","","","") #filpath(DIRECTORY, filename, EXTENSION)
  Call ETAT("XLOCALIZADOR","","",0,"",TBPAR,TBVAL) From AIMP3
Return

