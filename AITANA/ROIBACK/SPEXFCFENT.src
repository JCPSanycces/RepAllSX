#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION

Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "DEBUT"      : Gosub DEBUT
  When "OK"         : Gosub OK
  When Default
Endcase
Return

$OUVRE

#infbox(action)
#Raz [M]

Return

$DEBUT

[M]SALFCY= ''
[M]Mes=0
[M]Anio=0
Affzo [M]SALFCY
Affzo [M]mes
Affzo [M]anio
Return

$OK
Local integer cur_ano, cur_mes, sumar,I,mes_temp,anio_temp,num_lin,mes_exp,anio_exp,mes_fin,anio_fin
Local Date fecha_dia, fectemp, f_ult_diames
Local Char reg(250), fecha_txt(8)
local char xfich(50),xdir(250),xext(3), FICHERO(250), XBPCORD_ANT(15), XBPAADD_ANT(15)
Local char importa,GRABA_CAB,ya_procesada

importa = '0'
cur_ano = [M]anio
cur_mes = [M]mes

If clalev([F:XSOP])  = 0  : Local File SORDERP [XSOP]      : Endif
If clalev([F:XSOH])  = 0  : Local File SORDER  [XSOH]      : Endif
If clalev([F:XSDD])  = 0  : Local File SDELIVERYD  [XSDD]      : Endif
If clalev([F:XSHD])  = 0  : Local File SDELIVERY  [XSHD]      : Endif

xdir = "C:\SAGE\APP\X3V9\folders\PROD\BQT"
xfich = "ENTREGAS_CF"
Xext = "txt"
FICHERO      = filpath(Xdir,xfich,xext,"","","")
Openo FICHERO,0 Using [XCSV]
Iomode adxirs chr$(13)+chr$(10) Using [XCSV]

XGRABA_CAB= '1'
XBPCORD_ANT=""
XBPAADD_ANT=""
For [XSOP]SOP1 where XCANPER > 0 and XFECINI > [00/00/0000]  & [F:XSOP]SALFCY = [M]SALFCY & [F:XSOP]SOQSTA <> 3
#infbox "aqui llega" - [F:XSOP]SOHNUM

    Read [XSOH]SOH0 = [F:XSOP]SOHNUM
    if [F:XSOH]ORDSTA = 1 & [F:XSOH]HLDSTA = 1 

       if [F:XSOP]XPERIODO = 1 
          sumar = 1
       endif
       if [F:XSOP]XPERIODO = 2
          sumar = 6
       endif
       if [F:XSOP]XPERIODO = 3 
          sumar = 12
       endif
       if [F:XSOP]XPERIODO = 4 
          sumar = 3
       endif
# infbox num$([F:XSOP]xfecini) - num$(sumar) - num$([F:XSOP]XFECFIN)
       #fectemp =  addmonth([XSOP]XFECINI,sumar)
       fectemp = [XSOP]XFECINI
#infbox num$(fectemp) 
#infbox num$(cur_mes) - num$(cur_ano) 
       FOR I = 0 TO 1000
       
        if I > 0
           fectemp =  addmonth(fectemp,sumar)
        endif
        mes_temp = MONTH(fectemp)
        anio_temp = YEAR(fectemp)
        mes_fin = MONTH([F:XSOP]XFECFIN)
        anio_fin = YEAR([F:XSOP]XFECFIN)

#        if (mes_temp > mes_fin & anio_temp > anio_fin) |(mes_temp > cur_mes & anio_temp > cur_ano)
        if (mes_temp > cur_mes & anio_temp > cur_ano)
           break
	Endif
#infbox num$(mes_temp) - num$(mes_fin) - num$(anio_temp) - num$(anio_fin) - num$(cur_mes) - num$(cur_ano)
        if mes_temp = cur_mes & anio_temp = cur_ano

           ya_procesada = "0"
           For [XSDD] where [F:XSDD]BPCORD = [F:XSOP]BPCORD & [F:XSDD]SOHNUM = [F:XSOP]SOHNUM & [F:XSDD]SOPLIN = [F:XSOP]SOPLIN &[F:XSDD]ITMREF = [F:XSOP]ITMREF


             mes_exp = 0
             anio_exp = 0
             Read [XSHD]SDH0 = [F:XSDD]SDHNUM
             if !fstat

                mes_exp = MONTH([F:XSHD]SHIDAT)
                anio_exp = YEAR([F:XSHD]SHIDAT)
                if mes_temp = mes_exp & anio_temp = anio_exp
                   ya_procesada = "1"
                   Break
                Endif
             Endif
           Next    

          if ya_procesada <> "1"
           if [XSOP]BPCORD <> XBPCORD_ANT | [XSOP]BPAADD <> XBPAADD_ANT
                XBPCORD_ANT = [XSOP]BPCORD
                XBPAADD_ANT = [XSOP]BPAADD
                NUM_LIN = 0
                F_ult_diames = gdat$(1,cur_mes,cur_ano)
                f_ult_diames = eomonth(f_ult_diames)
                fecha_txt = ""
                fecha_txt = seg$(num$(f_ult_diames),7,10) +  seg$(num$(F_ult_diames),4,5)
                fecha_txt = fecha_txt + seg$(num$(f_ult_diames),1,2) 

#infbox num$(fecha_txt) 
          	reg = ""	
		reg = "H" + ";"
		reg = reg + [F:XSOH]SALFCY
		reg = reg + ";"
		reg = reg + [F:XSOP]STOFCY
		reg = reg + ";"
                reg = reg + ";"
                reg = reg + "FIX"
		reg = reg + ";"
		reg = reg + [F:XSOP]BPCORD
		reg = reg + ";"
		reg = reg + [F:XSOP]BPAADD
		reg = reg + ";"
		reg = reg + [F:XSOH]CUR
                reg = reg + ";"
                reg = reg + fecha_txt
                reg = reg + ";"
                reg = reg + fecha_txt
                reg = reg + ";1;;;"
		wrseq reg using [XCSV]
            Endif
            NUM_LIN +=1000
            reg= ""	
	    reg = "L" + ";"
	    reg = reg + NUM$(NUM_LIN)
            reg = reg + ";"
            reg = reg + [F:XSOP]SOHNUM
            reg = reg + ";"
            reg = reg + NUM$([F:XSOP]SOPLIN)
	    reg = reg + ";"
	    reg = reg + [F:XSOP]ITMREF
	    reg = reg + ";"
            reg = reg + [f:XSOP]ITMDES
	    reg = reg + ";"
	    reg = reg + [F:XSOP]SAU
	    reg = reg + ";"
	    reg = reg + NUM$([F:XSOP]XCANPER)
	    reg = reg + ";;;"
	    wrseq reg using [XCSV]
            importa = '1'
            break
	  Endif
        else
#           break
        Endif 
      Next I
   Endif
Next
Openo  Using  [XCSV] 
Close Local File [XSOP]
Close Local File [XSOH]
Close Local File [XSDD]
Close local File [XSHD]
if importa = '1' 
       
       Call IMPSILEN ('XSDH',FICHERO,GERRTRACE)
       Call LEC_TRACE From LECFIC 
endif 

Return

#######################################################################################
### Funcion de llamada a un modelo de import / export                               ### 
#######################################################################################
Subprog IMPSILEN (MODELE,NOMFICH,GERRTRACE)
    Value Char MODELE
    Value Char NOMFICH
    Variable Integer GERRTRACE
    If !clalev([F:AOE])   : Local File AOBJEXT    [AOE]  : Endif
    If !clalev([F:AOD])   : Local File AOBJEXTD   [AOD]  : Endif
    If !clalev([F:ZAOB])  : Local File AOBJET     [ZAOB] : Endif
    If !clalev([F:ADW])   : Local File ADOVAL     [ADW]  : Endif
    If !clalev([F:ZATY])  : Local File ATYPE      [ZATY] : Endif
    If !clalev([F:ZAMK])  : Local File AMSK       [ZAMK] : Endif
    If !clalev([F:ZAMZ])  : Local File AMSKZON    [ZAMZ] : Endif
    If !clalev([F:ZATB])  : Local File ATABLE     [ZATB] : Endif
    If !clalev([F:ZATZ])  : Local File ATABZON    [ZATZ] : Endif
    If !clalev([F:ZATI])  : Local File ATABIND    [ZATI] : Endif
    If !clalev([F:ZAFC])  : Local File AFONCTION  [ZAFC] : Endif
    If !clalev([F:APX])   : Local File APARIMPEXP [APX]  : Endif
    If !clalev([M:AOE0])  : Local Mask AOE0       [AOE0] : Endif
    If !clalev([M:AOE1])  : Local Mask AOE1       [AOE1] : Endif
    If !clalev([M:AOE2])  : Local Mask AOE2       [AOE2] : Endif
    If !clalev([M:IEX])   : Local Mask IMPTEST    [IEX]  : Endif
    If !clalev([M:DIA])   : Local Mask IMPENCH    [DIA]  : Endif
    If clalev([M:IMP2])=0 : Local Mask IMPOBJ2    [IMP2] : Endif

 #   If !clalev([M:IMP2]) : Local Mask IMPOBJ2 [M:IMP2] : Endif
  #    [M:IMP2]TYPEXP=2
   #   [M:IMP2]OKIMP=0



    Local Integer STAT : STAT = 0
    Local Char MESSAGE(100)
    Local Char FICHIER(200) : FICHIER = filpath("BQT",NOMFICH,"")

# Gosub OUVRE From GIMPOBJ : # Petites initialisations de [M:IMP2]
#    If !clalev([M:IMP2]) : Local Mask IMPOBJ2 [M:IMP2] : Endif
#      [M:IMP2]MODIMP=[L]MODELE : # Nom du modèle 
#      [M:IMP2]NOMIMP=[L]FICHIER : # path du fichier
#      [M:IMP2]TYPEXP = 2 #(POSTE serveur) 
#      Gosub EXEC From GIMPOBJ : # Appel de l'import silencieux


#    Call IMPORTSIL(MODELE,FICHIER) From GIMPOBJ

local integer err_trace
err_trace = GERRTRACE
Gosub OUVRE From GIMPOBJ
[M:IMP2]MODIMP="XSDH"
GSERVEUR=0
Read [F:AOE]AOE0 ="XSDH"
If !fstat Then
[M:IMP2]NOMIMP=FICHIER
[M:IMP2]TYPEXP=2
GSERVEUR=1
GESSAS=0
Gosub EXEC From GIMPOBJ 
GSERVEUR=0
If GERRTRACE>0 Then
#infbox("import a échoué")
Else
## Restitution de l'erreur globale
GERRTRACE=ERR_TRACE
Endif
Else
## Pas de modèle d'import
#infbox("Modèle d'import "- Zmonimport -" inexistant!") 
Endif
Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC



    If GERRTRACE <> 0
        GYNUM=0
    Endif
End





