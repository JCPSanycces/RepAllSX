#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "LECTURE"    : Gosub LECTURE
 When Default
Endcase
Return

$LECTURE

If !clalev([F:XTCH]) Local File TABCHANGE [XTCH] Endif
If !clalev([F:XSIH]) Local File SINVOICE [XSIH] Endif
#{TABCHANGE.CHGTYP_0} = 1 and
#{SINVOICEV.NUM_0} = {?NUM} and
#day({TABCHANGE.CHGSTRDAT_0})= day({?PM-SINVOICE.ACCDAT_0}) and
#month({TABCHANGE.CHGSTRDAT_0})= month({?PM-SINVOICE.ACCDAT_0}) and
#year({TABCHANGE.CHGSTRDAT_0}) =  year({?PM-SINVOICE.ACCDAT_0})

Gosub ACTION From CNSCSTSTD
GPE= 1

For JJ=0 To NOL
    If [M:CST2]NUM(JJ)='3IDR1001808CR-000748' and GUSER='ADMIN'
     #Dbgaff
    Endif
  If [M:CST2]CUR(JJ)<>'EUR'
    Read [XSIH]SIH0= [M:CST2]NUM(JJ)
    Read [XTCH]TCH0= 1;[M:CST2]CUR(JJ);"EUR";[XSIH]ACCDAT
    If fstat=0
      [M:CST2]XIMPORTE(JJ)= ar2([M:CST2]AMTNOTLIN(JJ) * [XTCH]REVCOURS)
    Endif
  Else
    [M:CST2]XIMPORTE(JJ)= ar2([M:CST2]AMTNOTLIN(JJ))
  Endif
  Affzo [M:CST2]XIMPORTE(JJ)
Next

Return

