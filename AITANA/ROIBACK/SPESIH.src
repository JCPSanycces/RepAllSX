Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR
End
###EMF1

######################################################################################
$ENVIO
######################################################################################

Local Char EXISTE(1), EMAIL(250)
Local Integer YESNO

EXISTE = '0'
EMAIL = ''
   Read [YSIV]SIV0 = [M:SIH0]NUM
   If !fstat

      If [F:YSIV]BPAADD <> ''
         EXISTE = '0'
         For [YCNT] Where [F:YCNT]BPANUM = [F:YSIV]BPCINV and  [F:YCNT]BPAADD = [F:YSIV]BPAADD and [F:YCNT]CNTFNC = 13

          EXISTE = '1'
          EMAIL = [F:YCNT]WEB
          Break
         Next
         If EXISTE = '0'
            For [YCNT] Where [F:YCNT]BPANUM = [F:YSIV]BPCINV and  [F:YCNT]BPAADD = '' and [F:YCNT]CNTFNC = 13
              EXISTE = '1'
              EMAIL = [F:YCNT]WEB
              Break
            Next
         Endif
         If EXISTE = '0'
            For [YCNT] Where [F:YCNT]BPANUM = [F:YSIV]BPCINV and  [F:YCNT]BPAADD = ' ' and [F:YCNT]CNTFNC = 13
              EXISTE = '1'
              EMAIL = [F:YCNT]WEB
              Break
            Next
         Endif
      Else
         For [YCNT] Where [F:YCNT]BPANUM = [F:YSIV]BPCINV and  [F:YCNT]BPAADD = '' and [F:YCNT]CNTFNC = 13
            EXISTE = '1'
            EMAIL = [F:YCNT]WEB
            Break
         Next
         If EXISTE = '0'
            For [YCNT] Where [F:YCNT]BPANUM = [F:YSIV]BPCINV and  [F:YCNT]BPAADD = ' ' and [F:YCNT]CNTFNC = 13
              EXISTE = '1'
              EMAIL = [F:YCNT]WEB
              Break
            Next
         Endif
      Endif
   Endif

   If EMAIL <> ''

#      call OUINON ("La factura se enviará a "+VIREBLC(email,1),YESNO) from GESECRAN
#      if yesno = 2
         Update [YAWH] Where [F:YAWH]CODE = 'XEMAIL' With [F:YAWH]DESTIN = '"'+vireblc(EMAIL,1)+'"'
         If !fstat
            Gosub LLAMA_IMPRESO
         Endif
#      endif
   Endif

#UPDATE [XAWH] WHERE [F:XAWH]CODE = 'APRINT2' WITH [F:XAWH]DESTIN = '"noreply@roiback.com"'


Return
########################################################
$LLAMA_IMPRESO
########################################################

Local Char    TBPAR (20)(50), TBVAL (50)(50)

  TBPAR (1) = "facturedeb" : TBVAL (1) = [M:SIH0]NUM
  TBPAR (2) = "facturefin" : TBVAL (2) = [M:SIH0]NUM
  TBPAR (3) = "sitedeb"    : TBVAL (3) = [M:SIH0]SALFCY
  TBPAR (4) = "sitefin"    : TBVAL (4) = [M:SIH0]SALFCY
  TBPAR (5) = "clientdeb"  : TBVAL (5) = [M:SIH0]BPCINV
  TBPAR (6) = "clientdeb"  : TBVAL (6) = [M:SIH0]BPCINV

  If [M:SIH1]STARPT = 1
     TBPAR (7) = "codimp" : TBVAL (7) = ' '
  Else
     TBPAR (7) = "codimp" : TBVAL (7) = '2'
  Endif
  Call ETAT("XSBONFACPMAIL","","",0,"",TBPAR,TBVAL) From AIMP3
  Update [F:YSIH] Where [F:YSIH]NUM = [M:SIH0]NUM With [F:YSIH]XENVIADA = 2

  Update [YAWH] Where [F:YAWH]CODE = 'XEMAIL' With [F:YAWH]DESTIN = '"noreply@roiback.com"'

Return

#FIN EMF1

