## Antes de entrada al campo 'CUFE' (pantalla SIH0) 21/10/2020 10:17:51 (AIT07)
######################################################################################
Subprog AS_YCUFE(VALEUR)
Variable Char    VALEUR()
#JC.21102020.HU017.STR
  If GFLAG <> "AAL" and GFLAG <> "CREDN" and GFLAG <> "STA" Then
    Grizo [M:SIH0]YCUFE
  Else
    Actzo [M:SIH0]YCUFE
  Endif
#JC.21102020.HU017.END
End

