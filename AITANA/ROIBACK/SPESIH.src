Local File SINVOICE [YSIH]
Local File SINVOICEV [YSIV]
Local File CONTACT [YCNT]
Local File AWRKPARH [YAWH]
# Fin EMF1

Return

#VGOMEZ - 22/09/2017
$APRES_CRE
  If !clalev([F:ZDUD])   Local File GACCDUDATE [ZDUD]  : Endif
  If !clalev([F:ZMDT])   Local File MANDATE    [ZMDT]  : Endif
  Local Char AUX
  For [ZMDT] Where [ZMDT]BPCNUM = [F:SIH]BPR and [ZMDT]BPCADD = [M:SIH1]BPAADD and [ZMDT]CPY = [F:SIH]CPY
    AUX = [ZMDT]UMRNUM
#    Infbox AUX
    Break
  Next

  For [ZDUD] Where [ZDUD]NUM = [F:SIH]NUM and [ZDUD]BPR = [F:SIH]BPR
    Trbegin [ZDUD]
      [ZDUD]BPAPAY = [M:SIH1]BPAADD
      [ZDUD]UMRNUM = AUX
      Rewrite [ZDUD]
    Commit
  Next
Return
