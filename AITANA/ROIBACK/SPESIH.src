$ACTION

Case ACTION
 When "OUVRE"   : Gosub OUVRE
 When "AVANTBOUT"   : Gosub AVANTBOUT
 When "APRES_CRE"   : Gosub APRES_CRE
### EMF1
 When "Fin" :Gosub FIN
# Fin EMF1
 When Default
Endcase
Return

### EMF1
$FIN
 Close Local File [YSIH], [YSIV],[YCNT],[YAWH]
Return
# Fin EMF1


$AVANTBOUT

Case BOUT
  When "3" :
  Local Char    TBPAR (20)(50), TBVAL (50)(50)

#      TBPAR (1) = "facturedeb" : TBVAL (1) = [M:SIH0]NUM
#      TBPAR (2) = "facturefin" : TBVAL (2) = [M:SIH0]NUM
#      TBPAR (3) = "sitedeb" : TBVAL (3) = [M:SIH0]SALFCY
#      TBPAR (4) = "sitefin" : TBVAL (4) = [M:SIH0]SALFCY
#      TBPAR (5) = "clientdeb" : TBVAL (5) = [M:SIH0]BPCINV
#      TBPAR (6) = "clientdeb" : TBVAL (6) = [M:SIH0]BPCINV
#      TBPAR (7) = "codimp" : TBVAL (7) = '1'

#      Call ETAT("XSBONFACP","","",0,"",TBPAR,TBVAL) From AIMP3

### EMF1
  When "4" : Gosub ENVIO
# Fin EMF1
Endcase
Return

$OUVRE

### EMF1

#If !clalev([F:XSIH])   Local File SINVOICE   [XSIH] : Endif
