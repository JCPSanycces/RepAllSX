#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
 Case ACTION


  When "OUVRE"          Gosub OUVRE
  When "AV_CHOIX"       Gosub AV_CHOIX
  When "FIN"           Gosub FIN
  When "AVANT_ENR"      Gosub AVANT_ENR
  When Default
 Endcase
Return


$OUVRE
  Local File SINVOICEV [ZSIV]
  Local File CONTACT [ZCNT]
  Local File XRECWRK [XRWK]
Return

$FIN


  Close File[ZSIV], [ZCNT], [XRWK]
Return
####################################################################################
$AV_CHOIX

 Local Integer I
 Local Char MAIL(250)
 If BOUT = 'O' or BOUT = 'A'
  For I = 0 To [M:DFUP]NBLIG
       Gosub CARGA_BPAADD
       Read [XRWK]XRWK0 = [M:FUP]QURNUM;[M:DFUP]BPC(I);[M:DFUP]BPAADD(I)
       If fstat
          Gosub CARGA_MAIL
         [M:DFUP]EMAIL(I) = MAIL : Affzo[M:DFUP]EMAIL(I)
       Else
         [M:DFUP]XEMAIL =  [F:XRWK]EMAIL : Affzo[M:DFUP]XEMAIL
         [M:DFUP]EMAIL(I) = [F:XRWK]EMAIL : Affzo[M:DFUP]EMAIL(I)
       Endif
  Next
 Endif

Return
###################################################################
$AVANT_ENR

# IF BOUT = 'E'

    If [M:DFUP]XEMAIL <> '' and [M:DFUP]XAADD <> ''

     Read [XRWK]XRWK0 = [M:FUP]QURNUM;[M:DFUP]BPC;[M:DFUP]XAADD
     If fstat > 1
        [F:XRWK]QURNUM = [M:FUP]QURNUM
        [F:XRWK]BPC    = [M:DFUP]BPC
        [F:XRWK]EMAIL  = [M:DFUP]XEMAIL
        [F:XRWK]BPAADD = [M:DFUP]XAADD
        Write[XRWK]

     Else
       If fstat = 0
        [F:XRWK]QURNUM = [M:FUP]QURNUM
        [F:XRWK]BPC    = [M:DFUP]BPC
        [F:XRWK]EMAIL  = [M:DFUP]XEMAIL
        [F:XRWK]BPAADD = [M:DFUP]XAADD
        Rewrite[XRWK]
      Endif

     Endif
     For I = 0 To [M:DFUP]NBLIG - 1
      If [M:DFUP]BPAADD(I) = [M:DFUP]XAADD
       [M:DFUP]EMAIL(I) = [M:DFUP]XEMAIL : Affzo[M:DFUP]EMAIL(I)
      Endif
     Next
    Else
     Delete [XRWK]XRWK0 = [M:FUP]QURNUM;[M:DFUP]BPC
     For I = 0 To [M:DFUP]NBLIG
         Gosub CARGA_MAIL
         [M:DFUP]EMAIL(I) = MAIL : Affzo[M:DFUP]EMAIL(I)
     Next
    Endif


# ENDIF

Return
###################################################################################
$CARGA_MAIL
###################################################################################
Local Char EXISTE(1)
EXISTE = '0'
   MAIL = ''

   Read [ZSIV]SIV0 = [M:DFUP]NUM(I)
   If !fstat

      If [F:ZSIV]BPAADD <> ''
         EXISTE = '0'
         For [ZCNT] Where [F:ZCNT]BPANUM = [F:ZSIV]BPCINV and  [F:ZCNT]BPAADD = [F:ZSIV]BPAADD and [F:ZCNT]CNTFNC = 13

          EXISTE = '1'
          MAIL = [F:ZCNT]WEB
          Break
         Next
         If EXISTE = '0'
            For [ZCNT] Where [F:ZCNT]BPANUM = [F:ZSIV]BPCINV and  [F:ZCNT]BPAADD = '' and [F:ZCNT]CNTFNC = 13


              EXISTE = '1'
              MAIL = [F:ZCNT]WEB
              Break
            Next
         Endif
         If EXISTE = '0'
            For [ZCNT] Where [F:ZCNT]BPANUM = [F:ZSIV]BPCINV and  [F:ZCNT]BPAADD = ' ' and [F:ZCNT]CNTFNC = 13


              EXISTE = '1'
              MAIL = [F:ZCNT]WEB
              Break
            Next
         Endif
       Else
         For [ZCNT] Where [F:ZCNT]BPANUM = [F:ZSIV]BPCINV and  [F:ZCNT]BPAADD = '' and [F:ZCNT]CNTFNC = 13

              EXISTE = '1'
              MAIL = [F:ZCNT]WEB
              Break
            Next
            If EXISTE = '0'
            For [ZCNT] Where [F:ZCNT]BPANUM = [F:ZSIV]BPCINV and  [F:ZCNT]BPAADD = ' ' and [F:ZCNT]CNTFNC = 13


              EXISTE = '1'
              MAIL = [F:ZCNT]WEB
              Break
            Next
         Endif
       Endif
   #>>GAO(28/05/2018): Si no hay dirección entrega se coge la de Vencimiento.
   #Para el desarrollo de campañas de reclamaciones, que hay facturas terceros y asientos sin dirección de enregas.
   Else
     If clalev([F:ZDUD]) = 0 Local File GACCDUDATE [ZDUD] : Endif
     Read [F:ZDUD]DUD0 = 'FACLI';[M:DFUP]NUM(I);1;1
     If !fstat Then
       If [F:ZDUD]BPAPAY <> '' Then
         EXISTE = '0'
         For [ZCNT] Where [F:ZCNT]BPANUM = [F:ZDUD]BPRPAY and [F:ZCNT]BPAADD = [F:ZDUD]BPAPAY and [F:ZCNT]CNTFNC = 13
           EXISTE = '1'
           MAIL = [F:ZCNT]WEB
           Break
         Next
         If EXISTE = '0' Then
           For [ZCNT] Where [F:ZCNT]BPANUM = [F:ZDUD]BPRPAY and  [F:ZCNT]BPAADD = '' and [F:ZCNT]CNTFNC = 13
             EXISTE = '1'
             MAIL = [F:ZCNT]WEB
             Break
           Next
         Endif
         If EXISTE = '0' Then
           For [ZCNT] Where [F:ZCNT]BPANUM = [F:ZDUD]BPRPAY and  [F:ZCNT]BPAADD = ' ' and [F:ZCNT]CNTFNC = 13
             EXISTE = '1'
             MAIL = [F:ZCNT]WEB
             Break
           Next
         Endif
       Else
         For [ZCNT] Where [F:ZCNT]BPANUM = [F:ZDUD]BPRPAY and  [F:ZCNT]BPAADD = '' and [F:ZCNT]CNTFNC = 13
           EXISTE = '1'
           MAIL = [F:ZCNT]WEB
           Break
         Next
         If EXISTE = '0' Then
           For [ZCNT] Where [F:ZCNT]BPANUM = [F:ZDUD]BPRPAY and  [F:ZCNT]BPAADD = ' ' and [F:ZCNT]CNTFNC = 13
             EXISTE = '1'
             MAIL = [F:ZCNT]WEB
             Break
           Next
         Endif
       Endif
     Endif
   #<<GAO(28/05/2018)
   Endif
Return

####################################################################################
$CARGA_BPAADD
###################################################################################
Local Char EXISTE(1)

   Read [ZSIV]SIV0 = [M:DFUP]NUM(I)
   If !fstat
      [M:DFUP]BPAADD(I) = [F:ZSIV]BPAADD : Affzo [M:DFUP]BPAADD(I)
   #>>GAO(22/05/2018): Si no hay dirección entrega se coge la de Vencimiento.
   #Para el desarrollo de campañas de reclamaciones, que hay facturas terceros y asientos sin dirección de enregas.
   Else
#      If clalev([F:ZSIH]) = 0 Local File SINVOICE [ZSIH] : Endif
#      If [F:ZSIV]BPAADD = '' Then
#        Read [F:ZSIH]SIH0 = [M:DFUP]NUM(I)
#        If !fstat Then
#          [M:DFUP]BPAADD(I) = [F:ZSIH]BPAPAY : Affzo [M:DFUP]BPAADD(I)
#        Endif
#      Endif
      If clalev([F:ZDUD]) = 0 Local File GACCDUDATE [ZDUD] : Endif
      Read [F:ZDUD]DUD0 = 'FACLI';[M:DFUP]NUM(I);1;1
      If !fstat Then
        [M:DFUP]BPAADD(I) = [F:ZDUD]BPAPAY : Affzo [M:DFUP]BPAADD(I)
      Endif
   #<<GAO(22/05/2018)
   Endif
Return

