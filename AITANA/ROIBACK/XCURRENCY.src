#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
#infbox action
Case ACTION
  When "EXEC"          : Gosub EXEC
  When "TERMINE"       : Gosub TERMINE
  When "INIT"          : Gosub INIT
  When Default
Endcase
Return

#####################################################################################
$INIT

   Local File TABCHANGE  [XTCH] ORDER BY [F:XTCH]CURDEN; [F:XTCH]CUR

Return
#####################################################################################
$TERMINE

 Close Local File [XTCH]

Return

####################################################################################
$EXEC
 
  Local Char OLD_CURDEN(5), OLD_CUR(5)

  Local Char xfich(50),xdir(250),xext(3),fichero(250)
  Local integer STAT
  
  xdir = "C:\SAGE\APP\X3V9\folders\PROD\BQT"
  xfich = "CURRENCY"
  Xext = "CSV"
  FICHERO      = filpath(Xdir,xfich,xext,"","","")

  call MOVE("C:\SAGE\APP\X3V9\folders\PROD\BQT\CURRENCY.CSV", "C:\SAGE\APP\X3V9\folders\PROD\XCUR\CURRENCY.CSV",STAT) from ORDSYS

  For [XTCH] 

      if [F:XTCH]CURDEN <> OLD_CURDEN or [F:XTCH]CUR <> OLD_CUR

       if [F:XTCH]CURDEN <> "BUD" and [F:XTCH]CUR <> "BUD"

          System RESULT = "C:\BIN\PHP\PHP.EXE C:\TRECE\CURRENCYPROD.PHP"-[F:XTCH]CURDEN-[F:XTCH]CUR

       endif

      endif

      OLD_CURDEN = [f:XTCH]CURDEN 
      OLD_CUR    = [F:XTCH]CUR

   Next

   Call IMPORTSIL("CHANGE",FICHERO) From GIMPOBJ 

   
Return


