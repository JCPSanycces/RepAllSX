##################################################################################
$ESCRIBIR_TABLA_AUX
  Trbegin [F:XLOC] #--> para empezar la trsnsacción de escribir
  Write [F:XLOC]
  If fstat
    Rollback
  Else
     Commit
  Endif
Return

##################################################################################
$COGER_CONSUMO
  Local Decimal IMPTO_PORCEN
  Local Decimal IMPTO_TOTAL

  Filter [F:XRES] Where XRES_LOC = [F:XLOC]LOC
  Read [F:XRES] Last
  If !fstat Then
          Read [XBPC] = [F:SDH]BPCORD

          If !fstat & [F:XBPC]XIMPINC = 2
           IMPTO_PORCEN = val([F:XRES]XRES_IMPTOS)
           If IMPTO_PORCEN <> 0 Then
              IMPTO_TOTAL = [F:XRES]XRES_TOT /  (IMPTO_PORCEN / 100 + 1)
           Else
              IMPTO_TOTAL = [F:XRES]XRES_TOT
           Endif
          Else
              IMPTO_TOTAL = [F:XRES]XRES_TOT
          Endif
    Gosub CAMBIO_DIVISA
    [F:XLOC]CONSUMO = IMPTO_TOTAL
  Endif
  Filter
Return

##################################################################################
$CAMBIO_DIVISA
  Local Decimal XDIV,XMULT
  Local Date FECHA_DIVISA

  FECHA_DIVISA= gdat$(1, [F:XRES]XMES, [F:XRES]XANIO)
  FECHA_DIVISA = eomonth(FECHA_DIVISA)

  Read [XBPC] = [F:SDH]BPCORD
  If [F:XRES]CUR <> [XBPC]CUR Then
     XDIV = 1
     XMULT = 1
     For [XTCH] Where [F:XTCH]CHGTYP = 1 & [F:XTCH]CURDEN = [F:XRES]CUR & [F:XTCH]CUR = [F:XBPC]CUR & [F:XTCH]CHGSTRDAT <= FECHA_DIVISA
          XDIV = [F:XTCH]CHGDIV
          XMULT = [F:XTCH]REVCOURS
     Next
     IMPTO_TOTAL = IMPTO_TOTAL / XDIV * XMULT
  Endif
Return

