#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#infbox ACTION
Case ACTION
 When "APRES_CRE"   : Gosub APRES_CRE
 When Default
Endcase
Return

##################################################################################
$APRES_CRE
##### Primero vamos a poner todos las localizaciones en el campo de texto
If GIMPORT
###################################################################################
If !clalev([F:XSDD])   : Local File SDELIVERYD  [XSDD]  : Endif
If !clalev([F:XRES])   : Local File XRESERVASPHP[XRES]  : Endif
If !clalev([XTXC])     : Local File TEXCLOB     [XTXC]  : Endif
If !clalev([F:XLOC])   : Local File XLOCALIZ    [XLOC]  : Endif

If !clalev([F:XBPC])   : Local File BPCUSTOMER [XBPC]   : Endif
   For [XSDD]SDD0 Where SDHNUM=[F:SDH]SDHNUM
     If [F:XSDD]SDDTEX<>""
       Read [F:XTXC]TXC0=[F:XSDD]SDDTEX
       If !fstat
          Raz [F:XTXC]TEXTE
          NUMLOC=0
          Filter [XRES]
          For [F:XRES] Where BPAADD=[F:SDH]BPAADD & BPCNUM=[F:SDH]BPCORD & ITMREF=[F:XSDD]ITMREF
&          &  XANIO=year([F:SDH]DLVDAT) & XMES=month([F:SDH]DLVDAT)
            If NUMLOC<>0:  Append [F:XTXC]TEXTE,"|": Endif
            Append [F:XTXC]TEXTE,[F:XRES]XRES_LOC
            NUMLOC+=1
          Next
          Rewrite [F:XTXC]
       Endif
     Endif
   Next
### Ahora los vamos a guardar individualmente
Local Integer POS0, POS1
Local Char XLOC(10)
 For [XSDD]SDD0 Where SDHNUM=[F:SDH]SDHNUM
   If [F:XSDD]SDDTEX<>""
    Read [F:XTXC]TXC0=[F:XSDD]SDDTEX
    If !fstat
       $BUCLE_LOC
       If POS0=0: POS1= instr(1,[F:XTXC]TEXTE,"|") Else  POS1= instr(POS0+1,[F:XTXC]TEXTE,"|"): Endif
       If POS0=0 & POS1=0: XLOC = [F:XTXC]TEXTE: Endif
       If POS0>=0 & POS1>0: XLOC = seg$([F:XTXC]TEXTE,POS0+1,POS1-1): Endif
       If POS0>0 & POS1=0: XLOC = mid$([F:XTXC]TEXTE,POS0+1,20): Endif
       If XLOC<>""
          Gosub ESC_LOC
          XLOC=""
          If POS1<>0
             POS0=POS1
             Goto BUCLE_LOC
          Endif
        Endif
    Endif
   Endif
 Next
Endif
Return
############################
$ESC_LOC
  [F:XLOC]SDHNUM = [F:SDH]SDHNUM
  [F:XLOC]LOC    = XLOC
   Gosub COGER_CONSUMO
   Gosub ESCRIBIR_TABLA_AUX
Return
