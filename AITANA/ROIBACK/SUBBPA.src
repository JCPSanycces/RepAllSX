Variable Char    VALEUR()
Call AM_XBPADES(VALEUR) From TRTBPA

  #    Gestion des clients : Réalimentation de la désignation de l'adresse de livraison
  Call ALIM_CLIENT_BPC4("BPADES", VALEUR)
  Gosub INIT_FLMODFONC  # FGR 05/06/2014 : X3SUIVI100629
End
