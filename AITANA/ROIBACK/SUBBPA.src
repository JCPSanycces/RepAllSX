# FGR 15/07/2010 : X3SUIVI66067 (fin)
######################################################################################


# --------------------------------------------------------------------------------
#                     Traitements appelées
# --------------------------------------------------------------------------------
##################################################################################
# Verifier en cas de modif du code adresse si la valeur precedente               #
# de celui-ci etait utilisee dans les RIBS ou les contacts ou les clients livrés #
##################################################################################
$SETNOL
Local Integer NOL
NOL = nolign -1
Return
##################################################################################
$CTRADR
Local Integer MATCH_ADR
Local Char    CPY, WBPRNUM
Local Char    WFOURN, WBPC
mkstat = 0
MATCH_ADR = 0
# --------------------------------------- #
# verif existence dans les rib            #
# --------------------------------------- #
# Cas particulier des représentants et des prospects : Pas d'écran rib -> Vérif dans les fichiers
If clalev([M:REP0])| clalev([M:BPP0])
   If clalev([M:REP0]) : WBPRNUM = [M:REP0]REPNUM : Endif
   If clalev([M:BPP0]) : WBPRNUM = [M:BPP0]BPCNUM : Endif
   If !clalev([F:BID]) : Local File BID[BID] : Endif
   For [BID]BID0 Where BPATYP=1 & BPANUM=WBPRNUM & BPAADD=[M]CODADR(nolign-1)
       MATCH_ADR += 1
   Next
Endif
If MATCH_ADR <> 0 GMESSAGE = [M]CODADR(nolign-1)-":"-mess(169,133,1) : mkstat = 1 : Return : Endif
# --------------------------------------- #
# verif existence dans les contacts       #
# --------------------------------------- #
# Cas particulier des représentants : Pas d'écran contact -> Vérif dans les fichiers
If clalev([M:REP0])
   If !clalev([F:CNT]) : Local File CONTACT[CNT] : Endif
   For [CNT]CNT0 Where BPATYP=1 & BPANUM=[M:REP0]REPNUM & BPAADD=[M]CODADR(nolign-1)
       MATCH_ADR += 1
   Next
Endif
If MATCH_ADR <> 0 GMESSAGE = [M]CODADR(nolign-1)-":"-mess(170,133,1) : mkstat = 1 : Return : Endif
# verif existence dans les clients livrés #
Gosub CTRADR_BPC4
#MAE, bg 97413
If MATCH_ADR <> 0 GMESSAGE = [M]CODADR(nolign-1)-":"-mess(22,199,1)-" "- mess(78,117,1)-":"-WBPC  :  : mkstat = 1 : Return : Endif
#If MATCH_ADR <> 0 GMESSAGE = [M]CODADR(nolign-1)-":"-mess(22,199,1)  : mkstat = 1 : Return : Endif
#MAE bg 84042
Gosub CTRADR_BPS2
If MATCH_ADR <> 0 GMESSAGE = [M]CODADR(nolign-1)-":"-mess(599,199,1)-" "- mess(17,7,1)-":"-WFOURN  : mkstat = 1 : Return : Endif
Return

$CTRADR_BPS2
If clalev([M:BPS2])
   # Issue 97413 - 2014-03-10 by MUARN : ajout contrôle code tiers facturant et payé
   # Vérifier le tiers facturant
   If MATCH_ADR = 0 & [M:BPS2]BPAINV = [M]CODADR(nolign-1) & [M:BPS2]BPSINV = [M:BPS0]BPSNUM
     MATCH_ADR = 1 : WFOURN = [M:BPS0]BPSNUM
   Endif
   #MAE, bg 97413, Vérifier que l'adresse n'est pas utilisée dans le tiers facturant d'un autre fournisseur
   If MATCH_ADR = 0
    If !clalev([F:BPS1]) : Local File BPSUPPLIER[BPS1] : Endif
    For [BPS1]BPS0 Where BPSINV=[M:BPS0]BPSNUM & BPAINV=[M]CODADR(nolign-1) & BPSNUM<>[M:BPS0]BPSNUM
       MATCH_ADR += 1 : WFOURN = [F:BPS1]BPSNUM : Break
    Next
   Endif
   # Vérifier aussi le tiers payé
   If MATCH_ADR = 0 & [M:BPS2]BPAPAY = [M]CODADR(nolign-1) & [M:BPS2]BPRPAY = [M:BPS0]BPSNUM
     MATCH_ADR = 1 : WFOURN = [M:BPS0]BPSNUM
   Endif
   #MAE, bg 97413, Vérifier que l'adresse n'est pas utilisée dans le tiers payé d'un autre fournisseur
   If MATCH_ADR = 0
    If !clalev([F:BPS1]) : Local File BPSUPPLIER[BPS1] : Endif
    For [BPS1]BPS0 Where BPRPAY=[M:BPS0]BPSNUM & BPAPAY=[M]CODADR(nolign-1) & BPSNUM<>[M:BPS0]BPSNUM
         MATCH_ADR += 1 : WFOURN = [F:BPS1]BPSNUM : Break
    Next
   Endif
Endif
Return

$CTRADR_BPC4
# --------------------------------------- #
# verif existence dans les clients livrés #
# --------------------------------------- #
# Cas particulier des clients : Il faut vérifier que l'adresses n'existe pas dans les clients livrés
If clalev([M:BPC4])
   #  Gestion des clients      : Vérif directe dans l'écran des clients livrés
   MATCH_ADR = find([M]CODADR(nolign-1),[M:BPC4]BPAADD(0..[M:BPC4]NBDLV-1))
   If MATCH_ADR = 1 WBPC = [M:BPC0]BPCNUM : Endif

# MAE, bg 97413, vérifier aussi le client facture     Corr 21503  19/04/04 (TB)
     If MATCH_ADR = 0 & [M:BPC3]BPAINV = [M]CODADR(nolign-1) &  [M:BPC3]BPCINV = [M:BPC0]BPCNUM
        MATCH_ADR = 1 : WBPC = [M:BPC0]BPCNUM
     Endif
     #MAE, bg 97413, Vérifier que l'adresse n'est pas utilisée dans le client facture d'un autre client
     If MATCH_ADR = 0
      If !clalev([F:BPC1]) : Local File BPCUSTOMER[BPC1] Endif
      For [BPC1]BPC0 Where BPCINV=[M:BPC0]BPCNUM & BPAINV=[M]CODADR(nolign-1) & BPCNUM<>[M:BPC0]BPCNUM
         MATCH_ADR += 1 : WBPC = [F:BPC1]BPCNUM : Break
      Next
     Endif
     #MAE, bg 97413, vérifier aussi le tiers payeur
     If MATCH_ADR = 0 & [M:BPC3]BPAPYR = [M]CODADR(nolign-1) & BPCNUM<>[M:BPC0]BPCNUM
        MATCH_ADR = 1
     Endif
     #MAE, bg 97413, Vérifier que l'adresse n'est pas utilisée dans le tiers payeur d'un autre client
     If MATCH_ADR = 0
      If !clalev([F:BPC1]) : Local File BPCUSTOMER[BPC1] : Endif
      For [BPC1]BPC0 Where BPCPYR=[M:BPC0]BPCNUM & BPAPYR=[M]CODADR(nolign-1) & BPCNUM<>[M:BPC0]BPCNUM
         MATCH_ADR += 1 : WBPC = [F:BPC1]BPCNUM : Break
      Next
     Endif
Elsif clalev([M:BPR0]) | clalev([M:BPS0]) | clalev([M:BPT0]) | clalev([M:REP0])
   #  Gestion des autres tiers : Vérif dans le fichier Clients-Livrés
   If clalev([M:BPR0]) : CPY = [M:BPR0]BPRNUM : Endif
   If clalev([M:BPS0]) : CPY = [M:BPS0]BPSNUM : Endif
   If clalev([M:BPT0]) : CPY = [M:BPT0]BPTNUM : Endif
   If clalev([M:REP0]) : CPY = [M:REP0]REPNUM : Endif
   If !clalev([F:BPD]) : Local File BPDLVCUST [BPD] : Endif
   For [BPD]BPD0 Where BPCNUM=CPY & BPAADD=[M]CODADR(nolign-1)
       MATCH_ADR += 1 : Break
   Next
Endif
Return

##################################################################################
$INIT_ADR_BP
  If GREP = "C" & [M]BPAADDFLG([M]XNUMLIG) =2
    #    Gestion des clients
    # --> En création, alimentation du 1er client livré
    # --> En création, alimentation de l'adresse du client facture
    If clalev([M:BPC4])
      If [M:BPC4]BPAADD(0) = ""
        [M:BPC4]BPAADD(0)=WCODADR
        [M:BPC4]BPDADDFLG(0)=2
        [M:BPC4]FLMOD(0) = 1                   # FGR 28/07/2014 : X3SUIVI100229
        [M:BPC4]NBDLV=1
        SAVNOLIGN = nolign
        nolign = 1
        Local Char WFCY(type([M:BPRC]FCY)-10) : WFCY=[M:BPRC]FCY
        Local Char WBPAADD(type([M:BPC4]BPAADD(0))-10) : WBPAADD=[M:BPC4]BPAADD(0)
        Gosub CHARGE_BPAADD From SUBBPC
        Affzo [M:BPC4]5, 10
        nolign = SAVNOLIGN
      Endif
    Endif  # FGR 20/02/2015 : X3SUIVI106383 : Endif au mauvais endroit
    If clalev([M:BPC3]) Then
      If [M:BPC3]BPAINV = "" & [M:BPC3]BPCINV = [M:BPC0]BPCNUM
        [M:BPC3]BPAINV= WCODADR : Affzo [M:BPC3]BPAINV
      Endif
      If [M:BPC3]BPAPYR = "" & [M:BPC3]BPCPYR = [M:BPC0]BPCNUM
        [M:BPC3]BPAPYR=WCODADR : Affzo [M:BPC3]BPAPYR
      Endif
    Endif
    #Endif  # FGR 20/02/2015 : X3SUIVI106383 : Endif au mauvais endroit
    # -----------------------------------------------------------------
    #    Gestion des fournisseurs
    # --> En création, alimentation du fournisseur par défaut
    If clalev([M:BPS2])
      If [M:BPS2]BPAINV = "" & [M:BPS2]BPSINV = [M:BPS0]BPSNUM
        [M:BPS2]BPAINV=WCODADR : Affzo [M:BPS2]BPAINV
      Endif
      If [M:BPS2]BPAPAY = "" & [M:BPS2]BPRPAY = [M:BPS0]BPSNUM
        [M:BPS2]BPAPAY=WCODADR : Affzo [M:BPS2]BPAPAY
      Endif
    Endif
  Endif
Return

##########################################################################
Subprog ALIM_CLIENT_BPC4(L_BPC4_ZONE, L_BPC4_VALEUR)
Value Char    L_BPC4_ZONE, L_BPC4_VALEUR
Local Integer I
# Gestion des clients : Réalimentation de zones du masque BPC4
# Appelé depuis :
#   - AM_XBPACRY : Réalimentation du code pays
#   - AM_XPOSCOD : Réalimentation du code postal
#   - AM_XBPADES : Réalimentation de la désignation de l'adresse de livraison

  If clalev([M:BPC4])
    I=find([M]XCODADR,[M:BPC4]BPAADD(0..[M:BPC4]NBDLV-1))
    If I<>0
      Assign "[M:BPC4]" + L_BPC4_ZONE + "(I-1)" With L_BPC4_VALEUR
      [M:BPC4]FLMOD(I-1) = 1                     # FGR 28/07/2014 : X3SUIVI100229
      If [M:BPC4]XBPAADD = [M:BPC4]BPAADD(I-1)
        Assign "[M:BPC4]" + "X" + L_BPC4_ZONE   With L_BPC4_VALEUR
        If L_BPC4_ZONE = "BPADES"
          Affzo [M:BPC4]XBPADES
        Endif
      Endif
    Endif
  Endif
End


