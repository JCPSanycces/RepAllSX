#<AdxTL>@(#)11.0.0.0 $Revision$
#######################################################################
# SUBBPA : Gestion des adresses                                       #
#######################################################################
# Gestion des masques BPABPR, BPABPC, BPABPP, BPABPS, BPABPT, BPAREP  #
#######################################################################
# Ces masques sont des copies du masque superviseur BPA               #
#######################################################################
# Dans ttes les actions, on pointe sur le trt superviseur TRTBPA      #
#######################################################################
$INIT_FLMODFONC
  # FGR 05/06/2014 : X3SUIVI100629
  If dim([M]FLMODFONC) > 0 Then
    [M]FLMODFONC([M]XNUMLIG) = 1
  Endif
Return

# --------------------------------------- NBADR -----------------------------
Subprog IB_NBADR
Call IB_NBADR From TRTBPA
End

########################################
Subprog AS_NBADR
  Call AS_NBADR From TRTBPA
End
########################################
Subprog C_NBADR
# FGR 01/12/2009 : X3SUIVI60473
#If [M]NBADR=0 & status<>82  mkstat=1 : End : Endif
If [M]NBADR=0 & status<>82 Then
  # FGR 04/12/2009 : X3SUIVI60655 : retour sur la fiche 60473.
  # On était obligé d'abandonner une création si on se positionne dans un champ
  # après l'onglet adresses. Et si le champ est obligatoire, par exemple adresse tiers payer
  # on ne peut pas en indiquer parce que les adresse n'existent pas encore, et on ne pas y aller
  # parce que le champ est obligatoire ! Du coup on est obligé d'abandonner la création.
  mkstat = 1
  GMESSAGE = mess(31,199,1)
  End
Endif
Local Integer NOL
Case status
   When 65    : # suppression d'une ligne
    # Si suppression de la ligne on regarde presence code adresse
    Gosub SETNOL
    Gosub CTRADR
    If mkstat : End : Endif
   When 68, 83 : # suppression de plusieurs lignes
       For NOL = nolign-1 To nolign1-1
              Gosub CTRADR
              If mkstat : Break : Endif
       Next NOL
Endcase
Call C_NBADR From TRTBPA
If mkstat End Endif
End
########################################
Subprog B1_NBADR
Call B1_NBADR From TRTBPA
End
########################################
Subprog APRES_NBADR
Call APRES_NBADR From TRTBPA
# Spécifique à l'import --> Recharger nolign pour sortir de la boucle de saisie
nolign = [M]NBADR

# LTA.sn - 93205
If func AFNC.ACTIV("LTA")
  Local Char TCRY(GLONCRY)
  TCRY=[M]BPACRY
  Gosub FMT_ADRVAL From TRTADRLIB
Endif
# LTA.en - 93205

End
# --------------------------------------- CODADR -----------------------------
Subprog C_CODADR(VALEUR)
Variable Char    VALEUR()
Local Integer NOL : NOL=nolign-1
Call C_CODADR(VALEUR) From TRTBPA
If mkstat End Endif
# Interdire la modification si l'adresse existe dans les clients livrés
#------ code adresse est obligatoire 29/01/98
If [M]CODADR (NOL) <> "" & VALEUR <> [M]CODADR(NOL)
    Gosub CTRADR : If mkstat : End : Endif
Endif

  #========================================================================
  # FGR 02/07/2012 : X3SUIVI81134 (début)
  If GREP = "M" Then
    # Seulement en modification
    If [M]CODADR(NOL) <> "" and [M]CODADR(NOL) <> VALEUR Then
      # Et si la valeur a changé (donc qu'elle risque d'exister en base)
      Local Integer OKANU
      Local Char SCLEPRIM(GLONVCR), SCLESEC(GLONVCR)(0..1)
      Local Char PARAM(250)(5)

      PARAM(1) = "ADR"
      PARAM(2) = mid$([M]IDENT,2, len([M]IDENT))            #'BPANUM'
      PARAM(3) = left$([M]IDENT,1) + "~" + [M]CODADR(NOL)   #'BPATYP' + "~" + 'BPAADD'
      SCLEPRIM = mid$([M]IDENT,2, len([M]IDENT))            #'BPANUM'
      SCLESEC(0) = left$([M]IDENT,1)                        #'BPATYP'
      SCLESEC(1) = [M]CODADR(NOL)                           #'BPAADD'
      # -------------------------------------
      # FGR 27/05/2013 : X3SUIVI89919 (début) :  Faux update pour ne pas bloquer sur cette table
      If !clalev([F:BPR]) Local File BPARTNER [BPR] : Endif
      Trbegin [BPR]
      Update [BPR] Where [F:BPR]BPRNUM = SCLEPRIM and [F:BPR]BPAADD = SCLESEC(1) With [F:BPR]BPAADD = ""
      # FGR 27/05/2013 : X3SUIVI89919 (fin)
      # -------------------------------------
      Call VERIF(nomap, "ADR", SCLEPRIM, SCLESEC, OKANU) From ANUCOD
      Rollback  # FGR 27/05/2013 : X3SUIVI89919 : Du coup à rollbacker obligatoirement
      If !OKANU Then
        mkstat = 1
        End
      Endif
    Endif
  Endif
  # FGR 02/07/2012 : X3SUIVI81134 (fin)
  #========================================================================
End
########################################
Subprog AM_CODADR(VALEUR)
Variable Char    VALEUR()
#Call AM_CODADR(VALEUR) From TRTBPA

Local    Char     WCODADR
Local    Integer  I
Local    Char     ACTION(20)
WCODADR = VALEUR
Gosub SETNOL
If [M]XCODADR= ""
 If nolign=1
  [M]BPAADDFLG (0)   = 2
 Else
  [M]BPAADDFLG (NOL) = 1
 Endif
 ACTION = "INIT_BPA"
 Gosub ACTION_BPA From TRTBPA
 Gosub CHARGE_ADR From TRTBPA
 Actzo 30
 zonsui = "XBPADES"
Else
 Call CHRIB(IDENT,[M]CODADR(NOL),VALEUR) From TRTBPA
 Call CHCNT(IDENT,[M]CODADR(NOL),VALEUR) From TRTBPA
Endif
[M]FLMOD(NOL) = 1
[M]XCODADR = VALEUR

# MABON - FQ65459 - 29/06/10 - Le champ ACCNONREI a changé de table
# MABON - FQ57657 - 14/09/09
#If dim([M]XACCNONREIM)>0 Then
#  Local Integer I
#  [M]XACCNONREIM=G_NON
#  If clalev([M:BPR0]) Then
#    Read [F:BPR]BPR0=[M:BPR0]BPRNUM
#    If !fstat Then
#      For I=0 To dim([F:BPR]ACCNONREI)-1
#        If [F:BPR]ACCNONREI(I)=VALEUR Then
#          [M]XACCNONREIM=G_OUI
#          Break
#        Endif
#      Next I
#    Endif
#  Endif
#Endif

Gosub SETNOL
# Si modif penser à vérifier IMPBPR, IMPBPC, IMPBPS, IMPREP
# --> init en création d'une adresse
If  [M]CODADR(NOL) = ""
    If nolign=1 Gosub INIT_ADR_BP : Endif
Endif

#LSE 06/02/2007
Local Char SZCRY
If clalev([M:BPRT])=0
    SZCRY=[M]CRY
Else
    SZCRY=[M:BPRT]CRY
Endif
If [M]XBPACRY=""
    If SZCRY<>""
        [M]XBPACRY= SZCRY
        Call INIPAYS([M]XBPACRY,[M]XCRYNAM) From TRTDIV
        [M]BPACRY(NOL)=[M]XBPACRY
        [M]CRYNAM (NOL)=[M]XCRYNAM
        #MAE, bg 78884
        # Gestion des clients : Réalimentation du code pays
        Call ALIM_CLIENT_BPC4("BPDCRY", [M]XBPACRY)
        Affzo 30
    Endif
Endif

End
