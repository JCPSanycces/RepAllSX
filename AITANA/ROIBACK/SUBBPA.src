########################################
Subprog AM_XBPACRY(VALEUR)
Variable Char    VALEUR()
Call AM_XBPACRY(VALEUR) From TRTBPA

# Gestion des clients : Réalimentation du code pays
Call ALIM_CLIENT_BPC4("BPDCRY", VALEUR)

#LTA.sn
If func AFNC.ACTIV("LTA")
  Local Char TCRY(GLONCRY)
  TCRY = VALEUR
  Gosub FMT_ADRVAL From TRTADRLIB
Endif
#LTA.en
#LTA.sn
If dim([M:BPC4]SSTENTCOD) > 0
  If !(func TRTADRLIB.CHKADR_CRY(VALEUR))
    Call ALIM_CLIENT_BPC4("SSTENTCOD", "")
  Endif
  If [M:BPAC]XCODADR =[M:BPC4]XBPAADD
    #When ENTCOD field exists, hide it and ShortDesc if the country is unsupported by SST
    If !(func TRTADRLIB.CHKADR_CRY(VALEUR))
      Raz [M:BPC4]XSSTENTCOD
      Chgfmt [M:BPC4]XSSTENTCOD  With "-K:" + num$(type([M:BPC4]XSSTENTCOD)-10) + "B" # Hide enterable
      If dim([M:BPC4]ZXSSTENTCOD) >= 0 Then
        Chgfmt [M:BPC4]ZXSSTENTCOD   With "-KP:" + num$(type([M:BPC4]ZXSSTENTCOD)-10) + "X"
      Endif
    Else
      Chgfmt [M:BPC4]XSSTENTCOD  With "K:" + num$(type([M:BPC4]XSSTENTCOD)-10) + "B" # Show enterable
      If dim([M:BPC4]ZXSSTENTCOD) >= 0 Then
        Chgfmt [M:BPC4]ZXSSTENTCOD   With "KP:" + num$(type([M:BPC4]ZXSSTENTCOD)-10) + "X"
      Endif
    Endif
  Endif
Endif
#LTA.en
Gosub INIT_FLMODFONC  # FGR 05/06/2014 : X3SUIVI100629
End

