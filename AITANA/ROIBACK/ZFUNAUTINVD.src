#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
 When "AUTINVDMAJ"        : Gosub AUTINVDMAJ
 When Default
Endcase
Return

$AUTINVDMAJ
  If !clalev([F:ZDUD])   Local File GACCDUDATE [ZDUD]  : Endif
  If !clalev([F:ZMDT])   Local File MANDATE    [ZMDT]  : Endif
  Local Char AUX
  For [ZMDT] Where [ZMDT]BPCNUM = [F:SIH]BPR and [ZMDT]BPCADD = [M:SIH1]BPAADD and [ZMDT]CPY = [F:SIH]CPY
    AUX = [ZMDT]UMRNUM
    Break
  Next
    For [ZDUD] Where [ZDUD]NUM = [F:SIH]NUM and [ZDUD]BPR = [F:SIH]BPR
#        Read [F:SIV]SIV0 = [F:SIH]NUM
        [ZDUD]BPAPAY = [F:SIV]BPAADD
        [ZDUD]UMRNUM = AUX
        Rewrite [ZDUD]
    Next
Return

