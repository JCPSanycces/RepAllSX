#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara ZIMPPAGOS (Especifico)
$ACTION
Case ACTION
  When "OK": Call IMP_FICHERO
Endcase
Return


Subprog IMP_FICHERO

Local Char FICCLI(250)
Local Char FICSRV(250): FICSRV=filpath("BQT","XXXX","CSV")
Local Integer STAT
Case [M]TYPORG
 When 1
    Call SET_NAMCLI(FICCLI) From ORDSYS
    Call COPSRV(FICCLI,FICSRV,STAT) From ORDSYS
 When 2
    Call COPIE([M]FICORG,FICSRV,STAT) From ORDSYS
Endcase
If STAT
 Call ERREUR(mess(12,139,1)) From GESECRAN : # Copie non réalisée
 End
Endif

Local Char FECHA,HORA,TIPOOPERACION,AUTORIZACION,PEDIDO,TIPOPAGO,IMPORTE,MONEDA,DEVOLUCION,MONEDA,PAISTARJETA,CREDITODEBITO,DESCRIPCION,USUARIO,IP,PAISCONEXION,CPAIS,PERSONALIZACION,WALLET
Local File SINVOICE
Local File COMPANY
Local File GACM
Local File GLED
Local File GACCOUNT

Openi filpath("BQT","XXXX","CSV") Using [TPV]
Iomode adxium 50 Using [TPV]
Iomode adxifs ";" Using [TPV]
Iomode adxirs chr$(10) Using [TPV]
Rdseq FECHA,HORA,TIPOOPERACION,AUTORIZACION,PEDIDO,TIPOPAGO,IMPORTE,MONEDA,DEVOLUCION,MONEDA,PAISTARJETA,CREDITODEBITO,DESCRIPCION,USUARIO,IP,PAISCONEXION,CPAIS,PERSONALIZACION,WALLET Using [TPV]
While !fstat
If mid$(AUTORIZACION,1,10 )="Autorizada": Gosub COBRO: Endif
Rdseq FECHA,HORA,TIPOOPERACION,AUTORIZACION,PEDIDO,TIPOPAGO,IMPORTE,MONEDA,DEVOLUCION,MONEDA,PAISTARJETA,CREDITODEBITO,DESCRIPCION,USUARIO,IP,PAISCONEXION,CPAIS,PERSONALIZACION,WALLET Using [TPV]

Wend
Openi Using [TPV]
Openo Using [COB]

Call IMPORTSIL("ZPAY",filpath("BQT","COBRO","TXT")) From GIMPOBJ

Call EFFACE(filpath("BQT","COBRO","TXT"),STAT) From ORDSYS
Call EFFACE(filpath("BQT","XXXX","CSV"),STAT) From ORDSYS

End

$COBRO

Local Integer I
Local Char FACTURA(30)
I = instr(1,DESCRIPCION,"(")
If !I: Return: Endif
  FACTURA=left$(DESCRIPCION,I-1)

  Read [SIH]SIH0=FACTURA
  If fstat: Return: Endif

  Openo filpath("BQT","COBRO","TXT") Using [COB]
  Iomode adxifs ";" Using [COB]
  Iomode adxirs chr$(10) Using [COB]
  IMPORTE=ctrans(IMPORTE,".","")
  Wrseq "P";             Using [COB]
  Wrseq "";              Using [COB]
  Wrseq "TPV";         Using [COB]  # TRANSACCION DE PAGO
  Wrseq [SIH]BPRPAY;     Using [COB]
  Call LEC_CPY([SIH]CPY) From CPTLEC
  Call LEC_GCM([CPY]ACM) From CPTLEC
  Call LEC_LED([GCM]LED) From CPTLEC
  Wrseq [LED]COA;        Using [COB]
  Read [GAC]GAC1=[LED]COA;[SIH]BPRSAC
  Wrseq [SIH]BPRSAC;        Using [COB]
  Wrseq [SIH]FCY;        Using [COB]
  Wrseq "C01";         Using [COB] # BANCO
  Wrseq "2";             Using [COB]
  Wrseq "EUR";           Using [COB]
  Wrseq IMPORTE;         Using [COB]
  Wrseq mid$(FECHA,7,4)+ mid$(FECHA,4,2)+mid$(FECHA,1,2)  Using [COB]
  Wrseq "D";             Using [COB]
  Wrseq "REC";           Using [COB] # IMPUTACION CONTABLE
  Wrseq [LED]COA;        Using [COB]
  Wrseq [SIH]BPRSAC;     Using [COB]
  Wrseq [SIH]BPRSAC;     Using [COB]
  Wrseq [SIH]BPRPAY;     Using [COB]
  Wrseq [SIH]BPRPAY;     Using [COB]
  Wrseq [SIH]GTE;        Using [COB]
  Wrseq [SIH]NUM;        Using [COB]
  Wrseq "";              Using [COB]
  Wrseq [SIH]BPRPAY;     Using [COB]
  Wrseq mid$(FECHA,7,4)+ mid$(FECHA,4,2)+mid$(FECHA,1,2);  Using [COB]
  Wrseq [SIH]FCY;        Using [COB]
  Wrseq [SIH]CUR;        Using [COB]
  Local Decimal XIMPORTE
  Local Integer STAT

  Local Date XFECHA: XFECHA=gdat$(val(mid$(FECHA,1,2)),val(mid$(FECHA,4,2)),val(mid$(FECHA,7,4)))
  #Call CONVERT("EUR",[SIH]CUR,"EUR",1,XFECHA,val(ctrans(IMPORTE,",",".")),XIMPORTE,STAT) From TRTDEV
  Wrseq num$([SIH]AMTATI);  Using [COB]
  #Wrseq ctrans(num$(XIMPORTE),".",",");  Using [COB]
  Wrseq IMPORTE;         Using [COB]
  Wrseq [SIH]ACCNUM;     Using [COB]
  Wrseq "1"              Using [COB]

Return




######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZIMPPAGOS) 07/05/2019 22:17:18 (ADMIN)
######################################################################################
######################################
Subprog AM_TYPORG(VALEUR)
Variable Integer VALEUR
[M]TYPORG = VALEUR
Gosub GRISE_ORG
End
$GRISE_ORG
Case [M]TYPORG
 When 2
  Actzo [M]FICORG2
 When Default
  [M]FICORG = "" : Affzo  [M]FICORG2 : Grizo  [M]FICORG2
Endcase
Return

Subprog C_FICORG2(VALEUR)
Variable Char    VALEUR()
Gosub ENUM_VOLFIL_TYPE  From ASYRSTO
mkstat = func ASYRSTO.CTL_VOLFIL([M]TYPORG, VALEUR,[M]FICORG,E_TYPE_FILEREAD,GMESSAGE)
End


