#################################################
$FORMA_FILTRO                                   #
#################################################
  Local Char PRIMERA
  Local Char ES_LIKE(1), ES_IN(1)
  Local Char CONDICION_FIJA(200)
  CONDICION_FIJA = " BPCNUM_0 = '"+[F:XCFLT]BPCNUM + "' AND BPAADD_0 = '"+[F:XCFLT]BPAADD+"' AND XPROCESO_0 = '"+PROCESO+"' AND ITMREF_0 = '' AND "
  PRIMERA = '0'

  For [XCRSF] Where [F:XCRSF]XFLTCOD = [F:XCFLT]XFLTCOD
    LINEA += 1
    ### CONDICION #############################################
    If PRIMERA <> '0' Then
      If [F:XCRSF]XFLTCOND = 1 Then
        FILTRO(LINEA) = FILTRO(LINEA) + " AND "
      Else
        FILTRO(LINEA) = FILTRO(LINEA) + " OR "+ CONDICION_FIJA
      Endif
    Else
      If TODOS = '0'
        FILTRO(LINEA) = "UPDATE XRESERVASPHP SET ITMREF_0 = '"+ [F:XCFLT]XFLTRES + "' WHERE BPCNUM_0 = '"+[F:XCFLT]BPCNUM+"' and BPAADD_0 = '"+[F:XCFLT]BPAADD+"' AND XPROCESO_0 = '" +PROCESO+
& "' AND ITMREF_0 = '' AND "
      Else
        FILTRO(LINEA) = "UPDATE XRESERVASPHP SET BPAADD_0 = 'TODOS', ITMREF_0 = '"+ [F:XCFLT]XFLTRES + "' WHERE BPCNUM_0 = '"+[F:XCFLT]BPCNUM+ "' AND XPROCESO_0 = '"+PROCESO+
& "' AND ITMREF_0 = '' AND "
      Endif
    Endif

    PRIMERA = '1'
    ### CAMPO #############################################
    If [F:XCRSF]XFLTCAMP = 1 Then             ##### CANAL
      FILTRO(LINEA) = FILTRO(LINEA) + "XRES_CANAL_0 "
    Endif
    If [F:XCRSF]XFLTCAMP = 2 Then             ##### COD. PROMOCIONAL
      FILTRO(LINEA) = FILTRO(LINEA) + "XRES_CPRO_0 "
    Endif
    If [F:XCRSF]XFLTCAMP = 3 Then             ##### CALL CENTER
      FILTRO(LINEA) = FILTRO(LINEA) + "XRES_UCALL_0 "
    Endif
    If [F:XCRSF]XFLTCAMP = 4 Then             ##### AFILIADO
      FILTRO(LINEA) = FILTRO(LINEA) + "XRES_AFIL_0 "
    Endif
    If [F:XCRSF]XFLTCAMP = 5 Then             ##### TIPO RESERVA - USUARIO AGENCIA
      FILTRO(LINEA) = FILTRO(LINEA) + "XRES_UAGE_0 "
    Endif
    If [F:XCRSF]XFLTCAMP = 6 Then             ##### LOCALIZADOR
      FILTRO(LINEA) = FILTRO(LINEA) + "XRES_LOC_0 "
    Endif
    If [F:XCRSF]XFLTCAMP = 7 Then             ##### USUARIO PARTICULAR
       FILTRO(LINEA) = FILTRO(LINEA) + "XRES_UPAR_0 "
    Endif
    If [F:XCRSF]XFLTCAMP = 8 Then             ##### USUARIO EMPRESA
       FILTRO(LINEA) = FILTRO(LINEA) + "XRES_UEMP_0 "
    Endif
    If [F:XCRSF]XFLTCAMP = 9 Then             ##### ESTADO
      FILTRO(LINEA) = FILTRO(LINEA) + "XRES_EST_0 "
    Endif
    If [F:XCRSF]XFLTCAMP = 10 Then             ##### ORIGEN
        FILTRO(LINEA) = FILTRO(LINEA) + "XRES_ORIG_0 "
    Endif
    If [F:XCRSF]XFLTCAMP = 11 Then             ##### TIPO HOTEL
        FILTRO(LINEA) = FILTRO(LINEA) + "XRES_THOT_0 "
    Endif
    ### OPERADOR #############################################
    ES_LIKE = '0'
    ES_IN = '0'

    If [F:XCRSF]XFLTOPE = 1 Then             ##### MAYOR
        FILTRO(LINEA) = FILTRO(LINEA) + "> "
    Endif
    If [F:XCRSF]XFLTOPE = 2 Then             ##### IGUAL
        FILTRO(LINEA) = FILTRO(LINEA) + "= "
    Endif
    If [F:XCRSF]XFLTOPE = 3 Then             ##### MENOR
        FILTRO(LINEA) = FILTRO(LINEA) + "< "
    Endif
    If [F:XCRSF]XFLTOPE = 4 Then             ##### MAYOR IGUAL
        FILTRO(LINEA) = FILTRO(LINEA) + ">= "
    Endif
    If [F:XCRSF]XFLTOPE = 5 Then             ##### MENOR IGUAL
        FILTRO(LINEA) = FILTRO(LINEA) + "<= "
    Endif
    If [F:XCRSF]XFLTOPE = 6 Then             ##### CONTENGA
        FILTRO(LINEA) = FILTRO(LINEA) + "like "
        ES_LIKE = '1'
    Endif
    If [F:XCRSF]XFLTOPE = 7 Then             ##### DISTINTO
        FILTRO(LINEA) = FILTRO(LINEA) + "<> "
    Endif
    If [F:XCRSF]XFLTOPE = 8 Then             ##### EN
        FILTRO(LINEA) = FILTRO(LINEA) + "IN ("
        ES_IN = '1'
    Endif
    If [F:XCRSF]XFLTOPE = 9 Then             ##### NO EN
        FILTRO(LINEA) = FILTRO(LINEA) + "NOT IN ("
        ES_IN = '1'
    Endif

        ### RESULTADO #############################################
    If ES_LIKE = '1' Then
        FILTRO(LINEA) = FILTRO(LINEA) + " '%"
        FILTRO(LINEA) = FILTRO(LINEA) + [F:XCRSF]XFLTVAL
        FILTRO(LINEA) = FILTRO(LINEA) + "%'"
    Else
      If ES_IN = '1' Then
        FILTRO(LINEA) = FILTRO(LINEA) + [F:XCRSF]XFLTVAL
        FILTRO(LINEA) = FILTRO(LINEA) + ")"
      Else
        FILTRO(LINEA) = FILTRO(LINEA) + " '"
        FILTRO(LINEA) = FILTRO(LINEA) + [F:XCRSF]XFLTVAL
        FILTRO(LINEA) = FILTRO(LINEA) + "'"
      Endif
    Endif
  Next

Return

###################################################################################
$CARGA_ENTREGAS                                                                   #
###################################################################################

Local Char OLD_BPCNUM(25), OLD_BPAADD(10), FECHA_TXT(8),REG(250), PRIMERA(1), OLD_ITMREF(30),GRABA(1)
Local Char REG1(250), REG2(250), REG3(250),REG4(250) #MRR (15/10/2018) Para que no corte campos con localizadores
Local Date F_ULT_DIAMES
Local Integer NUM_LIN
Local Decimal TOTAL, IMPTO_PORCEN, IMPTO_TOTAL
Local Decimal XCHG  ### EMF2
Local Char COND(1), XDESC(60), OLD_CUR(10)

###EMF1
Local Char APLICA_SUELO(1), SUELO(1)
#MRR 26/09/18 - añadir localizador
Local Integer I
Local Char LOCALIZADOR(250)(1..4) #(Para guardar los diferentes localizadores)
#MRR 26/09/2018 - añadir localizador

     GRABA = '0'
     PRIMERA = '0'
     For [XXRES] Where [F:XXRES]XPROCESADO = '' & [F:XXRES]BPAADD <> 'TODOS' & [F:XXRES]ITMREF<> '' & [F:XXRES]XANIO = [M]ANIO & [F:XXRES]XMES = [M]MES & [F:XXRES]SALFCY = [M]SALFCY
           IMPORTA = '1'
           GRABA = '1'


           If PRIMERA <> '0' and( [XXRES]ITMREF <> OLD_ITMREF | [F:XXRES]BPCNUM <> OLD_BPCNUM | [XXRES]BPAADD <> OLD_BPAADD)
                NUM_LIN +=1000
                XDESC = ''
                Read[XITM]ITM0 = OLD_ITMREF
                If !fstat
                     XDESC = [F:XITM]ITMDES1
                Endif
                XCHG = 1      #### EMF2
                Gosub CAMBIO_DIVISA

### EMF1
##suelo nuevo                if aplica_suelo = '' & TOTAL = 0
##suelo nuevo                   suelo = ''
##suelo nuevo                   Gosub Tarifa_Suelo
##suelo nuevo                   if suelo = '1'
##suelo nuevo                      TOTAL = 1
##suelo nuevo                      aplica_suelo = '1'
##suelo nuevo                   endif
##suelo nuevo                endif
### Fin EMF1

                REG= ""
                REG = "L" + ";"
          REG = REG + num$(NUM_LIN)
                REG = REG + ";"
                REG = REG + ";"
          REG = REG + ";"
          REG = REG + OLD_ITMREF
          REG = REG + ";"
                REG = REG + XDESC
          REG = REG + ";"
          REG = REG + "UN"
                REG = REG + ";"
          REG = REG + ctrans( vireblc(format$("N:15.4",TOTAL),0) ,",",".")
          REG = REG + ";*;;" # Para generar texto de albaran
          #MRR 26/09/2018 - añadir localizador
#         REG = REG + ";" + LOCALIZADOR(1) + ";" + LOCALIZADOR(2) + ";" + LOCALIZADOR(3)
#          REG1 = ''
#          REG2 = ''
#          REG3 = ''
          REG1 = LOCALIZADOR(1)
          REG2 = LOCALIZADOR(2)
          REG3 = LOCALIZADOR(3)
          REG4 = LOCALIZADOR(4)
          #MRR 26/09/2018 - añadir localizador
            If TOTAL <> 0
#         Wrseq REG  Using [XCSV]
          #MRR 26/09/2018
          Wrseq REG + ";" + REG1 + ";" + REG2 + ";" + REG3 + ";" + REG4 Using [XCSV]
          Raz LOCALIZADOR
          #MRR 26/09/2018
            Endif


                IMPTO_TOTAL = 0
                Gosub CALCULA_IMPUESTOS

                TOTAL = IMPTO_TOTAL
         Else

                IMPTO_TOTAL = 0
                Gosub CALCULA_IMPUESTOS
                TOTAL = TOTAL + IMPTO_TOTAL
         Endif

         #MRR 28/09/2018 - añadir localizador
                If LOCALIZADOR(1) = ""
                      LOCALIZADOR(1) = [F:XXRES]XRES_LOC
                    Else
                      If (len(LOCALIZADOR(1)) + len([F:XXRES]XRES_LOC) + 1) < 250 Then
                        LOCALIZADOR(1) += '|' + [F:XXRES]XRES_LOC
                      Else
                        If LOCALIZADOR(2) = ""
                          LOCALIZADOR(2) = [F:XXRES]XRES_LOC
                        Else
                          If (len(LOCALIZADOR(2)) + len([F:XXRES]XRES_LOC) + 1) < 250 Then
                            LOCALIZADOR(2) += '|' + [F:XXRES]XRES_LOC
                          Else
                            If LOCALIZADOR(3) = ""
                              LOCALIZADOR(3) = [F:XXRES]XRES_LOC
                            Else
                              If (len(LOCALIZADOR(3)) + len([F:XXRES]XRES_LOC) + 1) < 250 Then
                                LOCALIZADOR(3) += '|' + [F:XXRES]XRES_LOC
                              Else
                                If LOCALIZADOR(4) = ""
                                  LOCALIZADOR(4) = [F:XXRES]XRES_LOC
                                Else
                                  If (len(LOCALIZADOR(4)) + len([F:XXRES]XRES_LOC) + 1) < 250 Then
                                    LOCALIZADOR(4) += '|' + [F:XXRES]XRES_LOC
                                  Endif
                                Endif
                              Endif
                            Endif
                          Endif
                        Endif
                      Endif
                    Endif
                #MRR 28/09/2018 - añadir localizador
         OLD_ITMREF = [F:XXRES]ITMREF
         OLD_CUR = [F:XXRES]CUR
         PRIMERA = '1'

         If [F:XXRES]BPCNUM <> OLD_BPCNUM or [XXRES]BPAADD <> OLD_BPAADD
### EMF1
            APLICA_SUELO = ''
### Fin EMF1

            OLD_BPCNUM = [F:XXRES]BPCNUM
            OLD_BPAADD = [F:XXRES]BPAADD
            NUM_LIN = 0
            F_ULT_DIAMES = gdat$(1, [M]MES, [M]ANIO)
            F_ULT_DIAMES = eomonth(F_ULT_DIAMES)
            FECHA_TXT = ""
            FECHA_TXT = seg$(num$(F_ULT_DIAMES),7,10) +  seg$(num$(F_ULT_DIAMES),4,5)
            FECHA_TXT = FECHA_TXT + seg$(num$(F_ULT_DIAMES),1,2)

            Read [XBPC] = [F:XXRES]BPCNUM

                REG = ""
    REG = "H" + ";"
    REG = REG + [M]SALFCY
    REG = REG + ";"
    REG = REG + [M]SALFCY
    REG = REG + ";"
                REG = REG + ";"
                REG = REG + "CRS"
    REG = REG + ";"
    REG = REG + [F:XXRES]BPCNUM
    REG = REG + ";"
    REG = REG + [F:XXRES]BPAADD
    REG = REG + ";"
    REG = REG + [F:XBPC]CUR
                REG = REG + ";"
                REG = REG + FECHA_TXT
                REG = REG + ";"
                REG = REG + FECHA_TXT
                REG = REG + ";1;;;"
    Wrseq REG Using [XCSV]

         Endif

         Update [XXRES1] Where [F:XXRES1]XPROCESO = [F:XXRES]XPROCESO & [F:XXRES1]XHTLCRS = [F:XXRES]XHTLCRS & [F:XXRES1]XRESERVA = [F:XXRES]XRESERVA With [F:XXRES1]XPROCESADO = '1'  , [F:XXRES1]
& XCHGDIV = XCHG  ###EMF2

     Next
     ###### grabamos la última linea leida y no procesada.
     If GRABA = '1' Then

                NUM_LIN +=1000

                XDESC = ''
                Read[XITM]ITM0 = OLD_ITMREF
                If !fstat
                     XDESC = [F:XITM]ITMDES1
                Endif
                XCHG = 1     ### EMF2
                Gosub CAMBIO_DIVISA

### EMF1
##suelo nuevo                if aplica_suelo = '' & TOTAL = 0
##suelo nuevo                   suelo = ''
##suelo nuevo                   Gosub Tarifa_Suelo
##suelo nuevo                  if suelo = '1'
##suelo nuevo                      TOTAL = 1
##suelo nuevo                      aplica_suelo = '1'
##suelo nuevo                   endif
##suelo nuevo                endif
### Fin EMF1


                REG= ""
                REG = "L" + ";"
          REG = REG + num$(NUM_LIN)
                REG = REG + ";"
                REG = REG + ";"
          REG = REG + ";"
          REG = REG + OLD_ITMREF
          REG = REG + ";"
                REG = REG + XDESC
          REG = REG + ";"
          REG = REG + "UN"
                REG = REG + ";"
          REG = REG + ctrans( vireblc(format$("N:15.4",TOTAL),0) ,",",".")
          REG = REG + ";;;"
          #MRR 28/09/2018 - añadir localizador
#          REG = REG + ";" + LOCALIZADOR(1) + LOCALIZADOR(2) + LOCALIZADOR(3)
#          REG1 = ''
#          REG2 = ''
#          REG3 = ''
          REG1 = LOCALIZADOR(1)
          REG2 = LOCALIZADOR(2)
          REG3 = LOCALIZADOR(3)
          REG4 = LOCALIZADOR(4)
          #MRR 28/09/2018 - añadir localizador
            If TOTAL <> 0
#         Wrseq REG Using [XCSV]
          #MRR 28/09/2018
          Wrseq REG + ";" + REG1 + ";" + REG2 + ";" + REG3 + ";" + REG4 Using [XCSV]
          Raz LOCALIZADOR
          #MRR 28/09/2018
            Endif

      Endif

Return

