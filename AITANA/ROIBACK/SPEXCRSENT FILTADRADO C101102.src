                      Endif
                    Endif
                #MRR 28/09/2018 - añadir localizador

         OLD_ITMREF = [F:XXRES]ITMREF
         OLD_CUR = [F:XXRES]CUR
         PRIMERA = '1'

         If [F:XXRES]BPCNUM <> OLD_BPCNUM or [XXRES]BPAADD <> OLD_BPAADD

