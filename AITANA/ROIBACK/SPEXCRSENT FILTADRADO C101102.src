###################################################################################
$CALCULA_IMPUESTOS                                                                #
###################################################################################


  Read [XBPC] = [F:XXRES]BPCNUM

  If !fstat & [F:XBPC]XIMPINC = 1 # ¿DESCONTAR IMPUESTOS? NO --> VARIABLES CON IMPUESTOS INCLUIDOS
   If [F:XXRES]XRES_TCIMP <> 0 Then
      IMPTO_TOTAL = [F:XXRES]XRES_TCIMP # TOTAL CON IMPUESTOS # MAB.17022020.NEW
   Else
     IMPTO_PORCEN = val([F:XXRES]XRES_IMPTOS)
     If IMPTO_PORCEN <> 0 Then
        IMPTO_TOTAL = [F:XXRES]XRES_TOT /  (IMPTO_PORCEN / 100 + 1)
     Else
        IMPTO_TOTAL = [F:XXRES]XRES_TOT
     Endif
   Endif
   # MAB.17022020.NEW
  Else # ¿DESCONTAR IMPUESTOS? SI --> VARIABLES SIN IMPUESTOS INCLUIDOS
      If [F:XXRES]XRES_TSIMP <> 0 Then
        # IMPTO_TOTAL = [F:XXRES]XRES_TOT # MAB.17022020.OLD
        IMPTO_TOTAL = [F:XXRES]XRES_TSIMP # TOTAL SIN IMPUESTOS # MAB.17022020.NEW
      Else
        IMPTO_TOTAL = [F:XXRES]XRES_TOT
      Endif

  Endif

Return

######################################################################################
$CAMBIO_DIVISA_TODOS
###################################################################################

Local Decimal CAMBIO, XDIV, XMULT

 Read [XBPC] = [F:XXRES]BPCNUM

#Dbgaff

  # MAB.26032020,SNEW
  If [F:XBPC]XIMPINC = 1  Then # ¿DESCONTAR IMPUESTOS? NO --> VARIABLES CON IMPUESTOS INCLUIDOS
    If [F:XXRES]XRES_TCIMP <> 0 Then
      CAMBIO = [F:XXRES]XRES_TCIMP
    Else
      CAMBIO = [F:XXRES]XRES_TOT
    Endif
  Else # ¿DESCONTAR IMPUESTOS? SI --> VARIABLES SIN IMPUESTOS INCLUIDOS
      If [F:XXRES]XRES_TSIMP <> 0 Then
        CAMBIO = [F:XXRES]XRES_TSIMP
      Else
        CAMBIO = [F:XXRES]XRES_TOT
      Endif
  Endif
  # MAB.26032020,ENEW
  #  CAMBIO = [F:XXRES]XRES_TOT # MAB.26032020,OLD

  If [F:XBPC]CUR <> [F:XXRES]CUR Then
     XDIV = 1
     XMULT = 1
     For [XTCH] Where [F:XTCH]CHGTYP = 1 & [F:XTCH]CURDEN = [F:XXRES]CUR & [F:XTCH]CUR = [F:XBPC]CUR & [F:XTCH]CHGSTRDAT <= FECHA_DIVISA
          XDIV = [F:XTCH]CHGDIV
          XMULT = [F:XTCH]REVCOURS
     Next
     If [F:XBPC]XIMPINC = 1  Then
       If [F:XXRES]XRES_TCIMP <> 0 Then
          [F:XXRES]XRES_TCIMP = CAMBIO / XDIV * XMULT
       Else
         [F:XXRES]XRES_TOT = CAMBIO / XDIV * XMULT
       Endif
     Else
      If [F:XXRES]XRES_TSIMP <> 0 Then
          [F:XXRES]XRES_TSIMP = CAMBIO / XDIV * XMULT
       Else
         [F:XXRES]XRES_TOT = CAMBIO / XDIV * XMULT
       Endif
     Endif
     XCHG = XMULT     ###EMF2
  Endif

Return

###################################################################################
$CAMBIO_DIVISA
###################################################################################

Local Decimal CAMBIO, XDIV,XMULT
#Dbgaff
  Read [XBPC] = OLD_BPCNUM
  CAMBIO = TOTAL
  If [F:XBPC]CUR <> OLD_CUR Then
     XDIV = 1
     XMULT = 1
     For [XTCH] Where [F:XTCH]CHGTYP = 1 & [F:XTCH]CURDEN = OLD_CUR & [F:XTCH]CUR = [F:XBPC]CUR & [F:XTCH]CHGSTRDAT <= FECHA_DIVISA
          XDIV = [F:XTCH]CHGDIV
          XMULT = [F:XTCH]REVCOURS
     Next
     TOTAL = CAMBIO / XDIV * XMULT
     XCHG = XMULT  ###EMF2

  Endif

Return
#######################################################################################
### Funcion de llamada a un modelo de import / export                               ###
#######################################################################################
Subprog IMPSILEN (MODELE,NOMFICH,GERRTRACE)
    Value Char MODELE
    Value Char NOMFICH
    Variable Integer GERRTRACE
    If !clalev([F:AOE])   : Local File AOBJEXT    [AOE]  : Endif
    If !clalev([F:AOD])   : Local File AOBJEXTD   [AOD]  : Endif
    If !clalev([F:ZAOB])  : Local File AOBJET     [ZAOB] : Endif
    If !clalev([F:ADW])   : Local File ADOVAL     [ADW]  : Endif
    If !clalev([F:ZATY])  : Local File ATYPE      [ZATY] : Endif
    If !clalev([F:ZAMK])  : Local File AMSK       [ZAMK] : Endif
    If !clalev([F:ZAMZ])  : Local File AMSKZON    [ZAMZ] : Endif
    If !clalev([F:ZATB])  : Local File ATABLE     [ZATB] : Endif
    If !clalev([F:ZATZ])  : Local File ATABZON    [ZATZ] : Endif
    If !clalev([F:ZATI])  : Local File ATABIND    [ZATI] : Endif
    If !clalev([F:ZAFC])  : Local File AFONCTION  [ZAFC] : Endif
    If !clalev([F:APX])   : Local File APARIMPEXP [APX]  : Endif
    If !clalev([M:AOE0])  : Local Mask AOE0       [AOE0] : Endif
    If !clalev([M:AOE1])  : Local Mask AOE1       [AOE1] : Endif
    If !clalev([M:AOE2])  : Local Mask AOE2       [AOE2] : Endif
    If !clalev([M:IEX])   : Local Mask IMPTEST    [IEX]  : Endif
    If !clalev([M:DIA])   : Local Mask IMPENCH    [DIA]  : Endif
    If clalev([M:IMP2])=0 : Local Mask IMPOBJ2    [IMP2] : Endif

    Local Integer STAT : STAT = 0
    Local Char MESSAGE(100)
    Local Char FICHIER(200) : FICHIER = filpath("BQT",NOMFICH,"")

    Call IMPORTSIL(MODELE,FICHIER) From GIMPOBJ

    If GERRTRACE <> 0
        GYNUM=0
    Endif
End

###EMF1
###################################################################################
$TARIFA_SUELO
###################################################################################
  For [XSPC] Where [F:XSPC]PLI = 'TROI04' and [F:XSPC]PLIENAFLG = 2
    For [XSPL] Where [F:XSPL]PLI = 'TROI04' & [F:XSPL]PLICRI1 = [F:XBPC]BPCNUM &
&                    [F:XSPL]PLICRI2 = 'RESERVAS_WEB' & [F:XSPL]PLICRI3 = [F:XBPD]BPAADD &
&                    [F:XSPL]PLISTRDAT <= date$ & [F:XSPL]PLIENDDAT>= date$
           SUELO = '1'
      Break
    Next
    Break
  Next
Return
### Fin EMF1

