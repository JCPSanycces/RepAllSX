            OLD_BPCNUM = [F:XXRES]BPCNUM
            OLD_BPAADD = [F:XXRES]BPAADD
            NUM_LIN = 0
            F_ULT_DIAMES = gdat$(1, [M]MES, [M]ANIO)
            F_ULT_DIAMES = eomonth(F_ULT_DIAMES)
            FECHA_TXT = ""
            FECHA_TXT = seg$(num$(F_ULT_DIAMES),7,10) +  seg$(num$(F_ULT_DIAMES),4,5)
            FECHA_TXT = FECHA_TXT + seg$(num$(F_ULT_DIAMES),1,2)

            Read [XBPC] = [F:XXRES]BPCNUM

                REG = ""
    REG = "H" + ";"
    REG = REG + [M]SALFCY
