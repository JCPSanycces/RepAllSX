###      Read [XCRSFH]XFLTH0 = [F:XCFLT]XFLTCOD
###      ##### Controlamos que no sea un refacturable
###      If !fstat & [F:XCRSFH]XTIPFLT = 2
###        TODOS = '1'
###        LINEA = 0
###        For I = 0 To 39
###          FILTRO(I)=""
###        Next I
###        Gosub FORMA_FILTRO
###        #####  Aplicamos el filtro
###        Execsql From "S" Sql FILTRO
###      Endif
###    Next
    ###### PROCESAMOS EL RESTO DEVUELTO DE CRS SIN FILTRO
    For I = 0 To 39
      FILTRO(I)=""
    Next I
    FILTRO(1) = "UPDATE XRESERVASPHP SET XPROCESADO_0 = '1' WHERE XPROCESO_0 = '" +PROCESO+ "' AND ITMREF_0 = ''"
    Execsql From "S" Sql FILTRO

    #############################################################
    #############################################################
    Call OUINON("¿ Desea enlazar con el proceso de entregas para ese periodo y planta ?",YESNO) From GESECRAN
    If YESNO = 2 Then
      #### CARGAMOs ENTREGAS
      F_PRIMER_DIAMES = gdat$(1,[M]MES,[M]ANIO)
      F_ULTIMO_DIAMES = eomonth(F_PRIMER_DIAMES)
      EXISTE='0'
      For [XSDH] Where [F:XSDH]SALFCY = [M]SALFCY & [F:XSDH]SHIDAT >= F_PRIMER_DIAMES & [F:XSDH]SHIDAT <= F_ULTIMO_DIAMES
        EXISTE = '1'
        Break
      Next
      If EXISTE = '1' Then
        Call OUINON("Ya existen entregas para ese periodo y planta, ¿desea continuar con el proceso?",YESNO) From GESECRAN
        If YESNO = 2 Then
          TODOS = '0'
          IMPORTA = '0'
          Gosub CARGA_ENTREGAS
          Gosub CARGA_ENTREGAS_TODOS
        Endif
      Else
        TODOS = '0'
        IMPORTA = '0'
        Gosub CARGA_ENTREGAS
        Gosub CARGA_ENTREGAS_TODOS
      Endif
    Endif
  Else
    #### CARGAMOs ENTREGAS
