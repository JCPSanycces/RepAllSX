                                Else
                                  If (len(LOCALIZADOR(4)) + len([F:XXRES]XRES_LOC) + 1) < 250 Then
                                    LOCALIZADOR(4) += '|' + [F:XXRES]XRES_LOC
                                  Endif
                                Endif
                              Endif
                            Endif
                          Endif
