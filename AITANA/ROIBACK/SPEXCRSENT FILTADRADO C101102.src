                        Else
                          If (len(LOCALIZADOR(2)) + len([F:XXRES]XRES_LOC) + 1) < 250 Then
                            LOCALIZADOR(2) += '|' + [F:XXRES]XRES_LOC
                          Else
                            If LOCALIZADOR(3) = ""
                              LOCALIZADOR(3) = [F:XXRES]XRES_LOC
                            Else
