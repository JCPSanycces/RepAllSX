          REG1 = LOCALIZADOR(1)
          REG2 = LOCALIZADOR(2)
          REG3 = LOCALIZADOR(3)
          REG4 = LOCALIZADOR(4)
          #MRR 26/09/2018 - añadir localizador
            If TOTAL <> 0
#         Wrseq REG Using [XCSV]
          #MRR 26/09/2018
          Wrseq REG + ";" + REG1 + ";" + REG2 + ";" + REG3 + ";" + REG4 Using [XCSV]
          Raz LOCALIZADOR
          #MRR 26/09/2018
            Endif

                XCHG = 1             ###EMF2
                IMPTO_TOTAL = 0
                Gosub CAMBIO_DIVISA_TODOS
#infbox "carga divisa " - num$(XCHG)
                Gosub CALCULA_IMPUESTOS

                TOTAL = IMPTO_TOTAL
         Else
                XCHG = 1                 ###EMF2
                IMPTO_TOTAL  = 0
                Gosub CAMBIO_DIVISA_TODOS
#infbox "carga divisa " - num$(XCHG)
                Gosub CALCULA_IMPUESTOS

                TOTAL = TOTAL + IMPTO_TOTAL

         Endif

          #MRR 28/09/2018 - añadir localizador
                If LOCALIZADOR(1) = ""
                      LOCALIZADOR(1) = [F:XXRES]XRES_LOC
                    Else
                      If (len(LOCALIZADOR(1)) + len([F:XXRES]XRES_LOC) + 1) < 250 Then
                        LOCALIZADOR(1) += '|' + [F:XXRES]XRES_LOC
                      Else
                        If LOCALIZADOR(2) = ""
