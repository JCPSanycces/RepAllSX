$ACTION
Case ACTION
  When "OUVRE"      : Gosub OUVRE
  When "OK"         : Gosub OK
  When "DEBUT"      : Gosub DEBUT
  When Default
Endcase
Return

$OUVRE

 Local File BPCUSTOMER [XBPC]
 Local File BPDLVCUST  [XBPD]
 Local File ITMMASTER  [XITM]
 Local File XCLIFLTR   [XCFLT]
 Local File XCRSFLTR   [XCRSF]
 Local File XCRSFLTRH  [XCRSFH]
 Local File XRESERVASPHP [XXRES] Order By [F:XXRES]BPCNUM;[F:XXRES]BPAADD;[F:XXRES]ITMREF
 Local File XRESERVASPHP [XXRES1]
 Local File SDELIVERY  [XSDH]
 Local File XRESERVASPHP [XXRES2] Order By [F:XXRES2]XPROCESO Desc
 Local File TABCHANGE [XTCH]
 Local File SPRICLIST [XSPL] Order By [F:XSPL]MINQTY
 Local File SPRICCONF [XSPC]



Return

###################################################################################
$DEBUT

   For [XXRES2]
       [M]SALFCY= [F:XXRES2]SALFCY
       [M]MES=[F:XXRES2]XMES
       [M]ANIO= [F:XXRES2]XANIO
       Break
   Next
[M]XPROC = 1
Affzo [M]SALFCY
Affzo [M]MES
Affzo [M]ANIO
Affzo [M]XPROC
Return

#####################################################################################
$FIN
 Close Local File [XBPC],[XBPD], [XXRES], [XCFLT], [XCRSF], [XXRES1], [XITM], [XSDH], [XXRES2], [XCRSFH], [XTCH],[XSPC],[XSPL]
Return

