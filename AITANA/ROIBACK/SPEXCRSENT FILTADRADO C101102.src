    F_ULTIMO_DIAMES = eomonth(F_PRIMER_DIAMES)
    EXISTE='0'
    For [XSDH] Where [F:XSDH]SALFCY = [M]SALFCY & [F:XSDH]SHIDAT >= F_PRIMER_DIAMES & [F:XSDH]SHIDAT <= F_ULTIMO_DIAMES
      EXISTE = '1'
      Break
    Next

    If EXISTE = '1' Then
