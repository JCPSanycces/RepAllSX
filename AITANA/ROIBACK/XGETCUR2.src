#<AdxTL>@(#)0.0.0.0 $Revision$
####drubio 04/05/2018
#### subprograma que llama al WS REST, "DIVISAS". Mediante ASYSRESTCLI recuperamos las divisas en formato csv
#### se usa el modelo estandar CHANGE para importar las divisas
######################################################################
Subprog  XGETCUR(XFECINI,XFECFIN)
Value Date XFECINI
Value Date XFECFIN

#1 declaramos y asignamos valores
Gosub DEC_VAR

For JJ=0 To XFECFIN-XFECINI
  Gosub XSUBURL
  STATUSCODE=func ASYRRESTCLI.EXEC_REST_WS(NAME,HTTPMETHOD,SUBURL,PARAM_COD, PARAM_VAL,HEADERCOD, HEADERVAL,DATA,FUTURE,"",RESHEAD, RESBODY)
  If STATUSCODE = 200
    Gosub EXPCLOB
    Gosub IMPORT
  Endif
 XFECINI+=1
Next

If !GSERVEUR
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

End

######################################################################
$DEC_VAR

#abrimos traza
If !GSERVEUR
 Call OUVRE_TRACE("Importación divisas") From LECFIC
Endif

# tablas uadas
If !clalev([F:TCU])  : Local File TABCUR      [TCU]  : Endif
If !clalev([F:TCH])  : Local File TABCHANGE   [TCH]  : Endif
If !clalev([M:IMP2]) : Local Mask IMPOBJ2     [IMP2] : Endif

#clobs para wl WS
Local Clbfile RESHEAD(0)
Local Clbfile RESBODY(0)
Local Clbfile HTTPMETHOD(0)
Local Clbfile MESSA(0)

Local Integer STATUSCODE
Local Integer FUTURE
Local Integer JJ

Local Char HEADERCOD(64)(1)
Local Char HEADERVAL(255)(1)
Local Char PARAM_COD(64)(1)
Local Char PARAM_VAL(255)(1)
Local Char NAME(30)
Local Char SUBURL(250)
Local Char SUBURLTO(250)
Local Char RETURNS(250)
Local Char DATOS(255)(50)
Local Char XFECHA(10)
Local Date XCHGSTRDAT
Local Char FICEXP(100),FICIMP(100)

#asignación vallores
HEADERCOD(0)="Content-Type"
HEADERVAL(0)='"application/json"'
DATA ='"{'
DATA +='}"'
NAME = "DIVISAS"  #WS configurado en administración
HTTPMETHOD="GET"   #metodo del WS
FUTURE=0

FICEXP=filpath("XCUR","WS_"+date$,"csv") #fichero que devuelve el WS
FICIMP=filpath("XCUR",date$+"_zchange","csv") #fichero que construimos para importar

Gosub TO_DIVISAS

Return

######################################################################
###de la documentación de la API, construimos la url
######################################################################
$XSUBURL
SUBURL='/historic_rate'   #historic es para fechas, otras opciones son convert_to, convert_from
SUBURL+='.csv'            #formato csv. Puede ser json o xml. Escogemos csv por estar mejor formateado
SUBURL+='/?from=EUR'      #ponemos la divisa de base
SUBURL+= "&to="+SUBURLTO  #construido en $to_divisas. Para todas las divisas, poner  *
SUBURL+="&date="+format$("D:YYYY[-]MM[-]DD",XFECINI)
SUBURL+="&inverse=true"   #devuelve la divisa inversa

Return

######################################################################
### escribimos un fichero con los datos que devuelve el WS, al ser formato CSV
#####################################################################
$EXPCLOB

Openo FICEXP,0 Using [EXX]
 Iomode adxifs "|"        Using [EXX]
 Iomode adxirs ""         Using [EXX]
 Iomode adxium GASCII     Using [EXX]

Wrseq RESBODY Using [EXX]
Openo Using [EXX]

Return

######################################################################
$IMPORT

#leemos el fichero escrito por el WS
Openi FICEXP Using [ORI]
 Iomode adxifs ","        Using [ORI]
 Iomode adxirs chr$(10)         Using [ORI]
 Iomode adxium GASCII     Using [ORI]

#escribimos el fichero a importar
Openo FICIMP,0 Using [EXX]
 Iomode adxifs ";"                      Using [EXX]
 Iomode adxirs chr$(13)+chr$(10)        Using [EXX]
 Iomode adxium GASCII                   Using [EXX]

Rdseq DATOS Using [ORI]
While !fstat
  If DATOS(0)=GEURO  #'EUR', las dos primeras líneas son "basura"
    XFECHA= mid$(DATOS(2),9,2)+mid$(DATOS(2),6,2)+mid$(DATOS(2),3,2)
    #si hay una modificación en el cambio divisas, por importación no lo actualiza, por tanto, se borra registro y se vuelve a crear
    XCHGSTRDAT= gdat$(val(mid$(DATOS(2),9,2)),val(mid$(DATOS(2),6,2)),val(mid$(DATOS(2),3,2)))
    Read [TCH]TCH0=1;GEURO;DATOS(3); XCHGSTRDAT
    If fstat=0
      Trbegin [TCH]
        Delete [TCH]
      Commit
    Endif

    Wrseq GEURO;                            Using [EXX] #TABCHANGE.CUR        Divisa
    Wrseq DATOS(3);                         Using [EXX] #TABCHANGE.CURDEN     Divisa destino
    Wrseq XFECHA;                           Using [EXX] #TABCHANGE.CHGSTRDAT  Fecha cambio
    Wrseq "1";                              Using [EXX] #TABCHANGE.CHGTYP     Tipo cambio
    Wrseq num$(arr(val(DATOS(4)),0.00001))  Using [EXX] #TABCHANGE.CHGRAT     cambio

    #inverso
    Wrseq DATOS(3);                         Using [EXX] #TABCHANGE.CUR        Divisa
    Wrseq GEURO;                            Using [EXX] #TABCHANGE.CURDEN     Divisa destino
    Wrseq XFECHA;                           Using [EXX] #TABCHANGE.CHGSTRDAT  Fecha cambio
    Wrseq "1";                              Using [EXX] #TABCHANGE.CHGTYP     Tipo cambio
    Wrseq num$(arr(val(DATOS(5)),0.00001))  Using [EXX] #TABCHANGE.CHGRAT     cambio inverso
  Endif
  Rdseq DATOS Using [ORI]
Wend
Openi Using [ORI]
Openo Using [EXX]

Raz [M:IMP2]
[M:IMP2]MODIMP = "CHANGE"
[M:IMP2]NOMIMP = FICIMP
[M:IMP2]TYPEXP = 2

Call IMPORTSIL([M:IMP2]MODIMP,[M:IMP2]NOMIMP) From GIMPOBJ

Return

###################
$TO_DIVISAS
Raz JJ
For [TCU]TCU0
 If [F:TCU]CUR=GEURO | [F:TCU]EURFLG<>2 | ([F:TCU]EURFLG=2 & [F:TCU]EURDAT>date$)
  Filter [TCH] Where CURDEN=GEURO & CHGTYP=1 & CUR=[F:TCU]CUR & CHGSTRDAT<=date$
  Read [TCH]TCH0 Last
  If fstat<=2
   If JJ=0
    SUBURLTO+=[TCH]CUR
    JJ=1
   Else
    SUBURLTO+=","+[TCH]CUR
   Endif
  Endif
 Endif
Next TCU
Filter [TCH]
Return

