#<AdxTL>@(#)0.0.0.0 $Revision$
#MLGA - 25/11/19 - desactivado de momento por problema en el importe II - AS_AMTATI
#MRR01 - 25/11/19 - desactivado de momento por fallo con el campo vista
################################################################################
##############     Définition des codes Frais (Module FRAIS)     ###############
################################################################################

Raz GBIDC1
Call OBJET("EXS",GBIDC1,"1") From GOBJET
End

$ACTION
If GACTION="VISUEXSBLB"
 Case ACTION
  When "OUVRE" : Gosub OUVRE_BLB
  When "DEBUT" : Gosub DEBUT_BLB
  When "OK"    : Gosub OK_BLB
 Endcase
Else
 Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "RAZMASK"      : Gosub RAZMASK
  When "EFFMASK"      : Gosub EFFMASK
  When "AFFMASK"      : Gosub AFFMASK
  When "FILTRE"       : Gosub FILTRE
  When "LIENS"        : Gosub LIENS
  When "EXEBOUT"      : Gosub EXEBOUT
  When "INICRE"       : Gosub INICRE
  When "CREATION"     : Gosub CREATION
  When "MODIF"        : Gosub MODIF
  When "ANNULE"       : Gosub ANNULE
  When "RAZDUP"       : Gosub RAZDUP
  When "RAZCRE"       : Gosub RAZCRE
  When "FIN"          : Gosub FIN
  When "SETBOUT"      : Gosub SETBOUT
  When "VERIF_MOD"    : Gosub VERIF_MOD
  When Default
 Endcase
Endif
Return

$OUVRE
If !clalev([F:CCE2]) : Local File CACCE     [CCE2] : Endif
If !clalev([F:CPY])  : Local File COMPANY   [CPY]  : Endif
If !clalev([F:TVT])  : Local File TABVAT    [TVT]  : Endif
If !clalev([F:HAE])  : Local File GACCENTRY [HAE]  : Endif
If !clalev([F:AFT])  : Local File AFCTFCT   [AFT]  : Endif
If !clalev([F:EXM])  : Local File EXPARAM   [EXM]  : Endif
If !clalev([F:AUS])  : Local File AUTILIS   [AUS]  : Endif
If !clalev([F:CAC])  : Local File GACCCODE  [CAC]  : Endif
If !clalev([F:GCM])  : Local File GACM      [GCM]  : Endif
If !clalev([F:BEXP]) : Local File BLOBEXPENSES [BEXP] : Endif

Local Integer WNBREXS
Local Date    WDATDEB,WDATFIN
Local Char    WFILTRE(250), WPAR(50),WMODIF(250)
Local Char    SYMBOLE(50)

Global Integer GLOAD

Default Mask [EXS0]

Call PARAM("","EXPSTRDAT",WPAR) From ADOVAL
If WPAR<>"" : WDATDEB = gdat$(WPAR) : Endif
Call PARAM("","EXPENDDAT",WPAR) From ADOVAL
If WPAR<>"" : WDATFIN = gdat$(WPAR) : Endif

#If WPAR<>"" : WDATFIN = gdat$(evalue(WPAR)) : Endif

$RAZMASK
$EFFMASK
$AFFMASK
[M]DATDEB = WDATDEB
[M]DATFIN = WDATFIN
Return

$RAZDUP
Raz ACSEXS
Effzo [M:EXS0]15
Return

$RAZCRE
[M]DATDEB = WDATDEB
[M]DATFIN = WDATFIN
Return

$FILTRE
Raz FILTSUP
If !instr(1,GUSRAUZ,"1")
 # Dans le cas 'unique utilisateur' --> accès à GUSER
 FILTSUP = "CLB=GUSER"
Else
 # Dans le cas 'Tout utilisateur' --> vérifier les code d'accès.
Endif
Return

$LIENS
Gosub RAZMASK
Gosub CHARGE
Call SETCOLS([M]CLB)
Return

$SETBOUT
If CLECUR1="" or REP<>""
 Call VIREBOUT(CHAINE,"B") From GOBJET
Endif


Return

$VERIF_MOD
Gosub VERIF_CRE
Return

$VERIF_CRE
Return

$CHARGE
Gosub FILT

Raz nolign
Effzo 15

If WFILTRE="" : WFILTRE="1=1" : Endif

# Accès de l'utilisateur
[M]ACSEXS=[F:EXH]ACSEXS
Call D_ACSEXS([M]ACSEXS)

# Remplissage du tableau
For [EXS]EXS0 Where CLB=[F:EXH]CLB & evalue (WFILTRE)

 If nolign>=dim([M]CODEXP)
  If [M:EXS0]DATEXS(nolign-1)=[F:EXS]DATEXS
   While nolign>0 & [F:EXS]DATEXS=[M]DATEXS(nolign-1)
    Dela I,1,NBR NBR
    nolign-=1
   Wend
   If nolign>0
    WDATFIN = [F:EXS]DATEXS-1
    [M:EXS0]DATFIN = WDATFIN
    WDATFIN = [F:EXS]DATEXS-1
    Call ERREUR(mess(26,100,1)) From GESECRAN   # Tableau plein
   Else
    Call ERREUR(num$([F:EXS]DATEXS)-":"-mess(40,129,1)-">"-num$(dim([M]CODEXP))) From GESECRAN
   Endif
  Else
   WDATFIN = [F:EXS]DATEXS-1
   [M:EXS0]DATFIN = WDATFIN
   Call ERREUR(mess(26,100,1)) From GESECRAN   # Tableau plein
  Endif
  Break
 Endif
 nolign+=1
 [M] = [F:EXS]
 Gosub SETNOL

 # Mise à jour du lien avec la pièce comptable
 If [F:EXS]VCRNUM="" : Raz [M]VCRTYP(NOL) : Endif

 # Information venant de la définition du code frais
 Read [TES]TES0 = [F:EXS]CODEXP
 [M]UOM(NOL)=[F:TES]UOM

 # An icone is displayed if a picture exists for the expense
 Read [BEXP]BEXP0=[F:EXS]ACCNUM
 If !fstat : [M]FLGPCT(NOL) = "306"
   If [F:BEXP]ZPDF=2:  [M]FLGPCT(NOL) = "117": Endif
 Endif

 # Sauvegarde des infos (utilisation pour mettre à jour le champ VISA)
 [M]MODIF(NOL)=[M]FCY(NOL)+[M]DATEXS(NOL)+[M]CODEXP(NOL)+num$(QTY(NOL))+num$(AMTATI(NOL))+CUR(NOL)+
&              VAT(NOL)+num$([M]RATDIV(NOL))+num$([M]RATMLT(NOL))+[M]TAX1(NOL)+[M]TAX2(NOL)+
&              num$([M]AMTVAT(NOL))+num$([M]AMTTAX1(NOL))+num$([M]AMTTAX2(NOL))+
&              num$([M]DEDVAT(NOL))+num$([M]DEDTAX1(NOL))+num$([M]DEDTAX2(NOL))

 # Mise à jour des sections
 For I=1 To dim([F:EXS]CCE)
  If evalue("[F:EXS]CCE"+"("+num$(I-1)+")") <> ""
   Assign "[M]CCE"+num$(I)+"("+num$(NOL)+")" With   evalue("[F:EXS]CCE"+"("+num$(I-1)+")")
   If I<=4 : MODIF(NOL) -=evalue("[M]CCE"+num$(I)+"("+num$(NOL)+")") : Endif
  Else
   Assign "[M]CCE"+num$(I)+"("+num$(NOL)+")" With   ""
  Endif
 Next I

 #Mise à jour des comptes et plan de compte
 For I=1 To dim([F:EXS]ACC)
  If [F:EXS]ACC(I-1)<>""
    Assign "[M]ACC"+num$(I)+"("+num$(NOL)+")" With [F:EXS]ACC(I-1)
  Endif
  If [F:EXS]COA(I-1)<>""
    Assign "[M]COA"+num$(I)+"("+num$(NOL)+")" With [F:EXS]COA(I-1)
  Endif
 Next

 # Chargement des référentiels, de leur devise et des cours diviseur/multiplicateur
 For I=1 To len(mess(0,2644,1))
  If [F:EXS]LED(I-1)<>""
   Assign "[M]LED"+num$(I)+"("+num$(NOL)+")" With [F:EXS]LED(I-1)
  Endif
  If [F:EXS]CURLED(I-1)<>""
   Assign "[M]CURLED"+num$(I)+"("+num$(NOL)+")" With [F:EXS]CURLED(I-1)
  Endif
  Assign "[M]RATDIV"+num$(I)+"("+num$(NOL)+")" With [F:EXS]RATDIV(I-1)
  Assign "[M]RATMLT"+num$(I)+"("+num$(NOL)+")" With [F:EXS]RATMLT(I-1)
 Next

Next
[M]NBR=nolign

# Raffraichir l'état du relevé : Si le relévé possède une pièce comptable en catégorie réel, STA=2
#     STA=1 Non comptabilisé
#     STA=2 Comptabilisé

# On peut très bien se retrouver sans la tâche batch démarré
# CTRL lors de la comptabilisation et MAJ du STA)
#For I=0 To [M]NBR-1
# [M]STA(I)=1
# If [M]VCRNUM(I)<>""
#  Read [HAE]HAE0=[M]VCRTYP(I);[M]VCRNUM(I)
#  If !fstat and [HAE]CAT=1
#   [M]STA(I)=2
#  Endif
# Endif
#Next

Return


$FILT
Raz WFILTRE
If WDATDEB<>[0/0/0]
 WFILTRE -= "DATEXS>=["+format$(GFMD,WDATDEB)+"]"
Endif
If WDATFIN<>[0/0/0]
 If WFILTRE<>"" : WFILTRE-="&" : Endif
 WFILTRE -= "DATEXS<=["+format$(GFMD,WDATFIN)+"]"
Endif
Return

$EXEBOUT
Case BOUT
 When "B"
  Effzo 10
  [M]DATDEB = WDATDEB
  [M]DATFIN = WDATFIN
  Gosub CHARGE
  Affzo
Endcase
Return

$MODIF
# lcc
Gosub FILT
If WFILTRE="" : WFILTRE="1=1" : Endif
# Suppression des photos qui correspondent aux lignes supprimées de la note de frais
For [BEXP] Where CLB=[M]CLB & evalue(WFILTRE)
 If !find([F:BEXP]ACCNUM,[M]ACCNUM(0..[M]NBR-1))
  Delete [BEXP] Curr
  If fstat=1
   GOK=-1 : GLOCK="$BLOBEXPENSES"-[M]CLB : Break
  Endif
 Endif
Next
If GOK<>1 : Return : Endif
# Suppression des lignes de la note de frais
Delete [EXS] Where CLB=[M]CLB & evalue(WFILTRE)
If fstat=1
 GOK=-1 : GLOCK="$EXPENSES"-[M]CLB : Return
Endif
# end lcc
Gosub CREATION
Return

$CREATION
Raz WNBREXS
Sorta [M]NBR [M]NBR Order By [M]DATEXS(indice),[M]CODEXP(indice)
For nolign=1 To [M]NBR

 Raz [F:EXS]
 [F:EXS]=[M]

 If nolign>1 & [M]DATEXS(nolign-1) = [M]DATEXS(nolign-2)
  WNBREXS += 1
 Else
  WNBREXS  = 1
 Endif
 [F:EXS]NBREXS = WNBREXS

 Gosub SETNOL

 # Sauvegarde des infos (utilisation pour mettre à jour le champ VISA)
 WMODIF = [M]FCY(NOL)+[M]DATEXS(NOL)+[M]CODEXP(NOL)+num$(QTY(NOL))+num$(AMTATI(NOL))+CUR(NOL)+
&         VAT(NOL)+num$([M]RATDIV(NOL))+num$([M]RATMLT(NOL))+[M]TAX1(NOL)+[M]TAX2(NOL)+
&         num$([M]AMTVAT(NOL))+num$([M]AMTTAX1(NOL))+num$([M]AMTTAX2(NOL))+
&         num$([M]DEDVAT(NOL))+num$([M]DEDTAX1(NOL))+num$([M]DEDTAX2(NOL))

 # Mise à jour des sections
 For I=1 To dim([F:EXS]CCE)
  If evalue("[M]CCE"+num$(I)+"("+num$(NOL)+")") <> ""
   [F:EXS]CCE(I-1) = evalue("[M]CCE"+num$(I)+"("+num$(NOL)+")")
   If I<=4 : WMODIF -=evalue("[F:EXS]CCE"+"("+num$(I-1)+")") : Endif
  Else
   Raz [F:EXS]CCE(I-1)
  Endif
 Next I

 # Mise à jour des axes
 For I=0 To dim([F:EXS]DIE)-1
  If [M]DIE(I) <> ""
   [F:EXS]DIE(I) = [M]DIE(I)
  Else
   Raz [F:EXS]DIE(I)
  Endif
 Next I

 # Mise à jour des comptes
 For I=1 To dim([F:EXS]ACC)
  [F:EXS]ACC(I-1) = evalue("[M]ACC"+num$(I)+"("+num$(NOL)+")")
 Next I

 # Mise à jour des plans de compte
 For I=1 To dim([F:EXS]COA)
  [F:EXS]COA(I-1) = evalue("[M]COA"+num$(I)+"("+num$(NOL)+")")
 Next I

 # Mise à jour des référentiels et devises référentiels
 For I=1 To len(mess(0,2644,1))
  [F:EXS]LED(I-1) = evalue("[M]LED"+num$(I)+"("+num$(NOL)+")")
  [F:EXS]CURLED(I-1) = evalue("[M]CURLED"+num$(I)+"("+num$(NOL)+")")
  [F:EXS]RATDIV(I-1) = evalue("[M:EXS0]RATDIV"+num$(I)+"("+num$(NOL)+")")
  [F:EXS]RATMLT(I-1) = evalue("[M:EXS0]RATMLT"+num$(I)+"("+num$(NOL)+")")
 Next I

 # Affectation d'un numéro de relévé unique
 If [F:EXS]ACCNUM=0 : Call ACCNUM([F:EXS]ACCNUM) : [M]ACCNUM(NOL)= [F:EXS]ACCNUM  : Endif

 # Si modification faîte...
 If MODIF(NOL)<>WMODIF
  # Mise à jour du VISA
  #If !instr(1,GUSRAUZ,"1") :  Raz [F:EXS]VISA  : Endif
#  If [F:EXS]VISA<>"" [F:EXS]VISA=GUSER : Endif      #MRR01 desactivado por fallo con el campo vista
  # Mise à jour des zones de modif.
  If dim([F:EXS]UPDDAT)>0 : [F:EXS]UPDDAT = date$ : Endif
  If dim([F:EXS]UPDUSR)>0 : [F:EXS]UPDUSR = GUSER : Endif
 Endif
 If dim([F:EXS]CREDAT)>0 : [F:EXS]CREDAT = [M]CREDAT(NOL) : Endif
 If dim([F:EXS]CREUSR)>0 : [F:EXS]CREUSR = [M]CREUSR(NOL) : Endif

# ### lcc
#
#  If !clalev([F:EXSX]):Local File EXPENSES[EXSX] : Endif
#  Read [F:EXSX]EXS1=[F:EXS]ACCNUM
#  If fstat
#   ###
 Write [F:EXS]
 If fstat
  GOK=0 : Call FSTA("EXS") From GLOCK : Break
 Endif
# Else
#  Delete [F:EXSX] Where ACCNUM=[F:EXS]ACCNUM
#  [F:EXSX]=[F:EXS]
#  Rewrite [F:EXSX]
# Endif

Next nolign
Affzo [M:EXS0]15
Return

$INICRE
Raz ACCNUM
Return

$ANNULE
Delete [EXS] Where CLB=[L]CODE
If fstat
 GOK=-1 : GLOCK="$EXPENSES"-CLB : Return
Endif
Delete [BEXP] Where CLB=[L]CODE
If fstat
 GOK=-1 : GLOCK="$BLOBEXPENSES"-CLB : Return
Endif
Return

$FIN
Kill GLOAD
Return

Subprog ACCNUM(NUMERO)
Variable Integer NUMERO
Local File EXPENSES [XXX]
NUMERO = uniqid([F:XXX])
End

################################################################################
##############            Etiquette de l'écran EXS0              ###############
################################################################################

##################################### ACSEXS ###
Subprog D_ACSEXS(VALEUR)
Variable Char    VALEUR()
Call INIT_ACS([M]CLB,VALEUR)
End

##########################################################################
## Etiquette ajoutée par le superviseur 29/03/2004 10:51:20 (CP)
##########################################################################
Subprog C_CLB(VALEUR)
Variable Char    VALEUR()
# 1er contrôle : Accès
If !instr(1,GUSRAUZ,"1")  &  VALEUR<>GUSER
 # Dans le cas 'unique utilisateur' --> accès à GUSER
 # Accès impossible à cette fiche.
 GMESSAGE = VALEUR-mess(8,123,1) : mkstat=2 : End
Endif
# 2ème contrôle : paramètrage Tiers divers
Local Char APAR(GLONBPR)
Call PARAMUTIL("EXPBPR",APAR,VALEUR,"") From SUBAUS
Call LECTURE("BPR",APAR,"") From CONTOBJ
If fstat | [F:BPR]BPRACC<>2
 GMESSAGE = VALEUR-mess(43,129,1) : mkstat=2
Endif
# If the EXSGEN function is launched from F7 inside the GESEXS function (=> GLOAD=1), the status must be reset & display
# after the expense posting
If GLOAD=1
 Local Char    WFILTRE(250)
 Local Date    WDATDEB,WDATFIN
 WDATDEB=[M]DATDEB : WDATFIN=[M]DATFIN
 Gosub CHARGE : Affzo [M:EXS0]
 GLOAD=0
Endif
End

Subprog AM_CLB(VALEUR)
Variable Char VALEUR()
Call SETCOLS(VALEUR)
End

Subprog SETCOLS(USER)
Variable Char USER()
Call LECTURE("AUS",USER,"") From CONTOBJ
I=0
While [F:AUS]DIE(I)<>""
 [M]DIE(I)=[F:AUS]DIE(I)
 I+=1
Wend
Gosub INIFMT_CCE
zoncou="NBR"
Gosub CHG_FMT From W1EXS0
End

$INIFMT_CCE
Local Integer N
Local Char    FMT,INTIT(250)
## affichage des colonnes
#For N=1 To I
# If [M]DIE(N-1)<>""
#  # lecture du format
#  Call INICCEFMT([M]DIE(N-1)) From SETGLBDIE
#  FMT = "K:"+GCCEFMT
#  Call LECTEXTRA(INTIT,"GDIE","COLHEA",[M]DIE(N-1),"") From ATEXTRA
# Else
#  INTIT = ""
# Endif
# Gosub INTIT_CCE
#Next
Affzo
Return

$INTIT_CCE
Return #lcc
If GIMPORT Then Return Endif
Case N
 When 1  : Titcol [M:EXS0]NBR INTIT For CCE1
 When 2  : Titcol [M:EXS0]NBR INTIT For CCE2
 When 3  : Titcol [M:EXS0]NBR INTIT For CCE3
 When 4  : Titcol [M:EXS0]NBR INTIT For CCE4
 When 5  : Titcol [M:EXS0]NBR INTIT For CCE5
 When 6  : Titcol [M:EXS0]NBR INTIT For CCE6
 When 7  : Titcol [M:EXS0]NBR INTIT For CCE7
 When 8  : Titcol [M:EXS0]NBR INTIT For CCE8
 When 9  : Titcol [M:EXS0]NBR INTIT For CCE9
 When 10 : Titcol [M:EXS0]NBR INTIT For CCE10
 When 11 : Titcol [M:EXS0]NBR INTIT For CCE11
 When 12 : Titcol [M:EXS0]NBR INTIT For CCE12
 When 13 : Titcol [M:EXS0]NBR INTIT For CCE13
 When 14 : Titcol [M:EXS0]NBR INTIT For CCE14
 When 15 : Titcol [M:EXS0]NBR INTIT For CCE15
 When 16 : Titcol [M:EXS0]NBR INTIT For CCE16
 When 17 : Titcol [M:EXS0]NBR INTIT For CCE17
 When 18 : Titcol [M:EXS0]NBR INTIT For CCE18
 When 19 : Titcol [M:EXS0]NBR INTIT For CCE19
 When 20 : Titcol [M:EXS0]NBR INTIT For CCE20
Endcase
If FMT<>"" and N<=20 : Assign "[M:EXS0]FMTCCE"+num$(N) With FMT : Endif
Return

#################################### VARIABLE de BAS de TABLEAU ####
Subprog IB_NBR
Local Integer NOL
Local Char TYP(GLONGTE),NUM(GLONVCR)
Raz GBOUT1

Gosub SETNOL
mkstat = 0
If NOL>=[M:EXS0]NBR | [M:EXS0]NBR=0 : End : Endif

## Bouton 1 : Zoom sur pièce
If [M:EXS0]VCRNUM(NOL)<>""
 Read [HAE]=[M:EXS0]VCRTYP(NOL);[M:EXS0]VCRNUM(NOL)
 If !fstat
  GBOUT1 = mess(18,109,1) : #  Pièce
 Else
  Raz GBOUT1
 Endif
Endif

If GREP<>""
 Raz GBOUT3
Endif

End

Subprog B3_NBR
 # An icone is displayed if a picture exists for the expense
 Look [BEXP]BEXP0=[M]ACCNUM(nolign-1)
 If !fstat
  [M]FLGPCT(nolign-1) = "306"
 Else
  [M]FLGPCT(nolign-1) = ""
 Endif
 Affzo [M]FLGPCT(nolign-1)
End

##############
Subprog C_NBR
Local Integer I
Case status
 When 65 : # Annulation d'une ligne
  If [M]STA(nolign-1)>1
   # Suppression impossible, le relevé a déjà été comptabilisé
   GMESSAGE=mess(1,115,1)-" : "-mess(18,129,1)
   If !(dim(GWEBSERV)=1 & GWEBSERV=1) : mkstat=2 : Endif
  Endif
  If !instr(1,GUSRAUZ,"1") and [M]VISA(nolign-1)<>""
   # Suppression impossible, le relevé possède un visa
   GMESSAGE=mess(1,115,1)-" : "-mess(45,129,1)
   If !(dim(GWEBSERV)=1 & GWEBSERV=1) : mkstat=2 : Endif
  Endif
 When 68,83 : # Annulation  ou effacement d'un groupe de lignes
  For I = nolign - 1 To nolign1 - 1
   If [M]STA(nolign-1)>1
    # Suppression impossible, le relevé a déjà été comptabilisé
    GMESSAGE=mess(1,115,1)-" : "-mess(18,129,1)
    If !(dim(GWEBSERV)=1 & GWEBSERV=1) : mkstat=2 : Endif
   Endif
   If !instr(1,GUSRAUZ,"1") and [M]VISA(nolign-1)<>""
    # Suppression impossible, le relevé possède un visa
    GMESSAGE=mess(1,115,1)-" : "-mess(45,129,1)
    If !(dim(GWEBSERV)=1 & GWEBSERV=1) : mkstat=2 : Endif
   Endif
  Next
 When 75 :     # Modification
  If [M]STA(nolign-1)>2
   # Modification impossible, le relevé a déjà été comptabilisé
   GMESSAGE=mess(9,123,1)-" : "-mess(18,129,1)
   If !(dim(GWEBSERV)=1 & GWEBSERV=1) : mkstat=2 : Endif
  Endif
  If !instr(1,GUSRAUZ,"1") and [M]VISA(nolign-1)<>""
   # Modification impossible, le relevé possède un visa
   GMESSAGE=mess(9,123,1)-" : "-mess(45,129,1)
   If !(dim(GWEBSERV)=1 & GWEBSERV=1) : mkstat=2 : Endif
  Endif
Endcase

End


#################################### DATEXS ####
Subprog D_DATEXS(VALEUR)
Variable Date    VALEUR
If nolign>1
 VALEUR = [M]DATEXS(nolign-2)
Else
 VALEUR = [M]DATDEB
Endif
End

Subprog AM_DATEXS(VALEUR)
Variable Date    VALEUR
[M]RATDAT(nolign-1) = VALEUR
End

Subprog C_DATEXS(VALEUR)
Variable Date    VALEUR

# ->Dates par modules : ici on contrôle la date si on saisie une nvelle ligne ds le relevé.
# pas uniduement si création d'une nouvelle fiche.
If clalev([F:AOB])  = 0 : Local File AOBJET [AOB] : Endif
If [M]CODEXP(nolign-1) =""
 Call LECTURE("AOB",GABREV,"") From CONTOBJ
 Local Integer MODULE
 MODULE = [F:AOB]MODULE
 Call CTLDATMOD(MODULE,VALEUR,[M]CPY(nolign-1)) From CPTSUB
 If mkstat : End : Endif
Endif

If (VALEUR<[M]DATDEB or VALEUR>[M]DATFIN)
 GMESSAGE=mess(12,122,1)  # Date en dehors de la période
 mkstat=2 : End
Endif
End

#################################### FCY ####
Subprog AM_FCY(VALEUR)
Variable Char    VALEUR()
Local Char    SOC(GLONCPY), DEV(GLONCUR)
Local Integer ISITE
Read[CPY]CPY0=VALEUR
If !fstat
 SOC = [F:CPY]CPY
 DEV = [F:CPY]ACCCUR
 GCURLEG = [F:CPY]LEG
Else
 ISITE = find(VALEUR,GSITE(1..GNBSITE))
 If ISITE>0
  SOC = GSOCSITE(ISITE)
  Read[CPY]CPY0=SOC
  DEV = [F:CPY]ACCCUR
  GCURLEG = [F:CPY]LEG
 Endif
Endif
[M]CPY(nolign-1) = SOC : Affzo [M]CPY(nolign-1)
[M]CUR(nolign-1) = DEV : Affzo [M]CUR(nolign-1)
End

#################################### CODEXP ####
Subprog AM_CODEXP(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Read [TES]TES0 = VALEUR
[M]UOM(NOL) = [F:TES]UOM
Raz [M]VAT(NOL)
If !GIMPORT
 Affzo [M]UOM(NOL)
 Affzo [M]VAT(NOL)
Endif
End


Subprog C_CODEXP(VALEUR)
Variable Char    VALEUR()
Gosub SETNOL
Read [TES]TES0 = VALEUR

Local Integer IGCM,ILED
Local Char    CRRGCM(GLONGCM)
#Local Char    CRRLED(GLONLED)(1..len(mess(0,2644,1)))

Call VERIF([F:TES]GFY,[M]FCY(NOL),VALEUR) From CFYSUB
If mkstat : End : Endif

Call SETGCM([M]FCY(NOL),CRRGCM) From CPTDIV
IGCM = find(CRRGCM,GGCM(1..GGCMNBR))
If !IGCM : End : Endif

For I=1 To len(mess(0,2644,1))

 #If !find(evalue("GLED"+num$(I)+"("+num$(IGCM)+")"),CRRLED(1..len(mess(0,2644,1))))
 If evalue("GLED"+num$(I)+"("+num$(IGCM)+")")<>""

  ILED = find(evalue("GLED"+num$(I)+"("+num$(IGCM)+")"),GLED(1..GLEDNBR))
  If !ILED : Break : Endif
  Assign "[M]LED"+num$(I)+"("+num$(NOL)+")" With GLED(ILED)
  Assign "[M]COA"+num$(I)+"("+num$(NOL)+")" With GLEDCOA(ILED)

  Read [GCM]GCM0 = GGCM(IGCM)
  If !fstat
   For J=1 To dim([F:GCM]LED)
    If [F:GCM]LED(J-1) = GLED(ILED)
     Assign "[M]CURLED"+num$(J)+"("+num$(NOL)+")" With [F:GCM]CUR(J-1)
    Endif
   Next
  Endif

  Read [CAC]CAC0 = 20;[F:TES]ACCCOD;GLEDCOA(ILED)
  If !fstat
   Assign "[M]ACC"+num$(I)+"("+num$(NOL)+")" With [F:CAC]ACC(0)
  Endif
 Endif
Next I

# Lecture du modèle comptable
# La liste des référentiels (mode saisi - non auto)
# le code par référentiel
# ACC(1) = compte du code plan du Type de référentiel 1 (Social - Menu 2644)
#1ere solution
#Read [CAC]CAC0 = 20;[F:TES]ACCCOD;GLEDCOA(XXX)
#2eme solution
#Filter [CAC] With TYP=20 & ACCCOD=[F:TES]ACCCOD
#For [CAC]CAC0
 # Liste des codes plans
 # ACC(1) = premier code plan
#Next

#Read [TES]TES0 = VALEUR
#Read [CAC]CAC1 = 20;[F:TES]ACCCOD
#If !fstat
# For I=1 To 10
#  Assign "[M]ACC"+num$(I)+"("+num$(NOL)+")" With evalue("[F:CAC]ACC("+num$(I-1)+")")
# Next
#Endif

Call CONTEXE([F:TES]ACS) From CPTSUB
If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
Call CTLVLYDAT([M]DATEXS(nolign-1),[F:TES]VLYSTR,[F:TES]VLYEND) From CPTSUB
If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
End


#################################### AMTPAY Montant Réel TTC ####
Subprog AM_AMTPAY(VALEUR)
Variable Decimal VALEUR
Local Decimal SVG_AMT
SVG_AMT=[M:EXS0]AMTATI(nolign-1)
Call CALCUL([M:EXS0]AMTATI(nolign-1),nolign-1)
If [M:EXS0]AMTATI(nolign-1)<>SVG_AMT
 Gosub CALTVA
Endif
End


#################################### AMTATI Montant Remboursé TTC ####
Subprog AS_AMTATI(VALEUR)
Variable Decimal VALEUR

#MLGA ini - desactivado de momento por problema en el importe II
#Local Integer STAT
#Call CALCUL(VALEUR,nolign-1)
#If [M:EXS0]AMTATI(nolign-1)<>VALEUR
# [M]AMTATI(nolign-1) = VALEUR
# Gosub CALTVA
#Endif
