Subprog AS_CCE19(VALEUR)
Variable Char    VALEUR()
AXE = [M]DIE(18) : Goto SAICCE

Subprog AS_CCE20(VALEUR)
Variable Char    VALEUR()
AXE = [M]DIE(19) : Goto SAICCE

$SAICCE
Local Integer RES, IND, AXI
Local Char    COMPTE(GLONGAC)
Local Char    PLAN(GLONCOA)
Local Char    LED(GLONLED)

Gosub SETNOL
mkstat = 1

For I=1 To len(mess(0,2644,1))
 [L]LED = evalue("[M]LED"+num$(I)+"("+num$(NOL)+")")
 If [L]LED<>""
  Call INDLED([L]LED,AXE,IND,AXI) From CPTDIV
  If AXI
   COMPTE = evalue("[M]ACC"+num$(I)+"("+num$(NOL)+")")
   PLAN   = evalue("[M]COA"+num$(I)+"("+num$(NOL)+")")
   Call LECTURE("GAC",COMPTE,PLAN) From CONTOBJ
   If find(AXE,[F:GAC]DIE(0..[F:GAC]DACDIENBR-1))
    Raz mkstat
    Call LECTURE("TES",[M]CODEXP(NOL),"") From CONTOBJ
    RES = find(AXE,[F:TES]DIE(0..dim([F:TES]DIE)-1))
    If RES & [F:TES]CCEFLG(RES-1)=1 : mkstat = 2 : Endif
    Break
   Endif
  Endif
 Endif
Next

End

