For I=1 To len(mess(0,2644,1))
 Call CONTCCE(VALEUR,evalue("[M]LED"+num$(I)+"("+num$(NOL)+")"),AXE,[M]FCY(NOL),[M]DATEXS(NOL),
&             evalue("[M]ACC"+num$(I)+"("+num$(NOL)+")"),[M]DIE,"[M]CCE#",NOL) From CPTCNT
Next I
End


####################################
Subprog INICCE(VALEUR,AXE,CLB,CODEXP)
Variable Char VALEUR
Value Char    AXE
Value Char    CLB
Value Char    CODEXP

Local Integer RES1, RES2

If VALEUR <> "" : End : Endif
# Initialisation selon la tache
Call LECTURE("TES",[L]CODEXP,"") From CONTOBJ

RES1 = find(AXE,[F:TES]DIE(0..dim([F:TES]DIE)-1))

If RES1
 Case num$([F:TES]INICCE(RES1-1))
  When "1" : VALEUR = [F:TES]CCE(RES1-1)
  When "2"
   Call LECTURE("AUS",[L]CLB,"") From CONTOBJ
   RES2 = find(AXE,[F:AUS]DIE(0..dim([F:AUS]DIE)-1))
   If RES2
    VALEUR = [F:AUS]CCE(RES2-1)
   Endif
 Endcase
Endif
End

##########################################
Subprog CONTCCE(VALEUR,AXE,FCY,DAT,CCE,NOL)
Variable Char VALEUR
Value Integer AXE
Value Char    FCY()
Value Date    DAT
Value Char    CCE    : # "[M]CCE#" par exemple, # indique zone indicée
Value Integer NOL
Local Char    BID(20)
Local Integer I , K , OK


# Contrôle qu'on a au moins renseigné un axe
If VALEUR=""
 OK = 0
 For I=AXE+1 To GOPTCANA
  If evalue("[F:TES]CCEFLG"+"("+num$(I-1)+")")=2
   OK = 1 : Break
  Endif
 Next I
 If !OK : # C'est le dernier axe saisissable...
  OK = 0
  For I=1 To AXE-1
   K = instr(1,[L]CCE,"#")
   If K
    BID = evalue(left$([L]CCE,K-1)+num$(I)+"("+num$(NOL)+")")
   Else
    BID = evalue([L]CCE+"("+num$(NOL)+")")
   Endif
   If BID<>"" : OK = 1 : Break : Endif
  Next
  If !OK
   GMESSAGE = mess(98,106,1) # Au moins un axe doit être renseigné
   mkstat = 2 : End
  Endif
 Endif
Endif

If VALEUR="" : End : Endif
Call LECTURE("CCE",VALEUR,num$(AXE)) From CONTOBJ
If fstat
 GMESSAGE = VALEUR-mess(35,106,1) : # Section inexistante
 mkstat = 2 : End
Endif
Call VERIF([F:CCE]FCY,[L]FCY,VALEUR) From CFYSUB
If mkstat : End : Endif
Call CONTEXE([F:CCE]ACS) From CPTSUB
If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif
Call CTLVLYDAT([L]DAT,[F:CCE]VLYSTR,[F:CCE]VLYEND) From CPTSUB
If mkstat : GMESSAGE = VALEUR-GMESSAGE : End : Endif

For I=1 To GOPTCANA
 If I<>AXE
  K = instr(1,[L]CCE,"#")
  If K
   BID = evalue(left$([L]CCE,K-1)+num$(I)+"("+num$(NOL)+")")
  Else
   BID = evalue([L]CCE+"("+num$(NOL)+")")
  Endif
  If BID<>""
   Read [CCE2]CCE0 = I ; BID
   Look [AUZ]CAZ0 = 1 ; [F:CCE]AUZ ; [F:CCE2]AUZ
   If !fstat
    GMESSAGE = VALEUR-mess(26,106,1)-[F:CCE2]CCE  : # Interdit avec la section
    mkstat = 1 : Break
   Endif
  Endif
 Endif
Next I
End

###########################################################################################
###########################################################################################
############################### Gestion des accès        ##################################
###########################################################################################
###########################################################################################
#### Mise à jour des accès
Subprog MODIF_ACS(USR,ACS)
Value Char USR()
Value Char ACS()
If filinfo(filpath("FIL","EXPENSESH", "fde",nomap),0)<1 : End : Endif
If clalev([F:EXH]) = 0 : Local File EXPENSESH   [EXH] : Endif
Read [EXH]EXH0 = USR
If !fstat & [F:EXH]ACSEXS<>[L]ACS
 [F:EXH]ACSEXS=ACS
 Rewrite [EXH]
 If fstat
  GOK=0 : Call FSTA("EXH") From GLOCK
 Endif
Endif
End

###########################################################################################
#### Initialisation des accès
Subprog INIT_ACS(USR,ACS)
Value Char USR()
Variable  Char ACS()
Call LECTURE("AUS",USR,"") From CONTOBJ
If !fstat
 ACS=[F:AUS]ACSUSR
Endif
End

###########################################################################################
###########################################################################################
############################### Gestion de la TVA        ##################################
###########################################################################################
###########################################################################################
Subprog AS_VAT(VALEUR)
Variable Char    VALEUR()
Local Char PLAN(GLONCOA)
Call LECMAINPLAN(1,[M]CPY(nolign-1),PLAN) From CPTDIV
Read [TES]TES0 = [M]CODEXP(nolign-1)
Call LECTURE("CAC",[F:TES]ACCCOD,"20~"+PLAN) From CONTOBJ
Call LECTURE("GAC",[F:CAC]ACC(0),PLAN) From CONTOBJ
If [F:GAC]ACC<>""
 If [F:GAC]FLGVAT<2    # Compte non soumis à la TVA
  mkstat = 1 : End
 Endif
Endif
If VALEUR= ""
 Read [TES]TES0 = [M]CODEXP(nolign-1)
 VALEUR = [F:TES]VAT
 [M]VAT(nolign-1)=VALEUR
 Gosub CALTVA
Endif
If !instr(1,GUSRAUZ,"1") : mkstat = 2 : End : Endif
GBOUT2 = mess(1,119,1) : # Saisie taxes
End

Subprog C_VAT(VALEUR)
Variable Char VALEUR()
If VALEUR<>""
 Call LEC_TVT_LEG(GCURLEG,VALEUR) From CPTLEC
 If [F:TVT]VATTYP<>1
  # Cette taxe n'est pas de type TVA
  GMESSAGE = mess(11,119,1)
  mkstat = 2 : End
 Endif
Endif
Gosub SETNOL
[M]AMTCUR(NOL) = [M]AMTATI(NOL)-[M]AMTTAX1(NOL)-[M]AMTTAX2(NOL)-[M]AMTVAT(NOL)
End

Subprog AM_VAT(VALEUR)
Variable Char VALEUR()
If VALEUR<>[M]VAT(nolign-1)
 [M]VAT(nolign-1) = VALEUR
 Gosub CALTVA
 If STAT
  Call ERR_CALTAXE(STAT,MESSA) From SUBTVT
  GMESSAGE = MESSA : mkstat = 2 : End
 Endif
Endif
End


$CALTVA
Local Char    TAXES(GLONVAT)(1..3), MESSA(80)
Local Decimal MONTVAT(1..3) , MONTDED(1..3)
Local Integer TYPREG , STAT
Local Date    DATREF
Gosub SETNOL
TAXES(1) = [M]TAX1(NOL)
TAXES(2) = [M]TAX2(NOL)
TAXES(3) = [M]VAT(NOL)
DATREF   = [M]DATEXS(NOL)
Call CALTAXE([M]CPY(NOL),DATREF,"",[M]CUR(NOL)
& ,3,TAXES,2,[M]AMTATI(NOL),MONTVAT,MONTDED,TYPREG,STAT) From SUBTVT
If TYPREG<>1
 Raz MONTVAT, MONTDED
Endif
[M]AMTTAX1(NOL) = MONTVAT(1)
[M]AMTTAX2(NOL) = MONTVAT(2)
[M]AMTVAT(NOL)  = MONTVAT(3)
If dim([M]DEDTAX1)>0 : [M]DEDTAX1(NOL) = MONTDED(1) : Endif
If dim([M]DEDTAX2)>0 : [M]DEDTAX2(NOL) = MONTDED(2) : Endif
If dim([M]DEDVAT)>0  : [M]DEDVAT(NOL)  = MONTDED(3) : Endif
[M]AMTCUR(NOL) = [M]AMTATI(NOL)-[M]AMTTAX1(NOL)-[M]AMTTAX2(NOL)-[M]AMTVAT(NOL)
Return


Subprog AS_FCY(VALEUR)
Variable Char    VALEUR()
If GIMPORT & [M]MODIF(indice)<>"" & !find(VALEUR,GUSRFCY(1..GNBAUZ))
 mkstat = 2 : End
Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
Call CONTBPRCPY([M]CLB,VALEUR,"","","F") From CPTSUB
If mkstat=2 : End : Endif
Call GETSOC(VALEUR) From DEVSUB
End

Subprog AS_AMTPAY(VALEUR)
Variable Decimal VALEUR
If VALEUR<>0 : End : Endif

Local Integer NOL : NOL = nolign-1
Local Integer STAT
If GCURSHR="" : GCURSHR=GSYSCUR : Endif

# Initialisation par rapport au code tâche
Read [TES]TES0 = [M]CODEXP(NOL)

Case [F:TES]TYPVLT
  When 1
   # Montant unitaire saisi...
   If GCURSHR=[M:EXS0]CUR(NOL)
    # Même devise entre la note de frais et la devise reporting
    VALEUR = [F:TES]VLTDEFUNI*[M:EXS0]QTY(NOL)
   Else
    # La devise de la note de frais est différente de la devise reporting
    Local Decimal DEFCUR
    Local Char TYPCOU(10)
    Call PARAML([M:EXS0]FCY(NOL),"CNSTYPCUR",TYPCOU) From ADOVAL
    Call CONVERT3(GCURSHR,[M:EXS0]CUR(NOL),[F:CPY]ACCCUR,val(TYPCOU),[M:EXS0]DATEXS(NOL),
&                [F:TES]VLTDEFUNI,DEFCUR,0,STAT) From CPTSUB
    VALEUR = DEFCUR*[M:EXS0]QTY(NOL)
   Endif
  When 2
   # Montant via le paramétrage du collaborateur...
   Local Char DEFPAR
   Call PARAMUTIL([F:TES]VLTDEFPAR,DEFPAR,[M:EXS0]CLB,[M:EXS0]FCY(NOL)) From SUBAUS
   If GCURSHR=[M:EXS0]CUR(NOL)
    VALEUR = val(DEFPAR)*[M:EXS0]QTY(NOL)
   Else
    # La devise de la note de frais est différente de la devise reporting
    Local Decimal DEFCUR
    Local Char TYPCOU(10)
    Call PARAML([M:EXS0]FCY(NOL),"CNSTYPCUR",TYPCOU) From ADOVAL
    Call CONVERT3(GCURSHR,[M:EXS0]CUR(NOL),[F:CPY]ACCCUR,val(TYPCOU),[M:EXS0]DATEXS(NOL),
&                 val(DEFPAR),DEFCUR,0,STAT) From CPTSUB
    VALEUR= DEFCUR*[M:EXS0]QTY(NOL)
   Endif
Endcase
End


Subprog INI_COURS(ABRMSK,SOCIETE,DEVTRS,DATCOURS,TYPCOURS,NOLI)
Value Char    ABRMSK()
Value Char    SOCIETE()
Value Char    DEVTRS()
Value Date    DATCOURS
Value Integer TYPCOURS
Value Integer NOLI
Local Char    MASQUE(10)
MASQUE = "["+ABRMSK+"]"
Default Mask MASQUE
Call SETMAINREF(SOCIETE,GTYPGEN,GTYPANA) From CPTDIV
Call CHARG_ZONES_DEV(ABRMSK,SOCIETE,DEVTRS,DATCOURS,TYPCOURS,NOLI) From SUBBICS
Call INIT_COURS(ABRMSK,NOLI)
End

Subprog INIT_COURS(ABRMSK,NOLI)
Value Char    ABRMSK
Value Integer NOLI
# REMPLISSAGE du masque SAICURLED [SCL]
If clalev([M:SCL])=0 : Local Mask SAICURLED [SCL] : Endif # Masque pour la gestion des devises
Local Char MASQUE(10)
MASQUE = "["+ABRMSK+"]"
Default Mask MASQUE
For J=0 To min([M:SCL]NBRC-1,len(mess(0,2644,1)))
 [M:SCL]RATDIV(J)  = evalue("[M:EXS0]RATDIV"+num$([M:SCL]LEDTYP(J))+"("+num$(NOLI-1)+")")
 [M:SCL]RATMLT(J)  = evalue("[M:EXS0]RATMLT"+num$([M:SCL]LEDTYP(J))+"("+num$(NOLI-1)+")")
 [M:SCL]RATDIV1(J) = [M:SCL]RATDIV(J)
 [M:SCL]RATMLT1(J) = [M:SCL]RATMLT(J)
Next
End



######################################################################################
## Action VISUEXSBLB
######################################################################################

$OUVRE_BLB
Local Date DDAT
DDAT = PARAM(2)
If !clalev([F:BEXP])  : Local File BLOBEXPENSES [BEXP]  : Endif
Raz [F:BEXP]
Return

$DEBUT_BLB
Raz [M:EXSB]
Read [BEXP]BEXP0 = val(PARAM(3))
If !fstat
 [M:EXSB]BLOB = [F:BEXP]BLOB
Endif
# SAM 100682
If [M:EXS0]STA(nolign-1)>1 or (!instr(1,GUSRAUZ,"1") and [M:EXS0]VISA(nolign-1)<>"")
 Grizo [M:EXSB]BLOB
Else
 Actzo [M:EXSB]BLOB
Endif
# fin SAM 100682
Return

$OK_BLB
Call DEBTRANS From GLOCK
Gosub TR_OK_BLB
Return

$TR_OK_BLB
Trbegin [BEXP]
# SAM 100682
 If len([M:EXSB]BLOB)>0
# fin SAM 100682
  Readlock [BEXP]BEXP0 = val(PARAM(3))
  If fstat=1
   GOK=-1 : GLOCK="$BLOBEXPENSES"-PARAM(1)-PARAM(2)-PARAM(3)
  Elsif fstat=0
   [F:BEXP]BLOB   = [M:EXSB]BLOB
   Rewrite [BEXP]
   If fstat
    GOK=0 : Call FSTA("BEXP") From GLOCK
   Endif
  Elsif fstat
   Raz [F:BEXP]
   [F:BEXP]CLB    = PARAM(1)
   [F:BEXP]DATEXS = DDAT
   [F:BEXP]ACCNUM = val(PARAM(3))
   [F:BEXP]BLOB   = [M:EXSB]BLOB
   Write [BEXP]
   If fstat
    GOK = 0 : Call FSTA("BEXP") From GLOCK
   Endif
  Endif
  If GOK<0   : Goto ROLL_TR_OK_BLB
  Elsif !GOK : Goto AB_TR_OK_BLB
  Endif
 Else
  Delete [BEXP] Where ACCNUM=val(PARAM(3))
  If fstat=1
   GOK = -1 : GLOCK="$BLOBEXPENSES" : Goto ROLL_TR_OK_BLB
  Endif
 Endif
Commit
Return

$ROLL_TR_OK_BLB
Rollback
Call ROLL From GLOCK
If GROLL
 Return
Else
 Goto TR_OK_BLB
Endif
Return

$AB_TR_OK_BLB
Rollback
Return

