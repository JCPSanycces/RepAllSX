#MLGA fin

End


Subprog CALCUL(MNT,NOL)
Variable Decimal MNT
Value Integer NOL
Local Integer STAT

If GCURSHR="" : GCURSHR=GSYSCUR : Endif   # Aléatoirement, je me retrouve "Devise inexistante" car GCURSHR est vide

# Calcul par rapport au code tâche
Read [TES]TES0 = [M:EXS0]CODEXP(NOL)

Case [F:TES]TYPVLT
  When 1 : # Valeur fixe
   # Montant unitaire saisi...
   If GCURSHR=[M:EXS0]CUR(NOL)
    # Même devise entre la note de frais et la devise reporting
    If [F:TES]VLTPFDUNI>0 & [M:EXS0]AMTPAY(NOL)>[F:TES]VLTPFDUNI*[M:EXS0]QTY(NOL)
     # Montant plafonné
     MNT = [F:TES]VLTPFDUNI*[M:EXS0]QTY(NOL)
    Else
     # Montant remboursé = montant réel
     MNT = [M:EXS0]AMTPAY(NOL)
    Endif
   Else
    # La devise de la note de frais est différente de la devise reporting
    If [F:TES]VLTPFDUNI>0
     # Montant plafonné
     Local Decimal PFDCUR
     Local Char TYPCOU(10)
     Call PARAML([M:EXS0]FCY(NOL),"CNSTYPCUR",TYPCOU) From ADOVAL
     Call CONVERT3(GCURSHR,[M:EXS0]CUR(NOL),[F:CPY]ACCCUR,val(TYPCOU),[M:EXS0]DATEXS(NOL),
&                  [F:TES]VLTPFDUNI,PFDCUR,0,STAT) From CPTSUB
     If [M:EXS0]AMTPAY(NOL)>PFDCUR*[M:EXS0]QTY(NOL)
      MNT = PFDCUR*[M:EXS0]QTY(NOL)
     Else
      MNT = [M:EXS0]AMTPAY(NOL)
     Endif
    Else
     MNT = [M:EXS0]AMTPAY(NOL)
    Endif
   Endif

  When 2 : # Valeur utilisateur
   # Montant via le paramétrage du collaborateur...
   Local Char PFDPAR
   Call PARAMUTIL([F:TES]VLTPFDPAR,PFDPAR,[M:EXS0]CLB,[M:EXS0]FCY(NOL)) From SUBAUS
   If GCURSHR=[M:EXS0]CUR(NOL)
    # Même devise entre la note de frais et la devise reporting
    If val(PFDPAR)>0 & [M:EXS0]AMTPAY(NOL)>val(PFDPAR)*[M:EXS0]QTY(NOL)
     # Montant plafonné
     MNT = val(PFDPAR)*[M:EXS0]QTY(NOL)
    Else
     # Montant remboursé = montant réel
     MNT = [M:EXS0]AMTPAY(NOL)
    Endif
   Else
    # La devise de la note de frais est différente de la devise reporting
    If val(PFDPAR)>0
     # Montant plafonné
     Local Decimal PFDCUR
     Local Char TYPCOU(10)
     Call PARAML([M:EXS0]FCY(NOL),"CNSTYPCUR",TYPCOU) From ADOVAL
     Call CONVERT3(GCURSHR,[M:EXS0]CUR(NOL),[F:CPY]ACCCUR,val(TYPCOU),[M:EXS0]DATEXS(NOL),
&                  val(PFDPAR),PFDCUR,0,STAT) From CPTSUB
     If [M:EXS0]AMTPAY(NOL)>PFDCUR*[M:EXS0]QTY(NOL)
      MNT = PFDCUR*[M:EXS0]QTY(NOL)
     Else
      MNT = [M:EXS0]AMTPAY(NOL)
     Endif
    Else
     MNT = [M:EXS0]AMTPAY(NOL)
    Endif
   Endif
  When 3 : # Frais kilométriques
   Local Char MILPAR, VHLPAR
   Call PARAMUTIL("EXPMIL",MILPAR,[M:EXS0]CLB,[M:EXS0]FCY(NOL)) From SUBAUS
   Call PARAMUTIL("EXPVHL",VHLPAR,[M:EXS0]CLB,[M:EXS0]FCY(NOL)) From SUBAUS
   Read [EXM]EXM0=val(MILPAR);val(VHLPAR)
   If !fstat
    If GCURSHR=[M:EXS0]CUR(NOL)
     MNT = [F:EXM]INDRAT*[M:EXS0]QTY(NOL)
    Else
     Local Char TYPCOU(10)
     Call PARAML([M:EXS0]FCY(NOL),"CNSTYPCUR",TYPCOU) From ADOVAL
     Call CONVERT3(GCURSHR,[M:EXS0]CUR(NOL),[F:CPY]ACCCUR,val(TYPCOU),[M:EXS0]DATEXS(NOL),
&                  [F:EXM]INDRAT*[M:EXS0]QTY(NOL),MNT,0,STAT) From CPTSUB
    Endif
   Endif
Endcase
If MNT<>0
 If clalev([F:TCU])=0 : Local File TABCUR [TCU] : Endif
 If [F:TCU]CUR<>[M:EXS0]CUR(NOL)
  Read [TCU]TCU0 = [M:EXS0]CUR(NOL)
 Endif
 MNT = arr(MNT,[F:TCU]CURRND)
Endif
End

Subprog AM_AMTATI(VALEUR)
Variable Decimal VALEUR
[M]AMTATI(nolign-1) = VALEUR
Gosub CALTVA
End

Subprog C_CUR(VALEUR)
Variable Char    VALEUR()
Call CONTDEV(VALEUR,[M:EXS0]RATDAT(nolign-1)) From TRTDEV
If mkstat : End : Endif
End

Subprog AM_CUR(VALEUR)
Variable Char     VALEUR
If !GIMPORT
 [M:EXS0]CUR(nolign-1)=VALEUR
 Call INI_COURS("EXS0",[M:EXS0]CPY(nolign-1),[M:EXS0]CUR(nolign-1),[M:EXS0]RATDAT(nolign-1),1,nolign)
Endif
Call CALCUL([M:EXS0]AMTATI(nolign-1),nolign-1)
End

