#<AdxTL>@(#)0.0.0.0 $Revision$ Clientes
$ACTION
#Infbox ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
   When "APRES_MODIF"         : Gosub APRES_MODIF
   When "AVANT_CHOI"          : Gosub RECUPERA
   When "VERIF_CRE"           : Gosub VERIF_CRE
   When "SETBOUT"             : Gosub SETBOUT
   When "APRES_MODIF"         : Gosub APRES_MODIF
#   When "OUVRE"    :  Gosub OUVRE
#   When "FILTRE"   :  Gosub FILTRE
   When "LIENS"               : Gosub LIENS
#   When "CREATION" :  Gosub CREATION
#   When "MODIF"    :  Gosub MODIF
#   When "ANNULE"   :  Gosub ANNULE
#   When "APRES_CRE":  Gosub APRES_CRE
#   When "APRES_MOD" : Gosub APRES_MOD
#   When "INICRE_LIG": Gosub INICRE_LIG
#   When "DEFLIG" :    Gosub DEFLIG


  When Default
Endcase
Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$APRES_MODIF

    Global Char XBPAADD(5)
    #infbox (num$([BPC4]BPAADD(nolign-1)))
    XBPAADD = [BPC4]BPAADD(nolign-1)

Return
##############################################################
$LIENS
#Gosub LIENS From TABLEAUX
#MRR 10/10/18 Añadir campo XENVIO en clientes entrega
 If GACTFTC=2
    [M]XXENVIO   = [M]XENVIO(0)
    [M]XZFECHVEN = [M]ZFECHVEN(0)
    [M]XZCONRENV = [M]ZCONRENV(0)
 Endif
#MRR 10/10/18 Añadir campo XENVIO en clientes entrega

##############################################################
$VERIF_CRE
If [M:BPC3]CCE(0) = '' or [M:BPC3]CCE(2) = '' or [M:BPC3]CCE(3) = '' or [M:BPC3]CCE(4) = '' or [M:BPC3]CCE(5) = '' Then
  GERR = 1 : GMESSAGE = "Ejes analíticos obligatorios" : OK = 0
Endif
Return

##############################################################
$SETBOUT
  # Y10FE - STR
  Gosub MUESTRA_CENTROS
  # Y10FE - END
Return

