##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$RECUPERA
  Local File BPDLVCUST[XBPC0]
  Read [XBPC0]BPD0 = [M:BPC0]BPCNUM;XBPAADD
  If fstat > 1
     # no exite el registro
  Elsif fstat = 1
     # registro bloqueado
  Else
      #infbox [XBPC0]XHTLCRS
      Effzo [M:BPC4]XXHTLCRS
      [M:BPC4]XXHTLCRS = [XBPC0]XHTLCRS
      Affzo [M:BPC4]XXHTLCRS
  Endif
  Close File [XBPC0]
Return

##############################################################
$MUESTRA_CENTROS
  # Y10FE - STR
  Raz [M:BPC4]YSCONTABLE,YOGESTION,YUPROCESO
  Affzo [M:BPC4]YSCONTABLE,YOGESTION,YUPROCESO
  If !clalev([F:BPD0]) Then : Local File BPDLVCUST [F:BPD0] : Endif
  Filter [F:BPD0] Where BPCNUM = [M:BPC0]BPCNUM and BPAADD = [M:BPC4]XBPAADD
  Read [F:BPD0] First
  If !fstat Then
    [M:BPC4]YSCONTABLE  = [F:BPD0]YSCONTABLE
    Affzo [M:BPC4]YSCONTABLE
    [M:BPC4]YOGESTION   = [F:BPD0]YOGESTION
    Affzo [M:BPC4]YOGESTION
    [M:BPC4]YUPROCESO   = [F:BPD0]YUPROCESO
    Affzo [M:BPC4]YUPROCESO
  Endif
  Filter [F:BPD0]
  Close Local File [BPD0]
  # Y10FE - END
Return

