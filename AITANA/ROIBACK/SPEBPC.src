######################################################################################
## Después de modificar el campo '01 Servicio contable' (pantalla BPC4) 30/11/2020 15:35:27 (AIT07)
######################################################################################
# Y10FE
Subprog AM_YSCONTABLE(VALEUR)
Variable Char    VALEUR()
  If !clalev([F:BPD0]) Then : Local File BPDLVCUST [F:BPD0] : Endif
  Filter [F:BPD0] Where BPCNUM = [M:BPC0]BPCNUM and BPAADD = [M:BPC4]XBPAADD
  Read [F:BPD0] First
  If !fstat Then
    [F:BPD0]YSCONTABLE = VALEUR
    Trbegin [F:BPD0]
    Rewrite [F:BPD0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Endif
  Filter [F:BPD0]
  Close Local File [BPD0]
End

