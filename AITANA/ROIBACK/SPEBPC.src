## Etiqueta añadida por el supervisor (pantalla BPC4) 15/09/2016 15:50:41 (ADMIN)
######################################################################################


Subprog AS_NBDLV

    Effzo [M:BPC4]XXHTLCRS
    [M:BPC4]XXHTLCRS = [M:BPC4]XHTLCRS(nolign-1)
    Affzo [M:BPC4]XXHTLCRS

  # Y10FE - STR
  Gosub MUESTRA_CENTROS
  # Y10FE - END
End

######################################################################################
## Etiqueta añadida por el supervisor (pantalla BPC4) 15/09/2016 17:15:59 (ADMIN)
######################################################################################
Subprog AM_XXHTLCRS(VALEUR)
  Variable Char    VALEUR()
  [M]XHTLCRS([M]XNUMLIG) = VALEUR
  [M:BPC4]FLMOD([M]XNUMLIG) = 1
End

######################################################################################
## Etiqueta añadida por el supervisor (pantalla BPC4) 26/09/2016 12:46:24 (ADMIN)
######################################################################################
Subprog IB_NBDLV
End

Subprog AM_XHTLCRS(VALEUR)
Variable Char    VALEUR()
End

