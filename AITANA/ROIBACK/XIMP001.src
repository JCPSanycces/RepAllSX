#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
#infbox ACTION
Case ACTION
  When "EXEC"     : Gosub EXEC
  When Default
Endcase
 Return

##################################################################################
$EXEC
  Gosub IMPRIMIR_VENCIM
Return

##################################################################################
$IMPRIMIR_VENCIM
  Local Char TBPAR(15)(1..50),TBVAL(30)(1..50)

  #Valores que pasamos al report
  TBPAR(1) = 'tercfactdeb'
  TBVAL(1) = [M:DDM]BPRDEB
  TBPAR(2) = 'tercfactfin'
  TBVAL(2) = [M:DDM]BPRFIN
  TBPAR(3) = 'deladdressdeb'
  TBVAL(3) = ''
  TBPAR(4) = 'deladdressfin'
  TBVAL(4) = ''

  #Generación del informe.
  Call ETAT("XDEUCLI","",GLANGUE,0,"",TBPAR,TBVAL) From AIMP3

Return

##################################################################################

