#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
Case ACTION
  When "WVARPOST": Gosub WVARPOST
Endcase
Return

$WVARPOST
If WLIBRO=1
For WIND = 0 To IND
  If WCAUSAEXES(WIND)="E5"
   WIMPNSRLOCS(WIND)=WBASEEXES(WIND)
   WCAUSAEXES(WIND)=""
   WBASEEXES(WIND)=""
  Endif
  If WCLAREGESP(WIND)="08"
    WCLAREGESP(WIND)="01"
    WCAUSAEXE(WIND)=""
    WBASEEXE(WIND)=""
  Endif
###################################################################################################
## Modificación del SII: Solicitud de que las facturas a canarias haga desglose por operaciones
###################################################################################################
  If !clalev([F:ZDVS]) Local File DCLVATSPA[ZDVS]: Endif
  Filter [ZDVS] Where TAXTYP="R" & NUM=WNUMFACID(WIND)# & TYP=WGTE(WIND)
  Read [ZDVS]DVS0 First
  If !fstat and [F:ZDVS]VAC="CAN"
   WTIPODESG(WIND)="T"
   WIMPNSRLOCS(WIND)=WIMPNSRLOC(WIND)
   WIMPNS714S(WIND)=WIMPNS714(WIND)
   Raz WIMPNSRLOC(WIND)
   WSERVICIOS(WIND)=1
  Endif
Next

Endif
#If WLIBRO=2
#If !clalev([F:ZDVS]) Local File DCLVATSPA[ZDVS]: Endif
#For WIND = 0 To IND
#  Filter [ZDVS] Where TAXTYP="S" & NUM=WNUMFACID(WIND)# & TYP=WGTE(WIND)
#  Read [ZDVS]DVS0 First
#  If !fstat and [F:ZDVS]VAC="EXI"
#    WCLAREGESP(WIND)="09"
#  Endif
#Next
#Endif
Return

