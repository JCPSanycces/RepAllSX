Subprog ZINTCLI(ZCLIENTE)
 Value Char ZCLIENTE
  IF ZCLIENTE <> ''
    Local File BPCUSTOMER  [XBPC]
 ELSE
     Local File YBPCUSTOMER [XBPC]   
 ENDIF

 Local File BPADDRESS   [XBPA]
 Local File CONTACT     [XCNT]
 Local File BPARTNER    [XBPR]
 Local File CONTACTCRM  [XAIN]

  Local Char xfich(50),xdir(250),xext(3), REG1(250),REG2(250),REG3(250),REG4(250),REG5(250),REG6(250)
  Local Char TELF(15), FAX(15), EMAIL(50),FUNCION_CONTACTO(15),TXT_FUNCION(123)
  
  xdir = "c:\Sage\APP\X3V9\folders\PROTO\tmp"
  xfich = "PRUEBA"
  Xext = "txt"
  FICHERO      = filpath(Xdir,xfich,xext,"","","")
  Openo FICHERO,0 Using [XTMP]
  Iomode adxirs chr$(13)+chr$(10) Using [XTMP]

  If ZCLIENTE = '' 
    For [XBPC]
      Gosub Detalle
      WRSEQ SEG$(REG1,1,215)+SEG$(REG2,1,97)+SEG$(REG3,1,126)+SEG$(REG4,1,126)+SEG$(REG5,1,126)+SEG$(REG6,1,128) USING [XTMP]
    Next
  else
 
    FOR [XBPC] Where BPCNUM = ZCLIENTE
 
      Gosub Detalle
infbox reg1
      WRSEQ SEG$(REG1,1,215)+SEG$(REG2,1,97)+SEG$(REG3,1,126)+SEG$(REG4,1,126)+SEG$(REG5,1,126)+SEG$(REG6,1,128) USING [XTMP]


    Next
  ENDIF

 Openo Using [XTMP]



 Close Local File [XBPC], [XBPA], [XCNT], [XBPR], [XAIN]

END

#############################################################
$DETALLE
    REG1 = '' 
#	
    If [XBPC]CREDATTIM >= [XBPC]UPDDATTIM
	   REG1 = 'A'
	ELSE
	   REG1 = 'M'
	   If [XBPC]BPCSTA <> 2
	      REG1 = 'B'
	   ENDIF
	ENDIF

### CODIGO COMUNICACIONES CONCESIONARIO
        REG1 = REG1 + '999'
	
	REG1 = REG1 + format$("K0:7X",SEG$([XBPC]BPCNUM,1,7))

### CODIGO CLIENTE UNILEVER
        IF [XBPC]BCGCOD = 'SAM'
		REG1 = REG1 + ''
	ELSE
		REG1 = REG1 + SPACE$(10)
	ENDIF
	
	REG1 = REG1 + format$("K0:30X",SEG$([XBPC]BPCNAM,1,30))
#	REG1 = REG1 + format$("K0:30X",SEG$([XBPC]BPAINV,1,30))
	
	TELF='':FAX='':EMAIL=''
	For [XBPA] Where [XBPA]BPATYP = 1 & [XBPA]BPANUM = [XBPC]BPCNUM & [XBPA]BPAADDFLG = 2
		REG1 = REG1 + format$("K0:30X",SEG$([XBPA]BPAADDLIG(0),1,30))
		REG1 = REG1 + format$("K0:30X",SEG$([XBPA]CTY,1,30))
	        REG1 = REG1 + format$("K0:10X",SEG$([XBPA]POSCOD,1,10))
		
		TELF  = format$("K0:15X",SEG$([XBPA]TEL(1),1,15))
		FAX   = format$("K0:15X",SEG$([XBPA]TEL(2),1,15))
		EMAIL = format$("K0:50X",SEG$([XBPA]WEB(1),1,50))
	Break
	Next
	
	If [XBPC]BCGCOD = 'SAM'
		REG1 = REG1 + 'F'
	ELSE
	    REG1 = REG1 + 'C'
	ENDIF
        READ [XBPR]BPR0 = [XBPC]BPCNUM
        IF !FSTAT	
           REG1 = REG1 + format$("K0:15X",SEG$([XBPR]CRN, 1, 15))
    	   REG1 = REG1 + format$("K0:30X",SEG$([XBPR]BPRNAM,1,30))
        ELSE
           REG1 = REG1 + SPACE$(15)
           REG1 = REG1 + SPACE$(30)
        ENDIF
	
	
	REG1 = REG1 + TELF
### FAMILIA
        REG1 = REG1 + '  '
### COMPETENCIA BAJA
        REG1 = REG1 + '  '
	
	REG1 = REG1 + format$("K0:8X",vireblc(format$("D:DD[]MM[]YYYY", [F:XBPC]UPDDATTIM),0))
	
#PONER	REG1 = REG1 + format$("K0:1X",SEG$([XBPC]ZTMP,1,1))

### MOTIVO DE LA BAJA
        REG1 = REG1 + ' '
	
	REG1 = REG1 + 'NO'
	
### COMPETENCIA ALTA
	REG1 = REG1 + '  '

	REG1 = REG1 + FAX
	REG1 = REG1 + EMAIL

######### SEGUNDO REGISTROS ########
        REG2 = ''
	REG2 = REG2 + format$("K0:30X",SEG$([XBPA]BPAADDLIG(0),1,30))
	REG2 = REG2 + format$("K0:30X",SEG$([XBPA]CTY,1,30))
	REG2 = REG2 + format$("K0:10X",SEG$([XBPA]POSCOD,1,10))
	
#PONME	IF [XBPC]ZDDAY1 = '1' 
#PONME	   REG2 = REG2 + ' '
#PONME	ELSE 
	   REG2 = REG2 + 'F'
#PONME	ENDIF
#PONME	IF [XBPC]ZDDAY2 = '1' 
#PONME	   REG2 = REG2 + ' '
#PONME	ELSE 
	   REG2 = REG2 + 'F'
#PONME	ENDIF
#PONME	IF [XBPC]ZDDAY3 = '1' 
#PONME	   REG2 = REG2 + ' '
#PONME	ELSE 
	   REG2 = REG2 + 'F'
#PONME	ENDIF
#PONME	IF [XBPC]ZDDAY4 = '1' 
#PONME	   REG2 = REG2 + ' '
#PONME	ELSE 
	   REG2 = REG2 + 'F'
#PONME	ENDIF
#PONME	IF [XBPC]ZDDAY5 = '1' 
#PONME	   REG2 = REG2 + ' '
#PONME	ELSE 
	   REG2 = REG2 + 'F'
#PONME	ENDIF
#PONME	IF [XBPC]ZDDAY6 = '1' 
#PONME	   REG2 = REG2 + ' '
#PONME	ELSE 
	   REG2 = REG2 + 'F'
#PONME	ENDIF
#PONME	IF [XBPC]ZDDAY7 = '1' 
#PONME	   REG2 = REG2 + ' '
#PONME	ELSE 
	   REG2 = REG2 + 'F'
#PONME	ENDIF
	
#PONME	REG2 = REG2 + format$("K0:20X",SEG$([XBPC]ZHOR, 1, 20))
	
        REG3 = '':REG4 = '':REG5=''
	contador = 1
	For [XCNT] Where [F:XCNT]BPATYP = 1 & [XCNT]BPANUM = [XBPC]BPCNUM
          [F:XAIN]CNTFULNAM =''
          READ [XAIN]AIN0 = [F:XCNT]CCNCRM
          CASE CONTADOR
              WHEN 1 
### recuperar nombre funcion
                   CALL RECDESMENU (233,[XCNT]CNTFNC,'SPA',TXT_FUNCION)
                   REG3 = REG3 + format$("K0:15X",SEG$(TXT_FUNCION,1,15)) 
	           REG3 = REG3 + format$("K0:30X",SEG$([XAIN]CNTFULNAM,1,30))
	           REG3 = REG3 + format$("K0:50X",SEG$([XCNT]WEB, 1, 50))
	           REG3 = REG3 + format$("K0:15X",SEG$([XCNT]TEL, 1, 15))
                   REG3 = REG3 + format$("D:DD[]MM[]YYYY", [F:XCNT]CREDATTIM)
### FECHA DE BAJA
                   REG3 = REG3 + ''
               WHEN 2 
### recuperar nombre funcion
                   CALL RECDESMENU (233,[XCNT]CNTFNC,'SPA',TXT_FUNCION)
                   REG4 = REG3 + format$("K0:15X",SEG$(TXT_FUNCION,1,15)) 
	           REG4 = REG4 + format$("K0:30X",SEG$([XAIN]CNTFULNAM,1,30))
	           REG4 = REG4 + format$("K0:50X",SEG$([XCNT]WEB, 1, 50))
	           REG4 = REG4 + format$("K0:15X",SEG$([XCNT]TEL, 1, 15))
                   REG4 = REG4 + format$("D:DD[]MM[]YYYY", [F:XCNT]CREDATTIM)
### FECHA DE BAJA
                   REG4 = REG4 + ''
               WHEN 3
### recuperar nombre funcion
                   CALL RECDESMENU (233,[XCNT]CNTFNC,'SPA',TXT_FUNCION)
                   REG3 = REG3 + format$("K0:15X",SEG$(TXT_FUNCION,1,15)) 
	           REG5 = REG5 + format$("K0:30X",SEG$([XAIN]CNTFULNAM,1,30))
	           REG5 = REG5 + format$("K0:50X",SEG$([XCNT]WEB, 1, 50))
	           REG5 = REG5 + format$("K0:15X",SEG$([XCNT]TEL, 1, 15))
                   REG5 = REG5 + format$("D:DD[]MM[]YYYY", [F:XCNT]CREDATTIM)
### FECHA DE BAJA
                   REG5 = REG5 + ''
               WHEN DEFAULT
          ENDCASE    

         CONTADOR += 1 
         IF CONTADOR = 4
            Break
	 ENDIF
	Next
	WHILE CONTADOR < 4
          IF CONTADOR = 1: REG3 = REG3 + SPACE$(126): ENDIF
          IF CONTADOR = 2: REG4 = REG4 + SPACE$(126): ENDIF
          IF CONTADOR = 3: REG5 = REG5 + SPACE$(126): ENDIF
          CONTADOR +=1
        WEND
### CADENA CONCESIONARIO

        REG6 = ''
#        WRSEQ SEG$(REG1,1,215)+SEG$(REG2,1,97)+SEG$(REG3,1,126)+SEG$(REG4,1,126)+SEG$(REG5,1,126)+SEG$(REG6,1,128) USING [XTMP]

Return

#############################################################
Subprog RECDESMENU (ZMENU,ZCODIGO,ZIDIOMA,ZTEXTO)
    
 Value Char  ZIDIOMA,ZTEXTO
 VALUE INTEGER ZMENU,ZCODIGO

 LOCAL FILE APLSTD [ZAST]

 READ [ZAST]CLE = ZMENU;ZCODIGO;ZIDIOMA
 IF !FSTAT 
   ZTEXTO = [ZAST]LANMES
 ELSE
   ZTEXTO = ''
 ENDIF
 CLOSE Local File [ZAST]

END


