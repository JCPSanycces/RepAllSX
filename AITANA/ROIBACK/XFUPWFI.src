#<AdxTL>@(#)0.0.0.0 $Revision$ 
##################################################
Subprog XFUPWF
##################################################
Local File AWRKPARH [ZAWH]
Local File XRECWRK [ZRWK]
Local File SINVOICEV [ZSIV]
Local File CONTACT [ZCNT]
Local File FUP  [XFUP] #ORDER BY NUMEDT,ACCNUM,BPAADD
Local File FUP  [XXFUP]
Local File FUP  [XYFUP]
Local File XRECCOM [XXRCO]
Local Char MAIL(250),ICOMER(250)
Local Integer XDIR
Local Char NIVEL_3(1)
Local Char    TBPAR (20)(50), TBVAL (50)(50)
Local Integer NIVEL(2)

NIVEL = 4
Read [F:XXRCO] First
If !fstat
   NIVEL = [F:XXRCO]XLEVFUP
Endif

### ACTUALIZAMOS LA DIRECCION DE ENTREGA DE LA FACTURA EN EL FUP

    For [XFUP] Where [F:XFUP]NUMEDT = [M:FUP]QURNUM & [F:XFUP]BPRFUP = [F:BPA]BPANUM

       For [ZSIV] Where [F:ZSIV]NUM = [F:XFUP]NUM

          Update [XXFUP] Where [XXFUP]NUMEDT = [XFUP]NUMEDT and [XXFUP]ACCNUM = [XFUP]ACCNUM and [XXFUP]DUDLIG = [XFUP]DUDLIG and [XXFUP]NUMCOP = [XFUP]NUMCOP With [XXFUP]BPAADD = [ZSIV]BPAADD

          Break
       Next

    Next

    #>>GAO(28/05/2018): El bucle anterior rellena el campo BPAADD de la FUP tirando de la SIV.
    # En este bucle hago lo mismo para los registros que no se han rellenado el BPAADD porque no existe la SINVOICEV,
    # y lo rellene con el campo BPAPAY de la GACCDUDATE.
    If clalev([F:ZDUD]) = 0 Local File GACCDUDATE [ZDUD] : Endif
    For [XFUP] Where [F:XFUP]NUMEDT = [M:FUP]QURNUM & [F:XFUP]BPRFUP = [F:BPA]BPANUM & [F:XFUP]BPAADD = ''
      For [ZDUD] Where [F:ZDUD]NUM = [F:XFUP]NUM
        Update [XXFUP] Where [XXFUP]NUMEDT = [XFUP]NUMEDT and [XXFUP]ACCNUM = [XFUP]ACCNUM and [XXFUP]DUDLIG = [XFUP]DUDLIG and [XXFUP]NUMCOP = [XFUP]NUMCOP With [XXFUP]BPAADD = [ZDUD]BPAPAY
        Break
      Next
    Next
    #<<GAO(28/05/2018)


    XDIR = 0
    For [F:XFUP]XFUP1(3)  Where [F:XFUP]NUMEDT = [M:FUP]QURNUM & [F:XFUP]BPRFUP = [F:BPA]BPANUM
       ICOMER = ''
       MAIL = ''
       For [ZRWK] Where [F:ZRWK]QURNUM = [F:XFUP]NUMEDT and [F:ZRWK]BPC = [F:XFUP]BPRFUP and[F:ZRWK]BPAADD = [F:XFUP]BPAADD
         MAIL = [F:ZRWK]EMAIL
         Break
       Next
       If MAIL = ''
          Gosub CARGA_MAIL
       Endif

       NIVEL_3 = '0'
       Gosub NIVEL
       If NIVEL_3 = '1'
          ICOMER = ''
          Gosub CARGA_COMERCIAL
        Endif

       If MAIL <> ''
          If ICOMER <> ''
             Update [ZAWH] Where [F:ZAWH]CODE = 'XFUP2' With [F:ZAWH]DESTIN = '"'+MAIL+'"',[F:ZAWH]DESTIN(1) = '"'+ICOMER+'"', [F:ZAWH]TYPDES(1) = 1, [F:ZAWH]ENVOI(1) = 2
          Else
             Update [ZAWH] Where [F:ZAWH]CODE = 'XFUP2' With [F:ZAWH]DESTIN = '"'+MAIL+'"'
          Endif
       Else
          If ICOMER <> ''
             Update [ZAWH] Where [F:ZAWH]CODE = 'XFUP2' With [F:ZAWH]DESTIN(1) = '"'+ICOMER+'"', [F:ZAWH]TYPDES(1) = 1, [F:ZAWH]ENVOI(1) = 2
          Endif
       Endif
#infbox "campa"-[M:FUP]QURNUM-"client"-[F:BPA]BPANUM-"FCY"-[F:XFUP]FCY-"dirent"-[F:XFUP]BPAADD


        TBPAR (1) = "numedt"         : TBVAL (1) = [M:FUP]QURNUM
        TBPAR (2) = "bpc"            : TBVAL (2) = [F:BPA]BPANUM
        TBPAR (3) = "xaadd"          : TBVAL (3) = [F:XFUP]BPAADD
        TBPAR (4) = "fcy"            : TBVAL (4) = [F:XFUP]FCY
        TBPAR (5) = "preview"        : TBVAL (5) = "1"


#                 TBPAR (2) = "nfup"           : TBVAL (2) = "1"
#                 TBPAR (3) = "relbpr"         : TBVAL (3) = "1"
#                 TBPAR (5) = "adrdesgau"      : TBVAL (5) = "DE,GB,US"
#                 TBPAR (6) = "insertcoordexp" : TBVAL (6) = "DE"
#                 TBPAR (7) = "reedit"         : TBVAL (7) = "1"
#                 TBPAR (8) = "fcy"            : TBVAL (8) = [F:XFUP]FCY
#                 TBPAR (9) = "impselections"  : TBVAL (9) = "1"
#                 TBPAR(10) = "preview"        : TBVAL(10) = "2"

         Call ETAT("XFUP2","","",0,"",TBPAR,TBVAL) From AIMP3

         Update [ZAWH] Where [F:ZAWH]CODE = 'XFUP2' With [F:ZAWH]DESTIN = '"noreply@roiback.com"', [F:ZAWH]DESTIN(1)='',[F:ZAWH]TYPDES(1) = 1, [F:ZAWH]ENVOI(1) = 0

    Next

Close File [ZAWH],[ZRWK],[ZSIV],[ZCNT],[XFUP],[XXFUP],[XYFUP],[XXRCO]

End



###################################################################################
$CARGA_MAIL
###################################################################################
Local Char EXISTE(1)
EXISTE = '0'


#   Read [ZSIV]SIV0 = [F:XFUP]NUM
#   if !fstat

      If [F:XFUP]BPAADD <> ''
         EXISTE = '0'
         For [ZCNT] Where [F:ZCNT]BPANUM = [F:BPA]BPANUM  and  [F:ZCNT]BPAADD = [F:XFUP]BPAADD and [F:ZCNT]CNTFNC = 13

          EXISTE = '1'
          MAIL = [F:ZCNT]WEB
          Break
         Next
         If EXISTE = '0'
            For [ZCNT] Where [F:ZCNT]BPANUM = [F:BPA]BPANUM  and  [F:ZCNT]BPAADD = '' and [F:ZCNT]CNTFNC = 13


              EXISTE = '1'
              MAIL = [F:ZCNT]WEB
              Break
            Next
         Endif
         If EXISTE = '0'
            For [ZCNT] Where [F:ZCNT]BPANUM = [F:BPA]BPANUM  and  [F:ZCNT]BPAADD = ' ' and [F:ZCNT]CNTFNC = 13


              EXISTE = '1'
              MAIL = [F:ZCNT]WEB
              Break
            Next
         Endif
       Else
         For [ZCNT] Where [F:ZCNT]BPANUM = [F:BPA]BPANUM  and  [F:ZCNT]BPAADD = '' and [F:ZCNT]CNTFNC = 13

              EXISTE = '1'
              MAIL = [F:ZCNT]WEB
              Break
            Next
            If EXISTE = '0'
            For [ZCNT] Where [F:ZCNT]BPANUM = [F:BPA]BPANUM  and  [F:ZCNT]BPAADD = ' ' and [F:ZCNT]CNTFNC = 13

              EXISTE = '1'
              MAIL = [F:ZCNT]WEB
              Break
            Next
         Endif
       Endif
#   endif
Return


###################################################################################
$CARGA_COMERCIAL
###################################################################################
Local Char EXISTE(1)
EXISTE = '0'


#   Read [ZSIV]SIV0 = [F:XFUP]NUM
#   if !fstat

      If [F:XFUP]BPAADD <> ''
         EXISTE = '0'
         For [ZCNT] Where [F:ZCNT]BPANUM = [F:BPA]BPANUM  and  [F:ZCNT]BPAADD = [F:XFUP]BPAADD and [F:ZCNT]CNTFNC = 14

          EXISTE = '1'
          ICOMER = [F:ZCNT]WEB
          Break
         Next
         If EXISTE = '0'
            For [ZCNT] Where [F:ZCNT]BPANUM = [F:BPA]BPANUM  and  [F:ZCNT]BPAADD = '' and [F:ZCNT]CNTFNC = 14


              EXISTE = '1'
              ICOMER = [F:ZCNT]WEB
              Break
            Next
         Endif
         If EXISTE = '0'
            For [ZCNT] Where [F:ZCNT]BPANUM = [F:BPA]BPANUM  and  [F:ZCNT]BPAADD = ' ' and [F:ZCNT]CNTFNC = 14


              EXISTE = '1'
              ICOMER = [F:ZCNT]WEB
              Break
            Next
         Endif
       Else
         For [ZCNT] Where [F:ZCNT]BPANUM = [F:BPA]BPANUM  and  [F:ZCNT]BPAADD = '' and [F:ZCNT]CNTFNC = 14

              EXISTE = '1'
              ICOMER = [F:ZCNT]WEB
              Break
            Next
            If EXISTE = '0'
            For [ZCNT] Where [F:ZCNT]BPANUM = [F:BPA]BPANUM  and  [F:ZCNT]BPAADD = ' ' and [F:ZCNT]CNTFNC = 14

              EXISTE = '1'
              ICOMER = [F:ZCNT]WEB
              Break
            Next
         Endif
       Endif
#   endif
Return

#####################################################################
$NIVEL

    For [XYFUP] Where [F:XYFUP]NUMEDT = [M:FUP]QURNUM & [F:XYFUP]BPRFUP = [F:BPA]BPANUM and [F:XYFUP]BPAADD = [F:XFUP]BPAADD
      If [XYFUP]LEVFUP = NIVEL
        NIVEL_3 = '1'
        Break
      Endif
    Next

Return

