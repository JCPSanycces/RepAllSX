#<AdxTL>@(#)0.0.0.0 $Revision$
Gosub EXEC
End

$ACTION
  Case ACTION
    When "EXEC"        : Gosub EXEC
  Endcase
Return

$EXEC
Dbgaff
If !clalev([BPD]):Local File BPDLVCUST[BPD]: Endif
If !clalev([BPR]):Local File BPARTNER [BPR]: Endif
If !clalev([ZTEXVEN]): Local File ZTEXTOVENC: Endif
Local Date FECHAINI
Local Date FECHAFIN
Local Char TEXTO(200)(0..)
Local Char SUBJECT(80)
Local Integer Y
Local Char TTO(250): TTO=GZMAILAVI1+";"+GZMAILAVI2+";"+GZMAILAVI3
Filter [ZTEXVEN] Where ACTIVO=2
Read [ZTEXVEN]ZTEX0 First
For X=1 To 3 ##
  #SUBJECT = "Contratos con vencimiento menor a "
  SUBJECT = [F:ZTEXVEN]ASUNTO
  Case X
     When 1: SUBJECT -= "1 mes"
     When 2: SUBJECT -= "2 meses"
     When 3: SUBJECT -= "3 meses"
  Endcase
  FECHAINI = gdat$(day(date$),month(date$)+X-1,year(date$))
  FECHAFIN = gdat$(day(date$)-1,month(date$)+X,year(date$))
  Filter [BPD] Where ZCONRENV<>2 and ZFECHVEN>=FECHAINI and ZFECHVEN<=FECHAFIN
  Raz Y
  TEXTO(0)="Cliente;Razón Social;Hotel;Hotel CRS;Vecimiento"
  #TEXTO(0)+=chr$(10)
  Y=1
  TEXTO(Y)="=======;===================================;===================================;==============================;============="
  For [BPD]BPD0
    Read [BPR]BPR0=[F:BPD]BPCNUM
    Y+=1
    TEXTO(Y)+=[F:BPD]BPCNUM+";"+[F:BPR]BPRNAM+";"+[F:BPD]BPDNAM(0)+";"+[F:BPD]XHTLCRS+";"+format$("D:DD[/]MM[/]YYYY",[F:BPD]ZFECHVEN )
  Next
  If Y>1
    Gosub ENVIO_MAIL
    #Call ZMELADX("avivenc"+num$(X), "clientes@roiback.com", TTO, SUBJECT,TEXTO,"") From XMELADX
  Endif
Next
Filter [BPD]
Return

###################################################################
$ENVIO_MAIL
# Envío por mail
Local Integer TYPMES : TYPMES=1
Local Integer REQREC
Local Integer REQIMP
Local Char    USER(5): USER=GUSER
Local Char    MAIL(60)
Local Char    OBJJOI(5)
Local Char    CLEOBJ(5)
Local Char    CHRONO(5)
Local Integer ERD
Local Char    USR_EMAIL(100)(5): USR_EMAIL(0)=TTO
Local Integer USR_ENVOI(5): USR_ENVOI(0)=2
Local Integer USR_SUIVI(5)
Local Integer USR_NB: USR_NB=1
Local Clbfile TEXCLB(5): #TEXCLB="En el documento adjunto tiene la lista de contratos cercanos a vencer"
TEXCLB=[F:ZTEXVEN]TEXTO
Local Char    TEXOBJ(80)
Local Char    PCEJOI(200)(5)
Local Integer NBJOI
Local Char    TYPJOI(5)
Local Integer CATJOI
Local Char    CONTXT(5)

Openo filpath("BQT","Contratos","csv"),0 Using [MES]
Wrseq TEXTO(0) Using [MES]
Wrseq TEXTO(1) Using [MES]
For Z=2 To Y
Wrseq TEXTO(Z) Using [MES]
Next Z
Openo Using [MES]

PCEJOI(0)=filpath("BQT","Contratos","csv")
NBJOI=1

TEXOBJ=SUBJECT

Call ENVOI_MAIL(TYPMES,REQREC, REQIMP,USER,MAIL,OBJJOI,CLEOBJ,CHRONO,ERD
&                 ,USR_EMAIL,USR_ENVOI,USR_SUIVI,USR_NB,TEXCLB,TEXOBJ
&                 ,PCEJOI,NBJOI,TYPJOI,CATJOI,CONTXT) From AWRKMEL

Return

