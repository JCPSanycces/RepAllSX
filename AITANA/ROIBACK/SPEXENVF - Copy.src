######################################################################################
## Etiqueta añadida por el supervisor (pantalla XENVF) 29/10/2016 14:19:07 (ADMIN)
######################################################################################
Subprog AM_XTODAS(VALEUR)
Variable Integer VALEUR
Local Integer YESNO

If VALEUR = 2
    EXISTE = '0'
    For [F:XTFAC] Where [F:XTFAC]NUM <> 'TODOS'
      EXISTE = '1'
      Break
    Next

    If EXISTE = '1'
      Call OUINON("¿Desea cancelar la selección realizada?",YESNO) From GESECRAN
      If YESNO = 2
       Delete [XTFAC] Where [F:XTFAC]NUM <> 'TODOS'
       [M:XENVF]XTODAS = 1
       Affzo [M:XENVF]XTODAS
       Gosub BUSCART
       Gosub MARCA_YES
      Else
       VALEUR = [M:XENVF]XTODAS
      Endif
    Else
     [M:XENVF]XTODAS = VALEUR
     Affzo [M:XENVF]XTODAS
     Gosub BUSCART
     Gosub MARCA_YES
    Endif
Else
 Delete [XTFAC] Where [F:XTFAC]NUM <> 'TODOS'
 Gosub MARCA_NO
Endif

End


######################################################################################
$BUSCART

Local Integer II, X
Local Char CONDICION(250)(40)




   X = 0

   CONDICION(X) = "SELECT NUM_0,BPR_0,FCY_0,ACCDAT_0,SIVTYP_0,AMTATI_0,CUR_0,STA_0,XENVIADA_0 FROM SINVOICE WHERE "
   X +=1
   CONDICION(X) = " STA_0 = 3 "
   X +=1
   If [M:XENVF]NUM <> ''
      CONDICION(X) = " AND NUM_0 >='" + [M:XENVF]NUM +"'"
   Else
     CONDICION(X) = " AND NUM_0 <> ''"
   Endif

   X +=1
   If [M:XENVF]NUMF <> ''
      CONDICION(X) = " AND NUM_0 <='" + [M:XENVF]NUMF +"'"
   Else
     CONDICION(X) = " AND NUM_0 <> ''"
   Endif

   X +=1
   If [M:XENVF]BPCINV <> ''
      CONDICION(X) = " AND BPR_0 >='" + [M:XENVF]BPCINV +"'"
   Else
     CONDICION(X) = " AND BPR_0 <> ''"
   Endif

   X +=1
   If [M:XENVF]BPCINVF <> ''
      CONDICION(X) = " AND BPR_0 <='" + [M:XENVF]BPCINVF +"'"
   Else
     CONDICION(X) = " AND BPR_0 <> ''"
   Endif

   X +=1
   If [M:XENVF]INVDAT <> [00/00/0000]
      CONDICION(X) = " AND ACCDAT_0 >='" + [M:XENVF]INVDAT +"'"
   Else
     CONDICION(X) = " AND ACCDAT_0 <> 0"
   Endif

   X +=1
   If [M:XENVF]INVDATF <> [00/00/0000]
      CONDICION(X) = " AND ACCDAT_0 <='" + [M:XENVF]INVDATF +"'"
   Else
     CONDICION(X) = " AND ACCDAT_0 <> 0"
   Endif

   X +=1
   If [M:XENVF]SALFCY <> ''
      CONDICION(X) = " AND FCY_0 ='" + [M:XENVF]SALFCY +"'"
   Else
     CONDICION(X) = " AND FCY_0 <> ''"
   Endif

   X +=1
   If [M:XENVF]SIVTYP <> ''
      CONDICION(X) = " AND SIVTYP_0 ='" + [M:XENVF]SIVTYP +"'"
   Else
     CONDICION(X) = " AND SIVTYP_0 <> ''"
   Endif

   X +=1
   CONDICION(X) = " ORDER BY NUM_0"


   REQUEST = CONDICION
#infbox condicion
   II=0
   For (Char NUMFAC(35), Char CLIENT(35), Char PLANTA(15), Date FECHA, Char TIPO(15), Decimal IMPORTE, Char DIVISA(5),
& Integer ESTADO, Integer XENVIADA) From "S" Sql CONDICION As [XXXINV]

      [F:XTFAC]NUM =    [F:XXXINV]NUMFAC
      [F:XTFAC]SALFCY = [F:XXXINV]PLANTA
      [F:XTFAC]BPCINV = [F:XXXINV]CLIENT
      Write [XTFAC]

   Next


Return

####################################################################################
$MARCA_YES
Local Integer X
For X = 0 To 19

   If  [M:XENVF]XNUM(X) <> ''
      [M:XENVF]XSEL(X) = 2
      Affzo [M:XENVF]XSEL(X)
   Endif
Next
Return
####################################################################################
$MARCA_NO
Local Integer X
For X = 0 To 19

   If  [M:XENVF]XNUM(X) <> ''
      [M:XENVF]XSEL(X) = 1
      Affzo [M:XENVF]XSEL(X)
   Endif
Next
Return

###################################################################################
$CARGA_MAIL
###################################################################################

Local Char EXISTE(1)
EXISTE = '0'


   Read [XSIV]SIV0 = FACTURA
   If !fstat


      HOTEL = ''
      For [XBPD] Where [F:XBPD]BPCNUM = [F:XSIV]BPCINV & [F:XBPD]BPAADD = [F:XSIV]BPAADD
         HOTEL = [F:XBPD]XHTLCRS
         Break
      Next


      If [F:XSIV]BPAADD <> ''
         EXISTE = '0'
         For [XCNT] Where [F:XCNT]BPANUM = [F:XSIV]BPCINV and  [F:XCNT]BPAADD = [F:XSIV]BPAADD and [F:XCNT]CNTFNC = 13

          EXISTE = '1'
          MAIL = [F:XCNT]WEB
          Break
         Next
         If EXISTE = '0'
            For [XCNT] Where [F:XCNT]BPANUM = [F:XSIV]BPCINV and  [F:XCNT]BPAADD = '' and [F:XCNT]CNTFNC = 13


              EXISTE = '1'
              MAIL = [F:XCNT]WEB
              Break
            Next
         Endif
         If EXISTE = '0'
            For [XCNT] Where [F:XCNT]BPANUM = [F:XSIV]BPCINV and  [F:XCNT]BPAADD = ' ' and [F:XCNT]CNTFNC = 13


              EXISTE = '1'
              MAIL = [F:XCNT]WEB
              Break
            Next
         Endif
       Else
         For [XCNT] Where [F:XCNT]BPANUM = [F:XSIV]BPCINV and  [F:XCNT]BPAADD = '' and [F:XCNT]CNTFNC = 13

              EXISTE = '1'
              MAIL = [F:XCNT]WEB
              Break
            Next
            If EXISTE = '0'
            For [XCNT] Where [F:XCNT]BPANUM = [F:XSIV]BPCINV and  [F:XCNT]BPAADD = ' ' and [F:XCNT]CNTFNC = 13


              EXISTE = '1'
              MAIL = [F:XCNT]WEB
              Break
            Next
         Endif
       Endif
   Endif
Return
