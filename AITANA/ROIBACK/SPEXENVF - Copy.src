#<AdxTL>@(#)0.0.0.0 $Revision$ 
$ACTION
#Infbox ACTION
Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "AV_CHOIX"      : Gosub AV_CHOIX
  When "OK"            : Gosub OK
  When "FIN"           : Gosub FIN
  When Default
Endcase
Return

$OUVRE


Local File SINVOICE [XSIH] Order By [F:XSIH]NUM
Local File SINVOICE [XXSIH]
Local File XTMPFAC [XTFAC]
Local File SINVOICEV [XSIV]
Local File CONTACT [XCNT]
Local File AWRKPARH [XAWH]
Local File BPDLVCUST [XBPD]

Global Char PAGINAS(35)(100,1)
Global Integer FILA
Global Char ULTIMA_FAC(35),MAIL(250),FACTURA(50),HOTEL(50)

Local Integer T
For T = 0 To 99
 PAGINAS (T,0) = ''
Next
ULTIMA_FAC = ''
FILA = 1
Return

$FIN

 Delete [XTFAC] Where [F:XTFAC]NUM <> 'TODOS'
 Close Local File [XSIH], [XTFAC], [XSIV], [XCNT], [XAWH],[XXSIH],[XBPD]
Return

#################################################################
$AV_CHOIX
#################################################################

Local Char PRIN(1), PASA_FILTRO(1)
PRIN = '0'


If BOUT = 'O'
    Local Integer I


    Delete [XTFAC] Where [F:XTFAC]NUM <> 'TODOS'

    I = 0
    Raz [M:XENVF]
#    FOR [XSIH] WHERE [F:XSIH]STA = 3
#       IF PRIN = '0'
#        PRIN = '1'
#        PAGINAS(FILA,0) = [F:XSIH]NUM
#       ENDIF


#        Effzo [M:XENVF]XNUM(I)
#        EFFZO [m:XENVF]BPR(I)
#        EFFZO [m:XENVF]FCY(I)
#        EFFZO [M:XENVF]XINVDAT(I)
#        EFFZO [M:XENVF]XSIVTIP(I)
#        EFFZO [M:XENVF]AMTATI(I)
#        EFFZO [M:XENVF]CUR(I)
#        EFFZO [M:XENVF]STA(I)
#        EFFZO [M:XENVF]XEMAIL(I)
#        [M:XENVF]XNUM(I) = [F:XSIH]NUM
#        [M:XENVF]BPR(I) = [F:XSIH]BPR
#        [M:XENVF]FCY(i) = [F:XSIH]FCY
#        [M:XENVF]XINVDAT(I) = [F:XSIH]ACCDAT
#        [M:XENVF]XSIVTIP(I) = [F:XSIH]SIVTYP
#        [M:XENVF]AMTATI(I) = [F:XSIH]AMTATI
#        [M:XENVF]CUR(I) = [F:XSIH]CUR
#        [M:XENVF]STA(I)= [F:XSIH]STA


#        MAIL = ''
#        FACTURA = [F:XSIH]NUM
#        Gosub Carga_mail
#        [M:XENVF]XEMAIL(I)= MAIL


#        I +=1
#     IF I = 19
#      ULTIMA_FAC = [F:XSIH]NUM
#      BREAK
#     ENDIF

#    Next
#    [M:XENVF]NBLIG = I
#    Affzo [M:XENVF]
Endif

If BOUT = '>'
    Local Integer I

    I = 0


   If ULTIMA_FAC <> ''
    Effzo [M:XENVF]10

    For [XSIH] Where [XSIH]NUM > ULTIMA_FAC & [F:XSIH]STA = 3

     PASA_FILTRO = '0'
     Gosub FILTRO

     If PASA_FILTRO = '1'
       If PRIN = '0'
        PRIN = '1'
        FILA +=1
        PAGINAS(FILA,0) = [F:XSIH]NUM
       Endif


        Effzo [M:XENVF]XNUM(I)
        Effzo [M:XENVF]BPR(I)
        Effzo [M:XENVF]FCY(I)
        Effzo [M:XENVF]XSEL(I)
        Effzo [M:XENVF]XINVDAT(I)
        Effzo [M:XENVF]XSIVTIP(I)
        Effzo [M:XENVF]AMTATI(I)
        Effzo [M:XENVF]CUR(I)
        Effzo [M:XENVF]STA(I)
        Effzo [M:XENVF]XEMAIL(I)
        Effzo [M:XENVF]XHTLCRS(I)
        Effzo [M:XENVF]XENVIADA(I)

        [M:XENVF]XNUM(I) = [F:XSIH]NUM
        [M:XENVF]BPR(I) = [F:XSIH]BPR
        [M:XENVF]FCY(I) = [F:XSIH]FCY
        [M:XENVF]XINVDAT(I) = [F:XSIH]ACCDAT
        [M:XENVF]XSIVTIP(I) = [F:XSIH]SIVTYP
        [M:XENVF]AMTATI(I) = [F:XSIH]AMTATI
        [M:XENVF]CUR(I) = [F:XSIH]CUR
        [M:XENVF]STA(I)= [F:XSIH]STA

        [M:XENVF]XENVIADA(I) = [F:XSIH]XENVIADA

        MAIL = ''
        HOTEL = ''
        FACTURA = [F:XSIH]NUM
        Gosub CARGA_MAIL
        [M:XENVF]XEMAIL(I)= MAIL
        [M:XENVF]XHTLCRS(I) = HOTEL

        For [XTFAC] Where [F:XTFAC]NUM = [F:XSIH]NUM
          [M:XENVF]XSEL(I) = 2
          Break
        Next

        I +=1
       If I = 19
         ULTIMA_FAC = [F:XSIH]NUM
         Break
       Endif
      Endif
    Next
    If I < 19
      ULTIMA_FAC = ""
    Endif
    [M:XENVF]NBLIG = I
    Affzo [M:XENVF]
  Endif
Endif

If BOUT = '<'
    Local Integer I

    I = 0
  If FILA > 0
    Effzo [M:XENVF]10
    FILA -=1
    For [XSIH] Where [XSIH]NUM >= PAGINAS(FILA,0) & [F:XSIH]STA = 3
     PASA_FILTRO = '0'
     Gosub FILTRO
     If PASA_FILTRO = '1'
        Effzo [M:XENVF]XNUM(I)
        Effzo [M:XENVF]BPR(I)
        Effzo [M:XENVF]FCY(I)
        Effzo [M:XENVF]XSEL(I)
        Effzo [M:XENVF]XINVDAT(I)
        Effzo [M:XENVF]XSIVTIP(I)
        Effzo [M:XENVF]AMTATI(I)
        Effzo [M:XENVF]CUR(I)
        Effzo [M:XENVF]STA(I)
        Effzo [M:XENVF]XEMAIL(I)
        Effzo [M:XENVF]XHTLCRS(I)
        Effzo [M:XENVF]XENVIADA(I)

        [M:XENVF]XNUM(I) = [F:XSIH]NUM
        [M:XENVF]BPR(I) = [F:XSIH]BPR
        [M:XENVF]FCY(I) = [F:XSIH]FCY
        [M:XENVF]XINVDAT(I) = [F:XSIH]ACCDAT
        [M:XENVF]XSIVTIP(I) = [F:XSIH]SIVTYP
        [M:XENVF]AMTATI(I) = [F:XSIH]AMTATI
        [M:XENVF]CUR(I) = [F:XSIH]CUR
        [M:XENVF]STA(I)= [F:XSIH]STA
        [M:XENVF]XENVIADA(I) = [F:XSIH]XENVIADA

        MAIL = ''
        HOTEL = ''
        FACTURA = [F:XSIH]NUM
        Gosub CARGA_MAIL
        [M:XENVF]XEMAIL(I)= MAIL
        [M:XENVF]XHTLCRS(I) = HOTEL

        For [XTFAC] Where [F:XTFAC]NUM = [F:XSIH]NUM
          [M:XENVF]XSEL(I) = 2
          Break
        Next

         I +=1
         If I = 19
            ULTIMA_FAC = [F:XSIH]NUM
            Break
         Endif
      Endif
    Next
    [M:XENVF]NBLIG = I
    Affzo [M:XENVF]
  Endif
Endif
Return

######################################################################################
$FILTRO
######################################################################################
   PASA_FILTRO = '1'
   If [M:XENVF]NUM <> '' & [M:XENVF]NUM > [F:XSIH]NUM
      PASA_FILTRO = '0'

   Endif
   If [M:XENVF]NUMF <> '' & [M:XENVF]NUMF < [F:XSIH]NUM
      PASA_FILTRO = '0'

   Endif
   If [M:XENVF]BPCINV <> '' & [M:XENVF]BPCINV > [F:XSIH]BPR
      PASA_FILTRO = '0'

   Endif
   If [M:XENVF]BPCINVF <> '' & [M:XENVF]BPCINVF < [F:XSIH]BPR
      PASA_FILTRO = '0'

   Endif
   If [M:XENVF]INVDAT <> [00/00/0000] & [M:XENVF]INVDAT > [F:XSIH]ACCDAT
      PASA_FILTRO = '0'

   Endif
   If [M:XENVF]INVDATF <> [00/00/0000] & [M:XENVF]INVDATF < [F:XSIH]ACCDAT
      PASA_FILTRO = '0'

   Endif
   If [M:XENVF]SALFCY <> '' & [M:XENVF]SALFCY <> [F:XSIH]FCY
      PASA_FILTRO = '0'

   Endif
   If [M:XENVF]SIVTYP <> '' & [M:XENVF]SIVTYP <> [F:XSIH]SIVTYP
      PASA_FILTRO = '0'

   Endif
   If [F:XSIH]STA <> 3
      PASA_FILTRO = '0'

   Endif

Return
######################################################################################
$OK
######################################################################################

#Send GSERMES with
#& "_TO="+chr$(1)+"emilio.mayoral@trece.biz",
#& "_CC="+chr$(1)+"emiliohtc@gmail.com",
#& "_SUJET="+chr$(1)+"Asunto",
#& "_NOTE="+chr$(1)+"note",
#& "_CONTXT="+chr$(1)+"GESBPC"

Local Char    TBPAR (20)(50), TBVAL (50)(50)
Local Char EXISTE(1), EMAIL(250)
Local Char MAIL(30)
If !clalev([F:BPA])   : Local File BPADDRESS[BPA]    : Endif
If !clalev([F:CNT])   : Local File CONTACT  [CNT]    : Endif
If !clalev([F:BPD])   : Local File BPDLVCUST[BPD]    : Endif
If !clalev([F:SIH1])  : Local File SINVOICE[SIH1]    : Endif

For [XTFAC]
   EXISTE = '0'
   EMAIL = ''

   Read [XSIV]SIV0 = [F:XTFAC]NUM
   If !fstat

      If [F:XSIV]BPAADD <> ''
         EXISTE = '0'
         For [XCNT] Where [F:XCNT]BPANUM = [F:XSIV]BPCINV and  [F:XCNT]BPAADD = [F:XSIV]BPAADD and [F:XCNT]CNTFNC = 13

          EXISTE = '1'
          EMAIL = [F:XCNT]WEB
          Break
         Next
         If EXISTE = '0'
            For [XCNT] Where [F:XCNT]BPANUM = [F:XSIV]BPCINV and  [F:XCNT]BPAADD = '' and [F:XCNT]CNTFNC = 13


              EXISTE = '1'
              EMAIL = [F:XCNT]WEB
              Break
            Next
         Endif
         If EXISTE = '0'
            For [XCNT] Where [F:XCNT]BPANUM = [F:XSIV]BPCINV and  [F:XCNT]BPAADD = ' ' and [F:XCNT]CNTFNC = 13


              EXISTE = '1'
              EMAIL = [F:XCNT]WEB
              Break
            Next
         Endif
       Else
         For [XCNT] Where [F:XCNT]BPANUM = [F:XSIV]BPCINV and  [F:XCNT]BPAADD = '' and [F:XCNT]CNTFNC = 13

              EXISTE = '1'
              EMAIL = [F:XCNT]WEB
              Break
            Next
            If EXISTE = '0'
            For [XCNT] Where [F:XCNT]BPANUM = [F:XSIV]BPCINV and  [F:XCNT]BPAADD = ' ' and [F:XCNT]CNTFNC = 13


              EXISTE = '1'
              EMAIL = [F:XCNT]WEB
              Break
            Next
         Endif
       Endif
   Endif


#   If EMAIL <> ''
#
#      UPDATE [XAWH] WHERE [F:XAWH]CODE = 'APRINT2' WITH [F:XAWH]DESTIN = '"'+VIREBLC(email,1)+'"'
#
#
#      if !fstat
#                 TBPAR (1) = "facturedeb" : TBVAL (1) = [F:XTFAC]NUM
#                 TBPAR (2) = "facturefin" : TBVAL (2) = [F:XTFAC]NUM
#                 TBPAR (3) = "sitedeb" : TBVAL (3) = [F:XTFAC]SALFCY
#                 TBPAR (4) = "sitefin" : TBVAL (4) = [F:XTFAC]SALFCY
#                 TBPAR (5) = "clientdeb" : TBVAL (5) = [F:XTFAC]BPCINV
#                 TBPAR (6) = "clientdeb" : TBVAL (6) = [F:XTFAC]BPCINV
#READ [XXSIH]SIH0 = [F:XTFAC]NUM
#if [XXSIH]STARPT = 1
#                 TBPAR (7) = "codimp" : TBVAL (7) = ' '
#
#else
#                 TBPAR (7) = "codimp" : TBVAL (7) = '2'
#
#ENDIF
#if [XXSIH]XENVIADA <> 2
#             Call ETAT("XSBONFACPMAIL","","",0,"",TBPAR,TBVAL) From AIMP3
#             update [XXSIH] WHERE [F:XXSIH]NUM = [F:XTFAC]NUM WITH [F:XXSIH]XENVIADA = 2
#         else
#          if [M:XENVF]XTODAS <> 2
#               Call ETAT("XSBONFACPMAIL","","",0,"",TBPAR,TBVAL) From AIMP3
#          endif
#Endif
#      endif
#EMAIL = 'asotelo@quonext.com'

  If EMAIL <> ''
      Update [XAWH] Where [F:XAWH]CODE = 'APRINT2' With [F:XAWH]DESTIN = '"'+vireblc(EMAIL,1)+'"'
      If !fstat
      #MRR 28/09/2018 - si está marcado en cliente entrega el check "envio informe" se envía el excel, sino no
        Global Char FFIC(50)(1..5)

        Filter [F:XSIV] Where NUM = [F:XTFAC]NUM
          Filter [F:BPD] Where BPCNUM = [F:XSIV]BPCINV and BPAADD = [F:XSIV]BPAADD
            Read [F:BPD] First
            If !fstat Then
              Filter [F:CNT] Where BPANUM = [F:BPD]BPCNUM
              Read [F:CNT] First
              If !fstat Then
                #MAIL = [F:CNT]WEB
              Endif
              If [F:BPD]XENVIO = 2 Then
                Gosub PDF_FACTURAS
                Gosub EXCEL_LOCALIZADORES
              Else
                Gosub PDF_FACTURAS
              Endif
            Endif
      #MRR 28/09/2018 - si está marcado en cliente entrega el check "envio informe" se envía el excel, sino no
      Endif
      Update [XAWH] Where [F:XAWH]CODE = 'APRINT2' With [F:XAWH]DESTIN = '"noreply@roiback.com"'

Local Char TT(250)(1..50)
TT(1) = 'Estimado Colaborador / Dear client,:'
TT(3) = 'Adjuntamos factura Nº ' + [F:XTFAC]NUM +' según contrato vigente.'
TT(5) = 'Reciba un cordial saludo. /'
TT(7) = 'Please find attached Roiback’s invoice with number ' + [F:XTFAC]NUM + ',as per the conditions of our contract.'
TT(9) = 'We remain at your disposal for any questions. Kind regards,'
TT(11) = 'Roiback.'

#EMAIL = 'abel_9007@hotmail.com'
#Call ZMELADX(filpath("tmp","prueba",""),"clientes@roiback.com","mromero@quonext.com","ENVÍO DE FACTURA / SEND INVOICE ROIBACK",TT,FFIC) From XMELADX
Call ZMELADX(filpath("tmp","prueba",""),"clientes@roiback.com",EMAIL,"ENVÍO DE FACTURA / SEND INVOICE ROIBACK",TT,FFIC) From XMELADX
Filter [XSIV]

   Endif

Update [SIH1] Where [F:SIH1]NUM = [F:XTFAC]NUM With [F:SIH1]XENVIADA = 2

Next


Return


######################################################################################
## Etiqueta añadida por el supervisor (pantalla XENVF) 25/10/2016 11:35:43 (ADMIN)
######################################################################################
Subprog AM_XSEL(VALEUR)
Variable Integer VALEUR

   If VALEUR = 1 Then
      Delete [XTFAC] Where [F:XTFAC]NUM = [M:XENVF]XNUM(nolign-1) & [F:XTFAC]BPCINV = [M:XENVF]BPR(nolign-1)
   Else
      [F:XTFAC]NUM = [M:XENVF]XNUM(nolign-1)
      [F:XTFAC]SALFCY = [M:XENVF]FCY(nolign-1)
      [F:XTFAC]BPCINV = [M:XENVF]BPR(nolign-1)
      Write [XTFAC]
   Endif
End


######################################################################################


######################################################################################
## Etiqueta añadida por el supervisor (pantalla XENVF) 25/10/2016 12:27:30 (ADMIN)
######################################################################################
Subprog AM_NUM(VALEUR)
Variable Char    VALEUR()

Local Integer YESNO
Local Char EXISTE(1)
#LOCAL CHAR FACTURA(60)

    #FACTURA = VALEUR
    EXISTE = '0'
    For [F:XTFAC] Where [F:XTFAC]NUM <> 'TODOS'
      EXISTE = '1'
      Break
    Next

    If EXISTE = '1'
      Call OUINON("¿Desea cancelar la selección realizada?",YESNO) From GESECRAN
      If YESNO = 2
       Delete [XTFAC] Where [F:XTFAC]NUM <> 'TODOS'
       [M:XENVF]NUM = VALEUR
       Affzo [M:XENVF]NUM
       [M:XENVF]XTODAS = 1
       Affzo [M:XENVF]XTODAS
       Gosub BUSCAR
      Else
       VALEUR = [M:XENVF]NUM

      Endif
    Else
       [M:XENVF]NUM = VALEUR
       Affzo [M:XENVF]NUM
       Gosub BUSCAR
    Endif
End



######################################################################################
$BUSCAR
Local Integer II, X
Local Char CONDICION(250)(40)
           For X = 0 To 39
             CONDICION(X)=""
             PAGINAS(X,0)=""
           Next X
           FILA = 0

   Effzo [M:XENVF]10
   #[M:XENVF]NUM = FACTURA
   #AFFZO [M:XENVF]NUM

   X = 0

   CONDICION(X) = "SELECT NUM_0,BPR_0,FCY_0,ACCDAT_0,SIVTYP_0,AMTATI_0,CUR_0,STA_0,XENVIADA_0 FROM SINVOICE WHERE "
   X +=1
   CONDICION(X) = " STA_0 = 3 "
   X +=1
   If [M:XENVF]NUM <> ''
      CONDICION(X) = " AND NUM_0 >='" + [M:XENVF]NUM +"'"
   Else
     CONDICION(X) = " AND NUM_0 <> ''"
   Endif

   X +=1
   If [M:XENVF]NUMF <> ''
      CONDICION(X) = " AND NUM_0 <='" + [M:XENVF]NUMF +"'"
   Else
     CONDICION(X) = " AND NUM_0 <> ''"
   Endif

   X +=1
   If [M:XENVF]BPCINV <> ''
      CONDICION(X) = " AND BPR_0 >='" + [M:XENVF]BPCINV +"'"
   Else
     CONDICION(X) = " AND BPR_0 <> ''"
   Endif

   X +=1
   If [M:XENVF]BPCINVF <> ''
      CONDICION(X) = " AND BPR_0 <='" + [M:XENVF]BPCINVF +"'"
   Else
     CONDICION(X) = " AND BPR_0 <> ''"
   Endif

   X +=1
   If [M:XENVF]INVDAT <> [00/00/0000]
      CONDICION(X) = " AND ACCDAT_0 >='" + [M:XENVF]INVDAT +"'"
   Else
     CONDICION(X) = " AND ACCDAT_0 <> 0"
   Endif

   X +=1
   If [M:XENVF]INVDATF <> [00/00/0000]
      CONDICION(X) = " AND ACCDAT_0 <='" + [M:XENVF]INVDATF +"'"
   Else
     CONDICION(X) = " AND ACCDAT_0 <> 0"
   Endif

   X +=1
   If [M:XENVF]SALFCY <> ''
      CONDICION(X) = " AND FCY_0 ='" + [M:XENVF]SALFCY +"'"
   Else
     CONDICION(X) = " AND FCY_0 <> ''"
   Endif

   X +=1
   If [M:XENVF]SIVTYP <> ''
      CONDICION(X) = " AND SIVTYP_0 ='" + [M:XENVF]SIVTYP +"'"
   Else
     CONDICION(X) = " AND SIVTYP_0 <> ''"
   Endif

   X +=1
   CONDICION(X) = " ORDER BY NUM_0"


   REQUEST = CONDICION
#infbox condicion
   II=0
   For (Char NUMFAC(35), Char CLIENT(35), Char PLANTA(15), Date FECHA, Char TIPO(15), Decimal IMPORTE, Char DIVISA(5), Integer ESTADO, Integer XENVIADA ) From "S" Sql CONDICION As [XXINV]


        Effzo [M:XENVF]XNUM(II)
        Effzo [M:XENVF]BPR(II)
        Effzo [M:XENVF]FCY(II)
        Effzo [M:XENVF]XINVDAT(II)
        Effzo [M:XENVF]XSIVTIP(II)
        Effzo [M:XENVF]XEMAIL(II)
        Effzo [M:XENVF]XHTLCRS(II)
        Effzo [M:XENVF]XENVIADA(II)

        [M:XENVF]XNUM(II) = [F:XXINV]NUMFAC
        [M:XENVF]BPR(II) = [F:XXINV]CLIENT
        [M:XENVF]FCY(II) = [F:XXINV]PLANTA
        [M:XENVF]XINVDAT(II) = [F:XXINV]FECHA
        [M:XENVF]XSIVTIP(II) = [F:XXINV]TIPO
        [M:XENVF]AMTATI(II) = [F:XXINV]IMPORTE
        [M:XENVF]CUR(II) = [F:XXINV]DIVISA
        [M:XENVF]STA(II)= [F:XXINV]ESTADO
        [M:XENVF]XENVIADA(II) = [F:XXINV]XENVIADA

        MAIL = ''
        HOTEL = ''
        FACTURA = [F:XXINV]NUMFAC
        Gosub CARGA_MAIL
        [M:XENVF]XEMAIL(II)= MAIL
        [M:XENVF]XHTLCRS(II) = HOTEL


        II +=1
        If II = 19
          ULTIMA_FAC = [F:XXINV]NUMFAC
          Break
        Endif
    Next

    [M:XENVF]NBLIG = II
    Affzo [M:XENVF]


Return


######################################################################################
## Etiqueta añadida por el supervisor (pantalla XENVF) 26/10/2016 12:04:03 (ADMIN)
######################################################################################
Subprog AM_NUMF(VALEUR)
Variable Char    VALEUR()
Local Integer YESNO
Local Char EXISTE(1)

    EXISTE = '0'
    For [F:XTFAC] Where [F:XTFAC]NUM <> 'TODOS'
      EXISTE = '1'
      Break
    Next

    If EXISTE = '1'
      Call OUINON("¿Desea cancelar la selección realizada?",YESNO) From GESECRAN
      If YESNO = 2
       Delete [XTFAC] Where [F:XTFAC]NUM <> 'TODOS'
       [M:XENVF]NUMF = VALEUR
       Affzo [M:XENVF]NUMF
       [M:XENVF]XTODAS = 1
       Affzo [M:XENVF]XTODAS
       Gosub BUSCAR
      Else
       VALEUR = [M:XENVF]NUMF
      Endif
    Else
     [M:XENVF]NUMF = VALEUR
     Affzo [M:XENVF]NUMF
     Gosub BUSCAR
    Endif

End

Subprog AM_BPCINV(VALEUR)
Variable Char    VALEUR()
Local Integer YESNO
Local Char EXISTE(1)

    EXISTE = '0'
    For [F:XTFAC] Where [F:XTFAC]NUM <> 'TODOS'
      EXISTE = '1'
      Break
    Next

    If EXISTE = '1'
      Call OUINON("¿Desea cancelar la selección realizada?",YESNO) From GESECRAN
      If YESNO = 2
       Delete [XTFAC] Where [F:XTFAC]NUM <> 'TODOS'
       [M:XENVF]BPCINV = VALEUR
       Affzo [M:XENVF]BPCINV
       [M:XENVF]XTODAS = 1
       Affzo [M:XENVF]XTODAS
       Gosub BUSCAR
      Else
       VALEUR = [M:XENVF]BPCINV
      Endif
    Else
     [M:XENVF]BPCINV = VALEUR
     Affzo [M:XENVF]BPCINV
     Gosub BUSCAR
    Endif
End

