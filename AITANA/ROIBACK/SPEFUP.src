#<AdxTL>@(#)0.0.0.0 $Revision$ Reclamaciones
$ACTION
Case ACTION
  When "BB1_NBLIG" Gosub BB1_NBLIG
  When Default
Endcase
Return


$BB1_NBLIG
Local char filtro(250)
Local integer correos

if [M:FUP]QURNUM <> ''
#      Filtro = "select count(*) from TMPFUP2 where NUMREQ_0 = '"+[M:FUP]QURNUM+"'"
       Filtro = "select count(distinct (c.BPCINV_0+c.BPAADD_0)) from x3v9.PROD.TMPFUP2 a join x3v9.PROD.GACCDUDATE b on a.NUMDUD_0 = b.NUMDUD_0 join x3v9.PROD.SINVOICEV c on b.NUM_0 = c.NUM_0 where NUMREQ_0 ='"+[M:FUP]QURNUM+"' and a.SEL_0 = '2'"

      For (integer correos) From "S" Sql Filtro AS [XXX]
        [M:FUP]NBM =[F:XXX]correos
        Affzo [M:FUP]NBM
      next

Endif
Return


