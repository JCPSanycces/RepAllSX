#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara XENVFEE (Especifico)
######################################################################################
$ACTION
######################################################################################
#Infbox ACTION
Case ACTION
  When "OUVRE"         : Gosub OUVRE
  When "DEBUT"         : Gosub DEBUT
  When "BOUTON"        : Gosub BOUTON
  When "OK"            : Gosub OK
  When "FIN"           : Gosub FIN
  When Default
Endcase

Return

######################################################################################
$OUVRE
######################################################################################
#Infbox ('OUVRE')
Local File SINVOICE [XSIH1] Order By [F:XSIH1]NUM
Local File SINVOICE [XXSIH]
Local File XTMPFAC [XTFAC]
Local File SINVOICEV [XSIV]
Local File CONTACT [XCNT]
Local File AWRKPARH [XAWH]
Local File BPDLVCUST [XBPD]

Global Char PAGINAS(35)(100,1)
Global Integer FILA
Global Char ULTIMA_FAC(35),MAIL(250),FACTURA(50),HOTEL(50)

Local Integer T
For T = 0 To 99
 PAGINAS (T,0) = ''
Next
ULTIMA_FAC = ''
FILA = 1

Return

######################################################################################
$DEBUT
######################################################################################
Raz [M:XENVFE]

Return

######################################################################################
$FIN
######################################################################################
 Delete [XTFAC] Where [F:XTFAC]NUM <> 'TODOS'
 Close Local File [XSIH1], [XTFAC], [XSIV], [XCNT], [XAWH],[XXSIH],[XBPD]
Return

######################################################################################
$BOUTON
######################################################################################
Local Integer I

If BOUT = 'S' Then
  For I = 0 To NBLIG-1
    [M:XENVFE]XSEL(I) = 2
    Affzo [M:XENVFE]XSEL
  Next
Endif

If BOUT = 'D' Then
  For I = 0 To NBLIG-1
    [M:XENVFE]XSEL(I) = 1
    Affzo [M:XENVFE]XSEL
  Next
Endif
Return

######################################################################################
$FILTRO
######################################################################################
#Infbox ('FILTRO')
   PASA_FILTRO = '1'

   If [M:XENVFE]CPY <> '' & [M:XENVFE]CPY > [F:XSIH1]CPY
      PASA_FILTRO = '0'
   Endif

   If [M:XENVFE]NUM <> '' & [M:XENVFE]NUM > [F:XSIH1]NUM
      PASA_FILTRO = '0'
   Endif

   If [M:XENVFE]NUMF <> '' & [M:XENVFE]NUMF < [F:XSIH1]NUM
      PASA_FILTRO = '0'
   Endif

   If [M:XENVFE]BPCINV <> '' & [M:XENVFE]BPCINV > [F:XSIH1]BPR
      PASA_FILTRO = '0'

   Endif
   If [M:XENVFE]BPCINVF <> '' & [M:XENVFE]BPCINVF < [F:XSIH1]BPR
      PASA_FILTRO = '0'
   Endif

   If [M:XENVFE]INVDAT <> [00/00/0000] & [M:XENVFE]INVDAT > [F:XSIH1]ACCDAT
      PASA_FILTRO = '0'
   Endif

   If [M:XENVFE]INVDATF <> [00/00/0000] & [M:XENVFE]INVDATF < [F:XSIH1]ACCDAT
      PASA_FILTRO = '0'
   Endif

   If [M:XENVFE]SALFCY <> '' & [M:XENVFE]SALFCY <> [F:XSIH1]FCY
      PASA_FILTRO = '0'
   Endif

#   If [M:XENVFE]SIVTYP <> '' & [M:XENVFE]SIVTYP <> [F:XSIH1]SIVTYP
#      PASA_FILTRO = '0'
#   Endif

   If [F:XSIH1]STA <> 3
      PASA_FILTRO = '0'
   Endif

Return

######################################################################################
$OK
######################################################################################
#Infbox ('OK')
Local Integer I
Local Integer ESTADO

If !clalev([F:CPY2])   : Local File COMPANY   [CPY2]    : Endif
If !clalev([F:SIH3])   : Local File SINVOICE  [SIH3]    : Endif

If BOUT = 'O' # boton OK de la ventana
  Filter [F:CPY2] Where CPY = [M:XENVFE]CPY
  Read [F:CPY2] First
  If !fstat Then
    If [F:CPY2]ZFACTELEC = 2 Then   #Caso “Factura electrónica de Colombia”
      For I=0 To [M:XENVFE]NBLIG-1
        If [M:XENVFE]XSEL(I) = 2
#          Infbox 'Factura electrónica de Colombia'
          Call FACT_ELECT([M:XENVFE]XNUM(I)) From ZFACTELECT   #ZFACTELECT PROCESO YA EXISTENTE QUE ENVÍA VÍA WEBSERVICE LA FACTURA EN XML
        Endif
      Next
    Endif

    If [F:CPY2]ZFACELEBAV = 2 Then  #Caso “Factura electrónica Bavel”
      For I=0 To [M:XENVFE]NBLIG-1
        If [M:XENVFE]XSEL(I) = 2
#          Infbox 'Factura electrónica Bavel'
          Call XMLFACT([M:XENVFE]XNUM(I), ESTADO) From ZFACTBAVEL #ZFACTBAVEL PROCESO YA EXISTENTE EN PROTO QUE GENERA XML CON FORMATO SOLICITADO POR BAVEL
            If ESTADO = 0
              Read [F:SIH3]SIH0=[M:XENVFE]XNUM(I)
              [F:SIH3]ZEMIBAVEL = 2
              Rewrite [F:SIH3]
            Endif
        Endif
      Next
    Endif
  Endif
Endif

Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla XENVFEE) 25/10/2016 11:35:43 (ADMIN)
######################################################################################
Subprog AM_XSEL(VALEUR)
Variable Integer VALEUR

   If VALEUR = 1 Then
      Delete [XTFAC] Where [F:XTFAC]NUM = [M:XENVFE]XNUM(nolign-1) & [F:XTFAC]BPCINV = [M:XENVFE]BPR(nolign-1)
   Else
      [F:XTFAC]NUM = [M:XENVFE]XNUM(nolign-1)
      [F:XTFAC]SALFCY = [M:XENVFE]FCY(nolign-1)
      [F:XTFAC]BPCINV = [M:XENVFE]BPR(nolign-1)
      Write [XTFAC]
   Endif
End

######################################################################################
## Etiqueta añadida por el supervisor (pantalla XENVFEE) 25/10/2016 12:27:30 (ADMIN)
######################################################################################
Subprog AM_NUM(VALEUR)
Variable Char    VALEUR()

Local Integer YESNO
Local Char EXISTE(1)
#Local Char FACTURA(60)

    #FACTURA = VALEUR
    EXISTE = '0'
    For [F:XTFAC] Where [F:XTFAC]NUM <> 'TODOS'
      EXISTE = '1'
      Break
    Next

    If EXISTE = '1'
      Call OUINON("¿Desea cancelar la selección realizada?",YESNO) From GESECRAN
      If YESNO = 2
       Delete [XTFAC] Where [F:XTFAC]NUM <> 'TODOS'
       [M:XENVFE]NUM = VALEUR
       Affzo [M:XENVFE]NUM
#       [M:XENVFE]XTODAS = 1
#       Affzo [M:XENVFE]XTODAS
       Gosub BUSCAR
      Else
       VALEUR = [M:XENVFE]NUM

      Endif
    Else
       [M:XENVFE]NUM = VALEUR
       Affzo [M:XENVFE]NUM
       Gosub BUSCAR
    Endif
End

######################################################################################
$BUSCAR
######################################################################################
Local Integer II, X
Local Char CONDICION(250)(40)
Local Integer EMITIDA
Raz EMITIDA

If !clalev([F:CPY1])   : Local File COMPANY   [CPY1]    : Endif
If !clalev([F:BPC1])   : Local File BPCUSTOMER[BPC1]    : Endif
If !clalev([F:SIH1])   : Local File SINVOICE  [SIH1]    : Endif
If !clalev([F:SIH2])   : Local File SINVOICE  [SIH2]    : Endif
If !clalev([F:SIH3])   : Local File SINVOICE  [SIH3]    : Endif
If !clalev([F:SIH4])   : Local File SINVOICE  [SIH4]    : Endif

           For X = 0 To 39
             CONDICION(X)=""
             PAGINAS(X,0)=""
           Next X
           FILA = 0

   Effzo [M:XENVFE]10

   X = 0

   CONDICION(X) = "SELECT CPY_0,NUM_0,BPR_0,FCY_0,ACCDAT_0,SIVTYP_0,AMTATI_0,CUR_0,STA_0,ZEMIBAVEL_0,ZTRANS_0 FROM SINVOICE WHERE "
   X +=1
   CONDICION(X) = " STA_0 = 3 "

   X +=1
   If [M:XENVFE]CPY <> ''
      CONDICION(X) = " AND CPY_0 ='" + [M:XENVFE]CPY +"'"
   Else
     CONDICION(X) = " AND CPY_0 <> ''"
   Endif

   X +=1
   If [M:XENVFE]NUM <> ''
      CONDICION(X) = " AND NUM_0 >='" + [M:XENVFE]NUM +"'"
   Else
     CONDICION(X) = " AND NUM_0 <> ''"
   Endif

   X +=1
   If [M:XENVFE]NUMF <> ''
      CONDICION(X) = " AND NUM_0 <='" + [M:XENVFE]NUMF +"'"
   Else
     CONDICION(X) = " AND NUM_0 <> ''"
   Endif

   X +=1
   If [M:XENVFE]BPCINV <> ''
      CONDICION(X) = " AND BPR_0 >='" + [M:XENVFE]BPCINV +"'"
   Else
     CONDICION(X) = " AND BPR_0 <> ''"
   Endif

   X +=1
   If [M:XENVFE]BPCINVF <> ''
      CONDICION(X) = " AND BPR_0 <='" + [M:XENVFE]BPCINVF +"'"
   Else
     CONDICION(X) = " AND BPR_0 <> ''"
   Endif

   X +=1
   If [M:XENVFE]INVDAT <> [00/00/0000]
      CONDICION(X) = " AND ACCDAT_0 >='" + [M:XENVFE]INVDAT +"'"
   Else
     CONDICION(X) = " AND ACCDAT_0 <> 0"
   Endif

   X +=1
   If [M:XENVFE]INVDATF <> [00/00/0000]
      CONDICION(X) = " AND ACCDAT_0 <='" + [M:XENVFE]INVDATF +"'"
   Else
     CONDICION(X) = " AND ACCDAT_0 <> 0"
   Endif

   X +=1
   If [M:XENVFE]SALFCY <> ''
      CONDICION(X) = " AND FCY_0 ='" + [M:XENVFE]SALFCY +"'"
   Else
     CONDICION(X) = " AND FCY_0 <> ''"
   Endif

   X +=1
   If [M:XENVFE]SIVTYP <> ''
      CONDICION(X) = " AND SIVTYP_0 ='" + [M:XENVFE]SIVTYP +"'"
   Else
     CONDICION(X) = " AND SIVTYP_0 <> ''"
   Endif

   X +=1
   CONDICION(X) = " ORDER BY NUM_0"


   REQUEST = CONDICION
#Infbox CONDICION
   II=0

   For (Char SOCIEDAD(5),Char NUMFAC(35), Char CLIENT(35), Char PLANTA(15), Date FECHA, Char TIPO(15), Decimal IMPORTE, Char DIVISA(5), Integer ESTADO, Integer ZEMIBAVEL, Char ZTRANS(50) ) From "S"
& Sql CONDICION As [XXINV]

        Effzo [M:XENVFE]XNUM(II)
        Effzo [M:XENVFE]BPR(II)
        Effzo [M:XENVFE]FCY(II)
        Effzo [M:XENVFE]XINVDAT(II)
        Effzo [M:XENVFE]XSIVTIP(II)

        Filter [F:CPY1] Where CPY = [M:XENVFE]CPY
        Read [F:CPY1] First
        If !fstat Then
          If [F:CPY1]CRY = 'CO' or [F:CPY1]ZFACTELEC = 2 Then
            Filter [F:BPC1] Where BPCNUM = [F:XXINV]CLIENT
            Read [F:BPC1] First
            If !fstat Then
              If [F:BPC1]ZFACTELEC = 2 Then
                If [M:XENVFE]XFACTEMI <> 2 Then
                  Filter [F:SIH3] Where NUM = [F:XXINV]NUMFAC
                  Read [F:SIH3] First
                  If !fstat Then
                    If [F:SIH3]ZTRANS = ''
                      EMITIDA = 0
                      Gosub ESCRIBE_LINEAS_BUSQUEDA
                      II +=1
                      If II = 19
                        ULTIMA_FAC = [F:XXINV]NUMFAC
                        Break
                      Endif
                    Endif
                  Endif
                Else
                  Filter [F:SIH4] Where NUM = [F:XXINV]NUMFAC
                  Read [F:SIH4] First
                  If !fstat Then
                    If [F:SIH4]ZTRANS <> ''
                      EMITIDA = 2
                      Gosub ESCRIBE_LINEAS_BUSQUEDA
                      II +=1
                      If II = 19
                        ULTIMA_FAC = [F:XXINV]NUMFAC
                        Break
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Else
            If [F:CPY1]CRY = 'ES' or [F:CPY1]ZFACELEBAV = 2 Then
              If [M:XENVFE]XFACTEMI <> 2 Then
                Filter [F:SIH1] Where NUM = [F:XXINV]NUMFAC
                Read [F:SIH1] First
                If !fstat Then
                  If [F:SIH1]ZEMIBAVEL <> 2
                    Gosub ESCRIBE_LINEAS_BUSQUEDA2
                    II +=1
                    If II = 19
                      ULTIMA_FAC = [F:XXINV]NUMFAC
                      Break
                    Endif
                  Endif
                Endif
              Else
                Filter [F:SIH2] Where NUM = [F:XXINV]NUMFAC
                Read [F:SIH2] First
                If !fstat Then
                  If [F:SIH2]ZEMIBAVEL = 2
                    Gosub ESCRIBE_LINEAS_BUSQUEDA2
                    II +=1
                    If II = 19
                      ULTIMA_FAC = [F:XXINV]NUMFAC
                      Break
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif

        MAIL = ''
        HOTEL = ''
        FACTURA = [F:XXINV]NUMFAC
        Gosub CARGA_MAIL

    Next

    [M:XENVFE]NBLIG = II
    Affzo [M:XENVFE]


Return

######################################################################################
$ESCRIBE_LINEAS_BUSQUEDA
#######################################################################################
    If [M:XENVFE]XFACTEMI <> 2 Then
      [M:XENVFE]XSEL(II)  = 2
    Else
      [M:XENVFE]XSEL(II)  = 1
    Endif
    [M:XENVFE]XNUM(II)    = [F:XXINV]NUMFAC
    [M:XENVFE]BPR(II)     = [F:XXINV]CLIENT
    [M:XENVFE]FCY(II)     = [F:XXINV]PLANTA
    [M:XENVFE]XINVDAT(II) = [F:XXINV]FECHA
    [M:XENVFE]XSIVTIP(II) = [F:XXINV]TIPO
    [M:XENVFE]AMTATI(II)  = [F:XXINV]IMPORTE
    [M:XENVFE]CUR(II)     = [F:XXINV]DIVISA
    [M:XENVFE]XENVIADA(II)= EMITIDA

    Gosub CARGA_MAIL
    [M:XENVFE]XEMAIL(II)  = MAIL

Return


######################################################################################
$ESCRIBE_LINEAS_BUSQUEDA2
#######################################################################################
    If [M:XENVFE]XFACTEMI <> 2 Then
      [M:XENVFE]XSEL(II)  = 2
    Else
      [M:XENVFE]XSEL(II)  = 1
    Endif
    [M:XENVFE]XNUM(II)    = [F:XXINV]NUMFAC
    [M:XENVFE]BPR(II)     = [F:XXINV]CLIENT
    [M:XENVFE]FCY(II)     = [F:XXINV]PLANTA
    [M:XENVFE]XINVDAT(II) = [F:XXINV]FECHA
    [M:XENVFE]XSIVTIP(II) = [F:XXINV]TIPO
    [M:XENVFE]AMTATI(II)  = [F:XXINV]IMPORTE
    [M:XENVFE]CUR(II)     = [F:XXINV]DIVISA
    [M:XENVFE]XENVIADA(II)= [F:XXINV]ZEMIBAVEL

    Gosub CARGA_MAIL
    [M:XENVFE]XEMAIL(II)  = MAIL

Return

######################################################################################
######################################################################################
Subprog AM_NUMF(VALEUR)
Variable Char    VALEUR()
Local Integer YESNO
Local Char EXISTE(1)

    EXISTE = '0'
    For [F:XTFAC] Where [F:XTFAC]NUM <> 'TODOS'
      EXISTE = '1'
      Break
    Next

    If EXISTE = '1'
      Call OUINON("¿Desea cancelar la selección realizada?",YESNO) From GESECRAN
      If YESNO = 2
       Delete [XTFAC] Where [F:XTFAC]NUM <> 'TODOS'
       [M:XENVFE]NUMF = VALEUR
       Affzo [M:XENVFE]NUMF
#       [M:XENVFE]XTODAS = 1
#       Affzo [M:XENVFE]XTODAS
       Gosub BUSCAR
      Else
       VALEUR = [M:XENVFE]NUMF
      Endif
    Else
     [M:XENVFE]NUMF = VALEUR
     Affzo [M:XENVFE]NUMF
     Gosub BUSCAR
    Endif

End

