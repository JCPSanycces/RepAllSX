######################################################################################
Subprog AM_CPY(VALEUR)
Variable Char    VALEUR()

 [M:XENVFE]CPY = VALEUR
 Affzo [M:XENVFE]CPY
 Gosub BUSCAR
End

####################################################################################
$MARCA_YES
######################################################################################
Local Integer X
For X = 0 To 19

   If  [M:XENVFE]XNUM(X) <> ''
      [M:XENVFE]XSEL(X) = 2
      Affzo [M:XENVFE]XSEL(X)
   Endif
Next
Return

####################################################################################
$MARCA_NO
######################################################################################
Local Integer X
For X = 0 To 19

   If  [M:XENVFE]XNUM(X) <> ''
      [M:XENVFE]XSEL(X) = 1
      Affzo [M:XENVFE]XSEL(X)
   Endif
Next
Return

###################################################################################
$CARGA_MAIL
###################################################################################
Local Char EXISTE(1)
EXISTE = '0'
#   MAIL="lcuevas@quonext.com"
#   EXISTE = '1'
#   Return

   Read [XSIV]SIV0 = FACTURA
   If !fstat


      HOTEL = ''
      For [XBPD] Where [F:XBPD]BPCNUM = [F:XSIV]BPCINV & [F:XBPD]BPAADD = [F:XSIV]BPAADD
         HOTEL = [F:XBPD]XHTLCRS
         Break
      Next


      If [F:XSIV]BPAADD <> ''
         EXISTE = '0'
         For [XCNT] Where [F:XCNT]BPANUM = [F:XSIV]BPCINV and  [F:XCNT]BPAADD = [F:XSIV]BPAADD and [F:XCNT]CNTFNC = 13

          EXISTE = '1'
          MAIL = [F:XCNT]WEB
          Break
         Next
         If EXISTE = '0'
            For [XCNT] Where [F:XCNT]BPANUM = [F:XSIV]BPCINV and  [F:XCNT]BPAADD = '' and [F:XCNT]CNTFNC = 13


              EXISTE = '1'
              MAIL = [F:XCNT]WEB
              Break
            Next
         Endif
         If EXISTE = '0'
            For [XCNT] Where [F:XCNT]BPANUM = [F:XSIV]BPCINV and  [F:XCNT]BPAADD = ' ' and [F:XCNT]CNTFNC = 13


              EXISTE = '1'
              MAIL = [F:XCNT]WEB
              Break
            Next
         Endif
       Else
         For [XCNT] Where [F:XCNT]BPANUM = [F:XSIV]BPCINV and  [F:XCNT]BPAADD = '' and [F:XCNT]CNTFNC = 13

              EXISTE = '1'
              MAIL = [F:XCNT]WEB
              Break
            Next
            If EXISTE = '0'
            For [XCNT] Where [F:XCNT]BPANUM = [F:XSIV]BPCINV and  [F:XCNT]BPAADD = ' ' and [F:XCNT]CNTFNC = 13


              EXISTE = '1'
              MAIL = [F:XCNT]WEB
              Break
            Next
         Endif
       Endif
   Endif
Return

###################################################################################
$PDF_FACTURAS
###################################################################################
  #Dbgaff
  FFIC(2) = 'XSBONFACPMAIL'

  Global Char C_FICHIER(255)
                   TBPAR (1) = "facturedeb" : TBVAL (1) = [F:XTFAC]NUM
                   TBPAR (2) = "facturefin" : TBVAL (2) = [F:XTFAC]NUM
                   TBPAR (3) = "sitedeb"    : TBVAL (3) = [F:XTFAC]SALFCY
                   TBPAR (4) = "sitefin"    : TBVAL (4) = [F:XTFAC]SALFCY
                   TBPAR (5) = "clientdeb" : TBVAL (5) = [F:XTFAC]BPCINV
                   TBPAR (6) = "clientdeb" : TBVAL (6) = [F:XTFAC]BPCINV
  Read [XXSIH]SIH0 = [F:XTFAC]NUM
  If [XXSIH]STARPT = 1
                   TBPAR (7) = "codimp" : TBVAL (7) = ' '
  Else
                   TBPAR (7) = "codimp" : TBVAL (7) = '2'
  Endif

  If [XXSIH]XENVIADA <> 2
                   C_FICHIER = filpath("ZPDF","XSBONFACPMAIL","pdf","","","")
                   Call ETAT("XSBONFACPMAIL","","",0,"",TBPAR,TBVAL) From AIMP3
                   Update [XXSIH] Where [F:XXSIH]NUM = [F:XTFAC]NUM With [F:XXSIH]XENVIADA = 2

           Else
            If [M:XENVFE]XTODAS <> 2
                 C_FICHIER = filpath("ZPDF","XSBONFACPMAIL","pdf","","","")
                 Call ETAT("XSBONFACPMAIL","","",0,"",TBPAR,TBVAL) From AIMP3
            Endif
  Endif
  Sleep(5)
  Raz TBPAR,TBVAL
Return

###################################################################################
$EXCEL_LOCALIZADORES
###################################################################################
  FFIC(1) = 'XLOCCLIBREV'
  #Infbox ("EXCEL_LOCALIZADORES"-[F:XTFAC]NUM)
  TBPAR (1) = "numfacdeb" : TBVAL (1) = [F:XTFAC]NUM
  #Infbox ("Parametro"-TBVAL(1))
  Local Integer STAT
  Call  EFFACE(filpath("ZPDF","XLOCCLIBREV","xls","","",""),STAT) From ORDSYS
  Read [XXSIH]SIH0 = [F:XTFAC]NUM
  If [XXSIH]XENVIADA <> 2
                   C_FICHIER = filpath("ZPDF","XLOCCLIBREV","xls","","","")
                   Call ETAT("XLOCCLIBREV","","",0,"",TBPAR,TBVAL) From AIMP3
                   Update [XXSIH] Where [F:XXSIH]NUM = [F:XTFAC]NUM With [F:XXSIH]XENVIADA = 2

  Else
    If [M:XENVFE]XTODAS <> 2
      C_FICHIER = filpath("ZPDF","XLOCCLIBREV","xls","","","")
      Call ETAT("XLOCCLIBREV","","",0,"",TBPAR,TBVAL) From AIMP3
    Endif
  Endif
  ZZZ=0
  $ESPERA
  If filinfo(filpath("ZPDF","XLOCCLIBREV","xls","","",""),7)<0
    Sleep 1
    ZZZ+=1
    If ZZZ<10: Goto ESPERA: Endif
  Endif

  Raz TBPAR,TBVAL
Return

