##################################################
Subprog AM_AFTMODBPRI(VALEUR)
Variable Char   VALEUR()
  Local Integer I, J, NOL: NOL=nolign-1
  Local Char WNIP(60)
  Local File BPARTNER [BPR]

  If VALEUR<>""
    VALEUR=toupper(VALEUR)
    Read [BPR]BPR0=VALEUR
    If fstat=[V]CST_AOK
      [M:XSIII]NIP(NOL)   =[F:BPR]CRN
      [M:XSIII]BPRNAM(NOL)=[F:BPR]BPRNAM
      [M:XSIII]CRY(NOL)   =[F:BPR]CRY
      Affzo [M:XSIII]NIP(NOL),BPRNAM(NOL), CRY(NOL)
    Endif
  Endif
End


##################################################
Subprog C_FLGSEL(VALEUR)
Variable Integer VALEUR()
Local Integer NOL: NOL=nolign-1
Local Integer NERR: NERR=0

  Case maskcou
    When "XX025SIILR" : If [M:XSIIR]BPRVCR(NOL)=""  and VALEUR=2: NBERR=1: Endif
    When "XX025SIILPA": If [M:XSIIPA]BPRVCR(NOL)="" and VALEUR=2: NBERR=1: Endif
  Endcase

  If NBERR=1
    GMESSAGE="Número de factura proveedor vacío. Use la opción de mofificación para alimentarlo"
    mkstat=2
  Endif
End

#####################################################################################
Subprog C_TYPANUAL(VALEUR)
Variable Char VALEUR()
Local Integer NOL: NOL=nolign-1

  If GXX025EXTAP=2
    GMESSAGE="Inserción manual no permitida si origen de datos no es X3.": mkstat=2:
    End
  Endif

  VALEUR=toupper(VALEUR)
  If VALEUR<>"V" and VALEUR<>"S"
    GMESSAGE="Debe ser S o V": mkstat=2
  Endif
End

#####################################################################################
Subprog AM_TYPANUAL(VALEUR)
Variable Char VALEUR()
Local Integer NOL: NOL=nolign-1

  VALEUR=toupper(VALEUR)
  If [M:XSIIM]TYPANUAL(NOL)<>"" and VALEUR<>[M:XSIIM]TYPANUAL(NOL) and [M:XSIIM]NIP(NOL)<>""
    GMESSAGE="Modificación no permitida. Si no es correcto use modificación para cancelar la línea": mkstat=2: End
  Endif

  If VALEUR="V"
    Raz [M:XSIIM]CLAVEOPE(NOL)
    Grizo [M:XSIIM]CLAVEOPE(NOL)
    Affzo [M:XSIIM]CLAVEOPE(NOL)
  Elsif VALEUR="S"
    Actzo [M:XSIIM]CLAVEOPE(NOL)
    [M:XSIIM]CLAVEOPE(NOL)="A"
    Affzo [M:XSIIM]CLAVEOPE(NOL)
  Endif
End

#####################################################################################
Subprog C_OPECEE(VALEUR)
Variable Char VALEUR()
Local Integer NOL: NOL=nolign-1

  VALEUR=toupper(VALEUR)
  If VALEUR<>"A" and VALEUR<>"B"
    GMESSAGE="Debe ser A o B": mkstat=2
  Endif
End

######################################################################################
Subprog C_CLAVECEE(VALEUR)
Variable Char VALEUR()
Local Integer NOL: NOL=nolign-1

  VALEUR=toupper(VALEUR)
  If VALEUR<>"D" and VALEUR<>"R"
    GMESSAGE="Debe ser D o R": mkstat=2
  Endif

End

######################################################################################
Subprog AM_OPEMET(VALEUR)
Variable Char VALEUR()
Local Integer NOL: NOL=nolign-1
Local Char WNIP(60)

  VALEUR=toupper(VALEUR)
  If VALEUR<>"A" and VALEUR<>"B"
    GMESSAGE="Debe ser A o B": mkstat=2
  Endif

  If NOL>0 and [M:XSIIM]TYPANUAL(NOL)<>"M" and [M:XSIIM]NIP(NOL)<>""
    WNIP=[M:XSIIM]NIP(NOL)
    Gosub REV_CLAVEOPEMET
    If J=1
      GMESSAGE="Tercero ya existe para este tipo de operación": mkstat=2: End
    Endif
  Endif

End

#####################################################################################
Subprog C_VCRNUM(VALEUR)
Variable Char VALEUR()
Local Integer NOL: NOL=nolign-1

  If GXX025EXTAP=2
    GMESSAGE="Inserción manual no permitida si origen de datos no es X3.": mkstat=2:
    End
  Endif
End

######################################################################################
$DEL_SEGURO
  Local Integer YESNO, I, K
  WMSG="Estas cambiado el identificador ¿Quiere borrar el actual registro de este identificador y crear uno nuevo?"
  Call OUINON (WMSG, YESNO) From GESECRAN
  If YESNO = 2 : # 2 = YES
    Read [X025SII]X025SI0=[M:XSII]CPY;7;[M:XSIIM]GTE(NOL);[M:XSIIM]VCRNUM(NOL);1
    If fstat=[V]CST_AOK
      Trbegin  [X025SII]
        Delete Curr
      Commit
    Endif
  Else
    [M:XSIIM]NIP(NOL)=VALEUR
    Affzo [M:XSIIM]NIP(NOL)
    Call APRES_MET
    Gosub ACT_OPEANU
  Endif
Return

######################################################################################
$ACT_EMI
  Raz [M:XSIIE]
  Local Char CRITCAR (250)
  Local Integer WNL, GRP
  Local File XX025SII [YXSIE]
  CRITCAR="1=1"
  If [M:XSII]FCY<>""
    Call ADDCRIT(CRITCAR,ICRIT,"FCY",'[F:YXSIE]FCY="'+[M:XSII]FCY+'"'," & ") From GOBJSUB
  Endif

  # Site autorization
  If GUSRFCY(1)<>"\" & ([M:XSII]FCY<>"" | GRP) & GNBAUZ<>GNBSITE
    Call ADDCRIT(CRITCAR,ICRIT,"FCY",'find([F:YXSIE]FCY,GUSRFCY(1..GNBAUZ))'," & ") From GOBJSUB
  Endif

  # BPs
  If [M:XSII]BPR<>""
    Call ADDCRIT(CRITCAR, ICRIT,"BPR",'[F:YXSIE]BPR="'+[M:XSII]BPR+'"'," & ") From GOBJSUB
  Endif

  # lot
  If [M:XSII]LOT<>""
    Call ADDCRIT(CRITCAR, ICRIT,"LOT",'[F:YXSIE]LOTNUM="'+[M:XSII]LOT+'"'," & ") From GOBJSUB
   Endif

  # Error number
  If [M:XSII]VCRERRNUM<>""
    Call ADDCRIT(CRITCAR, ICRIT,"VCRERRNUM",'[F:YXSIE]VCRERRNUM="'+[M:XSII]VCRERRNUM+'"'," & ") From GOBJSUB
  Endif

  # Comunication type
  If [M:XSII]ALLCOM<>2
    Case [M:XSII]TYPCOM
      When 1: Call ADDCRIT(CRITCAR,ICRIT,"TYPCOM",'[F:YXSIE]TYPCOM=1'," & ")  From GOBJSUB
      When 2: Call ADDCRIT(CRITCAR,ICRIT,"TYPCOM",'[F:YXSIE]TYPCOM=2'," & ")  From GOBJSUB
      When 3: Call ADDCRIT(CRITCAR,ICRIT,"TYPCOM",'[F:YXSIE]TYPCOM=3'," & ")  From GOBJSUB
    Endcase
  Endif

 # Document status
  If [M:XSII]STAALL<>2
    Case [M:XSII]VCRSTA
      When 1: Call ADDCRIT(CRITCAR,ICRIT,"VCRSTA",'[F:YXSIE]VCRSTA<2'," & ")  From GOBJSUB
      When 2: Call ADDCRIT(CRITCAR,ICRIT,"VCRSTA",'[F:YXSIE]VCRSTA=2'," & ")  From GOBJSUB
      When 3: Call ADDCRIT(CRITCAR,ICRIT,"VCRSTA",'[F:YXSIE]VCRSTA=3'," & ")  From GOBJSUB
      When 4: Call ADDCRIT(CRITCAR,ICRIT,"VCRSTA",'[F:YXSIE]VCRSTA=4'," & ")  From GOBJSUB
    Endcase
  Endif

  Filter [YXSIE] Where TYPENV=1 and [F:YXSIE]DATOPE>=[M:XSII]DATINI and  [F:YXSIE]DATOPE<=[M:XSII]DATEND and [F:YXSIE]CPY=[M:XSII]CPY and evalue(CRITCAR)
  For [YXSIE]
    [M:XSIIE]FLGSEL(WNL)    =[F:YXSIE]FLGSEL
    [M:XSIIE]GTE(WNL)       =[F:YXSIE]GTE
    [M:XSIIE]VCRNUM(WNL)    =[F:YXSIE]VCRNUM
    [M:XSIIE]STADOC(WNL)    =[F:YXSIE]STADOC
    [M:XSIIE]VCRSTA(WNL)    =[F:YXSIE]VCRSTA
    [M:XSIIE]TYPCOM(WNL)    =[F:YXSIE]TYPCOM
    [M:XSIIE]DATOPE(WNL)    =[F:YXSIE]DATOPE
    [M:XSIIE]AMTATI(WNL)    =[F:YXSIE]AMTATI
    [M:XSIIE]CRY(WNL)       =[F:YXSIE]CRY
    [M:XSIIE]BPR(WNL)       =[F:YXSIE]BPR
    [M:XSIIE]BPRNAM(WNL)    =[F:YXSIE]BPRNAM
    [M:XSIIE]NIP(WNL)       =[F:YXSIE]NIP
    [M:XSIIE]VCRERRNUM(WNL) =[F:YXSIE]VCRERRNUM
    [M:XSIIE]VCRLIN(WNL)    =[F:YXSIE]VCRLIN
    WNL+=1
    If WNL=dim([M:XSIIE]FLGSEL): Break: Endif
  Next
  [M:XSIIE]NBLIG=WNL
  Affzo [M:XSIIE]1-99
  Close File [YXSIE]
Return

######################################################################################
$ACT_REC
  Raz [M:XSIIR]
  Local Char CRITCAR (250)
  Local Integer WNL, GRP
  Local File XX025SII [YXSIR]
  CRITCAR="1=1"
  If [M:XSII]FCY<>""
    Call ADDCRIT(CRITCAR,ICRIT,"FCY",'[F:YXSIR]FCY="'+[M:XSII]FCY+'"'," & ") From GOBJSUB
  Endif

  # Site autorization
  If GUSRFCY(1)<>"\" & ([M:XSII]FCY<>"" | GRP) & GNBAUZ<>GNBSITE
    Call ADDCRIT(CRITCAR,ICRIT,"FCY",'find([F:YXSIR]FCY,GUSRFCY(1..GNBAUZ))'," & ") From GOBJSUB
  Endif

  # BPs
  If [M:XSII]BPR<>""
    Call ADDCRIT(CRITCAR, ICRIT,"BPR",'[F:YXSIR]BPR="'+[M:XSII]BPR+'"'," & ") From GOBJSUB
  Endif

  # lot
  If [M:XSII]LOT<>""
    Call ADDCRIT(CRITCAR, ICRIT,"LOT",'[F:YXSIR]LOTNUM="'+[M:XSII]LOT+'"'," & ") From GOBJSUB
   Endif

  # Error number
  If [M:XSII]VCRERRNUM<>""
    Call ADDCRIT(CRITCAR, ICRIT,"VCRERRNUM",'[F:YXSIR]VCRERRNUM="'+[M:XSII]VCRERRNUM+'"'," & ") From GOBJSUB
  Endif

  # Comunication type
  If [M:XSII]ALLCOM<>2
    Case [M:XSII]TYPCOM
      When 1: Call ADDCRIT(CRITCAR,ICRIT,"TYPCOM",'[F:YXSIR]TYPCOM=1'," & ")  From GOBJSUB
