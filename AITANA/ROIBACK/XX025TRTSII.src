    Call ADDCRIT(CRITCAR, ICRIT,"BPR",'[F:YXSIM]BPR="'+[M:XSII]BPR+'"'," & ") From GOBJSUB
  Endif

  # lot
  If [M:XSII]LOT<>""
    Call ADDCRIT(CRITCAR, ICRIT,"LOT",'[F:YXSIM]LOTNUM="'+[M:XSII]LOT+'"'," & ") From GOBJSUB
   Endif

  # Error number
  If [M:XSII]VCRERRNUM<>""
    Call ADDCRIT(CRITCAR, ICRIT,"VCRERRNUM",'[F:YXSIM]VCRERRNUM="'+[M:XSII]VCRERRNUM+'"'," & ") From GOBJSUB
  Endif

  # Comunication type
  If [M:XSII]ALLCOM<>2
    Case [M:XSII]TYPCOM
      When 1: Call ADDCRIT(CRITCAR,ICRIT,"TYPCOM",'[F:YXSIM]TYPCOM=1'," & ")  From GOBJSUB
      When 2: Call ADDCRIT(CRITCAR,ICRIT,"TYPCOM",'[F:YXSIM]TYPCOM=2'," & ")  From GOBJSUB
      When 3: Call ADDCRIT(CRITCAR,ICRIT,"TYPCOM",'[F:YXSIM]TYPCOM=3'," & ")  From GOBJSUB
    Endcase
  Endif

 # Document status
  If [M:XSII]STAALL<>2
    Case [M:XSII]VCRSTA
      When 1: Call ADDCRIT(CRITCAR,ICRIT,"VCRSTA",'[F:YXSIM]VCRSTA<2'," & ")  From GOBJSUB
      When 2: Call ADDCRIT(CRITCAR,ICRIT,"VCRSTA",'[F:YXSIM]VCRSTA=2'," & ")  From GOBJSUB
      When 3: Call ADDCRIT(CRITCAR,ICRIT,"VCRSTA",'[F:YXSIM]VCRSTA=3'," & ")  From GOBJSUB
      When 4: Call ADDCRIT(CRITCAR,ICRIT,"VCRSTA",'[F:YXSIM]VCRSTA=4'," & ")  From GOBJSUB
    Endcase
  Endif

  Filter [YXSIM] Where TYPENV=7 and year([F:YXSIM]DATOPE)=year([M:XSII]DATINI)and [F:YXSIM]CPY=[M:XSII]CPY and evalue(CRITCAR)
  For [YXSIM]
    [M:XSIIM]FLGSEL(WNL)    =[F:YXSIM]FLGSEL
    [M:XSIIM]GTE(WNL)       =[F:YXSIM]GTE
