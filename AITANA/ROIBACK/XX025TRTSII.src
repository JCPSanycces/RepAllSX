  Local File XX025SII [YXSIM]
  CRITCAR="1=1"
  If [M:XSII]FCY<>""
    Call ADDCRIT(CRITCAR,ICRIT,"FCY",'[F:YXSIM]FCY="'+[M:XSII]FCY+'"'," & ") From GOBJSUB
  Endif

  # Site autorization
