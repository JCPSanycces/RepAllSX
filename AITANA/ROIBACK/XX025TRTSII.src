    [M:XSII]DATEND=gdat$(eomonth(VALEUR),month(VALEUR),year(VALEUR))
    Affzo [M:XSII]DATEND
    GXX=1
  Endif
  GMODCRI=1
End

##################################################
Subprog AM_AFTMODAT2(VALEUR)
