    Raz [M:XSIIE], [M:XSIIR], [M:XSIIC], [M:XSIII], [M:XSIICA], [M:XSIIPA], [M:XSIIM]
    Affzo [M:XSIIE]: Affzo [M:XSIIR]: Affzo [M:XSIIC]: Affzo [M:XSIII]: Affzo [M:XSIICA]: Affzo [M:XSIIPA]: Affzo [M:XSIIM]
    GXX=1
  Endif
End

##################################################
Subprog AM_AFTMODAT1(VALEUR)
