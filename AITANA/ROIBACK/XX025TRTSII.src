    [M:XSIIM]TYPCOM(WNL)    =[F:YXSIM]TYPCOM
    [M:XSIIM]DATOPE(WNL)    =[F:YXSIM]DATOPE
    [M:XSIIM]AMTATI(WNL)    =[F:YXSIM]AMTATI
    [M:XSIIM]CRY(WNL)       =[F:YXSIM]CRY
    [M:XSIIM]BPR(WNL)       =[F:YXSIM]BPR
