  GMODCRI=1
End


##################################################
Subprog AM_AFTMODCRI(VALEUR)
Variable Integer   VALEUR()
  If VALEUR =2
    GMODCRI=1
  Endif
End

##################################################
Subprog AM_FLGSEL(VALEUR)
Variable Integer VALEUR()
Local Integer NOL: NOL=nolign-1

  Case maskcou
    When "XX025SIILR"
      If [M:XSIIR]BPRVCR(NOL)="" and VALEUR=2
        VALEUR=1
        [M:XSIIR]FLGSEL(NOL)=1
        Affzo [M:XSIIR]FLGSEL(NOL)
        GMESSAGE="Número de factura proveedor vacío. Use la opción de mofificación para alimentarlo"
        mkstat=2
      Endif
    When "XX025SIILI"
      If [M:XSIII]VCRNUM(NOL)<>"" and [M:XSIII]BPRVCR(NOL)="" and VALEUR=2
        VALEUR=1
        [M:XSIII]FLGSEL(NOL)=1
        Affzo [M:XSIII]FLGSEL(NOL)
        GMESSAGE="Número de factura proveedor vacío. Use la opción de mofificación para alimentarlo"
        mkstat=2
      Endif
    When "XX025SIILPA"
      If [M:XSIIPA]VCRNUM(NOL)<>"" and [M:XSIIPA]BPRVCR(NOL)="" and VALEUR=2
        VALEUR=1
        [M:XSIIPA]FLGSEL(NOL)=1
        Affzo [M:XSIIPA]FLGSEL(NOL)
        GMESSAGE="Documento origen vacío. Use la opción de mofificación para alimentarlo"
        mkstat=2
      Endif
   Endcase
End

##################################################
Subprog AM_AFTMODAMT(VALEUR)
Variable Decimal   VALEUR()
  Local Integer NOL: NOL=nolign-1
  Local Decimal WAMT:  WAMT=3005.06
  If VALEUR <=WAMT
    GMESSAGE="El importe tiene que ser superior a"-num$(WAMT)-"euros"
    mkstat=2: End
  Endif

  If [M:XSIIM]STADOC(NOL)=2
    [M:XSIIM]FLGSEL(NOL)=2
    [M:XSIIM]STADOC(NOL)=1
    [M:XSIIM]TYPCOM(NOL)=2
    [M:XSIIM]VCRSTA(NOL)=1
    Affzo [M:XSIIM]FLGSEL(NOL),STADOC(NOL), TYPCOM(NOL),VCRSTA(NOL)
    Actzo [M:XSIIM]FLGSEL(NOL)

    If [M:XSIIM]TYPANUAL(NOL)<>"M"
      If [M:XSIIM]STADOC(NOL)=1 and [M:XSIIM]VCRNUM(NOL)<>""
        Local File XX025SII [XYSII]
        Readlock [F:XYSII]X025SI0 = [M:XSII]CPY;7;[M:XSIIM]GTE(NOL);[M:XSIIM]VCRNUM(NOL);1
        If fstat=[V]CST_AOK
          Trbegin [F:XYSII]
            [F:XYSII]FLGSEL=[M:XSIIM]FLGSEL(NOL)
            [F:XYSII]STADOC=[M:XSIIM]STADOC(NOL)
            [F:XYSII]VCRSTA=[M:XSIIM]VCRSTA(NOL)
            [F:XYSII]TYPCOM=[M:XSIIM]TYPCOM(NOL)
            Rewrite
          Commit
        Endif
      Endif
    Endif
  Endif

End

##################################################
Subprog AM_AFTMODBPR(VALEUR)
Variable Char   VALEUR()
  Local Integer I, J, NOL: NOL=nolign-1
  Local Char WNIP(60)
  Local File BPARTNER [BPR]

  If VALEUR<>""
    VALEUR=toupper(VALEUR)
    If maskcou="XX025SIILM"
      Read [BPR]BPR0=VALEUR
      If fstat=[V]CST_AOK
        [M:XSIIM]NIP(NOL)   =[F:BPR]CRN
        [M:XSIIM]BPRNAM(NOL)=[F:BPR]BPRNAM
        [M:XSIIM]CRY(NOL)   =[F:BPR]CRY
        [M:XSIIM]VCRNUM(NOL)=[F:BPR]CRN+"-"+num$(year([M:XSII]DATINI))+"-"+[M:XSIIM]TYPANUAL(NOL)
        Affzo [M:XSIIM]VCRNUM(NOL),NIP(NOL),BPRNAM(NOL), CRY(NOL)
      Endif
      If NOL>0 and [M:XSIIM]TYPANUAL(NOL)<>"M"
        WNIP=[M:XSIIM]NIP(NOL)
        Gosub REV_CLAVEOPEMET
        If J=1
          Raz [M:XSIIM]NIP(NOL), [M:XSIIM]BPRNAM(NOL)
          GMESSAGE="Tercero ya existe para este tipo de operación"
          Affzo [M:XSIIM]NIP(NOL), BPRNAM(NOL)
          mkstat=2: End
        Endif
      Endif
    Elsif maskcou="XX025SIILC"
      Read [BPR]BPR0=VALEUR
      If fstat=[V]CST_AOK
        [M:XSIIC]NIP(NOL)   =[F:BPR]CRN
        [M:XSIIC]BPRNAM(NOL)=[F:BPR]BPRNAM
        [M:XSIIC]CRY(NOL)   =[F:BPR]CRY
        Affzo [M:XSIIC]NIP(NOL),BPRNAM(NOL), CRY(NOL)
      Endif
    Endif
  Endif
  Close File [BPR]
End

##################################################
Subprog C_AFTNIPMET(VALEUR)
Variable Char   VALEUR()
  Local Integer J, NOL: NOL=nolign-1
  Local Char WNIP(60)

 # If VALEUR<>"" and [M:XSIIM]NIP(NOL)<>"" : Gosub DEL_SEGURO: Endif
  If VALEUR<>""
    VALEUR=toupper(VALEUR)
    [M:XSIIM]VCRNUM(NOL)=VALEUR+"-"+num$(year([M:XSII]DATINI))+"-"+[M:XSIIM]TYPANUAL(NOL)+[M:XSIIM]CLAVEOPE(NOL)
#    If NOL>0 and [M:XSIIM]TYPANUAL(NOL)<>"M"
    If [M:XSIIM]TYPANUAL(NOL)<>"M"
      WNIP=VALEUR
      Gosub REV_CLAVEOPEMET
      If J=1
        GMESSAGE="Tercero ya existe para este tipo de operación": mkstat=2: End
      Endif
    Endif

    Local File BPARTNER [BPR]
    Filter [BPR] Where CRN=VALEUR
    Read [BPR]BPR0 First
    If fstat=[V]CST_AOK
      [M:XSIIM]BPRNAM(NOL)=[F:BPR]BPRNAM
      [M:XSIIM]CRY(NOL)   =[F:BPR]CRY
      Affzo [M:XSIIM]BPRNAM(NOL), CRY(NOL)
    Endif
    Affzo [M:XSIIM]VCRNUM(NOL)
    Close File [BPR]
  Endif

End

##################################################
Subprog AM_AFTNIPMET(VALEUR)
Variable Char   VALEUR()
  Local Integer J, NOL: NOL=nolign-1
  Local Char WNIP(60)

  If VALEUR<>"" and [M:XSIIM]NIP(NOL)<>"" and [M:XSIIM]AMTATI(NOL)<>0 : Gosub DEL_SEGURO: Endif
End

##################################################
Subprog S_VCRNUM(VALEUR)
Variable Char  VALEUR()

  If [M:XSIII]GTE(nolign-1)="": End: Endif

  Local Integer K, NBVCR, NOL: NOL=nolign-1
  Local Integer CHOICE: CHOICE=0
  Local Char    TEX(40)(1..,1..2),TIT(GLONDES)(0..2)

  Local File XX025SII [XYSII]
  Filter [XYSII] Where year(DATOPE)=year([M:XSII]DATINI) and TYPENV=2 and GTE=[M:XSIII]GTE(NOL)
  For [XYSII]
    If [F:XYSII]BPRVCR<>""
      NBVCR += 1
      TEX(NBVCR,1) = mess(2,13230,1)
      TEX(NBVCR,2) = [F:XYSII]VCRNUM
    Endif
  Next

  TIT(0) = mess(8,31,1)       # Selección
  TIT(1) = mess(13030,200,1)  # Tipo libro
  TIT(2) = mess(2,176,1)      # Número documento

  If NBVCR > 0
    Call SAITEX_COL_MAX(NBVCR,TEX,CHOICE,TIT,80,50) From GESECRAN
    If status<>7 & CHOICE<>0
      VALEUR = TEX(CHOICE,2)
    Endif
  Else
    GMESSAGE="No existe factura en libro de recibidas" # El asiento no existe
    mkstat=2
  Endif
End

##################################################
Subprog AM_VCRNUM(VALEUR)
Variable Char  VALEUR()
  Local Integer NOL: NOL=nolign-1
  Local Char WMSG(250)

  If VALEUR="": GMESSAGE="Valor obligatorio":  mkstat=2: End: Endif

  J=find(VALEUR+"_"+num$(year([M:XSII]DATINI)),[M:XSIII]VCRNUM(0..[M:XSIII]NBLIGI-1))
  If J<>0
    GMESSAGE="Ya existe registro para este año"
    mkstat=2
    End
  Endif

  Local File XX025SII [XYSII]
  Read [XYSII]X025SI1=[M:XSII]CPY+"2"+[M:XSIII]GTE(NOL)+VALEUR+"1"
  If fstat=[V]CST_AOK
    Local Datetime WORIDAT, WDVSDAT
    # Alimentamos pantalla con los valores si existe
    [M:XSIII]FLGSEL(NOL)=2
    [M:XSIII]STADOC(NOL)=1
    [M:XSIII]TYPCOM(NOL)=1
    [M:XSIII]VCRNUM(NOL)=VALEUR+"_"+num$(year([M:XSII]DATINI))
    [M:XSIII]BPRVCR(NOL)=[F:XYSII]BPRVCR
    [M:XSIII]DATOPE(NOL)=[F:XYSII]DATOPE
    [M:XSIII]AMTATI(NOL)=[F:XYSII]AMTATI
    [M:XSIII]CUR(NOL)   ="EUR"
    [M:XSIII]BPR(NOL)   =[F:XYSII]BPR
    [M:XSIII]BPRNAM(NOL)=[F:XYSII]BPRNAM
    [M:XSIII]NIP(NOL)   =[F:XYSII]NIP
    [M:XSIII]CRY(NOL)   =[F:XYSII]CRY
    [M:XSIII]VCRSTA(NOL)=1
    [M:XSIII]VCRLIN(NOL)=1
    [M:XSIII]NBLIGI=NOL
    Affzo [M:XSIII]1-99
    WORIDAT=[F:XYSII]DATDVS
    WDVSDAT=[F:XYSII]DATVCRORI

    # creamos el nuevo tipo 4
    Trbegin [F:XYSII]
      [F:XYSII]CPY=[M:XSII]CPY
      [F:XYSII]STADOC=1
      [F:XYSII]TYPENV=4
      [F:XYSII]TYPCOM=1
      [F:XYSII]GTE   =[M:XSIII]GTE(NOL)
      [F:XYSII]VCRNUM=[M:XSIII]VCRNUM(NOL)
      [F:XYSII]VCRLIN=1
      [F:XYSII]VCRSTA=1
      [F:XYSII]DATOPE=[M:XSIII]DATOPE(NOL)
      [F:XYSII]BPRVCR=[M:XSIII]BPRVCR(NOL)
      [F:XYSII]AMTATI=[M:XSIII]AMTATI(NOL)
      [F:XYSII]BPR   =[M:XSIII]BPR(NOL)
      [F:XYSII]BPRNAM=[M:XSIII]BPRNAM(NOL)
      [F:XYSII]NIP   =[M:XSIII]NIP(NOL)
      [F:XYSII]CRY   =[M:XSIII]CRY(NOL)
      [F:XYSII]TYPREC=""
      [F:XYSII]DKEY=[F:XYSII]CPY+num$([F:XYSII]TYPENV)+[F:XYSII]GTE+[F:XYSII]VCRNUM+num$([F:XYSII]VCRLIN)
      [F:XYSII]DATDVS=WDVSDAT
      [F:XYSII]DATVCRORI=WORIDAT
      Write
    Commit
    [M:XSIII]FLGSEL(NOL)=2
    VALEUR=VALEUR+"_"+num$(year([M:XSII]DATINI))
  Else
    VALEUR=VALEUR+"_"+num$(year([M:XSII]DATINI))
    [M:XSIII]FLGSEL(NOL)=2
    Raz [M:XSIII]STADOC(NOL),TYPCOM(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL),VCRERRNUM(NOL)
    [M:XSIII]DATOPE(NOL)=date$
  Endif
  Affzo [M:XSIII]1-99
  Close File [XYSII]
End

##################################################
Subprog AM_VCRNUMCEE(VALEUR)
Variable Char  VALEUR()
  Local Integer YESNO, WOKK
  Local Integer NOL: NOL=nolign-1
  Local Char WMSG(250)
  Local Datetime WORIDAT, WDVSDAT

  If GXX025EXTAP=2 : End: Endif

  [M:XSIIC]FLGSEL(NOL)=2
  Raz [M:XSIIC]STADOC(NOL),TYPCOM(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL),VCRERRNUM(NOL)
  [M:XSIIC]DATOPE(NOL)=date$
  Affzo [M:XSIIC]1-99

End

