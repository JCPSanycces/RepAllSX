#<AdxTL>@(#)0.0.0.0 $Revision$
######################################
# SII process script  JUCON 15/01/17 #
######################################
$RES_DVS
  Local Integer WTRT : WTRT=0
  Call PARAML([M:XSII]CPY,"XX025DVSR",WRECSII) From ADOVAL
  If val(WRECSII)=2
    WMSG="¿Quiere resincronizar la tabla de impuestos (IVA y metálico)?"
    Call OUINON (WMSG, YESNO) From GESECRAN
    If YESNO = 2 : # 2 = YES
      ### VAT resincronization
      Gosub OUVRE     From DCLVATSPA
      # inicializating DCLVATSPA mask
      Local Mask DCLVATSPA [DIA]
      Raz [M:DIA]
      [M:DIA]YEA=year([M:XSII]DATINI)
      [M:DIA]ALLCPY=1
      [M:DIA]ALLFCY=1
      [M:DIA]CPY=[M:XSII]CPY
      If [M:DIA]FCY<>""
        [M:DIA]FCY=[M:XSII]FCY
      Else
        [M:DIA]ALLFCY=2
      Endif

      If  val([M:XSII]DATINI)>val(GFECSII)
        [M:DIA]STRDAT=[M:XSII]DATINI
        [M:DIA]ENDDAT=[M:XSII]DATEND
        WTRT=1
      Else
        If val([M:XSII]DATEND)>val(GFECSII)
          [M:DIA]STRDAT=GFECSII+1
          [M:DIA]ENDDAT=[M:XSII]DATEND
          WTRT=1
        Endif
      Endif

      If WTRT=1
        [M:DIA]RESINCRONI=2
        If GMETSII=2
          [M:DIA]CASH=2
        Else
          [M:DIA]CASH=1
        Endif
        Gosub CONTROLE  From DCLVATSPA
        Gosub EXEC      From DCLVATSPA
        Gosub TERMINE   From DCLVATSPA
        Close Mask [DIA]
      Endif
    Endif
  Endif
  GXX=2
Return

$READ_IVA
# Por rango de fechas revisa los registros de IVA a  tratar. Si no está tratado se crea en las tablas
# Si se ha gestionado se debe comprobar si se ha modifiado. Si no modificado NADA A HACER
# Si modificado se elimina  y se crea como modificado en las tablas

  Local Integer WVCRLIN, WTYPCOM, WRETEN, WTRT, WCAJA
  WTRT=0
  Local Date WSTRDAT, WSTREND
  Raz CRITERE
  Local Datetime WDATVCRORI
  Local Char WCRYORI(40)
  Local Decimal WRCG, WAMTATI
  CRITERE = '[F:DVS]CPY="'+[M:XSII]CPY+'"'
  If [M:XSII]FCY<>""
    CRITERE -= '& [F:DVS]FCY="'+[M:XSII]FCY+'"'
  Endif

  If [M:XSII]BPR<>""  # mejora rendimiento carga monitor
    CRITERE -= '& [F:DVS]BPRNUM="'+[M:XSII]BPR+'"'
  Endif

  WDATE=[M:XSII]DATINI

  If val(WDATE)=0: WDATE=date$: Endif

  If [M:XSII]DATINI=[0/0/0]: [M:XSII]DATINI=gdat$(1,month(WDATE),year(WDATE))  Endif
  If [M:XSII]DATEND=[0/0/0]: [M:XSII]DATEND=gdat$(eomonth(WDATE))  Endif

  WSTRDAT=[M:XSII]DATINI
  WSTREND=[M:XSII]DATEND

  If  val([M:XSII]DATINI)>val(GFECSII)
    WTRT=1
  Else
    If val([M:XSII]DATEND)>val(GFECSII)
      WSTRDAT=GFECSII+1
      WTRT=1
    Endif
  Endif

#  CRITERE -= '& [F:DVS]ACCDAT>=['+format$(GFMD,WENDDAT)+']'
#  CRITERE -= '& [F:DVS]ACCDAT<=['+format$(GFMD,[M:XSII]DATEND)+']'
  CRITERE -= '& [F:DVS]ACCDAT>=['+format$(GFMD,WSTRDAT)+']'
  CRITERE -= '& [F:DVS]ACCDAT<=['+format$(GFMD,WSTREND)+']'

  GPOINT = "AFTDEFCRI":  Gosub ENTREE From EXEFNC

  If WTRT<>1 : Return: Endif

  Read [CPY]CPY0=[M:XSII]CPY
  If fstat=[V]CST_AOK
    Filter [DVS] Where evalue(CRITERE) and VATTYP=2  #ver si recargo en el periodo. Si no hay no se penaliza rendimiento
    If rowcount([DVS])>0: WRETEN=1: Else WRETEN=0: Endif
    Filter [DVS]

    Filter [DVS] Where evalue(CRITERE) and REGTYP>10  #ver si iva caja en el periodo. Si no hay no se penaliza rendimiento
    If rowcount([DVS])>0: WCAJA=1: Else WCAJA=0: Endif
    Filter [DVS]

    For [F:DVS]DVS1 Where evalue(CRITERE)
      Raz  WFLGMOD, WTYPCOM, OKK # (WFLGMOD: 1-ya existe; 0-modificado o nuevo)
      If [F:DVS]VATTYP<>2
        Local File DCLVATSPA [XYDVS]
        Raz WRCG, WAMTATI
        For [XYDVS] Where NUM=[F:DVS]NUM & VATTYP=1 & TAXTYP=[F:DVS]TAXTYP & TYP=[F:DVS]TYP & REGTYP<4
          WAMTATI+=[F:XYDVS]AMTNOTL+[F:XYDVS]AMTTAXL
        Next
        If WRETEN=1  #calculamos recargo
          For [XYDVS] Where NUM=[F:DVS]NUM & VATTYP=2 & TAXTYP=[F:DVS]TAXTYP & TYP=[F:DVS]TYP & REGTYP<4
            WRCG+=[F:XYDVS]AMTTAXL
          Next
        Endif
        Close File [XYDVS]
      Endif

      #### Pagos y cobros c.c.
      If [F:DVS]REGTYP>10
        Raz WRCG, WAMTATI
        If WCAJA=1
          Local File DCLVATSPA [XYDVS]
          Raz WRCG, WAMTATI
          For [XYDVS] Where NUM=[F:DVS]NUM & REGTYP>10 & REGTYP=[F:DVS]REGTYP
            WAMTATI+=[F:XYDVS]AMTNOTL+[F:XYDVS]AMTTAXL
          Next
          Close File [XYDVS]
        Else
          WAMTATI=[F:DVS]AMTNOTL+[F:DVS]AMTTAXL
        Endif
      Endif
      #### Fin Pagos y cobros

      # Buscamos tipo de libro
      Case [F:DVS]TAXTYP
        When "R":   # Emitidas
          # Comprobamos si existe en SII
          If [F:DVS]REGTYP<11
            WTYPENV=1
            WVCRLIN=1
          Else
            WTYPENV=5
            WVCRLIN=[F:DVS]REGTYP-10
          Endif
          Read [X025SI]X025SI0=[F:DVS]CPY;WTYPENV;[F:DVS]TYP;[F:DVS]NUM;WVCRLIN
          If fstat=[V]CST_AOK and [F:DVS]VATTYP=1  #solo tratamos tipo 1
            WFLGMOD=1
            #Comprobamos si hay cambio
            Gosub CHK_MODIF    #   RETORNA WFLGMOD=0 SI NO HAY CAMBIO
          Else
            Gosub READ_DATVCRORI
          Endif
          If WFLGMOD=0
            Gosub WRI_SII
            OKK=2
          Endif
        When "S":  # Recibidas
          # Comprobamos si existe en SII
          If [F:DVS]REGTYP<11
            WTYPENV=2
            WVCRLIN=1
          Else
            WTYPENV=6
            WVCRLIN=[F:DVS]REGTYP-10
          Endif
          Read [X025SI]X025SI0=[F:DVS]CPY;WTYPENV;[F:DVS]TYP;[F:DVS]NUM;WVCRLIN
          If fstat=[V]CST_AOK  and [F:DVS]VATTYP=1  #solo tratamos tipo 1
            WFLGMOD=1
            #Comprobamos si hay cambio
            Gosub CHK_MODIF    #   RETORNA WFLGMOD=0 SI NO HAY CAMBIO
          Else
            Gosub READ_DATVCRORI
          Endif
          If WFLGMOD=0
            Gosub WRI_SII
            OKK=2
          Endif
      Endcase
    Next
  Endif
Return

#------------------------------------------------------------------------------#
$READ_CPS
#  Local Char CRITMET(250)
  Local Char WBPRCRN(40), WBPRNAM(80), WBPR(20), WCRY(5),WCRN (40)
  Local Decimal WAMTCSH, WAMTORICAJ
  Local Integer I,J, WNCRN

  If clalev([F:CPS])=0: Local File CASHPAYSPA [CPS]: Endif
  If clalev([F:BPR])=0: Local File BPARTNER   [BPR]: Endif
  If clalev([F:SIV])=0: Local File SINVOICEV  [SIV]: Endif
  If clalev([F:X5W])=0: Local File XX025WCSH  [X5W]: Endif

  Gosub CALMET

  WTYPENV=7

  If WUPDATE=0
    Trbegin [X5W]
      For [X5W]
        Raz [F:X5W]
        Filter [CPS] Where ACCNUM(0)=[F:X5W]ACCNUM
        Read [CPS] First
        If fstat=[V]CST_AOK
          If [F:CPS]INVNUM<>""
            Read [SIV]SIV0=[F:CPS]INVNUM
            If fstat=[V]CST_AOK
              If dim([F:SIV]BPIEECNUM)>0
                If [F:SIV]BPIEECNUM<>""
                  [F:X5W]NIP    =[F:SIV]BPIEECNUM
                  [F:X5W]BPRNAM =[F:SIV]BPINAM #jcc
                Endif
              Endif
            Endif
          Endif
          If [F:X5W]NIP=""
            Read[BPR]BPR0=[F:CPS]BPRNUM
            If fstat=[V]CST_AOK
              [F:X5W]NIP=[F:BPR]CRN
            Endif
          Endif
          If [F:X5W]NIP="":  [F:X5W]NIP="SIN_NIF": Endif
          [F:X5W]IMPORTE=[F:CPS]AMOUNT
          [F:X5W]BPRNUM=[F:CPS]BPRNUM
          Rewrite [X5W]
        Endif
      Next
    Commit
  Endif

  Raz WBPRCRN

  For [X5W]X5W1
    If WBPRCRN <> [F:X5W]NIP  and WBPRCRN <>"" : Gosub CHK_WRI:  Raz WAMTCSH:  Endif
    WAMTCSH+=[F:X5W]IMPORTE
    WBPR=[F:X5W]BPRNUM
    WBPRCRN=[F:X5W]NIP
    WBPRNAM=[F:X5W]BPRNAM #jcc
    Read[BPR]BPR0=[F:X5W]BPRNUM
    If fstat=[V]CST_AOK
      If WBPRNAM="" #jcc
        WBPRNAM=[F:BPR]BPRNAM(0)
      Endif
      WCRY=[F:BPR]CRY
    Else
      Raz WBPRNAM, WCRY
    Endif
  Next

  If WBPRCRN <>"": Gosub CHK_WRI:  Raz WAMTCSH, WBPRCRN:  Endif

  Gosub MNG_CANCEL_CASH

  Trbegin [X5W]
     Delete [X5W] Where ACCNUM>=0
  Commit

  Close File [CPS], [BPR], [X5W], [SIV]
$NOTRAIT
Return

#------------------------------------------------------------------------------#
$CHK_WRI
  If WAMTCSH>=6000
    Gosub WRI_CASH
  Else
   ##buscar si cancelación
    Gosub CHK_PROFLG_CASH
  Endif

Return

#------------------------------------------------------------------------------#
$MNG_CANCEL_CASH
  If GXX025EXTAP=1
    Filter [X025SI] Where CPY=[M:XSII]CPY and TYPENV=7 and TYPANUAL="M" and year(DATOPE)=year([M:XSII]DATINI)
    For [F:X025SI]
      Read [X5W]X5W1=[F:X025SI]NIP
      If fstat<>[V]CST_AOK
        # Cancelación
        If [F:X025SI]STADOC=1
          # borramos registro
          Trbegin  [X025SI]
            Delete Curr
          Commit
        Endif
        If [F:X025SI]STADOC=2 and [F:X025SI]TYPCOM<3
          Gosub CHG_STATUS
        Endif
      Endif
    Next
  Endif
Return

#------------------------------------------------------------------------------#
$MNG_CANCEL
  Local Integer WDEL: WDEL=0
  Local Integer WTRT: WTRT=0
  Local Date WSTRDAT, WSTREND
  Local Decimal WAMTORICAJ

  If GXX025EXTAP=1
    Local Char  CRITCAN (250)  #mejora rendimiento

    WSTRDAT=[M:XSII]DATINI
    WSTREND=[M:XSII]DATEND

    If  val([M:XSII]DATINI)>val(GFECSII)
      WTRT=1
    Else
      If val([M:XSII]DATEND)>val(GFECSII)
        WSTRDAT=GFECSII+1
        WTRT=1
      Endif
    Endif

    If WTRT<>1 : Return: Endif

    CRITCAN="1=1"
    If [M:XSII]STAALL<>2      : CRITCAN -= ' & [F:X025SI]VCRSTA='+num$([M:XSII]VCRSTA)       : Endif
    If [M:XSII]ALLCOM<>2      : CRITCAN -= ' & [F:X025SI]TYPCOM='+num$([M:XSII]TYPCOM)       : Endif
    If [M:XSII]BPR<>""        : CRITCAN -= ' & [F:X025SI]BPR="'+[M:XSII]BPR+'"'              : Endif
    If [M:XSII]LOT<>""        : CRITCAN -= ' & [F:X025SI]LOTNUM="'+[M:XSII]LOT+'"'           : Endif
    If [M:XSII]VCRERRNUM<>""  : CRITCAN -= ' & [F:X025SI]VCRERRNUM="'+[M:XSII]VCRERRNUM+'"'  : Endif

    Local File DCLVATSPA [XYDVS]
#    Filter [X025SI] Where CPY=[M:XSII]CPY and TYPENV<=2 and DATOPE>=[M:XSII]DATINI and DATOPE<=[M:XSII]DATEND & evalue(CRITCAN)
    Filter [X025SI] Where CPY=[M:XSII]CPY and TYPENV<=2 and DATOPE>=WSTRDAT and DATOPE<=WSTREND & evalue(CRITCAN)
     #FIN mejora rendimiento
    For [F:X025SI]
      Filter [XYDVS]
        If [F:X025SI]TYPENV=1
        Read [XYDVS]DVS5="R";[F:X025SI]NIP;[F:X025SI]GTE;[F:X025SI]VCRNUM
        If fstat<>[V]CST_AOK
          Filter [XYDVS] Where CPY=[M:XSII]CPY and TAXTYP="R" and TYP=[F:X025SI]GTE and NUM=[F:X025SI]VCRNUM# and REGTYP<11
          If REGTYP<11
            Read [XYDVS] First
          Else
            WAMTORICAJ=[F:X025SI]AMTATI
            Read [XYDVS] First
          Endif
        Endif
      Elsif [F:X025SI]TYPENV=2
        Read [XYDVS]DVS5="S";[F:X025SI]NIP;[F:X025SI]GTE;[F:X025SI]VCRNUM
        If fstat<>[V]CST_AOK
          Filter [XYDVS] Where CPY=[M:XSII]CPY and TAXTYP="S" and TYP=[F:X025SI]GTE and NUM=[F:X025SI]VCRNUM # and REGTYP<11
          If REGTYP<11
            Read [XYDVS] First
          Else
            WAMTORICAJ=[F:X025SI]AMTATI
            Read [XYDVS] First
          Endif
        Endif
      Endif
      If fstat<>[V]CST_AOK
        WDEL=1
      Endif
      Gosub CHK_PROFLG
    Next
    Close File [XYDVS]
  Endif
Return

#------------------------------------------------------------------------------#
$CHK_PROFLG
  If [F:XYDVS]PROFLG=1 or WDEL=1
    If [F:X025SI]STADOC=1
      # borramos registro
      Trbegin [X025SI]
        Delete Curr
      Commit
    Endif
    If [F:X025SI]STADOC=2 and [F:X025SI]TYPCOM<3
      # pasarla a cancelada
      Gosub CHG_STATUS
    Endif
  Endif
  Raz WDEL
Return

#------------------------------------------------------------------------------#
$CHK_PROFLG_CASH
  Local Char WVCRNUM(60)
  If WBPRCRN="": WBPRCRN=[F:X5W]NIP: Endif
  WVCRNUM=WBPRCRN+"-"+num$(year([M:XSII]DATINI))+"-M"
  Read [X025SI]X025SI1=[M:XSII]CPY+"7"+WVCRNUM+"1"
  If fstat=[V]CST_AOK
    If [F:X025SI]STADOC=1
    # borramos registro
      Trbegin [X025SI]
        Delete Curr
      Commit
    Endif
    If [F:X025SI]STADOC=2 and [F:X025SI]TYPCOM<3
      # pasarla a cancelada
     Gosub CHG_STATUS
     Endif
  Endif
Return

#------------------------------------------------------------------------------#
$CHG_STATUS
  Trbegin [X025SI]
    If WAMTORICAJ<>0
      [F:X025SI]TYPCOM=1
      [F:X025SI]AMTATI=[F:X025SI]AMTATI*-1
      [F:X025SI]AMTATIORI=WAMTORICAJ
    Else
      [F:X025SI]TYPCOM=3
    Endif
    [F:X025SI]STADOC=1
    [F:X025SI]VCRSTA=1
    Raz [F:X025SI]VCRERRNUM, VCRERRDES, LOTNUM, TIMESTAMP
    Rewrite
  Commit
Return

#------------------------------------------------------------------------------#
$ERRBATCH
   Call ECR_TRACE(errmes$(errn)-num$(errl)-errm,1) From GESECRAN
End

#------------------------------------------------------------------------------#
$WRI_SII
  GOK = 1 : OKK=1
  Local Integer  NBREC, WRITEOK
  Local Char  WFATYP(2)
  WRITEOK=1
  AUXINT=1
  If WTYPCOM=0 : WTYPCOM=1:  Endif
  Filter [F:X025SI]

  Trbegin [F:X025SI]  # For write the new records
  Raz [F:X025SI]
  If [F:DVS]TAXTYP="R" and [F:DVS]ORIMOD<>2
    If !clalev([F:SIH]): Local File SINVOICE: Endif
    Read [F:SIH]SIH2=[F:DVS]TYP;[F:DVS]NUM
    If fstat<>[V]CST_AOK :AUXINT=0: Endif
  Endif

  If [F:DVS]REGTYP=4 : AUXINT=0  : Endif      ## Excluimos retenciones
  If [F:DVS]VATTYP=2 : AUXINT=0  : Endif      ## Excluimos recargos
  If [F:DVS]TAXTYP="S" and [F:DVS]REGTYP=1 : WTYPENV=2 : Endif      # Compras
  If [F:DVS]REGTYP>10
    If [F:DVS]TAXTYP="S": WTYPENV=6 Else WTYPENV=5: Endif
  Endif      # Cobros y pagos caja


  If WTYPENV=5 or WTYPENV=6   # excluimos registros de caja de facturas anteriores al 2017
    If year([F:DVS]BPRDAT)<2017: AUXINT=0: Endif
  Endif

  #Buscamos si rectificativa si es abono
  Raz [F:X025SI]TYPREC

  If [F:DVS]TAXTYP="S"
    Local File DCLVATSPA [XYDVS]
    If [F:DVS]INVTYP=2
      Filter [XYDVS] Where INVTYP=1 and BPRNUM=[F:DVS]BPRNUM and (BPRVCR=[F:DVS]BPRVCR & [F:DVS]BPRVCR<>"") and BPRDAT=[F:DVS]BPRDAT
      Read First
      If fstat=[V]CST_AOK
        AUXINT=0    ## No escribimos el abono
      Else
        [F:X025SI]TYPREC="I"    ## Es por diferencias
      Endif
    Else
      Filter [XYDVS] Where INVTYP=2 and BPRNUM=[F:DVS]BPRNUM and (BPRVCR=[F:DVS]BPRVCR & [F:DVS]BPRVCR<>"") and BPRDAT=[F:DVS]BPRDAT
      Read First
      If fstat=[V]CST_AOK
        [F:X025SI]TYPREC="S"    ## Es por sustitución
      Else
        [F:X025SI]TYPREC=""
      Endif
    Endif
    Close File [XYDVS]
  Else
    If [F:DVS]INVTYP=2
      [F:X025SI]TYPREC="I"    ## Es por diferencias siempre en Ventas
    Endif
  Endif


  ## Writting records
  If AUXINT=1
    If WTYPENV<>5 and WTYPENV<>6
      Read [X025SI]X025SI1=[F:DVS]CPY+num$(WTYPENV)+[F:DVS]TYP+[F:DVS]NUM+"1"
    Else
      Read [X025SI]X025SI1=[F:DVS]CPY+num$(WTYPENV)+[F:DVS]TYP+[F:DVS]NUM+num$([F:DVS]REGTYP-10)
    Endif
    If fstat<>[V]CST_AOK

      [F:X025SI]FLGSEL=2
      If WTYPENV=2 and [F:DVS]BPRVCR="": [F:X025SI]FLGSEL=1: Endif
      If WTYPENV=6 and [F:DVS]BPRVCR="": [F:X025SI]FLGSEL=1: Endif
      [F:X025SI]TYPENV=WTYPENV
      [F:X025SI]STADOC=1
      [F:X025SI]TYPCOM=WTYPCOM
      [F:X025SI]GTE=[F:DVS]TYP
      [F:X025SI]VCRNUM=[F:DVS]NUM
      If WTYPENV=5 or  WTYPENV=6
        [F:X025SI]VCRLIN=[F:DVS]REGTYP-10
      Else
        [F:X025SI]VCRLIN=1
      Endif
      [F:X025SI]CPY=[F:DVS]CPY
      [F:X025SI]FCY=[F:DVS]FCY
      [F:X025SI]DATOPE= [F:DVS]ACCDAT
      If [F:DVS]INVTYP=1
        [F:X025SI]VCRTYP=1
        If [F:DVS]TCKNUM>0 or [F:DVS]CODOPE="J": [F:X025SI]VCRTYP=2: Endif
        If [F:DVS]CODOPE="O": [F:X025SI]VCRTYP=8: Endif
        If [F:X025SI]TYPREC="S" and [F:X025SI]VCRTYP=2: [F:X025SI]VCRTYP=8: Endif
        If [F:X025SI]TYPREC="S" and [F:X025SI]VCRTYP=1
          Call PARAML([F:X025SI]CPY,"XX025ABTYP",WFATYP) From ADOVAL
          If val(WFATYP)<>0: [F:X025SI]VCRTYP=val(WFATYP): Else [F:X025SI]VCRTYP =6 Endif
        Endif
      Elsif [F:DVS]INVTYP=2
        Call PARAML([F:X025SI]CPY,"XX025ABTYP",WFATYP) From ADOVAL
        If val(WFATYP)<>0: [F:X025SI]VCRTYP=val(WFATYP): Else [F:X025SI]VCRTYP =6 Endif
        If [F:DVS]TCKNUM>0 or [F:DVS]CODOPE="J": [F:X025SI]VCRTYP=7: Endif
      Endif
      If [F:DVS]CODOPE="A" or [F:DVS]CODOPE="B": [F:X025SI]VCRTYP=9: Endif

      If [F:DVS]CODOPE="X" and [F:DVS]INVTYP=1: [F:X025SI]VCRTYP=11:  Endif


      [F:X025SI]BPR=[F:DVS]BPRNUM
      [F:X025SI]BPRNAM=[F:DVS]BPRNAM
      [F:X025SI]CRY=[F:DVS]CRY
      If WCRYORI<>"": [F:X025SI]CRY=WCRYORI: Endif
      [F:X025SI]CODOPE=[F:DVS]CODOPE
      [F:X025SI]NIP=[F:DVS]CRN

      If [F:DVS]SCDREF<>"" and [F:DVS]IMPORT=1
        Local File COMPANY [XCP]
        Read [XCP]CPY0=[M:XSII]CPY
        [F:X025SI]VCRTYP=10
        [F:X025SI]BPRVCR=[F:DVS]NUM
        [F:X025SI]DATOPE= [F:DVS]DCLDAT
        [F:X025SI]BPR=[F:XCP]CPY
        [F:X025SI]BPRNAM=[F:XCP]CPYNAM
        [F:X025SI]NIP=[F:XCP]CRN
        [F:X025SI]CRY=[F:XCP]CRY
        Close File [XCP]
      Else
        [F:X025SI]BPRVCR=[F:DVS]BPRVCR
      Endif

      [F:X025SI]AMTATI=WAMTATI+WRCG #añadimos recargo si lo hay

#      If [F:DVS]SCDREF<>"" and [F:DVS]IMPORT=0
#        Local Decimal WAMTGAS
#        Local File DCLVATSPA [XYDVS]
#        Filter [XYDVS] Where NUM=[F:DVS]NUM
#        For [XYDVS]
#          WAMTGAS+=[F:DVS]AMTNOTL+[F:DVS]AMTTAXL
#        Next
#        Close File [XYDVS]
#        [F:X025SI]AMTATI=WAMTGAS
#      Endif

      [F:X025SI]DKEY=[F:X025SI]CPY+num$([F:X025SI]TYPENV)+[F:X025SI]GTE+[F:X025SI]VCRNUM+num$([F:X025SI]VCRLIN)
      [F:X025SI]VCRSTA=1
      [F:X025SI]DATDVS=gdatetime$(func SUBADC.CNVSYR(func SUBADC.CNVSTP([F:DVS]BPRDAT, 0)))

      [F:X025SI]DATVCRORI=WDATVCRORI
      [F:X025SI]VCRERRNUM=""
      [F:X025SI]VCRERRDES=""
      [F:X025SI]FLGNIFREC=1
      GPOINT = "BEFWRISII":  Gosub ENTREE From EXEFNC
      Raz WCRYORI
      If WRITEOK
        Write [F:X025SI]
        If fstat : GOK=0 : Call FSTA("X025SI") From GLOCK : Endif
      Endif
    Elsif (WTYPENV=5 or WTYPENV=6) and [F:X025SI]BPRNAM<>[F:DVS]BPRNAM  #pte jcc
      [F:X025SI]BPRNAM=[F:DVS]BPRNAM
      Rewrite [F:X025SI]
    Endif
  Endif

  If GOK<0   : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

  Commit

  Raz [F:X025SI]  #, [F:X025SD]
Return

$WRI_CASH
  GOK = 1 : OKK=1
  Local Integer  NBREC, WTYPCOM, WRITEOK, WVCRLIN
  Local Char WCSHDOC(60)
  Local Decimal WAMTORI
  WRITEOK=1
  WTYPCOM=1
  WCSHDOC=WBPRCRN+"-"+num$(year([M:XSII]DATINI))+"-M"

  # updating previous records because if exist (modified)
  Read [X025SI]X025SI1=[M:XSII]CPY+num$(WTYPENV)+""+WCSHDOC+"1"
  If fstat=[V]CST_AOK
    If [F:X025SI]AMTATI<>0
      Gosub CHK_MODIF_CSH
    Endif
  Endif

  Trbegin [X025SI]
  AUXINT=1
  ## Writting records
  If AUXINT=1
    Read [X025SI]X025SI1=[M:XSII]CPY+num$(WTYPENV)+""+WCSHDOC+"1"
    If fstat=[V]CST_AOK
      #nothing to do
    Else
      [F:X025SI]FLGSEL=2
      [F:X025SI]TYPENV=WTYPENV
      [F:X025SI]STADOC=1
      [F:X025SI]TYPCOM=WTYPCOM
      [F:X025SI]GTE=""
      [F:X025SI]TYPANUAL="M"
      [F:X025SI]VCRNUM=WCSHDOC
      [F:X025SI]VCRLIN=1
      [F:X025SI]CPY=[M:XSII]CPY
#      [F:X025SI]FCY=[M:XSII]FCY  no disponible en metálico. Va por sopciedad
      [F:X025SI]VCRTYP =1
      [F:X025SI]BPR=WBPR
      [F:X025SI]BPRNAM=WBPRNAM
      [F:X025SI]TYPCOM=WTYPCOM
      [F:X025SI]CRY=WCRY
      [F:X025SI]NIP=WBPRCRN
      [F:X025SI]DATOPE= gdat$(31,12,year([M:XSII]DATINI))
      [F:X025SI]AMTATIORI=WAMTORI
      If [F:X025SI]AMTATIORI<>0
        [F:X025SI]AMTATI=[F:X025SI]AMTATIORI-WAMTCSH
        [F:X025SI]AMTATIORI=WAMTCSH
      Else
        [F:X025SI]AMTATI=WAMTCSH    # Amount in EUR
      Endif
      [F:X025SI]DKEY=[F:X025SI]CPY+num$([F:X025SI]TYPENV)+[F:X025SI]GTE+[F:X025SI]VCRNUM+num$([F:X025SI]VCRLIN)
      [F:X025SI]VCRSTA=1
#      [F:X025SI]DATDVS=datetime$
      [F:X025SI]VCRERRNUM=""
      [F:X025SI]VCRERRDES=""

      GPOINT = "BEFWRICSH":  Gosub ENTREE From EXEFNC

      If WRITEOK
        Write [F:X025SI]
        If fstat : GOK=0 : Call FSTA("X025SI") From GLOCK : Endif
      Endif
    Endif
  Endif

  If GOK<0   : Goto ROLL_TR1
  Elsif !GOK : Goto AB_TR1
  Endif

  Commit

  Raz [F:X025SI]
Return

#------------------------------------------------------------------------------#
$CHK_MODIF
  Local Integer WCHG, WORIMOD
  Raz WCHG
  If [F:DVS]REGTYP=4: Return: Endif

  If [M:XSII]BPR<>""       & [F:X025SI]BPR<>[M:XSII]BPR             : Return: Endif # MEJORA RENDIMEINTO
  If [M:XSII]VCRERRNUM<>"" & [F:X025SI]VCRERRNUM<>[M:XSII]VCRERRNUM : Return: Endif
  If [M:XSII]LOT<>""       & [F:X025SI]LOTNUM<>[M:XSII]LOT          : Return: Endif # MEJORA RENDIMEINTO

  If [F:DVS]CODOPE<>[F:X025SI]CODOPE |([F:DVS]BPRNAM(0)<>[F:X025SI]BPRNAM & [F:X025SI]VCRTYP<>10)|([F:X025SI]DATOPE<>[F:DVS]ACCDAT & [F:X025SI]VCRTYP<>10)
    WCHG=1
  Endif

  If WCHG=0
    #comprobar cambio importe con recargo
    If [F:X025SI]AMTATI <>WAMTATI+WRCG : WCHG=1: Endif
  Endif

  If WCHG=0 & len([F:DVS]CRN)>9 and [F:X025SI]VCRTYP<>10
    If [F:DVS]CRY<>[F:X025SI]CRY & len([F:DVS]CRN)<>len([F:X025SI]NIP)  & right$([F:DVS]CRN,len([F:DVS]CRN)-8)<>[F:X025SI]NIP
      WCHG=1
    Endif
  Endif
  If [F:X025SI]TYPCOM=3: WCHG=1: Endif
  If WCHG=1
    WFLGMOD=0
    If [F:X025SI]STADOC=2
      If [F:DVS]PROFLG=1
        WTYPCOM=3    # Cancelation
      Else
        WTYPCOM=2   # Modification
      Endif
      If [F:X025SI]VCRSTA=4 :WTYPCOM=1: Endif # Alta si Rechazada
      If [F:X025SI]TYPENV=5 or [F:X025SI]TYPENV=6:   WTYPCOM=1: Return:  Endif # sólo alta en cobros y pagos de caja pte jcc
    Elsif [F:X025SI]STADOC=1 and [F:X025SI]TYPCOM>1
       WTYPCOM=2
    Endif
    Trbegin [X025SI]
      Delete Curr
    Commit
    Gosub READ_DATVCRORI
  Endif

Return

#------------------------------------------------------------------------------#
$READ_DATVCRORI
  Local Char WRESGAS(1)
  # Reading the date from original document
  If [F:DVS]PROFLG=1 : WFLGMOD=1: Return : Endif

  WORIMOD=[F:DVS]ORIMOD
  If WORIMOD=3 and [F:DVS]TAXTYP="R": WORIMOD=5: Endif
  If WORIMOD=3 and [F:DVS]TAXTYP="S": WORIMOD=6: Endif

  Call PARAML([M:XSII]CPY,"XX025FGAS",WRESGAS) From ADOVAL
  If val(WRESGAS)=2 and [F:DVS]SCDREF=""
    WORIMOD=2
  Endif

  Case WORIMOD
    When 2: # Finantial
      Local File GACCENTRY [XGAC]
      Read [XGAC]HAE0=[F:DVS]TYP;[F:DVS]NUM
      If fstat=[V]CST_AOK| [F:XGAC]UPDDATTIM<>[F:X025SI]DATVCRORI
          WDATVCRORI=[F:XGAC]CREDATTIM
#          WCHG=1
#        Endif
#        If [F:X025SI]DATVCRORI=gdatetime$("0000-00-00T00:00:00Z")
      Endif
      Close File  [XGAC]
    When 5: # Sales
      Local File SINVOICE [XSIH]
      Read [XSIH]SIH2=[F:DVS]TYP;[F:DVS]NUM
      If fstat=[V]CST_AOK
#        If [F:X025SI]DATVCRORI=gdatetime$("0000-00-00T00:00:00Z") | [F:XSIH]UPDDATTIM<>[F:X025SI]DATVCRORI
          WDATVCRORI=[F:XSIH]CREDATTIM
          WCRYORI=[F:XSIH]CRY
#          WCHG=1
#        Endif
      Endif
      Close File  [XSIH]
    When 6: # Purchasing
      Local File PINVOICE [XPIH]
      If [F:DVS]IMPORT=1 and [F:DVS]SCDREF<>""
        Local Integer A,B
        Local Char WNUMDUA(40)
        A=1+len([F:DVS]TYP)
        B=1+len([F:DVS]VAT)
        WNUMDUA=seg$([F:DVS]INDLNK,A+1,len([F:DVS]INDLNK)-B)
        Read [XPIH]PIH2=[F:DVS]TYP;WNUMDUA
        If fstat=[V]CST_AOK
          WDATVCRORI=[F:XPIH]CREDATTIM
        Endif
      Else
        Read [XPIH]PIH2=[F:DVS]TYP;[F:DVS]NUM
        If fstat=[V]CST_AOK
#        If [F:X025SI]DATVCRORI=gdatetime$("0000-00-00T00:00:00Z") | [F:XPIH]UPDDATTIM<>[F:X025SI]DATVCRORI
          WDATVCRORI=[F:XPIH]CREDATTIM
#          WCHG=1
        Endif
      Endif
      Close File  [XPIH]
  Endcase
Return

#------------------------------------------------------------------------------#
$CHK_MODIF_CSH
  If [F:X025SI]AMTATI<>WAMTCSH | [F:X025SI]BPR<>[F:CPS]BPRNUM | [F:X025SI]BPRNAM<>WBPRNAM | [F:X025SI]NIP<>WBPRCRN
    If [F:X025SI]STADOC=2
      WTYPCOM=2
      WAMTORI=[F:X025SI]AMTATIORI
    Elsif [F:X025SI]STADOC=1
      WTYPCOM=1
    Endif
    AUXINT=1
    Trbegin [X025SI]
      Delete Curr
   Commit
  Else
    AUXINT=0
  Endif

Return

#------------------------------------------------------------------------------#
$CALMET        # Cash payment. Recovering ACCNUM to trait in READ_CPS
  Local Integer WUPDATE: WUPDATE=0
  Local Integer WTRAIT: WTRAIT=2
  Local Char CRITMET (255)

  WDATE=[M:XSII]DATINI

  If val(WDATE)=0: WDATE=date$: Endif

  WDAT1=gdat$(1,1,year(WDATE))
  WDAT2=gdat$(31,12,year(WDATE))

  If dim([F:CPS]CPY)>0: WUPDATE=1: Endif

  If WUPDATE=0 # versión no actualizada se mantine el cálculo anterior
    Local File PAYMENTH   [XYPYH]
    Local File PAYMENTD   [XYPYD]
    Local File PAYACCNUM  [XYPAN]
    Local File TABPAYTYP  [XYTPY]

    CRITMET-='[F:XYPYH]CPY= [M:XSII]CPY'
    If [M:XSII]FCY<>"": CRITMET-='& [F:XYPYH]FCY= [M:XSII]FCY': Endif

    CRITMET -= '& [F:XYPYH]ACCDAT>=['+format$(GFMD,WDAT1)+']'
    CRITMET -= '& [F:XYPYH]ACCDAT<=['+format$(GFMD,WDAT2)+']'

    If [M:XSII]BPR<>"": CRITMET-='& [F:XYPYH]BPR= [M:XSII]BPR' : Endif
    GPOINT = "AFTCRIMET":  Gosub ENTREE From EXEFNC

    If WTRAIT=2
    # Search for cash payment
      If [M:XSII]BPR=""
        Link [XYPYD] With [XYPYH]PYH0=[F:XYPYD]NUM, [XYTPY]TPY0=[F:XYPYH]PAYTYP As [PYHX] Order By Key KEY1=[XYPYH]BPR
      Else
        Link [XYPYD] With [XYPYH]PYH0=[F:XYPYD]NUM, [XYTPY]TPY0=[F:XYPYH]PAYTYP As [PYHX] Order By Key KEY1=[M:XSII]BPR
      Endif
      Filter [PYHX] Where year([F:XYPYH]ACCDAT)=year(WDATE) & [F:XYPYH]SNS=2 & [F:XYTPY]SPACSH=2 & evalue (CRITMET)

      Trbegin [X5W]
        For [PYHX]KEY1
          Filter [XYPAN] Where TYPNUM=3 and STA=3 and NUM=[F:PYHX]NUM and RVSACCNUM=0
          Read [XYPAN]PAN0 First
          Filter [XYPAN]
          If fstat=[V]CST_AOK
            [F:X5W]ACCNUM=[F:CPS]ACCNUM
            Write [X5W]
          Endif
        Next
      Commit
    Endif

    Close File [XYPYH], [XYPYD], [XYPAN], [XYTPY]

  Else   # WUPDATE=1 : Lectura en la nueva estructura actualizada

    CRITMET-='[F:CPS]CPY= [M:XSII]CPY'
    If [M:XSII]FCY<>"": CRITMET-='& [F:CPS]FCY= [M:XSII]FCY': Endif

    CRITMET -= '& [F:CPS]DATGAS>=['+format$(GFMD,WDAT1)+']'
    CRITMET -= '& [F:CPS]DATGAS<=['+format$(GFMD,WDAT2)+']'

    If [M:XSII]BPR<>"": CRITMET-='& [F:CPS]BPRNUM= [M:XSII]BPR' : Endif
    GPOINT = "AFTCRIMET":  Gosub ENTREE From EXEFNC

    If WTRAIT=2
      Trbegin [X5W]
        If [M:XSII]BPR=""
          Filter [CPS] Where evalue (CRITMET) Order By Key CPS2
        Else
          Filter [CPS] Where evalue (CRITMET)
        Endif
        For [CPS]
          Raz [F:X5W]
          [F:X5W]ACCNUM=[F:CPS]ACCNUM
          [F:X5W]LIN=[F:CPS]LIN
          If [F:CPS]INVNUM<>""
            Read [SIV]SIV0=[F:CPS]INVNUM
            If fstat=[V]CST_AOK
              If dim([F:SIV]BPIEECNUM)>0
                If [F:SIV]BPIEECNUM<>""
                  If left$([F:SIV]BPIEECNUM,2)="ES"
                    [F:X5W]NIP    =mid$([F:SIV]BPIEECNUM,3,9)
                  Else
                    [F:X5W]NIP    =[F:SIV]BPIEECNUM
                  Endif
                  [F:X5W]BPRNAM =[F:SIV]BPINAM
                Endif
              Endif
            Endif
          Endif
          If [F:X5W]NIP=""
            Read[BPR]BPR0=[F:CPS]BPRNUM
            If fstat=[V]CST_AOK
              [F:X5W]NIP=[F:BPR]CRN
            Endif
          Endif
          If [F:X5W]NIP="":  [F:X5W]NIP="SIN_NIF": Endif
          [F:X5W]IMPORTE=[F:CPS]AMOUNT
          [F:X5W]BPRNUM=[F:CPS]BPRNUM
          Write [X5W]
        Next
      Commit
    Endif
  Endif

  If WTRAIT=1: Goto NOTRAIT:  Endif

Return

#------------------------------------------------------------------------------#
$AB_TR1
Rollback
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto WRI_SII : Endif

Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla XX025SII) 12/01/2017 10:42:09 (ADMIN)
######################################################################################
Subprog AV_CPY(VALEUR)
Variable Char  VALEUR()
  If GUSRFCY(1)<>"\" and GNBAUZ=1
    If [M:XSII]FCY=""
       [M:XSII]FCY=GUSRFCY(1)
    Endif
    Read [F:FCY]FCY0=[M:XSII]FCY
    If fstat : Raz [F:FCY] : Endif
    VALEUR=[F:FCY]LEGCPY
    Diszo [M:XSII]CPY, FCY
  Endif
End

Subprog C_CPY(VALEUR)
Variable Char    VALEUR()
  Local Char   WVAL(1), WDAT(15)


  If VALEUR<>""
    Read [F:CPY]CPY0=VALEUR
    If fstat <>[V]CST_AOK: Raz [F:CPY]
    Else GCURLEG=[F:CPY]LEG
    Endif

    Call PARAML(VALEUR,"XX025EXTAP",WVAL) From ADOVAL
    GXX025EXTAP=val(WVAL)

    Call PARAML(VALEUR,"XX02METSII",WVAL) From ADOVAL
    GMETSII=val(WVAL)

    Call PARAM(VALEUR,"XX02FECSII",WDAT) From ADOVAL
    If WDAT<>"" : GFECSII = gdat$(WDAT) : Endif

    Call PARAML(VALEUR,"XX02TERDEC",WVAL) From ADOVAL
    If val(WVAL)=0 : WVAL="1": Endif

    [M:XSII]TERCPY="("+mess(val(WVAL),13240,1)+")"
    Affzo [M:XSII]TERCPY

 # If Site group, don´t select a site
    If [F:CPY]CPYLEGFLG<2 : mkstat=2 : End: Endif

  Endif
End

Subprog C_FCY(VALEUR)
Variable Char    VALEUR()
    If VALEUR <> ""
        If [F:FCY]FCY<>VALEUR
            Read [F:FCY]FCY0=VALEUR
            If fstat : Raz [F:FCY] : Endif
        Endif
        If [M:XSII]CPY<>[F:FCY]LEGCPY
            [M:XSII]CPY = [F:FCY]LEGCPY
            Affzo [M:XSII]CPY
        Endif
    Else
        Call CONTALLFCY([M:XSII]CPY) From CPTSUB
    Endif
End

##################################################
Subprog C_DATINI(VALEUR)
Variable Date VALEUR()

#  If VALEUR=[0/0/0] : End : Endif
#   If month(VALEUR)<>month([M:XSII]DATEND)
#     GMESSAGE=mess(32,7711,1) - num$([M:XSII]DATEND)  #mess(00032,07711,1) : Deben estar en el mismo mes.
#     mkstat=2
#   Endif

End

##################################################
Subprog C_DATEND(VALEUR)
Variable Date VALEUR()

  If VALEUR=[0/0/0] and [M:XSII]DATINI=[0/0/0] : End : Endif
  If VALEUR<[M:XSII]DATINI
    GMESSAGE=mess(99,177,1) - num$([M:XSII]DATINI)  # La fecha fin no debe ser inferior a la fecha inicio.
    mkstat=2
  Endif

  If month(VALEUR)<>month([M:XSII]DATINI)
    GMESSAGE=mess(32,7711,1) - num$([M:XSII]DATINI)  #mess(00032,07711,1) : Deben estar en el mismo mes.
    mkstat=2
  Endif

  If year(VALEUR)<>year([M:XSII]DATINI)
    GMESSAGE="Deben estar en el mismo año." - num$([M:XSII]DATINI)
    mkstat=2
  Endif

  If month(VALEUR)<>month([M:XSII]DATEND) # anulamos bloqueo y creamos nuevo
    If [M:XSII]CPY<>""
      BLOQUEO="X025SII~"+[M:XSII]CPY+"~"+num$(month([M:XSII]DATINI))+num$(year([M:XSII]DATINI))
      Unlock =BLOQUEO
      [M:XSII]DATINI=VALEUR
      Gosub CONTROLE From XX025SII
    Endif
  Endif


End

##################################################
Subprog C_BPR(VALEUR)
Variable Char VALEUR()

  If GXX025EXTAP=2: End: Endif ## Aplicación externa

  If VALEUR<>""
    Local File BPARTNER  [BPR]
    Read [BPR]BPR0=VALEUR
    If fstat<>[V]CST_AOK
      GMESSAGE=mess(1128,196,1) # Tercero no válido
      mkstat=2
    Endif
    Close File [BPR]
  Endif
  If VALEUR<>[M:XSII]BPR
    GMODCRI=1
  Endif
End

##################################################
Subprog S_BPR(VALEUR)
Variable Char  VALEUR()

  If GXX025EXTAP=2: End: Endif ## Aplicación externa

  Local File BPARTNER    [BPR]
  Local File BPCUSTOMER  [BPC]
  Local File BPSUPPLIER  [BPS]

  Link [BPR] With [BPC]BPC0=[F:BPR]BPRNUM, [BPS]BPS0=[F:BPR]BPRNUM As [BPRX] Order By Key KEY1=[BPR]BPRNUM

  Filter [BPRX] Where [F:BPC]BPCSTA=2 or [F:BPS]ENAFLG=2

  Choose [BPRX] Using
&  [F:BPR]BPRNUM Titled mess(2,76,1)
& ,[F:BPR]BPRNAM Titled mess(2,697,1)
& ,[F:BPR]CRN  Titled mess(4,697,1)
& Sized (80,240)
& Titled mess(8,31,1)

  If status<>7
    VALEUR = [F:BPR]BPRNUM
  Endif
  Close File [BPC] ,[BPS], [BPR]

End


