    [M:XSIIM]NIP(WNL)       =[F:YXSIM]NIP
    [M:XSIIM]VCRERRNUM(WNL) =[F:YXSIM]VCRERRNUM
    [M:XSIIM]TYPANUAL(WNL)  =[F:YXSIM]TYPANUAL
    [M:XSIIM]CLAVEOPE(WNL)  =[F:YXSIM]CLAVEOPE
    [M:XSIIM]VCRLIN(WNL)    =[F:YXSIM]VCRLIN
    WNL+=1
    If WNL=dim([M:XSIIM]FLGSEL): Break: Endif
  Next
  [M:XSIIM]NBLIGM=WNL
  Affzo [M:XSIIM]1-99
  Close File [YXSIM]
Return

######################################################################################
$RIN_MSK
  Case maskcou
    When "XX025SIILE"
      Raz [M:XSIIE]FLGSEL(NOL),GTE(NOL),VCRNUM(NOL),STADOC(NOL),VCRSTA(NOL),TYPCOM(NOL),DATOPE(NOL),AMTATI(NOL),CRY(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),VCRERRNUM(NOL),CUR(NOL)
      Affzo [M:XSIIE]1-99
    When "XX025SIILR"
      Raz [M:XSIIR]FLGSEL(NOL),GTE(NOL),VCRNUM(NOL),BPRVCR(NOL),STADOC(NOL),VCRSTA(NOL),TYPCOM(NOL),DATOPE(NOL), DATREGCON(NOL), AMTATI(NOL),CRY(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),VCRERRNUM(NOL)
      Raz [M:XSIIR]CUR(NOL)
      Affzo [M:XSIIR]1-99
    When "XX025SIILC"
      Raz [M:XSIIC]FLGSEL(NOL),STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL),VCRERRNUM(NOL)
      Affzo [M:XSIIC]1-99
    When "XX025SIILI"
      Raz [M:XSIII]FLGSEL(NOL),STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL),VCRERRNUM(NOL)
      Affzo [M:XSIII]1-99
    When "XX025SIILCA"
      Raz [M:XSIICA]FLGSEL(NOL),STADOC(NOL),BPRVCR(NOL),TYPCOM(NOL),VCRNUM(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL),VCRERRNUM(NOL)
      Affzo [M:XSIICA]1-99
    When "XX025SIILPA"
      Raz [M:XSIIPA]FLGSEL(NOL),GTE(NOL),VCRNUM(NOL),STADOC(NOL),VCRSTA(NOL),TYPCOM(NOL),DATOPE(NOL),AMTATI(NOL),CRY(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),VCRERRNUM(NOL),CUR(NOL)
      Affzo [M:XSIIPA]1-99
    When "XX025SIILM"
      Raz [M:XSIIM]FLGSEL(NOL),GTE(NOL),VCRNUM(NOL),STADOC(NOL),VCRSTA(NOL),TYPCOM(NOL),DATOPE(NOL),AMTATI(NOL),CRY(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),VCRERRNUM(NOL)
      Raz [M:XSIIM]TYPANUAL(NOL), CLAVEOPE(NOL): : Affzo [M:XSIIM]1-99
  Endcase
Return

######################################################################################
Subprog SELREG
  Local Integer YESNO, I, K
  WMSG="¿Quiere seleccionar todos los registros?"
  Call OUINON (WMSG, YESNO) From GESECRAN
  If YESNO = 2 : # 2 = YES
    For I=1 To 7
      Case I
        When 1:
          For K=0 To [M:XSIIE]NBLIG-1
            If [M:XSIIE]STADOC(K)=1: [M:XSIIE]FLGSEL(K)=2: Endif
          Next
          Affzo [M:XSIIE]1-99
        When 2:
          For K=0 To [M:XSIIR]NBLIGR-1
            If [M:XSIIR]STADOC(K)=1 and [M:XSIIR]BPRVCR(K)<>"" : [M:XSIIR]FLGSEL(K)=2
            Else [M:XSIIR]FLGSEL(K)=1
            Endif
          Next
          Affzo [M:XSIIR]1-99
        When 3:
          For K=0 To [M:XSIIC]NBLIGC-1
            If [M:XSIIC]STADOC(K)=1: [M:XSIIC]FLGSEL(K)=2: Endif
          Next
          Affzo [M:XSIIC]1-99
        When 4:
          For K=0 To [M:XSIII]NBLIGI-1
            If [M:XSIII]STADOC(K)=1: [M:XSIII]FLGSEL(K)=2: Endif
          Next
          Affzo [M:XSIII]1-99
        When 5:
          For K=0 To [M:XSIICA]NBLIGCA-1
            If [M:XSIICA]STADOC(K)=1: [M:XSIICA]FLGSEL(K)=2: Endif
          Next
          Affzo [M:XSIICA]1-99
        When 6:
          For K=0 To [M:XSIIPA]NBLIGPA-1
            If [M:XSIIPA]STADOC(K)=1 and [M:XSIIPA]BPRVCR(K)<>"" : [M:XSIIPA]FLGSEL(K)=2: Endif  #pta v6
          Next
          Affzo [M:XSIIPA]1-99
        When 7:
          For K=0 To [M:XSIIM]NBLIGM-1
            If [M:XSIIM]STADOC(K)=1: [M:XSIIM]FLGSEL(K)=2: Endif
          Next
          Affzo [M:XSIIM]1-99
      Endcase
    Next
  Endif
End

######################################################################################
Subprog DSELREG
  Local Integer YESNO, I, K
  WMSG="¿Quiere desmarcar todos los registros?"
  Call OUINON (WMSG, YESNO) From GESECRAN
  If YESNO = 2 : # 2 = YES
    For I=1 To 7
      Case I
        When 1:
          For K=0 To [M:XSIIE]NBLIG-1
            If [M:XSIIE]STADOC(K)=1: [M:XSIIE]FLGSEL(K)=1: Endif
          Next
          Affzo [M:XSIIE]1-99
        When 2:
          For K=0 To [M:XSIIR]NBLIGR-1
            If [M:XSIIR]STADOC(K)=1: [M:XSIIR]FLGSEL(K)=1: Endif
          Next
          Affzo [M:XSIIR]1-99
        When 3:
          For K=0 To [M:XSIIC]NBLIGC-1
            If [M:XSIIC]STADOC(K)=1: [M:XSIIC]FLGSEL(K)=1: Endif
          Next
          Affzo [M:XSIIC]1-99
        When 4:
          For K=0 To [M:XSIII]NBLIGI-1
            If [M:XSIII]STADOC(K)=1: [M:XSIII]FLGSEL(K)=1: Endif
          Next
          Affzo [M:XSIII]1-99
        When 5:
          For K=0 To [M:XSIICA]NBLIGCA-1
            If [M:XSIICA]STADOC(K)=1: [M:XSIICA]FLGSEL(K)=1: Endif
          Next
          Affzo [M:XSIICA]1-99
        When 6:
          For K=0 To [M:XSIIPA]NBLIGPA-1
            If [M:XSIIPA]STADOC(K)=1: [M:XSIIPA]FLGSEL(K)=1: Endif
          Next
          Affzo [M:XSIIPA]1-99
        When 7:
          For K=0 To [M:XSIIM]NBLIGM-1
            If [M:XSIIM]STADOC(K)=1: [M:XSIIM]FLGSEL(K)=1: Endif
          Next
          Affzo [M:XSIIM]1-99
      Endcase
    Next
  Endif
End


##################################################
Subprog NIFNOCEN
  Local Integer YESNO, I, K
  WMSG="¿Quiere reactivar los registros rechazados de los NIF de clientes no censados?"
  Call OUINON (WMSG, YESNO) From GESECRAN
  If YESNO = 2 : # 2 = YES
    Local File XX025SII [XX25SI]
    Trbegin  [XX25SI]
    For K=0 To [M:XSIIE]NBLIG-1
      If [M:XSIIE]VCRSTA(K)=4
        Case [M:XSIIE]VCRERRNUM(K)
          When "1116", "1117"
            If [M:XSIIE]CRY(K)="ES" and (val([M:XSIIE]NIP(K))>0 or mid$([M:XSIIE]NIP(K),1,1)='X' or mid$([M:XSIIE]NIP(K),1,1)='Y'
&             or mid$([M:XSIIE]NIP(K),1,1)='Z' or mid$([M:XSIIE]NIP(K),1,1)='M')
              [M:XSIIE]FLGSEL(K)=2
              [M:XSIIE]STADOC(K)=1
              [M:XSIIE]VCRSTA(K)=1
              [M:XSIIE]TYPCOM(K)=1
              [M:XSIIE]FLGNIFREC(K)=2
            Endif
        Endcase
        Read [XX25SI]X025SI1=[M:XSII]CPY+"1"+[M:XSIIE]GTE(K)+[M:XSIIE]VCRNUM(K)+"1"
        If fstat=[V]CST_AOK:
          [F:XX25SI]FLGSEL=[M:XSIIE]FLGSEL(K)
          [F:XX25SI]STADOC=[M:XSIIE]STADOC(K)
          [F:XX25SI]VCRSTA=[M:XSIIE]VCRSTA(K)
          [F:XX25SI]TYPCOM=[M:XSIIE]TYPCOM(K)
          [F:XX25SI]FLGNIFREC=[M:XSIIE]FLGNIFREC(K)
          Rewrite
        Endif
      Else
        [M:XSIIE]FLGNIFREC(K)=1
      Endif
    Next
    Affzo [M:XSIIE]1-99

    For K=0 To [M:XSIIM]NBLIGM-1
      If [M:XSIIM]VCRSTA(K)=4
        Case [M:XSIIM]VCRERRNUM(K)
          When "1116", "1117"
            If [M:XSIIM]CRY(K)="ES" and (val([M:XSIIM]NIP(K))>0 or mid$([M:XSIIM]NIP(K),1,1)='X' or mid$([M:XSIIM]NIP(K),1,1)='Y'
&             or mid$([M:XSIIE]NIP(K),1,1)='Z' or mid$([M:XSIIE]NIP(K),1,1)='M')
              [M:XSIIM]FLGSEL(K)=2
              [M:XSIIM]STADOC(K)=1
              [M:XSIIM]VCRSTA(K)=1
              [M:XSIIM]TYPCOM(K)=1
              [M:XSIIM]FLGNIFREC(K)=2
            Endif
        Endcase
        Read [XX25SI]X025SI1=[M:XSII]CPY+"1"+[M:XSIIM]GTE(K)+[M:XSIIM]VCRNUM(K)+"1"
        If fstat=[V]CST_AOK:
          [F:XX25SI]FLGSEL=[M:XSIIM]FLGSEL(K)
          [F:XX25SI]STADOC=[M:XSIIM]STADOC(K)
          [F:XX25SI]VCRSTA=[M:XSIIM]VCRSTA(K)
          [F:XX25SI]TYPCOM=[M:XSIIM]TYPCOM(K)
          [F:XX25SI]FLGNIFREC=[M:XSIIM]FLGNIFREC(K)
          Rewrite
        Endif
      Else
        [M:XSIIM]FLGNIFREC(K)=1
      Endif
    Next
    Commit
    Affzo [M:XSIIM]1-99

    Close File [XX25SI]
  Endif
End

##################################################
Subprog REACT_ALL
  Local Integer YESNO, I, K
  WMSG="¿Quiere reactivar los registros de este error?"
  Call OUINON (WMSG, YESNO) From GESECRAN
  If YESNO = 2 : # 2 = YES
    Local File XX025SII [XX25SI]
    Trbegin  [XX25SI]
    #Emitidas
    For K=0 To [M:XSIIE]NBLIG-1
      If [M:XSIIE]VCRERRNUM(K)=[M:XSII]VCRERRNUM
        Raz [M:XSIIE]VCRERRNUM(K), VCRERRDES(K)
        [M:XSIIE]FLGSEL(K)=2
        [M:XSIIE]STADOC(K)=1
        [M:XSIIE]FLGNIFREC=1
        If [M:XSIIE]VCRSTA(K)=3
          [M:XSIIE]TYPCOM(K)=2
        Else
          [M:XSIIE]TYPCOM(K)=1
        Endif
        [M:XSIIE]VCRSTA(K)=1
        Read [XX25SI]X025SI1=[M:XSII]CPY+"1"+[M:XSIIE]GTE(K)+[M:XSIIE]VCRNUM(K)+"1"
        If fstat=[V]CST_AOK
          Raz [F:XX25SI]VCRERRNUM, VCRERRDES
          [F:XX25SI]FLGSEL=[M:XSIIE]FLGSEL(K)
          [F:XX25SI]STADOC=[M:XSIIE]STADOC(K)
          [F:XX25SI]VCRSTA=[M:XSIIE]VCRSTA(K)
          [F:XX25SI]TYPCOM=[M:XSIIE]TYPCOM(K)
          Rewrite
        Endif
      Endif
    Next
    Affzo [M:XSIIE]1-99

    #Recibidas
    For K=0 To [M:XSIIR]NBLIGR-1
      If [M:XSIIR]VCRERRNUM(K)=[M:XSII]VCRERRNUM
        Raz [M:XSIIR]VCRERRNUM(K), VCRERRDES(K)
        [M:XSIIR]FLGSEL(K)=2
        [M:XSIIR]STADOC(K)=1
        If [M:XSIIR]VCRSTA(K)=3
          [M:XSIIR]TYPCOM(K)=2
        Else
          [M:XSIIR]TYPCOM(K)=1
        Endif
        [M:XSIIR]VCRSTA(K)=1
        Read [XX25SI]X025SI1=[M:XSII]CPY+"2"+[M:XSIIR]GTE(K)+[M:XSIIR]VCRNUM(K)+"1"
        If fstat=[V]CST_AOK
          Raz [F:XX25SI]VCRERRNUM, VCRERRDES
          [F:XX25SI]FLGSEL=[M:XSIIR]FLGSEL(K)
          [F:XX25SI]STADOC=[M:XSIIR]STADOC(K)
          [F:XX25SI]VCRSTA=[M:XSIIR]VCRSTA(K)
          [F:XX25SI]TYPCOM=[M:XSIIR]TYPCOM(K)
          Rewrite
        Endif
      Endif
    Next
    Affzo [M:XSIIR]1-99

    #Operaciones CEE
    For K=0 To [M:XSIIC]NBLIGC-1
      If [M:XSIIC]VCRERRNUM(K)=[M:XSII]VCRERRNUM
        Raz [M:XSIIC]VCRERRNUM(K), VCRERRDES(K)
        [M:XSIIC]FLGSEL(K)=2
        [M:XSIIC]STADOC(K)=1
        If [M:XSIIC]VCRSTA(K)=3
          [M:XSIIC]TYPCOM(K)=2
        Else
          [M:XSIIC]TYPCOM(K)=1
        Endif
        [M:XSIIC]VCRSTA(K)=1
        Read [XX25SI]X025SI1=[M:XSII]CPY+"3"+[M:XSIIC]GTE(K)+[M:XSIIC]VCRNUM(K)+"1"
        If fstat=[V]CST_AOK
          Raz [F:XX25SI]VCRERRNUM, VCRERRDES
          [F:XX25SI]FLGSEL=[M:XSIIC]FLGSEL(K)
          [F:XX25SI]STADOC=[M:XSIIC]STADOC(K)
          [F:XX25SI]VCRSTA=[M:XSIIC]VCRSTA(K)
          [F:XX25SI]TYPCOM=[M:XSIIC]TYPCOM(K)
          Rewrite
        Endif
      Endif
    Next
    Affzo [M:XSIIC]1-99

    #Inmovilizado
    For K=0 To [M:XSIII]NBLIGI-1
      If [M:XSIII]VCRERRNUM(K)=[M:XSII]VCRERRNUM
        Raz [M:XSIII]VCRERRNUM(K), VCRERRDES(K)
        [M:XSIII]FLGSEL(K)=2
        [M:XSIII]STADOC(K)=1
        If [M:XSIII]VCRSTA(K)=3
          [M:XSIII]TYPCOM(K)=2
        Else
          [M:XSIII]TYPCOM(K)=1
        Endif
        [M:XSIII]VCRSTA(K)=1
        Read [XX25SI]X025SI1=[M:XSII]CPY+"4"+[M:XSIII]GTE(K)+[M:XSIII]VCRNUM(K)+"1"
        If fstat=[V]CST_AOK
          Raz [F:XX25SI]VCRERRNUM, VCRERRDES
          [F:XX25SI]FLGSEL=[M:XSIII]FLGSEL(K)
          [F:XX25SI]STADOC=[M:XSIII]STADOC(K)
          [F:XX25SI]VCRSTA=[M:XSIII]VCRSTA(K)
          [F:XX25SI]TYPCOM=[M:XSIII]TYPCOM(K)
          Rewrite
        Endif
      Endif
    Next
    Affzo [M:XSIII]1-99

    #Cobros caja
    For K=0 To [M:XSIICA]NBLIGCA-1
      If [M:XSIICA]VCRERRNUM(K)=[M:XSII]VCRERRNUM
        Raz [M:XSIICA]VCRERRNUM(K), VCRERRDES(K)
        [M:XSIICA]FLGSEL(K)=2
        [M:XSIICA]STADOC(K)=1
        If [M:XSIICA]VCRSTA(K)=3
          [M:XSIICA]TYPCOM(K)=2
        Else
          [M:XSIICA]TYPCOM(K)=1
        Endif
        [M:XSIICA]VCRSTA(K)=1
        Read [XX25SI]X025SI1=[M:XSII]CPY+"5"+[M:XSIICA]GTE(K)+[M:XSIICA]VCRNUM(K)+[M:XSIICA]VCRLIN(K)
        If fstat=[V]CST_AOK
          Raz [F:XX25SI]VCRERRNUM, VCRERRDES
          [F:XX25SI]FLGSEL=[M:XSIICA]FLGSEL(K)
          [F:XX25SI]STADOC=[M:XSIICA]STADOC(K)
          [F:XX25SI]VCRSTA=[M:XSIICA]VCRSTA(K)
          [F:XX25SI]TYPCOM=[M:XSIICA]TYPCOM(K)
          Rewrite
        Endif
      Endif
    Next
    Affzo [M:XSIICA]1-99

    #Pagos caja
    For K=0 To [M:XSIIPA]NBLIGPA-1
      If [M:XSIIPA]VCRERRNUM(K)=[M:XSII]VCRERRNUM
        Raz [M:XSIIPA]VCRERRNUM(K), VCRERRDES(K)
        [M:XSIIPA]FLGSEL(K)=2
        [M:XSIIPA]STADOC(K)=1
        If [M:XSIIPA]VCRSTA(K)=3
          [M:XSIIPA]TYPCOM(K)=2
        Else
          [M:XSIIPA]TYPCOM(K)=1
        Endif
        [M:XSIIPA]VCRSTA(K)=1
        Read [XX25SI]X025SI1=[M:XSII]CPY+"6"+[M:XSIIPA]GTE(K)+[M:XSIIPA]VCRNUM(K)+[M:XSIIPA]VCRLIN(K)
        If fstat=[V]CST_AOK
          Raz [F:XX25SI]VCRERRNUM, VCRERRDES
          [F:XX25SI]FLGSEL=[M:XSIIPA]FLGSEL(K)
          [F:XX25SI]STADOC=[M:XSIIPA]STADOC(K)
          [F:XX25SI]VCRSTA=[M:XSIIPA]VCRSTA(K)
          [F:XX25SI]TYPCOM=[M:XSIIPA]TYPCOM(K)
          Rewrite
        Endif
      Endif
    Next
    Affzo [M:XSIIPA]1-99

    #Operaciones anuales
    For K=0 To [M:XSIIM]NBLIGM-1
      If [M:XSIIM]VCRERRNUM(K)=[M:XSII]VCRERRNUM
        Raz [M:XSIIM]VCRERRNUM(K), VCRERRDES(K)
        [M:XSIIM]FLGSEL(K)=2
        [M:XSIIM]STADOC(K)=1
        [M:XSIIM]FLGNIFREC=1
        If [M:XSIIM]VCRSTA(K)=3
          [M:XSIIM]TYPCOM(K)=2
        Else
          [M:XSIIM]TYPCOM(K)=1
        Endif
        [M:XSIIM]VCRSTA(K)=1
        Read [XX25SI]X025SI1=[M:XSII]CPY+"7"+[M:XSIIM]GTE(K)+[M:XSIIM]VCRNUM(K)+"1"
        If fstat=[V]CST_AOK
          Raz [F:XX25SI]VCRERRNUM, VCRERRDES
          [F:XX25SI]FLGSEL=[M:XSIIM]FLGSEL(K)
          [F:XX25SI]STADOC=[M:XSIIM]STADOC(K)
          [F:XX25SI]VCRSTA=[M:XSIIM]VCRSTA(K)
          [F:XX25SI]TYPCOM=[M:XSIIM]TYPCOM(K)
          Rewrite
        Endif
      Endif
    Next
    Affzo [M:XSIIM]1-99

    Commit
    Close File [XX25SI]
  Endif
End

######################################################################################
$REV_CLAVEOPEMET
  Local Char WNUM(60)
  Local File XX025SII [XYSII]

  WNUM=WNIP+"-"+num$(year([M:XSII]DATINI))+"-"+[M:XSIIM]TYPANUAL(NOL)+[M:XSIIM]CLAVEOPE(NOL)
  Read [XYSII]X025SI1=[M:XSII]CPY+"7"+WNUM+"1"
  If fstat=[V]CST_AOK: J=1: Endif

  Close File [XYSII]

Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla XX025SIILE) 25/01/2017 15:15:49 (ADMIN)
######################################################################################
Subprog IB_NBLIG
  Local Integer NOL : NOL = nolign-1
  GBOUT1=mess(145,117,1)
  GBOUT2="Detalle del error"
  Case maskcou
    When "XX025SIILE"
      If [M:XSIIE]VCRNUM(NOL)="" : Raz GBOUT1, GBOUT2: Endif
      If [M:XSIIE]VCRERRNUM(NOL)="" : Raz GBOUT2: Endif
      If [M:XSIIE]STADOC(NOL)<>1 and [M:XSIIE]VCRNUM(NOL)<>"": Grizo [M:XSIIE]FLGSEL(NOL) Endif
#      If [M:XSIIE]VCRSTA(NOL)=2: Raz GBOUT3: Endif
    When "XX025SIILR"
      If [M:XSIIR]VCRNUM(NOL)="" : Raz GBOUT1, GBOUT2: Endif
      If [M:XSIIR]VCRERRNUM(NOL)="" : Raz GBOUT2: Endif
      If [M:XSIIR]STADOC(NOL)<>1 and [M:XSIIR]VCRNUM(NOL)<>"": Grizo [M:XSIIR]FLGSEL(NOL) Endif
#      If [M:XSIIR]VCRSTA(NOL)=2: Raz GBOUT3: Endif
    When "XX025SIILC"
      If [M:XSIIC]VCRNUM(NOL)="":  Raz GBOUT1, GBOUT2, GBOUT3
        Actzo [M:XSIIC]GTE(NOL): Actzo [M:XSIIC]VCRNUM(NOL)
        Affzo [M:XSIIC]GTE(NOL): Affzo [M:XSIIC]VCRNUM(NOL)
      Endif
      If [M:XSIIC]GTE(NOL)="": Raz GBOUT1: Endif
      If [M:XSIIC]VCRERRNUM(NOL)="" : Raz GBOUT2: Endif
      If [M:XSIIC]STADOC(NOL)<>1 and [M:XSIIC]VCRNUM(NOL)<>"": Grizo [M:XSIIC]FLGSEL(NOL), GTE(NOL), VCRNUM(NOL): Endif
#      If [M:XSIIC]VCRSTA(NOL)=2: Raz GBOUT4: Endif
    When "XX025SIILI"
      If [M:XSIII]VCRNUM(NOL)=""  Raz GBOUT1, GBOUT2, GBOUT3
        Actzo [M:XSIII]GTE(NOL): Actzo [M:XSIII]VCRNUM(NOL)
        Affzo [M:XSIII]GTE(NOL): Affzo [M:XSIII]VCRNUM(NOL)
      Endif
      If [M:XSIII]VCRERRNUM(NOL)="" : Raz GBOUT2: Endif
      If [M:XSIII]STADOC(NOL)<>1 and GXX025EXTAP=1 and [M:XSIII]VCRNUM(NOL)<>"": Grizo [M:XSIII]FLGSEL(NOL),GTE(NOL), VCRNUM(NOL): Endif
#      If [M:XSIII]VCRSTA(NOL)=2: Raz GBOUT4:Endif
    When "XX025SIILCA"
      If [M:XSIICA]VCRNUM(NOL)="" : Raz GBOUT1, GBOUT2: Endif
      If [M:XSIICA]VCRERRNUM(NOL)="" : Raz GBOUT2: Endif
      If [M:XSIICA]STADOC(NOL)<>1 and [M:XSIICA]VCRNUM(NOL)<>"": Grizo [M:XSIICA]FLGSEL(NOL) Endif
#      If [M:XSIICA]VCRSTA(NOL)=2: Raz GBOUT3: Endif
    When "XX025SIILPA"
      If [M:XSIIPA]VCRNUM(NOL)="" : Raz GBOUT1, GBOUT2: Endif
      If [M:XSIIPA]VCRERRNUM(NOL)="" : Raz GBOUT2: Endif
      If [M:XSIIPA]STADOC(NOL)<>1 and [M:XSIIPA]VCRNUM(NOL)<>"": Grizo [M:XSIIPA]FLGSEL(NOL) Endif
#      If [M:XSIIPA]VCRSTA(NOL)=2: Raz GBOUT3: Endif
    When "XX025SIILM"
      Raz GBOUT1
      If [M:XSIIM]VCRERRNUM(NOL)="" : Raz GBOUT2: Endif
      If [M:XSIIM]STADOC(NOL)<>1 and [M:XSIIM]VCRNUM(NOL)<>"": Grizo [M:XSIIM]FLGSEL(NOL) Endif
#      If [M:XSIIM]VCRSTA(NOL)=2: Raz GBOUT3: Endif
      If GXX025EXTAP=2 and [M:XSIIM]VCRERRNUM(nolign-1)="" and [M:XSIIM]NBLIGM=0
        Grizo [M:XSIIM]NBLIGM
      Endif
  Endcase
  If GXX025EXTAP=2: Raz GBOUT1: Endif
End

##################################################
Subprog IB2_NBLIG
  Local Integer NOL : NOL = nolign-1
  Local Char SOC(GLONCPY)
  Local Char    PARMSK(250)(1..20), SAVACT(20)
  Global Integer NL: NL=NOL

  SAVACT = GACTION : GACTION = "XX025SIERR"
  NL=NOL
  Call TRAITE_CHAR(SOC,PARMSK,"","XX025SIERR","XX025SIERR",4,"") From GTRAITE
  GACTION = SAVACT
  Raz NL
End

##################################################
Subprog IB3_NBLIGC
  Local Integer NOL : NOL = nolign-1
  If GXX025EXTAP=2
    Grizo [M:XSIIC]FLGSEL(NOL),STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Affzo [M:XSIIC]1-99: End
  Endif

  If [M:XSIIC]VCRNUM(NOL)<>"" and [M:XSIIC]STADOC(NOL)=1
    Local Char SOC(GLONCPY)
    Local Char    PARMSK(250)(1..20), SAVACT(20)
    Global Integer NL: NL=NOL

    SAVACT = GACTION : GACTION = "XX025SICEE"
    NL=NOL
    Call TRAITE_CHAR(SOC,PARMSK,"","XX025SICEE","XX025SICEE",4,"") From GTRAITE
    GACTION = SAVACT

    Raz NL
  Endif

End

##################################################
Subprog IB4_NBLIGI
  Local Integer NOL : NOL = nolign-1
  If GXX025EXTAP=2
    Grizo [M:XSIII]FLGSEL(NOL),STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Affzo [M:XSIII]1-99: End
  Endif
  If [M:XSIII]VCRNUM(NOL)<>"" and [M:XSIII]STADOC(NOL)=1
    Local Char SOC(GLONCPY)
    Local Char    PARMSK(250)(1..20), SAVACT(20)
    Global Integer NL: NL=NOL

    SAVACT = GACTION : GACTION = "XX025SIINM"
    NL=NOL
    Call TRAITE_CHAR(SOC,PARMSK,"","XX025SIINM","XX025SIINM",4,"") From GTRAITE
    GACTION = SAVACT

    Raz NL
   Else : Raz GBOUT3
   Endif

End

##################################################
Subprog IB5_NBLIG

  Local Integer WCHG, NOL : NOL = nolign-1
  Local Char SOC(GLONCPY)
