  Raz NL

End

##################################################
Subprog AVANT_MET

Local Integer NOL: NOL=nolign-1

  If GXX025EXTAP=2
    Grizo  [M:XSIIM]STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Grizo  [M:XSIIM]DATOPE(NOL), VCRTYP(NOL),CLAVEOPE(NOL)
    If [M:XSIIM]AMTATI(NOL)<>0
      Grizo [M:XSIIM]TYPANUAL(NOL)
    Else
      Affzo [M:XSIIM]TYPANUAL(NOL)
    Endif
    Affzo [M:XSIIM]1-99: End
  Endif

  If [M:XSIIM]TYPANUAL(NOL)="M"
    Grizo  [M:XSIIM]STADOC(NOL),TYPCOM(NOL),TYPANUAL(NOL),VCRNUM(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Grizo  [M:XSIIM]DATOPE(NOL), VCRTYP(NOL),CLAVEOPE(NOL)
  Else
    If [M:XSIIM]VCRNUM(NOL)=""
      [M:XSIIM]FLGSEL(NOL)=2
      [M:XSIIM]DATOPE(NOL)= gdat$(31,12,year([M:XSII]DATINI))
      [M:XSIIM]TYPANUAL(NOL)="S":   [M:XSIIM]CLAVEOPE(NOL)="A"
      [M:XSIIM]VCRLIN(NOL)=1
      Actzo  [M:XSIIM]1-99
    Elsif [M:XSIIM]STADOC(NOL)=1 and [M:XSIIM]TYPCOM(NOL)=2
      Grizo  [M:XSIIM]STADOC(NOL),TYPCOM(NOL),TYPANUAL(NOL),VCRNUM(NOL),DATOPE(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
      Grizo  [M:XSIIM]DATOPE(NOL), VCRTYP(NOL),CLAVEOPE(NOL)
#      Actzo  [M:XSIIM]FLGSEL(NOL), A
    Endif

  Endif
  If [M:XSIIM]STADOC(NOL)>1
    Grizo [M:XSIIM]FLGSEL(NOL)
  Else
    Actzo [M:XSIIM]FLGSEL(NOL)
  Endif
  Affzo [M:XSIIM]1-99
End

##################################################
Subprog APRES_MET
  Local Integer NOL: NOL=nolign-1
  Local Char WMSG(250)
  Local Char WMAN(2): WMAN="00"

  If GXX025EXTAP=2:End:Endif
  If [M:XSIIM]TYPANUAL(NOL)<>"M"
    If [M:XSIIM]STADOC(NOL)=1 and [M:XSIIM]VCRNUM(NOL)<>""
      Local File XX025SII [XYSII]
      Readlock [F:XYSII]X025SI0 = [M:XSII]CPY;7;[M:XSIIM]GTE(NOL);[M:XSIIM]VCRNUM(NOL);1
      If fstat=[V]CST_AOK
        Trbegin [F:XYSII]
        #borramos registro anterior
          Delete Curr
        Commit
      Endif

      Trbegin [F:XYSII]
        # creamos el nuevo tipo 7
        [F:XYSII]FLGSEL=[M:XSIIM]FLGSEL(NOL)
        [F:XYSII]CPY=[M:XSII]CPY
        [F:XYSII]STADOC=1
        [F:XYSII]TYPENV=7
        [F:XYSII]TYPCOM=[M:XSIIM]TYPCOM(NOL)
        [F:XYSII]GTE   =[M:XSIIM]GTE(NOL)
        [F:XYSII]VCRNUM=[M:XSIIM]VCRNUM(NOL)
        [F:XYSII]VCRLIN=1
        [F:XYSII]VCRSTA=1
        [F:XYSII]DATOPE=[M:XSIIM]DATOPE(NOL)
        [F:XYSII]BPR   =[M:XSIIM]BPR(NOL)
        [F:XYSII]AMTATI=[M:XSIIM]AMTATI(NOL)
        [F:XYSII]BPRNAM=[M:XSIIM]BPRNAM(NOL)
        [F:XYSII]NIP   =[M:XSIIM]NIP(NOL)
        [F:XYSII]CRY   =[M:XSIIM]CRY(NOL)
        [F:XYSII]DKEY  =[F:XYSII]CPY+num$([F:XYSII]TYPENV)+[F:XYSII]GTE+[F:XYSII]VCRNUM+num$([F:XYSII]VCRLIN)
        [F:XYSII]TYPANUAL=[M:XSIIM]TYPANUAL(NOL)
        [F:XYSII]CLAVEOPE=[M:XSIIM]CLAVEOPE(NOL)
        Write
      Commit
      Close File [XYSII]
    Endif
  Endif

End

##################################################
Subprog AVANT_CEE
Local Integer NOL: NOL=nolign-1

  If GXX025EXTAP=2 and [M:XSIIC]VCRNUM(NOL)<>""
    Grizo  [M:XSIIC]VCRNUM(NOL), GTE(NOL),STADOC(NOL),TYPCOM(NOL),BPRVCR(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Grizo  [M:XSIIC]DATOPE(NOL),BPRVCR(NOL), TYPOPE(NOL), CLAVDEC(NOL), VCRTYP(NOL)
    End
  Else
    Actzo[M:XSIIC]VCRNUM(NOL)
  Endif

  If [M:XSIIC]STADOC(NOL)>1
    Grizo  [M:XSIIC]FLGSEL(NOL),GTE(NOL),STADOC(NOL),TYPCOM(NOL),BPRVCR(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Grizo  [M:XSIIC]DATOPE(NOL),BPRVCR(NOL), TYPOPE(NOL), CLAVDEC(NOL), VCRTYP(NOL)
  Else
    Actzo  [M:XSIIC]FLGSEL(NOL),GTE(NOL),STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),BPRVCR(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Actzo  [M:XSIIC]DATOPE(NOL),BPRVCR(NOL), TYPOPE(NOL), CLAVDEC(NOL), VCRTYP(NOL)
    [M:XSIIC]VCRLIN(NOL)=1
  Endif

  Affzo [M:XSIIC]1-99
End

##################################################
Subprog APRES_CEE
Local Integer NOL: NOL=nolign-1

  If GXX025EXTAP=2 :End: Endif
  Local Char WMSG(250)
  If [M:XSIIC]STADOC(NOL)=1 and [M:XSIIC]VCRNUM(NOL)<>""
    Local File XX025SII [XYSII]
    If  [M:XSIIC]GTE(NOL)=""
      Readlock [F:XYSII]X025SI0 = [M:XSII]CPY;3;[M:XSIIC]GTE(NOL);[M:XSIIC]VCRNUM(NOL);1
      If fstat=[V]CST_AOK
        Trbegin [F:XYSII]
          #borramos registro anterior
          Delete Curr
        Commit
      Endif
      Trbegin [F:XYSII]
        # creamos el nuevo tipo 3
        [F:XYSII]FLGSEL=[M:XSIIC]FLGSEL(NOL)
        [F:XYSII]CPY=[M:XSII]CPY
        [F:XYSII]STADOC=1
        [F:XYSII]TYPENV=3
        [F:XYSII]TYPCOM=1
        [F:XYSII]GTE   =[M:XSIIC]GTE(NOL)
        [F:XYSII]VCRNUM=[M:XSIIC]VCRNUM(NOL)
        [F:XYSII]VCRLIN=1
        [F:XYSII]VCRSTA=1
        [F:XYSII]DATOPE=[M:XSIIC]DATOPE(NOL)
        [F:XYSII]BPRVCR=[M:XSIIC]BPRVCR(NOL)
        [F:XYSII]BPR   =[M:XSIIC]BPR(NOL)
        [F:XYSII]BPRNAM=[M:XSIIC]BPRNAM(NOL)
        [F:XYSII]NIP   =[M:XSIIC]NIP(NOL)
        [F:XYSII]CRY   =[M:XSIIC]CRY(NOL)
        [F:XYSII]TYPREC=[M:XSIIC]TYPREC(NOL)
        [F:XYSII]DKEY  =[F:XYSII]CPY+num$([F:XYSII]TYPENV)+[F:XYSII]GTE+[F:XYSII]VCRNUM+num$([F:XYSII]VCRLIN)
        [F:XYSII]TYPOPE=[M:XSIIC]TYPOPE(NOL)
        [F:XYSII]CLAVDEC    =[M:XSIIC]CLAVDEC(NOL)
        [F:XYSII]ESTMIEMBRO =[M:XSIIC]ESTMIEMBRO(NOL)
        [F:XYSII]DESBIENES  =[M:XSIIC]DESBIENES(NOL)
        [F:XYSII]DIRECOPE   =[M:XSIIC]DIRECOPE(NOL)
        [F:XYSII]PLAZOOPE   =[M:XSIIC]PLAZOOPE(NOL)
        [F:XYSII]FACDOC     =[M:XSIIC]FACDOC(NOL)
        Write
      Commit
    Endif
    Close File [XYSII]
    If [M:XSIIC]ESTMIEMBRO(NOL) ="" or [M:XSIIC]DESBIENES(NOL) ="" or [M:XSIIC]DIRECOPE(NOL)=""
      Call IB3_NBLIGC
    Endif
  Endif

End

##################################################
Subprog AVANT_INM
Local Integer NOL: NOL=nolign-1
#  If GXX025EXTAP=2
#    Grizo  [M:XSIII]FLGSEL(NOL),GTE(NOL),STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),BPRVCR(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL), VCRTYP(NOL)
#    Affzo [M:XSIII]1-99: End
#  Endif

  If GXX025EXTAP=2 and [M:XSIII]VCRNUM(NOL)<>""
    Grizo  [M:XSIII]VCRNUM(NOL),FLGSEL(NOL),GTE(NOL),STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),BPRVCR(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Grizo  [M:XSIII]BPRVCR(NOL),VCRTYP(NOL)
    End
  Else
    Actzo[M:XSIII]VCRNUM(NOL)
  Endif

  If [M:XSIII]STADOC(NOL)>1
    Grizo  [M:XSIII]FLGSEL(NOL),GTE(NOL),STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),BPRVCR(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Grizo  [M:XSIII]BPRVCR(NOL),VCRTYP(NOL)
  Else
    Actzo  [M:XSIII]FLGSEL(NOL),GTE(NOL),STADOC(NOL),TYPCOM(NOL),VCRNUM(NOL),BPRVCR(NOL),DATOPE(NOL),AMTATI(NOL),CUR(NOL),BPR(NOL),BPRNAM(NOL),NIP(NOL),CRY(NOL),VCRSTA(NOL)
    Actzo  [M:XSIII]BPRVCR(NOL),VCRTYP(NOL)
   [M:XSIII]FLGSEL(NOL)=2: [M:XSIII]VCRLIN(NOL)=1
  Endif
  Affzo [M:XSIII]1-99
End


##################################################
Subprog APRES_INM
Local Integer NOL: NOL=nolign-1
Local Char WMSG(250)

  If GXX025EXTAP=2 :End: Endif
  If [M:XSIII]STADOC(NOL)=1 and [M:XSIII]VCRNUM(NOL)<>""
    Local File XX025SII [XYSII]
    Trbegin [F:XYSII]
      Readlock [F:XYSII]X025SI0 = [M:XSII]CPY;4;[M:XSIII]GTE(NOL);[M:XSIII]VCRNUM(NOL);1
      If fstat<>[V]CST_AOK
        # creamos el nuevo tipo 4
        Gosub FIL_INM
        Write
      Else
        Gosub FIL_INM
        Rewrite
      Endif
    Commit
    Close File [XYSII]
  Endif
End

$FIL_INM
  [F:XYSII]FLGSEL=[M:XSIII]FLGSEL(NOL)
  [F:XYSII]CPY=[M:XSII]CPY
  [F:XYSII]STADOC=1
  [F:XYSII]TYPENV=4
  [F:XYSII]TYPCOM=1
  [F:XYSII]GTE   =[M:XSIII]GTE(NOL)
  [F:XYSII]VCRNUM=[M:XSIII]VCRNUM(NOL)
  [F:XYSII]VCRLIN=1
  [F:XYSII]VCRSTA=1
  [F:XYSII]AMTATI=[M:XSIII]AMTATI(NOL)
  [F:XYSII]DATOPE=[M:XSIII]DATOPE(NOL)
  [F:XYSII]BPRVCR=[M:XSIII]BPRVCR(NOL)
  [F:XYSII]BPR   =[M:XSIII]BPR(NOL)
  [F:XYSII]BPRNAM=[M:XSIII]BPRNAM(NOL)
  [F:XYSII]NIP   =[M:XSIII]NIP(NOL)
  [F:XYSII]CRY   =[M:XSIII]CRY(NOL)
  [F:XYSII]TYPREC=[M:XSIII]TYPREC(NOL)
  [F:XYSII]VCRTYP=[M:XSIII]VCRTYP(NOL)
  [F:XYSII]DKEY  =[F:XYSII]CPY+num$([F:XYSII]TYPENV)+[F:XYSII]GTE+[F:XYSII]VCRNUM+"1"
Return


##################################################
Subprog COMPROB_LIC(MODULO,WOKDEV)
Value Integer MODULO
Variable Integer WOKDEV
##### Existe el fichero de licencia
If filinfo(filpath(filpath("!","serialisation",""),"serial_sagespain",""),7)<=0
   WOKDEV=1
   End
Endif
##### Las licencias coinciden??

#Local Mask VISULIC
Local Integer USER
Local Integer DIVERS(1..9)
Local Integer NOMBRE(1..12)
Local Char CLAVE(12)(10)
CLAVE(0)="921541158178"
CLAVE(1)="485069284990"
CLAVE(2)="568977803782"
CLAVE(3)="842404070625"
CLAVE(4)="203650615336"
CLAVE(5)="637138499047"
CLAVE(6)="376282736253"
CLAVE(7)="750715347464"
CLAVE(8)="119826521819"
CLAVE(9)="094393962501"
# [M]FICHIER = filpath(filpath("!",".serialisation",""),"serial_sage","")
# Call SERIAL([M]FICHIER,[M]LICENCE,[M]CHCLI,[M]CHDIS,[M]DATDEB,[M]DATFIN,USER,DIVERS,NOMBRE) From VISULIC
LICENCE=GACTX._ASYRLIC.LICENSES.SERIAL
Openi filpath(filpath("!","serialisation",""),"serial_sagespain","")
Local Char LICX3(12), LICDV1(12), LICDV2(12), LICDV3(12), LICX32(12)

Rdseq LICX3
Rdseq LICDV1
Rdseq LICDV2
Rdseq LICDV3
Rdseq LICX32
Openi
If LICX3<>LICENCE
    WOKDEV=2: End
Endif
If len(LICX3)<>12 or len(LICX32)<>12 or len(LICDV1)<>12 or len(LICDV2)<>12 or len(LICDV3)<>12 or val(LICX3)=0 or val(LICDV1)=0
   WOKDEV=3:End
Endif
LICENDEV=""
For X=1 To 12
  For Y=0 To 9
   If mid$(LICX32,X,1)=mid$(CLAVE(Y),X,1)
      LICENDEV+=num$(Y)
      Break
   Endif
  Next
Next
If LICENDEV<>LICX3
  WOKDEV=4: End
Endif
If MODULO <= 30
  LICENDEV=""
  For X=1 To 12
   For Y=0 To 9
    If mid$(LICDV1,X,1)=mid$(CLAVE(Y),X,1)
     LICENDEV+=num$(Y)
     Break
    Endif
   Next
  Next

  VALORLIC=val(LICENDEV)-val(LICX3)
  For X=30 To 1 Step -1
    If 2^(X-1)<=VALORLIC
       If X=MODULO: End: Endif
       VALORLIC-=2^(X-1)
     Endif
   Next
Endif

If MODULO > 30 and MODULO <= 60
Endif

If MODULO > 60
Endif

End

