###################################################################
#      FUENTE PARA GENERAR LA IMPORTACION DE TARIFAS DE VENTA     #
###################################################################

Call GEN_SPL()
End

##########################################################################################
Subprog GEN_SPL()
#####
# Funciˇn que se encarga de generar la tarifa de venta a partir de las condiciones de los clientes (padres) y de los alumnos.
#####

# 1- Apertura de tablas
If !clalev([PP1]) : Local File BPCUSTOMER [PP1] : Endif
If !clalev([PP2]) : Local File YALUMNOS   [PP2] : Endif
If !clalev([PP3]) : Local File SPRICFICH  [PP3] : Endif
If !clalev([PP4]) : Local File SPRICLIST  [PP4] : Endif

# 2- Definiciˇn de variables
Local Char LDT
Local Char LFILE(200)
Local Char SPL_PADRE
Local Integer LSTA
Local Char CRITERIO_SPL(200)
Local Decimal PAD_PRI
Local Decimal PAD_DT1
Local Decimal PAD_DT2

# 3- Gestiˇn de la ruta para importaciˇn
LDT = format$("D:YYYY[]MM[]DD", date$) + "_" + left$(time$,2) + mid$(time$,4,2) + mid$(time$,7,2)
LFILE = "C:\Sage\X3ASMADRID\IEFILES\PROTO\SPL\SPL_" + LDT + ".txt"


# 4- Para cada cliente...
# 4.1 Compruebo si tiene hijos y que tenga las dos primeras familias estadÝsticas; sino salto
For [PP1] Where [PP1]BPCSTA = 2 and [PP1]TSCCOD(0)<>"" and [PP1]TSCCOD(1)<>""
  SPL_PADRE = ""
  PAD_PRI   = 0
  PAD_DT1   = 0
  PAD_DT2   = 0

  # 4.2 Si tiene hijos sigo
  For [PP2] Where [PP2]CLIENTE = [PP1]BPCNUM
    # 4.3 Si el padre ya tiene una tarifa en la estructura T310, traigo los datos; sino hay que crear una nueva
    If SPL_PADRE = ""
      Filter [PP3] Where [PP3]PLI = "T310" and [PP3]PLICRDIDX = [PP1]BPCSHO and [PP3]PLISTRDAT>=date$ and [PP3]PLIENDDAT<=date$
      Read [PP3] First
      If fstat = 0
        SPL_PADRE = [PP3]PLICRD
      Else
        Call NUMERO("SPTAV", "", date$, "", SPL_PADRE, LSTA)  From SUBANM
      Endif
      Filter [PP3]
    Endif

    # 4.4 Para el padre, busco la tarifa base apropiada T30 / T31 / T32 a partir de la segunda familia estadÝstica
    Case [PP1]TSCCOD(1)
      When "001" : CRITERIO_SPL = "[PP3]PLI = 'T300'"
      When "002" : CRITERIO_SPL = "[PP3]PLI = 'T301'"
      When "003" : CRITERIO_SPL = "[PP3]PLI = 'T302'"
    Endcase

    Filter [PP3] Where [PP3]PLICRDIDX = [PP1]TSCCOD(1) and [PP3]PLISTRDAT>=date$ and [PP3]PLIENDDAT<=date$ and evalue(CRITERIO_SPL)
    Read [PP3] First
    If fstat = 0
      Filter [PP4] Where [PP4]PLI = [PP3]PLI and [PP4]PLICRD = [PP3]PLICRD and [PP4]PLICRI2 = [PP1]TSCCOD(0) and [PP4]PLICRI3 = [PP2]ORDEN and [PP4]PLICRI5 = [PP2]GRADO
      Read [PP4] First
        If fstat = 0
          PAD_PRI = [PP4]PRI
          PAD_DT1 = [PP4]DCGVAL(0)
          PAD_DT2 = [PP4]DCGVAL(1)
        Endif
      Filter [PP4]
    Endif
    Filter [PP3]


  # 4.3 Para cada hijo saco las condiciones propias de la tabla de alumnos

  Next
Next

# 5- Compongo fichero cabecera

# 6- Compongo fichero lÝneas

# 7- Lanzo la importaciˇn

# 8- Cierro tablas


#Gosub DO_FILE
#Call IMP_MODEL(PTRK,"XSIH3",LFILE,LRTN,LCTR,LNER) From DSSLIBIE

End

