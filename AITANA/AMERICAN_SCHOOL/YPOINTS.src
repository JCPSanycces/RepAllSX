#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "CFMDLVFIL" : Gosub CFMDLVFIL
 When "IMPRIME"   : Gosub IMPRIME
 When "AUTINVDLIG": Gosub AUTINVDLIG
 When "AUTINVDREG": Gosub AUTINVDREG
 When "AUTINVDFIL": Gosub AUTINVDFIL
 When Default
Endcase
Return
###===================================================================================
$CFMDLVFIL

  If [M]XTSCCOD <> ""   : FILSUP -= '& TSCCOD(1) = "' +[M]XTSCCOD+ '"' : Endif

Return
###===================================================================================
$IMPRIME
#  If GFONCTION = "XENVF" Then
  If GFONCTION = "GESSIH" Then
    DESTINATION = 4          #Que lo imprima en PDF
#    If find([F:ARP]RPTCOD,"XLOCCLIBREV") Then
    If find([F:ARP]RPTCOD,"Y-FACVENPDF") Then
#      IMPRIMANTE = "ZEXCEL2"
      IMPRIMANTE = "VISTA"
    Else
      IMPRIMANTE  = "PDF"      #Destino, del diccionario de Informes X3
    Endif
#  FICHIER     = C_FICHIER  #Variable que se informe en el proceso
 #comento linea por error "variable inexistente" FICHIER     = GYWNOMFIC  #Variable que se informe en el proceso
  Endif

Return
###===================================================================================
$AUTINVDLIG

  If [F:SWI]SEQ <> 2 and (find(WIME,"4","5")) Then
    Read [XBPI]XBPI1 = [F:SDH]BPCORD;[F:SDD]BPAADD;[F:SDD]ITMREF
    If !fstat
      IJUMP = 1
    Endif
  Endif

  If [F:SWI]SEQ = 2 and (find(WIME,"4","5"))Then
    Read [XBPI]XBPI1 = [F:SDH]BPCORD;[F:SDD]BPAADD;[F:SDD]ITMREF
    If fstat
      IJUMP = 1
    Endif
  Endif

Return
###===================================================================================
$AUTINVDREG
If PASADA = 2 and (find(WIME,"4","5")) Then
  [F:SWI]LIN = PASADA
  [F:SWI]SEQ = PASADA
  [F:SWI]SWIKEY +="~"+num$(PASADA)
Endif

Return
###===================================================================================
$AUTINVDFIL
  PASADA = 1
Return

