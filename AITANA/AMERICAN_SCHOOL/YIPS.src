###############################################################################
$GET_PSDATA

Local Char LFILE_STU(200), LFILE_PAR(200)
Local Char LDATLIN_STU(60)(15) , LDATLIN_PAR(60)(15) , LDATLIN_ADD(60)(80)
#Local Char LDIREXPORT(100) : LDIREXPORT = "C:\Sage\X3ASMADRID\FOLDERS\" + nomap + "\IMPORT\"
Local Char LDIREXPORT(100) : LDIREXPORT = filpath('', '', '') +  "\IMPORT\"
Local Char LFILE_STU_NAME(100), LFILE_PAR_NAME(100)

Local Char LSEP(1) : LSEP = ";"

Local Char LFECHA(10), LHORA(10)
LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)
LFILE_STU_NAME = "STU_" +LFECHA+ "_" + LHORA + ".txt"
LFILE_PAR_NAME = "PAR_" +LFECHA+ "_" + LHORA + ".txt"
LFILE_STU  = LDIREXPORT + "STU_" +LFECHA+ "_" + LHORA + ".txt"
LFILE_PAR  = LDIREXPORT + "PAR_" +LFECHA+ "_" + LHORA + ".txt"
LFILE_PRO  = LDIREXPORT + "PRO_" +LFECHA+ "_" + LHORA + ".txt"

# IMPORTO LOS PADRES
Call ECR_TRACE("Importaciµn Padres", 0) From GESECRAN
adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE_PAR Using [ZEXP0]                     # abrir fichero
For [YPSC]    # vista clientes facturaciµn PS
  Gosub GET_BPCINV
Next
Openo Using [ZEXP0]                               # cerrar fichero
#Infbox "1.importado-aa"
#Infbox filpath('', '', '') +  "\IMPORT\"+  LFILE_PAR_NAME
#Infbox LNOMBRE_FICHERO
Call IMPORTSIL('YIPSBPC',LFILE_PAR ) From GIMPOBJ

# IMPORTO LOS ALUMNOS
Call ECR_TRACE("Importaciµn Alumnos", 0) From GESECRAN
adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE_STU Using [ZEXP1]                     # abrir fichero
For [YPSA]    # vista alumnos PS
  Gosub GET_STUDENTS
Next
#Infbox LFILE_STU
Openo Using [ZEXP1]                               # cerrar fichero
Call IMPORTSIL('YIPSALUM',LFILE_STU) From GIMPOBJ


# IMPORTO PROYECTOS = ALUMUNOS
adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE_PRO Using [ZEXP2]                     # abrir fichero
For [YPSA]    # vista alumnos PS
  Gosub GET_PROYECTO
Next
#Infbox LFILE_STU
Openo Using [ZEXP2]                               # cerrar fichero
Call IMPORTSIL('YOPPCRM',LFILE_PRO) From GIMPOBJ



Gosub SET_ORDEN_ALU

Return

