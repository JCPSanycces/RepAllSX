$GET_STUDENTS
####
#ALUMNOS - YIPSALUM
####
# 1  - > CLIENTE    Cliente - family num
# 2  - > ALUMNO     Student number
# 3  - > NOMBRE     Student first name
# 4  - > APELLIDOS  Student last name"
# 5  - > ORDEN      Entry order
# 6  - > GRADO      Grade
# 7  - > SHIP       Scholarship
# 8  - > ADICIONAL  Aditional yearbook
# 9  - > TRANSPORTE Transportation
# 10 - > EXEMPTION  F. Exemption status
# 11 - > FACTURARA  Bill To
#####
#;PAR-001656;32010;Stella;Matutes;4;T00009;0;0;2;Fee Exemption Status;Father
#####
LDATLIN_STU(1)  =  [YPSA]FAMILY_NUM



LDATLIN_STU(2)  =  [YPSA]STUDENT_NUM
LDATLIN_STU(3)  =  [YPSA]FIRST_NAME
LDATLIN_STU(4)  =  [YPSA]LAST_NAME


LDATLIN_STU(5)  =  "0" # utilizado para generar tarifa T310, habrÃ que modificar el spe del modelo de import para completar este campo, no estÃ en PS
                       # si el cµdigo de alumno ya existe en YALUMOS  - > no hacemos nada
                       # sino
                       #     si el idfamilia no existe en    YALUMNOS - > ORDEN = 0
                       #     else                                     - > ORDEN += 1
## JC.11082020.STR
#If !clalev([F:YAL0]) Then : Local File YALUMNOS [F:YAL0] : Endif
#Filter [F:YAL0] Where ALUMNO = [YPSA]STUDENT_NUM
#Read [F:YAL0] First
#If fstat <> 0 Then
#  If !clalev([F:YAL1]) Then : Local File YALUMNOS [F:YAL1] : Endif
#  Filter [F:YAL1] Where IDFAMILIA = [YPSA]FAMILY_NUM
#  Read [F:YAL1] First
#  If !fstat Then
#    GORDEN += 1
#  Endif
#  Filter [F:YAL1]
#Endif
#Filter [F:YAL0]
#Close Local File [YAL0],[YAL1]
#LDATLIN_STU(5) = num$(GORDEN)
## JC.11082020.END

LDATLIN_STU(6)  =  vireblc([YPSA]GRADE,2)
LDATLIN_STU(7)  =  [YPSA]SCHOLARSHIP
LDATLIN_STU(8)  =  "0" # Aclarar este campo ADICIONAL  ADITIONAL YEARBOOK
LDATLIN_STU(9)  =  "1" # [YPSA]BUS_STATUS
LDATLIN_STU(10) =  ""  # ACLARAR ESTE CAMPO EXEMPTION  F. Exemption status
LDATLIN_STU(11) =  [YPSA]BILLING

        Wrseq        LDATLIN_STU(1) + LSEP +
&                    LDATLIN_STU(2) + LSEP +
&                    LDATLIN_STU(3) + LSEP +
&                    LDATLIN_STU(4) + LSEP +
&                    LDATLIN_STU(5) + LSEP +
&                    LDATLIN_STU(6) + LSEP +
&                    LDATLIN_STU(7) + LSEP +
&                    LDATLIN_STU(8) + LSEP +
&                    LDATLIN_STU(9) + LSEP +
&                    LDATLIN_STU(10) + LSEP +
&                    LDATLIN_STU(11)
&              Using [ZEXP1]



Return



$GET_PROYECTO
####
#PROYECT - YIPSALUM
####
# 1  - > CLIENTE    Cliente - family num
# 2  - > ALUMNO     Student number
# 3  - > NOMBRE     Student first name
# 4  - > APELLIDOS  Student last name"
# 5  - > ORDEN      Entry order
# 6  - > GRADO      Grade
# 7  - > SHIP       Scholarship
# 8  - > ADICIONAL  Aditional yearbook
# 9  - > TRANSPORTE Transportation
# 10 - > EXEMPTION  F. Exemption status
# 11 - > FACTURARA  Bill To
#####
#O;101;24176;;20190901;EUR;;
#I;LUISA VIEIRA DE MAGALHAES~~SPA
#C;        ;0;0;0;1;2
#A;APD;1;20190901;
#####
    Wrseq "O" + LSEP + "101" + LSEP + [YPSA]STUDENT_NUM + LSEP +  [YPSA]STUDENT_NUM + LSEP + "" + LSEP + "" + LSEP + num$(date$) + LSEP + "EUR"  Using [ZEXP2]
    Wrseq "I" + LSEP + [YPSA]FIRST_NAME + " " + [YPSA]LAST_NAME   Using [ZEXP2]
    Wrseq "C" + LSEP + "        ;0;0;0;1;2"  Using [ZEXP2]
    Wrseq "A;APD;1;20190901;" Using [ZEXP2]

Return


###############################################################################
#**
#* Importa el cliente (progenitor/tutor) de PS a facturar
#*!
$GET_BPCINV
Local Char YBPCNUM(30)
#debemos buscar si existe para el registro [YPSA]STUDENT_NUM en X3 un BPC con rol PADRE
# si existe (actualizaciµn)
#         en EL TXT DEL IMPORT PONDREMOS EL BPCNUM YA EXISTENTE
#         el resto de campos los actualizadmos con la visat [YPSA] de PS
# si no existe (alta nueva)
#         no informamos BPCNUM en el txt y lo completamos con los datos de la vista
Filter [YBPC] Where [YBPC]BPCSHO = [YPSC]FAMILY_NUM and [YBPC]TSCCOD(2) = [YPSC]ROL
Read [YBPC] First
If !fstat Then  # existe el cliente a facturar
  YBPCNUM = [YBPC]BPCNUM
Else
  YBPCNUM = ""
Endif
Filter [YBPC]
Call ECR_TRACE("Cliente: " + YBPCNUM + " ID: " + [YPSC]FAMILY_NUM , 0) From GESECRAN
####
#CLIENTES - YIPSBPC
####
# 1  - > INDICADOR  B
# 2  - > BCGCOD   CategorÚa
# 3  - > BPCNUM   Cliente
# 4  - > BPRNAM   Razµn social
# 5  - > BPRNAM(1)  Razµn social
# 6  - > BPRSHO   Descrip. corta
# 7  - > CRN    NIF
# 8  - > TSCCOD(0)  Familia estadÚstica - PRICE LIST CLIENT - BILLING TYPE
# 9  - > TSCCOD(1)  Familia estadÚstica - PERIODO FACTURACION - BILLING FREQ
# 10 - > TSCCOD(2)  Familia estadÚstica - ROL PARENTAL
###
# 11 - > INDICADOR  C
# 12 - > BPAADD   Direcciµn
# 13 - > BPADES   Descripciµn
# 14 - > BPAADDLIG(0) LÚnea direcciµn
# 15 - > BPAADDLIG(1) LÚnea direcciµn
# 16 - > BPAADDLIG(2) LÚnea direcciµn
# 17 - > POSCOD       C.Postal
# 18 - > CTY          Poblaciµn
# 19 - > CRY          PaÚs
# 20 - > BPAADDFLG    Por defecto
# 21 - > WEB          Direcciµn correo
#####
#B;PS;PAR-001656;A*** M*****;;02455;Z43002455;001;001;PADRE
#C;001;PASEO DE LOS LAGOS 115;PASEO DE LOS **** ***;;;28223;POZUELO;ES;2
#####

# CLIENTE
LDATLIN_PAR(1)  = "B"
LDATLIN_PAR(2)  = "PS"
LDATLIN_PAR(3)  = YBPCNUM
LDATLIN_PAR(4)  = [YPSC]BILLING_NAME   # HAY QUE COMPROBAR QUE ES INFERIOR A 30 **** DIVIDIR ***
LDATLIN_PAR(5)  = ""
LDATLIN_PAR(6)  = [YPSC]FAMILY_NUM
If vireblc([YPSC]BILLING_NIF,2) = '' Then
  LDATLIN_PAR(7) = '---'
Else
 LDATLIN_PAR(7)  = [YPSC]BILLING_NIF
Endif
LDATLIN_PAR(8)  = toupper(vireblc([YPSC]BILLING_TYPE,4))
LDATLIN_PAR(9)  = toupper([YPSC]BILLING_FREQ)
LDATLIN_PAR(10) = [YPSC]ROL

        Wrseq        LDATLIN_PAR(1) + LSEP +
&                    LDATLIN_PAR(2) + LSEP +
&                    LDATLIN_PAR(3) + LSEP +
&                    LDATLIN_PAR(4) + LSEP +
&                    LDATLIN_PAR(5) + LSEP +
&                    LDATLIN_PAR(6) + LSEP +
&                    LDATLIN_PAR(7) + LSEP +
&                    LDATLIN_PAR(8) + LSEP +
&                    LDATLIN_PAR(9) + LSEP +
&                    LDATLIN_PAR(10) + LSEP
&              Using [ZEXP0]


#DIRECCIÆN
LDATLIN_ADD(1)  = "C"
LDATLIN_ADD(2)  = "001"
LDATLIN_ADD(3)  = "FACTURACION"
LDATLIN_ADD(4)  = [YPSC]BILLING_ADD1    # HAY QUE COMPROBAR QUE ES INFERIOR A 30 **** DIVIDIR ***
LDATLIN_ADD(5)  = [YPSC]BILLING_ADD2    # HAY QUE COMPROBAR QUE ES INFERIOR A 30 **** DIVIDIR ***
LDATLIN_ADD(6)  = ""
LDATLIN_ADD(7)  = [YPSC]BILLING_ZIP
LDATLIN_ADD(8)  = [YPSC]BILLING_CITY
LDATLIN_ADD(9)  = "ES" # [YPSC]BILLING_COUN
LDATLIN_ADD(10) = "2"
LDATLIN_ADD(11) = [YPSC]FATHER_EMAIL
LDATLIN_ADD(12) = [YPSC]MOTHER_EMAIL

        Wrseq        LDATLIN_ADD(1) + LSEP +
&                    LDATLIN_ADD(2) + LSEP +
&                    LDATLIN_ADD(3) + LSEP +
&                    LDATLIN_ADD(4) + LSEP +
&                    LDATLIN_ADD(5) + LSEP +
&                    LDATLIN_ADD(6) + LSEP +
&                    LDATLIN_ADD(7) + LSEP +
&                    LDATLIN_ADD(8) + LSEP +
&                    LDATLIN_ADD(9) + LSEP +
&                    LDATLIN_ADD(10)+ LSEP +
&                    LDATLIN_ADD(11)+ LSEP +
&                    LDATLIN_ADD(12)
&              Using [ZEXP0]


# CLIENTE - ENTREGA - 18/01/2021
LDATLIN_ADD(1)  = "D"
LDATLIN_ADD(2)  = "001"


        Wrseq        LDATLIN_ADD(1) + LSEP +
&                    LDATLIN_ADD(2)
&              Using [ZEXP0]

# Infbox LFILE_PAR
#Infbox filpath("IMP", LFILE_PAR_NAME, "txt",filpath('', '', ''))

#Call IMPORTSIL('YSDHFL',filpath("IMP", PFILE, "csv",nomap)) From GIMPOBJ

Return


####################################################################
# Asignar ordenes a los alumnos cargados.
####################################################################
$SET_ORDEN_ALU
  Local Integer LCONT :
  If !clalev([YALU0]) Then : Local File YALUMNOS [YALU0]  : Endif
  If !clalev([YALU1]) Then : Local File YALUMNOS [YALU1]  : Endif

  Filter [F:YALU0] Where ORDEN = 0
  For [F:YALU0]
    LCONT = 0
    Filter [F:YALU1] Where IDFAMILIA = [F:YALU0]IDFAMILIA and ORDEN <> 0
    LCONT = rowcount([F:YALU1]) + 1
    Trbegin [F:YALU0]
    [F:YALU0]ORDEN = LCONT
    Rewrite [YALU0]
    Commit
  Next

Return
####################################################################

###############################################################################
$OPEN_TABLES
If !clalev([YPSA]) : Local File YVIPSA [YPSA]     : Endif
If !clalev([YPSC]) : Local File YVIPSC [YPSC]     : Endif
If !clalev([YBPC]) : Local File BPCUSTOMER [YBPC] : Endif
Global Integer GORDEN : Raz GORDEN
Return

###############################################################################
$CLOSE_TABLES

Close Local File [YPSA], [YPSC], [YBPC]
Kill GORDEN

Return


###############################################################################
# Revisiµn de los estudiantes que tienen los padres en su ficha
# Si son mÃs de 2 hay que marcarlos como familia numerosa
# Si no, marcarlos como familia normal.
$UPD_DATA

  If !clalev([YALU0]) Then : Local File YALUMNOS [YALU0]  : Endif
  Filter [F:YBPC]
  For [F:YBPC]
     Filter [F:YALU0] Where IDFAMILIA = [F:YBPC]BPCSHO
     Trbegin [YBPC]
     If rowcount([F:YALU0])>2 Then
      [F:YBPC]YFAMNUM=2
      Call ECR_TRACE("1.Cliente " + [F:YBPC]BPCNUM + " es familia numerosa con " + num$(rowcount([F:YALU0])) + " hijos" , 0) From GESECRAN
     Else
      [F:YBPC]YFAMNUM=1
   #   Call ECR_TRACE("1.Cliente " + [F:YBPC]BPCNUM + " NO es familia numerosa con " + num$(rowcount([F:YALU0]))  + " hijos", 0) From GESECRAN
     Endif
     Rewrite [F:YBPC]
     If !fstat Then
      Commit
     Else
      Rollback
     Endif
     Filter [F:YALU0]
  Next

Return
