#####################################################################################
# Src: SPEYEF
#-------------------------------------------------------------------------------------
# Proyecto: Pons
#-------------------------------------------------------------------------------------
# Version: v12
#-------------------------------------------------------------------------------------
# PO30 - Envío facturas PDF desde específico
# Fecha inicio YPO30: 17/02/2020
# Desarrollador: JCH
# Código de desarrollo: YPO30
# Descripción del desarrollo: Envío de facturas PDF desde pantalla específica
# Fecha: 17/02/2020
# Codigo Actividad: YPO30
#######################################################################################

$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"    : Gosub OUVRE
  When "OK"       : Gosub OK
  When "FIN"      : Gosub FIN
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
  Global Char   GCORREO(100)
  Global Char   GCORREO2(100) # AIT51
Return

##############################################################
$OK
  Gosub ENVIO_SIH
Return

##############################################################
$FIN
  Kill GCORREO
  Kill GCORREO2 # AIT51 05022021 - SE AŃADE CORREO PARA LA MADRE
Return


##############################################################
######################    ETIQUETAS    #######################
##############################################################
$ENVIO_SIH
Local Char LWHERE(250) : Raz LWHERE

  If !clalev([F:SIV0]) Then : Local File SINVOICEV  [F:SIV0] : Endif
  If !clalev([F:BPC0]) Then : Local File BPCUSTOMER [F:BPC0] : Endif
  If !clalev([F:YBPA]) Then : Local File BPADDRESS  [F:YBPA] : Endif

  LWHERE = "1=1"
  If [M:YEF0]NUMINVDEB <> "" Then : LWHERE += " and NUM >= [M:YEF0]NUMINVDEB" : Endif
  If [M:YEF0]NUMINVFIN <> "" Then : LWHERE += " and NUM <= [M:YEF0]NUMINVFIN" : Endif
  If [M:YEF0]BPCINVDEB <> "" Then : LWHERE += " and NUM >= [M:YEF0]BPCINVDEB" : Endif
  If [M:YEF0]BPCINVFIN <> "" Then : LWHERE += " and NUM <= [M:YEF0]BPCINVFIN" : Endif

  If !GSERVEUR Then
    Call TEMPON("Envío de facturas") From GESECRAN
    Call OUVRE_TRACE ("Envío de facturas") From LECFIC
  Endif
  Global Char   GCORREO(100)
  Global Char   GCORREO2(100) # AIT51
  Filter [F:SIV0] Where evalue(LWHERE)
  For [SIV0]
    #Infbox [F:SIV0]BPCINV + " " + [F:BPC0]BPAADD

    Read [BPC0]BPC0 = [F:SIV0]BPCINV
    Read [F:YBPA]BPA0=1;[F:SIV0]BPCINV;[F:BPC0]BPAADD
    If !fstat Then
      # GCORREO = [F:BPC0]YMAIENVFRA
      GCORREO  = [F:YBPA]WEB(0)
      GCORREO2 = [F:YBPA]WEB(1)
     # Infbox "1"
      If [F:BPC0]YTIPENVFRA = 1 Then
     #   Infbox "2"
        Call TEMPON("Envío de la factura "+[F:SIV0]NUM+" a "+GCORREO + " y a " + GCORREO2) From GESECRAN
        #Infbox "Envío de la factura "+[F:SIV0]NUM+" a "+GCORREO + " y a " + GCORREO2
        Call ENVMAIL_SIH([F:SIV0]NUM,"Y-FACVEN","PDF") From SPEYLIB0
      Endif
    Endif
  Next

  If !GSERVEUR Then
    Call TEMPOFF() From GESECRAN
    Call FERME_TRACE From LECFIC
  Endif

  If clalev([F:SIV0])  Then : Close Local File    [F:SIV0] : Endif
  If clalev([F:BPC0])  Then : Close Local File    [F:BPC0] : Endif
  If clalev([F:YBPA])  Then : Close Local File    [F:YBPA] : Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
