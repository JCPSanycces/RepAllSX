#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Creación de pagos desde la pasarela de pagos de Redsys
#*!
Subprog IMP_PAGOS()
  Local Char LDIRMPORT(250) : LDIRIMPORT = filpath("","","",[S]nomap(0),"") + "\IMPORT\"
  Local Char LFILE_W(200)
  Local Char LSEP(1) : LSEP = ";"  # LSEParador


  Local Char LFECHA(10), LHORA(10) : Raz LFECHA, LHORA

  If !clalev([YPAG]) Then : Local File YPAGOSREDSYS [YPAG] : Endif

  # Procesar todos los registros con ESTADO = 1
  Filter [F:YPAG] Where RESPUESTA = 'OK' and PAGOPROCE = 1
  For [F:YPAG]
    LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
    LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)
    LFILE_W = "PAGOS_" + LFECHA + LHORA

    GERRTRACE = 0
    Gosub GENERA_FICHERO

    Gosub IMPORTA_FICHERO
Infbox num$(GERRTRACE)
    If GERRTRACE = 0 Then
      Trbegin [YPAG]
      [F:YPAG]PAGOPROCE = 2
      Rewrite [YPAG]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Else
      Trbegin [YPAG]
      [F:YPAG]PAGOPROCE = 5
      Rewrite [YPAG]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
   Endif

  Next


End

########################################################
$GENERA_FICHERO

  #Infbox LFILE_W
  Local Char LFECHA



  If !clalev([YSIH]) Then : Local File SINVOICE [YSIH] : Endif
  Read [YSIH]SIH0=[F:YPAG]NUMFAC
  If !fstat Then

    Gosub $OPEN_FILE_W

    LFECHA_AUX = mid$(num$(date$),7,4)+mid$(num$(date$),4,2)+mid$(num$(date$),1,2)

    Wrseq "P" + LSEP + '' + LSEP + "CTRF" + LSEP + [F:YSIH]BPR + LSEP + "SPA" + LSEP +  "430000000" + LSEP + "TRF" + LSEP + [F:YSIH]FCY + LSEP + '' + LSEP + '2' + LSEP + "EUR" + LSEP +
&    ctrans(num$([F:YSIH]AMTATI),',','.') + LSEP + "0" + LSEP + LFECHA_AUX + LSEP + [F:YSIH]BPAINV + LSEP + "" + LSEP Using [ZIMP_W]

    Wrseq "D" + LSEP + 'COBRO' + LSEP + "SPA" + LSEP + "430000000" + LSEP + [F:YSIH]BPR + LSEP +  "FAC" + LSEP + [F:YSIH]NUM + LSEP + "EUR" + LSEP + ctrans(num$([F:YSIH]AMTATI),',','.') + LSEP +
& ctrans(num$([F:YSIH]AMTATI),',','.') + LSEP + '' +
& LSEP + '0' + LSEP + '' + LSEP + '' + LSEP + [F:YSIH]BPR + LSEP + '' + LSEP + [F:YSIH]FCY + LSEP Using [ZIMP_W]
    Gosub $CLOSE_FILE_W

  Endif



Return



#########################################################
$IMPORTA_FICHERO
  Call IMPORTSIL('YBSIPAY',filpath("IMPORT", LFILE_W, "csv",nomap)) From GIMPOBJ
Return

########################################################
$OPEN_FILE_W

  adxifs = ";"
  adxirs = chr$(13)+chr$(10)
  Openo filpath('IMPORT', LFILE_W, 'csv',nomap)  Using [ZIMP_W]
Return


########################################################
$CLOSE_FILE_W
  Openo Using [ZIMP_W]

Return
