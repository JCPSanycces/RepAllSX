# GestiÛn de la m·scara BUDLIG (Especifico)

######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla BUDLIG) 13/05/2020 15:46:08 (AIT04)
######################################################################################
Subprog CL_YGENERA(VALEUR)
Variable Char    VALEUR()
# Al introducir l partida pregunto al usuario si quiere que se generen las lÌneas de forma autom·tica
If [M:BUDL]ENV <>"" and [M:BUDL]FIY <> 0
  Local Integer OK9
  Call OUINON ("øDesea que las lÌneas presupuestarias se generen de forma autom·tica (Si existen ya lÌneas, ser·n borradas)?", OK9) From GESECRAN
  If OK9 = 2
    # Apertura de tablas
    If !clalev([PP1]) : Local File BUD       [PP1] : Endif
    If !clalev([PP2]) : Local File GACCOUNT  [PP2] : Endif
    If !clalev([PP3]) : Local File ENVELOPPE [PP3] : Endif
    If !clalev([PP4]) : Local File CACCE     [PP4] : Endif

    # Saco el CCE2 de las partidas presupuestarias
    Local Char ES_CCE2
    Local Char ES_BUD
    Local Char ES_CPY
    Local Char ES_FCY
    Read [PP3]ENV0 = [M:BUDL]ENV
    If fstat = 0
      ES_CCE2 = [PP3]ENTMNA
      ES_BUD  = [PP3]BUD
      ES_CPY  = [PP3]SOCIETE
      ES_FCY  = ""
    Else
      Goto SALIR
    Endif

    # Fijo el importe en 100.000Ä
    Local Decimal ES_IMPORTE : ES_IMPORTE = 100000

    # Borro los registros actuales
    Trbegin [PP1]
      Delete [PP1] Where [PP1]CCE3 = [M:BUDL]ENV
    Commit

    # Escribo una lÌnea presupuestaria para cada cuenta con gestiÛn presupuesto y cada secciÛn CCE1, solamente del grupo 6
    Trbegin [PP1]
    Local Integer SUMA
      For [PP2] Where [PP2]BUDTRK = 2
        For [PP4] Where [PP4]DIE = 'DEP'
            Raz [PP1]
            [PP1]ACCNUM = uniqid([PP1])
            [PP1]LEDTYP  = 2
            [PP1]BUD     = ES_BUD
            [PP1]CPY     = ES_CPY
            [PP1]FCY     = ES_FCY
            [PP1]FIY     = [M:BUDL]FIY
            [PP1]VER     = "1"
            [PP1]ACC     = [PP2]ACC
            [PP1]CCE1    = [PP4]CCE
            [PP1]CCE2    = ES_CCE2
            [PP1]CCE3    = [M:BUDL]ENV
            [PP1]AMT(0)  = ES_IMPORTE
            [PP1]COA     = 'AES'
            [PP1]CREDAT  = date$
            [PP1]CREUSR  = GUSER
            [PP1]CUR     = 'EUR'
            [PP1]DIE1    = 'DEP'
            [PP1]DIE2    = 'ENT'
            [PP1]DIE3    = 'PAR'
            [PP1]LED     = 'AES'
            [PP1]STA     = 1
            Write [PP1]
            If fstat = 0 : SUMA+=1 : Endif
        Next
      Next
    Commit
    Infbox "Se han generado " + num$(SUMA) + " lÌneas presupuestarias"
    $SALIR

    # Cierro tablas
    Close Local File [PP1],[PP2],[PP3],[PP4]
  Endif
Else
  Errbox "Gracias por introducir la Partida Presupuestaria y el Ejercicio"
Endif
End

######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla BUDLIG) 19/05/2020 06:41:41 (AIT04)
######################################################################################
Subprog AM_YCUENTA(VALEUR)
Variable Char    VALEUR()
#Llamo al proceso de carga de pantalla SPE
Call CARGA_LINEAS([M:BUDL]ENV,[M:BUDL]FIY,0,VALEUR,[M:BUDL]YENTIDAD,[M:BUDL]YDPTO) From SPETRTBUL
End


######################################################################################
Subprog AM_YENTIDAD(VALEUR)
Variable Char    VALEUR()
#Llamo al proceso de carga de pantalla SPE
Call CARGA_LINEAS([M:BUDL]ENV,[M:BUDL]FIY,0,[M:BUDL]YCUENTA,VALEUR,[M:BUDL]YDPTO) From SPETRTBUL
End


######################################################################################
Subprog AM_YDPTO(VALEUR)
Variable Char    VALEUR()
#Llamo al proceso de carga de pantalla SPE
Call CARGA_LINEAS([M:BUDL]ENV,[M:BUDL]FIY,0,[M:BUDL]YCUENTA,[M:BUDL]YENTIDAD,VALEUR) From SPETRTBUL
End


##########################################################
Subprog CARGA_LINEAS(ENVELOPPE,EXERCICE,NUMERO,VCUENTA,VENTIDAD,VDPTO)
Value Char    ENVELOPPE()
Value Integer EXERCICE
Value Integer NUMERO
Value Char    VCUENTA
Value Char    VENTIDAD
Value Char    VDPTO

Local Mask BUDLIG

 #YAS04. Cuentro el n˙mero de registros para la partida introducida. Si son m·s de 500 bloqueo y pido m·s criterios
 Local Integer CUENTO
 Local Char CRITERIO(250) : CRITERIO = "[BUD]CCE3 = ENVELOPPE and [BUD]FIY = EXERCICE"
 If VCUENTA <> ""
  CRITERIO += " & [BUD]ACC = VCUENTA"
 Endif
 If VENTIDAD <> ""
  CRITERIO += " & [BUD]CCE2 = VENTIDAD"
 Endif
 If VDPTO <> ""
  CRITERIO += " & [BUD]CCE1 = VDPTO"
 Endif

 Filter [BUD] Where evalue(CRITERIO)
   For [BUD]
    CUENTO +=1
    If CUENTO > 500 : Break : Endif
   Next
 Filter [BUD]
 If CUENTO > 500
  Errbox("Por favor introduzca m·s criterios de selecciÛn de lÌneas presupuestaria; hay m·s de 500 lÌneas con los criterios introducidos")
  End
 Endif
 #YAS04 Fin

#Enveloppe - Exercice
[M]ENV = ENVELOPPE
[M]FIY = EXERCICE

#Code budget et projet
Call LECTURE("ENV",ENVELOPPE,"") From CONTOBJ
[M]BUD = [F:ENV]BUD
[M]PRJ = [F:ENV]PRJ
[M]CUR = [F:ENV]CURENV

#Code budget
Call LECTURE("BUP",[F:ENV]BUD,"") From CONTOBJ

#Type de rÈfÈrentiel
Case [F:BUP]LEV
 When 1 : #Niveau societe
  [M]CPY=[F:ENV]FCY
  SOCIETE =[F:ENV]FCY
 When 2 : #Niveau site
  Call LECTURE("FCY",[F:ENV]FCY,"") From CONTOBJ
  [M]FCY=[F:ENV]FCY
  [M]CPY=[F:FCY]LEGCPY
  SOCIETE=[F:FCY]LEGCPY
Endcase

Call LECTURE("CPY",SOCIETE,"") From CONTOBJ

Call LECTURE("GCM",[F:CPY]ACM,"") From CONTOBJ
[M]LEDTYP = [F:GCM]ANALEDTYP
[M]LED    = [F:GCM]LED([M]LEDTYP-1)

#Axes et sections
For I=0 To 2 # (Dim Zone DIE From table BUDPAR)-1
 [M]DIE(I)=[F:BUP]DIE(I)
Next

# 3Ëme section
Local Char FMT
If [F:BUP]DIE(2)<>""
 Call GLOBVAR From SETGLBDIE
 Call INICCEFMT([F:BUP]DIE(2)) From SETGLBDIE
 Call LECTURE("DIE",[F:BUP]DIE(2),"") From CONTOBJ
 Local Char DESDIE3(GLONAX1)
 Call LECTEXTRA(DESDIE3,"GDIE","COLHEA",[F:DIE]DIE,"") From ATEXTRA
 Titcol [M]NBLIG DESDIE3 For CCE3
 FMT = "K:"+GCCEFMT
 [M]FMTCCE3=FMT
Else
 FMT = "-K:10"
 [M]FMTCCE3=FMT
Endif
Chgfmt [M]CCE3 With [M]FMTCCE3

#Plan de compte
[M]COA= [F:BUP]COA

#IntitulÈ exercice
Read [FIY]FIY0 = [M]CPY;[M]LEDTYP;EXERCICE
If !fstat
 If [F:FIY]DESSHO<>""
  [M]EXEINFO  = [F:FIY]DESSHO
 Else
  Raz [M]EXEINFO
 Endif
 [M]FIYSTR=[F:FIY]FIYSTR
 [M]FIYEND=[F:FIY]FIYEND
Endif

#Info
Call SETGLBAPP(SOCIETE,GAPPNIV) From TRTGDD
[M]APPNIV=GAPPNIV
#Call LECTURE("ENF",ENVELOPPE,num$(EXERCICE)) From CONTOBJ
Read [ENF]ENF0= ENVELOPPE;EXERCICE
If ! fstat
 [M]AMTBUDFIY = [F:ENF]AMTBUDFIY
 [M]AMTAPPFIY = [F:ENF]AMTAPPFIY
 [M]AMTRESFIY = [F:ENF]AMTRESFIY
Endif
#Grizage (hors budget)
If [F:ENV]EXTBUD=2
 Grizo [M]AMT,AMTATT
Else
 Actzo [M]
Endif
#Chargement des lignes de budget
Raz [M:BUDL]NBLIG
Raz [M:BUDL]ACCNUM
Raz [M:BUDL]ACC
Raz [M:BUDL]CCE1
Raz [M:BUDL]CCE2
Raz [M:BUDL]CCE3
Raz [M:BUDL]LOT
Raz [M:BUDL]STA
Raz [M:BUDL]APPDAT
Raz [M:BUDL]AMT
Raz [M:BUDL]AMTAPP
Raz [M:BUDL]AMTATT
#NB: Suis obligÈ de faire plusieur Raz sinon
#    il me Raz les champs de mÍme nom des ecrans appelant celui-ci
Gosub LOAD_LIG
Gosub INFO_MONTANT From TRTBUL

Affzo [M]
End


##########################################################
$LOAD_LIG
Local Integer NOL
Local Integer INDENT, INDENV, INDCCE3 : # Index of each dimension in the ledger
Call GETGDDINDDIE([M]CPY,[M]DIE(2),INDENV,INDENT,INDCCE3) From TRTGDD
#Gosub CRITBUD
NOL=0
#For [BUD]BUD0 Where evalue(CRITBUD)
Filter [BUD] Where evalue(CRITERIO)
  For [BUD]
   [M]ACC(NOL)    = [F:BUD]ACC
   [M]TEX(NOL)    = [F:BUD]TEX
   If INDENT>0  : [M]CCE1(NOL) = evalue("[F:BUD]CCE"+num$(INDENT))  : Endif
   If INDENV>0  : [M]CCE2(NOL) = evalue("[F:BUD]CCE"+num$(INDENV))  : Endif
   If INDCCE3>0 : [M]CCE3(NOL) = evalue("[F:BUD]CCE"+num$(INDCCE3)) : Endif
   [M]AMT(NOL)    = [F:BUD]AMT(0)
   [M]AMTAPP(NOL) = [F:BUD]AMTAPP
   [M]AMTATT(NOL) = [F:BUD]AMTATT
   [M]STA(NOL)    = [F:BUD]STA
   [M]LOT(NOL)    = [F:BUD]LOT
   #Champ informatifs justes affichÈes
   [M]ACCNUM(NOL)    = [F:BUD]ACCNUM
   [M]APPDAT(NOL)    = [F:BUD]APPDAT
   [M]AMTCMM(NOL)    = [F:BUD]AMTCMM
   [M]AMTCMMPRP(NOL) = [F:BUD]AMTCMMPRP
   [M]AMTREA(NOL)    = [F:BUD]AMTREA
   [M]TOTREA(NOL)    = [F:BUD]AMTREA+[F:BUD]AMTCMMPRP+[F:BUD]AMTCMM
   If func AFNC.ACTIV("SVC")
    [M]AMTCCA(NOL)    = [F:BUD]AMTCCA
   Endif
   [M]AMTCAP(NOL)    = [F:BUD]AMTCAP
   [M]AMTFAS(NOL)    = [F:BUD]AMTFAS
   [M]REVDAT(NOL)    = [F:BUD]REVDAT
   ###
   NOL+=1
  Next
Filter [BUD]
[M]NBLIG=NOL
Gosub GESAFFZON From TRTBUL
Return

