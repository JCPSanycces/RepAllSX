# GestiÛn de la m·scara SOI1 (Especifico)

######################################################################################
## Etiqueta aÒadida por el supervisor (pantalla SOI1) 17/06/2020 12:48:46 (AIT04)
######################################################################################
$ACTION
Case ACTION
 When Default
Endcase
Return

Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
# Pongo por defecto los campos de artÌculo-cliente y de la tarifa
If VALEUR <> ""
  [M:SOI1]ITMREFBPC = VALEUR
  Affzo [M:SOI1]ITMREFBPC
  Read [BPC]BPC0 = [M:SOI1]BPCORD
  If fstat = 0
    Case [BPC]TSCCOD(1)
      When "001" : [M:SOI1]PLI = "T300"
      When "002" : [M:SOI1]PLI = "T301"
      When "003" : [M:SOI1]PLI = "T302"
    Endcase
    Affzo [M:SOI1]PLI
  Endif

  zonsui = "[M:SOI1]STOFCY"
Endif
End

