#<AdxTL>@(#)0.0.0.0 $Revision$ 
###########################################
#   CREACION MASIVA DE PEDIDOS ABIERTOS   #
###########################################


# 1-Apertura de tablas
Gosub OPEN_TABLES

# 2-Definici¾n de variables
Gosub DEFINITION

# 3-Ejecuto proceso
Gosub EXECUTE

# 4- Cierro tablas
Gosub CLOSE_TABLES

End


##################################################
$OPEN_TABLES
If !clalev([X1]) : Local File BPCUSTOMER [X1] : Endif
If !clalev([X2]) : Local File YALUMNOS   [X2] : Endif
If !clalev([X3]) : Local File SORDER     [X3] : Endif
If !clalev([X4]) : Local File BPARTNER   [X4] : Endif
If !clalev([X5]) : Local File BPADDRESS  [X5] : Endif
If !clalev([X6]) : Local File ATEXTRA    [X6] : Endif
If !clalev([X7]) : Local File BPARTNER   [X7] : Endif
If !clalev([X8]) : Local File YALUMNOS   [X8] : Endif
If !clalev([X9]) : Local File SORDERC    [X9] : Endif
If !clalev([X10]) : Local File ITMMASTER  [X10] : Endif
If !clalev([X11]) : Local File TABVAC     [X11] : Endif
If !clalev([X12]) : Local File SORDERQ    [X12] : Endif
Return



##################################################
$DEFINITION
Local Char LNUM
Local Integer LSTAT
Local Integer CONTA
Local Integer LINEA
Return


##################################################
$EXECUTE
# Recorro maestro de clientes. Solamente genero pedidos abiertos para los clientes que tengan hijos asociados
Filter [X4] Where [X4]BPCFLG = 2 Order By [X4]BPRSHO Asc  # Ordeno terceros - clientes por IDFamilia
  For [X4]
    Read [X1]BPC0 = [X4]BPRNUM
    If fstat = 0 and [X1]BPCSTA = 2                       # El cliente tiene que estar activo
      Read [X2]YAL1 = [X4]BPRSHO
      If fstat = 0                                        # El cliente debe tener al menos un hijo
        # Si todas las condiciones OK, creo el pedido abierto
        # Reinicio variables
        LNUM  = ""
        LSTAT = 0
        LINEA = 0

        # Creo el n·mero del pedido abierto
        Call NUMERO("YPOC","101",date$,"",LNUM,LSTAT) From SUBANM

        # Genero registro del pedido abierto (tabla SORDER)
        If LNUM <> ""
          Raz [X3]
          [X3]SOHNUM    =   LNUM
          [X3]ALLTYP    =   1
          [X3]APPFLG    =   4
          [X3]BETCPY    =   1
          [X3]BETFCY    =   1
          [X3]BPAINV    =   [X1]BPAINV
          [X3]BPAORD    =   [X1]BPAADD
          [X3]BPAPYR    =   [X1]BPAPYR

          Read [X5]BPA0 = 1;[X1]BPCNUM;[X1]BPAADD
          If fstat = 0
            [X3]BPCADDLIG(0)  =  [X5]BPAADDLIG(0)
            [X3]BPCADDLIG(1)  =  [X5]BPAADDLIG(1)
            [X3]BPCADDLIG(2)  =  [X5]BPAADDLIG(2)
            [X3]BPCCTY        =  [X5]CTY
            [X3]BPCPOSCOD     =  [X5]POSCOD
            [X3]BPCSAT        =  [X5]SAT
          Endif

          [X3]BPCCRY    =   [X4]CRY
          Read [X6]AXX0="TABCOUNTRY";"CRYDES";"SPA";[X4]CRY;""
          If fstat = 0
            [X3]BPCCRYNAM    =   [X6]TEXTE
          Endif
          [X3]BPCGRU    =   [X1]BPCGRU
          [X3]BPCINV    =   [X1]BPCINV
          [X3]BPCNAM(0) =   [X4]BPRNAM(0)
          [X3]BPCNAM(1) =   [X4]BPRNAM(1)
          [X3]BPCORD    =   [X1]BPCNUM
          [X3]BPCPYR    =   [X1]BPCPYR

          Read [X5]BPA0 = 1;[X1]BPCINV;[X1]BPAINV
          If fstat = 0
            [X3]BPIADDLIG(0)  =  [X5]BPAADDLIG(0)
            [X3]BPIADDLIG(1)  =  [X5]BPAADDLIG(1)
            [X3]BPIADDLIG(2)  =  [X5]BPAADDLIG(2)
            [X3]BPICTY        =  [X5]CTY
            [X3]BPIPOSCOD     =  [X5]POSCOD
            [X3]BPISAT        =  [X5]SAT
          Endif

          Read [X7]BPR0 = [X1]BPCINV
          If fstat = 0
            [X3]BPINAM(0) =   [X7]BPRNAM(0)
            [X3]BPINAM(1) =   [X7]BPRNAM(1)
          Endif

          [X3]CCE(0)    =   [X1]CCE(0)
          [X3]CCE(1)    =   [X1]CCE(1)
          [X3]CCE(2)    =   [X1]CCE(2)
          [X3]CCE(3)    =   [X1]CCE(3)
          [X3]CCE(4)    =   [X1]CCE(4)
          [X3]CCE(5)    =   [X1]CCE(5)
          [X3]CCE(6)    =   [X1]CCE(6)
          [X3]CCE(7)    =   [X1]CCE(7)
          [X3]CCE(8)    =   [X1]CCE(8)
          [X3]CCE(9)    =   [X1]CCE(9)
          [X3]CDTSTA    =   1
          [X3]CHGTYP    =   [X1]CHGTYP
          [X3]COPNBR    =   1
          [X3]CPY       =   "001"
          [X3]CREDAT    =   date$
          [X3]CREUSR    =   GUSER
          [X3]CUR       =   [X4]CUR
          [X3]CUSORDREF =   [X4]BPRSHO
          [X3]DIE(0)    =   [X1]DIE(0)
          [X3]DIE(1)    =   [X1]DIE(1)
          [X3]DIE(2)    =   [X1]DIE(2)
          [X3]DIE(3)    =   [X1]DIE(3)
          [X3]DIE(4)    =   [X1]DIE(4)
          [X3]DIE(5)    =   [X1]DIE(5)
          [X3]DIE(6)    =   [X1]DIE(6)
          [X3]DIE(7)    =   [X1]DIE(7)
          [X3]DIE(8)    =   [X1]DIE(8)
          [X3]DIE(9)    =   [X1]DIE(9)
          [X3]EXPNUM    =   [X1]EXPNUM
          [X3]IME       =   [X1]IME
          [X3]INVDTA(0) =   [X1]INVDTA(0)
          [X3]INVDTA(1) =   [X1]INVDTA(1)
          [X3]INVDTA(2) =   [X1]INVDTA(2)
          [X3]INVDTA(3) =   [X1]INVDTA(3)
          [X3]INVDTA(4) =   [X1]INVDTA(4)
          [X3]INVDTA(5) =   [X1]INVDTA(5)
          [X3]INVDTA(6) =   [X1]INVDTA(6)
          [X3]INVDTA(7) =   [X1]INVDTA(7)
          [X3]INVDTA(8) =   [X1]INVDTA(8)
          [X3]INVDTA(9) =   [X1]INVDTA(9)
          [X3]INVDTAAMT(0) =   [X1]INVDTAAMT(0)
          [X3]INVDTAAMT(1) =   [X1]INVDTAAMT(1)
          [X3]INVDTAAMT(2) =   [X1]INVDTAAMT(2)
          [X3]INVDTAAMT(3) =   [X1]INVDTAAMT(3)
          [X3]INVDTAAMT(4) =   [X1]INVDTAAMT(4)
          [X3]INVDTAAMT(5) =   [X1]INVDTAAMT(5)
          [X3]INVDTAAMT(6) =   [X1]INVDTAAMT(6)
          [X3]INVDTAAMT(7) =   [X1]INVDTAAMT(7)
          [X3]INVDTAAMT(8) =   [X1]INVDTAAMT(8)
          [X3]INVDTAAMT(9) =   [X1]INVDTAAMT(9)
          [X3]LAN       =   [X4]LAN
          [X3]OCNFLG    =   [X1]OCNFLG
          [X3]ODL       =   [X1]ODL
          [X3]ORDDAT    =   gdat$(31,08,2020)
          [X3]PRITYP    =   1
          [X3]PTE       =   [X1]PTE
          [X3]SALFCY    =   "101"
          [X3]SOHCAT    =   4
          [X3]SOHTYP    =   "SOC"
          [X3]TSCCOD(0) =   [X1]TSCCOD(0)
          [X3]TSCCOD(1) =   [X1]TSCCOD(1)
          [X3]TSCCOD(2) =   [X1]TSCCOD(2)
          [X3]TSCCOD(3) =   [X1]TSCCOD(3)
          [X3]VACBPR    =   [X1]VACBPR
          [X3]VLYDATCON =   gdat$(31,08,2021)
          Trbegin [X3]
            Write [X3]
          Commit
            If fstat = 0
              CONTA +=1
              # Genero la solicitud de entrega (registro en SORDERC), una para cada hijo
              For [X8] Where [X8]IDFAMILIA = [X4]BPRSHO
                LINEA +=1
                Raz [X9]
                [X9]SOHNUM    =   LNUM
                [X9]SOPLIN    =   LINEA
                [X9]BPAADD    =   [X1]BPAADD
                [X9]BPCORD    =   [X1]BPCNUM
                [X9]CPY       =   "001"
                [X9]CREDAT    =   date$
                [X9]CREUSR    =   GUSER
                [X9]CUMDATEAR =   gdat$(31,08,2020)
                [X9]CUSORDREF =   [X8]IDFAMILIA
                [X9]EARDAT    =   gdat$(31,08,2020)
                [X9]EARDATCUS =   gdat$(31,08,2020)
                [X9]EECLOC    =   1
                Read [X10]ITM0 = [X8]GRADO
                If fstat = 0
                  [X9]ITMDES     = [X10]ITMDES1
                  [X9]ITMDES1    = [X10]ITMDES1
                  [X9]ITMDESBPC  = [X10]ITMDES1
                  [X9]ITMREF     = [X8]GRADO
                  [X9]ITMREFBPC  = [X8]GRADO + "-" + num$(LINEA)
                  [X9]SAU        = [X10]SAU
                  [X9]SAUSTUCOE  = [X10]SAUSTUCOE
                  [X9]STU        = [X10]STU
                  [X9]VACITM(0)  = [X10]VACITM(0)
                  [X9]VACITM(1)  = [X10]VACITM(1)
                  [X9]VACITM(2)  = [X10]VACITM(2)
                Endif

                [X9]PJT     =   [X8]ALUMNO
                [X9]PLI     =   "T310"
                [X9]SALFCY  =   "101"
                [X9]STOFCY  =   "101"
                [X9]VACBPR  =   [X1]VACBPR
                If [X9]VACITM(0)<>""
                  Read [X11]TVC1 = [X1]VACBPR;[X9]VACITM(0)
                  If fstat = 0
                    [X9]VAT(0) = [X11]VAT
                  Endif
                Endif

                If [X9]VACITM(1)<>""
                  Read [X11]TVC1 = [X1]VACBPR;[X9]VACITM(1)
                  If fstat = 0
                    [X9]VAT(1) = [X11]VAT
                  Endif
                Endif

                If [X9]VACITM(2)<>""
                  Read [X11]TVC1 = [X1]VACBPR;[X9]VACITM(2)
                  If fstat = 0
                    [X9]VAT(2) = [X11]VAT
                  Endif
                Endif

                [X9]VLYDATITM  =   gdat$(31,08,2021)

                Trbegin [X9]
                  Write [X9]
                Commit

                # Creo ahora la solicitud de entrega (cond. de facturaci¾n)
                If fstat = 0
                  # Facturaci¾n anual
                  Call MAKE_AN(LNUM,LINEA,[X1]BPAADD,[X1]BPCNUM,[X8]GRADO,[X8]ALUMNO,[X1]EXPNUM,[X1]TSCCOD(1))
                Endif
              Next
            Endif
        Endif
      Else
        Goto NEXT_BPC
      Endif
    Else
      Goto NEXT_BPC
    Endif

    $NEXT_BPC
  Next

Filter [X4]


Infbox "Pedidos creados: " + num$(CONTA)
Return


##################################################
Subprog MAKE_AN(VNUM,VLIN,VDIR,VCLI,VGRA,VALU,VEXP,VPER)
Value Char VNUM
Value Integer VLIN
Value Char VDIR
Value Char VCLI
Value Char VGRA
Value Char VALU
Value Integer VEXP
Value Char VPER  #001: Anual    002: Semestral    003: Mensual

# Facturaci¾n anual
If VPER = "001"
  # Primero busco la ·ltima secuencia del pedido
  Local Integer VSEQ
  Filter [X12] Where [X12]SOHNUM = VNUM Order By [X12]SOQSEQ Asc
  Read [X12] Last
  If fstat = 0
    VSEQ = [X12]SOQSEQ
  Endif

  Raz [X12]
  Call MAKE_ALL(VNUM,VLIN,VDIR,VCLI,VGRA,VALU,VEXP,VSEQ)
  # [X12]DEMDLVDAT =  gdat$(01,09,year(date$)) # MAB.25012021. Se comenta temporalmente
  [X12]DEMDLVDAT =  gdat$(01,09,year(date$)-1)
  [X12]SHIDAT    =   [X12]DEMDLVDAT
  # [X12]YEA       =   year(date$) # MAB.25012021. Se comenta temporalmente
  [X12]YEA       =   year(date$)-1
  Trbegin [X12]
    Write [X12]
  Commit

# Facturaci¾n semestral
Elsif VPER = "002"
  Local Integer I

  For I=0 To 1
    # Primero busco la ·ltima secuencia del pedido
    Local Integer VSEQ
    Filter [X12] Where [X12]SOHNUM = VNUM Order By [X12]SOQSEQ Asc
    Read [X12] Last
    If fstat = 0
      VSEQ = [X12]SOQSEQ
    Endif

    Raz [X12]
    Call MAKE_ALL(VNUM,VLIN,VDIR,VCLI,VGRA,VALU,VEXP,VSEQ)
    If I=0
      # [X12]DEMDLVDAT =  gdat$(01,09,year(date$)) # MAB.25012021.old Se comenta temporalmente
      [X12]DEMDLVDAT =  gdat$(01,09,year(date$)-1) # MAB.25012021.new
      [X12]SHIDAT    =   [X12]DEMDLVDAT
      #[X12]YEA       =   year(date$) # MAB.25012021.old Se comenta temporalmente
      [X12]YEA       =   year(date$)-1 # MAB.25012021.new
    Elsif I=1
      # [X12]DEMDLVDAT =  gdat$(01,02,year(date$)+1) # MAB.25012021.old Se comenta temporalmente
      [X12]DEMDLVDAT =  gdat$(01,02,year(date$))  # MAB.25012021.new
      [X12]SHIDAT    =  [X12]DEMDLVDAT
      # [X12]YEA       =   year(date$)+1  # MAB.25012021. Se comenta temporalmente
      [X12]YEA       =   year(date$)  # MAB.25012021.new
    Endif

    Trbegin [X12]
      Write [X12]
    Commit
  Next

# Facturaci¾n mensual
Elsif VPER = "003"
  Local Integer I

  For I=0 To 9
    # Primero busco la ·ltima secuencia del pedido
    Local Integer VSEQ
    Filter [X12] Where [X12]SOHNUM = VNUM Order By [X12]SOQSEQ Asc
    Read [X12] Last
    If fstat = 0
      VSEQ = [X12]SOQSEQ
    Endif

    Raz [X12]
    Call MAKE_ALL(VNUM,VLIN,VDIR,VCLI,VGRA,VALU,VEXP,VSEQ)
    If I=0
#      [X12]DEMDLVDAT =  gdat$(01,09,year(date$)) # MAB.25012021.old Se comenta temporalmente
      [X12]DEMDLVDAT =  gdat$(01,09,year(date$)-1) # MAB.25012021.new
      [X12]SHIDAT    =   [X12]DEMDLVDAT
#      [X12]YEA       =   year(date$) # MAB.25012021. Se comenta temporalmente
      [X12]YEA       =   year(date$)-1 # MAB.25012021.new
    Elsif I=1
#      [X12]DEMDLVDAT =  gdat$(01,10,year(date$)) # MAB.25012021. Se comenta temporalmente
      [X12]DEMDLVDAT =  gdat$(01,10,year(date$)-1) # MAB.25012021.new
      [X12]SHIDAT    =   [X12]DEMDLVDAT
#      [X12]YEA       =   year(date$) # MAB.25012021. Se comenta temporalmente
      [X12]YEA       =   year(date$)-1 # MAB.25012021.new
    Elsif I=2
#      [X12]DEMDLVDAT =  gdat$(01,11,year(date$)) # MAB.25012021. Se comenta temporalmente
      [X12]DEMDLVDAT =  gdat$(01,11,year(date$)-1) # MAB.25012021.new
      [X12]SHIDAT    =   [X12]DEMDLVDAT
#      [X12]YEA       =   year(date$) # MAB.25012021. Se comenta temporalmente
      [X12]YEA       =   year(date$)-1 # MAB.25012021.new
    Elsif I=3
#      [X12]DEMDLVDAT =  gdat$(01,12,year(date$)) # MAB.25012021. Se comenta temporalmente
      [X12]DEMDLVDAT =  gdat$(01,12,year(date$)-1) # MAB.25012021.new
      [X12]SHIDAT    =   [X12]DEMDLVDAT
#      [X12]YEA       =   year(date$) # MAB.25012021. Se comenta temporalmente
      [X12]YEA       =   year(date$)-1 # MAB.25012021.new
    Elsif I=4
#      [X12]DEMDLVDAT =  gdat$(01,01,year(date$)+1) # MAB.25012021. Se comenta temporalmente
      [X12]DEMDLVDAT =  gdat$(01,01,year(date$)) # MAB.25012021.new
      [X12]SHIDAT    =   [X12]DEMDLVDAT
#      [X12]YEA       =   year(date$)+1 # MAB.25012021.old Se comenta temporalmente
      [X12]YEA       =   year(date$) # MAB.25012021.new
    Elsif I=5
#      [X12]DEMDLVDAT =  gdat$(01,02,year(date$)+1) # MAB.25012021. Se comenta temporalmente
      [X12]DEMDLVDAT =  gdat$(01,02,year(date$)) # MAB.25012021.new
      [X12]SHIDAT    =   [X12]DEMDLVDAT
#      [X12]YEA       =   year(date$)+1 # MAB.25012021.old Se comenta temporalmente
      [X12]YEA       =   year(date$) # MAB.25012021.new
    Elsif I=6
#      [X12]DEMDLVDAT =  gdat$(01,03,year(date$)+1) # MAB.25012021.old Se comenta temporalmente
      [X12]DEMDLVDAT =  gdat$(01,03,year(date$)) # MAB.25012021.new
      [X12]SHIDAT    =   [X12]DEMDLVDAT
#      [X12]YEA       =   year(date$)+1 # MAB.25012021.old Se comenta temporalmente
      [X12]YEA       =   year(date$) # MAB.25012021.new
    Elsif I=7
#      [X12]DEMDLVDAT =  gdat$(01,04,year(date$)+1) # MAB.25012021.old Se comenta temporalmente
      [X12]DEMDLVDAT =  gdat$(01,04,year(date$)) # MAB.25012021.new
      [X12]SHIDAT    =   [X12]DEMDLVDAT
#      [X12]YEA       =   year(date$)+1 # MAB.25012021.old Se comenta temporalmente
      [X12]YEA       =   year(date$) # MAB.25012021.new
    Elsif I=8
#      [X12]DEMDLVDAT =  gdat$(01,05,year(date$)+1) # MAB.25012021.old Se comenta temporalmente
      [X12]DEMDLVDAT =  gdat$(01,05,year(date$)) # MAB.25012021.new
      [X12]SHIDAT    =   [X12]DEMDLVDAT
#      [X12]YEA       =   year(date$)+1 # MAB.25012021.old Se comenta temporalmente
      [X12]YEA       =   year(date$) # MAB.25012021.new
    Elsif I=9
#      [X12]DEMDLVDAT =  gdat$(01,06,year(date$)+1) # MAB.25012021.old Se comenta temporalmente
      [X12]DEMDLVDAT =  gdat$(01,06,year(date$)) # MAB.25012021.new
      [X12]SHIDAT    =   [X12]DEMDLVDAT
#      [X12]YEA       =   year(date$)+1 # MAB.25012021.old Se comenta temporalmente
      [X12]YEA       =   year(date$) # MAB.25012021.new
    Endif

    Trbegin [X12]
      Write [X12]
    Commit
  Next
Endif
End


##################################################
Subprog MAKE_ALL(ANUM,ALIN,ADIR,ACLI,AGRA,AALU,AEXP,ASEQ)
Value Char ANUM
Value Integer ALIN
Value Char ADIR
Value Char ACLI
Value Char AGRA
Value Char AALU
Value Integer AEXP
Value Integer ASEQ

# Genero registro en SOQ
[X12]SOHNUM   =   ANUM
[X12]SOPLIN   =   ALIN
[X12]SOQSEQ   =   ASEQ + 50
[X12]ALLTYP   =   1
[X12]BPAADD   =   ADIR
[X12]BPCORD   =   ACLI
[X12]CAD      =   1
[X12]CPY      =   "001"
[X12]CREDAT   =   date$
[X12]CREUSR   =   GUSER
[X12]DEMSTA   =   1
[X12]DLVDAY   =   1
[X12]DLVFLG   =   2
[X12]DLVPIO   =   1
[X12]DRN      =   1
[X12]EXPNUM   =   AEXP
[X12]FMI      =   1
[X12]INVFLG   =   1
[X12]ITMREF   =   AGRA
[X12]MON      =   9
[X12]ORDDAT   =   date$
[X12]ORIQTY   =   1
[X12]PITFLG   =   1
[X12]PJT      =   AALU
[X12]QTY      =   1
[X12]QTYSTU   =   1
[X12]SALFCY   =   "101"
[X12]SOHCAT   =   4
[X12]SOQSTA   =   2
[X12]STOFCY   =   "101"
[X12]STOMGTCOD =  1
End


##################################################
$CLOSE_TABLES
Close Local File [X1]
Close Local File [X2]
Close Local File [X3]
Close Local File [X4]
Close Local File [X5]
Close Local File [X6]
Close Local File [X7]
Close Local File [X8]
Close Local File [X9]
Close Local File [X10]
Close Local File [X11]
Close Local File [X12]
Return
