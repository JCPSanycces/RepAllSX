#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "STYLE"        : Gosub STYLE
  When "LIENS"        : Gosub LIENS
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$LIENS
Return


##############################################################
$STYLE
# Muestro datos de la pantalla de Students
Raz [M:YBPC7]
[M:YBPC7]NBLIG = 0

nolign = 1
For [YAL] Where [YAL]IDFAMILIA = [M:BPRC]BPRSHO # [YAL]CLIENTE = [M:BPC0]BPCNUM
  [M:YBPC7]ALUMNO(nolign-1)      = [YAL]ALUMNO
  [M:YBPC7]NOMBRE(nolign-1)      = [YAL]NOMBRE
  [M:YBPC7]APELLIDOS(nolign-1)   = [YAL]APELLIDOS
  [M:YBPC7]ORDEN(nolign-1)       = [YAL]ORDEN
  [M:YBPC7]GRADO(nolign-1)       = [YAL]GRADO
  [M:YBPC7]SHIP(nolign-1)        = [YAL]SHIP
  [M:YBPC7]TRANSPORTE(nolign-1)  = [YAL]TRANSPORTE
  [M:YBPC7]EXEMPTION(nolign-1)   = [YAL]EXEMPTION
  [M:YBPC7]FACTURARA(nolign-1)   = [YAL]FACTURARA
  [M:YBPC7]ADICIONAL(nolign-1)   = [YAL]ADICIONAL
  nolign +=1
Next
[M:YBPC7]NBLIG = nolign-1
Affzo [M:YBPC7]
Return



##############################################################
######################    ETIQUETAS    #######################
##############################################################

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################
##############################################################
## Control en el campo Tipo envío factura
##############################################################
Subprog C_YTIPENVFRA(VALEUR)
Variable Integer VALEUR
  If VALEUR = 1 Then
    Actzo [M:BPC2]YMAIENVFRA
  Else
    Grizo [M:BPC2]YMAIENVFRA
  Endif
End

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################

