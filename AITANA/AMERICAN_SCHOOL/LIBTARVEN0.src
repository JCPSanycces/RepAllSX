#<AdxTL>@(#)0.0.0.0 $Revision$
###################################################################
#      FUENTE PARA GENERAR LA IMPORTACION DE TARIFAS DE VENTA     #
###################################################################
$ACTION


Case ACTION
  When "EXEC"   : Gosub EXEC
  When Default
Endcase

Return

##########################################################################################
#Subprog GET_SPL()
######
## Funciµn que se encarga de generar la tarifa de venta a partir de las condiciones de los clientes (padres) y de los alumnos.
######

$EXEC

  Local Char    LFILE(200)
  Local Char    SPL_PADRE
  Local Integer LSTA
  Local Char    CRITERIO_SPL(200)
  Local Decimal PAD_PRI
  Local Decimal PAD_DT1
  Local Decimal PAD_DT2
  Local Decimal PAD_SCHSHI
  Local Decimal PAD_BUS
  Local Char    SPL_PLICRDIDX
  Local Date    SPL_PLISTRDAT, SPL_PLIENDDAT # MAB.29062020.NEW

   If GUSER="AIT51" : Dbgaff : Endif

  Call OUVRE_TRACE("Generaciµn tarifa T310") From LECFIC
  Call ECR_TRACE("1.Inicio", 0) From GESECRAN
  Gosub ABRIR_TBL

  Gosub GEN_SPL

  Gosub IMP_SPL

  Gosub CERRAR_TBL
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE() From LECFIC

End

########################################################
#**
#* Genera tarifa T310
#*!
$GEN_SPL
Local Char LDATCAB(30)(6),LDATLIN(30)(12)
Local Char LDIREXPORT(100) : LDIREXPORT = filpath("","","") + "\IMPORT\"
Local Char    LSEP(1) : LSEP = ";"

# utilizado para generar ficheros ºnicos
Local Char LFECHA(10), LHORA(10)
LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

# ruta del fichero..
LFILE  = LDIREXPORT + "SPL_" +LFECHA+ "_" + LHORA + ".txt"
Call ECR_TRACE("2.Abrir fichero " + "SPL_" +LFECHA+ "_" + LHORA + ".txt", 0) From GESECRAN
Gosub OPEN_FILE

# 4- Para cada cliente...
# 4.1 Compruebo si tiene hijos y que tenga las dos primeras familias estadÚsticas; sino salto
For [PP1] Where [PP1]BPCSTA = 2 and [PP1]TSCCOD(0)<>"" and [PP1]TSCCOD(1)<>"" #  and [PP1]BPCNUM = 'ASM-000330'
  SPL_PADRE     = ""
  SPL_PLICRDIDX = ""
  PAD_PRI       = 0
  PAD_DT1       = 0
  PAD_DT2       = 0
  PAD_SCHSHI    = 0
  PAD_BUS       = 0

  Call ECR_TRACE("Tengo hijos - "  + [PP1]BPCSHO , 0) From GESECRAN
  # 4.2 Si tiene hijos sigo

  ### For [PP2] Where [PP2]CLIENTE = [PP1]BPCNUM anterior dsalvador

  ######## Escribimos la cabecera de la Tarifa T310 ###########################
  #Filter [PP2] Where [PP2]CLIENTE = [PP1]BPCNUM Order By [PP2]ORDEN Desc
  Filter [PP2] Where [PP2]IDFAMILIA = [PP1]BPCSHO Order By [PP2]ORDEN Desc
  Call ECR_TRACE("Generaciµn registros - Cliente  " + [PP1]BPCNUM + " - hijos encontrados: " + num$(rowcount([F:PP2])), 0) From GESECRAN
  Read [PP2] First
  If !fstat
      ### For [PP2] Where [PP2]CLIENTE = [PP1]BPCNUM
        Call ECR_TRACE("Tarifa:  " + [PP1]BPCSHO + " - SPL_PADRE : " + SPL_PADRE, 0) From GESECRAN
        SPL_PLICRDIDX = [PP1]BPCSHO
        # 4.3 Si el padre ya tiene una tarifa en la estructura T310, traigo los datos; sino hay que crear una nueva
        If SPL_PADRE = ""
          Filter [PP3] Where [PP3]PLI = "T310" and [PP3]PLICRDIDX = [PP1]BPCSHO and [PP3]PLISTRDAT<=date$ and [PP3]PLIENDDAT>=date$

          Read [PP3] First
          If fstat = 0
            SPL_PADRE = [PP3]PLICRD
            SPL_PLISTRDAT = [PP3]PLISTRDAT
            SPL_PLIENDDAT = [PP3]PLIENDDAT
            Call ECR_TRACE("Ya exise la tarifa " + [PP1]BPCSHO , 0) From GESECRAN
          Else
            Call NUMERO("SPTAV", "", date$, "", SPL_PADRE, LSTA)  From SUBANM
            Call ECR_TRACE("Creamos nueva tarifa " + [PP1]BPCSHO , 0) From GESECRAN
            SPL_PLISTRDAT = date$
            SPL_PLIENDDAT = date$  + 3650
          Endif
          Filter [PP3]
        Endif
        Call ECR_TRACE("Tarifa padre  SPL_PADRE : " + SPL_PADRE, 0) From GESECRAN
        # 4.4 Para el padre, busco la tarifa base apropiada T30 / T31 / T32 a partir de la segunda familia estadÚstica
        Case [PP1]TSCCOD(1)
          When "001"
            Call ECR_TRACE("Busqueda de tarifa T300" , 0) From GESECRAN
             CRITERIO_SPL = "[PP3]PLI = 'T300'"
          When "002"
            CRITERIO_SPL = "[PP3]PLI = 'T301'"
            Call ECR_TRACE("Busqueda de tarifa T301" , 0) From GESECRAN
          When "003"
            CRITERIO_SPL = "[PP3]PLI = 'T302'"
            Call ECR_TRACE("Busqueda de tarifa T302" , 0) From GESECRAN
        Endcase
        Call ECR_TRACE("Busqueda cabecera: " + [PP1]TSCCOD(0) , 0) From GESECRAN
        Filter [PP3] Where  [PP3]PLISTRDAT<=date$ and [PP3]PLIENDDAT>=date$ and evalue(CRITERIO_SPL)
            # and [PP3]PLICRDIDX = [PP1]TSCCOD(0) quito este filtro
        #Read [PP3] First
        #If fstat = 0
        For [PP3]
#          Infbox "aqui1"
#          Infbox [PP1]TSCCOD(0)
#          Infbox num$([PP2]ORDEN)
#          Infbox [PP2]GRADO
#          Infbox num$([PP1]YFAMNUM)
          Call ECR_TRACE("Tarifa encontrada: " + [F:PP3]PLI + "-" + [PP3]PLICRD , 0) From GESECRAN
          Call ECR_TRACE("Busqueda detalle tarifa: " + [PP3]PLI + " CON PLICRI2 = " + [PP1]TSCCOD(1) + " Y [PP4]PLICRD = " + [PP3]PLICRD + " Y [PP4]PLICRI4 = " + num$([PP2]ORDEN) + " [PP4]PLICRI5 = "
& + [PP2]GRADO + " [PP4]PLICRI3 (FAM.NUM) = " + num$([PP1]YFAMNUM), 0) From GESECRAN
          # Filter [PP4] Where [PP4]PLI = [PP3]PLI and [PP4]PLICRD = [PP3]PLICRD and [PP4]PLICRI2 = [PP1]TSCCOD(0) and [PP4]PLICRI3 = [PP2]ORDEN and [PP4]PLICRI5 = [PP2]GRADO
          Filter [PP4] Where [PP4]PLI = [PP3]PLI
&           and [PP4]PLICRI2 = [PP1]TSCCOD(1)
&           and [PP4]PLICRI4 = num$([PP2]ORDEN)
&           and [PP4]PLICRI5 = [PP2]GRADO
&           and [PP4]PLICRI3 = num$([PP1]YFAMNUM)
&           and [PP4]PLICRI1 = [PP1]TSCCOD(0)
&           and [PP4]PLICRD = [PP3]PLICRD

            # familia numerosa - he puesto el campo PLICRI3, el PLICRI4 es para el orden.
            # TIPO DE LISTA DE PRECIOS (PRIVADA, ASM, CORPORATE, ETC...)
            #REGISTRO TARIFA # MAB.30112020.OLD
          # con este bucle, lo unico que al final nos interesa es quedarnos con el cµdigo de la tarifa, el resto
          # de campos sobrarÚa, ya que los volvemos a buscar por cada estudiante
          Read [PP4] First
          If fstat = 0
               Call ECR_TRACE("Articulo en PP4 encontrada en: " + [F:PP3]PLI + "-" + [PP3]PLICRD , 0) From GESECRAN
#              Infbox "aqui2"
              PAD_PRI     = [PP4]PRI        # VALOR
              PAD_DT1     = [PP4]DCGVAL(0)  # DESCUENTO 21 FAMILY DISCOUNT
              PAD_DT2     = [PP4]DCGVAL(1)  # DESCUENTO 2  ASM DISCOUNT
              PAD_SCHSHI  = [PP4]DCGVAL(3)  # SCHOLARSHIPE
              PAD_BUS     = [PP4]DCGVAL(4)  # BUS

              Break # TARIFA ENCONTRADA, SALGO DEL BUCLE Y YA SABEMOS LA TARIFA PADRE EN LA QUE ESTêN LOS ARTëCULOS
            Else
              Call ECR_TRACE("Tarifa PP4 NO encontrada" , 0) From GESECRAN
            Endif
          Filter [PP4]
        # Endif
        Next
 #       Filter [PP3] # AIT51.02032021

        #####
        # SPRICFICH - Tarifa clientes (registros)
        ###
        # 1 -> Cµdigo tarifa
        # 2 -> Registro tarifa  Entrada
        # 3 -> Indice (Desc. corta Cliente)
        # 3 -> Fecha inicio validez
        # 4 -> Fecha fin validez
        #####
        #E;T310;TAV20190000048;03240;20190901;20291231
        #####
        LDATCAB(1) = "T310"
        LDATCAB(2) = SPL_PADRE
        LDATCAB(3) = SPL_PLICRDIDX
        LDATCAB(4) = SPL_PLISTRDAT
        LDATCAB(5) = SPL_PLIENDDAT

        # escribimos en el fichero
        Wrseq 'E'                + LSEP +
&                     LDATCAB(1) + LSEP +
&                     LDATCAB(2) + LSEP +
&                     LDATCAB(3) + LSEP +
&                     LDATCAB(4) + LSEP +
&                     LDATCAB(5) + LSEP
&               Using [ZEXP]

  Endif
  ######## Fin escritura cabecera de la Tarifa T310 ###########################

  ######## Escribimos los detalles de la Tarifa T310 ##########################
  # 4.3 Para cada hijo saco las condiciones propias de la tabla de alumnos
Call ECR_TRACE("EMPEZAMOS A BUSCAR DATOS DE LOS HIJOS" , 0) From GESECRAN

  Filter [PP2]
  Filter [PP2] Where [PP2]IDFAMILIA = [PP1]BPCSHO
  #For [PP2] Where [PP2]CLIENTE = [PP1]BPCNUM
  For [PP2] # Where [PP2]CLIENTE = [PP1]BPCNUM
        #####
        # SPRICLIST - Tarifa clientes (cab)
        ###
        # 1 ->  Padre (Cliente
        # 2 ->  Hijo  (Proyecto)
        # 3 ->  Grado (ArtÚculo)
        # 4 ->  Unidad "UN"
        # 5 ->  Divisa "EUR"
        # 6 ->  Valor Unitario
        # 7 ->  Dto. Familiar DCGVAL(0)       **** repasara estos dtos.
        # 8 ->  Dto. ASM    DCGVAL(1)
        # 9 ->  Dto. Scholarship% DCGVAL(3)
        # 10 -> Dto. Scholarship% DCGVAL(3)
        # 11 -> Bus
        #####
        #L;PAR-002227;28099;T00007;UN;0;0;EUR;8432.5;0;0;30
        #####
         # volvemos a buscar por cada uno de los artÚculos encontrados
         Call ECR_TRACE("HIJO EN EL QUE ESTOY: " + [PP2]NOMBRE + " QUE ESTUDIA: " +[F:PP2]GRADO, 0) From GESECRAN
         # Call ECR_TRACE("Busqueda de datos en la tarifa padre del articulo " + [PP2]GRADO , 0) From GESECRAN
         Call ECR_TRACE("Tarifa [PP4]PLI = "  + [PP3]PLI, 0) From GESECRAN
         Call ECR_TRACE("Per.Fac [PP4]PLICRI2 = " + [PP1]TSCCOD(1), 0) From GESECRAN
         Call ECR_TRACE("Orden [PP4]PLICRI4 = " +num$([PP2]ORDEN), 0) From GESECRAN
         Call ECR_TRACE("Grado [PP4]PLICRI5 = " + [PP2]GRADO, 0) From GESECRAN
         Call ECR_TRACE("Fam Num [PP4]PLICRI3 = " + num$([PP1]YFAMNUM), 0) From GESECRAN
         Call ECR_TRACE("TIPO Cliente [PP4]PLICRI1 = " +[PP1]TSCCOD(0), 0) From GESECRAN
         Call ECR_TRACE("Registro [PP4]PLICRD = " +[PP3]PLICRD, 0) From GESECRAN
         Filter [PP4] Where [PP4]PLI = [PP3]PLI
&           and [PP4]PLICRI2 = [PP1]TSCCOD(1)
&           and [PP4]PLICRI4 = num$([PP2]ORDEN)
&           and [PP4]PLICRI5 = [PP2]GRADO
&           and [PP4]PLICRI3 = num$([PP1]YFAMNUM)
&           and [PP4]PLICRI1 = [PP1]TSCCOD(0)
# &           and [PP4]PLICRD = [PP3]PLICRD
        Read [PP4] First
        If !fstat Then
            Call ECR_TRACE("[PP4]PLICRD = " +[PP3]PLICRD, 0) From GESECRAN
            PAD_PRI     = [PP4]PRI        # VALOR
            PAD_DT1     = [PP4]DCGVAL(0)  # DESCUENTO 21 FAMILY DISCOUNT
            PAD_DT2     = [PP4]DCGVAL(1)  # DESCUENTO 2  ASM DISCOUNT
            PAD_SCHSHI  = [PP4]DCGVAL(3)  # SCHOLARSHIPE
            PAD_BUS     = [PP4]DCGVAL(4)  # BUS
            LDATLIN(1)  =  [PP1]BPCNUM
            LDATLIN(2)  =  [PP2]ALUMNO
            LDATLIN(3)  =  [PP2]GRADO
            LDATLIN(4)  =  "UN"
            LDATLIN(5)  =  "EUR"
            LDATLIN(6)  =  num$(PAD_PRI)
            LDATLIN(7)  =  num$(PAD_DT1)
            LDATLIN(8)  =  num$(PAD_DT2)
            LDATLIN(9)  =  num$([PP2]SHIP)
            LDATLIN(10) =  num$([PP2]ADICIONAL)
            LDATLIN(11) =  num$(PAD_BUS)        # BUS
        Else
            Call ECR_TRACE("NO ENCONTRADO", 0) From GESECRAN
        Endif
        # Filter [PP4]

        # BUSCAR EL NÖMERO DE LëNEA YA DE LA TARIFA T310, PARA QUE SI EXISTE SEA UNA ACTUALIZACIÆN Y NO UNA CREACIÆN
        Local Char LNUMLIN(10)
        Filter [PP4] Where [PP4]PLI = 'T310' and [PP4]PLICRD = SPL_PADRE and [PP4]PLICRI1 = [PP1]BPCNUM and [PP4]PLICRI2 = [PP2]ALUMNO and [PP4]PLICRI3 = [PP2]GRADO
        Read [F:PP4] First
        If !fstat Then
          LNUMLIN = num$([F:PP4]PLILIN)
           Call ECR_TRACE("LINEA ENCONTRADA " + LNUMLIN, 0) From GESECRAN
        Else
          LNUMLIN = ''
           Call ECR_TRACE("LINEA NO ENCONTRADA", 0) From GESECRAN
        Endif

# numero de lÚnea
# cliente
# alumno
# articulo / grado
# un
# eur
# pri de la tarifa padre
# dto de la tarifa padre
# dto de la tarifa padre
# scholarship del estdudiante
# adicional del studiante
# bus de la tarifa padre


        Wrseq 'L'               + LSEP +
&                    LNUMLIN    + LSEP +
&                    LDATLIN(1) + LSEP +
&                    LDATLIN(2) + LSEP +
&                    LDATLIN(3) + LSEP +
&                    LDATLIN(4) + LSEP +
&                    LDATLIN(5) + LSEP +
&                    LDATLIN(6) + LSEP +
&                    LDATLIN(7) + LSEP +
&                    LDATLIN(8) + LSEP +
&                    LDATLIN(9) + LSEP +
&                    LDATLIN(10) + LSEP +
&                    LDATLIN(11)
&              Using [ZEXP]

  ######## Fin escritura detalles Tarifa T310 #################################

  Next # [PP2]
Next # [PP1]

Gosub CLOSE_FILE
Call ECR_TRACE("3.Cerrar fichero " + "SPL_" +LFECHA+ "_" + LHORA + ".txt", 0) From GESECRAN
Return

##########################################################
$ABRIR_TBL
If !clalev([PP1]) : Local File BPCUSTOMER [PP1] : Endif
If !clalev([PP2]) : Local File YALUMNOS   [PP2] : Endif
If !clalev([PP3]) : Local File SPRICFICH  [PP3] : Endif
If !clalev([PP4]) : Local File SPRICLIST  [PP4] : Endif
Return


#########################################################
$CERRAR_TBL
Close Local File [PP1], [PP2], [PP3], [PP4]
Return


########################################################
$CLOSE_FILE
Openo Using [ZEXP]
Return




########################################################
#**
#* Importa movimiento de salida
#*!
$IMP_SPL
mkstat = 0 : fstat = 0 : GERRTRACE = 0

#Call OUVRE_TRACE("Creaciµn Recepcion a partir de Entrega Validada") From LECFIC
Call ECR_TRACE("4.Lanzo importaciµn", 0) From GESECRAN
Call IMPORTSIL("YSPL", LFILE) From GIMPOBJ
Call ECR_TRACE("5.Fin importaciµn YSPL", 0) From GESECRAN

#Call FERME_TRACE From LECFIC
#Call LEC_TRACE From LECFIC   #si se quiere mostrar traza

mkstat = 0 : fstat = 0 : GERRTRACE = 0
Return

########################################################
$OPEN_FILE
adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE Using [ZEXP]
Return
