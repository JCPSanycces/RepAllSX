#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "SEL_TABLE"      : Gosub SEL_TABLE
  When "VERF_TABLE"     : Gosub VERF_TABLE
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$SEL_TABLE
  Case TABLE
    When "YSELCCE1"   : Gosub SEL_YSELCCE1
    When "YSELCCE2"   : Gosub SEL_YSELCCE2
    When "YSELCCE3"   : Gosub SEL_YSELCCE3
  Endcase
Return

##############################################################
$VERF_TABLE
  Case TABLE
    When "YSELCCE1"   : Gosub VERF_YSELCCE1
    When "YSELCCE2"   : Gosub VERF_YSELCCE2
    When "YSELCCE3"   : Gosub VERF_YSELCCE3
  Endcase
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$SEL_YSELCCE1
  If !clalev([F:CCE1]) Then : Local File CACCE [F:CCE1] : Endif
  Default File [CCE1]
  Filter [F:CCE1] Where DIE = "DEP"
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Selección Secciones analíticas"                                # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Sección"                                                       # título de la segunda columna
  COL(NBCOL)  = "CCE"                                                           # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la primera columna
  COL(NBCOL)  = "DES"                                                           # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Eje"                                                           # título de la primera columna
  COL(NBCOL)  = "DIE"                                                           # nombre del campo a mostrar en la primera columna
Return

##############################################################
$VERF_YSELCCE1
Return

##############################################################
$SEL_YSELCCE2
  If !clalev([F:CCE2]) Then : Local File CACCE [F:CCE2] : Endif
  Default File [CCE2]
  Filter [F:CCE2] Where DIE = "ENT"
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Selección Secciones analíticas"                                # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Sección"                                                       # título de la segunda columna
  COL(NBCOL)  = "CCE"                                                           # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la primera columna
  COL(NBCOL)  = "DES"                                                           # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Eje"                                                           # título de la primera columna
  COL(NBCOL)  = "DIE"                                                           # nombre del campo a mostrar en la primera columna
Return

##############################################################
$VERF_YSELCCE2
Return

##############################################################
$SEL_YSELCCE3
  If !clalev([F:CCE3]) Then : Local File CACCE [F:CCE3] : Endif
  Default File [CCE3]
  Filter [F:CCE3] Where DIE = "PAR"
  NBCOL       = 0                                                               # número de la columna
  TIT(NBCOL)  = "Selección Secciones analíticas"                                # título de la ventana
  NBCOL       += 1
  TIT(NBCOL)  = "Sección"                                                       # título de la segunda columna
  COL(NBCOL)  = "CCE"                                                           # nombre del campo a mostrar en la segunda columna
  NBCOL       += 1
  TIT(NBCOL)  = "Descripción"                                                   # título de la primera columna
  COL(NBCOL)  = "DES"                                                           # nombre del campo a mostrar en la primera columna
  NBCOL       += 1
  TIT(NBCOL)  = "Eje"                                                           # título de la primera columna
  COL(NBCOL)  = "DIE"                                                           # nombre del campo a mostrar en la primera columna
Return

##############################################################
$VERF_YSELCCE3
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
##############################################################
Funprog GET_CCE1(PPSHNUM,PPSDLIN)
Value  Char    PPSHNUM
Value  Decimal PPSDLIN

Local Char LRES(15)   : Raz LRES

  If !clalev([F:CAL0]) Then : Local File CPTANALIN [F:CAL0] : Endif
  Filter [F:CAL0] Where ABRFIC = "PSD" and VCRNUM = PPSHNUM and VCRLIN = PPSDLIN
  Read [F:CAL0] First
  If !fstat Then
    LRES = [F:CAL0]CCE(0)
  Endif
  Filter [F:CAL0]

  Close Local File [CAL0]

End LRES

##############################################################
Funprog GET_CCE2(PPSHNUM,PPSDLIN)
Value  Char    PPSHNUM
Value  Decimal PPSDLIN

Local Char LRES(15)   : Raz LRES

  If !clalev([F:CAL0]) Then : Local File CPTANALIN [F:CAL0] : Endif
  Filter [F:CAL0] Where ABRFIC = "PSD" and VCRNUM = PPSHNUM and VCRLIN = PPSDLIN
  Read [F:CAL0] First
