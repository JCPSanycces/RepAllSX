##############################################################
Funprog GET_CCE3(PPSHNUM,PPSDLIN)
Value  Char    PPSHNUM
Value  Decimal PPSDLIN

Local Char LRES(15)   : Raz LRES

  If !clalev([F:CAL0]) Then : Local File CPTANALIN [F:CAL0] : Endif
  Filter [F:CAL0] Where ABRFIC = "PSD" and VCRNUM = PPSHNUM and VCRLIN = PPSDLIN
