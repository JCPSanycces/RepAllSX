##############################################################
Funprog FILTRA_CCE(PPSHNUM,PPSDLIN)
Value     Char    PPSHNUM
Value     Decimal PPSDLIN

Local Integer LRES
Local Char    LCRIT(250) : LCRIT = "1=1"

  If PPSHNUM<> "" Then        : LCRIT -= "AND VCRNUM=PPSHNUM"       : Endif
  If PPSDLIN<> 0 Then         : LCRIT -= "AND VCRLIN=PPSDLIN"       : Endif
  If [M:CPD1]YCCE1 <> "" Then : LCRIT -= "AND CCE(0)=[M:CPD1]YCCE1" : Endif
  If [M:CPD1]YCCE2 <> "" Then : LCRIT -= "AND CCE(1)=[M:CPD1]YCCE2" : Endif
  If [M:CPD1]YCCE3 <> "" Then : LCRIT -= "AND CCE(2)=[M:CPD1]YCCE3" : Endif

  If !clalev([F:CAL0]) Then : Local File CPTANALIN [F:CAL0] : Endif
  Filter [F:CAL0] Where evalue(LCRIT)
  Read [F:CAL0] First
  If !fstat Then
    LRES = 2
  Endif
  Filter [F:CAL0]

  Close Local File [CAL0]

End LRES

##############################################################
Funprog GET_YITMDES1(PPSHNUM,PPSDLIN)
Value  Char    PPSHNUM
Value  Decimal PPSDLIN

Local Char LRES(250)   : Raz LRES

  If !clalev([F:PSD0]) Then : Local File PREQUISD [F:PSD0] : Endif
  Read [F:PSD0]PSD0 = PPSHNUM;PPSDLIN
  If !fstat Then
    LRES = [F:PSD0]ITMDES1
  Endif

  Close Local File [PSD0]

End LRES

##############################################################
Funprog GET_YCOMMENT(PPSHNUM)
Value  Char    PPSHNUM

Local Char LRES(250)   : Raz LRES

  If !clalev([F:AXX0]) Then : Local File ACLOB  [F:AXX0] : Endif
  Filter [F:AXX0] Where CODBLB = "CO_PSH" and IDENT1 = PPSHNUM
  Read [F:AXX0] First
  If !fstat Then
    LRES = func SPEYLIB0.F_RTF2TEXT([F:AXX0]CLOB)
  Endif
  Filter [F:AXX0]

  Close Local File [AXX0]

End LRES
