#<AdxTL>@(#)0.0.0.0 $Revision$ Facturas
$ACTION

#If GUSER="AIT04" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"          : Gosub OUVRE
  When "EXEBOUT"        : Gosub EXEBOUT
  When "SETBOUT"        : Gosub SETBOUT
  When "FIN"            : Gosub FIN
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
  Global Char   GCORREO(100)
Return

##############################################################
$EXEBOUT
  Case BOUT
    When "e" : Gosub ENVIO_PDF
    When "p" : Gosub GENERA_PDF
  Endcase
Return

##############################################################
$SETBOUT
  If GREP = "C" or GREP = "M" or GREP = "A" Then
    Call VIREBOUT(CHAINE,"e") From GOBJET
  Endif
Return

##############################################################
$FIN
  Kill GCORREO
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
$ENVIO_PDF

  If !clalev([F:SIV0]) Then : Local File SINVOICEV  [F:SIV0] : Endif
  If !clalev([F:BPC0]) Then : Local File BPCUSTOMER [F:BPC0] : Endif

  If !GSERVEUR Then
    Call TEMPON("Env甐 de facturas") From GESECRAN
    Call OUVRE_TRACE ("Env甐 de facturas") From LECFIC
  Endif

  Read [F:SIV0]SIV0 = [M:SIH0]NUM
  Read [BPC0]BPC0 = [F:SIV0]BPCINV
  If !fstat Then
    GCORREO = [F:BPC0]YMAIENVFRA
    If [F:BPC0]YTIPENVFRA = 1 Then
      Call TEMPON("Env甐 de la factura "+[F:SIV0]NUM+" a "+GCORREO) From GESECRAN
      Call ENVMAIL_SIH([F:SIV0]NUM,"SBONFACP","ENVIOPDF") From SPEYLIB0
    Elsif [F:BPC0]YTIPENVFRA = 2 Then
      Call TEMPON("Env甐 de la factura "+[F:SIV0]NUM+" a "+GCORREO) From GESECRAN
      Call ENVDEST_SIH([F:SIV0]NUM,"SBONFACP","IMPRESORA") From SPEYLIB0
    Endif
  Endif

  If !GSERVEUR Then
    Call TEMPOFF() From GESECRAN
    Call FERME_TRACE From LECFIC
  Endif

  If  clalev([F:SIV0])  Then : Close Local File     [F:SIV0] : Endif
  If  clalev([F:BPC0])  Then : Close Local File     [F:BPC0] : Endif

Return

##############################################################
$GENERA_PDF
Local Char PMSG(250)
Local Integer PSTAT
  Call GEN_PDF("SIH", [M:SIH0]NUM, "Y-FACVENPDF", "PDF", PSTAT, PMSG) From SPEYLIB0
  If STAT
    Call ECR_TRACE(mess(55,198,1) - [M:SIH0]NUM + ":" - mess(6,123,1) - PMSG, 1) From GESECRAN
  Else
    Call ECR_TRACE(mess(55,198,1) - [M:SIH0]NUM + ":" - mess(11,6050,1), 0) From GESECRAN
  Endif
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

##############################################################
##################    FUNCIONES PROPIAS    ###################
##############################################################
