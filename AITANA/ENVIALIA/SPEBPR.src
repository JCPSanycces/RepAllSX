#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

#If GUSER="AIT07" Then : Infbox ACTION : Endif
Case ACTION
  When "OUVRE"        : Gosub OUVRE
  When "LIENS"        : Gosub LIENS
  When "APRES_CRE"    : Gosub APRES_CRE
  When "APRES_MOD"    : Gosub APRES_MOD
  When "AP_ANNULE"    : Gosub AP_ANNULE
  When "FIN"          : Gosub FIN
  When Default
Endcase

Return

##############################################################
######################    ACCIONES    ########################
##############################################################
##############################################################
$OUVRE
# JC.YEN01.STR
  If !clalev([F:YDB0]) Then : Local File YDOCBPR [F:YDB0] : Endif
# JC.YEN01.END
Return

##############################################################
$LIENS
# JC.YEN01.STR
  Gosub CARGA_DOCBPR
# JC.YEN01.END

# JC.10112020.YEN06.STR
  Gosub CALCULA_DEPOSITOS
# JC.10112020.YEN06.END

Return

##############################################################
$APRES_CRE
# JC.YEN01.STR
  Gosub CREA_DOCBPR
# JC.YEN01.END
Return

##############################################################
$APRES_MOD
# JC.YEN01.STR
  Gosub MODIF_DOCBPR
# JC.YEN01.STR
Return

##############################################################
$AP_ANNULE
# JC.YEN01.STR
  Gosub BORRA_DOCBPR
# JC.YEN01.STR
Return

##############################################################
$FIN
# JC.YEN01.STR
  Close Local File [YDB0]
# JC.YEN01.END
Return

##############################################################
######################    ETIQUETAS    #######################
##############################################################
##############################################################
# JC.YEN01
$CARGA_DOCBPR
Local Integer LCON

  Filter [F:YDB0] Where BPRNUM = [M:BPR0]BPRNUM
  For [YDB0]
    [M:YDOC]YCATEGORIA(LCON)  = [F:YDB0]YCATEGORIA
    [M:YDOC]YDESCDOCUM(LCON)  = [F:YDB0]YDESCDOCUM
    [M:YDOC]YADJUNTOFLG(LCON) = [F:YDB0]YADJUNTOFLG
    [M:YDOC]YFECHAREC(LCON)   = [F:YDB0]YFECHAREC
    [M:YDOC]YPERIODO(LCON)    = [F:YDB0]YPERIODO
    [M:YDOC]YIMPORTE(LCON)    = [F:YDB0]YIMPORTE
    [M:YDOC]YOBSERVA(LCON)    = [F:YDB0]YOBSERVA
    LCON += 1
  Next
  [M:YDOC]NBLIG = LCON
  Affzo [M:YDOC]

If dim(LCON) > 0 Then : Kill LCON : Endif
Return

##############################################################
# JC.YEN01
$CREA_DOCBPR
Local Integer LCON

  For LCON = 0 To [M:YDOC]NBLIG - 1
    Trbegin [F:YDB0]
    [F:YDB0]BPRNUM      = [F:BPR]BPRNUM
    [F:YDB0]YCATEGORIA  = [M:YDOC]YCATEGORIA(LCON)
    [F:YDB0]YDESCDOCUM  = [M:YDOC]YDESCDOCUM(LCON)
    [F:YDB0]YADJUNTOFLG = [M:YDOC]YADJUNTOFLG(LCON)
    [F:YDB0]YFECHAREC   = [M:YDOC]YFECHAREC(LCON)
    [F:YDB0]YPERIODO    = [M:YDOC]YPERIODO(LCON)
    [F:YDB0]YIMPORTE    = [M:YDOC]YIMPORTE(LCON)
    [F:YDB0]YOBSERVA    = [M:YDOC]YOBSERVA(LCON)
    Write [F:YDB0]
    If !fstat Then
      Commit
    Else
      Rollback
    Endif
  Next

If dim(LCON) > 0 Then : Kill LCON : Endif
Return

##############################################################
# JC.YEN01
$MODIF_DOCBPR
Local Integer LCON

  Trbegin [F:YDB0]
  Delete  [F:YDB0] Where [F:YDB0]BPRNUM = [M:BPR0]BPRNUM
  If !fstat Then
    Commit
  Else
    Rollback
  Endif

  For LCON = 0 To [M:YDOC]NBLIG - 1
    Trbegin [F:YDB0]
    Read [F:YDB0]YDB0 = [M:BPR0]BPRNUM;[M:YDOC]YCATEGORIA(LCON)
    If !fstat Then
      [F:YDB0]BPRNUM      = [M:BPR0]BPRNUM
      [F:YDB0]YCATEGORIA  = [M:YDOC]YCATEGORIA(LCON)
      [F:YDB0]YDESCDOCUM  = [M:YDOC]YDESCDOCUM(LCON)
      [F:YDB0]YADJUNTOFLG = [M:YDOC]YADJUNTOFLG(LCON)
      [F:YDB0]YFECHAREC   = [M:YDOC]YFECHAREC(LCON)
      [F:YDB0]YPERIODO    = [M:YDOC]YPERIODO(LCON)
      [F:YDB0]YIMPORTE    = [M:YDOC]YIMPORTE(LCON)
      [F:YDB0]YOBSERVA    = [M:YDOC]YOBSERVA(LCON)
      Rewrite [F:YDB0]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Else
      [F:YDB0]BPRNUM      = [M:BPR0]BPRNUM
      [F:YDB0]YCATEGORIA  = [M:YDOC]YCATEGORIA(LCON)
      [F:YDB0]YDESCDOCUM  = [M:YDOC]YDESCDOCUM(LCON)
      [F:YDB0]YADJUNTOFLG = [M:YDOC]YADJUNTOFLG(LCON)
      [F:YDB0]YFECHAREC   = [M:YDOC]YFECHAREC(LCON)
      [F:YDB0]YPERIODO    = [M:YDOC]YPERIODO(LCON)
      [F:YDB0]YIMPORTE    = [M:YDOC]YIMPORTE(LCON)
      [F:YDB0]YOBSERVA    = [M:YDOC]YOBSERVA(LCON)
      Write [F:YDB0]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Endif
  Next

If dim(LCON) > 0 Then : Kill LCON : Endif
Return

##############################################################
# JC.YEN01
$BORRA_DOCBPR
  Trbegin [F:YDB0]
  Delete  [F:YDB0] Where [F:YDB0]BPRNUM = [M:BPR0]BPRNUM
  If !fstat Then
    Commit
  Else
    Rollback
  Endif
Return

##############################################################
# JC.10112020.YEN06.STR
$CALCULA_DEPOSITOS
  If !clalev([F:YVD0]) Then : Local File YVISDEPOSITO [F:YVD0] : Endif
  Filter [F:YVD0] Where BPRNUM = [M:BPR0]BPRNUM
  Read [F:YVD0] First
  If !fstat Then
    [M:YRR0]YDEPCONST = [F:YVD0]TOT_DEPCONST
    [M:YRR0]YDEPRECIB = [F:YVD0]TOT_DEPRECIB
    Affzo [M:YRR0]YDEPCONST
    Affzo [M:YRR0]YDEPRECIB
    If !clalev([F:BPR0]) Then : Local File BPARTNER [F:BPR0] : Endif
    Read [F:BPR0]BPR0 = [M:BPR0]BPRNUM
    If !fstat Then
      Trbegin [F:BPR0]
      [F:BPR0]YDEPCONST = [F:YVD0]TOT_DEPCONST
      [F:BPR0]YDEPRECIB = [F:YVD0]TOT_DEPRECIB
      Rewrite [F:BPR0]
      If !fstat Then
        Commit
      Else
        Rollback
      Endif
    Endif
    Close Local File [BPR0]
  Endif
  Filter [F:YVD0]
  Close Local File [YVD0]
Return

##############################################################
#################    ACCIONES DE CAMPO    ####################
##############################################################

