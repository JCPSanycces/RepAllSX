Subprog AM_YLIQUIDABLE(VALEUR)
Variable Integer VALEUR
# Reset the currency to the BP currency
If [F:BPR]CUR <> ""
  Raz [M]CURSEL
  [M]CURSEL = [F:BPR]CUR
  Affzo [M]CURSEL
Endif

Gosub CLEAR_GRID From SUBBPOI
End


######################################################################################


Funprog GET_MTC()
  Local Char LMTC
  Local Integer I : I = 0
  Local Char REQUEST(255)(0..3)

  REQUEST(0) = "SELECT CONVERT(CHAR,MAX(SUBSTRING(MTC_0,2,4))) as LRES FROM " + nomap + ".GACCENTRYD WHERE SUBSTRING(MTC_0,2,4) = 1"

  For (Char LRES) From "5" Sql REQUEST As [YLNK]
    I += 1
    If [F:YLNK]LRES = "" Then
     LMTC = "A1"
    Else
     LMTC = "A"+num$(val([F:YLNK]LRES) + 1)
    Endif
    # If LMTC = "" : LMTC = 0 : End : Endif
  Next
End LMTC
