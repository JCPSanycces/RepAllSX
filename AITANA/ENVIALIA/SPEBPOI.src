$OPEN_FILE_W

adxifs = ";"
adxirs = chr$(13)+chr$(10)
Openo LFILE_W Using [ZIMP_W]

Return

########################################################
$CLOSE_FILE_W

Openo Using [ZIMP_W]

Return





#####################################################################################################
#**
#* Función
#*
#* @param PTYP
#*!
Funprog ES_LIQUIDABLE(PTYP)
Value Char PTYP
Local Integer MTCOK : MTCOK = 0

  # TIPOS DE ASIENTO
  If MTCOK = 0 Then
    Read [F:GTE0]GTE0=PTYP
    If !fstat Then
      If [F:GTE0]YLIQUIDABLE = 2 Then
        MTCOK = 1
      Endif
    Endif
  Endif
  # TIPOS DE FACTURA DE VENTA
  Read [TSV0]TSV1= PTYP
  If !fstat Then
    If [F:TSV0]YLIQUIDABLE = 2 Then
      MTCOK = 1 # TIPO LIQUIDABLE
    Endif
  Endif
  # TIPOS DE FACTURA DE COMPRA
  If MTCOK = 0 Then
    Read [F:TPV0]TPV0=PTYP
    If !fstat Then
      If [F:TPV0]YLIQUIDABLE = 2 Then
        MTCOK = 1
      Endif
    Endif
  Endif


End MTCOK


#**
#* Función que devuelve el tipo de registro que estamos leyendo
#*!
Funprog GET_TIPOREGISTRO(PTYP, PNUM, PTYPDUD, PPAYNUM)
Value Char PTYP, PNUM, PPAYNUM
Value Integer PTYPDUD
Local Char LTIPO

# Check if posted journal entry.  If so, display Journal inquiry right click
#Read [F:HAE] = [M:BPOI]TYP(nolign-1);[M:BPOI]NUM(nolign-1)
#If !fstat
#  #GBOUT3 = mess(18,109,1)
#  LTIPO = 'ASIENTO'
#Endif

# Check if invoice.  Display appropriate right click option.
Read [F:SIH]SIH2 = PTYP;PNUM
If !fstat
 Case [F:SIH]ORIMOD
  When 3 : LTIPO = 'FACTURA_VENTA' # GBOUT4 = mess(43,109,1) : # Customer invoice
  When 5 : LTIPO = 'FACTURA_VENTA' # GBOUT4 = mess(45,109,1) : # Sales invoice
 Endcase
Elsif fstat=5
 Read [F:PIH]PIH2 = PTYP;PNUM
 If !fstat
  Case [F:PIH]ORIMOD
   When 3 : LTIPO = 'FACTURA_COMPRA' # GBOUT4 = mess(44,109,1) : # Supplier invoice
   When 6 : LTIPO = 'FACTURA_COMPRA' # GBOUT4 = mess(46,109,1) : # Purchase invoice
  Endcase
 Endif
Endif

# Check if payment, add payment right click option.
#If [M:BPOI]TYPDUD(nolign-1) = 3 & [M:BPOI]PAYNUM(nolign-1) <> ""
#  LTIPO = 'PAGO' # GBOUT5 = mess(47,109,1) : # Payment
#Endif

End LTIPO
######################################################################################
## Etiqueta ańadida por el supervisor (pantalla BPOINET) 13/01/2021 08:43:46 (AIT51)
