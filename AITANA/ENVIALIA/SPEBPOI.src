#####################################################################################################
#####################################################################################################
$ACTION

Case ACTION
  When "BOUTON"             : Gosub EXEBOUT
  When "INIT"               : Gosub INIT
  When "SETBOUT"            : Gosub SETBOUT
  When Default
Endcase
Return

#####################################################################################################
$INIT
  If clalev([F:TSV0])=0 : Local File TABSIVTYP  [TSV0] : Endif
  If clalev([F:TPV0])=0 : Local File TABPIVTYP  [TPV0] : Endif
  If clalev([F:GTE0])=0 : Local File GTYPACCENT [GTE0] : Endif
  If clalev([F:YDAE])=0 : Local File GACCENTRYD [YDAE] : Endif
  If clalev([F:YDUD])=0 : Local File GACCDUDATE [YDUD] : Endif

Return
#####################################################################################################
$SETBOUT
    Gosub SETBOUT From SUBBPOI
    If [M:BPOI]BPRSEL <> "" and [M:BPOI]NB > 0 Then
      CHMEN += "L"
      Gosub SET_BOUT_STD From GSAISIE
      Gosub SET_BOUT_SPE From GSAISIE
      ETABOU(GRAFF) = 1  # Refresh
    Endif

    GPE = 1
Return
#####################################################################################################
$EXEBOUT
Case BOUT
 When "V" :
  If [M:BPOI]YLIQUIDABLE = 2 Then
    Gosub CHX_FILTRE  # Search button

    GPE = 1
  Endif
 When "L" :
   If [M:BPOI]YLIQUIDABLE = 2 Then
    Gosub LIQUIDACION_CS
   Endif
 When Default
Endcase

Return


$CHX_FILTRE

Local Integer NOL, PBLOCK
Local Char CRITERE(255), CRITERE2(255), OCOA(GLONCOA), CRITGRPSAC(GLONSAC)(1..99), STATMESS, ORDERBY, SYMBOLE
Local Decimal ITEMTOTAL, NETTOTAL

# First time in
If [M:BPOI]BPRSEL = "" or [M:BPOI]CURSEL = "" : Return : Endif

# Clear screens if doing a new search
If dim([M:BPOI3]NUM) > 0 or [M:BPOI]NUM(0) <> ""
  Gosub CLEAR_GRID From SUBBPOI
Endif

Filter [DUD1]

CRITERE  = "[DUD1]CPY='" + [M:BPOI]CPYSEL + "'"

# If All Sites in not checked, add Site to filter
If [M:BPOI]ALLFCY <> 2
  CRITERE -= "& [DUD1]FCY='" + [M:BPOI]FCYSEL + "'"
Endif

# If all collective accounts is not checked, add either collective group or collective account
If [M:BPOI]ALLSAC<>2
 If [M:BPOI]GRPSAC<>""
  Call LECMAINPLAN(1,[M:BPOI]CPYSEL,OCOA) From CPTDIV
  Filter [GSC] Where [F:GSC]COA=OCOA & [F:GSC]GRU=[M:BPOI]GRPSAC
  Raz [L]CRITGRPSAC
  For [F:GSC]GSC0
   I+=1 : [L]CRITGRPSAC(I) = [F:GSC]SAC
  Next
  Filter [GSC]
  CRITERE -= "& find([DUD1]SAC,[L]CRITGRPSAC)"
 Else
  CRITERE -= "& [DUD1]SAC='"+[M:BPOI]SACSEL+"'"
 Endif
Endif

# BP - required field
CRITERE -= "& [DUD1]BPRPAY='" + [M:BPOI]BPRSEL + "'"

# Date range
If [M:BPOI]DUDDATDEB<>[0/0/0]
 CRITERE -= "& [DUD1]DUDDAT>=["+format$(GFMD,[M:BPOI]DUDDATDEB)+"]"
Endif
If [M:BPOI]DUDDATFIN<>[0/0/0]
 CRITERE -= "& [DUD1]DUDDAT<=["+format$(GFMD,[M:BPOI]DUDDATFIN)+"]"
Endif

# Currency - required field
CRITERE -= "& [DUD1]CUR ='" + [M:BPOI]CURSEL + "'"

# Filter out 0 amount open items, open items linked to a factor, and zero balance items.
# Only display unbalanced open items. FLGCLE (1 = Open / Unbalanced, 2 = Final, 4 = Temporary)
CRITERE -= "& [DUD1]AMTCUR<>0 & [DUD1]BPRFCT='' & [DUD1]FLGCLE=1"

# 100560.n  When Clearing all lines (B2_NB) on QA installs the DH1 link was not being reset so NO records were selected
# 100560.n  However, adding the line below makes the selection work again
If clalev([DH1]) > 0 : Close File [DH1] : Endif # 100560.n

# Linking with GACCENTRY to ensure only posted open items are retrieved.  Link seems to create a Left Outer Join.
# Therefore, I need to link GACCENTRY with GACCDUDATE in order to get only records that are posted (exist in GACCDUDATE).
# Sorting options.  1-Due date, 2-Source date, 3-Document type
Case [M:BPOI]TRI
  When 1 : Link [HAE] With [DUD1]DUD0 = [HAE]TYP;[HAE]NUM As [DH1] Where evalue(CRITERE) Order By [DUD1]DUDDAT Asc;[DUD1]ACCNUM Asc;[DUD1]DUDLIG Asc
  When 2 : Link [HAE] With [DUD1]DUD0 = [HAE]TYP;[HAE]NUM As [DH1] Where evalue(CRITERE) Order By [HAE]BPRDATVCR Asc;[DUD1]ACCNUM Asc;[DUD1]DUDLIG Asc
  When 3 : Link [HAE] With [DUD1]DUD0 = [HAE]TYP;[HAE]NUM As [DH1] Where evalue(CRITERE) Order By [DUD1]TYP Asc;[DUD1]ACCNUM Asc;[DUD1]DUDLIG Asc
Endcase

Gosub LOADGRID


Return


#####################################################################################################
$LOADGRID

ITEMTOTAL = 0
NOL = 0
PBLOCK = 0
Local Integer MATCHED : MATCHED = 1

# X3-53665
Call DELOCK("HAE") From GLOCK

For [DH1]
  If !func SUBBPOI.TEST_MTC(MATCHED) | [F:DH1]FLGREP=2 : Goto READ_NEXT_DH1 : Endif
  # SI EL TIPO NO ES LIQUIDABLE SALTAR EL REGISTRO
  If !func ES_LIQUIDABLE([F:DUD1]TYP) Then : Goto READ_NEXT_DH1 : Endif

  SYMBOLE = "HAE"+num$([F:DUD1]NUM)+"\"+num$([F:DUD1]TYP)
  Lock =SYMBOLE
  If fstat
    PBLOCK=1
  Else
    #94635 RICAR 2014/04/21 - CASH VAT - BEGIN
    If func AFNC.ACTIV("KPO") & func AFNC.PARAM("PORVAT",[M:BPOI]CPYSEL) = "2"
      If func PORLEGLIB.VAL_BPC_CASHVAT([F:DUD1]BPR, [F:HAE]ACCDAT) = 2
        Goto READ_NEXT_DH1
      Endif
    Endif
    #94635 RICAR 2014/04/21 - CASH VAT - END

    nolign = NOL + 1
    [M:BPOI] = [F:DUD1]
    # Make net positive or negative value based on sign (debit or credit)
    # Net total is taking into account Provisional payments per Christine B
    NETTOTAL = ([M:BPOI]AMTCUR(NOL) - [M:BPOI]PAYCUR(NOL) -[M:BPOI]TMPCUR(NOL)) * [M:BPOI]SNS(NOL)
    [M:BPOI]NETAMT(NOL) = NETTOTAL  # Open amount column
    [M:BPOI]AMTTONET(NOL) = 0  # Netting amount column
    [M:BPOI]PREVNET(NOL) = NETTOTAL  # Previous column is not displayed
    [M:BPOI]NETRES(NOL) = [M:BPOI]NETAMT(NOL) - [M:BPOI]AMTTONET(NOL)  # Remaining amount column
    ITEMTOTAL += [M:BPOI]NETAMT(NOL)

    # Open amount in ledger currency
    [M:BPOI]NETAMTLOC(NOL) = ([M:BPOI]AMTLOC(NOL) - [M:BPOI]PAYLOC(NOL) -[M:BPOI]TMPLOC(NOL)) * [M:BPOI]SNS(NOL)

    # Original amount and currently applied/payed and provisional payments
    [M:BPOI]ORIGAMTCUR(NOL) = [M:BPOI]AMTCUR(NOL) * [M:BPOI]SNS(NOL)
    [M:BPOI]ORIGPAYCUR(NOL) = [M:BPOI]PAYCUR(NOL) * [M:BPOI]SNS(NOL)
    [M:BPOI]ORIGTMPCUR(NOL) = [M:BPOI]TMPCUR(NOL) * [M:BPOI]SNS(NOL)

    # If Supplier invoice, add Payment Approval Status - 02/04/14 changed to use FLGPAZ for all lines
    STATMESS = mess([F:DUD1]FLGPAZ,510,1)
    [M:BPOI]PAYSTATUS(NOL) = STATMESS

    # If payment, add payment no. info to grid - will also be used for Payment inquiry.
    If [M:BPOI]TYPDUD(NOL) = 3
      [M:BPOI]PAYNUM(NOL) = [F:HAE]BPRVCR
    Endif

    # Add Source date, ref, and source document to grid
    [M:BPOI]BPRDATVCR(NOL) = [F:HAE]BPRDATVCR
    [M:BPOI]ACCDAT(NOL) = [F:HAE]ACCDAT
    [M:BPOI]REF(NOL) = [F:HAE]REF
    [M:BPOI]BPRVCR(NOL) = [F:HAE]BPRVCR
    [M:BPOI]FBPRVCR(NOL) = [F:HAE]BPRVCR
    # For Financials (or blank sources) set the Source document table column field to the Document number, but form mode will display the original Source document field
    If [F:HAE]ORIMOD = 2 or [F:HAE]BPRVCR = ""
      [M:BPOI]FBPRVCR(NOL) = [F:HAE]NUM
    Endif

    NOL += 1

    # Only allow up to number of rows set in screen
    If NOL+1 > dim([M:BPOI]NUM)
      GMESSAGE = mess(288,117,1)
      GERR = 2
      Break
    Endif
  Endif
  READ_NEXT_DH1
Next

[M:BPOI]NB = NOL
MAXLIG = nolign-1

# Totals section
[M:BPOI]NBITEM = NOL
[M:BPOI]TOTITEM = ITEMTOTAL
# Reset incase Calculate previously pressed
[M:BPOI]SELTOT = 0   # Total amount of calc items
[M:BPOI]SELITEM = 0  # Calculated items

# If some of the records were locked
If NOL > 0 & PBLOCK = 1
  GMESSAGE = mess(168,190,1)
  GERR = 2
Endif

# Either no records are returned based on criteria or all records have been locked by another process.
If NOL = 0
  If PBLOCK = 1
    Call ERREUR(mess(30,100,1)) From GESECRAN  # Operation in Progress on Another Workstation
  Else
    Call ERREUR(mess(99,100,1)) From GESECRAN  # No Records Selected
  Endif
  Return
Endif

Affzo [M:BPOI]

Return

#####################################################################################################
$LIQUIDACION_CS
Local Decimal LTOTAL_COBRADO, LTOTAL_PAGADO, LRESTO_FACTURA_VENTA, LRESTO_FACTURA_COMPRA
Local Char LBPR, LFCY, LMARCA
    # si se lanza la tarea batch
  If !GSERVEUR Then
    Call TEMPON("Proceso de liquidación" + [M:BPOI]BPRSEL ) From GESECRAN
    Call OUVRE_TRACE ("Proceso liquidación del tercero " + [M:BPOI]BPRSEL  ) From LECFIC
  Endif

  # Recorremos la pantalla para realizar los marcajes y vencimientos correspondientes
  # 1.  Marcaje de los cobros y pagos a cuenta que tiene el tercero asociado dentro del rango de fechas seleccionado de forma que disminuye el vencimiento pago de las facturas de compra y venta al
    #     quedar marcadas (relacionadas) con los asientos.
    # 1.1. Realizar los marcajes de las facturas junto con sus cobros o pagos
  Call ECR_TRACE("PASO 1 - MARCAJE FACTURAS", 0) From GESECRAN
  Gosub $MARCAJE_FACTURAS
    # 2.  Liquidación de las facturas mediante la generación de un asiento que las deje saldadas, por el importe que le quede pendiente generando el siguiente asiento:
  # GENERACIÓN DE ASIENTO
  Call ECR_TRACE("PASO 2 - GEN. ASIENTO COMPENSACION", 0) From GESECRAN
  Gosub GEN_ASIENTO_COMPENSACION
  If GERRTRACE = 0 Then
  # 3.  Lanzamiento de un nuevo marcaje dejando las facturas de compra y venta liquidadas con el marcaje y el asiento de compensación
    Call ECR_TRACE("PASO 3 - MARCAJE VENCIMIENTO ODG", 0) From GESECRAN
    Gosub $MARCAJE_VENCIMIENTOS
    # 4.  Generación de un nuevo vencimiento mediante la creación de un asiento de tipo LIQ por el importe que hemos llevado a la cuenta 555010 de forma que quede saldada
    # GENERACION DE ASIENTO
    Call ECR_TRACE("PASO 4 - GEN ASIENTO LIQUIDACIÓN", 0) From GESECRAN
    Gosub GEN_ASIENTO_LIQUIDACION
    If GERRTRACE > 0 Then
      Call ECR_TRACE("Error en la importación del asiento de Liquidación", 1) From GESECRAN
      Call ECR_TRACE("PROCESO PARADO", 1) From GESECRAN
    Endif
  Else
    Call ECR_TRACE("Error en la importación del asiento de Compensación", 1) From GESECRAN
    Call ECR_TRACE("PROCESO PARADO", 1) From GESECRAN
  Endif
  If !GSERVEUR Then
    Call TEMPOFF() From GESECRAN
    # fin de traza
    Call ECR_TRACE("Fichero " + ctrans(LFILE_W,"\","/") + " generado", 0) From GESECRAN
    Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
    Call FERME_TRACE From LECFIC

    mkstat = 0 : fstat = 0 : GERRTRACE = 0 : GOK = 1
  Endif
  Gosub CLEAR_GRID From SUBBPOI
Return

#####################################################################################################
$MARCAJE_FACTURAS
LMARCA = func GET_MTC()
For I=0 To [M:BPOI]NB

    LTIPOREG = func GET_TIPOREGISTRO([M:BPOI]TYP(I), [M:BPOI]NUM(I), [M:BPOI]TYPDUD(I), [M:BPOI]PAYNUM(I))
    # Trbegin [YDAE]

    If LTIPOREG = 'FACTURA_VENTA' Then
      LBPR = [M:BPOI]BPR(I)
      LFCY = [M:BPOI]FCY(I)
      LTOTAL_COBRADO = 0
      LRESTO_FACTURA_VENTA = abs([M:BPOI]NETAMT(I))
      # BUSCAR LOS ASIENTOS DE COBRO PARA EL CLIENTE (430000)

      Filter [F:YDAE] Where TYP = 'YCOB' and BPR = [M:BPOI]BPR(I) and MTC = ''
      For [F:YDAE]
        [F:YDAE]MTC = LMARCA
        [F:YDAE]MTCDAT = date$
        LTOTAL_COBRADO += [F:YDAE]AMTCUR
        Trbegin [YDAE]
        Rewrite [F:YDAE]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
        # BUSCAR VENCIMIENTO DEL ASIENTO YCOB PARA MARCARLO COMO SALDADO
        If [F:YDAE]AMTCUR <> 0 Then
          Read [F:YDUD]DUD0=[F:YDAE]TYP;[F:YDAE]NUM
          Call ECR_TRACE("PASO 1 - Actulización de vencimiento del asiento  " + [F:YDAE]NUM, 0) From GESECRAN
          If !fstat Then
            Call ECR_TRACE("PASO 1 - DENTRO - Marco vencimiento de " + [F:YDAE]NUM + " como saldado", 0) From GESECRAN
            # Trbegin [YDUD]
            [F:YDUD]PAYCUR = [F:YDAE]AMTCUR
            [F:YDUD]PAYLOC = [F:YDAE]AMTCUR
            [F:YDUD]FLGCLE = 2
            Trbegin [YDUD]
            Rewrite [F:YDUD]
            If !fstat Then
              Commit
            Else
              Rollback
            Endif
          Endif
        Endif
      Next
      LRESTO_FACTURA_VENTA -= LTOTAL_COBRADO
      # ACTUALIZAR MARCAJE FACTURA
      #Trbegin [YDAE]
      Filter [F:YDAE] Where TYP = [M:BPOI]TYP(I) and NUM = [M:BPOI]NUM(I) and BPR = [M:BPOI]BPR(I)
      Read [F:YDAE] First
      # Read [F:YDAE]DAE0=[M:BPOI]TYP(I);[M:BPOI]NUM(I);[M:BPOI]
      #Infbox num$(fstat)
      If !fstat Then
       [F:YDAE]MTC = LMARCA
       [F:YDAE]MTCDAT = date$
       Trbegin [YDAE]
       Rewrite [F:YDAE]
       If !fstat Then
        Commit
       Else
        Rollback
       Endif
      Endif
      # 1.2. Modificar el vencimiento. Asignar la cantidad del pago o del cobro a la factura de compra o de venta
      # DESCONTAR DEL VENCIMIENTO EL IMPORTE COBRADO
      If LTOTAL_COBRADO <> 0 Then
        Read [F:YDUD]DUD0=[M:BPOI]TYP(I);[M:BPOI]NUM(I)
        Call ECR_TRACE("PASO 1 - Actulización de vencimiento de la factura " + [M:BPOI]NUM(I), 0) From GESECRAN
        If !fstat Then
          Call ECR_TRACE("PASO 1 - DENTRO - Actulización de vencimiento de la factura " + num$(LTOTAL_PAGADO), 0) From GESECRAN
          # Trbegin [YDUD]
          [F:YDUD]PAYCUR = LTOTAL_COBRADO
          [F:YDUD]PAYLOC = LTOTAL_COBRADO
          Trbegin [YDUD]
          Rewrite [F:YDUD]
          If !fstat Then
            Commit
          Else
            Rollback
          Endif
        Endif
      Endif
    Elsif LTIPOREG = 'FACTURA_COMPRA' Then
      LTOTAL_PAGADO = 0
      LRESTO_FACTURA_COMPRA = abs([M:BPOI]NETAMT(I))

      # BUSCAR LOS ASIENTOS DE PAGOS AL PROVEEDOR  (400000)
      #Trbegin [YDAE]
      Filter [F:YDAE] Where TYP = 'YPAG' and BPR = [M:BPOI]BPR(I) and MTC = ''
      For [F:YDAE]
        [F:YDAE]MTC = LMARCA
        [F:YDAE]MTCDAT = date$
        LTOTAL_PAGADO += [F:YDAE]AMTCUR
        Trbegin [YDAE]
        Rewrite [F:YDAE]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
        # BUSCAR VENCIMIENTO DEL ASIENTO YPAG PARA MARCARLO COMO SALDADO
        If [F:YDAE]AMTCUR <> 0 Then
          Read [F:YDUD]DUD0=[F:YDAE]TYP;[F:YDAE]NUM
          Call ECR_TRACE("PASO 1 - Actulización de vencimiento del asiento  " + [F:YDAE]NUM, 0) From GESECRAN
          If !fstat Then
            Call ECR_TRACE("PASO 1 - DENTRO - Marco vencimiento de " + [F:YDAE]NUM + " como saldado", 0) From GESECRAN
            # Trbegin [YDUD]
            [F:YDUD]PAYCUR = [F:YDAE]AMTCUR
            [F:YDUD]PAYLOC = [F:YDAE]AMTCUR
            [F:YDUD]FLGCLE = 2
            Trbegin [YDUD]
            Rewrite [F:YDUD]
            If !fstat Then
              Commit
            Else
              Rollback
            Endif
          Endif
        Endif
      Next
      LRESTO_FACTURA_COMPRA -= LTOTAL_PAGADO
      # ACTUALIZAR MARCAJE FACTURA
      # Trbegin [YDAE]
      # Read [F:YDAE]YDAE=[M:BPOI]TYP(I);[M:BPOI]NUM(I)
      Filter [F:YDAE] Where TYP = [M:BPOI]TYP(I) and NUM = [M:BPOI]NUM(I) and BPR = [M:BPOI]BPR(I)
      Read [F:YDAE] First
      If !fstat Then
       [F:YDAE]MTC = LMARCA
       [F:YDAE]MTCDAT = date$
       Trbegin [YDAE]
       Rewrite [F:YDAE]
       If !fstat Then
        Commit
       Else
        Rollback
       Endif
      Endif

      # 1.2. Modificar el vencimiento. Asignar la cantidad del pago o del cobro a la factura de compra o de venta
      # DESCONTAR DEL VENCIMIENTO EL IMPORTE PAGADO
      If LTOTAL_PAGADO <> 0 Then
        Read [F:YDUD]DUD0=[M:BPOI]TYP(I);[M:BPOI]NUM(I)
        Call ECR_TRACE("PASO 1 - Actulización de vencimiento de la factura " + [M:BPOI]NUM(I), 0) From GESECRAN
        If !fstat Then
          # Trbegin [YDUD]
          Call ECR_TRACE("PASO 1 - DENTRO - Actulización de vencimiento de la factura " + num$(LTOTAL_PAGADO), 0) From GESECRAN
          [F:YDUD]PAYCUR = LTOTAL_PAGADO
          [F:YDUD]PAYLOC = LTOTAL_PAGADO
          Trbegin [YDUD]
          Rewrite [F:YDUD]
          If !fstat Then
            Commit
          Else
            Rollback
          Endif
        Endif
      Endif
    Endif
  Next

Return

#####################################################################################################
$MARCAJE_VENCIMIENTOS

For I=0 To [M:BPOI]NB
    LTIPOREG = func GET_TIPOREGISTRO([M:BPOI]TYP(I), [M:BPOI]NUM(I), [M:BPOI]TYPDUD(I), [M:BPOI]PAYNUM(I))
    If LTIPOREG = 'FACTURA_VENTA' Then
      LBPR = [M:BPOI]BPR(I)
      LFCY = [M:BPOI]FCY(I)
      LTOTAL_LIQ = 0
      LTOTAL_COBRADO = 0
      # BUSCAR LOS ASIENTOS DEL VENCIMIENTO GENERADO  (430000)
      # Trbegin [YDAE]
      Filter [F:YDAE] Where TYP = 'ODG' and BPR = [M:BPOI]BPR(I) and MTC = '' and ACC = '430000'
      For [F:YDAE]
        [F:YDAE]MTC = LMARCA
        [F:YDAE]MTCDAT = date$
        LTOTAL_COBRADO += [F:YDAE]AMTCUR
        Trbegin [YDAE]
        Rewrite [F:YDAE]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
        # BUSCAR VENCIMIENTO DEL ASIENTO O PARA MARCARLO COMO SALDADO - De momento no hace falta saldar este vencimiento
#        If [F:YDAE]AMTCUR <> 0 Then
#          Read [F:YDUD]DUD0=[F:YDAE]TYP;[F:YDAE]NUM
#          Call ECR_TRACE("PASO 1 - Actulización de vencimiento del asiento  " + [F:YDAE]NUM, 0) From GESECRAN
#          If !fstat Then
#            Call ECR_TRACE("PASO 1 - DENTRO - Marco vencimiento de " + [F:YDAE]NUM + " como saldado", 0) From GESECRAN
#            # Trbegin [YDUD]
#            [F:YDUD]PAYCUR = [F:YDAE]AMTCUR
#            [F:YDUD]PAYLOC = [F:YDAE]AMTCUR
#            [F:YDUD]FLGCLE = 2
#            Trbegin [YDUD]
#            Rewrite [F:YDUD]
#            If !fstat Then
#              Commit
#            Else
#              Rollback
#            Endif
#          Endif
#        Endif
      Next
      # Update [F:YDAE] Where TYP = [M:BPOI]TYP(I) and NUM = [M:BPOI]NUM(I) With MTC = 'D', MTCDAT = date$
      If LTOTAL_COBRADO <> 0 Then
        Read [F:YDUD]DUD0=[M:BPOI]TYP(I);[M:BPOI]NUM(I)
        Call ECR_TRACE("PASO 3 - Actulización de vencimiento de la factura " + [M:BPOI]NUM(I), 0) From GESECRAN
        If !fstat Then
          Call ECR_TRACE("PASO 3 - DENTRO - Actulización de vencimiento de la factura " + num$(LTOTAL_COBRADO), 0) From GESECRAN
          # Trbegin [YDUD]
          [F:YDUD]PAYCUR = [F:YDUD]PAYCUR + LTOTAL_COBRADO
          [F:YDUD]PAYLOC = [F:YDUD]PAYLOC + LTOTAL_COBRADO
          [F:YDUD]FLGCLE = 2 # FLAG DE FACTURA SALDADA
          Trbegin [YDUD]
          Rewrite [F:YDUD]
          If !fstat Then
            Commit
          Else
            Rollback
          Endif
        Endif
      Endif
      # 1.2. Modificar el vencimiento. Asignar la cantidad del pago o del cobro a la factura de compra o de venta
    Elsif LTIPOREG = 'FACTURA_COMPRA' Then
      LTOTAL_PAGADO = 0
      LBPR = [M:BPOI]BPR(I)
      LFCY = [M:BPOI]FCY(I)

      # BUSCAR LOS ASIENTOS DE PAGOS AL PROVEEDOR  (400000)
      Filter [F:YDAE] Where TYP = 'ODG' and BPR = [M:BPOI]BPR(I) and MTC = '' and ACC = '400000'
      For [F:YDAE]
        # Trbegin [YDAE]
        [F:YDAE]MTC = LMARCA
        [F:YDAE]MTCDAT = date$
        LTOTAL_PAGADO += [F:YDAE]AMTCUR
        Trbegin [YDAE]
        Rewrite [F:YDAE]
        If !fstat Then
          Commit
        Else
          Rollback
        Endif
        # BUSCAR VENCIMIENTO DEL ASIENTO ODG DE COMPRA PARA MARCARLO COMO SALDADO - De momento no hace falta saldar este vencimiento
#        If [F:YDAE]AMTCUR <> 0 Then
#          Read [F:YDUD]DUD0=[F:YDAE]TYP;[F:YDAE]NUM
#          Call ECR_TRACE("PASO 1 - Actulización de vencimiento del asiento  " + [F:YDAE]NUM, 0) From GESECRAN
#          If !fstat Then
#            Call ECR_TRACE("PASO 1 - DENTRO - Marco vencimiento de " + [F:YDAE]NUM + " como saldado", 0) From GESECRAN
#            # Trbegin [YDUD]
#            [F:YDUD]PAYCUR = [F:YDAE]AMTCUR
#            [F:YDUD]PAYLOC = [F:YDAE]AMTCUR
#            [F:YDUD]FLGCLE = 2
#            Trbegin [YDUD]
#            Rewrite [F:YDUD]
#            If !fstat Then
#              Commit
#            Else
#              Rollback
#            Endif
#          Endif
#        Endif
      Next
      If LTOTAL_PAGADO <> 0 Then
        Read [F:YDUD]DUD0=[M:BPOI]TYP(I);[M:BPOI]NUM(I)
        Call ECR_TRACE("PASO 3 - Actulización de vencimiento de la factura " + [M:BPOI]NUM(I), 0) From GESECRAN
        If !fstat Then
          Call ECR_TRACE("PASO 3 - DENTRO - Actulización de vencimiento de la factura " + num$(LTOTAL_PAGADO), 0) From GESECRAN
          # Trbegin [YDUD]
          [F:YDUD]PAYCUR = [F:YDUD]PAYCUR + LTOTAL_PAGADO
          [F:YDUD]PAYLOC = [F:YDUD]PAYLOC + LTOTAL_PAGADO
          [F:YDUD]FLGCLE = 2 # FLAG DE FACTURA SALDADA
          Trbegin [YDUD]
          Rewrite [F:YDUD]
          If !fstat Then
            Commit
          Else
            Rollback
          Endif
        Endif
      Endif
      # ACTUALIZAR MARCAJE FACTURA
      # Trbegin [YDAE]
      # Read [F:YDAE]YDAE=[M:BPOI]TYP(I);[M:BPOI]NUM(I)
#      Filter [F:YDAE] Where TYP = [M:BPOI]TYP(I) and NUM = [M:BPOI]NUM(I) and BPR = [M:BPOI]BPR(I)
#      Read [F:YDAE] First
#      If !fstat Then
#       [F:YDAE]MTC = LMARCA
#       [F:YDAE]MTCDAT = date$
#       Trbegin [YDAE]
#       Rewrite [F:YDAE]
#       If !fstat Then
#        Commit
#       Else
#        Rollback
#       Endif
#      Endif

    Endif
  Next


Return

#####################################################################################################
$GEN_ASIENTO_COMPENSACION
Global Char ASAS(30)
Local Char    LDIRIMPORT(250) : LDIRIMPORT = filpath("IMPBI","","")
Local Char    LFILE_W(200) : LFILE_W = "YCOMP"
Local Char    LDATCAB(100)(0..9)
Local Char    LDATLIN(100)(0..12)
Local Char    LFECHA(10), LHORA(10) : Raz LFECHA, LHORA
Local Char    LSEP(1) : LSEP = ";"  # separador

Local Decimal LTOTAL_CUADRE # Variable para el asiento de Cuadre

  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
  LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

  LDIRIMPORT += "\"
  LFILE_W = LDIRIMPORT + LFILE_W + "_" + LFECHA + LHORA + ".txt"

  mkstat = 0 : fstat = 0 : GERRTRACE = 0


  # borramos el fichero si existe...
  If filinfo(LFILE_W, 7) > 0 Then
    System "ae_rm " + LFILE_W
  Endif

  # abrir el fichero para escritura
  Gosub OPEN_FILE_W
  # CABECERA
  LDATCAB(1)  = 'G'                                                         #
  LDATCAB(2)  = 'ODG'                                                       # TYP
  LDATCAB(3)  = ''                                                          # NUM
  LDATCAB(4)  = LFCY                                                        # fcy - modificar para seleccionar la del asient
  LDATCAB(5)  =  'ODG'                                                      # JOU
  LDATCAB(6)  =  LFECHA                                                     # JOU
  LDATCAB(7)  = 'LIQUIDACIÓN MENSUAL CS ' + LBPR                            # REF
  LDATCAB(8)  = 'EUR'                                                       # CUR

  Wrseq LDATCAB(1) + LSEP + LDATCAB(2) + LSEP + LDATCAB(3) + LSEP + LDATCAB(4) + LSEP + LDATCAB(5) + LSEP + LDATCAB(6) + LSEP +
&     LDATCAB(7) + LSEP + LDATCAB(8) Using [ZIMP_W]

  # LINEAS
  LDATLIN(1)  = 'D'                                                         #
  LDATLIN(2)  = '1'                                                          # LIN
  LDATLIN(3)  = '1'                                                          # LEDTYP
  LDATLIN(4)  = '1'                                                          # IDTLIN
  LDATLIN(5)  =  LFCY                                                       # FCYLIN
  LDATLIN(6)  = 'P000'                                                      # SAC
  LDATLIN(7)  = '400000'                                                    # ACC
  LDATLIN(8)  = LBPR                                                        # BPR
  LDATLIN(9)  = 'LIQUIDACIÓN MENSUAL CS ' + LBPR                            # DES
  LDATLIN(10)  = '1'                                                        # SNS
  LDATLIN(11)  = num$(LRESTO_FACTURA_COMPRA)                                # AMTCUR
  LDATLIN(12)  = 'EUR'                                                      # CUR

  Wrseq LDATLIN(1) + LSEP + LDATLIN(2) + LSEP + LDATLIN(3) + LSEP + LDATLIN(4) + LSEP + LDATLIN(5) + LSEP + LDATLIN(6) + LSEP +
&     LDATLIN(7) + LSEP + LDATLIN(8) + LSEP + LDATLIN(9) + LSEP + LDATLIN(10) + LSEP + LDATLIN(11) + LSEP + LDATLIN(12) Using [ZIMP_W]

  LDATLIN(1)  = 'D'                                                        #
  LDATLIN(2)  = '2'                                                         # LIN
  LDATLIN(3)  = '1'                                                        # LEDTYP
  LDATLIN(4)  = '2'                                                         # IDTLIN
  LDATLIN(5)  =  LFCY                                                      # FCYLIN
  LDATLIN(6)  = 'C300'                                                     # SAC
  LDATLIN(7)  = '430000'                                                   # ACC
  LDATLIN(8)  = LBPR                                                       # BPR
  LDATLIN(9)  = 'LIQUIDACIÓN MENSUAL CS '+ LBPR                            # DES
  LDATLIN(10)  = '-1'                                                       # SNS
  LDATLIN(11)  = num$(LRESTO_FACTURA_VENTA)
  LDATLIN(12)  = 'EUR'                                                     # CUR

  Wrseq LDATLIN(1) + LSEP + LDATLIN(2) + LSEP + LDATLIN(3) + LSEP + LDATLIN(4) + LSEP + LDATLIN(5) + LSEP + LDATLIN(6) + LSEP +
&     LDATLIN(7) + LSEP + LDATLIN(8) + LSEP + LDATLIN(9) + LSEP + LDATLIN(10) + LSEP + LDATLIN(11) + LSEP + LDATLIN(12) Using [ZIMP_W]

  If LRESTO_FACTURA_VENTA <> LRESTO_FACTURA_COMPRA Then
    LDATLIN(1)  = 'D'                                                         #
    LDATLIN(2)  = '3'                                                          # LIN
    LDATLIN(3)  = '1'                                                         # LEDTYP
    LDATLIN(4)  = '3'                                                          # IDTLIN
    LDATLIN(5)  =  LFCY                                                       # FCYLIN
    LDATLIN(6)  = ''                                                          # SAC
    LDATLIN(7)  = '555010'                                                    # ACC
    LDATLIN(8)  = LBPR                                                        # BPR
    LDATLIN(9)  = 'LIQUIDACIÓN MENSUAL CS ' + LBPR                            # DES
    Local Char LSNS
    If LRESTO_FACTURA_VENTA > LRESTO_FACTURA_COMPRA Then
       LDATLIN(10)  = '1' #  DEBE
       LSNS = '-1'
       LTOTAL_CUADRE = LRESTO_FACTURA_VENTA
    Else
       LDATLIN(10)  = '-1'  #  HABER                                          # SNS
       LSNS = '1'
       LTOTAL_CUADRE = LRESTO_FACTURA_COMPRA
    Endif                                                                    # SNS
    LDATLIN(11)  = num$(abs(LRESTO_FACTURA_VENTA - LRESTO_FACTURA_COMPRA))   # AMTCUR
    LDATLIN(12)  = 'EUR'                                                     # CUR

    Wrseq LDATLIN(1) + LSEP + LDATLIN(2) + LSEP + LDATLIN(3) + LSEP + LDATLIN(4) + LSEP + LDATLIN(5) + LSEP + LDATLIN(6) + LSEP +
&     LDATLIN(7) + LSEP + LDATLIN(8) + LSEP + LDATLIN(9) + LSEP + LDATLIN(10) + LSEP + LDATLIN(11) + LSEP + LDATLIN(12) Using [ZIMP_W]

  Endif
  Gosub CLOSE_FILE_W

  Call IMPORTSIL("YGASLIQ",LFILE_W) From GIMPOBJ                      # lanza la imporación de presupuesto de venta



Return

#####################################################################################################
$GEN_ASIENTO_LIQUIDACION
Global Char ASAS(30)
Local Char    LDIRIMPORT(250) : LDIRIMPORT = filpath("IMPBI","","")
Local Char    LFILE_W(200) : LFILE_W = "YLIQ"
Local Char    LDATCAB(100)(0..9)
Local Char    LDATLIN(100)(0..12)
Local Char    LFECHA(10), LHORA(10) : Raz LFECHA, LHORA
Local Char    LSEP(1) : LSEP = ";"  # separador


  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)
  LHORA  = vireblc(num$(time$),4) : LHORA  = mid$(LHORA,1,2)+mid$(LHORA,4,2)+mid$(LHORA,7,2)

  LDIRIMPORT += "\"
  LFILE_W = LDIRIMPORT + LFILE_W + "_" + LFECHA + LHORA + ".txt"

  mkstat = 0 : fstat = 0 : GERRTRACE = 0
  # si se lanza la tarea batch
#  If !GSERVEUR Then
#    Call TEMPON("Proceso actualización de pedidos") From GESECRAN
#    Call OUVRE_TRACE ("Proceso actualización de pedidos") From LECFIC
#  Endif

  # borramos el fichero si existe...
  If filinfo(LFILE_W, 7) > 0 Then
    System "ae_rm " + LFILE_W
  Endif

  # abrir el fichero para escritura
  Gosub OPEN_FILE_W
  # CABECERA
  LDATCAB(1)  = 'G'                                                         #
  LDATCAB(2)  = 'LIQ'                                                       # TYP
  LDATCAB(3)  = ''                                                          # NUM
  LDATCAB(4)  = LFCY                                                        # fcy - modificar para seleccionar la del asient
  LDATCAB(5)  =  'LIQ'                                                      # JOU
  LDATCAB(6)  =  LFECHA                                                     # JOU
  LDATCAB(7)  = 'LIQUIDACIÓN MENSUAL CS ' + LBPR                            # REF
  LDATCAB(8)  = 'EUR'                                                       # CUR

  Wrseq LDATCAB(1) + LSEP + LDATCAB(2) + LSEP + LDATCAB(3) + LSEP + LDATCAB(4) + LSEP + LDATCAB(5) + LSEP + LDATCAB(6) + LSEP +
&     LDATCAB(7)  Using [ZIMP_W]

  # LINEAS
  LDATLIN(1)  = 'D'                                                         #
  LDATLIN(2)  = '1'                                                         # LIN
  LDATLIN(3)  = '1'                                                         # LEDTYP
  LDATLIN(4)  = '1'                                                         # IDTLIN
  LDATLIN(5)  =  LFCY                                                       # FCYLIN
  LDATLIN(6)  = 'P000'
  If LSNS = '-1' Then # debbe                                               # SAC
      LDATLIN(7)  = '430000'                                                # ACC
      LDATLIN(10)  = '1'
  Else                # haber
      LDATLIN(7)  = '400000'
      LDATLIN(10)  = '-1'
  Endif
  LDATLIN(8)  = LBPR                                                        # BPR
  LDATLIN(9)  = 'LIQUIDACIÓN MENSUAL CS ' + LBPR                            # DES
                                                     # SNS
#  LDATLIN(11)  = num$(LTOTAL_CUADRE)                                        # AMTCUR           #JC.09032021
  LDATLIN(11)  = num$(num$(abs(LRESTO_FACTURA_VENTA - LRESTO_FACTURA_COMPRA)))  # AMTCUR        #JC.09032021
  LDATLIN(12)  = 'EUR'                                                      # CUR

  Wrseq LDATLIN(1) + LSEP + LDATLIN(2) + LSEP + LDATLIN(3) + LSEP + LDATLIN(4) + LSEP + LDATLIN(5) + LSEP + LDATLIN(6) + LSEP +
&     LDATLIN(7) + LSEP + LDATLIN(8) + LSEP + LDATLIN(9) + LSEP + LDATLIN(10) + LSEP + LDATLIN(11) + LSEP + LDATLIN(12) Using [ZIMP_W]

  LDATLIN(1)  = 'D'                                                         #
  LDATLIN(2)  = '2'                                                          # LIN
  LDATLIN(3)  = '1'                                                         # LEDTYP
  LDATLIN(4)  = '2'                                                          # IDTLIN
  LDATLIN(5)  =  LFCY                                                       # FCYLIN
  LDATLIN(6)  = ''                                                          # SAC
  LDATLIN(8)  = LBPR                                                        # BPR
  LDATLIN(9)  = 'LIQUIDACIÓN MENSUAL CS ' + LBPR                            # DES
  LDATLIN(7)  = '555010'                                                    # ACC
  If LSNS = '-1' Then #                                                     # SAC
      LDATLIN(10)  = '-1'
  Else                #
      LDATLIN(10)  = '1'
  Endif                                                                     # SNS
#  LDATLIN(11)  = num$(LTOTAL_CUADRE)   # LTOTAL_COBRADO - LTOTAL_PAGADO     # AMTCUR                                             #JC.09032021
  LDATLIN(11)  = num$(num$(abs(LRESTO_FACTURA_VENTA - LRESTO_FACTURA_COMPRA)))   # LTOTAL_COBRADO - LTOTAL_PAGADO     # AMTCUR    #JC.09032021
  LDATLIN(12)  = 'EUR'                                                      # CUR

  Wrseq LDATLIN(1) + LSEP + LDATLIN(2) + LSEP + LDATLIN(3) + LSEP + LDATLIN(4) + LSEP + LDATLIN(5) + LSEP + LDATLIN(6) + LSEP +
&     LDATLIN(7) + LSEP + LDATLIN(8) + LSEP + LDATLIN(9) + LSEP + LDATLIN(10) + LSEP + LDATLIN(11) + LSEP + LDATLIN(12) Using [ZIMP_W]

  Gosub CLOSE_FILE_W

  Call IMPORTSIL("YGASLIQ",LFILE_W) From GIMPOBJ                      # lanza la imporación de presupuesto de venta



#  If !GSERVEUR Then
#    Call TEMPOFF() From GESECRAN
#    # fin de traza
#    Call ECR_TRACE("Fichero " + ctrans(LFILE_W,"\","/") + " generado", 0) From GESECRAN
#    Call ECR_TRACE("-------------------------------------", 0) From GESECRAN
#    Call FERME_TRACE From LECFIC
#
#    mkstat = 0 : fstat = 0 : GERRTRACE = 0 : GOK = 1
#  Endif

Return



