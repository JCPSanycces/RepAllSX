#<AdxTL>@(#)0.0.0.0 $Revision$
##===============================================================================
## WS de stocks
##===============================================================================
Subprog XWSSTJ(FCY_REQ,ITM_REQ,STA_REQ,FCY,ITM,STA,QTY,STU)
  Value Char FCY_REQ
  Value Char ITM_REQ
  Value Char STA_REQ
  Variable Char FCY()()
  Variable Char ITM()()
  Variable Char STA()()
  Variable Decimal QTY()
  Variable Char STU()()


  Local Char CRITERIO1(255)
  Local Decimal QTY_STA
  Local Integer JJ

  If !clalev([F:ITM]) : Local File ITMMASTER [F:ITM] : Endif
  If !clalev([F:STO]) : Local File STOCK     [F:STO] : Endif

  CRITERIO1 = '1=1 '
  If FCY_REQ <> ''
    CRITERIO1 += ' & STOFCY = "' + FCY_REQ + '"'
  Endif
  If ITM_REQ <> ''
    CRITERIO1 += ' & ITMREF = "' + ITM_REQ + '"'
  Endif
  If STA_REQ <> ''
    CRITERIO1 += ' & STA = "' + STA_REQ + '"'
  Endif

  Raz JJ

  Filter [F:STO] Where evalue(CRITERIO1) Order By Key AGRP=STOFCY;ITMREF;STA
  For [F:STO] AGRP(1)
    QTY_STA = 0
    For [F:STO] AGRP(2)
      QTY_STA = 0
      For [F:STO] AGRP(3)
        QTY_STA = 0
        For [F:STO] AGRP
          QTY_STA += [F:STO]QTYSTU
        Next

        FCY(JJ) = [F:STO]STOFCY
        ITM(JJ) = [F:STO]ITMREF
        STA(JJ) = [F:STO]STA
        QTY(JJ) = QTY_STA
        Read [F:ITM]ITM0 = [F:STO]ITMREF
        If !fstat
          STU(JJ) = [F:ITM]STU
        Endif
        JJ += 1
      Next
    Next
  Next
  Filter [F:STO]
End
##===============================================================================

