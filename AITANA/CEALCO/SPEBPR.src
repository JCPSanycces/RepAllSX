#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
  Case ACTION
    When "VERIF_CRE" : Gosub VERIF_CRE
    When Default
  Endcase
Return
########################################################################

$VERIF_CRE
#Infbox("VERIF")
If !clalev([F:XBPR])  : Local File BPARTNER     [XBPR]  : Endif
Local Integer CONT_NIF
Filter [XBPR] Where CRN = [M:BPRC]CRN
For [XBPR]
  CONT_NIF = 1
  Break
Next
If CONT_NIF = 1 Then
    #En las facturas FCC es obligatorio introducir el cliente asociado
    GERR = 1
    GMESSAGE = "El tercero"-[XBPR]BPRNUM+", tiene el mismo NIF " : mkstat = 2
    OK = 0
Endif

Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla BPRBPC) 04/04/2019 11:39:21 (ADMIN)
######################################################################################
Subprog C_CRN(VALEUR)
Variable Char    VALEUR()
If !clalev([F:XBPR])  : Local File BPARTNER     [XBPR]  : Endif
Local Integer CONT_NIF
Filter [XBPR] Where CRN = VALEUR
For [XBPR]
  CONT_NIF = 1
  Break
Next
If CONT_NIF = 1 Then
    If GUSER <> 'WS' Then
      GMESSAGE = "El tercero"-[XBPR]BPRNUM+", tiene el mismo NIF " : mkstat = 2
    Else
      GERR = 1
      GMESSAGE = ''
      Append GMESSAGE, '{'
      Append GMESSAGE, '"BPCNUM":' + '"'+ [XBPR]BPRNUM +'"'
      Append GMESSAGE, '}'
    Endif
    mkstat = 2
    #OK = 0
Endif
End


######################################################################################

