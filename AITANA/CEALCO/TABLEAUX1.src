##--  Proceso V7 P7
##----------------------------------------------------------------------------

#<AdxTL>@(#)6.0.0.0 $Revision$
########################################################
## Déclaration des variables
########################################################
$DECLARE
Local Char SAVACT(GLONACT) : SAVACT=ACTION

ACTION = "DEFLIG1" : Gosub T_ACTION   :# @YMIG@
Local Char    FICLIG(GLONATB) , ABLIG(GLONABR) , CRIT(250) , TRTLIG1(1)   :# @YMIG@
Local Integer STAT , SIGN , MAXLIG1   :# @YMIG@
Local Integer ONUM1(evalue("dim([M]"+ZONLIG+")"))   :# @YMIG@

ACTION=SAVACT
Return

########################################################
## Lecture des lignes
########################################################
$LIENS
Local Char SAVACT(GLONACT) : SAVACT=ACTION

ACTION = "DEFLIG1" : Gosub T_ACTION     :# @YMIG@
Assign "[G:"+ABLIG+"]currind" With 1              : # mbt 24/04/2002
Assign "[G:"+ABLIG+"]currlen" With 0              : # mbt 24/04/2002
nolign = 0
For [F] Where evalue(CRIT)
 If nolign>=dim([M]UPDFLG1)                  :# @YMIG@
  Break
 Endif
 nolign += 1
 [M] = [F]
 [M]UPDFLG1(nolign-1) = 0                          : # Flag de modif        :# @YMIG@
 [M]CREFLG1(nolign-1) = nolign                     : # Flag d'annulation      :# @YMIG@
 ONUM1(nolign-1)      = evalue("[F]"+ZONLIG)       : # Identificateur pour annul  :# @YMIG@
 ACTION = "LIENS_LIG1" : Gosub T_ACTION                       :# @YMIG@
Next
[M]NBLIG1 = nolign        :# @YMIG@
MAXLIG1 = nolign        :# @YMIG@

ACTION=SAVACT
Return

########################################################
## Enregistrement des lignes
########################################################
$CREATION
Local Char SAVACT(GLONACT) : SAVACT=ACTION

ACTION = "DEFLIG1" : Gosub T_ACTION                       :# @YMIG@
Assign "[G:"+ABLIG+"]currind" With 1                 : # mbt 24/04/2002
Assign "[G:"+ABLIG+"]currlen" With 0                 : # mbt 24/04/2002
For nolign=1 To [M]NBLIG1                           :# @YMIG@
 Raz [F]
 [F] = [M]
 Assign "[F]"+ZONLIG With 1000*nolign : # On numérote de 1000 en 1000
 Gosub INICRE_LIG1                                :# @YMIG@
 # GA 11/2007 fait dans INIMOD_LIG pour les appels directs à cette action
 #ACTION = "INICRE_LIG" : Gosub T_ACTION
 If GOK<1 : Break : Endif : # Propagation des erreurs
 Write
 If fstat
  GOK=0 : Call FSTA(ABLIG) From GLOCK : Break
 Endif
 TRTLIG1 = "C"                                  :# @YMIG@
 SIGN = +1 : Gosub VALLIG1                            :# @YMIG@
 If GOK<1 : Break : Endif : # Propagation des erreurs
Next nolign

ACTION=SAVACT
Return

########################################################
## Modification des lignes (optimisée)
########################################################
$MODIF
Local Char SAVACT(GLONACT) : SAVACT=ACTION
ACTION = "DEFLIG1" : Gosub T_ACTION                       :# @YMIG@
Assign "[G:"+ABLIG+"]currind" With 1                 : # mbt 24/04/2002
Assign "[G:"+ABLIG+"]currlen" With 0                 : # mbt 24/04/2002
## Première passe, lignes annulées
For nolign=1 To MAXLIG1                             :# @YMIG@
 If !find(nolign,[M]CREFLG1(0..[M]NBLIG1-1))                  :# @YMIG@
  Filter [F] Where evalue(CRIT) & evalue(ZONLIG+"="+num$(ONUM1(nolign-1)))    :# @YMIG@
  Readlock First
  Filter [F]
  If fstat=1
   GOK=-1 : GLOCK = "$"+FICLIG1-num$(nolign) : Break              :# @YMIG@
  Elsif !fstat : # Au cas où
   TRTLIG1 = "A"                                :# @YMIG@
   SIGN = -1 : Gosub VALLIG1                          :# @YMIG@
   If GOK<1 : Break : Endif
   Delete
  Endif
 Endif
Next nolign
## Deuxième passe, créations et modifications
For nolign=1 To [M]NBLIG1                           :# @YMIG@
 If [M]CREFLG1(nolign-1)=0  : # C'est une nouvelle ligne                  :# @YMIG@
  Raz [F]
  [F] = [M]
  Gosub INICRE_LIG1                               :# @YMIG@
 # GA 11/2007 fait dans INIMOD_LIG pour les appels directs à cette action
 #ACTION = "INICRE_LIG" : Gosub T_ACTION
  If GOK<1 : Break : Endif
  Write
  If fstat
   GOK=0 : Call FSTA(ABLIG) From GLOCK : Break
  Endif
  TRTLIG1 = "C"                                 :# @YMIG@
  SIGN = +1 : Gosub VALLIG1                           :# @YMIG@
  If GOK<1 : Break : Endif
 Elsif [M]UPDFLG1(nolign-1)<>0 : # La ligne a été modifiée            :# @YMIG@
  Filter [F] Where evalue(CRIT) & evalue(ZONLIG+"=[M]"+ZONLIG+"("+num$(nolign-1)+")")
  Readlock First
  Filter [F]
  If fstat=1
   GOK=-1 : GLOCK = "$"+FICLIG1-num$(nolign) : Break              :# @YMIG@
  Elsif !fstat : # Au cas où
   TRTLIG1 = "M"                                :# @YMIG@
   SIGN = -1 : Gosub VALLIG1                          :# @YMIG@
   If GOK<1 : Break : Endif
  Endif
  [F] = [M]
  Gosub INIMOD_LIG1                               :# @YMIG@
 # GA 11/2007 fait dans INIMOD_LIG pour les appels directs à cette action
 #ACTION = "INIMOD_LIG" : Gosub T_ACTION
  If GOK<1 : Break : Endif
  Rewrite
  If fstat
   GOK=0 : Call FSTA(ABLIG) From GLOCK : Break
  Endif
  TRTLIG1 = "M"                                 :# @YMIG@
  SIGN = +1 : Gosub VALLIG1                           :# @YMIG@
  If GOK<1 : Break : Endif
 Endif
Next nolign

ACTION=SAVACT
Return

$ANNULE
Local Char CRIT(250) , TRTLIG(1)
Local Integer SIGN
Local Char SAVACT(GLONACT) : SAVACT = [L]ACTION

[L]ACTION = "DEFLIG1" : Gosub T_ACTION                      :# @YMIG@
Assign "[G:"+ABLIG+"]currind" With 1              : # mbt 24/04/2002
Assign "[G:"+ABLIG+"]currlen" With 0              : # mbt 24/04/2002
For [F] Where evalue(CRIT)
 [L]TRTLIG1 = "A"                               :# @YMIG@
 [L]SIGN = -1 : Gosub VALLIG1                         :# @YMIG@
 If GOK<1 : Break : Endif
Next
If GOK<1 : Return : Endif
Delete [F] Where evalue(CRIT)
If fstat=1
 GOK=-1 : GLOCK = "$"+FICLIG1 : Return                      :# @YMIG@
Endif

[L]ACTION = SAVACT
Return

# Traitements complémentaires (stocks, en-cours clients, ....)
$VALLIG1                                    :# @YMIG@
[L]ACTION = "VALLIG1" : Gosub T_ACTION                      :# @YMIG@
Return

###############################################################
$T_ACTION
GPE = 0
GPV = 0
If dim(PSPE)>0 & PSPE
 If GTEST : Infbox PROGSPE+".$"+ACTION At (24,80) : Endif
 Gosub ACTION From =PROGSPE
Endif
If dim(PSPV)>0 & PSPV & !GPV
 If GTEST : Infbox PROGSPV+".$"+ACTION At (24,80) : Endif
 Gosub ACTION From =PROGSPV
Endif
If dim(PSUB)>0 & PSUB & !GPE
 If GTEST : Infbox PROGSUB+".$"+ACTION At (24,80) : Endif
 Gosub ACTION From =PROGSUB
Endif
Return

###############################################################
#-------------------------------------------#
# initialisation date creation et operateur #
#-------------------------------------------#
# @YMIG@
$INICRE_LIG1
If evalue ("dim([F:"+ABLIG+"]CREDAT)") > 0
 Assign "[F:"+ABLIG+"]CREDAT" With date$
Endif
If evalue ("dim([F:"+ABLIG+"]CRETIM)") > 0
 Assign "[F:"+ABLIG+"]CRETIM" With time
Endif
If evalue ("dim([F:"+ABLIG+"]CREUSR)") > 0
 Assign "[F:"+ABLIG+"]CREUSR" With GUSER
Endif
If evalue ("dim([F:"+ABLIG+"]EXPNUM)") > 0
 Assign "[F:"+ABLIG+"]EXPNUM" With [C]EXPORT
Endif
# GA 11/2007
ACTION = "INICRE_LIG1" : Gosub T_ACTION   :# @YMIG@
Return

#----------------------------------------#
# initialisation date modif et operateur #
#----------------------------------------#
# @YMIG@
$INIMOD_LIG1
If evalue ("dim([F:"+ABLIG+"]UPDDAT)") > 0
 Assign "[F:"+ABLIG+"]UPDDAT" With date$
Endif
If evalue ("dim([F:"+ABLIG+"]UPDTIM)") > 0
 Assign "[F:"+ABLIG+"]UPDTIM" With time
Endif
If evalue ("dim([F:"+ABLIG+"]UPDUSR)") > 0
 Assign "[F:"+ABLIG+"]UPDUSR" With GUSER
Endif
If evalue ("dim([F:"+ABLIG+"]EXPNUM)") > 0
 Assign "[F:"+ABLIG+"]EXPNUM" With [C]EXPORT
Endif
# GA 11/2007
ACTION = "INIMOD_LIG1" : Gosub T_ACTION   :# @YMIG@
Return

########################################################################
# Contrôle de l'insertion
Subprog INSERE(ZONLIG)
Value Char ZONLIG

If status= 72 | status= 73
 #-----------------------------------------------#
 # cg le 6 Mars 1998                             #
 # problème lors de l'insertion d'une ligne en   #
 # première position dans un tableau si tous les #
 # enregistrements n'ont pas été chargés dans    #
 # celui-ci : risque de dupplicate key           #
 # (cf commandes ouvertes)                       #
 #-----------------------------------------------#
 If dim(GQSEQ) >=0
  If (nolign=1 & evalue("[M]"+ZONLIG+"(0)")=GQSEQ+1)
&  | (nolign>1 & evalue("[M]"+ZONLIG+"("+num$(nolign-1)+")")
&  =evalue("[M]"+ZONLIG+"("+num$(nolign-2)+")")+1)
   Call ERREUR (mess(122,199,1)) From GESECRAN
   mkstat = 2
  Endif
 Else
  If (nolign=1 & evalue("[M]"+ZONLIG+"(0)")=1)
&  | (nolign>1 & evalue("[M]"+ZONLIG+"("+num$(nolign-1)+")")
&  =evalue("[M]"+ZONLIG+"("+num$(nolign-2)+")")+1)
   Call ERREUR (mess(122,199,1)) From GESECRAN
   mkstat = 2
  Endif
 Endif
Endif
End

########################################################################
# Attribution du no de ligne en saisie
Subprog LINNUM(ZONLIG)
Value Char ZONLIG
#-------------------------------------------------------#
# MB 28/9/98 Sortie de saisie par Return -> status 71   #
# MB 30/3/99 Changement de ligne en modif -> status 75  #
#-------------------------------------------------------#
Local Integer OK
OK  = 0
OK += (status=6)
OK += (status=7)
OK += (status>=27 & status<=70)
OK += (status>=72 & status<=74)
OK += (status>=76 & status<=91)
OK += (status>=94 & status<=99)
OK += (status >= 1792)
If OK : End : Endif

[M]UPDFLG1(nolign-1)=1                            :# @YMIG@

If evalue("[M]"+ZONLIG+"("+num$(nolign-1)+")")=0
 Local Integer NOL , NOL1 , NOL2 , DEB , FIN , INC
 NOL1 = nolign-1
 While NOL1>0 & [M]CREFLG1(NOL1-1)=0 : NOL1 -= 1 : Wend           :# @YMIG@
 #-----------------------------------------------#
 # cg le 6 Mars 1998                             #
 # problème lors de l'insertion d'une ligne en   #
 # première position dans un tableau si tous les #
 # enregistrements n'ont pas été chargés dans    #
 # celui-ci : risque de dupplicate key           #
 # (cf commandes ouvertes)                       #
 #-----------------------------------------------#
 If NOL1<=0
  DEB = 0
  If dim (GQSEQ) >= 0 : DEB = GQSEQ : Endif    : # cg
 Else
  DEB = evalue("[M]"+ZONLIG+"("+num$(NOL1-1)+")")
 Endif
 NOL2 = nolign-1
 While NOL2<[M]NBLIG1-1 & [M]CREFLG1(NOL2+1)=0 : NOL2 += 1 : Wend     :# @YMIG@
 If NOL2>=[M]NBLIG1-1                           :# @YMIG@
  If (DEB=0 | NOL1>0) & (NOL2=0 | evalue("[M]"+ZONLIG+"("+num$(NOL2-1)+")")>0) & NOL1=NOL2
   If NOL2=0
    Assign "[M]"+ZONLIG+"("+num$(NOL2)+")" With 1000
   Else
    Assign "[M]"+ZONLIG+"("+num$(NOL2)+")" With evalue("[M]"+ZONLIG+"("+num$(NOL2-1)+")")+1000
   Endif
  Else
   For NOL=NOL1 To NOL2
    Assign "[M]"+ZONLIG+"("+num$(NOL)+")" With  DEB+1000*(NOL-NOL1+1)
   Next
  Endif
 Else
  FIN = evalue("[M]"+ZONLIG+"("+num$(NOL2+1)+")")
  INC = int((FIN-DEB)/(NOL2-NOL1+2))
  If INC<1
   Call ERREUR (mess(122,199,1)) From GESECRAN
   mkstat=2 : End
  Else
   For NOL=NOL1 To NOL2
    Assign "[M]"+ZONLIG+"("+num$(NOL)+")" With DEB+INC*(NOL-NOL1+1)
   Next NOL
  Endif
 Endif
Endif
End






