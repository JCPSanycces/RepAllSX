#<AdxTL>@(#)0.0.0.0 $Revision$
# Mobile specific code
# This is representation code only (dedicated to user interface) :
#   Add an automatic comment

$METHODS
  If [L]CURPTH=""
    Case [L]ACTION
      When "AINSERT_CONTROL_BEFORE"
        this.ZOH.COMMENT="Created from a mobile phone by"-this.ACTX.USER-format$("D:[Date : ]8M[ ]2D[, ]4Y[ ]hh[:]mm[:]ss",date$)
    Endcase
  Endif
Return

$PROPERTIES
  Case CURPRO
    When "ZOH.CUSTOMER"
      Case ACTION
        When "PROPAGATE"
           Local File BPCUSTOMER
           Read [BPC]BPC0=this.CUSTOMER
           If fstat=0
             this.CURRENCY=[BPC]CUR
           Else
             ASTATUS=fmet this.ASTERROR("CUSTOMER","Customer has no default  currency, input forbidden",[V]CST_AERROR)
           Endif
        Endcase
    When "ZOH.FCY"
      Case ACTION
        When "INIT"
          Local Char DEFCOMP(20)
          DEFCOMP=fmet this.ACTX.APARAM.AGETUSERVALCHAR("SOCDEF")
          Local File COMPANY
          Read [CPY]CPY0=DEFCOMP
          If fstat=0
            this.FCY=[CPY]MAIFCY
          Endif
          If  fstat<>0 or this.FCY=""
             ASTATUS=fmet this.ASTERROR("","no default site found, input impossible",[V]CST_AERROR)
          Endif
      Endcase
  Endcase
Return

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

