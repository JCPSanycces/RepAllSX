#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Additional actions on simplified sales order : manage constraints linked to shipping

# Events related to property rules : CURPRO is the current property
$PROPERTIES
  Case [L]CURPRO
    When "CUSTOMER"
      If ARULE="CONTROL" : # For processed orders, modifying customer is forbidden
        If this.snapshot.CUSTOMER<>this.CUSTOMER
          If max(0,this.LINES(1..maxtab(this.LINES)).DLVQTY)>0
            ASTATUS=fmet this.ASETERROR(CURPRO,"Customer cannot be changed",[V]CST_AERROR)
          Endif
        Endif
      Endif
    When "LINES.DLVQTY" : # Delivered quantity can only be changed in "SHIP" operation
      If ARULE="CONTROL"
        If this.snapshot.DLVQTY<>this.DLVQTY and this.APARENT.OPERATION<>"SHIP"
          [L]ASTATUS=fmet this.ASETERROR(CURPRO,"Shipped quantity cannot be modified",[V]CST_AERROR)
        Endif
      Endif
    When "LINES.QTY" : # quantity cannot be smaller than shipped quantity
      If ARULE="CONTROL"
        If this.DLVQTY>this.QTY
          [L]ASTATUS=fmet this.ASETERROR(CURPRO,"Already"-num$(this.DLVQTY)-"shipped",[V]CST_AERROR)
        Endif
      Endif
  Endcase
Return

# Events related to class standard methods: CURPTH is the instance, AMETHOD the method code
# If CURPTH is empty, we are on the main class (sales order)
# If CURPTH="LINES", we are on the line collection

$EVENTS
  Case [L]CURPTH
    When "LINES"                                              : # LINE COLLECTION EVENTS
      Case [L]AEVENT
        When "ADDLINE_BEFORE"                                 : # Line insertion is requested
          If this.ORDSTA=4
            ASTATUS=fmet this.ASETERROR("","No line addition on invoiced order",[V]CST_AERROR)
          Endif
        When "ADELLINE_BEFORE"                                : # Line deletion is requested
          If this.ORDSTA=4
            ASTATUS=fmet this.ASETERROR("","No line deletion on invoiced order",[V]CST_AERROR)
          Endif
          Local Integer INDEX
          INDEX=fmet this.AGETINDBYLINE("LINES",ALINE)
          If this.LINES(INDEX).DLVQTY>0
            ASTATUS=fmet this.ASETERROR("","Shipped line cannot be deleted",[V]CST_AERROR)
          Endif
        When "ADELLINE_AFTER"  : this.QTY=0                    : # Line deleted : set quantity to 0
      Endcase

    When ""                                                  : # SALES ORDER EVENTS
      Case [L]AEVENT
        When "AINSERT_CONTROL_BEFORE","AUPDATE_CONTROL_BEFORE" : # Delivery status set according to qty
          Local Decimal SUM_QTY, SUM_DLVQTY
          SUM_QTY    = sum(0,this.LINES(1..maxtab(this.LINES)).QTY)
          SUM_DLVQTY = sum(0,this.LINES(1..maxtab(this.LINES)).DLVQTY)
          If SUM_DLVQTY=0            : this.ORDSTA=1         : # If no line shipped, ORDSTA=1
          Elsif SUM_QTY<>SUM_DLVQTY  : this.ORDSTA=2         : # If quantities different, ORDSTA=2
          Else               this.ORDSTA=max(this.ORDSTA,3)  : # Else ORDSTA=3 or 4
          Endif
      Endcase
  Endcase
Return

$OPERATIONS
  Case AOPERATION
    When "SHIP"    : Gosub SHIP From YSHIP                 : # Ship the order
    When "SHIPALL" : Gosub SHIPALL From YSHIPALL           : # Ship all the orders for the customer
  Endcase
Return

$METHODS
  Case AMETHOD
  Endcase
Return

