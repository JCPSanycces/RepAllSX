#<AdxTL>@(#)0.0.0.0 $Revision$
##==============================================================================
## XQ009: GAO(13/02/2019) Proponer PMP en el valor unitario.
##==============================================================================
$ACTION
  Case ACTION
    When "OUVRE" : Gosub OUVRE
  Endcase
Return
##==============================================================================
$OUVRE
Return
##==============================================================================
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()

  If clalev([F:XITV])=0 : Local File ITMMVT [XITV] : Endif

  Read [F:XITV]ITV0 = VALEUR;[M:SMR0]STOFCY
  If !fstat
    If GWEBSERV
      If [M:SMR1]PRI(nolign-1) <> [F:XITV]AVC and [F:XITV]AVC <> 0
        [M:SMR1]PRI(nolign-1) = [F:XITV]AVC
      Endif
    Else
      [M:SMR1]PRI(nolign-1) = [F:XITV]AVC
    Endif
    Affzo [M:SMR1]PRI(nolign-1)
  Endif

End
##==============================================================================
Subprog AM_PRI(VALEUR)
Variable Decimal VALEUR

  If GWEBSERV
    If clalev([F:XITV])=0 : Local File ITMMVT [XITV] : Endif
    Read [F:XITV]ITV0 = [M:SMR1]ITMREF(nolign-1);[M:SMR0]STOFCY
    If !fstat
      If VALEUR <> [F:XITV]AVC and [F:XITV]AVC <> 0
        VALEUR = [F:XITV]AVC
        Affzo [M:SMR1]PRI(nolign-1)
      Endif
    Endif
  Endif
End
##==============================================================================

