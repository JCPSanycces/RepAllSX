#<AdxTL>@(#)0.0.0.0 $Revision$
##===============================================================================
$ACTION
#If GUSER = 'DEV02' : Infbox(ACTION) : Endif
  Case ACTION
    When "VERIF_CRE"         : Gosub VERIF_CRE
    When Default
  Endcase
Return

##===============================================================================
$VERIF_CRE
  If GWEBSERV and GUSER = 'WS'

  If clalev([F:XSDH])=0 : Local File SDELIVERY [XSDH] : Endif
  If clalev([F:XSDD])=0 : Local File SDELIVERYD [XSDD] : Endif

  For Z=0 To [M:SRH1]NBLIG-1
    If [M:SRH1]DETSDHNUM(Z) <> ''
      Read [XSDH]SDH0 = [M:SRH1]DETSDHNUM(Z)
      If !fstat Then
        Read [XSDD]SDD0 = [M:SRH1]DETSDHNUM(Z);[M:SRH1]SDDLIN(Z)
        If fstat
            GERR = 1: GMESSAGE = 'No existe linea'-[M:SRH1]SDDLIN(Z)-'de la entrega'-[M:SRH1]DETSDHNUM(Z) :mkstat = 2
            OK=0
        Endif
      Else
          GERR = 1: GMESSAGE = 'No existe la entrega'-[M:SRH1]DETSDHNUM(Z) :mkstat = 2
          OK=0
      Endif
    Endif
  Next
  Endif
Return

