#<AdxTL>@(#)0.0.0.0 $Revision$
# PUBLISH THE SHIPMENT IN JSON FORMAT ON AN EXTERNAL WEB SERVER WITH A REST POST WEB SERVICE
$PUBLISH_SHIPMENT

# Variable declarations
Local Clbfile SHIPMENT_STRING(2), SHIPMENT_JSON(2)
Local Char PCOD(100)(1..10),PVAL(100)(1..10),HCOD(100)(1..10),HVAL(100)(1..10)
Local Clbfile RESHEAD(0),RESBODY(0)

# Store JSON shipment in a string: YSCRIPT.STRINGIFY stringifies its argument
  SHIPMENT_JSON=func YJSCRIPT.STRINGIFY(SHIPMENT)
  SHIPMENT_STRING='"'+escJson(SHIPMENT_JSON)+'"'

  # Call the web service with the argument : OK is the http status is (200 if no error)
  OK=func ASYRRESTCLI.EXEC_REST_WS("GENERIC","POST",func URL_BASE+"/shipment",PCOD, PVAL,
&                                  HCOD, HVAL, SHIPMENT_STRING, 0, "", RESHEAD, RESBODY)

Return

# REST GET WEB SERVICE TO GET THE PRICE OF AN ITEM FROM AN EXTERNAL WEB SERVER

Funprog PRICE(ITEM)
Variable Char ITEM()
Local Integer RETVAL,I, FUTURE : Local Decimal PRICE

# No additional parameter nor aditional header value are given here (only the values given in EXTERNAL definition are used)
Local Char PCOD(100)(1..10),PVAL(100)(1..10),HCOD(100)(1..10),HVAL(100)(1..10)
Local Clbfile DATA_SENT(0)

# Contains the result header and body
Local Clbfile RESHEAD(0),RESBODY(0)

  DATA_SENT="{}" : # No data is sent
  FUTURE=0       : # We wait for the answer

# Call the web service now
  RETVAL=func ASYRRESTCLI.EXEC_REST_WS("GENERIC","GET",func URL_BASE+"/prices/"+ITEM,
&            PCOD, PVAL, HCOD, HVAL, DATA_SENT, FUTURE, "price",RESHEAD, RESBODY)

# The service returns { "item" : ITEM_CODE, "price" : PRICE_VALUE } by default
# As we sent "price" in the request, only the price value is returned
# The web service is successful if return status is 200
  RESBODY=vireblc(RESBODY,4) : # Suppress leading / trailing spaces

  If RETVAL=200
    PRICE=val(RESBODY)
  Else
    PRICE=0
  Endif
End PRICE

# REST GET WEB SERVICE TO GET THE CURRENT RATE A FROM AN EXTERNAL WEB SERVER
# For the example, the web server is a fake one
Funprog RATE(CURRENCY)
Variable Char CURRENCY()
Local Integer RETVAL,I, FUTURE : Local Decimal RATE

# No additional parameter nor aditional header value are given here (only the values given in EXTERNAL definition are used)
Local Char PCOD(100)(1..10),PVAL(100)(1..10),HCOD(100)(1..10),HVAL(100)(1..10)
Local Clbfile DATA_SENT(0)

# Contains the result header and body
Local Clbfile RESHEAD(0),RESBODY(0)

  DATA_SENT="{}" : # No data is sent
  FUTURE=0       : # We wait for the answer

# Call the web service now
  RETVAL=func ASYRRESTCLI.EXEC_REST_WS("GENERIC","GET",func URL_BASE+"/rates/"+CURRENCY,
&            PCOD, PVAL, HCOD, HVAL, DATA_SENT, FUTURE, "rate",RESHEAD, RESBODY)

# The service returns { "currency" : CURRENCY_CODE, "rate" : RATE_VALUE } by default
# As we sent "rate" in the request, only the rate value is returned
# The web service is successful if return status is 200
  RESBODY=vireblc(RESBODY,4) : # Suppress leading / trailing spaces

  If RETVAL=200
    RATE=val(RESBODY)
  Else
    RATE=1
  Endif
End RATE

# Normally, we don't care about the base URL, because it is setup in the web service definition
# But here, we consider that the shipment server is on the same server than the main server,
# but with a different service number (we use 1337)
Funprog URL_BASE
Local Char URL_BASE(200)

# Read the external web server code (direct read to avoid buffer effects)
  Local File ADOVAL
  Read [ADW]ADW0="";"";"YWEBSERV"
  If fstat<>0 or [ADW]VALEUR=""
    URL_BASE=right$(baseUrl,2+instr(1,baseUrl,":")+1)
    URL_BASE=left$(URL_BASE,instr(1,URL_BASE,":"))+"1337"
  Else
    UTL_BASE=[ADW]VALEUR
  Endif
End URL_BASE

