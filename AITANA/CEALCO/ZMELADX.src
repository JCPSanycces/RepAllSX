Local Char FFIC(50)(1..5)
#Goto FICHERO
Local Char TT(250)(1..50)
FFIC(1) = 'PRUEBAPDF_10757'
TT(1)='Hola'
TT(2)=' envio de mail automático CEALCO'
TT(4) = 'Saludos'

#parametros(nombretxt a generar, correo que envia, destinatario, asunto; texto; fichero a adjuntar)
Call ZMELADX(filpath("tmp","prueba",""),"x3@cealco.es","mromero@quonext.com","prueba envio mail automatico",TT,FFIC)
#Call ZMELADX("fich1","prueba@leds-c4.com","divad14@hotmail.com","prueba envio mail automatico",TT,"")

End

####################################################################################
Subprog ZMELADX(FICH, FROMM, TTO, SUBJECT,TEXTO,FIC)
Value Char FICH, FROMM, TTO, SUBJECT, TEXTO,FIC

Local Char    FICHIER(GDIMFIC), ORDSYS(250)
Local Char    SERMES(50)
Local Integer STAT
Call PARAM("","SERMES",SERMES) From ADOVAL

FICHIER = filpath("tmp",FICH,"txt",0)
Openo FICHIER,0 Using [MES]
Iomode adxifs "" Using [MES]
Iomode adxirs chr$(10) Using [MES]
Iomode adxium GASCII Using [MES]

Wrseq "From: ";FROMM Using [MES]
Wrseq "To: ";TTO Using [MES]

SUBJECT = format$("KTv2:250X",SUBJECT)
If SUBJECT  <>""
 Wrseq "Subject: ";ctrans(SUBJECT) Using [MES]
Endif

Wrseq Using [MES]
Iomode adxium GUTF8 Using [MES]

Gosub TEXTOS
Wrseq Using [MES]

Local Char WPIECE,WSUF
Local Char FICHIER2(GDIMFIC)

WPIECE=FIC
WSUF='pdf'

#FICHIER2= filpath("tmp",WPIECE,WSUF)
FICHIER2 = GZFICHERO

Wrseq '# Application/pdf ; name="';WPIECE+"."+WSUF;'"'; Using [MES]
Wrseq '['+WPIECE+"."+WSUF+'] '; Using [MES]
Wrseq ' "';FICHIER2;'"' Using [MES]

Openo Using [MES]

ORDSYS = "meladx -r "+ TTO + " -s"-SERMES-"<"+FICHIER

Call SYSTEME(adxmac(0),ORDSYS,"",STAT) From ORDSYS

End

####################################################################################
$TEXTOS
For KK = 0 To dim(TEXTO)-1
    If KK<3
        Wrseq TEXTO(KK); Using [MES]
        Wrseq Using [MES]
    Else
        If TEXTO(KK)='' and TEXTO(KK-1)='' and TEXTO(KK-2)=''
        Else
            Wrseq TEXTO(KK); Using [MES]
            Wrseq Using [MES]
        Endif
    Endif
Next
Return

