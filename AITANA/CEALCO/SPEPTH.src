$ACTION
Case ACTION
 When "APRES_CRE" :  Gosub APRES_CRE
 When "FIN_PICK" :  Gosub FIN_PICK
 When Default
Endcase
Return

######################################################################################
$APRES_CRE

If [PTH]ZFLGSAL= 2 and GWEBSERV<>0
  Call MAJ_SOLDE From TRTACHRCP1
Endif


Return


Subprog C_NBLIG
End


######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla PTH1) 27/05/2019 16:26:27 (ADMIN)
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
If clalev([F:XITP])=0 : Local File ITMBPS [XITP] : Endif
If clalev([F:XITM])=0 : Local File ITMMASTER [XITM] : Endif

Read [XITP]ITP0= VALEUR;[M:PTH0]BPSNUM
If !fstat
  [M:PTH1]XITMBPS(nolign-1) = [XITP]ITMREFBPS
  Affzo [M:PTH1]XITMBPS(nolign-1)

#  [M:PTH1]ZITMDESBPS(nolign-1) = [XITP]ITMDESBPS
#  Affzo [M:PTH1]ZITMDESBPS(nolign-1)
Endif

End


######################################################################################

######################################################################################
$FIN_PICK
If clalev([F:XITP])=0 : Local File ITMBPS [XITP] : Endif
If clalev([F:XITM])=0 : Local File ITMMASTER [XITM] : Endif

Read [XITP]ITP0= [M:PTH1]ITMREF(nolign-1);[M:PTH0]BPSNUM
If !fstat
  [M:PTH1]XITMBPS(nolign-1) = [XITP]ITMREFBPS
  Affzo [M:PTH1]XITMBPS(nolign-1)
Endif


Return

