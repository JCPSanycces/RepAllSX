######################################################################################
Subprog C_CAJA(VALEUR)
Variable Char    VALEUR()
If VALEUR= ""
   End
Endif
If !clalev([F:BAN]): Local File BANK: Endif
Read [F:BAN]BAN0= VALEUR
If fstat
  GMESSAGE= "Banco o caja inexistente"
  mkstat=2
Endif
End


