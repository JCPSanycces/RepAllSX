#<AdxTL>@(#)0.0.0.0 $Revision$
######################################################################################
$ACTION

Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "LIENS_LIG"   : Gosub LIENS_LIG
 When "INICRE"      : Gosub INICRE
 When "CREATION"    : Gosub CREATION    From TABLEAUX
 When "MODIF"       : Gosub MODIF       From TABLEAUX
 When "ANNULE"      : Gosub ANNULE      From TABLEAUX
 When "APRES_CRE"   : Gosub LIENS       From TABLEAUX : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub LIENS       From TABLEAUX
 When "INICRE_LIG"  : [F:YSID]NUM = [M:YSIH0]NUM
 When "DEFLIG"      : Gosub DEFLIG
 When "SETBOUT"     : Gosub SETBOUT
 When "EXEBOUT"     : Gosub EXEBOUT
 When Default
Endcase
Return
######################################################################################
$EXEBOUT
If BOUT="a"
   If !clalev([F:SIH]): Local File SINVOICE: Endif
   If [F:YSIV]CREADA<>2 Gosub APRES_CRE: Return: Endif
   If [F:YSIV]VALIDADA<>2 Gosub VALIDACION
                          If [F:YSIV2]VALIDADA=2
                            Read [F:SIH]SIH0=[F:YSIV]NUM
                            If [F:SIH]INVTYP=2 or [F:SIH]INVTYP=4
                              If [F:YSIV]STOMVTFLG = 2: Gosub IMPORTSTOCK : Endif
                            Gosub IMPORTPAY
                            Endif
                           Endif
                           Return
   Endif
   Read [F:SIH]SIH0=[F:YSIV]NUM
   If [F:SIH]INVTYP=2 or [F:SIH]INVTYP=4
      If [F:YSIV]STOMVTFLG = 2 and [F:YSIV]ABOSTOCK<>2
        Gosub IMPORTSTOCK
      Endif
   Else
     For X=0 To 4
      If [F:YSIV]IMPCOBRO(X)<>0 and ([F:YSIV]COBRO(X)="" or [F:YSIV]PAGOCRE(X)<>2)
        Gosub IMPORTPAY: Break
      Endif
     Next
   Endif
Endif
Return
#######################################################################################
$SETBOUT
If !clalev([F:SIH]): Local File SINVOICE: Endif

Read [F:SIH]SIH0=[F:YSIV]NUM
If !fstat
   If [F:SIH]INVTYP=1 or [F:SIH]INVTYP=3
     XX=0
     For X=0 To 4
       If [F:YSIV]IMPCOBRO(X)<>0 and ([F:YSIV]COBRO(X)="" or [F:YSIV]PAGOCRE(X)<>2)
         XX=1
         Break
       Endif
     Next
     If XX=0
       Call VIREBOUT(CHAINE,"a") From GOBJET
     Endif
   Else
     If [F:YSIV]ABOSTOCK=2
       Call VIREBOUT(CHAINE,"a") From GOBJET
     Endif
   Endif
Endif
Return

######################################################################################
$OUVRE
  Gosub DECLARE From TABLEAUX
Return

######################################################################################
$LIENS
  Gosub LIENS From TABLEAUX
Return

######################################################################################
$LIENS_LIG
  Local Shortint NOL
  NOL=nolign-1
  [M:YSIH1]NUM(NOL)         = [F:YSID]NUM
  [M:YSIH1]NUMLIN(NOL)      = [F:YSID]NUMLIN
  [M:YSIH1]STOFCY(NOL)      = [F:YSID]STOFCY
  [M:YSIH1]ITMREF(NOL)      = [F:YSID]ITMREF
  [M:YSIH1]SAU(NOL)         = [F:YSID]SAU
  [M:YSIH1]QTY(NOL)         = [F:YSID]QTY
  [M:YSIH1]GROPRI(NOL)      = [F:YSID]GROPRI
  [M:YSIH1]DISCRGVAL1(NOL)  = [F:YSID]DISCRGVAL1
  [M:YSIH1]DISCRGVAL2(NOL)  = [F:YSID]DISCRGVAL2
  [M:YSIH1]DISCRGVAL3(NOL)  = [F:YSID]DISCRGVAL3
  [M:YSIH1]SIHORINUMD(NOL)  = [F:YSID]SIHORINUMD
Return

####################################################################
$INICRE
If [M:YSIH0]NUM=""
    [M:YSIH0]NUM= num$(uniqid([YSIV]))
Endif

[F:YSIV]NUM=[M:YSIH0]NUM
For JJ=0 To [M:YSIH1]NBLIG-1
  [M:YSIH1]NUM(JJ)= [F:YSIV]NUM
Next

Return

######################################################################################
$APRES_CRE

Call OUVRE_TRACE("Generacion factura") From LECFIC

Gosub IMPORTSIH
If [F:YSIV2]VALIDADA=2
Read [F:SIH]SIH0=[F:YSIV]NUM
If [F:SIH]INVTYP=2 or [F:SIH]INVTYP=4
  If [F:YSIV]STOMVTFLG = 2: Gosub IMPORTSTOCK Endif
Endif
  Gosub IMPORTPAY
Endif

If [F:YSIV2]ERROR<>''
  Gosub WRI_ERROR
Endif

Call FERME_TRACE From LECFIC
If GWEBSERV=0
  Call LEC_TRACE From LECFIC
Endif

Return

######################################################################################
$DEFLIG

Default Mask [YSIH1] #The screen holding your detail information
Default File [YSID] #The table holding your detail information
#Filtering expression to read all detail lines related to one header
CRIT   = '[F:YSID]NUM="'+num$([M:YSIH0]NUM)+'"'
FICLIG = "YSINVOICED" #The name of the detail Table
ABLIG  = "YSID"       #Its abbreviation
ZONLIG = "NUMLIN"     #The line counter field

Return
#####################################################################################
######################################################################################
$IMPORTSTOCK

Local Char FICHERO(250) : FICHERO= filpath("ZIMP","STOCK"+[F:YSIV]NUM+"_"+ctrans(num$(date$),"/",""),"txt")

#cabecera
Local Char VAR_0(20), VAR_1(20), VAR_2(20), VAR_3(20)

#lineas
Local Char VAR_17(20), VAR_18(20), VAR_19(20)
Local Char SP(1)

SP = ';'

VAR_0 =  ""
VAR_1 =  [F:YSIV]STOFCY
VAR_2 =  format$('YYYYMMDD',date$)
VAR_3 =  [F:YSIV]NUM

Openo FICHERO,0 Using [FIC1] #abrir el fichero
Iomode adxirs ''  Using [FIC1]
Iomode adxifs ";" Using [FIC1]
Iomode adxium 50  Using [FIC1]

Wrseq 'E' + SP + VAR_0 + SP + VAR_1 + SP + VAR_2 + SP + VAR_3  Using [FIC1]
Wrseq chr$(13)+chr$(10) Using [FIC1]

For [F:YSID] Where NUM=[F:YSIV]NUM

  VAR_17 = [F:YSID]ITMREF
  If !clalev([F:ITM]): Local File ITMMASTER: Endif
  Read [F:ITM]ITM0=[F:YSID]ITMREF
  VAR_18 = [F:ITM]STU
  VAR_19 = num$([F:YSID]QTY)

  Wrseq 'L' + SP+VAR_17+SP+VAR_18+SP+VAR_19 Using [FIC1]
  Wrseq chr$(13)+chr$(10) Using [FIC1]
Next

Openo Using [FIC1]

Call IMPORTSIL("ZSMR",FICHERO)From GIMPOBJ

If !clalev([F:YSIV2]):Local File YSINVOICEV[YSIV2]: Endif
If !clalev([SMH]): Local File SMVTH: Endif
Filter [F:SMH] Where VCRDES = [F:YSIV]NUM
Read [F:SMH]SMH0 First
If !fstat
  Read [F:YSIV2]SIV0=[F:YSIV]NUM
  [F:YSIV2]ABOSTOCK = 2
  [F:YSIV2]VCRNUM = [F:SMH]VCRNUM
  Rewrite [F:YSIV2]
Endif

Return

######################################################################################
$IMPORTPAY

If !clalev([F:TPY]): Local File TABPAYTYP: Endif
If !clalev([F:TPT]): Local File TABPAYTERM: Endif

### Multicobros

For X=0 To 4
Local Char FICHERO(250) : FICHERO= filpath("ZIMP","PAY"+[F:YSIV]NUM+"_"+num$(X)+"_"+ctrans(num$(date$),"/",""),"txt")
If [F:YSIV]IMPCOBRO(X)<>0
#cabecera
Local Char VAR_0(20), VAR_1(20), VAR_2(20), VAR_3(20), VAR_4(20)   #Numero, paytyp, bpr, coa, acc,
Local Char VAR_5(20), VAR_6(20), VAR_7(20), VAR_8(20), VAR_9(20)   #pam, fcy, ban. sns, cur
Local Char VAR_10(20), VAR_11(20)                                 #amtcur, accdat


#lineas
Local Char VAR_17(20), VAR_18(20), VAR_19(20), VAR_20(20), VAR_21(20) #dencod, nº linea, planta exp., artículo, unidad venta
Local Char VAR_22(20), VAR_23(20), VAR_24(20), VAR_25(20)             #Ctd. fact., precio bruto, Valor1 dcnto/gastos, Valor2 dcnto/gastos
Local Char VAR_26(20), VAR_27(20), VAR_28(20)                         #Valor3 dcnto/gastos, Nº factura en caso de abono, línea factura
Local Char SP(1)
Local Char CAJA(5)

SP = ';'

If !clalev([F:SIH]): Local File SINVOICE: Endif
Read [F:SIH]SIH0=[F:YSIV]NUM
If !clalev([F:FCY]): Local File FACILITY: Endif
Read [F:FCY]FCY0=[F:YSIV]SALFCY

VAR_0 =  ""
#Filter [TPT] Where PTE=[F:YSIV]PTE
#Read [F:TPT]TPT0 First
VAR_1 = "CCAJA"
If [F:YSIV]FORMCOBRO(X)="VISA"
VAR_1 = "CVIS"
Endif

VAR_2 =  [F:YSIV]BPCINV
VAR_3 =  "SPA"
If !clalev([GAC]): Local File GACCOUNT: Endif
Read [F:GAC]GAC1="SPA";[F:SIH]BPRSAC
VAR_4 =  [F:GAC]ACC
VAR_5 =  [F:YSIV]FORMCOBRO(X)
VAR_6 =  [F:FCY]FINRSPFCY
#VAR_7 =  "CAJA2"
#If [F:YSIV]FORMCOBRO(X)="VISA"
#VAR_7 = "B090"
VAR_7 =  [F:YSIV]CAJA(X)
#Endif


If [F:SIH]INVTYP=2 or [F:SIH]INVTYP=4
  VAR_8 =  "1"
Else
  VAR_8= "2"
Endif
VAR_9 = [F:SIH]CUR
VAR_10 = num$([F:YSIV]IMPCOBRO(X))
VAR_10X = [F:YSIV]COMENTARIO(X)

If [F:YSIV]FECHACOB(X)=[0/0/0]
VAR_11 = format$('YYYYMMDD',[F:YSIV]INVDAT)
[F:YSIV]FECHACOB(X)=[F:YSIV]INVDAT
Else
VAR_11 =  format$('YYYYMMDD',[F:YSIV]FECHACOB(X))
Endif



Openo FICHERO,0 Using [FIC1] #abrir el fichero
Iomode adxirs ''  Using [FIC1]
Iomode adxifs ";" Using [FIC1]
Iomode adxium 50  Using [FIC1]

Wrseq 'V' + SP + VAR_0 + SP + VAR_1 + SP + VAR_2 + SP + VAR_3 + SP + VAR_4 + SP + VAR_5 + SP + VAR_6 + SP + VAR_7 + SP + VAR_8 + SP + VAR_9 + SP + VAR_10+SP+VAR_10X + SP + VAR_11  Using [
& FIC1]
Wrseq chr$(13)+chr$(10) Using [FIC1]


If [F:SIH]INVTYP=2 or [F:SIH]INVTYP=4
  VAR_17 = "PAY"
Else
  VAR_17 = "REC"
Endif
  VAR_18 = "SPA"
  VAR_19 = [F:GAC]ACC
  VAR_20 = [F:YSIV]BPCINV
  VAR_21 = [F:SIH]GTE
  VAR_22 = [F:SIH]NUM
  VAR_23 = ""
  VAR_24 = [F:YSIV]BPCINV
  VAR_25 = ""
  VAR_26 = [F:YSIV]SALFCY
  VAR_28 = [F:SIH]CUR
  VAR_29 = num$([F:YSIV]IMPCOBRO(X))
  VAR_30 = ""
  VAR_31 = [F:YSIV]BPCINV
  VAR_32 = [F:SIH]BPRSAC
  If !clalev([DUD]): Local File GACCDUDATE: Endif
  Filter [F:DUD] Where TYP=[F:SIH]GTE and NUM=[F:SIH]NUM
  Read [F:DUD]DUD0 First
  VAR_33 = num$([F:DUD]ACCNUM)
  VAR_34 = num$([F:DUD]DUDLIG)

  Wrseq 'D' + SP+VAR_17+SP+VAR_18+SP+VAR_19+SP+VAR_20 + SP + VAR_21 + SP + VAR_22 + SP + VAR_23 + SP + VAR_24 + SP + VAR_25 + SP Using [FIC1]
  Wrseq VAR_26 + SP + VAR_28+SP+VAR_29+SP+VAR_30+SP+VAR_31+SP+VAR_32+SP+VAR_33+SP+VAR_34 Using [FIC1]
  Wrseq chr$(13)+chr$(10) Using [FIC1]


Openo Using [FIC1]
Sleep 2
If   [F:YSIV]COBRO(X)=""
Call IMPORTSIL("ZPAY",FICHERO)From GIMPOBJ
Endif

If !clalev([F:PYDX]): Local File PAYMENTD [PYDX]: Endif
If !clalev([F:YSIV2]):Local File YSINVOICEV[YSIV2]: Endif
Raz [F:PYDX]
Filter [PYDX] Where VCRNUM = [F:SIH]NUM and AMTLIN=[F:YSIV]IMPCOBRO(X)
Read [PYDX]PYD0 Last
If !fstat
   Read [F:YSIV2]SIV0=[F:YSIV]NUM
  [F:YSIV2]COBRO(X) = [F:PYDX]NUM
  Rewrite [F:YSIV2]
Else
  [F:YSIV2]ERROR="Error en la creación del pago"
  Rewrite [F:YSIV2]
Endif



$VALCOBRO
#If [F:YSIV2]COBRO(X) = "" and [F:YSIV2]COMENTARIO(X)="" and ([F:YSIV]FECHACOB(X)=[F:YSIV]INVDAT or  [F:YSIV]FECHACOB(X)=[0/0/0]) and [F:YSIV2]PAGOCRE(X) <> 2
Local Mask PAYREMBAN [DIA]
If !clalev([F:PYD]): Local File PAYMENTD: Endif
If !clalev([F:PYH]): Local File PAYMENTH: Endif
If !clalev([F:CPY]): Local File COMPANY: Endif
#Filter [F:PYD] Where VCRNUM=[F:SIH]NUM
#For [F:PYD]
   Read [F:PYH]PYH0=[F:PYDX]NUM
   If !fstat and [F:PYH]STA<>9
      Raz [M:DIA]
      [M:DIA]ALLCPY=1: [M:DIA]CPY=[F:SIH]CPY
      [F:CPY]CPY=[F:SIH]CPY
      [M:DIA]LEG=[F:CPY]LEG
      [M:DIA]ALLCPY=2
      [M:DIA]ALLFCY=2

      [M:DIA]PAY5=1: [M:DIA]PAY7=1: [M:DIA]PAY9=2
      [M:DIA]ALLTYP=2
      [M:DIA]ALLLOT=2
      [M:DIA]ALLBAN=2
      [M:DIA]ALLUSR=2
      [M:DIA]ALLFRMTYP=2
      [M:DIA]PRO=2: [M:DIA]TRC=2
      [M:DIA]ACCDAT=[F:YSIV]FECHACOB(X)
      [M:DIA]ACCSTA=9
      XGUSERFCY=GUSRFCY(1)
      XGUSRAUX=GUSRAUZ(1)
      GUSRFCY(1)=[F:PYH]FCY
      GUSRAUZ(1)="G"
       Call PAYCPT([F:PYH]NUM) From PAYCPTA
       If GMESSAGE<>""
         [F:YSIV2]ERROR="Validación pago:"-GMESSAGE
         Rewrite [F:YSIV2]
       Endif
      GUSRFCY(1)=XGUSERFCY
      GUSRAUZ(1)=XGUSRAUX
   Endif
Read [PYH]PYH0=[F:PYDX]NUM
If !fstat and [F:PYH]STA=9
  [F:YSIV2]PAGOCRE(X) = 2
  Rewrite [F:YSIV2]
Endif
#Endif
$NEXT_COBRO
Endif
Next
Return
######################################################################################
$IMPORTSIH

If !clalev([F:SIH1])  : Local File SINVOICE [SIH1]  : Endif
If !clalev([F:XBPC])  : Local File BPCUSTOMER [XBPC]  : Endif
If !clalev([F:XCAC])  : Local File GACCCODE [XCAC]  : Endif
If !clalev([F:XGAC])  : Local File GACCOUNT [XGAC]  : Endif

Local Char FICHERO(250) : FICHERO= filpath("ZIMP",[F:YSIV]NUM+"_"+ctrans(num$(date$),"/",""),"txt")

#cabecera
Local Char VAR_0(20), VAR_1(20), VAR_2(20), VAR_3(20), VAR_4(20)   #Planta venta, tipo factura, nº factura o abono, referencia, fecha fact.
Local Char VAR_5(20), VAR_6(20), VAR_7(20), VAR_8(20), VAR_9(20)   #Cliente factura, regimen IVA, divisa, mov. stock, planta expedición
Local Char VAR_10(20), VAR_11(20), VAR_12(20), VAR_13(20)          #Cond. pago, origen documento, Nº doc. origen, creada
Local Char VAR_14(20),VAR_15(20),VAR_16(20)                        #Validada, pago creado, cobro
Local Char VAR_AMT1(20),VAR_AMT2(20),VAR_AMT3(20),VAR_AMT4(20),VAR_AMT5(20),VAR_AMT6(20)
Local Char VAR_DIE1(20), VAR_DIE2(20), VAR_DIE3(20), VAR_DIE4(20), VAR_DIE5(20)
Local Char VAR_CCE1(20), VAR_CCE2(20), VAR_CCE3(20), VAR_CCE4(20), VAR_CCE5(20)
#lineas
Local Char VAR_17(20), VAR_18(20), VAR_19(20), VAR_20(20), VAR_21(20) #Nº factura, nº linea, planta exp., artículo, unidad venta
Local Char VAR_22(20), VAR_23(20), VAR_24(20), VAR_25(20)             #Ctd. fact., precio bruto, Valor1 dcnto/gastos, Valor2 dcnto/gastos
Local Char VAR_26(20), VAR_27(20), VAR_28(20), VAR_X (30)                       #Valor3 dcnto/gastos, Nº factura en caso de abono, línea factura
Local Char SP(1)
Local Char VAR_CCE1D(20), VAR_CCE2D(20), VAR_CCE3D(20), VAR_CCE4D(20), VAR_CCE5D(20)

 #ASR Nuevo campo colectivo añadido al proceso 03/02/2020
Read [XBPC]BPC0 = [F:YSIV]BPCINV
If !fstat Then
    Read [XCAC]CAC0 = 2;[XBPC]ACCCOD;"SPA"
    If !fstat
        Read [XGAC]GAC0 = "SPA";[XCAC]ACC(0)
        If !fstat
           VAR_X =  [XGAC]ACCSHO
        Endif
    Endif
Endif
 #ASR Nuevo campo colectivo añadido al proceso 03/02/2020

SP = ';'

VAR_0 =  [F:YSIV]SALFCY
VAR_1 =  [F:YSIV]SIVTYP
VAR_2 =  [F:YSIV]NUM
VAR_3 =  [F:YSIV]INVREF
VAR_4 =  format$('YYYYMMDD',[F:YSIV]INVDAT)
VAR_5 =  [F:YSIV]BPCINV
VAR_6 =  [F:YSIV]VAC
VAR_7 =  [F:YSIV]CUR
VAR_8 =  num$([F:YSIV]STOMVTFLG)
VAR_9 =  [F:YSIV]STOFCY
VAR_10 = [F:YSIV]PTE
VAR_11 = num$([F:YSIV]SIHORI)
VAR_12 = [F:YSIV]SIHORINUM
#VAR_13 = num$([F:YSIV]CREADA)
#VAR_14 = num$([F:YSIV]VALIDADA)
#VAR_15 = num$([F:YSIV]PAGOCRE)
#VAR_16 = num$([F:YSIV]COBRO)
VAR_AMT1 = num$([F:YSIV]INVDTAAMT1)
VAR_AMT2 = num$([F:YSIV]INVDTAAMT2)
VAR_AMT3 = num$([F:YSIV]INVDTAAMT3)
VAR_AMT4 = num$([F:YSIV]INVDTAAMT4)
VAR_AMT5 = num$([F:YSIV]INVDTAAMT5)
VAR_AMT6 = num$([F:YSIV]INVDTAAMT6)
VAR_DIE1 = "PER"
VAR_DIE2 = "CTO"
VAR_DIE3 = "DTO"
VAR_DIE4 = "ZON"
VAR_DIE5 = "CCT"
VAR_CCE1 = [F:YSIV]XCCE1
VAR_CCE2 = [F:YSIV]XCCE2
VAR_CCE3 = [F:YSIV]XCCE3
VAR_CCE4 = [F:YSIV]XCCE4
VAR_CCE5 = [F:YSIV]XCCE5

Openo FICHERO,0 Using [FIC1] #abrir el fichero
#Iomode  adxifs ';'                    Using [FIC1]
#Iomode  adxirs chr$(13)+chr$(10)      Using [FIC1]
#Iomode  adxium 50                     Using [FIC1]

#indicamos separador
Iomode adxirs ''  Using [FIC1]
Iomode adxifs ";" Using [FIC1]
Iomode adxium 50  Using [FIC1]

#Wrseq 'V' + SP + VAR_0 + SP + VAR_1 + SP + VAR_2 + SP + VAR_3 + SP + VAR_4 + SP + VAR_5 + SP + VAR_6 + SP + VAR_7 + SP + VAR_8 + SP + VAR_9 + SP + VAR_10 + SP + VAR_11 + SP + VAR_12 #+ SP + VAR_13 +
# SP
#& + VAR_14 + SP + VAR_15 + SP + VAR_16 Using [FIC1]

Wrseq 'V' + SP + VAR_0 + SP + VAR_1 + SP + VAR_2 + SP + VAR_3 + SP + VAR_4 + SP + VAR_5 + SP + VAR_X + SP + VAR_6 + SP + VAR_7 + SP + VAR_8 + SP + VAR_9 + SP + VAR_10 + SP + VAR_11 + SP + VAR_12
& + SP + VAR_AMT1 + SP + VAR_AMT2 + SP + VAR_AMT3 + SP + VAR_AMT4 + SP + VAR_AMT5 + SP + VAR_AMT6
& + SP + VAR_DIE1 + SP + VAR_DIE2 + SP + VAR_DIE3 + SP + VAR_DIE4 + SP + VAR_DIE5
& + SP + VAR_CCE1 + SP + VAR_CCE2 + SP + VAR_CCE3 + SP + VAR_CCE4 + SP + VAR_CCE5 Using [FIC1]
Wrseq chr$(13)+chr$(10) Using [FIC1]

#For II=0 To [M:YSIH1]NBLIG-1
For [F:YSID] Where NUM=[F:YSIV]NUM
#  VAR_17 = [F:YSID]NUM
#  VAR_18 = num$([F:YSID]NUMLIN)
  VAR_19 = [F:YSID]STOFCY
  VAR_20 = [F:YSID]ITMREF
  VAR_21 = [F:YSID]SAU
  VAR_22 = num$([F:YSID]QTY)
  VAR_23 = num$([F:YSID]GROPRI)
  VAR_24 = num$([F:YSID]DISCRGVAL1)
  VAR_25 = num$([F:YSID]DISCRGVAL2)
  VAR_26 = num$([F:YSID]DISCRGVAL3)
 # VAR_27 = [F:YSID]SIHORINUM
 # VAR_28 = num$([F:YSID]SIDORLIN)
 VAR_CCE1D = [F:YSID]CCE1
 VAR_CCE2D = [F:YSID]CCE2
 VAR_CCE3D = [F:YSID]CCE3
 VAR_CCE4D = [F:YSID]CCE4
 VAR_CCE5D = [F:YSID]CCE5

  Wrseq 'D' + SP  + VAR_19 + SP+ VAR_20 + SP + VAR_21 + SP + VAR_22 + SP + VAR_23 + SP + VAR_24 + SP + VAR_25 + SP + VAR_26 + SP + VAR_27 + SP + VAR_28 Using [FIC1]
  Wrseq chr$(13)+chr$(10) Using [FIC1]
  Wrseq 'A' + SP + VAR_DIE1 + SP  + VAR_DIE2 + SP  + VAR_DIE3 + SP  + VAR_DIE4 + SP  + VAR_DIE5
& + SP + VAR_CCE1D + SP + VAR_CCE2D + SP + VAR_CCE3D + SP + VAR_CCE4D + SP + VAR_CCE5D Using [FIC1]
  Wrseq chr$(13)+chr$(10) Using [FIC1]
Next

Openo Using [FIC1]
Sleep 2
If clalev([M:IMP2])=0 : Global Mask IMPOBJ2 [IMP2] : Endif
  Raz [M:IMP2]

  [M:IMP2]MODIMP = "YSIH"
  [M:IMP2]NOMIMP = FICHERO
  [M:IMP2]TYPEXP = 2
  [M:IMP2]AOWSTA = 1

  Call IMPORTSIL([M:IMP2]MODIMP,[M:IMP2]NOMIMP) From GIMPOBJ

#comprobar si factura está creada en tabla SINVOICE. Si es así --> ZSINVOICEV.CREADA = 2
#si factura está creada proceso continua, sino finaliza aqui
If !clalev([F:YSIV2]):Local File YSINVOICEV[YSIV2]: Endif

Read [F:SIH1]SIH0=[F:YSIV]NUM
If !fstat Then
  Read [F:YSIV2]SIV0=[F:YSIV]NUM
  [F:YSIV2]CREADA = 2
  Rewrite [F:YSIV2]
Else
  Sleep 10
  Call IMPORTSIL([M:IMP2]MODIMP,[M:IMP2]NOMIMP) From GIMPOBJ
  Read [F:SIH1]SIH0=[F:YSIV]NUM
  If !fstat Then
    Read [F:YSIV2]SIV0=[F:YSIV]NUM
    [F:YSIV2]CREADA = 2
    Rewrite [F:YSIV2]
  Else
    [F:YSIV2]ERROR="Error en la creación de la factura"
    Rewrite [F:YSIV2]
  Endif
Endif
If [F:YSIV2]CREADA<>2: Return: Endif
$VALIDACION
If !clalev([F:SIH]): Local File SINVOICE: Endif
If !clalev([F:SIV]): Local File SINVOICEV: Endif
If !clalev([F:SID]): Local File SINVOICED: Endif
If !clalev([F:SVV]): Local File SVCRVAT : Endif
If !clalev([F:TCU]): Local File TABCUR  : Endif
If !clalev([F:CPY]): Local File COMPANY  : Endif
If !clalev([F:ITM]): Local File ITMMASTER  : Endif
Local Mask SIHV
Local Mask SIH0
Local Mask SIH1
Local Mask SIH2
Local Mask SIH4
Call VALIDATION(2,[F:YSIV]NUM) From TRTVENFACV
       If GMESSAGE<>""
         [F:YSIV2]ERROR="Validación factura:"-GMESSAGE
         Rewrite [F:YSIV2]
       Endif

If !clalev([HAE]): Local File GACCENTRY: Endif
X=0
$ESPERA
Read [HAE]HAE0=[F:SIH]GTE;[F:SIH]NUM
If fstat and X<10: Sleep 1:X+=1: Goto ESPERA
Else
  If X=10: Return

  Else
    [F:YSIV2]VALIDADA = 2
     Rewrite [F:YSIV2]
  Endif
Endif

Return

######################################################################################
$WRI_ERROR
  Local Char TRAZA(250), TEXTO(250)
  Local Integer FSTAT_1, POS
  Openi filpath("TRA",GTRACE,"tra")   Using [FIC1] #abrir el fichero

    #Iomode  adxifs ''                    Using [FIC1]
    Iomode  adxirs chr$(13)+chr$(10)      Using [FIC1]
    Iomode  adxium 50                     Using [FIC1]
    Repeat
      Rdseq TRAZA   Using [FIC1]
      FSTAT_1= fstat
      POS= instr(1,TRAZA,"<")
      If POS>0 and mid$(TRAZA,POS+1,2)='00'
        TEXTO= right$(TRAZA, POS)
      Endif
    Until FSTAT_1 <> 0
  Openi Using [FIC1]
  If TEXTO<>''
    Read [F:YSIV2]SIV0=[F:YSIV]NUM
    [F:YSIV2]ERRORIMP=TEXTO
    Rewrite [F:YSIV2]
  Endif

Return

