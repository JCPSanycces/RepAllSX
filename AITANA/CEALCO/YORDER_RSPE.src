#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Representation code only (dedicated to user interface)
$PROPERTIES
  Case [L]CURPRO
    When "YOH.LINES.PRICE"
       # Every time a line price is updated, recompute the total amount (UI rule)
       If [L]ARULE="PROPAGATE" : this.APARENT.TOTAL=fmet this.APARENT.TOTAMOUNT : Endif
    When "YOH.CUSTOMER"
       # Assign contact information (additional user interface properties)
       If [L]ARULE="PROPAGATE" : Call READ_CONTACTS(this.CUSTOMER, this.APARENT.NAME, this.APARENT.PHONE) : Endif
  Endcase
Return

# Global events
$EVENTS
  Case CURPTH
    When ""
    When "YOH"
      Case [L]AEVENT
        When "AREAD_AFTER"  : Call READ_CONTACTS(this.CUSTOMER, this.APARENT.NAME, this.APARENT.PHONE)
       Endcase
  Endcase
Return

# Erase the discount (user interface method)
$RTZ_DISCOUNT
  Local Integer I
  For I=1 To maxtab(this.YOH.LINES)
    this.YOH.LINES(I).DISCOUNT=0
  Next I
Return

# Get the contact name and the phone for a given customer
Subprog READ_CONTACTS(CUSTOMER,NAME,PHONE)
Value Char CUSTOMER()
Variable Char NAME(),PHONE()

Local File YCUSTOMER [YBP]
  Read [YBP]YBP0=CUSTOMER
  If fstat=0
    NAME=[YBP]CNTNAM
    PHONE=[YBP]PHONE
  Endif
End


# Label associated to methods: AMETHOD is the method name
$METHODS
  Case AMETHOD
     When "RTZ_DISCOUNT" : Gosub RTZ_DISCOUNT
  Endcase
Return

# Label associated to operations: AOPERATION is the event name
$OPERATIONS
  Case AOPERATION
  Endcase
Return

