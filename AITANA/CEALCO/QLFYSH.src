#<AdxTL>@(#)0.0.0.0 $Revision$
# First test: check if classes have been correctly set
#------------------------------------------------------------------------------#

Local Clbfile RESULT
RESULT=func TESTSUITE()
Errbox RESULT
End

Funprog TESTSUITE()

  Call ADD_TESTCASE("TEST_YSHLINE","Test classes YSHIPLINE",1) From AXUNIT
  Call ADD_TESTCASE("TEST_YSHIP1","Consistency of class YSHIP",1) From AXUNIT
  Call ADD_TESTCASE("TEST_YSHIP2","Shipment creation test",1) From AXUNIT
# Call ADD_TESTCASE("TEST_YORDER","Test classes YORDER and YLINE",1) From AXUNIT

End func AXUNIT.RUN_TESTSUITE("Test number 1","Check the shipment classes")

#  Optional subprog called *before* running the test suite
Subprog SETUP

# Error handling variable
  Global Integer ERROR_V

# Cleanup tables
  Gosub CLEANUP_TABLES
End

#  Optional subprog called *after* running the test suite
Subprog TEARDOWN
  Gosub CLEANUP_TABLES
End

# Cleanup the YSHIP and YORDER table where some empty records could have been created
$CLEANUP_TABLES
  Local File YORDER, YLINE, YSHIP, YSHLINE
  Delete [YSH] Where ORDNUM="TST_001"
  Delete [YSL] Where ORDNUM="TST_001"
Return

$NOCLASS
ERROR_V=errn
Resume

#
# Test YSHIP and YSHIPLINE
#

Subprog TEST_YSHLINE()

#
# Check YSHLINE : init method should work, but creation method should not exist
#
  Local Instance YSHLINE Using C_YSHLINE
  Local Integer OK
  Local Integer NB_ERR

  YSHLINE=NewInstance C_YSHLINE AllocGroup null
  OK=fmet YSHLINE.AINIT

  If OK<>[V]CST_AOK
    NB_ERR+=1
    Call LOG_LINE(" ** ERROR : AINIT method failed on YSHLINE") From AXUNIT
  Else
    Call LOG_LINE("YSHLINE structure after AINIT") From AXUNIT
    Call LOG_CLASS(YSHLINE,"YSHLINE",1) From AXUNIT
  Endif

  [V]ERROR_V=0
  Onerrgo NOCLASS
  OK=fmet YSHLINE.AINSERT
  Onerrgo
  If ERROR_V=0
    NB_ERR+=1
    Call LOG_LINE(" ** ERROR :  YSHLINE has been declared as persistent") From AXUNIT
  Endif

  FreeGroup YSHLINE

  Call CHECK_EQUAL(NB_ERR,0) From AXUNIT

End

#
# Check class YSHIP
#
Subprog TEST_YSHIP1()

#
# Check class YSHLINE
#
  Local Instance YSHLINE Using C_YSHLINE
  Local Integer OK
  Local Integer NB_ERR

  YSHLINE=NewInstance C_YSHLINE AllocGroup null
  Local Instance YSHIP Using C_YSHIP
  Local Integer OK

  YSHIP=NewInstance C_YSHIP AllocGroup null
  OK=fmet YSHIP.AINIT

  If OK<>[V]CST_AOK
    NB_ERR+=1
    Call LOG_LINE(" ** ERROR :  AINIT method failed on YSHIP") From AXUNIT
  Else
    Call LOG_LINE("YSHIP structure after AINIT") From AXUNIT
    Call LOG_CLASS(YSHIP,"YSHIP",1) From AXUNIT
  Endif

  [V]ERROR_V=0
  Onerrgo NOCLASS
  OK=fmet YSHIP.AINSERT
  Onerrgo
  If ERROR_V<>0
    NB_ERR+=1
    Call LOG_LINE(" ** ERROR :  YSHIP has no AINSERT method") From AXUNIT
    Goto STOP_TEST
  Else
    If OK=[V]CST_AERROR
      Call LOG_LINE("AINSERT method was sucessfully denied because no line exists") From AXUNIT
      Call LOG_CLASS(YSHIP,"YSHIP",1) From AXUNIT
    Else
      NB_ERR+=1
      Call LOG_LINE(" ** ERROR :  An order without lines has been created") From AXUNIT
    Endif
  Endif

  FreeGroup YSHIP

  Call CHECK_EQUAL(NB_ERR,0) From AXUNIT
End

Subprog TEST_YSHIP2()

#
# Check YSHLINE : init method should work, but creation method should not exist
#
  Local Instance YSHIP Using C_YSHIP
  Local Integer OK
  Local Integer NB_ERR

  YSHIP=NewInstance C_YSHIP AllocGroup null
  OK=fmet YSHIP.AINIT

  Onerrgo NOCLASS
  [V]ERROR_V=0
  OK=fmet YSHIP.ADDLINE("SHIPLINES",[V]CST_ALASTPOS)
  Onerrgo
  If ERROR_V<>0 or OK=[V]CST_ANOTDEFINED
    NB_ERR+=1
    Call LOG_LINE(" ** ERROR :  YSHIP has no SHIPLINES collection or no line addition is allowed") From AXUNIT
  Else

    OK=fmet YSHIP.AINSERT
    If OK=[V]CST_AERROR
      Call LOG_LINE("AINSERT method was sucessfully denied because mandatory property exists") From AXUNIT
      Call LOG_CLASS(YSHIP,"YSHIP",1) From AXUNIT
    Else
      NB_ERR+=1
      Call LOG_LINE(" ** ERROR :  An order without customer has been created") From AXUNIT
    Endif
  Endif

  FreeGroup YSHIP

  YSHIP=NewInstance C_YSHIP AllocGroup null
  Local File YCUSTOMER
  Read [YBP]YBP0 First
  Local File YITEM
  Read [YIT]YIT0 First

  OK=fmet YSHIP.AINIT
  YSHIP.CUSTOMER=[YBP]BPCNUM

  OK=fmet YSHIP.ADDLINE("SHIPLINES",[V]CST_ALASTPOS)
  YSHIP.SHIPLINES(OK).ITEM=[YIT]ITMREF
  YSHIP.SHIPLINES(OK).NUMLIN=1
  YSHIP.SHIPLINES(OK).DLVNUM=1
  YSHIP.SHIPLINES(OK).ORDNUM="TST_001"
  YSHIP.SHIPLINES(OK).QTY=1
  YSHIP.ORDNUM="TST_001"
  YSHIP.DLVNUM=1
  YSHIP.CUSTOMER=[YBP]BPCNUM
  YSHIP.DLVDAT=date$
  OK=fmet YSHIP.AINSERT
  If OK=[V]CST_AERROR
    NB_ERR+=1
    Call LOG_LINE(" ** ERROR :  The shipment was not successful") From AXUNIT
    Call LOG_CLASS(YSHIP,"YSHIP",1) From AXUNIT
  Else
    Call LOG_LINE("AINSERT method successful") From AXUNIT
    Call LOG_CLASS(YSHIP,"YSHIP",1) From AXUNIT
  Endif

  Onerrgo NOCLASS
  [V]ERROR_V=0
  OK= fmet YSHIP.ADELETE
  Onerrgo
  If OK=[V]CST_AERROR and [V]ERROR_V=0
    NB_ERR+=1
    Call LOG_LINE("Shipment deletion should not be allowed") From AXUNIT
    Call LOG_CLASS(YSHIP,"YSHIP",1) From AXUNIT
  Else
    Call LOG_LINE("Shipment deletion was successfully denied") From AXUNIT
  Endif

STOP_TEST

  Call CHECK_EQUAL(NB_ERR,0) From AXUNIT
End

