#<AdxTL>@(#)0.0.0.0 $Revision$
# Third test: check the additional controls
#------------------------------------------------------------------------------#

Local Clbfile RESULT
RESULT=func TESTSUITE()
Errbox RESULT
End

Funprog TESTSUITE()

  Call ADD_TESTCASE("TEST_YORDER","Test classes YORDER with controls",1) From AXUNIT

End func AXUNIT.RUN_TESTSUITE("Test number 1","Check the classes")

#  Optional subprog called *before* running the test suite
Subprog SETUP

# Error handling variable
  Global Integer ERROR_V

# Cleanup tables
  Gosub CLEANUP_TABLES
End

#  Optional subprog called *after* running the test suite
Subprog TEARDOWN
  Gosub CLEANUP_TABLES
End

# Cleanup the YSHIP and YORDER table where some empty records could have been created
$CLEANUP_TABLES
  Local File YORDER, YLINE, YSHIP, YSHLINE
  Delete [YOH] Where ORDNUM=""
  Delete [YLI] Where ORDNUM=""
  Delete [YSH] Where ORDNUM=""
  Delete [YSL] Where ORDNUM=""
  Delete [YLI] Where pat(ORDNUM,"FR011_*")<>0
  Delete [YOH] Where pat(ORDNUM,"FR011_*")<>0
  Delete [YOH] Where ORDNUM="TST_001"
  Delete [YLI] Where ORDNUM="TST_001"
  Update [BPC] Where BPCNUM="AO005" With YOHLAST=""
Return

Subprog TEST_YORDER()

#
# Check class YORDER
#
  Local Instance YORDER Using C_YORDER
  Local Integer OK,NUML,I
  Local Integer NB_ERR

  YORDER=NewInstance C_YORDER AllocGroup null
  OK=fmet YORDER.AINIT
  YORDER.FCY="FR011"
  YORDER.CUSTOMER="AO005"
  OK=fmet YORDER.ADDLINE("LINES",[V]CST_ALASTPOS)
  If OK=[V]CST_ANOTDEFINED
    NB_ERR+=1
    Call LOG_LINE(" ** ERROR : ADDLINE method failed on YORDER for the first line") From AXUNIT
  Else
    YORDER.LINES(OK).ITEM="BMS001"
    YORDER.LINES(OK).QTY=100
    OK=fmet YORDER.AINSERT
    If OK<>[V]CST_AOK
      NB_ERR+=1
      Call LOG_LINE(" ** ERROR : AINSERT method failed on YORDER") From AXUNIT
      Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
    Else
      Call LOG_LINE("Creation of an order with 1 line succeeded") From AXUNIT

      Local File BPCUSTOMER
      Read [BPC]BPC0="AO005"
      If [BPC]YOHLAST<>"FR011_00001"
        NB_ERR+=1
        Call LOG_LINE(" ** ERROR : YOHLAST not correctly set on BPCUSTOMER table (value="+[BPC]YOHLAST+")") From AXUNIT
      Endif

      FreeGroup YORDER
      YORDER=NewInstance C_YORDER AllocGroup null
      OK=fmet YORDER.AREAD("FR011_00001")
      If OK<>[V]CST_AOK
        NB_ERR+=1
        Call LOG_LINE(" ** ERROR : AREAD method failed on YORDER") From AXUNIT
      Else
       YORDER.LINES(1).DISCOUNT=90
        OK=fmet YORDER.AUPDATE
        If OK=[V]CST_AOK
          NB_ERR+=1
          Call LOG_LINE(" ** ERROR : Control on discount incorrectly set") From AXUNIT
        Else
          Call LOG_LINE("Control on discount successfully set") From AXUNIT
          Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
        Endif

        FreeGroup YORDER
        YORDER=NewInstance C_YORDER AllocGroup null
        OK=fmet YORDER.AREAD("FR011_00001")
        If OK<>[V]CST_AOK
          NB_ERR+=1
          Call LOG_LINE(" ** ERROR : AREAD method failed on YORDER") From AXUNIT
        Else
          YORDER.LINES(1).DISCOUNT=10
          OK=fmet YORDER.ADDLINE("LINES",[V]CST_ALASTPOS)
          If OK=[V]CST_ANOTDEFINED
            NB_ERR+=1
            Call LOG_LINE(" ** ERROR : ADDLINE method failed on YORDER for the second line") From AXUNIT
          Else
            YORDER.LINES(OK).ITEM="BMS002"
            YORDER.LINES(OK).QTY=200
            OK=fmet YORDER.AUPDATE
            If OK<>[V]CST_AOK
              NB_ERR+=1
              Call LOG_LINE(" ** ERROR : AUPDATE method failed on YORDER") From AXUNIT
              Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
            Else
              Call LOG_LINE("Update of an order with 2 lines succeeded") From AXUNIT
            Endif

            FreeGroup YORDER
            YORDER=NewInstance C_YORDER AllocGroup null
            OK=fmet YORDER.AREAD("FR011_00001")
            If OK<>[V]CST_AOK
              NB_ERR+=1
              Call LOG_LINE(" ** ERROR : AREAD method failed on YORDER") From AXUNIT
            Else
              OK=fmet YORDER.ADDLINE("LINES",[V]CST_ALASTPOS)
              If OK=[V]CST_ANOTDEFINED
                NB_ERR+=1
                Call LOG_LINE(" ** ERROR : ADDLINE method failed on YORDER for the third line") From AXUNIT
              Else
                YORDER.LINES(OK).ITEM="TOO001"
                YORDER.LINES(OK).QTY=300
                NUML=OK
                OK=fmet YORDER.AUPDATE
                If OK=[V]CST_AOK
                  NB_ERR+=1
                  Call LOG_LINE(" ** ERROR : Filter on items not set, TOO001, not sold product, was entered successfully") From AXUNIT
                Else
                  Call LOG_LINE("Filter on item successfully set") From AXUNIT
                  Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
                Endif

                FreeGroup YORDER
                YORDER=NewInstance C_YORDER AllocGroup null
                OK=fmet YORDER.AREAD("FR011_00001")
                If OK<>[V]CST_AOK
                  NB_ERR+=1
                  Call LOG_LINE(" ** ERROR : AREAD method failed on YORDER") From AXUNIT
                Else
                  YORDER.OPERATION="SHIP"
                  YORDER.LINES(2).DLVQTY=YORDER.LINES(2).QTY
                  OK=fmet YORDER.AUPDATE
                  If OK=[V]CST_AOK
                    Call LOG_LINE("YORDER Update successful") From AXUNIT
                  Else
                    NB_ERR+=1
                    Call LOG_LINE(" ** ERROR : YORDER Update was not successful") From AXUNIT
                    Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
                  Endif

                  FreeGroup YORDER
                  YORDER=NewInstance C_YORDER AllocGroup null
                  OK=fmet YORDER.AREAD("FR011_00001")
                  If OK<>[V]CST_AOK
                    NB_ERR+=1
                    Call LOG_LINE(" ** ERROR : AREAD method failed on YORDER") From AXUNIT
                  Else
                    YORDER.OPERATION=""
                    OK=fmet YORDER.ADELLINE("LINES",2)
                    If OK=[V]CST_AOK
                      NB_ERR+=1
                      Call LOG_LINE(" ** ERROR : Deletion of a shipped line not correctly checked") From AXUNIT
                    Else
                      Call LOG_LINE("Control on line deletion correct") From AXUNIT
                      Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
                    Endif

                    YORDER.ORDCLO=2
                    OK=fmet YORDER.AUPDATE
                    If OK=[V]CST_AOK
                      NB_ERR+=1
                      Call LOG_LINE(" ** ERROR : A partially shipped order could be closed") From AXUNIT
                    Else
                      Call LOG_LINE("Control on ORDCLO successful: partially shipped order cannot be closed") From AXUNIT
                      Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
                    Endif

                    FreeGroup YORDER
                    YORDER=NewInstance C_YORDER AllocGroup null
                    OK=fmet YORDER.AREAD("FR011_00001")
                    If OK<>[V]CST_AOK
                      NB_ERR+=1
                      Call LOG_LINE(" ** ERROR : AREAD method failed on YORDER") From AXUNIT
                    Else
                      YORDER.OPERATION="SHIP"
                      For I=1 To maxtab(YORDER.LINES) : YORDER.LINES(I).DLVQTY=YORDER.LINES(I).QTY : Next I
                      YORDER.ORDCLO=2
                      OK=fmet YORDER.AUPDATE
                      If OK=[V]CST_AERROR
                        NB_ERR+=1
                        Call LOG_LINE(" ** ERROR : An completely shipped order could not be closes") From AXUNIT
                        Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
                      Else
                        Call LOG_LINE("Control on ORDCLO successful: totally shipped order can be closed") From AXUNIT
                      Endif
                    Endif
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif

  Call CHECK_EQUAL(NB_ERR,0) From AXUNIT

End
