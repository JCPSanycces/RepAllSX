#<AdxTL>@(#)0.0.0.0 $Revision$
# Random values generation : called from a standard X3 function on the label ACTION: ACTION must be equal to EXEC
$ACTION : If ACTION<>"EXEC" : Return : Endif

Local Char CUSTOMER_LIST(30)(1..), ITEM_LIST(30)(1..), COMMENT_LIST(80)(1..), SITE_LIST(5)(1..)
Call INIT_RANDOM_GENERATOR(CUSTOMER_LIST,ITEM_LIST,COMMENT_LIST,SITE_LIST)

Local Integer I, OK, TRA
Local Decimal T
Local Char LOGFILE_NAME(100)

# Instantiate a class to generate the log
Local Instance MYLOG Using C_ALOG
  MYLOG=NewInstance C_ALOG AllocGroup null

# Open the log file
  TRA=fmet MYLOG.ABEGINLOG("Sales order generation")
  LOGFILE_NAME=fmet MYLOG.AGETNAME

  T=val(timestamp$)
  Local File YORDER  [YOH]

  For I=1 To 500
    Gosub CREATE_RANDOM_ORDER
  Next I

  TRA=fmet MYLOG.APUTLINE("Time to generate 500 orders:"+num$((val(timestamp$)-T)/1000),TRA)
  TRA=fmet MYLOG.AENDLOG
  FreeGroup MYLOG
  Errbox "The log file is"-LOGFILE_NAME

Return

$CREATE_RANDOM_ORDER
Local Instance MYORDER Using C_YORDER

  MYORDER = NewInstance C_YORDER AllocGroup null                        : # Instantiate the order
  OK=fmet MYORDER.AINIT                                                 : # Apply init values
  MYORDER.FCY         = func RANDOM_CODE(SITE_LIST)                     : # Assign random site
  MYORDER.CUSTOMER    = func RANDOM_CODE(CUSTOMER_LIST)                 : # Assign random customer
  MYORDER.ORDDAT      = func RANDOM_DATE([1/1/2010],date$)              : # Assign date
  MYORDER.COMMENT     = func RANDOM_CODE(COMMENT_LIST)                  : # Assign random comment

  For J=1 To func RANDOM_INTEGER(5,10)                                  : # create randomly between 5 and 10 lines
    K=fmet MYORDER.ADDLINE("LINES",[V]CST_ALASTPOS)                     : # Use the insert line method
    If K=[V]CST_ANOTDEFINED                                             : # Raise an error if line insert failed
      OK=[V]CST_AERROR : TRA=fmet MYLOG.APUTLINE("** Error found in ADDLINE method for J="+num$(J),TRA)
      Break
    Endif
    MYORDER.LINES(K).ITEM      = func RANDOM_CODE(ITEM_LIST)            : # Assign random item
    MYORDER.LINES(K).QTY       = func RANDOM_INTEGER(1,100)             : # Assign random quantity
    MYORDER.LINES(K).UNITPRICE*= func RANDOM_DECIMAL(1,1.5)             : # Assign random unit price
    MYORDER.LINES(K).UNITPRICE = ar2(MYORDER.LINES(K).UNITPRICE)        : # Round the unit price
  Next J

  If OK<>[V]CST_AERROR
    OK=fmet MYORDER.AINSERT                                             : # Call the insert method
    Gosub LOG_RESULT                                                    : # Write the result in logfile
  Endif

  FreeGroup MYORDER
Return

$LOG_RESULT
  If OK>=[V]CST_AERROR
    TRA=fmet MYLOG.APUTLINE("** Errors found in AINSERT method",TRA)
    TRA=fmet MYLOG.APUTINSTERRS(MYORDER)
  Else
    If OK>[V]CST_AOK
      TRA=fmet MYLOG.APUTLINE("** Warning found in AINSERT method",TRA)
      OK=fmet MYLOG.APUTINSTERRS(MYORDER)
    Endif
    TRA=fmet MYLOG.APUTLINE(func AFNC.MES3("Order $1$ created with $2$ lines and a total of $3$",MYORDER.ORDNUM,num$(J-1),num$(MYORDER.TOTAL)),TRA)
  Endif
Return

Subprog INIT_RANDOM_GENERATOR(CUSTOMER_LIST,ITEM_LIST,COMMENT_LIST,SITE_LIST)
Variable Char CUSTOMER_LIST()(1..), ITEM_LIST()(1..),COMMENT_LIST()(1..),SITE_LIST()(1..)
Local File YCUSTOMER, YITEM,FACILITY
Local Integer I,J
Local Char COMMENT(80)

  I=0 : For [FCY] Where SALFLG=2 : I+=1 : SITE_LIST(I)=[FCY]FCY        : Next
  I=0
  For [YBP] : I+=1 : CUSTOMER_LIST(I)=[YBP]BPCNUM       : Next

# Add a statistical bias to have more customer codes ending with 1
  For [YBP] Where pat(BPCNUM,"*1")<>0 : For J=1 To 5 : I+=1 : CUSTOMER_LIST(I)=[YBP]BPCNUM : Next J : Next

  I=0 : For [YIT] : I+=1 : ITEM_LIST(I)=[YIT]ITMREF     : Next
  I=0
  For COMMENT=
&    "Urgent order","Please refer to M. MARTIN", "Do not deliver on Monday", "First grade quality expected", "Special Thanksgiving offer",
&    "Shipping by AIR", "These goods cannot be reselled", "Under the 123-XYZ Contract conditions", "Goods return allowed within one month",
&    "Warranty extended to 2 years", "1% Discount if payed by transfer", "Don't forget our 10th anniversary special conditions next month",
&    "Warranty limited to 6 month", "2% Discount if payed by transfer", "Carrier will be HENRY Ldt", "Please control the packages at arrival",
&    "Heavy packages", "Urgent shipping option not paid", "The gaskets are excluded from the warranty", "Call our 7*24 service for any question",
&    "Fragile goods", "Samples included", "No return allowed on consumable goods", "Service contract 567/UI apply to the goods",
&    "The electronic devices are subject to special installation conditions", "Order controlled by Mr JOHNSON",
&    "Additional charges are applied on returns if the packages have been opened", "Next month the new contracts will apply to resellers",
&    "Our duty: to give you the best quality at affordable prices", "Don't forget the next promotion period!", "Installation will by done by Jonas",
&    "For quantity over 10,000, please ask for availability","You can now order on our website", "Our new catalog will be available soon"
    I+=1 : COMMENT_LIST(I)=COMMENT
  Next
End

Funprog RANDOM_CODE(CODE_LIST)
Value Char CODE_LIST()(1..)
End CODE_LIST(1+int(rnd(maxtab(CODE_LIST))))

Funprog RANDOM_DATE(D1,D2)
Value Date D1,D2
End D1+int(rnd(D2-D1))

Funprog RANDOM_INTEGER(I1,I2)
Value Integer I1,I2
End I1+int(rnd(I2-I1+1))

Funprog RANDOM_DECIMAL(D1,D2)
Value Decimal D1,D2
End D1+rnd(D2-D1)

