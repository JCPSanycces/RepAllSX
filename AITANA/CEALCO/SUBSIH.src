[M:ALP]BPRNUM     = [M:SIH1]BPCORD
Raz [M:ALP]VCRSEQ
If dim([M:SIH4]WRH)>0 [M:ALP]WRH=[M:SIH4]WRH(NOL) Endif

Return

# V6.2 : Certification
# --------------------------------------------------------- #
# Contrôle des dates des documents d'origine                #
# --------------------------------------------------------- #
# La date du document d'origine ne doit pas être supérieure #
# à la date de la facture ou de l'avoir                     #
# --------------------------------------------------------- #
# En sortie GMESSAGE est rempli et                          #
#           mkstat=1                                        #
# --------------------------------------------------------- #
Subprog CTLDAT_ORI(WINVDAT)
Value Date WINVDAT
#-----
Local Integer I
Local Char    WSIHORINUM(GLONVCR)
Local Date    WSIHORIDAT
#-----

For I=0 To [M:SIH4]NBLIG-1
  Case [M:SIH1]SIHORI
    When 2 :    # Commandes
      If [M:SIH4]SOHNUM(I)<>""
          If !clalev([SOH])   Local File SORDER     [SOH]  : Endif
          Read [SOH] SOH0=[M:SIH4]SOHNUM(I) : If fstat Raz [F:SOH] : Endif
          If [F:SOH]ORDDAT>WINVDAT
            WSIHORINUM=[M:SIH4]SOHNUM(I) : WSIHORIDAT=[F:SOH]ORDDAT
            mkstat=1
          Endif
      Endif
    When 3 :    # Livraisons
      If [M:SIH4]SDHNUM(I)<>""
          If !clalev([SDH])   Local File SDELIVERY  [SDH]  : Endif
          Read [SDH] SDH0=[M:SIH4]SDHNUM(I) : If fstat Raz [F:SDH] : Endif
          #If [F:SDH]DLVDAT>WINVDAT : # Dde 73382
          If [F:SDH]SHIDAT>WINVDAT  : # Dde 73382
            #WSIHORINUM=[M:SIH4]SDHNUM(I) : WSIHORIDAT=[F:SDH]DLVDAT : # Dde 73382
            WSIHORINUM=[M:SIH4]SDHNUM(I) : WSIHORIDAT=[F:SDH]SHIDAT  : # Dde 73382
            mkstat=1
          Endif
      Endif
    When 4 :    # Facture
      If [M:SIH4]XSIHORINUM(I)<>""
          If !clalev([SIV2])  Local File SINVOICEV  [SIV2] : Endif
          #Read [SIV] SIV0=[M:SIH4]XSIHORINUM(I) : If fstat Raz [F:SIV] : Endif   : # Bug 80828
          #If [F:SIV]INVDAT>WINVDAT                                               : # Bug 80828
          #  WSIHORINUM=[M:SIH4]XSIHORINUM(I) : WSIHORIDAT=[F:SIV]INVDAT          : # Bug 80828
          Read [SIV2] SIV0=[M:SIH4]XSIHORINUM(I) : If fstat Raz [F:SIV2] : Endif  : # Bug 80828
          If [F:SIV2]INVDAT>WINVDAT                                               : # Bug 80828
            WSIHORINUM=[M:SIH4]XSIHORINUM(I) : WSIHORIDAT=[F:SIV2]INVDAT          : # Bug 80828
            mkstat=1
          Endif
      Endif
    When 6 :    # Retour
      If [M:SIH4]SRHNUM(I)<>""
          If !clalev([SRH])   Local File SRETURN    [SRH]  : Endif
          Read [SRH] SRH0=[M:SIH4]SRHNUM(I) : If fstat Raz [F:SRH] : Endif
          If [F:SRH]RTNDAT>WINVDAT
            WSIHORINUM=[M:SIH4]SRHNUM(I) : WSIHORIDAT=[F:SRH]RTNDAT
            mkstat=1
          Endif
      Endif
    When 7 :    # Contrat
      If [M:SIH4]CONNUM(I)<>""
          If !clalev([CON])   Local File CONTSERV   [CON]  : Endif
          Read [CON] CON0=[M:SIH4]CONNUM(I) : If fstat Raz [F:CON] : Endif
          If [F:CON]CONSTRDAT>WINVDAT
            WSIHORINUM=[M:SIH4]CONNUM(I) : WSIHORIDAT=[F:CON]CONSTRDAT
            mkstat=1
          Endif
      Endif
    When 8 :    # Demande
      If [M:SIH4]SRENUM(I)<>""
          If !clalev([SRE])   Local File SERREQUEST [SRE]  : Endif
          Read [SRE] SRE0=[M:SIH4]SRENUM(I) : If fstat Raz [F:SRE] : Endif
          If [F:SRE]SREDATASS>WINVDAT
            WSIHORINUM=[M:SIH4]SRENUM(I) : WSIHORIDAT=[F:SRE]SREDATASS
            mkstat=1
          Endif
      Endif
    When 9 :    # Transfert
      If !clalev([SGH])   Local File SCHGH      [SGH]  : Endif
      If [M:SIH4]SGHNUM(I)<>"" & [M:SIH4]SGHNUM(I)<>"$"
          Read [SGH] SGH0=[M:SIH4]SGHNUM(I) : If fstat Raz [F:SGH] : Endif
          If [F:SGH]IPTDAT>WINVDAT
            WSIHORINUM=[M:SIH4]SGHNUM(I) : WSIHORIDAT=[F:SGH]IPTDAT
            mkstat=1
          Endif
      Else
          Filter [SGH] Where SIHNUM=[M:SIH0]NUM
          For [SGH]SGH1
              If [F:SGH]IPTDAT>WINVDAT
                WSIHORINUM=[F:SGH]VCRNUM : WSIHORIDAT=[F:SGH]IPTDAT
                mkstat=1
              Endif
          Next
          Filter [SGH]
      Endif
    When 10 :
      # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) #
      # SIHORI=10 Schedule invoice with direct line
      #--Schedule invoice line with sales order line as origin
      If [M:SIH0]INVTYP = 1 & [M:SIH4]VCRINVCNDTYP(I)=10 & [M:SIH4]VCRINVCNDLIN(I)>0 & [M:SIH4]SIDORI(I)=2
        If [M:SIH4]SOHNUM(I)<>""
            If !clalev([SOH])   Local File SORDER     [SOH]  : Endif
            Read [SOH] SOH0=[M:SIH4]SOHNUM(I) : If fstat Raz [F:SOH] : Endif
            If [F:SOH]ORDDAT>WINVDAT
              WSIHORINUM=[M:SIH4]SOHNUM(I) : WSIHORIDAT=[F:SOH]ORDDAT
              mkstat=1
            Endif
        Endif
      Endif
Endcase

  If mkstat=1
      # 87538
      #GMESSAGE =mess(18,197,1)-num$(I+1)-":"-mess([M:SIH1]SIHORI(I),413,1)-WSIHORINUM-format$(GFMD,WSIHORIDAT)-":\"
      GMESSAGE =mess(18,197,1)-num$(I+1)-":"-mess([M:SIH1]SIHORI,413,1)-WSIHORINUM-format$(GFMDAT,WSIHORIDAT)-":\" :#--CPO 83985 GFMDAT au lieu de GFMD
      # 87538
      If [M:SIH0]INVTYP=1
          GMESSAGE-=mess(347,192,1)
      Else
          GMESSAGE-=mess(348,192,1)
      Endif
      Break
  Endif

Next I
#-----
End


#-----------------------------------------------------------------------#
#                    POUR LES AVOIRS                                    #
#-----------------------------------------------------------------------#
# ETIQUETTES ET SOUS-PROGRAMMES APPELES PAR LES ACTIONS CHAMPS          #
#-----------------------------------------------------------------------#
#########################################################################
# SIHINIZONENT                                                          #
#        Appelé en AVANT-NBLIG en modification d'une ligne d'avoir      #
#                                                                       #
#        - Lecture des tables articles                                  #
#        - Lecture de la règle de gestion à appliquer                   #
#        - Si la ligne est déjà créée :                                 #
#             Si la ligne n'est pas gérée en stock :                    #
#                Grisage des champs stock                               #
#             Si la ligne est gérée en stock       :                    #
#                Désactivation de la qté                                #
#        - Si la ligne n'est pas créée :                                #
#             Si la ligne est gérée en stock       :                    #
#                Si avoir direct ou ligne directe d'avoir s/facture     #
#                    Activation des champs stocks                       #
#                Si ligne d'avoir sur facture (picking)                 #
#                    Désactivation lot, n° série                        #
#                                                                       #
#########################################################################
Subprog SIHINIZONENT
Local Integer NOL : NOL=nolign-1

If [M:SIH4]STOMGTCOD(NOL)<>1 & [M:SIH1]STOMVTFLG=2 & [M:SIH4]RTNSTOUPD(NOL)=2 &
&  (find([M:SIH1]SIHORI,1,4) | ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)=""))
    # Si article géré en stock et maj des stock et
    # avoir direct ou sur facture ou ligne directe d'un avoir sur retour
    # --> Lecture article et règle de gestion (sf si on va le faire ds INIZONENT)
    If !([M:SIH4]CREFLG(NOL)=0 & [M:SIH4]STOMGTCOD(NOL)<>1 & [M:SIH1]STOMVTFLG=2 & [M:SIH4]RTNSTOUPD(NOL)=2 &
&       ([M:SIH1]SIHORI=1 | ([M:SIH1]SIHORI=4 & [M:SIH4]XSIHORINUM(NOL)="") | ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)="")) &
&        [M:SIH4]WSTOFLG(NOL)=0)
        Call LECFICENT([M:SIH4]DSTOFCY(NOL),[M:SIH1]BPCORD,"",nolign-1,12,[M:SIH0]TRSCOD,0) From STKECR
    Endif
Endif

If [M:SIH4]CREFLG(NOL) <> 0
    # ----------------------- #
    # La ligne est déjà créée #
    # ----------------------- #
    # Désactivation des champs
    If [M:SIH4]STOMGTCOD(NOL)=1 | [M:SIH1]STOMVTFLG=1 | [M:SIH4]RTNSTOUPD(NOL)=1 | ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)<>"")
        # --> Si ligne non gérée en stock, grizage des champs stock
        Actzo [M:SIH4]QTY(NOL)
        Call STKGRILIG ("SIH4", NOL) From TRTVENSTK
    Else
        # --> Si ligne gérée en stock, désactivation de la qté
        Diszo [M:SIH4]QTY(NOL)
    Endif
Else
    # ------------------------------- #
    # La ligne n'est pas encore créée #
    # ------------------------------- #
    Actzo [M:SIH4]QTY(NOL)
    If [M:SIH4]STOMGTCOD(NOL)<>1 & [M:SIH1]STOMVTFLG=2 & [M:SIH4]RTNSTOUPD(NOL)=2
        # -------------------- #
        # Ligne gérée en stock #
        # -------------------- #
        If ([M:SIH1]SIHORI=1 | ([M:SIH1]SIHORI=4 & [M:SIH4]XSIHORINUM(NOL)="") | ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)="")) &
&           [M:SIH4]WSTOFLG(NOL)=0
            # Si avoir direct ou ligne directe d'avoir s/facture ou ligne directe d'avoir s/retour
            # Si les champs stocks ne sont pas renseignés       : Il faut "réactiver la ligne"
            #
            # (cas particulier où on a passé le flg mvt de stock de non à oui)
            # (cas particulier des lignes de composants générées automatiquement)
            Call STKACTLIG(NOL) From STKECR
            #   Initialisation et grisage champs stock sur ligne document d'entrée
            #   si "U" Pas d'initialisation des unités et coefficients
            Call INIZONENT([M:SIH4]ITMREF(NOL),"SIH4",[M:SIH4]DSTOFCY(NOL),[M:SIH1]BPCORD,2,"U",NOL,12,[M:SIH0]TRSCOD,[M]NUM,3,1) From STKECR
            If mkstat End : Endif
#            If dim([M:SIH4]PRIORD)>0  Raz [M:SIH4]PRIORD(NOL) : Actzo PRIORD(NOL) : Endif
            If dim([M:SIH4]PRIORD)>0  Actzo PRIORD(NOL) : Endif
        Elsif [M:SIH1]SIHORI=4 & [M:SIH4]XSIHORINUM(NOL)<>""
           # Si ligne d'avoir sur facture (picking)            : Il faut Activer/Désactiver les chmps
           #
           # Bug 67637
           # Il faut désactiver les champs statut,type emplacement, emplacement en fonction du contexte de l'article
           If dim([M:SIH4]WSTOSAI)>0
               If val(mid$([M:SIH4]WSTOSAI(NOL),4,1))=2 Diszo [M:SIH4]STA(NOL)    Else Actzo [M:SIH4]STA(NOL)    Endif
               If dim([M:SIH4]LOCTYP) >= 0 Then  # FGR 10/04/2015 : X3SUIVI107584
                 If val(mid$([M:SIH4]WSTOSAI(NOL),5,1))=2 Diszo [M:SIH4]LOCTYP(NOL) Else Actzo [M:SIH4]LOCTYP(NOL) Endif
               Endif
               If dim([M:SIH4]LOC) >= 0 Then  # FGR 10/04/2015 : X3SUIVI107584
                 If val(mid$([M:SIH4]WSTOSAI(NOL),6,1))=2 Diszo [M:SIH4]LOC(NOL)    Else Actzo [M:SIH4]LOC(NOL)    Endif
               Endif
           Endif
           # Bug 67637
           #      Il faut désactiver les champs lot, n°série
           # (cas particulier où on a passé le flg mvt de stock de non à oui
           Call STKDISZONPIC("SIH4", NOL) From TRTVENSTK
        Endif
        # Activation de la désignation du mvt toujours saisissable en création de la ligne
        If dim([M:SIH4]MVTDES)>0  Actzo MVTDES(NOL) : Endif
    # Bug 67637
    Else
        # ------------------------ #
        # Ligne non gérée en stock #
        # ------------------------ #
        Call STKGRILIG ("SIH4", NOL) From TRTVENSTK
    # Bug 67637
    Endif
Endif
End
