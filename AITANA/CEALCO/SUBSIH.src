# ---------------------- BPRSAC : collectif --------------------------
Subprog C_BPRSAC(VALEUR)
Variable Char    VALEUR()

# Pour les proformas on ne fait pas le ctrl (pb proforma avec prospect)
If VALEUR = "" & [M]INVTYP = 5 End Endif

If !clalev([F:CPY]) : Local File COMPANY  [CPY] : Endif
#If !clalev([F:GAC]) : Local File GACCOUNT [GAC] : Endif
Read [GAC]GAC1 = GCOA(GTYPGEN);VALEUR
If [F:GAC]AUZBPR(0)<>2
 # Tiers incompatible avec le collectif
 GMESSAGE = mess(45,106,1) : mkstat = 2 : End
Endif
# Ctrl non fait avant la V6 : Faut-il le faire ??
Call CONTACC(GTYPGEN,GCOA(GTYPGEN),[F:GAC]ACC,[M]SALFCY,"",[M]INVDAT) From CPTCNT
End

