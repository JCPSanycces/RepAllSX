Subprog AS_WRHE(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2 & VALEUR<>"" & [M]NBLIG<>0
   GMESSAGE=mess(342,184,1) : mkstat=2
Endif
End

Subprog AS_WRH(VALEUR)
Variable Char    VALEUR()
If GWRHOBY=2
  VALEUR = [M:SIH1]WRHE : mkstat=2 : End
Endif
If VALEUR=""
  VALEUR = [M:SIH1]WRHE
Endif
End

Subprog C_WRH(VALEUR)
Variable Char    VALEUR()
If VALEUR<>""
  Read [ITW]ITW0=[M]ITMREF(nolign-1);VALEUR
  If fstat
     GMESSAGE=[M]ITMREF(nolign-1)-":"-mess(343,184,1) : mkstat=2
  Endif
Endif

End

Subprog AM_WRH(VALEUR)
Variable Char    VALEUR()
If [M:SIH4]WRH(nolign-1)<>""
   Raz [M:SIH4]LOC(nolign-1)
Endif
End
######################################################################################
Subprog D_ISEXTDOC(VALEUR)
Variable Integer VALEUR

# -- RMA * Digital signature (DKS activity code related) * by default, all documents are internal
If GIMPORT
  If GFONCTION="FUNAUTINVS" | GFONCTION="FUNAUTINVC" | GFONCTION="FUNAUTINVT"
    #Field action triggered while automatically creating invoices by those fonctions
    #The process modifies the GIMPORT value to 1
    VALEUR = 1
  Else
    #It is an imported invoice
    VALEUR = 2
  Endif
Else
  VALEUR = 1
Endif

End
######################################################################################
Subprog AM_NUM(VALEUR)
Variable Char    VALEUR()

# -- RMA * Digital signature (DKS activity code related) * manually assigning a doc. number sets the document as external
If dim([M]ISEXTDOC)>0
    If VALEUR <>""
        [M]ISEXTDOC = 2
    Else
        [M]ISEXTDOC = 1
    Endif
Endif

End
