#######################################
# ------------------------- REP1 -------------------------------
Subprog AM_REP1(VALEUR)
Variable Char    VALEUR()

# --> Initialisation taux commission 1
If VALEUR = "" [M:SIH4]REPRAT1(nolign-1)=0 : End : Endif
If [M]CREFLG(nolign-1) <>0 : End : Endif
If [F:BPC]BPCNUM <> [M]BPCORD
    Read [F:BPC]BPC0 = [M]BPCORD
    If fstat Raz [F:BPC] : Endif
Endif
Read [F:REP]REP0 = VALEUR
If fstat=0
    If [F:BPC]COMCAT <> 0
        [M:SIH4]REPRAT1(nolign-1) = [F:REP]COMRAT1([F:BPC]COMCAT-1)
    Endif
Endif
End
########################################
# ------------------------- REPRAT1 -------------------------------
Subprog AS_REPRAT1(VALEUR)
Variable Decimal VALEUR

# --> Pas de saisie si rep1 non renseigne
If [M]REP1(nolign-1) = "":VALEUR = 0:mkstat=2:Endif
End
########################################
# ------------------------- REP2 -------------------------------
Subprog AM_REP2(VALEUR)
Variable Char    VALEUR()

# --> Initialisation taux commission 2
If VALEUR = "" [M:SIH4]REPRAT2(nolign-1)=0 : End : Endif
If [M]CREFLG(nolign-1) <> 0:End:Endif
If [F:BPC]BPCNUM <> [M]BPCORD
    Read [F:BPC]BPC0 = [M]BPCORD
    If fstat Raz [F:BPC] : Endif
Endif
Read [F:REP]REP0 = VALEUR
If fstat=0
    If [F:BPC]COMCAT <> 0
        [M:SIH4]REPRAT2(nolign-1) = [F:REP]COMRAT2([F:BPC]COMCAT-1)
    Endif
Endif
End
########################################
# ------------------------- REPRAT1 -------------------------------
Subprog AS_REPRAT2(VALEUR)
Variable Decimal VALEUR
# --> Pas de saisie si rep2 non renseigne
If [M]REP2(nolign-1) = "":VALEUR = 0:mkstat=2:Endif
End

