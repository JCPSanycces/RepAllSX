# ---------------------- CURTYP : type de cours --------------------------
# Issue 63491
Subprog C_CURTYP(VALEUR)
Variable Integer VALEUR

If VALEUR=[M:SIH2]CURTYP End Endif

Local Integer SPSTAT
Local Char    WOLDCUR(GLONTCU), WNEWCUR(GLONTCU)
Local Integer WCURTYP
Local Date    WINVDAT

WOLDCUR = [M:SIH2]CUR : WNEWCUR = [M:SIH2]CUR
WCURTYP = VALEUR
WINVDAT = [M:SIH0]INVDAT
Gosub CTL_EXIST_RAT_CUR From SUBSIHB
If SPSTAT <> 0 End Endif

End
# End issue 63491
#########################################################################
Subprog AM_CURTYP(VALEUR)
Variable Integer VALEUR
Local    Integer I
# --> Recalcul de l'en-cours et de l'en-cours autorise et des montants de facturation
Call CONVERT_MONTANT ([M:SIH2]CUR, [M:SIH2]CUR, VALEUR) From SUBSIHB
#----- Chargement du cours devise et du cours reporting -----#
#Call COURSITE([M:SIH2]CUR,GFCY,VALEUR,[M:SIH0]INVDAT,[M:SIH2]RATCUR,I)   From TRTDEV
#Call COURDEV([M:SIH2]CUR,GSYSCUR,VALEUR,[M:SIH0]INVDAT,[M:SIH2]RATRPT,I) From TRTDIV

# --> Chargement zones devises et cours -----#
#[M:SIH2]CURTYP=VALEUR
Call INI_COURS("SIH2",GSOCIETE,[M:SIH2]CUR,[M:SIH0]INVDAT,VALEUR) From SUBBICS

# Issue 63491
Affzo [SIH2]RAT1,LABEL,RAT2,CURMLT
# End issue 63491

[M:SIH0]CHGTYP=VALEUR
#----- Affichage des éléments de facturation onglet 1 et montants -----#
Affzo [SIH2]25
Local Char ANC_CUR : ANC_CUR=[M:SIH0]CUR
If [M:SIH4]NBLIG <> 0
#   On fait uniquement une conversion des montants : A voir
    GTARFLG = "C"
    Local    Char    WZONCOU
    Gosub RECALC_LIGNE From SUBSIHB
Endif
Raz GTARFLG
End
