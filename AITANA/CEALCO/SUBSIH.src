Subprog AM_RAT2(VALEUR)
Variable Decimal VALEUR
Local Char WCHAMP(10) : WCHAMP="RATMLT"
Gosub AM_RATX
# Issue 64430
If mkstat=2 End Endif
# End issue 64430

#Local Integer INDLED
#INDLED=find(GTYPGEN,[M:SCL]LEDTYP(0..[M:SCL]NBRC-1))
#If INDLED
#  [M:SCL]RATMLT(INDLED-1) =VALEUR : # Mise à jour de l'écran SAICURLED
