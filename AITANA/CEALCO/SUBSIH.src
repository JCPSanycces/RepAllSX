# ------------------------- STRDAT : Date début de prestation -------------------------------
Subprog AM_STRDAT(VALEUR)
Variable Date    VALEUR
If VALEUR=[0/0/0]
  [M:SIH4]ENDDAT(nolign-1)=[0/0/0] : Affzo [SIH4]ENDDAT(nolign-1)
Endif
End
# ------------------------- ENDDAT : Date fin de prestation -------------------------------
Subprog AS_ENDDAT(VALEUR)
Variable Date    VALEUR
If [M:SIH4]STRDAT(nolign-1)=[0/0/0]
  mkstat=2 : End
Endif
End
########################################
Subprog C_ENDDAT(VALEUR)
Variable Date    VALEUR
# Si la date début est renseignée alors la date fin doit être renseignée
If [M:SIH4]STRDAT(nolign-1)<>[0/0/0] & VALEUR=[0/0/0]
  GMESSAGE=mess(123,107,1) : # Date fin de prestation à renseigner
  mkstat=1 : End
Endif
End
# ------------------------- PERNBR : Nombre de périodes  -------------------------------
Subprog AS_PERNBR(VALEUR)
Variable Decimal VALEUR
If !GLOCITAPRE  mkstat=2 : End : Endif
End
# ------------------------- PERTYP : Type de périodes  -------------------------------
Subprog AS_PERTYP(VALEUR)
Variable Integer VALEUR
If !GLOCITAPRE  mkstat=2 : End : Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran SIH4) 29/07/2008 17:01:20 (CPO)
######################################################################################
Subprog AS_EECFLOPHY(VALEUR)
Variable Integer VALEUR
#-----Si facture avec mvt. de stock et article géré en stock => EECFLOPHY non modifiable
#----si la valeur du champ est "Oui"
If [M]STOMGTCOD(nolign-1)>1 and [M:SIH1]STOMVTFLG = 2 and [M]EECFLOPHY(nolign-1)=2
    mkstat=2
Endif
# -- Si avoir en valeur, EECFLOPHY n'est pas saisissable
If [M:SIH0]INVTYP=2  & [M:SIH4]QTY(nolign-1)=0 mkstat=2 Endif
End

######################################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran SIH4) 30/07/2008 10:03:32 (CPO)
######################################################################################
Subprog AM_EECFLOPHY(VALEUR)
Variable Integer VALEUR
End
######################################################################################
$D_CCEX
#------------------------------------#
# Initialisation commune aux 20 axes #
#------------------------------------#
If AXE>GNBDIE Return : Endif
Call INIT_CCE(VALEUR,AXE,"SID","",0) From TRTX3CPT
Return

$AS_CCEX
#----------------------------------#
# Avant saisie commune aux 20 axes #
#----------------------------------#

# 89619 : Saisie sections analytiques composants sous-traitance
# Les sections analytiques sont saisissables sauf sur les factures validées
# Elles st saisissables pour tous les types de lignes sf les composants kit (Saisie bloquée sur la ligne (C_NBLIG))
If GMODIF = 6 mkstat=2 Endif
# 89619

Call SAIS_CCE(VALEUR,AXE,"","") From TRTX3CPT
Return

$C_CCEX
#-----------------------------#
# Contrôle commun aux 20 axes #
#-----------------------------#
Call CTRL_CCE(VALEUR,AXE,"",GFINRSP,[M:SIH0]INVDAT) From TRTX3CPT
#--CPO 74669 Import des factures et contrôle sections (+modif obj SIH)
If GIMPORT & mkstat
  GMESSAGE-="-"-mess(18,197,1)-num$(nolign)-mess(80,197,1)-[M:SIH4]ITMREF(nolign-1)
Endif
#--CPO
Return
######################################################################################


#-----------------------------------------------------------------------#
# ETIQUETTES ET SOUS-PROGRAMMES APPELES PAR LES ACTIONS CHAMPS          #
#-----------------------------------------------------------------------#
#-----------------------------------------------------------------------------------#
# Modification dates de début/fin prestation entête avec répercution sur les lignes #
#-----------------------------------------------------------------------------------#
$REPORT_PERIODE_LIG
#---------------------------------------#
# TYPDAT : Type de la date à reporter   #
#          1 = Date début               #
#          2 = Date fin                 #
# OK     : Report sur toutes les lignes #
#          2 = Oui                      #
#          autres valeurs = Non         #
#          uniquement si date non nulle #
#---------------------------------------#
If [M:SIH4]NBLIG>0
  For I=0 To [M:SIH4]NBLIG-1
    If OK=2
&   | (TYPDAT=1 & [M:SIH4]STRDAT(I)=[0/0/0])
&   | (TYPDAT=2 & ([M:SIH4]ENDDAT(I)=[0/0/0] | [M:SIH4]ENDDAT(I)<[M:SIH4]STRDAT(I))) : # Bug 62989
      Case TYPDAT
        When 1 : [M:SIH4]STRDAT(I)=VALEUR : Affzo [M:SIH4]STRDAT(I)
                 # Bug 62989 : Si date fin ligne se retrouve < date début ligne, on force la date fin entête si ok
                 If [M:SIH4]ENDDAT(I)<[M:SIH4]STRDAT(I) & [M:SIH2]ENDDATSVC>=[M:SIH4]STRDAT(I)
                     [M:SIH4]ENDDAT(I)=[M:SIH2]ENDDATSVC : Affzo [M:SIH4]ENDDAT(I)
                 Endif
        When 2 : [M:SIH4]ENDDAT(I)=VALEUR : Affzo [M:SIH4]ENDDAT(I)
                 # Bug 62989 : Si date début ligne se retrouve < date fin ligne, on force la date fin entête si ok
                 If [M:SIH4]STRDAT(I)<[M:SIH4]ENDDAT(I) & [M:SIH2]STRDATSVC<=[M:SIH4]ENDDAT(I)
                     [M:SIH4]STRDAT(I)=[M:SIH2]STRDATSVC : Affzo [M:SIH4]STRDAT(I)
                 Endif
      Endcase
      [M:SIH4]UPDFLG(I)=1
    Endif
  Next I
Endif
Return


#-----------------------------------------------------------------------#
$RAZ_DISZO_TAR
# Remise à zéro et diszo des zones de tarifs en cas d'avoir en valeur
Raz [M:SIH4]GROPRI(NOL) : Diszo [M:SIH4]GROPRI(NOL) : Affzo [M:SIH4]GROPRI(NOL)
If dim([M:SIH4]DISCRGVAL1(NOL))>0 Raz [M:SIH4]DISCRGVAL1(NOL) : Diszo [M:SIH4]DISCRGVAL1(NOL) : Affzo [M:SIH4]DISCRGVAL1(NOL) Endif
If dim([M:SIH4]DISCRGVAL2(NOL))>0 Raz [M:SIH4]DISCRGVAL2(NOL) : Diszo [M:SIH4]DISCRGVAL2(NOL) : Affzo [M:SIH4]DISCRGVAL2(NOL) Endif
If dim([M:SIH4]DISCRGVAL3(NOL))>0 Raz [M:SIH4]DISCRGVAL3(NOL) : Diszo [M:SIH4]DISCRGVAL3(NOL) : Affzo [M:SIH4]DISCRGVAL3(NOL) Endif
If dim([M:SIH4]DISCRGVAL4(NOL))>0 Raz [M:SIH4]DISCRGVAL4(NOL) : Diszo [M:SIH4]DISCRGVAL4(NOL) : Affzo [M:SIH4]DISCRGVAL4(NOL) Endif
If dim([M:SIH4]DISCRGVAL5(NOL))>0 Raz [M:SIH4]DISCRGVAL5(NOL) : Diszo [M:SIH4]DISCRGVAL5(NOL) : Affzo [M:SIH4]DISCRGVAL5(NOL) Endif
If dim([M:SIH4]DISCRGVAL6(NOL))>0 Raz [M:SIH4]DISCRGVAL6(NOL) : Diszo [M:SIH4]DISCRGVAL6(NOL) : Affzo [M:SIH4]DISCRGVAL6(NOL) Endif
If dim([M:SIH4]DISCRGVAL7(NOL))>0 Raz [M:SIH4]DISCRGVAL7(NOL) : Diszo [M:SIH4]DISCRGVAL7(NOL) : Affzo [M:SIH4]DISCRGVAL7(NOL) Endif
If dim([M:SIH4]DISCRGVAL8(NOL))>0 Raz [M:SIH4]DISCRGVAL8(NOL) : Diszo [M:SIH4]DISCRGVAL8(NOL) : Affzo [M:SIH4]DISCRGVAL8(NOL) Endif
If dim([M:SIH4]DISCRGVAL9(NOL))>0 Raz [M:SIH4]DISCRGVAL9(NOL) : Diszo [M:SIH4]DISCRGVAL9(NOL) : Affzo [M:SIH4]DISCRGVAL9(NOL) Endif
Raz [M:SIH4]NETPRI(NOL) : Diszo [M:SIH4]NETPRI(NOL) : Affzo [M:SIH4]NETPRI(NOL)
Raz [M:SIH4]NETPRINOT(NOL) : Affzo [M:SIH4]NETPRINOT(NOL)
Raz [M:SIH4]NETPRIATI(NOL) : Affzo [M:SIH4]NETPRIATI(NOL)
Raz [M:SIH4]CPRPRI(NOL)    : Diszo [M:SIH4]CPRPRI(NOL) : Affzo [M:SIH4]CPRPRI(NOL)
Raz [M:SIH4]PFM(NOL)       : Affzo [M:SIH4]PFM(NOL)
Return
#-----------------------------------------------------------------------#
$ACTZO_TAR
# Activation des zones de tarifs
If GPRIMOD=2    : # 104045 : Activation only if the user can modify prices and discounts
    Actzo [M:SIH4]GROPRI(NOL)
    If dim([M:SIH4]DISCRGVAL1(NOL))>0 Actzo [M:SIH4]DISCRGVAL1(NOL) Endif
    If dim([M:SIH4]DISCRGVAL2(NOL))>0 Actzo [M:SIH4]DISCRGVAL2(NOL) Endif
    If dim([M:SIH4]DISCRGVAL3(NOL))>0 Actzo [M:SIH4]DISCRGVAL3(NOL) Endif
    If dim([M:SIH4]DISCRGVAL4(NOL))>0 Actzo [M:SIH4]DISCRGVAL4(NOL) Endif
    If dim([M:SIH4]DISCRGVAL5(NOL))>0 Actzo [M:SIH4]DISCRGVAL5(NOL) Endif
    If dim([M:SIH4]DISCRGVAL6(NOL))>0 Actzo [M:SIH4]DISCRGVAL6(NOL) Endif
    If dim([M:SIH4]DISCRGVAL7(NOL))>0 Actzo [M:SIH4]DISCRGVAL7(NOL) Endif
    If dim([M:SIH4]DISCRGVAL8(NOL))>0 Actzo [M:SIH4]DISCRGVAL8(NOL) Endif
    If dim([M:SIH4]DISCRGVAL9(NOL))>0 Actzo [M:SIH4]DISCRGVAL9(NOL) Endif
    Actzo [M:SIH4]NETPRI(NOL), NETPRINOT(NOL), NETPRIATI(NOL), CPRPRI(NOL)
Endif          : # 104045 : Activation only if the user can modify prices and discounts
Return
#-----------------------------------------------------------------------#
$AFF_RECH_TAR
# Affichage des zones de tarifs
Affzo [M:SIH4]GROPRI(NOL)
If dim([M:SIH4]DISCRGVAL1(NOL))>0 Affzo [M:SIH4]DISCRGVAL1(NOL) Endif
If dim([M:SIH4]DISCRGVAL2(NOL))>0 Affzo [M:SIH4]DISCRGVAL2(NOL) Endif
If dim([M:SIH4]DISCRGVAL3(NOL))>0 Affzo [M:SIH4]DISCRGVAL3(NOL) Endif
If dim([M:SIH4]DISCRGVAL4(NOL))>0 Affzo [M:SIH4]DISCRGVAL4(NOL) Endif
If dim([M:SIH4]DISCRGVAL5(NOL))>0 Affzo [M:SIH4]DISCRGVAL5(NOL) Endif
If dim([M:SIH4]DISCRGVAL6(NOL))>0 Affzo [M:SIH4]DISCRGVAL6(NOL) Endif
If dim([M:SIH4]DISCRGVAL7(NOL))>0 Affzo [M:SIH4]DISCRGVAL7(NOL) Endif
If dim([M:SIH4]DISCRGVAL8(NOL))>0 Affzo [M:SIH4]DISCRGVAL8(NOL) Endif
If dim([M:SIH4]DISCRGVAL9(NOL))>0 Affzo [M:SIH4]DISCRGVAL9(NOL) Endif
Return
