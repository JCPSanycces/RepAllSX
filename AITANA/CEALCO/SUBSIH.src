# ---------------------- PIHNUM : N° facture achat
Subprog IB_PIHNUM
If [M]PIHNUM="" & GFONC1<>"GESPIH" Raz GBOUT1 Endif
End
########################################
# ---------------------- VACBPR : regime taxe --------------------------
Subprog AS_VACBPR(VALEUR)
Variable Char    VALEUR()
# On ne peut modifier le regime de taxe d'un avoir sur facture
#If [M:SIH0]INVTYP = 2 & [M:SIH1]SIHORI = 4 mkstat = 2 : Endif
End
#---------------------------------------
Subprog AM_VACBPR(VALEUR)
Variable Char    VALEUR()

Local Char    WANCVACBPR : WANCVACBPR=[M]VACBPR     : # Bug 75162

[M]VACBPR = VALEUR
Gosub NEW_FACTURE From TRTVENFACC
Gosub NEW_REGIME From TRTVENFACC

If [M:SIH4]NBLIG <> 0
    Local    Char    WZONCOU
    GTARFLG = "V" : Gosub RECALC_LIGNE From SUBSIHB : Raz GTARFLG
    If mkstat [M]VACBPR=WANCVACBPR : End : Endif    : # Bug 75162
Endif

#RMA * 95066
Call FLD4041DIS(VALEUR, [M:SIH0]SIVTYP) From SUBSIH

End
########################################
# ---------------------- PRITYP : type prix --------------------------
Subprog AS_PRITYP(VALEUR)
Variable Integer VALEUR
# On ne peut modifier le type de prix d'un avoir sur facture
#If [M:SIH0]INVTYP = 2 & [M:SIH1]SIHORI = 4 mkstat = 2 : Endif
# On ne peut modifier le type de prix si on a une ligne d'avoir en valeur
If [M:SIH0]INVTYP = 2 & find(0, [M:SIH4]QTY(0..[M:SIH4]NBLIG-1)) mkstat = 2 : Endif
End
#---------------------------------------
Subprog AM_PRITYP(VALEUR)
Variable Integer VALEUR

If [M:SIH4]NBLIG <> 0 & GTARFLG = ""
# On a pas demandé la recherche tarif : Bascule des prix HT et TTC
    [M]PRITYP = VALEUR
    Local    Char    WZONCOU
    GTARFLG = "P" : Gosub RECALC_LIGNE From SUBSIHB
    Raz GTARFLG
Endif
End
########################################
# ---------------------- STOMVTFLG : flag mise à jour en stock --------------------------
Subprog AM_STOMVTFLG(VALEUR)    : # Action mise en interactif
Variable Integer VALEUR

Local Integer NOL, WRET

If VALEUR = 1    : # bug 31504
#If VALEUR = 1 & !GIMPORT
# ----------------------------------- #
# Si flag maj stock : oui --> non     #
# Traitement pour les factures        #
# ----------------------------------- #
   If [M:SIH0]INVTYP=1 & sum([M:SIH4]STOMGTCOD)>[M]NBLIG &
&     ([M:SIH1]SIHORI=1 | [M:SIH1]SIHORI=2 |
&      ([M:SIH1]SIHORI=3 & find("", [M:SIH4]SDHNUM(0..[M]NBLIG-1))))
       # S'il y a des lignes gérées en stock et
       # facture directe ou facture de commande ou
       # facture de livraison et il y a des lignes directes
       For NOL=0 To [M]NBLIG-1
           # Il faut déstocker de STOSORW
           Call DELSTOSORW(NOL,NOL,"SIH4",[M:SIH4]DSTOFCY(NOL),WRET) From STKSOR
           If WRET<>0 mkstat=2 : Break Endif
           If [M:SIH4]STOMGTCOD(NOL)>1
               Call RECSTOSOR (2,"SIH4",NOL,[M:SIH4]DSTOFCY(NOL),[M:SIH4]ITMREF(NOL),5,
&                          [M:SIH0]NUM,[M:SIH4]SIDLIN(NOL),"",WRET) From STKECR
           Endif
       Next
       If mkstat=2 End Endif
       Affzo [M:SIH4]5
   Endif
Endif
# -------------------------- #
# Traitement pour les avoirs #
# -------------------------- #
If [M:SIH0]INVTYP=2 & !GIMPORT
#   on est forcement sur un avoir direct ou un avoir sur facture avec mouvement de stock
    If VALEUR = 1
#     Si flag maj stock : oui --> non
#        remise à 0 de l'écran STOENTW
        Call DELSTOENTW (-1,-1,"SIH4",1,1,[M:SIH4]DSTOFCY(NOL),1,"") From STKENT
        For NOL=0 To[M]NBLIG-1
            [M]WSTOFLG(NOL)=2                        : # Article non géré en stock
            If [M]SIHORI=1 [M]RTNSTOUPD(NOL)=1 Endif : # Pas de maj des stocks
        Next
        Raz [M]GESLOT, [M]WSTOSEQ, [M]WSRUFLG
        Gosub RAZ_TABL_STOCK From SUBSIHB           : # Raz des champs stock sur la ligne de document
        # Force l'affichage afin que les Grizo
        # appelés ensuite fonctionnent
        Affzo [M:SIH4]5
        Call STKGRICOL("SIH4",[M]NBLIG) From STKECR : # Grize toutes les colonnes stock
    Endif
    If VALEUR=2
#     Si flag maj stock : non --> oui
        If [F:SLT]STRNUM<>GFLAG Read [SLT]SLT0=5;GFLAG
                                If fstat Raz [F:SLT] Endif
                                Endif
        For I=0 To [M]NBLIG-1
            # article géré en stock et avoir en qté : direct ou sur facture ou ligne directe d'un avoir sur retour
            If [M:SIH4]STOMGTCOD(I)>1 & [M:SIH4]QTY(I)<>0 & ([M:SIH1]SIHORI=1 | ([M:SIH1]SIHORI=4 & [M:SIH4]RTNSTOUPD(I)=2) | ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(I)=""))
                If [M]SIHORI=1 [M]RTNSTOUPD(I)=2 Endif : # Maj des stocks
                Raz [M]WSTOFLG(I)
                Default Mask [SIH4]
                Call INIZONENT([M:SIH4]ITMREF(I),"SIH4",[M:SIH4]DSTOFCY(I),[M:SIH1]BPCORD,2,"U",I,12,[M]TRSCOD,[M]NUM,3,1) From STKECR
                If mkstat Break : Endif
                # Lecture des mouvements de stock d'une ligne de document pour stockage dans écran de travail STOENTW
                Call STJSTOENTW("SIH4",12,18,[M:SIH0]INVDAT,I,[M:SIH4]NBLIG,"SLT",0,WRET) From STKENT
                # WRET=1 : Erreur pour stockage dans ENTW : La ligne ne peut pas être créée
                # WRET=2 : Aucune ligne ds ENTW : Tt a déjà été retourné : Pas de ligne à créer
                # WRET=4 : Il y a des lignes ENTW mais il y a aussi des mvts en attente : La ligne peut être créée
                # WRET=6 : Aucune ligne ds ENTW : Ts les mvts st en attente : La ligne ne peut pas être créée
                If WRET=4
                    Call MESSAGE([M:SIH4]XSIHORINUM(NOL)-":"-[M:SIH4]ITMREF(NOL)-mess(152,191,1)) From GESECRAN
                Elsif WRET<>0
                    If WRET=2
                        Call ERREUR([M:SIH4]XSIHORINUM(NOL)-":"-[M:SIH4]ITMREF(NOL)-"\"-mess(285,192,1)) From GESECRAN
                    Elsif WRET=6
                        Call ERREUR([M:SIH4]XSIHORINUM(NOL)-":"-[M:SIH4]ITMREF(NOL)-":"-mess(284,192,1)-"\"-mess(153,191,1)) From GESECRAN
                    Endif
                    mkstat=2 : Break
                Endif
                If [M:SIH1]SIHORI=4 & [M:SIH4]XSIHORINUM(NOL) <> ""
                    Call RECPRISTJ([M:SIH4]DSTOFCY(NOL),5,[M:SIH4]XSIHORINUM(NOL),[M:SIH4]SIDORILIN(NOL),[M:SIH4]PRIORD(NOL)) From STKENT
                    Affzo [M:SIH4]PRIORD(NOL)
                Endif
            Endif
        Next
        If mkstat End Endif
    Endif
Endif
# Activation/Désactivation des champs
If VALEUR=1
    Grizo [M:SIH1]STOFCY, TRSFAM
    If dim([M:SIH1]WRHE)>0 Grizo [M:SIH1]WRHE Endif
    If [M:SIH0]INVTYP=2 & dim ([M:SIH1]SRGLOCDEF)>0 Grizo [M:SIH1]SRGLOCDEF Endif
Endif
If VALEUR=2
   If find([M:SIH1]SIHORI,1,4) : # Facture directe ou avoir direct ou avoir sur facture
      Actzo [M:SIH1]STOFCY, TRSFAM
      If dim([M:SIH1]WRHE)>0 Actzo [M:SIH1]WRHE Endif
      If [M:SIH0]INVTYP=2 & dim ([M:SIH1]SRGLOCDEF)>0 Actzo [M:SIH1]SRGLOCDEF Endif
   Else                        : # Facture Cde, Liv, Contrat, Dde, Trsf ou Avoir sur Retour
      Diszo [M:SIH1]STOFCY, TRSFAM
      If dim([M:SIH1]WRHE)>0 Diszo [M:SIH1]WRHE Endif
      If [M:SIH0]INVTYP=2 & dim ([M:SIH1]SRGLOCDEF)>0 Diszo [M:SIH1]SRGLOCDEF Endif
   Endif
Endif
#

End
########################################
# ---------------------- STOFCY : site stock --------------------------
Subprog AS_STOFCY(VALEUR)
Variable Char    VALEUR()
# Si ce n'est pas un avoir sur facture et qu'il y a déjà des lignes
If [M]NBLIG<>0 & [M]SIHORI<>4 mkstat=2 Endif
# Si c'est un avoir sur facture mais que l'on est pas en création
If [M]SIHORI=4 & GREP<>"C" mkstat=2 Endif
End
#---------------------------------------
Subprog C_STOFCY(VALEUR)
Variable Char    VALEUR()
# Si facture (directe,cde,liv,contrat) ou avoir (direct,facture,retour) avec mvt stock
If ([M:SIH0]INVTYP<3 & [M:SIH1]STOMVTFLG=2) & VALEUR=""
   mkstat=2
Endif
# Actzo ou Grizo des dépôts selon le site
[M]STOFCY=VALEUR
Gosub WRH_ETAT From SUBSIHA
End

#########################################################################
#                     ECRAN COMPLEMENT : SIH2                           #
#########################################################################
########################################
# ---------------------- CUR : devise --------------------------
# Issue 63491
Subprog C_CUR(VALEUR)
Variable Char    VALEUR()

If VALEUR=[M:SIH2]CUR End Endif

Local Integer SPSTAT
Local Char    WOLDCUR(GLONTCU), WNEWCUR(GLONTCU)
Local Integer WCURTYP
Local Date    WINVDAT

WOLDCUR = [M:SIH2]CUR    : WNEWCUR = VALEUR
WCURTYP = [M:SIH2]CURTYP
WINVDAT = [M:SIH0]INVDAT
Gosub CTL_EXIST_RAT_CUR From SUBSIHB
If SPSTAT <> 0 mkstat=2 : End Endif

End
# End isssue 63491
#########################################################################
Subprog AM_CUR(VALEUR)
Variable Char    VALEUR()
Local    Integer I
# --> Recalcul de l'en-cours et de l'en-cours autorise et des montants de facturation
Call CONVERT_MONTANT (VALEUR, [M:SIH0]CUR, [M:SIH2]CURTYP) From SUBSIHB
# --> Chargement du cours devise et du cours reporting
#Call COURSITE(VALEUR,GFCY,[M:SIH2]CURTYP,[M:SIH0]INVDAT,[M:SIH2]RATCUR,I)   From TRTDEV
#Call COURDEV(VALEUR,GSYSCUR,[M:SIH2]CURTYP,[M:SIH0]INVDAT,[M:SIH2]RATRPT,I) From TRTDIV

# --> Chargement zones devises et cours -----#
#[M:SIH2]CUR=VALEUR

Call INI_COURS("SIH2",GSOCIETE,VALEUR,[M:SIH0]INVDAT,[M:SIH2]CURTYP) From SUBBICS

#If GACTMUL=2
# Alimentation du format des colonnes frais/remise
Call ALIFORREM (5, GFLAG, "SIH4", 0, VALEUR) From TRTPRICE
#Endif
Affzo [M:SIH4]5

If VALEUR = GLOCALDEV
    Diszo [M]CURTYP
Else
    Actzo [M]CURTYP
Endif
Affzo [SIH2]RAT1,LABEL,RAT2,CURMLT

Local Char ANC_CUR : ANC_CUR=[M:SIH0]CUR
# 29/05/01
[M:SIH0]CUR = VALEUR

Affzo [M:SIH0]CUR
Affzo [M:SIH2]25
# On a pas demandé la recherche tarif : Conversion des montants
If [M:SIH4]NBLIG <> 0 & GTARFLG = ""
    [M:SIH0]CUR = VALEUR
    Local    Char    WZONCOU
    GTARFLG = "C" : Gosub RECALC_LIGNE From SUBSIHB
Endif
Raz GTARFLG

# SAM 110033: Swiss localization: hide / display fields BVRNUMREF / PAYBAN
If func AFNC.ACTIV("KSW") Then
  Call SHOW_HIDE_BVRFIELDS([M:SIH0]SALFCY, [M:SIH0]INVTYP, [M:SIH2]PTE, VALEUR) From SUBSIHSWI
Endif
# SAM 110033 END
End

End
