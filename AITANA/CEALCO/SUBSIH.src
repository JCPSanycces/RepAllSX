Subprog C_STRDUDDAT(VALEUR)
Variable Date    VALEUR
If VALEUR <> [M]STRDUDDAT & VALEUR < [M:SIH0]INVDAT
    Local Integer OK : OK=1
    Call AVERTIR(mess(252,192,1), OK) From GESECRAN
    If OK=1 mkstat=2 Endif
Endif
End
