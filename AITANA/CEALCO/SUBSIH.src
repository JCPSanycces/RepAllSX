########################################
#----------------------------------------------#
# Après modif cours diviseur ou multiplicateur #
#----------------------------------------------#
$AM_RATX
#-----
Local Integer INDLED
INDLED=find(GTYPGEN,[M:SCL]LEDTYP(0..[M:SCL]NBRC-1))
If INDLED
  Assign "[M:SCL]" +WCHAMP+"(INDLED-1)" With VALEUR : # Mise à jour de l'écran SAICURLED
  Assign "[M:SIH2]"+WCHAMP+"(INDLED-1)" With VALEUR : # Mise à jour tableau des cours invisibles
Endif

# Issue 64430
Local Decimal WCOURS
If [M:SIH2]RATMLT<>0 & [M:SIH2]RATDIV<>0
    WCOURS=arr([M:SIH2]RATMLT/[M:SIH2]RATDIV, 10^-GDECRCU)
    If GUSER="LD" Infbox "WCOURS="-num$(WCOURS) Endif
Endif
If WCOURS=0 GMESSAGE=mess(549,192,1) : GERR=1 : mkstat=2 : Return : Endif
# End issue 64430

#-----
If [M:SIH2]CURLED(INDLED-1)<>[M:SIH2]CUR
  Local Char    CODLED(GLONLED)
  Local Char    DEVLED(GLONCUR)
  Local Integer I
  If !clalev([F:CPY]) : Local File COMPANY  [CPY] : Endif
  If [F:CPY]CPY<>GSOCIETE
    Read [CPY] CPY0=GSOCIETE   : If fstat  Raz [F:CPY] : Endif
  Endif
  If [F:GCM]GCM<>[F:CPY]ACM
    Read [GCM] GCM0=[F:CPY]ACM : If fstat  Raz [F:CPY] : Endif
  Endif
  For I=1 To len(mess(0,2644,1))
    If I<>INDLED
      Call LECLED(GSOCIETE,I,CODLED,DEVLED) From CPTDIV
      If DEVLED=[M:SIH2]CURLED(INDLED-1) & [F:GCM]FLGVCRRAT(I-1)=2
        Assign "[M:SCL]" +WCHAMP+"(I-1)" With VALEUR
        Assign "[M:SIH2]"+WCHAMP+"(I-1)" With VALEUR
      Endif
    Endif
  Next
Endif
#-----
# 89253 : Modification des cours : Recalcul de la marge
# Recherche du prix de revient car il défini en dev société (il doit être reconverti avec le nvx cours)
If [M:SIH4]NBLIG <> 0
    Local    Char    WZONCOU : WZONCOU=WCHAMP
    Gosub RECALC_LIGNE From SUBSIHB
Endif
Raz GTARFLG
# 89253

# 104460 : Modification cours : Recalcul des mnts HT et TTC de la facture dans la devise société
Local Decimal WCOURS : WCOURS=0
Local Integer STAT
If [M:SIH2]RATDIV(GTYPGEN-1)<>0 WCOURS=arr([M:SIH2]RATMLT(GTYPGEN-1)/[M:SIH2]RATDIV(GTYPGEN-1), 10^-GDECRCU) : Endif
Call COURMNT([M:SIH2]CUR,GLOCALDEV,GLOCALDEV,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,1,
&            [M:SIHV]INVNOT,[M:SIHV]INVNOTRPT,WCOURS,STAT) From TRTDEV
Call COURMNT([M:SIH2]CUR,GLOCALDEV,GLOCALDEV,[M:SIH0]CHGTYP,[M:SIH0]INVDAT,1,
&            [M:SIHV]INVATI,[M:SIHV]INVATIRPT,WCOURS,STAT) From TRTDEV
Affzo [M:SIHV]INVNOTRPT, INVATIRPT
# 104460

Return
