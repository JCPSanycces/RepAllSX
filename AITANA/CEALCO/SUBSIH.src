Subprog FLD4041DIS(AVAC,ASIVTYP)
Value Char AVAC
Value Char ASIVTYP

#RMA * 95066
If [M:SIH1]INVSTA = 3 : End : Endif

If !func AFNC.ACTIV("KPO") : End : Endif

If !clalev([F:SLT]) : Local File SALTRS [SLT] : Endif
If [F:SLT]STRTYP <> 5 | [F:SLT]STRNUM <> GFLAG
  Read [F:SLT]SLT0 = 5;GFLAG
  If fstat : Raz [F:SLT] : Endif
Endif

Local Char HS(1)

[L]HS = func PORLEGLIB.SHWHID4041(GCURLEG,AVAC,1,ASIVTYP,40)
If find([F:SLT]FLD40RENCOD,3) : [L]HS = "-" : Endif
If [L]HS = "+"
  If find([F:SLT]FLD40RENCOD,2) | [M:SIH1]INVSTA = 3 : [L]HS = "P" : Endif
Endif
Chgfmt [M:SIH1]FLD40REN With [L]HS+"K:5X"

[L]HS = func PORLEGLIB.SHWHID4041(GCURLEG,AVAC,1,ASIVTYP,41)
If find([F:SLT]FLD41RENCOD,3) : [L]HS = "-" : Endif
If [L]HS = "+"
  If find([F:SLT]FLD41RENCOD,2) | [M:SIH1]INVSTA = 3 : [L]HS = "P" : Endif
Endif
Chgfmt [M:SIH1]FLD41REN With [L]HS+"K:5X"

Affzo [M:SIH1]FLD40REN
Affzo [M:SIH1]FLD41REN

End
