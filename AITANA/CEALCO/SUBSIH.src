Subprog C_PTE(VALEUR)
Variable Char    VALEUR()

# Condition de paiement obligatoire si pas avoir
If [M:SIH0]INVTYP<>2 & VALEUR=""
   mkstat=2
Endif
End

######################################################################################
Subprog AM_PTE(VALEUR)
Variable Char    VALEUR()
Local    Integer SEVCRTYP
# 78411 - If Payment terms were SE and no longer are - void any outstanding Auth
If func AFNC.ACTIV("SEPP")
  If !clalev([F:SEU])  Local File SEAUTH [SEU] Endif
  If find([M:SIH0]INVTYP,2,4) : SEVCRTYP = 18 : Else : SEVCRTYP = 5 : Endif

  If !func SEPPLIB.SEPP_DOC(VALEUR) & func SEPPLIB.SEPP_DOC([M:SIH2]PTE)
&   & func SEPPCDT.SEPP_OK(SEVCRTYP,[F:SIV]NUM,1) & [F:SEU]STAFLG=3
    Call MESSAGE(mess(38,2092,1)) From GESECRAN
  Endif
Endif

# 87923 : Gestion des prélèvements SDD
If dim([M:SIH2]UMRNUM)>0
    If GSDDMGT=2 & find([M:SIH0]INVTYP, 1,2)
        Local Integer WSDDFLG
        WSDDFLG=func TRTVENSDD.IS_PTE_SDD(VALEUR,GSOCIETE)
        If [M:SIH2]SDDFLG=2 & WSDDFLG=1 Raz [M:SIH2]UMRNUM Endif
        [M:SIH2]SDDFLG=WSDDFLG
        If [M:SIH2]SDDFLG=2 & [M:SIH2]UMRNUM=""
            Call INIT_UMRNUM(GSOCIETE,[M:SIH1]BPRPAY,2,2,[M:SIH2]UMRNUM) From INVSDDLIB
        Endif
    Else
        [M:SIH2]SDDFLG=1
    Endif
    Gosub GRIZO_UMRNUM From TRTVENSDD
Endif
# 87923

# SAM 110033: Swiss localization: hide / display fields BVRNUMREF / PAYBAN and recalculate PAYBAN
If func AFNC.ACTIV("KSW") Then
  Call CALC_PAYBAN([M:SIH0]SALFCY, [M:SIH0]INVTYP, VALEUR, [M:SIH1]BPRPAY, [M:SIH2]CUR) From SUBSIHSWI
Endif
# SAM 110033 END

End
######################################################################################
# 87923 : Gestion des prélèvements SDD
# ---------------------- UMRNUM : N° mandat --------------------------
Subprog C_UMRNUM(VALEUR)
Variable Char    VALEUR()

#--CPO 87923 Gestion des prélèvements SDD
#--Pas de contrôle si on vient des facturations automatiques
#--Pas de contrôle depuis bt Ddes de service et Contrats de service
#--Car init et contrôle fait ailleurs (non bloquants)
#--Sauf si on reste sur la facture créée et on vient la modifier, le contrôle doit se déclencher !
# Issue 107888 - 2016-09-09 by CPO : US150 Free products not deliverable invoicing
#--Pas de contrôle si bt factures sur commandes normales avec échéanciers de facturation
#--Ajout FUNAUTINVSCH et GESSOH
If find(GFONC1,"FUNAUTINVD","FUNAUTINVO","FUNAUTINVC","FUNAUTINVS","FUNAUTINVT","FUNAUTINSCH","GESSRE", "GESCON","GESSOH")<1 |
& (find(GFONC1,"GESSRE", "GESCON")>0 and GREP<>"C")
& |    (GFONC1="GESSOH" and [M:SIH1]SIHORI=10 and GREP<>"C")
  #--/
  If VALEUR="" mkstat=2 :  GMESSAGE=mess(10,123,1) : End Endif
  Call CTL_UMRNUM(VALEUR,GSOCIETE,[M:SIH1]BPRPAY) From INVSDDLIB
  If mkstat=2 End Endif
Endif

End
######################################################################################
# 87923

######################################################################################
## Etiquette ajoutée par le superviseur (écran SIH2) 28/09/2010 15:32:23 (LD)
######################################################################################
Subprog AM_DEP(VALEUR)
Variable Char    VALEUR()
# V6.2 : 60763 Settlements Discounts
#Gbn-81683-Early discount-Dans tous les cas, il faut faire le recalcul en cas de modif
#          du code escompte.
# Si le code escompte a évolué, que cela influe sur l'élt de facturation remise sur taxe
# --> Il faut refaire le calcul facture
[M:SIH2]DEP=VALEUR

# 102423 : Belgium Early discounts
# Early discount rate determination
If find(GDEPMGTMOD, 1,5)
#If find(GDEPMGTMOD, 1,5) & [M:SIH0]INVTYP=1
    Call ALIDISVAT (5, VALEUR, GBIDI1,[M:SIH2]DEPRAT) From SUBTDA
Endif
#  102423

If [M:SIH4]NBLIG<>0        : # 102423 : Belgium Early discounts
    Gosub CHARG_TABLEAUX From TRTVENFACC
    Gosub CAL_FACTURE From TRTVENFACC
    [M:SIH0]INVCLCFLG=1
    [M:SIH4]INVNOT = [M:SIHV]INVNOT
    [M:SIH4]INVATI = [M:SIHV]INVATI
    Affzo [M:SIHV]1-99
    Affzo [M:SIH4]1-99
Endif                      : # 102423

End
