#Subprog B3_PJT(VALEUR)
#Variable Char    VALEUR()
#[M:SIH1]PJTFLT = "BPC"
#End
###########################################################################
#Subprog AM_PJT(VALEUR)
#Variable Char    VALEUR()
#
#[M:SIH1]CMGNUM = ""
#[M:SIH1]OPGNUM = ""
#[M:SIH1]OPGTYP = ""
#
#[M:SIH1]PJT = VALEUR
#Affzo [M:SIH1]PJT
#End
# ---------------------- PJT : Affaire --------------------------
########################################
Subprog IB_PJT

  If GMODU(13) = 2 Then
    If [M:SIH1]PJT = "" Then
      If [M:SIH1]SIHORI = 1
        Call TEXTE(23422, GBOUT5) From OBJDIV      #Origine marketing
        If [M:SIH1]OPGNUM <> "" Then
          Case [M:SIH1]OPGTYP
            When "OMM"
              GBOUT6 = mess(2,2994,1) - ":" - [M:SIH1]OPGNUM
            When "OMP"
              GBOUT6 = mess(3,2994,1) - ":" - [M:SIH1]OPGNUM
            When "OMT"
              GBOUT6 = mess(4,2994,1) - ":" - [M:SIH1]OPGNUM
            When "OMN"
              GBOUT6 = mess(5,2994,1) - ":" - [M:SIH1]OPGNUM
            When Default
              Raz GBOUT6
          Endcase
        Else
          Raz GBOUT5
        Endif
      Else
        Raz GBOUT5
        Raz GBOUT6
      Endif
    Else
      Raz GBOUT5
      Raz GBOUT6
    Endif
  Else
    Raz GBOUT5
    Raz GBOUT6
  Endif
End

##########################################################################
Subprog AM_PJT(VALEUR)
Variable Char    VALEUR()

  [M:SIH1]CMGNUM = ""
  [M:SIH1]OPGNUM = ""
  [M:SIH1]OPGTYP = ""


  # Réinitialisation des sections analytiques
  # ssi aucune ligne saisie (car il n'y a pas de réinitialisation des sections sur les lignes)
  If [M:SIH4]NBLIG=0
      If dim([M]NBAXE)>0
        If [M]NBAXE>0
            For I=1 To [M]NBAXE Raz [M]CCE(I-1) : Next
        Endif
        [M:SIH1]PJT=VALEUR
        Call INIT_CCEH("SIH2","NBAXE","SIH") From TRTX3CPT
        Affzo [M:SIH2]20
      Endif
  Endif

End

# 71065 : PJT
########################################
Subprog AM_REP(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL : NOL=nolign-1
Local    Integer SAV_INDICE : SAV_INDICE=indice #Fq74245-Gbn
If [M:SIH4]NBLIG <> 0
    Local Char    WZONCOU : WZONCOU="REP"
    Local Integer OK : OK=1
    Raz GTARFLG
#   --> Rep. gérés à la ligne : Demande de répercution sur le détail
#   --> Rep. non gérés à la ligne : Répercution automatique
    If GLINREP=2 Call OUINON(mess(67,196,1), OK) From GESECRAN Endif
    If GLINREP=1 | OK=2 Gosub RECALC_LIGNE From SUBSIHB Endif
Endif
indice=SAV_INDICE #Fq74245-Gbn
End
########################################
# ---------------------- SIHORINUM : N° document origine
Subprog IB_SIHORINUM

Raz GBOUT1
#  Facture ou proforma : Tunnel sur document origine
Case [M:SIH1]SIHORI
    When 2 :    # Commandes
      If [M]SIHORINUM <> "" & GFONC1 <> "GESSOH" GBOUT1 = mess(48,198,1) : Endif
    When 3 :    # Livraisons
      If [M]SIHORINUM <> "" & GFONC1 <> "GESSDH" GBOUT1 = mess(90,198,1) : Endif
    When 5 :    # Devis
      If [M]SIHORINUM <> "" & GFONC1 <> "GESSQH" GBOUT1 = mess(121,198,1) : Endif
    When 6 :    # Retour
      If [M]SIHORINUM <> "" & GFONC1 <> "GESSRH" GBOUT1 = mess(192,198,1) : Endif
    When 7 :    # Contrat
        If GMODU(12) = 2
            If [M]SIHORINUM <> "" & GFONC1 <> "GESCON" GBOUT1 = mess(92,198,1) : Endif
        Else
            Raz GBOUT1
        Endif
    When 8 :    # Demande
        If GMODU(12) = 2
            If [M]SIHORINUM <> "" & GFONC1 <> "GESSRE"
                Read [SRE] SRE0 = [M]SIHORINUM
                If fstat
                    Raz GBOUT1
                Else
                    Call TEXTE(14603, GBOUT1) From OBJDIV      #Demande de service
                Endif
            Else
                Raz GBOUT1
            Endif
        Else
            Raz GBOUT1
        Endif
    When 9 :    # Transfert
      If [M]SIHORINUM <> "" & GFONC1 <> "GESSCS" GBOUT1 = mess(461,198,1) : Endif
    When 10 :   # Scheduled invoices
      # 107888 : Scheduled invoices : (LD:10/05/16)
      # For the moment, we manage only scheduled invoices from order
      # This will have to be changed when we'll manage other scheduled invoices
      Raz GBOUT1
      If [M]SIHORINUM <> ""
        If [M]SIHORITYP=10 & GFONC1 <> "GESSOH" GBOUT1 = mess(48,198,1) Endif
      Endif
      # 107888 : Scheduled invoices : (LD:10/05/16)
Endcase

End
#---------------------------------------
$AB1_SIHORINUM
#----------------------------------------#
# Action avant bouton tunnel             #
#----------------------------------------#
Local Char WOBJCLEC, WOBJETC

WOBJCLEC=[M]SIHORINUM
#  Facture ou proforma : Tunnel sur document origine
Case SIHORI
    When 2 :    # Commandes
      WOBJETC= "SOH"
    When 3 :    # Livraisons
      WOBJETC= "SDH"
    When 5 :    # Devis
      WOBJETC= "SQH"
    When 6 :    # Retour
      WOBJETC= "SRH"
    When 7 :    # Contrat
      WOBJETC= "CON"
    When 8 :    # Demande de service
      WOBJETC= "SRE"
    When 9 :    # Transfert
      WOBJETC= "SCS"
    When 10 :   # Scheduled invoices
      # 107888 : Scheduled invoices : (LD:10/05/16)
      # For the moment, we manage only scheduled invoices from order
      # This will have to be changed when we'll manage other scheduled invoices
      If [M]SIHORITYP=10 WOBJETC= "SOH" Endif
      Gosub AB1_SIHORINUM From LIBSAL_INVCND_SIH
      # 107888 : Scheduled invoices : (LD:10/05/16)
Endcase
Return
#---------------------------------------
$BB1_SIHORINUM
#----------------------------------------#
# Action avant bouton tunnel             #
#----------------------------------------#
Local Char WOBJCLEC, WOBJETC

WOBJCLEC=[M]SIHORINUM
#  Facture ou proforma : Tunnel sur document origine
Case SIHORI
    When 10 :   # Scheduled invoices
      # 107888 : Scheduled invoices : (LD:10/05/16)
      # For the moment, we manage only scheduled invoices from order
      # This will have to be changed when we'll manage other scheduled invoices
      If [M]SIHORITYP=10 WOBJETC= "SOH" Endif
      Gosub BB1_SIHORINUM From LIBSAL_INVCND_SIH
      # 107888 : Scheduled invoices : (LD:10/05/16)
Endcase
Return
