#########################################################################
#                     ECRAN LIGNES : SIH4                               #
#########################################################################

########################################
# ---------------------- NBLIG : no ligne --------------------------
Subprog IB_NBLIG
Local Integer NOL : NOL = nolign-1

# Si facture directe avec maj stock
# ou facture de commande
# ou facture de livraison mais ligne sans no liv
# et article géré en stock
Raz GOUVSOR
If   [M:SIH0]INVTYP=1 & [M:SIH4]STOMGTCOD(NOL)<>1 &
&  (([M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG=2)      | [M:SIH1]SIHORI=2 |
&   ([M:SIH1]SIHORI=3 & [M:SIH4]SDHNUM(NOL)=""))
   GOUVSOR=1
Endif

Call IB_NOTECHECK([M:SIH4]ITMREF(NOL),"ITMREF",18)  From TRTNTSCTL # product notes

# Bouton  1 : Calcul tarif
# Bouton  2 : Visu calcul tarif
# Bouton  3 : Saisie des sorties
# Bouton  4 : Modification des sorties
# Bouton  5 : Saisie des entrées
# Bouton  6 : Informations lots
# Bouton  7 : Saisie complément lot
# Bouton  8 : Modification des entrées
# Bouton  9 : Texte ligne
# Bouton 10 : Périodes de prestation
# Bouton 11 : Tunnels
# Bouton 12 : Detail valorisation
# Bouton 13 : Stock par site
# Bouton 14 : Traçabilité pièces ventes (SYMEU 22/12/2008)
# Bouton 15 : Situation ligne (MABON 03/02/2009)
# Bouton 16 : Suppression lignes issues d'une livraison
# Bouton 17 : Product information - DF 79831

GBOUT15 = mess(164,198,1)               : # Situation ligne

If [M:SIH4]ITMREF(NOL)=""
   Raz GBOUT1,GBOUT2,GBOUT3,GBOUT4,GBOUT5,GBOUT6,GBOUT7,GBOUT8,GBOUT9,GBOUT10,GBOUT11,GBOUT12, GBOUT13, GBOUT14, GBOUT15
   Raz GBOUT16,GBOUT17  # DF 79831
   End
Endif

# Si je n'ai pas de verrou et que je ne suis ni en création, ni en duplication,
# c'est que cette livraison est verrouillée par une autre session
If GUNVERROU=0  & !find(GREP,"C","D") Raz GBOUT3 Endif

# Facture ou proforma : Tunnel sur document origine
If find([M]INVTYP,1,5)
   Raz GBOUT11
   If [M]SDHNUM(NOL)<>""
       If GFONC1<>"GESSDH" GBOUT11=mess(90,198,1)-[M]SDHNUM(NOL) : Endif  : # Livraisons
   Elsif [M]SOHNUM(NOL)<>""
       If GFONC1<>"GESSOH" GBOUT11=mess(48,198,1)-[M]SOHNUM(NOL) : Endif  : # Commandes
   Elsif [M]SQHNUM(NOL)<>""
       If GFONC1<>"GESSQH" GBOUT11=mess(121,198,1)-[M]SQHNUM(NOL) : Endif : # Devis
   Endif
Endif
# Avoir : Tunnel sur document origine
If [M]INVTYP=2 & GFONC1<>"GESSRH"
   If [M:SIH4]SRHNUM(NOL) <> ""
      GBOUT11 = mess(192,198,1)-[M:SIH4]SRHNUM(NOL)                       : # Retour
   Else
      Raz GBOUT11
   Endif
Endif

# BRBAN 105200#US2
If func AFNC.ACTIV("INVCA")>0
  If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
    Raz GBOUT1
    Raz GBOUT2
    Raz GBOUT9
    Raz GBOUT11
   # Issue 110573 - 2015-10-23 by BRBAN
    Raz GBOUT8
  Endif
Endif
# -

# SYMEU 09/12/2008 : branchement traçabilité pièces
If find(GREP,"C","D") or find("CONSPIV",GNAVIG(1..GPILNAV)) or [M:SIH0]INVTYP>2 Then Raz GBOUT14 Endif

# Si facture/avoir validé, pas de calcul tarif, pas d'accés aux stock
# Mais modif des stocks uniquement pour modifier les sections analytiques des stocks
# et on se barre
If [M:SIH1]INVSTA=3
   Raz GBOUT1,GBOUT3,GBOUT5,GBOUT6,GBOUT7
   Raz GBOUT16,GBOUT17   # DF 79831
   If [M:SIH0]INVTYP=1 : # Facture
       Raz GBOUT8
       # Pas de modif sorties
       # Si article non géré en stock ou Fac directe sans mvt de stock ou Fac de liv ou Fac de trsfert
       If [M:SIH4]STOMGTCOD(NOL)=1 | ([M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG<>2) |
&         ([M:SIH1]SIHORI=3 & [M:SIH4]SDHNUM(NOL)<>"") | ([M:SIH1]SIHORI=9 & [M:SIH4]SGHNUM(NOL)<>"") |
&          find([M:SIH1]SIHORI,7,8,10)  : # 107888 : Scheduled invoices : (LD:10/05/16)
#&          find([M:SIH1]SIHORI,7,8)    : # 107888 : Scheduled invoices : (LD:10/05/16)
           Raz GBOUT4
       Endif
   Else                : # Avoir
       Raz GBOUT4
       # Pas de modif entrées
       # Si article non géré en stock ou Avoir/ligne d'avoir ss mvt de stock ou Avoir sur retour
       If [M:SIH4]STOMGTCOD(NOL)=1 | [M:SIH1]STOMVTFLG=1 | [M:SIH4]RTNSTOUPD(NOL)=1 |
&         ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)<>"")
           Raz GBOUT8
       Endif
   Endif
   Gosub IB_NBLIG From LIBSAL_INVCND_SIH # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) SIHORI=10 Schedule invoice
   End
Endif

# Recalcul tarif uniquement si ligne directe et qté renseignée
If ([M:SIH4]SOHNUM(NOL)<>"" | [M:SIH4]SDHNUM(NOL)<>"" |
&   [M:SIH4]SQHNUM(NOL)<>"" | [M:SIH4]CONNUM(NOL)<>"" |
&   [M:SIH4]SRENUM(NOL)<>"" | [M:SIH4]SGHNUM(NOL)<>"")|
&  ([M:SIH0]INVTYP=2 & [M:SIH1]SIHORI<>1) |
&   [M:SIH4]QTY(NOL)=0
   Raz GBOUT1
Endif

# Pas de visu calcul tarif et détail valorisation si qté à 0 (avoir en valeur)
If  [M:SIH4]QTY(NOL)=0 Raz GBOUT2, GBOUT12 Endif

# ----- #
# Avoir #
# ----- #
If [M:SIH0]INVTYP=2
#   Pas de bouton stock si ss mvt de stock ou si ligne d'avoir sur retour
#    If [M:SIH1]STOMVTFLG=1 | [M:SIH4]STOMGTCOD(NOL)=1 | (([M:SIH1]SIHORI=4 & [M:SIH4]XSIHORINUM(NOL)<>"") | [M:SIH1]SIHORI=6)
    If [M:SIH1]STOMVTFLG=1 | [M:SIH4]STOMGTCOD(NOL)=1 | [M:SIH4]RTNSTOUPD(NOL)=1 | ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)<>"")
        Raz GBOUT5, GBOUT6, GBOUT7, GBOUT8
    Else
        If [F:SLT]STRNUM<>GFLAG Read [SLT]SLT0=5;GFLAG
                                If fstat Raz [F:SLT] Endif
                                Endif
        Call STKINIBTN( 5, 8, 6, 7, "SIH4", "SLT", [M]ITMREF(NOL), [M:SIH4]DSTOFCY(NOL) ) From STKENT
    Endif
Endif

# Pas de saisie sortie, si :
#    ce n'est pas une facture          ou
#    article non géré en stock         ou
#    facture directe non géré en stock ou
#    facture d'une ligne de livraison  ou
#    facture de transfert              ou
#    facture de dde de service, contrat de service
#    facture d'échéance            : # 107888 : Scheduled invoices : (LD:10/05/16)
If [M:SIH0]INVTYP<>1 | [M:SIH4]STOMGTCOD(NOL)=1 |
&  ([M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG<>2) |
&  ([M:SIH1]SIHORI=3 & [M:SIH4]SDHNUM(NOL)<>"") |
&  ([M:SIH1]SIHORI=9 & [M:SIH4]SGHNUM(NOL)<>"") |
&  find([M:SIH1]SIHORI, 7,8,10)    : # 107888 : Scheduled invoices : (LD:10/05/16)
#&  find([M:SIH1]SIHORI, 7,8)      : # 107888 : Scheduled invoices : (LD:10/05/16)
   Raz GBOUT3
Endif
# Pas de modif des sortie, si :
#    ce n'est pas une facture          ou
#    facture non validée
If [M:SIH0]INVTYP<>1 | [M:SIH1]INVSTA<>3 Raz GBOUT4 Endif

# Pas de période de prestation si paramètre LOCITAPRE non actif ou proforma
If !GLOCITAPRE | [M]INVTYP=5 Raz GBOUT10 Endif

# Pas de détail valorisation ligne si avoir
If [M:SIH0]INVTYP=2 Raz GBOUT12 Endif

# Déf. bouton stock site
If [M]STOMVTFLG=1 | [M]STOMGTCOD(NOL)=1 | [M]RTNSTOUPD(NOL)=1 Raz GBOUT13 Endif

## Suppression des lignes livraisons uniquement ssi facture de livraison et s'il y a plus d'une ligne pour cette livraison
#If [M]SIHORI<>3 | [M]SDHNUM(NOL)="" | (!find ([M]SDHNUM(NOL),[M]SDHNUM(0..NOL-1)) & !find([M]SDHNUM(NOL),[M]SDHNUM(NOL+1..[M]NBLIG-1)))
# Suppression des lignes livraisons uniquement ssi facture de livraison
If [M]SIHORI<>3 | [M]SDHNUM(NOL)=""
    Raz GBOUT16
Endif

Call IB_PRDINF([M:SIH4]ITMREF(NOL),17) From PRDINFLIB  # DF 79831

Gosub IB_NBLIG From LIBSAL_INVCND_SIH # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) SIHORI=10 Schedule invoice

End

#---------------------------------------
Subprog B1_NBLIG
#----------------------------------------#
# Bouton Recalcul tarif                  #
#----------------------------------------#
Local Integer NOL, TYPRECH
If nolign > [M]NBLIG End : Endif
#   --> Ctrl autorisation modification
If !find (GREP, "C", "D")
    GBIDC2="M": GFCY=[M]SALFCY : Gosub AUTORIS_OPT From CONTX3
    If !GBIDI2  GZNUM=0:GERR = 1:GMESSAGE = mess(2,104,1): End : Endif
Endif
NOL=nolign-1
If [M]FOCFLG(NOL) <> 3
    Call LECT_FIC(NOL) From SUBSIHB
    Call SUB_TOT(NOL)  From SUBSIHB
    If find([M]LINTYP(NOL),1,2,6,10)
        TYPRECH = 1
    Else
        Local Integer ORI : ORI=NOL
        While !find([M]LINTYP(ORI),2,6,10) & ORI >= 0 ORI-=1 Wend
        If find([M]LINTYP(ORI),2,6,10) GPNTITMREF=[M]ITMREF(ORI) Endif
        TYPRECH = 4
    Endif
    Call ALICLCAMT([M]ITMREF(NOL), [M]QTY(NOL), NOL, "SIH4", [M]CLCAMT1(NOL), [M]CLCAMT2(NOL)) From TRTX3
    Call RECH_TARIF(TYPRECH,[M]ITMREF(NOL),NOL,[M]QTY(NOL),"SIH",[M]GROPRI(NOL)) From TRTVENTAR
    Call CLCNETPRI([M]QTY(NOL),[M]CUR,NOL) From TRTVENPRI
    Call CLCPFM([M]DSTOFCY(NOL), [M]PRITYP,[M]CHGTYP, [M]INVDAT, [M]CUR, NOL,1) From TRTVENPRI
    Call APRES_LIGNE (NOL,1) From SUBSIHB
    [M]UPDFLG(NOL) = 1
    [M:SIH0]INVCLCFLG=2  : # on doit faire le calcul de la facture
    Affzo [M]1-99
    mkstat = 4
Endif

Gosub B1_NBLIG From LIBSAL_INVCND_SIH # Issue 107888 US140 - 2016-03-25 by CPO : Scheduled invoices object management

nolign=NOL+1
End
#---------------------------------------
########################################
#-----------------------------------------------#
# fenêtre détail en modification                #
#-----------------------------------------------#
$AB8_NBLIG

#-- Habilitation Modification mvts stock si on trouve K dans la chaine des boutons autorisés
# hcb 27842
Local Integer NOL : NOL = nolign-1
Raz GBIDI2
GFCY=[M:SIH4]DSTOFCY(NOL)
GBIDC2="K" : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GMESSAGE=mess(2,104,1)
   GOUVENT=0
   Return
Endif


If [M:SIH0]NUM<>""
  SYMBOLE2="SIV"+[M:SIH0]NUM
  Lock=SYMBOLE2
  If fstat
    GMESSAGE=[M:SIH0]NUM-mess(10,100,1)
    Call ERREUR(GMESSAGE) From GESECRAN
    GOUVENT=0
    Return
  Endif
Endif
GOUVENT=2
Return
########################################
$BB8_NBLIG
If [M:SIH0]NUM<>""
  SYMBOLE2="SIV"+[M:SIH0]NUM
  Unlock=SYMBOLE2
Endif
If GRELITSIH=1
    mkstat=4
Endif
Return
# ---
########################################
$AB11_NBLIG
#----------------------------------------#
# Action avant bouton tunnel             #
#----------------------------------------#
Local Char    WOBJCLEC, WOBJETC
Local Integer NOL : NOL = nolign-1

If [M]SRHNUM(NOL) <> ""
   WOBJCLEC= [M]SRHNUM(NOL)
   WOBJETC = "SRH"
Elsif [M]SDHNUM(NOL) <> ""
   WOBJCLEC= [M]SDHNUM(NOL)
   WOBJETC = "SDH"
Elsif [M]SOHNUM(NOL) <> ""
   WOBJCLEC= [M]SOHNUM(NOL)
   WOBJETC = "SOH"
   Gosub AB11_NBLIG From LIBSAL_INVCND_SIH # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) SIHORI=10 Schedule invoice
Elsif [M]SQHNUM(NOL) <> ""
   WOBJCLEC= [M]SQHNUM(NOL)
   WOBJETC = "SQH"
Endif
Return
########################################
# Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) SIHORI=10 Schedule invoice
$BB11_NBLIG

  If [M:SIH1]SIHORI=10 : Gosub BB11_NBLIG From LIBSAL_INVCND_SIH : Endif

Return
########################################
# Dde 62603 : Suppression des lignes d'un BL sur une facture
#------------------------------------------------------------
Subprog B16_NBLIG
Local Integer SAVSTAT, SAVNOL

# Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) SIHORI=10 Schedule invoice
If [M:SIH1]SIHORI=10 and [M:SIH4]SIDORI(nolign-1)=10 and [M:SIH4]VCRINVCNDLIN(nolign-1)>0
  Gosub B16_NBLIG From LIBSAL_INVCND_SIH
  End
Else
# End issue 107888
  # --> pour supprimer cette ligne, il faut la désélectionner de la liste 'sélection commandes'
  If [M:SIH4]CREFLG(nolign-1)=0
     GMESSAGE=mess(223,192,1) : GERR=1  : End
  Endif


  SAVSTAT= status
  SAVNOL = nolign

  Gosub SUPLIV

  status = SAVSTAT
  nolign = SAVNOL
  mkstat = 4
Endif

End
#------------------------------------------------------------#
# Suppression des lignes d'une livraison                     #
#------------------------------------------------------------#
$SUPLIV
Local Integer WRET
Local Integer NOL                 : NOL=nolign-1
Local Char    WSDHNUM(GLONVCR)    : WSDHNUM=[M]SDHNUM(NOL)

# Recherche de la 1ère ligne de la livraison
WI=find (WSDHNUM, [M:SIH4]SDHNUM(0..[M:SIH4]NBLIG-1))
If WI
    # Suppresion de toutes les lignes de livraison
    While [M]SDHNUM(WI-1)=WSDHNUM & WI <= [M]NBLIG
        Call SUP_LIG(WI-1, WRET) From SUBSIHB
        #   Si pas de suppression de la ligne, il faut lire la suivante
        If WRET = 1 WI +=1 : Endif
    Wend
Endif

[M:SIH0]INVCLCFLG=2  : # on doit faire le calcul de la facture
Affzo [M:SIH4]1-99


Return
# Dde 62603

#---------------------------------------
Subprog C_NBLIG
Local Integer NOL, WRET

# Valeurs de GMODIF :
#    0 = Modification ligne
#    1 = Suppression ligne
#    2 = Nouvelle ligne
#    3 = Suppression des composants kit          (suite à GMODIF=1)
#    4 = Suppression des composants nomenclature (suite à GMODIF=1)
#    6 = Modification d'une facture validée

NOL=nolign-1
If [M:SIH1]INVSTA <> 3
   If [M:SIH4]NBLIG <> 0
      Diszo [M:SIH0]SIVTYP, SALFCY, BPCINV
      Diszo [M:SIH1]BPRPAY, BPCGRU, PRITYP, BPCORD  : # suppression Diszo de VACBPR (bug 13356)
      Diszo [M:SIH2]CUR, CURTYP
      # Si STOFCY="" il faut rendre le flag mvt de stock inaccessible : il doit rester à non
      # Sinon il faut renseigner STOFCY non modifiable s'il y a des lignes
      # Et cela obligerait à ctrler ts les article-site et à reporter STOFCY sur ttes les lignes
      If [M:SIH1]STOFCY="" Diszo [M:SIH1]STOMVTFLG Endif
   Else
      #Gbn-102366
      If find (GREP, "C", "D")
          Actzo [M:SIH0]SIVTYP, SALFCY
      Endif
      Actzo [M:SIH0]BPCINV
      #Gbn-102366-Fin
      Actzo [M:SIH1]BPRPAY, BPCGRU, VACBPR, BPCORD
      If GNOTATI=2 Actzo [M:SIH1]PRITYP Endif
      If GUPDCUR=2 Actzo [M:SIH2]CUR Endif
      If [M:SIH2]CUR <> GLOCALDEV Actzo [M:SIH2]CURTYP Endif
   Endif
Endif

GMODIF=2
# --> Contrôle d'insertion de lignes
If status = 73 | status = 82
   Gosub TEST_INS From SUBSIHB
Endif
# --> Contrôle de modification de lignes
If status = 75
   GMODIF = 0
   If [M:SIH1]INVSTA=3  GMODIF=6 : Endif
   Gosub TEST_MOD From SUBSIHB
   If mkstat End Endif
Endif


# --> Contrôle de suppression de lignes
If status = 65
   GMODIF = 1
   Gosub TEST_ANU From SUBSIHB
   If mkstat End Endif
   If   !GIMPORT & [M:SIH0]INVTYP=1 & [M:SIH4]STOMGTCOD(NOL)<>1 &
&     (([M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG=2)     | [M:SIH1]SIHORI=2 |
&      ([M:SIH1]SIHORI=3 & [M:SIH4]SDHNUM(NOL)=""))
      Call DELSTOSORW(NOL,NOL,"SIH4",[M:SIH4]DSTOFCY(NOL),WRET) From STKSOR
      If WRET<>0 mkstat=2 : End Endif
   Endif
   # ----- #
   # Avoir #
   # ----- #
   # --> Ligne gérée en stock : Suppression ssi la ligne n'a pas encore été crée
   If   [M:SIH0]INVTYP=2 & [M:SIH4]STOMGTCOD(NOL)<>1 & [M:SIH4]RTNSTOUPD(NOL)=2 & [M:SIH1]STOMVTFLG=2 &
&       (find([M:SIH1]SIHORI, 1,4) | ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)=""))
       If [M:SIH4]CREFLG(NOL)=0
           If !GIMPORT Call DELSTOENTW (NOL,NOL,"SIH4",1,1,[M:SIH4]DSTOFCY(NOL),1,"") From STKENT : Endif
       Else
           # La suppression d'une ligne validée doit se faire via la fenêtre de modification
           GMESSAGE = mess (6,184,1) : mkstat = 2 : End
       Endif
   Endif
Endif
If status = 68 | status = 83
   GMODIF = 1
   For NOL=nolign-1 To nolign1-1
      Gosub TEST_ANU From SUBSIHB
      If mkstat:Break:Endif
      # ----- #
      # Avoir #
      # ----- #
      # --> Ligne gérée en stock
      If   [M:SIH0]INVTYP=2 & [M:SIH4]STOMGTCOD(NOL)<>1 & [M:SIH4]RTNSTOUPD(NOL)=2 & [M:SIH1]STOMVTFLG=2 &
&         (find([M:SIH1]SIHORI, 1,4) | ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)=""))
          If [M:SIH4]CREFLG(NOL)<>0
              # La suppression d'une ligne validée doit se faire via la fenêtre de modification
              GMESSAGE = mess (6,184,1) : mkstat = 2 : Break
          Endif
      Endif
      # ------- #
      # Facture #
      # ------- #
      If   [M:SIH0]INVTYP=1 & [M:SIH4]STOMGTCOD(NOL)<>1 &
&         (([M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG=2)     | [M:SIH1]SIHORI=2 |
&          ([M:SIH1]SIHORI=3 & [M:SIH4]SDHNUM(NOL)=""))
          Call DELSTOSORW(NOL,NOL,"SIH4",[M:SIH4]DSTOFCY(NOL),WRET) From STKSOR
          If WRET<>0 mkstat=2 : Break Endif
      Endif
   Next NOL
   If mkstat End Endif
   # ----- #
   # Avoir #
   # ----- #
   # --> Ligne gérée en stock : Suppression ssi la ligne n'a pas encore été crée
   If   [M:SIH0]INVTYP=2 & [M:SIH4]STOMGTCOD(NOL)<>1 & [M:SIH4]RTNSTOUPD(NOL)=2 & [M:SIH1]STOMVTFLG=2 &
&       (find([M:SIH1]SIHORI, 1,4) | ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)=""))
       If [M:SIH4]CREFLG(NOL)=0
           If !GIMPORT Call DELSTOENTW (nolign-1,nolign1-1,"SIH4",1,1,[M:SIH4]DSTOFCY(NOL),1,"") From STKENT : Endif
       Endif
   Endif
Endif

# BRBAN 105200#US2
If func AFNC.ACTIV("INVCA")>0
  If func TRTINVCAN.INVCAN([F:FCY]LEG,[F:TSV]INVTYP)>0 & [F:TSV]INVCAN=2
    If find(status,65,68,83,73,82,67)
      mkstat = 2 : End
    Endif
  Endif
Endif

End

#---------------------------------------
Subprog AVANT_NBLIG
Local Integer NOL : NOL=nolign-1
Local Integer WRETOUR
Local Char    WNUMTEX(12)

# Si facture directe avec maj stock
# ou facture de commande
# ou facture de livraison mais ligne sans no liv
# et article géré en stock
# --> Lecture article et règle de gestion
If [M:SIH4]ITMREF(NOL)<>""
   If   [M:SIH0]INVTYP=1 & [M:SIH4]STOMGTCOD(NOL)<>1 &
&     (([M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG=2)      | [M:SIH1]SIHORI=2 |
&      ([M:SIH1]SIHORI=3 & [M:SIH4]SDHNUM(NOL)=""))
      Call INIZONSOR("SIH4",[M:SIH4]ITMREF(NOL),[M:SIH4]DSTOFCY(NOL),NOL,4,[M:SIH0]TRSCOD,"")
&                    From STKECR
   Endif
Endif

# ----- #
# Avoir #
# ----- #
If [M:SIH0]INVTYP=2
    If status=75
        Call SIHINIZONENT
    Else
        If [M:SIH4]STOMGTCOD(NOL)<>1 & [M:SIH1]STOMVTFLG=2 & [M:SIH4]RTNSTOUPD(NOL)=2 &
&          (find([M:SIH1]SIHORI, 1,4) | ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)=""))
            # Si avoir direct ou avoir sur facture avec mvt de stock et article géré en stock
            # --> Lecture article et règle de gestion
            Call LECFICENT([M:SIH4]DSTOFCY(NOL),[M:SIH1]BPCORD,"",nolign-1,12,[M:SIH0]TRSCOD,0) From STKECR
        Endif
        If find(status,73, 82) :     # Insertion de ligne
            Actzo [M:SIH4]ITMREF(NOL)
        Endif
    Endif
Endif

If GMODIF = 2
# --> Création d'une ligne : Alimentation des zones à partir des zones d'entete
    Call INIT_SIH(NOL, 1) From SUBSIHB
Else
# --> Lecture des fichiers en ligne
    Call LECT_FIC(NOL)    From SUBSIHB
Endif
If GMODIF = 1
# --> Suppression
    If find([M]LINTYP(NOL),2,10) GMODIF=3 : Endif
    If find([M]LINTYP(NOL),6) GMODIF=4 : Endif
    GFOCFLG = [M]FOCFLG(NOL)
Endif

Call SUB_TOT(NOL) From SUBSIHB

Gosub AVANT_NBLIG From LIBSAL_INVCND_SIH # Issue 107888 US140 - 2016-03-25 by CPO : Scheduled invoices object management

#--CPO 79343
If GMODIF=1 and GREP<>"C" and GSIHSUPPLIGDSP <> 999999
  Local Integer WTEMPDSP : Raz WTEMPDSP
  Call CTLSUPP_EXISTDSP("SIH",NOL,WTEMPDSP) From TRTVENDIV
  If WTEMPDSP=1
    If [M:SIH4]CREFLG(NOL)<>0
      GSIHSUPPLIGDSP = 999999 :#--CPO La suppression d'une ligne non pickée est définitive si on enregistre...
    Endif
  Endif
Endif
#--/CPO

End
#---------------------------------------
Subprog APRES_NBLIG
Local Integer  NOL, ORI
Local Integer  NL
Local Integer  OK, RET
Local Integer  FUNCTION
Local Integer  SAVNOL, SAVSTAT
If GIMPORT
  Gosub AAPRES_NBLIG : # Si import il faut appeler le début de l'action SAISTOSOR !
Endif

NOL=nolign-1
ORI=nolign-1
NL=nolign
OK=1
FUNCTION = 4

SAVSTAT=status
SAVNOL=nolign

# Bug 82658 : Recherche tarif si changement de référence article
# Globale utilisée pour flagger les erreurs suite à la recherche tarif
If dim(GERRITMREF)>0 Kill GERRITMREF Endif

# Si abandon : uniquement réhabilitation des totaux
If adxgtb=1 | find(status,6,7)
   Call ADD_TOT(NOL) From SUBSIHB
   Gosub APRES_NBLIG_ABA From LIBSAL_INVCND_SIH # Issue 107888 US140 - 2016-03-25 by CPO : Scheduled invoices object management
   End
Endif

# S'il n'y a plus de ligne, raz de l'origine
If [M:SIH4]NBLIG=0
   [M:SIH1]SIHORI=1
   Raz [M:SIH1]SIHORINUM
   Raz [M:SIH1]SIHORIDAT
   # 107888 : Scheduled invoices : (LD:10/05/16)
   Raz [M:SIH1]SIHORITYP
   # 107888 : Scheduled invoices : (LD:10/05/16)
Endif

# Positionnement flag calcul a effectuer
[M:SIH0]INVCLCFLG=2

# Bug 84030
#--------------------------------------------------------------------------------------#
# Suppression d'une ligne de gratuit : Modification de la ligne à l'origine du gratuit #
#--------------------------------------------------------------------------------------#
If GMODIF = 1 & GFOCFLG = 3
  Call RAZORIGRA(NOL) From TRTVENBOM
Endif
#--------------------------------------------------------------------------------------#
# Insertion d'une ligne : Maj des lignes de gratuit qui suivent la ligne insérée       #
# Maj du n° de ligne à l'origine du gratuit car les lignes ont été renumérotées        #
#--------------------------------------------------------------------------------------#
If GMODIF=2 & NOL<[M]NBLIG-2
  Call MAJORIGRA(NOL,"SIDLIN") From TRTVENBOM
Endif
# Bug 84030

#---------------------------------------------#
# Suppression du gratuit lié à la ligne       #
#---------------------------------------------#
If find(status,65,68,83) & GFOCFLG=2
   Call SUPGRA(NOL, FUNCTION, RET) From TRTVENBOM
   Affzo [M:SIH4]5
Endif
status = SAVSTAT
nolign = SAVNOL

#---------------------------------------------#
# Suppression de la nomenclature de l'article #
#---------------------------------------------#
OK=1
#If GMODIF=4 & (([M:SIH4]LINTYP(NOL) = 6  & find([M:SIH4]LINTYP(NL), 7,8,9)))    : # Bug 71161
If GMODIF=4 & find([M:SIH4]LINTYP(NL), 7,8,9)                                    : # Bug 71161
   If !GIMPORT Call OUINON(mess(13,191,1),OK) From GESECRAN : Endif
   If OK<>2
      Gosub MODNOM From TRTVENBOM
      GMODIF = 2
      Affzo [M:SIH4]1-99
      status = SAVSTAT
      nolign = SAVNOL
      End
   Endif
Endif
If GMODIF=3 | OK=2
   Gosub SUPNOM From TRTVENBOM
   GMODIF = 1
   Affzo [M:SIH4]1-99
   status = SAVSTAT
   nolign = SAVNOL
   End
Endif

# Si suppression une ligne : uniquement affichage des totaux
If find(status,65,68,83)

   # 101874 : V9 : Taxe code control
   # Valuation can now be done for each ligne depending on SIHVALLIG parameter
   If GSIHVALLIG=2 & (!GIMPORT & !(dim(GWEBSERV)=1 & GWEBSERV=1))
       If [M:SIH1]INVSTA<>3
         If [M:SIH0]INVCLCFLG<>1
           If [M:SIH4]NBLIG<>0
               Gosub CHARG_TABLEAUX From TRTVENFACC
               Gosub CAL_FACTURE From SUBSIHC
               [M:SIH0]INVCLCFLG=1
               [M:SIH4]INVNOT = [M:SIHV]INVNOT
               [M:SIH4]INVATI = [M:SIHV]INVATI
               Affzo [M:SIHV]1-99
               Affzo [M:SIH4]15
           Endif
         Endif
       Endif
   Endif
   # 101874

   Affzo [M]INVNOT, INVATI, PFMTOT
   status = SAVSTAT
   nolign = SAVNOL
   End
Endif

GNETMAR = 1
# 95345 : Changement taux de tva en modification facture
# Vérif. codes taxes (impliquant une modif éventuelle des codes taxes) à faire ssi ligne directe
# Les lignes issues d'un doc d'origine doivent doivent conserver les codes taxes d'origine
#Call VERIF_VATCOD (NOL) From SUBSIHB
If sum([M]SQHNUM(NOL),[M]SOHNUM(NOL),[M]SDHNUM(NOL),[M]CONNUM(NOL),[M]SRENUM(NOL),[M]SGHNUM(NOL),[M]XSIHORINUM(NOL),[M]SRHNUM(NOL))= ""
    Call VERIF_VATCOD (NOL) From SUBSIHB
Endif
# 95345

Call APRES_LIGNE (NOL, 1) From SUBSIHB

Gosub APRES_NBLIG From LIBSAL_INVCND_SIH # Issue 107888 US140 - 2016-03-25 by CPO : Scheduled invoices object management

#------------------------------#
# Traitement des nomenclatures #
#------------------------------#
# --> Modification
If find(GMODIF, 0,6) : # Si modification d'une facture non validée ou d'une facture validée
    OK=1
    If !GIMPORT & (([M:SIH4]LINTYP(NOL) = 6  & find([M:SIH4]LINTYP(NL), 7,8,9)))
        Call OUINON(mess(14,191,1),OK) From GESECRAN
        # MSG=Repercussion sur les composants ?
    Endif
    If find([M:SIH4]LINTYP(NOL),2,10) | OK = 2
        Gosub MODNOM From TRTVENBOM
        SAVNOL=nolign
        Affzo [M:SIH4]
        nolign=SAVNOL
        Raz GTARFLG : # Bug 62571
    Endif
    # Sauvegarde nouvelle quantité pour calcul qté nomenclature
    [M]CQTY(NOL) = [M]QTY(NOL)
    End
Endif

# 101874 : V9 : Taxe code control
# Valuation can now be done for each ligne depending on SIHVALLIG parameter
If GSIHVALLIG=2 & (!GIMPORT & !(dim(GWEBSERV)=1 & GWEBSERV=1))
    If [M:SIH1]INVSTA<>3
      If [M:SIH0]INVCLCFLG<>1
          Gosub CHARG_TABLEAUX From TRTVENFACC
          Gosub CAL_FACTURE From SUBSIHC
          [M:SIH0]INVCLCFLG=1
          [M:SIH4]INVNOT = [M:SIHV]INVNOT
          [M:SIH4]INVATI = [M:SIHV]INVATI
          Affzo [M:SIHV]1-99
          Affzo [M:SIH4]15
      Endif
    Endif
Endif
# 101874

End
#########################################################################
# Etiquette exécutée avant l'action SAISTOSOR ou l'action SAISTOENT
#########################################################################
$AB4_NBLIG
#-- Habilitation Modification mvts stock si on trouve K dans la chaine des boutons autorisés
# hcb 27842
Local Integer  NOL
NOL = nolign-1
Raz GBIDI2
GFCY=[M:SIH4]DSTOFCY(NOL)
GBIDC2="K" : Gosub AUTORIS_OPT From CONTX3
If !GBIDI2  GMESSAGE=mess(2,104,1)
   GOUVSOR=0
   Return
Else
   GOUVSOR = 1
Endif
Return


$AAPRES_NBLIG

# Issue X3-58977
# Exceeding the max lenght for compilation : moved to SUBSIH1
Gosub AAPRES_NBLIG From SUBSIH1
# End issue X3-58977

