If dim([M:SIH4]ECCVALMAJ) >= 0 Then
  [M:ALP]ECCVALMAJ    = [M:SIH4]ECCVALMAJ(NOL)
Endif
# FGR 21/04/2015 : X3SUIVI105605 (fin)
# --------------------------------------
[M:ALP]PCU        = [M:SIH4]SAU(NOL)
[M:ALP]PCUSTUCOE  = [M:SIH4]SAUSTUCOE(NOL)
[M:ALP]QTY        = [M:SIH4]QTYSTU(NOL)
[M:ALP]TYPQTY     = 1
[M:ALP]BESDAT     = [M:SIH0]INVDAT
[M:ALP]DLVDAT     = [M:SIH0]INVDAT
Raz [M:ALP]ALLDAT
Raz [M:ALP]STOLOC
[M:ALP]PECINTLOC  = 2
[M:ALP]PECSCOLOC  = 1
[M:ALP]PECPLFLOC  = 2
[M:ALP]PECCUNLOK  = 1
Raz [M:ALP]FILSTO
#--- Bug 90028
Raz [M:ALP]ALLQTY

[M:ALP]LOT        = [M:SIH4]LOTFIL(NOL)
[M:ALP]LOC        = [M:SIH4]LOCFIL(NOL)
[M:ALP]STA        = [M:SIH4]STAFIL(NOL)
[M:ALP]VCRNUM     = [M:SIH0]NUM
[M:ALP]VCRLIN     = [M:SIH4]SIDLIN(NOL)
