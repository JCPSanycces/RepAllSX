######################################################################################
Subprog C_AMTLIN(VALEUR)
Variable Decimal VALEUR
# Si avoir : Le montant ligne est saisissable ssi la qté est à 0, dans ce cas, il faut renseigner un montant
If [M:SIH0]INVTYP=2 & [M:SIH4]QTY(nolign-1)=0 & VALEUR=0 mkstat=2 Endif
End
# --------------------------------------- VACITM1 --------------------------------
Subprog C_VACITM1(VALEUR)
Variable Char    VALEUR()
#--CPO 71937 Lors de l'import, [M]VACITM1(nolign-1)=VALEUR, mais il faut quand même faire une recherche de taxe
#--car le niveau peut venir du fichier d'import
#If [M]VACITM1(nolign-1)=VALEUR
If [M]VACITM1(nolign-1)=VALEUR and !GIMPORT
#--/
    Call CTLVAT([M]VAT1(nolign-1)) From TRTVENCTL
Else
    Local Char LOLDVAT : LOLDVAT=[M:SIH4]VAT1(nolign-1) #gbn-83192
    Raz [M:SIH4]VAT1(nolign-1)        : # Bug 78972
    Call ALIVAT(VALEUR,11,1,[M:SIH1]BPCORD,[M:SIH4]ITMREF(nolign-1),"SIH4",nolign-1,[M:SIH4]VAT1(nolign-1)) From TRTX3
    #Gbn-83192
    If LOLDVAT<>[M:SIH4]VAT1(nolign-1)
     [M:SIH4]INIACCFLG(nolign-1)=2
    Endif
Endif
End
######################################################################################
## Etiquette ajoutée par le superviseur (écran SIH4) 06/10/2008 15:34:13 (LD)
######################################################################################
Subprog AM_AMTLIN(VALEUR)
Variable Decimal VALEUR
Local Integer NOL : NOL=nolign-1
# Si saisie d'un montant ligne, il s'agit d'un avoir en valeur :
# --> Concernant les stocks : Pas de mise à jour
# --> Concernant les tarifs : Calcul de la marge et c'est tout
# -------------------------------- #
# Traitement concernant les stocks #
# -------------------------------- #
If [M]RTNSTOUPD(NOL)=2
    #   Avoir en valeur : Pas de mise à jour des stock
    Call DELSTOENTW (NOL,NOL,"SIH4",1,1,[M:SIH4]DSTOFCY(NOL),1,"") From STKENT
    Raz [M]GESLOT(NOL), [M]WSTOSEQ(NOL), [M]WSTOFLG(NOL), [M]WSRUFLG(NOL)
    Call STKRAZGRILIG("SIH4", NOL) From TRTVENSTK
    [M]WSTOFLG(NOL)=2   : # Article non géré en stock
    [M]RTNSTOUPD(NOL)=1 : # Pas de maj des stocks
Endif
If dim([M:SIH4]EECFLOPHY)>0 [M]EECFLOPHY(NOL)=1 : Diszo [M]EECFLOPHY(NOL) Endif
# -------------------------------- #
# Traitement concernant les tarifs #
# -------------------------------- #
[M]AMTLIN(NOL)=VALEUR
Call CLCPFM([M]DSTOFCY(NOL), [M]PRITYP, [M]CHGTYP, [M:SIH0]INVDAT, [M:SIH2]CUR, NOL, 2) From TRTVENPRI
If GDACLOK = 1
    Call CTLPFM([M:SIH2]CUR,[M:SIH4]CPRPRI(NOL), NOL) From TRTVENPRI
    If mkstat=2 End Endif
Endif

End
