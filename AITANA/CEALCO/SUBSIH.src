######################################################################################
Subprog AS_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

  # FGR 01/04/2015 : X3SUIVI105605
  Gosub ECCVALMAJMIN_ENABLE
End

######################################################################################
Subprog C_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Integer LRET
Local Integer NOL

  # FGR 10/04/2015 : X3SUIVI105605 : Seulement pour les factures.
  If [M:SIH0]INVTYP = 1 Then
    NOL = nolign-1
    Call CTLECCVAL(VALEUR, [M:SIH4]DSTOFCY(NOL), [M:SIH4]ITMREF(NOL), 4, "", [M:SIH0]INVDAT, LRET) From STKSOR
    If LRET >= 1 Then
      # A partir des livraisons, tous les messages sont bloquants
      mkstat = 2
    Endif
  Endif
End

######################################################################################
Subprog AM_ECCVALMAJ(VALEUR)
Variable Char    VALEUR()

Local Char WECCVALMAJ(GLONECS)
Local Char WECCVALMIN(GLONICVVAL)
Local Char PITM(GLONITM)

  # FGR 10/04/2015 : X3SUIVI105605
  Raz WECCVALMAJ
  Raz WECCVALMIN
  Raz PITM
  # si version majeure trouvée et si article gere la version mineure : recherche derniere version mineure
  If [F:ITM]ITMREF <> [M:SIH4]ITMREF(nolign-1) Then
    Read [ITM]ITM0=[M:SIH4]ITMREF(nolign-1)
  Endif
  If VALEUR  <> "" and [F:ITM]ECCSTO = 3 Then
    WECCVALMAJ = VALEUR
    PITM = [F:ITM]ITMREF
    Gosub READECCMIN From STKACT
    [M:SIH4]ECCVALMIN(nolign-1) = WECCVALMIN
    Affzo [M:SIH4]ECCVALMIN(nolign-1)
  Elsif VALEUR = "" and [M:SIH4]ECCVALMIN(nolign-1) <> "" Then
    Raz [M:SIH4]ECCVALMIN(nolign-1)
    Affzo [M:SIH4]ECCVALMIN(nolign-1)
  Endif
End

######################################################################################
Subprog AS_ECCVALMIN(VALEUR)
Variable Char    VALEUR()

  # FGR 01/04/2015 : X3SUIVI105605
  Gosub ECCVALMAJMIN_ENABLE
End

######################################################################################
$ECCVALMAJMIN_ENABLE
  # FGR 01/04/2015 : X3SUIVI105605
  If [M:SIH0]INVTYP <> 1 Then
    mkstat = 2
  Endif
  If [M:SIH1]STOMVTFLG <> 2 Then
    mkstat = 2
  Endif
  If (dim([M:SIH4]SRENUM) >= 0  and [M:SIH4]SRENUM(nolign-1) <> "") or [M:SIH4]SDHNUM(nolign-1) <> "" or [M:SIH4]SOHNUM(nolign-1) <> "" or [M:SIH4]CREFLG(nolign-1) <> 0 Then
    mkstat = 2
  Endif
  If find([M:SIH4]LINTYP(nolign-1),3,4,5,11,12,13) Then
    mkstat = 2
  Endif
Return

######################################################################################
Subprog C_DSTOFCY(VALEUR)
Variable Char    VALEUR()

Local Integer LRET
Local Integer NOL

  # FGR 10/04/2015 : X3SUIVI105605 : Seulement pour les factures.
  If dim([M:SIH4]ECCVALMAJ) >= 0 Then
    If [M:SIH0]INVTYP = 1 Then
      NOL = nolign-1
      Call CTLECCVAL([M:SIH4]ECCVALMAJ(NOL), VALEUR, [M:SIH4]ITMREF(NOL), 4, "", [M:SIH0]INVDAT, LRET) From STKSOR
      If LRET > 1 Then
        mkstat = 2
      Endif
    Endif
  Endif
End

# SAM 88426 - 2015-06-22 by LUCUE
Subprog C_BPRFCT(VALEUR)
Variable Char    VALEUR()
If VALEUR="": End: Endif
If !clalev([FCT]): Local File FACTOR [FCT]: Endif
Raz [F:FCT]
Call LECTURE("FCT",VALEUR,"") From CONTOBJ
If [F:FCT]FCTTYP>1
  Call LEC_FCY([M:SIH0]SALFCY) From CPTLEC
  If [F:FCY]LEGCPY<>[F:FCT]BANCPY or ([F:FCT]BANFCY<>"" and [F:FCY]FINRSPFCY<>[F:FCT]BANFCY)
       # 107888 : Scheduled invoices : X3-6337 (LD:28/10/16)
       #GMESSAGE=mess(204,121,1): mkstat=2 #Incompatibility between the company/site of the factor and the company/site of the invoice
       GMESSAGE=VALEUR-":"-mess(204,121,1): mkstat=2 #Incompatibility between the company/site of the factor and the company/site of the invoice
       # 107888 : Scheduled invoices : X3-6337 (LD:28/10/16)
  Endif
Endif

End
# End SAM 88426
