##################################################
# Action SIHP2NBLIG : création gratuit           #
##################################################
$P2_NBLIG
Local Integer  ORI        : ORI=nolign-1
Local Integer  NL         : NL=nolign
Local Integer  FUNCTION   : FUNCTION=4
Local Integer  RET

If adxgtb=1 | find(status,6,7) Return Endif

#------------------------------------------------#
# Création d'une ligne                           #
# --> Génération des gratuits (sf si avoir)      #
#------------------------------------------------#

If [M]INVTYP = 2 Raz GFOCITMREF Endif
If GMODIF = 2 & GFOCITMREF <> ""
    If !GIMPORT | (GIMPORT & ((dim(G_FOCFLG)>0 & G_FOCFLG=0) | (dim(G_FOCFLG)<=0)))       : # Bug 72575
        # Recherche de l'article origine si on est positionné sur un composant
        If !find([M]LINTYP(ORI),1,2,6,10)
            While !find([M]LINTYP(ORI),1,2,6,10) & ORI >= 0
                ORI-=1
            Wend
        Endif
        If !GIMPORT & ORI = [M]NBLIG [M]NBLIG +=1 : Endif                                 : # Bug 72575
        Call CREGRA("G",1, ORI, [M:SIH0]INVDAT, FUNCTION, NL, RET) From TRTVENBOM
        If !GIMPORT & ORI = NL-1 & ORI = [M]NBLIG - 1 :[M]NBLIG-=1:Endif                  : # Bug 72575
        If GIMPORT VALEUR=[M]NBLIG Endif                                                  : # Bug 72575
        Affzo [M:SIH4]5
    Endif                                                                                 : # Bug 72575
Endif
Return

#---------------------------------------
Subprog AP_NBLIG
#-----------------------------------------------#
# Si l'on sort du tableau, calcul de la facture #
#-----------------------------------------------#
Local Integer OK
If status>=65 & status<=90 End Endif
If find(status,7,27,28) | status >= 1792 End Endif
If [M:SIH1]INVSTA=3    End Endif
If [M:SIH0]INVCLCFLG=1 End Endif
# If GLOCUSATAX   # 106867.o
If !GIMPORT & !GWEBSERV & func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
    # Spécificité USA
    Local Char     WKU_MAJ : WKU_MAJ="2"
    Local Integer  OK
    Call OUVRE_TRACE(mess(322,197,1)) From LECFIC
Endif
Gosub CHARG_TABLEAUX From TRTVENFACC
Gosub CAL_FACTURE From TRTVENFACC
# If GLOCUSATAX   # 106867.o
If !GIMPORT & !GWEBSERV & func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
    # Spécificité USA
    Call FERME_TRACE From LECFIC
    If GMESSAGE <> "" & !GIMPORT
        Call OUINON(GMESSAGE+"\"+mess(88,191,1), OK) From GESECRAN
        If OK=2 Call LEC_TRACE From LECFIC : Endif
        Raz GMESSAGE
    Endif
Endif
[M:SIH0]INVCLCFLG=1
[M:SIH4]INVNOT = [M:SIHV]INVNOT
[M:SIH4]INVATI = [M:SIHV]INVATI

Affzo [M:SIHV]1-99
Affzo [M:SIH4]15

End

########################################
# ---------------------- ITMREF : Référence article --------------------------
Subprog IB_ITMREF
# Désactivation bouton interro stock et disponible à la vente
If [M]STOMGTCOD(nolign-1) = 1
   Raz GBOUT3
Endif
End
#---------------------------------------
Subprog AV_ITMREF(VALEUR)    : # Interactif
Variable Char    VALEUR()

Local    Decimal WQTY
Local    Integer J, NOL
NOL=nolign-1

#--- Bug 80673
If dim(GCREPARBOU)>0 & GCREPARBOU=1 End Endif

pcolor=GCOUL(0)

# Si facture directe avec maj stock
# ou facture de commande
# ou facture de livraison mais ligne sans no liv
# et article géré en stock
If   [M:SIH0]INVTYP=1 & [M:SIH4]STOMGTCOD(NOL)<>1 &
&  (([M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG=2)      | [M:SIH1]SIHORI=2 |
&   ([M:SIH1]SIHORI=3 & [M:SIH4]SDHNUM(NOL)=""))
   # Colorisation de l'article
   # - si tout le stock à sortir n'a pas été renseigné
   # - s'il y a une quantité en rupture
   If [M:SIH1]INVSTA<>2 & [M:SIH4]STOMGTCOD(NOL)<>1
      # Nouvelle ligne ou ligne modifiée
      If [M:SIH4]CREFLG(NOL)=0 | ([M:SIH4]CREFLG(NOL)<>0 & [M:SIH4]UPDFLG(NOL)<>0)
         # Si ligne en cours de saisie
         If [M:SIH4]QTYSTU(NOL)=0
            pcolor=GCOUL(1)
         Else
            WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTU(J)*([M:SOW]WSTOSEQ(J)=[M:SIH4]WSTOSEQ(NOL)))
            # Tout le stock à sortir n'a pas été renseigné
            If WQTY<>[M:SIH4]QTYSTU(NOL)
               pcolor=GCOUL(1)
            Else
               WQTY=sigma(J=0,[M:SOW]NBLIG-1,[M:SOW]WQTYSTU(J)*
&                        ([M:SOW]WSTOSEQ(J)=[M:SIH4]WSTOSEQ(NOL)&[M:SOW]WSTOCOU(J)<>0))
               # Il y a une quantité en rupture
               If WQTY<>[M:SIH4]QTYSTU(NOL)
                  pcolor=GCOUL(2)
               Endif
            Endif
         Endif
      Endif
   Endif
Endif
End
#---------------------------------------
Subprog AS_ITMREF(VALEUR)
Variable Char    VALEUR()
If GMODIF <> 2 mkstat=2 Endif
End
#---------------------------------------
Subprog C_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL    : NOL = nolign-1
Local    Integer RET, OK, I
Local    Char    REP

  # FGR 06/06/2013 : X3SUIVI90225 (début)
  If dim(GWLTRT) >= 0 Then
    If GWLTRT = "TRTSIHSRE" Then
      # Si on est en facturation de demande de service on ne contrôle pas l'article. Ca a été fait dans la demande de service.
      # FGR 19/08/2013 : X3SUIVI87923 (début)
      Read [ITM]ITM0=VALEUR
      If fstat <> 0 GMESSAGE = mess(8,192,1) : mkstat=2 : End : Endif
      # FGR 19/08/2013 : X3SUIVI87923 (fin)
      End
    Endif
  Endif
  # FGR 06/06/2013 : X3SUIVI90225 (fin)

# --> Etape n°1 : Remplacement par article de substitution
Call CTLSBSITM(VALEUR, [M]INVDAT, RET) From TRTVENCTL
If RET = 1
#   MSG=probleme sur l'article de substitution
    GMESSAGE = mess(40,192,1) : mkstat=2 : End
Elsif RET = 2
#   MSG=remplacement par l'article de substitution
    VALEUR = [F:ITS]ITMREF
    GMESSAGE = mess(10,191,1) - VALEUR : GERR=2
Endif

# --> Etape n°2 : Lecture objet ITM
# MSG=article vente sans article maitre
Read [ITM]ITM0=VALEUR
If fstat <> 0 GMESSAGE = mess(8,192,1) : mkstat=2 : End : Endif

# --> Etape n°3 : Contrôle du statut de l'article
If [F:ITM]ITMSTA > 1
   If GERR = 2 GMESSAGE += " \ " Endif
   GMESSAGE += mess(3,196,1)+" ("+mess([F:ITM]ITMSTA,246,1)+")"
   If [F:ITM]ITMSTA = 6
      mkstat=2 : End
   Else
      GERR=3
   Endif
Endif
# On vérifie que la date de facture est bien >= la date de début de vie de l'article
If [F:ITM]LIFSTRDAT<>[0/0/0] & [M:SIH0]INVDAT<[F:ITM]LIFSTRDAT
   mkstat=2 : GMESSAGE=mess(331,199,1)-":"-format$(GFMDAT,[F:ITM]LIFSTRDAT) : End
Endif
# On vérifie que l'article est toujours vendu
If clalev([F:ITG])= 0 Local File ITMCATEG [ITG] : Endif
If [F:ITG]TCLCOD <> [F:ITM]TCLCOD
    Read [ITG]ITG1=[F:ITM]TCLCOD;""
    If fstat GMESSAGE = [F:ITM]TCLCOD-":"-mess(338,199,1) : mkstat=2 : End : Endif
Endif
If [F:ITG]SALFLG<>2 GMESSAGE = mess(221,199,1)-"("-[F:ITM]TCLCOD-")" : mkstat=2 : End : Endif

# --> Etape n°4 : Recherche interdit
If dim([M]REP1(NOL)) > 0 REP = [M]REP1(NOL):Endif
Call RECH_INTERDIT (VALEUR, [M]BPAADD, REP, 4) From TRTVENTAR
If mkstat=2 End : Endif

# Saisie d'une nvelle ligne directe : Si facture de commande ou de livraison ou de transfert inter-site
# ==> l'article doit être non réceptionné
If GFONCTION="GESSIH" & !GIMPORT
    If [M]INVTYP=1 & find([M]SIHORI, 2,3,9) & [M]STOMVTFLG=2 & [M]BETFCY=2
        If [F:ITM]RCPFLG=2 GMESSAGE=mess(55,198,1)-mess(491,197,1)-":"-mess(298,192,1) : mkstat=2 : End : Endif
    Endif
Endif

#If ([M]INVTYP=1 & [M]SIHORI<>1) | (([M]SIHORI=1 | [M]SIHORI=4) & [M]STOMVTFLG=2)
If [M]STOMVTFLG=2
   Call CONTITF(VALEUR, [M:SIH4]DSTOFCY(nolign-1), [F:ITM]STOMGTCOD) From TRTVENCTL
   If mkstat = 2 End : Endif
Endif

# Bug 82658 : Recherche tarif si changement de référence article
# Erreur suite à la recherche tarif effectuée en AM_
If dim(GERRITMREF)>0 & GERRITMREF=2
  # Si on resaisit l'article initial
  # --> Il faut redéclencher l'AM_ pour recharger les champs avec l'article initial
  If VALEUR=[M]ITMREF(NOL) Call AM_ITMREF(VALEUR) Endif
  Kill GERRITMREF
Endif
# Bug 82658

End

#---------------------------------------
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL : NOL = nolign-1

# Bug 82658 : Recherche tarif désormais branchée en fin de l'action
## --> Il faut forcer la recherche tarif
#Raz [M:SIH4]QTY(NOL)

[M]LINTYP(NOL) = 1
# --> si avoir, on ne traite pas les composés (kits, nomenclatures)
If [M]INVTYP <> 2
   If [F:ITS]ITMTYP = 2 [M]LINTYP(NOL) = 6 :Endif
   If [F:ITS]ITMTYP = 3 [M]LINTYP(NOL) = 2 :Endif
Endif

Call INIT_ITM (NOL, VALEUR) From SUBSIHB

# Bug 82658 : Recherche tarif si changement de référence article
# Si ce n'est pas un gratuit et qté non nulle et facture/avoir direct
If [M]QTY(NOL)<>0 & [M]FOCFLG(NOL) <> 3 & [M]SOHNUM(NOL) = "" & [M]SDHNUM(NOL)="" &
&  [M]CONNUM(NOL)="" & [M]SRENUM(NOL)="" & [M]XSIHORINUM(NOL)=""
    Call ALICLCAMT(VALEUR, [M]QTY(NOL), NOL, "SIH4", [M:SIH4]CLCAMT1(NOL), [M:SIH4]CLCAMT2(NOL)) From TRTX3
    # ------ Recherche tarif --------------
    Local Integer TYP
    Local Char    WSVG_ITMREF(GLONITM)
    # Article normal ou composé
    TYP=1
    # Composant
    If find([M:SIH4]LINTYP(NOL),3,4,5,7,8,9,11,12,13)
        Local Integer ORI : ORI=NOL
        While !find([M]LINTYP(ORI),2,6,10) & ORI >= 0 ORI-=1 Wend
        If find([M]LINTYP(ORI),2,6,10) GPNTITMREF=[M]ITMREF(ORI) Endif
        TYP=4
    Endif
    # --> Recherche tarif
    Call RECH_TARIF(TYP,VALEUR,NOL,[M]QTY(NOL),"SIH",[M]GROPRI(NOL)) From TRTVENTAR
    # --> Calcul du prix net
    Call CLCNETPRI([M]QTY(NOL), [M:SIH2]CUR, NOL) From TRTVENPRI
    # Le ctrl du prix net et le calcul de marge utilise la classe [M]
    WSVG_ITMREF=[M]ITMREF(NOL) : [M]ITMREF(NOL)=VALEUR
    If GDACLOK = 1
        Call CTLNETPRI([M:SIH1]BPCORD,[M:SIH2]CURTYP,[M:SIH0]INVDAT,[M:SIH2]CUR,NOL) From TRTVENPRI
        If mkstat=2
          [M]ITMREF(NOL)=WSVG_ITMREF
          # Déclaration d'une globale signalant l'erreur sur le champ, globale testée en C_
          If dim(GERRITMREF)<0 Global Integer GERRITMREF : GERRITMREF=2 Endif
          End
        Endif
    Endif
    # --> Calcul de la marge
    Call CLCPFM([M]DSTOFCY(NOL), [M]PRITYP, [M]CHGTYP, [M:SIH0]INVDAT, [M:SIH2]CUR, NOL, 2) From TRTVENPRI
    If GDACLOK = 1
        Call CTLPFM([M:SIH2]CUR,[M:SIH4]CPRPRI(NOL), NOL) From TRTVENPRI
        If mkstat=2
          [M]ITMREF(NOL)=WSVG_ITMREF
          # Déclaration d'une globale signalant l'erreur sur le champ, globale testée en C_
          If dim(GERRITMREF)<0 Global Integer GERRITMREF : GERRITMREF=2 Endif
          End
        Endif
    Endif
    Gosub AFF_RECH_TAR
    Affzo [M:SIH4]NETPRI(NOL)
    Affzo [M:SIH4]CPRPRI(NOL), PFM(NOL)
Endif
# Bug 82658

Affzo [M]ITMDES(NOL), ITMDES1(NOL), SAU(NOL),SAUSTUCOE(NOL), STU(NOL), LINTYP(NOL)
Affzo [M:SIH4]VACITM1(NOL),VACITM2(NOL),VACITM3(NOL)
If [M:SIH4]DACSAUCOE(NOL) < 2
    Diszo [M:SIH4]SAUSTUCOE(NOL)
Else
    Actzo [M:SIH4]SAUSTUCOE(NOL)
Endif

# Si facture directe avec maj stock
# ou facture de commande
# ou facture de livraison mais ligne sans no liv
# et article géré en stock
# --> Lecture article et règle de gestion
If   [M:SIH0]INVTYP=1 & [M:SIH4]STOMGTCOD(NOL)<>1 &
&  (([M:SIH1]SIHORI=1 & [M:SIH1]STOMVTFLG=2)      | [M:SIH1]SIHORI=2 |
&   ([M:SIH1]SIHORI=3 & [M:SIH4]SDHNUM(NOL)=""))
   Call INIZONSOR("SIH4",VALEUR,[M:SIH4]DSTOFCY(NOL),NOL,4,[M:SIH0]TRSCOD,"") From STKECR
   If dim([M:SIH4]LOC)>0
      Call STKINIEMPS([M:SIH4]LOC(NOL)) From STKLOC
   Endif
# Sinon, si facture ou proforma
Elsif find([M:SIH0]INVTYP,1,5)
   # Effacement et grisage des champs stock
   Raz [M]STA(NOL)    : Grizo [M]STA(NOL)
   Raz [M]MVTDES(NOL) : Grizo [M]MVTDES(NOL)
   If dim([M:SIH4]LOC)>0     Raz [M]LOC(NOL)    : Grizo [M]LOC(NOL)    Endif
   If dim([M:SIH4]LOT)>0     Raz [M]LOT(NOL)    : Grizo [M]LOT(NOL)    Endif
   If dim([M:SIH4]SLO)>0     Raz [M]SLO(NOL)    : Grizo [M]SLO(NOL)    Endif
   If dim([M:SIH4]SERNUM)>0  Raz [M]SERNUM(NOL) : Grizo [M]SERNUM(NOL) Endif
   If dim([M:SIH4]SERNUMF)>0 Raz [M]SERNUMF(NOL)                       Endif
   If dim([M:SIH4]PALNUM)>0  Raz [M]PALNUM(NOL) : Grizo [M]PALNUM(NOL) Endif
   If dim([M:SIH4]CTRNUM)>0  Raz [M]CTRNUM(NOL) : Grizo [M]CTRNUM(NOL) Endif
Endif

# ----- #
# Avoir #
# ----- #
If [M:SIH0]INVTYP=2
    # Si avoir direct
    # ou avoir sur facture
    # ou ligne directe d'un avoir sur retour
    # avec mouvement de stock et article géré en stock
    # --> Lecture article et règle de gestion

    Actzo [M:SIH4]SAU(NOL), QTY(NOL)
    If [M:SIH4]STOMGTCOD(NOL)<>1 & [M:SIH1]STOMVTFLG=2 & [M:SIH1]BETFCY=1 &
&      (find([M:SIH1]SIHORI,1,4) | ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)=""))
        #   Initialisation et grisage champs stock sur ligne document d'entrée
        #   si "U" Pas d'initialisation des unités et coefficients
        Call STKACTLIG(NOL) From STKECR
        Call INIZONENT(VALEUR,"SIH4",[M]STOFCY,[M]BPCORD,2,"U",NOL,12,[M]TRSCOD,[M]NUM,3,1) From STKECR
        If mkstat End : Endif
        If dim([M]PRIORD)>0  Raz [M]PRIORD(NOL) : Actzo PRIORD(NOL) : Endif
        If dim([M]MVTDES)>0  Raz [M]MVTDES(NOL) : Actzo MVTDES(NOL) : Endif
        [M]RTNSTOUPD(NOL)=2 : # Maj des stocks
    Else
        # Pas de gestion des stocks
        Raz [M]GESLOT(NOL), [M]WSTOSEQ(NOL), [M]WSTOFLG(NOL), [M]WSRUFLG(NOL)
        Call STKRAZGRILIG ("SIH4", NOL) From TRTVENSTK
        [M]WSTOFLG(NOL)=2  : # Article non géré en stock
        [M]RTNSTOUPD(NOL)=1 : # Pas de maj des stocks
    Endif
Endif

# Bug 72575
##      Si import des gratuits : le flag gratuit doit etre garni dans [M]
If GIMPORT & (dim(G_FOCFLG)>0 & G_FOCFLG=1)
    # Garnissage du flag gratuit dans [M]
    If find([F:SID]FOCFLG, 1,2,3) [M]FOCFLG(NOL)=[F:SID]FOCFLG Else [M]FOCFLG(NOL)=1 Endif
    # Sur la ligne du gratuit il faut rechercher l'article origine
    If [M]FOCFLG(NOL)=3 and NOL>0 # Issue 112809 - 2016-01-25 by CPO : added "and NOL>0" Imported free item on first order line
        Local Integer WNOLCPE : WNOLCPE=NOL-1
        If WNOLCPE>=0 & !find([M]LINTYP(WNOLCPE),1,2,6,10)
            While !find([M]LINTYP(WNOLCPE),1,2,6,10) & WNOLCPE >= 0
                WNOLCPE-=1
            Wend
        Endif
        If WNOLCPE>=0 # Issue 112809 - 2016-01-25 by CPO : "ceinture-bretelles" (si 2 et plus premières lignes de gratuits...)
          [M]ORILIN(NOL)=[M]SIDLIN(WNOLCPE)
        Endif
    Endif
Endif
# Bug 72575

End

########################################
# -------------------------- ITMREF : Référence article -------------------
Subprog IB_ITMDES
Global   Char    GITMREF
# Alimentation GITMREF pour appel GOBJETC
GITMREF=[M]ITMREF(nolign-1)
End
########################################
# -------------------------- ITMREF1 : Référence std ----------------------
Subprog IB_ITMDES1
Global   Char    GITMREF
# Alimentation GITMREF pour appel GOBJETC
GITMREF=[M]ITMREF(nolign-1)
End
# 107888 : Scheduled invoices : (LD:04/03/16)
########################################
# ------------------------- INVPRC : Percentage ------------------------
Subprog AS_INVPRC(VALEUR)
Variable Decimal VALEUR

# The percentage is enable for an invoice/credit not line who's origin is schedule invoice
# To see if the control is good for a credit note ...
If [M:SIH1]INVSTA = 3 or [M:SIH4]SIDORI(nolign-1)<>10 mkstat=2 Endif

End
# 107888 : Scheduled invoices : (LD:04/03/16)
#######################################
# ------------------------- SAU : Unité de vente ------------------------
Subprog AS_SAU(VALEUR)    : # --- Web - Obligatoire - Synchrone
Variable Char    VALEUR()
If GMODIF <> 2 | [M]LINTYP(nolign-1) <> 1 mkstat=2 : Endif

#LSE 05/12/2006 FQ38520
Local Integer NOL : NOL=nolign-1
If [F:ITM]ITMREF <> [M:SIH4]ITMREF(NOL)
    Read [ITM]ITM0=[M:SIH4]ITMREF(NOL)
    If fstat Raz [F:ITM] Endif
Endif
If [F:ITM]HDKITMTYP=5
    mkstat=2
Endif

End
#---------------------------------------
Subprog AM_SAU(VALEUR)
Variable Char    VALEUR()
[M:SIH4]QTY(nolign-1) = 0
[M:SIH4]QTYSTU(nolign-1) = 0
Affzo [M:SIH4]SAUSTUCOE(nolign-1)
If [M:SIH4]DACSAUCOE(nolign-1) < 2
    Diszo [M:SIH4]SAUSTUCOE(nolign-1)
Else
    Actzo [M:SIH4]SAUSTUCOE(nolign-1)
Endif
End
########################################
# ------------------------- SAUSTUCOE : Coef UV-US ------------------------
Subprog AS_SAUSTUCOE(VALEUR)
Variable Decimal VALEUR
If GMODIF<>2 | [M]LINTYP(nolign-1)<>1 | [M]SAU(nolign-1)=[M]STU(nolign-1) | [M]QTY(nolign-1)=0
    mkstat=2
Endif
End
##########################################################################
## Etiquette ajoutée par le superviseur 16/07/2003 10:55:34 (LD)
##########################################################################
Subprog AM_SAUSTUCOE(VALEUR)
Variable Decimal VALEUR
Local    Integer  NOL     : NOL=nolign-1
Local    Shortint TYP
Local    Decimal  WANC_SAUSTUCOE

# La modif. du coef de conversion UV_US entraîne une nvelle recherche tarif (utile si tarif en US)
# Pas de recherche tarif pour les gratuits
If [M:SIH4]FOCFLG(NOL) = 3 End : Endif
# ----- Recherche tarif -------
# Article normal ou composé
TYP=1
# Composant
If find([M:SIH4]LINTYP(NOL),3,4,5,7,8,9,11,12,13) TYP=4 Endif
# --> Recherche tarif
WANC_SAUSTUCOE=[M]SAUSTUCOE(NOL)
[M]SAUSTUCOE(NOL)=VALEUR
Call RECH_TARIF(TYP,[M]ITMREF(NOL),NOL,[M]QTY(NOL),"SIH",[M]GROPRI(NOL)) From TRTVENTAR
# --> Calcul du prix net
Call CLCNETPRI([M]QTY(NOL), [M]CUR, NOL) From TRTVENPRI
If GDACLOK = 1
    Call CTLNETPRI([M]BPCORD,[M]CHGTYP,[M]INVDAT,[M]CUR,NOL) From TRTVENPRI
    If mkstat=2 [M]SAUSTUCOE(NOL)=WANC_SAUSTUCOE : End : Endif
Endif
# --> Calcul de la marge
Call CLCPFM([M]DSTOFCY(NOL), [M]PRITYP, [M]CHGTYP, [M]INVDAT, [M]CUR, NOL, 2) From TRTVENPRI
If GDACLOK = 1
    Call CTLPFM([M]CUR,[M]CPRPRI(NOL), NOL) From TRTVENPRI
    If mkstat=2 [M]SAUSTUCOE(NOL)=WANC_SAUSTUCOE : End : Endif
Endif
Gosub AFF_RECH_TAR
Affzo [M:SIH4]NETPRI(NOL), CPRPRI(NOL), PFM(NOL)

nolign=NOL+1
End
########################################
# ------------------------- QTY : Quantité -------------------------------
Subprog IB_QTY

#If [M]INVTYP <> 1 | ([M]SIHORI=1 & [M]STOMVTFLG=1) | [M]STOMGTCOD(nolign-1)=1
If [M]STOMVTFLG=1 | [M]STOMGTCOD(nolign-1)=1 | [M]SIHORI=9 | [M:SIH0]INVTYP<>1
    Raz GBOUT3  : # Stock par site
Endif
End
#---------------------------------------
Subprog AS_QTY(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL : NOL=nolign-1

If ([M]LINTYP(NOL)>2 & [M]LINTYP(NOL)<6) | ([M]LINTYP(NOL)>10 & [M]LINTYP(NOL)<14) mkstat=2 : Endif
# --> Modification impossible si facture de livraison ou de transfert
If [M]INVTYP=1 & ([M]SDHNUM(NOL)<>"" | [M]SGHNUM(NOL)<>"") mkstat=2 : End : Endif
# --> Modification impossible si ligne d'avoir en valeur
#     Si Avoir avec mouvement de stock, ligne déjà créée et gérée en stock
#     (On ne passe plus d'avoir en valeur à avoir en qté (délicat pour la gestion des stocks))
If [M:SIH0]INVTYP=2 & [M:SIH1]STOMVTFLG=2 & [M]CREFLG(NOL)<>0 & [M:SIH4]STOMGTCOD(NOL)<>1
    # --> On ne passe plus d'avoir en valeur à avoir en qté et inversement (délicat pour la gestion des stocks)
    If (find([M:SIH1]SIHORI, 1,4) | ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)="")) & [M]QTY(NOL)=0 mkstat=2 : End : Endif
Endif
# --> Si avoir direct ou sur facture avec mvt stock
#If [M]INVTYP=2 & find([M]SIHORI, 1, 4) & [M]STOMVTFLG=2 & [M]STOMGTCOD(NOL)<>1
#   # Si la ligne existait et qu'elle est gérée en stock
#   If [M]CREFLG(NOL)<>0
#      GMESSAGE=mess(72,192,1)+"\"+mess(121,192,1)-mess(262,198,1)
#      mkstat=2 : End
#   Endif
#Endif
End
#---------------------------------------
Subprog C_QTY(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL : NOL = nolign-1
Local    Integer OK
Local    Decimal QTY, QTYUS, WSTUDIS, COEF
Local    Integer WLOC

# Si ce n'est pas un avoir, la qté est obligatoire
If [M:SIH0]INVTYP<>2 & VALEUR=0 mkstat=2 : End : Endif
If [M:SIH0]INVTYP=2
    # Avoir
    # Si la ligne est déjà créée :
    If [M]CREFLG(NOL)<>0
        # Si la ligne est gérée en stock
        # --> On ne passe plus d'avoir en qté à avoir en valeur (délicat pour la gestion des stocks)
        If [M:SIH4]STOMGTCOD(NOL)<>1 & [M:SIH1]STOMVTFLG=2 &
&       (find([M:SIH1]SIHORI, 1,4) | ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)=""))
            If VALEUR=0 mkstat=2 : End : Endif
        Endif
    Endif
    # --> Si le montant ligne n'est pas saisissable refus de saisir une qté à 0
    If !GIMPORT & GSLTAMTLINCOD<>1 & VALEUR=0 GMESSAGE=mess(332,192,1) : mkstat=2 : End : Endif
    # --> Si le montant ligne est saisissable et la qté est à 0 on ne fait aucun contrôle
    If VALEUR=0 End Endif
Endif

#-------------------------------------------#
# Ctr par rapport qte mini et qte maxi      #
#-------------------------------------------#
Gosub CTR_QTY From SUBSIHB
If mkstat=2 End:Endif
# Contrôle uniquement si facture et pas composant d'un kit
If [M:SIH0]INVTYP = 1 & find([M]LINTYP(NOL),1,2,6,7,8,9,10)
#  Quantité facture > quantité commandée restant à facturer
   If [M]YINVQTY(NOL) <> 0 & VALEUR > [M]YINVQTY(NOL)
      If GERR = 2 GMESSAGE += " \ " Endif
      GERR=2 : GMESSAGE+=mess(44,191,1)
   Endif
Endif
# Si avoir sur retour on ne peut pas saisir une qté > qté retour
If [M:SIH0]INVTYP=2 & [M:SIH4]SRHNUM(NOL) <> ""
    Read [SRD]SRD0=[M:SIH4]SRHNUM(NOL);[M:SIH4]SRDLIN(NOL)
    If !fstat & VALEUR > [F:SRD]QTY mkstat=2 : GMESSAGE=mess(204,192,1) : End : Endif
    If !fstat & VALEUR < [F:SRD]QTY
        OK=2:Call AVERTIR(mess(219,192,1),OK) From GESECRAN
        If OK=1 mkstat=2 : End : Endif
    Endif
Endif
# Contrôle stock disponible
#If [M]STOMGTCOD(NOL)=1 | ([M]SIHORI=1 & [M:SIH1]STOMVTFLG=1) | [M:SIH0]INVTYP<>1 End : Endif
If [M:SIH1]STOMVTFLG=1 | [M]STOMGTCOD(NOL)=1 | [M]SIHORI=9 | [M:SIH0]INVTYP<>1 End : Endif

# Si composant d'un kit/sous-traité, pas de contrôle
If find([M]LINTYP(NOL),3,4,5,11,12,13) End Endif
QTYUS = 0
#---------------------------------
# Si nouvelle ligne
Call CNVQTY(VALEUR,[M]SAUSTUCOE(NOL),[M]STU(NOL),QTYUS) From TRTVENQTE
If [M]CREFLG(NOL) = 0
   If [M:SIH4]SOHNUM(NOL)<>"" & [M:SIH4]SDHNUM(NOL)=""
      Read [SOQ]SOQ0=[M:SIH4]SOHNUM(NOL);[M:SIH4]SOPLIN(NOL);[M:SIH4]SOQSEQ(NOL)
      If !fstat
         # Test de dispo sur nouvelle qte livrée par rapport à qté allouée
         If QTYUS > [F:SOQ]ALLQTYSTU
            QTYUS = QTYUS - [F:SOQ]ALLQTYSTU
         Else
            QTYUS = 0
         Endif
      Endif
   Endif
# Sinon si augmentation de la quantité livrée
Elsif QTYUS > [M]YQTYSTU(NOL)
   If [M:SIH4]SOHNUM(NOL)<>"" & [M:SIH4]SDHNUM(NOL)=""
      Read [SOQ]SOQ0=[M:SIH4]SOHNUM(NOL);[M:SIH4]SOPLIN(NOL);[M:SIH4]SOQSEQ(NOL)
      # La commande existe et n'est pas soldée
      If !fstat & [F:SOQ]SOQSTA<>3
         # Test de dispo fait sur différence qte livrée par rapport à qté allouée
         If QTYUS > [M]YQTYSTU(NOL) + [F:SOQ]ALLQTYSTU
            QTYUS = QTYUS - [M]YQTYSTU(NOL) - [F:SOQ]ALLQTYSTU
         Else
            QTYUS = 0
         Endif
      Else
         QTYUS = QTYUS - [M]YQTYSTU(NOL)
      Endif
   Else
      QTYUS = QTYUS - [M]YQTYSTU(NOL)
   Endif
Else
   QTYUS=0
Endif

#---------------------------------

# Lecture de l'article
If [F:ITM]ITMREF <> [M]ITMREF(NOL)
   Read [ITM]ITM0=[M]ITMREF(NOL)
   If fstat Raz [F:ITM] Endif
Endif
If QTYUS <> 0
   Read [ITV]ITV0=[M]ITMREF(NOL);[M]DSTOFCY(NOL)
   If fstat  Raz [F:ITV]  Endif

   # Emplacement interne + en attente de rangement
   WLOC = 1
   # Calcul stock disponible
   Call STODISTOT("",WLOC,[F:SRU]AUZSTA,"",WSTUDIS) From STKLIB

   # Stock non disponible
   If WSTUDIS < QTYUS
      If GERR = 2 GMESSAGE += " \ " Endif
      If [F:ITM]NEGSTO = 2
         OK = 2
         # Voulez-vous quand même facturer ?
         Call AVERTIR(mess(79,192,1),OK) From GESECRAN
         If OK<>2 mkstat=2 Endif
      Else
         # Stock négatif interdit !
         mkstat = 2 : GMESSAGE = mess(123,192,1)
      Endif
   Endif
Endif
End
#---------------------------------------
Subprog AM_QTY(VALEUR)
Variable Decimal VALEUR
Local    Integer NOL       :  NOL=nolign-1
Local    Integer WRET, WRECH_TAR, TYP
Local    Decimal WSVGQTY
Local    Decimal WSNETPRI, WSNETPRINOT, WSNETPRIATI : # Bug 70861

Local    Decimal WCPO_QTY : WCPO_QTY = [M:SIH4]QTY(NOL) # Issue 107888 US140 - 2016-03-25 by CPO : Scheduled invoices object management
# -------------------------------- #
# Traitement concernant les tarifs #
# -------------------------------- #

# Issue 107888 US140 - 2016-03-25 by CPO : Scheduled invoices object management
#--This call has to be the first. Due to rounding constraint, il can modify the VALEUR value
Gosub AM_QTY From LIBSAL_INVCND_SIH # Issue 107888 US140 - 2016-03-25 by CPO : Scheduled invoices object management
If mkstat>0 or GERR=1 : End : Endif
# End issue 107888

# Issue 111617
# --> Calcul des montants de base calcul de taxe pour les facture/avoir en qté et les avoirs en valeur
Local    Decimal WUNTCLCAMT1, WUNTCLCAMT2 : Raz WUNTCLCAMT1, WUNTCLCAMT2
If [M]QTY(NOL) <> 0
    WUNTCLCAMT1=[M]CLCAMT1(NOL)/[M]QTY(NOL) : WUNTCLCAMT2=[M]CLCAMT2(NOL)/[M]QTY(NOL)
Endif
Call ALICLCAMT([M]ITMREF(NOL), VALEUR, NOL, "SIH4", [M:SIH4]CLCAMT1(NOL), [M:SIH4]CLCAMT2(NOL)) From TRTX3
# End issue 111617

If VALEUR<>0
    # Qté renseignée : Facture ou Avoir en qté
    # Issue 111617
    # Calcul déjà effectué ci-dessus
#    # --> Calcul des montants de base calcul de taxe
#    Local    Decimal WUNTCLCAMT1, WUNTCLCAMT2 : Raz WUNTCLCAMT1, WUNTCLCAMT2
#    If [M]QTY(NOL) <> 0
#        WUNTCLCAMT1=[M]CLCAMT1(NOL)/[M]QTY(NOL) : WUNTCLCAMT2=[M]CLCAMT2(NOL)/[M]QTY(NOL)
#    Endif
#    Call ALICLCAMT([M]ITMREF(NOL), VALEUR, NOL, "SIH4", [M:SIH4]CLCAMT1(NOL), [M:SIH4]CLCAMT2(NOL)) From TRTX3
    # End issue 111617
    # Pas de recherche tarif pour les gratuits
    If [M:SIH4]FOCFLG(NOL) = 3 End:Endif
    # Pas de recherche tarif pour les lignes issues de commande ou livraison ou contrat ou demande de services
    If [M:SIH4]SOHNUM(NOL)<>"" | [M:SIH4]SDHNUM(NOL)<>"" | [M:SIH4]CONNUM(NOL)<>"" | [M:SIH4]SRENUM(NOL)<>""
        WRECH_TAR=1
    Else
    #-------------------------------------------------------------------#
    # Recherche tarif si modif qte ou creation lignes diverses facture  #
    #-------------------------------------------------------------------#
        If GMODIF = 0
            WRECH_TAR = 1
            If [M:SIH4]FOCFLG(NOL) = 2
                GMESSAGE = mess(7,191,1)+"\"+mess(21,191,1)
            Else
                GMESSAGE = mess(21,191,1)
            Endif
            Call OUINON(GMESSAGE,WRECH_TAR) From GESECRAN
            Raz GMESSAGE
        If WRECH_TAR=2 & find([M:SIH4]LINTYP(NOL),2,6,10) GTARFLG="1" Endif : # Bug 62571
        Else
            WRECH_TAR = 2
        Endif
    Endif
    If WRECH_TAR = 2
        # ------ Recherche tarif --------------
        # Article normal ou composé
        TYP=1
        # Composant
        If find([M:SIH4]LINTYP(NOL),3,4,5,7,8,9,11,12,13)
            Local Integer ORI : ORI=NOL
            While !find([M]LINTYP(ORI),2,6,10) & ORI >= 0 ORI-=1 Wend
            If find([M]LINTYP(ORI),2,6,10) GPNTITMREF=[M]ITMREF(ORI) Endif
            TYP=4
        Endif
        # --> Recherche tarif
        Call RECH_TARIF(TYP,[M]ITMREF(NOL),NOL,VALEUR,"SIH",[M]GROPRI(NOL)) From TRTVENTAR
    Endif

    # Bug 70861 : Recalcul prix net si recherche tarif ou si ligne directe (car impact des frais/remise par ligne sur le prix net)
    WSNETPRI=[M]NETPRI(NOL) : WSNETPRINOT=[M]NETPRINOT(NOL) : WSNETPRIATI=[M]NETPRIATI(NOL)
    If WRECH_TAR=2 | sum([M]SOHNUM(NOL),[M]SDHNUM(NOL),[M]CONNUM(NOL),[M]SRENUM(NOL),[M]SGHNUM(NOL),[M]XSIHORINUM(NOL)) = ""
        WSVGQTY=[M]QTY(NOL) : [M]QTY(NOL)=VALEUR
        Call CLCNETPRI(VALEUR, [M:SIH2]CUR, NOL) From TRTVENPRI
        [M]QTY(NOL)=WSVGQTY
        If GDACLOK = 1
            Call CTLNETPRI([M:SIH1]BPCORD,[M:SIH2]CURTYP,[M:SIH0]INVDAT,[M:SIH2]CUR,NOL) From TRTVENPRI
            If mkstat=2 : End Endif
        Endif
        Gosub AFF_RECH_TAR
        Affzo [M:SIH4]NETPRI(NOL)
    Endif
    # Bug 70861

    # --> Calcul de la marge (Si recherche tarif ou Si chgnt montant base calcul taxe)
    If WRECH_TAR=2 | [M]CLCAMT1(NOL)/VALEUR<>WUNTCLCAMT1 | [M]CLCAMT2(NOL)/VALEUR<>WUNTCLCAMT2
&                  | [M]NETPRI(NOL)<>WSNETPRI | [M]NETPRINOT(NOL)<>WSNETPRINOT | [M]NETPRIATI(NOL)<>WSNETPRIATI : # Bug 70861
        WSVGQTY=[M]QTY(NOL) : [M]QTY(NOL)=VALEUR
        Call CLCPFM([M]DSTOFCY(NOL), [M]PRITYP, [M]CHGTYP, [M:SIH0]INVDAT, [M:SIH2]CUR, NOL, 2) From TRTVENPRI
        [M]QTY(NOL)=WSVGQTY
        If GDACLOK = 1
            Call CTLPFM([M:SIH2]CUR,[M:SIH4]CPRPRI(NOL), NOL) From TRTVENPRI
            If mkstat=2 End Endif
        Endif
    Endif
    Gosub ACTZO_TAR : # Activation des zones tarifs (si désactivées par un avoir en valeur)
    #If WRECH_TAR = 2                    : # Bug 70861
    #    Gosub AFF_RECH_TAR              : # Bug 70861
    #    Affzo [M:SIH4]NETPRI(NOL)       : # Bug 70861
    #Endif                               : # Bug 70861
    Raz [M:SIH4]AMTLIN(NOL) : Diszo [M:SIH4]AMTLIN(NOL)
    If dim([M:SIH4]EECFLOPHY)>0 Actzo [M:SIH4]EECFLOPHY(NOL) : Affzo [M:SIH4]EECFLOPHY(NOL) Endif
    Affzo [M:SIH4]CPRPRI(NOL), PFM(NOL), AMTLIN(NOL)
Else
    # Qté à 0 : Avoir en valeur
    # Désactivation des zones tarifs
    Gosub RAZ_DISZO_TAR
    Actzo [M:SIH4]AMTLIN(NOL)
    If dim([M:SIH4]EECFLOPHY)>0 [M:SIH4]EECFLOPHY(NOL)=1 : Diszo [M:SIH4]EECFLOPHY(NOL) : Affzo [M:SIH4]EECFLOPHY(NOL) Endif
Endif

If [M:SIH0]INVTYP<>2 | [M:SIH1]STOMVTFLG=1 End Endif
# ----------------------------------------------------------- #
# Avoir avec mvt de stock : Traitement concernant les stocks  #
# ----------------------------------------------------------- #
If VALEUR=0
    #   Qté à 0 : Avoir en valeur : Pas de mise à jour des stock
    Call DELSTOENTW (NOL,NOL,"SIH4",1,1,[M:SIH4]DSTOFCY(NOL),1,"") From STKENT
    Raz [M]GESLOT(NOL), [M]WSTOSEQ(NOL), [M]WSTOFLG(NOL), [M]WSRUFLG(NOL)
    Call STKRAZGRILIG("SIH4", NOL) From TRTVENSTK
    [M]WSTOFLG(NOL)=2   : # Article non géré en stock
    [M]RTNSTOUPD(NOL)=1 : # Pas de maj des stocks
Elsif [M:SIH4]QTY(NOL)=0
    #   Qté renseignée : Passage d'un avoir en valeur en avoir classique : Traiter la mise à jour des stock
    #   article géré en stock et avoir direct ou sur facture ou ligne directe d'un avoir sur retour
    If [M:SIH4]STOMGTCOD(NOL)>1 & ([M:SIH1]SIHORI=1 | ([M:SIH1]SIHORI=4 & [M:SIH4]RTNSTOUPD(NOL)=2) | ([M:SIH1]SIHORI=6 & [M:SIH4]SRHNUM(NOL)=""))
        If [M]SIHORI=1 [M]RTNSTOUPD(NOL)=2 Endif : # Maj des stocks
        Raz [M]WSTOFLG(NOL)
        Default Mask [SIH4]
        Call STKACTLIG(NOL) From STKECR
        Call INIZONENT([M:SIH4]ITMREF(NOL),"SIH4",[M:SIH4]DSTOFCY(NOL),[M:SIH1]BPCORD,2,"U",NOL,12,[M]TRSCOD,[M]NUM,3,1) From STKECR
        If mkstat End : Endif
        If dim([M]PRIORD)>0  Raz [M]PRIORD(NOL) : Actzo PRIORD(NOL) : Endif
        If dim([M]MVTDES)>0  Raz [M]MVTDES(NOL) : Actzo MVTDES(NOL) : Endif
        # Lecture des mouvements de stock d'une ligne de document pour stockage dans écran de travail STOENTW
        Call STJSTOENTW("SIH4",12,18,[M:SIH0]INVDAT,NOL,[M:SIH4]NBLIG,"SLT",0,WRET) From STKENT
        # WRET=1 : Erreur pour stockage dans ENTW : La ligne ne peut pas être créée
        # WRET=2 : Aucune ligne ds ENTW : Tt a déjà été retourné : Pas de ligne à créer
        # WRET=4 : Il y a des lignes ENTW mais il y a aussi des mvts en attente : La ligne peut être créée
        # WRET=6 : Aucune ligne ds ENTW : Ts les mvts st en attente : La ligne ne peut pas être créée
        If WRET=4
            Call MESSAGE([M:SIH4]XSIHORINUM(NOL)-":"-[M:SIH4]ITMREF(NOL)-mess(152,191,1)) From GESECRAN
        Elsif WRET<>0
            If WRET=2
                Call ERREUR([M:SIH4]XSIHORINUM(NOL)-":"-[M:SIH4]ITMREF(NOL)-"\"-mess(285,192,1)) From GESECRAN
            Elsif WRET=6
                Call ERREUR([M:SIH4]XSIHORINUM(NOL)-":"-[M:SIH4]ITMREF(NOL)-":"-mess(284,192,1)-"\"-mess(153,191,1)) From GESECRAN
            Endif
            mkstat=2 : End
        Endif
        If [M:SIH1]SIHORI=4 & [M:SIH4]XSIHORINUM(NOL) <> ""
            Call RECPRISTJ([M:SIH4]DSTOFCY(NOL),5,[M:SIH4]XSIHORINUM(NOL),[M:SIH4]SIDORILIN(NOL),[M:SIH4]PRIORD(NOL)) From STKENT
            Affzo [M:SIH4]PRIORD(NOL)
        Endif
        # CPO 24/07/2008 Pour la DEB
        If dim([M:SIH4]EECFLOPHY)>0
            # --- Si article non soumis à la DEB => EECFLOPHY = Non
            If [F:ITM]ITMREF<>[M:SIH4]ITMREF(NOL)
                Read [ITM]ITM0=[M:SIH4]ITMREF(NOL)
                If fstat Raz [F:ITM] : Endif
            Endif
            If [F:ITM]EECGES = 2
                [M:SIH4]EECFLOPHY(NOL)=[M:SIH1]STOMVTFLG
            Else
                [M:SIH4]EECFLOPHY(NOL)=1 : Diszo [M:SIH4]EECFLOPHY(NOL)
            Endif
        Endif
        # fin CPO
    Endif
Endif

End

########################################
# ------------------------- GROPRI -------------------------------
Subprog AS_GROPRI(VALEUR)    : # --- Web - Obligatoire - Synchrone
Variable Decimal VALEUR
If [M:SIH4]FOCFLG(nolign-1) = 3 | [M:SIH4]QTY(nolign-1)=0 mkstat=2 Endif
End
########################################
Subprog C_GROPRI(VALEUR)
Variable Decimal VALEUR
# En création d'une ligne ou si modification du prix
If ([M]CREFLG(nolign-1)=0 & [M]UPDFLG(nolign-1)=0) | [M]GROPRI(nolign-1)<>VALEUR
    # Si article normal non gratuit, avertissement si prix à 0
    If find([M]LINTYP(nolign-1),1,2,6,10) & [M]FOCFLG(nolign-1) <> 3 & VALEUR =0
        Local Integer OK : OK=2     : # ok=2 bug 14352 autoriser import prix nul
        Call AVERTIR(mess(62,194,1),OK) From GESECRAN
        If OK <> 2 mkstat=2 : Endif
    Endif
Endif
End
