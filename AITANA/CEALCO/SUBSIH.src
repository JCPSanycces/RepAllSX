Subprog C_ORIDOCNUM(VALEUR)
Variable Char    VALEUR()

#97101 RICAR 2014/07/03 - 50001 Law decret - BEGIN
If func PORLEGLIB.ORIDOCNUM_IS_MANDATORY([M]SALFCY,[M]SIVTYP)
  If VALEUR = ""
    mkstat   = 2
    GMESSAGE = mess(10,123,1)
  Else
    Local Integer CTRL      :[L]CTRL       = 1
    Call CTRL_STRUCT(VALEUR,[L]CTRL) From PORLEGLIB
    If [L]CTRL = 0
      Call ERREUR(mess(135,7711,1)) From GESECRAN
      mkstat = 2
      End
    Endif
  Endif
Endif
#97101 RICAR 2014/07/03 - 50001 Law decret - END

End
######################################################################################
#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
Subprog VAL_INVDAT(P_SIVTYP,P_DATE,P_CONT)
Variable Char P_SIVTYP
Variable Date P_DATE
Variable Char P_CONT

If !clalev([F:TSV]) : Local File TABSIVTYP [TSV] : Endif
If !clalev([F:ANM]) : Local File ACODNUM [ANM]   : Endif

Local Integer STAT

Call LEC_TSV_LEG(GCURLEG, P_SIVTYP, STAT) From TRTLECLEG

If STAT = 0
  Read [F:ANM]ANM0 = P_CONT
  If fstat = 0
    If [F:TSV]NUMDAYINV > 0 and [F:TSV]INVTYP <> 5 and [F:ANM]CTLCHR = 2
      If P_DATE > (date$ + [F:TSV]NUMDAYINV)
        Call MESSAGE (func AFNC.MES1(mess(75,7711,1),num$([F:TSV]NUMDAYINV))) From GESECRAN
        mkstat=2
      Endif
    Endif
  Endif
Endif
End
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END
######################################################################################
Subprog C_DPEDAT(VALEUR)
Variable Date    VALEUR

  # FGR 04/07/2014 : X3SUIVI91606
  If VALEUR <> [0/0/0] Then
    If [M:SIH0]INVTYP = 1 Then
      If VALEUR < [M:SIH0]INVDAT Then
        GMESSAGE = mess(402,192,1) - format$(GFMDAT, VALEUR) - "<" - format$(GFMDAT, [M:SIH0]INVDAT)
        mkstat = 2
        End
      Endif
    Elsif [M:SIH0]INVTYP = 2 Then
      If VALEUR > [M:SIH0]INVDAT Then
        GMESSAGE = mess(403,192,1) - format$(GFMDAT, VALEUR) - "<" - format$(GFMDAT, [M:SIH0]INVDAT)
        mkstat = 2
        End
      Endif
    Endif
  Endif
End

######################################################################################
Subprog AM_DPEDAT(VALEUR)
Variable Date    VALEUR

  # FGR 04/07/2014 : X3SUIVI91606
  If VALEUR <> [0/0/0] Then
    If [M:SIH1]ARVDAT = [0/0/0] or ([M:SIH1]ARVDAT <> [0/0/0] and (VALEUR > [M:SIH1]ARVDAT or [M:SIH1]DPEDAT = [M:SIH1]ARVDAT)) Then
      [M:SIH1]ARVDAT = VALEUR
      Affzo [M:SIH1]ARVDAT
    Endif
  Endif
End

######################################################################################
Subprog C_ARVDAT(VALEUR)
Variable Date    VALEUR

  # FGR 04/07/2014 : X3SUIVI91606
  If VALEUR <> [0/0/0] Then
    If [M:SIH1]DPEDAT <> [0/0/0] and VALEUR < [M:SIH1]DPEDAT Then
      GMESSAGE = mess(401,192,1) - format$(GFMDAT, [M:SIH1]DPEDAT) - ">" - format$(GFMDAT, VALEUR)
      mkstat = 2
      End
    Endif
  Endif
End

######################################################################################
Subprog C_SSTCOD(VALEUR)
Variable Char    VALEUR()
# 101380 WHen coming from Service Requests - grab the SSTCOD from the item
# no entry for SSTCOD on the source document in this case
# If GLOCUSATAX & [M:SIH1]SIHORI=8 & GREP="C" & GCREPARBOU=1 & VALEUR=""   # 106867.n
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2 & [M:SIH1]SIHORI=8 & GREP="C" & GCREPARBOU=1 & VALEUR=""  # 106867.n
  VALEUR=[F:ITM]SSTCOD
Endif
End

Subprog AV_SFISSTCOD(VALEUR)
Variable Char    VALEUR()
#101380 - Do not alow updating of SST code for certain cases.
#See SUBSFIT for setting of override flag.
If [M:SIH2]SFISSTOVRFLG(nolign-1)=1 : mkstat=2 : Endif
End
