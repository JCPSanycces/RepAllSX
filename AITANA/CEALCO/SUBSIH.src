#<AdxTL>@(#)7.0.0.0 $Revision$
Call OBJET ("SIH", GBIDC1, GBIDC2) From GOBJET
End
#########################################################################
# SUBSIH : Gestion des factures                                         #
#########################################################################
# Contient uniquement les actions sur les champs                        #
# Les actions appelées par l'objet sont dans SUBSIHA                    #
##########################################################################
#Issue 111617 - 20151019 by LD : Ecotaxe for credit note with value (Avoir en valeur)
# Issue X3-38450 - 20171030 by LD : Invalid sales invoice without currency rate
# Issue X3-63491 - 20171218 by LD : Wrong amount in sales invoice elements in amounts with a different currency
# Issue X3-58977 - 20171220 by LD : PCU on stock transaction from credit memo incorrect
# Issue X3-64430 - 20171227 by LD : Contrôle du cours multiplicateur

$ACTION
#--- Dem 78842
# Entry point reserved for ETO
GPOINT=ACTION
GPE=0
Gosub ENTREE From EXEFNC
If GPE=1 : Return : Endif
#---

Case ACTION
 When "AVANT_OUVRE"   : Gosub AVANT_OUVRE  From SUBSIHA1  # FGR 02/12/2011 : X3SUIVI7165 déplacement
 When "DEFTRANS"      : Gosub DEFTRANS     From SUBSIHA1  # FGR 02/12/2011 : X3SUIVI7165 déplacement
 When "VARIANTE"      : Gosub VARIANTE     From SUBSIHA1  # FGR 02/12/2011 : X3SUIVI7165 déplacement
 When "SETTRANS"      : Gosub SETTRANS     From SUBSIHA1  # FGR 02/12/2011 : X3SUIVI7165 déplacement
 When "OUVRE"         : Gosub OUVRE        From SUBSIHA1  # FGR 22/08/2014 : X3SUIVI85190 : déplacé plus de place dans le script
 When "OUVRE_BOITE"   : Gosub OUVRE_BOITE  From SUBSIHA1  # FGR 02/12/2011 : X3SUIVI7165 déplacement
 When "FERME"         : Gosub FERME        From SUBSIHA1  # FGR 02/12/2011 : X3SUIVI7165 déplacement
 When "FIN"           : Call  RAZSTOSORW   From STKSOR
 When "ABANDON"       : Gosub ABANDON      From SUBSIHA
 When "BOITE"         : Gosub BOITE        From SUBSIHA
 When "FILTRE"        : Gosub FILTRE       From SUBSIHA
 When "DEFLIG"        : Gosub DEFLIG       From SUBSIHA
 When "AFFMASK"       : Gosub AFFMASK      From SUBSIHA
 When "APRES_MODIF"   : Gosub APRES_MODIF  From SUBSIHA
 When "GRISE"         : Gosub GRISE        From SUBSIHA
 When "LIENS"         : Gosub LIENS        From SUBSIHA
 When "LIENS_LIG"     : Gosub LIENS_LIG    From SUBSIHA
 When "STYLE"         : Gosub STYLE        From SUBSIHA
 When "AVANT_CHOI"    : Gosub AVANT_CHOI   From SUBSIHA
 When "RAZCRE"        : Gosub RAZCRE       From SUBSIHA
 When "RAZDUP"        : Gosub RAZDUP       From SUBSIHA
 When "INICRE"        : Gosub INICRE       From SUBSIHA
 When "INICRE_LIG"    : Gosub INICRE_LIG   From SUBSIHA
 When "INIMOD"        : Gosub INIMOD       From SUBSIHA
 When "INIMOD_LIG"    : Gosub INIMOD_LIG   From SUBSIHA
 When "VALLIG"        : Gosub VALLIG       From SUBSIHA
 When "VERIF_CRE"     : Gosub VERIF_CRE    From SUBSIHA
 When "CREATION"      : Gosub CREATION     From SUBSIHA
 When "APRES_CRE"     : Gosub APRES_CRE    From SUBSIHA
 When "AB_CREATION"   : Gosub AB_CRE_MOD   From SUBSIHA1
 When "AVANT_MOD"     : Gosub AVANT_MOD    From SUBSIHA
 When "AVANT_MODFIC"  : Gosub AVANT_MODFIC From SUBSIHA
 When "VERIF_MOD"     : Gosub VERIF_MOD    From SUBSIHA
 When "VERF_ANU"      : Gosub VERF_ANU     From SUBSIHA1
 When "ANNULE"        : Gosub ANNULE       From SUBSIHA1
 When "AP_ANNULE"     : Gosub AP_ANNULE    From SUBSIHA1   # 117130.n
 When "MODIF"         : Gosub MODIF        From SUBSIHA
 When "APRES_MOD"     : Gosub APRES_MOD    From SUBSIHA
 When "AB_MODIF"      : Gosub AB_CRE_MOD   From SUBSIHA1
 When "SETBOUT"       : Gosub SETBOUT      From SUBSIHA
 When "AVANTBOUT"     : Gosub AVANTBOUT    From SUBSIHA
 When "EXEBOUT"       : Gosub EXEBOUT      From SUBSIHA
 When "STATUT"        : Gosub STATUT       From SUBSIHA1
 When "AV_IMPRIME"    : Gosub AV_IMPRIME   From SUBSIHA
 When "AP_IMPRIME"    : Gosub AP_IMPRIME   From SUBSIHA
 When "REMP_DERLU"    : Gosub REMP_DERLU   From SUBSIHC
 When "FILGAUCHE"     : Gosub FILGAUCHE    From SUBSIHC
 When "AP_FILGAUCHE"  : Gosub AP_FILGAUCHE From SUBSIHC
 When "HINT"          : Gosub HINT_KEY     From SUBSIHC
# When "TIROIR"        : Gosub TIROIR       From SUBSIHC
 When "DEB_PICK"      : Gosub DEB_PICK     From SUBSIHC
 When "PICKE"         : Gosub PICKE        From SUBSIHC
 When "DEPICK"        : Gosub DEPICK       From SUBSIHC
 When "FIN_PICK"      : Gosub FIN_PICK     From SUBSIHC
 #MAE, bg 77405
 When "VERROU"        : Gosub VERROU_HAE   From SUBSIHA
 When "DEVERROU"      : Gosub DEVERROU_HAE From SUBSIHA
 When "AVANT_SUITE"   : Gosub AVANT_SUITE  From SUBSIHA  : # 79705 : V7 : SAT in SPRICLINK
 When Default
Endcase

#########################################################################
#    Débranchements d'actions                                           #
#########################################################################
Case ACTION
 When "TRT_DIV"       : Gosub TRT_DIV
 When "AAPRES_NBLIG"  : Gosub AAPRES_NBLIG
 When "AB4_NBLIG"     : Gosub AB4_NBLIG
 When "AB1_SIHORINUM" : Gosub AB1_SIHORINUM
 When "BB1_SIHORINUM" : Gosub BB1_SIHORINUM  # 107888 : Scheduled invoices : (LD:23/05/16)
 When "AB8_NBLIG"     : Gosub AB8_NBLIG
 When "BB8_NBLIG"     : Gosub BB8_NBLIG
 When "AB11_NBLIG"    : Gosub AB11_NBLIG
 When "BB11_NBLIG"    : Gosub BB11_NBLIG     # Issue 107888 - 2015-09-28 by CPO : Scheduled invoices (New component) SIHORI=10 Schedule invoice
 When "AB2_BPCINV"    : Gosub AB2_BPCINV     # FGR 10/11/2009 : X3SUIVI57700
 When "BB2_BPCINV"    : Gosub BB2_BPCINV     # FGR 10/11/2009 : X3SUIVI57700
 When "AB2_BPRPAY"    : Gosub AB2_BPRPAY     # FGR 10/11/2009 : X3SUIVI57700
 When "BB2_BPRPAY"    : Gosub BB2_BPRPAY     # FGR 10/11/2009 : X3SUIVI57700
 When "AB2_BPAADD"    : Gosub AB2_BPAADD     # FGR 10/11/2009 : X3SUIVI57700
 When "BB2_BPAADD"    : Gosub BB2_BPAADD     # FGR 10/11/2009 : X3SUIVI57700
 When Default
Endcase

Return
#########################################################################
# FGR 10/11/2009 : X3SUIVI57700 (début)
#######################################
$AB2_BPCINV
Local Integer IMODCHAMP

  IMODCHAMP = varmode([M:SIH0]BPCINV)
  If IMODCHAMP = 1 or IMODCHAMP = 2 Then
    Actzo [M:SIH0]BPCINV
  Endif
Return

#######################################
$BB2_BPCINV
  If IMODCHAMP = 1 Then
    Grizo [M:SIH0]BPCINV
  Elsif IMODCHAMP = 2 Then
    Diszo [M:SIH0]BPCINV
  Endif
Return

#######################################
$AB2_BPRPAY
Local Integer IMODCHAMP

  IMODCHAMP = varmode([M:SIH1]BPRPAY)
  If IMODCHAMP = 1 or IMODCHAMP = 2 Then
    Actzo [M:SIH1]BPRPAY
  Endif
Return

#######################################
$BB2_BPRPAY
  If IMODCHAMP = 1 Then
    Grizo [M:SIH1]BPRPAY
  Elsif IMODCHAMP = 2 Then
    Diszo [M:SIH1]BPRPAY
  Endif
Return

#######################################
$AB2_BPAADD
Local Integer IMODCHAMP
Local  Integer  SAV_GCONSULT : SAV_GCONSULT=GCONSULT    : # 79705 : V7 : SAT in SPRICLINK
Local  Integer  SAV_GCONSDIA : SAV_GCONSDIA=GCONSDIA    : # 79705 : V7 : SAT in SPRICLINK

  IMODCHAMP = varmode([M:SIH1]BPAADD)
  If IMODCHAMP = 1 or IMODCHAMP = 2 Then
    Actzo [M:SIH1]BPAADD
    # 79705 : V7 : SAT in SPRICLINK
    # Chp non modifiable et on est pas encore rentré en modif :
    # l'adresse ne doit pas être modifiable car cela n'activera pas le bouton enr
    If GREP="" GCONSULT=1 : GCONSDIA=2 Endif
  Endif

Return

#######################################
$BB2_BPAADD
  If IMODCHAMP = 1 Then
    Grizo [M:SIH1]BPAADD
  Elsif IMODCHAMP = 2 Then
    Diszo [M:SIH1]BPAADD
  Endif

GCONSULT=SAV_GCONSULT : # 79705 : V7 : SAT in SPRICLINK
GCONSDIA=SAV_GCONSDIA : # 79705 : V7 : SAT in SPRICLINK
Return
# FGR 10/11/2009 : X3SUIVI57700 (fin)
#########################################################################

#########################################################################
#    Actions liés au type traitement et affichage divers                #
#########################################################################
$TRT_DIV
Case TRAIT
    When "P2NBLIG"    : Gosub P2_NBLIG
Endcase
Return
#########################################################################
#                     ECRAN ENTETE : SIH0                               #
#########################################################################
########################################
# ---------------------- SIVTYP : Type facture utilisateur ------------------------
######################################################################################
## Etiquette ajoutée par le superviseur (écran SIH0) 21/10/2008 17:06:56 (LD)
######################################################################################
Subprog AS_SIVTYP(VALEUR)
Variable Char    VALEUR()
If VALEUR=""
    Local Char WSIVTYP(GLONTSV)
    Gosub INIT_SIVTYP From SUBSIHB
    If GERR=1 End : Endif
    VALEUR=WSIVTYP
Endif
End
#---------------------------------------
Subprog C_SIVTYP(VALEUR)
Variable Char    VALEUR()
# La facture doit être autorisée par transaction
If GFACTYP=1 & [F:TSV]INVTYP <> 1 | GFACTYP=2 & [F:TSV]INVTYP <> 2 |
&  GFACTYP=3 & [F:TSV]INVTYP <> 5 | GFACTYP=4 & !find([F:TSV]INVTYP,1,5)
    GMESSAGE=mess(173,192,1) : mkstat = 2 : End
Endif

#-------- CPO 68872 Vérification du rôle en saisie
#Réponse mail MB : le contrôle doit être géré
Call CONT_ROLE(VALEUR,"TSV","SIVTYP") From SUBARL
#--------

If func AFNC.ACTIV("KPO")>0
  If func PORLEGLIB.CTLDOCTYP(VALEUR,"SIV",GMESSAGE) = 1
    mkstat = 2 : End
  Endif
Endif

End
#---------------------------------------
Subprog AM_SIVTYP(VALEUR)
Variable Char    VALEUR()

Local Libelle WINVTYP : WINVTYP=[M:SIH0]INVTYP   : # 87923 : Gestion des prélèvements SDD

# Pour l'instant on ne créé que des factures/ proforma directes
[M]SIHORI = 1

If !clalev([F:TCA])  Local File TABCOUAFF  [TCA] Endif
Local Integer WRET
Call LECTCA(5,WRET) From SUBTCA
If fstat | !WRET
    GERR=1 : GMESSAGE=mess(58,105,1)-mess(5,14,1)-mess(250,199,1) : End
Endif

# Alimentation des champs liés au type de facture
# --> Alimentation catégorie facture, type pièce, code journal
# --> Alimentation infos compteur
# --> Si type pièce renseigné : Contrôle et récup infos compteur
Gosub CHARG_SIVTYP From SUBSIHB
If GERR=1 : mkstat=2 : End : Endif

## Alimentation catégorie facture, type pièce, code journal
#[M]INVTYP = [F:TSV]INVTYP
#[M]GTE    = [F:TSV]GTE
#[M]JOU    = [F:TSV]JOU
#[M]COD    = [F:TSV]COD

#Case [M]INVTYP
# When 1    : # Facture
#     GMANCOU = [F:TCA]MANCOU(3) : GCPT = [F:TCA]CODNUM(3)
# When 2    : # Avoir
#     GMANCOU = [F:TCA]MANCOU(4) : GCPT = [F:TCA]CODNUM(4)
# When 5    : # Proforma
#     GMANCOU = [F:TCA]MANCOU(5) : GCPT = [F:TCA]CODNUM(5)
#Endcase

#If [M]INVTYP <> 5 & [M]GTE <> ""
#   # Lecture type pièce
#   If [F:GTE]TYP <> [M]GTE
#      Read [GTE]GTE0=[M]GTE : If fstat Raz [F:GTE] : Endif
#   Endif
#   # Type de pièce inexistant
#   If [F:GTE]TYP=""
#      GERR=1 : GMESSAGE = [M]GTE-mess(17,114,1)  : mkstat=1 : End
#   Endif
#   # Type de pièce inactive
#   If [F:GTE]ENAFLG<>2
#      GERR=1 : GMESSAGE = [M]GTE-mess(274,199,1) : mkstat=1 : End
#   Endif
#   # Type de pièce non réel
#   If [F:GTE]VCRREA<>2
#      GERR=1 : GMESSAGE = [M]GTE-mess(59,119,1) : mkstat=1 : End
#   Endif
#   # Vous n'avez pas les droits d'exécution
#   If [F:GTE]ACS<>""
#      Call CONTEXE([F:GTE]ACS) From CPTSUB
#      If mkstat GERR=1:GMESSAGE=[F:GTE]ACS-GMESSAGE : End : Endif
#   Endif
#   # Récupération des infos compteur à partir du type de pièce
#   If [F:GTE]COU<>""
#      GMANCOU=[F:GTE]MANNUM : GCPT=[F:GTE]COU
#   Endif
#Endif
#If GUSER="ADMIN" : Dbgaff : Endif
If [M]BPCINV<>""
   #--- Lecture Client facture
   Read [BPC]BPC0=[M]BPCINV
   If !fstat
      # Alimentation à partir du modèle d'édition
      If [M]INVTYP=2
         Call ALI_PRTMOD("SIH0",6) From TRTX3
         If [M:SIH0]COPNBE=0 [M:SIH0]COPNBE=1 Endif
      Else
         Call ALI_PRTMOD("SIH0",5) From TRTX3
         If [M:SIH0]COPNBR=0 [M:SIH0]COPNBR=1 Endif
      Endif
   Endif
Endif

If [M]INVTYP=2
   Actzo [M:SIH1]CNOREN
Else
   Grizo [M:SIH1]CNOREN
Endif
If GREP="C" & GMANCOU=1
    Diszo [M:SIH0]NUM
Else
    Actzo [M:SIH0]NUM
Endif

#Localisation Belge --str
If func AFNC.ACTIV("KBE") Then
  If GIMPORT
    If find([M:SIH0]INVTYP,2,4,5) : Raz [F:SIH]BELVCS : Endif
  Endif
  If [M:SIH0]INVTYP=5
    Call DISPLAY_VCS("SIH1","",3,-1)  From INVVCSLIB  :#-- hide VCS field for proforma
  Else
    Call DISPLAY_VCS("SIH1","",3,0)  From INVVCSLIB
  Endif
Endif
#Localisation Belge --end

# 87923 : Gestion des prélèvements SDD
If func AFNC.ACTIV("SDD")
    # On est passé d'une proforma à une facture ou un avoir ou inversement
    If WINVTYP<>[M:SIH0]INVTYP
        If GSDDMGT=2 & find([M:SIH0]INVTYP, 1,2)
            [M:SIH2]SDDFLG=func TRTVENSDD.IS_PTE_SDD([M:SIH2]PTE,GSOCIETE)
        Else
            [M:SIH2]SDDFLG=1
        Endif
        If [M:SIH2]SDDFLG=1 & [M:SIH2]UMRNUM<>"" Raz [M:SIH2]UMRNUM Endif
        If [M:SIH2]SDDFLG=2 & [M:SIH2]UMRNUM=""
            Call INIT_UMRNUM(GSOCIETE,[M:SIH1]BPRPAY,2,2,[M:SIH2]UMRNUM) From INVSDDLIB
        Endif
        Call DISPLAY_UMRNUM ([F:TSV]INVTYP) From TRTVENSDD
        Gosub GRIZO_UMRNUM From TRTVENSDD
    Endif
Endif
# 87923

#RMA * 85785
If dim([M:SIH0]ORIDOCNUM) > 0
  Call SHOW_HIDE_ORIDOCNUM([M:SIH0]SALFCY,VALEUR,"SIH0") From PORLEGLIB
Endif

#97101 RICAR 2014/07/03 - 50001 Law decret - BEGIN
If func AFNC.ACTIV("KPO")
  Call SHOW_HIDE_PERDEB_PERFIN([M:SIH0]SALFCY,VALEUR,"SIH1") From PORLEGLIB
  Call FLD4041DIS([M:SIH1]VACBPR,VALEUR)
Endif
#97101 RICAR 2014/07/03 - 50001 Law decret - END

# --------------------------------------
# FGR 02/04/2015 : X3SUIVI105605 (début)
If dim([M:SIH4]ECCVALMAJ) >= 0 Then
  If [M:SIH0]INVTYP <> 5 and [M:SIH0]INVTYP <> 2 Then
    Chgfmt [M:SIH4]ECCVALMAJ  With "K:" + num$(type([M:SIH4]ECCVALMAJ)-10) + "X"
    Chgfmt [M:SIH4]ECCVALMIN  With "K:" + num$(type([M:SIH4]ECCVALMIN)-10) + "X"
  Else
    Chgfmt [M:SIH4]ECCVALMAJ  With "-K:" + num$(type([M:SIH4]ECCVALMAJ)-10) + "X"
    Chgfmt [M:SIH4]ECCVALMIN  With "-K:" + num$(type([M:SIH4]ECCVALMIN)-10) + "X"
  Endif
Endif
# FGR 02/04/2015 : X3SUIVI105605 (fin)
# --------------------------------------

# SAM 110033: Swiss localization: hide / display fields BVRNUMREF / PAYBAN
If func AFNC.ACTIV("KSW") Then
  Call SHOW_HIDE_BVRFIELDS([M:SIH0]SALFCY, [M:SIH0]INVTYP, [M:SIH2]PTE, [M:SIH2]CUR) From SUBSIHSWI
Endif
# SAM 110033 END

End

########################################
# ---------------------- SALFCY : site vente ------------------------
Subprog C_SALFCY(VALEUR)
Variable Char    VALEUR()
Local    Char    WLEGCPY
# Si le site de stockage est déjà renseigné revérifier la société juridique
If [M:SIH1]STOFCY<>"" & [M:SIH1]STOFCY <> VALEUR
    If [F:FCY]FCY <> VALEUR
        Read [FCY]FCY0=VALEUR
    Endif
#   Nouvelle société juridique
    WLEGCPY=[F:FCY]LEGCPY
    Read [FCY]FCY0=[M:SIH1]STOFCY
    If [F:FCY]LEGCPY <> WLEGCPY
        Raz [M:SIH1]STOFCY
        Affzo [M:SIH1]STOFCY
    Endif
Endif
End
#---------------------------------------
Subprog AM_SALFCY(VALEUR)
Variable Char    VALEUR()
Local    Char    PARAM(10)
## Alimentation du paramètre tronc commun : Suppression factures non validées
#Global Libelle GSIVSUP
#Call PARAM(GFCY,"SIVSUP",PARAM) From ADOVAL
#GSIVSUP = val(PARAM)

# Chargement des globales référenciels, comptes et sections de la société
If !clalev([F:TCA])  Local File TABCOUAFF  [TCA] Endif
GFCY=VALEUR : Gosub CHARG_PARAM From SUBSIHA : If GERR=1 mkstat=2 : End Endif

If !clalev([F:TSV]) : Local File TABSIVTYP [TSV] : Endif
If [M:SIH0]SIVTYP<>""
    If [F:TSV]SIVTYP<>[M:SIH0]SIVTYP
        #- X3Suivi 71937 Multi-législation -#
        #Read [TSV] TSV0=[M:SIH0]SIVTYP
        Local Integer WRET
        Call LEC_TSV_LEG(GCURLEG,[M:SIH0]SIVTYP,WRET) From TRTLECLEG
        If WRET Raz [F:TSV] Endif
    Endif
Endif
If [M:SIH0]SIVTYP="" | ([F:TSV]LEG<>GCURLEG & [F:TSV]LEG<>"")
    # Si type facture non renseigné ou si législation différente : On initialise le type de facture
    If GREP="" or (GREP="C" and [M]SALFCY<>"") #X3-58117 (JUCON 15/11/17)
        [M]INVTYP=GFACTYP
        If GFACTYP=3         : [M]INVTYP=5 : Endif
        If find(GFACTYP,4,5) : [M]INVTYP=1 : Endif
    Endif

    Local Char WSIVTYP(GLONTSV)
    # Alimentation des champs liés au type de facture
    # --> Alimentation catégorie facture, type pièce, code journal
    # --> Alimentation infos compteur
    # --> Si type pièce renseigné : Contrôle et récup infos compteur
    Gosub INIT_SIVTYP From SUBSIHB
    If GERR=1 mkstat=2 : End : Endif
    [M:SIH0]SIVTYP=WSIVTYP
    If GREP="C" & GMANCOU=1
        Diszo [M:SIH0]NUM
    Else
        Actzo [M:SIH0]NUM
    Endif
Endif

If [M:SIH0]BPCINV <> ""
#   Alimentation flag inter-site et inter-société
    Call ALIBETCPY(5,VALEUR,[M:SIH0]BPCINV,GBIDC1,GBIDC2,GBIDC3,[M:SIH1]BETFCY,[M:SIH1]BETCPY) From TRTVENISOC
    If [M:SIH1]BETFCY=2
        # 92731 : Création de facture inter-site
        # Point d'entrée permettant la création de factures inter-site
        Local Integer WPE_CRESIHBETFCY : Raz WPE_CRESIHBETFCY
        GPOINT ="CRESIHBETFCY" : Gosub ENTREE From EXEFNC
        # Facture inter-site
        #If [M:SIH1]BETCPY=1
        If [M:SIH1]BETCPY=1 & WPE_CRESIHBETFCY=0
        # 92731
            # On refuse une facture intra-société
            Call ERREUR (mess(319,192,1)) From GESECRAN : mkstat=2 : End
        Endif
        Raz WPE_CRESIHBETFCY : # 92731
        # Le client commande est aussi le fsseur (correspond au site de vente)
        If [M:SIH0]BPCINV=GBIDC3
            Local Integer WOK : WOK=1
            Call AVERTIR (mess(151,191,1), WOK)From GESECRAN
            If WOK=1 mkstat=2 : End : Endif
        Endif
        If [M]SIHORI=9
           [M:SIH1]STOMVTFLG=2
        Else
           # Une facture directe inter-site doit tjs être sans mvt de stock (pas de reception de factures)
           [M:SIH1]STOMVTFLG=1
        Endif
        Diszo [M:SIH1]STOMVTFLG
        Grizo [M:SIH1]STOFCY, TRSFAM
        If dim([M:SIH1]WRHE)>0 Grizo [M:SIH1]WRHE Endif
        If [M:SIH0]INVTYP=2 & dim ([M:SIH1]SRGLOCDEF)>0 Grizo [M:SIH1]SRGLOCDEF Endif
    Else
        Actzo [M:SIH1]STOMVTFLG
    Endif
    Affzo [M:SIH1]BETFCY
    Affzo [M:SIH1]BETCPY
Endif
# Affichage entêtes de colonne variables
If clalev([F:CPY])=0 : Local File COMPANY [CPY] : Endif
If [F:CPY]CPY<>GSOCIETE
    Read [CPY] CPY0=GSOCIETE
    If fstat Raz [F:CPY] Endif
Endif
If [F:CPY]PLISTC=[M:SIH0]PLISTC : # Seulement si la structure n'a pas changé, si elle a changé, ce sera fait dsn ALICOLREM
    Gosub AFF_TITCOL From SUBSIHA
Endif
#If GACTMUL=2
# Alimentation concernant les colonnes frais/remises en fonction de la structure tarif de la société
Local Char WSVG_PLISTC : WSVG_PLISTC=[M:SIH0]PLISTC
Call ALICOLREM (1,5,GFLAG,"SIH4", [M:SIH2]CUR, 1,[M:SIH0]PLISTC) From TRTPRICE
# Affichage entêtes colonnes variables (sections analytiques) en cas de changement de société
If WSVG_PLISTC=GPLISTC
    # (A faire ssi la structure tarif n'a pas changé, sinon cela a déjà été fait dans ALICOLREM)
    Gosub AFF_TITCOL From SUBSIHA
Else
  # Affzo nécessaire si sections invisibles pour faire disparaitre les colonnes
  If [M:SIH4]NBLIG=0
      [M:SIH4]NBLIG=1 : Affzo [SIH4]5 : Effzo [SIH4]5
  Endif
Endif
# Rechargement si nécessaire des elements de pied de la facture
Call CHARG_SIHX From TRTVENFACC
#Endif
#----- Chargement du cours devise et du cours reporting -----#
If [M:SIH2]CUR<>""
  Call INI_COURS("SIH2",GSOCIETE,[M:SIH2]CUR,[M:SIH0]INVDAT,[M:SIH2]CURTYP) From SUBBICS
  Affzo [M:SIH2]RAT1, LABEL, RAT2, CURMLT
Endif

# Effacement tableau des sections entête si changement société
If dim([M:SIH2]NBAXE)>0 & [M:SIH2]NBAXE>0
  [M:SIH0]SALFCY=VALEUR
  Effzo [SIH2]20 : Affzo [SIH2]20
Endif

If GUPDCUR=1
    Diszo [M:SIH2]CUR
    Diszo [M:SIH2]CURTYP
Else
    Actzo [M:SIH2]CUR
    If [M:SIH2]CUR <> GLOCALDEV Actzo [M:SIH2]CURTYP Endif
Endif

If GNOTATI=1
    Diszo [M:SIH1]PRITYP
Else
    Actzo [M:SIH1]PRITYP
Endif

If GLINREP=1
    If dim([M:SIH4]REP1) > 0 Diszo [M:SIH4]REP1, REPRAT1 Endif
    If dim([M:SIH4]REP2) > 0 Diszo [M:SIH4]REP2, REPRAT2 Endif
Else
    If dim([M:SIH4]REP1) > 0 Actzo [M:SIH4]REP1, REPRAT1 Endif
    If dim([M:SIH4]REP2) > 0 Actzo [M:SIH4]REP2, REPRAT2 Endif
Endif

Gosub SHOW_HIDE_ENTCOD From TRTADRLIB   #LTA.n

Call SETUP_SSTFIELDS From SUBSIHA       # 101380.n

Affzo [M:SIH4]5 : # Affichage tableau des lignes (Pr champs dépendants d'un paramètre soc/site ex:Période prestation)
#------------------------------------------------------------#
# Renseignement des unités de répartition                    #
#------------------------------------------------------------#
[M:SIH0]DSPWEU = GSALDSPWEU
[M:SIH0]DSPVOU = GSALDSPVOU

# JPGA : Traitement des exceptions Société : MAJ des informations au cas ou on changerait de Société
If [M:SIH0]BPCINV <> ""
    If dim([M:SIH1]VACBPR) > 0
        #Gbn-79727-Ajouter alim à partir du client livré
        # JPGA : Initialisation du Régime taxe
        If [F:BPD]VACBPR<>""
             # Alimentation régime de taxe à partir du client livré
             If [F:BPD]VACBPR<>[M:SIH1]VACBPR
                 [M:SIH1]VACBPR = [F:BPD]VACBPR
             Endif
        Else
            Call INIT_REGIME([M:SIH0]BPCINV, GSOCIETE, "C", [M:SIH1]VACBPR) From CPTSUB
        Endif
        Affzo [M:SIH1]VACBPR
    Endif
    If dim([M:SIH2]PTE) > 0
        # JPGA : Initialisation du code condition de paiement
        #Call INIPTE ([F:BPC]BPCPYR, [F:BPC]BPCINV, "C", [M:SIH2]PTE) From TRTX3      : # 87923
        Call INIPTE ([M:SIH1]BPRPAY, [M:SIH0]BPCINV, "C", [M:SIH2]PTE) From TRTX3     : # 87923
        Affzo [M:SIH2]PTE
        # 87923 : Gestion des prélèvements SDD
        If dim([M:SIH2]UMRNUM)>0
            If GSDDMGT=2 & find([M:SIH0]INVTYP, 1,2)
                [M:SIH2]SDDFLG=func TRTVENSDD.IS_PTE_SDD([M:SIH2]PTE,GSOCIETE)
            Else
                [M:SIH2]SDDFLG=1
            Endif
            If [M:SIH2]SDDFLG=1
                Raz [M:SIH2]UMRNUM
            Elsif [M:SIH2]UMRNUM <> ""
                # Si mandat renseigné, raz s'il n'est plus cohérent (si changement de société)
                Call CTL_UMRNUM([M:SIH2]UMRNUM,GSOCIETE,[M:SIH1]BPRPAY) From INVSDDLIB
                If mkstat=2 Raz mkstat : Raz [M:SIH2]UMRNUM Endif
            Endif
            If [M:SIH2]SDDFLG=2 & [M:SIH2]UMRNUM=""
                Call INIT_UMRNUM(GSOCIETE,[M:SIH1]BPRPAY,2,2,[M:SIH2]UMRNUM) From INVSDDLIB
            Endif
            Gosub GRIZO_UMRNUM From TRTVENSDD
        Endif
        # 87923
    Endif
    If dim([M:SIH2]DEP) > 0
        # JPGA : Initialisation des escomptes et agios
        Call INIT_ESCOMPTE([M:SIH0]BPCINV, GSOCIETE, "C", [M:SIH2]DEP) From CPTSUB

        # 102423 : Belgium Early discounts
        # Early discount rate determination
        If find(GDEPMGTMOD, 1,5)
            Call ALIDISVAT (5, [M:SIH2]DEP, GBIDI1,[M:SIH2]DEPRAT) From SUBTDA
        Endif
        #  102423

        Affzo [M:SIH2]DEP
    Endif
Endif

# On recharge la liste des éléments de facturation, pour gérer le flag "remise sur taxe"
Local Integer NBPOSTE : NBPOSTE=dim([M:SIH2]INVDTA)
Call SAISFOOT (8,"SIH2",NBPOSTE,[F:SIH]CURTYP,[F:BPC]CUR,
&              [F:SIH]CUR,"NON") From SUBSFIT
[M:SIH2]NBFAC = NBPOSTE
Affzo [M:SIH2]25

#Localisation Belge --str
If func AFNC.ACTIV("KBE") Then
  If [M:SIH0]INVTYP=5
    Call DISPLAY_VCS("SIH1","",3,-1)  From INVVCSLIB  :#-- hide VCS field for proforma
  Else
    Call DISPLAY_VCS("SIH1","",3,0)  From INVVCSLIB
  Endif
Endif
#Localisation Belge --end

#RMA * 85785
If dim([M:SIH0]ORIDOCNUM) > 0
  Call SHOW_HIDE_ORIDOCNUM(VALEUR,[M:SIH0]SIVTYP,"SIH0") From PORLEGLIB
Endif

#97101 RICAR 2014/07/03 - 50001 Law decret - BEGIN
If func AFNC.ACTIV("KPO")
  Call SHOW_HIDE_PERDEB_PERFIN(VALEUR,[M:SIH0]SIVTYP,"SIH1") From PORLEGLIB
  Call FLD4041DIS([M:SIH1]VACBPR,[M:SIH0]SIVTYP)
Endif
#97101 RICAR 2014/07/03 - 50001 Law decret - END

# SAM 110033: Swiss localization: hide / display fields BVRNUMREF / PAYBAN
If func AFNC.ACTIV("KSW") Then
  Call SHOW_HIDE_BVRFIELDS(VALEUR, [M:SIH0]INVTYP, [M:SIH2]PTE, [M:SIH2]CUR) From SUBSIHSWI
Endif
# SAM 110033 END

End

######################################## INVDAT : date facture
# ---------------------- INVDAT : date facture ------------------------
Subprog C_INVDAT(VALEUR)
Variable Date    VALEUR
Local Decimal    EXERCICE , PERIODE
# --> Pas de controle pour les proforma
# La date de l'avoir n'est pas répercutée sur les mvts de stock
If [M:SIH0]INVTYP = 5 End : Endif
#If GMODU(2) = 2    : # Présence du module compta
    If clalev([F:PER])=0 : Local File PERIOD [PER] : Endif
    Call GETPERSOC(GSOCIETE,GTYPGEN,VALEUR,EXERCICE,PERIODE) From CPTSUB
    If EXERCICE=0 | PERIODE=0
      GMESSAGE = mess(1,104,1) : # MSG=Date incorrecte
      mkstat = 2 : End
    Endif
    If clalev([F:FIY])=0 : Local File FISCALYEAR [FIY] : Endif
    Read [FIY]FIY0 = GSOCIETE;GTYPGEN;EXERCICE
    If fstat | [F:FIY]FIYSTA<>2
      GMESSAGE = mess(20,101,1) : # MSG=Exercice non ouvert
      mkstat = 2 : End
    Endif
    If [F:PER]PERSTA<2
      GMESSAGE = mess(35,101,1) : # MSG=Periode non ouverte
      mkstat = 2 : End
    Endif
    If [F:PER]PERSTA>2
      GMESSAGE = mess(36,101,1) : # MSG=Période fermee
      mkstat = 2 : End
    Endif
#Endif
# 71937 : Multilégislation
Local Integer WRET
Call LEC_GTE_LEG(GCURLEG,[M]GTE,WRET) From TRTLECLEG
If WRET Raz [F:GTE] Endif
# 71937
Call CTLVLYDAT(VALEUR,[F:GTE]VLYSTR,[F:GTE]VLYEND) From CPTSUB
If mkstat : GMESSAGE = [F:GTE]TYP-GMESSAGE : Endif

# V6.2 : Certification
#----- Contrôle date pour certification NF -----#
# Bug 68075
If find(GREP,"C","D")
  # Création, Duppli facture : L'ancienne valeur est à [0/0/0] et il n'y a pas de n° de document
  Call CTLDAT_CNF(5,[M]SALFCY,[0/0/0],VALEUR,"","") From CONTX3
  If mkstat  End : Endif
Elsif VALEUR<>[M:SIH0]INVDAT
  # Modif facture
  Call CTLDAT_CNF(5,[M]SALFCY,[M:SIH0]INVDAT,VALEUR,GCPT,[M:SIH0]NUM) From CONTX3
Endif
# Bug 68075
# --- si presence de la date d'application taxe                           bug 15093
If dim([M:SIH2]VATDAT)>0
    # Bug 70183 et Dde 51781 : Init. de la date d'application de la taxe sur une facture de livraison
    # Ssi la date d'application est saisissable dans l'écran facture

    # Si Avoir ou facture de livraison et le champ date d'application taxe est saisissable
    If [M]INVTYP=2 | ([M]SIHORI=3 & varmode([M:SIH2]VATDAT)= 0)
        [M:SIH2]VATDAT=VALEUR                                         : # bug 15093
    Endif
Endif

#85803 RICAR 2014/05/20 - Portuguese legal requirements - BEGIN
Call VAL_INVDAT([M:SIH0]SIVTYP,VALEUR,GCPT)
#85803 RICAR 2014/05/20 - Portuguese legal requirements - END

End
#---------------------------------------
Subprog AM_INVDAT(VALEUR)
Variable Date    VALEUR
# V6.2 : Certification
If [M:SIH0]INVTYP <> 5
# Bug 68075
#    # Controle date pour certification NF
#    If !find(GREP,"C","D")
#      Call CTLDAT_CNF(5,[M]SALFCY,[M:SIH0]INVDAT,VALEUR,GCPT,[M:SIH0]NUM) From CONTX3
#      If mkstat Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE : End : Endif
#    Endif
# Bug 68075
    # Si ctrl date documents et des lignes existent, contrôle date des documents d'origine
    If GCTLDATORI=2 & [M:SIH1]SIHORI>1 & [M:SIH4]NBLIG>0
      Call CTLDAT_ORI(VALEUR)
      If mkstat Call ERREUR(GMESSAGE) From GESECRAN : Raz GMESSAGE : End : Endif
    Endif
Endif

If GREP = "M" | GREP = ""
  If [M:SIH1]STOMVTFLG = 2
    If [M:SIH0]INVTYP = 2
       Call MESSAGE(mess(340,192,1)) From GESECRAN
    Endif
  Endif
Endif
# Par défaut Origine échéance = date facture
Local    Shortint WDUDCLC : WDUDCLC=1
# Si Facture ou Proforma sur une livraison : récup origine échéance du client
If find([M:SIH0]INVTYP, 1,5) & [M:SIH1]SIHORI=3
    If !clalev ([F:BPC]) : Local File BPCUSTOMER [BPC] : Endif
    If [F:BPC]BPCNUM <> [M:SIH0]BPCINV
        Read [BPC]BPC0 = [M:SIH0]BPCINV
        If fstat Raz [F:BPC] : Endif
    Endif
    WDUDCLC=[F:BPC]DUDCLC
Endif
# Si origine échéance=date facture, réinitialisation de la date début d'échéance
If WDUDCLC = 1
    [M:SIH2]STRDUDDAT = VALEUR
    Affzo [M:SIH2]STRDUDDAT
Endif
#-----
If [M:SIH2]CUR<>"" & (find([M:SIH0]INVTYP, 1,5) | ([M:SIH0]INVTYP=2 & [M:SIH1]SIHORI<>4))
#  [M:SIH0]INVDAT=VALEUR
    Call INI_COURS("SIH2",GSOCIETE,[M:SIH2]CUR,VALEUR,[M:SIH2]CURTYP) From SUBBICS
    Affzo [M:SIH2]RAT1, LABEL, RAT2, CURMLT
Endif

If [M:SIH4]NBLIG<>0 & !(dim(G_SIH_CAL)>0 & G_SIH_CAL<>"C") : # bug 15093
    Gosub CHARG_TABLEAUX From TRTVENFACC
    Gosub CAL_FACTURE From SUBSIHC
    [M:SIH0]INVCLCFLG=1
    [M:SIH4]INVNOT = [M:SIHV]INVNOT
    [M:SIH4]INVATI = [M:SIHV]INVATI
    Affzo [M:SIHV]1-99
    Affzo [M:SIH4]15
Endif
End

########################################
# ---------------------- BPCINV : client facture ------------------------

Subprog AP_BPCINV(VALEUR)
Variable Char    VALEUR()
# --> Alimentation de la raison sociale
If [M:ADB3]BPRNAM(0) <> ""
    [M]BPINAM = [M:ADB3]BPRNAM(0)
Else
    [M]BPINAM = [F:BPC]BPCNAM
Endif
If [M:SIH1]BPCORD = VALEUR
    [M:SIH1]BPCNAM = [M:SIH0]BPINAM
    Affzo [M:SIH1]BPCNAM
Endif
Affzo [M:SIH0]BPINAM
End

#---------------------------------------
Subprog AM_BPCINV(VALEUR)
Variable Char    VALEUR()
If GUSER="ADMIN" : Dbgaff : Endif
# --> Si Utilisation du bouton adresse, il ne faut pas passer en AM_
If dim(GWIMPMOD)<1 | GWIMPMOD=0
   #MAE If !GIMPORT & VALEUR = [M]BPCINV End : Endif
   If !GIMPORT & VALEUR = [M]BPCINV & GCREFONC = 0 End : Endif
Endif

If [M:SIH0]SALFCY <> ""
    Local Char WVALEUR : WVALEUR=VALEUR
#   Alimentation flag inter-site et inter-société
    Call ALIBETCPY(5,[M:SIH0]SALFCY,WVALEUR,GBIDC1,GBIDC2,GBIDC3,[M:SIH1]BETFCY,[M:SIH1]BETCPY) From TRTVENISOC
    If [M:SIH1]BETFCY=2
        # 92731 : Création de facture inter-site
        # Point d'entrée permettant la création de factures inter-site
        Local Integer WPE_CRESIHBETFCY : Raz WPE_CRESIHBETFCY
        GPOINT ="CRESIHBETFCY" : Gosub ENTREE From EXEFNC
        # Facture inter-site
        #If [M:SIH1]BETCPY=1
        If [M:SIH1]BETCPY=1 & WPE_CRESIHBETFCY=0
        # 92731
            # On refuse une facture intra-société
            Call ERREUR (mess(319,192,1)) From GESECRAN : mkstat=2 : End
        Endif
        Raz WPE_CRESIHBETFCY : # 92731
        # Le client commande est aussi le fsseur (correspond au site de vente)
        If VALEUR=GBIDC3
            Local Integer WOK : WOK=1
            Call AVERTIR (mess(151,191,1), WOK)From GESECRAN
            If WOK=1 mkstat=2 : End : Endif
        Endif
        # Une facture directe inter-site doit tjs être sans mvt de stock (pas de reception de factures)
        If [M]SIHORI=9
           [M:SIH1]STOMVTFLG=2
        Else
           [M:SIH1]STOMVTFLG=1
        Endif
        Diszo [M:SIH1]STOMVTFLG
        Grizo [M:SIH1]STOFCY, TRSFAM
        If dim([M:SIH1]WRHE)>0 Grizo [M:SIH1]WRHE Endif
        If [M:SIH0]INVTYP=2 & dim ([M:SIH1]SRGLOCDEF)>0 Grizo [M:SIH1]SRGLOCDEF Endif
    Else
        Actzo [M:SIH1]STOMVTFLG
    Endif
Endif
Local Char WANCCUR : WANCCUR    = [M:SIH2]CUR

##RMA * 82772
If [F:BPC]BPCTYP = 2 & dim([M:ADB3]EECNUMX) & [M:ADB3]EECNUMX <> ""
  Local Char SAVBPIEECNUM(GLONEEC)
  SAVBPIEECNUM = [M:ADB3]EECNUMX
Endif

#--CPO 89490 Une fois le client modifié en modification (GREP="M")
#-- : possible si suppression de toutes les lignes
#-- Il faut faire un Raz de [m:adi4]
#-- seulement si GACTSAD=2 et pas en IMPORT
# If GREP="M" and (GACTSAD=2 or GLOCUSATAX) and !GIMPORT and find("",[M:SIH0]BPCINV,VALEUR)=0 and [M:SIH0]BPCINV<>VALEUR   # 106867.o
If GREP="M" and (GACTSAD=2 or (func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2)) and !GIMPORT and find("",[M:SIH0]BPCINV,VALEUR)=0 and [M:SIH0]BPCINV<>VALEUR   # 106867.n
Raz [M:ADI4]
Endif
#--/

# chgt et affichage des valeurs par défaut client facture
#If GUSER="MLGA" : Dbgaff : Endif
Call ALIFAC("F",VALEUR) From TRTVENFAC
If mkstat = 2 End : Endif
[M:ADI4]BPAADD=[F:BPC]BPAPYR ## SAM # 119565
##RMA * 82772
If dim([L]SAVBPIEECNUM)>0
  [M:SIH0]BPIEECNUM = [L]SAVBPIEECNUM
  Kill SAVBPIEECNUM
Endif

GBPCNUM = VALEUR

# GRNA 20/05/2011
Local Char CUSSEAORI : CUSSEAORI = "SIH1"
Gosub AM_BPRNUM From CUSSEALIB

If WANCCUR<>[M:SIH2]CUR
    # Alimentation du format des colonnes frais/remise
    Call ALIFORREM (5, GFLAG, "SIH4", 0, [M:SIH2]CUR) From TRTPRICE
Endif

# --> Affichage des observations du client facture
If !GIMPORT
   If len(vireblc([F:BPC]BPCREM,2)) & GERR=0 GMESSAGE = [F:BPC]BPCREM : GERR=2 : Endif
Endif
# --> Réalimentation de la raison sociale en fonction de la saisie adresse
If [M:ADB3]BPRNAM(0) <> ""
   [M]BPINAM = [M:ADB3]BPRNAM(0)
Else
    [M]BPINAM = [F:BPC]BPCNAM
Endif
If [M:SIH1]BPCORD = VALEUR
    [M]BPCNAM = [M]BPINAM
Endif
If [M:SIH2]CUR = GLOCALDEV
    Diszo [M:SIH2]CURTYP
Elsif [M:SIH2]CUR <> GLOCALDEV
    Actzo [M:SIH2]CURTYP
Endif

# 87923 : Gestion des prélèvements SDD
If dim([M:SIH2]UMRNUM)>0
    If GSDDMGT=2 & find([M:SIH0]INVTYP, 1,2)
        [M:SIH2]SDDFLG=func TRTVENSDD.IS_PTE_SDD([M:SIH2]PTE,GSOCIETE)
    Else
        [M:SIH2]SDDFLG=1
    Endif
    Gosub GRIZO_UMRNUM From TRTVENSDD
Endif
# 87923

Affzo [M:SIH0]BPINAM, CUR, INVDAT
Affzo [M:SIH1]1-99
Affzo [M:SIH2]1-99

# Issue 115715 - 2016-04-22 by RICAR : POR Leg.: debit notes without reference period
# Issue 115715
If func AFNC.ACTIV("KPO")
  Call SHOW_HIDE_PERDEB_PERFIN([M:SIH0]SALFCY,[M:SIH0]SIVTYP,"SIH1") From PORLEGLIB
  Call FLD4041DIS([M:SIH1]VACBPR,[M:SIH0]SIVTYP)
Endif
# End issue 115715

Call NEW_SFIT ("M","SIH2",[M:SIH2]CUR,[M]BPCINV,VALEUR,[M:SIH0]INVDAT) From SUBSFIT

# SAM 110033: Swiss localization: recalculate PAYBAN
If func AFNC.ACTIV("KSW") Then
  Call CALC_PAYBAN([M:SIH0]SALFCY, [M:SIH0]INVTYP, [M:SIH2]PTE, [M:SIH1]BPRPAY, [M:SIH2]CUR) From SUBSIHSWI
Endif
# SAM 110033 END

End

#########################################################################
#                     ECRAN GENERALITE : SIH1                           #
#########################################################################
######################################################################################
## Etiquette ajoutée par le superviseur (écran SIH1) 18/09/2006 17:07:47 (LD)
######################################################################################
# ---------------------- BPCORD : Client commande  --------------------------
Subprog AM_BPCORD(VALEUR)
Variable Char    VALEUR()
# chgt et affichage des valeurs par défaut client commande
Call ALIFAC("C",VALEUR) From TRTVENFAC
If mkstat = 2 End : Endif
GBPCNUM = VALEUR
# --> Affichage des observations du client commande
If !GIMPORT
   If len(vireblc([F:BPC]BPCREM,2)) & GERR=0 GMESSAGE = [F:BPC]BPCREM : GERR=2 : Endif
Endif

Call NEW_SFIT ("M","SIH2",[M:SIH2]CUR,[M:SIH0]BPCINV,VALEUR,[M:SIH0]INVDAT) From SUBSFIT


Affzo [M]BPCNAM, BPAADD, BPDNAM, STOFCY, REP, VACBPR
End
# ---------------------- BPRPAY : Tiers payeur --------------------------
Subprog AS_BPRPAY(VALEUR)
Variable Char    VALEUR()
# modif interdite : total des reglements provisoires [M]AMTTMP<>0
If [SIH0]AMTTMP<>0 : mkstat=2 : Endif

# Si c'est un avoir et origine non définie pas de ctrl zone obligatoire
#If [M:SIH0]INVTYP = 2 & [M:SIH1]SIHORI = 0 mkstat = 2 : Endif
End

######################################################################################
## Etiquette ajoutée par le superviseur (écran SIH1) 27/09/2004 15:36:52 (LD)
######################################################################################
Subprog AM_BPRPAY(VALEUR)
Variable Char    VALEUR()
If GREP="C"
    # Initialisation du code condition de paiement
    Call INIPTE (VALEUR, [M:SIH0]BPCINV, "C", [M:SIH2]PTE) From TRTX3
    Affzo [M:SIH2]PTE
Endif

# 87923 : Gestion des prélèvements SDD
If dim([M:SIH2]UMRNUM)>0
    If GSDDMGT=2 & find([M:SIH0]INVTYP, 1,2)
        [M:SIH2]SDDFLG=func TRTVENSDD.IS_PTE_SDD([M:SIH2]PTE,GSOCIETE)
    Else
        [M:SIH2]SDDFLG=1
    Endif
    If [M:SIH2]SDDFLG=1
        Raz [M:SIH2]UMRNUM
    Elsif [M:SIH2]UMRNUM <> ""
        # Si mandat renseigné, raz s'il n'est plus cohérent (si changement de tiers payeur)
        Call CTL_UMRNUM([M:SIH2]UMRNUM,GSOCIETE,VALEUR) From INVSDDLIB
        If mkstat=2 Raz mkstat : Raz [M:SIH2]UMRNUM Endif
    Endif
    If [M:SIH2]SDDFLG=2 & [M:SIH2]UMRNUM=""
        Call INIT_UMRNUM(GSOCIETE,VALEUR,2,2,[M:SIH2]UMRNUM) From INVSDDLIB
    Endif
    Gosub GRIZO_UMRNUM From TRTVENSDD
Endif
# 87923

# SAM 110033: Swiss localization: recalculate PAYBAN
If func AFNC.ACTIV("KSW") Then
  Call CALC_PAYBAN([M:SIH0]SALFCY, [M:SIH0]INVTYP, [M:SIH2]PTE,VALEUR, [M:SIH2]CUR) From SUBSIHSWI
Endif
# SAM 110033 END

End
########################################
# ---------------------- BPAADD : adresse de livraison --------------------------

Subprog AP_BPAADD(VALEUR)
Variable Char    VALEUR()

# --> Si modif client raz adresse avant de passer dans le bouton adresse
If !GIMPORT & VALEUR <> [M]BPAADD Raz [M:ADB2] : Endif

# --> Alimentation de la raison sociale
If [M:ADB2]BPRNAM(0) <> ""
    [M]BPDNAM = [M:ADB2]BPRNAM(0)
Else
    [M]BPDNAM = [F:BPD]BPDNAM(0)
Endif
Affzo [M]BPDNAM
End

#---------------------------------------
Subprog AM_BPAADD(VALEUR)
Variable Char    VALEUR()

# Si utilisation du bouton adresse, il ne faut pas passer en AM_
If dim(GWIMPMOD)<1 | GWIMPMOD=0  : # Bug 63563 : Utilisation GENSIH de TRTVENFACG
    If !GIMPORT & [M]BPAADD = VALEUR End : Endif
Endif
Local Char WANCVACBPR (GLONTVB) : WANCVACBPR=[M:SIH1]VACBPR
#LTA.sn
# If GLOCUSATAX and func AFNC.ACTIV("LTA")   # 106867.o
If func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
  Read [F:BPA]BPA0=1;[M:SIH1]BPCORD;VALEUR
  If fstat = 0 and [F:BPA]ADRVAL <> 2 and func TRTADRLIB.CHKADR_CRY([F:BPA]CRY)
    If func TRTADRLIB.CHKADR_MANDATORY()
      GERR=1
      GMESSAGE=mess(366,192,1) # Address has not been validated
      mkstat = 2
      End
    Else
      Call MESSAGE(mess(366,192,1)) From GESECRAN  # Address has not been validated
    Endif
  Endif
Endif
#LTA.en
# --> chgt et affichage des valeurs par défaut client facture
Call ALIFAC("L",VALEUR) From TRTVENFAC
# --> Réalimentation de la raison sociale
If [M:ADB2]BPRNAM(0) <> ""
    [M]BPDNAM = [M:ADB2]BPRNAM(0)
Else
    [M]BPDNAM = [F:BPD]BPDNAM(0)
Endif
Affzo [M:SIH1]BPDNAM, STOFCY
Affzo [M:SIH1]15, 25

# Les représentants ont été rechargés : Demande de répercution sur le détail
If [M:SIH4]NBLIG <> 0
    Local Char    WZONCOU : WZONCOU="BPAADD"
    Local Integer OK : OK=1
    Raz GTARFLG
    If WANCVACBPR<>[M:SIH1]VACBPR GTARFLG="V" Endif
    If GLINREP = 2 Call OUINON(mess(128,191,1), OK) From GESECRAN Endif
    If GLINREP=1 | OK=2 | GTARFLG="V" Gosub RECALC_LIGNE From SUBSIHB Endif
    # 79705 : V7 : SAT in SPRICLINK
    # To trigger recalculate prices
    Global Char GADDACTMOD(GLONDES)
    GADDACTMOD = "1"
    # 79705 : V7 : SAT in SPRICLINK
Endif

End
