#                        ACTION LIEES AUX ZONES STOCKS
#---------------------------------------------------------------------#
# ------------------------- LOT ----------------------------------
Subprog IB_LOT
If [M:SIH1]SIHORI=4 & [M:SIH4]XSIHORINUM(nolign-1) <> "" Raz GBOUT2 Endif
End

######################################################
# Attention : étiquette exécutée uniquement si Avoir #
######################################################
Subprog C_LOT(VALEUR)
Variable Char    VALEUR()
Local Shortint NOL : NOL=nolign-1
Local Char     WVCRNUMORI
Local Integer  LRET, WVCRTYPORI, WVCRLINORI

If [M:SIH0]INVTYP<>2 End Endif

If [M:SIH1]SIHORI=4 & [M:SIH4]XSIHORINUM(NOL) <> ""
    WVCRTYPORI = 5
    WVCRNUMORI = [M:SIH4]XSIHORINUM(NOL)
    WVCRLINORI = [M:SIH4]SIDORILIN(NOL)
Endif

LRET = func STKACT.FSTKCTRLOT(VALEUR,"SIH4",NOL,[M:SIH4]ITMREF(NOL),[M:SIH4]BPSLOT(NOL),
&                          13,[M:SIH0]NUM,[M:SIH4]SIDLIN(NOL),
&                          WVCRNUMORI, WVCRTYPORI, WVCRLINORI, 0,
&                          [M:SIH4]DSTOFCY(NOL),"LOCTYP",[M:SIH4]GESLOT(NOL))
If mod(LRET,2)=1
    Diszo [M:SIH4]BPSLOT(NOL)
Else
    Actzo [M:SIH4]BPSLOT(NOL)
Endif
If mkstat=2 End Endif
Affzo [M:SIH4]BPSLOT(NOL)
End

# ------------------------- NBSLOT -------------------------------
######################################################
# Attention : étiquette exécutée uniquement si Avoir #
######################################################
Subprog C_NBSLO(VALEUR)
Variable Decimal VALEUR

If [M:SIH0]INVTYP<>2 End Endif

#-----------------------#
# Contrôle nbr sous-lot #
#-----------------------#
Local Shortint NOL : NOL=nolign-1
Call STKCTRNBSLO(VALEUR, [M:SIH4]SAU(NOL), [M:SIH4]QTY(NOL)) From STKACT
End

# ------------------------- SLO -------------------------------
######################################################
# Attention : étiquette exécutée uniquement si Avoir #
######################################################
Subprog C_SLO(VALEUR)
Variable Char    VALEUR()

Local Char     WVCRNUMORI
Local Integer  WVCRTYPORI, WVCRLINORI

If [M:SIH0]INVTYP<>2 End Endif

#-----------------------#
# Contrôle N° sous-lot  #
#-----------------------#
Local Shortint NOL : NOL=nolign-1
If VALEUR<>""
  If [M:SIH1]SIHORI=4 & [M:SIH4]XSIHORINUM(NOL) <> ""
      WVCRTYPORI = 5
      WVCRNUMORI = [M:SIH4]XSIHORINUM(NOL)
      WVCRLINORI = [M:SIH4]SIDORILIN(NOL)
  Endif
  Call STKCTRSLO(VALEUR, [M:SIH4]NBSLO(NOL), [M:SIH4]LOT(NOL),
&               [M:SIH4]ITMREF(NOL),[M:SIH4]BPSLOT(NOL),[M:SIH4]GESLOT(NOL), WVCRNUMORI, WVCRTYPORI, WVCRLINORI, 0,
&               [M:SIH4]DSTOFCY(NOL), [M:SIH4]SLOF(NOL)) From STKACT
  Affzo [M:SIH4]SLOF(NOL)
Endif
End

Subprog B1_SLO(VALEUR)
Variable Char    VALEUR()
Local Shortint NOL : NOL=nolign-1
Call RECLASTSLO([M:SIH4]ITMREF(NOL), [M:SIH4]LOT(NOL), "","", VALEUR) From STKLIB
End
# ------------------------- BPSLOT     -------------------------------
######################################################################################
## Etiquette ajoutée par le superviseur (écran SIH4) 12/01/2009 08:54:03 (LD)
######################################################################################
Subprog C_BPSLOT(VALEUR)
Variable Char    VALEUR()
If dim([M:SIH4]SLO)>0
    Call STKCTRLOF(VALEUR, [M:SIH4]ITMREF(nolign-1), [M:SIH4]LOT(nolign-1), [M:SIH4]SLO(nolign-1), [M:SIH4]NBSLO(nolign-1), [M:SIH4]GESLOT(nolign-1) ) From STKACT
Else
    Call STKCTRLOF(VALEUR, [M:SIH4]ITMREF(nolign-1), [M:SIH4]LOT(nolign-1), "", 1, [M:SIH4]GESLOT(nolign-1) ) From STKACT
Endif
End
# ------------------------- SERNUM     -------------------------------
########################################
Subprog AM_SERNUM(VALEUR)
Variable Char    VALEUR()
Local    Integer NOL
Local    Char    LSERF(GLONSER)
Local    Decimal LQTYF
NOL=nolign-1

If [M]INVTYP=1
    If VALEUR<>""
       # Alimentation de [M:ALP]
       Gosub ALI_ALP
       # Détermination no série fin
       Call CTLSORSER("SIH4",NOL,VALEUR,[M:SIH4]QTYSTU(NOL),LSERF,LQTYF) From STKSOR
       If LQTYF=0
          Raz VALEUR, [M:SIH4]SERNUMF(NOL)
       Else
          [M:SIH4]SERNUMF(NOL)=LSERF
       Endif
    Else
       Raz [M:SIH4]SERNUMF(NOL)
    Endif
Endif
End
