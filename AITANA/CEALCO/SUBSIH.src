######################################################################################
## Etiquette ajoutée par le superviseur (écran SIH2) 19/05/2008 14:40:30 (ACA)
######################################################################################
Subprog IB_NBFAC
    If GREP = "C"
        IJ1=-1
        For IJ0 = 0 To dim([M:SFIT]DTA)-1
            If  [M:SFIT]DTA(IJ0)=[M:SIH2]INVDTA(nolign-1) and [M:SFIT]ORI(IJ0)=0
                IJ1=IJ0
                Break
            Endif
        Next
        If IJ1=-1
            Raz GBOUT3
        Endif
    Else
        Raz GBOUT3
    Endif
End
#####################################################################################
Subprog AP_NBFAC
#-----------------------------------------------#
# Si l'on sort du tableau, calcul de la facture #
#-----------------------------------------------#
Local Integer OK
If status >= 65 & status <=   90 End Endif
If find(status,7,27,28) | status >= 1792 End Endif
If [M:SIH1]INVSTA = 3 End Endif
If [M:SIH0]INVCLCFLG=1 End Endif
#If !find (status, 92,93)
    If [M:SIH4]NBLIG<>0
#      If GLOCUSATAX   # 106867.o
      If !GIMPORT & !GWEBSERV & func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
        # Spécificité USA
        Local Char     WKU_MAJ : WKU_MAJ="2"
        Local Integer  OK
        Call OUVRE_TRACE(mess(322,197,1)) From LECFIC
      Endif
      Gosub CHARG_TABLEAUX From TRTVENFACC
      Gosub CAL_FACTURE From TRTVENFACC
#      If GLOCUSATAX   # 106867.o
      If !GIMPORT & !GWEBSERV & func AFNC.ACTIV("LTA") & [F:CPY]SSTTAXACT = 2   # 106867.n
        # Spécificité USA
        Call FERME_TRACE From LECFIC
        If GMESSAGE <> "" & !GIMPORT
            Call OUINON(GMESSAGE+"\"+mess(88,191,1), OK) From GESECRAN
            If OK=2 Call LEC_TRACE From LECFIC : Endif
            Raz GMESSAGE
        Endif
      Endif
      [M:SIH0]INVCLCFLG=1
      [M:SIH4]INVNOT = [M:SIHV]INVNOT
      [M:SIH4]INVATI = [M:SIHV]INVATI
      Affzo [M:SIHV]1-99
      Affzo [M:SIH4]1-99
    Endif
#Endif
End
#---------------------------------------
Subprog APRES_NBFAC
    [M:SIH0]INVCLCFLG=2  : # on doit faire le calcul de la facture

    # ACA - Pour mise à jour du Format le cas échéant
    Affzo [M:SIH2]INVDTAAMT(nolign-1)
End
# ---------------------- INVDTAAMT --------------------------
######################################################################################
## Etiquette ajoutée par le superviseur (écran SIH2) 16/05/2008 14:43:38 (ACA)
######################################################################################
Subprog AM_INVDTAAMT(VALEUR)
Variable Decimal VALEUR

    # ACA - On vérifie que la saisie ne s'est pas faite avec trop de décimales
    # Possible à cause du picking qui ajoute 2 décimales pour les éléments calculés
    #Fq76549-Gbn
    If [M:SIH2]AMTCOD(nolign-1)=1
&       and [M:SIH2]INVDTATYP(nolign-1)<>3
&       and arr(VALEUR,[F:TCU]CURRND) <> VALEUR : # Trop de decimales
            GERR=1 : GMESSAGE=mess(303,184,1)-mess(134,126,1)-":"-num$([F:TCU]DECNBR)
            mkstat=1
        End
    Endif

    # ACA - On retabli le bon nombre de decimales pour le format
    If [M:SIH2]AMTCOD(nolign-1)=1
&       and [M:SIH2]FORMAT(nolign-1)<>func TRTX3FNC.GETFMTREM(1)
            [M:SIH2]FORMAT(nolign-1)=func TRTX3FNC.GETFMTREM(1)
    Endif

    If GREP="C"
        Call ADD_NBTRF(0, [M:SIH2]INVDTA(nolign-1), VALEUR) From SUBSFIT
    Endif

    #--CPO 102340 Avenants lignes mis à jour si modification en-tête
    #--Il faut enrichir la correction 90362 qui met à 1 les UPDFLG si pas d'éléments répartis
    #--Mettre le flag à 1 uniquement si passage d'un élément réparti à 0
    If [M:SIH2]INVDTAAMT(nolign-1)<>0 and VALEUR = 0
      #--Vérifier que l'élément est réparti sur lignes
      If clalev([F:SFI])=0 : Local File SFOOTINV [SFI] : Endif

      If [M:SIH2]INVDTA(nolign-1)<>[F:SFI]SFINUM
        Read [F:SFI]SFI0 = [M:SIH2]INVDTA(nolign-1)
        If fstat : Raz [F:SFI] : Endif
      Endif

      If find([F:SFI]DSPLIN,2,3,4)>0
        If dim(G_PREV_DSPLIN)<0 : Global Integer G_PREV_DSPLIN : Endif
        G_PREV_DSPLIN = 1
      Endif
    Endif
    #--/102340
End
