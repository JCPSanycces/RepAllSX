#<AdxTL>@(#)12.0.0.0 $Revision$
Local Integer MAXCOL : MAXCOL=200
Local File APROCESSUS [APR], ACLOB [ACB]
Local Char COLOR_LIST(6)(1..MAXCOL),LASTPROCESS(20)(1..MAXCOL), FIRSTPROCESS(20)(1..MAXCOL), CHCOLOR(100)
Local Integer COLOR_NUM(1..MAXCOL),NBCOLOR,NBPROCESS,I,J,COUNT(1..MAXCOL)
Local Integer OLD_COLOR(1..MAXCOL), NEW_COLOR(1..MAXCOL)

J=0
For I=0,2815,13158,17096,21208,26214,29014,32612,33126,39174,328965,870263,873328,1098305,1135728,1135987,1201779,
&     1250068,1267829,1321628,1381043,1391708,1777441,1853836,2054280,2183526,2651829,2894048,3021081,3100039,
&     3168683,3303062,3453491,3509396,3823214,4094159,4178960,4242631,4356003,4757183,5460848,5473766,8357659,
&     8495267,9943016,10066329,10072816,10279876,10922863,12312803,12566463,12703135,14213357,14540779,14711718,
&     14738364,14805995,15787750,15865880,16060689,16118514,16447479,16734208,16739841,16760832,16777215
  J+=1
  OLD_COLOR(J)=I
Next I
Errbox num$(J)

J=0
For I=16777215,5066579,5066579,5066579,5066579,16734208,16734208,16734208,16734208,40922,0,5066579,5066579,40922,5066579,5066579,5066579,5066579,5066579,5066579,
&     5066579,5066579,0,5066579,5066579,5066579,5066579,5066579,0,5066579,5066579,5066579,40922,16734208,5066579,5066579,40922,40922,5066579,40922,5066579,5066579,
&     4303168,5066579,5066579,5066579,5066579,4303168,4303168,40922,16777215,4303168,16777215,16777215,6166317,16777215,16777215,16777215,6166317,6166317,16777215,
&     16777215,16734208,16739841,16760832,16777215
  J+=1
  NEW_COLOR(J)=I
Next I
Errbox num$(J)
End

Local Clbfile CLOB_PRO
Local Char PRO_COD(20)
Local Integer UPDATEFLG

Local Char PRODEB(20),PROFIN(20)

# A modifier avant lancement
# PRODEB="YTECHNO" : PROFIN="YTECHNO"
PRODEB="" : PROFIN="zzzzzz"
UPDATEFLG=0

For [APR] Where TYPEP=1 and CODPRO<=PROFIN and CODPRO>=PRODEB
  NBPROCESS+=1
  CLOB_PRO=[APR]CLOB : PRO_COD=[APR]CODPRO
  Gosub TRANSCODE
  If UPDATEFLG : [APR]CLOB=CLOB_PRO : Rewrite [APR] : Endif
Next

For [ACB] Where CODBLB="APRJSON"
  CLOB_PRO=[ACB]CLOB : PRO_COD=left$([ACB]IDENT1,instr(1,[ACB]IDENT1+"~","~")-1)
  If PRO_COD<=PROFIN and PRO_COD>=PRODEB
    Gosub TRANSCODE
    If UPDATEFLG : [ACB]CLOB=CLOB_PRO : Rewrite [ACB] : Endif
  Endif
Next


Sorta NBCOLOR COLOR_NUM,COLOR_LIST,COUNT,FIRSTPROCESS,LASTPROCESS
Openo filpath("tmp","colors","txt"),0 Using [ZZZ]
For I=1 To NBCOLOR
  Wrseq '"';COLOR_LIST(I);'";';num$(COLOR_NUM(I));";";num$(COUNT(I));';"';FIRSTPROCESS(I);'";"';LASTPROCESS(I);'"' Using [ZZZ]
Next I
Openo Using [ZZZ]
End

$TRANSCODE
  I=instr(1,CLOB_PRO,'color":')
  If I<>0
    While I
       J=instr(I+7,CLOB_PRO,",")
       Break (J=0)
       CHCOLOR=seg$(CLOB_PRO,I+7,J-1)
       L=find(val(CHCOLOR),COLOR_NUM(1..NBCOLOR))
       If L=0
         NBCOLOR+=1 : L=NBCOLOR
         COLOR_NUM(NBCOLOR)=val(CHCOLOR)
         COLOR_LIST(NBCOLOR)=func TOHEX(val(CHCOLOR))
       Endif
       If LASTPROCESS(L)<>PRO_COD : LASTPROCESS(L)=PRO_COD : COUNT(L)+=1 : Endif
       If FIRSTPROCESS(L)="" : FIRSTPROCESS(L)=PRO_COD : Endif
       If UPDATEFLG : M=find(val(CHCOLOR),OLD_COLOR) : If M : CLOB_PRO=left$(CLOB_PRO,I+6)+num$(NEW_COLOR(M))+right$(CLOB_PRO,J) : Endif : Endif
       I=instr(J,CLOB_PRO,'color":')
    Wend
  Endif
  I=instr(1,CLOB_PRO,'COLOR=\"#')
  If I<>0
    While I
       J=instr(I+9,CLOB_PRO,"\")
       Break (J=0)
       CHCOLOR=seg$(CLOB_PRO,I+9,J-1)
       L=find(CHCOLOR,COLOR_LIST(1..NBCOLOR))
       If L=0
         NBCOLOR+=1 : L=NBCOLOR : COLOR_LIST(L)=CHCOLOR
         COLOR_NUM(L)=func TONUM(CHCOLOR)
       Endif
       If LASTPROCESS(L)<>PRO_COD : LASTPROCESS(L)=PRO_COD : COUNT(L)+=1 : Endif
       If FIRSTPROCESS(L)="" : FIRSTPROCESS(L)=PRO_COD : Endif
       If UPDATEFLG : M=find(COLOR_NUM(L),OLD_COLOR) : If M : CLOB_PRO=left$(CLOB_PRO,I+8)+num$(func TOHEX(NEW_COLOR(M)))+right$(CLOB_PRO,J) : Endif : Endif
       I=instr(J,CLOB_PRO,'COLOR=\"#')
    Wend
  Endif
  Return

Funprog TOHEX(I)
Value Integer I
Local Integer J
Local Char CHAINE(6)
  For J=1 To 6
    CHAINE=chr$(mod(I,16)+48+7*(mod(I,16)>9))+CHAINE
    I=int(I/16)
  Next J
End CHAINE

Funprog TONUM(CHAINE)
Value Char CHAINE()
Local Integer I,J
  For J=1 To 6
    I=I*16+ascii(mid$(CHAINE,J,1))-48-7*(mid$(CHAINE,J,1)>="A")
  Next J
End I
