#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Script that creates a shipment : ORDNUM is the order ID to be shipped ("this" is the order instance)

$SHIP

# Preliminary verifications : read the order and verify it exists, then check if not already totally shipped or invoiced
  ASTATUS=fmet this.AREAD([L]ORDNUM)
  If ASTATUS>=[V]CST_AERROR
    ASTATUS=fmet this.ASETERROR("ORDNUM","The order does not exist",ASTATUS) : Return
  Elsif this.ORDSTA>=3
    ASTATUS=fmet this.ASETERROR("ORDSTA","Order already totally shipped or invoiced",[V]CST_AERROR) : Return
  Endif

# Let's create a shipment instance and set the default header values
Local Instance SHIPMENT Using C_ZSHIP
  SHIPMENT=NewInstance C_ZSHIP AllocGroup this
  ASTATUS=fmet SHIPMENT.AINIT
  If ASTATUS>=[V]CST_AERROR : Return : Endif
  SHIPMENT.ORDNUM=this.ORDNUM : SHIPMENT.DLVDAT=date$ : SHIPMENT.CUSTOMER=this.CUSTOMER

# The shipment number will be the number of existing shipments plus one
  Local File ZSHIP [ZS] Where ORDNUM=this.ORDNUM : SHIPMENT.DLVNUM=rowcount([ZS])+1

# Loop on the order lines. Only the lines that have a quantity not shipped are generated
  SHIPMENT.DLVTOTAL=0
  For I=1 To maxtab(this.LINES)
    If this.LINES(I).QTY>this.LINES(I).DLVQTY : # Select only lines not completely shipped
      J=fmet SHIPMENT.ADDLINE("SHIPLINES",[V]CST_ALASTPOS)
      If J<0 : ASTATUS=fmet this.ASETERROR("","Unable to create shipment lines",[V]CST_AERROR) : Break : Endif
      SHIPMENT.SHIPLINES(J).ORDNUM=this.ORDNUM
      SHIPMENT.SHIPLINES(J).DLVNUM=SHIPMENT.DLVNUM
      SHIPMENT.SHIPLINES(J).NUMLIN=J
      SHIPMENT.SHIPLINES(J).ITEM=this.LINES(I).ITEM
      SHIPMENT.SHIPLINES(J).QTY=this.LINES(I).QTY-this.LINES(I).DLVQTY
      SHIPMENT.DLVTOTAL+=this.LINES(I).UNITPRICE*SHIPMENT.SHIPLINES(J).QTY*(1-this.LINES(I).DISCOUNT/100)
    Endif
  Next I

# If everything is OK, we can create the shipment and update the order lines
  If ASTATUS<>[V]CST_AERROR
    ASTATUS=fmet SHIPMENT.AINSERT
    If ASTATUS<>[V]CST_AERROR
      For I=1 To maxtab(this.LINES)
        this.LINES(I).DLVQTY=this.LINES(I).QTY  : # Quantities are shipped
      Next I
      ASTATUS=fmet this.AUPDATE
    Endif
  Endif
Return : # To be commented if we want the additional piece of code to be executed

  If ASTATUS<>[V]CST_AERROR
# Additionally, we can:
  #1) Publish the shipment on an external web site by using a REST web service
    Gosub PUBLISH From ZWEBSERV
  #2) Create a text description of the shipment in a mongoDB document
    Gosub DOCUMENT From ZWEBSERV
  Endif

Return


