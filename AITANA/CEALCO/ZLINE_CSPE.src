#<AdxTL>@(#)0.0.0.0 $Revision$
# Code associated to the class ZLINE (order line)

# No global methods have been defined on the order line class
$METHODS
Return


# Events related to property rules. CURPRO is the property code, ACTION the rule code
$PROPERTIES
  Case [L]CURPRO
    When "QTY"        : Gosub QTY
    When "UNITPRICE"  : Gosub UNITPRICE
    When "DISCOUNT"   : Gosub DISCOUNT
    When "ITEM"       : Gosub ITEM
  Endcase
Return

# On quantity: default value is 1, price recomputed if quantity modified, quantity cannot be less than delivered quantity
$QTY
  Case [L]ACTION
    When "INIT"      : this.QTY=1 : # Default quantity
    When "CONTROL"
         If this.QTY<this.DLVQTY
           [L]ASTATUS=fmet this.ASETERROR(CURPRO,"Quantity cannot be less than"-num$(this.DLVQTY),[V]CST_AERROR)
         Endif
    When "PROPAGATE" : this.PRICE=func PRICE(this.UNITPRICE,this.QTY,this.DISCOUNT)
  Endcase
Return

# On unit price: price cannot be negative, and the price is recomputed if the unit price changed
$UNITPRICE
  Case [L]ACTION
    When "CONTROL"
       If this.UNITPRICE<0 : [L]ASTATUS=fmet this.ASETERROR(CURPRO,"Price must >=0",[V]CST_AERROR) : Endif
    When "PROPAGATE" : this.PRICE=func PRICE(this.UNITPRICE,this.QTY,this.DISCOUNT)
  Endcase
Return

# On discount: if modified, price line is recomputed.
$DISCOUNT
  Case [L]ACTION
    When "PROPAGATE" : this.PRICE=func PRICE(this.UNITPRICE,this.QTY,this.DISCOUNT)
  Endcase
Return

# On item: set the default price value if the item is modified
$ITEM
  Case [L]ACTION
    When "PROPAGATE" : this.UNITPRICE=func ZPRICE.SEARCH_PRICE(this.ITEM)
  Endcase
Return

# Price line computation
Funprog PRICE(PRICE,QTY,DISCOUNT)
Value Decimal PRICE,QTY,DISCOUNT
End ar2(PRICE*QTY*(1-DISCOUNT/100))

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

