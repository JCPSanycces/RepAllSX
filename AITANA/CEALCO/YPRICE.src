#<AdxTL>@(#)0.0.0.0 $Revision$
# Price computation
Funprog PRICE(ITEM,CURRENCY)
Value Char ITEM()
Value Char CURRENCY
Local Decimal PRICE_FOUND
Local Tinyint WEBSEARCH
Local File ITMSALES [ITS]

# Read the YWEBPRICE web price determination parameter value (at folder level)
  Local File ADOVAL
  Read [ADW]ADW0="";"";"YWEBPRICE"
  WEBSEARCH=val([ADW]VALEUR)

# If web services are set up, call them
  If WEBSEARCH=2
    PRICE_FOUND = func YWEBSERV.PRICE(ITEM)
    RATE_FOUND  = func YWEBSERV.RATE(CURRENCY)
    If RATE_FOUND=0 : RATE_FOUND=1 : Endif
    PRICE_FOUND/=RATE_FOUND

# Otherwise, use a simplified algorith (read in database regardless of currency)
  Else
    Read [ITS]ITS0=ITEM
    If fstat=[V]CST_AOK
      PRICE_FOUND = arr([ITS]BASPRI,0.01)
    Else
      PRICE_FOUND=0
    Endif
  Endif

End PRICE_FOUND

