#<AdxTL>@(#)0.0.0.0 $Revision$
#webservice de consultas donde se devuelve un clob

Local Clbfile Z_XML
#Dbgaff
Call XWSCONS("SIH","NUM='FV18A0001-000005'",Z_XML)

End

Subprog XWSCONS(TABLA, FILTRO, O_XML)
Value Char TABLA
Value Char FILTRO
Variable Clbfile O_XML

Local Integer JJ

If FILTRO=''
  FILTRO="1=1"
Endif

Raz O_XML

Append O_XML,'<xml_version>1.04</xml_version>'
Append O_XML,'<tables>'

### Bucle sobre las tablas solicitadas
For X=0 To dim(TABLA)-1
Case TABLA(X)
  When "SOH"  : Gosub XSOH
  When "POH"  : Gosub XPOH
  When "SDH"  : Gosub XSDH
  When "SRH"  : Gosub XSRH
  When "PNH"  : Gosub XPNH
  When "SIH"  : Gosub XSIH
Endcase
Next

Append O_XML,'</tables>'

End

$XSOH

If !clalev([F:SOH]) : Local File SORDER   [SOH] : Endif
If !clalev([F:SOQ]) : Local File SORDERQ  [SOQ] : Endif
If !clalev([F:SOP]) : Local File SORDERP  [SOP] : Endif

Link [SOQ] With
& [SOH]SOH0 = [SOQ]SOHNUM,
& [SOP]SOP0 = [SOQ]SOHNUM; [SOQ]SOPLIN; [SOQ]SOQSEQ
& As [XPED]

For [XPED] Where evalue(FILTRO)
JJ+=1
  Append O_XML,'<sorder>'
  Append O_XML,'<STOFCY>'+[SOQ]STOFCY+'</STOFCY>'
  Append O_XML,'<ITMREF>'+[SOQ]ITMREF+'</ITMREF>'
  Append O_XML,'<SOHNUM>'+[SOH]SOHNUM+'</SOHNUM>'
  Append O_XML,'<DEMDLVDAT>'+[SOH]DEMDLVDAT+'</DEMDLVDAT>'
  Append O_XML,'<ORDDAT>'+[SOH]ORDDAT+'</ORDDAT>'
  Append O_XML,'<BPCORD>'+[SOH]BPCORD+'</BPCORD>'
  Append O_XML,'<BPCNAM>'+[SOH]BPCNAM(0)+'</BPCNAM>'
  Append O_XML,'<QTYSTU>'+num$([SOQ]QTYSTU)+'</QTYSTU>'
  Append O_XML,'<DLVQTYSTU>'+num$([SOQ]DLVQTYSTU)+'</DLVQTYSTU>'
  Append O_XML,'<SOPLIN>'+num$([SOQ]SOPLIN)+'</SOPLIN>'
  Append O_XML,'<APPFLG>'+num$([SOH]APPFLG)+'</APPFLG>'
  Append O_XML,'<HLDSTA>'+num$([SOH]HLDSTA)+'</HLDSTA>'
  Append O_XML,'<CUSORDREF>'+[SOH]CUSORDREF+'</CUSORDREF>'
  Append O_XML,'<SAU>'+[SOP]SAU+'</SAU>'
  Append O_XML,'<GROPRI>'+num$([SOP]GROPRI)+'</GROPRI>'
  Append O_XML,'<XORDLIN>'+num$([SOQ]XORDLIN)+'</XORDLIN>'
  Append O_XML,'<XORIGEN>'+num$([SOH]XORIGEN)+'</XORIGEN>'
  Append O_XML,'<XORIMAIL>'+num$([SOH]XORIMAIL)+'</XORIMAIL>'
  Append O_XML,'<BPAADD>'+[SOH]BPAADD+'</BPAADD>'
  Append O_XML,'<DISCRGVAL1>'+num$([SOP]DISCRGVAL1)+'</DISCRGVAL1>'
  Append O_XML,'<DISCRGVAL2>'+num$([SOP]DISCRGVAL2)+'</DISCRGVAL2>'
  Append O_XML,'<INVDTAAMT_3>'+num$([SOH]INVDTAAMT(3))+'</INVDTAAMT_3>'
  Append O_XML,'</sorder>'
Next

Return

$XPOH

If !clalev([F:POH]) : Local File PORDER   [POH] : Endif
If !clalev([F:POQ]) : Local File PORDERQ  [POQ] : Endif
If !clalev([F:POP]) : Local File PORDERP  [POP] : Endif

Link [POQ] With
& [POH]POH0 = [POQ]POHNUM,
& [POP]POP0 = [POQ]POHNUM; [POQ]POPLIN; [POQ]POQSEQ
& As [XPEC]

For [XPEC] Where evalue(FILTRO)
JJ+=1
  Append O_XML,'<porder>'
  Append O_XML,'<POHFCY>'+[POH]POHFCY+'</POHFCY>'
  Append O_XML,'<ITMREF>'+[POQ]ITMREF+'</ITMREF>'
  Append O_XML,'<POHNUM>'+[POQ]POHNUM+'</POHNUM>'
  Append O_XML,'<EXTRCPDAT>'+[POQ]EXTRCPDAT+'</EXTRCPDAT>'
  Append O_XML,'<BPSNUM>'+[POH]BPSNUM+'</BPSNUM>'
  Append O_XML,'<BPRNAM>'+[POH]BPRNAM(0)+'</BPRNAM>'
  Append O_XML,'<text_pie_cab></text_pie_cab>'
  Append O_XML,'<QTYSTU>'+num$([POQ]QTYSTU)+'</QTYSTU>'
  Append O_XML,'<RCPQTYSTU>'+num$([POQ]RCPQTYSTU)+'</RCPQTYSTU>'
  Append O_XML,'<ORDDAT>'+[POH]ORDDAT+'</ORDDAT>'
  Append O_XML,'<POPLIN>'+num$([POQ]POPLIN)+'</POPLIN>'
  Append O_XML,'<STU>'+[POQ]STU+'</STU>'
  Append O_XML,'<GROPRI>'+num$([POP]GROPRI)+'</GROPRI>'
  Append O_XML,'<LINCLEFLG>'+num$([POQ]LINCLEFLG)+'</LINCLEFLG>'
  Append O_XML,'<ORDDAT_lin>'+[POQ]ORDDAT+'</ORDDAT_lin>'
  Append O_XML,'</porder>'
Next

Return

$XSDH

If !clalev([F:SDD]) : Local File SDELIVERYD [SDD] : Endif
If !clalev([F:SDH]) : Local File SDELIVERY  [SDH] : Endif

Link [SDD] With
& [SDH]SDH0= [SDD]SDHNUM
& As [XENT]

For [XENT] Where evalue(FILTRO)
JJ+=1
  Append O_XML,'<sdelivery>'
  Append O_XML,'<SDHNUM>'+[SDD]SDHNUM+'</SDHNUM>'
  Append O_XML,'<STOFCY>'+[SDH]STOFCY+'</STOFCY>'
  Append O_XML,'<SALFCY>'+[SDH]SALFCY+'</SALFCY>'
  Append O_XML,'<ITMREF>'+[SDD]ITMREF+'</ITMREF>'
  Append O_XML,'<SHIDAT>'+[SDH]SHIDAT+'</SHIDAT>'
  Append O_XML,'<QTY>'+num$([SDD]QTY)+'</QTY>'
  Append O_XML,'<SDDLIN>'+num$([SDD]SDDLIN)+'</SDDLIN>'
  Append O_XML,'<BPAADD>'+[SDH]BPAADD+'</BPAADD>'
  Append O_XML,'<BPCORD>'+[SDH]BPCORD+'</BPCORD>'
  Append O_XML,'<SOHNUM>'+[SDD]SOHNUM+'</SOHNUM>'
  Append O_XML,'<SOPLIN>'+num$([SDD]SOPLIN)+'</SOPLIN>'
  Append O_XML,'<XORDLIN>'+num$([SDD]XORDLIN)+'</XORDLIN>'
  Append O_XML,'<SAU>'+[SDD]SAU+'</SAU>'
  Append O_XML,'<CFMFLG>'+num$([SDH]CFMFLG)+'</CFMFLG>'
  Append O_XML,'</sdelivery>'
Next

Return


$XSRH

If !clalev([F:SRD]) : Local File SRETURND   [SRD] : Endif
If !clalev([F:SRH]) : Local File SRETURN    [SRH] : Endif

Link [SRD] With
& [SRH]SRH0= [SRD]SRHNUM
& As [XDEV]

For [XDEV] Where evalue(FILTRO)
JJ+=1
  Append O_XML,'<sreturn>'
  Append O_XML,'<SRHNUM>'+[SRD]SRHNUM+'</SRHNUM>'
  Append O_XML,'<BPCORD>'+[SRH]BPCORD+'</BPCORD>'
  Append O_XML,'<BPAADD>'+[SRH]BPAADD+'</BPAADD>'
  Append O_XML,'<RTNDAT>'+[SRH]RTNDAT+'</RTNDAT>'
  Append O_XML,'<STOFCY>'+[SRH]STOFCY+'</STOFCY>'
  Append O_XML,'<SRDLIN>'+num$([SRD]SRDLIN)+'</SRDLIN>'
  Append O_XML,'<ITMREF>'+[SRD]ITMREF+'</ITMREF>'
  Append O_XML,'<QTYSTU>'+num$([SRD]QTYSTU)+'</QTYSTU>'
  Append O_XML,'<STU>'+[SRD]STU+'</STU>'
  Append O_XML,'<EXTQTYSTU>'+num$([SRD]EXTQTYSTU)+'</EXTQTYSTU>'
  Append O_XML,'<NETPRI>'+num$([SRD]NETPRI)+'</NETPRI>'
  Append O_XML,'<NETPRIATI>'+num$([SRD]NETPRIATI)+'</NETPRIATI>'
  Append O_XML,'<SDHNUM>'+[SRD]SDHNUM+'</SDHNUM>'
  Append O_XML,'<SDDLIN>'+num$([SRD]SDDLIN)+'</SDDLIN>'
  Append O_XML,'</sreturn>'
Next

Return

$XPNH

If !clalev([F:PND]) : Local File PRETURND   [PND] : Endif
If !clalev([F:PNH]) : Local File PRETURN    [PNH] : Endif

Link [PND] With
& [PNH]PNH0= [PND]PNHNUM
& As [XDEVC]

For [XDEVC] Where evalue(FILTRO)
JJ+=1
  Append O_XML,'<preturn>'
  Append O_XML,'<PNHNUM>'+[PND]PNHNUM+'</PNHNUM>'
  Append O_XML,'<BPSNUM>'+[PNH]BPSNUM+'</BPSNUM>'
  Append O_XML,'<RTNDAT>'+[PNH]RTNDAT+'</RTNDAT>'
  Append O_XML,'<LINAMT>'+num$([PND]LINAMT)+'</LINAMT>'
  Append O_XML,'<LINATIAMT>'+num$([PND]LINATIAMT)+'</LINATIAMT>'
  Append O_XML,'<PNHFCY>'+[PNH]PNHFCY+'</PNHFCY>'
  Append O_XML,'<PTHNUM>'+[PND]PTHNUM+'</PTHNUM>'
  Append O_XML,'<PTDLIN>'+num$([PND]PTDLIN)+'</PTDLIN>'
  Append O_XML,'<PNDLIN>'+num$([PND]PNDLIN)+'</PNDLIN>'
  Append O_XML,'<ITMREF>'+[PND]ITMREF+'</ITMREF>'
  Append O_XML,'<QTYSTU>'+num$([PND]QTYSTU)+'</QTYSTU>'
  Append O_XML,'<STU>'+[PND]STU+'</STU>'
  Append O_XML,'<NETPRI>'+num$([PND]NETPRI)+'</NETPRI>'
  Append O_XML,'<CFMFLG>'+num$([PNH]CFMFLG)+'</CFMFLG>'
  Append O_XML,'</preturn>'
Next

Return

$XSIH

If !clalev([F:SID]) : Local File SINVOICED  [SID] : Endif
If !clalev([F:SIH]) : Local File SINVOICE   [SIH] : Endif
If !clalev([F:SIV]) : Local File SINVOICEV  [SIV] : Endif

Link [SID] With
& [SIH]SIH0= [SID]NUM,
& [SIV]SIV0= [SID]NUM
& As [XFAC]

For [XFAC] Where evalue(FILTRO)
JJ+=1
  Append O_XML,'<sinvoice>'
  Append O_XML,'<NUM>'+[SID]NUM+'</NUM>'
  Append O_XML,'<SIVTYP>'+[SIH]SIVTYP+'</SIVTYP>'
  Append O_XML,'<BPCORD>'+[SIV]BPCORD+'</BPCORD>'
  Append O_XML,'<INVDAT>'+[SIV]INVDAT+'</INVDAT>'
  Append O_XML,'<SALFCY>'+[SIV]SALFCY+'</SALFCY>'
  Append O_XML,'<AMTATI>'+num$([SIH]AMTATI)+'</AMTATI>'
  Append O_XML,'<AMTNOT>'+num$([SIH]AMTNOT)+'</AMTNOT>'
  Append O_XML,'<SNS>'+num$([SIH]SNS)+'</SNS>'

  Append O_XML,'<ITMREF>'+[SID]ITMREF+'</ITMREF>'
  Append O_XML,'<QTY>'+num$([SID]QTY)+'</QTY>'
  Append O_XML,'<SAU>'+[SID]SAU+'</SAU>'
  Append O_XML,'<NETPRI>'+num$([SID]NETPRI)+'</NETPRI>'
  Append O_XML,'<AMTLIN>'+num$([SID]AMTLIN)+'</AMTLIN>'
  Append O_XML,'<AMTATILIN>'+num$([SID]AMTATILIN)+'</AMTATILIN>'
  Append O_XML,'<SDHNUM>'+[SID]SDHNUM+'</SDHNUM>'
  Append O_XML,'<SDDLIN>'+num$([SID]SDDLIN)+'</SDDLIN>'
  Append O_XML,'<SOHNUM>'+[SID]SOHNUM+'</SOHNUM>'
  Append O_XML,'<SOPLIN>'+num$([SID]SOPLIN)+'</SOPLIN>'
  Append O_XML,'<XORDLIN>'+num$([SID]XORDLIN)+'</XORDLIN>'
  Append O_XML,'<SIHORINUM>'+[SID]SIHORINUM+'</SIHORINUM>'
  Append O_XML,'<SIDORILIN>'+num$([SID]SIDORILIN)+'</SIDORILIN>'
  Append O_XML,'<SRHNUM>'+[SID]SRHNUM+'</SRHNUM>'
  Append O_XML,'<SRDLIN>'+num$([SID]SRDLIN)+'</SRDLIN>'

  Append O_XML,'</sinvoice>'
Next

Return

