#<AdxTL>@(#)0.0.0.0 $Revision$
# Code associated to the user interface only on sales order representation

$PROPERTIES
  Case [L]CURPRO
    When "ZOH.LINES.PRICE" : Gosub PRICE
  Endcase
Return

# Every time a line price is updated, recompute the total amount (user interface rule)
$PRICE
  Case [L]ACTION
    When "PROPAGATE"
      this.APARENT.TOTAL=fmet this.APARENT.TOTAMOUNT
  Endcase
Return

# Global events
$METHODS
  Case CURPTH
    When ""
      Case [L]ACTION
        When "DISC_ERASE"   : ASTATUS=fmet this.ZOH.DISC_ERASE : # Discount erasement by calling the class method
        When "AREAD_AFTER"  : Gosub AREAD_AFTER : # Populate the shipping list
      Endcase
  Endcase
Return

# Populate the shipment history if the order was already shipped
$AREAD_AFTER
  If this.ZOH.ORDSTA>=2
    Local File ZSHIP Where ORDNUM=this.ZOH.ORDNUM Order By Key MYKEY=DLVNUM Desc
    Local Integer I
    For [ZSH]
      I=fmet this.ADDLINE("SHIPLINES",[V]CST_ALASTPOS)
      If I>0
        SetInstance this.SHIPLINES(I) With [ZSH]
      Endif
    Next
  Endif
Return

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return

