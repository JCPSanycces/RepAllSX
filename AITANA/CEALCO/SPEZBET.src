#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara ZPV0 (Especifico)

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZPV0) 23/04/2019 15:58:42 (ADMIN)
######################################################################################
$ACTION

Case ACTION
 When "OUVRE"       : Gosub OUVRE
 When "LIENS"       : Gosub LIENS
 When "LIENS_LIG"   : Gosub LIENS_LIG
 When "INICRE"      : Gosub INICRE
 When "CREATION"    : Gosub CREATION    From TABLEAUX
 When "MODIF"       : Gosub MODIF       From TABLEAUX
 When "ANNULE"      : Gosub ANNULE      From TABLEAUX
 When "APRES_CRE"   : Gosub LIENS       From TABLEAUX : Gosub APRES_CRE
 When "APRES_MOD"   : Gosub LIENS       From TABLEAUX
 When "INICRE_LIG"  : [F:ZBETD]NUM= [M:ZBET0]NUM
 When "DEFLIG"      : Gosub DEFLIG
 When Default
Endcase
Return

######################################################################################
$OUVRE
  Gosub DECLARE From TABLEAUX
Return

######################################################################################
$LIENS
  Gosub LIENS From TABLEAUX
  If GWEBSERV=0
    GCONSULT=1
  Endif
Return

######################################################################################
$LIENS_LIG
  Local Shortint NOL
  NOL=nolign-1
  [M:ZBET1]ITMREF(NOL)= [F:ZBETD]ITMREF
  [M:ZBET1]SDDLIN(NOL)= [F:ZBETD]SDDLIN
  [M:ZBET1]SDHNUM(NOL)= [F:ZBETD]SDHNUM
  [M:ZBET1]NUM(NOL)   = [F:ZBETD]NUM
  [M:ZBET1]LIN(NOL)   = [F:ZBETD]LIN
Return

####################################################################
$INICRE
If [M:ZBET0]NUM=""
    [M:ZBET0]NUM= num$(uniqid([ZBET]))
Endif

[F:ZBET]NUM=[M:ZBET0]NUM
For JJ=0 To [M:ZBET1]NBLIG-1
  [M:ZBET1]NUM(JJ)= [F:ZBET]NUM
Next

Return

######################################################################################
$APRES_CRE

Gosub IMPORTPTH

Return

######################################################################################
$DEFLIG

Default Mask [ZBET1] #The screen holding your detail information
Default File [ZBETD] #The table holding your detail information
#Filtering expression to read all detail lines related to one header
CRIT   = '[F:ZBETD]NUM="'+num$([M:ZBET0]NUM)+'"'
FICLIG = "ZBETCPYD" #The name of the detail Table
ABLIG  = "ZBETD"     #Its abbreviation
ZONLIG = "LIN"   #The line counter field

Return

######################################################################################
$IMPORTPTH

Local Char FICHERO(250) : FICHERO= filpath("ZIMP",[ZBET]NUM+"_"+ctrans(num$(date$),"/",""),"txt")

Openo FICHERO,0 Using [FIC1] #abrir el fichero
Iomode  adxifs '|'                    Using [FIC1]
Iomode  adxirs chr$(13)+chr$(10)      Using [FIC1]
Iomode  adxium 50                     Using [FIC1]

Wrseq "H";                            Using [FIC1]      #cabecera
Wrseq [ZBET]PRHFCY;                   Using [FIC1]      #Planta expedición  [PTH]PRHFCY
Wrseq [ZBET]BPSNUM;                   Using [FIC1]      #Proveedor          [PTH]BPSNUM
Wrseq [ZBET]NUM                       Using [FIC1]      #Num. WS rec. interp[PTH]BETNUM

For II=0 To [M:ZBET1]NBLIG-1
  Wrseq "D";                          Using [FIC1]      #línea
  Wrseq [M:ZBET1]SDHNUM(II);          Using [FIC1]      #Nº entrega         [PTD]SDHNUM
  Wrseq [M:ZBET1]SDDLIN(II);          Using [FIC1]      #línea entrega      [PTD]SDDLIN
  Wrseq [M:ZBET1]ITMREF(II)           Using [FIC1]      #Artículo           [PTD]ITMREF
Next

Openo Using [FIC1]

Local Char MODELE(50)
MODELE = "ZPTHI"
#FICHERO= filpath("ZIMP","Interplanta-recepción","")
If GWEBSERV=0
  Call OUVRE_TRACE("Generació recepción") From LECFIC
Endif
Call IMPORTSIL(MODELE,FICHERO) From GIMPOBJ

If GWEBSERV=0
  Call FERME_TRACE From LECFIC
  Call LEC_TRACE From LECFIC
Endif

#If clalev([F:ZPTH])=0 : Local File PRECEIPT [ZPTH] : Endif
#Trbegin [ZBET]
#For [ZPTH] Where [ZPTH]ZBETNUM= [ZBET]NUM
#  [ZBET]PTHNUM= [ZPTH]PTHNUM
#  Rewrite [ZBET]
#Next
#Commit

Return

