#<AdxTL>@(#)0.0.0.0 $Revision$
# This function gets an instance pointer, and based on its description, generates a stringified JSON description

Funprog STRINGIFY(STRUCTURE)
End func STRINGIFYL(STRUCTURE,0)

Funprog STRINGIFYL(STRUCTURE,LEVEL)
Value Integer LEVEL
Local Clbfile CHAINE,CHAINE1
Local Char PROG(100)
Local Integer I,J,K,L,N
PROG="func"-seg$(adxpno(0),instr(1,adxpno(0),"/")+1,instr(1,adxpno(0),"$")-1)+ ".STRINGIFYL"

If dim(STRUCTURE,0)>1
  End "**Error too many dimensions**"
Endif

If dim(STRUCTURE)>1
  CHAINE="[ "
  If dim(STRUCTURE)=32767
    L=maxtab(STRUCTURE)
    For I=0 To L
      If (type(STRUCTURE)=524 and STRUCTURE(I)<>null) or type(STRUCTURE)<>524 : Gosub ADD_MEMBER : Endif
      CHAINE+=string$(I<L,", ")
    Next I
  Else
    L=dim(STRUCTURE,-1)+dim(STRUCTURE,1)-1
    For I=dim(STRUCTURE,-1) To L
      Gosub ADD_MEMBER
      CHAINE+=string$(I<L,", ")
    Next I
  Endif
  CHAINE+=" ]"
Else
  I=0
  Gosub ADD_MEMBER
Endif
End CHAINE

$ADD_MEMBER
Case type(STRUCTURE)
  When 1,2,4,5,6,7 : CHAINE+=num$(STRUCTURE(I))
  When 3 : CHAINE+= '"'+format$("D:4Y[-]MM[-]DD",STRUCTURE(I))+'"'
  When 522 : K=b64Encode(STRUCTURE(I),CHAINE1) : CHAINE+= "'"+CHAINE1+"'"
  When 524 : LEVEL+=1 : CHAINE+="{ "+chr$(10)+space$(3*LEVEL) : N=0 :
             K=STRUCTURE(I).ObjectNbs
             For J=1 To K
               If find(STRUCTURE(I).ObjectVar(J),"AATTRIBUTES","ACTX","AERROR","AINF","AKEYS","AORDER","APARENT","ASTALIN","AUUID")=0
&              and left$(STRUCTURE(I).ObjectVar(J),1)<>"_"
&              and ((LEVEL=1) or find(STRUCTURE(I).ObjectVar(J),"CREDATTIM","UPDDATTIM","CREUSR","UPDUSR")=0)
                 CHAINE+=string$(N>0,","+chr$(10)+space$(3*LEVEL)) : N+=1
                 CHAINE+='"'+STRUCTURE(I).ObjectVar(J)+'" : '+evalue(PROG+"(STRUCTURE(I)."+STRUCTURE(I).ObjectVar(J)+",LEVEL)")
               Endif
             Next J
             LEVEL=max(LEVEL-1,0)
             CHAINE+=chr$(10)+space$(3*LEVEL)+" }"
  When 525,526 : CHAINE+='"'+num$(STRUCTURE(I))+'"'
  When Default : CHAINE+= '"'+escJson(STRUCTURE(I))+'"'
 Endcase
 Return



Funprog ITEMS
  Local File ITMSALES [ITS], ITMMASTER [ITM]
  Openo filpath("TRA","itm","tra"),0 Using [ZZ]
  For [ITM]ITM0
    Read [ITS]ITS0=[ITM]ITMREF
    If fstat=[V]CST_AOK
       Wrseq '{ "item" : "'+[ITM]ITMREF+'", "price" : '+num$([ITS]BASPRI)+"}," Using [ZZ]
    Else
       Wrseq '{ "item" : "'+[ITM]ITMREF+'", "price" : 0 },' Using [ZZ]
    Endif
  Next
  Openo Using [ZZ]
End 0
Return

