#####################################################################################
# CodAct: YYY Herramientas Desarrollo
######################################################################################

Call OBJET ("YDD",GBIDC1,GBIDC2) From GOBJET
End

########################################
$ACTION
Case ACTION
 When "OUVRE"            : Gosub OUVRE
 When "FILTRE"           : Gosub FILTRE
 When "CREATION"         : Gosub CREATION
 When "APRES_CRE"        : Gosub APRES_CRE
 When "INICRE"           : Gosub INICRE
 When "LIENS"            : Gosub LIENS
 When "STYLE"            : Gosub STYLE
 When "MODIF"            : Gosub MODIF
 When "APRES_MOD"        : Gosub APRES_MOD
 When "ANNULE"           : Gosub ANNULE
 When "DEFLIG"           : Gosub DEFLIG
 When "DEFLIG1"          : Gosub DEFLIG1
 When "INICRE_LIG"       : Gosub INI_LIG
 When "INIMOD_LIG"       : Gosub INI_LIG
 When "INICRE1_LIG"      : Gosub INI1_LIG
 When "INIMOD1_LIG"      : Gosub INI1_LIG
 When "EXEBOUT"          : Gosub EXEBOUT
 When "RAZDUP"           : Gosub RAZDUP
 When Default
Endcase

Return

$RAZDUP
Local Integer I
For I=0 To [M:YD1]NBLIG-1
   [M:YD1]YDESANUM(I)=[M:YD0]YDESANUM
Next
Affzo [M:YD1]NBLIG

Return

####################################################################
$INICRE

If [M:YD0]YDESANUM=0
    Read [F:YDC1]Last
    If fstat : Raz [F:YDC1] : Endif
    [M:YD0]YDESANUM=[F:YDC1]YDESANUM+1
Endif

[F:YDC]YDESANUM=[M:YD0]YDESANUM
[F:YDE]YDESANUM=[M:YD0]YDESANUM

Return


####################################################################
$OUVRE

If !clalev([F:YDC1]) : Local File YDESACAB [F:YDC1] : Endif

Gosub DECLARE From TABLEAUX
Gosub DECLARE From TABLEAUX1
#[M]DOSSIER=nomap(0)
Return

####################################################################
$FILTRE
#Default File [YDC]
#Default File [YDE]
Return

####################################################################
$CREATION

Gosub CREATION From TABLEAUX
If GOK < 1  Return  Endif
Gosub CREATION From TABLEAUX1
If GOK < 1  Return  Endif
Return

####################################################################
$APRES_CRE
# -- Rechargement des indicateurs UPDFLG et CREFLG #
Gosub LIENS From TABLEAUX
Gosub LIENS From TABLEAUX1
Return

####################################################################
$LIENS
[M]DOSSIER=nomap(0)
# -- Chargement des lignes dans le tableau
Gosub LIENS From TABLEAUX
Gosub LIENS From TABLEAUX1
Local Integer K
For K=0 To [M:YD1]NBLIG-1
    [M:YD1]YAUXCHK(K)=[M:YD1]TYPOBJ(K)+[M:YD1]NOMOBJ(K)
Next
Return
####################################################################

$STYLE
#Estilos de Colores
    If dim([L]STYLE_X3)<0 :     Local Char STYLE_X3(15)  : STYLE_X3="BANLIN"   : Endif
    If dim([L]STYLE_N)<0 :     Local Char STYLE_N(15)  : STYLE_N=""   : Endif

    Local Integer K
    For K=0 To [M:YD1]NBLIG-1
        Case [M:YD1]TYPOBJ(K)
            When "TRT":
                Chgstl [M:YD1]NBLIG(K) With STYLE_X3
            When Default:
                Chgstl [M:YD1]NBLIG(K) With STYLE_N
        Endcase
        If [M:YD1]YNUEVO(K)=2
            Chgstl [M:YD1]NBLIG(K) With "BACKORANGE"
        Endif
    Next

Affzo [M:YD1]NBLIG

Return

####################################################################
$MODIF
Gosub MODIF From TABLEAUX
If GOK < 1  Return  Endif
Gosub MODIF From TABLEAUX1
If GOK < 1  Return  Endif

Return

####################################################################
$APRES_MOD
# -- Rechargement des indicateurs UPDFLG et CREFLG #
Gosub LIENS From TABLEAUX
Gosub LIENS From TABLEAUX1
Return

###############################################################
$ANNULE
Gosub ANNULE From TABLEAUX : # Effacement des lignes
If GOK < 1  Return  Endif
Gosub ANNULE From TABLEAUX1 : # Effacement des lignes
If GOK < 1  Return  Endif
Return
###############################################################
$DEFLIG
#----------------------------------#
# DÃ©finition du fichier des lignes #
#----------------------------------#
# CritÃ¨re de lecture      (CRIT)   #
# Nom du fichier          (FICLIG) #
# AbrÃ©viation du fichier  (ABLIG)  #
# Zone numÃ©ro de ligne    (ZONLIG) #
#----------------------------------#
Default Mask [YD1]
Default File [YDD]
CRIT = '[F:YDD]YDESANUM='+num$([M:YD0]YDESANUM)
FICLIG = "YDESADET" : ABLIG = "YDD"
ZONLIG = "LINEA"
Return
###############################################################
$DEFLIG1
#----------------------------------#
# Définition du fichier des lignes #
#----------------------------------#
# Critère de lecture      (CRIT)   #
# Nom du fichier          (FICLIG) #
# Abréviation du fichier  (ABLIG)  #
# Zone numéro de ligne    (ZONLIG) #
#----------------------------------#

Default Mask [YD3]
Default File [YDE]
CRIT = '[F:YDE]YDESANUM='+num$([M:YD0]YDESANUM)
FICLIG = "YDESAINC" : ABLIG = "YDE"
ZONLIG = "LINEAINC"
Return

####################################################################
$INI_LIG
# -- alim no commande
[F:YDD]YDESANUM= [F:YDC]YDESANUM
Return

$INI1_LIG
[F:YDE]YDESANUM= [F:YDC]YDESANUM
Gosub CHARG_TEXT_LIGNE
Return

$CHARG_TEXT_LIGNE
    If [M:YD3]COMENTINCI(nolign-1)<>""
        Call CRE_CLOB([M:YD3]COMENTINCI(nolign-1),GOK) From TRTX3TEX
        If GOK<1  Return : Endif
    Endif
    [F:YDE]COMENTINCI=[M:YD3]COMENTINCI(nolign-1)

Return


Subprog C_TYPOBJ(VALEUR)
Variable Char    VALEUR()
Gosub SET_TYP
If !find(VALEUR,TEX(1..NBTEX))
 Local File ATABLE [ATB]
 Read [ATB]ABRFIC = VALEUR
 If !fstat
  GBIDC1 = [ATB]CODFIC
#  Call TEXTE([F:ATB]INTITFIC,[M]INTITOBJ(nolign-1)) From OBJDIV
 Else
  GMESSAGE = mess(42,115,1) : mkstat = 2 : End : # Type d'objet incorrect
 Endif
Endif


End
######################################################################################
#--------------#
$SET_TYP
Local Integer NBTEX,ABI
Local Char    TEX(10)(1..80),TEXTE(50)(1..80,1..2)
NBTEX = 0
NBTEX += 1 : TEX(NBTEX) = "ABA" : TEXTE(NBTEX,2) = mess(96,134,1)  : # Abonnements
NBTEX += 1 : TEX(NBTEX) = "ABT" : TEXTE(NBTEX,2) = mess(92,134,1)  : # Taches batch
NBTEX += 1 : TEX(NBTEX) = "ABG" : TEXTE(NBTEX,2) = mess(97,134,1)  : # Groupes de tÃ¢ches
NBTEX += 1 : TEX(NBTEX) = "ACL" : TEXTE(NBTEX,2) = mess(111,133,1) : # Table de contrÃ´le
NBTEX += 1 : TEX(NBTEX) = "ACN" : TEXTE(NBTEX,2) = mess(15,126,1)  : # Consultation
NBTEX += 1 : TEX(NBTEX) = "ACT" : TEXTE(NBTEX,2) = mess(30,124,1)  : # Action
NBTEX += 1 : TEX(NBTEX) = "ACV" : TEXTE(NBTEX,2) = mess(14,115,1)  : # Code activitÃ©
NBTEX += 1 : TEX(NBTEX) = "ADC" : TEXTE(NBTEX,2) = mess(111,125,1) : # Traitement (dico)
Call OK_CODACT(nomap(0),"ABI",ABI)
If ABI
 NBTEX += 1 : TEX(NBTEX) = "ABM" : TEXTE(NBTEX,2) = mess(41,127,1)  : # Datamart
 NBTEX += 1 : TEX(NBTEX) = "ABF" : TEXTE(NBTEX,2) = mess(63,148,1)  : # Table de fait
 NBTEX += 1 : TEX(NBTEX) = "ABI" : TEXTE(NBTEX,2) = mess(6,16,1)    : # Dimension
 NBTEX += 1 : TEX(NBTEX) = "AHH" : TEXTE(NBTEX,2) = mess(43,127,1)  : # Hierarchie
 NBTEX += 1 : TEX(NBTEX) = "ABV" : TEXTE(NBTEX,2) = mess(10,148,1)  : # RÃ¨gle de synchronisation
 NBTEX += 1 : TEX(NBTEX) = "AII" : TEXTE(NBTEX,2) = mess(44,127,1)  : # Conditions prÃ©dÃ©fnies
 NBTEX += 1 : TEX(NBTEX) = "ABO" : TEXTE(NBTEX,2) = mess(42,127,1)  : # Etats Business Objects
 NBTEX += 1 : TEX(NBTEX) = "BIA" : TEXTE(NBTEX,2) = mess(83,148,1)  : # Objets biar
Endif
NBTEX += 1 : TEX(NBTEX) = "ADI" : TEXTE(NBTEX,2) = mess(75,125,1)  : # Tables diverses
NBTEX += 1 : TEX(NBTEX) = "ADF" : TEXTE(NBTEX,2) = mess(138,139,1) : # Liens de documentation
NBTEX += 1 : TEX(NBTEX) = "ADO" : TEXTE(NBTEX,2) = mess(108,139,1) : # Documentation
NBTEX += 1 : TEX(NBTEX) = "ADP" : TEXTE(NBTEX,2) = mess(81,123,1)  : # ParamÃ¨tre
NBTEX += 1 : TEX(NBTEX) = "ADX" : TEXTE(NBTEX,2) = mess(44,115,1)  : # Traitement (adx)
NBTEX += 1 : TEX(NBTEX) = "ADV" : TEXTE(NBTEX,2) = mess(136,125,1) : # ParamÃ¨trage tables diverses
NBTEX += 1 : TEX(NBTEX) = "ADZ" : TEXTE(NBTEX,2) = mess(189,151,1) : # Aide sur champ
NBTEX += 1 : TEX(NBTEX) = "AFC" : TEXTE(NBTEX,2) = mess(33,124,1)  : # Fonction
NBTEX += 1 : TEX(NBTEX) = "AGB" : TEXTE(NBTEX,2) = mess(122,139,1) : # Variable globale
NBTEX += 1 : TEX(NBTEX) = "AHI" : TEXTE(NBTEX,2) = mess(110,125,1) : # Formule d'Ã©puration
NBTEX += 1 : TEX(NBTEX) = "ALH" : TEXTE(NBTEX,2) = mess(2,7818,1)  : # Requetes
NBTEX += 1 : TEX(NBTEX) = "ALQ" : TEXTE(NBTEX,2) = mess(3,7818,1)  : # Requetes SQL
NBTEX += 1 : TEX(NBTEX) = "AMK" : TEXTE(NBTEX,2) = mess(2,42,1)    : # Ecran
NBTEX += 1 : TEX(NBTEX) = "AML" : TEXTE(NBTEX,2) = mess(3,95,1)    : # Message
NBTEX += 1 : TEX(NBTEX) = "ANG" : TEXTE(NBTEX,2) = mess(101,125,1) : # Navigation
NBTEX += 1 : TEX(NBTEX) = "ANM" : TEXTE(NBTEX,2) = mess(184,100,1) : # Compteur
NBTEX += 1 : TEX(NBTEX) = "AOB" : TEXTE(NBTEX,2) = mess(15,124,1)  : # Objet
NBTEX += 1 : TEX(NBTEX) = "AOE" : TEXTE(NBTEX,2) = mess(97,141,1)  : # ModÃ¨le import-export
NBTEX += 1 : TEX(NBTEX) = "ARP" : TEXTE(NBTEX,2) = mess(46,115,1)  : # Etats (dico)
NBTEX += 1 : TEX(NBTEX) = "ASU" : TEXTE(NBTEX,2) = mess(207,124,1) : # Sous-programmes
NBTEX += 1 : TEX(NBTEX) = "ATB" : TEXTE(NBTEX,2) = mess(56,123,1)  : # Tables
NBTEX += 1 : TEX(NBTEX) = "ATN" : TEXTE(NBTEX,2) = mess(109,125,1) : # Transaction
NBTEX += 1 : TEX(NBTEX) = "ATY" : TEXTE(NBTEX,2) = mess(164,124,1) : # Type de donnÃ©es
NBTEX += 1 : TEX(NBTEX) = "AUR" : TEXTE(NBTEX,2) = mess(208,124,1) : # DÃ©finition des URL
NBTEX += 1 : TEX(NBTEX) = "AVW" : TEXTE(NBTEX,2) = mess(15,127,1)  : # Vues
NBTEX += 1 : TEX(NBTEX) = "AWA" : TEXTE(NBTEX,2) = mess(55,75,1)   : # RÃ¨gle Workflow
NBTEX += 1 : TEX(NBTEX) = "AWI" : TEXTE(NBTEX,2) = mess(14,126,1)  : # FenÃªtre
NBTEX += 1 : TEX(NBTEX) = "AWM" : TEXTE(NBTEX,2) = mess(152,75,1)  : # Modeles de donnÃ©es Worflow
NBTEX += 1 : TEX(NBTEX) = "AWR" : TEXTE(NBTEX,2) = mess(153,75,1)  : # RÃ¨gles d'affection Workflow
NBTEX += 1 : TEX(NBTEX) = "AWW" : TEXTE(NBTEX,2) = mess(154,75,1)  : # Plan travail Workflow
NBTEX += 1 : TEX(NBTEX) = "ELT" : TEXTE(NBTEX,2) = mess(206,133,1) : # ElÃ©ment web
NBTEX += 1 : TEX(NBTEX) = "ETA" : TEXTE(NBTEX,2) = mess(45,115,1)  : # Etat (rpt)
NBTEX += 1 : TEX(NBTEX) = "EXE" : TEXTE(NBTEX,2) = mess(193,123,1) : # ExÃ©cution trt
If filinfo(filpath("FIL","GAUTACE","fde",nomap(0)),0)>=0
 NBTEX += 1 : TEX(NBTEX) = "GAU" : TEXTE(NBTEX,2) = mess(64,125,1)  : # PiÃ¨ce automatique
Endif
NBTEX += 1 : TEX(NBTEX) = "TAB" : TEXTE(NBTEX,2) = mess(117,126,1) : # Table (contenu)
NBTEX += 1 : TEX(NBTEX) = "TRT" : TEXTE(NBTEX,2) = mess(43,115,1)  : # Traitement (src)
NBTEX += 1 : TEX(NBTEX) = "TXT" : TEXTE(NBTEX,2) = mess(49,115,1)  : # Texte (txt)
NBTEX += 1 : TEX(NBTEX) = "ASY" : TEXTE(NBTEX,2) = mess(23,42,1)   : # Styles
Return

######################################################################################
$EXEBOUT
Case BOUT
When "x": Gosub CP_SRC_CLI
Endcase
Return

######################################################################################
#copiar los fuentes SRC a cliente
$CP_SRC_CLI
    Local Integer K,LSTA
    For K=0 To [M:YD1]NBLIG-1
        If [M:YD1]TYPOBJ(K)="TRT"
            Call YCPSRC2CLI([M:YD1]NOMOBJ(K),"src",LSTA)
            If (LSTA) Infbox [M:YD1]NOMOBJ(K)-"no existe!" Endif
        Endif
    Next
Return
######################################################################################
Subprog YCPSRC2CLI(FICHIER,SUF,LSTAT)
Value Char FICHIER()
Value Char SUF()
Variable Integer LSTAT
    #pej
    #FICHIER="ZMRATEST"
    #SUF="src"
    Local Char FICSRV(GDIMFIC), FICCLI(GDIMFIC)
    FICSRV=filpath("TRT",FICHIER,SUF)
    FICCLI="C:\TEMP\"+nomap(0)+"."+FICHIER+"."+format$('D:4Y[-]MM[-]DD',date$)+"."+SUF
    Call COPCLI(FICSRV,FICCLI,LSTAT) From ORDSYS
End

######################################################################################
Subprog B1_NBLIG
    Local Integer LSTA
    If [M:YD1]TYPOBJ(nolign-1)="TRT"
        Call YCPSRC2CLI([M:YD1]NOMOBJ(nolign-1),"src",LSTA)
            If (LSTA) Infbox [M:YD1]NOMOBJ(nolign-1)-"no existe!" Endif

    Endif
End
######################################################################################

Subprog YCPFIL2CLI(FICHIER,FLD,SUF,LSTAT)
Value Char FICHIER()
Value Char FLD()
Value Char SUF()
Variable Integer LSTAT
    #pej
    #FICHIER="ZMRATEST"
    #SUF="src"
    Local Char FICSRV(GDIMFIC), FICCLI(GDIMFIC)
    FICSRV=filpath(FLD,FICHIER,SUF)
    FICCLI="C:\TEMP\"+nomap(0)+"."+FICHIER+"."+SUF
    Call COPCLI(FICSRV,FICCLI,LSTAT) From ORDSYS
End


