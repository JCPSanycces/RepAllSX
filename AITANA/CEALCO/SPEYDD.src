######################################################################################
######################################################################################
##Este Subprog estaba en PATCHABI pero se discontinuó, y la hemos copiado aquí
Subprog OK_CODACT(APPLI,COD,OK)
Value Char       APPLI
Value Char       COD
Variable Integer OK
Local File ADOSACT [ADA3]
OK = 0
Read [ADA3]ADA0=APPLI;COD
If !fstat & [F:ADA3]FLACT=2
OK = 1
Endif
Close Local File [ADA3]
End
