#<AdxTL>@(#)0.0.0.0 $Revision$
# Third test: check the additional controls
#------------------------------------------------------------------------------#

Local Clbfile RESULT
RESULT=func TESTSUITE()
Errbox RESULT
End

Funprog TESTSUITE()

  Call ADD_TESTCASE("TEST_YORDER","Test classes YORDER with controls",1) From AXUNIT

End func AXUNIT.RUN_TESTSUITE("Test number 1","Check the classes")

#  Optional subprog called *before* running the test suite
Subprog SETUP

# Error handling variable
  Global Integer ERROR_V

# Cleanup tables
  Gosub CLEANUP_TABLES
End

#  Optional subprog called *after* running the test suite
Subprog TEARDOWN
  Gosub CLEANUP_TABLES
End

# Cleanup the YSHIP and YORDER table where some empty records could have been created
$CLEANUP_TABLES
  Local File YORDER, YLINE, YSHIP, YSHLINE
  Delete [YOH] Where ORDNUM="TST_001"
  Delete [YLI] Where ORDNUM="TST_001"
  Delete [YSH] Where ORDNUM="TST_001"
  Delete [YSL] Where ORDNUM="TST_001"
Return

Subprog TEST_YORDER()

#
# Check class YORDER
#
  Local Instance YORDER Using C_YORDER
  Local Integer OK
  Local Integer NB_ERR
  Local Char ORDER_NUM(100)
  YORDER=NewInstance C_YORDER AllocGroup null
  OK=fmet YORDER.AINIT

  Local File YCUSTOMER : Read [YBP]YBP0 First
  Local File YITEM     : Read [YIT]YIT0 First
  Local File FACILITY  : Read [FCY]FCY0 First

  YORDER.FCY=[FCY]FCY
  YORDER.CUSTOMER=[YBP]BPCNUM
  OK=fmet YORDER.ADDLINE("LINES",[V]CST_ALASTPOS)
  If OK=[V]CST_ANOTDEFINED
    NB_ERR+=1
    Call LOG_LINE(" ** ERROR : ADDLINE method failed on YORDER for the first line") From AXUNIT
  Else
    YORDER.LINES(OK).ITEM=[YIT]ITMREF
    YORDER.LINES(OK).QTY=100
    OK=fmet YORDER.ADDLINE("LINES",[V]CST_ALASTPOS)
    If OK=[V]CST_ANOTDEFINED
      NB_ERR+=1
      Call LOG_LINE(" ** ERROR : ADDLINE method failed on YORDER for the second line") From AXUNIT
    Else
      Read [YIT]YIT0>"B"
      YORDER.LINES(OK).ITEM=[YIT]ITMREF
      YORDER.LINES(OK).QTY=200
      OK=fmet YORDER.AINSERT
      If OK<>[V]CST_AOK
        NB_ERR+=1
        Call LOG_LINE(" ** ERROR : AINSERT method failed on YORDER") From AXUNIT
        Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
      Else
        ORDER_NUM=YORDER.ORDNUM
        Call LOG_LINE("Creation of an order with 2 lines succeeded") From AXUNIT
        If left$(YORDER.ORDNUM,10)<>[FCY]FCY+"-"+num$(year(date$))
          NB_ERR+=1
          Call LOG_LINE(" ** ERROR : Default value for ORDNUM set incorrectly ("+YORDER.ORDNUM+")") From AXUNIT
        Endif
        If YORDER.LINES(1).SORTLIN<>1 or YORDER.LINES(1).NUMLIN<>1 or YORDER.LINES(1).ORDNUM<>YORDER.ORDNUM
&       or YORDER.LINES(2).SORTLIN<>2 or YORDER.LINES(2).NUMLIN<>2 or YORDER.LINES(2).ORDNUM<>YORDER.ORDNUM
          NB_ERR+=1
          Call LOG_LINE(" ** ERROR : Default assignment of technical properties on lines") From AXUNIT
          Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
        Else
          Call LOG_LINE("Assignment of technical properties on lines successful") From AXUNIT
        Endif
        If YORDER.ORDSTA<>1
          Call LOG_LINE("Wrong assignment of order status on not shipped order ("+num$(YORDER.ORDSTA)-"instead of 1") From AXUNIT
        Else
          Call LOG_LINE("Assignment of order status on not shipped order successful") From AXUNIT
        Endif
      Endif
      FreeGroup YORDER
      YORDER=NewInstance C_YORDER AllocGroup null
      OK=fmet YORDER.AREAD(ORDER_NUM)
      If OK<>[V]CST_AOK
        NB_ERR+=1
        Call LOG_LINE(" ** ERROR : AREAD method failed on YORDER") From AXUNIT
      Else
        YORDER.LINES(1).DLVQTY=1
        OK=fmet YORDER.AUPDATE
        If OK<>[V]CST_AERROR
          NB_ERR+=1
          Call LOG_LINE(" ** ERROR : shipped quantity assignment control done incorrectly") From AXUNIT
        Else
          Call LOG_LINE("Shipped quantity control successful") From AXUNIT
        Endif
        YORDER.OPERATION="SHIP"
        OK=fmet YORDER.AUPDATE
        If OK=[V]CST_AOK
          Call LOG_LINE("shipment assignment ok") From AXUNIT
          If YORDER.ORDSTA<>2
            Call LOG_LINE("Wrong assignment of order status on partially shipped order ("+num$(YORDER.ORDSTA)-"instead of 2") From AXUNIT
          Else
            Call LOG_LINE("Assignment of order status on partially shipped order successful") From AXUNIT
          Endif
        Endif
        YORDER.LINES(1).DLVQTY=150
        OK=fmet YORDER.AUPDATE
        If OK=[V]CST_AERROR
          Call LOG_LINE("Wrong shipment line assignment correctly tested") From AXUNIT
          Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
          YORDER.LINES(1).DLVQTY=100
        Else
          NB_ERR+=1
          Call LOG_LINE(" ** ERROR : Shipped quantity can be more than ordered quantity") From AXUNIT
          Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
        Endif
        YORDER.LINES(2).DLVQTY=200
        OK=fmet YORDER.AUPDATE
        If OK=[V]CST_AOK
          If YORDER.ORDSTA<>3
            Call LOG_LINE("Wrong assignment of order status on shipped order ("+num$(YORDER.ORDSTA)-"instead of 3") From AXUNIT
          Else
            Call LOG_LINE("Assignment of order status on shipped order successful") From AXUNIT
          Endif
        Else
          NB_ERR+=1
          Call LOG_LINE(" ** ERROR at order update") From AXUNIT
          Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
        Endif
      Endif
    Endif
  Endif
  Call CHECK_EQUAL(NB_ERR,0) From AXUNIT

  Local File YLINE
  Delete [YLI] Where pat(ORDNUM,[FCY]FCY+"-"+num$(year(date$))+"*")<>0
  Local File YORDER
  Delete [YLI] Where pat(ORDNUM,[FCY]FCY+"-"+num$(year(date$))+"*")<>0
End

