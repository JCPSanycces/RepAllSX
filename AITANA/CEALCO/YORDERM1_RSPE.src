#<AdxTL>@(#)0.0.0.0 $Revision$
# Class YORDERM1


#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
  Case [L]CURPTH
    When ""
      Case AEVENT
          When "AQUERY_JOIN_AFTER"
            Gosub CHANGE_LINK
          When "AQUERY_TRANS_AFTER"
            Gosub ASSIGN_COUNTRY
    Endcase
    When "YOH"
      Case [L]AEVENT
        When "AINSERT_CONTROL_BEFORE"
          If this.CURRENCY="" : Gosub DEFAULT_CUR : Endif
        When "AUPDATE_CONTROL_AFTER","AINSERT_CONTROL_AFTER"
          this.UPDDATMOB=date$
        When "AREAD_AFTER"
            Gosub READ_CUSTINFO
            Call READ_CONTACTS(this.CUSTOMER, this.APARENT.NAME, this.APARENT.PHONE) From YORDER_RSPE
      Endcase
    When "YOH.LINES"
      Case [L]AEVENT
        When "AINSERT_BEFORE"
          If this.QTY=0   : this.QTY=1      : Endif
          If this.UNITPRICE=0 : this.UNITPRICE=func YPRICE.PRICE(this.ITEM,this.APARENT.CURRENCY) : Endif
      Endcase
  Endcase

Return


#**
#* Label for coding action on INIT, GET, CONTROL and PROPAGATE
#* @param CURPRO Local Char(50), contains the property code
#* @param ARULE Local Char(20), contains the action code requested
#* @return ASTATUS Local Integer
#*!
$PROPERTIES
  If [L]ARULE="INIT"
    Case CURPRO
      When "YOH.FCY" : # Set the default company by using SOCDEF user parameter (first company if not found)
        Local Char DEFCOMP(20)
        Local File COMPANY
        DEFCOMP=fmet this.ACTX.APARAM.AGETUSERVALCHAR("SOCDEF")
        Read [CPY]CPY0=DEFCOMP
        If fstat<>[V]CST_AOK : Read [CPY]CPY0 First : Endif
        this.FCY=[CPY]MAIFCY
      When "YOH.COMMENT" : # Set a default comment for mobile devices
        this.COMMENT="Created from a mobile device by"-this.ACTX.USER-format$("D:[Date : ]8M[ ]2D[, ]4Y[ ]hh[:]mm[:]ss",date$)
    Endcase
  Endif
Return


#**
#* Label for coding your methods
#* @param AMETHOD Local Char(20), contains the method code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$METHODS
 Case [L]AMETHOD
 Endcase
Return

$OPERATIONS
 Case [L]AOPERATION
 Endcase
Return

$DEFAULT_CUR
Local File BPCUSTOMER
  Read [BPC]BPC0=this.CUSTOMER
  If fstat=[V]CST_AOK : this.CURRENCY=[BPC]CUR
  Else                : this.CURRENCY="EUR"
  Endif
Return

$DEFAULT_COMP
Local Char DEFCOMP(20)
Local File COMPANY
  DEFCOMP=fmet this.ACTX.APARAM.AGETUSERVALCHAR("SOCDEF")
  Read [CPY]CPY0=DEFCOMP
  If fstat<>[V]CST_AOK : Read [CPY]CPY0 First : Endif
  this.FCY=[CPY]MAIFCY
Return

$CHANGE_LINK
 Close File [LNK_]
 Local File BPARTNER [YBPR]
 Link [YOH] With [YBPR]BPR0=[YOH]CUSTOMER As [LNK_]
Return

$READ_CUSTINFO
  Local File BPARTNER [YBPR], BPCUSTOMER [YBPC]
  Read [YBPR]BPR0=this.CUSTOMER
  Read [YBPC]BPC0=this.CUSTOMER
  this.APARENT.OSTAUZ=max([YBPC]OSTAUZ,1000) : # Authorized credit is at least 1000
Return

$ASSIGN_COUNTRY
  this.COUNTRY=[YBPR]CRY
Return

