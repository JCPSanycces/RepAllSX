##===================================================================================
$ACTION
  Case ACTION
    When "OUVRE"     : Gosub OUVRE
    When "RAZDUP"    : Gosub RAZDUP
    When "VERIF_CRE" : Gosub VERIF_CRE
  Endcase
Return
##===================================================================================
#$APRES_CRE
#        Local Char TBPAR(15)(1..50),TBVAL(30)(1..50)
##        Call ETAT("BONLIV", "ZPRINT", [M:SDH0]LAN, 2, "", TBPAR, TBVAL) From AIMP3
#Call ZEMILIO From ZEMILIO
#  GFILPATH = filpath("BQT", "prueba","pdf")
#  Call WORKFLOW(1,"ARP","","") From AWRK
#Return
##===================================================================================
$OUVRE
  If !clalev([F:ZSOH]) : Local File SORDER [ZSOH] : Endif
Return
##===================================================================================
$RAZDUP
  Raz [M:SOH0]CUSORDREF
  Affzo [M:SOH0]CUSORDREF
Return
##===================================================================================
$VERIF_CRE
  If [M:SOH0]CUSORDREF = ''
    OK = 0
    GMESSAGE = "La Referencia no puede estar vacía."
    GERR = 1
  Endif
Return
##===================================================================================
Subprog C_CUSORDREF(VALEUR)
Variable Char    VALEUR()
  ##Call UNICITE(VALEUR,[M]CUSORDREF) From OBJDIV
  Read [F:ZSOH]XSOH6 = VALEUR
  If !fstat
    GERR=1 : GMESSAGE = "Referencia usada en el pedido"-[F:ZSOH]SOHNUM : mkstat=2
  Endif
End
##===================================================================================

