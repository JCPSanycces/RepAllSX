#<AdxTL>@(#)0.0.0.0 $Revision$
# Function that searches the price for a given item
# Two options:

Funprog SEARCH_PRICE(ITEM)
Value Char ITEM
Local Decimal UNITPRICE
OPTION=1

If OPTION=1
# Search in database in a ITMSALES table
  Local File ITMSALES [ITS]
  Read [ITS]ITS0=ITEM
  If fstat=[V]CST_AOK
    UNITPRICE=arr([ITS]BASPRI,0.01) : # Default price uses BASPRI
  Endif
Else
# Call a web service to get the price
  UNITPRICE=func ZWEBSERV.PRICE(ITEM)
Endif

End UNITPRICE
