#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char YBPCNUM(50)(2)
Local Decimal YOSTAUZ(50)(2)
Local Decimal YSALDOPAGO(50)(2)
Local Decimal YSALDOSOH(50)(2)

Call XWSRIESGO ("S1360","S1360",YBPCNUM, YOSTAUZ, YSALDOPAGO, YSALDOSOH)


End

Subprog XWSRIESGO(XBPCINI, XBPCFIN, XBPCNUM ,XOSTAUZ, XSALDOPAGO, XSALDOSOH)
Value    Char     XBPCINI
Value    Char     XBPCFIN
Variable Char     XBPCNUM     ()
Variable Decimal  XOSTAUZ     ()
Variable Decimal  XSALDOPAGO  ()
Variable Decimal  XSALDOSOH   ()

Gosub DEC_VARIABLES

For [XBPC] Where evalue(CRIT)
  Raz XSALDOSOH(NOL)
  Raz XSALDOPAGO(NOL)
  XBPCNUM(NOL)= [XBPC]BPCNUM
  XOSTAUZ(NOL)= [XBPC]OSTAUZ

  For [XPED] Where BPCORD= [XBPC]BPCNUM and DLVQTY<QTY
    XSALDOSOH(NOL)= XSALDOSOH(NOL) + ([XSOP]NETPRI*([XSOQ]QTY -[XSOQ]DLVQTY))
  Next

  For [XENT] Where [XSDH]BPCORD= [XBPC]BPCNUM and [XSDH]INVFLG<>2
    XSALDOSOH(NOL)= XSALDOSOH(NOL) + ([XSDD]NETPRI*[XSDD]QTY)
  Next

  For [XDUD]  Where AMTCUR>(PAYCUR + TMPCUR) and TYP='FACLI' and BPR= [XBPC]BPCNUM and (PAYCUR + TMPCUR>0)
    XSALDOPAGO(NOL)=  XSALDOPAGO(NOL) + ([XDUD]AMTCUR - [XDUD]PAYCUR - [XDUD]TMPCUR)
  Next
  NOL+=1
Next

End


###########################################
$DEC_VARIABLES

If !clalev([F:XBPC])  : Local File BPCUSTOMER     [XBPC]  : Endif
If !clalev([F:XSOP])  : Local File SORDERP        [XSOP]  : Endif
If !clalev([F:XSOQ])  : Local File SORDERQ        [XSOQ]  : Endif
If !clalev([F:XSDD])  : Local File SDELIVERYD     [XSDD]  : Endif
If !clalev([F:XSDH])  : Local File SDELIVERY      [XSDH]  : Endif
If !clalev([F:XDUD])  : Local File GACCDUDATE     [XDUD]  : Endif

Link [XSOQ] With
&       [XSOP]SOP0 ~=[XSOQ]SOHNUM;[XSOQ]SOPLIN;[XSOQ]SOQSEQ
&    As [XPED]

Link [XSDD] With
&        [XSDH]SDH0 ~=[XSDD]SDHNUM
&    As [XENT]


Local Char CRIT (150)
Local Integer NOL

CRIT= "BPCNUM>=XBPCINI and BPCNUM<=XBPCFIN"

Return

