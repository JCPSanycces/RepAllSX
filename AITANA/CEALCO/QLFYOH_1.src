#<AdxTL>@(#)0.0.0.0 $Revision$
# First test on sales order
#------------------------------------------------------------------------------#

Local Clbfile RESULT
RESULT=func TESTSUITE()
Errbox RESULT
End

Funprog TESTSUITE()

  Call ADD_TESTCASE("TEST_YLINE1","Test YLINE creation",1) From AXUNIT
  Call ADD_TESTCASE("TEST_YLINE2","Test YLINE update",1) From AXUNIT
  Call ADD_TESTCASE("TEST_YORDER","Test classes YORDER with controls",1) From AXUNIT

End func AXUNIT.RUN_TESTSUITE("Test number 1","Check the classes")

#  Optional subprog called *before* running the test suite
Subprog SETUP

# Error handling variable
  Global Integer ERROR_V

# Cleanup tables
  Gosub CLEANUP_TABLES
End

#  Optional subprog called *after* running the test suite
Subprog TEARDOWN
  Gosub CLEANUP_TABLES
End

# Cleanup the YSHIP and YORDER table where some empty records could have been created
$CLEANUP_TABLES
  Local File YORDER, YLINE
  Delete [YOH] Where ORDNUM="TST_001"
  Delete [YLI] Where ORDNUM="TST_001"
Return

$NOCLASS
ERROR_V=errn
Resume

#
# Test YORDER and YLINE
#

Subprog TEST_YLINE1()

#
# Check class YLINE (Creation)
#
  Local Instance YLINE Using C_YLINE
  Local Integer OK
  Local Integer NB_ERR
  Local Decimal EXPECTED_PRICE

  YLINE=NewInstance C_YLINE AllocGroup null
  OK=fmet YLINE.AINIT

  If OK<>[V]CST_AOK
    NB_ERR+=1
    Call LOG_LINE(" ** ERROR : AINIT method failed on YLINE") From AXUNIT
  Else
    YLINE.ORDNUM="TST_001" : YLINE.NUMLIN=1 : YLINE.NUMLIN=1

    Call LOG_LINE("Check line creation") From AXUNIT
    Onerrgo NOCLASS
    [V]ERROR_V=0
    OK=fmet YLINE.AINSERT
    Onerrgo
    If OK=[V]CST_AERROR or [V]ERROR_V<>0
      Call LOG_LINE("AINSERT method of YLINE sucessfully denied because mandatory property") From AXUNIT
      Call LOG_CLASS(YLINE,"YLINE",1) From AXUNIT
    Else
      NB_ERR+=1
      Call LOG_LINE("No mandatory properties exist in YLINE class") From AXUNIT
    Endif

    FreeGroup YLINE
    YLINE=NewInstance C_YLINE AllocGroup null
    OK=fmet YLINE.AINIT
    Local File YCUSTOMER
    Read [YBP]YBP0 First
    Local File YITEM
    Read [YIT]YIT0 First

    YLINE.ORDNUM="TST_001" : YLINE.NUMLIN=1 : YLINE.SORTLIN=1
    YLINE.ITEM=[YIT]ITMREF : YLINE.QTY=1 : YLINE.UNITPRICE=3.14 : YLINE.DISCOUNT=0
    Onerrgo NOCLASS
    [V]ERROR_V=0
    OK=fmet YLINE.AINSERT
    Onerrgo
    If OK=[V]CST_AERROR or [V]ERROR_V<>0
      NB_ERR+=1
      Call LOG_LINE("YLINE creation method failed") From AXUNIT
      Call LOG_CLASS(YLINE,"YLINE",1) From AXUNIT
    Endif
    FreeGroup YLINE
  Endif
  Call CHECK_EQUAL(NB_ERR,0) From AXUNIT
End

Subprog TEST_YLINE2()

#
# Check class YLINE (Update)
#
  Local Instance YLINE Using C_YLINE
  Local Integer OK
  Local Integer NB_ERR

  YLINE=NewInstance C_YLINE AllocGroup null
  Call LOG_LINE("Check line read") From AXUNIT
  Onerrgo NOCLASS
  [V]ERROR_V=0
  OK=fmet YLINE.AREAD("TST_001",1)
  Onerrgo
  If OK=[V]CST_AERROR or [V]ERROR_V<>0
    NB_ERR+=1
    Call LOG_LINE(" ** ERROR: cannot read a line previously created") From AXUNIT
  Else
    Onerrgo NOCLASS
   [V]ERROR_V=0
    OK=fmet YLINE.AUPDATE
    Onerrgo
    If OK=[V]CST_AERROR or [V]ERROR_V<>0
      NB_ERR+=1
      Call LOG_LINE("Update was impossible") From AXUNIT
      FreeGroup YLINE
      YLINE=NewInstance C_YLINE AllocGroup null
      OK=fmet YLINE.AREAD("TST_001",1)
    Endif
    Call LOG_LINE("Update discount value") From AXUNIT
    YLINE.DISCOUNT=20
    Onerrgo NOCLASS
   [V]ERROR_V=0
    OK=fmet YLINE.AUPDATE
    Onerrgo
    If OK=[V]CST_AERROR or[V]ERROR_V<>0
      NB_ERR+=1
      Call LOG_LINE("Update was not allowed") From AXUNIT
      FreeGroup YLINE
      YLINE=NewInstance C_YLINE AllocGroup null
      OK=fmet YLINE.AREAD("TST_001",1)
    Endif

    Call LOG_LINE("Check discount value") From AXUNIT
    If YLINE.DISCOUNT<>20
      NB_ERR+=1
      Call LOG_LINE("Discount was not udated") From AXUNIT
      FreeGroup YLINE
      YLINE=NewInstance C_YLINE AllocGroup null
      OK=fmet YLINE.AREAD("TST_001",1)
    Endif
  Endif

  FreeGroup YLINE
  Call CHECK_EQUAL(NB_ERR,0) From AXUNIT
End

End

Subprog TEST_YORDER()

#
# Check class YORDER
#
  Local Instance YORDER Using C_YORDER
  Local Integer OK
  Local Integer NB_ERR

  Local File YLINE
  Delete [YLI] Where ORDNUM="TST_001"

  YORDER=NewInstance C_YORDER AllocGroup null
  Onerrgo NOCLASS
  [V]ERROR_V=0
  OK=fmet YORDER.AINIT
  Onerrgo
  If OK<>[V]CST_AOK or [V]ERROR_V<>0
    NB_ERR+=1
    Call LOG_LINE(" ** ERROR : AINIT method failed on YORDER") From AXUNIT
  Else
    YORDER.ORDNUM="TST_001"
    YORDER.ORDDAT=[0/0/0] : YORDER.CUSTOMER="" : YORDER.FCY="" : YORDER.CURRENCY=""
    Onerrgo NOCLASS
    [V]ERROR_V=0
    OK=fmet YORDER.AINSERT
    Onerrgo
    If [V]ERROR_V<>0
      NB_ERR+=1
      Call LOG_LINE("No insertion method available on YORDER") From AXUNIT
    Else
      If OK<>[V]CST_AERROR
        NB_ERR+=1
        Call LOG_LINE("Insertion was not denied despiste mandatory fields were not filled") From AXUNIT
      Else
        FreeGroup YORDER
        YORDER=NewInstance C_YORDER AllocGroup null
        OK=fmet YORDER.AINIT
        YORDER.ORDNUM="TST_001"
        Local File YCUSTOMER : Read [YBP]YBP0 First
        Local File YITEM     : Read [YIT]YIT0 First
        Local File FACILITY  : Read [FCY]FCY0 First
        Local File TABCUR Where CURENDDAT=[0/0/0] : Read [TCU]TCU0 First
        YORDER.ORDDAT=date$ : YORDER.CUSTOMER=[YBP]BPCNUM : YORDER.FCY=[FCY]FCY : YORDER.CURRENCY=[TCU]CUR
        Call LOG_LINE("Check line adding on an order") From AXUNIT
        OK=fmet YORDER.ADDLINE("LINES",[V]CST_ALASTPOS)
        If OK=[V]CST_ANOTDEFINED
          NB_ERR+=1
          Call LOG_LINE(" ** ERROR : ADDLINE method failed on YORDER") From AXUNIT
        Else
          YORDER.LINES(OK).ITEM=[YIT]ITMREF : YORDER.LINES(OK).QTY=1 : YORDER.LINES(OK).UNITPRICE=3.14
          OK=fmet YORDER.AINSERT
          If OK=[V]CST_AERROR
            NB_ERR+=1
            Call LOG_LINE("Error at order creation") From AXUNIT
            Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
          Else
            Call LOG_LINE("Order successfully created") From AXUNIT
          Endif
        Endif
      Endif
    Endif
  Endif
  FreeGroup YORDER

  YORDER=NewInstance C_YORDER AllocGroup null
  Onerrgo NOCLASS
  [V]ERROR_V=0
  OK= fmet YORDER.AREAD("TST_001")
  Onerrgo
  If OK=[V]CST_AERROR or [V]ERROR_V<>0
    NB_ERR+=1
    Call LOG_LINE("Read failed on YORDER") From AXUNIT
  Endif
  If YORDER.ORDDAT<>date$ or YORDER.CUSTOMER<>[YBP]BPCNUM or YORDER.FCY<>[FCY]FCY or YORDER.CURRENCY<>[TCU]CUR
& or YORDER.LINES(1).ITEM<>[YIT]ITMREF or YORDER.LINES(1).QTY<>1 or YORDER.LINES(1).UNITPRICE<>3.14
    NB_ERR+=1
    Call LOG_LINE("Reading the order does not return the right values") From AXUNIT
    Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
  Else
    Call LOG_LINE("Update the previous order") From AXUNIT
    YORDER.LINES(1).QTY=2
    YORDER.ORDDAT=date$-1
    Onerrgo NOCLASS
    [V]ERROR_V=0
    OK= fmet YORDER.AUPDATE
    Onerrgo
    If OK<>[V]CST_AOK or [V]ERROR_V<>0
      NB_ERR+=1
      Call LOG_LINE("Update on order failed") From AXUNIT
      Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
    Else
      FreeGroup YORDER
      YORDER=NewInstance C_YORDER AllocGroup null
      OK= fmet YORDER.AREAD("TST_001")
      If YORDER.LINES(1).QTY<>2 or YORDER.ORDDAT<>date$-1
        NB_ERR+=1
        Call LOG_LINE("Reading the order after update does not return the right values") From AXUNIT
      Endif
    Endif
  Endif

  FreeGroup YORDER

  Call CHECK_EQUAL(NB_ERR,0) From AXUNIT

End

