#<AdxTL>@(#)0.0.0.0 $Revision$
# ZORDER Class

# GLOBAL METHODS AND EVENTS ASSOCIATED TO THE CLASS
$METHODS
  Case [L]CURPTH
    When "LINES" : # Lines methods
      Case [L]ACTION
        When "ADELLINE_BEFORE" : Gosub CONTROL_DELETION_LINE                              : # Controls before line deletion
        When "ADELLINE_AFTER"  : Gosub LINE_DELETION                                      : # Additional actions when line is deleted
      Endcase
    When ""      : # Order class methods
      Case [L]ACTION
        When "TOTAMOUNT"  : Gosub TOTAMOUNT                                               : # When the TOTAMOUNT method is called
        When "SHIP"       : Gosub SHIP From ZSHIP                                         : # When the shipment method is called
        When "DISC_ERASE" : Gosub DISC_ERASE                                              : # When the discount erase method is called
        When "AINSERT_CONTROL_BEFORE" : Gosub SET_ORDNUM                                  : # When order creation is requested
          Gosub AUPDATE_CONTROL_BEFORE                                                    : # Global controls for creation and update
        When "AUPDATE_CONTROL_BEFORE"                                                     : # When order update is requested
          Gosub AUPDATE_CONTROL_BEFORE                                                    : # Global controls for creation and update
      Endcase
  Endcase
Return

# DIFFERENT ROUTINES ASSOCIATED TO THE GLOBAL METHODS

# When delivered quantity is not null, deletion of a line is forbidden
$CONTROL_DELETION_LINE
  If this.LINES(ALINE).DLVQTY>0
    ASTATUS=fmet this.ASETERROR("","Shipped line cannot be deleted",[V]CST_AERROR)
  Endif
Return

# The supervisor handles automatically a line deletion, but we can set the quantity to 0
$LINE_DELETION
  this.QTY=0
Return

# Loop on all the lines to erase the discount
$DISC_ERASE
  For I=1 To maxtab(this.LINES)
    this.LINES(I).DISCOUNT=0
  Next I
Return

# Grand total amount computation : use the sum operator on the LINES collection for PRICE property
$TOTAMOUNT
  ARET_VALUE=sum(0,this.LINES(1..maxtab(this.LINES)).PRICE)
Return

# Assignment of technical properties
$AUPDATE_CONTROL_BEFORE

# Firstly, let's set the shipment status according to shipped quantities
  Local Integer MAXL       : MAXL=maxtab(this.LINES)                       : # Maximum line number entered
  Local Decimal SUM_QTY    : SUM_QTY=sum(0,this.LINES(1..MAXL).QTY)        : # Total ordered quantities
  Local Decimal SUM_DLVQTY : SUM_DLVQTY=sum(0,this.LINES(1..MAXL).DLVQTY)  : # Total shipped quantities

  If SUM_DLVQTY=0 : # No line shipped ?
    this.ORDSTA=1 : # Not shipped
  Elsif SUM_QTY=SUM_DLVQTY : # cumulated quantities are the same ?
    this.ORDSTA=3 : # Totally shipped
  Else this.ORDSTA=2 : # Partially shipped
  Endif

# Secondly, let's compute the grand total by calling the corresponding method
  this.TOTAL=fmet this.TOTAMOUNT

# Thirdly, set ORDLIN with the order
#          and NUMLIN that is the reference to the line and must be different for every line (a new line is assigned with max +1)
  For I=1 To MAXL : # Lines pointer assignment
    this.LINES(I).SORTLIN= this.LINES(I).AORDER
    this.LINES(I).ORDNUM=this.ORDNUM
    If this.LINES(I).NUMLIN=0
      this.LINES(I).NUMLIN=max(this.LINES(1..MAXL).NUMLIN)+1
    Endif
  Next I
Return

# Set a default order number if not assigned by using the last number + 1
$SET_ORDNUM
  If this.ORDNUM=""
  Local File ZORDER
    Read [ZOH]ZOH0 Last
    If fstat<>[V]CST_AOK
      this.ORDNUM="00000001"
    Else
      this.ORDNUM=format$("N0:8",val([ZOH]ORDNUM)+1)
    Endif
  Endif
Return


# RULES ASSOCIATED TO THE PROPERTIES
$PROPERTIES
  Case [L]CURPRO
    When "CUSTOMER"       : Gosub CUSTOMER
    When "ORDDAT"         : Gosub ORDDAT
  Endcase
Return

# On customer: the modification is forbidden if the order has already been shipped
#              if the customer is modified, set the currency with the default customer currency
$CUSTOMER
  Case ACTION
    When "CONTROL"
      If this.snapshot.CUSTOMER<>this.CUSTOMER
        If max(0,this.LINES(1..maxtab(this.LINES)).DLVQTY)>0
          ASTATUS=fmet this.ASETERROR(CURPRO,"Customer cannot be changed",[V]CST_AERROR)
        Endif
      Endif
    When "PROPAGATE"
      Local File BPCUSTOMER
      Read [BPC]BPC0=this.CUSTOMER
      this.CURRENCY=[BPC]CUR
  Endcase
Return

# Default value on order date is the current date
$ORDDAT
  Case ACTION
    When "INIT"
      this.ORDDAT=date$
  Endcase
Return

#**
#* Label for coding event of CRUD
#* @param CURPTH Local Char(250), contains the class path
#* @param AEVENT Local Char(20), contains the event code
#* @return ASTATUS Local Integer
#*!
$EVENTS
#Case [L]CURPTH
#   When ""
#    Case [L]AEVENT
#    Endcase
#Endcase
Return


#**
#* Label for coding your operations
#* @param AOPERATION Local Char(20), contains the operation code
#* @return ARET_VALUE (the type of the return value is declared in the method)
#*!
$OPERATIONS
#Case [L]AOPERATION
#Endcase
Return

