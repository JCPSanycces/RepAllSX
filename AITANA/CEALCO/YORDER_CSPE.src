#<AdxTL>@(#)0.0.0.0 $Revision$ 
$PROPERTIES : # Events related to property rules : CURPRO is the current property
  Case [L]CURPRO
    When "CUSTOMER"
      If ARULE="PROPAGATE"
        Local File YCUSTOMER [CUST]
        Read [CUST]YBP0=this.CUSTOMER
        this.CURRENCY=[CUST]CUR
      Endif
    When "ORDDAT"
      If ARULE="INIT"      : this.ORDDAT=date$ : Endif
    When "ORDSTA"
      If ARULE="INIT"      : this.ORDSTA=1     : Endif
    When "LINES.ITEM"
      If ARULE="PROPAGATE" : this.UNITPRICE=func YPRICE.PRICE(this.ITEM,this.APARENT.CURRENCY) : Endif
  Endcase
Return

# Events related to class methods: CURPTH is the instance, AEVENT the method code
$EVENTS
  Case [L]CURPTH
    When ""
      Case [L]AEVENT
        When "AUPDATE_CONTROL_BEFORE"
          Gosub SET_POINTERS
        When "AUPDATE_CONTROL_AFTER"
          this.TOTAL=fmet this.TOTAMOUNT()
        When "AINSERT_CONTROL_BEFORE"
          If this.ORDNUM="" : Gosub INIT_ORDNUM : Endif
          Gosub SET_POINTERS
          this.TOTAL=fmet this.TOTAMOUNT()
        When "AINSERT_CONTROL_AFTER"
          this.TOTAL=fmet this.TOTAMOUNT()
      Endcase
  Endcase
Return

# Get a counter value
$INIT_ORDNUM
Local Char MESSAGE(250)
Local Integer OK
  OK=func ANM_TOOL.NUMERO(GACTX,"YOH",this.FCY,this.ORDDAT,"",this.ORDNUM,MESSAGE)
  If OK=[V]CST_AERROR
    ASTATUS=fmet this.ASETERROR("",MESSAGE,OK)
  Endif
Return

# Set technical pointers:
# NUMLIN is the line reference. Technical, must be different for every line (if 0, we assign max + 1)
# SORTLIN is the sorting order for the line. Assigned with the technical property called AORDER
$SET_POINTERS
  Local Integer MAXL : MAXL=maxtab(this.LINES)  : # Maximum line number entered
  For I=1 To MAXL : # Lines pointer assignment
    this.LINES(I).ORDNUM=this.ORDNUM
    this.LINES(I).SORTLIN=this.LINES(I).AORDER
    If this.LINES(I).NUMLIN=0 : this.LINES(I).NUMLIN=max(this.LINES(1..MAXL).NUMLIN)+1 : Endif
  Next I
Return

# Label associated to methods: AMETHOD is the method name
$METHODS
  Case AMETHOD
    When "TOTAMOUNT"              : # Compute the total amount by summing the price on all lines
      ARET_VALUE=ar2(sum(0,this.LINES(1..maxtab(this.LINES)).PRICE))
    When "DISC_ERASE"             : # Erase all the discounts
      Local Integer I
      For I=1 To maxtab(this.LINES) : this.LINES(I).DISCOUNT=0 : Next I
  Endcase
Return

# Label associated to operations: AOPERATION is the event name
$OPERATIONS
  Case AOPERATION
  Endcase
Return

#$ACTION:AEVENT=ACTION: Gosub EVENTS: AOPERATION=ACTION: Gosub OPERATIONS: AMETHOD=ACTION: Goto METHODS

