#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Use of REST web services and mongoDB APIs

# CALL A WEB SERVICE TO DISPLAY THE SHIPMENT POST OF A JSON STRUCTURE DESCRIBING THE SHIPMENT ON AN HTTP SERVER (SUB-ADRESS /shipment)
$PUBLISH

# Variable declarations
Local Clbfile SHIPMENT_STRING(2), SHIPMENT_JSON(2)
Local Char PCOD(100)(1..10),PVAL(100)(1..10),HCOD(100)(1..10),HVAL(100)(1..10)
Local Clbfile RESHEAD(0),RESBODY(0)

  # Store the shipment in JSON format in a string: YSCRIPT.STRINGIFY stringifies its argument
  SHIPMENT_JSON=func STRINGIFY(SHIPMENT) : SHIPMENT_STRING='"'+escJson(SHIPMENT_JSON)+'"'

  # Call the web service with the corresponding argument : OK returns http status that is 200 if OK
  OK=func ASYRRESTCLI.EXEC_REST_WS("SHIPMENT","POST","/shipment",PCOD, PVAL, HCOD, HVAL, SHIPMENT_STRING, 0, "", RESHEAD, RESBODY)
Return


# CALL A WEB SERVICE TO GET THE PRICE OF AN ITEM GET A JSON STRUCTURE DESCRIBING THE PRINCE ON AN HTTP SERVER (SUB-ADRESS /PRICES)
Funprog PRICE(ITEM)
Variable Char ITEM()
Local Integer RETVAL,I, FUTURE : Local Decimal PRICE

# No additional parameter nor aditional header value are given here (only the values given in EXTERNAL definition are used)
Local Char PCOD(100)(1..10),PVAL(100)(1..10),HCOD(100)(1..10),HVAL(100)(1..10)
Local Clbfile DATA_SENT(0)

# Contains the result header and body
Local Clbfile RESHEAD(0),RESBODY(0)

  DATA_SENT="{}" : # No data is sent
  FUTURE=0       : # We wait for the answer
  RETVAL=func ASYRRESTCLI.EXEC_REST_WS("SHIPMENT","GET","/prices/"+ITEM,PCOD, PVAL, HCOD, HVAL, DATA_SENT, FUTURE, "price",RESHEAD, RESBODY)
  RESBODY=vireblc(RESBODY,4)

  # The service returns { "item" : ITEM_CODE, "price" : PRICE_VALUE } if http status is 200 (OK)
  # But here we requested only the value of "price"
  If RETVAL=200
    PRICE=val(RESBODY)
  Else
    PRICE=0
  Endif
End PRICE

# CALL AN API TO PUBLISH THE SHIPMENT IN MONGODB
$DOCUMENT

# Variables declarations
Local Char FILE_NAME(200), FILE_TITLE(200)
Local Clbfile TEXT
Local Char PROPS_COD(20)(1..2) : Local Char PROPS_VAL(100)(1..2)
Local Clbfile RESHEAD(0), DATA(0)
Local Char ID(36)
Local Blbfile BYTES(0)
Local Integer IS_ASCII : IS_ASCII=50
Local Char CRLF : CRLF=chr$(13)+chr$(10)
Local Integer I

FILE_NAME="Shipment-"+this.ORDNUM+".txt"
FILE_TITLE="Order for customer"-this.CUSTOMER-"dated"-format$("D:DD[/]MM[/]YYYY",this.ORDDAT)

# Let's fill the text:
  TEXT+="Order #"+this.ORDNUM-"dated"-format$("D<:12M[ ]2D[, ]4Y",this.ORDDAT)+CRLF
  TEXT+="---------------------------------------------------------------------"+CRLF
  TEXT+=" Item          Qty"+CRLF
  For I=1 To maxtab(SHIPMENT.SHIPLINES)
    TEXT+=format$("K:15X",SHIPMENT.SHIPLINES(I).ITEM)+format$("N:5",SHIPMENT.SHIPLINES(I).QTY)+CRLF
  Next I
  TEXT+=CRLF+"Total amount:"-format$("N:9.2",SHIPMENT.DLVTOTAL)+CRLF

# The document will be read-only
  Raz PROPS_COD, PROPS_VAL
  PROPS_COD(1)="isReadOnly" : PROPS_VAL(1)='true'

# The content must be stored in a blob containing ASCII
  OK=strEncode(TEXT,BYTES,IS_ASCII)

# Let's create the document. If everything is OK, OK is equal to 200 and ID contains the ID of the document
  OK = func ASYRSAREA.WRITEALL(BYTES,FILE_TITLE,FILE_NAME, "text/plain", PROPS_COD, PROPS_VAL, ID, 'LOG', 0, RESHEAD, DATA)
Return




# TECHNICAL FUNCTION THAT STRIGINFIES AN INSTANCE AS A JSON

Funprog STRINGIFY(STRUCTURE)
End func STRINGIFYL(STRUCTURE,0)

Funprog STRINGIFYL(STRUCTURE,LEVEL)
Value Integer LEVEL
Local Clbfile CHAINE,CHAINE1
Local Char PROG(100)
Local Integer I,J,K,L,N

PROG="func"-seg$(adxpno(0),instr(1,adxpno(0),"/")+1,instr(1,adxpno(0),"$")-1)+ ".STRINGIFYL"

If dim(STRUCTURE,0)>1
  End "**Error too many dimensions**"
Endif

If dim(STRUCTURE)>1
  CHAINE="[ "
  If dim(STRUCTURE)=32767
    L=maxtab(STRUCTURE)
    For I=0 To L
      If (type(STRUCTURE)=524 and STRUCTURE(I)<>null) or type(STRUCTURE)<>524 : Gosub ADD_MEMBER : Endif
      CHAINE+=string$(I<L,", ")
    Next I
  Else
    L=dim(STRUCTURE,-1)+dim(STRUCTURE,1)-1
    For I=dim(STRUCTURE,-1) To L
      Gosub ADD_MEMBER
      CHAINE+=string$(I<L,", ")
    Next I
  Endif
  CHAINE+=" ]"
Else
  I=0
  Gosub ADD_MEMBER
Endif
End CHAINE

$ADD_MEMBER
Case type(STRUCTURE)
  When 1,2,4,5,6,7 : CHAINE+=num$(STRUCTURE(I))
  When 3 : CHAINE+= '"'+format$("D:4Y[-]MM[-]DD",STRUCTURE(I))+'"'
  When 522 : K=b64Encode(STRUCTURE(I),CHAINE1) : CHAINE+= "'"+CHAINE1+"'"
  When 524 : LEVEL+=1 : CHAINE+="{ "+chr$(10)+space$(3*LEVEL) : N=0 :
             K=STRUCTURE(I).ObjectNbs
             For J=1 To K
               If find(STRUCTURE(I).ObjectVar(J),"AATTRIBUTES","ACTX","AERROR","AINF","AKEYS","AORDER","APARENT","ASTALIN","AUUID")=0
&              and ((LEVEL=1) or find(STRUCTURE(I).ObjectVar(J),"CREDATTIM","UPDDATTIM","CREUSR","UPDUSR")=0)
                 CHAINE+=string$(N>0,","+chr$(10)+space$(3*LEVEL)) : N+=1
                 CHAINE+='"'+STRUCTURE(I).ObjectVar(J)+'" : '+evalue(PROG+"(STRUCTURE(I)."+STRUCTURE(I).ObjectVar(J)+",LEVEL)")
               Endif
             Next J
             LEVEL=max(LEVEL-1,0)
             CHAINE+=chr$(10)+space$(3*LEVEL)+" }"
  When 525,526 : CHAINE+='"'+num$(STRUCTURE(I))+'"'
  When Default : CHAINE+= '"'+escJson(STRUCTURE(I))+'"'
 Endcase
 Return


