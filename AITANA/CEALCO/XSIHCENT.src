#<AdxTL>@(#)0.0.0.0 $Revision$
##================================================================================
## XQ003: GAO(03/09/2018) GAP 010 Factura centralizada.
##================================================================================
#Gosub $OK
#End
$ACTION
  Case ACTION
    When "SETBOUT"    : Gosub SETBOUT
    When "AVANTBOUT"  : Gosub AVANTBOUT
    When "EXEC"       : Gosub EXEC
    When "OK"         : Gosub OK
    When Default
  Endcase
Return
##================================================================================
$OK
  #Inicio de la traza del proceso
  Gosub INICIO_TRAZA

  #Definición de variables
  Gosub DEF_VARIABLES

  #Creación del fichero para importación
  Gosub CREA_FICHERO

  #Generación de facturas de ventas asociadas
  Gosub CREA_SIH

  #Recalcula los elementos de facturación de la factura de venta, y vencimientos
  Gosub ACT_SIH_EF

  #Fin de la traza del proceso
  Gosub FIN_TRAZA
Return
##================================================================================
$INICIO_TRAZA
  #Proceso de creación de facturas de ventas asociadas
  Call OUVRE_TRACE(mess(3,6000,1)) From LECFIC

  Call ECR_TRACE("=============================================================",0) From GESECRAN
  #Inicio del proceso
  Call ECR_TRACE(mess(1,6000,1)-format$("D:DD[-]MM[-]YY",date$)+"/"+time$,0)        From GESECRAN
  Call ECR_TRACE("=============================================================",0) From GESECRAN
Return
##================================================================================
$FIN_TRAZA
  Call ECR_TRACE("=============================================================",0) From GESECRAN
  #Fin del proceso
  Call ECR_TRACE(mess(2,6000,1)-format$("D:DD[-]MM[-]YY",date$)+"/"+time$,0)        From GESECRAN
  Call ECR_TRACE("=============================================================",0) From GESECRAN

  Call FERME_TRACE From LECFIC
  Call LEC_TRACE   From LECFIC
Return
##================================================================================
$DEF_VARIABLES
  Local Char WFICHERO(250), NOMBREFICH(30), V_SEP(1)
  Local Char CRITERIO1(250),CRITERIO2(250)
  Local Char V_SALFCY(5),V_INVTYP(5),V_SIHNUM(20),V_BPCINV(20),V_CUR(5),V_ACCDAT(10),V_EF_SALFCY(5),V_EF_SIHNUM(20)
  Local Char V_XBPSASOC(20),V_XPIHASOC(20), V_STRDUDDAT(10),V_SIVTYP(10),V_ACTEF(1)
  Local Char V_ITMREF(20),V_ITMDES(35),V_SAU(5)
  Local Decimal V_QTY,V_NETPRI,V_DTAAMT,V_EF_IMPORTEAI,V_EF_BASE
  Local Integer NUMSIH,NUMLINDUD,SIH_NUMTOTDUD,PIH_NUMTOTDUD,MAYOR_NUMDUD
  Local Shortint NUMDIAS,V_DTA,ZEJERCICIO,ZPERIODO,CONT_DUD,JJDTA
  Local Date V_FECHAFICHERO, DUDCALCDATE, FECHCALCULO,PRIMERVTO_PIH
  Local Tinyint ESCRIBE_OK
  Local Decimal DUDAMT_PIH(10), DUDAMT_SIH, ACUMULADO_DUD, RECARGO_TOT, RECARGO_DUD(10), REC_PARCIAL, REC_DUD, IMPORTE_DTAAMT

  Gosub RAZ_VARIABLES
  Raz V_SEP
  Raz WFICHERO, NOMBREFICH, CRITERIO1, CRITERIO2

  V_SEP = ';'

  If !clalev([F:ZPIH]) : Local File PINVOICE   [ZPIH] : Endif  #Cabecera factura compras
  If !clalev([F:ZPID]) : Local File PINVOICED  [ZPID] : Endif  #Líneas factura compras
  If !clalev([F:ZITM]) : Local File ITMMASTER  [ZITM] : Endif  #Artículos
  If !clalev([F:ZSIH]) : Local File SINVOICE   [ZSIH] : Endif  #Facturas ventas
  If !clalev([F:ZSIV]) : Local File SINVOICEV  [ZSIV] : Endif  #Facturas ventas
  If !clalev([F:ZDUD]) : Local File GACCDUDATE [ZDUD] : Endif  #Vencimientos
  If !clalev([F:ZTPT]) : Local File TABPAYTERM [ZTPT] : Endif  #Condiciones de pago
  If !clalev([F:ZBPC]) : Local File BPCUSTOMER [ZBPC] : Endif
  If !clalev([F:ZCPY]) : Local File COMPANY    [ZCPY] : Endif
  If !clalev([F:ZPVF]) : Local File PVCRFOOT   [ZPVF] : Endif  #Elementos de facturación fact. compras
  If !clalev([F:ZSVF]) : Local File SVCRFOOT   [ZSVF] : Endif  #Elementos de facturación fact. ventas
  If !clalev([F:ZSVV]) : Local File SVCRVAT    [ZSVV] : Endif  #Impuestos fact. ventas
  If !clalev([F:ZDUD2]): Local File GACCDUDATE [ZDUD2]: Endif  #Vencimientos
  If !clalev([F:ZDUD3]): Local File GACCDUDATE [ZDUD3]: Endif  #Vencimientos
  If !clalev([F:ZPER]) : Local File PERIOD     [ZPER] : Endif  #Periodos
Return
##================================================================================
$RAZ_VARIABLES
  Raz V_SALFCY,V_SIHNUM,V_BPCINV,V_CUR,V_ACCDAT,V_ITMREF,V_ITMDES,V_SAU,V_XBPSASOC,V_XPIHASOC,V_STRDUDDAT
  Raz V_QTY,V_NETPRI,V_DTA,V_DTAAMT
  Raz V_INVTYP,V_SIVTYP,ESCRIBE_OK
Return
##================================================================================
$CREA_FICHERO
  FECHA_HOY  = date$
  NOMBREFICH = "SIH_CENT_"+format$("YYYYMMDDhhmmss",datetime$)
  WFICHERO   = filpath("XCENT",NOMBREFICH,"txt","")
  Openo WFICHERO, 0               Using [XWR]
  Iomode adxirs chr$(13)+chr$(10) Using [XWR]  #Separador de registros. Fin de linea.
  Iomode adxifs ";"               Using [XWR]  #Separador de campos.
  Iomode adxium 50                Using [XWR]  #Formato de fichero. 50: ASCII, 122: UCS2, 0: UTF8
Return
##================================================================================
$CREA_SIH
  CRITERIO1 = 'find([F:ZPIH]PIVTYP,"FCC","ACC") & [F:ZPIH]STA = 3 & [F:ZPIH]XBPCASOC <> "" & [F:ZPIH]XSIHASOC = "" '
  #CRITERIO1 = 'find([F:ZPIH]PIVTYP,"FCC","ACC")                   & [F:ZPIH]XBPCASOC <> "" & [F:ZPIH]XSIHASOC = "" '
  CRITERIO2 = '[F:ZPIH]CPY = "' + [M:XCENT1]CPY + '"'

  If [M:XCENT1]FCYINI <> ''
    If [M:XCENT1]FCYFIN <> ''
      CRITERIO2 -= '& [F:ZPIH]FCY >= "' + [M:XCENT1]FCYINI + '" & [F:ZPIH]FCY <= "' + [M:XCENT1]FCYFIN + '"'
    Else
      CRITERIO2 -= '& [F:ZPIH]FCY >= "' + [M:XCENT1]FCYINI + '"'
    Endif
  Endif

  If [M:XCENT1]DATEINI <> [0/0/0]
    If [M:XCENT1]DATEFIN <> [0/0/0]
      CRITERIO2 -= '& [F:ZPIH]ACCDAT >= [M:XCENT1]DATEINI & [F:ZPIH]ACCDAT <= [M:XCENT1]DATEFIN '
    Else
      CRITERIO2 -= '& [F:ZPIH]ACCDAT >= [M:XCENT1]DATEINI '
    Endif
  Endif

  If [M:XCENT1]BPSINI <> ''
    If [M:XCENT1]BPSFIN <> ''
      CRITERIO2 -= '& [F:ZPIH]BPR >= "' + [M:XCENT1]BPSINI + '" & [F:ZPIH]BPR <= "' + [M:XCENT1]BPSFIN + '"'
    Else
      CRITERIO2 -= '& [F:ZPIH]BPR >= "' + [M:XCENT1]BPSINI + '"'
    Endif
  Endif

#If GUSER = 'DEV01'
#  CRITERIO1 = '[F:ZPIH]NUM = "FCC18A0001-000029" ' #'[F:ZPIH]NUM = "FCC18A0001-000004" '
#  CRITERIO2 = '1=1'
#Endif
  NUMSIH = 0
  #Bucle de facturas compras
  Filter [F:ZPIH] Where evalue(CRITERIO1) & evalue(CRITERIO2) Order By NUM
  For [F:ZPIH]
    #Cabecera factura
    NUMSIH += 1
    Gosub WRITE_CAB

    #Bucle de líneas
    Filter [F:ZPID] Where NUM = [F:ZPIH]NUM Order By PIDLIN
    For [F:ZPID]
      Gosub RAZ_VARIABLES
      Gosub WRITE_LIN
    Next
    Filter [ZPID]

    #Elementos de facturación
    Gosub WRITE_SVCRFOOT

    #Factura tratada
    Call ECR_TRACE(mess(4,6000,1)+":"-[F:ZPIH]NUM,0) From GESECRAN
  Next
  Filter [F:ZPIH]


  Openo Using [XWR]
#  Sleep 1

  If filinfo(WFICHERO,7)>0 Then
    #Se ha creado el fichero txt con datos.
    Call ECR_TRACE(mess(5,6000,1)-NOMBREFICH+'.txt'-"con datos"+".",0) From GESECRAN
    Gosub IMPORT_SIH
#    Gosub MOVER_FICH
    Gosub ACTUALIZA_PIH
  Else
    #No se ha procesado ninguna factura de compras, ni creado ninguna factura de ventas.
    Call ECR_TRACE(mess(11,6000,1),0) From GESECRAN
  Endif
Return
##================================================================================
$WRITE_CAB
  V_SALFCY    = [F:ZPIH]FCY
  Case [F:ZPIH]PIHTYP
    When 1,2 :     V_INVTYP = "1" : V_SIVTYP = "FCC"   #Factura
    When 3,4 :     V_INVTYP = "2" : V_SIVTYP = "ACC"   #Abono
    When Default : V_INVTYP = "1" : V_SIVTYP = "FCC"
  Endcase
  V_SIHNUM    = ""
  V_BPCINV    = [F:ZPIH]XBPCASOC
  V_CUR       = [F:ZPIH]CUR
  V_ACCDAT    = date$
  V_XBPSASOC  = [F:ZPIH]BPR
  V_XPIHASOC  = [F:ZPIH]NUM
  V_ACTEF     = '2'

  Gosub FECHA_INI_VENC
  #DUDCALCDATE = [F:ZPIH]STRDUDDAT-4    #4 días anterior al vencimiento de la factura de compras
  DUDCALCDATE = FECHCALCULO - 4         #date$-NUMDIAS
  V_STRDUDDAT = func FORMATODATE(DUDCALCDATE)


  Wrseq 'V'         + V_SEP + V_SALFCY + V_SEP + V_INVTYP + V_SEP + V_SIVTYP    + V_SEP + V_SIHNUM   + V_SEP
&      + V_BPCINV   + V_SEP + V_CUR    + V_SEP + V_ACCDAT + V_SEP + V_STRDUDDAT + V_SEP + V_XBPSASOC + V_SEP
&      + V_XPIHASOC + V_SEP + V_ACTEF Using [XWR]
Return
##================================================================================
$FECHA_INI_VENC
  #Cálculo de la fecha inicio del vencimiento
  Raz NUMDIAS, FECHCALCULO

  Read [F:ZDUD]DUD0 = [F:ZPIH]GTE;[F:ZPIH]NUM;1;1
  If !fstat
    Read [F:ZBPC]BPC0 = V_BPCINV
    If !fstat
      Read [F:ZCPY]CPY0 = [F:ZPIH]CPY
      If !fstat
        Read [F:ZTPT]TPT0 = [F:ZBPC]PTE;[F:ZCPY]LEG;1
        If !fstat
          #Fecha de cálculo para el inicio del cálculo del vencimiento: el día de hoy menos los meses y días de la condición de pago.
          FECHCALCULO = addmonth([F:ZDUD]DUDDAT,-[F:ZTPT]NBRMON) - [F:ZTPT]NBRDAY
        Else
          FECHCALCULO = date$
        Endif
      Endif
    Endif
  Else
    FECHCALCULO = date$
  Endif
Return
##================================================================================
$WRITE_LIN
  V_ITMREF = [F:ZPID]ITMREF
  V_ITMDES = [F:ZPID]ITMDES1
  V_SAU    = [F:ZPID]UOM
  V_QTY    = [F:ZPID]QTYUOM
  V_NETPRI = [F:ZPID]NETPRI

  Wrseq 'D'         + V_SEP + V_ITMREF       + V_SEP + V_ITMDES + V_SEP + V_SAU + V_SEP
&     + num$(V_QTY) + V_SEP + num$(V_NETPRI)   Using [XWR]
Return
##================================================================================
$WRITE_SVCRFOOT
  #Elementos de facturación.
  #El elemento de facturación 3 de FC se corresponde con el elemento fact. 5 de FV
  #El elemento de facturación 4 de FC se corresponde con el elemento fact. 7 de FV
  Raz V_DTA,V_DTAAMT : ESCRIBE_OK = 1

  Filter [F:ZPVF] Where VCRTYP = 8 and VCRNUM = [F:ZPIH]NUM Order By IND
  For [F:ZPVF]
    Case [F:ZPVF]INVDTA
      When 3       : ESCRIBE_OK = 2 : V_DTA = 5 : V_DTAAMT = [F:ZPVF]INVDTAAMT*(-1)
      When 4       : ESCRIBE_OK = 2 : V_DTA = 7 : V_DTAAMT = [F:ZPVF]INVDTAAMT*(-1)
      When Default : ESCRIBE_OK = 1
    Endcase

    If ESCRIBE_OK = 2
      Wrseq 'F' + V_SEP + num$(V_DTA) + V_SEP + num$(V_DTAAMT) Using [XWR]
    Endif
  Next
  Filter [F:ZPVF]

  Wrseq 'F' + V_SEP + '1' + V_SEP + '0' Using [XWR]
  Wrseq 'F' + V_SEP + '2' + V_SEP + '0' Using [XWR]
  Wrseq 'F' + V_SEP + '3' + V_SEP + '0' Using [XWR]
  Wrseq 'F' + V_SEP + '4' + V_SEP + '0' Using [XWR]
  #Wrseq 'F' + V_SEP + '6' + V_SEP + '0' Using [XWR]
  Wrseq 'F' + V_SEP + '8' + V_SEP + '0' Using [XWR]
Return
##================================================================================
$IMPORT_SIH
  #Para poder importar con el SAS marcado
  If clalev([M:IMP2])=0 : Local Mask IMPOBJ2 [IMP2] : Endif
  Raz [M:IMP2]

  [M:IMP2]MODIMP = "XSIH1"
  [M:IMP2]NOMIMP = WFICHERO
  [M:IMP2]TYPEXP = 2
  [M:IMP2]AOWSTA = 2  #SAS

  Call IMPORTSIL([M:IMP2]MODIMP,[M:IMP2]NOMIMP) From GIMPOBJ

  If [M:IMP2]STAT or GOK<1 Then
    # (Process error). #Importación del fichero con errores
    Call ECR_TRACE(mess(7,6000,1)+":"-NOMBREFICH,1) From GESECRAN
  Else
    # (Success). Importación del fichero OK
    Call ECR_TRACE(mess(6,6000,1)+":"-NOMBREFICH,0) From GESECRAN
  Endif
Return
##================================================================================
$ACTUALIZA_PIH
  Filter [F:ZPIH] Where evalue(CRITERIO1) & evalue(CRITERIO2) Order By NUM
  Trbegin [F:ZPIH]
    For [F:ZPIH]
      Read [F:ZSIH]SPE_SIH1 = [F:ZPIH]NUM
      If !fstat
        Read [F:ZSIV]SIV0 = [F:ZSIH]NUM
        If !fstat
          [F:ZPIH]XSIHASOC = [F:ZSIH]NUM
          Rewrite [F:ZPIH]
        Endif
      Endif
    Next
  Commit
  Filter [F:ZPIH]
Return
##================================================================================
$MOVER_FICH
  Local Integer STAT2

  FICH_ORI = filpath("XCENT",NOMBREFICH,"txt")
  FICH_DES = filpath("XCENT\IMPORTED",NOMBREFICH,"txt")
  Call MOVE(FICH_ORI,FICH_DES,STAT2)From ORDSYS
Return
##================================================================================
Funprog FORMATODATE(ZFD)
  Variable Date ZFD
  Local Char DIA(2),MES(2),ANNO(4)
  Local Char CADENA(10)

  DIA = '' : MES = '' : ANNO = ''
  DIA = num$(day(ZFD)) : MES = num$(month(ZFD)) : ANNO = num$(year(ZFD))

  If day(ZFD) >= 1 and day(ZFD) <= 9 : DIA = '0'+DIA : Endif
  If month(ZFD) >= 1 and month(ZFD) <= 9 : MES = '0'+MES : Endif

  CADENA = ANNO + MES + DIA
End CADENA
##================================================================================
$ACT_SIH_EF
  Local Decimal V_IMPORT
  Local Integer XTIPO
  Raz V_IMPORT,XTIPO,V_EF_BASE,V_EF_IMPORTEAI

  #Fichero para actualizar el EF 6 (Rec FCC) de las facturas
  FECHA_HOY  = date$
  NOMBREFICH = "SIH_CENT_EF_"+format$("YYYYMMDDhhmmss",datetime$)
  WFICHERO   = filpath("XCENT",NOMBREFICH,"txt","")
  Openo WFICHERO, 0               Using [XZR]
  Iomode adxirs chr$(13)+chr$(10) Using [XZR]  #Separador de registros. Fin de linea.
  Iomode adxifs ";"               Using [XZR]  #Separador de campos.
  Iomode adxium 50                Using [XZR]  #Formato de fichero. 50: ASCII, 122: UCS2, 0: UTF8


  #Filtramos las facturas de ventas a actualizar los EF
  CRITERIO1 = '[F:ZSIH]XACTEF = 2 '
  Filter [F:ZSIH] Where evalue(CRITERIO1) Order By NUM
  For [F:ZSIH]
    Raz V_EF_BASE, V_EF_IMPORTEAI, V_DTAAMT, XTIPO

    Read [F:ZSIV]SIV0 = [F:ZSIH]NUM
    If !fstat
      V_EF_SALFCY = [F:ZSIV]SALFCY
    Endif
    V_EF_SIHNUM = [F:ZSIH]NUM

#Call ECR_TRACE("factV:"-[F:ZSIH]NUM,0) From GESECRAN
    #Cabecera
    Wrseq 'V' + V_SEP + V_EF_SALFCY + V_SEP + V_EF_SIHNUM Using [XZR]

    #EF
    Filter [F:ZSVV] Where VCRNUM = V_EF_SIHNUM Order By VAT
    For [F:ZSVV]
      V_EF_BASE += [F:ZSVV]VATGRO   #Importe base de la factura de ventas
    Next
    Filter [F:ZSVV]

    V_EF_IMPORTEAI = V_EF_BASE
    Filter [F:ZSVF] Where VCRNUM = V_EF_SIHNUM and find([F:ZSVF]DTA,1,2,3,4,5,7) Order By DTA
    For [F:ZSVF]
      V_EF_IMPORTEAI = V_EF_IMPORTEAI + [F:ZSVF]DTANOT    #Importe en cascada (calculado en los demás EF)
    Next
    Filter [F:ZSVF]

    If [F:ZSIH]SIVTYP = '2'
      XTIPO = 5  #abono
    Else
      XTIPO = 4  #factura
    Endif

    Read [F:ZSVF]SVF0 = V_EF_SIHNUM;XTIPO;6
    If !fstat
      #Para el EF 6 (Rec FCC) actualizamos sus importes, ya que hay que aplicar el porcentaje en cascada
      V_IMPORT = ([F:ZSVF]DTAAMT / 100) * V_EF_IMPORTEAI  #Importe en cascada aplicando el porcentaje del EF 6 sobre el importe en cascada calculado
      If V_EF_BASE <> 0
        V_DTAAMT = (V_IMPORT / V_EF_BASE) * 100           #Porcentaje a aplicar sobre la base para que tengamos como si se aplicase en cascada
      Else
        V_DTAAMT = 0
      Endif

      Wrseq 'F' + V_SEP + '6' + V_SEP + num$(V_DTAAMT) Using [XZR]
    Endif
  Next
  Filter [F:ZSIH]

  Openo Using [XZR]


  #Para poder importar con el SAS marcado
  If clalev([M:IMP2])=0 : Local Mask IMPOBJ2 [IMP2] : Endif
  Raz [M:IMP2]

  [M:IMP2]MODIMP = "XSIH2"
  [M:IMP2]NOMIMP = WFICHERO
  [M:IMP2]TYPEXP = 2
  [M:IMP2]AOWSTA = 2  #SAS

  Call IMPORTSIL([M:IMP2]MODIMP,[M:IMP2]NOMIMP) From GIMPOBJ


  #Volvemos a poner el porcentaje del elemento de facturación 6 (Rec FCC) como estaba, que es como está en el cliente.
  Trbegin [F:ZSVF],[F:ZSIV]
  Filter [F:ZSIH] Where evalue(CRITERIO1) Order By NUM
  For [F:ZSIH]
    Read [F:ZSIV]SIV0 = [F:ZSIH]NUM
    If !fstat
      Read [F:ZBPC]BPC0 = [F:ZSIV]BPCINV
      If !fstat
        If [F:ZSIH]SIVTYP = '2'
          XTIPO = 5  #abono
        Else
          XTIPO = 4  #factura
        Endif

        Read [F:ZSVF]SVF0 = [F:ZSIH]NUM;XTIPO;6
        If !fstat
          IMPORTE_DTAAMT = 0
          For JJDTA = 0 To 29
            #Buscamos el elemento facturación 6 en el cliente
            If [F:ZBPC]INVDTA(JJDTA) = 6
              IMPORTE_DTAAMT = [F:ZBPC]INVDTAAMT(JJDTA)
              Break
            Endif
          Next JJDTA

          #Call ECR_TRACE("DTAAMT(3):"-num$(IMPORTE_DTAAMT),0) From GESECRAN

          [F:ZSVF]DTAAMT = IMPORTE_DTAAMT #[F:ZBPC]INVDTAAMT(3)
          Rewrite [F:ZSVF]
          [F:ZSIV]INVDTAAMT(3) = IMPORTE_DTAAMT #[F:ZBPC]INVDTAAMT(3)
          Rewrite [F:ZSIV]
        Endif
      Endif
    Endif
  Next
  Commit

  #Vencimientos
  Gosub VENCIM

  #Desmarco el campo de actualizar EF
  Trbegin [F:ZSIH]
  Filter [F:ZSIH] Where evalue(CRITERIO1) Order By NUM
  For [F:ZSIH]
    [F:ZSIH]XACTEF = 1
    Rewrite [F:ZSIH]
  Next
  Commit
  Filter [F:ZSIH]

Return
##================================================================================
$VENCIM
  Raz NUMLINDUD, SIH_NUMTOTDUD, PIH_NUMTOTDUD, DUDAMT_PIH, DUDAMT_SIH, ACUMULADO_DUD
  Raz PRIMERVTO_PIH, RECARGO_TOT, RECARGO_DUD, REC_PARCIAL, REC_DUD, MAYOR_NUMDUD

  Filter [F:ZSIH] Where evalue(CRITERIO1) Order By NUM
  For [F:ZSIH]
    Raz NUMLINDUD, SIH_NUMTOTDUD, PIH_NUMTOTDUD, DUDAMT_PIH, DUDAMT_SIH, ACUMULADO_DUD
    Raz PRIMERVTO_PIH, RECARGO_TOT, RECARGO_DUD, REC_PARCIAL, REC_DUD, MAYOR_NUMDUD

    #Importe total del, o de los, vencimientos de la factura de ventas
    Filter [F:ZDUD] Where [F:ZDUD]TYP = [F:ZSIH]GTE and NUM = [F:ZSIH]NUM and LIG = 1 Order By NUM;LIG;DUDLIG
    For [F:ZDUD]
      SIH_NUMTOTDUD += 1            #Número total de vencimientos fact. ventas.
      DUDAMT_SIH += [F:ZDUD]AMTCUR  #Importe total de los vencimientos de la factura ventas generada.
    Next
    Filter [F:ZDUD]

    #Leo la factura de compras asociada a la de ventas actual
    Read [F:ZPIH]PIH0 = [F:ZSIH]XPIHASOC
    If !fstat
      #Importe total del, o de los, vencimientos de la factura de compras
      Filter [F:ZDUD] Where [F:ZDUD]TYP = [F:ZPIH]GTE and NUM = [F:ZPIH]NUM and LIG = 1 Order By NUM;LIG;DUDLIG
      For [F:ZDUD]
        PIH_NUMTOTDUD += 1               #Número total vencimientos fact. compras.
        DUDAMT_PIH(0) += [F:ZDUD]AMTCUR  #DUDAMT_PIH(0) tiene el importe total de los vencimientos de la factura compras.
        If [F:ZDUD]LIG = 1 and [F:ZDUD]DUDLIG = 1
          #primer vencimiento de compras
          PRIMERVTO_PIH = [F:ZDUD]DUDDAT
        Endif
      Next
      Filter [F:ZDUD]

#      If GUSER = 'DEV01'
#        Call ECR_TRACE("paso 1 DUDAMT_PIH(0):"-num$(DUDAMT_PIH(0))-" pih_numtotdud:"-num$(PIH_NUMTOTDUD),0)  From GESECRAN
#      Endif

      #Cambio la fecha del primer vencimiento de ventas
      Read [F:ZDUD2]DUD0 = [F:ZSIH]GTE;[F:ZSIH]NUM;1;1
      If !fstat
        ZEJERCICIO = 0 : ZPERIODO = 0
        Call CALCPERIOD(PRIMERVTO_PIH-4,ZEJERCICIO,ZPERIODO)

        Trbegin [F:ZDUD2]
        [F:ZDUD2]DUDDAT = PRIMERVTO_PIH-4
        [F:ZDUD2]FIY    = ZEJERCICIO
        [F:ZDUD2]PER    = ZPERIODO
        Rewrite [F:ZDUD2]
        If !fstat : Commit : Else : Rollback : Endif
      Endif

      #Si hay dos o más vencimientos en la factura de compras
      If PIH_NUMTOTDUD >= 2
        Filter [F:ZDUD] Where [F:ZDUD]TYP = [F:ZPIH]GTE and NUM = [F:ZPIH]NUM and LIG = 1 Order By NUM;LIG;DUDLIG
        For [F:ZDUD]
          #Recorremos los vencimientos de la factura de compras.
          NUMLINDUD += 1
          DUDAMT_PIH(NUMLINDUD) = [F:ZDUD]AMTCUR  #DUDAMT_PIH(i) tiene el importe del vencimiento i de la fact. compra.

          #A partir del segundo vencimiento
          If NUMLINDUD >= 2
            #Call ECR_TRACE("Vencimiento núm:"-num$(NUMLINDUD),0) From GESECRAN
            Gosub ACT_DUD
          Endif
        Next
        Filter [F:ZDUD]
      Endif
    Endif

  Next
  Filter [F:ZSIH]
Return
##================================================================================
$ACT_DUD
  #Si hay varios vencimientos en la factura de compras, los actualizo en la de ventas
  Read [F:ZDUD2]DUD0 = [F:ZSIH]GTE;[F:ZSIH]NUM;1;1   #Primer vencimiento factura de ventas.
                                                     #Para actualizarle el importe y como referencia para copiar los datos en los demas vencimientos.
  If !fstat
    #Cuando estamos en el segundo vencimiento, actualizamos el importe del primer vencimiento de la factura venta.
    If NUMLINDUD = 2
      #Reparto del recargo (diferencia entre la fact. ventas y la de compas) entre los venciminetos.
      #Lo calculo aquí porque lo repartiré si se hacen modificaciones (modif. o crear) en los vencimientos ventas.
      If SIH_NUMTOTDUD >= PIH_NUMTOTDUD
        MAYOR_NUMDUD = SIH_NUMTOTDUD
      Else
        MAYOR_NUMDUD = PIH_NUMTOTDUD
      Endif
      RECARGO_TOT = DUDAMT_SIH - DUDAMT_PIH(0)
      REC_DUD     = ar2(RECARGO_TOT/MAYOR_NUMDUD)
      REC_PARCIAL = 0
      If PIH_NUMTOTDUD >= 2 or SIH_NUMTOTDUD >= 2
        For CONT_DUD = 1 To MAYOR_NUMDUD
          If CONT_DUD = MAYOR_NUMDUD
            #último vencimiento. Meto el resto para evitar problemas de redondeos.
            RECARGO_DUD(CONT_DUD) = RECARGO_TOT - REC_PARCIAL
          Else
            RECARGO_DUD(CONT_DUD) = REC_DUD
            REC_PARCIAL          += REC_DUD
          Endif
        Next
      Endif

#      If GUSER = 'DEV01'
#        Call ECR_TRACE("sih_numtotdud:"-num$(SIH_NUMTOTDUD)-" pih_numtotdud:"-num$(PIH_NUMTOTDUD) -" mayor:"-num$(MAYOR_NUMDUD),0)  From GESECRAN
#        Call ECR_TRACE("recargo_tot:"-num$(RECARGO_TOT)-" rec_dud:"-num$(REC_DUD) -" cont_dud:"-num$(CONT_DUD),0)  From GESECRAN
#      Endif

      ACUMULADO_DUD += DUDAMT_PIH(1)

      Trbegin [F:ZDUD2]
      [F:ZDUD2]AMTCUR = DUDAMT_PIH(1) + RECARGO_DUD(1)
      Rewrite [F:ZDUD2]
      If !fstat : Commit : Else : Rollback : Endif
    Endif

    If SIH_NUMTOTDUD >= NUMLINDUD
      #Hay más de un vencimiento en la de ventas. Le actualizamos el importe y la fecha según hay en compras.
      #Por aquí pasa si también en compras hay mas de un vencimiento.
      Read [F:ZDUD3]DUD0 = [F:ZSIH]GTE;[F:ZSIH]NUM;1;NUMLINDUD   #Vencimiento actual factura de ventas, a modificar.
      If !fstat
        Trbegin [F:ZDUD3]
        [F:ZDUD3]DUDDAT   = [F:ZDUD]DUDDAT-4  #Cuatro días antes al vencimiento de compras

        If NUMLINDUD = PIH_NUMTOTDUD
          #último vencimiento. Número de vencimiento actual es igual al número total de vencimientos de compras.
          [F:ZDUD3]AMTCUR = DUDAMT_SIH - ACUMULADO_DUD
        Else
          [F:ZDUD3]AMTCUR = DUDAMT_PIH(NUMLINDUD) + RECARGO_DUD(NUMLINDUD)
          ACUMULADO_DUD  += DUDAMT_PIH(NUMLINDUD)
        Endif

        Rewrite [F:ZDUD3]
        If !fstat : Commit : Else : Rollback : Endif
      Endif
    Else
      #Creamos los sucesivos vencimientos de ventas en ZDUD3, ya que hay más vencimientos en la de compras.
      #Primero vemos el ejercico y periodo del vencimiento nuevo.
      ZEJERCICIO = 0 : ZPERIODO = 0
      Call CALCPERIOD([F:ZDUD]DUDDAT-4,ZEJERCICIO,ZPERIODO)

      Trbegin [F:ZDUD3]
      [F:ZDUD3]         = [F:ZDUD2]         #Copiamos en ZDUD3 el primer vencimiento de ventas (todos los campos) de ZDUD2
      [F:ZDUD3]DUDLIG   = NUMLINDUD         #Modificamos los campos adecuados para que sea correcta la inserción
      [F:ZDUD3]DUDDAT   = [F:ZDUD]DUDDAT-4  #Cuatro días antes al vencimiento de compras
      [F:ZDUD3]FIY      = ZEJERCICIO
      [F:ZDUD3]PER      = ZPERIODO

      If NUMLINDUD = PIH_NUMTOTDUD
        #último vencimiento.
        #Es el total de la factura de ventas menos el recargo (porque va incluido en el total),
        #menos el acumulado que va en los demás vencimientos y le sumamos su parte del recargo.
        [F:ZDUD3]AMTCUR = DUDAMT_SIH - RECARGO_TOT - ACUMULADO_DUD + RECARGO_DUD(NUMLINDUD)
      Else
        [F:ZDUD3]AMTCUR = DUDAMT_PIH(NUMLINDUD) + RECARGO_DUD(NUMLINDUD)
        ACUMULADO_DUD  += DUDAMT_PIH(NUMLINDUD)
      Endif

      [F:ZDUD3]NUMDUD   = left$([F:ZDUD2]NUMDUD,len([F:ZDUD2]NUMDUD)-1)+num$(NUMLINDUD)
      Write [F:ZDUD3]
      If fstat
        GOK=0 : Call FSTA("ZDUD3") From GLOCK
        Rollback
        #Error en GACCDUDATE
        Call ECR_TRACE("Error en el vencimiento:"-[F:ZDUD2]NUM,1)  From GESECRAN
      Else
        Commit
      Endif
    Endif
  Endif
Return
##================================================================================
Subprog CALCPERIOD(XFECHA,XFIY,XPER)
   Value Date XFECHA
   Variable Shortint XFIY
   Variable Shortint XPER

   Filter [F:ZPER] Where CPY = [F:ZSIH]CPY and LEDTYP = 1 and PERSTR <= XFECHA and PEREND >= XFECHA
   For [F:ZPER]
     XFIY = [F:ZPER]FIYNUM
     XPER = [F:ZPER]PERNUM
   Next
End
##================================================================================
$ACT_SIH_EF_OLD
  Local Decimal V_IMPORT
  Local Integer XTIPO
  Raz V_IMPORT,XTIPO,V_EF_BASE,V_EF_IMPORTEAI

  #Fichero para actualizar el EF 6 (Rec FCC) de las facturas
  FECHA_HOY  = date$
  NOMBREFICH = "SIH_CENT_EF_"+format$("YYYYMMDDhhmmss",datetime$)
  WFICHERO   = filpath("XCENT",NOMBREFICH,"txt","")
  Openo WFICHERO, 0               Using [XZR]
  Iomode adxirs chr$(13)+chr$(10) Using [XZR]  #Separador de registros. Fin de linea.
  Iomode adxifs ";"               Using [XZR]  #Separador de campos.
  Iomode adxium 50                Using [XZR]  #Formato de fichero. 50: ASCII, 122: UCS2, 0: UTF8


  #CRITERIO1 = '[F:ZPIH]NUM = "FC18A0001-000001" ' : CRITERIO2 = '1=1'
#Call ECR_TRACE("criterio1:"-CRITERIO1,0) From GESECRAN

  #Filtramos las facturas de compras seleccionadas y tenemos las facturas de ventas creadas
  Filter [F:ZPIH] Where evalue(CRITERIO1) & evalue(CRITERIO2) Order By NUM
  For [F:ZPIH]
#Call ECR_TRACE("factC:"-[F:ZPIH]NUM,0) From GESECRAN
    Read [F:ZSIH]SPE_SIH1 = [F:ZPIH]NUM
    If !fstat
      Read [F:ZSIV]SIV0 = [F:ZSIH]NUM
      If !fstat
        V_EF_SALFCY = [F:ZSIV]SALFCY
      Endif
      V_EF_SIHNUM = [F:ZSIH]NUM
#Call ECR_TRACE("factV:"-[F:ZSIH]NUM,0) From GESECRAN
      #Cabecera
      Wrseq 'V' + V_SEP + V_EF_SALFCY + V_SEP + V_EF_SIHNUM Using [XZR]

      #EF
      Filter [F:ZSVV] Where VCRNUM = V_EF_SIHNUM Order By VAT
      For [F:ZSVV]
        V_EF_BASE += [F:ZSVV]VATGRO   #Importe base de la factura de ventas
      Next
      Filter [F:ZSVV]

      V_EF_IMPORTEAI = V_EF_BASE
      Filter [F:ZSVF] Where VCRNUM = V_EF_SIHNUM and find([F:ZSVF]DTA,1,2,3,4,5,6,7) Order By DTA
      For [F:ZSVF]
        If [F:ZSVF]DTA = 6
          #Para el EF 6 (Rec FCC) actualizamos sus importes, ya que hay que aplicar el porcentaje en cascada
          V_IMPORT = ([F:ZSVF]DTAAMT / 100) * V_EF_IMPORTEAI  #Importe en cascada aplicando el porcentaje del EF 6 sobre el importe en cascada calculado
          V_DTAAMT = (V_IMPORT / V_EF_BASE) * 100             #Porcentaje a aplicar sobre la base para que tengamos como si se aplicase en cascada

#Call ECR_TRACE("[F:ZSVF]DTAAMT:"-num$([F:ZSVF]DTAAMT)-" V_EF_IMPORTEAI:"-num$(V_EF_IMPORTEAI)-" V_IMPORT:"-num$(V_IMPORT),0) From GESECRAN
#Call ECR_TRACE("V_EF_BASE:"-num$(V_EF_BASE)-" V_DTAAMT:"-num$(V_DTAAMT),0) From GESECRAN

          Wrseq 'F' + V_SEP + '6' + V_SEP + num$(V_DTAAMT) Using [XZR]
        Else
          V_EF_IMPORTEAI = V_EF_IMPORTEAI + [F:ZSVF]DTANOT    #Importe en cascada (calculado en los demás EF)
        Endif
      Next
      Filter [F:ZSVF]

    Endif
  Next
  Filter [F:ZPIH]

  Openo Using [XZR]


  #Para poder importar con el SAS marcado
  If clalev([M:IMP2])=0 : Local Mask IMPOBJ2 [IMP2] : Endif
  Raz [M:IMP2]

  [M:IMP2]MODIMP = "XSIH2"
  [M:IMP2]NOMIMP = WFICHERO
  [M:IMP2]TYPEXP = 2
  [M:IMP2]AOWSTA = 2  #SAS

  Call IMPORTSIL([M:IMP2]MODIMP,[M:IMP2]NOMIMP) From GIMPOBJ


  #Volvemos a poner el porcentaje del elemento de facturación 6 (Rec FCC) como estaba, que es como está en el cliente.
  Trbegin [F:ZSVF]
  Filter [F:ZPIH] Where evalue(CRITERIO1) & evalue(CRITERIO2) Order By NUM
  For [F:ZPIH]
    Read [F:ZSIH]SPE_SIH1 = [F:ZPIH]NUM
    If !fstat
      Read [F:ZSIV]SIV0 = [F:ZSIH]NUM
      If !fstat
        Read [F:ZBPC]BPC0 = [F:ZSIV]BPCINV
        If !fstat
          If [F:ZSIH]SIVTYP = '2'
            XTIPO = 5  #abono
          Else
            XTIPO = 4  #factura
          Endif

          Read [F:ZSVF]SVF0 = [F:ZSIH]NUM;XTIPO;6
          If !fstat
            [F:ZSVF]DTAAMT = [F:ZBPC]INVDTAAMT(3)
            Rewrite [F:ZSVF]
          Endif
        Endif
      Endif
    Endif
  Next
  Commit
  Filter [F:ZPIH]

Return
##================================================================================
$SETBOUT
Return
##================================================================================
$AVANTBOUT
Return
##================================================================================
$EXEC
Return
##================================================================================

