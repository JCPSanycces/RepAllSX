#<AdxTL>@(#)0.0.0.0 $Revision$
# Random generation of leads (1 to 3 leads per customer)

$ACTION
Case ACTION
 When "EXEC"      : Gosub EXEC
Endcase
Return

# This script is an "old fashioned" script that works even if the class does not exist
# Useful during the exercise before class has been created
# But the $EXEC_CLASS label is better
$EXEC
Local File YCUSTOMER [YBP]
Local Integer I,OK,LNUM
Local File YLEAD
LNUM=nbrecord([YLE])
For [YBP]
  If rnd(1)>0.7
    For I=1 To int(rnd(5))
      Raz [YLE]
      LNUM+=1
      [YLE]CUSTOMER=[YBP]BPCNUM
      [YLE]LEADNUM=LNUM
      [YLE]LEADDATE=date$-int(rnd(15))
      [YLE]COMMENT="Customer"-[YBP]BPCNAM-"lead #"+num$(I)
      If dim([YLE]AMOUNT)>0 : [YLE]AMOUNT=(int(1+rnd(299))*10)*10 : Endif
      Write [YLE]
    Next I
  Endif
Next
Return

# Same algorithm, but using a class instance
$EXEC_CLASS
Local File BPCUSTOMER
Local Integer I,OK,LNUM
Local Instance LEAD Using C_YLEAD
Local File YLEAD
LNUM=nbrecord([YLE])
For [BPC] Where BPCSTA=2
  If rnd(1)>0.5
    For I=1 To int(rnd(4))
      LNUM+=1
      LEAD = NewInstance C_YLEAD AllocGroup null
      OK=fmet LEAD.AINIT
      LEAD.BPCNUM=[BPC]BPCNUM
      LEAD.LEADNUM=LNUM
      LEAD.LEADDATE=date$-int(rnd(15))
      LEAD.COMMENT="Customer"-[BPC]BPCNAM-"lead #"+num$(I)
      If dim(LEAD.AMOUNT)>0 : LEAD.AMOUNT=(int(1+rnd(299))*10)*10 : Endif
      OK=fmet LEAD.AINSERT
      FreeGroup LEAD
    Next I
  Endif
Next
Return

