#informamos los parametros especificos del informe, numero de remesa y proveedor
PARAM = "numdeb"          : VALEUR = 'CSDD2001A0001000003'                     : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
PARAM = "bpr"             : VALEUR = '13001'                                   : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR

#Call EFFACE(GFICHERO,STAT) From ORDSYS

Call ETAT("ZREMESA","ZPDF","SPA",0,"",TBPAR,TBVAL) From AIMP3

Return

######################################################################################
$SENDMAIL
#Infbox "sendmail"
#Call OUVRE_TRACE("Generación mails pagos") From LECFIC

If !clalev([F:ZPAY])   : Local File PAYMENTH   [ZPAY]  : Endif #tabla pagos

Filter [F:ZPAY] Where FRMNUM= 'CSDD2001A0001000003' Order By BPR #ordenamos por tercero para asi poder controlar el cambio de proveedor
Local Char ZBPR
For [F:ZPAY]
  If ZBPR<>[F:ZPAY]BPR
    ZBPR = [F:ZPAY]BPR
    Gosub IMPRIMIR #creamos el pdf
    Sleep 10 #por seguridad y dado que la creación del informe puede llegar a tardar unos segundos
#    Gosub MAIL #enviamos el pdf
  Endif
Next

