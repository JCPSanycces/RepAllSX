#PARAM = "__CDUSER"        : VALEUR = GUSER                                     : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#PARAM = "__ADXSOL"        : VALEUR = "X3SQLPU9"                                : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
