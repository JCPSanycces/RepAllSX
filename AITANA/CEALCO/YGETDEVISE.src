#<AdxTL>@(#)0.0.0.0 $Revision$ 
Subprog HTTP_GE
 Local Clbfile RESHEAD(10)
 Local Clbfile RESBODY(10)

 Local Char HEADERCOD(64)(3)
 Local Char HEADERVAL(255)(3)
 HEADERCOD(0) = "url"
 HEADERVAL(0) = "http://footballpool.dataaccess.eu/data/info.wso?wsdl"
 HEADERCOD(1) = "method"
 HEADERVAL(1) = "GET"
 Local Clbfile BODY(0)
 BODY = '{}'
 Local Integer STATUSCODE
 STATUSCODE = func ASYRWEBSER.EXEC_HTTP(HEADERCOD, HEADERVAL, BODY, RESHEAD, RESBODY)
Infbox num$(STATUSCODE)
 End STATUSCODE



Subprog YGETDEVISE
  #--
  Local Clbfile RESHEAD(10)
  Local Clbfile RESBODY(10)
  Local Clbfile BODY(0)

  #--
  Local Char HEADERCOD(64)(3), HEADERVAL(255)(3)
  Local Integer STATUSCODE

  #--
  HEADERCOD(0) = "url"
  HEADERVAL(0) = "http://www.ecb.europa.eu/stats/eurofxref/eurofxref-daily.xml"
  HEADERCOD(1) = "method"
  HEADERVAL(1) = "GET"
  BODY = '{}'

  #--
  STATUSCODE = func ASYRWEBSER.EXEC_HTTP(HEADERCOD, HEADERVAL, BODY, RESHEAD, RESBODY)
  If STATUSCODE = 200
    Infbox "200"
  Else
    Infbox "500"
  Endif


End

$ACT_ESTADO
  #-- comprobamos si ya existe el estado para el elemento e id
  Read[F:YRE]YRE0 = I_YRESTA;C_YELEMENT;C_YID
  If !fstat : Return : Endif

  #--
  If !adxlog
    Trbegin [F:YRE]
    Gosub MAJ_YRE
    Commit
  Else
    Gosub MAJ_YRE
  Endif

Return

$MAJ_YRE
  #--
  Raz [F:YRE]
  [F:YRE]YRESTA   = I_YRESTA
  [F:YRE]YELEMENT = C_YELEMENT
  [F:YRE]YID      = C_YID
  Write [F:YRE]

Return











#<AdxTL>@(#)0.80.0.0 $Revision$
Subprog  ZGETCUR

#If filinfo(filpath("ZCUR",date$+"_zchange","csv"),7)<0
  Local Clbfile RESHEAD
  Local Clbfile RESBODY

   Local Char HEADERCOD(64)(3)
   Local Char HEADERVAL(255)(3)
   HEADERCOD(0) = "url"
   HEADERVAL(0) = "http://www.ecb.europa.eu/stats/eurofxref/eurofxref-daily.xml"
   HEADERCOD(1) = "method"
   HEADERVAL(1) = "GET"
   Local Clbfile BODY(0)
   BODY = '{}'
   Local Integer STATUSCODE
   STATUSCODE = func ASYRWEBSER.EXEC_HTTP(HEADERCOD, HEADERVAL, BODY, RESHEAD, RESBODY)
   If STATUSCODE <> 200
     Goto END_HTTP_GET
   Endif

   $END_HTTP_GET

  Gosub EXPCLOB
#Endif

End

######################################################################
$EXPCLOB

#RESBODY= right$(RESBODY,instr(1,RESBODY,"Cube currency")-1)
RESBODY= ctrans(RESBODY,">","|"+chr$(10))

Openo filpath("TRA","prueba","csv"),0 Using [EXX]
Iomode adxifs "|"        Using [EXX]
Iomode adxirs ""         Using [EXX]
Iomode adxium GASCII     Using [EXX]

Wrseq RESBODY Using [EXX]
Openi Using [EXX]

Return

