#<AdxTL>@(#)0.0.0.0 $Revision$
# Routines used by batch workflow
Funprog HEADER
Local Char HEADER(250)
  HEADER= "          Order ID  "
  HEADER+="Line "
  HEADER+="                 Item "
  HEADER+=" Qty before "
  HEADER+=" Qty after  "
End HEADER

Funprog HEADLINE
End string$(len(func HEADER),"-")

Funprog LINE
Local File YLINE
Local Char LINE(250)
  Read [YLI]YLI0=[AUD]ID1;val([AUD]ID2)
  LINE ="  "+format$("K:16X",[YLI]ORDNUM)+"  "
  LINE+=format$("N:4",[YLI]NUMLIN)+" "
  LINE+=space$(20-len([YLI]ITEM))+[YLI]ITEM+" "
  LINE+=format$("N:11",val([AUL]OVAL))+" "
  LINE+=format$("N:11",val([AUL]NVAL))+" "
End LINE


Funprog ITEM(ID1,ID2)
Variable Char ID1(),ID2()
Local File YLINE [YL]
  Read [YL]YLI0=ID1;val(ID2)
End [YL]ITEM

Funprog ITMDESC(ID1,ID2)
Variable Char ID1(),ID2()
Local File YLINE [YL],ITMMASTER [IT]
  Read [YL]YLI0=ID1;val(ID2)
  Read [IT]ITM0=[YL]ITEM

End [IT]ITMDES1

