#<AdxTL>@(#)0.0.0.0 $Revision$
##=========================================================================
## Web Service de consultas de saldos de clientes. Se devuelve un clob.
##=========================================================================
Local Clbfile Z_XML
Call XWSSALDOS("DUD","find([BPR]BPRNUM,'20005')","find([DUD]BPR,'20005')",Z_XML)
Infbox Z_XML
End
##=========================================================================
Subprog XWSSALDOS(TABLA,FILTRO,FILTRO2,O_XML)
  Value Char TABLA
  Value Char FILTRO
  Value Char FILTRO2
  Variable Clbfile O_XML

  Local Char    CLIENTE(15),RAZON_SOCIAL(71),ASIENTO(20),DOC_ORIGEN(20)
  Local Decimal SALDO_TOTAL,PAGADO,PENDIENTE,SUBTOTAL,RIESGO_AUT,IMPORTE_SDH,SUBSDH
  Local Date    FECHA_DOCU,FECHA_VENC
  Local Integer JJ,LL

  If FILTRO = ''
    FILTRO = "1=1"
  Endif
  If FILTRO2 = ''
    FILTRO2 = "1=1"
  Endif

  Raz O_XML

  #Append O_XML,'<xml_version>1.04</xml_version>'
  #Append O_XML,'['

  #Bucle sobre las tablas solicitadas
  For X=0 To dim(TABLA)-1
    Case TABLA(X)
      When "DUD"  : Gosub XDUD4 #Gosub XDUD2
    Endcase
  Next

  #Append O_XML,']'
End
##=======================================================================
$XDUD4
  If !clalev([F:DUD])  : Local File GACCDUDATE [DUD]  : Endif
  If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif
  If !clalev([F:BPC])  : Local File BPCUSTOMER [BPC]  : Endif
  If !clalev([F:DUD2]) : Local File GACCDUDATE [DUD2] : Endif
  If !clalev([F:SDH])  : Local File SDELIVERY  [SDH]  : Endif
  If !clalev([F:SDD])  : Local File SDELIVERYD [SDD]  : Endif
  If !clalev([F:HAE])  : Local File GACCENTRY  [HAE]  : Endif
  If !clalev([F:BPR2]) : Local File BPARTNER   [BPR2] : Endif

  Link [BPR] With [BPC]BPC0 = [BPR]BPRNUM
&            As [XCLI]
&            Where [BPR]BPCFLG = 2 & evalue(FILTRO)
&            Order By [BPR]BPRNUM
  Columns [XCLI]([BPR]BPRNUM,[BPR]BPRNAM,[BPR]CUR,[BPC]OSTAUZ, [BPC]CDTISR)

  Append O_XML,'{"riesgo":['

  JJ = 0
  For [XCLI]
    JJ+=1
    If JJ=1
      Append O_XML,'{'
    Else
      Append O_XML,',{'
    Endif

    #Cálculo del saldo total
    SUBTOTAL = 0
    Filter [F:DUD2] Where BPR = [BPR]BPRNUM and BPRTYP = 1 and CUR = [BPR]CUR and AMTCUR > (PAYCUR + TMPCUR)
    For [F:DUD2]
      SUBTOTAL += [DUD2]SNS*([DUD2]AMTCUR - [DUD2]PAYCUR - [DUD2]TMPCUR)
    Next

    #Cálculo del importe en Entregas no facturadas
    SUBSDH = 0
    Link [SDD] With [SDH]SDH0 = [SDD]SDHNUM
&              As [XENT]
&              Where [SDH]INVFLG <> 2 & [SDH]BPCINV = [BPR]BPRNUM
&              Order By [SDD]SDHNUM;[SDD]SDDLIN
    Columns [XENT]([SDD]NETPRINOT,[SDD]NETPRIATI,[SDD]QTY)

    For [XENT]
      SUBSDH += (ar2([SDD]NETPRIATI * [SDD]QTY))
    Next

    DOC_ORIGEN   = ''
    FECHA_DOCU   = [0/0/0]
    CLIENTE      = [BPR]BPRNUM
    If [BPR]BPRNAM(1) <> ""
      RAZON_SOCIAL = [BPR]BPRNAM(0) + " " + [BPR]BPRNAM(1)
    Else
      RAZON_SOCIAL = [BPR]BPRNAM(0)
    Endif
    DIVISA       = [BPR]CUR
    SALDO_TOTAL  = SUBTOTAL
    ASIENTO      = ''
    PAGADO       = 0
    PENDIENTE    = 0
    RIESGO_AUT   = [BPC]OSTAUZ
    IMPORTE_SDH  = SUBSDH
    FECHA_VENC   = [0/0/0]

    Append O_XML,'"BPR": "'        + CLIENTE           + '",'
    Append O_XML,'"BPRNAM": "'     + RAZON_SOCIAL      + '",'
    Append O_XML,'"RIESGOAUT": "'  + num$(RIESGO_AUT)  + '",'
    Append O_XML,'"DIVISA": "'     + DIVISA            + '",'
    Append O_XML,'"SALDOTOTAL": "' + num$(SALDO_TOTAL) + '",'
    Append O_XML,'"ENTRNOFAC": "'  + num$(IMPORTE_SDH) + '",'
    Append O_XML,'"RIESGOASEG": "' + num$([BPC]CDTISR) + '"'
#    Append O_XML,'"NUM": "'        + ASIENTO           + '",'
#    Append O_XML,'"NUMDAT": "'     + num$(FECHA_DOCU)  + '",'
#    Append O_XML,'"DUDDAT": "'     + num$(FECHA_VENC)  + '",'
#    Append O_XML,'"DOCORIGEN": "'  + DOC_ORIGEN        + '",'
#    Append O_XML,'"PAGADO": "'     + num$(PAGADO)      + '",'
#    Append O_XML,'"PENDIENTE": "'  + num$(PENDIENTE)   + '"'
    Append O_XML,'}'

  Next
  Columns [XCLI]

  Append O_XML,'],'
  Append O_XML,'"facturas":['

  Link [DUD] With [BPR2]BPR0 = [DUD]BPR,
&                 [BPC]BPC0 = [DUD]BPR
&            As [XSAL]
&            Where [BPR2]BPCFLG = 2 & [DUD]BPRTYP = 1 & ([DUD]AMTCUR > [DUD]PAYCUR + [DUD]TMPCUR)
&                  & evalue(FILTRO2)
&            Order By [DUD]BPR;[DUD]CUR;[DUD]NUM
  Columns [XSAL]([DUD]BPR,[BPR2]BPRNAM,[DUD]NUM,[DUD]CUR,[DUD]AMTCUR,[DUD]PAYCUR,[DUD]TMPCUR,[DUD]LIG,
&                [DUD]SNS,[DUD]TYP,[DUD]DUDDAT,[BPC]OSTAUZ,[DUD]BPRTYP)

  LL = 0
  For [XSAL]
    LL+=1
    If LL=1
      Append O_XML,'{'
    Else
      Append O_XML,',{'
    Endif

    #Cálculo del saldo total
    SUBTOTAL = 0
    Filter [F:DUD2] Where BPR = [DUD]BPR and BPRTYP = 1 and CUR = [DUD]CUR and AMTCUR > (PAYCUR + TMPCUR)
    For [F:DUD2]
      SUBTOTAL += [DUD2]SNS*([DUD2]AMTCUR - [DUD2]PAYCUR - [DUD2]TMPCUR)
    Next

        #Cálculo del importe en Entregas no facturadas
        SUBSDH = 0
        Link [SDD] With [SDH]SDH0 = [SDD]SDHNUM
&                  As [XENT]
&                  Where [SDH]INVFLG <> 2 & [SDH]BPCINV = [DUD]BPR
&                  Order By [SDD]SDHNUM;[SDD]SDDLIN
        Columns [XENT]([SDD]NETPRINOT,[SDD]NETPRIATI,[SDD]QTY)

        For [XENT]
          SUBSDH += (ar2([SDD]NETPRIATI * [SDD]QTY))
        Next

        #Documento origen para los SINIC
        DOC_ORIGEN = ''
        If [DUD]TYP = 'SINIC'
          Read [F:HAE]HAE0 = [DUD]TYP;[DUD]NUM
          If !fstat
            DOC_ORIGEN = [HAE]BPRVCR
          Endif
        Else
          DOC_ORIGEN = ''
        Endif

        #Fecha del documento
        FECHA_DOCU = [0/0/0]
        If [DUD]TYP <> ''
          Read [F:HAE]HAE0 = [DUD]TYP;[DUD]NUM
          If !fstat
            FECHA_DOCU = [HAE]ACCDAT
          Endif
        Else
          FECHA_DOCU = [0/0/0]
        Endif


        CLIENTE      = [DUD]BPR
        If [BPR2]BPRNAM(1) <> ""
          RAZON_SOCIAL = [BPR2]BPRNAM(0) + " " + [BPR2]BPRNAM(1)
        Else
          RAZON_SOCIAL = [BPR2]BPRNAM(0)
        Endif
        DIVISA       = [DUD]CUR
        SALDO_TOTAL  = SUBTOTAL
        ASIENTO      = [DUD]NUM
        PAGADO       = [DUD]SNS*[DUD]PAYCUR
        PENDIENTE    = [DUD]SNS*([DUD]AMTCUR - [DUD]PAYCUR - [DUD]TMPCUR)
        RIESGO_AUT   = [BPC]OSTAUZ
        IMPORTE_SDH  = SUBSDH
        FECHA_VENC   = [DUD]DUDDAT

        Append O_XML,'"BPR": "'        + CLIENTE           + '",'
        Append O_XML,'"BPRNAM": "'     + RAZON_SOCIAL      + '",'
        Append O_XML,'"RIESGOAUT": "'  + num$(RIESGO_AUT)  + '",'
        Append O_XML,'"DIVISA": "'     + DIVISA            + '",'
        Append O_XML,'"SALDOTOTAL": "' + num$(SALDO_TOTAL) + '",'
        Append O_XML,'"ENTRNOFAC": "'  + num$(IMPORTE_SDH) + '",'
        Append O_XML,'"NUM": "'        + ASIENTO           + '",'
        Append O_XML,'"NUMDAT": "'     + num$(FECHA_DOCU)  + '",'
        Append O_XML,'"DUDDAT": "'     + num$(FECHA_VENC)  + '",'
        Append O_XML,'"DOCORIGEN": "'  + DOC_ORIGEN        + '",'
        Append O_XML,'"PAGADO": "'     + num$(PAGADO)      + '",'
        Append O_XML,'"PENDIENTE": "'  + num$(PENDIENTE)   + '"'
        Append O_XML,'}'

      Next
    Columns [XSAL]

  Append O_XML,']}'
Return
##=========================================================================
$XDUD3
  If !clalev([F:DUD])  : Local File GACCDUDATE [DUD]  : Endif
  If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif
  If !clalev([F:BPC])  : Local File BPCUSTOMER [BPC]  : Endif
  If !clalev([F:DUD2]) : Local File GACCDUDATE [DUD2] : Endif
  If !clalev([F:SDH])  : Local File SDELIVERY  [SDH]  : Endif
  If !clalev([F:SDD])  : Local File SDELIVERYD [SDD]  : Endif
  If !clalev([F:HAE])  : Local File GACCENTRY  [HAE]  : Endif
  If !clalev([F:BPR2]) : Local File BPARTNER   [BPR2] : Endif

  Link [BPR] With [BPC]BPC0 = [BPR]BPRNUM
&            As [XCLI]
&            Where [BPR]BPCFLG = 2 & evalue(FILTRO)
&            Order By [BPR]BPRNUM
  Columns [XCLI]([BPR]BPRNUM,[BPR]BPRNAM,[BPR]CUR,[BPC]OSTAUZ)

  JJ = 0
  For [XCLI]
    JJ+=1
    #Append O_XML,'JJ:'+num$(JJ)
    If JJ=1
      Append O_XML,'{'
    Else
      Append O_XML,',{'
    Endif

    #Append O_XML,'"BPR1": "'        + [BPR]BPRNUM           + '",'

    Link [DUD] With [BPR2]BPR0 = [DUD]BPR
&              As [XSAL]
&              Where [DUD]BPRTYP = 1 & ([DUD]AMTCUR > [DUD]PAYCUR + [DUD]TMPCUR)
&                    & [DUD]BPR = [BPR]BPRNUM & evalue(FILTRO2)
&              Order By [DUD]BPR;[DUD]CUR;[DUD]NUM
    Columns [XSAL]([DUD]BPR,[DUD]NUM,[DUD]CUR,[DUD]AMTCUR,[DUD]PAYCUR,[DUD]TMPCUR,[DUD]LIG,
&                  [DUD]SNS,[DUD]TYP,[DUD]DUDDAT,[DUD]BPRTYP)

    LL = 0
    For [XSAL]
      LL += 1
      Break
    Next

    If LL >= 1
      LL = 0
      For [XSAL]
        LL+=1
        If LL>=2
          Append O_XML,',{'
        Endif

        #Cálculo del saldo total
        SUBTOTAL = 0
        Filter [F:DUD2] Where BPR = [DUD]BPR and BPRTYP = 1 and CUR = [DUD]CUR and AMTCUR > (PAYCUR + TMPCUR)
        For [F:DUD2]
          SUBTOTAL += [DUD2]SNS*([DUD2]AMTCUR - [DUD2]PAYCUR - [DUD2]TMPCUR)
        Next

        #Cálculo del importe en Entregas no facturadas
        SUBSDH = 0
        Link [SDD] With [SDH]SDH0 = [SDD]SDHNUM
&                  As [XENT]
&                  Where [SDH]INVFLG <> 2 & [SDH]BPCINV = [DUD]BPR
&                  Order By [SDD]SDHNUM;[SDD]SDDLIN
        Columns [XENT]([SDD]NETPRINOT,[SDD]NETPRIATI,[SDD]QTY)

        For [XENT]
          SUBSDH += (ar2([SDD]NETPRIATI * [SDD]QTY))
        Next

        #Documento origen para los SINIC
        DOC_ORIGEN = ''
        If [DUD]TYP = 'SINIC'
          Read [F:HAE]HAE0 = [DUD]TYP;[DUD]NUM
          If !fstat
            DOC_ORIGEN = [HAE]BPRVCR
          Endif
        Else
          DOC_ORIGEN = ''
        Endif

        #Fecha del documento
        FECHA_DOCU = [0/0/0]
        If [DUD]TYP <> ''
          Read [F:HAE]HAE0 = [DUD]TYP;[DUD]NUM
          If !fstat
            FECHA_DOCU = [HAE]ACCDAT
          Endif
        Else
          FECHA_DOCU = [0/0/0]
        Endif


        CLIENTE      = [DUD]BPR
        If [BPR]BPRNAM(1) <> ""
          RAZON_SOCIAL = [BPR]BPRNAM(0) + " " + [BPR]BPRNAM(1)
        Else
          RAZON_SOCIAL = [BPR]BPRNAM(0)
        Endif
        DIVISA       = [DUD]CUR
        SALDO_TOTAL  = SUBTOTAL
        ASIENTO      = [DUD]NUM
        PAGADO       = [DUD]SNS*[DUD]PAYCUR
        PENDIENTE    = [DUD]SNS*([DUD]AMTCUR - [DUD]PAYCUR - [DUD]TMPCUR)
        RIESGO_AUT   = [BPC]OSTAUZ
        IMPORTE_SDH  = SUBSDH
        FECHA_VENC   = [DUD]DUDDAT

        Append O_XML,'"BPR": "'        + CLIENTE           + '",'
        Append O_XML,'"BPRNAM": "'     + RAZON_SOCIAL      + '",'
        Append O_XML,'"RIESGOAUT": "'  + num$(RIESGO_AUT)  + '",'
        Append O_XML,'"DIVISA": "'     + DIVISA            + '",'
        Append O_XML,'"SALDOTOTAL": "' + num$(SALDO_TOTAL) + '",'
        Append O_XML,'"ENTRNOFAC": "'  + num$(IMPORTE_SDH) + '",'
        Append O_XML,'"NUM": "'        + ASIENTO           + '",'
        Append O_XML,'"NUMDAT": "'     + num$(FECHA_DOCU)  + '",'
        Append O_XML,'"DUDDAT": "'     + num$(FECHA_VENC)  + '",'
        Append O_XML,'"DOCORIGEN": "'  + DOC_ORIGEN        + '",'
        Append O_XML,'"PAGADO": "'     + num$(PAGADO)      + '",'
        Append O_XML,'"PENDIENTE": "'  + num$(PENDIENTE)   + '"'
        Append O_XML,'}'

      Next
    Else
      DOC_ORIGEN   = ''
      FECHA_DOCU   = [0/0/0]
      CLIENTE      = [BPR]BPRNUM
      If [BPR]BPRNAM(1) <> ""
        RAZON_SOCIAL = [BPR]BPRNAM(0) + " " + [BPR]BPRNAM(1)
      Else
        RAZON_SOCIAL = [BPR]BPRNAM(0)
      Endif
      DIVISA       = [BPR]CUR
      SALDO_TOTAL  = 0
      ASIENTO      = ''
      PAGADO       = 0
      PENDIENTE    = 0
      RIESGO_AUT   = [BPC]OSTAUZ
      IMPORTE_SDH  = 0
      FECHA_VENC   = [0/0/0]

      Append O_XML,'"BPR": "'        + CLIENTE           + '",'
      Append O_XML,'"BPRNAM": "'     + RAZON_SOCIAL      + '",'
      Append O_XML,'"RIESGOAUT": "'  + num$(RIESGO_AUT)  + '",'
      Append O_XML,'"DIVISA": "'     + DIVISA            + '",'
      Append O_XML,'"SALDOTOTAL": "' + num$(SALDO_TOTAL) + '",'
      Append O_XML,'"ENTRNOFAC": "'  + num$(IMPORTE_SDH) + '",'
      Append O_XML,'"NUM": "'        + ASIENTO           + '",'
      Append O_XML,'"NUMDAT": "'     + num$(FECHA_DOCU)  + '",'
      Append O_XML,'"DUDDAT": "'     + num$(FECHA_VENC)  + '",'
      Append O_XML,'"DOCORIGEN": "'  + DOC_ORIGEN        + '",'
      Append O_XML,'"PAGADO": "'     + num$(PAGADO)      + '",'
      Append O_XML,'"PENDIENTE": "'  + num$(PENDIENTE)   + '"'
      Append O_XML,'}'
    Endif
    Columns [XSAL]

  Next
  Columns [XCLI]

Return
##=========================================================================
$XDUD2
  If !clalev([F:DUD])  : Local File GACCDUDATE [DUD]  : Endif
  If !clalev([F:BPR])  : Local File BPARTNER   [BPR]  : Endif
  If !clalev([F:BPC])  : Local File BPCUSTOMER [BPC]  : Endif
  If !clalev([F:DUD2]) : Local File GACCDUDATE [DUD2] : Endif
  If !clalev([F:SDH])  : Local File SDELIVERY  [SDH]  : Endif
  If !clalev([F:SDD])  : Local File SDELIVERYD [SDD]  : Endif
  If !clalev([F:HAE])  : Local File GACCENTRY  [HAE]  : Endif

  Link [DUD] With [BPR]BPR0 = [DUD]BPR,
&                 [BPC]BPC0 = [DUD]BPR
&            As [XSAL]
&            Where [BPR]BPCFLG = 2 & [DUD]BPRTYP = 1 & ([DUD]AMTCUR > [DUD]PAYCUR + [DUD]TMPCUR) & evalue(FILTRO)
&            Order By [DUD]BPR;[DUD]CUR;[DUD]NUM
  Columns [XSAL]([DUD]BPR,[BPR]BPRNAM,[DUD]NUM,[DUD]CUR,[DUD]AMTCUR,[DUD]PAYCUR,[DUD]TMPCUR,[DUD]LIG,
&                [DUD]SNS,[DUD]TYP,[DUD]DUDDAT,[BPC]OSTAUZ,[DUD]BPRTYP)

  For [XSAL]
  JJ+=1
    If JJ=1
      Append O_XML,'{'
    Else
      Append O_XML,',{'
    Endif

    #Cálculo del saldo total
    SUBTOTAL = 0
    Filter [F:DUD2] Where BPR = [DUD]BPR and BPRTYP = 1 and CUR = [DUD]CUR and AMTCUR > (PAYCUR + TMPCUR)
    For [F:DUD2]
      SUBTOTAL += [DUD2]SNS*([DUD2]AMTCUR - [DUD2]PAYCUR - [DUD2]TMPCUR)
    Next

    #Cálculo del importe en Entregas no facturadas
    SUBSDH = 0
    Link [SDD] With [SDH]SDH0 = [SDD]SDHNUM
&              As [XENT]
&              Where [SDH]INVFLG <> 2 & [SDH]BPCINV = [DUD]BPR
&              Order By [SDD]SDHNUM;[SDD]SDDLIN
    Columns [XENT]([SDD]NETPRINOT,[SDD]NETPRIATI,[SDD]QTY)

    For [XENT]
      SUBSDH += (ar2([SDD]NETPRIATI * [SDD]QTY))
    Next

    #Documento origen para los SINIC
    DOC_ORIGEN = ''
    If [DUD]TYP = 'SINIC'
      Read [F:HAE]HAE0 = [DUD]TYP;[DUD]NUM
      If !fstat
        DOC_ORIGEN = [HAE]BPRVCR
      Endif
    Else
      DOC_ORIGEN = ''
    Endif

    #Fecha del documento
    FECHA_DOCU = [0/0/0]
    If [DUD]TYP <> ''
      Read [F:HAE]HAE0 = [DUD]TYP;[DUD]NUM
      If !fstat
        FECHA_DOCU = [HAE]ACCDAT
      Endif
    Else
      FECHA_DOCU = [0/0/0]
    Endif


    CLIENTE      = [DUD]BPR
    If [BPR]BPRNAM(1) <> ""
      RAZON_SOCIAL = [BPR]BPRNAM(0) + " " + [BPR]BPRNAM(1)
    Else
      RAZON_SOCIAL = [BPR]BPRNAM(0)
    Endif
    DIVISA       = [DUD]CUR
    SALDO_TOTAL  = SUBTOTAL
    ASIENTO      = [DUD]NUM
    PAGADO       = [DUD]SNS*[DUD]PAYCUR
    PENDIENTE    = [DUD]SNS*([DUD]AMTCUR - [DUD]PAYCUR - [DUD]TMPCUR)
    RIESGO_AUT   = [BPC]OSTAUZ
    IMPORTE_SDH  = SUBSDH
    FECHA_VENC   = [DUD]DUDDAT

    Append O_XML,'"BPR": "'        + CLIENTE           + '",'
    Append O_XML,'"BPRNAM": "'     + RAZON_SOCIAL      + '",'
    Append O_XML,'"RIESGOAUT": "'  + num$(RIESGO_AUT)  + '",'
    Append O_XML,'"DIVISA": "'     + DIVISA            + '",'
    Append O_XML,'"SALDOTOTAL": "' + num$(SALDO_TOTAL) + '",'
    Append O_XML,'"ENTRNOFAC": "'  + num$(IMPORTE_SDH) + '",'
    Append O_XML,'"NUM": "'        + ASIENTO           + '",'
    Append O_XML,'"NUMDAT": "'     + num$(FECHA_DOCU)  + '",'
    Append O_XML,'"DUDDAT": "'     + num$(FECHA_VENC)  + '",'
    Append O_XML,'"DOCORIGEN": "'  + DOC_ORIGEN        + '",'
    Append O_XML,'"PAGADO": "'     + num$(PAGADO)      + '",'
    Append O_XML,'"PENDIENTE": "'  + num$(PENDIENTE)   + '"'
    Append O_XML,'}'

  Next
  Columns [XSAL]
Return
##=========================================================================
$XDUD
  If !clalev([F:DUD]) : Local File GACCDUDATE [DUD] : Endif
  If !clalev([F:BPR]) : Local File BPARTNER   [BPR] : Endif
  If !clalev([F:DUD2]) : Local File GACCDUDATE [DUD2] : Endif

  Link [DUD] With [BPR]BPR0 = [DUD]BPR
&            As [XSAL]
&            Where [BPR]BPCFLG = 2 & [DUD]AMTCUR > [DUD]PAYCUR + [DUD]TMPCUR & evalue(FILTRO)
&            Order By Key ZKDUD=[DUD]BPR;[DUD]CUR;[DUD]NUM;[DUD]LIG
  Columns [XSAL]([DUD]BPR,[BPR]BPRNAM,[DUD]NUM,[DUD]CUR,[DUD]AMTCUR,[DUD]PAYCUR,[DUD]TMPCUR,[DUD]LIG)

  For [XSAL]ZKDUD(1)
  JJ+=1
    If JJ=1
      Append O_XML,'{'
    Else
      Append O_XML,',{'
    Endif

#    #Cálculo del total
#    Filter [F:DUD2] Where BPR = [DUD]BPR and AMTCUR > (PAYCUR + TMPCUR) Order By Key ZKDUD=BPR;CUR
#    For [F:DUD2]ZKDUD(1)
#      SUBTOTAL = 0
#      DIVISA   = ""
#      For [F:DUD2]ZKDUD(2)
#        SUBTOTAL += [DUD2]AMTCUR - [DUD2]PAYCUR - [DUD2]TMPCUR
#        DIVISA    = [DUD2]CUR
#      Next
#    Next

    For [XSAL]ZKDUD(2)
      SUBTOTAL = 0

      For [XSAL]ZKDUD(3)
        For [XSAL]ZKDUD(4)
          SUBTOTAL += [DUD]AMTCUR - [DUD]PAYCUR - [DUD]TMPCUR
        Next

        CLIENTE      = [DUD]BPR
        If [BPR]BPRNAM(1) <> ""
          RAZON_SOCIAL = [BPR]BPRNAM(0) + " " + [BPR]BPRNAM(1)
        Else
          RAZON_SOCIAL = [BPR]BPRNAM(0)
        Endif
        DIVISA       = [DUD]CUR
        SALDO_TOTAL  = SUBTOTAL
        ASIENTO      = [DUD]NUM
        PAGADO       = [DUD]PAYCUR
        PENDIENTE    = [DUD]AMTCUR - [DUD]PAYCUR - [DUD]TMPCUR

        Append O_XML,'"BPR": "'        + CLIENTE           + '",'
        Append O_XML,'"BPRNAM": "'     + RAZON_SOCIAL      + '",'
        Append O_XML,'"SALDOTOTAL": "' + num$(SALDO_TOTAL) + '",'
        Append O_XML,'"DIVISA": "'     + DIVISA            + '",'
        Append O_XML,'"NUM": "'        + ASIENTO           + '",'
        Append O_XML,'"PAGADO": "'     + num$(PAGADO)      + '",'
        Append O_XML,'"PENDIENTE": "'  + num$(PENDIENTE)   + '"'
        Append O_XML,'}'

      Next
    Next
  Next
  Columns [XSAL]
Return
##=========================================================================

