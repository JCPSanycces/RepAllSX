##================================================================================
## XQ003: GAO(03/09/2018) GAP 010 Factura centralizada.
##================================================================================
$ACTION
  Case ACTION
    When Default
  Endcase
Return
##================================================================================
Subprog AM_FCYINI(VALEUR)
Variable Char    VALEUR()
  [M:XCENT1]FCYFIN = VALEUR
  Affzo [M:XCENT1]FCYFIN
End
##================================================================================
Subprog C_FCYFIN(VALEUR)
Variable Char    VALEUR()
  If VALEUR <> "" and [M:XCENT1]FCYINI = ""
    #Planta inicio está vacía
    GERR = 2 : GMESSAGE = mess(8,6000,1) : mkstat = 2
  Endif
End
##================================================================================
Subprog AM_BPSINI(VALEUR)
Variable Char    VALEUR()
  [M:XCENT1]BPSFIN = VALEUR
  Affzo [M:XCENT1]BPSFIN
End
##================================================================================
Subprog C_BPSFIN(VALEUR)
Variable Char    VALEUR()
  If VALEUR <> "" and [M:XCENT1]BPSINI = ""
    #Proveedor inicio está vacío
    GERR = 2 : GMESSAGE = mess(9,6000,1) : mkstat = 2
  Endif
End
##================================================================================
Subprog C_DATEFIN(VALEUR)
Variable Date    VALEUR
  If VALEUR <> [0/0/0] and [M:XCENT1]DATEINI = [0/0/0]
    #Fecha inicio está vacía
    GERR = 2 : GMESSAGE = mess(10,6000,1) : mkstat = 2
  Endif
End
##================================================================================
Subprog AV_CPY(VALEUR)
Variable Char    VALEUR()
  VALEUR = "S0000"
End
##================================================================================

