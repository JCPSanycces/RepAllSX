#<AdxTL>@(#)0.0.0.0 $Revision$
# First test: check the YLEAD methods
#------------------------------------------------------------------------------#

Local Clbfile RESULT
RESULT=func TESTSUITE()
Errbox RESULT
End

Funprog TESTSUITE()

  Call ADD_TESTCASE("TEST_YLEAD","Test class YLEAD with controls",1) From AXUNIT

End func AXUNIT.RUN_TESTSUITE("Test number 1","Check leads")

#  Optional subprog called *before* running the test suite
Subprog SETUP

# Error handling variable
  Global Integer ERROR_V

# Cleanup tables
  Gosub CLEANUP_TABLES
End

#  Optional subprog called *after* running the test suite
Subprog TEARDOWN
  Gosub CLEANUP_TABLES
End

# Cleanup the YLEAD record
$CLEANUP_TABLES
  Local File YLEAD
  Delete [YLE] Where LEADNUM=9999
Return

$NOCLASS
ERROR_V=errn
Resume

#
# Test YORDER and YLINE
#

Subprog TEST_YLEAD()

#
# Check class YLINE
#
  Local Instance YLEAD Using C_YLEAD
  Local Integer OK
  Local Integer NB_ERR
  Local Decimal EXPECTED_PRICE
  Local File YCUSTOMER
  Read [YBP]YBP0 First

  YLEAD=NewInstance C_YLEAD AllocGroup null
  OK=fmet YLEAD.AINIT

  If OK<>[V]CST_AOK
    NB_ERR+=1
    Call LOG_LINE(" ** ERROR : AINIT method failed on YLEAD") From AXUNIT
  Else
    YLEAD.LEADNUM=9999
    YLEAD.BPCNUM=[YBP]BPCNUM
    YLEAD.LEADDATE=date$
    YLEAD.AMOUNT=3.14

    Call LOG_LINE("Check lead creation") From AXUNIT
    OK=fmet YLEAD.AINSERT
    If OK=[V]CST_AERROR
      NB_ERR+=1
      Call LOG_LINE(" ** ERROR at YLEAD creation") From AXUNIT
      Call LOG_CLASS(YLEAD,"YLEAD",1) From AXUNIT
    Else

      FreeGroup YLEAD
      YLEAD=NewInstance C_YLEAD AllocGroup null
      Call LOG_LINE("Check lead read") From AXUNIT
      OK=fmet YLEAD.AREAD(9999)
      If OK=[V]CST_AERROR
        NB_ERR+=1
        Call LOG_LINE(" ** ERROR: cannot read a lead previously created") From AXUNIT
      Else
        Call LOG_LINE("Check customer control") From AXUNIT
        YLEAD.BPCNUM="NOT_A_CUSTOMER"
        OK=fmet YLEAD.AUPDATE
        If OK<>[V]CST_AERROR
          NB_ERR+=1
          Call LOG_LINE(" ** ERROR: An customer that doesn't exist was allowed") From AXUNIT
          FreeGroup YLEAD
          YLEAD=NewInstance C_YLEAD AllocGroup null
          OK=fmet YLINE.AREAD(9999)
        Endif

      Endif
    Endif
  Endif

  Call CHECK_EQUAL(NB_ERR,0) From AXUNIT

  Local File YLEAD
  Delete [YLE] Where LEADNUM=9999
End

