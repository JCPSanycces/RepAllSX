#GAO(03/01/2019): Validar entregas que vienen del web service
If GWEBSERV and GUSER = 'WS'
  Call VALIDATION([F:SDH]SDHNUM) From TRTVENLIVV
Endif

Return
##=======================================================================================
Subprog AM_BPCORD(VALEUR)
Variable Char    VALEUR()
  #XQ008(03/01/2019)
  Local Integer I

  If (GWEBSERV and GUSER = "WS")
   For I = 0 To [M]NBFAC-1
     [M]FORMAT(I) = "NZ:9.4#[]"
     #Infbox("formato:"-[M]FORMAT(I))
   Next I
  Endif
End
