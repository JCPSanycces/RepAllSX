#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Ship all the orders pending for the customer associated to the current order
# "this" is the current order
$SHIPALL

# Variable declarations
Local Integer ORDNB,OK
Local Char YORDNUM(16)(1..)
Local Instance CURRENT_ORDER Using C_YORDER

# Check the current order
  ASTATUS=fmet this.AREAD([L]ORDNUM)
  If ASTATUS>=[V]CST_AERROR : ASTATUS=fmet this.ASETERROR("ORDNUM","The order does not exist",ASTATUS) : Return : Endif

# Count and store all the orders numbers to be shipped in an array
  Local File YORDER [YOH] Where [YOH]CUSTOMER=this.CUSTOMER and [YOH]ORDSTA<3
  For [YOH] : ORDNB+=1 : YORDNUM(ORDNB)=[YOH]ORDNUM : Next

# Instantiate a class to generate the log
Local Instance MYLOG Using C_ALOG
  MYLOG=NewInstance C_ALOG AllocGroup null

# Open the log file
  TRA=fmet MYLOG.ABEGINLOG("Shipment of"-num$(ORDNB)-"orders for customer"-this.CUSTOMER)
  LOGFILE_NAME=fmet MYLOG.AGETNAME
  T=val(timestamp$)

# Perform the shipment for every order
  For I=1 To ORDNB

  # Display the progression in percentage
    Call ASYNCTRACK(this.ACTX, "Sales order shipping",YORDNUM(I),int(100*I/ORDNB)) From ASYRASYNC

  # Instantiate a class and call the shipment operation. Stop if any error occurs
    CURRENT_ORDER=NewInstance C_YORDER AllocGroup null
    OK=fmet CURRENT_ORDER.SHIP(YORDNUM(I))
    If OK= [V]CST_AOK
      TRA=fmet MYLOG.APUTLINE(func AFNC.MES2("Order $1$ shipped successfully for customer ($2$)",num$(YORDNUM(I)),CURRENT_ORDER.CUSTOMER),TRA)
    Else
      TRA=fmet MYLOG.APUTLINE(func AFNC.MES1("Error when shipping order $1$for customer ($2$)",num$(YORDNUM(I)),CURRENT_ORDER.CUSTOMER),TRA)
      FreeGroup CURRENT_ORDER
      Break
    Endif

  # Display in the progression box and handle interruption
    If func ASYRASYNC.ABORTREQUESTED(this.ACTX)
      Call ADDDIAGNOSE(this.ACTX,"Interruption. "-num$(I)-"orders shipped",[V]CST_ASUCCESS) From ASYRASYNC
      Break
    Else
      Call ADDDIAGNOSE(this.ACTX,
&                      func AFNC.MES2("Order $1$ shipped for customer $2$",YORDNUM(I),CURRENT_ORDER.CUSTOMER),
&                      [V]CST_ASUCCESS) From ASYRASYNC
    Endif

    FreeGroup CURRENT_ORDER
  Next I

# Final display: Let's allow the log file (in [TRA] volume) to be downloaded and end the log file
  Call ADDDIAGNOSE(this.ACTX,"Generation time"-num$((val(timestamp$)-T)/1000)-"seconds",[V]CST_ASUCCESS) From ASYRASYNC
  Call ADDLINKDOWNLOAD(this.ACTX,"ATYPE7","[TRA]/"+LOGFILE_NAME+".tra") From ASYRASYNC
  OK=fmet MYLOG.AENDLOG
Return


