######################################################################################
## Etiqueta añadida por el supervisor (pantalla PIH3) 27/05/2019 16:24:47 (ADMIN)
######################################################################################
Subprog AM_ITMREF(VALEUR)
Variable Char    VALEUR()
If clalev([F:XITP])=0 : Local File ITMBPS [XITP] : Endif
If clalev([F:XITM])=0 : Local File ITMMASTER [XITM] : Endif

Read [XITP]ITP0= VALEUR;[M:PIH0]BPR
If !fstat
  [M:PIH3]XITMBPS(nolign-1) = [XITP]ITMREFBPS
  Affzo [M:PIH3]XITMBPS(nolign-1)

#  [M:PIH3]ZITMDESBPS(nolign-1) = [XITP]ITMDESBPS
#  Affzo [M:PIH3]ZITMDESBPS(nolign-1)
Endif


Read [XITM]ITM0= VALEUR
If !fstat
  [M:PIH3]ITMDES1(nolign-1) = [XITM]ITMDES2
  Affzo [M:PIH3]ITMDES1(nolign-1)
Endif
End


######################################################################################
#================================================================

$FIN_PICK
If clalev([F:XITP])=0 : Local File ITMBPS [XITP] : Endif
If clalev([F:XITM])=0 : Local File ITMMASTER [XITM] : Endif

Read [XITP]ITP0= [M:PIH3]ITMREF(nolign-1);[M:PIH0]BPR
If !fstat
  [M:PIH3]XITMBPS(nolign-1) = [XITP]ITMREFBPS
  Affzo [M:PIH3]XITMBPS(nolign-1)
Endif

Read [XITM]ITM0= [M:PIH3]ITMREF(nolign-1)
If !fstat
  [M:PIH3]ITMDES1(nolign-1) = [XITM]ITMDES2
  Affzo [M:PIH3]ITMDES1(nolign-1)
Endif

Return

