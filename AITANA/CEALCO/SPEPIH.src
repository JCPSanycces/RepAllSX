#<AdxTL>@(#)0.0.0.0 $Revision$
##==============================================================================
# XQ003: GAO(25/09/2018) Controlar que esté relleno el Cliente asociado cuando la factura es FCC.
##==============================================================================
$ACTION
  Case ACTION
    When "VERIF_CRE" : Gosub VERIF_CRE
    When "FIN_PICK" :  Gosub FIN_PICK
    When Default
  Endcase
Return
##==============================================================================
$VERIF_CRE
  If find([M:PIH0]PIVTYP,"FCC","ACC") and [M:PIH1]XBPCASOC = ""
    #En las facturas FCC es obligatorio introducir el cliente asociado
    GERR = 1 : GMESSAGE = mess(12,6000,1) : mkstat = 2
    OK = 0
  Endif
Return
##==============================================================================
Subprog C_XBPCASOC(VALEUR)
Variable Char    VALEUR()
  If find([M:PIH0]PIVTYP,"FCC","ACC") and VALEUR = ""
    #En las facturas FCC es obligatorio introducir el cliente asociado
    GERR = 2 : GMESSAGE = mess(12,6000,1) : mkstat = 2
  Endif
End
##==============================================================================

######################################################################################
## Etiqueta añadida por el supervisor (pantalla PIH3) 16/05/2019 09:51:18 (DEV01)
######################################################################################
Subprog AM_DISCRGVAL2(VALEUR)
Variable Decimal VALEUR
If clalev([F:BPC])=0 : Local File BPSUPPLIER [BPS] : Endif
If clalev([F:PRS])=0 : Local File PRICSTRUCT [PRS] : Endif

Local Char PROVEEDOR(30)
Local Char TARIFA(5)
Local Decimal QTY
Local Decimal BRUTO
Local Decimal NETO
Local Char CUR
Local Integer I : I = 1
Local Integer J : J = 0

PROVEEDOR = [M:PIH0]BPR
QTY=evalue("[M:PIH3]QTYUOM("+num$(nolign-1)+")")
CUR = [M:PIH1]CUR
Read [F:BPS]BPS0 = PROVEEDOR
TARIFA = [F:BPS]PLISTC
Read [PRS]PRS0 = 2;TARIFA
BRUTO = [M:PIH3]GROPRI(nolign-1)

#recogemos valores en descuentos
Local Decimal DISCRGVAL(0..8)
For I =1  To 9
  If I-1 = 1 Then
    DISCRGVAL(I-1) = VALEUR
  Else
    If evalue("DIM([M:PIH3]DISCRGVAL"+num$(I)+"("+num$(nolign-1)+"))")>0
         DISCRGVAL(I-1)=evalue("[M:PIH3]DISCRGVAL"+num$(I)+"("+num$(nolign-1)+")")
    Endif
  Endif
Next I
#Procedemos a los calculos del precio neto segun descuentos
If QTY = 0  QTY = 1  Endif # si la cantidad es 0 ponemos 1 y evitamos division por 0
NETO = BRUTO # en principio neto es igual a bruto antes de descuentos.

For Z= 0 To 8
#Infbox num$(Z)-num$(DISCRGVAL(Z))
  If [F:PRS]NPRNOTFLG(Z) = 2 # si se aplicla
     If [F:PRS]INCDCR(Z) = 1 #si es un aumento
        If [F:PRS]VALTYP(Z) = 1 #Si es Importe
            If [F:PRS]CLCRUL <> 1 # Si no es por unidad
                NETO += DISCRGVAL(Z)/QTY
            Else
                NETO += DISCRGVAL(Z)
            Endif
        Elsif [F:PRS]VALTYP(Z) = 2 # Si es porcentaje ACumulado
              NETO += (BRUTO*DISCRGVAL(Z))/100
        Else                        #si es porcentaje en Cascada
              NETO += (NETO*DISCRGVAL(Z))/100
        Endif
     Else                     #Si es disminución
        #Infbox "DISMINUCION"-num$(NETO)
        If [F:PRS]VALTYP(Z) = 1
            If [F:PRS]CLCRUL(Z) <> 1
                NETO -= DISCRGVAL(Z)/QTY
            Else
                NETO -= DISCRGVAL(Z)
            Endif
        Elsif [F:PRS]VALTYP(Z) = 2
            NETO -= (BRUTO*DISCRGVAL(Z))/100
        Else
            #Infbox "EN CASCADA"-num$(NETO)
            NETO -= (NETO*DISCRGVAL(Z))/100
        Endif
     Endif
  Endif
  #Infbox "ZETA: "+ num$(Z)-"NETO: "-num$(NETO)
Next Z
If GPURRND = 2
     Call ARRDEV(NETO,CUR) From TRTDIV
Else
     NETO = arr(NETO,10^-GDECPRI)
Endif
[M:PIH3]NETPRI(nolign-1) = NETO
Affzo [M:PIH3]NETPRI
#llamar a accion de NETPRI
Call AM_NETPRI(NETO) From SUBPIH
Call PAMVATFLG("PIH3",nolign-1,"NETPRI") From TRTACHFAC1

End


######################################################################################

######################################################################################
## Etiqueta añadida por el supervisor (pantalla PIH3) 27/05/2019 10:11:15 (ADMIN)
######################################################################################
Subprog AM_GROPRI(VALEUR)
Variable Decimal VALEUR
If clalev([F:BPC])=0 : Local File BPSUPPLIER [BPS] : Endif
If clalev([F:PRS])=0 : Local File PRICSTRUCT [PRS] : Endif

Local Char PROVEEDOR(30)
Local Char TARIFA(5)
Local Decimal QTY
Local Decimal BRUTO
Local Decimal NETO
Local Char CUR
Local Integer I : I = 1
Local Integer J : J = 0

PROVEEDOR = [M:PIH0]BPR
QTY=evalue("[M:PIH3]QTYUOM("+num$(nolign-1)+")")
CUR = [M:PIH1]CUR
Read [F:BPS]BPS0 = PROVEEDOR
TARIFA = [F:BPS]PLISTC
Read [PRS]PRS0 = 2;TARIFA
BRUTO = VALEUR

#recogemos valores en descuentos
Local Decimal DISCRGVAL(0..8)
For I =1  To 9
  If evalue("DIM([M:PIH3]DISCRGVAL"+num$(I)+"("+num$(nolign-1)+"))")>0
       DISCRGVAL(I-1)=evalue("[M:PIH3]DISCRGVAL"+num$(I)+"("+num$(nolign-1)+")")
  Endif
Next I
#Procedemos a los calculos del precio neto segun descuentos
If QTY = 0  QTY = 1  Endif # si la cantidad es 0 ponemos 1 y evitamos division por 0
NETO = BRUTO # en principio neto es igual a bruto antes de descuentos.

For Z= 0 To 8
#Infbox num$(Z)-num$(DISCRGVAL(Z))
  If [F:PRS]NPRNOTFLG(Z) = 2 # si se aplicla
     If [F:PRS]INCDCR(Z) = 1 #si es un aumento
        If [F:PRS]VALTYP(Z) = 1 #Si es Importe
            If [F:PRS]CLCRUL <> 1 # Si no es por unidad
                NETO += DISCRGVAL(Z)/QTY
            Else
                NETO += DISCRGVAL(Z)
            Endif
        Elsif [F:PRS]VALTYP(Z) = 2 # Si es porcentaje ACumulado
              NETO += (BRUTO*DISCRGVAL(Z))/100
        Else                        #si es porcentaje en Cascada
              NETO += (NETO*DISCRGVAL(Z))/100
        Endif
     Else                     #Si es disminución
        #Infbox "DISMINUCION"-num$(NETO)
        If [F:PRS]VALTYP(Z) = 1
            If [F:PRS]CLCRUL(Z) <> 1
                NETO -= DISCRGVAL(Z)/QTY
            Else
                NETO -= DISCRGVAL(Z)
            Endif
        Elsif [F:PRS]VALTYP(Z) = 2
            NETO -= (BRUTO*DISCRGVAL(Z))/100
        Else
            #Infbox "EN CASCADA"-num$(NETO)
            NETO -= (NETO*DISCRGVAL(Z))/100
        Endif
     Endif
  Endif
  #Infbox "ZETA: "+ num$(Z)-"NETO: "-num$(NETO)
Next Z
If GPURRND = 2
     Call ARRDEV(NETO,CUR) From TRTDIV
Else
     NETO = arr(NETO,10^-GDECPRI)
Endif

[M:PIH3]NETPRI(nolign-1) = NETO
Affzo [M:PIH3]NETPRI
#[M:PIH3]GROPRI(nolign-1) = BRUTO
#Affzo [M:PIH3]GROPRI

#llamar a accion de NETPRI
Call AM_NETPRI(NETO) From SUBPIH
Call PAMVATFLG("PIH3",nolign-1,"NETPRI") From TRTACHFAC1
End




