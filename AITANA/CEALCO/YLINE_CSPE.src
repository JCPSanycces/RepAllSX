#<AdxTL>@(#)0.0.0.0 $Revision$
# Events related to property rules. CURPRO is the property code, ARULE the rule code
# Label associated to rules: CURPRO is the property, ARULE the rule (INIT, GET, CONTROL, PROPAGATE)
$PROPERTIES
  Case [L]CURPRO
    When "QTY"
      Case [L]ARULE
        When "INIT"      : Gosub INIT_QTY
        When "CONTROL"   : Gosub CONTROL_QTY
        When "PROPAGATE" : Gosub COMPUTE_PRICE
      Endcase
    When "UNITPRICE"
      Case [L]ARULE
        When "CONTROL"   : Gosub CONTROL_UNIT_PRICE
        When "PROPAGATE" : Gosub COMPUTE_PRICE
      Endcase
    When "DISCOUNT"
      Case [L]ARULE
        When "PROPAGATE" : Gosub COMPUTE_PRICE
      Endcase
  Endcase
Return

# Rules associated to quantity
$INIT_QTY : this.QTY=1 : Return


$CONTROL_QTY
  If this.QTY<0
    [L]ASTATUS=fmet this.ASETERROR([L]CURPRO, "Qty cannot be negative",[V]CST_AERROR)
  Endif
Return

$COMPUTE_PRICE : this.PRICE=arr(this.QTY*this.UNITPRICE*(1-this.DISCOUNT/100),0.001) : Return

# On unit price: price cannot be negative

$CONTROL_UNIT_PRICE
  If this.UNITPRICE<0
    [L]ASTATUS=fmet this.ASETERROR(CURPRO,"Price must positive",[V]CST_AERROR)
  Endif
Return

# Label associated to standard events: CURPTH is the instance scope, AEVENT the event name
$EVENTS
  Case CURPTH
    When ""
      Case AEVENT
      Endcase
  Endcase
Return

# Label associated to methods: AMETHOD is the method name
$METHODS
  Case AMETHOD
  Endcase
Return

# Label associated to operations: AOPERATION is the event name
$OPERATIONS
  Case AOPERATION
  Endcase
Return

# $ACTION:AEVENT=ACTION: Gosub EVENTS: AOPERATION=ACTION: Gosub OPERATIONS: AMETHOD=ACTION: Goto METHODS

