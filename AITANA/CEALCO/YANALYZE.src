#<AdxTL>@(#)0.0.0.0 $Revision$
# Operation called in sales order representation
# Analyzes the average amount and quantity for all orders of the current customer
# Compares it to the average amount and quantity for the orders of other customers

$ANALYZE

Local Integer OK
Local Instance MYLOG Using C_ALOG
Local Char LOGFILE_NAME(250)

# Let's generate a class to generate the log (in the same group than "this")
  MYLOG=NewInstance C_ALOG AllocGroup this

# Open the log file
  OK=fmet MYLOG.ABEGINLOG("Analysis of order and ranking of customer orders")
  LOGFILE_NAME=fmet MYLOG.AGETNAME

# Let's first fill the instance
  ASTATUS=fmet this.AREAD([L]ORDNUM)
  If ASTATUS>=[V]CST_AERROR
    ASTATUS=fmet this.ASETERROR("ORDNUM","The order does not exist",ASTATUS) : Return
    Return
  Endif

# Declare tables and perform the join that will read the line orders per customer
Local File    YORDER [YOH],YLINE [YOL], BPCUSTOMER [BPC]

  Link [YOL] With [YOH]YOH0=[YOL]ORDNUM,
&                  [BPC]BPC0=[YOH]CUSTOMER
&               As [MYOR]
&     Order By Key CUST=[BPC]BPCNUM;[YOH]ORDNUM;[YOL]NUMLIN

# Total number of lines
Local Integer ORDCOUNT
 ORDCOUNT=nbrecord([YOL])

# Declare variables for the first loop
Local Integer NBORD,RANK
Local Decimal TOTQTY,TOTAMOUNT,ORDQTY
Local Integer STOPPED

# Compute the total quantity ot the order
  ORDQTY=0
  For I=1 To maxtab(this.LINES)
    If find(this.ASTALIN,[V]CST_ADEL,[V]CST_ANEWDEL)=0
      ORDQTY+=this.LINES(I).QTY
    Endif
  Next I

# Analyze the current order and compare it to all the orders of the customer
  Raz TOTQTY, TOTAMOUNT
  For [MYOR]CUST(2) Where [BPC]BPCNUM=this.CUSTOMER
    NBORD+=1
    RANK+=([YOH]TOTAL>=this.TOTAL)
    TOTAMOUNT+=[YOH]TOTAL
    For [MYOR]CUST
      TOTQTY+=[YOL]QTY
    Next
  Next

# First log: give the comparizon with the other orders of the customer and the total
  OK=fmet MYLOG.APUTLINE(" Order #"+format$("K:20X",this.ORDNUM)+" ranked at place: "+num$(RANK)+"/"+num$(NBORD),[V]CST_AOK)
  OK=fmet MYLOG.APUTLINE("  ("+format$("N:2.2[%]",100*this.TOTAL/TOTAMOUNT)+" of amount ordered by the customer)",[V]CST_AOK)
  OK=fmet MYLOG.APUTLINE("  ("+format$("N:2.2[%]",100*ORDQTY/TOTQTY)+" of quantities ordered by the customer)",[V]CST_AOK)

# Declare variables for the second loop
Local Integer NBORD2,NBORD2INI,RANK2
Local Decimal TOTQTY2,TOTAMOUNT2,TOTCUSTOMER
Local Char CUSTOMER2(type([BPC]BPCNUM)-10)

# Analyze the current order and compare it to all the orders of the customer
  RANK2=1
  Raz NBORD2, TOTAMOUNT2, TOTQTY2, STOPPED

# Loop on every customer
  For [MYOR]CUST(1) Where [BPC]BPCNUM<>this.CUSTOMER
    TOTCUSTOMER=0

# Let's update the asynchronous box for every invoice
  Call ASYNCTRACK(this.ACTX, escJson("Managing customer"),escJson([YOH]CUSTOMER),int(100*(NBORD+NBORD2)/ORDCOUNT)) From ASYRASYNC
  NBORD2INI=NBORD2
  CUSTOMER2=[YOH]CUSTOMER

    For [MYOR]CUST(2)
      NBORD2+=1 : TOTAMOUNT2+=[YOH]TOTAL : TOTCUSTOMER+=[YOH]TOTAL
      For [MYOR]CUST
        TOTQTY2+=[YOL]QTY
      Next
    Next
    RANK2+=(TOTCUSTOMER>=TOTAMOUNT)

# Check if stop requested after every customer loop
    If func ASYRASYNC.ABORTREQUESTED(this.ACTX)
      Call ADDDIAGNOSE(this.ACTX,escJson("Interruption. "-num$(NBORD+NBORD2)-"orders analyzed"),[V]CST_ASUCCESS) From ASYRASYNC
      STOPPED=1
      Break
    Else
      Call ADDDIAGNOSE(this.ACTX,escJson(num$(NBORD2-NBORD2INI)-"orders analyzed for "+CUSTOMER2),[V]CST_ASUCCESS) From ASYRASYNC
    Endif

  Next

  If STOPPED=1
    OK=fmet MYLOG.APUTLINE(" Analysis interrupted",[V]CST_AOK)
  Else

#   Second log: give the comparizon with the other customers
    OK=fmet MYLOG.APUTLINE(" Customer "+format$("K:20X",this.CUSTOMER)+" ranked at order:"+num$(RANK2)+ " among customers",[V]CST_AOK)
    OK=fmet MYLOG.APUTLINE("  ("+format$("N:2.2[%]",100*TOTAMOUNT/(TOTAMOUNT2+TOTAMOUNT))+" of amount ordered by all customers)",[V]CST_AOK)
    OK=fmet MYLOG.APUTLINE("  ("+format$("N:2.2[%]",100*TOTQTY/(TOTQTY2+TOTQTY))+" of quantities ordered by all customers)",[V]CST_AOK)
  Endif

# Let's allow the log file (in [TRA] volume) to be downloaded
  Call ADDLINKDOWNLOAD(this.ACTX,"ATYPE7","[TRA]/"+LOGFILE_NAME+".tra") From ASYRASYNC

  OK=fmet MYLOG.AENDLOG
Return

