$ACTION
#If GUSER = 'DEV02' : Infbox(ACTION) : Endif
  Case ACTION
    When "APRES_MODIF" : Gosub APRES_MODIF
    When "DEFLIG"            : Gosub DEFLIG
    When "INICRE_LIG"        : Gosub INI_LIG
    When "INIMOD_LIG"        : Gosub INI_LIG
    When "AAPRES_NBLIG"      : Gosub AAPRES_NBLIG
    When "BAPRES_NBLIG"      : Gosub BAPRES_NBLIG
    When "INICRE_LIG"        : Gosub INICRE_LIG
    When "APRES_CRE" : Gosub APRES_CRE
    When Default
  Endcase
Return
