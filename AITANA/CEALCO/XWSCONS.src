#<AdxTL>@(#)0.0.0.0 $Revision$ 
#webservice de consultas donde se devuelve un clob

Local Clbfile Z_XML
#Dbgaff
#Call XWSCONS("SIH","IMPORTE_PAGADO>0",Z_XML)
#Call XWSCONS("SIH","[SIV]INVDAT=[24/01/2019] and [DUD]TYP<>'SINIC'",Z_XML)
Call XWSCONS("SIH","[SIV]INVDAT=[24/01/2019] and !find([DUD]TYP,'SINIC')",Z_XML)
End

Subprog XWSCONS(TABLA, FILTRO, O_XML)
Value Char TABLA
Value Char FILTRO
Variable Clbfile O_XML

Local Integer JJ

If FILTRO=''
  FILTRO="1=1"
Endif

Raz O_XML

#Append O_XML,'<xml_version>1.04</xml_version>'
Append O_XML,'['

### Bucle sobre las tablas solicitadas
For X=0 To dim(TABLA)-1
Case TABLA(X)
  When "SOH"  : Gosub XSOH
  When "POH"  : Gosub XPOH
  When "SDH"  : Gosub XSDH
  When "SRH"  : Gosub XSRH
  When "PNH"  : Gosub XPNH
  When "SIH"  : Gosub XSIH
Endcase
Next

Append O_XML,']'

End

$XSOH

If !clalev([F:SOH]) : Local File SORDER   [SOH] : Endif
If !clalev([F:SOQ]) : Local File SORDERQ  [SOQ] : Endif
If !clalev([F:SOP]) : Local File SORDERP  [SOP] : Endif

Link [SOQ] With
& [SOH]SOH0 = [SOQ]SOHNUM,
& [SOP]SOP0 = [SOQ]SOHNUM; [SOQ]SOPLIN; [SOQ]SOQSEQ
& As [XPED]

For [XPED] Where evalue(FILTRO)
JJ+=1
  #>>GAO(11/12/2018)
  #Append O_XML,'{'
  If JJ=1
    Append O_XML,'{'
  Else
    Append O_XML,',{'
  Endif
  #<<GAO(11/12/2018)
  Append O_XML,'"STOFCY": "'+[SOQ]STOFCY+'",'
  Append O_XML,'"ITMREF": "'+[SOQ]ITMREF+'",'
  Append O_XML,'"SOHNUM": "'+[SOH]SOHNUM+'",'
  Append O_XML,'"ORDSTA": "'+num$([SOH]ORDSTA)+'",'
  Append O_XML,'"DEMDLVDAT": "'+[SOH]DEMDLVDAT+'",'
  Append O_XML,'"ORDDAT": "'+[SOH]ORDDAT+'",'
  Append O_XML,'"BPCORD": "'+[SOH]BPCORD+'",'
  Append O_XML,'"BPCNAM": "'+[SOH]BPCNAM(0)+'",'
  Append O_XML,'"QTYSTU": "'+num$([SOQ]QTYSTU)+'",'
  Append O_XML,'"DLVQTYSTU": "'+num$([SOQ]DLVQTYSTU)+'",'
  Append O_XML,'"SOPLIN": "'+num$([SOQ]SOPLIN)+'",'
  Append O_XML,'"APPFLG": "'+num$([SOH]APPFLG)+'",'
  Append O_XML,'"HLDSTA": "'+num$([SOH]HLDSTA)+'",'
  Append O_XML,'"CUSORDREF": "'+[SOH]CUSORDREF+'",'
  Append O_XML,'"SAU": "'+[SOP]SAU+'",'
  Append O_XML,'"GROPRI": "'+num$([SOP]GROPRI)+'",'
  Append O_XML,'"XORDLIN": "'+num$([SOQ]XORDLIN)+'",'
  Append O_XML,'"XORIGEN": "'+num$([SOH]XORIGEN)+'",'
  Append O_XML,'"XORIMAIL": "'+num$([SOH]XORIMAIL)+'",'
  Append O_XML,'"BPAADD": "'+[SOH]BPAADD+'",'
  Append O_XML,'"DISCRGVAL1": "'+num$([SOP]DISCRGVAL1)+'",'
  Append O_XML,'"DISCRGVAL2": "'+num$([SOP]DISCRGVAL2)+'",'
  Append O_XML,'"INVDTAAMT_3": "'+num$([SOH]INVDTAAMT(3))+'"'
  Append O_XML,'}'
Next

Return

$XPOH

If !clalev([F:POH]) : Local File PORDER   [POH] : Endif
If !clalev([F:POQ]) : Local File PORDERQ  [POQ] : Endif
If !clalev([F:POP]) : Local File PORDERP  [POP] : Endif

Link [POQ] With
& [POH]POH0 = [POQ]POHNUM,
& [POP]POP0 = [POQ]POHNUM; [POQ]POPLIN; [POQ]POQSEQ
& As [XPEC]

For [XPEC] Where evalue(FILTRO)
  JJ+=1
  If JJ=1
    Append O_XML,'{'
  Else
    Append O_XML,',{'
  Endif
  Append O_XML,'"POHFCY": "'+[POH]POHFCY+'",'
  Append O_XML,'"ITMREF": "'+[POQ]ITMREF+'",'
  Append O_XML,'"POHNUM": "'+[POQ]POHNUM+'",'
  Append O_XML,'"CLEFLG": "'+num$([POH]CLEFLG)+'",'
  Append O_XML,'"EXTRCPDAT": "'+[POQ]EXTRCPDAT+'",'
  Append O_XML,'"BPSNUM": "'+[POH]BPSNUM+'",'
  Append O_XML,'"BPRNAM": "'+[POH]BPRNAM(0)+'",'
  #Append O_XML,'"text_pie_cab></text_pie_cab>'
  Append O_XML,'"QTYSTU": "'+num$([POQ]QTYSTU)+'",'
  Append O_XML,'"RCPQTYSTU": "'+num$([POQ]RCPQTYSTU)+'",'
  Append O_XML,'"ORDDAT": "'+[POH]ORDDAT+'",'
  Append O_XML,'"POPLIN": "'+num$([POQ]POPLIN)+'",'
  Append O_XML,'"STU": "'+[POQ]STU+'",'
  Append O_XML,'"GROPRI": "'+num$([POP]GROPRI)+'",'
  Append O_XML,'"LINCLEFLG": "'+num$([POQ]LINCLEFLG)+'",'
  Append O_XML,'"ORDDAT_lin": "'+[POQ]ORDDAT+'"'
  Append O_XML,'}'
Next

Return

$XSDH

If !clalev([F:SDD]) : Local File SDELIVERYD [SDD] : Endif
If !clalev([F:SDH]) : Local File SDELIVERY  [SDH] : Endif
If !clalev([F:XSOH]): Local File SORDER     [XSOH]: Endif
If !clalev([F:XSOQ]): Local File SORDERQ    [XSOQ]: Endif

Link [SDD] With
& [SDH]SDH0= [SDD]SDHNUM
& As [XENT]

For [XENT] Where evalue(FILTRO)
JJ+=1
  If JJ=1
    Append O_XML,'{'
  Else
    Append O_XML,',{'
  Endif
  Append O_XML,'"SDHNUM": "'+[SDD]SDHNUM+'",'
  Append O_XML,'"STOFCY": "'+[SDH]STOFCY+'",'
  Append O_XML,'"SALFCY": "'+[SDH]SALFCY+'",'
  Append O_XML,'"ITMREF": "'+[SDD]ITMREF+'",'
  Append O_XML,'"XREFPEDIDO": "'+[SDH]XREFPEDIDO+'",'
  Append O_XML,'"SHIDAT": "'+[SDH]SHIDAT+'",'
  Append O_XML,'"QTY": "'+num$([SDD]QTY)+'",'
  Append O_XML,'"NETPRI": "'+num$([SDD]NETPRI)+'",'
  Append O_XML,'"CPRPRI": "'+num$([SDD]CPRPRI)+'",'
  Append O_XML,'"SDDLIN": "'+num$([SDD]SDDLIN)+'",'
  Append O_XML,'"BPAADD": "'+[SDH]BPAADD+'",'
  Append O_XML,'"BPCORD": "'+[SDH]BPCORD+'",'
  Append O_XML,'"SOHNUM": "'+[SDD]SOHNUM+'",'
  Append O_XML,'"SOPLIN": "'+num$([SDD]SOPLIN)+'",'
  Append O_XML,'"XORDLIN": "'+num$([SDD]XORDLIN)+'",'
  Append O_XML,'"SAU": "'+[SDD]SAU+'",'
  Read [XSOH]SOH0= [SDD]SOHNUM
  If fstat=0
    Append O_XML,'"CUSORDREF": "' +[XSOH]CUSORDREF +'",'
    Append O_XML,'"XORIGEN": "'   +[XSOH]XORIGEN   +'",'
    Append O_XML,'"XORIMAIL": "'  +[XSOH]XORIMAIL +'",'
  Endif
  Append O_XML,'"CFMFLG": "'+num$([SDH]CFMFLG)+'"'
  Append O_XML,'}'
Next

Return


$XSRH

If !clalev([F:SRD]) : Local File SRETURND   [SRD] : Endif
If !clalev([F:SRH]) : Local File SRETURN    [SRH] : Endif

Link [SRD] With
& [SRH]SRH0= [SRD]SRHNUM
& As [XDEV]

For [XDEV] Where evalue(FILTRO)
JJ+=1
  If JJ=1
    Append O_XML,'{'
  Else
    Append O_XML,',{'
  Endif
  Append O_XML,'"SRHNUM": "'+[SRD]SRHNUM+'",'
  Append O_XML,'"BPCORD": "'+[SRH]BPCORD+'",'
  Append O_XML,'"BPAADD": "'+[SRH]BPAADD+'",'
  Append O_XML,'"RTNDAT": "'+[SRH]RTNDAT+'",'
  Append O_XML,'"STOFCY": "'+[SRH]STOFCY+'",'
  Append O_XML,'"SRDLIN": "'+num$([SRD]SRDLIN)+'",'
  Append O_XML,'"ITMREF": "'+[SRD]ITMREF+'",'
  Append O_XML,'"QTYSTU": "'+num$([SRD]QTYSTU)+'",'
  Append O_XML,'"STU": "'+[SRD]STU+'",'
  Append O_XML,'"EXTQTYSTU": "'+num$([SRD]EXTQTYSTU)+'",'
  Append O_XML,'"NETPRI": "'+num$([SRD]NETPRI)+'",'
  Append O_XML,'"NETPRIATI": "'+num$([SRD]NETPRIATI)+'",'
  Append O_XML,'"SDHNUM": "'+[SRD]SDHNUM+'",'
  Append O_XML,'"SDDLIN": "'+num$([SRD]SDDLIN)+'"'
  Append O_XML,'}'
Next

Return

$XPNH

If !clalev([F:PND]) : Local File PRETURND   [PND] : Endif
If !clalev([F:PNH]) : Local File PRETURN    [PNH] : Endif

Link [PND] With
& [PNH]PNH0= [PND]PNHNUM
& As [XDEVC]

For [XDEVC] Where evalue(FILTRO)
JJ+=1
  If JJ=1
    Append O_XML,'{'
  Else
    Append O_XML,',{'
  Endif
  Append O_XML,'"PNHNUM": "'+[PND]PNHNUM+'",'
  Append O_XML,'"BPSNUM": "'+[PNH]BPSNUM+'",'
  Append O_XML,'"RTNDAT": "'+[PNH]RTNDAT+'",'
  Append O_XML,'"LINAMT": "'+num$([PND]LINAMT)+'",'
  Append O_XML,'"LINATIAMT": "'+num$([PND]LINATIAMT)+'",'
  Append O_XML,'"PNHFCY": "'+[PNH]PNHFCY+'",'
  Append O_XML,'"PTHNUM": "'+[PND]PTHNUM+'",'
  Append O_XML,'"PTDLIN": "'+num$([PND]PTDLIN)+'",'
  Append O_XML,'"PNDLIN": "'+num$([PND]PNDLIN)+'",'
  Append O_XML,'"ITMREF": "'+[PND]ITMREF+'",'
  Append O_XML,'"QTYSTU": "'+num$([PND]QTYSTU)+'",'
  Append O_XML,'"STU": "'+[PND]STU+'",'
  Append O_XML,'"NETPRI": "'+num$([PND]NETPRI)+'",'
  Append O_XML,'"CFMFLG": "'+num$([PNH]CFMFLG)+'"'
  Append O_XML,'}'
Next

Return

$XSIH

If !clalev([F:SID])   : Local File SINVOICED  [SID]   : Endif
If !clalev([F:SIH])   : Local File SINVOICE   [SIH]   : Endif
If !clalev([F:SIV])   : Local File SINVOICEV  [SIV]   : Endif
If !clalev([F:DUD])   : Local File GACCDUDATE [DUD]   : Endif
If !clalev([F:AOX])   : Local File AOBJTXT    [AOX]   : Endif
If !clalev([F:XWDUD]) : Local File XWDUD      [XWDUD] : Endif
If !clalev([F:SIL])   : Local File BPCINVLIG  [SIL]   : Endif
If !clalev([F:HAE])   : Local File GACCENTRY  [HAE]   : Endif

Local Decimal XIMPORTE
Local Integer XCHAR, XCHAR2, XCONTDUD, I, SIH_VENTAS, SIH_TERCEROS
Local Char XABRV, FECHAFAC(10),DIAFAC(2),MESFAC(2),ANNOFAC(4),RUTAFAC(250)

If FILTRO= "IMPORTE_PAGADO>0"
  #FILTRO="[XWDUD]AMTCUR>([XWDUD]PAYCUR+[XWDUD]TMPCUR)"
Endif

#Vemos si existen facturas de ventas y facturas de terceros
Raz SIH_VENTAS, SIH_TERCEROS
  Link [SID] With
&      [SIH]SIH0    = [SID]NUM,
&      [SIV]SIV0    = [SID]NUM,
&      [XWDUD]XWDUD0= [SID]NUM
&      As [XFAC]

For [XFAC] Where evalue(FILTRO)
  SIH_VENTAS = 2
  Break
Next

  Link [SIL] With
&      [SIH]SIH0    = [SIL]NUM,
&      [XWDUD]XWDUD0= [SIL]NUM
&      As [XFACT]

For [XFACT] Where evalue(FILTRO)
  SIH_TERCEROS = 2
  Break
Next


  Link [SID] With
&      [SIH]SIH0    = [SID]NUM,
&      [SIV]SIV0    = [SID]NUM,
&      [XWDUD]XWDUD0= [SID]NUM
&      As [XFAC]
&      Order By [SID]NUM;[SID]SIDLIN

For [XFAC] Where evalue(FILTRO)
  JJ+=1
  If JJ=1
    Append O_XML,'{'
  Else
    Append O_XML,',{'
  Endif
  Raz XIMPORTE
  Append O_XML,'"NUM": "'+[SID]NUM+'",'
  Append O_XML,'"SIVTYP": "'+[SIH]SIVTYP+'",'
  Append O_XML,'"BPCORD": "'+[SIV]BPCORD+'",'
  Append O_XML,'"INVDAT": "'+[SIV]INVDAT+'",'
  Append O_XML,'"SALFCY": "'+[SIV]SALFCY+'",'
  Append O_XML,'"AMTATI": "'+num$([SIH]AMTATI)+'",'
  Append O_XML,'"AMTNOT": "'+num$([SIH]AMTNOT)+'",'
  Append O_XML,'"SNS": "'+num$([SIH]SNS)+'",'

  Append O_XML,'"SIDLIN": "'+num$([SID]SIDLIN)+'",'
  Append O_XML,'"ITMREF": "'+[SID]ITMREF+'",'
  Append O_XML,'"QTY": "'+num$([SID]QTY)+'",'
  Append O_XML,'"SAU": "'+[SID]SAU+'",'
  Append O_XML,'"NETPRI": "'+num$([SID]NETPRI)+'",'
  #Append O_XML,'"AMTLIN": "'+num$([SID]AMTLIN)+'",'
  Append O_XML,'"AMTLIN": "'+num$([SID]QTY* [SID]NETPRI)+'",'
  Append O_XML,'"AMTATILIN": "'+num$([SID]AMTATILIN)+'",'
  Append O_XML,'"SDHNUM": "'+[SID]SDHNUM+'",'
  Append O_XML,'"SDDLIN": "'+num$([SID]SDDLIN)+'",'
  Append O_XML,'"SOHNUM": "'+[SID]SOHNUM+'",'
  Append O_XML,'"SOPLIN": "'+num$([SID]SOPLIN)+'",'
  Append O_XML,'"XORDLIN": "'+num$([SID]XORDLIN)+'",'
  Append O_XML,'"SIHORINUM": "'+[SID]SIHORINUM+'",'
  Append O_XML,'"SIDORILIN": "'+num$([SID]SIDORILIN)+'",'
  Append O_XML,'"SRHNUM": "'+[SID]SRHNUM+'",'
  Append O_XML,'"SRDLIN": "'+num$([SID]SRDLIN)+'",'
  #>>GAO(14/02/2019): Cambio este bloque por el de abajo
#  If filinfo(filpath("XPDF",[SID]NUM,"pdf"),7)>0 Then
#    Append O_XML,'"PDF": "'+filpath("XPDF",[SID]NUM,"pdf")+'",'
#  Else
#    Append O_XML,'"PDF": "'+''+'",'
#  Endif
  Raz FECHAFAC
  FECHAFAC = format$("YYYYMMDD",[SIV]INVDAT)
  ANNOFAC  = num$(year([SIV]INVDAT))
  MESFAC   = format$("N0:2",num$(month([SIV]INVDAT)))
  DIAFAC   = format$("N0:2",num$(day([SIV]INVDAT)))
  RUTAFAC  = "XPDF\"+ANNOFAC+'\'+MESFAC+'\'+DIAFAC
#  If filinfo(filpath("XPDF",[SID]NUM,"pdf"),7)>0 Then
#    #Append O_XML,'"PDF": "'+filpath("XPDF",[SID]NUM,"pdf")+'",'
#    Append O_XML,'"PDF": "'+'\CEALCO\XPDF\'+[SID]NUM+'.pdf",'
#  Else
  If filinfo(filpath(RUTAFAC,[SID]NUM,"pdf"),7)>0 Then
    #Append O_XML,'"PDF": "'+filpath("XPDF\"+FECHAFAC,[SID]NUM,"pdf")+'",'
    Append O_XML,'"PDF": "'+'\CEALCO\'+RUTAFAC+'\'+[SID]NUM+'.pdf",'
  Else
    If filinfo(filpath("XPDF",[SID]NUM,"pdf"),7)>0 Then
      #Append O_XML,'"PDF": "'+filpath("XPDF",[SID]NUM,"pdf")+'",'
      Append O_XML,'"PDF": "'+'\CEALCO\XPDF\'+[SID]NUM+'.pdf",'
    Else
      Append O_XML,'"PDF": "'+''+'",'
    Endif
  Endif
  #<<GAO(14/02/2019)
#  For [DUD] Where NUM= [SID]NUM
#    XIMPORTE+= [DUD]PAYCUR
#  Next
  Append O_XML,'"IMPORTE_PAGADO": "'+num$([XWDUD]PAYCUR + [XWDUD]TMPCUR)+'",'
  Append O_XML,'"ADJUNTOS": ['
  Raz XCHAR
  For [AOX] Where ABREV='SIH' and IDENT1=[SID]NUM
    XCHAR = instr(1, [AOX]NAM,"/")+1
    XCHAR2= instr(1, [AOX]NAM, "]")-1 #quitamos los primeros caracteres
    XABRV=  left$([AOX]NAM,XCHAR2)
    XABRV= ctrans(XABRV,"[","")
    XABRV= ctrans(XABRV,"]","")
    #Append O_XML,'"'+filpath(XABRV,"","")+right$([AOX]NAM, XCHAR)+'",'
    Append O_XML,'"'+right$([AOX]NAM, XCHAR)+'",'
  Next
  If XCHAR=0
    Append O_XML,+'"",'
  Endif
  Append O_XML,'""'
  Append O_XML,'],'

  Filter [DUD] Where NUM= [SIH]NUM
  XCONTDUD= rowcount([DUD])
  If XCONTDUD>1
    Raz I #GAO(29/11/2018)
    Append O_XML,'"DUDDAT": ['
    For [DUD]
      If I=0
        I=1
        Append O_XML,'"'+[DUD]DUDDAT+'"'
      Else
        Append O_XML,','
        Append O_XML,'"'+[DUD]DUDDAT+'"'
      Endif
    Next
    Raz I

    Append O_XML,'],'
    Append O_XML,'"AMTCUR": ['
    For [DUD]
      If I=0
        I=1
        Append O_XML,'"'+num$([DUD]AMTCUR)+'"'
      Else
        Append O_XML,','
        Append O_XML,'"'+num$([DUD]AMTCUR)+'"'
      Endif
    Next
    Append O_XML,']'
  Else
    For [DUD]
      Append O_XML,'"DUDDAT": ["'+[DUD]DUDDAT+'"],'       #GAO(30/11/2018): Le pongo corchetes porque lo pide el cliente
      Append O_XML,'"AMTCUR": ["'+num$([DUD]AMTCUR)+'"]'  #GAO(30/11/2018): Le pongo corchetes porque lo pide el cliente
    Next
  Endif
  Filter [DUD]

  #>>GAO(22/11/2018): Factura centralizada
  Append O_XML, ',' + '"XPIHASOC": "' + [SIH]XPIHASOC + '"'
  #Append O_XML, ',' + '"PDFPIH": "'   + filpath("XPDF",[SIH]XPIHASOC,"pdf")
  Append O_XML, ',' + '"ADJUNT_PIH": ['
  Raz XCHAR
  For [AOX] Where ABREV='PIH' and IDENT1=[SIH]XPIHASOC
    XCHAR = instr(1, [AOX]NAM,"/")+1
    XCHAR2= instr(1, [AOX]NAM, "]")-1 #quitamos los primeros caracteres
    XABRV=  left$([AOX]NAM,XCHAR2)
    XABRV= ctrans(XABRV,"[","")
    XABRV= ctrans(XABRV,"]","")
    #Append O_XML,'"'+filpath(XABRV,"","")+right$([AOX]NAM, XCHAR)+'",'
    Append O_XML,'"'+right$([AOX]NAM, XCHAR)+'",'
  Next
  If XCHAR=0
    Append O_XML,+'"",'
  Endif
  Append O_XML,'""'
  Append O_XML,']'
  #<<GAO(22/11/2018)

  Append O_XML,'}'
Next


#GAO(14/01/2019): Y ahora añadimos las facturas tercero cliente
  Link [SIL] With
&      [SIH]SIH0    = [SIL]NUM,
&      [XWDUD]XWDUD0= [SIL]NUM
&      As [XFACT]
&      Order By [SIL]NUM;[SIL]LIG

For [XFACT] Where evalue(FILTRO)
  JJ+=1
  If JJ=1 and SIH_VENTAS <> 2
    Append O_XML,'{'
  Else
    Append O_XML,',{'
  Endif
  Raz XIMPORTE
  Append O_XML,'"NUM": "'       + [SIL]NUM                       + '",'
  Append O_XML,'"SIVTYP": "'    + [SIH]SIVTYP                    + '",'
  Append O_XML,'"BPCORD": "'    + [SIH]BPR                       + '",'
  Append O_XML,'"INVDAT": "'    + [SIH]ACCDAT                    + '",'
  Append O_XML,'"SALFCY": "'    + [SIH]FCY                       + '",'
  Append O_XML,'"AMTATI": "'    + num$([SIH]AMTATI)              + '",'
  Append O_XML,'"AMTNOT": "'    + num$([SIH]AMTNOT)              + '",'
  Append O_XML,'"SNS": "'       + num$([SIH]SNS)                 + '",'

  Append O_XML,'"SIDLIN": "'    + num$([SIL]LIG)                 + '",'
  Append O_XML,'"ITMREF": "'    + [SIL]ACC(0)                    + '",'
  Append O_XML,'"QTY": "'       + num$([SIL]QTY)                 + '",'
  Append O_XML,'"SAU": "'       + ""                             + '",'
  Append O_XML,'"NETPRI": "'    + num$([SIL]AMTNOTLIN)           + '",'
  Append O_XML,'"AMTLIN": "'    + num$([SIL]AMTNOTLIN)           + '",'
  Append O_XML,'"AMTATILIN": "' + num$([SIL]AMTATILIN)           + '",'
  Append O_XML,'"SDHNUM": "'    + ""                             + '",'
  Append O_XML,'"SDDLIN": "'    + num$(0)                        + '",'
  Append O_XML,'"SOHNUM": "'    + ""                             + '",'
  Append O_XML,'"SOPLIN": "'    + num$(0)                        + '",'
  Append O_XML,'"XORDLIN": "'   + num$(0)                        + '",'
  Append O_XML,'"SIHORINUM": "' + ""                             + '",'
  Append O_XML,'"SIDORILIN": "' + num$(0)                        + '",'
  Append O_XML,'"SRHNUM": "'    + ""                             + '",'
  Append O_XML,'"SRDLIN": "'    + num$(0)                        + '",'
  #>>GAO(14/02/2019): Cambio este bloque por el de abajo
  #If filinfo(filpath("XPDF",[SIL]NUM,"pdf"),7)>0 Then
  #  Append O_XML,'"PDF": "'     + filpath("XPDF",[SIL]NUM,"pdf") + '",'
  #Else
  #  Append O_XML,'"PDF": "'     + ''                             + '",'
  #Endif
  Raz FECHAFAC
  FECHAFAC = format$("YYYYMMDD",[SIH]ACCDAT)
  ANNOFAC  = num$(year([SIH]ACCDAT))
  MESFAC   = format$("N0:2",num$(month([SIH]ACCDAT)))
  DIAFAC   = format$("N0:2",num$(day([SIH]ACCDAT)))
  RUTAFAC  = "XPDF\"+ANNOFAC+'\'+MESFAC+'\'+DIAFAC
#  If filinfo(filpath("XPDF",[SIL]NUM,"pdf"),7)>0 Then
#    Append O_XML,'"PDF": "'+'\CEALCO\XPDF\'+[SIL]NUM+'.pdf",'
#  Else
  If filinfo(filpath(RUTAFAC,[SIL]NUM,"pdf"),7)>0 Then
    Append O_XML,'"PDF": "'+'\CEALCO\'+RUTAFAC+'\'+[SIL]NUM+'.pdf",'
  Else
    If filinfo(filpath("XPDF",[SIL]NUM,"pdf"),7)>0 Then
      Append O_XML,'"PDF": "'+'\CEALCO\XPDF\'+[SIL]NUM+'.pdf",'
    Else
      Append O_XML,'"PDF": "'+''+'",'
    Endif
  Endif
  #<<GAO(14/02/2019)
  Append O_XML,'"IMPORTE_PAGADO": "' + num$([XWDUD]PAYCUR + [XWDUD]TMPCUR) + '",'
  Append O_XML,'"ADJUNTOS": ['
  Raz XCHAR
  For [AOX] Where ABREV='BIC' and IDENT1=[SIL]NUM
    XCHAR = instr(1, [AOX]NAM,"/")+1
    XCHAR2= instr(1, [AOX]NAM, "]")-1 #quitamos los primeros caracteres
    XABRV=  left$([AOX]NAM,XCHAR2)
    XABRV= ctrans(XABRV,"[","")
    XABRV= ctrans(XABRV,"]","")
    Append O_XML,'"'            + right$([AOX]NAM, XCHAR)        + '",'
  Next
  If XCHAR=0
    Append O_XML, + '"",'
  Endif
  Append O_XML,'""'
  Append O_XML,'],'

  Filter [DUD] Where NUM= [SIH]NUM
  XCONTDUD= rowcount([DUD])
  If XCONTDUD>1
    Raz I #GAO(29/11/2018)
    Append O_XML,'"DUDDAT": ['
    For [DUD]
      If I=0
        I=1
        Append O_XML,'"'        + [DUD]DUDDAT                    + '"'
      Else
        Append O_XML,','
        Append O_XML,'"'        + [DUD]DUDDAT                    + '"'
      Endif
    Next
    Raz I

    Append O_XML,'],'
    Append O_XML,'"AMTCUR": ['
    For [DUD]
      If I=0
        I=1
        Append O_XML,'"'        + num$([DUD]AMTCUR)              + '"'
      Else
        Append O_XML,','
        Append O_XML,'"'        + num$([DUD]AMTCUR)              + '"'
      Endif
    Next
    Append O_XML,']'
  Else
    For [DUD]
      Append O_XML,'"DUDDAT": ["' + [DUD]DUDDAT       + '"],' #Pongo corchetes porque lo pide el cliente
      Append O_XML,'"AMTCUR": ["' + num$([DUD]AMTCUR) + '"]'  #Pongo corchetes porque lo pide el cliente
    Next
  Endif
  Filter [DUD]

  #Factura centralizada
  Append O_XML, ',' + '"XPIHASOC": "' + [SIH]XPIHASOC + '"'
  Append O_XML, ',' + '"ADJUNT_PIH": ['
  Raz XCHAR
  For [AOX] Where ABREV='PIH' and IDENT1=[SIH]XPIHASOC
    XCHAR = instr(1, [AOX]NAM,"/")+1
    XCHAR2= instr(1, [AOX]NAM, "]")-1 #quitamos los primeros caracteres
    XABRV=  left$([AOX]NAM,XCHAR2)
    XABRV= ctrans(XABRV,"[","")
    XABRV= ctrans(XABRV,"]","")
    Append O_XML,'"'            + right$([AOX]NAM, XCHAR) + '",'
  Next
  If XCHAR=0
    Append O_XML,+'"",'
  Endif
  Append O_XML,'""'
  Append O_XML,']'

  Append O_XML,'}'
Next


#GAO(28/01/2019): Añadimos los asientos de saldos iniciales de clientes. Los cogemos de la tabla de Vencimientos.
If FILTRO = '' Then
  Link [DUD] With
&      [HAE]HAE0 = [DUD]TYP;[DUD]NUM
&      As [XASI]
&      Where [DUD]TYP = "SINIC" and find(left$([DUD]SAC,1),"C","D")
&      Order By [DUD]TYP;[DUD]NUM;[DUD]LIG

#If GUSER = 'DEV01' : Infbox("filtro:"-FILTRO-"JJ:"-num$(JJ)) : Endif
#For [XASI] Where evalue('[DUD]TYP="SINIC" and find(left$([DUD]SAC,1),"C","D")') and evalue(FILTRO)
For [XASI] Where evalue(FILTRO)
#If GUSER = 'DEV01' and JJ > 2000 : Infbox("JJ:"-num$(JJ)) : Endif
  JJ+=1
  If JJ=1
    Append O_XML,'{'
  Else
    Append O_XML,',{'
  Endif
  Raz XIMPORTE
  Append O_XML,'"NUM": "'       + [DUD]NUM                       + '",'
  Append O_XML,'"SIVTYP": "'    + [DUD]TYP                       + '",'
  Append O_XML,'"BPCORD": "'    + [DUD]BPR                       + '",'
  Append O_XML,'"INVDAT": "'    + [DUD]DUDDAT                    + '",'
  Append O_XML,'"SALFCY": "'    + [DUD]FCY                       + '",'
  Append O_XML,'"AMTATI": "'    + num$([DUD]AMTCUR)              + '",'
  Append O_XML,'"AMTNOT": "'    + num$([DUD]AMTCUR)              + '",'
  Append O_XML,'"SNS": "'       + num$([DUD]SNS)                 + '",'

  Append O_XML,'"SIDLIN": "'    + num$([DUD]LIG)                 + '",'
  Append O_XML,'"ITMREF": "'    + ""                             + '",'
  Append O_XML,'"QTY": "'       + num$(0)                        + '",'
  Append O_XML,'"SAU": "'       + ""                             + '",'
  Append O_XML,'"NETPRI": "'    + num$(0)                        + '",'
  Append O_XML,'"AMTLIN": "'    + num$(0)                        + '",'
  Append O_XML,'"AMTATILIN": "' + num$(0)                        + '",'
  Append O_XML,'"SDHNUM": "'    + ""                             + '",'
  Append O_XML,'"SDDLIN": "'    + num$(0)                        + '",'
  Append O_XML,'"SOHNUM": "'    + ""                             + '",'
  Append O_XML,'"SOPLIN": "'    + num$(0)                        + '",'
  Append O_XML,'"XORDLIN": "'   + num$(0)                        + '",'
  Append O_XML,'"SIHORINUM": "' + ""                             + '",'
  Append O_XML,'"SIDORILIN": "' + num$(0)                        + '",'
  Append O_XML,'"SRHNUM": "'    + ""                             + '",'
  Append O_XML,'"SRDLIN": "'    + num$(0)                        + '",'
  If filinfo(filpath("XPDF",[DUD]NUM,"pdf"),7)>0 Then
    Append O_XML,'"PDF": "'     + filpath("XPDF",[DUD]NUM,"pdf") + '",'
  Else
    Append O_XML,'"PDF": "'     + ''                             + '",'
  Endif
  Append O_XML,'"IMPORTE_PAGADO": "' + num$([DUD]PAYCUR + [DUD]TMPCUR) + '",'
  Append O_XML,'"ADJUNTOS": ['
  Raz XCHAR
  For [AOX] Where ABREV='DUD' and IDENT1=[DUD]NUM
    XCHAR = instr(1, [AOX]NAM,"/")+1
    XCHAR2= instr(1, [AOX]NAM, "]")-1 #quitamos los primeros caracteres
    XABRV=  left$([AOX]NAM,XCHAR2)
    XABRV= ctrans(XABRV,"[","")
    XABRV= ctrans(XABRV,"]","")
    Append O_XML,'"'            + right$([AOX]NAM, XCHAR)        + '",'
  Next
  If XCHAR=0
    Append O_XML, + '"",'
  Endif
  Append O_XML,'""'
  Append O_XML,'],'

#  Filter [DUD] Where NUM= [SIH]NUM
#  XCONTDUD= rowcount([DUD])
#  If XCONTDUD>1
#    Raz I #GAO(29/11/2018)
#    Append O_XML,'"DUDDAT": ['
#    For [DUD]
#      If I=0
#        I=1
#        Append O_XML,'"'        + [DUD]DUDDAT                    + '"'
#      Else
#        Append O_XML,','
#        Append O_XML,'"'        + [DUD]DUDDAT                    + '"'
#      Endif
#    Next
