#    Append O_XML,']'
#  Else
#    For [DUD]
#      Append O_XML,'"DUDDAT": ["' + [DUD]DUDDAT       + '"],' #Pongo corchetes porque lo pide el cliente
#      Append O_XML,'"AMTCUR": ["' + num$([DUD]AMTCUR) + '"]'  #Pongo corchetes porque lo pide el cliente
#    Next
#  Endif
#  Filter [DUD]
   Append O_XML,'"DUDDAT": ["' + [DUD]DUDDAT       + '"],' #Pongo corchetes porque lo pide el cliente
   Append O_XML,'"AMTCUR": ["' + num$([DUD]AMTCUR) + '"]'  #Pongo corchetes porque lo pide el cliente


  #Factura centralizada
  Append O_XML, ',' + '"XPIHASOC": "' + "" + '"'
  Append O_XML, ',' + '"ADJUNT_PIH": ['
  Raz XCHAR
#  For [AOX] Where ABREV='PIH' and IDENT1=[SIH]XPIHASOC
#    XCHAR = instr(1, [AOX]NAM,"/")+1
#    XCHAR2= instr(1, [AOX]NAM, "]")-1 #quitamos los primeros caracteres
#    XABRV=  left$([AOX]NAM,XCHAR2)
#    XABRV= ctrans(XABRV,"[","")
#    XABRV= ctrans(XABRV,"]","")
#    Append O_XML,'"'            + right$([AOX]NAM, XCHAR) + '",'
#  Next
#  If XCHAR=0
    Append O_XML,+'"",'
#  Endif
  Append O_XML,'""'
  Append O_XML,']'

  Append O_XML,'}'
Next
Endif

Return

