$ACTION
Case ACTION
 When Default
Endcase
Return

Subprog AM_PTE(VALEUR)
Variable Char    VALEUR()
If !clalev([F:TPT]):Local File TABPAYTERM: Endif
Local Integer WTRT: WTRT=0
Filter [F:TPT] Where PTE=VALEUR and PAM="TRF"
If rowcount([F:TPT])>0
 [M:BPC3]PAYBAN=GZBANPAGO
 Affzo [M:BPC3]PAYBAN
Endif
End


