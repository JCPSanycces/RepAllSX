#<AdxTL>@(#)0.0.0.0 $Revision$
# Second test: check if additional default values have been correctly set
#------------------------------------------------------------------------------#

Local Clbfile RESULT
RESULT=func TESTSUITE()
Errbox RESULT
End

Funprog TESTSUITE()

  Call ADD_TESTCASE("TEST_YORDER","Test classes YORDER with controls",1) From AXUNIT

End func AXUNIT.RUN_TESTSUITE("Test number 1","Check the classes")

#  Optional subprog called *before* running the test suite
Subprog SETUP

# Error handling variable
  Global Integer ERROR_V

# Cleanup tables
  Gosub CLEANUP_TABLES
End

#  Optional subprog called *after* running the test suite
Subprog TEARDOWN
  Gosub CLEANUP_TABLES
End

# Cleanup the YSHIP and YORDER table where some empty records could have been created
$CLEANUP_TABLES
  Local File YORDER, YLINE
  Delete [YOH] Where ORDNUM="TST_001"
  Delete [YLI] Where ORDNUM="TST_001"
Return

$NOCLASS
ERROR_V=errn
Resume

#
# Test YORDER and YLINE
#

Subprog TEST_YORDER()

#
# Check class YLINE
#
  Local Instance YLINE Using C_YLINE
  Local Instance YORDER Using C_YORDER
  Local Integer OK
  Local Integer NB_ERR
  Local Decimal EXPECTED_PRICE

  YLINE=NewInstance C_YLINE AllocGroup null
  OK=fmet YLINE.AINIT

  If OK<>[V]CST_AOK
    NB_ERR+=1
    Call LOG_LINE(" ** ERROR : AINIT method failed on YLINE") From AXUNIT
  Else
    Call LOG_LINE("Initialization done for order line") From AXUNIT
    If YLINE.QTY<>1
      NB_ERR+=1
      Call LOG_LINE(" ** ERROR : Default value not set on quantity") From AXUNIT
    Endif
    If YLINE.UNITPRICE<>0
      NB_ERR+=1
      Call LOG_LINE(" ** ERROR : Default value must not be given at the line level") From AXUNIT
    Endif
  Endif
  FreeGroup YLINE

  YORDER=NewInstance C_YORDER AllocGroup null
  OK=fmet YORDER.AINIT
  If OK<>[V]CST_AOK
    NB_ERR+=1
    Call LOG_LINE(" ** ERROR : AINIT method failed on YORDER") From AXUNIT
  Else
    Call LOG_LINE("Initialization done for order") From AXUNIT
    Local File YCUSTOMER : Read [YBP]YBP0 First
    Local File YITEM     : Read [YIT]YIT0 First
    Local File FACILITY  : Read [FCY]FCY0 First

    YORDER.CUSTOMER=[YBP]BPCNUM
    YORDER.FCY=[FCY]FCY
    YORDER.ORDNUM="TST_001"
    If YORDER.ORDSTA<>1 or YORDER.ORDDAT<>date$ or YORDER.CURRENCY<>[YBP]CUR
      Call LOG_LINE(" ** ERROR : Wrong default values on sales order") From AXUNIT
      Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
    Else
      Call LOG_LINE("Check line adding on an order") From AXUNIT
      OK=fmet YORDER.ADDLINE("LINES",[V]CST_ALASTPOS)
      If OK=[V]CST_ANOTDEFINED
        NB_ERR+=1
        Call LOG_LINE(" ** ERROR : ADDLINE method failed on YORDER") From AXUNIT
      Else
        YORDER.LINES(OK).ITEM=[YIT]ITMREF
        If YORDER.LINES(1).ORDNUM<>YORDER.ORDNUM or YORDER.LINES(1).QTY<>1
&       or YORDER.LINES(1).PRICE<>func YPRICE.PRICE(YORDER.LINES(1).ITEM,YORDER.CURRENCY)
&       or YORDER.LINES(1).DISCOUNT<>0 or YORDER.LINES(1).PRICE<>YORDER.LINES(1).UNITPRICE
          NB_ERR+=1
          Call LOG_LINE(" ** ERROR : Wrong default values on sales line") From AXUNIT
          Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
        Else
          OK=fmet YORDER.AINSERT()
          If OK<>[V]CST_AOK
            NB_ERR+=1
            Call LOG_LINE(" ** ERROR : Sales order creation failed") From AXUNIT
            Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
          Else
            If YORDER.LINES(1).ORDNUM<>YORDER.ORDNUM or YORDER.LINES(1).SORTLIN<>1 or YORDER.LINES(1).NUMLIN<>1
              NB_ERR+=1
              Call LOG_LINE(" ** ERROR : Wrong assignment of sales line keys") From AXUNIT
              Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
            Else
              If YORDER.TOTAL<>YORDER.LINES(1).PRICE
                NB_ERR+=1
                Call LOG_LINE(" ** ERROR : Wrong computation of sales order total") From AXUNIT
                Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
              Else
                Call LOG_LINE("Sales order successfully created") From AXUNIT
                Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif

  FreeGroup YORDER

  YORDER=NewInstance C_YORDER AllocGroup null
  Onerrgo NOCLASS
  [V]ERROR_V=0
  OK= fmet YORDER.AREAD("TST_001")
  Onerrgo
  If OK=[V]CST_AERROR or [V]ERROR_V<>0
    NB_ERR+=1
    Call LOG_LINE(" ** ERROR : Read failed on YORDER") From AXUNIT
  Else
    YORDER.LINES(1).QTY=-1
    Onerrgo NOCLASS
    [V]ERROR_V=0
    OK= fmet YORDER.AUPDATE
    Onerrgo
    If [V]ERROR_V<>0
      NB_ERR+=1
      Call LOG_LINE(" ** ERROR : update method unavailable on YORDER") From AXUNIT
    Elsif OK=[V]CST_AOK
      NB_ERR+=1
      Call LOG_LINE("negative quantity on a line was not rejected") From AXUNIT
    Else
      Call LOG_LINE("negative quantity on a line was rejected") From AXUNIT
      FreeGroup YORDER
      YORDER=NewInstance C_YORDER AllocGroup null
      OK= fmet YORDER.AREAD("TST_001")
      Read [YBP]YBP0>"B"
      YORDER.CUSTOMER=[YBP]BPCNUM
      YORDER.LINES(1).QTY=2
      YORDER.LINES(1).DISCOUNT=20
      OK= fmet YORDER.AUPDATE
      If OK<>[V]CST_AOK
        NB_ERR+=1
        Call LOG_LINE("Update on sales order was not successful") From AXUNIT
        Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
      Else
        If YORDER.CURRENCY<>[YBP]CUR or YORDER.LINES(1).PRICE<>2*YORDER.LINES(1).UNITPRICE*0.8
          NB_ERR+=1
          Call LOG_LINE(" ** ERROR : propagation rules failed on sales order update") From AXUNIT
          Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
        Else
          Call LOG_LINE("Update successful on YORDER") From AXUNIT
          Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT

          FreeGroup YORDER

          YORDER=NewInstance C_YORDER AllocGroup null
          OK= fmet YORDER.AREAD("TST_001")
          If OK=[V]CST_AERROR
            Call LOG_LINE(" ** ERROR : Read failed on YORDER") From AXUNIT
            Call LOG_CLASS(YORDER.AERROR,"YORDER.AERROR",1) From AXUNIT
          Else
            Onerrgo NOCLASS
            [V]ERROR_V=0
            OK= fmet YORDER.ADELETE()
            Onerrgo
            If OK=[V]CST_AERROR or [V]ERROR_V<>0
              Call LOG_LINE(" ** ERROR : Delete failed on YORDER") From AXUNIT
  #            If YORDER.AERROR(1)=null
  #               Call LOG_LINE("error not found") From AXUNIT
  #            Endif
              Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif

  FreeGroup YORDER

  Call CHECK_EQUAL(NB_ERR,0) From AXUNIT

End

