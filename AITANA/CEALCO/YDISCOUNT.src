#<AdxTL>@(#)0.0.0.0 $Revision$
# Type DIS

Funprog CONTROL_DISCOUNT(AINSTANCE,APRONAME,AVALUE)
Variable Instance AINSTANCE Using OBJECT
Value Char APRONAME
Variable Decimal AVALUE

Local Integer RETVAL
If  AVALUE>50
  RETVAL=fmet AINSTANCE.ASETERROR(APRONAME,"Discount too high",[V]CST_AERROR)
Elsif AVALUE<0
  RETVAL=fmet AINSTANCE.ASETERROR(APRONAME,"Discount must be positive",[V]CST_AERROR)
Else
  RETVAL=[V]CST_AOK
Endif

End RETVAL
