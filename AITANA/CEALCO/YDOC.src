#<AdxTL>@(#)0.0.0.0 $Revision$
# CREATION OF A DOCUMENT IN LOG VOLUME
# Uses administration data access API
# Parameters are: an instance of a document, a file name, and a title
Funprog CREATE_JSON_DOC(DOCUMENT,FILE_NAME,FILE_TITLE)
Variable Instance DOCUMENT Using OBJECT
Value Char FILE_NAME()
Value Char FILE_TITLE()

# Miscellaneous variables declarations
Local Clbfile DOCUMENT_JSON(2)

Local Char PROPS_COD(20)(1..2) : Local Char PROPS_VAL(100)(1..2)
Local Clbfile RESHEAD(0), DATA(0)
Local Char ID(36)
Local Blbfile BYTES(0)
Local Integer IS_ASCII : IS_ASCII=50

# Store the document in JSON format in a string: YSCRIPT.STRINGIFY stringifies its argument
  DOCUMENT_JSON=func YJSCRIPT.STRINGIFY(DOCUMENT)

# The content must be stored in a blob containing ASCII
  OK=strEncode(DOCUMENT_JSON,BYTES,IS_ASCII)

# The document will be read-only
  Raz PROPS_COD, PROPS_VAL
  PROPS_COD(1)="isReadOnly" : PROPS_VAL(1)='true'

# Let's create the document.
# If everything is OK, OK is equal to 200 and ID contains the ID of the document
  OK = func ASYRSAREA.WRITEALL
&   (BYTES,FILE_TITLE,FILE_NAME, "application/json", PROPS_COD, PROPS_VAL, ID, 'STD', 1, RESHEAD, DATA)
End OK


Funprog CREATE_HTML_SHIP(SHIPMENT,FILE_NAME,FILE_TITLE)
Variable Instance SHIPMENT Using C_YSHIP
Value Char FILE_NAME()
Value Char FILE_TITLE()
Local Integer I

Local File YORDER,BPCUSTOMER
Read [YOH]YOH0=SHIPMENT.ORDNUM : Read [BPC]BPC0=SHIPMENT.CUSTOMER

# Miscellaneous variables declarations
Local Clbfile DOCUMENT_HTML(2)

Local Char PROPS_COD(20)(1..2) : Local Char PROPS_VAL(100)(1..2)
Local Clbfile RESHEAD(0), DATA(0)
Local Char ID(36)
Local Blbfile BYTES(0)
Local Integer IS_ASCII : IS_ASCII=50

# Create a raw html document
  DOCUMENT_HTML="<HTML"
  DOCUMENT_HTML+="<H1>Shipment number "+SHIPMENT.ORDNUM+"/"+num$(SHIPMENT.DLVNUM)+"</H1>"
  DOCUMENT_HTML+="<BR>"
  DOCUMENT_HTML+="<H2>Customer:"+SHIPMENT.CUSTOMER+" "+[BPC]BPCNAM+"</H2>"
  DOCUMENT_HTML+="<H3>Total:"+num$(SHIPMENT.TOTAL)+" "+[YOH]CURRENCY+"</H3>"
  DOCUMENT_HTML+="<H3>Date:"+format$("D:DD[/]MM[/]YYYY",SHIPMENT.DLVDAT)+"</H3>"
  DOCUMENT_HTML+="<TABLE>"
  DOCUMENT_HTML+="<TR><TH>ITEM</TH><TH>Quantity</TH></TR>"
  For I=1 To maxtab(SHIPMENT.SHIPLINES)
    DOCUMENT_HTML+="<TR><TD>"+SHIPMENT.SHIPLINES(I).ITEM+"</TD><TD align=right>"+num$(SHIPMENT.SHIPLINES(I).QTY)+"</TD></TR>"
  Next I
  DOCUMENT_HTML+="</TABLE>"
  DOCUMENT_HTML+="</HTML>"

# The content must be stored in a blob containing ASCII
  OK=strEncode(DOCUMENT_HTML,BYTES,IS_ASCII)

# The document will be read-only
  Raz PROPS_COD, PROPS_VAL
  PROPS_COD(1)="isReadOnly" : PROPS_VAL(1)='true'

# Let's create the document.
# If everything is OK, OK is equal to 200 and ID contains the ID of the document
  OK = func ASYRSAREA.WRITEALL
&   (BYTES,FILE_TITLE,FILE_NAME, "text/html", PROPS_COD, PROPS_VAL, ID, 'STD', 1, RESHEAD, DATA)
End OK

