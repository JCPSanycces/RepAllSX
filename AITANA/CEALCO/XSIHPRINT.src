##=============================================================================
Subprog XSIHPRINT(XNUM)
Value Char XNUM

  If clalev([F:ZSIH])=0 : Local File SINVOICE  [ZSIH] : Endif
  If clalev([F:ZSIV])=0 : Local File SINVOICEV [ZSIV] : Endif
  Local Char TBPAR(20)(1..50),TBVAL(30)(1..50)
  Local Integer NBPAR
  Local Integer CODIMP
  Global Char C_FICHIER(250)

  Read [ZSIH]SIH0= XNUM
  If fstat=0
    If [ZSIH]ORIMOD = 5
      #Factura de ventas
      Read [F:ZSIV]SIV0 = XNUM

      Raz CODIMP
      If [ZSIV]STARPT=2
        CODIMP = 2
      Else
        CODIMP = 1
      Endif

  #>>GAO(24/12/2018): Comento Todo este bloque y sustituyo por el de abajo.
  #                   No existe XTRACE.adx, ni JJ, ni SBONFACP2.
#  Call XTRACE_TEST("generamos pdf"-XNUM) From XTRACE
#  NBPAR = 0
#  PARAM = "__ExportFile"    : VALEUR = filpath("XPDF", XNUM,"pdf")           : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__FormatExport"  : VALEUR = "29"                                      : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__REPORT"        : VALEUR = "SBONFACP2"                               : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__DESTINATION"   : VALEUR = "3"                                       : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__TYPDBA"        : VALEUR = "2"                                       : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__DBDATABASE"    : VALEUR = "sagex3"                                  : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__DBUSER"        : VALEUR = nomap                                     : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__DBPASSWORD"    : VALEUR = "tiger"                                   : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__WSTATION"      : VALEUR = "SERVERX3.Cealco.local"                   : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__CDUSER"        : VALEUR = GUSER                                     : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__ADXSOL"        : VALEUR = "SAGEX3"                                  : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__APPLICATION"   : VALEUR = nomap+";"+adxmac(-1)+";"+num$(adxtcp)     : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__APPRPT"        : VALEUR = ""                                        : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__RPTLAN"        : VALEUR = "SPA"                                     : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "facturedeb"      : VALEUR = ZNUM(JJ)                                  : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "facturefin"      : VALEUR = ZNUM(JJ)                                  : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  Call ETAT("SBONFACP2", "", "SPA", 2, "", TBPAR, TBVAL) From AIMP3

#  NBPAR = 0
#  PARAM = "__ExportFile"    : VALEUR = filpath("XPDF", XNUM,"pdf")            : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__FormatExport"  : VALEUR = "29"                                   : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__REPORT"        : VALEUR = "XSBONFACP"                            : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__DESTINATION"   : VALEUR = "4"                                    : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__TYPDBA"        : VALEUR = "2"                                    : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__DBDATABASE"    : VALEUR = "sagex3"                               : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__DBUSER"        : VALEUR = nomap                                  : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__DBPASSWORD"    : VALEUR = "tiger"                                : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__WSTATION"      : VALEUR = "SERVERX3.Cealco.local"                : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__CDUSER"        : VALEUR = GUSER                                  : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__ADXSOL"        : VALEUR = "SAGEX3"                               : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__APPLICATION"   : VALEUR = nomap+";"+adxmac(-1)+";"+num$(adxtcp)  : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__APPRPT"        : VALEUR = ""                                     : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "__RPTLAN"        : VALEUR = "SPA"                                  : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "facturedeb"      : VALEUR = XNUM                                   : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
#  PARAM = "facturefin"      : VALEUR = XNUM                                   : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
  #<<GAO(24/12/2018)

      NBPAR = 0
      PARAM = "sitedeb"       : VALEUR = [F:ZSIH]FCY          : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "sitefin"       : VALEUR = [F:ZSIH]FCY          : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "facturedeb"    : VALEUR = XNUM                 : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "facturefin"    : VALEUR = XNUM                 : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "typedeb"       : VALEUR = num$([F:ZSIH]INVTYP) : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "typefin"       : VALEUR = num$([F:ZSIH]INVTYP) : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "clientdeb"     : VALEUR = [F:ZSIH]BPR          : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "clientfin"     : VALEUR = [F:ZSIH]BPR          : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "datedeb"       : VALEUR = num$([F:ZSIV]INVDAT) : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "datefin"       : VALEUR = num$([F:ZSIV]INVDAT) : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "codimp"        : VALEUR = num$([F:ZSIV]STARPT) : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "impselections" : VALEUR = num$(1)              : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "duplicata"     : VALEUR = num$(1)              : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "traystd"       : VALEUR = num$(1)              : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "traybvr"       : VALEUR = num$(1)              : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "logosoc"       : VALEUR = num$(2)              : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "fcycpynam"     : VALEUR = num$(1)              : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR

      #C_FICHIER = filpath("XPDF",XNUM,"pdf","","","")
      Gosub CREATEFOLDER
      C_FICHIER = filpath(RUTA,XNUM,"pdf","","","")
#      Call ETAT("XSBONFACP","","SPA",0,"",TBPAR,TBVAL) From AIMP3

#MRR (08/07/2019) - Añadida condición para que se imprima formato XSBONFACPALC si las facturas son tipo 'FVT' y 'AVT'
      If [ZSIH]SIVTYP = 'FVT' or [ZSIH]SIVTYP = 'AVT'  Then
        Call ETAT("XSBONFACPALC","","SPA",0,"",TBPAR,TBVAL) From AIMP3
      Else
        Call ETAT("XSBONFACP","","SPA",0,"",TBPAR,TBVAL) From AIMP3
      Endif
#MRR (08/07/2019) - Añadida condición para que se imprima formato XSBONFACPALC si las facturas son tipo 'FVT' y 'AVT'

    Endif

    If [ZSIH]ORIMOD = 3
      #Call ECR_TRACE("imprimiendo PDF:"-[F:XSIH]NUM,0) From GESECRAN
      #Factura de terceros clientes
      NBPAR = 0
      PARAM = "societe"       : VALEUR = [F:ZSIH]CPY          : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "datedeb"       : VALEUR = num$([F:ZSIH]ACCDAT) : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "datefin"       : VALEUR = num$([F:ZSIH]ACCDAT) : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "numdeb"        : VALEUR = XNUM                 : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "numfin"        : VALEUR = XNUM                 : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "sitedeb"       : VALEUR = [F:ZSIH]FCY          : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "sitefin"       : VALEUR = [F:ZSIH]FCY          : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "tauxagios"     : VALEUR = num$([F:ZSIV]STARPT) : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "tauxescompte"  : VALEUR = num$([F:ZSIV]STARPT) : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "duplicata"     : VALEUR = num$(1)              : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "impselections" : VALEUR = num$(1)              : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "numedt"        : VALEUR = num$(1)              : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "nbrmulprint"   : VALEUR = num$(1)              : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "mulcoprint"    : VALEUR = num$(1)              : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "mentionpays"   : VALEUR = num$(1)              : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "mentionmontant": VALEUR = num$(1)              : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "sddprn"        : VALEUR = num$(1)              : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "traystd"       : VALEUR = num$(1)              : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
      PARAM = "traybvr"       : VALEUR = num$(1)              : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR

      #C_FICHIER = filpath("XPDF",XNUM,"pdf","","","")
      Gosub CREATEFOLDER2
      C_FICHIER = filpath(RUTA,XNUM,"pdf","","","")
      Call ETAT("XBPCINV","","SPA",0,"",TBPAR,TBVAL) From AIMP3
    Endif

  Endif
End
##=============================================================================
$CREATEFOLDER
  #GAO(14/02/2019)
  Local Integer NB_LIENS,STAT
  Local Char RUTA(250),FECHAFAC(10),ANNOFAC(4),MESFAC(2),DIAFAC(2),RUTAANNO(250),RUTAMES(250),RUTADIA(250)
  Raz NB_LIENS,STAT,RUTA,FECHAFAC

#  FECHAFAC = format$("YYYYMMDD",[F:ZSIV]INVDAT)
#  RUTA     = "D:\SAGE\SAGEX3\FOLDERS\CEALCO\XPDF\"+FECHAFAC
#  NB_LIENS = filinfo(RUTA,7)
#  If NB_LIENS < 0
#    Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+RUTA+'"',"",STAT) From ORDSYS
#  Endif

  ANNOFAC = num$(year([F:ZSIV]INVDAT))
  MESFAC  = format$("N0:2",num$(month([F:ZSIV]INVDAT)))
  DIAFAC  = format$("N0:2",num$(day([F:ZSIV]INVDAT)))

  RUTAANNO = "D:\SAGE\SAGEX3\FOLDERS\CEALCO\XPDF\"+ANNOFAC
  RUTAMES  = "D:\SAGE\SAGEX3\FOLDERS\CEALCO\XPDF\"+ANNOFAC+"\"+MESFAC
  RUTADIA  = "D:\SAGE\SAGEX3\FOLDERS\CEALCO\XPDF\"+ANNOFAC+"\"+MESFAC+"\"+DIAFAC
  RUTA     = RUTADIA

  NB_LIENS = filinfo(RUTAANNO,7)
  If NB_LIENS < 0
    Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+RUTAANNO+'"',"",STAT) From ORDSYS
  Endif
  NB_LIENS = filinfo(RUTAMES,7)
  If NB_LIENS < 0
    Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+RUTAMES+'"',"",STAT) From ORDSYS
  Endif
  NB_LIENS = filinfo(RUTADIA,7)
  If NB_LIENS < 0
    Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+RUTADIA+'"',"",STAT) From ORDSYS
  Endif

Return
##=============================================================================
$CREATEFOLDER2
  #GAO(14/02/2019)
  Local Integer NB_LIENS,STAT
  Local Char RUTA(250),FECHAFAC(10),ANNOFAC(4),MESFAC(2),DIAFAC(2),RUTAANNO(250),RUTAMES(250),RUTADIA(250)
  Raz NB_LIENS,STAT,RUTA,FECHAFAC

#  FECHAFAC = format$("YYYYMMDD",[F:ZSIH]ACCDAT)
#  RUTA     = "D:\SAGE\SAGEX3\FOLDERS\CEALCO\XPDF\"+FECHAFAC
#  NB_LIENS = filinfo(RUTA,7)
#  If NB_LIENS < 0
#    Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+RUTA+'"',"",STAT) From ORDSYS
#  Endif

  ANNOFAC = num$(year([F:ZSIH]ACCDAT))
  MESFAC  = format$("N0:2",num$(month([F:ZSIH]ACCDAT)))
  DIAFAC  = format$("N0:2",num$(day([F:ZSIH]ACCDAT)))

  RUTAANNO = "D:\SAGE\SAGEX3\FOLDERS\CEALCO\XPDF\"+ANNOFAC
  RUTAMES  = "D:\SAGE\SAGEX3\FOLDERS\CEALCO\XPDF\"+ANNOFAC+"\"+MESFAC
  RUTADIA  = "D:\SAGE\SAGEX3\FOLDERS\CEALCO\XPDF\"+ANNOFAC+"\"+MESFAC+"\"+DIAFAC
  RUTA     = RUTADIA

  NB_LIENS = filinfo(RUTAANNO,7)
  If NB_LIENS < 0
    Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+RUTAANNO+'"',"",STAT) From ORDSYS
  Endif
  NB_LIENS = filinfo(RUTAMES,7)
  If NB_LIENS < 0
    Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+RUTAMES+'"',"",STAT) From ORDSYS
  Endif
  NB_LIENS = filinfo(RUTADIA,7)
  If NB_LIENS < 0
    Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+RUTADIA+'"',"",STAT) From ORDSYS
  Endif

Return
