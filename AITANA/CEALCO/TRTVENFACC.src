# 116439.n - Moved to TRTVENFACC1
#$OUT_NBVAT
#GMESSAGE=mess(299,192,1)           : # Trop de codes taxe differents
#JLNONOK=1
#
#Return

#------------------------------------------------------------------------
# Chargement d'un tableau des taxes en local ﾃ partir des tableaux XV et XF
#
$CHARGE_TTAX
Local Decimal TBASTAX (0..dim([M:SIHV]XVTAX)-1)            : # Base de taxe    : Base produit + Base des ﾃｩlﾃｩments
Local Decimal TAMTTAX (0..dim([M:SIHV]XVTAX)-1)            : # Montant de taxe : Taxe produit + Taxe des ﾃｩlﾃｩments
Local Decimal TBASDEP (0..dim([M:SIHV]XVTAX)-1)            : # Base escomptable : Taxe produit + Taxe des ﾃｩlﾃｩments #gbn-81683
Local Char    TTAX (GLONVAT) (0..dim([M:SIHV]XVTAX)-1)     : # Code taxe
Local Decimal TTAUTAX (0..dim([M:SIHV]XVTAX)-1)            : # Taux de taxe
Local Integer WNBRTAX

Local Integer JLNONOK            : # controle nbre taxes ( 0=OK / 1=erreur )
Local Integer JL, JLV, JLV1, RV

Raz TBASTAX, TAMTTAX, TTAX, TTAUTAX

WNBRTAX=0
For JL=0 To dim(TBASTAX)-1
  If [M:SIHV]XVTAX(JL)<>""
     TTAX(JL)        = [M:SIHV]XVTAX(JL)
     TTAUTAX(JL)     = [M:SIHV]XVRAT(JL)
     TBASTAX(JL)     = [M:SIHV]XVSMI(JL)
     TAMTTAX(JL)     = [M:SIHV]XVAMT(JL)
     TBASDEP(JL)     = [M:SIHV]XVBASDEP(JL) #gbn-81683
     WNBRTAX += 1
  Endif
Next JL

# les pieds
Raz JLV1
For JL=0 To dim([M:SIHV]XFNUM)-1
#         il faut ajouter les donnﾃｩes taxes du pied dans le tableau global des taxes
    If [M:SIHV]XFTAX(JL)<>""                                       : # on a un code taxe
       RV=find([M:SIHV]XFTAX(JL),TTAX(0..dim(TTAX)-1))
       If !RV                                                      : # il faut creer la taxe
          If [M:SIHV]XFVATAMT(JL)<>0                               : #  si on a un mnt de taxe
             RV=find("",TTAX(0..dim(TTAX)-1))          : # recherche d'un poste
             If RV
                WNBRTAX += 1
             Else
                Gosub OUT_NBVAT From TRTVENFACC1  # 116439.n - Moved the call to TRTVENFACC1
             Endif
          Else                                                     : #  si mnt de taxe nul
             JLV1=1                                                : #  positionnement flag
          Endif
       Endif
       If RV
          TTAX(RV-1)     = [M:SIHV]XFTAX(JL)
          TTAUTAX(RV-1)  = [M:SIHV]XFRAT(JL)
          TBASTAX(RV-1) += [M:SIHV]XFSMI(JL)
          TAMTTAX(RV-1) += [M:SIHV]XFVATAMT(JL)
       Endif
# 96695 : Prise en cpte base HT d'un ﾃｩlt ds la base HT des taxes si mnt de taxe de l'elt nul
#    Elsif [M:SIHV]XFVATAMT(JL)<>0                                 : # On a un mnt de taxe : taux produit
    Elsif [M:SIHV]XFSMI(JL)<>0                                     : # On est en taux produit et on a une base
# 96695
        For I=0 To dim([M:SIHV]XVTAX)-1
            If evalue ("dim([M:SIHV]DTAVAT"+format$("N0:2",I+1)+")")>0
                If evalue ("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")") <> ""
                    RV=find(evalue("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")"),TTAX(0..dim(TTAX)-1))
                    If !RV                                                      : # il faut creer la taxe
                       If evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")") <> 0 : #  si on a un mnt de taxe
                          RV=find("",TTAX(0..dim(TTAX)-1))          : # recherche d'un poste
                          If RV
                             WNBRTAX += 1
                          Else
                             Gosub OUT_NBVAT From TRTVENFACC1 # 116439.n - Moved the call to TRTVENFACC1
                          Endif
                       Else                                                     : #  si mnt de taxe nul
                          JLV1=1                                                : #  positionnement flag
                       Endif
                    Endif
                    If RV
                        TTAX(RV-1)     = evalue ("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")")
                        TTAUTAX(RV-1)  = evalue ("[M:SIHV]DTAVATRT"+format$("N0:2",I+1)+"("+num$(JL)+")")
                        TBASTAX(RV-1) += evalue ("[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$(JL)+")")
                        TAMTTAX(RV-1) += evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")
                    Endif
                Endif
            Endif
        Next
    Endif
Next JL

#         si un poste exonere de taxe n'a pas ete mis dans le tableau global des taxes
#         il faut essayer de trouver un poste dispo dans le tableau global
#         ??? Pourquoi gerer l'exo en dernier : pas explique sauf si necessaire de mettre le poste en dernier
If JLV1
  For JL=0 To dim([M:SIHV]XFNUM)-1
    # Issue 116730
    # Ne doit concerner que les ﾃｩlﾃｩments en taux fixe
    # Les ﾃｩlﾃｩments en taux produit ont dﾃｩjﾃ ﾃｩtﾃｩ pris en compte dans la boucle prﾃｩcﾃｩdente
    #If [M:SIHV]XFTAX(JL)<>"" & [M:SIHV]XFVATAMT(JL)=0
    If [M:SIHV]XFTAX(JL)<>"" & [M:SIHV]XFVATAMT(JL)=0 & [M:SIHV]VATRUL(JL)=4
    # End issue 116730
       RV=find([M:SIHV]XFTAX(JL),TTAX(0..dim([F:SIH]TAX)-1))
       If !RV                                                      : # il faut creer la taxe
          RV=find("",TTAX(0..dim(TTAX)-1))             : # recherche du 1er poste vide
          If RV
             WNBRTAX += 1
          Else
             Gosub OUT_NBVAT From TRTVENFACC1 # 116439.n - Moved the call to TRTVENFACC1
          Endif
       Endif
       If RV
          TTAX(RV-1)     = [M:SIHV]XFTAX(JL)
          TTAUTAX(RV-1)  = [M:SIHV]XFRAT(JL)
          TBASTAX(RV-1) += [M:SIHV]XFSMI(JL)
          TAMTTAX(RV-1) += [M:SIHV]XFVATAMT(JL)
       Endif
    Elsif [M:SIHV]XFTAX(JL)="" & [M:SIHV]VATRUL(JL)=1
        For I=0 To dim([M:SIHV]XVTAX)-1
            If evalue ("dim([M:SIHV]DTAVAT"+format$("N0:2",I+1)+")")>0
                If evalue ("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")") <> "" &
&                  evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")=0
                    RV=find(evalue("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")"),TTAX(0..dim([F:SIH]TAX)-1))
                    If !RV                                                      : # il faut creer la taxe
                       RV=find("",TTAX(0..dim(TTAX)-1))          : # recherche d'un poste
                       If RV
                           WNBRTAX += 1
                       Else
                           Gosub OUT_NBVAT From TRTVENFACC1 # 116439.n - Moved the call to TRTVENFACC1
                       Endif
                    Endif
                    If RV
                        TTAX(RV-1)     = evalue ("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")")
                        TTAUTAX(RV-1)  = evalue ("[M:SIHV]DTAVATRT"+format$("N0:2",I+1)+"("+num$(JL)+")")
                        TBASTAX(RV-1) += evalue ("[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$(JL)+")")
                        TAMTTAX(RV-1) += evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")
                    Endif
                Endif
            Endif
        Next
    Endif
  Next JL
Endif

Return

#------------------------------------------------------------------------
# Chargement de [F:SIH] ﾃ partir des tableaux XV et XF
#
$CHARGE_SIH

Local Integer JL, JLNV           : # pour nbre de taxes a stocker
Local Integer JLDV               : # indice derniﾃｨre taxe

Raz [F:SIH]TAX, [F:SIH]BASTAX, [F:SIH]AMTTAX, [F:SIH]NBRTAX

# Chargement d'un tableau des taxes en local ﾃ partir des tableaux XV et XF
Gosub CHARGE_TTAX

JLNV=dim([M:SIHV]XVTAX)-1                           : # nbre de taxes maxi du masque valorisation
JLDV=find("",[M:SIHV]XVTAX)                           : # recherche rang derniere taxe dans tableau
If JLDV : JLNV=JLDV-1 : Endif
If JLNV>dim([F:SIH]TAX) : Gosub OUT_NBVAT From TRTVENFACC1 : Endif # 116439.n - Moved the call to TRTVENFACC1

# Chargement de [F:SIH] ﾃ partir du tableau des taxes en local
For JL=0 To dim(TBASTAX)-1
  If TTAX(JL)<>""
     [F:SIH]TAX(JL)=TTAX(JL)
     [F:SIH]BASTAX(JL)=TBASTAX(JL)
     [F:SIH]AMTTAX(JL)=TAMTTAX(JL)
     [F:SIH]NBRTAX+=1
  Endif
Next JL

# totaux HT et TTC
[F:SIH]AMTNOT  = [M:SIHV]INVNOT
[F:SIH]AMTATI  = [M:SIHV]INVATI
[F:SIH]AMTNOTL = [M:SIHV]INVNOTRPT
[F:SIH]AMTATIL = [M:SIHV]INVATIRPT
[F:SIH]BASDEP  = [M:SIHV]BASDEP #gbn-81683

# Spﾃｩcificitﾃｩ USA
If dim([M:SIH4]AMTTAXUSA) > 0
   For JL=0 To 9
       [F:SIH]AMTTAXUSA(JL) = [M:SIH4]AMTTAXUSA(JL)
   Next
Endif

# Issue 110830 - 2016-01-27 by CPO : Spanish legislation
If func AFNC.ACTIV("KSP") and GCURLEG="SPA"
  If [M:SIHV]XVTAX(0)="" and [M:SIHX]XVTAX(0)<>"" and [M:SIHV]INVNOT=0
    [F:SIH]TAX(0)= [M:SIHX]XVTAX(0)
    [F:SIH]NBRTAX+=1
  Endif
Endif
Return


