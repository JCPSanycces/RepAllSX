############################################################################
# Chargement de la valorisation des documents devis, commandes, livraisons #
# - Table SVCRFOOT [SVF] : Elﾃｩments de facturation                         #
# - Table SVCRVAT  [SVV] : Taxes                                           #
# Le chargement s'effectue ﾃ partir de l'ﾃｩcran de valorisation [M:SIHV]    #
#    et du fichier entﾃｪte doc [F:SQH],[F:SOH],[F:SDH],[F:SIH]              #
# Prﾃｩ-requis : [M:SIHV] chargﾃｩ, [F:SQH],[F:SOH],[F:SDH],[F:SIH] chargﾃｩ     #
############################################################################
# Entrﾃｩe  LMAJCOD    : Code mise ﾃ jour :                                  #
#                            "C" : Crﾃｩation                                #
#                            "M" : Modification                            #
#                            "A" : Suppression                             #
#         LOBJCOD    : Code objet :                                        #
#                            "SQH" : Devis                                 #
#                            "SOH" : Commandes                             #
#                            "SDH" : Livraisons                            #
#                            "TNH" : Transportation notes                  # : # 91606 :(04/08/14) Transportation notes (Sales part dev)
#                            "SIH" : Factures                              #
############################################################################
Subprog UPD_VALORISATION (LMAJCOD, LOBJCOD)
Value Char    LMAJCOD
Value Char    LOBJCOD

Local Integer JL, RV
Local Integer WTRBEGIN, WVCRTYP
Local Char    WVCRNUM(GLONVCR), WVAT(GLONVAT)

#--CPO 84133 Complﾃｩmemt : ouverture des tables
If clalev([F:SVV])=0 : Local File SVCRVAT  [SVV] : Endif
If clalev([F:SVF])=0 : Local File SVCRFOOT [SVF] : Endif
#--/CPO

$UPD_VAL
GOK=1

If adxlog<>1
   Trbegin [SVV],[SVF]
   WTRBEGIN=1
Endif

Case LOBJCOD
  When "SQH" : WVCRTYP=1  : WVCRNUM=[F:SQH]SQHNUM
  When "SOH" : WVCRTYP=20 : WVCRNUM=[F:SOH]SOHNUM
  When "SDH" : WVCRTYP=2  : WVCRNUM=[F:SDH]SDHNUM
  # 91606 :(04/08/14) Transportation notes (Sales part dev)
  When "TNH" : WVCRTYP=22 : WVCRNUM=[F:TNH]TNHNUM
  # 91606 :(04/08/14) Transportation notes (Sales part dev)
  When "SIH" : WVCRTYP=4  : WVCRNUM=[F:SIH]NUM
Endcase

Case LMAJCOD
    When "C" : Gosub SVF_CREATION    # Creation     dans la table SVCRFOOT
               If GOK<1 End Endif
               Gosub SVV_CREATION    # Creation     dans la table SVCRVAT
               If GOK<1 End Endif
    When "M" : Gosub SVF_ANNULE      # Modification dans la table SVCRFOOT
                If GOK<1 End Endif
               Gosub SVF_CREATION
               If GOK<1 End Endif
               Gosub SVV_ANNULE      # Modification dans la table SVCRVAT
               If GOK<1 End Endif
               Gosub SVV_CREATION
               If GOK<1 End Endif
    When "A" : Gosub SVF_ANNULE      # Suppression  dans la table SVCRFOOT
               If GOK<1 End Endif
               Gosub SVV_ANNULE      # Suppression  dans la table SVCRVAT
               If GOK<1 End Endif
Endcase

If WTRBEGIN=1 : Commit : Endif

End


# ----------------------------------- #
# Creation     dans la table SVCRFOOT #
# ----------------------------------- #
$SVF_CREATION
# On boucle sur la table des ﾃｩlements de pied
For JL=0 To dim([M:SIHV]XFNUM)-1
  If [M:SIHV]XFNUM(JL)<>0
     Raz [F:SVF]
    #If [M:SIHV]XFDTAAMT(JL) <> 0.0001  #XQ008 GAO(23/01/2019)
     Gosub INICRE_SVF
     #>>XQ008 GAO(23/01/2019)
     #Call ECR_TRACE("EF:"-[M:SIHV]XFNUM(JL)-" importe:"-num$([M:SIHV]XFDTAAMT(JL)),0) From GESECRAN
     #<<XQ008
     [F:SVF]DTA        = [M:SIHV]XFNUM(JL)
     [F:SVF]DTAAMT     = [M:SIHV]XFDTAAMT(JL)
     [F:SVF]DTATYP     = [M:SIHV]CLCBAS(JL)
     [F:SVF]DTANOT     = [M:SIHV]XFNOT(JL)
     # 102423 : Belgium Early discounts
     [F:SVF]DTADEP     = [M:SIHV]DTADEP(JL)
     # 102423
     For I=0 To dim([F:SVF]DTANET)-1
         [F:SVF]DTAVATNOT(I) = evalue ("[M:SIHV]DTANOT"+format$("N0:2",I+1)+"("+num$(JL)+")")
         [F:SVF]DTANET(I)    = evalue ("[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$(JL)+")")
         [F:SVF]DTAVAT(I)    = evalue ("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")")
         [F:SVF]DTAVATRAT(I) = evalue ("[M:SIHV]DTAVATRT"+format$("N0:2",I+1)+"("+num$(JL)+")")
         [F:SVF]DTAVATAMT(I) = evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")
         # 102423 : Belgium Early discounts
         [F:SVF]DTAVATDEP(I) = evalue ("[M:SIHV]DTADEP"+format$("N0:2",I+1)+"("+num$(JL)+")")
         # 102423
     Next

     [F:SVF]CLCORD     = [M:SIHV]CLCORD(JL)
     [F:SVF]AMTCOD     = [M:SIHV]AMTCOD(JL)
     [F:SVF]DTADSP     = [M:SIHV]DSP(JL)
     [F:SVF]DTADEPFLG  = [M:SIHV]DTADEPFLG(JL) #Gbn-81683

     Write [F:SVF]
     If fstat   GOK=0 : Call FSTA("SVF") From GLOCK : Break : Endif
    #Endif  #XQ008 GAO(23/01/2019)
  Endif
Next JL

If GOK<1 Goto AB_UPDVAL Endif
Return

$INICRE_SVF

[F:SVF]VCRTYP=WVCRTYP  : [F:SVF]VCRNUM=WVCRNUM

Case LOBJCOD
  When "SQH" : [F:SVF]=[F:SQH]
  When "SOH" : [F:SVF]=[F:SOH]
  When "SDH" : [F:SVF]=[F:SDH]
  # 91606 :(04/08/14) Transportation notes (Sales part dev)
  When "TNH" : [F:SVF]=[F:TNH]
  # 91606 :(04/08/14) Transportation notes (Sales part dev)
  When "SIH" : [F:SVF]=[F:SIH]
Endcase

If evalue("dim([F:SVF]CREDAT)")>0
    Assign "[F:SVF]CREDAT" With date$
Endif
If evalue("dim([F:SVF]CREUSR)")>0
    Assign "[F:SVF]CREUSR" With GUSER
Endif
If evalue("dim([F:SVF]EXPNUM)")>0
    Assign "[F:SVF]EXPNUM" With [C]EXPORT
Endif

Return

# ----------------------------------- #
# Suppression  dans la table SVCRFOOT #
# ----------------------------------- #
$SVF_ANNULE

Delete [SVF] Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
If fstat=1
    GOK=-1 : GLOCK="$SVCRFOOT"-WVCRTYP-WVCRNUM : Goto ROL_UPDVAL
Endif
Return

# ----------------------------------- #
# Creation     dans la table SVCRVAT  #
# ----------------------------------- #
$SVV_CREATION

# On boucle sur la table des taxes liﾃｩes aux produits
For JL=0 To dim ([M:SIHV]XVTAX)-1
  If [M:SIHV]XVTAX(JL)<>""
     Raz [F:SVV]
     Gosub INICRE_SVV

     [F:SVV]VAT       = [M:SIHV]XVTAX(JL)
     [F:SVV]VATTYP    = [M:SIHV]XVTYP(JL)
     [F:SVV]VATRAT    = [M:SIHV]XVRAT(JL)

     [F:SVV]VATGRO    = [M:SIHV]XVNOT(JL)
     [F:SVV]VATNET    = [M:SIHV]XVSMI(JL)
     [F:SVV]VATAMT    = [M:SIHV]XVAMT(JL)
     [F:SVV]VATSUPAMT = [M:SIHV]XVSUP(JL)

     [F:SVV]BASTAX    = [M:SIHV]XVSMI(JL)
     [F:SVV]AMTTAX    = [M:SIHV]XVAMT(JL)

     Gosub SVV_CREATION_VAT_DEP From TRTVENFACDEP #gbn-81683

     Write [F:SVV]
     If fstat   GOK=0 : Call FSTA("SVV") From GLOCK : Break : Endif
  Endif
Next JL
If GOK<1 Goto AB_UPDVAL Endif

# On boucle sur la table des ﾃｩlﾃｩments de pied
Local Shortint LDEPCNX

For JL=0 To dim([M:SIHV]XFTAX)-1
  If [M:SIHV]XFTAX(JL)<>""                                       : # on a un code taxe
        Read [SVV]SVV0=WVCRTYP;WVCRNUM;[M:SIHV]XFTAX(JL)
        If fstat
            Raz [F:SVV]
            Gosub INICRE_SVV
            [F:SVV]VAT    = [M:SIHV]XFTAX(JL)
            [F:SVV]VATTYP = 1
            [F:SVV]VATRAT = [M:SIHV]XFRAT(JL)
            [F:SVV]BASTAX = [M:SIHV]XFSMI(JL)
            [F:SVV]AMTTAX = [M:SIHV]XFVATAMT(JL)
            LDEPCNX=1 : Gosub SVV_CREATION_FOOT_DEP From TRTVENFACDEP #gbn-81683

            Write [F:SVV]
            If fstat   GOK=0 : Call FSTA("SVV") From GLOCK : Break : Endif
        Else
            [F:SVV]BASTAX += [M:SIHV]XFSMI(JL)
            [F:SVV]AMTTAX += [M:SIHV]XFVATAMT(JL)
            LDEPCNX=2 : Gosub SVV_CREATION_FOOT_DEP From TRTVENFACDEP #gbn-81683

            Rewrite [F:SVV]
            If fstat   GOK=0 : Call FSTA("SVV") From GLOCK : Break : Endif
        Endif
# 96695 : Prise en cpte base HT d'un ﾃｩlt ds la base HT des taxes si mnt de taxe de l'elt nul
#    Elsif [M:SIHV]XFVATAMT(JL)<>0                                 : # On a un mnt de taxe : taux produit
  Elsif [M:SIHV]XFSMI(JL)<>0                                     : # On est en taux produit et on a une base
# 96695
        For I=0 To dim([M:SIHV]XVTAX)-1
            If evalue ("dim([M:SIHV]DTAVAT"+format$("N0:2",I+1)+")")>0
                If evalue ("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")") <> ""
                    WVAT=evalue ("[M:SIHV]DTAVAT"+format$("N0:2",I+1)+"("+num$(JL)+")")
                    Read [SVV]SVV0=WVCRTYP;WVCRNUM;WVAT
                    If fstat
                        Raz [F:SVV]
                        Gosub INICRE_SVV
                        [F:SVV]VAT    = WVAT
                        [F:SVV]VATTYP = 1
                        [F:SVV]VATRAT = evalue ("[M:SIHV]DTAVATRT"+format$("N0:2",I+1)+"("+num$(JL)+")")
                        [F:SVV]BASTAX = evalue ("[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$(JL)+")")
                        [F:SVV]AMTTAX = evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")
                        Write [F:SVV]
                        If fstat   GOK=0 : Call FSTA("SVV") From GLOCK : Break : Endif
                    Else
                        [F:SVV]BASTAX += evalue ("[M:SIHV]DTANET"+format$("N0:2",I+1)+"("+num$(JL)+")")
                        [F:SVV]AMTTAX += evalue ("[M:SIHV]DTAVATMT"+format$("N0:2",I+1)+"("+num$(JL)+")")
                        Rewrite [F:SVV]
                        If fstat   GOK=0 : Call FSTA("SVV") From GLOCK : Break : Endif
                    Endif
                Endif
            Endif
        Next
  Endif
Next JL
If GOK<1 Goto AB_UPDVAL Endif

Return

$INICRE_SVV

[F:SVV]VCRTYP=WVCRTYP  : [F:SVV]VCRNUM=WVCRNUM

Case LOBJCOD
  When "SQH" : [F:SVV]=[F:SQH]
  When "SOH" : [F:SVV]=[F:SOH]
  When "SDH" : [F:SVV]=[F:SDH]
  # 91606 :(04/08/14) Transportation notes (Sales part dev)
  When "TNH" : [F:SVV]=[F:TNH]
  # 91606 :(04/08/14) Transportation notes (Sales part dev)
  When "SIH" : [F:SVV]=[F:SIH]
Endcase

If evalue("dim([F:SVV]CREDAT)")>0
    Assign "[F:SVV]CREDAT" With date$
Endif
If evalue("dim([F:SVV]CREUSR)")>0
    Assign "[F:SVV]CREUSR" With GUSER
Endif
If evalue("dim([F:SVV]EXPNUM)")>0
    Assign "[F:SVV]EXPNUM" With [C]EXPORT
Endif

Return

# ----------------------------------- #
# Suppression  dans la table SVCRVAT  #
# ----------------------------------- #
$SVV_ANNULE

Delete [SVV] Where VCRTYP=WVCRTYP & VCRNUM=WVCRNUM
If fstat=1
    GOK=-1 : GLOCK="$SVCRVAT"-WVCRTYP-WVCRNUM : Goto ROL_UPDVAL
Endif
Return


#-----------------------------------------------------------------------#
#    Rollback                                                           #
#-----------------------------------------------------------------------#
#--> rollback + nouvelle tentative
$ROL_UPDVAL
  If WTRBEGIN = 1 Then
    # FGR 09/08/2013 : X3SUIVI91776 : Ne faire le Rollback QUE si WTRBEGIN = 1. Sinon c'est l'appelant qui s'en charge.
    #                  Sans ce test, ﾃｧa provoque l'erreur "Return ne correspond pas ﾃ Gosub"
    Rollback
  Endif
  Call ROLL From GLOCK
  If   GROLL
     #--  rollback suite ﾃ une erreur dans la transaction
     Call ECR_TRACE(num$(WVCRTYP)-WVCRNUM-mess(17,107,1),1)From GESECRAN
  Else Goto UPD_VAL
  Endif
Return

#--> rollback
$AB_UPDVAL
  If WTRBEGIN = 1 Then
    # FGR 09/08/2013 : X3SUIVI91776 : Ne faire le Rollback QUE si WTRBEGIN = 1. Sinon c'est l'appelant qui s'en charge.
    #                  Sans ce test, ﾃｧa provoque l'erreur "Return ne correspond pas ﾃ Gosub"
    Rollback
  Endif
  Call ECR_TRACE(num$(WVCRTYP)-WVCRNUM-mess(17,107,1),1)From GESECRAN
Return

