#########################################################################
# CALCULTAXE calcule les montants des taxes 1/2/3
#------------------------------------------------------------------------
# appel (garnir) :
#   CPY    CUR  DAT  PRITYP  VAT
#   RAT    si le taux n'est pas garni (=999.99) il est recherche en table
#   BASTAX montants soumis aux taxes
#     lignes produit  : (0) soumis ﾃ TVA  (1) soumis ﾃ TS1  (2) soumis ﾃ TS2
#     frais           : (3) soumis ﾃ TVA
#     taxe secondaire : (4) soumis ﾃ TVA
# retour
#   RAT    si non garnis ﾃ l'appel
#   BASTAX les montants sont mis ﾃ jour (ex: (4) si TS1 TS2 soumis ﾃ TVA)
#          mis ﾃ jour dans le cas du calcul ﾃ partir du TTC
#      nota un montant exonﾃｩrﾃｩ reste garni (pour les rﾃｩpartitions prorata)
#   AMTNOT montant HT
#   AMTATI montant TTC
#
#########################################################################
Subprog CALCULTAXE (CPY,CUR,DAT,PRITYP,VAT,RV,RAT,BASTAX,AMTTAX,AMTNOT,AMTATI)
Value    Char     CPY            : # sociﾃｩtﾃｩ (nﾃｩcessaire ﾃ table des taux de taxe
Value    Char     CUR            : # devise
Value    Date     DAT            : # date (nﾃｩcessaire ﾃ table des taux de taxe)
Value    Integer  PRITYP         : # 1=HT 2=TTC
Value    Char     VAT () (0..)   : # les 3 codes de taxe
Value    Shortint RV (0..2)      : # rang de la taxe dans le tableau des taxes XV
Variable Decimal  RAT (0..)      : # les 3 taux de taxe
Variable Decimal  BASTAX (0..)   : # les bases de taxe
Variable Decimal  AMTTAX (0..)   : # les montants
Variable Decimal  AMTNOT         : # montant HT  (si ligne=celui de la ligne)
Variable Decimal  AMTATI         : # montant TTC (si ligne=celui de la ligne)

Local    Shortint I
Local    Decimal  MTSOUMIS (0..2)
Local    Decimal  TAXE1          : # si calcul sur autre que le ht
Local    Decimal  TAXE2          : # si calcul sur autre que le ht
Local    Decimal  TVATAXE1       : # si calcul sur autre que le ht et taxe soumise ﾃ tva : # Bug 65799
Local    Decimal  TVATAXE2       : # si calcul sur autre que le ht et taxe soumise ﾃ tva : # Bug 65799
Local    Decimal  TXTOT          : # taux total de la ligne si prix TTC

# tester le dim(VAT) et les autres ???

MTSOUMIS(0)=BASTAX(0) : MTSOUMIS(1)=BASTAX(1) : MTSOUMIS(2)=BASTAX(2)

# Taxes secondaires :
# - Calcul de la taxe UNIQUEMENT si la base n est pas le HT

Raz TVATAXE1, TVATAXE2 : # Bug 65799
Raz TAXE1, TAXE2       : # Issue 74556 - Optimisation
For I=1 To 2
   # Bug 73097
   # Si Document HT,  calcul des taxes secondaires
   # Si Document TTC, calcul des taxes secondaires sf si mnt TTC ligne taxe principale ﾃ 0 (Dans ce cas, pas de taxe donc pas de calcul des taxes)
#  If RV(I)<>0                               : # Bug 73097
  If RV(I)<>0 & (PRITYP=1 | MTSOUMIS(0)<>0)  : # Bug 73097
    If [M:SIHX]XVBAS(RV(I)-1)=2   : # si base de taxe est montant1
#      TAXE1=arr(MTSOUMIS(I)*RAT(I)/100,[F:TCU]CURRND)
      If MTSOUMIS(I)<>0   : # Issue 74556 - Optimisation
        Call RNDTVA(MTSOUMIS(I),RAT(I),[F:TCU]CURRND,TAXE1) From SUBTVT
      Endif
      AMTTAX(I)=TAXE1
      If [M:SIHX]XVCHA(RV(I)-1)=2      : # la taxe est soumise ﾃ taxe principale
       If TAXE1<>0        :  # Issue 74556 - Optimisation
        Call RNDTVA(TAXE1,RAT(0),[F:TCU]CURRND,TVATAXE1) From SUBTVT : # calcul de la taxe principale : # Bug 65799
        If [M:SIHX]XVTYP(RV(I)-1)=2 : BASTAX(4) += TAXE1 : Endif : # c'est une taxe parafiscale
        If [M:SIHX]XVTYP(RV(I)-1)=3 : BASTAX(5) += TAXE1 : Endif : # c'est une taxe spﾃｩciale
       Endif
      Endif
    Endif
    If [M:SIHX]XVBAS(RV(I)-1)=3    : # si base de taxe est montant2
#      TAXE2=arr(MTSOUMIS(I)*RAT(I)/100,[F:TCU]CURRND)
      If MTSOUMIS(I)<>0   : # Issue 74556 - Optimisation
        Call RNDTVA(MTSOUMIS(I),RAT(I),[F:TCU]CURRND,TAXE2) From SUBTVT
      Endif
      AMTTAX(I)=TAXE2
      If [M:SIHX]XVCHA(RV(I)-1)=2  : # la taxe est soumise ﾃ taxe principale
        If TAXE2<>0       : # Issue 74556 - Optimisation
          Call RNDTVA(TAXE2,RAT(0),[F:TCU]CURRND,TVATAXE2) From SUBTVT : # calcul de la taxe principale : # Bug 65799
          If [M:SIHX]XVTYP(RV(I)-1)=2 : BASTAX(4) += TAXE2 : Endif : # c'est une taxe parafiscale
          If [M:SIHX]XVTYP(RV(I)-1)=3 : BASTAX(5) += TAXE2 : Endif : # c'est une taxe spﾃｩciale
        Endif
      Endif
    Endif
  Endif
Next I


# Document saisi avec type de prix TTC
# - cumul des % pour determiner le la base HT de chaque taxe
# - Attention : il faut enlever du TTC ligne les taxes TAXE1 et TAXE2 calculees sur autre que HT

If PRITYP=2
  Raz TXTOT                        : # taux cumule
  For I=0 To 2
    If RV(I)<>0 and [M:SIHX]XVBAS(RV(I)-1)<2  : # uniquement si taxe sur HT
      TXTOT += RAT(I)/100
      If [M:SIHX]XVCHA(RV(I)-1)=2 and I<>0    : # si taxe principale sur taxe secondaire
        TXTOT += (RAT(I)/100)*(RAT(0)/100)
      Endif
    Endif
  Next I
  For I=0 To 2
    If RV(I)<>0 and [M:SIHX]XVBAS(RV(I)-1)<2  : # uniquement si taxe sur HT
      If TXTOT<>0
#         BASTAX(I)=arr(((MTSOUMIS(I)-TAXE1-TAXE2)/(TXTOT+1)),[F:TCU]CURRND)
# Bug 65799
#         Call RNDTVA2(MTSOUMIS(I)-TAXE1-TAXE2,TXTOT*100,[F:TCU]CURRND,GBIDD3) From SUBTVT
#         BASTAX(I)=MTSOUMIS(I)-TAXE1-TAXE2-GBIDD3
         Raz GBIDD3     : # Issue 74556 - Optimisation
         If MTSOUMIS(I)-TAXE1-TAXE2-TVATAXE1-TVATAXE2<>0   : # Issue 74556 - Optimisation
           Call RNDTVA2(MTSOUMIS(I)-TAXE1-TAXE2-TVATAXE1-TVATAXE2,TXTOT*100,[F:TCU]CURRND,GBIDD3) From SUBTVT
         Endif
         BASTAX(I)=MTSOUMIS(I)-TAXE1-TAXE2-TVATAXE1-TVATAXE2-GBIDD3
# Bug 65799
      Endif
    Endif
  Next I
Endif

# Calcul des taxes secondaires sur HT

For I=1 To 2
  If RV(I)<>0 and [M:SIHX]XVBAS(RV(I)-1)<2
#    AMTTAX(I)=arr(BASTAX(I)*RAT(I)/100,[F:TCU]CURRND)
    Raz AMTTAX(I)     : # Issue 74556 - Optimisation
    If BASTAX(I)<>0   : # Issue 74556 - Optimisation
      Call RNDTVA(BASTAX(I),RAT(I),[F:TCU]CURRND,AMTTAX(I)) From SUBTVT
      If [M:SIHX]XVCHA(RV(I)-1)=2      : # la taxe est soumise ﾃ taxe principale
        If [M:SIHX]XVTYP(RV(I)-1)=2 : BASTAX(4) += AMTTAX(I) : Endif : # c'est une taxe parafiscale
        If [M:SIHX]XVTYP(RV(I)-1)=3 : BASTAX(5) += AMTTAX(I) : Endif : # c'est une taxe spﾃｩciale
      Endif
    Endif
  Endif
Next I

# Calcul de la taxe principale

# - si document en HT : taux applique sur base HT + montants des taxes secondaires soumises
If PRITYP=1
   #AMTTAX(0)=arr((BASTAX(0)+BASTAX(4)+BASTAX(5))*RAT(0)/100,[F:TCU]CURRND)
   GBIDD3=BASTAX(0)+BASTAX(4)+BASTAX(5)
   Raz AMTTAX(0)  : # Issue 74556 - Optimisation
   If GBIDD3<>0   : # Issue 74556 - Optimisation
     Call RNDTVA(GBIDD3,RAT(0),[F:TCU]CURRND,AMTTAX(0)) From SUBTVT
   Endif
Endif

# - si document en TTC : taxe calculee par difference
#   dans MTSOUMIS(0)=TTC / BASTAX(0)=HT / AMTTAX(1 et 2)= Taxes secondaires
If PRITYP=2
   # 85189 : Mnt taxe nﾃｩgatif si TVA exo et taxe secondaire avec formule
   #AMTTAX(0)=MTSOUMIS(0)-BASTAX(0)-AMTTAX(1)-AMTTAX(2)
   # 96182 : Si prix net nﾃｩgatif, le Mnt taxe est nﾃｩgatif, dans ce cas c'est normal, le laisser nﾃｩgatif
   #AMTTAX(0)=max(0,MTSOUMIS(0)-BASTAX(0)-AMTTAX(1)-AMTTAX(2))
   ## 85189
   If MTSOUMIS >= 0
     AMTTAX(0)=max(0,MTSOUMIS(0)-BASTAX(0)-AMTTAX(1)-AMTTAX(2))
   Else
     AMTTAX(0)=MTSOUMIS(0)-BASTAX(0)-AMTTAX(1)-AMTTAX(2)
   Endif
   # 96182
Endif

# Calcul du HT et TTC ligne

If PRITYP=1
  AMTNOT=MTSOUMIS(0)
  AMTATI=AMTNOT+AMTTAX(0)+AMTTAX(1)+AMTTAX(2)
Endif
If PRITYP=2
  AMTATI=MTSOUMIS(0)
  AMTNOT=AMTATI-AMTTAX(0)-AMTTAX(1)-AMTTAX(2)
Endif

End


###########################################################################
# Ouverture et reservations : Repartition des elts facturation a la ligne
###########################################################################
$OUV_DSPLIN
Global Integer G_VALSFL  : # Nbre de postes de repartition ( code activite SFL )
Global Integer G_VALSIH  : # nbre de lignes factures ( code activite SIH )

G_VALSFL=func AFNC.ACTIV ("SFL")
G_VALSIH=func AFNC.ACTIV ("SIH")

If !clalev([M:SIHV]) : Local Mask SIHV [SIHV]    : Endif

#-- Tables utilisees dans le garnissage des champs de [M:SIHV]
#   ( lors du chargement de table de valorisation dans [M:SIHV] )

If !clalev([F:TVT])  : Local File TABVAT   [TVT] : Endif
Gosub OPEN_SFI From TRTX3CPY: #If !clalev([F:SFI])  : Local File SFOOTINV [SFI] : Endif

Return

###########################################################################
# Repartition des elements de facturation a la ligne
# - si repartion au poids  : GSALDSPWEU = Unite de repartition
# - si repartion au volume : GSALDSPVOU = Unite de repartition
###########################################################################
$CLC_DSPLIN

Local Integer JL, JL0, JL1, JL2
If dim(G_CLCDSPLIN)<1    : Return : Endif     : # faire la rﾃｩpartition si G_CLCDSPLIN=1
If G_CLCDSPLIN=0         : Return : Endif     : # ( dans INICRE, INIMOD )
Raz G_CLCDSPLIN

If !find(2,[M:SIHV]DSPLIN) & !find(3,[M:SIHV]DSPLIN) & !find(4,[M:SIHV]DSPLIN) & !find(5,[M:SIHV]DSPLIN)

  #--CPO 102340 Avenants lignes mis ﾃ jour si modification en-tﾃｪte
  #--Il faut enrichir la correction 90362 qui met ﾃ 1 les UPDFLG si pas d'ﾃｩlﾃｩments rﾃｩpartis
  #--G_PREV_DSPLIN est mis ﾃ 1 en AM_INVDTAAMT si un ﾃｩlﾃｩment rﾃｩparti est remis ﾃ 0
  If dim(G_PREV_DSPLIN)<0
    Return
  Elsif G_PREV_DSPLIN <> 1
    Return
  Endif

  G_PREV_DSPLIN = 0 :#--Une fois pris en compte, on doit le remettre ﾃ 0 !
  #--/102340

   #--CPO 90362 DDTANOT et DDTANUM non remis a zﾃｩro sur commande
   #--Avant le return, il faut Raz les DDTANUM et DDTANOT
   #--Cas d'un passage ﾃ 0 d'un ﾃｩlement auparavant rﾃｩparti
   # --- Raz de la classe [M:SIHV]DDTANUMxx et DDTANOTxx de la repartition
   If dim([M:SIHV]DDTANUM01)>0 : Raz [M:SIHV]DDTANUM01, [M:SIHV]DDTANOT01 : Endif
   If dim([M:SIHV]DDTANUM02)>0 : Raz [M:SIHV]DDTANUM02, [M:SIHV]DDTANOT02 : Endif
   If dim([M:SIHV]DDTANUM03)>0 : Raz [M:SIHV]DDTANUM03, [M:SIHV]DDTANOT03 : Endif
   If dim([M:SIHV]DDTANUM04)>0 : Raz [M:SIHV]DDTANUM04, [M:SIHV]DDTANOT04 : Endif
   If dim([M:SIHV]DDTANUM05)>0 : Raz [M:SIHV]DDTANUM05, [M:SIHV]DDTANOT05 : Endif
   If dim([M:SIHV]DDTANUM06)>0 : Raz [M:SIHV]DDTANUM06, [M:SIHV]DDTANOT06 : Endif
   If dim([M:SIHV]DDTANUM07)>0 : Raz [M:SIHV]DDTANUM07, [M:SIHV]DDTANOT07 : Endif
   If dim([M:SIHV]DDTANUM08)>0 : Raz [M:SIHV]DDTANUM08, [M:SIHV]DDTANOT08 : Endif
   If dim([M:SIHV]DDTANUM09)>0 : Raz [M:SIHV]DDTANUM09, [M:SIHV]DDTANOT09 : Endif
   #     Si + de 9 colonnes de rﾃｩparition ( raz champ par champ )

   For JL0=10 To G_VALSFL
      For JL1=0 To VAL_SIH-1
          Assign ("[M:SIHV]DDTANUM"+format$("N0:2",JL0)+"("+num$(JL1)+")") With 0
          Assign ("[M:SIHV]DDTANOT"+format$("N0:2",JL0)+"("+num$(JL1)+")") With 0
      Next JL1
   Next JL0
   #--Il faut ﾃｩgalement positionner le flag, car il y a eu des rﾃｩpartitions auparavant
   #--Cas d'un dernier ﾃｩlﾃｩment rﾃｩparti qui est remis ﾃ 0
   #--Le test est fait sur le flag de [SIH4] car qque soit le document d'oﾃｹ on vient, il y a transclasse et on rﾃｩcupﾃｨre les infos
    If find(2,[M:SIH4]DSPLINFLG(0..[M:SIH4]NBLIG))>0
      For JL0=0 To [M:SIH4]NBLIG-1
        # Nomencl.ss-traitance : Si Pdt fini, c'est le service et non le pdt fini qui hﾃｩrite de la valeur proratisﾃｩe
        If [M:SIH4]LINTYP(JL0)=10 JL2=JL0+1 Else JL2=JL0 Endif

        [M:SIH4]UPDFLG(JL2)=1
        Case [M:SIH0]ORICLC
             When "GESSQH" : [M:SQH2]UPDFLG(JL2)=1
             When "GESSDH", "GESSDHF" : [M:SDH1]UPDFLG(JL2)=1
            # 91606 :(04/08/14) Transportation notes (Sales part dev)
             When "GESTNH" : [M:TNH1]UPDFLG(JL2)=1
            # 91606 :(04/08/14) Transportation notes (Sales part dev)
             When "GESSOH" : [M:SOH4]UPDFLG(JL2)=1
        Endcase
      Next
    Endif
   #--/
   Return                                     : # aucun elt reparti a la ligne
Endif

# --- Constitution de tableaux internes des valeurs de repartition des lignes
#     tous les tableaux sont de la dimension du nombre de lignes de la facture
#     popur chaque ligne : chargement des valeurs de repartition necessaires

Local Decimal T_DSPAMT   (0..[M:SIH4]NBLIG)   : # Tableau repartition montants
Local Decimal T_DSPQTY   (0..[M:SIH4]NBLIG)   : # Tableau repartition quantites
Local Decimal T_DSPWEI   (0..[M:SIH4]NBLIG)   : # Tableau repartition poids
Local Decimal T_DSPVOL   (0..[M:SIH4]NBLIG)   : # Tableau repartition volumes

Local Decimal S_DSPPRO                        : # somme des valeurs de repartition
Local Decimal L_DSPXXX
Local Decimal T_DSPPRO   (0..[M:SIH4]NBLIG)   : # Tableau des valeurs reparties de elt courant
Local Decimal T_DSPDEP   (0..[M:SIH4]NBLIG)   : # 102423 : Belgium Early discounts : Discount amount table

Local Decimal W_DSPECART

For JL=0 To [M:SIH4]NBLIG-1
    If dim([M:SIH4]DSPLINFLG)>0 & [M:SIH4]DSPLINFLG(JL)=1
       Goto DSP_L0                            : # ligne non concernee par la repartition
    Endif
    # Prorata des montants
    # Nomencl.ss-traitance : On ne prend pas le pdt fini (LINTYP=10) (on prend le service et la matiﾃｨre fournie)
    If !find([M:SIH4]LINTYP(JL), 10)
        If find(3,[M:SIHV]DSPLIN)
           T_DSPAMT(JL)=[M:SIH4]AMTNOTLIN(JL)
        Endif
    Endif
    # Prorata des qtﾃｩs
    # Nomencl.ss-traitance : On ne prend pas le service (LINTYP=11,13) (on prend le pdt fini et la matiﾃｨre fournie)
    If !find([M:SIH4]LINTYP(JL), 11,13)
        If find(2,[M:SIHV]DSPLIN)                 : # repartir suivant qte US (choux+carottes)
           T_DSPQTY(JL)=[M:SIH4]QTYSTU(JL)
        Endif
    Endif
    # Prorata des poids ou volume : (lecture article)
    # Nomencl.ss-traitance : On ne prend ni le service (LINTYP=11,13) ni la matiﾃｨre (LINTYP=12) (on ne prend que le pdt fini)
    If !find([M:SIH4]LINTYP(JL), 11,12,13)
        If find(4,[M:SIHV]DSPLIN) | find(5,[M:SIHV]DSPLIN)
           If [M:SIH4]ITMREF(JL)<>[F:ITM]ITMREF
              Read [ITM]ITM0=[M:SIH4]ITMREF(JL)
           Endif
        Endif
    Endif
    # Prorata des poids
    # Nomencl.ss-traitance : On ne prend ni le service (LINTYP=11,13) ni la matiﾃｨre (LINTYP=12) (on ne prend que le pdt fini)
    If !find([M:SIH4]LINTYP(JL), 11,12,13)
        If find(4,[M:SIHV]DSPLIN)                 : # repartir suivant poids
         If not(([F:ITM]SCSFLG=2 | [F:ITM]GENFLG=2) & [F:ITM]SALFLG=2 & [F:ITM]DLVFLG<>2) # Issue 107888 - 2016-06-20 by CPO : US120 Normal order -> Invoices (by using a scheduling invoice)
           T_DSPWEI(JL)=[M:SIH4]QTYSTU(JL)*[F:ITM]ITMWEI
           # Issue 74556 - Optimisation
           If [F:ITM]WEU<>GSALDSPWEU & T_DSPWEI(JL)<>0
              Call CALCUL_QTY(T_DSPWEI(JL),[F:ITM]WEU,T_DSPWEI(JL),GSALDSPWEU,GBIDD3) From TRTX3
           Endif
         Endif
        Endif
    Endif
    # Prorata des volumes
    # Nomencl.ss-traitance : On ne prend ni le service (LINTYP=11,13) ni la matiﾃｨre (LINTYP=12) (on ne prend que le pdt fini)
    If !find([M:SIH4]LINTYP(JL), 11,12,13)
        If find(5,[M:SIHV]DSPLIN)                 : # repartir suivant volume
         If not(([F:ITM]SCSFLG=2 | [F:ITM]GENFLG=2) & [F:ITM]SALFLG=2 & [F:ITM]DLVFLG<>2) # Issue 107888 - 2016-06-20 by CPO : US120 Normal order -> Invoices (by using a scheduling invoice)
           T_DSPVOL(JL)=[M:SIH4]QTYSTU(JL)*[F:ITM]ITMVOU
           # Issue 74556 - Optimisation
           If [F:ITM]VOU<>GSALDSPVOU & T_DSPVOL(JL)<>0
              Call CALCUL_QTY(T_DSPVOL(JL),[F:ITM]VOU,T_DSPVOL(JL),GSALDSPVOU,GBIDD3) From TRTX3
           Endif
         Endif
        Endif
    Endif
$DSP_L0
Next

# --- Init. de la classe [M:SIHV]DDTANUMxx et DDTANOTxx de la repartition
If dim([M:SIHV]DDTANUM01)>0 : Raz [M:SIHV]DDTANUM01, [M:SIHV]DDTANOT01 : Endif
If dim([M:SIHV]DDTANUM02)>0 : Raz [M:SIHV]DDTANUM02, [M:SIHV]DDTANOT02 : Endif
If dim([M:SIHV]DDTANUM03)>0 : Raz [M:SIHV]DDTANUM03, [M:SIHV]DDTANOT03 : Endif
If dim([M:SIHV]DDTANUM04)>0 : Raz [M:SIHV]DDTANUM04, [M:SIHV]DDTANOT04 : Endif
If dim([M:SIHV]DDTANUM05)>0 : Raz [M:SIHV]DDTANUM05, [M:SIHV]DDTANOT05 : Endif
If dim([M:SIHV]DDTANUM06)>0 : Raz [M:SIHV]DDTANUM06, [M:SIHV]DDTANOT06 : Endif
If dim([M:SIHV]DDTANUM07)>0 : Raz [M:SIHV]DDTANUM07, [M:SIHV]DDTANOT07 : Endif
If dim([M:SIHV]DDTANUM08)>0 : Raz [M:SIHV]DDTANUM08, [M:SIHV]DDTANOT08 : Endif
If dim([M:SIHV]DDTANUM09)>0 : Raz [M:SIHV]DDTANUM09, [M:SIHV]DDTANOT09 : Endif
#     Si + de 9 colonnes de rﾃｩparition ( raz champ par champ )

For JL0=10 To G_VALSFL
   For JL1=0 To VAL_SIH-1
       Assign ("[M:SIHV]DDTANUM"+format$("N0:2",JL0)+"("+num$(JL1)+")") With 0
       Assign ("[M:SIHV]DDTANOT"+format$("N0:2",JL0)+"("+num$(JL1)+")") With 0
   Next JL1
Next JL0

# --- Boucle sur tous les ﾃｩlﾃｩments

For JL=0 To dim([M:SIHV]XFNUM)-1
    Raz T_DSPPRO, S_DSPPRO                        : # init du tableau de repartition

    If [M:SIHV]XFNUM(JL)=0 : Break       : Endif  : # Fin de traitement des elts

   #--CPO 90362 DDTANOT et DDTANUM non remis a zﾃｩro sur commande
   #--Remplacement du test sur XFNUM par celui sur XFNOT (ce dernier contient la val HT)
   #--La correction logique est commentﾃｩe, je la laisse pour mﾃｩmoire
   #If [M:SIHV]XFNUM(JL)=0 : Goto DSP_L1 : Endif  : # Pas de valeur HT --> elt suivant
   #If [M:SIHV]XFNOT(JL)=0 : Goto DSP_L1 : Endif  : # Pas de valeur HT --> elt suivant
   #--/

    #--CPO 90362 DDTANOT et DDTANUM non remis a zﾃｩro sur commande
   #If [M:SIHV]DSPLIN(JL)<>1                      : # Si elt a repartir
    If [M:SIHV]DSPLIN(JL)>1                       : # Si elt a repartir
    #--/
       Case [M:SIHV]DSPLIN(JL)
         When 2   S_DSPPRO=sum(T_DSPQTY)
         When 3   S_DSPPRO=sum(T_DSPAMT)
         When 4   S_DSPPRO=sum(T_DSPWEI)
         When 5   S_DSPPRO=sum(T_DSPVOL)
       Endcase
    Endif

    # Bug 69745 : Si somme de rﾃｩpartition ﾃ 0 : rﾃｩpartition sur la derniﾃｨre ligne
#    If S_DSPPRO=0 : Goto DSP_L1 : Endif           : # Si somme des valeurs de rﾃｩpartition=0 --> elt suivant
    If S_DSPPRO=0
      #--CPO 90362 Ici  effet de bord 69745 Il ne faut pas afficher les ﾃｩlﾃｩments non rﾃｩpartis dans "Dﾃｩtail valo"
      #T_DSPPRO([M:SIH4]NBLIG-1)=[M:SIHV]XFNOT(JL)
      #If [M:SIHV]DSPLIN(JL)>1                             # FGR 22/04/2015 : X3SUIVI105605
      If [M:SIHV]DSPLIN(JL)>1 and [M:SIH4]NBLIG > 0 Then   # FGR 22/04/2015 : X3SUIVI105605
        T_DSPPRO([M:SIH4]NBLIG-1)=[M:SIHV]XFNOT(JL)
      Else
        Goto DSP_L1
      Endif
    Else
    # Bug 69745
#   --- Boucle-1 sur les lignes : valeurs affectee a chaque ligne

        For JL0=0 To [M:SIH4]NBLIG-1
            Case [M:SIHV]DSPLIN(JL)
              When 2   L_DSPXXX=T_DSPQTY(JL0)
              When 3   L_DSPXXX=T_DSPAMT(JL0)
              When 4   L_DSPXXX=T_DSPWEI(JL0)
              When 5   L_DSPXXX=T_DSPVOL(JL0)
              When Default : L_DSPXXX=0  :#--CPO 90362 DDTANOT et DDTANUM non remis a zﾃｩro sur commande
            Endcase
            T_DSPPRO(JL0)=arr(([M:SIHV]XFNOT(JL)*L_DSPXXX)/S_DSPPRO,[F:TCU]CURRND)

            # 102423 : Belgium Early discounts
            # Discount amount calcul
            If GDEPMGTMOD=5 & [M:SIH2]DEPRAT<>0 & [M:SIHV]DTADEPFLG(JL)=2 & [M:SIHV]DTADEP(JL)<>0
                T_DSPDEP(JL0)=arr(T_DSPPRO(JL0)*[M:SIH2]DEPRAT/100,[F:TCU]CURRND)
            Endif
            # 102423

        Next JL0
    Endif
#   --- Ecart de calcul mis sur la ligne ayant la + grande valeur absolue

    W_DSPECART=[M:SIHV]XFNOT(JL)-sum(T_DSPPRO)
    If W_DSPECART
       If [M:SIHV]XFNOT(JL)<0
          JL1=find(min(T_DSPPRO),T_DSPPRO)
       Else
          JL1=find(max(T_DSPPRO),T_DSPPRO)
       Endif
       If JL1
          T_DSPPRO(JL1-1) +=W_DSPECART

          # 102423 : Belgium Early discounts
          # This T_DSPPRO has changed : Discount amount calcul again
          If GDEPMGTMOD=5 & [M:SIH2]DEPRAT<>0 & [M:SIHV]DTADEPFLG(JL)=2 & [M:SIHV]DTADEP(JL)<>0
              T_DSPDEP(JL0)=arr(T_DSPPRO(JL0)*[M:SIH2]DEPRAT/100,[F:TCU]CURRND)
          Endif
          # 102423
       Endif
    Endif

    # 102423 : Belgium Early discounts
    # Check that discount amount total for the element = total of discount amounts spread by lines
    W_DSPECART=[M:SIHV]DTADEP(JL)-sum(T_DSPDEP)
    If W_DSPECART
       If [M:SIHV]DTADEP(JL)<0
          JL1=find(min(T_DSPDEP),T_DSPDEP)
       Else
          JL1=find(max(T_DSPDEP),T_DSPDEP)
       Endif
       If JL1
          T_DSPDEP(JL1-1) +=W_DSPECART
       Endif
    Endif
    # 102423

#   --- Boucle-2 : Chargement dans [M:SIHV] ( bloc invisible ) : repartition elt courant
#                  Une ligne de [M:SIHV] ( tableaux DDTANUNxx DDTANOTxx ) par ligne

    For JL0=0 To [M:SIH4]NBLIG-1

        # Ventilation Qte, Poids, Volume :
        # Nomencl.ss-traitance : Si Pdt fini, c'est le service et non le pdt fini qui hﾃｩrite de la valeur proratisﾃｩe
        If find([M:SIHV]DSPLIN(JL), 2,4,5) & [M:SIH4]LINTYP(JL0)=10 JL2=JL0+1 Else JL2=JL0 Endif

        [M:SIH4]UPDFLG(JL2)=1
        Case [M:SIH0]ORICLC
             When "GESSQH" : [M:SQH2]UPDFLG(JL2)=1
             When "GESSDH", "GESSDHF" : [M:SDH1]UPDFLG(JL2)=1
            # 91606 :(04/08/14) Transportation notes (Sales part dev)
             When "GESTNH" : [M:TNH1]UPDFLG(JL2)=1
            # 91606 :(04/08/14) Transportation notes (Sales part dev)
             When "GESSOH" : [M:SOH4]UPDFLG(JL2)=1
        Endcase

        If T_DSPPRO(JL0)
           For JL1=1 To G_VALSFL
               If evalue ("dim([M:SIHV]DDTANUM"+format$("N0:2",JL1)+")")>0
                  If evalue ("[M:SIHV]DDTANUM"+format$("N0:2",JL1)+"("+num$(JL2)+")")=0
                     Assign ("[M:SIHV]DDTANUM"+format$("N0:2",JL1)+"("+num$(JL2)+")") With [M:SIHV]XFNUM(JL)
                     #Gbn-84185-Effet de bord 69745-Si EF non rﾃｩparti son occurrence doit ﾃｪtre nulle dans SINVOICED
                     #--CPO 90362 DDTANOT et DDTANUM non remis a zﾃｩro sur commande
                    #If [M:SIHV]DSPLIN(JL)<>1                      : # Si elt a repartir
                     If [M:SIHV]DSPLIN(JL)>1                       : # Si elt a repartir
                     #--/
                      Assign ("[M:SIHV]DDTANOT"+format$("N0:2",JL1)+"("+num$(JL2)+")") With T_DSPPRO(JL0)
                      # 102423 : Belgium Early discounts
                      If GDEPMGTMOD=5 & [M:SIH2]DEPRAT<>0 & [M:SIHV]DTADEPFLG(JL)=2 & [M:SIHV]DTADEP(JL)<>0
                          Assign ("[M:SIHV]DDTADEP"+format$("N0:2",JL1)+"("+num$(JL2)+")") With T_DSPDEP(JL0)
                      Endif
                      # 102423
                     Else
                      Assign ("[M:SIHV]DDTANOT"+format$("N0:2",JL1)+"("+num$(JL2)+")") With 0
                      # 102423 : Belgium Early discounts
                      If GDEPMGTMOD=5 & [M:SIH2]DEPRAT<>0 & [M:SIHV]DTADEPFLG(JL)=2
                          Assign ("[M:SIHV]DDTADEP"+format$("N0:2",JL1)+"("+num$(JL2)+")") With 0
                      Endif
                      # 102423
                     Endif
                     Break
                  Endif
               Endif
           Next JL1
        Endif
    Next JL0

$DSP_L1
Next JL

Return

###########################################################################
# Repartition des elements de facturation dans les tables des lignes
# - Le nombre de postes a garnir = valeur du code activite SFL
#   ( rﾃｩpartition par ligne deja effectue dans [M:SIHV] ( voir CLC_DSPLIN )
# - Tables SQUOTED [SQD]  SORDERQ [SOQ]  SDELIVERYD [SDD]  SINVOICED [SID]
###########################################################################
Subprog UPD_DSPLIN (ABRFIC,NOL)
Value Char    ABRFIC   : # abreviation table
Value Integer NOL      : # indice ligne ( nolign-1 )

Local Integer JL
Local Integer DDTANUM
Local Decimal DDTANOT
Local Decimal DDTADEP : # 102423 : Belgium Early discounts

Case ABRFIC
  When "SQD"   Raz [F:SQD]DDTANUM : Raz [F:SQD]DDTANOT
  When "SOQ"   Raz [F:SOQ]DDTANUM : Raz [F:SOQ]DDTANOT
  When "SDD"   Raz [F:SDD]DDTANUM : Raz [F:SDD]DDTANOT
  When "SID"   Raz [F:SID]DDTANUM : Raz [F:SID]DDTANOT
               Raz [F:SID]DDTADEP : # 102423 : Belgium Early discounts
Endcase

For JL=1 To G_VALSFL
    If evalue ("dim([M:SIHV]DDTANUM"+format$("N0:2",JL)+")")>0
       If evalue ("[M:SIHV]DDTANUM"+format$("N0:2",JL)+"("+num$(NOL)+")")<>0
          [L]DDTANUM=evalue ("[M:SIHV]DDTANUM"+format$("N0:2",JL)+"("+num$(NOL)+")")
          [L]DDTANOT=evalue ("[M:SIHV]DDTANOT"+format$("N0:2",JL)+"("+num$(NOL)+")")
          # 102423 : Belgium Early discounts
          [L]DDTADEP=evalue ("[M:SIHV]DDTADEP"+format$("N0:2",JL)+"("+num$(NOL)+")")
          # 102423
          Assign ("[F:"+ABRFIC+"]DDTANUM("+num$(JL-1)+")") With [L]DDTANUM
          Assign ("[F:"+ABRFIC+"]DDTANOT("+num$(JL-1)+")") With [L]DDTANOT
          # 102423 : Belgium Early discounts
          If ABRFIC="SID"
            Assign ("[F:"+ABRFIC+"]DDTADEP("+num$(JL-1)+")") With [L]DDTADEP
          Endif
          # 102423
       Endif
    Else
       Break
    Endif
Next JL

End


###########################################################################
# NOTA: les taxes ﾃ la ligne
# - les montants des taxes ﾃ la ligne ne doivent jamais ﾃｪtre recalculﾃｩs en dehors de
#   de la gestion de la ligne (jamais dans le traitement des pieds)
#   et servent ﾃ recharger le tableau avec les valeurs des lignes en cas de modification
# - La rﾃｩpartition des taxes ﾃ la ligne se fera au prorata des valeurs de dﾃｩpart uniquement
#   lors de la validation dﾃｩfinitive de la facture ( plus de possibilitﾃｩ de revenir)
#   par souci d'homogﾃｩnﾃｩitﾃｩ, toutes les bases de calcul des lignes seront mises ﾃ zﾃｩro
#   exceptﾃｩ la base1 qui sert de rﾃｩception au s/p de calcul des taxes US avec le taux stockﾃｩ
#
###########################################################################
# TRAITEMENTS
# - OUVERTURE ( Gosub $OUVRE_SIHX )
#      ouverture de tous les fichiers nﾃｩcessaires au calcul
#      ouverture ﾃｩcran SIHV sous [M:SIHV] et [M:SIHX]
#      crﾃｩation tableau XF des pieds facture (frais ligne, regroupﾃｩs, frais pied)
# - DEBUT DE FACTURE ( Gosub $NEW_FACTURE )
#      initialisation des tableaux XV et XF
# - APRES MODIF DU REGIME ( Gosub $NEW_REGIME )
#     mise ﾃ jour des codes taxes dans tableau XF
# - En sortie Tableau Pieds / Tableau lignes
#   ( Gosub $CHARG_TABLEAUX )
#     boucle de toutes les lignes (pour chaque ligne appel PLUS_LIGNE) qui charge XV
#   ( Gosub $CAL_FACTURE )
#     garnissage des ﾃｩlﾃｩments de pied XF
#     calcul des ﾃｩlﾃｩments de pied sur le HT
#     calcul des taxes
#     calcul des ﾃｩlﾃｩments de pied sur le TTC
#     transfert de SIHX dans SIHV
#     dans SIHV regroupements de pied, suppression des lignes inutiles de XV et XF
# - CHARGEMENT [F:SIH] [F:SIV] ( Gosub CHARGE_SIHSIV )
#     Auto : appelﾃｩ aprﾃｨs CAL_FACTURE
#     Saisie : appelﾃｩ dans INI_CRE
#
#########################################################################


