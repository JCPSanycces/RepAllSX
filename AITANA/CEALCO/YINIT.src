#<AdxTL>@(#)0.0.0.0 $Revision$
# Init the YTMP table after init of web server parameter
$ACTION : If ACTION<>"EXEC" : Return : Endif

Local File YTMP, YITEM,YSHIP

# Clean up all the movement tables
Trbegin YTMP
Delete [YTM] Where 1=1

Local Integer I

For [YIT]
  I+=1
  Case I
    When 1 : [YTM]CURRENCY="EUR"
    When 2 : [YTM]CURRENCY="USD"
    When 3 : [YTM]CURRENCY="GBP"
    When 4 : [YTM]CURRENCY="AUD"
    When 5 : [YTM]CURRENCY="ZAR"
    When 6 : Break
  Endcase
  [YTM]ITM=[YIT]ITMREF
  [YTM]URL="http://"+func YWEBSERV.URL_BASE
  Write [YTM]
Next
Commit
End

