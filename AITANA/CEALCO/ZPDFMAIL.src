#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
  When "EXEC" : Gosub EXEC
Endcase
Return

$EXEC
Local File PAYFRM
If !clalev([F:ZPAY])   : Local File PAYMENTH   [ZPAY]  : Endif #tabla pagos
Filter [F:FRM] Where PAYTYP = 'CSDD' and ZFLGMAIL<>2 and STA >= 6 and STA <= 11
For [F:FRM]
  Local Char TEXTO(250)
  Local Integer ESTADO
#  If !GBATCH
#    Call OUVRE_TRACE("Generación mails pagos") From LECFIC
#  Endif
  Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

  Raz ESTADO

  Filter [F:ZPAY] Where FRMNUM= [F:FRM]FRMNUM Order By BPR #ordenamos por tercero para asi poder controlar el cambio de proveedor
  Local Char ZBPR
  For [F:ZPAY]
    If ZBPR<>[F:ZPAY]BPR
    ZBPR = [F:ZPAY]BPR
    Gosub IMPRIMIR #creamos el pdf
#    If ESTADO <> 2 Then
#      Gosub MAIL #enviamos el pdf
#    Endif

    TEXTO="Remesa nº"-[F:FRM]FRMNUM-"Tercero:"-ZBPR
    Case ESTADO
       When 2: TEXTO+=" Problemas de impresión"
#      When 1: TEXTO+=" Cliente sin contacto"
#      When 3: TEXTO+=" Envío correcto"
    Endcase
    Call ECR_TRACE(TEXTO ,0) From GESECRAN

  Endif
Next
#If !GBATCH
#  Call FERME_TRACE From LECFIC
#  Call LEC_TRACE From LECFIC
#Endif


[F:FRM]ZFLGMAIL=2
Rewrite [F:FRM]
Next
Return
####################################
$IMPRIMIR
Gosub CREATEFOLDER
GZFICHERO = filpath(RUTA,[F:FRM]FRMNUM+"_"+ZBPR,"PDF","","","")

Local Integer J
Raz J
Local Integer STAT
#cargamos los datos del informe ZREMESA, los necesarios son los justo de aquí abajo
Local Char    TBPAR(20)(1..50) , TBVAL(100)(1..50)
Local Integer NBPAR
NBPAR = 0

#informamos los parametros especificos del informe, numero de remesa y proveedor
PARAM = "numdeb"          : VALEUR = [F:FRM]FRMNUM                            : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
PARAM = "bpr"             : VALEUR = ZBPR                                      : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR

Call EFFACE(GZFICHERO,STAT) From ORDSYS

Call ETAT("ZREMESA","ZPDF","SPA",0,"",TBPAR,TBVAL) From AIMP3

$ESPERA
J+=1
If J<10
 If filinfo(GZFICHERO,7)<0: Sleep 15: Goto ESPERA: Endif
Endif

#Sleep 10

If filinfo(GZFICHERO,7)<0
  ESTADO=2
Else
  Raz ESTADO
Endif

Return

######################################################################################
$CREATEFOLDER
  Local Integer NB_LIENS,STAT
  Local Char RUTA(250),FECHAFAC(10),ANNOFAC(4),MESFAC(2),DIAFAC(2),RUTAANNO(250),RUTAMES(250),RUTADIA(250)
  Raz NB_LIENS,STAT,RUTA,FECHAFAC

  ANNOFAC = num$(year([F:ZPAY]DUDDAT))
  MESFAC  = format$("N0:2",num$(month([F:ZPAY]DUDDAT)))
  DIAFAC  = format$("N0:2",num$(day([F:ZPAY]DUDDAT)))

  RUTAANNO = "D:\SAGE\SAGEX3\FOLDERS\cealco\XPDF\"+ANNOFAC
  RUTAMES  = "D:\SAGE\SAGEX3\FOLDERS\cealco\XPDF\"+ANNOFAC+"\"+MESFAC
  RUTADIA  = "D:\SAGE\SAGEX3\FOLDERS\cealco\XPDF\"+ANNOFAC+"\"+MESFAC+"\"+DIAFAC
  RUTA     = RUTADIA

  NB_LIENS = filinfo(RUTAANNO,7)
  If NB_LIENS < 0
    Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+RUTAANNO+'"',"",STAT) From ORDSYS
  Endif
  NB_LIENS = filinfo(RUTAMES,7)
  If NB_LIENS < 0
    Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+RUTAMES+'"',"",STAT) From ORDSYS
  Endif
  NB_LIENS = filinfo(RUTADIA,7)
  If NB_LIENS < 0
    Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+RUTADIA+'"',"",STAT) From ORDSYS
  Endif

Return

$MAIL
#creamos el texto del mail
  Local Char TT(250)(1..50)
  Local Char ZDEST(250)
  Local Char ZASUNTO(50) : ZASUNTO='Aviso de Remesa de Pago'
  TT(1)='Muy Srs. nuestros:'
  TT(3)='Adjunto al presente email. Enviamos detalle de los documentos que en fecha de hoy hemos pagado a través de transferencia bancaria a su cuenta.'
  TT(5)='Sin otro particular aprovechamos la ocasión para saludarles muy atentamente.'
  TT(8)='IXOS Cealco'
  TT(9)='Tel.: 938 49 68 33'
  TT(10)='https://www.cealco.es/'

  #parametros(nombretxt a generar, correo que envia, destinatario, asunto; texto; fichero a adjuntar)
  If !clalev([F:ZCNT]) : Local File CONTACT [ZCNT] : Endif
  #buscamos el contacto del proveedor cuya funcion sea "envio mail compras"
  Raz ZDEST
  Filter [F:ZCNT] Where BPATYP=1 and CNTFNC=13 and BPANUM = [F:ZPAY]BPR
  Read [F:ZCNT] First
  If !fstat Then
#    Infbox 'bpanum: ' + [F:ZCNT]BPANUM + ' mail: ' + [F:ZCNT]WEB
    For [F:ZCNT]
      ZDEST=[F:ZCNT]WEB
    Next
  Endif
  Filter [F:ZCNT]

  If ZDEST<>''
    Call ZMELADX(filpath("tmp",[F:FRM]FRMNUM+"_"+ZBPR,""),"x3@cealco.es",ZDEST,ZASUNTO,TT,[F:FRM]FRMNUM+"_"+ZBPR) From ZMELADX
    ESTADO = 3
  Else
    ESTADO = 1
  Endif

  #programa para enviar mail por la orden de sistema "meladx"
  #parametros( "fichero", "remitente", "destinatario","asunto","cuerpo mail","adjunto")

Return

