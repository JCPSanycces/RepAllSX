#<AdxTL>@(#)0.0.0.0 $Revision$
Local Char YPTHNUM(50)(2)
Local Char YBPSNUM(50)(2)
Local Char YBPSNDE(50)(2)
Local Char YITMREF(50)(2)
Local Decimal YQTY(50)(2)
Local Integer YPTDLIN (2)
Local Char YSTU(50)(2)
Local Char YSTA(50)(2)
Local Char YLOT(50)(2)
Local Char YBPSLOT(50)(2)
Local Date XRCPDAT (2)
Local Char XPRHFCY(50)(2)
Local Char XPOHNUM(50)(2)
#Dbgaff
Call XWSDATPTH(gdat$(01,01,2019),gdat$(03,01,2019), YPTHNUM, YPTDLIN, YBPSNUM, YBPSNDE, YITMREF, YQTY, YSTU, YLOT, YSTA, YBPSLOT, XRCPDAT, XPRHFCY, XPOHNUM)

End

Subprog XWSDATPTH(XDATEINI, XDATEFIN, XPTHNUM, XPTDLIN, XBPSNUM, XBPSNDE, XITMREF, XQTYSTU, XSTU, XLOT, XSTA,XBPSLOT, XRCPDAT, XPRHFCY, XPOHNUM)
Value    Date     XDATEINI
Value    Date     XDATEFIN
Variable Char     XPTHNUM     ()
Variable Integer  XPTDLIN     ()
Variable Char     XBPSNUM     ()
Variable Char     XBPSNDE     ()
Variable Char     XITMREF     ()
Variable Decimal  XQTYSTU     ()
Variable Char     XSTU        ()
Variable Char     XLOT        ()
Variable Char     XSTA        ()
Variable Char     XBPSLOT     ()
Variable Date     XRCPDAT     ()
Variable Char     XPRHFCY     ()
Variable Char     XPOHNUM     ()
#Dbgaff
#>>GAO(17/12/2018)
If XDATEINI = [0/0/0]
  XDATEINI = [31/12/1999]
Endif
#<<GAO(17/12/2018)

Gosub DEC_VARIABLES
Raz NOL
For [XPTD] Where evalue(CRIT)
  Read [XPTH]PTH0= [XPTD]PTHNUM
  Filter [XSTJ] Where STOFCY= [XPTH]PRHFCY and VCRTYP=6 and VCRNUM= [XPTD]PTHNUM and VCRLIN= [XPTD]PTDLIN
  Read [XSTJ]Last
    XPTHNUM(NOL)=  [XPTD]PTHNUM
    XPTDLIN(NOL)=  [XPTD]PTDLIN
    XBPSNUM(NOL)=  [XPTH]BPSNUM
    XBPSNDE(NOL)=  [XPTH]BPSNDE
    XITMREF(NOL)=  [XPTD]ITMREF
    XQTYSTU(NOL)=  [XSTJ]QTYSTU
    XSTU(NOL)   =  [XSTJ]STU
    XSTA(NOL)   =  [XSTJ]STA
    XLOT(NOL)   =  [XSTJ]LOT
    XBPSLOT(NOL)=  [XSTJ]BPSLOT
    XRCPDAT(NOL)=  [XPTD]RCPDAT
    XPRHFCY(NOL)=  [XPTD]PRHFCY  #GAO(22/11/2018)
    XPOHNUM(NOL)=  [XPTD]POHNUM  #GAO(26/11/2018)
    NOL+=1

    If NOL = 9999 Then
      Break
    Endif


  If year(XDATEINI)<2000
    [XPTD]XFLGWS=2
    Rewrite [XPTD]  #GAO(18/12/2018)
  Endif
Next

If year(XDATEINI)<2000
  Commit
Endif

End

###########################################
$DEC_VARIABLES

If !clalev([F:XPTH])  : Local File PRECEIPT     [XPTH]  : Endif
If !clalev([F:XPTD])  : Local File PRECEIPTD    [XPTD]  : Endif
If !clalev([F:XSTJ])  : Local File STOJOU       [XSTJ]  : Endif

Local Char CRIT (150)
Local Integer NOL
If year(XDATEINI)<2000
  Trbegin [XPTD]
  CRIT='XFLGWS<>2'
Else
  CRIT='RCPDAT>= XDATEINI and RCPDAT<= XDATEFIN'
Endif

Return

