#<AdxTL>@(#)0.0.0.0 $Revision$
# ZQ001: MRR(20/01/20) Envio remesas
# Se aÃ±ade botÃ³n para enviar un mail a los clientes con un informe adjunto de los pagos de esa remesa
######################################################################################
$ACTION
#Infbox ACTION
Case ACTION
 When "FICHIER" : Gosub FICHIER
 When "EXEBOUT" : Gosub EXEBOUT #ejecutamos el botÃ³n especifico
 When "SETBOUT" : Gosub SETBOUT #mostramos/ocultamos el botÃ³n especifico
 When Default
Endcase
Return

######################################################################################
$FICHIER
FICHIER=GZFICHERO
Return

######################################################################################
$EXEBOUT
Case BOUT
  When "e" : Gosub SENDMAIL #botÃ³n "EnvÃ­o clientes"
Endcase

Return

######################################################################################
$SETBOUT
#solo dejamos el boton de envio activo si el tipo de pago es CSDD y el estado es de Documento en fichero en adelante (ML 689)

If [M:FRM0]PAYTYP = 'CSDD' and [M:FRM0]STA >= 6 Then
  CHMEN += "e"                             #activamos el botÃ³n de "envio remesas"
Else
  Call VIREBOUT(CHAINE,"e") From GOBJET    #desactivamos el botÃ³n
Endif

Return

######################################################################################
$SENDMAIL
Local Char TEXTO(250)
Local Integer ESTADO

Call OUVRE_TRACE("GeneraciÃ³n mails pagos") From LECFIC
Call ECR_TRACE(string$(70,"-"),0) From GESECRAN

If !clalev([F:ZPAY])   : Local File PAYMENTH   [ZPAY]  : Endif #tabla pagos
Raz ESTADO

Filter [F:ZPAY] Where FRMNUM= [M:FRM0]FRMNUM Order By BPR #ordenamos por tercero para asi poder controlar el cambio de proveedor
Local Char ZBPR
For [F:ZPAY]
  If ZBPR<>[F:ZPAY]BPR
    ZBPR = [F:ZPAY]BPR
    Gosub IMPRIMIR #creamos el pdf
    If ESTADO <> 2 Then
      Gosub MAIL #enviamos el pdf
    Endif

    TEXTO="Remesa nÂº"-[M:FRM0]FRMNUM-"Tercero:"-ZBPR
    Case ESTADO
      When 1: TEXTO+=" Cliente sin contacto"
      When 2: TEXTO+=" Problemas de impresiÃ³n"
      When 3: TEXTO+=" EnvÃ­o correcto"
    Endcase
    Call ECR_TRACE(TEXTO ,0) From GESECRAN
  Endif
Next

If !clalev([F:ZFRM])   : Local File PAYFRM   [ZFRM]  : Endif

Read [F:ZFRM]FRM0=[M:FRM0]FRMFLG;[M:FRM0]FRMNUM
If fstat=0
  Trbegin [F:ZFRM]
  [F:ZFRM]ZFLGMAIL=2
  [M:FRM0]ZFLGMAIL=2
  Affzo [M:FRM0]ZFLGMAIL
  Rewrite  [F:ZFRM]
  Commit
Endif

Call FERME_TRACE From LECFIC
Call LEC_TRACE From LECFIC

Return

######################################################################################
$IMPRIMIR
Gosub CREATEFOLDER
GZFICHERO = filpath(RUTA,[M:FRM0]FRMNUM+"_"+ZBPR,"PDF","","","")

Local Integer J
Raz J
Local Integer STAT
#cargamos los datos del informe ZREMESA, los necesarios son los justo de aquÃ­ abajo
Local Char    TBPAR(20)(1..50) , TBVAL(100)(1..50)
Local Integer NBPAR
NBPAR = 0

#informamos los parametros especificos del informe, numero de remesa y proveedor
PARAM = "numdeb"          : VALEUR = [M:FRM0]FRMNUM                            : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR
PARAM = "bpr"             : VALEUR = ZBPR                                      : NBPAR += 1 : TBPAR(NBPAR) = PARAM : TBVAL(NBPAR) = VALEUR

Call EFFACE(GZFICHERO,STAT) From ORDSYS

Call ETAT("ZREMESA","ZPDF","SPA",0,"",TBPAR,TBVAL) From AIMP3

$ESPERA
J+=1
If J<10
 If filinfo(GZFICHERO,7)<0: Sleep 15: Goto ESPERA: Endif
Endif

#Sleep 10

If filinfo(GZFICHERO,7)<0
  ESTADO=2
Else
  Raz ESTADO
Endif

Return

######################################################################################
$MAIL
#creamos el texto del mail
  Local Char TT(250)(1..50)
  Local Char ZDEST(250)
  Local Char ZASUNTO(50) : ZASUNTO='Aviso de Remesa de Pago'
  TT(1)='Muy Srs. nuestros:'
  TT(3)='Adjunto al presente email. Enviamos detalle de los documentos que en fecha de hoy hemos pagado a travÃ©s de transferencia bancaria a su cuenta.'
  TT(5)='Sin otro particular aprovechamos la ocasiÃ³n para saludarles muy atentamente.'
  TT(8)='IXOS Cealco'
  TT(9)='Tel.: 938 49 68 33'
  TT(10)='https://www.cealco.es/'

  #parametros(nombretxt a generar, correo que envia, destinatario, asunto; texto; fichero a adjuntar)
  If !clalev([F:ZCNT]) : Local File CONTACT [ZCNT] : Endif
  #buscamos el contacto del proveedor cuya funcion sea "envio mail compras"
  Raz ZDEST
  Filter [F:ZCNT] Where BPATYP=1 and CNTFNC=13 and BPANUM = [F:ZPAY]BPR
  Read [F:ZCNT] First
  If !fstat Then
#    Infbox 'bpanum: ' + [F:ZCNT]BPANUM + ' mail: ' + [F:ZCNT]WEB
    For [F:ZCNT]
      ZDEST=[F:ZCNT]WEB
    Next
  Endif
  Filter [F:ZCNT]

#cuando no hay contacto con funciÃ³n envio remesa se envÃ­a el correo a un mail fijo para ellos controlar lo que no se envÃ­a y mandar una carta
  If ZDEST<>''
    Call ZMELADX(filpath("tmp",[M:FRM0]FRMNUM+"_"+ZBPR,""),"x3@cealco.es",ZDEST,ZASUNTO,TT,[M:FRM0]FRMNUM+"_"+ZBPR) From ZMELADX
    ESTADO = 3
  Else
    Call ZMELADX(filpath("tmp",[M:FRM0]FRMNUM+"_"+ZBPR,""),"x3@cealco.es","imprimir@cealco.es",ZASUNTO,TT,[M:FRM0]FRMNUM+"_"+ZBPR) From ZMELADX
    ESTADO = 1
  Endif

  #programa para enviar mail por la orden de sistema "meladx"
  #parametros( "fichero", "remitente", "destinatario","asunto","cuerpo mail","adjunto")

Return
######################################################################################
$CREATEFOLDER
  Local Integer NB_LIENS,STAT
  Local Char RUTA(250),FECHAFAC(10),ANNOFAC(4),MESFAC(2),DIAFAC(2),RUTAANNO(250),RUTAMES(250),RUTADIA(250)
  Raz NB_LIENS,STAT,RUTA,FECHAFAC

#  ANNOFAC = num$(year(date$))
#  MESFAC  = format$("N0:2",num$(month(date$)))
#  DIAFAC  = format$("N0:2",num$(day(date$)))

#Para que se genere el fichero en la estructura de carpetas con la fecha de vencimiento
  ANNOFAC = num$(year([F:ZPAY]DUDDAT))
  MESFAC  = format$("N0:2",num$(month([F:ZPAY]DUDDAT)))
  DIAFAC  = format$("N0:2",num$(day([F:ZPAY]DUDDAT)))

  RUTAANNO = "D:\SAGE\SAGEX3\FOLDERS\DUMMY2\XPDF\"+ANNOFAC
  RUTAMES  = "D:\SAGE\SAGEX3\FOLDERS\DUMMY2\XPDF\"+ANNOFAC+"\"+MESFAC
  RUTADIA  = "D:\SAGE\SAGEX3\FOLDERS\DUMMY2\XPDF\"+ANNOFAC+"\"+MESFAC+"\"+DIAFAC
  RUTA     = RUTADIA

  NB_LIENS = filinfo(RUTAANNO,7)
  If NB_LIENS < 0
    Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+RUTAANNO+'"',"",STAT) From ORDSYS
  Endif
  NB_LIENS = filinfo(RUTAMES,7)
  If NB_LIENS < 0
    Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+RUTAMES+'"',"",STAT) From ORDSYS
  Endif
  NB_LIENS = filinfo(RUTADIA,7)
  If NB_LIENS < 0
    Call SYSTEME(adxmac(0),'ae_mkdir'-'"'+RUTADIA+'"',"",STAT) From ORDSYS
  Endif

Return

######################################################################################
Subprog IMPRIME(NBPAR,PARAMETRE)
Value    Integer NBPAR
Variable Char    PARAMETRE()()

End

