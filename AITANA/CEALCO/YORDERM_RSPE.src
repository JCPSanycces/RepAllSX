#<AdxTL>@(#)0.0.0.0 $Revision$ 
# Mobile specific code
# This is representation code only (dedicated to user interface) :

$PROPERTIES
  Case [L]CURPRO
    When "YOH.FCY"      : If [L]ARULE="INIT"      : Gosub DEFAULT_COMP    : Endif
    When "YOH.COMMENT"  : If [L]ARULE="INIT"      : Gosub DEFAULT_COMMENT : Endif
  Endcase
Return

$EVENTS
  Case [L]CURPTH
    When ""
      Case AEVENT
          When "AQUERY_JOIN_AFTER"
            Gosub CHANGE_LINK
          When "AQUERY_TRANS_AFTER"
            Gosub ASSIGN_COUNTRY
    Endcase
    When "YOH"
      Case [L]AEVENT
        When "AINSERT_CONTROL_BEFORE"
          If this.CURRENCY="" : Gosub DEFAULT_CUR : Endif
        When "AUPDATE_CONTROL_AFTER","AINSERT_CONTROL_AFTER"
          this.UPDDATMOB=date$
        When "AREAD_AFTER"
            Gosub READ_CUSTINFO
            Call READ_CONTACTS(this.CUSTOMER, this.APARENT.NAME, this.APARENT.PHONE) From YORDER_RSPE
      Endcase
    When "YOH.LINES"
      Case [L]AEVENT
        When "AINSERT_BEFORE"
          If this.QTY=0   : this.QTY=1      : Endif
          If this.UNITPRICE=0 : this.UNITPRICE=func YPRICE.PRICE(this.ITEM,this.APARENT.CURRENCY) : Endif
      Endcase
  Endcase
Return

$DEFAULT_COMMENT
  this.COMMENT="Created from a mobile device by"-this.ACTX.USER-format$("D:[Date : ]8M[ ]2D[, ]4Y[ ]hh[:]mm[:]ss",date$)
Return

$DEFAULT_CUR
Local File YCUSTOMER
  Read [YBP]YBPC=this.CUSTOMER
  this.CURRENCY=[YBP]CUR
  If this.CURRENCY=""
    ASTATUS=fmet this.ASETERROR("CUSTOMER","Customer has no default  currency, input forbidden",[V]CST_AERROR)
  Endif
Return

$DEFAULT_COMP
Local Char DEFCOMP(20)
Local File COMPANY

  DEFCOMP=fmet this.ACTX.APARAM.AGETUSERVALCHAR("SOCDEF")
  Read [CPY]CPY0=DEFCOMP
  If fstat=0
    this.FCY=[CPY]MAIFCY
  Endif
  If  fstat<>0 or this.FCY=""
    ASTATUS=fmet this.ASETERROR("","no default site found, input impossible",[V]CST_AERROR)
  Endif
Return

$READ_CUSTINFO
  Local File YCUSTOMER [YBPC]
  Read [YBPC]YBP0=this.CUSTOMER
  this.APARENT.OSTAUZ=max([YBPC]OSTAUZ,1000) : # Authorized credit is at least 1000
Return

$CHANGE_LINK
 Close File [LNK_]
 Local File YCUSTOMER [YBPC]
 Link [YOH] With [YBPC]YBP0=[YOH]CUSTOMER As [LNK_]
Return

$ASSIGN_COUNTRY
 this.COUNTRY=[YBPC]CRY
Return

# Label associated to methods: AMETHOD is the method name
$METHODS
  Case AMETHOD
  Endcase
Return

# Label associated to operations: AOPERATION is the event name
$OPERATIONS
  Case AOPERATION
  Endcase
Return

