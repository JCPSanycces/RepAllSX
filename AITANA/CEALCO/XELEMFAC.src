#<AdxTL>@(#)0.0.0.0 $Revision$
##===============================================================================
# Descuento en cascada, se llama desde parametrización > ventas > elementos de facturación.
# Sólo para pronto pago (elemento 3)
##===============================================================================
$ACTION
  Case ACTION
    When "XFCC"   : Gosub XFCC #en los elementos de facturacion definimos la acción
    When Default
  Endcase
Return
##===============================================================================
$XFCC
  Local Integer ZI,IND,ZOK
  Local Decimal ZBASE,ZCUOTA,ZPORCENT,ZBASE_NETA,ZRECFCC

  #Buscamos la base inicial y le restamos o sumamos los elementos de facturación anteriores
  #Base en cascada.

#  For IND = 0 To [M:SIH2]NBFAC-1
#    Infbox([M:SIH2]SHO(IND)-" "-num$([M:SIH2]INVDTA(IND))-" "-num$([M:SIH2]INVDTAAMT(IND)))
#  Next

#  For IND = 0 To [M:SIHV]NBFOOT-1
#    Infbox("IND:"-num$(IND)-"desc:"-[M:SIHV]XFSHO(IND)-" "-num$([M:SIHV]XFNUM(IND))-" "-num$([M:SIHV]XFNOT(IND)))
#  Next

#  [M:SIHV]XFNOT(nolign-1) = 2.88 #WMNTCLCBAS
#  Affzo [M:SIHV]XFNOT(nolign-1)


  #Cuando no sea por importación
  If !GIMPORT
    Gosub BASE_CUOTA

    #El elemento 6 es el recargo
    ZPORCENT = 0 : ZOK = 1
    For IND = 0 To [M:SIH2]NBFAC-1
      If [M:SIH2]INVDTA(IND) = 6
        ZPORCENT = [M:SIH2]INVDTAAMT(IND)
        ZOK = 2
      Endif
    Next

    ZBASE_NETA = ZBASE + ZCUOTA
    WMNTCLCBAS = ZBASE_NETA

    #If ZOK = 2
    #  ZBASE_NETA = ZBASE + ZCUOTA
    #  ZRECFCC    = ZBASE_NETA * (ZPORCENT/100)
    #  WMNTCLCBAS = ZBASE_NETA
    #  If [M:SIHV]XFNUM(7) = 6
    #    [M:SIHV]XFNOT(7) = ZRECFCC
    #    Affzo [M:SIHV]XFNOT(7)
    #  Endif
    #Endif
    #Infbox("Base2:"-num$(ZBASE)-" Cuota:"-num$(ZCUOTA)-" ZRECFCC:"-num$(ZRECFCC)-" WMNTCLCBAS:"-num$(WMNTCLCBAS))
  Endif

Return
##===============================================================================
$BASE_CUOTA
  Raz ZBASE, ZCUOTA

  For ZI = 0 To [M:SIHV]NBVAT-1
    ZBASE += [M:SIHV]XVNOT(ZI)
  Next ZI

  For ZI = 0 To [M:SIHV]NBFOOT-1
    ZCUOTA += [M:SIHV]XFNOT(ZI)
  Next ZI
Return
##===============================================================================

