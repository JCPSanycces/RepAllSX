#<AdxTL>@(#)0.0.0.0 $Revision$
#Call EXEC
#
#End
#
#$ACTION
#  Case ACTION
#    When "EXEC"       : Gosub EXEC
#    When Default
#  Endcase
#Return
#
##==========================================================================================
#$EXEC

Openo filpath("TXT","traza usuario","txt","") Using [ZZZ]
Iomode adxirs chr$(13)+chr$(10) Using [ZZZ]
Iomode adxifs "" Using [ZZZ]
Iomode adxium 50 Using [ZZZ]
Wrseq GUSER Using [ZZZ]

  If !clalev([F:ZSDH]) : Local File SDELIVERY   [F:ZSDH] : Endif

  Filter [F:ZSDH] Where CREUSR = 'WS' and PRNNDE <> 2 and SDHNUM = 'EV18A0002-000048'

  For [F:ZSDH]
    Gosub PRINT_REPORT
  Next

Openo Using [ZZZ]
End
#Return
#======================================================================================
$PRINT_REPORT

    Local Char LTBPAR(20)(1..19)
    Local Char LTBVAL(20)(1..19)
    Local Char C_FICHIER(200)
    Raz LTBPAR, LTBVAL
    Local Integer LNBPAR
    LNBPAR = 0
    LNBPAR += 1 : LTBPAR(LNBPAR) = "sitedeb"       : LTBVAL(LNBPAR) = [F:ZSDH]STOFCY
    LNBPAR += 1 : LTBPAR(LNBPAR) = "sitefin"       : LTBVAL(LNBPAR) = [F:ZSDH]STOFCY
    LNBPAR += 1 : LTBPAR(LNBPAR) = "Livraisondeb"  : LTBVAL(LNBPAR) = [F:ZSDH]SDHNUM
    LNBPAR += 1 : LTBPAR(LNBPAR) = "Livraisonfin"  : LTBVAL(LNBPAR) = [F:ZSDH]SDHNUM
    LNBPAR += 1 : LTBPAR(LNBPAR) = "clientdeb"     : LTBVAL(LNBPAR) = [F:ZSDH]BPCORD
    LNBPAR += 1 : LTBPAR(LNBPAR) = "clientfin"     : LTBVAL(LNBPAR) = [F:ZSDH]BPCORD
    LNBPAR += 1 : LTBPAR(LNBPAR) = "datedeb"       : LTBVAL(LNBPAR) = [F:ZSDH]SHIDAT
    LNBPAR += 1 : LTBPAR(LNBPAR) = "datefin"       : LTBVAL(LNBPAR) = [F:ZSDH]SHIDAT
    LNBPAR += 1 : LTBPAR(LNBPAR) = "devdeb"        : LTBVAL(LNBPAR) = [F:ZSDH]CUR
    LNBPAR += 1 : LTBPAR(LNBPAR) = "devfin"        : LTBVAL(LNBPAR) = [F:ZSDH]CUR
    LNBPAR += 1 : LTBPAR(LNBPAR) = "typedeb"       : LTBVAL(LNBPAR) = [F:ZSDH]SDHTYP
    LNBPAR += 1 : LTBPAR(LNBPAR) = "typefin"       : LTBVAL(LNBPAR) = [F:ZSDH]SDHTYP
    LNBPAR += 1 : LTBPAR(LNBPAR) = "categlivdeb"   : LTBVAL(LNBPAR) = num$([F:ZSDH]SDHCAT)
    LNBPAR += 1 : LTBPAR(LNBPAR) = "categlivdeb"   : LTBVAL(LNBPAR) = num$([F:ZSDH]SDHCAT)
    LNBPAR += 1 : LTBPAR(LNBPAR) = "valdeb"        : LTBVAL(LNBPAR) = num$([F:ZSDH]CFMFLG)
    LNBPAR += 1 : LTBPAR(LNBPAR) = "valfin"        : LTBVAL(LNBPAR) = num$([F:ZSDH]CFMFLG)
    LNBPAR += 1 : LTBPAR(LNBPAR) = "facdeb"        : LTBVAL(LNBPAR) = num$([F:ZSDH]INVFLG)
    LNBPAR += 1 : LTBPAR(LNBPAR) = "facfin"        : LTBVAL(LNBPAR) = num$([F:ZSDH]INVFLG)
    LNBPAR += 1 : LTBPAR(LNBPAR) = "codimp"        : LTBVAL(LNBPAR) = num$([F:ZSDH]PRNNDE)

    Wrseq "Parametros escritos"-[F:ZSDH]SDHNUM Using [ZZZ]
    #Variable que pasaremos al script del punto de entrada, con la carpeta, el nombre del fichero y la extension

    C_FICHIER = filpath("TXT","BONLIV","pdf","","","")
    GFILPATH = C_FICHIER

#    Wrseq GFILPATH Using [ZZZ]
#    Wrseq "LLAMADA A ETAT"-GPOINT Using [ZZZ]

    #Call ETAT("BONLIV","A01OFI","SPA",0,"Informe",LTBPAR(1..LNBPAR),LTBVAL(1..LNBPAR)) From AIMP3
 Return

