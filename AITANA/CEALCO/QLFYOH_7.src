#<AdxTL>@(#)0.0.0.0 $Revision$
# Third test: check the additional controls
#------------------------------------------------------------------------------#

Local Clbfile RESULT
RESULT=func TESTSUITE()
Errbox RESULT
End

Funprog TESTSUITE()

  Call ADD_TESTCASE("TEST_YORDER","Test classes YORDER with controls",1) From AXUNIT

End func AXUNIT.RUN_TESTSUITE("Test number 1","Check the classes")

#  Optional subprog called *before* running the test suite
Subprog SETUP

# Error handling variable
  Global Integer ERROR_V

# Cleanup tables
  Gosub CLEANUP_TABLES
End

#  Optional subprog called *after* running the test suite
Subprog TEARDOWN
  Gosub CLEANUP_TABLES
End

# Cleanup the YSHIP and YORDER table where some empty records could have been created
$CLEANUP_TABLES
  Local File YORDER, YLINE, YSHIP, YSHLINE
  Delete [YOH] Where ORDNUM=""
  Delete [YLI] Where ORDNUM=""
  Delete [YSH] Where ORDNUM=""
  Delete [YSL] Where ORDNUM=""
  Delete [YLI] Where pat(ORDNUM,"FR011_*")<>0
  Delete [YOH] Where pat(ORDNUM,"FR011_*")<>0
  Delete [YOH] Where ORDNUM="TST_001"
  Delete [YLI] Where ORDNUM="TST_001"
  Update [BPC] Where BPCNUM="AO005" With YOHLAST=""
Return

Subprog TEST_YORDER()

#
# Check class YORDER
#
  Local Instance YORDER Using C_YORDER
  Local Integer OK,NUML,I
  Local Integer NB_ERR

  YORDER=NewInstance C_YORDER AllocGroup null
  OK=fmet YORDER.AINIT
  YORDER.FCY="FR011"
  YORDER.CUSTOMER="AO005"
  OK=fmet YORDER.ADDLINE("LINES",[V]CST_ALASTPOS)
  If OK=[V]CST_ANOTDEFINED
    NB_ERR+=1
    Call LOG_LINE(" ** ERROR : ADDLINE method failed on YORDER for the first line") From AXUNIT
  Else
    YORDER.LINES(OK).ITEM="BMS001"
    YORDER.LINES(OK).QTY=100
    YORDER.LINES(OK).DISCOUNT=10
    OK=fmet YORDER.ADDLINE("LINES",[V]CST_ALASTPOS)
    If OK=[V]CST_ANOTDEFINED
      NB_ERR+=1
      Call LOG_LINE(" ** ERROR : ADDLINE method failed on YORDER for the second line") From AXUNIT
    Else
      YORDER.LINES(OK).ITEM="BMS002"
      YORDER.LINES(OK).DISCOUNT=20
      YORDER.LINES(OK).QTY=200

      Local Decimal AMOUNT1,AMOUNT2

      [V]ERROR_V=0
      Onerrgo NOMETH
      AMOUNT1=fmet YORDER.TOTAMOUNT
      Onerrgo
      If [V]ERROR_V<>0
        NB_ERR+=1
        Call LOG_LINE(" ** ERROR : TOTAMOUNT method not found") From AXUNIT
      Else
        Call LOG_LINE("TOTAMOUNT method found") From AXUNIT
        AMOUNT2=arr(YORDER.LINES(1).PRICE+YORDER.LINES(2).PRICE,0.01)
        If AMOUNT1<>AMOUNT2
          NB_ERR+=1
          Call LOG_LINE(" ** ERROR : total amount computation incorrect (expected"-num$(AMOUNT2)+", got"-num$(AMOUNT1)+")") From AXUNIT
        Else
          Call LOG_LINE("Total amount computation correct (returns"-num$(AMOUNT2)+")") From AXUNIT
          OK=fmet YORDER.AINSERT
          If OK<>[V]CST_AOK
            NB_ERR+=1
            Call LOG_LINE(" ** ERROR : AINSERT method failed on YORDER") From AXUNIT
            Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
          Else
            Call LOG_LINE("AINSERT method successful on YORDER") From AXUNIT
            If YORDER.TOTAL<>AMOUNT1
              NB_ERR+=1
              Call LOG_LINE(" ** ERROR : total amount computation not called before creation") From AXUNIT
            Else
              Call LOG_LINE("Total amount computation successfully called at creation") From AXUNIT
              FreeGroup YORDER
              YORDER=NewInstance C_YORDER AllocGroup null
              OK=fmet YORDER.AREAD("FR011_00001")
              If OK<>[V]CST_AOK
                NB_ERR+=1
                Call LOG_LINE(" ** ERROR : AREAD method failed on YORDER") From AXUNIT
              Else
                Call LOG_LINE("AREAD method successful on YORDER") From AXUNIT
                [V]ERROR_V=0
                Onerrgo NOMETH
                I=fmet YORDER.DISC_ERASE
                Onerrgo
                If [V]ERROR_V<>0
                  NB_ERR+=1
                  Call LOG_LINE(" ** ERROR : DISC_ERASE method not found") From AXUNIT
                Else
                  Call LOG_LINE("DISC_ERASE method found") From AXUNIT
                  If max(YORDER.LINES(1..maxtab(YORDER.LINES)).DISCOUNT)<>0
                    Call LOG_LINE(" ** ERROR : DISC_ERASE method failed") From AXUNIT
                    Call LOG_CLASS(YORDER,"YORDER",1) From AXUNIT
                  Else
                  Call LOG_LINE("DISC_ERASE method successful") From AXUNIT
                  Endif
                Endif
              Endif
            Endif
          Endif
        Endif
      Endif
    Endif
  Endif

  Call CHECK_EQUAL(NB_ERR,0) From AXUNIT

End

$NOMETH
ERROR_V=errn
Resume
