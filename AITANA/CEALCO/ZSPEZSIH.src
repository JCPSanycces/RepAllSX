#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION

Case ACTION
 When "EXEC"       : Gosub EXEC
Endcase
Return

$EXEC
If !clalev([F:YSIV]): Local File YSINVOICEV: Endif
If !clalev([F:YSID]): Local File YSINVOICED: Endif

Filter [F:YSIV] Where [F:YSIV]CREADA<>2
For [F:YSIV]
  Gosub APRES_CRE From SPEYSIH
Next

Return

