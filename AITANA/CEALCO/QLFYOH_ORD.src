#<AdxTL>@(#)0.0.0.0 $Revision$
Funprog TESTSUITE()

# 3 tests are done here: an unsuccessful creation attempt with missing information, a successful attempt, a deletion
  Call ADD_TESTCASE("SUCCESS_CREATE","Successful creation",3) From AXUNIT
  Call ADD_TESTCASE("SUCCESS_READ","Read the previously created order",14) From AXUNIT
  Call ADD_TESTCASE("SUCCESS_UPDATE","Successful update",3) From AXUNIT
  Call ADD_TESTCASE("FAIL_CREATE","Creation failure (missing infos)",3) From AXUNIT

End func AXUNIT.RUN_TESTSUITE("Test case YORDER","Check the different methods")

# First test
Subprog SUCCESS_CREATE()
Local Instance MYORDER Using C_YORDER
Local Integer K,OK

# Order instantiation and initialization
  MYORDER = NewInstance C_YORDER AllocGroup null
  OK=fmet MYORDER.AINIT
  Call CHECK_EQUAL(OK, [V]CST_AOK) From AXUNIT : # Is the status ok after initialization?

# Assign values to header information
  MYORDER.ORDNUM = "31415926" : MYORDER.CUSTOMER = "ES009" : MYORDER.CURRENCY = "EUR" : MYORDER.ORDDAT=date$ : MYORDER.FCY="FR021"

# Add a line and set values to it
  K=fmet MYORDER.ADDLINE("LINES",[V]CST_ALASTPOS)
  Call CHECK_TRUE(K>0) From AXUNIT : # Is the insertion successful ?
  MYORDER.LINES(K).ITEM = "BMS005" : MYORDER.LINES(K).UNITPRICE = 3.14

# Add a second line and set values to it
  K=fmet MYORDER.ADDLINE("LINES",[V]CST_ALASTPOS)
  Call CHECK_TRUE(K>0) From AXUNIT : # Is the insertion successful ?
  MYORDER.LINES(K).ITEM = "BMS007" : MYORDER.LINES(K).UNITPRICE = 100 : MYORDER.LINES(K).DISCOUNT=25

# Perform the creation
  OK=fmet MYORDER.AINSERT
  Call CHECK_EQUAL(OK, [V]CST_AOK) From AXUNIT : # Is the status ok after creation?

# Clean up and end
  FreeGroup MYORDER
 End

# Second test
Subprog SUCCESS_READ()
 Local Instance MYORDER Using C_YORDER
 Local Integer K,OK

# Order instantiation and initialization
  MYORDER = NewInstance C_YORDER AllocGroup null
  OK=fmet MYORDER.AREAD("31415926")
  Call CHECK_EQUAL(OK, [V]CST_AOK) From AXUNIT : # Is the status ok after read?

# Check the values that have been assigned or defaulted
  Call CHECK_EQUAL(MYORDER.ORDNUM,"31415926") From AXUNIT
  Call CHECK_EQUAL(MYORDER.CUSTOMER,"ES009") From AXUNIT
  Call CHECK_EQUAL(MYORDER.CURRENCY,"EUR") From AXUNIT
  Call CHECK_EQUAL(MYORDER.ORDDAT,date$) From AXUNIT
  Call CHECK_EQUAL(MYORDER.ORDSTA,1) From AXUNIT
  Call CHECK_EQUAL(MYORDER.TOTAL,78.14) From AXUNIT

# Check if there are two lines in the order and check some values
  Call CHECK_EQUAL(maxtab(MYORDER.LINES),2) From AXUNIT
  Call CHECK_EQUAL(MYORDER.LINES(1).ITEM,"BMS005") From AXUNIT
  Call CHECK_EQUAL(MYORDER.LINES(1).QTY,1) From AXUNIT
  Call CHECK_EQUAL(MYORDER.LINES(1).DLVQTY,0) From AXUNIT

# Call a method
  Call CHECK_EQUAL(MYORDER.LINES(2).DISCOUNT,25) From AXUNIT
  OK=fmet MYORDER.DISC_ERASE
  Call CHECK_EQUAL(MYORDER.LINES(2).DISCOUNT,0) From AXUNIT

# Clean up and end
  FreeGroup MYORDER
 End

# Third test
Subprog SUCCESS_UPDATE()
 Local Instance MYORDER Using C_YORDER
 Local Integer K,OK

# Order instantiation and read
  MYORDER = NewInstance C_YORDER AllocGroup null
  OK=fmet MYORDER.AREAD("31415926")
  Call CHECK_EQUAL(OK, [V]CST_AOK) From AXUNIT : # Is the status ok after read?

# Change a value in header information
  MYORDER.ORDDAT=date$-1

# Add a new line and set values to it
  K=fmet MYORDER.ADDLINE("LINES",[V]CST_ALASTPOS)
  Call CHECK_EQUAL(K,3) From AXUNIT : # Is the insertion successful and it is the third line ?
  MYORDER.LINES(K).ITEM = "BMS008"  : MYORDER.LINES(K).UNITPRICE = 17.32

# Perform the creation
  OK=fmet MYORDER.AUPDATE
  Call CHECK_EQUAL(OK, [V]CST_AOK) From AXUNIT : # Check if successful
# Clean up and end
  FreeGroup MYORDER
 End

# Fourth test
 Subprog FAIL_CREATE()
  Local Instance MYORDER Using C_YORDER
  Local Integer K,OK

# Order instantiation and initialization
  MYORDER = NewInstance C_YORDER AllocGroup null
  OK=fmet MYORDER.AINIT
  Call CHECK_EQUAL(OK, [V]CST_AOK) From AXUNIT : # Is the status ok after initialization?

# Assign values to header information but forget to assign a customer
  MYORDER.ORDNUM = "27182818" : MYORDER.CURRENCY = "EUR" : MYORDER.ORDDAT=date$

# Add a line and set values to it
  K=fmet MYORDER.ADDLINE("LINES",[V]CST_ALASTPOS)
  Call CHECK_TRUE(K>0) From AXUNIT : # Is the insertion successful ?
  MYORDER.LINES(K).ITEM = "BMS005" : MYORDER.LINES(K).UNITPRICE = 3.14

# Perform the creation
  OK=fmet MYORDER.AINSERT
  Call CHECK_EQUAL(OK, [V]CST_AERROR) From AXUNIT : # Creation should not be possible

# Clean up and end
  FreeGroup MYORDER
 End

# Optional subprog called *before* running the test suite
Subprog SETUP
  Call TEARDOWN
End

# Cleanup after the test suite
Subprog TEARDOWN
 Local File YORDER [YOH],YLINE [YLI]
 Delete [YOH] Where find(ORDNUM,"31415926","27182818")<>0
 Delete [YLI] Where find(ORDNUM,"31415926","27182818")<>0
End
