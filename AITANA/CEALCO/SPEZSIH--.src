######################################################################################
#$ACTION
#
#Case ACTION
# When "OUVRE"       : Gosub OUVRE
# When "LIENS"       : Gosub LIENS
# When "LIENS_LIG"   : Gosub LIENS_LIG
# When "INICRE"      : Gosub INICRE
# When "CREATION"    : Gosub CREATION    From TABLEAUX
# When "MODIF"       : Gosub MODIF       From TABLEAUX
# When "ANNULE"      : Gosub ANNULE      From TABLEAUX
# When "APRES_CRE"   : Gosub LIENS       From TABLEAUX : Gosub APRES_CRE
# When "APRES_MOD"   : Gosub LIENS       From TABLEAUX
# When "INICRE_LIG"  : [F:ZSID]NUM = [M:ZSIH0]NUM
# When "DEFLIG"      : Gosub DEFLIG
# When Default
#Endcase
#Return
$ACTION
#Infbox ACTION
  Case ACTION
    When "OUVRE"              : Gosub OUVRE
    When "FILTRE"             : Gosub FILTRE
    When "CREATION"           : Gosub CREATION
    When "APRES_CRE"          : Gosub APRES_CRE
    When "LIENS"              : Gosub LIENS
    When "MODIF"              : Gosub MODIF
    When "APRES_MOD"          : Gosub APRES_MOD
    When "ANNULE"             : Gosub ANNULE
    When "DEFLIG"             : Gosub DEFLIG
    When "INICRE_LIG"         : Gosub INI_LIG
    When "INIMOD_LIG"         : Gosub INI_LIG
    When "INICRE"             : Gosub INICRE
#    When "VERIF_CRE"          : Gosub VERIF_CRE
    When Default
  Endcase
Return


######################################################################################
$OUVRE
  Gosub DECLARE From TABLEAUX
Return

######################################################################################
$FILTRE
  Default File [ZSIV]

Return

#######################################################################################
$CREATION
  Gosub CREATION From TABLEAUX

Return

######################################################################################
$APRES_CRE
  # -- Regeneración de los indicadores UPDFLG y CREFLG #
  Gosub LIENS From TABLEAUX

#Gosub IMPORTPTH    #cambiar por IMPORTSIH

Return

######################################################################################
$LIENS
  Gosub LIENS From TABLEAUX
  If GWEBSERV=0
    GCONSULT=1
  Endif
Return

######################################################################################
$MODIF
  Gosub MODIF From TABLEAUX

Return

######################################################################################
$APRES_MOD
  # -- Regeneración de los indicadores UPDFLG y CREFLG #
  Gosub LIENS From TABLEAUX

Return

######################################################################################
$ANNULE
  Gosub ANNULE From TABLEAUX # Borrado de líneas

Return

