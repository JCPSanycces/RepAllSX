#<AdxTL>@(#)0.0.0.0 $Revision$

# Cleanup script (used before a demo)
# Modifications have been done in order to fill the specific table YITEM and YCUSTOMER
#  if BPCUSTOMER and YITEM tables exist)
#  otherwise, these tables have to be supplied as a patch
#  this allows using this specific development in any environment (including SUPERV, Sage X3 people)

$ACTION : If ACTION<>"EXEC" : Return : Endif

Local File YORDER, YLINE,YSHIP,YSHLINE,AVALNUM,YLEAD,AUDITH,AUDITL,ADOVAL
Local Integer SEQLIST(1..100)

# Clean up all the movement tables
Trbegin YORDER
Delete [YOH] Where 1=1
Delete [YLI] Where 1=1
Delete [YSH] Where 1=1
Delete [YSL] Where 1=1
Delete [YLE] Where 1=1

# Delete the counters values
Delete [AVN] Where CODNUM="YOH"

# Delete the audit records
Repeat
  I=1
  For [AUD] Where find(TBL,"YLEAD","YORDER","YLINE","YSHIP","YSHLINE")<>0
    SEQLIST(I)=[AUD]SEQ
    I+=1
    If I>dim(SEQLIST) : Break : Endif
  Next
  If I>1
    Delete [AUL] Where find(SEQ,SEQLIST(1..I-1))<>0
    Delete [AUD] Where find(SEQ,SEQLIST(1..I-1))<>0
  Endif
Until I<=1

# Set the default parameter values
Update [ADW] Where CMP="" and FCY=""  and find(PARAM,"YWEBPRICE","YWEBSEARCH","YDOCGEN","YPUBLISH")<>0
& With VALEUR="1"
Commit

# Clean MongoDB generated data
Local Integer I
I=func CLEAN_MONGO

# Disable audit flag on modifying lines and regenerate triggers
Local File ATABLE,ADOSSIER,ACTIV,ATABZON
  Read [ADS]DOSSIER=nomap
  Update [ATB] Where CODFIC="YLINE" With AUDUPD=1
  Call MAJTRIG("YLINE") From DOSTAB

# If a table ITMMASTER exists, create the record in YITEM from ITMMASTER
  If filinfo(filpath("FIL","ITMMASTER","fde",nomap),0)>0
    Gosub FILL_ITM
  Endif

# If a table BPCUSTOMER exists, create the record in YCUSTOMER from BPCUSTOMER
  If filinfo(filpath("FIL","BPCUSTOMER","fde",nomap),0)>0
    Gosub FILL_BPC
  Endif

End

# Cleanup the MongoDB shipments

Funprog CLEAN_MONGO

Local Char DOC_LIST(50)(1..1000,1..2)
Local Clbfile FILTERS(0)
Local Char PROPERTIES(20)(1..2)
Local Integer FUTURE,OK,I,J,RES
Local Clbfile RESHEAD(0)

# Filters assignment
  FILTERS =" ((documentType eq 'application/json') or (documentType eq 'text/html'))"
  FILTERS+=" and volume.code eq 'STD'"
  FILTERS+=" and fileName like 'Ship_%'"

  PROPERTIES(1)="fileName" : PROPERTIES(2)="$uuid"

# Let's assign the future mode (0=wait to get the data)
  FUTURE=0

# It is time to call the API
  OK=func ASYRSAREA.LIST(FILTERS, PROPERTIES, FUTURE, RESHEAD, DOC_LIST)

# If OK is not 200, return an error
# RESHEAD is ignored here
  If OK<>200
    End [V]CST_ANOTDEFINED
  Endif

# Count the number of lines returned (stop when a line where all the field are empty is found)
  For I=1 To dim(DOC_LIST,1)
    Break sum(DOC_LIST(I,1..COLNUMBER)="")
  Next I

 Openo filpath('TRA','docs','tra'),0 Using [ZZ]
 For J=1 To I-1
   OK=func ASYRSAREA.REMOVE(DOC_LIST(J,2), FUTURE, RESHEAD, RES)
   Break (OK<>200)
   Wrseq "Doc:"+DOC_LIST(J,1)-"deleted" Using [ZZ]
 Next J
Openo Using [ZZ]

End I-1

$FILL_ITM
Gosub CLOSE_FILES
Local File YITEM [YIT]
Local File ITMMASTER [ITM]
Local File ATEXTRA [AXX]
Local File ATEXTRA [AXX1]
Local File APLSTD [APL1]
Local File APLSTD [APL2]
Local File ATABDIV [ADI1]
Local File ATABDIV [ADI2]
Local File CBLOB [CBB]
Local File ITMSALES [ITS]

  Trbegin [YIT]

  Delete [YIT] Where 1=1

  For [ITM] Where SALFLG=2 and TSICOD<>""
    Raz [YIT]
    [YIT]=[ITM]
    [YIT]TSICOD=[ITM]TSICOD(0)
    Read [ITS]ITS0=[ITM]ITMREF
    If fstat=0 : [YIT]PRICE=arr([ITS]BASPRI,0.01) : Else [YIT]PRICE=0 : Endif
    For [CBB] Where CODBLB="ITM" and TYPBLB=3 and IDENT1=[ITM]ITMREF
      [YIT]IMG=[CBB]BLOB
    Next
    Write [YIT]
  Next

  Delete [AXX] Where CODFIC="YITEM" and ZONE="DES1AXX"
  For [AXX] Where CODFIC="ITMMASTER" and ZONE="DES1AXX"
    [AXX1]=[AXX] : [AXX1]CODFIC="YITEM"
    Write [AXX1]
  Next

  Delete [APL1] Where LANCHP=1005
  For [APL1] Where LANCHP=246
    [APL2]=[APL1] : [APL2]LANCHP=1005
    Write [APL2]
  Next

  Delete [ADI1] Where NUMTAB=1005
  For [ADI1] Where NUMTAB=20
    [ADI2]=[ADI1] : [ADI2]NUMTAB=1005
    Write [ADI2]
  Next

  Delete [AXX1] Where CODFIC="ATABDIV" and IDENT1="1005"
  For [AXX] Where CODFIC="ATABDIV" and IDENT1="20"
    [AXX1]=[AXX] : [AXX1]IDENT1="1005"
    Write [AXX1]
  Next



  Commit
  Gosub CLOSE_FILES

Return

$FILL_BPC
Gosub CLOSE_FILES

Local File YCUSTOMER [YBP]
Local File BPCUSTOMER [BPC]
Local File BPARTNER [BPR]
Local File ATABDIV [ADI1]
Local File ATABDIV [ADI2]
Local File APLSTD [APL1]
Local File APLSTD [APL2]
Local File CONTACT [CNT]
Local File CONTACTCRM [AIN]
Local File BPADDRESS [BPA]
Link [CNT] With [AIN]AIN0~=[CNT]CCNCRM As [CONT]
Local File ATEXTRA [AXX]
Local File ATEXTRA [AXX1]

  Trbegin [YBP]



  Delete [YBP] Where 1=1
  For [BPC] Where BPCSTA=2
    [YBP]=[BPC]
    Read [BPR]BPR0=[BPC]BPCNUM
    For [BPA] Where BPATYP=1 and BPANUM=[BPC]BPCNUM
      [YBP]ADDRESS1=[BPA]BPAADDLIG(0)
      [YBP]ADDRESS2=[BPA]BPAADDLIG(1)
      [YBP]POSCOD=[BPA]POSCOD
      [YBP]SAT=[BPA]SAT
      [YBP]CITY=[BPA]CTY
      Break
    Next
    For [CONT]CNT0 Where BPATYP=1 and BPANUM=[BPC]BPCNUM
      [YBP]CNTNAM=[AIN]CNTFNA-[AIN]CNTLNA
      [YBP]PHONE=[CNT]TEL
      Break
    Next
    [YBP]CRY=[BPR]CRY
    [YBP]TSCCOD=[BPC]TSCCOD
    If [YBP]TSCCOD="" : [YBP]TSCCOD=num$(int(rnd(7)+1)*100) : Endif

    Write [YBP]
  Next

  Delete [ADI1] Where NUMTAB=1006
  For [ADI1] Where NUMTAB=30
    [ADI2]=[ADI1] : [ADI2]NUMTAB=1006
    Write [ADI2]
  Next

  Delete [AXX1] Where CODFIC="ATABDIV" and IDENT1="1006"
  For [AXX] Where CODFIC="ATABDIV" and IDENT1="30"
    [AXX1]=[AXX] : [AXX1]IDENT1="1006"
    Write [AXX1]
  Next

  Delete [APL1] Where LANCHP=1006
  For [APL1] Where LANCHP=401
    [APL2]=[APL1] : [APL2]LANCHP=1006
    Write [APL2]
  Next

  Commit

  Gosub CLOSE_FILES

Return

$CLOSE_FILES
If clalev([AIN]) : Close Local File [AIN] : Endif
If clalev([CNT]) : Close Local File [CNT] : Endif
If clalev([YIT]) : Close Local File [YIT] : Endif
If clalev([ITM]) : Close Local File [ITM] : Endif
If clalev([AXX]) : Close Local File [AXX] : Endif
If clalev([AXX1]) : Close Local File [AXX1] : Endif
If clalev([APL1]) : Close Local File [APL1] : Endif
If clalev([APL2]) : Close Local File [APL2] : Endif
If clalev([ADI1]) : Close Local File [ADI1] : Endif
If clalev([ADI2]) : Close Local File [ADI2] : Endif
If clalev([YBP]) : Close Local File [YBP] : Endif
If clalev([BPC]) : Close Local File [BPC] : Endif
If clalev([BPR]) : Close Local File [BPR] : Endif
If clalev([BPA]) : Close Local File [BPA] : Endif
If clalev([CNT]) : Close Local File [CNT] : Endif
If clalev([CONT]) : Close Local File [CONT] : Endif
If clalev([AIN]) : Close Local File [AIN] : Endif
If clalev([CBB]) : Close Local File [CBB] : Endif

Return

