## XVT 15-04-2019
## BIBLIOTECA GESTIÓN DE CALIFICACIONES v11
## ESTE PROGRAMA CONTIENE LAS FUNCIONES NECESARIAS PARA LA GESTIÓN DE CALIFICACIONES
## Y LAS MODIFICACIONES SOBRE PEDIDOS, RECEPCIONES, ENTREGAS, FACTURAS
## ORGANIZADO EN UNA SECCIÓN PARA LAS MMPP Y OTRA PARA PRODUCTOS
## FRUTOS CÁSCARA - SUPPORT-3571 - XVT19082020 - RECÁLCULOS SEGÚN INDICACIONES ELENA
##1. % RENDIMIENTO EN PEPITA (RTO). MODIFICA LA CANTIDAD1.
##CANTIDAD1 = CANTIDAD * RTO EN PEPITA / 100
##
##2. HUMEDAD. MODIFICA LA CANTIDAD2. HAY VARIOS TIPOS DE HUMEDAD.
##A. HUMEDAD DE LA MUESTRA (HMU): LA HUMEDAD REAL DE LA ALMENDRA. SI ESTA HUMEDAD ESTA POR DEBAJO DE LA HUMEDAD MÁXIMA TOLERADA LA CANTIDAD2 = CANTIDAD1.
##B. HUMEDAD MÁXIMA TOLERADA (HMAX): ES UN VALOR MÁXIMO A PARTIR DEL CUAL SE PENALIZA DISMINUYENDO LA CANTIDAD2 RESPECTO DE LA CANTIDAD1. SE DEFINE EN LA TABLA VARIA 6003, CÓDIGO 2.
##C. HUMEDAD CON GASTOS: ES UN VALOR A PARTIR DEL CUAL SE COBRAN GASTOS POR SECADO AL AGRICULTOR. NO MODIFICA CANTIDADES. SE DEFINE EN LA TABLA VARIA 6003, CÓDIGO 3.
##D. HUMEDAD CORREGIDA (HCO): LA RELACIÓN ENTRE LA HUMEDAD DE LA MUESTRA Y LA HUMEDAD CORREGIDA SE DEFINE EN LA TABLA VARIA 6004. LA HUMEDAD CORREGIDA SUSTITUYE A LA HUMEDAD DE LA MUESTRA EN LA
# Formula QUE SIRVE PARA CALCULAR LA CANTIDAD2 CUANDO LA HUMEDAD DE MUESTRA ES 7 O MAYOR DE 7.
##
##CÁLCULO DE CANTIDAD2. SIEMPRE HAY QUE RELLENAR LA CANTIDAD2 PORQUE LA LIQUIDACIÓN AL AGRICULTOR SE HACE CON LA CANTIDAD2.
##• CASO 1: CON UNA HUMEDAD DE MUESTRA MENOR O IGUAL A LA HUMEDAD MÁXIMA TOLERADA, CANTIDAD1 = CANTIDAD2.
##• CASO 2: CON UNA HUMEDAD DE MUESTRA MAYOR A LA HUMEDAD MÁXIMA TOLERADA Y MENOR DE 7
##          (HUMEDAD A PARTIR DE LA CUAL HAY CORRECCIÓN. ESTA HUMEDAD TAMBIÉN HABRÍA QUE DEFINIRLA EN LA TABLA VARIA 6003),
##          CANTIDAD2 = CANTIDAD X (RTO – ( RTO X (HMU – HMAX)/100))/100
##• CASO 3: CON UNA HUMEDAD DE MUESTRA IGUAL O MAYOR QUE 7,
##          CANTIDAD2 = CANTIDAD X (RTO – (RTO X (HCO – HMAX)/100))/100
##XVT24082020 - se detecta que la humedad corregida en FC no se está buscando correctamente.

## MATERIAS PRIMAS
## ACEITUNA

## UVA
Subprog B_UVA_GRADO2CANTIDAD1(PGRADO,PQTY,PCANT1)
  Value Decimal PGRADO
  Value Decimal PQTY
  Variable Decimal PCANT1

  #APLICACIÓN: IMPORTACIÓN DE PESADAS BÁSCULAS ROMERO
  PCANT1=PGRADO*PQTY

End

## PRODUCTOS


#**
#* FRUTOS CON CASCARA. Rendimeinto de pepita. Modifica la CANT1
#* CANT1 = CANT * RENDIMIENTO / 100
#*
#* @param PRENDIMIENTO  -- Porcentaje
#* @param PTRANS        -- Nombre de la transacción
#* @param PCANTIDAD     -- Cantidad estándar
#*!
Funprog FC_RENDIMIENTO2CANTIDAD1(PRENDIMIENTO, PTRANS, PCANTIDAD)
 Local Decimal LRES

  If PRENDIMIENTO <> 0 and PCANTIDAD <> 0  Then
    LRES = arr(PCANTIDAD * PRENDIMIENTO / 100,0.01)
  Else
    LRES = 0
  Endif

End LRES

#**
#* CEREAL. Función que nos devuelve el valor de la CANTIDAD1 para CEREAL
#*
#* @param PHUMEDAD  -- Humedad
#* @param PCANTIDAD -- Cantidad estándar
#*
#*!
Funprog C_HUMEDAD2CANTIDAD1(PHUMEDAD, PTRANS, PCANTIDAD)
 Local Decimal LRES

 If !clalev([ADI]) : Local File ATABDIV [ADI] : Endif
 Filter [ADI] Where NUMTAB = 6003 and A1 = PTRANS and A2 = "MAXHUMEDAD"
 Read [F:ADI] First
 If !fstat Then
  # SI HUMEDAD <= VALOR DEL PARÁMETRO MAXHUMEDAD
  If PHUMEDAD <= [F:ADI]N1 Then
    LRES = PCANTIDAD
  Else
    LRES = arr(PCANTIDAD - (PCANTIDAD * arr(1 - ((100-PHUMEDAD)/(100-[F:ADI]N1)),0.001)),1) # Formula proporcionada por Elena
  Endif
 Else
  GMESSAGE = "No existe parámetro de Max. Humedad para Cereales (MAXHUMEDAD). Revise la parametrización."
  LRES = PCANTIDAD
 Endif

End LRES



#**
#* FRUTOS CON CASCARA. La Humedad Modifica de la CANTIDAD2
#*
#* @param PHUMEDAD
#* @param PTRANS
#* @param PCANTIDAD - QTY ORIGINAL
#* @param PCANTIDAD1
#*!
#XVT 19082020.o Funprog FC_HUMEDAD2CANTIDAD2(PHUMEDAD, PTRANS, PCANTIDAD, PCANTIDAD1)
Funprog FC_HUMEDAD2CANTIDAD2(PHUMEDAD, PTRANS, PCANTIDAD, PCANTIDAD1, PRENDIMIENTO)  #XVT19082020.n
 Local Decimal LRES
 Local Decimal LMAXHUMEDAD, LMAXHUMEGAS
 Local Decimal LMAXHUMESC   #XVT19082020.n

 If !clalev([ADI]) : Local File ATABDIV [ADI] : Endif
 Filter [ADI] Where NUMTAB = 6003 and A1 = PTRANS and A2 = "MAXHUMEDAD"
 Read [F:ADI] First
 If !fstat Then
  LMAXHUMEDAD = [F:ADI]N1

 Else
  LMAXHUMEDAD = 0
 Endif
 Filter [ADI]

 Filter [ADI] Where NUMTAB = 6003 and A1 = PTRANS and A2 = "MAXHUMEGAS"
 Read [F:ADI] First
 If !fstat Then
  LMAXHUMEGAS = [F:ADI]N1
 Else
  LMAXHUMEGAS = 0
 Endif
 Filter [ADI]

#XVT19082020.bn
 Filter [ADI] Where NUMTAB = 6003 and A1 = PTRANS and A2 = "MAXHUMSINCO"
 Read [F:ADI] First
 If !fstat Then
  LMAXHUMESC = [F:ADI]N1
 Else
  LMAXHUMESC = 0
 Endif
 Filter [ADI]
#XVT19082020.en

 If PHUMEDAD > LMAXHUMEDAD Then
    If PHUMEDAD < LMAXHUMESC Then   #XVT19082020.n
      #CASO 2  Cantidad2 = Cantidad x (Rto – ( Rto x (Hmu – Hmax)/100))/100
      LRES = arr((PCANTIDAD * ( PRENDIMIENTO - (PRENDIMIENTO * ( PHUMEDAD - LMAXHUMEDAD)/100))/100), 0.01)
    Else
      #CASO 3 Cantidad2 = Cantidad x (Rto – (Rto x (Hco – Hmax)/100))/100
      # BUSCAR EN LA TABLA CORRECTORA
#XVT24082020.o      Filter [ADI] Where NUMTAB = 6004 and N1 > PHUMEDAD Order By N1 Asc
      Filter [ADI] Where NUMTAB = 6004 and N1 <= PHUMEDAD Order By N1 Desc #XVT24082020.n
      Read [F:ADI] First
      If !fstat Then
        #CANTIDAD2 = CANTIDAD X (RTO – (RTO X (HCO – HMAX)/100))/100
        LRES = arr (PCANTIDAD * (PRENDIMIENTO -(PRENDIMIENTO * ([F:ADI]N2-LMAXHUMEDAD)/100  ))/100  , 0.01)
      Else
        LRES = 0
      Endif
      Filter [ADI]
    Endif

 Else
   #CASO 1
   LRES = PCANTIDAD1
 Endif

End LRES


#**
#* UVA
#* Fórmula para calcular la calidad en base al PH, POTASIO Y GLUCONICO
#* Si tenemos los tres valores, se suman los puntos, y en función de los puntos
#* calculamos la calidad
#*
#* @param PPH         -- Valor campo PH
#* @param PPOTASIO    -- Valor campo Potasio
#* @param PGLUCONICO  -- Valor campo Gluconico
#* @param PTRANS      -- Transacción en la que estamos
#* @param PCALIDAD    -- Calidad que nos pasa Básculas Romero
#*!
Funprog U_PUNTOS2CALIDAD(PPH, PPOTASIO, PGLUCONICO, PTRANS, PCALIDAD, PPUNTOS)
  Variable Decimal PPUNTOS
  Local Char LRES
  Local Char LGLCALIDAD : LGLCALIDAD = "GLCALIDAD" # GLUCONICO
  Local Char LPOCALIDAD : LPOCALIDAD = "POCALIDAD" # POTASIO
  Local Char LPHCALIDAD : LPHCALIDAD = "PHCALIDAD" # PH
  Local Decimal LPUNTOS
  Local Char LTIPOCALIDAD # : LTIPOCALIDAD = "TIPOCALIDADA"
  Local Char LCALIDADBAJA

  If !clalev([ADI]) : Local File ATABDIV [ADI] : Endif

  # DETERMINAR SI EL TIPO DE CALIDAD ES DE TIPO A O DE TIPO B
  # GUARDAR LA CALIDAD BAJA. SI LA CALIDAD QUE NOS PROPORCIONA B.R. ES IGUAL A LA BAJA, LOS PUNTOS
  # NO AFECTARÁN A LA CALIDAD, PERO SI ALMACENERAMOS EL RESULTADO DE LOS PUNTOS.
  Filter [ADI] Where NUMTAB = 6003 and A3 = PCALIDAD and A1 = PTRANS # Order By N1 Asc
  Read [F:ADI] First
  LTIPOCALIDAD = [F:ADI]A2
  Filter [ADI] Where NUMTAB = 6003 and A2 = LTIPOCALIDAD and A1 = PTRANS Order By N1 Asc
  Read [F:ADI] First
  LCALIDADBAJA = [F:ADI]A3 # SE SUPONE QUE ESTO ES LA CALIDAD BAJA DEL TIPO DE CALIDAD A o B
  # Infbox "Tipo calidad:" + LTIPOCALIDAD + " - Código calidad baja: " + LCALIDADBAJA
  LPUNTOS = 0
  # Infbox "PH:" + num$(PPH) + " - POTASIO: " + num$(PPOTASIO) + " - GLUCONICO: "+ num$(PGLUCONICO) + " - PTRANS: " + PTRANS
 # MAB 09092019.OLD
 # If PPH <> 0 and PPOTASIO <> 0 and PGLUCONICO <> 0 and PCALIDAD <> '' Then
    # Infbox "0 -" + num$(LPUNTOS)
    # SUMAR PUNTOS DEL GLUCONICO

    #If PGLUCONICO <> 0 Then # AUNQUE EL GLUCONICO SEA CERO TAMBIEN DEBE DE SUMAR LOS PUNTOS

      Filter [ADI] Where NUMTAB = 6003 and A1 = PTRANS and  A2 = LGLCALIDAD and N2 <= PGLUCONICO and N3 >= PGLUCONICO
      Read [F:ADI] First
      If !fstat Then
         LPUNTOS = LPUNTOS + [F:ADI]N1
         # Infbox "PGLUCONICO ->" + num$([F:ADI]N1) + " - Resultado:" + num$(LPUNTOS)
      Endif
    #Endif
    # SUMAR PUNTOS DEL POTASIO
    # If PPOTASIO <> 0 Then # AUNQUE EL POTASIO SEA CERO TAMBIEN DEBE DE SUMAR LOS PUNTOS
      Filter [ADI] Where NUMTAB = 6003 and A1 = PTRANS and  A2 = LPOCALIDAD and N2 <= PPOTASIO and N3 >= PPOTASIO
      Read [F:ADI] First
      If !fstat Then
         LPUNTOS = LPUNTOS + [F:ADI]N1
         # Infbox "PPOTASIO ->" + num$([F:ADI]N1) + " - Resultado:" + num$(LPUNTOS)
      Endif
    # Endif
    # SUMAR PUNTOS DEL PH
    # If PPH <> 0 Then # AUNQUE EL PH SEA CERO TAMBIEN DEBE DE SUMAR LOS PUNTOS
      Filter [ADI] Where NUMTAB = 6003 and A1 = PTRANS and  A2 = LPHCALIDAD and N2 <= PPH and N3 >= PPH
      Read [F:ADI] First
      If !fstat Then
         LPUNTOS = LPUNTOS + [F:ADI]N1
         # Infbox "PPH ->" + num$([F:ADI]N1) + " - Resultado:" + num$(LPUNTOS)
      Endif
    # Endif
    # SUMAR PUNTOS DEL PH
    # RESULTADO CALIDAD EN FUNCIÓN DE LOS PUNTOS
    #Infbox LTIPOCALIDAD
    #Infbox num$(LPUNTOS)
    Filter [ADI] Where NUMTAB = 6003 and A1 = PTRANS and  A2 = LTIPOCALIDAD and N2 <= LPUNTOS and N3 >= LPUNTOS
    #Infbox "NUM REG:" + num$(rowcount([ADI]))
    Read [F:ADI] First
    If !fstat Then
       LRES = [F:ADI]A3 # RESULTADO ALFANUMERICO
    Endif
  # Endif
  # MAB.09092019.OLD
  # SI LA CALIDAD QUE NOS HA PASADO BASCULAS ROMERO, ES BAJA, NO SE MODIFICA LA CALIDAD
  # SOLO SE ALMACENAN LOS PUNTOS RESULTANTES.
  If PCALIDAD = LCALIDADBAJA
     LRES = PCALIDAD
  #   Infbox "4 - CALIDAD BAJA - SE QUEDA IGUAL" + num$(LPUNTOS)
  Endif
  #Infbox "Total puntos:" + num$(LPUNTOS)
  PPUNTOS = LPUNTOS
End LRES

#**
#* UVA
#* Función que nos devuelve el GRADO en base al Gluconico y tipo de uva
#* en la transacción de BOD
#*
#* @param PGLUCONICO
#* @param PTIPOUVA
#* @param PTRANS
#*!
Funprog U_GLUCONICO2GRADO(PGLUCONICO, PTIPOUVA, PTRANS)
  Local Float LRES

  If !clalev([ADI]) : Local File ATABDIV [ADI] : Endif
  If PTIPOUVA = 'B' Then # UVA BLANCA
    Filter [ADI] Where NUMTAB = 6003 and A1 = PTRANS and A2 = "MAXGLUCONICOUB"
  Elsif PTIPOUVA = 'T' Then # UVA TINTA
    Filter [ADI] Where NUMTAB = 6003 and A1 = PTRANS and A2 = "MAXGLUCONICOUT"
  Endif
  Read [F:ADI] First
  If PGLUCONICO > [F:ADI]N2 Then
    LRES = [F:ADI]N1
  Endif

End LRES

#**
#* MOSTO - UVA.
#* El grado del mosto modifica la densidad, en función
#* de la relación en las tablas varias
#*
#*!
Funprog U_GRADO2DENSIDAD(PGRADO)
  Local Decimal LRES
  If !clalev([ADI]) : Local File ATABDIV [ADI] : Endif
  Filter [ADI] Where NUMTAB = 6005 and PGRADO >= N2 and PGRADO <= N2
  Read [F:ADI] First
  If !fstat Then
    LRES = [F:ADI]N1
  Else
    LRES = 0
  Endif

End LRES

#**
#* MOSTO. Modifica Cantidad2 en funcion del grado y la cant1
#*
#* @param PCANTIDAD1
#*!
Funprog U_CANTIDAD12CANTIDAD2(PCANTIDAD1, PGRADO)
  Local Decimal LRES

  LRES = arr(PCANTIDAD1 * PGRADO,0.000001) # / 100


End LRES

#**
#* UVA. CANTIDAD1 O HECTOLITROS EN MOSTO Y VINO (81 Y 80)
#*
#* @param PCANTIDAD
#* @param PDENSIDAD
#*!
Funprog U_DENSIDAD2CANT1(PCANTIDAD, PDENSIDAD)
  Local Decimal LRES
  If PDENSIDAD <> 0 Then
    LRES = arr((PCANTIDAD / 100)/PDENSIDAD,0.000001)
  Endif

End LRES

