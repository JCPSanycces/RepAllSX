$ACTION
Case ACTION
 When Default
Endcase
Return

Subprog AM_KZDNI(VALEUR)
  Variable Char    VALEUR()
  Gosub APRES_MODIF From TRTBPA : If mkstat : End : Endif
  [M:CNTT]ZDNI([M]KNOLIG) = VALEUR
  [M:CNTT]FLMOD([M]KNOLIG) = 1
  Gosub INIT_FLMODFONC From SUBCNT

End


