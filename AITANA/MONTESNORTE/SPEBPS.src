#XVT20190215 MIGRACIÓN A V11

$ACTION
  Gosub ACTION From YARBPOPC
Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla BPS0) 05/06/2019 13:10:04 (ADMIN)
######################################################################################
Subprog AM_BPSNUM(VALEUR)
Variable Char    VALEUR()
    If !clalev([F:BPR1]) : Local File BPARTNER [BPR1] : Endif

    Read [BPR1]BPR0 = VALEUR
    If fstat = 0
        If GREP = "C" | GREP = "D" or GREP = ""

            [M:BPS0]BPSNUM = VALEUR
            Affzo [M:BPS0]BPSNUM

            Gosub CHARG_LIN From YARBPOPC
        Endif
        SYMBOLE2 = "BPR"+num$(VALEUR)
        Lock = SYMBOLE2 With lockwait = 0
        If fstat
            If GREP = "C" or GREP = "D"
               GERR=1 : GMESSAGE = mess(10,100,1) : mkstat = 2 : End
            Endif
        Endif
    Endif
End


