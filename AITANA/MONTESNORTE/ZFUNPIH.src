#<AdxTL>@(#)0.0.0.0 $Revision$
#XVT22052020 SUPPORT3501 - SELECCIÓN DE RECIBOS AGRARIOS CON TERCEROS CON REPRESENTACIÓN
#

$ACTION
Infbox "ZIMPLIQ - " + ACTION
  Case ACTION
    When "PIHFILTRE" : Gosub PIHFILTRE
  Endcase
Return


$PIHFILTRE
#Infbox "ZFUNPIH - PIHFILTRE: WCRIT= " + WCRIT
  If !clalev([YPS]) : Local File YPERSEC [YPS] : Endif
  Local Mask PIHPST [DIA]

  If [M:DIA]ZREPRECAG=2 Then
    PIHFILTRE = ''
    PIHFILTRE += '( PIVTYP="ELQ" or PIVTYP="FLQ") AND ZREPRECAG=2'
  Endif

#Infbox "ZFUNPIH" + " " + PIHFILTRE
Return

