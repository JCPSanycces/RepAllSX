###################################################################################
$LIENS_ZPIH3
 # 20200702 - MS - COMENTO EL CÓDIGO YA QUE NO CARGA LA A CANTIDAD 1
  If !clalev([ZPID]) : Local File PINVOICED[ZPID] : Endif
  Raz nolign
  nolign=0
  Filter [ZPID] Where NUM=[M:PIH0]NUM
  For [ZPID]
      nolign+=1
      [M:ZPIH3] = [F:ZPID]
  Next
  [M:ZPIH3]ZNBLIG = nolign
  nolign=0
  Affzo [M:ZPIH3]

####  20200702 - MS - Solución
#
#     If GUSER = "ADMIN" : Infbox(num$(nolign)) : Endif
#     [M:ZPIH3]ZCANT1(nolign-1) = [M:PIH3]QTYUOM(nolign-1)
####  Next
####  [M:ZPIH3]ZNBLIG = nolign
####  nolign=0
#     Affzo [M:ZPIH3]ZCANT1(nolign-1)
Return

###################################################################################
$LIENS_LIG_ZPIH3
###  20200702 - MS - Solución
  If GUSER = "ADMIN" : Infbox(num$(nolign)) : Endif
  [M:ZPIH3] = [M:PIH3]
  [M:ZPIH3]ZCANT1(nolign-1) = [M:PIH3]QTYUOM(nolign-1)
###  Next
###  [M:ZPIH3]ZNBLIG = nolign
###  nolign=0
   Affzo [M:ZPIH3]ZCANT1(nolign-1)




Return



$ANNULE
    If [PIH]PIVTYP="FLQ" or [PIH]PIVTYP="ELQ" Then
    ##BORRAR REFERENCIA EN TABLA YTPLINPER
     If clalev([F:ZPID])=0: Local File PINVOICED [ZPID] : Endif
     Filter [F:ZPID] Where (PIVTYP='FLQ' or PIVTYP='ELQ') and [ZPID]ZNUMECTA=[PIH]NUM
     Read [F:ZPID]First
     If !fstat Then

      #la entrega a cuenta aparece en alguna liquidación
      #no se puede borrar, si no se borra antes la liquidación
        Call MESSAGE ("La factura aparece en alguna liquidación. Imposible borrar") From GESECRAN
        GOK=0
        Return
     Endif
     If clalev([F:YP1])=0 : Local File YTPLINPER  [YP1] : Endif
      Filter [F:YP1] Where [F:YP1]ZNUMFAC = [PIH]NUM
      Readlock [F:YP1] First
      If !fstat Then
        [F:YP1]ZNUMFAC=""
        [F:YP1]TFACGEN=1
        Rewrite [F:YP1]
        If !fstat Then
          Unlock [F:YP1]
        Else
          Call MESSAGE("No se pudo actualizar Precios Liquidaciones. Imposible borrar") From GESECRAN
          GOK=0
        Endif
#      Else
#        Call MESSAGE("No se pudo actualizar Precios Liquidaciones. Imposible borrar") From GESECRAN
#        GOK=0
      Endif
    Endif

Return

###################################################################################
$TITCOL_ZPIH3
  Call OCULTA_CAMPOS("PIH") From ZSPEMASKL
  Affzo [M:ZPIH3]

Return
######################################################################################
$AFFMASK
  #ocultar calificaciones que no aplican por transacción
  If GFLAG="ALL" : Return : Endif
  Call OCULTA_CAMPOS("PIH") From ZSPEMASKL
  Affzo [M:ZPIH3]
Return
######################################################################################
Subprog C_ACCDAT(VALEUR)
Variable Date    VALEUR
  #EN LAS FACTURAS SIN CAMPAÑA SE INICIALIZARÁ EL CAMPO ZEJERCICIO
  #A CERO.
  #PENDIENTE APLICARLO A ABONOS

  Local Integer VEJERCICIO : VEJERCICIO=0
  Call GET_EJERCICIO("",[F:FCY]YTIPOFCY,VALEUR,VEJERCICIO) From ZLIBMONTES

  [M:PIH0]ZEJERCICIO=VEJERCICIO
  Affzo [M:PIH0]ZEJERCICIO

  # Infbox num$(VEJERCICIO)

  If VEJERCICIO = 0 Then
    Call MESSAGE ("Campaña no definida para este tipo de planta.") From GESECRAN
    mkstat = 2
  Endif
End

Subprog C_ZEJERCICIO(VALEUR)
Variable Decimal VALEUR
  Local Integer POK : POK=0
  If VALEUR<>0 Then
     # Call CHECK_EJERCICIO("",[F:FCY]YTIPOFCY,VALEUR,POK) From ZLIBMONTES
     Call CHECK_EJERCICIO([M:PIH0]FCY,[F:FCY]YTIPOFCY,VALEUR,POK) From ZLIBMONTES # MAB.23012020.NEW
     If POK=0 Then
      Call MESSAGE ("Campaña no definida para este tipo de planta.") From GESECRAN
      VALEUR=0
     Endif
  Endif
End


