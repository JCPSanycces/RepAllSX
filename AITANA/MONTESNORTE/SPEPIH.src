Subprog AM_ZPH(VALEUR)
Variable Decimal VALEUR

Local Decimal LPUNTOS
Local Char LRES
# If VALEUR <> 0 Then
    If func ZLIBMONTES.GET_TIPOITEM([M:PIH3]ITMREF(nolign-1)) = "90" Then # If GFLAG = "BOD" Then # Transacción de BODEGA
      LRES = func ZGESCALIF.U_PUNTOS2CALIDAD(VALEUR,[M:ZPIH3]ZPOTASIO(nolign-1),[M:ZPIH3]ZGLUCONICO(nolign-1), GFLAG, [M:ZPIH3]ZCALIDAD(nolign-1), LPUNTOS)
      If LRES <> '' Then
          [M:ZPIH3]ZCALIDAD(nolign-1) =  LRES
          [M:ZPIH3]ZPUNTOS(nolign-1) = LPUNTOS
          Affzo [M:ZPIH3]ZCALIDAD(nolign-1)
          Affzo [M:ZPIH3]ZPUNTOS(nolign-1)
          [M:PIH3]ZCALIDAD(nolign-1) =  [M:ZPIH3]ZCALIDAD(nolign-1)
          [M:PIH3]ZPUNTOS(nolign-1) = [M:ZPIH3]ZPUNTOS(nolign-1)
          Affzo [M:PIH3]ZCALIDAD
          Affzo [M:PIH3]ZPUNTOS
      Endif
    Endif
#  Endif
  [M:PIH3]ZPH(nolign-1) = VALEUR
  Affzo [M:PIH3]ZPH
  # [M:PIH3]QTYUOM(nolign-1) = [M:PIH3]Z QTY(nolign-1)
  [M:PIH3]UPDFLG(nolign-1) = 1
End

Subprog AM_ZPOTASIO(VALEUR)
Variable Decimal VALEUR
Local Decimal LPUNTOS
