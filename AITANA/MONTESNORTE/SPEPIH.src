$ACTION
#If GUSER="ADMIN" : Infbox "SPEPIH " + ACTION: Endif
Case ACTION
    When "APRES_CRE" : Gosub APRES_CRE
    When "LIENS"    : Gosub LIENS
    When "AFFMASK"  : Gosub AFFMASK
    When "ANNULE"   : Gosub ANNULE
    When "SETBOUT"  : Gosub SETBOUT
 When Default
Endcase
Return

###################################################################################
$SETBOUT

If clalev([F:HAE])=0 : Local File GACCENTRY [HAE] : Endif
Read [HAE] HAE0=[M:PIH0]GTE;[M:PIH0]NUM
If !fstat
                                                 # existe el asiento contable
  If !clalev([ZVACCANT]) : Local File YVACCANT [ZVACCANT] : Endif   # Vista Línea  Asto. a Regularizar
  Filter [ZVACCANT] Where BPRVCR = [M:PIH1]BPRVCR and ACC = '40710009'
  Read [ZVACCANT] First
  If !fstat   #exsite apunte con '40710009'
              # debemeos comprobar que no existe el contraasiento
    Filter [ZVACCANT] Where BPRVCR = ("RG-" + [M:PIH1]BPRVCR) and ACC = '40710009'
    Read [ZVACCANT] First
    If !fstat
      Call VIREBOUT(CHAINE,"6") From GOBJET   # ya existe el contrasiento
    Else

    Endif
  Else
     Call VIREBOUT(CHAINE,"6") From GOBJET   # ya existe el contrasiento
  Endif
Else
  Call VIREBOUT(CHAINE,"6") From GOBJET   # ya existe el contrasiento
Endif

  # desactivamos el botón de Reg. cuando
  # si hay asto. contable con la cta. 40710009 y BPRVCR (doc. ori)
Return


###################################################################################
$APRES_CRE
Return

