# If VALEUR <> 0 Then
    If func ZLIBMONTES.GET_TIPOITEM([M:PIH3]ITMREF(nolign-1)) = "90" Then # Transacción de BOD
      LRES =  func ZGESCALIF.U_PUNTOS2CALIDAD([M:ZPIH3]ZPH(nolign-1),VALEUR,[M:ZPIH3]ZGLUCONICO(nolign-1), GFLAG, [M:ZPIH3]ZCALIDAD(nolign-1), LPUNTOS)
      If LRES <> '' Then
        [M:ZPIH3]ZCALIDAD(nolign-1) = LRES
        [M:ZPIH3]ZPUNTOS(nolign-1) = LPUNTOS
