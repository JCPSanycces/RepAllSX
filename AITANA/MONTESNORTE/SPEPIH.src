If VALEUR <> 0 Then
    If func ZLIBMONTES.GET_TIPOITEM([M:PIH3]ITMREF(nolign-1)) = "21" Then # If GFLAG = "CER" Then # Transacción de CEREAL
      #[M:ZPIH3]ZCANT1(nolign-1) =  func ZGESCALIF.C_HUMEDAD2CANTIDAD1(VALEUR, GFLAG, [M:PIH3]QTY(nolign-1))
      [M:ZPIH3]ZCANT1(nolign-1) =  func ZGESCALIF.C_HUMEDAD2CANTIDAD1(VALEUR, GFLAG, [M:PIH3]ZCANT1(nolign-1))
      Affzo [M:ZPIH3]ZCANT1
      [M:PIH3]ZCANT1(nolign-1) = [M:ZPIH3]ZCANT1(nolign-1)
      Affzo [M:PIH3]ZCANT1(nolign-1)
    Endif
  Endif
  [M:PIH3]ZHUMEDAD(nolign-1) = VALEUR
  Affzo [M:PIH3]ZHUMEDAD(nolign-1)
   [M:PIH3]UPDFLG(nolign-1) = 1
End

