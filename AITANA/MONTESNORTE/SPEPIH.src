######################################################################################
Subprog AM_ZCALIDAD(VALEUR)
Variable Char    VALEUR()
  Local Integer ESTAT

    If (VALEUR<>"")
        Call MODIF_CALIDAD(VALEUR, [M:PIH3]TSICOD1(nolign-1), [M:PIH3]TSICOD2(nolign-1),
&            [M:PIH3]TSICOD3(nolign-1), 2, ESTAT) From YSELAGRO
        If ESTAT=0 Then
            GERR=1
            # GMESSAGE=mess(12,1986,1)
            Infbox "Calidad no contemplada para el artículo seleccionado"
            mkstat=2
            EXISTE=1
        Endif
    Endif
    [M:PIH3]ZCALIDAD(nolign-1) = VALEUR
    Affzo [M:PIH3]ZCALIDAD(nolign-1)
    [M:PIH3]UPDFLG(nolign-1) = 1
  # Chgfmt [M:SIH4]ZCANT2 With "-N:10"
End


