Subprog AM_ZCANT1(VALEUR)
Variable Decimal VALEUR
Local Char LTIPOPRODUCTO
  LTIPOPRODUCTO = func ZLIBMONTES.GET_TIPOITEM([M:PIH3]ITMREF(nolign-1))
  If VALEUR <> 0 Then
    If LTIPOPRODUCTO = "50" Then # If GFLAG = "FRU" Then # Transacción de FRUTOS CON CASCARA
      [M:ZPIH3]ZCANT2(nolign-1) =  func ZGESCALIF.FC_HUMEDAD2CANTIDAD2([M:ZPIH3]ZHUMEDAD(nolign-1), GFLAG, [M:ZPIH3]QTYUOM(nolign-1) , VALEUR)
      Affzo [M:ZPIH3]ZCANT2
      [M:PIH3]ZCANT2(nolign-1) = [M:ZPIH3]ZCANT2(nolign-1)
      Affzo [M:PIH3]ZCANT2(nolign-1)
    Endif
    If LTIPOPRODUCTO = "81" Then
      [M:ZPIH3]ZCANT2(nolign-1) = func ZGESCALIF.U_CANTIDAD12CANTIDAD2(VALEUR, [M:ZPIH3]ZGRADO(nolign-1))
      Affzo [M:ZPIH3]ZCANT2
      [M:PIH3]ZCANT2(nolign-1) = [M:PIH3]ZCANT2(nolign-1)
      Affzo [M:PIH3]ZCANT2(nolign-1)
    Endif
  Endif

  [M:PIH3]ZCANT1(nolign-1) = VALEUR
  Affzo [M:PIH3]ZCANT1(nolign-1)
   [M:PIH3]UPDFLG(nolign-1) = 1
End

Subprog AM_ZCANT2(VALEUR)
Variable Decimal VALEUR
 [M:PIH3]ZCANT2(nolign-1) = VALEUR
 Affzo [M:PIH3]ZCANT2(nolign-1)
 [M:PIH3]UPDFLG(nolign-1) = 1
End

Subprog AM_ZDENSIDAD(VALEUR)
Variable Decimal VALEUR
Local Char LTIPOPRODUCTO
  If VALEUR <> 0 Then
    LTIPOPRODUCTO = func ZLIBMONTES.GET_TIPOITEM([M:PIH3]ITMREF(nolign-1))
    If LTIPOPRODUCTO = '81' or LTIPOPRODUCTO = '80' Then
      [M:ZPIH3]ZCANT1(nolign-1) = func ZGESCALIF.U_DENSIDAD2CANT1([M:ZPIH3]QTYUOM(nolign-1), VALEUR)
      Affzo [M:ZPIH3]ZCANT1
      [M:PIH3]ZCANT1(nolign-1) = [M:ZPIH3]ZCANT1(nolign-1)
    Endif

  Endif
  [M:PIH3]ZDENSIDAD(nolign-1) = VALEUR
  Affzo [M:PIH3]ZDENSIDAD(nolign-1)
  [M:PIH3]UPDFLG(nolign-1) = 1
End

Subprog AM_ZGLUCONICO(VALEUR)
Variable Decimal VALEUR
Local Decimal LPUNTOS
Local Char LRES
Local Char LTIPOUVA
# If VALEUR <> 0 Then
    If func ZLIBMONTES.GET_TIPOITEM([M:PIH3]ITMREF(nolign-1)) = "90" Then  # If GFLAG = "BOD" Then # Transacción de BODEGA
      LRES = func ZGESCALIF.U_PUNTOS2CALIDAD([M:ZPIH3]ZPH(nolign-1),[M:ZPIH3]ZPOTASIO(nolign-1),VALEUR, GFLAG, [M:ZPIH3]ZCALIDAD(nolign-1), LPUNTOS)
      If LRES <> '' Then
          [M:ZPIH3]ZCALIDAD(nolign-1) = LRES
          [M:ZPIH3]ZPUNTOS(nolign-1) = LPUNTOS
      Endif
      Affzo [M:ZPIH3]ZCALIDAD
      Affzo [M:ZPIH3]ZPUNTOS
      [M:PIH3]ZCALIDAD(nolign-1) = [M:ZPIH3]ZCALIDAD(nolign-1)
      [M:PIH3]ZPUNTOS(nolign-1) = [M:ZPIH3]ZPUNTOS(nolign-1)
      Affzo [M:PIH3]ZCALIDAD(nolign-1)
      Affzo [M:PIH3]ZPUNTOS(nolign-1)
    Endif
    If func ZLIBMONTES.GET_TIPOITEM([M:PIH3]ITMREF(nolign-1)) = "90" Then # If GFLAG = "BOD" Then
      # COMO SABEMOS SI ES UVA BLANCA O TINTA ?????
      LTIPOUVA = func ZLIBMONTES.GET_TIPOUVA([M:PIH3]ITMREF(nolign-1))
      [M:ZPIH3]ZGRADO(nolign-1) = func ZGESCALIF.U_GLUCONICO2GRADO([M:ZPIH3]ZGLUCONICO(nolign-1) ,LTIPOUVA, GFLAG)
      Affzo [M:ZPIH3]ZGRADO
      [M:PIH3]ZGRADO(nolign-1) = [M:ZPIH3]ZGRADO(nolign-1)
      Affzo [M:PIH3]ZGRADO(nolign-1)
    Endif
#  Endif
  [M:PIH3]ZGLUCONICO(nolign-1) = VALEUR
  Affzo [M:PIH3]ZGLUCONICO(nolign-1)
   [M:PIH3]UPDFLG(nolign-1) = 1
End

Subprog AM_ZGRADO(VALEUR)
Variable Decimal VALEUR
Local Char LTIPOPRODUCTO

  LTIPOPRODUCTO = func ZLIBMONTES.GET_TIPOITEM([M:PIH3]ITMREF(nolign-1))
  If VALEUR <> 0 Then
    If LTIPOPRODUCTO = "90" Then # "BOD"
      Call B_UVA_GRADO2CANTIDAD1(VALEUR,[M:PIH3]QTYUOM(nolign-1),[M:ZPIH3]ZCANT1(nolign-1)) From ZGESCALIF
      Affzo [M:ZPIH3]ZCANT1(nolign-1)
      [M:PIH3]ZCANT1(nolign-1) = [M:ZPIH3]ZCANT1(nolign-1)
      Affzo [M:PIH3]ZCANT1(nolign-1)
    Endif
    If LTIPOPRODUCTO = "81"  Then # MOSTO Y VINO
      [M:ZPIH3]ZDENSIDAD(nolign-1) = func ZGESCALIF.U_GRADO2DENSIDAD(VALEUR)
      Affzo [M:ZPIH3]ZDENSIDAD
      [M:PIH3]ZDENSIDAD(nolign-1) = [M:ZPIH3]ZDENSIDAD(nolign-1)
      Affzo [M:PIH3]ZDENSIDAD(nolign-1)
    Endif
  Endif
  [M:PIH3]ZGRADO(nolign-1) = VALEUR
  Affzo [M:PIH3]ZGRADO(nolign-1)
   [M:PIH3]UPDFLG(nolign-1) = 1
End

