#<AdxTL>@(#)0.0.0.0 $Revision$
# Gestión de la máscara ZPESADAISIP (Especifico)
$ACTION
  Case ACTION
    When "OUVRE" : Gosub OUVRE
    When "OK" : Gosub OK
    When Default
  Endcase

Return

$OUVRE

  Errbox "Esta función no se encuentra disponible"
  End
 ##recuperar datos de los movimientos
  If !clalev([ZSOH]) : Local File SORDER [ZSOH] : Endif
  If !clalev([ZSOQ]) : Local File SORDERQ [ZSOQ]: Endif
  If !clalev([ZSOHI]) : Local File SORDER [ZSOHI] : Endif
  If !clalev([ZSOQI]) : Local File SORDERQ [ZSOQI]: Endif
  If !clalev([ZITM]) : Local File ITMMASTER [ZITM]: Endif
  If !clalev([ZPTH]) : Local File PRECEIPT [ZPTH] : Endif
  If !clalev([ZPTD]) : Local File PRECEIPTD [ZPTD] : Endif
  If !clalev([ZSDH]) : Local File SDELIVERY [ZSDH] : Endif
  If !clalev([ZSDD]) : Local File SDELIVERYD [ZSDD] : Endif

  Local Char    LFILE(200)
  Local Char    LDIRIMPORT(250) : LDIRIMPORT = "E:\IMPORTEXPORT\IMP\"
  Local Char LFECHA(10)

Return

$OK


  LFECHA = vireblc(num$(date$),4) : LFECHA = mid$(LFECHA,1,2)+mid$(LFECHA,4,2)+mid$(LFECHA,7,4)

  Infbox "Creación de entregas y recepciones"
  ##agregar controles
  ##1) Crear entrega de cooperativa base
    LFILE  = LDIRIMPORT + [ZSOQI]SOHNUM+"_SDH_"+LFECHA+".txt"
    Gosub OPEN_FILE
#H;99B;99B01;EV-99B0101-00003;SDH;01000074;001;EUR;20190626;20190626;1;;;;;
#L;PV-99B19-00007;1000;8001005;VINO MACABEO ;KG;100;;

      Wrseq "H;" + [ZSOQI]SALFCY + ";" + [ZSOQI]STOFCY +";;SDH;"+[ZSOQI]BPCORD +";"+ [ZSOQI]BPAADD +";EUR;"+
&    LFECHA +";"+ LFECHA +";1;;;;;" Using [ZIMP]
      Wrseq "L;" + [ZSOQI]SOHNUM +";"+ num$([ZSOQI]SOPLIN) +";"+ [M:ZPSI]ITMREF + ";" + [M:ZPSI]ITMDES + ";" +
&    [ZITM]SAU + ";"+ num$([M:ZPSI]QTYSHP) +";;" Using [ZIMP]

    Gosub CLOSE_FILE

    Call OUVRE_TRACE("Creación Recepcion a partir de Entrega Validada") From LECFIC
    Call IMPORTSIL("SDH", LFILE) From GIMPOBJ
    Call FERME_TRACE From LECFIC


  ##2) Crear recepción en comercializadora


  ##3) Crear entrega en comercializadora


    Call LEC_TRACE From LECFIC

Return


########################################################
$OPEN_FILE
  adxifs = ";"
  adxirs = chr$(13)+chr$(10)
  Openo LFILE Using [ZIMP]
Return

########################################################
$CLOSE_FILE
  Openo Using [ZIMP]
Return

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZPESADAISIP) 28/06/2019 11:33:50 (ADMIN)
######################################################################################
Subprog AM_SOHCLI(VALEUR)
Variable Char    VALEUR()



  Read [ZSOH]SOH0 = VALEUR
  #añadir controles: es contramarca, no está saldado, está asignada al pedido el lote y la ubicación.


  Filter [ZSOQ] Where [ZSOQ]SOHNUM=VALEUR
  Read [ZSOQ] First
  [M:ZPSI]POHCONT=[ZSOQ]FMINUM
  Affzo [M:ZPSI]POHCONT
  Read [ZITM]ITM0=[ZSOQ]ITMREF
  [M:ZPSI]ITMREF=[ZITM]ITMREF
  [M:ZPSI]ITMDES=[ZITM]ITMDES1
  [M:ZPSI]QTYSTU=[ZSOQ]QTYSTU
  Affzo [M:ZPSI]ITMREF
  Affzo [M:ZPSI]ITMDES
  Affzo [M:ZPSI]QTYSTU

  Filter [ZSOQI] Where POHNUM=[ZSOQ]FMINUM and POPLIN=[ZSOQ]FMILIN and POQSEQ=[ZSOQ]FMISEQ
  Read [ZSOQI] First
  [M:ZPSI]SOHCONT=[ZSOQI]SOHNUM
  Affzo [M:ZPSI]SOHCONT

  Filter [ZSOQI]
  Filter [ZSOQ]

End


Subprog AM_QTYSHP(VALEUR)
Variable Decimal VALEUR
End


