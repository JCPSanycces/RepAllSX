If GUSER="ADMIN" : Infbox "HOLA1 " : Endif
$ACTION
#If GUSER="ADMIN" : Infbox "YKK: " + ACTION: Endif
Case ACTION
  When "PRUEBA" : Gosub PRUEBA
 When Default
Endcase
Return

$PRUEBA
Infbox "HOLA"

If !clalev([ZHAE]) : Local File GACCENTRY [ZHAE] : Endif

Filter [ZHAE] Where BPRVCR = [M:PIH1]BPRVCR
Infbox [ZHAE]NUM


If GUSER="ADMIN" : Infbox "HOLA " : Endif
Return

