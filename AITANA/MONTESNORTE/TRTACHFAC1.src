#<AdxTL>@(#)6.0.0.0 $Revision$
###########################################################################
# TRTACHFAC1          Traitements liés aux Factures          Module ACHAT #
# ----------------------------------------------------------------------- #
# Sous-programmes                                                         #
#   - VALID_PIH  : Validation des factures en comptabilité                #
#   - PAMVATFLG  : Test modif rubrique pour calcul des taxes              #
#   - REGPRIX_FCC : Régul de stock liée aux factures compl. sur cdes      #
# ----------------------------------------------------------------------- #
# ACTIONS modélisation WEB (Traitement standard GTRAITE)                  #
#   - TRTVALPIH  : Validation des factures (Utilise le S/P VALID_PIH)     #
#                                                                         #
# ACTIONS modélisation WEB (Saisie de fenêtre GSAISIE)                    #
#   - VISUQTEPIH : Affichage détail des quantités d'une ligne facture     #
#   - DIVCHXPIH  : Choix facturation partielle                            #
# ----------------------------------------------------------------------- #
# Fonctions                                                               #
#   - RATSOCORI  : Récupération cours devise société d'origine            #
#   - RATRPTORI  : Récupération cours devise de reporting d'origine       #
###########################################################################

$ACTION
Case ACTION
 When "INIT"
  #-----------------------------------------------#
  # Initialisations avant exécution du traitement #
  #-----------------------------------------------#
  Case GACTION
   When "TRTVALPIH"  : Gosub INIT_TRTVALPIH
  Endcase
 When "EXEC"
  #-------------------------#
  # Exécution du traitement #
  #-------------------------#
  Case GACTION
   When "TRTVALPIH"  : Gosub EXEC_TRTVALPIH
  Endcase
 When "TERMINE"
  #-----------------------------------#
  # Fin après exécution du traitement #
  #-----------------------------------#
  Case GACTION
   When "TRTVALPIH"  : Gosub TERM_TRTVALPIH
  Endcase
 When "OUVRE"
  #--------------------------------------------------------------#
  # Avant la définition des boutons et l'ouverture de la fenêtre #
  #--------------------------------------------------------------#
  Case GACTION
   When "VISUQTEPIH" : Gosub OUVRE_VISUQTEPIH
   When "DIVCHXPIH"  : Gosub OUVRE_DIVCHXPIH
  Endcase
 When "TITRE"
  #---------------------#
  # Titre de la fenêtre #
  #---------------------#
  Case GACTION
   When "DIVCHXPIH"  : Gosub TITRE_DIVCHXPIH
  Endcase
 When "DEBUT"
  #---------------------------------#
  # Après l'ouverture de la fenêtre #
  #---------------------------------#
  Case GACTION
   When "VISUQTEPIH" : Gosub DEBUT_VISUQTEPIH
   When "DIVCHXPIH"  : Gosub DEBUT_DIVCHXPIH
  Endcase
 When "BOUTON"
  #--------#
  # Bouton #
  #--------#
  Case GACTION
   When "DIVCHXPIH"  : Gosub BOUT_DIVCHXPIH
  Endcase
 When "FINSAI"
  #------------------------------------------#
  # Avant de revenir à la fenêtre précédente #
  #------------------------------------------#
  Case GACTION
   When "DIVCHXPIH"  : Gosub FINSAI_DIVCHXPIH
  Endcase
Endcase
Return


##########################################################################
# TRTVALPIH : Action de validation des facture/avoirs en comptabilité    #
# ---------------------------------------------------------------------- #
# Paramètres de l'action TRTVALPIH :                        MBT 10/11/00 #
#   PARAM(1) = NUM    : Numéro de facture ou d'avoir à traiter           #
#   PARAM(2) = EXEFLG : Code retour toujours à 1 ??????                  #
##########################################################################
#------------------------------------------#
# Récupération des paramètres pour le Call #
#------------------------------------------#
$INIT_TRTVALPIH
Local Char    WNUM(GLONPIH) : WNUM=PARAM(1)
Local Integer WNBPCE        : WNBPCE=val(PARAM(2))
Call OUVRE_TRACE(mess(136,197,1))  From LECFIC
Return
#----------------------------------#
# Exécution du traitement par Call #
#----------------------------------#
$EXEC_TRTVALPIH
Call VALID_PIH(WNUM,WNBPCE)
Return
#--------------------------------------------------#
# Après exécution du traitement màj des paramètres #
#--------------------------------------------------#
$TERM_TRTVALPIH
Call FERME_TRACE From LECFIC
PARAM(2)=num$(WNBPCE)
TRA=1 : # Lecture de la trace
Return


##########################################################################
# VALID_PIH : S/P de validation des facture/avoirs en comptabilité       #
# ---------------------------------------------------------------------- #
# Subprog VALID_PIH (WNUM,WNBPCE)                                        #
#   WNUM    : Numéro de la facture ou avoir à traiter                    #
#   WNBPCE  : Code retour toujours à 1 ??????                            #
##########################################################################
Subprog VALID_PIH(WNUM,WNBPCE)
Value    Char    WNUM
Variable Integer WNBPCE
Local Integer  I , OK , WRETOUR , WINVTYP
Local Shortint OUVFICFLG
Local Char     PARAM2(10)
Local Char     WPCEAUTO(GLONGAU)
Local Char     WMSG(250), WMESSAGE(250) , IDENT(30) , WTRANSAC(max(GLONGAU,10)), WACTFLG(GLONACV), WACTFLG2(GLONACV)
Local Char     TZONE(10)(1..3) : # Table des zones à forcer (Ex: type de pièce)
Local Char     TVAL(10)(1..3)  : # Table des valeurs des zones à forcer
Local Char     TMESSA(100)(1..10)
Local Integer  FVAL(1..10)
Local Integer  NBRVCR, INDVCR
Local Char     WNUMEROS(250)
#----- Variables locales clé table GACCDUDATE pour éviter le Read Lock Curr -----#
Local Char     DUD_TYP(GLONGTE)
Local Char     DUD_NUM(GLONVCR)
Local Shortint DUD_LIG, DUD_DUDLIG
# Issue 94252 - 2013-11-22 by MUARN : lettrage avoir sur facture INVNUM non renseigné
Local Char    WNUMORI(GLONVCR)
# Issue X3-110159 - 2019-02-20 by MUARN : type pièce référentiel non saisissable
Local Integer SAV_GNBTYPLED : SAV_GNBTYPLED = GNBTYPLED

#-----
If clalev([F:GAU]) = 0 : Local File GAUTACE    [GAU] : Endif
If clalev([F:DUD]) = 0 : Local File GACCDUDATE [DUD] : Endif
If clalev([F:PYO]) = 0 : Local File PAYORDER   [PYO] : Endif
If clalev([F:CPY]) = 0 : Local File COMPANY    [CPY] : Endif
If clalev([F:STJ]) = 0 : Local File STOJOU     [STJ] : Endif
If clalev([F:SJV]) = 0 : Local File STOJOUVAL  [SJV] : Endif
# Issue 82703 - 2012-10-04 by SR : Pour les FCC sur commande
If clalev([F:TCM])  = 0 : Local File TABCOSTMET [TCM] : Endif
If clalev([F:PID2]) = 0 : Local File PINVOICED  [PID2] : Endif
If clalev([F:PND2]) = 0 : Local File PRETURND   [PND2] : Endif
If clalev([F:PIA])  = 0 : Local File BPSINVLIGA [PIA]  : Endif
# Issue 89349-7 - 2013-12-16 by SR : Gérer les avoirs sur FCC
If clalev([F:PIH2]) = 0 : Local File PINVOICE   [PIH2] : Endif
# Issue X3-73378 - 2018-01-25 by SR : Pour sauvegarder la ligne en cours de validation
If !clalev([F:PID3]) Local File PINVOICED [PID3] : Endif

# Bug 67451
If GMODU(3) = 2   : # Présence du module tiers
    If clalev([F:PYH])=0 : Local File PAYMENTH [PYH] : Endif
    If clalev([F:PYD])=0 : Local File PAYMENTD [PYD] : Endif
Endif
# Bug 67451
#----- Ouverture pour mise à jour sous-traitance -----#
If GMODU(8)=2
  If clalev([M:SBCK])=0 Local Mask SBCK  [SBCK] : Endif
Endif
#----- Lecture code activité "KIT" -----#
If clalev ([F:ACV])<=0 Local File ACTIV [ACV] : OUVFICFLG=1 : Endif
Read [ACV] CODACT="KIT" : If fstat Raz [F:ACV] : Endif
If [F:ACV]FLACT=2 WACTFLG="KIT" Else Raz WACTFLG : Endif
## <PP 16/09/03> ABL
#----- Lecture code activité "ABL" -----#
#Read [ACV] CODACT="ABL" : If fstat Raz [F:ACV] : Endif    : # mis en commentaire par EL le 26/11/2003
#If [F:ACV]FLACT=2 WACTFLG2="ABL" Else Raz WACTFLG2 : Endif
## <Fin PP>
If OUVFICFLG=1 Close Local File [ACV] : Raz OUVFICFLG : Endif
IDENT   = WNUM
WINVTYP = [F:PIH]INVTYP
Gosub TRANSAC
Call DEBTRANS From GLOCK

Gosub TR1
If GOK=1
  If [F:BPS]BPSNUM<>[F:PIH]BPR
     Read [BPS] BPS0=[F:PIH]BPR : If fstat Raz [F:BPS] : Endif
  Endif
  If [F:BPR]BPRNUM<>[F:PIH]BPR
    Read [BPR] BPR0=[F:PIH]BPR
    If fstat Raz [F:BPR] : Endif
  Endif
  Call WORKFLOW("F_FUNPIH","","") From SUBAMSC
Endif
#VPO 03/02/11 71150 on utilise GTYPLED_X3TC au lieu de GTYPLED
# on restaure la valeur car peut-être écrasé dans ss-pro de compta
For I=1 To 10
    GTYPLED(I)=GTYPLED_X3TC(I)
Next I

# Issue X3-110159 - 2019-02-20 by MUARN : type pièce référentiel non saisissable
# Issue X3-38295 - 2017-09-13 by MUARN : ITAPRE perte de variable avec ss-pro compta
#If GFONCTION="GESPIH" & GLOCITAPRE & dim(GSOC_ACTIVE)>0 & dim(GFCY)>0
If GFONCTION="GESPIH" & ( GLOCITAPRE & dim(GSOC_ACTIVE)>0 & dim(GFCY)>0 ) | SAV_GNBTYPLED <> GNBTYPLED
  Raz GFCY, GSOC_ACTIVE
Endif

End

###################################################################################
###################################################################################
$TRANSAC
Local Integer RET
Case WINVTYP
     When 1 : WTRANSAC = "PIHI"                  : # facture (invoice)
     When 2 : WTRANSAC = "PIHC"                  : # avoir (credit note)
              Read [GAU]GAU0 = WTRANSAC
              If fstat : WTRANSAC = "PIHI"       : Endif
Endcase
#--- Récupération code pièce auto dans le paramétrage type facture utilisateur ---#
If [F:PIH]PIVTYP<>""
  If clalev([F:TPV])=0 Local File TABPIVTYP [TPV] : OUVFICFLG=1 : Endif
  #MAE, ajout LEG
  Call LEC_TPV_LEG(GCURLEG,[F:PIH]PIVTYP,RET) From TRTLECLEG
  #Read [TPV]TPV0=[F:PIH]PIVTYP :
  If RET Raz [F:TPV] : Endif
  If [F:TPV]COD<>""
    WTRANSAC=[F:TPV]COD
    Read [GAU] GAU0 = WTRANSAC
    If fstat WTRANSAC = "PIHI" : Endif
  Endif
  If OUVFICFLG=1 Close Local File [TPV] : Raz OUVFICFLG : Endif
Endif
#--- Point d'entrée GAUVALPIH pour forcer une pièce automatique particulière ---#
# WTRANSAC = Pièce automatique à utiliser lors de la validation de la facture   #
#-------------------------------------------------------------------------------#
GPOINT="GAUVALPIH" : Gosub ENTREE From EXEFNC
Read [GAU] GAU0=WTRANSAC : If fstat  WTRANSAC="PIHI" : Endif
#-----
Return


#########################################################################
#########################################################################

$TR1
GOK = 1
Trbegin [PIH]
  Readlock [PIH]PIH0 = WNUM
  If fstat=1
    GOK=-1 : GLOCK="$PINVOICE"-WNUM : Goto ROLL_TR1
  Elsif fstat
    GOK=0 : Call RSTA("PIH",WNUM) From GLOCK
    Rollback : Return
  Endif

  # Issue 107231 - 2015-03-30 by MUARN : PE mise à jour table
  #----- Point d'entrée MAJVALPIHA pour màj champs spécifiques lors de la validation -----#
  #----- avant mise à jour des tables standards                                      -----#
  GPOINT="MAJVALPIHA" : Gosub ENTREE From EXEFNC
  If GOK=0  Rollback : Return : Endif
  If GOK<0  Goto ROLL_TR1     : Endif

  If [F:PIH]RATDAT=[0/0/0]  [F:PIH]RATDAT=[F:PIH]ACCDAT  : Endif
  #----- Chargement GSOCIETE, GLOCALDEV et GFINRSP -----#
  Call GETDEV([F:PIH]FCY) From DEVSUB : If GFINRSP="" GFINRSP=[F:PIH]FCY : Endif
  If GMODU(2)=2 : # Présence du module comptabilité
    #----- Validation avec pièce automatique -----#
    Raz GNUMPCE
    Raz TMESSA, TZONE, TVAL

    TZONE(1)="TYP"    : TVAL(1)=[F:PIH]GTE
    TZONE(2)="JOU"    : TVAL(2)=[F:PIH]JOU
    TZONE(3)="TYPDUD" : TVAL(3)="2"
    GFCYDEF(0)=GFCYDEF(2)
    #----- Passage par les groupes de pièces -----#
    Call EVALGRP(WTRANSAC,"NUM","PIH]NUM",FVAL) From VALGRP
    Call VALGRP3(WTRANSAC,IDENT,WRETOUR,TMESSA,TZONE,TVAL,FVAL) From VALGRP
    #-----
    GFCYDEF(0)=GFCYDEF(6)
    #----- Erreur à la validation -----#
    If WRETOUR
      Call ECR_TRACE([F:PIH]NUM-TMESSA(1),1) From GESECRAN
      WNBPCE = 1
      GOK = 0
      Rollback : Return
    Endif
    #----- La pièce automatique n'autorise pas la validation -----#
    If GNUMPCE="" & [F:PIH]AMTATI<>0
      Call ECR_TRACE([F:PIH]NUM-mess(272,199,1),1) From GESECRAN
      WNBPCE = 1
      GOK = 0
      Rollback : Return
    Endif
    #----- Màj de la table des liens et chargement de la liste des pièces créées -----#
    Raz WNUMEROS
    NBRVCR= find("",TMESSA(1..dim(TMESSA)))
    For INDVCR=1 To NBRVCR-1
      Call LNKGRP("1",[F:PIH]NUM,[F:PIH]ACCNUM,TMESSA(INDVCR),WRETOUR,WMESSAGE) From VALGRP
      If WRETOUR
        GOK = 0 : Break
      Elsif WNUMEROS=""
        WNUMEROS=WMESSAGE
      Else
        WNUMEROS+=","-WMESSAGE
      Endif
    Next
    If GOK=0  Rollback : Return : Endif
    #----- Etalement des prestations -----#
    If WACTFLG="KIT"
      Call PARAM([F:PIH]FCY,"ITAPRE",PARAM2) From ADOVAL
      GLOCITAPRE=val(PARAM2)
      If GLOCITAPRE>0  GLOCITAPRE-=1 : Endif
    Else
      Raz GLOCITAPRE
    Endif
    #-----
    If GLOCITAPRE
      #----- Recherche code pièce auto -----#
      Call PARAM([F:PIH]FCY,"GAUKIK4",WPCEAUTO) From ADOVAL
      If WPCEAUTO=""  WPCEAUTO="KIK4" : Endif
      #-----
      Call TRANSFERT(WPCEAUTO,[F:PIH]NUM,[F:PIH]PIVTYP,WRETOUR) From CPTTRS
      If GOK<0
        Goto ROLL_TR1
      Elsif !GOK | WRETOUR
        Call ECR_TRACE([F:PIH]NUM-GMESSAGE,1) From GESECRAN
        WNBPCE = 1
        GOK = 0
        Rollback : Return
      Endif
    Endif
    #-----
    If GMODU(14)=2 : # Présence du module Immobilisation
      #-----------------------#
      # Dépense immobilisable #
      #-----------------------#
      Call CREDEP("PIH", WMESSAGE) From SUBLOF2
      If GOK = 0
        Call ECR_TRACE(WMESSAGE,1) From GESECRAN
        Rollback : Return
      Endif
    Endif
    #------ Imputation des règlements acomptes à la facture -----#
    If [F:PIH]PIHTYP=1
      Call TRT_ACOMPTES(-1,2,[F:PIH]AMTATI) From SUBPIHC : # Suppression affectation acomptes
      If GOK=-1   Goto ROLL_TR1   : Endif
      If GOK=0  Rollback : Return : Endif
      #-----
      Call TRT_ACOMPTES( 1,2,[F:PIH]AMTATI) From SUBPIHC : # Réaffectation des acomptes
      If GOK=-1   Goto ROLL_TR1   : Endif
      If GOK=0  Rollback : Return : Endif
      #--- Variables pour le Call IMPUTE -----#
      Local Integer WREGNUM (50) : # ACCNUM du règlement
      Local Integer WREGLIG (50) : # DUDLIG du règlement (toujours 1)
      Local Decimal WMONTANT(50) : # Montant imputé
      Local Integer WNBECH       : # Nombre d'acomptes
      # Issue 83196 - 2012-07-09 by MUARN : nouveau call IMPUTE2
      Local Char    WPAYVCR (20) (0..49) : # réglement (clé de la pièce)

      #--- Variables pour màj montants réglés sur échéances commandes ---#
      Local Char    NUMCDE(GLONPOH)
      Local Integer LIGCDE, STAT
      Local Integer WERR               :   # 67451
      #--- Mise à jour montants réglés sur échéances commandes ---#
      For [PID] PID0 Where NUM=[F:PIH]NUM
        Raz NUMCDE, LIGCDE

        # Issue 88577 - 2013-04-11 by MUARN : annulation approbation BUO
        If func AFNC.ACTIV("GDD")
          Local Integer INDANA
          Call SETMAINREF([F:PIH]CPY,GTYPGEN,GTYPANA) From CPTDIV
          # Issue 106965 - 2015-03-13 by MUARN : ajout PIDLIN
          Filter [CAL] Where ABRFIC="PID" & VCRTYP=0 & VCRNUM=[F:PIH]NUM & VCRLIN=[PID]PIDLIN
          For [CAL]CAL0
            For INDANA=0 To dim([F:CAL]CCE)-1
              If [F:CAL]DIE(INDANA)="" : Break : Endif
              If [F:CAL]CCE(INDANA)<>""
                Call CTLCCE([F:CAL]CCE(INDANA),[F:CAL]DIE(INDANA),[F:PIH]FCY,[F:PIH]ACCDAT,0,
&                [F:CAL]DIE(INDANA),[F:CAL]CCE(INDANA),[F:CAL]COA(GTYPANA-1),[F:CAL]ACC(GTYPANA-1)) From SELCCE
              Endif
            Next
          Next
          Filter [CAL]
          If mkstat: GOK=0 : GERR=1 : Break : Endif
        Endif

        Case [F:PID]TYPORI
          When 1 : NUMCDE=[F:PID]NUMORI : LIGCDE=[F:PID]LINORI
          When 2 : Read [PTD] PTD0=[F:PID]NUMORI;[F:PID]LINORI
                   If fstat Raz [F:PTD] : Endif
                   NUMCDE=[F:PTD]POHNUM : LIGCDE=[F:PTD]POPLIN
        Endcase
        If NUMCDE<>""
          Filter [DUD] Where TYP="*PO" & NUM=NUMCDE & PAMTYP=2 & DINAMT>0 Order By Key DUD0
          For [DUD]
            #----- Si règlement d'acompte temporaire, pas de validation possible -----#
            If [F:DUD]TMPCUR<>0
              # Bug 67451
              # Au moins une étape de comptabilisation doit être passée
              WERR=1
              If GMODU(3) = 2   : # Présence du module tiers
                  WERR=0
                  For [PYD]PYD1 Where DUDNUM=[F:DUD]ACCNUM & DUDLIG=[F:DUD]DUDLIG
                      Read [PYH]PYH0=[F:PYD]NUM
                      If fstat | ([F:PYH]STAFLG(2)<>2  & ([F:PYH]STAFLG(7)<>2 | [F:PYH]STAFLG(8)<>2))
                          WERR=1 : Break
                      Endif
                  Next
              Endif
              If WERR
                # Bug 67451
                  Call ECR_TRACE(mess(824,196,1)-[F:DUD]TYP-[F:DUD]NUM,1) From GESECRAN
                  GOK=0 : Break : # Règlement d'acompte non validé *PO xxxxxxxxxx
              Endif
            Endif
            #-----
            If [F:DUD]DINAMT>[F:DUD]PAYCUR
              DUD_TYP   =[F:DUD]TYP
              DUD_NUM   =[F:DUD]NUM
              DUD_LIG   =[F:DUD]LIG
              DUD_DUDLIG=[F:DUD]DUDLIG
              Readlock [DUD] DUD0=DUD_TYP;DUD_NUM;DUD_LIG;DUD_DUDLIG
              If fstat=1
                GOK=-1 : GLOCK="$GACCDUDATE"-"*PO"-NUMCDE         : Break
              Elsif fstat
                GOK=0  : Call RSTA("DUD","*PO"+NUMCDE) From GLOCK : Break
              Endif
              If [F:DUD]DINAMT>[F:DUD]PAYCUR
                [F:DUD]PAYCUR=[F:DUD]DINAMT
              Endif
              #--- Conversion du Mt réglé ---#
              Call CONVERT([F:DUD]CUR,GLOCALDEV,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]RATDAT,
&                          [F:DUD]PAYCUR,[F:DUD]PAYLOC,STAT) From TRTDEV
#              Call CONVERT([F:DUD]CUR,GSYSCUR,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]RATDAT,
#&                          [F:DUD]PAYCUR,[F:DUD]PAYRPT,STAT) From TRTDEV
              #---
              Call SLDECH("DUD")From MODECHE
              Rewrite [DUD]
              If fstat GOK=0 : Call FSTA("DUD") From GLOCK : Break : Endif
              Call HISTOECH("DUD",1,[F:PIH]ACCDAT)From MODECHE
            Endif
          Next
          Filter [DUD]
          If GOK<1 Break : Endif
        Endif
      Next
      If GOK=-1   Goto ROLL_TR1   : Endif
      If GOK=0  Rollback : Return : Endif
      #--- Effacement des montants réglés sur échéances facture car màj par IMPUTE ---#
      For [DUD] DUD0 Where TYP=[F:PIH]GTE & NUM=[F:PIH]NUM & CPY=[F:PIH]CPY & CUR=[F:PIH]CUR
        DUD_TYP   =[F:DUD]TYP
        DUD_NUM   =[F:DUD]NUM
        DUD_LIG   =[F:DUD]LIG
        DUD_DUDLIG=[F:DUD]DUDLIG
        Readlock [DUD] DUD0=DUD_TYP;DUD_NUM;DUD_LIG;DUD_DUDLIG
        If fstat=1
          GOK=-1 : GLOCK="$GACCDUDATE"-[F:PIH]GTE-[F:PIH]NUM         : Break
        Elsif fstat
          GOK=0  : Call RSTA("DUD",[F:PIH]GTE+[F:PIH]NUM) From GLOCK : Break
        Endif
        Raz [F:DUD]PAYCUR, [F:DUD]PAYLOC : #, [F:DUD]PAYRPT
        Call SLDECH("DUD")From MODECHE
        Rewrite [DUD]
        If fstat GOK=0 : Call FSTA("DUD") From GLOCK : Break : Endif
        Call HISTOECH("DUD",1,[F:PIH]ACCDAT)From MODECHE
      Next
      If GOK=-1   Goto ROLL_TR1   : Endif
      If GOK=0  Rollback : Return : Endif
      #----- Imputation des règlements acomptes à la facture -----#
      Raz WREGNUM, WREGLIG, WMONTANT, WNBECH
      For [PYO] PYO0 Where DUDNUM=[F:PIH]ACCNUM
        WREGNUM (WNBECH)=[F:PYO]PAYNUM
        WREGLIG (WNBECH)=1                 : # =1 au lieu de =[F:PYO]DUDLIG
        WMONTANT(WNBECH)=[F:PYO]DUDPAYAMT
        WPAYVCR (WNBECH)=[F:PYO]PAYVCR # Issue 83196 - 2012-07-09 by MUARN : appel IMPUTE2
        WNBECH+=1
        If WNBECH>49 Break : Endif
      Next
      If WNBECH>0
        # Issue 83196 - 2012-07-09 by MUARN : nouvelle fonction IMPUTE2
        #Call IMPUTE([F:PIH]ACCNUM,WREGNUM,WREGLIG,WMONTANT,WNBECH) From IPTACPT
        Call IMPUTE2([F:PIH]ACCNUM,WREGNUM,WREGLIG,WMONTANT,WNBECH,WPAYVCR) From IPTACPT
        If GOK=-1   Goto ROLL_TR1   : Endif
        If GOK=0
          Call ECR_TRACE(GMESSAGE,1) From GESECRAN
          Rollback : Return
        Endif
      Endif
    Else

      Raz WNUMORI # Issue 94252 - 2013-11-22 by MUARN : lettrage avoir
      # Issue 88577 - 2013-04-11 by MUARN : annulation approbation BUO
      For [PID] PID0 Where NUM=[F:PIH]NUM

        # Issue 94252 - 2013-11-22 by MUARN : lettrage avoir
        If ([F:PID]TYPORI = 4 & WNUMORI="") & [F:PIH]PIHTYP=3
          WNUMORI=[F:PID]NUMORI
        Elsif ([F:PID]TYPORI =4 & WNUMORI <> [F:PID]NUMORI) & [F:PIH]PIHTYP=3
          Raz WNUMORI
        Elsif [F:PID]TYPORI < 4 & [F:PIH]PIHTYP=3
          Raz WNUMORI
        Endif

        If func AFNC.ACTIV("GDD")
          Local Integer INDANA
          Call SETMAINREF([F:PIH]CPY,GTYPGEN,GTYPANA) From CPTDIV
          # Issue 106965 - 2015-03-13 by MUARN : ajout PIDLIN
          Filter [CAL] Where ABRFIC="PID" & VCRTYP=0 & VCRNUM=[F:PIH]NUM & VCRLIN=[PID]PIDLIN
          For [CAL]CAL0
            For INDANA=0 To dim([F:CAL]CCE)-1
              If [F:CAL]DIE(INDANA)="" : Break : Endif
              If [F:CAL]CCE(INDANA)<>""
                Call CTLCCE([F:CAL]CCE(INDANA),[F:CAL]DIE(INDANA),[F:PIH]FCY,[F:PIH]ACCDAT,0,
&                [F:CAL]DIE(INDANA),[F:CAL]CCE(INDANA),[F:CAL]COA(GTYPANA-1),[F:CAL]ACC(GTYPANA-1)) From SELCCE
              Endif
            Next
          Next
          Filter [CAL]
          If mkstat: GOK=0 : GERR=1 : Break : Endif
        Endif
      Next
      If GOK=0  Rollback : Return : Endif

    Endif
  Endif
  #-----
  WNBPCE=1
  #-----
  If GMODU(3)=2 : # Présence du module tiers
    #-----------------------------#
    # Lettrage facture et avoir   #
    #-----------------------------#
    If [F:PIH]INVNUM<>""
      Call LETAVOIR([F:PIH]NUM,[F:PIH]INVNUM) From SUBBIS
    # Issue 94252 - 2013-11-22 by MUARN : rapprochement sans INVNUM renseigné mais toutes les lignes sur meme facture
    Elsif WNUMORI <> "" & [F:PIH]PIHTYP=3
      Call LETAVOIR([F:PIH]NUM, WNUMORI) From SUBBIS
    Endif
  Endif

  #-----------------------------#
  # mise à jour solde comptable #
  # fait dans le module compta  #
  #-----------------------------#

  #-------------------------------------------------#
  # mise à jour du montant facturé non comptabilisé #
  # il faut décrémenter ce montant                  #
  #-------------------------------------------------#
  Local Integer STAT, WIFFTYP
  Local Decimal WINVAMT
  Call DEFSITE([F:PIH]FCY) From TRTACHDEF1
  WINVAMT=-[F:PIH]AMTATI*(3-(2*[F:PIH]INVTYP))
  WIFFTYP=[F:PIH]INVTYP+5
  Call MAJENC_BPS([F:PIH]BPR,WIFFTYP,[F:PIH]FCY,[F:PIH]CUR,[F:PIH]CURTYP,[F:PIH]ACCDAT,
&                 [F:PIH]NUM,0,WINVAMT,[F:PIH]AMTATI) From TRTBPMVT

  #----------------------------------#
  # Régul de prix  pas de simulation #
  # dans le cas article géré en stock#
  # et si article de sous traitance  #
  #----------------------------------#
  # Issue 82703 - 2013-02-05 by SR : Pour toutes les factures normales et les factures complémentaires si Maj coût = OUI
  Call MAJ_REACSTPUR From TRTACHFAC1
  If GOK<1 Rollback : Return : Endif
  Call REGPRIX(WTRANSAC) From TRTACHFAC1
  If GOK<1 Rollback : Return : Endif
  #--------------------------------------------------------#
  # Désengagement : Le module compta doit être présent     #
  # Pas de désengagement pour les factures complémentaires #
  #--------------------------------------------------------#
  If [F:PIH]PIHTYP<>2 & GMODU(2)=2
     Call BUDGET(WTRANSAC,WMESSAGE) From TRTACHFAC1
     If GOK<1 Rollback : Return : Endif
  Endif
  #85785
  If func PORLEGLIB.DIGSIGNPIH("", [F:PIH]CPY,[F:PIH]PIVTYP)
    # ----------------------------------------------------------- #
    # -- RMA * DKS Activity code related. Sign Document.          #
    # ----------------------------------------------------------- #
    If func AFNC.ACTIV("DKS")
        Local Char DKSORIG(3): DKSORIG = "PUR"
        Local Integer DKSRET : DKSRET  = 1
        Local Integer ORI    : ORI     = 1
        Gosub DKS_SIGN_TRIGGER From DKSLIB
        If DKSRET = 0 : GOK = 0 : Endif
    Endif
    # ----------------------------------------------------------- #
  Endif
  #--------------------------------------------------------#
  #  MAJ statut + la qté en unité oeuvre (voir plus haut)  #
  #--------------------------------------------------------#
  [F:PIH]STA = 3
  If dim([F:PIH]UPDDAT)>0  [F:PIH]UPDDAT=date$     : Endif
  If dim([F:PIH]UPDTIM)>0  [F:PIH]UPDTIM=time      : Endif
  If dim([F:PIH]UPDUSR)>0  [F:PIH]UPDUSR=GUSER     : Endif
  If dim([F:PIH]EXPNUM)>0  [F:PIH]EXPNUM=[C]EXPORT : Endif
  #----- Point d'entrée MAJVALPIH pour màj champs spécifiques lors de la validation -----#
  GPOINT="MAJVALPIH" : Gosub ENTREE From EXEFNC
  If GOK=0  Rollback : Return : Endif
  If GOK<0  Goto ROLL_TR1     : Endif
  #-----
  Rewrite [PIH]
  If fstat
       GOK = 0 : Call FSTA("PIH") From GLOCK
       Rollback : Return
  Endif
  #----- Mise à jour statistiques entête facture -----#
  Call VALSTA("PIH",1) From SUBPS2 : If GOK<1  Rollback : Return : Endif
  #----- Mise à jour statistiques lignes facture -----#
  Filter [PID] Where NUM=[F:PIH]NUM
  For [PID]
    Call VALSTA("PID",1) From SUBPS2 : If GOK<1 Break : Endif
  Next
  Filter [PID]
  If GOK<1 Rollback : Return : Endif
  #----- La validation s'est bien passée, écriture de la trace des pièces créées -----#
  If GTRACE<>""
    Call ECR_TRACE(mess(120,150,1)-mess(742,197,1)-[F:PIH]NUM,0) From GESECRAN
  Endif
  Call ECR_TRACE(mess(40,107,1)-WNUMEROS,0) From GESECRAN
  #-----
Commit
Return

$ROLL_TR1
Rollback
Call ROLL From GLOCK
If GROLL : Return : Else : Goto TR1 : Endif
Return


##########################################################################################
#   Traitement des budgets (désengagements)                                              #
##########################################################################################
Subprog BUDGET(WTRANSAC,WMESSAGE)
Value    Char WTRANSAC
Variable Char WMESSAGE
#----- Test présence du module compta -----#
If GMODU(2)<>2 | GOPTCANA<1  End : Endif
#----- Variables locales -----#
Local Integer  STAT,       WSIGN
Local Char     WPOHNUM(GLONPOH)
Local Integer  WPOPLIN
Local Integer  WPOQSEQ
#----- Ouverture des fichiers si nécessaire -----#
If !clalev([F:POH])  Local File PORDER    [POH] : Endif
If !clalev([F:POP])  Local File PORDERP   [POP] : Endif
If !clalev([F:POQ])  Local File PORDERQ   [POQ] : Endif
If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif
If !clalev([F:TB0])  Local File PORDER    [TB0] : Endif
If !clalev([F:TB1])  Local File PORDERQ   [TB1] : Endif
If !clalev([F:TB2])  Local File CPTANALIN [TB2] : Endif
#----- Boucle de lecture sur les lignes de la facture -----#
For [PID] PID0 Where NUM=[F:PIH]NUM
  # Issue 83801 - 2012-07-27 by SR : Possibilité de ne pas lancer la mise à jour des budgets
  #  Gosub MAJ_BUDGET : If GOK<1 Break : Endif
     GPE = 1
     [V]GPOINT="CUSMAJCMM" : Gosub ENTREE From EXEFNC
     If GPE
        Gosub MAJ_BUDGET : If GOK<1 Break : Endif
     Endif
Next
End

##########################################################################################
#   Appel pour mise à jour des budgets (désengagements)                                  #
#   QTYBUDLIN = qte facturee +- qté reliquat                                             #
##########################################################################################
$MAJ_BUDGET
If [F:PID]QTYBUDLIN=0 Return : Endif : # Qté à désengagée nulle
If [F:PID]ITMREF=""   Return : Endif : # Ligne diverse sans référence article
If [F:PID]TYPORI=1
  #----- Origine ligne : commande facturée -----#
  WPOHNUM = [F:PID]POHNUM
  WPOPLIN = [F:PID]POPLIN
  WPOQSEQ = [F:PID]POQSEQ
Elsif [F:PID]TYPORI=2
  #----- Origine ligne : réception facturée -----#
  If clalev([F:PTD])=0  Local File PRECEIPTD [PTD] : Endif
  #----- Lecture réception détail puis récupération de la commande -----#
  Read [PTD] PTD0=[F:PID]PTHNUM;[F:PID]PTDLIN
  If fstat Raz [F:PTD] : Return : Endif
  WPOHNUM = [F:PTD]POHNUM
  WPOPLIN = [F:PTD]POPLIN
  WPOQSEQ = [F:PTD]POQSEQ
Elsif [F:PID]TYPORI=4
  #----- Origine ligne : facture (avoir/facture) -----#
  If clalev([F:PID2])=0 Local File PINVOICED [PID2] : Endif
  Read [PID2] PID0=[F:PID]INVNUM;[F:PID]INVLIN
  If fstat Raz [F:PID2] : Return : Endif
  If [F:PID2]TYPORI>2  Return : Endif
  If [F:PID2]TYPORI=1 : # Avoir sur ligne facture origine commande
    WPOHNUM = [F:PID2]POHNUM
    WPOPLIN = [F:PID2]POPLIN
    WPOQSEQ = [F:PID2]POQSEQ
  Else                : # Avoir sur ligne facture origine réception
    If clalev([F:PTD])=0  Local File PRECEIPTD [PTD] : Endif
    Read [PTD] PTD0=[F:PID2]PTHNUM;[F:PID2]PTDLIN
    If fstat Raz [F:PTD] : Return : Endif
    WPOHNUM = [F:PTD]POHNUM
    WPOPLIN = [F:PTD]POPLIN
    WPOQSEQ = [F:PTD]POQSEQ
  Endif
  If WPOHNUM=""   Return : Endif        : # Si pas de numéro de cde  alors c'est fini !
  Read [POQ] POQ0=WPOHNUM;WPOPLIN;WPOQSEQ
  If fstat Raz [F:POQ] : Return : Endif
  # Issue 94968/95376 - 2013-12-17 by MUARN : commande soldée
  # il faut regarder s'il existe une réception, car il faut peut-être réengager.
  #If [F:PID]PRIREN>=0 & [F:POQ]LINCLEFLG=2  Return : Endif : # Si ligne commande soldée alors c'est fini !
  If [F:POQ]LINCLEFLG=2
    # si la commande est soldée recherche s'il existe une réception de la commande non soldée
    If [F:PID2]TYPORI=1
      If !clalev([F:PTD3]) Local File PRECEIPTD  [PTD3] : Endif
      Local Integer MAJ_CMM : MAJ_CMM = 1
      For [PTD3] Where POHNUM=[F:POQ]POHNUM
&                    & POPLIN=[F:POQ]POPLIN
&                    & POQSEQ=[F:POQ]POQSEQ
        # il existe une réception non soldée il faut réengager
        If [F:PTD3]LININVFLG=1 : MAJ_CMM = 2 : Break : Endif
      Next
      # aucune réception non soldée, pas de mise à jour des engagements
      If MAJ_CMM = 1 : Return : Endif
    Else
      # la réception est soldée, on ne réengage pas
      If [F:PTD]LININVFLG=2 : Return : Endif
    Endif
  Endif
Else
  #----- Origine ligne : ni commande, ni réception, ni avoir/facture
  Return
Endif
If WPOHNUM = "" : Return : Endif        : # Si pas de numéro de cde alors c'est fini !
#----- Lecture détail commande -----#
Read [POH] POH0=WPOHNUM
If fstat Raz [F:POH] : Return : Endif
[F:TB0]=[F:POH]
Read [POQ] POQ0=WPOHNUM;WPOPLIN;WPOQSEQ
If fstat Raz [F:POQ] : Return : Endif
[F:TB1]=[F:POQ]
#----- Commande classique -----#
If [F:POH]POHTYP<>2
  Read [POP] POP0=WPOHNUM;WPOPLIN;1
  If fstat Raz [F:POP] : Return : Endif
#----- Commande ouverte -----#
Else
  Filter [POP] Where POHNUM=WPOHNUM & POPLIN=WPOPLIN & POPDAT>=[F:POQ]DEMRCPDAT
  Read [POP] POP1 First
  Filter [POP]
  If fstat Raz [F:POP] : Return : Endif
Endif
#-----
Read [CAL] CAL0="POP";0;WPOHNUM;WPOPLIN;[F:POP]POPSEQ;"";1
If fstat  Raz [F:CAL] : Endif
[F:TB2]=[F:CAL]
#-----
If [F:PIH]PIHTYP>2 WSIGN=+1 Else WSIGN=-1 : Endif
If WTRANSAC="!#DEVALIDE"
  WSIGN=-WSIGN          : # Inversion signe si dévalidation comptable
  Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,WSIGN,2,"PID1",3,STAT) From TRTACHDIV1
Else
  Call TRTMAJCMM([F:POQ]POHNUM,[F:POQ]POPLIN,[F:POQ]POQSEQ,WSIGN,2,"PID",3,STAT) From TRTACHDIV1
Endif
If !STAT  WNBPCE=1 : Endif
Return

#################################################################
# Issue 82703 - 2013-02-05 by SR : Maj coût achat de la commande#
#################################################################
Subprog MAJ_REACSTPUR
# Issue 82703 - 2012-10-04 by SR : Pour les FCC sur commande
Local Decimal WMNT
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
Local Char    WPOHNUM(GLONVCR),WSHIPNUM(GLONVCR)
Local Integer WPOPLIN,WPOQSEQ, WRET, WORI,WSHIPLIN
If clalev([F:PND2]) = 0 : Local File PRETUNRD  [PND2] : Endif
If clalev([F:PID2]) = 0 : Local File PINVOICED [PID2] : Endif
# Issue 89349-7 - 2013-12-16 by SR : Gérer les avoirs sur FCC
If clalev([F:PIH2]) = 0 : Local File PINVOICE   [PIH2] : Endif
# Issue 110325 - 2016-01-11 by SR : FCC sur expé
If clalev([F:SHD]) = 0 : Local File SHIPMENTD   [SHD] : Endif

# Si facture normale ou si facture complémentaire et CSTMAJLIN = OUI
# Issue 89348-7 - 2013-12-16 by SR : Gérer les avoirs sur FCC
For [PID] PID0 Where NUM=[F:PIH]NUM & LINTYP=1
  # Issue 89349-7 - 2013-12-16 by SR : Gérer les avoirs sur FCC
  # si avoir sur facture : relire la facture pour savoir si il s'agit d'une FCC
  If [F:PIH]PIHTYP = 3 & [F:PID]TYPORI = 4
     If [F:PIH2]NUM <> [F:PID]NUMORI
      Read [F:PIH2]PIH0 = [F:PID]NUMORI
      If fstat : Raz [F:PIH2] : Endif
    Endif
  Endif
  #
  # Si facture normale ou avoir sur retour
  # ou FCC nouveau cout
  # ou avoir sur facture normale
  # ou avoir sur FCC et nouveau cout
  If find([F:PIH]PIHTYP,1,4)
&   | ([F:PIH]PIHTYP = 2 &  [F:PID]CSTMAJLIN = 2)
&   | ([F:PIH]PIHTYP = 3 &  [F:PIH2]PIHTYP=1)
&   | ([F:PIH]PIHTYP = 3 &  [F:PIH2]PIHTYP=2 & [F:PID]CSTMAJLIN = 2)
    # Y-a-t-il une ligne de commande à mettre à jour ?
    Raz WPOHNUM, WPOPLIN, WPOQSEQ
        # Issue 110325 - 2016-01-11 by SR : FCC sur expédition
        Case [F:PIH]PIHTYP
          When 1 :                            # Facture
             WPOHNUM = [F:PID]POHNUM
             WPOPLIN = [F:PID]POPLIN
             WPOQSEQ = [F:PID]POQSEQ
          When 2 :                            # Facture complémentaire
            Case [F:PID]TYPORI
                  When 1,2 :                  # Origine Commande ou Réception
                    WPOHNUM = [F:PID]POHNUM
                    WPOPLIN = [F:PID]POPLIN
                    WPOQSEQ = [F:PID]POQSEQ
                  When 4   :                  # Origine Facture
                    Read [F:PID2]PID0 = [F:PID]NUMORI;[F:PID]LINORI
                    If !fstat
                      WPOHNUM = [F:PID2]POHNUM
                      WPOPLIN = [F:PID2]POPLIN
                      WPOQSEQ = [F:PID2]POQSEQ
                    Endif
                  When 6   :                  # Origine  expéditiion
                    Read [F:SHD]SHD0 = [F:PID]NUMORI;[F:PID]LINORI
                    If !fstat
                      WPOHNUM = [F:SHD]POHNUM
                      WPOPLIN = [F:SHD]POPLIN
                      WPOQSEQ = [F:SHD]POQSEQ
                      WSHIPNUM= [F:PID]NUMORI
                      WSHIPLIN= [F:PID]LINORI
                    Endif
             Endcase
           When 3 :                           # Avoir
                    Read [F:PID2]PID0 = [F:PID]NUMORI;[F:PID]LINORI
                    If !fstat
                      WPOHNUM = [F:PID2]POHNUM
                      WPOPLIN = [F:PID2]POPLIN
                      WPOQSEQ = [F:PID2]POQSEQ
                      # Issue 110325 - 2016-01-11 by SR : FCC et avoirs sur FCC sur expé
                      If [F:PID2]TYPORI = 6
                         WSHIPNUM= [F:PID2]NUMORI
                         WSHIPLIN= [F:PID2]LINORI
                      Endif
                    Endif
           When 4 :                           # Avoir sur retour
                    Read [F:PND2]PND0 = [F:PID]PNHNUM;[F:PID]PNDLIN
                    If !fstat
                      WPOHNUM = [F:PND2]POHNUM
                      WPOPLIN = [F:PND2]POPLIN
                      WPOQSEQ = [F:PND2]POQSEQ
                    Endif
        Endcase
        # Si il y a une ligne de commande à mettre à jour, il faut passer LINCSTPUR (-LINCPSPUR pour les avoirs)
        If  WPOHNUM <> ""
            WMNT = [F:PID]LINCSTPUR
            If [F:PIH]PIHTYP > 2
                WMNT *= -1
            Endif
            Raz WRET
            Call MAJ_REACSTPUR(WPOHNUM,WPOPLIN,WPOQSEQ,WMNT,WRET) From STCCLC
            If WRET
                #Problème de mise à jour du coût d'achat réalisé
                GMESSAGE = mess(795,197,1)
                Call ECR_TRACE([F:PID]NUM+"/"+num$([F:PID]PIDLIN)-GMESSAGE,1) From GESECRAN
                GOK = 0
                Break
            Endif
            # Fi FCC sur commande, et si des réceptions ont été créées depuis la création de la FCC
            # et ligne soldée on lance la regul de stock
            # Issue 95710 - 2014-01-09 by SR : A faire aussi si avoir sur FCC sur commande
            If ([F:PIH]PIHTYP = 2 & [F:PID]TYPORI = 1) |
&              ([F:PIH]PIHTYP = 3 &  [F:PIH2]PIHTYP=2 & [F:PID2]TYPORI = 1)
               Read [F:POQ]POQ0 = WPOHNUM;WPOPLIN;WPOQSEQ
               If!fstat & [F:POQ]RCPQTYSTU <> 0 & [F:POQ]LINCLEFLG = 2
                  WORI = 1
                  Call REGPRIX_FCC(WORI,"",0)
                  If GOK<1 : End : Endif
                  #----- Relecture article de la ligne en cours de traitement si nécessaire -----#
                  If [F:ITM]ITMREF<>[F:PID]ITMREF
                    Read [ITM] ITM0=[F:PID]ITMREF : If fstat Raz [F:ITM] : Endif
                  Endif
               Endif
            Endif
            # Issue 110325 - 2016-01-11 by SR : FCC sur expé
            # Fi FCC sur expé , et si des réceptions ont été créées depuis la création de la FCC
            # et ligne soldée on lance la regul de stock
            # A faire aussi si avoir sur FCC sur expé
            If ([F:PIH]PIHTYP = 2 & [F:PID]TYPORI=6) |
&              ([F:PIH]PIHTYP = 3 &  [F:PIH2]PIHTYP=2 & [F:PID2]TYPORI=6)
               Read [F:SHD]SHD0 = WSHIPNUM;WSHIPLIN
               If!fstat & [F:SHD]RCPQTYSTU <> 0 & [F:SHD]CLEFLG = 2
                  Read [F:POQ]POQ0 = WPOHNUM;WPOPLIN;WPOQSEQ
                  If !fstat
                    WORI = 4
                    Call REGPRIX_FCC(WORI,"",0)
                    If GOK<1 : End : Endif
                    #----- Relecture article de la ligne en cours de traitement si nécessaire -----#
                    If [F:ITM]ITMREF<>[F:PID]ITMREF
                      Read [ITM] ITM0=[F:PID]ITMREF : If fstat Raz [F:ITM] : Endif
                    Endif
                  Endif
               Endif
            Endif
            # End issue 110325
        Endif
    Endif
Next
End

########################################################
# Régularisation des prix dans les mouvements de stock #
########################################################
Subprog REGPRIX(WTRANSAC)
Value Char     WTRANSAC
#----- Variables locales -----#
Local Char     WFCY    (GLONFCY)
Local Char     WITMREF (GLONITM)
Local Date     WIPTDAT
Local Integer  WVCRTYP
Local Char     WVCRNUM (GLONVCR), WVCRNUM2(GLONVCR)
Local Integer  WVCRLIN, WVCRLIN2
Local Decimal  WQTY,WPRI,WPRIORI, WMT, WNETPRI, WQTYRES, WQTYSTU2
Local Integer  WRET, STAT, WTYP
Local Char     WNUMORI (GLONVCR), WTRSCOD(GLONADI)
Local Integer  WLINORI
Local Decimal  SAV_QTYSTU
Local Decimal  WRATCUR
Local Shortint WI
Local Integer I : # Issue 79861 - 2012-02-20 by VPO
Local Decimal  WINVDTACST
Local Integer WINVDTACSTPTD : # Issue 79861 - 2012-02-20 by VPO
Local Decimal WDISCRGVAL, WDISCRGAMT, WTAXE, WCOURS, WMT, WRND # Issue 121029 - 2017-01-25 by MUARN : sous-traitance sans OF frais/remise et élément de facturation, taxes

#-----
If !clalev([F:POQ])  Local File PORDERQ   [POQ]  : Endif
If !clalev([F:PTH])  Local File PRECEIPT  [PTH]  : Endif
If !clalev([F:PTD])  Local File PRECEIPTD [PTD]  : Endif
If !clalev([F:PID2]) Local File PINVOICED [PID2] : Endif
If !clalev([F:STJ])  Local File STOJOU    [STJ]  : Endif
# Issue 77116 - 2011-10-14 by SR
If clalev([F:SJV]) = 0 : Local File STOJOUVAL  [SJV] : Endif
# Issue 83162 - 2012-07-02 by MUARN
If clalev([F:PFI]) = 0 : Local File PFOOTINV   [PFI] : Endif
# Issue 89349 - 2013-11-25 by SR : Rapprochement
If clalev([F:STCR]) = 0 : Local File COSTSTCR  [STCR] : Endif
# Issue 89349-7 - 2013-12-16 by SR : Gérer les avoirs sur FCC
If clalev([F:PIH2]) = 0 : Local File PINVOICE   [PIH2] : Endif
# Issue X3-73378 - 2018-01-25 by SR : Avoir en valeur et SST
If clalev([F:PID3]) = 0 : Local File PINVOICED  [PID3] : Endif

#-----
Read [PIV] PIV0=[F:PIH]NUM : If fstat  Raz [F:PIV] : Endif
If [F:PIV]BETCPY=2 & [F:PIV]SIHNUM<>""
  If !clalev([F:SIV])  Local File SINVOICEV [SIV] : Endif
  Read [SIV] SIV0=[F:PIV]SIHNUM : If fstat  Raz [F:SIV] : Endif
  If [F:SIV]SIHORI=9
    If !clalev([F:SGH])  Local File SCHGH     [SGH] : Endif
    If !clalev([F:SGD])  Local File SCHGD     [SGD] : Endif
  Endif
Endif
#-----
# FQ 70864 GA 02/2011
If GMODU(8)=2 | [F:PID]LINTYP>1
  If clalev([M:SBCK])=0 Local Mask SBCK  [SBCK] : Endif
Endif

# FQ 70864 GA 02/2011 sous-traitance EO prix saisi sur les lignes [F:PID]LINTYP=3 ou 4
#----- Lecture des lignes détails facture -----#
#For [PID] PID0 Where NUM=[F:PIH]NUM & LINTYP<3
# Issue 82703 - 2013-02-05 by SR :
# Issue 89349 - 2013-11-25 by SR : Rapprochement
#For [PID] PID0 Where NUM=[F:PIH]NUM & LINTYP<>2 & ([F:PIH]PIHTYP <> 2 |([F:PID]TYPORI <> 1 & [F:PID]CSTMAJLIN = 2))
For [PID] PID0 Where NUM=[F:PIH]NUM & LINTYP<>2
  # Issue 89349-7 - 2013-12-16 by SR : Gérer les avoirs sur FCC
  # si avoir sur facture : relire la facture pour savoir si il s'agit d'une FCC
  If [F:PIH]PIHTYP = 3 & [F:PID]TYPORI = 4
     If [F:PIH2]NUM <> [F:PID]NUMORI
      Read [F:PIH2]PIH0 = [F:PID]NUMORI
      If fstat : Raz [F:PIH2] : Endif
     Endif
     # Issue X3-112305 - 2018-11-15 by SR : Relire aussi la ligne de facture car on se sert de PID2 TYPORI
     If [F:PID2]NUM <> [F:PID]NUMORI | [F:PID2]PIDLIN <> [F:PID]LINORI
        Read [F:PID2]PID0 = [F:PID]NUMORI;[F:PID]LINORI
        If fstat : Raz [F:PID2] : Endif
     Endif
  Endif
  # Si pas facture complémentaire ou facture complémentaire sur rcp/fact et CSTMAJLIN = OUI
  # Issue 89349-7 - 2013-12-16 by SR : Gérer les avoirs sur FCC
  #If [F:PIH]PIHTYP <> 2 |([F:PID]TYPORI <> 1 & [F:PID]CSTMAJLIN = 2)
  #
  # Si facture ou avoir sur retour
  # ou (FCC sur rcp/Fac et CSTMAJLIN =2)
  # ou avoir sur facture normale
  # ou avoir sur FCC sur rcp/Fac et CSTMAJLIN =2)
  # Issue 110325 - 2016-01-11 by SR :FCC sur expé : tester aussi TYPORI ) 6
  # Issue X3-112305 - 2018-11-15 by SR : Gérer l'annulation comptable des FCC sur cde/Expé :Ajout tests de WTRANSAC
  If find([F:PIH]PIHTYP,1,4)
&    | ([F:PIH]PIHTYP = 2 & !find([F:PID]TYPORI,1,6) & [F:PID]CSTMAJLIN = 2)
&    | ([F:PIH]PIHTYP = 3 & [F:PIH2]PIHTYP=1)
&    | ([F:PIH]PIHTYP = 3 & [F:PIH2]PIHTYP =  2 & !find([F:PID2]TYPORI,1,6) & [F:PID]CSTMAJLIN = 2)
&    | (WTRANSAC="!#DEVALIDE")
    If [F:PID]ITMREF<>""
      Read [ITM] ITM0=[F:PID]ITMREF : If fstat  Raz [F:ITM] : Endif
      # Issue X3-112305 - 2018-11-15 by SR : Gérer l'annulation des FCC/Avoirs sur FCC sur commande/Expé
      If WTRANSAC = ("!#DEVALIDE")
&       & (([F:PIH]PIHTYP = 2 & find([F:PID]TYPORI,1,6) & [F:PID]CSTMAJLIN = 2)
&       | ([F:PIH]PIHTYP = 3 & [F:PIH2]PIHTYP =  2 & find([F:PID2]TYPORI,1,6) & [F:PID]CSTMAJLIN = 2))
        # WTRANSAC inconnu de REGPRIX_FCC, on passe une valeur particulière dans ORI
        # annulation d'une FCC sur cde ou d'un avoir sur FCC sur cde
        If ([F:PIH]PIHTYP = 2 & [F:PID]TYPORI = 1) | ([F:PIH]PIHTYP = 3 & [F:PID2]TYPORI = 1)
          Call REGPRIX_FCC(90,"",0)
        # annulation d'une FCC sur expé ou d'un avoir sur FCC sur expé
        Else
          Call REGPRIX_FCC(91,"",0)
        Endif
        # End issue X3-112305
      #----- Si article géré en stock ou facture de sous-traitance -----#
      # Issue 71362 - 2011-04-18 by CCC : si matière fournie par sous-traitant, màj wipcost
      # Issue 116523 - 2016-05-18 by MUARN : Ajout avoir
      # Issue X3-112305 - 2018-11-15 by SR : Elsif à la place de Else
      Elsif [F:ITM]STOMGTCOD>1 | [F:ITM]SCSFLG=2 | ([F:PID]PIHTYP=2 & [F:PID]TYPORI<>5)
&     | [F:PID]LINTYP=4 | ([F:PID]PIHTYP=3 & [F:PID]TYPORI<>5)
        Case [F:PID]TYPORI
          When 1 : Gosub LECT_CDE     : # Origine Commande
          When 2 : If [F:PID]PIHTYP=2
                     Gosub LECT_RCPFC : # Origine Réception (facture complémentaire)
                   Else
                     Gosub LECT_RCP   : # Origine Réception (facture classique)
                   Endif
          When 3 : Gosub LECT_RETOUR  : # Origine Retour
          When 4 : Gosub LECT_FACTURE : # Origine Facture
          When 5
            If [F:PIV]BETCPY=2 & [F:PIV]SIHNUM<>"" & [F:SIV]SIHORI=9
                   Gosub LECT_CHGSTO  : # Origine Divers (Transferts inter-sociétés)
            Endif
        Endcase
        If GOK<>1  Break : Endif
      Endif
    Endif
  # Issue 89349-7 - 2013-12-16 by SR : Gérer les avoirs sur FCC
  # Facture complémentaire ou avoir, CSTMAJLIN = NON et charge renseignée
  Elsif find([F:PIH]PIHTYP,2,3)   &  [F:PID]CSTMAJLIN = 1 & [F:PID]FCSCOD <> ""
      Gosub ECR_COSTSTCR
    If GOK<>1  Break : Endif
  Endif
  #$NEXT_PID
  # Issue X3-51860 - 2017-09-08 by MUARN : mise à jour cout achat sur article site
  # Issue X3-112305 - 2018-11-15 by SR : Pas en annulation de facture
  If [F:PIH]PIHTYP = 1 & find([F:PID]TYPORI,1,2) & [F:PID]QTYUOM <> 0 & WTRANSAC <> ("!#DEVALIDE")
    Read [ITV]ITV0=[F:PID]ITMREF;[F:PID]FCYLIN
    If !fstat & [F:PID]ACCDAT>=[F:ITV]LASPURDAT
      [F:ITV]LASPURPRI=[F:PID]CSTPUR
      [F:ITV]LASPURDAT=[F:PID]ACCDAT
      Call REWITV From STKLIB
    Endif
  Endif
Next
End

$ECR_COSTSTCR
Raz [F:STCR]
[F:STCR] = [F:PID]
[F:STCR]CUR = [F:PID]NETCUR
# Issue 89349-7 - 2013-12-16 by SR : Gérer les avoirs sur FCC
# Issue 110325 - 2016-01-11 by SR : FCC sur expé TYPORI = 6
Case [F:PIH]PIHTYP :
  When 2 # FCC
      Case [F:PID]TYPORI :
          When 1 : Read [F:POQ]POQ0 = [F:PID]NUMORI;[F:PID]LINORI;[F:PID]SEQORI
                   If !fstat : [F:STCR]ITMREFORI = [F:POQ]ITMREF : Endif
          When 2 : Read [F:PTD]PTD0 = [F:PID]NUMORI;[F:PID]LINORI
                   If !fstat : [F:STCR]ITMREFORI = [F:PTD]ITMREF : Endif
          When 6 : Read [F:SHD]SHD0 = [F:PID]NUMORI;[F:PID]LINORI
                   If !fstat : [F:STCR]ITMREFORI = [F:SHD]ITMREF : Endif
      Endcase
  When 3 # Avoir sur FCC
      If [F:PID2]NUM <> [F:PID]NUMORI | [F:PID2]PIDLIN <> [F:PID]LINORI
         Read [F:PID2]PID0 = [F:PID]NUMORI;[F:PID]LINORI
         If fstat : Raz [F:PID2] : Endif
      Endif
      [F:STCR]TYPORI     = [F:PID2]TYPORI
      [F:STCR]NUMORI     = [F:PID2]NUMORI
      [F:STCR]LINORI     = [F:PID2]LINORI
      [F:STCR]SEQORI     = [F:PID2]SEQORI
      [F:STCR]AMTNOTLIN = -[F:PID]AMTNOTLIN
      Case [F:PID2]TYPORI :
          When 1 : Read [F:POQ]POQ0 = [F:PID2]NUMORI;[F:PID2]LINORI;[F:PID2]SEQORI
                   If !fstat : [F:STCR]ITMREFORI = [F:POQ]ITMREF : Endif
          When 2 : Read [F:PTD]PTD0 = [F:PID2]NUMORI;[F:PID2]LINORI
                    If !fstat : [F:STCR]ITMREFORI = [F:PTD]ITMREF : Endif
          When 6 : Read [F:SHD]SHD0 = [F:PID2]NUMORI;[F:PID2]LINORI
                   If !fstat : [F:STCR]ITMREFORI = [F:SHD]ITMREF : Endif
      Endcase
Endcase
# End issue 110325
Write [F:STCR]
If fstat GOK=0 : Call FSTA("STCR") From GLOCK : Endif
Return
# End issue 89349

#------------------------------------------------------#
# Appel du sous-programme de régularisation des stocks #
#------------------------------------------------------#
$REGUL_PRI
# Issue 95354 GA 02/2014 pas de regul d'entrée si pas de réception
If clalev([F:PTD2]) > 0
  If find([F:PTD2]VCRTYPORI,10,36) & [F:PTD2]LINTYP>2 Return Endif
Endif
# Issue 95354 GA 12/2013 pas de regul d'entrée si pas de mvt de stock
If clalev([F:PTD]) > 0
  If find([F:PTD]VCRTYPORI,10,36) & [F:PTD]LINTYP>2 Return Endif
Endif
If [F:PID]LINTYP>2 Return Endif

If WQTY<>0
  WMT=arr(WPRI*WQTY,10^-8)
Else
  # Issue 78027 - 2011-11-25 by VPO : DLR: Régule entrée facture qté inférieure à la reception
  #WMT=WPRI
  WMT=arr(WPRI,10^-8)
Endif
#----- Impression paramètres du Call si trace détaillée -----#
If GSTOTRACE>2
  Call ECR_TRACE("-- Call REGPRIX  From STKVALREG",0)       From GESECRAN
  Call ECR_TRACE("   PFCY    ="-WFCY,0)                     From GESECRAN
  Call ECR_TRACE("   PTRSTYP ="-num$(WTYP),0)               From GESECRAN
  Call ECR_TRACE("   PITM    ="-WITMREF,0)                  From GESECRAN
  Call ECR_TRACE("   PIPTDAT ="-num$([F:PIH]ACCDAT),0)      From GESECRAN
  Call ECR_TRACE("   PTRSCOD ="-num$(WTRSCOD),0)            From GESECRAN
  Call ECR_TRACE("   PVCRTYP ="-num$(WVCRTYP),0)            From GESECRAN
  Call ECR_TRACE("   PVCRNUM ="-WVCRNUM,0)                  From GESECRAN
  Call ECR_TRACE("   PVCRLIN ="-num$(WVCRLIN),0)            From GESECRAN
  Call ECR_TRACE("   PTYPREG = 17",0)                       From GESECRAN
  Call ECR_TRACE("   PNUMREG ="-[F:PID]NUM,0)               From GESECRAN
  Call ECR_TRACE("   PLINREG ="-num$([F:PID]PIDLIN),0)      From GESECRAN
  Call ECR_TRACE("   PNEWAMT ="-num$(WMT),0)                From GESECRAN
  Call ECR_TRACE("   PQTY    ="-num$(WQTY),0)               From GESECRAN
  # Issue 79861 - 2012-02-20 by VPO : elt de facturation non valorisés en stock
  If GACTDECCST
  Call ECR_TRACE("   PINVDTA ="-num$(WINVDTACST),0)         From GESECRAN
  Endif
  Call ECR_TRACE("   PRET    ="-num$(WRET),0)               From GESECRAN
  Call ECR_TRACE("----------------------------",0)          From GESECRAN
Endif
If !clalev([M:SDP]) : Local Mask SAIDECPRI [SDP] : Endif
Raz [M:SDP]

#--- Point d'entrée CGHREGVAL pour modifier le montant de valorisation stock ---#
#-------------------------------------------------------------------------------#
GPOINT="CHGREGVAL" : Gosub ENTREE From EXEFNC

# Issue 78027 - 2011-11-25 by VPO : DLR: Régule entrée facture qté inférieure à la reception
#[M:SDP]PRI    = WPRI
[M:SDP]QTY    = WQTY

# Issue 113362 - 2016-01-05 by MUARN : élément de facturation et devise
If [F:PID]CPRCUR <> [F:PIH]CUR
    Local   Decimal  WINVDTACST_DEV, WCOURS
    WINVDTACST_DEV = WINVDTACST
    Call CONVERT_PIH(WINVDTACST_DEV,WINVDTACST)
Endif

[M:SDP]AMTTOT = WMT
If GACTDECCST
    [M:SDP]INVDTACST = WINVDTACST
    [M:SDP]MATCST([F:ITM]BRDCOD-1) = [M:SDP]AMTTOT-[M:SDP]INVDTACST
Endif
# CCC (14/02/05) Bug 28345 : Utilisation devise société dans la valeur du lot => passer le taux de conversion
If [F:PIH]RATDIV(0)<>0 & [F:PIH]RATMLT(0)<>0
  # Issue 89349-4-5 - 2014-01-31 by SR : Ne pas passer de pièce de régul dans le cas du rapprochement
  If find([F:PIH]PIHTYP,2,3) & [F:PID]CSTMAJLIN = 1 & [F:PID]FCSCOD <> ""
    # Issue number 109768 - 2016-02-11 by STLIG : always pass the Accounting date ...
    Call REGPRIX (WFCY,WTYP,WITMREF,[F:PIH]ACCDAT,WTRSCOD,WVCRTYP,WVCRNUM,WVCRLIN,
&                 0,"",0,1,WRET) From STKVALREG
  Else
    # Issue number 109768 - 2016-02-11 by STLIG : always pass the Accounting date ...
    Call REGPRIX (WFCY,WTYP,WITMREF,[F:PIH]ACCDAT,WTRSCOD,WVCRTYP,WVCRNUM,WVCRLIN,
&                 17,[F:PID]NUM,[F:PID]PIDLIN,1,WRET) From STKVALREG
  Endif
Else
    WRET=6
Endif
If WRET=2     : # Aucun mouvement trouvé pour la régularisation des prix
  Call ECR_TRACE([F:PID]NUM-num$([F:PID]PIDLIN)-[F:PID]ITMREF-mess(215,197,1),1) From GESECRAN
Elsif WRET<>0 : # Erreur sur la régularisation des prix
  Call ECR_TRACE([F:PID]NUM-num$([F:PID]PIDLIN)-[F:PID]ITMREF-mess(519,197,1)-"("+num$(WRET)+")",1) From GESECRAN
Endif
Return


#------------------------#
# Lecture de la commande #
#------------------------#
$LECT_CDE
Read [POQ] POQ0=[F:PID]POHNUM;[F:PID]POPLIN;[F:PID]POQSEQ
If !fstat
  SAV_QTYSTU=[F:PID]QTYSTU
  #----- Boucle sur les réceptions jusqu'à concurrence de la qté facturée -----#
  For [PTD] PTD2 Where POHNUM=[F:POQ]POHNUM
&                    & POPLIN=[F:POQ]POPLIN
&                    & POQSEQ=[F:POQ]POQSEQ
    Gosub LECT_RCP : If GOK<>1  Break : Endif
    [F:PID]QTYSTU-=[F:PTD]QTYSTU
    If [F:PID]QTYSTU<=0 : Break : Endif
  Next
  [F:PID]QTYSTU=SAV_QTYSTU # Issue 89563 GA 05/2013
Endif
Return


#------------------------------------------------#
# Lecture et traitement à partir de la réception #
# ---------------------------------------------- #
# Cas des factures complémentaires sur réception #
#------------------------------------------------#
$LECT_RCPFC
Read [PTD] PTD0=[F:PID]PTHNUM;[F:PID]PTDLIN
If fstat  Raz [F:PTD] : Return : Endif
#----- Lecture entête réception si ,nécessaire -----#
If [F:PTH]PTHNUM<>[F:PTD]PTHNUM
  Read [PTH] PTH0=[F:PTD]PTHNUM : If fstat  Raz [F:PTH] : Endif
Endif
#----- Lecture de l'article de la ligne d'origine -----#
If [F:ITM]ITMREF<>[F:PTD]ITMREF
  Read [ITM] ITM0=[F:PTD]ITMREF : If fstat  Raz [F:ITM] : Endif
Endif
#----- Article géré en stock ou sous-traitance -----#
# Issue 99967 GA 06/2014 added | [F:PID]LINTYP>=2 in case of EO
If [F:ITM]STOMGTCOD>1 | [F:ITM]SCSFLG=2 | [F:PID]LINTYP>=2
  WFCY   =[F:PTD]PRHFCY
  WITMREF=[F:PTD]ITMREF
  #----- Récupération date en fonction du paramètre ACCDATSTK -----#
  If func AFNC.PARAM("ACCDATSTK",WFCY)="2"
    WIPTDAT=[F:PIH]ACCDAT
  Else
    WIPTDAT=[F:PTD]RCPDAT
  Endif
  #-----
  WVCRTYP=6
  WVCRNUM=[F:PTD]PTHNUM
  WVCRLIN=[F:PTD]PTDLIN

  If [F:PID]LINTYP>2 & [F:PID]CPR=0    # Issue 99967 GA 06/2014 [F:PID]CPR is null, as credit invoice
     # Issue 121029 - 2017-01-25 by MUARN : les frais/remise et éléments de facturation valorisés en stock doivent être prix en compte
     #If [F:PID]QTYSTU<>0
     #   WPRI = [F:PID]AMTNOTLIN / [F:PID]QTYSTU
     #Else
     #   WPRI = [F:PID]AMTNOTLIN
     #Endif
     #WQTY = 0
     # Check currency because using [F:PID]AMTNOTLIN
     #If WPRI<>0 & [F:PID]CPRCUR<>[F:PIH]CUR  # need to convert calculated amount ?
# Issue 102605 GA 12/2014 replaced [F:PTH]CHGTYP,[F:PTH]RCPDAT,
#         Local Integer WSTAT
#         Call CONVERT2([F:PIH]CUR,[F:PID]CPRCUR,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]RATDAT,
#&                  WPRI,WPRI,WSTAT) From TRTDEV
     #    Call CONVERT_PIH(WPRI,WPRI)
     #Endif
     # calcul du CPR ligne service et matière de la facture
     Gosub CAL_CPR_PID
     WQTY = 0
     # End issue 121029
  Else
     WQTY   =0
     WPRI   =[F:PID]CPR : # C'est bien le delta en montant et non unitaire !
  Endif

  # Issue 79861 - 2012-02-20 by VPO : elt de facturation non valorisés en stock
  #WINVDTACST=sigma(WI=1,9,evalue("[F:PID]DISCRGAMT"+num$(WI)))
  Raz WINVDTACST
  For I=1 To 9
    If [F:PIV]INVDTALIN2(I-1)<>0
      Read [PFI] PFI0=[F:PIV]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
      If [F:PFI]NPRVLT=2
        WINVDTACST+=evalue("[F:PID]DISCRGAMT"+num$(I))
      Endif
    Endif
  Next I


  #----- Article géré en stock -----#
  If !find([F:PTD]VCRTYPORI,10,36) & [F:ITM]SCSFLG<>2 & [F:PID]LINTYP<>4 # Issue 95354 GA 12/2013
    If WTRANSAC="!#DEVALIDE"  WPRI=-WPRI : Endif
    WTYP=3 : Gosub REGUL_PRI
  Else
  #----- Sous-traitance -----#
    If WTRANSAC="!#DEVALIDE"  WPRI=-WPRI : Endif
    # Issue 89807 GA 05/2013 si et seulement si OF ou EO, ne pas tester uniquement [F:ITM]SCSFLG=2
    If clalev([M:SBCK]) & find([F:PTD]VCRTYPORI,10,36)
      # Issue X3-63103 - 2017-11-16 by MUARN : Pas de quantité en FCC
      # Issue 121029 - 2017-05-09 by MUARN : Calcul de WNETPRI
#      Call PCAL_QTY([F:PID]QTYPUU,[F:PID]PUU,GBIDD1,[F:PTD]STU,
#&                 [F:PID]ITMREF,[F:PID]BPSNUM,1,GBIDD3) From TRTACHQTE1
#      If GBIDD3=0 GBIDD3=1 : Endif
#      #----- Prix net exprimé en unité de stock -----#
#      If [F:PID]UOMPUUCOE=0  [F:PID]UOMPUUCOE=1 : Endif
#
#      If [F:PID]QTYUOM <> 0
#        WNETPRI=[F:PID]NETPRI/([F:PID]UOMPUUCOE*GBIDD3)
#      Else
#        WNETPRI = [F:PID]AMTNOTLIN
#      Endif
      WNETPRI = [F:PID]AMTNOTLIN
      # End issue X3-63103
      #----- Prix net exprimé en devise société -----#
      WI=find(GLOCALDEV,[F:PIH]CURLED)
      If WI & [F:PIH]RATDIV(WI-1)<>0
        WRATCUR=[F:PIH]RATMLT(WI-1)/[F:PIH]RATDIV(WI-1)
      Else
        WRATCUR=0
      Endif
      If WRATCUR=0
        Call CONVERT2([F:PIH]CUR,GCUR,GCUR,[F:PIH]CURTYP,[F:PIH]RATDAT,WNETPRI,WNETPRI,
&                   STAT) From TRTDEV
      Else
        WNETPRI=WNETPRI*WRATCUR
      Endif
      #-----
      WNETPRI = arr(WNETPRI,10^-8)
      # End issue 121029
      # Issue X3-63103 - 2017-11-27 by MUARN : Gestion annulation comptable
      If WTRANSAC="!#DEVALIDE"  WNETPRI=-WNETPRI : Endif
      Raz [M:SBCK]                    # Issue 105321 GA 03/2015
      [M:SBCK]MAJCOD = "F"
      [M:SBCK]RCPDAT = WIPTDAT
      [M:SBCK]ITMREF = [F:ITM]ITMREF   # FQ 70864 GA 02/2011 avant WITMREF  # FQ 56565 GA 07/2009
      [M:SBCK]PTHNUM = WVCRNUM
      [M:SBCK]PTDLIN = WVCRLIN
      [M:SBCK]VCRNUM = [F:PTD]POHNUM   # FQ 56565 GA 07/2009
      [M:SBCK]VCRLIN = [F:PTD]POPLIN   # FQ 56565 GA 07/2009
      If dim([M:SBCK]LINTYP)>0 [M:SBCK]LINTYP = [F:PTD]LINTYP Endif  # FQ 76147 GA 09/2011
      [M:SBCK]INVQTY = WQTY
      # Issue 121029 - 2017-01-25 by MUARN : les frais/remise et éléments de facturation valorisés en stock doivent être prix en compte
      #[M:SBCK]CPLPRI = WPRI
      #[M:SBCK]CPLCRG = 0
      [M:SBCK]CPLPRI = WNETPRI
      [M:SBCK]CPLCRG = WPRI - WNETPRI
      # End issue 121029
      # Issue X3-67828 - 2017-12-11 by SR: conversion du montant des éléments de facturation en devise société
      If [F:PID]CPRCUR <> [F:PIH]CUR
         Local   Decimal  WINVDTACST_DEV, WCOURS
         WINVDTACST_DEV = WINVDTACST
         Call CONVERT_PIH(WINVDTACST_DEV,WINVDTACST)
      Endif
      [M:SBCK]INVDTACST = WINVDTACST
      [M:SBCK]MSGFLG = 1
      [M:SBCK]ITMREFORI = [F:PTD]ITMREFORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRTYPORI = [F:PTD]VCRTYPORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRNUMORI = [F:PTD]VCRNUMORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRLINORI = [F:PTD]VCRLINORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRSEQORI = [F:PTD]VCRSEQORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      Raz GMESSAGE
      Call MAJ_SBC From SBCLIB
      If [M:SBCK]CODRET<>0
        Gosub SBCK_ERROR  # Issue 109433 by GA 09/2015
      Endif
    Endif
  Endif
Endif
#----- Relecture article de la ligne en cours de traitement si nécessaire -----#
If [F:ITM]ITMREF<>[F:PID]ITMREF
  Read [ITM] ITM0=[F:PID]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
Return


#------------------------------------------------#
# Lecture et traitement à partir de la réception #
#------------------------------------------------#
$LECT_RCP
#--- Isue 84130 by TS
Local Decimal WINVQTYSTU

If [F:ITM]ITMREF<>[F:PID]ITMREF
  Read [ITM] ITM0=[F:PID]ITMREF : If fstat  Raz [F:ITM] : Endif
Endif
If [F:PID]TYPORI=2
  Read [PTD] PTD0=[F:PID]PTHNUM;[F:PID]PTDLIN
  If fstat  Return : Endif
Endif
If [F:PTH]PTHNUM<>[F:PTD]PTHNUM
  Read [PTH] PTH0=[F:PTD]PTHNUM : If fstat  Raz [F:PTH] : Endif
Endif
WTRSCOD=[F:PTH]TRSCOD
#----- Article non géré en stock et non sous-traitance, pas de régul ! -----#
# Issue 71362 - 2011-04-18 by CCC : si matière fournie par sous-traitant, màj wipcost
#If [F:PTD]STOMGTCOD<2 & [F:ITM]SCSFLG<>2 & [F:PID]TYPORI<>4 & [F:PID]LINTYP<>4
If !find([F:PTD]VCRTYPORI,10,36) & [F:PTD]STOMGTCOD<2 & [F:PID]TYPORI<>4 # Issue 95354 GA 12/2013
  Return
Endif
#----- Pas de régul si prix réception = prix facture -----# Appel systématique !!
#If [F:PTD]CPR<>[F:PID]CPR |
#&  [F:ITM]SCSFLG=2        |
#& ([F:PID]PRTFLG=1 & [F:PTD]QTYSTU<>[F:PTD]INVQTYSTU)
  WFCY    = [F:PTD]PRHFCY
  WITMREF = [F:PTD]ITMREF
  #----- Récupération date en fonction du paramètre ACCDATSTK -----#
  If func AFNC.PARAM("ACCDATSTK",WFCY)="2"
    WIPTDAT=[F:PIH]ACCDAT
  Else
    WIPTDAT=[F:PTD]RCPDAT
  Endif
  #-----
  WVCRTYP = 6
  WVCRNUM = [F:PTD]PTHNUM
  WVCRLIN = [F:PTD]PTDLIN
  #--- Isue 84130 by TS
  #If [F:PID]QTYSTU > [F:PTD]QTYSTU
  #   WQTY = [F:PTD]QTYSTU
  #Else
  #   WQTY = [F:PID]QTYSTU
  #Endif
  If [F:PID]TYPORI=1
    # Quantité facturée sur la réception (issue de factures sur commandes)
    WINVQTYSTU = [F:PTD]INVQTYSTU
    For [PID2]PID1 Where TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI=[F:PTD]PTDLIN
      WINVQTYSTU -= min([F:PID2]QTYSTU,[F:PTD]QTYSTU)
    Next
    # La quantité facturée pour cette réception est le minimum entre :
    # - la quantité de la facture que l'on valide
    # - la quantité de la réception
    # - la quantité facturée sur la réception (issue de factures sur commandes)
    WQTY = min([F:PID]QTYSTU,[F:PTD]QTYSTU,WINVQTYSTU)
  Else
    WQTY = min([F:PID]QTYSTU,[F:PTD]QTYSTU)
  Endif
  #---
  If [F:PID]LINTYP>2 & [F:PID]CPR=0    # Issue 99967 GA 06/2014 [F:PID]CPR is null
     # Issue 121029 - 2017-01-25 by MUARN : les frais/remise et éléments de facturation valorisés en stock doivent être prix en compte
     #If [F:PID]QTYSTU<>0
     #   WPRI = [F:PID]AMTNOTLIN / [F:PID]QTYSTU
     #Else
     #   WPRI = [F:PID]AMTNOTLIN
     #Endif
     #WPRIORI = [F:PTD]NETPRI           # Issue 100967 GA 06/2014
     # Check currency because using [F:PID]AMTNOTLIN
     #If WPRI<>0 & [F:PID]CPRCUR<>[F:PIH]CUR  # need to convert calculated amount ?
         # Issue 102605 GA 12/2014 replaced
#         Local Integer WSTAT
#         Call CONVERT2([F:PIH]CUR,[F:PID]CPRCUR,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]RATDAT,
#&                  WPRI,WPRI,WSTAT) From TRTDEV
#         Call CONVERT2([F:PIH]CUR,[F:PID]CPRCUR,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]RATDAT,
#&                  WPRIORI,WPRIORI,WSTAT) From TRTDEV
     #    Call CONVERT_PIH(WPRI,WPRI)
     #    Call CONVERT_PIH(WPRIORI,WPRIORI)
     #Endif

     # calcul du CPR ligne service et matière de la facture
     Gosub CAL_CPR_PID
     # calcul du CPR ligne service et matière de la réception
     Gosub CAL_CPR_PTD
     # End issue 121029
  Else
     WPRI = [F:PID]CPR
     WPRIORI = [F:PTD]CPR
  Endif
  # Issue 79861 - 2012-02-20 by VPO : elt de facturation non valorisés en stock
  #WINVDTACST = sigma(WI=1,9,evalue("[F:PID]DISCRGAMT"+num$(WI)))
  Raz WINVDTACST
  For I=1 To 9
    If [F:PIV]INVDTALIN2(I-1)<>0
      Read [PFI] PFI0=[F:PIV]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
      If [F:PFI]NPRVLT=2
        WINVDTACST+=evalue("[F:PID]DISCRGAMT"+num$(I))
      Endif
    Endif
  Next I
  #----- Si facturation partielle et solde réception -----#
  # Issue 78027 - 2011-11-25 by VPO : DLR: Régule entrée facture qté inférieure à la reception
  # Il faut 2 cas, 1 pour la surfacturation, un cas sinon
  #If [F:PID]TYPORI=2 & [F:PID]PRTFLG=1 & [F:PTD]QTYSTU<>[F:PTD]INVQTYSTU
  If [F:PID]TYPORI=2 & [F:PID]PRTFLG=1 & [F:PTD]QTYSTU<[F:PTD]INVQTYSTU
    Raz GBIDD1
    Columns [PID2] (QTYSTU)
    For [PID2] PID1 Where TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI=[F:PTD]PTDLIN
      GBIDD1+=[F:PID2]QTYSTU
    Next
    Columns [PID2]
    WQTY=[F:PID]QTYSTU+[F:PTD]QTYSTU-GBIDD1-[F:PTD]RTNQTYSTU
    If WQTY<=0  WQTY=1 : Endif
    WPRI   =[F:PID]CPR
    WPRIORI=[F:PTD]CPR
   #WQTY=[F:PID]QTYSTU+[F:PTD]QTYSTU-[F:PTD]INVQTYSTU-[F:PTD]RTNQTYSTU
   #If WQTY<=0  WQTY=1 : Endif
   #WPRI   =arr([F:PID]CPR*[F:PID]QTYSTU/WQTY,10^-8)
   #WPRIORI=arr([F:PTD]CPR*[F:PID]QTYSTU/WQTY,10^-8)

  # Issue 78027 - 2011-11-25 by VPO : DLR: Régule entrée facture qté inférieure à la reception
  # ajout du cas hors sur-facturation
  # Issue 122064 - 2017-05-24 by MUARN : ne pas faire si aucune quantité sur facture
  Elsif [F:PID]TYPORI=2 & [F:PID]PRTFLG=1 & [F:PTD]QTYSTU<>[F:PTD]INVQTYSTU & [F:PID]QTYSTU<>0
    Raz GBIDD1
    Columns [PID2] (QTYSTU)
    For [PID2] PID1 Where TYPORI=2 & NUMORI=[F:PTD]PTHNUM & LINORI=[F:PTD]PTDLIN
      GBIDD1+=[F:PID2]QTYSTU
    Next
    Columns [PID2]
    WQTY=[F:PID]QTYSTU+[F:PTD]QTYSTU-GBIDD1-[F:PTD]RTNQTYSTU
    If WQTY<=0  WQTY=1 : Endif
    # Issue 78027 - 2011-11-25 by VPO : DLR: Régule entrée facture qté inférieure à la reception
    #WPRI   =arr([F:PID]CPR*[F:PID]QTYSTU/WQTY,10^-8)
    #WPRIORI=arr([F:PTD]CPR*[F:PID]QTYSTU/WQTY,10^-8)
    WPRI   =[F:PID]CPR*[F:PID]QTYSTU/WQTY
    WPRIORI=[F:PTD]CPR*[F:PID]QTYSTU/WQTY
  Endif
  #-----
  #Cas particulier: Facturation/Réception de sous-traitance
  # Issue 71362 - 2011-04-18 by CCC : si matière fournie par sous-traitant, màj wipcost
  #If [F:ITM]SCSFLG<>2 & [F:PID]LINTYP<>4
  If !find([F:PTD]VCRTYPORI,10,36) & [F:ITM]SCSFLG<>2 & [F:PID]LINTYP<>4 # Issue 95354 GA 12/2013
    #----- Article géré en stock -----#
    If WTRANSAC="!#DEVALIDE"
     #WPRI=WPRIORI
      If WQTY<>0
        WPRI=(WPRIORI-WPRI)*WQTY : WQTY=0
      Else
        WPRI=(WPRIORI-WPRI)
      Endif
    Endif
    WTYP=3 : Gosub REGUL_PRI
  Else
    # Issue 78027 - 2011-11-25 by VPO : DLR: Régule entrée facture qté inférieure à la reception
    WPRI = arr(WPRI,10^-8)
    WPRIORI = arr(WPRIORI,10^-8)
    #----- Sous-traitance -----#
    Call PCAL_QTY([F:PID]QTYPUU,[F:PID]PUU,GBIDD1,[F:PTD]STU,
&                 [F:PID]ITMREF,[F:PID]BPSNUM,1,GBIDD3) From TRTACHQTE1
    If GBIDD3=0 GBIDD3=1 : Endif
    #----- Prix net exprimé en unité de stock -----#
    If [F:PID]UOMPUUCOE=0  [F:PID]UOMPUUCOE=1 : Endif
    WNETPRI=[F:PID]NETPRI/([F:PID]UOMPUUCOE*GBIDD3)
    #----- Prix net exprimé en devise société -----#
    WI=find(GLOCALDEV,[F:PIH]CURLED)
    If WI & [F:PIH]RATDIV(WI-1)<>0
      WRATCUR=[F:PIH]RATMLT(WI-1)/[F:PIH]RATDIV(WI-1)
    Else
      WRATCUR=0
    Endif
    If WRATCUR=0
      Call CONVERT2([F:PIH]CUR,GCUR,GCUR,[F:PIH]CURTYP,[F:PIH]RATDAT,WNETPRI,WNETPRI,
&                   STAT) From TRTDEV
    Else
      WNETPRI=WNETPRI*WRATCUR
    Endif
    #-----
    # Issue 121029 - 2017-05-18 by MUARN : ne pas faire
    #If WNETPRI=0
    #  WNETPRI = WPRI
    #Else
    #  WNETPRI = arr(WNETPRI,10^-8)
    #Endif
    WNETPRI = arr(WNETPRI,10^-8)
    If WTRANSAC="!#DEVALIDE"
      If WQTY=0 WNETPRI=-WNETPRI : WPRI=-WPRI Else WQTY=-WQTY : Endif
    Endif
    #----- Régularisation des prix sous-traitance -----#
    # Issue 89807 GA 05/2013 si et seulement si OF ou EO, ne pas tester uniquement [F:ITM]SCSFLG=2
    If clalev([M:SBCK]) & find([F:PTD]VCRTYPORI,10,36)
      Raz [M:SBCK]                    # Issue 105321 GA 03/2015
      [M:SBCK]MAJCOD = "F"
      [M:SBCK]RCPDAT = [F:PTD]RCPDAT
      [M:SBCK]ITMREF = [F:ITM]ITMREF   # FQ 70864 GA 02/2011 avant WITMREF  # FQ 56565 GA 07/2009
      [M:SBCK]PTHNUM = WVCRNUM
      [M:SBCK]PTDLIN = WVCRLIN
      [M:SBCK]VCRNUM = [F:PTD]POHNUM   # FQ 56565 GA 07/2009
      [M:SBCK]VCRLIN = [F:PTD]POPLIN   # FQ 56565 GA 07/2009
      If dim([M:SBCK]LINTYP)>0 [M:SBCK]LINTYP = [F:PTD]LINTYP Endif  # FQ 76147 GA 09/2011
      [M:SBCK]INVQTY = WQTY
      [M:SBCK]CPLPRI = WNETPRI
      # Issue 121029 - 2017-01-25 by MUARN : les frais/remise et éléments de facturation valorisés en stock doivent être prix en compte
      #If WPRI<>0                       # FQ 70864 GA 04/2011 sauf si pas de prix de revient
      #   [M:SBCK]CPLCRG = WPRI - WNETPRI
      #Elsif WQTY<>0
      #  # Issue 81304 - 2012-06-06 by CCC
      #   # CPLPRI doit correspondre au prix total
      #   [M:SBCK]CPLPRI = arr((WNETPRI*WQTY+WINVDTACST)/WQTY,10^-8)
      #Endif
      [M:SBCK]CPLCRG = WPRI - WNETPRI
      # End issue 121029
      # Issue X3-67828 - 2017-12-11 by SR: conversion du montant des éléments de facturation en devise société
      If [F:PID]CPRCUR <> [F:PIH]CUR
         Local   Decimal  WINVDTACST_DEV, WCOURS
         WINVDTACST_DEV = WINVDTACST
         Call CONVERT_PIH(WINVDTACST_DEV,WINVDTACST)
      Endif
      [M:SBCK]INVDTACST = WINVDTACST
      [M:SBCK]MSGFLG = 1
      [M:SBCK]ITMREFORI = [F:PTD]ITMREFORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRTYPORI = [F:PTD]VCRTYPORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRNUMORI = [F:PTD]VCRNUMORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRLINORI = [F:PTD]VCRLINORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRSEQORI = [F:PTD]VCRSEQORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      Raz GMESSAGE
      Call MAJ_SBC From SBCLIB
      If [M:SBCK]CODRET<>0
        Gosub SBCK_ERROR  # Issue 109433 by GA 09/2015
      Endif
    Endif
  Endif
#Endif
Return


#-------------------------------------------------------------#
# Lecture et traitement à partir du retour (Avoir sur retour) #
#-------------------------------------------------------------#
$LECT_RETOUR
If !clalev([F:PNH])  Local File PRETURN  [PNH] : Endif
If !clalev([F:PND])  Local File PRETURND [PND] : Endif
Read [PND] PND0=[F:PID]PNHNUM;[F:PID]PNDLIN
If fstat  Return : Endif
If [F:PNH]PNHNUM<>[F:PND]PNHNUM
  Read [PNH] PNH0=[F:PND]PNHNUM : If fstat  Raz [F:PNH] : Endif
Endif
WTRSCOD=[F:PNH]TRSCOD
#----- Article non géré en stock et non sous-traitance, pas de régul ! -----#
If [F:PND]STOMGTCOD<2 & [F:ITM]SCSFLG<>2 & [F:PID]TYPORI<>4
  Return
Endif
#-----
Filter [STJ] Where STOFCY=[F:PND]PNHFCY
&                & VCRTYP=8
&                & VCRNUM=[F:PND]PNHNUM
&                & VCRLIN=[F:PND]PNDLIN
&                & REGFLG<>2
Read [STJ] STJ1 First
If fstat
  Raz [F:STJ] : [F:STJ]PRIORD=[F:PND]CPR
Endif
Filter [STJ]
#-----
Read [SJV] SJV0=[F:STJ]STOFCY;[F:STJ]UPDCOD;[F:STJ]ITMREF;[F:STJ]IPTDAT;[F:STJ]MVTSEQ;[F:STJ]MVTIND
If fstat  Raz [F:SJV] : Endif
#----- Pas de régul si prix retour = prix facture -----#
# Issue X3-150207 - 2019-07-29 by SR : round the CPR value of the credit note
#If [F:STJ]PRIORD<>[F:PID]CPR | [F:ITM]SCSFLG=2
If [F:STJ]PRIORD<>arr([F:PID]CPR,10^-GDECPRI) | [F:ITM]SCSFLG=2
  Local Integer STAT
  Read [PTD] PTD0=[F:PND]PTHNUM;[F:PND]PTDLIN
  If fstat Raz [F:PTD] : Return : Endif
  WFCY   =[F:PND]PNHFCY
  WITMREF=[F:PND]ITMREF
  #----- Récupération date en fonction du paramètre ACCDATSTK -----#
  If func AFNC.PARAM("ACCDATSTK",WFCY)="2"
    WIPTDAT=[F:PIH]ACCDAT
  Else
    WIPTDAT=[F:PND]RTNDAT
  Endif
  #-----
  WVCRTYP=8
  WVCRNUM=[F:PND]PNHNUM
  WVCRLIN=[F:PND]PNDLIN
  If [F:PID]QTYSTU>[F:PND]QTYSTU
    WQTY=[F:PND]QTYSTU
  Else
    WQTY=[F:PID]QTYSTU
  Endif
  WPRI=arr(([F:STJ]PRIORD-[F:PID]CPR)*WQTY,10^-8)
  #WPRI=-arr([F:PID]CPR*WQTY,10^-GDECPRI)
  WQTY=0
  # Issue 79861 - 2012-02-20 by VPO : elt de facturation non valorisés en stock
  #WINVDTACST=[F:SJV]OINVDTATOT-sigma(WI=1,9,evalue("[F:PID]DISCRGAMT"+num$(WI)))
  Raz WINVDTACST
  For I=1 To 9
    If [F:PIV]INVDTALIN2(I-1)<>0
      Read [PFI] PFI0=[F:PIV]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
      If [F:PFI]NPRVLT=2
        WINVDTACST+=evalue("[F:PID]DISCRGAMT"+num$(I))
      Endif
    Endif
  Next I
  WINVDTACST=[F:SJV]OINVDTATOT-WINVDTACST

  #----- Article géré en stock -----#
  If !find([F:PTD]VCRTYPORI,10,36) & [F:ITM]SCSFLG<>2 & [F:PID]LINTYP<>4 # Issue 95354 GA 12/2013
    If WTRANSAC="!#DEVALIDE"
      If WQTY=0 WPRI=-WPRI Else WQTY=-WQTY : Endif
    Endif
    WTYP=11 : Gosub REGUL_PRI
  Else
    #----- Sous-traitance -----#
    Call PCAL_QTY([F:PID]QTYPUU,[F:PID]PUU,GBIDD1,[F:PND]STU,
&                 [F:PID]ITMREF,[F:PID]BPSNUM,1,GBIDD3) From TRTACHQTE1
    If GBIDD3=0 GBIDD3=1 : Endif
    #----- Prix net exprimé en unité de stock -----#
    If [F:PID]UOMPUUCOE=0 [F:PID]UOMPUUCOE=1 : Endif
    WNETPRI=[F:PID]NETPRI/([F:PID]UOMPUUCOE*GBIDD3)
    #----- Prix net exprimé en devise société -----#
    WI=find(GLOCALDEV,[F:PIH]CURLED)
    If WI & [F:PIH]RATDIV(WI-1)<>0
      WRATCUR=[F:PIH]RATMLT(WI-1)/[F:PIH]RATDIV(WI-1)
    Else
      WRATCUR=0
    Endif
    If WRATCUR=0
      Call CONVERT2([F:PIH]CUR,GCUR,GCUR,[F:PIH]CURTYP,[F:PIH]RATDAT,WNETPRI,WNETPRI,
&                   STAT) From TRTDEV
    Else
      WNETPRI=WNETPRI*WRATCUR
    Endif
    # Issue 121029 - 2017-05-18 by MUARN : ne pas faire
    #If WNETPRI=0
    #  WNETPRI=WPRI
    #Else
    #  WNETPRI=arr(WNETPRI,10^-8)
    #Endif
    WNETPRI = arr(WNETPRI,10^-8)
    # Issue X3-63103 - 2017-11-27 by MUARN : ajout WNETPRI
    If WTRANSAC="!#DEVALIDE"
      If WQTY=0 WPRI=-WPRI : WNETPRI=-WNETPRI Else WQTY=-WQTY : Endif
    Endif
    #----- Régularisation des prix sous-traitance -----#
    # Issue 89807 GA 05/2013 si et seulement si OF ou EO, ne pas tester uniquement [F:ITM]SCSFLG=2
    If clalev([M:SBCK]) & find([F:PTD]VCRTYPORI,10,36)
      Raz [M:SBCK]                    # Issue 105321 GA 03/2015
      [M:SBCK]MAJCOD = "F"
      [M:SBCK]RCPDAT = [F:PTD]RCPDAT
      [M:SBCK]ITMREF = [F:ITM]ITMREF   # FQ 70864 GA 02/2011 avant WITMREF  # FQ 56565 GA 07/2009
      [M:SBCK]PTHNUM = [F:PTD]PTHNUM
      [M:SBCK]PTDLIN = [F:PTD]PTDLIN
      [M:SBCK]VCRNUM = [F:PTD]POHNUM   # FQ 56565 GA 07/2009
      [M:SBCK]VCRLIN = [F:PTD]POPLIN   # FQ 56565 GA 07/2009
      If dim([M:SBCK]LINTYP)>0 [M:SBCK]LINTYP = [F:PTD]LINTYP Endif  # FQ 76147 GA 09/2011
      [M:SBCK]INVQTY = WQTY
      [M:SBCK]CPLPRI =-WPRI
      [M:SBCK]CPLCRG = 0
      # Issue X3-67828 - 2017-12-11 by SR: conversion du montant des éléments de facturation en devise société
      If [F:PID]CPRCUR <> [F:PIH]CUR
         Local   Decimal  WINVDTACST_DEV, WCOURS
         WINVDTACST_DEV = WINVDTACST
         Call CONVERT_PIH(WINVDTACST_DEV,WINVDTACST)
      Endif
      [M:SBCK]INVDTACST = WINVDTACST
      [M:SBCK]MSGFLG = 1
      [M:SBCK]ITMREFORI = [F:PTD]ITMREFORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRTYPORI = [F:PTD]VCRTYPORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRNUMORI = [F:PTD]VCRNUMORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRLINORI = [F:PTD]VCRLINORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRSEQORI = [F:PTD]VCRSEQORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      Raz GMESSAGE
      Call MAJ_SBC From SBCLIB
      If [M:SBCK]CODRET<>0
        Gosub SBCK_ERROR  # Issue 109433 by GA 09/2015
      Endif
    Endif
  Endif
Endif
Return


#------------------------------------------------------------------#
#        Lecture et traitement à partir de la facture              #
# ---------------------------------------------------------------- #
# Cas des avoirs sur facture                                       #
# Lecture de la facture pour savoir si avoir en montant ou en qtés #
# De même pour les factures complémentaires                        #
# On traite les avoirs sur factures complémentaires                #
#------------------------------------------------------------------#
$LECT_FACTURE
# On remonte sur la facture à l'origine de l'avoir
Read [PID2] PID0=[F:PID]INVNUM;[F:PID]INVLIN
If fstat  Return : Endif
#----- Si facture complémentaire, recherche facture d'origine -----#
If [F:PID2]PIHTYP=2 & [F:PID2]TYPORI=4 & [F:PID2]QTYSTU=0
  WNUMORI=[F:PID2]NUMORI
  WLINORI=[F:PID2]LINORI
  Read [PID2] PID0=WNUMORI;WLINORI
  If fstat Raz [F:PID2] : Return : Endif
Endif
# Issue 119586 - 2016-11-21 by SR
##----- Lecture de l'article de la ligne d'origine -----#
#If [F:ITM]ITMREF<>[F:PID2]ITMREF
#  Read [ITM] ITM0=[F:PID2]ITMREF : If fstat Raz [F:ITM] : Endif
#Endif
# La facture à l'origine de l'avoir est une facture normale
# ou c'était une FCC sur facture mais on est remonté sur la facture
# Dans ces 2 cas [PID2] contient une facture normale : on récupère son article
If [F:PID2]PIHTYP <> 2
   WITMREF = [F:PID2]ITMREF
Else # Facture à l'origine de l'avoir est une FCC sur réception(impossible que ce soit sur cde ou expé):
# Il faut remonter sur le document d'origine pour récupérer l'article
   Read [F:PTD]PTD0 = [F:PID2]NUMORI;[F:PID2]LINORI                # FCC sur réception
   If fstat : Raz [F:PTD] :   Else WITMREF = [F:PTD]ITMREF : Endif
Endif
  #----- Lecture de l'article de la ligne d'origine -----#
If [F:ITM]ITMREF<>WITMREF
  Read [ITM] ITM0=WITMREF : If fstat Raz [F:ITM] : Endif
Endif
# End issue 119586
#----- Si article géré en stock ou article sous-traitance -----#
# Issue 99967 GA 06/2014 added | [F:PID]LINTYP>=2 in case of EO
If [F:ITM]STOMGTCOD>1 | [F:ITM]SCSFLG=2 | [F:PID]LINTYP>=2
  Case [F:PID2]TYPORI
    When 1 : Gosub TRT_CDE2 : # Origine Commande
    When 2 : Gosub TRT_RCP2 : # Origine Réception
    When 3 :                : # Origine Retour  (Impossible)
    When 4 :                : # Origine Facture (Impossible)
    When 5 :                : # Origine Divers  (Pas de régul)
  Endcase
Endif
#----- Relecture article de la ligne en cours de traitement si nécessaire -----#
If [F:ITM]ITMREF<>[F:PID]ITMREF
  Read [ITM] ITM0=[F:PID]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
Return


#----------------------------------#
#      Lecture de la commande      #
# -------------------------------- #
# Cas des factures complémentaires #
#    et des avoirs sur commande    #
#----------------------------------#
$TRT_CDE2
Read [POQ] POQ0=[F:PID2]POHNUM;[F:PID2]POPLIN;[F:PID2]POQSEQ
If !fstat
  If [F:PIH]PIHTYP=2                     : # Facture complémentaire
    SAV_QTYSTU=[F:PID2]QTYSTU
  Elsif [F:PID]NETPRI=[F:PID]ORINETPRI & [F:PID]QTYSTU<>0 : # Avoir en qtés
    SAV_QTYSTU=[F:PID]QTYSTU
  Else                                   : # Avoir en valeur
    SAV_QTYSTU=[F:PID2]QTYSTU
  Endif
  #----- Boucle sur les réceptions jusqu'à concurrence de la qté facturée -----#
  Filter [PTD] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN & POQSEQ=[F:POQ]POQSEQ
&              Order By Key PTD2
  For [PTD]
    Gosub TRT_RCP2 : If GOK<>1 Break : Endif
    If [F:PIH]PIHTYP=2                   : # Facture complémentaire
      [F:PID2]QTYSTU-=[F:PTD]QTYSTU
      If [F:PID2]QTYSTU<=0 [F:PID2]QTYSTU=SAV_QTYSTU : Break : Endif
    Elsif [F:PID]NETPRI=[F:PID]ORINETPRI & [F:PID]QTYSTU<>0 : # Avoir en qtés
      [F:PID]QTYSTU -=[F:PTD]QTYSTU
      If [F:PID]QTYSTU <=0 [F:PID]QTYSTU =SAV_QTYSTU : Break : Endif
    Else                                 : # Avoir en valeur
      [F:PID2]QTYSTU-=[F:PTD]QTYSTU
      If [F:PID2]QTYSTU<=0 [F:PID2]QTYSTU=SAV_QTYSTU : Break : Endif
    Endif
  Next
  Filter [PTD]
Endif
Return


#------------------------------------------------#
# Lecture et traitement à partir de la réception #
# ---------------------------------------------- #
# Cas des factures complémentaires et des avoirs #
#------------------------------------------------#
$TRT_RCP2
If [F:ITM]ITMREF<>[F:PID2]ITMREF
  Read [ITM] ITM0=[F:PID2]ITMREF : If fstat Raz [F:ITM] : Endif
Endif
# si FCC sur réception, on lit la réception
If [F:PID2]TYPORI=2
  Read [PTD] PTD0=[F:PID2]PTHNUM;[F:PID2]PTDLIN
  If fstat  Return : Endif
Endif
If [F:PTH]PTHNUM<>[F:PTD]PTHNUM
  Read [PTH] PTH0=[F:PTD]PTHNUM : If fstat  Raz [F:PTH] : Endif
Endif
If [F:POH]POHNUM<>[F:PTD]POHNUM & [F:PTD]POHNUM<>"" # Issue 99967 GA 06/2014
  Read [POH] POH0=[F:PTD]POHNUM : If fstat  Raz [F:POH] : Endif
Endif
WTRSCOD=[F:PTH]TRSCOD
#----- Article non géré en stock et non sous-traitance, pas de régul ! -----#
# Issue 117430 - 2016-09-13 by MUARN : à cet endroit TYPORI toujours = 4, on ne sortait pas pour article non géré en stock
#If [F:PTD]STOMGTCOD<2 & [F:ITM]SCSFLG<>2 & [F:PID]TYPORI<>4 # Issue 99967 GA 06/2014 + TYPORI
If [F:PTD]STOMGTCOD<2 & !find([F:PTD]VCRTYPORI,10,36) # Issue 99967 GA 06/2014 + TYPORI
  Return
Endif
#-----
WFCY    = [F:PTD]PRHFCY
WITMREF = [F:PTD]ITMREF
#----- Récupération date en fonction du paramètre ACCDATSTK -----#
If func AFNC.PARAM("ACCDATSTK",WFCY)="2"
  WIPTDAT=[F:PIH]ACCDAT
Else
  WIPTDAT=[F:PTD]RCPDAT
Endif
#-----
WVCRTYP = 6
WVCRNUM = [F:PTD]PTHNUM
WVCRLIN = [F:PTD]PTDLIN
If [F:PIH]PIHTYP=2                   : # Facture complémentaire - Additionnal invoice
  # Issue 106958 GA 03/2015 error since correction 99967 was undone
  # Issue 84130 - 2013-03-06 by MUARN : landed cost le CPR est devenu montant
  WPRI=[F:PID]CPR
  WQTY = 0
  # Issue 121029 - 2017-01-25 by MUARN : inutile fait plus tard
  ## Issue 102605 GA 19/01/2015
  ## In case Field [F:PID]CPR is null
  #If ([F:PID]CPRCUR=[F:PIH]CUR & abs([F:PID]AMTNOTLIN-WPRI)<=0.01) | WPRI=0
  #  WPRI=[F:PID]AMTNOTLIN
  #Endif
  #WQTY = 0
  # Issue 79861 - 2012-02-20 by VPO : elt de facturation non valorisés en stock
  #WINVDTACST = sigma(WI=1,9,evalue("[F:PID]DISCRGAMT"+num$(WI)))
  Raz WINVDTACST
  For I=1 To 9
    If [F:PIV]INVDTALIN2(I-1)<>0
      Read [PFI] PFI0=[F:PIV]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
      If [F:PFI]NPRVLT=2
        WINVDTACST+=evalue("[F:PID]DISCRGAMT"+num$(I))
      Endif
    Endif
  Next I

# Issue 122089 - 2017-03-17 by MUARN : avoir en quantité ne pas tester <> mais <
# Issue 112762 - 2015-11-26 by MUARN : avoir en quantité avec prix différent de la facture
#Elsif [F:PID]NETPRI=[F:PID]ORINETPRI & [F:PID]QTYSTU<>0 : # Avoir en qtés
#Elsif ([F:PID]QTYPUU<>[F:PID]ORIQTYPUU & [F:PID]QTYSTU<>0) | ([F:PID]QTYPUU=[F:PID]ORIQTYPUU & [F:PID]NETPRI=[F:PID]ORINETPRI)
Elsif ([F:PID]QTYPUU<[F:PID]ORIQTYPUU & [F:PID]QTYSTU<>0) | ([F:PID]QTYPUU=[F:PID]ORIQTYPUU & [F:PID]NETPRI=[F:PID]ORINETPRI)
  If [F:PID]QTYSTU > [F:PTD]QTYSTU
    WQTY = -[F:PTD]QTYSTU
  Else
    WQTY = -[F:PID]QTYSTU
  Endif
  #WPRI = [F:PID]CPR
  #WPRI = arr([F:PID]CPR*WQTY,10^-GDECPRI)
  If [F:PID]CPR=[F:PTD]CPR
    If [F:PID]QTYSTU>[F:PTD]QTYSTU
      # Issue 108848 - 2015-06-19 by MUARN : avoir complet
      If [F:PID]ORIQTYPUU = [F:PID]QTYPUU
        WPRI = 0
      Else
        WPRI=arr(([F:PTD]QTYSTU-[F:PID]QTYSTU)*[F:PID]CPR,10^-GDECPRI)
      Endif
      # Issue 79861 - 2012-02-20 by VPO : elt de facturation non valorisés en stock
#      WINVDTACST=-(sigma(WI=1,9,evalue("[F:PTD]DISCRGAMT"+num$(WI)))
#&                 -sigma(WI=1,9,evalue("[F:PID]DISCRGAMT"+num$(WI))))
      Raz WINVDTACST
      For I=1 To 9
        If [F:PIV]INVDTALIN2(I-1)<>0
          Read [PFI] PFI0=[F:PIV]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
          If [F:PFI]NPRVLT=2
            WINVDTACST+=evalue("[F:PID]DISCRGAMT"+num$(I))
          Endif
        Endif
      Next I
      Raz WINVDTACSTPTD
      For I=1 To 9
        If [F:PTH]INVDTALIN2(I-1)<>0
          Read [PFI] PFI0=[F:PTH]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
          If [F:PFI]NPRVLT=2
            WINVDTACSTPTD+=evalue("[F:PTD]DISCRGAMT"+num$(I))
          Endif
        Endif
      Next I
      WINVDTACST=-(WINVDTACSTPTD-WINVDTACST)

    Else
      WPRI=0
      WINVDTACST=0
    Endif
  Else
    WPRI=arr(([F:PID]CPR-[F:PTD]CPR)*WQTY,10^-GDECPRI)
    # Issue 79861 - 2012-02-20 by VPO : elt de facturation non valorisés en stock
#    WINVDTACST=-(sigma(WI=1,9,evalue("[F:PID]DISCRGAMT"+num$(WI)))
#&               -sigma(WI=1,9,evalue("[F:PTD]DISCRGAMT"+num$(WI))))
    Raz WINVDTACST
    For I=1 To 9
      If [F:PIV]INVDTALIN2(I-1)<>0
        Read [PFI] PFI0=[F:PIV]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
        If [F:PFI]NPRVLT=2
          WINVDTACST+=evalue("[F:PID]DISCRGAMT"+num$(I))
        Endif
      Endif
    Next I
    Raz WINVDTACSTPTD
    For I=1 To 9
      If [F:PTH]INVDTALIN2(I-1)<>0
        Read [PFI] PFI0=[F:PTH]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
        If [F:PFI]NPRVLT=2
          WINVDTACSTPTD+=evalue("[F:PTD]DISCRGAMT"+num$(I))
        Endif
      Endif
    Next I
    WINVDTACST=-(WINVDTACST-WINVDTACSTPTD)

  Endif
  WQTY = 0
Else                                                    : # Avoir en valeur
  # Issue 96117 - 2014-01-24 by SR
  # si avoir sur FCC sur rcp : [F:PID2] = la FCC--> QTYSTU = 0 : il faut prendre qté de la rcp
  # si avoir sur FCC sur fct : [F:PID2] = la fct--> QTYSTU <> 0
  If [F:PID2]QTYSTU>[F:PTD]QTYSTU | [F:PID2]QTYSTU = 0
    WQTY=[F:PTD]QTYSTU
  Else
    WQTY=[F:PID2]QTYSTU
  Endif
  # Issue 102605 GA 13/10/2014
  # Field [F:PID]CPR contains total amount if value credit invoice is associated to an additional invoice
  If [F:PID2]PIHTYP=2 & [F:PID2]QTYSTU = 0
    WPRI = -[F:PID]CPR
  Else
    WPRI = -arr([F:PID]CPR*WQTY,10^-8)
  Endif
  WQTY = 0
  # Issue 79861 - 2012-02-20 by VPO : elt de facturation non valorisés en stock
  #WINVDTACST = -sigma(WI=1,9,evalue("[F:PID]DISCRGAMT"+num$(WI)))
  Raz WINVDTACST
  For I=1 To 9
    If [F:PIV]INVDTALIN2(I-1)<>0
      Read [PFI] PFI0=[F:PIV]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
      If [F:PFI]NPRVLT=2
        WINVDTACST+=evalue("[F:PID]DISCRGAMT"+num$(I))
      Endif
    Endif
  Next I
  WINVDTACST = -WINVDTACST

Endif
#----- Article géré en stock -----#
If !find([F:PTD]VCRTYPORI,10,36) & [F:ITM]SCSFLG<>2 & [F:PID]LINTYP<>4 # Issue 95354 GA 12/2013
  If WTRANSAC="!#DEVALIDE"
    If WQTY=0 WPRI=-WPRI Else WQTY=-WQTY : Endif
  Endif
  WTYP=3 : Gosub REGUL_PRI
Else
#----- Sous-traitance -----#
  # Issue 100967 GA 07/2014 different cases for subcontract receipt - start
  #----- Si avoir en qtés, il faut passer une quantité au s/p MAJ_SBC et prix unitaire -----#
  If [F:PIH]PIHTYP=3 & [F:PID]NETPRI=[F:PID]ORINETPRI & [F:PID]QTYSTU<>0
    If [F:PID]QTYSTU>[F:PTD]QTYSTU
      WQTY=-[F:PTD]QTYSTU
    Else
      WQTY=-[F:PID]QTYSTU
    Endif
    # we need a unit price for credit invoice with a qty
    If [F:PID]CPR<>0
      WPRI= -[F:PID]CPR
    Else
      # EO credit invoice: [F:PID]CPR is null, as additional invoice
      If [F:PID]LINTYP>2 & [F:PID]CPR=0
         # Issue 121029 - 2017-01-25 by MUARN : les frais/remise et éléments de facturation valorisés en stock doivent être prix en compte
         #WPRI = [F:PID]AMTNOTLIN
         # Check currency because using [F:PID]AMTNOTLIN
         #If WPRI<>0 & [F:PID]CPRCUR<>[F:PIH]CUR  # need to convert calculated amount ?
         #   # Issue 102605 GA 12/2014 replaced [F:PTH]CHGTYP,[F:PTH]RCPDAT,
#        #     Local Integer WSTAT
#        #     Call CONVERT2([F:PIH]CUR,[F:PID]CPRCUR,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]RATDAT,
#&       #                   WPRI,WPRI,WSTAT) From TRTDEV
         #    Call CONVERT_PIH(WPRI,WPRI)
         #Endif
         #WPRI=-arr(WPRI/WQTY,10-GDECPRI)
         # calcul du CPR ligne service et matière de la facture
         Gosub CAL_CPR_PID
         # End issue 121029
      Endif
    Endif
  Else
  #  WQTY must be null
  #  WQTY=-[F:PID]QTYSTU   # Issue 95354 GA 12/2013 on est sur un avoir: qté<0
    WQTY=0
    # Issue 121029 - 2017-01-25 by MUARN : les frais/remise et éléments de facturation valorisés en stock doivent être prix en compte
    # EO additional invoice or value credit invoice [F:PID]CPR is null
    # WO additional invoice or value credit invoice [F:PID]CPR is wrong
    # If [F:PID]LINTYP>2 & [F:PID]CPR=0  # Issue 102605 GA 03/2015
    #If [F:PID]LINTYP<>2
    If [F:PID]LINTYP > 2
       # Issue 121029 - 2017-01-25 by MUARN : les frais/remise et éléments de facturation valorisés en stock doivent être prix en compte
       #WPRI = [F:PID]AMTNOTLIN
       #WQTY = 0
       # Check currency because using [F:PID]AMTNOTLIN
       #If WPRI<>0 & [F:PID]CPRCUR<>[F:PIH]CUR  # need to convert calculated amount ?
       #     # Issue 102605 GA 12/2014 replaced [F:PTH]CHGTYP,[F:PTH]RCPDAT,
#           Local Integer WSTAT
#           Call CONVERT2([F:PIH]CUR,[F:PID]CPRCUR,GLOCALDEV,[F:PIH]CURTYP,[F:PIH]RATDAT,
#&                        WPRI,WPRI,WSTAT) From TRTDEV
       #      Call CONVERT_PIH(WPRI,WPRI)
       #Endif
       # calcul du CPR ligne service et matière de la facture
       Gosub CAL_CPR_PID
       # End issue 121029
       If [F:PIH]PIHTYP=3 WPRI*=-1 Endif
       # Issue X3-73378 - 2018-01-25 by SR : Avoir en valeur ou FCC : passer un montant dans WPRI
       If [F:PID]PIHTYP = 2 : # FCC
         WPRI *= [F:PID2]QTYSTU
       Else : # Avoir en valeur
        # Relire la facture à l'origine de l'avoir
        Read [F:PID3]PID0 = [F:PID]NUMORI;[F:PID]LINORI
        If fstat : Raz [F:PID3] : Endif
        # Avoir sur FCC sur réception
        If [F:PID3]PIHTYP = 2 & [F:PID3]TYPORI = 2
           WPRI *= [F:PTD]QTYSTU
        Else
           WPRI *= [F:PID2]QTYSTU
        Endif
       Endif
       # End issue X3-73378
    Else
     # keep calculated difference value
    Endif
  Endif
  # Issue 100967 GA 07/2014 different cases for subcontract receipt - end
  #-----
  If WTRANSAC="!#DEVALIDE"
    If WQTY=0 WPRI=-WPRI Else WQTY=-WQTY : Endif
  Endif
  # Issue 89807 GA 05/2013 si et seulement si OF ou EO, ne pas tester uniquement [F:ITM]SCSFLG=2
  If clalev([M:SBCK]) & find([F:PTD]VCRTYPORI,10,36)
      # Issue 121029 - 2017-01-25 by MUARN : les frais/remise et éléments de facturation valorisés en stock doivent être prix en compte
      #----- Sous-traitance -----#
      # Issue X3-63103 - 2017-11-16 by MUARN : ne faire que si l'article est le même que la réception, sinon init à 1 de GBIDD3
      If [F:PTD]ITMREF = [F:PID]ITMREF
        Call PCAL_QTY([F:PID]QTYPUU,[F:PID]PUU,GBIDD1,[F:PTD]STU,
&                 [F:PID]ITMREF,[F:PID]BPSNUM,1,GBIDD3) From TRTACHQTE1
      Else
        GBIDD3 = 1
      Endif
      If GBIDD3=0 GBIDD3=1 : Endif
      #----- Prix net exprimé en unité de stock -----#
      If [F:PID]UOMPUUCOE=0  [F:PID]UOMPUUCOE=1 : Endif
      # Issue 121029 - 2017-05-09 by MUARN : tenir compte quantité nulle
      #WNETPRI=[F:PID]NETPRI/([F:PID]UOMPUUCOE*GBIDD3)
      # Issue X3-73378 - 2018-01-25 by SR : Avoir en valeur :
      # [F:PID]QTYUOM <> 0 et pourtant il faut passer un montant à la valo : On se sert donc de WQTY
      #If [F:PID]QTYUOM <> 0
      If WQTY <> 0
        WNETPRI=[F:PID]NETPRI/([F:PID]UOMPUUCOE*GBIDD3)
      Else
        WNETPRI = [F:PID]AMTNOTLIN
      Endif
      #----- Prix net exprimé en devise société -----#
      WI=find(GLOCALDEV,[F:PIH]CURLED)
      If WI & [F:PIH]RATDIV(WI-1)<>0
        WRATCUR=[F:PIH]RATMLT(WI-1)/[F:PIH]RATDIV(WI-1)
      Else
        WRATCUR=0
      Endif
      If WRATCUR=0
        Call CONVERT2([F:PIH]CUR,GCUR,GCUR,[F:PIH]CURTYP,[F:PIH]RATDAT,WNETPRI,WNETPRI,
&                   STAT) From TRTDEV
      Else
        WNETPRI=WNETPRI*WRATCUR
      Endif
      #-----
      # Issue X3-63103 - 2017-11-27 by MUARN : Avoir sans quantité
      If WTRANSAC<>"!#DEVALIDE" & WQTY=0 & [F:PIH]PIHTYP=3 : WNETPRI=-WNETPRI : Endif
      WNETPRI = arr(WNETPRI,10^-8)
      # End issue 121029
      Raz [M:SBCK]                    # Issue 105321 GA 03/2015
      [M:SBCK]MAJCOD = "F"
      [M:SBCK]RCPDAT = [F:PTD]RCPDAT
      [M:SBCK]ITMREF = [F:ITM]ITMREF   # FQ 70864 GA 02/2011 avant WITMREF  # FQ 56565 GA 07/2009
      [M:SBCK]PTHNUM = WVCRNUM
      [M:SBCK]PTDLIN = WVCRLIN
      [M:SBCK]VCRNUM = [F:PTD]POHNUM   # FQ 56565 GA 07/2009
      [M:SBCK]VCRLIN = [F:PTD]POPLIN   # FQ 56565 GA 07/2009
      If dim([M:SBCK]LINTYP)>0 [M:SBCK]LINTYP = [F:PTD]LINTYP Endif  # FQ 76147 GA 09/2011
      [M:SBCK]INVQTY = WQTY
      # Issue 121029 - 2017-01-25 by MUARN : les frais/remise et éléments de facturation valorisés en stock doivent être prix en compte
      #[M:SBCK]CPLPRI = WPRI
      #[M:SBCK]CPLCRG = 0
      [M:SBCK]CPLPRI = WNETPRI
      [M:SBCK]CPLCRG = WPRI - WNETPRI
      # End issue 121029
      # Issue X3-67828 - 2017-12-11 by SR: conversion du montant des éléments de facturation en devise société
      If [F:PID]CPRCUR <> [F:PIH]CUR
         Local   Decimal  WINVDTACST_DEV, WCOURS
         WINVDTACST_DEV = WINVDTACST
         Call CONVERT_PIH(WINVDTACST_DEV,WINVDTACST)
      Endif
      [M:SBCK]INVDTACST = WINVDTACST
      [M:SBCK]MSGFLG = 1
      [M:SBCK]ITMREFORI = [F:PTD]ITMREFORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRTYPORI = [F:PTD]VCRTYPORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRNUMORI = [F:PTD]VCRNUMORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRLINORI = [F:PTD]VCRLINORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRSEQORI = [F:PTD]VCRSEQORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      Raz GMESSAGE
      Call MAJ_SBC From SBCLIB
      If [M:SBCK]CODRET<>0
        Gosub SBCK_ERROR  # Issue 109433 by GA 09/2015
      Endif
  Endif
Endif
Return


#---------------------------------------------------------#
# Lecture et traitement à partir des changements de stock #
#               Transferts inter-sociétés                 #
#---------------------------------------------------------#
$LECT_CHGSTO
Raz WVCRNUM2,WVCRLIN2, WQTYSTU2
WQTYRES=[F:PID]QTYSTU
For [SGH] SGH1 Where SIHNUM=[F:PIV]SIHNUM
  WTRSCOD=[F:SGH]TRSCOD
  For [SGD] SGD0 Where VCRNUM=[F:SGH]VCRNUM & ITMREF=[F:PID]ITMREF
    If [F:SGD]QTYSTUDES>WQTYSTU2
      WVCRNUM2=[F:SGD]VCRNUM : WVCRLIN2=[F:SGD]VCRLIN : WQTYSTU2=[F:SGD]QTYSTUDES
    Endif
    #----- Pas de régul si prix mvt = prix facture -----#
    If [F:SGD]PRI<>[F:PID]CPR | WQTYRES<[F:SGD]QTYSTUDES | [F:ITM]SCSFLG=2
      Gosub REGUL_CHGSTO
    Else
      WQTYRES-=[F:SGD]QTYSTUDES
    Endif
  Next
Next
#----- Traitement du reliquat de quantité si celui-ci existe (sur-facturation) -----#
If WQTYRES>0 & WVCRNUM2<>""
  Read [SGH] SGH0=WVCRNUM2          : If fstat  Raz [F:SGH] : Endif
  Read [SGD] SGD0=WVCRNUM2;WVCRLIN2 : If fstat  Raz [F:SGD] : Endif
  If [F:SGH]VCRNUM<>"" & [F:SGD]VCRNUM<>""
    Raz [F:SGD]QTYSTUDES : Gosub REGUL_CHGSTO
  Endif
Endif
Return


#----------------------------------------------------------------------------#
# Régularisation mouvements changements de stock (Transferts inter-sociétés) #
#----------------------------------------------------------------------------#
$REGUL_CHGSTO
WFCY    = [F:SGH]FCYDES
WITMREF = [F:SGD]ITMREF
#----- Récupération date en fonction du paramètre ACCDATSTK -----#
If func AFNC.PARAM("ACCDATSTK",WFCY)="2"
  WIPTDAT=[F:PIH]ACCDAT
Else
  WIPTDAT=[F:SGH]IPTDAT
Endif
#-----
WVCRTYP = 29
WVCRNUM = [F:SGD]VCRNUM
WVCRLIN = [F:SGD]VCRLIN
WPRI    = [F:PID]CPR
WPRIORI = [F:SGD]PRI
# Issue 79861 - 2012-02-20 by VPO : elt de facturation non valorisés en stock
#WINVDTACST = sigma(WI=1,9,evalue("[F:PID]DISCRGAMT"+num$(WI)))
Raz WINVDTACST
For I=1 To 9
  If [F:PIV]INVDTALIN2(I-1)<>0
    Read [PFI] PFI0=[F:PIV]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
    If [F:PFI]NPRVLT=2
      WINVDTACST+=evalue("[F:PID]DISCRGAMT"+num$(I))
    Endif
  Endif
Next I

If WQTYRES>=[F:SGD]QTYSTUDES & [F:SGD]QTYSTUDES<>0
  WQTY = [F:SGD]QTYSTUDES
  WQTYRES-=[F:SGD]QTYSTUDES
Else
  WPRI   =arr(([F:PID]CPR*WQTYRES)-([F:SGD]PRI*[F:SGD]QTYSTUDES),10^-8)
  WPRIORI=arr(([F:SGD]PRI*[F:SGD]QTYSTUDES)-([F:PID]CPR*WQTYRES),10^-8)
  WQTY=0
  Raz WQTYRES
Endif
#----- Article géré en stock -----#
#If [F:ITM]SCSFLG<>2 & [F:PID]LINTYP<>4 # Issue 95354 GA 12/2013
If !find([F:PTD]VCRTYPORI,10,36) & [F:ITM]SCSFLG<>2 & [F:PID]LINTYP<>4 # Issue 99967 GA 06/2014
  If WTRANSAC="!#DEVALIDE"
    If WQTY<>0
      WPRI=(WPRIORI-WPRI)*WQTY : WQTY=0
    Else
      WPRI=WPRIORI-WPRI
    Endif
  Endif
  WTYP=3 : Gosub REGUL_PRI
Else
  #----- Sous-traitance -----#
  Call PCAL_QTY([F:PID]QTYPUU,[F:PID]PUU,GBIDD1,[F:SGD]STU,
&               [F:PID]ITMREF,[F:PID]BPSNUM,1,GBIDD3) From TRTACHQTE1
  If GBIDD3=0 GBIDD3=1 : Endif
  #----- Prix net exprimé en unité de stock -----#
  If [F:PID]UOMPUUCOE=0  [F:PID]UOMPUUCOE=1 : Endif
  WNETPRI=[F:PID]NETPRI/([F:PID]UOMPUUCOE*GBIDD3)
  #----- Prix net exprimé en devise société -----#
  WI=find(GLOCALDEV,[F:PIH]CURLED)
  If WI & [F:PIH]RATDIV(WI-1)<>0
    WRATCUR=[F:PIH]RATMLT(WI-1)/[F:PIH]RATDIV(WI-1)
  Else
    WRATCUR=0
  Endif
  If WRATCUR=0
    Call CONVERT2([F:PIH]CUR,GCUR,GCUR,[F:PIH]CURTYP,[F:PIH]RATDAT,WNETPRI,WNETPRI,
&                 STAT) From TRTDEV
  Else
    WNETPRI=WNETPRI*WRATCUR
  Endif
  #-----
  If WNETPRI=0
    WNETPRI = WPRI
  Else
    WNETPRI = arr(WNETPRI,10^-8)
  Endif
  If WTRANSAC="!#DEVALIDE"
    If WQTY=0 WNETPRI=-WNETPRI : WPRI=-WPRI Else WQTY=-WQTY : Endif
  Endif
  #----- Régularisation des prix sous-traitance -----#
  # Issue 89807 GA 05/2013 si et seulement si OF ou EO, ne pas tester uniquement [F:ITM]SCSFLG=2
  If clalev([M:SBCK]) & find([F:PTD]VCRTYPORI,10,36)
      Raz [M:SBCK]                    # Issue 105321 GA 03/2015
      [M:SBCK]MAJCOD = "F"
      [M:SBCK]RCPDAT = [F:SGH]IPTDAT
      [M:SBCK]ITMREF = [F:PID]ITMREF   # FQ 70864 GA 02/2011 avant WITMREF  # FQ 56565 GA 07/2009
      [M:SBCK]PTHNUM = WVCRNUM
      [M:SBCK]PTDLIN = WVCRLIN
      [M:SBCK]VCRNUM = [F:PTD]POHNUM   # FQ 56565 GA 07/2009
      [M:SBCK]VCRLIN = [F:PTD]POPLIN   # FQ 56565 GA 07/2009
      If dim([M:SBCK]LINTYP)>0 [M:SBCK]LINTYP = [F:PTD]LINTYP Endif  # FQ 76147 GA 09/2011
      [M:SBCK]INVQTY = WQTY
      [M:SBCK]CPLPRI = WNETPRI
      [M:SBCK]CPLCRG = WPRI - WNETPRI
      # Issue X3-67828 - 2017-12-11 by SR: conversion du montant des éléments de facturation en devise société
      If [F:PID]CPRCUR <> [F:PIH]CUR
         Local   Decimal  WINVDTACST_DEV, WCOURS
         WINVDTACST_DEV = WINVDTACST
         Call CONVERT_PIH(WINVDTACST_DEV,WINVDTACST)
      Endif
      [M:SBCK]INVDTACST = WINVDTACST
      [M:SBCK]MSGFLG = 1
      [M:SBCK]ITMREFORI = [F:PTD]ITMREFORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRTYPORI = [F:PTD]VCRTYPORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRNUMORI = [F:PTD]VCRNUMORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRLINORI = [F:PTD]VCRLINORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      [M:SBCK]VCRSEQORI = [F:PTD]VCRSEQORI  # Issue 105321 GA 03/2015 ([F:POQ] replaced for code review)
      Raz GMESSAGE
      Call MAJ_SBC From SBCLIB
      If [M:SBCK]CODRET<>0
        Gosub SBCK_ERROR  # Issue 109433 by GA 09/2015
      Endif
  Endif
Endif
Return


##########################################################################
# QTES_LIGFAC : S/P d'affichage du détail des quantités     MBT 13/10/98 #
#   ABMSK    : Abréviation du masque écran contenant les lignes          #
#   NOL      : indice de la ligne à traiter (nolign-1)                   #
#   QTEMAX   : Quantité maxi facturable en UA                            #
# ---------------------------------------------------------------------- #
# Remplacé par l'action VISUQTEPIH avec paramètres :        MBT 17/11/00 #
#   PARAM(1) = WABMSK : Abréviation du masque écran contenant les lignes #
#   PARAM(2) = NOLIG  : indice de la ligne à traiter (nolign-1)          #
##########################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUVRE_VISUQTEPIH
Local Char     WABMSK(4) : WABMSK=PARAM(1)
Local Shortint NOL       : NOL=val(PARAM(2))
Local Decimal  WQTEMAX
If evalue("[M:"+WABMSK+"]TYPORI(NOL)=0") FIN=1 : Return : Endif
Call CAL_QTEMAX(NOL,[M:PIH3]NBLIG,WQTEMAX) From SUBPIHB
Return
#------------------------------------------------------------------#
# Après l'ouverture de la fenêtre des frais/remises lignes facture #
#------------------------------------------------------------------#
$DEBUT_VISUQTEPIH
#----- Variables locales -----#
Local  Decimal  COEF, QTE
Raz [M:PDQ1]
COEF=evalue("[M:"+WABMSK+"]UOMPUUCOE(NOL)")
#----- Chargement des zones dans le masque -----#
[M:PDQ1]TYPORI   =evalue("[M:"+WABMSK+"]TYPORI(NOL)")
[M:PDQ1]NUMORI   =evalue("[M:"+WABMSK+"]NUMORI(NOL)")
[M:PDQ1]LINORI   =evalue("[M:"+WABMSK+"]LINORI(NOL)")
[M:PDQ1]ITMREF   =evalue("[M:"+WABMSK+"]ITMREF(NOL)")
[M:PDQ1]ITMDES   =evalue("[M:"+WABMSK+"]ITMDES(NOL)")
[M:PDQ1]QTYUOM   =evalue("[M:"+WABMSK+"]QTYUOM(NOL)")
[M:PDQ1]UOM      =evalue("[M:"+WABMSK+"]UOM(NOL)")
[M:PDQ1]NETPRI   =evalue("[M:"+WABMSK+"]NETPRI(NOL)")
[M:PDQ1]AMTNOTLIN=evalue("[M:"+WABMSK+"]AMTNOTLIN(NOL)")
[M:PDQ1]CUR      =GCUR
[M:PDQ1]PUU      =evalue("[M:"+WABMSK+"]PUU(NOL)")
[M:PDQ1]MAXQTYPUU=WQTEMAX
[M:PDQ1]MAXQTYUOM=WQTEMAX/COEF
Call QTEARR([M:PDQ1]MAXQTYUOM,[M:PDQ1]UOM) From TRTDIV
#----- Si ligne issue d'une réception -----#
If [M:PDQ1]TYPORI=2
  If [F:PTD]PTHNUM<>[M:PDQ1]NUMORI | [F:PTD]PTDLIN<>[M:PDQ1]LINORI
    Read [PTD] PTD0=[M:PDQ1]NUMORI;[M:PDQ1]LINORI : If fstat Raz [F:PTD] : Endif
  Endif
  If [F:ITM]ITMREF<>[F:PTD]ITMREF
    Read [ITM] ITM0=[F:PTD]ITMREF : If fstat Raz [F:ITM] : Endif
  Endif
  Local Decimal WQQQQTYPUU, WQQQQTYSTU, WRRRQTYPUU, WRRRQTYSTU
  If [F:PTD]STOMGTCOD<2
    WRRRQTYPUU=[F:PTD]RRRQTYPUU    : # Non géré en stock
  Else
    Gosub RECHQTE_QR From SUBPIHB : # Géré en stock
  Endif
  #----- Quantités facturables -----#
  [M:PDQ1]MAXQTYPUU=GPIH_QTEMAX
  [M:PDQ1]MAXQTYUOM=GPIH_QTEMAX/COEF
  #----- Calcul de la quantité acceptée en UA (statut A) -----#
  QTE=[F:PTD]QTYPUU-(WQQQQTYPUU+WRRRQTYPUU)
  If QTE>0 [M:PDQ1]AAAQTYPUU=QTE : Endif
  #----- Calcul de la quantité sous contrôle en UA (statut Q) -----#
  [M:PDQ1]QQQQTYPUU=WQQQQTYPUU
  #----- Calcul de la quantité rejetée en UA (statut R) -----#
  [M:PDQ1]RRRQTYPUU=WRRRQTYPUU
  #----- Calcul de la quantité retournée en UA -----#
  [M:PDQ1]RTNQTYPUU=[F:PTD]RTNQTYPUU
  #----- Calcul des quantités en unité de facturation -----#
  [M:PDQ1]MAXQTYUOM=[M:PDQ1]MAXQTYPUU/COEF
  Call QTEARR([M:PDQ1]MAXQTYUOM,[M:PDQ1]UOM) From TRTDIV
  [M:PDQ1]AAAQTYUOM=[M:PDQ1]AAAQTYPUU/COEF
  Call QTEARR([M:PDQ1]AAAQTYUOM,[M:PDQ1]UOM) From TRTDIV
  [M:PDQ1]QQQQTYUOM=[M:PDQ1]QQQQTYPUU/COEF
  Call QTEARR([M:PDQ1]QQQQTYUOM,[M:PDQ1]UOM) From TRTDIV
  [M:PDQ1]RRRQTYUOM=[M:PDQ1]RRRQTYPUU/COEF
  Call QTEARR([M:PDQ1]RRRQTYUOM,[M:PDQ1]UOM) From TRTDIV
  [M:PDQ1]RTNQTYUOM=[F:PTD]RTNQTYPUU/COEF
  Call QTEARR([M:PDQ1]RTNQTYUOM,[M:PDQ1]UOM) From TRTDIV
Else
  Grizo [PDQ1]AAAQTYUOM, QQQQTYUOM, RRRQTYUOM, RTNQTYUOM,
&             UOM2,      UOM3,      UOM4,      UOM5,
&             AAAQTYPUU, QQQQTYPUU, RRRQTYPUU, RTNQTYPUU,
&             PUU2,      PUU3,      PUU4,      PUU5
Endif
[M:PDQ1]UOM1=[M:PDQ1]UOM
[M:PDQ1]UOM2=[M:PDQ1]UOM
[M:PDQ1]UOM3=[M:PDQ1]UOM
[M:PDQ1]UOM4=[M:PDQ1]UOM
[M:PDQ1]UOM5=[M:PDQ1]UOM
[M:PDQ1]PUU1=[M:PDQ1]PUU
[M:PDQ1]PUU2=[M:PDQ1]PUU
[M:PDQ1]PUU3=[M:PDQ1]PUU
[M:PDQ1]PUU4=[M:PDQ1]PUU
[M:PDQ1]PUU5=[M:PDQ1]PUU
#----- Affichage foreground -----#
Affzo [PDQ1]1-99
Return


##########################################################################
# PAMVATFLG : S/P de test modification rubrique             MBT 16/10/98 #
#             pour calcul ou recalcul des taxes                          #
# ---------------------------------------------------------------------- #
# Subprog PAMVATFLG (ABMSK,NOLIG,NOMZON)                                 #
#   ABMSK  : Abréviation du masque écran contenant les lignes            #
#   NOLIG  : indice de la ligne active (nolign-1)                        #
#   NOMZON : Nom du champ courant                                        #
#                                                                        #
# ATTENTION : Ce S/P est appelé par une action "Après_modif"             #
##########################################################################
Subprog PAMVATFLG (ABMSK,NOLIG,NOMZON)
Value  Char     ABMSK
Value  Integer  NOLIG
Value  Char     NOMZON
Local  Shortint FLAG : FLAG=1
If NOMZON = "UOM"        |
&  NOMZON = "QTYUOM"     |
&  NOMZON = "GROPRI"     |
&  NOMZON = "DISCRGVAL1" |
&  NOMZON = "DISCRGVAL2" |
&  NOMZON = "DISCRGVAL3" |
&  NOMZON = "DISCRGVAL4" |
&  NOMZON = "DISCRGVAL5" |
&  NOMZON = "DISCRGVAL6" |
&  NOMZON = "DISCRGVAL7" |
&  NOMZON = "DISCRGVAL8" |
&  NOMZON = "DISCRGVAL9" |
&  NOMZON = "NETPRI"     |
&  NOMZON = "AMTNOTLIN"  |
&  NOMZON = "LINPURTYP"  |
&  NOMZON = "VAT1"       |
&  NOMZON = "VAT2"       |
&  NOMZON = "VAT3"       |
&  NOMZON = "TAXRCP"     |
&  NOMZON = "TAXISS"     |
&  NOMZON = "TAXOTH1"    |
&  NOMZON = "TAXOTH2"
  FLAG=2
Endif
If FLAG=2 & evalue("[M:"+ABMSK+"]LINFLG(NOLIG)")=1
  Assign "[M:"+ABMSK+"]LINFLG(NOLIG)" With 2
Endif
End

##########################################################################
# Action DIVCHXPIH : Choix facturation partielle            MBT 17/11/00 #
#   PARAM(1) = NOMESS  : Numéro du message à afficher                    #
#   PARAM(2) = NUMCHAP : Numéro du chapitre                              #
##########################################################################
#--------------------------------------------------------------#
# Avant la définition des boutons et l'ouverture de la fenêtre #
#--------------------------------------------------------------#
$OUVRE_DIVCHXPIH
Local Shortint NOL : NOL=nolign-1
Local Char     WBOUT(1)
#----- Pas de question pour facturation partielle -----#
If QTYPUU(NOL)>=GPIH_QTEMAX | [M:PIH0]PIHTYP=3
  FIN=1 : WBOUT="F" : Return
Endif
#-----
Local Shortint WNOMESS  : WNOMESS =val(PARAM(1))
Local Shortint WNUMCHAP : WNUMCHAP=val(PARAM(2))
Local Integer  OK
Local Decimal  QTE
QTE=GPIH_QTEMAX/[M:PIH3]UOMPUUCOE(NOL)
Call QTEARR(QTE,[M:PIH3]UOM(NOL)) From TRTDIV
#-----
#OK=2 : Call OUINON(mess(WNOMESS,WNUMCHAP,1),OK) From GESECRAN : # <- Fait pour le WEB 130
#If OK=1 WBOUT="A" Else WBOUT="B" : Endif                      : # <- Fait pour le WEB 130
#OK=0 : FIN=1 : Return                                         : # <- Fait pour le WEB 130
#Endif
#-----
Return
#---------------------#
# Titre de la fenêtre #
#---------------------#
$TITRE_DIVCHXPIH
TIT=mess(25,198,1)
Return
#---------------------------------#
# Après l'ouverture de la fenêtre #
#---------------------------------#
$DEBUT_DIVCHXPIH
[M:CHX]TEXTE=mess(WNOMESS,WNUMCHAP,1)
Affzo [CHX]1-99
Return
#--------#
# Bouton #
#--------#
$BOUT_DIVCHXPIH
WBOUT=BOUT : FIN=1
Return
#------------------------------------------#
# Avant de revenir à la fenêtre précédente #
#------------------------------------------#
$FINSAI_DIVCHXPIH
If WBOUT="F" Return : Endif
If WBOUT="B" [M:PIH3]PRTFLG(NOL)=2 Else [M:PIH3]PRTFLG(NOL)=1 : Endif
If WBOUT<>"A" & WBOUT<>"B" mkstat=1 : Return : Endif
#----- Si ligne de type non DIVERS, contrôle dépassement qté maxi -----#
If [M:PIH3]TYPORI(NOL)<>5 & [M:PIH3]QTYPUU(NOL)>GPIH_QTEMAX & !GIMPORT
   GMESSAGE=mess(147,194,1)-format$("N:15F",QTE)-[M:PIH3]UOM(NOL)
   OK=1 : Call AVERTIR(GMESSAGE,OK) From GESECRAN : Raz GMESSAGE
   If OK=1 mkstat=1 : Return : Endif
Endif
[M:PIH3]AMTNOTLIN(NOL)=[M:PIH3]NETPRI(NOL)*VALEUR
Call ARRDEV([M:PIH3]AMTNOTLIN(NOL),[M:PIH1]CUR) From TRTDIV
# Issue 82067 - 2012-07-06 by MUARN : écart arrondi facture/réception après valo stock
[M:PIH3]AMTNOTLINCAL(NOL)=[M:PIH3]AMTNOTLIN(NOL)
If !GIMPORT Affzo [PIH3]AMTNOTLIN(NOL) : Endif
Return


##########################################################################
# ENGAGEMENTS : S/P de gestion des engagements                           #
# ---------------------------------------------------------------------- #
# Subprog ENGAGEMENTS ()                                                 #
##########################################################################
Subprog ENGAGEMENTS ()
End


############################################################################
# Gosub MAJ_ADRESSE : Transaction de modification de l'adresse fournisseur #
#                     sur l'entête d'une facture d'achat (PINVOICE) après  #
#                     l'appui sur le bouton "Adresse"         MBT 18/07/05 #
# ------------------------------------------------------------------------ #
# L'action SAIADRBPR précède le Gosub MAJ_ADRESSE             MBT 18/07/05 #
# Attention la classe [M:PIH0] doit contenir la facture en cours et        #
#           la variable WTYPADR contient le type d'adresse                 #
#               1 = Adresse fournisseur facturant                          #
#               2 = Adresse fournisseur payé                               #
#           la variable WABREV contient l'abréviation écran                #
#               AD66 = Ecran [M:AD66] adresse fournisseur facturant        #
#               AD67 = Ecran [M:AD67] adresse fournisseur payé             #
############################################################################
$MAJ_ADRESSE
Local Char    SAV_DEFMSK(255) : SAV_DEFMSK=dbgstr(1)
Local Libelle WADBFLG
#-----
Default Mask "["+WABREV+"]"
#-----
[L]WADBFLG=[M]ADBFLG
If [M]ADBFLG=0 & GACTSAD<>2  [M]BPAADD=[F:PIH]BPAINV : Goto FIN_ADR : Endif
#----- Mide à jour de l'entête de commande -----#
Local Char     WCLE(GLONPIH) : [L]WCLE=[M:PIH0]NUM
Call DEBTRANS From GLOCK
$TR_ADR
GOK=1
Trbegin [PIH]
  Readlock [PIH] PIH0=[L]WCLE
  If fstat=1  GOK=-1 : GLOCK="$PINVOICE"-[L]WCLE           : Goto ROLL_ADR
  Elsif fstat GOK=0  : Call RSTA("PIH",[L]WCLE) From GLOCK : Goto AB_ADR : Endif
  If [L]WADBFLG<>2
    If [L]WADBFLG=1
      Case [L]WTYPADR
        When 1       : [F:PIH]BPAINV=[M]BPAADD
        When 2       : [F:PIH]BPAPAY=[M]BPAADD
        When Default : [F:PIH]BPAINV=[M]BPAADD
      Endcase
    Endif
    If GACTSAD=2 : # Stockage systématique de l'adresse !
      Case [L]WTYPADR
        When 2
          #----- Lecture BPARTNER (fournisseur payé) si nécessaire -----#
          If [F:BPR]BPRNUM<>[F:PIH]BPRPAY
            Read [BPR] BPR0=[F:PIH]BPRPAY
            If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
          Endif
          #----- Lecture de l'adresse si nécessaire -----#
          If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:PIH]BPRPAY | [F:BPA]BPAADD<>[F:PIH]BPAPAY
            Read [BPA] BPA0=1;[F:PIH]BPRPAY;[F:PIH]BPAPAY
            If fstat  Raz [F:BPA] : Endif
          Endif
          #-----
          [F:PIH]BPYNAM(0)    = [F:BPR]BPRNAM(0)
          [F:PIH]BPYNAM(1)    = [F:BPR]BPRNAM(1)
          [F:PIH]BPYADDLIG(0) = [F:BPA]BPAADDLIG(0)
          [F:PIH]BPYADDLIG(1) = [F:BPA]BPAADDLIG(1)
          [F:PIH]BPYADDLIG(2) = [F:BPA]BPAADDLIG(2)
          [F:PIH]BPYCRY       = [F:BPA]CRY
          [F:PIH]BPYCRYNAM    = [F:BPA]CRYNAM
          [F:PIH]BPYSAT       = [F:BPA]SAT
          [F:PIH]BPYPOSCOD    = [F:BPA]POSCOD
          [F:PIH]BPYCTY       = [F:BPA]CTY
        When Default
          #----- Lecture BPARTNER (fournisseur facturant) si nécessaire -----#
          If [F:BPR]BPRNUM<>[F:PIH]BPR
            Read [BPR] BPR0=[F:PIH]BPR
            If fstat Raz [F:BPR] : [F:BPR]CUR=GLOCALDEV : [F:BPR]LAN=GLANGUE : Endif
          Endif
          #----- Lecture de l'adresse si nécessaire -----#
          If [F:BPA]BPATYP<>1 | [F:BPA]BPANUM<>[F:PIH]BPR | [F:BPA]BPAADD<>[F:PIH]BPAINV
            Read [BPA] BPA0=1;[F:PIH]BPR;[F:PIH]BPAINV
            If fstat  Raz [F:BPA] : Endif
          Endif
          #-----
          [F:PIH]BPRNAM(0)    = [F:BPR]BPRNAM(0)
          [F:PIH]BPRNAM(1)    = [F:BPR]BPRNAM(1)
          [F:PIH]BPAADDLIG(0) = [F:BPA]BPAADDLIG(0)
          [F:PIH]BPAADDLIG(1) = [F:BPA]BPAADDLIG(1)
          [F:PIH]BPAADDLIG(2) = [F:BPA]BPAADDLIG(2)
          [F:PIH]CRY          = [F:BPA]CRY
          [F:PIH]CRYNAM       = [F:BPA]CRYNAM
          [F:PIH]SAT          = [F:BPA]SAT
          [F:PIH]POSCOD       = [F:BPA]POSCOD
          [F:PIH]CTY          = [F:BPA]CTY
      Endcase
    Else
      Case [L]WTYPADR
        When 2
          Raz [F:PIH]BPYNAM,[F:PIH]BPYADDLIG,[F:PIH]BPYCRY,[F:PIH]BPYCRYNAM,
&             [F:PIH]BPYSAT,[F:PIH]BPYPOSCOD,[F:PIH]BPYCTY
        When Default
          Raz [F:PIH]BPRNAM,[F:PIH]BPAADDLIG,[F:PIH]CRY,[F:PIH]CRYNAM,
&             [F:PIH]SAT,[F:PIH]POSCOD,[F:PIH]CTY
      Endcase
    Endif
  Else
    Case [L]WTYPADR
      When 1
        [F:PIH]=[M]
        [F:PIH]BPAINV=[M]BPAADD
      When 2
        [F:PIH]BPAPAY       = [M]BPAADD
        [F:PIH]BPYNAM(0)    = [M]BPRNAM(0)
        [F:PIH]BPYNAM(1)    = [M]BPRNAM(1)
        [F:PIH]BPYADDLIG(0) = [M]BPAADDLIG(0)
        [F:PIH]BPYADDLIG(1) = [M]BPAADDLIG(1)
        [F:PIH]BPYADDLIG(2) = [M]BPAADDLIG(2)
        [F:PIH]BPYCRY       = [M]CRY
        [F:PIH]BPYCRYNAM    = [M]CRYNAM
        [F:PIH]BPYSAT       = [M]SAT
        [F:PIH]BPYPOSCOD    = [M]POSCOD
        [F:PIH]BPYCTY       = [M]CTY
      When Default
        [F:PIH]=[M]
        [F:PIH]BPAINV=[M]BPAADD
    Endcase
  Endif
  If dim([F:PIH]UPDDAT)>0  [F:PIH]UPDDAT=date$     : Endif
  If dim([F:PIH]UPDTIM)>0  [F:PIH]UPDTIM=time      : Endif
  If dim([F:PIH]UPDUSR)>0  [F:PIH]UPDUSR=GUSER     : Endif
  If dim([F:PIH]EXPNUM)>0  [F:PIH]EXPNUM=[C]EXPORT : Endif
  Rewrite [PIH]
  If fstat GOK=0 : Call FSTA("PIH") From GLOCK : Goto AB_ADR : Endif
Commit
$FIN_ADR
Default Mask SAV_DEFMSK
Gosub DEVERROU From GOBJET : Gosub RELIT From GOBJET
Return
$ROLL_ADR
Rollback : Call ROLL From GLOCK
If GROLL   Goto FIN_ADR  Else  Goto TR_ADR : Endif
$AB_ADR
Rollback
Goto FIN_ADR


###############################################################
# RATSOC : S/P de récupération cours devise société d'origine #
# ----------------------------------------------------------- #
# NUMFAC : Numéro de la facture                               #
# LINFAC : Ligne de la facture                                #
# COURS  : Cours devise trouvé                                #
# WRET   : Code retour                                        #
###############################################################
Subprog RATSOC(NUMFAC,LINFAC,COURS,WRET)
Value    Char    NUMFAC
Value    Integer LINFAC
Variable Decimal COURS
Variable Integer WRET
#-----
Local Libelle WINDIC
#-----
[L]WINDIC=1 : Gosub RATORI
If fstat  [L]WRET=1 : Endif
#-----
End


#################################################################
# RATRPT : S/P de récupération cours devise reporting d'origine #
# ------------------------------------------------------------- #
# NUMFAC : Numéro de la facture                                 #
# LINFAC : Ligne de la facture                                  #
# COURS  : Cours devise trouvé                                  #
# WRET   : Code retour                                          #
#################################################################
Subprog RATRPT(NUMFAC,LINFAC,COURS,WRET)
Value    Char    NUMFAC
Value    Integer LINFAC
Variable Decimal COURS
Variable Integer WRET
#-----
Local Libelle WINDIC
#-----
[L]WINDIC=2 : Gosub RATORI
If fstat  [L]WRET=1 : Endif
#-----
End


#########################################################
# RATSOCORI Récupération cours devise société d'origine #
#########################################################
Funprog RATSOCORI(NUMFAC,LINFAC)
Value    Char    NUMFAC     : # Numéro de la facture
Value    Integer LINFAC     : # No de ligne de la facture
#-----
Local Decimal COURS         : # Cours devise
Local Integer WRET
Local Libelle WINDIC
#-----
[L]WINDIC=1 : Gosub RATORI
#-----
End [L]COURS


##############################################################
# RATRPTORI Récupération cours devise de reporting d'origine #
##############################################################
Funprog RATRPTORI(NUMFAC,LINFAC)
Value    Char    NUMFAC     : # Numéro de la facture
Value    Integer LINFAC     : # No de ligne de la facture
#-----
Local Decimal COURS         : # Cours devise
Local Integer WRET
Local Libelle WINDIC
#-----
[L]WINDIC=2 : Gosub RATORI
#-----
End [L]COURS


#-------------------------------------#
# Récupération cours devise d'origine #
#-------------------------------------#
$RATORI
#-----
Local Char     SAV_GLOCALDEV(GLONCUR)
Local Char     WDEVDEST(GLONCUR)
Local Char     WPARAM(10)
Local Decimal  WMT
Local Decimal  WRATCUR, WRATRPT
Local Shortint WI
#-----
If !clalev([F:PIHB])  Local File PINVOICE   [PIHB] : Endif
If !clalev([F:PIDB])  Local File PINVOICED  [PIDB] : Endif
#-----
[L]COURS=1
If [F:PIHB]NUM<>[L]NUMFAC
  Read [PIHB] PIH0=[L]NUMFAC
  If fstat  Raz [F:PIHB] : Return : Endif
Endif
WI=find(GLOCALDEV,[F:PIHB]CURLED)
If WI & [F:PIHB]RATDIV(WI-1)<>0
  WRATCUR=[F:PIHB]RATMLT(WI-1)/[F:PIHB]RATDIV(WI-1)
Else
  WRATCUR=0
Endif
WI=find(GSYSCUR,[F:PIHB]CURLED)
If WI & [F:PIHB]RATDIV(WI-1)<>0
  WRATRPT=[F:PIHB]RATMLT(WI-1)/[F:PIHB]RATDIV(WI-1)
Else
  WRATRPT=0
Endif
If [L]WINDIC=1
  [L]COURS=WRATCUR
Else
  [L]COURS=WRATRPT
Endif
If [L]COURS=0  [L]COURS=1 : Endif
If [F:PIDB]NUM<>[L]NUMFAC | [F:PIDB]PIDLIN<>[L]LINFAC
  Read [PIDB] PID0=[L]NUMFAC;[L]LINFAC
  If fstat  Raz [F:PIDB] : Return : Endif
Endif
#-----
SAV_GLOCALDEV=GLOCALDEV
Call GETDEV([F:PIHB]FCY) From DEVSUB
If [L]WINDIC=1
  [L]WDEVDEST=GLOCALDEV
Else
  [L]WDEVDEST=GSYSCUR
Endif
#-----
If find([F:PIDB]TYPORI,1,2,3)
  If !clalev([F:POH])  Local File PORDER     [POH] : Endif
  If !clalev([F:PTH])  Local File PRECEIPT   [PTH] : Endif
  If !clalev([F:PTD])  Local File PRECEIPTD  [PTD] : Endif
Endif
If [F:PIDB]TYPORI=3
  If !clalev([F:PND])  Local File PRETURND   [PND] : Endif
  If !clalev([F:BPS])  Local File BPSUPPLIER [BPS] : Endif
Endif
#-----
Case [F:PIDB]TYPORI
  When 1
    If [F:POH]POHNUM<>[F:PIDB]NUMORI
      Read [POH] POH0=[F:PIDB]NUMORI
      If fstat  Goto FIN_RATORI : Endif
    Endif
    Call CONVERT([F:PIHB]CUR,[L]WDEVDEST,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                10^(GDECRCU+1),[L]WMT,[L]WRET) From TRTDEV
    [L]COURS=arr(WMT/10^(GDECRCU+1),10^-GDECRCU)
  When 2
    If [F:PTH]PTHNUM<>[F:PIDB]NUMORI
      Read [PTH] PTH0=[F:PIDB]NUMORI
      If fstat  Goto FIN_RATORI : Endif
    Endif
    If [F:PTD]PTHNUM<>[F:PIDB]NUMORI | [F:PTD]PTDLIN<>[F:PIDB]LINORI
      Read [PTD] PTD0=[F:PIDB]NUMORI
      If fstat  Raz [F:PTD] : Endif
    Endif
    Call PARAM([F:PTH]PRHFCY,"PTHCURDAT",[L]WPARAM) From ADOVAL
    If val([L]WPARAM)<2 & [F:PTD]POHNUM<>""
      If [F:POH]POHNUM<>[F:PTD]POHNUM
        Read [POH] POH0=[F:PTD]POHNUM
        If fstat
          Raz [F:POH] : [F:POH]CHGTYP=[F:PTH]CHGTYP : [F:POH]ORDDAT=[F:PTH]RCPDAT
        Endif
      Endif
      Call CONVERT([F:PIHB]CUR,[L]WDEVDEST,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                  10^(GDECRCU+1),[L]WMT,[L]WRET) From TRTDEV
      [L]COURS=arr([L]WMT/10^(GDECRCU+1),10^-GDECRCU)
    Else
      Call CONVERT([F:PIHB]CUR,[L]WDEVDEST,GLOCALDEV,[F:PTH]CHGTYP,[F:PTH]RCPDAT,
&                  10^(GDECRCU+1),[L]WMT,[L]WRET) From TRTDEV
      [L]COURS=arr([L]WMT/10^(GDECRCU+1),10^-GDECRCU)
    Endif
  When 3
    If [F:PND]PNHNUM<>[F:PIDB]NUMORI | [F:PND]PNDLIN<>[F:PIDB]LINORI
      Read [PND] PND0=[F:PIDB]NUMORI;[F:PIDB]LINORI
      If fstat  Goto FIN_RATORI : Endif
    Endif
    If [F:BPS]BPSNUM<>[F:PND]BPSNUM
      Read [BPS] BPS0=[F:PND]BPSNUM
      If fstat  Goto FIN_RATORI : Endif
    Endif
    If [F:PND]PTHNUM<>""
      If [F:PTH]PTHNUM<>[F:PIDB]NUMORI
        Read [PTH] PTH0=[F:PIDB]NUMORI
        If fstat  Goto FIN_RATORI : Endif
      Endif
      Call PARAM([F:PTH]PRHFCY,"PTHCURDAT",[L]WPARAM) From ADOVAL
      If val([L]WPARAM)<2 & [F:PND]POHNUM<>""
        If [F:POH]POHNUM<>[F:PND]POHNUM
          Read [POH] POH0=[F:PND]POHNUM
          If fstat
            Raz [F:POH] : [F:POH]CHGTYP=[F:BPS]CHGTYP : [F:POH]ORDDAT=[F:PND]RTNDAT
           Endif
        Endif
        Call CONVERT([F:PIHB]CUR,[L]WDEVDEST,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                    10^(GDECRCU+1),[L]WMT,[L]WRET) From TRTDEV
        [L]COURS=arr([L]WMT/10^(GDECRCU+1),10^-GDECRCU)
      Else
        Call CONVERT([F:PIHB]CUR,[L]WDEVDEST,GLOCALDEV,[F:BPS]CHGTYP,[F:PND]RTNDAT,
&                    10^(GDECRCU+1),[L]WMT,[L]WRET) From TRTDEV
        [L]COURS=arr([L]WMT/10^(GDECRCU+1),10^-GDECRCU)
      Endif
    Else
      Call CONVERT([F:PIHB]CUR,[L]WDEVDEST,GLOCALDEV,[F:BPS]CHGTYP,[F:PND]RTNDAT,
&                  10^(GDECRCU+1),[L]WMT,[L]WRET) From TRTDEV
      [L]COURS=arr([L]WMT/10^(GDECRCU+1),10^-GDECRCU)
    Endif
Endcase
If [L]COURS=0  [L]COURS=1 : Endif
#-----
$FIN_RATORI
GLOCALDEV=SAV_GLOCALDEV
If [L]COURS=0  [L]COURS=1 : Endif
Return


#----------------------------------------------------------------------------#
# Pour l'Allemagne : Etiquette exploitée dans les pièces automatiques        #
# de génération de facture (PIHI/PIHC/PIHI2), dans l'action                  #
# 'Après création des lignes' de la ligne de pièces auto correspondant au HT #
#----------------------------------------------------------------------------#
$INITAX
If dim([F:TB1]VAT)>1 & dim([M:HAE2]TAX2)>NOL
  [M:HAE2]TAX2(NOL) = [F:TB1]VAT(1) : # Code taxe parafiscale
Endif
If dim([F:TB1]VAT)>2 & dim([M:HAE2]TAX3)>NOL
  [M:HAE2]TAX3(NOL) = [F:TB1]VAT(2) : # Code taxe spéciale
Endif
Return


#----------------------------------------------------------------------------#
# Etiquette exploitée dans les pièces automatiques de génération de facture  #
#   (PIHI/PIHC/PIHI2/PIHI3), dans l'action 'Après liens' de la ligne de      #
#    pièces auto correspondant à la TVA des éléments de facturation          #
#----------------------------------------------------------------------------#
$LECPFIACC
If !clalev([F:CAL])  Local File CPTANALIN [CAL] : Endif
Read [CAL] CAL0="PVF";[F:TB1]VCRTYP;[F:TB1]VCRNUM;0;[F:TB1]IND;"";1 : #CHECK IGNORE_LINE
If fstat  Raz [F:CAL] : Endif
If !clalev([F:GAC])  Local File GACCOUNT [GAC] : Endif
Read [GAC] GAC0=[F:CAL]COA(0);[F:CAL]ACC(0)
If fstat  Raz [F:GAC] : Endif
Return

#################################################################
# Issue 82703 - 2013-04-25 by TS : Régul valo stock FCC         #
# Issue 110325 - 2016-01-11 by SR : Régul stock FCC sur expé    #
# Issue X3-112305 - 2018-11-16 by SR:Régul stock annulation FCC #
#################################################################
# Régularisation des prix dans les mouvements de stock à partir #
# à partir :                                                    #
# - des factures complémentaires sur commandes soldées          #
# - des avoirs sur factures complémentaires sur cdes soldées    #
# Uniquement si "Nouveau coût" = OUI                            #
#                                                               #
#   LORI = 1: Validation d'une FCC ou d'un avoir sur FCC        #
#             si la commande est soldée                         #
#   LORI = 2: Solde d'une ligne de commande                     #
#             - depuis la commande                              #
#             - depuis les réceptions (création ou modif)       #
#   LORI = 3: Désolde d'une ligne de commande                   #
#             - depuis la commande                              #
#             - depuis les réceptions (suppression ou modif)    #
#   LORI = 4: Validation d'une FCC  ou d'un avoir sur FCC sur   #
#              expé si l'expédition est soldée                  #
#   LORI = 5: Solde d'une ligne d'expédition                    #
#             - depuis l'expédition                             #
#             - depuis les réceptions (création ou modif)       #
#   LORI = 6: Désolde d'une ligne d'expédition                  #
#             - depuis l'expédition                             #
#             - depuis les réceptions (suppression ou modif)    #
#   LORI = 90 : Annulation FCC sur cde/Avoir sur FCC sur cde    #
#   LORI = 91 : Annulation FCC sur expé/Avoir sur FCC sur expé  #
# PTHNUM, PTDLIN : en suppression de réception, permet de ne    #
#                  pas traiter la réception en cours            #
#---------------------------------------------------------------#
# - La ligne de commande [F:POQ] doit être en ligne             #
# - Si validation d'une FCC ou d'un avoir sur FCC (LORI=1,4),   #
#   la classe [F:PID] doit être en ligne                        #
# - Si FCC sur expé [F:SHD] doit être en ligne                  #
#                                                               #
#################################################################
Subprog REGPRIX_FCC(LORI,LPTHNUM,LPTDLIN)
Value Integer   LORI
Value Char      LPTHNUM
Value Integer   LPTDLIN

Local Char     WFCY    (GLONFCY)
Local Char     WITMREF (GLONITM)
Local Date     WIPTDAT
Local Integer  WVCRTYP
Local Char     WVCRNUM (GLONVCR)
Local Integer  WVCRLIN
Local Decimal  WQTY, WPRI, WMT
Local Integer  WRET, STAT, WTYP
Local Shortint WI
Local Integer  I
Local Decimal  WINVDTACST
Local Char     WTRSCOD(GLONADI)

If !clalev([F:PTH2]) Local File PRECEIPT   [PTH2] : Endif
If !clalev([F:PTD2]) Local File PRECEIPTD  [PTD2] : Endif
If !clalev([F:PIH])  Local File PINVOICE   [PIH]  : Endif
If !clalev([F:PIV])  Local File PINVOICEV  [PIV]  : Endif
If !clalev([F:PID])  Local File PINVOICED  [PID]  : Endif

#--- Issue 95710
If !clalev([F:PIH1]) Local File PINVOICE   [PIH1] : Endif
If !clalev([F:PIV1]) Local File PINVOICEV  [PIV1] : Endif
If !clalev([F:PID1]) Local File PINVOICED  [PID1] : Endif
If !clalev([F:PIH4]) Local File PINVOICE   [PIH4] : Endif
If !clalev([F:PIV4]) Local File PINVOICEV  [PIV4] : Endif
If !clalev([F:PID4]) Local File PINVOICED  [PID4] : Endif
#---
If !clalev([F:STJ])  Local File STOJOU     [STJ]  : Endif
If !clalev([F:SJV])  Local File STOJOUVAL  [SJV]  : Endif
If !clalev([F:PFI])  Local File PFOOTINV   [PFI]  : Endif
# Issue X3-112305 - 2018-11-15 by SR :90 = Annulation de FCC sur commande/Expé : Se positionner sur les buffers
If LORI >= 90
  # FCC sur commande
  If [F:PIH]PIHTYP = 2 & [F:PID]TYPORI=1
    Read [F:POQ]POQ0 =  [F:PID]NUMORI;[F:PID]LINORI;[F:PID]SEQORI
    If fstat : Raz [F:POQ] : Endif
  # Avoir sur FCC sur commande
  Elsif [F:PIH]PIHTYP = 3 & [F:PIH2]PIHTYP =  2 & [F:PID2]TYPORI=1
    Read [F:POQ]POQ0 =  [F:PID2]NUMORI;[F:PID2]LINORI;[F:PID2]SEQORI
    If fstat : Raz [F:POQ] : Endif
  # FCC sur expé
  Elsif [F:PIH]PIHTYP = 2 & [F:PID]TYPORI=6
    Read [F:SHD]SHD0 = [F:PID]NUMORI;[F:PID]LINORI
    If fstat : Raz [F:SHD] : Endif
  # Avoir sur FCC sur expé
  Elsif [F:PIH]PIHTYP = 3 & [F:PIH2]PIHTYP =  2 & [F:PID2]TYPORI=6
    Read [F:SHD]SHD0 = [F:PID2]NUMORI;[F:PID2]LINORI
    If fstat : Raz [F:SHD] : Endif
  Endif
Endif
# End issue X3-112305
# Issue 110325 - 2016-01-12 by SR : FCC sur expé
# Issue X3-112305 - 2018-11-15 by SR : Ne pas faire si annulation comptable d'une FCC sur commande/Avoir sur FCC sur commande
If LORI > 3 & LORI <> 90
  If [F:POQ]POHNUM <> [F:SHD]POHNUM | [F:POQ]POPLIN <> [F:SHD]POPLIN | [F:POQ]POQSEQ <> [F:SHD]POQSEQ
    Read [F:POQ]POQ0 = [F:SHD]POHNUM;[F:SHD]POPLIN;[F:SHD]POQSEQ
    If fstat : Raz [F:POQ] : Endif
  Endif
Endif
# End issue 110325
# L'article est-il géré en stock ?
If [F:ITM]ITMREF <> [F:POQ]ITMREF
  Read [ITM] ITM0=[F:POQ]ITMREF : If fstat  Raz [F:ITM] : Endif
  If fstat : Raz [F:ITM] : Endif
Endif
If [F:ITM]STOMGTCOD < 2 : End : Endif
# L'article-site est-il géré en stock ?
If [F:ITF]ITMREF<>[F:POQ]ITMREF | [F:ITF]STOFCY<>[F:POQ]PRHFCY
  Read [F:ITF]ITF0 = [F:POQ]ITMREF;[F:POQ]PRHFCY
  If fstat : Raz [F:ITF] : Endif
Endif
If [F:ITF]STOMGTCOD < 2 : End : Endif
# Issue X3-112305 - 2018-11-15 by SR : Annulation facture
If LORI = 90
   Gosub TRT_PTD
   Goto FIN
Elsif LORI = 91
   Gosub TRT_PTD_SHIP
   Goto FIN
Endif
# End issue X3-112305
# Validation d'une facture complémentaire ou d'un avoir sur FCC
If LORI=1
  If [F:POQ]LINCLEFLG=2
    If [F:PIH]NUM<>[F:PID]NUM
      Read [PIH]PIH0=[F:PID]NUM
      If fstat : Raz [F:PIH] Endif
    Endif
    If [F:PIV]NUM<>[F:PID]NUM
      Read [PIV]PIV0=[F:PID]NUM
      If fstat : Raz [F:PIV] Endif
    Endif
    # Traitement des lignes de réception
    Gosub TRT_PTD
  Endif

# C/M/S d'une ligne de réception
#--- Issue 95710
#Elsif find(LORI,2,3)
#  # Factures complémentaires de la ligne de commande
#  Link [PID] With [PIH]PIH0=[F:PID]NUM, [PIV]PIV0=[F:PID]NUM As [LNK]
#  Filter [LNK] Where TYPORI=1 & NUMORI=[F:POQ]POHNUM & LINORI=[F:POQ]POPLIN & SEQORI=[F:POQ]POQSEQ & PIHTYP=2
#&                  & CSTMAJLIN=2 & [F:PIH]STA=3 Order By Key PID1
#  For [LNK]
#    # Traitement des lignes de réception
#    Gosub TRT_PTD
#  Next
#  Filter [LNK]
#Endif
Elsif find(LORI,2,3)
  # Factures complémentaires de la ligne de commande
  Link [PID1] With [PIH1]PIH0=[F:PID1]NUM, [PIV1]PIV0=[F:PID1]NUM As [LNK1]
  Filter [LNK1] Where TYPORI=1 & NUMORI=[F:POQ]POHNUM & LINORI=[F:POQ]POPLIN & SEQORI=[F:POQ]POQSEQ & PIHTYP=2
&                  & CSTMAJLIN=2 & [F:PIH1]STA=3 Order By Key PID1
  For [LNK1]
    [F:PIH]=[F:PIH1] : [F:PID]=[F:PID1] : [F:PIV]=[F:PIV1]
    # Traitement des lignes de réception
    Gosub TRT_PTD
    #--- Avoirs sur la facture complémentaire de la ligne de commande
    Link [PID4] With [PIH4]PIH0=[F:PID4]NUM, [PIV4]PIV0=[F:PID4]NUM As [LNK4]
    Filter [LNK4] Where TYPORI=4 & NUMORI=[F:PID1]NUM & LINORI=[F:PID1]PIDLIN & SEQORI=0 & PIHTYP=3
&                    & CSTMAJLIN=2 & [F:PIH4]STA=3 Order By Key PID1
    For [LNK4]
      [F:PIH]=[F:PIH4] : [F:PID]=[F:PID4] : [F:PIV]=[F:PIV4]
      # Traitement des lignes de réception
      Gosub TRT_PTD
    Next
    Filter [LNK4]
  Next
  Filter [LNK1]
# Issue 110325 - 2016-01-11 by SR :FCC sur expé
Elsif LORI = 4
  If [F:SHD]CLEFLG=2
    If [F:PIH]NUM<>[F:PID]NUM
      Read [PIH]PIH0=[F:PID]NUM
      If fstat : Raz [F:PIH] Endif
    Endif
    If [F:PIV]NUM<>[F:PID]NUM
      Read [PIV]PIV0=[F:PID]NUM
      If fstat : Raz [F:PIV] Endif
    Endif
    # Traitement des lignes de réception
    Gosub TRT_PTD_SHIP
  Endif
Elsif find(LORI,5,6)
  # Factures complémentaires de la ligne d'expédition
  Link [PID1] With [PIH1]PIH0=[F:PID1]NUM, [PIV1]PIV0=[F:PID1]NUM As [LNK1]
  Filter [LNK1] Where TYPORI=6 & NUMORI=[F:SHD]SHIPNUM & LINORI=[F:SHD]SHIPLIN & SEQORI=0 & PIHTYP=2
&                  & CSTMAJLIN=2 & [F:PIH1]STA=3 Order By Key PID1
  For [LNK1]
    [F:PIH]=[F:PIH1] : [F:PID]=[F:PID1] : [F:PIV]=[F:PIV1]
    # Traitement des lignes de réception
    Gosub TRT_PTD_SHIP
    #--- Avoirs sur la facture complémentaire de la ligne d'expédition
    Link [PID4] With [PIH4]PIH0=[F:PID4]NUM, [PIV4]PIV0=[F:PID4]NUM As [LNK4]
    Filter [LNK4] Where TYPORI=4 & NUMORI=[F:PID1]NUM & LINORI=[F:PID1]PIDLIN & SEQORI=0 & PIHTYP=3
&                    & CSTMAJLIN=2 & [F:PIH4]STA=3 Order By Key PID1
    For [LNK4]
      [F:PIH]=[F:PIH4] : [F:PID]=[F:PID4] : [F:PIV]=[F:PIV4]
      # Traitement des lignes de réception
      Gosub TRT_PTD_SHIP
    Next
    Filter [LNK4]
  Next
  Filter [LNK1]
# End issue 110325
Endif
# Issue X3-113489 - 2018-11-15 by SR
$FIN
Close Local File [PIH1]
Close Local File [PIV1]
Close Local File [PID1]
Close Local File [PIH4]
Close Local File [PIV4]
Close Local File [PID4]
#---

End

#--- Traitement des lignes de réception de la ligne de commande de la FCC
# En suppression de réception, on ne traite pas la ligne en cours de suppression
$TRT_PTD
Link [PTD2] With [PTH2]PTH0=[F:PTD2]PTHNUM As [LNK2]
If LPTHNUM = ""
  Filter [LNK2] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN
&                   & POQSEQ=[F:POQ]POQSEQ Order By Key PTD2
Else
  # Issue X3-69568 - 2017-12-22 by SR : PTHNUM ou PTDLIN et non PTHNUM et PTDLIN
  Filter [LNK2] Where POHNUM=[F:POQ]POHNUM & POPLIN=[F:POQ]POPLIN
&                   & POQSEQ=[F:POQ]POQSEQ & (PTHNUM <> LPTHNUM | PTDLIN <> LPTDLIN)
&                      Order By Key PTD2
Endif

For [LNK2]
 Gosub REG_PTD
Next
Filter [LNK2]
Return

# Issue 110325 - 2016-01-11 by SR : FCC sur expé
####################################################################################
$TRT_PTD_SHIP
#--- Traitement des lignes de réception de la ligne d'expédition de la FCC
# En suppression de réception, on ne traite pas la ligne en cours de suppression
Link [PTD2] With [PTH2]PTH0=[F:PTD2]PTHNUM As [LNK2]
If LPTHNUM = ""
  Filter [LNK2] Where SHIPNUM=[F:SHD]SHIPNUM & SHIPLIN=[F:SHD]SHIPLIN
&                     Order By Key PTD2
Else
  # Issue X3-69568 - 2017-12-22 by SR : PTHNUM ou PTDLIN et non PTHNUM et PTDLIN
  Filter [LNK2] Where SHIPNUM=[F:SHD]SHIPNUM & SHIPLIN=[F:SHD]SHIPLIN
&                    & (PTHNUM <> LPTHNUM | PTDLIN <> LPTDLIN)
&                      Order By Key PTD2
Endif

For [LNK2]
 Gosub REG_PTD
Next
Filter [LNK2]
Return

Return

#--- Régularisation de la ligne de réception de la ligne de commande de la FCC
$REG_PTD

WTRSCOD=[F:PTH2]TRSCOD
#----- Article géré en stock ou sous-traitance -----#
# Issue 99967 GA 06/2014 added | [F:PID]LINTYP>=2 in case of EO
If [F:ITM]STOMGTCOD>1 | [F:ITM]SCSFLG=2 | [F:PID]LINTYP>=2
  WFCY   =[F:PTD2]PRHFCY
  WITMREF=[F:PTD2]ITMREF
  #----- Récupération date en fonction du paramètre ACCDATSTK -----#
  If func AFNC.PARAM("ACCDATSTK",WFCY)="2"
    WIPTDAT=[F:PIH]ACCDAT
  Else
    WIPTDAT=[F:PTD2]RCPDAT
  Endif
  #-----
  WVCRTYP=6
  WVCRNUM=[F:PTD2]PTHNUM
  WVCRLIN=[F:PTD2]PTDLIN
  WQTY   =0

  # Eléments de facturation non valorisés en stock
  Raz WINVDTACST
  For I=1 To 9
    If [F:PIV]INVDTALIN2(I-1)<>0
      Read [PFI] PFI0=[F:PIV]INVDTALIN2(I-1) : If fstat Raz [F:PFI] : Endif
      If [F:PFI]NPRVLT=2
        WINVDTACST+=evalue("[F:PID]DISCRGAMT"+num$(I))
      Endif
    Endif
  Next I
  #-----------------------------------------------------------------------------
  # Dans tous les cas FCC sur commande :
  # Mnt à régulariser = mnt facture * (qté rcp / qté rcp de la ligne de cde)
  #
  # Si modification de la quantité réceptionnée et ligne de commande était soldée
  # on fait d'abord un désolde, puis, si besoin, un solde
  #
  # Issue 110325 - 2016-01-12 by SR
  # Dans tous les cas FCC sur expédition :
  # Mnt à régulariser = mnt facture * (qté rcp / qté rcp de la ligne d'expé)
  #
  # Si modification de la quantité réceptionnée et ligne d'expé était soldée
  # on fait d'abord un désolde, puis, si besoin, un solde
  #
  #-----------------------------------------------------------------------------
  # Issue X3-112305 - 2018-11-15 by SR : Annulation comptable FCC sur cde/Expé et leurs avoirs
  If find(LORI,90,91)
     If LORI = 90
        WPRI = [F:PID]CPR*[F:PTD2]QTYSTU/[F:POQ]RCPQTYSTU
     Else
        WPRI = [F:PID]CPR*[F:PTD2]QTYSTU/[F:SHD]RCPQTYSTU
     Endif
     WPRI *=-1
  Else
  # Issue 110325 - 2016-01-11 by SR : FCC sur expé
    If LORI<4
      WPRI = [F:PID]CPR*[F:PTD2]QTYSTU/[F:POQ]RCPQTYSTU
    Else
      WPRI = [F:PID]CPR*[F:PTD2]QTYSTU/[F:SHD]RCPQTYSTU
    Endif
  Endif
  # End issue X3-112305
  #--- Issue 95710
  # Si avoir, il faut passer WPRI en négatif (en annulation de FCC, LORI = 90/91, cette ligne le repassera en positif)
  If [F:PID]PIHTYP>2 WPRI*=-1  Endif
  #---
  # Si désolde, il faut inverser WPRI
  # Issue 110325 - 2016-01-12 by SR : FCC sur expé
  #If LORI=3 : WPRI *= -1 : Endif
  If find(LORI,3,6) : WPRI *= -1 : Endif
  WPRI = arr(WPRI,10^-GDECPRI)

  If [F:ITM]SCSFLG<>2
    WTYP=3
    Gosub REGUL_PRI From TRTACHFAC1
  # Article sous-traitance
  # Issue 95354 GA 02/2014 la rcp se trouve dans [F:PTD2]
  # Issue 89807 GA 05/2013 si et seulement si OF ou EO, ne pas tester uniquement [F:ITM]SCSFLG=2
  # Elsif clalev([M:SBCK]) & find([F:PTD]VCRTYPORI,10,36)
   Elsif clalev([M:SBCK]) & find([F:PTD2]VCRTYPORI,10,36)
    [M:SBCK]MAJCOD = "F"
    [M:SBCK]RCPDAT = WIPTDAT
    [M:SBCK]ITMREF = [F:ITM]ITMREF
    [M:SBCK]PTHNUM = WVCRNUM
    [M:SBCK]PTDLIN = WVCRLIN
    [M:SBCK]VCRNUM = [F:PTD2]POHNUM
    [M:SBCK]VCRLIN = [F:PTD2]POPLIN
    If dim([M:SBCK]LINTYP)>0 : [M:SBCK]LINTYP=[F:PTD2]LINTYP : Endif
    [M:SBCK]INVQTY = WQTY
    [M:SBCK]CPLPRI = WPRI
    [M:SBCK]CPLCRG = 0
    # Annulation comptable : Avoir sur FCC
     If find(LORI,90,91) <> 0 & [F:PID]PIHTYP>2
      [M:SBCK]CPLPRI *= -1
     Endif
     # Issue X3-67828 - 2017-12-11 by SR: conversion du montant des éléments de facturation en devise société
     If [F:PID]CPRCUR <> [F:PIH]CUR
        Local   Decimal  WINVDTACST_DEV, WCOURS
        WINVDTACST_DEV = WINVDTACST
        Call CONVERT_PIH(WINVDTACST_DEV,WINVDTACST)
     Endif
     [M:SBCK]INVDTACST = WINVDTACST
     [M:SBCK]MSGFLG = 1
     Raz GMESSAGE
     Call MAJ_SBC From SBCLIB
     If [M:SBCK]CODRET<>0
        Gosub SBCK_ERROR  # Issue 109433 by GA 09/2015
     Endif
  Endif
Endif
Return

############################################################
# Issue 109433 by GA 09/2015 send correct PIH + error message
############################################################
$SBCK_ERROR
  #If GMESSAGE<>""
  #  Call ECR_TRACE([F:PIH]NUM-GMESSAGE,0)       From GESECRAN
  #Else
  #  Call ECR_TRACE([F:PIH]NUM-mess(96,193,1),0) From GESECRAN
  #Endif
  If [M:SBCK]VCRTYPORI=10
    GMESSAGE=[F:PIH]NUM-mess(96,193,1)-":"-GMESSAGE
  Elsif [M:SBCK]VCRTYPORI=36
    GMESSAGE=[F:PIH]NUM-mess(913,196,1)-":"-GMESSAGE
  Endif
Return
############################################################
# CONVERT_PIH :                   # Issue 102605 GA 12/2014
# use [F:PIH] informations to convert an amount or price
############################################################
Subprog CONVERT_PIH(MTORG,MTDES)
Value    Decimal MTORG            : # Montant origine
Variable Decimal MTDES            : # Montant destination

Local Integer WI,WSTAT: WSTAT=0
Local Decimal WRATCUR : WRATCUR=0
  #----- Prix net exprimé en devise société -----#
  WI=find(GLOCALDEV,[F:PIH]CURLED)
  If WI & [F:PIH]RATDIV(WI-1)<>0
    WRATCUR=[F:PIH]RATMLT(WI-1)/[F:PIH]RATDIV(WI-1)
  Else
    WRATCUR=0
  Endif
  If WRATCUR=0
    Call CONVERT2([F:PIH]CUR,GCUR,GCUR,[F:PIH]CURTYP,[F:PIH]RATDAT,MTORG,MTDES,
&                 WSTAT) From TRTDEV
  Else
    MTDES=MTORG*WRATCUR
  Endif
End

# Issue 121029 - 2017-01-25 by MUARN : les frais/remise et éléments de facturation valorisés en stock doivent être prix en compte
$CAL_CPR_PID
  If [F:PID]QTYUOM <> 0
    WPRI = [F:PID]NETPRI
  Else
    WPRI = [F:PID]AMTNOTLIN
  Endif
 #----- Eléments provenant du tarif -----#
 Raz WDISCRGVAL
 For I=1 To 9
   If GINVDTALIN(I-1)<>0 & GNPRNOTFLG(I-1)=1
     Read [PFI] PFI0=GINVDTALIN(I-1) : If fstat Raz [F:PFI] : Endif
     If [F:PFI]NPRVLT=2
       #----- C'est un montant -----#
       If GDISCRGTYP(I-1)=1
         If GCLCRUL(I-1)=1 : # Par unité
           WDISCRGVAL+=evalue("[F:PID]DISCRGVAL"+num$(I))*[F:PID]QTYUOM
         Else              : # Par ligne
           WDISCRGVAL+=evalue("[F:PID]DISCRGVAL"+num$(I))
         Endif
       #----- C'est un pourcentage -----#
       Else
         WDISCRGVAL+=arr([F:PID]AMTNOTLIN*evalue("[F:PID]DISCRGVAL"+num$(I))/100,WRND)
       Endif
     Endif
   Endif
 Next I
 If [F:PID]QTYUOM <>0
   WPRI += WDISCRGVAL / [F:PID]QTYUOM
 Else
   WPRI += WDISCRGVAL
 Endif
 #----- Eléments provenant du pied de facture -----#
 Raz WDISCRGAMT
 If !clalev([F:PVF2]) Local File PVCRFOOT [PVF2] : Endif
 Filter [F:PVF2] Where VCRTYP=8 & VCRNUM=[F:PID]NUM & INVLINFLG <> 6
 For [PVF2]
   If [F:PFI]PFINUM <> [F:PVF2]INVDTA
     Read [PFI] PFI0=[F:PVF2]INVDTA : If fstat Raz [F:PFI] : Endif
   Endif
   If [F:PFI]NPRVLT=2
     I=find([F:PVF2]INVDTA,[F:PIV]INVDTALIN2(0..8))
     If I<>0
       WDISCRGAMT+=evalue("[F:PID]DISCRGAMT"+num$(I))
     Endif
   Endif
 Next
 Filter [F:PVF2]
 If [F:PID]QTYUOM <>0
   WPRI += WDISCRGAMT / [F:PID]QTYUOM
 Else
   WPRI += WDISCRGAMT
 Endif
 If GNODVATSTO = 2
   #----- Taxes non déductible -----#
   WTAXE=[F:PID]AMTTAXLIN1-[F:PID]DEDTAXLIN1
   WTAXE+=[F:PID]AMTTAXLIN2-[F:PID]DEDTAXLIN2
   WTAXE+=[F:PID]AMTTAXLIN3-[F:PID]DEDTAXLIN3
   If dim([F:PID]AMTTAXRCP)>0
     WTAXE+=[F:PID]AMTTAXRCP-[F:PID]DEDTAXRCP
     WTAXE+=[F:PID]AMTTAXISS-[F:PID]DEDTAXISS
     WTAXE+=[F:PID]AMTTAXOTH1-[F:PID]DEDTAXOTH1
     WTAXE+=[F:PID]AMTTAXOTH2-[F:PID]DEDTAXOTH2
   Endif
   If [F:PID]QTYUOM <>0
     WPRI += WTAXE / [F:PID]QTYUOM
   Else
     WPRI += WTAXE
   Endif
 Endif
 # facture en devise
 If WPRI<>0 & GLOCALDEV<>[F:PIH]CUR
   Call CONVERT_PIH(WPRI,WPRI)
 Endif
Return

$CAL_CPR_PTD
 WPRIORI = [F:PTD]NETPRI
 #----- Eléments provenant du tarif -----#
 Raz WDISCRGVAL
 For I=1 To 9
   If GINVDTALIN(I-1)<>0 & GNPRNOTFLG(I-1)=1
     Read [PFI] PFI0=GINVDTALIN(I-1) : If fstat Raz [F:PFI] : Endif
     If [F:PFI]NPRVLT=2
       #----- C'est un montant -----#
     If GDISCRGTYP(I-1)=1
       If GCLCRUL(I-1)=1 : # Par unité
         WDISCRGVAL+=evalue("[F:PTD]DISCRGVAL"+num$(I))*[F:PTD]QTYUOM
       Else              : # Par ligne
         WDISCRGVAL+=evalue("[F:PTD]DISCRGVAL"+num$(I))
       Endif
     #----- C'est un pourcentage -----#
     Else
       WDISCRGVAL+=arr([F:PTD]LINAMT*evalue("[F:PTD]DISCRGVAL"+num$(I))/100,WRND)
       Endif
     Endif
   Endif
 Next I
 If [F:PTD]QTYUOM <>0
   WPRIORI += WDISCRGVAL / [F:PTD]QTYUOM
 Else
   WPRIORI += WDISCRGVAL
 Endif
 #----- Eléments provenant du pied de facture -----#
 Raz WDISCRGAMT
 If !clalev([F:PVF2]) Local File PVCRFOOT [PVF2] : Endif
 Filter [F:PVF2] Where VCRTYP=6 & VCRNUM=[F:PID]PTHNUM & INVLINFLG <> 6
 For [PVF2]
   If [F:PFI]PFINUM <> [F:PVF2]INVDTA
     Read [PFI] PFI0=[F:PVF2]INVDTA : If fstat Raz [F:PFI] : Endif
   Endif
   If [F:PFI]NPRVLT=2
     I=find([F:PVF2]INVDTA,[F:PTH]INVDTALIN2(0..8))
     If I<>0
       WDISCRGAMT+=evalue("[F:PTD]DISCRGAMT"+num$(I))
     Endif
   Endif
 Next
 Filter [F:PVF2]
 If [F:PTD]QTYUOM <>0
   WPRIORI += WDISCRGAMT / [F:PTD]QTYUOM
 Else
   WPRIORI += WDISCRGAMT
 Endif
 If GNODVATSTO = 2
   #----- Taxes non déductible -----#
   WTAXE=[F:PTD]AMTTAXLIN1-[F:PTD]DEDTAXLIN1
   WTAXE+=[F:PTD]AMTTAXLIN2-[F:PTD]DEDTAXLIN2
   WTAXE+=[F:PTD]AMTTAXLIN3-[F:PTD]DEDTAXLIN3
   If dim([F:PTD]AMTTAXRCP)>0
     WTAXE+=[F:PTD]AMTTAXRCP-[F:PTD]DEDTAXRCP
     WTAXE+=[F:PTD]AMTTAXISS-[F:PTD]DEDTAXISS
     WTAXE+=[F:PTD]AMTTAXOTH1-[F:PTD]DEDTAXOTH1
     WTAXE+=[F:PTD]AMTTAXOTH2-[F:PTD]DEDTAXOTH2
   Endif
   If [F:PTD]QTYUOM <>0
     WPRIORI += WTAXE / [F:PTD]QTYUOM
   Else
     WPRIORI += WTAXE
   Endif
 Endif

 If WPRIORI<>0 & GLOCALDEV<>[F:PTH]CUR
   WMT=WPRIORI
   If GPTHCURDAT<>2 & [F:PTD]POHNUM<>""
         If [F:POH]POHNUM<>[F:PTD]POHNUM
           Read [POH] POH0=[F:PTD]POHNUM
           If fstat
             Raz [F:POH] : [F:POH]ORDDAT=[F:PTH]RCPDAT : [F:POH]CHGTYP=[F:PTH]CHGTYP
           Endif
         Endif
         Call CONVERT2([F:PTH]CUR,GLOCALDEV,GLOCALDEV,[F:POH]CHGTYP,[F:POH]ORDDAT,
&                   WMT,WPRIORI,STAT) From TRTDEV
         WPRIORI=arr(WPRIORI,10^-GDECPRI)
       Else
         If [F:PTH]CHGCOE=0
           Call CONVERT2([F:PTH]CUR,GLOCALDEV,GLOCALDEV,[F:PTH]CHGTYP,[F:PTH]RCPDAT,
&                     WMT,WPRIORI,STAT) From TRTDEV
           WPRIORI=arr(WPRIORI,10^-GDECPRI)
         Else
           WPRIORI=arr(WMT*[F:PTH]CHGCOE,10^-GDECPRI)
         Endif
       Endif
     Endif
Return

