######################################################################################
##### SPEYT0  --- Precios liquidaciones                       REV - JGM - 19/03/08 ###
######################################################################################
##XVT201-05-20 Migración a V11
##v11
#XVT210520 - S3501 - Filtro adicional por Régimen impuesto proveedor tercero-sociedad
#XVT160620 - Elena solicita poder modificar/añadir/borrar terceros aunque ya se existan terceros
# con facturas. Para ello, deberá recalcularse las líneas de artículos.
#XVT040720 - Propuesta terceros y artículos sólo de recepciones no saldadas
$ACTION
#If GUSER="eclipse" or GUSER ="ADMIN" Then Dbgaff : Endif
#Infbox ACTION
    Case ACTION
        When "OUVRE"            : Gosub OUVRE
        When "INICRE"           : Gosub INICRE
        When "CREATION"         : Gosub CREATION
        When "LIENS"            : Gosub LIENS
        When "MODIF"            : Gosub MODIF
        When "ANNULE"           : Gosub ANNULE
        When "CONTROLE"         : Gosub CONTROLE
        When "PICKE"            : Gosub PICKE
        When "DEPICK"           : Gosub DEPICK
        When "OUVRE_BOITE"      : Gosub OUVRE_BOITE
        When "TIROIR"           : Gosub TIROIR
        When "AP_FILGAUCHE"     : Gosub AP_FILGAUCHE
        When "SETBOUT"          : Gosub SETBOUT
        When "FIN_PICK"         : Gosub FIN_PICK
        When "AVANT_MODFIC"     : Gosub AVANT_MODFIC
        When "AVANT_MOD"        : Gosub AVANT_MOD
        When "EXEC"             : Gosub EXEC
        When "AV_IMPRIME"       : Gosub AV_IMPRIME
        When "ABANDON"          : Gosub ABANDON
        When "FILTRE"           : Gosub FILTRE
        When "FILGAUCHE"        : Gosub FILGAUCHE
        When "RAZCRE"           : Gosub RAZCRE
        When "RAZDUP"           : Gosub RAZDUP
        When "EXEBOUT"          : Gosub EXEBOUT
        When Default
    Endcase
Return
#v11.n       Eliminamos la gestión por transacciones en esta pantalla
#v11.o       When "VARIANTE"         : Gosub VARIANTE
#v11.o       When "SETTRANS"         : Gosub SETTRANS
######################################################################################
$OUVRE
#v11.o    If clalev([F:YTD])=0 : Local File YTIPDOC    [YTD] : Endif
    If clalev([F:TCA])=0 : Local File TABCOUAFF  [TCA] : Endif
    If clalev([F:ITM])=0 : Local File ITMMASTER  [ITM] : Endif
#v11.o    If clalev([F:YCC])=0 : Local File YCLASTAD   [YCC] : Endif
#v11.o    If clalev([F:YCL])=0 : Local File YCLASIFIC  [YCL] : Endif
    If clalev([F:YCS])=0 : Local File YCALSTAD   [YCS] : Endif
    If clalev([F:YCA])=0 : Local File YCALIDAD   [YCA] : Endif
#v11.o    If clalev([F:YPY])=0 : Local File YPARANY    [YPY] : Endif
    If clalev([F:ZCAM])=0 : Local File ZCAMPANYA  [ZCAM] : Endif
    If clalev([F:PTD])=0 : Local File PRECEIPTD  [PTD] : Endif
    If clalev([F:STJ])=0 : Local File STOJOU     [STJ] : Endif
#V11.o    If clalev([F:YTT])=0 : Local File YTRANSAC   [YTT] : Endif
    If clalev([F:YLC])=0 : Local File YTPLINPER  [YLC] : Endif
    If clalev([F:PND])=0 : Local File PRETURND   [PND] : Endif
    If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
    If clalev([F:YPS])=0 : Local File YPERSEC    [YPS] : Endif
#v11.o    If clalev([F:YTG])=0 : Local File YTPLINGRUP [YTG] : Endif
    If clalev([F:FCY])=0 : Local File FACILITY   [FCY] : Endif
    If clalev([F:PTD])=0 : Local File PRECEIPTD  [PTD] : Endif
    If clalev([F:BPR])=0 : Local File BPARTNER   [BPR] : Endif
#v11.o    If clalev([F:YLP])=0 : Local File YPCLINPER  [YLP] : Endif

    If clalev([M:YTS4])=0 : Local Mask YSELYT04   [YST4] : Endif
    If clalev([M:YTS2])=0 : Local Mask YSELYT02   [YST2] : Endif

    If clalev([F:SID])=0 : Local File SINVOICED  [SID] : Endif
    If clalev([F:SIV])=0 : Local File SINVOICEV  [SIV] : Endif
#    If clalev([F:YAN])=0 : Local File YANTICIP   [YAN] : Endif
    If clalev([F:PID])=0 : Local File PINVOICED  [PID] : Endif
    If clalev([F:PIH])=0 : Local File PINVOICE   [PIH] : Endif
    If clalev([F:ZPTH])=0 : Local File ZPRECEIPT[ZPTH] : Endif
    If clalev([F:PTH])=0 : Local File PRECEIPT   [PTH] : Endif
    If clalev([F:BPE])=0 : Local File BPEXCEPT   [BPE] : Endif   #XVT210520.n


    GLOCSEL="STOFCY=[M:YT00]FCY"

    Local Char VFCYDEB(5), VFCYFIN(5)
    Local Char VBPSINI(20), VBPSFI(20)
    Local Char GNUM
    Local Integer STAT
    Local Integer CEXEBOUT : CEXEBOUT=0 #XVT POR ALGÚN MOTIVO SE ESTÁ EJECUTANDO DOS VECES CADA ACCIÓN
    Local Integer NOL
    Local Integer FYG
    #CONTROLAMOS QUE EL BOTÓN EXEBOUT SÓLO SE LLAME UNA VEZ.
Return
######################################################################################
$EXEC
    Local   Integer   SALIR_REG

    If GACTION ="YT05"
        Call TEMPON("C") From GESECRAN
        Call COMPROBAR_REG(SALIR_REG)
        If SALIR_REG <> 2
            Call BUSCAR_COMPRAS
            Call BUSCAR_VENTAS
            Call BUSCAR_ANTICIPOS
        Endif
        Call TEMPOFF From GESECRAN
    Endif
Return

$EXEBOUT
#XVT POR ALGÚN MOTIVO SE ESTÁ EJECUTANDO DOBLE EL EXEBOUT. SOLO HA DE EJECUTARSE LA PRIMERA LLAMADA
  If CEXEBOUT Then
    CEXEBOUT=0
    Return
  Endif
  If BOUT="3" : CEXEBOUT+=1 : Gosub PROPOSTA_TERCER : Endif
  If BOUT="4" : CEXEBOUT+=1 : Gosub PROPOSTA_ARTICLE : Endif
Return
######################################################################################
$RAZCRE
  Raz GNUM
#v11.bo
#    Diszo [M:YT05]
#    Diszo [M:YT06]
#    Diszo [M:YT07]
#v11.eo
Return
######################################################################################
$RAZDUP
#v11.bo
#    Diszo [M:YT05]
#    Diszo [M:YT06]
#    Diszo [M:YT07]
#v11.eo
Return
######################################################################################
$INICRE
  #Infbox "inicre" + GREP
    #Ponemos el test a activo cuando estamos en importación
    #If GIMPORT Then : [F:YT0]TACTIU=2 : Endif
    If (GREP="C" or GREP = "D")
        #Estamos creando un nuevo documento. Pasaremos a asignar un nuevo contador.
        #Si GREP="D", estamos en duplicación (modificación del número de orden),
        #eL contador debe ser el mismo que el del albaran origen
         #Ya ha volcado los datos al buffer del fichero y vamos a llamar la rutina de contadores
          GOK=1
          If GNUM="" Then
            Call NUMERO("ZPRLI",[M]FCY,date$,"",GNUM,STAT) From SUBANM
            If STAT<>0
                GERR=1 : GMESSAGE=mess(60,199,1): GOK=0 : End
            Endif
          Endif
        [F:YT0]NUMDOC=GNUM
        [M:YT00]NUMDOC=GNUM

        Affzo [M:YT00]NUMDOC
    Endif
    If GREP="C" Then
      Raz [M:YT03]
      Raz [M:YT02]
    Endif
    # Si estamos duplicando, borrar la columna de Nº de Factura
    If GREP="D" Then
      For I = 0 To [M:YT03]NBPER
        [M:YT03]ZNUMFAC(I) = ''
        [M:YT03]TFACGEN(I) = 1
      Next I
    Endif
Return
######################################################################################
$CREATION
    Call ACTU_YTPLINPER
 #v11.o   Call ACTU_YTPLINGRUP
    Call ACTU_YTPLINEAS
 #v11.o   Call ACTU_YTPCOM
 #v11.o   Call ACTU_YTPVEN
 #v11.o   Call ACTU_YTPANT
    Call GENERA_TPLINEAS
Return
######################################################################################
$MODIF
    Call DEL_YTPLINPER
    Call ACTU_YTPLINPER
#v11.o    Call DEL_YTPLINGRUP
#v11.o    Call ACTU_YTPLINGRUP
    Call DEL_YTPLINEAS
    Call ACTU_YTPLINEAS
#v11.o    Call DEL_YTPCOM
#v11.o    Call ACTU_YTPCOM
#v11.o    Call DEL_YTPVEN
#v11.o    Call ACTU_YTPVEN
#v11.o    Call DEL_YTPANT
#v11.o    Call ACTU_YTPANT

    Call GENERA_TPLINEAS
Return
######################################################################################
$ANNULE
#    Call ELIMINAR_DOCUMENTOS
    Gosub FACTURAS_YA_GENERADAS
    If FYG Then
       Call MESSAGE ("Imposible borrar: existen facturas asociadas a este registro") From GESECRAN
       GOK=0
    Else
      Call DEL_YTPLINEAS
      Call DEL_YTPLINPER
    Endif
Return

$FACTURAS_YA_GENERADAS
 NOL=0
 FYG=0
    For NOL=0 To [M:YT03]NBPER-1
        If [M:YT03]TFACGEN(NOL)=2 Then
          FYG=1

        Endif
    Next
Return
######################################################################################
$LIENS

    Gosub LIENS_YTPLINPER
    Gosub LIENS_YTPLINEAS
