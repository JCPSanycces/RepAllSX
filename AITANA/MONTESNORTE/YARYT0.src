######################################################################################
#v11.oSubprog CREA_LINEA(PUNTER,TROBAT_CAL,TROBAT_REC)
Subprog CREA_LINEA(PUNTER)  #v11.n
    Value Integer PUNTER
    #v11.oValue Integer TROBAT_CAL
    #v11.oValue Integer TROBAT_REC
    #v11.o Local Char CALIDAD
    #v11.oLocal Char RECOLL

#v11.oIf TROBAT_CAL <> 2 : CALIDAD = [F:PTD]YCALIDAD : Endif
#v11.oIf TROBAT_REC <> 2 : RECOLL  = [F:PTD]YRECOLL : Endif
#    If [M:YT02]ITMREF(PUNTER)="70001" and [M:YT02]CALIDAD(PUNTER)="" Then
#          Infbox "C "+ [F:PTD]PTHNUM
#    Endif
    [M:YT02]NUMLIN(PUNTER)     = (PUNTER + 1) * 1000
    [M:YT02]ITMREF(PUNTER)     = [F:PTD]ITMREF
#v11.o    [M:YT02]CODI1(PUNTER)      = [F:PTD]TSICOD(0)
#v11.o    [M:YT02]CODI2(PUNTER)      = [F:PTD]TSICOD(1)
#v11.o    [M:YT02]CODI3(PUNTER)      = [F:PTD]TSICOD(2)
    [M:YT02]CALIDAD(PUNTER)    = [F:PTD]ZCALIDAD
#v11.o    [M:YT02]CALIBRE(PUNTER)    = ""
#v11.o    [M:YT02]RECOLL(PUNTER)     = RECOLL
#v11.o    [M:YT02]DATAINI(PUNTER)    = [M:YT00]DATAINIEX
#v11.o    [M:YT02]DATAFI(PUNTER)     = [M:YT00]DATAFIEX
    [M:YT02]TIPO(PUNTER)       = 1
    [M:YT02]ZCANT1(PUNTER)  = [F:PTD]ZCANT1
    [M:YT02]ZCANT2(PUNTER)  = [F:PTD]ZCANT2
    [M:YT02]PREU1(PUNTER)   = 0
    [M:YT02]IMPORTE1(PUNTER)= 0
    [M:YT02]QTYSTU(PUNTER)  = [F:PTD]QTYSTU
    [M:YT02]QTYFAC(PUNTER)  = 1
#v11.o    [M:YT02]QUANTITAT1(PUNTER) = 0
#v11.o    [M:YT02]QUANTITAT2(PUNTER) = 0
#v11.o    [M:YT02]QUANTITAT3(PUNTER) = 0
    [M:YT02]NBLIG=PUNTER + 1
End
######################################################################################
Subprog ACUMULAR(PUNTER)
    Value Integer PUNTER
#    Local Integer K
#    If [M]CODIPERSON(PUNTER) = ""
#        K=find([F:PTD]BPSNUM,[M:YT03]CODIPERSON(0..[M:YT03]NBPER-1))
#    Else
#        K =0
#        If [M]CODIPERSON(PUNTER) = [F:PTD]BPSNUM : K = 1 : Endif
#    Endif
#    If (K>0)
#      If [M:YT02]ITMREF(PUNTER)="70001" and [M:YT02]CALIDAD(PUNTER)="" Then
#          Infbox "C "+ [F:PTD]PTHNUM
#    Endif
        [M:YT02]QTYSTU(PUNTER) += [F:PTD]QTYSTU
        [M:YT02]ZCANT1(PUNTER) += [F:PTD]ZCANT1
        [M:YT02]ZCANT2(PUNTER) += [F:PTD]ZCANT2
#    Endif
End
######################################################################################
Subprog DESACUMULAR(PUNTER)
    Value Integer PUNTER
    Local Integer K
    If [M]CODIPERSON(PUNTER) = ""
        K=find([F:PND]BPSNUM,[M:YT03]CODIPERSON(0..[M:YT03]NBPER-1))
    Else
        K =0
        If [M]CODIPERSON(PUNTER) = [F:PND]BPSNUM : K = 1 : Endif
    Endif
      If (K>0)
          If (K>0)
          [M:YT02]QTYSTU(PUNTER) -= [F:PTD]QTYSTU
          [M:YT02]ZCANT1(PUNTER) -= [F:PTD]ZCANT1
          [M:YT02]ZCANT2(PUNTER) -= [F:PTD]ZCANT2
      Endif
    Endif
End
######################################################################################
$PROPOSTA_TERCER
    Local Integer P
    Local Integer I
    Local Integer G
    Local Integer SWCREA
    Local Integer SALTAR_TERCERO #XVT210520.n

    Local Char CRITERE(250)
#  MAB.28102019.
#      If (NBPER<>0) #v11.o| [M:YT03]CODIPERSON(nolign-1)<>"")
##        End
#        Return
#    Endif
    Gosub DEF_LIMITS_TERCER
    P=0
    Call TEMPON("C") From GESECRAN

#v11.bo    CRITERE = " [BPR]YTIPSOC >= [M:YST4]YTIPSOCINI and [BPR]YTIPSOC <= [M:YST4]YTIPSOCFI"
#    If [M:YST4]YNUMSOCINI <> "" and [M:YST4]YNUMSOCFI <> ""
#        CRITERE += " and [BPR]YNUMSOC >= [M:YST4]YNUMSOCINI and [BPR]YNUMSOC <= [M:YST4]YNUMSOCFI"
#v11.eo    Endif

    Read [F:FCY]FCY0=[M:YT00]FCY
    VCFYDEB="" : VFCYFIN="ZZZZZ"

    Link [YPS] With [BPR]BPR0=CODIPERSON As [YCC] Where [YPS]CODIPERSON >= VBPSINI and
& [YPS]CODIPERSON <= VBPSFI and [YPS]TIPOFCY = [M:YT00]TIPOFCY and [YPS]ACTIVO=2
&  and [YPS]CPY = [F:FCY]LEGCPY
&  and ([YPS]TIPOREL >=[M:YT00]TIPORELDEB and
& [YPS]TIPOREL <= [M:YT00]TIPORELFIN)

    For [YCC]
      #XVT210520.bn
      Read [F:BPE]BPE0=[YCC]CODIPERSON;[F:FCY]LEGCPY
      If !fstat Then

        SALTAR_TERCERO=1  #POR DEFECTO SALTAR
        If [M:YT00]VAC1 + [M:YT00]VAC2 + [M:YT00]VAC1 = "" Then
          SALTAR_TERCERO=0
        Else
          If [M:YT00]VAC1 = [F:BPE]VACBPS or
&          [M:YT00]VAC2 = [F:BPE]VACBPS or
&          [M:YT00]VAC3 = [F:BPE]VACBPS Then
            SALTAR_TERCERO=0
          Else
            SALTAR_TERCERO=1
          Endif
        Endif
      Endif

    If !SALTAR_TERCERO Then
      #XVT210520.en

#v11.o        If ([M:YT04]TOTENTRAT=2) Then
#V11.o            Read [FCY]FCY0= [M:YT00]FCY  #ya tenemos el dato
#v11.o            If fstat=0
                ## Filtre per personal, tipus de planta i que no estigui totalment facturat

#V11.bn - filtro para comprobar el tipo de planta de cada línea de recepción.

      If [M:YT00]FCYDEB<>"" and [M:YT00]FCYFIN<>"" : VFCYDEB=[M:YT00]FCYDEB : VFCYFIN=[M:YT00]FCYFIN : Endif

      Link [PTD] With [FCY]FCY0=[F:PTD]PRHFCY, [PTH]PTH0=[PTD]PTHNUM As [RES2]
&     Where [PTD]BPSNUM=[YCC]CODIPERSON
&     and [PTH]ZEJERCICIO=[M:YT00]EJERCICIO
&     and [FCY]FINRSPFCY=[M:YT00]FCY
&     and [FCY]YTIPOFCY=[M:YT00]TIPOFCY
&     and [PTD]PRHFCY>=VFCYDEB and [PTD]PRHFCY<=VFCYFIN and [PTD]RCPDAT>=[M:YT00]FECHAINI
&     and [PTD]RCPDAT<=[M:YT00]FECHAFIN and [PTD]INVQTYSTU=0

      Read [RES2] First
      If !fstat
        Call CREA_LINEA_TERCER(P,[F:YPS]CODIPERSON)
        P+=1
      Endif
#v11.en

#v11.bo                Filter [PTD] Where BPSNUM=[F:YPS]CODIPERSON and YTIPOFCY=[F:FCY]YTIPOFCY and LININVFLG<2
#                Read [PTD]First

#v11.o                    Call CREA_LINEA_TERCER(P,[F:YPS]CODIPERSON)
#v11.o                    P+=1
#v11.o                Endif
#v11.o            Endif
#v11.o        Else
     Endif #saltar tercero  #XVT210520.n
    Next

    NBPER=P
    If P>0 : Affzo [M:YT03] : Endif

# activem el boto de registrar i treiem el tempon
#   Filter [PTD]
    mkstat=4
    Call TEMPOFF From GESECRAN

Return
######################################################################################
Subprog CREA_LINEA_TERCER(PUNTER,TERCER)
    Value Integer PUNTER
    Value Char    TERCER

    [M:YT03]NUMLIN(PUNTER)     = (PUNTER + 1) * 1000
    [M:YT03]CODIPERSON(PUNTER) = TERCER
#v11.o    [M:YT03]DATA(PUNTER)       = date$
#v11.o    [M:YT03]REFERENCIA(PUNTER) = ""
#v11.o    [M:YT03]TESTACTIU(PUNTER)  = 2
    [M:YT03]TFACGEN(PUNTER)    = 1
    [M:YT03]NBPER              = PUNTER + 1
End
######################################################################################
#Código al entrar al objeto destino
Subprog ENTRADA_CODIGO_DOCUM()

End
######################################################################################
#Código al devolver del objeto
Subprog SALIDA_CODIGO_DOCUM()

    If [F:YRE]OBJETO_D="YC1" or [F:YRE]OBJETO_D="YC2" Then
        #Grabar los parámetros devueltos por el documento relacionado
        Call GRABAR_PARAMETROS_SALIDA() From YSELAGRO
        If [F:YRE]OBJETO_D="YC1" Then
            [M:YT00]YDOCCAL=[M:YT02]YDOCCAL(GYLIN)
        Elsif [F:YRE]OBJETO_D="YC2" Then
            [M:YT00]YDOCCLA=[M:YT02]YDOCCLA(GYLIN)
        Endif
        Raz GYSTIPO
        Raz GYSPARAM
        mkstat=4
    Endif
End
######################################################################################
Subprog FORMATEJAR_TIPO
    If (NBLIG=0 | [M:YT02]ITMREF(nolign-1)="" | [M:YT02]TIPO(nolign-1)=1)
        #Tipo por Recepción
        GBOUT2=""
        Actzo [M:YT02]PREU1(nolign-1)
        Actzo [M:YT02]IMPORTE1(nolign-1)
#V11.BO    Elsif (NBLIG=0 | [M:YT02]ITMREF(nolign-1)="" | [M:YT02]TIPO(nolign-1)=2)
#        #Tipo por calibres
#        GBOUT2=mess(37,1986,1)
#        Grizo [M:YT02]PREU1(nolign-1)
#        Grizo [M:YT02]IMPORTE1(nolign-1)
#    Elsif (NBLIG=0 | [M:YT02]ITMREF(nolign-1)="" | [M:YT02]TIPO(nolign-1)=3)
#        #Tipo por calidad
#        GBOUT2=mess(37,1986,1)
#        Actzo [M:YT02]PREU1(nolign-1)
#        Actzo [M:YT02]IMPORTE1(nolign-1)
#    Elsif (NBLIG=0 | [M:YT02]ITMREF(nolign-1)="" | [M:YT02]TIPO(nolign-1)=5)
#        #Tipo por Liquidación
#        GBOUT2=""
#        Actzo [M:YT02]PREU1(nolign-1)
#V11.EO        Actzo [M:YT02]IMPORTE1(nolign-1)
    Endif
End
######################################################################################
Subprog FORMATEJAR_TIPO_YT04
    If (NBGRP=0 | [M:YT04]ITMREF(nolign-1)="" | [M:YT04]TIPO(nolign-1)=1)
        #Tipo por Recepción
        GBOUT2=""
        Actzo [M:YT04]PREU1(nolign-1)
        Actzo [M:YT04]IMPORTE1(nolign-1)
    Elsif (NBGRP=0  | [M:YT04]ITMREF(nolign-1)="" | [M:YT04]TIPO(nolign-1)=2)
        #Tipo por calibres
        GBOUT2=mess(37,1986,1)
        Grizo [M:YT04]PREU1(nolign-1)
        Grizo [M:YT04]IMPORTE1(nolign-1)
    Elsif (NBGRP=0 | [M:YT04]ITMREF(nolign-1)="" | [M:YT04]TIPO(nolign-1)=3)
        #Tipo por calidad
        GBOUT2=mess(37,1986,1)
        Actzo [M:YT04]PREU1(nolign-1)
        Actzo [M:YT04]IMPORTE1(nolign-1)
    Elsif (NBGRP=0 | [M:YT04]ITMREF(nolign-1)="" | [M:YT04]TIPO(nolign-1)=5)
        #Tipo por Liquidación
        GBOUT2=""
        Actzo [M:YT04]PREU1(nolign-1)
        Actzo [M:YT04]IMPORTE1(nolign-1)
    Endif
End
######################################################################################
Subprog RECALCULAR_CANTIDAD
    Local Integer P
    Local Integer I
    Local Integer SWCREA
    Local Char SENTENCIA(254)

    If [M:YT01]TIPOGASTO=2 Then : End : Endif

    P=0
    Call TEMPON("C") From GESECRAN

    For I=0 To [M:YT02]NBLIG-1

        If [M:YT01]MULTIFCY = 2
            SENTENCIA = "[F:PTD]YTIPOFCY = [M:YT01]TIPOFCY "
        Else
            SENTENCIA = "[F:PTD]PRHFCY=[M:YT00]FCY "
        Endif

        If [M:YT02]CALIDAD(I)<>"" Then
            SENTENCIA += "& [F:PTD]YCALIDAD = [M:YT02]CALIDAD(I) "
        Endif
        If [M:YT02]RECOLL(I)<>"" Then
            SENTENCIA += "& [F:PTD]YRECOLL = [M:YT02]RECOLL(I) "
        Endif

        Filter [PTD] Where [F:PTD]LININVFLG<2 &
&       [F:PTD]RCPDAT   >= [M:YT02]DATAINI(I) &
&       [F:PTD]RCPDAT   <= [M:YT02]DATAFI(I)  &
&       [F:PTD]ITMREF   = [M:YT02]ITMREF(I)  &
&        evalue(SENTENCIA)

        [M:YT02]QUANTITAT1(I) = 0
        If [M:YT00]CLASEDOC<>29 Then
            [M:YT02]QUANTITAT2(I) = 0
            [M:YT02]QUANTITAT3(I) = 0
        Endif

        Default Mask [M:YT02]

        For [PTD]
              Call ACUMULAR(I)
        Next

        Filter [PTD]

        If [M:YT01]MULTIFCY = 2
            SENTENCIA = "[F:PND]YTIPOFCY = [M:YT01]TIPOFCY "
        Else
            SENTENCIA = "[F:PND]PNHFCY=[M:YT00]FCY "
        Endif

        If [M:YT02]CALIDAD(I)<>"" Then
            SENTENCIA += "& [F:PND]YCALIDAD = [M:YT02]CALIDAD(I) "
        Endif
        If [M:YT02]RECOLL(I)<>"" Then
            SENTENCIA += "& [F:PND]YRECOLL = [M:YT02]RECOLL(I) "
        Endif

        Filter [PND] Where [F:PND]LININVFLG<2 &
&       [F:PND]RTNDAT   >= [M:YT02]DATAINI(I) &
&       [F:PND]RTNDAT   <= [M:YT02]DATAFI(I)  &
&       [F:PND]ITMREF   = [M:YT02]ITMREF(I)  &
&       evalue(SENTENCIA)

        For [PND]
              Call DESACUMULAR(I)
        Next

        Filter [PND]

        [M:YT02]IMPORTE1(I) = [M:YT02]QUANTITAT1(I) * [M:YT02]PREU1(I)
        Call ARRDEV(IMPORTE1(I), GLOCALDEV) From TRTDIV
        [M:YT02]UPDFLG(I) = 1

    Next

    Call TEMPOFF From GESECRAN
    Affzo [M:YT02]
#v11.bo   If [M:YT01]PRODUCTO<>2 Then
#        Call RECALCULAR_CANTIDAD_GRUPO
#v11.eo    Endif
End
