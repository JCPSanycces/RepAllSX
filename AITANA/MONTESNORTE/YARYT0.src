#
#    Call TEMPOFF From GESECRAN
#    Affzo [M:YT04]
#v11.eo   End
######################################################################################
#### ----    PICKING DE PROVEEDORES
######################################################################################
$OUVRE_BOITE
    Global Char     GBOXYBP(10)
    Global Char     GBOXPOH(10)

    GBOXYBP = "GAU_CHE"+num$(find("YBP",OBJLIS(1..8)))
    GBOXPOH = "GAU_CHE"+num$(find("POH",OBJLIS(1..8)))
Return
######################################################################################
$PICKE
    Local Integer    ZLIN : ZLIN = 0

    If currbox = GBOXYBP
        Local Integer X
        X=find([F:BPS]BPSNUM,[M:YT03]CODIPERSON(0..[M:YT03]NBPER-1))
        If X : Return : Endif

        [M]NBPER +=1
        nolign = [M]NBPER
        [M:YT03]CODIPERSON(nolign-1) = [F:BPS]BPSNUM
        [M:YT03]NUMLIN(nolign-1) = nolign
        [M:YT03]CREFLG(nolign-1)=0
        status = 0

        Affzo [M:YT03]10
        Affzo [M:YT03]CODIPERSON
    Endif

    If currbox = GBOXPOH
        ###--- Si la tabla de precios es Tipo de Tecero = Tecero Factura
        If [M:YT01]TBPR <=1

            Local Integer X
            X=find([F:POH]BPSNUM,[M:YT03]CODIPERSON(0..[M:YT03]NBPER-1))
            If X : Return : Endif

            [M]NBPER +=1
            nolign = [M]NBPER
            [M:YT03]CODIPERSON(nolign-1) = [F:POH]BPSNUM
            [M:YT03]NUMLIN(nolign-1) = nolign
            [M:YT03]CREFLG(nolign-1)=0
            status = 0

            Affzo [M:YT03]10
            Affzo [M:YT03]CODIPERSON
        Elsif [M:YT01]TBPR = 2
            Local Integer X
            X=find([F:POH]BPSNUM,[M:YT03]CODIPERSON(0..[M:YT03]NBPER-1))
            If X : Return : Endif

            [M]NBPER +=1
            nolign = [M]NBPER
            Read [BPS]BPS0 = [F:POH]BPSNUM
            If fstat
                Raz [F:BPS]
                Return
            Endif

            [M:YT03]CODIPERSON(nolign-1) = [F:BPS]BPSINV
            [M:YT03]POHNUM(nolign-1) = [F:POH]POHNUM
            [M:YT03]NUMLIN(nolign-1) = nolign
            [M:YT03]CREFLG(nolign-1)=0
            status = 0

            Affzo [M:YT03]10
            Affzo [M:YT03]CODIPERSON


        Elsif [M:YT01]TBPR = 3

            For [YLP] Where POHNUMP = [F:POH]POHNUM
                ZLIN +=1

                Local Integer X
                X=find([F:YLP]CODIPERSON,[M:YT03]CODIPERSON(0..[M:YT03]NBPER-1))
                If X : Return : Endif

                [M]NBPER +=1
                nolign = [M]NBPER

                [M:YT03]CODIPERSON(nolign-1) = [F:YLP]CODIPERSON
                [M:YT03]POHNUM(nolign-1) = [F:POH]POHNUM
                [M:YT03]NUMLIN(nolign-1) = nolign
                [M:YT03]CREFLG(nolign-1)=0
                status = 0

                Affzo [M:YT03]10
                Affzo [M:YT03]CODIPERSON
            Next

            If ZLIN = 0
                Local Integer X
                X=find([F:POH]BPSNUM,[M:YT03]CODIPERSON(0..[M:YT03]NBPER-1))
                If X : Return : Endif

                [M]NBPER +=1
                nolign = [M]NBPER

                [M:YT03]CODIPERSON(nolign-1) = [F:POH]BPSNUM
                [M:YT03]POHNUM(nolign-1) = [F:POH]POHNUM
                [M:YT03]NUMLIN(nolign-1) = nolign
                [M:YT03]CREFLG(nolign-1)=0
                status = 0

                Affzo [M:YT03]10
                Affzo [M:YT03]CODIPERSON
            Endif

        Endif
    Endif
Return
######################################################################################
$DEPICK
    If currbox = GBOXYBP
        Local Integer LINEA,J
        J = 0
        OK = 0
        If ([M:YT03]NBPER<>0)
           While (OK<>1)
                LINEA= find([F:BPS]BPSNUM,[M:YT03]CODIPERSON(J..[M:YT03]NBPER-1))
                If !LINEA OK = 1 : Break : Endif
                If [M:YT03]CREFLG(LINEA-1)=0
                    NOL = J+LINEA-1
                    Dela NOL,1,[M:YT03]NBPER-1 [M:YT03]NBPER
                    [M:YT03]NBPER-=1
                    J=J+LINEA
                Else
                    OK=1
                Endif
            Wend
        Endif
    Endif

    If currbox = GBOXPOH
        Local Integer LINEA,J

        If [M:YT01]TBPR <=1
            J = 0
            OK = 0
            If ([M:YT03]NBPER<>0)
               While (OK<>1)
                    LINEA= find([F:POH]BPSNUM,[M:YT03]CODIPERSON(J..[M:YT03]NBPER-1))
                    If !LINEA OK = 1 : Break : Endif
                    If [M:YT03]CREFLG(LINEA-1)=0
                        NOL = J+LINEA-1
                        Dela NOL,1,[M:YT03]NBPER-1 [M:YT03]NBPER
                        [M:YT03]NBPER-=1
                        J=J+LINEA
                    Else
                        OK=1
                    Endif
                Wend
            Endif
        Else

            J = 0
            OK = 0
            If ([M:YT03]NBPER<>0)
               While (OK<>1)
                    LINEA= find([F:POH]POHNUM,[M:YT03]POHNUM(J..[M:YT03]NBPER-1))
                    If !LINEA OK = 1 : Break : Endif
                    If [M:YT03]CREFLG(LINEA-1)=0
                        NOL = J+LINEA-1
                        Dela NOL,1,[M:YT03]NBPER-1 [M:YT03]NBPER
                        [M:YT03]NBPER-=1
                        J=J+LINEA
                    Else
                        OK=1
                    Endif
                Wend
            Endif
        Endif
    Endif
    Affzo [M:YT03]10
Return
######################################################################################
$TIROIR
    If currbox = GBOXYBP
        If !find(currbox,GBOXYBP)  Return : Endif
        ILIS=val(right$(currbox,8))
        Gosub REMP_LISGAU From GOBJSUB
    Endif

    If currbox = GBOXPOH
        If !find(currbox,GBOXPOH)  Return : Endif
        ILIS=val(right$(currbox,8))
        Gosub REMP_LISGAU From GOBJSUB
    Endif
Return
######################################################################################
$AP_FILGAUCHE
    WPICK=2 : Gosub ACTUALIS_MARQUAGE
Return
######################################################################################
$ACTUALIS_MARQUAGE
    If [M:YT03]NBPER>0
      For I=0 To [M:YT03]NBPER-1
        If [M:YT03]CREFLG(I)=0
            Gosub MARQUAGE_LIGNE
        Endif
      Next I
    Endif
Return
######################################################################################
$MARQUAGE_LIGNE
    If dim(FILGAUSUP)<1
      #----- Variables locales superviseur -----#
      Local Integer FILTREG : FILTREG=1
      Local Integer INDCUR  : INDCUR=1
      Local Integer ICRITERE, IFILROLE, IFILSUITE, IFILGAUSUP
      Local Char    FILTSUP(240), FILROLE(250)(0..2) , FILSUITE(250)(0..5), CRITERE(250)
      Local Char    FILGAUSUP(240)(0..2)
      Local Char    WINPROG(GLONADC), ACTION(20) : WINPROG="WGOYT0"
      Local Char    HINTLIS(10)(0..8)
      #----- Variables locales pour gestion picking liste de gauche -----#
      Local Char     WNUM(GLONVCR), WPOQLNK(16)
      Local Char     WLIN
      Local Shortint J
    Endif
    #-----

    If currbox = GBOXYBP
          HINTLIS(val(right$(GBOXYBP,8)))="YBP0"
    Endif

    If currbox = GBOXPOH
          HINTLIS(val(right$(GBOXPOH,8)))="POH0"
    Endif

    If [M:YT03]CREFLG(I)=0
      J=WPICK

        If currbox = GBOXYBP
            WNUM = [M:YT03]CODIPERSON(I)
            Read [BPS] BPS0=WNUM     : If fstat Raz [F:BPS] : Endif
            If [F:BPS]BPSNUM="" WPICK=0 : Endif
        Endif

        If currbox = GBOXPOH
            WNUM = [M:YT03]POHNUM(I)
            Read [POH]POH0 = WNUM    : If fstat Raz [F:POH] : Endif
            If [F:POH]POHNUM="" WPICK=0 : Endif
        Endif

        Case WPICK
          When 1 : Gosub DEPICK From GOBJSUB
          When 2 : Gosub REPICK From GOBJSUB
        Endcase

      WPICK=J
    Endif
Return
######################################################################################
$SETBOUT
    If GIMPORT Then : Return : Endif

#    If [M:YT03]NBPER>0 Then
#      Call VIREBOUT(CHAINE,"3") From GOBJET
#    Else
#      CHMEN+="3"
#    Endif
#
#    If [M:YT02]NBLIG>0 or [M:YT03]NBPER=0 Then
#      Call VIREBOUT(CHAINE,"4") From GOBJET
#    Else
#      CHMEN+="4"
#    Endif

    If BOUT = "A"
        Gosub TIROIR
    Endif
    If BOUT = "1" : REP = "M" : Call RECALCULAR_CANTIDAD : Endif
    If BOUT = "2" : REP = "M" : Endif
    If BOUT = "3" : REP = "M" : Endif
    If BOUT = "4" : REP = "M" : Endif
  #XVT160620.bn
   Gosub FACTURAS_YA_GENERADAS
      If FYG Then
          Call VIREBOUT(CHAINE,"3") From GOBJET
      Else
          CHMEN+="3"
      Endif

      If [M:YT02]NBLIG>0 Then
              Call VIREBOUT(CHAINE,"4") From GOBJET
      Else
         CHMEN+="4"
      Endif

Return
######################################################################################
$FIN_PICK
    zonsui="[M:YT03]NBPER(nolign-1)" : # Es situa a la pestaña de linies de proveedor
Return
######################################################################################
$FILGAUCHE
    If find(currbox,GBOXPOH)
        FILGAUSUP(0) ="[F:POH]POHFCY=[M:YT00]FCY"
        FILGAUSUP(1)=""
    Endif
Return
######################################################################################
Subprog DEL_YTPLINPER
    # Esborrem la relació de tercers
    Delete [YLC] Where NUMDOC=[M:YT00]NUMDOC
    If fstat=1  : GOK=-1 : Call RSTA("YLC",adxuid(1)) From GLOCK : End : Endif
End
######################################################################################
Subprog ACTU_YTPLINPER
    Local Integer I
    # Creem els registres de tercers.
    For I=0 To NBPER-1
        [F:YLC]NUMDOC      = [M:YT00]NUMDOC
        [F:YLC]NUMLIN      = I +1
        [F:YLC]CODIPERSON  = [M:YT03]CODIPERSON(I)
#V11.o        [F:YLC]DATA        = [M:YT03]DATA(I)
#V11.o        [F:YLC]REFERENCIA  = [M:YT03]REFERENCIA(I)
#V11.o        [F:YLC]PORCEN      = [M:YT03]PORCEN(I)
#V11.o        [F:YLC]TESTACTIU   = [M:YT03]TESTACTIU(I)
#V11.o        [F:YLC]POHNUM      = [M:YT03]POHNUM(I)
#V11.o        [F:YLC]BPSINV      = [M:YT03]BPSINV(I)
        [F:YLC]TFACGEN     = [M:YT03]TFACGEN(I)
        [F:YLC]ZNUMFAC = [M:YT03]ZNUMFAC(I) #  MAB.30102019. Pongo esto porque al duplicar está cogiendo los número de factura
        Write [YLC]
        If fstat
            GOK=0 : Call FSTA("YLC") From GLOCK : End
            Rollback
        Endif
    Next I
End
######################################################################################
Subprog DEL_YTPLINGRUP
    # Esborrem la relació de tercers
    Delete [YTG] Where NUMDOC=[M:YT00]NUMDOC
    If fstat=1  : GOK=-1 : Call RSTA("YTG",adxuid(1)) From GLOCK : End : Endif
End
######################################################################################
Subprog ACTU_YTPLINGRUP
    Local Integer I

    # Creem els registres de grups de articles
    For I=0 To [M:YT04]NBGRP-1
        nolign = I+1
        Raz [F:YTG]
#        If GREP = "D" : Call DUPLICAR_DOCUMENTOS_GRUPO([M:YT04]YDOCCAL(I),[M:YT04]YDOCCLA(I),[M:YT04]YDOCCAL(I),[M:YT04]YDOCCLA(I)) : Endif

        [F:YTG]            = [M:YT04]
        [F:YTG]NUMDOC      = [M:YT00]NUMDOC
        [F:YTG]FCY         = [M:YT00]FCY
        #V11.O[F:YTG]TIPDOC      = [M:YT00]TIPDOC
        [F:YTG]CLASEDOC    = [M:YT00]CLASEDOC
        [F:YTG]SERIE       = [M:YT00]SERIE
        [F:YTG]EXERCICI    = [M:YT00]EXERCICI
        [F:YTG]TIPOFCY     = [M:YT01]TIPOFCY
        [F:YTG]NUMLIN      = nolign

        Write [YTG]
        If fstat
            GOK=0 : Call FSTA("YTG") From GLOCK : End
            Rollback
        Endif
    Next I
End
######################################################################################
#### Proceso de generacion de lineas de articulo a partir de los grupos           ####
######################################################################################
Subprog GENERA_TPLINEAS
    Local Integer NUM,I,FILAS
    NUM = 0

    Filter [YT1] Where NUMDOC = [M:YT00]NUMDOC
    FILAS = rowcount([YT1])

    If FILAS > 0 : Filter [YT1] : End : Endif

    Filter [YT1]

    #Las tablas de gastos, no generan lineas si se introducen los datos por Grupos de Articulos
#v11.o    If [M:YT00]CLASEDOC=29 and [M:YT01]PRODUCTO=1 Then : End : Endif

#v11.bo    For I=0 To [M:YT04]NBGRP-1
#        For [ITM]ITM0 Where TSICOD([M:YT01]GRUPESTAD-1)=[M:YT04]GRUPO(I) and ([F:ITM]YTPROD=1 or [F:ITM]YTPROD=8)
#
#            NUM = NUM +1
#            Raz [F:YT1]
#            nolign = I+1
#            [F:YT1]            = [M:YT04]
#            [F:YT1]ITMREF      = [F:ITM]ITMREF
#            [F:YT1]TSICOD(0)   = [F:ITM]TSICOD(0)
#            [F:YT1]TSICOD(1)   = [F:ITM]TSICOD(1)
#            [F:YT1]TSICOD(2)   = [F:ITM]TSICOD(2)
#            [F:YT1]NUMDOC      = [M:YT00]NUMDOC
#            [F:YT1]FCY         = [M:YT00]FCY
#            [F:YT1]TIPDOC      = [M:YT00]TIPDOC
#            [F:YT1]CLASEDOC    = [M:YT00]CLASEDOC
#            [F:YT1]SERIE       = [M:YT00]SERIE
#            [F:YT1]EXERCICI    = [M:YT00]EXERCICI
#            [F:YT1]TIPOFCY     = [M:YT01]TIPOFCY
#            [F:YT1]NUMLIN      = NUM
#            Write [YT1]
#            If fstat
#                GOK=0 : Call FSTA("YT1") From GLOCK : End
#                Rollback
#            Endif
#        Next
#v11.eo    Next I

    # -- Generación de líneas en la tabla Grupos Articulos
    Raz nolign
    nolign=0
    For [YT1]YT10 Where NUMDOC=[M:YT00]NUMDOC
        nolign += 1
        [M:YT02] = [F:YT1]
    Next
    [M:YT02]NBLIG = min(nolign,dim([M:YT02]NUMLIN))
    nolign=0

    Affzo [YT02]5
End
######################################################################################
Subprog DUPLICAR_DOCUMENTOS
    Local Char DOCUMENTO
    Local Shortint INDEX

    INDEX = nolign-1
    #Asignaremos 0 al par. de la transacción ya que estamos dentro de una nueva transacción
    If [F:YT1]YDOCCAL<>"" and [M:YT02]YTESTCAL(INDEX)="1" Then
        #Enlace con documento CALIDAD. Si la linia es de picking de pesadas y no se
        #ha duplicado el documento, creamos uno de nuevo
#        Call DUPLICAR_CALIDAD([F:YT1]YDOCCAL, "", DOCUMENTO)
        Call DUPLICAR_CALIDAD([M:YT02]YDOCCAL(INDEX), "", DOCUMENTO)
        [M:YT02]YDOCCAL(INDEX) = DOCUMENTO
#        [F:YT1]YDOCCAL = DOCUMENTO
        [M:YT02]YTESTCAL(INDEX)=""
        Affzo [M:YT02]YDOCCAL(INDEX)
        Affzo [M:YT02]YTESTCAL(INDEX)
     Endif
    If [F:YT1]YDOCCLA<>"" and [M:YT02]YTESTCLA(INDEX)="1" Then
        #Enlace con documento CLASIFICACION. Si la linia es de picking de pesadas y no se
        #ha duplicado el documento, creamos uno de nuevo
#        Call DUPLICAR_CLASIFICACION([F:YT1]YDOCCLA, "", DOCUMENTO)
        Call DUPLICAR_CLASIFICACION([M:YT02]YDOCCLA(INDEX), "", DOCUMENTO)
        [M:YT02]YDOCCLA(INDEX) = DOCUMENTO
#        [F:YT1]YDOCCLA = DOCUMENTO
        [M:YT02]YTESTCLA(INDEX)=""
        Affzo [M:YT02]YDOCCLA(INDEX)
        Affzo [M:YT02]YTESTCLA(INDEX)
     Endif
End
######################################################################################
Subprog DUPLICAR_CLASIFICACION(NUMERO,ORDEN,CLASIF)
    Value    Char NUMERO
    Value    Char ORDEN
    Variable Char CLASIF
    Local    Char SENTENCIA(50)
    Local    Char GNUM

    Raz CLASIF
    If (NUMERO="") : End : Endif

#v11.o    If clalev([F:YC2])=0 : Local File YACCABCLA  [YC2] : Endif
#v11.o    If clalev([F:YL2])=0 : Local File YACLINCLA  [YL2] : Endif
#v11.o    If clalev([F:XC2])=0 : Local File YACCABCLA  [XC2] : Endif
#v11.o    If clalev([F:XL2])=0 : Local File YACLINCLA  [XL2] : Endif

    Raz [F:YC2]
    Raz [F:YL2]
    Raz [F:XC2]
    Raz [F:XL2]

    SENTENCIA = "YDOCREL='"+NUMERO+"'"
    If (ORDEN<>"") Then
        SENTENCIA = SENTENCIA + " and YDOCLIN='"+ORDEN+"'"
    Endif

    Readlock [YC2]YC20=NUMERO
    Readlock [YL2]YL20=NUMERO
    For [YC2]YC20 Where evalue(SENTENCIA)
        ORDEN = [F:YC2]YDOCLIN

        GOK = 1
   #V11.O     Call COGER_CONTADOR([F:YC2]TIPDOC,[F:YC2]SERIE,GNUM,[F:YC2]FCY,[F:YC2]EXERCICI) From XCONTROLES

        If GNUM = ""
            GOK = 0
            GERR=1
            ERROR=1
            GMESSAGE=mess(64,199,1)
            Unlock [YL2]
            Unlock [YC2]
            End
        Endif

        [F:XC2] = [F:YC2]
        [F:XC2]YDOCREL  = GNUM
        [F:XC2]YDOCLIN  = ORDEN
        [F:XC2]DATA     = date$

        Write [XC2]
        If fstat
            GOK=0
            Call FSTA("XC2") From GLOCK :
            Unlock [YL2]
            Unlock [YC2]
            End
        Endif

        For [YL2]YL20 Where YDOCREL=NUMERO and YDOCLIN=ORDEN
            [F:XL2] = [F:YL2]
            [F:XL2]YDOCREL    = GNUM
            [F:XL2]YDOCLIN    = ORDEN

            Write [XL2]
            If fstat
                GOK=0
                Call FSTA("XL2") From GLOCK
                Unlock [YL2]
                Unlock [YC2]
                End
            Endif
        Next

    Next
    Unlock [YL2]
    Unlock [YC2]

    CLASIF = GNUM
End
######################################################################################
Subprog DUPLICAR_CALIDAD(NUMERO,ORDEN,CALIDAD)
    Value    Char NUMERO
    Value    Char ORDEN
    Variable Char CALIDAD
    Local    Char SENTENCIA(50)
    Local    Char GNUM

    Raz CALIDAD
    If (NUMERO="") : End : Endif

#v11.o    If clalev([F:YC1])=0 : Local File YACCABCAL  [YC1] : Endif
#v11.o    If clalev([F:YL1])=0 : Local File YACLINCAL  [YL1] : Endif
#v11.o   If clalev([F:XC1])=0 : Local File YACCABCAL  [XC1] : Endif
#v11.o   If clalev([F:XL1])=0 : Local File YACLINCAL  [XL1] : Endif

    Raz [F:YC1]
    Raz [F:YL1]
    Raz [F:XC1]
    Raz [F:XL1]

    SENTENCIA = "YDOCREL='"+NUMERO+"'"
    If (ORDEN<>"") Then
        SENTENCIA = SENTENCIA + " and YDOCLIN='"+ORDEN+"'"
    Endif

    Readlock [YC1]YC10=NUMERO
    Readlock [YL1]YL10=NUMERO
    For [YC1]YC10 Where evalue(SENTENCIA)
        ORDEN = [F:YC1]YDOCLIN

        GOK = 1
#        Call COGER_CONTADOR([F:YC1]TIPDOC,[F:YC1]SERIE,GNUM,[F:YC1]FCY,[F:YC1]EXERCICI) From XCONTROLES

        If GNUM = ""
            GOK = 0
            GERR=1
            ERROR=1
            GMESSAGE=mess(64,199,1)
            Unlock [YL1]
            Unlock [YC1]
            End
        Endif

        [F:XC1] = [F:YC1]
        [F:XC1]YDOCREL  = GNUM
        [F:XC1]YDOCLIN  = ORDEN
        [F:XC1]DATA     = date$

        Write [XC1]
        If fstat
            GOK=0
            Unlock [YL1]
            Unlock [YC1]
            Call FSTA("XC1") From GLOCK
            End
        Endif

        For [YL1]YL10 Where YDOCREL=NUMERO and YDOCLIN=ORDEN
            [F:XL1] = [F:YL1]
            [F:XL1]YDOCREL    = GNUM
            [F:XL1]YDOCLIN    = ORDEN

            Write [XL1]
            If fstat
                GOK=0
                Call FSTA("XL1") From GLOCK
                Unlock [YL1]
                Unlock [YC1]
                End
            Endif
        Next

    Next
    Unlock [YL1]
    Unlock [YC1]

    CALIDAD = GNUM
End
#######################################################################################
Subprog DUPLICAR_DOCUMENTOS_GRUPO(YDOCCAL,YDOCCLA,YDOCCAL_DES,YDOCCLA_DES)
    Value Char YDOCCAL
    Value Char YDOCCLA
    Variable Char YDOCCAL_DES
    Variable Char YDOCCLA_DES
    Local Integer I

    If YDOCCAL<>"" Then
        Call DUPLICAR_CALIDAD(YDOCCAL, "", YDOCCAL_DES)
    Endif
    If YDOCCLA<>"" Then
        Call DUPLICAR_CLASIFICACION(YDOCCLA, "", YDOCCLA_DES)
    Endif

    For I=0 To [M:YT02]NBLIG-1
        If [M:YT02]YDOCCAL(I) = YDOCCAL
            [M:YT02]YDOCCAL(I) = YDOCCAL_DES
            [M:YT02]YTESTCAL(I)=""
            Affzo [M:YT02]YDOCCAL(I)
            Affzo [M:YT02]YTESTCAL(I)
        Endif
        If [M:YT02]YDOCCLA(I) = YDOCCLA
            [M:YT02]YDOCCLA(I) = YDOCCLA_DES
            [M:YT02]YTESTCLA(I)=""
            Affzo [M:YT02]YDOCCLA(I)
            Affzo [M:YT02]YTESTCLA(I)
        Endif
    Next
End
######################################################################################
Subprog DEL_YTPLINEAS
    # Esborrem la relació de tercers
    Delete [YT1] Where NUMDOC=[M:YT00]NUMDOC
    If fstat=1  : GOK=-1 : Call RSTA("YT1",adxuid(1)) From GLOCK : End : Endif
End
######################################################################################
Subprog ACTU_YTPLINEAS
    Local Integer I

    # Creem els registres de tercers.
    For I=0 To NBLIG-1
        nolign = I+1
#        If GREP = "D" : Call DUPLICAR_DOCUMENTOS : Endif
        [F:YT1]            = [M:YT02]
        [F:YT1]NUMDOC      = [F:YT0]NUMDOC
#        [F:YT1]TSICOD(0)   = [M:YT02]CODI1
#        [F:YT1]TSICOD(1)   = [M:YT02]CODI2
#        [F:YT1]TSICOD(2)   = [M:YT02]CODI3
        [F:YT1]FCY         = [M:YT00]FCY
#        [F:YT1]TIPDOC      = [M:YT00]TIPDOC
#        [F:YT1]CLASEDOC    = [M:YT00]CLASEDOC
#        [F:YT1]SERIE       = [M:YT00]SERIE
        [F:YT1]EXERCICI    = [M:YT00]EJERCICIO
        [F:YT1]TIPOFCY     = [M:YT00]TIPOFCY
        [F:YT1]NUMLIN      = nolign

        Write [YT1]
        If fstat
            GOK=0 : Call FSTA("YT1") From GLOCK : End
            Rollback
        Endif
    Next I
End
