######################################################################################
$CONTROLE
#    [M:YT00]PRODINI     = [M:YST2]PRODINI
#    [M:YT00]PRODFI      = [M:YST2]PRODFI
#    [M:YT00]CALINI      = [M:YST2]CALINI
#    [M:YT00]CALFI       = [M:YST2]CALFI
#    [M:YT00]RECOINI     = [M:YST2]RECOINI
