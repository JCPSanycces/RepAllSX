Return
######################################################################################
$PROPOSTA_ARTICLE
    Local Integer P
    Local Integer I
    Local Integer K
    Local Integer SWCREA
    Local    Char    CRITERE_PTD(250)
    Local    Char    CRITERE_PND(250)

#v11.bo control no necesario por que el botón no está disponible
#    If (NBLIG<>0 | [M:YT02]ITMREF(nolign-1)<>"")
#        End
#v11.eo    Endif
    Gosub DEF_LIMITS
    P=0
    Call TEMPON("C") From GESECRAN

    Local    Char        CAMP_CAL  : CAMP_CAL = "CALIDAD"
    Local    Char        CAMP_REC  : CAMP_REC = "RECOLL"
    Local    Char        PANTALLA  : PANTALLA = masknam([M:YT02])
    Local    Integer     TROBAT_CAL
    Local    Integer     TROBAT_REC

Local Integer DUMMY : DUMMY=0
VCFYDEB="" : VFCYFIN="ZZZZZ"
If [M:YT00]FCYDEB<>"" and [M:YT00]FCYFIN<>"" : VFCYDEB=[M:YT00]FCYDEB : VFCYFIN=[M:YT00]FCYFIN : Endif

 Link [PTD] With [FCY]FCY0=[F:PTD]PRHFCY, [F:YLC]YLC3=[PTD]BPSNUM,
&    [PTH]PTH0=[PTD]PTHNUM   As [RES2]
&     Where [YLC]NUMDOC=[M:YT00]NUMDOC
&     and [PTH]ZEJERCICIO=[M:YT00]EJERCICIO
&     and [FCY]FINRSPFCY=[M:YT00]FCY
&     and [FCY]YTIPOFCY=[M:YT00]TIPOFCY
&     and [PTD]PRHFCY>=VFCYDEB and [PTD]PRHFCY<=VFCYFIN and [PTD]RCPDAT>=[M:YT00]FECHAINI
&     and [PTD]RCPDAT<=[M:YT00]FECHAFIN and [F:PTD]INVQTYSTU=0
 P=0
 For [RES2]
    If P=0 Then
#    Infbox "PRIMERA PASADA P="+num$(P)
    #el primer artículo-calidad siempre se inserta
    #el resto, dependerá de si ya se han insertado o no
      Read [PTD]PTD0=[RES2]PTHNUM;[RES2]PTDLIN
      Call CREA_LINEA(P)   ###xvtcrea
   #   Call ACUMULAR(P)
      P+=1
    Else
    #en las siguientes pasadas, si el articulo-calidad ya se habia insertado, solo
    #se acumula el total, y si no, se crea la linea de articulo-calidad.

     SWCREA=0
#     Infbox "OTRAS PASADAS P="+num$(P) + " SWCREA="+num$(SWCREA) + " [M:YT02]NBLIG="+num$([M:YT02]NBLIG)
      For I=0 To [M:YT02]NBLIG -1
      #  Infbox [F:PTD]ITMREF + " " + [M:YT02]ITMREF(I) + " CALIDAD PTD:" + [F:PTD]ZCALIDAD +" CALIDAD PANT: "+ [M:YT02]CALIDAD(I)
        If [F:PTD]ITMREF = [M:YT02]ITMREF(I) and [F:PTD]ZCALIDAD = [M:YT02]CALIDAD(I)
#        Infbox "P "+ num$(P) + " SOLO ACUMULA " + [F:PTD]ITMREF + " " + [M:YT02]ITMREF(I) + " CALIDAD PTD:" + [F:PTD]ZCALIDAD +" CALIDAD PANT: "+ [M:YT02]CALIDAD(I)
          Call ACUMULAR(I)
          SWCREA=1
        Endif
      Next I

      If (SWCREA=0)
#          Infbox "P "+num$(P) + " CREA " + [F:PTD]ITMREF + " " + [M:YT02]ITMREF(I) + " CALIDAD PTD:" + [F:PTD]ZCALIDAD +" CALIDAD PANT: "+ [M:YT02]CALIDAD(I)
          Call CREA_LINEA(P)
         # Call ACUMULAR(P)
          P+=1
      Endif
     # DUMMY+=1
     # If DUMMY>10 Then Break : Endif
    Endif

 Next

  NBLIG=P
  Sorta [M:YT02]NBLIG [M:YT02]NBLIG Order By [M:YT02]ITMREF(indice),[M:YT02]CALIDAD(indice)
  If P>0 : Affzo [M:YT02] : Endif
# activem el boto de registrar i treiem el tempon
  mkstat=4
  Call TEMPOFF From GESECRAN
Return
