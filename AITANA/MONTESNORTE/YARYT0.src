#    [M:YT00]BPSFI       = [M:YST4]BPSFI
#    [M:YT00]TOTENTRAT   = [M:YST4]TOTENTRAT
    Gosub DEF_LIMITS
    Gosub DEF_LIMITS_TERCER
Return
######################################################################################
$DEF_LIMITS
#v11.bn
Return
#v11.en
    If ([M:YT00]PRODINI="") : [M:YT00]PRODINI="0"                   : Endif
    If ([M:YT00]PRODFI="")  : [M:YT00]PRODFI="zzzzzzzzzzzzzzzzzzzz" : Endif
    If ([M:YT00]CALINI="")  : [M:YT00]CALINI="0"                    : Endif
    If ([M:YT00]CALFI="")   : [M:YT00]CALFI="zzzz"                  : Endif
    If ([M:YT00]RECOINI="") : [M:YT00]RECOINI="0"                   : Endif
    If ([M:YT00]RECOFI="")  : [M:YT00]RECOFI="zzzz"                 : Endif
Return
######################################################################################
$DEF_LIMITS_TERCER
    If ([M:YT00]BPSINI="")  Then
      VBPSINI=""
    Else
        VBPSINI=[M:YT00]BPSINI
    Endif

    If ([M:YT00]BPSFI="") Then
      VBPSFI="zzzzzzzzzzzzzzzzzzzz"
    Else
      VBPSFI=[M:YT00]BPSFI
    Endif
Return
