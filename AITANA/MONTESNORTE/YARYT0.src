        If [F:YT2]YFILTYPFCY = 0 or [F:YT2]YFILTYPFCY = 2
            CRITERE += " & [F:YT0]TIPOFCY=[F:YTT]TIPOFCY"
        Endif

        If [F:YTT]TIPDOC <> "" and [F:YTT]YFILTRE = 2
            CRITERE += " AND [F:YT0]TIPDOC=[F:YTT]TIPDOC"
        Endif
    Endif
Return
