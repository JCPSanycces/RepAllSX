######################################################################################
Subprog BUSCAR_COMPRAS
    Local   Char    CRITERE(250), CRITERE2(250)
    Local   Integer LIN_TER
    Local   Integer I,X,K,P



    CRITERE = "[PTD]YTIPOFCY=[F:FCY]YTIPOFCY"
    If [M:YST5]TSICOD(0) <> ""
        CRITERE +=" & [PTD]TSICOD(0)=[M:YST5]TSICOD(0)"
    Endif
    If [M:YST5]TSICOD(1) <> ""
        CRITERE +=" & [PTD]TSICOD(1)=[M:YST5]TSICOD(1)"
    Endif
    If [M:YST5]TSICOD(2) <> ""
        CRITERE +=" & [PTD]TSICOD(2)=[M:YST5]TSICOD(2)"
    Endif
    If [M:YST5]TSICOD(3) <> ""
        CRITERE +=" & [PTD]TSICOD(3)=[M:YST5]TSICOD(3)"
    Endif
    If [M:YST5]TSICOD(4) <> ""
        CRITERE +=" & [PTD]TSICOD(4)=[M:YST5]TSICOD(4)"
    Endif

    CRITERE2 = "[PTD]LININVFLG<2 & [PTD]YEXERCICI=[M:YT00]EXERCICI"

    If [M:YST5]DATINIC <> [00/00/00] and [M:YST5]DATFINC <> [00/00/00]
        CRITERE2 += "& ([PTD]RCPDAT>=[M:YST5]DATINIC & [PTD]RCPDAT<=[M:YST5]DATFINC)"
    Endif

    If [M:YST5]BPSINI <> "" and [M:YST5]BPSFIN <> ""
        CRITERE2 += "& ([PTD]BPSNUM>=[M:YST5]BPSINI & [PTD]BPSNUM<=[M:YST5]BPSFIN)"
    Endif

    nolign = 0
    For [PTD] Where evalue(CRITERE) & evalue(CRITERE2)
        nolign +=1
        [M:YT05] = [F:PTD]
        [M:YT05]PTHNUM(nolign-1) = [F:PTD]PTHNUM
        [M:YT05]PTDLIN(nolign-1) = [F:PTD]PTDLIN
    Next
    [M:YT05]NBCOM = nolign
    nolign=0
    Affzo [M:YT05]

    ##---- CARGAR LOS TERCEROS A LIQUIDAR ----##
    LIN_TER = 0
    For I=0 To [M:YT05]NBCOM-1
        X = 0
        X = find([M:YT05]BPSNUM(I),[M:YT03]CODIPERSON(0..[M:YT03]NBPER-1))
        If X = 0
            Call CREA_LINEA_TERCER(LIN_TER,[M:YT05]BPSNUM(I))
            LIN_TER +=1
        Endif
    Next

    If LIN_TER>0 : Affzo [M:YT03] : Endif

    ##---- CARGAR LOS ARTICULOS A LIQUIDAR ----##
    ### JGM - 12/08/2010
    ### Si los campos Calidad y Recogida estan invisibles, omitiremos estos campos en la busqueda-
    Local    Char        CAMP_CAL  : CAMP_CAL = "CALIDAD"
    Local    Char        CAMP_REC  : CAMP_REC = "RECOLL"
    Local    Char        PANTALLA  : PANTALLA = masknam([M:YT02])
    Local    Integer     TROBAT_CAL
    Local    Integer     TROBAT_REC

    Call BUSCAR_CAMP_INV(PANTALLA,CAMP_CAL,TROBAT_CAL) From XCONTROLES

    If TROBAT_CAL = 2 ### INVISIBLE
        [M:YT00]SWCALI=2
    Endif

    Call BUSCAR_CAMP_INV(PANTALLA,CAMP_REC,TROBAT_REC) From XCONTROLES

    If TROBAT_REC = 2 ### INVISIBLE
        [M:YT00]SWRECO=2
    Endif
    nolign = 1

    Default Mask [M:YT02]

    For [PTD] Where evalue(CRITERE) & evalue(CRITERE2)
        K=find([F:PTD]BPSNUM,[M:YT03]CODIPERSON(0..[M:YT03]NBPER-1))
        If (K>0)
        #V11.O    Call LECTU_PROD([F:PTD]ITMREF)
        # Controlem que sigui materia prima
        # S.V. S'ha afegit l'opció 8 pels prod. de fruita de camp
            If ([F:ITM]YTPROD=1 or [F:ITM]YTPROD=8)
                If (P=0)
                    Call CREA_LINEA(P,TROBAT_CAL,TROBAT_REC)
                    [M:YT02]TIPO(P) = 2
                    Call ACUMULAR(P)
                    P+=1
                Else
                    SWCREA=0
                    If TROBAT_CAL = 2 : Raz [F:PTD]YCALIDAD : Endif
                    If TROBAT_REC = 2 : Raz [F:PTD]YRECOLL : Endif

                    For I=0 To NBLIG -1
                        If ([F:PTD]ITMREF   = [M:YT02]ITMREF(I) &
&                       [F:PTD]YCALIDAD = [M:YT02]CALIDAD(I) &
&                       [F:PTD]YRECOLL  = [M:YT02]RECOLL(I))
                            Call ACUMULAR(I)
                            SWCREA=1
                        Endif
                    Next I

                    If (SWCREA=0)
                        Call CREA_LINEA(P,TROBAT_CAL,TROBAT_REC)
                        [M:YT02]TIPO(P) = 2
                        Call ACUMULAR(P)
                        P+=1
                    Endif
                Endif
            Endif
        Endif
    Next

    NBLIG=P
    Sorta [M:YT02]NBLIG [M:YT02]NBLIG Order By [M:YT02]ITMREF(indice),[M:YT02]CALIDAD(indice)
    If P>0 : Affzo [M:YT02] : Endif
    mkstat=4
    Affzo [M:YT02]
End
######################################################################################
Subprog BUSCAR_VENTAS
    Local   Char  CRITERE(250), CRITERE2(250)

    CRITERE = "[SID]YTIPOFCY=[F:FCY]YTIPOFCY"
    If [M:YST5]TSICOD(0) <> ""
        CRITERE +=" & [SID]TSICOD(0)=[M:YST5]TSICOD(0)"
    Endif
    If [M:YST5]TSICOD(1) <> ""
        CRITERE +=" & [SID]TSICOD(1)=[M:YST5]TSICOD(1)"
    Endif
    If [M:YST5]TSICOD(2) <> ""
        CRITERE +=" & [SID]TSICOD(2)=[M:YST5]TSICOD(2)"
    Endif
    If [M:YST5]TSICOD(3) <> ""
        CRITERE +=" & [SID]TSICOD(3)=[M:YST5]TSICOD(3)"
    Endif
    If [M:YST5]TSICOD(4) <> ""
        CRITERE +=" & [SID]TSICOD(4)=[M:YST5]TSICOD(4)"
    Endif

    CRITERE2 = "[SIV]INVSTA=3 & [SIV]YEXERCICI=[M:YT00]EXERCICI"

    If [M:YST5]DATINIV <> [00/00/00] and [M:YST5]DATFINV <> [00/00/00]
        CRITERE2 += "& ([SID]INVDAT>=[M:YST5]DATINIV & [SID]INVDAT<=[M:YST5]DATFINV)"
    Endif

    If [M:YST5]BPCINI <> "" and [M:YST5]BPCFIN <> ""
        CRITERE2 += "& ([SID]BPCINV>=[M:YST5]BPCINI & [SID]BPCINV<=[M:YST5]BPCFIN)"
    Endif

    Link [SID] With [SIV]SIV0=NUM As [VEN]

    nolign = 0
    For [VEN] Where evalue(CRITERE) & evalue(CRITERE2)
        nolign +=1
        [M:YT06] = [F:SID]
        [M:YT06]SIHNUM(nolign-1) = [F:SID]NUM
        [M:YT06]SIDLIN(nolign-1) = [F:SID]SIDLIN
    Next
    [M:YT06]NBVEN = nolign
    nolign=0
    mkstat=4
    Affzo [M:YT06]

    Call AGRUPAR_VENTAS

    ## Aplicar precio de venta
    For I=0 To [M:YT02]NBLIG-1
        Call BUSCAR_PREU_VEN([M:YT02]ITMREF(I),[M:YT02]PREU1(I))
    Next
    Affzo [M:YT02]
End
######################################################################################
Subprog BUSCAR_ANTICIPOS
    Local   Char  CRITERE(250), CRITERE2(250), CRITERE3(250)

    CRITERE = "[PID]YTIPOFCY=[F:FCY]YTIPOFCY"
    If [M:YST5]TSICOD(0) <> ""
        CRITERE +=" & [PID]TSICOD(0)=[M:YST5]TSICOD(0)"
    Endif
    If [M:YST5]TSICOD(1) <> ""
        CRITERE +=" & [PID]TSICOD(1)=[M:YST5]TSICOD(1)"
    Endif
    If [M:YST5]TSICOD(2) <> ""
        CRITERE +=" & [PID]TSICOD(2)=[M:YST5]TSICOD(2)"
    Endif
    If [M:YST5]TSICOD(3) <> ""
        CRITERE +=" & [PID]TSICOD(3)=[M:YST5]TSICOD(3)"
    Endif
    If [M:YST5]TSICOD(4) <> ""
        CRITERE +=" & [PID]TSICOD(4)=[M:YST5]TSICOD(4)"
    Endif

    CRITERE2 = "[YAN]YEXELIN=[M:YT00]EXERCICI"
    If [M:YST5]DATINIA <> [00/00/00] and [M:YST5]DATFINA <> [00/00/00]
        CRITERE2 += "& ([YAN]ACCDAT>=[M:YST5]DATINIA & [YAN]ACCDAT<=[M:YST5]DATFINA)"
    Endif

    nolign = 0

    For I=0 To [M:YT03]NBPER-1
        CRITERE3 = "[YAN]BPSNUM=[M:YT03]CODIPERSON(I)"

        Link [YAN] With [PID]PID0 = [YAN]NUM;[YAN]PIDLIN As [ANT]

        For [ANT] Where evalue(CRITERE) and evalue(CRITERE2) and evalue(CRITERE3)

            Read [PIH]PIH0 = [F:YAN]NUM : If fstat : Raz [PIHA] : Endif
            Read [PID]PID0 = [F:YAN]NUM;[F:YAN]PIDLIN : If fstat : Raz [PIDA] : Endif

            nolign +=1
            [M:YT07] = [F:PID]
            [M:YT07]PIHNUM(nolign-1) = [F:PID]NUM
            [M:YT07]PIDLIN(nolign-1) = [F:PID]PIDLIN

        Next
    Next
    [M:YT07]NBANT = nolign
    nolign=0
    Affzo [M:YT07]
End
######################################################################################
######################################################################################
Subprog DEL_YTPCOM
    # Esborrem la relació de tercers
    Delete [YT5] Where NUMDOC=[M:YT00]NUMDOC
    If fstat=1  : GOK=-1 : Call RSTA("YT5",adxuid(1)) From GLOCK : End : Endif
End
######################################################################################
Subprog ACTU_YTPCOM
    Local Integer I
    # Creem els registres de tercers.
    For I=0 To [M:YT05]NBCOM-1
        [F:YT5]NUMDOC      = [M:YT00]NUMDOC
        [F:YT5]NUMLIN      = I +1
        [F:YT5]PTHNUM      = [M:YT05]PTHNUM(I)
        [F:YT5]PTDLIN      = [M:YT05]PTDLIN(I)
        Write [YT5]
        If fstat
            GOK=0 : Call FSTA("YT5") From GLOCK : End
            Rollback
        Endif
    Next I
End
######################################################################################
Subprog DEL_YTPVEN
    # Esborrem la relació de tercers
    Delete [YT6] Where NUMDOC=[M:YT00]NUMDOC
    If fstat=1  : GOK=-1 : Call RSTA("YT6",adxuid(1)) From GLOCK : End : Endif
End
######################################################################################
Subprog ACTU_YTPVEN
    Local Integer I
    # Creem els registres de tercers.
    For I=0 To [M:YT06]NBVEN-1
        [F:YT6]NUMDOC      = [M:YT00]NUMDOC
        [F:YT6]NUMLIN      = I +1
        [F:YT6]SIHNUM      = [M:YT06]SIHNUM(I)
        [F:YT6]SIDLIN      = [M:YT06]SIDLIN(I)
        Write [YT6]
        If fstat
            GOK=0 : Call FSTA("YT6") From GLOCK : End
            Rollback
        Endif
    Next I
End
######################################################################################
Subprog DEL_YTPANT
    # Esborrem la relació de tercers
    Delete [YT7] Where NUMDOC=[M:YT00]NUMDOC
    If fstat=1  : GOK=-1 : Call RSTA("YT7",adxuid(1)) From GLOCK : End : Endif
End
######################################################################################
Subprog ACTU_YTPANT
    Local Integer I
    # Creem els registres de tercers.
    For I=0 To [M:YT07]NBANT-1
        [F:YT7]NUMDOC      = [M:YT00]NUMDOC
        [F:YT7]NUMLIN      = I +1
        [F:YT7]PIHNUM      = [M:YT07]PIHNUM(I)
        [F:YT7]PIDLIN      = [M:YT07]PIDLIN(I)
        Write [YT7]
        If fstat
            GOK=0 : Call FSTA("YT7") From GLOCK : End
            Rollback
        Endif
    Next I
End
######################################################################################
Subprog BUSCAR_PREU_VEN(XITMREF,XPREU)
    Variable  Char    XITMREF
    Variable  Decimal XPREU
    Local     Integer X
    Local     Decimal IMPORTE
    Local     Decimal CANTIDAD
    Local     Integer FAM_NOL

    If [M:YST5]PRIAGR(0) = 2
        FAM_NOL = 0
    Elsif [M:YST5]PRIAGR(1) = 2
        FAM_NOL = 1
    Elsif [M:YST5]PRIAGR(2) = 2
        FAM_NOL = 2
    Elsif [M:YST5]PRIAGR(3) = 2
        FAM_NOL = 3
    Elsif [M:YST5]PRIAGR(4) = 2
        FAM_NOL = 4
    Endif

    Read [ITM]ITM0 = XITMREF : If fstat : Raz [ITM] : Endif

    For X=0 To [M:YT06]NBPRI-1
        If [M:YT06]FAMART(X) = [F:ITM]TSICOD(FAM_NOL)
            IMPORTE += [M:YT06]QTY(X) * ([M:YT06]NETPRI(X)-[M:YT06]CPRPRI(X))
            CANTIDAD += [M:YT06]QTY(X)
        Endif
    Next

    If CANTIDAD <> 0
        XPREU = IMPORTE / CANTIDAD
        XPREU = arr(XPREU,10^-GDECPRI)
    Endif
End
######################################################################################
Subprog COMPROBAR_REG(XSALIR_REG)
    Variable    Integer XSALIR_REG
    Local       Integer RESP

    XSALIR_REG = 1

    If [M:YT02]NBLIG <> 0 or [M:YT03]NBPER <> 0
        RESP =2
        Qstbox mess(210,1986,1) Using RESP Sleep 10

        If RESP = 1
            Call ELIMINAR_REG_TER
            Call ELIMINAR_REG_ART
            Call ELIMINAR_REG_COM
            Call ELIMINAR_REG_VEN
            Call ELIMINAR_REG_ANT
        Else
            XSALIR_REG = 2
        Endif
    Endif
End
######################################################################################
Subprog ELIMINAR_REG_TER
    While [M:YT03]NBPER <>0
        NOL = 0
        Dela NOL,1,[M:YT03]NBPER -1 [M:YT03]NBPER
        [M:YT03]NBPER-=1
    Wend
    Affzo [M:YT03]
End
######################################################################################
Subprog ELIMINAR_REG_ART
    While [M:YT02]NBLIG <>0
        NOL = 0
        Dela NOL,1,[M:YT02]NBLIG -1 [M:YT02]NBLIG
        [M:YT02]NBLIG-=1
    Wend
    Affzo [M:YT02]
End
######################################################################################
Subprog ELIMINAR_REG_COM
    While [M:YT05]NBCOM <>0
        NOL = 0
        Dela NOL,1,[M:YT05]NBCOM -1 [M:YT05]NBCOM
        [M:YT05]NBCOM-=1
    Wend
    Affzo [M:YT05]
End
######################################################################################
Subprog ELIMINAR_REG_VEN
