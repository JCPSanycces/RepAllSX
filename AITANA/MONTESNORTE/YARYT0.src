    Affzo [M:YT00]
    Affzo [M:YT01]

#v11.bo
#    Diszo [M:YT05]
#    Diszo [M:YT06]
#    Diszo [M:YT07]
#v11.eo
Return
######################################################################################
##--- Actualitzem la pantalla de relació de tercers YTPLINPER
######################################################################################
$LIENS_YTPLINPER

    Raz nolign
    nolign=0
    For [YLC]YLC0 Where NUMDOC=[M:YT00]NUMDOC
        nolign += 1
        [M:YT03] = [F:YLC]
    Next
    [M:YT03]NBPER = nolign
    nolign=0
    Affzo [M:YT03]

Return
######################################################################################
##--- Actualitzem la pantalla de relació de articles YTPLINEAS
######################################################################################
$LIENS_YTPLINEAS

    Raz nolign
    nolign=0
    For [YT1]YT10 Where NUMDOC=[M:YT00]NUMDOC
        nolign += 1
        [M:YT02] = [F:YT1]
#v11.O        If [F:YT1]YDOCCAL<>"" : [M:YT02]YTESTCAL(nolign-1) = "1" : Endif
#v11.O        If [F:YT1]YDOCCLA<>"" : [M:YT02]YTESTCLA(nolign-1) = "1" : Endif
#v11.O       Call LECTU_PROD([F:YT1]ITMREF)
        Call FORMATEJAR_TIPO
    Next
    [M:YT02]NBLIG = nolign
    nolign=0
    Affzo [M:YT02]

Return
######################################################################################
##--- Actualitzem la pantalla de grupos de articulos YTPLINGRUP
######################################################################################
$LIENS_YTPLINGRUP

    Raz nolign
    nolign=0
    For [YTG]YTG0 Where NUMDOC=[M:YT00]NUMDOC
        nolign += 1
        [M:YT04] = [F:YTG]
        Call C_GRUPO([M:YT04]GRUPO(nolign-1)) From SPVYT0
        Call FORMATEJAR_TIPO_YT04
    Next
    [M:YT04]NBGRP = min(nolign,dim([M:YT04]NUMLIN))
    nolign=0
    Affzo [M:YT04]

Return

