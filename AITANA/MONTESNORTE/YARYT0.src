        NOL = 0
        Dela NOL,1,[M:YT06]NBVEN -1 [M:YT06]NBVEN
        [M:YT06]NBVEN-=1
    Wend
    Affzo [M:YT06]
End
######################################################################################
Subprog ELIMINAR_REG_ANT
    While [M:YT07]NBANT <>0
        NOL = 0
        Dela NOL,1,[M:YT07]NBANT -1 [M:YT07]NBANT
        [M:YT07]NBANT-=1
    Wend
    Affzo [M:YT07]
End
######################################################################################
Subprog AGRUPAR_VENTAS
    Local       Integer FAM_NOL

    If [M:YST5]PRIAGR(0) = 2
        FAM_NOL = 0
    Elsif [M:YST5]PRIAGR(1) = 2
        FAM_NOL = 1
    Elsif [M:YST5]PRIAGR(2) = 2
        FAM_NOL = 2
    Elsif [M:YST5]PRIAGR(3) = 2
        FAM_NOL = 3
    Elsif [M:YST5]PRIAGR(4) = 2
        FAM_NOL = 4
    Endif

    For I=0 To [M:YT06]NBVEN-1
        Read [SID]SID0 = [M:YT06]SIHNUM(I);[M:YT06]SIDLIN(I) : If fstat  : Raz [SID] : Endif
        Call INSERT_AGR_VEN([F:SID]TSICOD(FAM_NOL),[M:YT06]QTY(I),[M:YT06]NETPRI(I),[M:YT06]CPRPRI(I))
    Next

    Affzo [M:YT06]10
End
######################################################################################
Subprog INSERT_AGR_VEN(FAMILIA,CANTIDAD,PRIVEN,PRICOST)
    Variable    Char    FAMILIA
    Variable    Decimal CANTIDAD
    Variable    Decimal PRIVEN
    Variable    Decimal PRICOST
    Local       Integer PRI_NOL

    PRI_NOL=find(FAMILIA,[M:YT06]FAMART(0..[M:YT06]NBPRI-1))
    If (PRI_NOL>0)
        [M:YT06]QTYG(PRI_NOL) += CANTIDAD
        [M:YT06]IMPG(PRI_NOL) += (CANTIDAD * (PRIVEN-PRICOST))
        [M:YT06]PRIG(PRI_NOL) += arr(([M:YT06]IMPG(PRI_NOL)/[M:YT06]QTYG(PRI_NOL)),10^-GDECPRI)
    Else
        PRI_NOL = [M:YT06]NBPRI
        [M:YT06]FAMART(PRI_NOL) = FAMILIA
        [M:YT06]QTYG(PRI_NOL)   = CANTIDAD
        [M:YT06]IMPG(PRI_NOL)   = (CANTIDAD * (PRIVEN-PRICOST))
        [M:YT06]PRIG(PRI_NOL)   = arr(([M:YT06]IMPG(PRI_NOL)/[M:YT06]QTYG(PRI_NOL)),10^-GDECPRI)
        [M:YT06]NBPRI +=1
    Endif
End
######################################################################################

