#<AdxTL>@(#)0.0.0.0 $Revision$ 
##puntos de entrada para la elección de planta de expedición
##en cooperativa base cuando el usuario selecciona contramarca con recepción
##y una planta de entrega en la cooperativa base. Este punto se
##complementa cn el TRTVENISOC, en el que se asigna la planta
##de expedición, ya que por aquí no lo hace (falla)
$ACTION
  Case ACTION
  When "GENPURORD" : Gosub GENPURORD
  When "CONTREMARQ": Gosub CONTREMARQ
  When Default
  Endcase
Return


$GENPURORD
  If FICHIER = "PORDER" and ABRFIC = "POH" Then
    [F:POH]ORDDAT     = [F:SOH]ORDDAT
    [F:POH]EXTRCPDAT1 = [F:SOH]DEMDLVDAT
#    Infbox [F:POH]STOFCY
    If !clalev([ZFCY]) : Local File FACILITY [ZFCY] : Endif
      Read [ZFCY]FCY0=[F:SOQ]ZNUMFOU
      If !fstat and [F:SOH]SALFCY<>[ZFCY]FINRSPFCY Then
       [F:POH]STOFCY = [F:SOQ]ZNUMFOU
#       Infbox "intersociedad poh"
      Endif
#    Infbox "en poh STOFCY " + [F:POH]STOFCY
#    Infbox NUMFOU
  Endif
  If FICHIER = "PORDERQ" and ABRFIC = "POQ" Then
    [F:POQ]ORDDAT     = [F:SOH]ORDDAT
    [F:POQ]RETRCPDAT  = [F:SOH]DEMDLVDAT
    [F:POQ]EXTRCPDAT  = [F:SOH]DEMDLVDAT
#    Infbox "EN PORDERQ " +[F:POQ]LINSTOFCY + " NOLIGN=" + num$(nolign)
    If !clalev([ZFCY]) : Local File FACILITY [ZFCY] : Endif
      Read [ZFCY]FCY0=[F:SOQ]ZNUMFOU
      If !fstat and [F:SOH]SALFCY<>[ZFCY]FINRSPFCY Then
       [M:POI1]LINSTOFCY(nolign)=[F:SOQ]ZNUMFOU
       [F:POQ]LINSTOFCY =[F:SOQ]ZNUMFOU
  #     Infbox "intersociedad poq"
      Endif
#    Infbox "EN PORDERQ2 " + [F:POQ]LINSTOFCY
  Endif
Return


$CONTREMARQ
  #ELECCIÓN CONTRAMARCA EN LÍNEA DE VENTA
  If clalev([M:SOH4]) Then
    #bucar la financiera de la cooperativa base, para que el proveedor sea la financiera
    #y el ZMUNFOU pasará a "planta de expedición" (STOFCY)
    If !clalev([ZFCY]) : Local File FACILITY [ZFCY] : Endif
    Read [ZFCY]FCY0=[F:SOQ]ZNUMFOU
    If !fstat and [F:SOH]SALFCY<>[ZFCY]FINRSPFCY Then
      #en el caso que el proveedor sea planta, pero no sea la misma financiera que la de vente
      #que es el caso interplanta
      NUMFOU = [ZFCY]FINRSPFCY
  #    Infbox "Proveedor no interplanta " + NUMFOU
    Else
      #PARA EL CASO EN QUE EL PROVEEDOR SELECCIONADO SEA UN TERCERO (NO PLANTA), o no sea la misma
      #financiera (caso interplanta)
      NUMFOU = [F:SOQ]ZNUMFOU
  #    Infbox "proveedor interplanta"
    Endif
  Endif
Return


