  Filter [F:ADI]

End

##########################################################################################
#**
#* Oculta campos de pantalla de FACTURAS DE VENTAS
#*
#* @param PTRAN
#*!
Subprog OCULTA_SIH(PTRAN)
  # Si el campo no existe en la tabla varia, lo ocultamos
  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZCANT1"
  Read [F:ADI] First
  If fstat Then
     Chgfmt [M:ZSIH4]ZCANT1 With "-N:15"
     Titcol [M:ZSIH4]ZNBLIG " " For ZCANT1
     Diszo [M:ZSIH4]ZCANT1
  Else
     # Chgfmt [M:ZSIH4]ZCANT1 With "N:15"
     If GFLAG="BOG" Then
      Titcol [M:ZSIH4]ZNBLIG "Hectolitro " For ZCANT1
      Titcol [M:SIH4]NBLIG "Hectolitro " For ZCANT1
      Titcol [M:SIH4]NBLIG "Precio HLT " For ZPRECIO1
     Else
      Titcol [M:ZSIH4]ZNBLIG "Cantidad 1 " For ZCANT1
     Endif
     Actzo [M:ZSIH4]ZCANT1
     Actzo [M:SIH4]ZCANT1
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZCANT2"
  Read [F:ADI] First
  If fstat Then
      Chgfmt [M:ZSIH4]ZCANT2 With "-N:15"
      Titcol [M:ZSIH4]ZNBLIG " " For ZCANT2
      Diszo [M:ZSIH4]ZCANT2
  Else
      # Chgfmt [M:ZSIH4]ZCANT2 With "N:15"
      If GFLAG="BOG" Then
        Titcol [M:ZSIH4]ZNBLIG "Hectogrado " For ZCANT2
        Titcol [M:SIH4]NBLIG "Hectogrado " For ZCANT2
        Titcol [M:SIH4]NBLIG "Precio HGD " For ZPRECIO2
      Else
        Titcol [M:ZSIH4]ZNBLIG "Cantidad 2 " For ZCANT2
