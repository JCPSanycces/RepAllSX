  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZPUNTOS"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZSDH2]ZPUNTOS With "-N:10"
    Titcol [M:ZSDH2]ZNBLIC " " For ZPUNTOS
    Diszo [M:ZSDH2]ZPUNTOS
  Else
    # Chgfmt [M:ZSDH2]ZPUNTOS With "N:10"
