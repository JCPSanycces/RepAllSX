    # Chgfmt [M:ZSDH2]ZCALIDAD With "K:10"
    Titcol [M:ZSDH2]ZNBLIC "Calidad" For ZCALIDAD
    Actzo [M:ZSDH2]ZCALIDAD
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZGRADO"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZSDH2]ZGRADO With "-N:10"
    Titcol [M:ZSDH2]ZNBLIC " " For ZGRADO
    Diszo [M:ZSDH2]ZGRADO
  Else
   # Chgfmt [M:ZSDH2]ZGRADO With "N:10"
    Titcol [M:ZSDH2]ZNBLIC "Grado" For ZGRADO
    Actzo [M:ZSDH2]ZGRADO
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZHUMEDAD"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZSDH2]ZHUMEDAD With "-N:10"
    Titcol [M:ZSDH2]ZNBLIC " " For ZHUMEDAD
    Diszo [M:ZSDH2]ZHUMEDAD
  Else
    # Chgfmt [M:ZSDH2]ZHUMEDAD With "N:10"
    Titcol [M:ZSDH2]ZNBLIC "Humedad" For ZHUMEDAD
    Actzo [M:ZSDH2]ZHUMEDAD
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZRENDIMIENTO"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZSDH2]ZRENDIMIENTO With "-N:10"
    Titcol [M:ZSDH2]ZNBLIC " " For ZRENDIMIENTO
    Diszo [M:ZSDH2]ZRENDIMIENTO
