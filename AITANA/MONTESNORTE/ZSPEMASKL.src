  Else
    # Chgfmt [M:ZPIH3]ZGLUCONICO With "N:10"
    Titcol [M:ZPIH3]ZNBLIG "Glucónico " For ZGLUCONICO
    Actzo [M:ZPIH3]ZGLUCONICO
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZPOTASIO"
