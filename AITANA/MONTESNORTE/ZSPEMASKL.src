  If fstat Then
    Chgfmt [M:ZSDH2]ZDENSIDAD With "-N:10"
    Titcol [M:ZSDH2]ZNBLIC " " For ZDENSIDAD
    Diszo [M:ZSDH2]ZDENSIDAD
  Else
    # Chgfmt [M:ZSDH2]ZDENSIDAD With "N:10"
    Titcol [M:ZSDH2]ZNBLIC "Densidad" For ZDENSIDAD
    Actzo [M:ZSDH2]ZDENSIDAD
  Endif

  Filter [F:ADI]

End
##########################################################################################
#**
#* Oculta campos de Facturas de RECEPCIONES
#*
#* @param PTRAN
#*!
Subprog OCULTA_PTH(PTRAN)
  # Si el campo no existe en la tabla varia, lo ocultamos
  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZCANT1"
  Read [F:ADI] First
  If fstat Then
     Chgfmt [M:ZPTH1]ZCANT1 With "-N:15"
     Titcol [M:ZPTH1]ZNBLIC " " For ZCANT1
     Diszo [M:ZPTH1]ZCANT1
  Else
     # Chgfmt [M:ZPTH1]ZCANT1 With "N:15"
     Titcol [M:ZPTH1]ZNBLIC "Cantidad 1 " For ZCANT1
     Actzo [M:ZPTH1]ZCANT1
  Endif


  #Diszo [M:ZPTH1]ZVTCAMPO

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZCANT2"
  Read [F:ADI] First
  If fstat Then
      Chgfmt [M:ZPTH1]ZCANT2 With "-N:15"
      Titcol [M:ZPTH1]ZNBLIC " " For ZCANT2
      Diszo [M:ZPTH1]ZCANT2
  Else
      # Chgfmt [M:ZPTH1]ZCANT2 With "N:15"
      Titcol [M:ZPTH1]ZNBLIC "Cantidad 2" For ZCANT2
      Actzo [M:ZPTH1]ZCANT2
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZCALIDAD"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZPTH1]ZCALIDAD With "-K:10"
    Titcol [M:ZPTH1]ZNBLIC " " For ZCALIDAD
    Diszo [M:ZPTH1]ZCALIDAD
  Else
    # Chgfmt [M:ZPTH1]ZCALIDAD With "K:10"
    Titcol [M:ZPTH1]ZNBLIC "Calidad" For ZCALIDAD
    Actzo [M:ZPTH1]ZCALIDAD
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZGRADO"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZPTH1]ZGRADO With "-N:10"
    Titcol [M:ZPTH1]ZNBLIC " " For ZGRADO
    Diszo [M:ZPTH1]ZGRADO
  Else
    # Chgfmt [M:ZPTH1]ZGRADO With "N:10"
    Titcol [M:ZPTH1]ZNBLIC "Grado" For ZGRADO
    Actzo [M:ZPTH1]ZGRADO
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZHUMEDAD"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZPTH1]ZHUMEDAD With "-N:10"
    Titcol [M:ZPTH1]ZNBLIC " " For ZHUMEDAD
    Diszo [M:ZPTH1]ZHUMEDAD
  Else
    # Chgfmt [M:ZPTH1]ZHUMEDAD With "N:10"
    Titcol [M:ZPTH1]ZNBLIC "Humedad" For ZHUMEDAD
    Actzo [M:ZPTH1]ZHUMEDAD
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZRENDIMIENTO"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZPTH1]ZRENDIMIENTO With "-N:10"
    Titcol [M:ZPTH1]ZNBLIC " " For ZRENDIMIENTO
    Diszo [M:ZPTH1]ZRENDIMIENTO
  Else
    # Chgfmt [M:ZPTH1]ZRENDIMIENTO With "N:10"
    Titcol [M:ZPTH1]ZNBLIC "Rendimiento" For ZRENDIMIENTO
    Actzo [M:ZPTH1]ZRENDIMIENTO
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZPESOESPE"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZPTH1]ZPESOESPE With "-N:10"
    Titcol [M:ZPTH1]ZNBLIC " " For ZPESOESPE
    Diszo [M:ZPTH1]ZPESOESPE
  Else
    # Chgfmt [M:ZPTH1]ZPESOESPE With "N:10"
    Titcol [M:ZPTH1]ZNBLIC "Peso" For ZPESOESPE
    Actzo [M:ZPTH1]ZPESOESPE
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZPH"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZPTH1]ZPH With "-N:10"
    Titcol [M:ZPTH1]ZNBLIC " " For ZPH
    Diszo [M:ZPTH1]ZPH
  Else
    # Chgfmt [M:ZPTH1]ZPH With "N:10"
    Titcol [M:ZPTH1]ZNBLIC "Ph" For ZPH
    Actzo [M:ZPTH1]ZPH
  Endif


  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZGLUCONICO"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZPTH1]ZGLUCONICO With "-N:10"
    Titcol [M:ZPTH1]ZNBLIC " " For ZGLUCONICO
    Diszo [M:ZPTH1]ZGLUCONICO
  Else
    # Chgfmt [M:ZPTH1]ZGLUCONICO With "N:10"
    Titcol [M:ZPTH1]ZNBLIC "Gluconico" For ZGLUCONICO
    Actzo [M:ZPTH1]ZGLUCONICO
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZPOTASIO"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZPTH1]ZPOTASIO With "-N:10"
    Titcol [M:ZPTH1]ZNBLIC " " For ZPOTASIO
    Diszo [M:ZPTH1]ZPOTASIO
  Else
    # Chgfmt [M:ZPTH1]ZPOTASIO With "N:10"
    Titcol [M:ZPTH1]ZNBLIC "Potasio" For ZPOTASIO
    Actzo [M:ZPTH1]ZPOTASIO
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZPUNTOS"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZPTH1]ZPUNTOS With "-N:10"
    Titcol [M:ZPTH1]ZNBLIC " " For ZPUNTOS
    Diszo [M:ZPTH1]ZPUNTOS
  Else
    # Chgfmt [M:ZPTH1]ZPUNTOS With "N:10"
    Titcol [M:ZPTH1]ZNBLIC "Puntos" For ZPUNTOS
    Actzo [M:ZPTH1]ZPUNTOS
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZDENSIDAD"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZPTH1]ZDENSIDAD With "-N:10"
    Titcol [M:ZPTH1]ZNBLIC " " For ZDENSIDAD
    Diszo [M:ZPTH1]ZDENSIDAD
  Else
    # Chgfmt [M:ZPTH1]ZDENSIDAD With "N:10"
    Titcol [M:ZPTH1]ZNBLIC "Densidad" For ZDENSIDAD
    Actzo [M:ZPTH1]ZDENSIDAD
  Endif

  Filter [F:ADI]

End

#**
#*
#*
#* @param PTRAN
#* @param PCAMPO
#* Ejemplo de llamada:
#* func ZSPEMASKL.SET_ESTADO_CAMPO('SDH', GFLAG, 'ZCALIDAD')
#*!
Funprog SET_ESTADO_CAMPO(PTRAN, PFLAG, PCAMPO )
  Local Integer LRES
  Local Integer ASTATUS
  If !clalev([ADI]) : Local File ATABDIV [ADI] : Endif
  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=PFLAG and A3=PCAMPO
  Read [F:ADI] First
  If fstat Then
     LRES = 0
  Else
     LRES = 1
  Endif
  Filter [F:ADI]
End LRES

