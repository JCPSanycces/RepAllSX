    Diszo [M:ZSIH4]ZPUNTOS
  Else
    # Chgfmt [M:ZSIH4]ZPUNTOS With "N:10"
    Titcol [M:ZSIH4]ZNBLIG "Puntos " For ZPUNTOS
  Endif

  Filter [F:ADI]

End
##########################################################################################
#**
#* Oculta campos de Facturas de ENTREGAS
#*
#* @param PTRAN
#*!
Subprog OCULTA_SDH(PTRAN)
   # Si el campo no existe en la tabla varia, lo ocultamos
  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZCANT1"
  Read [F:ADI] First
  If fstat Then
     Chgfmt [M:ZSDH2]ZCANT1 With "-N:15"
     Titcol [M:ZSDH2]ZNBLIC " " For ZCANT1
     Diszo [M:ZSDH2]ZCANT1
  Else
    # Chgfmt [M:ZSDH2]ZCANT1 With "N:15"
     If GFLAG="BOG" Then
      Titcol [M:ZSDH2]ZNBLIC "Hectolitro " For ZCANT1
      Titcol [M:SDH1]NBLIG "Hectolitro " For ZCANT1
     Else
      Titcol [M:ZSDH2]ZNBLIC "Cantidad 1 " For ZCANT1
     Endif
     Actzo [M:ZSDH2]ZCANT1
     Actzo [M:SDH1]ZCANT1
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZCANT2"
  Read [F:ADI] First
  If fstat Then
      Chgfmt [M:ZSDH2]ZCANT2 With "-N:15"
      Titcol [M:ZSDH2]ZNBLIC " " For ZCANT2
      Diszo [M:ZSDH2]ZCANT2
  Else
     # Chgfmt [M:ZSDH2]ZCANT2 With "N:15"
      If GFLAG="BOG" Then
        Titcol [M:ZSDH2]ZNBLIC "Hectogrado " For ZCANT2
        Titcol [M:SDH1]NBLIG "Hectogrado " For ZCANT2
      Else
        Titcol [M:ZSDH2]ZNBLIC "Cantidad 2" For ZCANT2
      Endif
      Actzo [M:ZSDH2]ZCANT2
