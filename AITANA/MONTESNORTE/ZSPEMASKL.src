#<AdxTL>@(#)0.0.0.0 $Revision$
#**
#* Sub que oculta campos de la transacción si no están definidos en la tabla varia 6100
#*
#* @param PTRAN _Nombre de la transacción
#*!
Subprog OCULTA_CAMPOS(PTRAN)

  If !clalev([ADI]) : Local File ATABDIV [ADI] : Endif
  # Declaración de pantalla
  Case PTRAN   # GABREV --> Variable que nos devuelve el nombre de pantalla
    When "SDH" : Call OCULTA_SDH(PTRAN) # ENTREGAS
    When "PTH" : Call OCULTA_PTH(PTRAN) # RECEPCIONES
    When "SIH" : Call OCULTA_SIH(PTRAN) # VENTAS
    When "PIH" : Call OCULTA_PIH(PTRAN) # COMPRAS
  Endcase

End
##########################################################################################
#**
#* Oculta campos de Facturas de COMPRAS
#*
#* @param PTRAN
#*!
Subprog OCULTA_PIH(PTRAN)
  # Si el campo no existe en la tabla varia, lo ocultamos
  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZCANT1"
  Read [F:ADI] First
  If fstat Then
     Chgfmt [M:ZPIH3]ZCANT1 With "-N:15"
     Titcol [M:ZPIH3]ZNBLIG " " For ZCANT1
     Diszo [M:ZPIH3]ZCANT1
  Else
    # Chgfmt [M:ZPIH3]ZCANT1 With "N:15"
     Titcol [M:ZPIH3]ZNBLIG "Cantidad 1 " For ZCANT1
     Actzo [M:ZPIH3]ZCANT1
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZCANT2"
  Read [F:ADI] First
  If fstat Then
      Chgfmt [M:ZPIH3]ZCANT2 With "-N:15"
      Titcol [M:ZPIH3]ZNBLIG " " For ZCANT2
      Diszo [M:ZPIH3]ZCANT2
  Else
     # Chgfmt [M:ZPIH3]ZCANT2 With "N:15"
      Titcol [M:ZPIH3]ZNBLIG "Cantidad 2 " For ZCANT2
      Actzo [M:ZPIH3]ZCANT2
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZCALIDAD"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZPIH3]ZCALIDAD With "-K:10"
    Titcol [M:ZPIH3]ZNBLIG " " For ZCALIDAD
    Diszo [M:ZPIH3]ZCALIDAD
  Else
   # Chgfmt [M:ZPIH3]ZCALIDAD With "K:10"
    Titcol [M:ZPIH3]ZNBLIG "Calidad " For ZCALIDAD
    Actzo [M:ZPIH3]ZCALIDAD
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZGRADO"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZPIH3]ZGRADO With "-N:10"
    Titcol [M:ZPIH3]ZNBLIG " " For ZGRADO
    Diszo [M:ZPIH3]ZGRADO
  Else
    # Chgfmt [M:ZPIH3]ZGRADO With "N:10"
    Titcol [M:ZPIH3]ZNBLIG "Grado " For ZGRADO
    Actzo [M:ZPIH3]ZGRADO
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZHUMEDAD"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZPIH3]ZHUMEDAD With "-N:10"
    Titcol [M:ZPIH3]ZNBLIG " " For ZHUMEDAD
    Diszo [M:ZPIH3]ZHUMEDAD
  Else
    # Chgfmt [M:ZPIH3]ZHUMEDAD With "N:10"
    Titcol [M:ZPIH3]ZNBLIG "Humedad " For ZHUMEDAD
    Actzo [M:ZPIH3]ZHUMEDAD
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZRENDIMIENTO"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZPIH3]ZRENDIMIENTO With "-N:10"
    Titcol [M:ZPIH3]ZNBLIG " " For ZRENDIMIENTO
    Diszo [M:ZPIH3]ZRENDIMIENTO
  Else
   # Chgfmt [M:ZPIH3]ZRENDIMIENTO With "N:10"
    Titcol [M:ZPIH3]ZNBLIG "Rendimiento " For ZRENDIMIENTO
    Actzo [M:ZPIH3]ZRENDIMIENTO
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZPESOESPE"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZPIH3]ZPESOESPE With "-N:10"
    Titcol [M:ZPIH3]ZNBLIG " " For ZPESOESPE
    Diszo [M:ZPIH3]ZPESOESPE
  Else
   # Chgfmt [M:ZPIH3]ZPESOESPE With "N:10"
    Titcol [M:ZPIH3]ZNBLIG "Peso " For ZPESOESPE
    Actzo [M:ZPIH3]ZPESOESPE
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZPH"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZPIH3]ZPH With "-N:10"
    Titcol [M:ZPIH3]ZNBLIG " " For ZPH
