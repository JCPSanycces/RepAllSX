    Actzo [M:ZSIH4]ZGLUCONICO
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZPOTASIO"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZSIH4]ZPOTASIO With "-K:10"
    Titcol [M:ZSIH4]ZNBLIG " " For ZPOTASIO
    Diszo [M:ZSIH4]ZPOTASIO
  Else
    # Chgfmt [M:ZSIH4]ZPOTASIO With "K:10"
    Titcol [M:ZSIH4]ZNBLIG "Potasio " For ZPOTASIO
    Actzo [M:ZSIH4]ZPOTASIO
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZPUNTOS"
  Read [F:ADI] First
  If fstat Then
