  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZCALIDAD"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZSDH2]ZCALIDAD With "-K:10"
    Titcol [M:ZSDH2]ZNBLIC " " For ZCALIDAD
    Diszo [M:ZSDH2]ZCALIDAD
