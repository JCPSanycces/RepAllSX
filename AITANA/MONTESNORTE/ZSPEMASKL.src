  If fstat Then
    Chgfmt [M:ZSDH2]ZGLUCONICO With "-N:10"
    Titcol [M:ZSDH2]ZNBLIC " " For ZGLUCONICO
    Diszo [M:ZSDH2]ZGLUCONICO
  Else
    # Chgfmt [M:ZSDH2]ZGLUCONICO With "N:10"
