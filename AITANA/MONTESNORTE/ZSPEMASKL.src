    Titcol [M:ZSIH4]ZNBLIG " " For ZRENDIMIENTO
    Diszo [M:ZSIH4]ZRENDIMIENTO
  Else
    # Chgfmt [M:ZSIH4]ZRENDIMIENTO With "K:10"
