    Actzo [M:ZSDH2]ZRENDIMIENTO
  Endif


  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZPESOESPE"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZSDH2]ZPESOESPE With "-N:10"
    Titcol [M:ZSDH2]ZNBLIC " " For ZPESOESPE
    Diszo [M:ZSDH2]ZPESOESPE
  Else
    # Chgfmt [M:ZSDH2]ZPESOESPE With "N:10"
    Titcol [M:ZSDH2]ZNBLIC "Peso" For ZPESOESPE
    Actzo [M:ZSDH2]ZPESOESPE
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZPH"
