      Actzo [M:ZSIH4]ZCANT2
      Actzo [M:SIH4]ZCANT2
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZCALIDAD"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZSIH4]ZCALIDAD With "-K:10"
    Titcol [M:ZSIH4]ZNBLIG " " For ZCALIDAD
    Diszo [M:ZSIH4]ZCALIDAD
  Else
    # Chgfmt [M:ZSIH4]ZCALIDAD With "K:10"
    Titcol [M:ZSIH4]ZNBLIG "Calidad " For ZCALIDAD
    Actzo [M:ZSIH4]ZCALIDAD
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZGRADO"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZSIH4]ZGRADO With "-K:10"
    Titcol [M:ZSIH4]ZNBLIG " " For ZGRADO
    Diszo [M:ZSIH4]ZGRADO
  Else
    # Chgfmt [M:ZSIH4]ZGRADO With "K:10"
    Titcol [M:ZSIH4]ZNBLIG "Grado " For ZGRADO
    Actzo [M:ZSIH4]ZGRADO
  Endif

  Filter [F:ADI] Where NUMTAB=6100 and A1 = PTRAN and A2=GFLAG and A3="ZDENSIDAD"
  Read [F:ADI] First
  If fstat Then
    Chgfmt [M:ZSIH4]ZDENSIDAD With "-K:10"
    Titcol [M:ZSIH4]ZNBLIG " " For ZDENSIDAD
    Diszo [M:ZSIH4]ZDENSIDAD
  Else
    # Chgfmt [M:ZSIH4]ZDENSIDAD With "N:10"
    Titcol [M:ZSIH4]ZNBLIG "Densidad " For ZDENSIDAD
    Actzo [M:ZSIH4]ZDENSIDAD
