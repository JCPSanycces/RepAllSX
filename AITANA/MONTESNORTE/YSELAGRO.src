######################################################################################
# Selección de Articulos O.F
######################################################################################
$SEL_MFI
    If clalev([F:MFI])=0 : Local File MFGITM    [MFI] : Endif
    If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif
    Local Char CODFIC    : CODFIC = "MFGITM"

    Link [MFI] With [ITM]ITM0=ITMREF As [XXX]

    SIZLIG = 120  ###--Modificar altura (80 por defecto)
    SIZCOL = 300  ###--Modificar ancho (240 por defecto)

    CRITERE = PARAM(1)
    START   = "[F:MFI]ITMREF"
    TIT(0) = mess(1,5000,1) ##"Articulos"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:MFI]MFGNUM"    : Gosub YTEXTE  #TIT(NBCOL)="N.Orden"
    NBCOL += 1 : COL(NBCOL) = "[F:MFI]ITMREF"    : Gosub YTEXTE  #TIT(NBCOL)="Artículo"
    NBCOL += 1 : COL(NBCOL) = "[F:ITM]ITMDES1"   : Call TEXTFIC("ITMMASTER","ITMDES1",1,TIT(NBCOL)) From OBJDIV # TIT(NBCOL)="Descripción"
    NBCOL += 1 : COL(NBCOL) = "[F:MFI]UOM"       : Gosub YTEXTE  #TIT(NBCOL)="Unidad"
    NBCOL += 1 : COL(NBCOL) = "[F:MFI]YCODIENV"  : Gosub YTEXTE  #TIT(NBCOL)="Envase"
    NBCOL += 1 : COL(NBCOL) = "[F:MFI]YCODISUP"  : Gosub YTEXTE  #TIT(NBCOL)="Soporte"

    Default File [XXX]
Return
######################################################################################
# Selección de Plantas
######################################################################################
$SEL_FCY
    If PARAM(1)="" : PARAM(1)="1=1" : Endif
    CRITERE(1) = PARAM(1)
    OPTIONS    = PARAM(2)
    OBJET      = "FCY"
Return
######################################################################################
#SVR 13-01-2014. La pantalla de facturación de recepciones, no funcionavan las seleccionar
$SEL_PTH
    Local Char CODFIC    : CODFIC = "PRECEIPT"

    CRITERE = PARAM(1)
    START   = "[F:PTH]PTHNUM"
    TIT(0) = mess(2,5000,1) ##"Recepciones"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:PTH]PTHNUM"    : Gosub YTEXTE  #TIT(NBCOL)="Recepción"
    NBCOL += 1 : COL(NBCOL) = "[F:PTH]RCPDAT"    : Gosub YTEXTE  #TIT(NBCOL)="Fecha"
    NBCOL += 1 : COL(NBCOL) = "[F:PTH]BPSNUM"    : Gosub YTEXTE  #TIT(NBCOL)="Proveedor"
    NBCOL += 1 : COL(NBCOL) = "[F:PTH]PRHFCY"    : Gosub YTEXTE  #TIT(NBCOL)="Planta"
    NBCOL += 1 : COL(NBCOL) = "[F:PTH]BPSNDE"    : Gosub YTEXTE  #TIT(NBCOL)="N.Entrega"

    Default File [PTH]
Return
######################################################################################
$TEXTE
Call TEXTFIC(CODFIC, COL(NBCOL), 1, TIT(NBCOL)) From OBJDIV
Return
######################################################################################
# Selección de Precios Liquidaciones
######################################################################################
$SEL_PREC
    If PARAM(1)="" : PARAM(1)="1=1" : Endif
    CRITERE(1) = PARAM(1)
    OPTIONS    = PARAM(2)
    OBJET      = "YT0"
Return
######################################################################################
# Selección de Palets
######################################################################################
$SEL_YV6
    If clalev([F:YV6])=0 : Local File YPPCABPAL [YV6] : Endif
    If clalev([F:YW6])=0 : Local File YPPLINPAL [YW6] : Endif
    Local Char CODFIC    : CODFIC = "YPPCABPAL"

    Link [YV6] With [YW6]YW60=NUMDOC As [XXX]

    CRITERE(1) = PARAM(1) + " and [F:YW6]TGENERA <> 2 "

    START   = "[F:YV6]NUMDOC"
    TIT(0) = mess(3,5000,1) ##"Doc. de Palets"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:YV6]NUMDOC"     : Gosub YTEXTE  #TIT(NBCOL)="Nº Documento"
    NBCOL += 1 : COL(NBCOL) = "[F:YV6]CODIPERSON" : Gosub YTEXTE  #TIT(NBCOL)="Código pers."
    NBCOL += 1 : COL(NBCOL) = "[F:YV6]DATA"       : Gosub YTEXTE  #TIT(NBCOL)="Fecha"
    Default File [XXX]
Return
######################################################################################
# Selección de Productos desde la BUSQUEDA
######################################################################################
$SEL_BUSART
#No se puede llamar directamente ésta acción. Se debe utilizar la acción YSELBUSART
    Local Char CODFIC    : CODFIC = "ITMMASTER"

    If not (dim(GSENTENCIA)>0) : Return : Endif
    Local File ATEXTRA [AX3] Where CODFIC="ATABDIV" and ZONE="SHODES" and LANGUE="SPA" and IDENT1=num$(1025)

    If len(GSENTENCIA)=254 Then
        GERR=2
        GMESSAGE=mess(89,1986,1)
        Return
    Endif

    Local File ITMMASTER [ITM] Where evalue(GSENTENCIA)

    #Existe 1 solo reg. que cumple la condición. Devolvemos el producto.
    If rowcount([ITM])=1 Then
        If GSENTENCIA<>"" Then
            Filter [ITM] Where evalue(GSENTENCIA)
        Else
            Filter [ITM] Where evalue(GSENTENCIA)
        Endif
        Read [ITM] First : If fstat  Raz [F:ITM] : Endif
        VALEUR = [F:ITM]ITMREF
        Return
    Endif

    If GYTPROD=6 or GYTPROD=7 or GYTPROD=8 Then

        #Enlazamos
        Link [ITM] With [AX3]AXX0="ATABDIV";"SHODES";"SPA";num$(1025);YCONF As [YYY]
        Default File [YYY]

        #Existe más de 1 registro que cumple la condición
        CRITERE = GSENTENCIA

        START   = "[F:ITM]ITMREF"
        TIT(0) = mess(1,5000,1) ##"Articulos"
        NBCOL = 0
        NBCOL += 1 : COL(NBCOL) = "[F:ITM]ITMREF"      : Gosub YTEXTE  #TIT(NBCOL)="Código"
        NBCOL += 1 : COL(NBCOL) = "[F:ITM]ITMDES1"     : Gosub YTEXTE  #TIT(NBCOL)="Descripción"
        NBCOL += 1 : COL(NBCOL) = "[F:ITM]YCALIBRE"    : Gosub YTEXTE  #TIT(NBCOL)="Calibre"
        NBCOL += 1 : COL(NBCOL) = "[F:ITM]YENVAS"      : Gosub YTEXTE  #TIT(NBCOL)="Envase"
        NBCOL += 1 : COL(NBCOL) = "[F:ITM]ITMDES2"     : Gosub YTEXTE  #TIT(NBCOL)="Desc.Envase"
        NBCOL += 1 : COL(NBCOL) = "[F:ITM]YCALIDAD"    : Gosub YTEXTE  #TIT(NBCOL)="Calidad"
        NBCOL += 1 : COL(NBCOL) = "[F:ITM]ITMDES3"     : Gosub YTEXTE  #TIT(NBCOL)="Calidad/Marca"
        NBCOL += 1 : COL(NBCOL) = "[F:ITM]YCONF"       : Gosub YTEXTE  #TIT(NBCOL)="Confección"
        If GYTPROD=7 Then
            NBCOL += 1 : COL(NBCOL) = "[F:AX3]TEXTE"       : TIT(NBCOL)="Desc."
        Endif

    Else
        #Llamamos a la seleccion estandard
        CRITERE(1) = GSENTENCIA
        OPTIONS    = ""
        OBJET      = "ITM"
    Endif

    Kill GSENTENCIA
    Kill GYTPROD
Return
######################################################################################
$SEL_TPROD
    If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif
    Local Char CODFIC    : CODFIC = "ITMMASTER"

    CRITERE = "[F:ITM]YTPROD = val(PARAM(1))"
    START   = "[F:ITM]ITMREF"
    TIT(0) = mess(4,5000,1) ##"Suportes"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:ITM]ITMREF"  : Gosub YTEXTE  #TIT(NBCOL)="Artículo"
    NBCOL += 1 : COL(NBCOL) = "[F:ITM]ITMDES1" : Gosub YTEXTE  #TIT(NBCOL)="Descripción"
    Default File [ITM]
Return
######################################################################################
# Selección de Clasificaciones
######################################################################################
$SEL_ALTEST
    If clalev([F:BOH])=0 : Local File BOM  [BOH] Order By Key BOH0: Endif
    Local Char CODFIC    : CODFIC = "BOM"

    CRITERE = "[F:BOH]ITMREF=PARAM(1)"
    START   = "[F:BOH]BOMALT"
    TIT(0) = mess(5,5000,1) ##"Alt. Estructura"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:BOH]BOMALT"  : Gosub YTEXTE  #TIT(NBCOL)="Código"
    NBCOL += 1 : COL(NBCOL) = "[F:BOH]BOMDES"  : Gosub YTEXTE  #TIT(NBCOL)="Descripción"
    Default File [BOH]
Return
######################################################################################
# Selección de Clasificaciones
######################################################################################
$SEL_CLA
    Local    Integer INDEX    : INDEX  = 0
    Local    Char    XCOD1    : XCOD1  = PARAM(1)
    Local    Char    XCOD2    : XCOD2  = PARAM(2)
    Local    Char    XCOD3    : XCOD3  = PARAM(3)
    Local    Integer XCLASE   : XCLASE = val(PARAM(4))

    Call BUSQUEDA_CALIBRE(XCOD1,XCOD2,XCOD3,XCLASE,INDEX)

    If clalev([F:XCC])=0 : Local File YCLASTAD  [XCC] Order By Key CLE=CODCALIBRE: Endif
    If clalev([F:XCL])=0 : Local File YCLASIFIC [XCL] : Endif

    Link [XCL] With [XCC]CLE=CODCALIBRE As [XXX]

    #Creamos la sentencia CRITERE
    CRITERE ="[F:XCC]TACTIU=2"
    If PARAM(4)<>"0" Then
        CRITERE += " & [F:XCL]CLACALIBRE <> val(PARAM(4))"
    Endif

    CRITERE += " & [F:XCC]CODI1=XCOD1 & [F:XCC]CODI2=XCOD2 & [F:XCC]CODI3=XCOD3"

    If INDEX = 1 : Call MESSAGE(mess(99,100,1)) From GESECRAN : Return : Endif

    START   = "[F:XCL]CODCALIBRE"
    TIT(0) = mess(6,5000,1) ##"Clasificaciones"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:XCC]CODI1 "     : Call TEXTFIC("YCLASTAD","CODI1",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Familia"
    If XCOD2 <> "" Then
        NBCOL += 1 : COL(NBCOL) = "[F:XCC]CODI2 " : Call TEXTFIC("YCLASTAD","CODI2",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Subfamilia"
    Endif
    If XCOD3 <> "" Then
        NBCOL += 1 : COL(NBCOL) = "[F:XCC]CODI3 " : Call TEXTFIC("YCLASTAD","CODI3",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Producto"
    Endif
    NBCOL += 1 : COL(NBCOL) = "[F:XCC]CODCALIBRE" : Call TEXTFIC("YCLASTAD","CODCALIBRE",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Código"
    NBCOL += 1 : COL(NBCOL) = "[F:XCL]NOMCALIBRE" : Call TEXTFIC("YCLASIFIC","NOMCALIBRE",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Descripción"
    NBCOL += 1 : COL(NBCOL) = "[F:XCL]CLACALIBRE" : Call TEXTFIC("YCLASIFIC","CLACALIBRE",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Clase"
    Default File [XXX]
Return
######################################################################################
# Selección de Calidades
######################################################################################
$SEL_CAL
    Local    Integer INDEX    : INDEX  = 0
    Local    Char    XCOD1    : XCOD1  = PARAM(1)
    Local    Char    XCOD2    : XCOD2  = PARAM(2)
    Local    Char    XCOD3    : XCOD3  = PARAM(3)
    Local    Integer XCLASE   : XCLASE = val(PARAM(4))

    Call BUSQUEDA_CALIDAD(XCOD1,XCOD2,XCOD3,XCLASE,INDEX)

    If clalev([F:XCS])=0 : Local File YCALSTAD [XCS] Order By Key CLE=CODCALIDAD: Endif
    If clalev([F:XCA])=0 : Local File YCALIDAD [XCA] : Endif

    #Creamos la sentencia CRITERE
    CRITERE ="[F:XCS]TACTIU=2"
    If PARAM(4)<>"0" Then
        CRITERE += " & [F:XCA]CLASECALID <> val(PARAM(4))"
    Endif

    CRITERE += " & [F:XCS]CODI1=XCOD1 & [F:XCS]CODI2=XCOD2 & [F:XCS]CODI3=XCOD3"

    If INDEX = 1 : Call MESSAGE(mess(99,100,1)) From GESECRAN : Return : Endif

    Link [XCA] With [XCS]CLE=CODCALIDAD As [XXX]

    START   = "[F:XCA]CODCALIDAD"
    TIT(0) = mess(7,5000,1) ##"Calidades"
    NBCOL = 0

    NBCOL += 1 : COL(NBCOL) = "[F:XCS]CODI1 "     : Call TEXTFIC("YCALSTAD","CODI1",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Familia"
    If XCOD2 <> "" Then
        NBCOL += 1 : COL(NBCOL) = "[F:XCS]CODI2 " : Call TEXTFIC("YCALSTAD","CODI2",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Subfamilia"
    Endif
    If XCOD3 <> "" Then
        NBCOL += 1 : COL(NBCOL) = "[F:XCS]CODI3 " : Call TEXTFIC("YCALSTAD","CODI3",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Producto"
    Endif

    NBCOL += 1 : COL(NBCOL) = "[F:XCS]CODCALIDAD" : Call TEXTFIC("YCALSTAD","CODCALIDAD",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Código"
    NBCOL += 1 : COL(NBCOL) = "[F:XCA]NOMCALIDAD" : Call TEXTFIC("YCALIDAD","NOMCALIDAD",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Descripción"
    NBCOL += 1 : COL(NBCOL) = "[F:XCA]CLASECALID" : Call TEXTFIC("YCALIDAD","CLASECALID",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Clase"
    Default File [XXX]
Return
######################################################################################
# Selección de Calificaciones
######################################################################################
$SEL_CAF
    Local Integer INDEX : INDEX = 0

    If clalev([F:XFS])=0 : Local File YCAFSTAD [XFS] Order By Key CLE=CODCALIFIC: Endif
    If clalev([F:YCF])=0 : Local File YCALIFIC [YCF] : Endif

    #Creamos la sentencia CRITERE
    CRITERE ="[F:XFS]TACTIU=2"
    If PARAM(4)<>"0" Then
        CRITERE += " & [F:YCF]CLACALIFI <> val(PARAM(4))"
    Endif

    Filter [XFS] Where TACTIU=2 and CODI1=PARAM(1) and CODI2=PARAM(2) and CODI3=PARAM(3)
    If rowcount([XFS])>0 Then
        CRITERE += " & [F:XFS]CODI1=PARAM(1) & [F:XFS]CODI2=PARAM(2) & [F:XFS]CODI3=PARAM(3)"
        INDEX = 1
    Else
        Filter [XFS] Where TACTIU=2 and CODI1=PARAM(1) and CODI2=PARAM(2) and CODI3=""
        If rowcount([XFS])>0 Then
            CRITERE += " & [F:XFS]CODI1=PARAM(1) & [F:XFS]CODI2=PARAM(2) & [F:XFS]CODI3=''"
            INDEX = 2
        Else
            Filter [XFS] Where TACTIU=2 and CODI1=PARAM(1) and CODI2="" and CODI3=""
            If rowcount([XFS])>0 Then
                CRITERE += " & [F:XFS]CODI1=PARAM(1) & [F:XFS]CODI2='' & [F:XFS]CODI3=''"
                INDEX = 3
            Endif
        Endif
    Endif

    If INDEX = 0 : Call MESSAGE(mess(99,100,1)) From GESECRAN : Return : Endif

    Filter [XFS] Where TACTIU=2
    Link [YCF] With [XFS]CLE=CODCALIFIC As [XXX]

    START   = "[F:YCF]CODCALIFIC"
    TIT(0) = mess(8,5000,1) ##"Calificaciones"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:XFS]CODI1 "     : Call TEXTFIC("YCAFSTAD","CODI1",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Familia"
    If INDEX=1 or INDEX=2 Then
        NBCOL += 1 : COL(NBCOL) = "[F:XFS]CODI2 " : Call TEXTFIC("YCAFSTAD","CODI2",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Subfamilia"
    Endif
    If INDEX=1 Then
        NBCOL += 1 : COL(NBCOL) = "[F:XFS]CODI3 " : Call TEXTFIC("YCAFSTAD","CODI3",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Producto"
    Endif
    NBCOL += 1 : COL(NBCOL) = "[F:XFS]CODCALIFIC" : Call TEXTFIC("YCAFSTAD","CODCALIFIC",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Código"
    NBCOL += 1 : COL(NBCOL) = "[F:YCF]NOMCALIFIC" : Call TEXTFIC("YCALIFIC","NOMCALIFIC",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Descripción"
    NBCOL += 1 : COL(NBCOL) = "[F:YCF]CLACALIFI"  : Call TEXTFIC("YCALIFIC","CLACALIFI",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Clase"
    Default File [XXX]
Return
######################################################################################
# Selección de Envases a ENVSTAD o ITMMASTER
######################################################################################
$SEL_ENVASE
    Local Integer INDEX

    If clalev([F:YES])=0 : Local File YENVSTAD  [YES] : Endif
    #Abrimos los envases de la tabla de productos
    If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] Where [F:ITM]YTPROD=2 : Endif

    #Creamos la sentencia CRITERE
    Filter [YES] Where TACTIU=2 and CODI1=PARAM(1) and CODI2=PARAM(2) and CODI3=PARAM(3)
    If rowcount([YES])>0 Then
        CRITERE = "[F:YES]CODI1=PARAM(1) & [F:YES]CODI2=PARAM(2) & [F:YES]CODI3=PARAM(3)"
        INDEX = 1
    Else
        Filter [YES] Where TACTIU=2 and CODI1=PARAM(1) and CODI2=PARAM(2) and CODI3=""
        If rowcount([YES])>0 Then
            CRITERE = "[F:YES]CODI1=PARAM(1) & [F:YES]CODI2=PARAM(2) & [F:YES]CODI3=''"
            INDEX = 2
        Else
            Filter [YES] Where TACTIU=2 and CODI1=PARAM(1) and CODI2="" and CODI3=""
            If rowcount([YES])>0 Then
                CRITERE = "[F:YES]CODI1=PARAM(1) & [F:YES]CODI2='' & [F:YES]CODI3=''"
            INDEX = 3
            Endif
        Endif
    Endif

    If CRITERE="" Then
        #Acceso a Producto
        CRITERE(1) = "[F:ITM]YTPROD=2"
        OPTIONS    = ""
        OBJET      = "ITM"
    Else
        #Acceso a Envases
        Filter [YES] Where TACTIU=2
        Link [YES] With [ITM]ITM0=CODENVASE As [XXX]

        START   = "[F:YES]CODENVASE"
        TIT(0) = mess(9,5000,1) ##"Envases"
        NBCOL = 0
        NBCOL += 1 : COL(NBCOL) = "[F:YES]CODI1 "     : Call TEXTFIC("YENVSTAD","CODI1",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Familia"
        If INDEX=1 or INDEX=2 Then
            NBCOL += 1 : COL(NBCOL) = "[F:YES]CODI2 " : Call TEXTFIC("YENVSTAD","CODI2",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Subfamilia"
        Endif
        If INDEX=1 Then
            NBCOL += 1 : COL(NBCOL) = "[F:YES]CODI3 " : Call TEXTFIC("YENVSTAD","CODI3",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Producto"
        Endif
        NBCOL += 1 : COL(NBCOL) = "[F:YES]CODENVASE " : Call TEXTFIC("YENVSTAD","CODENVASE",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Envase"
        NBCOL += 1 : COL(NBCOL) = "[F:ITM]ITMDES1"    : Call TEXTFIC("ITMMASTER","ITMDES1",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Descripción"
        Default File [XXX]
    Endif
Return
######################################################################################
# Selección de Plantaciones
######################################################################################
$SEL_FIN
    Local Char CODFIC
    If GYHESPERID=1 Then
        Local    Integer XNUM_REG : XNUM_REG = 0
        Local    Integer XNOL_REG : XNOL_REG = nolign-1

        If GABREV = "YCI" and [M:YCI1]POHNUM(XNOL_REG) <> ""

            If clalev([F:YP1])=0 : Local File YPCLINFI  [YP1] : Endif

            For [YP1] Where POHNUMP = [M:YCI1]POHNUM(XNOL_REG) and NUMLIN = [M:YCI1]POPLIN(XNOL_REG)
                XNUM_REG +=1
                Break
            Next

        Endif

        If XNUM_REG >0

            Link [YP1] With [YPL]YPL0=EXERCICI;CODIPLANTA As [XXX]

            CRITERE(1) = "[YPL]TESTACTIU=2"
            CRITERE(1) += " & [YP1]POHNUMP='" + [M:YCI1]POHNUM(XNOL_REG) + "'"
            CRITERE(1) += " & [YP1]NUMLIN=" +  num$([M:YCI1]POPLIN(XNOL_REG))

            If PARAM(1)<>"" Then
                CRITERE(1) += " & [YPL]EXERCICI='" + PARAM(1) + "'"
            Endif
            If PARAM(2)<>"" Then
                CRITERE(1) += " & [YPL]VARIETAT='" + PARAM(2) + "'"
            Endif
            If PARAM(3)<>"" Then
                CRITERE(1) += " & [YPL]CODIPROPI= '" + PARAM(3) + "'"
            Endif
            CODFIC = "YPLANTACI"

            START   = "[F:YPL]CODIPLANTA"
            TIT(0) = mess(10,5000,1) ##"Plantaciones"
            NBCOL = 0
            NBCOL += 1 : COL(NBCOL) = "[F:YPL]EXERCICI"   : Gosub YTEXTE  #TIT(NBCOL)="Ejercicio"
            NBCOL += 1 : COL(NBCOL) = "[F:YPL]CODIPLANTA" : Gosub YTEXTE  #TIT(NBCOL)="Cod. plant."
            NBCOL += 1 : COL(NBCOL) = "[F:YPL]NOMPLANTA"  : Gosub YTEXTE  #TIT(NBCOL)="Descripción"
            NBCOL += 1 : COL(NBCOL) = "[F:YPL]CODIPROPI"  : Gosub YTEXTE  #TIT(NBCOL)="Cod. propiet"
            NBCOL += 1 : COL(NBCOL) = "[F:YPL]VARIETAT"   : Gosub YTEXTE  #TIT(NBCOL)="Variedad"
            NBCOL += 1 : COL(NBCOL) = "[F:YPL]CODIFINCA"  : Gosub YTEXTE  #TIT(NBCOL)="Código finca"

            Default File [XXX]

        Else
   ### Proceso modificado por JGAYA 16/07/07, para incluir la descripción de la variedad
   ### en la selección.

            #Accede a la tabla de plantaciones ya que no existe la aplicación de hesperides.

            CRITERE(1) = "[F:YPL]TESTACTIU=2"
            If PARAM(1)<>"" Then
                CRITERE(1) += " & [F:YPL]EXERCICI='" + PARAM(1) + "'"
            Endif
            If PARAM(2)<>"" Then
                CRITERE(1) += " & [F:YPL]VARIETAT='" + PARAM(2) + "'"
            Endif
            If PARAM(3)<>"" Then
                CRITERE(1) += " & [F:YPL]CODIPROPI= '" + PARAM(3) + "'"
            Endif

            OPTIONS    = ""
            OBJET      = "YPL"
        Endif

    Else
        #Accede a la tabla ARITMOS que contiene las plantaciones según hesperides.
        If clalev([F:YAR])=0 : Local File YARITMOS [YAR] Order By Key YAR1 : Endif
        CODFIC = "YARITMOS"

        CRITERE = "[F:YAR]EXERCICI=PARAM(1) & [F:YAR]CPRODUCTE=PARAM(2) & [F:YAR]PROPIETARI = PARAM(3)"
        START   = "[F:YAR]CPLANTACIO"

        TIT(0) = mess(10,5000,1) ##"Plantaciones"
        NBCOL = 0
        NBCOL += 1 : COL(NBCOL) = "[F:YAR]EXERCICI"   : Gosub YTEXTE  #TIT(NBCOL)="Campaña"
        NBCOL += 1 : COL(NBCOL) = "[F:YAR]CPLANTACIO" : Gosub YTEXTE  #TIT(NBCOL)="Código"
        NBCOL += 1 : COL(NBCOL) = "[F:YAR]DPLANTACIO" : Gosub YTEXTE  #TIT(NBCOL)="Descripción"
        NBCOL += 1 : COL(NBCOL) = "[F:YAR]PROPIETARI" : Gosub YTEXTE  #TIT(NBCOL)="Propietario"
        NBCOL += 1 : COL(NBCOL) = "[F:YAR]CPRODUCTE"  : Gosub YTEXTE  #TIT(NBCOL)="Producto"
        NBCOL += 1 : COL(NBCOL) = "[F:YAR]CFINCA"     : Gosub YTEXTE  #TIT(NBCOL)="Finca"

        Default File [YAR]
    Endif
Return
######################################################################################
$SEL_LIQ
    If clalev([F:XTD])=0 : Local File YTIPDOC [XTD] Order By Key CLE=CODITIPDOC: Endif
    Local Char CODFIC    : CODFIC = "YTIPDOC"

    CRITERE = ""
    If PARAM(1) <> "" : CRITERE =  " ([F:XTD]CLASEDOCUM = val(PARAM(1))"    : Endif
    If PARAM(2) <> "" : CRITERE += " OR [F:XTD]CLASEDOCUM = val(PARAM(2))" : Endif
    If PARAM(3) <> "" : CRITERE += " OR [F:XTD]CLASEDOCUM = val(PARAM(3)))" : Endif
    If PARAM(4) <> "" : CRITERE += " & [F:XTD]TIPOCLASE = val(PARAM(4))"   : Endif
    If PARAM(5) <> "" : CRITERE += " & [F:XTD]TIPOFCY = val(PARAM(5))"     : Endif

    START   = "[F:XTD]CODITIPDOC"
    TIT(0) = mess(11,5000,1) ##"Tipos de documento"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:XTD]CODITIPDOC" : Gosub YTEXTE  #TIT(NBCOL) = "Código"
    NBCOL += 1 : COL(NBCOL) = "[F:XTD]DESDOCUM"   : Gosub YTEXTE  #TIT(NBCOL) = "Descripción"
    NBCOL += 1 : COL(NBCOL) = "[F:XTD]CLASEDOCUM" : Gosub YTEXTE  #TIT(NBCOL) = "Clase Doc."

    Default File [XTD]
Return
######################################################################################
# Selección del Tipo (TV 1018) según el tipo de documento
######################################################################################
$SEL_TIPO
    If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
    CRITERE = '[F:ADI]NUMTAB=1018'
    CRITERE+= ' & ([F:ADI]A1=PARAM(1) or [F:ADI]A1="")'
    Default File [ADI]
    OBJET="ADI"
    START   = "[F:ADI]CODE"
Return
######################################################################################
# Selección de la Transacción
######################################################################################
$SEL_TRANS
    If clalev([F:AWI])=0 : Local File AWINDOW   [AWI] : Endif
    If clalev([F:YRE])=0 : Local File YRELDOC   [YRE] : Endif
    If clalev([F:AXX])=0 : Local File ATEXTRA   [AXX] : Endif

    Local Char CODFIC    : CODFIC = "AWINDOW"

    CRITERE = "[F:AWI]OBJ=PARAM(1) & [F:AWI]TRN<>''"

# Exemple: GFONCTION="GESSOH" --> Objecte origen="SOH"
# GFLAG es la transacció en la que es troba actualment
# PARAM(1) es l´objecte al que volem accedir.
# Si troba una transacció per defecte ja no ensenya la pantalla de transaccións.
    If !GIMPORT
        Filter [YRE] Where OBJETO=right$(GFONCTION,4) and TRANSAC=GFLAG and OBJETO_D=PARAM(1)
        If rowcount([YRE])>0
            Read [YRE] First
            If !fstat and [F:YRE]TRANSAC_D<>""
                CRITERE += " & [F:AWI]TRN=[F:YRE]TRANSAC_D"
            Endif
        Endif
        Filter [YRE]
    Endif


    START   = "[F:AWI]TRN"
    TIT(0) = mess(12,5000,1) ##"Transacciones"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:AWI]TRN"     : Gosub YTEXTE  #TIT(NBCOL)="Transacción"
    NBCOL += 1 : COL(NBCOL) = "[F:AWI]LIBEL"   : Gosub YTEXTE  #TIT(NBCOL)="Descripción"
    Default File [AWI]
Return
######################################################################################
# Selección de Tipo de Documento
######################################################################################
$SEL_TIPDOC
    If clalev([F:XTD])=0 : Local File YTIPDOC [XTD] : Endif
    Local Char CODFIC    : CODFIC = "YTIPDOC"

    CRITERE = "1=1"

    If PARAM(2) <> "" and val(PARAM(2))<>3 Then : CRITERE += " & ([F:XTD]TIPOCLASE = val(PARAM(2)) or [F:XTD]TIPOCLASE = 3)" : Endif

    If val(PARAM(3)) <> 0 : CRITERE += " & [F:XTD]TIPOFCY = val(PARAM(3))"   : Endif

    If PARAM(1)<>"" and val(PARAM(1)) = 20 Then
        CRITERE +=  " & ([F:XTD]CLASEDOCUM = 20 or [F:XTD]CLASEDOCUM = 14 or [F:XTD]CLASEDOCUM = 15)"
    Elsif PARAM(1)<>"" Then
        CRITERE +=  " & [F:XTD]CLASEDOCUM = val(PARAM(1))"
    Endif

    START   = "[F:XTD]CODITIPDOC"

    TIT(0) = mess(11,5000,1) ##"Tipo de Documento"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:XTD]CODITIPDOC" : Gosub YTEXTE  #TIT(NBCOL)="Código"
    NBCOL += 1 : COL(NBCOL) = "[F:XTD]DESDOCUM"   : Gosub YTEXTE  #TIT(NBCOL)="Descripción"
    NBCOL += 1 : COL(NBCOL) = "[F:XTD]CLASEDOCUM" : Gosub YTEXTE  #TIT(NBCOL)="Clase Doc."

    Default File [XTD]
Return
######################################################################################
# Selección de Tipo de Documento
######################################################################################
$SEL_TIPDOC2
    If clalev([F:XTD])=0 : Local File YTIPDOC [XTD] : Endif
    Local Char CODFIC    : CODFIC = "YTIPDOC"

    CRITERE = "1=1"
    If PARAM(2) <> "" : CRITERE += " & ([F:XTD]TIPOCLASE = val(PARAM(2)) or [F:XTD]TIPOCLASE = 3)" : Endif
    If val(PARAM(3)) <> 0 : CRITERE += " & [F:XTD]TIPOFCY = val(PARAM(3))"   : Endif

    If PARAM(1)<>"" and val(PARAM(1)) = 20 Then
        CRITERE +=  " & ([F:XTD]CLASEDOCUM = 20 or [F:XTD]CLASEDOCUM = 14 or [F:XTD]CLASEDOCUM = 15)"
    Elsif PARAM(1)<>"" and val(PARAM(1)) = 3 Then
        CRITERE +=  " & ([F:XTD]CLASEDOCUM = 3 or [F:XTD]CLASEDOCUM = 44)"
    Elsif PARAM(1)<>"" Then
        CRITERE +=  " & [F:XTD]CLASEDOCUM = evalue(PARAM(1))"
    Endif

    START   = "[F:XTD]CODITIPDOC"

    TIT(0) = mess(11,5000,1) ##"Tipo de Documento"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:XTD]CODITIPDOC" : Gosub YTEXTE  #TIT(NBCOL)="Código"
    NBCOL += 1 : COL(NBCOL) = "[F:XTD]DESDOCUM"   : Gosub YTEXTE  #TIT(NBCOL)="Descripción"
    NBCOL += 1 : COL(NBCOL) = "[F:XTD]CLASEDOCUM" : Gosub YTEXTE  #TIT(NBCOL)="Clase Doc."

    Default File [XTD]
Return
######################################################################################
# Selección de Tipo de Documento para Transacciones
######################################################################################
$SEL_TDTRAN
    If clalev([F:XTD])=0 : Local File YTIPDOC [XTD] : Endif
    Local Char CODFIC    : CODFIC = "YTIPDOC"

    CRITERE = ""
    If PARAM(1) <> "" : CRITERE = " [F:XTD]CLASEDOCUM = val(PARAM(1)) " : Endif
    If PARAM(2) <> "" : CRITERE += " & ([F:XTD]TIPOCLASE = val(PARAM(2)) or [F:XTD]TIPOCLASE = 3 )" : Endif
    If PARAM(3) <> "" : CRITERE += " & [F:XTD]TIPOFCY = val(PARAM(3))" : Endif

    START   = "[F:XTD]CODITIPDOC"

    TIT(0) = mess(11,5000,1) ##"Tipo de Documento"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:XTD]CODITIPDOC" : Gosub YTEXTE  #TIT(NBCOL)="Código"
    NBCOL += 1 : COL(NBCOL) = "[F:XTD]DESDOCUM"   : Gosub YTEXTE  #TIT(NBCOL)="Descripción"
    NBCOL += 1 : COL(NBCOL) = "[F:XTD]CLASEDOCUM" : Gosub YTEXTE  #TIT(NBCOL)="Clase Doc."

    Default File [XTD]
Return
######################################################################################
# Selección del Documento
######################################################################################
$SEL_DOCUM
    Raz GYSPARAM
    GYLIN=nolign-1
    If clalev([F:YRE])=0 : Local File YRELDOC   [YRE] : Endif

    Local Char CODFIC    : CODFIC = "YRELDOC"

    Filter [YRE]
    If PARAM(3) <> ""
        Read [YRE]YRE0 = PARAM(1);PARAM(2);PARAM(3)
        If fstat
            PARAM(3) = ""
        Endif
    Endif

    If PARAM(2) <> ""
        Read [YRE]YRE0 = PARAM(1);PARAM(2);PARAM(3)
        If fstat
            PARAM(2) = ""
        Endif
    Endif

    Raz [F:YRE]

    CRITERE = "[F:YRE]OBJETO=PARAM(1) & [F:YRE]TRANSAC=PARAM(2) & [F:YRE]TIPDOC=PARAM(3) & "
    CRITERE +="[F:YRE]MOSTRAR=val(PARAM(5))"
    If (PARAM(4)<>"") Then
        CRITERE +="& [F:YRE]YCLASE=val(PARAM(4))"
    Endif

    START   = "[F:YRE]OBJETO"
    TIT(0) = mess(13,5000,1) ##"Documentos"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:YRE]NUMLIN"   : Gosub YTEXTE  #TIT(NBCOL)="Linea"
    NBCOL += 1 : COL(NBCOL) = "[F:YRE]DESOBJ_D" : Gosub YTEXTE  #TIT(NBCOL)="Descripción"
    Default File [YRE]
Return
######################################################################################
$FIN_DOCUM
    If [F:YRE]OBJETO = "" : Return : Endif ##--Si no seleccionamos ningun documento salimos --##
    Call ENTRADA_CODIGO_DOCUM() From ="YAR"+[F:YRE]OBJETO
    If clalev([F:YRE])<>0
        Call ACCESO_OBJETO_DESTINO()
        Call SALIDA_CODIGO_DOCUM() From ="YAR"+[F:YRE]OBJETO
        If clalev([F:YRE])<>0
            #Grabar el número del documento relacionado
            Call GRABAR_PARAMETROS_SALIDA()
        Endif
    Endif
    nolign=GYLIN+1
Return
######################################################################################
$FIN_ALTEST
Return
######################################################################################
# Selección de Trazabilidad
######################################################################################
$SEL_TRAZA
    If clalev([F:YTZ])=0 : Local File YTRAZABIL [YTZ] : Endif

    Local Char CODFIC    : CODFIC = "YTRAZABIL"

    If GYHESPERID=1 Then
        If clalev([F:YPL])=0 : Local File YPLANTACI [YPL] : Endif
        Link [YTZ] With [YPL]YPL0=EXERCICI;PLANTACIO As [XXX]
    Else
        If clalev([F:YAR])=0 : Local File YARITMOS [YAR] : Endif
        Link [YTZ] With [YAR]YAR0=EXERCICI;CPLANTACIO As [XXX]
    Endif

    CRITERE = "1=1"
    If PARAM(1) <> "" Then
        CRITERE += " & [F:YTZ]FCY=PARAM(1)"
    Endif
    If PARAM(2) <> "" Then
        CRITERE += " & [F:YTZ]TERCER=PARAM(2)"
    Endif
    If PARAM(3) <> "" Then
        CRITERE += " & [F:YTZ]PRODUCTE=PARAM(3) "
    Endif
    If PARAM(4) <> "" Then
        CRITERE += " & [F:YTZ]DIRECCION = PARAM(4) "
    Endif
    If PARAM(5) <> "" Then
        CRITERE += " & [F:YTZ]EXERCICI = PARAM(5) "
    Endif
    If PARAM(6) <> "" Then
        CRITERE += " & [F:YTZ]PLANTACIO = PARAM(6) "
    Endif

    START   = "[F:YTZ]CODITRAZA"
    TIT(0) = mess(14,5000,1) ##"Trazabilidad"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:YTZ]CODITRAZA"  : Gosub YTEXTE  #TIT(NBCOL)="Código"
    NBCOL += 1 : COL(NBCOL) = "[F:YTZ]DESCRIPCIO" : Gosub YTEXTE  #TIT(NBCOL)="Descripción"
    NBCOL += 1 : COL(NBCOL) = "[F:YTZ]FCY"        : Gosub YTEXTE  #TIT(NBCOL)="Planta"
    NBCOL += 1 : COL(NBCOL) = "[F:YTZ]PRODUCTE"   : Gosub YTEXTE  #TIT(NBCOL)="Producto"
    NBCOL += 1 : COL(NBCOL) = "[F:YTZ]TERCER"     : Gosub YTEXTE  #TIT(NBCOL)="Tercero"
    NBCOL += 1 : COL(NBCOL) = "[F:YTZ]PLANTACIO"  : Gosub YTEXTE  #TIT(NBCOL)="Plantación"
    If GYHESPERID=1 Then
        NBCOL += 1 : COL(NBCOL) = "[F:YPL]NOMPLANTA"  :  Call TEXTFIC("YPLANTACI","NOMPLANTA",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Desc.Plantación"
    Else
        NBCOL += 1 : COL(NBCOL) = "[F:YAR]DPLANTACIO"  :  Call TEXTFIC("YARITMOS","DPLANTACIO",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Desc.Plantación"
    Endif
    Default File [XXX]
Return
######################################################################################
# Selección de las CONFECCIONES
######################################################################################
$SEL_CONF

    If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
    CRITERE = '[F:ADI]NUMTAB=1025'
    Default File [ADI]
    OBJET="ADI"
    START   = "[F:ADI]CODE"
Return
######################################################################################
# Selección de las PESADAS DE COMPRAS
######################################################################################
$SEL_PES
    If clalev([F:YCI])=0 : Local File YACCABLOT  [YCI] : Endif

    CRITERE = "[F:YCI]TESTVAL<> 2 & [F:YCI]FCY=PARAM(1) "

    START   = "[F:YCI]NUMDOC"
    TIT(0) = mess(15,5000,1) ##"Pesadas de Compras"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:YCI]NUMDOC"     : TIT(NBCOL)="Nº Documento"
    NBCOL += 1 : COL(NBCOL) = "[F:YCI]CODIPERSON" : TIT(NBCOL)="Código pers."
    NBCOL += 1 : COL(NBCOL) = "[F:YCI]DATA"       : TIT(NBCOL)="Fecha"
    Default File [YCI]
Return
######################################################################################
# Selección de las PESADAS DE VENTAS
######################################################################################
$SEL_PES_VEN
    If clalev([F:YV1])=0 : Local File YAVCABLOT  [YV1] : Endif
    Local Char CODFIC    : CODFIC = "YAVCABLOT"

    ##WY26019 - SVR - 24/10/2013. El filtre al buscar les pesades era per la planta de venta i aquí per la d'stock
    CRITERE = "[F:YV1]TESTVAL<> 2 & [F:YV1]FCY=PARAM(1) "

    START   = "[F:YV1]NUMDOC"
    TIT(0) = mess(16,5000,1) ##"Pesadas de Ventas"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:YV1]NUMDOC"     : Gosub YTEXTE  #TIT(NBCOL)="Nº Documento"
    NBCOL += 1 : COL(NBCOL) = "[F:YV1]CODIPERSON" : Gosub YTEXTE  #TIT(NBCOL)="Código pers."
    NBCOL += 1 : COL(NBCOL) = "[F:YV1]DATA"       : Gosub YTEXTE  #TIT(NBCOL)="Fecha"
    Default File [YV1]
Return
######################################################################################
# Selección de doc. de clasificación
######################################################################################
$SEL_DOCCLA
    If clalev([F:YC2])=0 : Local File YACCABCLA  [YC2] : Endif
    Local Char CODFIC    : CODFIC = "YACCABCLA"

    CRITERE = "[F:YC2]FCY=PARAM(1)"

    If PARAM(2)<>"" Then : CRITERE += " & [F:YC2]TESTACT=val(PARAM(2))" : Endif

    START   = "[F:YC2]YDOCREL"
    TIT(0) = mess(17,5000,1) ## "Documentos Clasificación"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:YC2]YDOCREL"    : Gosub YTEXTE  #TIT(NBCOL)="Nº Documento"
    NBCOL += 1 : COL(NBCOL) = "[F:YC2]YDOCLIN"    : Gosub YTEXTE  #TIT(NBCOL)="Orden"
    NBCOL += 1 : COL(NBCOL) = "[F:YC2]TIPDOC"     : Gosub YTEXTE  #TIT(NBCOL)="Tipo Documento"
    NBCOL += 1 : COL(NBCOL) = "[F:YC2]DATA"       : Gosub YTEXTE  #TIT(NBCOL)="Fecha"
    Default File [YC2]
Return
######################################################################################
# Acceso al documento seleccionado
######################################################################################
Subprog YENTDOCUM(YOBJETO,YTRANS,YTIPDOC,YCLASE,YOBJETOD,YTIPDOCREL,YCAMPO,YARTICULO)
    Value     Char        YOBJETO
    Value     Char        YTRANS
    Value     Char        YTIPDOC
    Value     Char        YCLASE
    Value     Char        YOBJETOD
    Value     Integer     YTIPDOCREL
    Value     Char        YCAMPO
    Value     Char        YARTICULO
    Local     Char        SENTENCIA(254)
    Local     Char        SENTENCIA1(254)

    GYLIN=nolign-1
    If clalev([F:YRE])=0 : Local File YRELDOC   [YRE] : Endif
    If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif

    If GYCALAUTO <> 2 and YARTICULO <> ""
        Read [ITM]ITM0=YARTICULO
        If fstat : Raz [ITM] : Return : Endif

        If [F:ITM]YCALAUTO <> 2
            End
        Endif
    Endif

    Raz SENTENCIA
    SENTENCIA1 = "1=1"
#    SENTENCIA = "OBJETO=YOBJETO and TRANSAC=YTRANS and MOSTRAR=YTIPDOCREL"
    SENTENCIA = "OBJETO=YOBJETO and MOSTRAR=YTIPDOCREL"
    If (YCLASE<>"") : SENTENCIA = SENTENCIA + " and CLASE_D=val(YCLASE)" : Endif
    If (YOBJETOD<>"") : SENTENCIA=SENTENCIA+" and OBJETO_D=YOBJETOD" : Endif
    If (YCAMPO<>"") : SENTENCIA=SENTENCIA+" and CAMPO=YCAMPO" : Endif
    If (YTRANS<>"") : SENTENCIA1 = SENTENCIA1 + " and TRANSAC=YTRANS" : Endif
    If (YTIPDOC<>"") : SENTENCIA1 = SENTENCIA1 + " and TIPDOC=YTIPDOC" : Endif

    Filter [YRE] Where evalue(SENTENCIA) and evalue(SENTENCIA1)
    If rowcount([F:YRE])>0 Then
        Read [YRE] First
        If fstat<>0 Then : Close File [F:YRE] : Endif
        While clalev([F:YRE])<>0
            #Llamamos a la rutina FIN_DOCUM para que acceda al doc. destino, grave los param., etc.
            Call FI_ENTDOCUM
            If clalev([F:YRE])<>0 Then
                Read [YRE] Next
                If fstat<>0 Then : Close File [F:YRE] : Endif
            Endif
        Wend

    Else

        Filter [YRE] Where evalue(SENTENCIA) and TRANSAC=YTRANS and TIPDOC=""
        If rowcount([F:YRE])>0 Then
            Read [YRE] First
            If fstat<>0 Then : Close File [F:YRE] : Endif
            While clalev([F:YRE])<>0
                #Llamamos a la rutina FIN_DOCUM para que acceda al doc. destino, grave los param., etc.
                Call FI_ENTDOCUM
                If clalev([F:YRE])<>0 Then
                    Read [YRE] Next
                    If fstat<>0 Then : Close File [F:YRE] : Endif
                Endif
            Wend

        Else

            Filter [YRE] Where evalue(SENTENCIA) and TIPDOC=YTIPDOC and TRANSAC=""
            If rowcount([F:YRE])>0 Then
                Read [YRE] First
                If fstat<>0 Then : Close File [F:YRE] : Endif
                While clalev([F:YRE])<>0
                    #Llamamos a la rutina FIN_DOCUM para que acceda al doc. destino, grave los param., etc.
                    Call FI_ENTDOCUM
                    If clalev([F:YRE])<>0 Then
                        Read [YRE] Next
                        If fstat<>0 Then : Close File [F:YRE] : Endif
                    Endif
                Wend

            Else

                Filter [YRE] Where evalue(SENTENCIA) and TIPDOC="" and TRANSAC=""
                If fstat=0 and rowcount([F:YRE])>0 Then
                    Read [YRE] First
                    If fstat<>0 Then : Close File [F:YRE] : Endif
                    While clalev([F:YRE])<>0
                        #Llamamos a la rutina FIN_DOCUM para que acceda al doc. destino, grave los param., etc.
                        Call FI_ENTDOCUM
                        If clalev([F:YRE])<>0 Then
                            Read [YRE] Next
                            If fstat<>0 Then : Close File [F:YRE] : Endif
                        Endif
                    Wend
                Endif
            Endif
        Endif
    Endif
    nolign=GYLIN+1
End
######################################################################################
Subprog FI_ENTDOCUM()
    If [F:YRE]OBJETO = "" : End : Endif ##--Si no seleccionamos ningun documento salimos --##
    Call ENTRADA_CODIGO_DOCUM() From ="YAR"+[F:YRE]OBJETO
    If clalev([F:YRE])<>0
        Call ACCESO_OBJETO_DESTINO()
        If clalev([F:YRE])<>0
            Call SALIDA_CODIGO_DOCUM() From ="YAR"+[F:YRE]OBJETO
            #Grabar el número del documento relacionado
            If clalev([F:YRE])<>0 : Call GRABAR_PARAMETROS_SALIDA() : Endif
        Endif
    Endif
End
######################################################################################


######################################################################################
##### RUTINAS PARA ACCEDER A OTRO OBJETO Y DEVOLVER PARAMETROS
######################################################################################
Subprog ACCESO_OBJETO_DESTINO()
    Local     Char     CLAVE(GLONADI)(0..1)

    If [F:YRE]OBJETO_D = "" : End : Endif
    If [F:YRE]MOSTRAR = 3 and [F:YRE]CAMPO = "" : End : Endif
    Raz GYFILTRO
    If ([F:YRE]PARAM2="") Then
        GBIDC1= evalue([F:YRE]PARAM1)
        Call OBJET([F:YRE]OBJETO_D,GBIDC1,"") From GOBJET
    Elsif ([F:YRE]PARAM3="") Then
        GBIDC1= evalue([F:YRE]PARAM2)
        GBIDC2= evalue([F:YRE]PARAM1)
        Call OBJET([F:YRE]OBJETO_D,GBIDC1,GBIDC2) From GOBJET
    Else
        GBIDC1= evalue([F:YRE]PARAM1)
        CLAVE(0)=evalue([F:YRE]PARAM2)
        CLAVE(1)=evalue([F:YRE]PARAM3)
        Call OBJET([F:YRE]OBJETO_D,GBIDC1,CLAVE) From GOBJET
    Endif
End
######################################################################################
Subprog GRABAR_PARAMETROS_SALIDA()
    Local     Char     PANTALLA(25)
    Local     Char     CAMP(25)
    Local     Integer  POS

    If GYSPARAM<>"" Then
        If [F:YRE]SPARAM1<>"" Then

#PENDENT -> NOMES MKSTAT=4 QUAN SIGUI NECESSARI
#If evalue([F:YRE]SPARAM1)="" Then : mkstat=4 : Endif

            If GYSTIPO(1)=0 Then
                Assign([F:YRE]SPARAM1) With GYSPARAM(1)
            Else
                Assign([F:YRE]SPARAM1) With val(GYSPARAM(1))
            Endif
#            Affzo=[F:YRE]SPARAM1
            POS = instr(1,[F:YRE]SPARAM1,']')
            PANTALLA = left$([F:YRE]SPARAM1,POS)
            CAMP = right$([F:YRE]SPARAM1,POS+1)
            Default Mask PANTALLA
            Affzo [M]=CAMP
        Endif
        If [F:YRE]SPARAM2<>"" Then
            If GYSTIPO(2)=0 Then
                Assign([F:YRE]SPARAM2) With GYSPARAM(2)
            Else
                Assign([F:YRE]SPARAM2) With val(GYSPARAM(2))
            Endif
#            Affzo=[F:YRE]SPARAM2
            POS = instr(1,[F:YRE]SPARAM2,']')
            PANTALLA = left$([F:YRE]SPARAM2,POS)
            CAMP = right$([F:YRE]SPARAM2,POS+1)
            Default Mask PANTALLA
            Affzo [M]=CAMP
        Endif
        If [F:YRE]SPARAM3<>"" Then
            If GYSTIPO(3)=0 Then
                Assign([F:YRE]SPARAM3) With GYSPARAM(3)
            Else
                Assign([F:YRE]SPARAM3) With val(GYSPARAM(3))
            Endif
#            Affzo=[F:YRE]SPARAM3
            POS = instr(1,[F:YRE]SPARAM3,']')
            PANTALLA = left$([F:YRE]SPARAM3,POS)
            CAMP = right$([F:YRE]SPARAM3,POS+1)
            Default Mask PANTALLA
            Affzo [M]=CAMP
        Endif

#           SVR - 24/10/2013. Nova rutina al sortir del YRELDOC per actualitzar tarifes, etc.
            FLAG_ERREUR = 0
            Onerrgo ERR_INICM
            Call SALIDA_YRELDOCUM() From = "YAR"+[F:YRE]OBJETO
            Onerrgo

        mkstat=4
    Endif
End
######################################################################################
$ERR_INICM
    FLAG_ERREUR = 2
Resume
######################################################################################
### PROCESO DE SELECCION DE ARTICULOS POR DESCRIPCIÓN                              ###
######################################################################################
$SEL_ART_DES
    Local Integer FILAS
    Local Char ART
    Local Shortint NOL  : NOL=nolign-1
    Local Char CODFIC    : CODFIC = "ITMMASTER"

    ART = VALEUR

    If clalev([F:ITM])=0 : Local File ITMMASTER [ITM] : Endif
    If clalev([F:ITX])=0 : Local File ITMMASTER [ITX] : Endif

    Filter [ITM]
    Filter [ITX]

    Read [F:ITX]ITM0 = ART
    If fstat
        Filter [ITX]
        Filter [ITX] Where  pat(ITMDES1,"*"+ART+"*")

        FILAS = rowcount([ITX])
        If FILAS <> 1

            Filter [ITM] Where pat(ITMDES1,"*"+ART+"*")
            CRITERE = ""
            START   = "[F:ITM]ITMREF"

            TIT(0) = mess(1,5000,1) ##"Articulos"
            NBCOL = 0
            NBCOL += 1 : COL(NBCOL) = "[F:ITM]ITMREF"  : Gosub YTEXTE #TIT(NBCOL)="Código"
            NBCOL += 1 : COL(NBCOL) = "[F:ITM]ITMDES1" : Gosub YTEXTE #TIT(NBCOL)="Descripción"
            NBCOL += 1 : COL(NBCOL) = "[F:ITM]TCLCOD"  : Gosub YTEXTE #TIT(NBCOL)="Categoria"

            Default File [ITM]
        Else
            Read [ITX] First : If fstat  Raz [F:ITX] : Endif
            [M]ITMREF(NOL) = [F:ITX]ITMREF
            VALEUR = [F:ITX]ITMREF
            Affzo [M]ITMREF(NOL)
            Call AM_ITMREF([F:ITX]ITMREF)  From ="SPV"+PARAM(1)
        Endif
    Else
        Call AM_ITMREF(ART) From ="SPV"+PARAM(1)
    Endif

    Filter [ITX]
End
######################################################################################
$VERF_ART_DES
    Local Shortint NOL  : NOL=nolign-1
    Local Char ARTICULO
    ARTICULO = [F:ITM]ITMREF
    Filter [ITM]
    If GERR = 0 : Call AM_ITMREF(ARTICULO) From ="SPV"+PARAM(1) : Endif
Return
######################################################################################
# Selección de Proveedores
######################################################################################
$SEL_BPS
    If clalev([F:BPS])=0 : Local File BPSUPPLIER [BPS] : Endif
    If clalev([F:YPS])=0 : Local File YPERSEC    [YPS] : Endif

    Local Char CODFIC    : CODFIC = "BPSUPPLIER"

    Link [BPS] With [YPS]YPS0=BPSNUM As [XXX]

    CRITERE = "[F:YPS]TEST = 2 & [F:YPS]TIPOFCY= val(PARAM(1)) and [F:BPS]ENAFLG=2"

    GBIDC3="" : Call FILROLE("BPS",GBIDC3) From SUBARL
    If GBIDC3<>"" CRITERE += "& " + GBIDC3 : Endif

    START   = "[F:BPS]BPSNUM"
    TIT(0) = mess(18,5000,1) ##"Proveedores"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:BPS]BPSNUM" : Gosub YTEXTE #TIT(NBCOL)="Proveedor"
    NBCOL += 1 : COL(NBCOL) = "[F:BPS]BPSNAM" : Gosub YTEXTE #TIT(NBCOL)="Razón social"
    NBCOL += 1 : COL(NBCOL) = "[F:BPS]BPSSHO" : Gosub YTEXTE #TIT(NBCOL)="Descrip. corta"
    Default File [XXX]
    DEFPAG =1
Return
######################################################################################
# Selección de Terceros
######################################################################################
$SEL_BPR
    If clalev([F:XBP])=0 : Local File BPARTNER   [XBP] : Endif
    If clalev([F:YPS])=0 : Local File YPERSEC    [YPS] : Endif
    Local Char CODFIC    : CODFIC = "BPARTNER"

    Link [XBP] With [YPS]YPS0=BPRNUM As [XXX]

    CRITERE = "[F:YPS]TEST = 2 & [F:YPS]TIPOFCY= val(PARAM(1))"
### and [F:XBP]ENAFLG=2"

    START   = "[F:XBP]BPRNUM"
    TIT(0) = mess(19,5000,1) ##"Terceros"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:XBP]BPRNUM" : Gosub YTEXTE #TIT(NBCOL)="Tercero"
    NBCOL += 1 : COL(NBCOL) = "[F:XBP]BPRNAM" : Gosub YTEXTE #TIT(NBCOL)="Razón social"
    NBCOL += 1 : COL(NBCOL) = "[F:XBP]BPRSHO" : Gosub YTEXTE #TIT(NBCOL)="Descrip. corta"
    Default File [XXX]
    DEFPAG = 1
Return
######################################################################################
# Selección de Clientes
######################################################################################
$SEL_BPC
    If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] : Endif
    If clalev([F:YPS])=0 : Local File YPERSEC    [YPS] : Endif
    If clalev([F:XBR])=0 : Local File BPARTNER   [XBR] : Endif

    Local Char CODFIC    : CODFIC = "BPCUSTOMER"

    Link [BPC] With [YPS]YPS0=BPCNUM, [XBR]BPR0=BPCNUM As [XXX]

    CRITERE = "[F:YPS]TEST = 2 & [F:YPS]TIPOFCY= val(PARAM(1)) & [F:BPC]BPCSTA=2"

    GBIDC3="" : Call FILROLE("BPC",GBIDC3) From SUBARL
    If GBIDC3<>"" CRITERE += "& " + GBIDC3 : Endif
    Read [XBR]BPR0 = [F:BPC]BPCNUM : If fstat Raz [F:XBR] : Endif

    START   = "[F:BPC]BPCNUM"
    TIT(0) = mess(20,5000,1) ##"Clientes"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:BPC]BPCNUM" : Gosub YTEXTE #TIT(NBCOL)="Cliente"
    NBCOL += 1 : COL(NBCOL) = "[F:BPC]BPCNAM" : Gosub YTEXTE #TIT(NBCOL)="Razón social"
    NBCOL += 1 : COL(NBCOL) = "[F:BPC]BPCSHO" : Gosub YTEXTE #TIT(NBCOL)="Descrip. corta"
    NBCOL += 1 : COL(NBCOL) = "[F:XBR]CRN"    : Call TEXTFIC("BPARTNER","CRN",1,TIT(NBCOL)) From OBJDIV  #TIT(NBCOL)="N.I.F."
    Default File [XXX]
    DEFPAG = 1
Return
######################################################################################
# Selección de direcciones de entrega
######################################################################################
$SEL_ADD_ENTREGA
    Local Char CODFIC    : CODFIC = "BPADDRESS"

    If PARAM(1)="" or PARAM(2)<>"" Then : Return : Endif

    If [M]NBLIG > 0 and GFONC1<>"GESYCV" and GFONC1<>"GESYOT" Then : Return : Endif

    If clalev([F:BPA2])=0 : Local File BPADDRESS [BPA2] : Endif
    If clalev([F:BPD])=0  : Local File BPDLVCUST [BPD]  : Endif

    If (dim(GMODCLIENTE)>0) : GMODCLIENTE="NO" : Endif

    #Fer un read i si 0 o 1 registres, sortir
    Filter [BPA2]  Where BPANUM=PARAM(1) and YTACTIU=2 and BPATYP=1
    If rowcount([BPA2])<2 Then
        Read [F:BPA2]BPA0 First
        If [F:BPA2]BPAADD<>"" Then
            If GFONC1="GESYCV" or GFONC1="GESYOT" Then
                VALEUR = [F:BPA2]BPAADD
                mkstat=2
            Endif
        Endif
        Filter [F:BPA2]
        Return
    Endif

    Filter [F:BPA2]

    Link [BPA2] With [BPD]BPD0=BPANUM;BPAADD As [XXX]

    CRITERE = "[F:BPA2]YTACTIU = 2 & [F:BPD]BPCNUM=PARAM(1)"

    PARAM(2)=""
    ORDRE = "[F:BPA2]BPANUM;[F:BPA2]BPAADD"   ##MOD P26071 - RPASC - 22/11/2013
    START   = "[F:BPA2]BPAADD"
    TIT(0) = mess(21,5000,1) ##"Direcciones Entrega"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:BPA2]BPANUM"    : Gosub YTEXTE #TIT(NBCOL)="Cliente"
    NBCOL += 1 : COL(NBCOL) = "[F:BPA2]BPAADD"    : Gosub YTEXTE #TIT(NBCOL)="Dir."
    NBCOL += 1 : COL(NBCOL) = "[F:BPA2]BPADES"    : Gosub YTEXTE # TIT(NBCOL)="Título Dirección"
    NBCOL += 1 : COL(NBCOL) = "[F:BPD]BPDNAM"     : Call TEXTFIC("BPDLVCUST","BPDNAM",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Razón social"
    NBCOL += 1 : COL(NBCOL) = "[F:BPA2]BPAADDLIG" : Gosub YTEXTE #TIT(NBCOL)="Dirección"
    NBCOL += 1 : COL(NBCOL) = "[F:BPA2]CTY"       : Gosub YTEXTE #TIT(NBCOL)="Ciudad"
    Default File [XXX]
Return
######################################################################################
# Selección de direcciones de Proveïdors
######################################################################################
$SEL_ADD_BPS
    Local Char CODFIC    : CODFIC = "BPADDRESS"

    If PARAM(1)="" or PARAM(2)<>"" Then : Return : Endif

    If [M]NBLIG > 0 and GFONC1<>"GESYCV" and GFONC1<>"GESYOT" Then : Return : Endif

    If clalev([F:XBPA])=0  : Local File BPADDRESS   [XBPA] : Endif
    If clalev([F:XBPS])=0  : Local File BPSUPPLIER  [XBPS]  : Endif

    If (dim(GMODCLIENTE)>0) : GMODCLIENTE="NO" : Endif

    #Fer un read i si 0 o 1 registres, sortir
    Filter [XBPA]  Where BPANUM=PARAM(1) and YTACTIU=2 and BPATYP=1
    If rowcount([XBPA])<2 Then
        Read [F:XBPA]BPA0 First
        If [F:XBPA]BPAADD<>"" Then
            If GFONC1="GESYCI"
                VALEUR = [F:XBPA]BPAADD
                mkstat=2
            Endif
        Endif
        Filter [F:XBPA]
        Return
    Endif

    Link [XBPA] With [XBPS]BPS0=BPANUM As [XXX]

    CRITERE = "[F:XBPA]YTACTIU = 2 & [F:XBPS]BPSNUM=PARAM(1)"

    PARAM(2)=""
    START   = "[F:XBPA]BPAADD"
    TIT(0) = mess(22,5000,1) ##"Direcciones Proveedor"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:XBPA]BPANUM"    : Gosub YTEXTE #TIT(NBCOL)="Proveedor"
    NBCOL += 1 : COL(NBCOL) = "[F:XBPA]BPAADD"    : Gosub YTEXTE #TIT(NBCOL)="Dir."
    NBCOL += 1 : COL(NBCOL) = "[F:XBPS]BPSNAM"    : Call TEXTFIC("BPSUPPLIER","BPSNAM",1,TIT(NBCOL)) From OBJDIV # TIT(NBCOL)="Razón social"
    NBCOL += 1 : COL(NBCOL) = "[F:XBPA]BPADES"    : Gosub YTEXTE #TIT(NBCOL)="Título Dirección"
    NBCOL += 1 : COL(NBCOL) = "[F:XBPA]BPAADDLIG" : Gosub YTEXTE #TIT(NBCOL)="Dirección"
    NBCOL += 1 : COL(NBCOL) = "[F:XBPA]CTY"       : Gosub YTEXTE #TIT(NBCOL)="Ciudad"
    Default File [XXX]
Return
######################################################################################
# Selección de clientes según tipo de Socio
######################################################################################
$SEL_BPR_TIPO
    If clalev([F:XBP])=0 : Local File BPARTNER   [XBP] : Endif
    If clalev([F:YPS])=0 : Local File YPERSEC    [YPS] : Endif



    Link [XBP] With [YPS]YPS0=BPRNUM As [XXX]

    CRITERE = "[F:YPS]TEST = 2 & [F:YPS]TIPOFCY= val(PARAM(1)) & [F:XBP]YTIPSOC=val(PARAM(2))"

    START   = "[F:XBP]BPRNUM"
    TIT(0) = mess(20,5000,1) ##"Clientes"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:XBP]BPRNUM" : Gosub YTEXTE #TIT(NBCOL)="Cliente"
    NBCOL += 1 : COL(NBCOL) = "[F:XBP]BPRNAM" : Gosub YTEXTE #TIT(NBCOL)="Razón social"
    NBCOL += 1 : COL(NBCOL) = "[F:XBP]BPRSHO" : Gosub YTEXTE #TIT(NBCOL)="Descrip. corta"
    Default File [XXX]
Return
######################################################################################
$ENT_ENV
    Local Char OBJETO,CLAVE,CLAVE1

    OBJETO = PARAM(1)
    CLAVE  = PARAM(2)
    CLAVE1 = PARAM(3)

    Call OBJET(OBJETO,CLAVE1,CLAVE) From GOBJET

Return
######################################################################################
$ENT_CODITABLA
    Local Integer WSTAT
    Local Char CODFIC
    If val(PARAM(1))=1 Then
        #Calificacion
        If clalev([F:YCF])=0 : Local File YCALIFIC [YCF] : Endif
        CODFIC = "YCALIFIC"
        START   = "[F:YCF]CODCALIFIC"
        TIT(0) = mess(6,5000,1) ##"Calificación"
        NBCOL = 0
        NBCOL += 1 : COL(NBCOL) = "[F:YCF]CODCALIFIC"  : Gosub YTEXTE #TIT(NBCOL)="Código"
        NBCOL += 1 : COL(NBCOL) = "[F:YCF]NOMCALIFIC"  : Gosub YTEXTE #TIT(NBCOL)="Descripción"
        NBCOL += 1 : COL(NBCOL) = "[F:YCF]NOMCALIFI2"  : Gosub YTEXTE #TIT(NBCOL)="Desc. Corta"
        Default File [YCF]
    Elsif val(PARAM(1))=2 Then
        #Coste
        If clalev([F:YCO])=0 : Local File YCOSTE   [YCO] : Endif
        CODFIC = "YCOSTE"
        CRITERE = "[F:YCO]TACTIU = 2"
        START   = "[F:YCO]CODICOST"
        TIT(0) = mess(23,5000,1) ##"Costes"
        NBCOL = 0
        NBCOL += 1 : COL(NBCOL) = "[F:YCO]CODICOST" : Gosub YTEXTE #TIT(NBCOL)="Coste"
        NBCOL += 1 : COL(NBCOL) = "[F:YCO]NOMCOST"  : Gosub YTEXTE #TIT(NBCOL)="Descripción"
        Default File [YCO]
    Elsif val(PARAM(1))=3 Then
        #Características
        If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
        CRITERE = '[F:ADI]NUMTAB=1004'
        CRITERE+= ' & ([F:ADI]A1=PARAM(1) or [F:ADI]A1="")'
        Default File [ADI]
        OBJET="ADI"
        START   = "[F:ADI]CODE"
    Elsif val(PARAM(1))=4 Then
        #Credit Conceptos
        Call LECACT("YSC", WSTAT) From TRTX3
        If WSTAT = 1
            If clalev([F:YCN])=0 : Local File YCONCEP   [YCN] : Endif
            CODFIC = "YCONCEP"
            #CRITERE = "[F:YCO]TACTIU = 2"
            START   = "[F:YCN]CCONCEP"
            TIT(0) = mess(23,5000,1) ##"Costes"
            NBCOL = 0
            NBCOL += 1 : COL(NBCOL) = "[F:YCN]CCONCEP"  : Gosub YTEXTE #TIT(NBCOL)="Cód Concepto"
            NBCOL += 1 : COL(NBCOL) = "[F:YCN]DESNOR"   : Gosub YTEXTE #TIT(NBCOL)="Descripción"
            Default File [YCN]
        Else
            GERR=1
            GMESSAGE = mess(127,1986,1)
            Return
        Endif
    Elsif val(PARAM(1))=5 Then
        #Relación de clasificaciones prog. externo - X3
        If clalev([F:YCL])=0 : Local File YCLASIFIC  [YCL] : Endif
        CODFIC = "YCLASIFIC"
        START   = "[F:YCL]CODCALIBRE"
        TIT(0) = mess(6,5000,1) ##"Clasificación"
        NBCOL = 0
        NBCOL += 1 : COL(NBCOL) = "[F:YCL]CODCALIBRE"  : Gosub YTEXTE #TIT(NBCOL)="Código"
        NBCOL += 1 : COL(NBCOL) = "[F:YCL]NOMCALIBRE"  : Gosub YTEXTE #TIT(NBCOL)="Descripción"
        NBCOL += 1 : COL(NBCOL) = "[F:YCL]NOMCALIBR2"  : Gosub YTEXTE #TIT(NBCOL)="Desc. Corta"
        Default File [YCL]
    Elsif val(PARAM(1))=6 Then        #Condiciones de pago
        If clalev([F:TPT])=0 : Local File TABPAYTERM  [TPT] : Endif
        CODFIC = "TABPAYTERM"
        START   = "[F:TPT]PTE"
        TIT(0) = mess(24,5000,1) ##"Condiciones de pago"
        NBCOL = 0
        NBCOL += 1 : COL(NBCOL) = "[F:TPT]PTE"       : Gosub YTEXTE # TIT(NBCOL)="Código"
        NBCOL += 1 : COL(NBCOL) = "[F:TPT]PTELIN"    : Gosub YTEXTE #TIT(NBCOL)="Línea"
        NBCOL += 1 : COL(NBCOL) = "[F:TPT]LANDESSHO" : Gosub YTEXTE #TIT(NBCOL)="Descripción"
        Default File [TPT]
    Elsif val(PARAM(1))=7 Then        #Informes
        If clalev([F:ARP])=0 : Local File AREPORT  [ARP] : Endif
        CODFIC = "AREPORT"
        CRITERE = '[F:ARP]ENAFLG=2'
        START   = "[F:ARP]RPTCOD"
        TIT(0) = mess(25,5000,1) ##"Informes"
        NBCOL = 0
        NBCOL += 1 : COL(NBCOL) = "[F:ARP]RPTCOD"    : Gosub YTEXTE #TIT(NBCOL)="Código"
        NBCOL += 1 : COL(NBCOL) = "[F:ARP]GRP"       : Gosub YTEXTE #TIT(NBCOL)="Grupo"
        NBCOL += 1 : COL(NBCOL) = "[F:ARP]RPTDES"    : Gosub YTEXTE #TIT(NBCOL)="Descripción"
        Default File [ARP]
    Elsif val(PARAM(1))=8 Then        #Modalidades
        #Modalidades
        If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
        CRITERE = '[F:ADI]NUMTAB=1016'
        CRITERE+= ' & ([F:ADI]A1=PARAM(1) or [F:ADI]A1="")'
        Default File [ADI]
        OBJET="ADI"
        START   = "[F:ADI]CODE"
    Else
        GERR=1
        GMESSAGE = mess(127,1986,1)
        Return
    Endif
Return
######################################################################################
$ENT_SELCAMPO
    If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
    Local Char CODFIC

    If val(PARAM(1))>1 & val(PARAM(1))<=4 Then

        #Familia-Subfamilia-Producto
        If val(PARAM(1))=2 Then
            #Familia
            CRITERE = '[F:ADI]NUMTAB=20'
        Elsif val(PARAM(1))=3 Then
            #Subfamilia
            CRITERE = '[F:ADI]NUMTAB=21'
        Elsif val(PARAM(1))=4 Then
            #Subfamilia
            CRITERE = '[F:ADI]NUMTAB=22'
        Endif
        Default File [ADI]
        OBJET="ADI"
        START   = "[F:ADI]CODE"

    Elsif val(PARAM(1))=5 Then

        #Artículo
        If clalev([F:YITM])=0 : Local File ITMMASTER   [YITM] : Endif
        CODFIC = "ITMMASTER"
        START   = "[F:YITM]ITMREF"
        TIT(0) = mess(1,5000,1) ##"Artículos"
        NBCOL = 0
        NBCOL += 1 : COL(NBCOL) = "[F:YITM]ITMREF"   : Gosub YTEXTE #TIT(NBCOL)="Artículo"
        NBCOL += 1 : COL(NBCOL) = "[F:YITM]ITMDES1"  : Gosub YTEXTE #TIT(NBCOL)="Descripción"
        Default File [YITM]

    Elsif val(PARAM(1))=6 Then

        #Tipo de Socio
        If clalev([F:AST])=0 : Local File APLSTD  [AST] : Endif
        CODFIC = "APLSTD"
        CRITERE = '[F:AST]LANCHP=1975 & [F:AST]LAN=GLANGUE & [F:AST]LANNUM>0'
        START   = "[F:AST]LANNUM"
        TIT(0) = mess(26,5000,1) ## "Tipo Socio"
        NBCOL = 0
        NBCOL += 1 : COL(NBCOL) = "[F:AST]LANNUM"  : Gosub YTEXTE #TIT(NBCOL)="Tipo Socio"
        NBCOL += 1 : COL(NBCOL) = "[F:AST]LANMES"  : Gosub YTEXTE #TIT(NBCOL)="Descripción"
        Default File [AST]

    Elsif val(PARAM(1))=7 Then

        #Tercero
        If clalev([F:XBP])=0 : Local File BPARTNER [XBP] : Endif
        CODFIC = "BPARTNER"
        START   = "[F:XBP]BPRNUM"
        TIT(0) = mess(19,5000,1) ##"Terceros"
        NBCOL = 0
        NBCOL += 1 : COL(NBCOL) = "[F:XBP]BPRNUM" : Gosub YTEXTE #TIT(NBCOL)="Tercero"
        NBCOL += 1 : COL(NBCOL) = "[F:XBP]BPRNAM" : Gosub YTEXTE #TIT(NBCOL)="Razón social"
        NBCOL += 1 : COL(NBCOL) = "[F:XBP]BPRSHO" : Gosub YTEXTE #TIT(NBCOL)="Descrip. corta"
        Default File [XBP]

    Elsif val(PARAM(1))=8 Then

        #Clasificaciones
        #Comprobamos si está activo el código de actividad YGC (Cárnicas)
        If func XCONTROLES.CODACT_ACTIVO("YGC") Then
            Gosub ENT_SELCAMPO From YGCSELECCION
        Endif

    Elsif val(PARAM(1))=9 Then

        #Familia-Est.1-Prov.
        CRITERE = '[F:ADI]NUMTAB=40'
        Default File [ADI]
        OBJET="ADI"
        START   = "[F:ADI]CODE"

    Elsif val(PARAM(1))<>1 Then
        #Infbox "Sel. no creada para éste campo!"
        GERR=1
        GMESSAGE = mess(127,1986,1)
        Return
    Endif
Return
######################################################################################
# Valores del menú local 1969
# 2 - Familia
# 3 - Subfamilia
# 4 - Producto
# 5 - Artículo
# 6 - Tipo de Socio
# 7 - Tercero
# 8 -
# 9 -Fam.Est.Prov.
######################################################################################
Subprog YCTRCAMPO(YSELCAMPO,YCAMPO,YDESC)
    Value     Integer YSELCAMPO
    Value     Char YCAMPO()
    Variable  Char YDESC()

    #Si no hay valor en la linia, ponemos la desc. en blanco
    If YCAMPO="" Then : YDESC="" : End : Endif

    If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
    If clalev([F:AXX])=0 : Local File ATEXTRA [AXX] : Endif

    If YSELCAMPO=2 Then
        #Familia
        Read [AXX]AXX0="ATABDIV";"LNGDES";"SPA";num$(20);YCAMPO
        If fstat=0 Then
            YDESC = [F:AXX]TEXTE
        Else
            mkstat = 2
        Endif

    Elsif YSELCAMPO=3 Then
        #Subfamilia
        Read [AXX]AXX0="ATABDIV";"LNGDES";"SPA";num$(21);YCAMPO
        If fstat=0 Then
            YDESC = [F:AXX]TEXTE
        Else
            mkstat = 2
        Endif

    Elsif YSELCAMPO=4 Then
        #Producto
        Read [AXX]AXX0="ATABDIV";"LNGDES";"SPA";num$(22);YCAMPO
        If fstat=0 Then
            YDESC = [F:AXX]TEXTE
        Else
            mkstat = 2
        Endif

    Elsif YSELCAMPO=5 Then
        #Artículo
        If clalev([F:YITM])=0 : Local File ITMMASTER   [YITM] : Endif
        Read [YITM]ITM0=YCAMPO
        If fstat=0 Then
            YDESC=[F:YITM]ITMDES1
        Else
            mkstat = 2
        Endif

    Elsif YSELCAMPO=6 Then
        #Tipo de Socio
        If clalev([F:AST])=0 : Local File APLSTD  [AST] : Endif
        Filter [AST] Where [F:AST]LANCHP=1975 & [F:AST]LAN=GLANGUE & [F:AST]LANNUM=val(YCAMPO)
        If rowcount([F:AST])>0 Then
            Read [AST] First : If fstat  Raz [F:AST] : Endif
            YDESC=[F:AST]LANMES
        Else
            mkstat = 2
        Endif
        Filter [AST]

    Elsif YSELCAMPO=7 Then
        #Tercero
        If clalev([F:XBP])=0 : Local File BPARTNER [XBP] : Endif
        Read [XBP]BPR0=YCAMPO
        If fstat=0 Then
            YDESC=[F:XBP]BPRSHO
        Else
            mkstat = 2
        Endif

    Elsif YSELCAMPO=8 Then

        #Clasificaciones
        #Comprobamos si está activo el código de actividad YGC (Cárnicas)
        If func XCONTROLES.CODACT_ACTIVO("YGC") Then
            Gosub YCTRCAMPO From YGCSELECCION
        Endif

    Elsif YSELCAMPO=9 Then

        #Fam.Est.1 Proveedor

        Read [AXX]AXX0="ATABDIV";"LNGDES";"SPA";num$(40);YCAMPO
        If fstat=0 Then
            YDESC = [F:AXX]TEXTE
        Else
            mkstat = 2
        Endif

    Endif
End
######################################################################################
$ENT_SELOBJETO
    Local Char CODFIC

    If val(PARAM(1))=2 Then
        #Cliente
        If clalev([F:XBP])=0 : Local File BPCUSTOMER [XBP] : Endif
        CODFIC = "BPCUSTOMER"
        START   = "[F:XBP]BPCNUM"
        TIT(0) = mess(20,5000,1) ##"Clientes"
        NBCOL = 0
        NBCOL += 1 : COL(NBCOL) = "[F:XBP]BPCNUM" : Gosub YTEXTE #TIT(NBCOL)="Cliente"
        NBCOL += 1 : COL(NBCOL) = "[F:XBP]BPCNAM" : Gosub YTEXTE #TIT(NBCOL)="Razón social"
        NBCOL += 1 : COL(NBCOL) = "[F:XBP]BPCSHO" : Gosub YTEXTE #TIT(NBCOL)="Descrip. corta"
        Default File [XBP]
    Elsif val(PARAM(1))=3 Then
        #Artículo
        If clalev([F:YITM])=0 : Local File ITMMASTER   [YITM] : Endif
        CODFIC = "ITMMASTER"
        START   = "[F:YITM]ITMREF"
        TIT(0) = mess(1,5000,1) ##"Artículos"
        NBCOL = 0
        NBCOL += 1 : COL(NBCOL) = "[F:YITM]ITMREF"   : Gosub YTEXTE #TIT(NBCOL)="Artículo"
        NBCOL += 1 : COL(NBCOL) = "[F:YITM]ITMDES1"  : Gosub YTEXTE #TIT(NBCOL)="Descripción"
        Default File [YITM]
    Elsif val(PARAM(1))<>1 Then
       # Infbox "Sel. no creada para éste campo!"
        GERR=1
        GMESSAGE = mess(127,1986,1)
        Return
    Endif
Return
######################################################################################
Subprog YENTPLANT(EXERCICI,YPLANTA)
    Value    Char    EXERCICI
    Variable Char    YPLANTA

    GBIDC1= YPLANTA
    GBIDC2= EXERCICI
    If GYHESPERID=1 Then
        If clalev([F:YPL])=0 : Local File YPLANTACI [YPL] : Endif
        Call OBJET("YPL",GBIDC1,GBIDC2) From GOBJET
        YPLANTA = [F:YPL]CODIPLANTA
    Else
        If clalev([F:YAR])=0 : Local File YARITMOS [YAR] : Endif
        Call OBJET("YAR",GBIDC1,GBIDC2) From GOBJET
        YPLANTA = [F:YAR]CPLANTACIO
    Endif
End
######################################################################################
Subprog YGOBJET3(YCLAVE1,YCLAVE2,YCLAVE3,YCAMPO,YOBJETO)
    Value    Char    YCLAVE1()
    Value    Char    YCLAVE2()
    Value    Char    YCLAVE3()
    Variable Char    YCAMPO()
    Value    Char    YOBJETO()
    Local    Char    CLAVE(GLONADI)(0..1)
    Global   Char    YRETORN(45)

    GBIDC1 = YCLAVE1
    CLAVE(0) = YCLAVE2
    CLAVE(1) = YCLAVE3
    Call OBJET(YOBJETO,GBIDC1,CLAVE) From GOBJET
    YCAMPO = YRETORN
    Kill YRETORN
End
######################################################################################
Subprog MODIF_CALIDAD(VALOR,COD1,COD2,COD3,CLASE,ESTAT)
    Value     Char     VALOR
    Value     Char     COD1
    Value     Char     COD2
    Value     Char     COD3
    Value     Integer  CLASE
    Variable  Integer  ESTAT     : ESTAT = 1
    Local     Shortint NOL       : NOL=nolign-1
    Local     Integer  NUM

    If clalev([F:YCA])=0 : Local File YCALIDAD  [YCA] : Endif
    If clalev([F:YCS])=0 : Local File YCALSTAD  [YCS] : Endif

    Local    Char    XCOD1
    Local    Char    XCOD2
    Local    Char    XCOD3

    For NUM = 1 To 4
        Case NUM
            When 1
               XCOD1 = COD1
               XCOD2 = COD2
               XCOD3 = COD3
            When 2
               XCOD1 = COD1
               XCOD2 = COD2
               XCOD3 = ""
            When 3
               XCOD1 = COD1
               XCOD2 = ""
               XCOD3 = ""
            When 4
               XCOD1 = COD1
               XCOD2 = ""
               XCOD3 = COD3
        Endcase
        Read [YCS]YCS2=XCOD1;XCOD2;XCOD3;VALOR
        If (fstat=0)
            Break
        Endif
    Next

    Read [YCS]YCS2=XCOD1;XCOD2;XCOD3;VALOR
    If (fstat<>0)
        ESTAT=0
        End
    Else
        If ([F:YCS]TACTIU=1)
            ESTAT=0
            End
        Else
            Read [YCA]YCA0=VALOR
            If ([F:YCA]CLASECALID=CLASE and [F:YCA]CLASECALID<>3)
                ESTAT=0
                End
            Endif
        Endif
    Endif
End
######################################################################################
######################################################################################
Subprog MODIF_CALIBRE(VALOR,COD1,COD2,COD3,CLASE,ESTAT)
    Value     Char     VALOR
    Value     Char     COD1
    Value     Char     COD2
    Value     Char     COD3
    Value     Integer  CLASE
    Variable  Integer  ESTAT     : ESTAT = 1
    Local     Shortint NOL       : NOL=nolign-1
    Local     Integer  NUM

    If clalev([F:YCL])=0 : Local File YCLASIFIC [YCL] : Endif
    If clalev([F:YCC])=0 : Local File YCLASTAD  [YCC] : Endif

    Local    Char    XCOD1
    Local    Char    XCOD2
    Local    Char    XCOD3

    For NUM = 1 To 4
        Case NUM
            When 1
               XCOD1 = COD1
               XCOD2 = COD2
               XCOD3 = COD3
            When 2
               XCOD1 = COD1
               XCOD2 = COD2
               XCOD3 = ""
            When 3
               XCOD1 = COD1
               XCOD2 = ""
               XCOD3 = ""
            When 4
               XCOD1 = COD1
               XCOD2 = ""
               XCOD3 = COD3
        Endcase
        Read [YCC]YCC2=XCOD1;XCOD2;XCOD3;VALOR
        If (fstat=0)
            Break
        Endif
    Next

    Read [YCC]YCC2=XCOD1;XCOD2;XCOD3;VALOR
    If (fstat<>0)
        ESTAT=0
        End
    Else
        If ([F:YCC]TACTIU=1)
            ESTAT=0
            End
        Else
            Read [YCL]YCL0=VALOR
            If ([F:YCL]CLACALIBRE=CLASE and [F:YCL]CLACALIBRE<>3)
                ESTAT=0
                End
            Endif
        Endif
    Endif
End
######################################################################################
Subprog MODIF_TRANS(OBJETO, TRANS, ESTAT)
    Value Char OBJETO()
    Value Char TRANS()
    Variable Integer ESTAT

    If clalev([F:YAWI])=0 : Local File AWINDOW   [YAWI] : Endif
    ESTAT = 1

    Filter [YAWI] Where OBJ=OBJETO and TRN=TRANS and ENAFLG=2
    If fstat<>0 or rowcount([YAWI])=0 Then
        ESTAT = 0
    Endif
End
######################################################################################
$SEL_ADD_ENT
    Local Char CODFIC    : CODFIC = "BPADDRESS"

    If PARAM(1)="" or PARAM(2)<>"" Then : Return : Endif

    If clalev([F:BPA2])=0 : Local File BPADDRESS [BPA2] : Endif
    If clalev([F:BPD])=0  : Local File BPDLVCUST [BPD]  : Endif

    Link [BPA2] With [BPD]BPD0=BPANUM;BPAADD As [XXX]

    CRITERE = "[F:BPA2]YTACTIU = 2 & [F:BPD]BPCNUM=PARAM(1)"

    PARAM(2)=""
    START   = "[F:BPA2]BPAADD"
    TIT(0) = mess(21,5000,1) ##"Direcciones Entrega"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:BPA2]BPANUM" : Gosub YTEXTE #TIT(NBCOL)="Cliente"
    NBCOL += 1 : COL(NBCOL) = "[F:BPA2]BPAADD" : Gosub YTEXTE #TIT(NBCOL)="Entrega"
    NBCOL += 1 : COL(NBCOL) = "[F:BPD]BPDNAM"  : Call TEXTFIC("BPDLVCUST","BPDNAM",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Razón social"
    NBCOL += 1 : COL(NBCOL) = "[F:BPA2]BPADES" : Gosub YTEXTE #TIT(NBCOL)="Dirección"
    Default File [XXX]
Return
######################################################################################
$SEL_ADI
    Local Char NUMTAB(10), DEPCOD(GLONADI),DEPCOD1(GLONADI),DEPCOD2(GLONADI)

    If clalev([F:ADV])=0 : Local File ATABTAB [ADV] : Endif
    If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif

    [L]NUMTAB = PARAM(1) : # table diverse
    [L]DEPCOD = PARAM(2) : # code dépendance
    [L]DEPCOD1= PARAM(3)
    [L]DEPCOD2= PARAM(4)

    CRITERE = 'NUMTAB = '+[L]NUMTAB
    If [L]DEPCOD<>""
     Read [ADV]CODE = val([L]NUMTAB)
     If !fstat & [F:ADV]DEPNUM<>0
      CRITERE += ' & ((DEPCOD = "'+[L]DEPCOD+'") or (DEPCOD ="")'

      If [L]DEPCOD1 <> ""
        CRITERE += ' or (DEPCOD = "'+[L]DEPCOD1+'")'
      Endif
      If [L]DEPCOD2 <> ""
        CRITERE += ' or (DEPCOD = "'+[L]DEPCOD2+'")'
      Endif
      CRITERE += ')'
     Endif

    Endif
    Default File [ADI]
    OBJET   = "ADI"
    START   = "[F:ADI]CODE"
Return
######################################################################################
Subprog YCONTADI(VALEUR,NUMTAB,YTABDIV,YTABDIV1,YTABDIV2)
    Variable Char    VALEUR()
    Value    Char    NUMTAB()
    Value    Char    YTABDIV
    Value    Char    YTABDIV1
    Value    Char    YTABDIV2

    If val(NUMTAB)<>0
     If clalev([F:ADV])=0 : Local File ATABTAB [ADV] : Endif
     If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif
     If [L]YTABDIV<>""
      Read [ADV]CODE = val([L]NUMTAB)
      If !fstat & [F:ADV]DEPNUM<>0
       Read [ADI]CODE=val([L]NUMTAB);VALEUR
       If ! fstat & [F:ADI]DEPCOD<>[L]YTABDIV & [F:ADI]DEPCOD<>"" & [F:ADI]DEPCOD<>[L]YTABDIV1 & [F:ADI]DEPCOD<>[L]YTABDIV2
        GMESSAGE = VALEUR -mess(99,133,1)- [L]YTABDIV - [L]YTABDIV1 - [L]YTABDIV2
        mkstat = 2
       Endif
      Endif
     Endif
    Endif
End
######################################################################################
# Selección de Ofertas
######################################################################################
$SEL_OFERTA
    Local Char CODFIC    : CODFIC = "SQUOTE"

    If clalev([F:SQH])=0 : Local File SQUOTE     [SQH] : Endif
    If clalev([F:BPC])=0 : Local File BPCUSTOMER [BPC] Order By Key KEY1=BPCNAM : Endif

    Link [SQH] With [BPC]BPC0=BPCORD As [XXX] Order By Key KEY1=[BPC]BPCNAM

    START   = "[F:SQH]SQHNUM"
    TIT(0) = mess(27,5000,1) ##"Presupuestos"
    NBCOL = 0

    NBCOL += 1 : COL(NBCOL) = "[F:BPC]BPCNAM"     : Call TEXTFIC("BPCUSTOMER","BPCNAM",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Razon social"
    NBCOL += 1 : COL(NBCOL) = "[F:SQH]BPCORD"     : Gosub YTEXTE #TIT(NBCOL)="Cliente"
    NBCOL += 1 : COL(NBCOL) = "[F:SQH]SQHNUM"     : Gosub YTEXTE #TIT(NBCOL)="Presupuesto"
    NBCOL += 1 : COL(NBCOL) = "[F:SQH]CUSQUOREF"  : Gosub YTEXTE #TIT(NBCOL)="Referencia"
    Default File [XXX]
Return
######################################################################################
$SEL_DOCREL
    Local Char SENTENCIA(254)
    Local Char CODFIC

    If clalev([F:YRE])=0 : Local File YRELDOC   [YRE] : Endif

    Raz SENTENCIA
    SENTENCIA = "OBJETO=PARAM(1) and TRANSAC=PARAM(2) and MOSTRAR=PARAM(6)"
    If PARAM(3)<>"" : SENTENCIA = SENTENCIA + " and TIPDOC=PARAM(3)" : Endif
    If PARAM(4)<>"" : SENTENCIA = SENTENCIA + " and CLASE_D=val(PARAM(4))" : Endif
    If PARAM(5)<>"" : SENTENCIA=SENTENCIA+" and OBJETO_D=PARAM(5)" : Endif
    If PARAM(7)<>"" : SENTENCIA=SENTENCIA+" and CAMPO=PARAM(7)" : Endif

    Filter [YRE] Where evalue(SENTENCIA)
    If (fstat<>0) Then : Close File [F:YRE] : Return : Endif

    If rowcount([F:YRE])>1 Then
        Read [F:YRE]YRE0 First
        If fstat<>0 Then : Close File [F:YRE] : Return : Endif
   Endif

    If [F:YRE]TIPDOC_D<>"" Then
        SENTENCIA = "TIPDOC=[F:YRE]TIPDOC_D"
    Else
        SENTENCIA = "1=1"
    Endif

    If PARAM(5)="YC1" Then
        If clalev([F:YC1])=0 : Local File YACCABCAL [YC1] : Endif
        Default File [F:YC1]
        CODFIC = "YACCABCAL"
        CRITERE = SENTENCIA
        START   = "[F:YC1]YDOCREL"
        TIT(0) = mess(7,5000,1) ##"Calidad"
    Elsif PARAM(5)="YC2" Then
        If clalev([F:YC2])=0 : Local File YACCABCLA [YC2] : Endif
        CODFIC = "YACCABCLA"
        CRITERE = SENTENCIA
        Default File [F:YC2]
        START   = "[F:YC2]YDOCREL"
        TIT(0) = mess(6,5000,1) ##"Clasificación"
    Elsif PARAM(5)="YC3" Then
        If clalev([F:YCC])=0 : Local File YACCABENV [YC3] : Endif
        CODFIC = "YACCABENV"
        CRITERE = SENTENCIA
        Default File [F:YC3]
        START   = "[F:YC3]YDOCREL"
        TIT(0) = mess(9,5000,1) ##"Envases"
    Else
        Return
    Endif

    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F]YDOCREL"     : Gosub YTEXTE #TIT(NBCOL)="Documento"
    NBCOL += 1 : COL(NBCOL) = "[F]YDOCLIN"     : Gosub YTEXTE #TIT(NBCOL)="Orden"
    NBCOL += 1 : COL(NBCOL) = "[F]CODIPERSON"  : Gosub YTEXTE #TIT(NBCOL)="Tercero"
Return
######################################################################################
$SEL_NUMDOC
    Local Char CODFIC

    If PARAM(1)="YC1" Then
        If clalev([F:YC1])=0 : Local File YACCABCAL  [YC1] : Endif
        CODFIC = "YACCABCAL"

        CRITERE = "[F:YC1]YDOCLIN='"+GORDENDOC+"'"
        START   = "[F:YC1]YDOCREL"
        TIT(0) = mess(28,5000,1) ##"Selección documento"
        NBCOL = 0
        NBCOL += 1 : COL(NBCOL) = "[F:YC1]YDOCREL"    : Gosub YTEXTE #TIT(NBCOL)="Nº Documento"
        NBCOL += 1 : COL(NBCOL) = "[F:YC1]DESDOCUM"   : Gosub YTEXTE #TIT(NBCOL)="Desc. Documento"
        NBCOL += 1 : COL(NBCOL) = "[F:YC1]FCY"        : Gosub YTEXTE #TIT(NBCOL)="Planta"
        NBCOL += 1 : COL(NBCOL) = "[F:YC1]EXERCICI"   : Gosub YTEXTE #TIT(NBCOL)="Campaña"
        NBCOL += 1 : COL(NBCOL) = "[F:YC1]TIPDOC"     : Gosub YTEXTE #TIT(NBCOL)="Documento"
        NBCOL += 1 : COL(NBCOL) = "[F:YC1]ITMREF"     : Gosub YTEXTE #TIT(NBCOL)="Producto"
        NBCOL += 1 : COL(NBCOL) = "[F:YC1]CODIPERSON" : Gosub YTEXTE #TIT(NBCOL)="Socio"
        NBCOL += 1 : COL(NBCOL) = "[F:YC1]DATA"       : Gosub YTEXTE #TIT(NBCOL)="Fecha"
        Default File [YC1]
    Elsif PARAM(1)="YC2" Then
    Elsif PARAM(1)="YC3" Then
    Elsif PARAM(1)="YC5" Then
    Endif
Return
######################################################################################
# Selección de Recepciones desde la BUSQUEDA
######################################################################################
#No se puede llamar directamente ésta acción. Se debe utilizar la acción YSELBUSPTH
$SEL_BUSPTH
    Local Char SENTENCIA(254)
    Local Char CODFIC    : CODFIC = "PRECEIPTD"


    If !clalev ([M:YPTW]) Then : Return : Endif

    SENTENCIA="1=1"
    If [M:YPTW]WTRAZA <> ""
        SENTENCIA+=" & YCODTRAZA='"+[M:YPTW]WTRAZA+"'"
    Endif
    If [M:YPTW]WPESINI <> ""
        SENTENCIA+=" & YNUMPESAD>='"+[M:YPTW]WPESINI+"'"
    Endif
    If [M:YPTW]WPESFI <> ""
        SENTENCIA+=" & YNUMPESAD<='"+[M:YPTW]WPESFI+"'"
    Endif

    Local File PRECEIPTD [YPTD] Where evalue(SENTENCIA)

    #Existe 1 solo reg. que cumple la condición. Devolvemos el producto.
    If rowcount([YPTD])=1 Then
        Filter [YPTD] Where evalue(SENTENCIA)
        Read [YPTD] First : If fstat  Raz [F:YPTD] : Endif
        VALEUR = [F:YPTD]PTHNUM
        Return
    Endif

    CRITERE = SENTENCIA
    START   = "[F:YPTD]PTHNUM"
    TIT(0) = mess(2,5000,1) ##"Recepciones"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:YPTD]PTHNUM"  : Gosub YTEXTE #TIT(NBCOL)="N.Recepción"
    NBCOL += 1 : COL(NBCOL) = "[F:YPTD]BPSNUM"  : Gosub YTEXTE #TIT(NBCOL)="Proveedor"
    Default File [YPTD]
Return
######################################################################################
$FIN_TRAZA

Return
######################################################################################
#Acceder a la tabla varia 20,21,etc. en función del valor de param(1)
$ENT_SELGRUPO
    If clalev([F:ADI])=0 : Local File ATABDIV [ADI] : Endif

    CRITERE = "[F:ADI]NUMTAB = val(PARAM(1))+19"
    Default File [ADI]
    OBJET="ADI"
    START   = "[F:ADI]CODE"
Return
######################################################################################
# Selección Terceros en función de la clase de Tercero
# (T.V. 1012 - Cuadrilla, Veterinario, etc.)
######################################################################################
$SEL_TERCERO
    If PARAM(1)="" : PARAM(1)="1=1" : Endif
    If PARAM(1)="C" or PARAM(1)="CU" Then
        CRITERE(1) = "[F:BPR]YTIPSOC=6"
    Elsif PARAM(1)="V" Then
        CRITERE(1) = "[F:BPR]YTIPSOC=4"
    Endif
    OPTIONS    = ""
    OBJET      = "BPR"
Return
######################################################################################
Subprog CONTROLAR_TERCERO_RELACION(CLASETERCE, TERCERO, ESTAT)
Value Char CLASETERCE()
Value Char TERCERO()
Variable Integer ESTAT

    Raz ESTAT
    If clalev([F:XPR])=0 : Local File BPARTNER  [XPR] : Endif
    Read [XPR]BPR0=TERCERO
    If fstat<>0 Then
        End
    Endif

    If (CLASETERCE="C" or CLASETERCE="CU") and [F:XPR]YTIPSOC<>6 Then
        End
    Elsif CLASETERCE="V" and [F:XPR]YTIPSOC<>4 Then
        End
    Endif
    ESTAT = 1
End
######################################################################################
Subprog YELIMDOC(YCAMPO)
    Variable Char    YCAMPO()

    YCAMPO=""
End
######################################################################################
$SEL_EXE

    REQUETE="SELECT DISTINCT(EXERCICI_0) FROM YPARANY "

    For (Char EXERC) From "5" Sql REQUETE As [XXX]
        NBTEX += 1
        TEX(NBTEX)   = [F:XXX]EXERC
    Next

    TIT = "Ejercicios"
Return
######################################################################################
# Selección de Tarifa de Transporte
# Solo se puede utilizar desde la pantalla YDH3
######################################################################################
$SEL_TARIFATRANS
    Local Char SENTENCIA(254)

    If clalev([F:YCP])=0  : Local File YCABPREU [YCP]  : Endif
    If clalev([F:YLR])=0  : Local File YLINPREU [YLR]  : Endif
    If clalev([F:AST1])=0 : Local File APLSTD   [AST1] : Endif
    If clalev([F:AST2])=0 : Local File APLSTD   [AST2] : Endif

    #Filtramos siempre por la planta y la fecha
    SENTENCIA = "FCY='" + [M]YFCY + "' & DATA_INI <= [" + num$([M]YFECHA)  + "] & DATA_FI >= [" + num$([M]YFECHA) + "]"

    If [M]YFILTRE<>2 Then
        #Si no está activa la opción de "No filtrar en la consulta de transporte", filtramos por el resto de campos
        If [M]YGRUPV<>"" Then
            SENTENCIA = SENTENCIA + " & GRUPVEHICL='" + [M]YGRUPV + "'"
        Endif
        If [M]YGRUPT<>"" Then
            SENTENCIA = SENTENCIA + " & GRUPTERCE='" + [M]YGRUPT + "'"
        Endif
        If [M]YGRUPP<>"" Then
            SENTENCIA = SENTENCIA + " & GRUPPROD='" + [M]YGRUPP + "'"
        Endif
        If [M]YGRUPR<>"" Then
            SENTENCIA = SENTENCIA + " & GRUPREPRE='" + [M]YGRUPR + "'"
        Endif
        If GYFILQTYTRA=2 Then
            If [M]YQTYTRA<>0 and [M]YQTYTRA<>13 Then
                SENTENCIA = SENTENCIA + " & YQTYTRA=" + num$([M]YQTYTRA)
            Endif
        Endif
    Endif

    If clalev([F:AXX1])=0 : Local File ATEXTRA [AXX1] Where CODFIC="ATABDIV" and ZONE="SHODES" and LANGUE="SPA" and IDENT1=num$(1013) : Endif
    If clalev([F:AXX2])=0 : Local File ATEXTRA [AXX2] Where CODFIC="ATABDIV" and ZONE="SHODES" and LANGUE="SPA" and IDENT1=num$(1013) : Endif

    Link [YLR] With [YCP]YCP0=CODITAULA,[AST1]CLE=num$(1981);YQTYTRA;"SPA",[AST2]CLE=num$(1995);TIPOCALC;"SPA",
&   [AXX1]AXX0="ATABDIV";"SHODES";"SPA";"1013";GRUPVEHICL,
&   [AXX2]AXX0="ATABDIV";"SHODES";"SPA";"1013";GRUPTERCE
&    As [YYY] Where [F:YCP]TCLASE=1 and [F:YCP]TACTIU=2


    Default File [YYY]

    #Existe más de 1 registro que cumple la condición
    CRITERE = SENTENCIA

    START   = "[F:YLR]CODITAULA"

    OBJET = "YLP"
Return
######################################################################################
$FIN_TARIFATRANS
    Local Decimal IMPORTE

    If [F:YLR]CODITAULA = "" : Return : Endif ##--Salimos si no seleccionamos ningun registro --##
    [M]YGRUPV = [F:YLR]GRUPVEHICL
    [M]YGRUPT = [F:YLR]GRUPTERCE
    [M]YGRUPP = [F:YLR]GRUPPROD
    [M]YGRUPR = [F:YLR]GRUPREPRE

    If [M]YQTYTRA <> [F:YLR]YQTYTRA Then
        ###--- Buscamos la cantidad del nuevo campo seleccionado
        [M]YQTYTRA = [F:YLR]YQTYTRA
        Call AM_YTCANTRANS([M:YDH3]YTCANTRANS) From SPVYDH3
    Endif

    [M]YPREUTRANS = [F:YLR]PREU1
    [M]YIMPTRANS = [F:YLR]IMPORTE
    If [M]YPREUTRANS <> 0 Then
        IMPORTE = ([M]YCANTRANS * [M]YPREUTRANS)
        If [M]YQTYTRA = 16 : IMPORTE = IMPORTE / 1000 : Endif
        Call ARRDEV(IMPORTE,[M:YDH3]CUR) From TRTDIV
        [M]YIMPTRANS = IMPORTE
#        Affzo [M]YIMPTRANS
    Endif
    [M]YTIMPTRANS = 2
    Affzo [M]5
Return
######################################################################################
######################################################################################
# Selección de Tarifa de Descarga
# Solo se puede utilizar desde la pantalla YDH3
######################################################################################
$SEL_TARIFADESC
    Local Char SENTENCIA(254)
    Local Char CODFIC    : CODFIC = "YLINPREU"

    If clalev([F:YCP])=0  : Local File YCABPREU [YCP]  : Endif
    If clalev([F:XLR])=0  : Local File YLINPREU [XLR]  : Endif
    If clalev([F:AST1])=0 : Local File APLSTD   [AST1] : Endif
    If clalev([F:AST2])=0 : Local File APLSTD   [AST2] : Endif

    #Filtramos siempre por la planta y la fecha
    SENTENCIA = "FCY='" + [M]YFCY + "' & DATA_INI <= [" + num$([M]YFECHA)  + "] & DATA_FI >= [" + num$([M]YFECHA) + "]"

    If [M]YFILTRE<>2 Then
       If [M]YGRUPTD<>"" Then
            SENTENCIA = SENTENCIA + " & GRUPTERCE='" + [M]YGRUPTD + "'"
        Endif
        If [M]YGRUPDD<>"" Then
            SENTENCIA = SENTENCIA + " & GRUPREPRE='" + [M]YGRUPDD + "'"
        Endif
        If GYFILQTYDES=2 Then
            If [M]YQTYDESC<>0 and [M]YQTYDESC<>13 Then
                SENTENCIA = SENTENCIA + " & YQTYTRA=" + num$([M]YQTYDESC)
            Endif
        Endif
    Endif

    If clalev([F:AXX1])=0 : Local File ATEXTRA [AXX1] Where CODFIC="ATABDIV" and ZONE="SHODES" and LANGUE="SPA" and IDENT1=num$(1013) : Endif
    If clalev([F:AXX2])=0 : Local File ATEXTRA [AXX2] Where CODFIC="ATABDIV" and ZONE="SHODES" and LANGUE="SPA" and IDENT1=num$(1013) : Endif

    Link [XLR] With [YCP]YCP0=CODITAULA,[AST1]CLE=num$(1981);YQTYTRA;"SPA",[AST2]CLE=num$(1995);TIPOCALC;"SPA",
&   [AXX1]AXX0="ATABDIV";"SHODES";"SPA";"1013";GRUPREPRE,
&   [AXX2]AXX0="ATABDIV";"SHODES";"SPA";"1013";GRUPTERCE
&    As [YYY] Where [F:YCP]TCLASE=1 and [F:YCP]TACTIU=2


    Default File [YYY]

    #Existe más de 1 registro que cumple la condición
    CRITERE = SENTENCIA

    START   = "[F:XLR]CODITAULA"
    TIT(0) = mess(29,5000,1) ##"Tarifas Descargas"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:YCP]DESCRIPCIO"          : Call TEXTFIC("YCABPREU","DESCRIPCIO",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Tabla"
    NBCOL += 1 : COL(NBCOL) = "[F:XLR]FCY"                 : Gosub YTEXTE #TIT(NBCOL)="Planta"
    NBCOL += 1 : COL(NBCOL) = "[F:XLR]GRUPREPRE"           : TIT(NBCOL)="P.Descargador"
    NBCOL += 1 : COL(NBCOL) = "LEFT$([F:AXX1]TEXTE,25)"    : TIT(NBCOL)="P.Descargador"
    NBCOL += 1 : COL(NBCOL) = "[F:XLR]GRUPTERCE"           : Gosub YTEXTE #TIT(NBCOL)="P.Tercero"
    NBCOL += 1 : COL(NBCOL) = "LEFT$([F:AXX2]TEXTE,25)"    : Call TEXTFIC("YLINPREU","GRUPTERCE",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="P.Tercero"
    NBCOL += 1 : COL(NBCOL) = "left$([F:AST1]LANMES,25)"   : Call TEXTFIC("YLINPREU","YQTYTRA",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="T.Precio"
    NBCOL += 1 : COL(NBCOL) = "[F:XLR]QUANT_INI"           : Gosub YTEXTE #TIT(NBCOL)="Can.Inicio"
    NBCOL += 1 : COL(NBCOL) = "[F:XLR]QUANT_FI"            : Gosub YTEXTE #TIT(NBCOL)="Can.Fin"
    NBCOL += 1 : COL(NBCOL) = "[F:XLR]DATA_INI"            : Gosub YTEXTE #TIT(NBCOL)="Fecha Inicio"
    NBCOL += 1 : COL(NBCOL) = "[F:XLR]DATA_FI"             : Gosub YTEXTE #TIT(NBCOL)="Fecha Fin"
    NBCOL += 1 : COL(NBCOL) = "[F:XLR]PREU1"               : Gosub YTEXTE #TIT(NBCOL)="Precio"
    NBCOL += 1 : COL(NBCOL) = "[F:XLR]IMPORTE"             : Gosub YTEXTE #TIT(NBCOL)="Importe"
Return
######################################################################################
$FIN_TARIFADESC
    Local Decimal IMPORTE

    If [F:XLR]CODITAULA = "" : Return : Endif ##--Salimos si no seleccionamos ningun registro --##
    [M]YGRUPTD = [F:XLR]GRUPTERCE
    [M]YGRUPDD = [F:XLR]GRUPREPRE

    If [M]YQTYDESC <> [F:XLR]YQTYTRA Then
        ###--- Buscamos la cantidad del nuevo campo seleccionado
        [M]YQTYDESC = [F:XLR]YQTYTRA
        Call AM_YTCANDESC([M:YDH3]YTCANDESC) From SPVYDH3
    Endif

    [M]YPREUDESC = [F:XLR]PREU1
    [M]YIMPDESC = [F:XLR]IMPORTE
    If [M]YPREUDESC <> 0 Then
        IMPORTE = ([M]YCANDESC * [M]YPREUDESC)
        If [M]YQTYDESC = 16 : IMPORTE = IMPORTE / 1000 : Endif
        Call ARRDEV(IMPORTE,[M:YDH3]CUR) From TRTDIV
        [M]YIMPDESC = IMPORTE
#        Affzo [M]YIMPdesc
    Endif
    [M]YTIMPDESC = 2
    Affzo [M]10
Return
######################################################################################
######################################################################################
$SEL_DOC
    Local Char CODFIC    : CODFIC = "YCABTRANS"

    If clalev([F:XCT])=0 : Local File YCABTRANS [XCT] Order By Key CLE=DATADOCUME : Endif

    CRITERE =  " [F:XCT]CODITIPDOC = '" + PARAM(1) + "'"
    CRITERE += " & [F:XCT]TIPOFCY = " + PARAM(2)

    START   = "[F:XCT]YCTNUM"
    TIT(0) = mess(13,5000,1) ##"Documentos"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:XCT]YCTNUM"     : Gosub YTEXTE #TIT(NBCOL) = "Nº. Doc."
    NBCOL += 1 : COL(NBCOL) = "[F:XCT]FCY"        : Gosub YTEXTE #TIT(NBCOL) = "Planta"
    NBCOL += 1 : COL(NBCOL) = "[F:XCT]EXERCICI"   : Gosub YTEXTE #TIT(NBCOL) = "Ejercicio"
    NBCOL += 1 : COL(NBCOL) = "[F:XCT]CODITIPDOC" : Gosub YTEXTE #TIT(NBCOL) = "Tipo Doc."
    NBCOL += 1 : COL(NBCOL) = "[F:XCT]DATADOCUME" : Gosub YTEXTE #TIT(NBCOL) = "Fecha"
    NBCOL += 1 : COL(NBCOL) = "[F:XCT]CODIPERSON" : Gosub YTEXTE #TIT(NBCOL) = "Tercero"

    Default File [XCT]
Return
######################################################################################
# Selección de Transportista / Descargador
######################################################################################
$SEL_BPT
    If clalev([F:XBP])=0 : Local File BPARTNER   [XBP] : Endif
    If clalev([F:YPS])=0 : Local File BPCARRIER  [XBT] : Endif
    Local Char CODFIC    : CODFIC = "BPCARRIER"

    Link [XBT] With [XBP]BPR0=BPTNUM As [XXX]

    If val(PARAM(1)) = 0
        CRITERE = "[F:XBP]YTIPSOC <> 8"
    Elsif val(PARAM(1)) = 8
        CRITERE = "[F:XBP]YTIPSOC = 8"
    Endif

    START   = "[F:XBT]BPTNUM"
    TIT(0) = mess(18,5000,1) ##"Proveedores"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:XBT]BPTNUM"
    If val(PARAM(1)) = 0
        TIT(NBCOL)="Transportista"
    Elsif val(PARAM(1)) = 8
        TIT(NBCOL)="Descargador"
    Endif

    NBCOL += 1 : COL(NBCOL) = "[F:XBT]BPTNAM" : Gosub YTEXTE #TIT(NBCOL)="Razón social"
    NBCOL += 1 : COL(NBCOL) = "[F:XBT]BPTSHO" : Gosub YTEXTE #TIT(NBCOL)="Descrip. corta"
    Default File [XXX]
Return
######################################################################################
######################################################################################
# Selección de Tarifa de Transporte
# Solo se puede utilizar desde la pantalla YCI2
######################################################################################
$SEL_TARIFATRANSYCI
    Local Char SENTENCIA(254)
    Local Char CODFIC    : CODFIC = "YLINPREU"

    Call TEXTFIC("BPDLVCUST","BPDNAM",1,TIT(NBCOL)) From OBJDIV #

    If clalev([F:YCP])=0  : Local File YCABPREU [YCP]  : Endif
    If clalev([F:YLR])=0  : Local File YLINPREU [YLR]  : Endif
    If clalev([F:AST1])=0 : Local File APLSTD   [AST1] : Endif
    If clalev([F:AST2])=0 : Local File APLSTD   [AST2] : Endif

    #Filtramos siempre por la planta y la fecha
    SENTENCIA = "FCY='" + [M]FCY + "' & DATA_INI <= [" + num$([M]DATA)  + "] & DATA_FI >= [" + num$([M]DATA) + "]"

    If [M]TFILTRE<>2 Then
        #Si no está activa la opción de "No filtrar en la consulta de transporte", filtramos por el resto de campos
        If [M]GRUPPORTSV<>"" Then
            SENTENCIA = SENTENCIA + " & GRUPVEHICL='" + [M]GRUPPORTSV + "'"
        Endif
        If [M]GRUPPORTST<>"" Then
            SENTENCIA = SENTENCIA + " & GRUPTERCE='" + [M]GRUPPORTST + "'"
        Endif
        If [M]XPORTSP<>"" Then
            SENTENCIA = SENTENCIA + " & GRUPPROD='" + [M]XPORTSP + "'"
        Endif
        If [M]GRUPPORTSR<>"" Then
            SENTENCIA = SENTENCIA + " & GRUPREPRE='" + [M]GRUPPORTSR + "'"
        Endif

    Endif

    #Enlazamos

    If clalev([F:AXX1])=0 : Local File ATEXTRA [AXX1] Where CODFIC="ATABDIV" and ZONE="SHODES" and LANGUE="SPA" and IDENT1=num$(1013) : Endif
    If clalev([F:AXX2])=0 : Local File ATEXTRA [AXX2] Where CODFIC="ATABDIV" and ZONE="SHODES" and LANGUE="SPA" and IDENT1=num$(1013) : Endif

    Link [YLR] With [YCP]YCP0=CODITAULA,[AST1]CLE=num$(1981);YQTYTRA;"SPA",[AST2]CLE=num$(1995);TIPOCALC;"SPA",
&   [AXX1]AXX0="ATABDIV";"SHODES";"SPA";"1013";GRUPVEHICL,
&   [AXX2]AXX0="ATABDIV";"SHODES";"SPA";"1013";GRUPTERCE
&    As [YYY] Where [F:YCP]TCLASE=1 and [F:YCP]TACTIU=2


    Default File [YYY]

    #Existe más de 1 registro que cumple la condición
    CRITERE = SENTENCIA

    START   = "[F:YLR]CODITAULA"
    TIT(0) = mess(30,5000,1) ##"Tarifas Transporte"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:YCP]DESCRIPCIO"          : Call TEXTFIC("YCABPREU","DESCRIPCIO",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Tabla"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]FCY"                 : Gosub YTEXTE #TIT(NBCOL)="Planta"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]GRUPVEHICL"          : Gosub YTEXTE #TIT(NBCOL)="P.Vehiculo"
    NBCOL += 1 : COL(NBCOL) = "left$([F:AXX1]TEXTE,25)"    : Call TEXTFIC("YLINPREU","GRUPVEHICL",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="P.Vehiculo"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]GRUPTERCE"           : Gosub YTEXTE #TIT(NBCOL)="P.Tercero"
    NBCOL += 1 : COL(NBCOL) = "left$([F:AXX2]TEXTE,25)"    : Call TEXTFIC("YLINPREU","GRUPTERCE",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="P.Tercero"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]GRUPPROD"            : Gosub YTEXTE #TIT(NBCOL)="P.Artículo"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]GRUPREPRE"           : Gosub YTEXTE #TIT(NBCOL)="P.Trans."
    NBCOL += 1 : COL(NBCOL) = "left$([F:AST1]LANMES,25)"   : Call TEXTFIC("YLINPREU","YQTYTRA",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="T.Precio"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]QUANT_INI"           : Gosub YTEXTE #TIT(NBCOL)="Ctd. Inicio"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]QUANT_FI"            : Gosub YTEXTE #TIT(NBCOL)="Ctd. Fin"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]PREU1"               : Gosub YTEXTE #TIT(NBCOL)="Precio"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]IMPORTE"             : Gosub YTEXTE #TIT(NBCOL)="Importe"
Return
######################################################################################
$FIN_TARIFATRANSYCI
    Local Decimal IMPORTE

    If [F:YLR]CODITAULA = "" : Return : Endif ##--Salimos si no seleccionamos ningun registro --##
    [M]GRUPPORTSV = [F:YLR]GRUPVEHICL
    [M]GRUPPORTST = [F:YLR]GRUPTERCE
    [M]XPORTSP    = [F:YLR]GRUPPROD
    [M]GRUPPORTSR = [F:YLR]GRUPREPRE

    If [M]YQTYTRA <> [F:YLR]YQTYTRA Then
        ###--- Buscamos la cantidad del nuevo campo seleccionado
        [M]YQTYTRA = [F:YLR]YQTYTRA
        Call AM_YQTYTRA([M]YQTYTRA) From SPVYCI
    Endif

    [M]PREUTRAN = [F:YLR]PREU1
    [M]IMPTRAN  = [F:YLR]IMPORTE
    If [M]PREUTRAN <> 0 Then
        IMPORTE = ([M]KILOSORI * [M]PREUTRAN)
        If [M]YQTYTRA = 16 : IMPORTE = IMPORTE / 1000 : Endif
        Call ARRDEV(IMPORTE,[M]CUR) From TRTDIV
        [M]IMPTRAN = IMPORTE
#        Affzo [M]IMPTRAN
    Endif
    [M]TFILTRE = 2
    Affzo [M:YCI2]5
Return
######################################################################################
# Selección de Tarifa de Transporte
# Solo se puede utilizar desde la pantalla YCI2
######################################################################################
$SEL_TARIFATRANSYV1
    Local Char SENTENCIA(254)
    Local Char CODFIC    : CODFIC = "YLINPREU"

    If clalev([F:YCP])=0  : Local File YCABPREU [YCP]  : Endif
    If clalev([F:YLR])=0  : Local File YLINPREU [YLR]  : Endif
    If clalev([F:AST1])=0 : Local File APLSTD   [AST1] : Endif
    If clalev([F:AST2])=0 : Local File APLSTD   [AST2] : Endif

    #Filtramos siempre por la planta y la fecha
    SENTENCIA = "FCY='" + [M]STOFCY + "' & DATA_INI <= [" + num$([M]DATA)  + "] & DATA_FI >= [" + num$([M]DATA) + "]"

    If [M]TFILTRE<>2 Then
        #Si no está activa la opción de "No filtrar en la consulta de transporte", filtramos por el resto de campos
        If [M]GRUPPORTSV<>"" Then
            SENTENCIA = SENTENCIA + " & GRUPVEHICL='" + [M]GRUPPORTSV + "'"
        Endif
        If [M]GRUPPORTST<>"" Then
            SENTENCIA = SENTENCIA + " & GRUPTERCE='" + [M]GRUPPORTST + "'"
        Endif
        If [M]XPORTSP<>"" Then
            SENTENCIA = SENTENCIA + " & GRUPPROD='" + [M]XPORTSP + "'"
        Endif
        If [M]GRUPPORTSR<>"" Then
            SENTENCIA = SENTENCIA + " & GRUPREPRE='" + [M]GRUPPORTSR + "'"
        Endif

    Endif

    #Enlazamos

    If clalev([F:AXX1])=0 : Local File ATEXTRA [AXX1] Where CODFIC="ATABDIV" and ZONE="SHODES" and LANGUE="SPA" and IDENT1=num$(1013) : Endif
    If clalev([F:AXX2])=0 : Local File ATEXTRA [AXX2] Where CODFIC="ATABDIV" and ZONE="SHODES" and LANGUE="SPA" and IDENT1=num$(1013) : Endif

    Link [YLR] With [YCP]YCP0=CODITAULA,[AST1]CLE=num$(1981);YQTYTRA;"SPA",[AST2]CLE=num$(1995);TIPOCALC;"SPA",
&   [AXX1]AXX0="ATABDIV";"SHODES";"SPA";"1013";GRUPVEHICL,
&   [AXX2]AXX0="ATABDIV";"SHODES";"SPA";"1013";GRUPTERCE
&    As [YYY] Where [F:YCP]TCLASE=1 and [F:YCP]TACTIU=2


    Default File [YYY]

    #Existe más de 1 registro que cumple la condición
    CRITERE = SENTENCIA

    START   = "[F:YLR]CODITAULA"
    TIT(0) = mess(30,5000,1) ##"Tarifas Transporte"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:YCP]DESCRIPCIO"          : Call TEXTFIC("YCABPREU","DESCRIPCIO",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Tabla"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]FCY"                 : Gosub YTEXTE #TIT(NBCOL)="Planta"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]GRUPVEHICL"          : Gosub YTEXTE #TIT(NBCOL)="P.Vehiculo"
    NBCOL += 1 : COL(NBCOL) = "left$([F:AXX1]TEXTE,25)"    : Call TEXTFIC("YLINPREU","GRUPVEHICL",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="P.Vehiculo"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]GRUPTERCE"           : Gosub YTEXTE #TIT(NBCOL)="P.Tercero"
    NBCOL += 1 : COL(NBCOL) = "left$([F:AXX2]TEXTE,25)"    : Call TEXTFIC("YLINPREU","GRUPTERCE",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="P.Tercero"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]GRUPPROD"            : Gosub YTEXTE #TIT(NBCOL)="P.Artículo"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]GRUPREPRE"           : Gosub YTEXTE #TIT(NBCOL)="P.Trans."
    NBCOL += 1 : COL(NBCOL) = "left$([F:AST1]LANMES,25)"   : Call TEXTFIC("YLINPREU","YQTYTRA",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="T.Precio"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]QUANT_INI"           : Gosub YTEXTE #TIT(NBCOL)="Ctd. Inicio"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]QUANT_FI"            : Gosub YTEXTE #TIT(NBCOL)="Ctd. Fin"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]PREU1"               : Gosub YTEXTE #TIT(NBCOL)="Precio"
    NBCOL += 1 : COL(NBCOL) = "[F:YLR]IMPORTE"             : Gosub YTEXTE #TIT(NBCOL)="Importe"
Return
######################################################################################
$FIN_TARIFATRANSYV1
    Local Decimal IMPORTE
    If [F:YLR]CODITAULA = "" : Return : Endif ##--Salimos si no seleccionamos ningun registro --##
    [M]GRUPPORTSV = [F:YLR]GRUPVEHICL
    [M]GRUPPORTST = [F:YLR]GRUPTERCE
    [M]XPORTSP    = [F:YLR]GRUPPROD
    [M]GRUPPORTSR = [F:YLR]GRUPREPRE

    If [M]YQTYTRA <> [F:YLR]YQTYTRA Then
        ###--- Buscamos la cantidad del nuevo campo seleccionado
        [M]YQTYTRA = [F:YLR]YQTYTRA
        Call AM_YQTYTRA([M]YQTYTRA) From SPVYV1
    Endif

    [M]PREUTRAN = [F:YLR]PREU1
    [M]IMPTRAN  = [F:YLR]IMPORTE
    If [M]PREUTRAN <> 0 Then
        IMPORTE = ([M]KILOSORI * [M]PREUTRAN)
        If [M]YQTYTRA = 16 : IMPORTE = IMPORTE / 1000 : Endif
        Call ARRDEV(IMPORTE,[M]CUR) From TRTDIV
        [M]IMPTRAN = IMPORTE
#        Affzo [M]IMPTRAN
    Endif
    [M]TFILTRE = 2
    Affzo [M:YV12]5
Return
######################################################################################
$SEL_PEDIDO
    If PARAM(1)="YCV" or PARAM(1)="YVP" Then

        If PARAM(2)="C" Then
            #Llamamos a la seleccion estandard
            CRITERE(1)="[F:SOH]CDTSTA <=1 "
            If dim([M:YCV0]DRN)>0 Then
                CRITERE(1)+=" & [F:SOH]DRN = [M:YCV0]DRN"
            Endif
            OPTIONS    = ""
            OBJET      = "SOH"
        Else
            #Estamos en la linea o la secuencia
            If clalev([F:SOH])=0 : Local File SORDER [SOH] : Endif
            If clalev([F:SOQ])=0 : Local File SORDERQ [SOQ] : Endif
            Link [SOQ] With [SOH]SOH0=SOHNUM As [XXX]

            CRITERE(1)="[F:SOQ]SOHNUM = PARAM(3) & [F:SOQ]SOQSTA = 1 "

            If PARAM(2)="L" Then
                START   = "[F:SOQ]SOPLIN"
            Else
                CRITERE(1)+=" & [F:SOQ]SOPLIN = val(PARAM(4)) "
                START   = "[F:SOQ]SOQSEQ"
            Endif

            TIT(0) = mess(31,5000,1) ##"Pedidos de Venta"
            NBCOL = 0
            NBCOL += 1 : COL(NBCOL) = "[F:SOQ]SOHNUM"     : Call TEXTFIC("SORDERQ","SOHNUM",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Nº Documento"
            NBCOL += 1 : COL(NBCOL) = "[F:SOQ]SOPLIN"     : Call TEXTFIC("SORDERQ","SOPLIN",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Linea"
            NBCOL += 1 : COL(NBCOL) = "[F:SOQ]SOQSEQ"     : Call TEXTFIC("SORDERQ","SOQSEQ",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Secuencia"
            NBCOL += 1 : COL(NBCOL) = "[F:SOH]BPCORD"     : Call TEXTFIC("SORDER","BPCORD",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Cliente"
            NBCOL += 1 : COL(NBCOL) = "[F:SOH]ORDDAT"     : Call TEXTFIC("SORDERQ","ORDDAT",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Fecha"
            Default File [XXX]
        Endif

    Elsif GABREV="YOT" or GABREV="YDM" Then
        CRITERE(1)=""
        OPTIONS    = ""
        OBJET      = "POH"
    Endif
Return
######################################################################################
$SEL_PLANTILLA
    If clalev([F:YTX])=0 : Local File YTRANSAV [YTX] : Endif

    If PARAM(1)="" : PARAM(1)="1=1" : Endif
    CRITERE(1) = PARAM(1)
    OPTIONS    = PARAM(2)
    OBJET      = "YP3"
Return
######################################################################################
$SEL_MFGNUM
    Local Char     FCY        : FCY       = PARAM(1)
    Local Integer  WMFGSTA    : WMFGSTA   = val(PARAM(2))
    Local Char     CODFIC     : CODFIC    = "MFGHEAD"
    Local Char     TIPODOCUM  : TIPODOCUM = PARAM(3)

    If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
    If clalev ([F:MFG])=0 : Local File MFGHEAD    : Endif

    Default File [MFG]

    If WMFGSTA <>0
       CRITERE = 'MFGFCY = FCY & MFGSTA< WMFGSTA'
    Else
       CRITERE = 'MFGFCY = FCY'
    Endif
    If TIPODOCUM <> "" Then
       CRITERE += ' & YTIPDOC = TIPODOCUM'
    Endif

    START='MFGNUM'
    ORDRE ='MFGNUM'

    TIT(0)= mess(12, 123, 1)+mess(156,197,1)
    NBCOL = 0
    NBCOL +=1 : COL(NBCOL)="MFGNUM" : Call TEXTFIC("MFGHEAD" ,  COL(NBCOL), 1, TIT(NBCOL) ) From OBJDIV
    NBCOL +=1 : COL(NBCOL)="MFGFCY" : Call TEXTFIC("MFGHEAD" ,  COL(NBCOL), 1, TIT(NBCOL) ) From OBJDIV
    NBCOL +=1 : COL(NBCOL)="ROUNUM" : Call TEXTFIC("MFGHEAD" ,  COL(NBCOL), 1, TIT(NBCOL) ) From OBJDIV
    NBCOL +=1 : COL(NBCOL)="mess([F:MFG]MFGSTA,317,1)" : Call TEXTFIC("MFGHEAD" , "MFGSTA", 1,TIT(NBCOL) ) From OBJDIV
    NBCOL +=1 : COL(NBCOL)="STRDAT" : Call TEXTFIC("MFGHEAD" ,  COL(NBCOL), 1, TIT(NBCOL) ) From OBJDIV
    NBCOL +=1 : COL(NBCOL)="mess([F:MFG]MFGPIO,365,1)" : Call TEXTFIC("MFGHEAD" , "MFGPIO", 1,TIT(NBCOL) ) From OBJDIV
Return
######################################################################################
# Selección de Tarifa de Transporte
# Solo se puede utilizar desde la pantalla YPA0
######################################################################################
$SEL_TARIFATRANSPOC
    Local Char SENTENCIA(254)

    If clalev([F:YCP])=0  : Local File YCABPREU [YCP]  : Endif
    If clalev([F:YLR])=0  : Local File YLINPREU [YLR]  : Endif
    If clalev([F:AST1])=0 : Local File APLSTD   [AST1] : Endif
    If clalev([F:AST2])=0 : Local File APLSTD   [AST2] : Endif

    #Filtramos siempre por la planta y la fecha
    SENTENCIA = "FCY='" + [M:POC0]POHFCY + "' & DATA_INI <= [" + num$([M:POC2]XSTRDAT)  + "] & DATA_FI >= [" + num$([M:POC2]XENDDAT) + "]"

    If [M:YPA0]YPORTST<>"" Then
        SENTENCIA = SENTENCIA + " & GRUPTERCE='" + [M:YPA0]YPORTST + "'"
    Endif

    #Enlazamos
    If clalev([F:AXX1])=0 : Local File ATEXTRA [AXX1] Where CODFIC="ATABDIV" and ZONE="SHODES" and LANGUE="SPA" and IDENT1=num$(1013) : Endif
    If clalev([F:AXX2])=0 : Local File ATEXTRA [AXX2] Where CODFIC="ATABDIV" and ZONE="SHODES" and LANGUE="SPA" and IDENT1=num$(1013) : Endif

    Link [YLR] With [YCP]YCP0=CODITAULA,[AST1]CLE=num$(1981);YQTYTRA;"SPA",[AST2]CLE=num$(1995);TIPOCALC;"SPA",
&   [AXX1]AXX0="ATABDIV";"SHODES";"SPA";"1013";GRUPVEHICL,
&   [AXX2]AXX0="ATABDIV";"SHODES";"SPA";"1013";GRUPTERCE
&    As [YYY] Where [F:YCP]TCLASE=1 and [F:YCP]TACTIU=2


    Default File [YYY]

    #Existe más de 1 registro que cumple la condición
    CRITERE = SENTENCIA

    START   = "[F:YLR]CODITAULA"

    OBJET = "YLP"
Return
######################################################################################
$FIN_TARIFATRANSPOC
    Local Decimal IMPORTE

    If [F:YLR]CODITAULA = "" : Return : Endif ##--Salimos si no seleccionamos ningun registro --##

    [M:YPA0]YPTRAN = [F:YLR]PREU1
    VALEUR = [M:YPA0]YPTRAN

    Affzo [M:YPA0]YPTRAN
Return
######################################################################################
# Selección de Tipo de Documento - Forma de Pagament
# tipdoc -> PARAM(1)
######################################################################################
$SEL_TDFPAG
    If clalev([F:YIP])=0  : Local File YTIPDOT   [YIP] : Endif
    Local Char CODFIC    : CODFIC = "YTIPDOT"

    Filter [F:YIP] Where CODITIPDOC = PARAM(1) and CODITABLA = 6
    If rowcount([F:YIP])=0 Then
        #Mostrem totes les condicions de pago
        Filter [F:YIP]
        CRITERE(1) = "1=1"
        OBJET      = "TPT"
    Else
        #Mostrem les condicions del tipo document-forma de pago
        Filter [F:YIP]
        CRITERE = " [F:YIP]CODITIPDOC = PARAM(1) and CODITABLA = 6 "

        START   = "[F:YIP]CODI2"

        TIT(0) = mess(11,5000,1) + " - " + mess(24,5000,1) ####"TIPO de Documento - Condición Pago"
        NBCOL = 0
        NBCOL += 1 : COL(NBCOL) = "[F:YIP]CODITIPDOC" : Gosub YTEXTE #TIT(NBCOL)="Tipo Documento"
        NBCOL += 1 : COL(NBCOL) = "[F:YIP]CODI2"      : Gosub YTEXTE #TIT(NBCOL)="Condición Pago"
        NBCOL += 1 : COL(NBCOL) = "[F:YIP]DESCRIPCIO" : Gosub YTEXTE #TIT(NBCOL)="Descripción"

        Default File [YIP]
    Endif
Return
######################################################################################
$FIN_TDFPAG
    If (clalev([F:TPT])>0 and [F:TPT]PTE="") or (clalev([F:YIP])>0 and [F:YIP]CODI2 = "") : Return : Endif ##--Salimos si no seleccionamos ningun registro --##

    If clalev([F:TPT])>0 and [F:TPT]PTE<>"" Then
        If PARAM(2)="SDH" Then
            [M:SDH2]PTE=[F:TPT]PTE
        Else
            [M:SIH2]PTE=[F:TPT]PTE
        Endif
    Elsif clalev([F:YIP])>0 and [F:YIP]CODI2 <> "" Then
        If PARAM(2)="SDH" Then
            [M:SDH2]PTE=[F:YIP]CODI2
        Else
            [M:SIH2]PTE=[F:YIP]CODI2
        Endif
    Endif
    Affzo [M:SDH2]PTE
Return
######################################################################################
# Selección de Artículos-Planta
######################################################################################
$SEL_ITV
Local Char PLANTAEXP
    PLANTAEXP=""
    If GFONC1="GESSDH" Then
        PLANTAEXP = [M:SDH0]STOFCY
    Elsif GFONC1="GESSOH"
        PLANTAEXP = [M:SOH2]STOFCY
    Elsif GFONC1="GESPTH"
        PLANTAEXP = [M:PTH1]PRHFCY
    Elsif GFONC1="GESYCV"
        PLANTAEXP = [M:YCV0]FCY
    Elsif GFONC1="GESYNI"
        PLANTAEXP = [M:YNI0]STOFCY
    Endif

    ORDRE = 'ITMREF'
    START = 'ITMREF'

    CRITERE(1) = ' ITMREF >= "' + VALEUR + '"'
    If PLANTAEXP<>"" Then : CRITERE(1) = CRITERE(1) + " and STOFCY = PLANTAEXP" : Endif
    OPTIONS = ""
    OBJET = "ITF"
Return
######################################################################################
# Fin de Selección de Artículos-Planta
######################################################################################
$FIN_ITV
    If clalev([F:ITF])<=0 or (clalev([F:ITF])>0 and [F:ITF]ITMREF="" or [F:ITF]STOFCY = "") : Return : Endif ##--Salimos si no seleccionamos ningun registro --##

    VALEUR = [F:ITF]ITMREF
Return
######################################################################################
$SEL_MFG
    If clalev ([F:ATZ])=0 : Local File ATABZON    : Endif
    If clalev ([F:MFG])=0 : Local File MFGHEAD    : Endif

    Local Integer WMFGSTA : WMFGSTA = val(PARAM(1))
    Local Char CODFIC     : CODFIC = "MFGHEAD"
    Default File [MFG]

    If WMFGSTA <>0
       CRITERE = 'MFGSTA< WMFGSTA'
    Else
       Raz CRITERE
    Endif

    SIZLIG = 120  ###--Modificar altura (80 por defecto)
    SIZCOL = 300  ###--Modificar ancho (240 por defecto)


    START='MFGNUM'
    ORDRE ='MFGNUM'

    TIT(0)= mess(12, 123, 1)+mess(156,197,1)
    NBCOL = 0
    NBCOL +=1 : COL(NBCOL)="MFGNUM" : Gosub YTEXTE
    NBCOL +=1 : COL(NBCOL)="MFGFCY" : Gosub YTEXTE
    NBCOL +=1 : COL(NBCOL)="ROUNUM" : Gosub YTEXTE
    NBCOL +=1 : COL(NBCOL)="mess([F:MFG]MFGSTA,317,1)" : Call TEXTFIC(CODFIC , "MFGSTA", 1,TIT(NBCOL) ) From OBJDIV
    NBCOL +=1 : COL(NBCOL)="STRDAT" : Gosub YTEXTE
    NBCOL +=1 : COL(NBCOL)="mess([F:MFG]MFGPIO,365,1)" : Call TEXTFIC(CODFIC , "MFGPIO", 1,TIT(NBCOL) ) From OBJDIV
    NBCOL +=1 : COL(NBCOL)="YREFGEN" : Gosub YTEXTE
Return
######################################################################################
$YTEXTE
    Call TEXTFIC(CODFIC ,  COL(NBCOL), 1, TIT(NBCOL) ) From OBJDIV
Return
######################################################################################
$FIN_YSELADDENT

    If clalev([F:BPA])=0 : Local File BPADDRESS   [BPA] : Endif

    ###--- Función que actualiza el camp de dirección en pedidos de venta ---###
    ###--- JGM - 13/12/2010 -------------------------------------------------###
    If [F:BPA2]BPAADD = "" : Return : Endif
    If GABREV = "SOH"
        # --> Si modif client raz adresse avant de passer dans le bouton adresse
        If !GIMPORT & VALEUR <> [M:SOH1]BPAADD Raz [M:ADB2] : Endif

        # --> Alimentation de la raison sociale
        If [M:ADB2]BPRNAM(0) <> ""
            [M:SOH1]BPDNAM = [M:ADB2]BPRNAM(0)
        Else
            [M:SOH1]BPDNAM = [F:BPD]BPDNAM(0)
        Endif
        Affzo [M:SOH1]BPDNAM

        Call C_BPAADD(VALEUR) From W1SOH1
        Call AM_BPAADD(VALEUR) From W1SOH1 #SUBSOH
        [M:SOH1]BPAADD = VALEUR
        VALEUR = [M]BPCORD
        Affzo [M:SOH1]BPAADD
    Endif
    ###----------------------------------------------------------------------###

    If GABREV = "YV1"
        Call AM_DIRECCION(VALEUR) From SPVYV1
    Endif

    If GABREV = "SRH"
       Call AM_BPAADD(VALEUR) From SUBSRH
    Endif

    Read [BPA]BPA0 = [F:BPA2]BPATYP;[F:BPA2]BPANUM;[F:BPA2]BPAADD
    If fstat : Raz [BPA] : Endif
Return
######################################################################################
$SEL_POH
    If clalev([F:POH])=0 : Local File PORDER [POH] : Endif
    If clalev([F:POQ])=0 : Local File PORDERQ [POQ] : Endif
    Link [POQ] With [POH]POH0=POHNUM As [XXX]

    CRITERE(1) = PARAM(1)

    START   = "[F:POH]POHNUM"
    TIT(0) = mess(32,5000,1) ##"Pedidos de Compra"
    NBCOL = 0

    NBCOL += 1 : COL(NBCOL) = "mess([F:POH]POHTYP,506,1)"    : Call TEXTFIC("PORDER","POHTYP",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Tipo Pedido"
    NBCOL += 1 : COL(NBCOL) = "[F:POQ]PRHFCY"                : Call TEXTFIC("PORDERQ","PRHFCY",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Planta recepción"
    NBCOL += 1 : COL(NBCOL) = "[F:POQ]POHNUM"                : Call TEXTFIC("PORDERQ","POHNUM",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Nº Documento"
    NBCOL += 1 : COL(NBCOL) = "[F:POQ]POPLIN"                : Call TEXTFIC("PORDERQ","POPLIN",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Linea"
    NBCOL += 1 : COL(NBCOL) = "[F:POQ]ITMREF"                : Call TEXTFIC("PORDERQ","ITMREF",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Articulo"
    NBCOL += 1 : COL(NBCOL) = "[F:POH]BPSNUM"                : Call TEXTFIC("PORDER","BPSNUM",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Proveedor"
    NBCOL += 1 : COL(NBCOL) = "[F:POH]ORDDAT"                : Call TEXTFIC("PORDER","ORDDAT",1,TIT(NBCOL)) From OBJDIV #TIT(NBCOL)="Fecha"
    Default File [XXX]
Return
######################################################################################
$FIN_POH
    If GABREV = "YDV"
        Local    Integer NOL        : NOL = nolign-1

        [M:YCV1]POHNUM(NOL) = [F:POQ]POHNUM
        [M:YCV1]POPLIN(NOL) = [F:POQ]POPLIN
        [M:YCV1]POQSEQ(NOL) = [F:POQ]POQSEQ

        Affzo [M:YCV1]POHNUM(NOL)
        Affzo [M:YCV1]POPLIN(NOL)
        Affzo [M:YCV1]POQSEQ(NOL)
    Endif
Return
######################################################################################
Subprog BUSQUEDA_CALIBRE(COD1,COD2,COD3,CLASE,ESTAT)
    Variable  Char     COD1
    Variable  Char     COD2
    Variable  Char     COD3
    Value     Integer  CLASE
    Variable  Integer  ESTAT     : ESTAT = 1
    Local     Integer  SALIR_FOR : SALIR_FOR = 1

    If clalev([F:YCL2])=0 : Local File YCLASIFIC [YCL2] : Endif
    If clalev([F:YCC2])=0 : Local File YCLASTAD  [YCC2] : Endif

    Local    Char    XCOD1
    Local    Char    XCOD2
    Local    Char    XCOD3

    For NUM = 1 To 4
        Case NUM
            When 1
               XCOD1 = COD1
               XCOD2 = COD2
               XCOD3 = COD3
            When 2
               XCOD1 = COD1
               XCOD2 = COD2
               XCOD3 = ""
            When 3
               XCOD1 = COD1
               XCOD2 = ""
               XCOD3 = ""
            When 4
               XCOD1 = COD1
               XCOD2 = ""
               XCOD3 = COD3
        Endcase

        For [YCC2] Where TACTIU=2 and CODI1=XCOD1 and CODI2=XCOD2 and CODI3=XCOD3
            Read [YCL2]YCL0 = [F:YCC2]CODCALIBRE
            If fstat or [F:YCL2]CLACALIBRE = CLASE
                Raz [YCL2]
                ESTAT = 1
            Else
                ESTAT = 0
                SALIR_FOR = 2
                Break
            Endif
        Next
        If SALIR_FOR = 2 : Break : Endif
    Next

    COD1 = XCOD1
    COD2 = XCOD2
    COD3 = XCOD3
End
######################################################################################
Subprog BUSQUEDA_CALIDAD(COD1,COD2,COD3,CLASE,ESTAT)
    Variable  Char     COD1
    Variable  Char     COD2
    Variable  Char     COD3
    Value     Integer  CLASE
    Variable  Integer  ESTAT     : ESTAT = 1
    Local     Integer  SALIR_FOR : SALIR_FOR = 1
    Local     Integer  NUM

    If clalev([F:YCS2])=0 : Local File YCALSTAD  [YCS2] : Endif
    If clalev([F:YCA2])=0 : Local File YCALIDAD  [YCA2] : Endif

    Local    Char    XCOD1
    Local    Char    XCOD2
    Local    Char    XCOD3

    For NUM = 1 To 4
        Case NUM
            When 1
               XCOD1 = COD1
               XCOD2 = COD2
               XCOD3 = COD3
            When 2
               XCOD1 = COD1
               XCOD2 = COD2
               XCOD3 = ""
            When 3
               XCOD1 = COD1
               XCOD2 = ""
               XCOD3 = ""
            When 4
               XCOD1 = COD1
               XCOD2 = ""
               XCOD3 = COD3
        Endcase

        For [YCS2] Where TACTIU=2 and CODI1=XCOD1 and CODI2=XCOD2 and CODI3=XCOD3
            Read [YCA2]YCA0 = [F:YCS2]CODCALIDAD
            If fstat or [F:YCA2]CLASECALID = CLASE
                Raz [YCA2]
                ESTAT = 1
            Else
                ESTAT = 0
                SALIR_FOR = 2
                Break
            Endif
        Next
        If SALIR_FOR = 2 : Break : Endif
    Next

    COD1 = XCOD1
    COD2 = XCOD2
    COD3 = XCOD3
End
######################################################################################
$SEL_YITMFCY
    If PARAM(1)="" : PARAM(1)="1=1" : Endif
    CRITERE(1) = PARAM(1)
    OPTIONS    = PARAM(2)
    OBJET      = "ITF"
Return
######################################################################################
$FIN_YITMFCY
    If clalev([F:ITF])<=0 or (clalev([F:ITF])>0 and [F:ITF]ITMREF="" or [F:ITF]STOFCY = "") : Return : Endif ##--Salimos si no seleccionamos ningun registro --##

    VALEUR = [F:ITF]ITMREF
Return
######################################################################################
$SEL_DOC_CAR
    If clalev([F:XV5])=0 : Local File YAVCABCAR [XV5] Order By Key CLE=DATA : Endif
    Local Char CODFIC    : CODFIC = "YAVCABCAR"

    START   = "[F:XV5]YDOCREL"
    TIT(0) = mess(13,5000,1)##"Documentos"
    NBCOL = 0
    NBCOL += 1 : COL(NBCOL) = "[F:XV5]YDOCREL"    : Gosub YTEXTE #TIT(NBCOL) = "Nº. Doc."
    NBCOL += 1 : COL(NBCOL) = "[F:XV5]CODIPERSON" : Gosub YTEXTE #TIT(NBCOL) = "Tercero"
    NBCOL += 1 : COL(NBCOL) = "[F:XV5]FCY"        : Gosub YTEXTE #TIT(NBCOL) = "Planta"
    NBCOL += 1 : COL(NBCOL) = "[F:XV5]DATA"       : Gosub YTEXTE #TIT(NBCOL) = "Fecha"


    Default File [XV5]
Return
######################################################################################

