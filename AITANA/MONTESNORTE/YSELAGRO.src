#<AdxTL>@(#)0.0.0.0 $Revision$
#<AdxTL>@(#)9.0.0.0 $Revision$
$ACTION
    If dim(XGPE)<0 Then : Global Integer XGPE : Endif
    If dim(XGPOINT)<0 Then : Global Char XGPOINT(40) : Endif

    #Cridem a un punt d'entrada per si es vol afegir o canviar el comportament
    Raz XGPE : XGPOINT = GPOINT : GPOINT = "Y" + ACTION
    Gosub ENTREE From EXEFNC
    GPOINT = XGPOINT : If XGPE=1 Then : Return : Endif

    Case ACTION
        When "SEL_TABLE"      : Gosub SEL_TABLE
        When "VERF_TABLE"     : Gosub VERF_TABLE
        When "FIN_TABLE"      : Gosub FIN_TABLE
        When "SEL_LISTE"      : Gosub SEL_LISTE
    Endcase
Return
########################################################################
$SEL_TABLE
    Case GACTION
        When "YSELFIN"        : Gosub SEL_FIN
        When "YSELDOCUM"      : Gosub SEL_DOCUM
        When "YSELCLA"        : Gosub SEL_CLA
        When "YSELCAL"        : Gosub SEL_CAL
        When "YSELCAF"        : Gosub SEL_CAF
        When "YSELTIPO"       : Gosub SEL_TIPO
        When "YSELTRANS"      : Gosub SEL_TRANS
        When "YSELTRANS1"     : Gosub SEL_TRANS
        When "YSELLIQ"        : Gosub SEL_LIQ
        When "YSELTIPDOC"     : Gosub SEL_TIPDOC
        When "YSELTDOC"       : Gosub SEL_TIPDOC2
        When "YSELTDTRAN"     : Gosub SEL_TDTRAN
        When "YSELFCY"        : Gosub SEL_FCY
        When "YSELPREC"       : Gosub SEL_PREC
        When "YSELTRAZA"      : Gosub SEL_TRAZA
        When "YSELCONF"       : Gosub SEL_CONF
        When "YSELPES"        : Gosub SEL_PES
        When "YSELDOCCLA"     : Gosub SEL_DOCCLA
        When "YSELARTDES"     : Gosub SEL_ART_DES
        When "YSELBPS"        : Gosub SEL_BPS
        When "YSELBPR"        : Gosub SEL_BPR
        When "YSELBPC"        : Gosub SEL_BPC
        When "YSBPRTIPO"      : Gosub SEL_BPR_TIPO
        When "YSELPESVEN"     : Gosub SEL_PES_VEN
        When "YSELADDENT"     : Gosub SEL_ADD_ENTREGA
        When "YSELADD"        : Gosub SEL_ADD_ENT
        When "YSELADDBPS"     : Gosub SEL_ADD_BPS
        When "YSELBUSART"     : Gosub SEL_BUSART
        When "YSELALTEST"     : Gosub SEL_ALTEST
        When "YSELTPROD"      : Gosub SEL_TPROD
        When "YENTENV"        : Gosub ENT_ENV
        When "YCODITABLA"     : Gosub ENT_CODITABLA
        When "YSELCAMPO"      : Gosub ENT_SELCAMPO
        When "YSELOBJETO"     : Gosub ENT_SELOBJETO
        When "YSELMFI"        : Gosub SEL_MFI
        When "YSELENVASE"     : Gosub SEL_ENVASE
        When "YSELYV6"        : Gosub SEL_YV6
        When "YSELADI"        : Gosub SEL_ADI
        When "YSELOFERTA"     : Gosub SEL_OFERTA
        When "YSELDOCREL"     : Gosub SEL_DOCREL
        When "YSELNUMDOC"     : Gosub SEL_NUMDOC
        When "YSELBUSPTH"     : Gosub SEL_BUSPTH
        When "YSELGRUPO"      : Gosub ENT_SELGRUPO
        When "YSELTERCER"     : Gosub SEL_TERCERO
        When "YSELTARTRA"     : Gosub SEL_TARIFATRANS
        When "YSELTARDES"     : Gosub SEL_TARIFADESC
        When "YSELDOC"        : Gosub SEL_DOC
        When "YSELBPT"        : Gosub SEL_BPT
        When "YSELTARYCI"     : Gosub SEL_TARIFATRANSYCI
        When "YSELTARYV1"     : Gosub SEL_TARIFATRANSYV1
        When "YSELPEDIDO"     : Gosub SEL_PEDIDO
        When "YSELPLANTI"     : Gosub SEL_PLANTILLA
        When "YSELMFGNUM"     : Gosub SEL_MFGNUM
        When "YSELTARPOC"     : Gosub SEL_TARIFATRANSPOC
        When "YSELTDFPAG"     : Gosub SEL_TDFPAG
        When "YSELITV"        : Gosub SEL_ITV
        When "YSELMFG"        : Gosub SEL_MFG
        When "YSELPOH"        : Gosub SEL_POH
        When "YSELITMFCY"     : Gosub SEL_YITMFCY
        When "YSELDOCCAR"     : Gosub SEL_DOC_CAR
        When "YSELPTH"        : Gosub SEL_PTH
    Endcase
Return
########################################################################
$FIN_TABLE
    Case GACTION
        When "YSELDOCUM"      : Gosub FIN_DOCUM
        When "YSELALTEST"     : Gosub FIN_ALTEST
        When "YSELTRAZA"      : Gosub FIN_TRAZA
        When "YSELTARTRA"     : Gosub FIN_TARIFATRANS
        When "YSELTARDES"     : Gosub FIN_TARIFADESC
        When "YSELTARYCI"     : Gosub FIN_TARIFATRANSYCI
        When "YSELTARYV1"     : Gosub FIN_TARIFATRANSYV1
        When "YSELTARPOC"     : Gosub FIN_TARIFATRANSPOC
        When "YSELTDFPAG"     : Gosub FIN_TDFPAG
        When "YSELITV"        : Gosub FIN_ITV
        When "YSELADDENT"     : Gosub FIN_YSELADDENT
        When "YSELITMFCY"     : Gosub FIN_YITMFCY
        When "YSELPOH"        : Gosub FIN_POH
    Endcase
Return
########################################################################
$VERF_TABLE
    Case GACTION
        When "YSELARTDES"     : Gosub VERF_ART_DES
    Endcase
Return
########################################################################
$SEL_LISTE
    Case GACTION
        When "YSELEXE"        Gosub SEL_EXE
    Endcase
Return
########################################################################
#$VERF_NORD
#Código para comprovar si existe el registro en la tabla donde queremos acceder
#    If clalev([F:YC1])=0 : Local File YACCABCAL [YC1] : Endif
