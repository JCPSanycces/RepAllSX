### COPIADO DE ARITMOAGRO PARA DEBUGGER                                            ###
######################################################################################
$ACTION
#    Dbgaff
#Infbox "SPEYCQ: " + ACTION + " "  + GUSER
    Gosub ACTION From YARYCQ
Return
######################################################################################
Subprog C_TIPDOC(VALEUR)
    Variable Char    VALEUR()
    Read [YTD]YTD0=VALEUR
    If (fstat=0 and ([F:YTD]CLASEDOCUM<>14 & [F:YTD]CLASEDOCUM<>15) or [F:YTD]TIPOCLASE <> 1
& or [F:YTD]TIPOFCY <> [M:YCQ]YTIPOFCY)
        GERR=2
        GMESSAGE=mess(1,1986,1)
        GOK=0
        mkstat = 2
    Else
        [M:YCQ]CLASEDOC = [F:YTD]CLASEDOCUM
        If [F:YTD]CLASEDOCUM = 15
            [M:YCQ]RESTANT = 1
            [M:YCQ]TANT = 1
            Grizo [M:YCQ]TANT
        Endif
        If [F:YTD]CLASEDOCUM = 14
            [M:YCQ]RESTANT = 2
            [M:YCQ]TANT = 1
            Actzo [M:YCQ]TANT
        Endif

        Affzo [M:YCQ]RESTANT
        Affzo [M:YCQ]TANT

        Call OMPLIR_TIPDOC([F:YTD]CLASEDOCUM) From YARYCQ
    Endif
End
######################################################################################
Subprog AM_DATAFI(VALEUR)
    Variable Date    VALEUR
    If [M:YCQ]DATAINI > VALEUR
        GERR=2
        GMESSAGE = mess(99,177,1)
        GOK=0
        mkstat = 2
    Endif
End
######################################################################################
Subprog AM_FCY(VALEUR)
    Variable Char    VALEUR()
    Read [FCY]FCY0 = VALEUR
    If fstat
        Raz [F:FCY]
        ERROR = 1
        End
    Endif
    [M:YCQ]YTIPOFCY = [F:FCY]YTIPOFCY
End
######################################################################################
Subprog C_MULTIFCY(VALEUR)
    Variable Integer VALEUR
    If VALEUR = 1
        Grizo [M:YCQ]TIPOFCY
        Raz [M:YCQ]TIPOFCY
        Actzo [M:YCQ]FCY
    Else
        Grizo [M:YCQ]FCY
        Raz [M:YCQ]FCY
        Actzo [M:YCQ]TIPOFCY
    Endif
End
######################################################################################
Subprog C_TIPOFCY(VALEUR)
    Variable Integer VALEUR
    If [M:YCQ]MULTIFCY = 2 : [M:YCQ]YTIPOFCY = VALEUR : Endif
End
######################################################################################
Subprog C_TIPD(VALEUR)
    Variable Char    VALEUR()

    If VALEUR = ""
        Raz  [M:YCQ]TIPH
        Grizo [M:YCQ]TIPH
    Else
        Actzo [M:YCQ]TIPH
    Endif
End
######################################################################################
Subprog C_TIPH(VALEUR)
    Variable Char    VALEUR()
    If [M:YCQ]TIPD <> "" and VALEUR = ""
        GERR = 1
        GMESSAGE = mess(10,123,1)
        mkstat = 2
    Endif
End
######################################################################################
Subprog C_YMODALITD(VALEUR)
    Variable Char    VALEUR()
    If VALEUR = ""
        Raz  [M:YCQ]YMODALITH
        Grizo [M:YCQ]YMODALITH
    Else
        Actzo [M:YCQ]YMODALITH
    Endif
End
######################################################################################
Subprog C_YMODALITH(VALEUR)
    Variable Char    VALEUR()
    If [M:YCQ]YMODALITD <> "" and VALEUR = ""
        GERR = 1
        GMESSAGE = mess(10,123,1)
        mkstat = 2
    Endif
End
######################################################################################
Subprog C_YTIPLIQD(VALEUR)
    Variable Char    VALEUR()
    If VALEUR = ""
        Raz  [M:YCQ]YTIPLIQH
        Grizo [M:YCQ]YTIPLIQH
    Else
        Actzo [M:YCQ]YTIPLIQH
    Endif
End
######################################################################################
Subprog C_YTIPLIQH(VALEUR)
    Variable Char    VALEUR()
    If [M:YCQ]YTIPLIQD <> "" and VALEUR = ""
