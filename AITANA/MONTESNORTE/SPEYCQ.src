######################################################################################
Subprog AM_RESTANT(VALEUR)
    Variable Integer VALEU

    [M:YCQ]RESTANT = VALEUR
    Affzo [M:YCQ]RESTANT

    #Call OMPLIR_TIPDOC([M:YCQ]CLASEDOC) From YARYCQ
End
######################################################################################
Subprog C_YTIPDOC(VALEUR)
    Variable Char    VALEUR()

    Read [YTD]YTD0=VALEUR
    If (fstat=0 and ([F:YTD]CLASEDOCUM<>34 or [F:YTD]TIPOCLASE <> 1))
        GERR=2
        GMESSAGE=mess(1,1986,1)
        GOK=0
        mkstat = 2
    Endif
End
######################################################################################
Subprog C_NUMDOC(VALEUR)
    Variable Char    VALEUR()
    If clalev([F:YT0])=0 : Local File YTPCABEC   [YT0] : Endif
    Read [YT0]YT00=VALEUR
    If fstat
        GERR=2
        GMESSAGE=mess(74,1986,1)
        GOK=0
        mkstat = 2
    Endif
End
######################################################################################
Subprog AM_NUMDOC(VALEUR)
    Variable Char    VALEUR()
    Local Integer NUM,I
#Infbox "SPQYCQ - AM_NUMDOC " + GUSER + " " + VALEUR
    If clalev([F:YT0])=0 : Local File YTPCABEC   [YT0] : Endif

    Read [YT0]YT00 = VALEUR : If fstat Raz [F:YT0] : End : Endif
    If [YT0]ANTILIQ = 1 Then
      #entrega a cuenta

      [M:YCQ]PIVTYP="ELQ"
      [M:YCQ]RESTANT=1
      [M:YCQ]TRECEP=2
    Else

      [M:YCQ]PIVTYP="FLQ"
      [M:YCQ]RESTANT=2
      [M:YCQ]TRECEP=1
    Endif

    [M:YCQ]PTE="TLQ"
    Affzo [M:YCQ]PIVTYP
    Affzo [M:YCQ]PTE
    Affzo [M:YCQ]RESTANT
    Affzo [M:YCQ]TRECEP
#v11.bo
#    For I=0 To [M]NBINV-1
#        Dela I,1,[M]NBINV-1 [M]NBINV
#        [M]NBINV-=1
#    Next
#
#    NUM=0
#    For I=0 To 14
#        If [F:YT0]INVDTA(I) = 0 : Break : Endif
#        [M:YCQ]INVDTA(NUM) = [F:YT0]INVDTA(I)
#        NUM += 1
#    Next
#
#    [M:YCQ]NBINV = NUM
#
#    Affzo [M:YCQ]25
#v11.eo
End
######################################################################################
Subprog AM_TPLANTA(VALEUR)
    Variable Integer VALEUR
    If VALEUR = 2
        [M:YCQ]TRECEP = 1
        Affzo [M:YCQ]TRECEP
    Endif
End
######################################################################################
Subprog AM_TRECEP(VALEUR)
    Variable Integer VALEUR
    If VALEUR = 2
        [M:YCQ]TPLANTA = 1
        Affzo [M:YCQ]TPLANTA
    Endif
End
######################################################################################
######################################################################################
Subprog ZYCQ()
  #xvt 11-05-202 - no está funcionando la llamada a OK
  #es un poltergheist, porque en ARARNQUE y en TEST no pasa
  #añadimos este subprograma para ser llamado por la acción ZYCQ
  #en sustitución del OK estándar.
 # Infbox "SPEYCQ - SUBPROG ZYCQ "
  Gosub OUVRE From YARYCQ
  Gosub OK From YARYCQ
 # Infbox "SPEYCQ - SUBPROG ZYCQ END"
End







