#<AdxTL>@(#)0.0.0.0 $Revision$

Funprog SELITSSTOCK(PITMREF)
Value Char PITMREF
Local Decimal VSTOC : VSTOC=0
Local Char VSTOFCY : VSTOFCY=""

If clalev([M:SIH1]) Then
  VSTOFCY=[M:SIH1]STOFCY
Elsif clalev([M:SDH0]) Then
  VSTOFCY=[M:SDH0]STOFCY
Endif

If VSTOFCY<>"" Then
  If !clalev ([F:ZSTK]) : Local File STOCK [ZSTK] : Endif
  Filter [F:ZSTK] Where ITMREF=PITMREF and STOFCY=VSTOFCY
  For [F:ZSTK]
    VSTOC += [F:ZSTK]QTYSTU
  Next
  Filter [F:ZSTK]
  End num$(VSTOC)
Else
  End "0"
Endif

End


Funprog SELITSPVP(PITMREF)
Value Char PITMREF

  If !clalev([F:SPL]) : Local File SPRICLIST [SPL] : Endif
  Filter [SPL] Where [SPL]PLI='TPVP' and [SPL]PLICRI1=PITMREF and [SPL]PLISTRDAT<=date$ and [SPL]PLIENDDAT > date$
  Read [SPL] First
  If !fstat Then
    End [SPL]PRI
  Else
    End 0
  Endif
  Filter [SPL]

End

# func ZTRTVENSEL.SELITSSTOCK(PITMREF)

