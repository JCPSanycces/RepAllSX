#<AdxTL>@(#)0.0.0.0 $Revision$ 
######################################################################################
### ZNOMINA -- Fichero para importación asientos contable nóminas LOGIC CONTROL
######################################################################################
### MANEL 14.02.14 ###
### CBG 23.10.20 - Se ha creado en Sage X3 el volumen NOMINAS
### Elena debe escoger el fichero desde este volumen (por lo que vimos estara en \NOMINAS\MONTES\2020
### En la subcarpeta OK se generara un fichero con el numero de Asiento

$ACTION
    Case ACTION
        When "OUVRE"             : Gosub OUVRE
        When "DEBUT"             : Gosub DEBUT
        When "OK"                : Gosub OK
        When "FIN"               : Gosub FIN
        When Default
   Endcase
Return
######################################################################################
$OUVRE
    Global Integer GERROR
    GERROR = 0

    Global Char CSEP(1)
    CSEP = '|'                 # Separador de campos del fichero txt a generar

    Global Char RUTA(GDIMFIC)
    Global Char RFICHERODESTINO(250)
    Global Char NFICHERODESTINO(250)
    Global Char FICHERODESTINO(GDIMFIC)

    adxium = 50                # Variable X3 que indica que el fichero a importar es ascii
    adxirs = chr$(13)+chr$(10) # Variable X3 que indica el separador de registro del fichero txt a generar

    If clalev ([F:CPY])=0 : Local File COMPANY [CPY] : Endif
    If clalev ([F:FCY])=0 : Local File FACILITY [FCY] : Endif
    If clalev ([F:GCM])=0 : Local File GACM [GCM] : Endif
    If clalev ([F:GLED])=0 : Local File GLED [LED] : Endif
    If clalev ([F:GCOA])=0 : Local File GCOA [COA1] : Endif

    If clalev ([F:APX])=0 : Local File APARIMPEXP [APX] : Endif

    If clalev ([F:BPR])=0 : Local File BPARTNER [BPR] : Endif
    If clalev ([F:GAC])=0 : Local File GACCOUNT [GAC] : Endif
    If clalev ([F:CCE])=0 : Local File CACCE [CCE] : Endif

    Read [APX]APX0 = 'REPIMPDEF'

    #RUTA = [F:APX]DIRECTORY
    RUTA = "[NOMINAS]"
    #Infbox "Ruta es " + RUTA
    If right$(RUTA,len(RUTA))<>"\": RUTA = RUTA + "\": Endif
Return
######################################################################################
$DEBUT
    #[M:DIA]NOMIMP = RUTA+"NOMINAS\NOM_CLASS_????????.txt"
    [M:DIA]NOMIMP = RUTA+"\NOM_CLASS_????????.txt"
    Affzo [M:DIA]NOMIMP
Return
######################################################################################
$OK
    Gosub CONTROL_LEC
    If GERROR <> 0: Return: Endif

    Call OUVRE_TRACE("Importación asientos nómina") From LECFIC
    Call ECR_TRACE(" ",0) From GESECRAN
    Call ECR_TRACE(string$(88,"-"),0) From GESECRAN
    #Call PRTSCR("ZNOMINA","DIA","",0,1) From ATRTX3   # --- Traza de los parametros
    Call ECR_TRACE(" ",0) From GESECRAN

    Call TEMPON("E") From GESECRAN

    GMESSAGE=""
    Call TRATAR_FICHERO

    #Llamada al modelo de importación
    Call IMPSILEN ("ZNOMINAS",FICHERODESTINO)

    Call TEMPOFF From GESECRAN

    Call FERME_TRACE From LECFIC
    Call LEC_TRACE From LECFIC
Return
#############################################################
$CONTROL_LEC
    Local Integer X, WINI, STAT, ZFIN, TRA
    Local Char WFICHERO(GDIMFIC), URL(GDIMFIC)
    Local Char FICHEROORIGEN : FICHEROORIGEN = ""
    Local Char FICHEROPROCESAR(250) : FICHEROPROCESAR = ""

    If [M:DIA]TYPEXP=1 : # Client
        [M:DIA]NOMIMP=""
        Call SET_FICNAM([M:DIA]NOMIMP,[M:DIA]FICDON,URL) From ORDSYS
        Call COPSRV([M:DIA]NOMIMP,[M:DIA]FICDON,STAT) From ORDSYS
        If STAT=1
            # Fichier non copié sur le poste client
            Call ERREUR(mess(164,141,1)) From GESECRAN
            ZFIN = 1 : TRA = 0 : Return
        Elsif STAT>1
            # Fichier inexistant
            Call ERREUR(mess(101,100,1)-"("+num$(STAT)+")") From GESECRAN
            ZFIN = 1 : TRA = 0 : Return
        Endif
    Else
         [M:DIA]FICDON = [M:DIA]NOMIMP
         FICHEROORIGEN = mid$([M:DIA]NOMIMP,10,len([M:DIA]NOMIMP))
         #Infbox "FICHEROORIGEN ES " + FICHEROORIGEN

         WINI=1
         For X=1 To len(FICHEROORIGEN)
          If find(mid$(FICHEROORIGEN,X,1),"/","\")
            WINI=X+1
          Endif
         Next X

         FICHEROPROCESAR = "\\SQL\IMPORTEXPORT\NOMINAS" + FICHEROORIGEN
         #Infbox "FICHEROPRCOESAR ES " + FICHEROPROCESAR
    Endif

    WFICHERO=left$([M:DIA]NOMIMP,len([M:DIA]NOMIMP))

    WINI=1
    For X=1 To len(FICHEROPROCESAR)
        If find(mid$(WFICHERO,X,1),"\","/")
            WINI=X+1
        Endif
    Next X

    WFICHERO=mid$(WFICHERO,WINI,len(WFICHERO))

    #Infbox "WFICHERO ES " + WFICHERO
    #Infbox "M:DIA-FICDON ES " + [M:DIA]FICDON
    RFICHERODESTINO = mid$(FICHEROPROCESAR, 1,len(FICHEROPROCESAR) - len(WFICHERO))
    NFICHERODESTINO = WFICHERO
    #Infbox "El fichero destino sera " + NFICHERODESTINO
    #La ruta donde esta el fichero es \\SQL\IMPORTEXPORT\NOMINAS\MONTES
    #If filinfo([M:DIA]FICDON,7) >= 0
    #    Openi [M:DIA]FICDON Using [LEC]
    If filinfo(FICHEROPROCESAR,7) >= 0
        Openi FICHEROPROCESAR Using [LEC]
    Else
       Call ECR_TRACE("Fichero"-WFICHERO-"inexistente!!",1) From GESECRAN
       GERROR=-1
       Return
    Endif

Return

######################################################################################
$FIN
    Close File [CPY]
    Close File [FCY]
    Close File [GCM]
    Close File [LED]
    Close File [COA1]
    Close File [APX]
    Close File [GAC]
    Close File [BPR]
    If GERROR = 0: Openi Using [LEC]: Endif

    Kill GERROR
    Kill CSEP
    Kill RUTA
    Kill FICHERODESTINO
Return

######################################################################################
### Funcion que lee el fichero origen y crea el fichero para la importación
######################################################################################
Subprog TRATAR_FICHERO
    Local Char SENTENCIA(255), RDSSTA(2)
    Local Char CUR_TIPOLIN(1), ANT_TIPOLIN(1)

    Local Char COA1(3), COA2(3)
    Local Char FCY(5), ACCDAT(8), DES(30), SNS(2), REF(20)
    Local Char MES(2)
    Local Char ACC(10), ANTACC(10), BPR(20), BPRCUR(20), DESLIN(30), AMTCUR(20)
    Local Char CCE(20)(4), DSP

    Local Integer LIN, I

    # Abre el fichero como escritura
    #FICHERODESTINO = filpath(RUTA,"NOMINA_"+num$(adxuid(1)),"txt")
    #FICHERODESTINO = filpath("\\Sql\importexport\NOMINAS\MONTES\2020\OK","NOMINA_"+num$(adxuid(1)),"txt")
    FICHERODESTINO = filpath(RFICHERODESTINO + "OK","NOMINA_"+num$(adxuid(1)),"txt")
    #Infbox "El fichero destino es " + FICHERODESTINO
    Openo FICHERODESTINO,0 Using [ESC]
    #Infbox "Aqui llego"

    LIN=0
    ANT_TIPOLIN=""

    While 1=1
        Rdseq SENTENCIA,RDSSTA Using [LEC]
        If fstat<>0 Then: Break: Endif

        CUR_TIPOLIN=left$(SENTENCIA,1)
   # Infbox (SENTENCIA+"  T: "+CUR_TIPOLIN+"  A: "+ANT_TIPOLIN)

        If CUR_TIPOLIN="G" Then      # ----------------- CABECERA ASIENTO -----------------------------
#            FCY = vireblc(mid$(SENTENCIA,20,3),2)    #196387.o 5 DÍGITOS EN PLANTA
            FCY = vireblc(mid$(SENTENCIA,20,5),2)    #196387.n 5 DÍGITOS EN PLANTA
            Read [FCY]FCY0=FCY
            If fstat<>0 Then
                GERR=1
                Call ECR_TRACE("PLANTA FINANCIERA"-FCY-"INEXISTENTE" ,1) From GESECRAN
                GERROR += 1
                Break
            Endif

            Read [CPY]CPY0=[F:FCY]LEGCPY
            If fstat<>0 Then
                Call ECR_TRACE("SOCIEDAD"-[F:FCY]LEGCPY-"INEXISTENTE EN X3",1) From GESECRAN
                GERROR += 1
            Endif

            # OBTENER MODELO COMPTABLE DE LA SOCIEDAD ----
            Read [GCM]GCM0=[F:CPY]ACM

            # OBTENER PLANES DE CUENTAS DE LOS REFERENCIALES SOCIAL Y ANALÍTICO S/MODELO COMPTABLE ---
            # EL SOCIAL:
            Read [LED]LED0=[F:GCM]LED([F:GCM]GENLEDTYP-1)
            COA1=[F:LED]COA

            # OBTENER PLAN DE CUENTAS SOCIAL (LONGITUD CUENTAS)
            Read [COA1]COA0=COA1

            # EL ANALITICO, SI EXISTE:
            If [F:GCM]GENLEDTYP <> [F:GCM]ANALEDTYP Then
                Read [LED]LED0=[F:GCM]LED([F:GCM]ANALEDTYP-1)
                COA2=[F:LED]COA

                # OBTENER PLAN DE ANALÍTICO (LONGITUD CUENTAS)
                #needed? Read [COA2]COA0=COA2
            Else
                COA2=""
            Endif

            ACCDAT = mid$(SENTENCIA,28,8)
            MES    = mid$(ACCDAT,5,2)
            DES    = vireblc(mid$(SENTENCIA,36,30),2)

            If DES = "" Then
                Call OBTENER_DESCRIP_MES(MES,DES)
                DES = "Nómina"-DES
            Endif
            REF="NOMINA"
            BPRCUR=""

        Elsif CUR_TIPOLIN="D" Then   # ------------------ LINEAS APUNTES CONTABLES ----------------------------
            SNS=vireblc(mid$(SENTENCIA,59,2),2)
            DESLIN=DES
            AMTCUR=mid$(SENTENCIA,61,20)
            ACC=vireblc(mid$(SENTENCIA,9,10),2)

            # --- Verificar TERCERO
            BPR=mid$(ACC,5,4)
            If left$(ACC,2)="46" Then
               ACC=left$(ACC,3)+string$([F:COA1]ACCLEN-3,"0")

               #@#not yet
               If 0=1 and BPR <> "" and BPR<>"0000" Then
                   Read [BPR]BPR0=BPR
                   If fstat<>0 and left$(ACC,2) = "46" Then  # --- Existe el tercero ? ---
                       Call ECR_TRACE("TERCERO " + BPR + " INEXISTENTE",1) From GESECRAN
                       GERROR += 1
                   Endif
               Endif
               DESLIN = vireblc(DES - BPR,2)
            Else
               BPR=""
            Endif
            BPRCUR=BPR
            BPR=""  #@

            # --- Verificar CUENTA
            Read [GAC]GAC0=COA1;ACC
            If fstat<>0 Then  # --- Existe la cuenta ? ---
              Call ECR_TRACE( "CUENTA"-ACC-"INEXISTENTE",1) From GESECRAN
              GERROR += 1
            Endif
            If [F:GAC]SAC<>2 Then BPR="": Endif

            If ANT_TIPOLIN="G"  Then # --- Escribir Cabecera Asiento (despues de leer el primer apunte D !) #? ---
                 Wrseq "G"+CSEP+FCY+CSEP+'NOM'+CSEP+ACCDAT+CSEP+"NOMINA"+CSEP+REF+CSEP+DES Using [ESC]
            Endif

            # --- Escribir apunte contable SOCIAL ----
            LIN=LIN+1

            Wrseq "D"+CSEP+num$(LIN)+CSEP+num$([F:GCM]GENLEDTYP)+CSEP+ACC+CSEP+BPR+CSEP+SNS+CSEP+num$(val(AMTCUR))+CSEP+DESLIN Using [ESC]

            # --- Escribir apuntes ANALITICOS ---
            If COA2<>"" Then
                For I = 0 To [F:GAC]COANBR
                    If [F:GAC]OTHCOA(I)=COA2 Then
                        Wrseq "D"+CSEP+num$(LIN)+CSEP+num$([F:GCM]ANALEDTYP)+CSEP+[F:GAC]DEFACC(I)+CSEP+BPR+CSEP+SNS+CSEP+num$(val(AMTCUR))+CSEP+DESLIN Using [ESC]

                        #DSP = [F:CNA]DSP  # --- Hay Distribución (Reparto a priori) ---

                        CUR_TIPOLIN="d"
                    Endif
                Next
            Endif
            ANTACC=ACC

        Elsif CUR_TIPOLIN="A" Then
        # ---------------------------------------LINEAS SECCIONES ANALÍTICAS -----------------------
           If ANT_TIPOLIN = "d" or left$(ANTACC,2)="46" Then
              CCE(0)=vireblc(mid$(SENTENCIA,5,15),2)
              CCE(1)=vireblc(mid$(SENTENCIA,20,15),2)
              CCE(2)=vireblc(mid$(SENTENCIA,35,15),2)
              CCE(3)=vireblc(mid$(SENTENCIA,50,15),2)
              AMTCUR=mid$(SENTENCIA,80,20)

              If CCE(0)='' and ANT_TIPOLIN <> "d" Then
                  Call ECR_TRACE( "DEPARTAMENTO INEXISTENTE EN TRABAJADOR"-BPRCUR-" DE PLANTA FIN."-FCY,1) From GESECRAN
                  GERROR += 1
              Endif

              If ANT_TIPOLIN = "d" Then
                  Wrseq "A"+CSEP+"AX1"+CSEP+CCE(0)+CSEP+"AX2"+CSEP+CCE(1)+CSEP+"AX3"+CSEP+CCE(2)+CSEP+"AX4"+CSEP+CCE(3)+CSEP+num$(val(AMTCUR)) Using [ESC]
              Endif
              CUR_TIPOLIN=ANT_TIPOLIN
            Endif
        Endif

        ANT_TIPOLIN=CUR_TIPOLIN
    Wend

    Openo Using [ESC]
End

###########################################################################################
Subprog OBTENER_DESCRIP_MES(MES,DESCR)
    Value Char MES
    Variable Char DESCR

    Case MES
        When "01" : DESCR="Enero"
        When "02" : DESCR="Febrero"
        When "03" : DESCR="Marzo"
        When "04" : DESCR="Abril"
        When "05" : DESCR="Mayo"
        When "06" : DESCR="Junio"
        When "07" : DESCR="Julio"
        When "08" : DESCR="Agosto"
        When "09" : DESCR="Septiembre"
        When "10" : DESCR="Octubre"
        When "11" : DESCR="Noviembre"
        When "12" : DESCR="Diciembre"
        When Default : DESCR=""
    Endcase
End
######################################################################################


######################################################################################
## Funcion de llamada a un modelo de import / export
######################################################################################
Subprog IMPSILEN (MODELE,NOMFICH)
    Value Char MODELE
    Value Char NOMFICH
    If GERROR <> 0 : End : Endif

    If !clalev([F:AOE])   : Local File AOBJEXT    [AOE]  : Endif
    If !clalev([F:AOD])   : Local File AOBJEXTD   [AOD]  : Endif
    If !clalev([F:ZAOB])  : Local File AOBJET     [ZAOB] : Endif
    If !clalev([F:ADW])   : Local File ADOVAL     [ADW]  : Endif
    If !clalev([F:ZATY])  : Local File ATYPE      [ZATY] : Endif
    If !clalev([F:ZAMK])  : Local File AMSK       [ZAMK] : Endif
    If !clalev([F:ZAMZ])  : Local File AMSKZON    [ZAMZ] : Endif
    If !clalev([F:ZATB])  : Local File ATABLE     [ZATB] : Endif
    If !clalev([F:ZATZ])  : Local File ATABZON    [ZATZ] : Endif
    If !clalev([F:ZATI])  : Local File ATABIND    [ZATI] : Endif
    If !clalev([F:ZAFC])  : Local File AFONCTION  [ZAFC] : Endif
    If !clalev([F:APX])   : Local File APARIMPEXP [APX]  : Endif
    If !clalev([M:AOE0])  : Local Mask AOE0       [AOE0] : Endif
    If !clalev([M:AOE1])  : Local Mask AOE1       [AOE1] : Endif
    If !clalev([M:AOE2])  : Local Mask AOE2       [AOE2] : Endif
    If !clalev([M:IEX])   : Local Mask IMPTEST    [IEX]  : Endif
    If !clalev([M:DIA])   : Local Mask IMPENCH    [DIA]  : Endif
    If clalev([M:IMP2])=0 : Local Mask IMPOBJ2    [IMP2] : Endif
    Local Integer STAT : STAT = 0
    Local Char FICHIER(200) : FICHIER = filpath("BQR",NOMFICH,"")
    Local Char MESSAGE(100)

    Call IMPORTSIL(MODELE,FICHIER) From GIMPOBJ
    If GERRTRACE <> 0
        GYNUM=0
    Endif

End

######################################################################################
## Etiqueta añadida por el supervisor (pantalla ZNOMINA) 31/05/2013 13:05:18 (TRASP)
######################################################################################
Subprog C_TYPEXP(VALEUR)
Variable Integer VALEUR

    If GBATCH & VALEUR=1
     GMESSAGE = mess(163,141,1) : # Le poste client est inaccessible en batch
     mkstat = 2 : End
    Endif

End
######################################################################################
Subprog AM_TYPEXP(VALEUR)
Variable Integer VALEUR

  If VALEUR=1
     Grizo NOMIMP
  Else
     Actzo NOMIMP
  Endif
End
######################################################################################
Subprog C_NOMIMP(VALEUR)
Variable Char    VALEUR()

    Local Char NOMFIC(GDIMFIC)
    NOMFIC = VALEUR
    Gosub CONTFIC
    VALEUR = NOMFIC
End
######################################################################################
$CONTFIC
    Local Integer ER
    Local Char    REPERT(GDIMFIC)
    Local Char    MACHINE(GDIMFIC) , OS(GDIMFIC)

    If NOMFIC=""
        GMESSAGE = mess(35,126,1) : # Nom de fichier incorrect
        mkstat=1 : Return
    Elsif left$(NOMFIC,1)="#"
        GMESSAGE = mess(162,141,1) : # Le répertoire doit étre indiqué sur un serveur
        mkstat = 2 : Return
    Elsif instr(1,NOMFIC,"#")
        Return
    Endif
    Call MACHINE(NOMFIC,MACHINE,REPERT) From ORDSYS
    Call GET_OS(MACHINE,OS) From ORDSYS
    If OS=""
        GMESSAGE = MACHINE-mess(90,141,1) : # Machine inexistante
         mkstat = 2 : Return
    Elsif OS="unix"
        If pat(left$(REPERT,3),"!:\")
            GMESSAGE = mess(162,141,1) : # Le répertoire doit étre indiqué sur un serveur
            mkstat = 2 : Return
        Elsif left$(REPERT,1)="\"
            GMESSAGE = mess(147,141,1) : # Répertoire inaccessible
            mkstat = 2 : Return
        Endif
    Else
        If left$(REPERT,1)="/"
            GMESSAGE = mess(147,141,1) : # Répertoire inaccessible
            mkstat = 2 : Return
        Endif
    Endif
    Call EXISTE(NOMFIC,ER) From ORDSYS
    Case ER
        When 2
            GMESSAGE = mess(55,141,1) : # Ce fichier est un répertoire
            mkstat = 2 : Return
        When 0
            GMESSAGE = mess(03,141,1) : # Fichier á  importer inexistant
            mkstat = 2 : Return
    Endcase
Return
######################################################################################

