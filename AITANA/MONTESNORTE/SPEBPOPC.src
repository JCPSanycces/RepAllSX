######################################################################################
## Etiqueta añadida por el supervisor (pantalla YPSBPR) 26/07/2018 16:10:01 (ADMIN)
######################################################################################
Subprog AV_HAYCAPSOC(VALEUR)
Variable Integer VALEUR
    If !clalev([XCS]) : Local File XFGCS [XCS] : Endif

    Local Char M_CPY(5)
    Local Integer M_TIPOFCY
    Local Char M_TERCERO(20)
    Local Integer HAYCS : HAYCS=0

    If clalev([M:YPSR]) Then
        M_CPY=[M:YPSR]CPY(nolign-1)
        M_TIPOFCY=[M:YPSR]TIPOFCY(nolign-1)
        M_TERCERO=[M:BPR0]BPRNUM
    Endif

    If clalev([M:BPC0]) Then
        M_CPY=[M:YPSC]CPY(nolign-1)
        M_TIPOFCY=[M:YPSC]TIPOFCY(nolign-1)
        M_TERCERO=[M:BPC0]BPCNUM
    Endif

    If clalev([M:BPS0]) Then
        M_CPY=[M:YPSC]CPY(nolign-1)
        M_TIPOFCY=[M:YPSC]TIPOFCY(nolign-1)
        M_TERCERO=[M:BPS0]BPSNUM
    Endif


    Filter [XCS] Where CPY=M_CPY and BPRNUM=M_TERCERO and TIPOFCY=M_TIPOFCY
    If !fstat Then
        For [F:XCS]
            HAYCS+=1
        Next
    Endif
    Filter [XCS]

    If HAYCS Then
        VALEUR=2
    Else VALEUR=1
    Endif

End


