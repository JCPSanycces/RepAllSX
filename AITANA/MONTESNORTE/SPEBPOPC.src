    #XVT26/07/2018 permitir el mismo tipo de planta en diferentes sociedades

######################################################################################
Subprog C_CODITERREL(VALEUR)
    Variable Char    VALEUR()
    Local    Char    PANT_YTR
    Local    Integer ESTAT
    Local    Char    TERCERO

    TERCERO  = func YARBPOPC.CODI_TERCER()
    PANT_YTR = func YARBPOPC.CODI_PANT_YTR()

    Case GABREV
        When "BPC"
            Call UNICITE(VALEUR,[M:YTRC]CODITERREL) From OBJDIV
        When "BPS"
            Call UNICITE(VALEUR,[M:YTRP]CODITERREL) From OBJDIV
        When "BPR"
            Call UNICITE(VALEUR,[M:YTRT]CODITERREL) From OBJDIV
    Endcase

    If (VALEUR<>"")
        Call CONTROLAR_TERCERO_RELACION(evalue(PANT_YTR + "CLASETERCE(nolign-1)"), VALEUR, ESTAT) From YSELAGRO
        If ESTAT=0 Then
            GERR=1
            mkstat=2
        Endif
    Endif

    Read [YTR]YTR2 = VALEUR  : If fstat  Raz [F:YTR] : Endif
    If (fstat=0)
        If [F:YTR]BPRNUM <> TERCERO
            GERR =1
            GMESSAGE =mess(119,1986,1) - [F:YTR]BPRNUM
        Endif
    Endif
End
######################################################################################
Subprog AS_NBLIG
    Local    Integer PUNTER
    Local    Char    PANT_YPS

    PANT_YPS = func YARBPOPC.CODI_PANT_YPS()

    Assign (PANT_YPS + "OBSERVACIO(LINANT)") With evalue(PANT_YPS+"YOBS")
    Affzo [M]OBSERVACIO

    PUNTER = nolign - 1
    Assign (PANT_YPS + "YOBS") With evalue(PANT_YPS+"OBSERVACIO(PUNTER)")
    Assign (PANT_YPS + "LINANT") With PUNTER
    Affzo [M]YOBS
    Affzo [M]LINANT
End
#####################################################################################
Subprog AVANT_NBLIG
    ##---- Funcion de INSERTAR ----##
    Local    Char    PANT_YPS

    PANT_YPS = func YARBPOPC.CODI_PANT_YPS()

    If status = 73
        PUNTER = nolign - 1
        Assign (PANT_YPS + "OBSERVACIO(nolign-1)") With evalue(PANT_YPS+"YOBS")
        Affzo [M]         ###### [M:YPS0]5
        Raz [M]           ###### [M:YPS0]YOBS
        Assign (PANT_YPS + "LINANT") With nolign-1
        Affzo [M]         ###### [M:YPS0]10
    Endif

    ##---- Funcion de BORRAR ----##
    If status = 65
        PUNTER = nolign
        Assign (PANT_YPS + "YOBS") With evalue(PANT_YPS+"OBSERVACIO(PUNTER)")
        Assign (PANT_YPS + "LINANT") With PUNTER-1
        Affzo [M]        ###### [M:YPS0]10
        ##### Affzo [M:YPS0]5
    Endif
End
######################################################################################
Subprog C_TIPOFCY(VALEUR)
    Variable Integer VALEUR
    #XVT26/07/2018.bo
    #se permite crear registros con el mismo tipo de planta, ya que serán de sociedades distintas
    #Call UNICITE (VALEUR, [M]TIPOFCY) From OBJDIV
    #XVT26/07/2018.eo
End
######################################################################################
Subprog C_YTIPDOC(VALEUR)
Variable Char    VALEUR()

    If VALEUR="" Then : End : Endif
    If clalev([F:YTD])=0 : Local File YTIPDOC  [YTD] : Endif
    Read [YTD]YTD0=VALEUR
    If (fstat=0 and [F:YTD]CLASEDOCUM <> 7 or ([F:YTD]TIPOCLASE <> 1 and [F:YTD]TIPOCLASE <> 3))
        GERR=2
        GMESSAGE=mess(1,1986,1)
        GOK=0
        mkstat = 2
    Endif
End
