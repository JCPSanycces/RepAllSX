#<AdxTL>@(#)0.0.0.0 $Revision$ 
#<AdxTL>@(#)3.0.0.0 $Revision$
############################################################################################
# PUNTO DE ENTRADA DE FICMAG. MEJORAS FORMATEO DE NORMAS CSB.
###########################################################################################
#
#! ***** LAS VARIABLES QUE EMPIEZAN POR X PUEDEN SER UTILES PARA UTILIZARLAS EN LOS REG.BANCARIOS ******

############################################################################################
$ACTION
    Case ACTION
        When "OPENFILE"      : Gosub OPENFILE    ## MF 2009
        When "AV_LIGNE"      : Gosub AV_LIGNE    ## JG/MF 2007-08
        When Default
    Endcase
Return
############################################################################################

$OPENFILE  # --- INICIO LECTURA REG.BANCARIO --- 
# MF 2009
#
    If clalev([F:PLH])=0
      Local File PAYMENTH [PLH]  # --- Lectura sumatorio previo de PYHs s/remesa

      Local Decimal XTOTREM  # --- Total Remesa (suma a priori)
      XTOTREM = 0

      #--- SUMA PREVIA DEL TOTAL DE LA REMESA ---
      For [PLH] Where FRMFLG=1 & FRMNUM = [F:PYH]FRMNUM
         XTOTREM += [F:PLH]AMTCUR
      Next
    Endif

Return

$AV_LIGNE  # --- Lectura detalle PAYMENTHs 
# MF 2007-08
#
    If clalev([F:PLU])=0
      Local File PAYMENTD  [PLU]  # --- Lectura de PYDs ---

      # --- VARIABLES GENERALES UTILES PARA MODELOS REG.BAN ------------------------
      Local Integer XNUMPYH  # --- TOTAL PAYMENTHs
      Local Integer XNUMPYD  # --- TOTAL PAYMENTDs (PYHxPYD)
      Local Integer XNUMDPH  # --- N.PAYMENTDs POR PAYMENTH
      Local Integer MAXPYD   # --- N.Maximo de lineas (PYD) en un pago (PYH)
      XNUMPYH = 0
      XNUMPYD = 0
      MAXPYD = 500

      Local Char XCNC(40)(0..MAXPYD)  # --- ARRAY DE CONCEPTOS
      Local Integer XNUMCNC       # --- TOTAL CONCEPTOS
      XNUMCNC = 0

      Local Char DAT,FDAT

      Local File SINVOICE  [STA]  # --- Facturas de ventas (N19,N58 etc)
      Local File SINVOICED [STB]
      Local File SINVOICEV [STC]

      Local File PINVOICE  [PTA]  # --- Facturas de compras (N34,N68 etc)

      Local File GACCENTRY [SGC]  # --- Datos utilies para cobros/pagos vtos. porting saldos iniciales

      Local Char XFAC(15)(0..MAXPYD)  # --- ARRAY DE NUM.FACTURA
      Local Date XDAT(0..MAXPYD)      # --- ARRAY DE FECHAS FACTURA
      Local Char XREF(20)(0..MAXPYD)  # --- ARRAY DE REFERENCIAS (EJ. N.FACTURA PROVEEDOR)
      Local Decimal XIMP(0..MAXPYD)   # --- ARRAY DE IMPORTES PYD
      Local Integer XSNS(0..MAXPYD)   # --- ARRAY DE SIGNOS IMPORTES PYD

      Local Integer FCNCIMP  # --- Indica si el importe ha de ir concadenado en el concepto (por que cabe)

      #--- VARIABLES PARA NORMA 19F ------------------------------------------------
      Local Char NALB(20)
      Local Char ART(30)
      Local Char CANT
      Local Char PREC
      Local Char IMP
      Local Char IVA
      Local Char BAS
      Local Char IMPL

      # --- Variables UTILES para el modelo ---
      Local Integer XNUMOPC  # --- TOTAL LINEAS OPCIONALES
      Local Integer XNUMSID  # --- TOTAL LINEAS FACTURAS (SIHxSID)
      Local Integer XNUMDSH  # --- N.Lineas por current FACTURA
      XNUMOPC = 0
      XNUMSID = 0
      # --- End 19F ------------------------------------------------------
    Endif
    
    # --- Inicializacion de variables ------
    Raz XCNC
    Raz XFAC
    Raz XDAT
    Raz XREF

    XNUMPYH += 1   # --- CONTADOR DE PAYMENTHs DE LA REMESA ---
    XNUMDPH = 0    # --- Num. PYD current PYD
    XNUMDSH = 0    # --- Num. Lineas de factura current Factura
    # --- LECTURA LINEAS DE PAGO ---
    Filter [PLU] Where NUM=[F:PYH]NUM Order By Key CLE = NUM;LIN  # --- Filtro s/PYH ---
    
    For [PLU]CLE Where NUM=[F:PYH]NUM
      XNUMDPH += 1
      XNUMPYD += 1
      FCNCIMP = 1    # --- Por defecto, se concadena el importe en el concepto... (s/norma)

      # ---------------------------------------------------------------------------------------------------
      If pat([F:PYH]PAYTYP,'*19F') = 0 and [F:TFB]FILREF <> "9F" # --- VARIABLES UTILES PARA MODELOS REGBAN
      # ---------------------------------------------------------------------------------------------------

        # --- Array de 16 conceptos para desglosar Facturas agrupadas s/PYH ---
        XFAC(XNUMDPH-1) = [F:PLU]VCRNUM   # --- N.Documento indicado en el pago
        XCNC(XNUMDPH-1) = [F:PLU]VCRNUM   # --- Inicialización para concepto s/N.Documento. Se formatea luego
        XREF(XNUMDPH-1) = ""              # --- Referencia proveedor o de venta
        DAT = "" : FDAT = ""

        If [F:PLU]VCRNUM <> '' and [F:PLU]BPRINV <> '' and [F:PLU]IPTTYP = 3  # --- ES FACTURA ---

          If [F:PYH]SNS = 2  # --- Factura de CLIENTE ---
            Read [STA]SIH0 = [F:PLU]VCRNUM
            If fstat  # --- No existe: Vencimiento de porting ?
              Raz [F:STA]
              Read [SGC]HAE0 = [F:PLU]VCRTYP; [F:PLU]VCRNUM
              XCNC(XNUMDPH-1) = [F:SGC]DESVCR
              If XCNC(XNUMDPH-1) = "" : XCNC(XNUMDPH-1) = "N/F."+XCNC(XNUMDPH-1): Endif
            Else
              DAT = left$([F:STA]ACCDAT,10)
              Read [STC]SIV0 = [F:PLU]VCRNUM
              If fstat : Raz [F:STC] : Endif
              If [F:STC]INVREF<>""
                XREF(XNUMDPH-1) = [F:STC]INVREF
              Else If [F:STA]DES<>""
                  XCNC(XNUMDPH-1) = XCNC(XNUMDPH-1)-[F:STA]DES  # --- Añade una descripción de la factura
                Endif
              Endif
            Endif

          Else               # --- Factura de PROVEEDOR ---
            Read [PTA]PIH0 = [F:PLU]VCRNUM
            If fstat 
              Raz [F:PTA]
              Read [SGC]HAE0 = [F:PLU]VCRTYP; [F:PLU]VCRNUM
              XREF(XNUMDPH-1) = [F:SGC]BPRVCR
              DAT = left$([F:SGC]BPRDATVCR,10)
            Else
              DAT = left$([F:PTA]BPRDAT,10)
              XREF(XNUMDPH-1) = [F:PTA]BPRVCR
            Endif
            XCNC(XNUMDPH-1) = 'S/Fac.'+XREF(XNUMDPH-1)
            FCNCIMP = 0  # --- El importe no cabe en el concepto, no concadenar...
          Endif

        Elsif [F:PLU]VCRNUM = '' # --- ES ANTICIPO MANUAL ---
          XCNC(XNUMDPH-1) = "Anticipo"
          DAT = left$([F:PYH]ACCDAT,10)
        Endif

        If DAT <> "" and mid$(DAT,5,2) <> '00'  # ---FORMATEO FECHA ---
          XDAT(XNUMDPH-1) = DAT
          FDAT = mid$(DAT,7,2) + "/" + mid$(DAT,5,2) + "/"+ mid$(DAT,3,2)
        Endif
        XCNC(XNUMDPH-1) = XCNC(XNUMDPH-1) + " " + FDAT

        # --- FORMATEO IMPORTE ---
        If [F:PLU]AMTLIN2 >= 0
          XSNS(XNUMDPH-1) = 1
        Else
          XSNS(XNUMDPH-1) = -1
        Endif
        If FCNCIMP > 0
          XCNC(XNUMDPH-1) = XCNC(XNUMDPH-1) + "  " + num$([F:PLU]AMTLIN2)
          If [F:PLU]CURLIN <> 'EUR'
            XCNC(XNUMDPH-1) = XCNC(XNUMDPH-1) + " " + [F:PLU]CURLIN
          Endif
        Endif
        XIMP(XNUMDPH-1) = abs([F:PLU]AMTLIN2)
        XNUMCNC += XNUMCNC

      # ---------------------------------------------------------------------------------------------------
      Else #------------ Norma 19 RECIBO/FACTURA ----------------------------------------------------------
      # ---------------------------------------------------------------------------------------------------
        If [F:PLU]VCRNUM <> "" and XNUMDPH = 1  # -- Sólo si PYH con 1 PYD factura !
           Read [STA]SIH0 = [F:PLU]VCRNUM
           If fstat : Raz [F:STA] : Endif

           Read [STB]SID0 = [F:PLU]VCRNUM
           If fstat : Raz [F:STB] : Endif

           Read [STC]SIV0 = [F:PLU]VCRNUM
           If fstat : Raz [F:STC] : Endif

           GPOINT = "BEFORE_FOR": Gosub ENTREE From EXEFNC
           For [STB]SID0 Where NUM=[F:PLU]VCRNUM 
                XNUMDSH += 1   # --- LINEAS FACTURA ---
                XNUMSID += 1   # --- TOTAL LINEAS FACTURAS ---

                GPOINT = "AV_LIGNE": Gosub ENTREE From EXEFNC
           Next
           GPOINT = "AFTER_FOR": Gosub ENTREE From EXEFNC
        Endif  # --- END 9F ----------

        Break
      Endif

    Next
Return
############################################################################################
############################################################################################





