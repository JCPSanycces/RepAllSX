#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "SEL_TABLE"     : Gosub SEL_TABLE
 When Default
Endcase
Return

#########################################################################
#    CHOIX DANS LES TABLES                                              #
#########################################################################
$SEL_TABLE

  # ESTAS VARIABLES SON DIFERENTES EN OTROS DOSSIERES
  # SI LA SELECCIÓN NO DEVUELVE NADA, VERIFICAR QUE EL CÓDIGO DE LOS MENSAJES
  # CORRESPONDE CON LOS VALORES QUE MÁS ABAJO.

  Local Char LCODCON : LCODCON = '4' # conductor
  Local Char LCODMAT : LCODMAT = '5' # matricula
  Local Char LCODREM : LCODREM = '6' # REMOLQUE
Case TABLE
    When "SELZAIN"    : Gosub S_ZAIN
    When "SELZMAT"    : Gosub S_ZMAT
    When "SELZMATR"    : Gosub S_ZMATR
Endcase
Return


$S_ZAIN
If clalev([F:CNT])=0 : Local File CONTACT : Endif
If clalev([F:AIN])=0 : Local File CONTACTCRM : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   : Endif
Local Char CODFIC    : CODFIC = "CONTACT"

#Link [ITS] With [ITM]ITM0=[ITS]ITMREF As [KITS]

Link [CNT] With [AIN]AIN0=[CNT]CCNCRM As [ZAIN]
Default File [ZAIN]

ORDRE   = 'CNTNUM'
START   = 'CNTNUM'

CRITERE='[F:CNT]CNTFNC='+LCODCON+' and [F:CNT]BPANUM=[M]BPTNUM'
OBJET="ZAIN"

Return



$S_ZMAT
If clalev([F:CNT])=0 : Local File CONTACT : Endif
If clalev([F:AIN])=0 : Local File CONTACTCRM : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   : Endif
Local Char CODFIC    : CODFIC = "CONTACT"

#Link [ITS] With [ITM]ITM0=[ITS]ITMREF As [KITS]

Link [CNT] With [AIN]AIN0=[CNT]CCNCRM As [ZAIN]
Default File [ZAIN]

ORDRE   = 'CNTNUM'
START   = 'CNTNUM'

CRITERE='[F:CNT]CNTFNC='+LCODMAT+' and [F:CNT]BPANUM=[M]BPTNUM'
OBJET="ZAIN"

Return

$S_ZMATR
If clalev([F:CNT])=0 : Local File CONTACT : Endif
If clalev([F:AIN])=0 : Local File CONTACTCRM : Endif
If clalev([F:ATZ])=0 : Local File ATABZON   : Endif
Local Char CODFIC    : CODFIC = "CONTACT"

#Link [ITS] With [ITM]ITM0=[ITS]ITMREF As [KITS]

Link [CNT] With [AIN]AIN0=[CNT]CCNCRM As [ZAIN]
Default File [ZAIN]

ORDRE   = 'CNTNUM'
START   = 'CNTNUM'

CRITERE='[F:CNT]CNTFNC='+LCODREM+' and [F:CNT]BPANUM=[M]BPTNUM'
OBJET="ZAIN"

Return

