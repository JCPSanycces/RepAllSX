######################################################################################
### Programa que muestra pantalla de cambio para Ventas Directas     JGM 19/07/07  ###
######################################################################################
$ACTION
    Case ACTION
        When "OUVRE"             : Gosub OUVRE
        When "DEBUT"             : Gosub DEBUT
        When "OK"                : Gosub OK
        When Default
   Endcase
Return
######################################################################################
$OUVRE
    If clalev([F:ARD])<=0 : Local File AREPORTD  [ARD] : Endif  ## definicion parametros informes
   # If clalev([F:YRE])=0  : Local File YRELDOC   [YRE] : Endif
   # If clalev([F:YIP])=0  : Local File YTIPDOT   [YIP] : Endif
   # If clalev([F:YSLT])=0 : Local File SALTRS    [YSLT] : Endif
   # If clalev([F:AIA])=0  : Local File APRTAUS   [AIA] : Endif
   # If clalev([F:AIM])=0  : Local File APRINTER  [AIM] : Endif

    If GABREV = "SDH"
#        If clalev([F:YTV])=0 : Local File YTRSVENT  [YTV] : Endif
#        Read [YTV]YTV0 = 4;[F:SLT]STRNUM : If fstat Raz [F:YTV] : Endif
#        If [F:YTV]TPVTEST = 2
#            FIN = 0
#        Else
            FIN=1
#        Endif
    Elsif GABREV = "SIH"
        If [F:SLT]TRSFAM = "SUM"
                 FIN=0
            Else
                 FIN=1
        Endif
    Endif
Return
######################################################################################
$DEBUT
    Raz [M:YPV]

    If GABREV = "SDH"
###################################################
# Sumar las lineas              RPASC (18/01/2011)
###################################################
        Local Decimal ZIMPORTE
        Local Integer I
        Raz ZIMPORTE
        For I = 1 To [M:SDH1]NBLIG
            ZIMPORTE += ([M:SDH1]NETPRIATI(I-1) * [M:SDH1]QTY(I-1))
        Next
        Call ARRDEV (ZIMPORTE,[M:SDH1]CUR) From TRTDIV
        [M:YPV]IMPORTE = ZIMPORTE
###################################################
#        [M:YPV]IMPORTE = [M:SDH0]DLVATI

        Affzo [M:YPV]IMPORTE
        [M:YPV]PTE = [M:SDH2]PTE
        Affzo [M:YPV]PTE
    Elsif GABREV = "SIH"
        [M:YPV]IMPORTE = [M:SIHV]INVATI
        Affzo [M:YPV]IMPORTE
        [M:YPV]PTE = [M:SIH2]PTE
        Affzo [M:YPV]PTE
    Endif
Return
######################################################################################
$OK
Return
Local Char TBPAR(10)(1..50),TBVAL(30)(1..50),TICKET(20)
Local Shortint I
Local Char MISSATGE
Local Decimal ENTREGADO
Local Char DESTINO
Local Integer TIPO
Local Char TICKET

    #Forma de Pago
    If [M:YPV]PTE <> [M:SDH2]PTE

        If clalev([F:SDH])=0 : Local File SDELIVERY [SDH] : Endif
        Filter [SDH]
        Read [SDH]SDH0=[M:SDH0]SDHNUM
        If !fstat
           [F:SDH]PTE = [M:YPV]PTE
            Rewrite [SDH]
        Endif
    Endif

    Affzo [M:YPV]

    If [M:YPV]ENTREGADO = 0
        [M:YPV]ENTREGADO = [M:YPV]IMPORTE
        [M:YPV]CAMBIO = 0
        Affzo [M:YPV]ENTREGADO
        Affzo [M:YPV]CAMBIO
    Endif


    If [M:YPV]CAMBIO < 0
        Infbox "IMPORTE ENTREGADO INFERIOR AL TOTAL"
    Endif

    If clalev ([F:SLT])=0 Local File SALTRS [SLT] Endif
    Read [SLT]SLT0=4;GFLAG

    If ([F:SDH]NPRFLG = 2 & [F:SLT]NPRFLG = 2)
       Gosub SET_CLE From GOBJSUB
       CLECUR = 1
    Endif

