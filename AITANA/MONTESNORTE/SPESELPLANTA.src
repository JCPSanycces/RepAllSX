#<AdxTL>@(#)0.0.0.0 $Revision$
$ACTION
Case ACTION
 When "SEL_TABLE"     : Gosub SEL_TABLE
 When Default
Endcase
Return

#########################################################################
#    CHOIX DANS LES TABLES                                              #
#########################################################################
$SEL_TABLE
Case TABLE
    When "SELZPLANTA"    : Gosub S_ZPLANTA
Endcase
Return


$S_ZPLANTA
#SELECCIÓN PLANTA SEGÚN EL TIPO DE PLANTA

  ##TABLAS QUE PARTICIPARÁN EN LA SELECCIÓN
  If clalev([F:ZFCY])=0 : Local File FACILITY[ZFCY] : Endif

  ##PARA QUE LA SELECCIÓN FUNCIONE DESDE CUALQUIER PANTALLA, POR PARÁMETRO SE
  ##DEBERÁ PASAR EL CÓDIGO A FILTRAR
  Local Char ZCODI1 : ZCODI1=PARAM(1)

  #SI HAY QUE ENLAZAR LAS TABLAS, EL LINK SE HARÁ INDICANDO PRIMERO LA
  #TABLA SOBRE LA CUAL SE DESEA MOSTRAR LAS COLUMNAS, SIENDO EL RESTO DE TABLAS
  #LAS QUE SIRVEN COMO CRITERIO SOBRE LA PRIMERA
  Default File [ZFCY]

  ORDRE = "FCY"  #SE INDICA QUÉ COLUMNA VA A SERVIR DE ORDENACIÓN
  START = "FCY" #SE INDICA QUÉ COLUMNA SE DEVUELVE EN LA SELECCIÓN
  SENS =1
  DEFPAG = 5
  SIZCOL = 100
  SIZLIG = 150

  #APLICACIÓN DE LOS CRITERIOS SOBRE EL DEFAULT FILE, EN ESTE CASO EL LINK
  If GFONCTION="GESZPE"
    CRITERE='[F:ZFCY]YTIPOFCY=val(ZCODI1)'
  Endif

  TIT(0) = "Selección Planta"
  NBCOL = 0
  NBCOL +=1 : COL(NBCOL) = "FCY" : TIT(NBCOL)="Planta"
  NBCOL +=1 : COL(NBCOL) = "FCYNAM" : TIT(NBCOL)="Nombre"
Return

