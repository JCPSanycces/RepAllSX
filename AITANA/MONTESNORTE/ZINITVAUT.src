#<AdxTL>@(#)0.0.0.0 $Revision$ Inicialización variables asien
#####################################################################################################
# GETBPRVCR : Obtener el documento origen compras S/[PYD]VCRNUM para utilizar en asto.auto. de pagos
#####################################################################################################
Subprog GETBPRVCR(TYP,NUM,BPRVCR,STAT)
Value    Char TYP()
Value    Char NUM()
Variable Char BPRVCR()
Variable Integer STAT

    If clalev([F:LPIH])=0 : Local File PINVOICE [LPIH] : Endif

    Read [LPIH]=NUM
    If !fstat
        BPRVCR = "S/F."+[F:LPIH]BPRVCR
    Else
        BPRVCR = NUM
    Endif
    STAT= 0

Return




